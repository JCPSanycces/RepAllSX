#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################
$ACTION
Case ACTION
 When "AVANT_ENR" : Gosub AVANT_CRE_ENR   : # Bug 64296 
 When "AVANT_CRE" : Gosub AVANT_CRE_ENR   : # Bug 64296 
 When "ENR"       : Gosub CRE_ENR
 When "CRE"       : Gosub CRE_ENR
Endcase

Return

##############################################################
#--- Bug 64296 
$AVANT_CRE_ENR

If [M]LANCHP=2713
   If [M]LANNUM(0)<>1 | [M]CODE(0)<>"0" | [M]LANMES(0)<>""
      Call ERREUR(mess(95,187,1)) From GESECRAN
      FOK=0
      Return
   Endif
Endif
Return
#---

##############################################################
$CRE_ENR
#--- Bug 64296
If !find([M]LANCHP,2707,2713) : Return : Endif
#If [M]LANCHP<>2707 : Return : Endif
#---
# Maj du menu local 2713 à partir du 2707 ou l'inverse
If [M]MENLOCAL=2 & [M]NBLIG>0 & sum([M]CODE)="" : Return : Endif

If !clalev([F:AST8]) : Local File APLSTD  [AST8] : Endif
If !clalev([F:AML8]) : Local File AMENLOC [AML8] : Endif
Call DEBTRANS From GLOCK
 
$CRE_ENR_SUI
GOK=1 
Trbegin [AST8]

#--- Bug 64296
If [M]LANCHP=2707
   # Suppression des valeurs du menu local 2713
   Delete [AST8] Where LANCHP=2713
 
   For [AST]CLE Where LANCHP=[M]LANCHP 
     If [F:AST]LANNUM=0
       Read [AST8]CLE = 2713;[F:AST]LANNUM;[F:AST]LAN 
       [F:AST8]       = [F:AST]
       [F:AST8]LANCHP = 2713 
       [F:AST8]LANMES = "0"+[F:AST]LANMES 
       If fstat 
         Write [AST8]
       Else
         Rewrite [AST8] 
       Endif 
     Else
       Read [AST8]CLE = 2713;[F:AST]LANNUM+1;[F:AST]LAN 
       [F:AST8]       = [F:AST]
       [F:AST8]LANCHP = 2713 
       [F:AST8]LANNUM = [F:AST]LANNUM+1
       If fstat 
         Write [AST8]
         If !fstat & [F:AST]LANNUM=1
           [F:AST8] = [F:AST]
           [F:AST8]LANCHP = 2713 
           [F:AST8]LANMES = "" 
           Write [AST8]
         Endif
       Else
         Rewrite [AST8] 
       Endif
     Endif 
     If fstat 
       GOK=0 : Call FSTA("AST8") From GLOCK : Break 
     Endif 
   Next
#--- Bug 64296
Elsif [M]LANCHP=2713
   # Suppression des valeurs du menu local 2707
   Delete [AST8] Where LANCHP=2707
 
   For [AST]CLE Where LANCHP=[M]LANCHP 
     If [F:AST]LANNUM=0
       Read [AST8]CLE = 2707;[F:AST]LANNUM;[F:AST]LAN 
       [F:AST8]       = [F:AST]
       [F:AST8]LANCHP = 2707 
       [F:AST8]LANMES = right$([F:AST]LANMES,2) 
       If fstat 
         Write [AST8]
       Else
         Rewrite [AST8] 
       Endif 
     Elsif [F:AST]LANNUM>1
       Read [AST8]CLE = 2707;[F:AST]LANNUM-1;[F:AST]LAN 
       [F:AST8]       = [F:AST]
       [F:AST8]LANCHP = 2707 
       [F:AST8]LANNUM = [F:AST]LANNUM-1
       If fstat 
         Write [AST8]
       Else
         Rewrite [AST8] 
       Endif
     Endif 
     If fstat 
       GOK=0 : Call FSTA("AST8") From GLOCK : Break 
     Endif 
   Next
Endif
#---

If GOK<0   : Goto ROLL_TR1 
Elsif !GOK : Goto AB_TR1 
Endif 

Gosub TIT
If GOK<0   : Goto ROLL_TR1  
Elsif !GOK : Goto AB_TR1  
Endif 
Gosub MENLOC
If GOK<0   : Goto ROLL_TR1  
Elsif !GOK : Goto AB_TR1  
Endif

Commit 

Close Local File [AST8]
Close Local File [AML8]

Return

$AB_TR1 
Rollback 
Return 
 
$ROLL_TR1 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto CRE_ENR_SUI : Endif 

$MENLOC
#--- Bug 64296
If [M]LANCHP=2707
   Readlock [AML8]MENLOC = 2713
   If fstat
     Raz [F:AML8]
     [F:AML8] = [M]
     [F:AML8]MENLOC = 2713  
     [F:AML8]AUZMOD = 1  
     If [F:AML8]MAXI<>0 : [F:AML8]MAXI+=1 : Endif  
     #--- Bug 67789
     If [F:AML8]MINI<>0 : [F:AML8]MINI+=1 : Endif
     #---
     [F:AML8]CREDAT = date$ 
     [F:AML8]CREUSR = GUSER 
     [F:AML8]CRETIM = time
     Write [AML8]
     #--- Bug 67789
     #If fstat 
     #  GOK = 0 : Call FSTA("AML8") From GLOCK  
     #Endif
   #Endif
   Else
     If [M]MAXI<>0 : [F:AML8]MAXI=[M]MAXI+1 : Endif  
     If [M]MINI<>0 : [F:AML8]MINI=[M]MINI+1 : Endif
     Rewrite [AML8] 
   Endif
   If fstat 
     GOK = 0 : Call FSTA("AML8") From GLOCK  
   Endif
   #---
#--- Bug 64296
Elsif [M]LANCHP=2713
   Readlock [AML8]MENLOC = 2707
   If fstat
     Raz [F:AML8]
     [F:AML8] = [M]
     [F:AML8]MENLOC = 2707  
     [F:AML8]AUZMOD = 1  
     #--- Bug 67789
     #If [F:AML8]MAXI<>0 : [F:AML8]MAXI+=1 : Endif  
     If [F:AML8]MAXI<>0 : [F:AML8]MAXI-=1 : Endif
     If [F:AML8]MINI<>0 : [F:AML8]MINI-=1 : Endif  
     #---
     [F:AML8]CREDAT = date$ 
     [F:AML8]CREUSR = GUSER 
     [F:AML8]CRETIM = time
     Write [AML8]
     #--- Bug 67789
     #If fstat 
     #  GOK = 0 : Call FSTA("AML8") From GLOCK  
     #Endif
   #Endif
   Else
     If [M]MAXI<>0 : [F:AML8]MAXI=[M]MAXI-1 : Endif  
     If [M]MINI<>0 : [F:AML8]MINI=[M]MINI-1 : Endif
     Rewrite [AML8] 
   Endif
   If fstat 
     GOK = 0 : Call FSTA("AML8") From GLOCK  
   Endif
   #---
Endif
#---
Return

$TIT 
#--- Bug 64296
If [M]LANCHP=2707
   For [AST]CLE Where LANCHP=200 & LANNUM=2507 
     Read [AST8]CLE = 200;2513;[F:AST]LAN 
     [F:AST8]       = [F:AST]
     [F:AST8]LANNUM = 2513 
     If fstat 
       Write [AST8]
     Else
       Rewrite [AST8] 
     Endif 
     If fstat 
       GOK=0 : Call FSTA("AST8") From GLOCK : Break 
     Endif 
   Next
#--- Bug 64296
Elsif [M]LANCHP=2713
   For [AST]CLE Where LANCHP=200 & LANNUM=2513 
     Read [AST8]CLE = 200;2507;[F:AST]LAN 
     [F:AST8]       = [F:AST]
     [F:AST8]LANNUM = 2507 
     If fstat 
       Write [AST8]
     Else
       Rewrite [AST8] 
     Endif 
     If fstat 
       GOK=0 : Call FSTA("AST8") From GLOCK : Break 
     Endif 
   Next
Endif
#---
Return

