#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(20)(1..3) , VALEUR(10)
PARAM(1) = "000000000000005"
PARAM(2) = ""
PARAM(3) = "6"
Call TRAITE_CHAR(VALEUR,PARAM,"","MATPCA","MATPCA",4,"") From GTRAITE
End

#########################################
## Traitement des actions : MATPCA
#########################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "END"        : Kill GNIVEAU : FIN = 1
Endcase
Return

#############################################
$OUVRE
If clalev ([F:PCA])=0   : Local File CAISSE    [PCA]  : Endif
If clalev ([F:ORG])=0   : Local File ORGANISME [ORG]  : Endif
If clalev ([F:ID])=0    : Local File EMPLOID   [ID]   : Endif
If clalev ([F:HRCTR])=0 : Local File EMPLOCTR  [HRCTR]: Endif
If clalev ([F:ORA])=0   : Local File ORGAFFIL  [ORA]  : Endif

Local Integer J, JJ, I
Global Integer GNIVEAU
Return

#############################################
$DEBUT
Raz [M:MPCA]
[M:MPCA]EMP=PARAM(1)
Read [F:ID]ID0=[M:MPCA]EMP
[M:MPCA]NAM =[F:ID]NAM - [F:ID]SRN

If [F:ID]FLGMULCTR<>2
 Grizo[M:MPCA]CTRNUM
Else
 Actzo[M:MPCA]CTRNUM
Endif

If PARAM(2)<>""
 [M:MPCA]CTRNUM=PARAM(2)
 Call CHERCHE([M:MPCA]EMP,[M:MPCA]CTRNUM)
Else
#JOJAC - 2016-08-12 - X3PEOP-975 - START
 #JOJAC - 2016-09-12 - X3PEOP-975 - START
 #If [F:ID]FLGMULCTR<>2
 #JOJAC - 2016-08-12 - X3PEOP-975 - END
#JOJAC - 2016-08-12 - X3PEOP-975 - END
  Call CHERCHE_CTR([M:MPCA]EMP,datesyst,[M:MPCA]CTRNUM) From DIVPAYE
  Call CHERCHE([M:MPCA]EMP,[M:MPCA]CTRNUM)
#JOJAC - 2016-08-12 - X3PEOP-975 - START
 #Endif
#JOJAC - 2016-08-12 - X3PEOP-975 - START
Endif
GNIVEAU=val(PARAM(3))
Affzo EMP,NAM,CTRNUM

#Setmok [M:MPCA] With 0
Return

####################
Subprog CHERCHE(EMP,CTR)
Value Char EMP ()
Value Char CTR ()
Local Integer I
Local Char LSTORG
Local Integer NBRORG

Call PARAM (GCURLEG,"NBCAISTD",LSTORG) From ADOVAL
NBRORG=val(LSTORG)
Raz LSTORG
Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL
Effzo [M:MPCA]10-15
#Filter [HRCTR] Where REFNUM=EMP & CTRNUM=CTR & CTRDAT<=datesyst
Filter [HRCTR] Where REFNUM=EMP & CTRNUM=CTR
Read [HRCTR]CTR1 Last
Filter [HRCTR]

If !fstat
 nolign=1

#JOJAC - 2016-09-14 - X3PEOP-741 - START
#For I=1 To NBRORG
I=0
 #For [ADI] Where NUMTAB = 10469 and LEG = GCURLEG and ENAFLG = 2
For [ADI] Where NUMTAB=10469 and LEG=GCURLEG and ENAFLG=2 and N1=1
#JASMI - 2017-09-14 - X3-49836 - END
  I+=1
  #If I > len(mess(0,val(LSTORG),1))
#JASMI - 2017-09-13 - X3-49836 - START
#  If I > NBRORG
#    Break
#  Endif
#JASMI - 2017-09-13 - X3-49836 - END
#JOJAC - 2016-09-14 - X3PEOP-741 - END
  Call ORGANISME_LEV([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[M:MPCA]ORG(nolign-1),I-1,[M:MPCA]LEV(nolign-1) ) From SUBORG
#LIPET - 2018-08-03 - X3-103478 - START
#JASMI - 2017-09-13 - X3-49836 - START
 # [M:MPCA]CAI(nolign-1) = I
  [M:MPCA]CAIBAK(nolign-1) = I
  [M:MPCA]CAI(nolign-1) = [ADI]CODE
#JASMI - 2017-09-13 - X3-49836 - END
#LIPET - 2018-08-03 - X3-103478 - END
  Affzo [M:MPCA]10-15
  #JOJAC - 2016-09-14 - START
  #[M:MPCA]CAIVAL(nolign-1) = mess(I,val(LSTORG),1)
#JASMI - 2017-09-14 - X3-49836 - START
#  [M:MPCA]CAIVAL(nolign-1) = [ADI]CODE
#  Call LECTEXTRA([M:MPCA]CAIVAL(nolign-1),"ATABDIV","LNGDES","10469",[F:ADI]CODE) From ATEXTRA
#JASMI - 2017-09-14 - X3-49836 - END
  #JOJAC - 2016-09-14 - END
  If [M:MPCA]ORG(nolign-1)<>""
   Call ORGAFFIL_LEV ([M:MPCA]ORG(nolign-1),[F:HRCTR]ETRFCY,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[M:MPCA]NUMAFF(nolign-1),
&                    [M:MPCA]NUMCTR(nolign-1),[M:MPCA]LEVAFF (nolign-1)) From SUBORA
   If  [M:MPCA]NUMAFF(nolign-1)<>""
    Call ORGPRV ([M:MPCA]ORG(nolign-1),[F:HRCTR]ETRFCY,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[M:MPCA]CODOPT(nolign-1),[M:MPCA]CODPOP(nolign-1)) From SUBORA
   Endif
  Endif
  nolign+=1

Next
[M:MPCA]TBL=nolign-1

nolign=1

#JASMI - 2017-09-14 - X3-49836 - START
#For I=NBRORG+1 To len(mess(0,val(LSTORG),1))
For [ADI] Where NUMTAB = 10469 and LEG = GCURLEG and ENAFLG = 2 and N1=2
  I+=1
#JASMI - 2017-09-14 - X3-49836 - END
  Call ORGANISME_LEV([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[M:MPCA]ORG2(nolign-1),I-1,[M:MPCA]LEV2(nolign-1)) From SUBORG
#JASMI - 2017-09-14 - X3-49836 - START
#  [M:MPCA]CAI2(nolign-1) = I
#  [M:MPCA]CAIVAL2(nolign-1) = mess(I,val(LSTORG),1)
  [M:MPCA]CAI2(nolign-1) = [ADI]CODE
#JASMI - 2017-09-14 - X3-49836 - START
  If [M:MPCA]ORG2(nolign-1)<>""
    Call ORGAFFIL_LEV ([M:MPCA]ORG2(nolign-1),[F:HRCTR]ETRFCY,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[M:MPCA]NUMAFF2(nolign-1),
&                    [M:MPCA]NUMCTR2(nolign-1),[M:MPCA]LEVAFF2(nolign-1)) From SUBORA
  If [M:MPCA]NUMAFF2(nolign-1)<>""
    Call ORGPRV ([M:MPCA]ORG2(nolign-1),[F:HRCTR]ETRFCY,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[M:MPCA]CODOPT2(nolign-1),[M:MPCA]CODPOP2(nolign-1)) From SUBORA
   Endif
  Endif
  nolign+=1
 Next
 [M:MPCA]TBL2=nolign-1
Endif

Affzo [M:MPCA]10-15
End

#############################################
$OK
Call DEBTRANS From GLOCK
Trbegin [PCA]
Gosub TR1
If !GOK : Gosub AB_TR1 : Return : Endif
Commit
Return

#############################################
$TR1
GOK=1
# Traitement des caisses de cotisations affectées à un contrat
For nolign=1 To [M:MPCA]TBL
 If [M:MPCA]LEV(nolign-1)>=GNIVEAU    :# lignes éventellement modifiées
  If [M:MPCA]ORG(nolign-1)=""
   Gosub DEL_ORA
   If !GOK : Break : Return : Endif
  Else
   Gosub TR_ORA
   If !GOK : Break : Return : Endif
  Endif
#LIPET - 2018-08-03 - X3-103478 - START
#  If [M:MPCA]LEV(nolign-1)=6
#   Read [PCA]PCA0=6;GCURLEG;"";"";"";"";[M:MPCA]CTRNUM
#  Else
#   Read [PCA]PCA0=5;GCURLEG;"";"";"";[M:MPCA]EMP;""
#  Endif
  If [M:MPCA]LEV(nolign-1)=6
   Read [PCA]PCA0=6;"";"";"";"";"";[M:MPCA]CTRNUM
  Else
   Read [PCA]PCA0=5;"";"";"";"";[M:MPCA]EMP;""
  Endif
#LIPET - 2018-08-03 - X3-103478 - END
  If fstat=5 & [M:MPCA]ORG(nolign-1)<>""
   Raz [F:PCA]
   [F:PCA]LEV =[M:MPCA]LEV(nolign-1)
   If [M:MPCA]LEV(nolign-1)=6
    [F:PCA]CTR = [M:MPCA]CTRNUM
    [F:PCA]EMP = ""
   Else
    [F:PCA]CTR = ""
    [F:PCA]EMP = [M:MPCA]EMP
   Endif
#LIPET - 2018-08-03 - X3-103478 - START
#JASMI - 2017-09-14 - X3-49836 - START
   [F:PCA]ORG([M:MPCA]CAIBAK(nolign-1)-1) = [M:MPCA]ORG(nolign-1)
#   [F:PCA]ORG(nolign-1) = [M:MPCA]ORG(nolign-1)
#JASMI - 2017-09-14 - X3-49836 - END
#LIPET - 2018-08-03 - X3-103478 - END
   If dim([F:PCA]CREDAT)>0 : [F:PCA]CREDAT = date$ : Endif
   If dim([F:PCA]CREUSR)>0 : [F:PCA]CREUSR = GUSER : Endif
   If dim([F:PCA]CRETIM)>0 : [F:PCA]CRETIM = time  : Endif
   Write [F:PCA]
  Elsif !fstat
#LIPET - 2018-08-03 - X3-103478 - START
#JASMI - 2017-09-14 - X3-49836 - START
  # [F:PCA]ORG([M:MPCA]CAI(nolign-1)-1)=[M:MPCA]ORG(nolign-1)
  [F:PCA]ORG([M:MPCA]CAIBAK(nolign-1)-1)=[M:MPCA]ORG(nolign-1)
   #[F:PCA]ORG(nolign-1)=[M:MPCA]ORG(nolign-1)
#JASMI - 2017-09-14 - X3-49836 - END
#LIPET - 2018-08-03 - X3-103478 - END
   If dim([F:PCA]UPDDAT)>0 : [F:PCA]UPDDAT = date$ : Endif
   If dim([F:PCA]UPDUSR)>0 : [F:PCA]UPDUSR = GUSER : Endif
   If dim([F:PCA]UPDTIM)>0 : [F:PCA]UPDTIM = time  : Endif
   Rewrite [F:PCA]
  Endif
  If fstat<>0
   GOK = 0 : Call FSTA("PCA") From GLOCK : Break
  Endif
 Endif
Next

# Traitement des autres caisses affectées à un contrat
For nolign=1 To [M:MPCA]TBL2
 If [M:MPCA]LEV2(nolign-1)>=GNIVEAU    :# lignes éventellement modifiées
  If [M:MPCA]ORG2(nolign-1)=""
   Gosub DEL_ORA2
   If !GOK : Break : Return : Endif
  Else
   Gosub TR_ORA2
   If !GOK : Break : Return : Endif
  Endif

  If [M:MPCA]LEV2(nolign-1)=6
   Read [PCA]PCA0=6;"";"";"";"";"";[M:MPCA]CTRNUM
  Else
   Read [PCA]PCA0=5;"";"";"";"";[M:MPCA]EMP;""
  Endif

  If fstat=5 & [M:MPCA]ORG2(nolign-1)<>""
   Raz [F:PCA]
   [F:PCA]LEV = [M:MPCA]LEV2(nolign-1)
   If [M:MPCA]LEV2(nolign-1)=6
    [F:PCA]CTR = [M:MPCA]CTRNUM
    [F:PCA]EMP = ""
   Else
    [F:PCA]CTR = ""
    [F:PCA]EMP = [M:MPCA]EMP
   Endif
#JASMI - 2017-09-14 - X3-49836 - START
#   [F:PCA]ORG([M:MPCA]CAI2(nolign-1)-1) = [M:MPCA]ORG2(nolign-1)
   [F:PCA]ORG(nolign-1) = [M:MPCA]ORG2(nolign-1)
#JASMI - 2017-09-14 - X3-49836 - END
   If dim([F:PCA]CREDAT)>0 : [F:PCA]CREDAT = date$ : Endif
   If dim([F:PCA]CREUSR)>0 : [F:PCA]CREUSR = GUSER : Endif
   If dim([F:PCA]CRETIM)>0 : [F:PCA]CRETIM = time  : Endif
   Write [F:PCA]
  Elsif !fstat
#JASMI - 2017-09-14 - X3-49836 - START
#   [F:PCA]ORG([M:MPCA]CAI2(nolign-1)-1)=[M:MPCA]ORG2(nolign-1)
   [F:PCA]ORG(nolign-1)=[M:MPCA]ORG2(nolign-1)
#JASMI - 2017-09-14 - X3-49836 - END
   If dim([F:PCA]UPDDAT)>0 : [F:PCA]UPDDAT = date$ : Endif
   If dim([F:PCA]UPDUSR)>0 : [F:PCA]UPDUSR = GUSER : Endif
   If dim([F:PCA]UPDTIM)>0 : [F:PCA]UPDTIM = time  : Endif
   Rewrite [F:PCA]
  Endif
  If fstat<>0
   GOK = 0 : Call FSTA("PCA") From GLOCK : Break
  Endif
 Endif
Next

If GOK=0 : Return : Endif

Return

#############################################
AB_TR1
Rollback
GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

#############################################
$DEL_ORA
If [M:MPCA]LEVAFF(nolign-1)=6
 Delete [F:ORA] Where LEV=6 & CTRNUM=[M:MPCA]CTRNUM
Else
 Delete [F:ORA] Where LEV=5 & REFNUM=[M:MPCA]EMP
Endif
Return

#############################################
$TR_ORA
#LIPET - 2018-08-03 - X3-103478 - START
#If [M:MPCA]LEVAFF(nolign-1)=6
# Read [ORA]ORA0=6;"";"";"";"";[M:MPCA]CTRNUM;GCURLEG;[M:MPCA]ORG(nolign-1)
#Else
# Read [ORA]ORA0=5;"";"";"";[M:MPCA]EMP;"";GCURLEG;[M:MPCA]ORG(nolign-1)
#Endif
If [M:MPCA]LEVAFF(nolign-1)=6
 Read [ORA]ORA0=6;"";"";"";"";[M:MPCA]CTRNUM;"";[M:MPCA]ORG(nolign-1)
Else
 Read [ORA]ORA0=5;"";"";"";[M:MPCA]EMP;"";"";[M:MPCA]ORG(nolign-1)
Endif
#LIPET - 2018-08-03 - X3-103478 - END
If fstat=5
 Raz [F:ORA]
 [F:ORA]LEV =[M:MPCA]LEVAFF(nolign-1)
 If [M:MPCA]LEVAFF(nolign-1)=6
  [F:ORA]CTR = [M:MPCA]CTRNUM
  [F:ORA]REFNUM = ""
 Else
  [F:ORA]CTR = ""
  [F:ORA]REFNUM = [M:MPCA]EMP
 Endif
 [F:ORA]ORG    = [M:MPCA]ORG(nolign-1)
 [F:ORA]NUMAFF = [M:MPCA]NUMAFF(nolign-1)
 [F:ORA]NUMCTR = [M:MPCA]NUMCTR(nolign-1)
 [F:ORA]CODOPT = [M:MPCA]CODOPT(nolign-1)
 [F:ORA]CODPOP = [M:MPCA]CODPOP(nolign-1)
 If dim([F:ORA]CREDAT)>0 : [F:ORA]CREDAT = date$ : Endif
 If dim([F:ORA]CREUSR)>0 : [F:ORA]CREUSR = GUSER : Endif
 If dim([F:ORA]CRETIM)>0 : [F:ORA]CRETIM = time  : Endif
 Write [F:ORA]
Elsif !fstat
 [F:ORA]NUMAFF = [M:MPCA]NUMAFF(nolign-1)
 [F:ORA]NUMCTR = [M:MPCA]NUMCTR(nolign-1)
 [F:ORA]CODOPT = [M:MPCA]CODOPT(nolign-1)
 [F:ORA]CODPOP = [M:MPCA]CODPOP(nolign-1)
 If dim([F:ORA]UPDDAT)>0 : [F:ORA]UPDDAT = date$ : Endif
 If dim([F:ORA]UPDUSR)>0 : [F:ORA]UPDUSR = GUSER : Endif
 If dim([F:ORA]UPDTIM)>0 : [F:ORA]UPDTIM = time  : Endif
 Rewrite [F:ORA]
Endif
Return

#############################################
$DEL_ORA2
If [M:MPCA]LEVAFF2(nolign-1)=6
 Delete [F:ORA] Where LEV=6 & CTRNUM=[M:MPCA]CTRNUM
Else
 Delete [F:ORA] Where LEV=5 & REFNUM=[M:MPCA]EMP
Endif
Return

#############################################
$TR_ORA2
#LIPET - 2018-08-03 - X3-103478 - START
#If [M:MPCA]LEVAFF2(nolign-1)=6
# Read [ORA]ORA0=6;"";"";"";"";[M:MPCA]CTRNUM;GCURLEG;[M:MPCA]ORG2(nolign-1)
#Else
# Read [ORA]ORA0=5;"";"";"";[M:MPCA]EMP;"";GCURLEG;[M:MPCA]ORG2(nolign-1)
#Endif
If [M:MPCA]LEVAFF2(nolign-1)=6
 Read [ORA]ORA0=6;"";"";"";"";[M:MPCA]CTRNUM;"";[M:MPCA]ORG2(nolign-1)
Else
 Read [ORA]ORA0=5;"";"";"";[M:MPCA]EMP;"";"";[M:MPCA]ORG2(nolign-1)
Endif
#LIPET - 2018-08-03 - X3-103478 - END
If fstat=5
 Raz [F:ORA]
 [F:ORA]LEV =[M:MPCA]LEVAFF2(nolign-1)
 If [M:MPCA]LEVAFF2(nolign-1)=6
  [F:ORA]CTR = [M:MPCA]CTRNUM
  [F:ORA]REFNUM = ""
 Else
  [F:ORA]CTR = ""
  [F:ORA]REFNUM = [M:MPCA]EMP
 Endif
 [F:ORA]ORG    = [M:MPCA]ORG2(nolign-1)
 [F:ORA]NUMAFF = [M:MPCA]NUMAFF2(nolign-1)
 [F:ORA]NUMCTR = [M:MPCA]NUMCTR2(nolign-1)
 [F:ORA]CODOPT = [M:MPCA]CODOPT2(nolign-1)
 [F:ORA]CODPOP = [M:MPCA]CODPOP2(nolign-1)
 If dim([F:ORA]CREDAT)>0 : [F:ORA]CREDAT = date$ : Endif
 If dim([F:ORA]CREUSR)>0 : [F:ORA]CREUSR = GUSER : Endif
 If dim([F:ORA]CRETIM)>0 : [F:ORA]CRETIM = time  : Endif
 Write [F:ORA]
Elsif !fstat
 [F:ORA]NUMAFF = [M:MPCA]NUMAFF2(nolign-1)
 [F:ORA]NUMCTR = [M:MPCA]NUMCTR2(nolign-1)
 [F:ORA]CODOPT = [M:MPCA]CODOPT2(nolign-1)
 [F:ORA]CODPOP = [M:MPCA]CODPOP2(nolign-1)
 If dim([F:ORA]UPDDAT)>0 : [F:ORA]UPDDAT = date$ : Endif
 If dim([F:ORA]UPDUSR)>0 : [F:ORA]UPDUSR = GUSER : Endif
 If dim([F:ORA]UPDTIM)>0 : [F:ORA]UPDTIM = time  : Endif
 Rewrite [F:ORA]
Endif
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran MATPCA) 04/10/2010 10:57:16 (DBA)
######################################################################################

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call SELCTR([M:MPCA]EMP,datesyst,datesyst,VALEUR) From DIVPAYE
Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call CHERCHE ([M:MPCA]EMP,VALEUR)
End


Subprog AM_ORG(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEV
End

Subprog AM_NUMAFF(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF
End

Subprog AM_NUMCTR(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF
End

Subprog AM_CODOPT(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF
End

Subprog AM_CODPOP(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF
End

Subprog AM_ORG2(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEV2
End

$CHGLEV
If [M:MPCA]LEV(nolign-1)<GNIVEAU
 [M:MPCA]LEV(nolign-1)=GNIVEAU
Endif
Affzo [M:MPCA]LEV(nolign-1)
Return

$CHGLEV2
If[M:MPCA]LEV2(nolign-1)<GNIVEAU
 [M:MPCA]LEV2(nolign-1)=GNIVEAU
Endif
Affzo [M:MPCA]LEV2(nolign-1)
Return

Subprog AS_NUMAFF(VALEUR)
Variable Char    VALEUR()

If [M:MPCA]ORG(nolign-1)="" : mkstat=1 : End : Endif
End

#Urssaf & Pole emploi interdit
Subprog AS_NUMCTR(VALEUR)
Variable Char    VALEUR()
#JASMI - 2017-09-14 - X3-49836 - START
#If [M:MPCA]CAI(nolign-1)<3 | [M:MPCA]ORG(nolign-1)="" : mkstat=1 : End : Endif
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  If [M:MPCA]CAI(nolign-1)<3 | [M:MPCA]ORG(nolign-1)="" : mkstat=1 : End : Endif
Endif
#JASMI - 2017-09-14 - X3-49836 - END
End

#V08R09 : Prévoyance only
Subprog AS_CODOPT(VALEUR)
Variable Char    VALEUR()
#JASMI - 2017-09-14 - X3-49836 - START
#If [M:MPCA]CAI(nolign-1)<>3  | [M:MPCA]ORG(nolign-1)="" : mkstat=1 : End : Endif
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  If [M:MPCA]CAI(nolign-1)<>3  | [M:MPCA]ORG(nolign-1)="" : mkstat=1 : End : Endif
Endif
#JASMI - 2017-09-14 - X3-49836 - END
End

#V08R09 : Prévoyance only
Subprog AS_CODPOP(VALEUR)
Variable Char    VALEUR()
#JASMI - 2017-09-14 - X3-49836 - START
#If [M:MPCA]CAI(nolign-1)<>3 | [M:MPCA]ORG(nolign-1)=""   : mkstat=1 : End : Endif
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  If [M:MPCA]CAI(nolign-1)<>3 | [M:MPCA]ORG(nolign-1)=""   : mkstat=1 : End : Endif
Endif
#JASMI - 2017-09-14 - X3-49836 - END
End

Subprog AM_NUMAFF2(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF2
End

Subprog AM_NUMCTR2(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF2
End

Subprog AM_CODOPT2(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF2
End

Subprog AM_CODPOP2(VALEUR)
Variable Char    VALEUR()
Gosub CHGLEVAFF2
End

$CHGLEVAFF
If [M:MPCA]LEVAFF(nolign-1)<[M:MPCA]LEV(nolign-1)
 [M:MPCA]LEVAFF(nolign-1)=[M:MPCA]LEV(nolign-1)
Endif
Affzo [M:MPCA]LEVAFF(nolign-1)
Return

$CHGLEVAFF2
If[M:MPCA]LEVAFF2(nolign-1)<[M:MPCA]LEV2(nolign-1)
 [M:MPCA]LEVAFF2(nolign-1)=[M:MPCA]LEV2(nolign-1)
Endif
Affzo [M:MPCA]LEVAFF2(nolign-1)
Return

Subprog AS_NUMAFF2(VALEUR)
Variable Char    VALEUR()
If [M:MPCA]ORG2(nolign-1)="" : mkstat=1 : End : Endif
End

