#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# TRTACHTAR1          Traitements liés aux tarifs             Module ACHAT #
#              (Tout ce qui touche aux fichiers tarif )                    #
# ------------------------------------------------------------------------ #
# Sous-programmes :                                                        #
#   - RECH_TARIF : Recherche tarif achat                                   #
#   - TAR_GROUPE : Traitement tarifs groupés                               #
############################################################################


############################################################################
# RECH_TARIF : S/P de recherche tarif achat                   MBT 12/01/98 #
#              Alimentation du fichier lien PPRICSTRUCT                    #
#              Lecture des fichiers servant à la recherche                 #
#              Recherche tarif et chargement de la classe [M]              #
#              Calcul du prix net                                          #
# ------------------------------------------------------------------------ #
# Subprog RECH_TARIF (TRAIT,NOL)                                           #
#   TRAIT : Code traitement PSH = Recherche depuis demandes achats         #
#                           PSM = Recherche depuis gestion auto DA         #
#                           POH = Recherche depuis cdes standards          #
#                           POM = Recherche depuis gestion auto cdes stds  #
#                           POI = Recherche depuis cdes / articles         #
#                           POC = Recherche depuis cdes ouvertes           #
#                           POV = Recherche depuis cdes ouv. (valo contrat)#
#                           POD = Recherche depuis demandes livr.          #
#                           PTH = Recherche depuis rcp directes            #
#                           PNH = Recherche depuis retours sans rcp        #
#                           PMG = Recherche depuis les plans (valo contrat)#
#                           PSCM = Recherche écran EO/matière              #
#                           PSCS = Recherche écran EO/service              #
#                           FSCM = Recherche fichier EO/matière            #
#                           FSCS = Recherche fichier EO/service            #
#   NOL    : indice de la ligne active (nolign-1)                          #
############################################################################
Subprog RECH_TARIF (TRAIT,NOL)
Value  Char     TRAIT
Value  Integer  NOL
#----- Variables locales -----#
Local  Char     VAT(GLONVAT)(0..2), FOCITMREF(GLONITM), FOCUOM(GLONUOM)
Local  Decimal  WCLCAMT(1..7)
Local  Decimal  MONTANT(0..10), FOCQTY
Local  Decimal  GROPRI,         DISCRGVAL(0..8),  NETPRI,   COEFUNITE
Local  Date     PLISTRDAT,      PLIENDDAT
Local  Shortint MOTIF(0..10),   PRIORITE(0..10),  FOCMOTIF, SVGNOLIGN, I
Local  Char     PLI   (GLONPLI) (0..10)
Local  Char     PLICRD (30) (0..10)
Local  Integer  PLILIN    (0..10)
Local  Libelle  INTERDIT,       ERR,     LTIFLG
Local  Integer  STAT, PRIREN
Local  Integer  MODULE  : MODULE=6  : # Pour point d'entrée TARIFACH
Local  Integer  PLITYP  : PLITYP=1  : # Pour point d'entrée TARIFACH
Local Decimal  WBASE, WQTE, GCOEUOM # Issue 10401 - 2013-04-26 by MUARN : prix base
#----- Paramètres complémentaires appel recherche tarifs -----#
Local  Char     PARAM_T (25) (0..5) : # indice 0 = coef. multiplicateur UV --> US
#----- Pour tarifs inter-sociétés -----#
Local  Char     LBPSNUM    (GLONBPS)   : # fournisseur
Local  Char     LITMREF    (GLONITM)   : # article
Local  Char     LITMREFORI (GLONITM)   : # article lancé
Local  Char     LPOHFCY    (GLONFCY)   : # site cde achat
Local  Char     LPRHFCY    (GLONFCY)   : # site reception achat
Local  Char     LSALFCY    (GLONFCY)   : # site cde vente
Local  Char     LSALCPY    (GLONCPY)   : # société cde vente
Local  Char     LBPCORD    (GLONBPC)   : # client cde vente
#----- Sauvegarge de la valeur du paramètre PURPRICE -----#
If dim(GPURPRICE)>0  Local Integer SVGPURPRICE : SVGPURPRICE=GPURPRICE : Endif
#----- SAUVEGARDE DE nolign -----#
SVGNOLIGN=nolign
nolign=NOL+1
#----- Traitements recherche tarif suivant la valeur du code -----#
Case TRAIT
  When "PSH" : Gosub TARPSH
  When "PSM" : Gosub TARPSM
  When "POH" : Gosub TARPOH
  When "POM" : Gosub TARPOM
  When "POI" : Gosub TARPOI
  When "POC" : Gosub TARPOC
  When "POV" : Gosub TARPOC
  When "POD" : Gosub TARPOD
  When "PTH" : Gosub TARPTH
  When "PNH" : Gosub TARPNH
  When "PMG" : Gosub TARPMG
  When "PSCM" : Gosub TARPSCM
  When "PSCS" : Gosub TARPSCS
  When "FSCM" : Gosub TARFSCM
  When "FSCS" : Gosub TARFSCS
Endcase
#----- Restitution de la valeur du paramètre PURPRICE -----#
If dim(GPURPRICE)>0  GPURPRICE=SVGPURPRICE : Endif
#----- RESTITUTION DE nolign -----#
nolign=SVGNOLIGN
End


#---------------------------------------------#
# Recherche tarif depuis les demandes d'achat #
#---------------------------------------------#
$TARPSH
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>[M:PSH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PSH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:PSH1]ITMREF(NOL)
  Read [ITS] ITS0=[M:PSH1]ITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:PSH1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PSH1]BPSNUM(NOL)
  Read [ITP] ITP0=[M:PSH1]ITMREF(NOL);[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture des fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:PSH1]BPSNUM(NOL) : LITMREF=[M:PSH1]ITMREF(NOL)
LPOHFCY=[M:PSH0]PSHFCY      : LPRHFCY=[M:PSH1]PRHFCY(NOL)
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:PSH1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:PSH1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#-----
If [F:ITP]PUU<>"" [F:PPK]PUU=[F:ITP]PUU Else [F:PPK]PUU=[F:ITM]PUU : Endif
#----- Chargement des codes taxes -----#
Call RECHVATCOD(1,2,[M:PSH1]BPSNUM(NOL),[M:PSH1]ITMREF(NOL),"PSH1",NOL,VAT) From TRTX3
#----- Recherche du tarif -----#
Call TARIFRECH(6,1,TRAIT,[M:PSH0]PRQDAT,[M:PSH1]QTYPUU(NOL),[M:PSH1]PUU(NOL),
&              [M:PSH1]CHGTYP(NOL),[M:PSH1]CUR (NOL),1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#----- Alimentation de la classe [M:PSH1] -----#
[M:PSH1]GROPRI(NOL)=MONTANT(0) : [M:PSH1]PRIREN(NOL)=MOTIF(0)
If MONTANT(10)<>0 [M:PSH1]OFS(NOL)=MONTANT(10) : Endif
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("DIM([M:PSH1]DISCRGVAL"+num$(I)+"(NOL))")>0
    Assign "[M:PSH1]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
    Assign "[M:PSH1]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I

# Issue 10401 - 2013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-02 by MUARN : gestion des gratuits
#If [M:PSH1]GROPRI(NOL)=0
If [M:PSH1]GROPRI(NOL)=0 & [M:PSH1]PRIREN(NOL)=0
  Read [ITM]ITM0=[M:PSH1]ITMREF(NOL)
  WBASE = [F:ITM]PURBASPRI
  If GSYSCUR <> [M:PSH1]CUR(NOL)
    Call CONVERT2(GSYSCUR, [M:PSH1]CUR(NOL), GLOCALDEV, [M:PSH1]CHGTYP(NOL), [M:PSH0]PRQDAT,
&                   WBASE, WBASE, STAT) From TRTDEV
    WBASE=arr(WBASE,10^-GDECPRI)
  Endif
  If [F:ITM]ITMREF<>[M:PSH1]ITMREF(NOL)
    Read [ITM] ITM0=[M:PSH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  If [F:ITM]PUU <> [M:PSH1]PUU(NOL)
    Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:PSH1]PUU(NOL),
&             [M:PSH1]ITMREF(NOL),[M:PSH1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
    WBASE = WBASE/GCOEUOM
    WBASE=arr(WBASE,10^-GDECPRI)
  Endif
  GROPRI = WBASE
  [M:PSH1]GROPRI(NOL) = GROPRI
  # Issue 95247 - 2014-01-03 by MUARN : ajout motif prix
  If WBASE <> 0
    [M:PSH1]PRIREN(NOL) = GUPDPRIPUR
  Endif
Endif

If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:PSH1]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:PSH1]QTYPUU(NOL),NETPRI,
&           [M:PSH1]CUR(NOL)) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:PSH1]NETPRI(NOL)=NETPRI
Return


#-------------------------------------------------------------#
# Recherche tarif depuis la gestion auto des demandes d'achat #
#-------------------------------------------------------------#
$TARPSM
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[F:PSD]BPSNUM
  Read [BPR] BPR0=[F:PSD]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
  Read [BPS] BPS0=[F:PSD]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>[F:PSD]ITMREF
  Read [ITM] ITM0=[F:PSD]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:PSD]ITMREF
  Read [ITS] ITS0=[F:PSD]ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[F:PSD]ITMREF | [F:ITP]BPSNUM<>[F:PSD]BPSNUM
  Read [ITP] ITP0=[F:PSD]ITMREF;[F:PSD]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[F:PSD]BPSNUM : LITMREF=[F:PSD]ITMREF
LPOHFCY=[F:PSD]PSHFCY : LPRHFCY=[F:PSD]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:PSD]BPSNUM
  Read [BPR] BPR0=[F:PSD]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#-----
If [F:ITP]PUU<>"" [F:PPK]PUU=[F:ITP]PUU Else [F:PPK]PUU=[F:ITM]PUU : Endif
#----- Chargement des codes taxes -----#
Call RECHVATCOD(1,2,[F:PSD]BPSNUM,[F:PSD]ITMREF,"PSD",0,VAT) From TRTX3
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Recherche du tarif -----#
Call TARIFRECH(6,1,TRAIT,[F:PSH]PRQDAT,[F:PSD]QTYPUU,[F:PSD]PUU,
&              [F:PSD]CHGTYP,[F:PSD]CUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#----- Alimentation de la classe [F:PSD] -----#
# Issue 10401 - 2011-12-01 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : gestion des gratuits
If MONTANT(0)=0 & MOTIF(0)=0
  Read [ITM]ITM0=[F:PSD]ITMREF
  GROPRI = [F:ITM]PURBASPRI
  [F:PSD]GROPRI=GROPRI :
  If MOTIF(0) = 0
    [L]PRIREN = GUPDPRIPUR
  Else
    [F:PSD]PRIREN=MOTIF(0)
  Endif
Else
  [F:PSD]GROPRI=MONTANT(0) : [F:PSD]PRIREN=MOTIF(0)
  GROPRI = MONTANT(0)
Endif
#[F:PSD]GROPRI=MONTANT(0) : [F:PSD]PRIREN=MOTIF(0)
#GROPRI=MONTANT(0)
# fin Issue 10401 - 2011-12-01 by MUARN : prix de base

For I=1 To 9
  If evalue ("dim([F:PSD]DISCRGVAL"+num$(I)+")")>0
    Assign "[F:PSD]DISCRGVAL"+num$(I) With MONTANT(I)
    Assign "[F:PSD]DISCRGREN"+num$(I) With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
If dim(GCALNETLIN)>0  GCALNETLIN=0         : Endif
If dim(GCALNETABR)>0  GCALNETABR="[F:PSD]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[F:PSD]QTYPUU,NETPRI,
&           [F:PSD]CUR) From TRTPRICE
If GMESSAGE<>"" & GTRACE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
Raz GMESSAGE
[F:PSD]NETPRI=NETPRI
Return


#------------------------------------------------#
# Recherche tarif depuis les commandes standards #
#------------------------------------------------#
$TARPOH
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
  Read [BPS] BPS0=[M:POH0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:POH0]BPSNUM | [F:MVS]CUR<>[M:POH1]CUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:POH0]BPSNUM;[M:POH1]CUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
  Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:POH2]ITMREF(NOL)
  Read [ITS] ITS0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:POH2]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:POH0]BPSNUM
  Read [ITP] ITP0=[M:POH2]ITMREF(NOL);[M:POH0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:POH0]BPSNUM : LITMREF=[M:POH2]ITMREF(NOL)
LPOHFCY=[M:POH0]POHFCY : LPRHFCY=[M:POH2]PRHFCY(NOL)
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[M:POH2]VAT1(NOL)
VAT(1)=[M:POH2]VAT2(NOL)
VAT(2)=[M:POH2]VAT3(NOL)
#----- Recherche du tarif -----#
Call TARIFRECH(6,1,TRAIT,[M:POH0]ORDDAT,[M:POH2]QTYUOM(NOL),[M:POH2]UOM(NOL),
&              [M:POH1]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#---------------- Alimentation de la classe [M:POH2] -----------------#
# LINFLG(NOL)=0 indique ici que la ligne est en cours de création     #
# Alors on calcule la date prévue de livraison avec le délai du tarif #
#---------------------------------------------------------------------#
Raz LTIFLG
If [M:POH2]RETQTYSTU(NOL)=0  LTIFLG=1 : Endif
#--------------------------------------------------------#
# Point d'entrée LTIPRICE pour forcer la prise en compte #
#  du délai tarif malgré une prise en compte de besoins  #
# ------------------------------------------------------ #
# Variable modifiable par le point d'entrée :            #
#   - LTIFLG  0 = Pas de prise en compte du délai tarif  #
#             1 = Recalcul date de réception prévue avec #
#                 le délai tarif                         #
#--------------------------------------------------------#
If [M:POH2]LINFLG(NOL)=0 & MONTANT(10)<>0
  GPOINT="LTIPRICE" : Gosub ENTREE From EXEFNC
Endif
If LTIFLG=1 & [M:POH2]LINFLG(NOL)=0 & MONTANT(10)<>0
  [M:POH2]RETRCPDAT(NOL)=[M:POH0]ORDDAT+MONTANT(10)
Endif
#-----
[M:POH2]GROPRI(NOL)=MONTANT(0) : [M:POH2]PRIREN(NOL)=MOTIF(0)
If MONTANT(10)<>0  [M:POH2]OFS(NOL)=MONTANT(10) : Endif
GROPRI=MONTANT(0)
#---------------------------------------------------------------#
# Alimentation de l'écran de simulation PPSIMUL1 s'il est actif #
#---------------------------------------------------------------#
If dim([M:PPM1]XMOTIFA)>0 & dim([M:PPM1]XMOTIFB)>0
  For I=0 To 9
    [M:PPM1]PLI(I)   =PLI(I)
    [M:PPM1]PIO(I)   =PRIORITE(I)
    [M:PPM1]PLICRD(I)=PLICRD(I)
    [M:PPM1]PLILIN(I)=PLILIN(I)
  Next I
Endif
#-----
For I=1 To 9
  If evalue ("dim([M:POH2]DISCRGVAL"+num$(I)+"(NOL))")>0
    Assign "[M:POH2]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
    Assign "[M:POH2]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#
# Issue 10401 - 2013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
If [M:POH2]GROPRI(NOL)=0 & [M:POH2]PRIREN(NOL)=0  Gosub TARIF_ABSENT : Endif
#  If [M:POH2]GROPRI(NOL)=0 & [M:POH2]PRIREN(NOL)=0  Gosub TARIF_ABSENT : Endif
#If [M:POH2]GROPRI(NOL)=0 & [M:POH2]PRIREN(NOL)=0  Gosub TARIF_ABSENT
#Elsif [M:POH2]GROPRI(NOL)=0
#  Read [ITM]ITM0=[M:POH2]ITMREF(NOL)
#  WBASE = [F:ITM]PURBASPRI
#  If GSYSCUR <> [M:POH1]CUR
#    Call CONVERT2(GSYSCUR, [M:POH1]CUR, GLOCALDEV, [M:POH1]CHGTYP, [M:POH0]ORDDAT,
#&                   WBASE, WBASE, STAT) From TRTDEV
#    WBASE=arr(WBASE,10^-GDECPRI)
#  Endif
#  If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
#    Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
#  Endif
#  If [F:ITM]PUU <> [M:POH2]UOM(NOL)
#    Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POH2]UOM(NOL),
#&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#    WBASE = WBASE/GCOEUOM
#    WBASE=arr(WBASE,10^-GDECPRI)
#  Endif
#  GROPRI = WBASE
#  [M:POH2]GROPRI(NOL) = WBASE
#Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:POH2]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:POH2]QTYUOM(NOL),NETPRI,
&           [M:POH1]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:POH2]NETPRI(NOL)=NETPRI
Return


#----------------------------------------------------------------#
# Recherche tarif depuis la gestion auto des commandes standards #
#----------------------------------------------------------------#
$TARPOM
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:ITM]ITMREF<>[F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:POQ]ITMREF
  Read [ITS] ITS0=[F:POQ]ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[F:POQ]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[F:POQ]ITMREF;[F:POH]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[F:POH]BPSNUM : LITMREF=[F:POQ]ITMREF
LPOHFCY=[F:POH]POHFCY : LPRHFCY=[F:POQ]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#-----
If [F:ITP]PUU<>"" [F:PPK]PUU=[F:ITP]PUU Else [F:PPK]PUU=[F:ITM]PUU : Endif
#----- Chargement des codes taxes -----#
VAT(0)=[F:POP]VAT(0)
VAT(1)=[F:POP]VAT(1)
VAT(2)=[F:POP]VAT(2)
#----- Recherche du tarif -----#
Call TARIFRECH(6,1,TRAIT,[F:POH]ORDDAT,[F:POQ]QTYUOM,[F:POQ]UOM,
&              [F:POH]CHGTYP,[F:POH]CUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#----- Alimentation de la classe [F:POP] -----#
[F:POP]GROPRI=MONTANT(0) : [F:POP]PRIREN=MOTIF(0)
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("dim([F:POP]DISCRGVAL"+num$(I)+")")>0
    Assign "[F:POP]DISCRGVAL"+num$(I) With MONTANT(I)
    Assign "[F:POP]DISCRGREN"+num$(I) With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#
If [F:POP]GROPRI=0 & [F:POP]PRIREN=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0         : Endif
If dim(GCALNETABR)>0  GCALNETABR="[F:POP]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[F:POQ]QTYUOM,NETPRI,
&           [F:POH]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[F:POP]NETPRI=NETPRI
Return


#-----------------------------------------------------------------------#
# Recherche tarif depuis les commandes par article (plan de l'acheteur) #
#-----------------------------------------------------------------------#
$TARPOI
#----- Lecture si nécessaire des ficjiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:POI1]BPSNUM(NOL) | [F:MVS]CUR<>[M:POI1]CUR(NOL)
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:POI1]BPSNUM(NOL);[M:POI1]CUR(NOL)
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
  Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:POI1]ITMREF(NOL)
  Read [ITS] ITS0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [ITP] ITP0=[M:POI1]ITMREF(NOL);[M:POI1]BPSNUM(NOL) : If fstat Raz [F:ITP] : Endif
Endif
#----- Si contremarque, lecture fichiers ventes -----#
If [M:POI1]SOHNUM(NOL)<>""
  If clalev([F:SOH]) & [F:SOH]SOHNUM<>[M:POI1]SOHNUM(NOL)
    Read [SOH] SOH0=[M:POI1]SOHNUM(NOL)
    If fstat  Raz [F:SOH] : Endif
  Endif
  If clalev([F:SOP]) & ([F:SOP]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&                       [F:SOP]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&                       [F:SOP]SOPSEQ<>[M:POI1]SOQSEQ(NOL))
    Read [SOP] SOP0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
    If fstat  Raz [F:SOP] : Endif
  Endif
  If clalev([F:SOQ]) & ([F:SOQ]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&                       [F:SOQ]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&                       [F:SOQ]SOQSEQ<>[M:POI1]SOQSEQ(NOL))
    Read [SOQ] SOQ0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
    If fstat  Raz [F:SOQ] : Endif
  Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:POI1]BPSNUM(NOL) : LITMREF=[M:POI1]ITMREF(NOL)
LPOHFCY=[M:POI1]POHFCY      : LPRHFCY=[M:POI1]PRHFCY(NOL)
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[M:POI1]VAT1(NOL)
VAT(1)=[M:POI1]VAT2(NOL)
VAT(2)=[M:POI1]VAT3(NOL)
#----- Recherche du tarif -----#
Call TARIFRECH(6,1,TRAIT,[M:POI1]ORDDAT,[M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&              [M:POI1]CHGTYP(NOL),[M:POI1]CUR(NOL),1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#---------------- Alimentation de la classe [M:POI1] -----------------#
# LINFLG(NOL)=0 indique ici que la ligne est en cours de création     #
# Alors on calcule la date prévue de livraison avec le délai du tarif #
#---------------------------------------------------------------------#
Raz LTIFLG
If [M:POI1]RETQTYSTU(NOL)=0  LTIFLG=1 : Endif
#--------------------------------------------------------#
# Point d'entrée LTIPRICE pour forcer la prise en compte #
#  du délai tarif malgré une prise en compte de besoins  #
# ------------------------------------------------------ #
# Variable modifiable par le point d'entrée :            #
#   - LTIFLG  0 = Pas de prise en compte du délai tarif  #
#             1 = Recalcul date de réception prévue avec #
#                 le délai tarif                         #
#--------------------------------------------------------#
If [M:POI1]LINFLG(NOL)=0 & MONTANT(10)<>0
  GPOINT="LTIPRICE" : Gosub ENTREE From EXEFNC
Endif
If LTIFLG=1 & [M:POI1]LINFLG(NOL)=0 & MONTANT(10)<>0
  [M:POI1]RETRCPDAT(NOL)=[M:POI1]ORDDAT+MONTANT(10)
Endif
#-----
[M:POI1]GROPRI(NOL)=MONTANT(0) : [M:POI1]PRIREN(NOL)=MOTIF(0)
If MONTANT(10)<>0  [M:POI1]OFS(NOL)=MONTANT(10) : Endif
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("dim([M:POI1]DISCRGVAL"+num$(I)+"(NOL))")>0
    Assign "[M:POI1]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
    Assign "[M:POI1]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#

# Issue 10401  2013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0  Gosub TARIF_ABSENT : Endif
#If [M:POI1]GROPRI(NOL)=0 & [M:POI1]PRIREN(NOL)=0  Gosub TARIF_ABSENT
#Elsif [M:POI1]GROPRI(NOL)=0
#  Read [ITM]ITM0=[M:POI1]ITMREF(NOL)
#  GROPRI = [F:ITM]PURBASPRI
#  If GSYSCUR <> [M:POI1]CUR
#    WBASE=[L]GROPRI
#    Call CONVERT2(GSYSCUR, [M:POI1]CUR(NOL), GLOCALDEV, [M:POI1]CHGTYP(NOL), [M:POI1]ORDDAT,
#&                   WBASE, [L]GROPRI, STAT) From TRTDEV
#    [L]GROPRI=arr([L]GROPRI,10^-GDECPRI)
#  Endif
#  If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
#    Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
#  Endif
#  If [F:ITM]PUU <> [M:POI1]UOM(NOL)
#    Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POI1]UOM(NOL),
#&             [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#    [L]GROPRI = [L]GROPRI/GCOEUOM
#    [L]GROPRI=arr([L]GROPRI,10^-GDECPRI)
#  Endif
#  [M:POI1]GROPRI(NOL) = [L]GROPRI
#Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:POI1]QTYUOM(NOL),NETPRI,
&           [M:POI1]CUR(NOL)) From TRTPRICE
If GMESSAGE<>"" Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:POI1]NETPRI(NOL)=NETPRI
Return

#-----------------------------------------------#
# Recherche tarif depuis les commandes ouvertes #
# --------------------------------------------- #
# Attention POC --> pour ligne POP              #
#                   chargement NETPRI (ligne)   #
#        et POV --> pour prix valorisation      #
#                   chargement PRIVLT           #
#-----------------------------------------------#
$TARPOC
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POC0]BPSNUM
  Read [BPS] BPS0=[M:POC0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:POC0]BPSNUM | [F:MVS]CUR<>[M:POC1]CUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:POC0]BPSNUM;[M:POC1]CUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:POC2]ITMREF
  Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:POC2]ITMREF
  Read [ITS] ITS0=[M:POC2]ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:POC2]ITMREF | [F:ITP]BPSNUM<>[M:POC0]BPSNUM
  Read [ITP] ITP0=[M:POC2]ITMREF;[M:POC0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:POC0]BPSNUM : LITMREF=[M:POC2]ITMREF
LPOHFCY=[M:POC0]POHFCY : LPRHFCY=[M:POC2]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:POC0]BPSNUM
  Read [BPR] BPR0=[M:POC0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[M:POC2]VAT(0)
VAT(1)=[M:POC2]VAT(1)
VAT(2)=[M:POC2]VAT(2)
#----- RECHERCHE DU TARIF -----#
NOMTRAIT = "WAT"+[M:POC2]PLI
If TRAIT = "POV"
    Call TARIF("",[M:POC2]XSTRDAT,[M:POC2]EXTQTYPUU,[M:POC2]PUU,[M:POC1]CHGTYP,[M:POC1]CUR,1,
&             [M:POC2]VAT,0,
&             PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&             FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT) From =NOMTRAIT
Else
    Call TARIF("",[M:POC2]POPSTRDAT(NOL),[M:POC2]EXTQTYPUU,[M:POC2]PUU,[M:POC1]CHGTYP,[M:POC1]CUR,1,
&             [M:POC2]VAT,0,
&             PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&             FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT) From =NOMTRAIT
Endif
#--------------------------------------------------------------------------------#
# Point d'entrée TARIFACH pour intervenir sur les valeurs du tarif achat trouvés #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                                    #
#                                                                                #
# MODULE    : Module (6 = Achats)                                                #
# PLITYP    : Type de tarif (1 = Normal)                                         #
# TRAIT     : Code traitement ayant lancé la recherche                           #
#               POC = Recherche depuis contrats pour ligne tarif                 #
#               POV = Recherche depuis contrats pour prix de valorisation        #
# ------------------------------------------------------------------------------ #
# Variables modifiables par le point d'entrée                                    #
#                                                                                #
# MONTANT(0..10) : Valeurs tarif trouvées                                        #
#                    indice  0 = Prix unitaire brut                              #
#                    indices 1 à 9 = Frais/Remises 1 à 9                         #
#                    indice 10 = Délai en jour pour calcul date de réception     #
# MOTIF (0..10)  : Codes motifs                                                  #
#                    indice  0 = Motif du prix unitaire brut                     #
#                    indices 1 à 9 = Motifs des Frais/Remises 1 à 9              #
#--------------------------------------------------------------------------------#
GPOINT="TARIFACH" : Gosub ENTREE From EXEFNC
#----- Alimentation de la classe [M:POC2] -----#
If TRAIT="POV"
  GROPRI=MONTANT(0)
  For I=1 To 9
    If evalue ("dim([M:POC2]DISCRGVAL"+num$(I)+"(NOL))")>0
      DISCRGVAL(I-1)=MONTANT(I)
    Endif
  Next I
  #----- Si pas de prix de base -----#
  # Issue 10401 - 2013-04-26 by MUARN : prix de base
  # Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
  If GROPRI=0 & MOTIF(0)=0  Gosub TARIF_ABSENT : Endif
#  If GROPRI=0 & MOTIF(0)=0  Gosub TARIF_ABSENT
#  Elsif GROPRI=0
#    Read [ITM]ITM0=[M:POC2]ITMREF
#    WBASE = [F:ITM]PURBASPRI
#    If GSYSCUR <> [M:POC1]CUR
#      Call CONVERT2(GSYSCUR, [M:POC1]CUR, GLOCALDEV, [M:POC1]CHGTYP, [M:POC0]ORDDAT,
#&                   WBASE, WBASE, STAT) From TRTDEV
#      WBASE=arr(WBASE,10^-GDECPRI)
#    Endif
#    If [F:ITM]PUU <> [M:POC2]PUU
#      Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POC2]PUU,
#&             [M:POC2]ITMREF,[M:POC0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#      WBASE = WBASE/GCOEUOM
#      WBASE=arr(WBASE,10^-GDECPRI)
#    Endif
#    [L]GROPRI=WBASE
#  Endif
#  [L]GROPRI = WBASE
  # fin Issue 10401 - 2013-04-26 by MUARN : prix de base
  #-----
  If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:POC2]" : Endif
  Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,1,NETPRI,[M:POC1]CUR) From TRTPRICE
  If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
  [M:POC2]PRIVLT=NETPRI
  GBIDA1=[M:POC2]XSTRDAT
Else
  [M:POC2]GROPRI(NOL)=MONTANT(0) : [M:POC2]PRIREN(NOL)=MOTIF(0)
  GROPRI=MONTANT(0)
  For I=1 To 9
    If evalue ("dim([M:POC2]DISCRGVAL"+num$(I)+"(NOL))")>0
      Assign "[M:POC2]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
      Assign "[M:POC2]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
      DISCRGVAL(I-1)=MONTANT(I)
    Endif
  Next I
  #----- Si pas de prix de base -----#
  # Issue 10401 - 2013-04-26 by MUARN : prix de base
  # Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
  If GROPRI=0 & MOTIF(0)=0  Gosub TARIF_ABSENT : Endif
#  If GROPRI=0 & MOTIF(0)=0  Gosub TARIF_ABSENT
#  Elsif GROPRI=0
#    Read [ITM]ITM0=ITMREF
#    WBASE = [F:ITM]PURBASPRI
#    If GSYSCUR <> [M:POC1]CUR
#      Call CONVERT2(GSYSCUR, [M:POC1]CUR, GLOCALDEV, [M:POC1]CHGTYP, [M:POC0]ORDDAT,
#&                   WBASE, WBASE, STAT) From TRTDEV
#      WBASE=arr(WBASE,10^-GDECPRI)
#    Endif
#    If [F:ITM]PUU <> [M:POC2]PUU
#      Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POC2]PUU,
#&             [M:POC2]ITMREF,[M:POC0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#      WBASE = WBASE/GCOEUOM
#      WBASE=arr(WBASE,10^-GDECPRI)
#    Endif
#    [M:POC2]GROPRI(NOL)=WBASE
#    [L]GROPRI = WBASE
#  Endif
  # fin Issue 10401 - 2013-04-26 by MUARN : prix de base
  #-----
  If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:POC2]" : Endif
  Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,1,NETPRI,[M:POC1]CUR) From TRTPRICE
  If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
  [M:POC2]NETPRI(NOL)=NETPRI
  GBIDA1=[M:POC2]POPSTRDAT(NOL)
Endif
Return

#---------------------------------------------------------#
# Recherche tarif depuis les demandes de livraison fermes #
# Attention on est en phase de mise à jour                #
# Alimentation à partir des clases [F]                    #
#---------------------------------------------------------#
$TARPOD
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:POH]BPSNUM
  Read [BPS] BPS0=[F:POH]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[F:POH]BPSNUM | [F:MVS]CUR<>[F:POH]CUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[F:POH]BPSNUM;[F:POH]CUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:POC]ITMREF
  Read [ITS] ITS0=[F:POC]ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[F:POC]ITMREF | [F:ITP]BPSNUM<>[F:POH]BPSNUM
  Read [ITP] ITP0=[F:POC]ITMREF;[F:POH]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[F:POH]BPSNUM : LITMREF=[F:POC]ITMREF
LPOHFCY=[F:POH]POHFCY : LPRHFCY=[F:POC]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:POH]BPSNUM
  Read [BPR] BPR0=[F:POH]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[F:POP]VAT(0)
VAT(1)=[F:POP]VAT(1)
VAT(2)=[F:POP]VAT(2)
#----- Recherche du tarif -----#
NOMTRAIT="WAT"+[F:POC]PLI
Call TARIF("",[F:POQ]DEMRCPDAT,[F:POQ]QTYPUU,[F:POQ]PUU,[F:POH]CHGTYP,[F:POH]CUR,1,
&          [F:POP]VAT,0,PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&          FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT) From =NOMTRAIT
#----- Alimentation de la classe [F:POP] -----#
[F:POP]GROPRI=MONTANT(0) : [F:POP]PRIREN=MOTIF(0)
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("dim([F:POP]DISCRGVAL"+num$(I)+")")>0
    Assign "[F:POP]DISCRGVAL"+num$(I) With MONTANT(I)
    Assign "[F:POP]DISCRGREN"+num$(I) With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#
# Issue 10401 - 2013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
If [F:POP]GROPRI=0 & [F:POP]PRIREN=0  Gosub TARIF_ABSENT : Endif
#If [F:POP]GROPRI=0 & [F:POP]PRIREN=0  Gosub TARIF_ABSENT
#Elsif [F:POP]GROPRI=0
#  Read [ITM]ITM0=[F:POC]ITMREF
#  GROPRI = [F:ITM]PURBASPRI
#  [F:POP]GROPRI= GROPRI
#Endif
# fin Issue 10401 - 2013-04-26 by MUARN : prix de base

#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0         : Endif
If dim(GCALNETABR)>0  GCALNETABR="[F:POP]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[F:POQ]QTYPUU,NETPRI,
&           [F:POH]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[F:POP]NETPRI=NETPRI
Return

#------------------------------------------------#
# Recherche tarif depuis les réceptions directes #
#------------------------------------------------#
$TARPTH
#----- Lecture si nécessaies des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
  Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:PTH0]BPSNUM
  Read [BPS] BPS0=[M:PTH0]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:PTH0]BPSNUM | [F:MVS]CUR<>[M:PTH0]CUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:PTH0]BPSNUM;[M:PTH0]CUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:PTH1]ITMREF(NOL)
  Read [ITS] ITS0=[M:PTH1]ITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:PTH1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PTH0]BPSNUM
  Read [ITP] ITP0=[M:PTH1]ITMREF(NOL);[M:PTH0]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:PTH0]BPSNUM      : LITMREF=[M:PTH1]ITMREF(NOL)
LPOHFCY=[M:PTH1]POHFCY(NOL) : LPRHFCY=[M:PTH0]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
  Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[M:PTH1]VAT1(NOL)
VAT(1)=[M:PTH1]VAT2(NOL)
VAT(2)=[M:PTH1]VAT3(NOL)
#----- Recherche du tarif pour les réceptions directes -----#
Call TARIFRECH(6,1,TRAIT,[M:PTH0]RCPDAT,[M:PTH1]QTYUOM(NOL),[M:PTH1]UOM(NOL),
&              [M:PTH0]CHGTYP,[M:PTH1]NETCUR(NOL),1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#----- Alimentation de la classe [M:PTH1] -----#
[M:PTH1]GROPRI(NOL)=MONTANT(0) : [M:PTH1]PRIREN(NOL)=MOTIF(0)
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("dim([M:PTH1]DISCRGVAL"+num$(I)+"(NOL))")>0
    Assign "[M:PTH1]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
    Assign "[M:PTH1]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#
# Issue 10401 - 22013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
If [M:PTH1]GROPRI(NOL)=0 & [M:PTH1]PRIREN(NOL)=0  Gosub TARIF_ABSENT : Endif
#If [M:PTH1]GROPRI(NOL)=0 & [M:PTH1]PRIREN(NOL)=0  Gosub TARIF_ABSENT
#Elsif [M:PTH1]GROPRI(NOL)=0
#  Read [ITM]ITM0=[M:PTH1]ITMREF(NOL)
#  WBASE = [F:ITM]PURBASPRI
#  If GSYSCUR <> [M:PTH1]NETCUR(NOL)
#    Call CONVERT2(GSYSCUR, [M:PTH1]NETCUR(NOL), GLOCALDEV, [M:PTH0]CHGTYP, [M:PTH0]RCPDAT,
#&                   WBASE, WBASE, STAT) From TRTDEV
#    WBASE=arr(WBASE,10^-GDECPRI)
#  Endif
#  If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
#    Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
#  Endif
#  If [F:ITM]PUU <> [M:PTH1]UOM(NOL)
#    Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:PTH1]UOM(NOL),
#&             [M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#    WBASE = WBASE/GCOEUOM
#    WBASE=arr(WBASE,10^-GDECPRI)
#  Endif
#  GROPRI = WBASE
#  [M:PTH1]GROPRI(NOL) = WBASE
#Endif
# fin Issue 10401 - 2013-04-26 by MUARN : prix de base
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:PTH1]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:PTH1]QTYUOM(NOL),NETPRI,
&           [M:PTH0]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:PTH1]NETPRI(NOL)=NETPRI
Return

#------------------------------------------------#
# Recherche tarif depuis les retours fournisseur #
#------------------------------------------------#
$TARPNH
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:PNH1]BPSNUM
  Read [BPR] BPR0=[M:PNH1]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:PNH1]BPSNUM
  Read [BPS] BPS0=[M:PNH1]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:PNH1]BPSNUM | [F:MVS]CUR<>[M:PNH1]NETCUR(NOL)
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:PNH1]BPSNUM;[M:PNH1]NETCUR(NOL)
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:PNH1]ITMREF(NOL)
  Read [ITS] ITS0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:PNH1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PNH1]BPSNUM
  Read [ITP] ITP0=[M:PNH1]ITMREF(NOL);[M:PNH1]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:PNH1]BPSNUM      : LITMREF=[M:PNH1]ITMREF(NOL)
LPOHFCY=[M:PNH1]POHFCY(NOL) : LPRHFCY=[M:PNH1]PNHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:PNH1]BPSNUM
  Read [BPR] BPR0=[M:PNH1]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
VAT(0)=[M:PNH1]VAT1(NOL)
VAT(1)=[M:PNH1]VAT2(NOL)
VAT(2)=[M:PNH1]VAT3(NOL)
#----- Recherche du tarif pour les retours directs -----#
Call TARIFRECH(6,1,TRAIT,[M:PNH1]RTNDAT,[M:PNH1]QTYUOM(NOL),[M:PNH1]UOM(NOL),
&              [F:BPS]CHGTYP,[M:PNH1]NETCUR(NOL),1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#-------------- Alimentation de la classe [M:PNH1] ---------------#
# LINFLG(NOL)=0 Indique ici que la ligne est en cours de création #
#-----------------------------------------------------------------#
[M:PNH1]GROPRI(NOL)=MONTANT(0) : [M:PNH1]PRIREN(NOL)=MOTIF(0)
GROPRI=MONTANT(0)
For I=1 To 9
  If evalue ("dim([M:PNH1]DISCRGVAL"+num$(I)+"(NOL))")>0
    Assign "[M:PNH1]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
    Assign "[M:PNH1]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
    DISCRGVAL(I-1)=MONTANT(I)
  Endif
Next I
#----- Si pas de prix de base -----#
# Issue 10401 - 2013-04-26 by MUARN : prix de base
# Issue 95247 - 2014-01-03 by MUARN : prix de base géré dans TARIF_ABSENT
If [M:PNH1]GROPRI(NOL)=0 & [M:PNH1]PRIREN(NOL)=0  Gosub TARIF_ABSENT : Endif
#If [M:PNH1]GROPRI(NOL)=0 & [M:PNH1]PRIREN(NOL)=0  Gosub TARIF_ABSENT
#Elsif [M:PNH1]GROPRI(NOL)=0
#  Read [ITM]ITM0=[M:PNH1]ITMREF(NOL)
#  [L]GROPRI = [F:ITM]PURBASPRI
#  If GSYSCUR <> [M:PNH1]NETCUR(NOL)
#    WBASE=[L]GROPRI
#      Call CONVERT2(GSYSCUR, [M:PNH1]NETCUR(NOL), GLOCALDEV, [F:BPS]CHGTYP, [M:PTH0]RCPDAT,
#&                   WBASE, WBASE, STAT) From TRTDEV
#      [L]WBASE=arr([L]WBASE,10^-GDECPRI)
#      [L]GROPRI=[L]WBASE
#    Endif
#    If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
#      Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
#    Endif
#    If [F:ITM]PUU <> [M:PNH1]UOM(NOL)
#      Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:PNH1]UOM(NOL),
#&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
#      [L]GROPRI = [L]GROPRI/GCOEUOM
#      [L]GROPRI=arr([L]GROPRI,10^-GDECPRI)
#  Endif
#  [M:PNH1]GROPRI(NOL) = [L]GROPRI
#Endif
# fin Issue 10401 - 2013-04-26 by MUARN : prix de base
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:PNH1]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:PNH1]QTYUOM(NOL),NETPRI,
&           [M:PNH1]NETCUR(NOL)) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:PNH1]NETPRI(NOL)=NETPRI
Return

#----------------------------------------------------#
# Recherche tarif depuis les plans pour les contrats #
#----------------------------------------------------#
$TARPMG
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[F:POC]BPSNUM
  Read [BPR] BPR0=[F:POC]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:POC]BPSNUM
  Read [BPS] BPS0=[F:POC]BPSNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[F:POC]BPSNUM | [F:MVS]CUR<>[F:POH]CUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[F:POC]BPSNUM;[F:POH]CUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[F:POC]ITMREF
  Read [ITM] ITM0=[F:POC]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:POC]ITMREF
  Read [ITS] ITS0=[F:POC]ITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[F:POC]ITMREF | [F:ITP]BPSNUM<>[F:POC]BPSNUM
  Read [ITP] ITP0=[F:POC]ITMREF;[F:POC]BPSNUM : If fstat Raz [F:ITP] : Endif
Endif
If [F:POH]POHNUM<>[F:POC]POHNUM
  Read [POH] POH0=[F:POC]POHNUM : If fstat Raz [F:POH] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[F:POC]BPSNUM : LITMREF=[F:POC]ITMREF
LPOHFCY=[F:POC]POHFCY : LPRHFCY=[F:POC]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:POC]BPSNUM
  Read [BPR] BPR0=[F:POC]BPSNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
Call RECHVATCOD(1,2,[F:POC]BPSNUM,[F:POC]ITMREF,"POC",0,VAT) From TRTX3
#----- Recherche du tarif -----#
NOMTRAIT="WAT"+[F:POC]PLI
Call TARIF("",[F:POC]STRDAT,[F:POC]EXTQTYPUU,[F:POC]PUU,[F:POH]CHGTYP,[F:POH]CUR,1,VAT,0,
&          PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,
&          FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,PLISTRDAT,PLIENDDAT,INTERDIT) From =NOMTRAIT
#--------------------------------------------------------------------------------#
# Point d'entrée TARIFACH pour intervenir sur les valeurs du tarif achat trouvés #
# ------------------------------------------------------------------------------ #
# Variables utilisables par le point d'entrée                                    #
#                                                                                #
# MODULE    : Module (6 = Achats)                                                #
# PLITYP    : Type de tarif (1 = Normal)                                         #
# TRAIT     : Code traitement ayant lancé la recherche                           #
#               PMG = Recherche depuis les plans pour prix de valorisation       #
# ------------------------------------------------------------------------------ #
# Variables modifiables par le point d'entrée                                    #
#                                                                                #
# MONTANT(0..10) : Valeurs tarif trouvées                                        #
#                    indice  0 = Prix unitaire brut                              #
#                    indices 1 à 9 = Frais/Remises 1 à 9                         #
#                    indice 10 = Délai en jour pour calcul date de réception     #
# MOTIF (0..10)  : Codes motifs                                                  #
#                    indice  0 = Motif du prix unitaire brut                     #
#                    indices 1 à 9 = Motifs des Frais/Remises 1 à 9              #
#--------------------------------------------------------------------------------#
GPOINT="TARIFACH" : Gosub ENTREE From EXEFNC
#----- Alimentation de la classe [F:POC] -----#
GROPRI=MONTANT(0)
For I=1 To 9
  DISCRGVAL(I-1)=MONTANT(I)
Next I
#----- Si pas de prix de base -----#
If GROPRI=0 & MOTIF(0)=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0  : Endif
If dim(GCALNETABR)>0  GCALNETABR="" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,1,NETPRI,[F:POH]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[F:POC]PRIVLT=NETPRI
GBIDA1=[F:POC]STRDAT
Return

#-----------------------------------------------------------------#
# Recherche tarif depuis écran [M:SCO2] composant matière d'un EO #
#-----------------------------------------------------------------#
$TARPSCM
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
  Read [BPR] BPR0=[M:SCO0]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
  Read [BPS] BPS0=[M:SCO0]BPRNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:SCO0]BPRNUM | [F:MVS]CUR<>GCUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:SCO0]BPRNUM;GCUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:SCO2]CPNITMREF(NOL)
  Read [ITM] ITM0=[M:SCO2]CPNITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:SCO2]CPNITMREF(NOL)
  Read [ITS] ITS0=[M:SCO2]CPNITMREF(NOL) : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:SCO2]CPNITMREF(NOL) | [F:ITP]BPSNUM<>[M:SCO0]BPRNUM
  Read [ITP] ITP0=[M:SCO2]CPNITMREF(NOL);[M:SCO0]BPRNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:SCO0]BPRNUM : LITMREF=[M:SCO2]CPNITMREF(NOL) : LITMREFORI=[M:SCO0]ITMREF
LPOHFCY=[M:SCO0]POHFCY : LPRHFCY=[M:SCO2]STOFCY(NOL)
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
  Read [BPR] BPR0=[M:SCO0]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
If dim([M:SCO2]VAT1)>0
   VAT(0)=[M:SCO2]VAT1(NOL)
   VAT(1)=[M:SCO2]VAT2(NOL)   #CHECK IGNORE_LINE
   VAT(2)=[M:SCO2]VAT3(NOL)   #CHECK IGNORE_LINE
Endif
#----- Cout standard toujours lu pour renseigner SCM.REFPRI -----#
Gosub REFPRI_EO
#----- Recherche du tarif -----#
# FQ 76146 GA 09/2011 avant [M:SCO2]BOMUOM(NOL)
# FQ 78120 avant [M:SCO1]ORDDAT
Call TARIFRECH(6,1,TRAIT,[M:SCO3]OPESTR,[M:SCO2]RETQTY(NOL),[L]UOM,
&              [F:BPS]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#---------------- Alimentation de la classe [M:SCO2] -----------------#
# GA GROPRI et PRIREN ne sont pas enregistrés pour les matières, seult NETPRI
[M:SCO2]GROPRI(NOL)=MONTANT(0) : [M:SCO2]PRIREN(NOL)=MOTIF(0)
# si un délai est précisé au niveau du tarif ...
If MONTANT(10)<>0  [M:SCO2]BOMOFS(NOL)=MONTANT(10) : Endif
GROPRI=MONTANT(0)
PRIREN=MOTIF(0)
#-----
For I=1 To 9
 If evalue ("dim([M:SCO2]DISCRGVAL"+num$(I)+"(NOL))")>0
   Assign "[M:SCO2]DISCRGVAL"+num$(I)+"(NOL)" With MONTANT(I)
   Assign "[M:SCO2]DISCRGREN"+num$(I)+"(NOL)" With MOTIF(I)
   DISCRGVAL(I-1)=MONTANT(I)
 Endif
Next I
#----- Si pas de prix de base -----#
If GROPRI=0 & PRIREN=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:SCO2]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:SCO2]RETQTY(NOL),NETPRI,
&           [M:SCO1]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:SCO2]NETPRI(NOL)=NETPRI
# Issue 87038 GA 01/2013 pb de performances
# Affzo [SCO2]
Return

#-----------------------------------------------------------------#
# Recherche tarif maj auto [F:SCM] composant matière d'un EO      #
#-----------------------------------------------------------------#
$TARFSCM
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[F:SCO]BPRNUM
  Read [BPR] BPR0=[F:SCO]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[F:SCO]BPRNUM
  Read [BPS] BPS0=[F:SCO]BPRNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[F:SCO]BPRNUM | [F:MVS]CUR<>GCUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[F:SCO]BPRNUM;GCUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[F:SCM]CPNITMREF
  Read [ITM] ITM0=[F:SCM]CPNITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[F:SCM]CPNITMREF
  Read [ITS] ITS0=[F:SCM]CPNITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[F:SCM]CPNITMREF | [F:ITP]BPSNUM<>[F:SCO]BPRNUM
  Read [ITP] ITP0=[F:SCM]CPNITMREF;[F:SCO]BPRNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[F:SCO]BPRNUM : LITMREF=[F:SCM]CPNITMREF : LITMREFORI=[F:SCI]ITMREF
LPOHFCY=[F:SCO]POHFCY : LPRHFCY=[F:SCM]STOFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:SCO]BPRNUM
  Read [BPR] BPR0=[F:SCO]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
If dim([F:SCM]VAT1)>0  VAT(0)=[F:SCM]VAT1 : Endif
If dim([F:SCM]VAT2)>0  VAT(1)=[F:SCM]VAT2 : Endif
If dim([F:SCM]VAT3)>0  VAT(2)=[F:SCM]VAT3 : Endif
#----- Cout standard toujours lu pour renseigner SCM.REFPRI -----#
Gosub REFPRI_EO
#----- Recherche du tarif -----#
# FQ 78120 avant [F:SCO]ORDDAT
Call TARIFRECH(6,1,TRAIT,[F:SCS]OPESTR,[F:SCM]RETQTY,[F:SCM]BOMUOM,
&              [F:BPS]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#---------------- Alimentation de la classe [F:SCM] -----------------#
# GA GROPRI et PRIREN ne sont pas enregistrés pour les matières, seult NETPRI
[F:SCM]GROPRI=MONTANT(0) : [F:SCM]PRIREN=MOTIF(0)
# si un délai est précisé au niveau du tarif ...
If MONTANT(10)<>0  [F:SCM]BOMOFS=MONTANT(10) : Endif
GROPRI=MONTANT(0)
PRIREN=MOTIF(0)
#-----
For I=1 To 9
 If evalue ("dim([F:SCM]DISCRGVAL"+num$(I)+")")>0
   Assign "[F:SCM]DISCRGVAL"+num$(I) With MONTANT(I)
   Assign "[F:SCM]DISCRGREN"+num$(I) With MOTIF(I)
   DISCRGVAL(I-1)=MONTANT(I)
 Endif
Next I
#----- Si pas de prix de base -----#
If GROPRI=0 & PRIREN=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0         : Endif
If dim(GCALNETABR)>0  GCALNETABR="[F:SCM]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[F:SCM]RETQTY,NETPRI,
&           [F:SCO]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[F:SCM]NETPRI=NETPRI
Return


#-----------------------------------------------------------------#
# Recherche tarif depuis écran [M:SCO3] service d'un EO           #
#-----------------------------------------------------------------#
############################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                          #
############################################################################

$TARPSCS
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
  Read [BPR] BPR0=[M:SCO0]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
  Read [BPS] BPS0=[M:SCO0]BPRNUM : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:SCO0]BPRNUM | [F:MVS]CUR<>GCUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:SCO0]BPRNUM;GCUR
  If fstat Raz [F:MVS] : Endif
Endif
If [F:ITM]ITMREF<>[M:SCO3]SRVITMREF
  Read [ITM] ITM0=[M:SCO3]SRVITMREF : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITS]ITMREF<>[M:SCO3]SRVITMREF
  Read [ITS] ITS0=[M:SCO3]SRVITMREF : If fstat Raz [F:ITS] : Endif
Endif
If [F:ITP]ITMREF<>[M:SCO3]SRVITMREF | [F:ITP]BPSNUM<>[M:SCO0]BPRNUM
  Read [ITP] ITP0=[M:SCO3]SRVITMREF;[M:SCO0]BPRNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:SCO0]BPRNUM : LITMREF=[M:SCO3]SRVITMREF  : LITMREFORI=[M:SCO0]ITMREF
LPOHFCY=[M:SCO0]POHFCY : LPRHFCY=[M:SCO3]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:SCO0]BPRNUM
  Read [BPR] BPR0=[M:SCO0]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
If dim([M:SCO3]VAT1)>0
   VAT(0)=[M:SCO3]VAT1
   VAT(1)=[M:SCO3]VAT2   #CHECK IGNORE_LINE
   VAT(2)=[M:SCO3]VAT3   #CHECK IGNORE_LINE
Endif
#----- Cout standard toujours lu pour renseigner SCS.REFPRI -----#
Gosub REFPRI_EO
#----- Recherche du tarif -----#
# FQ 78120 avant [M:SCO1]ORDDAT
Call TARIFRECH(6,1,TRAIT,[M:SCO3]OPESTR,[M:SCO3]EXTSTRQTY,[M:SCO3]SCOPUU,
&              [F:BPS]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#-----
For I=1 To 9
 If evalue ("dim([M:SCO3]DISCRGVAL"+num$(I)+")")>0
   Assign "[M:SCO3]DISCRGVAL"+num$(I) With MONTANT(I)
   Assign "[M:SCO3]DISCRGREN"+num$(I) With MOTIF(I)
 Endif
 DISCRGVAL(I-1)=MONTANT(I)   # FQ 78120 GA 01/2012 stocker même si les zones n'existent pas dans [M:SCO3]
Next I
#---------------- Alimentation de la classe [M:SCO3] -----------------#
If MONTANT(0)<> 0
   [M:SCO3]GROPRI=MONTANT(0) : [M:SCO3]PRIREN=MOTIF(0)
   # si un délai est précisé au niveau du tarif ... on remplace SCOLTI
   If MONTANT(10)<>0  [M:SCO3]SCOLTI=MONTANT(10) : Endif
   GROPRI=MONTANT(0)
Endif
If GROPRI=0 & PRIREN=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0          : Endif
If dim(GCALNETABR)>0  GCALNETABR="[M:SCO3]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:SCO3]EXTSTRQTY,NETPRI,
&           [M:SCO1]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[M:SCO3]NETPRI=NETPRI
# Issue 87038 GA 01/2013 pb de performances
# Affzo [SCO3]
Return


