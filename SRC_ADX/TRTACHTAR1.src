If [F:ITP]ITMREF<>[F:SCS]SRVITMREF | [F:ITP]BPSNUM<>[F:SCO]BPRNUM
  Read [ITP] ITP0=[F:SCS]SRVITMREF;[F:SCO]BPRNUM : If fstat Raz [F:ITP] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
