LPOHFCY=[F:SCO]POHFCY : LPRHFCY=[F:SCS]PRHFCY
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[F:SCO]BPRNUM
  Read [BPR] BPR0=[F:SCO]BPRNUM : If fstat Raz [F:BPR] : Endif
Endif
#----- Chargement fichier lien PPRICLINK -----#
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#----- Chargement des codes taxes -----#
If dim([F:SCS]VAT1)>0  VAT(0)=[F:SCS]VAT1 : Endif
If dim([F:SCS]VAT2)>0  VAT(1)=[F:SCS]VAT2 : Endif
If dim([F:SCS]VAT3)>0  VAT(2)=[F:SCS]VAT3 : Endif
#----- Cout standard toujours lu pour renseigner SCS.REFPRI -----#
Gosub REFPRI_EO
#----- Recherche du tarif -----#
# FQ 78120 avant [F:SCO]ORDDAT
Call TARIFRECH(6,1,TRAIT,[F:SCS]OPESTR,[F:SCS]EXTSTRQTY,[F:SCS]SCOPUU,
&              [F:BPS]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#-----
For I=1 To 9
 If evalue ("dim([F:SCS]DISCRGVAL"+num$(I)+")")>0
   Assign "[F:SCS]DISCRGVAL"+num$(I) With MONTANT(I)
   Assign "[F:SCS]DISCRGREN"+num$(I) With MOTIF(I)
 Endif
 DISCRGVAL(I-1)=MONTANT(I)   # FQ 78120 GA 01/2012 stocker même si les zones n'existent pas dans [F:SCS]
Next I
#---------------- Alimentation de la classe [F:SCS] -----------------#
If MONTANT(0)<> 0
   [F:SCS]GROPRI=MONTANT(0) : [F:SCS]PRIREN=MOTIF(0)
   # si un délai est précisé au niveau du tarif ... on remplace SCOLTI
   If MONTANT(10)<>0  [F:SCS]SCOLTI=MONTANT(10) : Endif
   GROPRI=MONTANT(0)
Endif
If GROPRI=0 & PRIREN=0  Gosub TARIF_ABSENT : Endif
#-----
If dim(GCALNETLIN)>0  GCALNETLIN=0         : Endif
If dim(GCALNETABR)>0  GCALNETABR="[F:SCS]" : Endif
Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[F:SCS]EXTSTRQTY,NETPRI,
&           [F:SCO]CUR) From TRTPRICE
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
[F:SCS]NETPRI=NETPRI
Return

#############################################################################
# Prix de référence pour les ordres de sous-traitance
#############################################################################
$REFPRI_EO
#----- Variables locales -----#
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN, VCRTYP, VCRLIN, VCRSEQ
Local Char     CUR(GLONCUR), UOM(GLONUOM), VCRNUM(GLONVCR), PRHFCY(GLONFCY)
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
#-----
Raz [L]NETPRI, [L]GROPRI, [L]PRIREN, [L]VCRTYP, [L]VCRNUM, [L]VCRLIN, [L]VCRSEQ
Raz LECCMAJ, LECCMIN
Case TRAIT
  When "PSCM"   : # Matière fournie par le sous-traitant
    GBIDA1      =[M:SCO3]OPESTR   # FQ 78120 GA 01/2012 avant [M:SCO1]ORDDAT
    [L]BETFCY   =[M:SCO0]BETFCY
    [L]CUR      =[M:SCO1]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    If dim([M:SCO2]BOMUOM(NOL))>0     # UML actif # FQ 76146 GA 09/2011
       [L]UOM   =[M:SCO2]BOMUOM(NOL)
    Else
       [L]UOM   =[F:ITM]PUU
    Endif
    [L]PRHFCY   =[M:SCO1]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[M:SCO0]SCONUM
    [L]VCRLIN   =[M:SCO1]SCILIN
    [L]VCRSEQ   =[M:SCO2]SCMLIN(NOL)
    If dim([M:SCO2]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:SCO2]ECCVALMAJ(NOL)
        [L]LECCMIN  =[M:SCO2]ECCVALMIN(NOL)
    Endif
  When "FSCM"   : # Matière fournie par le sous-traitant
    GBIDA1      =[F:SCS]OPESTR   # FQ 78120 GA 01/2012 avant [F:SCO]ORDDAT
    [L]BETFCY   =[F:SCO]BETFCY
    [L]CUR      =[F:SCO]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[F:SCM]BOMUOM
    [L]PRHFCY   =[F:SCI]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[F:SCM]SCONUM
    [L]VCRLIN   =[F:SCM]SCILIN
    [L]VCRSEQ   =[F:SCM]SCMLIN
    [L]LECCMAJ  =[F:SCM]ECCVALMAJ
    [L]LECCMIN  =[F:SCM]ECCVALMIN
  When "PSCS"   : # Service de l'ordre de sous-traitance
    GBIDA1      =[M:SCO3]OPESTR   # FQ 78120 GA 01/2012 avant [M:SCO1]ORDDAT
    [L]BETFCY   =[M:SCO0]BETFCY
    [L]CUR      =[M:SCO1]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[M:SCO3]SCOPUU
    [L]PRHFCY   =[M:SCO3]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[M:SCO0]SCONUM
    [L]VCRLIN   =[M:SCO1]SCILIN
    [L]VCRSEQ   =[M:SCO3]SCSLIN
    [L]LECCMAJ  =""
    [L]LECCMIN  =""
  When "FSCS"   : # Service de l'ordre de sous-traitance
    GBIDA1      =[F:SCS]OPESTR   # FQ 78120 GA 01/2012 avant [F:SCO]ORDDAT
    [L]BETFCY   =[F:SCO]BETFCY
    [L]CUR      =[F:SCO]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[F:SCS]SCOPUU
    [L]PRHFCY   =[F:SCS]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[F:SCS]SCONUM
    [L]VCRLIN   =[F:SCS]SCILIN
    [L]VCRSEQ   =[F:SCS]SCSLIN
    [L]LECCMAJ  =""
    [L]LECCMIN  =""
Endcase
# Issue 96192 GA 01/2014 tester GPURPRICE
#----- Prendre le coût standard si prix nul & GPURPRICE -----#
If [L]NETPRI=0 & GPURPRICE=2
  Gosub COUT_STD
Endif
#
Case TRAIT
  When "PSCM"   : # Matière fournie par le sous-traitant
    [M:SCO2]REFPRI(NOL)=[L]NETPRI
  When "FSCM"   : # Matière fournie par le sous-traitant
    [F:SCM]REFPRI      =[L]NETPRI
  When "PSCS"   : # Service de l'ordre de sous-traitance
    [M:SCO3]REFPRI     =[L]NETPRI
  When "FSCS"   : # Service de l'ordre de sous-traitance
    [F:SCS]REFPRI      =[L]NETPRI
Endcase
Return

#############################################################################
# Si aucun tarif trouvé :                                                   #
#   - prendre le prix de base de l'article-vente si inter-sites             #
#   - prendre le prix de référence de l'opération si article sous-traitance #
#   - prendre le coût std de l'article si GPURPRICE=2                       #
#############################################################################
$TARIF_ABSENT
#----- Variables locales -----#
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN, VCRTYP, VCRLIN, VCRSEQ
Local Char     CUR(GLONCUR), UOM(GLONUOM), VCRNUM(GLONVCR), PRHFCY(GLONFCY)
Local Decimal  WBASE, WQTE, GCOEUOM # Issue 10401 - 2013-04-26 by MUARN : prix base
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
#-----
Raz [L]NETPRI, [L]GROPRI, [L]PRIREN, [L]VCRTYP, [L]VCRNUM, [L]VCRLIN, [L]VCRSEQ
Raz [L]LECCMAJ, [L]LECCMIN
Case TRAIT
  When "POH"
    GBIDA1      =[M:POH0]ORDDAT
    [L]BETFCY   =[M:POH0]BETFCY
    [L]CUR      =GCUR
    [L]CHGTYP   =[M:POH1]CHGTYP
    [L]UOM      =[M:POH2]UOM(NOL)
    [L]PRHFCY   =[M:POH2]PRHFCY(NOL)
    [L]VCRTYP   =[M:POH2]VCRTYPORI(NOL)
    [L]VCRNUM   =[M:POH2]VCRNUMORI(NOL)
    [L]VCRLIN   =[M:POH2]VCRLINORI(NOL)
    [L]VCRSEQ   =[M:POH2]VCRSEQORI(NOL)
    If dim([M:POH2]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:POH2]ECCVALMAJ(NOL)
        [L]LECCMIN  =[M:POH2]ECCVALMIN(NOL)
    Endif
  When "POM"
    GBIDA1      =[F:POH]ORDDAT
    [L]BETFCY   =[F:POH]BETFCY
    [L]CUR      =[F:POH]CUR
    [L]CHGTYP   =[F:POH]CHGTYP
    [L]UOM      =[F:POQ]UOM
    [L]PRHFCY   =[F:POQ]PRHFCY
    [L]VCRTYP   =[F:POQ]VCRTYPORI
    [L]VCRNUM   =[F:POQ]VCRNUMORI
    [L]VCRLIN   =[F:POQ]VCRLINORI
    [L]VCRSEQ   =[F:POQ]VCRSEQORI
    [L]LECCMAJ  =[F:POQ]ECCVALMAJ
    [L]LECCMIN  =[F:POQ]ECCVALMIN
  When "POI"
    GBIDA1      =[M:POI1]ORDDAT
    [L]BETFCY   =[M:POI1]BETFCY(NOL)
    [L]CUR      =[M:POI1]CUR(NOL)
    [L]CHGTYP   =[M:POI1]CHGTYP(NOL)
    [L]UOM      =[M:POI1]UOM(NOL)
    [L]PRHFCY   =[M:POI1]PRHFCY(NOL)
    [L]VCRTYP   =[M:POI1]VCRTYPORI(NOL)
    [L]VCRNUM   =[M:POI1]VCRNUMORI(NOL)
    [L]VCRLIN   =[M:POI1]VCRLINORI(NOL)
    [L]VCRSEQ   =[M:POI1]VCRSEQORI(NOL)
    If dim([M:POI1]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:POI1]ECCVALMAJ(NOL)
        [L]LECCMIN  =[M:POI1]ECCVALMIN(NOL)
    Endif
  When "POC", "POV"
    GBIDA1      =[M:POC0]ORDDAT
    [L]BETFCY   =[M:POC0]BETFCY
    [L]CUR      =[M:POC1]CUR
    [L]CHGTYP   =[M:POC1]CHGTYP
    [L]UOM      =[M:POC2]PUU
    [L]PRHFCY   =[M:POC2]PRHFCY
    If dim([M:POC2]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:POC2]ECCVALMAJ
        [L]LECCMIN  =[M:POC2]ECCVALMIN
    Endif
  When "POD"
    GBIDA1      =[F:POQ]DEMRCPDAT
    [L]BETFCY   =[F:POH]BETFCY
    [L]CUR      =[F:POH]CUR
    [L]CHGTYP   =[F:POH]CHGTYP
    [L]UOM      =[F:POQ]PUU
    [L]PRHFCY   =[F:POQ]PRHFCY
    [L]LECCMAJ  =[F:POQ]ECCVALMAJ
    [L]LECCMIN  =[F:POQ]ECCVALMIN
  When "PTH"
    GBIDA1      =[M:PTH0]RCPDAT
    [L]BETFCY   =[M:PTH0]BETFCY
    [L]CUR      =[M:PTH1]NETCUR(NOL)
    [L]CHGTYP   =[M:PTH0]CHGTYP
    [L]UOM      =[M:PTH1]UOM(NOL)
    [L]PRHFCY   =[M:PTH0]PRHFCY
    Raz LECCMAJ, LECCMIN
    If dim([M:PTH1]ECCVALMAJ)>0
        [L]LECCMAJ = string$([M:PTH1]ECCVALMAJ(NOL)<>"$",[M:PTH1]ECCVALMAJ(NOL))
        [L]LECCMIN = string$([M:PTH1]ECCVALMIN(NOL)<>"$",[M:PTH1]ECCVALMIN(NOL))
    Endif
  When "PNH"
    GBIDA1      =[M:PNH1]RTNDAT
    [L]BETFCY   =[M:PNH1]BETFCY
    [L]CUR      =[M:PNH1]NETCUR(NOL)
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[M:PNH1]UOM(NOL)
    [L]PRHFCY   =[M:PNH1]PNHFCY
    If dim([M:PNH1]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:PNH1]ECCVALMAJ(NOL)
        [L]LECCMIN  =[M:PNH1]ECCVALMIN(NOL)
    Endif
  When "PMG"
    GBIDA1      =[F:POH]ORDDAT
    [L]BETFCY   =[F:POH]BETFCY
    [L]CUR      =GCUR
    [L]CHGTYP   =[F:POH]CHGTYP
    [L]UOM      =[F:POC]PUU
    [L]PRHFCY   =[F:POC]PRHFCY
    [L]LECCMAJ  =[F:POC]ECCVALMAJ
    [L]LECCMIN  =[F:POC]ECCVALMIN
  When "PSCM"   : # Matières de l'ordre de sous-traitance
    GBIDA1      =[M:SCO3]OPESTR   # FQ 78120 GA 01/2012 avant [M:SCO1]ORDDAT
    [L]BETFCY   =[M:SCO0]BETFCY
    [L]CUR      =[M:SCO1]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    If dim([M:SCO2]BOMUOM(NOL))>0     # UML actif # FQ 76146 GA 09/2011
       [L]UOM   =[M:SCO2]BOMUOM(NOL)
    Else
       [L]UOM   =[F:ITM]PUU
    Endif
    [L]PRHFCY   =[M:SCO2]STOFCY(NOL)
    If [L]PRHFCY="" [L]PRHFCY   =[M:SCO1]PRHFCY Endif  # STOFCY non renseigné sur les matières fournies par le ss-traitant
    [L]VCRTYP   = 36
    [L]VCRNUM   =[M:SCO0]SCONUM
    [L]VCRLIN   =[M:SCO1]SCILIN
    [L]VCRSEQ   =[M:SCO2]SCMLIN(NOL)
    If dim([M:SCO2]ECCVALMAJ)>0
        [L]LECCMAJ  =[M:SCO2]ECCVALMAJ(NOL)
        [L]LECCMIN  =[M:SCO2]ECCVALMIN(NOL)
    Endif
  When "PSCS"   : # Service de l'ordre de sous-traitance
    GBIDA1      =[M:SCO3]OPESTR   # FQ 78120 GA 01/2012 avant [M:SCO1]ORDDAT
    [L]BETFCY   =[M:SCO0]BETFCY
    [L]CUR      =[M:SCO1]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[M:SCO3]SCOPUU
    [L]PRHFCY   =[M:SCO3]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[M:SCO0]SCONUM
    [L]VCRLIN   =[M:SCO1]SCILIN
    [L]VCRSEQ   =[M:SCO3]SCSLIN
    [L]LECCMAJ  =""
    [L]LECCMIN  =""
  When "FSCM"   : # Matières de l'ordre de sous-traitance
    GBIDA1      =[F:SCS]OPESTR # FQ 78120 GA 01/2012 avant [F:SCO]ORDDAT
    [L]BETFCY   =[F:SCO]BETFCY
    [L]CUR      =[F:SCO]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[F:SCM]BOMUOM
    [L]PRHFCY   =[F:SCM]STOFCY
    If [L]PRHFCY="" [L]PRHFCY   =[F:SCO]MFGFCY Endif  # STOFCY non renseigné sur les matières fournies par le ss-traitant
    [L]VCRTYP   = 36
    [L]VCRNUM   =[F:SCM]SCONUM
    [L]VCRLIN   =[F:SCM]SCILIN
    [L]VCRSEQ   =[F:SCM]SCMLIN
    [L]LECCMAJ  =[F:SCM]ECCVALMAJ
    [L]LECCMIN  =[F:SCM]ECCVALMIN
  When "FSCS"   : # Service de l'ordre de sous-traitance
    GBIDA1      =[F:SCS]OPESTR # FQ 78120 GA 01/2012 avant [F:SCO]ORDDAT
    [L]BETFCY   =[F:SCO]BETFCY
    [L]CUR      =[F:SCO]CUR
    [L]CHGTYP   =[F:BPS]CHGTYP
    [L]UOM      =[F:SCS]SCOPUU
    [L]PRHFCY   =[F:SCS]PRHFCY
    [L]VCRTYP   = 36
    [L]VCRNUM   =[F:SCS]SCONUM
    [L]VCRLIN   =[F:SCS]SCILIN
    [L]VCRSEQ   =[F:SCS]SCSLIN
    [L]LECCMAJ  =""
    [L]LECCMIN  =""
Endcase
#-------------------------------------------------------------#
# Si inter-sites, on prend le prix de base de l'article-vente #
#-------------------------------------------------------------#
If [L]BETFCY=2 & GMODU(5)=2 & [F:ITS]ITMREF<>""
  If [L]UOM<>[F:ITM]SAU
    Call SREC_COE([F:ITM]ITMREF,LBPCORD,[F:ITM]SAU,[L]UOM,GBIDD1) From TRTVENQTE
    If GBIDD1<>0 [L]NETPRI=[F:ITS]BASPRI*GBIDD1 Else Raz [L]NETPRI : Endif
  Else
    [L]NETPRI=[F:ITS]BASPRI
  Endif
  If [L]NETPRI<>0 & [L]CUR<>GSYSCUR
    [L]GROPRI=[L]NETPRI
    Call CONVERT2(GSYSCUR,[L]CUR,GLOCALDEV,[L]CHGTYP,GBIDA1,
&                 [L]GROPRI,[L]NETPRI,[L]STAT) From TRTDEV
  Endif
  #----- Chargement prix net et motif du prix -----#
  [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
  [L]PRIREN=GUPDPRIPUR
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & GPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article de sous-traitance, module GP actif et no OF renseigné    #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG=2 & GMODU(8)=2 & [L]VCRNUM<>"" & [L]VCRTYP=10
  If !clalev([F:MFO])  Local File MFGOPE [MFO] : Endif
# Issue 87203 - 2013-01-14 by CCC
#  Read [MFO] MFO0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:MFO]MFGNUM<>[L]VCRNUM | [F:MFO]OPENUM<>[L]VCRLIN | [F:MFO]OPESPLNUM<>[L]VCRSEQ
    Read [MFO] MFO0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:MFO] Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:MFO]REFPRI<>0
  If [F:MFO]REFPRI<>0
    [L]NETPRI=[F:MFO]REFPRI : # Récupération du prix de référence
    #----- Conversion prix si devise différente -----#
    If GLOCALDEV<>[L]CUR
      Call CONVERT2(GLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:MFO]REFPRI,[L]NETPRI,[L]STAT) From TRTDEV
    Endif
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:MFO]OPEUOM
      Call PCAL_QTY(GBIDD1,[F:MFO]OPEUOM,GBIDD1,[L]UOM,
&                   [F:ITM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
    [L]PRIREN=GUPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & GPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article de sous-traitance et ref EO renseignée                   #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG=2 & [L]VCRNUM<>"" & [L]VCRTYP=36
  If !clalev([F:SCS])  Local File SCOSRV [SCS] : Endif
# Issue 87203 - 2013-01-14 by CCC
#  Read [SCS] SCS0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:SCS]SCONUM<>[L]VCRNUM | [F:SCS]SCILIN<>[L]VCRLIN | [F:SCS]SCSLIN<>[L]VCRSEQ
    Read [SCS] SCS0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:SCS] : Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:SCS]NETPRI<>0
  If [F:SCS]NETPRI<>0
    [L]NETPRI=[F:SCS]NETPRI : # Récupération du prix saisi
    # Issue 116304 - 2016-04-29 by MUARN : Recherche devise pour service
    If !clalev([F:SCO]) : Local File SCOHEAD [SCO] : Endif
    If [F:SCO]SCONUM<>[L]VCRNUM
      Read [SCO]SCO0=[L]VCRNUM
      If fstat : Raz [F:SCO] : Endif
    Endif
    #----- Conversion prix si devise différente -----#
    # Issue 116304 - 2016-04-29 by MUARN : Comparer avec devise service non GLOCALDEV
    # Issue X3-72637-25003 - 2018-01-22 by SR : Modifier aussi les paramètres de CONVERT2
     #If GLOCALDEV<>[L]CUR
#      Call CONVERT2(GLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
#&                   [F:SCS]NETPRI,[L]NETPRI,[L]STAT) From TRTDEV
    If [F:SCO]CUR<>[L]CUR
      Call CONVERT2([F:SCO]CUR,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:SCS]NETPRI,[L]NETPRI,[L]STAT) From TRTDEV
    Endif
    # End issue X3-72637-25003
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:SCS]SCOPUU
      Call PCAL_QTY(GBIDD1,[F:SCS]SCOPUU,GBIDD1,[L]UOM,
&                   [F:SCS]SRVITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
    [L]PRIREN=GUPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & GPURPRICE=2
    Gosub COUT_STD
  Endif
#---------------------------------------------------------------------#
# Si article matière fournie et ref EO renseignée                     #
#---------------------------------------------------------------------#
Elsif [F:ITM]SCSFLG<>2 & [F:ITM]SCPFLG<>2 & [L]VCRNUM<>"" & [L]VCRTYP=36
  If !clalev([F:SCM])  Local File SCOMAT [SCM] : Endif
# Issue 87203 - 2013-01-14 by CCC
#  Read [SCM] SCM0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
  If [F:SCM]SCONUM<>[L]VCRNUM | [F:SCM]SCILIN<>[L]VCRLIN | [F:SCM]SCMLIN<>[L]VCRSEQ
  Read [SCM] SCM0=[L]VCRNUM;[L]VCRLIN;[L]VCRSEQ
    If fstat Raz [F:SCM] Endif # Issue 89721 GA 05/2013
  Endif
  # Issue 89721 GA 05/2013 If !fstat & [F:SCM]GROPRI<>0
  If [F:SCM]GROPRI<>0
    [L]NETPRI=[F:SCM]GROPRI : # Récupération du prix saisi
    # Issue X3-72637- 25003 - 2018-01-19 by SR : Récupérer la devise de l'E.O cf SAM 116304
    If !clalev([F:SCO]) : Local File SCOHEAD [SCO] : Endif
    If [F:SCO]SCONUM<>[L]VCRNUM
      Read [SCO]SCO0=[L]VCRNUM
      If fstat : Raz [F:SCO] : Endif
    Endif
    #----- Conversion prix si devise différente -----#
    # Issue X3-72637-25003 - 2018-01-19 by SR : Faire comme pour le service cf SAM 116304
    #If GLOCALDEV<>[L]CUR
    #      Call CONVERT2(GLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
#&                   [F:SCM]GROPRI,[L]NETPRI,[L]STAT) From TRTDEV
    If [F:SCO]CUR<>[L]CUR
      Call CONVERT2([F:SCO]CUR,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
&                   [F:SCM]GROPRI,[L]NETPRI,[L]STAT) From TRTDEV
    Endif
    # End issue X3-72637-25003
    #----- Conversion prix si unité différente -----#
    If [L]UOM<>[F:SCM]STU
      Call PCAL_QTY(GBIDD1,[F:SCM]STU,GBIDD1,[L]UOM,
&                   [F:SCM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1
      If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
      [L]NETPRI=[L]NETPRI*[L]COEFUNITE
    Endif
    #----- Chargement prix net, prix brut et motif du prix -----#
    [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
    [L]PRIREN=GUPDPRIPUR
  Endif
  #----- Prendre le coût standard si prix nul -----#
  If [L]NETPRI=0 & GPURPRICE=2
    Gosub COUT_STD
  Endif
Endif
#-------------#
# Fin commune #
#-------------#
# Issue 10401 - 2013-04-26 by MUARN : prix de base
If [L]NETPRI = 0
  Read [ITM]ITM0=LITMREF
  [L]NETPRI = [F:ITM]PURBASPRI
Endif
If [L]NETPRI = 0 & GPURPRICE=2
  Gosub COUT_STD
Endif

[L]GROPRI=[L]NETPRI
Case TRAIT
  When "POH"
    # Issue 10401 - 2013-04-26 by MUARN : prix base conversion devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
        Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:POH0]ORDDAT,
&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:POH2]ITMREF(NOL)
        Read [ITM] ITM0=[M:POH2]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:POH2]UOM(NOL)
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POH2]UOM(NOL),
&             [M:POH2]ITMREF(NOL),[M:POH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif
    [M:POH2]NETPRI(NOL)=[L]NETPRI
    [M:POH2]GROPRI(NOL)=[L]NETPRI
    [M:POH2]PRIREN(NOL)=[L]PRIREN
  When "POM"
    [F:POP]NETPRI      =[L]NETPRI
    [F:POP]GROPRI      =[L]NETPRI
    [F:POP]PRIREN      =[L]PRIREN
  When "POI"
    # Issue 10401 - 2013-04-26 by MUARN : prix base conversion devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
        Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:POI1]ORDDAT,
&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
        Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:POI1]UOM(NOL)
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POI1]UOM(NOL),
&             [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif
    [M:POI1]NETPRI(NOL)=[L]NETPRI
    [M:POI1]GROPRI(NOL)=[L]NETPRI
    [M:POI1]PRIREN(NOL)=[L]PRIREN
  When "POC"
    # Issue 10401 - 2013-04-26 by MUARN : prix base conversion devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
          Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:POC0]ORDDAT,
&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:POC2]ITMREF
        Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:POC2]PUU
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POC2]PUU,
&             [M:POC2]ITMREF,[M:POC0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif
    [M:POC2]NETPRI(NOL)=[L]NETPRI
    [M:POC2]GROPRI(NOL)=[L]NETPRI
    [M:POC2]PRIREN(NOL)=[L]PRIREN
  When "POV"
    # Issue 10401 - 2013-04-26 by MUARN : prix de base avec devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
          Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:POC0]ORDDAT,
&                   WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:POC2]ITMREF
        Read [ITM] ITM0=[M:POC2]ITMREF : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:POC2]PUU
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:POC2]PUU,
&             [M:POC2]ITMREF,[M:POC0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif

    [M:POC2]PRIVLT     =[L]NETPRI
  When "POD"
    # Issue 10401 - 2013-04-26 by MUARN : prix de base avec devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
          Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [F:POQ]DEMRCPDAT,
&                   WBASE, [L]NETPRI, STAT) From TRTDEV
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[F:POP]ITMREF
        Read [ITM] ITM0=[F:POP]ITMREF : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [F:POQ]PUU
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[F:POQ]PUU,
&             [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif

    [F:POP]NETPRI      =[L]NETPRI
    [F:POP]GROPRI      =[L]NETPRI
    [F:POP]PRIREN      =[L]PRIREN
  When "PTH"
    # Issue 10401 - 2013-04-26 by MUARN : prix de base avec devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
         Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:PTH0]RCPDAT,
&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
        Read [ITM] ITM0=[M:PTH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:PTH1]UOM(NOL)
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:PTH1]UOM(NOL),
&             [M:PTH1]ITMREF(NOL),[M:PTH0]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif

    [M:PTH1]NETPRI(NOL)=[L]NETPRI
    [M:PTH1]GROPRI(NOL)=[L]NETPRI
    [M:PTH1]PRIREN(NOL)=[L]PRIREN
  When "PNH"
    # Issue 10401 - 2013-04-26 by MUARN : prix de base avec devise
    If [L]PRIREN <> GUPDPRIPUR
      If GSYSCUR <> [L]CUR
        WBASE=[L]NETPRI
        # sr 04.12 Si = cout standard, la conversion &a eja ete faite
        #If [L]PRIREN <> GUPDPRIPUR
        #MAE, bug 99122
#       Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:PTH0]RCPDAT,
#&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        Call CONVERT2(GSYSCUR, [L]CUR, GLOCALDEV, [L]CHGTYP, [M:PNH1]RTNDAT,
&                     WBASE, [L]NETPRI, STAT) From TRTDEV
        #Endif
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI=[L]NETPRI
      Endif
      # Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
      If [F:ITM]ITMREF<>[M:PNH1]ITMREF(NOL)
        Read [ITM] ITM0=[M:PNH1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
      Endif
      If [F:ITM]PUU <> [M:PNH1]UOM(NOL)
        Call PCAL_QTY(1,[F:ITM]PUU,WQTE,[M:PNH1]UOM(NOL),
&             [M:PNH1]ITMREF(NOL),[M:PNH1]BPSNUM,1,GCOEUOM) From TRTACHQTE1
        [L]NETPRI = [L]NETPRI/GCOEUOM
        [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
        [L]GROPRI = [L]NETPRI
      Endif
    Endif
    # fin Issue 10401 - 2013-04-26 by MUARN : prix base conversion UA
    # Issue 95247 - 2014-01-03 by MUARN : a n'effectuer que si NETPRI est différent de 0
    If [L]NETPRI <>0
      [L]PRIREN = GUPDPRIPUR
    Endif

    [M:PNH1]NETPRI(NOL)=[L]NETPRI
    [M:PNH1]GROPRI(NOL)=[L]NETPRI
    [M:PNH1]PRIREN(NOL)=[L]PRIREN
  When "PMG"
    [F:POC]PRIVLT      =[L]NETPRI
  When "PSCM"
    [M:SCO2]REFPRI(NOL)=[L]NETPRI
    [M:SCO2]NETPRI(NOL)=[L]NETPRI
    [M:SCO2]GROPRI(NOL)=[L]NETPRI
    [M:SCO2]PRIREN(NOL)=[L]PRIREN
  When "PSCS"
    [M:SCO3]REFPRI =[L]NETPRI
    [M:SCO3]NETPRI =[L]NETPRI
    [M:SCO3]GROPRI =[L]NETPRI
    [M:SCO3]PRIREN =[L]PRIREN
  When "FSCM"
    [F:SCM]REFPRI=[L]NETPRI
    [F:SCM]NETPRI=[L]NETPRI
    [F:SCM]GROPRI=[L]NETPRI
    [F:SCM]PRIREN=[L]PRIREN
  When "FSCS"
    [F:SCS]REFPRI =[L]NETPRI
    [F:SCS]NETPRI =[L]NETPRI
    [F:SCS]GROPRI =[L]NETPRI
    [F:SCS]PRIREN =[L]PRIREN
Endcase
Return

#-------------------------------------------------------------------------#
# Le tarif par défaut est le coût std article suivant paramètre GPURPRICE #
#-------------------------------------------------------------------------#
$COUT_STD
If !clalev([F:ITC])  Local File ITMCOST [ITC] : Endif
Call GETPRI([F:ITM]ITMREF,LECCMAJ,LECCMIN,[L]PRHFCY,GBIDA1,1,"","",1,[L]NETPRI,STAT) From STKVAL
If !STAT & [F:ITC]VLTTOT<>0
  [L]NETPRI=[F:ITC]VLTTOT
  #----- Conversion prix si devise différente -----#
  If GLOCALDEV<>[L]CUR
    Call CONVERT2(GLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,datesyst,
&                 [F:ITC]VLTTOT,[L]NETPRI,[L]STAT) From TRTDEV
  Endif
  #----- Conversion prix si unité différente -----#
  If [L]UOM<>[F:ITM]STU
    Call PCAL_QTY(GBIDD1,[F:ITM]STU,GBIDD1,[L]UOM,
&                 [F:ITM]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1
  If [L]COEFUNITE=0  [L]COEFUNITE=1 : Endif
    [L]NETPRI=[L]NETPRI*[L]COEFUNITE
  Endif
  #----- Chargement prix net, prix brut et motif du prix -----#
  [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
  [L]PRIREN=GUPDPRIPUR
Endif
Return


##########################################################################
# TAR_GROUPE : S/P de traitement des tarifs groupés         MBT 15/01/98 #
# ---------------------------------------------------------------------- #
# Subprog TAR_GROUPE (TRAIT)                                             #
#    TRAIT : Code traitement  POI = Traitement depuis cdes / articles    #
#                             POH = Traitement depuis cdes standards     #
#                                                                        #
# ATTENTION : GPURGRUDIS  Automatisme tarifs groupés  1 = Non            #
#                                                     2 = Oui            #
#                                                     3 = A la demande   #
##########################################################################
Subprog TAR_GROUPE (TRAIT)
Value  Char     TRAIT
#----- Variables locales -----#
Local  Char     VAT(GLONVAT)(3), FOCITMREF(GLONITM), FOCUOM(GLONUOM)
Local  Decimal  WCLCAMT(1..7)
Local  Decimal  MONTANT(0..10),  FOCQTY
Local  Decimal  GROPRI,          DISCRGVAL(0..8),    NETPRI, QTE
Local  Date     PLISTRDAT,       PLIENDDAT
Local  Shortint MOTIF(0..10),    PRIORITE(0..10),    FOCMOTIF
Local  Char     PLI(GLONPLI)(0..10)
Local  Char     PLICRD(30)(0..10)
Local  Integer  PLILIN(0..10)
Local  Libelle  INTERDIT,  ERR
Local  Integer  OK
Local  Shortint SVGNOLIGN, I, J, NOL
#---- Paramètres complémentaires appel recherche tarifs
Local  Char     PARAM_T(25)(0..5) : # Indice 0 = coef. multiplicateur UV --> US
#----- Pour tarifs inter-sociétés -----#
Local  Char     LBPSNUM (GLONBPS) : # Fournisseur
Local  Char     LITMREF (GLONITM) : # Article
Local  Char     LPOHFCY (GLONFCY) : # Site cde achat
Local  Char     LPRHFCY (GLONFCY) : # Site reception achat
Local  Char     LSALFCY (GLONFCY) : # Site cde vente
Local  Char     LSALCPY (GLONCPY) : # Société cde vente
Local  Char     LBPCORD (GLONBPC) : # Client cde vente
#----- Sauvegarde de nolign -----#
SVGNOLIGN=nolign : NOL=nolign-1
#----- Test paramètre question traitement tarifs groupés ? Non/Oui -----#
If GPURGRUDIS<2  Goto FINTGR : Endif
If GPURGRUDIS=3 & TRAIT<>"POI"
  OK=2 : Call OUINON(mess(61,196,1),OK) From GESECRAN
  If OK=1  Goto FINTGR : Endif
Endif
#----- Chargement fichier lien PPRICSTRUCT -----#
If TRAIT<>"POI"
  nolign=1 : # Pas de notion de ligne pour les tarifs groupés
Endif
#----- Traitement des tarifs groupés suivant la valeur du code -----#
Case TRAIT
  When "POI" : Gosub TGRPOI
  When "POH" : Gosub TGRPOH
Endcase
#----- Restitution de nolign -----#
$FINTGR
nolign=SVGNOLIGN
End

#-----------------------------------------------------------------#
# Traitements des tarifs groupés depuis les commandes par article #
#-----------------------------------------------------------------#
$TGRPOI
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPS] BPS0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE    |
&  [F:MVS]BPSNUM<>[M:POI1]BPSNUM(NOL) | [F:MVS]CUR<>[M:POI1]CUR(NOL)
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:POI1]BPSNUM(NOL);[M:POI1]CUR(NOL)
  If fstat Raz [F:MVS] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:POI1]BPSNUM(NOL) : LITMREF=""
LPOHFCY=[M:POI1]POHFCY      : LPRHFCY=""
Gosub IS_ALIFICVEN From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
  Read [BPR] BPR0=[M:POI1]BPSNUM(NOL) : If fstat Raz [F:BPR] : Endif
Endif
#-----
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#------------------ Recherche des tarifs groupés ------------------#
# Remarque : Les variables [M:POI1]QTYPUU(NOL) et [M:POI1]PUU(NOL) #
#            ne sont pas utilisées.                                #
#------------------------------------------------------------------#
Call TARIFRECH(6,2,"POI",[M:POI1]ORDDAT,[M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&              [M:POI1]CHGTYP(NOL),[M:POI1]CUR(NOL),1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#----- Recalcul prix net HT, montant HT ligne et montant TTC ligne -----#
For I=0 To [M:POI1]NBLIG-1
  If [M:POI1]GRPFLG(I)=1
    GROPRI=[M:POI1]GROPRI(I)
    If dim([M:POI1]DISCRGVAL1(I))>0 DISCRGVAL(0)=[M:POI1]DISCRGVAL1(I) : Endif
    If dim([M:POI1]DISCRGVAL2(I))>0 DISCRGVAL(1)=[M:POI1]DISCRGVAL2(I) : Endif
    If dim([M:POI1]DISCRGVAL3(I))>0 DISCRGVAL(2)=[M:POI1]DISCRGVAL3(I) : Endif
    If dim([M:POI1]DISCRGVAL4(I))>0 DISCRGVAL(3)=[M:POI1]DISCRGVAL4(I) : Endif
    If dim([M:POI1]DISCRGVAL5(I))>0 DISCRGVAL(4)=[M:POI1]DISCRGVAL5(I) : Endif
    If dim([M:POI1]DISCRGVAL6(I))>0 DISCRGVAL(5)=[M:POI1]DISCRGVAL6(I) : Endif
    If dim([M:POI1]DISCRGVAL7(I))>0 DISCRGVAL(6)=[M:POI1]DISCRGVAL7(I) : Endif
    If dim([M:POI1]DISCRGVAL8(I))>0 DISCRGVAL(7)=[M:POI1]DISCRGVAL8(I) : Endif
    If dim([M:POI1]DISCRGVAL9(I))>0 DISCRGVAL(8)=[M:POI1]DISCRGVAL9(I) : Endif
    If dim(GCALNETLIN)>0  GCALNETLIN=I+1        : Endif
    If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
    Call CALNET(2,[F:BPS]PLISTC,GROPRI,DISCRGVAL,[M:POI1]QTYUOM(I),NETPRI,
&               [M:POI1]CUR(I)) From TRTPRICE
    [M:POI1]NETPRI(I)=NETPRI
    VAT(0)=[M:POI1]VAT1(I) : WCLCAMT(1)=[M:POI1]CLCAMT1(I)
    VAT(1)=[M:POI1]VAT2(I) : WCLCAMT(2)=[M:POI1]CLCAMT2(I)
    VAT(2)=[M:POI1]VAT3(I) : WCLCAMT(3)=[M:POI1]CLCAMT3(I)
    [M:POI1]LINAMT(I)=[M:POI1]NETPRI(I)*[M:POI1]QTYUOM(I)
    Call ARRDEV([M:POI1]LINAMT(I),[M:POI1]CUR(I)) From TRTDIV
    Call CLCTAXEMNT2([M:POI1]LINAMT(I),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                    [M:POI1]LINATIAMT(I)) From TRTX3
    Call ARRDEV([M:POI1]LINATIAMT(I),[M:POI1]CUR(I)) From TRTDIV
    If [M:POI1]CREFLG(I)<>0  [M:POI1]UPDFLG(I)=1 : Endif
  Endif
Next I
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
Return

#--------------------------------------------------------------#
# Traitement des tarifs groupés depuis les commandes standards #
#--------------------------------------------------------------#
$TGRPOH
#----- Lecture si nécessaire des fichiers utilisés pour le tarif -----#
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
  Read [BPS] BPS0=[M:POH0]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
If [F:MVS]BPSRSK<>[F:BPS]BPSRSK  | [F:MVS]CPY<>GSOCIETE |
&  [F:MVS]BPSNUM<>[M:POH0]BPSNUM | [F:MVS]CUR<>GCUR
  Read [MVS] MVS0=[F:BPS]BPSRSK;GSOCIETE;[M:POH0]BPSNUM;GCUR
  If fstat  Raz [F:MVS] : Endif
Endif
#----- Lecture fichiers ventes si inter-sociétés -----#
LBPSNUM=[M:POH0]BPSNUM : LITMREF=""
LPOHFCY=[M:POH0]POHFCY : LPRHFCY=""
Gosub IS_ALIFICVEN  From TRTPRICE
# Issue 75584 - 2011-10-03 by SR : On se repositionne sur le bon Tiers
If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
  Read [BPR] BPR0=[M:POH0]BPSNUM : If fstat  Raz [F:BPR] : Endif
Endif
#-----
Call ALIPLK (TRAIT) From TRTPRICE
[F:PPK]SALCPY=LSALCPY : [F:PPK]SALFCY=LSALFCY
#---------------- Recherche des tarifs groupés ----------------#
# Remarque : Les variables [M:POH2]QTYPUU(0) et [M:POH2]PUU(0) #
#            ne sont pas utilisées.                            #
#--------------------------------------------------------------#
Raz [M:POH2]GRPFLG
#----- Sauvegarde du tableau des lignes pour restitution des lignes non modifiables -----#
If !clalev([M:POHX])  Local Mask POH2 [POHX] : Default Mask [POH2] : Endif
Raz [M:POHX] : Transmask [M:POH2] To [M:POHX]
#-----
For I=0 To [M:POH2]NBLIG-1
  Call MAJ_CUMULS_LIG(I,-2) From SUBPOHC
  Call MAJ_BASTAX_LIG(I,-1) From SUBPOHC
  If [M:POH2]LINTYP(I)=2  [M:POH2]GRPFLG(I)=1 : Endif : # Pas de tarifs groupés
Next I
#----- Recherche et application des tarifs groupés -----#
Call TARIFRECH(6,2,"POH",[M:POH0]ORDDAT,[M:POH2]QTYPUU(0),[M:POH2]PUU(0),
&              [M:POH1]CHGTYP,GCUR,1,VAT,PARAM_T,
&              MONTANT,MOTIF,PRIORITE,
&              PLI,PLICRD,PLILIN,
&              FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,
&              PLISTRDAT,PLIENDDAT,INTERDIT,ERR) From TRTPRICE
#-----
For I=0 To [M:POH2]NBLIG-1
  If [M:POH2]LINRCPNBR(I)>0 |
&    [M:POH2]LININVNBR(I)>0 |
&    [M:POH2]LINCLEFLG(I)=2 |
&    [M:POH2]LINTYP   (I)=2
    [M:POH2]GROPRI(I)=[M:POHX]GROPRI(I)
    If dim([M:POH2]DISCRGVAL1(I))>1 [M:POH2]DISCRGVAL1(I)=[M:POHX]DISCRGVAL1(I) : Endif
    If dim([M:POH2]DISCRGVAL2(I))>1 [M:POH2]DISCRGVAL2(I)=[M:POHX]DISCRGVAL2(I) : Endif
    If dim([M:POH2]DISCRGVAL3(I))>1 [M:POH2]DISCRGVAL3(I)=[M:POHX]DISCRGVAL3(I) : Endif
    If dim([M:POH2]DISCRGVAL4(I))>1 [M:POH2]DISCRGVAL4(I)=[M:POHX]DISCRGVAL4(I) : Endif
    If dim([M:POH2]DISCRGVAL5(I))>1 [M:POH2]DISCRGVAL5(I)=[M:POHX]DISCRGVAL5(I) : Endif
    If dim([M:POH2]DISCRGVAL6(I))>1 [M:POH2]DISCRGVAL6(I)=[M:POHX]DISCRGVAL6(I) : Endif
    If dim([M:POH2]DISCRGVAL7(I))>1 [M:POH2]DISCRGVAL7(I)=[M:POHX]DISCRGVAL7(I) : Endif
    If dim([M:POH2]DISCRGVAL8(I))>1 [M:POH2]DISCRGVAL8(I)=[M:POHX]DISCRGVAL8(I) : Endif
    If dim([M:POH2]DISCRGVAL9(I))>1 [M:POH2]DISCRGVAL9(I)=[M:POHX]DISCRGVAL9(I) : Endif
    If dim([M:POH2]DISCRGREN1(I))>1 [M:POH2]DISCRGREN1(I)=[M:POHX]DISCRGREN1(I) : Endif
    If dim([M:POH2]DISCRGREN2(I))>1 [M:POH2]DISCRGREN2(I)=[M:POHX]DISCRGREN2(I) : Endif
    If dim([M:POH2]DISCRGREN3(I))>1 [M:POH2]DISCRGREN3(I)=[M:POHX]DISCRGREN3(I) : Endif
    If dim([M:POH2]DISCRGREN4(I))>1 [M:POH2]DISCRGREN4(I)=[M:POHX]DISCRGREN4(I) : Endif
    If dim([M:POH2]DISCRGREN5(I))>1 [M:POH2]DISCRGREN5(I)=[M:POHX]DISCRGREN5(I) : Endif
    If dim([M:POH2]DISCRGREN6(I))>1 [M:POH2]DISCRGREN6(I)=[M:POHX]DISCRGREN6(I) : Endif
    If dim([M:POH2]DISCRGREN7(I))>1 [M:POH2]DISCRGREN7(I)=[M:POHX]DISCRGREN7(I) : Endif
    If dim([M:POH2]DISCRGREN8(I))>1 [M:POH2]DISCRGREN8(I)=[M:POHX]DISCRGREN8(I) : Endif
    If dim([M:POH2]DISCRGREN9(I))>1 [M:POH2]DISCRGREN9(I)=[M:POHX]DISCRGREN9(I) : Endif
    [M:POH2]NETPRI(I)=[M:POHX]NETPRI(I)
    [M:POH2]GRPFLG(I)=0
  Elsif [M:POH2]GRPFLG(I)=1
    Call REAJUST_TARIF("POH2",I,[M:POH2]UOM(I),[M:POH2]UOM(I),1,1) From TRTACHPRI1
    Call MAJ_CALTAX_LIG("POH2",I) From TRTACHDIV1
    If [M:POH2]CREFLG(I)<>0  [M:POH2]UPDFLG(I)=1 : Endif
    [M:POH2]WAPPFLG(I)=2
  Endif
  Call MAJ_BASTAX_LIG(I,+1) From SUBPOHC
  Call MAJ_CUMULS_LIG(I,+2) From SUBPOHC
Next I
#-----
If GMESSAGE<>""  Gosub AVERTIR_PRIX_NEGATIF : Endif
#----- Recalcul totaux HT, TVA et TTC -----#
[M:POH3]TOTORD=sum([M:POH3]INVORDAMT)+sum([M:POH3]INVLINAMT)+[M:POH3]TOTLINAMT
If [M:POH1]VACTYP<>4
  [M:POH3]TOTTAXAMT=sum([M:POH3]AMTTAX)
Else
  [M:POH3]TOTTAXAMT=0
Endif
[M:POH3]TTVORD=[M:POH3]TOTORD+[M:POH3]TOTTAXAMT
If !GIMPORT  Affzo [POH2]1-99 : Affzo [POH3]5-15 : Endif
#-----
Return


###############################################################################
# AVERTIR_PRIX_NEGATIF : Gosub d'avertissement en cas de prix net négatif     #
# --------------------------------------------------------------------------- #
# Test GTRACE   pour écriture dans le fichier trace                           #
# Test GSERVEUR pour affichage du message si le traitement n'est pas un BATCH #
###############################################################################
$AVERTIR_PRIX_NEGATIF
If GMESSAGE=""  Return : Endif
If GTRACE<>""
  Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Elsif GSERVEUR=0
  Call MESSAGE(GMESSAGE)     From GESECRAN
Endif
Raz GMESSAGE, GERR
Return

