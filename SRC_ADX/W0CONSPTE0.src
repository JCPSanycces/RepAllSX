## Zone PTESTA4
mkstat = 0
zoncou = "PTESTA4"
indice = 0
IMPENT = [M]PTESTA4
If varinit([M]PTESTA4,indice)=0
 IMPENT = 1
Endif
If varmode([M]PTESTA4,indice)=0
 [M]PTESTA4(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTESTA4" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PTESTA4(indice)
 Endif
Endif
[M]PTESTA4 = IMPENT

## Zone PTESTA5
mkstat = 0
zoncou = "PTESTA5"
indice = 0
IMPENT = [M]PTESTA5
If varinit([M]PTESTA5,indice)=0
 IMPENT = 1
Endif
If varmode([M]PTESTA5,indice)=0
 [M]PTESTA5(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTESTA5" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PTESTA5(indice)
 Endif
Endif
