####################################
IMPTBL = 0

## Zone PTESTA1
mkstat = 0
zoncou = "PTESTA1"
indice = 0
IMPENT = [M]PTESTA1
If varinit([M]PTESTA1,indice)=0
 IMPENT = 1
Endif
If varmode([M]PTESTA1,indice)=0
 [M]PTESTA1(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTESTA1" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PTESTA1(indice)
 Endif
Endif
[M]PTESTA1 = IMPENT

## Zone PTESTA2
mkstat = 0
zoncou = "PTESTA2"
indice = 0
IMPENT = [M]PTESTA2
If varinit([M]PTESTA2,indice)=0
 IMPENT = 1
Endif
If varmode([M]PTESTA2,indice)=0
 [M]PTESTA2(indice) = IMPENT
