#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CONSPTE0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!A",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PAUS
mkstat = 0
zoncou = "PAUS"
indice = 0
If varmode([M]PAUS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAUS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AUS","!",[M]PAUS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PAUS" : GZNUM = 16058 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone UOM
mkstat = 0
zoncou = "UOM"
indice = 0
If varmode([M]UOM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UOM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TUN","!B",[M]UOM,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "UOM" : GZNUM = 2915 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PJTDEB
mkstat = 0
zoncou = "PJTDEB"
indice = 0
WCHAR = [M]PJTDEB
If varmode([M]PJTDEB,indice)=0
 SAVACT = GACTION : GACTION = "PJTBEFZON"
 Call PJT_BEFORE_ZONE([M]PJTDEB,"PTE0","PJTDEB",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJTDEB : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTDEB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "PJTCTL"
  Call PJT_CONTROL([M]PJTDEB,"PTE0","PJTDEB",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PJTDEB" : GZNUM = 54671 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]PJTDEB
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]PJTDEB = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PJTDEB" : GZNUM = 54671 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]PJTDEB or IMPMOD
     SAVACT = GACTION : GACTION = "PJTAFTMOD"
     Call PJT_AFTER_MODIFY([M]PJTDEB,"PTE0","PJTDEB",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PJTDEB" : GZNUM = 54671 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "STD"
      Call AM_PJTDEB([M]PJTDEB) From CNSPTESTD
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "PJTDEB" : GZNUM = 54671 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PJTFIN
mkstat = 0
zoncou = "PJTFIN"
indice = 0
WCHAR = [M]PJTFIN
If varmode([M]PJTFIN,indice)=0
 SAVACT = GACTION : GACTION = "PJTBEFZON"
 Call PJT_BEFORE_ZONE([M]PJTFIN,"PTE0","PJTFIN",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJTFIN : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTFIN" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "PJTCTL"
  Call PJT_CONTROL([M]PJTFIN,"PTE0","PJTFIN",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PJTFIN" : GZNUM = 54672 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]PJTFIN
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]PJTFIN = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PJTFIN" : GZNUM = 54672 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CTLALPV"
    Call CTLALPV([M]PJTFIN,[M:PTE0]PJTDEB) From CONTDIV
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PJTFIN" : GZNUM = 54672 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_PJTFIN([M]PJTFIN) From CNSPTESTD
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PJTFIN" : GZNUM = 54672 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]PJTFIN or IMPMOD
       SAVACT = GACTION : GACTION = "PJTAFTMOD"
       Call PJT_AFTER_MODIFY([M]PJTFIN,"PTE0","PJTFIN",0,9,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_ANO,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[V]CST_AYES,[M:PTE0]FCY,"","","","","") From TRTPJT
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "PJTFIN" : GZNUM = 54672 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone PJTDSPALL
mkstat = 0
zoncou = "PJTDSPALL"
indice = 0
IMPENT = [M]PJTDSPALL
If varinit([M]PJTDSPALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]PJTDSPALL,indice)=0
 [M]PJTDSPALL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJTDSPALL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PJTDSPALL(indice)
 Endif
Endif
[M]PJTDSPALL = IMPENT

## Zone PTEDATDEB
mkstat = 0
zoncou = "PTEDATDEB"
indice = 0
If varmode([M]PTEDATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTEDATDEB" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PTEDATDEB=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PTEDATDEB" : GZNUM = 1805 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PTEDATFIN
mkstat = 0
zoncou = "PTEDATFIN"
indice = 0
If varmode([M]PTEDATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PTEDATFIN" : Gosub ACTION From =IMPTRT
 Endif
 If [M]PTEDATFIN=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]PTEDATFIN,[M:PTE0]PTEDATDEB) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PTEDATFIN" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
