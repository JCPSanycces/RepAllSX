#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque INVCNDSIMUL
# action INVCNDSIM (remplace le sous-pro SIMUL de SUBINVCND)
# simule la rûˋpartition des paiements ûˋchelonnûˋs (conditions de paiement)

$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return
#--------------------------------------
$OUVRE
If clalev([F:FCY])=0    : Local File FACILITY  [FCY]    : Endif
If clalev([F:CPY])=0    : Local File COMPANY   [CPY]    : Endif
If clalev([F:INVCND])=0 : Local File TABINVCND [INVCND] : Endif

  Global Instance GCLSINVCNDSIM Using C_TABINVCNDSIM

Return
#--------------------------------------
$FERME

  If (GCLSINVCNDSIM <> null) : FreeGroup GCLSINVCNDSIM : Endif
  Kill GCLSINVCNDSIM

Return
#--------------------------------------
$DEBUT
Local Char    DEV(GLONCUR), INVCNDCOD(GLONINVCND), FCY(GLONFCY), SOCIETE(GLONCPY), LEG(GLONADI),BPCORD(GLONBPC)
Local Decimal MNT
Local Date    DAT

  If GFONCTION="GESINVCND"
     INVCNDCOD = [M:INVCND1]INVCND
  Else
     INVCNDCOD = VALEUR
  Endif
  If INVCNDCOD="" : INVCNDCOD=[F:INVCND]INVCND : Endif

  LEG    = PARAM(1)
  FCY    = PARAM(2)
  BPCORD = PARAM(3)
  DAT    = PARAM(4)
  DEV    = PARAM(5)
  MNT    = val(PARAM(6))

  If FCY=""
    FCY=GFCYDEF(5)
  Endif

  If [F:FCY]FCY<>[L]FCY
    Read [F:FCY]FCY0=[L]FCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  If DEV = ""
   If FCY<>""
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     DEV = [F:CPY]ACCCUR
   Else
     DEV=GSYSCUR
   Endif
  Endif

  Case GACTION
   When "INVCNDSIM" :
    [M:INVCNDSI]SIMINVCND = INVCNDCOD
    [M:INVCNDSI]SIMLEG    = LEG
    [M:INVCNDSI]SIMFCY    = FCY
    [M:INVCNDSI]SIMBPCORD = BPCORD
    If MNT=0 : MNT=1000 : Endif
    [M:INVCNDSI]SIMTOT    = MNT
    [M:INVCNDSI]CUR       = DEV
    [M:INVCNDSI]SIMDAT    = DAT
    Gosub TR2
  Endcase
Return
#--------------------------------------
$TR1
Case COUZON
 When "SIMTOT" : [M:INVCNDSI]SIMTOT = val(CZ)
 When "SIMDAT" : [M:INVCNDSI]SIMDAT = gdat$(val(mid$(CZ,1,2)),val(mid$(CZ,4,2)),val(mid$(CZ,7,4)))
Endcase
$TR2
Local Integer MY_STATUS

  If (GCLSINVCNDSIM <> null) : FreeGroup GCLSINVCNDSIM : GCLSINVCNDSIM=null : Endif
  GCLSINVCNDSIM = NewInstance C_TABINVCNDSIM AllocGroup null
  #--Calling the method SIMULATE of the TABINVCNDSIM class
  GCLSINVCNDSIM.INVCND = [M:INVCNDSI]SIMINVCND
  GCLSINVCNDSIM.LEG    = [M:INVCNDSI]SIMLEG

  MY_STATUS = fmet GCLSINVCNDSIM.SIMULATE([M:INVCNDSI]SIMFCY,[M:INVCNDSI]SIMBPCORD,[M:INVCNDSI]SIMDAT,[M:INVCNDSI]CUR,[M:INVCNDSI]SIMTOT)
  If ([L]MY_STATUS >= [V]CST_AERROR)
    # Error management
    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GCLSINVCNDSIM)
    MY_STATUS = func SUBINVCND.RAZMAXMSG(GCLSINVCNDSIM,"") #"INVCNDCOLL")
    GERR = 1
    Return
  Endif

  nolign=0
  For ILINE=1 To maxtab(GCLSINVCNDSIM.INVCNDCOLL)
    If GCLSINVCNDSIM.INVCNDCOLL(ILINE)<>null and find(GCLSINVCNDSIM.INVCNDCOLL(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      nolign += 1
      [M:INVCNDSI]INVCNDLIN (nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).INVCNDLIN
      [M:INVCNDSI]INVPERCENT(nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).INVPERCENT
      [M:INVCNDSI]SIMAMT    (nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).SIMAMT
      [M:INVCNDSI]PERFROM   (nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).PERFROM
      [M:INVCNDSI]PERTO     (nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).PERTO
      [M:INVCNDSI]NEXINVDAT (nolign-1) = GCLSINVCNDSIM.INVCNDCOLL(ILINE).NEXINVDAT
      If GERR = 1 Then
        Break
      Endif
    Endif
  Next
  [M:INVCNDSI]NBLIG=nolign

Affzo [M:INVCNDSI]

[F:INVCND]INVCND = [M:INVCNDSI]SIMINVCND
Return
#--------------------------------------
######################################################################################
## Etiquette ajoutûˋe par le superviseur (ûˋcran INVCNDSIMUL) 10/11/2015 17:17:56 (CPO)
######################################################################################
Subprog AM_SIMTOT(VALEUR)
Variable Decimal VALEUR
  [M:INVCNDSI]SIMTOT=VALEUR
  Gosub TR2
End
#--------------------------------------
Subprog AM_SIMDAT(VALEUR)
Variable Date    VALEUR
  [M:INVCNDSI]SIMDAT=VALEUR
  Gosub TR2
End
#--------------------------------------
Subprog AM_SIMFCY(VALEUR)
Variable Char    VALEUR()
  [M:INVCNDSI]SIMFCY=VALEUR
  Gosub TR2
End
#--------------------------------------
Subprog AM_SIMBPCORD(VALEUR)
Variable Char    VALEUR()
  [M:INVCNDSI]SIMBPCORD=VALEUR
  Gosub TR2
End
#--------------------------------------
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

Local Decimal NV_SIMTOT
Local Integer WRET

  Call CONVERT([M:INVCNDSI]CUR, VALEUR, GLOCALDEV, 1, [M:INVCNDSI]SIMDAT, [M:INVCNDSI]SIMTOT,NV_SIMTOT,WRET) From TRTDEV
  If WRET=0
    [M:INVCNDSI]SIMTOT=NV_SIMTOT
  Endif
  [M:INVCNDSI]CUR=VALEUR
  Gosub TR2
End
######################################################################################

