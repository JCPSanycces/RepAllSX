Subprog _WRITE_FILE(NAME,CLOB)
Value Char NAME()
Value Clbfile CLOB()
Local Char FICHIER(250) : FICHIER = filpath("BI",NAME,"txt")
Openo FICHIER,0
Wrseq CLOB
Openo
End

#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to export in a Clob the data detail of a representation.
#* @see
#*<code>
#*  ASTATUS = func ASYREIP.EXPORT_DATA_DETAIL(this,[V]CST_ANO,JSONDET)
#* </CODE>
#* @param WREP : Instance : Instance of the representation
#* @param FLGATT : Integer : Flag to discribe if we export or not the attributes
#* @param CLOB : Clbfile : Clob who contains the data detail
#* @param MESSAGE : Char : Message if the script returns a error
#*
#* @return STAT : Integer : The status code return by the script.
#*
#*
#*!
Funprog EXPORT_DATA_DETAIL(WREP,FLGATT,CLOB,MESSAGE)
Variable Instance  WREP      Using OBJECT
Value Integer       FLGATT
Variable Clbfile     CLOB
Variable Char      MESSAGE

End func EXPORT_DATA_DETAIL_FULL(WREP,FLGATT,[V]CST_AFALSE,CLOB,MESSAGE)

# Issue X3-74605 - 2018-06-14 by CCC : export the content of the clob => add WITHCLOB parameter
#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to export in a Clob the data detail of a representation.
#* @see
#*<code>
#*  ASTATUS = func ASYREIP.EXPORT_DATA_DETAIL(this,[V]CST_ANO,JSONDET)
#* </CODE>
#* @param WREP : Instance : Instance of the representation
#* @param FLGATT : Integer : Flag to discribe if we export or not the attributes
#* @param WITHCLOB : Integer : Flag to say if the content of Clob must be inserted into the result
#* @param CLOB : Clbfile : Clob who contains the data detail
#* @param MESSAGE : Char : Message if the script returns a error
#*
#* @return STAT : Integer : The status code return by the script.
#*
#*
#*!
Funprog EXPORT_DATA_DETAIL_FULL(WREP,FLGATT,WITHCLOB,CLOB,MESSAGE)
Variable Instance   WREP      Using OBJECT
Value Integer       FLGATT
Value Integer       WITHCLOB
Variable Clbfile    CLOB
Variable Char       MESSAGE
Local Integer       STAT

If WREP=null
 End [V]CST_AERROR
Endif

Local Char REP(GLONASW+2)
REP = right$(WREP.ObjectType,3)

Local Instance DET Using C_AREPENT
Call DESCRIPTION_REPRESENTATION(DET,"DET") From =func SUBASW.PREFIX_TRT+REP
DET.FCT = "$details"

Local Instance  PSYR   Using C_ASYR
PSYR = NewInstance C_ASYR AllocGroup null
PSYR.CODFAC = DET.FCT
PSYR.CODREP = REP
PSYR.NOATT = FLGATT
Call DETAIL_JSON_FULL(DET,WREP,PSYR,WITHCLOB,CLOB) From ASYRDATEDT

FreeGroup PSYR
FreeGroup DET
End STAT

#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to export in a Clob the desired prototype.
#*
#* @see
#*<code>
#* ASTATUS = func  ASYREIP.EXPORT_PROTOTYPE(WACV,[V]CST_AFAC_DETAILS,JSONPROTOS)
#* </CODE>
#*
#* @param WREP : Instance : Instance of the representation
#* @param FACETTE : Integer : Constant who describes the facette to export. Use the constants following
#* ([V]CST_AFAC_SUMMARY,[V]CST_AFAC_QUERY,[V]CST_AFAC_EDIT ,[V]CST_AFAC_DETAILS,CST_AFAC_LOOKUP)
#*@param MESSAGE : Char : Message if the script returns a error
#* @param WPROTO : Clbfile : Clob who contains the prototype.
#*
#* @return STAT : Integer : The status code return by the script.
#*!
Funprog EXPORT_PROTOTYPE(WREP,FACETTE,WPROTO,MESSAGE)
Variable Instance  WREP      Using OBJECT
Value Integer FACETTE
Variable Clbfile   WPROTO
Variable Char MESSAGE
If WREP=null
 End [V]CST_AERROR
Endif

Local Instance  PSYR   Using C_ASYR
Local Instance ASWK(1..) Using C_ASYRWRK
Local Instance ARCV Using C_ASYRRCV
Local Instance ASND Using C_ASYRSND
PSYR = NewInstance C_ASYR AllocGroup null
ARCV = NewInstance C_ASYRRCV AllocGroup null
ASND = NewInstance C_ASYRSND AllocGroup null

PSYR.CODREP = right$(WREP.ObjectType,3)

Local Instance DET Using C_AREPENT
Call DESCRIPTION_REPRESENTATION(DET,"DET") From =func SUBASW.PREFIX_TRT+PSYR.CODREP

Local Integer STAT,SUBCLA
Local Uuident  UIDINS , UID , UIDPAR
Local Clbfile  CLOB(0)
Local Char SCRIPT(GLONADC)

STAT=[V]CST_AOK

Case FACETTE
 When [V]CST_AFAC_DETAILS : PSYR.CODFAC = "$details"
 When [V]CST_AFAC_EDIT      : PSYR.CODFAC = "$edit"
 When [V]CST_AFAC_QUERY    : PSYR.CODFAC = "$query"
 When [V]CST_AFAC_LOOKUP   : PSYR.CODFAC = "$lookup"
 When [V]CST_AFAC_SUMMARY : PSYR.CODFAC = "$summary"
 When Default : STAT=[V]CST_AERROR
Endcase

If STAT=[V]CST_AOK
 SCRIPT = func APREFIXTRT.GET_PREFIX_JSO+PSYR.CODREP
 STAT = func ASYRSYS.CHECK_SCRIPT(WREP.ACTX,SCRIPT)
 If STAT = [V]CST_AOK
  STAT = func =SCRIPT+".APPEND_PROTOTYPE" With (WREP.ACTX,ASND,ARCV,PSYR,PSYR.CODFAC)
  If STAT = [V]CST_AOK : WPROTO = ASND.DATA : Endif
 Endif
Endif

FreeGroup PSYR
FreeGroup ARCV
FreeGroup ASND
FreeGroup DET
End STAT

#**
#* This Sub program is working on Fusion Session Client AND Syracuse Session Client.
#* It permit to load  a instance of representation with a clob who contains data detail
#* @see
#*<code>
#* ASTATUS = func ASYREIP.LOAD_REPRESENTATION(WACV,ENTITY_CLOB)
#* </CODE>
#*
#* @param WREP : Instance : Instance of the representation
#* @param JSON : Clbfile : Clob who contains the data detail
#* @param MESSAGE : Char : Message if the script returns a error
#* @return STAT : Integer : The status code return by the script.
#*!
Funprog LOAD_REPRESENTATION(WREP,JSON,MESSAGE)
Variable Instance  WREP      Using OBJECT
Variable Clbfile   JSON
Variable Char MESSAGE

If WREP=null
 End [V]CST_AERROR
Endif

Local Char REPNAM(GLONASW+2)
REPNAM = right$(WREP.ObjectType,3)

Local Instance  PSYR   Using C_ASYR
PSYR = NewInstance C_ASYR AllocGroup null

Local Instance REP Using C_AREPENT
Call DESCRIPTION_REPRESENTATION(REP,"DET") From =func SUBASW.PREFIX_TRT+REPNAM

Local Integer  STAT,SUBCLA
Local Uuident  UIDINS , UID , UIDPAR
Local Clbfile    CLOB(0)

STAT=[V]CST_AOK

Local Instance  UPD(1..)    Using C_ADELTA
Local Instance  NODE        Using C_ASYRJSO
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  ULN(1..)    Using C_ADELTALIN

STAT = func ASYRJSONPARSE.PARSEJSON(WREP.ACTX,JSON,NODES,NODE)
If STAT=[V]CST_AOK
 #Add $uuid when necessary
 UID = func  MAJ_UUIDS(NODES,NODES(1), NullUuid,0)

 #get deltas:
 STAT = func ASYRDEL.PARSEDELTA(WREP.ACTX,NODE,UPD)
 If STAT=[V]CST_AOK
  #and set the master uuid:
  Assign "WREP."+REP.ICL+".AUUID" With UID

  Call SET_SYSSNAPSHOT(WREP,1) From ASYRDELSYS
  # For mobile there is not properties $index and $isDeleted
  For I=1 To maxtab(UPD)
   If UPD(I)<>null & UPD(I).COL<>""
    UPD(I).IND = -1
   Endif
  Next I
  Call SET_REPRESENTATION(REP,WREP,UPD,ULN) From ASYRDELCLI
  Call SET_SYSSNAPSHOT(WREP,0) From ASYRDELSYS
 Endif
Endif
FreeGroup PSYR
FreeGroup REP
End STAT

# Add an $uuid to each object :
Funprog MAJ_UUIDS(NODES ,NODE,UIP,ADD)
Variable Instance  NODES(1..)  Using C_ASYRJSO
Variable Instance  NODE        Using C_ASYRJSO
Value Uuident UIP
Value Integer ADD

Local Uuident  UID: UID = NullUuid
Local Uuident  CHILDUID: CHILDUID = NullUuid

Local Instance  PNODE          Using C_ASYRJSO
Local Instance  PLAST         Using C_ASYRJSO
Local Instance  PNEW         Using C_ASYRJSO

Local Char NODEVALUE(250)
Local Integer LADD

If ADD
 #First look for the object' uuid
 PNODE=NODE
 While PNODE <> null
  If PNODE.PRO = "$uuid"
    NODEVALUE = fmet PNODE.AGETCNT
    If left$(NODEVALUE,1) = '"'
     NODEVALUE = mid$(NODEVALUE,2 ,len(NODEVALUE)-2)
    Endif
    UID     = toUuid(NODEVALUE)
    Break
  Endif
  PLAST = PNODE
  PNODE = PNODE.NEX
 Wend

 If UID = NullUuid
  #add a $uuid node
  UID = getUuid
  UIP = UID
  NODES(maxtab(NODES)) =  NewInstance C_ASYRJSO AllocGroup NODES
  PNEW = NODES(maxtab(NODES) )
  PNEW.TYP = 3
  PNEW.PRO = "$uuid"
  PNEW.CLB = NODES(1).CLB
  PNEW.START = 1+len(PNEW.CLB.CLB)
  NODEVALUE = '"'+ num$(UID) + '"'
  PNEW.LENGTH = len(NODEVALUE)
  Append PNEW.CLB.CLB , NODEVALUE
  PNEW.FAT = NODE.FAT
  PLAST.NEX = PNEW
 Endif
Endif

#Maj children
PNODE=NODE
While PNODE <> null
 If PNODE.SUB <> null
  LADD = (PNODE.TYP = 1)
  CHILDUID = func MAJ_UUIDS(NODES, PNODE.SUB, UIP,LADD)
  If UID = NullUuid
   UID = CHILDUID
  Endif
 Endif
 PNODE = PNODE.NEX
Wend
End UID
#--------------------------------------------------#

$SET_UUID
Assign "WREP."+REP.ICL+".AUUID" With UID
Call MAJ_FIELD(UPD,0,0,NullUuid,UID,-1,"","",0,CLOB) From  ASYRDELSYS
Call MAJ_UUID(UPD,REP,"",NullUuid,UID) : # 23.2.15 Test mb sans garantie de résultat
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UID=NullUuid
  UPD(I).UID = UID
 Endif
Next I
Return

#--------------------------------------------------#
Subprog MAJ_UUID(UPD,REP,COL,UIP,UID)
Variable Instance UPD(1..) Using C_ADELTA
Variable Instance REP      Using C_AREPENT
Value    Char     COL
Value    Uuident  UIP , UID
Local Integer I , IND
Local Uuident NEWUID
Local Char    PRO(50)
[L]IND = -1
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UID=NullUuid
  If UPD(I).COL=[L]COL
   If [L]PRO=""
    [L]PRO = UPD(I).PRO
    #If COL<>"" : [L]IND = 1 : Endif
   Elsif UPD(I).PRO=[L]PRO
    [L]UID = getUuid
    #If [L]COL<>"" : [L]IND += 1 : Endif
   Endif
   UPD(I).IND = [L]IND
   UPD(I).UIDPAR = [L]UIP
   UPD(I).UID = [L]UID
  Elsif UPD(I).COL<>"" and ([L]COL="" or  instr(1,UPD(I).COL,[L]COL)) : # Sous-collection
   [L]NEWUID = getUuid
   Call MAJ_UUID(UPD,REP,UPD(I).COL,[L]UID,[L]NEWUID)
  Else
   Break : # Fin de collection
  Endif
 Endif
Next I
End

#--------------------------#
$SEARCH_UUID_MASTER
UID = NullUuid
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UIDPAR=NullUuid & UPD(I).UID<>NullUuid & (len(UPD(I).COL) =0)
  UID = UPD(I).UID
  Break
 Endif
Next I
If maxtab(UPD)=0
 STAT = func ASYRSUB._ASETSTATUS(WREP.ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(34,149,1))
Elsif UID=NullUuid
 SUBCLA = 0
 For I=1 To maxtab(REP.COL)
  If REP.COL(I)<>null & instr(1,REP.COL(I).GRI,".")
   SUBCLA = 1 : Break
  Endif
 Next I
 If SUBCLA
  STAT = [V]CST_AERROR
 Endif
Endif
Return

#**
#* This Sub program is working on Syracuse Session Client only.
#* It permit to create in MongoDb  a entity based on the data detail of a representation
#* @see
#*<code>
#* ASTATUS = func  ASYREIP.MDB_CREATE_EDI_ENTITY(JSONDET, this.ACV.CODACT,"type_entity","etag_entity",AUUID,MESSAGE)
#* </CODE>
#*
#* @param JSONDET : Clbfile : Clob who contains the data detail
#* @param ID_ENTITY : Char : Id of the entity
#* @param TYPE_ENTITY : Char : type of the entity
#* @param ETAG_ENTITY : Char : Etag of the entity
#* @param AUUID : Char : UUid created by mongodb
#* @param MESSAGE : Char : Message if the script returns a error
#*
#* @return STAT : Integer : The status code return by the script.
#*!
Funprog MDB_CREATE_EDI_ENTITY(JSONDET, ID_ENTITY,TYPE_ENTITY,ETAG_ENTITY,AUUID,MESSAGE)
Value Clbfile JSONDET()
Value Char ID_ENTITY()
Value Char TYPE_ENTITY()
Value Char ETAG_ENTITY()
Variable Char AUUID
Variable Char MESSAGE

Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)

Local Char MODULE(100)    : MODULE = 'syracuse-edi/lib/edi_Entity'
Local Char FONCTION(30)   : FONCTION = 'createEdiCacheEntity'
Local Char MODE(10)         : MODE = 'wait'
Local Char ENCODINGS(40)  : ENCODINGS = '0'
Local Char RETURNS(50)      : RETURNS = ''
Local Clbfile ARGUMENTS(0),ARG(0)
Local Integer STATUSCODE

Raz AUUID,MESSAGE

ARGUMENTS = '{"id":"'+ID_ENTITY + '", "type":"' + TYPE_ENTITY + '","etag":"' + ETAG_ENTITY + '", "json":' + JSONDET + '}'

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, 0, RETURNS, '', RESHEAD, RESBODY)

If STATUSCODE=[V]CST_AHTTP_INTERNAL
 MESSAGE = func ASYRWEBSER.GETMESS(RESHEAD)
 STATUSCODE = [V]CST_AERROR
Else
 STATUSCODE = [V]CST_AOK
 AUUID = RESBODY
Endif
End STATUSCODE

#**
#* This Sub program is working on Syracuse Session Client only.
#* It permit to get a entity from Mongodb by his UUID.
#*
#* #* @see
#*<code>
#* ASTATUS = func  ASYREIP.MDB_GET_EDI_ENTITY_UUID(AUUID, ENTITY_CLOB, MESSAGE)
#* </CODE>
#*
#* @param AUUID : Char : UUID of the entity
#* @param ENTITY_CLOB : Clbfile : Clob who contains the entity from Mongodb
#* @param MESSAGE : Char : Message if the script returns a error
#*
#* @return STAT : Integer : The status code return by the script.
#*!
Funprog MDB_GET_EDI_ENTITY_UUID(AUUID,ENTITY_CLOB,MESSAGE)
Value    Char   AUUID()
Variable Clbfile ENTITY_CLOB()
Variable Char MESSAGE()

Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)

Local Char MODULE(100)    : MODULE = 'syracuse-edi/lib/edi_Entity'
Local Char FONCTION(30)   : FONCTION = 'getEdiCacheJson'
Local Char MODE(10)         : MODE = 'wait'
Local Char ENCODINGS(40)  : ENCODINGS = '0'
Local Char RETURNS(50)      : RETURNS = ''
Local Clbfile ARGUMENTS(0),ARG(0)
Local Integer STATUSCODE,I

Raz ENTITY_CLOB,MESSAGE

ARGUMENTS = '{"uuid":"'+AUUID+'"}'

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, 0, RETURNS, '', RESHEAD, RESBODY)
If STATUSCODE=[V]CST_AHTTP_INTERNAL
 MESSAGE = func ASYRWEBSER.GETMESS(RESHEAD)
 STATUSCODE = [V]CST_AERROR
Else
 ENTITY_CLOB = RESBODY
 STATUSCODE = [V]CST_AOK
Endif
End STATUSCODE


#**
#* This Sub program is working on Syracuse Session Client only.
#* It permit to get a entity from Mongodb by his ID.
#*
#* #* @see
#*<code>
#* ASTATUS = func  ASYREIP.MDB_GET_EDI_ENTITY_ID(this.ACV.CODACT,"type_entity", ENTITY_CLOB, MESSAGE)
#* </CODE>
#*
#* @param ID_ENTITY : Char : Id of the entity
#* @param TYPE_ENTITY : Char : type of the entity
#* @param ENTITY_CLOB : Clbfile : Clob who contains the entity from Mongodb
#* @param MESSAGE : Char : Message if the script returns a error
#*
#* @return STAT : Integer : The status code return by the script.
#*!
Funprog MDB_GET_EDI_ENTITY_ID(ID_ENTITY,TYPE_ENTITY,ENTITY_CLOB,MESSAGE)
Value Char ID_ENTITY()
Value Char TYPE_ENTITY()
Variable Clbfile ENTITY_CLOB()
Variable Char MESSAGE()

Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)

Local Char MODULE(100)    : MODULE = 'syracuse-edi/lib/edi_Entity'
Local Char FONCTION(30)   : FONCTION = 'getEdiCacheJson'
Local Char MODE(10)         : MODE = 'wait'
Local Char ENCODINGS(40)  : ENCODINGS = '0'
Local Char RETURNS(50)      : RETURNS = ''
Local Clbfile ARGUMENTS(0),ARG(0)
Local Integer STATUSCODE,I

Raz ENTITY_CLOB,MESSAGE

ARGUMENTS = '{"filter" :{"jsonWhere":{'
ARGUMENTS += '"id":"'+ID_ENTITY + '", "type":"' + TYPE_ENTITY+'"'
ARGUMENTS += '}}}'

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, ENCODINGS, 0, RETURNS, '', RESHEAD, RESBODY)
If STATUSCODE=[V]CST_AHTTP_INTERNAL
 MESSAGE = func ASYRWEBSER.GETMESS(RESHEAD)
 STATUSCODE = [V]CST_AERROR
Else
 ENTITY_CLOB = RESBODY
 STATUSCODE = [V]CST_AOK
Endif
End STATUSCODE

