#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:42"
A_USER  = "DOC"
A_STAMP = "20181109230542"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMACOPY0 [PJMAC0]
Gosub HORODAT
Local Inpbox "PJMACOPY0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJMAC0] As [SIM_]
Grizo [PJMAC0]5
Grizo [PJMAC0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJMAC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=127 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=54 : Y1(1)=4 : Y2(1)=8
Return

$ON_OPPNUM
Onevent AFTER_CHANGE Gosub AMM_OPPNUM From W1PJMACOPY0
Onevent BEFORE_INPUT Call AS_OPPNUM(zc) From W1PJMACOPY0
Onevent CONTROL Call C_OPPNUM(zc) From W1PJMACOPY0
Return

Subprog IB_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMPIM
Call IBUPIM(VALEUR) From PJMSELECT
Gosub _AFF
End

Subprog AS_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14664,GBOUT1) From OBJDIV
Call TEXTE(14664,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_OPPNUM(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_OPPNUM(zc) From W1PJMACOPY0
Onkey 130 Titled GBOUT2 Call B2_OPPNUM(zc) From W1PJMACOPY0
Onkey   2 Titled GBOUTS Call S_OPPNUM(zc) From W1PJMACOPY0
Onkey 144 Titled GBOUTP Call P_OPPNUM(zc) From W1PJMACOPY0
Onkey 146 Titled GBOUTA Call SA_OPPNUM(zc) From W1PJMACOPY0
Gosub _AFF
End

Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PIM","A",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
Endif
Gosub _AFF
End

$AMM_OPPNUM
Call AM_OPPNUM(zc)
If !mkstat & GOBJET
 zoncou = "OPPNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_OPPNUM(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZOPPNUM)")>indice
 [M]OPPNUM(indice) = VALEUR
 Affzo ZOPPNUM(indice)
Endif
Gosub _AFF
End

Subprog S_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMOPP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMOPP"
 PARMSK(1) = "0"
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = "0"
 PARMSK(5) = "0"
 PARMSK(6) = "[F:PIM]PIMNUM desc"
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPJMOPP","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMPIM
 Call TUNPIM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_OPPNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMOPP
 Call TUNCRM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PIM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OPPNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMACOPY0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_SALFCY
Return

$ON_ZSALFCY
Onevent BEFORE_AREA Gosub AV_ZSALFCY From W1PJMACOPY0
Return

$AV_ZSALFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]SALFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

$ON_CUR
Return

$ON_ZCUR
Onevent BEFORE_AREA Gosub AV_ZCUR From W1PJMACOPY0
Return

$AV_ZCUR
Call LECTEXTRA(zc,"TABCUR","INTDES",num$([M]CUR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_OPPSTATE
Onevent INIT_AREA Call D_OPPSTATE(zc) From W1PJMACOPY0
Return

Subprog D_OPPSTATE(VALEUR)
Variable Integer VALEUR
If varinit([M]OPPSTATE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CRMFLG
Onevent AFTER_CHANGE Gosub AMM_CRMFLG From W1PJMACOPY0
Onevent INIT_AREA Call D_CRMFLG(zc) From W1PJMACOPY0
Onevent BEFORE_INPUT Call AS_CRMFLG(zc) From W1PJMACOPY0
Return

Subprog D_CRMFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]CRMFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CRMFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_CRMFLG
Call AM_CRMFLG(zc)
If !mkstat & GOBJET
 zoncou = "CRMFLG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRMFLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CRMFLG(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "CRMFLG" : GZNUM = 1002876 : Endif
Gosub _AFF
End

$ON_CRMOPP
Onevent BEFORE_AREA Gosub AV_CRMOPP From W1PJMACOPY0
Onevent AFTER_AREA Call AP_CRMOPP(zc) From W1PJMACOPY0
Onevent CONTROL Call C_CRMOPP(zc) From W1PJMACOPY0
Onevent BEFORE_INPUT Call AS_CRMOPP(zc) From W1PJMACOPY0
Onevent AFTER_CHANGE Gosub AMM_CRMOPP From W1PJMACOPY0
Return

Subprog IB_CRMOPP(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMPIM
Call IBUPIM(VALEUR) From PJMSELECT
Gosub _AFF
End

$AV_CRMOPP
## Action STD
Call AV_CRMOPP(zc) From SUBPJMACOPY
Gosub _AFF
Return

Subprog AS_CRMOPP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14664,GBOUT1) From OBJDIV
Call TEXTE(14664,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Call IB_CRMOPP(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_CRMOPP(zc) From W1PJMACOPY0
Onkey 130 Titled GBOUT2 Call B2_CRMOPP(zc) From W1PJMACOPY0
Onkey   2 Titled GBOUTS Call S_CRMOPP(zc) From W1PJMACOPY0
Onkey 144 Titled GBOUTP Call P_CRMOPP(zc) From W1PJMACOPY0
Onkey 146 Titled GBOUTA Call SA_CRMOPP(zc) From W1PJMACOPY0
Gosub _AFF
End

Subprog C_CRMOPP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("PIM","D",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
Endif
Gosub _AFF
End

Subprog AP_CRMOPP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_CRMOPP(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
Gosub _AFF
End

$AMM_CRMOPP
Call AM_CRMOPP(zc)
If !mkstat & GOBJET
 zoncou = "CRMOPP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRMOPP(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCRMOPP)")>indice
 [M]CRMOPP(indice) = VALEUR
 Affzo ZCRMOPP(indice)
Endif
Gosub _AFF
End

Subprog S_CRMOPP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "PIM"
PARMSK(2) = "D"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRMOPP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMPIM
 Call TUNPIM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_CRMOPP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMOPP
 Call TUNCRM(VALEUR) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CRMOPP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "PIM"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRMOPP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("PIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCRMOPP
Onevent BEFORE_AREA Gosub AV_ZCRMOPP From W1PJMACOPY0
Return

$AV_ZCRMOPP
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]CRMOPP(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_DESTAFF
Onevent CONTROL Call C_DESTAFF(zc) From W1PJMACOPY0
Onevent AFTER_AREA Call AP_DESTAFF(zc) From W1PJMACOPY0
Return

Subprog C_DESTAFF(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "DESTAFF" : GZNUM = 55983 : Endif
Endif
Gosub _AFF
End

Subprog AP_DESTAFF(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AP_DESTAFF(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "DESTAFF" : GZNUM = 55983 : Endif
Gosub _AFF
End

$CHG_STY
Return


