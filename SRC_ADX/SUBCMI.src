#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBCMI : Transactions de saisie interventions           CRM 6/01/04 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:HTR]HDKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWB]AWINBRO  Table des browsers            #
#                       [F:AWT]AWINBOUT Table des boutons             #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base         #
# ITN0
# ITN1
# ITN3
# ITN7
# ITN8
# ITN4
#                                                                     #
# Nom des écrans générés : WHxyyyz                                    #
#                            x = 1 pour parc client                   #
#                            x = 2 pour demandes                      #
#                            x = 3 pour interventions
#                            x = 4 Plan de travail
#                                                                     #
#                          yyy = nom de la transaction (HTRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                0, 1, 2, 3, 4 pour parc
#######################################################################
##########################################################################################################
Call OBJET("CMI",GBIDC1,GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST                      
    When "FILTRE"      : Gosub FILTRE
    When "EFFMASK"     : [M:CMI0]HTRTYP = 3
    When "SETBOUT"     : Gosub SETBOUT  
    When "EXEBOUT"     : Gosub EXEBOUT  
    When "LIENS"       : Gosub TRT_DIETRS From SUBDST
                         Gosub LIENS
    When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST
                         Gosub RAZCRE
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "INICRE"      : Gosub INICRE
    When "CREATION"    : Gosub CREATION
    When "APRES_CRE"   : Gosub APRES_CRE
    When "INIMOD"      : Gosub INIMOD
    When "MODIF"       : Gosub MODIF
    When "APRES_MOD"   : Gosub APRES_MOD
    When "ANNULE"      : Gosub ANNULE
    When "AV_IMPRIME"  : Gosub COP_ECRAN
    When "FERME"       : Gosub FERME
    When Default
  Endcase
Return

##########################################################################################################
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
Local Char APPLI
Local Char WDIE_ABRFIC(GLONABR) 
Local Integer WDIE_DTRTYP 
Local Integer IINIMODTRS   # FGR 29/01/2010 : X3SUIVI62022

  APPLI = nomap
  [L]WDIE_ABRFIC = "HTR"
  [L]WDIE_DTRTYP = 3
  Gosub TRT_DIETRS From SUBDST
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
# Ne traiter que les transactions de type parc client   #
#-------------------------------------------------------#
$FILTRE
  FILTSUP = "[F:HTR]HTRTYP=3"
Return
  
##########################################################################################################  
# Désactivation bouton "Validation" et "Copie" #  
#----------------------------------------------#  
$SETBOUT  
  If GREP <> "" or !CLECUR Then
    Call VIREBOUT(CHAINE,"12") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return  

##########################################################################################################  
# Après appui sur bouton "Validation" #  
#-------------------------------------#  
$EXEBOUT  
  Case REP
    When "1"
      Call DEBTRANS From GLOCK  
      Trbegin ADOVAL  
      Gosub TRT_ECRAN
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif  
    When Default  
  Endcase  
Return  

##########################################################################################################
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
  Gosub LOADDATA From SUBCMIB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
  [M:CMI0]HTRTYP = 3
  [M:CMI0]ENAFLG = 2
  Raz [M:CMI5]NBLIG
  Raz [M:CMI5]OBJLIS
  Raz [M:CMI5]OBJLISCLA
  Raz [M:CMI5]CLELIS
  Raz [M:CMI5]ORDLIS
  Raz [M:CMI5]FLTLIS
  [M:CMI5]DERLU = 2
  [M:CMI5]FIRLIS = 1
  Gosub ONGLETS_INIT From SUBCMIB
  Gosub BLOCS_INIT From SUBCMIB
  Gosub COLFIX_INIT From SUBCMIB
  Gosub CHAMPS_INIT From SUBCMIB
  Gosub TRT_DIETRS From SUBDST 
  Gosub PE_HDKTRS From SUBHDKTRS
  Affzo [CMI0]1-99
  Affzo [CMI1]1-99
  Affzo [CMI2]1-99
  Affzo [CMI3]1-99
  Affzo [CMI4]1-99
  Affzo [CMI5]1-99
Return

##########################################################################################################
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
  Case COUZON
    When Default
     Gosub PE_HDKTRS From SUBHDKTRS
  Endcase
Return

##########################################################################################################
# Chargement avant le Write #
#---------------------------#
$INICRE
  Raz [F:HTV]
  Gosub CHARGE_ATEXTRA
  Gosub ONGLETS_ENREG From SUBCMIB
  Gosub BLOCS_ENREG From SUBCMIB
  Gosub COLFIX_ENREG From SUBCMIB
  Gosub CHAMPS_ENREG From SUBCMIB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$CREATION
  [F:HTV] = [F:HTR]
  Write [HTV]
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE=mess(521,177,1)
    Return
  Endif
  Gosub TRT_DIETRS From SUBDST
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
  Gosub CHARGE_ATEXTRA
  IINIMODTRS = 0  # FGR 28/01/2010 : X3SUIVI62022
  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    # FGR 28/01/2010 : X3SUIVI62022 (début)
    IINIMODTRS = 1
    #GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    #GERR = 2
    #Erreur lors de la lecture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    #GMESSAGE=mess(521,177,1)
    #Return
    # FGR 28/01/2010 : X3SUIVI62022 (fin)
  Endif
  Gosub ONGLETS_ENREG From SUBCMIB
  Gosub BLOCS_ENREG From SUBCMIB
  Gosub COLFIX_ENREG From SUBCMIB
  Gosub CHAMPS_ENREG From SUBCMIB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
$MODIF
  [F:HTV] = [F:HTR]
  If IINIMODTRS = 0 Then
    Rewrite [HTV]
  Else
    Write [HTV]
  Endif
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de l'écriture de la table des valeurs de transaction de saisie (HDKTRSVAL).
    GMESSAGE=mess(521,177,1)
    Return
  Endif
  Gosub TRT_DIETRS From SUBDST
  Gosub TRT_ECRAN
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$ANNULE
Local Char WDIE_ABRFIC(GLONABR)

  Delete [AXX] Where CODFIC="HDKTRS" and IDENT1=num$([F:HTR]HTRTYP) and IDENT2=[F:HTR]HTRNUM
  [L]WDIE_ABRFIC = "HTR"
  Gosub TRT_DIETRS From SUBDST 
  Gosub TRT_ECRAN
  Delete [HTV] Where [F:HTV]HTRTYP=[F:HTR]HTRTYP and [F:HTV]HTRNUM=[F:HTR]HTRNUM
  If fstat <> 0 Then
    GOK = 0  # FGR 28/01/2010 : X3SUIVI62022
    GERR = 2
    #Erreur lors de la suppression dans la  table des valeurs de transaction de saisie.+" (HDKTRSVAL)"
    GMESSAGE=mess(523,177,1) - "(HDKTRSVAL)"
    Return
  Endif
Return

##########################################################################################################
# Création ou modif de texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA 
  Call MAJTEXTRA([M:CMI0]DESAXX,"HDKTRS","DESAXX",num$([M:CMI0]HTRTYP),[M:CMI0]HTRNUM) From ATEXTRA
  [F:HTR]HTRDES = GLANGUE + "~" + [M:CMI0]DESAXX
  [F:HTR]HTRTYPCAR = num$([F:HTR]HTRTYP)
Return

##########################################################################################################
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
  Gosub INIT_VARIABLES From CRMTRSUTI
#---------------- Noms fenêtres et traitement -----------------#
Local Char     WINREF(GLONFEN) : WINREF = "OITN"
Local Char     NOMWIN(GLONFEN) : NOMWIN = "WOITN" + [M:CMI0]HTRNUM
Local Char     NOMTRT(GLONADC) : NOMTRT = "WGOITN" + [M:CMI0]HTRNUM

  #------------------------- Intervention --------------------------#
  MFROM = "ITN1"
  MTO = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "1"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Adresses --------------------------#
  MFROM = "ITN3"
  MTO = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "3"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Ressources --------------------------#
  MFROM = "ITN7"
  MTO = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "7"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Consommations --------------------------#
  MFROM = "ITN8"
  MTO = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "8"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  #------------------------- Compte-rendu --------------------------#
  MFROM = "ITN4"
  MTO = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "4"
  Gosub GERE_MSK_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  If ACTION = "ANNULE" Then
    Gosub TRT_SUP_FEN
  Else
    Gosub TRT_GEN_FEN
  Endif
Return

##########################################################################################################
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
  Call DELWIN(NOMWIN,APPLI) From MSKDIV
Return

##########################################################################################################
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
  If clalev([F:AOB])=0 Local File =APPLI+".AOBJET"  [AOB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par FUNHDKTRS
  If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par FUNHDKTRS
  #----- Suppression fenêtre si transaction non active -----#
  If [M:CMI0]ENAFLG = 1 Then
    Gosub TRT_SUP_FEN
    Return
  Endif
  #----- Génération fenêtre si transaction active -----#
  Delete [AWI] Where WIN = NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINDOW" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0 
    Call RSTA ("AWI",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWP] Where WIN = NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINPAR" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0 
    Call RSTA ("AWP",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWB] Where WIN = NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBRO" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWB",NOMWIN) From GLOCK
    Return
  Endif
  Delete [AWT] Where WIN = NOMWIN
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$AWINBOUT" - NOMWIN
    Return
  Elsif fstat Then
    GOK = 0
    Call RSTA ("AWT",NOMWIN) From GLOCK
    Return
  Endif
  Read [AWI]AWI0=WINREF
  If fstat <> 0 Then
    GOK = 0
    Return
  Endif
  [F:AWI]WIN = NOMWIN
  [F:AWI]MSKENT = "ITN0"
  #Intervention
  WMSKREF = "ITN1"
  WNOMMSK = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "1"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 0
  Endif
  WFLGMSK = 2
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  WMSKREF = "ITN3" 
  WNOMMSK = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "3"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 1
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Ressources
  WMSKREF = "ITN7"
  WNOMMSK = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "7"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 2
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Consommations
  WMSKREF = "ITN8"
  WNOMMSK = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "8"
  I = find(WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 3
  Endif
  Gosub ONGLETVISIBLE_HDK From CRMTRSUTI
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  #Compte-rendu
  WMSKREF = "ITN4"
  WNOMMSK = "WH" + num$([M:CMI0]HTRTYP) + [M:CMI0]HTRNUM + "4"
  I = find( WMSKREF,[F:AWI]NOMMSK)-1
  If I < 0 Then
    I = 4
  Endif
  WFLGMSK = 2
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS = [M:CMI0]ACSCOD
  If dim([F:AWI]LIBEL) > 0 Then
    [F:AWI]LIBEL = [M:CMI0]DESAXX
  Endif
  [F:AWI]ENAFLG = 2
  [F:AWI]TRN = [M:CMI0]HTRNUM
  Write [AWI]
  If fstat Then
    GOK = 0
    Call FSTA("AWI") From GLOCK
    Return
  Endif
  For [AWP]AWP0 Where WIN = WINREF
    [F:AWP]WIN = NOMWIN
    Write [AWP]
    If fstat Then
      GOK = 0
      Call FSTA("AWP") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  #Ajout des browsers
  IROWLIS = 15
  INBROWREF = 2
  Gosub BROWSERS_HDK From CRMTRSUTI
  If GOK < 1 Then
    Return
  Endif
  For [AWT]AWT0 Where WIN = WINREF
    [F:AWT]WIN = NOMWIN
    Write [AWT]
    If fstat Then
      GOK = 0
      Call FSTA("AWT") From GLOCK
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
  If !OK Then
    GOK = 0
  Endif
Return

##########################################################################################################
Subprog AS_HTRNUM(VALEUR)
Variable Char    VALEUR()

  #-----------------------#
  # Avant saisie document #
  #-----------------------#
  [M:CMI0]HTRTYP = 3
End

##########################################################################################################
# Hard copy des écrans de paramétrage #
#-------------------------------------#
$COP_ECRAN
Local Char WINT(20)(2) 
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(4)
Local Char WABR(GLONABR)(2)

  #-----
  Call TEXTFIC("HDKTRS","HTRNUM",2,WINT(0)) From OBJDIV
  Call TEXTFIC("HDKTRS","ACSCOD",2,WINT(1)) From OBJDIV
  WTIT = WINT(0) - ":" - [M:CMI0]HTRNUM-[M:CMI0]DESAXX-WINT(1) - ":" - [M:CMI0]ACSCOD
  WMSK(0) = "CMI1"
  WMSK(1) = "CMI2"
  WMSK(2) = "CMI3"
  WMSK(3) = "CMI4"
  WMSK(4) = "DIESCRTRS"
  WMSK(5) = "CMI5"
  Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
  OK = 0 : # Pour ne pas imprimer tout de suite !
Return

##########################################################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

Local Integer TYP

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif
  TYP = 3
  Gosub GENPATCH From FUNHDKTRS
End

##########################################################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI

Local Integer TYP

  TYP = 3
  Gosub GENDOS From FUNHDKTRS
End

##########################################################################################################
Subprog AM_SCOCOD(VALEUR)
Variable Integer VALEUR
End

##########################################################################################################
Subprog AM_TITNADDFLG(VALEUR)
Variable Integer VALEUR
End

##########################################################################################################
Subprog AM_TITNHDTFLG(VALEUR)
Variable Integer VALEUR
End

##########################################################################################################
Subprog AM_HDTMACCOD(VALEUR)
Variable Integer VALEUR
End

##########################################################################################################
Subprog C_OBJLIS(VALEUR)
Variable Char    VALEUR()

Local Integer I

  #Vérifie si ce code solution n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CMI5]OBJLIS)-1
    If I <> nolign-1 Then
      If [M:CMI5]OBJLIS(I) = VALEUR and [M:CMI5]OBJLIS(I) <> "" Then
        #Ce browser a déjà été saisi.
        GMESSAGE = mess(956,182,1)
        GERR = 2
        mkstat = 2
        Break
      Endif
    Endif
  Next
  If GERR Then
    End
  Endif
  If VALEUR = "ITN" Then
    #Valeur refusée. Il s'agit d'un browser standard.
    GMESSAGE = mess(959,182,1)
    GERR = 2
    mkstat = 2
    End
  Elsif VALEUR = "IT2" Then
    #Valeur refusée. Il s'agit d'un browser standard.
    GMESSAGE = mess(959,182,1)
    GERR = 2
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_OBJLIS(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:CMI5]OBJLISCLA(nolign-1) = ""
  Else
    Read [AOB]ABREV=VALEUR
    If fstat Then
      [M:CMI5]OBJLISCLA(nolign-1) = ""
    Else
      Call TEXTE([F:AOB]LIBEL, [M:CMI5]OBJLISCLA(nolign-1)) From OBJDIV
    Endif
  Endif
  [M:CMI5]CLELIS(nolign-1) = "ITN0"
  [M:CMI5]ORDLIS(nolign-1) = 1
  [M:CMI5]FLTLIS(nolign-1) = "1=1"
  Affzo [M:CMI5]OBJLISCLA(nolign-1), CLELIS(nolign-1), ORDLIS(nolign-1), FLTLIS(nolign-1)
End

##########################################################################################################
Subprog AS_ISSQTYCOD(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End

##########################################################################################################
Subprog AS_ISSISSCOD(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End

##########################################################################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE
Local Integer TYP
Local Char CODTAB(GLONTRS)

  MODULE = 12
  TYP = 3
  CODTAB = TABLE
  #-----
  Gosub OUVRE_COPTRS From SELTRS
  Gosub EXEC_COPTRS  From SELTRS
  Gosub FERME_COPTRS From SELTRS
Return
