#<AdxTL>@(#)80.0.0.0 $Revision$
#-------------------------------------------------------------------#
# Appelûˋ AVANT la mise û  jour de structure
#-------------------------------------------------------------------#

Subprog AMAJ
Local Integer PHASE : PHASE=1

Onerrgo ERREUR
Gosub BOUCLEMAJ
Onerrgo
End

#-------------------------------------------------------------------#
# Appelûˋ APRES la mise û  jour de structure
#-------------------------------------------------------------------#

Subprog MAJ
Local Integer PHASE : PHASE=2

If GERRDOS
 # Pas d'exûˋcution de la phase $1$ de la migration suite û  l'erreur $2$
 # X3-108771 19.09.2018
 Call ECR_TRACE(format$("D:"+GFMDAT4,date$)-time$-":"-func AFNC.MES2(mess(216,125,1),num$(PHASE),num$(GERRDOS)),1) From GESECRAN
 End
Endif

Onerrgo ERREUR
Gosub BOUCLEMAJ
Onerrgo

Gosub CHGVERS
End

#################################################
$FILLIST
Local Char    TABTRAIT(GLONADC)(1000),MOTHER(100) : MOTHER=""
Local Integer NBTRAIT,I
Raz TABTRAIT
NBTRAIT=0
For I=7 To 0 Step -1
 If adxmother(I)<>"" & MOTHER<>adxmother(I)
  MOTHER=adxmother(I)
  Gosub LISTADX
 Endif
Next I
Sorta NBTRAIT TABTRAIT(0..NBTRAIT)
Return

#################################################
$LISTADX
Local Char    WTRAIT(GLONADC),ORDRE(250)
ORDRE = adxmac(0)+'@lsadx -a '+MOTHER+' TRT "'+TRAIT+'_###.adx"'
Local File (TRT(GLONADC)) From System ORDRE As [TRT_]
For [TRT_]
 WTRAIT=left$([TRT_]TRT,len([TRT_]TRT)-4)
 If find(WTRAIT,TABTRAIT(0..NBTRAIT))=0
  TABTRAIT(NBTRAIT)=WTRAIT
  NBTRAIT+=1
 Endif
Next
Close Local File [TRT_]
Return

#################################
$BOUCLEMAJ
Local Integer OKTRT , ERR, NOTRAIT
Local Char    TRAIT(GLONADC)
Local Decimal PATCHVERSION
Local Decimal VERSION

VERSION = val(DOSVERS)
ERR = GERRDOS

While 1 & GERRDOS=0 & int(VERSION)<=val(SUPVERS)
  If VERSION<val(SUPVERS) & VERSION>=80
   TRAIT  = "DOSMAJ"+num$(int(VERSION))
   Call EXISTE_ADX("","",TRAIT,OKTRT) From ORDSYS
   If OKTRT>0
    Gosub FILLIST
    For NOTRAIT=0 To NBTRAIT-1
     PATCHVERSION=val(right$(TABTRAIT(NOTRAIT),len(TRAIT)+2))
     If ((VERSION-int(VERSION))*1000)<PATCHVERSION & int(VERSION)+(PATCHVERSION/1000)<=val(SUPVERS)
      Call EXISTE_ADX("","",TABTRAIT(NOTRAIT),OKTRT) From ORDSYS
      If OKTRT>0 & GERRDOS=0
       #107271
       If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 | (VERSION+1)>=30
        If GINFO
         # Mise û  jour en version
         Call AFF_VLC(mess(93,125,1)-num$(int(VERSION))+"."+format$("N0:3",PATCHVERSION),"") From GESECRAN
        Endif
        Call ECR_TIME(mess(93,125,1)-num$(int(VERSION))+"."+format$("N0:3",PATCHVERSION)) From DOSSUB
        If PHASE=1
         Call AMAJ From =TABTRAIT(NOTRAIT)
        Elsif PHASE=2
         Call MAJ From =TABTRAIT(NOTRAIT)
        Else
         GERRDOS=1
         Break 2
        Endif
       Endif
       VERSION=int(VERSION)+(PATCHVERSION/1000)
      Else
       Break 2
      Endif
     Endif
    Next
   Else
    Break
   Endif
  Endif
  If int(VERSION)<int(val(SUPVERS))
   TRAIT  = "DOSMAJ"+num$(int(VERSION)+1)
   Call EXISTE_ADX("","",TRAIT,OKTRT) From ORDSYS
   If OKTRT>0
    #107271
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 | (VERSION+1)>=30
     If GINFO
      # Mise û  jour en version
      Call AFF_VLC(mess(93,125,1)-num$(int(VERSION)+1),"") From GESECRAN
     Endif
     Call ECR_TIME(mess(93,125,1)-num$(int(VERSION)+1)) From DOSSUB
     If PHASE=1
      Call AMAJ From =TRAIT
     Elsif PHASE=2
      Call MAJ From =TRAIT
     Else
      GERRDOS=1
      Break
     Endif
    Endif
   Else
    Break
   Endif
   VERSION = int(VERSION)+1
  Else
   Break
  Endif
Wend

If ERR<>GERRDOS
 # Une erreur $1$ a provoquûˋ l'arrûˆt de la phase $2$ de migration û  la version $3$
 Call ECR_TRACE(format$("D:"+GFMDAT4,date$)-time$-":"-func AFNC.MES3(mess(215,125,1),num$(GERRDOS),num$(PHASE),num$(VERSION)),1) From GESECRAN
#108627
Elsif VERSION<>val(SUPVERS)
 If OKTRT<=0
  #Traitement inexistant dans l'archive
  Call ECR_TRACE(TRAIT-mess(158,139,1),1) From GESECRAN
 Endif
 GERRDOS=1
 # Une erreur $1$ a provoquûˋ l'arrûˆt de la phase $2$ de migration û  la version $3$
 Call ECR_TRACE(format$("D:"+GFMDAT4,date$)-time$-":"-func AFNC.MES3(mess(215,125,1),num$(GERRDOS),num$(PHASE),SUPVERS),1) From GESECRAN
Endif
Return


$CHGVERS
#-------------------------------------------------------------------#
# Changement du numûˋro de version
#-------------------------------------------------------------------#

#107271
#106969
# Issue X3-108947 - 2018-09-18 by CCC

If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)
# If int(VERSION)=VERSION
# Call MAJPARHIS([F:ADS]DOSSIER,"RELEASE",num$(int(VERSION))) From SUBADS
# Else
# Call MAJPARHIS([F:ADS]DOSSIER,"RELEASE",num$(VERSION)) From SUBADS
# Endif
   Call MAJPARHIS([F:ADS]DOSSIER,"RELEASE",func APRODUCT.FORMAT_RELEASE(VERSION)) From SUBADS
   If VERSION=val(SUPVERS)
      Call MAJPARHIS([F:ADS]DOSSIER,"RELABR",func APRODUCT.AGETRELEASEABR(GDOSREF)) From SUBADS
   Endif
Else
# If int(VERSION)=VERSION
# Call MAJPAR([F:ADS]DOSSIER,"RELEASE",num$(int(VERSION))) From SUBADS
# Else
# Call MAJPAR([F:ADS]DOSSIER,"RELEASE",num$(VERSION)) From SUBADS
# Endif
   Call MAJPAR([F:ADS]DOSSIER,"RELEASE",func APRODUCT.FORMAT_RELEASE(VERSION)) From SUBADS
   If VERSION=val(SUPVERS)
       Call MAJPAR([F:ADS]DOSSIER,"RELABR",func APRODUCT.AGETRELEASEABR(GDOSREF)) From SUBADS
   Endif
   If VERSION=val(SUPVERS)
       Call MAJPAR([F:ADS]DOSSIER,"NUMPATCH",num$(int((VERSION-int(VERSION))*1000))) From SUBADS
   Else
        Call MAJPAR([F:ADS]DOSSIER,"NUMPATCH","0") From SUBADS
   Endif
Endif

Return

#-------------------------------------------------------------------#
# Erreurs
#-------------------------------------------------------------------#

$ERREUR
GERRDOS = errn
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)+"\"+string$(GERREUR>0,errmes$(GERREUR))-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

