#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################################
# UUMGPOSTRC53                                         Module Commun Data  #
#                                                                          #
#              Post-migration of Sales/BP Invoices                         #
#                                                                          #
# Management of new table : TRCVCRDOC  -  Log file of accounting entries   #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSTRC53") From LECFIC
  Endif

  #Call RAZ_UUMGPOSTRC53(DOSSIER)
  Call MAJ_UUMGPOSTRC53(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


########################################################################
Subprog RAZ_UUMGPOSTRC53(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSTRC53",ERR) From TRTMIG

End

###################################################################################
Subprog MAJ_UUMGPOSTRC53(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(8)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC53",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC53",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC53",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC53",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGPOSTRC53 Accouting log file Process : Update TRCVCRDOC") From DOSSUB
Call ECR_TRACE("UUMGPOSTRC53 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Opening of files  -----#
If clalev([F:TVD]) : Close File [TVD] : Endif
If clalev([F:TVD])  = 0 : Local File =DOSSIER+".TRCVCRDOC"   [TVD]  : Endif      # Accounting log file
If clalev([F:SIH])  = 0 : Local File =DOSSIER+".SINVOICE"    [SIH]  : Endif      # Sales/BP Invoices
If clalev([F:DUD])  = 0 : Local File =DOSSIER+".GACCDUDATE"  [DUD]  : Endif      # Open item

#-----  Declaration of Variables
Gosub MIG_OUVRE From TRTMIG
Local Char WTAB_TVD (100) (adxwrb)
Local Shortint WCPT_TVD

# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3
Local Date DCLE1

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_COM03
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:SIH]STA=3 & [F:SIH]ACCNUM>0 & [F:SIH]NUM>'"+ACLE1+"'"
Else
 CRITERE = "[F:SIH]STA=3 & [F:SIH]ACCNUM>0 & 1=1"
Endif

Trbegin [TVD]
GOK = 1

For [SIH]SIH0  Where evalue(CRITERE)

 NBLUS+=1

 Read [DUD]DUD1(1) = [F:SIH]ACCNUM
 If !fstat
  Read [TVD]TVD2 = [F:DUD]TYP;[F:DUD]NUM
  If fstat
   Raz [TVD]
   [F:TVD]TYPNUM = 2
   [F:TVD]NUM    = [F:SIH]NUM
   [F:TVD]ACCNUM = [F:SIH]ACCNUM
   [F:TVD]TYPVCR = [F:DUD]TYP
   [F:TVD]NUMVCR = [F:DUD]NUM
   [F:TVD]CREUSR = GUSER
   [F:TVD]CREDAT = date$
   [F:TVD]UPDUSR = GUSER
   [F:TVD]UPDDAT = date$

   # To Save reference
   Gosub TVD_STK
   WriteB [TVD]
   If fstat
    Call ECR_TRACE("File TRCVCRDOC, Error ="-num$(fstat),1) From GESECRAN
    # To Display reference
    Gosub TVD_ERRTRA
    GOK=0 : Break
   Endif
  Endif
 Endif

 NBCOMMIT += 1
 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:SIH]NUM
  STOP=1
  Break
 Endif
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC53",7,ERR) From TRTMIG
Else
 Flush [F:TVD]
 If fstat
  Call ECR_TRACE("File TRCVCRDOC, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub TVD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Commit
 Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSTRC53",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_COM03
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [TVD], [SIH], [DUD]

$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSTRC53") From TRTMIG
Call ECR_TIME("UUMGPOSTRC53 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

##############################################################################################
$TVD_STK
Call STK (WTAB_TVD,WCPT_TVD,[F:TVD]NUM) From TRTMIG
Return
##############################################################################################
$TVD_ERRTRA
Call ERRTRA (WTAB_TVD,WCPT_TVD,"File TRCVCRDOC(NUM)=") From TRTMIG
Return

