#*********************************************************************#
# SUBTIT : W-A-S         VP/OL - Septembre 2009                       #
#*********************************************************************#
# Article WAS                                                         #
#*********************************************************************#

$ACTION
Case ACTION
  When "OUVRE"            : Gosub OUVRE
  When "LIENS"            : Gosub LIENS
  When "MODIF"            : Gosub MODIF
  When "CREATION"         : Gosub CREATION
  When "APRES_CRE"        : Gosub APRES_CRE
  When "MODIF"            : Gosub MODIF
  When "APRES_MOD"        : Gosub APRES_MOD
  When "ANNULE"           : Gosub ANNULE
  When "DEFLIG"           : Gosub DEFLIG
  When "INICRE_LIG"       : Gosub INI_LIG    
  When "INIMOD_LIG"       : Gosub INI_LIG   
  When "ABANDON"          : Gosub ABANDON
  When "RAZCRE"           : Gosub RAZCRE 
  When "RAZDUP"           : Gosub RAZDUP 
  When "AVANT_MODFIC"     : Gosub AVANT_MODFIC
  When "INICRE"           : Gosub INICRE
  When "INIMOD"           : Gosub INIMOD

  When Default
Endcase
Return


$OUVRE

If !clalev([F:TXC]) Local File TEXCLOB [TXC] Endif 

Gosub DECLARE From TABLEAUX

Call INI_CLOB From ACLOB

Return

$LIENS 


If [M:TIT1]TITTEX <> ""
  If !GIMPORT : Call SET_IMAGE (4) From GESECRAN : Endif
Else
  If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif
Endif

If GFONC1="GESTIT" Call RAZ_CLOB From ACLOB Endif

# -- Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX
Local Integer STAT
If [M:TIT1]TITTEX <> ""
  Read [TXC]TXC0=[M:TIT1]TITTEX
  Call RANGE_CLOB([F:TXC]TEXTE,[M:TIT1]TITTEX,STAT) From ACLOB
  Call LIRE_CLOB([M:TIT1]TEXTE,[F:TIT]TITTEX,STAT) From ACLOB 
Endif
Return


$CREATION

Gosub CREATION From TABLEAUX
If GOK < 1  Return  Endif
Gosub TEXTRA
If GOK<1 : Return : Endif

Return


$APRES_CRE 
# -- Rechargement des indicateurs UPDFLG et CREFLG # 
Gosub LIENS From TABLEAUX 

Return

################################################################################################
#           programme - process  SUBTIT
#           Objet Articles WEB
#
#################################################################################################



$MODIF

Gosub MODIF From TABLEAUX
If GOK < 1  Return  Endif
Gosub TEXTRA
If GOK<1 : Return : Endif

Return
 
$APRES_MOD 
# -- Rechargement des indicateurs UPDFLG et CREFLG # 
Gosub LIENS From TABLEAUX 
Return 

$ANNULE
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK < 1  Return  Endif
Local Integer WRET
If left$([F:TIT]TITTEX,3)="TIT"
   Call SUP_CLOB([F:TIT]TITTEX,WRET) From TRTX3TEX
Endif

Call SUPTEXTRA("TITMMASTER","INTDES1",[M]ITMREF,"") From ATEXTRA

Return


$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [TIT2]
Default File [TIK]
CRIT = '[F:TIK]ITMREF="'+[M:TIT0]ITMREF+'"'
FICLIG = "TITMLINK" : ABLIG = "TIK"
ZONLIG = "LIG"
Return

####################################################################
$INI_LIG
# -- alim no commande
[F:TIK]ITMREF = [F:TIT]ITMREF
Return

####################################################################
$ABANDON
Local Integer WRET

If GREP="D"
   If left$([M:TIT1]TITTEX,3)="TIT"
      Call SUP_CLOB([M:TIT1]TITTEX,WRET) From TRTX3TEX
   Endif
Endif

Call RAZ_CLOB From ACLOB


Return

####################################################################
$RAZCRE

Call RAZ_CLOB From ACLOB
Raz [M:TIT1]TITTEX

Return

####################################################################
$RAZDUP

Local Integer WRET
Call RAZ_CLOB From ACLOB

If left$([M:TIT1]TITTEX,3)="TIT"
   Call DUP_CLOB("TIT",[M:TIT1]TITTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M:TIT1]TITTEX Endif
Endif

Return

#########################################################################
$AVANT_MODFIC

Local Integer WRET
If [M:TIT1]TITTEX="" & left$([F:TIT]TITTEX,3)="TIT"
    Call SUP_CLOB([F:TIT]TITTEX,WRET) From TRTX3TEX
Endif


Return

##########################################################################
$INICRE

Gosub CRE_CLOB

Return

##########################################################################
$INIMOD

Gosub CRE_CLOB

Return

##########################################################################
$CRE_CLOB

Local Integer WRETOUR

If [M:TIT1]TEXTE<>"" & [M:TIT1]TITTEX=""
 Local Integer WTEXSEQ
 Raz WRETOUR
 Call NUM_TXC("TIT",WTEXSEQ,WRETOUR) From TRTX3TEX
 If WRETOUR=0
  [M:TIT1]TITTEX="TIT"+"~"+format$("N0:8#",num$(WTEXSEQ))
 Endif

Endif
If [M:TIT1]TITTEX<>""
   If left$([M:TIT1]TITTEX,3)="TIT"
      Raz WRETOUR
      Call RANGE_CLOB([M:TIT1]TEXTE,[M:TIT1]TITTEX,STAT) From ACLOB
      Call CRE_CLOB([M:TIT1]TITTEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:TIT]TITTEX = [M:TIT1]TITTEX
   
Endif


Return

###################
$TEXTRA

If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TITMMASTER","INTDES1",CLECUR2,CLECUR1,"TITMMASTER","INTDES1",[M]ITMREF,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]INTDES1,"TITMMASTER","INTDES1",[M]ITMREF,"") From ATEXTRA

Return

