#<AdxTL>@(#)1.0.0.0 $Revision$
# CONSULTATION EVENEMENT
# ======================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
# Liste des fonctions :
# -------------------
#
# Subprog AS_NUM(VALEUR)
# Subprog B1_NUM(VALEUR)
# Subprog AV_LIN(VALEUR)
#
# Liste des routines :
# ------------------
#
# $ACTION
# $OUVRE
# $DEBUT
# $FIR
# $LAS
# $PRE
# $SUI
# $RECHARGE
# $EXCLUSION
# $FILL_DETEVT
#
########################################################################################################################
# Modifications :
# -------------
#
# - MWA - 26.02.2015 - FQ105600 - Ajout unité d'oeuvre pour le plan de production
# - CBO - 17.02.2015 - FQ100398/13: Liaison FXD PHY
# - MDJ - 17.04.2014 - FQ 98522 - Table DEPRECARC[DEPA] not open in AS_NBLIG1
# - MWA - 14.10.2013 - FQ 93429 - Problème d'affichage sur type de pièce.
# - CBO - 12.03.2012 - FQ 80246 - GFMDAT4 au lieu de DD[/]MM[/]YYYY
# - GBO - 10.01.2011 - FQ 70466 - Evénement et archivage chg plan de production
# - GBO - 18.11.2010 - FQ 69205 - Plantage sur le chargement de l'onglet DPP1. L'effzo de DPP1 est fait après l'alimentation
#                                 du plan.
# - GBO - 23.09.2010 - FQ 67485 - Plantage sur la tentative de chargement de l'onglet DPP1 lorsque l'événement n'est pas
#                                 géré par plan.
# - GBO - 02.08.2010 - FQ 65636 - Archivage plan sur MTC et RVA NC30/NC34
# - GLE - 16.11.2009 - FQ 59900 - Gestion des codes activités dans la table diverse des tables d'événements 962
#
########################################################################################################################
Local Char PARAM(30)(1..4) , VALEUR(30)
PARAM(1)= "LEACRT"
PARAM(2)= "CRA0801LEASE000002"
PARAM(3)= "20090126552163410"
PARAM(4)= ""
Call SAISIE_CHAR(VALEUR,PARAM,"DETEVT","TRTDETEVT","") From GSAISIE
End

#-------------------------------------------------------------------------------------
$ACTION
 #If GUSER="GBO" : Infbox ACTION : Endif
 Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
  When "FIR"   : Gosub FIR
  When "LAS"   : Gosub LAS
  When "PRE"   : Gosub PRE
  When "SUI"   : Gosub SUI
  When Default
 Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE

 Local Char    LEVT
 Local Char    LREF
 Local Char    LTIMSTP
 Local Char    LATB
 Local Char    LNOMMSK
 Local Integer LNUMAML
 Local Char    LINTIT
 Local Integer LINDICE

 LEVT    = PARAM(1)
 LREF    = PARAM(2)
 LTIMSTP = PARAM(3)
 LINDICE = val(PARAM(4))

Return

#-------------------------------------------------------------------------------------
$DEBUT

 Global Date G_FIYENDCUR      : # Date de fin de l'exercice courant
 Global Date G_PERENDCUR      : # Date de fin de la période courante de l'exercice courant
 Global Date G_FIYENDNXT      : # Date de fin de l'exercice suivant
 Global Date G_PERENDNXT      : # Date de fin de la période courante de l'exercice suivant

 If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
 Filter [ADI] Where NUMTAB=962 & CODE=LEVT
 Read [F:ADI] Last
 If fstat or !find([F:ADI]A2,GTABEVT) : # FQ59900 ajout du find
  # Erreur
  Return
 Endif
 LATB = [F:ADI]A2
 If clalev ([F:REVT]) : Close Local File [REVT] : Endif
 Local File =LATB [F:REVT]
 Read [F:REVT]EVE0=LREF;LTIMSTP
 If fstat
  # Erreur
  Return
 Endif
 [M:DEH]EVT=LEVT
 [M:DEH]=[F:REVT]
 Call GET_CNX_FROM_PLAN ([M:DEH]CPY, [M:DEH]DPRPLN, [M:DEH]CNX) From GLOBIENS
 [M:DEG]=[F:REVT]
 Gosub EXCLUSION
 If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
 If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
 If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif
 Filter [ATZ] Where CODFIC = LATB
 Raz [M:DEA], [M:DED], [M:DEM], [M:DEN]
 For [F:ATZ]CODZONE
  Gosub FILL_DETEVT
 Next
 Filter [ATZ]
 If [M:DEG]CPTFLG=G_OUI
  If !clalev([F:LCD]) : Local File LNKCPTABD [LCD] : Endif
  Filter [F:LCD] Where REF=LREF & TIMSTP=LTIMSTP
  Read [F:LCD] First
  If !fstat
   [M:DEG]TYP   =[F:LCD]TYP
   [M:DEG]NUM   =[F:LCD]NUM
   [M:DEG]CPTREF=[F:LCD]CPTREF
  Else
   # FQ93429
   Raz [M:DEG]TYP
   Raz [M:DEG]NUM
   Raz [M:DEG]CPTREF
  Endif
 Else
  Raz [M:DEG]TYP
  Raz [M:DEG]NUM
  Raz [M:DEG]CPTREF
 Endif
 Diszo [M:DEG]NUM

 #Fq67485
#If [M:DEH]EVT="FASMTC" | [M:DEH]EVT="FASREEVAL" | [M:DEH]EVT="FASREEVAL"
 If find([M:DEH]EVT,GARCEVT)
  Gosub LOAD_DPP1
 Endif

 If [M:DPP1]NBLIG1
  [M:DEH]FLGARC="216"
 Else
  [M:DEH]FLGARC=""
 Endif

 Affzo [M:DEH]
 Affzo [M:DEM]
 Affzo [M:DEN]
 Affzo [M:DED]
 Affzo [M:DEA]
Return

#-------------------------------------------------------------------------------------
$LOAD_DPP1

  If clalev([F:DEPA])=0   : Local File DEPRECARC        [DEPA]   : Endif
  If clalev([F:DEP1])=0   : Local File DEPRECARC        [DEP1]   : Endif
  If clalev([F:DEP2])=0   : Local File DEPRECARC        [DEP2]   : Endif
  If clalev([F:DEP3])=0   : Local File DEPRECARC        [DEP3]   : Endif
  If clalev([F:FIS]) =0   : Local File FISCYEAR         [FIS]    : Endif
  If clalev([F:CNX]) =0   : Local File CONTEXT          [CNX]    : Endif

  Local Integer LCURDPP, LCURCNX

  Effzo [M:DPP1] #Fq69205-Déplacement du raz de l'écran

  # Initialisation du contexte en cours
  [M:DPP1]CURDPP = [M:DEH]DPRPLN

  # Lecture de la devise du contexte en cours
  Call GET_CNX_FROM_PLAN ([F:FAS]CPY, [M:DPP1]CURDPP, [L]LCURCNX) From GLOBIENS
  Read [CNX] CNX0=[F:FAS]CPY;[L]LCURCNX
  If (fstat) Then : Raz [F:CNX] : Endif
  [M:DPP1]CUR=[F:CNX]CUR

  # FQ105600 Récupération de l'unité du plan de production utilisée en paramètre du type de données QTY ou QT1
  If ([F:FAS]PROPLN <> "") Then
    If clalev([F:PPH]) =0    : Local File PROPLNH       [PPH]    : Endif
    Read [F:PPH]PPH0=[F:FAS]PROPLN
  Endif

  # Récupération de la date de fin de l'exercice courant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TECOURA
  Read [FIS]First
  If (fstat) Then : Raz [F:FIS] : Endif
  Filter [FIS]
  G_FIYENDCUR = [F:FIS]DATENDFIY
  G_PERENDCUR = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  # Récupération de la date de fin de l'exercice suivant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TESUIV
  Read [FIS]First
  Filter [FIS]
  If (fstat) Then : Raz [F:FIS] : Endif
  G_FIYENDNXT = [F:FIS]DATENDFIY
  G_PERENDNXT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
  nolign=1

   Filter [DEP1] Where AASREF=[M:DEH]REF and DPRPLN=[M:DEH]DPRPLN & EVT=[M:DEH]EVT & TIMSTP=[M:DEG]TIMSTP
&  Order By Key CLE=AASREF; DPRPLN; FIYENDDAT; PERENDDAT Desc
  #> 1 >>>>>>>>>>>>>>>>>
  For [DEP1] CLE(3)

    #> 2 >>>>>>>>>>>>>>>>>
    For [DEP1] CLE
      #- 3 ----------------
      If ( [F:DEP1]STRDPRDAT <= [F:DEP1]FIYENDDAT ) Then
        # -- Positionnement sur la dernière période de chaque exercice
        #=================
        [M:DPP1] = [F:DEP1]
        #=================
        # Lecture DEPREC début exercice
        Filter [DEP3] Where AASREF=[M:DEH]REF and DPRPLN=[M:DEH]DPRPLN and FIYENDDAT=[F:DEP1]FIYENDDAT and EVT=[M:DEH]EVT and TIMSTP=[M:DEG]TIMSTP
&                  Order By Key CLE=AASREF; DPRPLN; FIYENDDAT; PERENDDAT Desc
        Read  [DEP3] First
        If (fstat) Then : Infbox num$(fstat) : Endif
        Filter [DEP3]
        [M:DPP1]FCY1(nolign-1)       = [F:DEP1]FCY
        [M:DPP1]FIYENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:DEP1]FIYENDDAT)
        [M:DPP1]RSDDUR(nolign-1)   = [F:DEP3]RSDDUR
        [M:DPP1]DPRVAL(nolign-1) = [F:DEP1]DPRBAS - [F:DEP1]RSDVAL
        [M:DPP1]DPRBAS(nolign-1) = [F:DEP1]DPRBAS
        [M:DPP1]IMLBLC(nolign-1)   = [F:DEP3]IMLBLC
        [M:DPP1]IML(nolign-1)       = [F:DEP1]PERIMLCUM + [F:DEP1]IML
        [M:DPP1]IMLRVE(nolign-1)    = [F:DEP1]PERRVECUM + [F:DEP1]IMLRVE
        [M:DPP1]IMLRVETRF(nolign-1) = [F:DEP1]PERTRFCUM + [F:DEP1]IMLRVETRF
        If ( [F:FAS]ISSDAT <> [0/0/0] and
&            [F:FAS]ISSDAT >= [F:DEP1]FIYSTRDAT and [F:FAS]ISSDAT <= [F:DEP1]FIYENDDAT ) Then
          [M:DPP1]IMLRVEISS(nolign-1) = [F:FAS]IMLRVEISS ([M:DPP1]CURDPP-1)
        Endif
        If ( [F:FAS]ISSDAT <> [0/0/0] and
&            [F:FAS]ISSDAT >= [F:DEP1]FIYSTRDAT and [F:FAS]ISSDAT <= [F:DEP1]FIYENDDAT ) Then
          [M:DPP1]DERRVEISS(nolign-1) = [F:FAS]DERRVEISS
        Endif
        [M:DPP1]DPRRAT2E(nolign-1)   = [F:DEP1]DPRRAT2
        [M:DPP1]RSDQTY(nolign-1)    = [F:DEP1]RSDQTY + [F:DEP1]FIYQTY - [F:DEP1]PERQTY
        Filter [DEP2] Where AASREF=[M:DPP1]AASREF and DPRPLN=[M:DPP1]CURDPP and
&                           FIYENDDAT=[M:DPP1]FIYENDDAT(nolign-1)
&                  Order By AASREF; DPRPLN; FIYENDDAT; PERENDDAT
        [M:DPP1]RVAAMT(nolign-1)    = 0
        [M:DPP1]RVACRB(nolign-1)    = 0
        [M:DPP1]MTCDEVADJ(nolign-1) = 0
        [M:DPP1]MTCDPEDEV(nolign-1) = 0
        For [DEP2]
          If ([F:DEP2]RVAAMT <> 0 ) Then : [M:DPP1]RVAAMT(nolign-1) += [F:DEP2]RVAAMT : Endif
          [M:DPP1]RVACRB(nolign-1) += [F:DEP2]RVACRB
          If ( [F:DEP2]MTCDPEDAT <> [0/0/0] ) Then
            [M:DPP1]MTCDEVADJ(nolign-1) = [F:DEP2]MTCDEVADJ
            [M:DPP1]MTCDPEDEV(nolign-1) = [F:DEP2]MTCDPEDEV
          Endif
        Next
        Filter [DEP2]
        If ( ( [M:DPP1]DPRBAS(nolign-1) > 0 and  [M:DPP1]EXERVADEV(nolign-1) < 0 ) or
&            ( [M:DPP1]DPRBAS(nolign-1) < 0 and  [M:DPP1]EXERVADEV(nolign-1) > 0 )     ) Then
          [M:DPP1]EXERVADEV(nolign-1) = 0
        Endif
        If (G_ACTCCN = G_OUI ) Then
          [M:DPP1]EXECADCRB(nolign-1)  = [F:DEP1]P_1CADCRB + [F:DEP1]PERCADCRB
          [M:DPP1]TRFCADCUM(nolign-1)  = [F:DEP3]TRFCADCUM
        Endif
        nolign += 1
        If ( [F:DEP1]NBV = [F:DEP1]RSDVAL ) Then
          BSORFNDEXE = 1
        Endif
      Endif
      #- 3 ----------------
      Break 1
    Next
    #> 2 >>>>>>>>>>>>>>>>>
  Next
  #> 1 >>>>>>>>>>>>>>>>>
  Filter [DEP1]
  [M:DPP1]NBLIG1 = nolign-1
 nolign=1 : Call AS_NBLIG1
 Affzo [M:DPP1]
Return

#-------------------------------------------------------------------------------------
$FIR
 If dim([M:ELT]NBEVT)<0 : Return : Endif
 LINDICE=1 : Gosub RECHARGE
Return

#-------------------------------------------------------------------------------------
$LAS
 If dim([M:ELT]NBEVT)<0 : Return : Endif
 LINDICE=[M:ELT]NBEVT : Gosub RECHARGE
Return

#-------------------------------------------------------------------------------------
$PRE
 If dim([M:ELT]NBEVT)<0 : Return : Endif
 If LINDICE>1
  LINDICE-=1 : Gosub RECHARGE
 Endif
Return

#-------------------------------------------------------------------------------------
$SUI
 If dim([M:ELT]NBEVT)<0 : Return : Endif
 If LINDICE<[M:ELT]NBEVT
  LINDICE+=1 : Gosub RECHARGE
 Endif
Return

#-------------------------------------------------------------------------------------
$RECHARGE
 LEVT    = [M:ELT]EVT(LINDICE-1)
 LREF    = [M:ELT]REF(LINDICE-1)
 LTIMSTP = [M:ELT]TIMSTP(LINDICE-1)
 Gosub DEBUT
Return

#-------------------------------------------------------------------------------------
$EXCLUSION
 Local Char EXCFLD(10)(1..21)
 EXCFLD(01)  = "CPY"
 EXCFLD(02)  = "FCY"
 EXCFLD(03)  = "REF"
 EXCFLD(04)  = "LIN"
 EXCFLD(05)  = "DPRPLN"
 EXCFLD(06)  = "CNX"
 EXCFLD(07)  = "EVTINT"
 EXCFLD(08)  = "CREUSR"
 EXCFLD(09)  = "CREDAT"
 EXCFLD(10)  = "CRETIM"
 EXCFLD(11)  = "TIMSTP"
 EXCFLD(12)  = "EVTDAT"
 EXCFLD(13)  = "CPTDATINT"
 EXCFLD(14)  = "CPTFLG"
 EXCFLD(15)  = "SNSEVE"
 EXCFLD(16)  = "SNSCPT"
 EXCFLD(17)  = "CREUSRO"
 EXCFLD(18)  = "TIMSTPO"
 EXCFLD(19)  = "CPTDATINTO"
 EXCFLD(20)  = "CREORI"
 EXCFLD(21)  = "CUR"
Return

#-------------------------------------------------------------------------------------
$FILL_DETEVT

 If find([F:ATZ]CODZONE,EXCFLD) : Return : Endif

 Read [F:ATY]CODTYP=[F:ATZ]CODTYP

 #> Entier

 If [F:ATY]TYPTYP=1
  LNOMMSK = "[M:DEM]"
  LNUMAML = [F:ATZ]NOLIB
  [M:DEM]NBCHM   += 1
  [M:DEM]FLDNAMM([M:DEM]NBCHM-1)  = [F:ATZ]CODZONE
  Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
  [M:DEM]FLDDESM([M:DEM]NBCHM-1)  = [F:ATX]TEXTE
  If evalue("[F:REVT]"+[F:ATZ]CODZONE+">0")
   [M:DEM]FLDVALM([M:DEM]NBCHM-1)  = mess(evalue("[F:REVT]"+[F:ATZ]CODZONE),LNUMAML,1)
  Endif
 Endif

 #> Décimal

 If [F:ATY]TYPTYP=2 | [F:ATY]TYPTYP=3 | [F:ATY]TYPTYP=4 | [F:ATY]TYPTYP=5 | [F:ATY]TYPTYP=6
  LNOMMSK = "[M:DEN]"
  [M:DEN]NBCHN   += 1
  [M:DEN]FLDNAMN([M:DEN]NBCHN-1)  = [F:ATZ]CODZONE
  Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
  [M:DEN]FLDDESN([M:DEN]NBCHN-1)  = [F:ATX]TEXTE
  [M:DEN]FLDVALN([M:DEN]NBCHN-1)  = format$("N:13.2",evalue("[F:REVT]"+[F:ATZ]CODZONE)) #num$(evalue("[F:REVT]"+[F:ATZ]CODZONE))
 Endif

 #> Date

 If [F:ATY]TYPTYP=8
  LNOMMSK = "[M:DED]"
  [M:DED]NBCHD   += 1
  [M:DED]FLDNAMD([M:DED]NBCHD-1)  = [F:ATZ]CODZONE
  Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
  [M:DED]FLDDESD([M:DED]NBCHD-1)  = [F:ATX]TEXTE
  If evalue("[F:REVT]"+[F:ATZ]CODZONE)<>[0/0/0]
   [M:DED]FLDVALD([M:DED]NBCHD-1)  = format$("D:" + GFMDAT4,evalue("[F:REVT]"+[F:ATZ]CODZONE))
  Endif
 Endif

 #> Alphanumérique

 If [F:ATY]TYPTYP=7
  LNOMMSK = "[M:DEA]"
  [M:DEA]NBCHA   += 1
  [M:DEA]FLDNAMA([M:DEA]NBCHA-1)  = [F:ATZ]CODZONE
  Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
  [M:DEA]FLDDESA([M:DEA]NBCHA-1)  = [F:ATX]TEXTE
  # FQ100398/13
  If [F:ATY]CODTYP = "AXX" or [F:ATY]CODTYP = "AX1" or [F:ATY]CODTYP = "AX2" or [F:ATY]CODTYP = "AX3"
    Call LECTEXTRA([M:DEA]FLDVALA([M:DEA]NBCHA-1), LATB, [F:ATZ]CODZONE, [F:PHY]PHYREF, [F:REVT]TIMSTP) From ATEXTRA

  Else
    [M:DEA]FLDVALA([M:DEA]NBCHA-1)  = evalue("[F:REVT]"+[F:ATZ]CODZONE)
  Endif
 Endif

Return

######################################################################################
Subprog AS_NUM(VALEUR)
Variable Char    VALEUR()
 If [M]NUM=""
  GBOUT1=""
 Endif
End

######################################################################################
Subprog B1_NUM(VALEUR)
Variable Char    VALEUR()
 Local Char    PAR(30)(1..3)
 PAR(1) = [M:DEG]TYP
 PAR(2) = [M:DEG]NUM
 PAR(3) = num$(func GLOBIENS.GET_LEDTYP_FROM_PLAN ([M:DEH]CPY, [M:DEH]DPRPLN))
 Call SAISIE_CHAR(VALEUR,PAR,"GPCCAB","TRTGPCCAB","") From GSAISIE
End

######################################################################################
Subprog AV_LIN(VALEUR)
Variable Decimal VALEUR
 If [F:ADI]N2<>GVML_OMDEPEN
  Chgfmt [M]LIN With "-N:4"
 Endif
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran DPPARC) 28/07/2010 17:44:46 (GBO)
######################################################################################
Subprog AS_NBLIG1

  Local Integer NOL
  Local Integer BSORFNDPER  : BSORFNDPER = 0

  # Lecture des dotations périodiques de l'exercice choisi dans le tableau

  [L]NOL=nolign-1
  [M:DPP1]ZONCUR = [M:DPP1]FIYENDDAT([L]NOL)


  nolign = 1
  Effzo [M:DPP1]20

  If clalev([F:DEPA])=0   : Local File DEPRECARC   [DEPA]   : Endif  #FQ-98522

  Filter [DEPA] Where AASREF=[M:DEH]REF and DPRPLN=[M:DEH]DPRPLN and FIYENDDAT = [M:DPP1]ZONCUR & EVT=[M:DEH]EVT and TIMSTP=[M:DEG]TIMSTP
&              Order By AASREF; DPRPLN; FIYENDDAT; PERENDDAT

    For [DEPA]

      # FQ54202
      [M:DPP1]FCY2(nolign-1)       = [F:DEPA]FCY
      [M:DPP1]FIYSTRDAT2(nolign-1) = [F:DEPA]FIYSTRDAT
      [M:DPP1]FIYENDDAT2(nolign-1) = [F:DEPA]FIYENDDAT
      [M:DPP1]PERSTRDAT(nolign-1)  = [F:DEPA]PERSTRDAT
      [M:DPP1]PERENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:DEPA]PERENDDAT)
      [M:DPP1]PERENDDAT(nolign-1)  = [F:DEPA]PERENDDAT
      [M:DPP1]DPRBAS2(nolign-1)    = [F:DEPA]DPRBAS
      [M:DPP1]RSDVAL2(nolign-1)    = [F:DEPA]RSDVAL
      [M:DPP1]DPRVAL2(nolign-1)    = [F:DEPA]DPRBAS - [F:DEPA]RSDVAL
      [M:DPP1]PERCLOCUM(nolign-1)  = [F:DEPA]DPRCUM + [F:DEPA]PERCLOCUM + [F:DEPA]PERCLOEXC
      [M:DPP1]IMLBLC2(nolign-1)    = [F:DEPA]IMLBLC
      # FQ64544
      [M:DPP1]PERDPEFLG(nolign-1)  = [F:DEPA]PERDPEFLG
      [M:DPP1]PERENDDPE(nolign-1)  = [F:DEPA]PERENDDPE
      [M:DPP1]PEREXCDPR(nolign-1)  = [F:DEPA]PEREXCDPR
      [M:DPP1]IML2(nolign-1)       = [F:DEPA]IML
      [M:DPP1]IMLRVE2(nolign-1)    = [F:DEPA]IMLRVE
      [M:DPP1]IMLRVETRF2(nolign-1) = [F:DEPA]IMLRVETRF
      If ( [F:FAS]ISSDAT <> [0/0/0] and [F:DEPA]IMLBLC <> 0 and
&          [F:FAS]ISSDAT >= [F:DEPA]PERSTRDAT and [F:FAS]ISSDAT <= [F:DEPA]PERENDDAT ) Then
        [M:DPP1]IMLRVEISS2(nolign-1) = [F:FAS]IMLRVEISS ([M:DPP1]CURDPP-1)
      Endif
      If ( [F:DEPA]NBV = [F:DEPA]RSDVAL and BSORFNDPER = 1 ) Then
        [M:DPP1]DERRVEISS2(nolign-1) = [F:FAS]DERRVEISS
      Endif
      [M:DPP1]NBV2(nolign-1)       = [F:DEPA]NBV
      # FQ59941
      If ( G_ACTKRU = G_OUI ) Then
        [M:DPP1]KBIRNBV(nolign-1)       = [F:DEPA]KBIRNBV
      Endif
      [M:DPP1]IMLRVELIM(nolign-1)  = [F:DEPA]IMLRVELIM
      [M:DPP1]NSPVAL2(nolign-1)    = [F:DEPA]NSPVAL
      [M:DPP1]IMLTYP2(nolign-1)    = [F:DEPA]IMLTYP
      [M:DPP1]INTIMLTYP2(nolign-1) = [F:DEPA]INTIMLTYP
      [M:DPP1]EXTIMLTYP2(nolign-1) = [F:DEPA]EXTIMLTYP
      [M:DPP1]RVADAT2(nolign-1)    = [F:DEPA]RVADAT
      [M:DPP1]RVATIADAT(nolign-1)  = [F:DEPA]RVATIADAT
      [M:DPP1]RVATYP(nolign-1)     = [F:DEPA]RVATYP
      [M:DPP1]RVACOE2(nolign-1)    = [F:DEPA]RVACOE
      [M:DPP1]RVACOEREF(nolign-1)  = [F:DEPA]RVACOEREF
      [M:DPP1]EXERVADEV2(nolign-1) = [F:DEPA]EXERVADEV + [F:DEPA]PERRVADEV
      # FQ64311
      If ( ( [M:DPP1]DPRBAS2(nolign-1) > 0 and [M:DPP1]EXERVADEV2(nolign-1) < 0 ) or
&          ( [M:DPP1]DPRBAS2(nolign-1) < 0 and [M:DPP1]EXERVADEV2(nolign-1) > 0 )     ) Then
        [M:DPP1]EXERVADEV2(nolign-1) = 0
      Endif
      [M:DPP1]RVAAMT2(nolign-1)    = [F:DEPA]RVAAMT
      [M:DPP1]RVACRB2(nolign-1)    = [F:DEPA]RVACRB
      [M:DPP1]DPM2(nolign-1)       = [F:DEPA]DPM
      [M:DPP1]DPRDUR2(nolign-1)    = [F:DEPA]DPRDUR
      [M:DPP1]APLDUR2(nolign-1)    = [F:DEPA]APLDUR
      [M:DPP1]RSDDUR2(nolign-1)    = [F:DEPA]RSDDUR
      [M:DPP1]DPRRATFLG2(nolign-1) = [F:DEPA]DPRRATFLG
      [M:DPP1]DPRRAT2(nolign-1)    = [F:DEPA]DPRRAT
      [M:DPP1]DPRRAT2P(nolign-1)   = [F:DEPA]DPRRAT2
      [M:DPP1]ACLCOE2(nolign-1)    = [F:DEPA]ACLCOE
      [M:DPP1]PRATYP2(nolign-1)    = [F:DEPA]PRATYP
      [M:DPP1]STRDPRDAT2(nolign-1) = [F:DEPA]STRDPRDAT
      [M:DPP1]ENDDPRDAT2(nolign-1) = [F:DEPA]ENDDPRDAT
      [M:DPP1]ALWCOD2(nolign-1)    = [F:DEPA]ALWCOD
      [M:DPP1]RSDQTY2(nolign-1)    = [F:DEPA]RSDQTY
      [M:DPP1]FIYQTY2(nolign-1)    = [F:DEPA]FIYQTY
      [M:DPP1]PERQTY(nolign-1)     = [F:DEPA]PERQTY
      [M:DPP1]MTCDPEDAT(nolign-1)  = [F:DEPA]MTCDPEDAT
      [M:DPP1]MTCTIATYP(nolign-1)  = [F:DEPA]MTCTIATYP
      [M:DPP1]MTCTIADAT(nolign-1)  = [F:DEPA]MTCTIADAT
      [M:DPP1]DPEDEV(nolign-1)     = [F:DEPA]DPEDEV
      [M:DPP1]EXCDEV(nolign-1)     = [F:DEPA]EXCDEV
      [M:DPP1]DERDEV(nolign-1)     = [F:DEPA]DERDEV
      [M:DPP1]DERRVEDEV(nolign-1)  = [F:DEPA]DERRVEDEV
      [M:DPP1]RVACRBDEV(nolign-1)  = [F:DEPA]RVACRBDEV
      [M:DPP1]RVETRFDEV(nolign-1)  = [F:DEPA]RVETRFDEV
      [M:DPP1]PSTDPE(nolign-1)     = [F:DEPA]PSTDPE
      [M:DPP1]PSTEXC(nolign-1)     = [F:DEPA]PSTEXC
      [M:DPP1]PSTDER(nolign-1)     = [F:DEPA]PSTDER
      [M:DPP1]PSTDERRVE(nolign-1)  = [F:DEPA]PSTDERRVE
      [M:DPP1]PSTRVACRB(nolign-1)  = [F:DEPA]PSTRVACRB
      [M:DPP1]PSTRVETRF(nolign-1)  = [F:DEPA]PSTRVETRF
      [M:DPP1]MTCDPEDEV2(nolign-1) = [F:DEPA]MTCDPEDEV
      [M:DPP1]MTCDEVADJ2(nolign-1) = [F:DEPA]MTCDEVADJ

      [M:DPP1]PERREFCLC2(nolign-1) = [F:DEPA]PERREFCLC
      [M:DPP1]DPMI2(nolign-1)      = [F:DEPA]DPMI
      [M:DPP1]PERREFCL2I(nolign-1) = [F:DEPA]PERREFCLCI
      [M:DPP1]DPMT2(nolign-1)      = [F:DEPA]DPMT
      [M:DPP1]PERREFCL2T(nolign-1) = [F:DEPA]PERREFCLCT
      [M:DPP1]BSEVAL2(nolign-1)    = [F:DEPA]BSEVAL
      [M:DPP1]PERCLOCUMI(nolign-1) = [F:DEPA]EXECLOCUMI + [F:DEPA]PERCLOCUMI
      [M:DPP1]PERCLOCUMT(nolign-1) = [F:DEPA]EXECLOCUMT + [F:DEPA]PERCLOCUMT
      [M:DPP1]DPEI(nolign-1)       = [F:DEPA]DPEI
      [M:DPP1]DPET(nolign-1)       = [F:DEPA]DPET
      [M:DPP1]PEREXCDPRI(nolign-1) = [F:DEPA]PEREXCDPRI
      [M:DPP1]PEREXCDPRT(nolign-1) = [F:DEPA]PEREXCDPRT
      [M:DPP1]NBVI2(nolign-1)      = [F:DEPA]NBVI
      [M:DPP1]NBVT2(nolign-1)      = [F:DEPA]NBVT
      # FQ64544
      [M:DPP1]LNKCUM(nolign-1)     = [F:DEPA]LNKCUM
      [M:DPP1]PERLNKCUM(nolign-1)  = [F:DEPA]PERLNKCUM
      [M:DPP1]LNK(nolign-1)        = [F:DEPA]LNK
      [M:DPP1]LNKDEV(nolign-1)     = [F:DEPA]LNKDEV
      [M:DPP1]PSTLNK(nolign-1)     = [F:DEPA]PSTLNK
      # FQ54343
      If (G_ACTCCN = G_OUI and [M:DPP1]CURDPP = G_CCNPLNCAD and G_CCNRPR = G_OUI and [F:FAS]OWNTYP = GVML_TDCONCE) Then
        [M:DPP1]PERCADCRB2(nolign-1)  = [F:DEPA]PERCADCRB
        [M:DPP1]CADCRBDEV(nolign-1)   = [F:DEPA]CADCRBDEV
        [M:DPP1]PSTCADCRB(nolign-1)   = [F:DEPA]PSTCADCRB
        [M:DPP1]TRFCADCUM2(nolign-1)  = [F:DEPA]TRFCADCUM
        [M:DPP1]P_1CADCRB(nolign-1)   = [F:DEPA]P_1CADCRB
      Endif


      If ( [F:FAS]ISSDAT <> [0/0/0] and
&          [F:FAS]ISSDAT >= [F:DEPA]PERSTRDAT and [F:FAS]ISSDAT <= [F:DEPA]PERENDDAT ) Then
        BSORFNDPER = 1
      Endif

      nolign += 1
    Next
    Filter [DEPA]
    [M:DPP1]NBLIG2 = nolign-1
    Affzo [M:DPP1]30
####  Endif
End

Subprog B2_NBLIG1
Local Decimal BASPAG
#
##
##    AFFICHAGE DETAIL EXERCICE
#
#  Deux fenêtres pour différencier les écrans affichés uniquement pour le détail période
#  et ceux utilisés pour le détail exercice respectivement DPPDET & DPPDETE.
#  les écrans à ne pas afficher sont paramétrés comme invisible au niveau de la fenêtre
#  Le bouton initialement géré par X3 a été remplacé par STD pour être géré par la transaction
#  Le code X3 a été auparavant rapatrié dans la transaction. Manipulation à refaire si un
#  changement au niveau des paramètres de la fenêtre est nécessaire.
#
If !GWEBSERV
 ## Action DPPDET
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "DPPDET"
 PARMSK(1) = [M]AASREF
 PARMSK(2) = num$([M]DPRPLN)
 PARMSK(3) = [M]FIYENDDAT(nolign-1)
 PARMSK(4) = [0/0/0]
 PARMSK(5) = num$(nolign)
 If ([M]DPRPLN =  G301FIS) Then
   Call SAISIE_NUM(BASPAG,PARMSK,"DPPDETE","DPPDET","XWDPPDET") From GSAISIE
 Else
   Call SAISIE_NUM(BASPAG,PARMSK,"DPPDETENF","DPPDET","XWDPPDET") From GSAISIE
 Endif
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub AFF From GSAISIE
End

