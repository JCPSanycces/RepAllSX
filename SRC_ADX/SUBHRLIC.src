#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("HRLIC",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet HRLIC) 17/05/2016 17:17:34 (DLEFR)
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FERME"       : Gosub FERME
    When "LIENS"       : Gosub LIENS
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "AP_CHANGE"   : Gosub AP_CHANGE
    When "ANNULE"      : Gosub ANNULE
    When "CHGCOD"      : Gosub CHGCOD
    When "SEL_TABLE"   : Gosub SEL_TABLE
    When "AS_COD"      : Raz GCURLEG
  Endcase
Return

########################################
$OUVRE
  If clalev ([F:HRLIC])=0 : Local File HRLICAUT [HRLIC] : Endif
  If clalev ([F:HRLIC2])=0 : Local File HRLICAUT [HRLIC2] : Endif
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

  #LIPET - 2017-08-22 - START
  If dim([M:HRLIC1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
  #LIPET - 2017-08-22 - END
Return

########################################
$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  # To manage the button Tunnel
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONHRLIC) : Endif
  VCOD = CLE2

Return

########################################
$LIENS
  GCURLEG = [F:HRLIC]LEG
  #LIPET - 2017-08-22 - START
  #If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  If dim([M:HRLIC1]LEG)=0:If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif:Endif
  #LIPET - 2017-08-22 - END

  # To manage translated texts (data type AX3 & AX1)
  Call LECTEXTRA([M]DESAXX,"HRLICAUT","DESAXX",[M]COD,GCURLEG) From ATEXTRA
  Call LECTEXTRA([M]SHOAXX,"HRLICAUT","SHOAXX",[M]COD,GCURLEG) From ATEXTRA
Return

########################################
$VERIF_CRE
$VERIF_MOD
  If [M]DEFVAL=2
   Filter [F:HRLIC2] Where COD<>[M]COD & LEG=GCURLEG & DEFVAL=2
   Read [F:HRLIC2]HRLIC0 First
   Filter [F:HRLIC2]
   If !fstat
    # A default value already exist for this legislation : XXX
    GMESSAGE = mess(1,10712,1)-":'"-[F:HRLIC2]COD+"'"
    OK = 0 : Return
   Endif
  Endif
Return

########################################
$CREATION
$MODIF
  Gosub TEXTRA
  If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
  If GREP="D"
    ## In duplication mode we want to keep all translated texts
    Call DUPTEXTRA("HRLICAUT","DESAXX",CLECUR1,"","HRLICAUT","DESAXX",[F:HRLIC]COD,GCURLEG)  From ATEXTRA
    Call DUPTEXTRA("HRLICAUT","SHOAXX",CLECUR1,"","HRLICAUT","SHOAXX",[F:HRLIC]COD,GCURLEG)  From ATEXTRA
  Endif
  Call MAJTEXTRA([M]DESAXX,"HRLICAUT","DESAXX",[F:HRLIC]COD,GCURLEG) From ATEXTRA
  Call MAJTEXTRA([M]SHOAXX,"HRLICAUT","SHOAXX",[F:HRLIC]COD,GCURLEG) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
  Call CHGTEXTRA("HRLICAUT","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
  Call CHGTEXTRA("HRLICAUT","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
  Call SUPTEXTRA("HRLICAUT","DESAXX",SUPP,[L]CODE) From ATEXTRA
  Call SUPTEXTRA("HRLICAUT","SHOAXX",SUPP,[L]CODE) From ATEXTRA
Return

########################################
#To change the main code
$CHGCOD
  Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

########################################
$SEL_TABLE
  Case TABLE
    When "SELHRLIC"
      If clalev ([F:HRLIC])=0 : Local File HRLICAUT [HRLIC] : Endif
      OBJET="HRLIC"
      START = "[F:HRLIC]COD"

      #Filter based on code legislation
      If PARAM(1)<>""
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:HRLIC]LEG="'+PARAM(1)+'" | [F:HRLIC]LEG="")',"&") From GOBJSUB
      Endif
      #Filter based on group of company
      If PARAM(2)<>""
        #OBJET=""
        DEFPAG = 1    :# To have page up and page down
        TIT=mess(16,10712,1)   :#Permis et habilitations
        Gosub NOMFIC From ="WOHRLIC"
        Call  TRANSCOL("HRLIC",NBCOL,COL,TIT,FMTCOL) From OBJDIV
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
        If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
        If GUSRACS=2
          Link [HRLIC] With
&           [AGC]AGC0=[F:HRLIC]GRP,
&           [AXX]AXX0="HRLICAUT";"DESAXX";GLANGUE;[F:HRLIC]COD;[F:HRLIC]LEG
&           As [LNK]
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRLIC]GRP="")',"&") From GOBJSUB
        Else
          Link [HRLIC] With
&           [AGC]AGC0=[F:HRLIC]GRP,
&           [AXX]AXX0="HRLICAUT";"DESAXX";GLANGUE;[F:HRLIC]COD;[F:HRLIC]LEG,
&           [ACC]CODACC=GUSER;[F:HRLIC]CODACS
&           As [LNK]
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:AGC]CPY="'+PARAM(2)+'" | [F:HRLIC]GRP="") & ([F:HRLIC]CODACS="" | [F:ACC]CONSUL=2)',"&") From GOBJSUB
        Endif

        Call ADDCRIT(CRITOBJ,ICRITOBJ,"CRITOBJ",'[F:HRLIC]ENAFLG=2',"&") From GOBJSUB

        NBCOL += 1 : COL(NBCOL) = "[F:HRLIC]GRP"    : COLTYP(NBCOL) =  type([F:HRLIC]GRP) : TIT(NBCOL) =mess(237,133,1)
        Default File [LNK]
      Endif
  Endcase
Return

##################################################
Subprog DEFHRLIC(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC

  If GFONCTION = "GESHRLIC" | COD<>"" : End : Endif

  If func AFNC.ACTIV("LEG")=0
   LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   LEG = GCURLEG
  Endif

  If clalev([F:HRLIC])=0  : Local File HRLICAUT [HRLIC]  : Endif

  # Find default code for legislation
  If LEG<>""
   Filter [F:HRLIC] Where [F:HRLIC]LEG=[L]LEG & DEFVAL=2
   Read [F:HRLIC]HRLIC0 First
   Filter [F:HRLIC]
   If !fstat
    COD=[F:HRLIC]COD
    End
   Endif
  Endif

  Filter [F:HRLIC] Where [F:HRLIC]LEG="" & DEFVAL=2
  Read [F:HRLIC]HRLIC0 First
  Filter [F:HRLIC]
  If !fstat
   COD=[F:HRLIC]COD
   End
  Endif
End

##################################################
# To do a generic Call CONTSEL... from
Subprog CONTSEL(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()
  Call CONTHRLIC(COD,LEG,SOC)
End

##################################################
Subprog CONTHRLIC(COD,LEG,SOC)
Value    Char    COD
Value    Char    LEG()
Value    Char    SOC()

  If GFONCTION = "GESHRLIC" | COD="" : End : Endif

  If clalev([F:HRLIC])=0 : Local File HRLICAUT [HRLIC] : Endif

  If func AFNC.ACTIV("LEG")=0
   LEG = GDOSLEG
  Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
   LEG = GCURLEG
  Endif

  If LEG<>""
   Read [HRLIC]HRLIC0=COD;LEG
   If fstat
    Read [HRLIC]HRLIC0=COD;""
    If !fstat
      LEG=""
    Else
      # Fiche inexistante pour la législation courante
      GMESSAGE = [L]COD-":"-mess(14,10712,1)-"["+[L]LEG+"]"
      mkstat = 2 : End
    Endif
   Endif
  Else
   Read [HRLIC]HRLIC0(1)=COD
   If !fstat
    LEG = [F:HRLIC]LEG
   Else
    # Fiche inexistante
    GMESSAGE = [L]COD-":"-mess(23,100,1)
    mkstat = 2 : End
   Endif
  Endif

  If LEG<>""
   Call CONTROLE("HRLIC","",LEG,COD,mkstat) From CONTOBJ
  Else
   Call CONTROLE("HRLIC","","",COD,mkstat) From CONTOBJ
  Endif

  If [F:HRLIC]GRP<>"" & SOC<>""
   If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
   Look [AGC]AGC0 = [F:HRLIC]GRP;SOC
   If fstat
    GMESSAGE = [L]COD-":"-mess(63,127,1)-":"-[F:HRLIC]GRP : # Réservé au groupe de société
    mkstat = 2 : End
   Endif
  Endif

  If GUSRACS<>2
   If [F:HRLIC]CODACS <> ""
    If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
    Read [F:ACC]CODACC = GUSER;[F:HRLIC]CODACS
    If fstat or [F:ACC]CONSUL <> 2
     GMESSAGE = [F:HRLIC]COD-":"-mess(3,104,1) :#Access denied
     mkstat = 2 : End
    Endif
   Endif
  Endif
End

##################################################
Subprog TUNHRLIC(COD,LEG,SOC)
Variable Char    COD()
Value    Char    LEG
Value    Char    SOC
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONHRLIC)
 TOKILL = 1
Endif

If clalev([F:HRLIC])=0 : Local File HRLICAUT [HRLIC] : Endif

# To update the HRLIC code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG=""              : # If LEG="" then firstly we search a HRCSP record with LEG="" secondly a HRCSP record with LEG<>""
 Read [F:HRLIC]HRLIC0 = VCOD;LEG
 If fstat
  Read [HRLIC]HRLIC0(1)=VCOD
  If !fstat
   LEG = [F:HRLIC]LEG
  Endif
 Endif
Endif

Read [HRLIC]HRLIC0 = VCOD;LEG
If fstat : LEG="" : Endif

Call OBJET("HRLIC",LEG,VCOD) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif

Filter [HRLIC]

End

##################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  GCURLEG = VALEUR
End


######################################################################################

