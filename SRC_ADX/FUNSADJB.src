###########################################################
# Construit le filtre en fonction des paramètres saisis dans [SADJ]
###########################################################
Subprog FILSMA(PFIL)
Variable Char PFIL()

Local Integer I

Raz PFIL

    If !clalev([M:SADJ])
        PFIL="1=1"
        End
    Endif

    If [M:SADJ]ITMREFEND<>""
        Call ADDCRIT(PFIL,I,"","[F:SMA]ITMREF>=[M:SADJ]ITMREFSTR & [F:SMA]ITMREF<=[M:SADJ]ITMREFEND","&") From GOBJSUB
    Endif
    If [M:SADJ]CPYEND<>""
        Call ADDCRIT(PFIL,I,"","[F:SMA]CPY>=[M:SADJ]CPYSTR & [F:SMA]CPY<=[M:SADJ]CPYEND","&") From GOBJSUB
    Endif
    If [M:SADJ]STOFCYEND<>""
        Call ADDCRIT(PFIL,I,"","[F:SMA]STOFCY>=[M:SADJ]STOFCYSTR & [F:SMA]STOFCY<=[M:SADJ]STOFCYEND","&") From GOBJSUB
    Endif
    If [M:SADJ]TCLCODEND<>""
        Call ADDCRIT(PFIL,I,"","[F:SMA]TCLCOD>=[M:SADJ]TCLCODSTR & [F:SMA]TCLCOD<=[M:SADJ]TCLCODEND","&") From GOBJSUB
    Endif
    If PFIL="" : PFIL="1=1" : Endif
End

###########################################################
# Teste si un enregistrement SMA peut être traité en fonction
# des bornes renseignées dans l'écran STOADJ [SADJ]
#
# Renvoie 0 si OK
# Renvoie 1 si pas de régul à faire
#
# Les tables [F:ITM] et [F:ITF] doivent être ouvertes
###########################################################
Funprog TSTEXEREG(PITM,PFCY,PNUMVLT)
Value Char PITM
Value Char PFCY
Value Integer PNUMVLT

Local Integer I, J, LRET
Local Decimal LQTY0, LQTY
Local Char    LTCM(GLONTCM), REQ(250)(40), REQ2(250)(40)

Local Integer TYP(20)
Local Date    LDATPER    # Date début 1ère période ouverte pour les stocks
Local Date    LDAT0
Local Integer LALLVCRNEG
LALLVCRNEG = 0  # Mettre 1 pour avoir la liste complète des documents qui passent le stock en négatif


# Prise en compte des bornes de sélection
If clalev([M:SADJ])
    If [F:ITM]ITMREF<>PITM
        Read [ITM]ITM0=PITM
    Endif
    If dim([M:SADJ]TSICODSTR) > 0
      For I = 0 To dim([M:SADJ]TSICODSTR)-1
        If [M:SADJ]TSICODEND(I)<>"" & ([F:ITM]TSICOD(I)<[M:SADJ]TSICODSTR(I) | [F:ITM]TSICOD(I)>[M:SADJ]TSICODEND(I))
            End 1
        Endif
      Next I
    Endif

    If [F:ITF]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
        Read [ITF]ITF0=PITM;PFCY
    Endif

    If [M:SADJ]BUYEND<>"" & ([F:ITF]BUY<[M:SADJ]BUYSTR | [F:ITF]BUY>[M:SADJ]BUYEND)
        End 2
    Endif

    If [M:SADJ]VLTEND<>""
        Call GETTCM(PITM,PFCY,LTCM,LRET) From STKVAL
        If (LTCM<[M:SADJ]VLTSTR | LTCM>[M:SADJ]VLTEND)
            End 3
        Endif
    Endif
Endif

If [F:SMA]QTY=0 & [F:SMA]AMT=0
    Readlock [SMA] Curr
    Delete [SMA] Curr
    End 4
Endif

#--- On ne fait la régul de sortie que dans le cas de la valo au PMP ou FIFO ou LIFO ---#
Call GETTCM(PITM,PFCY,LTCM,LRET) From STKVAL
If !(find([F:TCM]ISSVLTCOD(PNUMVLT),4,5,6,8) & [F:TCM]PRIREGS=2)    # Vérif que la méthode de valo est régularisable
    End 5
Endif

# Les méthodes PMP e PM Lot ne peuvent être régularisées si 2ème méthode
# car le calcul de PM à date se base sur la valeur d'ordre
If PNUMVLT=1 & find([F:TCM]ISSVLTCOD(PNUMVLT),4,6)
    End 5
Endif

# Recherche de la 1ère date sur période comptable ouverte
Read [FCY]FCY0=PFCY
If fstat : ERR=1 : Endif
Filter [PER] Where CPY=[F:FCY]LEGCPY & PERSTOSTA<4
Read [PER]PER0 First
Filter [PER]

LDATPER = [F:PER]PERSTR

Filter [STJ] Where STOFCY = PFCY
&                & ITMREF = PITM
&                & VCRTYP = [F:SMA]VCRTYP
&                & VCRNUM = [F:SMA]VCRNUM
&                & VCRLIN = [F:SMA]VCRLIN
&                & UPDCOD = 2
Read [STJ]STJ0 Last  # On récupère la plus ancienne date, celle qui correspond à la date du document
Filter [STJ]

If LDATPER=[0/0/0] | [F:STJ]IPTDAT<LDATPER
    #MJH X3-105102 Retain and log issue price adjustments that cannot be posted due to closed period
    Call ECRTRACE(mess(1205,196,1),1)
    Call ECRTRACE(mess(29,105,1) + ":" - [F:SMA]STOFCY + " ; " +
&                 mess(133,187,1)+ ":" - [F:SMA]ITMREF +" ; " +
&                 mess(22,107,1) + ":" - mess([F:SMA]VCRTYPREG,701,1) + " ; " +
&                 mess(02,176,1) + ":" - [F:SMA]VCRNUMREG - num$([F:SMA]VCRLINREG) + " ; " +
&                 mess(03,011,1) + ":" - num$([F:STJ]IPTDAT) + " ; " +
&                 mess(50,104,1) + ":" - num$([F:SMA]AMT)
&                 ,1)

#    Readlock [SMA] Curr
#    Delete [SMA] Curr
    End 7
Else
    Call ECRTRACE("Period ok : PFCY="-PFCY-"LDATPER="-num$(LDATPER)-PITM-num$([F:STJ]IPTDAT),0)
Endif

# Issue 91384 - 2013-08-02 by CCC : Le test du stock négatif n'est utile que pour la régul au PMP
If [F:TCM]ISSVLTCOD(PNUMVLT)=4
    # Teste que le stock ne passe pas en négatif avec les documents qui suivent
    # On calcule d'abord la quantité totale après le doc d'origine
    Raz I: REQ(I) = "SELECT S1.STOFCY_0, SUM(S1.ACTQTY_0) "
    I+=1 : REQ(I) = "FROM STOJOU S1, "
    # Issue 71160 - 2011-01-31 by CCC : Une même ligne de doc peut avoir des mouvemetns avec CREMVTSEQ différents (inventaires, changements stocks)
    #I+=1 : REQ(I) =     "(SELECT STOFCY_0 F, ITMREF_0 I, MIN(IPTDAT_0) IPT, CREMVTDAT_0 CD, CREMVTTIM_0 CT, CREMVTSEQ_0 CS "
    I+=1 : REQ(I) =     "(SELECT STOFCY_0 F, ITMREF_0 I, MIN(IPTDAT_0) IPT, CREMVTDAT_0 CD, CREMVTTIM_0 CT, min(CREMVTSEQ_0) CS "
    I+=1 : REQ(I) =      "FROM STOJOU "
    I+=1 : REQ(I) =      "WHERE VCRTYP_0 ="+num$([F:SMA]VCRTYP)
    I+=1 : REQ(I) =      "  AND VCRNUM_0 = '"+[F:SMA]VCRNUM+"' "
    I+=1 : REQ(I) =      "  AND VCRLIN_0 ="+num$([F:SMA]VCRLIN)
    I+=1 : REQ(I) =      "  AND STOFCY_0 = '"+PFCY+"' AND ITMREF_0 = '"+PITM+"' "
    I+=1 : REQ(I) =      "  AND UPDCOD_0 = 2 "
    #I+=1 : REQ(I) =      "GROUP BY STOFCY_0, ITMREF_0, CREMVTDAT_0, CREMVTTIM_0, CREMVTSEQ_0 "
    I+=1 : REQ(I) =      "GROUP BY STOFCY_0, ITMREF_0, CREMVTDAT_0, CREMVTTIM_0 "
    I+=1 : REQ(I) =      ") DOC0 "
    I+=1 : REQ(I) = "WHERE S1.ITMREF_0=DOC0.I "
    I+=1 : REQ(I) = "  AND S1.UPDCOD_0=2 "
    I+=1 : REQ(I) = "  AND (  S1.IPTDAT_0>DOC0.IPT "
    I+=1 : REQ(I) = "      OR S1.IPTDAT_0=DOC0.IPT AND (S1.CREMVTDAT_0>DOC0.CD "
    I+=1 : REQ(I) =                               " OR S1.CREMVTDAT_0=CD AND (S1.CREMVTTIM_0>DOC0.CT "
    I+=1 : REQ(I) =                                                     " OR S1.CREMVTTIM_0=DOC0.CT AND S1.CREMVTSEQ_0>DOC0.CS "
    I+=1 : REQ(I) =                                                        " ) "
    I+=1 : REQ(I) =                                  " ) "
    I+=1 : REQ(I) =      " ) "
    I+=1 : REQ(I) = "GROUP BY S1.STOFCY_0"
    Raz GMESSAGE
    REQ2(0) = "SELECT SUM(ACTQTY_0) ACTQTY, IPTDAT_0, VCRTYP_0, VCRNUM_0, VCRLIN_0 "
    For J=1 To I-1
        REQ2(J) = REQ(J)
    Next
    #REQ2(I) = "  AND S1.STOFCY_0='"+[F:SQL1]STOFCY+"' "   #--> alimenté dans la boucle => attention utilisation de la variable I

    # Issue 99880 - 2014-05-22 by CCC : test that even with internal change, stock can't be negative
    ## Issue 71160 - 2011-01-31 by CCC : Une même ligne de doc peut avoir des mouvements avec CREMVTSEQ différents (inventaires, changements stocks)
    REQ2(I+1) = "GROUP BY S1.STOFCY_0, S1.ITMREF_0, S1.VCRTYP_0, S1.VCRNUM_0, S1.VCRLIN_0, S1.IPTDAT_0, S1.CREMVTDAT_0, S1.CREMVTTIM_0, S1.CREMVTSEQ_0 "
    REQ2(I+2) = "ORDER BY S1.IPTDAT_0, S1.CREMVTDAT_0, S1.CREMVTTIM_0, S1.CREMVTSEQ_0, S1.VCRTYP_0, S1.VCRNUM_0, S1.VCRLIN_0 "
    #REQ2(I+1) = "GROUP BY S1.STOFCY_0, S1.ITMREF_0, S1.VCRTYP_0, S1.VCRNUM_0, S1.VCRLIN_0, S1.IPTDAT_0, S1.CREMVTDAT_0, S1.CREMVTTIM_0 "
    #REQ2(I+2) = "ORDER BY S1.IPTDAT_0, S1.CREMVTDAT_0, S1.CREMVTTIM_0, S1.VCRTYP_0, S1.VCRNUM_0, S1.VCRLIN_0 "

    Anasql From num$(GTYPDBA*2+1) Sql REQ Using TYP    # Vérification de la requête
    For (Char STOFCY, Decimal QTY0) From num$(GTYPDBA*2+1) Sql REQ As [SQL1]
        # Si on ne souhaite pas faire de contrôle sur un site particulier,
        # il faut l'indiquer dans la variable globale GADJFCYEXC
        If dim(GADJFCYEXC)<=0 | !find([F:SQL1]STOFCY,GADJFCYEXC)
            LQTY0=[F:SQL1]QTY0
            If [F:ITV]ITMREF<>PITM | [F:ITV]STOFCY<>[F:SQL1]STOFCY
                Read [ITV]ITV0=PITM;[F:SQL1]STOFCY
            Endif
            If [F:ITV]AVCBASQTY-LQTY0<0

                Filter [STJ] Where STOFCY = PFCY & ITMREF = PITM
&                                & VCRTYP =[F:SMA]VCRTYP
&                                & VCRNUM =[F:SMA]VCRNUM
&                                & VCRLIN =[F:SMA]VCRLIN
&                                & UPDCOD = 2
&                            Order By IPTDAT
                Read [STJ] First
                Filter [STJ]
                LDAT0=[F:STJ]IPTDAT
                GMESSAGE="TSTEXEREG"-num$(LDAT0)-mess([F:SMA]VCRTYP,701,1)-[F:SMA]VCRNUM-num$([F:SMA]VCRLIN)-":"-mess(28,196,1)
                If LALLVCRNEG
                    Call ECRTRACE(GMESSAGE-":"-num$(LQTY0)-"/"-num$([F:ITV]AVCBASQTY),0)
                Else
                    Break
                Endif
            Else
                # Pour chaque document suivant le doc d'origine, on vérifie qu'on ne passe pas en négatif
                LQTY=[F:ITV]AVCBASQTY-LQTY0
                REQ2(I) = "  AND S1.STOFCY_0='"+[F:SQL1]STOFCY+"' "
                For (Decimal ACTQTY, Date IPTDAT, Integer VCRTYP, Char VCRNUM, Integer VCRLIN) From num$(GTYPDBA*2+1) Sql REQ2 As [SQL2]
                    LQTY+=[F:SQL2]ACTQTY
                    If LQTY<0
                        GMESSAGE=[F:SQL1]STOFCY-num$([F:SQL2]IPTDAT)-mess([F:SQL2]VCRTYP,701,1)-[F:SQL2]VCRNUM-num$([F:SQL2]VCRLIN)-":"-mess(28,196,1)-":"-num$(LQTY)
                        If LALLVCRNEG
                            Call ECRTRACE(GMESSAGE,0)
                        Else
                            Break 2
                        Endif
                    Endif
                Next
            Endif
        Endif
    Next
    If GMESSAGE<>""
        If LALLVCRNEG<>0
            GMESSAGE = mess(7,21,1)-":"-mess(28,196,1)
        Endif
        End 6
    Endif
Endif

End 0

####################################################################
# Renvoie le PMP avant/après mouvement
####################################################################
# Paramètres E : PITM = Article
#                PFCY = Site
#                PIPT = Date d'imputation
#                PDAT = Date création ligne de pièce
#                PTIM = Heure création ligne de pièce
#                PSEQ = N° de séquence création ligne de pièce
#                PNUMVLT = 0:1ère méthode de valo
#                          1:2ème méthode de valo
#                PSUP = B : inclus les mouvements de la même date, même heure
####################################################################
Subprog GETAVC(PITM,PFCY,PIPT,PDAT,PTIM,PSEQ,PNUMVLT,PSUP,PQTYACT,PAMT)
Value    Char    PITM
Value    Char    PFCY
Value    Date    PIPT
Value    Date    PDAT
Value    Char    PTIM
Value    Integer PSEQ
Value    Integer PNUMVLT
Value    Char    PSUP
Variable Decimal PQTYACT
Variable Decimal PAMT()

Local Integer LMINREG, LMINAGG, I
Local Decimal LAMTDEL(dim(PAMT))
Local Char REQ(250)

If !clalev([M:SDPA]) : Local Mask SAIDECPRI [SDPA] : Endif   # Masque qui contient le détail du montant PMP (calculé dans GETAVC)

If !clalev([F:ITV]) : Local File ITMMVT : Endif

If [F:ITV]ITMREF<>PITM | [F:ITV]STOFCY<>PFCY
    Read [ITV]ITV0=PITM;PFCY
Endif

PQTYACT = [F:ITV]AVCBASQTY
PAMT    = [F:ITV]AVCBASAMT
If GACTDECCST
    Call LOADVAR(PAMT,"[F:ITV]", 0, "A", 1, 0, 0) From STKVALECR
Endif
Call ECRTRACE(num$(PAMT(0)),0)

If instr(1,PSUP,"B")
    Filter [STJ] Where STOFCY  = PFCY
&                    & UPDCOD  = 2
&                    & ITMREF  = PITM
&                    & ( IPTDAT  > PIPT
&                      | (IPTDAT  = PIPT
&                        & ( CREMVTDAT > PDAT
&                          | (CREMVTDAT = PDAT
&                            & ( CREMVTTIM > PTIM
&                              | CREMVTTIM = PTIM & CREMVTSEQ>=PSEQ))
&                          )
&                        )
&                      )
Else
    Filter [STJ] Where STOFCY  = PFCY
&                    & UPDCOD  = 2
&                    & ITMREF  = PITM
&                    & ( IPTDAT  > PIPT
&                      | (IPTDAT  = PIPT
&                        & ( CREMVTDAT > PDAT
&                          | (CREMVTDAT = PDAT
&                            & ( CREMVTTIM > PTIM
&                              | CREMVTTIM = PTIM & CREMVTSEQ>PSEQ))
&                          )
&                        )
&                      )
Endif

For [STJ]STJ1(4)
    LMINREG = 2
    Raz LAMTDEL
    # La recherche de minreg doit se faire hors filtre sur IPTDAT
    # car une ligne de document peut avoir plusieurs dates d'imputation à cause des régul sur période fermée
    REQ="SELECT MIN(REGFLG_0) FROM STOJOU"
&      + " WHERE STOFCY_0='"+PFCY+"'"
&      + " AND ITMREF_0='"+PITM+"'"
&      + " AND VCRTYP_0="+num$([F:STJ]VCRTYP)
&      + " AND VCRNUM_0='"+[F:STJ]VCRNUM+"'"
&      + " AND VCRLIN_0="+num$([F:STJ]VCRLIN)
    For (Integer MINREG) From num$(GTYPDBA*2+1) Sql REQ As [STJX]
        LMINREG=[F:STJX]MINREG
    Next
    For [STJ]STJ1
        # Issue 88107 - 2013-02-20 by CCC
        If GACTDECCST
            Raz [F:SJV]
        Endif
        If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
            Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
        Endif
        # L'écart non absorbé (comme son nom l'indique) n'a pas été absorbé par AVCBASAMT
        # on n'en tient donc pas compte lors de la remontée des mouvements pour trouver le pmp à date
        # Par contre, les écarts non absorbés sur les sorties ou entrées négatives doivent être pris en compte
        If find([F:STJ]TRSTYP,11,2,4,6,24,27)
            Case PNUMVLT
                When 0 :
                    If [F:STJ]AMTDEV<>0
&                    | GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
&                    & ( sigma(0,GACTMAT-1,abs([F:SJV]DEVMATCST(indcum)))>0
&                      | sigma(0,GACTMAC-1,abs([F:SJV]DEVMACCST(indcum)))>0
&                      | sigma(0,GACTLAB-1,abs([F:SJV]DEVLABCST(indcum)))>0
&                      | [F:SJV]DEVSCOCST<>0
&                      | [F:SJV]DEVINVDTA<>0
&                      | [F:SJV]DEVOVEMAT<>0
&                      | [F:SJV]DEVOVEMAC<>0
&                      | [F:SJV]DEVOVELAB<>0
&                      | [F:SJV]DEVOVESCO<>0
&                      )
                        PAMT    += [F:STJ]AMTDEV
                        If GACTDECCST
                            Call LOADVAR(PAMT,"[F:SJV]", PNUMVLT, "DEV", 1, 1, 0) From STKVALECR
                        Endif
                    Endif
                When 1:
                    If [F:STJ]AMTDEV2<>0
&                    | GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
&                    & ( sigma(0,GACTMAT-1,abs([F:SJV]DEVMATCST2(indcum)))>0
&                      | sigma(0,GACTMAC-1,abs([F:SJV]DEVMACCST2(indcum)))>0
&                      | sigma(0,GACTLAB-1,abs([F:SJV]DEVLABCST2(indcum)))>0
&                      | [F:SJV]DEVSCOCST2<>0
&                      | [F:SJV]DEVINVDTA2<>0
&                      | [F:SJV]DEVOVEMAT2<>0
&                      | [F:SJV]DEVOVEMAC2<>0
&                      | [F:SJV]DEVOVELAB2<>0
&                      | [F:SJV]DEVOVESCO2<>0
&                      )
                        PAMT    += [F:STJ]AMTDEV2
                        If GACTDECCST
                            Call LOADVAR(PAMT,"[F:SJV]", PNUMVLT, "DEV", 1, 1, 0) From STKVALECR
                        Endif
                    Endif
            Endcase
        Endif
        If [F:STJ]REGFLG=1 | [F:STJ]TRSTYP=35
            # De plus, le pmp est calculé avec le montant d'ordre, pas le montant de valo => utilisation d'AMTORD
            If PNUMVLT=1 & [F:STJ]PRINAT2=5
                PAMT    -= [F:STJ]AMTVAL2
            Else
                PAMT    -= [F:STJ]AMTORD
            Endif
            If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
                Call LOADVAR(PAMT,"[F:SJV]", 0, "O", -1, 1, 0) From STKVALECR
            Endif
            PQTYACT -= [F:STJ]ACTQTY
        Else
            LAMTDEL -= [F:STJ]VARORD
            If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
                Call LOADVAR(LAMTDEL,"[F:SJV]", 0, "DO", -1, 1, 0) From STKVALECR
            Endif
        Endif
        Call ECRTRACE(num$([F:STJ]REGFLG)+";"+num$([F:STJ]IPTDAT)+";"+num$([F:STJ]MVTSEQ)+";"+num$([F:STJ]ACTQTY)+";"+num$([F:STJ]VARORD)+";"+num$(PAMT(0))+";"+num$(LAMTDEL),0)
    Next
    If LMINREG=2   # Document supprimé (mais pas comptabilisé) => normalement mnt=0 mais peut être <>0 si au moment de la suppression le stock passait à 0
        For I=0 To dim(PAMT)-1
            PAMT(I) += LAMTDEL(I)
        Next
    Endif
    Call ECRTRACE([F:STJ]VCRNUM+";"+num$([F:STJ]VCRLIN)+";"+num$(PQTYACT)+";"+num$(PAMT(0)),0)
Next
Filter [STJ]

End

###########################################################
# En mode simulation permet de limiter les enreg SMA à prendre en compte
$FLT_SIMU
#    LFIL1+="&ITMREF='XXXXX'&STOFCY='XXX'"
    # FQ 63359 GA 03/2010    # Simulation: les [F:SMA] ne sont pas supprimés, il faut les éviter !
    If DSMANUM>0
#       LFIL1+= "& [SMA]NUM>DSMANUM"
    Endif
Return

###########################################################
Subprog STKADJ
If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif
If dim(GDIMCST)<=0 : Global Integer GDIMCST : Endif
GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
Local Integer LNBFCY
Local Decimal LDELTA(1+GDIMCST*GACTDECCST), LAMTDEV(1+GDIMCST*GACTDECCST)    # valeur utilisée lors de la création des nouveaux mouvements
Local Integer I, LRET, LNB
Local Char    LCRIT1(250),LCRIT2(250)
Local Char    LTCM(GLONTCM), LITM(GLONITM), LFCY(GLONFCY), LTIM(GLONHS)
Local Date    LIPT, LDAT
Local Integer LCRESEQ, LSEQ, LMVTIND
Local Integer LSMANUM, LSMALLC, LSMASEQ, LSEQ
Local Date    LSMAIPT, LSMADAT
Local Char    LSMAITM(GLONITM), LSMATIM(GLONHS)
Local Char    LSMALOT(GLONLOT), LSMASLO(GLONSLO)
Local Char    LLOT(GLONLOT), LSLO(GLONSLO)

Local Integer LVLTCOD
Local Integer LSTOP, LTEST, LREPEAT, LSJAOK, LSENS
Local Decimal LAMTRND, LPRIRND
Local Integer WARRONDI
Local Decimal LTMPAMT,LTMPQTY,LTMPAVC
Local Decimal LQTYLIN, LQTYLINACT, LAMTLIN(1+GDIMCST*GACTDECCST), LDEVLIN(1+GDIMCST*GACTDECCST), LDEVREG
Local Decimal LRCPQTY,LRCPQTYACT, LRCPAMT(1+GDIMCST*GACTDECCST), LRCPPRI(1+GDIMCST*GACTDECCST)    # Quantité et montant de l'entrée pour régul FIFO
Local Decimal LCUMAMT(1+GDIMCST*GACTDECCST), LSUMVARRCP, LSUMVARISS, LSUMVARDEV
Local Decimal LRCPDEV(1+GDIMCST*GACTDECCST)
Local Char    LMES(250), LTXT(250)
Local Integer LNBMVT
Local Integer LINDFCY, LMINSEQ    # Servent de butée dans le déroulement de [STJ2] Les nouveaux mvts auront MVTSEQ<LSEQFCY
Local Integer LOUVTRA
Local Char    LFIL1(250),LFIL2(250)(2)
Local Integer LNUMVLT
Local Decimal LCNVRPT

Local Char    LVCRNUM(GLONVCR),LVCRNUMREG(GLONVCR)
Local Integer LVCRTYP, LVCRTYPREG, LVCRLIN, LVCRLINREG
Local Char    LSTOFCY(GLONFCY)

Local Char    LSAVNUM(GLONVCR)    # Sauvegarde du n° de doc venant d'être régularisé => tous les mouvements suivants qui ont ce n° sont évités
Local Char    LSAVFCY(GLONFCY)
Local Integer LSAVTYP, LSAVLIN, LSAVSEQ

Local Char    LSMAITM(GLONITM),DSMAITM(GLONITM)  # FQ 63359 GA 03/2010
Local Integer DSMANUM, DSMALLC, DSMASEQ, DCPT    # FQ 63359 GA 03/2010

Local Integer LADJSIMU : LADJSIMU=0
Local Integer LSAVSTOTRACE : LSAVSTOTRACE =  GSTOTRACE
Local Integer LRETAIN_SMA : LRETAIN_SMA = 0

# FQ 63359 GA 03/2010
Raz DSMAITM,DSMANUM, DSMALLC, DSMASEQ, DCPT
If dim([M:SADJ]SIMFLG)>0 & [M:SADJ]SIMFLG=2
    LADJSIMU = 1
Endif

Global Integer GISSADJ : GISSADJ=1

If GSTOTRACE>1 | LADJSIMU    # FQ 63359 GA 03/2010 trace si on est mode Simulation
    Call TEXTE( 6040, LMES) From OBJDIV
    If LADJSIMU
        Call TEXTE( 4973, GBIDC1) From OBJDIV
        LMES -= "("+GBIDC1+")"
    Endif
    If !GSERVEUR & GTRACE=""
        LOUVTRA = 1
        Call OUVRE_TRACE(LMES) From LECFIC
        Call ECR_TRACE(LMES,0) From GESECRAN
    Else
        Call ECR_TRACE(LMES,-1) From GESECRAN
    Endif
Endif

Trbegin [SMA]
For [SMA]SMA1 Where LLC=0
    Raz LLC, LDAT
    For [ITB] Where ITMREF=[F:SMA]ITMREF
        LLC=max(LLC,[F:ITB]LLC)
    Next
    [F:SMA]LLC = LLC
    Rewrite [SMA]
Next
Commit

Raz [F:SMA]

Call FILSMA(LFIL2)

Link [SMA] With [STJ]STJ1~=[F:SMA]STOFCY;[F:SMA]VCRTYP;[F:SMA]VCRNUM;[F:SMA]VCRLIN
&            As [LNK]
&          Where [F:STJ]ITMREF=[F:SMA]ITMREF
&          Order By [SMA]LLC Desc;[F:SMA]ITMREF;[F:STJ]IPTDAT;[F:STJ]CREMVTDAT;[F:STJ]CREMVTTIM;[F:STJ]CREMVTSEQ;[SMA]NUM

$BEGIN_SMA
Raz LNB, LREPEAT
#---- Boucle sur les régul en attente -----#

# FQ 63359 GA 03/2010: nbrecord([SMA])-DCPT pour tenir compte des suppressions en mode Simulation
Call ECRTRACE(format$("D:"+GFMDAT4,date$)-time$-":"-"Remaining SMA records :"+num$(nbrecord([SMA])-DCPT),0)

If LSTOP>=0
    LNUMVLT=0
Endif

# Positionnement du filtre
If LSTOP<0
    LFIL1 = "[SMA]NUM=LSMANUM"
Elsif LSTOP=1
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT=LSMADAT&[F:STJ]CREMVTTIM=LSMATIM&[F:STJ]CREMVTSEQ=LSMASEQ&[F:STJ]LOT=LSMALOT&[F:STJ]SLO=LSMASLO&NUM>LSMANUM"
    LSTOP+= 1
Elsif LSTOP=2
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT=LSMADAT&[F:STJ]CREMVTTIM=LSMATIM&[F:STJ]CREMVTSEQ=LSMASEQ&[F:STJ]LOT=LSMALOT&[F:STJ]SLO>LSMASLO"
    LSTOP+= 1
Elsif LSTOP=3
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT=LSMADAT&[F:STJ]CREMVTTIM=LSMATIM&[F:STJ]CREMVTSEQ=LSMASEQ&[F:STJ]LOT>LSMALOT"
    LSTOP+= 1
Elsif LSTOP=4
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT=LSMADAT&[F:STJ]CREMVTTIM=LSMATIM&[F:STJ]CREMVTSEQ>LSMASEQ"
    LSTOP+= 1
Elsif LSTOP=5
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT=LSMADAT&[F:STJ]CREMVTTIM>LSMATIM"
    LSTOP+= 1
Elsif LSTOP=6
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT=LSMAIPT&[F:STJ]CREMVTDAT>LSMADAT"
    LSTOP+= 1
Elsif LSTOP=7
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF=LSMAITM&[F:STJ]IPTDAT>LSMAIPT"
    LSTOP+= 1
Elsif LSTOP=8
    LFIL1 = "[SMA]LLC=LSMALLC&[SMA]ITMREF>LSMAITM"
    LSTOP+= 1
Elsif LSTOP=9
    LFIL1 = "[SMA]LLC<LSMALLC"
    LSTOP = 0
Else
    LFIL1 = "1=1"
Endif

If LADJSIMU
    Gosub FLT_SIMU
Endif

Call DEBTRANS From GLOCK
If adxlog=0    # C'est possible qu'une transaction soit déjà ouverte si l'enregistrement [SMA] précédent n'a pas été traité
    Trbegin [SMA]
Endif

For [F:LNK] Where evalue(LFIL1) & evalue (LFIL2)
    Call ECRTRACE(time$-"LSTOP="+num$(LSTOP)-num$([F:SMA]LLC)-num$([F:STJ]IPTDAT)-num$([F:STJ]CREMVTDAT)-num$([F:STJ]CREMVTTIM)-num$([F:STJ]CREMVTSEQ)-num$([F:STJ]MVTSEQ)-num$([F:SMA]NUM),0)
    LSMANUM=[F:SMA]NUM
    LSMALLC=[F:SMA]LLC
    LSMAITM=[F:SMA]ITMREF
    LSMALOT=[F:SMA]LOT
    LSMASLO=[F:SMA]SLO
    LSMAIPT=[F:STJ]IPTDAT
    LSMADAT=[F:STJ]CREMVTDAT
    LSMATIM=[F:STJ]CREMVTTIM
    LSMASEQ=[F:STJ]CREMVTSEQ

    Read [SMA]SMA1=LSMALLC;LSMANUM

    If LNUMVLT>1
        LNUMVLT=0
    Endif

    While LNUMVLT<2
        Gosub TRT_SMA
        If !GOK | LSTOP<0
            Break 2
        Endif
        If LSTOP=100  # Le SMA ne peut pas être traité mais il faut le conserver --> on passe à l'article suivant
            LNUMVLT=GACTVLT2<>0
            Break
        Endif
        LNUMVLT+=1
    Wend

    If GOK       # FQ 63359 GA 03/2010
       If !LADJSIMU
          If LSTOP<>100
             Call ECRTRACE("Before Delete [F:SMA]"-num$([F:SMA]NUM)-[F:SMA]ITMREF-[F:SMA]STOFCY-[F:SMA]VCRNUM-num$([F:SMA]VCRLIN),0)
             If LRETAIN_SMA = 0 #MJH X3-105102 Retain adjustments that can't be posted due to closed period
               Delete [SMA]SMA1=LSMALLC;LSMANUM #MJH X3-105102 original
             Endif
             Raz LRETAIN_SMA
             LSTOP=1
          Else
             LSTOP=8
          Endif
       Else
       # FQ 63359 GA 03/2010
       # Dans le cas de la simu on sauvegarde le dernier [F:SMA]NUM pour l'éviter au prochain For ...
            Call ECRTRACE("End simulating [F:SMA]"-num$([F:SMA]NUM)-[F:SMA]ITMREF-[F:SMA]STOFCY-[F:SMA]VCRNUM-num$([F:SMA]VCRLIN),0)
            DSMAITM=[F:SMA]ITMREF
            DSMANUM=[F:SMA]NUM
            DSMALLC=[F:SMA]LLC
            DSMASEQ=[F:STJ]CREMVTSEQ
            DCPT+=1
            If LSTOP<>100
               LSTOP=1
            Else
               LSTOP=8
            Endif
       Endif
    Endif

    Break
Next

Filter [SMA]

If GOK
    If !LADJSIMU
        Call ECRTRACE([F:SMA]ITMREF-[F:SMA]STOFCY-[F:SMA]VCRNUM-num$([F:SMA]VCRLIN)-"Commit",0)
        Commit
    #Else
    #    Rollback # pas de Rollback intermédiaire sinon résultats faux au niveau supérieur
    Endif
Else
    Call ECRTRACE([F:SMA]ITMREF-[F:SMA]STOFCY-[F:SMA]VCRNUM-num$([F:SMA]VCRLIN)-"GOK="-num$(GOK),1)
    Rollback
Endif

# Si on n'a fait qu'un tour ou qu'on va changer de LLC, on calcule les PRF qui sont à calculer
If find(LSTOP,0,9) & !LREPEAT
    For [SRW]reckey Where find(VCRTYP,10,36)<>0
        Call ECRTRACE("Compute of "-[F:SRW]VCRNUM-num$([F:SRW]VCRLIN)-mess([F:SRW]VCRTYP,701,1)-num$([F:SRW]CREMVTSEQ)-[F:SRW]CPY,0)
        LSAVNUM = [F:SRW]VCRNUM
        LSAVLIN = [F:SRW]VCRLIN
        LSAVTYP = [F:SRW]VCRTYP
        If !LADJSIMU
            GOK=1
            Call CALMFC([F:SRW]STOFCY,[F:SRW]VCRTYP,[F:SRW]VCRNUM,[F:SRW]VCRLIN)
            If GMESSAGE<>""
                Call ECRTRACE(GMESSAGE,1)
                Raz GMESSAGE
            Endif
            If GOK
                Trbegin [SRW]
                Delete [SRW] Where VCRNUM=LSAVNUM
&                                & VCRLIN=LSAVLIN
&                                & VCRTYP=LSAVTYP
                Commit
                LREPEAT=1
            Endif
        Else
            Call ECRTRACE("Simulation => not compute",0)
            Delete [SRW] Where VCRNUM=LSAVNUM
&                            & VCRLIN=LSAVLIN
&                            & VCRTYP=LSAVTYP
        Endif
    Next
    [G:SRW]currind=1
    [G:SRW]currlen=0
    If !LADJSIMU     # FQ 63359 GA 03/2010
        # Mise à jour des LLC (au cas où)
        Trbegin [SMA]
        For [SMA]SMA1 Where LLC=0
            For [ITB] Where ITMREF=[F:SMA]ITMREF
                [F:SMA]LLC=max([F:SMA]LLC,[F:ITB]LLC)
            Next
            Rewrite [SMA]
        Next
        Commit
    Endif
Endif

If LSTOP<>0 | LREPEAT
    Raz [F:STJ1]
    Goto BEGIN_SMA
Endif

Raz  GISSADJ
Kill GISSADJ

If LADJSIMU & adxlog=1
    Rollback
Endif
GSTOTRACE = LSAVSTOTRACE

If LOUVTRA
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

End

###############################################################################
# TRT_SMA est appelé pour chaque SMA et pour chaque n° de méthode de valo
###############################################################################
# Met à jour l'écart non absorbé de l'entrée à l'origine de la régularisation
#
###############################################################################
$TRT_SMA
    Call ECRTRACE("---------------------------------------------------------------------------------",0)
    If GACTVLT2
        Call ECRTRACE("LNUMVLT"-num$(LNUMVLT),0)
    Endif

    If LSTOP >= 0
        Call ECRTRACE("---------------------------------------------------------------------------------",0)
        Call ECRTRACE("ARTICLE : "+num$([F:SMA]ITMREF),0)
        Call ECRTRACE("---------------------------------------------------------------------------------",0)
        Call ECRTRACE("[F:SMA]VCRTYP : "+num$([F:SMA]VCRTYP)-mess([F:SMA]VCRTYP,701,1),0)
        Call ECRTRACE("[F:SMA]VCRNUM : "+[F:SMA]VCRNUM,0)
        Call ECRTRACE("[F:SMA]VCRLIN : "+num$([F:SMA]VCRLIN),0)
        Call ECRTRACE("[F:SMA]LOT : "+num$([F:SMA]LOT),0)
        Call ECRTRACE("[F:SMA]SLO : "+num$([F:SMA]SLO),0)
        Call ECRTRACE("[F:SMA]LLC    : "-num$([F:SMA]LLC)-"[F:SMA]NUM"-num$([F:SMA]NUM),0)

        LVCRNUM = [F:SMA]VCRNUM
        LVCRLIN = [F:SMA]VCRLIN
        LVCRTYP = [F:SMA]VCRTYP
        LSTOFCY = [F:SMA]STOFCY
        LVCRNUMREG = [F:SMA]VCRNUMREG
        LVCRLINREG = [F:SMA]VCRLINREG
        LVCRTYPREG = [F:SMA]VCRTYPREG

        Delete [SRW] Where !find(VCRTYP,10,36)
        LNB+=adxdlrec

        Gosub DIM_VAR
        Raz LCUMAMT, LSUMVARRCP, LSUMVARISS, LSUMVARDEV
        Raz LTABFCY, LTABAMT, LTABQTYACT, LAMTDEV, LDELTA, LSUMVARDEV, LSUMVARRCP, LSUMVARISS
        LTABFCY(0) = [F:SMA]STOFCY
        LINDFCY=0
    Else
        Call ECRTRACE("[F:SMA]VCRTYP"-num$([F:SMA]VCRTYP),0)
        Call ECRTRACE("[F:SMA]VCRNUM"-[F:SMA]VCRNUM,0)
        Call ECRTRACE("[F:SMA]VCRLIN"-num$([F:SMA]VCRLIN),0)
        Call ECRTRACE("[F:SMA]LOT : "+num$([F:SMA]LOT),0)
        Call ECRTRACE("[F:SMA]SLO : "+num$([F:SMA]SLO),0)
        Call ECRTRACE("[F:SMA]LLC    : "-num$([F:SMA]LLC)-"[F:SMA]NUM"-num$([F:SMA]NUM),0)
    Endif

    Call ECRTRACE("LSTOP="+num$(LSTOP),0)
    If LSTOP>=0
        LTEST = func TSTEXEREG([F:SMA]ITMREF,[F:SMA]STOFCY,LNUMVLT)
        Case LTEST
            When 6 : Call ECRTRACE([F:SMA]ITMREF-[F:SMA]STOFCY-GMESSAGE,1)
                     Raz GMESSAGE
                     LSTOP = 100
                     Return
            When 7 : LRETAIN_SMA = 1 #MJH X3-105102 Retain adjustments that can't be posted due to closed period
                     Call ECRTRACE("TSTEXEREG output --> "+num$(LTEST),0)
            When Default : Call ECRTRACE("TSTEXEREG output --> "+num$(LTEST),0)
        Endcase
        Raz GMESSAGE
    Endif
    If LSTOP<0 | (!LTEST)
        Readlock [ITV]ITV0=[F:SMA]ITMREF;[F:SMA]STOFCY
        If fstat
            Call FSTA("ITV") From FUNSADJB
            GOK = 0
            Return
        Endif
        # Récupération méthode de valo
        # A faire à chaque fois car la méthode peut être dépositionnée
        Call GETTCM([F:SMA]ITMREF, [F:SMA]STOFCY, LTCM, LRET) From STKVAL
        If LRET
            #Call ECRTRACE("GETTCM : "+mess(7,21,1)-num$(LRET))
            Call ECRTRACE("GETTCM : "+mess(7,21,1)-num$(LRET), 1)  # FGR 21/12/2009 : X3SUIVI60986
            GOK=0
            Return
        Endif

        If LSTOP>=0    # Traitement d'un nouveau SMA --> on rectifie l'écart non absorbé des mouvements correspondants
            # Récupération CREMVTDAT et CREMVTTIM de la ligne de doc
            Raz [F:SJA], [F:STJ2], [F:SJL]
            Gosub READ_FIRST

            If [F:STJ2]STOFCY<>LFCY
                Gosub SETRND From FUNSADJB
            Endif

            Case [F:TCM]ISSVLTCOD(LNUMVLT)
                When 4   : # PMP
                    Gosub UPD_AVCDEV From TRTADJAVC
                When 5,8 : # FIFO, LIFO
                    # Se fait lors de la régul des mouvements de sorties (UPD_IFO)
                When 6   : # PM Lot
                    Gosub UPD_ALCDEV From TRTADJALC
            Endcase
            If GOK=0 : Return : Endif
        Endif

        If LSTOP<>-1
            Raz LSEQFCY, LMINSEQ
            For LINDFCY=0 To LNBFCY-1
                LSEQFCY(LINDFCY) = func GETLASTSEQ(LITFFCY(LINDFCY),LITM,LIPT,LDAT,LTIM)
                If LSEQFCY(LINDFCY)>0
                    # Filtrage des mouvements postérieurs au mouvement qui est à l'origine de la régul
                    If LSEQFCY(LINDFCY)<LMINSEQ | LMINSEQ=0
                        LMINSEQ = LSEQFCY(LINDFCY)
                    Endif
                Endif
                Call ECRTRACE("LITFFCY("+num$(LINDFCY)+") ="+LITFFCY(LINDFCY)-"LSEQFCY("+num$(LINDFCY)+") ="+num$(LSEQFCY(LINDFCY)),0)
            Next
            LINDFCY = 0
        Endif

        Case [F:TCM]ISSVLTCOD(LNUMVLT)
            When 4   : # PMP
                Gosub UPD_AVC From TRTADJAVC
            When 5,8 : # FIFO, LIFO
                # Issue 111385 - 2015-10-16 by CCC : Inter-sites transfer
                #If find(func STKLIB.SENSVCR([F:SMA]VCRTYP),1,-2)     # Entrée
                If find(func STKLIB.SENSVCR([F:SMA]VCRTYP),1,-2,3)     # Entrée
                    Gosub UPD_IFO From TRTADJIFO
                Endif
            When 6   : # PMP
                Gosub UPD_ALC From TRTADJALC
        Endcase
        If LSTOP<0 : Return : Endif
        If GOK=0   : Return : Endif

    Endif
Return

$DIM_VAR
Filter [ITF] Where ITMREF=[F:SMA]ITMREF
LNBFCY = rowcount([ITF])
#----- LTABFCY ----#
If dim(LTABFCY)>0 : Kill LTABFCY : Endif
If dim(LITFFCY)>0 : Kill LITFFCY : Endif
Local Char LTABFCY(GLONFCY)(LNBFCY)   # Liste des sites traités
Local Char LITFFCY(GLONFCY)(LNBFCY)   # Liste complète des sites pour l'article
Raz LINDFCY
For [ITF]
      LITFFCY(LINDFCY) = [F:ITF]STOFCY
      LINDFCY+=1
Next
Filter [ITF]

#----- LSEQFCY ----#
If dim(LSEQFCY)>0 : Kill LSEQFCY : Endif
Local Integer LSEQFCY(LNBFCY)

#----- LTABQTYACT ----#
If dim(LTABQTYACT)>0 : Kill LTABQTYACT : Endif
Local Decimal LTABQTYACT(dim(LTABFCY))

#----- LTABAMT ----#
If dim(LTABAMT)>0 : Kill LTABAMT : Endif
Local Decimal LTABAMT(dim(LTABFCY),1+GDIMCST*GACTDECCST)

#----- LTABAVC ----#
If dim(LTABAVC)>0 : Kill LTABAVC : Endif
Local Decimal LTABAVC(dim(LTABFCY),1+GDIMCST*GACTDECCST)

Return


$READ_FIRST
# 118579.n - add CREMVTSEQ to the filter criteria since VCRNUM, VCRLIN and VCRTYP can produce duplicates on TRSTYP
Case [F:TCM]ISSVLTCOD(LNUMVLT)
    When 6   : # PM Lot
            Filter [SJL]  Where STOFCY    = [F:SMA]STOFCY
&                             & ITMREF    = [F:SMA]ITMREF
&                             & LOT       = [F:SMA]LOT
&                             & SLO       = [F:SMA]SLO
&                             & VCRTYP    = [F:SMA]VCRTYP
&                             & VCRNUM    = [F:SMA]VCRNUM
&                             & VCRLIN    = [F:SMA]VCRLIN
&                             & CREMVTSEQ = [F:SMA]CREMVTSEQ
            Read [SJL]SJL0 First
            If !fstat
                Gosub READ_STJ2 From TRTADJALC
            Endif
            If fstat
                # Document supprimé => pas de SJA si pas de AMTDEV
                Filter [STJ2] Where STOFCY    = [F:SMA]STOFCY
&                                 & ITMREF    = [F:SMA]ITMREF
&                                 & LOT       = [F:SMA]LOT
&                                 & SLO       = [F:SMA]SLO
&                                 & VCRTYP    = [F:SMA]VCRTYP
&                                 & VCRNUM    = [F:SMA]VCRNUM
&                                 & VCRLIN    = [F:SMA]VCRLIN
&                                 & CREMVTSEQ = [F:SMA]CREMVTSEQ
&                                 & TRSTYP <> 35
                Read [STJ2]STJ1 First
                Filter [STJ2]
            Endif
            Filter [SJL]
    When Default :
            Filter [SJA]  Where STOFCY    = [F:SMA]STOFCY
&                             & ITMREF    = [F:SMA]ITMREF
&                             & VCRTYP    = [F:SMA]VCRTYP
&                             & VCRNUM    = [F:SMA]VCRNUM
&                             & VCRLIN    = [F:SMA]VCRLIN
&                             & CREMVTSEQ = [F:SMA]CREMVTSEQ
            Read [SJA]SJA0 First
            If !fstat
#                Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
                Gosub READ_STJ2 From TRTADJAVC
            Endif
            If fstat
                # Document supprimé => pas de SJA si pas de AMTDEV
                Filter [STJ2] Where STOFCY    = [F:SMA]STOFCY
&                                 & ITMREF    = [F:SMA]ITMREF
&                                 & VCRTYP    = [F:SMA]VCRTYP
&                                 & VCRNUM    = [F:SMA]VCRNUM
&                                 & VCRLIN    = [F:SMA]VCRLIN
&                                 & CREMVTSEQ = [F:SMA]CREMVTSEQ
&                                 & TRSTYP <> 35
                Read [STJ2]STJ1 First
                Filter [STJ2]
            Endif
            Filter [SJA]

Endcase

Return

###############################################################################
# Met à jour le montant non absorbé de la ligne de document à l'origine de la régul
#
# Paramètres E : PQTY    = quantité active du stock après la ligne de doc en cours dans [STJ2]
#                          Cette valeur est mise à jour si ISSVLTCOD=PMP
#                PAMT    = montant du stock après la ligne de doc en cours dans [STJ2]
#                          Cette valeur est mise à jour si ISSVLTCOD=PMP
#                PAMTRND, PPRIRND = arrondis (montant, prix)
#
#            S : PAMTDEV = nouvel écart non absorbé
#
# Renvoie le nombre d'enregistrements écrits
###############################################################################
Funprog MAJAMTDEV(PQTY,PAMT, PAMTRND, PPRIRND, PAMTDEV, PNUMVLT)
Variable Decimal PQTY
Variable Decimal PAMT()
Value    Decimal PAMTRND, PPRIRND
Variable Decimal PAMTDEV()
Value    Integer PNUMVLT

End func MAJAMTDEV2(PQTY,PAMT, PAMTRND, PPRIRND, PAMTDEV, PNUMVLT, "")

Funprog MAJAMTDEV2(PQTY,PAMT, PAMTRND, PPRIRND, PAMTDEV, PNUMVLT, PSUP)
Variable Decimal PQTY
Variable Decimal PAMT()
Value    Decimal PAMTRND, PPRIRND
Variable Decimal PAMTDEV()
Value    Integer PNUMVLT
Value    Char    PSUP

Local Decimal LQTYLIN, LQTYLINACT, LAMTLIN(1+GDIMCST*GACTDECCST), LDEVLIN(1+GDIMCST*GACTDECCST), LDELTA(1+GDIMCST*GACTDECCST)
Local Decimal LDEVAMT(dim(LDEVLIN))
Local Integer LNB, LNBMVT, LVLTCOD, I, LIO

Raz PAMTDEV

    If instr(1,PSUP,"L")
        #---- Récupération du montant non absorbé par le stock sur la ligne de doc pour màj si nécessaire ----#
        Call CALVALDOCLOT2([F:SMA]STOFCY,[F:SMA]ITMREF,[F:SMA]LOT,[F:SMA]SLO,[0/0/0],[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "O",
&                          LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT) From FUNSADJC
    Else
        #---- Récupération du montant non absorbé par le stock sur la ligne de doc pour màj si nécessaire ----#
        Call CALVALDOC2([F:SMA]STOFCY,[F:SMA]ITMREF,[0/0/0],[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT)
    Endif
    If find([F:STJ2]TRSTYP,2,4,6,11,24) | [F:STJ2]TRSTYP=14 & [F:STJ2]ACTQTY<0
        LVLTCOD = [F:TCM]ISSVLTCOD+1
        LIO = 2    # Sortie
    Else
        LVLTCOD = [F:TCM]RCPVLTCOD+1
        LIO = 1    # Entrée
    Endif
    Case [F:TCM]ISSVLTCOD(PNUMVLT)
        When 4, 6:
            # Est-ce que le nouveau montant de stock peut absorber ce qui n'avait pas pu l'être ?...
            If LIO=2 & PQTY=0 & PAMT(0)<>0 & (PAMT(0)-LDEVAMT(0)+LDEVLIN(0))<>0
                For I=0 To dim(PAMT)-1
                    LDELTA(I) = -(PAMT(I)-LDEVAMT(I))
                    If LAMTLIN(I)+LDELTA(I)>0
                        LDEVLIN(I) = LAMTLIN(I)+LDELTA(I)-LDEVLIN(I)
                    Else
                        LDEVLIN(I) = 0
                    Endif
                    PAMT(I) = 0
                Next
            Elsif PQTY=0 | PQTY*(PAMT(0)-LDEVAMT(0)+LDEVLIN(0))<0         # ... non => on absorbe ce que l'on peut
                For I=0 To dim(PAMT)-1
                    LDEVLIN(I) = - (LDEVLIN(I) + PAMT(I)-LDEVAMT(I))
                    LDELTA(I) = -(PAMT(I)-LDEVAMT(I))
                    PAMT(I) = 0
                Next
            Else                 # ... oui => on absorbe tout
                For I=0 To dim(PAMT)-1
                    PAMT(I)   +=  LDEVLIN(I)-LDEVAMT(I)
                    LDELTA(I) = LDEVLIN(I)
                    LDEVLIN(I) = -(LDEVLIN(I))
                Next
            Endif
            If LDEVLIN(0)<>0 | LDELTA(0)<>0 | LDEVAMT(0)<>0
                If instr(1,PSUP,"L")
                    Filter [SJL] Where STOFCY = [F:SMA]STOFCY
&                                    & ITMREF = [F:SMA]ITMREF
&                                    & LOT    = [F:SMA]LOT
&                                    & SLO    = [F:SMA]SLO
&                                    & VCRTYP = [F:SMA]VCRTYP
&                                    & VCRNUM = [F:SMA]VCRNUM
&                                    & VCRLIN = [F:SMA]VCRLIN
                    Read [SJL]SJL0 First
                    Gosub READ_STJ2 From TRTADJALC
                Else
                    Filter [SJA] Where STOFCY = [F:SMA]STOFCY
&                                    & ITMREF = [F:SMA]ITMREF
&                                    & VCRTYP = [F:SMA]VCRTYP
&                                    & VCRNUM = [F:SMA]VCRNUM
&                                    & VCRLIN = [F:SMA]VCRLIN
                    Read [SJA]SJA0 First
                    #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
                    Gosub READ_STJ2 From TRTADJAVC
                Endif
                Raz LAMTLIN
                Call ECRTRACEVAL("LAMTLIN",LAMTLIN)
                Call ECRTRACEVAL("LDELTA",LDELTA)
                Call ECRTRACEVAL("LDEVLIN",LDEVLIN)
                LNB = func UPDSTJLIN2([F:SMA]STOFCY,[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN,1,
&                                    LNBMVT, LQTYLINACT, LAMTLIN(0), LDELTA, LDEVLIN, LVLTCOD, PNUMVLT, PAMTRND, PPRIRND, PSUP)
                If instr(1,PSUP,"L")
                    Filter [SJL]
                Else
                    Filter [SJA]
                Endif
            Endif
            If GOK>0
                For I=0 To dim(PAMTDEV)-1
                    PAMTDEV(I) = LDEVLIN(I)
                Next
            Endif
        When 5, 8:
            If PAMTDEV(0)<>0
                Filter [SJA] Where STOFCY = [F:SMA]STOFCY
&                                & ITMREF = [F:SMA]ITMREF
&                                & VCRTYP = [F:SMA]VCRTYP
&                                & VCRNUM = [F:SMA]VCRNUM
&                                & VCRLIN = [F:SMA]VCRLIN
                Read [SJA]SJA0 First
                #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
                Gosub READ_STJ2 From TRTADJAVC
                Raz LAMTLIN
                LNB = func UPDSTJLIN([F:SMA]STOFCY,[F:SMA]VCRTYP,[F:SMA]VCRNUM,[F:SMA]VCRLIN,1,
&                                    LNBMVT, LQTYLINACT, LAMTLIN(0), LDELTA, PAMTDEV, LVLTCOD, PNUMVLT, PAMTRND, PPRIRND)
                Filter [SJA]
                If GOK>0 & [F:STJ2]TRSTYP=5 # Entrée OF
                    Gosub UPD_MWIDEV
                Endif
            Endif
    Endcase
End LNB


###############################################################################
# Renvoie le plus petit MVTSEQ pour un article, une date d'imputation,
# une date de création et une heure de création donnés
###############################################################################
Funprog GETLASTSEQ(PFCY,PITM,PIPT,PDAT,PTIM)
Value Char    PFCY
Value Char    PITM
Value Date    PIPT
Value Date    PDAT
Value Char    PTIM

Local Char LFCY(GLONFCY)
Local Date LIPT
Raz [F:STJ]

    Columns [STJ] (STOFCY,UPDCOD,ITMREF,IPTDAT)
        Filter [STJ] Where ITMREF=PITM & REGFLG=1
&                         & (IPTDAT > PIPT
&                           | (IPTDAT = PIPT
&                             & ( CREMVTDAT > PDAT
&                               | (CREMVTDAT = PDAT & CREMVTTIM >= PTIM)
&                               )
&                             )
&                           )
&                     Order By ITMREF;IPTDAT Asc; CREMVTDAT Asc; CREMVTTIM Asc; MVTSEQ Desc; MVTIND Desc
    For  [STJ]
        If [F:STJ]UPDCOD=2
            Break
        Endif
        Raz [F:STJ]IPTDAT
    Next
    Filter [STJ]
    Columns [STJ]
    LIPT = [F:STJ]IPTDAT
    Columns [STJ] (MVTSEQ)
    Filter [STJ] Where STOFCY = PFCY
&                    & UPDCOD = 2
&                    & ITMREF = PITM
&                    & IPTDAT = LIPT
    For [STJ]STJ0
        Break
    Next
    Filter [STJ]
    Columns [STJ]

End [F:STJ]MVTSEQ    # Récupération du MVTSEQ à ne pas dépasser pour l'IPTDAT en cours

###############################################################################
# ISSADJ : Met à jour les mouvements d'une ligne de document de sortie
###############################################################################
# Paramètres E : PQTYACTFCY = quantité (base PMP pour méthode PMP, ou qté entrée pour méthode Fifo/Lifo)
#                PAMTFCY    = montant (idem qté)
#                PAVCQTY    = prix (idem qté)
#                PAMTRND, PPRIRND    = arrondi
#                PNUMVLT    = n° méthode valo (0=1ère; 1=2ème)
#            S : PQTYLINACT = qté active de la ligne de doc de sortie régularisée
#                PAMTLIN    = montant de la ligne de doc de sortie régularisée
#                PDELTA     = delta de montant
#                PDEVLIN    = écart non absorbé
#
# Prérequis : [F:STJ2] et [F:TCM] positionnée
###############################################################################
Funprog ISSADJ(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)
Value    Decimal PQTYACTFCY
Value    Decimal PAMTFCY()
Value    Decimal PAVCFCY()
Value    Decimal PAMTRND
Value    Decimal PPRIRND
Value    Integer PNUMVLT
Variable Decimal PQTYLINACT
Variable Decimal PAMTLIN()
Variable Decimal PDELTA()
Variable Decimal PDEVLIN()

End func ISSADJ2(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, "", PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)

Funprog ISSADJ2(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, PSUP, PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)
Value    Decimal PQTYACTFCY
Value    Decimal PAMTFCY()
Value    Decimal PAVCFCY()
Value    Decimal PAMTRND
Value    Decimal PPRIRND
Value    Integer PNUMVLT
Value    Char    PSUP
Variable Decimal PQTYLINACT
Variable Decimal PAMTLIN()
Variable Decimal PDELTA()
Variable Decimal PDEVLIN()

Local Decimal LDELTA(1+GDIMCST*GACTDECCST), LDELTADEV(1+GDIMCST*GACTDECCST)
Local Integer LNBMVT, LNB, I, LRET
Local Decimal LQTYLIN, LQTYLINACT, LAMTLIN(1+GDIMCST*GACTDECCST), LDEVLIN(1+GDIMCST*GACTDECCST), LAMTTMP(1+GDIMCST*GACTDECCST)
Local Decimal LDEVAMT(dim(LDEVLIN))
Local Decimal LCNVRPT
# Issue 108950 - 2015-08-26 by CCC
Local Integer LNBMVT2
Local Decimal LQTYLIN2, LQTYLINACT2, LAMTLIN2(1+GDIMCST*GACTDECCST), LDEVLIN2(1+GDIMCST*GACTDECCST)

# Issue 112836 - 2016-04-27 by CCC
Local Decimal LQTYASS, LQTYDIS

Call ECRTRACE("begin ISSADJ2("+num$(PQTYACTFCY)+","+num$(PAMTFCY)+","+num$(PAVCFCY)+","+num$(PAMTRND)+","+num$(PPRIRND)+","+num$(PNUMVLT)+","+PSUP+")",0)

    #---- Récupération des valeurs de la ligne de doc ----#
    # Issue 83992 - 2012-08-10 by CCC
    If instr(1,PSUP,"L")<>0
        If [F:STJ2]TRSTYP=8
            Call CALVALDOCLOT2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V",
&                           LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT) From FUNSADJC
        Else
            Call CALVALDOCLOT2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[0/0/0],[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V",
&                              LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT) From FUNSADJC
        Endif
    Else
        If [F:STJ2]TRSTYP=8
            Call CALVALDOC2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]IPTDAT,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V",
&                           LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT)
        Else
            Call CALVALDOC2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[0/0/0],[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT)
        Endif
    Endif

    # On peut arriver avec PRINAT=8 sur un retour client par exemple
    # Issue 94844 - 2014-02-05 by CCC : il faut passer pour le retour client si régul FIFO
    If find([F:STJ2]PRINAT,5,6,7,9,8)
        #---- Calcul du delta de montant ----#
        Case [F:TCM]ISSVLTCOD(PNUMVLT)
            When 4, 6:    # PMP et PM Lot
                If find([F:STJ2]PRINAT,5,7)
                    If !([F:STJ2]TRSTYP=13 & ([F:TCM]CUNPOS<>[F:TCM]ISSVLTCOD(PNUMVLT) & LQTYLIN>0 | [F:TCM]CUNNEG<>[F:TCM]ISSVLTCOD(PNUMVLT) & LQTYLIN<0))
                        # Issue 99565 - 2014-04-22 by CCC : calculate values in order to have LDELTA(i)+LAMTLIN(i) = AUC(i)*qty
                        If PQTYACTFCY<(-LQTYLINACT)    # SHOULDN'T happen, otherwise, value is put in non abs. amount
                            For I=0 To dim(LDELTA)-1
                                LDELTA(I) = -LAMTLIN(I)
                                LDELTADEV(I) = PAMTFCY(I)+LAMTLIN(I)-LDEVLIN(I)
                            Next
                        Else
                            If PQTYACTFCY<>0
                                LDELTA(0) = arr(PAMTFCY(0)*LQTYLINACT/PQTYACTFCY,PAMTRND)
                                If GACTDECCST   # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
                                    Call REPVAL(LDELTA(0),PAMTFCY(1..dim(PAMTFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
                                Endif
                            Else
                                LDELTA(0) = arr(PAVCFCY(0)*LQTYLINACT,PAMTRND)
                                If GACTDECCST   # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
                                    Call REPVAL(LDELTA(0),PAVCFCY(1..dim(PAVCFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
                                Endif
                            Endif
                            For I=0 To dim(LDELTA)-1
                                LDELTA(I) -= LAMTLIN(I)
                                LDELTADEV(I) = -LDEVLIN(I)
                            Next
                        Endif
                    Endif
                Endif
            When 5,8 : # FIFO - LIFO
                If find([F:STJ2]PRINAT,6,9) | find([F:STJ2]PRINAT,8) & [F:STJ2]TRSTYP=11
                    # Calcul de la différence de montant sur cette ligne de doc de sortie
                    # PAMTFCY correspond au nouveau montant de l'entrée
                    # PQTYACTFCY correspond au rapport de la quantité utilisée par la sortie / la quantité totale de l'entrée
                    For I=0 To dim(LDELTA)-1
                        # Issue 83408 - 2012-08-28 by CCC
                        ## Issue 80960 - 2012-03-23 by CCC
                        ##LDELTA(I) = arr(PAMTFCY(I)*PQTYACTFCY,PAMTRND)
                        #LDELTA(I) = arr(PAMTFCY(I)*PQTYACTFCY-LAMTLIN(I),PAMTRND)
                        LDELTA(I) = arr(PAMTFCY(I),PAMTRND)
                    Next
                    Raz LDELTADEV
                Endif
        Endcase
    Endif

    If LDELTA(0)<>0 | LDELTADEV(0)<>0
        LMES = mess([F:STJ2]VCRTYP,701,1)-[F:STJ2]VCRNUM-mess(61,100,1)-num$([F:STJ2]VCRLIN)
        LMES+= " : delta="+num$(LDELTA)
        Call ECRTRACE( LMES, 0)
        Call ECRTRACEVAL("LAMTLIN",LAMTLIN)
        Call ECRTRACEVAL("LDELTA",LDELTA)
        Call ECRTRACEVAL("LDEVLIN",LDEVLIN)

        #----- Ecriture des nouveaux STOJOU ------#
        LNB += func UPDSTJLIN2([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, 2,
&                             LNBMVT, LQTYLINACT, LAMTLIN(0), LDELTA, LDELTADEV, [F:TCM]ISSVLTCOD+1, PNUMVLT, PAMTRND, PPRIRND, PSUP)
        If !GOK
            End 0
        Endif

        Raz [F:SDH]
        Case [F:STJ2]TRSTYP
            When 2 : # Sortie diverse
                If [F:STJ2]VCRTYP=31    # Assemblage
                    # ----- Régul prix composé + création SMA pour composé -----#
                        Call CONVERT2(GLOCALDEV,GSYSCUR,GLOCALDEV,GCHGTYP,[F:STJ2]IPTDAT,
&                                     1,LCNVRPT,LRET) From TRTDEV

# Issue 81476 - 2012-08-06 by CCC : C'est la somme de tous les mouvements de l'assemblage qui donne le delta
#                        Raz [M:SDP]
#                        Call LOADFIC("[M:SDP]",LDELTA,"","CST",1,0) From FUNSADJB
#                        [M:SDP]QTY    = 0
#                        [M:SDP]AMTTOT = func SUBSDPCOM.SUMCST("SDP")
                        Call SUMSJV2SDP("STOFCY=[F:STJ2]STOFCY & VCRTYP=[F:STJ2]VCRTYP & VCRNUM=[F:STJ2]VCRNUM", -1, 0) From STKVALECR
                        [M:SDP]QTY    = 0    # On passe un delta à la régul

                    # Issue 112836 - 2016-04-27 by CCC : save the difference of amount on the assembly to adjust disassembly
                    Call LOADVAR(LAMTTMP, "[M:SDP]", 0, "", 1, 0, 0) From STKVALECR

                    Raz [F:STJ], LQTYASS
                    For [STJ]STJ1(4) Where STOFCY = [F:STJ2]STOFCY
&                                        & UPDCOD = 2
&                                        & VCRTYP = [F:STJ2]VCRTYP
&                                        & VCRNUM = [F:STJ2]VCRNUM
&                                        & VCRLIN = 1
                        # Issue 112836 - 2016-04-27 by CCC : need to know the quantity of the assembly
                        For [STJ]STJ1
                            LQTYASS += [F:STJ]ACTQTY
                        Next

                        Call REGPRIX([F:STJ]STOFCY, [F:STJ]TRSTYP, [F:STJ]ITMREF, [F:STJ]IPTDAT,
&                                    "", [F:STJ]VCRTYP, [F:STJ]VCRNUM, [F:STJ]VCRLIN,
&                                    [F:STJ]VCRTYP, [F:STJ]VCRNUM, [F:STJ]VCRLIN, LCNVRPT, LRET) From STKVALREG

                        # mise à jour de cremvtdat pour les mouvements créés par la régul
                        Update [STJ1] Where STOFCY=[F:STJ]STOFCY
&                                         & VCRTYP=[F:STJ]VCRTYP
&                                         & VCRNUM=[F:STJ]VCRNUM
&                                         & VCRLIN=[F:STJ]VCRLIN
&                                         & CREMVTDAT=[0/0/0]
&                                    With CREMVTDAT=[F:STJ]CREMVTDAT,
&                                         CREMVTTIM=[F:STJ]CREMVTTIM
                        LNB += adxuprec
                        GISSADJ=2    # On veut pouvoir créer un SMA même si on est en cours de régul de sortie
                        Case func STKLIB.TSTREG
                            When 1 :
                                # On passe en paramètre AMTORD+AMTDEV car si une régule ne peut se faire (stock nul au moment de la régul)
                                # on aura uniquement de l'écart non absorbé.
                                # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter to CRESMA
                                Call CRESMA([F:STJ]STOFCY,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                           [F:STJ]TRSTYP,[F:STJ]CREMVTSEQ,
&                                           [F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                           [F:STJ]ACTQTY,LDELTA,LRET) From STKLIB
                                LREPEAT = 1
                            When 2 :
                                # On passe en paramètre AMTORD+AMTDEV car si une régule ne peut se faire (stock nul au moment de la régul)
                                # on aura uniquement de l'écart non absorbé.
                                # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter to CRESMALOT
                                Call CRESMALOT([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,
&                                              [F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                              [F:STJ]TRSTYP,[F:STJ]CREMVTSEQ,
&                                              [F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                              [F:STJ]ACTQTY,LDELTA,LRET) From FUNSADJC
                                LREPEAT = 1
                        Endcase
                        GISSADJ=1
                        Break    # Par sécurité
                    Next
                    Filter [STJ]

                    # Issue 108950 - 2015-08-26 by CCC : If component=product, movements of product are not read => add its value in AUC amount
                    If [F:STJ]ITMREF=[F:STJ2]ITMREF
                        If instr(1,PSUP,"L")<>0
                            Call CALVALDOCLOT([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                             [F:STJ]CREMVTSEQ, PNUMVLT, "O", LNBMVT2, LQTYLIN2, LQTYLINACT2, LAMTLIN2, LDEVLIN2) From FUNSADJC
                        Else
                            Call CALVALDOC([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,
&                                          [F:STJ]CREMVTSEQ, PNUMVLT, "O", LNBMVT2, LQTYLIN2, LQTYLINACT2, LAMTLIN2, LDEVLIN2)
                        Endif
                        Call ECRTRACE("Assembly with product=component -> LAMTLIN+="+num$(LAMTLIN2(0)),0)
                    Endif

                    # Issue 112836 - 2016-04-27 by CCC : adjust disassembly of the assembly for the product
                    Raz [F:STJ]
                    If LQTYASS<>0
                        For [STJ]STJ1(4) Where STOFCY = [F:STJ2]STOFCY
&                                            & UPDCOD = 2
&                                            & VCRTYP = 32
&                                            & VCRTYPORI = 31
&                                            & VCRNUMORI = [F:STJ2]VCRNUM
&                                            & VCRLINORI = 1
                            Raz LQTYDIS
                            For [STJ]STJ1
                                LQTYDIS += [F:STJ]ACTQTY
                            Next
                            Raz [M:SDP]
                            Call LOADFIC("[M:SDP]", LAMTTMP, "", "CST", LQTYDIS/LQTYASS, 0) From STKVALECR
                            Gosub CAL_TOT From SUBSDP    # Calcule PRI = somme de toutes les composantes
                            [M:SDP]AMTTOT = [M:SDP]PRI
                            Call REGPRIX([F:STJ]STOFCY, [F:STJ]TRSTYP, [F:STJ]ITMREF, [F:STJ]IPTDAT,
&                                        "", [F:STJ]VCRTYP, [F:STJ]VCRNUM, [F:STJ]VCRLIN,
&                                        [F:STJ]VCRTYP, [F:STJ]VCRNUM, [F:STJ]VCRLIN, LCNVRPT, LRET) From STKVALREG
                        Next
                        Filter [STJ]
                    Endif
                Endif
            When 4 : # Livraison
                # CCC (2009-11-03) Bug 55625 : calcul de marge si PMP et regul en cours au pmp
                # Issue 66578 - 2010-08-18 by CCC : La marge peut être calculée à partir du FIFO
                If [F:TCM]PFMCLCBAS=[F:TCM]ISSVLTCOD(PNUMVLT)# & [F:TCM]PFMCLCBAS=4
                    If instr(1,PSUP,"L")<>0
                        Local Char REQ(250)
                        REQ="SELECT SUM(ACTQTY_0) FROM STOJOU"
&                         + " WHERE STOFCY_0='"+[F:STJ2]STOFCY+"'"
&                         + " AND ITMREF_0='"+[F:STJ2]ITMREF+"'"
&                         + " AND VCRTYP_0="+num$([F:STJ2]VCRTYP)
&                         + " AND VCRNUM_0='"+[F:STJ2]VCRNUM+"'"
&                         + " AND VCRLIN_0="+num$([F:STJ2]VCRLIN)
&                         + " AND REGFLG_0=1"
                        For (Decimal QTYLIN) From num$(GTYPDBA*2+1) Sql REQ As [STJX]
                            If [F:STJX]QTYLIN<>0
                                Call UPDPFM(PQTYACTFCY, PAMTFCY(0), PAVCFCY(0), LDELTA/[F:STJX]QTYLIN)    # Met à jour la marge de la livraison et/ou de la facture
                            Endif
                        Next
                    Else
                        Call UPDPFM(PQTYACTFCY, PAMTFCY(0), PAVCFCY(0), LDELTA/LQTYLINACT)    # Met à jour la marge de la livraison et/ou de la facture
                    Endif
                    If [F:SDH]SDHNUM<>[F:STJ2]VCRNUM
                        Read [SDH]SDH0 = [F:SDD]SDHNUM    # Par sécurité, mais UPDPFM doit le faire...
                    Endif
                Endif
            When 6, 29:    # Sortie matière
                If PNUMVLT=0
                    # Met à jour les WIPCOST et lance un calcul de PRF
                    Call MWIMAT([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,[F:STJ2]VCRTYPORI,[F:STJ2]VCRNUMORI,[F:STJ2]VCRLINORI,[F:STJ2]ITMREF,LAMTLIN,LDELTA,PAMTRND)
                    If GOK
&                      & [F:STJ2]VCRTYPORI<>0     # Issue 102110 - 2014-08-14 by CCC : without WO => no need of SRW
                        Local Decimal PTABNUL(1) : Raz PTABNUL
                        # On enregistre le fait que le PRF de l'OF est à recalculer
                        Call ECRSRW([F:STJ2]STOFCY, [F:STJ2]VCRTYPORI, [F:STJ2]VCRNUMORI, [F:STJ2]VCRLINORI, 0, PTABNUL)
                    Endif
                Endif
        Endcase

        If !GOK
            End 0
        Endif
    # If delivery or inter-sites transfer (to manage customer returns)
    # or assembly (to manage dissaembly of the assembly)
    # => save the new value
    # Issue 112836 - 2016-04-27 by CCC : add assembly-disassembly case
        If [F:STJ2]TRSTYP=14
&        | [F:STJ2]TRSTYP=4
&        | [F:STJ2]TRSTYP=2 & [F:STJ2]VCRTYP=31
            For I=0 To dim(LAMTLIN)-1
                LAMTTMP(I) = (LAMTLIN(I)+LDELTA(I))        # Le montant est négatif et on va l'utiliser pour l'entrée càd >0
            Next
            If instr(1,PSUP,"L")
                Call ECRSRWLOT2([F:STJ2]STOFCY, [F:STJ2]ITMREF, [F:STJ2]LOT, [F:STJ2]SLO, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, 0, LQTYLINACT, LAMTTMP) From FUNSADJC
            Else
                Call ECRSRW1([F:STJ2]STOFCY, [F:STJ2]ITMREF, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, LQTYLINACT, LAMTTMP)
            Endif
            If !GOK
                End 0
            Endif
        Endif
    Else
        If instr(1,PSUP,"L")
            For I=1 To LNBMVT-1
                Read [SJL]SJL0 Next
            Next
            Gosub READ_STJ2 From TRTADJALC
        Else
            For I=1 To LNBMVT-1
                Read [SJA]SJA0 Next
            Next
            #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
            Gosub READ_STJ2 From TRTADJAVC
        Endif
    Endif

    # Issue 108950 - 2015-08-26 by CCC : add value of assembly product when product=component
    #PQTYLINACT = LQTYLINACT
    PQTYLINACT = LQTYLINACT + LQTYLINACT2
    For I=0 To dim(PAMTLIN)-1
        # Issue 108950 - 2015-08-26 by CCC : add value of assembly product when product=component
        #PAMTLIN(I)  = LAMTLIN(I)+LDELTA(I)
        PAMTLIN(I)  = LAMTLIN(I)+LDELTA(I)+LAMTLIN2(I)
        PDELTA(I)   = LDELTA(I)
        PDEVLIN(I)  = LDELTADEV(I)
    Next

Call ECRTRACE("End ISSADJ2("+num$(PQTYACTFCY)+","+num$(PAMTFCY)+","+num$(PAVCFCY)+","+num$(PAMTRND)+","+num$(PPRIRND)+","+num$(PNUMVLT)+",'"+PSUP+"',"+num$(PQTYLINACT)
&            +","+num$(PAMTLIN)+","+num$(PDELTA)+","+num$(PDEVLIN)+")",0)

End LNB

###############################################################################
# Ecrit un enregistrement [SRW]
###############################################################################
Subprog ECRSRW(PFCY, PVCRTYP, PVCRNUM, PVCRLIN, PQTYACT, PAMT)
Value Char    PFCY
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Decimal PQTYACT
Value Decimal PAMT()

Call ECRSRW2(PFCY, "", PVCRTYP, PVCRNUM, PVCRLIN, 0, PQTYACT, PAMT)

End

Subprog ECRSRW1(PFCY, PITM, PVCRTYP, PVCRNUM, PVCRLIN, PQTYACT, PAMT)
Value Char    PFCY
Value Char    PITM
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Decimal PQTYACT
Value Decimal PAMT()

Call ECRSRW2(PFCY, PITM, PVCRTYP, PVCRNUM, PVCRLIN, 0, PQTYACT, PAMT)

End

###############################################################################
# ECRSRW2 : Ecrit un enregistrement [SRW]
###############################################################################
Subprog ECRSRW2(PFCY, PITM, PVCRTYP, PVCRNUM, PVCRLIN, PCREMVTSEQ, PQTYACT, PAMT)
Value Char    PFCY
Value Char    PITM
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Integer PCREMVTSEQ
Value Decimal PQTYACT
Value Decimal PAMT

Local Integer I,J, LRET

If PVCRNUM=""
    End
Endif

    Call GETSOC(PFCY) From DEVSUB
    # Issue 71160 - 2011-01-31 by CCC
    #Read [SRW]SRW0=PVCRNUM;PVCRLIN;PVCRTYP;GSOCIETE
    Raz [F:SRW]
    Read [SRW]SRW0=PVCRNUM;PVCRLIN;PVCRTYP;PCREMVTSEQ;GSOCIETE

    [F:SRW]QTY += PQTYACT
    [F:SRW]AMT += PAMT(0)
    # PAMT peut ne pas être renseigné dans le cas des OF
    If GACTDECCST & dim(PAMT)>1
        Call LOADFIC("[F:SRW]",PAMT, "", "CST", 1, 0) From STKVALECR
    Endif
    Case fstat
        When 0       : Rewrite [SRW]
        When 1       :
        When Default : [F:SRW]CPY  = GSOCIETE
                       [F:SRW]STOFCY = PFCY
                       [F:SRW]VCRTYP = PVCRTYP
                       [F:SRW]VCRNUM = PVCRNUM
                       [F:SRW]VCRLIN = PVCRLIN
                       [F:SRW]CREMVTSEQ = PCREMVTSEQ
                       [F:SRW]ITMREF = PITM     # L'article n'est pas renseigné pour les sorties matières
                       Write [SRW]
    Endcase

    If fstat
        Call RSTA("SRW",PVCRNUM+";"+num$(PVCRLIN)+";"
&                       +num$(PVCRTYP)+";"+num$([F:SRW]CREMVTSEQ)+";"+num$(GSOCIETE)) From GLOCK
        Raz GOK
    Else
        If !find(PVCRTYP,9,10,36,0)     # Issue 102110 - 2014-08-14 by CCC : add 0
            Read [STJ]STJ1=PFCY;PVCRTYP;PVCRNUM;PVCRLIN
            LITM = [F:STJ]ITMREF
            For [STJ]STJ1(4) Where VCRTYPORI = PVCRTYP
&                                & VCRNUMORI = PVCRNUM
&                                & VCRLINORI = PVCRLIN
&                                & UPDCOD = 2
&                                & ITMREF = LITM
                # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter to CRESMA
                Call CRESMA([F:STJ]STOFCY,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,[F:STJ]TRSTYP,[F:STJ]CREMVTSEQ,PVCRTYP,PVCRNUM,PVCRLIN,1,1,LRET) From STKLIB
            Next
            [G:STJ]currind=1
            [G:STJ]currlen=0
        Endif
    Endif

End

##########################################################################
Funprog RCPADJ(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)
Value    Decimal PQTYACTFCY
Value    Decimal PAMTFCY()
Value    Decimal PAVCFCY()
Value    Decimal PAMTRND, PPRIRND
Value    Integer PNUMVLT
Variable Decimal PQTYLINACT
Variable Decimal PAMTLIN()
Variable Decimal PDELTA()
Variable Decimal PDEVLIN()

End func RCPADJ2(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, "", PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)

##########################################################################
Funprog RCPADJ2(PQTYACTFCY, PAMTFCY, PAVCFCY, PAMTRND, PPRIRND, PNUMVLT, PSUP, PQTYLINACT, PAMTLIN, PDELTA, PDEVLIN)
Value    Decimal PQTYACTFCY
Value    Decimal PAMTFCY()
Value    Decimal PAVCFCY()
Value    Decimal PAMTRND, PPRIRND
Value    Integer PNUMVLT
Value    Char    PSUP
Variable Decimal PQTYLINACT
Variable Decimal PAMTLIN()
Variable Decimal PDELTA()
Variable Decimal PDEVLIN()

Local Decimal LDELTA(dim(PDELTA)), LDELTADEV(dim(PDEVLIN))
Local Integer LNBMVT, LNB, I, LRET
Local Decimal LQTYLIN, LQTYLINACT, LAMTLIN(dim(PAMTLIN)), LDEVLIN(dim(PDEVLIN))
Local Decimal LDEVAMT(dim(LDEVLIN))
Local Decimal LTOT(dim(LDEVLIN)), LTOTNEG, LDELTATMP(dim(LDEVLIN))

Local Decimal LQTYORI, LAMTORI
Local Decimal LINVDTA   # Get the value of invoicing elements of a receipt
Local Decimal LQTYLINTOT   # Get the total active quantity for a document line (doesn't care of lot number)

Local Char LFILLOT(250)

Call ECRTRACE("begin RCPADJ("+num$(PQTYACTFCY)+","+num$(PAMTFCY)+","+num$(PAVCFCY)+","+num$(PAMTRND)+","+num$(PPRIRND)+","+num$(PNUMVLT)+")",0)

    #---- Récupération des valeurs de la ligne de doc ----#
    If instr(1,PSUP,"L")<>0
        LFILLOT = "LOT=[F:STJ2]LOT&SLO=[F:STJ2]SLO"
        If [F:STJ2]TRSTYP=8
            Call CALVALDOCLOT2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]IPTDAT,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V",
&                           LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT) From FUNSADJC
        Else
            Call CALVALDOCLOT2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]LOT,[F:STJ2]SLO,[0/0/0],[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "V",
&                              LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT) From FUNSADJC
        Endif
    Else
        LFILLOT = "1=1"
        If [F:STJ2]TRSTYP=8
            Call CALVALDOC2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ2]IPTDAT,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "O",
&                           LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT)
        Else
            Call CALVALDOC2([F:STJ2]STOFCY,[F:STJ2]ITMREF,[0/0/0],[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, [F:STJ2]CREMVTSEQ, PNUMVLT, "O", LNBMVT, LQTYLIN, LQTYLINACT, LAMTLIN, LDEVLIN, LDEVAMT)
        Endif
    Endif

    Call GETSOC([F:STJ2]STOFCY) From DEVSUB
    Raz [F:SRW]
    Case [F:STJ2]TRSTYP
        When 1:
            # Issue 112836 - 2016-04-27 by CCC : add disassembly of an assembly case
            If [F:STJ2]VCRTYP=32
                Filter [SRW] Where CPY    = GSOCIETE
&                                & VCRTYP = [F:STJ2]VCRTYPORI
&                                & VCRNUM = [F:STJ2]VCRNUMORI
&                                & VCRLIN = [F:STJ2]VCRLINORI
&                                & evalue(LFILLOT)
                Read [SRW] First
                Filter [SRW]
            Endif
        When 3, 12 :
            Filter [SRW] Where CPY    = GSOCIETE
&                            & VCRTYP = [F:STJ2]VCRTYPORI
&                            & VCRNUM = [F:STJ2]VCRNUMORI
&                            & VCRLIN = [F:STJ2]VCRLINORI
&                            & evalue(LFILLOT)
            Read [SRW] First
            Filter [SRW]
        When 14 :
            Filter [SRW] Where CPY    = GSOCIETE
&                            & VCRTYP = [F:STJ2]VCRTYP
&                            & VCRNUM = [F:STJ2]VCRNUM
&                            & VCRLIN = [F:STJ2]VCRLIN
&                            & evalue(LFILLOT)
            Read [SRW] First
            Filter [SRW]
    Endcase
    # Issue 69727 - 2010-12-09 by CCC : Un écart non absorbé sur une entrée doit être régularisé s'il est régularisable
    If [F:SRW]VCRNUM<>"" | (LDEVLIN<>0 & [F:TCM]PRIREG=2)
        If [F:SRW]VCRNUM<>"" & [F:SRW]QTY<>0
            # Issue 99565 - 2014-04-22 by CCC : AUC rounding & global/detail synchronization
            #LDELTA(0) = arr(LQTYLINACT*[F:SRW]AMT/[F:SRW]QTY-LAMTLIN(0),PAMTRND)
            LDELTA(0) = arr(LQTYLINACT*[F:SRW]AMT/[F:SRW]QTY,PAMTRND)
            # Issue 113876 - 2016-02-01 by CCC : In context of inter-sites, we need to have invoicing elements of the delivery and the receipt
            If [F:STJ2]VCRTYP=6 & [F:SRW]VCRTYP=4
                Read [PTD]PTD0=[F:STJ2]VCRNUM;[F:STJ2]VCRLIN
                If !fstat
                    If GBETFCYCST<>1
                        LINVDTA = func STKVAL.GETPTDINVDTA([F:STJ2]VCRNUM,[F:STJ2]VCRLIN)
                    Else
                        LINVDTA = 0
                    Endif
                    LQTYLINTOT = func STKVAL.GETDOCLINQTY([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,[F:STJ2]ITMREF)
                    If LQTYLINTOT<>0
                        LDELTA(0) += LINVDTA * LQTYLINACT/LQTYLINTOT
                    Else # security but shouldn't happen
                        LDELTA(0) += LINVDTA
                    Endif
                Endif
            Endif
            If GACTDECCST
                # Issue 99565 - 2014-04-22 by CCC : AUC rounding & global/detail synchronization
                Call LOADVAR(LDELTA,"[F:SRW]",0, "", LQTYLINACT/[F:SRW]QTY, 0, PAMTRND) From STKVALECR
                # Issue 113876 - 2016-02-01 by CCC : In context of inter-sites, we need to have invoicing elements of the delivery and the receipt
                ## To respect 60056 demand, invoicing element delta has to be null
                #LDELTA(0) -= LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1)
                #LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1)=0
                LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1) += LINVDTA
                Call REPVAL(LDELTA(0),LDELTA(1..dim(PAMTFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
            Endif
            For I=0 To dim(LDELTA)-1
                LDELTA(I) -= LAMTLIN(I)
            Next
            # Issue 113876 - 2016-02-01 by CCC : we keep invoicing elements of the delivery and receipt
            #If GACTDECCST    # Issue 106399 - 2015-03-18 by CCC : detailed cost testing
            #    LDELTA(0) += LAMTLIN(1+GACTMAT+GACTMAC+GACTLAB+1)
            #    LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1)=0
            #Endif
        Else
            For I=0 To dim(LDELTA)-1
                LDELTA(I) = LDEVLIN(I)
            Next
        Endif

        # If global value is negative or quantity becomes null
        # remaining value is set to variance not absorbed
        Raz LTOTNEG
        If PAMTFCY(0)+LAMTLIN(0)+LDELTA(0)<0
&        | PQTYACTFCY+LQTYLINACT=0
            For I=0 To dim(PAMTFCY)-1
                LDELTA(I) = -PAMTFCY(I)-LAMTLIN(I)
                LDELTADEV(I) = PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)-LDEVLIN(I)
            Next
        Else
            # Otherwise, cost elements becoming negative are cumulated to be spread on positive values
            For I=0 To dim(PAMTFCY)-1
                # Issue 97422 - 2014-03-03 by CCC : Invoicing elements can be negative
                #If PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)<0 | PQTYACTFCY+LQTYLINACT=0
                If PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)<0 & I<>(1+GACTMAT+GACTMAC+GACTLAB+1)
                    LTOTNEG += PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)
    #                LDELTADEV(I) = PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)-(LDEVLIN(I))
                    LDELTA(I) = -PAMTFCY(I)-LAMTLIN(I)
                Else
                    LDELTADEV(I) = -(LDEVLIN(I))
                Endif
                LTOT(I)=PAMTFCY(I)+LAMTLIN(I)+LDELTA(I)
            Next
        Endif

        # Issue 99565 - 2014-04-22 by CCC : AUC rounding & global/detail synchronization
        If GACTDECCST
            If LTOTNEG<>0
                Raz LDELTATMP
                Call REPVAL(LTOTNEG,LTOT(1..dim(LTOT)-1),PAMTRND,LDELTATMP(1..dim(LDELTATMP)-1)) From STKVALECR
                For J=1 To dim(PAMTFCY)-1
                    LDELTA(J)+=LDELTATMP(J)
                Next
            Endif
            Call REPVAL(LDELTA(0),LDELTA(1..dim(PAMTFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
            Call REPVAL(LDELTADEV(0),LDELTADEV(1..dim(PAMTFCY)-1),PAMTRND,LDELTADEV(1..dim(LDELTADEV)-1)) From STKVALECR
        Endif
    Elsif find([F:STJ2]PRINAT,5,7)  # valorisé au PMP (par exemple règle d'exception dans la méthode de valo)
# Issue 99565 - 2016-05-02 by BEEBE/CCC : AUC rounding & global/detail synchronization
#        If PQTYACTFCY<>0
#            For I=0 To dim(PAMTFCY)-1
#                LDELTA(I) = arr(LQTYLINACT*PAMTFCY(I)/PQTYACTFCY-LAMTLIN(I),PAMTRND)
#                LDELTADEV(I) = -(LDEVLIN(I))
#            Next
#        Else
#            For I=0 To dim(PAMTFCY)-1
#                LDELTA(I) = arr(LQTYLINACT*PAVCFCY(I)-LAMTLIN(I),PAMTRND)
#                LDELTADEV(I) = -(LDEVLIN(I))
#            Next
#        Endif
        If PAMTFCY(0)*PQTYACTFCY<>0
            LDELTA(0) = arr(PAMTFCY(0)*LQTYLINACT/PQTYACTFCY,PAMTRND)
            If GACTDECCST
                Call REPVAL(LDELTA(0),PAMTFCY(1..dim(PAMTFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
            Endif
        Else
            LDELTA(0) = arr(PAVCFCY(0)*LQTYLINACT,PAMTRND)
            If GACTDECCST
                Call REPVAL(LDELTA(0),PAVCFCY(1..dim(PAVCFCY)-1),PAMTRND,LDELTA(1..dim(LDELTA)-1)) From STKVALECR
            Endif
        Endif
        For I=0 To dim(LDELTA)-1
            LDELTA(I) -= LAMTLIN(I)
            LDELTADEV(I) = -LDEVLIN(I)
        Next
    Elsif [F:STJ2]TRSTYP=19 & [F:STJ2]PRINAT=8
        Raz LQTYORI, LAMTORI, LDELTA
        Filter [STJ] Where STOFCY=[F:STJ2]STOFCY
&                        & VCRTYPORI=[F:STJ2]VCRTYPORI & VCRNUMORI=[F:STJ2]VCRNUMORI & VCRLINORI=[F:STJ2]VCRLINORI
&                        & ITMREF=[F:STJ2]ITMREF
&                        & VCRTYP=12 & TRSTYP=6
&                        & LOT=[F:STJ2]LOT & SLO=[F:STJ2]SLO
&                        & UPDCOD=2
        For [STJ] reckey
            LQTYORI += [F:STJ]ACTQTY * ([F:STJ]REGFLG=1)
            LDELTA(0) += [F:STJ]VARORD
            If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
                Read [SJV]SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
                If !fstat
                    Call LOADVAR(LDELTA,"[F:SJV]", 0, "DO", 1, 1, 0) From STKVALECR
                Endif
            Endif
        Next
        Filter [STJ]
        If LQTYORI<>0
            For I=0 To dim(PAMTFCY)-1
                LDELTA(I) = arr(LQTYLINACT*LDELTA(I)/ LQTYORI-LAMTLIN(I),PAMTRND)
            Next
        Else
            Raz LDELTA, LDELTADEV
        Endif
    Else
        Raz LDELTA, LDELTADEV    # ldevlin<>0 après calvaldoc => pour ne pas ajouter à ITH ce qui a déjà été compté
    Endif

    If sigma(0,dim(LDELTA)-1,abs(LDELTA(indcum)))<>0 | sigma(0,dim(LDELTADEV)-1,abs(LDELTADEV(indcum)))<>0
&    | LDEVAMT(0)<>0

# Issue 118956 - 2016-12-08 by CCC : For FIFO mode, call entry price adjustment to update FIFO table
        If find([F:TCM]ISSVLTCOD(PNUMVLT),5,8)
            Raz [M:SDP]

            [M:SDP]QTY    = 0   # Delta is passed to adjustment process
            [M:SDP]AMTTOT = LDELTA(0)
            # Get detailed rounded amount
            If GACTDECCST
                Call LOADFIC("[M:SDP]", LDELTA, "", "CST", 1, 0) From STKVALECR
            Endif
            GISSADJ = 2     # Allow creation of STKMVTADJ record
            Call REGPRIX([F:STJ2]STOFCY, [F:STJ2]TRSTYP, [F:STJ2]ITMREF, [F:STJ2]IPTDAT, "",
&                        [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, [F:STJ2]VCRTYP, [F:STJ2]VCRNUM, [F:STJ2]VCRLIN, 1, LRET) From STKVALREG
            GISSADJ = 1
            If LRET
                GOK=0
                End 0
            Endif

            For I=1 To LNBMVT-1
                Read [SJA]SJA0 Next
            Next
            Gosub READ_STJ2 From TRTADJAVC

        Else
            #----- Ecriture des nouveaux STOJOU ------#
            LNB += func UPDSTJLIN2([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN, 1,
&                                 LNBMVT, LQTYLINACT, LAMTLIN(0), LDELTA, LDELTADEV, [F:TCM]RCPVLTCOD+1, PNUMVLT, PAMTRND, PPRIRND,PSUP)
        Endif
        If !GOK
            End 0
        Endif

        # Issue 118956 - 2016-12-08 by CCC : take into account stock returns
        If [F:STJ2]TRSTYP=19 & PNUMVLT=0
            # Met à jour les WIPCOST et lance un calcul de PRF
            Call MWIMAT([F:STJ2]STOFCY,[F:STJ2]VCRTYP,[F:STJ2]VCRNUM,[F:STJ2]VCRLIN,[F:STJ2]VCRTYPORI,[F:STJ2]VCRNUMORI,[F:STJ2]VCRLINORI,[F:STJ2]ITMREF,LAMTLIN,LDELTA,PAMTRND)
            If GOK
&              & [F:STJ2]VCRTYPORI<>0     # Issue 102110 - 2014-08-14 by CCC : without WO => no need of SRW
                Local Decimal PTABNUL(1) : Raz PTABNUL
                # On enregistre le fait que le PRF de l'OF est à recalculer
                Call ECRSRW([F:STJ2]STOFCY, [F:STJ2]VCRTYPORI, [F:STJ2]VCRNUMORI, [F:STJ2]VCRLINORI, 0, PTABNUL)
            Endif
        Endif

        If [F:STJ2]TRSTYP=5 # Entrée OF
            Gosub UPD_MWIDEV
        Endif
        # Issue 91954 - 2013-10-07 by CCC
        If [F:STJ2]TRSTYP=12
            Gosub UPD_SRETURN
        Endif
    Else
        If instr(1,PSUP,"L")
            For I=1 To LNBMVT-1
                Read [SJL]SJL0 Next
            Next
            Gosub READ_STJ2 From TRTADJALC
        Else
            For I=1 To LNBMVT-1
                Read [SJA]SJA0 Next
            Next
            #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
            Gosub READ_STJ2 From TRTADJAVC
        Endif
    Endif

    PQTYLINACT = LQTYLINACT
    For I=0 To dim(PAMTLIN)-1
        PAMTLIN(I)  = LAMTLIN(I)+LDELTA(I)
        PDELTA(I)   = LDELTA(I)
        PDEVLIN(I)  = LDELTADEV(I)
    Next

Call ECRTRACE("end RCPADJ("+num$(PQTYACTFCY)+","+num$(PAMTFCY)+","+num$(PAVCFCY)+","+num$(PAMTRND)+","+num$(PPRIRND)+","+num$(PNUMVLT)+","+num$(PQTYLINACT)+","+num$(PAMTLIN)+","+num$(PDELTA)
&            +","+num$(PDEVLIN)+")",0)

End LNB

###############################################################################
# ISSADJ_MVTINV : Ecrit le mouvement inverse avant le mvt de régul
###############################################################################
$ISSADJ_MVTINV
    [F:STJ] = [F:STJ2]
    Readlock [STJ]STJ0 =
    [F:STJ]REGFLG=2
    Rewrite [STJ]
    If fstat
        Call FSTA("STJ") From GLOCK
        GOK = 0
        LRET=4
        Return
    Endif

    # Issue 91122 - 2013-09-06 by CCC : Traceability
    If [F:ITM]ITMREF <> [F:STJ]ITMREF
        Read [F:ITM]ITM0 = [F:STJ]ITMREF
    Endif
    If [F:ITM]TRKCOD = 2
        Gosub MAJ_STOTRK_REGFLG From STKVALREG
        If GOK<1
            LRET=4
            Return
        Endif
    Endif

    Call ECRTRACE("Write opposite movement only with quantity",0)
    [F:STJ]ACTQTY = -[F:STJ]ACTQTY
    [F:STJ]QTYSTU = -[F:STJ]QTYSTU
    [F:STJ]QTYPCU = -[F:STJ]QTYPCU
    [F:STJ]AMTORD = 0
    [F:STJ]AMTVAL = 0
    [F:STJ]VARORD = 0
    [F:STJ]VARVAL = 0
    [F:STJ]AMTDEV = 0
    [F:STJ]PRINAT = 0    # Cela permet de distinguer les vrais mouvements d'annulation avec prix=0 des mouvements d'annulations dus à la régul
    If GACTVLT2
        Raz [F:STJ]AMTVAL2,[F:STJ]VARVAL2,[F:STJ]PRIVAL2,[F:STJ]AMTDEV2,[F:STJ]PRINAT2
    Endif
    [F:STJ]AGGIFAFLG = 1
    [F:STJ]NUMVCR = ""
    [F:STJ]GTE = ""
    Raz [F:STJ]ACCDAT

    [F:STJ]VCRTYPREG = [F:SMA]VCRTYPREG
    [F:STJ]VCRNUMREG = [F:SMA]VCRNUMREG
    [F:STJ]VCRLINREG = [F:SMA]VCRLINREG
    [F:STJ]PRIREGFLG = 1
    Call ECRSTJ(0,LRET) From STKLIB
    If LRET
        Call FSTA("STJ") From GLOCK
        Raz GOK
        Return
    Endif
    Call ECRTRACE("STOFCY="-[F:STJ]STOFCY-"UPDCOD="-num$([F:STJ]UPDCOD)-"ITMREF="-[F:STJ]ITMREF-"IPTDAT="-[F:STJ]IPTDAT-"MVTSEQ="-num$([F:STJ]MVTSEQ)-"MVTIND="-num$([F:STJ]MVTIND),0)
    Call ECRTRACE("VCRTYP="-mess([F:STJ]VCRTYP,701,1)-"VCRNUM="-[F:STJ]VCRNUM-"VCRLIN="-num$([F:STJ]VCRLIN),0)
Return

###############################################################################
# ISSADJ_MVTNEW : Ecrit le mouvement de régularisation dans STOJOU
###############################################################################
$ISSADJ_MVTNEW
    [F:STJ] = [F:STJ2]

    If LNUMVLT=0
        Raz [F:STJ]VARVAL2,[F:STJ]AMTDEV2
        [F:STJ]VARORD  = LDELTA
        [F:STJ]AMTORD += [F:STJ]VARORD

        [F:STJ]AMTVAL += LDELTA
        [F:STJ]VARVAL  = LDELTA
        [F:STJ]AMTDEV  = LAMTDEV

        If GACTVLT2 & LNUMVLT=0
            [F:STJ]AMTDEV2 = LDELTA
        Endif

        # Il ne faut modifier PRINAT que sur les sorties
        # Sur les entrées, si on est au PMP c'est pour avoir une valeur par défaut
        If find([F:STJ2]TRSTYP,2,4,6,11,24) | [F:STJ2]TRSTYP=14 & [F:STJ2]ACTQTY<0
            [F:STJ]PRINAT  = LVLTCOD
        Endif

        If [F:STJ]QTYSTU<>0
            [F:STJ]PRIORD = arr([F:STJ]AMTORD/[F:STJ]QTYSTU,PPRIRND)
            [F:STJ]PRIVAL = arr([F:STJ]AMTVAL/[F:STJ]QTYSTU,PPRIRND)
        Else
            Raz [F:STJ]PRIORD, [F:STJ]PRIVAL
        Endif
        If [F:STJ]TRSTYP=23
            [F:STJ]PRIORD=[F:STJ2]PRIORD
        Endif
    Else
        Raz [F:STJ]VARORD,[F:STJ]VARVAL,[F:STJ]AMTDEV
        [F:STJ]AMTVAL2+= LDELTA
        [F:STJ]VARVAL2 = LDELTA
        [F:STJ]AMTDEV2 = LAMTDEV
        If [F:STJ]QTYSTU<>0
            [F:STJ]PRIVAL2 = arr([F:STJ]AMTVAL2/[F:STJ]QTYSTU,PPRIRND)
        Else
            Raz [F:STJ]PRIVAL2
        Endif
    Endif


    [F:STJ]AGGIFAFLG = 1
    [F:STJ]NUMVCR = ""
    [F:STJ]GTE = ""
    Raz [F:STJ]ACCDAT

    [F:STJ]VCRTYPREG = [F:SMA]VCRTYPREG
    [F:STJ]VCRNUMREG = [F:SMA]VCRNUMREG
    [F:STJ]VCRLINREG = [F:SMA]VCRLINREG
    [F:STJ]PRIREGFLG = 1

    Call ECRSTJ(0,LRET) From STKLIB
    If LRET
        Call FSTA("STJ") From GLOCK
        Raz GOK
        Return
    Endif
    Call ECRTRACE("STOFCY="-[F:STJ]STOFCY-"UPDCOD="-num$([F:STJ]UPDCOD)-"ITMREF="-[F:STJ]ITMREF-"IPTDAT="-[F:STJ]IPTDAT-"MVTSEQ="-num$([F:STJ]MVTSEQ)-"MVTIND="-num$([F:STJ]MVTIND),0)
    Call ECRTRACE("VCRTYP="-mess([F:STJ]VCRTYP,701,1)-"VCRNUM="-[F:STJ]VCRNUM-"VCRLIN="-num$([F:STJ]VCRLIN),0)

    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST

        #------ Récupération des valeurs d'origine ------#
        [F:SJV] = [F:SJV2]

        #------ Récupération de la nouvelle clé ------#
        [F:SJV] = [F:STJ]

        Raz [F:SJV]DOMATCST, [F:SJV]DVMATCST, [F:SJV]DEVMATCST, [F:SJV]DV2MATCST, [F:SJV]DEVMATCST2
        Raz [F:SJV]DOMACCST, [F:SJV]DVMACCST, [F:SJV]DEVMACCST, [F:SJV]DV2MACCST, [F:SJV]DEVMACCST2
        Raz [F:SJV]DOLABCST, [F:SJV]DVLABCST, [F:SJV]DEVLABCST, [F:SJV]DV2LABCST, [F:SJV]DEVLABCST2
        Raz [F:SJV]DOSCOTOT, [F:SJV]DVSCOTOT, [F:SJV]DEVSCOCST, [F:SJV]DV2SCOTOT, [F:SJV]DEVSCOCST2
        Raz [F:SJV]DOINVDTA, [F:SJV]DVINVDTA, [F:SJV]DEVINVDTA, [F:SJV]DV2INVDTA, [F:SJV]DEVINVDTA2
        Raz [F:SJV]DOOVEMAT, [F:SJV]DVOVEMAT, [F:SJV]DEVOVEMAT, [F:SJV]DV2OVEMAT, [F:SJV]DEVOVEMAT2
        Raz [F:SJV]DOOVEMAC, [F:SJV]DVOVEMAC, [F:SJV]DEVOVEMAC, [F:SJV]DV2OVEMAC, [F:SJV]DEVOVEMAC2
        Raz [F:SJV]DOOVELAB, [F:SJV]DVOVELAB, [F:SJV]DEVOVELAB, [F:SJV]DV2OVELAB, [F:SJV]DEVOVELAB2
        Raz [F:SJV]DOOVESCO, [F:SJV]DVOVESCO, [F:SJV]DEVOVESCO, [F:SJV]DV2OVESCO, [F:SJV]DEVOVESCO2

        Call DELTA2SJV(LDELTA, LAMTDEV, LNUMVLT, LIO=2 | (LNUMVLT=0 & [F:STJ]PRINAT=8) | (LNUMVLT=1 & [F:STJ]PRINAT2=8)) From STKVALECR

        #---------------------
        # Ecart non absorbé 2ème méthode
        #---------------------
        If GACTVLT2 & LNUMVLT=0
            Call LOADFIC("[F:SJV]", LDELTA, "DEV", "2", 1, 0) From STKVALECR
        Endif

        [F:SJV]CREDAT = date$
        [F:SJV]CREUSR = GUSER
        Raz [F:SJV]UPDDAT,[F:SJV]UPDUSR

        Write [SJV]
        If fstat
            Call FSTA("SJV") From GLOCK
            Raz GOK
            Return
        Endif
    Endif

Return

########################################################################
$ISSADJ_MVTUPD
    Call ECRTRACE("Update movement ldelta="+num$(LDELTA),0)
    Read [STJ]STJ0=[F:STJ2]STOFCY;[F:STJ2]UPDCOD;[F:STJ2]ITMREF;[F:STJ2]IPTDAT;[F:STJ2]MVTSEQ;[F:STJ2]MVTIND
    Call ECRTRACE(num$([F:STJ]AMTORD)-num$([F:STJ]VARORD)-num$([F:STJ]PRIORD),0)

    If LNUMVLT=0
        [F:STJ]VARORD += LDELTA
        [F:STJ]AMTORD += LDELTA

        [F:STJ]AMTVAL += LDELTA
        [F:STJ]VARVAL += LDELTA

        [F:STJ]AMTDEV += LAMTDEV

        If GACTVLT2 & LNUMVLT=0
            [F:STJ]AMTDEV2 += LDELTA
        Endif

        # Il ne faut modifier PRINAT que sur les sorties
        # Sur les entrées, si on est au PMP c'est pour avoir une valeur par défaut
        If find([F:STJ2]TRSTYP,2,4,6,11,24) | [F:STJ2]TRSTYP=14 & [F:STJ2]ACTQTY<0
            [F:STJ]PRINAT  = LVLTCOD
        Endif

        If [F:STJ]QTYSTU<>0
            [F:STJ]PRIORD = arr([F:STJ]AMTORD/[F:STJ]QTYSTU,PPRIRND)
            [F:STJ]PRIVAL = arr([F:STJ]AMTVAL/[F:STJ]QTYSTU,PPRIRND)
        Else
            Raz [F:STJ]PRIORD, [F:STJ]PRIVAL
        Endif

        If [F:STJ]TRSTYP=23
            [F:STJ]PRIORD=[F:STJ2]PRIORD
        Endif
    Else
        [F:STJ]AMTVAL2+= LDELTA
        [F:STJ]VARVAL2+= LDELTA
        [F:STJ]AMTDEV2+= LAMTDEV
        If [F:STJ]QTYSTU<>0
            [F:STJ]PRIVAL2 = arr([F:STJ]AMTVAL2/[F:STJ]QTYSTU,PPRIRND)
        Else
            Raz [F:STJ]PRIVAL2
        Endif
    Endif


    [F:STJ]VCRTYPREG = [F:SMA]VCRTYPREG
    [F:STJ]VCRNUMREG = [F:SMA]VCRNUMREG
    [F:STJ]VCRLINREG = [F:SMA]VCRLINREG
    [F:STJ]PRIREGFLG = 1

    Call REWSTJ(LRET) From STKLIB
    If LRET
        Call FSTA("STJ") From GLOCK
        Raz GOK
        Return
    Endif
    Call ECRTRACE("STOFCY="-[F:STJ]STOFCY-"UPDCOD="-num$([F:STJ]UPDCOD)-"ITMREF="-[F:STJ]ITMREF-"IPTDAT="-[F:STJ]IPTDAT-"MVTSEQ="-num$([F:STJ]MVTSEQ)-"MVTIND="-num$([F:STJ]MVTIND),0)
    Call ECRTRACE("VCRTYP="-mess([F:STJ]VCRTYP,701,1)-"VCRNUM="-[F:STJ]VCRNUM-"VCRLIN="-num$([F:STJ]VCRLIN),0)
    Call ECRTRACE(num$([F:STJ]AMTORD)-num$([F:STJ]VARORD)-num$([F:STJ]PRIORD),0)
    Call ECRTRACE(num$([F:STJ]AMTVAL)-num$([F:STJ]VARVAL)-num$([F:STJ]PRIVAL)-num$([F:STJ]AMTDEV)-"/"-num$([F:STJ]AMTVAL2)-num$([F:STJ]VARVAL2)-num$([F:STJ]PRIVAL2)-num$([F:STJ]AMTDEV2),0)

    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST

        #------ Récupération des valeurs d'origine ------#
        [F:SJV] = [F:SJV2]
        #------ Récupération de la nouvelle clé ------#
        [F:SJV] = [F:STJ]
        Read [SJV] =

        Call DELTA2SJV(LDELTA, LAMTDEV, LNUMVLT, LIO=2 | (LNUMVLT=0 & [F:STJ]PRINAT=8) | (LNUMVLT=1 & [F:STJ]PRINAT2=8)) From STKVALECR

        If GACTVLT2 & LNUMVLT=0
            Call LOADFIC("[F:SJV]", LDELTA, "DEV", "2", 1, 1) From STKVALECR
        Endif

        [F:SJV]UPDDAT = date$
        [F:SJV]UPDUSR = GUSER

        Rewrite [SJV]
        If fstat
            Call FSTA("SJV") From GLOCK
            Raz GOK
            Return
        Endif
    Endif

Return


########################################################################
# CALVALDOC : calcule la valeur d'ordre d'une ligne de doc
########################################################################
# Paramètres E : PFCY = Site
#                PITM = Article (nécessaire car la ligne a pu être créée puis supprimée pour un autre article)
#                PTYP = Type de doc
#                PNUM = N° de doc
#                PLIN = Ligne de doc
#                PNUMVLT = 0 ou 1 : renvoie l'écart non absorbé de la 1ère ou 2nde méthode de valo
#                PSUPP = O --> renvoie la valeur d'ordre
#                        V --> renvoie la valeur de valo (en fonction de LNUMVLT)
#            S : PNBMVT = nombre de mouvements actifs pour la ligne de doc
#                PQTY = Quantité physique
#                PQTYACT = Quantité active
#                PAMT() = Montant d'ordre
#                PDEV() = Ecart non absorbé
########################################################################
Subprog CALVALDOC(PFCY, PITM, PTYP, PNUM, PLIN, PCRESEQ, PNUMVLT, PSUPP, PNBMVT, PQTY, PQTYACT, PAMT, PDEV)
Value Char       PFCY
Value Char       PITM
Value Integer    PTYP
Value Char       PNUM
Value Integer    PLIN
Value Integer    PCRESEQ
Value Integer    PNUMVLT
Value Char       PSUPP
Variable Integer PNBMVT
Variable Decimal PQTY
Variable Decimal PQTYACT
Variable Decimal PAMT()
Variable Decimal PDEV()

Local Decimal LDEVAMT(dim(PDEV))
Local Date LIPT : Raz LIPT

Call CALVALDOC2(PFCY, PITM, LIPT, PTYP, PNUM, PLIN, PCRESEQ, PNUMVLT, PSUPP, PNBMVT, PQTY, PQTYACT, PAMT, PDEV, LDEVAMT)
End

Subprog CALVALDOC2(PFCY, PITM, PIPT, PTYP, PNUM, PLIN, PCRESEQ, PNUMVLT, PSUPP, PNBMVT, PQTY, PQTYACT, PAMT, PDEV, PDEVAMT)
Value Char       PFCY
Value Char       PITM
Value Date       PIPT
Value Integer    PTYP
Value Char       PNUM
Value Integer    PLIN
Value Integer    PCRESEQ
Value Integer    PNUMVLT
Value Char       PSUPP
Variable Integer PNBMVT
Variable Decimal PQTY
Variable Decimal PQTYACT
Variable Decimal PAMT()
Variable Decimal PDEV()
Variable Decimal PDEVAMT()

Raz PNBMVT, PQTY, PQTYACT, PAMT, PDEV
Local Char LFIL(250)

Columns [STJ] (PRINAT,AMTDEV, ACTQTY, VARORD, VARVAL, AMTDEV2, VARVAL2, REGFLG, QTYSTU,STOFCY,UPDCOD,ITMREF,IPTDAT,MVTSEQ,MVTIND,CREMVTDAT,TRSTYP)

LFIL="STOFCY=PFCY & ITMREF=PITM & VCRTYP=PTYP & VCRNUM=PNUM & VCRLIN=PLIN & UPDCOD=2"
If PCRESEQ>0
    LFIL+="&CREMVTSEQ=PCRESEQ"
Endif
If PIPT<>[0/0/0]
    LFIL+="&IPTDAT=PIPT"
Endif

# Issue 102112 - 2014-09-03 by CCC : VARVAL value is more reliable than PRINAT to know if the mvt has been created because of standard cost or not
## Issue 84744 - 2013-04-08 by CCC : Ne pas tenir compte des TRSTYP=35 sur coût standard
##For [STJ] reckey Where evalue(LFIL)
#For [STJ] reckey Where evalue(LFIL) & !(TRSTYP=35 & find(PRINAT,0,2,3))
For [STJ] reckey Where evalue(LFIL) & !(TRSTYP=35 & VARVAL<>0)
    PNBMVT  += ([F:STJ]REGFLG=1)
    PQTY    += [F:STJ]QTYSTU * ([F:STJ]REGFLG=1)
    PQTYACT += [F:STJ]ACTQTY * ([F:STJ]REGFLG=1)
    If instr(1,PSUPP,"V")
        If PNUMVLT=0
            PAMT    += [F:STJ]VARVAL
        Else
            PAMT    += [F:STJ]VARVAL2
        Endif
    Else
        PAMT    += [F:STJ]VARORD * ([F:STJ]TRSTYP<>35)
    Endif
    # Dans le cas d'un mouvement qui serait valorisé au coût standard, l'écart non absorbé n'est pas siginficatif lorsqu'on souhaite connaitre le montant d'ordre
    If instr(1,PSUPP,"V") | [F:STJ]PRINAT>3
        If PNUMVLT=0
            PDEVAMT += [F:STJ]AMTDEV * ([F:STJ]TRSTYP=35)
            PDEV    += [F:STJ]AMTDEV * ([F:STJ]TRSTYP<>35)
        Else
            PDEV    += [F:STJ]AMTDEV2
        Endif
    Endif
    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
        Read [F:SJV]SJV0 = [F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
        If !fstat
            I=1
            For J=0 To GACTMAT-1
                If instr(1,PSUPP,"V")
                    If PNUMVLT=0
                        PAMT(I) += [F:SJV]DVMATCST(J)
                    Else
                        PAMT(I) += [F:SJV]DV2MATCST(J)
                    Endif
                Else
                    PAMT(I) += [F:SJV]DOMATCST(J) * ([F:STJ]TRSTYP<>35)
                Endif
                If instr(1,PSUPP,"V") | [F:STJ]PRINAT>3
                    If PNUMVLT=0
                        PDEV(I) += [F:SJV]DEVMATCST(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVMATCST(J) * ([F:STJ]TRSTYP=35)
                    Else
                        PDEV(I) += [F:SJV]DEVMATCST2(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVMATCST2(J) * ([F:STJ]TRSTYP=35)
                    Endif
                Endif
                I+=1
            Next
            For J=0 To GACTMAC-1
                If instr(1,PSUPP,"V")
                    If PNUMVLT=0
                        PAMT(I) += [F:SJV]DVMACCST(J)
                    Else
                        PAMT(I) += [F:SJV]DV2MACCST(J)
                    Endif
                Else
                    PAMT(I) += [F:SJV]DOMACCST(J) * ([F:STJ]TRSTYP<>35)
                Endif
                If instr(1,PSUPP,"V") | [F:STJ]PRINAT>3
                    If PNUMVLT=0
                        PDEV(I) += [F:SJV]DEVMACCST(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVMACCST(J) * ([F:STJ]TRSTYP=35)
                    Else
                        PDEV(I) += [F:SJV]DEVMACCST2(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVMACCST2(J) * ([F:STJ]TRSTYP=35)
                    Endif
                Endif
                I+=1
            Next
            For J=0 To GACTLAB-1
                If instr(1,PSUPP,"V")
                    If PNUMVLT=0
                        PAMT(I) += [F:SJV]DVLABCST(J)
                    Else
                        PAMT(I) += [F:SJV]DVLABCST(J)
                    Endif
                Else
                    PAMT(I) += [F:SJV]DOLABCST(J) * ([F:STJ]TRSTYP<>35)
                Endif
                If instr(1,PSUPP,"V") | [F:STJ]PRINAT>3
                    If PNUMVLT=0
                        PDEV(I) += [F:SJV]DEVLABCST(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVLABCST(J) * ([F:STJ]TRSTYP=35)
                    Else
                        PDEV(I) += [F:SJV]DEVLABCST2(J) * ([F:STJ]TRSTYP<>35)
                        PDEVAMT(I) += [F:SJV]DEVLABCST2(J) * ([F:STJ]TRSTYP=35)
                    Endif
                Endif
                I+=1
            Next
            If instr(1,PSUPP,"V")
                If PNUMVLT=0
                    PAMT(I) += [F:SJV]DVSCOTOT
                    I+=1
                    PAMT(I) += [F:SJV]DVINVDTA
                    I+=1
                    PAMT(I) += [F:SJV]DVOVEMAT
                    I+=1
                    PAMT(I) += [F:SJV]DVOVEMAC
                    I+=1
                    PAMT(I) += [F:SJV]DVOVELAB
                    I+=1
                    PAMT(I) += [F:SJV]DVOVESCO
                Else
                    PAMT(I) += [F:SJV]DV2SCOTOT
                    I+=1
                    PAMT(I) += [F:SJV]DV2INVDTA
                    I+=1
                    PAMT(I) += [F:SJV]DV2OVEMAT
                    I+=1
                    PAMT(I) += [F:SJV]DV2OVEMAC
                    I+=1
                    PAMT(I) += [F:SJV]DV2OVELAB
                    I+=1
                    PAMT(I) += [F:SJV]DV2OVESCO
                Endif
            Else
                PAMT(I) += [F:SJV]DOSCOTOT * ([F:STJ]TRSTYP<>35)
                I+=1
                PAMT(I) += [F:SJV]DOINVDTA * ([F:STJ]TRSTYP<>35)
                I+=1
                PAMT(I) += [F:SJV]DOOVEMAT * ([F:STJ]TRSTYP<>35)
                I+=1
                PAMT(I) += [F:SJV]DOOVEMAC * ([F:STJ]TRSTYP<>35)
                I+=1
                PAMT(I) += [F:SJV]DOOVELAB * ([F:STJ]TRSTYP<>35)
                I+=1
                PAMT(I) += [F:SJV]DOOVESCO * ([F:STJ]TRSTYP<>35)
            Endif
            If instr(1,PSUPP,"V") | [F:STJ]PRINAT>3
                I-=5
                If PNUMVLT=0
                    PDEV(I) += [F:SJV]DEVSCOCST * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVSCOCST * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVINVDTA * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVINVDTA * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVEMAT * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVEMAT * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVEMAC * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVEMAC * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVELAB * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVELAB * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVESCO * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVESCO * ([F:STJ]TRSTYP=35)
                Else
                    PDEV(I) += [F:SJV]DEVSCOCST2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVSCOCST2 * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVINVDTA2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVINVDTA2 * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVEMAT2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVEMAT2 * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVEMAC2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVEMAC2 * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVELAB2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVELAB2 * ([F:STJ]TRSTYP=35)
                    I+=1
                    PDEV(I) += [F:SJV]DEVOVESCO2 * ([F:STJ]TRSTYP<>35)
                    PDEVAMT(I) += [F:SJV]DEVOVESCO2 * ([F:STJ]TRSTYP=35)
                Endif
            Endif
        Endif
    Endif

Next
Filter [STJ]
Columns [STJ]

End

########################################################################
# UPDSTJLIN : Met à jour les valeurs des mouvements d'une ligne de doc
# La classe [F:STJ2] doit être positionnée sur le premier mouvement à modifier et un filtre doit être actif
########################################################################
Funprog UPDSTJLIN(PFCY, PTYP, PNUM, PLIN, PIO, PNBMVT, PQTYLIN, PAMTLIN, PVARLIN, PDEVLIN, PVLTCOD, PNUMVLT, PAMTRND, PPRIRND)
Value Char    PFCY
Value Integer PTYP
Value Char    PNUM
Value Integer PLIN
Value Integer PIO
Value Integer PNBMVT
Value Decimal PQTYLIN
Value Decimal PAMTLIN
Value Decimal PVARLIN()
Value Decimal PDEVLIN()
Value Integer PVLTCOD
Value Integer PNUMVLT # FGR 01/02/2010 : X3SUIVI60986
Value Decimal PAMTRND, PPRIRND

End func UPDSTJLIN2(PFCY, PTYP, PNUM, PLIN, PIO, PNBMVT, PQTYLIN, PAMTLIN, PVARLIN, PDEVLIN, PVLTCOD, PNUMVLT, PAMTRND, PPRIRND, "")

Funprog UPDSTJLIN2(PFCY, PTYP, PNUM, PLIN, PIO, PNBMVT, PQTYLIN, PAMTLIN, PVARLIN, PDEVLIN, PVLTCOD, PNUMVLT, PAMTRND, PPRIRND, PSUP)
Value Char    PFCY
Value Integer PTYP
Value Char    PNUM
Value Integer PLIN
Value Integer PIO
Value Integer PNBMVT
Value Decimal PQTYLIN
Value Decimal PAMTLIN
Value Decimal PVARLIN()
Value Decimal PDEVLIN()
Value Integer PVLTCOD
Value Integer PNUMVLT # FGR 01/02/2010 : X3SUIVI60986
Value Decimal PAMTRND, PPRIRND
Value Char    PSUP

Local Integer LSTOP : Raz LSTOP
Local Decimal LCUMVAR(dim(PVARLIN)), LCUMDEV(dim(PDEVLIN))
Local Integer LVLTCOD : LVLTCOD=PVLTCOD    # Nécessaire dans ISSADJ_MVTNEW
Local Integer LNUMVLT : LNUMVLT=PNUMVLT    # Nécessaire dans ISSADJ_MVTNEW
Local Decimal LDELTA(dim(PVARLIN)), LAMTDEV(dim(PDEVLIN))
Local Integer I, J, LRET, LNB : Raz LNB
Local Integer LMVTSEQ, LIO
Local Integer LCREMVTSEQ  # 118579.n - Issue where VCRNUM, VCRTYP and VCRLIN not enough.  Also check for CREMVTSEQ
Local Integer LMVTUPD
Local Decimal LMVTVAL(dim(PVARLIN))

Call ECRTRACE("UPDSTJLIN2(PFCY, PTYP, PNUM, PLIN, PIO, PNBMVT, PQTYLIN, PAMTLIN, PVARLIN, PDEVLIN, PVLTCOD, PNUMVLT, PAMTRND, PPRIRND, PSUP)",0)
Call ECRTRACE("UPDSTJLIN2("+PFCY+", "+num$(PTYP)+", "+num$(PNUM)+", "+num$(PLIN)+", "+num$(PIO)+", "+num$(PNBMVT)+", "+num$(PQTYLIN)
&            +", "+num$(PAMTLIN)+", "+num$(PVARLIN)+", "+num$(PDEVLIN)+", "+num$(PVLTCOD)+", "+num$(PNUMVLT)+", "+num$(PAMTRND)+", "+num$(PPRIRND)+", '"+PSUP+"')",0)

LIO = PIO    # 1=Entrée 2=Sortie

Raz fstat

#118579.n - Initialize CREMVTSEQ value - we know that we are no longer on a related record when this value changes.
#           Used when same VCRTYP can have multiple TRSTYP
[L]LCREMVTSEQ=[F:STJ2]CREMVTSEQ

While !fstat & GOK & LNB<PNBMVT

    # 118579.n - added CREMVTSEQ to this check
    If [F:STJ2]MVTSEQ<=LMVTSEQ | [F:STJ2]STOFCY<>PFCY | [F:STJ2]VCRNUM<>PNUM | [F:STJ2]VCRLIN<>PLIN | [F:STJ2]VCRTYP<>PTYP | [F:STJ2]CREMVTSEQ<>LCREMVTSEQ
        If instr(1,PSUP,"L")
            Read [SJL]SJL0 Prev
            Gosub READ_STJ2 From TRTADJALC
            Break
        Else
            Read [SJA]SJA0 Prev
            #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
            Gosub READ_STJ2 From TRTADJAVC
            Break
        Endif
    Endif
    If GACTDECCST & [F:STJ2]CREMVTDAT>=GDATDECCST
        Raz [F:SJV2]
        Read [SJV2]SJV0=[F:STJ2]STOFCY;[F:STJ2]UPDCOD;[F:STJ2]ITMREF;[F:STJ2]IPTDAT;[F:STJ2]MVTSEQ;[F:STJ2]MVTIND
        If fstat & GADONIX<>2
            [F:SJV2]=[F:STJ2]
            Call FSTA("SJV2") From GLOCK
            Raz GOK
            Break
        Endif
    Endif

    If PQTYLIN<>0
        For I=0 To dim(LAMTDEV)-1
            LAMTDEV(I) = arr(PDEVLIN(I)*[F:STJ2]ACTQTY/PQTYLIN,PAMTRND)
            LDELTA(I)  = arr(PVARLIN(I)*[F:STJ2]ACTQTY/PQTYLIN,PAMTRND)
        Next
    Elsif PAMTLIN<>0
        For I=0 To dim(LAMTDEV)-1
            LAMTDEV(I) = arr(PDEVLIN(I)*[F:STJ2]AMTORD/PAMTLIN,PAMTRND)
            LDELTA(I)  = arr(PVARLIN(I)*[F:STJ2]AMTORD/PAMTLIN,PAMTRND)
        Next
    Else
        For I=0 To dim(LAMTDEV)-1
            LAMTDEV(I) = arr(PDEVLIN(I)/PNBMVT,PAMTRND)
            LDELTA(I)  = arr(PVARLIN(I)/PNBMVT,PAMTRND)
        Next
    Endif

    If [F:STJ2]AGGIFAFLG=2 | [F:TCM]PRIREGS<>2
        Gosub ISSADJ_MVTINV
        If LMVTSEQ=0
            LMVTSEQ = [F:STJ]MVTSEQ
        Endif
        Gosub ISSADJ_MVTNEW
        If !GOK
            Break
        Endif

        LCUMVAR(0)+=[F:STJ]VARORD
        LCUMDEV(0)+=[F:STJ]AMTDEV

        LMVTUPD=0
    Else
        Gosub ISSADJ_MVTUPD

        LCUMVAR(0)+=[F:STJ]VARORD-[F:STJ2]VARORD
        LCUMDEV(0)+=[F:STJ]AMTDEV-[F:STJ2]AMTDEV

        LMVTUPD=1
    Endif

    If GACTDECCST
        I=1
        For J=0 To GACTMAT-1
            LCUMVAR(I) += [F:SJV]DOMATCST(J)-LMVTUPD*[F:SJV2]DOMATCST(J)
            LCUMDEV(I) += [F:SJV]DEVMATCST(J)-LMVTUPD*[F:SJV2]DEVMATCST(J)
            I+=1
        Next
        For J=0 To GACTMAC-1
            LCUMVAR(I) += [F:SJV]DOMACCST(J)-LMVTUPD*[F:SJV2]DOMACCST(J)
            LCUMDEV(I) += [F:SJV]DEVMACCST(J)-LMVTUPD*[F:SJV2]DEVMACCST(J)
            I+=1
        Next
        For J=0 To GACTLAB-1
            LCUMVAR(I) += [F:SJV]DOLABCST(J)-LMVTUPD*[F:SJV2]DOLABCST(J)
            LCUMDEV(I) += [F:SJV]DEVLABCST(J)-LMVTUPD*[F:SJV2]DEVLABCST(J)
            I+=1
        Next
        LCUMVAR(I) += [F:SJV]DOSCOTOT-LMVTUPD*[F:SJV2]DOSCOTOT
        LCUMDEV(I) += [F:SJV]DEVSCOCST-LMVTUPD*[F:SJV2]DEVSCOCST
        I+=1
        LCUMVAR(I) += [F:SJV]DOINVDTA-LMVTUPD*[F:SJV2]DOINVDTA
        LCUMDEV(I) += [F:SJV]DEVINVDTA-LMVTUPD*[F:SJV2]DEVINVDTA
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVEMAT-LMVTUPD*[F:SJV2]DOOVEMAT
        LCUMDEV(I) += [F:SJV]DEVOVEMAT-LMVTUPD*[F:SJV2]DEVOVEMAT
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVEMAC-LMVTUPD*[F:SJV2]DOOVEMAC
        LCUMDEV(I) += [F:SJV]DEVOVEMAC-LMVTUPD*[F:SJV2]DEVOVEMAC
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVELAB-LMVTUPD*[F:SJV2]DOOVELAB
        LCUMDEV(I) += [F:SJV]DEVOVELAB-LMVTUPD*[F:SJV2]DEVOVELAB
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVESCO-LMVTUPD*[F:SJV2]DOOVESCO
        LCUMDEV(I) += [F:SJV]DEVOVESCO-LMVTUPD*[F:SJV2]DEVOVESCO
    Endif

    LNB+=1

    If LNB<PNBMVT
        If instr(1,PSUP,"L")
            Read [SJL]SJL0 Next
            If !fstat
                Gosub READ_STJ2 From TRTADJALC
            Endif
        Else
            Read [SJA]SJA0 Next
            If !fstat
                #Read [STJ2]STJ0=[F:SJA]STOFCY;[F:SJA]UPDCOD;[F:SJA]ITMREF;[F:SJA]IPTDAT;[F:SJA]MVTSEQ;[F:SJA]MVTIND
                Gosub READ_STJ2 From TRTADJAVC
            Endif
        Endif
    Else
        Break
    Endif
Wend
# Si la ligne de doc n'existe plus (à été supprimée entièrement),
# on crée un mouvement nul en quantité contenant juste le montant
If LNB = 0 & GOK
    Filter [STJ] Where STOFCY = PFCY
&                    & ITMREF = [F:SJA]ITMREF
&                    & VCRTYP = PTYP
&                    & VCRNUM = PNUM
&                    & VCRLIN = PLIN
&                    & REGFLG = 2
&                    & !find(PRINAT,0,2,3)
    Read [STJ]STJ0 First
    Filter [STJ]
    [F:STJ2] = [F:STJ]    # !!! Ne pas écraser le filtre de STJ2 !!!

    [F:STJ2]TRSTYP=35   # Issue 71240 - 2012-04-04 by CCC : comment
    # Issue 91859 - 2016-07-14 by ERMIL : Do not use an auto journal if the source document did not have an auto journal
    If [F:STJ2]ENTCOD <> ""
#      [F:STJ2]ENTCOD = "STKUV"     # Issue 84400 - 2012-09-11 by CCC
      Call PARAM(PFCY,"ACCCSTADJ",[F:STJ]ENTCOD) From ADOVAL # Issue 91856 - 2016-07-18 MJH : Allow the user to define the Automatic journal code through a parameter
    Endif

    For I=0 To dim(LAMTDEV)-1
        LDELTA(I) = PVARLIN(I)
        LAMTDEV(I)= PDEVLIN(I)
    Next
    # On prépare la classe [F:STJ2] sur laquelle va s'appuyer l'écriture du nouveau mouvement
    Raz [F:STJ2]ACTQTY,[F:STJ2]QTYSTU,[F:STJ2]QTYPCU
    Raz [F:STJ2]AMTORD,[F:STJ2]AMTVAL,[F:STJ2]VARORD,[F:STJ2]VARVAL,[F:STJ2]AMTDEV
    Raz [F:STJ2]PRINAT    # Cela permet de distinguer les vrais mouvements d'annulation avec prix=0 des mouvements d'annulations dus à la régul
    Raz [F:STJ2]AMTVAL2,[F:STJ2]VARVAL2,[F:STJ2]AMTDEV2
    Raz [F:STJ2]PRINAT2    # Cela permet de distinguer les vrais mouvements d'annulation avec prix=0 des mouvements d'annulations dus à la régul
    Raz [F:STJ2]STA,[F:STJ2]LOT,[F:STJ2]SLO,[F:STJ2]SERNUM,[F:STJ2]LOC,[F:STJ2]PALNUM,[F:STJ2]CTRNUM
    Raz [F:STJ2]USRFLD1,[F:STJ2]USRFLD2,[F:STJ2]USRFLD3,[F:STJ2]USRFLD4
    Raz [F:STJ2]STOFLD1,[F:STJ2]STOFLD2
    Raz [F:STJ2]ECCVALMAJ, [F:STJ2]ECCVALMIN

    If GACTDECCST
        Raz [F:SJV2]
    Endif

    Gosub ISSADJ_MVTNEW

    LCUMVAR(0) += [F:STJ]VARORD
    LCUMDEV(0) += [F:STJ]AMTDEV
    If GACTDECCST
        I=1
        For J=0 To GACTMAT-1
            LCUMVAR(I) += [F:SJV]DOMATCST(J)
            LCUMDEV(I) += [F:SJV]DEVMATCST(J)
            I+=1
        Next
        For J=0 To GACTMAC-1
            LCUMVAR(I) += [F:SJV]DOMACCST(J)
            LCUMDEV(I) += [F:SJV]DEVMACCST(J)
            I+=1
        Next
        For J=0 To GACTLAB-1
            LCUMVAR(I) += [F:SJV]DOLABCST(J)
            LCUMDEV(I) += [F:SJV]DEVLABCST(J)
            I+=1
        Next
        LCUMVAR(I) += [F:SJV]DOSCOTOT
        LCUMDEV(I) += [F:SJV]DEVSCOCST
        I+=1
        LCUMVAR(I) += [F:SJV]DOINVDTA
        LCUMDEV(I) += [F:SJV]DEVINVDTA
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVEMAT
        LCUMDEV(I) += [F:SJV]DEVOVEMAT
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVEMAC
        LCUMDEV(I) += [F:SJV]DEVOVEMAC
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVELAB
        LCUMDEV(I) += [F:SJV]DEVOVELAB
        I+=1
        LCUMVAR(I) += [F:SJV]DOOVESCO
        LCUMDEV(I) += [F:SJV]DEVOVESCO
    Endif

    LNB += 1
Endif

If GOK & sigma(0,dim(LCUMDEV)-1,abs(LCUMDEV(indcum))) <> sigma(0,dim(PDEVLIN)-1,abs(PDEVLIN(indcum)))
    If PNUMVLT=0
        [F:STJ]AMTORD+= PVARLIN(0)-LCUMVAR(0)
        [F:STJ]VARORD+= PVARLIN(0)-LCUMVAR(0)
        [F:STJ]AMTVAL+= PVARLIN(0)-LCUMVAR(0)
        [F:STJ]VARVAL+= PVARLIN(0)-LCUMVAR(0)
        [F:STJ]AMTDEV+= PDEVLIN(0)-LCUMDEV(0)
        Rewrite [STJ]
        If GACTDECCST & [F:SJV]ITMREF<>""    # On s'assure que l'enreg SJV a bien été lu précédemment. Si ce n'est pas le cas, c'est qu'on n'a pas besoin d'en mettre un à jour
            Read [SJV] Curr
            I=1
            For J=0 To GACTMAT-1
                [F:SJV]OMATCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DOMATCST(J)+= PVARLIN(I)-LCUMVAR(I)
                If LIO=2 | [F:STJ]PRINAT=8
                    [F:SJV]VMATCST(J) += PVARLIN(I)-LCUMVAR(I)
                    [F:SJV]DVMATCST(J)+= PVARLIN(I)-LCUMVAR(I)
                Else
                    Raz [F:SJV]DVMATCST
                Endif
                [F:SJV]DEVMATCST(J) += PDEVLIN(I)-LCUMDEV(I)

                I+=1
            Next
            [F:SJV]OMATTOT = sum([F:SJV]OMATCST)
            [F:SJV]DOMATTOT = sum([F:SJV]DOMATCST)
            [F:SJV]VMATTOT = sum([F:SJV]VMATCST)
            [F:SJV]DVMATTOT = sum([F:SJV]DVMATCST)

            For J=0 To GACTMAC-1
                [F:SJV]OMACCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DOMACCST(J)+= PVARLIN(I)-LCUMVAR(I)
                If LIO=2 | [F:STJ]PRINAT=8
                    [F:SJV]VMACCST(J) += PVARLIN(I)-LCUMVAR(I)
                    [F:SJV]DVMACCST(J)+= PVARLIN(I)-LCUMVAR(I)
                Else
                    Raz [F:SJV]DVMACCST
                Endif
                [F:SJV]DEVMACCST(J) += PDEVLIN(I)-LCUMDEV(I)

                I+=1
            Next

            [F:SJV]OMACTOT = sum([F:SJV]OMACCST)
            [F:SJV]DOMACTOT = sum([F:SJV]DOMACCST)
            [F:SJV]VMACTOT = sum([F:SJV]VMACCST)
            [F:SJV]DVMACTOT = sum([F:SJV]DVMACCST)

            For J=0 To GACTLAB-1
                [F:SJV]OLABCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DOLABCST(J)+= PVARLIN(I)-LCUMVAR(I)
                If LIO=2 | [F:STJ]PRINAT=8
                    [F:SJV]VLABCST(J) += PVARLIN(I)-LCUMVAR(I)
                    [F:SJV]DVLABCST(J)+= PVARLIN(I)-LCUMVAR(I)
                Else
                    Raz [F:SJV]DVLABCST
                Endif

                [F:SJV]DEVLABCST(J) += PDEVLIN(I)-LCUMDEV(I)

                I+=1
            Next

            [F:SJV]OLABTOT = sum([F:SJV]OLABCST)
            [F:SJV]DOLABTOT = sum([F:SJV]DOLABCST)
            [F:SJV]VLABTOT = sum([F:SJV]VLABCST)
            [F:SJV]DVLABTOT = sum([F:SJV]DVLABCST)

            [F:SJV]OSCOTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOSCOTOT+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VSCOTOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVSCOTOT+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVSCOCST += PDEVLIN(I)-LCUMDEV(I)

            I+=1

            [F:SJV]OINVDTATOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOINVDTA+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VINVDTATOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVINVDTA+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVINVDTA += PDEVLIN(I)-LCUMDEV(I)

            I+=1

            [F:SJV]OOVEMATTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOOVEMAT+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VOVEMATTOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVOVEMAT+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVOVEMAT += PDEVLIN(I)-LCUMDEV(I)

            I+=1

            [F:SJV]OOVEMACTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOOVEMAC+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VOVEMACTOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVOVEMAC+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVOVEMAC += PDEVLIN(I)-LCUMDEV(I)

            I+=1

            [F:SJV]OOVELABTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOOVELAB+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VOVELABTOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVOVELAB+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVOVELAB += PDEVLIN(I)-LCUMDEV(I)

            I+=1

            [F:SJV]OOVESCOTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DOOVESCO+= PVARLIN(I)-LCUMVAR(I)
            If LIO=2 | [F:STJ]PRINAT=8
                [F:SJV]VOVESCOTOT += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DVOVESCO+= PVARLIN(I)-LCUMVAR(I)
            Endif

            [F:SJV]DEVOVESCO += PDEVLIN(I)-LCUMDEV(I)

            Rewrite [SJV]
            If fstat
                Call FSTA("SJV") From GLOCK
                Raz GOK
            Endif
        Endif
    Elsif GACTVLT2 & GACTDECCST & [F:SJV]ITMREF<>""    # On s'assure que l'enreg SJV a bien été lu précédemment. Si ce n'est pas le cas, c'est qu'on n'a pas besoin d'en mettre un à jour
        Read [SJV] Curr
        I=1
        For J=0 To GACTMAT-1
            If LIO=2 | [F:STJ]PRINAT2=8
                [F:SJV]V2MATCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DV2MATCST(J)+= PVARLIN(I)-LCUMVAR(I)
            Else
                Raz [F:SJV]DV2MATCST
            Endif
            [F:SJV]DEVMATCST2(J) += PDEVLIN(I)-LCUMDEV(I)

            I+=1
        Next
        [F:SJV]V2MATTOT = sum([F:SJV]V2MATCST)
        [F:SJV]DV2MATTOT = sum([F:SJV]DV2MATCST)

        For J=0 To GACTMAC-1
            If LIO=2 | [F:STJ]PRINAT2=8
                [F:SJV]V2MACCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DV2MACCST(J)+= PVARLIN(I)-LCUMVAR(I)
            Else
                Raz [F:SJV]DV2MACCST
            Endif
            [F:SJV]DEVMACCST2(J) += PDEVLIN(I)-LCUMDEV(I)

            I+=1
        Next

        [F:SJV]V2MACTOT = sum([F:SJV]V2MACCST)
        [F:SJV]DV2MACTOT = sum([F:SJV]DV2MACCST)

        For J=0 To GACTLAB-1
            If LIO=2 | [F:STJ]PRINAT2=8
                [F:SJV]V2LABCST(J) += PVARLIN(I)-LCUMVAR(I)
                [F:SJV]DV2LABCST(J)+= PVARLIN(I)-LCUMVAR(I)
            Else
                Raz [F:SJV]DV2LABCST
            Endif

            [F:SJV]DEVLABCST2(J) += PDEVLIN(I)-LCUMDEV(I)

            I+=1
        Next

        [F:SJV]V2LABTOT = sum([F:SJV]V2LABCST)
        [F:SJV]DV2LABTOT = sum([F:SJV]DV2LABCST)

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2SCOTOT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2SCOTOT+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2SCOTOT
        Endif

        [F:SJV]DEVSCOCST2 += PDEVLIN(I)-LCUMDEV(I)

        I+=1

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2INVDTA += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2INVDTA+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2INVDTA
        Endif

        [F:SJV]DEVINVDTA2 += PDEVLIN(I)-LCUMDEV(I)

        I+=1

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2OVEMAT += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2OVEMAT+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2OVEMAT
        Endif

        [F:SJV]DEVOVEMAT2 += PDEVLIN(I)-LCUMDEV(I)

        I+=1

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2OVEMAC += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2OVEMAC+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2OVEMAC
        Endif

        [F:SJV]DEVOVEMAC2 += PDEVLIN(I)-LCUMDEV(I)

        I+=1

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2OVELAB += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2OVELAB+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2OVELAB
        Endif

        [F:SJV]DEVOVELAB2 += PDEVLIN(I)-LCUMDEV(I)

        I+=1

        If LIO=2 | [F:STJ]PRINAT2=8
            [F:SJV]V2OVESCO += PVARLIN(I)-LCUMVAR(I)
            [F:SJV]DV2OVESCO+= PVARLIN(I)-LCUMVAR(I)
        Else
            Raz [F:SJV]DV2OVESCO
        Endif

        [F:SJV]DEVOVESCO2 += PDEVLIN(I)-LCUMDEV(I)

        Rewrite [SJV]
        If fstat
            Call FSTA("SJV") From GLOCK
            Raz GOK
        Endif
  Endif
Endif

End LNB

########################################################################
Subprog UPDITH(PNUMVLT,PITM,PFCY,PIPT,PAMTRCP,PAMTISS,PDEV)
Value    Integer PNUMVLT
Value    Char    PITM
Value    Char    PFCY
Value    Date    PIPT
Variable Decimal PAMTRCP
Variable Decimal PAMTISS
Variable Decimal PDEV

If PAMTRCP=0 & PAMTISS=0 & PDEV=0
    End
Endif

Local Decimal LEXE, LPER
Local Integer LCRE

If !clalev([F:PER]) : Local File PERIOD    [PER] : Endif
If !clalev([F:ITH]) : Local File ITMMVTHIS [ITH] : Endif

#1- Rechercher la période
Raz LEXE, LPER
Call GETITH(PITM,PFCY,PIPT,0,LCRE) From STKLIB
LEXE = [F:ITH]FIYNUM

#2- Mettre à jour ITH
If PNUMVLT=0
    [F:ITH]YEARCPAMT += PAMTRCP
    [F:ITH]MONRCPAMT += PAMTRCP
    [F:ITH]YEAISSAMT += PAMTISS
    [F:ITH]MONISSAMT += PAMTISS
    [F:ITH]AMTDEV += PDEV
Else
    [F:ITH]AMTDEV2 += PDEV
Endif
Call REWITH From STKLIB
If fstat
    Call RSTA("ITH",PITM-PFCY-[F:PER]PERSTR) From GLOCK
    GOK = 0
    End
Endif
Call ECRTRACE("Update ITMMVTHIS: ITMREF="+PITM-"STOFCY="+PFCY-"PERSTR="+[F:PER]PERSTR,0)
If PNUMVLT=0
    Call ECRTRACE("[F:ITH]YEARCPAMT += "+num$(PAMTRCP)-"("+num$([F:ITH]YEARCPAMT)+")",0)
    Call ECRTRACE("[F:ITH]MONRCPAMT += "+num$(PAMTRCP)-"("+num$([F:ITH]MONRCPAMT)+")",0)
    Call ECRTRACE("[F:ITH]YEAISSAMT += "+num$(PAMTISS)-"("+num$([F:ITH]YEAISSAMT)+")",0)
    Call ECRTRACE("[F:ITH]MONISSAMT += "+num$(PAMTISS)-"("+num$([F:ITH]MONISSAMT)+")",0)
    Call ECRTRACE("[F:ITH]AMTDEV += "+num$(PDEV)-"("+num$([F:ITH]AMTDEV)+")",0)
    Update [ITH] Where ITMREF=PITM
&                    & STOFCY=PFCY
&                    & FIYNUM=LEXE
&                    & PERSTR>[F:PER]PERSTR
&                With  YEARCPAMT+=PAMTRCP,
&                    YEAISSAMT+=PAMTISS
    If fstat
        Call RSTA("ITH",PITM-PFCY-[F:PER]PERSTR) From GLOCK
        GOK = 0
        End
    Endif
Else
    Call ECRTRACE("[F:ITH]AMTDEV2 += "+num$(PDEV)-"("+num$([F:ITH]AMTDEV2)+")",0)
Endif


If GOK
    PDEV = 0
    PAMTRCP = 0
    PAMTISS = 0
Endif

End

########################################################################
# Met à jour la marge d'une livraison et/ou d'une facture
#
# La table [F:STJ2] doit être positionnée sur un mouvement de la livraison
########################################################################
Subprog UPDPFM(PQTYACTFCY, PAMTFCY, PAVCFCY, PDELTA)
Value    Decimal PQTYACTFCY
Value    Decimal PAMTFCY
Value    Decimal PAVCFCY
Value    Decimal PDELTA

Local Decimal LTMPAMT, LTMPQTY, LTMPAVC
Local Char    LMES(250), LTXT(250)
Local Integer LRET
Local Char    LTCM(GLONTCM)

# Issue 99366 - 2014-06-10 by CCC
Call GETDEV([F:STJ2]STOFCY) From DEVSUB

    #---- On écrit temporairement dans la classe [F:ITV] qui va être utilisée pour le calcul de marge
    LTMPAMT = [F:ITV]AVCBASAMT
    LTMPQTY = [F:ITV]AVCBASQTY
    LTMPAVC = [F:ITV]AVC
    [F:ITV]AVCBASAMT = PAMTFCY
    [F:ITV]AVCBASQTY = PQTYACTFCY
    [F:ITV]AVC       = PAVCFCY
    If [F:STJ2]VCRTYP=4     # On peut avoir des factures avec mvt de stock => une ligne de livraison n'existe pas forcément
        Read [SDD]SDD0=[F:STJ2]VCRNUM;[STJ2]VCRLIN
        If fstat
            Call ECRTRACE(mess(239,192,1)-":"-[F:STJ2]VCRNUM+";"+num$([F:STJ2]VCRLIN),1) From FUNSADJB
        Else
            Call GETTCM([F:STJ2]ITMREF, [F:STJ2]STOFCY, LTCM, LRET) From STKVAL
            Read [SDH]SDH0 = [F:SDD]SDHNUM
            If !fstat
                # Issue 66578 - 2010-08-18 by CCC : Si la marge est calculée avec la valeur FIFO,
                #     c'est le delta de la ligne de doc qui est utilisé pour la màj de la marge
                Case [F:TCM]PFMCLCBAS
                    When 4 : Gosub MARGE_LIV
                    When 5,8 : Gosub MARGE_LIV_DELTA
                    When 6 : Gosub MARGE_LIV_DELTA
                Endcase

                Rewrite [SDD]
                Call TEXTE (13371,LTXT) From OBJDIV    # Calcul de la marge
                LMES+= mess(4,701,1)-LTXT+" --> "+num$([F:SDD]PFM)
                Call ECRTRACE(LMES,0)
            Endif
        Endif
#        Filter [SID] Where SDHNUM=[F:STJ2]VCRNUM
#&                        & SDDLIN=[F:STJ2]VCRLIN
#        Read [SID] First
        Filter [SID]
        Read [SID]SID3=[F:STJ2]VCRNUM;[F:STJ2]VCRLIN
    Elsif [F:STJ2]VCRTYP=5
        Read [SID]SID0=[F:STJ2]VCRNUM;[STJ2]VCRLIN
        If fstat
            Call ECRTRACE(mess(7,119,1)-":"-[F:STJ2]VCRNUM+";"+num$([F:STJ2]VCRLIN),1) From FUNSADJB
        Endif
    Endif
    If !fstat
        Read [SIV]SIV0=[F:SID]NUM
        If fstat
            Call ECRTRACE(mess(7,119,1)-":"-[F:SID]NUM,1) From FUNSADJB
        Else
            # Issue 66578 - 2010-08-18 by CCC : Si la marge est calculée avec la valeur FIFO,
            #     c'est le delta de la ligne de doc qui est utilisé pour la màj de la marge
            Case [F:TCM]PFMCLCBAS
                When 4 : Gosub MARGE From TRTVENFAC
                When 5,8 : Gosub MARGE_FAC_DELTA
                When 6 : Gosub MARGE_FAC_DELTA
            Endcase
            Rewrite [SID]
            If fstat
                Call RSTA("SID",[F:STJ2]VCRNUM+";"+num$([F:STJ2]VCRLIN)) From GLOCK
            Else
                Call TEXTE (13371,LTXT) From OBJDIV    # Calcul de la marge
                LMES+= mess(5,701,1)-LTXT+" --> "+num$([F:SID]PFM)
                Call ECRTRACE(LMES,0)
            Endif
        Endif
    Endif
    #---- On remet [ITV] comme avant -----#
    [F:ITV]AVCBASAMT = LTMPAMT
    [F:ITV]AVCBASQTY = LTMPQTY
    [F:ITV]AVC       = LTMPAVC
End

# Bug 80451 : PE CALPFM1 non appelé
########################################################################
#$MARGE_LIV
#Local Decimal COUTHT, COUTHTC, COEF, WQTY
#Local Integer LOK, WNATPRI, STAT
#
## Pas de calcul de marge pour les gratuits
#If [F:SDD]NETPRI = 0 & [F:SDD]FOCFLG = 3 Return Endif
#
## Récupération du coef de conversion UV en US pour calcul de la marge
#
#WQTY = [F:SDD]QTYSTU
## Calcul prix revient
#Call DEFCPR ([F:SDD]ITMREF,[F:SDH]STOFCY,0,"",0,0,[F:SDH]SHIDAT,WQTY,
#&            COUTHT,LOK) From STKVAL
#If LOK <> 0
##       Pas de récup du prix de revient donc pas de recalcul de la marge
#    Return
#Else
#    # Si devise document <> devise base calcul marge (société du site expé)
#    If [F:SDH]CUR <> GLOCALDEV & COUTHT <> 0
#        Call CONVERT (GLOCALDEV,[F:SDH]CUR,GLOCALDEV,[F:SDH]CHGTYP,
#&                     [F:SDH]SHIDAT,COUTHT,COUTHTC,STAT) From TRTDEV
#        COUTHT=COUTHTC
#    Endif
## CCC (09/02/09) Bug 52249 : Si le prix est passé à 0 il faut en tenir compte
##    # Si Prix de revient récupéré à 0 : S'il était renseigné on ne fait rien
##    If COUTHT = 0 & [F:SDD]CPRPRI <> 0
##        Return
##    Else
#        # Le prix de revient est exprimé en US : Le convertir en UV
#        COUTHT=COUTHT*[F:SDD]SAUSTUCOE
##    Endif
#Endif
#
#Gosub CALSPEPFM From TRTVENPRI
#[F:SDD]CPRPRI=arr(COUTHT,10^-GDECPRI)
## --> Calcul de la marge
#[F:SDD]PFM = [F:SDD]NETPRINOT - [F:SDD]CPRPRI
#Return
########################################################################
$MARGE_LIV
Local Decimal COUTHT, COUTHTC, COEF, WQTY
Local Integer LOK, WNATPRI, STAT
Local Decimal XCRPPRI, XPFM
Local Decimal PHTNET                       : # 95792 : Variable inexistante dans PE CALPFM

# Pas de calcul de marge pour les gratuits
If [F:SDD]NETPRI = 0 & [F:SDD]FOCFLG = 3 Return Endif

If [F:ITM]ITMREF <> [F:SDD]ITMREF
    Read [F:ITM]ITM0 = [F:SDD]ITMREF
    If fstat  Raz [F:ITM] : Endif
Endif

# Récupération du coef de conversion UV en US pour calcul de la marge
XCPRPRI  = [F:SDD]CPRPRI
XPFM     = [F:SDD]PFM
PHTNET   = [F:SDD]NETPRINOT       : # 95792 : Variable inexistante dans PE CALPFM

WQTY = [F:SDD]QTYSTU
# Calcul prix revient
Call DEFCPR ([F:SDD]ITMREF,[F:SDH]STOFCY,0,"",0,0,[F:SDH]SHIDAT,WQTY,
&            COUTHT,LOK) From STKVAL
If LOK = 0
    # Si devise document <> devise base calcul marge (société du site expé)
    If [F:SDH]CUR <> GLOCALDEV & COUTHT <> 0
        # Issue X3-98052
        # No rounding, to be consistent with what is done in TRTVENPRI
#        Call CONVERT (GLOCALDEV,[F:SDH]CUR,GLOCALDEV,[F:SDH]CHGTYP,
#&                     [F:SDH]SHIDAT,COUTHT,COUTHTC,STAT) From TRTDEV
        Call CONVERT2 (GLOCALDEV,[F:SDH]CUR,GLOCALDEV,[F:SDH]CHGTYP,
&                     [F:SDH]SHIDAT,COUTHT,COUTHTC,STAT) From TRTDEV
        # End issue X3-98052
        COUTHT=COUTHTC
    Endif
# CCC (09/02/09) Bug 52249 : Si le prix est passé à 0 il faut en tenir compte
#    # Si Prix de revient récupéré à 0 : S'il était renseigné on ne fait rien
#    If COUTHT = 0 & [F:SDD]CPRPRI <> 0
#        Return
#    Else
    # Le prix de revient est exprimé en US : Le convertir en UV
    COUTHT=COUTHT*[F:SDD]SAUSTUCOE

    #  Point d'entree calcul d'un cout supplémentaire pour le calcul de la marge
    Gosub CALSPEPFM From TRTVENPRI

    If GSALRND = 2
        Call ARRDEV(COUTHT,[F:SDH]CUR) From TRTDIV
        XCPRPRI=COUTHT
    Else
        XCPRPRI=arr(COUTHT,10^-GDECPRI)
    Endif

    # Pas de calcul de marge pour les gratuits
    If [F:SDD]NETPRI<>0 | [F:SDD]FOCFLG<>3
        # Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
        If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & [F:SDD]NETPRINOT<>0)
            # --> Calcul de la marge
            XPFM = [F:SDD]NETPRINOT - XCPRPRI
        Endif
    Endif
#    Endif
Endif

# Point d'entree pour recalcul de la marge
Gosub CALSPEPFM1 From TRTVENPRI

[F:SDD]CPRPRI= XCPRPRI
[F:SDD]PFM   = XPFM

Return
# Bug 80451

##########################################################################
$MARGE_LIV_DELTA
Local Decimal COUTHT, COUTHTC
Local Integer STAT

    COUTHT = PDELTA
    If [F:SDH]CUR <> GLOCALDEV & COUTHT <> 0
        # Issue X3-98052
        # No rounding, to be consistent with what is done in TRTVENPRI
#        Call CONVERT (GLOCALDEV,[F:SDH]CUR,GLOCALDEV,[F:SDH]CHGTYP,
#&                                         [F:SDH]SHIDAT,COUTHT,COUTHTC,STAT) From TRTDEV
        Call CONVERT2 (GLOCALDEV,[F:SDH]CUR,GLOCALDEV,[F:SDH]CHGTYP,
&                                         [F:SDH]SHIDAT,COUTHT,COUTHTC,STAT) From TRTDEV
        # End issue X3-98052
        COUTHT = COUTHTC
    Endif
    # Le prix de revient est exprimé en US : Le convertir en UV
    COUTHT=COUTHT*[F:SDD]SAUSTUCOE
    [F:SDD]CPRPRI+=arr(COUTHT,10^-GDECPRI)
    # --> Calcul de la marge
    [F:SDD]PFM = [F:SDD]NETPRINOT - [F:SDD]CPRPRI
Return

##########################################################################
$MARGE_FAC_DELTA
Local Decimal COUTHT, COUTHTC
Local Integer STAT

    If [F:ITM]ITMREF <> [F:SID]ITMREF
        Read [F:ITM]ITM0 = [F:SID]ITMREF
        If fstat  Raz [F:ITM] : Endif
    Endif
    COUTHT = PDELTA
    If [F:SIV]CUR <> GLOCALDEV & COUTHT <> 0
        # Issue X3-98052
        # No rounding, to be consistent with what is done in TRTVENPRI
#        Call CONVERT (GLOCALDEV, [F:SIV]CUR, GLOCALDEV, [F:SIH]CURTYP, [F:SIV]INVDAT, COUTHT, COUTHTC, STAT) From TRTDEV
        Call CONVERT2 (GLOCALDEV, [F:SIV]CUR, GLOCALDEV, [F:SIH]CURTYP, [F:SIV]INVDAT, COUTHT, COUTHTC, STAT) From TRTDEV
        # End issue X3-98052
        COUTHT = COUTHTC
    Endif
    # Le prix de revient est exprimé en US : Le convertir en UV
    COUTHT=COUTHT*[F:SDD]SAUSTUCOE
    If GSALRND = 2
        Call ARRDEV(COUTHT,[F:SIV]CUR) From TRTDIV
        [F:SID]CPRPRI+=COUTHT
    Else
        [F:SID]CPRPRI+=arr(COUTHT,10^-GDECPRI)
    Endif
    # Pas de calcul de marge pour les gratuits
    If [F:SID]NETPRI = 0 & [F:SID]FOCFLG = 3 Return Endif

    # Calcul de marge pour les articles vendus ou les articles livrables ayant un prix net
    If [F:ITM]SALFLG=2 | ([F:ITM]SALFLG=1 & [F:SID]NETPRINOT<>0)
        # --> Calcul de la marge
        [F:SID]PFM = [F:SID]NETPRINOT - [F:SID]CPRPRI
        #Call ARRDEV([F:SID]PFM,[F:SIV]CUR) From TRTDIV
    Endif
Return

# Issue 91954 - 2013-10-07 by CCC
##########################################################################
# Update Customer return PRIORD with AVC
##########################################################################
$UPD_SRETURN
Read [SRD]SRD0=[F:STJ2]VCRNUM;[F:STJ2]VCRLIN
If !fstat
    [F:SRD]PRIORD = [F:STJ]PRIORD
    Rewrite [SRD]
    Call ECRTRACE("Customer return"-[F:STJ2]VCRNUM-num$([F:STJ2]VCRLIN)-": priord="+num$([F:SRD]PRIORD),0)
Endif
Return

##########################################################################
Subprog MWIMAT(PFCY,PVCRTYP,PVCRNUM,PVCRLIN,PVCRTYPORI,PVCRNUMORI,PVCRLINORI,PITM,PAMTLIN,PDELTA,PARR)
Value Char    PFCY
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Value Integer PVCRTYPORI
Value Char    PVCRNUMORI
Value Integer PVCRLINORI
Value Char    PITM
Value Decimal PAMTLIN
Value Decimal PDELTA()
Value Decimal PARR

Local Integer LVCRTYPORI
Local Char LVCRNUMORI(GLONVCR)

Local Integer NOYEA, LAST_SEQ, LRET
Local Decimal LBASAMT

Local Decimal LQTY, LQTYACT
Local Decimal LAMTTOT, LAMTMAX
Local Integer LSEQ
Local Integer LFIND
Local Decimal MAX_VAL
Local Integer MAX_IND
Local Integer I
Local Decimal LDELTA(dim(PDELTA))
For I=0 To dim(PDELTA)-1
    LDELTA(I) = -PDELTA(I)
Next

Local Decimal LDEV(dim(PDELTA)), LDEVTOT

If [F:FCY]FCY<>PFCY
    Read [FCY]FCY0=PFCY
Endif

If [F:ITM]ITMREF<>PITM
    Read [ITM]ITM0=PITM
Endif

Raz [F:MWI]

# Issue 102017 - 2014-06-19 by CCC : Origin document is the product for a component tracking without WO => get "WO number" in WIPCOST
LFIND=0
If PVCRTYPORI=0
    For [MWI] reckey Where MFGTRKNUM=PVCRNUM
&                        & MFGTRKLIN=PVCRLIN
&                        & ITMREF=PITM
&                        & MFGFCY=PFCY
&                        & TXNTYP=1
&                        & VCRTYP=37
        LFIND=1
        Break
    Next
    LVCRTYPORI = 37
    LVCRNUMORI = [F:MWI]VCRNUM
Else
    Filter [MWI] Where MFGTRKNUM=PVCRNUM
&                    & MFGTRKLIN=PVCRLIN
&                    & ITMREF=PITM
&                    & MFGFCY=PFCY
&                    & TXNTYP=1
&                    & VCRTYP=PVCRTYPORI
&                    & VCRNUM=PVCRNUMORI
    Look [MWI] First
    Filter [MWI]
    If !fstat : LFIND=1 : Endif
    LVCRTYPORI = PVCRTYPORI
    LVCRNUMORI = PVCRNUMORI
Endif

Call GET_LAST_SEQ(LVCRTYPORI,LVCRNUMORI,LAST_SEQ) From MWIPLIB

If !LFIND     # S'il n'existe pas de wipcost pour ce suivi et cette mati?re (prix nul) il faut le cr?er
    Case [F:STJ2]TRSTYP
        When 6 :
            Raz [F:MKM]
            Read [MKM]MKM0=PVCRNUM;PVCRLIN
        When 29 :
            Raz [F:SCM]
            Filter [SCM] Where SCONUM=LVCRNUMORI & SCILIN=PVCRLINORI & ITMREF=PITM
            Read [SCM] First
            Filter [SCM]
    Endcase
    If fstat
        End
    Endif
    If !clalev([M:STW]) : Local Mask STOWORK [STW] : Endif
    If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
    nolign = 1
    [M:STW] = [F:STJ2]
    [M:STW]QTYSTUACT(0)  =[F:STJ2]ACTQTY
    [M:STW]WAIFLG(0) = 0
    [M:STW]MAJCOD(0) = "C"
    If [M:STW]QTYSTU(0)=0
        Call ECRTRACE(PVCRNUM-num$(PVCRLIN)-": QTYSTU=0",1)
        End
    Endif
    # Ajouter PAMTLIN permet de gérer les cas où le wipcost n'avait pas été créé à tort (en migration par exemple)
    [M:STW]PRIVAL(0) = (-PAMTLIN+LDELTA(0))/[M:STW]QTYSTU(0)
    [M:STW]NBLIG=1
    [M:SVW]AMTVAL(0)    = -PAMTLIN+LDELTA(0)
    [M:SVW]PRINAT(0)    = 8
    If GACTDECCST
        Call LOADFIC("[M:SDP]",LDELTA,"","CST",1,0) From STKVALECR
        Call COPSDP2SVWVALA(0,1,PARR) From STKVALECR
    Endif
    Call MAJ_WIPCOST(LRET) From MWIPLIB
Else

    Read [MWH]MWH0=LVCRTYPORI;LVCRNUMORI

    Raz LAMTTOT
    Raz LFIND
    For [MWI]reckey Where MFGTRKNUM=PVCRNUM
&                       & MFGTRKLIN=PVCRLIN
&                       & VCRTYP = LVCRTYPORI
&                       & VCRNUM = LVCRNUMORI
&                       & TXNTYP=1
&                       & ITMREF=PITM
&                       & MFGFCY=PFCY
&                       & GLPSTA=2
        LFIND = 1
        Break
    Next

    If LFIND
        # Un des enreg WIPCOST a déjà été comptabilisé => création d'un wip avec le delta
        Gosub CRE_MWI
    Else
        # Pas de wip du suivi comptabilisé => on proratise les montants pour tenir compte du delta dans les wip existants
        Columns [MWI] (AMOUNT)
        For [MWI]reckey Where MFGTRKNUM=PVCRNUM
&                           & MFGTRKLIN=PVCRLIN
&                           & ITMREF=PITM
&                           & MFGFCY=PFCY
&                           & TXNTYP=1
            LAMTTOT += [F:MWI]AMOUNT
        Next
        Columns [MWI]
        If LAMTTOT=0    # Par sécurité
            Gosub CRE_MWI
        Else
            # Modification des champs AMOUNT, CSTELM() et UNTCST
            Raz LSEQ, LAMTMAX
            For [MWI]reckey Where MFGTRKNUM=PVCRNUM
&                               & MFGTRKLIN=PVCRLIN
&                               & ITMREF=PITM
&                               & MFGFCY=PFCY
&                               & TXNTYP=1
&                               & AMOUNT<>0
                If [F:MWI]AMOUNT>LAMTMAX
                    LSEQ=[F:MWI]WIPSEQ
                    LAMTMAX=[F:MWI]AMOUNT
                Endif
                For I=0 To GDIMCST*GACTDECCST
                    LDEV(I) = arr(LDELTA(I)*[F:MWI]AMOUNT/LAMTTOT,PARR)
                Next
                LDEVTOT += LDEV
                Gosub UPD_MWIAMT
            Next

            # pour que LDELTA soit bien pris en compte totalement
            If LSEQ<>0 & LDEVTOT<>arr(LDELTA(0),PARR)
                Read [MWI]MWI0=LVCRTYPORI;LVCRNUMORI;1;LSEQ
                For I=0 To GDIMCST*GACTDECCST
                    LDEV(I)=arr(LDELTA(I),PARR)-LDEVTOT
                Next
                Gosub UPD_MWIAMT
            Endif
        Endif
    Endif
Endif

#---- Traitements des FG de sortie
If [F:ITF]ITMREF<>[F:MWI]ITMREF | [F:ITF]STOFCY<>[F:MWI]MFGFCY
    Read [ITF]ITF0 = [F:MWI]ITMREF;[F:MWI]MFGFCY
Endif
If fstat
    If [F:MWI]SCOFLG<>3
        Call FSTA("ITF") From GLOCK
        GOK = 0
        End
    Endif
Else
    If [F:ITF]OVECOD <> ""
        # Issue 114047 - 2016-03-07 by CCC : Distinguish WO & EO issues
        If PVCRTYPORI=36
            Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,29,LRET) From STKVAL
        Else
            Call LECOVE([F:MWI]ITMREF,[F:MWI]MFGFCY,6,LRET) From STKVAL
        Endif
        If LRET>1
            Call FSTA("OVE") From GLOCK
            GOK = 0
            End
        Elsif !LRET
            If [F:OVE]CLCLEV = 2 & [F:OVE]FORBASIS=1
                # Les FG de l'article sont calculés en sortie et sont basés sur le montant => recalcul des FG
                If LAMTTOT=0
                    Columns [MWI] (AMOUNT)
                    For [MWI]reckey Where MFGTRKNUM=PVCRNUM
&                                       & MFGTRKLIN=PVCRLIN
&                                       & ITMREF=PITM
&                                       & MFGFCY=PFCY
&                                       & TXNTYP=1
                        LAMTTOT += [F:MWI]AMOUNT
                    Next
                    Columns [MWI]
                Endif
                LBASAMT = LAMTTOT
                # Recherche de wipcost déjà comptabilisés
                Raz LFIND
                For [MWI]reckey Where MFGTRKNUM=PVCRNUM
&                                   & MFGTRKLIN=PVCRLIN
&                                   & VCRTYP=LVCRTYPORI
&                                   & VCRNUM=LVCRNUMORI
&                                   & TXNTYP=5
&                                   & ITMREF=PITM
&                                   & MFGFCY=PFCY
&                                   & GLPSTA=2
                    LFIND = 1
                    Break
                Next
                If LFIND
                    # Annulation des wipcost existants...
                    Call GET_LAST_SEQ(LVCRTYPORI,LVCRNUMORI,LAST_SEQ) From MWIPLIB
                    Filter [MWI2] Where MFGTRKNUM=PVCRNUM
&                                     & MFGTRKLIN=PVCRLIN
&                                     & VCRTYP=LVCRTYPORI
&                                     & VCRNUM=LVCRNUMORI
&                                     & TXNTYP=5
&                                     & ITMREF=PITM
&                                     & MFGFCY=PFCY
&                                     & WIPSEQ<=LAST_SEQ
&                                 Order By Key XMWI=VCRNUM;MFGTRKNUM;MFGTRKLIN;OVENAT;WIPSEQ Desc
                    For [MWI2]XMWI(4)
                        [F:MWI]=[F:MWI2]
                        Raz [F:MWI]QTY,[F:MWI]QTYACT,[F:MWI]AMOUNT,[F:MWI]CSTELM
                        For [MWI2]XMWI
                            [F:MWI]QTY-=[F:MWI2]QTY
                            [F:MWI]QTYACT-=[F:MWI2]QTYACT
                            [F:MWI]AMOUNT-=[F:MWI2]AMOUNT
                            For I=0 To dim([F:MWI]CSTELM)-1
                                [F:MWI]CSTELM(I)=[F:MWI2]CSTELM(I)
                            Next
                        Next
                        If [F:MWI]QTY<>0 | [F:MWI]AMOUNT<>0
                            LAST_SEQ+=1
                            [F:MWI]WIPSEQ = LAST_SEQ
                            [F:MWI]TXNACT=3
                            Call ECR_MWI From MWIPLIB
                            If fstat
                                Call FSTA("MWI") From GLOCK
                                LRET = 1
                                Break        #MAE, bg70563 #End
                            Endif
                            LAST_SEQ = [F:MWI]WIPSEQ : # GH 02/2016 bug 108954 incrementation for WIPCOST
                        Endif
                    Next
                    Filter [MWI2]
                    #MAE, bg 70563
                    If LRET = 1 : End : Endif
                    [G:MWI2]currlen = 0
                Else
                    # Suppression des wipcost existants...
                    Delete [MWI] Where MFGTRKNUM=PVCRNUM
&                                    & MFGTRKLIN=PVCRLIN
&                                    & TXNTYP=5
&                                    & ITMREF=PITM
&                                    & MFGFCY=PFCY
                Endif
                # .. puis recalcul
                Call MAT_OH([F:OVE]OVECOD,2,LBASAMT,LRET) From MWIPLIB
                If LRET = 1
                   GOK = 0
                    End
                Endif
            Endif
        Endif
    Endif
Endif

End

#############################################################
# Met à jour les écarts (txntyp=17) dans WIPCOST
$UPD_MWIDEV
Local Integer LAST_SEQ
Filter [MWI] Where MFGFCY=[F:STJ2]STOFCY
&                & VCRTYP=[F:STJ2]VCRTYPORI
&                & VCRNUM=[F:STJ2]VCRNUMORI
&                & VCRLIN=[F:STJ2]VCRLINORI
&                & OVENAT=""
&                & TXNTYP=17
Read [MWI]MWI0 Last
Filter [MWI]
If !fstat
    If [F:MWI]GLPSTA=2  # Comptabilisé => création nouvel enreg 17
        Call GET_LAST_SEQ([F:MWI]VCRTYP,[F:MWI]VCRNUM,LAST_SEQ) From MWIPLIB
        [F:MWI]WIPSEQ=LAST_SEQ+1
        [F:MWI]AMOUNT = 0
        Raz [F:MWI]GLPDAT, [F:MWI]GLPSTA
        Raz [F:MWI]CSTELM(0..8)
        [F:MWI]CSTELM(9)=LDELTA
        [F:MWI]CSTELM(10)=LDELTADEV
        Call ECR_MWI From MWIPLIB
    Else                # Non comptabilisé => modif des montants absorbés et non absorbés
        [F:MWI]CSTELM(9)+=LDELTA
        [F:MWI]CSTELM(10)+=LDELTADEV
        Rewrite [MWI]
    Endif
Endif
Return

#############################################################
# Met à jour les montants du WIPCOST en ajoutant LDEV
$UPD_MWIAMT
    # CCC (2010-03-01) Bug 62931 : Gestion du cas où AMOUNT=0 ou passe à 0
    If LDEV=0
        Return
    Endif
    For I=0 To dim([F:MWI]CSTELM)-1
        If I>7 & GACTDECCST
            Break
        Endif
        If [F:MWI]AMOUNT=0 | [F:MWI]AMOUNT+LDEV=0
            [F:MWI]CSTELM(I) = 0
        Else
            [F:MWI]CSTELM(I) += arr([F:MWI]CSTELM(I)*LDEV/[F:MWI]AMOUNT,PARR)
        Endif
    Next
    If GACTDECCST
        Call LOADFIC("[F:MWI]",LDEV, "", "CST", 1, 1) From STKVALECR   # Met à jour les zones MATCST, MACCST...

        [F:MWI]CSTELM(8)  = sum([F:MWI]MATCST)        # Matière
        [F:MWI]CSTELM(10) = sum([F:MWI]MACCST)
        [F:MWI]CSTELM(9)  = sum([F:MWI]LABCST)
        [F:MWI]CSTELM(11) = [F:MWI]SCOCST
        [F:MWI]CSTELM(16) = [F:MWI]INVDTACST
        [F:MWI]CSTELM(12) = [F:MWI]OVEMATCST
        [F:MWI]CSTELM(14) = [F:MWI]OVEMACCST
        [F:MWI]CSTELM(13) = [F:MWI]OVELABCST
        [F:MWI]CSTELM(15) = [F:MWI]OVESCOCST
    Endif
    If [F:MWI]AMOUNT=0
        [F:MWI]CSTELM(0) = LDEV
    Endif
    [F:MWI]AMOUNT += LDEV    # Attention à l'ordre car c'est l'ancienne valeur qui est utilisée pour màj CSTELM

    Gosub MAJ_MATLEV0

    If [F:MWI]QTY<>0
        [F:MWI]UNTCST  = arr([F:MWI]AMOUNT/[F:MWI]QTY,PARR) : # Qty will never be 0 at this point
    Endif

    # Pour que AMOUNT = somme(CSTELM)
    MAX_IND = 0 # égalisation sur la première série seulement (0-7)
    MAX_VAL = 0
    For I = 0 To 7
        If abs(MAX_VAL) < abs([F:MWI]CSTELM(I))
            MAX_VAL = [F:MWI]CSTELM(I)
            MAX_IND = I
        Endif
    Next
    If sum([F:MWI]CSTELM(0..7)) <> [F:MWI]AMOUNT
        [F:MWI]CSTELM(MAX_IND) += ([F:MWI]AMOUNT - sum([F:MWI]CSTELM(0..7)))
    Endif

    Rewrite [MWI]
Return

#############################################################
# Crée un wipcost avec le delta en se basant sur le dernier écrit pour la ligne de suivi
$CRE_MWI

Call GET_LAST_SEQ(LVCRTYPORI,LVCRNUMORI,LAST_SEQ) From MWIPLIB

Filter [MWI] Where MFGTRKNUM=PVCRNUM
&                & MFGTRKLIN=PVCRLIN
&                & ITMREF=PITM
&                & MFGFCY=PFCY
&                & TXNTYP=1
Raz LQTY, LQTYACT
For [MWI]MWI1  # Le dernier écrit (wipseq le plus grand) sera en ligne
    LQTY    += [F:MWI]QTY
    LQTYACT += [F:MWI]QTYACT
Next
Filter [MWI]

# La quantité consommée se trouve déjà sur les autres enreg wipcost
[F:MWI]QTY       = 0
[F:MWI]QTYACT    = 0

For I=0 To 7+(!GACTDECCST)*9
    If [F:MWI]AMOUNT=0
        If I=0
            [F:MWI]CSTELM(I) = arr(LDELTA,PARR)#*sgn(LDELTA)    # Issue 88959 - 2013-03-29 by CCC
        Else
            [F:MWI]CSTELM(I) = 0
        Endif
    Else
        [F:MWI]CSTELM(I) = arr([F:MWI]CSTELM(I)*LDELTA/[F:MWI]AMOUNT,PARR)#*sgn(LDELTA)     # Issue 88959 - 2013-03-29 by CCC
    Endif
Next
If GACTDECCST
    Call LOADFIC("[F:MWI]",LDELTA, "", "CST", 1, 0) From STKVALECR   # Alimente les zones MATCST, MACCST...

    [F:MWI]CSTELM(8)  = sum([F:MWI]MATCST)        # Matière
    [F:MWI]CSTELM(10) = sum([F:MWI]MACCST)
    [F:MWI]CSTELM(9)  = sum([F:MWI]LABCST)
    [F:MWI]CSTELM(11) = [F:MWI]SCOCST
    [F:MWI]CSTELM(16) = [F:MWI]INVDTACST
    [F:MWI]CSTELM(12) = [F:MWI]OVEMATCST
    [F:MWI]CSTELM(14) = [F:MWI]OVEMACCST
    [F:MWI]CSTELM(13) = [F:MWI]OVELABCST
    [F:MWI]CSTELM(15) = [F:MWI]OVESCOCST
Endif

Gosub MAJ_MATLEV0

[F:MWI]AMOUNT    = LDELTA(0)
[F:MWI]UNTCST    = arr([F:MWI]AMOUNT/LQTY,PARR) : # Qty will never be 0 at this point

[F:MWI]WIPSEQ    = LAST_SEQ + 1

[F:MWI]GLPSTA    = 1
Raz [F:MWI]GLPDAT

Call ECR_MWI From MWIPLIB
If fstat
    Call FSTA("MWI") From GLOCK
    LRET = 1
    Return
Endif

Return

#############################################################
$MAJ_MATLEV0
Local Integer LMATFLG

If [F:MWH]VCRTYP<>[F:MWI]VCRTYP | [F:MWH]VCRNUM<>[F:MWI]VCRNUM
    Raz [F:MWH]
    Read [MWH]MWH0=[F:MWI]VCRTYP;[F:MWI]VCRNUM
Endif
If [F:MWH]MATLEVFLG = 2
    Raz LMATFLG
    Case [F:MWI]VCRTYP
        When 10 :
            If [F:MKM]MFGTRKNUM<>[F:MWI]MFGTRKNUM | [F:MKM]MATTRKLIN<>[F:MWI]MFGTRKLIN
                Raz [F:MKM]
                Read [MKM]MKM0=[F:MWI]MFGTRKNUM;[F:MWI]MFGTRKLIN
            Endif
            LMATFLG = func SUBCSTB.ISMAT([F:MWI]ITMREF, 2, [F:MKM]BOMALT, [F:MKM]IPTDAT)
        When 36 :
            Raz [F:SCM]
            Filter [SCM] Where SCONUM=LVCRNUMORI & SCILIN=PVCRLINORI & ITMREF=PITM
            Read [SCM] First
            Filter [SCM]
            LMATFLG = func SUBCSTB.ISMAT([F:MWI]ITMREF, 3, [F:SCM]BOMALT, [F:MWI]TXNDAT)
    Endcase
    If LMATFLG
        [F:MWI]MATLEV0=[F:MWI]CSTELM(8)
    Endif
Endif
Return


#############################################################
Subprog CALMFC(PFCY,PVCRTYP,PVCRNUM,PVCRLIN)
Value Char PFCY
Value Integer PVCRTYP # FGR 01/02/2010 : X3SUIVI60986 : pas PVCRLIN
Value Char PVCRNUM
#Value Char PVCRLIN
Value Integer PVCRLIN   # FGR 21/12/2009 : X3SUIVI60986

Case PVCRTYP
    When 10 : Read [MFI]MFI0 = PVCRNUM;PVCRLIN
    When 36 : Read [SCI]SCI0 = PVCRNUM;PVCRLIN
Endcase

# Issue 95720 - 2014-01-09 by CCC : Si la matière n'était pas liée à une ligne, PVCRLIN=0 => ne pas faire de filtre sur VCRLIN
Filter [MFC] Where STOFCY = PFCY
&                & VCRTYP = PVCRTYP
&                & VCRNUM = PVCRNUM
&                & MFCTYP = 4
&                & UID    = 0
Look [MFC]MFC0 First
Filter [MFC]
If fstat
    Call ECRTRACE(PVCRNUM-": pas de PRF trouvé => pas de recalcul",0)
    End    # Si le coût n'existe pas, on ne le calcule pas
Endif

# Issue 82841 - 2012-08-30 by CCC
#If !clalev([M:MWF0]) : Local Mask MWF0 : Endif
#Raz [M:MWF0], GERR, GMESSAGE  # Il faut s'assurer que l'écran est bien vide
#Gosub INIT     From FUNWIPMFC
#
#Default Mask [MWF0]
#[M:MWF0]STOFCY = PFCY
#[M:MWF0]VCRTYP = PVCRTYP
#[M:MWF0]VCRNUM = PVCRNUM
#[M:MWF0]PRNCOD = 1    # Pas d'impression
#[M:MWF0]FLXBUD = 1    # --> utile uniquement pour l'impression => valeur 1 car on n'a pas d'impression
#[M:MWF0]ORIDEVCLC = 1 # Origine écart utile uniquement pour l'impression
Case PVCRTYP
    When 10 :
        If !clalev([M:MWF0]) : Local Mask MWF0 [MWF0] : Endif
        Raz [M:MWF0], GERR, GMESSAGE  # Il faut s'assurer que l'écran est bien vide
        Gosub INIT     From FUNWIPMFC

        Default Mask [MWF0]

    When 36 :
        If !clalev([M:SWF0]) : Local Mask SWF0 [SWF0] : Endif
        Raz [M:SWF0], GERR, GMESSAGE  # Il faut s'assurer que l'écran est bien vide
        Gosub INIT     From FUNWIPMFC

        Default Mask [SWF0]
Endcase
[M]STOFCY = PFCY
[M]VCRTYP = PVCRTYP
[M]VCRNUM = PVCRNUM
[M]PRNCOD = 1    # Pas d'impression
[M]FLXBUD = 1    # --> utile uniquement pour l'impression => valeur 1 car on n'a pas d'impression
[M]ORIDEVCLC = 1 # Origine écart utile uniquement pour l'impression

Gosub CONTROLE From FUNWIPMFC
If !GOK | GERR=1
    Call ECRTRACE(GMESSAGE,1)
    Raz GMESSAGE
    GOK=0
    End
Endif
GISSADJ=2    # Pour permettre l'écriture éventuelle d'enreg SMA
Gosub EXEC     From FUNWIPMFC
GISSADJ=1
Call ECRTRACE("Apres EXEC GOK="+num$(GOK)-"GERR="+num$(GERR),0)

Filter [MFC] Where VCRNUM=PVCRNUM & MFCTYP=4
Read [MFC]MFC0 First
Filter [MFC]
If fstat
    Call ECRTRACE(PVCRNUM-": pas de PRF trouvé",1)
Else
    Call ECRTRACE(PVCRNUM-": csttot="-num$([F:MFC]CSTTOT),0)
Endif
End

#########################################################################
# détermine les arrondis à appliquer
#########################################################################
$SETRND

    # Issue 113876 - 2016-03-09 by CCC : When site is changing, reload value of general parameter
    Call PARAM([F:STJ2]STOFCY,"BETFCYCST",GBIDC1) From ADOVAL
    GBETFCYCST = val(GBIDC1)

    # Pour être cohérent avec STKMAJ dans la valeur de l'arrondi
    WARRONDI=0
    GPOINT="AMTRND" : Gosub ENTREE From EXEFNC

    # Arrondi devise
    If [L]WARRONDI=1
       LAMTRND=[F:TCU]CURRND
       LPRIRND=[F:TCU]CURRND
    # Arrondi type donnée
    Else
        If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
        Read [F:ATZ]CODZONE="STOJOU";"AMTORD"
        If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
        Read [ATY]CODTYP=[F:ATZ]CODTYP
        If fstat = 0
          LAMTRND= 10^-(mod([F:ATY]LNGTYP,1)*10)
        Else
          LAMTRND=0.01
        Endif
        Read [F:ATZ]CODZONE="STOJOU";"PRIORD"
        If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
        Read [ATY]CODTYP=[F:ATZ]CODTYP
        If fstat = 0
          LPRIRND= 10^-(mod([F:ATY]LNGTYP,1)*10)
        Else
          LPRIRND=0.01
        Endif
    Endif
Return

