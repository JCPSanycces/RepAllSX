#<AdxTL>@(#)0.0.0.0 $Revision$
Run FUNSADJ
End
# Issue X3-98052 - 20180803 by LD : Cost price on line of Sales Order is rounding for currency conversion


################################################################################
# ECRTRACE : Ecriture dans le fichier de trace ouvert selon paramètre stock STOTRACE
#            ( Cf. ECR_TRACE de GESECRAN )
#            !!!!!!! Utilisée dans STKVAL et SUBCGVB !!!!!!!!!
################################################################################
# PMES : Message à enregistrer
# PERR : Code message (0=info , 1=Erreur)
################################################################################
Subprog ECRTRACE( PMES, PERR )
Value Char PMES
Value Integer PERR
    If GTRACE<>""
&    & (  GSTOTRACE=2 & PERR=1
&       | GSTOTRACE>2 )
        # Trace optionnelle du nombre de curseurs ouverts dans oracle
        If dim(ZGSIDCUR)>0 & GTYPDBA=1
            If ZGSIDCUR=0
                # Récupération du SID oracle courant de la session
                ZGSIDCUR = func GETSID
            Endif
            Call ECR_TRACE( func NBCURSORS-PMES, PERR ) From GESECRAN
        Else
            Call ECR_TRACE( PMES, PERR ) From GESECRAN
        Endif
    Endif
End


Subprog ECRTRACEVAL(PNAME,PVAL)
Value Char    PNAME
Value Decimal PVAL()
Local Integer I
Raz GBIDC1
For I=0 To dim(PVAL)-1
    If PVAL(I)<>0
        GBIDC1+="("+num$(I)+")"-num$(PVAL(I))+";"
    Endif
Next
Call ECRTRACE(PNAME+"="+GBIDC1,0)
End

Funprog NBCURSORS
Local Integer NB
Local Char REQ(250)
If dim(ZGSIDCUR)>0 & ZGSIDCUR>0
    REQ = "SELECT a.Value From v$sesstat a, v$statname b Where a.statistic# = b.statistic#  and a.sid="+num$(ZGSIDCUR)+" and b.name = 'opened cursors current'"
    For (Integer N) From "3" Sql REQ As [SQLX]
        NB = [F:SQLX]N
        Break
    Next
Else
    End ""    # Pas de SID => on ne peut pas renvoyer le nombre de curseurs
Endif
End num$(NB)-";" #-num$([S]dbglong(9))+";"+num$([S]dbglong(10))+";"+num$([S]dbglong(11))

Funprog GETSID
Local Integer SID
Local Char REQ(250)
REQ = "SELECT s.sid From v$session s Where s.audsid=SYS_CONTEXT('USERENV','SESSIONID')"
For (Integer N) From "3" Sql REQ As [SQLX]
    SID = [F:SQLX]N
    Break
Next
End SID

Subprog FSTA(ABR)
Value Char ABR
GBIDI1 = GSERVEUR
GSERVEUR = 1  # Pour afficher l'erreur dans la trace
Call FSTA(ABR) From GLOCK
GSERVEUR = GBIDI1
Call ECRTRACE(GMESSAGE,1)
Raz GMESSAGE
End

###########################################################
$OPEN_FILE

