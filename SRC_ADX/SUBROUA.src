    Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

# Pas de lien vers cas d'emploi, si pas de gamme chargée     # 11.01 MM demande 11708
If  [M:ROU0]ITMREF="" | find("GESROW",GNAVIG(1..GPILNAV-1))
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
If !CLECUR | GREP <> "" Then
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
#----- Objet à 3 éléments de clé : ajout de la touche suppression si autorisé -----#
#Plus vrai en 150 : à vérifier !!!
#If CLECUR  CHAINE+="A" : Endif
#----- Si suppression non autorisée, grisage du bouton -----#
#If GREP<>"C"
#  GBIDC2="S" : Gosub AUTORIS_OPT From CONTX3
#  If !GBIDI2  Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
#Endif

# Issue 104937 - 10-11-2015 by STLIG
Gosub SETBOUT From ECCROU
Return

