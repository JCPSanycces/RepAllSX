#########################################################################
$AM_WST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF1]WCR=[F:MWS]WCR
  [M:ROF1]WSTTYP=[F:MWS]WSTTYP
#  [M:ROF1]WSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF1]WSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF1]XWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  [M:ROF1]WSTNBR = [F:MWS]WSTNBR
  Case GWSTEFFINH
         When 1:        # ben rien
         When Default:  [M:ROF1]EFF = [F:MWS]EFF
  Endcase
  [M:ROF1]SHR = [F:MWS]SHR
  If !GIMPORT
      Affzo [ROF1]WCR
      Affzo [ROF1]XWSTTYP
      Affzo [ROF1]WSTDES
      Affzo [ROF1]WSTNBR
      Affzo [ROF1]EFF
      Affzo [ROF1]SHR
  Endif
  If [F:MWS]WSTTYP=3
      [M:ROF2]SCOCOD=2 : [M:ROF2]SCOWST=VALEUR
      [M:ROF1]LABWCR="" : [M:ROF1]LABWST="" : [M:ROF1]LABWSTTYP=0 : [M:ROF1]LABWSTDES=""
      [M:ROF1]XLABWSTTYP=""
      [M:ROF1]SETLABCOE=0 : [M:ROF1]OPELABCOE=0
      If !GIMPORT : Affzo [ROF1]LABWCR, XLABWSTTYP, LABWST, LABWSTDES, SETLABCOE, OPELABCOE : Endif
  Endif
  If [F:MWS]WSTTYP <> 3 & [M:ROF2]SCOCOD=2 : [M:ROF2]SCOCOD=3 : Endif
 Endif
Else
 [M:ROF1]WCR = ""
 [M:ROF1]WSTTYP=0
 [M:ROF1]WSTDES=""
 [M:ROF1]XWSTTYP=""
 [M:ROF1]EFF = 100
 [M:ROF1]SHR = 0
 If !GIMPORT : Affzo [ROF1]WCR, XWSTTYP, WSTDES, EFF, SHR : Endif
Endif
If [M:ROF2]SCOCOD = 1 : Grizo [M:ROF2]30 : Actzo [M:ROF2]SCOCOD : Else : Actzo [M:ROF2]30 : Endif
Return

#########################################################################
$AV_LABWST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If [M:ROF1]WSTTYP=3
   VALEUR="" : [M:ROF1]LABWCR="" : [M:ROF1]LABWSTTYP=0 : [M:ROF1]LABWSTDES=""
   [M:ROF1]XLABWSTTYP=""
   If !GIMPORT : Affzo [ROF1]LABWCR, XLABWSTTYP, LABWSTDES : Endif
Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF1]LABWCR=[F:MWS]WCR
  [M:ROF1]LABWSTTYP=[F:MWS]WSTTYP
#  [M:ROF1]LABWSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF1]LABWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF1]XLABWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  If !GIMPORT : Affzo [ROF1]LABWCR, XLABWSTTYP, LABWSTDES : Endif
 Endif
Endif
Return

#########################################################################
$AM_LABWST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF1]LABWCR=[F:MWS]WCR
  [M:ROF1]LABWSTTYP=[F:MWS]WSTTYP
#  [M:ROF1]LABWSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF1]LABWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF1]LABNBR=[F:MWS]WSTNBR
  [M:ROF1]XLABWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  If !GIMPORT : Affzo [ROF1]LABWCR, XLABWSTTYP, LABWSTDES, LABNBR : Endif
 Endif
  If [M:ROF1]SETLABCOE=0 : [M:ROF1]SETLABCOE=1 : Endif
  If [M:ROF1]OPELABCOE=0 : [M:ROF1]OPELABCOE=1 : Endif
Else
 [M:ROF1]LABWCR="" : [M:ROF1]LABWSTTYP=0 : [M:ROF1]LABWSTDES="" : [M:ROF1]XLABWSTTYP="" : [M:ROF1]LABNBR=0
 If !GIMPORT : Affzo [ROF1]LABWCR, XLABWSTTYP, LABWSTDES, LABNBR : Endif # llc 11.01
Endif
Return

#########################################################################
$AV_ROOTIMCOD
If VALEUR <> 0
   If VALEUR = 2
      [M:ROF1]OPETIM=0
      If !GIMPORT : Affzo [ROF1]OPETIM, TIMUOM2 : Endif
   Else
      [M:ROF1]CAD=0 : [M:ROF1]X="" : [M:ROF1]TIMUOM3=""
      If !GIMPORT : Affzo [ROF1]CAD, X, TIMUOM3 : Endif
   Endif
   If VALEUR <> 1
       [M:ROF1]TIMCOD=0
       [M:ROF1]BASQTY=0
       If !GIMPORT : Affzo [ROF1]TIMCOD, BASQTY : Endif
   Endif
Endif
Return

#########################################################################
$AM_ROOTIMCOD
If VALEUR <> 0
   If VALEUR = 2
      [M:ROF1]OPETIM=0
      If !GIMPORT : Affzo [ROF1]OPETIM, TIMUOM2 : Endif
   Else
      [M:ROF1]CAD=0 : [M:ROF1]X="" : [M:ROF1]TIMUOM3=""
      If !GIMPORT : Affzo [ROF1]CAD, X, TIMUOM3 : Endif
   Endif
   If VALEUR <> 1
       [M:ROF1]TIMCOD=0
       [M:ROF1]BASQTY=0
       If !GIMPORT : Affzo [ROF1]TIMCOD, BASQTY : Endif
   Endif
   If VALEUR = 1
       [M:ROF1]TIMCOD=1
       [M:ROF1]BASQTY=1
       If !GIMPORT : Affzo [ROF1]TIMCOD, BASQTY : Endif
   Endif
Endif
Return

#########################################################################
$C_SCOCOD
If VALEUR=2 & [M:ROF1]WSTTYP <> 3
   GMESSAGE=mess(6,193,1) : mkstat=2
Endif
Return

#########################################################################
$AM_SCOCOD
[M:ROF2]SCOITMREF="" : [M:ROF2]SCOWST="" : [M:ROF2]SCOWCR=""
[M:ROF2]SCOWSTTYP=0 : [M:ROF2]SCOWSTDES="" : [M:ROF2]XSCOWSTTYP=""
# sr 11.02 demande 16689
[M:ROF2]BPRNUM = "": [M:ROF2]REFPRI = 0
If !GIMPORT : Affzo [ROF2]SCOITMREF, SCOWST, SCOWCR, XSCOWSTTYP, SCOWSTDES, BPRNUM, REFPRI : Endif
Return

#########################################################################
$AV_SCOWST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF2]SCOWCR=[F:MWS]WCR
  [M:ROF2]SCOWSTTYP=[F:MWS]WSTTYP
#  [M:ROF2]SCOWSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF2]SCOWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF2]XSCOWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  If !GIMPORT : Affzo [ROF2]SCOWCR, XSCOWSTTYP, SCOWSTDES : Endif
 Endif
Endif
Return

#########################################################################
$AM_SCOWST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF2]SCOWCR=[F:MWS]WCR
  [M:ROF2]SCOWSTTYP=[F:MWS]WSTTYP
#  [M:ROF2]SCOWSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF2]SCOWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF2]XSCOWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  If !GIMPORT : Affzo [ROF2]SCOWCR, XSCOWSTTYP, SCOWSTDES : Endif
 Endif
Else
 [M:ROF2]SCOWCR="" : [M:ROF2]SCOWSTTYP=0 : [M:ROF2]SCOWSTDES="" : [M:ROF2]XSCOWSTTYP=""
 If !GIMPORT : Affzo [ROF2]SCOWCR, XSCOWSTTYP, SCOWSTDES : Endif
Endif
Return

#########################################################################
$MAJ_FENETRE
# mise à état initial des zones des écrans ROF0, ROF1, ROF2, ROF3 et ROF5 en cas de création
If clalev ([ITM])=0 : Local File ITMMASTER [ITM] : Endif
Raz [M:ROF0], [M:ROF1], [M:ROF2]
Raz [M:ROF3], [M:ROF5] : # Issue 112849 - 2015-11-30 by GH : text not reset to blank
[M:ROF1]EFF=100 : [M:ROF1]WSTNBR=1 : [M:ROF1]OPESTUCOE=1
[M:ROF1]SETLABCOE=1 : [M:ROF1]OPELABCOE=1 : [M:ROF2]SCOCOD=1
Read [ITM]ITM0=[M:ROU0]ITMREF
If !fstat : [M:ROF1]OPEUOM=[F:ITM]STU : Endif
If LCAP <> 0
    Raz [M:ROF3]
    [M:ROF3]ALTOPECOD = 1
    [M:ROF3]SPLCOD = 1
    [M:ROF3]SPLMAXNBR = 0
Endif
Return

#########################################################################
$AS_SETTIM
If [M:ROU0]TIMUOMCOD=1
   [M:ROF1]TIMUOM1=mess(30,197,1)
Else
   [M:ROF1]TIMUOM1=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF1]TIMUOM1 : Endif
Return

#########################################################################
$AM_SETTIM
If [M:ROU0]TIMUOMCOD=1
   [M:ROF1]TIMUOM1=mess(30,197,1)
Else
   [M:ROF1]TIMUOM1=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF1]TIMUOM1 : Endif
Return

#########################################################################
$AV_TIMUOM1
If [M:ROF1]IND1=0
   If [M:ROU0]TIMUOMCOD=1
      VALEUR=mess(30,197,1)
   Else
      VALEUR=mess(32,197,1)
   Endif
Endif
[M:ROF1]IND1+=1
Return

#########################################################################
$AS_OPETIM
If [M:ROU0]TIMUOMCOD=1
   [M:ROF1]TIMUOM2=mess(30,197,1)
Else
   [M:ROF1]TIMUOM2=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF1]TIMUOM2 : Endif
Return

#########################################################################
$AM_OPETIM
If [M:ROU0]TIMUOMCOD=1
   [M:ROF1]TIMUOM2=mess(30,197,1)
Else
   [M:ROF1]TIMUOM2=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF1]TIMUOM2 : Endif
Return

#########################################################################
$AV_TIMUOM2
If [M:ROF1]IND2=0
   If [M:ROU0]TIMUOMCOD=1
      VALEUR=mess(30,197,1)
   Else
      VALEUR=mess(32,197,1)
   Endif
Endif
[M:ROF1]IND2+=1
Return

#########################################################################
$AS_CAD
[M:ROF1]X="/"
If [M:ROU0]TIMUOMCOD=1
   [M:ROF1]TIMUOM3=mess(30,197,1)
Else
   [M:ROF1]TIMUOM3=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF1]X, TIMUOM3 : Endif
Return

#########################################################################
# correction bug 17344   (TB  14/02/03)
$C_CAD
If VALEUR=0 & [M:ROF1]ROOTIMCOD=2
   mkstat = 2 : GMESSAGE = mess(10,123,1)
Endif
Return

#########################################################################
$AM_CAD
If VALEUR <> 0
   If [M:ROU0]TIMUOMCOD=1
      [M:ROF1]TIMUOM3=mess(30,197,1)
   Else
      [M:ROF1]TIMUOM3=mess(32,197,1)
   Endif
   [M:ROF1]X="/"
Else
   [M:ROF1]TIMUOM3="" : [M:ROF1]X=""
Endif
If !GIMPORT : Affzo [ROF1]X, TIMUOM3 : Endif
Return

#########################################################################
$AV_X
If [M:ROF1]INDX=0
   If [M:ROF1]CAD=0 : VALEUR="" : Else VALEUR="/" : Endif
Endif
[M:ROF1]INDX+=1
Return

#########################################################################
$AV_TIMUOM3
If [M:ROF1]IND3=0
   If [M:ROF1]CAD=0
      VALEUR=""
   Else
      If [M:ROU0]TIMUOMCOD=1
         VALEUR=mess(30,197,1)
      Else
         VALEUR=mess(32,197,1)
      Endif
   Endif
Endif
[M:ROF1]IND3+=1
Return

#########################################################################
$AS_GRPSETTIM
If [M:ROU0]TIMUOMCOD=1
   [M:ROF3]TIMUOM7=mess(30,197,1)
Else
   [M:ROF3]TIMUOM7=mess(32,197,1)
Endif
If !GIMPORT : Affzo [ROF3]TIMUOM7 : Endif
Return

#########################################################################
$AM_GRPSETTIM
If VALEUR<>0
   If [M:ROU0]TIMUOMCOD=1
      [M:ROF3]TIMUOM7=mess(30,197,1)
   Else
      [M:ROF3]TIMUOM7=mess(32,197,1)
   Endif
Else
   [M:ROF3]TIMUOM7=""
Endif
If !GIMPORT : Affzo [ROF3]TIMUOM7 : Endif
Return

#########################################################################
$AV_TIMUOM7
If [M:ROF3]IND7=0
   If [M:ROF3]GRPSETTIM=0
      VALEUR=""
   Else
      If [M:ROU0]TIMUOMCOD=1
         VALEUR=mess(30,197,1)
      Else
         VALEUR=mess(32,197,1)
      Endif
   Endif
Endif
[M:ROF1]IND6+=1
Return

#########################################################################
$CONVERSION
If [F:ROT]TIMUOMCOD=[M:ROU0]TIMUOMCOD : Return : Endif
KHM=1
If [M:ROU0]TIMUOMCOD=1 & [F:ROT]TIMUOMCOD=2 : KHM=1/60 : Else KHM=60 : Endif
[F:ROT]SETTIM=KHM*[F:ROT]SETTIM
If [F:ROT]ROOTIMCOD=1 : [F:ROT]OPETIM=KHM*[F:ROT]OPETIM : Endif
If [F:ROT]ROOTIMCOD=2 : [F:ROT]CAD=[F:ROT]CAD/KHM : Endif
If [F:ROT]ROOTIMCOD=3 : [F:ROT]OPETIM=KHM*[F:ROT]OPETIM : Endif
[F:ROT]GRPSETTIM=KHM*[F:ROT]GRPSETTIM

[F:ROT]SETTIM        = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]SETTIM)            # llc 03.01 8355
[F:ROT]OPETIM        = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM)            # llc 03.01 8355
[F:ROT]CAD           = arr([F:ROT]CAD, 0.0001)               # llc 03.01 8355
[F:ROT]GRPSETTIM     = func TRTX3.ARRTYP("", "", "TIH", [F:ROT]OPETIM)            # llc 03.01 8355
Return



#########################################################################
# Alimentation automatique de la date de début
$AS_VALSTRDAT
Local Integer WOK
Local Date DATDEB

DATDEB = [M:ROU1]VALSTRDAT(nolign-1)

# Si ce n'est pas une nouvelle ligne, on ne propose pas d'initialiser la date de début
If [M:ROU1]CREFLG(nolign-1) <> 0 : End : Endif

Call VERIF_VARIANTE(1,nolign, WOK)
If WOK=1 & [M:ROU1]VALENDDAT(nolign-2)<>[0/0/0]
   VALEUR = [M:ROU1]VALENDDAT(nolign-2)+1
Endif

# Pour le cas où l'opération ait été saisie depuis la fiche
If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If DATDEB<>[0/0/0] : VALEUR = DATDEB : Endif
Endif
Return


#########################################################################
# Alimentation automatique de la date de fin
$AS_VALENDDAT
Local Integer WOK
Local Date DATFIN

DATFIN = [M:ROU1]VALENDDAT(nolign-1)
# Si ce n'est pas une nouvelle ligne, on ne propose pas d'initialiser la date de fin
If [M:ROU1]CREFLG(nolign-1) <> 0 : End : Endif

Call VERIF_VARIANTE(2,nolign, WOK)
# If WOK=1 & [M:ROU1]VALSTRDAT(nolign)<>[0/0/0] : # GH 14/01/2014 bug 95829
If WOK=1 & [M:ROU1]VALSTRDAT(nolign)<>[0/0/0] & [M:ROU1]VALSTRDAT(nolign)-1>=[M:ROU1]VALSTRDAT(nolign-1)
    VALEUR = [M:ROU1]VALSTRDAT(nolign)-1
Endif

If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If DATFIN <>[0/0/0] : VALEUR = DATFIN : Endif
Endif
Return

#########################################################################
# Contrôle de la date de début
$C_VALSTRDAT
Local Integer WOK
Local Integer OK


# la date début doit être comprise entre les dates de
# validité de l'entête
If VALEUR<>[0/0/0]
   If ([M:ROU0]ROUSTRDAT<>[0/0/0] & VALEUR < [M:ROU0]ROUSTRDAT) |
&     ([M:ROU0]ROUENDDAT<>[0/0/0] & VALEUR > [M:ROU0]ROUENDDAT)
      mkstat=2 :  GMESSAGE=mess(10,193,1) :  End
   Endif
Endif

# La date début de validité doit être postérieure à la
# date de fin de l'opération précédente
OK = 1
If [M:ROU0]DATREF=[0/0/0]
  Call VERIF_VARIANTE(1,nolign,WOK)
  If WOK=1 & [M:ROU1]VALENDDAT(nolign-2)>=VALEUR
      # If VALEUR=[0/0/0]  : # GH 14/01/2014 bug 95829
      If VALEUR=[0/0/0] | [M:ROU1]VALSTRDAT(nolign-2)>=VALEUR
         GMESSAGE = mess(193,193,1) : mkstat=2 : End
      Endif
      Call OUINON (mess(158,190,1),OK) From GESECRAN
      If OK<>2 :  mkstat=1 : End : Endif
      [M:ROU1]UPDFLG(nolign-2) = 2     #  la ligne précédente a été modifiée
      [M:ROU1]VALENDDAT(nolign-2) = VALEUR-1 :  Affzo [M:ROU1]VALENDDAT(nolign-2)
  Endif
  If WOK=1 & [M:ROU1]VALENDDAT(nolign-2)= [0/0/0] & VALEUR <>[0/0/0]
     [M:ROU1]UPDFLG(nolign-2) = 2
     [M:ROU1]VALENDDAT(nolign-2) = VALEUR-1: Affzo [M:ROU1]VALENDDAT(nolign-2)
  Endif
Endif

# Pour une opération donnée, la date de début doit être < à la date fin
If instr(1,dbgstr(1),"ROU1") | GIMPORT
   If [M:ROU1]VALENDDAT(nolign-1)<>[0/0/0] & VALEUR>[M:ROU1]VALENDDAT(nolign-1)
       GMESSAGE = mess(90,121,1): mkstat = 2: End : Endif
Elsif instr(1,dbgstr(1),"ROF0")
  If [M:ROF0]VALENDDAT<>[0/0/0] & VALEUR>[M:ROF0]VALENDDAT
       GMESSAGE = mess(90,121,1): mkstat = 2: End : Endif
Endif


# idem pour la ligne qui précéde la ligne courante
If instr(1,dbgstr(1),"ROU1") | GIMPORT
  If nolign >1 & [M:ROU1]OPENUM(nolign-1)=[M:ROU1]OPENUM(nolign-2)
    If  [M:ROU1]VALENDDAT(nolign-2) < [M:ROU1]VALSTRDAT(nolign-2) & [M:ROU1]VALENDDAT(nolign-2)<>[0/0/0]
        [M:ROU1]VALENDDAT(nolign-2)=[0/0/0] : Affzo [M:ROU1]VALENDDAT(nolign-2)
        GMESSAGE = mess(193,193,1) : mkstat = 2 : End
    Endif
  Endif
Elsif instr(1,dbgstr(1),"ROF0")
  If nolign >1 & [M:ROF0]OPENUM=[M:ROU1]OPENUM(nolign-2)
    If  [M:ROU1]VALENDDAT(nolign-2) < [M:ROU1]VALSTRDAT(nolign-2) & [M:ROU1]VALENDDAT(nolign-2)<>[0/0/0]
        [M:ROU1]VALENDDAT(nolign-2)=[0/0/0] : Affzo [M:ROU1]VALENDDAT(nolign-2)
        GMESSAGE = mess(193,193,1)  : mkstat = 2 : End
    Endif
  Endif
Endif

Return

#########################################################################
# Contrôle de la date de fin
$C_VALENDDAT
Local Integer OK
Local Integer WOK

# la date fin doit être comprise entre les dates de
# validité de l'entête
If VALEUR<>[0/0/0]
   If ([M:ROU0]ROUSTRDAT<>[0/0/0] & VALEUR < [M:ROU0]ROUSTRDAT) |
&     ([M:ROU0]ROUENDDAT<>[0/0/0] & VALEUR > [M:ROU0]ROUENDDAT)
      mkstat=2 : GMESSAGE=mess(10,193,1) : End
   Endif
Endif

OK = 1
#la date fin de l'opération n doit être antérieure à la
#date début de l'opération n+1
If [M:ROU0]DATREF=[0/0/0]
    Call VERIF_VARIANTE(2,nolign,WOK)
    If WOK=1 & [M:ROU1]VALSTRDAT(nolign)<=VALEUR
       # If VALEUR=[0/0/0]  : # GH 14/01/2014 bug 95829
       If VALEUR = [0/0/0] |  [M:ROU1]VALENDDAT(nolign)<=VALEUR
          GMESSAGE = mess(193,193,1) : mkstat=1 : End
       Endif
       Call OUINON (mess(159,190,1),OK) From GESECRAN
       If OK<>2 : mkstat = 1 : End : Endif
       [M:ROU1]UPDFLG(nolign) = 2     # signale que ligne a été modifiée
       [M:ROU1]VALSTRDAT(nolign) = VALEUR +1 : Affzo  [M:ROU1]VALSTRDAT(nolign)
    Endif

    # valeur nulle interdite si une variante d'opération suit
    If WOK=1 & VALEUR=[0/0/0] & [M:ROU1]VALSTRDAT(nolign)<>[0/0/0]
        VALEUR = [M:ROU1]VALSTRDAT(nolign)-1
    Endif
Endif


# la date de fin doit être > à la date début opération
If instr(1,dbgstr(1),"ROU1") | GIMPORT
    If VALEUR <>[0/0/0] & VALEUR < [M:ROU1]VALSTRDAT(nolign-1)
     mkstat=2 : End : Endif
Elsif instr(1,dbgstr(1),"ROF0")
  If VALEUR <>[0/0/0] & VALEUR < [M:ROF0]VALSTRDAT
     mkstat=2 : End : Endif
Endif


# idem pour la ligne suivante
If instr(1,dbgstr(1),"ROU1") | GIMPORT
  If [M:ROU1]OPENUM(nolign-1)= [M:ROU1]OPENUM(nolign)
    If [M:ROU1]VALENDDAT(nolign)<>[0/0/0] & [M:ROU1]VALSTRDAT(nolign)> [M:ROU1]VALENDDAT(nolign)
        [M:ROU1]VALSTRDAT(nolign)=[0/0/0] : Affzo [M:ROU1]VALSTRDAT(nolign)
        GMESSAGE = mess(193,193,1)  : mkstat = 2 : End
    Endif
  Endif
Elsif instr(1,dbgstr(1),"ROF0")
  If [M:ROF0]OPENUM= [M:ROU1]OPENUM(nolign)
    If [M:ROU1]VALENDDAT(nolign)<>[0/0/0] & [M:ROU1]VALSTRDAT(nolign)> [M:ROU1]VALENDDAT(nolign)
        [M:ROU1]VALSTRDAT(nolign)=[0/0/0] : Affzo [M:ROU1]VALSTRDAT(nolign)
        GMESSAGE = mess(193,193,1) : mkstat = 2 : End
    Endif
  Endif
Endif
Return

#########################################################################
$C_OPENUM
Local Integer L : L = nolign-1

If L<>0 & VALEUR < [M:ROU1]OPENUM(L-1)                   : mkstat = 2 : Return : Endif
If [M:ROU1]NBLIG > nolign & VALEUR > [M:ROU1]OPENUM(L+1) : mkstat = 2 : Return : Endif

# si numéro d'OP déjà utilisé
# Issue 104937 - 2015-11 by GH : versioning
#If [M:ROU0]DATREF<>[0/0/0]
#    Look [ROO]ROO0 = [M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;VALEUR
#    If !fstat : mkstat=2 : GMESSAGE=mess(191,193,1) : Return : Endif
#Endif
If [M:ROU0]DATREF<>[0/0/0]
    If dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ<>0 & find(VALEUR,[M:ROU1]OPENUM(0..nolign-2),[M:ROU1]OPENUM(nolign..[M:ROU1]NBLIG-1))
       Return
    Endif
    # consider the hidden operations
    Filter [ROO] Where (VALSTRDAT > [M:ROU0]DATREF | (VALENDDAT < [M:ROU0]DATREF & VALENDDAT<>[0/0/0]))
    Look [ROO]ROO0(4) = [M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;VALEUR
    Filter [ROO]
    If fstat<=2 : GMESSAGE=mess(191,193,1) : mkstat=2 : Return : Endif
Endif
Return

#########################################################################
$AS_TIMCOD
If clalev ([TRO])=0 : Local File TABROUALT [TRO] : Endif
If clalev ([ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If instr(1,dbgstr(1),"ROU1") | GIMPORT
 Case VALEUR
   When 1 : [M:ROU1]BASQTY(nolign-1)=1
   When 2 : [M:ROU1]BASQTY(nolign-1)=100
   When 3 : [M:ROU1]BASQTY(nolign-1)=1000
   When 4
     If GREP="C" | GREP="D"
        Read [TRO]TRO0=[M:ROU0]ROUALT
        If ! fstat & [F:TRO]FCY<>""
           Read [ITF]ITF0=[M:ROU0]ITMREF;[F:TRO]FCY
           If ! fstat : [M:ROU1]BASQTY(nolign-1)=[F:ITF]MFGLOTQTY : Endif
        Else
           [M:ROU1]BASQTY(nolign-1)=0
        Endif
     Endif
   When Default : [M:ROU1]BASQTY(nolign-1)=0
 Endcase
 If !GIMPORT : Affzo [ROU1]BASQTY(nolign-1) : Endif
Elsif instr(1,dbgstr(1),"ROF1")
 Case VALEUR
   When 1 : [M:ROF1]BASQTY=1
   When 2 : [M:ROF1]BASQTY=100
   When 3 : [M:ROF1]BASQTY=1000
   When 4
     If GREP="C" | GREP="D"
        Read [TRO]TRO0=[M:ROU0]ROUALT
        If ! fstat & [F:TRO]FCY<>""
           Read [ITF]ITF0=[M:ROU0]ITMREF;[F:TRO]FCY
           If ! fstat : [M:ROF1]BASQTY=[F:ITF]MFGLOTQTY : Endif
        Else
           [M:ROF1]BASQTY=0
        Endif
     Endif
   When Default : [M:ROF1]BASQTY=0
 Endcase
 If !GIMPORT : Affzo [ROF1]BASQTY : Endif
Endif
Return

