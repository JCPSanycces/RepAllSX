Return

#########################################################################
## GH 05/10/11 bug 76828 on gère sur ROUALT et FCY le cas d'un Local File ROUTING [ROH] Where ... en amont

$APRES_MODIF
Case COUZON
 When "ROUALT"
  If TUNNEL
    I=val(CZ)
    Read [TRO]TRO0 = I
    If !fstat & [F:TRO]FCY<>""
     Look [ROH]ROH0 = [M:ROU0]ITMREF;I;[F:TRO]FCY
     If fstat & func EXISTE(I,[F:TRO]FCY)
      mkstat=2 : GMESSAGE=mess(8,123,1) : # Accès impossible à cette fiche
      OK=-1 : Return
     Endif
    Elsif [M:ROU0]FCY<>"" : # GH 25/11/13 bug 94517
     Look [ROH]ROH0 = [M:ROU0]ITMREF;I;[M:ROU0]FCY
     If fstat & func EXISTE(I,[M:ROU0]FCY)
      mkstat=2 : GMESSAGE=mess(8,123,1) : # Accès impossible à cette fiche
      OK=-1 : Return
     Endif
    Endif
  Endif
  # 27172 01.05 MM
  Read [ACC]CODACC = GUSER;[F:TRO]ACSCOD
  If !fstat & [F:ACC]MODIF=1 & GREP="C"
   mkstat =2 : GMESSAGE = mess(144,199,1)  #Pas d'autorisation de modification sur cette alternative
  Endif

 When "DATREF"
  OK=-1
  [M:ROU0]DATREF = CZ    # car [M] pas encore chargé ! GH 11/2015
  Raz [M:ROU1]
  Raz [M:ROU3]
  Gosub LIENS From SUBROUA
  If !GIMPORT
      Affzo [M:ROU1]1-99
      Affzo [M:ROU3]1-99
  Endif

 When "FCY"
  If TUNNEL
   Look [ROH]ROH0 = [M:ROU0]ITMREF;[M:ROU0]ROUALT;CZ
   If fstat & func EXISTE([M:ROU0]ROUALT,CZ)
    mkstat=2 : GMESSAGE=mess(8,123,1) : # Accès impossible à cette fiche
    OK=-1 : Return
   Endif
  Endif
Endcase

Gosub APRES_MODIF From ECCROU # Issue 104937 - 2015-11 by GH : versioning
OMODIF = 1
Return

Funprog EXISTE(ALT,FCY)
Value Integer ALT
Value Char FCY()
Local File ROUTING [ROH]
Look [ROH]ROH0 = [M:ROU0]ITMREF;ALT;FCY
If !fstat : End 1
Else      : End 0
Endif
End

#########################################################################
$APRES_CRE
Local Integer WFOUND
Raz WFOUND

Gosub APRES_CRE From ECCROU  # Issue 104937 - 2015-11 by GH : versioning

Gosub SET_CLE From GOBJSUB
CLECUR=1
If !GIMPORT : Gosub RELIT From GOBJSUB : Endif

#  #----- Affichage icone texte -----#
If !GIMPORT
    If [M:ROU0]TEXNUM <>""
       Call SET_IMAGE(4)   From GESECRAN
    Else
       Call RESET_IMAGE(4) From GESECRAN
    Endif
Endif

# 24415 11.04 MM
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
#  ouverture des nomencl. entête sous autre abréviation
If clalev([F:ROHW])=0 : Local File ROUTING [ROHW] : Endif

# report du code accès appliqué à la gamme dans [F:ROH]ACSCOD
# il existe déjà une gamme qui possède cette alternative
Filter [ROH] Where ROUALT=[M:ROU0]ROUALT
For [ROH]
    If [F:ROH]ITMREF<>[M:ROU0]ITMREF
        WFOUND=1
        OK=adxlog : # Issue 104937 - 2015-11 by CCC : versioning
        If !OK : Trbegin [ROHW] : Endif
        Readlock [ROHW]ROH0=[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU0]FCY : # Beryl Site en fin de clé primaire
        If !fstat
            [F:ROHW]ACSCOD =  [F:ROH]ACSCOD
            Rewrite [ROHW]
            If fstat & !OK : Rollback : OK=1 : Endif
        Endif
        Unlock [ROHW]
        If !OK : Commit : Endif
        OK = 1
    Endif
    If WFOUND=1 Break Endif
Next
Filter [ROH]

# c'est la première gamme qui possède cette alternative
If !WFOUND
    Read [TRO]TRO0 =[M:ROU0]ROUALT
    If !fstat
        Read [ACC]CODACC=GUSER;[F:TRO]ACSCOD
        If !fstat
            If [F:ACC]CODACC <>""
                OK=adxlog : # Issue 104937 - 2015-11 by CCC : versioning
                If !OK : Trbegin [ROH] : Endif
                Readlock [ROH]ROH0=[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU0]FCY : # Beryl Site en fin de clé primaire
                If !fstat
                    [F:ROH]ACSCOD = [F:ACC]CODACC
                    Rewrite [ROH]
                    If fstat & !OK : Rollback : OK=1 : Endif
                Endif
                Unlock [ROH]
                If !OK : Commit : Endif
                OK = 1
            Endif
        Endif
    Endif
Endif
Return

