# alimentation des zones liées aux postes de charge
$AV_OPENUM
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> 0
 If [M:ROF1]WST <> ""
  Read [MWS]WST0=[M:ROF1]WST;[M:ROU0]FCY
  If ! fstat
   [M:ROF1]WCR=[F:MWS]WCR
#   [M:ROF1]WSTDES=[F:MWS]WSTDES
   #LECTURE du libellé traduisible
   Call LECTEXTRA([M:ROF1]WSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
   [M:ROF1]WSTTYP=[F:MWS]WSTTYP
   [M:ROF1]XWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  Endif
 Endif
 If [M:ROF1]LABWST <> ""
  Read [MWS]WST0=[M:ROF1]LABWST;[M:ROU0]FCY
  If ! fstat
   [M:ROF1]LABWCR=[F:MWS]WCR
#   [M:ROF1]LABWSTDES=[F:MWS]WSTDES
   #LECTURE du libellé traduisible
   Call LECTEXTRA([M:ROF1]LABWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA

   [M:ROF1]LABWSTTYP=[F:MWS]WSTTYP
   [M:ROF1]XLABWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  Endif
 Endif
 If [M:ROF2]SCOWST <> ""
  Read [MWS]WST0=[M:ROF2]SCOWST;[M:ROU0]FCY
  If ! fstat
   [M:ROF2]SCOWCR=[F:MWS]WCR
 #  [M:ROF2]SCOWSTDES=[F:MWS]WSTDES
   #LECTURE du libellé traduisible
   Call LECTEXTRA([M:ROF2]SCOWSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
   [M:ROF2]SCOWSTTYP=[F:MWS]WSTTYP
   [M:ROF2]XSCOWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  Endif
 Endif
Endif
Return

