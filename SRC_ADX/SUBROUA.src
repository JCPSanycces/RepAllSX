If dim(ORPL) > 0 : Kill ORPL  : Endif
If dim([V]OMODIF) > 0
   #Kill OMODIF : # GA 09/2007 erreur en import de gamme OMODIF inexistant
   # GH 16/09/2015 bug 105074
   If dim([L]SAV_OMODIF)<0 : Kill OMODIF : Else [V]OMODIF = [L]SAV_OMODIF : Endif
Endif
