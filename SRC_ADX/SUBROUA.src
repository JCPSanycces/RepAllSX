#########################################################################
$D_BASQTY
If clalev ([TRO])=0 : Local File TABROUALT [TRO] : Endif
If clalev ([ITF])=0 : Local File ITMFACILIT [ITF] : Endif
Local Integer VTIMCOD
If instr(1,dbgstr(1),"ROU1") | GIMPORT : VTIMCOD=[M:ROU1]TIMCOD(nolign-1) : Endif
If instr(1,dbgstr(1),"ROF1")           : VTIMCOD=[M:ROF1]TIMCOD : Endif
Case VTIMCOD
     When 1 : VALEUR=1
     When 2 : VALEUR=100
     When 3 : VALEUR=1000
     When 4
          Read [TRO]TRO0=[M:ROU0]ROUALT
          If ! fstat & [F:TRO]FCY<>""
             Read [ITF]ITF0=[M:ROU0]ITMREF;[F:TRO]FCY
             If ! fstat : VALEUR=[F:ITF]MFGLOTQTY : Endif
          Endif
     When Default : VALEUR=0
Endcase
Return

#########################################################################
$B2_STDOPENUM
If VALEUR=0 : Return : Endif

Local Integer OK
If GIMPORT
    OK = 2
Else
    OK = 1
    Call OUINON(mess(1,190,1),OK) From GESECRAN
Endif
If OK<>2 : Return : Endif

If clalev([F:ROT])=0 : Local File ROUOPESTD [ROT] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:TCO])=0 : Local File TABCOEFF  [TCO] : Endif

Local Integer     LIG, LCAP
Local Decimal     KHM, VOPESTUCOE

#LCAP = 0
#If dim([M:ROU1]OPENUMLEV(nolign-1)) > 0 : LCAP = 1 : Endif
LCAP = 1

Read [ROT]ROT0=VALEUR;[M:ROU0]FCY
If !fstat
    LIG=nolign
    If instr(1,dbgstr(1),"ROU1") | GIMPORT
        If [F:ROT]OPEUOM="" : [F:ROT]OPEUOM=[M:ROU1]OPEUOM(nolign-1) : Endif
        Read [ITM]ITM0=[M:ROU0]ITMREF
        If !fstat & [F:ROT]OPEUOM<>[F:ITM]STU
           Read [TCO]TCO0=[F:ITM]STU;[F:ROT]OPEUOM
           If !fstat
               VOPESTUCOE=[F:TCO]COEUOM
           Else
               VOPESTUCOE=1        # 40660 mm 04.07
           Endif
        Elsif !fstat & [F:ROT]OPEUOM=[F:ITM]STU : VOPESTUCOE=1
        Endif
        Gosub CONVERSION
        [M:ROU1]=[F:ROT]
        # FGR 21/09/2009 : X3SUIVI57981
        #[M:ROU1]ROODES(nolign-1)=[F:ROT]STDOPEDES
        # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
        Call LECTEXTRA([M:ROU1]ROODES(nolign-1),"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
        [M:ROU1]OPESTUCOE(nolign-1)=VOPESTUCOE
        [M:ROU1]ROOTEX(nolign-1) = [F:ROT]OPETEXNUM
        # 17809 MM 07.05
        [M:ROU1]SETTIMTMP(nolign-1) = [F:ROT]SETTIM
        [M:ROU1]OPETIMTMP(nolign-1) = [F:ROT]OPETIM
        [M:ROU1]PRPTIMTMP(nolign-1) = [F:ROT]PRPTIM
        [M:ROU1]WAITIMTMP(nolign-1) = [F:ROT]WAITIM
        [M:ROU1]PSPTIMTMP(nolign-1) = [F:ROT]PSPTIM
        # fin 17809 MM 07.05
        nolign=LIG
        If !GIMPORT
            Affzo [ROU1]1-99
            nolign=LIG
            zonsui="WST(nolign-1)"
        Endif
   Elsif instr(1,dbgstr(1),"ROF0")
       If [F:ROT]OPEUOM="" : [F:ROT]OPEUOM=[M:ROF1]OPEUOM : Endif
       Read [ITM]ITM0=[M:ROU0]ITMREF
       If !fstat & [F:ROT]OPEUOM<>[F:ITM]STU
           Read [TCO]TCO0=[F:ITM]STU;[F:ROT]OPEUOM
           If !fstat
               VOPESTUCOE=[F:TCO]COEUOM
           Else
               VOPESTUCOE=1
           Endif
       Elsif !fstat & [F:ROT]OPEUOM=[F:ITM]STU : VOPESTUCOE=1
       Endif
       Gosub CONVERSION
      [M:ROF0]=[F:ROT] : [M:ROF1]=[F:ROT] : [M:ROF2]=[F:ROT]
      # 17809 MM 07.05
      [M:ROF1]SETTIMTMP = [F:ROT]SETTIM
      [M:ROF1]OPETIMTMP = [F:ROT]OPETIM
      [M:ROF1]PRPTIMTMP = [F:ROT]PRPTIM
      [M:ROF1]WAITIMTMP = [F:ROT]WAITIM
      [M:ROF1]PSPTIMTMP = [F:ROT]PSPTIM
      # fin 17809 MM 07.05
      If LCAP <> 0 : [M:ROF3]=[F:ROT] : Endif
     [M:ROF1]OPESTUCOE=VOPESTUCOE
     # FGR 21/09/2009 : X3SUIVI57981
     #[M:ROF0]ROODES=[F:ROT]STDOPEDES
     # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
     Call LECTEXTRA([M:ROF0]ROODES,"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
     [M:ROF2]OPETEXNUM = [F:ROT]OPETEXNUM
     If !GIMPORT
         Affzo [ROF0]1-99
         Affzo [ROF1]1-99
         Affzo [ROF2]1-99
         If LCAP <> 0 : Affzo [ROF3]1-99 : Endif
     Endif
     If [M:ROF2]SCOCOD = 1 : Grizo [M:ROF2]30 : Actzo [M:ROF2]SCOCOD : Else : Actzo [M:ROF2]30 : Endif
  Endif
Endif
Return

#########################################################################
$D_OPEUOM
If clalev ([ITM])=0 : Local File ITMMASTER [ITM] : Endif
Read [ITM]ITM0=[M:ROU0]ITMREF
If !fstat : VALEUR=[F:ITM]STU : Endif
Return

#########################################################################
$AM_OPEUOM
Local Decimal WCOEFF
# recherche coefficient US/UO
If clalev ([ITM])=0 : Local File ITMMASTER [ITM] : Endif
Read [ITM]ITM0=[M:ROU0]ITMREF
If !fstat
    Call RECH_COEFF([F:ITM]STU, VALEUR, WCOEFF) From MFGLIB
    If WCOEFF <> 0
        If GIMPORT
            [M:ROU1]OPESTUCOE(nolign-1) = WCOEFF
        Else
            If instr(1,dbgstr(1),"ROU1")
                [M:ROU1]OPESTUCOE(nolign-1) = WCOEFF
            Else
                [M:ROF1]OPESTUCOE           = WCOEFF
            Endif
        Endif
    Endif
Endif
If dim(SAVNOLIGN)>0 and instr(1,dbgstr(1),"ROF0") Then
  nolign = SAVNOLIGN
Endif
If [M:ROU1]CREFLG(nolign-1)<>0
   If !GIMPORT
       If instr(1,dbgstr(1),"ROU1")
          If [M:ROU1]ROOTIMCOD(nolign-1)=1
             Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="OPETIM(NOLIGN-1)"
          Elsif [M:ROU1]ROOTIMCOD(nolign-1)=2
             Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="CAD(NOLIGN-1)"
          Endif
       Elsif  instr(1,dbgstr(1),"ROF1")
          If [M:ROF1]ROOTIMCOD=1
             Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="OPETIM"
          Elsif [M:ROF1]ROOTIMCOD=2
             Call MESSAGE (mess(23,193,1)) From GESECRAN : zonsui="CAD"
          Endif
       Endif
   Endif
Endif
#
Return

#########################################################################
# Recherche des variantes d'opération
Subprog VERIF_VARIANTE ( LSENS,LIG,WOK)
Value Integer LSENS  # FGR 14/01/2010 : X3SUIVI60986
Value Integer LIG    # FGR 14/01/2010 : X3SUIVI60986

# LSENS= Type variante (1= précédante , 2= suivante)
# LIG = n° ligne courante
Variable Integer WOK        #  Si variante existe, WOK=1 , sinon WOK=2
WOK=0
# Comparaison n° opération ligne courante/précédante
If LSENS = 1
  If LIG>1
      If instr(1,dbgstr(1),"ROU1") | GIMPORT
        If  [M:ROU1]OPENUM(LIG-2)= [M:ROU1]OPENUM(LIG-1)
            WOK=1
        Endif
      Elsif instr(1,dbgstr(1),"ROF0")
         If  [M:ROU1]OPENUM(LIG-2)= [M:ROF0]OPENUM
            WOK=1
        Endif
      Endif
  Endif
Endif

# Comparaison n° opération ligne courante/suivante
If LSENS=2
  If instr(1,dbgstr(1),"ROU1") | GIMPORT
      If [M:ROU1]OPENUM(LIG)<>0 & [M:ROU1]OPENUM(LIG)=[M:ROU1]OPENUM(LIG-1)
         WOK=1
      Endif
  Elsif instr(1,dbgstr(1),"ROF0")
      If [M:ROU1]OPENUM(LIG)<>0 & [M:ROU1]OPENUM(LIG)=[M:ROF0]OPENUM
         WOK=1
      Endif
 Endif
Endif
End

##########################################################################
Subprog ROURPL(LOPE,LOPENEW)
Value    Integer  LOPE
Value    Integer  LOPENEW
Local Integer I, J

For I = 0 To [M:ROU1]NBLIG-1
    If [M:ROU1]OPENUM(I)  = LOPE
       [M:ROU1]OPENUM(I) =  LOPENEW
       #[M:ROU3]OPENUM(I) = [M:ROU1]OPENUM(I) : # GH 05/10/2015 bug 105524
       For J=0 To [M:ROU3]BASTAB - 1
           If [M:ROU3]OPENUM(J)    = LOPE : [M:ROU3]OPENUM(J)    = LOPENEW : Endif : # GH 05/10/2015 bug 105524
           #If [M:ROU3]NEXOPENUM(J) = LOPE : [M:ROU3]NEXOPENUM(J) = LOPENEW : Endif : # Issue 88670 - 2015-12-04 by GH : done below
       Next J
       [M:ROU1]CREFLG(I)  = 0 : # pour considérer la ligne comme nouvelle
       [M:ROU1]UPDFLG(I)  = 1
       [M:ROU1]CONCATKEY(I) = num$(LOPENEW) + num$([M:ROU1]RPLIND(I))
       #If !GIMPORT : Affzo [ROU1]OPENUM(I) : Endif : # Issue 88670 - 2015-12-04 by GH : done below
    Endif
Next I

# Issue 88670 - 2015-12-04 by GH : resort the card Operation not to have pb in insertion of new lines afterward
Sorta [M:ROU1]NBLIG [M:ROU1]NBLIG Order By [M:ROU1]OPENUM(indice),[M:ROU1]RPLIND(indice)
If !GIMPORT : Affzo [M:ROU1]1-99 : Endif

# Issue 88670 - 2015-12-04 by GH : recalculate the next operation colummn in card Scheduling
Sorta [M:ROU3]BASTAB [M:ROU3]BASTAB Order By [M:ROU3]OPENUM(indice)
Gosub RAF_ROU3 From SUBROU
#If !GIMPORT : Affzo [M:ROU3]1-99 : Endif

mkstat = 4
End

##########################################################################
Subprog ROURPL1(LOPEINC)
Value Integer LOPEINC
Local Integer I, J, K
Local Integer LASTNUM

# Issue 112982 - 2015-12-04 by GH : when an old operation value is used as new operation value
Local Integer JALOPE ([M:ROU3]BASTAB)
Local Integer JALNEX ([M:ROU3]BASTAB)
For K=0 To [M:ROU3]BASTAB - 1
    [L]JALOPE(K) = [M:ROU3]OPENUM(K)
    [L]JALNEX(K) = [M:ROU3]NEXOPENUM(K)
Next K

LASTNUM = 0
J = 0
For I = 0 To [M:ROU1]NBLIG-1
    If [M:ROU1]OPENUM(I) <> LASTNUM | LASTNUM = 0
       LASTNUM            = [M:ROU1]OPENUM(I)
       [M:ROU1]OPENUM(I)  = (J + 1 ) * LOPEINC
       J += 1
    Else
        [M:ROU1]OPENUM(I)  = [M:ROU1]OPENUM(I-1)
    Endif
    #[M:ROU3]OPENUM(I)  = [M:ROU1]OPENUM(I) : # GH 05/10/2015 bug 105524
# Issue 112982 - 2015-12-04 by GH : when an old operation value is used as new operation value
#    For K=0 To [M:ROU3]BASTAB - 1
#        If [M:ROU3]OPENUM(K) = LASTNUM    : [M:ROU3]OPENUM(K)    = [M:ROU1]OPENUM(I) : Endif : # GH 05/10/2015 bug 105524
#        If [M:ROU3]NEXOPENUM(K) = LASTNUM : [M:ROU3]NEXOPENUM(K) = [M:ROU1]OPENUM(I) : Endif
#    Next K
    For K=0 To [M:ROU3]BASTAB - 1
        If [L]JALOPE(K) = LASTNUM : [M:ROU3]OPENUM(K)    = [M:ROU1]OPENUM(I) : Endif : # GH 05/10/2015 bug 105524
        If [L]JALNEX(K) = LASTNUM : [M:ROU3]NEXOPENUM(K) = [M:ROU1]OPENUM(I) : Endif
    Next K
    [M:ROU1]CREFLG(I)  = 0 :# pour considérer la ligne comme nouvelle
    [M:ROU1]UPDFLG(I)  = 1
    [M:ROU1]CONCATKEY(I) = num$([M:ROU1]OPENUM(I)) + num$([M:ROU1]RPLIND(I))
    If !GIMPORT : Affzo [ROU1]OPENUM(I) : Endif
Next I
If !GIMPORT : Affzo [M:ROU3]1-99 : Endif
mkstat = 4
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ROUG) 14/12/2006 13:56:50 (SR)
######################################################################################
Subprog AM_WQTYREF(VALEUR)
Variable Decimal VALEUR
Local Char    WFCY(GLONFCY)
Local Char    WROO(GLONVCR)
Local Integer WALT
Local Date    WDAT
Local Decimal WQTY : WQTY = VALEUR

# MHB 23/10/08
# Soit le graphique est appelé depuis la gestion des gammes ==> écran ROU0 [ROU0]
# Soit le graphique est appelé depuis la gestion des gammes multi-niveaux ==> écran VISUROUG [VROG]
If clalev([M:ROU0]) Then
  WFCY = [M:ROU0]FCY
  WROO = [M:ROU0]ITMREF
  WALT = [M:ROU0]ROUALT
Else
  WFCY = [M:VROG]FCY
  WROO = [M:VROG]ROUNUM
  WALT = [M:VROG]ROUALT
Endif
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
If WFCY = "" : WFCY = GFCY : Endif

If GDATEREF=[0/0/0]
  If !GIMPORT : GDATEREF = date$ : Endif
Endif
WDAT = GDATEREF

Gosub CHARG_GRAPHE From FUNGROU
# si rien dans le tableau ou que des lignes avec 0 dans la durée
If [M:ROUG]NBLIGC = 0 | (sum([M:ROUG]LTI(0..[M:ROUG]NBLIGC-1)) = 0)
    End
Else
    Affzo [M:ROUG]1-99
Endif
End

