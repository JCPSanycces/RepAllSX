Return

########################################################################
$SUPPRESS_TEX
Local Integer WRET, I
# on ne vire les textes sur les données de base que si abandon en dupplication
If GREP = "D"
      Call SUP_CLOB([M:ROU0]TEXNUM,WRET) From TRTX3TEX
      For I=0 To [M]NBLIG-1
          Call SUP_CLOB([M:ROU1]ROOTEX(I),WRET) From TRTX3TEX
      Next I
Endif
Call RAZ_CLOB From ACLOB

Return

