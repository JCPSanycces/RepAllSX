#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
## Programme extension pour le traitement SUBROU (objet ROU)
#########################################################################

#########################################################################
# Etiquettes de déroutement du prog SUBROU pour les actions
#########################################################################
## déclaration des variables
$OUVRE
Local Char    FICLIG(10) , ABLIG(5) , CRIT(250), TRTLIG(1)
Local Integer STAT , SIGN , MAXLIG, PREM
Global Integer OOPE(dim([M:ROU1]NOLIG))
Global Integer ORPL(dim([M:ROU1]NOLIG))
Global Integer OINSERT

#Global Integer OMODIF : # GH 16/09/2015 bug 105074
If dim([V]OMODIF)<0
   Global Integer OMODIF
Else
   Local Integer SAV_OMODIF
   SAV_OMODIF = [V]OMODIF
   [V]OMODIF=0
Endif

If dim(GDATEREF)<0 Then
  Global Date    GDATEREF
Endif
If GDATEREF=[0/0/0]
    If !GIMPORT : GDATEREF = date$ : Endif # par défaut affichage gamme active a date du jour
Else
    Local Date RWARP
    RWARP = GDATEREF
Endif
#
Call INIVAR    From MFGLIB

If clalev([F:PJA]) = 0 : Local File PARJAL      [PJA]  : Endif
If clalev([F:TRO]) = 0 : Local File TABROUALT   [TRO]  : Endif
Gosub OUVRE From ECCROU # Issue 104937 - 2015-11 by GH : versioning

If dim(SDATEREF)<=0 : Global Date   SDATEREF : Endif
SDATEREF = GDATEREF
OINSERT=0
Gosub DEFLIG

# Issue 112678 - 2015-11-20 by GH : values were not displayed for an inserted line
If dim([V]GTABZON)>0 & [V]GTABZON="ROU1" : Raz [V]GTABZON  : Endif
Return

$OUVRE_BOITE
## GH 06/10/11 bug 76807
If TUNNEL
 TUNCLE="zz" : # pour forcer le chargement de la liste gauche
 PREM=1      : # pour entrer en création dans AVANT_CHOI
Endif
Return

###########################################################################################
#    Avant l'execution des boutons et des menus                                           #
###########################################################################################
$AVANTBOUT
Local Char     WFONC1(30)
Local Char     WTYP(4), WTEX(12), WANCTEX(12), SYMBOLE2(20)
Local Integer  WCOD
Local Integer  WMODULE    :    WMODULE = 8
GERR=0
# Pour etre sur qu'il soit bien chargé
GFCY=[M]FCY
Case BOUT
    When "1" :      Global Date    GDATREF     : GDATREF = [M:ROU0]DATREF
                    Global Decimal GQTYREF     : GQTYREF = 0
 #                  Global Integer GALT        : GALT    = [M:ROU0]ROUALT


                    If GDATREF = [0/0/0] : GDATREF = date$ : Endif
                    # Quantité de base = qté réappro ou qté min ou qté max ou 1
                    Read [ITF]ITF0=[M:ROU0]ITMREF;[M:ROU0]FCY
                    If fstat = 0
                        GQTYREF = [F:ITF]REOMINQTY
                    Endif
                    If GQTYREF = 0
                       GQTYREF = [M:ROU2]WORMINQTY
                    Endif
                    If GQTYREF = 0
                       GQTYREF = [M:ROU2]WORMAXQTY
                    Endif
                    If GQTYREF = 0
                       GQTYREF = 1
                    Endif
Endcase
Return

###########################################################################################
$EXEBOUT
Case BOUT
  When "2" : # Cas d'emploi de gammes - Objet ROW - Index ROH1
    Local Char     WCLE1(30)
    Local Char     WCLE2(30) (2)
    WCLE1    = [M:ROU0]FCY
    WCLE2(0) = [M:ROU0]ITMREF
    WCLE2(1) = num$([M:ROU0]ROUALT)
    Global Char GFLTROW (250)
    GFLTROW = 'ITMREF="'+[M:ROU0]ITMREF+'"& ROUALT='+num$([M:ROU0]ROUALT)+' & FCY="'+[M:ROU0]FCY+'"'
    If [F:ROH]ITMREF<>[M:ROU0]ITMREF | [F:ROH]FCY<>[M:ROU0]FCY | [F:ROH]ROUALT<>[M:ROU0]ROUALT
       Read [ROH]ROH1=[M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT
       If fstat Raz [F:ROH] : Return : Endif
    Endif
    Call OBJET_CHAR(WCLE1,"ROW",WCLE2(0)+"~"+WCLE2(1)) From GOBJET
    If dim(GFLTROW)>0 Kill GFLTROW Endif
Endcase
Return

###########################################################################################
$STATUT
If mkstat=4 & GREP=""
      #MAE, bg 50938
      #GREP="M" : REP="M"
      #Gosub SETBOUT From GOBJSUB
      Gosub ENTRE_MODIF From GOBJSUB
Endif
If [M:ROU0]TEXNUM <> "" & !GIMPORT
    Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT
    Call RESET_IMAGE (4) From GESECRAN
Endif

Gosub STATUT From ECCROU # Issue 104937 - 2015-11 by GH : versioning
Return

#########################################################################
## remise à zéro du nombre de ligne si creation
$RAZCRE
Call RAZ_CLOB From ACLOB
Raz [M:ROU0]TEXNUM
Raz [M:ROU1]ROOTEX
If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif
#
[M:ROU1]NBLIG=0 : [M:ROU3]BASTAB=0 : Raz [M:ROU1] : Raz [M:ROU3]

## GH 06/10/11 bug 76807
If TUNNEL & SAVCLE2<>""
 [M:ROU0]ITMREF=SAVCLE2
 If dim([M:ROU0]ZITMREF)=1 : Affzo [ROU0]ZITMREF : Endif
 SUIZON="ROUALT"
Endif

Gosub AFFMASK From ECCROU # Issue 104937 - 2015-11 by GH : versioning

# Issue 110957 - 2015-09-21 by CCC
If !GIMPORT
   If dim([M:ROU0]CRID)>0 : Diszo [ROU0]CRID : Endif
Endif
Return

#########################################################################
$RAZDUP
Local Integer I, WRET
Call RAZ_CLOB From ACLOB
# on ne duplique pas si c'est un lien vers ITM
If left$([M:ROU0]TEXNUM,3) <> "ITM"
    Call DUP_CLOB("ROH",[M:ROU0]TEXNUM,WRET) From TRTX3TEX
    If WRET<1 Raz [M:ROU0]TEXNUM : Endif
Endif

For I=0 To [M:ROU1]NBLIG-1
    Call DUP_CLOB("ROO",[M:ROU1]ROOTEX(I),WRET) From TRTX3TEX
    If WRET<1 Raz [M:ROU1]ROOTEX(I) : Endif
Next

# Issue 104937 - 2015-11-19 by CCC : While revion of version, do not reset CREFLG
If dim([L]TRTGBM)=1 & [L]TRTGBM="CRERVV" : Return : Endif
Gosub RAZDUP From ECCROU

Raz [M:ROU1]UPDFLG
Raz [M:ROU1]CREFLG
Return

#########################################################################
$AFFMASK
Gosub AFFMASK From ECCROU  # Issue 104937 - 2015-11 by GH : versioning
Return

#########################################################################
## définition du filtre de lecture
$DEFLIG
# le fichier des lignes doit être par défaut
Default File [ROO]
# Critère de lecture
# le critère suivant ne fonctionne pas !!!!!!!!
#Maintenant il devrait !!!!!
CRIT = '[F:ROO]FCY="'+[M:ROU0]FCY+ '" & [F:ROO]ITMREF="'+[M:ROU0]ITMREF+ '" & num$([F:ROO]ROUALT) = "'+num$([M:ROU0]ROUALT)+'"'
FICLIG = "ROUOPE" : ABLIG = "ROO" : # nom et abréviation du fichier lignes
Return

#########################################################################
## Lecture des lignes
$LIENS
Local Integer I, VOPE
Call RAZ_CLOB From ACLOB

If GDATEREF <> [0/0/0]
   [M:ROU0]DATREF = GDATEREF
Endif

Gosub LIENS1 From ECCROU # Issue 104937 - 2015-11 by GH : versioning

# Test de la validité
If GDATEREF <> [0/0/0] & ([F:ROH]ROUSTRDAT > GDATEREF | ([F:ROH]ROUENDDAT < GDATEREF & [F:ROH]ROUENDDAT<>[0/0/0]))
   Call MESSAGE(mess(8,193,1)) From GESECRAN
Endif

nolign = 0
If GDATEREF <> [0/0/0]
   VOPE=0
   # Issue 83770 GA 07/2012 Test VALSTRDAT added
   For [ROO]ROO0 Where FCY = [M:ROU0]FCY & ITMREF = [M:ROU0]ITMREF & ROUALT = [M:ROU0]ROUALT
&                    & (VALSTRDAT <= GDATEREF)
&                    & (VALENDDAT >= GDATEREF | VALENDDAT=[0/0/0])
       If [F:ROO]OPENUM<>VOPE
          VOPE=[F:ROO]OPENUM
          nolign += 1
          Gosub ZAFF
       Endif
   Next
Else
   For [ROO]ROO0 Where FCY = [M:ROU0]FCY & ITMREF = [M:ROU0]ITMREF & ROUALT = [M:ROU0]ROUALT
       nolign +=1
       Gosub ZAFF
   Next
Endif
[M:ROU1]NBLIG = nolign : MAXLIG=nolign

# chargement de la concaténation pour contrôle unicité
For I=0 To [M:ROU1]NBLIG-1
  [M:ROU1]CONCATKEY(I)=num$([M:ROU1]OPENUM(I))+num$([M:ROU1]RPLIND(I))
Next
Gosub LIENS From SUBROU3

#------------------------#
# Affichage icone texte  #
#------------------------#
If !GIMPORT
    If [M:ROU0]TEXNUM <> ""
        Call SET_IMAGE (4) From GESECRAN
    Else
        Call RESET_IMAGE (4) From GESECRAN
    Endif
Endif

Gosub LIENS2 From ECCROU  # Issue 104937 - 2015-11 by GH : versioning

# Issue 110957 - 2015-09-21 by CCC
If !GIMPORT
   If dim([M:ROU0]CRID)>0
      [M:ROU0]CRID = func TRTX3FNC.CCMID([M:ROU0]ITMREF,"","")
      Diszo [ROU0]CRID
   Endif
   If dim([M:ROU0]CRFLG)>0
      [M:ROU0]CRFLG = string$([M:ROU0]CRID<>"","151")
   Endif
Endif
Return

$ZAFF
[M:ROU1]=[F:ROO]
[M:ROU1]UPDFLG(nolign-1)=0 : [M:ROU1]CREFLG(nolign-1)=nolign
OOPE(nolign-1)=[F:ROO]OPENUM : ORPL(nolign-1)=[F:ROO]RPLIND
Return

#########################################################################
## Filtrage des données
$FILTRE
#If dim(GDATEREF)>0 & GDATEREF <> [0/0/0]
#   FILTSUP = "ROUSTRDAT<=GDATEREF & ((ROUENDDAT>=GDATEREF & ROUENDDAT<>[0/0/0]) | ROUENDDAT=[0/0/0])"
#Else
#   FILTSUP = ""
#Endif :## mis en commentaires pour pouvoir tout visualiser le 09/02/00    (TB)
If clalev([M:BOH0]) > 0 : Return : Endif : # pour SELOPE
If clalev([M:MFG2]) > 0 : Return : Endif : # pour SELOPE
If clalev([M:MFMW]) > 0 : Return : Endif : # pour SELOPE
If clalev([M:MBW1]) > 0 : Return : Endif : # pour SELOPE
If clalev([M:ITF5]) > 0 : Return : Endif : # pour SELROU (rajouté le 24/06/99)
If clalev([M:ROW]) > 0 : Return : Endif : # pour Cas d'emploi gammes (rajouté le 21/11/01 MM)

If GFONC1<>"GESROU"
  If GROUALT(0) <> 0
    If FILTSUP = ""
        FILTSUP="find(ROUALT, GROUALT)"
    Else
        FILTSUP-="& find(ROUALT, GROUALT)"
    Endif
  Endif
Endif
Return

#########################################################################

$VERIF_CRE
If [M:ROU1]NBLIG=0
   Call ERREUR(mess(9,193,1)) From GESECRAN : # la gamme n'a pas d'opérations
   If !GIMPORT : zonsui="[ROU1]NBLIG"  : Endif
   OK=0
Else : # GH 11/2015
  If clalev([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
  For I=0 To [M:ROU1]NBLIG-1
      Look [MWS]WST0 = [M:ROU1]WST(I);[M:ROU0]FCY
      If fstat
         Call ERREUR([M:ROU1]WST(I)-mess(196,193,1)-[M:ROU0]FCY) From GESECRAN
         If !GIMPORT : zonsui="[ROU1]NBLIG("+num$(I)+")" : Endif
         OK=0 : Break
      Endif
  Next
Endif
If !OK : Return : Endif

Gosub JALONNE_OK
Return

#########################################################################
## Modification des lignes
$MODIF
# débranchement vers le prog SUBROU3 si masque 3 (jalonnements)
Local Integer ICREA

# FGR 02/10/2009 : X3SUIVI58337
Call MAJTEXTRA([M:ROU0]ROUDESAXX, "ROUTING", "ROUDESAXX", [M:ROU0]ITMREF+"~"+num$([M:ROU0]ROUALT),[M:ROU0]FCY) From ATEXTRA

ICREA=0
Gosub DEFLIG

# première passe, lignes annulées
For nolign=1 To MAXLIG
    If !find(nolign, [M:ROU1]CREFLG(0..[M:ROU1]NBLIG-1))
       Readlock [ROO]ROO0=[M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;OOPE(nolign-1);ORPL(nolign-1)
       If fstat=1
          GOK=-1 : GLOCK = "$"+FICLIG-num$(nolign) : Break
       Elsif !fstat : # au cas où
          SIGN=-1 : Gosub VALLIG
          If GOK<1 : Break : Endif
          ICREA=1
          Delete [ROO] Where FCY = [M:ROU0]FCY & ITMREF=[M:ROU0]ITMREF & ROUALT=[M:ROU0]ROUALT
&                            & OPENUM=OOPE(nolign-1) & RPLIND=ORPL(nolign-1)
       Endif
     Endif
Next nolign
# deuxième passe, créations et modifications
For nolign=1 To [M:ROU1]NBLIG
       If [M:ROU1]CREFLG(nolign-1)=0 : # c'est une nouvelle ligne
       ICREA=1 : [F:ROO]=[M:ROU1]
       [F:ROO]ITMREF=[M:ROU0]ITMREF : [F:ROO]ROUALT=[M:ROU0]ROUALT : [F:ROO]FCY = [M:ROU0]FCY
       Gosub INICRE_LIG From TABLEAUX
       Gosub INICRE_LIG :# sr 080200
       Write [ROO]
       If fstat
          GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
       Endif
       SIGN=+1 : Gosub VALLIG
       If GOK<1 : Break : Endif
    Elsif [M:ROU1]UPDFLG(nolign-1) <> 0 : # la ligne a été modifiée
       Readlock [ROO]ROO0=[M:ROU0]FCY ;[M:ROU0]ITMREF;[M:ROU0]ROUALT;[M:ROU1]OPENUM(nolign-1);[M:ROU1]RPLIND(nolign-1)
       If fstat=1
          GOK=-1 : GLOCK="$"+FICLIG-num$(nolign) : Break
       Endif
       # on a viré le texte
       # on ne vire jamais les textes sur les données de base pour l'instant
       If [M:ROU1]ROOTEX(nolign-1)="" & [F:ROO]ROOTEX <> ""
#          Call SUP_CLOB([F:ROO]ROOTEX,WRET) From TRTX3TEX
       Endif
       [F:ROO]=[M:ROU1]
       [F:ROO]ITMREF = [M:ROU0]ITMREF : [F:ROO]ROUALT=[M:ROU0]ROUALT : [F:ROO]FCY = [M:ROU0]FCY
       Gosub INICRE_LIG :# sr 04.01 pour texte
       Rewrite [ROO]
       If fstat
          GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
       Endif
    Endif
Next nolign

# 12.05 33528
Gosub MODIF From SUBROU3
If GOK<1 : Return : Endif

# Issue 104937 - 2015-11 by GH : versioning
Gosub MODIF From ECCROU
If GOK<1 : Return : Endif
Return

#######################################################################
$INICRE_LIG
Local Integer WRETOUR
Local Char WNUMTEX (12)
Local Integer NOL : NOL = nolign-1
Local Integer I    # pour test

If [M:ROU1]ROOTEX(NOL)<>""
   If left$([M:ROU1]ROOTEX(NOL),3)="ROO"
      Call CRE_CLOB([M:ROU1]ROOTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:ROU1]ROOTEX(NOL),3),"ROT")
      Call DUP_CLOB("ROO",[M:ROU1]ROOTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:ROO]ROOTEX = [M:ROU1]ROOTEX(NOL)
Endif
Return

##########################################################################
$INICRE
# FGR 02/10/2009 : X3SUIVI58337
[F:ROH]IDENT1 = [M:ROU0]ITMREF + "~" + num$([M:ROU0]ROUALT)

If [M:ROU0]TEXNUM<>""
   If left$([M:ROU0]TEXNUM,3)="ROH"
      Call CRE_CLOB([M:ROU0]TEXNUM,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:ROU0]TEXNUM,3),"ITM")
      Call DUP_CLOB("ROH",[M:ROU0]TEXNUM,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
Else
    If [F:ITM]ITMREF <> [M:ROU0]ITMREF
        Read [F:ITM]ITM0 = [M:ROU0]ITMREF
        If fstat : Raz [F:ITM] : Endif
    Endif
    If [F:ITM]MFGTEX <> ""
       [M:ROU0]TEXNUM = [F:ITM]MFGTEX
    Endif
Endif
[F:ROH]TEXNUM = [M:ROU0]TEXNUM

Read [TRO]TRO0= [M:ROU0]ROUALT
[F:ROH]ACSCOD = [F:TRO]ACSCOD  # bug 6336  Code accès en Redondance 12/01/01
Return

#########################################################################
## Mises à jour diverses
$CREATION
# FGR 02/10/2009 : X3SUIVI58337
Call MAJTEXTRA([M:ROU0]ROUDESAXX, "ROUTING", "ROUDESAXX", [M:ROU0]ITMREF+"~"+num$([M:ROU0]ROUALT),[M:ROU0]FCY) From ATEXTRA

# débranchement vers le prog SUBROU3 si masque 3 (jalonnements)
Gosub CREATION From SUBROU3
# création des opérations de gamme
Gosub DEFLIG
For nolign = 1 To [M:ROU1]NBLIG
    [F:ROO] = [M:ROU1]
    [F:ROO]ITMREF = [M:ROU0]ITMREF : [F:ROO]ROUALT=[M:ROU0]ROUALT : [F:ROO]FCY = [M:ROU0]FCY
    Gosub INICRE_LIG From TABLEAUX
    Gosub INICRE_LIG
    Write [ROO]
    If fstat
       GOK = 0 : Call FSTA("ROO") From GLOCK : Break
    Endif
    SIGN=+1 : Gosub VALLIG
Next nolign
If GOK<1 : Return : Endif

Gosub CREATION From ECCROU # Issue 104937 - 2015-11 by GH : versioning
If GOK<1 : Return : Endif
Return

#########################################################################
## Traitements complémentaires effectués à la ligne
$VALLIG
# sr 04.02 perte des textes en renumérotation demande 13862
Local Integer I, WOK_SUPP_TEXTE
# la variable SIGN vaut +1 ou -1 selon création/modif
If SIGN=-1 : # on est en suppression de ligne
# on supprime l'enregistrement ROUSCD correspondant à l'opé supprimée
# si on n'a pas d'autre opération de même numéro
   If clalev([RO2])=0 : Local File ROUOPE [RO2] : Endif
   Filter [RO2] Where FCY = [F:ROO]FCY &
&                     ITMREF=[F:ROO]ITMREF & ROUALT=[F:ROO]ROUALT &
&                     OPENUM=[F:ROO]OPENUM  & RPLIND<>[F:ROO]RPLIND
   Read [RO2] First
   If !fstat
    Default File [F:ROO]   # MM le 18/04/02
    Return : Endif
   Readlock [F:ROS]ROS0=[F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
   If !fstat : Delete [F:ROS] : Endif

   # sr 04.02 demande 13862
   # on ne vire jamais les textes sur les données de base pour l'instant
   #Suppression du texte ssi ce même numéro n'est pas sur une autre ligne (cas de la renumérotation)
#   Raz WOK_SUPP_TEXTE
#   For I = 0 To [M:ROU1]NBLIG
#        If [M:ROU1]ROOTEX(I) = [F:ROO]ROOTEX & [M:ROU1]CREFLG(I) = 0
#           WOK_SUPP_TEXTE = 1
#           Break
#        Endif
#   Next
#   If WOK_SUPP_TEXTE <> 1
#       Local Char WNUMTEX(12)
#       Local Integer WRET
#       WNUMTEX = [F:ROO]ROOTEX
#       If WNUMTEX <> ""
#          WRET = 0
#         Call SUP_CLOB(WNUMTEX,WRET) From TRTX3TEX
#       Endif
#   Endif
   Default File [F:ROO]
Endif
Return

#########################################################################
$AVANT_MOD
Local Integer WOK

# demande 10018 MM 05/02
# Dans le cas où on cherche à modifier la gamme, on envoie un message d'avertissement
# si au moins un suivi sur un OF utilisant cette gamme a été réalisé
For [MFG] Where ROUNUM=[M:ROU0]ITMREF & ROUALT=[M:ROU0]ROUALT & MFGTRKFLG = 4
    WOK = 1
    Call AVERTIR(mess(198,193,1), WOK) From GESECRAN
    If WOK=1 : Raz OK : Raz GMESSAGE : Endif
    Break
Next
Return

#########################################################################
$VERIF_MOD
Local Integer TROUVE
Local Integer IANNULE

If GIMPORT : Return : Endif
If [M:ROU1]NBLIG = 0
    If GDATEREF <> [0/0/0]
       # Issue 83770 GA 07/2012 Test VALSTRDAT added
       For [ROO] Where FCY = [M:ROU0]FCY & ITMREF=[M:ROU0]ITMREF & ROUALT=[M:ROU0]ROUALT
&                    & (VALSTRDAT <= GDATEREF)
&                    & (VALENDDAT >= GDATEREF | VALENDDAT=[0/0/0])
          If !fstat : TROUVE=1 : Break : Endif
       Next
    Endif
    If TROUVE <> 1
       Call OUINON(mess(25,193,1),OK) From GESECRAN
       If OK=2 : IANNULE=1 : Endif
    Endif
Endif
Return

#########################################################################
# JALONNE_OK a été dupliqué en sous programme CTRJAL (CFGLIBD)
# pour utilisation sans affichage dans le configurateur
# Merci de reporter les modifications ou d'avertir M. Giet
#
$JALONNE_OK
Local Integer I
Local Integer OPEOK
Local Integer MFGOK
Local Integer IND1     # indices pour les matrices suivantes
Local Integer IND2


If [M:ROU3]BASTAB = 0 : Return : Endif
If GIMPORT & [M:ROU1]NBLIG  = 0 : Return : Endif

# matrice contenant les numéros d'opérations
Local Integer OPE(0..[M:ROU3]BASTAB-1,0..[M:ROU3]BASTAB-1)
# matrice contenant le rang des opérations dans le jalonnement
Local Integer RG(0..[M:ROU3]BASTAB-1,0..[M:ROU3]BASTAB-1)

# il faut une et une seule opération qui n'ait pas d'opération suivante
# et il faut au moins une opération productive
OPEOK=0 : MFGOK=0
For I=0 To [M:ROU3]BASTAB-1
    If [M:ROU3]NEXOPENUM(I)=0 : OPEOK+=1 : Endif
    If [M:ROU3]MFGMST(I)=2 : MFGOK+=1 : Endif
Next I
# il faut au moins une opé productive!
If MFGOK=0
    For I=0 To [M:ROU3]BASTAB-1
        If [M:ROU3]NEXOPENUM(I)=0
            [M:ROU3]MFGMST(I) = 2
            MFGOK = 1
            [M:ROU0]CFMFLG=2
            If !GIMPORT : Affzo [M:ROU3]1-99 : Endif
            Break
        Endif
    Next I
Endif
# il faut une dernière opération !
If OPEOK=0
    [M:ROU0]CFMFLG=1 : If !GIMPORT : Affzo [ROU0]CFMFLG : Endif
    Call MESSAGE(mess(20,193,1)) From GESECRAN
    Goto FIN_CONTROLE
Endif
# il faut une et une seule dernière opération !
If OPEOK>1
    [M:ROU0]CFMFLG=1 : If !GIMPORT : Affzo [ROU0]CFMFLG : Endif
    Call MESSAGE(mess(21,193,1)) From GESECRAN
    Goto FIN_CONTROLE
Endif
#
# contrôle de boucle proprement dit
#
$DEBUT
# mise à zéro des matrices OPE et RG
For IND1=0 To [M:ROU3]BASTAB-1
    For IND2=0 To [M:ROU3]BASTAB-1
         OPE(IND1,IND2)=0
         RG(IND1,IND2)=0
    Next IND2
Next IND1
IND1=0
IND2=0
#
RG(IND1,IND2)=find(0,[M:ROU3]NEXOPENUM(0..[M:ROU3]BASTAB-1))
If RG(IND1,IND2)<>0
    OPE(IND1,IND2)=[M:ROU3]OPENUM(RG(IND1,IND2)-1)
Else
   Goto FIN_BOUCLE
Endif
#
$BOUCLE1
IND1+=1
# quand on a fini de parcourir le réseau des opérations
If IND1<=0 | IND2<0 | IND1>=[M:ROU3]BASTAB | IND2>=[M:ROU3]BASTAB
   Goto FIN_BOUCLE
Endif
# recherche du réseau en branche directe
RG(IND1,IND2)=find(OPE(IND1-1,IND2),[M:ROU3]NEXOPENUM(0..[M:ROU3]BASTAB-1))
If RG(IND1,IND2)<>0
   OPE(IND1,IND2)=[M:ROU3]OPENUM(RG(IND1,IND2)-1)
   Goto BOUCLE1
Else
   IND2+=1
#
$BOUCLE2
# quand on a fini de parcourir le réseau
   If IND1<=0 |IND2<=0 | IND1>=[M:ROU3]BASTAB | IND2>=[M:ROU3]BASTAB
       Goto FIN_BOUCLE
   Endif
# recherche d'une autre opération précédente à partir d'un rang supérieur
# à la dernière opération précédente trouvée
   RG(IND1,IND2)=find(OPE(IND1-1,IND2-1),[M:ROU3]NEXOPENUM(RG(IND1,IND2-1)+1..[M:ROU3]BASTAB-1))
   If RG(IND1,IND2)<>0
       OPE(IND1,IND2)=[M:ROU3]OPENUM(RG(IND1,IND2)-1)
       Goto BOUCLE1
   Else
       IND1-=1
       Goto BOUCLE2
   Endif
Endif
#
$FIN_BOUCLE
# on vérifie que le nombre d'opérations trouvées dans le réseau
# correspond au nombre total d'opérations
I=0
For IND1=0 To [M:ROU3]BASTAB-1
    For IND2=0 To [M:ROU3]BASTAB-1
        If OPE(IND1,IND2)<>0 : I+=1 : Endif
    Next IND2
Next IND1
If I <> [M:ROU3]BASTAB
   [M:ROU0]CFMFLG=1 : If !GIMPORT : Affzo [ROU0]CFMFLG : Endif
   Call MESSAGE(mess(22,193,1)) From GESECRAN
Endif
#
$FIN_CONTROLE
If MFGOK<>0 & OPEOK=1 & I=[M:ROU3]BASTAB
   [M:ROU0]CFMFLG=2
   If !GIMPORT : Affzo [ROU0]CFMFLG : Endif
Endif
Return

#########################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
# on ne vire jamais les textes sur les données de base pour l'instant
If [M:ROU0]TEXNUM="" & [F:ROH]TEXNUM <> ""
#   Call SUP_CLOB([F:ROH]TEXNUM,WRET) From TRTX3TEX
Endif

Gosub JALONNE_OK
[F:ROH]CFMFLG=[M:ROU0]CFMFLG
Return

#########################################################################
$APRES_MOD
Gosub APRES_MOD From ECCROU : # Issue 104937 - 2015-11 by GH : versioning

If IANNULE=1 : Gosub ANNULATION : Endif
Gosub SET_CLE From GOBJSUB
CLECUR=1
