$AV_WST
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
If VALEUR <> ""
 Read [MWS]WST0=VALEUR;[M:ROU0]FCY
 If ! fstat
  [M:ROF1]WCR=[F:MWS]WCR
  [M:ROF1]WSTTYP=[F:MWS]WSTTYP
#  [M:ROF1]WSTDES=[F:MWS]WSTDES
  #LECTURE du libellé traduisible
  Call LECTEXTRA([M:ROF1]WSTDES,"WORKSTATIO","WSTDESAXX", [F:MWS]WST , [F:MWS]WCRFCY ) From ATEXTRA
  [M:ROF1]XWSTTYP=format$("K:2X",mess([F:MWS]WSTTYP,313,1))
  If !GIMPORT : Affzo [ROF1]WCR, XWSTTYP, WSTDES : Endif
 Endif
