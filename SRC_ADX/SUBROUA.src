 Case VALEUR
   When 1 : [M:ROU1]BASQTY(nolign-1)=1
   When 2 : [M:ROU1]BASQTY(nolign-1)=100
   When 3 : [M:ROU1]BASQTY(nolign-1)=1000
   When 4
     Read [TRO]TRO0=[M:ROU0]ROUALT
     If ! fstat & [F:TRO]FCY<>""
        Read [ITF]ITF0=[M:ROU0]ITMREF;[F:TRO]FCY
