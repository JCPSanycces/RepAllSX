#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRTIM4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone LVESUBNR
mkstat = 0
zoncou = "LVESUBNR"
indice = 0
status = 1
zoncou = "LVESUBNR"
If varmode([M]LVESUBNR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LVESUBNR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]LVESUBNR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]LVESUBNR = nolign
   status = 75
   Call SAI_LVESUBNR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_LVESUBNR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone LVESUBNR
mkstat = 0
zoncou = "LVESUBNR"

## Zone LVESUBTYP
mkstat = 0
zoncou = "LVESUBTYP"
WCHAR = [M]LVESUBTYP(indice)
If varmode([M]LVESUBTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "LVESUBTYP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]LVESUBTYP(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRLST"
  Call CONTHRLST([M]LVESUBTYP(indice)) From SUBHRLST
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]LVESUBTYP(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]LVESUBTYP(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_LVESUBTYP([M]LVESUBTYP(indice)) From SUBHRTIM
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LVESUBTYP(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LVESUBTYP([M]LVESUBTYP(indice)) From SUBHRTIM
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LVESUBTYP" : GZNUM = 1001385 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LVESUBNR
mkstat = 0
zoncou = "LVESUBNR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRTIM4"
Return

