#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
## Xtend: Gestion Sites 
## Actions
#  Version 0001
#
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "SEL_TABLE"        : Gosub SEL_TABLE
 When "VERF_TABLE"       : Gosub VERF_TABLE
 When "FIN_TABLE"        : Gosub FIN_TABLE
 When "SEL_LISTE"        : Gosub SEL_LISTE
 When "TRT_DIV"          : Gosub TRT_DIV
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
##     AYSCHGFCYW    CHGFCYW    Changement du site de travail
##     AYSFCYDUPS    FCYDUPSEL  Sélection Site de copie
##     AYSLANSEL     LANSEL     Sélection langue d'un site Xtend
##     AYSLANCTL     LANCTL     Contrôle langue d'un site Xtend
##     AYSLNKSEL     LNKSEL     Sélection lien Xtend-Dossier
##     AYSLNKCTL     LNKCTL     Contrôle lien Xtend-Dossier
######################################################################################
#------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "CHGFCYW"
   If dim(GAYTFCYWRK)<0 : Global Char GAYTFCYWRK(GLONAYS) : Endif
   OBJET="AYS" : VALEUR = GAYTFCYWRK 
   TIT(0)=mess(1,7900,1)
 When "FCYDUPSEL"
   OBJET="AYS"  
   TIT(0)=mess(1,7900,1)
   CRITERE='[F:AYS]FCYCOD<>"'+GAYTFCYWRK+'"'
   VALEUR=PARAM(1)
Endcase
Return

#------------------------------------------------------------#
$VERF_TABLE
Case TABLE
 When "CHGFCYW"
   Call SETFCYWRK([F:AYS]FCYCOD) From SUBAYS
Endcase
Return

#------------------------------------------------------------#
$FIN_TABLE
Case TABLE
 When "FCYDUPSEL"
    PARAM(1)=VALEUR     # Rq:pas de sélection=""
Endcase
Return

#------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "LANSEL"
    If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
    Read [F:AYS]AYS0 = PARAM(1)
    If fstat=0
        Local Integer WI
        TIT=mess(15,7900,1)-PARAM(1)
        For WI=0 To [F:AYS]LANNBR-1
            NBTEX+=1
            TEX(NBTEX)=[F:AYS]LANCOD(WI)
            Call LECTEXTRA(TEXTE(NBTEX), "TABLAN","INTDES",TEX(NBTEX),"") From ATEXTRA
            If TEXTE(NBTEX)=""
                TEXTE(NBTEX)=TEX(NBTEX)
            Endif    
            TEXTE(NBTEX)+=space$(15)
        Next
    Endif
 When "LNKSEL"
    If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
    Read [F:AYS]AYS0 = PARAM(1)
    If fstat=0
        Local Integer WI
        TIT=mess(79,7900,1)-PARAM(1)
        For WI=0 To [F:AYS]LNKNBR-1
            NBTEX+=1
            TEX(NBTEX)=[F:AYS]LNKADS(WI)
            TEXTE(NBTEX)=TEX(NBTEX)
            If [F:AYS]LNKADSDEF(WI)=2
              TEXTE(NBTEX)-=mess(80,7900,1)
            Else
              TEXTE(NBTEX)+=space$(15)
            Endif
        Next
    Endif
Endcase
Return

#------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "LANCTL"
    If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
    Raz [F:AYS]
    Read [F:AYS]AYS0 = PARAM(1)
    If !find(VALEUR, [F:AYS]LANCOD)
            GERR=1
            GMESSAGE=mess(18,7900,1)
            mkstat=2
    Endif
 When "LNKCTL"
    If clalev([F:AYS])=0 : Local File AYTFCY [AYS] : Endif
    Raz [F:AYS]
    Read [F:AYS]AYS0 = PARAM(1)
    If !find(VALEUR, [F:AYS]LNKADS)
            GERR=1
            GMESSAGE=mess(81,7900,1)
            mkstat=2
    Endif
 When "FCYWRN"
    If VALEUR<>GAYTFCYWRK
       GERR=2
       GMESSAGE=mess(21,7900,1)
    Endif
Endcase
Return

