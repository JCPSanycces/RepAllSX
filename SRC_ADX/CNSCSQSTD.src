#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# CNSCSDSTD : Consultation des devis ventes                             #
# ECRAN 1   : CONSCSQ1                                                  #
# ECRAN 2   : CONSCSQ2                                                  #
# ECRAN CRIT: CRITCSQ                                                   #
#########################################################################

Local Char PARAM(20)(1..2)
PARAM(1) = "EB"
PARAM(2) = "MAR"
Call GCONSULT("CSQ","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case GACTION
    When "CONSCSQ"
        Case ACTION
          When "AUTORIS"    : Gosub AUTORIS
          When "OUVRE"      : Gosub OUVRE
          When "LECTURE"    : Gosub LECTURE
          When "SETBOUT"    : Gosub SETBOUT
          When "EXEBOUT"    : Gosub EXEBOUT
          When "FIN_CRIT"   : Gosub FIN_CRIT
          When Default
        Endcase
    Endcase
Return
###################################################################
#                                                                 #
#        TRAITEMENTS LIES L'ACTION CONSCSQ                        #
#                                                                 #
###################################################################
$AUTORIS
Return


############################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
# B : HT/Période            : Actif                                                     #
# C : HT/Représentant       : Actif si représentant présent dans la consultation        #
# D : Palmarès Client       : Actif                                                     #
# E : Palmarès Représentant : Actif si représentant présent                             #
# ------------------------------------------------------------------------------------- #

If [F:AMZ]CODMSK<>GBOITE | [F:AMZ]CODZON<>"REP1"
    Read [F:AMZ]CODE = GBOITE;"REP1"
    If fstat Raz [F:AMZ] : Endif
Endif
If [M:CSQ2]NBLIG>0 CHMEN += "BD" Endif
If [M:CSQ2]NBLIG>0 & [F:AMZ]SAIAFF= 2 CHMEN += "CE" Endif
#If [M:CSQ2]NBLIG>0 & [M:CSQ1]BPCORD=""  CHMEN += "D" Endif
#If [M:CSQ2]NBLIG>0 & [M:CSQ1]BPCORD="" & [F:AMZ]SAIAFF= 2 CHMEN += "E" Endif

Return
###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$EXEBOUT

Case BOUT
    When "B", "C", "D", "E" :
#        OK=1 : CHANGE=1 : # Pour déclencher un réaffichage de la consultation
        [M:CSQ1]QUODATDEB=[M:CCSQ]QUODATDEB : # Pour restituer les critères de date de départ
        [M:CSQ1]QUODATFIN=[M:CCSQ]QUODATFIN
Endcase

Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT
Local Integer WAFFREP

If clalev([F:TCU])=0 Local File TABCUR  [TCU]  : Endif
If clalev([F:AMZ])=0 Local File AMSKZON [AMZ]  : Endif

NAVIG="CONSCSQ"

Gosub DEFCRIT

[M:CSQ1]CURD=GSYSCUR


Return
# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:CSQ1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSQ1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:CSQ1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0 = PARAM(I)
                                     If fstat
                                       Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSQ1]BPCORD = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSQ1]SALFCY = PARAM(I)
           If [M:CSQ1]SALFCY <> ""
             Call GETDEV([M:CSQ1]SALFCY) From DEVSUB
             [M:CSQ1]CPY  = GSOCIETE
             [M:CSQ1]CURS = GLOCALDEV
           Endif
        Endif
      Endif
  Endcase
Next I

If !find([M:CSQ1]VLYSTAN,1,2) : [M:CSQ1]VLYSTAN= 2 : Endif
If !find([M:CSQ1]VLYSTAO,1,2) : [M:CSQ1]VLYSTAO= 2 : Endif
If !find([M:CSQ1]QUOSTAN,1,2) : [M:CSQ1]QUOSTAN= 2 : Endif
If !find([M:CSQ1]QUOSTAO,1,2) : [M:CSQ1]QUOSTAO= 2 : Endif
If !find([M:CSQ1]APPFLGN,1,2) : [M:CSQ1]APPFLGN= 2 : Endif
If !find([M:CSQ1]APPFLGO,1,2) : [M:CSQ1]APPFLGO= 2 : Endif
If !find([M:CCSQ]TRI,1,2)     : [M:CCSQ]TRI = 1   : Endif

[M:CSQ1]QUODATFIN=eomonth(date$)
[M:CSQ1]QUODATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

# -- copie de l'écran critères (CCSQ) vers le masque 1 (CSQ1)
Gosub CRITENT From =PROGCNS

Return
############################################################
$LECTURE
Local Decimal WMNTORG(0..1), WMNTDES(0..1)
Local Integer SPSTAT, WI, WJ
Local Char    WCUR(GLONCUR)

# Mail CH : 03/03/04
#If [M:CSQ1]CPY="" & [M:CSQ1]SALFCY=""
# NBLU=0 : Return
#Endif

  # FGR 21/10/2009 : X3SUIVI56101
  If GPILNAV > 1 Then
    #acces depuis clients ou tiers
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC") Then
      Diszo [M:CSQ1]BPCORD
    Endif

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSQ1"
    Gosub LECTURE From CUSSEALIB
  Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSQ]TRI
      When 1 : # tri par numéro
        Filter [SQH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SQH0
      When 2 : # tri par date
        Filter [SQH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key CLE=[F:SQH]QUODAT;[F:SQH]SQHNUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSQ]TRI
      When 1 : # tri par numéro
        Filter [SQH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SQH0 Desc
      When 2 : # tri par date
        Filter [SQH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SQH]QUODAT Desc ;[F:SQH]SQHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSQ2] : Endif

#-- lecture
$BOUCLE
For [SQH] With Nohint

# Filtre sur la société
  If [M:CSQ1]CPY <> ""
      If [F:FCY]FCY <> [F:SQH]SALFCY Read [F:FCY]FCY0 = [F:SQH]SALFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CSQ1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSQ2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:SQH]SQHNUM
         DEBDAT = [F:SQH]QUODAT
     Endif
     FINNUM = [F:SQH]SQHNUM
     FINDAT = [F:SQH]QUODAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:SQH]SQHNUM
         FINDAT = [F:SQH]QUODAT
     Endif
     DEBNUM = [F:SQH]SQHNUM
     DEBDAT = [F:SQH]QUODAT
  Endif

# Modifié par Dominique BOPP après discussion avec Jacky LESAGE
# Objectif : disposer d'un maximum de rubriques possibles dans l'écran de consultation des devis
  nolign = NOL+1
  [M:CSQ2]=[F:SQH] : # Un trans-classe pour commencer

# Ne subsistent ici que des champs dimensionnés de part et d'autre, pour lesquels un renommage
# est nécessaire dans les écrans
  If dim([M:CSQ2]REP1)>=nolign
      [M:CSQ2]REP1(nolign-1)       = [F:SQH]REP(0)
      If dim([M:CSQ2]REP2)>=nolign : # L'un ne va pas sans l'autre
          [M:CSQ2]REP2(nolign-1)       = [F:SQH]REP(1)
      Endif
  Endif
  [M:CSQ2]BPCNAM1(nolign-1)    = [F:SQH]BPCNAM(0)

#    Calcul des montants en devise société
  If [F:SQH]CUR <> [M:CSQ1]CURS
      WMNTORG (0) = [F:SQH]QUOINVNOT : # Montants les plus complets (D BOPP pour 140)
      WMNTORG (1) = [F:SQH]QUOINVATI : # Montants les plus complets (D BOPP pour 140)
      Call CONVERT2([F:SQH]CUR, [M:CSQ1]CURS, [M:CSQ1]CURS, [F:SQH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
      Call CONVERT2([F:SQH]CUR, [M:CSQ1]CURS, [M:CSQ1]CURS, [F:SQH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
      If [F:TCU]CUR <> [M:CSQ1]CURS
         Read [F:TCU]TCU0 = [M:CSQ1]CURS
         If fstat Raz [F:TCU] : Endif
      Endif
      [M:CSQ2]QUONOTSOC(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
      [M:CSQ2]QUOATISOC(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
      [M:CSQ2]QUONOTSOC(nolign-1)  = [F:SQH]QUOINVNOT : # Montants les plus complets (D BOPP pour 140)
      [M:CSQ2]QUOATISOC(nolign-1)  = [F:SQH]QUOINVATI : # Montants les plus complets (D BOPP pour 140)
  Endif
#    Calcul des montants en devise dossier
  If [F:SQH]CUR <> [M:CSQ1]CURD
      WMNTORG (0) = [F:SQH]QUOINVNOT : # Montants les plus complets (D BOPP pour 140)
      WMNTORG (1) = [F:SQH]QUOINVATI : # Montants les plus complets (D BOPP pour 140)
#      Call CONVERT2_TAB([F:SQH]CUR, [M:CSQ1]CURD, [M:CSQ1]CURS, [F:SQH]CHGTYP, date$, WMNTORG, WMNTDES,SPSTAT) From TRTDEV
      Call CONVERT2([F:SQH]CUR, [M:CSQ1]CURD, [M:CSQ1]CURS, [F:SQH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
      Call CONVERT2([F:SQH]CUR, [M:CSQ1]CURD, [M:CSQ1]CURS, [F:SQH]CHGTYP, datesyst, WMNTORG(1), WMNTDES(1),SPSTAT) From TRTDEV
      If [F:TCU]CUR <> [M:CSQ1]CURD
         Read [F:TCU]TCU0 = [M:CSQ1]CURD
         If fstat Raz [F:TCU] : Endif
      Endif
      [M:CSQ2]QUONOTDOS(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
      [M:CSQ2]QUOATIDOS(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
      [M:CSQ2]QUONOTDOS(nolign-1)  = [F:SQH]QUOINVNOT : # Montants les plus complets (D BOPP pour 140)
      [M:CSQ2]QUOATIDOS(nolign-1)  = [F:SQH]QUOINVATI : # Montants les plus complets (D BOPP pour 140)
  Endif

  $SUIV
Next
Filter [SQH]

If [M:CSQ1]SALFCY="" & [M:CSQ1]CPY="" [M:CSQ1]CURS=GSYSCUR Endif

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL    = "1=1"
WFIL1   = "1=1"
WFIL2   = "1=1"

If [M:CSQ1]SALFCY <> ""
    WFIL += "&[F:SQH]SALFCY=[M:CSQ1]SALFCY"
Endif
#    Autorisation site
# 86749 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
#If GUSRFCY(1)<>"\" & [M:CSQ1]SALFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & [M:CSQ1]SALFCY = "" & GNBAUZ<>GNBSITE
# 86749
 WFIL += "& find([F:SQH]SALFCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CSQ1]BPCORD <> ""
   WFIL += "&[F:SQH]BPCORD =[M:CSQ1]BPCORD"
Endif

# Prise en compte des devis commandé
## --> Si 1 (Non) On exclut les devis Partiellement ou totalement commandé (valeur 2 et 3)
# --> Si 1 (Non) On exclut les devis totalement commandé (valeur 3)
If [M:CSQ1]QUOSTAO = 1
#   WFIL += "&[F:SQH]QUOSTA=1"
   WFIL += "&[F:SQH]QUOSTA<>3"
Endif
# Prise en compte ou pas des devis non commandé
# --> Si 1 (Non) On exclut les devis non commandés
If [M:CSQ1]QUOSTAN = 1
   WFIL += "&[F:SQH]QUOSTA<>1"
Endif

# Prise en compte des devis valides
# --> Si 1 (Non) On exclut les devis dt date validité non renseignée ou renseignée et >= date du jour
If [M:CSQ1]VLYSTAO = 1
   WFIL += "& !([F:SQH]VLYDAT = [0/0/0] | ([F:SQH]VLYDAT <> [0/0/0] & [F:SQH]VLYDAT>=date$))"
#   WFIL += "& ([F:SQH]VLYDAT <> [0/0/0] & [F:SQH]VLYDAT<date$)"
Endif
# Prise en compte des devis non valides
# --> Si 1 (Non) On exclut les devis dt date validité < date du jour
If [M:CSQ1]VLYSTAN = 1
#   WFIL += "& ([F:SQH]VLYDAT = [0/0/0] | ([F:SQH]VLYDAT <> [0/0/0] & [F:SQH]VLYDAT>=date$))"
  WFIL += "& !([F:SQH]VLYDAT <> [0/0/0] & [F:SQH]VLYDAT<date$)"
Endif

# Prise en compte des devis signés
# --> Si 1 (Non) On exclut les devis totalement signés (valeur 3), pas de gestion (valeur 4), oui automatique (valeur 5)
If [M:CSQ1]APPFLGO = 1
   WFIL += "&[F:SQH]APPFLG<3"
Endif
# Prise en compte ou pas des devis non signés
# --> Si 1 (Non) On exclut les devis non signés (valeur 1)
If [M:CSQ1]APPFLGN = 1
   WFIL += "&[F:SQH]APPFLG<>1"
Endif

If [M:CCSQ]SQHNUMDEB <> ""
   WFIL1 += "&[F:SQH]SQHNUM>=[M:CCSQ]SQHNUMDEB"
Endif
If [M:CCSQ]SQHNUMFIN <> ""
   WFIL1 += "&[F:SQH]SQHNUM<=[M:CCSQ]SQHNUMFIN"
Endif

If [M:CCSQ]QUODATDEB <> [0/0/0]
   WFIL1 += "&[F:SQH]QUODAT>=[M:CCSQ]QUODATDEB"
Endif
If [M:CCSQ]QUODATFIN <> [0/0/0]
   WFIL1 += "&[F:SQH]QUODAT<=[M:CCSQ]QUODATFIN"
Endif

# FGR 23/02/2015 : X3SUIVI104383 (début)
If [M:CCSQ]SQHTYP <> "" Then
  WFIL1 += "&[F:SQH]SQHTYP=[M:CCSQ]SQHTYP"
Endif
# FGR 23/02/2015 : X3SUIVI104383 (fin)

# 71065 : PJT
If [M:CCSQ]PJTDEB <> ""
   WFIL1 += "&[F:SQH]PJT>=[M:CCSQ]PJTDEB"
Endif
If [M:CCSQ]PJTFIN <> ""
   WFIL1 += "&[F:SQH]PJT<=[M:CCSQ]PJTFIN"
Endif
# 71065 : PJT

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSQ]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SQH]SQHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SQH]QUODAT>DEBDAT | ([F:SQH]QUODAT=DEBDAT & [F:SQH]SQHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSQ]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SQH]SQHNUM>FINNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SQH]QUODAT>FINDAT | ([F:SQH]QUODAT=FINDAT & [F:SQH]SQHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSQ]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SQH]SQHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL1 += "& ([F:SQH]QUODAT<DEBDAT | ([F:SQH]QUODAT=DEBDAT & [F:SQH]SQHNUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT
Return

#############################################################################
##     Etiquettes masques CONSCSQ1 & CONSCSQ2 & CRITCQH                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]SALFCY = ""
  # Mail CH : 03/03/04
  #  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  #  Raz [M]CURS
  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
Affzo [M]CURS
End
###########################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Affzo CURS, ZCPY
Raz [M]SALFCY, ZSALFCY
Affzo SALFCY,ZSALFCY
If VALEUR<>"" : GSOCIETE=VALEUR : Endif
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End
########################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
   Affzo CURS, CPY, ZCPY
Endif
End
########################################
Subprog IB_NBLIG
GBOUT1 = mess(121, 198,1)-[M]SQHNUM(nolign-1)
End
########################################
Subprog AM_SQHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SQHNUMFIN= VALEUR : Endif
End
########################################
Subprog AM_QUODATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]QUODATFIN= VALEUR : Endif
End
# 71065 : PJT
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(4)<>2 End Endif

Call VALGTC(APPLI,"CSQ") From SUBGTC

End
######################################################################################

