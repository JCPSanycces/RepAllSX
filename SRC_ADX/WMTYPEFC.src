#<AdxTL>@(#)0.0.0.0 $Revision$Class Code
# Supervisor
## ATY-ATYPE ## EFC
# 2018-11-09 07:14:09 887

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,FLOCOD,FLOREL,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char FLOCOD
Value Char FLOREL
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDIFLO [EFL]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDIFLO" [EFL]
Endif

Default File [F:EFL]
Read [F:EFL]EFL0 = [L]FLOCOD;[L]FLOREL
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]FLOCOD)+"~"+num$([L]FLOREL)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "FLGACT"
  [L]ATSTFILTER = ([F:EFL]FLGACT = [V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(52386)
 When "VALID"
  [L]ATSTFILTER = ([F:EFL]VALID = [V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(50676)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]FLOCOD)+"~"+num$([L]FLOREL)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


