$ACTION_CLOTURE_PERIODE
 # A modernization is pending on the opening period. The DEPSTA field is set to yes.
 If [F:DEPS]KMDRDEV<>0 & [F:DEPS]KMDRDAT=[F:DEPS]PERSTRDAT
  [F:DEPS]DEPSTA                  = GVML_SCNOCAL
  [F:FAS]FLGCNXCLC([F:DEPS]CNX-1) = G_OUI
  [F:FAS]FLGCLC                   = G_OUI
 Endif
Return
