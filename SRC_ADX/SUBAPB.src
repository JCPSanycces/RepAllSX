Subprog C_SERVEURTRT(VALEUR)
Variable Char    VALEUR()
If [M]SERVEURAPP="" and VALEUR<>""
 # Vous devez définir le serveur d'application avant de définir le serveur de traitement
 VALEUR=""
 mkstat=2
GMESSAGE=mess(223,124,1)
Endif
End

Subprog AS_SERVEURTRT(VALEUR)
Variable Char    VALEUR()
If [M]SERVEURAPP=""
  mkstat=1
Endif
End

Subprog AS_NOPORT(VALEUR)
Variable Decimal VALEUR
If [M]SERVEURAPP=""
  mkstat=1
Endif

End


