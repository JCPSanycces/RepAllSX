######################################################################################
Subprog AP_DOSSIER(VALEUR)
Variable Char    VALEUR()

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=VALEUR
If fstat<>0
  GMESSAGE=mess(7,125,1)
  mkstat=2
Endif

End


