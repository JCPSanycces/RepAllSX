######################################################################################
## Etiquette ajoutée par le superviseur (écran APB1) 06/03/2013 09:03:41 (CCORA)
######################################################################################
Subprog C_USR(VALEUR)
Variable Char    VALEUR()

If [M]DOSSIER="" and VALEUR="" and [M]POOLALIAS="" : End : Endif

Onerrgo ERRLOG
Local Integer ERCH
Local File =[M]DOSSIER+".AUTILIS" [AU_S]
If ERCH=1 : End : Endif

Read [AU_S]CODUSR=VALEUR
If fstat<>0
   GMESSAGE=mess(141,100,1) : mkstat=2  : # Code utilisateur inexistant
Elsif [F:AU_S]ENAFLG<>2
    GMESSAGE=mess(96,9139,1)-mess(1,8,1) : mkstat=2  : # Code utilisateur inactif
Elsif [F:AU_S]USRCONXTD<>2
    GMESSAGE = mess(279,123,1) : mkstat=2  :  # Code utilisateur non autorisé pour ce type de connexion
Else
  [M]LOGIN=[F:AU_S]LOGIN
  Affzo [M]LOGIN
Endif
Close File [AU_S]


End

######################################################################################
