#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet APB
Raz GPILOBJ,GNBMASKOUV
Call OBJET("APB",GBIDC1,GBIDC2) From GOBJET
End


######################################################################################
## Etiquette ajoutée par le superviseur (Objet APB) 06/08/2010 09:09:15 (CCORA)
######################################################################################
$ACTION
Case ACTION
 When "LIENS"             : Gosub LIENS
 When "VERIF_CRE"         : Gosub MAJ
 When "VERIF_MOD"         : Gosub MAJ
 When "EXEBOUT"           : Gosub EXEBOUT
 When Default
Endcase
Return


$MAJ
#   Cryptage du mot de passe avant de le mettre dans la table
If left$([M:APB1]SYSTMDP,6)<>"CRYPT:"
  Call INCRYPT([M:APB1]SYSTMDP,[M:APB1]SYSTMDP) From INTRUTILA
  [M:APB1]SYSTMDP="CRYPT:"+[M:APB1]SYSTMDP
Endif
If left$([M:APB1]USRMDP,6)<>"CRYPT:"
  Call INCRYPT([M:APB1]USRMDP,[M:APB1]USRMDP) From INTRUTILA
  [M:APB1]USRMDP="CRYPT:"+[M:APB1]USRMDP
Endif
Return

$LIENS
Raz [M]LOGIN
If [M]USR<>""
  Onerrgo ERRLOG
  Local Integer ERCH
  Local File =[M]DOSSIER+".AUTILIS" [AU_S]
  If ERCH=1 : Return : Endif
  Read [AU_S]CODUSR=[M]USR
  If fstat=0
    [M]LOGIN=[F:AU_S]LOGIN
    Affzo [M]LOGIN
  Endif
Endif
Close File [AU_S]
Return

$ERRLOG
ERCH=1
Resume


$EXEBOUT

If BOUT="U"
  Local Char NAMEFIC(250),DIRSEP,VALL1(200)

  Case GOS(1)
   When "dos"   : DIRSEP="\"
   When Default : DIRSEP="/"
  Endcase
  NAMEFIC=filpath("X3_ROOT"+DIRSEP+"GEN","adxpoolconfig_" + GINSTID,"xml","X3_PUB")
  If filinfo(NAMEFIC,7)<0 : Return : Endif
  Local Char URL(200),RETOUR(200)
  URL=GVIRTDIR+"/X3_ROOT/GEN/"+"adxpoolconfig_" + GINSTID
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL
  Return
Endif


If BOUT<>"V" : Return : Endif
#  Création du fichier XML de description des entrées
# Le fichier est stocké sous X3_PUB/X3_ROOT/GEN

Local Char NAMEFIC(250),DIRSEP,VALL1(200),ALOGIN(50)

Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

NAMEFIC=filpath("X3_ROOT"+DIRSEP+"GEN","adxpoolconfig_" + GINSTID,"xml","X3_PUB")
Openo NAMEFIC,0 Using [XPB]

Iomode adxifs "" Using [XPB]
Iomode adxirs chr$(10) Using [XPB]
Iomode adxium GUTF8 Using [XPB]

Wrseq '<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>' Using [XPB]
Wrseq '<pool>' Using [XPB]

If clalev([F:APB])=0  : Local File APOOLBRG  [APB]  : Endif

For [APB]
Wrseq '  <entries id="'+[F:APB]POOLALIAS+'">' Using [XPB]
Wrseq '    <alias>'+[F:APB]POOLALIAS+'</alias>' Using [XPB]
Wrseq '    <lib>'+[F:APB]INTITPOOL+'</lib>' Using [XPB]
Wrseq '    <solution>'+GINSTID+'</solution>' Using [XPB]
Wrseq '    <solvers>'+func APRODUCT.AGETRELEASESUP()+'</solvers>' Using [XPB]
If SERVEURTRT<>""
  Wrseq '    <serverhostname>'+SERVEURTRT+'</serverhostname>' Using [XPB]
Elsif SERVEURAPP<>""
  Wrseq '    <serverhostname>'+SERVEURAPP+'</serverhostname>' Using [XPB]
Else
  Wrseq '    <serverhostname>'+adxmac(-1)+'</serverhostname>' Using [XPB]
Endif
If NOPORT<>0
  Wrseq '    <serverport>'+num$(NOPORT)+'</serverport>' Using [XPB]
Else
  Wrseq '    <serverport>'+num$(adxtcp)+'</serverport>' Using [XPB]
Endif
If SERVEURTRT<>"" and SERVEURAPP<>""
  Wrseq '    <adxfolder>'+SERVEURAPP+"@"+[F:APB]DOSSIER+'</adxfolder>' Using [XPB]
Else
  Wrseq '    <adxfolder>'+[F:APB]DOSSIER+'</adxfolder>' Using [XPB]
Endif
Wrseq '    <language>'+[F:APB]USRLAN+'</language>' Using [XPB]
ALOGIN=[F:APB]USR
Local File =[F:APB]DOSSIER+".AUTILIS" [AU_S]
Read [AU_S]CODUSR=[F:APB]USR
If fstat=0
  ALOGIN=[F:AU_S]LOGIN
Endif
Close File [AU_S]
Wrseq '    <userid>'+ALOGIN+'</userid>' Using [XPB]
Wrseq '    <password>'+[F:APB]USRMDP+'</password>' Using [XPB]
Wrseq '    <osuserid>'+[F:APB]USRSYST+'</osuserid>' Using [XPB]
Wrseq '    <ospassword>'+[F:APB]SYSTMDP+'</ospassword>' Using [XPB]
Wrseq '    <maxsize>'+num$([F:APB]MAXENTRY)+'</maxsize>' Using [XPB]
Wrseq '    <initsize>'+num$([F:APB]NBENTRY)+'</initsize>' Using [XPB]
If [F:APB]AUTOSTART=2
  Wrseq '    <autostart>'+'on'+'</autostart>' Using [XPB]
Else
  Wrseq '    <autostart>'+'off'+'</autostart>' Using [XPB]
Endif
If dim([F:APB]IMPCLI)>0 and [F:APB]IMPCLI=2
  Wrseq '    <impCli>'+'kilo'+'</impCli>' Using [XPB]
Else
  Wrseq '    <impCli>'+'juliet'+'</impCli>' Using [XPB]
Endif
Wrseq '    <reserved>'+'off'+'</reserved>' Using [XPB]
Wrseq '    <unusetime>'+num$([F:APB]LIFETIME * 1000) +'</unusetime>' Using [XPB]
Wrseq '    <trace name="POOL" on="off" >' Using [XPB]
Wrseq '        <server host="localhost" port="1515" ></server>' Using [XPB]
Wrseq '        <chanels>' Using [XPB]
Wrseq '            <chanel level="9" name="POOLGR" on="off" xxnum="1" >' Using [XPB]
Wrseq '                <module name="thread" on="on" ></module>' Using [XPB]
Wrseq '            </chanel>' Using [XPB]
Wrseq '            <chanel level="1" name="POOLCN" on="off" xxnum="2" >' Using [XPB]
Wrseq '                <module name="protocol" on="on" ></module>' Using [XPB]
Wrseq '            </chanel>' Using [XPB]
Wrseq '        </chanels>' Using [XPB]
Wrseq '    </trace>' Using [XPB]

Wrseq '  </entries>' Using [XPB]
Next

Wrseq '</pool>' Using [XPB]

Openo Using [XPB]

Call UPDBRGPOOL(GINSTID)


Return



$VISUXML
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+"X3_ROOT"+AASEP+"GEN"
  URL+=+AASEP+"adxpoolconfig_" + GINSTID+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return

######################################################################################


Subprog UPDBRGPOOL(ASOLNAME)
Value Char ASOLNAME

Local Char WHOST(200)
WHOST = ""
Local Integer WPORT
WPORT = 0

Local Char VPROP(200)
Local Integer OK

# Recherche la valeur de la property dans Solution.xml
# OK=0 si valeur trouvée
#   =1 propriété non trouvée
#   =2 fichier solution non trouvé
#   =3 pb de lecture sur le fichier


# Recherche la valeur de la property "component.serverjava.servername" dans Solution.xml
Call RECHPROP("component.serverjava.servername",VPROP,OK) From INTRUTILA
If OK = 0
    WHOST = VPROP
Endif

# Recherche la valeur de la property "all.host.port" dans Solution.xml
Call RECHPROP("all.host.port",VPROP,OK) From INTRUTILA
If OK = 0
    WPORT = val(VPROP)
Endif


If WHOST <> "" and WPORT <> 0

Local Char WTARGET (128)
WTARGET  = WHOST
WTARGET += ":"
WTARGET += num$(WPORT)

Onerrgo UPDPOOLERR

    Local Integer WEXISTS
    WEXISTS = func SRVEXISTS(WHOST,WPORT)

    If WEXISTS=1



        #Préparation de la variable contenant le nom de la méthode statique à appeller
        Local Char WUPDATE(200)
        WUPDATE= "com.sage.x3.resource.manager.CResourceManagerServiceImpl:updateX3Pools"

        #Ouverture de la connection
        Opadxd WTARGET With nomap ,GLANGUE , adxusr, password  Using [JSRV]

        Onerrgo CALLERR
        #Appel du serveur bridge rattache
        Calliu = WUPDATE With ASOLNAME Using [JSRV]

        #Fermeture de la connection
        Opadxd Using [JSRV]

#     Mise à jour de la configuration réussie sur le serveur
        Call MESSAGE(mess(224,124,1)-WTARGET) From GESECRAN
    Else
# Serveur inexistant
        Call ERREUR(mess(225,124,1)-WTARGET) From GESECRAN
    Endif
Endif

Goto UPDPOOLEND


$CALLERR
Opadxd Using [JSRV]
Goto UPDPOOLERR


$UPDPOOLERR
# La mise à jour de la configuration a échoué sur le serveur
  Call ERREUR(mess(226,124,1)-WTARGET) From GESECRAN
End
$UPDPOOLEND



End

#-------------------------------------------------------------------
#
# Fonction de test d'existence d'un serveur
#
#-------------------------------------------------------------------
Funprog SRVEXISTS(AHOST,APORT)
  Value Char AHOST()
  Value Integer APORT
  Local Integer WOPEN
  [L]WOPEN =-1 :# ni 0, ni 1 !!!
  Onerrgo EXISTSERR

  # génère une erreur "27" si host inconnu ou si le port n'est pas ouvert
  Opsock [L]AHOST,[L]APORT Using [TSTB]

  # test si il y a eu une erreur
  If [L]WOPEN=0 : Goto EXISTSEND : Endif

  # Fermeture après une seconde
  Sleep(1)
  Opsock [L]AHOST,0 Using [TSTB]

  # un peu d'attente car  la fermeture est effective 2 à 3 secondes après !!!
  Sleep(2)
  [L]WOPEN =1
  Goto EXISTSEND

$EXISTSERR
  [L]WOPEN =0
  Call ERREUR("FONCTION : Error ("+num$(errn)+") : ["+errm+"]") From GESECRAN
  Resume:# le bloc d'erreur est obligatoirement clos par un "Resume"

$EXISTSEND
  # pour supprimer le débranchement sur erreur
  Onerrgo
End [L]WOPEN



