#<AdxTL>@(#)3.0.0.0 $Revision$
Call OUVRE_TRACE("MAJ Xtend") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##################################################
Subprog PATCH_X3(APPLI)
Value Char APPLI
If GVERSOL<"16v.000" : End : Endif
Call RAZDES(APPLI)
End

##################################################
Subprog PATCH(APPLI)
Value Char APPLI
If GVERSOL<"16v.000" : End : Endif
Call RAZDES(APPLI)
End


Subprog RAZDES(APPLI)
Value Char APPLI
Local File =APPLI+".ATABLE"  [ATB]
Local File =APPLI+".ATABZON" [ATZ]

Local Integer ATX,AXX
Local Char    NOMATX

Call ECR_TRACE("Raz champ ATX d'xtend en V6",0) From GESECRAN
For [ATB] Where CODACT ="AYT" & find(CODFIC,"AYTACT","AYTELTBLC","AYTELTBLCW","AYTELTDLK","AYTELTFLD","AYTENT","AYTFCY","AYTINT"
&                                   ,"AYTMEN","AYTMES","AYTPAG","AYTPRF")
 Call ECR_TRACE("---- Updated"-[F:ATB]CODFIC-"(DES)",0) From GESECRAN
 Local File =[F:ATB]CODFIC [AAA_]
 Trbegin [AAA_]
 Update [AAA_] Where 1=1 With DES=0
 If fstat
  Call ERREUR("AWKPAR",2) From DOSDIC
 Endif
 Commit
 Close Local File [AAA_]
Next ATB

End
