#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TLP2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SEAKEY
mkstat = 0
zoncou = "SEAKEY"
indice = 0
IMPENT = [M]SEAKEY
If varinit([M]SEAKEY,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEAKEY,indice)=0
 [M]SEAKEY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEAKEY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEAKEY(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SEAKEY" : GZNUM = 255 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]SEAKEY = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone ITMFLDNBR
mkstat = 0
zoncou = "ITMFLDNBR"
indice = 0
status = 1
zoncou = "ITMFLDNBR"
If varmode([M]ITMFLDNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMFLDNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]ITMFLDNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]ITMFLDNBR = nolign
   status = 75
   Call SAI_ITMFLDNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_ITMFLDNBR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone ITMFLDNBR
mkstat = 0
zoncou = "ITMFLDNBR"

## Zone ITMFLD
mkstat = 0
zoncou = "ITMFLD"
If varmode([M]ITMFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMFLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]ITMFLD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ITMFLD" : GZNUM = 14859 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ITMFLD([M]ITMFLD(indice)) From SUBTLP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ITMFLD" : GZNUM = 14859 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone INDFLD
mkstat = 0
zoncou = "INDFLD"
If varmode([M]INDFLD,indice)=0
 SAVACT = GACTION : GACTION = "CFGASIND"
 Call CFGASIND(13,[M]ITMFLD(nolign-1)) From CFGLIB
 GACTION = SAVACT
 If mkstat=1 : Raz [M]INDFLD(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "INDFLD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]INDFLD(indice)=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "INDFLD" : GZNUM = 773 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CFGCTRIND"
   Call CFGCTRIND([M]INDFLD(indice),13,[M]ITMFLD(nolign-1)) From CFGLIB
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "INDFLD" : GZNUM = 773 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ITMFLDNBR
mkstat = 0
zoncou = "ITMFLDNBR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "TLP2"
Return

