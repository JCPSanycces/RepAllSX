#<AdxTL>@(#)8.0.0.0 $Revision$
################################################################################
# Mise à jour des nouveaux champs DUCS v4.2                                    #
################################################################################

#########################
Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIDCL: Mise à jour DUCS Urssaf 4.2") From LECFIC
 Call EXE_UTIDCL(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################
Subprog EXE_UTIDCL(APPLI)
Value Char APPLI
Local Integer OK ,I, INDARR
Call ECR_TRACE("UTIDCL: Process Start on : "+APPLI,0) From GESECRAN
Local File =APPLI+".DUCS1" [DCL]
Local File =APPLI+".ADOVAL" [ADW]
Call DEBTRANS From GLOCK
Gosub TR1
Call ECR_TRACE("UTIDCL: Process End on : "+APPLI,0) From GESECRAN
Close Local File [DCL],[ADW]
End


#########################
$TR1
Trbegin [DCL]
GOK = 1
Filter [ADW] Where PARAM="ARRCO"
Read[ADW]ADW0 First
Filter [ADW]
If !fstat
 INDARR=val([ADW]VALEUR)
Else
 INDARR=5 :#valeur standard par défaut
Endif
For [F:DCL]DCL0
 If [F:DCL]CAI<3
  [F:DCL]CAICOD=[F:DCL]CAI    
  [F:DCL]ORGCOD=[F:DCL]ORG
 Elsif [F:DCL]CAI>=3 & [F:DCL]CAI<=5
  [F:DCL]CAICOD=[F:DCL]CAI+1  
  [F:DCL]ORGCOD=[F:DCL]ORG
 Else
  [F:DCL]CAICOD=INDARR
  [F:DCL]ORGCOD=""
 Endif
 Rewrite [F:DCL]
 If fstat
  GOK = 0 : Call FSTA("DCL") From GLOCK : Break
 Endif
Next
If GOK<0 : Goto ROLL_TR1
Elsif GOK=0 : Gosub AB_TR1
Endif
Commit
Return

#########################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################
$AB_TR1
Rollback
Return

#########################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","DUCS1","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif 
Call EXE_UTIDCL(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="PAIE" End : Endif   
If filinfo(filpath("FIL","DUCS1","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif 
Call EXE_UTIDCL(APPLI)
End




