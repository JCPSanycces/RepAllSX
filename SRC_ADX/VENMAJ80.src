#<AdxTL>@(#)0.0.0.0 $Revision$
End
#####################################################################################
# VENMAJ80 : Mises à jour à effectuer lors du passage à la version 11 (Release 80)  #
#                                                                     Module ventes #
# --------------------------------------------------------------------------------- #
# Avant mise à jour AMAJ                                                            #
#                                                                                   #
#    - Table SALTRS [SLT]                 : Transactions Ventes                     #
#####################################################################################
# --------------------------------------------------------------------------------- #
# Après mise à jour MAJ                                                             #
#                                                                                   #
#####################################################################################

# Attention !! les sous-pro appelés depuis DOSMAJXX se nomment AMAJ et MAJ ou AVENMAJXX et VENMAJXX

#################################################################################
# Moulinettes avec anciens et nouveaux champs màj concernant le module ventes   #
#################################################################################
Subprog AMAJ
Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ80 : Process for sales data") From LECFIC
    WOUV_TRACE=1
  Endif
  #--------------------------------
  Gosub SET_FIRST   From TRTFIRST
  #--------------------------------
  Call AV_SLT : # Moulinette des transactions Ventes
  #--------------------------------
  Gosub UNSET_FIRST   From TRTFIRST
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

#################################################################################
#    ---> Concerne les transactions VENTES                                      #
#################################################################################
Subprog AV_SLT
Local Shortint INDIC, WI
Local Integer  I
Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(20), CRITERE(90)
Local Integer  IERR

  IERR = 0
  If filinfo(filpath("FIL","SALTRS","fde",[F:ADS]DOSSIER),0) <= 0 Then
    End
  Endif
  #--------------------------------
  Local File =[F:ADS]DOSSIER+".SALTRS"    [SLT]
  #--------------------------------
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("VENMAJ80 Sales Transactions Process : Update SALTRS") From DOSSUB
  #
  Call ECR_TIME("VENMAJ80 Sales Transactions Process : --- Step 1 ") From DOSSUB

  Gosub TXNSQH  # Quote transactions
  Gosub TXNSOH  # Order transactions
  Gosub TXNSOR  # Open order transactions
  Gosub TXNSDH  # Delivery transactions
  Gosub TXNSIH  # Invoice transactions
  Gosub TXNSRH  # Return transactions
#--------------------------------
End

#-------------------------------------------------------------------------------#
# Quote transactions                                                            #
#-------------------------------------------------------------------------------#
$TXNSQH
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=1
      Raz INDIC
      # 71065 : PJT
      # Project code line PJTCODD
      If dim([F:SLT]PJTCODD)>0
          If !find([F:SLT]PJTCODD,1,2,3) : INDIC=1 : [F:SLT]PJTCODD=3 : Endif : # project code line (invisible)
          If [F:SLT]PJTSCRD<>0  & [F:SLT]PJTSCRD=0 INDIC=1 : [F:SLT]PJTSCRD=1  : Endif
      Endif
      # 71065 : PJT
      If INDIC=1
         Rewrite [SLT]
         If fstat
             Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
         Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Order transactions                                                            #
#-------------------------------------------------------------------------------#
$TXNSOH
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=2
      Raz INDIC
      # 71065 : PJT
      # Project code PJTCODD
      If dim([F:SLT]PJTCODD)>0
          If !find([F:SLT]PJTCODD,1,2,3) : INDIC=1 : [F:SLT]PJTCODD=3 : Endif : # Project code on the line (invisible)
          If [F:SLT]PJTSCRD<>0  & [F:SLT]PJTSCRD=0 INDIC=1 : [F:SLT]PJTSCRD=1  : Endif
      Endif
      # 71065 : PJT
      If INDIC=1
          Rewrite [SLT]
          If fstat
              Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
          Endif
      Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Open order transaction                                                        #
#-------------------------------------------------------------------------------#
$TXNSOR
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=3
    Raz INDIC
    # 71065 : PJT
    # Project code on the head of contract
    If dim([F:SLT]PJTCOD)>0
        If !find([F:SLT]PJTCOD,1,2,3)    INDIC=1 : [F:SLT]PJTCOD=3    : Endif   : # (invisible)
    Endif
    # Project code on item line
    If dim([F:SLT]PJTCODD)>0
        If !find([F:SLT]PJTCODD,1,2,3)   INDIC=1 : [F:SLT]PJTCODD=3   : Endif   : # (invisible)
    Endif
    # 71065 : PJT
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Delivery transactions                                                         #
#-------------------------------------------------------------------------------#
$TXNSDH
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=4
    Raz INDIC
    # 71065 : PJT
    # Project code on the head of delivery
    If dim([F:SLT]PJTCOD)>0
        If !find([F:SLT]PJTCOD,1,2,3)  INDIC=1 : [F:SLT]PJTCOD=3  : Endif   : # (invisible)
    Endif
    # Project code line PJTCODD
    If dim([F:SLT]PJTCODD)>0
      If !find([F:SLT]PJTCODD,1,2,3) : INDIC=1 : [F:SLT]PJTCODD=3 : Endif : # Project code lines (invisible)
      If [F:SLT]PJTSCRD<>0  & [F:SLT]PJTSCRD=0 INDIC=1 : [F:SLT]PJTSCRD=1  : Endif
    Endif
    # 71065 : PJT
    If INDIC=1
      Rewrite [SLT]
      If fstat
          Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
Commit
Return

#-------------------------------------------------------------------------------#
# Invoice transactions                                                          #
#-------------------------------------------------------------------------------#
$TXNSIH
  IERR = 0
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 5
    Raz INDIC
    # 71065 : PJT
    # Project code lines PJTCODD
    If dim([F:SLT]PJTCODD)>0
        If !find([F:SLT]PJTCODD,1,2,3) : INDIC=1 : [F:SLT]PJTCODD=3 : Endif : # Project code on the line (invisible)
        If [F:SLT]PJTSCRD<>0  & [F:SLT]PJTSCRD=0 INDIC=1 : [F:SLT]PJTSCRD=1  : Endif
    Endif
    # 71065 : PJT
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        IERR = 1
      Endif
    Endif
  Next
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
Return

#-------------------------------------------------------------------------------#
# Return transactions                                                           #
#-------------------------------------------------------------------------------#
$TXNSRH
Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP=6 | STRTYP=7 | STRTYP=8
    Raz INDIC
    # 71065 : PJT
    # Project code on the head of return
    If dim([F:SLT]PJTCOD)>0
        If !find([F:SLT]PJTCOD,1,2,3)    INDIC=1 : [F:SLT]PJTCOD=3  : Endif : # (invisible)
    Endif
    # Project code lines PJTCODD
    If dim([F:SLT]PJTCODD)>0
        If !find([F:SLT]PJTCODD,1,2,3) : INDIC=1 : [F:SLT]PJTCODD=3 : Endif : # Project code on the line (invisible)
        If [F:SLT]PJTSCRD<>0  & [F:SLT]PJTSCRD=0 INDIC=1 : [F:SLT]PJTSCRD=1  : Endif
    Endif
    # 71065 : PJT
    If INDIC=1
        Rewrite [SLT]
        If fstat
            Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
        Endif
    Endif
  Next
Commit
Return

##################################################################################
# Moulinettes avec champs version V10 uniquement màj concernant le module ventes #
##################################################################################
Subprog MAJ

Local Integer WOUV_TRACE

  If GTRACE = "" Then
    Call OUVRE_TRACE("VENMAJ80 : Process for sales data") From LECFIC
    WOUV_TRACE = 1
  Endif
  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End

