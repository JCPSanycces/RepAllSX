#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRCGD1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRCGD"
 Call DEFHRCGD([M]COD,GCURLEG,GSOCIETE) From SUBHRCGD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]COD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]COD,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRCGD"
   Call CONTHRCGD([M]COD,GCURLEG,GSOCIETE) From SUBHRCGD
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]COD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]COD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJW"
     PARAM(1) = "HRCGD"
     Local Char    VALEUR(250)
     VALEUR = [M]COD
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
     [M]COD = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 44769 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBHRCGD
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"HRCTRGRD","DESAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone SHOAXX
mkstat = 0
zoncou = "SHOAXX"
indice = 0
If varinit([M]SHOAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]SHOAXX,"HRCTRGRD","SHOAXX",[M]COD,[M]LEG) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOAXX" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone GRP
mkstat = 0
zoncou = "GRP"
indice = 0
If varmode([M]GRP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("AGF","!C",[M]GRP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CGRPCPYLEG"
  Call C_GRPCPYLEG([M]GRP,GCURLEG) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 28843 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CODACS
mkstat = 0
zoncou = "CODACS"
indice = 0
If varmode([M]CODACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DEFVAL
mkstat = 0
zoncou = "DEFVAL"
indice = 0
IMPENT = [M]DEFVAL
If varinit([M]DEFVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]DEFVAL,indice)=0
 [M]DEFVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFVAL(indice)
 Endif
Endif
[M]DEFVAL = IMPENT

## Zone CTRXITAUT
mkstat = 0
zoncou = "CTRXITAUT"
indice = 0
IMPENT = [M]CTRXITAUT
If varinit([M]CTRXITAUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CTRXITAUT,indice)=0
 [M]CTRXITAUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRXITAUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CTRXITAUT(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CTRXITAUT(IMPENT) From SUBHRCGD
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTRXITAUT" : GZNUM = 47723 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]CTRXITAUT = IMPENT

## Zone CTRXITGRD
mkstat = 0
zoncou = "CTRXITGRD"
indice = 0
If varmode([M]CTRXITGRD,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRXGD"
 Call DEFHRXGD([M]CTRXITGRD,GCURLEG,GSOCIETE) From SUBHRXGD
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CTRXITGRD : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRXITGRD" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRXGD"
  Call CONTHRXGD([M]CTRXITGRD,GCURLEG,GSOCIETE) From SUBHRXGD
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CTRXITGRD
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CTRXITGRD = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CTRXITGRD([M]CTRXITGRD) From SUBHRCGD
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CTRXITGRD" : GZNUM = 47332 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CTRDATFCY
mkstat = 0
zoncou = "CTRDATFCY"
indice = 0
IMPENT = [M]CTRDATFCY
If varinit([M]CTRDATFCY,indice)=0
 IMPENT = 1
Endif
If varmode([M]CTRDATFCY,indice)=0
 [M]CTRDATFCY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRDATFCY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CTRDATFCY(indice)
 Endif
Endif
[M]CTRDATFCY = IMPENT

## Zone FLGCREBUL
mkstat = 0
zoncou = "FLGCREBUL"
indice = 0
IMPENT = [M]FLGCREBUL
If varinit([M]FLGCREBUL,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCREBUL,indice)=0
 [M]FLGCREBUL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGCREBUL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGCREBUL(indice)
 Endif
Endif
[M]FLGCREBUL = IMPENT

## Zone FLGDSN
mkstat = 0
zoncou = "FLGDSN"
indice = 0
IMPENT = [M]FLGDSN
If varinit([M]FLGDSN,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGDSN,indice)=0
 [M]FLGDSN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGDSN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGDSN(indice)
 Endif
Endif
[M]FLGDSN = IMPENT

## Zone RENMUT
mkstat = 0
zoncou = "RENMUT"
indice = 0
IMPENT = [M]RENMUT
If varinit([M]RENMUT,indice)=0
 IMPENT = 1
Endif
If varmode([M]RENMUT,indice)=0
 [M]RENMUT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RENMUT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RENMUT(indice)
 Endif
Endif
[M]RENMUT = IMPENT

## Zone SSPGRD
mkstat = 0
zoncou = "SSPGRD"
indice = 0
If varinit([M]SSPGRD,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SSPGRD,"10344","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SSPGRD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SSPGRD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SSPGRD,"10344","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SSPGRD,"10344",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_SSPGRD([M]SSPGRD) From SUBHRCGD
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "SSPGRD" : GZNUM = 38311 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone CODN4H
mkstat = 0
zoncou = "CODN4H"
indice = 0
If varmode([M]CODN4H,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODN4H" : Gosub ACTION From =IMPTRT
 Endif
Endif

