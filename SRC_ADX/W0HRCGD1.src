If varmode([M]DETN4H,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DETN4H" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone REGSTR
mkstat = 0
zoncou = "REGSTR"
indice = 0
IMPENT = [M]REGSTR
If varinit([M]REGSTR,indice)=0
 IMPENT = 1
Endif
If varmode([M]REGSTR,indice)=0
 [M]REGSTR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "REGSTR" : Gosub ACTION From =IMPTRT
