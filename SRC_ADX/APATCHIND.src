End

$INDTEX
# pour  l'instant rien
#Infbox "code reservé indus"
 For K=1 To NBLAN
  NUMERO = val([L]CLEOBJ)
  Read [ITX_]NUMERO = LANGUE(K);NUMERO
  If fstat = 0
      If [F:ITX_]TEXTE <> ""
          Wrseq '5';'"'+[F:ITX_]TEXTE+'"';'"'+LANGUE(K)+'"';num$(NUMERO);'"'+[F:ITX_]COMMENT+'"'
      Endif
  Endif
 Next K
Return

