  If mkstat : GERR = 1 : GZONE = "WFDSITSPRC" : GZNUM = 3568 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]WFDSITSPRC(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WFDSITSPRC([M]WFDSITSPRC(indice)) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WFDSITSPRC" : GZNUM = 3568 : Endif
    Gosub AFF From GSAISIE
