# Superviseur
# Gestion du masque HRMAT12 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"
indice = 0
status = 1
zoncou = "NBRPAR"
If varmode([M]NBRPAR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRPAR From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRPAR : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPAR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPAR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPAR = nolign
   status = 75
   Call SAI_NBRPAR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRPAR From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRPAR" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone WPARDAT
mkstat = 0
zoncou = "WPARDAT"
indice = 0
If varmode([M]WPARDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WPARDAT([M]WPARDAT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WPARDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPARDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_WPARDAT([M]WPARDAT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WPARDAT" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone WFLGPAR
mkstat = 0
zoncou = "WFLGPAR"
indice = 0
IMPENT = [M]WFLGPAR
WNUM = IMPENT
If varinit([M]WFLGPAR,indice)=0
 IMPENT = 2
Endif
If varmode([M]WFLGPAR,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WFLGPAR(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WFLGPAR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGPAR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGPAR(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WFLGPAR(IMPENT) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WFLGPAR" : GZNUM = 46653 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]WFLGPAR = IMPENT

## Zone WFLGITS
mkstat = 0
zoncou = "WFLGITS"
indice = 0
IMPENT = [M]WFLGITS
WNUM = IMPENT
If varinit([M]WFLGITS,indice)=0
 IMPENT = 2
Endif
If varmode([M]WFLGITS,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WFLGITS(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WFLGITS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFLGITS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WFLGITS(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_WFLGITS(IMPENT) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WFLGITS" : GZNUM = 46652 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]WFLGITS = IMPENT

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone WNBRFDSPAR
mkstat = 0
zoncou = "WNBRFDSPAR"
indice = 0
status = 1
zoncou = "WNBRFDSPAR"
WNUM = [M]WNBRFDSPAR
If varmode([M]WNBRFDSPAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WNBRFDSPAR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]WNBRFDSPAR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]WNBRFDSPAR = nolign
   status = 75
   Call SAI_WNBRFDSPAR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_WNBRFDSPAR From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WNBRFDSPAR" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]WNBRFDSPAR or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WNBRFDSPAR From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WNBRFDSPAR" : GZNUM = 0 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

## Zone WNBRFDSITS
mkstat = 0
zoncou = "WNBRFDSITS"
indice = 0
status = 1
zoncou = "WNBRFDSITS"
WNUM = [M]WNBRFDSITS
If varmode([M]WNBRFDSITS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WNBRFDSITS" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]WNBRFDSITS
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]WNBRFDSITS = nolign
   status = 75
   Call SAI_WNBRFDSITS(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_WNBRFDSITS From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WNBRFDSITS" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]WNBRFDSITS or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WNBRFDSITS From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WNBRFDSITS" : GZNUM = 0 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone WADD7
mkstat = 0
zoncou = "WADD7"
indice = 0
IMPENT = [M]WADD7
If varinit([M]WADD7,indice)=0
 IMPENT = 1
Endif
If varmode([M]WADD7,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WADD7(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WADD7(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WADD7" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WADD7(indice)
 Endif
Endif
[M]WADD7 = IMPENT

####################################
## Bloc liste 6
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRPAR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRPAR From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRPAR" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone FLGPAR
mkstat = 0
zoncou = "FLGPAR"
IMPENT = [M]FLGPAR(indice)
If varinit([M]FLGPAR,indice)=0
 IMPENT = 1
Endif
[M]FLGPAR(indice) = IMPENT

## Zone FLGITS
mkstat = 0
zoncou = "FLGITS"
IMPENT = [M]FLGITS(indice)
If varinit([M]FLGITS,indice)=0
 IMPENT = 1
Endif
[M]FLGITS(indice) = IMPENT

## Zone NBRPAR
mkstat = 0
zoncou = "NBRPAR"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_WNBRFDSPAR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone WNBRFDSPAR
mkstat = 0
zoncou = "WNBRFDSPAR"
SAVACT = GACTION : GACTION = "STD"
Call C_WNBRFDSPAR From SUBEML2
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WNBRFDSPAR" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone WFDSPAR
mkstat = 0
zoncou = "WFDSPAR"
WCHAR = [M]WFDSPAR(indice)
If varmode([M]WFDSPAR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFDSPAR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]WFDSPAR(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FDS","",[M]WFDSPAR(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_WFDSPAR([M]WFDSPAR(indice)) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]WFDSPAR(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WFDSPAR([M]WFDSPAR(indice)) From SUBEML2
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WFDSPAR" : GZNUM = 45508 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WFDSPARPRC
mkstat = 0
zoncou = "WFDSPARPRC"
WNUM = [M]WFDSPARPRC(indice)
If varmode([M]WFDSPARPRC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WFDSPARPRC" : Gosub ACTION From =IMPTRT
 Endif
 If [M]WFDSPARPRC(indice)=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "WFDSPARPRC" : GZNUM = 3568 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]WFDSPARPRC(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WFDSPARPRC" : GZNUM = 3568 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]WFDSPARPRC(indice) or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WFDSPARPRC([M]WFDSPARPRC(indice)) From SUBEML2
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WFDSPARPRC" : GZNUM = 3568 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone WNBRFDSPAR
mkstat = 0
zoncou = "WNBRFDSPAR"

End

####################################
## Bloc tableau 4
####################################
