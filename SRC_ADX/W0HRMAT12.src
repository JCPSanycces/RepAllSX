  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "WFDSITSPRC" : GZNUM = 3568 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]WFDSITSPRC(indice)<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
