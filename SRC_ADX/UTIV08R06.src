#<AdxTL>@(#)9.0.0.0 $Revision$
#######################################################################
# MAj des champs suplémentaires
#######################################################################
Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIV08R06 : Mise à jour de la norme DADS-U V08R06") From LECFIC
 Call EXE_UTIV08R06(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################
# Maj norme 
#########################################################
Subprog EXE_UTIV08R06(APPLI)
Value Char    APPLI
Call ECR_TRACE("UTIV08R06 : Process Start on : "+APPLI,0) From GESECRAN
Gosub MAJ_DAD
Call ECR_TRACE("UTIV08R06: Process End on : "+APPLI,0) From GESECRAN
End

#########################################################
$MAJ_DAD
Local File =APPLI+".EMPLOPRO"[PRO]
Local File =APPLI+".DADEMP"  [HRDAE]
Local File =APPLI+".DADEMP4" [DAC]
Local File =APPLI+".SITEPAYE"[HRSIT]
Local File =APPLI+".DADFCY"  [DFC]

Local Integer FLGECR

Call ECR_TRACE("UTIV08R06 : Mise jour des fichiers par les nouveautés DADS-U V08R06 ",0) From GESECRAN

##########
Trbegin [PRO]
GOK=1
For [PRO]PRO0
 FLGECR=0
 If dim([F:PRO]SYSFLG)>=0 & [F:PRO]SYSFLG=0 : [F:PRO]SYSFLG=1: FLGECR=1 : Endif
 If FLGECR
  Rewrite [F:PRO]
  If fstat :  GOK=0 : Break : Endif
 Endif
Next
If !GOK 
 Call ECR_TRACE("Echec de la mise à jour de la table EMPLOPRO",1) From GESECRAN
 Rollback 
Else 
 Call ECR_TRACE("Mise à jour de la table EMPLOPRO effectuée",0) From GESECRAN
 Commit 
Endif

############
Trbegin [HRDAE]
GOK=1
For [HRDAE]DAE0
 FLGECR=0
 If dim([F:HRDAE]NATBAS)>=0    & [F:HRDAE]NATBAS=0    : [F:HRDAE]NATBAS=1    : FLGECR=1 : Endif
 If dim([F:HRDAE]SYSFLG)>=0    & [F:HRDAE]SYSFLG=0    : [F:HRDAE]SYSFLG=1    : FLGECR=1 : Endif
 If dim([F:HRDAE]AGFFLG)>=0    & [F:HRDAE]AGFFLG=0    : [F:HRDAE]AGFFLG=1    : FLGECR=1 : Endif
 If dim([F:HRDAE]BUIDAYTYP)>=0 & [F:HRDAE]BUIDAYTYP=0 : [F:HRDAE]BUIDAYTYP=1 : FLGECR=1 : Endif
 If FLGECR
  Rewrite [F:HRDAE]
  If fstat :  GOK=0 : Break : Endif
 Endif 
Next
If !GOK 
 Call ECR_TRACE("Echec de la mise à jour de la table DADEMP",1) From GESECRAN
 Rollback
Else
 Call ECR_TRACE("Mise à jour de la table DADEMP effectuée",0) From GESECRAN 
 Commit 
Endif

############
Trbegin [DAC]
GOK=1
For [DAC]DAC0
 FLGECR=0
 If dim([F:DAC]OLDSPE)>=0 & [F:DAC]OLDSPE>2 : [F:DAC]OLDSPE=2 : FLGECR=1 : Endif
 If dim([F:DAC]DAYTYP)>=0 & [F:DAC]DAYTYP=0 : [F:DAC]DAYTYP=1 : FLGECR=1 : Endif
 If FLGECR
  Rewrite [F:DAC]
  If fstat :  GOK=0 : Break : Endif
 Endif 
Next
If !GOK 
 Call ECR_TRACE("Echec de la mise à jour de la table DADEMP4",1) From GESECRAN
 Rollback
Else
 Call ECR_TRACE("Mise à jour de la table DADEMP4 effectuée",0) From GESECRAN 
 Commit 
Endif

############
Trbegin [HRSIT]
GOK=1
For [HRSIT]FCY0
 FLGECR=0
 If dim([F:HRSIT]SECPRH)>=0 & [F:HRSIT]SECPRH=0  : [F:HRSIT]SECPRH=[F:HRSIT]REGPRH : FLGECR=1 : Endif
 If dim([F:HRSIT]FLGAPP)>=0 & [F:HRSIT]FLGAPP=0  : [F:HRSIT]FLGAPP=1             : FLGECR=1 : Endif
 If dim([F:HRSIT]FLGFOR)>=0 & [F:HRSIT]FLGFOR=0  : [F:HRSIT]FLGFOR=1             : FLGECR=1 : Endif
 If FLGECR
  Rewrite [F:HRSIT]
  If fstat :  GOK=0 : Break : Endif
 Endif 
Next
If !GOK 
 Call ECR_TRACE("Echec de la mise à jour de la table SITEPAYE",1) From GESECRAN
 Rollback
Else
 Call ECR_TRACE("Mise à jour de la table SITEPAYE effectuée",0) From GESECRAN 
 Commit 
Endif

############
Trbegin [DFC]
GOK=1
For [DFC]DFC0
 FLGECR=0
 If dim([F:DFC]SECPRH)>=0 & [F:DFC]SECPRH=0  : [F:DFC]SECPRH=[F:DFC]REGPRH : FLGECR=1 : Endif
 If dim([F:DFC]FLGAPP)>=0 & [F:DFC]FLGAPP=0  : [F:DFC]FLGAPP=1             : FLGECR=1 : Endif
 If dim([F:DFC]FLGFOR)>=0 & [F:DFC]FLGFOR=0  : [F:DFC]FLGFOR=1             : FLGECR=1 : Endif
 If FLGECR
  Rewrite [F:DFC]
  If fstat :  GOK=0 : Break : Endif
 Endif 
Next
If !GOK 
 Call ECR_TRACE("Echec de la mise à jour de la table DADFCY",1) From GESECRAN
 Rollback
Else
 Call ECR_TRACE("Mise à jour de la table DADFCY effectuée",0) From GESECRAN 
 Commit 
Endif

Close Local File [PRO],[HRDAE],[DAC],[HRSIT],[DFC]
Return

#########################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI="PAIE" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","EMPLOPRO","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADEMP","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADEMP4","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","SITEPAYE","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADFCY","fde",APPLI),0)<=0 : End : Endif 
Call EXE_UTIV08R06(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI="PAIE" : End : Endif
If filinfo(filpath("FIL","EMPLOPRO","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADEMP","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADEMP4","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","SITEPAYE","fde",APPLI),0)<=0 : End : Endif 
If filinfo(filpath("FIL","DADFCY","fde",APPLI),0)<=0 : End : Endif 
Call EXE_UTIV08R06(APPLI)
End



