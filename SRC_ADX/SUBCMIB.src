##########################################################################################################
# Traitement de gestion des champs
$CHAMPS
Local Integer INBFIENAM
Local Char SZTEXTE (100)
Local Char SZCHAMPS (50)
Local Integer ITROUVE
Local Integer IVISIBLE
Local Integer IPOSITION
Local Integer IMODE
Local Integer ISAISIE
Local Integer IAFFICHE

  INBFIENAM = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTV]FIENAM
    Raz [F:HTV]FIEVAL
  Endif
  #[ITN1]SCO
  #---------------------#
  # Sous-traité
  SZREFERENCE = "[ITN1]SCO"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI2]SCOCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]SCOCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI2]SCOCOD = 1
    Else
      [M:CMI2]SCOCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN1]SCOAMT
  #---------------------#
  # Montant sous-traité
  SZREFERENCE = "[ITN1]SCOAMT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI2]SCOAMTCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]SCOAMTCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI2]SCOAMTCOD = 1
    Else
      [M:CMI2]SCOAMTCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN1]CUR
  #---------------------#
  # Devise
  SZREFERENCE = "[ITN1]CUR"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI2]SCOAMTCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]SCOAMTCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI2]SCOAMTCOD = 1
    Else
      [M:CMI2]SCOAMTCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN1]FULOBJ
  #---------------------#
  # Complément d'informations
  SZREFERENCE = "[ITN1]FULOBJ"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI2]OBJCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]OBJCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI2]OBJCOD = 1
    Else
      [M:CMI2]OBJCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN1]OBJICO
  #---------------------#
  # Complément d'informations
  SZREFERENCE = "[ITN1]OBJICO"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMI2]OBJCOD>1
      [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
      [F:HTV]FIEVAL(INBFIENAM) = "3"
      INBFIENAM += 1
    Endif
  Endif
  #écran ITN3
  #[ITN3]DTCKIL
  #[ITN3]DTCKILX
  #---------------------#
  # Distance
  SZREFERENCE = "[ITN3]DTCKIL"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI3]DTCKILCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI3]DTCKILCOD)
    INBFIENAM += 1
    [F:HTV]FIENAM(INBFIENAM) = "[ITN3]DTCKILX"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI3]DTCKILCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI3]DTCKILCOD = 1
    Else
      [M:CMI3]DTCKILCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN3]TRITIM
  #[ITN3]TRITIMX
  #---------------------#
  # Temps de trajet
  SZREFERENCE = "[ITN3]DTCKIL"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI3]TRITIMCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI3]TRITIMCOD)
    INBFIENAM += 1
    [F:HTV]FIENAM(INBFIENAM) = "[ITN3]TRITIMX"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI3]TRITIMCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI3]TRITIMCOD = 1
    Else
      [M:CMI3]TRITIMCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN3]IFFADD
  #---------------------#
  # Indications particulières
  SZREFERENCE = "[ITN3]IFFADD"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI3]IFFADDCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI3]IFFADDCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI3]IFFADDCOD = 1
    Else
      [M:CMI3]IFFADDCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  # Ecran "ITN8"
  #[ITN8]IFFADD
  #---------------------#
  # Parc
  SZREFERENCE = "[ITN8]HDTMACSRE"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTMACCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTMACCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTMACCOD = 1
    Else
      [M:CMI4]HDTMACCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTCPN
  #---------------------#
  # Composant
  SZREFERENCE = "[ITN8]HDTCPN"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTCPNCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTCPNCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTCPNCOD = 1
    Else
      [M:CMI4]HDTCPNCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTTYP
  #---------------------#
  # Type de consommation
  SZREFERENCE = "[ITN8]HDTTYP"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTTYPCOD = 1
  Endif
  If SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTTYPCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTTYPCOD = 1
    Else
      [M:CMI4]HDTTYPCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTSTOFCY
  #---------------------#
  # Site de stockage
  SZREFERENCE = "[ITN8]HDTSTOFCY"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HSTOFCYCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HSTOFCYCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HSTOFCYCOD = 1
    Else
      [M:CMI4]HSTOFCYCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTSTOFCY
  #---------------------#
  # Sortie de stock
  SZREFERENCE = "[ITN8]HDTSTOISS"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]STOISSCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]STOISSCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]STOISSCOD = 1
    Else
      [M:CMI4]STOISSCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTISSQTY
  #---------------------#
  # Quantité à sortir
  SZREFERENCE = "[ITN8]HDTISSQTY"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]ISSQTYCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]ISSQTYCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]ISSQTYCOD = 1
    Else
      [M:CMI4]ISSQTYCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTISSISS
  #---------------------#
  # Quantité sortie
  SZREFERENCE = "[ITN8]HDTISSISS"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]ISSISSCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]ISSISSCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]ISSISSCOD = 1
    Else
      [M:CMI4]ISSISSCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTDONDAT
  #---------------------#
  # Effectué le
  SZREFERENCE = "[ITN8]HDTDONDAT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]DONDATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]DONDATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]DONDATCOD = 1
    Else
      [M:CMI4]DONDATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]BHDTDONHOU
  #---------------------#
  # Effectué à
  SZREFERENCE = "[ITN8]BHDTDONHOU"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]DONHOUCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]DONHOUCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]DONHOUCOD = 1
    Else
      [M:CMI4]DONHOUCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]SPGTIMHOU
  #[ITN8]SPGTIMMNT
  #---------------------#
  # Durée réelle
  SZREFERENCE = "[ITN8]SPGTIMHOU"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTTIMCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = "[ITN8]SPGTIMHOU"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTTIMCOD)
    INBFIENAM += 1
    [F:HTV]FIENAM(INBFIENAM) = "[ITN8]SPGTIMMNT"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTTIMCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTTIMCOD = 1
    Else
      [M:CMI4]HDTTIMCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTINV
  #---------------------#
  # Facturable
  SZREFERENCE = "[ITN8]HDTINV"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTINVCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTINVCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTINVCOD = 1
    Else
      [M:CMI4]HDTINVCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTAMT
  #---------------------#
  # Montant consommé
  SZREFERENCE = "[ITN8]HDTAMT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTAMTCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTAMTCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTAMTCOD = 1
    Else
      [M:CMI4]HDTAMTCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTAMTINV
  #---------------------#
  # Montant facturable
  SZREFERENCE = "[ITN8]HDTAMTINV"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]AMTINVCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]AMTINVCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]AMTINVCOD = 1
    Else
      [M:CMI4]AMTINVCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTCUR
  #---------------------#
  #Devise
  SZREFERENCE = "[ITN8]HDTCUR"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMI4]HDTAMTCOD > 2 Then
      If [M:CMI4]AMTINVCOD > 2 Then
        [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
    Endif
  Endif
  #[ITN8]PITHDT
  #---------------------#
  # Points débités
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    SZREFERENCE = "[ITN8]PITHDT"
    If SZTYP_ACTION = "INIT" Then
      [M:CMI4]HDTPITCOD = 1
    Elsif SZTYP_ACTION = "ENREG" Then
      [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTPITCOD)
      INBFIENAM += 1
    Elsif SZTYP_ACTION = "READ" Then
      ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
      If ITROUVE = 0 Then
        [M:CMI4]HDTPITCOD = 1
      Else
        [M:CMI4]HDTPITCOD = val([F:HTV]FIEVAL(ITROUVE-1))
      Endif
    Endif
  Endif
  #[ITN8]HDTTEX
  #---------------------#
  # Texte
  SZREFERENCE = "[ITN8]HDTTEX"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTTEXCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTTEXCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTTEXCOD = 1
    Else
      [M:CMI4]HDTTEXCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[ITN8]HDTNUM
  #---------------------#
  # Chrono
  SZREFERENCE = "[ITN8]HDTNUM"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]HDTNUMCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]HDTTEXCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI4]HDTNUMCOD = 1
    Else
      [M:CMI4]HDTNUMCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #Ecran ITN4
  #[ITN4]HTOTTIMSPG
  #[ITN4]MTOTTIMSPG
  #[ITN4]TIMSPGX
  #[ITN4]TIMSPGY
  #---------------------#
  #Temps réellement passé
  SZREFERENCE = "[ITN4]HTOTTIMSPG"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI2]TIMSPGCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = "[ITN4]HTOTTIMSPG"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]TIMSPGCOD)
    INBFIENAM += 1
    [F:HTV]FIENAM(INBFIENAM) = "[ITN4]MTOTTIMSPG"
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]TIMSPGCOD)
    INBFIENAM += 1
    If [M:CMI2]TIMSPGCOD > 2 Then
      [F:HTV]FIENAM(INBFIENAM) = "[ITN4]TIMSPGX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]TIMSPGCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[ITN4]TIMSPGY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI2]TIMSPGCOD)
      INBFIENAM += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMI2]TIMSPGCOD = 1
    Else
      [M:CMI2]TIMSPGCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  # FGR 02/04/2015 : X3SUIVI105605 (début)
  #[ITN8]ECCVALMAJ
  #---------------------#
  # Version majeure
  If dim([M:CMI4]ECCCOD) >= 0 Then
    SZREFERENCE = "[ITN8]ECCVALMAJ"
    If SZTYP_ACTION = "INIT" Then
      [M:CMI4]ECCCOD = 1
    Elsif SZTYP_ACTION = "ENREG" Then
      [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]ECCCOD)
      INBFIENAM += 1
    Elsif SZTYP_ACTION = "READ" Then
      ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
      If ITROUVE = 0 Then
        [M:CMI4]ECCCOD = 1
      Else
        [M:CMI4]ECCCOD = val([F:HTV]FIEVAL(ITROUVE-1))
      Endif
    Elsif SZTYP_ACTION = "VERIF" Then
    Endif
  Endif
  #[ITN8]ECCVALMIN
  #---------------------#
  # Version mineure
  If dim([M:CMI4]ECCCODMIN) >= 0 Then
    SZREFERENCE = "[ITN8]ECCVALMIN"
    If SZTYP_ACTION = "INIT" Then
      [M:CMI4]ECCCODMIN = 1
    Elsif SZTYP_ACTION = "ENREG" Then
      [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
      [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMI4]ECCCODMIN)
      INBFIENAM += 1
    Elsif SZTYP_ACTION = "READ" Then
      ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
      If ITROUVE = 0 Then
        [M:CMI4]ECCCODMIN = 1
      Else
        [M:CMI4]ECCCODMIN = val([F:HTV]FIEVAL(ITROUVE-1))
      Endif
    Elsif SZTYP_ACTION = "VERIF" Then
    Endif
  Endif
  # FGR 02/04/2015 : X3SUIVI105605 (fin)
Return

