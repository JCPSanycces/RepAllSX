##########################################################################################################
# Traitement de gestion des colonnes fixes lors de la lecture
$COLFIX_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub COLFIX
Return

##########################################################################################################
# Traitement de gestion des colonnes fixes
$COLFIX
Local Integer ITROUVE
Local Integer INBTABLEAU
Local Char SZREFERENCE

  Raz SZREFERENCE
  INBTABLEAU = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]COLFIXNAM
    Raz [F:HTR]COLFIXVAL
    INBTABLEAU = 0
  Endif
  #ITN7 Réservation de ressources
  SZREFERENCE = "[ITN7]NBRER"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI1]COLFIXRER = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMI1]COLFIXRER <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU)= SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU)= [M:CMI1]COLFIXRER
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMI1]COLFIXRER = 0
    Else
      [M:CMI1]COLFIXRER = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #ITN8 Consommation
  SZREFERENCE = "[ITN8]NBLIG"
  If ACTION = "INIT" Then
    [M:CMI1]COLFIXHDT = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMI1]COLFIXHDT <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU)= SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU)= [M:CMI1]COLFIXHDT
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMI1]COLFIXHDT = 0
    Else
      [M:CMI1]COLFIXHDT = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
Return

