Return

##########################################################################################################
# Traitement de gestion des blocs
$BLOCS
Local Integer INBBLOCINVI

  INBBLOCINVI = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]BLOCINVI
  Endif
  #Gestion du temps
  SZREFERENCE = "[ITN8]10"
  If SZTYP_ACTION = "INIT" Then
    [M:CMI4]ITNTIMFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMI4]ITNTIMFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMI4]ITNTIMFLG = 2
    Else
      [M:CMI4]ITNTIMFLG = 1
    Endif
  Endif
Return

