#<AdxTL>@(#)5.0.0.0 $Revision$
GBIDI1 = 1
Call OBJET("PAH",GBIDC1,GBIDC2) From GOBJET
End


$SELECH
Case ACTSELECH
 When "DEBUT"
  Local Libelle BPRFIX, FLMT
  Local Integer IND, CAS, FINTYP, I, J, K
  Local Integer USRPAZ, MAXPAZ
  Local Decimal NNUM, NLIG, MT, MT2, MTAGIO, MTLOC, MTAGIOLOC
  Local Decimal MTRPT, MTAGIORPT
  Local Char    CRITERE(200), BPR(GLONBPR), PRIO(2), OPT(1), ODEFMASK(200)
  Local Char    LLEVPAZ(3), CODE_ESC(10)
  Local Integer BPROPT, FCYOPT
  Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
  [L]USRPAZ=val(LLEVPAZ)
  [L]MAXPAZ=len(mess(0,510,1))
  If OPT="" : Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL : Endif
  [L]FCYOPT=val(OPT) : # OD inter-sites
  Call PARAM(VALEUR,"SEVBPRENT",OPT) From ADOVAL : [L]BPROPT=val(OPT) : # OD inter-tiers
  ODEFMASK=dbgstr(1)
  IND=SAVNOLIGN2-1 : NNUM=[M]DUDNUM(IND) : NLIG=[M]DUDLIG(IND)
  If [M]IPTTYP(IND)=4
   CAS = 2
  Elsif NNUM<>0 & NLIG<>0
   Call LECDUD(NNUM,NLIG) From SUBPAH
   If fstat=0 & [F:DUD]NUM=VALEUR
&   & (([F:DUD]TYP="*SO" & [M]IPTTYP(IND)=1)
&   |  ([F:DUD]TYP="*PO" & [M]IPTTYP(IND)=2)
&   |  !find([M]IPTTYP(IND),1,2))
&   & (!(find([F:DUD]TYP,"*SO","*PO") & [F:DUD]PAMTYP=1))
    CAS=3
   Endif
  Endif
  If CAS : FIN=1 : FINTYP=0 : Return : Endif

  If [L]FCYOPT=1 : CRITERE="FCY='"+[M]FCY+"'"
  Else           : CRITERE="CPY='"+[M]CPY+"'"
  Endif

  Case [M]IPTTYP(IND)
   When 1       : CRITERE+=" & TYP='*SO'" : # Cde client
   When 2       : CRITERE+=" & TYP='*PO'" : # Cde fou
   When Default : CRITERE+=" & TYP='"+[M]VCRTYP(IND)+"'"
  Endcase
  If VALEUR<>""               : CRITERE+=" & NUM='"+VALEUR+"'" : Endif
  If find([M]IPTTYP(IND),1,2) : CRITERE+=" & PAMTYP<>1" : Endif
  Filter [DUD] Where evalue(CRITERE)
  [L]BPR=[M]BPR
  Local Mask REGECHW [RECH]
  Default Mask ODEFMASK
  Raz [M:RECH] : I = dim([M:RECH]BPRPAY)
  nolign = 0 : J = 0
  Repeat
   If [L]BPR<>"" : [L]BPRFIX=![L]BPRFIX : Endif
   If [L]BPR="" & VALEUR<>""
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD0
   Else
    Filter [DUD] Where evalue(CRITERE) Order By Key DUD3
   Endif
   For [DUD] Where FLGCLE=1 & ((BPRPAY=[L]BPR & [L]BPRFIX) | ![L]BPRFIX) With Nohint
    If nolign>=I : Break : Endif
    Call MTECHE(MT,MTLOC,MTRPT,MTAGIO,MTAGIOLOC,MTAGIORPT,-1)
    nolign+=1 : [M:RECH]=[F:DUD]
    [M:RECH]ACCLIG(nolign-1)=[F:DUD]DUDLIG
    [M:RECH]SOLDE(nolign-1)=MT
    [M:RECH]TOTAL += [M:RECH]AMTCUR(nolign-1)-[M:RECH]SOLDE(nolign-1)
    If !J & MT>0 : J=nolign : Endif
    If NNUM=[F:DUD]ACCNUM & NLIG=[F:DUD]DUDLIG : J=nolign : Endif
   Next : # [DUD]
   [M:RECH]DEVISE = [M:RECH]CUR(0)
  Until nolign | ![L]BPRFIX
  Filter [DUD]
  If !J : J=1 : Endif
  [M:RECH]NECH=nolign
  If nolign>1 & !find("",[M:RECH]BPRFCT(0..[M:RECH]NECH-1))
   # Facture gérée par le factor XXX
   GMESSAGE=mess(89,121,1)-[M:RECH]BPRFCT(0) : GERR=1 :  FIN=1 : FINTYP=2 : Return
  Endif
  CHARGE=0 : Default Mask [RECH]

 When "FIN"

  If !CAS & PARAM(3)="1"
   NNUM=val(PARAM(1)) : NLIG=val(PARAM(2))
  Endif

  IND=SAVNOLIGN2-1 : PARAM(1)=num$([M]DUDNUM(IND)) : PARAM(2)=num$([M]DUDLIG(IND))
  Default Mask ODEFMASK
  If FINTYP=2 | (!CAS & PARAM(3)="-1") : mkstat=2 : Return
  Elsif !CAS & PARAM(3)="0" : # Pas d'échéance
   If find([M]IPTTYP(IND),1,2) & ([M]IPTTYP(IND)=1 | [L]USRPAZ>=[L]MAXPAZ)
    Case [M]IPTTYP(IND)
     When 1
      Call LECTURE("SOH",VALEUR,"") From CONTOBJ
      If fstat=0 : I=[F:SOH]INVSTA : Else I=-1 : Endif
     When 2
      Call LECTURE("POH",VALEUR,"") From CONTOBJ
      If fstat=0 : I=[F:POH]INVFLG : Else I=-1 : Endif
    Endcase
    Case I
     When -1 : # Aucune échéance
      GMESSAGE=mess(10,117,1) : mkstat=2 : Return
     When 3 : # Commande totalement facturée
      GMESSAGE=mess(57,117,1) : mkstat=2 : Return
     When 2 : # Cde partiellement facturée
      GMESSAGE=mess(58,117,1)+"\"
     When Default : GMESSAGE=""
    Endcase
    GMESSAGE+=mess(21,117,1) : # Pas d'acompte demandé
    OK=2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
    If OK<>2 : mkstat=2 : Return
    Else : CAS = OK
    Endif
   Else : # Aucune échéance
    GMESSAGE=mess(10,117,1) : mkstat=2 : Return
   Endif
  Endif

  GMESSAGE=""
  If CAS=0 | CAS=3
   ## Contrôles bloquants
   Read [DUD]DUD1 = NNUM;NLIG
   If fstat
    GOK=2 : Call RSTA("DUD",num$(NNUM)-num$(NLIG)) From GLOCK : mkstat=2 : Return
   Endif
   Gosub CTL_DUD
   If GMESSAGE<>"" : mkstat=2 : Return : Endif
   If NNUM<>[M]OD1 | NLIG<>[M]OD2
    ## Avertissements
    Call MTECHE(MT,MTLOC,MTRPT,MTAGIO,MTAGIOLOC,MTAGIORPT,IND) : FLMT=1 : # Echéance déjà soldée
    If [F:DUD]AMTCUR*MT<=0 : GMESSAGE+="\"+mess(15,117,1) : Endif
    Gosub VRF_DUD
    If instr(1,GMESSAGE,mess(28,121,1)) : mkstat=2 : Return : Endif  :# Bug 14084
   Endif : # NNUM<>DUDNUM & NLIG<>DUDLIG
  Endif
  If CAS<>2 & (NNUM<>[M]OD1 | NLIG<>[M]OD2)
   For I=0 To [M]NBLIG-1
    If I<>IND & [M]DUDNUM(I)=NNUM & [M]DUDLIG(I)=NLIG & [M]DENCOD(I)=[M]DENCOD(IND)
    GMESSAGE+="\"+mess(22,117,1)-num$(I+1) :# Echéance imputée ligne I+1
   Endif
  Next I
  If len(GMESSAGE)>=mod(type(GMESSAGE)-10,256)
    GMESSAGE="\"+mess(140,121,1) # Echéance imputée sur plusieurs lignes
  Endif
  ##
  If GMESSAGE<>""
   GMESSAGE=right$(GMESSAGE,2)
   I=2 : Call AVERTIR(GMESSAGE,I) From GESECRAN
   GMESSAGE="" : If I<>2 : mkstat=2 : Return : Endif
  Endif : # GMESSAGE
 Endif

 If NNUM<>[M]DUDNUM(IND) | NLIG<>[M]DUDLIG(IND)
  PARAM(1)=num$(NNUM) : PARAM(2)=num$(NLIG)

  CODE_ESC = [F:DUD]DEP

  ## Les agios sont en (-) et les escomptes en (+)
  ## [M]SNSDUD vaut -1 pour les avoirs, +1 pour les factures
  If [M:PAH0]TYP = 1 : # Ordres de paiement
   [M]SNSDUD(IND) = [F:DUD]SNS*-1
  Else : # Récibos
   [M]SNSDUD(IND) = [F:DUD]SNS
  Endif

  If [M]SNSDUD(IND) = -1 : # Avoirs
   CODE_ESC = ""
   MTAGIO = 0 : MTAGIOLOC = 0 : MTAGIORPT = 0
  Endif

  [M]DUDNUM(IND) = NNUM
  [M]DUDLIG(IND) = NLIG
  [M]FCYLIN(IND) = [F:DUD]FCY
  [M]CURVCR(IND) = [F:DUD]CUR
  [M]AMTVCR(IND) = MT
  [M]DEP(IND)    = CODE_ESC
  [M]AMTDEP(IND) = MTAGIO
  [M]AMTLOC(IND)    = MTLOC
  [M]AMTLOCDEP(IND) = MTAGIOLOC
  [M]AMTLOCLIN(IND) = MTLOC - MTAGIOLOC
  [M]AMTRPT(IND)    = MTRPT
  [M]AMTRPTDEP(IND) = MTAGIORPT
  [M]AMTRPTLIN(IND) = MTRPT - MTAGIORPT
  [M]CURECH      = [F:DUD]CUR
  Affzo [PAH1]AMTVCR(IND) : Affzo [PAH1]CURVCR(IND) : Affzo [PAH1]DEP(IND) : Affzo [PAH1]AMTDEP(IND)
  Affzo [PAH1]TOTPAY : Affzo [PAH1]CURECH
 Endif
 [M]OVCR=[M]VCRTYP(IND)+"\"+VALEUR
Endcase
Return

$CTL_DUD
If [F:DUD]BPRFCT<>""
 GMESSAGE = mess(89,121,1)-[F:DUD]BPRFCT : Return :  # Facture gérée par le factor FACTOR
Elsif [F:DUD]DUDSTA<>2 & !find([F:DUD]TYP,"*SO","*PO")
 If [M:PAH0]TYP = 1
  Call LECTURE("BIS",[F:DUD]NUM,"") From CONTOBJ
  If fstat=0 & [F:PIH]GTE=[F:DUD]TYP
   If !find([F:PIH]ORIMOD,3,2)
    ## Echéance non validée
    GMESSAGE = mess(28,121,1)
    Return
   Endif
  Endif
 Else
  Call LECTURE("BIC",[F:DUD]NUM,"") From CONTOBJ
  If fstat=0 & [F:SIH]GTE=[F:DUD]TYP
   If !find([F:SIH]ORIMOD,3,2)
    ## Echéance non validée
    GMESSAGE = mess(28,121,1)
    Return
   Endif
  Endif
 Endif
Endif
If GMESSAGE<>"" : Return : Endif
Local Char    OPTCTLBAP(1)
Call PARAMUTIL("CTLPAZ",[L]OPTCTLBAP,"","") From SUBAUS
If [F:DUD]SNS=-1 & [F:DUD]FLGPAZ<[L]MAXPAZ & ([L]USRPAZ<[L]MAXPAZ | [L]OPTCTLBAP="1")
 # Echéance sans 'bon à payer'
 GMESSAGE = mess(16,117,1)
 If [F:DUD]FLGPAZ<>0 : GMESSAGE -= "("+mess([F:DUD]FLGPAZ,510,1)+")" : Endif
Elsif [L]BPROPT=1 & [M]BPR<>"" & !find([F:DUD]TYP,"*SO","*PO")
&  & (([F:DUD]SAC<>[M]BPRSAC & [F:CDA]ACCBPR="") | ([F:DUD]BPR<>[M]BPR & [F:DUD]BPRPAY<>[M]BPR))
 # Génération OD-Tiers SAC BPR
 GMESSAGE = mess(19,117,1)-[F:DUD]SAC-[F:DUD]BPR
Endif
Return


$VRF_DUD
If [F:DUD]SNS=-1 & [F:DUD]FLGPAZ<[L]MAXPAZ & [L]OPTCTLBAP<>"1"
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(16,117,1) : # Echéance sans 'bon à payer'
 If [F:DUD]FLGPAZ : GMESSAGE-="("+mess([F:DUD]FLGPAZ,510,1)+")" : Endif
Endif
If [F:DUD]SOINUM<>"" & OPT<>"R" : # Echéance sur relevé SOINUM
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(17,117,1)-[F:DUD]SOINUM
Endif
If [L]FCYOPT=3 & [M]FCY<>"" & [F:DUD]FCY<>[M]FCY : # Génération OD-sites
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(18,117,1)-[M]FCY-"->"-[F:DUD]FCY
Endif
If [L]BPROPT=3 & [M]BPR<>""
&  & (([F:DUD]SAC<>[M]BPRSAC & [F:CDA]ACCBPR="") | ([F:DUD]BPR<>[M]BPR & [F:DUD]BPRPAY<>[M]BPR))
 # Génération OD-tiers
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(19,117,1)-[M]BPRSAC-[M]BPR-"->"-[F:DUD]SAC-[F:DUD]BPR
Endif
If !find([F:DUD]TYP,"*SO","*PO") & [F:DUD]DUDSTA<>2
 # Echéance non validée
 Gosub MSG_VRF_DUD
 GMESSAGE+=mess(28,121,1)
Endif
Return

$MSG_VRF_DUD
GMESSAGE+="\" : # Echéance
If GIMPORT : GMESSAGE+=mess(1,292,1)-num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)+" : " : Endif
Return


##############################################################
Subprog MTECHE(MT,MTLOC,MTRPT,MTAGIO,MTAGIOLOC,MTAGIORPT,IND)
##############################################################
Value Integer IND
Variable Decimal MT
Variable Decimal MTLOC
Variable Decimal MTRPT
Variable Decimal MTAGIO
Variable Decimal MTAGIOLOC
Variable Decimal MTAGIORPT
Local Integer I, SIGN

Local Decimal TAUX_ESC, ARD
Local Integer DELAI

MT = 0    : MTAGIO = 0
MTLOC = 0 : MTAGIOLOC = 0
MTRPT = 0 : MTAGIORPT = 0

Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ
ARD=[F:TCU]CURRND

Case [M:PAH0]TYP
 When 1  # Ordre de paiement
  SIGN = [F:DUD]SNS*-1
 When 2
  SIGN = [F:DUD]SNS
Endcase

MT    = ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)
MTLOC = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)

If GCURSHR = [M:PAH1]CURVCR(0)
 MTRPT = MT
Elsif GCURSHR = [M:PAH1]CURCPY
 MTRPT = MTLOC
Else
 Call CONVERT([M:PAH1]CURVCR(0),GCURSHR,[M:PAH1]CURCPY,1,[M:PAH0]DAT,MT,MTRPT,STAT) From TRTDEV
 If STAT
  GOK=0 : GMESSAGE=mess(16,114,1)-[M:PAH1]CURVCR(0)-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[M:PAH0]DAT)-")"
  End
 Endif
Endif

For I=0 To [M]NBDOC-1
 If I<>IND & [F:DUD]ACCNUM=[M]DUDNUM(I) & [F:DUD]DUDLIG=[M]DUDLIG(I)
  MT-=[M]AMTVCR(I)
 Endif
Next I

# Destinations comptables des escomptes
Case [M:PAH0]TYP
 When 1 : Call PARAM([M:PAH0]CPY,"DENPAY",GDIV(2)) From ADOVAL  # AP Discounts
 When 2 : Call PARAM([M:PAH0]CPY,"DENDEP",GDIV(2)) From ADOVAL  # AR Discounts
Endcase
# Destinations comptables des agios
Call PARAM([M:PAH0]CPY,"DENCRG",GDIV(5)) From ADOVAL
If [F:DUD]DEP<>""
 Call ESC_AGIO([F:DUD]DEP,MT,[M:PAH0]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIO,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
 Call ESC_AGIO([F:DUD]DEP,MTLOC,[M:PAH0]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIOLOC,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
 Call ESC_AGIO([F:DUD]DEP,MTRPT,[M:PAH0]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIORPT,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
 If ([L]TAUX_ESC<0 & GDIV(2)="") or ([L]TAUX_ESC>0 & GDIV(5)="") : [L]TAUX_ESC=0 : Endif
Endif
If [L]TAUX_ESC <> 0
 If [L]TAUX_ESC>0 and DELAI<0 : [L]MTAGIO *= -1 : [L]MTAGIOLOC *= -1 : Endif
 [L]MTAGIO    = arr([L]MTAGIO,ARD)
 [L]MTAGIOLOC = arr([L]MTAGIOLOC,ARD)
 [L]MTAGIORPT = arr([L]MTAGIORPT,ARD)
Endif

MTAGIO    = -[L]MTAGIO*[L]SIGN
MTAGIOLOC = -[L]MTAGIOLOC*[L]SIGN
MTAGIORPT = -[L]MTAGIORPT*[L]SIGN

If GREP<>"M" : End : Endif
For [PAO]PAO1 Where NUM=[M]NUM & DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
 MT += [F:PAO]AMTVCR
Next

End
