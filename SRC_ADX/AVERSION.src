#<AdxTL>@(#)10.0.0.0 $Revision$
Call VERSION
End

$ACTION
Case ACTION
 When "TRT_DIV" : Call VERSION
Endcase
Return

Subprog VERSION

Local Integer STAT
Local Char    VERADO(80) , VERAPL(80)(1..2) , BUILD(20) , RELEASE(10)
Local Char    FICAPL(250)
Local Char    SAVIFS(5) , SAVIRS(5)

# Version adonix
Call SYSTEME2(adxmac(0),"adonix -v"-nomap,"",STAT,VERADO) From ORDSYS

# Version appli
FILAPL = filpath("","version","inf")
If filinfo(FILAPL,0)>=0
 SAVIFS = adxifs
 SAVIRS = adxirs
 adxifs = ""
 adxirs = chr$(10)
 Openi FILAPL
 Rdseq VERAPL(1)
 Rdseq VERAPL(2)
 Openi
 adxifs = SAVIFS
 adxirs = SAVIRS
Endif

# No release

Call PARAM("","RELEASE",RELEASE) From ADOVAL

# No build du client X3
Call PARCLI("X3FileVersion",BUILD) From GLOBVAR

Call MESSAGE(
&  "Adonix :"-VERADO
& +"\\X3 :"-GVERCLI+" - No Build :"-BUILD
& +"\\"+mess(23,151,1)-":"-VERAPL(1)-VERAPL(2)-"("+RELEASE+")"
& +"\\"+mess(1,14,1)-":"-GVERSION
& ) From GESECRAN
#& Titled mess(98,115,1)
End
