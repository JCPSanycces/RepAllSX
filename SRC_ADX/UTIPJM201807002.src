#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201807002
# Issue X3-101580 - 2018-07-23 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201807002(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201807002(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Integer ITOCREATE
Local Char AREQ(250)(0..)
Local Integer IREQ

  Call ECR_TRACE("UTIPJM201807002: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL" [ADW]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [ADW]
  IREQ = 0
  IREQ += 1 : AREQ(IREQ) -= "SELECT A.PARAM_0"
  IREQ += 1 : AREQ(IREQ) -= "From " + DOSSIER + ".ADOPAR A"
  IREQ += 1 : AREQ(IREQ) -= "Where 1=1"
  IREQ += 1 : AREQ(IREQ) -= "  and A.CHAPITRE_0 = 'TC' and A.GRPPAR_0 = 'PJM'"
  IREQ += 1 : AREQ(IREQ) -= "  and not EXISTS(SELECT 'x' From " + DOSSIER + ".ADOVAL B Where B.PARAM_0 = A.PARAM_0 and B.CMP_0 = ' ' and B.FCY_0 = ' ')"
  For (Char PARAM(GLONADP)) From num$(GTYPDBA*2+1) Sql AREQ As [WWW]
    ITOCREATE = 1
    Raz [F:ADW]
    [F:ADW] = [F:WWW]
    Case [F:WWW]PARAM
      When "PJMTIMAUTO"
        ITOCREATE = 2
        [F:ADW]VALEUR = "1"
      When "PJMLOGFIL"
        ITOCREATE = 2
        [F:ADW]VALEUR = "1"
      When "PJMAUSCST0"
        ITOCREATE = 2
        [F:ADW]VALEUR = "1"
      When "PJMTIMBUD"
        ITOCREATE = 2
        [F:ADW]VALEUR = "2"
      When "PJMDEFSTA"
        ITOCREATE = 2
        [F:ADW]VALEUR = "1"
      When "PJMTIMENT"
        ITOCREATE = 2
        [F:ADW]VALEUR = "1"
    Endcase
    If ITOCREATE = 2 Then
      COMPTEUR += 1
      Write [F:ADW]
      If fstat Then
        Call ECR_TRACE("File ADOVAL" - [F:ADW]CMP - "/" - [F:ADW]FCY - "/" - [F:ADW]PARAM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201807002 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201807002 : records processed with error(s).", 0) From GESECRAN
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807002(APPLI)
End

