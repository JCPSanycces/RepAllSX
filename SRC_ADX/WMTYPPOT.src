#<AdxTL>@(#)0.0.0.0 $Revision$Class Position
# Supervisor
## ATY-ATYPE ## POT
# 2018-11-09 07:14:56 087

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,COD,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char COD
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File POSTE [POT]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".POSTE" [POT]
Endif

Default File [F:POT]
Read [F:POT]POT0 = [L]COD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]COD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]COD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


