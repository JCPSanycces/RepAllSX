$CHARGE_BOM
GCONBOM_BOM+=1
Onerrgo FIN_ERRGO_BOM
Local Shortint IADIME : IADIME = 30    : # Taille pour le Setmode
Local Integer  INBAFF                  : # Pile/Indice
Local Integer  IAFFCOD(0..IADIME)      : # Code instruction
Local Char     IAFFMASK(GLONABR)(0..IADIME)  : # Abréviation écran
Local Char     IAFFCHP(50)(0..IADIME)        : # Zone écran
Local Integer  IAFFIND(0..IADIME)            : # Indice de la zone
Local Char     IAFFTXT(250)(0..IADIME) : # Texte
Local Integer  IAFFRANG(0..IADIME)     : # Rang
Local Integer  IAFFOPT1(0..IADIME)     : # Option1 Ex: Status, premier rang affzo 10-20
Local Integer  IAFFOPT2(0..IADIME)     : # Option2 Ex: Raccourci clavier, dernier rang affzo 10-20

Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
Local Char    PROGIMP(GLONADC) , PROGIMS(GLONADC)
Local Char    OBJLIS(GLONAOB)(1..8)
Local Integer AMA(0..16) , RESTMSK(0..16)
Local Integer CRE, MODI, SUPPR, ISITE
Local Char    ERRMES(50)
Local Integer NRMASK , ILIS , RELIT
Local Integer PSPE, PSUB, PSPV, PSTD
Local Integer PIMP
Local Char    SYMBOLE(35)
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16), CLE2(GLONID2)(0..16)
Local Char    SCLE2(GLONID2) , COUZON(GLONAVA)
Local Integer TPCLE1 , TPCLE2(0..16)
Local Char    SAVCLE1(GLONID1) , SAVCLE2(GLONID2)
Local Char    FILTRE(240) , FILTSUP(240) , CRITTAB(250)
Local Char    CRITERE(250) , FILROLE(250) , FILSUITE(250)
Local Integer ICRITERE , IFILROLE , IFILSUITE
Local Char    ACTION(20) , CHAINE(20) , REP(1)
Local Char    MESSA(250)
Local Char    IDENT(50), ABREV(GLONAOB), SITCUR(15)
Local Integer MA, CL , CLECUR, AFFICHE, AUTENA, OPTENA, OPTDOC , OKTRT,OK
Local Integer TUNNEL, VERROU
Local Integer NBMEN , NBRMEN , ETAMEN(1..60)
Local Char    CHMEN(30) , BOUT(1)
Local Integer GPLMTR : GPLMTR=0
Local Char GCLEPLM(GLONPLM)
Local Char GREPPLM : # "C" ou "M"

OK=1

# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
If WBOMALTTYP = 2 #production
  ABREV="BOD"
  # Issue 86381 - 2013-01-03 by RBA
  GABREV=ABREV
  #/ Issue 86381 - 2013-01-03 by RBA
  ABFIC="BOH"
  WINPROG="WGOBODP"
  # Issue 80297 - 2012-27-02 by RBA
  # Issue 81372 - 2012-05-04 by SR
  Call ISWINDOWOK (nomap,"OBODP") From INTRUTILB
  GFONBOD="BOMP"
  ### "WOBOD SUBBOD SPEBOD SPVBOD"
  Call SETPROG("BOD",PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Elsif WBOMALTTYP = 3 #sous-traitance
  ABREV="BOD"
  GABREV=ABREV
  ABFIC="BOH"
  WINPROG="WGOBODS"
  Call ISWINDOWOK (nomap,"OBODS") From INTRUTILB
  GFONBOD="BOMS"
  ### "WOBOD SUBBOD SPEBOD SPVBOD"
  Call SETPROG("BOD",PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Endif

#ABREV="BOD"
