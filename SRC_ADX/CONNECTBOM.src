#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance

Gosub DEFVAR From =WINPROG

# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif

Gosub OUVRE_MSK From GOBJET
For MA=0 To NBMASK
    Gosub RAZMASK From =WINPROG
Next MA
Gosub OUVRE From =PROGOBJ

ACTION="OUVRE"
# Issue 79241 - 2012-01-12 by VPO : pb sur action SPE OUVRE
#Gosub ACTION From =PROGSUB
#Appel des actions OUVRE spécifiques et verticales
Gosub ACTIONG From SUBIMPOBJ

If !OK : Goto FIN_BOM_ERR : Endif

If evalue("clalev([F:"+ABFIC+"])")=0 : Gosub OUVFIC From =PROGOBJ : Endif
Default File [F:BOH]

GCLEPLM=func CONNECTFCT.GETVAL("BOM","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
If GCLEPLM=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_BOM_ERR
Endif

If !OK : Goto FIN_BOM_ERR : Endif

Raz [F:ITM]
If [F:PIT]TYP=2 : #PLM Nomenclatures
    Read [F:ITM]ITM5=GCLEPLM
    If fstat
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(16,7710,1)-GCLEPLM,1) From GESECRAN : # Ligne x Article PLM inexistant
        Goto FIN_BOM_ERR
    Endif
Else
    Read [F:ITM]ITM0=GCLEPLM
    If fstat
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(212,199,1)-GCLEPLM,1) From GESECRAN : # Ligne x Article inexistant
        Goto FIN_BOM_ERR
    Endif
Endif

Raz [F:BOH]
Raz [F:BOD]
GCLE=""
If pat(GVERSION,"1.5.*")
Read [F:BOH]BOH0=[F:ITM]ITMREF;[F:PPA]BOMALT
Else
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
#Read [F:BOH]BOH0=[F:ITM]ITMREF;[F:PPA]BOMALT;2
Read [F:BOH]BOH0=[F:ITM]ITMREF;[F:PPA]BOMALT;WBOMALTTYP
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance
Endif
If fstat
    GREPPLM = "C"
Else
    GREPPLM = "M"
    Gosub SETCLE
    Gosub VERROU
    If !OK : Goto FIN_BOM_ERR : Endif
    Onerrgo FIN_ERRGO_VERROU
#VPO 17/09/09 il ne faut pas faire de transaction ici
#    Trbegin [BOH]
#    GPLMTR=1
#    If pat(GVERSION,"1.5.*")
#    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT
#    Else
#    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP
#    Endif
#    Delete [BOH] Curr
Endif

##If fstat
## ici, on est toujours en creation
If 1=1
 CLECUR = 0
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : Goto FIN_BOM_VERROU : Endif
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK
   GREP = "C" : REP = "C"
   ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
   ###ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 Endif
Else
 Gosub SETCLE
 Gosub VERROU
 If !OK : Goto FIN_BOM_ERR : Endif
 Onerrgo FIN_ERRGO_VERROU
 nolign = 1
 For IMA=0 To NBMASK
  If AMA(IMA)
   Gosub CHARGEMSK From =WINPROG
  Endif
 Next IMA
 For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
 Next MA
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
 CLECUR = 1
 CHAINE = "M"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ###ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M")
  OK = 1
  ACTION = "AVANT_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_AVANT_MOD" : Gosub ACTION  From SUBIMPOBJ
 Else
  OK = 0
 Endif
 GREP = "M" : REP = "M"
Endif

If !OK | GREP="" : Goto FIN_BOM_VERROU : Endif

#on affecte les valeurs du mask
[M:BOH0]ITMREF = [F:ITM]ITMREF
[M:BOH0]BOMALT = [F:PPA]BOMALT
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
#[M:BOH0]BOMALTTYP = 2
[M:BOH0]BOMALTTYP = WBOMALTTYP
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance
If GREP="C"
    Gosub VALDEFMSKBOM
Endif
nolign = 1
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
If WBOMALTTYP = 2
  For MA=0 To NBMASK
      If ABMSK(MA)<>"BOD1"
          Gosub SETMASK From =WINPROG
          nolign=1
          For NOPIV=1 To NBPIVZON
              If pat(WPIVTABZON(NOPIV),"BOM/*") & find(WPIVZON(NOPIV),"ITMREF","BOMALT","BOMALTTYP")=0
                  If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                     Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
                  Endif
              Endif
          Next
      Endif
  Next MA
Elsif WBOMALTTYP = 3
  For MA=0 To NBMASK
    If ABMSK(MA)<>"BOS2" and ABMSK(MA)<>"BOD1"
        Gosub SETMASK From =WINPROG
        nolign=1
        For NOPIV=1 To NBPIVZON
            If pat(WPIVTABZON(NOPIV),"BOM/*") & find(WPIVZON(NOPIV),"ITMREF","BOMALT","BOMALTTYP")=0
                If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
                   Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
                Endif
            Endif
        Next
    Endif
  Next MA
Endif
#For MA=0 To NBMASK
#    If ABMSK(MA)<>"BOD1"
#        Gosub SETMASK From =WINPROG
#        nolign=1
#        For NOPIV=1 To NBPIVZON
#            If pat(WPIVTABZON(NOPIV),"BOM/*") & find(WPIVZON(NOPIV),"ITMREF","BOMALT","BOMALTTYP")=0
#                If evalue("dim([M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
#                   Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:"+ABMSK(MA)+"]"+WPIVZON(NOPIV),WPIVVAL(NOPIV),OK) From CONNECTFCT
#                Endif
#            Endif
#        Next
#    Endif
#Next MA
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance
#cas particulier


If !OK : Goto FIN_BOM_VERROU : Endif

$FIN_BOM
Return
$FIN_BOM_VERROU
If GPLMTR : Rollback : GPLMTR=0 : Endif
Gosub DEVERROU
$FIN_BOM_ERR
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Return

#####FIN onerrgo###########
$FIN_ERRGO_VERROU
Onerrgo
#on est en erreur sur la ligne
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,1) From GESECRAN : # erreur
If errn
    Call ECR_TRACE(errp+"("+num$(errl)+"):"-errmes$(errn),1) From GESECRAN
Endif
If GPLMTR : Rollback : GPLMTR=0 : Endif
Gosub DEVERROU
$FIN_ERRGO_BOM
Onerrgo
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
ERR=1
OK=0
Resume


$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
###ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
###If !OK : Return : Endif
OK = 1
SYMBOLE = format$("K:3X",ABFIC)+GCLE
Lock =SYMBOLE With lockwait=0
If fstat
  Call ECR_TRACE(GCLEPLM-mess(61,141,1),1) From GESECRAN : # Fiche en cours de modification
  Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
  OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
SYMBOLE = format$("K:3X",ABFIC)+GCLE
If SYMBOLE <> ""
    Unlock =SYMBOLE
Endif
SYMBOLE = ""
Return

$SETCLE
CLECUR1 = [F:BOH]ITMREF
GCLE = num$([F:BOH]BOMALT)+"\"+[F:BOH]ITMREF+"\"+num$([F:BOH]BOMALTTYP)
Return

$VALID
 Gosub DEFAUT From =PROGOBJ
 Raz mkstat
 OK = 1
 Gosub VALIDOBJ
 If !OK
   # ici on sort de subprog VALID avec GMESSAGE=vide, si OK a été razé via $ACTIONG
   # qui a mis le message dans la trace puis l’a razé
   If GMESSAGE="" : GMESSAGE=ACTION : Endif
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
   GMESSAGE=""
 Elsif GOK>=1
   If GREPPLM="C"
        GCONBOM_NEW += 1
   Elsif GREPPLM="M"
        GCONBOM_MAJ += 1
   Endif
 Endif
 Raz GREP
Return

$VALIDOBJ
If GREP="C"
 ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(100,141,1),1) From GESECRAN : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"C",IDENT) From AWRK
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ###ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
   Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-mess(101,141,1),1) From GESECRAN : # Erreur modification
 Else
  Gosub SETCLE
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ###ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  ###Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM,-1) From GESECRAN
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
 Endif
Endif
Return

$TR1
GOK = 1
If !GPLMTR
Trbegin ADOVAL
Endif
  #VPO 17/09/09 ON PASSE LE Delete ICi
  If GREPPLM="M"
    #Trbegin [BOH]
    GPLMTR=1
    If pat(GVERSION,"1.5.*")
    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT
    Else
    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP
    Endif
    Delete [BOH] Curr
 Endif
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ###ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
GPLMTR =0
Return

$AB_TR1
Rollback
GPLMTR =0
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
GPLMTR =0
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
If !GPLMTR
Trbegin ADOVAL
Endif
  #VPO 17/09/09 ON PASSE LE Delete ICi
  If GREPPLM="M"
    #Trbegin [BOH]
    GPLMTR=1
    If pat(GVERSION,"1.5.*")
    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT
    Else
    Delete [BOD] Where ITMREF=[F:BOH]ITMREF & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP
    Endif
    Delete [BOH] Curr
 Endif
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 ###Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ###ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
GPLMTR =0
Return

$AB_TR2
Rollback
GPLMTR =0
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
###ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
GPLMTR =0
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#####################################################
$VALDEFMSKBOM
nolign=1
For MA=0 To NBMASK
    Gosub SETMASK From =WINPROG
    For [PDV]PDV0 Where ID=CONREF & CODFIC="BOM"
        If evalue("dim([M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE+")")>0
            TYP = evalue("type([M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE+")")
            Case TYP
            When 1, 2, 4, 5, 6, 7, 9
               Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With val([F:PDV]VALDEF)
            When 3
                Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With [F:PDV]VALDEF
            When Default
               Assign "[M:"+ABMSK(MA)+"]"+[F:PDV]CODZONE With [F:PDV]VALDEF
            Endcase
        Endif
    Next
Next MA
Return

#####################################################
$VALDEFMSKBOMD
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
If WBOMALTTYP = 2
  For [PDV]PDV0 Where ID=CONREF & CODFIC="BOMD"
    If evalue("dim([M:BOD1]"+[F:PDV]CODZONE+")")>0
        TYP = evalue("type([M:BOD1]"+[F:PDV]CODZONE+")")
        Case TYP
        When 1, 2, 4, 5, 6, 7, 9
           Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
        When 3
            Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        When Default
           Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
        Endcase
    Endif
  Next
Elsif WBOMALTTYP = 3
  If WMSK = "BOS2"
    For [PDV]PDV0 Where ID=CONREF & CODFIC="BOMD"
      If evalue("dim([M:BOS2]"+[F:PDV]CODZONE+")")>0
          TYP = evalue("type([M:BOS2]"+[F:PDV]CODZONE+")")
          Case TYP
          When 1, 2, 4, 5, 6, 7, 9
             Assign "[M:BOS2]"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
          When 3
              Assign "[M:BOS2]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
          When Default
             Assign "[M:BOS2]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
          Endcase
      Endif
    Next
  Elsif WMSK = "BOD1"
    For [PDV]PDV0 Where ID=CONREF & CODFIC="BOMD"
      If evalue("dim([M:BOD1]"+[F:PDV]CODZONE+")")>0
          TYP = evalue("type([M:BOD1]"+[F:PDV]CODZONE+")")
          Case TYP
          When 1, 2, 4, 5, 6, 7, 9
             Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With val([F:PDV]VALDEF)
          When 3
              Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
          When Default
             Assign "[M:BOD1]"+[F:PDV]CODZONE+"(nolign-1)" With [F:PDV]VALDEF
          Endcase
      Endif
    Next
  Endif
Endif

#For [PDV]PDV0 Where ID=CONREF & CODFIC="BOMD"
