#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBPLMINT","PLMINT",4,"SPEPLMINT") From GTRAITE
End

######################################################################
# CONNECTBOM : PLM Import des Nomenclatures                          #
######################################################################
$ACTION
Case ACTION
Endcase
Return


######################################################################
Subprog TRAITE(OS,FICCSV,FICCLI,CONPIT,CONREF,REJ,FICREJ,REF,FICREF,ERRG,ERRNOFIC)
Value Char OS(),FICCSV(),FICCLI(),CONPIT(),CONREF()
Value Integer REJ
Value Char FICREJ()
Value Integer REF
Value Char FICREF()
Variable Integer ERRG,ERRNOFIC

Local Integer ERR : ERR=0
Local Integer NOLIG : NOLIG=0
Local Integer OUVFICREJ: OUVFICREJ=0

Local Clbfile LIGCLOB(10)
# Issue 86383 - 2012-04-12 by RBA
Local Clbfile LIGCLOBREJ(10)
#/ Issue 86383 - 2012-04-12 by RBA
Local Clbfile LIGENTETE(10)
Local Integer ERRFIC : ERRFIC=0

Local Char WBOMREF(GLONPLM) : Raz WBOMREF
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
Local Integer WBOMALTTYP # pour stocker l'alternative : 2=production, 3=sous-traitance
Local Char WCPNTYP
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance
Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub INITPIVOT From CONNECTFCT

If clalev ([F:PDV]) = 0 : Local File PLMDEFVAL [PDV] : Endif
If clalev ([F:PPA]) = 0 : Local File PLMPAR [PPA] : Endif
Read [PPA]PPA0=CONREF
# Issue 85472 - 2013-18-01 by RBA : Sous-traitance
WBOMALTTYP=[F:PPA]BOMALTTYP
#/ Issue 85472 - 2013-18-01 by RBA : Sous-traitance
GIMPORT=1

 GCONBOM_NBF+=1
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("==========================",0) From GESECRAN
 If FICCLI<>""
  GCONBOM_FIC(GCONBOM_NBF)=FICCLI
  Call ECR_TRACE(mess(220,139,1)-"|"+FICCLI,0) From GESECRAN : # Traitement du fichier
 Else
  GCONBOM_FIC(GCONBOM_NBF)=FICCSV
  Call ECR_TRACE(mess(38,115,1)-"|"+FICCSV,0) From GESECRAN : # Lecture du fichier
 Endif

 Gosub OUVFIC
 Onerrgo FIN_ERRGO
 Gosub LIREFIC
 If ERRFIC
    ERRG+=1 : ERRNOFIC+=1
    Call ECR_TRACE(mess(14,7710,1),1) From GESECRAN : # Lecture du fichier impossible
    Goto FIN
 Endif

 While !ERRFIC
     Gosub CHARGEPIVOT From CONNECTFCT
     If !ERR
         If WBOMREF<>"" & WBOMREF<>func CONNECTFCT.GETVAL("BOM","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
             Gosub VALID_BOM
             If !ERR : WBOMREF=func CONNECTFCT.GETVAL("BOM","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL) : Gosub CHARGE_BOM : Endif
         Elsif WBOMREF=""
             WBOMREF=func CONNECTFCT.GETVAL("BOM","ITMREF",NBPIVZON,WPIVTABZON,WPIVVAL) : Gosub CHARGE_BOM
         Endif
         #Issue 85348 - 2012-04-12 by RBA
#         If !ERR : Gosub CHARGE_BOMD : Endif
         If !ERR
            Raz GPE
            GPOINT = "CHARGE_LIG"
            Gosub ENTREE From EXEFNC
            If GPE = 0
              If !ERR : Gosub CHARGE_BOMD : Endif
            Endif
            Raz GPE
         Endif
         #/Issue 85348 - 2012-04-12 by RBA
     Endif
     If ERR & REJ
        ERRG+=1
        # on doit ecrire dans le fichier des rejets
        Gosub ECR_REJ
     Else
        Gosub LIREFIC
     Endif
     ERR=0
 Wend
 If !ERR
     If WBOMREF<>""
         Gosub VALID_BOM
     Endif
 Endif
 If ERR & REJ
    ERRG+=1
    # on doit ecrire dans le fichier des rejets
    Gosub ECR_REJ
 Endif
$FIN
 Onerrgo
 Gosub FERMEFIC
 GIMPORT=0
 adxium = SAVADXIUM
 adxifs = SAVADXIFS
 adxirs = SAVADXIRS
End
############
$FIN_ERRGO
 ERRG+=1 : ERRNOFIC+=1
 Call ECR_TRACE(mess(17,7710,1),1) From GESECRAN : # Erreur sur traitement d'une ligne du fichier
 Goto FIN
############


######################################################################
#Ouverture du fichier CSV
$OUVFIC
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openi FICCSV,0 Using [FCSV]
 adxifs=""
 adxirs=IRS
 #VPO 10/12/09 60608 si chinois , il faut UTF8
 If GLANGUE="CHI"
 adxium=GUTF8
 Else
 adxium=GASCII
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FCSV]
 Iomode adxirs adxirs Using [FCSV]
 Iomode adxium adxium Using [FCSV]
 If WPIVHEATYP<>1
    Rdseq LIGCLOB Using [FCSV]
    If fstat=0
        LIGENTETE=LIGCLOB
        Call FILE_UTF8_BOM(LIGENTETE) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
 Endif
Return

$LIREFIC
Rdseq LIGCLOB Using [FCSV]
If fstat<>0
    ERRFIC=1
Else
    If NOLIG=0  & WPIVHEATYP=1
       Call FILE_UTF8_BOM(LIGCLOB) From CONNECTFCT : # FQ 65094 GA 06/2010
    Endif
    GCONBOM_ENR+=1
    NOLIG+=1
Endif
Return

$FERMEFIC
 Openi Using [FCSV]
 Openo Using [FREJ]
Return

######################################################################
#Ouverture du fichier REJ
$OUVFICREJ
 If OS="unix"
    IRS = chr$(10)
 Else
    IRS = chr$(13)+chr$(10)
 Endif

 Openo FICREJ,0 Using [FREJ]
 adxifs=""
 adxirs=IRS
 #VPO 10/12/09 60608 si chinois , il faut UTF8
 If GLANGUE="CHI"
 adxium=GUTF8
 Else
 adxium=GASCII
 Endif
 Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
 Iomode adxifs adxifs Using [FREJ]
 Iomode adxirs adxirs Using [FREJ]
 Iomode adxium adxium Using [FREJ]
 OUVFICREJ=1
 If WPIVHEATYP<>1
    Wrseq LIGENTETE Using [FREJ]
 Endif
Return

$ECR_REJ
If !OUVFICREJ
    Gosub OUVFICREJ
Endif
If OS="unix"
    IRS = chr$(10)
Else
    IRS = chr$(13)+chr$(10)
Endif
Openi FICCSV,0 Using [FREF]
adxifs=""
adxirs=IRS
#VPO 10/12/09 60608 si chinois , il faut UTF8
If GLANGUE="CHI"
adxium=GUTF8
Else
adxium=GASCII
Endif
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
Iomode adxifs adxifs Using [FREF]
Iomode adxirs adxirs Using [FREF]
Iomode adxium adxium Using [FREF]

#Issue 86383 - 2012-04-12 by RBA
#Rdseq LIGCLOB Using [FREF]
#While !fstat
#    If pat(LIGCLOB,WBOMREF+";*")
#        Wrseq LIGCLOB Using [FREJ]
#    Endif
#    Rdseq LIGCLOB Using [FREF]
#Wend
Rdseq LIGCLOBREJ Using [FREF]
While !fstat
    If pat(LIGCLOBREJ,WBOMREF+";*")
        Wrseq LIGCLOBREJ Using [FREJ]
    Endif
    Rdseq LIGCLOBREJ Using [FREF]
Wend
#/ Issue 86383 - 2012-04-12 by RBA
Openi Using [FREF]
GCONBOM_REJ+=1

If !ERRFIC
# on se positionne sur la nomenclature suivante
#Issue 86383 - 2012-04-12 by RBA
#Gosub LIREFIC
#/ Issue 86383 - 2012-04-12 by RBA
While !ERRFIC & pat(LIGCLOB,WBOMREF+";*")
    Gosub LIREFIC
Wend
Endif

Raz WBOMREF
Return

######################################################################
$INIVARNB
Global Integer GCONBOM_NBF : GCONBOM_NBF = 0 : #nombre de fichier BOM
Global Char    GCONBOM_FIC(GDIMFIC)(1..1000) : Raz GCONBOM_FIC
Global Integer GCONBOM_ENR : GCONBOM_ENR = 0 : #enreg lus
Global Integer GCONBOM_BOM : GCONBOM_BOM = 0 : #nomemclatures lus
Global Integer GCONBOM_NEW : GCONBOM_NEW = 0 : #enreg importés/nouveaux
Global Integer GCONBOM_MAJ : GCONBOM_MAJ = 0 : #enreg importés/maj
Global Integer GCONBOM_REJ : GCONBOM_REJ = 0 : #enreg rejetés
Return

$SUPVARNB
  # Désallocation des variables globales
  If dim(GCONBOM_NBF)>0 Then Kill GCONBOM_NBF Endif
  If dim(GCONBOM_FIC)>0 Then Kill GCONBOM_FIC Endif
  If dim(GCONBOM_ENR)>0 Then Kill GCONBOM_ENR Endif
  If dim(GCONBOM_BOM)>0 Then Kill GCONBOM_BOM Endif
  If dim(GCONBOM_NEW)>0 Then Kill GCONBOM_NEW Endif
  If dim(GCONBOM_MAJ)>0 Then Kill GCONBOM_MAJ Endif
  If dim(GCONBOM_REJ)>0 Then Kill GCONBOM_REJ Endif
Return
######################################################################

$VALID_BOM
Onerrgo FIN_ERRGO_BOM
Local Integer OK
OK=1

Gosub SETCLE : #pour avoir les zones cle renseignees
nolign = 1
For MA=0 To NBMASK
  TRTMSK="W0"+NOMMSK(MA)
  ##Infbox num$(MA)-TRTMSK
  If AMA(MA)
    Gosub SETMASK From =WINPROG
    mkstat=0
    GNBAFF=0
    #Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
    Call SAIMSK("BOM","IMP_ZONE","CONNECTBOM") From =TRTMSK
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSIMP,1) From GESECRAN : # erreur
    Endif
    Setmode
  Endif
Next MA

If !OK : Goto FIN_BOM_VERROU : Endif

Gosub VALID
If !OK : Goto FIN_BOM_VERROU : Endif
Gosub DEVERROU

Goto FIN_BOM

###########################################################
$CHARGE_BOMD
Onerrgo FIN_ERRGO_BOM
Local Integer OK
OK=1

Raz [F:ITM]
Local Char WCPNITMREF(GLONPLM)
WCPNITMREF=func CONNECTFCT.GETVAL("BOMD","CPNITMREF",NBPIVZON,WPIVTABZON,WPIVVAL)
If WCPNITMREF=""
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(9,7710,1),1) From GESECRAN : # Ligne x Référence non renseignée
    Goto FIN_BOM_VERROU
Endif

If [F:PIT]TYP=2 : #PLM Nomenclatures
    Read [F:ITM]ITM5=WCPNITMREF
    If fstat
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(16,7710,1)-WCPNITMREF,1) From GESECRAN : # Ligne x Article PLM inexistant
        Goto FIN_BOM_VERROU
    Endif
Else
    Read [F:ITM]ITM0=WCPNITMREF
    If fstat
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-mess(212,199,1)-WCPNITMREF,1) From GESECRAN : # Ligne x Article inexistant
        Goto FIN_BOM_VERROU
    Endif
Endif

#VPO 17/09/09 evol
If [F:PIT]TYP=2 : #PLM Nomenclatures
    If [F:ITM]ITMREF=[M:BOH0]ITMREF
        # on ne traite pas les lignes ayant la même référence article
        Return
    Endif
Endif


If WBOMALTTYP = 2
  #on affecte les valeurs du mask
  [M:BOD1]NBLIG+=1
  NOBOMD=[M:BOD1]NBLIG
  nolign=NOBOMD
  [M:BOD1]CPNITMREF(nolign-1)=[F:ITM]ITMREF
  # Issue 85566 - 2012-30-11 by RBA : forcage du BOMSEQ
  #If nolign > 1
  #    [M:BOD1]BOMSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign-2) + GBOMSTE
  #Else
  #    [M:BOD1]BOMSEQ(nolign-1) = GBOMSTE
  #Endif
  If func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL)<>""
    [M:BOD1]BOMSEQ(nolign-1) = val(func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL))
  Else
    If nolign > 1
        [M:BOD1]BOMSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign-2) + GBOMSTE
    Else
        [M:BOD1]BOMSEQ(nolign-1) = GBOMSTE
    Endif
  Endif
  #/ Issue 85566
  nolign=NOBOMD
  Gosub VALDEFMSKBOMD
  nolign=NOBOMD
  For NOPIV=1 To NBPIVZON
      If pat(WPIVTABZON(NOPIV),"BOMD/*") & find(WPIVZON(NOPIV),"BOMSEQ","CPNITMREF")=0
          nolign=NOBOMD
          If evalue("dim([M:BOD1]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
             Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:BOD1]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
          Endif
      Endif
  Next
  If !OK : Goto FIN_BOM_VERROU : Endif
  nolign=NOBOMD
  Call APRES_NBLIG From SUBBOD

  If [M:BOD1]LIKQTY(NOBOMD-1)<0
      [M:BOD1]CPNTYP(NOBOMD-1)=4
      [M:BOD1]LIKQTY(NOBOMD-1)=abs([M:BOD1]LIKQTY(NOBOMD-1))
  Endif
  Raz mkstat
  Call C_CPNITMREF([M:BOD1]CPNITMREF(NOBOMD-1)) From SUBBOD
  If dim([M:BOD1]BOMUOM)>0    # UML actif
      If [M:BOD1]BOMUOM(NOBOMD-1)="" : [M:BOD1]BOMUOM(NOBOMD-1)=[M:BOD1]STU(NOBOMD-1) : Endif
      Call BOMCOE([M:BOD1]BOMUOM(NOBOMD-1),[M:BOD1]STU(NOBOMD-1),[M:BOD1]CPNITMREF(NOBOMD-1),"BOD1") From UOMLIB
  Endif
  If mkstat
      GREP = "" : REP="" : OK=0
      Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
  Endif
  If !OK : Goto FIN_BOM_VERROU : Endif

  If dim([M:BOD1]BOMUOM)>0    # UML actif
      If [M:BOD1]BOMQTY(NOBOMD-1)<>0
      Call LIKQTY([M:BOD1]BOMQTY(NOBOMD-1),[M:BOD1]BOMSTUCOE(nolign-1),[M:BOD1]STU(nolign-1),"BOD1")  From UOMLIB
      Endif
  Endif
  If [M:BOD1]LIKQTY(NOBOMD-1)<>0
  Call AM_LIKQTY([M:BOD1]LIKQTY(NOBOMD-1)) From SUBBOD
  Call BOMQTY([M:BOD1]LIKQTY(NOBOMD-1),[M:BOD1]WBOMSTUCOE(nolign-1),"BOD1") From UOMLIB
  Endif
  If mkstat
      GREP = "" : REP="" : OK=0
      Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
  Endif
  If !OK : Goto FIN_BOM_VERROU : Endif

Elsif WBOMALTTYP = 3

  WCPNTYP = func CONNECTFCT.GETVAL("BOMD","CPNTYP",NBPIVZON,WPIVTABZON,WPIVVAL)

  If WCPNTYP = "7" #service
    Local Char WMSK
    WMSK = "BOS2"  #MSK SERVICE
    #on affecte les valeurs du mask
    [M:BOS2]NBLIG+=1
    NOBOMD=[M:BOS2]NBLIG
    nolign=NOBOMD
    [M:BOS2]CPNITMREF(nolign-1)=[F:ITM]ITMREF
    If func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL)<>""
      [M:BOS2]BOMSEQ(nolign-1) = val(func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL))
    Else
      If nolign > 1
          [M:BOD1]BOMSEQ(nolign-1) = [M:BOS2]BOMSEQ(nolign-2) + GBOMSTE
      Else
          [M:BOD1]BOMSEQ(nolign-1) = GBOMSTE
      Endif
    Endif
    nolign=NOBOMD
    Gosub VALDEFMSKBOMD
    nolign=NOBOMD
    For NOPIV=1 To NBPIVZON
        If pat(WPIVTABZON(NOPIV),"BOMD/*") & find(WPIVZON(NOPIV),"BOMSEQ","CPNITMREF")=0
            nolign=NOBOMD
            If evalue("dim([M:BOS2]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
               Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:BOS2]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
            Endif
        Endif
    Next
    If !OK : Goto FIN_BOM_VERROU : Endif
    nolign=NOBOMD
#    Call APRES_NBLIG From SUBBOD # Issue 93939 GA 10/2013
    Call APRES_NBLIG From SUBBODB

    If [M:BOS2]LIKQTY(NOBOMD-1)<0
        [M:BOS2]CPNTYP(NOBOMD-1)=7
        [M:BOS2]LIKQTY(NOBOMD-1)=abs([M:BOS2]LIKQTY(NOBOMD-1))
    Endif
    Raz mkstat
    # Issue 93939 GA 10/2013
    #Call C_CPNITMREF([M:BOS2]CPNITMREF(NOBOMD-1)) From SUBBOD
    Call AM_CPNITMREF([M:BOS2]CPNITMREF(NOBOMD-1)) From SUBBODB
    If dim([M:BOS2]BOMUOM)>0    # UML actif
        If [M:BOS2]BOMUOM(NOBOMD-1)="" : [M:BOS2]BOMUOM(NOBOMD-1)=[M:BOS2]STU(NOBOMD-1) : Endif
        Call BOMCOE([M:BOS2]BOMUOM(NOBOMD-1),[M:BOS2]STU(NOBOMD-1),[M:BOS2]CPNITMREF(NOBOMD-1),"BOS2") From UOMLIB
    Endif
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_BOM_VERROU : Endif

  #  If dim([M:BOS2]BOMUOM)>0    # UML actif
  #      If [M:BOS2]BOMQTY(NOBOMD-1)<>0
  #      Call LIKQTY([M:BOS2]BOMQTY(NOBOMD-1),[M:BOS2]BOMSTUCOE(nolign-1),[M:BOS2]STU(nolign-1),"BOS2")  From UOMLIB
  #      Endif
  #  Endif
  # Issue 93939 GA 10/2013 déjà fait dans AM_CPNITMREF
  #  If [M:BOS2]LIKQTY(NOBOMD-1)<>0
  #  Call AM_LIKQTY([M:BOS2]LIKQTY(NOBOMD-1)) From SUBBOD
  ##  Call BOMQTY([M:BOS2]LIKQTY(NOBOMD-1),[M:BOS2]WBOMSTUCOE(nolign-1),"BOS2") From UOMLIB
  #  Endif
  #  If mkstat
  #      GREP = "" : REP="" : OK=0
  #      Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
  #  Endif
  #  If !OK : Goto FIN_BOM_VERROU : Endif

  Elsif WCPNTYP = "1" #matiere

    Local Char WMSK
    WMSK = "BOD1"  #MSK MATIERE
    #on affecte les valeurs du mask
    [M:BOD1]NBLIG+=1
    NOBOMD=[M:BOD1]NBLIG
    nolign=NOBOMD
    [M:BOD1]CPNITMREF(nolign-1)=[F:ITM]ITMREF
    If func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL)<>""
      [M:BOD1]BOMSEQ(nolign-1) = val(func CONNECTFCT.GETVAL("BOMD","BOMSEQ",NBPIVZON,WPIVTABZON,WPIVVAL))
    Else
      If nolign > 1
          [M:BOD1]BOMSEQ(nolign-1) = [M:BOD1]BOMSEQ(nolign-2) + GBOMSTE
      Else
          [M:BOD1]BOMSEQ(nolign-1) = GBOMSTE
      Endif
    Endif
    nolign=NOBOMD
    Gosub VALDEFMSKBOMD
    nolign=NOBOMD
    For NOPIV=1 To NBPIVZON
        If pat(WPIVTABZON(NOPIV),"BOMD/*") & find(WPIVZON(NOPIV),"BOMSEQ","CPNITMREF")=0
            nolign=NOBOMD
            If evalue("dim([M:BOD1]"+WPIVZON(NOPIV)+")")>0 & WPIVVALFIC(NOPIV)<>""
               Call ASSIGNVAL(CONPIT,WPIVTABZON(NOPIV),"[M:BOD1]"+WPIVZON(NOPIV)+"(nolign-1)",WPIVVAL(NOPIV),OK) From CONNECTFCT
            Endif
        Endif
    Next
    If !OK : Goto FIN_BOM_VERROU : Endif
    nolign=NOBOMD
    Call APRES_NBLIG From SUBBOD

    If [M:BOD1]LIKQTY(NOBOMD-1)<0
        [M:BOD1]CPNTYP(NOBOMD-1)=7
        [M:BOD1]LIKQTY(NOBOMD-1)=abs([M:BOD1]LIKQTY(NOBOMD-1))
    Endif
    Raz mkstat
    Call C_CPNITMREF([M:BOD1]CPNITMREF(NOBOMD-1)) From SUBBOD
    If dim([M:BOD1]BOMUOM)>0    # UML actif
        If [M:BOD1]BOMUOM(NOBOMD-1)="" : [M:BOD1]BOMUOM(NOBOMD-1)=[M:BOD1]STU(NOBOMD-1) : Endif
        Call BOMCOE([M:BOD1]BOMUOM(NOBOMD-1),[M:BOD1]STU(NOBOMD-1),[M:BOD1]CPNITMREF(NOBOMD-1),"BOD1") From UOMLIB
    Endif
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_BOM_VERROU : Endif

    If dim([M:BOD1]BOMUOM)>0    # UML actif
        If [M:BOD1]BOMQTY(NOBOMD-1)<>0
        Call LIKQTY([M:BOD1]BOMQTY(NOBOMD-1),[M:BOD1]BOMSTUCOE(nolign-1),[M:BOD1]STU(nolign-1),"BOD1")  From UOMLIB
        Endif
    Endif
    If [M:BOD1]LIKQTY(NOBOMD-1)<>0
    Call AM_LIKQTY([M:BOD1]LIKQTY(NOBOMD-1)) From SUBBOD
    Call BOMQTY([M:BOD1]LIKQTY(NOBOMD-1),[M:BOD1]WBOMSTUCOE(nolign-1),"BOD1") From UOMLIB
    Endif
    If mkstat
        GREP = "" : REP="" : OK=0
        Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG)-GCLEPLM-GMESSAGE,1) From GESECRAN : # erreur
    Endif
    If !OK : Goto FIN_BOM_VERROU : Endif
  Endif
Endif

