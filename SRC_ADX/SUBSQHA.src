####################################################################
$ABANDON
#------------------------------------#
# Abandon création par l'utilisateur #
#------------------------------------#
Local Integer I, WRET

# TS - Nouvelle gestion de texte
#-------------------------------
If GREP = "D"
   If left$([M:SQH0]SQHTEX1,3)="SQH"
      Call SUP_CLOB([M:SQH0]SQHTEX1,WRET) From TRTX3TEX
   Endif
   If left$([M:SQH0]SQHTEX2,3)="SQH"
      Call SUP_CLOB([M:SQH0]SQHTEX2,WRET) From TRTX3TEX
   Endif
   For I=0 To [M]NBLIG-1
      If left$([M:SQH2]SQDTEX(I),3)="SQD"
         Call SUP_CLOB([M:SQH2]SQDTEX(I),WRET) From TRTX3TEX
      Endif
   Next I
Endif

Call RAZ_CLOB From ACLOB

Gosub PJM_OPPOR_PSO_FREEGROUP From SUBSOHA1      # Issue X3-8085/121537 - 2017-02-15 by FGR

