$CHARGESQD
Local Integer WRET

If dim([F:SQD]CPY)>0 : [F:SQD]CPY=GSOCIETE : Endif

[F:SQD]BPAADD    =  [M:SQH2]DBPAADD(NOL)
[F:SQD]DAYLTI    =  [M:SQH2]DDAYLTI(NOL)
[F:SQD]STOFCY    =  [M:SQH2]DSTOFCY(NOL)
[F:SQD]VACITM(0) =  [M:SQH2]VACITM1(NOL)
[F:SQD]VACITM(1) =  [M:SQH2]VACITM2(NOL)
[F:SQD]VACITM(2) =  [M:SQH2]VACITM3(NOL)
[F:SQD]VAT(0)    =  [M:SQH2]VAT1(NOL)
[F:SQD]VAT(1)    =  [M:SQH2]VAT2(NOL)
[F:SQD]VAT(2)    =  [M:SQH2]VAT3(NOL)
[F:SQD]PJT       =  [M:SQH2]DPJT(NOL)   : # 71065 : PJT
If dim([M:SQH2]SSTCOD(NOL))>0 : [F:SQD]SSTCOD=[M:SQH2]SSTCOD(NOL) : Endif  # 101380.n

# TS - Nouvelle gestion de texte
#-------------------------------
If [M:SQH2]SQDTEX(NOL)<>""
   If left$([M:SQH2]SQDTEX(NOL),3)="SQD"
      Call CRE_CLOB([M:SQH2]SQDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Elsif !find(left$([M:SQH2]SQDTEX(NOL),3),"ITU","ITS")
      Call DUP_CLOB("SQD",[M:SQH2]SQDTEX(NOL),GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:SQD]SQDTEX = [M:SQH2]SQDTEX(NOL)
Endif

# Issue 117128.s - 2016-09-28 by CATUA : Move WS calls outside database transactions (Comment out - Quote Creation Line)
#If func AFNC.ACTIV("LTA") and [F:CPY]SSTTAXACT = 2
#  #Check from address, if different
#  If [F:SQD]STOFCY <> [F:SQH]STOFCY
#    Call CHECK_FRADR([F:SQD]STOFCY,1,WRET) From TRTADRLIB
#  Endif
#  # Check delivery address, if different
#  If [F:SQD]BPAADD <> "" and [F:SQD]BPAADD <> [F:SQH]BPAADD
#      Call CHECK_LIN_TOADR(1, [F:SQH]BPCORD, [F:SQD]BPAADD) From TRTADRLIB
#  Endif
#Endif
# Issue 117128.e

# --- Stockage a la ligne des elt de facturation
Call UPD_DSPLIN("SQD",NOL) From TRTVENFACC

Return

