#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# SUBSQHA : GESTION DES DEVIS                         EB - MARS     1998#
#########################################################################
# Contient les traitements des actions appelés par l'objet SUBSQH       #
# Etiquettes                                                            #
#########################################################################
#########################################################################
$AV_IMPRIME
#---------------------------------------------------------------#
# avant impression alimentation du no doc de la transaction     #
#---------------------------------------------------------------#
If [M:SQH0]DOCNAM<>""
   [L]AREPORT=[M:SQH0]DOCNAM
Elsif WSLTDOCNAM<>""
   [L]AREPORT=WSLTDOCNAM
Endif

Return
#########################################################################
$AP_IMPRIME
#---------------------------------------------------------------#
# apres impression repositionnement sur le bon enregistrement   #
#---------------------------------------------------------------#
Gosub RELIT From GOBJSUB
#MAE, le 23/01/08, bg 45433
Raz [L]AREPORT
Return
#########################################################################
$DEFTRANS

If GFONC1 <> "GESSQH" Raz GFLAG Endif

# GRNA 18/05/2011
Local Char CUSSEAPAR : CUSSEAPAR = "TRSCSQUO"
Gosub DEFTRANS From CUSSEALIB

Return
#########################################################################
$VARIANTE

# La transaction lu est elle utilisable ?
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=1;[F:AWI]TRN
If fstat
   OK = 0
Elsif [F:SLT]ENAFLG<>2
   OK = 0
Endif
Return
#########################################################################
$SETTRANS

Gosub SETTRANS_DEF
If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
Read [SLT]SLT0=1;GFLAG
If clalev ([F:DTR])=0 Local File DIETRS [DTR] Endif
Read [DTR]DTR0="SLT";1;GFLAG;0;0

WSLTDOCFLG = [F:SLT]DOCFLG
WSLTDOCNAM = [F:SLT]DOCNAM
WSLTSTRNUM = [F:SLT]STRNUM

If  func AFNC.ACTIV("LTA") : GSSTENTCOD  = [F:SLT]SSTENTCOD  : Endif  #LTA.n

#MAE, le 29/01/08, GRP_SITE
GGRPFCY = [F:SLT]GFY

Close Local File [SLT], [DTR]
Return

#------------------------------------------------------------------------
# afin d'être appelé dans ouvre pour ne pas planter en import
$SETTRANS_DEF
If dim(WSLTDOCFLG)<=0  : Local Shortint WSLTDOCFLG           : Endif
If dim(WSLTSNSFLG)<=0  : Local Shortint WSLTSNSFLG           : Endif
If dim(WSLTDOCNAM)<=0  : Local Char     WSLTDOCNAM (GLONARP) : Endif
If dim(WSLTSNSNAM)<=0  : Local Char     WSLTSNSNAM (GLONARP) : Endif
If dim(WSLTSTRNUM)<=0  : Local Char     WSLTSTRNUM (GLONTRS) : Endif
If dim(GSSTENTCOD)<=0  : Global Integer GSSTENTCOD           : Endif  #LTA.n
Return


#########################################################################
$OUVRE

#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

If GIMPORT Gosub SETTRANS_DEF Endif

Global Char     GNUM(GLONVCR)  : # N° DE DEVIS
Global Shortint GREVQ          : # 0 = the question was not asked
                                 # 1 = No / 2 = Yes
Global Char     GTARFLG(1)     : # Flag recalcul des tarifs
Global Shortint GINVTYP        : # 1 = facture / 2 = avoir / 5 = proforma
Global Integer  GDACLOK        : # Flag ctrl qté, prix, marge, montant mini
Global Integer  GPRIMOD        : # Flag modif des prix/remises

#Local  Integer  WNBGAUCHE      : WNBGAUCHE = GNBGAUCHE
Local Char CODE (3)
Local Integer RETOUR

#Gosub OPEN_CPYVIEW From TRTX3CPY

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif
If !clalev([F:VQD]): Local File VSQUOTED   [VQD]: Endif
If !clalev([F:GCM])  Local File GACM       [GCM] Endif

GVENCFG=1

GREVQ = 0

If !clalev([F:ACV])  Local File ACTIV      [ACV]   Endif
#Global Integer GACTMUL : GACTMUL=1    : # Globale multisociété : 1(non) / 2(oui)
#Read [ACV] CODACT="MUL" : If fstat  Raz [F:ACV] : Endif
#If [F:ACV]FLACT=2 GACTMUL=2 Endif

Local Char WPARAM(10)
#--------------------------------------------------------------#
# Chargement param.utilisateur ctrl qte,prix,marge,montant mini#
#--------------------------------------------------------------#
Call PARAMUTIL("SDACLOK",WPARAM,"","") From SUBAUS
GDACLOK=val(WPARAM)
If GDACLOK=0 GDACLOK=1 Endif
#------------------------------------------------------------#
# Chargement param.utilisateur modif des prix/remises        #
#------------------------------------------------------------#
Call PARAMUTIL("SPRIMOD",WPARAM,"","") From SUBAUS
GPRIMOD=val(WPARAM)
If GPRIMOD=0 GPRIMOD=1 Endif

###############################################################
# Ouverture de la table affaire si module Action Co Actif   Modif CRM 22/10/2003
###############################################################
If GMODU(13) = 2
    If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
    Global Char GSZSQHFROMOPPRAZCRE(GLONPJT)  # FGR 14/02/2012 X3SUIVI79621 : avec une longueur c'est mieux
Endif
#------------------------------------------------------------#
#              Chargements liés aux tarifs                   #
#------------------------------------------------------------#
# Contrôle existence de la structure tarif par défaut        #
# Chargement des variables globales pour la recherche tarif  #
# Récupération de la structure des frais/remises             #
# Récupération des types de frais/remises                    #
#              des no éléments facturation                   #
#------------------------------------------------------------#
GORITITCOL=1
#If GACTMUL=2
GPLISTC="néant" :# Pour forcer l'affichage des entêtes de colonne si structure=""
#Endif
Call CTLSTRUCT (1,RETOUR) From TRTPRICE
If RETOUR <>0: OK=0: Return :Endif
Call TARIFCHGT(5)         From TRTPRICE
Call COLREM("C",1,"")     From TRTPRICE
Call TYPREM(1,"")  From TRTPRICE
#------------------------------------------------------------#

Global Char     GFOCITMREF(GLONITM)
Global Decimal  GFOCQTY
Global Char     GFOCUOM, GPNTITMREF(GLONITM)
Global Shortint GFOCMOTIF
Global Shortint GFOCFLG

Raz GSOC_ACTIVE
GFCY = GFCYDEF (5)
# Ctrl site par défaut par rapport au critère, si aucun site par défaut, charge le 1er site correspondant au critere
Call GETFCYDEF(GFCY,"[F:FCY]SALFLG=2") From TRTX3
# Chargement globales référenciels, comptes et sections de la société
Gosub CHARG_PARAM : If GERR=1 OK=0 : Return Endif
# --- Déclaration classe ecran pour le configurateur ---------------------------
Call LECACT("CFG",RETOUR) From TRTX3
If RETOUR = 1 Local Mask CFGWRK [CFW] Endif

# --- Déclaration des fenetres d'adresses --------------------------------------
If clalev([M:ADB_])=0 : Local Mask ADRBPC [M:ADB_] : Endif :# CPO 68724 - Zones adresse en bureautique
# Bug 70949
#If clalev([M:ADB1])=0 Local Mask ADRBPC [ADB1] Endif
#If clalev([M:ADB2])=0 Local Mask ADRBPC [ADB2] Endif
If clalev([M:ADB1])=0
    Local Mask ADRBPC [ADB1]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBY])
    Local Mask ADRBPC [ADBY] : [M:ADBY]=[M:ADB1] : # Sauvegarde de l'écran d'adresse ADB1 à cause de la navigation
  Endif
Endif
If clalev([M:ADB2])=0
    Local Mask ADRBPC [ADB2]                     : # Déclaration de l'écran d'adresse ADB1
Else
  If !clalev([M:ADBZ])
    Local Mask ADRBPC [ADBZ] : [M:ADBZ]=[M:ADB2] : # Sauvegarde de l'adresse ADB2 à cause de la navigation
  Endif
Endif
# Bug 70949

Local Char SFIT_OBJ : SFIT_OBJ="SQH"
Gosub INIT_SFIT From SUBSFIT

# FGR 28/07/2015 : X3SUIVI108078 : Optimisation (début)
  Link [SQD] With [ITM]ITM0=[F:SQD]ITMREF,
&                 [ITS]ITS0=[F:SQD]ITMREF
&              As [LSQD]
# FGR 28/07/2015 : X3SUIVI108078 : Optimisation

Gosub DECLARE From TABLEAUX

# --- Ouverture + reservations pour repartition elts facturation a la ligne ----
Gosub OUV_DSPLIN From TRTVENFACC

# Detail local tax data
Gosub OUVRE_LTA From TRTTAXSST   # 106867.n
# Gosub OUVRE_LTA From TRTTAXUSA   # 106867.o

Return


###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$STATUT

#fq6051-gbn
GCONSULT=SAV_GCONSULT
GCONSDIA=SAV_GCONSDIA

Case BOUT
    When "E"     : If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]SQHTEX1 <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif
    When "F"     : If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]SQHTEX2 <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif
    When "H"     : If [M:ADB1]ADBFLG = 2 | [M]CNTNAM <> [M:ADB1]CNTNAM : # Adresse client
                       # Dde 77155 : Dégriser le bouton enregistrer si utilisation système de taxes américaines
                       #If GREP <> "C" & GREP <> "M" & GREP <> "D"
                       # If GLOCUSATAX   # 106867.o
                       If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
                           Gosub ENTRE_MODIF From GOBJSUB
                       Elsif GREP <> "C" & GREP <> "M" & GREP <> "D"
                           Gosub MAJADRESSE From SUBSQHB
                       Endif
                       If [M:ADB1]BPRNAM(0) <> ""
                           [M:SQH0]BPCNAM = [M:ADB1]BPRNAM(0)
                           Affzo [M:SQH0]BPCNAM
                       Endif
                   Endif
    When "J"     : If [M:ADB2]ADBFLG = 2 | [M]CNTNAM <> [M:ADB2]CNTNAM : # Adresse client livré
                       # Dde 77155 : Dégriser le bouton enregistrer si utilisation système de taxes américaines
                       #If GREP <> "C" & GREP <> "M" & GREP <> "D"
                       # 79705 : V7 : SAT in SPRICLINK
                       # Dégriser le bouton enregistrer si la recherche tarif a été executée
                       #If GLOCUSATAX
                       # If GLOCUSATAX | (!find(GREP,"C","M","D") & sum([M]UPDFLG)<>0)   # 106867.o
                       If (func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2) | (!find(GREP,"C","M","D") & sum([M]UPDFLG)<>0)   # 106867.n
                           Gosub ENTRE_MODIF From GOBJSUB
                       Elsif GREP <> "C" & GREP <> "M" & GREP <> "D"
                           Gosub MAJADRESSE From SUBSQHB
                       Endif
                       If [M:ADB2]BPRNAM(0) <> ""
                           [M:SQH1]BPDNAM = [M:ADB2]BPRNAM(0)
                           Affzo [M:SQH1]BPDNAM
                       Endif
                   Endif
                   Gosub SHOW_HIDE_ENTCOD  From TRTADRLIB #LTA.n

    When "M"     : If mkstat=4 & GREP=""                               : # Informations CEE
#                      GREP="M" : REP="M" : # Pour forcer le bouton 'enregistrer'
                      Gosub ENTRE_MODIF From GOBJSUB
                   Endif
Endcase
Return

# 79705 : V7 : SAT in SPRICLINK
#######################################################################
# Après exécution d'une action et avant l'exécution de l'action suite #
#######################################################################
$AVANT_SUITE
Case BOUT
  When "H","J" :  # After execution Adresse and before execution recalculate prices
    # Not trigger recalculate prices if globale not informed
    If (dim(GADDACTMOD)<0 | GADDACTMOD<>"1") OK=0 Endif
Endcase
Return
# 79705 : V7 : SAT in SPRICLINK

