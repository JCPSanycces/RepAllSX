$AFFICHE_BCK_TIERS
  # FGR 12/03/2014 : X3SUIVI69847
  If [F:BPC]BPCTYP = 4 Then
    Chgtzn [M:SQH0]BPCORD With mess(240,196,1)
  Else
    Chgtzn [M:SQH0]BPCORD With mess(1,277,1)
  Endif
Return

# Issue 117128.s - 2016-10-05 by CATUA : Move WS calls outside database transactions (Quote Creation Header)
####################################################################
$UPDATE_ADRVAL
  Local Char    SQHNUM(20) : SQHNUM = [F:SQH]SQHNUM
  If clalev([F:SQH5])=0 : Local File SQUOTE [SQH5] : Endif
  Local Integer SSTTRBEGIN   #Issue 122614 - JOBRO
  SSTTRBEGIN=0               #Issue 122614 - JOBRO
  If !adxlog                 #Issue 122614 - JOBRO
    SSTTRBEGIN=1
    Trbegin [SQH5]
  Endif

  Update [SQH5] Where SQHNUM = [L]SQHNUM With ADRVAL = 2

  If SSTTRBEGIN=1  #Issue 122614 - JOBRO
    If fstat
      Rollback
    Else
      Commit
    Endif
  Endif   #Issue 122614 - JOBRO
  Close Local File [SQH5]
Return
# Issue 117128.e

#########################################################################
# 101380 - Setup SST Override related fields
#########################################################################
Subprog SETUP_SSTFIELDS

# If GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Grizo [M:SQH2]VACITM1,VACITM2,VACITM3
  If dim([M:SQH2]SSTCOD)>0 :
    Chgfmt [M:SQH2]SSTCOD     With "K:"   + num$(type([M:SQH2]SSTCOD)-10)     + "B"     # Show enterable
    Chgfmt [M:SQH3]SFISSTCOD  With "K:"   + num$(type([M:SQH3]SFISSTCOD)-10)  + "B"     # Show enterable
    Actzo [M:SQH2]SSTCOD
  Endif
Else
  Actzo [M:SQH2]VACITM1,VACITM2,VACITM3
  If dim([M:SQH2]SSTCOD)>0
    Chgfmt [M:SQH2]SSTCOD     With "-K:"  + num$(type([M:SQH2]SSTCOD)-10)     + "B"     # Hide
    Chgfmt [M:SQH3]SFISSTCOD  With "-K:"  + num$(type([M:SQH3]SFISSTCOD)-10)  + "B"     # Hide
  Endif
Endif

End
####################################################################
# Issue X3-44998 - 2017-07-27 by CPO : Duplicated sale documents: analytical dimension not controlled (idem X3SUIVI93839)
$VERIF_CTL_ALLCCE
Local Integer NE
Local Char SAXECTRL(GLONCCE)

  If dim([M:SQH3]CCE)>0
    # -------------------------------------
    For I = 0 To [M:SQH3]NBAXE-1
      If [M:SQH3]CCE(I) <> "" Then
        nolign = I + 1
        Call C_CCE([M:SQH3]CCE(I)) From W1SQH3
        If mkstat Then
          OK = 0
          Break
        Endif
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
  Endif

  For I=0 To [M:SQH2]NBLIG-1
    For NE = 1 To 20
      If evalue("type([M:SQH2]CCE" + num$(NE) + "(I)) >= 0") Then
        SAXECTRL = evalue("[M:SQH2]CCE" + num$(NE) + "(I)")
        If SAXECTRL <> "" Then
          nolign = I + 1
          #--for the ENAFLG flag
          Call CONTSEL("CCE","!",SAXECTRL,num$(GDIE(NE)),mkstat) From CONTOBJ
          If !mkstat
            Call CTRL_CCE(SAXECTRL, NE, "", GFINRSP, [M:SQH0]QUODAT) From TRTX3CPT
          Endif
          If mkstat Then
            OK = 0
            GMESSAGE = mess(162,154,1)-[M:SQH2]ITMREF(I)-":"-GMESSAGE
            Break
          Endif
        Endif
      Endif
    Next NE

    If OK = 0 Then
      Break

    Endif
  Next
  If OK = 0 Then
    Return
  Endif

Return
# End issue X3-44998

