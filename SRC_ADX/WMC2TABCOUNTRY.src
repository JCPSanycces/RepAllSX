####################################################################
# 31 : CRNFMTFLG Company tax ID no. form ( Field Local menu number 1)
####################################################################

$SET_CRNFMTFLG
If [L]_AOLDVAL<>this.CRNFMTFLG
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CRNFMTFLG
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CRNFMTFLG
 Gosub PROPAGATE_CRNFMTFLG
Endif
Return

$INIT_CRNFMTFLG
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRNFMTFLG"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.CRNFMTFLG=0 and fmet this.AGETATTRIBUTE("CRNFMTFLG","$isMandatory")="true"
 this.CRNFMTFLG = 1
Endif
Return
 
$CONTROL_CRNFMTFLG
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRNFMTFLG"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CRNFMTFLG             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CRNFMTFLG             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CRNFMTFLG
[L]CURPRO = "CRNFMTFLG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.CRNFMTFLG=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CRNFMTFLG
[L]CURPRO = "CRNFMTFLG"
If this.CRNFMTFLG<0 or this.CRNFMTFLG>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.CRNFMTFLG)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_CRNFMTFLG
[L]CURPRO = "CRNFMTFLG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CRNFMTFLG
[L]CURPRO = "CRNFMTFLG"
Return

$PROPAGATE_CRNFMTFLG
this.isReadonly = 0
[L]CURPRO = "CRNFMTFLG"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CRNFMTFLG
Gosub DECLARE_VAR From WMC0TABCOUNTRY
[L]CURPRO = "CRNFMTFLG"
$_LNKPRO_CRNFMTFLG
Return


