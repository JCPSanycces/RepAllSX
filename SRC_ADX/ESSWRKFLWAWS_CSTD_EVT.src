#<AdxTL>@(#)0.0.0.0 $Revision$ 


# Class ESSWRKFLWAWS


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
    Endcase
Endcase
Return


$AREAD_AFTER
Local Integer L


#Set the current legislation for the record
this.TCH_LEG = func DIVPAYE_SOA.GET_LEG_EMP(this.REFNUM, 1) #Site level

#Set technical properties
Local File EMPLOID [ID4]
Read [ID4]ID0 = this.REFNUM
If fstat = [V]CST_AOK
  this.TCH_NAM = [F:ID4]NAM
  this.TCH_SRN = [F:ID4]SRN
  #Title
  If func DIVPAYE.IS_KZA(this.TCH_LEG)>0
    Local File ESSWRKEMP [EWID2]
    Read [EWID2]EWID0 = this.UID
    If fstat = [V]CST_AOK
      this.ESSWRKEMP.TCH_CIVKZA = [F:EWID2]CIV
    Endif
  Endif
Endif

#Populate persons to contact
Local File ESSWRKEMP [EWID1]
Read [EWID1]EWID0 = this.UID
If fstat = [V]CST_AOK
  #Transfer the data to collection
  L = fmet this.ADDLINE("ESSEMPPERCNT",1)
  SetInstance this.ESSEMPPERCNT(L) With [F:EWID1]
Endif

#Populate passport details
If this.CODFIC = "EMPLOIDSPAS"
  Local File ESSWRKSA [EWSA1]
  Read [EWSA1]EWSA0 = this.UID
  If fstat = [V]CST_AOK
    #Transfer the data to collection
    L = fmet this.ADDLINE("ESSPASDET",1)
    SetInstance this.ESSPASDET(L) With [F:EWSA1]
  Endif
Endif

Return


