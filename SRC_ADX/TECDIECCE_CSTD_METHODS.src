#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Class TECDIECCE
# Issue X3-81871 - 2018-03-08 by FGR
###############################################################################
$GET_DEFAULT_VALUES
#Variable Instance INSCALL Using OBJECT : #
#Value Char SCDECOD ()
#Value Char SCDECPY ()
#Value Char SCDIE ()
#Value Char SDIE ()
#Value Char SCCE ()
#Value Char SGACCOA ()
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  ILINE = fmet this.ADDLINE("TEC", [V]CST_ALASTPOS)
  # ------------------------
  this.CALLER = INSCALL                                                               # Instance on CALLER class
  this.TEC.CDECOD = SCDECOD
  this.TEC.CDECPY = SCDECPY                                                           # Current company
  this.TEC.CDECPYLEG = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.TEC.CDECPY,"LEG")  # Company's Legislation
  this.TEC.CALCDIE = SCDIE                                                            # Collection name in CALLER class
  this.TEC.CALDIE = SDIE                                                              # DIE property name in CALLER class
  this.TEC.CALCCE = SCCE                                                              # CCE property name in CALLER class
  this.TEC.GACCOA = SGACCOA                                                           # Current Chart code of the caller
  # ------------------------
  this.TEC.OPTCANA = func ASYRFNC.ACTIV("ANA")                                        # Number of analytical dimensions
  # ------------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CLEAR_ALL_CDIE())
  If [L]ARET_VALUE < [V]CST_AERROR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.DIE_LOAD_INPUT_VALUES(this))  # RETRO-CALL
    If [L]ARET_VALUE < [V]CST_AERROR Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._CONTROL_INPUT_VALUES())
      If [L]ARET_VALUE < [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._LOAD_DEFAULT_CCE())
        If [L]ARET_VALUE < [V]CST_AERROR Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._LOAD_CALLER_CCE_VALUES())
        Endif
      Endif
    Endif
  Endif
Return

###############################################################################
$SET_IDENTIFIER
#Value Shortint ILINE
#Value Char SVALUE ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  this.INPUT(ILINE).INPLM693 = SVALUE
Return

###############################################################################
$_CONTROL_INPUT_VALUES
#Local Integer ARET_VALUE

Local Char SCOLLECTION(250)
Local Char SPROPERTY(250)

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If this.CALLER = null Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.ASETERROR("TECDIECCE", func AFNC.MES1(mess(5,2001,1), "INSCALL"), [V]CST_AERROR))
  Endif
  If this.TEC.CDECPY = AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(5,2001,1), "SCDECPY"), [V]CST_AERROR))
  Endif
  If this.TEC.CALCDIE = AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(5,2001,1), "SCDIE"), [V]CST_AERROR))
  Endif
  If this.TEC.CALDIE = AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(5,2001,1), "SDIE"), [V]CST_AERROR))
  Endif
  If this.TEC.CALCCE = AVOID.ACHAR Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(5,2001,1), "SCCE"), [V]CST_AERROR))
  Endif
  # ------------------------
  SCOLLECTION = "this.CALLER." + this.TEC.CALCDIE
  If evalue("dim(" + SCOLLECTION + ")") < 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(6,2001,1), "SCDIE"), [V]CST_AERROR))
  Else
    If evalue("MAXTAB(" + SCOLLECTION + ")") = 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", mess(7,2001,1), [V]CST_AERROR))
    Endif
    SPROPERTY = SCOLLECTION + "(1)." + this.TEC.CALDIE
    If evalue("dim(" + SCOLLECTION + ")") < 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(6,2001,1), "SDIE"), [V]CST_AERROR))
    Endif
    SPROPERTY = SCOLLECTION + "(1)." + this.TEC.CALCCE
    If evalue("dim(" + SCOLLECTION + ")") < 0 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(6,2001,1), "SCCE"), [V]CST_AERROR))
    Endif
  Endif
  # ------------------------
Return

###############################################################################
$ADD_CDIE_DIE
#Value Char SDIE ()
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If fmet this.CHECK_CDIE_DIE_EXIST(SDIE) = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(2,2001,1), SDIE), [V]CST_AERROR))
  Else
    ILINE = fmet this.ADDLINE("CDIE", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      this.CDIE(ILINE).DIE = SDIE
    Else
      [L]ARET_VALUE = max([L]ARET_VALUE, [V]CST_AERROR)
    Endif
  Endif
Return

###############################################################################
$CHECK_CDIE_DIE_EXIST
#Value Char SDIE ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------
  If SDIE <> AVOID.ACHAR Then
    NI = find(SDIE, this.CDIE(1..maxtab(this.CDIE)).DIE)
    While NI > 0
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = [V]CST_AYES
        Break
      Else
        NI1 = NI
        NI = find(SDIE, this.CDIE(NI+1..maxtab(this.BUD)).DIE)
        If NI > 0 Then
          NI += NI1
        Endif
      Endif
    Wend
  Endif
Return

###############################################################################
$CLEAR_ALL_CDIE
#Local Integer ARET_VALUE

Local Integer NI
Local Integer IRET
Local Char SFIELD(250)
Local Char SFIELD1(250)
Local Char SFIELD2(250)

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  For NI = 1 To maxtab(this.CDIE)
    If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      IRET = fmet this.ADELLINE("CDIE", this.CDIE(NI).AORDER)
      If IRET = [V]CST_ANOTDEFINED Then
        [L]ARET_VALUE = max([L]ARET_VALUE, [V]CST_AERROR)
        Break
      Endif
    Endif
  Next NI
  # ------------------------
  If this.TEC.CALCDIE = "CDIE" and this.TEC.CALDIE = "DIE" Then
    For NI = 1 To maxtab(this.CALLER.CDIE)
      If this.CALLER.CDIE(NI) <> null and find(this.CALLER.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.ADD_CDIE_DIE(this.CALLER.CDIE(NI).DIE))
      Endif
    Next NI
  Else
    SFIELD = "this.CALLER." + this.TEC.CALCDIE
    For NI = 1 To evalue("maxtab(" + SFIELD + ")")
      SFIELD1 = SFIELD + "(" + num$(NI) + ")"
      SFIELD2 = SFIELD1 + ".ASTALIN"
      If evalue(SFIELD1) <> null and find(evalue(SFIELD2),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        SFIELD2 = SFIELD1 + "." + this.TEC.CALDIE
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.ADD_CDIE_DIE(evalue(SFIELD2)))
      Endif
    Next NI
  Endif
  # ------------------------
  For NI = 1 To len(mess(0,693,1))
    If this.INPUT(NI) = null Then
      IRET = fmet this.ADDLINE("INPUT", [V]CST_ALASTPOS)
    Endif
    Raz this.INPUT(NI).INPLM693
  Next NI
  # ------------------------
Return

###############################################################################
$_LOAD_DEFAULT_CCE
#Local Integer ARET_VALUE

Local Integer NI
Local Char SCPY(GLONCPY)
Local Integer IFOUND

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Local File CACCEDEF [CDE]
  # ------------------------
  IFOUND = [V]CST_ANO
  For SCPY = this.TEC.CDECPY, AVOID.ACHAR
    Read [CDE]CDE0=this.TEC.CDECOD;SCPY
    If fstat = [V]CST_AOK Then
      this.TEC.CDECPYREA = [F:CDE]CPY
      IFOUND = [V]CST_AYES
      Break
    Endif
  Next
  If IFOUND = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(3,2001,1), this.TEC.CDECOD), [V]CST_AERROR))
  Else
    For NI = 1 To maxtab(this.CDIE)
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        this.TEC.DIECUR = this.CDIE(NI).DIE
        # ------------------------
        # Load real needed company use for CDE table
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._INIT_SECTION(NI, this.CDIE(NI).CCE))
      Endif
    Next NI
  Endif
Return

###############################################################################
$_INIT_SECTION
#Value Integer ILINE
#Variable Char SCCE ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer ITER693
Local Tinyint ICDECCEXY

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Local File CACCEDEF [CDE]
  # ------------------------
  Read [CDE]CDE0=this.TEC.CDECOD;this.TEC.CDECPYREA
  # ------------------------
  INDAXE = find(this.CDIE(ILINE).DIE, [F:CDE]DIE(0..dim([F:CDE]DIE)-1))
  ITER693 = len(mess(0,693,1))
  # ------------------------
  If INDAXE > 0 Then
    Raz SCCE     # Raz at this level because INIT_SECTION can be call in SPE before STD.
                 # At the beginning of STD(here) if SCCE is not empty, the STD method do nothing.
    For NI = 1 To [F:CDE]NBLIG
      ICDECCEXY = evalue("[F:CDE]CCE" + num$(INDAXE) + "(" + num$(NI-1) + ")")
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CDECCE_VALUE_ALLOWED([F:CDE]FLD(ICDECCEXY-1)))
      If [L]ARET_VALUE < [V]CST_AERROR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.INIT_SECTION(ILINE, SCCE, INDAXE, ITER693, ICDECCEXY))
        If [L]ARET_VALUE >= [V]CST_AERROR Then
          Break
        Else
          If SCCE <> AVOID.ACHAR Then
            Break
          Endif
        Endif
      Endif
    Next NI
  Endif
Return

###############################################################################
$INIT_SECTION
#Value Integer ILINE
#Variable Char SCCE ()
#Value Integer IINDAXE
#Value Integer IITER693
#Value Integer ICDECCEXY
#Local Integer ARET_VALUE

Local Integer XX
Local Integer XY
Local Integer INDAXE2
Local Integer OKINI
Local Integer ILOOP
Local Char SCOLLECTION(250)
Local Char SCOLLECTIONI(250)
Local Char SPROPERTY(250)
Local Char WAXE(GLONDIE)
Local Char WCCE(GLONCCE)
Local Char SITE(GLONFCY)
Local Char IDENT(250)
Local Char IDENT2(250)
Local Char ZONE(GLONAVA)
Local Char ABREV(GLONABR)
Local Char MODELE(GLONGCM)
Local Char PLAN(GLONCOA)(1..10)
Local Integer NBPLAN
Local Integer REFTYP(1..10)
Local Integer NPLAN
Local Char XIDENT2(250)
Local Char TABLE(GLONATB)

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  # Method can be called by specific to have another way to load default value.
  # Specific is going to be called before standard : in this cals SCCE is not emprty is receive a value from specific.
  If SCCE = AVOID.ACHAR Then
    # ------------------------
    Local File CACCEDEF [CDE]
    # ------------------------
    Read [CDE]CDE0=this.TEC.CDECOD;this.TEC.CDECPYREA
    # ------------------------
    If ICDECCEXY = 6 or ICDECCEXY = 20 Then
      # -----------------------------------------------------------------------
      # Pièce / document d'origine  => cas particulier
      Onerrgo ERREUR_INIT_SECTION
      If fmet this._EVALUABLE([F:CDE]FLD(ICDECCEXY-1)) = [V]CST_AYES Then
        If [F:CDE]FLD(ICDECCEXY-1) <> AVOID.ACHAR Then
          SCCE = evalue([F:CDE]FLD(ICDECCEXY-1))
        Endif
      Else
        # Waiting for a value formated 'CALLER.CDIE.CCE'
        If this.TEC.CALCDIE = "CDIE" and this.TEC.CALDIE = "DIE" Then
          Raz INDAXE2
          For XX = 1 To maxtab(this.CALLER.CDIE)
            If this.CALLER.CDIE(XX) <> null and find(this.CALLER.CDIE(XX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              If this.TEC.DIECUR = this.CALLER.CDIE(XX).DIE Then
                INDAXE2 = XX
                Break
              Endif
            Endif
          Next XX
        Else
          SCOLLECTION = "this.CALLER." + this.TEC.CALCDIE
          Raz INDAXE2
          For XX = 1 To evalue("maxtab(" + SCOLLECTION + ")")
            SCOLLECTIONI = SCOLLECTION + "(" + num$(XX) + ")"
            SPROPERTY = SCOLLECTIONI + ".ASTALIN"
            If evalue(SCOLLECTIONI) <> null and find(evalue(SPROPERTY),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
              SPROPERTY = SCOLLECTIONI + "." + this.TEC.CALDIE
              If this.TEC.DIECUR = evalue(SPROPERTY) Then
                INDAXE2 = XX
                Break
              Endif
            Endif
          Next XX
        Endif
        If INDAXE2 > 0 Then
          SCCE = evalue([F:CDE]FLD(ICDECCEXY-1)+"("+num$(INDAXE2-1)+")")
        Endif
      Endif
      Onerrgo
      # -----------------------------------------------------------------------
    Elsif ICDECCEXY = 21 Then
      # -----------------------------------------------------------------------
      # Sections précédentes => cas particulier
      # A la différence des "Pièces" ou "Document d'origne", l'utilitaire boucle sur le tableau jusqu'à trouver une valeur.
      # L’identifiant sera le nom du champ section et non sa valeur et pourra être saisi sous forme « CCE# ».
      # ------------------------
      If [F:CDE]FLD(ICDECCEXY-1) <> AVOID.ACHAR Then
        Local File CACCE [CCE]
        # ------------------------
        Onerrgo ERREUR_INIT_SECTION
        # Recherche des axes/sections précédentes
        For XX = 1 To maxtab(this.CDIE)
          If this.CDIE(XX) <> null and find(this.CDIE(XX).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            WAXE = this.CDIE(XX).DIE
            Raz WCCE
            If WAXE <> AVOID.ACHAR Then
              WCCE = this.CDIE(XX).CCE
            Endif
            If WCCE <> AVOID.ACHAR Then
              Read [F:CCE]CCE0=WAXE;WCCE
              If fstat = [V]CST_AOK Then
                Raz INDAXE2
                For XY = 1 To this.TEC.OPTCANA
                  If this.TEC.DIECUR = [F:CCE]OTHDIE(XY-1) Then
                    INDAXE2 = XY
                    Break
                  Endif
                Next
                If INDAXE2 > 0 Then
                  SCCE = [F:CCE]DEFCCE(INDAXE2-1)
                Endif
              Endif
            Endif
            If SCCE <> AVOID.ACHAR Then
              Break
            Endif
          Endif
        Next
        Onerrgo
      Endif
      # -----------------------------------------------------------------------
    Else
      # -----------------------------------------------------------------------
      Raz IDENT
      Raz IDENT2
      If ICDECCEXY > 0 and ICDECCEXY <> IITER693 and [F:CDE]FLD(ICDECCEXY-1) <> AVOID.ACHAR Then
        # IITER693=None
        Onerrgo ERREUR_INIT_SECTION
        IDENT = evalue([F:CDE]FLD(ICDECCEXY-1))
        Onerrgo
      Endif
      If IDENT = AVOID.ACHAR and ICDECCEXY = 7 Then
        # If company is empty and site not : get the company from the site
        Onerrgo ERREUR_INIT_SECTION
        SITE = evalue([F:CDE]FLD(ICDECCEXY))
        Onerrgo
        If SITE <> AVOID.ACHAR Then
          IDENT = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(SITE, "LEGCPY")
        Endif
      Endif
      If IDENT <> AVOID.ACHAR Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._GET_TABLE_ACCESS_INF(ICDECCEXY, ABREV, TABLE, ZONE, IDENT, IDENT2))
        If ABREV <> AVOID.ACHAR Then
          # ------------------------
          # Because of performances way, I choose to work like that to not have to read records twice
          Case ICDECCEXY
            When 18
              # MWC
              IDENT = evalue(IDENT)
              IDENT2 = evalue(IDENT2)
          Endcase
          # ------------------------
          # Without abreviation, table is open with the default one, which is on the table description
          Local File =TABLE
          # ------------------------
          If ABREV <> "GAC" Then
            Call LEC_CCE_ON_ABREV(this.ACTX, ABREV, IDENT, IDENT2) From CPTLEC_SYRA
            If fstat = [V]CST_AOK Then
              Gosub INIT_SECTION_EVALUE
            Endif
          Else
            OKINI = [V]CST_AFALSE
            If this.TEC.GACCOA <> AVOID.ACHAR Then
              IDENT2 = this.TEC.GACCOA
              If fmet this.ACTX.ACACHE.COA.AGETVALNUM(IDENT2, "ANATRK") = [V]CST_AYES Then
                Call LEC_GAC(this.ACTX, IDENT, IDENT2) From CPTLEC_SYRA
                If fstat = [V]CST_AOK Then
                  Gosub INIT_SECTION_EVALUE
                  OKINI = [V]CST_ATRUE
                Endif
              Endif
            Endif
            If OKINI = [V]CST_AFALSE Then
              XIDENT2 = IDENT2
              Call SETPLAN3(this.TEC.CDECPY, NBPLAN, PLAN, REFTYP) From CPTDIV_SYRA
              For NPLAN = 1 To NBPLAN
                If XIDENT2 <> PLAN(NPLAN) Then
                  If fmet this.ACTX.ACACHE.COA.AGETVALNUM(PLAN(NPLAN), "ANATRK") = [V]CST_AYES Then
                    Call LEC_GAC(this.ACTX, IDENT, PLAN(NPLAN)) From CPTLEC_SYRA
                    If fstat = [V]CST_AOK Then
                      IDENT2 = PLAN(NPLAN)
                      Call LEC_GAC(this.ACTX, IDENT, IDENT2) From CPTLEC_SYRA
                      If fstat = [V]CST_AOK Then
                        Gosub INIT_SECTION_EVALUE
                        Break
                      Endif
                    Endif
                  Endif
                Endif
              Next
            Endif
          Endif
        Endif
      Endif
      # -----------------------------------------------------------------------
    Endif
  Endif
Return

$ERREUR_INIT_SECTION
Resume

$INIT_SECTION_EVALUE
  Onerrgo ERREUR_INIT_SECTION
  For XX = 1 To this.TEC.OPTCANA
    If this.TEC.DIECUR = evalue("[F:" + ABREV + "]DIE(" + num$(XX-1) + ")") Then
      SCCE = evalue("[F:" + ABREV + "]" + ZONE + "(" + num$(XX-1) + ")")
      Break
    Endif
  Next
  Onerrgo
Return

###############################################################################
$EVALUABLE
#Value Char SSTRING ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_ANO
  # ------------------------
  If instr(1,SSTRING,"func") or
&    instr(1,SSTRING,"evalue") or
&    instr(1,SSTRING,"this")
&  Then
    [L]ARET_VALUE = [V]CST_AYES
  Endif
Return

###############################################################################
$CDECCE_VALUE_ALLOWED
#Value Char SSTRING ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If instr(1,SSTRING,":") or instr(1,SSTRING,"]") Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CALLER.ASETERROR("TECDIECCE", func AFNC.MES1(mess(4,2001,1), SSTRING), [V]CST_AERROR))
  Endif
Return

###############################################################################
$_GET_TABLE_ACCESS_INF
#Value Shortint INDEX
#Variable Char SABREV ()
#Variable Char STABLE ()
#Variable Char SZONE ()
#Variable Char IDENT1 ()
#Variable Char IDENT2 ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  Raz SABREV
  SZONE = "CCE"
  Raz IDENT2
  Case INDEX
    When 1
      SABREV = "ITM" : STABLE = "ITMMASTER"
    When 2
      SABREV = "BPC" : STABLE = "BPCUSTOMER"
    When 3
      SABREV = "BPS" : STABLE = "BPSUPPLIER"
    When 4
      SABREV = "REP" : STABLE = "SALESREP"
    When 5
      SABREV = "AUS" : STABLE = "AUTILIS"
    When 7
      SABREV = "CPY" : STABLE = "COMPANY"
    When 8
      SABREV = "FCY" : STABLE = "FACILITY"
    When 9
      SABREV = "TCU" : STABLE = "TABCUR"
    When 10
      SABREV = "TVT" : STABLE = "TABVAT"
    When 11
      SABREV = "SFI" : STABLE = "SFOOTINV"
    When 12
      SABREV = "TDA" : STABLE = "TABDEPAGIO"
    When 13
      SABREV = "BAN" : STABLE = "BANK"
    When 14
      SABREV = "GAC" : STABLE = "GACCOUNT"
      SZONE = "CCEDEF"
    When 15
      SABREV = "FAS" : STABLE = "FIXASSET"
    When 16
      SABREV = "PFI" : STABLE = "PFOOTINV"
    When 17
      SABREV = "BPR" : STABLE = "BPARTNER"
    When 18
      SABREV = "MWC" : STABLE = "WORKCOST"
      # zones de clé inversées
      IDENT  = "[F:CDE]FLD(7)"                   # Information not available at this level. Will be evaluated at the caller method level
      IDENT2 = "[F:CDE]FLD(ICDECCEXY-1)"         # Information not available at this level. Will be evaluated at the caller method level
    When 19
      SABREV = "ONA" : STABLE = "OVENAT"
    When 22
      SABREV = "AUS" : STABLE = "AUTILIS"
    When 23
      SABREV = "FCS" : STABLE = "FRECST"
    When 24
      SABREV = "OPPPJM" : STABLE = "OPPORPJM"
    When 25
      SABREV = "PJCC" : STABLE = "PJMCOSTCTR"
  Endcase
Return

###############################################################################
$_LOAD_CALLER_CCE_VALUES
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NE
Local Char SFIELD(250)
Local Char SFIELD1(250)
Local Char SFIELD2(250)

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------
  If this.TEC.CALCDIE = "CDIE" and this.TEC.CALDIE = "DIE" and this.TEC.CALCCE = "CCE" Then
    For NI = 1 To maxtab(this.CDIE)
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        For NE = 1 To maxtab(this.CALLER.CDIE)
          If this.CALLER.CDIE(NE) <> null and find(this.CALLER.CDIE(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.CDIE(NI).DIE = this.CALLER.CDIE(NE).DIE Then
              this.CALLER.CDIE(NE).CCE = this.CDIE(NI).CCE
              Break
            Endif
          Endif
        Next NE
      Endif
    Next NI
  Else
    SFIELD = "this.CALLER." + this.TEC.CALCDIE
    For NI = 1 To maxtab(this.CDIE)
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        For NE = 1 To evalue("maxtab(" + SFIELD + ")")
          SFIELD1 = SFIELD + "(" + num$(NE) + ")"
          SFIELD2 = SFIELD1 + ".ASTALIN"
          If evalue(SFIELD1) <> null and find(evalue(SFIELD2),[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            SFIELD2 = SFIELD1 + "." + this.TEC.CALDIE
            If this.CDIE(NI).DIE = evalue(SFIELD2) Then
              Assign "this.CALLER." + this.TEC.CALCDIE + "(" + num$(NE) + ")" + "." + this.TEC.CALCCE With this.CDIE(NI).CCE
              Break
            Endif
          Endif
        Next NE
      Endif
    Next NI
  Endif
Return

