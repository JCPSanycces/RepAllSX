#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIACH17      Utilitaire de resynchronisation des         Module ACHAT #
#               éléments de facturation après la                         #
#               modification du paramétrage en v6                        #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Un élément de facturation change de type (pourcentage ou montant)    #
#    * Il faut mettre à jour le nouveau type dans toutes les tables      #
#      qui l'utilisent :                                                 #
#        - BPSCATEG    Catégories fournisseur (à partir de la v5)        #
#        - BPSUPPLIER  Fournisseurs                                      #
#        - PVCRFOOT    Eléments entête documents achat                   #
#    * Il faut récupérer la valeur par défaut                            #
# ---------------------------------------------------------------------- #
#      [F:BSG]AMTCOD    = [F:PFI]AMTCOD                                  #
#      [F:BSG]INVDTAAMT = [F:PFI]DEFVAL                                  #
#                                                                        #
#      [F:BPS]AMTCOD    = [F:PFI]AMTCOD                                  #
#      [F:BPS]INVDTAAMT = [F:PFI]DEFVAL                                  #
##########################################################################


Call MAJ_UTIACH17
End


Subprog MAJ_UTIACH17
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH17 - Resynchro éléments facturation") From SAIDOS
If DOSSIER<>""
  #-----
  Local Integer OK
  Local Libelle WSIMFLG
  Call OUINON("Simulation ?",OK) From GESECRAN
  If OK=2  WSIMFLG=1 Else Raz WSIMFLG : Endif
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH17 : Utilitaire resynchro éléments de facturation achats") From LECFIC
  Call EXE_UTIACH17(DOSSIER,WSIMFLG)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH17(DOSSIER,WSIMFLG)
Value Char    DOSSIER
Value Libelle WSIMFLG
#----- Variables locales -----#
Local Shortint WTAB_PFINUM(500)
Local Libelle  WTAB_AMTCOD(500)
Local Decimal  WTAB_DEFVAL(500)
Local Shortint WTAB_NBR
#-----
Local Char     WMSG(90), WCRITERE(100)
Local Integer  NBENR, NBCOR, NBCOR2
Local Char     WBPSNUM(GLONBPS)
Local Char     WPOHNUM(GLONPOH)
Local Char     WCLE(max(GLONBPS,GLONPOH))
Local Integer WCOMPTEUR, WSTOP
Local Integer  WI, WJ, WSTA
Local Libelle  WFLAG
Local Libelle  WTRACE : WTRACE=2 : # WTRACE=2 --> Trace détaillée
#-----
Call ECR_TIME("UTIACH17 : Début traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:PFI])   Local File =DOSSIER+".PFOOTINV"    [PFI] : Endif
If !clalev([F:BPR])   Local File =DOSSIER+".BPARTNER"    [BPR] : Endif
If !clalev([F:BSG])   Local File =DOSSIER+".BPSCATEG"    [BSG] : Endif
If !clalev([F:BPS])   Local File =DOSSIER+".BPSUPPLIER"  [BPS] : Endif
If !clalev([F:PVF])   Local File =DOSSIER+".PVCRFOOT"    [PVF] : Endif
#----- Chargement en mémoire des éléments de facturation -----#
Raz WTAB_NBR
For [PFI] PFI0
  WTAB_PFINUM(WTAB_NBR)=[F:PFI]PFINUM
  WTAB_AMTCOD(WTAB_NBR)=[F:PFI]AMTCOD
  WTAB_DEFVAL(WTAB_NBR)=[F:PFI]DEFVAL
  WTAB_NBR+=1
  If WTAB_NBR>dim(WTAB_PFINUM)-1
    Call ECR_TRACE("WTAB_PFINUM"-mess(26,100,1),0) From GESECRAN : Break 
  Endif
Next
#----- Début du traitement -----#
Raz NBENR, NBCOR
Gosub TRT_BSG
Gosub TRT_BPS
Gosub TRT_PVF
#----- Fin du traitement -----#
$FIN_UTIACH17
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH17 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [PFI], [BPR], [BPS], [PVF]
If clalev([F:BSG])  Close Local File [BSG] : Endif
End


#---------------------------------------------------#
# Traitement de la table des catégories fournisseur #
#---------------------------------------------------#
$TRT_BSG
Local Char WBSGCOD(GLONBSG)
If WTRACE=2
  Call ECR_TRACE("----- BPSCATEG",0) From GESECRAN
Endif
Call DEBTRANS From GLOCK
$BOUCLE_BSG
Trbegin [BSG]
  For [BSG] BSG0
    WBSGCOD=[F:BSG]BSGCOD
    Raz WFLAG, NBCOR2
    For WI=0 To dim([F:BSG]INVDTA)-1
      WJ=find([F:BSG]INVDTA(WI),WTAB_PFINUM(0..WTAB_NBR-1))
      If WJ
        NBENR+=1
        If [F:BSG]AMTCOD(WI)<>WTAB_AMTCOD(WJ-1)
          If !WFLAG
            Readlock [BSG] BSG0=WBSGCOD
            #----- Erreur d'accès sur le ficher BPSCATEG -----#
            If fstat
              WMSG=mess(12,100,1)-"BPSCATEG"-WBSGCOD
              Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
              Break  
            Endif
            #-----
            WFLAG=1
          Endif
          NBCOR2+=1
          If WTRACE=2
            WMSG=WBSGCOD-num$(WTAB_PFINUM(WJ-1))-"AMTCOD :"-num$([F:BSG]AMTCOD(WI))-"-->"-num$(WTAB_AMTCOD(WJ-1))
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WMSG=WBSGCOD-num$(WTAB_PFINUM(WJ-1))-"INVDTAAMT :"-num$([F:BSG]INVDTAAMT(WI))-"-->"
          Endif
          [F:BSG]AMTCOD(WI)=WTAB_AMTCOD(WJ-1)
          If WTAB_AMTCOD(WJ-1)=1
            [F:BSG]INVDTAAMT(WI)=WTAB_DEFVAL(WJ-1)
          Else
            Call CONVERT(GSYSCUR,[F:BSG]CUR,[F:BSG]CUR,[F:BSG]CHGTYP,datesyst,
&                        WTAB_DEFVAL(WJ-1),[F:BSG]INVDTAAMT(WI),WSTA) From TRTDEV
          Endif
          If WTRACE=2
            WMSG-=num$([F:BSG]INVDTAAMT(WI))
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
        Endif
      Endif
    Next WI
    If WFLAG
      If !WSIMFLG
        Rewrite [BSG]
      Else
        Unlock  [BSG]
      Endif
      #----- Erreur d'écriture sur le fichier BPSCATEG -----#
      If fstat
        WMSG=mess(13,100,1)-"BPSCATEG"-WBSGCOD
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
      #-----
      Else
        NBCOR+=NBCOR2
      Endif
      #-----
    Endif
  Next
Commit
Return


#-----------------------------------------#
# Traitement de la table des fournisseurs #
#-----------------------------------------#
$TRT_BPS
If WTRACE=2
  Call ECR_TRACE("----- BPSUPPLIER",0) From GESECRAN
Endif
Call DEBTRANS From GLOCK
Raz WCLE, WSTOP
$BOUCLE_BPS
GOK=1
If WSTOP=1
  WSTOP=0 : WCRITERE ='BPSNUM>"'+WCLE+'"'
Else
  WCRITERE="1=1"
Endif
Raz WCOMPTEUR
Trbegin [BPS]
  For [BPS] BPS0 Where evalue(WCRITERE)
    Read [BPR] BPR0=[F:BPS]BPSNUM
    If fstat
      WMSG=mess(12,100,1)-"BPARTNER"-[F:BPS]BPSNUM
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
        Break  
    Endif
    WBPSNUM=[F:BPS]BPSNUM
    Raz WFLAG, NBCOR2
    For WI=0 To dim([F:BPS]INVDTA)-1
      WJ=find([F:BPS]INVDTA(WI),WTAB_PFINUM(0..WTAB_NBR-1))
      If WJ
        NBENR+=1
        If [F:BPS]AMTCOD(WI)<>WTAB_AMTCOD(WJ-1)
          If !WFLAG
            Readlock [BPS] BPS0=WBPSNUM
            #----- Erreur d'accès sur le ficher BPSUPPLIER -----#
            If fstat
              WMSG=mess(12,100,1)-"BPSUPPLIER"-WBPSNUM
              Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
              Break  
            Endif
            #-----
            WFLAG=1
          Endif
          NBCOR2+=1
          If WTRACE=2
            WMSG=WBPSNUM-num$(WTAB_PFINUM(WJ-1))-"AMTCOD :"-num$([F:BPS]AMTCOD(WI))-"-->"-num$(WTAB_AMTCOD(WJ-1))
            Call ECR_TRACE(WMSG,0) From GESECRAN
            WMSG=WBPSNUM-num$(WTAB_PFINUM(WJ-1))-"INVDTAAMT :"-num$([F:BPS]INVDTAAMT(WI))-"-->"
          Endif
          [F:BPS]AMTCOD   (WI)=WTAB_AMTCOD(WJ-1)
          If WTAB_AMTCOD(WJ-1)=1
            [F:BPS]INVDTAAMT(WI)=WTAB_DEFVAL(WJ-1)
          Else
            Call CONVERT(GSYSCUR,[F:BPR]CUR,[F:BPR]CUR,[F:BPS]CHGTYP,datesyst,
&                        WTAB_DEFVAL(WJ-1),[F:BPS]INVDTAAMT(WI),WSTA) From TRTDEV
          Endif
          If WTRACE=2
            WMSG-=num$([F:BPS]INVDTAAMT(WI))
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
        Endif
      Endif
    Next WI
    If WFLAG
      If !WSIMFLH
        Rewrite [BPS]
      Else
        Unlock  [BPS]
      Endif
      #----- Erreur d'écriture sur le fichier BPSUPPLIER -----#
      If fstat
        WMSG=mess(13,100,1)-"BPSUPPLIER"-WBPSNUM
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),0) From GESECRAN
      #-----
      Else
        NBCOR+=NBCOR2
      Endif
      #-----
    Endif
    #-----
    If WCOMPTEUR>GMAXUPDTRS
      WCLE=WBPSNUM : WSTOP=1 : Break
    Endif
  Next
Commit
If WSTOP  Goto BOUCLE_BPS : Endif
Return


#---------------------------------#
# Traitement de la table PVCRFOOT #
# ------------------------------- #
#  Ne rien faire pour l'instant ! #
#---------------------------------#
$TRT_PVF
Return
