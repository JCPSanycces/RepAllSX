#<AdxTL>@(#)3.0.0.0 $Revision$
Call VALPROFAPP("ZMBT",nomap)
End

Local Char PARAM(30)(1..2), VALEUR(30)
Call TRAITE_CHAR(VALEUR,PARAM,"","VALMENU","VALMENU",3,"XYVALMENU") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
Endcase
Return

$INIT
Local File ADOVAL [ADW] , APROFIL [APF]
TMP = 1
Return

$INIT_DIA
Read [ADW]ADW0 = "";"";"SUPDOS"
If [F:ADW]VALEUR<>nomap or GADONIX=2
 Read [ADW]ADW0 = "";"";"ADMUSR"
 [M:DIA]PROFIL = [F:ADW]VALEUR+"*"
Endif
Return

$EXEC
If instr(1,[M:DIA]PROFIL,"*") | instr(1,[M:DIA]PROFIL,"?")
 Call OUVRE_TRACE(mess(38,125,1)) From LECFIC
Endif
Call VALMENU([M:DIA]PROFIL,nomap)
If instr(1,[M:DIA]PROFIL,"*") | instr(1,[M:DIA]PROFIL,"?")
 Call FERME_TRACE From LECFIC
 TRA = 1
Endif
Return

##################################################################
## Validation des profils menus (fonction VALMENU)
##################################################################

Subprog VALMENU(MODELE,APPLI)
Value Char MODELE , APPLI
Local Char PROFIL(GLONAPM)
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = APPLI
Gosub DECLARE
For I=0 To [F:ADS]NBRLAN-1
 SRCMEN = filpath("M"+[F:ADS]LAN(I),"","",APPLI)
 If filinfo(SRCMEN,0)<0
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+SRCMEN+'"',"",STAT) From ORDSYS
 Endif
Next I
Read [ADW]ADW0 = "";"";"ADMUSR"
SUPERU = [F:ADW]VALEUR
If instr(1,MODELE,"*") | instr(1,MODELE,"?")
 For [APF2]CODPRF Where MODULE=0
  If pat([F:APF2]CODPRF,MODELE)
   Call ECR_TRACE(mess(38,125,1)-[F:APF2]CODPRF,0) From GESECRAN
   PROFIL = [F:APF2]CODPRF
   If PROFIL=SUPERU
    If APPLI<>GDOSX3 or GADONIX=2
     Call DEBTRANS From GLOCK
     Gosub TR1
     If GOK<1 : Break : Endif
     Call VALPROFAPP(PROFIL,APPLI)
    Endif
   Else
    Call VALPROFAPP(PROFIL,APPLI)
   Endif
  Endif
 Next AFP2
Else
 PROFIL = MODELE
 If PROFIL=SUPERU 
  If nomap<>GDOSX3 or GADONIX=2
   Call DEBTRANS From GLOCK
   Gosub TR1
   If GOK<1 : End : Endif
   Call VALPROFAPP(PROFIL,APPLI)
  Endif
 Else
  Call VALPROFAPP(PROFIL,APPLI)
 Endif
Endif
End

##########################################################
# Validation des profils menus
##########################################################

Subprog VALPROFAPP(PROFIL,APPLI) 
Value Char PROFIL 
Value Char APPLI 
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER = APPLI
If fstat
 Call ERREUR(APPLI-":"-mess(23,100,1)) From GESECRAN
 End
Endif
Gosub RECPROF
Gosub GENPROF
End

################################################
# Recherche de la hiérarchie
################################################

$RECPROF 
Gosub DECLARE
Read [APF]CODPRF = 0 ; PROFIL
Read [ADW]ADW0 = "";"";"ADMUSR"
SUPERU = [F:ADW]VALEUR

USRMEN = toupper(PROFIL)

Link [AMU]
& With [AFC]CODINT=[F:AMU]FONCTION
&    , [ACV]CODACT=[F:AFC]CODACT
& As   [LNK]
& Where [F:AMU]CODPRF=PROFIL
&     & [F:AMU]MENU>="A"
&     & ([F:AFC]CODACT="" | [F:ACV]FLACT=2)
&       Order By Key CLE = [F:AMU]CODPRF;[F:AMU]MENU;[F:AMU]NUMLIG

##  Passe préliminaire pour virer les menus à 1 seule fonction
Local Integer OK, NEWLIG, NEWLIB , INTERR , NBFONC , TRACE
Local Char    NEWMEN(GLONAFC)
Local Decimal NBMEN 

If !adxlog
 Trbegin [AMU]
 TRANS = 1
Endif
 
NBMEN = 0 
For [LNK]CLE(2)
 NBFONC = 0 
 For [LNK]CLE
  NBFONC += 1
 Next
 If NBFONC : NBMEN += 1 : Endif
 If NBFONC=1 & [F:AMU]FONCTION="MENU"
  Filter [AMU2] Where CODPRF=PROFIL & FONCTION="MENU" & CODMEN=[F:AMU]MENU
  Read [AMU2] First
  Filter [AMU2]
  If fstat=0
   NEWMEN = [F:AMU2]MENU
   NEWLIG = [F:AMU2]NUMLIG
   NEWLIB = [F:AMU2]LIBMENU
   Delete [AMU2]
   If fstat=1 | fstat>5
    GCLE = [F:AMU2]CODPRF-[F:AMU2]MENU-num$([F:AMU2]NUMLIG)
    Call RSTA("AMU2",GCLE) From GLOCK
   Endif
   Read [AMU2]CODMEN = [F:AMU]CODPRF;[F:AMU]NUMLIG
   If !fstat
    [F:AMU2]MENU = NEWMEN
    [F:AMU2]NUMLIG = NEWLIG
    [F:AMU2]LIBMENU = NEWLIB
    Rewrite [AMU2]
    If fstat
     Call FSTA("AMU2") From GLOCK
    Endif
   Endif
  Endif
 Endif
Next LNK

If TRANS
 Commit
 TRANS = 0
Endif

## Numéro des menus
NBMEN = 0
For [LNK]CLE
 NBMEN += 1
 TBMEN(NBMEN) = [F:AMU]CODMEN
 TBNUM(NBMEN) = [F:AMU]NUMLIG
Next

##  Phase de chargement 
NOMMEN = MENCUR
Local Integer MAXFUNC : MAXFUNC=5000
Local Integer NMODULE(1..MAXFUNC)   : # No du module (menu local 14)
Local Integer NFONC(1..MAXFUNC)     : # No de rang dans la table
Local Integer NPERE(1..MAXFUNC)     : # NUMLIG du menu père
Local Integer NUMFN(1..MAXFUNC)     : # No de fonction interne NUMFNC
Local Integer NTEXT(1..MAXFUNC)     : # No du texte libellé (Alt)
Local Integer NAID(1..MAXFUNC)      : # No du texte menu
Local Char    CFONC(GLONAFC)(1..MAXFUNC) : # Code de la fonction
Local Char    CMEN(15)(1..MAXFUNC)  : # Code du MENU
Local Char    CTRAN(15)(1..MAXFUNC) : # Code de la transaction
Local Char    CTEXT(30)(1..MAXFUNC) : # Texte mis sur la fonction (non traductible)
Local Integer ICOU                  : # Indice dans la table


For [LNK]CLE(2)
 MENCUR = [F:AMU]MENU
 PAPA = 0
 K = find(MENCUR,TBMEN(1..NBMEN))
 If K : PAPA = TBNUM(K) : Endif
 If PAPA<>0 or MENCUR=[F:APF]MENDEP
  If MENCUR=[F:APF]MENDEP : PAPA = 0 : Endif
  For [LNK]CLE
    ICOU+=1
    NFONC(ICOU)=[F:AMU]NUMLIG
    If [F:AMU]LIBMENU<>0
         NAID(ICOU)=[F:AMU]LIBMENU
    Else
         NAID(ICOU)=0  : # Non traductible !!!
         CTEXT(ICOU)=[F:AMU]INTIT
    Endif
    If [F:AFC]NOM<>0
         NTEXT(ICOU)=[F:AFC]NOM
    Else
         NTEXT(ICOU)=NAID(ICOU)
    Endif
         NMODULE(ICOU)=[F:AFC]MODULE
         NPERE(ICOU)=PAPA
         CFONC(ICOU)=[F:AMU]FONCTION
    If [F:AFC]TYPTRAIT=2
         NUMFN(ICOU)=0
         CMEN(ICOU)=vireblc([F:AMU]CODMEN,2)
         NTEXT(ICOU)=0
    Else
         NUMFN(ICOU)=[F:AFC]NUMFNC
         CTRAN(ICOU)=vireblc([F:AMU]CODMEN,2)
    Endif
  Next LNK
 Endif
Next LNK(2)
Return

####################
$DECLARE
Local Char    SRCMEN(GDIMFIC) : # Chemin source menu
Local Char    MENCUR(20)      : # Nom menu courant
Local Char    USRMEN(20)      : # Utilisateur du menu
Local Char    NOMMEN(20)      : # Nom menu
Local Integer NUMMEN          : # No ligne de menu
Local Char    TIT(50)         : # Intitulé menu
Local Char    LIBMEN(50)      : # Intitulé menu
Local Integer M , M1, M2 , I , J , K ,OK, OKMEN , STAT
Local Char    CHAINE(100) , HISDOS(GLONADS) , HISMEN(GLONAPM)
Local Char    SUPERU(GLONAUS)
Local Integer NBMEN , TBNUM(1..5000)
Local Char    TBMEN(20)(1..5000)
Local Integer TR_OK
Local Integer LANCUR
Local Char    LANGUE(GLONLAN)
Local Char    SAVIFS(5), SAVIRS(5)
Local Integer SAVIUM
Local Integer TRANS
If APPLI=nomap
 Local File ADOVAL    [ADW]
 Local File AMENUSER  [AMU]
 Local File AMENUSER  [AMU2]
 Local File APROFIL   [APF]
 Local File APROFIL   [APF2]
 Local File AFONCTION [AFC]
 Local File ATEXTE    [ATX]
 Local File APLSTD    [AST]
 Local File ACTIV     [ACV]
 Local File AELT      [AEL]
 Local File ATEXTRA   [AXX2]
Else
 Local File =APPLI+".ADOVAL"    [ADW]
 Local File =APPLI+".AMENUSER"  [AMU]
 Local File =APPLI+".AMENUSER"  [AMU2]
 Local File =APPLI+".APROFIL"   [APF]
 Local File =APPLI+".APROFIL"   [APF2]
 Local File =APPLI+".AFONCTION" [AFC]
 Local File =APPLI+".ATEXTE"    [ATX]
 Local File =APPLI+".APLSTD"    [AST]
 Local File =APPLI+".ACTIV"     [ACV]
 Local File =APPLI+".AELT"      [AEL]
 Local File =APPLI+".ATEXTRA"   [AXX2]
Endif
If filinfo(filpath("FIL","ATEXTRA","FDE",[F:ADS]DOSCOP),0)>=0
 Local File =[F:ADS]DOSCOP+"."+"ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ATEXTRA","fde",[F:ADS]DOSREF),0)>=0
 Local File =[F:ADS]DOSREF+"."+"ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0 
 Local File =GDOSX3+"."+"ATEXTRA" [AXX1] 
Endif
Return

#####################################
##  Phase de génération 
#####################################

$GENPROF
Local File =APPLI+".ADOVAL" [A_DW]
Read [A_DW]ADW0 = "";"";"HISDOS"
If !fstat  : HISDOS = [F:A_DW]VALEUR : Endif
Read [A_DW]ADW0 = "";"";"HISMEN"
If !fstat  : HISMEN = [F:A_DW]VALEUR : Endif
Close Local File [A_DW]

For LANCUR=0 To [F:ADS]NBRLAN-1  
 If USRMEN<>""
  LAN = [F:ADS]LAN(LANCUR)
  If filinfo(filpath("M"+LAN,"","",APPLI),0)<0
   Call ECR_TRACE("|"+filpath("M"+LAN,"","",APPLI)-":"-mess(86,133,1),1) From GESECRAN : # Répertoire inexistant
  Else
   SRCMEN = filpath("M"+LAN,USRMEN,"mnu",APPLI)
   Openo SRCMEN , 0 Using [APM_]
   Iomode adxifs "" Using [APM_]
   Iomode adxirs chr$(10) Using [APM_]
   Iomode adxium GUTF8 Using [APM_]
   For I=1 To ICOU
    Wrseq mess(NMODULE(I),14,1); Using [APM_]    : # Famille
    Wrseq "|"+num$(NFONC(I)); Using [APM_]       : # Id Menu
    Wrseq "|"+num$(NPERE(I)); Using [APM_]       : # Id du papa
    Wrseq "|"+num$(NUMFN(I)); Using [APM_]       : # No de fonction
    Wrseq "|1"; Using [APM_]                     : # Etat initial
    If CMEN(I)<>""
      Wrseq "|"+CFONC(I)-CMEN(I); Using [APM_]   : # Menu
    Else
      Call TEXTELAN(NTEXT(I),LIBMEN,LAN) From OBJDIV
      Wrseq "|"+CFONC(I)-LIBMEN; Using [APM_]    : # Fonction
    Endif
    If NAID(I)<>0
      If NAID(I)<>NTEXT(I) or CMEN(I)<>""     
        Call TEXTELAN(NAID(I),LIBMEN,LAN) From OBJDIV
      Endif
#  Bug 86271     --   CC 03/12/2012
      If CTRAN(I)<>"" : : LIBMEN-=CTRAN(I) : Endif
#  Bug 86271  
      Wrseq "|"+LIBMEN; Using [APM_]             : # Texte du menu
    Elsif CTEXT(I)<>""
      Wrseq "|"+CTEXT(I); Using [APM_]           : # Texte du menu
    Endif
    Wrseq "|"; Using [APM_]      
    If CTRAN(I)<>"" : Wrseq CTRAN(I); Using [APM_] : Endif    : # Code transaction
    Wrseq Using [APM_]                           : # fin des courses
   Next I
   Openo Using [APM_]
   If HISDOS<>"" & HISMEN=USRMEN & filinfo(filpath("M"+LAN,"","",HISDOS),0)>0
    Call COPIE(SRCMEN,filpath("M"+LAN,USRMEN,"mnu",HISDOS),STAT) From ORDSYS
   Endif 
   Gosub ECRWEB
  Endif
 Endif
Next LANCUR

Return
   
#####################################
$TR1
GOK=1
Trbegin [AMU] , [APF]
 Delete [APF] Where CODPRF=PROFIL
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("APF",PROFIL) From GLOCK : Goto AB_TR1
 Endif
 Delete [AMU] Where CODPRF=PROFIL
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("AMU",PROFIL) From GLOCK : Goto AB_TR1
 Endif
 For I=0 To len(mess(0,14,1))
  Raz [F:APF]
  [F:APF]MODULE = I
  [F:APF]CODPRF = PROFIL
  [F:APF]TYPPRF = 2
  [F:APF]MENDEP = "GENE"
  If dim([F:AXX2]TEXTE)>0 & I=0 & dim([F:AXX1]TEXTE)>0
   # Administrateur du système
   Call COPTEXTRA("APROFIL","INTPRF","0",[F:APF]CODPRF) From ATEXTRA
  Endif
  Write [APF]
  If fstat
   GOK=0 : Call FSTA("APF") From GLOCK : Break
  Endif
 Next I
 If GOK<1 : Goto AB_TR1 : Endif

 Read [AFC]CODINT = "MENU"
 If fstat
  EXTMEN = "MENU"
 Else
  EXTMEN = [F:AFC]CODEXT
 Endif
 Raz NUMMEN
 For [AFC]MENU Where [F:AFC]MENU<>""
  K = 1
  If [F:AFC]CODACT<>""
   Read [ACV]CODACT=[F:AFC]CODACT
   If fstat | [F:ACV]FLACT<>2
    K = 0
   Endif
  Endif
  If K
   Raz [F:AMU]
   [F:AMU] = [F:AFC]
   [F:AMU]CODPRF = PROFIL
   [F:AMU]FONCTION = [F:AFC]CODINT
   [F:AMU]TYPFCT = [F:AFC]TYP
   NUMMEN += 1 : [F:AMU]NUMLIG = NUMMEN
   If [F:AFC]TYPTRAIT=2
    [F:AMU]CODMEN   = [F:AFC]TRAIT
    [F:AMU]FONCTION = EXTMEN
   Endif
   Write [AMU]
   If fstat
    GOK=0 : Call FSTA("AMU") From GLOCK : Break
   Endif
  Endif
 Next AFC
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$RIEN
Resume


#####################################

$ECRWEB

#  Déclarations
Local Integer MAXMENU : MAXMENU=1000         : # Nombre maxi de menus
Local Integer TMENEC(1..MAXMENU),REFEC(1..MAXMENU),NIVNEC(1..MAXMENU)
Local Integer IIF, IDEB, IG, ILL, TREC
Local Integer I,J,MENCOU,ATMEN,IMEN,NIVCOU,OPENF,DEB
Local Char CLASSCOU,ADAPP,LA,CFIN,VALLM(200),LANCOU,VALL1(250),MENRAT
Local Integer NOMEN,NOMES
Local Integer NBM0                  : # Nombre de menus de niveau le plus élévés 
Local Shortint ICOU2
ICOU2 = max(1,ICOU)                 : # ICOU peut-être égal à 0
Local Integer NIV(1..ICOU2+1)       : # Niveau de la fonction courante (1 à 10)
Local Char CLASS(GLONAFC)(1..ICOU2)      : # Classe de la fonction courante (sert pour les trier)

#  Préparation du tri des fonctions
Sorta ICOU NPERE,NFONC,NMODULE,NUMFN,NTEXT,NAID,CFONC,CTRAN,CTEXT,CMEN
& Order By NPERE(indice+1), NFONC(indice+1)

#  Cherche les menus de niveau 1

For I=1 To ICOU
  If NPERE(I)<>0 : Break 1 : Endif
  If CMEN(I)<>""                      : # On exclut les fonctions rattachées au niveau 1
    CLASS(I)=chr$(64+I)
    NIV(I)=1
    IMEN+=1
    TMENEC(IMEN)=NFONC(I)
    NIVNEC(IMEN)=1
    REFEC(IMEN)=I
    NBM0+=1
  Else
    CLASS(I)=chr$(64+I)
    NIV(I)=1
  Endif
Next I

# Remplit la table des niveaux

While ATMEN<>IMEN
  ATMEN+=1
  MENCOU=TMENEC(ATMEN)
  NIVCOU=NIVNEC(ATMEN)
  CLASSCOU=CLASS(REFEC(ATMEN))
  Gosub TRTMEN
Wend


Sorta ICOU CLASS,NPERE,NFONC,NMODULE,NUMFN,NTEXT,NAID,CFONC,CTRAN,CTEXT,NIV,CMEN   Order By CLASS(indice+1)


Call GLOBWEB(APPLI) From INTRUTILA
##                Pour ne travailler que dans une langue  -- CC 20/10/2003
LANCOU=[F:ADS]LAN(LANCUR)

Local Char WE_HORDAT(14)
Call ENVVAR(WE_HORDAT) From INTRUTILA

Call NAMEFIC(APPLI,"PROF",LANCOU,USRMEN,SRCMEN) From INTRUTILA
Openo SRCMEN,0 Using [HML_]
Iomode adxifs "" Using [HML_]
Iomode adxirs chr$(10) Using [HML_]
Iomode adxium GUTF8 Using [HML_]
CFIN='"/>'
Wrseq '<?xml version="1.0" encoding="utf-8" standalone="yes" ?>' Using [HML_]
Wrseq '<PROF NAM="'+USRMEN+'" APP="'+APPLI+'" VER="'+'5" TIM="'+WE_HORDAT+'">' Using [HML_]
NIVCOU=1

Local Integer NBOUV,NBFERM,ICOMMENT,NBX
Local Char CODMENCOU(15)(0..20)
ICOMMENT=0
For DEB=1 To ICOU
  If NIV(DEB)<>0 : Break 1 : Endif
Next DEB


For I=DEB To ICOU
    If (NIV(I) < NIVCOU) Then
      If (NIVCOU-1) >= max(1,NIV(I))
        For J=NIVCOU-1 To max(1,NIV(I)) Step -1
          Wrseq "</MEN>" Using [HML_]  : NBFERM+=1
          If ICOMMENT=1 : Wrseq"! Niv "+num$(J) Using [HML_] : Endif 
        Next J
        If I>DEB and NUMFN(I-1)=0 : Wrseq "</MEN>" Using [HML_]  : NBFERM+=1 : Endif
      Elsif I>DEB and NUMFN(I-1)=0 
        Wrseq "</MEN>" Using [HML_] 
        If ICOMMENT=1 : Wrseq"! Nivx "+num$(1) Using [HML_] : Endif  
      Endif
    Elsif NIVCOU>1 and NPERE(I)<>0 and NIV(I)=NIV(I-1) and NUMFN(I)=0 and NUMFN(I-1)=0 
      Wrseq "</MEN>" Using [HML_]    : NBFERM+=1
      If ICOMMENT=1 : Wrseq"! Nivy "+num$(NIVCOU) Using [HML_] : Endif  
    Elsif NIVCOU>1 and NIV(I)=NIV(I-1) and NUMFN(I)<>0 and NUMFN(I-1)=0 
      Wrseq "</MEN>" Using [HML_]    : NBFERM+=1
      If ICOMMENT=1 : Wrseq"! Nivz "+num$(NIVCOU) Using [HML_] : Endif  
    Elsif I>DEB and NIV(I)=NIV(I-1) and NUMFN(I-1)=0 
      Wrseq "</MEN>" Using [HML_]    : NBFERM+=1
      If ICOMMENT=1 : Wrseq"! Nivw "+num$(NIVCOU) Using [HML_] : Endif  
    Endif 

   NIVCOU=NIV(I)

   If NUMFN(I)=0
       CFIN='">'
       Gosub TEXTF
       Wrseq ' <MEN NAM="'+CMEN(I)+'" NIV="'+num$(NIV(I))+'" C_'+LANCOU+'="'+VALLM+CFIN Using [HML_]
       CODMENCOU(NIV(I))=CMEN(I)
       NBOUV+=1
   Else
       CFIN='"/>'
       Gosub TEXTF
       VALL1=' <FUN NAM="'+CFONC(I)+'" NIV="'+num$(NIV(I))+'" NUM="'+num$(NUMFN(I))+'"'
       MENRAT=""
       If NIV(I)>1 : MENRAT=CODMENCOU(NIV(I)-1) : Endif
       VALL1+=' MEN="'+MENRAT+'"'
       If CTRAN(I)<>"" : VALL1+= '   TRA="'+CTRAN(I)+'"' : Endif
#  Bug 86271     --   CC 03/12/2012
       If CTRAN(I)<>"" and NAID(I)>0 : : VALLM-=CTRAN(I) : Endif
#  Bug 86271  
       VALL1+= ' C_'+LANCOU+'="'+VALLM+CFIN 
       Wrseq VALL1 Using [HML_]
   Endif
Next I
#   Si on termine par un menu il y a une fermeture de plus à gérer
If ICOU>0 and NUMFN(ICOU)=0
  Wrseq "</MEN>" Using [HML_]    : NBFERM+=1
  If ICOMMENT=1 : Wrseq"! Nivw "+num$(NIVCOU) Using [HML_] : Endif  
Endif

#Infbox("avant  nbouv "-num$(NBOUV)-"  nbferm "-num$(NBFERM))
For J=NIVCOU-1 To 1 Step -1
   Wrseq "</MEN>" Using [HML_]   : NBFERM+=1
   If ICOMMENT=1 : Wrseq"! Nivx "+num$(J) Using [HML_] : Endif  
Next J
#Infbox("apres  nbouv "-num$(NBOUV)-"  nbferm "-num$(NBFERM))

#If NBOUV<>NBFERM : Infbox("Profil "+USRMEN-num$(NBOUV-NBFERM)) : Endif

Wrseq '</PROF>' Using [HML_]
Openo  Using [HML_]


# Création des liens
If adxlog=0
 Trbegin [AEL]
 TREC=1
Endif
Local Char PROF : PROF=USRMEN
Gosub WI_CREPROF From INTRUTILB
If TREC=1
 Commit
Endif

#Gosub WE_VISU

Return

$WE_VISU
  Local Char URL(200),RETOUR(200),AASEP
  AASEP="/"
  If instr(1,GVIRTDIR,"\") : AASEP="\" : Endif
  URL=GVIRTDIR+AASEP+APPLI+AASEP+"GEN"+AASEP+LANCOU+AASEP+"PROF"
  URL+=+AASEP+USRMEN+".xml"
  URL=ctrans(URL,"\","/")
  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return





$TEXTF:
  If NAID(I)<>0
    Read [ATX]NUMERO = LANCOU;NAID(I)
    If fstat=0
      VALLM = [F:ATX]TEXTE
    Else
      If LANCOU<>GLANGUE 
        Read [ATX]NUMERO = GLANGUE;NAID(I) 
      Else
        Read [ATX]NUMERO = GLANDEF;NAID(I) 
      Endif
      If fstat=0 
        VALLM = [F:ATX]TEXTE 
      Else
        VALLM = "" 
      Endif
    Endif
  Elsif CTEXT(I)<>""
    VALLM = CTEXT(I) 
  Endif
  Gosub MVALC From INTRUTILA
Return



$TRTMEN:
IIF=0
IG=find(MENCOU,NPERE(1..ICOU))
While IG<>0
  IIF+=1
  CLASS(IG)=CLASSCOU+chr$(64+IIF)
  NIV(IG)=NIVCOU+1
  If NUMFN(IG)=0    : # C'est un menu
    IMEN+=1
    TMENEC(IMEN)=NFONC(IG)
    NIVNEC(IMEN)=NIVCOU+1
    REFEC(IMEN)=IG
  Endif
  IDEB=IG+1
  IG=find(MENCOU,NPERE(IDEB..ICOU))
  If IG<>0 : IG+=IDEB-1 : Endif
Wend
Return


########################################################################
# Pour exécution validation du menu ADMIN  dans les dossiers applicatifs 
# lors intégration du PATCH
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
#--- pas de validation du menu X3
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])<=0 Local File ADOSSIER [ADS]:  Endif
Read [ADS]DOSSIER = APPLI
If fstat : End : Endif
# Mise à jour menu
Call GENMEN From DOSMEN
End

Subprog C_PROFIL(VALEUR)
Variable Char VALEUR
VALEUR = toupper(VALEUR)
If !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?")
 Read [APF]CODPRF = 0;VALEUR
 If fstat
  GMESSAGE = mess(84,141,1) : mkstat = 2 : End : # Code inexistant
 Endif
Endif
End
