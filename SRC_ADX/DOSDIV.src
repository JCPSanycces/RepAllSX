#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion de dossier
###############################################################
## DOSDIV  Traitements divers
###############################################################
Subprog DIVERS
Onerrgo ERREUR
Local Char SAVDOS(GLONADS) , SYMBOLE(10)
SAVDOS = [F:ADS]DOSSIER
If GINFO
 Call AFF_VLC(mess(33,125,1),"") From GESECRAN
Endif
Call ECR_TIME(mess(33,125,1)-[F:ADS]DOSSIER) From DOSSUB       : # Initialisations diverses
Call PARAM                                                     : # Init paramètres systèmes
Call USERS                                                     : # Création utilisateur
Gosub CREATEADMCA                                              : # Creation de ADMCA en creation ou en migration :#F_add_admca_managment
If GCRE
 Call ECR_TIME(mess(68,126,1)) From DOSSUB                     : # Validation des fonctions
 Call VALFCT([F:ADS]DOSSIER) From AVALAFC
Endif
Call COMPTEURS                                                 : # Raz compteurs
Call APLLCK                                                    : # Raz lock
#CHECK UNUSED_BEGIN
Case GPRODUIT
 When -1 : # Superviseur
 When  0 : # X3
  Call PERIODE From DOSDIV1                                    : # Premiers exercices et périodes
  Call AXANA                                                   : # Nb d'axes analytiques
 When  1 : # Géode
  Gosub ACTION From DOSDIV1
 When  2 : # Paye
  Call AXANA                                                   : # Nb d'axes analytiques
  Call GENDOS([F:ADS]DOSSIER) From GENTRT                      : # Génération du traitement DEFTABLE
 When  3 : # Biens
  Call AXANA                                                   : # Nb d'axes analytiques
Endcase
#CHECK UNUSED_END
Call MENUSER From DOSMEN                                       : # MAJ menus utilisateurs
Call FAVORIS(SAVDOS)                                           : # MAJ des favoris
Call MAJBLOB                                                   : # MAJ des blobs contenant les logos pour les états
Call TEXTRA                                                    : # Génération du fichier des textes traduisibles
If GCRE
 Call MEMOS                                                    : # Mémos globaux
 Call ICONES(GDOSX3,SAVDOS)                                    : # Copie des images du répertoire X3_PUB/nomap/RES
Endif
Call ECR_TIME(mess(95,125,1)-[F:ADS]DOSSIER) From DOSSUB       : # Création des paramètres du dossier
Call CREPAR                                                    : # Création paramètres du dossier
Call MAJDROIT                                                  : # Mise à jour de l'onglet "Liens" en création
Call MAJPATCH                                                  : # Mise à jour table APATCH
Call MAJVOL                                                    : # Mise à jour de la table AVOLUME
Call CRELIBWEBD(SAVDOS) From INTRUTILC                         : # Crée la liste des langues du dossier
#  On exécute cette séquence en mode exclusif     C 09/12/2008
SYMBOLE = "VALLANG"
Lock =SYMBOLE From =GDOSX3 With lockwait=0
If fstat=0
  Call CREFOLDERS From VALCSTWEB                               : # Création du fichier folders
 # Crée les répertoires pouvant manquer d'X3_ROOT (si ajout de langue) et les libellés associés
  Call CRELIBALL From VALLANG
  Unlock =SYMBOLE From =GDOSX3
Endif
Read [ADS]DOSSIER=SAVDOS
Onerrgo
End

###########################################################
# Mise à jour de la table AVOLUME
###########################################################

Subprog MAJVOL
Call ECR_TRACE(mess(81,125,1)-"AVOLUME",0) From GESECRAN : # Mise à jour de la table
Local Char    APPLI(GDIMFIC) , VOLUME(1)
Local Char    MACHINE(GDIMFIC),REPERT(GDIMFIC),REPERTDOS(GDIMFIC)
Local Integer I , ERREUR, OK
Local File =[F:ADS]DOSSIER+".AVOLUME" [AVL]
MACHINE = adxmac(0)
APPLI  = [F:ADS]DOSSIER
VOLUME = [F:ADS]VOLUME
Gosub SET_DIRECT_STO From DOSAPL
If !find("REPORT",TBDIR(1..NBDIR))
 NBDIR += 1 : TBDIR(NBDIR) = "REPORT"
Endif
Trbegin [AVL]
 For I=1 To NBDIR
  Look [AVL]CODE=toupper(TBDIR(I))
  If fstat
   Raz [F:AVL]
   [F:AVL]VOLUME = toupper(TBDIR(I))
   [F:AVL]ROOT   = TBDIR(I)
   [F:AVL]VOLTYP = 1
   [F:AVL]CREUSR = GUSER
   [F:AVL]CREDATTIM = datetime$
   Write [AVL]
   If fstat
    Call ERREUR("AVOLUME",1) From DOSDIC
   Endif
   #112507
   ERREUR = 0
   Call CREREP(filpath(TBDIR(I),"","",APPLI,VOLUME,MACHINE),ERREUR) From DOSAPL
  Endif
 Next I
Commit

#109897
Onerrgo ERR_VOL
NEWREP=filpath(GBATCHDIR,"","",GDOSX3)
Call MACHINE(NEWREP,MACHINE,REPERT) From ORDSYS
REPERT=ctrans(REPERT,"\","/")

# Create record SRV
Trbegin [AVL]
 Read [AVL]CODE=GBATCHDIR
 If fstat
  Raz [AVL]
  [F:AVL]VOLUME=GBATCHDIR
  [F:AVL]ROOT = REPERT
  Write [AVL]
  If fstat
   Call ERREUR("AVOLUME",1) From DOSDIC
  Endif
 Elsif [F:AVL]ROOT<>REPERT
  [F:AVL]ROOT = REPERT
  Rewrite [AVL]
  If fstat
   Call ERREUR("AVOLUME",2) From DOSDIC
  Endif
 Endif
Commit
Onerrgo

Onerrgo ERR_VOL
REPERTDOS=filpath("","","",APPLI,VOLUME,MACHINE)
For [AVL]
  #112507
  ERREUR = 0
  OK=1
  REPERT=filpath([F:AVL]ROOT,"","",APPLI,VOLUME,MACHINE)
  If OK & REPERTDOS=left$(REPERT,len(REPERTDOS))
   Call CREREP(REPERT,ERREUR) From DOSAPL
  Endif
Next
Onerrgo

End

$ERR_VOL
OK=0
Resume

#############################################################
## Mise à jour table APATCH (BY 28/09/05 Bug 26146)        ##
#############################################################
Subprog MAJPATCH
Local File =[F:ADS]DOSSIER+".APATCH" [APT]
Local File =GDOSX3+".APATCH"         [A_PT]
Local Integer PNUM
Call ECR_TRACE(mess(81,125,1)-"APATCH",0) From GESECRAN : # Mise à jour de la table
Trbegin [APT]
 Read [APT]APT0 Last
 If fstat>2
  PNUM = 1
 Else
  PNUM = [F:APT]NUM+1
 Endif
 Raz [F:APT]
 Filter [A_PT] Where TYP="P"
 Read [A_PT]APT0 Last
 Filter [A_PT]
 If fstat<=2
  [F:APT] = [F:A_PT]
 Else
  [F:APT]NUMP    = 0
  [F:APT]PATNUM  = 0
  #106969
  #[F:APT]RELEASE = GVERSION
  [F:APT]RELEASE = func APRODUCT.AGETRELEASEABR(GDOSX3)+"."+format$("N0:3#",func AFNC.PARAMDOS(GDOSX3, "NUMPATCH"))
 Endif
 [F:APT]NUM     = PNUM
 [F:APT]DAT     = date$
 [F:APT]USR     = GUSER
 [F:APT]FIC     = mess(57,125,1)
 [F:APT]TYP     = "P"
 Write [APT]
 If fstat
  Call ERREUR("APATCH",1) From DOSDIC
 Endif
Commit
End

#############################################################
## Mise à jour de l'onglet "Liens"
#############################################################
Subprog MAJDROIT
Onerrgo ERRDOS
Local Integer ER , NBSOL
If !GCRE : End : Endif
Call ECR_TRACE(mess(191,139,1),0) From GESECRAN : # Mise à jour des droits dossier
Local File ADOSSIER [A_D] , ADOSSIER [A_D_]
Trbegin [A_D]
 Readlock [A_D]DOSSIER=[F:ADS]DOSSIER
 If !fstat
  Raz [F:A_D]SOLDOS
  Raz [F:A_D]SOLAUZ
  NBSOL = 0
  For [A_D_]
   If [F:A_D_]DOSSIER<>[F:ADS]DOSSIER & !find([F:A_D_]DOSSIER,[F:A_D]SOLDOS)
    ER = 0
    If filinfo(filpath("FIL","ADOVAL","fde",[F:A_D_]DOSSIER),0)>0
     Local File =[F:A_D_]DOSSIER+".ADOVAL" [AX__]
     Read [AX__]ADW0 = "";"";"TYPDOS"
     If !ER & !fstat & val([F:AX__]VALEUR)=GPRODUIT+1
      Read [AX__]ADW0 = "";"";"SUPDOS"
      If !ER & !fstat & [F:AX__]VALEUR=GDOSX3 & [L]NBSOL<dim([F:A_D]SOLDOS)-1
       [L]NBSOL += 1
       [F:A_D]SOLDOS([L]NBSOL-1) = [F:A_D_]DOSSIER
       If [F:A_D_]DOSSIER=GDOSX3
        [F:A_D]SOLAUZ([L]NBSOL-1) = 3
       Else
        [F:A_D]SOLAUZ([L]NBSOL-1) = 1
       Endif
      Endif
     Endif
     Close Local File [AX__]
    Endif
   Endif
  Next A_D_
  Rewrite [A_D]
 Endif
Commit
Close Local File [A_D] , [A_D_]
End

$ERRDOS
ER = errn
Resume

#############################################################
## Init paramètres systèmes                                ##
#############################################################
Subprog PARAM
Local Date    DATFIN
Local Integer I
Local Char    CHAINE(30)
Call ECR_TIME(mess(34,125,1)) From DOSSUB
# Paramètres système
If GINFO
 Call AFF_VLC(mess(33,125,1),mess(34,125,1)) From GESECRAN
Endif
Local File =[F:ADS]DOSSIER+".ADOVAL"  [ADW]
Trbegin [ADW]
 Call MAJPAR("TYPDBA",num$([F:ADS]TYPDBA))
 Call MAJPAR("TYPDOS",num$(GPRODUIT+1)) : # 0 Superviseur, 1 X3, 2 Géode, 3 Paye, 4 Biens
 Call MAJPAR("LANGUAGE",[F:ADS]LANDEF)
 Call MAJPAR("CRYDEF",[F:ADS]CRYDEF)
 Call MAJPAR("DESAPP",[F:ADS]NOMDOS)
 Call MAJPAR("ADONIX","1") : # En principe ce n'est pas le dossier de développement interne
 CHAINE = ""
 For I=0 To dim([F:ADS]MODULE)-1
  CHAINE += num$([F:ADS]MODULE(I))
 Next I
 Call MAJPAR("MODULE1",left$(CHAINE,10))
 Call MAJPAR("MODULE2",right$(CHAINE,11))
 Call MAJPAR("TEST",num$([F:ADS]TSTFLG))
 Call MAJPAR("SPECIF",num$([F:ADS]SPEFLG))
 Call MAJPAR("TMPID","")
 Call MAJPAR("DOSLEG",sigma(0,[F:ADS]NBLEG-1,string$(indcum>0,"~")+[F:ADS]DOSLEG(indcum)))
 If GCRE
  If dim([F:ADS]RPTCUR)>0
   Local File =[F:ADS]DOSSIER+".ADOPAR" [ADP]
   Call MAJPAR("SYSCUR",[F:ADS]RPTCUR)
   Read [ADP]ADP1="CURSHRFLD"
   If !fstat
    Call MAJPAR("CURSHRFLD",[F:ADS]RPTCUR)
   Endif
   Close Local File [ADP]
  Endif
  Call MAJPAR("STRDAT",format$("D:YYYYMMDD",[F:ADS]STRDAT))
  DATFIN = max(date$,addmonth([F:ADS]STRDAT,12)-1)
  DATFIN = gdat$(31,12,year(DATFIN))
  Call MAJPAR("ENDDAT",format$("D:YYYYMMDD",DATFIN) )
  #X3-15226 Manage sub-revision number
  #Call MAJPAR("NUMPATCH","0")
  Call MAJPAR("HISDOS","")
  Call MAJPAR("CPYMAXLEN","0")
  Call MAJPAR("CPYMINLEN","0")
  Call MAJPAR("FCYMAXLEN","0")
  Call MAJPAR("FCYMINLEN","0")
  Call MAJPAR("REPBI","SAGE") : # En principe ce n'est pas le dossier de développement interne
  Call MAJPAR("IMPBI","SAGE~IMPORT") : # En principe ce n'est pas le dossier de développement interne
 Endif
Commit
End

Subprog MAJPAR(PARAM,VALEUR)
Value Char PARAM
Value Char VALEUR
Read [ADW]ADW0 = "";"";PARAM
If fstat
 Raz [F:ADW]
 [F:ADW]PARAM  = PARAM
 [F:ADW]VALEUR = VALEUR
 Write [ADW]
Else
 [F:ADW]VALEUR = VALEUR
 Rewrite [ADW]
Endif
If fstat
 Call ERREUR("ADOVAL",1) From DOSDIC
Endif
End

#############################################################
## Remise à 0 des flags de validation                      ##
#############################################################
Subprog FLGMSK
Onerrgo RIEN
Local File =[F:ADS]DOSSIER+".AMSK"     [AMK]
Local File =[F:ADS]DOSSIER+".ATABLE"   [ATB]
Local File =[F:ADS]DOSSIER+".AWINDOW"  [AWI]
Local File =[F:ADS]DOSSIER+".AOBJET"   [AOB]
Local File =[F:ADS]DOSSIER+".ACONSULT" [ACN]
Local File =[F:ADS]DOSSIER+".AVIEW"    [AVW]
Local File =[F:ADS]DOSSIER+".ACTIV"    [ACV]
Trbegin [AMK]
 Update [AMK] Where UPDFLG=1 With UPDFLG=0
Commit
Trbegin [ATB]
 Update [ATB] Where UPDFLG=1 With UPDFLG=0
Commit
Trbegin [AWI]
 Update [AWI] Where UPDFLG=1 With UPDFLG=0
Commit
Trbegin [AOB]
 Update [AOB] Where UPDFLG=1 With UPDFLG=0
Commit
Trbegin [ACN]
 Update [ACN] Where UPDFLG=1 With UPDFLG=0
Commit
Trbegin [AVW]
 Update [AVW] Where UPDFLG=1 With UPDFLG=0
Commit
If dim([F:ACV]UPDFLG)>0
 Trbegin [ACV]
  Update [ACV] Where UPDFLG=1 With UPDFLG=0
 Commit
Endif
Close Local File [AMK] , [ATB] , [AWI] , [AOB] , [ACN] , [AVW] , [ACV]
Onerrgo
End

$RIEN
Resume


#############################################################
## Creation des ATEXTRA des AINDEX si besoin               ##
#############################################################
Subprog ANXTEXTRA
Local File =[F:ADS]DOSREF+".AINDEX"  [ANX]
Local File =[F:ADS]DOSSIER+".AINDEX"  [DANX]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX2]
If filinfo(filpath("FIL","ATEXTRA","fde",[F:ADS]DOSCOP),0)>=0
 Local File =[F:ADS]DOSCOP+".ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ACLOB","fde",[F:ADS]DOSREF),0)>=0
 Local File =[F:ADS]DOSREF+".ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0
 Local File =GDOSX3+".ATEXTRA" [AXX1]
Endif
Local Integer K
Trbegin [AXX2]
 For [ANX]ANX2
  Read [DANX]ANX2=[F:ANX]TABLE;[F:ANX]CODIND
  If !fstat
   K=0
   For [AXX2] Where CODFIC="AINDEX" & ZONE="COMDES" & IDENT1=[F:ANX]TABLE & IDENT2=[F:ANX]CODIND & TEXTE<>""
      K=1 : Break
   Next
   If K=0
     Call COPTEXTRA("AINDEX","COMDES",[F:ANX]TABLE,[F:ANX]CODIND) From ATEXTRA
   Endif
  Endif
 Next ANX
Commit
End
#############################################################
## Création d'un utilisateur                               ##
#############################################################
Subprog USERS
Local Char SUPERU(5)
Local File =[F:ADS]DOSSIER+".ADOVAL"  [ADW]
Local File =[F:ADS]DOSSIER+".AUTILIS" [AUS]
Local File =[F:ADS]DOSSIER+".AFCTFCT" [AFT]
Local File =[F:ADS]DOSSIER+".ACCES"   [ACC]
Local File =[F:ADS]DOSSIER+".ATEXTRA" [AXX2]
If filinfo(filpath("FIL","ATEXTRA","fde",[F:ADS]DOSCOP),0)>=0
 Local File =[F:ADS]DOSCOP+".ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ACLOB","fde",[F:ADS]DOSREF),0)>=0
 Local File =[F:ADS]DOSREF+".ATEXTRA"  [AXX1]
Elsif filinfo(filpath("FIL","ATEXTRA","fde",GDOSX3),0)>=0
 Local File =GDOSX3+".ATEXTRA" [AXX1]
Endif
If dim([F:AUS]USRBI)>0 & filinfo(filpath("FIL","ABIPRFUSR","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".ABIPRFUSR"   [AIU]
Endif
If nbrecord([AUS])=0
 Call ECR_TIME(mess(35,125,1)) From DOSSUB
# Création utilisateurs
 If GINFO
  Call AFF_VLC(mess(33,125,1),mess(35,125,1)) From GESECRAN
 Endif
 Read [ADW]ADW0 = "";"";"ADMUSR"
 If !fstat : SUPERU = [F:ADW]VALEUR : Endif
 If SUPERU="" : SUPERU = "ADMIN" : Endif
 Trbegin [AUS] , [AFT]
  Raz [F:AUS]
  [F:AUS]USR    = SUPERU
  If dim([F:AXX1]TEXTE)>0
   Call LECTEXTRA([F:AUS]NOMUSR,"AUTILIS","INTUSR",[F:AUS]USR,"") : # subprog spécial pour lire dans AXX1 et non pas dans AXX
   Call COPTEXTRA("AUTILIS","INTUSR",[F:AUS]USR,"") From ATEXTRA
  Endif
  If [F:AUS]NOMUSR = ""
   [F:AUS]NOMUSR = mess(158,124,1) : # Administrateur du système
  Endif
  [F:AUS]LOGIN  = SUPERU
  [F:AUS]PRFMEN = SUPERU
  [F:AUS]PRFFCT = SUPERU
  [F:AUS]PASSE = "" : Call CRYPT([F:AUS]PASSE) From GESUSER
  If dim([F:AUS]NEWPAS)>0
   [F:AUS]NEWPAS = "" : Call CRYPTNEW([F:AUS]NEWPAS) From GESUSER
  Endif
  If dim([F:AUS]USRBI)>0
   [F:AUS]USRBI = "ADMIN"
   If clalev([F:AIU])>0
    [F:AIU]PRF = [F:AUS]USRBI
    [F:AIU]USR = "Administrator"
    If dim([F:AXX1]TEXTE)>0
     Call COPTEXTRA("ABIPRFUSR","INTUSR",[F:AIU]USR,"") From ATEXTRA
    Endif
    [F:AIU]PWD = "" : # Call CRYPTNEW([F:AIU]PWD) From GESUSER
    [F:AIU]CREDAT = date$
    [F:AIU]CREUSR = GUSER
    If dim([F:AIU]CRETIM)>0 : [F:AIU]CRETIM = time : Endif
    Write [AIU]
    If fstat : Call ERREUR("ABIPRFUSR",1) From DOSDIC : Endif
   Endif
  Endif
  Call MAJPAR("NBLSTGAU","30")
  Call MAJPAR("NBDERLUS","5")
  [F:AUS]ENAFLG     = 2
  [F:AUS]ALLACS     = 2
  [F:AUS]USRCONNECT = 2
  Call MAJPAR("CHDERLUS","2")
  #Call MAJPAR("DEMSRV","1") : #107748
  Call MAJPAR("CONFSUP","2")
  Call MAJPAR("CONFDUP","2")
  Call MAJPAR("CONFABD","2")
  [F:AUS]USREXT = 1
  Call MAJPAR("CHGDAT","2")
  Call MAJPAR("SELGLO","2")
  Call MAJPAR("GRPLIAISON","STD")
  [F:AUS]CREDAT = date$
  [F:AUS]CREUSR = GUSER
  If dim([F:AUS]CRETIM)>0 : [F:AUS]CRETIM = time : Endif
  Write [AUS]
  If fstat : Call ERREUR("AUTILIS",1) From DOSDIC : Endif
  Raz [F:AFT]
  [F:AFT]PRFCOD = SUPERU
  If dim([F:AXX1]TEXTE)>0
   Call COPTEXTRA("AFCTFCT","INTPRF",[F:AFT]PRFCOD,"") From ATEXTRA
  Endif
  [F:AFT]DIFIMP = 2
  [F:AFT]ALLFCT = 2
  [F:AFT]ALLACS = 2
  [F:AFT]CREDAT = date$
  [F:AFT]CREUSR = GUSER
  For I=1 To dim([F:AFT]AUTETA)
   [F:AFT]AUTETA(I-1) = 2
  Next I
  Write [AFT]
  If fstat : Call ERREUR("AFCTFCT",1) From DOSDIC : Endif
  Raz [F:ACC]
  [F:ACC]CODACC = ""
  [F:ACC]USR    = SUPERU
  [F:ACC]CONSUL = 2
  [F:ACC]MODIF  = 2
  [F:ACC]EXEC   = 2
  [F:ACC]PRFCOD = SUPERU
  Write [ACC]
  If fstat : Call ERREUR("ACCES",1) From DOSDIC : Endif
 Commit
Endif
End

#F_add_admca_managment
#############################################################
## Création user ADMCA                                     ##
#############################################################
$CREATEADMCA
#check if ADMCA exist in GDOSX3
Local File =GDOSX3+".AUTILIS" [F:AUS__]
Read [F:AUS__]CODUSR = "ADMCA"
If fstat
 Close Local File [F:AUS__]
 Return
Endif
Close Local File [F:AUS__]

# we create admca user only in creation folder or in migration.
# In migration for update authorize functions
If GCRE or SUPVERS<>DOSVERS
 Call CREATE_ADMCA
 Return
Endif

# we create ADMCA user si it not exist in all cases
Local File =[F:ADS]DOSSIER+".AUTILIS" [F:AUS__]
Read [F:AUS__]CODUSR = "ADMCA"
If fstat
 Call CREATE_ADMCA
Endif
Close Local File [F:AUS__]
Return

#############################################################

Subprog CREATE_ADMCA

Local File =[F:ADS]DOSSIER+".ADOVAL"  [ADW]
Local File =[F:ADS]DOSSIER+".AUTILIS" [AUS]
Local File =[F:ADS]DOSSIER+".AFCTFCT" [AFT]
Local File =[F:ADS]DOSSIER+".ACCES"   [ACC]
Local File =[F:ADS]DOSSIER+".APROFIL" [APF]
Local File =[F:ADS]DOSSIER+".AMENUSER" [AMU]
Local File =[F:ADS]DOSSIER+".ADOVALAUS" [ADU]


#SAM 120950
Local File =[F:ADS]DOSSIER+".AFCTFCY"   [AFF]
Local File =[F:ADS]DOSSIER+".AFONCTION" [AFC]
Local File =[F:ADS]DOSSIER+".AFCTPRF"   [AFP1]
Local File =[F:ADS]DOSSIER+".FACILITY"  [FCY]
Local File =[F:ADS]DOSSIER+".FACGROUP"  [FGRA]


Local File =GDOSX3+".AUTILIS" [AUS2]
Local Char ADMCA(5), SAVPASSE(250),SAVNEWPAS(250)
Local Integer OKADMCA,EXISTADMCA

[L]ADMCA="ADMCA"

Call ECR_TIME("Création utilisateur ADMCA") From DOSSUB
# Création utilisateurs
If GINFO
 Call AFF_VLC(mess(33,125,1),"Création utilisateur ADMCA") From GESECRAN
Endif

# delete user, profile if admca exist
Read [F:AUS]CODUSR = [L]ADMCA
If !fstat
 EXISTADMCA = 1
Endif

If EXISTADMCA>0
 Trbegin [APF]
  Delete [APF] Where CODPRF=[L]ADMCA & MODULE=0
  If fstat : Call ERREUR("APROFIL",3) From DOSDIC : Endif
  Delete [AMU] Where CODPRF=[L]ADMCA
  If fstat : Call ERREUR("AMENUSER",3) From DOSDIC : Endif
  Delete [ACC] Where USR=[L]ADMCA
  If fstat : Call ERREUR("ACC",3) From DOSDIC : Endif
  Delete [ADU] Where CODUSR=[L]ADMCA
  If fstat : Call ERREUR("ADU",3) From DOSDIC : Endif
  Delete [AUS] Where USR=[L]ADMCA
  If fstat : Call ERREUR("AUTILIS",3) From DOSDIC : Endif
 Commit
Endif

Call ECR_TIME("Copie utilisateur ADMCA") From DOSSUB
Local Mask ACOPIE [DIA_]
[M:DIA_]DOSORG = GDOSX3
[M:DIA_]DOSDES = [F:ADS]DOSSIER
Onerrgo ERREUR
Call TRTCOP("AFT",[L]ADMCA,"","","") From ACOPIE
Call TRTCOP("AUS",[L]ADMCA,"","","") From ACOPIE
Onerrgo
Close Local Mask [DIA_]

Trbegin [AUS]
 Read [F:AUS]CODUSR = [L]ADMCA
  If !fstat
   [F:AUS]PASSE = "" : Call CRYPT([F:AUS]PASSE) From GESUSER
   If dim([F:AUS]NEWPAS)>0
    [F:AUS]NEWPAS = "" : Call CRYPTNEW([F:AUS]NEWPAS) From GESUSER
   Endif
   Rewrite [F:AUS]
   If fstat : Call ERREUR("AUTILIS",2) From DOSDIC : Endif
  Endif
Commit

#SAM 120950
# Update AFCTFCY (AFF) records for ADMCA based on AFCTPRF (AFP) records
Call MAJAFF("ADMCA") From SUBAFP1

End

#############################################################
## Initialisation des compteurs                            ##
#############################################################
Subprog COMPTEURS
Local File =[F:ADS]DOSSIER+".APLCOM" [COM]
If GCRE
 If GINFO
  Call AFF_VLC(mess(33,125,1),mess(36,125,1)) From GESECRAN
 Endif
# Initialisation des compteurs
 Call ECR_TIME(mess(36,125,1)) From DOSSUB
 Trbegin [COM]
  For [COM]
   Case [F:COM]COMTYP
    When 7,8     : [F:COM]COMFLD = ""
    When Default : [F:COM]COMFLD = "1"
   Endcase
   Rewrite [COM]
   If fstat : Call ERREUR("APLCOM",2) From DOSDIC : Endif
  Next COM
 Commit
Else
 If GINFO
  Call AFF_VLC(mess(33,125,1),mess(122,125,1)) From GESECRAN
 Endif
# Mise à jour des compteurs
 Call ECR_TIME(mess(122,125,1)) From DOSSUB
 Local File =[F:ADS]DOSREF+".APLCOM" [COM_]
 Trbegin [COM]
  For [COM_]
   Read [COM]COMCLE=[F:COM_]COMNOM;[F:COM_]COMIND
   If fstat
    [F:COM] = [F:COM_]
    Case [F:COM]COMTYP
     When 7,8     : [F:COM]COMFLD = ""
     When Default : [F:COM]COMFLD = "1"
    Endcase
    Write [COM]
    If fstat : Call ERREUR("APLCOM",1) From DOSDIC : Endif
   Endif
  Next COM_
 Commit
Endif
End

