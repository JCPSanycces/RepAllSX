## Installation des biar s'ils n'existent pas
####################################################################
Subprog VERFBIAR
End

##########################################################
Subprog LECTEXTRA(VALEUR,TABLE,CHAMP,CLE1,CLE2)
Variable Char    VALEUR()
Value    Char    TABLE, CHAMP, CLE1, CLE2
Read [AXX1]AXX0 = TABLE;CHAMP;GLANGUE;CLE1;CLE2
If fstat=0
 VALEUR = [F:AXX]TEXTE
Else
 Read [AXX1]AXX0 = TABLE;CHAMP;GLANDEF;CLE1;CLE2
 If fstat=0
  VALEUR = [F:AXX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
End

################################################################
# MAJ des favoris
################################################################

Subprog FAVORIS(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".ACLOB" [ACB] , =DOSSIER+".AFONCTION" [AFC]
Local Integer MAJ
Trbegin [ACB]
 For [ACB] Where IDENT2="FAVORIS"
  Call MODIF_FAVORIS([F:ACB]CLOB,MAJ)
  If MAJ
   Rewrite [ACB]
   If fstat
    Call ERREUR('ACLOB~'+[F:ACB]IDENT1+'~'+[F:ACB]IDENT2,2) From DOSDIC
   Endif
  Endif
 Next ACB
Commit
Close Local File [ACB] , [AFC]
End

Subprog MODIF_FAVORIS(CLOB,MAJ)
Variable Clbfile CLOB
Variable Integer MAJ
Local Integer I , J , F , N , NUM
Local Char    FNC(GLONAFC)
MAJ = 0
F = instr(1,CLOB,'<FUN NAM=')
While F
 I = instr(F,CLOB,'"')
 If !I : Break : Endif
 J = instr(I+1,CLOB,'"')
 If !J : Break : Endif
 FNC = seg$(CLOB,I+1,J-1)
 Read [AFC]CODINT=FNC
 If !fstat
  N = instr(J,CLOB,' NUM=')
  If N
   I = instr(N,CLOB,'"')
   If !I : Break : Endif
   J = instr(I+1,CLOB,'"')
   If !J : Break : Endif
   NUM = val(seg$(CLOB,I+1,J-1))
   If NUM<>[F:AFC]NUMFNC
    If MAJ=0 : MAJ = 1 : Endif
    CLOB = left$(CLOB,I)+num$([F:AFC]NUMFNC)+right$(CLOB,J)
   Endif
  Endif
 Endif
 F = instr(F+10,CLOB,'<FUN NAM=')
Wend
End

