#############################################################
## MAJ des blobs contenant les logos pour les états        ##
#############################################################
Subprog MAJBLOB
If GINFO
 Call AFF_VLC(mess(33,125,1),mess(152,125,1)) From GESECRAN
Endif
# Mise à jour des blobs logos
Call ECR_TIME(mess(152,125,1)) From DOSSUB
Local File =GDOSREF+".ABLOB"        [ABB] , =GDOSREF+".AOBJTXT"        [AOX]
Local File =[F:ADS]DOSSIER+".ABLOB" [DABB], =[F:ADS]DOSSIER+".AOBJTXT" [DAOX]
Trbegin [ABB] , [AOX]
 For [ABB] Where CODBLB="PJ_ADS" & IDENT1=GDOSREF
  Read [DABB]ABB0=[F:ABB]CODBLB;[F:ADS]DOSSIER;[F:ABB]IDENT2;[F:ABB]IDENT3
  If fstat
   [F:DABB] = [F:ABB]
   [F:DABB]IDENT1 = [F:ADS]DOSSIER
   If dim([F:DABB]CRETIM)>0 : [F:DABB]CRETIM = time : Endif
   [F:DABB]CREDAT = date$
   [F:DABB]CREUSR = GUSER
   Write [DABB]
   If fstat : Call ERREUR("ABLOB",1) From DOSDIC : Endif
  Endif
 Next ABB
 For [AOX] Where ABREV="ADS" & IDENT1=GDOSREF
  Read [DAOX]AOX0=[F:AOX]ABREV;[F:ADS]DOSSIER;[F:AOX]IDENT2;[F:AOX]IDENT3
  If fstat
   [F:DAOX] = [F:AOX]
   [F:DAOX]IDENT1 = [F:ADS]DOSSIER
   Write [DAOX]
   If fstat : Call ERREUR("AOBJTXT",1) From DOSDIC : Endif
  Endif
 Next AOX
Commit
Close Local File [ABB] , [DABB] , [AOX] , [DAOX]
End

##################################################
## Init du nb d'axes analytiques
##################################################
Subprog AXANA
Local File =[F:ADS]DOSSIER+".AMENLOC" [AML]
Local File =[F:ADS]DOSSIER+".ACTIV"   [ACV]
Local File =[F:ADS]DOSSIER+".APLSTD"  [AST]
Local Integer NBAXE , I , J
Read [ACV]CODACT = "ANA"
If !fstat
 # Init du nombre d'axes analytiques
 Call ECR_TIME(mess(116,125,1)) From DOSSUB
 NBAXE = [F:ACV]DIME
 Trbegin [AML] , [AST]
  # Nb mini et maxi d'axes
  Update [AML] Where MENLOC=601 With MINI=NBAXE , MAXI=NBAXE
  # Effacement du trop plein
  Delete [AST] Where LANCHP=601 & LANNUM>NBAXE
  # Remplissage des manquants
  For I=0 To [F:ADS]NBRLAN-1
   Read [AST]CLE = 601;0;[F:ADS]LAN(I)
   If fstat
    [F:AST]LANCHP = 601
    [F:AST]LANNUM = 0
    [F:AST]LAN    = [F:ADS]LAN(I)
    [F:AST]LANMES = left$("123456789",NBAXE)
    [F:AST]UPDDAT = date$
    If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM = time : Endif
    Write [AST]
   Else
    [F:AST]LANMES = left$("123456789",NBAXE)
    Rewrite [AST]
   Endif
   For J=1 To NBAXE
    Read [AST]CLE = 601;J;[F:ADS]LAN(I)
    If fstat
     [F:AST]LANCHP = 601
     [F:AST]LANNUM = J
     [F:AST]LAN    = [F:ADS]LAN(I)
     [F:AST]LANMES = "#####"
     [F:AST]UPDDAT = date$
     If dim([F:AST]UPDTIM)>0 : [F:AST]UPDTIM = time : Endif
     Write [AST]
    Endif
   Next J
  Next I
 Commit
Endif
End

###############################################################
## Lecture du fichier de connexion
###############################################################
Subprog LEC_CONN(DOSSIER,VOLUME)
Value Char DOSSIER
Value Char VOLUME
Gosub FILCON
Local Integer OK
OK = 0
If filinfo(FILCON,0)>=0
 Openi FILCON Using [IN]
 Iomode adxifs "#" Using [IN]
 Iomode adxirs chr$(13)+chr$(10) Using [IN]
 Iomode adxium GUTF8 Using [IN]
 fstat = 0
 Gosub LEC_CHAMP
 While fstat=0
  If CHAMP(1)=DOSSIER : OK = 1 : Break : Endif
 Gosub LEC_CHAMP
 Wend
 Openi Using [IN]
 If !OK
  Openi FILCON Using [IN]
  Iomode adxifs "#" Using [IN]
  Iomode adxirs chr$(13)+chr$(10) Using [IN]
  Iomode adxium GUTF8 Using [IN]
  fstat = 0
  OK = 0
  Gosub LEC_CHAMP
  While fstat=0
   If CHAMP(1)=GDOSX3 : OK = 1 : Break : Endif
   Gosub LEC_CHAMP
  Wend
  Openi Using [IN]
 Endif
Endif
If OK
 [M:ADS9]CSERVEUR = CHAMP(2)
 [M:ADS9]CPORT    = val(CHAMP(3))
 [M:ADS9]CPATH    = CHAMP(4)
 [M:ADS9]CSERVTRT = CHAMP(18)
Endif
# On renseigne ce que l'on peut
[M:ADS9]CDOSSIER = DOSSIER
[M:ADS9]CPATH    = filpath("","","",DOSSIER,VOLUME,adxmac(0))
If filinfo(filpath("","","","X3_PUB",VOLUME),0)>0
 [M:ADS9]CPUB     = filpath("","","","X3_PUB",VOLUME)
Else
 [M:ADS9]CPUB     = filpath("","","","X3_PUB")
Endif
If [M:ADS9]CSERVEUR=""
 [M:ADS9]CSERVEUR = adxmac(-1)
Endif
If [M:ADS9]CPORT=0
 [M:ADS9]CPORT   = adxtcp
Endif
If [M:ADS9]CSERVTRT=""
 [M:ADS9]CSERVTRT = adxmac(-1)
Endif
# ...
End

##################################
Subprog ECR_CONN(DOSSIER)
Value Char DOSSIER
Gosub FILCON
Openo FILTMP , 0 Using [OUT]
Iomode adxifs "#" Using [OUT]
Iomode adxirs chr$(13)+chr$(10) Using [OUT]
Iomode adxium GUTF8 Using [OUT]
If filinfo(FILCON,0)>=0
 Openi FILCON Using [IN]
 Iomode adxifs "#" Using [IN]
 Iomode adxirs chr$(13)+chr$(10) Using [IN]
 Iomode adxium GUTF8 Using [IN]
 fstat = 0
 Gosub LEC_CHAMP
 While fstat = 0
  If CHAMP(1)<>DOSSIER
   Gosub ECR_CHAMP
  Endif
  Gosub LEC_CHAMP
 Wend
 Openi Using [IN]
Endif
CHAMP(1)  = [M:ADS9]CDOSSIER
CHAMP(2)  = [M:ADS9]CSERVEUR
CHAMP(3)  = num$([M:ADS9]CPORT)
CHAMP(4)  = [M:ADS9]CPATH
CHAMP(18) = [M:ADS9]CSERVTRT
Gosub ECR_CHAMP
Openo Using [OUT]
Call MOVE(FILTMP,FILCON,STAT) From ORDSYS
If filinfo(FILOLD,0)>0
 Call EFFACE(FILOLD,STAT) From ORDSYS
Endif
End

#####################
$ECR_CHAMP
For I=1 To NBCHAMP
 Wrseq CHAMP(I), Using [OUT]
Next I
Wrseq Using [OUT]
Return

#####################
$LEC_CHAMP
For I=1 To NBCHAMP
 Rdseq CHAMP(I) Using [IN]
 If fstat : Break : Endif
Next I
Rdseq BIDON Using [IN]
Return

#####################
$FILCON
Local Char    FILCON(250) , FILTMP(250) , FILOLD(250) , BIDON(250)
Local Integer NBCHAMP , STAT
NBCHAMP = 28
Local Char    CHAMP(250)(1..NBCHAMP)
FILCON = filpath("","ADXAPPLI","Ux3a",GDOSX3)
FILTMP = filpath("","ADXAPPLI","tmp",GDOSX3)
FILOLD = filpath("","X3APPLI","ini",GDOSX3) : # Fichier version 130
Return

####################################################################
## Création d'un fichier des paramètres de l'appli
####################################################################
Subprog CREPAR
# Est-ce que le dossier existe
If filinfo(filpath("","","",[F:ADS]DOSSIER,[F:ADS]VOLUME),0)<0 : End : Endif
Local Char FICPAR(GDIMFIC)
FICPAR = filpath("","PARAM","ini",[F:ADS]DOSSIER,[F:ADS]VOLUME)
Openo FICPAR, 0 Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium GUTF8 Using [P]
Call ECRIT("ADS")
For [ADD]ADD0 Where DOSSIER=[F:ADS]DOSSIER
 Call ECRIT("ADD")
Next ADD
For [ADA]ADA0 Where DOSSIER=[F:ADS]DOSSIER
 Call ECRIT("ADA")
Next ADA
For [ADE]ADE0 Where DOSSIER=[F:ADS]DOSSIER
 Call ECRIT("ADE")
Next ADE
If clalev([F:ADK])>0
 For [ADK]ADK0 Where DOSSIER=[F:ADS]DOSSIER
  Call ECRIT("ADK")
 Next ADK
Endif
Openo Using [P]
End

#####################
Subprog ECRIT(CLASSE)
Value Char CLASSE
Local Integer I , J , NBVAR , DIME , TYP
Local Char    VARIA(GLONAVA)
Wrseq "#"+CLASSE Using [P]
NBVAR = evalue("clanbs([F:"+CLASSE+"],1)")
For I=1 To NBVAR
 VARIA = evalue("clavar([F:"+CLASSE+"],"+num$(I)+")")
 If left$(VARIA,1)<>"~"
  DIME  = evalue("dim([F:"+CLASSE+"]"+VARIA+")")
  TYP   = evalue("type([F:"+CLASSE+"]"+VARIA+")")
  For J=1 To DIME
   Wrseq VARIA Using [P]
   Wrseq J Using [P]
   Case TYP
    When 3
     Wrseq format$("D:YYYYMMDD",evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")")) Using [P]
    When Default
     Wrseq evalue("[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")") Using [P]
   Endcase
  Next J
 Endif
Next I
Wrseq "#" Using [P]
End

#####################
$ERREUR
GERREUR = errn
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)+"\"+errmes$(GERREUR)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GERREUR , GMESSAGE
Resume

####################################################################
## Copie des mémos globaux
####################################################################
Subprog MEMOS
If GCRE
 # Copie des mémos globaux
 Call ECR_TIME(mess(122,133,1)) From DOSSUB
 If GINFO
  Call AFF_VLC(mess(33,125,1),mess(122,133,1)) From GESECRAN
 Endif
 Local File =[F:ADS]DOSSIER+".AOBJSEL" [DAOS] , =[F:ADS]DOSREF+".AOBJSEL" [RAOS]
 Local Integer NBMEM , STAT , I , K , L
 Local Char    MEMO(50)(1..5000)
 Call SYSTEME2(adxmac(0),"lsadx -a"-[F:ADS]DOSREF-"ETM glo","",NBMEM,MEMO) From ORDSYS
 For I=1 To NBMEM
  Call COPIE(filpath("ETM",MEMO(I),"glo",[F:ADS]DOSREF),filpath("ETM",MEMO(I),"glo",[F:ADS]DOSSIER),STAT) From ORDSYS
  K = instr(1,MEMO(I),"_")
  L = instr(K+1,MEMO(I),"_")
  If K & L
   Trbegin [DAOS]
    Read [RAOS]AOS0 = seg$(MEMO(I),K+1,L-1);right$(MEMO(I),L+1);2;left$(MEMO(I),K-1)
    If !fstat
     [F:DAOS] = [F:RAOS]
     Write [DAOS]
     If fstat : Call ERREUR("AOBJSEL",1) From DOSDIC : Endif
    Endif
   Commit
  Endif
 Next I
Endif
End

####################################################################
## Copie des images contenues dans le répertoire X3_PUB/folder/RES
####################################################################
Subprog ICONES(DOSREF,DOSDES)
Value Char    DOSREF , DOSDES
Local Char    REPWEB(250) , EXT(10)(1..4) , IMAGES(50)(1..100) , ICONE(50) , SEP(1)
Local Char    REPORG(250) , REPDES(250)
Local Integer I , J , K , NBE , NBRIMG , STAT , NBTOT
# Copie des images
Call ECR_TIME(mess(285,125,1)) From DOSSUB
If GINFO
 # Initialisations diverses
 Call AFF_VLC(mess(33,125,1),mess(285,125,1)) From GESECRAN
Endif
NBE = 1  : EXT(NBE) = "gif"
NBE += 1 : EXT(NBE) = "bmp"
REPWEB = filpath("","","",[L]DOSREF)
SEP =  "/"
K = instr(1,REPWEB,SEP)
If !K
 SEP = "\"
Endif
REPWEB = left$(REPWEB,len(REPWEB)-len([L]DOSREF))+"X3_PUB"+SEP
For J=1 To NBE
 Call SYSTEME2(adxmac(0),"lsadx -a"-[L]DOSREF-REPWEB+[L]DOSREF+SEP+"RES"-EXT(J),"",NBRIMG,IMAGES) From ORDSYS
 NBRMIG = min(NBRIMG,dim(IMAGES))
 For I=1 To NBRIMG
  ICONE = IMAGES(I)+string$(EXT(J)<>"","."+EXT(J))
  REPDES = REPWEB+[L]DOSDES+SEP+"RES"
  REPORG = REPWEB+[L]DOSREF+SEP+"RES"
  If filinfo(REPORG+SEP+ICONE,0)>0 & filinfo(REPDES,0)>0
   Call COPIE(REPORG+SEP+ICONE,REPDES+SEP+ICONE,STAT) From ORDSYS
   NBTOT += 1
  Endif
 Next I
Next J
Call ECR_TRACE(num$(NBTOT)-mess(74,141,1),0) From GESECRAN : # fichiers copiés
End

