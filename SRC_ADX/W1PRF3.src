#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PRF3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:05"
A_USER  = "DOC"
A_STAMP = "20181109230605"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "TBL2"
  If [M]TBL2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PRF3 [PRF3]
Gosub HORODAT
Local Inpbox "PRF3" From GFONCTION At A_STAMP With A_WINDPREV Mask [PRF3] As [SIM_]
Grizo [PRF3]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PRF3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=24
Return

$ON_TBL2
Onevent BEFORE_INPUT Call AS_TBL2 From W1PRF3
Return

Subprog AS_TBL2
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(13751,GBOUT1) From OBJDIV
Call TEXTE(47762,GBOUT2) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TBL2 From W1PRF3
Onkey 130 Titled GBOUT2 Call B2_TBL2 From W1PRF3
Gosub _AFF
End

Subprog B1_TBL2
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B1_TBL2 From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_TBL2
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B2_TBL2 From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CODVRA
Onevent CONTROL Call C_CODVRA(zc) From W1PRF3
Onevent BEFORE_INPUT Call AS_CODVRA(zc) From W1PRF3
Onevent AFTER_CHANGE Gosub AMM_CODVRA From W1PRF3
Return

Subprog AS_CODVRA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(124,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODVRA(zc) From W1PRF3
Onkey   2 Titled GBOUTS Call S_CODVRA(zc) From W1PRF3
Onkey 144 Titled GBOUTP Call P_CODVRA(zc) From W1PRF3
Onkey 146 Titled GBOUTA Call SA_CODVRA(zc) From W1PRF3
Gosub _AFF
End

Subprog C_CODVRA(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTVRA
 Call CONTVRA(VALEUR) From SUBVRA
 If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action STD
   Call C_CODVRA(VALEUR) From SUBPRF
   If mkstat : GERR = 1 : GZONE = "CODVRA" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CODVRA
Call AM_CODVRA(zc)
If !mkstat & GOBJET
 zoncou = "CODVRA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODVRA(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODVRA)")>indice
 [M]CODVRA(indice) = VALEUR
 Affzo ZCODVRA(indice)
Endif
Gosub _AFF
End

Subprog S_CODVRA(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "VRA"
PARMSK(2) = "S"
PARMSK(3) = num$(GCURLEG)
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CODVRA(VALEUR)
Variable Char    VALEUR()
Call OBJET("VRA",VALEUR,num$(GCURLEG)) From GOBJET
Gosub _AFF
End

Subprog SA_CODVRA(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "VRA"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODVRA(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("VRA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODVRA
Onevent BEFORE_AREA Gosub AV_ZCODVRA From W1PRF3
Return

$AV_ZCODVRA
Call LECTEXTRA(zc,"VARIA","DES",num$(GCURLEG),num$([M]CODVRA(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_ENAFLG3
Onevent INIT_AREA Call D_ENAFLG3(zc) From W1PRF3
Onevent BEFORE_INPUT Call AS_ENAFLG3(zc) From W1PRF3
Return

Subprog D_ENAFLG3(VALEUR)
Variable Integer VALEUR
If varinit([M]ENAFLG3,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ENAFLG3(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47557,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ENAFLG3(zc) From W1PRF3
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog B1_ENAFLG3(VALEUR)
Variable Integer VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_ENAFLG3(VALEUR) From SUBPRF
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


