#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("FAE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS" : Gosub LIENS
 When Default
Endcase
Return

$LIENS
Call AM_TYPEXP([M]TYPEXP)
Return

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End
