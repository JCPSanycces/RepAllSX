########################################
Subprog C_NBLIG
# pour bug moteur
If [M:MBI]NBLIG > 0
  If [M:MBI]ITMREF([M:MBI]NBLIG-1) = ""
    status=65 : nolign=[M:MBI]NBLIG
    Dela [M:MBI]NBLIG-1,1,[M:MBI]NBLIG-1 [M:MBI]NBLIG : [M:MBI]NBLIG-=1
  Endif
Endif
GMODIF = 2
NOL = nolign-1
#En ajout de ligne récupération d'un numéro unique
If status=73 | status=82
    If dim([M:MBI]PRODTYP)<[M:MBI]NBLIG+2
          GMESSAGE=mess(122,199,1)
          mkstat=2
    Endif
    [M:MBI]WLINUM(NOL) = GMFILIN
    GMFILIN += 1
Elsif    status=65             : # Annulation simple
      NOL=nolign-1 : Gosub ANNU_LIG
Elsif status=68 | status=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub ANNU_LIG
          If mkstat : Break : Endif
      Next NOL
Endif
End

#######################################
$ANNU_LIG
Call STKCTRNBLIG("MBI",[M:MBI]FCY) From STKENT
Return

########################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
#On ne peut pas saisir une date > date du jour
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
End

########################################
Subprog AS_PRODTYP(VALEUR)
Variable Integer VALEUR
If [F:BTS]OFFLG = 1  : GMENLOC(1) = 1 : Endif
If [F:BTS]BOMFLG = 1 : GMENLOC(2) = 1 : Endif
If GMENLOC(1) = 1 : VALEUR = 2 : mkstat = 2 : End : Endif
If GMENLOC(2) = 1 : VALEUR = 1 : mkstat = 2 : End : Endif
GMENLOC(3) = 1
GMENLOC(4) = 1
End

########################################
Subprog AM_PRODTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
# Issue 75664 - 2011-09-02 by CCC : la ligne a déjà été pré-chargée en import => il ne faut rien supprimer
If !GIMPORT
  Raz [M:MBI]MFGNUM(NOL),[M:MBI]ITMREF(NOL),[M:MBI]BOMALT(NOL),[M:MBI]UOMCPLQTY(NOL),
&     [M:MBI]STU(NOL),[M:MBI]CPLQTY(NOL),[M:MBI]WINDIC(NOL),[M:MBI]CLEFLG(NOL),
&     [M:MBI]MFIITMREF(NOL)
Endif
End

########################################
Subprog AS_MFGNUM(VALEUR)
Variable Char    VALEUR()
# FQ 61131 GA 01/2010 pas de maj de MFGNUM si l'article lancé a déjà été choisi
If [M:MBI]MFGNUM(nolign-1)<>"" & [M:MBI]ITMREF(nolign-1)<>""
   mkstat=2
Endif

End

########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
# ADC
If !GVTMOD
    # 09.05 import
    If [M:MBI]PRODTYP(nolign-1) = 2 : End : Endif
    Read [F:MFG]MFG0 = VALEUR
    If fstat : GMESSAGE = mess(23,100,1)
        mkstat = 1
        End
    Endif
    If [F:MFG]MFGFCY <> [M:MBI]FCY
        GMESSAGE = mess(23,100,1)
        mkstat = 1
        End
    Endif
Endif
#L'OF doit être complet
If [F:MFG]TYPMOD = 1    : GMESSAGE = mess(51,190,1) : mkstat = 1 : End : Endif
#L'OF doit être ferme
If [F:MFG]MFGSTA <> 1   : GMESSAGE = mess(19,190,1) : mkstat = 1 : End : Endif
#L'OF ne doit pas être suspendu
If [F:MFG]SUSFLG = 2    : GMESSAGE = mess(180,190,1) : mkstat = 1 : End : Endif
#Selon paramètre général l'OF doit être alloué complètement
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
     GMESSAGE = mess(18,190,1)
     mkstat = 1
     End
Endif
#Selon paramètre général, l'OF doit être édité
If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 : End : Endif
mkstat = 0
# boucle d'analyse des matières bloquantes si rupture
For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                        # 10.02 Performances
    If [F:MFM]SHTQTY <> 0
       Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
       If !fstat & [F:ITF]MFGSHTCOD = 1
          GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
          mkstat = 1
          Break
       Endif
    Endif
Next
If mkstat = 1 : End : Endif
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()
If [M:MBI]PRODTYP(nolign-1) = 2 : End : Endif
# 09.06 demande 37629
#[M:MBI]LOT(nolign-1) = ""            # 03.05 29377
If dim([M:MBI]LOT) > 0 : [M:MBI]LOT(nolign-1) = "" : Endif
# FQ 61131 GA 01/2010 idem FUNBENCHI, FUNBENCHM et FUNBENCHO
Read [F:MFG]MFG0 = VALEUR
If fstat : Raz [F:MFG] : Endif
If [F:MFG]ITMLINNBR = 1 & [M:MBI]ITMREF(nolign-1)=""
    Filter [F:MFI] Where MFGNUM = VALEUR
    Read [F:MFI]MFI0 First
    Filter [F:MFI]
    If !fstat
       # GH 28/06/2016 bug 116885 - don't load a line with a not usable product
       If [F:ITM]ITMREF <> [F:MFI]ITMREF
          Read [F:ITM]ITM0 = [F:MFI]ITMREF
          If fstat : GMESSAGE = [F:MFI]ITMREF-":"-mess(212,199,1) : mkstat = 2 : End : Endif
       Endif
       If [F:ITM]ITMSTA=6
          GMESSAGE=[F:MFI]ITMREF-":"-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")" : mkstat=2 : End
       Endif
       [M:MBI]ITMREF(nolign-1) = [F:MFI]ITMREF
       [M:MBI]BOMALT(nolign-1) = [F:MFI]BOMALT
       [M:MBI]MFGLIN(nolign-1) = [F:MFI]MFGLIN
       Gosub CHARG_MFI

       #--- Contrôle date entrée par rapport aux dates mouvements en attente
       Local Date    LDATRUP
       Local Decimal LQTYRUP
       Call CTLRUP([M:MBI]FCY,[M:MBI]ITMREF(nolign-1),[M:MBI]IPTDAT(nolign-1),
&                   1,LDATRUP,LQTYRUP) From STKLIB
       #---
    Endif
Else
    # Issue 79597 - 2012-02-08 by CCC
    Raz [M:MBI]MFGLIN(nolign-1)
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()

# Issue 79597 - 2012-02-08 by CCC
If VALEUR<>[M:MBI]ITMREF(nolign-1)
    Raz [M:MBI]MFGLIN(nolign-1)
Endif

Case [M:MBI]PRODTYP(nolign-1)
    When 1 :
        If [M:MBI]MFGLIN(nolign-1) <> 0
           Read [F:MFI]MFI0 = [M:MBI]MFGNUM(nolign-1);[M:MBI]MFGLIN(nolign-1)
            If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [F:MFI] : End : Endif
            If  [F:MFI]ITMSTA = 4 : GMESSAGE = mess(83,193,1) : mkstat = 1 :  Filter [F:MFI]: End : Endif
        Else
            Filter [F:MFI] Where MFGNUM = [M:MBI]MFGNUM(nolign-1) & ITMREF = VALEUR
            Read [F:MFI]MFI0 First
            If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Filter [F:MFI] : End : Endif
            If  [F:MFI]ITMSTA = 4 : GMESSAGE = mess(83,193,1) : mkstat = 1 :  Filter [F:MFI]: End : Endif
        Endif
    When 2 :
        # 05.02 Gestion des sous-produits demande 9469
        If [M:MBI]ITMTYP(nolign-1) <> 2
            Filter [F:BOH] Where ITMREF = VALEUR & BOMALTTYP = 2
            Read [F:BOH]BOH0 First
            If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Endif
        Endif
Endcase
Filter [F:MFI]
Filter [F:BOH]
If mkstat = 1 : End : Endif

If [F:ITM]ITMREF <> VALEUR
   Read [F:ITM]ITM0 = VALEUR
   If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
Endif
# GH 28/06/2016 bug 116885 - don't load a line with a not usable product
If [F:ITM]ITMSTA=6
    GMESSAGE=VALEUR-":"-mess(3,196,1)-"("+mess([F:ITM]ITMSTA,246,1)+")"
    mkstat=1 : End
Endif

If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:MBI]FCY
   Read [F:ITF]ITF0 = VALEUR;[M:MBI]FCY
   If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
Endif

# Issue 107513/8 - 2015-08-18 by JUSYN : BOM that relates to a versioned product is not allowed to be tracked
If func ECCLIB.NBRCPN(VALEUR) > 0
    If [M:MBI]PRODTYP(nolign-1) = 2
            # Product versioned
                GMESSAGE = mess(327,193,1)
                # "BOM relates to a versioned product"
                mkstat = 1
    Endif
Endif

If [M:MBI]WINDIC(nolign-1) <> 1 & [M:MBI]UOMCPLQTY(nolign-1)=0
   # GH 28/07/2016 bug 115804 - not reset QUAFLG when its value was already changed via INIZONENT
   # GH 05/09/13 bug 91383
   [M:MBI]QUAFLG(nolign-1) = [F:ITF]QUAFLG                           # hcb V6CQ
Endif

# Issue 91969 GA 08/2013
Local Integer WRET
Call LECSRU([F:MFI]MFGFCY,[F:ITM]TCLCOD,5,[M:MBI]TRSCOD,"",WRET) From STKLIB
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If [M:MBI]PRODTYP(nolign-1) = 1 : Gosub CHARG_MFI
                If !GIMPORT
                    [M:MBI]ITMREF(nolign-1) = VALEUR
                    Call AV_ITMREF([M:MBI]ITMREF(nolign-1))
                    Affzo [M:MBI]ITMREF(nolign-1)
                Endif

  #--- Contrôle date entrée par rapport aux dates mouvements en attente
  Local Date    LDATRUP
  Local Decimal LQTYRUP
  Call CTLRUP([M:MBI]FCY,VALEUR,[M:MBI]IPTDAT(nolign-1),1,
&             LDATRUP,LQTYRUP) From STKLIB
  #---

Endif
End

########################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
# 05.02 Gestion des sous-produits demande 9469
If VALEUR <> 0 & [M:MBI]ITMTYP(nolign-1) <> 2
    Read [F:BOH]BOH0 = [M:MBI]ITMREF(nolign-1);VALEUR;2
    If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
    # 22157
    If [F:BOH]USESTA <> 2 : GMESSAGE = mess(51,193,1) : mkstat = 1 : End : Endif
Endif
End

########################################
Subprog AP_BOMALT(VALEUR)
Variable Decimal VALEUR
# 05.02 gestion des sous-produits demande 9469
If VALEUR <> 0 & [M:MBI]ITMTYP(nolign-1) <> 2
                Gosub CHARG_BOH
                If !GIMPORT Affzo [M:MBI]ITMREF(nolign-1) : Endif
                End
Endif
End

########################################
Subprog C_CRIT2(VALEUR)
Variable Integer VALEUR
If VALEUR = [M]CRIT1 : GMESSAGE = mess(144,193,1) : mkstat = 1 : End : Endif
End


########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M:MBI]WSTOFLG(nolign-1) <> 1 & VALEUR <> ""
   pcolor = GCOUL(1)
Else
   pcolor = GCOUL(0)
Endif
End

########################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
Local Char LUSCAV(5)
Local Char LFMT(GLONARP)
Local Integer LMODIF

Call CTLUOM ([M:MBI]ITMREF(nolign-1),3,"", VALEUR,[M:MBI]UOMSTUCOE(nolign-1), LUSCAV, LFMT, LMODIF) From STKACT
If LUSCAV <> "S"
   If LUSCAV <> "C"
      mkstat = 2
      End
    Endif
Endif

If LMODIF=2
   Actzo [M:MBI]UOMSTUCOE(nolign-1)
    Endif

If [M:MBI]UOMSTUCOE(nolign-1) = 0 : [M:MBI]UOMSTUCOE(nolign-1) = 1 : Endif
If [M:MBI]CPLQTY(nolign-1) <> 0
    [M:MBI]UOMCPLQTY(nolign-1) = ([M:MBI]CPLQTY(nolign-1)  / [M:MBI]UOMSTUCOE(nolign-1))
    Call QTEARR([M:MBI]UOMCPLQTY(nolign-1),[M:MBI]UOM(nolign-1)) From TRTDIV
Endif

If [M:MBI]UOMCPLQTY(nolign-1) <> 0
    [M:MBI]CPLQTY(nolign-1) = ([M:MBI]UOMCPLQTY(nolign-1)  * [M:MBI]UOMSTUCOE(nolign-1))
    Call QTEARR([M:MBI]CPLQTY(nolign-1),[M:MBI]STU(nolign-1)) From TRTDIV
Endif

Affzo [MBI]CPLQTY(nolign-1)
Affzo [MBI]UOMSTUCOE(nolign-1)
Affzo [MBI]UOMCPLQTY(nolign-1) : # GH 08/12/14 bug 98683
End

########################################
Subprog AM_UOMCPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer WRETOUR, WNOL
Local Integer LLIN : LLIN = [M:MBI]WLINUM(nolign-1)

# Issue 87766 - 2013-02-21 by CCC
If VALEUR<>0 & [M:MBI]WLOCSEQ(nolign-1) = 0
    Call STKWLOCSEQ("MBI", nolign-1, WRETOUR) From STKECR
    If WRETOUR=1
        mkstat=2
        End
    Endif
Endif

# Issue 94351 suite 87766 GA 11/2013 1ère saisie d'une qté
If [M:MBI]WINDIC(nolign-1) <> 1 & VALEUR<>0 & [M:MBI]UOMCPLQTY(nolign-1)=0
    Call INIZONENT([M:MBI]ITMREF(nolign-1),"MBI",[M:MBI]FCY,"",0,"U",nolign-1,5,[M:MBI]TRSCOD,[M:MBI]MFGNUM(nolign-1),3,1) From STKECR
    # Issue 102629 : [M:MBI]LOT is deleted in INIZONENT
    If dim([M:MBI]MFILOT) > 0
        [M:MBI]LOT(nolign-1) = [M:MBI]MFILOT(nolign-1) : Affzo [MBI]LOT(nolign-1)
    Endif
    # Issue 49288 - 2017-08-23 by GH : Read versions again because of deletion in INIZONENT
    If dim([M:MBI]ECCVALMAJ(nolign-1))>0
        If [F:MFI]MFGNUM <> [M:MBI]MFGNUM(nolign-1) | [F:MFI]MFGLIN <> [M:MBI]MFGLIN(nolign-1)
            Read [F:MFI]MFI0 = [M:MBI]MFGNUM(nolign-1);[M:MBI]MFGLIN(nolign-1)
        Endif
        [M:MBI]ECCVALMAJ(nolign-1) = [F:MFI]ECCVALMAJ : Affzo [MBI]ECCVALMAJ(nolign-1)
        [M:MBI]ECCVALMIN(nolign-1) = [F:MFI]ECCVALMIN : Affzo [MBI]ECCVALMIN(nolign-1)
    Endif
    If [M:MBI]WSTOSEQ(nolign-1)=0
        # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
        If dim([M:MBI]SLO) > 0 & [M:MBI]LOT(nolign-1)<>""
           Raz [M:MBI]SLO(nolign-1)
           Call STKAMLOT([M:MBI]LOT(nolign-1),"MBI",nolign-1,[M:MBI]ITMREF(nolign-1),"SLO") From STKACT
        Endif
        Call STJSTOENTW("MBI",5,15,[M:MBI]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRETOUR) From STKENT
    Endif
Elsif VALEUR<>0 & [M:MBI]UOMCPLQTY(nolign-1)=0 & [M:MBI]WSTOSEQ(nolign-1)=0
    # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
    If dim([M:MBI]SLO) > 0 & [M:MBI]LOT(nolign-1)<>""
       Raz [M:MBI]SLO(nolign-1)
       Call STKAMLOT([M:MBI]LOT(nolign-1),"MBI",nolign-1,[M:MBI]ITMREF(nolign-1),"SLO") From STKACT
    Endif
Endif

#--- Contrôle si la quantité UC génère une qté US arrondie
Local Integer LRET
If [M:MBI]UOM(nolign-1)<>[M:MBI]STU(nolign-1)
   Call STKCTRCOE(VALEUR,[M:MBI]UOMSTUCOE(nolign-1),[M:MBI]STU(nolign-1),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:MBI]UOMCPLQTY(nolign-1) = VALEUR
[M:MBI]CPLQTY(nolign-1)= VALEUR * [M:MBI]UOMSTUCOE(nolign-1)
Call QTEARR([M:MBI]CPLQTY(nolign-1),[M:MBI]STU(nolign-1)) From TRTDIV

If [M:MBI]PRODTYP(nolign-1) = 1
   # Issue 64789 - 2010-06-10 by CCC
   #If  VALEUR < [M:MBI]WQTY(nolign-1)
   If  [M:MBI]CPLQTY(nolign-1) < [M:MBI]WQTY(nolign-1)
                [M:MBI]CLEFLG(nolign-1) = 1
   Else         [M:MBI]CLEFLG(nolign-1) = 2
   Endif
Endif
Affzo [M:MBI]CPLQTY(nolign-1)
End

########################################
Subprog AV_IPTDAT(VALEUR)
Variable Date    VALEUR
If [M:MBI]WMATOK(nolign-1) = 2
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif
End


########################################
Subprog AS_WCDED(VALEUR)
Variable Char    VALEUR()
If [M]WITMREFF <> "" & [M]WMFGNUMF = "" : Raz VALEUR : mkstat = 2 : End: Endif
[M]ORDFILTER = "1=1"
If [M]WITMREFD   <> "" : [M]ORDFILTER += "&ITMREF>=[M]WITMREFD" : Endif
If [M]WITMREFF   <> "" : [M]ORDFILTER += "&ITMREF<=[M]WITMREFF" : Endif
End

########################################
Subprog AM_WCDED(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]WCDEF = VALEUR : Endif
End

########################################
Subprog C_WCDEF(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WCDED : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AS_WPJTD(VALEUR)
Variable Char    VALEUR()
If [M]WITMREFF <> "" & [M]WMFGNUMF = ""  : Raz VALEUR : mkstat = 2 : End: Endif
End

########################################
Subprog AM_WPJTD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]WPJTF = VALEUR : Endif
End

########################################
Subprog C_WPJTF(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]WPJTD : GMESSAGE = mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AS_WCDEF(VALEUR)
Variable Char    VALEUR()
If [M]WITMREFF <> "" & [M]WMFGNUMF = "" : Raz VALEUR : mkstat = 2 : End: Endif
[M]ORDFILTER = "1=1"
If [M]WITMREFD   <> "" : [M]ORDFILTER += "&ITMREF>=[M]WITMREFD" : Endif
If [M]WITMREFF   <> "" : [M]ORDFILTER += "&ITMREF<=[M]WITMREFF" : Endif
End

########################################
Subprog AS_WPJTF(VALEUR)
Variable Char    VALEUR()
If [M]WITMREFF <> "" & [M]WMFGNUMF = "" : Raz VALEUR : mkstat = 2 : End: Endif
End


########################################
Subprog AS_WITMREFD(VALEUR)
Variable Char    VALEUR()
If [M]WNOMENCF <> "" | [M]WBOMALTF <> 0 |  [F:BTS]OFFLG = 1 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_WITMREFF(VALEUR)
Variable Char    VALEUR()
If [M]WNOMENCF <> "" | [M]WBOMALTF <> 0 | [F:BTS]OFFLG = 1 : mkstat = 2 : End : Endif
End

########################################
# 04.02 gestion des sous-produits demande 9469
Subprog APRES_NBLIG
Local Integer NOL,NOL1,WMAX
NOL = nolign-1
NOL1 = nolign
WMAX = dim([M:MBI]PRODTYP) -2
# 09.05
If GIMPORT
   End
Endif
If [M:MBI]PRODTYP(NOL) = 2 & [M:MBI]ITMTYP(NOL) <> 2 & dim([M:MBI]PRODTYP)>=[M:MBI]NBLIG+2 &
&       [M:MBI]ITMREF(NOL1) = ""  & [M:MBI]WINDIC(NOL) = 0
        Call RECHERCHE_SOUS_PRODUIT([M:MBI]ITMREF(NOL),WMAX,[M:MBI]UOMCPLQTY(NOL),NOL1)
        [M:MBI]NBLIG = nolign
        nolign = NOL1
        Affzo [M:MBI]15
Endif
End



########################################
Subprog IB_NBLIG
#GBOUT1 =  "Etat suivi"
#GBOUT2 =  "Détail article"
#GBOUT3 =  "Ordre de fabrication"
#GBOUT4 =  "Nomenclature"
#GBOUT5     =     "Saisie détail quantités"
#GBOUT6     =     "Stock"
#GBOUT7     =     "Consommation matières" selon MATFLG
#GBOUT8     =     "Complément lot"
#GBOUT9     =     "infos lot"

If [M:MBI]ITMREF(nolign-1) <> ""
    #  Bouton saisie détail quantités
    Call STKINIBTN( 5, 0, 9, 8, "MBI", "BTS", [M:MBI]ITMREF(nolign-1) , [M:MBI]FCY) From STKENT
Else
    Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9
    ENT
Endif
#  Bouton détail suivi et bouton détail article , tunnel OF
If [M:MBI]PRODTYP(nolign-1) = 1
    Raz GBOUT4, GBOUT7
    If [F:MFG]MFGNUM <> [M:MBI]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MBI]MFGNUM(nolign-1)
        If fstat : Raz [F:MFG] : Endif
    Endif
    If find([F:BTS]MATFLG,2,4) & find([F:MFG]MFGMOD,1,2)
           GBOUT7 = mess(402,198,1)
    Endif
Elsif [M:MBI]PRODTYP(nolign-1) = 2
     Raz GBOUT1, GBOUT2, GBOUT3, GBOUT7
    If find([F:BTS]MATFLG,2,4)
           GBOUT7 = mess(402,198,1)
    Endif
Endif
# si code activité lot à non, ne pas proposer la consultation des lots
If dim([M:MBI]LOT) < 1 : Raz GBOUT6 : Endif
End

########################################
Subprog B9_NBLIG
Call INFOLOT("MBI", nolign-1) From STKENT
End

########################################
Subprog B8_NBLIG
GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT = 1                         # permet de passer le test de l'ouverture de la fenetre complément lot
End


#########################################
Subprog AM_UOMSTUCOE(VALEUR)
Variable Decimal VALEUR

#--- Contrôle si le coef UC/US génère une qté US arrondie
Local Integer LRET
If [M:MBI]UOM(nolign-1)<>[M:MBI]STU(nolign-1)
   Call STKCTRCOE([M:MBI]UOMCPLQTY(nolign-1),VALEUR,[M:MBI]STU(nolign-1),LRET) From STKACT
   If LRET=0 : mkstat=2 : End : Endif
Endif

[M:MBI]CPLQTY(nolign-1) = [M:MBI]UOMCPLQTY(nolign-1) * VALEUR
Call QTEARR([M:MBI]CPLQTY(nolign-1),[M:MBI]STU(nolign-1)) From TRTDIV
Affzo [M:MBI]CPLQTY(nolign-1)
End



########################################
# LOT
########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
If [F:ITM]LOTMGTCOD=4 & dim([M:MBI]SLO)>0
   Call RECLASTSLO([M:MBI]ITMREF(nolign-1), VALEUR, "", "", [M:MBI]SLO(nolign-1)) From STKLIB
   Affzo [M:MBI]SLO(nolign-1)
Endif
End


########################################
# Lot blanc : Indique qu'il n'y a pas de n° de lot
Subprog B3_LOT(VALEUR)
Variable Char    VALEUR()
VALEUR = ""
[M:MBI]GESLOT(nolign-1) = "B"
End

########################################
# Info lot : Indique si le lot est blanc ou géré par un compteur
Subprog B4_LOT(VALEUR)
Variable Char    VALEUR()
    # Indique si le lot est blanc ou géré par compteur
    # (Un sous pro a été créé car il est appellé à 2 endroits
    # et dans plusieurs écrans: bouton3 NBLIG et bouton4 Lot
    Call INFOLOT("MBI", nolign-1) From STKENT
End

########################################
# NBSLO
########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR
# FQ 55203 pb en import car le varmode ne fonctionne pas, et ce ctrl se déclenche
If [F:ITM]LOTMGTCOD=4 & dim([M:MBI]NBSLO)>0
   Call STKCTRNBSLO(VALEUR, [M:MBI]UOM(nolign-1), [M:MBI]UOMCPLQTY(nolign-1)) From STKACT
Endif
End

########################################
# SLO
########################################
# Calcul le n° de sous lot fin en vérifiant, si nécessaire, l'existence des sous lots.
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local Char WBPSLOT(GLONLOT)

If VALEUR<>""
    Call STKCTRSLO(VALEUR, [M:MBI]NBSLO(nolign-1), [M:MBI]LOT(nolign-1),
&                  [M:MBI]ITMREF(nolign-1), WBPSLOT, [M:MBI]GESLOT(nolign-1), "", 0, 0, 0,
&                  [M:MBI]FCY, [M:MBI]SLOF(nolign-1)) From STKACT
    If !mkstat
        Affzo [M:MBI]SLOF(nolign-1)
    Endif
Endif
End

