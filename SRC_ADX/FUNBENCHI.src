## Etiquette ajoutée par le superviseur 23/09/2003 13:44:51 (SR)
##########################################################################
Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()

If [M:MBI]PRODTYP(nolign-1) <> 1 : End : Endif
#---------------------------------------------------------------------------------#
#Si lot retenu à la création de l'OF, alors pas de saisie                         #
#---------------------------------------------------------------------------------#
Read [F:MFI]MFI0 = [M:MBI]MFGNUM(nolign-1);[M:MBI]MFGLIN(nolign-1)
If fstat : Raz [F:MFI] : Endif
If VALEUR <> "" & VALEUR = [F:MFI]LOT : mkstat = 2 : End : Endif
End

