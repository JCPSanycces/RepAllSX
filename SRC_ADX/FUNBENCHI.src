##########################################################################
Subprog AS_SLO(VALEUR)
Variable Char    VALEUR()
End

##########################################################################
## Etiquette ajoutée par le superviseur 22/07/2003 14:08:31 (SR)
##########################################################################
Subprog AVANT_NBLIG
Local Integer NOL : NOL = nolign-1
#insertion
If status=73 | status=82
   Local Integer LRET
   If dim([M:MBI]ITMREF)=nolign
      GMESSAGE=mess(7,184,1) #"Tableau des entrées plein."
      GERR = 1
   Else
      Call STKACTLIG(nolign-1) From STKECR
      Actzo [M]ITMREF(nolign-1),ITMDES1(nolign-1)
      If dim([M]UOM)>0
         Actzo [M]UOM(nolign-1),UOMCPLQTY(nolign-1)
      Endif
      If dim([M]UOMSTUCOE)>0
         Actzo [M]UOMSTUCOE(nolign-1)
      Endif
      If dim([M]MVTDES)>0
         Actzo [M]MVTDES(nolign-1)
      Endif
   Endif
#suppression
Elsif status=65 | status=68 | status=83
   If [M:MBI]CREFLG(NOL)=0
    #----------------------------------------#
    # Suppression des enreg l'écran de stock #
    #----------------------------------------#
        Call DELSTOENTW(NOL,NOL,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
  Endif
Endif


If dim([M:MBI]WRH) > 0
   If [M:MBI]WRH(NOL)=""
      [M:MBI]WRH(NOL)=[M:MBI]WRHE
   Endif
Endif
End

