## Etiquette ajoutée par le superviseur (écran MTKBENCHI) 02/04/2013 14:41:59 (HCB) 89061
######################################################################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
If [M:MBI]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:MBI]LOC(nolign-1),[M:MBI]WLOCSEQ(nolign-1)) From STKACT
Endif
End

