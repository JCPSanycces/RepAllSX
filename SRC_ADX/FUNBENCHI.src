######################################################################################
$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MKIB","",0) From TRTX3CPT
Return


$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date d'imputation
Local Date WDATE : WDATE = [M:MBI]IPTDAT(nolign-1)
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return




######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHI) 13/10/2009 11:43:53 (CCC)
######################################################################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End


######################################################################################
# Actzo ou Grizo des dépôts selon le site
######################################################################################
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]FCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES=2
  If GWRHOBY=2
    If [M:MBI]WRHE<>"" & [M:MBI]NBLIG<>0
      Diszo [M:MBI]WRHE
    Else
      Actzo [M:MBI]WRHE
    Endif
    Diszo [M:MBI]WRH
  Else
    Actzo [M:MBI]WRHE
    Actzo [M:MBI]WRH
  Endif
Else
  Grizo [M:MBI]WRHE
  Grizo [M:MBI]WRH
Endif
Return

########################################
# Dépôt à la ligne
########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:MBI]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:MBI]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:MBI]WRH(nolign-1)<>""
   Raz [M:MBI]LOC(nolign-1)
Endif
End

