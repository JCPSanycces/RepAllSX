#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
# ACTION = SAIBENCHI
##############################################################################
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABA"           : Gosub ABA
    When "FIN"           : Gosub FIN
    When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG

    When "AB3_NBLIG"     : Gosub AB3_NBLIG
    When "AB4_NBLIG"     : Gosub AB4_NBLIG
    When "BB3_NBLIG"     : Gosub LECTURE_BTS
    When "AB7_NBLIG"     : Gosub AB7_NBLIG
    When "BB7_NBLIG"     : Gosub BB7_NBLIG
    When "AP_CHOIX"      : Gosub AP_CHOIX
Endcase
Return


$AAPRES_NBLIG
#-------------------------------------------------#
# Appelé avant l'action SAISTOENT                 #
#-------------------------------------------------#
Local Shortint WRET
Local Char     LSUP(1)
Local Shortint NOL : NOL=nolign-1
If nolign = 0 : Return : Endif
If [M:MBI]UOMCPLQTY(NOL) = 0 : Return : Endif

If [F:ITM]ITMREF<>[M:MBI]ITMREF(NOL)
  Read [ITM]ITM0=[M:MBI]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
If !find(status,65,68,83)
    Diszo [M:MBI]ITMREF(nolign-1)
Endif

Call OUVENT([M:MBI]FCY,"MBI",5,[M:MBI]TRSCOD,"",15,[M:MBI]IPTDAT(NOL),nolign-1,NBLIG,"BTS","",WRET) From STKENT
Return



$AB3_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton Tunnel OF                  #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR)
WOBJET="MFG"
WCLE1 =[M:MBI]MFGNUM(NOL)
Return



$AB4_NBLIG
Local Integer  NBTBO
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR)
#
WCLE1=[M:MBI]ITMREF(nolign-1)
#   sélectionner les alt. de nomenclature compatibles avec site de prod
Filter [TBO] Where ([F:TBO]FCY=[M:MBI]FCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP=2
For [TBO]TBO0
     GBOMALT (NBTBO) = [F:TBO]BOMALT
     NBTBO += 1
Next
#
Filter [TBO]
#  FILTRE sur article parent
Local File BOM [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 2
#
WCLE2 = num$([M:MBI]BOMALT(nolign-1))
GFONBOD="BOMP"
GDATEREF=[M:MBI]IPTDAT(nolign-1)
Return

###########################################################################
$AB7_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton plan de conso              #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Decimal WCOEFF
Local Integer WCONSMAT
Case [M:MBI]PRODTYP(NOL)
    When 1 :
            WCOEFF = ([M:MBI]CPLQTY(NOL) / [M:MBI]MFIEXTQTY(nolign-1))
            # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
            # Ce sont les quantités qui sont arrondies
            #WCOEFF = arr(WCOEFF,0.00000001)
            WCONSMAT = [F:BTS]CONSMAT
    When 2 :
            WCOEFF = [M:MBI]CPLQTY(NOL)
Endcase

Return

$BB7_NBLIG
#colorisation de la date selon ce qui a été fait dans le plans de conso
Call AV_IPTDAT([M:MBI]IPTDAT(nolign-1))
Affzo [M:MBI]IPTDAT(nolign-1)
Gosub LECTURE_BTS
Return

###########################################################################

$INIT
Local Char        LFCY(GLONFCY)   : LFCY   = PARAM(1)
Local Char        LWRH(GLONWRH)   : LWRH   = PARAM(2)
Local Char        LVCR(GLONVCR)   : LVCR   = PARAM(3)
Local Char        LITM(GLONITM)   : LITM   = PARAM(4)
Local Integer     LALT            : LALT   = val(PARAM(5))
Local Char        LORI(5)         : LORI   = PARAM(6)
Local Char        LUSR(GLONAUS)   : LUSR   = PARAM(7)
Local Integer     LRETOK          : LRETOK = val(PARAM(8))
Local Decimal     LCOEFF          : LCOEFF = val(PARAM(9))
Local Integer     OK
Global Char       GMILNUM(GLONTRS)

If LORI = "MBO" & LRETOK = 2
    Call AVERTIR(mess(131,190,1),OK) From GESECRAN
    If OK <> 2 : FIN = 1 : Endif
Endif
Raz GSTATUT
Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du pilotage, on vérifie si un code transaction est passé
If GFONCTION = "FUNBENPLT"
    If [M:MBP]MILTRS <> ""
        Read [BTS]BTS0=62;[M:MBP]MILTRS
        If !fstat & [F:BTS]ENAFLG=2
            GMILNUM = [F:BTS]BTSNUM
            OK = 0
            Return
        Endif
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=62&ENAFLG=2"
# 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=62;GFLAG
    Filter [BTS]
    If !fstat
        If dim(GMILNUM)<=0
            Global Char    GMILNUM(GLONTRS)
        Endif
        GMILNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif

If GMILNUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMILNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=62;GMILNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif
# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:BTS]WRHOBY
Else
  GWRHOBY = 1
Endif

Return

###########################################################################
$OUVRE
#01.10 mm 61503 - Si on vient par tunnel il faut sauvegarder les variables globales
Gosub SAUV_GLOB From TRTX3GLOB
#
Local Integer     RETOUR
Local Integer     WRET
Global Integer    GMFILIN: GMFILIN = 1
Global Decimal    GTOTQTY
Global Shortint   GMFGTRACE         : # affichage d'une trace en gestion
Global Integer    GCONSLCT : GCONSLCT = GCONSULT
Global Char       SAV_GFONC1(20) : SAV_GFONC1 = GFONC1
Local Integer     VALOK
Local Char        LFCY(GLONFCY)   : LFCY   = PARAM(1)
Local Char        LWRH(GLONWRH)   : LWRH   = PARAM(2)
Local Char        LVCR(GLONVCR)   : LVCR   = PARAM(3)
Local Char        LITM(GLONITM)   : LITM   = PARAM(4)
Local Integer     LALT            : LALT   = val(PARAM(5))
Local Char        LORI(5)         : LORI   = PARAM(6)
Local Char        LUSR(GLONAUS)   : LUSR   = PARAM(7)
Local Integer     LRETOK          : LRETOK = val(PARAM(8))
Local Decimal     LCOEFF          : LCOEFF = val(PARAM(9))

Raz GCONSULT
GFONC1 = "FUNBENCHI"
#
If LFCY <> ""
    GFCY = LFCY
Else
    Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Endif

Gosub OUVRE_INIT
Return

###############################################################################
$OUVRE_INIT
Raz GSOC_ACTIVE

If !clalev([M:VALW]) Local Mask STOVALW [VALW] : Endif
If !clalev([M:ENTW]) Local Mask STOENTW [ENTW] : Endif
Raz [M:ENTW]
[M:ENTW]WZONPCU = "UOM"
[M:ENTW]WZONQUC = "UOMCPLQTY"
[M:ENTW]WZONCCS = "UOMSTUCOE"
[M:ENTW]WZONSTU = "STU"
[M:ENTW]WZONQUS = "CPLQTY"
[M:ENTW]WZONSTOUPD = ""


If !clalev([M:STW]) Local Mask STOWORK [STW] : Endif
#Gosub STK_INILOC From STKLOC # cf CHARG_PARAM

If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:ALP])  Local Mask ALLPAR     [ALP]   Endif
If !clalev([M:SOW])  Local Mask STOSORW    [SOW]   Endif
If !clalev([M:MTB3]) Local Mask MTKBCRIT3  [MTB3]  Endif  # 15806 MM 05.05 : gestion memo STD

If GMODU(2)=2 : # Si module compta actif
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif
Endif

Gosub OPEN_FILE
Gosub CHARG_PARAM

Call DELSTOENTW(-1,-1,"MBI",1,1,"",0,"") From STKENT

#
Local Integer TRA : TRA = 0

Gosub LECTURE_BTS
If GVTMOD : Return : Endif
# substitution fenêtre
BOITE     = "WIMBI"+GMILNUM
WMASQUE   = "WT62"+GMILNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY

Gosub CHANGE_AWI From BENCHLIB
GORITITCOL = 1
Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

$ABA
Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
Gosub DEBUT
Return

####################################################################################
$DEBUT
Raz    [M:MBI]
[M:MBI]FCY = GFCY
Gosub WRH_ETAT
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

# CCC (2009-09-23) Bug 57792 : alimenter le code transaction systématiquement
Gosub LECTURE_BTS
[M:MBI]TRSCOD = [F:BTS]TRSCOD

[M:MBI]FILTART  = [F:BTS]FILTDEF
[M:MBI]LORI     = LORI
[M:MBI]COEFF    = LCOEFF
If dim([M:MBI]WRHE) > 0
   [M:MBI]WRHE     = LWRH
   #--- Bug 65493
   If [M:MBI]WRHE=""
      Call WRHINIT2([M:MBI]WRHE,[M:MBI]FCY,2) From STKWRH
   Endif
  #---
Endif
If LORI = "PILOT"
    Gosub CHARG_MASKB
Else
    If LVCR <> "" & [F:BTS]OFFLG = 2
        [M:MBI]WMFGNUMD = LVCR
        [M:MBI]WMFGNUMF = LVCR
        Gosub CHARG_MASK
        Grizo [M:MBI]5,7,10
    Elsif LITM <> "" & [F:BTS]BOMFLG = 2
        [M:MBI]WNOMENCD = LITM
        [M:MBI]WNOMENCF = LITM
        [M:MBI]WBOMALTD = LALT
        [M:MBI]WBOMALTF = LALT
        Gosub CHARG_MASK
        Grizo [M:MBI]5,7,10
    Endif
Endif

Case [F:BTS]CRIT1
     When 1 : [M:MBI]WSRT += 1
     When 2 : [M:MBI]WSRT += 2
     When 3 : [M:MBI]WSRT += 4
Endcase
Case [F:BTS]CRIT2
     When 1 : [M:MBI]WSRT += 8
     When 2 : [M:MBI]WSRT += 16
     When 3 : [M:MBI]WSRT += 32
Endcase

# 15806 MM 05.05 : application memo STD
If LORI =""
    If filinfo(filpath("ETM",GUSER+"_"+GMILNUM+"_"+"STD","mbi",0),0)>=0
        Call LECMEMO("STD","[M:MTB3]",GMILNUM+"~mbi") From GMEMO
        [M:MBI] = [M:MTB3]
        Affzo [M:MBI]10
    Endif
Endif

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables ( sections analytiques)           #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD
  Local Char BASPAG(10)
  If (dim([M:MBI]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT62"+GMILNUM+"1"
      If [M:MBI]NBLIG = 0 : [M:MBI]NBLIG = 1 : Affzo [M:MBI]15 : Effzo [M:MBI]15 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return

#########################################################################
$SETBOUT
# Pour interdire la navigation
GREP="M"

ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = 1                                     # validation
ETABOU(GABAN) = 1
If LORI <> "" : ETABOU(GSPE2) = 0 : Endif # Critères interdit si on vient du plan de suivi des temps
If LORI = "PILOT"
    ETABOU(GSPE1) = 0                                     # recherche
Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MBI]REACT = 2 : Gosub CHARG_MASK : [M:MBI]REACT = 1 : Endif
    When "3"       :     Gosub VALIDATION
Endcase
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return


#######################################################################
$OPEN_FILE
If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif       # pour générer encours
If clalev([M:MTIK])=0 : Local Mask MTIK      [MTIK] : Endif       # masque buffer decl prod
If clalev([M:MTOK])=0 : Local Mask MTOK      [MTOK] : Endif       # masque buffer suivi opé
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([F:BTS])<=0 : Local File BENCHTRS  [BTS]  : Endif
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD])<=0 : Local File BOMD       [BOD] : Endif
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])<=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKM])<=0 : Local File MFGMATTRK  [MKM] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TBO])<=0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:STO])<=0 : Local File STOCK      [STO] : Endif
If clalev([F:STS])<=0 : Local File STOSER     [STS] : Endif  # numéros de série
If clalev([F:STC])<=0 : Local File STOLOC     [STC] : Endif
If clalev([F:STJ])<=0 : Local File STOJOU     [STJ] : Endif
If clalev([F:STL])<=0 : Local File STOLOT     [STL] : Endif
If clalev([F:ORD])<=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 62 | [F:BTS]BTSNUM <> GMILNUM
    Read [BTS]BTS0=62;GMILNUM : If fstat Raz [F:BTS] : Endif
Endif
GFLAG   = [F:BTS]BTSNUM
Return

########################################################################
$CHARG_PARAM
Call GETCPY(GFCY,"BTS",62,GMILNUM) From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

# Issue 94351 GA 11/2013
##----- Variables société
Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
Gosub STK_INILOC From STKLOC
Return

###############################################################
$CHARG_MASK
Local Char CRITERE2(255)
Local Char CRITERE(255)
# 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char CUSFLT(255)
Local Char FORMULE1(255)

CRITERE  = "1=1"
CRITERE2 = "1=1"
Raz FORMULE1

Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT


Local Integer WMAX : WMAX = dim([M:MBI]ITMREF) - 2
Local Decimal LDIS
Local Integer STA
Local Integer OK
# 04.02 gestion des sous-produits demande 9469
Local Integer NOL, NOL1
Local Integer WVERBOM # Issue 107513/8 - 2015-07-13 by JUSYN : Versioning

[M:MBI]TRSCOD = [F:BTS]TRSCOD
Effzo [M:MBI]15

Call STKCTRIPT(date$,[M:MBI]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

GMFILIN = 1
If [F:BTS]OFFLG = 2 & ([M:MBI]WNOMENCF = "" & [M:MBI]WBOMALTF = 0)
   CRITERE += "& MFGFCY = [M:MBI]FCY"
   If [M:MBI]WMFGNUMF <> ""
      CRITERE += "& MFGNUM >= [M:MBI]WMFGNUMD & MFGNUM <= [M:MBI]WMFGNUMF"
   Endif
   If [M:MBI]WITMREFF <> ""
      CRITERE += "& ITMREF >= [M:MBI]WITMREFD & ITMREF <= [M:MBI]WITMREFF"
   Endif
   Case [M:MBI]FILTART
        When 1 : CRITERE -= " & MFITRKFLG <"+num$(5)
        When 2 : CRITERE -= " & MFITRKFLG ="+num$(5)
   Endcase
   #on ne prend pas les articles exclus
   CRITERE -= " & ITMSTA <>"+num$(4)
   If [M:MBI]ENDDATEND <> [0/0/0]
      CRITERE2 += "& ENDDAT >= [M:MBI]ENDDATSTR & ENDDAT <= [M:MBI]ENDDATEND"
   Endif
   If [M:MBI]WCDEF <> ""
      CRITERE2 += "& VCRNUMORI >= [M:MBI]WCDED & VCRNUMORI <= [M:MBI]WCDEF"
   Endif
   If [M:MBI]WPJTF <> ""
      CRITERE2 += "& PJT >= [M:MBI]WPJTD & PJT <= [M:MBI]WPJTF"
   Endif
   # Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
   # 09.01 demande 10405
   Raz CUSFLT
   GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
   If CUSFLT = "" : CUSFLT = "1=1" : Endif
   Gosub ANALYSE_FORMULE
   If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

#
   Filter [F:MFI] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
   nolign = 0
   For [F:MFI]
      If [F:MFG]MFGNUM <> [F:MFI]MFGNUM
          Read [F:MFG]MFG0 = [F:MFI]MFGNUM
          If fstat : Raz [F:MFG] : Endif
      Endif
      #L'OF doit être complet
      If [F:MFG]TYPMOD = 1    : Goto NEXTMFI  : Endif
      #L'OF doit être ferme
      If [F:MFG]MFGSTA <> 1   : Goto NEXTMFI : Endif
      #L'OF ne doit pas être suspendu
      If [F:MFG]SUSFLG = 2    : Goto NEXTMFI : Endif
      #Selon paramètre général l'OF doit être alloué complètement
      If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
         Goto NEXTMFI
      Endif
      #Selon paramètre général, l'OF doit être édité
      If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Goto NEXTMFI : Endif
      mkstat = 0

     # FQ 62819 GA 03/2010 ajout d'un PE avec test GPE idem FUNBENCHM(CUSCTLSUP) et FUNBENCHO
      GPOINT = "CUSSELENR" : GPE=1 : Gosub ENTREE From EXEFNC
      If !GPE  : Goto NEXTMFI  : Endif

     # boucle d'analyse des matières bloquantes si rupture
      For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                    # 10.02 Performances
               If [F:MFM]SHTQTY <> 0
                  Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                  If !fstat & [F:ITF]MFGSHTCOD = 1
                     mkstat = 1
                     Break
                  Endif
               Endif
      Next
      If mkstat = 1 : Goto NEXTMFI : Endif
      If [F:ITM]ITMREF <> [F:MFI]ITMREF
          Read [F:ITM]ITM0 = [F:MFI]ITMREF
          If fstat : Goto NEXTMFI : Endif
      Endif
      If [F:ITM]ITMSTA=6 : Goto NEXTMFI : Endif : # GH 28/06/2016 bug 116885 - don't load a line with a not usable product
      If [F:ITF]ITMREF <> [F:MFI]ITMREF | [F:ITF]STOFCY <> [F:MFI]MFGFCY
           Read [F:ITF]ITF0 = [F:MFI]ITMREF;[F:MFI]MFGFCY
           If fstat : Raz [F:ITF] : Endif
      Endif
      If clalev([F:ITW])
&      & dim([M:MBI]WRHE)>0 & [M:MBI]WRHE<>"" & GWRHOBY=2
&      & ([F:ITW]ITMREF<>[F:ITM]ITMREF | [F:ITW]WRH<>[M:MBI]WRHE)
          Read [F:ITW]ITW0=[F:ITM]ITMREF;[M:MBI]WRHE
          If fstat
              Goto NEXTMFI
          Endif
      Endif
      If nolign+1 > WMAX : Break : Endif
      nolign  += 1
      [M:MBI]PRODTYP(nolign-1) = 1
      [M:MBI]IPTDAT(nolign-1) = date$
      [M:MBI]WLINUM(nolign-1)  = GMFILIN
      [M:MBI]WINDIC(nolign-1) = 1
      Gosub CHARG_MFI
      GMFILIN += 1
   $NEXTMFI
   Next
   [M:MBI]NBLIG = nolign
   Filter [F:MFI]
Elsif [F:BTS]BOMFLG = 2 & ([M:MBI]WNOMENCF <> "" | [M:MBI]WBOMALTF <> 0)
   CRITERE += "& BOMALTTYP =" + num$(2)
   If [M:MBI]WNOMENCF <> ""
       CRITERE += "& ITMREF >= [M:MBI]WNOMENCD & ITMREF <= [M:MBI]WNOMENCF"
   Endif
   If [M:MBI]WBOMALTF <> 0
      CRITERE += "& BOMALT >= [M:MBI]WBOMALTD & BOMALT <= [M:MBI]WBOMALTF"
   Endif
   CRITERE += "& USESTA = "+num$(2)
    # 05.02 demande 14201 + 22157
    CRITERE2 = "(BOHSTRDAT<=date$| BOHSTRDAT=[0/0/0]) & (BOHENDDAT>=date$ | BOHENDDAT=[0/0/0]) & USESTA = 2"
  # Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
  # 09.01 demande 10405
  Raz CUSFLT
  GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
  If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
  Gosub ANALYSE_FORMULE
  If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

   If CRITERE2 <> ""
        Filter [F:BOH] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
   Else
        Filter [F:BOH] Where evalue(CRITERE) & evalue(CUSFLT) & evalue(FORMULE1)
   Endif
   nolign = 0
   WVERBOM = 0  # Issue 107513/8 - 2015-07-13 by JUSYN : Versioning
   For [F:BOH]
      If [F:ITM]ITMREF <> [F:BOH]ITMREF
           Read [F:ITM]ITM0 = [F:BOH]ITMREF
          If fstat : Goto NEXTBOH : Endif
      Endif
      If [F:ITM]ITMSTA=6 : Goto NEXTBOH : Endif : # GH 28/06/2016 bug 116885 - don't load a line with a not usable product
      # Issue 107513/8 - 2015-08-18 by JUSYN : Versioning - no BOM with versioned parent product
      # Product versioned
      If func ECCLIB.NBRCPN([F:BOH]ITMREF) > 0
              WVERBOM += 1
              Goto NEXTBOH
      Endif
      If [F:ITF]ITMREF <> [F:BOH]ITMREF | [F:ITF]STOFCY <> [M:MBI]FCY
           Read [F:ITF]ITF0 = [F:BOH]ITMREF;[M:MBI]FCY
           If fstat : Raz [F:ITF] : Endif
      Endif
      If clalev([F:ITW])
&      & dim([M:MBI]WRHE)>0 & [M:MBI]WRHE<>"" & GWRHOBY=2
&      & ([F:ITW]ITMREF<>[F:ITM]ITMREF | [F:ITW]WRH<>[M:MBI]WRHE)
          Read [F:ITW]ITW0=[F:ITM]ITMREF;[M:MBI]WRHE
          If fstat
              Goto NEXTBOH
          Endif
      Endif
      If nolign+1 > WMAX : Break : Endif
      nolign  += 1
      [M:MBI]PRODTYP(nolign-1) = 2
      [M:MBI]IPTDAT(nolign-1)  = date$
      [M:MBI]ITMTYP(nolign-1)  = 1
      [M:MBI]WLINUM(nolign-1)  = GMFILIN
      [M:MBI]WINDIC(nolign-1)  = 1
      Gosub CHARG_BOH
      GMFILIN += 1
      # 04.02 gestion des sous-produits demande 9469
      NOL  = nolign-1
      NOL1 = nolign

      Call RECHERCHE_SOUS_PRODUIT([M:MBI]ITMREF(NOL),WMAX,[M:MBI]UOMCPLQTY(NOL),NOL1)
      nolign = NOL1
   $NEXTBOH
   Next
   [M:MBI]NBLIG = nolign
   Filter [F:BOH]
Endif
# 08.02 demande 15501 chargement spécifique du masque MBI
GPOINT = "LOAMSKMBI" : Gosub ENTREE From EXEFNC

# Issue 107513/8 - 2015-07-13 by JUSYN : Versioning
# BOM lines from BOMs which parent products are versioned and therefore not displayed
If WVERBOM > 0
    Call MESSAGE(mess(326,193,1)) From GESECRAN
    # "There are BOM lines not displayed because of their versioned parent product!"
Endif

Gosub AFF_TABLEAU
Return

###############################################################
$CHARG_MASKB

Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT

Local Integer WMAX : WMAX = dim([M:MBI]ITMREF) - 2
Local Decimal LDIS
Local Integer STA
Local Integer OK
# 04.02 gestion des sous-produits demande 9469
Local Integer NOL, NOL1, WI

[M:MBI]TRSCOD = [F:BTS]TRSCOD
Effzo [M:MBI]15

Call STKCTRIPT(date$,[M:MBI]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

GMFILIN = 1
nolign = 0
For WI = 0 To [M:MTPK]NBLIG-1
   Read [F:MFG]MFG0 = [M:MTPK]MFGNUM(WI)
   Case [F:BTS]FILTDEF
        When 1 :    Filter [F:MFI] Where MFGNUM = [M:MTPK]MFGNUM(WI) & ITMSTA <>4 & MFITRKFLG <5
        When 2 :    Filter [F:MFI] Where MFGNUM = [M:MTPK]MFGNUM(WI) & ITMSTA <>4 & MFITRKFLG =5
        When 3 :    Filter [F:MFI] Where MFGNUM = [M:MTPK]MFGNUM(WI) & ITMSTA <>4
   Endcase
   For [F:MFI]
     # boucle d'analyse des matières bloquantes si rupture
      For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM
               If [F:MFM]SHTQTY <> 0
                  Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                  If !fstat & [F:ITF]MFGSHTCOD = 1
                     mkstat = 1
                     Break
                  Endif
               Endif
      Next
      If mkstat = 1 : Goto NEXTMF2 : Endif
      If [F:ITM]ITMREF <> [F:MFI]ITMREF
          Read [F:ITM]ITM0 = [F:MFI]ITMREF
          If fstat : Goto NEXTMF2 : Endif
      Endif
      If [F:ITM]ITMSTA=6 : Goto NEXTMF2 : Endif : # GH 28/06/2016 bug 116885 - don't load a line with a not usable product
      If [F:ITF]ITMREF <> [F:MFI]ITMREF | [F:ITF]STOFCY <> [F:MFI]MFGFCY
           Read [F:ITF]ITF0 = [F:MFI]ITMREF;[F:MFI]MFGFCY
           If fstat : Raz [F:ITF] : Endif
      Endif
# Issue 65478 - 2010-07-08 by CCC : Contrôle existence fiche article-dépôt
      If clalev([F:ITW])
&      & dim([M:MBI]WRHE)>0 & [M:MBI]WRHE<>"" & GWRHOBY=2
&      & ([F:ITW]ITMREF<>[F:ITM]ITMREF | [F:ITW]WRH<>[M:MBI]WRHE)
          Read [F:ITW]ITW0=[F:ITM]ITMREF;[M:MBI]WRHE
          If fstat
              Goto NEXTMF2
          Endif
      Endif
      If nolign+1 > WMAX : Break : Endif
      nolign  += 1
      [M:MBI]PRODTYP(nolign-1) = 1
      [M:MBI]IPTDAT(nolign-1) = date$
      [M:MBI]WLINUM(nolign-1)  = GMFILIN
      [M:MBI]WINDIC(nolign-1) = 1
      Gosub CHARG_MFI
      GMFILIN += 1
   $NEXTMF2
   Next
Next
[M:MBI]NBLIG = nolign
Filter [F:MFI]
# 08.02 demande 15501 chargement spécifique du masque MBI
GPOINT = "LOAMSKMBI" : Gosub ENTREE From EXEFNC
Grizo [M:MBI]5,7,10

Gosub AFF_TABLEAU
Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:MBI]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=15;[M:MBI]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

########################################
$CHARG_MFI
Local Integer J, WRETOUR, WNOL
Local Char    WCCE(15)
# 04.02 demande 9134
Local Decimal WRMNEXTQTY
Local Integer LIG : LIG=nolign-1

#
[M:MBI] = [F:MFI]
# 04.02 demande 9134
Gosub CALC_WRMNEXTQTY

# CCC (23/04/08) DM 46260
#If [F:MFI]UOMSTUCOE <> 0
#   [M:MBI]UOMCPLQTY(nolign-1) = (WRMNEXTQTY / [F:MFI]UOMSTUCOE)
#Else
#   [M:MBI]UOMCPLQTY(nolign-1) = WRMNEXTQTY
#Endif
Gosub CALC_UOMCPLQTY

If [M:MBI]UOMCPLQTY(nolign-1) < 0 : Raz [M:MBI]UOMCPLQTY(nolign-1) : Endif
# Issue 85893 - 2012-11-21 by CCC : la comparaison de la qté réalisée avec la qté à réaliser doit se faire en US
#[M:MBI]WQTY(nolign-1)      = [M:MBI]UOMCPLQTY(nolign-1)
[M:MBI]WQTY(nolign-1)      = [M:MBI]UOMCPLQTY(nolign-1) * [M:MBI]UOMSTUCOE(nolign-1)
If [F:BTS]CPLUPDFLG = 2
    [M:MBI]CLEFLG(nolign-1)    = 2
    [M:MBI]CPLQTY(nolign-1)    = [M:MBI]UOMCPLQTY(nolign-1) * [M:MBI]UOMSTUCOE(nolign-1)
    Call QTEARR([M:MBI]CPLQTY(nolign-1),[M:MBI]STU(nolign-1)) From TRTDIV
Else
    Raz [M:MBI]UOMCPLQTY(nolign-1),[M:MBI]CPLQTY(nolign-1)
    [M:MBI]CLEFLG(nolign-1) = 1
Endif
[M:MBI]MFIEXTQTY(nolign-1) = [F:MFI]EXTQTY
[M:MBI]MFITOTQTY(nolign-1) = [F:MFI]CPLQTY
[M:MBI]MFIRMNQTY(nolign-1) = [F:MFI]RMNEXTQTY
[M:MBI]MFIUOMQTY(nolign-1) = [F:MFI]UOMEXTQTY
If dim([M:MBI]MFILOT) > 0
    [M:MBI]MFILOT(nolign-1) = [F:MFI]LOT
Endif
If [F:MFI]UOMSTUCOE <> 0
    [M:MBI]UOMEXTQTY(nolign-1) = (WRMNEXTQTY / [F:MFI]UOMSTUCOE)
Else
    [M:MBI]UOMEXTQTY(nolign-1) = WRMNEXTQTY
Endif
[M:MBI]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
[M:MBI]QUAFLG(nolign-1)    = [F:ITF]QUAFLG                           # hcb V6CQ
If [M:MBI]ITMTYP(nolign-1) = 0 : [M:MBI]ITMTYP(nolign-1) = 1 : Endif
# Issue 107513/8 - 2015-07-13 by JUSYN : EEC setting ECCSAIFLG default
If dim([M:MBI]ECCSAIFLG(nolign-1)) > 0
    [M:MBI]ECCSAIFLG(nolign-1) = 9 # version number is not modifiable
Endif
#
#Case [F:ITM]QUAFLG
#     When 1 : [M:MBI]STA(nolign-1) = "A"
#     When 2 : [M:MBI]STA(nolign-1) = "Q"
#     When 3 : [M:MBI]STA(nolign-1) = "Q"
#Endcase
#si ajout de ligne et non chargement initial
If [M:MBI]WINDIC(nolign-1) <> 1
    # Issue 87766 - 2013-02-21 by CCC
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        Call INIZONENT([M:MBI]ITMREF(nolign-1),"MBI",[M:MBI]FCY,"",0,"U",nolign-1,5,[M:MBI]TRSCOD,[M:MBI]MFGNUM(nolign-1),3,1) From STKECR
    Endif
    # Issue 107513/8 - 2015-07-13 by JUSYN : ECC - Major and minor version after RAZ in INIZONENT
    If dim([M:MBI]ECCVALMAJ(nolign-1)) > 0
        [M:MBI]ECCVALMAJ(nolign-1)       = [F:MFI]ECCVALMAJ
        [M:MBI]ECCVALMIN(nolign-1)       = [F:MFI]ECCVALMIN
    Endif

    If dim([M:MBI]LOT) > 0
        [M:MBI]LOT(nolign-1) = [F:MFI]LOT
    Endif

    status=0
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
        If dim([M:MBI]SLO) > 0 & [M:MBI]LOT(nolign-1)<>""
           Raz [M:MBI]SLO(nolign-1)
           Call STKAMLOT([M:MBI]LOT(nolign-1),"MBI",nolign-1,[M:MBI]ITMREF(nolign-1),"SLO") From STKACT
        Endif
        Call STJSTOENTW("MBI",5,15,[M:MBI]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRETOUR) From STKENT
    Endif
Endif
#Chargement des sections ana
Call CHARG_ACCCCE(nolign-1,"","","[M:MBI]CCE",
&                    "MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT
For J = 1 To GNBDIE
    If evalue ("[M:MBI]CCE"+num$(J)+"(nolign-1)")=""
        Call INISEC(WCCE,"MKIB", J) From TRTX3CPT
        Assign "[M:MBI]CCE"+num$(J)+"(nolign-1)" With WCCE
    Endif
Next
#

Return

#######################################################
$CALC_UOMCPLQTY
If [M:MBI]COEFF=0
    If [F:MFI]UOMSTUCOE <> 0
       [M:MBI]UOMCPLQTY(nolign-1) = (WRMNEXTQTY / [F:MFI]UOMSTUCOE)
    Else
       [M:MBI]UOMCPLQTY(nolign-1) = WRMNEXTQTY
    Endif
Else
    [M:MBI]UOMCPLQTY(nolign-1) = [F:MFI]EXTQTY * [M:MBI]COEFF
    Call QTEARR([M:MBI]UOMCPLQTY(nolign-1),[M:MBI]UOM(nolign-1)) From TRTDIV
Endif
Return


########################################
$CHARG_BOH
Local Integer J,WRETOUR,WNOL
Local Char    WCCE(15)
#
[M:MBI] = [F:BOH]
[M:MBI]UOM(nolign-1)       = [F:ITM]STU
[M:MBI]STU(nolign-1)       = [F:ITM]STU
[M:MBI]UOMSTUCOE(nolign-1) = 1
[M:MBI]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
[M:MBI]QUAFLG(nolign-1)    = [F:ITF]QUAFLG                         # hcb V6CQ
[M:MBI]ITMTYP(nolign-1) = 1
# Issue 68333 - 2010-10-18 by CCC
[M:MBI]ITMKEY(nolign-1) = [F:BOH]ITMREF+"1"
#
[M:MBI]UOMCPLQTY(nolign-1)  = 0
[M:MBI]CPLQTY(nolign-1)     = 0
If [F:BTS]CPLUPDFLG = 2
    Case [F:BTS]QTYSAI
        When 1:
        When 2:    [M:MBI]UOMCPLQTY(nolign-1)  =[F:ITF]MFGLOTQTY
                   Call QTEARR([M:MBI]UOMCPLQTY(nolign-1), [M:MBI]UOM(nolign-1)) From TRTDIV
                   [M:MBI]CPLQTY(nolign-1)     =[F:ITF]MFGLOTQTY
                   Call QTEARR([M:MBI]CPLQTY(nolign-1), [M:MBI]STU(nolign-1)) From TRTDIV
        When 3:    [M:MBI]UOMCPLQTY(nolign-1)  =[F:ITF]REOMINQTY
                   Call QTEARR([M:MBI]UOMCPLQTY(nolign-1), [M:MBI]UOM(nolign-1)) From TRTDIV
                   [M:MBI]CPLQTY(nolign-1)     =[F:ITF]REOMINQTY
                   Call QTEARR([M:MBI]CPLQTY(nolign-1), [M:MBI]STU(nolign-1)) From TRTDIV
    Endcase
Endif

#si ajout de ligne et non chargement initial
If [M:MBI]WINDIC(nolign-1) <> 1
    # Issue 87766 - 2013-02-21 by CCC
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        Call INIZONENT([M:MBI]ITMREF(nolign-1),"MBI",[M:MBI]FCY,"",0,"",nolign-1,5,[M:MBI]TRSCOD,"",3,1) From STKECR
    Endif

    status=0
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        Call STJSTOENTW("MBI",5,15,[M:MBI]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRETOUR) From STKENT
    Endif
Endif

#chargement des sections ana
For J = 1 To GNBDIE
   Call INISEC(WCCE,"MKIB", J) From TRTX3CPT
   Assign "[M:MBI]CCE"+num$(J)+"(nolign-1)" With WCCE
Next
Return

########################################
# 04.02 demande 9134
$CALC_WRMNEXTQTY
Local Integer I

WRMNEXTQTY = [F:MFI]RMNEXTQTY
If nolign > 1
   For I = 0 To nolign-2
       If [M:MBI]IPTDAT(I)  = [M:MBI]IPTDAT(nolign-1)  &
&         [M:MBI]PRODTYP(I) = [M:MBI]PRODTYP(nolign-1) &
&         [M:MBI]MFGNUM(I)  = [M:MBI]MFGNUM(nolign-1)  &
&         [M:MBI]ITMREF(I)  = [M:MBI]ITMREF(nolign-1)  &
&         [M:MBI]MFGLIN(I)  = [F:MFI]MFGLIN
          WRMNEXTQTY -= [M:MBI]UOMCPLQTY(I)
       Endif
    Next
Endif
Return


########################################
# 04.02 gestion des sous-produits demande 9469
# y a t il des sous produits dans la nomenclature
Subprog RECHERCHE_SOUS_PRODUIT(LITM,LMAX,LQTY,NUMLIG)
Value    Char    LITM
Value    Integer LMAX
Value    Decimal LQTY
Variable Integer NUMLIG

Local    Integer WTYPMVT
Local    Decimal WDIS
Local    Integer NOL2
Local    Integer WRET

nolign = NUMLIG
# 05.02 demande 14201
Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = [F:BOH]BOMALT & BOMALTTYP = [F:BOH]BOMALTTYP &
&         (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <= date$)) &
&         (BOMENDDAT = [0/0/0] | (BOMENDDAT >= date$))

# lecture premier enregistrement
Read [BOD]BOD0 First                  # 10.02 Performances

# tant qu'y en a !
While !fstat
   If [F:ITM]ITMREF <> [F:BOD]CPNITMREF
      Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
      If fstat : Goto NEXTBOD : Endif
   Endif
 # article avec statut non actif
   If [F:ITM]ITMSTA > 1
       Goto NEXTBOD
   Endif
 # lecture article site
   If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:MBI]FCY
      Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:MBI]FCY
      If fstat : Goto NEXTBOD : Endif
   Endif
   Call LECITV2([M:MBI]FCY,[F:BOD]CPNITMREF,WRET) From MFGLIB
   Call STODISTOT("",0,7,"",WDIS) From STKLIB
   If [F:BOD]CPNTYP = 4
          If nolign + 1 > LMAX : Break : Endif
          nolign  += 1
          [M:MBI]PRODTYP(nolign-1) = 2
          [M:MBI]IPTDAT(nolign-1)  = date$
          [M:MBI]ITMTYP(nolign-1)  = 2
          [M:MBI]WLINUM(nolign-1)  = GMFILIN
          [M:MBI]WINDIC(nolign-1)  = [M:MBI]WINDIC(nolign-2)
          Gosub CHARG_BOD
          GMFILIN += 1
   Else
          # si article fantôme
           If [F:ITM]PHAFLG = 2
              NOL2 = nolign
              Call RECHERCHE_SOUS_PRODUIT([F:ITM]ITMREF,LMAX,LQTY,NOL2)
              nolign = NOL2
           Endif
    Endif
$NEXTBOD
   Read [BOD]BOD0 Next                 # 10.02 Performances
Wend
NUMLIG = nolign
End

########################################
# 04.02 gestion des sous-produits demande 9469
$CHARG_BOD
Local    Decimal WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Decimal WBASQTY
Local    Integer WLIKQTYCOD
Local    Decimal WLIKQTY
Local    Integer WQTYRND
Local    Decimal WLSCA
Local    Char    WSTU(GLONUOM)     # llc 01.02 UOM
Local    Integer J
Local    Char    WCCE(15)

[M:MBI] = [F:BOD]
[M:MBI]ITMREF(nolign-1)    = [F:BOD]CPNITMREF
[M:MBI]UOM(nolign-1)       = [F:ITM]STU
[M:MBI]STU(nolign-1)       = [F:ITM]STU
[M:MBI]UOMSTUCOE(nolign-1) = 1
[M:MBI]SERMGTCOD(nolign-1) = [F:ITM]SERMGTCOD
[M:MBI]QUAFLG(nolign-1)    = [F:ITF]QUAFLG                        # hcb V6CQ
[M:MBI]ITMTYP(nolign-1) = 2
# Issue 68333 - 2010-10-18 by CCC
[M:MBI]ITMKEY(nolign-1) = [F:BOD]ITMREF+"2"
# calcul quantité
If LQTY = 0 : WLIEN = 0
Else
    WQTY         = LQTY
    WSTU         = [F:ITM]STU
    WBASQTY      = [F:BOH]BASQTY
    WLIKQTYCOD   = [F:BOD]LIKQTYCOD
    WLIKQTY      = [F:BOD]LIKQTY
    WQTYRND      = [F:BOD]QTYRND
    WSCA         = [F:BOD]SCA
    Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    WLIEN = WQTYBA
Endif
[M:MBI]UOMCPLQTY(nolign-1)  = WLIEN
Call QTEARR([M:MBI]UOMCPLQTY(nolign-1), [M:MBI]UOM(nolign-1)) From TRTDIV
[M:MBI]CPLQTY(nolign-1)     = WLIEN
Call QTEARR([M:MBI]CPLQTY(nolign-1), [M:MBI]STU(nolign-1)) From TRTDIV

#Case [F:ITM]QUAFLG
#     When 1 : [M:MBI]STA(nolign-1) = "A"
#     When 2 : [M:MBI]STA(nolign-1) = "Q"
#     When 3 : [M:MBI]STA(nolign-1) = "Q"
#Endcase
#si ajout de ligne et non chargement initial
If [M:MBI]WINDIC(nolign-1) <> 1

    # Issue 87766 - 2013-02-21 by CCC
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        Call INIZONENT([M:MBI]ITMREF(nolign-1),"MBI",[M:MBI]FCY,"",0,"",nolign-1,5,[M:MBI]TRSCOD,"",3,1) From STKECR
    Endif

    status=0
    If [M:MBI]UOMCPLQTY(nolign-1) <> 0
        Call STJSTOENTW("MBI",5,15,[M:MBI]IPTDAT(nolign-1),nolign-1,NBLIG,"BTS",3,WRET) From STKENT
    Endif
Endif

#chargement des sections ana
For J = 1 To GNBDIE
   Call INISEC(WCCE,"MKIB", J) From TRTX3CPT
   Assign "[M:MBI]CCE"+num$(J)+"(nolign-1)" With WCCE
Next


Return

###########################################
$AFF_TABLEAU
Local Integer I, WRETOUR
Case [M:MBI]WSRT
     When 17  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]ENDDAT(indice),
&                                                        [M:MBI]MFGNUM(indice),
&                                                        [M:MBI]MFGLIN(indice)
     When 33  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]ENDDAT(indice),
&                                                        [M:MBI]ITMKEY(indice),
&                                                        [M:MBI]ITMREF(indice),
&                                                        [M:MBI]MFGLIN(indice)
     When 10  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]MFGNUM(indice),
&                                                        [M:MBI]ENDDAT(indice),
&                                                        [M:MBI]MFGLIN(indice)
     When 34  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]MFGNUM(indice),
&                                                        [M:MBI]ITMKEY(indice),
&                                                        [M:MBI]ITMREF(indice),
&                                                        [M:MBI]MFGLIN(indice)
     When 12  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]ITMKEY(indice),
&                                                        [M:MBI]ITMREF(indice),
&                                                        [M:MBI]ENDDAT(indice),
&                                                        [M:MBI]MFGLIN(indice)
     When 20  : Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]ITMKEY(indice),
&                                                        [M:MBI]ITMREF(indice),
&                                                        [M:MBI]MFGNUM(indice),
&                                                        [M:MBI]MFGLIN(indice)
Endcase
For I = 0 To  [M:MBI]NBLIG - 1
    # Issue 90379 - 2013-06-26 by CCC : Pas d'affichage dans INIZONENT puisque l'affichage complet est fait juste après
    Call INIZONENT([M:MBI]ITMREF(I),"MBI",[M:MBI]FCY,"",0,"U",I,5,[M:MBI]TRSCOD,[M:MBI]MFGNUM(I),3,0) From STKECR
    # car RAZ dans INIZONENT
    If dim([M:MBI]MFILOT) > 0
        [M:MBI]LOT(I) = [M:MBI]MFILOT(I)
    Endif
    # Issue 107513/8 - 2015-08-18 by JUSYN : Read versions again because of deletion in INIZONENT
    If dim([M:MBI]ECCVALMAJ(I))>0
        If [F:MFI]MFGNUM <> [M:MBI]MFGNUM(I) | [F:MFI]MFGLIN <> [M:MBI]MFGLIN(I)
            Read [F:MFI]MFI0 = [M:MBI]MFGNUM(I);[M:MBI]MFGLIN(I)
        Endif
        [M:MBI]ECCVALMAJ(I) = [F:MFI]ECCVALMAJ
        [M:MBI]ECCVALMIN(I) = [F:MFI]ECCVALMIN
    Endif

    status=0
    If [M:MBI]UOMCPLQTY(I) <> 0
        # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
        If dim([M:MBI]SLO) > 0 & [M:MBI]LOT(I)<>""
           Raz [M:MBI]SLO(I)
           Call STKAMLOT([M:MBI]LOT(I),"MBI",I,[M:MBI]ITMREF(I),"SLO") From STKACT
        Endif
        Call STJSTOENTW("MBI",5,15,[M:MBI]IPTDAT(I),I,NBLIG,"BTS",3,WRETOUR) From STKENT
    Else    # Issue 87766 - 2013-02-21 by CCC
        [M:MBI]WLOCSEQ(I)=0
    Endif
Next

Affzo [M:MBI]10,15
Return

################################################################################################
$VALIDATION
Local Integer I
# Issue 73286 - GA 01/2012
GPE=0 : GPOINT = "BEFVALID" : Gosub  ENTREE From EXEFNC
If GPE <> 0 : Return : Endif

Gosub CRE_SUIVI
If VALOK <> 2 : Return : Endif

#---- Régularisation des mouvements et alloc -----#
#CCC (17/11/08) Bug 50329
#For I = 0 To [M:MBI]NBLIG-1
If sigma(0,[M:MBI]NBLIG-1,WMTKNUM(indcum)<>"") : # GH 02/2016 bug 108954 optimisation
        Call REGFROMENT( 0, "MBI", "[M:MBI]CREFLG(I)=0", "ITMREF", [M:MBI]FCY ) From TRTSHTCOM
Endif
#Next

If LORI <> "PILOT"
   Call FERME_TRACE From LECFIC
   If TRA = 1
      GPE = 1
      # demande 15682 ne pas afficher la trace
      # Mettre GPE = 0 pour inhiber l'action standard
      GPOINT = "AFFTRA"
      Gosub  ENTREE From EXEFNC
      If GPE <> 0
         Call LEC_TRACE From LECFIC
      Endif
   Endif
   TRA = 0
Endif

# GH 02/2016 bug 108954 don't lose entries if the validation didn't totally succeed
# Effzo [MBI]15
J=0
For I=0 To [M:MBI]NBLIG-1
  If WMTKNUM(I)="" & [M:MBI]CPLQTY(I)<>0
     J=1 : Break
  Endif
Next
If !J
   # all what should be validated was => clear the grid
   Effzo [MBI]15
   [M:MBI]NBLIG=0
Else
   # all what should be validated was not => remove validated lines of the grid to make a new try of validation
   I=0
   While I<[M:MBI]NBLIG
     If WMTKNUM(I)<>""
        Dela I, 1 [M:MBI]NBLIG : [M:MBI]NBLIG-=1 : I-=1
     Endif
     I+=1
   Wend
   Affzo [MBI]15
Endif
Return

################################################################################################
$FIN
GCONSULT = GCONSLCT
GFONC1 = SAV_GFONC1
Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
Kill GMFILIN, GMILNUM
Raz GORITITCOL
Call IMPSCR From ATRTX3
PARAM(8) = num$(LRETOK)

If GFLAG=[F:BTS]BTSNUM Raz GFLAG Endif # FQ 51401 GA 01/2009

# 01.10 mm 61503
Gosub REST_GLOB From TRTX3GLOB

Return

########################################
$CRE_SUIVI
Local Integer I,OK,WOK, WLIN, WITMCLENBR, WNBITM, STAT, LRET, WRETOUR, WRET, WNBMAT, WMATCLENBR, WNOLIGN
Local Date    WDAT
Local Char    WMFGNUM(GLONVCR),WWMFGNUM(GLONVCR),WMFGTRKNUM(GLONVCR),TIT(80)
Local Char    WNUMTEX (12)
Local Decimal WWQTY,WCPLQTY,WREJQTY,WQUAQTY
Local Char    WMTKNUMSTR(GLONVCR), WMTKNUMEND(GLONVCR)        # llc étiquettes (9727)
Local Char    WMTKNUM(GLONVCR)(max(1,[M:MBI]NBLIG))
Local Integer WCRETRK, WNEW
Local Integer WMFGMKI                                         # GH 17/09/2015 bug 110557

Raz WMTKNUMSTR, WMTKNUMEND                  # llc étiquettes (9727)
Raz WMTKNUM

#1ere chose y a-t-il quelque chose à suivre ?
If [M:MBI]NBLIG = 0 :  Return : Endif

WOK = 0
# en mode VT tout est ok et pas de message
If !GVTMOD
    VALOK = 1
    For I = 0 To [M:MBI]NBLIG-1
        If [M:MBI]CPLQTY(I) <> 0
           WOK = 1
           If [M:MBI]WSTOFLG(I) = 0
              Call ERREUR(mess(113,193,1)+num$(I+1)) From GESECRAN
              WOK = 2 : Break
           Endif
        Endif
    Next I
    If WOK = 2 : Return : Endif

    If WOK = 0 : Call ERREUR(mess(219,193,1)) From GESECRAN   : Return : Endif
    #
    #Un petit message de confirmation...
    Call OUINON(mess(20,196,1),VALOK) From GESECRAN
    If VALOK <> 2 : Return : Endif
    #
Else
    VALOK = 2
Endif

# FQ 73634 GA 05/2011 ctrl déplacé après la Question ...
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
For I=0 To [M:MBI]NBLIG-1
    #If func MFGLIB.CHKMFGLOCK([M:MBI]MFGNUM(I),0) : # GH 21/02/2014 bug 94986
    If [M:MBI]CPLQTY(I)<>0
&      & !sigma(0,I-1,[M:MBI]MFGNUM(indcum)=[M:MBI]MFGNUM(I) & [M:MBI]CPLQTY(indcum)<>0)
&      & func MFGLIB.CHKMFGLOCK([M:MBI]MFGNUM(I),0)
        Call ERREUR([M:MBI]MFGNUM(I)-":"-mess(280,193,1)) From GESECRAN
        VALOK=1 : Break
    Endif
Next
If VALOK = 1 : Return : Endif

#On y va ...

If LORI <> "PILOT"
    TIT = mess(214,195,1)
    TRA=0
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

#
# Issue 101365 - 2014-09-30 by CCC : WCRETRK%1 => no standard sorting ; WCRETRK%2 => use next entry point
Raz WCRETRK
GPOINT="MBITRKCRE"
Gosub ENTREE From EXEFNC
If mod(WCRETRK,2)=0
    Sorta [M:MBI]NBLIG [M:MBI]NBLIG Order By [M:MBI]IPTDAT(indice),
&                                            [M:MBI]PRODTYP(indice),
&                                            [M:MBI]MFGNUM(indice),
&                                            [M:MBI]CLEFLG(indice)  # Issue 79080 - 2012-02-02 by CCC : Ajout de CLEFLG dans le tri
Endif
#Récupération du compteur
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
#
Raz [L]WLIN
For nolign = 1 To [M:MBI]NBLIG
  If [M:MBI]CPLQTY(nolign-1) <> 0

    # Issue 101365 - 2014-09-30 by CCC : WNEW=1 to create a new tracking number
    Raz WNEW
    If mod(WCRETRK,4)>=2
        GPOINT="MBITRKLIN"
        Gosub ENTREE From EXEFNC
    Endif

    If WLIN = 0
        WNEW=1
    Elsif [M:MBI]IPTDAT(nolign-1) <> WDAT
        WNEW=1
    Endif

    If WNEW=1
       If WNBITM<>0 : # GH 17/09/2015 bug 110557 if WLIN<>0
           If WWMFGNUM <> ""
               Gosub MAJ_ENTOF
               Raz WWMFGNUM
           Endif
           Gosub CRE_ENTETE
           If GOK<1 : Break : Endif
       Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
       Endif
       WDAT    = [M:MBI]IPTDAT(nolign-1)
       If [M:MBI]PRODTYP(nolign-1) = 1 : WMFGNUM  = [M:MBI]MFGNUM(nolign-1)
                                         WWMFGNUM = [M:MBI]MFGNUM(nolign-1)
       Endif
       Call DEBTRANS From GLOCK
       Trbegin [MKI]
       Call NUMERO(GCODNUM,[M:MBI]FCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
       If STAT
          Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
          GOK = 0
          Break
       Endif
       WMTKNUM(nolign-1) = WMFGTRKNUM
    Else
       If [M:MBI]MFGNUM(nolign-1) <> WMFGNUM : Raz WMFGNUM : Endif
       If [M:MBI]MFGNUM(nolign-1) <> WWMFGNUM & WWMFGNUM <> ""
          Gosub MAJ_ENTOF
          Raz WWMFGNUM
          If GOK<1 : Break : Endif
          If [M:MBI]PRODTYP(nolign-1) = 1 : WWMFGNUM = [M:MBI]MFGNUM(nolign-1) : Endif
       Endif
    Endif
    Raz [M:MTIK]
    [M:MTIK]          = [M:MBI]
    [M:MTIK]MFGFCY    = [M:MBI]FCY
    [M:MTIK]MFGTRKNUM = WMFGTRKNUM
    [M:MTIK]ITMTRKLIN = [M:MBI]WLINUM(nolign-1)
    [M:MTIK]MATFLG    = [F:BTS]MATFLG
    [M:MTIK]ENTCOD    = [F:BTS]ENTCOD
    [M:MTIK]TRSFAM    = [F:BTS]TRSFAM
    [M:MTIK]TRSCOD    = [F:BTS]TRSCOD
    [M:MTIK]ENTCODS   = [F:BTS]ENTCODS
    [M:MTIK]TRSFAMS   = [F:BTS]TRSFAMS
    [M:MTIK]TRSCODS   = [F:BTS]TRSCODS
    [M:MTIK]MATFLTFLG = [F:BTS]MATFLTFLG
    # 01.06 demande 34449
    [M:MTIK]CONSMAT   = [F:BTS]CONSMAT
    # 07.02
    [M:MTIK]WITMCLENBR = WITMCLENBR
    [M:MTIK]WMATCLENBR = WMATCLENBR
    # 11.01 demande 11423 Ajouter STOCODMAN
    [M:MTIK]STOCODMAN = [F:BTS]STOCODMAN
    [M:MTIK]WNBMAT    = WNBMAT
     Case [M:MBI]PRODTYP(nolign-1)
     When 1 :
     #Lecture article lancé OF
           Read [F:MFI]MFI0 = [M:MBI]MFGNUM(nolign-1);[M:MBI]MFGLIN(nolign-1)
           If fstat : GOK = 0 : Call RSTA("MFI",[M:MBI]MFGNUM(nolign-1)+num$([M:MBI]MFGLIN(nolign-1))) From GLOCK : Break : Endif
           WNOLIGN = nolign
           [M:MTIK]TYPTRT = 3
           Call CRE_MKI From MTKAUTLIB
           If GOK < 1 : TRA = 1 : Break : Endif
           nolign = WNOLIGN
           [L]WLIN       += 1
           WITMCLENBR    = [M:MTIK]WITMCLENBR
           WMATCLENBR    = [M:MTIK]WMATCLENBR
            # 12.03 si sous-produit pas de maj des qtés réalisées de l'entête d'OF demande 20496
           If [F:MFI]ITMTYP = 1
               WCPLQTY      += [M:MTIK]WCPLQTY
               WREJQTY      += [M:MTIK]WREJCPLQTY
               WQUAQTY      += [M:MTIK]WQUACPLQTY
           Endif
           WNBITM       += [M:MTIK]WNBITM : # WNBITM += 1 # GH 17/09/2015 bug 110557
           WNBMAT        = [M:MTIK]WNBMAT
           WMFGMKI      += [M:MTIK]WNBITM : # GH 17/09/2015 bug 110557
     When 2 :
    #Lecture de l'article de nomenclature
    # 04.02 gestion des sous-produits demande 9469
           If [M:MBI]ITMTYP(nolign-1) <> 2
               Read [F:BOH]BOH0 = [M:MBI]ITMREF(nolign-1);[M:MBI]BOMALT(nolign-1);2
               If fstat : GOK = 0 : Call RSTA("BOH",[M:MBI]ITMREF(nolign-1)+num$([M:MBI]BOMALT(nolign-1))) From GLOCK : Break : Endif
           Endif
           WNOLIGN = nolign
           [M:MTIK]TYPTRT = 7
           Call CRE_MKI From MTKAUTLIB
           If GOK < 1 : TRA = 1 : Break : Endif
           nolign = WNOLIGN
           [L]WLIN   += 1
           WITMCLENBR = [M:MTIK]WITMCLENBR
           WMATCLENBR = [M:MTIK]WMATCLENBR
           WNBITM    += [M:MTIK]WNBITM : # WNBITM += 1 # GH 17/09/2015 bug 110557
           WNBMAT     = [M:MTIK]WNBMAT
    Endcase
  Endif
Next
If GOK>0 & WWMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
If GOK < 1
   If adxlog : Gosub AB_TR : Endif
Else
   If WNBITM <> 0 : Gosub CRE_ENTETE
   Elsif adxlog   : Rollback # GH 17/09/2015 bug 110557
   Endif
Endif

If GOK < 1
   # GH 02/2016 bug 108954  cancel the tracking number set on the associated lines
   If WMFGTRKNUM<>""
      Look [MTK]MTK0 = WMFGTRKNUM
      If fstat
        For I=0 To [M:MBI]NBLIG-1
            If WMTKNUM(I) = WMFGTRKNUM : WMTKNUM(I)="" : Endif
        Next I
      Endif
   Endif
   Return
Endif

Gosub LBE

# 11.02 demande 16662 point d'entrée permettant d'effectuer un traitement supplémentaire
# en fin de plan, exemple, lancer une impression
GPOINT = "CUSTRTSUP" : Gosub  ENTREE From EXEFNC
Return

############################################

$MAJ_ENTOF
If WMFGMKI<>0 : # GH 17/09/2015 bug 110557 test WMFGMKI
  #Maj entête d'OF
  Readlock [F:MFG]MFG0 = WWMFGNUM
  If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(WWMFGNUM) : Return
  Elsif fstat GOK=0  : Call RSTA("MFG",num$(WWMFGNUM)) From GLOCK : Return
  Endif
  [F:MFG]ITMCLENBR += WITMCLENBR
  [F:MFG]MATCLENBR += WMATCLENBR
  If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&    [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&    [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
     [F:MFG]MFGTRKFLG = 5
     # CCC (10/01/08) DM 44021
  #   [F:MFG]TRKLAST   = WDAT
  Else
     [F:MFG]MFGTRKFLG = 4
     # CCC (10/01/08) DM 44021
  #   Raz [F:MFG]TRKLAST
  Endif

  # CCC (10/01/08) DM 44021
  If [F:MFG]TRKLAST<WDAT
     [F:MFG]TRKLAST   = WDAT
  Endif
  If [F:MFG]TRKLASTC<date$
     [F:MFG]TRKLASTC  = date$
  Endif
  If [F:MFG]TRKFIRST>WDAT | [F:MFG]TRKFIRST = "00/00/00"
      [F:MFG]TRKFIRST = WDAT
  Endif
  If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
      [F:MFG]TRKFIRSTC = date$
  Endif
  [F:MFG]CPLQTY       += WCPLQTY
  [F:MFG]REJCPLQTY    += WREJQTY
  [F:MFG]QUACPLQTY    += WQUAQTY
  If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
     [F:MFG]RMNEXTQTY = 0
  Else
     [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
  Endif
  Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
  If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
  If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
  If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
  Rewrite [F:MFG]
  If fstat
     GOK = 0 : Call FSTA("MFG") From GLOCK : Return
  Endif
  #----- MISE à jour statistiques entête OF -----#
  Call VALSTA("MFG",1) From SUBPS2
  If GOK < 1 : Return : Endif
Endif

Raz WITMCLENBR, WMATCLENBR, WCPLQTY, WREJQTY, WQUAQTY, WMFGMKI : # GH 17/09/2015 bug 110557 raz WMFGMKI
Return

############################################################
#Création entête de suivi
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    If WMFGNUM <> ""
       Read [F:MFG] = WMFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = [M:MBI]FCY
    [F:MTK]TRSCOD    = [M:MTIK]TRSCOD
    [F:MTK]TRSCODS   = [M:MTIK]TRSCODS
    [F:MTK]MFGTRKNUM = WMFGTRKNUM
    [F:MTK]MFGTRKDAT = WDAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    [F:MTK]OPETRKFLG = 1
    [F:MTK]ITMTRKFLG = 2
    [F:MTK]MATTRKFLG = 1
    [F:MTK]NBRITM    = WNBITM
    [F:MTK]NBRMAT    = WNBMAT
    If [F:MTK]NBRMAT <> 0 : [F:MTK]MATTRKFLG = 2 : Endif
    # Issue 74667 - 2011-07-12 by CCC
    If [F:MFG]MFGTEX <> ""
       [F:MTK]MTKTEX = [F:MFG]MFGTEX
       If left$([F:MTK]MTKTEX,3)="MFG"
          Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
       Endif
    Endif

    #point d'entrée  pour mise à jour de tables spécifiques liées à [MTK] sr 01.02 demande 12361
    GPOINT = "BENMTKMAJ" : Gosub ENTREE From EXEFNC
    #
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif

If GOK < 1
   Gosub AB_TR
Else
   Commit
   LRETOK = 2
   TRA = 1
   Call ECR_TRACE(mess(79,190,1)-[F:MTK]MFGTRKNUM,0) From GESECRAN

   If WMTKNUMSTR = ""       # llc étiquettes 9727
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
       # Les n° de documents ne sont pas nécessairement créés de façon croissante
   Elsif WMTKNUMEND < [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
   Elsif WMTKNUMSTR > [F:MTK]MFGTRKNUM
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
   Endif

   Raz WMFGTRKNUM
Endif

Raz WNBITM, WNBMAT,  WMFGNUM, WLIN
Return

$AB_TR
Rollback
LRETOK=0
If GOK<0 & GLOCK<>"" :  # GH 02/2016 bug 108954 put an error in the log in case of lock
   Call ECR_LOCK("") From GLOCK : GLOCK=""
   TRA=1
Endif
If !GVTMOD
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(mess(254,193,1)+"\"+mess(255,193,1),1) From GESECRAN
   TRA=1
Endif
Return

############################################################
# impression étiquettes de stock 9727
$LBE
If WMTKNUMSTR <> "" & WMTKNUMEND <> "" & !GVTMOD & [F:BTS]PRNCOD1 > 1
   Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
   WPARAM(1) = [M:MBI]FCY
   WPARAM(2) = "15"
   WPARAM(3) = WMTKNUMSTR
   WPARAM(4) = WMTKNUMEND
   Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif
Return

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
Effzo [M:MBI]15
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
[M]FCY = VALEUR
If dim([M:MBI]WRHE)>0
    Call WRHINIT([M:MBI]WRHE,VALEUR,2) From STKWRH
    Affzo [M:MBI]WRHE
Endif
Gosub WRH_ETAT
# Issue 73720 - 2011-05-18 by CCC
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
End

