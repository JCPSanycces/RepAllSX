#<AdxTL>@(#)3.0.0.0 $Revision$
#------------------------------------------------------------------------------------------------------------------
#
#   Common BPARTNER representation functions library.
#
#   _FILL_MAILMERGE_PROPERTIES          Private function to fill representation properties used for mail merge.
#
#------------------------------------------------------------------------------------------------------------------

#**
#* This function fill representation properties for default adress and default contact. These properties
#* can be available on the query facet as technical properties and used with the office plugin.
#*
#* @param PREPINST  Instance of the representation to be enriched
#* @param PBPRNUM   Business partner identifier (can be a customer, a business partner, a lead or a sales representant
#* @param PBPAADD   Default address identifier to use
#* @param PCNTNAM   Default contact identifier to use
#*
#* @return LRET     Return value
#*
#* @private
#*!
Funprog _FILL_MAILMERGE_PROPERTIES(PREPINST, PBPRNUM, PBPAADD, PCNTNAM)
Variable Instance PREPINST Using OBJECT
Const    Char     PBPRNUM
Const    Char     PBPAADD
Const    Char     PCNTNAM
Local Integer LRET

  # Additionnal technical properties in the query coming from default address
  If PBPAADD<>""
    Local File BPADDRESS [BPA]
    Read [F:BPA]BPA0=1;PBPRNUM;PBPAADD
    If !fstat
      PREPINST.RPOSCOD       =  [F:BPA]POSCOD
      PREPINST.RBPAADDLIG1   =  [F:BPA]BPAADDLIG(0)
      PREPINST.RBPAADDLIG2   =  [F:BPA]BPAADDLIG(1)
      PREPINST.RBPAADDLIG3   =  [F:BPA]BPAADDLIG(2)
      PREPINST.RCTY          =  [F:BPA]CTY
      PREPINST.RSAT          =  [F:BPA]SAT
      PREPINST.RCRY          =  [F:BPA]CRY
      If PREPINST.RCRY<>"" 
       Call LECTEXTRA_SYR(PREPINST,"", PREPINST.RCRYDES,"TABCOUNTRY","CRYDES",PREPINST.RCRY,"") From ATEXTRA
      Endif
      PREPINST.REMAIL        =  [F:BPA]WEB(0)
    Endif
  Endif

  # Additionnal technical properties in the query coming from default contact
  If PCNTNAM<>""
    Local File CONTACT [CNT]
    Read [F:CNT]CNT0=1;PBPRNUM;PCNTNAM
    If !fstat
      Local File CONTACTCRM [AIN]
      Read [F:AIN]AIN0=[F:CNT]CCNCRM
      If !fstat
        PREPINST.RCNTTTL   = [F:AIN]CNTTTL
        PREPINST.RCNTLNA   = [F:AIN]CNTLNA
        PREPINST.RCNTFNA   = [F:AIN]CNTFNA
      Endif
      PREPINST.RCNTFNC  = [F:CNT]CNTFNC
      PREPINST.RCNTEMA  = [F:CNT]WEB
      PREPINST.RCNTTEL  = [F:CNT]TEL
      PREPINST.RCNTFAX  = [F:CNT]FAX
    Endif
  Endif

End LRET
