#<AdxTL>@(#)%I%
# Supervisor
# Inquiry PTE

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:17:13"
A_USER  = "ADMIN"
A_STAMP = "20181109081713"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1001392,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSPTESTD"
PROGSPE    = "CNSPTESPE"
CBOITE     = "DCNSPTE"
BOITE      = "FCNSPTE"
NOMMSK(0)  = "CONSPTE0"
ABMSK(0)   = "PTE0"
NOMMSK(1)  = "CONSPTE1"
ABMSK(1)   = "PTE1"
CNOMMSK    = "CRITPTE"
CABMSK     = "CPTE"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:PTE])=0 : Local File PJMTIMEMP    [PTE] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CPTE]
 When  0 : Local Mask =NOMMSK(0) [PTE0]
 When  1 : Local Mask =NOMMSK(1) [PTE1]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CPTE]
 When  0 : Grizo [PTE0]
 When  1 : Grizo [PTE1]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
If dim([M:CPTE]CPY)>0
 Grizo [CPTE]CPY
Endif
If dim([M:CPTE]FCY)>0
 Grizo [CPTE]FCY
Endif
If dim([M:CPTE]PAUS)>0
 Grizo [CPTE]PAUS
Endif
If dim([M:CPTE]PTEUOM)>0
 Grizo [CPTE]PTEUOM
Endif
If dim([M:CPTE]PJTDEBC)>0
 Grizo [CPTE]PJTDEBC
Endif
If dim([M:CPTE]PJTFINC)>0
 Grizo [CPTE]PJTFINC
Endif
If dim([M:CPTE]PJTDSPALL)>0
 Grizo [CPTE]PJTDSPALL
Endif
If dim([M:CPTE]PTEDATDEB)>0
 Grizo [CPTE]PTEDATDEB
Endif
If dim([M:CPTE]PTEDATFIN)>0
 Grizo [CPTE]PTEDATFIN
Endif
If dim([M:CPTE]PTESTA1)>0
 Grizo [CPTE]PTESTA1
Endif
If dim([M:CPTE]PTESTA2)>0
 Grizo [CPTE]PTESTA2
Endif
If dim([M:CPTE]PTESTA3)>0
 Grizo [CPTE]PTESTA3
Endif
If dim([M:CPTE]PTESTA4)>0
 Grizo [CPTE]PTESTA4
Endif
If dim([M:CPTE]PTESTA5)>0
 Grizo [CPTE]PTESTA5
Endif
If dim([M:CPTE]PTETYP)>0
 Grizo [CPTE]PTETYP
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CPTE])>0 : Close Local Mask [CPTE] : Endif
 When  0 : If clalev([M:PTE0])>0 : Close Local Mask [PTE0] : Endif
 When  1 : If clalev([M:PTE1])>0 : Close Local Mask [PTE1] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CPTE]
 When  0 : Default Mask [PTE0]
 When  1 : Default Mask [PTE1]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CPTE]
 When  0 : Raz [M:PTE0]
 When  1 : Raz [M:PTE1]
Endcase
Return

$CRITENT
If dim([M:CPTE]CPY)>0 & dim([M:PTE0]CPY)>0
 [M:CPTE]CPY = [M:PTE0]CPY
Endif
If dim([M:CPTE]FCY)>0 & dim([M:PTE0]FCY)>0
 [M:CPTE]FCY = [M:PTE0]FCY
Endif
If dim([M:CPTE]PAUS)>0 & dim([M:PTE0]PAUS)>0
 [M:CPTE]PAUS = [M:PTE0]PAUS
Endif
If dim([M:CPTE]PTEUOM)>0 & dim([M:PTE0]UOM)>0
 [M:CPTE]PTEUOM = [M:PTE0]UOM
Endif
If dim([M:CPTE]PJTDEBC)>0 & dim([M:PTE0]PJTDEB)>0
 [M:CPTE]PJTDEBC = [M:PTE0]PJTDEB
Endif
If dim([M:CPTE]PJTFINC)>0 & dim([M:PTE0]PJTFIN)>0
 [M:CPTE]PJTFINC = [M:PTE0]PJTFIN
Endif
If dim([M:CPTE]PJTDSPALL)>0 & dim([M:PTE0]PJTDSPALL)>0
 [M:CPTE]PJTDSPALL = [M:PTE0]PJTDSPALL
Endif
If dim([M:CPTE]PTEDATDEB)>0 & dim([M:PTE0]PTEDATDEB)>0
 [M:CPTE]PTEDATDEB = [M:PTE0]PTEDATDEB
Endif
If dim([M:CPTE]PTEDATFIN)>0 & dim([M:PTE0]PTEDATFIN)>0
 [M:CPTE]PTEDATFIN = [M:PTE0]PTEDATFIN
Endif
If dim([M:CPTE]PTESTA1)>0 & dim([M:PTE0]PTESTA1)>0
 [M:CPTE]PTESTA1 = [M:PTE0]PTESTA1
Endif
If dim([M:CPTE]PTESTA2)>0 & dim([M:PTE0]PTESTA2)>0
 [M:CPTE]PTESTA2 = [M:PTE0]PTESTA2
Endif
If dim([M:CPTE]PTESTA3)>0 & dim([M:PTE0]PTESTA3)>0
 [M:CPTE]PTESTA3 = [M:PTE0]PTESTA3
Endif
If dim([M:CPTE]PTESTA4)>0 & dim([M:PTE0]PTESTA4)>0
 [M:CPTE]PTESTA4 = [M:PTE0]PTESTA4
Endif
If dim([M:CPTE]PTESTA5)>0 & dim([M:PTE0]PTESTA5)>0
 [M:CPTE]PTESTA5 = [M:PTE0]PTESTA5
Endif
If dim([M:CPTE]PTETYP)>0 & dim([M:PTE0]PTETYP)>0
 [M:CPTE]PTETYP = [M:PTE0]PTETYP
Endif
Return

$ENTCRIT
If dim([M:CPTE]CPY)>0 & dim([M:PTE0]CPY)>0
[M:PTE0]CPY = [M:CPTE]CPY
Endif
If dim([M:CPTE]FCY)>0 & dim([M:PTE0]FCY)>0
[M:PTE0]FCY = [M:CPTE]FCY
Endif
If dim([M:CPTE]PAUS)>0 & dim([M:PTE0]PAUS)>0
[M:PTE0]PAUS = [M:CPTE]PAUS
Endif
If dim([M:CPTE]PTEUOM)>0 & dim([M:PTE0]UOM)>0
[M:PTE0]UOM = [M:CPTE]PTEUOM
Endif
If dim([M:CPTE]PJTDEBC)>0 & dim([M:PTE0]PJTDEB)>0
[M:PTE0]PJTDEB = [M:CPTE]PJTDEBC
Endif
If dim([M:CPTE]PJTFINC)>0 & dim([M:PTE0]PJTFIN)>0
[M:PTE0]PJTFIN = [M:CPTE]PJTFINC
Endif
If dim([M:CPTE]PJTDSPALL)>0 & dim([M:PTE0]PJTDSPALL)>0
[M:PTE0]PJTDSPALL = [M:CPTE]PJTDSPALL
Endif
If dim([M:CPTE]PTEDATDEB)>0 & dim([M:PTE0]PTEDATDEB)>0
[M:PTE0]PTEDATDEB = [M:CPTE]PTEDATDEB
Endif
If dim([M:CPTE]PTEDATFIN)>0 & dim([M:PTE0]PTEDATFIN)>0
[M:PTE0]PTEDATFIN = [M:CPTE]PTEDATFIN
Endif
If dim([M:CPTE]PTESTA1)>0 & dim([M:PTE0]PTESTA1)>0
[M:PTE0]PTESTA1 = [M:CPTE]PTESTA1
Endif
If dim([M:CPTE]PTESTA2)>0 & dim([M:PTE0]PTESTA2)>0
[M:PTE0]PTESTA2 = [M:CPTE]PTESTA2
Endif
If dim([M:CPTE]PTESTA3)>0 & dim([M:PTE0]PTESTA3)>0
[M:PTE0]PTESTA3 = [M:CPTE]PTESTA3
Endif
If dim([M:CPTE]PTESTA4)>0 & dim([M:PTE0]PTESTA4)>0
[M:PTE0]PTESTA4 = [M:CPTE]PTESTA4
Endif
If dim([M:CPTE]PTESTA5)>0 & dim([M:PTE0]PTESTA5)>0
[M:PTE0]PTESTA5 = [M:CPTE]PTESTA5
Endif
If dim([M:CPTE]PTETYP)>0 & dim([M:PTE0]PTETYP)>0
[M:PTE0]PTETYP = [M:CPTE]PTETYP
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


