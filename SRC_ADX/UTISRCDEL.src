#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# UTISRCDEL: script used to delete a source X3 script that shouldn't be in a folder
#############################################################################

Local Mask ACOMPOBJ [ACMP]
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTISRCDEL: SRC control and deletion") From LECFIC

Call SRC_LIST

Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End


##################################
Subprog SRC_LIST
Local Char DOSSIER(30) : DOSSIER=nomap
Local Integer LRET
Local Char LTITLE(200) : LTITLE=mess(936,9900,1) # Scripts
Local Char LFROM(200)  : LFROM =mess(94,100,1)   # From
Local Char LTO  (200)  : LTO   =mess(95,100,1)   # To

Call SAIDOS(GDOSSIER,mess(117,124,1)) From SAIDOS : # Changement de dossier
If [L]DOSSIER="" [L]DOSSIER=nomap Endif
If [L]DOSSIER<>""
   If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
   Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

   Local Char ADCDEB(GLONADC)
   Local Char ADCFIN(GLONADC)
   [L]ADCDEB=""
   [L]ADCFIN=""
   If !GBATCH
     Call SAICAR([L]ADCDEB,[L]LTITLE,[L]LFROM,"ADC",0,GLONADC,"",[L]LRET) From GESECRAN
     If [L]ADCFIN="" [L]ADCFIN=[L]ADCDEB Endif
     Call SAICAR([L]ADCFIN,[L]LTITLE,[L]LTO,"ADC",0,GLONADC,"",[L]LRET) From GESECRAN
   Endif
   If [L]ADCDEB=""
      [L]ADCDEB="CFGLIB"
      [L]ADCFIN="CFGLIBE"
   Endif
   If [L]ADCFIN>=[L]ADCDEB
      Call FOLDER_SRC_LIST([L]DOSSIER,[L]ADCDEB,[L]ADCFIN,LRET)
   Endif
Endif
End

##################################
Subprog FOLDER_SRC_LIST(DOSSIER,ADCDEB,ADCFIN,LRET)
Value Char DOSSIER
Value Char ADCDEB
Value Char ADCFIN
Value Integer LRET

Local Integer LRET

# Traitement des Fiches
  Call ECR_TRACE("---- Folder "+DOSSIER,0) From GESECRAN
  Gosub CHECK_ADC

End



#### Extrait de ACOMPOBJ ####
$CHECK_ADC
Local Integer  NB_ADC
Local Integer  DIF
Local Integer  PATCH,EXCEL,TRACE
Local Char     CRITERE(250)

## Number of scripts to check/delete
Raz NB_ADC

 If filinfo(filpath("FIL","ADICTRT","fde",[L]DOSSIER),0)>0
  If [L]DOSSIER=nomap
   Local File ADICTRT [ADC1]
  Else
   Local File =[L]DOSSIER+".ADICTRT" [ADC1]
  Endif
 Endif
 Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
 Local Char    ORDRE(200)
 Local Integer I , OK , CMPDIC
 CRITERE = "1=1"
 If [L]ADCDEB="" & [L]ADCFIN="ZZZZZZZZZZZZ"
  If GADONIX=2
   CRITERE += "& [F:TRT_]TRAIT<'X' & !find(left$([F:TRT_]TRAIT,4),'SUBX','SUBY','SUBZ')"
  Endif
 Else
  CRITERE += "& [F:TRT_]TRAIT>=[L]ADCDEB & [F:TRT_]TRAIT<=[L]ADCFIN"
 Endif
 If left$([L]ADCDEB,1)<>"W" & left$([L]ADCFIN,1)<>"W"
  CRITERE += '& left$([F:TRT_]TRAIT,1)<>"W"'
 Endif
 CMPDIC = (([L]ADCDEB<>"") & clalev([F:ADC1])>0)
 Call MACHINE([L]DOSSIER,MACHINE,APPLI) From ORDSYS
 ORDRE = MACHINE+'@lsadx -a '+APPLI-' TRT src'
 Local File (TRAIT(GLONADC)) From System ORDRE As [TRT_]
 For [TRT_]
  If [F:TRT_]TRAIT<>"" & evalue(CRITERE)
   If CMPDIC
    Read [ADC1]ADC0 = [F:TRT_]TRAIT
    # Source script delivered can not be suppressed
    If fstat | [F:ADC1]SRC<>2
      NB_ADC += 1
      Gosub SUPPRESS_SRC_FILE
    Endif
   Endif
  Endif
  If NB_ADC>9 Break Endif # Maximum 9 files ?
 Next TRT_
 Close Local File [TRT_]
 If clalev([F:ADC1])>0
  Close Local File [ADC1]
 Endif

Return

$SUPPRESS_SRC_FILE
  Local Integer STAT
  Local Char    W_FICSRC(250)
  If left$([L]DOSSIER,5)<>"X3IND" & [L]DOSSIER<>"GX3APP" & GUSER="ADMIN"
    # mess(2,20,1) : Script
    W_FICSRC = filpath("TRT",[F:TRT_]TRAIT,"src",[L]DOSSIER)
    If filinfo(W_FICSRC,0)>=0
      Call ECR_TRACE(mess(2,20,1)-num$(NB_ADC)-[F:TRT_]TRAIT-"Suppressed",0) From GESECRAN
      Call EFFACE(W_FICSRC,STAT) From ORDSYS
    Endif
  Else
    Call ECR_TRACE(mess(2,20,1)-num$(NB_ADC)-[F:TRT_]TRAIT-"could not be suppressed",-1) From GESECRAN
  Endif
Return

########################################################################
# Issue 109347
Subprog PATCH(APPLI)
Value Char    APPLI
End

