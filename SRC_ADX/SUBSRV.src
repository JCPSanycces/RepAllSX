#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management SRV
Call OBJET("SRV",GBIDC1,"") From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "APRES_CRE" : Gosub APRES_CRE
 When "APRES_MOD" : Gosub APRES_MOD
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "AP_ANNULE" : Gosub AP_ANNULE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AS_COD"    : Raz GCURLEG        :#Used in SELOBJETL action to disable the filter under the current legislation
#JASMI - 2016-09-26 - START
 When "SEL_TABLE" : Gosub SEL_TABLE
#JASMI - 2016-09-26 - END
Endcase

Return

########################################
$OUVRE
If clalev ([F:CCE])=0 : Local File =GTABCPT+"CACCE" [CCE] : Endif
If clalev ([F:DSP])=0 : Local File =GTABCPT+"CADSP" [DSP] : Endif
If clalev ([F:ESB])=0  : Local File EMPSBD        [ESB]  : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################################
$LIENS
GCURLEG = [F:SRV]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]DES,"SERVICE","DES",[M]COD,"") From ATEXTRA
Call LECTEXTRA([M]DESSHO,"SERVICE","DESSHO",[M]COD,"") From ATEXTRA

#[DBA] 24\05\12 :  Waiting new link with accouting module
#If GOPTCANA>0
# [M]NBRCCE = GOPTCANA
#Endif
#JOJAC - 2017-01-31 - START
#Effzo [M]ACCCOD : Grizo [M]ACCCOD
#JOJAC - 2017-01-31 - END

#92876 US2583
#If GOPTCANA>0
# [M:SRV1]NBRCCE = GOPTCANA
#Endif

If dim([M:SRV1]DIE)>0
   # Rang 2 dans le menu 2230 Service
   #JOJAC - 2017-01-24 - START
   #Call INIT_DIE(2,"","SRV1","NBRCCE","SRV","DIE","CCE","DIE","CCE") From TRTHRCPT
   Call CHARG_DIE(19,"","SRV1","NBRCCE","SRV","DIE","CCE","DIE","CCE") From TRTHRCPT
   #JOJAC - 2017-01-24 - END
   Affzo [SRV1]40
Endif
#END 92876 US2583

#

#MAPAD - 2016-02-22 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBSRVLEG
#MAPAD - 2016-02-22 - Req 114309 - END

Return

########################################
$RAZCRE

Raz GCURLEG #New - Reset
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#If GOPTCANA>0
# [M:SRV1]NBRCCE = GOPTCANA
#Endif
Affzo 30


#92876 US2583
If dim([M:SRV1]DIE)>0
   # Rang 2 dans le menu 2230 Service
   #JOJAC - 2017-01-24 - START
   #Call INIT_DIE(2,"","SRV1","NBRCCE","SRV","DIE","CCE","DIE","CCE") From TRTHRCPT
   Call INIT_DIE(19,"","SRV1","NBRCCE","SRV","DIE","CCE","DIE","CCE") From TRTHRCPT
   #JOJAC - 2017-01-24 - END
   Affzo [SRV1]40
Endif
#END 92876 US2583

#MAPAD - 2016-02-22 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBSRVLEG
#MAPAD - 2016-02-22 - Req 114309 - END



Return

########################################
$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call AUTSRV From GLOBPAY
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub MAJ_ESB
If [V]GOK<0 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("SERVICE","DES",CLECUR1,"","SERVICE","DES",[F:SRV]COD,"")  From ATEXTRA
 Call DUPTEXTRA("SERVICE","DESSHO",CLECUR1,"","SERVICE","DESSHO",[F:SRV]COD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"SERVICE","DES",[F:SRV]COD,"") From ATEXTRA
Call MAJTEXTRA([M]DESSHO,"SERVICE","DESSHO",[F:SRV]COD,"") From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("SERVICE","DES",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
Call CHGTEXTRA("SERVICE","DESSHO",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
Call AUTSRV From GLOBPAY
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("SERVICE","DES",[L]CODE,"") From ATEXTRA
Call SUPTEXTRA("SERVICE","DESSHO",[L]CODE,"") From ATEXTRA
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

#MAPAD - 2016-02-22 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBSRVLEG
#MAPAD - 2016-02-22 - Req 114309 - END

Return

########################################
Subprog C_MODCOM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AV_CHEFNAM(VALEUR)
Variable Char    VALEUR()
If [M]CHEF(nolign-1)="" : [L]VALEUR="" : End : Endif
If !clalev([F:ID]) : Local File EMPLOID [ID] : Endif
Read [ID]ID0=[M]CHEF(nolign-1)
[L]VALEUR=toupper([F:ID]NAM)-tolower([F:ID]SRN)
End

########################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
 Effzo [M]CHEF,CHEFNAM
Endif

GCURLEG = VALEUR

#MAPAD - 2016-02-22 - Req 114309 - START
  Call DISPLAY_HIDE() From SUBSRVLEG
#MAPAD - 2016-02-22 - Req 114309 - END

End

############################################
$MAJ_ESB
Local  Integer L_K
If clalev([F:CTR1])=0 : Local File EMPLOCTR    [CTR1] : Endif
Delete [ESB] Where [F:ESB]SRV=[F:SRV]COD & [F:ESB]NIVEAU=3
If fstat=1
   GOK = -1 : GLOCK = "$EMPSBD"-[F:ESB]REFNUM-[F:ESB]CTRNUM-[F:ESB]CTRDAT-num$(3)-num$([F:ESB]RANG)
Endif
If !GOK  Then Return Endif
Filter [F:CTR1] Where ETRSRV=[F:SRV]COD
If rowcount([F:CTR1]) > 0 Then
    For [F:CTR1]CTR1
      For L_K=0 To len(mess(0,50,1))
          If [F:SRV]CHEF(L_K)<> ""
              Raz [F:ESB]
              [F:ESB]REFNUM=[F:CTR1]REFNUM
              [F:ESB]CTRNUM=[F:CTR1]CTRNUM
              [F:ESB]CTRDAT=[F:CTR1]CTRDAT
              [F:ESB]CHEF=[F:SRV]CHEF(L_K)
              [F:ESB]NIVEAU=3
              [F:ESB]RANG=L_K+1
              Gosub WRITE_ESB
              If !GOK : Break 2 : Endif
          Endif
      Next L_K
    Next
Endif
Return

########################################
$WRITE_ESB
Read [F:ESB]ESB0 = [F:CTR1]REFNUM;[F:CTR1]CTRNUM;[F:CTR1]CTRDAT;[F:SRV]CHEF(L_K);3;L_K+1
If fstat
 [F:ESB]SRV=[F:SRV]COD
 If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
 If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
 If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
 Write [F:ESB]
Else
 [F:ESB]SRV=[F:SRV]COD
 If dim([F:ESB]CREDAT)>0 : [F:ESB]CREDAT = date$     : Endif
 If dim([F:ESB]CRETIM)>0 : [F:ESB]CRETIM = time      : Endif
 If dim([F:ESB]CREUSR)>0 : [F:ESB]CREUSR = GUSER     : Endif
 Rewrite [F:ESB]
Endif
If fstat
 GOK = 0 : Call FSTA("ESB") From GLOCK : Return
Endif
Return

#JOJAC - 2016-08-02 - X3PEOP-943 - START
Subprog CONTSRV(COD)
Variable Char    COD()

If GFONCTION = "GESRV" | COD="" : End : Endif

If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif

If COD <> ""
  Filter [F:SRV] Where COD=[L]COD
  Read [F:SRV] First
  Filter [F:SRV]
  If fstat
      GMESSAGE = COD-":"-mess(23,100,1)
      mkstat = 2 : End
  Endif
#  Else
#      Filter [F:SRV] Where LEG = GCURLEG & COD = [L]COD
#      Read [F:SRV] First
#      Filter [F:SRV]
#      If fstat
#        Filter [F:SRV] Where COD=[L]COD
#        Read [F:SRV] First
#        Filter [F:SRV]
#        If [F:SRV]LEG<>""
#          GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:SRV]LEG
#          mkstat = 2 : End
#        Endif
#      Endif
#  Endif
Endif
Filter [F:SRV]
End

$SEL_TABLE
Case TABLE
  When "SELSRV"
    If clalev ([F:SRV])=0 : Local File SERVICE [SRV] : Endif
    Filter [F:SRV]
    OBJET     = "SRV"
    If PARAM(1)<>""
      Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:SRV]LEG="'+PARAM(1)+'" | [F:PVH]SRV="")',"&") From GOBJSUB
    Endif
Endcase
Return

Subprog TUNSRV(COD)
Variable Char    COD()

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONSRV)
 TOKILL = 1
Endif
If clalev([F:SRV])=0 : Local File SERVICE [SRV] : Endif
# To update the PRF code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#If no code is specified, it's better to select one of the curent legislation
  Filter [SRV] Where LEG=GCURLEG
  Read [F:SRV] First
  Filter [SRV]
  If !fstat : VCOD=[F:SRV]COD : Endif
Else
  Read [SRV]SRV0 = VCOD
Endif
Call OBJET("SRV",VCOD,GCURLEG) From GOBJET
COD = VCOD
If TOKILL : Kill VCOD : Endif
End
#JOJAC - 2016-08-02 - X3PEOP-943 - END

