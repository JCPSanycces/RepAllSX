$GET_JSON_STRUCTURE
Local Integer PC(1..12),DC(1..12)
PC(1)  = 1
PC(2)  = (instr(1,"qbl",AF)>0)
PC(4)  = (instr(1,"eqbl",AF)>0)
PC(5)  = (instr(1,"qbel",AF)>0)
PC(6)  = (instr(1,"qb",AF)>0)
PC(7)  = (instr(1,"qbe",AF)>0)
PC(8)  = (instr(1,"e",AF)>0)
PC(9)  = (instr(1,"d",AF)>0)
PC(10) = (instr(1,"q",AF)>0)
PC(11) = (instr(1,"l",AF)>0)
PC(12) = (instr(1,"s",AF)>0)
Return
