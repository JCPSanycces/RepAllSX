#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMAPPROVER_RSTD, Change Request - Approver and Recommendation Collections
###############################################################################
# Issue 110210/8 - 2015-12-14 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When "NCSREC.NCSAPPROVER"
      Case [L]AEVENT
        When "AREAD_AFTER"
          Gosub POPULATE_APPROVER_NAME
          Gosub ACTIVATE_APPROVER_FIELDS
        When "ADDLINE_BEFORE"
          Gosub CLEAR_ERRORS
          Gosub APPROVER_CHECK_ADDLINE
        When "ADDLINE_AFTER"
          Gosub ACTIVATE_APPROVER_FIELDS
        When "ADELLINE_BEFORE"
          Gosub APPROVER_CHECK_ADELLINE
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "NCSREC.NCSAPPROVER.NCSAPPUSR"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub POPULATE_APPROVER_NAME
          Gosub ACTIVATE_APPROVER_FIELDS
      Endcase
  Endcase
Return

###############################################################################

# --------------------------------------------------
# Populate approver name display only properties.
$POPULATE_APPROVER_NAME

  Local Instance SELUSER Using C_AUTILIS

  SELUSER = NewInstance C_AUTILIS AllocGroup null
  ASTATUS = fmet SELUSER.AREAD(this.NCSAPPUSR)
  If (ASTATUS <> [V]CST_AOK)
    ASTATUS = fmet this.ASETERROR ("", "", [V]CST_AERROR)
  Else
    this.USERNAM = SELUSER.INTUSR
  Endif

  FreeGroup SELUSER

Return

# --------------------------------------------------
# Enable / disable approver fields at a child class level.
$ACTIVATE_APPROVER_FIELDS

  Local Integer LOCSTATUS

  # Default: all disabled ...
  LOCSTATUS = fmet this.ASETATTRIBUTE("NCSAPPUSR",   "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("TRANSTYPE",  "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("APPRSTAT",   "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("APPRREASON", "$isDisabled",  "true")

  # Change Manager: enable User and Transaction Type ...
  If (this.APARENT.CRSTATUS = 2)
    If (this.ACTX.USER = this.APARENT.NCSMANAGER)
      LOCSTATUS = fmet this.ASETATTRIBUTE("NCSAPPUSR",   "$isDisabled",  "false")
      LOCSTATUS = fmet this.ASETATTRIBUTE("TRANSTYPE",  "$isDisabled",  "false")
    Endif

    # Approver: enable Approval status and Reason ...
    If (this.ACTX.USER = this.NCSAPPUSR)
      LOCSTATUS = fmet this.ASETATTRIBUTE("APPRSTAT",   "$isDisabled",  "false")
      LOCSTATUS = fmet this.ASETATTRIBUTE("APPRREASON", "$isDisabled",  "false")
    Endif
  Endif

Return

# --------------------------------------------------
# Clear (any) errors.
$CLEAR_ERRORS

  ASTATUS = fmet this.ADELETEERROR ("")

Return

# --------------------------------------------------
# Approver collection: before ADDLINE check the logged-in user is the Change Manager, and
# the Change Request is "In Review" ...
$APPROVER_CHECK_ADDLINE

  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(6,3702,1), [V]CST_AERROR)
  Elsif (this.NCSMANAGER <> this.ACTX.USER or this.CRSTATUS <> 2)
      ASTATUS = fmet this.ASETERROR ("", mess(2,3702,1), [V]CST_AERROR)
  Endif

Return

# --------------------------------------------------
# Approver collection: before ADELLINE check the logged-in user is the Change Manager ...
$APPROVER_CHECK_ADELLINE

  Local Char MESSAGE(100)
  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(6,3702,1), [V]CST_AERROR)
  Elsif(this.ACTX.USER <> this.NCSMANAGER or this.CRSTATUS <> 2)
     ASTATUS = fmet this.ASETERROR ("", mess(2,3702,1), [V]CST_AERROR)
  Endif

Return

