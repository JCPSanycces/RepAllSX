Return

$LNKPRO_PURBASPRI
Gosub DECLARE_VAR From WMC0ITMMASTER
[L]CURPRO = "PURBASPRI"
$_LNKPRO_PURBASPRI
Local Char AFORMAT(50)
[L]ASTATUS =  func ASYRTRTATY.GETFORMATMD5(this,"PURBASPRI",this.PURBASPRI,[L]AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]AFORMAT<>''
[L]AFORMAT='"'+[L]AFORMAT+'"'
[L]ASTATUS = fmet this.ASETATTRIBUTE("PURBASPRI","$x3Format",[L]AFORMAT)
Endif
Return


