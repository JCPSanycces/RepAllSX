####################################################################
# 121 : PLMITMREF PLM product ( Field PLM 70)
####################################################################

$SET_PLMITMREF
If [L]_AOLDVAL<>this.PLMITMREF
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_PLMITMREF
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.PLMITMREF
 Gosub PROPAGATE_PLMITMREF
Endif
Return

$INIT_PLMITMREF
Gosub DECLARE_VAR From WMC0ITMMASTER
[L]CURPRO = "PLMITMREF"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_PLMITMREF
Gosub DECLARE_VAR From WMC0ITMMASTER
[L]CURPRO = "PLMITMREF"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_PLMITMREF             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_PLMITMREF             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_PLMITMREF
[L]CURPRO = "PLMITMREF"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.PLMITMREF,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_PLMITMREF
[L]CURPRO = "PLMITMREF"
If vireblc(this.PLMITMREF,2)<>vireblc(format$("K:70X",this.PLMITMREF),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_PLMITMREF
[L]CURPRO = "PLMITMREF"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_PLMITMREF
[L]CURPRO = "PLMITMREF"
Return

$PROPAGATE_PLMITMREF
this.isReadonly = 0
[L]CURPRO = "PLMITMREF"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_PLMITMREF
Gosub DECLARE_VAR From WMC0ITMMASTER
[L]CURPRO = "PLMITMREF"
$_LNKPRO_PLMITMREF
Return


