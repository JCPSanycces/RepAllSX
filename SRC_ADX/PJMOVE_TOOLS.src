  Gosub LOCAL_FILE_PJMTSKOPE From PJMOVE
  # -------------------------
  Filter [PTKO] Where evalue(SFILTER) and [F:PTKO]OPPNUM = SOPPNUM and [F:PTKO]TASCOD = TAS
  For [PTKO]
    [L]ARET_VALUE += [F:PTKO]EXTQTY * [F:PTKO]OPECST2
  Next
  Filter [PTKO]
End [L]ARET_VALUE

#######################################################################################
Funprog TAS_PROGRESS_ALL_TASKS(SOPPNUM, UOM)
Value Char SOPPNUM
Value Char UOM ()

Local Decimal ARET_VALUE
Local Decimal NCSMTOT
Local Decimal NRMNTOT

  [L]ARET_VALUE = 0
  # -------------------
  NCSMTOT = func TAS_COMPUTE_CSMQTY_ALL_TASKS(SOPPNUM, UOM)
  NRMNTOT = func TAS_COMPUTE_RMNQTY_ALL_TASKS(SOPPNUM, UOM)
  # -------------------
  If NCSMTOT <> 0 Then
    [L]ARET_VALUE = ar2(NCSMTOT / (NCSMTOT + NRMNTOT) * 100)
  Endif
End [L]ARET_VALUE

#######################################################################################
Funprog TAS_START_END_DATE(SOPPNUM, BUD, STRDAT, ENDDAT)
Value Char SOPPNUM
Value Char BUD
Variable Date STRDAT
Variable Date ENDDAT

Local Decimal ARET_VALUE
Local Integer IISPARENT
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = [V]CST_AOK
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  # -------------------------
  Gosub LOCAL_FILE_PJMBUD From PJMOVE
  # -------------------------
  IISPARENT = [V]CST_ANO
  Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = BUD
  For [PJBU]
    IISPARENT = [V]CST_AYES
    [L]ARET_VALUE = func TAS_START_END_DATE([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, STRDAT, ENDDAT)
  Next
  Filter [PJBU]
  # -------------------------
  Gosub LOCAL_FILE_PJMTSK From PJMOVE
  # -------------------------
  Filter [PJTA] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]PBUCOD = BUD
  For [PJTA]
    If STRDAT = [0/0/0] or [F:PJTA]TASSTARTDT < STRDAT Then
      STRDAT = [F:PJTA]TASSTARTDT
    Endif
    # ----------------------------------------
    If ENDDAT = [0/0/0] or [F:PJTA]TASENDDT > ENDDAT Then
      ENDDAT = [F:PJTA]TASENDDT
    Endif
  Next
  Filter [PJTA]
End [L]ARET_VALUE

#######################################################################################
Funprog TAS_PROGRESS(SOPPNUM, TAS)
Value Char SOPPNUM
Value Char TAS

Local Decimal DCSMTOT
Local Decimal DRMNTOT
Local Decimal ARET_VALUE
Local Integer IRET

  [L]ARET_VALUE = 0
  # -------------------------
  DCSMTOT = 0
  DRMNTOT = 0
  IRET = func _TAS_PROGRESS(SOPPNUM, TAS, DCSMTOT, DRMNTOT)
  If DCSMTOT <> 0 Then
    [L]ARET_VALUE = ar2(DCSMTOT / (DCSMTOT + DRMNTOT) * 100)
  Endif
End [L]ARET_VALUE

#######################################################################################
Funprog _TAS_PROGRESS(SOPPNUM, TAS, NCSMTOT, NRMNTOT)
Value Char SOPPNUM
Value Char TAS ()
Variable Decimal NCSMTOT
Variable Decimal NRMNTOT

Local Decimal ARET_VALUE
Local Integer IISPARENT
Local Decimal NLCSMTOT
Local Decimal NLRMNTOT
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = [V]CST_AOK
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  # -------------------------
  NLCSMTOT = 0
  NLRMNTOT = 0
  # -------------------------
  Gosub LOCAL_FILE_PJMTSK From PJMOVE
  # -------------------------
  IISPARENT = [V]CST_ANO
  Filter [PJTA] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]TASPAE = TAS
  For [PJTA]
    IISPARENT = [V]CST_AYES
    [L]ARET_VALUE = func _TAS_PROGRESS([F:PJTA]OPPNUM, [F:PJTA]TASCOD, NCSMTOT, NRMNTOT)
  Next
  Filter [PJTA]
  # -------------------------
  IRET = func RTKO_GET_PROGRESS(SOPPNUM, TAS, NCSMTOT, NRMNTOT)
  NCSMTOT += NLCSMTOT
  NRMNTOT += NLRMNTOT
End [L]ARET_VALUE

#######################################################################################
Funprog RTKO_GET_PROGRESS(SOPPNUM, TAS, NCSMTOT, NRMNTOT)
Value Char SOPPNUM
Value Char TAS ()
Variable Decimal NCSMTOT
Variable Decimal NRMNTOT

Local Decimal ARET_VALUE
Local Decimal NLCSMTOT
Local Decimal NLRMNTOT
Local Char SCOMUOM(GLONUOM)
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = [V]CST_AOK
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  # -------------------------
  SCOMUOM = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, GACTX.AFOLDER, "HOURLYUNIT")
  # -------------------------
  Gosub LOCAL_FILE_PJMTSKOPE From PJMOVE
  # -------------------------
  Filter [PTKO] Where evalue(SFILTER) and [F:PTKO]OPPNUM = SOPPNUM and [F:PTKO]TASCOD = TAS
  For [PTKO]
    NLCSMTOT = [F:PTKO]CSMQTY
    NLRMNTOT = [F:PTKO]RMNQTY
    If [F:PTKO]OPEUOM2 <> SCOMUOM Then
      Call CONVERT_QTY(GACTX, [F:PTKO]OPEUOM2, SCOMUOM, NLCSMTOT) From TRTX3_SYRA
      Call CONVERT_QTY(GACTX, [F:PTKO]OPEUOM2, SCOMUOM, NLRMNTOT) From TRTX3_SYRA
    Endif
    NCSMTOT += NLCSMTOT
    NRMNTOT += NLRMNTOT
  Next
  Filter [PTKO]
End [L]ARET_VALUE

#######################################################################################
Funprog RTKO_PROGRESS(CSMQTY, RMNQTY)
Value Decimal CSMQTY
Value Decimal RMNQTY

Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  If CSMQTY <> 0 Then
    [L]ARET_VALUE = ar2(CSMQTY / (CSMQTY + RMNQTY) * 100)
  Endif
End [L]ARET_VALUE

#######################################################################################
Funprog RTKO_EXTAMT(PLNQTY, LABCST)
Value Decimal PLNQTY
Value Decimal LABCST

Local Decimal ARET_VALUE

  [L]ARET_VALUE = PLNQTY * LABCST
End [L]ARET_VALUE

#######################################################################################
Funprog PJOA_PROGRESS(CSMQTY, RMNQTY)
Value Decimal CSMQTY
Value Decimal RMNQTY

Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  If CSMQTY <> 0 Then
    [L]ARET_VALUE = ar2(CSMQTY / (CSMQTY + RMNQTY) * 100)
  Endif
End [L]ARET_VALUE

