#######################################################################################
#######################################################################################
# Budgets
#######################################################################################
Funprog BUD_COMPUTE_QTYBUD_ALL_BUDGETS(SOPPNUM, UOM)
Value Char SOPPNUM
Value Char UOM

Local Decimal ARET_VALUE
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  ARET_VALUE = 0
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  Call GET_PJMBUD_FILTER(SFILTER) From PJMOVE    # Issue X3-91018 - 2018-05-21 by TEJAC
  # -------------------------
  Gosub LOCAL_FILE_PJMBUD From PJMOVE
  # -------------------------
  Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = AVOID.ACHAR
  For [PJBU]
    [L]ARET_VALUE += func BUD_COMPUTE_QTYBUD([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, UOM)
  Next
  Filter [PJBU]
End [L]ARET_VALUE

#######################################################################################
Funprog BUD_COMPUTE_QTYBUD(SOPPNUM, BUD, UOM)
Value Char SOPPNUM
Value Char BUD
Value Char UOM

Local Decimal ARET_VALUE
Local Integer IISPARENT
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = 0
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  Call GET_PJMBUD_FILTER(SFILTER) From PJMOVE    # Issue X3-91018 - 2018-05-21 by TEJAC
  # -------------------------
  Gosub LOCAL_FILE_PJMBUD From PJMOVE
  # -------------------------
  IISPARENT = [V]CST_ANO
  Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = BUD
  For [PJBU]
    IISPARENT = [V]CST_AYES
    [L]ARET_VALUE += func BUD_COMPUTE_QTYBUD([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, UOM)
  Next
  Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUCOD = BUD
  For [PJBU]
    [L]ARET_VALUE += func BUDLIG_COMPUTE_QTYBUD([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, UOM)
  Next
  Filter [PJBU]
End [L]ARET_VALUE

#######################################################################################
Funprog BUDLIG_COMPUTE_QTYBUD(SOPPNUM, BUD, UOM)
Value Char SOPPNUM
Value Char BUD
Value Char UOM

Local Decimal ARET_VALUE
Local Decimal CONQTY
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = 0
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  Call GET_PJMBUD_FILTER(SFILTER) From PJMOVE    # Issue X3-91018 - 2018-05-21 by TEJAC
  # -------------------------
  Gosub LOCAL_FILE_PJMBUDLIG From PJMOVE
  # -------------------------
  Filter [PJLB] Where evalue(SFILTER) and [F:PJLB]OPPNUM = SOPPNUM and [F:PJLB]PBUCOD = BUD
  For [PJLB]
    CONQTY = [F:PJLB]PLBQTY
    If [F:PJLB]PLBU <> UOM Then
      Call CONVERT_QTY(GACTX, [F:PJLB]PLBU, UOM, CONQTY) From TRTX3_SYRA
    Endif
    [L]ARET_VALUE += CONQTY
  Next
  Filter [PJLB]
End [L]ARET_VALUE

