  # -------------------------
  Gosub LOCAL_FILE_PJMBUDLIG From PJMOVE
  # -------------------------
  Filter [PJLB] Where evalue(SFILTER) and [F:PJLB]OPPNUM = SOPPNUM and [F:PJLB]PBUCOD = BUD
  For [PJLB]
    [L]ARET_VALUE += [F:PJLB]PLBAMT
  Next
  Filter [PJLB]
End [L]ARET_VALUE

#######################################################################################
Funprog BUD_PROGRESS(SOPPNUM, BUD)
Value Char SOPPNUM
Value Char BUD

Local Decimal DCSMTOT
Local Decimal DRMNTOT
Local Decimal ARET_VALUE
Local Integer IRET

  [L]ARET_VALUE = 0
  # -------------------------
  DCSMTOT = 0
  DRMNTOT = 0
  IRET = func _BUD_PROGRESS(SOPPNUM, BUD, DCSMTOT, DRMNTOT)
  If DCSMTOT <> 0 Then
    [L]ARET_VALUE = ar2(DCSMTOT / (DCSMTOT + DRMNTOT) * 100)
  Endif
End [L]ARET_VALUE

#######################################################################################
Funprog _BUD_PROGRESS(SOPPNUM, BUD, CSMTOT, RMNTOT)
Value Char SOPPNUM
Value Char BUD
Variable Decimal CSMTOT
Variable Decimal RMNTOT

Local Decimal ARET_VALUE
Local Decimal NCSMTOT
Local Decimal NRMNTOT
Local Integer IISPARENT
Local Char SFILTER(250)(0..)           # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : become an array

  [L]ARET_VALUE = [V]CST_AOK
  Call LOAD_FILTER(SFILTER) From PJMOVE          # Issue X3-91018 - 2018-05-21 by TEJAC/FGR : #SFILTER = func LOAD_FILTER()
  Call GET_PJMBUD_FILTER(SFILTER) From PJMOVE    # Issue X3-91018 - 2018-05-21 by TEJAC
  # -------------------------
  Gosub LOCAL_FILE_PJMBUD From PJMOVE
  # -------------------------
  IISPARENT = [V]CST_ANO
  Filter [PJBU] Where evalue(SFILTER) and [F:PJBU]OPPNUM = SOPPNUM and [F:PJBU]PBUPAE = BUD
  For [PJBU]
    IISPARENT = [V]CST_AYES
    [L]ARET_VALUE += func _BUD_PROGRESS([F:PJBU]OPPNUM, [F:PJBU]PBUCOD, CSMTOT, RMNTOT)
  Next
  # -------------------------
  Gosub LOCAL_FILE_PJMTSK From PJMOVE
  # -------------------------
  Filter [PJTA] Where evalue(SFILTER) and [F:PJTA]OPPNUM = SOPPNUM and [F:PJTA]PBUCOD = BUD
  For [PJTA]
    NCSMTOT = 0
    NRMNTOT = 0
    IRET = func _TAS_PROGRESS([F:PJTA]OPPNUM, [F:PJTA]TASCOD, NCSMTOT, NRMNTOT)
    CSMTOT += NCSMTOT
    RMNTOT += NRMNTOT
  Next
  Filter [PJTA]
End [L]ARET_VALUE

