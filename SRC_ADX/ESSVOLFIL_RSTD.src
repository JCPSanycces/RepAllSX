$AQUERY_OPEN_AFTER
Local Instance  IVOLUME Using C_AVOLUME
Local Integer   NBFILES
Local Char      FILES(255)(1..)
Local Char      VOLUME(GLONAVL)
Local Char      PATH(250),QWHERE(250)
Local Char      ASCDESC(5):ASCDESC="asc"
Local Integer   I,IROW,KEEP
Local Integer   NAMELENGTH : NAMELENGTH=250
Local Char     QWHERE(250)


[L]QWHERE = func ASYRMAIN.PARVAL(ARCV,"Where")
[L]VOLUME = func ASYRMAIN.PARVAL(ARCV,"VOLUME")
[L]PATH = func ASYRMAIN.PARVAL(ARCV,"FULLNAME")
#[L]PATH = func  GET_VALFILTER(QWHERE,"FULLNAME")

PQRY.QPARAMS(1) = "VOLUME=" + VOLUME
#SAM 109949 {
If len([L]PATH) > 0 Then
 PQRY.QPARAMS(2) = "FULLNAME=" + [L]PATH
Endif
#} SAM 109949

IVOLUME = NewInstance C_AVOLUME AllocGroup null
ASTATUS = fmet IVOLUME.AREAD(VOLUME)

If !ASTATUS
 If FIRSTPAGE
  NBFILES = PQRY.QCOUNT+1
 Endif

 If instr(1,INDEXES(PQRY.QASCEND),"desc")
  ASCDESC = "desc"
 Endif

 ASTATUS = fmet IVOLUME.LS([L]PATH,"",ASCDESC,[L]QWHERE,NBFILES,FILES)

 If !ASTATUS
  Local Char    TVOLUME(GLONAVL)(1..max(1,NBFILES)),TFULLNAME(NAMELENGTH)(1..max(1,NBFILES))
  Local File    (Char VOLUME(GLONAVL), Char FULLNAME(NAMELENGTH)) From Variable TVOLUME, TFULLNAME As [LNK_]

  For I=1 To NBFILES
   IROW += 1
   TVOLUME(IROW)      = VOLUME
   TFULLNAME(IROW)    = FILES(I)
  Next I
 Endif

Endif
FreeGroup IVOLUME
Return

$AQUERY_TRANS_AFTER
this.AVOLFIL.VOLUME    = [LNK_]VOLUME
this.AVOLFIL.FULLNAME  = [LNK_]FULLNAME
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]VOLUME;[LNK_]FULLNAME"
Return

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "VOLUME"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AVOLFIL.VOLUME"
             TBFIL(NBPRO) = "[LNK_]VOLUME"
NBPRO += 1 : TBPRO(NBPRO) = "FULLNAME"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AVOLFIL.FULLNAME"
             TBFIL(NBPRO) = "[LNK_]FULLNAME"
Return

Funprog GET_VALFILTER(_QWHERE,_CRITERIA)
Value Char  _QWHERE,_CRITERIA

Local Char VALFILTER(250),CRITERIA(250)
Local Integer  POS1,POS2

CRITERIA = _CRITERIA + " eq '"
POS1 = instr(1,_QWHERE,CRITERIA)
If POS1
 POS2 = instr(POS1+len(CRITERIA),_QWHERE,"'")
 If POS2
  [L]VALFILTER = mid$(_QWHERE,POS1+len(CRITERIA),POS2-(POS1+len(CRITERIA)))
 Endif
Endif

End VALFILTER




