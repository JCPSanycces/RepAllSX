#<AdxTL>@(#)0.0.0.0 $Revision$

# Structure TABCUR

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
       When "AINSERT_BEFORE"               : Gosub AINSERT_BEFORE
       When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
       When "AUPDATE_BEFORE"               : Gosub AUPDATE_BEFORE
       When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "DCURFMT1"     : Gosub DCURFMT1
  When "DCURFMT2"     : Gosub DCURFMT2
  When "DCURFMT3"     : Gosub DCURFMT3
  When "DECNBR"       : Gosub DECNBR
  When "EURFLG"       : Gosub EURFLG
  When "CURRND"       : Gosub CURRND
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




###############################################################################################################################
$AREAD_AFTER
Gosub TRANS_COLUMN_CLASS
Gosub MANDATORIES
Gosub SYNCHRONIZE_PROPERTIES
Return

###############################################################################################
$AINSERT_CONTROL_BEFORE
Gosub MANDATORIES
Gosub CONTROLS
Gosub SYNCHRONIZE_PROPERTIES
Return

###############################################################################################
$AINSERT_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

###############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub MANDATORIES
Gosub CONTROLS
Gosub SYNCHRONIZE_PROPERTIES
Return

###############################################################################################
$AUPDATE_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

###############################################################################################
$TRANS_CLASS_COLUMN
this.CURFMT1 = num$(this.DCURFMT1)
this.CURFMT2 = num$(this.DCURFMT2)
this.CURFMT3 = num$(this.DCURFMT3)
Return

###############################################################################################
$TRANS_COLUMN_CLASS
this.DCURFMT1 = val(this.CURFMT1)
this.DCURFMT2 = val(this.CURFMT2)
this.DCURFMT3 = val(this.CURFMT3)
Return

###############################################################################################
$CONTROLS
Local Decimal DEC1, DEC2, DEC3, DEC4, DEC5
Local Integer MY_STATUS

DEC1 = 10*(this.DCURFMT1-int(this.DCURFMT1))
DEC2 = 10*(this.DCURFMT2-int(this.DCURFMT2))
DEC3 = 10*(this.DCURFMT3-int(this.DCURFMT3))
DEC4 = this.DECNBR
If  this.CURRND>0
  DEC5 = -log(this.CURRND)
Elsif this.CURRND=0
  DEC5 = 0
  [L]ASTATUS = fmet this.ASETERROR("CURRND",mess(137,126,1),[V]CST_AWARNING)
Else
  [L]ASTATUS = fmet this.ASETERROR("CURRND",mess(126,143,1),[V]CST_AERROR)
Endif

If DEC1<>DEC2 or DEC1<>DEC3 or DEC2<>DEC3
  # Caution, incompatibility between the formats
  [L]MY_STATUS = fmet this.ASETERROR("DCURFMT1",mess(136,126,1),[V]CST_AWARNING)
Elsif DEC1<>DEC4
  # Caution, incompatibility between the formats and the number of decimals
  [L]MY_STATUS = fmet this.ASETERROR("DCURFMT1",mess(137,126,1),[V]CST_AWARNING)
Elsif DEC1<>DEC5
  # Caution, incompatibility between the formats and the rounding
  [L]MY_STATUS = fmet this.ASETERROR("DCURFMT1",mess(138,126,1),[V]CST_AWARNING)
Endif

[L]ASTATUS = max([L]ASTATUS,[L]MY_STATUS)

Return

######################################################################################################
$MANDATORIES
Gosub EURFLG_MANDATORY
Return

######################################################################################################
$SYNCHRONIZE_PROPERTIES
If this.EURFLG<>[V]CST_AYES
    this.EURRAT=AVOID.ADEC
    this.EURDAT=AVOID.ADATE
    this.CURENDDAT=AVOID.ADATE
    If this.EURFLG<>[V]CST_ANO
    	this.EURFLG=[V]CST_ANO
    Endif
Endif
Return

######################################################################################################
$DCURFMT1
Case [L]ARULE
  When "INIT"           : Gosub DCURFMT1_INIT
  When "CONTROL"        : Gosub DCURFMT1_CONTROL
Endcase
Return

###############################################################################################
$DCURFMT1_INIT
this.DCURFMT1 = 9.2
Return

$DCURFMT1_CONTROL
Local Char  MESSAGE(250)
Local Integer MY_STATUS
[L]MY_STATUS = func VERFMT(this.DCURFMT1,20,1,MESSAGE )
If [L]MY_STATUS<>CST_AOK
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,MESSAGE,[L]MY_STATUS)
Endif
Return

###############################################################################################
$DCURFMT2
Case [L]ARULE
  When "INIT"           : Gosub DCURFMT2_INIT
  When "CONTROL"        : Gosub DCURFMT2_CONTROL
Endcase
Return

###############################################################################################
$DCURFMT2_INIT
this.DCURFMT2 = 6.2
Return

$DCURFMT2_CONTROL
Local Char  MESSAGE(250)
Local Integer MY_STATUS
[L]MY_STATUS=func VERFMT(this.DCURFMT2,10,1,MESSAGE )
If [L]MY_STATUS<>CST_AOK
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,MESSAGE,[L]MY_STATUS)
Endif
Return

###############################################################################################
$DCURFMT3
Case [L]ARULE
 When "INIT"            : Gosub DCURFMT3_INIT
 When "CONTROL"         : Gosub DCURFMT3_CONTROL
Endcase
Return

###############################################################################################
$DCURFMT3_INIT
this.DCURFMT3 = 11.2
Return

$DCURFMT3_CONTROL
Local Char  MESSAGE(250)
Local Integer MY_STATUS
[L]MY_STATUS = func VERFMT(this.DCURFMT3,20,0,MESSAGE)
If [L]MY_STATUS<>CST_AOK
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,MESSAGE,[L]MY_STATUS)
Endif
Return

###############################################################################################
$DECNBR
Case [L]ARULE
  When "CONTROL"      : Gosub DECNBR_CONTROL
  When "PROPAGATE"    : Gosub DECNBR_PROPAGATE
Endcase
Return

$DECNBR_CONTROL
If this.DECNBR<=0
  [L]ASTATUS = fmet this.ASETERROR("DECNBR",mess(126,143,1),[V]CST_AERROR)
Endif
Return

$DECNBR_PROPAGATE
this.CURRND = 10^-this.DECNBR
Return

###############################################################################################
$EURFLG
Case [L]ARULE
  When "PROPAGATE"   : Gosub EURFLG_PROPAGATE
Endcase
Return

$EURFLG_PROPAGATE
Gosub EURFLG_MANDATORY
If this.EURFLG <> [V]CST_AYES
  this.EURRAT = AVOID.ADEC
Endif
Return

###############################################################################################
$CURRND
Case [L]ARULE
   When "CONTROL"   : Gosub CURRND_CONTROL
Endcase
Return

$CURRND_CONTROL
If this.CURRND=0
  DEC5 = 0
  [L]ASTATUS = fmet this.ASETERROR("CURRND",mess(137,126,1),[V]CST_AWARNING)
Elsif this.CURRND<0
  [L]ASTATUS = fmet this.ASETERROR("CURRND",mess(126,143,1),[V]CST_AERROR)
Endif

Return

###############################################################################################
$EURFLG_MANDATORY
Local Integer MY_STATUS
  If this.EURFLG = [V]CST_AYES
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURRAT", "$isMandatory", "true")
  Else
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURRAT", "$isMandatory", "false")
  Endif
Return

###############################################################################################
Funprog VERFMT(DCURFMT,MAXLNG,TROIS, MESSAGE)
Variable Decimal DCURFMT
Value    Integer MAXLNG
Value    Integer TROIS
Variable Char MESSAGE

Local Integer RETOUR

RETOUR = [V]CST_AOK

Local Integer I, J, D
Local Decimal X
I=int(DCURFMT)
If I=DCURFMT
 D=0
Else
 D = 1
 X = DCURFMT-I
 While X<>int(X) : X *= 10 : Wend
Endif
J = I+D+X
If TROIS : J += int((I-1)/3) : Endif
If J>MAXLNG
 RETOUR=[V]CST_AERROR
 #  Format too long
 MESSAGE = mess(150,100,1)
Endif
End RETOUR

