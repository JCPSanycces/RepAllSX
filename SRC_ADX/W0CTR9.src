#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR9 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLGCTRCPT
mkstat = 0
zoncou = "FLGCTRCPT"
indice = 0
IMPENT = [M]FLGCTRCPT
WNUM = IMPENT
If varinit([M]FLGCTRCPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCTRCPT,indice)=0
 [M]FLGCTRCPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGCTRCPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGCTRCPT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_FLGCTRCPT(IMPENT) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLGCTRCPT" : GZNUM = 47334 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]FLGCTRCPT = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone BPR
mkstat = 0
zoncou = "BPR"
indice = 0
If varmode([M]BPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPR" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_BPR([M]BPR) From SUBCTR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "BPR" : GZNUM = 46536 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ACCCOD
mkstat = 0
zoncou = "ACCCOD"
indice = 0
If varmode([M]ACCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACCCOD" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCAC"
 Call CONTCAC([M]ACCCOD,"35") From SUBCAC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CAC","!",[M]ACCCOD,"35",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "ACCCOD" : GZNUM = 1687 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DSP
mkstat = 0
zoncou = "DSP"
indice = 0
If varmode([M]DSP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSP" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("DSP","!",[M]DSP,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_DSP([M]DSP) From SUBCTR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CTLDSP"
   Call CTRL_DSP([M]DSP,[M:CTR0]ETRFCY,[M:CTR0]CTRDAT) From TRTX3CPT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "DSP" : GZNUM = 3022 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DSPDES
mkstat = 0
zoncou = "DSPDES"
indice = 0
If varinit([M]DSPDES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DSPDES,"","","","") From ATEXTRA
 GACTION = SAVACT
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBAXECPR
mkstat = 0
zoncou = "NBAXECPR"
indice = 0
status = 1
zoncou = "NBAXECPR"
If varmode([M]NBAXECPR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBAXECPR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBAXECPR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBAXECPR = nolign
   status = 75
   Call SAI_NBAXECPR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBAXECPR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBAXECPR
mkstat = 0
zoncou = "NBAXECPR"

## Zone CCE
mkstat = 0
zoncou = "CCE"
SAVACT = GACTION : GACTION = "INICCEFMT"
Call INICCEFMT(num$([M]DIE(nolign-1))) From SETGLBDIE
GACTION = SAVACT
If mkstat=1 : Raz [M]CCE(indice) : Endif
If !mkstat
 If varmode([M]CCE,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_CCE([M]CCE(indice)) From SUBCTR
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CCE(indice) : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CCE" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   Call CONTROLE("CCE","!",[M]CCE(indice),num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CCE([M]CCE(indice)) From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CCE" : GZNUM = 21 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone INICCE
mkstat = 0
zoncou = "INICCE"
IMPENT = [M]INICCE(indice)
If varinit([M]INICCE,indice)=0
 IMPENT = 3
 SAVACT = GACTION : GACTION = "STD"
 Call D_INICCE(IMPENT) From SUBCTR
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]INICCE,indice)=0
  Call INICOMBO(10315) From COMBOS
  [M]INICCE(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "INICCE" : Gosub ACTION From =IMPTRT
   IMPENT = [M]INICCE(indice)
  Endif
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "INICCE" : GZNUM = 13750 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]INICCE(indice) = IMPENT

## Zone NBAXECPR
mkstat = 0
zoncou = "NBAXECPR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR9"
Return

