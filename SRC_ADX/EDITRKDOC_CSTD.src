###################################################################

#@param WDOCID
#@param WCATTYP
#@param WTRKSTA
#@return WOK
#*!
Funprog TRK_UPDATE_STA(WDOCID, WCATTYP, WTRKSTA)
Value Char WDOCID
Value Integer WCATTYP
Value Integer WTRKSTA

  Local Integer WOK : WOK = [V]CST_AOK
  Local Integer WNUMLIN
  WNUMLIN = func EDIRUN_CSTD.GET_EDITRKDOC_NUMLIN(WDOCID, WCATTYP)-1

  Local File EDITRKDOC [EDK]
  Read [EDK]EDK0 = WDOCID; WCATTYP; WNUMLIN
  If !fstat
    Trbegin [EDK]
    [EDK]TRKSTA = WTRKSTA
    Rewrite [EDK]
    If !fstat
      Commit
      WOK = [V]CST_AOK
    Else
      Rollback
      WOK = [V]CST_AERROR
    Endif
  Else
    #error
    WOK = [V]CST_AERROR
  Endif
  LogicClose File [EDK]
#  ARET_VALUE = WOK

End WOK

###################################################################

$MET_DELETE_ALL
  Call DELETE_ALL(this)
Return

###################################################################

Subprog DELETE_ALL(WOBJECT)
Variable Instance WOBJECT Using OBJECT
#  Local Integer WOK


End

