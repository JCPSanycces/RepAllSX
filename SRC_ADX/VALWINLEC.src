#<AdxTL>@(#)12.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
## VALWINLEC Lecture de la fenêtre en mémoire
#---------------------------------------------------------------------------------------------------#

#---------------------------------------------------------------------------------------------------#
## Ouverture des tables
#---------------------------------------------------------------------------------------------------#

$OUVFIC
If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"   [AWI] : Endif
If clalev([F:AWZ2])=0 : Local File =APPLI+".AWINDOW"  [AWZ2] : Endif
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"   [AWP] : Endif
If clalev([F:AWB])=0  : Local File =APPLI+".AWINBRO"   [AWB] : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"  [AWT] : Endif
If clalev([F:AOB])=0  : Local File =APPLI+".AOBJET"    [AOB] : Endif
If clalev([F:AOT])=0  : Local File =APPLI+".AOBJTAB"   [AOT] : Endif
If clalev([F:AOL])=0  : Local File =APPLI+".AOBJLST"   [AOL] : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"   [ATZ] : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"    [ATB] : Endif
If clalev([F:ATI])=0  : Local File =APPLI+".ATABIND"   [ATI] : Endif
If clalev([F:ANX])=0  : Local File =APPLI+".AINDEX"    [ANX] : Endif
If clalev([F:ATY])=0  : Local File =APPLI+".ATYPE"     [ATY] : Endif
If clalev([F:AML])=0  : Local File =APPLI+".AMENLOC"   [AML] : Endif
If clalev([F:ATX])=0  : Local File =APPLI+".ATEXTE"    [ATX] : Endif
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"      [AMK] : Endif
If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"   [AMZ] : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"   [AMP] : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"     [ACV] : Endif
If clalev([F:ACT])=0  : Local File =APPLI+".ACTION"    [ACT] : Endif
If clalev([F:ATR])=0  : Local File =APPLI+".ACTPAR"    [ATR] : Endif
If clalev([F:AAR])=0  : Local File =APPLI+".ACTCODPAR" [AAR] : Endif
If clalev([F:ACN])=0  : Local File =APPLI+".ACONSULT"  [ACN] : Endif
If clalev([F:AST])=0  : Local File =APPLI+".APLSTD"    [AST] : Endif
If clalev([F:AEL])=0  : Local File =APPLI+".AELT"      [AEL] : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK] : Endif
If clalev([F:ATN])=0  : Local File =APPLI+".ATRANSAC"  [ATN] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER            [ADS] : Endif


If dim([F:ATZ]OPTION)<0 : # CCL 114469
 If clalev([F:ATZ])=0  : Close Local File   [ATZ] : Endif
 If clalev([F:ATB])=0  : Close Local File   [ATB] : Endif
 If clalev([F:ATI])=0  : Close Local File   [ATI] : Endif
 Local File =APPLI+".ATABIND"   [ATI]
 Local File =APPLI+".ATABLE"    [ATB]
 Local File =APPLI+".ATABZON"   [ATZ]
Endif

Return

#---------------------------------------------------------------------------------------------------#
## Déclaration des variables
#---------------------------------------------------------------------------------------------------#

$DEFVAR

Local Integer MAXBRO : MAXBRO = dim([F:AWB]OBJLIS)+1     : # Nb max de browsers (10 avec derlu)
Local Integer MAXFOL : MAXFOL = dim([F:AWI]NOMMSK)+1     : # Nb max de folders (16 avec l'entête)
Local Integer MAXOPT : MAXOPT = dim([F:AOB]OPTCND)       : # Nb max d'options de sélection (20)
Local Integer MAXFIL : MAXFIL = 100                      : # Nb max de tables liées
Local Integer MAXSEL : MAXSEL = dim([F:AOL]SELZON)       : # Nb max de colonnes dans liste de gauche (16)
Local Integer MAXBOU : MAXBOU = 80                       : # Nb max de boutons spéciaux #114910 60->80
Local Integer MAXBST : MAXBST = dim([F:AWI]BSTD)         : # Nb max de boutons standard (30)
Local Integer MAXACT : MAXACT = 100                      : # Nb max d'actions par fenêtre
Local Integer MAXPAR : MAXPAR = 20                       : # Nb max de paramètres par action
Local Integer MAXCLE : MAXCLE = 16                       : # Nb max de parties de clé
Local Integer MAXSCR : MAXSCR = dim([F:AOB]SCRNAM)       : # Nb max de masques pour le WEB service
Local Integer MAXLNK : MAXLNK = 12                       : # Nb max de tables liées dans un link (moteur)

#---------------------------------------------------------------------------------------------------#
## En-tête de la fenêtre
#---------------------------------------------------------------------------------------------------#

Local Schar   AWI_BOX(GLONABR)                           : # Abréviation de la boîte
Local Integer AWI_DES                                    : # Nom de la fenêtre
Local Schar   AWI_TRN(10)                                : # Code transaction
Local Char    AWI_LIBEL(30)                              : # Libellé de la transaction
Local Integer AWI_TYP                                    : # Type Affichage (plein écran,dialo,message,debug)
Local Integer AWI_WINTYP                                 : # Type Fenêtre (divers,objet,consult,etc)
Local Integer ISVT : ISVT=0                              : # VT (0,1) (same variable declared in VALMSKLEC)
Local Integer ISJSONONLY : ISJSONONLY=0              : # ISJSONONLY (0,1) (same variable declared in VALWINLEC)
Local Schar   AWI_CNS(GLONACN)                           : # Code consultation
Local Schar   AWI_OBJ(GLONAOB)                           : # Code objet
Local Integer AWI_GLO                                    : # 0:Local ou 1:Global (fenêtres spéciales)
Local Integer AWI_BOU                                    : # 0=Fenêtre sans boutons
Local Schar   AWI_ABRENA(GLONABR)                        : # Abréviation du masque contenant le champ ENAFLG

Local Integer AWI_NBRMSK                                 : # Nombre d'écrans (n°1 = entête)
Local Schar   AWI_NOMMSK(GLONAMK)(1..MAXFOL)             : # Nom des écrans
Local Schar   AWI_ABRMSK(GLONABR)(1..MAXFOL)             : # Abréviation des écrans
Local Integer AWI_INTMSK(1..MAXFOL)                      : # Intitulé folders
Local Schar   AWI_INTFLD(60)(1..MAXFOL)                  : # Intitulé évalué des folders
Local Integer AWI_FLGMSK(1..MAXFOL)                      : # 2=Folder visualisé
Local Integer AWI_ROWMSK(1..MAXFOL)                      : # Numéro d'ordre des folders

Local Integer AWI_STA(1..MAXBST)                         : # Status boutons standard
Local Integer AWI_TXT(1..MAXBST)                         : # Intitulé boutons standard
Local Integer AWI_ACT(1..MAXBST)                         : # No action sur bouton standard
Local Integer AWI_CRUD(1..MAXBST)                        : # vaut 1 si bouton CRUD (Enregistrer, Créer, Supprimer,
#                                                                                   Abandon, Ok, Fin)

#---------------------------------------------------------------------------------------------------#
## Boutons spéciaux
#---------------------------------------------------------------------------------------------------#

Local Schar   AWT_COD(1)(1..MAXBOU)                      : # Code
Local Integer AWT_STA(1..MAXBOU)                         : # Status
Local Integer AWT_TXT(1..MAXBOU)                         : # Intitulé
Local Integer AWT_VAL(1..MAXBOU)                         : # Code (1)Invalidant/(2)Validant
Local Integer AWT_NIV(1..MAXBOU)                         : # Niveau (0 std, x0 menu, xy s-menu)
Local Integer AWT_ACT(1..MAXBOU)                         : # No action sur bouton spécial
Local Integer AWT_LNI(1..MAXBOU)                         : # Longueur du code AWT_COD
Local Integer AWT_NBR                                    : # Nb de boutons spéciaux

#---------------------------------------------------------------------------------------------------#
## Objet principal
#---------------------------------------------------------------------------------------------------#

Local Integer AOB_LIBEL                                  : # Intitulé objet
Local Integer AOB_GES                                    : # Type de gestion
Local Integer AOB_ORD                                    : # Ascendant/Descendant
Local Schar   AOB_CLE(GLONAVA)                           : # Index
Local Integer AOB_TRE                                    : # Liste hiérarchisée o/n
Local Integer AOB_LIBPAR                                 : # Libellé du paramètre (clesec)
Local Integer AOB_FCYDEP                                 : # Pour géode
Local Integer AOB_NBRSCR                                 : # Nombre d'écrans pour le WEB service
Local Schar   AOB_NAMSCR(GLONAMK)(1..MAXSCR)             : # Nom des écrans pour le WEB Service
Local Schar   AOB_ABRSCR(GLONABR)(1..MAXSCR)             : # Abréviation des écrans pour le WEB Service
Local Schar   AOB_TITTRN(GLONAOB)                        : # Objet des transactions

#---------------------------------------------------------------------------------------------------#
## En-tête de la table liée à l'objet principal de la fenêtre
#---------------------------------------------------------------------------------------------------#

Local Schar   ATB_FIC(GLONATB)                           : # Nom de la table de l'objet
Local Schar   ATB_ABR(GLONABR)                           : # Abréviation de cette table
Local Schar   ATB_INT(GLONAVA)                           : # Nom du champ intitulé

#---------------------------------------------------------------------------------------------------#
## Browsers de la fenêtre
#---------------------------------------------------------------------------------------------------#

Local Integer AWB_DER                                    : # Affichage liste de gauche derlu
Local Integer AWB_FIR                                    : # Derniers lus en première position
Local Integer AWB_AFL                                    : # Affichage browser


Local Integer AWB_NBR                                    : # Nombre de browser
Local Schar   AWB_NUM(2)(1..MAXBRO)                      : # Numéro de browser
Local Schar   AWB_ACC(GLONAVA)(1..MAXBRO)                : # Nom du champ code accès
Local Schar   AWB_FCY(GLONAVA)(1..MAXBRO)                : # Nom du champ code site

Local Schar   AWB_OBJ(GLONAOB)(1..MAXBRO)                : # Code objet de chaque browser
Local Integer AWB_GES(1..MAXBRO)                         : # Type de gestion
Local Schar   AWB_CLE(GLONAVA)(1..MAXBRO)                : # Nom de l'index
Local Schar   AWB_IND(250)(1..MAXBRO)                    : # Description de l'index
Local Schar   AWB_FIC(GLONATB)(1..MAXBRO)                : # Nom de la table
Local Integer AWB_NOI(1..MAXBRO)                         : # Numéro de l'index de la table
Local Integer AWB_ORD(1..MAXBRO)                         : # Sens de lecture
Local Integer AWB_TRE(1..MAXBRO)                         : # Type de liste de gauche
Local Integer AWB_BRO(1..MAXBRO)                         : # Type browser (o/n)
Local Integer AWB_CHG(1..MAXBRO)                         : # Option de chargement
Local Integer AWB_FLE(1..MAXBRO)                         : # Présence doubles flêches (o/n)
Local Schar   AWB_ABR(GLONABR)(1..MAXBRO)                : # Abréviation de la table
Local Schar   AWB_ABB(GLONABR)(1..MAXBRO)                : # Abréviation saisie
Local Schar   AWB_EXP(60)(1..MAXBRO)                     : # Expression de lien
Local Integer AWB_INT(1..MAXBRO)                         : # Intitulé du browser

Local Integer AWB_NBFIC(1..MAXBRO)                       : # Nombre de tables liées par browser
Local Schar   AWB_FICLNK(GLONATB)(1..MAXFIL,1..MAXBRO)   : # Nom de la table
Local Schar   AWB_EXPLNK(200)(1..MAXFIL,1..MAXBRO)       : # Expression de lien
Local Integer AWB_OBLLNK(1..MAXFIL,1..MAXBRO)            : # Lien requis pour les listes de gauche
Local Schar   AWB_CODLNK(GLONADI)(1..MAXFIL,1..MAXBRO)   : # Code liaison
Local Schar   AWB_ABRLNK(GLONABR)(1..MAXFIL,1..MAXBRO)   : # Abréviation de la table liée
Local Schar   AWB_CLELNK(GLONAVA)(1..MAXFIL,1..MAXBRO)   : # Clé de la table liée

Local Integer AWB_NBSEL(1..MAXBRO)                       : # Nombre de colonne par browser
Local Schar   AWB_SELZON(GLONAVA)(1..MAXSEL,1..MAXBRO)   : # Nom du champ
Local Schar   AWB_SELFIC(GLONATB)(1..MAXSEL,1..MAXBRO)   : # Nom de la table
Local Schar   AWB_SELABR(GLONABR)(1..MAXSEL,1..MAXBRO)   : # Abréviatioon de la table
Local Schar   AWB_SELEXP(200)(1..MAXSEL,1..MAXBRO)       : # Expression
Local Integer AWB_SELINT(1..MAXSEL,1..MAXBRO)            : # Intitulé de la colonne
Local Schar   AWB_SELTYP(GLONATY)(1..MAXSEL,1..MAXBRO)   : # Type de donnée de la colonne
Local Integer AWB_SELTYPTYP(1..MAXSEL,1..MAXBRO)         : # Type de la colonne
Local Schar   AWB_SELFMT(30)(1..MAXSEL,1..MAXBRO)        : # Format de la colonne (html)
Local Schar   AWB_SELFOR(30)(1..MAXSEL,1..MAXBRO)        : # Format de la colonne (affiché)
Local Integer AWB_SELNOLIB(1..MAXSEL,1..MAXBRO)          : # No de menu local
Local Schar   AWB_SELOPT(10)(1..MAXSEL,1..MAXBRO)        : # Option de saisie pour le format de la colonne
Local Decimal AWB_SELLNG(1..MAXSEL,1..MAXBRO)            : # Longueur du champ (colonne)

#---------------------------------------------------------------------------------------------------#
## Actions sur boutons
#---------------------------------------------------------------------------------------------------#

Local Schar   ACT_COD(GLONACT)(1..MAXACT)                : # Code action
Local Integer ACT_TYP(1..MAXACT)                         : # Type action (Gobjet/Gtraite/Gsaisie/...)
Local Integer ACT_TYA(1..MAXACT)                         : # Avec zone courante(2) Sans (1)
Local Integer ACT_SUI(1..MAXACT)                         : # Numéro action si action suivante
Local Schar   ACT_PAR1(GLONACN)(1..MAXACT)               : # Code consultation
Local Schar   ACT_PAR2(GLONFEN)(1..MAXACT)               : # Fenêtre principale
Local Integer ACT_PAR3(1..MAXACT)                        : # Saisie initiale
Local Schar   ACT_PAR4(GLONFEN)(1..MAXACT)               : # Fenêtre critère
Local Schar   ACT_PAR5(10)(1..MAXACT)                    : # Identifiant action
Local Schar   ACT_TRT(GLONADC)(1..MAXACT)                : # Nom du traitement standard
Local Schar   ACT_SPE(GLONADC)(1..MAXACT)                : # Nom du traitement spécifique
Local Schar   ACT_SUB(GLONASU)(1..MAXACT)                : # Nom du sous-programme
Local Schar   ACT_INS(250)(1..MAXACT)                    : # Intruction
Local Integer ACT_NBP(1..MAXACT)                         : # Nb de paramètres pour cette action

#---------------------------------------------------------------------------------------------------#
## Paramètres sur actions
#---------------------------------------------------------------------------------------------------#

Local Schar   PAR_COD(10)(1..MAXACT,1..MAXPAR)           : # Code paramètre
Local Libelle PAR_TYP(1..MAXACT,1..MAXPAR)               : # Type paramètre
Local Libelle PAR_ADR(1..MAXACT,1..MAXPAR)               : # Adress/valeur
Local Schar   PAR_VAL(80)(1..MAXACT,1..MAXPAR)           : # Valeur paramètres

#---------------------------------------------------------------------------------------------------#
## Variables diverses
#---------------------------------------------------------------------------------------------------#

Local Char    NOMPROG(GLONADC), FICSRC(GDIMFIC), MAGIC(80)
Local Char    CHAINE(250), CHAINE2(250)
Local Char    CLES(GLONAVA)(1..MAXCLE) , SNSCLES(1)(1..MAXCLE)
Local Integer NBCLES
Local Integer I , J , K , L , N , T , A , B , P , R , W , X , Y , OK , OKTXT , OKACC , OKFCY , OKS
Local Char    FLDTXT(GLONAVA)(1..MAXBRO)
Local Char    TYPFMT(10) , OPTFMT(10) , NUMFMT(10) , CHFMT(30)
Local Integer LNGFMT
Local Char    NLG(2), MESSA(50)
Local Char    PARAM(250)
Local Integer MAXHAUT , COL , BRW , HTENT

Local Char    CLEFCY(GLONAVA) , CLEDEP(GLONAVA) , CLEGEO(GLONAVA) : # X3 Géode
Local Char    CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..MAXCLE)
Local Integer NBCLE
Local Char    CLE(GLONAVA)(1..MAXCLE)

Local Char    BCOD(3)(1..MAXBOU)
Local Integer BVAL(1..MAXBOU), BTXT(1..MAXBOU), BTYP(1..MAXBOU), BACT(1..MAXBOU)

Local Char    OBJET(GLONAOB)

Local Char    BOUTSTD(60)
Local Integer NIV, STD
Local Integer SPA, FLGOK
Local Integer NBCLE2

Local Char    SAVIFS(5) , SAVIRS(5)
Local Libelle SAVIUM

Local Date    JOUR
Local Char    HEURE(10)

#---------------------------------------------------------------------------------------------------#
## Initialisations
#---------------------------------------------------------------------------------------------------#

JOUR  = date$
HEURE = time$
MAGIC = mess(77,133,1) : # Superviseur Adonix
Call PARAM("","ECRRESOL",PARAM) From ADOVAL
Call RESOLUTION(val(PARAM),COL,MAXHAUT,BRW) From GLOBVAR
Return

#---------------------------------------------------------------------------------------------------#
## Lecture de la fenêtre en mémoire
#---------------------------------------------------------------------------------------------------#

$LECTURE

OK = 1
If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER = APPLI
 If fstat
  GMESSAGE = APPLI-":"-mess(78,133,1) : # Dossier inexistant
  OK = 0 : Return
 Endif
Endif

Read [AWI]AWI0 = FENETRE
If fstat
 GMESSAGE = FENETRE-":"-mess(6,126,1) : # Fenêtre inexistante
 OK = 0 : Return
Endif

#{SAM 131394
If !func AFNC.IS_VALIDATION_ENABLED(APPLI,[F:AWI]CODACT,[F:AWI]MODULE)
 # Issue X3-75929 - 2018-07-26 by ALSHE : set error status to be able to use it in VALOBJ.PERDU
 GMESSAGE = FENETRE-":"-mess(124,133,1)-"("+[F:AWI]CODACT+")" : # Fenêtre inactive
 GERR = 3: OK = 0 : Return
Endif
#SAM 131394}

If [F:AWI]MDL=2 : # Fenêtre modèle
 GMESSAGE = "" : OK = 0 : Return
Elsif [F:AWI]CODACT<>""
 Read [ACV]CODACT = [F:AWI]CODACT
 # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
 #                                        - change message text if activity code doesn't exist
 If fstat
  GMESSAGE = FENETRE-":"-mess(8,176,1)-"("+[F:AWI]CODACT+")" # Non-existent Activity Code
  GERR = 1 : OK = 0 : Return
 Else
  If [F:ACV]FLACT<>2
   GMESSAGE = FENETRE-":"-mess(124,133,1)-"("+[F:AWI]CODACT+")" # Fenêtre inactive
   GERR = 3 : OK = 0 : Return
  Endif
 Endif
Endif
HTENT = 0
If [F:AWI]MSKENT<>""
 Read [AMK]CODMSK=[F:AWI]MSKENT
 If !fstat & [F:AMK]MDL=2 : # Ecran modèle -> pas de validation fenêtre
  Call ECR_TRACE(FENETRE-[F:AWI]MSKENT-":"-mess(121,133,1),-1) From GESECRAN
  GMESSAGE = "" : OK = 0 : Return
 Endif
 HTENT = [F:AMK]NBRLIG
Endif
For I=1 To [F:AWI]NBMSK
 Read [AMK]CODMSK=[F:AWI]NOMMSK(I-1)
 If !fstat & [F:AMK]MDL=2 : # Ecran modèle -> pas de validation fenêtre
  Call ECR_TRACE(FENETRE-[F:AWI]NOMMSK(I-1)-":"-mess(121,133,1),-1) From GESECRAN
  GMESSAGE = "" : OK = 0 : Break
 Endif
 If HTENT+[F:AMK]NBRLIG>MAXHAUT & 1=0 : # Pas assez de place en hauteur (obsolète en convergence)
  Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(75,133,1),-1) From GESECRAN
 Endif
Next I
If !OK : Return : Endif

#Call NOMTRTWIN(FENETRE,NOMPROG) From MSKDIV
NOMPROG="WG"+FENETRE   : # Migrations optimisées   CC 24/10/2011

If [F:AWI]OBJ<>""
 OBJET = [F:AWI]OBJ
 Read [AOB]ABREV = OBJET
 If fstat
  GMESSAGE = OBJET-":"-mess(16,123,1) : # Objet non défini
  OK = 0 : Return
 Elsif [F:AOB]CODACT<>""
  Read [ACV]CODACT = [F:AOB]CODACT
  # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
  #                                        - change message text if activity code doesn't exist
  If fstat
   GMESSAGE = OBJET-":"-mess(8,176,1)-"("+[F:AOB]CODACT+")" # Non-existent Activity Code
   GERR = 1 : OK = 0 : Return
  Else
   If [F:ACV]FLACT<>2
    GMESSAGE = OBJET-":"-mess(125,133,1)-"("+[F:AOB]CODACT+")" : # Objet inactif
    GERR = 3 : OK = 0 : Return
   Endif
  Endif
 Endif
 Read [ATB]CODFIC = [F:AOB]NOMFIC
 If fstat
  GMESSAGE = [F:AOB]NOMFIC-":"-mess(17,123,1) : # Table non définie
  OK = 0 : Return
 Elsif [F:ATB]CODACT<>""
  Read [ACV]CODACT = [F:ATB]CODACT
  # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
  #                                        - change message text if activity code doesn't exist
  If fstat
   GMESSAGE = [F:AOB]NOMFIC-":"-mess(8,176,1)-"("+[F:ATB]CODACT+")" # Non-existent Activity Code
   GERR = 1 : OK = 0 : Return
  Else
   If [F:ACV]FLACT<>2
    GMESSAGE = [F:AOB]NOMFIC-":"-mess(126,133,1)-"("+[F:ATB]CODACT+")" : # Table inactive
    GERR = 3 : OK = 0 : Return
   Endif
  Endif
 Endif
 # Intitulé des transactions
 Raz AOB_TITTRN , CHAINE
 For [ATN]ATN1 Where OBJGES=[L]OBJET & OBJ<>""
  CHAINE = [F:ATN]COD : Break
 Next ATN
 If CHAINE<>""
  Read [ATN]ATN0 = CHAINE
  AOB_TITTRN = [F:ATN]OBJ : # Intitulé des transactions
 Endif
Else
 Raz [F:AOB], [F:ATB]
Endif

# Objet principal

AOB_LIBEL  = [F:AOB]LIBEL
AOB_GES    = [F:AOB]TYPGES
AOB_ORD    = [F:AOB]SELORD
AOB_CLE    = [F:AOB]SELCLE
AOB_TRE    = [F:AOB]SELTREE
AOB_LIBPAR = [F:AOB]LIBPAR
If dim([F:AOB]FCYDEP)>0
 AOB_FCYDEP = [F:AOB]FCYDEP
Endif
AOB_NBRSCR = 0
For I=1 To [F:AOB]NBSCR
 OKS = 1
 If [F:AOB]SCRNAM(I-1)=""
  OKS = 0
 Else
  Read [AMK]CODMSK=[F:AOB]SCRNAM(I-1)
  If fstat
   OKS = 0
  Elsif [F:AMK]CODACT<>""
   Read [ACV]CODACT = [F:AMK]CODACT
   If fstat or [F:ACV]FLACT<>2
    OKS = 0
   Endif
  Endif
 Endif
 If OKS
  AOB_NBRSCR += 1
  AOB_NAMSCR(AOB_NBRSCR) = [F:AOB]SCRNAM(I-1)
  If [F:AOB]SCRABR(I-1)<>""
   AOB_ABRSCR(AOB_NBRSCR) = [F:AOB]SCRABR(I-1)
  Else
   AOB_ABRSCR(AOB_NBRSCR) = [F:AMK]ABRMSK
  Endif
 Endif
Next I

ATB_FIC   = [F:ATB]CODFIC
If dim([F:AOB]ABRFIC)>0 & [F:AOB]ABRFIC<>""
 ATB_ABR = [F:AOB]ABRFIC
Else
 ATB_ABR = [F:ATB]ABRFIC
Endif
ATB_INT   = [F:ATB]INTIT

# Clé

Read [ATI]NUMLIG(2) = ATB_FIC;1
If fstat
 Raz [F:ATI]
Else
 CHAINE = [F:ATI]DESCRIPT
 Raz CLE, NBCLE
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLE += 1
  If I
   CLE(NBCLE) = left$(CHAINE,I-1)
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE(NBCLE) = CHAINE
   CHAINE = ""
  Endif
 Wend
 Case NBCLE
  When 1
   CLEPRIM = CLE(1)
  When 2
   If AOB_GES=3
    CLEPRIM = CLE(1) : CLESEC = CLE(2)
   Else
    CLEPRIM = CLE(2) : CLESEC = CLE(1)
   Endif
  When Default
   CLEPRIM = CLE(2) : CLESEC = CLE(1)
   For I=3 To NBCLE
    CLESEC(I-2) = CLE(I)
   Next I
 Endcase
Endif

# Clé Géode

If AOB_FCYDEP=2 & NBCLE>1
 I = find("FCY",CLE(1..NBCLE-1))
 J = find("DEP",CLE(1..NBCLE-1))
 If (I=1 & J<3) | (J=1 & I<3)
  If I : CLEFCY = CLE(I) : Endif
  If J : CLEDEP = CLE(J) : Endif
  K=(I<>0)+(J<>0)
  If NBCLE=1+K
   CLEGEO = CLE(K+1)
  Else
   # L = nb de paramètres
   If AOB_LIBPAR=0
    L = 0
   Else
    Call TEXTE(AOB_LIBPAR,CHAINE) From OBJDIV
    L = sigma(1,len(CHAINE),mid$(CHAINE,indcum,1)="~")+1
   Endif
   CLEGEO = CLE(K+1+L)
  Endif
 Endif
Endif

# Fenêtre

AWI_WINTYP = [F:AWI]WINTYP
If dim([F:AWI]FVT)>0 and [F:AWI]FVT=2
  ISVT=1
Endif
ISJSONONLY=func INTRUTILB.JSONONLYPARAM(APPLI)
AWI_DES    = [F:AWI]DES
AWI_TRN    = [F:AWI]TRN
AWI_LIBEL  = [F:AWI]LIBEL
AWI_CNS    = [F:AWI]CNS
AWI_OBJ    = [F:AWI]OBJ
AWI_TYP    = [F:AWI]TYP
AWI_GLO    = 0

# Fenêtres spéciales

Case FENETRE
 When "DEBUGGER", "TEMPON", "TEMPON2", "VALIDCAR"
  AWI_GLO = 1
Endcase

If [F:AWI]MSKENT="" & [F:AWI]NBMSK=0
 P = 0
Else
 P = 1
 If [F:AWI]MSKENT=""
  AWI_NOMMSK(P) = ""
  AWI_ABRMSK(P) = ""
  AWI_ROWMSK(P) = -1
 Else
  Read [AMK]CODMSK=[F:AWI]MSKENT
  If fstat
   GMESSAGE = [F:AWI]MSKENT-":"-mess(1,105,1) : # Ecran inexistant
   OK = 0 : Return
  Elsif [F:AMK]CODACT<>""
   Read [ACV]CODACT = [F:AMK]CODACT
   # Issue X3-75929 - 2018-07-26 by ALSHE : - set error status to be able to use it in VALOBJ.PERDU
   #                                        - change message text if activity code doesn't exist
   If fstat
    GMESSAGE = [F:AWI]MSKENT-":"-mess(8,176,1)-"("+[F:AMK]CODACT+")" : # Masque inactif
    GERR = 1 : OK = 0 : Return
   Else
    If [F:ACV]FLACT<>2
     GMESSAGE = [F:AWI]MSKENT-":"-mess(80,133,1)-"("+[F:AMK]CODACT+")" : # Masque inactif
     GERR = 3 : OK = 0 : Return
    Endif
   Endif
  Endif
  AWI_NOMMSK(P) = [F:AWI]MSKENT
  AWI_FLGMSK(P) = 2
  AWI_ROWMSK(P) = -1
  AWI_INTFLD(P) = ""
  AWI_INTMSK(P) = 0
  AWI_ABRMSK(P) = [F:AMK]ABRMSK
 Endif
 AWI_BOX = ""
 For I=1 To [F:AWI]NBMSK
  K = 1
  If [F:AWI]ACTMSK(I-1)<>""
   Read [ACV]CODACT = [F:AWI]ACTMSK(I-1)
   If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
  Endif
  If K
   Read [AMK]CODMSK=[F:AWI]NOMMSK(I-1)
   If fstat
    Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(1,105,1),1) From GESECRAN : # Ecran inexistant
    Raz [F:AMK]
   Elsif [F:AMK]CODACT<>""
    Read [ACV]CODACT = [F:AMK]CODACT
    # Issue X3-75929 - 2018-07-26 by ALSHE : - Split trace in warning and error message
    If fstat
     Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(8,176,1)-"("+[F:AMK]CODACT+")",1) From GESECRAN # Non-existent Activity Code
     Raz [F:AMK] : GMESSAGE = ""
    Else
     If [F:ACV]FLACT<>2
      Call ECR_TRACE([F:AWI]NOMMSK(I-1)-":"-mess(80,133,1)-"("+[F:AMK]CODACT+")",-1) From GESECRAN # Masque inactif
      Raz [F:AMK] : GMESSAGE = ""
     Endif
    Endif
   Endif
   If [F:AMK]ABRMSK<>""
    If AWI_BOX=""
     AWI_BOX = [F:AMK]ABRMSK
    Endif
    P += 1
    AWI_NOMMSK(P) = [F:AWI]NOMMSK(I-1)
    AWI_FLGMSK(P) = [F:AWI]FLGMSK(I-1)
    AWI_ROWMSK(P) = [F:AWI]ROWMSK(I-1)
    AWI_INTMSK(P) = [F:AWI]INTMSK(I-1)
    AWI_INTFLD(P) = [F:AWI]INTFOLD(I-1)
    AWI_ABRMSK(P) = [F:AMK]ABRMSK
   Endif
  Endif
 Next I
Endif
If AWI_NOMMSK(1)<>"" & AWI_BOX=""
 GMESSAGE = FENETRE-":"-mess(188,123,1) : # Il doit y avoir un onglet
 OK = 0 : Return
Elsif P<=1
 GMESSAGE = FENETRE-":"-mess(211,123,1) : # Aucun écran disponible pour cette fenêtre
 OK = 0 : Return
Endif
AWI_NBRMSK = P

Sorta AWI_NBRMSK
&     AWI_ROWMSK
&   , AWI_NOMMSK
&   , AWI_FLGMSK
&   , AWI_INTMSK
&   , AWI_INTFLD
&   , AWI_ABRMSK
& Order By AWI_ROWMSK(indice+1)

# Recherche de la zone ENAFLG

Raz AWI_ABRENA
If OBJET<>"" & AOB_GES<>2 & ATB_FIC<>""
 Filter [ATZ] Where CODFIC=ATB_FIC & CODZONE="ENAFLG"
 Read [ATZ]CODZONE First
 Filter [ATZ]
 If !fstat
  For I=1 To AWI_NBRMSK
   Filter [AMZ] Where CODMSK=AWI_NOMMSK(I) & CODZON="ENAFLG"
   Read [AMZ]CODE First
   Filter [AMZ]
   If !fstat
    Read [AMK]CODMSK=AWI_NOMMSK(I)
    AWI_ABRENA = [F:AMK]ABRMSK : Break
   Endif
  Next I
 Endif
Endif

# Boutons standards & actions sur boutons

A = 0   : # Compteur action
STD = 1 : # Standard
AWI_BOU = 0
Case [F:AWI]WINTYP
 When 3 : # Consultation
  For B=1 To MAXBST
   Case [F:AWI]BSTD(B-1)
    When 2
     Case B
      When 1  : AWI_STA(B) = GSTABOU+100+B  : AWI_TXT(B) = -(1000*123+27)  : # Recherche
      When 2  : AWI_STA(B) = GSTABOU2+100+B : AWI_TXT(B) = -(1000*133+182) : # Critères
      When 3  : AWI_STA(B) = GSTABOU+100+B  : AWI_TXT(B) = -(1000*124+144) : # Retour
      When 4  : AWI_STA(B) = GSTABOU+100+B  : AWI_TXT(B) = -(1000*133+183) : # Suite
      When 5  : AWI_STA(B) = GSTABOU+100+B  : AWI_TXT(B) = -(1000*133+184) : # Dernier
      When 6  : AWI_STA(B) = GSTAEND        : AWI_TXT(B) = -(1000*123+65)  : AWI_CRUD(B)=1 : # Fin
     Endcase
     AWI_BOU += 1
   Endcase
  Next B
 When 4 : # Critères consultation
  For B=1 To 2
   Case [F:AWI]BSTD(B-1)
    When 2
     Case B
      When 1 : AWI_STA(B) = GSTAOK   : AWI_TXT(B) = -(1000*100+157): AWI_CRUD(B)=1 : # Ok
      When 2 : AWI_STA(B) = GSTAEND  : AWI_TXT(B) = -(1000*123+65) : AWI_CRUD(B)=1 : # Fin
     Endcase
     AWI_BOU += 1
   Endcase
  Next B
 When Default
  W = 0
  For B=1 To MAXBST
   W += 1
   Case [F:AWI]BSTD(B-1)
    When 2
     Case B
      When 1  : AWI_STA(B) = GSTAENR  : AWI_TXT(B) = -(1000*123+2)   : AWI_CRUD(B)=1  : # Enregistrer
      When 2  : AWI_STA(B) = GSTACRE  : AWI_TXT(B) = -(1000*123+3)   : AWI_CRUD(B)=1  : # Créer
      When 3  : AWI_STA(B) = GSTAANU  : AWI_TXT(B) = -(1000*123+4)   : AWI_CRUD(B)=1  : # Supprimer
      When 4  : AWI_STA(B) = GSTAFIN  : AWI_TXT(B) = -(1000*123+5)   : AWI_CRUD(B)=1  : # Abandon
      When 5  : AWI_STA(B) = GSTAOK   : AWI_TXT(B) = -(1000*100+157) : AWI_CRUD(B)=1  : # Ok
      When 6  : AWI_STA(B) = GSTANEW  : AWI_TXT(B) = -(1000*133+189) : # Nouveau
      When 7  : AWI_STA(B) = GSTAFIR  : AWI_TXT(B) = -(1000*133+187) : # Premier
      When 8  : AWI_STA(B) = GSTALAS  : AWI_TXT(B) = -(1000*133+188) : # Dernier
      When 9  : AWI_STA(B) = GSTAPRE  : AWI_TXT(B) = -(1000*126+30)  : # Précédent
      When 10 : AWI_STA(B) = GSTASUI  : AWI_TXT(B) = -(1000*126+31)  : # Suivant
      When 11 : AWI_STA(B) = GSTASEL  : AWI_TXT(B) = -(1000*123+22)  : # Sélection
      When 12 : AWI_STA(B) = GSTACHG  : AWI_TXT(B) = -(1000*124+135) : # Changement de clé
      When 13 : AWI_STA(B) = GSTAEDI  : AWI_TXT(B) = -(1000*123+61)  : # Impression
      When 14 : AWI_STA(B) = GSTALIS  : AWI_TXT(B) = -(1000*124+137) : # Liste
      When 15 : AWI_STA(B) = GSTAJOI  : AWI_TXT(B) = -(1000*124+118) : # Pièces jointes
      When 16 : AWI_STA(B) = GSTACOM  : AWI_TXT(B) = -(1000*124+123) : # Commentaires
      When 17 : AWI_STA(B) = GSTADAT  : AWI_TXT(B) = -(1000*123+199) : # Propriétés
      When 18 : If GPRODUIT=1 : ## GEODE
                 AWI_STA(B)= GSTAPCK  : AWI_TXT(B) = -(1000*133+186) : # Sélection Picking
                Else
                 AWI_STA(B)= GSTAEND  : AWI_TXT(B) = -(1000*123+65)  : AWI_CRUD(B)=1 : # Fin
                Endif
      When 19 : If GPRODUIT=1 : ## GEODE
                 AWI_STA(B)= GSTAEND  : AWI_TXT(B) = -(1000*123+65)  : AWI_CRUD(B)=1 : # Fin
                Endif
     Endcase
     AWI_BOU += 1
   Endcase
   If [F:AWI]ACTSTD(B-1)<>""
    Read [ACT]ACTION = [F:AWI]ACTSTD(B-1)
    If fstat
     Call ECR_TRACE([F:AWI]ACTSTD(B-1)-mess(84,133,1),1) From GESECRAN : # Action inexistante
    Else
     K = 1
     If [F:ACT]CODACT<>""
      Read [ACV]CODACT = [F:ACT]CODACT
      If fstat or [F:ACV]FLACT<>2
       K = 0
      Endif
     Endif
     If K
      A += 1
      If A>=MAXACT
       GMESSAGE = FENETRE-":"-mess(91,133,1)-"("+num$(MAXACT)+")" : # Trop d'actions
       OK = 0 : Break
      Endif
      AWI_ACT(B) = A
      ACT_COD(A) = [F:AWI]ACTSTD(B-1)
      Gosub LECACT
      If !OK : Break : Endif
     Endif
    Endif
   Endif
  Next B
Endcase
If !OK : Return : Endif

# Boutons spéciaux & actions sur boutons (phase 1)

B   = 0 : # No bouton actif
STD = 0 : # Spécif
W   = 0 : # Indice bouton dans le dico fenêtre
For [AWT] Where WIN=FENETRE
 AWI_BOU += 1
 W += 1
 K = 1
 If [F:AWT]CODACTBOUT<>""
  Read [ACV]CODACT = [F:AWT]CODACTBOUT
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  B += 1
  If B>=MAXBOU
   GMESSAGE = mess(112,133,1)-"("+num$(MAXBOU)+")" : # Trop de boutons
   OK = 0 : Break
  Endif
  BCOD(B) = [F:AWT]CODBOUT
  BVAL(B) = [F:AWT]VALBOUT
  BTXT(B) = [F:AWT]TXTBOUT
  BTYP(B) = [F:AWT]TYPBOUT
  If [F:AWT]ACTBOUT<>""
   Read [ACT]ACTION = [F:AWT]ACTBOUT
   If fstat
    Call ECR_TRACE([F:AWT]ACTBOUT-mess(84,133,1),1) From GESECRAN : # Action inexistante
   Else
    K = 1
    If [F:ACT]CODACT<>""
     Read [ACV]CODACT = [F:ACT]CODACT
     If fstat or [F:ACV]FLACT<>2
      K = 0
     Endif
    Endif
    If K
     A += 1
     If A>=MAXACT
      GMESSAGE = mess(91,133,1)-"("+num$(MAXACT)+")" : # Trop d'actions
      OK = 0 : Break
     Endif
     BACT(B) = A
     ACT_COD(A) = [F:AWT]ACTBOUT
     Gosub LECACT
     If !OK : Break : Endif
    Endif
   Endif
  Endif
 Endif
Next
If !OK : Return : Endif

AWT_NBR = B

# Affectation des status sur les boutons spéciaux et menus (phase 2)

B = 0
For I=1 To AWT_NBR
 If BTYP(I)=1
  B += 1
  AWT_COD(B) = BCOD(I)
  AWT_LNI(B)=len(BCOD(I))
  AWT_VAL(B) = BVAL(I)
  AWT_TXT(B) = BTXT(I)
  AWT_ACT(B) = BACT(I)
  Case BVAL(I)
   When 1 : AWT_STA(B) = GSTABOU2+B
   When 2 : AWT_STA(B) = GSTABOU+B
  Endcase
 Endif
Next I

N = 0 : # Niveau
T = 0 : # Status
For I=1 To AWT_NBR
 If BTYP(I)=2
  If len(BCOD(I))=1
   N += 10
   B += 1
   AWT_NIV(B) = N
   AWT_TXT(B) = BTXT(I)
   AWT_LNI(B)=len(BCOD(I))
   For J=1 To AWT_NBR
    If BTYP(J)=3 & left$(BCOD(J),len(BCOD(J))-1)=BCOD(I)
     B += 1
     AWT_COD(B) = right$(BCOD(J),len(BCOD(J)))
     AWT_LNI(B)=len(BCOD(J))
     AWT_NIV(B) = N
     AWT_TXT(B) = BTXT(J)
     AWT_ACT(B) = BACT(J)
     T += 1
     AWT_STA(B) = GSTAITM+T
    Elsif BTYP(J)=2 & left$(BCOD(J),len(BCOD(J))-1)=BCOD(I)
     B += 1
     AWT_NIV(B) = N+1
     AWT_TXT(B) = BTXT(J)
     AWT_LNI(B)=len(BCOD(J))
     For K=1 To AWT_NBR
      If BTYP(K)=3 & left$(BCOD(K),len(BCOD(K))-1)=BCOD(J)
       B += 1
       AWT_COD(B) = right$(BCOD(K),len(BCOD(K)))
       AWT_LNI(B)=len(BCOD(K))
       AWT_NIV(B) = N+1
       AWT_TXT(B) = BTXT(K)
       AWT_ACT(B) = BACT(K)
       T += 1
       AWT_STA(B) = GSTAITM+T
      Endif
     Next K
    Endif
   Next J
  Endif
 Elsif BTYP(I)=3
  For J=1 To AWT_NBR
   If BCOD(J)=left$(BCOD(I),len(BCOD(I))-1)
    J = 99 : Break
   Endif
  Next J
  If J<>99
   GMESSAGE = left$(BCOD(I),len(BCOD(I))-1)-":"-mess(154,124,1) : # Menu inexistant
   OK = 0 : Break
  Endif
 Endif
Next I
If !OK : Return : Endif

# Listes de gauche

Read [AWB]AWB0 = FENETRE
If fstat : Raz [F:AWB] : Endif

Sorta [F:AWB]NBLIS
&     [F:AWB]ROWLIS
&    ,[F:AWB]OBJLIS
&    ,[F:AWB]INTLIS
&    ,[F:AWB]CLELIS
&    ,[F:AWB]ORDLIS
&    ,[F:AWB]TRELIS
&    ,[F:AWB]BROLIS
&    ,[F:AWB]CHGLIS
&    ,[F:AWB]FLELIS
&    ,[F:AWB]ABRLIS
&    ,[F:AWB]ACTLIS
&    ,[F:AWB]EXPLIS
& Order By [F:AWB]ROWLIS(indice)

Raz J, N, R
For I=0 To [F:AWB]NBLIS-1
 If I=0
  If [F:AWB]FIRLIS=2
   Gosub INIVAR_DERLU
  Endif
 Endif
 K = 1
 If [F:AWB]ACTLIS(I)<>""
  Read [ACV]CODACT = [F:AWB]ACTLIS(I)
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  Read [AOB]ABREV = [F:AWB]OBJLIS(I)
  If fstat
   Call ECR_TRACE([F:AWB]OBJLIS(I)-mess(161,123,1),1) From GESECRAN : # Objet inexistant
   K = 0
  Elsif [F:AOB]CODACT<>""
   Read [ACV]CODACT = [F:AOB]CODACT
   If fstat or [F:ACV]FLACT<>2
    Call ECR_TRACE([F:AWB]OBJLIS(I)-mess(125,133,1)-"("+[F:AOB]CODACT+")",-1) From GESECRAN : # Objet inactif
    K = 0
   Endif
  Endif
 Endif
 If K
  J += 1
  AWB_OBJ(J) = [F:AWB]OBJLIS(I)
  AWB_CLE(J) = [F:AWB]CLELIS(I)
  AWB_ORD(J) = [F:AWB]ORDLIS(I)
  AWB_TRE(J) = [F:AWB]TRELIS(I)
  AWB_CHG(J) = [F:AWB]CHGLIS(I)
  AWB_FLE(J) = [F:AWB]FLELIS(I)
  AWB_BRO(J) = [F:AWB]BROLIS(I)
  AWB_EXP(J) = [F:AWB]EXPLIS(I)
  AWB_ABB(J) = [F:AWB]ABRLIS(I)
  AWB_INT(J) = [F:AWB]INTLIS(I)
  If [F:AOB]NOMFIC<>""
   AWB_FIC(J) = [F:AOB]NOMFIC
   Read [ATB]CODFIC = [F:AOB]NOMFIC
   If fstat
    Call ECR_TRACE([F:AOB]NOMFIC-mess(32,133,1),1) From GESECRAN : # Table inexistante
    Raz [F:ATB]
   Elsif [F:ATB]CODACT<>""
    Read [ACV]CODACT = [F:ATB]CODACT
    If fstat or [F:ACV]FLACT<>2
     Call ECR_TRACE([F:AOB]NOMFIC-mess(126,133,1)-"("+[F:ATB]CODACT+")",-1) From GESECRAN : # Table inactive
     Raz [F:ATB]
    Endif
   Endif
   If [F:ATB]CODFIC<>""
    If dim([F:AOB]ABRFIC)>0 & [F:AOB]ABRFIC<>""
     AWB_ABR(J) = [F:AOB]ABRFIC
    Else
     AWB_ABR(J) = [F:ATB]ABRFIC
    Endif
    If left$([F:AWB]CLELIS(I),4)="SPE_"
     Raz T
     For [ATI] Where CODFIC=[F:AOB]NOMFIC
      T += 1
     Next
     OK = 0
     For [ANX]ANX1 Where TABLE=[F:AOB]NOMFIC & FLACT=2
      T += 1
      If [F:ANX]CODIND=[F:AWB]CLELIS(I)
       AWB_IND(J) = [F:ANX]DESCRIPT
       AWB_NOI(J) = T
       OK = 1
       Break
      Endif
     Next
    Elsif [F:AWB]CLELIS(I)<>""
     Read [ATI]CODIND = [F:AOB]NOMFIC;[F:AWB]CLELIS(I)
     If fstat
      OK = 0
     Else
      AWB_IND(J) = [F:ATI]DESCRIPT
      AWB_NOI(J) = [F:ATI]NUMLIG
     Endif
    Else
     Read [ATI]NUMLIG(1) = [F:AOB]NOMFIC
     AWB_CLE(J) = [F:ATI]CODIND
     AWB_IND(J) = [F:ATI]DESCRIPT
     AWB_NOI(J) = [F:ATI]NUMLIG
    Endif
    If !OK
     GMESSAGE = [F:AOB]NOMFIC-[F:AWB]CLELIS(I)-mess(6,114,1) : # Clé inexistante
     Break
    Elsif AWB_GES(J)=3 & instr(1,AWB_IND(J),"+")=0 & instr(1,AWB_IND(J),"-")=0
     # Objet : Clé incorrecte
     GMESSAGE = mess(33,115,1)-[F:AOB]ABREV+"\"+[F:AWB]CLELIS(I)-":"-mess(1,127,1)
     OK = 0 : Break
    Endif
   Endif
  Endif
  If [F:AWB]OBJLIS(I)=OBJET & !R
   AWB_NUM(J) = ""
   R = 1
  Else
   N += 1
   If N=9 : N += 1 : Endif
   AWB_NUM(J) = num$(N)
  Endif
  If [F:AWB]OBJLIS(I)=OBJET & [F:AWB]DERLU=2 & [F:AWB]FIRLIS<>2 & !find(OBJET,AWB_OBJ(1..J-1))
   Gosub INIVAR_DERLU
  Endif
 Endif
Next I
If [F:AWB]DERLU=2 & [F:AWB]FIRLIS<>2 & !find(OBJET,[F:AWB]OBJLIS(0..[F:AWB]NBLIS-1))
 Gosub INIVAR_DERLU
Endif
If !OK : Return : Endif

AWB_NBR = J
AWB_DER = [F:AWB]DERLU
AWB_FIR = [F:AWB]FIRLIS
If dim([F:AWB]AFLBRO)>0
 AWB_AFL = [F:AWB]AFLBRO
Endif

# Objets

For L=1 To AWB_NBR
 Gosub INIVAR_OBJ
 If !OK : Break : Endif
Next L

Return

#------------------------------------------------------------------------#
# Sous-programmes
#------------------------------------------------------------------------#

#---------------------------------------------------------------------------------------------------#
# Initialisation browser derniers lus
#---------------------------------------------------------------------------------------------------#

$INIVAR_DERLU
J += 1
AWB_OBJ(J) = OBJET
AWB_CHG(J) = 2
AWB_BRO(J) = 1
AWB_NUM(J) = "9"
AWB_TRE(J) = 1
AWB_ORD(J) = 1
AWB_FLE(J) = 1
Read [AOB]ABREV = OBJET
AWB_FIC(J) = [F:AOB]NOMFIC
Read [ATB]CODFIC = [F:AOB]NOMFIC
If dim([F:AOB]ABRFIC)>0 & [F:AOB]ABRFIC<>""
 AWB_ABR(J) = [F:AOB]ABRFIC
Else
 AWB_ABR(J) = [F:ATB]ABRFIC
Endif
Read [ATI]NUMLIG(1) = [F:AOB]NOMFIC
AWB_CLE(J) = [F:ATI]CODIND
AWB_IND(J) = [F:ATI]DESCRIPT
AWB_NOI(J) = [F:ATI]NUMLIG
AWB_INT(J) = -(123*1000+196)  : # Derniers Lus
Return

#---------------------------------------------------------------------------------------------------#
# Initialisation des objets dans les browsers
#---------------------------------------------------------------------------------------------------#
$EVALLEG
K=0
Resume

$INIVAR_OBJ

Read [AOB]ABREV = AWB_OBJ(L)

AWB_ACC(L) = [F:AOB]ZACC
If AWB_NUM(L)="" & FENETRE<>"OFCY"
 AWB_FCY(L) = [F:AOB]ZSITE
Endif
AWB_GES(L) = [F:AOB]TYPGES

# Tables liées

J = 0
For [AOT] Where ABREV=AWB_OBJ(L)
 K = 1
 If [F:AOT]TABACT<>""
  Read [ACV]CODACT = [F:AOT]TABACT
  If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
 Endif
 If K
  Read [ATB]CODFIC = [F:AOT]TABFIC
  If !fstat
   If J>=MAXFIL
    # Trop de tables dans la gestion de cet objet (#)
    Call ECR_TRACE(AWB_OBJ(L)-":"-func AFNC.MES(mess(202,125,1),num$(J)),-1) From GESECRAN
    Break
   Endif
   J += 1
   AWB_FICLNK(J,L) = [F:ATB]CODFIC
   If [AOT]TABCLE<>""
    AWB_CLELNK(J,L) = [F:AOT]TABCLE
   Else
    Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
    AWB_CLELNK(J,L) = [F:ATI]CODIND
   Endif
   If [F:AOT]TABABR<>""
    AWB_ABRLNK(J,L) = [F:AOT]TABABR
   Else
    AWB_ABRLNK(J,L) = [F:ATB]ABRFIC
   Endif
   If [F:AOT]TABLIEN<>""
    AWB_EXPLNK(J,L) = [F:AOT]TABLIEN
    AWB_OBLLNK(J,L) = 1
   Else
    AWB_OBLLNK(J,L) = 0
    Filter [ATZ] Where CODFIC=ATB_FIC & LIEN=[F:ATB]CODFIC
    Read [ATZ]NUMLIG First
    Filter [ATZ]
    If !fstat
     If [F:ATZ]EXPLIEN<>""
      AWB_EXPLNK(J,L) = vireblc(format$("KT:200X",[F:ATZ]EXPLIEN),2)
     Else
      AWB_EXPLNK(J,L) = "[F:"+ATB_ABR+"]"+[F:ATZ]CODZONE
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
AWB_NBFIC(L) = J

# Champs sélection

Read [AOL]AOL0 = AWB_OBJ(L)

Raz J , AWB_NBSEL(L)
For I=1 To [F:AOL]NBSEL
 K = 1
 If [F:AOL]SELFIC(I-1)<>"" & [F:AOL]SELZON(I-1)<>""
  Read [ATZ]CODZONE=[F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1)
  If fstat
   K = 0
  Elsif [F:ATZ]CODTYP="ADI" & !func AFNC.ACTIV("LEG")
   Onerrgo EVALLEG
   Read [AMP]CODPAR=2;[F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1);"ADI"
   If !fstat & [F:AMP]VALPAR<>"" & num$(evalue([F:AMP]VALPAR))="909"
    K = 0
   Endif
   Onerrgo
  Endif
 Elsif [F:AOL]SELTYP(I-1)="ALEG" & !func AFNC.ACTIV("LEG")
  K = 0
 Endif
 If K
  AWB_NBSEL(L) += 1
  AWB_SELZON(AWB_NBSEL(L),L) = [F:AOL]SELZON(I-1)
  AWB_SELFIC(AWB_NBSEL(L),L) = [F:AOL]SELFIC(I-1)
  AWB_SELEXP(AWB_NBSEL(L),L) = [F:AOL]SELEXP(I-1)
  AWB_SELTYP(AWB_NBSEL(L),L) = [F:AOL]SELTYP(I-1)
  K = 1
  If [F:AOL]SELFIC(I-1)<>""
   Read [ATB]CODFIC = [F:AOL]SELFIC(I-1)
   If fstat
    K = 0
   Else
    If [F:AOL]SELFIC(I-1)=AWB_FIC(L)
     AWB_SELABR(AWB_NBSEL(L),L) = AWB_ABR(L)
    Endif
    If AWB_SELABR(AWB_NBSEL(L),L)=""
     For [AOT] Where ABREV=AWB_OBJ(L) & TABFIC=[F:AOL]SELFIC(I-1)
      K = 1
      If [F:AOT]TABACT<>""
       Read [ACV]CODACT = [F:AOT]TABACT
       If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
      Endif
      If K & [F:AOT]TABABR=""
       AWB_SELABR(AWB_NBSEL(L),L) = [F:ATB]ABRFIC : Break
      Endif
     Next AOT
    Endif
    If AWB_SELABR(AWB_NBSEL(L),L)=""
     For [AOT] Where ABREV=AWB_OBJ(L) & TABFIC=[F:AOL]SELFIC(I-1)
      K = 1
      If [F:AOT]TABACT<>""
       Read [ACV]CODACT = [F:AOT]TABACT
       If fstat or [F:ACV]FLACT<>2 : K = 0 : Endif
      Endif
      If K & [F:AOT]TABABR<>""
       AWB_SELABR(AWB_NBSEL(L),L) = [F:AOT]TABABR : Break
      Endif
     Next AOT
    Endif
    If AWB_SELABR(AWB_NBSEL(L),L)=""
     AWB_SELABR(AWB_NBSEL(L),L) = [F:ATB]ABRFIC
    Endif
    K = 1
    If [F:AOL]SELZON(I-1)<>""
     Read [ATZ]CODZONE = [F:AOL]SELFIC(I-1);[F:AOL]SELZON(I-1)
     If fstat
      K = 0
     Else
      AWB_SELTYP(AWB_NBSEL(L),L) = [F:ATZ]CODTYP
     Endif
    Endif
   Endif
  Endif
  If K
   If [F:AOL]SELINT(I-1)<>0
    AWB_SELINT(AWB_NBSEL(L),L) = [F:AOL]SELINT(I-1)
   Elsif [F:AOL]SELFIC(I-1)<>""
    AWB_SELINT(AWB_NBSEL(L),L) = [F:ATZ]NOCOURT
   Endif
   If AWB_SELTYP(AWB_NBSEL(L),L)<>""
    Read [ATY]CODTYP = AWB_SELTYP(AWB_NBSEL(L),L)
    AWB_SELTYPTYP(AWB_NBSEL(L),L) = [F:ATY]TYPTYP
    If [F:AOL]SELZON(I-1)<>""
     If [F:ATZ]LONG<>0
      AWB_SELLNG(AWB_NBSEL(L),L) = [F:ATZ]LONG
     Elsif [F:ATY]LNGTYP<>0
      AWB_SELLNG(AWB_NBSEL(L),L) = [F:ATY]LNGTYP
     Endif
     If [F:ATY]OPTION<>""
      AWB_SELOPT(AWB_NBSEL(L),L) = [F:ATY]OPTION
     Elsif [F:ATZ]OPTION<>""
      AWB_SELOPT(AWB_NBSEL(L),L) = [F:ATZ]OPTION
     Endif
    Else
     If dim([F:AOL]SELLNG)>0 & [F:AOL]SELLNG(I-1)<>0
      AWB_SELLNG(AWB_NBSEL(L),L) = [F:AOL]SELLNG(I-1)
     Endif
     If dim([F:AOL]SELSAI)>0 & [F:AOL]SELSAI(I-1)<>""
      AWB_SELOPT(AWB_NBSEL(L),L) = [F:AOL]SELSAI(I-1)
     Endif
    Endif
   Endif
   If AWB_SELZON(AWB_NBSEL(L),L)<>""
    If [F:ATY]NOLIB<>0
     AWB_SELNOLIB(AWB_NBSEL(L),L) = [F:ATY]NOLIB
    Else
     AWB_SELNOLIB(AWB_NBSEL(L),L) = [F:ATZ]NOLIB
    Endif
   Endif
   If [F:AOL]SELFIC(I-1)<>"" & [F:AOL]SELFIC(I-1)=AWB_FIC(L)
    If [F:ATZ]CODTYP="ATX"
     FLDTXT(L) = [F:ATZ]CODZONE
    Endif
   Endif
  Endif
  If AWB_SELTYP(AWB_NBSEL(L),L)="ATX"
   AWB_SELLNG(AWB_NBSEL(L),L) = 30
   AWB_SELFMT(AWB_NBSEL(L),L) = "K:30X"
   AWB_SELFOR(AWB_NBSEL(L),L) = '""'
  Elsif AWB_SELNOLIB(AWB_NBSEL(L),L)<>0
   Read [AML]MENLOC=AWB_SELNOLIB(AWB_NBSEL(L),L)
   If !fstat & [F:AML]LONG<>0
    AWB_SELLNG(AWB_NBSEL(L),L) = [F:AML]LONG
    AWB_SELFMT(AWB_NBSEL(L),L) = "LA"+format$("N0:5#",AWB_SELNOLIB(AWB_NBSEL(L),L))+":"+num$([F:AML]LONG)+"X"
   Else
    AWB_SELLNG(AWB_NBSEL(L),L) = 15
    AWB_SELFMT(AWB_NBSEL(L),L) = "LA"+format$("N0:5#",AWB_SELNOLIB(AWB_NBSEL(L),L))+":15X"
   Endif
   AWB_SELFOR(AWB_NBSEL(L),L) = '""'
  Else
   Case AWB_SELTYPTYP(AWB_NBSEL(L),L)
    When 1
     If AWB_SELLNG(AWB_NBSEL(L),L)=0
      AWB_SELLNG(AWB_NBSEL(L),L) = 4
     Endif
     AWB_SELFMT(AWB_NBSEL(L),L) = "N:"+num$(AWB_SELLNG(AWB_NBSEL(L),L))+"f"
     AWB_SELFOR(AWB_NBSEL(L),L) = '""'
    When 2,3,4,5,6
     If AWB_SELLNG(AWB_NBSEL(L),L)<>0
      AWB_SELFMT(AWB_NBSEL(L),L) = "N:"+num$(int(AWB_SELLNG(AWB_NBSEL(L),L)))+"F"
      Gosub FMTNUM
     Else
      Case AWB_SELTYPTYP(AWB_NBSEL(L),L)
       When 2     : AWB_SELLNG(AWB_NBSEL(L),L) = 5  : AWB_SELFMT(AWB_NBSEL(L),L) = "N:5#"
       When 3     : AWB_SELLNG(AWB_NBSEL(L),L) = 8  : AWB_SELFMT(AWB_NBSEL(L),L) = "N:8#"
       When 4,5,6 : AWB_SELLNG(AWB_NBSEL(L),L) = 15 : AWB_SELFMT(AWB_NBSEL(L),L) = "N:15F" : AWB_SELOPT(AWB_NBSEL(L),L) += "F"
      Endcase
      AWB_SELFOR(AWB_NBSEL(L),L) = '""'
     Endif
    When 8
     If AWB_SELOPT(AWB_NBSEL(L),L)<>""
      Gosub FMTDAT
     Else
      AWB_SELLNG(AWB_NBSEL(L),L) = func VALMSKLEC.LG(GFMDAT,8)
      AWB_SELFMT(AWB_NBSEL(L),L) = "DZz:"+GFMDAT
      AWB_SELFOR(AWB_NBSEL(L),L) = '""'
     Endif
    When Default
     If AWB_SELLNG(AWB_NBSEL(L),L)<>0
      AWB_SELFMT(AWB_NBSEL(L),L) = "K:"+num$(AWB_SELLNG(AWB_NBSEL(L),L))+"X"
      Gosub FMTCAR
     Else
      AWB_SELLNG(AWB_NBSEL(L),L) = 30
      AWB_SELFMT(AWB_NBSEL(L),L) = "K:"+num$(AWB_SELLNG(AWB_NBSEL(L),L))+"X"
      AWB_SELFOR(AWB_NBSEL(L),L) = '""'
     Endif
   Endcase
  Endif
 Endif
Next I

# Vérification des clés
If find(AWB_TRE(L),2,3) & AWB_FIC(L)<>""
 CHAINE = AWB_IND(L)
 NBCLES = 0
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  NBCLES += 1
  If I
   CHAINE = right$(CHAINE,I+1)
  Else
   CHAINE = ""
  Endif
 Wend
 If NBCLES>AWB_NBSEL(L)
  # Champs de sélection incompatibles avec l'index
  Call ECR_TRACE(AWB_OBJ(L)-":"-mess(73,126,1),-1) From GESECRAN
  OK = 0 : Return
 Endif
Endif

# Vérification des tables liées

J = 0
For CHAINE=FLDTXT(L),AWB_ACC(L),AWB_FCY(L)
 J += 1
 If CHAINE<>""
  K = 0
  For I=1 To AWB_NBFIC(L)
   Case J
    When 1 : If AWB_FICLNK(I,L) = "ATEXTE"  & AWB_ABRLNK(I,L)="ATX" : K = I : Break : Endif
    When 2 : If AWB_FICLNK(I,L) = "ACCES"   & AWB_ABRLNK(I,L)="ACC" : K = I : Break : Endif
    When 3 : If AWB_FICLNK(I,L) = "AFCTFCY" & AWB_ABRLNK(I,L)="AFF" : K = I : Break : Endif
   Endcase
  Next I
  If K
   AWB_NBFIC(L) -= 1
   For I=K To AWB_NBFIC(L)
    AWB_FICLNK(I,L) = AWB_FICLNK(I+1,L)
    AWB_EXPLNK(I,L) = AWB_EXPLNK(I+1,L)
    AWB_OBLLNK(I,L) = AWB_OBLLNK(I+1,L)
    AWB_CODLNK(I,L) = AWB_CODLNK(I+1,L)
    AWB_ABRLNK(I,L) = AWB_ABRLNK(I+1,L)
    AWB_CLELNK(I,L) = AWB_CLELNK(I+1,L)
   Next I
   AWB_FICLNK(I+1,L) = ""
   AWB_EXPLNK(I+1,L) = ""
   AWB_OBLLNK(I+1,L) = 0
   AWB_CODLNK(I+1,L) = ""
   AWB_ABRLNK(I+1,L) = ""
   AWB_CLELNK(I+1,L) = ""
  Endif
 Endif
Next CHAINE

# Vérification du nombre de tables liées

J = 0
If FLDTXT(L)<>""  : J += 1 : Endif
If AWB_ACC(L)<>"" : J += 1 : Endif
If AWB_FCY(L)<>"" : J += 1 : Endif
For I=1 To AWB_NBFIC(L)
 If AWB_EXPLNK(I,L)<>"" & AWB_OBLLNK(I,L)
  J += 1
 Endif
Next I
If AWB_ABB(L)<>"" & AWB_FCY(L)="" & AWB_ACC(L)="" & FLDTXT(L)="" & sum(AWB_OBLLNK(1..AWB_NBFIC(L),L))=0
 J += 1
Endif
If J>MAXLNK
 # Trop de liens sur cette table
 Call ECR_TRACE(AWB_FIC(L)-":"-mess(12,133,1)-"(+"+num$(MAXLNK)+")",-1) From GESECRAN
Endif
Return

#---------------------------------------------------------------------------------------------------#
# Chargement des actions sur boutons et des paramètres
#---------------------------------------------------------------------------------------------------#

$LECACT
Gosub MEMACT
While [F:ACT]ACTSUI<>"" & !fstat & OK
 Read [ACT]ACTION = [F:ACT]ACTSUI
 If fstat
  Call ECR_TRACE([F:ACT]ACTSUI-mess(84,133,1),1) From GESECRAN : # Action inexistante
 Else
  K = 1
  If [F:ACT]CODACT<>""
   Read [ACV]CODACT = [F:ACT]CODACT
   If fstat or [F:ACV]FLACT<>2
    K = 0
   Endif
  Endif
  If K
   If A>=MAXACT
    GMESSAGE = mess(91,133,1)-"("+num$(MAXACT)+")" : # Trop d'actions
    OK = 0 : Break
   Endif
   A += 1
   ACT_SUI(A-1) = A
   ACT_COD(A)   = [F:ACT]ACTION
   Gosub MEMACT
  Endif
 Endif
Wend
Return

$MEMACT
ACT_TYP(A)  = [F:ACT]TYP
ACT_TYA(A)  = [F:ACT]TYPACT
ACT_PAR1(A) = [F:ACT]PARAM1
ACT_PAR2(A) = [F:ACT]PARAM2
ACT_PAR3(A) = [F:ACT]PARAM3
ACT_PAR4(A) = [F:ACT]PARAM4
ACT_PAR5(A) = [F:ACT]PARAM5
ACT_TRT(A)  = [F:ACT]CODTRT
ACT_SPE(A)  = [F:ACT]SPETRT
ACT_SUB(A)  = [F:ACT]SUBPRG
ACT_INS(A)  = [F:ACT]INSTRU
Raz K, P
For [ATR]NOPAR Where ACTION=ACT_COD(A)
 K += 1
 If ACT_TYA(A)<>2 or K>1
  If P>=MAXPAR
   GMESSAGE = mess(14,135,1)-"("+num$(MAXPAR)+")" : # Trop de paramètres
   OK = 0 : Break
  Endif
  P += 1
  PAR_COD(A,P) = [F:ATR]CODPAR
  PAR_TYP(A,P) = [F:ATR]TYPPAR
  N = 100 * STD + W
  Filter [AWP] Where WIN=[F:AWI]WIN & NUM=N & PARAM=[F:ATR]CODPAR
  Read [AWP]AWP0 First
  Filter [AWP]
  If fstat
   PAR_ADR(A,P) = 2
   PAR_VAL(A,P) = ""
  Else
   If [F:ATR]ADRVAL=1 & [F:AWP]VALEUR=""
    PAR_ADR(A,P) = 2
   Else
    PAR_ADR(A,P) = [F:ATR]ADRVAL
   Endif
   PAR_VAL(A,P) = [F:AWP]VALEUR
  Endif
 Endif
Next ATR
ACT_NBP(A) = P
Return

#--------------------------------------------------------------#
# Calcul du format de la colonne
#--------------------------------------------------------------#

$FMTCAR
AWB_SELFOR(AWB_NBSEL(L),L) = '"K'
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"T") : AWB_SELFOR(AWB_NBSEL(L),L) += "T"            : # Tokenisé
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"D") : AWB_SELFOR(AWB_NBSEL(L),L) += "TD"           : # Token interdites
Endif
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"1") : AWB_SELFOR(AWB_NBSEL(L),L) += "1"  : Endif   : # Au moins 1 caractère
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"z") : AWB_SELFOR(AWB_NBSEL(L),L) += "z"  : Endif   : # Commentaires non affichés
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"=") : AWB_SELFOR(AWB_NBSEL(L),L) += "="            : # Centré
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"<") : AWB_SELFOR(AWB_NBSEL(L),L) += "<"            : # Cadré à gauche
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),">") : AWB_SELFOR(AWB_NBSEL(L),L) += ">"            : # Cadré à droite
Endif
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"U") : AWB_SELFOR(AWB_NBSEL(L),L) += "U" : Endif    : # Format fichier
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"W") : AWB_SELFOR(AWB_NBSEL(L),L) += "W" : Endif    : # Non creusé
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"X") : AWB_SELFOR(AWB_NBSEL(L),L) += "X" : Endif    : # Saisie masquée
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"c") : AWB_SELFOR(AWB_NBSEL(L),L) += "c" : Endif    : # Colorisé
AWB_SELFOR(AWB_NBSEL(L),L) += ":"
AWB_SELFOR(AWB_NBSEL(L),L) += num$(AWB_SELLNG(AWB_NBSEL(L),L))
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"C")
 AWB_SELFOR(AWB_NBSEL(L),L) += "c"
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"A")
 If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"#")
  AWB_SELFOR(AWB_NBSEL(L),L) += "B"
 Else
  AWB_SELFOR(AWB_NBSEL(L),L) += "A"
 Endif
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"#")
 AWB_SELFOR(AWB_NBSEL(L),L) += "#"
Else
 AWB_SELFOR(AWB_NBSEL(L),L) += "X"
Endif
AWB_SELFOR(AWB_NBSEL(L),L) += '"'
Return

#-----------------#
$FMTNUM
AWB_SELFOR(AWB_NBSEL(L),L) = '"N'
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"+") : AWB_SELFOR(AWB_NBSEL(L),L) += "+" : Endif       : # Nb > 0
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"z") : AWB_SELFOR(AWB_NBSEL(L),L) += "z" : Endif       : # Zéro non affiché
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"0") : AWB_SELFOR(AWB_NBSEL(L),L) += "0" : Endif       : # Paddé avec des 0
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"3") : AWB_SELFOR(AWB_NBSEL(L),L) += "3" : Endif       : # Séparateur de 3 chiffres
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"W") : AWB_SELFOR(AWB_NBSEL(L),L) += "W" : Endif       : # Non creusé
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"-") : AWB_SELFOR(AWB_NBSEL(L),L) += "-" : Endif       : # Signe forcé
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"D") : AWB_SELFOR(AWB_NBSEL(L),L) += "D" : Endif       : # Signe après
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"c") : AWB_SELFOR(AWB_NBSEL(L),L) += "c" : Endif       : # Colorisé
AWB_SELFOR(AWB_NBSEL(L),L) += ":"
AWB_SELFOR(AWB_NBSEL(L),L) += num$(AWB_SELLNG(AWB_NBSEL(L),L))
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"F") & AWB_SELLNG(AWB_NBSEL(L),L)=int(AWB_SELLNG(AWB_NBSEL(L),L)) : # Flottant si pas de décimales
 AWB_SELFOR(AWB_NBSEL(L),L) += "F"
Else
 AWB_SELFOR(AWB_NBSEL(L),L) +="#"
Endif
AWB_SELFOR(AWB_NBSEL(L),L) += '"'
Return

#-----------------#
$FMTDAT
AWB_SELFOR(AWB_NBSEL(L),L) = '"D'
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"z")  : AWB_SELFOR(AWB_NBSEL(L),L) += "z" : Endif       : # Commentaires non affichés
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"Z")  : AWB_SELFOR(AWB_NBSEL(L),L) += "Z" : Endif       : # Date nulle autorisée
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"W")  : AWB_SELFOR(AWB_NBSEL(L),L) += "W" : Endif       : # Non creusé
If instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"c")  : AWB_SELFOR(AWB_NBSEL(L),L) += "c" : Endif       : # Colorisé
If !instr(1,AWB_SELFOR(AWB_NBSEL(L),L),"Z") : AWB_SELFOR(AWB_NBSEL(L),L) += "Z" : Endif
If !instr(1,AWB_SELFOR(AWB_NBSEL(L),L),"z") : AWB_SELFOR(AWB_NBSEL(L),L) += "z" : Endif
AWB_SELFOR(AWB_NBSEL(L),L) += ':"'
If    instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"1") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMDAT'  : K = func VALMSKLEC.LG(GFMDAT,8)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"2") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMDAT4' : K = func VALMSKLEC.LG(GFMDAT4,10)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"3") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMDAT3' : K = func VALMSKLEC.LG(GFMDAT3,15)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"4") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMDAT9' : K = func VALMSKLEC.LG(GFMDAT9,20)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"5") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMJOU'  : K = func VALMSKLEC.LG(GFMJOU,5)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"6") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMMOI'  : K = func VALMSKLEC.LG(GFMMOI,5)
Elsif instr(1,AWB_SELOPT(AWB_NBSEL(L),L),"7") : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMMOI4' : K = func VALMSKLEC.LG(GFMMOI4,7)
Else                                          : AWB_SELFOR(AWB_NBSEL(L),L) += '+GFMDAT'  : K = func VALMSKLEC.LG(GFMDAT,8)
Endif
AWB_SELLNG(AWB_NBSEL(L),L) = K
Return

