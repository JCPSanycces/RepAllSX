#<AdxTL>@(#)9.0.0.0 $Revision$
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# FPE     05.04.2018 X3-85531 : Amount printed with no decimals if     #
#                               Currency parameter was empty.          #
########################################################################

$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE From CPTRPT
 When "INIPAR" : Gosub INIPAR From CPTRPT
 When "CONT1"  : Gosub CONT1 From CPTRPT
Endcase
Return

####################################################
## Etats DETNPBP
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

####################################################
## Vérif paramètres
####################################################
GOK = 1
Call IMPRIME(NBPAR,PARAMETRE) From CPTRPT
If GOK<1 : End : Endif

Call TEMPON("O") From GESECRAN

####################################################
## Récup paramètres
####################################################
Local Char    PARAM(30) , ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer I ,  K , W

Local Char    SOCIETE(GLONCPY) , SITDEB(GLONFCY) , SITFIN(GLONFCY)
Local Char    DEVISE(GLONCUR) , COLDEB(GLONSAC) , COLFIN(GLONSAC) , GRPCOL(GLONGSC)
Local Char    CPTDEB(GLONGAC) , CPTFIN(GLONGAC)
Local Integer NUMBID
Local Date    DATDEB , DATFIN
Local Integer EFFACE
Local Char    NOM_ETAT(20)
# Issue X3-75715
Local Char    W_LEDTYP(2)             # Issue X3-75715 - 2018-02-13 by JMR : Field to recover the Ledger type
Local Decimal W_AMTLED : W_AMTLED = 0 # Issue X3-75715 - 2018-02-13 by JMR : Field to recover record if Ledger amount > 0
Local Decimal W_AMTCUR : W_AMTCUR = 0 # Issue X3-75715 - 2018-02-13 by JMR : Field to recover record if Entry amount > 0
# End issue X3-75715

Local Integer ICRIT
Local Char    CRITERE(250)(1..5) , SUBCRIT(250)
Local Char    X3PRF(10) , X3FCT(10)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : NUMREQ = val(PARAM)
Call GETPARAM("__REPORT",NBPAR,PARAMETRE,PARAM)
K = instr(1,PARAM,".")
If K : PARAM = left$(PARAM,K-1) : Endif
ETAT = PARAM

NOM_ETAT = ETAT
W = instr(1,NOM_ETAT,"-")
If W : NOM_ETAT = right$(NOM_ETAT,W+1) : Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITDEB)
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITFIN)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)    : DATDEB   = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)    : DATFIN   = PARAM
Call GETPARAM("devise",NBPAR,PARAMETRE,DEVISE)
Call GETPARAM("coldeb",NBPAR,PARAMETRE,COLDEB)
Call GETPARAM("colfin",NBPAR,PARAMETRE,COLFIN)
Call GETPARAM("grpcol",NBPAR,PARAMETRE,GRPCOL)
Call GETPARAM("comptedeb",NBPAR,PARAMETRE,CPTDEB)
Call GETPARAM("comptefin",NBPAR,PARAMETRE,CPTFIN)
Call GETPARAM("efface",NBPAR,PARAMETRE,PARAM)    : EFFACE   = val(PARAM)
Call GETPARAM("referentiel",NBPAR,PARAMETRE,W_LEDTYP) # Issue X3-75715 - 2018-02-13 by JMR : Recover the Ledger type

Call GETPARAM("comptefin",NBPAR,PARAMETRE,CPTFIN)
Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

####################################################
## Quelques contrôles
####################################################

Gosub OUVFIC

####################################################
## Affectation du no de requête
####################################################

PARAM = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

####################################################
## Effacement table temporaire
####################################################

If EFFACE
 Call DEBTRANS From GLOCK
 Gosub TR_EFF
Endif

Gosub TR_ECR

Call TEMPOFF From GESECRAN
#Infbox num$(LIGNE)-"lignes"-"Requête"-num$(NUMREQ)

End


####################################################
$TR_ECR
Raz CRITERE
ICRIT = 1

## Critères généraux

Call ADDCRIT(CRITERE,ICRIT,'[FGR]CPY="'+SOCIETE+'"')
If SITDEB<>""
 Call ADDCRIT(CRITERE,ICRIT,'[FGR]FCY>="'+SITDEB+'"')
Endif
If SITFIN<>""
 Call ADDCRIT(CRITERE,ICRIT,'[FGR]FCY<="'+SITFIN+'"')
Endif
Call ADDCRIT(CRITERE,ICRIT,'[DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']')
Call ADDCRIT(CRITERE,ICRIT,'[DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']')

Call ADDCRIT(CRITERE,ICRIT,'[HAE]STA=2')
Call ADDCRIT(CRITERE,ICRIT,'find([HAE]CAT,1,4)')
#Call ADDCRIT(CRITERE,ICRIT,'[HAE]PER>0')

# Issue X3-75715
If DEVISE <> ""
 Call ADDCRIT(CRITERE,ICRIT,'[DAE]CUR="'+DEVISE+'"')
Endif
# End issue X3-75715

SUBCRIT =  '([DAE]MTC="" | [DAE]MTC>="a" |'
SUBCRIT -= '[DAE]MTCDATMAX>['+format$(GFMD,DATFIN)+'] |'
SUBCRIT -= '[DAE]MTCDATMIN<['+format$(GFMD,DATDEB)+'])'
Call ADDCRIT(CRITERE,ICRIT,SUBCRIT)

Call ADDCRIT(CRITERE,ICRIT,'[DAE]SAC<>""')
If COLDEB<>""
  Call ADDCRIT(CRITERE,ICRIT,'[DAE]SAC>="'+COLDEB+'"')
Endif
If COLFIN<>""
  Call ADDCRIT(CRITERE,ICRIT,'[DAE]SAC<="'+COLFIN+'"')
Endif
If CPTDEB<>""
  Call ADDCRIT(CRITERE,ICRIT,'[DAE]BPR>="'+CPTDEB+'"')
Endif
If CPTFIN<>""
  Call ADDCRIT(CRITERE,ICRIT,'[DAE]BPR<="'+CPTFIN+'"')
Endif

If GRPCOL<>""
 Gosub SETSOC
 If SOC<>""
  Read [GCM]GCM0 = [F:CPY]ACM
  Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
 Endif

 SUBCRIT = 'find([F:DAE]SAC'
 For [GSC]GSC0 Where COA = [F:LED]COA & GRU=GRPCOL
  SUBCRIT += ',"'+[F:GSC]SAC+'"'
 Next
 SUBCRIT += ")"
 Call ADDCRIT(CRITERE,ICRIT,SUBCRIT)
Endif

For I=1 To dim(CRITERE)
 If CRITERE(I)="" : CRITERE(I) = "1=1" : Endif
Next I

# Issue X3-75715
If W_LEDTYP <> ""
  Call ADDCRIT(CRITERE,ICRIT,'[DAE]LEDTYP='+W_LEDTYP)
Endif

Call ADDCRIT(CRITERE,ICRIT,'[DAE]AMTLED<>'+num$(W_AMTLED))
Call ADDCRIT(CRITERE,ICRIT,'[DAE]AMTCUR<>'+num$(W_AMTCUR))
# End issue X3-75715

Link [DAE] With [HAE]HAE0=[DAE]TYP;[DAE]NUM , [FGR]FGR0=SOCIETE;[DAE]FCYLIN
&                  ,[BPR]BPR0=[F:DAE]BPR , [ACC]CODACC=GUSER;[F:BPR]ACS , [AFF]AFF0=[DAE]FCYLIN;X3PRF;X3FCT
&   As [LNK]
&   Where evalue(CRITERE(1)) & evalue(CRITERE(2)) & evalue(CRITERE(3)) & evalue(CRITERE(4))
&   & [F:ACC]CONSUL=2 & [F:AFF]PRFCOD<>""
&   Order By Key CLE = [DAE]BPR

Columns [LNK] ([F:DAE]BPR,[F:DAE]ACCNUM)

LIGNE = 0
Call DEBTRANS From GLOCK
Gosub TR1
Return

####################################################
$TR1
GOK = 1
Trbegin [ARM]
 For [LNK]CLE : #With Nohint
  LIGNE += 1
  Raz [F:ARM]
  [F:ARM]RPTCOD = ETAT
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = LIGNE
  [F:ARM]CLEA1  = [F:DAE]BPR
  [F:ARM]CLEA2  = "B"
# Issue X3-85531
#   Get currency code.
#   If Currency param is empty, get the currency pertaining to the selected Ledger.
#   If Currency param is not empty, that's it.
  If DEVISE = ""
    Read [CPY]CPY0 = SOCIETE
    If fstat
      GOK = 0 : Call FSTA("CPY") From GLOCK : Break
    Else
      Read [GCM]GCM0 = [F:CPY]ACM
      If fstat
        GOK = 0 : Call FSTA("GCM") From GLOCK : Break
      Else
        [F:ARM]CLEA3 = [F:GCM]CUR(val(W_LEDTYP) - 1)
      Endif
    Endif
  Else
    [F:ARM]CLEA3  = DEVISE
  Endif
# End issue X3-85531
  [F:ARM]CLEN1  = [F:DAE]ACCNUM
  If NUMBID=0 : NUMBID = [F:DAE]ACCNUM : Endif
  [F:ARM]CREDAT = date$
  Write [ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit

Return

$AB_TR1
Rollback
Return

$TR_EFF
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=ETAT & USR=GUSER
Commit
Return

$OUVFIC
If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:GSC])=0 : Local File GRPSAC     [GSC] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER  [BPR] : Endif
If clalev([F:ACC])=0 : Local File ACCES     [ACC] : Endif
If clalev([F:AFF])=0 : Local File AFCTFCY   [AFF] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
Return

Subprog ADDCRIT(CRITERE,ICRIT,SUBCRIT)
Variable Char    CRITERE()(1..)
Variable Integer ICRIT
Value    Char    SUBCRIT
If len(CRITERE(ICRIT))+len(SUBCRIT)>240
 ICRIT += 1
Endif
If CRITERE(ICRIT)<>"" : CRITERE(ICRIT) -= "&" : Endif
CRITERE(ICRIT) -= SUBCRIT
End

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

$SETSOC
Local Char SOC(GLONCPY)
SOC = ""
K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
If K
 SOC = [M:RPT]VALINT1(K-1)
 Read [CPY]CPY0 = SOC
 If [F:CPY]CPYLEGFLG <> [V]CST_AYES
  Read [FGR]FGR0(1) = SOC
  Read [FCY]FCY0 = [F:FGR]FCY
  SOC = [F:FCY]LEGCPY
  Read [CPY]CPY0 = SOC
 Endif
Endif
Return

