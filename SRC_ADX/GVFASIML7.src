#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 22 Décembre  2017 14:25:58

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EFASIML" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EFASIML" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub FASIML7
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$FASIML7
 #--> Désignation
 [F:EVT0]DES        = [F:MAS1]AASDES1
 #--> Menus locaux
 If G_ACTCCN=G_OUI
  [F:EVT0]RNWFLG     = [F:MAS1]RNWFLG
 Endif
 [F:EVT0]PURNAT     = [F:MAS1]PURNAT
 [F:EVT0]OWNTYP     = [F:MAS1]OWNTYP
 [F:EVT0]GACACN     = [F:MAS1]GACACN
 If G_ACTIAS=G_OUI
  [F:EVT0]IASACN     = [F:MAS1]IASACN
 Endif
 [F:EVT0]IMLTYP     = [F:DEPW]IMLTYP
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = [F:MAS1]USRFLDM1
 [F:EVT0]USRFLDM2   = [F:MAS1]USRFLDM2
 [F:EVT0]USRFLDM3   = [F:MAS1]USRFLDM3
 [F:EVT0]USRFLDM4   = [F:MAS1]USRFLDM4
 [F:EVT0]USRFLDM5   = [F:MAS1]USRFLDM5
 [F:EVT0]USRFLDM6   = [F:MAS1]USRFLDM6
 [F:EVT0]USRFLDC1   = [F:MAS1]USRFLDC1
 [F:EVT0]USRFLDC2   = [F:MAS1]USRFLDC2
 [F:EVT0]IML        = [F:DEPW]IML
 [F:EVT0]IMLRVE     = [F:DEPW]IMLRVE
 [F:EVT0]RVARVE     = func TRTFASIML.GET_RVARVE([F:DEPW]IML, [F:DEPW]EXERVADEV+[F:DEPW]PERRVADEV-[F:DEPW]RVACRB)
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [F:MAS1]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
 [F:EVT0]USRFLDA1   = [F:MAS1]USRFLDA1
 [F:EVT0]USRFLDA2   = [F:MAS1]USRFLDA2
 [F:EVT0]USRFLDA3   = [F:MAS1]USRFLDA3
 [F:EVT0]USRFLDA4   = [F:MAS1]USRFLDA4
 [F:EVT0]USRFLDA5   = [F:MAS1]USRFLDA5
 [F:EVT0]USRFLDA6   = [F:MAS1]USRFLDA6
 [F:EVT0]USRFLDA7   = [F:MAS1]USRFLDA7
 [F:EVT0]USRFLDA8   = [F:MAS1]USRFLDA8
 [F:EVT0]USRFLDA9   = [F:MAS1]USRFLDA9
 [F:EVT0]USRFLDA10  = [F:MAS1]USRFLDA10
 [F:EVT0]ACGGRP     = [F:MAS1]ACGGRP
 [F:EVT0]AASBUS     = [F:MAS1]AASBUS
 [F:EVT0]DSP        = [F:MAS1]DSP
 [F:EVT0]DIE1       = [F:MAS1]DIE(0)
 [F:EVT0]CCE1       = [F:MAS1]CCE(0)
 [F:EVT0]DIE2       = [F:MAS1]DIE(1)
 [F:EVT0]CCE2       = [F:MAS1]CCE(1)
 [F:EVT0]DIE3       = [F:MAS1]DIE(2)
 [F:EVT0]CCE3       = [F:MAS1]CCE(2)
 [F:EVT0]DIE4       = [F:MAS1]DIE(3)
 [F:EVT0]CCE4       = [F:MAS1]CCE(3)
 [F:EVT0]DIE5       = [F:MAS1]DIE(4)
 [F:EVT0]CCE5       = [F:MAS1]CCE(4)
 [F:EVT0]DIE6       = [F:MAS1]DIE(5)
 [F:EVT0]CCE6       = [F:MAS1]CCE(5)
 [F:EVT0]DIE7       = [F:MAS1]DIE(6)
 [F:EVT0]CCE7       = [F:MAS1]CCE(6)
 [F:EVT0]DIE8       = [F:MAS1]DIE(7)
 [F:EVT0]CCE8       = [F:MAS1]CCE(7)
 [F:EVT0]DIE9       = [F:MAS1]DIE(8)
 [F:EVT0]CCE9       = [F:MAS1]CCE(8)
 If G_ACTIAS=G_OUI
  [F:EVT0]IASCGU     = [F:MAS1]IASCGU
 Endif
 [F:EVT0]GAC        = [F:MAS1]GAC
 If G_ACTIAS=G_OUI
  [F:EVT0]IASACC     = [F:MAS1]IASACC
 Endif
 [F:EVT0]DPM        = [F:DEPW]DPM
 [F:EVT0]DIE10      = [F:MAS1]DIE(9)
 [F:EVT0]CCE10      = [F:MAS1]CCE(9)
 [F:EVT0]DIE11      = [F:MAS1]DIE(10)
 [F:EVT0]CCE11      = [F:MAS1]CCE(10)
 [F:EVT0]DIE12      = [F:MAS1]DIE(11)
 [F:EVT0]CCE12      = [F:MAS1]CCE(11)
 [F:EVT0]DIE13      = [F:MAS1]DIE(12)
 [F:EVT0]CCE13      = [F:MAS1]CCE(12)
 [F:EVT0]DIE14      = [F:MAS1]DIE(13)
 [F:EVT0]CCE14      = [F:MAS1]CCE(13)
 [F:EVT0]DIE15      = [F:MAS1]DIE(14)
 [F:EVT0]CCE15      = [F:MAS1]CCE(14)
 [F:EVT0]DIE16      = [F:MAS1]DIE(15)
 [F:EVT0]CCE16      = [F:MAS1]CCE(15)
 [F:EVT0]DIE17      = [F:MAS1]DIE(16)
 [F:EVT0]CCE17      = [F:MAS1]CCE(16)
 [F:EVT0]DIE18      = [F:MAS1]DIE(17)
 [F:EVT0]CCE18      = [F:MAS1]CCE(17)
 [F:EVT0]DIE19      = [F:MAS1]DIE(18)
 [F:EVT0]CCE19      = [F:MAS1]CCE(18)
 [F:EVT0]DIE20      = [F:MAS1]DIE(19)
 [F:EVT0]CCE20      = [F:MAS1]CCE(19)
 #--> Dates
 [F:EVT0]USRFLDD1   = [F:MAS1]USRFLDD1
 [F:EVT0]USRFLDD2   = [F:MAS1]USRFLDD2
 [F:EVT0]USRFLDD3   = [F:MAS1]USRFLDD3
 [F:EVT0]USRFLDD4   = [F:MAS1]USRFLDD4
 [F:EVT0]FIYSTRDAT  = [F:DEPW]FIYSTRDAT
 [F:EVT0]FIYENDDAT  = [F:DEPW]FIYENDDAT
 [F:EVT0]PERSTRDAT  = [F:DEPW]PERSTRDAT
 [F:EVT0]PERENDDAT  = [F:DEPW]PERENDDAT
Return

$ECLATE_NBFLD
 LNBFLD=3
Return

$ECLATE_STATUS
  T_INTNOMZON(0)    = "IML"
  T_INTNOMZON(1)    = "IMLRVE"
  T_INTNOMZON(2)    = "RVARVE"
Return

$INFO_EVTINT
 EVT = "FASIML"
 LPLN= 7
Return

