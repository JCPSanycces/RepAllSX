#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------------
# TRTMAKFIC : Fabrication de librairie FIC
#----------------------------------------------------------------------------------------------
# (C) PROSPER
# (C) PROSPER - 19/03/08 - Adaptation à la paye !
#----------------------------------------------------------------------------------------------

Call TRTMAKFIC From TRTMAKFIC
End

Subprog XMAKEZFIC()

Local File ATABLE,ATABZON,ATABIND,ATEXTE,ATYPE

Local Char TABLEDEB(type([F:ATB]CODFIC)-10)
Local Char TABLEFIN(type([F:ATB]CODFIC)-10)
Local Char ABREV(3)(1..20),CHAINE(250),TRAIT(250),ORDRE(250),SCCS(250),CHEMIN(250),
&            CHEMIN_MODULE(250)(1..20),CHEMIN_STANDARD(250),RACINE(10),NOMZONE(10)(1..20),
&            TYP(15),COMPLEMENT(60),CARACTERE(1),NOMCLE(10),MESSAGE(250)
Local Libelle MODULEDEB,MODULEFIN,RAZ_STANDARD,RAZ_MODULE
Local Integer ENTREE_STANDARD,ENTREE_MODULE,NBMODULE,I,J,NBZONE,CHAMP_INDICE,OK

[L]SCCS = "#<AdxT" + [V]GADOVERS + ">@(#)0.0.0.0 $Revision$"

[L]SCCS += "Librairie de fonctions OPEN/CLOSE "

[L]ENTREE_STANDARD = 2
[L]ENTREE_MODULE = 2
[L]RAZ_STANDARD = 2
[L]RAZ_MODULE = 2
[L]CHEMIN = filpath("TRT","","")
[L]RACINE = "WWFIC"

Case [V]GPRODUIT
    When 1
        # GESCOM ( X3 )

        [L]TABLEDEB = ""
        [L]TABLEFIN = "ZZZZZZZZZZ"
        [L]MODULEDEB = 1
        [L]MODULEFIN = 13
        
        [L]NBMODULE = 13
        
        [L]ABREV(1) = "GEN"    : # Superviseur
        [L]ABREV(2) = "CPT"    : # Compta
        [L]ABREV(3) = "TIE"    : # Tiers
        [L]ABREV(4) = "IMM"    : # Immo
        [L]ABREV(5) = "VEN"    : # Vente
        [L]ABREV(6) = "ACH"    : # Achat
        [L]ABREV(7) = "STK"    : # Stock
        [L]ABREV(8) = "GPA"    : # GPAO
        [L]ABREV(9) = "TCO"    : # Tronc Commun
        [L]ABREV(10) = "DEV"   : # Développement
        [L]ABREV(11) = "IX3"   : # Interne X3
        [L]ABREV(12) = "CRM"    : # Support Client
        [L]ABREV(13) = "ACO"    : # Action Commerciale

    When 2
        # PAYE ( SPRH )

        [L]TABLEDEB = ""
        [L]TABLEFIN = "ZZZZZZZZZZ"
        [L]MODULEDEB = 1
        [L]MODULEFIN = 11
        
        [L]NBMODULE = 11
        
        [L]ABREV(1) = "GEN"    : # Superviseur
        [L]ABREV(2) = "PAY"    : # Paye
        [L]ABREV(3) = "CPT"    : # Interface compta
        [L]ABREV(4) = "TPS"    : # Gestion des temps
        [L]ABREV(5) = "FOR"    : # Formation
        [L]ABREV(6) = "NDF"    : # Note de frais
        [L]ABREV(7) = "INA"    : # Inactif ( :D )
        [L]ABREV(8) = "COM"    : # Compétence
        [L]ABREV(9) = "TCO"    : # Tronc Commun
        [L]ABREV(10) = "DEV"   : # Développement
        [L]ABREV(11) = "IX3"   : # Interne X3

Endcase

[L]CHEMIN_STANDARD = [L]CHEMIN + "/" + [L]RACINE + "STD.src"

For [L]I = 1 To [L]NBMODULE
    [L]CHEMIN_MODULE([L]I) = [L]CHEMIN + "/" + [L]RACINE + [L]ABREV([L]I) + ".src"
Next

[L]MESSAGE = "Génération librairies OPEN/CLOSE : "+[L]RACINE
[L]MESSAGE += "\"
[L]MESSAGE += "Sortie : "+ctrans([L]CHEMIN,"\","/")
Call OUINON([L]MESSAGE,[L]OK) From GESECRAN
If [L]OK = 1 : End : Endif
   
adxifs = "" : adxirs = chr$(10)

If [L]ENTREE_STANDARD = 2
    If [L]RAZ_STANDARD = 2 or filinfo([L]CHEMIN_STANDARD,7) <= 0
        Openo [L]CHEMIN_STANDARD , 0 
        Wrseq [L]SCCS
        Wrseq "#----------------------------------------------------------"
        Wrseq "# Librairie de fonctions OPEN/CLOSE sur tables standards"
        Wrseq "#           => Renvoi l'appel vers la librairie concernée"
        Wrseq "#----------------------------------------------------------"
        Wrseq "# (C) PROSPER "+format$("Dz:DD[/]MM[/]YY",date$)+" - GENERATION AUTOMATIQUE"
        Wrseq "#----------------------------------------------------------"
        Wrseq "# Dictionnaire Générateur : "+adxmac(-1)+"@"+nomap
        Wrseq "#----------------------------------------------------------"
        Wrseq
        Wrseq 'Call MESSAGE("Ce module est une librairie") From GESECRAN'
        Wrseq "End"
        Openo
    Endif
Endif

If [L]ENTREE_MODULE = 2
    For [L]I = [L]MODULEDEB To [L]MODULEFIN
        If filinfo([L]CHEMIN_MODULE([L]I),7) <= 0 or [L]RAZ_MODULE = 2
            Openo [L]CHEMIN_MODULE([L]I) , 0
            Wrseq [L]SCCS
            Wrseq "#----------------------------------------------------------"
            Wrseq "# Librairie de fonctions OPEN/CLOSE sur tables "+[L]ABREV([L]I)
            Wrseq "#----------------------------------------------------------"
            Wrseq "# (C) PROSPER "+format$("Dz:DD[/]MM[/]YY",date$)+" - GENERATION AUTOMATIQUE"
            Wrseq "#----------------------------------------------------------"
            Wrseq
            Wrseq 'Call MESSAGE("Ce module est une librairie") From GESECRAN'
            Wrseq "End"
            Openo        
        Endif
    Next
Endif

For [F:ATB]CODFIC Where [F:ATB]CODFIC >= [L]TABLEDEB 
&                & [F:ATB]CODFIC <= [L]TABLEFIN
&                & [F:ATB]MODULE >= [L]MODULEDEB
&                & [F:ATB]MODULE <= [L]MODULEFIN
    # La belle entête !!!.....
    [L]CHAINE = "# " + format$("K:10X",[F:ATB]CODFIC) + " : " 
    Read [F:ATX]NUMERO = "FRA" ; [F:ATB]INTITFIC
    If fstat = 0
        [L]CHAINE += [F:ATX]TEXTE
    Else
        [L]CHAINE += "PANIC - Pas de texte"
    Endif
    [L]TRAIT = "#" + string$(len([L]CHAINE),"-")
    If [L]ENTREE_STANDARD = 2
        Gosub ENTREE_STANDARD 
    Endif
    If [L]ENTREE_MODULE = 2
        Gosub ENTREE_MODULE
    Endif
Next

Close Local File [ATB],[ATZ],[ATI]

End

$ENTREE_STANDARD
Openo [L]CHEMIN_STANDARD
Gosub ENTETE_FIC
Wrseq "$OPEN_"+[F:ATB]ABRFIC
Wrseq "Gosub OPEN_"+[F:ATB]ABRFIC+" From "+[L]RACINE+[L]ABREV([F:ATB]MODULE)
Wrseq "Return"
Wrseq "$CLOSE_"+[F:ATB]ABRFIC
Wrseq "Gosub CLOSE_"+[F:ATB]ABRFIC+" From "+[L]RACINE+[L]ABREV([F:ATB]MODULE)
Wrseq "Return"
Openo 
Return

$ENTREE_MODULE
Openo [L]CHEMIN_MODULE([F:ATB]MODULE)
Gosub ENTETE_FIC
Wrseq "$OPEN_"+[F:ATB]ABRFIC
Wrseq "Local Integer OPEN_"+[F:ATB]ABRFIC
Wrseq "If clalev([F:"+[F:ATB]ABRFIC+"]) = 0"
Wrseq "    [L]OPEN_"+[F:ATB]ABRFIC+" = 2 : Local File "+[F:ATB]CODFIC
Wrseq "Else"
Wrseq "    [L]OPEN_"+[F:ATB]ABRFIC+" = 1"
Raz [L]NOMCLE
Raz [L]NOMZONE
For [F:ATI]NUMLIG Where [F:ATI]CODFIC = [F:ATB]CODFIC
&                & [F:ATI]HOMONYM = 1
    # Pour toutes les clés sans homonymes !
    [L]NOMCLE = [F:ATI]CODIND
    Break
Next
If [L]NOMCLE <> ""
    # Si on a trouvé une clé !
    # Recherchons les composantes de la clé !
    [L]J = 1 : [L]CHAMP_INDICE = 1
    For [L]I = 1 To len([F:ATI]DESCRIPT)
        [L]CARACTERE = mid$([F:ATI]DESCRIPT,[L]I,1)
        Case [L]CARACTERE
            When "+","-"
                # La zone est fini !
                [L]J += 1
            When "("
                [L]CHAMP_INDICE = 2
            When ")"
                [L]CHAMP_INDICE = 1
            When Default
            If [L]CHAMP_INDICE = 1
                [L]NOMZONE([L]J) += [L]CARACTERE
            Endif
        Endcase
    Next
    [L]NBZONE = find("",[L]NOMZONE)
    [L]NBZONE -= 1                    : # Ben oui, on veut la dernière qui va bien !
    For [L]I = 1 To [L]NBZONE
        # Et cette zone, c'est quoi son type ?
        Read [F:ATZ]CODZONE = [F:ATB]CODFIC ; [L]NOMZONE([L]I)
        If fstat = 0
            # Encore heureux !
            # Et le type de cette zone, c'est quoi en fait !
            Read [F:ATY]CODTYP = [F:ATZ]CODTYP
            If fstat = 0
                # Encore heureux aussi !!!!
                Raz [L]TYP,[L]COMPLEMENT
                Case [F:ATY]TYPTYP
                    When 1
                        [L]TYP = "Libelle"
                    When 2
                        [L]TYP = "Shortint"
                    When 3
                        [L]TYP = "Integer"
                    When 4
                        [L]TYP = "Decimal"
                    When 5
                        [L]TYP = "Float"
                    When 6
                        [L]TYP = "Double"
                    When 7
                        [L]TYP = "Char"
                        [L]COMPLEMENT = "(type([F:"+[F:ATB]ABRFIC+"]"+[L]NOMZONE([L]I)
                        [L]COMPLEMENT += ")-10)"
                    When 8
                        [L]TYP = "Date"
                    When Default
                        # Ben la je sais pas trop quoi faire !, tu appelles les pompiers ?
                Endcase
            Endif
        Endif
        Wrseq "    Local "+[L]TYP+" S_"+[L]NOMZONE([L]I)+"_"+[F:ATB]ABRFIC+[L]COMPLEMENT
    Next
    For [L]I = 1 To [L]NBZONE
        Wrseq "    [L]S_"+[L]NOMZONE([L]I)+"_"+[F:ATB]ABRFIC
&                    +" = [F:"+[F:ATB]ABRFIC+"]"+[L]NOMZONE([L]I)
    Next
Else
    Wrseq "    # PANIC - Pas de clé sans homonyme !"
Endif
Wrseq "Endif"
Wrseq "Return"
Wrseq "$CLOSE_"+[F:ATB]ABRFIC
Wrseq "If [L]OPEN_"+[F:ATB]ABRFIC+" = 1"
If [L]NOMCLE <> ""
    [L]ORDRE = "Read [F:" + [F:ATB]ABRFIC + "]" + [L]NOMCLE + " = "
    For [L]I = 1 To [L]NBZONE
        [L]ORDRE += "S_"+[L]NOMZONE([L]I)+"_"+[F:ATB]ABRFIC
        If [L]I < [L]NBZONE
            [L]ORDRE += " ; "
        Endif
    Next
Else
    [L]ORDRE = "# PANIC - Pas de clé sans homonyme !"
Endif
Wrseq "    "+[L]ORDRE
Wrseq "Else"
Wrseq "    Close Local File ["+[F:ATB]ABRFIC+"]"
Wrseq "Endif"
Wrseq "Return"
Openo
Return

$ENTETE_FIC
Wrseq [L]TRAIT
Wrseq [L]CHAINE
Wrseq [L]TRAIT
Return

