#<AdxTL>@(#)1.0.0.0 $Revision$
# FGR 23/03/2009 : X3SUIVI53600
# Moulinette pour Initialiser N2 à 1:NON de ATABDIV=433.

  Call MAJ_UTICRM003(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICRM003(APPLI)
End

########################################################################
Subprog MAJ_UTICRM003(DOSSIER)
Value Char DOSSIER

Local Integer IERR

  If DOSSIER = "X3" Then
    End 
  Endif

  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("Initialisation à non des conflits sur RdV") From DOSSUB
  #------------------------------------------------------
  IERR = 0
  Call ECR_TIME("DEBUT => Initialisation des conflits sur RdV (ADI)") From DOSSUB
  Call CRMSTEP4(DOSSIER, IERR) From CRMMAJ30
  Call ECR_TIME("FIN => Initialisation des conflits sur RdV (ADI)") From DOSSUB
  #------------------------------------------------------
End
