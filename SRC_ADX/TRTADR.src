#######################################################################
# Fenetre des codes adresses pour les contacts  et les RIB            #
#######################################################################
Subprog SELBPA (BPA)
Variable Char BPA

Local Char    WTBADR(60) (50)
Local Integer WNBADR
Local Char    WTXT(60)
Local Integer WCHOIX

If   clalev ([M:BPA])  or clalev ([M:BPAF]) or clalev ([M:BPAB]) or clalev ([M:BPAP])
& or clalev ([M:BPAC]) or clalev ([M:BPAS]) or clalev ([M:BPAR])
& or clalev ([M:BPAT])
    #--------------------------------------#
    # chargement du tableau a afficher     #
    #--------------------------------------#

    For I= 0 To [M]NBADR-1
        WTXT = format$("K:3X",[M]CODADR (I))+" "+format$("K:30X",[M]BPADES(I))+" "+[M]POSCOD (I)

        If !find(WTXT,WTBADR(0..WNBADR))
            WNBADR +=1
            WTBADR(WNBADR) = WTXT
        Endif
    Next I

    WCHOIX = 1
    Call SAITEX (WNBADR,WTBADR,WCHOIX,mess(44,195,1)) From GESECRAN
    If WCHOIX = 0 : mkstat = 2 : End: Endif
    #---------------------------#
    # en retour de la selection #
    #---------------------------#
    WTXT = WTBADR(WCHOIX)
    BPA  = left$(WTXT,3)
    BPA  = vireblc(BPA, 1)

Endif
End

#######################################################################
# Fenetre sélection des rinb                                          #
#######################################################################
Subprog SELBID (BID)
Variable Char BID

Local Char    WTBBID(65) (50)
Local Integer WNBBID
Local Char    WTXT(65)
Local Integer WCHOIX

#If  clalev ([M:BID]) = 0 : End : Endif

If clalev ([M:BID]) or clalev ([M:BIDF]) or clalev ([M:BIDB])
& or clalev ([M:BIDC]) or clalev ([M:BIDS]) or clalev ([M:BIDT])

    #--------------------------------------#
    # chargement du tableau a afficher     #
    #--------------------------------------#
    For I= 0 To [M]NBRIB-1
        WTXT = format$("K:30X", [M]BIDNUM (I))+" "+format$("K:30X",[M]PAB1(I))

        If !find(WTXT,WTBBID(0..WNBBID))
            WNBBID +=1
            WTBBID(WNBBID) = WTXT
        Endif
    Next I

    WCHOIX = 1
    Call SAITEX (WNBBID,WTBBID,WCHOIX,mess(52,195,1)) From GESECRAN
    If WCHOIX = 0 : mkstat = 2 : End: Endif
    #---------------------------#
    # en retour de la selection #
    #---------------------------#
    WTXT = WTBBID(WCHOIX)
    BID  = left$(WTXT,30)
    BID  = vireblc(BID, 1)

Endif
End

#######################################################################
# Fenetre sélection des contacts                                      #
#######################################################################
Subprog SELCNT (CNT)
Variable Char CNT

Local Char    WTBCNT(60) (50)
Local Integer WNBCNT
Local Char    WTXT(60)
Local Integer WCHOIX

#if  clalev ([M:CNT]) = 0 : End : Endif
If clalev ([M:CNT]) or clalev ([M:CNTF]) or clalev ([M:CNTB]) or clalev ([M:CNTP])
& or clalev ([M:CNTC]) or clalev ([M:CNTS]) or clalev ([M:CNTT])
    #--------------------------------------#
    # chargement du tableau a afficher     #
    #--------------------------------------#
    For I= 0 To [M]NBCNT-1
        WTXT = format$("K:35X", [M]CNTNAM (I))+" "+format$("K:20X",[M]CNTCHN(I))

        If !find(WTXT,WTBCNT(0..WNBCNT))
            WNBCNT +=1
            WTBCNT(WNBCNT) = WTXT
        Endif
    Next I

    WCHOIX = 1
    Call SAITEX (WNBCNT,WTBCNT,WCHOIX,mess(53,195,1)) From GESECRAN
    If WCHOIX = 0 : mkstat = 2 : End: Endif
    #---------------------------#
    # en retour de la selection #
    #---------------------------#
    WTXT = WTBCNT(WCHOIX)
    CNT  = left$(WTXT,35)
    CNT  = vireblc(CNT, 1)
Endif

End

