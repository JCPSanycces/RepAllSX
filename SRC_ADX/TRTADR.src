#<AdxTL>@(#)12.0.0.0 $Revision$
###########################################################################
#  Sous-programes  communs à SUBCPY & SUBFCY & SUBBPR                     #
###########################################################################
#                                                                         #
#-------------------------------------------------------------------------#
# Traitements e_commerce                                                  #
#-------------------------------------------------------------------------#
# ACTIONS                                                                 #
# --------------------                                                    #
# Sélection dans liste                                                    #
# --------------------                                                    #
# SELLBPAW : Fenêtre des codes adresses pour Clients livrés, contacts, RIB#
# --------------------                                                    #
# Sélection dans table                                                    #
# --------------------                                                    #
# SELTBPAW : Fenêtre des codes adresses pour Clients livrés, contacts, RIB#
#                                                                         #
###########################################################################
###########################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return
###########################################################################
###########################################################################
#    CHOIX DANS LES LISTES                                                #
###########################################################################
$SEL_LISTE
Case LISTE
    When "SELLBPA"   : Gosub SL_BPA
Endcase
Return
###########################################################################
#    CHOIX DANS LES TABLES                                                #
###########################################################################
$SEL_TABLE
Case TABLE
    When "SELTBPA"   : Gosub ST_BPA
Endcase
Return
###########################################################################
#    DETAIL DES ACTIONS SELECTION DANS LISTES                             #
###########################################################################
$SL_BPA

Local Char    WTXT(60)
Local Integer I

If clalev ([F:ACV])<=0 Local File ACTIV [ACV] Endif
Read [ACV] CODACT="BPA"
If !fstat
   If type(TEX) > 10
      Local Char TEX(mod(type(TEX)-10,256))(0..[F:ACV]DIME)
   Endif
   If type(TEXTE) > 10
      Local Char TEXTE(mod(type(TEXTE)-10,256))(0..[F:ACV]DIME)
   Endif
Endif
Close Local File [ACV]

If   clalev ([M:BPA])  or clalev ([M:BPAF]) or clalev ([M:BPAB]) or clalev ([M:BPAP])
& or clalev ([M:BPAC]) or clalev ([M:BPAS]) or clalev ([M:BPAR])
& or clalev ([M:BPAT]) or clalev ([M:BPAG])
    #--------------------------------------#
    # chargement du tableau a afficher     #
    #--------------------------------------#
    For I= 0 To [M]NBADR-1
        WTXT = format$("K:3X",[M]CODADR (I))+" "+format$("K:30X",[M]BPADES(I))+" "+[M]POSCOD (I)
        If !find(WTXT,TEXTE(0..NBTEX))
            NBTEX +=1
          # TEX(NBTEX) = format$("K:3X",[M]CODADR (I))
            TEX(NBTEX) = [M]CODADR(I) : # mb 5.3.2001, le format$ complète par des blancs !
            TEXTE(NBTEX) = WTXT
        Endif
    Next I

    TIT = mess(44,195,1)
Endif
Return
###########################################################################
#    DETAIL DES ACTIONS SELECTION DANS TABLES                             #
###########################################################################
$ST_BPA
If clalev([F:ATZ])=0 : Local File ATABZON : Endif
If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
Local Char    CODFIC    : CODFIC = "BPADDRESS"
Local Integer WTYPADR   : WTYPADR = val(PARAM(1))
Default File [BPA]

CRITERE = 'BPATYP='+num$(PARAM(1))+' & BPANUM="'+PARAM(2)+'"'

TIT(0) = mess(44,195,1)
NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "BPAADD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPADES" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "POSCOD" : Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return
###########################################################################

#-------------------------------------------------------------------------#
# Traitements non e-commerce                                              #
#-------------------------------------------------------------------------#
#----------------------------------------------------------#
#  CHARG_CPYFCY : corps du paragraphe LIENS                #
# -------------------------------------------------------- #
# cg le 29/01/98 ajout adresse par defaut  dans les tables #
# bpartner - company - facility                            #
# ajout code objet le 7/09/98                              #
#----------------------------------------------------------#
Subprog CHARG_BPA(GABREV,CPY,TYP,DEFADD)       : # cg le 07/09/98

Value Char    GABREV
Value Char    CPY
Value Integer TYP
Value Char    DEFADD

#-- on ne test pas avec clalev [m:bpa] car via le tunnel on a toujours les classes M
If GABREV = "CPY"
        Raz [M:BPA]
Elsif GABREV = "FCY"
        Raz [M:BPAF]
Elsif GABREV = "BPR"
        Raz [M:BPAB]
Elsif GABREV = "BPP"
        Raz [M:BPAP]
Elsif GABREV = "BPC"
        Raz [M:BPAC]
Elsif GABREV = "BPS"
        Raz [M:BPAS]
Elsif GABREV = "REP"
        Raz [M:BPAR]
Elsif GABREV = "BPT"
        Raz [M:BPAT]
Elsif GABREV = "GAC" or GABREV = "GAB"  : # comptes généraux et comptes generaux USA
        Raz [M:BPAG]
Elsif GABREV = "AUS"
        Raz [M:AUS7]
Endif
nolign = 0
#------------------------------------------------------------#
# On charge TOUTES les adresses y compris l'adresse générale #
#------------------------------------------------------------#
For [BPA]BPA0 Where BPATYP=TYP & BPANUM=CPY
    nolign += 1
    If GABREV = "CPY"
        [M:BPA]    = [F:BPA]
    Elsif GABREV = "FCY"
        [M:BPAF]   = [F:BPA]
    Elsif GABREV = "BPR"
        [M:BPAB]   = [F:BPA]
    Elsif GABREV = "BPP"
        [M:BPAP]   = [F:BPA]
    Elsif GABREV = "BPC"
        [M:BPAC]   = [F:BPA]
    Elsif GABREV = "BPS"
        [M:BPAS]   = [F:BPA]
    Elsif GABREV = "REP"
        [M:BPAR]   = [F:BPA]
    Elsif GABREV = "BPT"
        [M:BPAT]   = [F:BPA]
    Elsif GABREV = "GAC" or GABREV = "GAB"
        [M:BPAG]   = [F:BPA]
    Elsif GABREV = "AUS"
        [M:AUS7]   = [F:BPA]
    Endif
    [M]BPACRY(nolign-1)  = [F:BPA]CRY
    [M]CODADR(nolign-1)  = [F:BPA]BPAADD
    [M]ADDLIG1(nolign-1) = [F:BPA]BPAADDLIG(0)
    [M]ADDLIG2(nolign-1) = [F:BPA]BPAADDLIG(1)
    [M]ADDLIG3(nolign-1) = [F:BPA]BPAADDLIG(2)
    If TYP = 4
       [M]BPADES(nolign-1) = [F:BPA]BPADES
       [M]SAT(nolign-1)    = [F:BPA]SAT
       [M]POSCOD(nolign-1) = [F:BPA]POSCOD
       [M]CTY(nolign-1)    = [F:BPA]CTY
       [M]EXTNUM(nolign-1) = [F:BPA]EXTNUM
       [M]WEB(nolign-1)    = [F:BPA]WEB(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
       [M]TEL(nolign-1)    = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
    Endif
    If [F:BPA]BPAADD = DEFADD
        [M]BPAADDFLG (nolign -1) = 2
    Else
        [M]BPAADDFLG (nolign -1) = 1
    Endif
Next
[M]NBADR      = nolign
[M]XBPADES    = [M]BPADES(0)
[M]XLIG(0)    = [M]ADDLIG1(0)
[M]XLIG(1)    = [M]ADDLIG2(0)
[M]XLIG(2)    = [M]ADDLIG3(0)
[M]XPOSCOD    = [M]POSCOD(0)
[M]XBPACRY    = [M]BPACRY(0)
[M]XCTY       = [M]CTY(0)
[M]XCRYNAM    = [M]CRYNAM(0)
[M]XSAT       = [M]SAT(0)
[M]XTEL       = [M]TEL(0)
[M]XFAX       = [M]FAX(0)
[M]XWEB       = [M]WEB(0)
[M]XBPAADDFLG = [M]BPAADDFLG (0)
[M]XEXTNUM    = [M]EXTNUM(0)
End

#----------------------------------------------------------#
# Lecture des RIBs DE LA SOCIETE
#----------------------------------------------------------#
Subprog CHARG_RIB(GABREV,CPY,TYP,DEFBID)
Value Char    GABREV
Value Char    CPY
Value Integer TYP
Value Char    DEFBID

Local Char CRITERE (50)
CRITERE="1=1"
If GABREV = "CPY"
        Raz [M:BID]
Elsif GABREV = "FCY"
        Raz [M:BIDF]
Elsif GABREV = "BPR"
        Raz [M:BIDB]
Elsif GABREV = "BPC"
        Raz [M:BIDC]
Elsif GABREV = "BPS"
        Raz [M:BIDS]
Elsif GABREV = "BPT"
        Raz [M:BIDT]
Elsif GABREV = "AUS"
        Raz [M:AUS3]
Endif
nolign = 0
For [BID]BID0 Where BPATYP=TYP & BPANUM=CPY & evalue(CRITERE)
 nolign += 1
 Case GABREV
  When "CPY" : [M:BID]  = [F:BID]
  When "FCY" : [M:BIDF] = [F:BID]
  When "BPR" : [M:BIDB] = [F:BID]
  When "BPC" : [M:BIDC] = [F:BID]
  When "BPS" : [M:BIDS] = [F:BID]
  When "BPT" : [M:BIDT] = [F:BID]
 Endcase
# DBA le 23/06/03 : Sugg 12674
 [M]BIDBPAADD(nolign-1) = [F:BID]BPAADD
 [M]BIDNUM(nolign-1)    = [F:BID]BIDNUM
 [M]PAB1(nolign-1)      = [F:BID]PAB1
 [M]PAB2(nolign-1)      = [F:BID]PAB2
 [M]BIDCRY(nolign-1)    = [F:BID]CRY
 [M]BIDCUR(nolign-1)    = [F:BID]CUR
 If [F:BID]BIDNUM = DEFBID
          [M]BIDNUMFLG (nolign -1) = 2
 Else     [M]BIDNUMFLG (nolign -1) = 1
 Endif
 If GABREV="BPR"
  If clalev ([F:ACV])<=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT="VII"
  If !fstat & [F:ACV]FLACT=2
   [M]PAB3(nolign-1)     = [F:BID]PAB3
   [M]PAB4(nolign-1)     = [F:BID]PAB4
   [M]BICCOD(nolign-1)   = [F:BID]BICCOD
   [M]MIDPAB1(nolign-1)  = [F:BID]MIDPAB1
   [M]MIDPAB2(nolign-1)  = [F:BID]MIDPAB2
   [M]MIDPAB3(nolign-1)  = [F:BID]MIDPAB3
   [M]MIDPAB4(nolign-1)  = [F:BID]MIDPAB4
   [M]MIDBICCOD(nolign-1)= [F:BID]MIDBICCOD
   [M]MIDCRY(nolign-1)   = [F:BID]MIDCRY
  Endif
 Endif
Next
[M]NBRIB  = nolign
End

#----------------------------------------------------------#
#  CREBPA_CPYFCY : création des ADRESSES                   #
#----------------------------------------------------------#
Subprog CREBPA_CPYFCY(GABREV,CPY,TYP)

Value Char    GABREV
Value Char    CPY
Value Integer TYP
#
# Suppression des adresses pour la société/site en cours de MAJ
Local Char CLE_TO_DEL(25)
CLE_TO_DEL = num$(TYP) + CPY

Delete [BPA] Where BPATYP=TYP & BPANUM=CPY
# Vérification si un enregistrement est locké : si oui : fin !
If fstat = 1
 GOK = -1
 GLOCK = "$BPADDRESS"-CLE_TO_DEL : End
Endif

#Creation des adresses pour la société/site en cours de MAJ
For nolign=1 To [M]NBADR
    If GABREV = "CPY"
        [F:BPA]    = [M:BPA]
    Elsif GABREV = "FCY"
        [F:BPA]    = [M:BPAF]
    Elsif GABREV = "BPR"
        [F:BPA]    = [M:BPAB]
    Elsif GABREV = "BPP"
        [F:BPA]    = [M:BPAP]
    Elsif GABREV = "BPP"
        [F:BPA]    = [M:BPAP]
    Elsif GABREV = "BPC"
        [F:BPA]    = [M:BPAC]
    Elsif GABREV = "BPS"
        [F:BPA]    = [M:BPAS]
    Elsif GABREV = "REP"
        [F:BPA]    = [M:BPAR]
    Elsif GABREV = "BPT"
        [F:BPA]    = [M:BPAT]
    Elsif GABREV = "GAC" or GABREV = "GAB"
        [F:BPA]    = [M:BPAG]
    Elsif GABREV = "AUS"
        [F:BPA]    = [M:AUS7]
    Endif
     [F:BPA]BPATYP       = TYP
     [F:BPA]BPANUM       = CPY
     [F:BPA]BPAADD       = [M]CODADR(nolign-1)
     [F:BPA]BPAADDLIG(0) = [M]ADDLIG1(nolign-1)
     [F:BPA]BPAADDLIG(1) = [M]ADDLIG2(nolign-1)
     [F:BPA]BPAADDLIG(2) = [M]ADDLIG3(nolign-1)
     [F:BPA]CRY          = [M]BPACRY(nolign-1)
     [F:BPA]CREDAT       = date$
     [F:BPA]CREUSR       = GUSER
     If TYP = 4
      [F:BPA]SAT    = [M]SAT(nolign-1)
      [F:BPA]BPADES = [M]BPADES(nolign-1)
      [F:BPA]CRYNAM = [M]CRYNAM(nolign-1)
      [F:BPA]EXTNUM = [M]EXTNUM(nolign-1)
      [F:BPA]POSCOD = [M]POSCOD(nolign-1)
      [F:BPA]CTY    = [M]CTY(nolign-1)
      [F:BPA]TEL(0) = [M]TEL(nolign-1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
      # FGR 21/08/2015 : X3SUIVI109994 (début)
      [F:BPA]TEL(1) = [M]FAX(nolign-1)
      If dim([F:BPA]FAX) >= 0 Then
        [F:BPA]FAX    = [M]FAX(nolign-1)
      Endif
      # FGR 21/08/2015 : X3SUIVI109994 (fin)
      [F:BPA]WEB(0)   = [M]WEB(nolign-1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]WEB
     Endif
     # -- récupération du nom du pays
     If clalev ([F:TCY]) <= 0 Local File TABCOUNTRY [TCY] Endif
     Read [TCY]TCY0 = [F:BPA]CRY
     If fstat=0
      Call LECTEXTRA([F:BPA]CRYNAM,"TABCOUNTRY","CRYDES",[F:BPA]CRY,"") From ATEXTRA
     Endif
     Write [BPA]
     If fstat
            GOK=0 : Call FSTA("BPA") From GLOCK : Break
     Endif
     If [F:BPA]BPAADD = "" : WCODADR = 1 : Endif
Next nolign
End

#----------------------------------------------------------#
#  CRERIB_CPYFCY : création des RIBS                       #
#----------------------------------------------------------#
Subprog CRERIB_CPYFCY(CPY,TYP)
Value Char    CPY
Value Integer TYP

# Suppression des RIBs pour la société en cours de MAJ
Local Char CLE_TO_DEL(25)
CLE_TO_DEL = num$(TYP) + CPY
Delete [BID] Where BPATYP=TYP & BPANUM=CPY
# Vérification si un enregistrement est locké : si oui : fin !
If fstat = 1
 GOK = -1
 GLOCK = "$BID"-CLE_TO_DEL : End
Endif

# Creation des RIBs pour la société/site en cours de MAJ
For nolign=1 To [M]NBRIB
 Case GABREV
  When "CPY" : [F:BID] = [M:BID]
  When "FCY" : [F:BID] = [M:BIDF]
  When "BPR" : [F:BID] = [M:BIDB]
  When "BPC" : [F:BID] = [M:BIDC]
  When "BPS" : [F:BID] = [M:BIDS]
  When "BPT" : [F:BID] = [M:BIDT]
 Endcase
 [F:BID]BPATYP = TYP
 [F:BID]BPANUM = CPY
 [F:BID]BIDNUM = [M]BIDNUM(nolign-1)
 # DBA le 23/06/03 : Sugg 12674
 [F:BID]BPAADD = [M]BIDBPAADD(nolign-1)
 [F:BID]PAB1   = [M]PAB1(nolign-1)
 [F:BID]PAB2   = [M]PAB2(nolign-1)
 [F:BID]CRY    = [M]BIDCRY(nolign-1)
 [F:BID]CUR    = [M]BIDCUR(nolign-1)
 If GABREV="BPR"
  If clalev ([F:ACV])<=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT="VII"
  If !fstat & [F:ACV]FLACT=2
   [F:BID]PAB3      = [M]PAB3(nolign-1)
   [F:BID]PAB4      = [M]PAB4(nolign-1)
   [F:BID]BICCOD    = [M]BICCOD(nolign-1)
   [F:BID]MIDPAB1   = [M]MIDPAB1(nolign-1)
   [F:BID]MIDPAB2   = [M]MIDPAB2(nolign-1)
   [F:BID]MIDPAB3   = [M]MIDPAB3(nolign-1)
   [F:BID]MIDPAB4   = [M]MIDPAB4(nolign-1)
   [F:BID]MIDBICCOD = [M]MIDBICCOD(nolign-1)
   [F:BID]MIDCRY    = [M]MIDCRY(nolign-1)
  Endif
 Endif
 Write [BID]
 If fstat
  GOK=0 : Call FSTA("BID") From GLOCK : Break
 Endif
Next nolign
End

#######################################################################

