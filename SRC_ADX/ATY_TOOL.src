#**
#* Verify the format of PARVAL according to the type code given in PARTYPNUM
#* PARTYPNUM takes the value of local menu 10030:
#*
#* @param PARTYPNUM
#* @param PARVAL
#* @return RES_OK  1-format is valid, 0-format is invalid
#*
#*!
Funprog CHECK_PARTYP(PARTYPNUM, PARVAL)
Value Integer PARTYPNUM
Value Char PARVAL
 Local Integer RES_OK
 RES_OK = 1
 Case PARTYPNUM
  When 7 : # Char
   RES_OK = func CHECK_TYPADX_CHAR(PARVAL)
  When 1,2,3,4,5,6 : # Integer/Decimal/Libelle
   RES_OK = func CHECK_TYPADX_NUM(PARTYPNUM, PARVAL)
  When 8 : # Date
   RES_OK = func CHECK_TYPADX_DATE(PARVAL)
  When 10 : # Clob ?
   RES_OK = func CHECK_TYPADX_CHAR(PARVAL)
  When 9,13 : # BLOB/CLASS ?
   RES_OK = 0
  When 11 : # Uuid ?
   RES_OK = func CHECK_TYPADX_UUID(PARVAL)
  When 12: # Datetime ?
   RES_OK = func CHECK_TYPADX_DATETIME(PARVAL)
 Endcase
End RES_OK


#**
#* Check if the string PARVAL is a valid UUID
#*
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_UUID(PARVAL)
Value Char PARVAL
 Local Integer RES_OK, I
 RES_OK = 1
 Onerrgo TYPADX_ERR
 Local Uuident L_VAL
 L_VAL = toUuid(PARVAL)
 Onerrgo
 If RES_OK and toupper(num$(L_VAL))<>toupper(PARVAL)
  RES_OK = 0
 Endif
End RES_OK


#**
#* Check if the string PARVAL is a valid DATE, two formats are considered as valid for a date:
#* 19990131 or 990131
#*
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_DATE(PARVAL)
Value Char PARVAL
 Local Integer RES_OK, I
 RES_OK = 1
 Onerrgo TYPADX_ERR
 Local Date L_VAL
 L_VAL = PARVAL
 Onerrgo
End RES_OK


#**
#* Check if the string PARVAL is a valid Datetime, allowed format : 2002-10-03T00:00:00Z
#*
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_DATETIME(PARVAL)
Value Char PARVAL
 Local Integer RES_OK, I
 RES_OK = 1
 Onerrgo TYPADX_ERR
 Local Datetime L_VAL
 L_VAL =  gdatetime$(PARVAL)
 Onerrgo
 If RES_OK and num$(L_VAL)="0000-00-00T00:00:00Z" and PARVAL<>"0000-00-00T00:00:00Z"
  RES_OK = 0
 Endif
End RES_OK


#**
#* Check if the string PARVAL begins with " or ' and also ends with " or '
#*
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_CHAR(PARVAL)
Value Char PARVAL
 Local Integer RES_OK, I, J
 I = len(PARVAL)
 If I >= 2
  If left$(PARVAL,1)='"' and right$(PARVAL,I)='"'
   J = instr(2,PARVAL,'"')
   If J = I # means there's no other " in the middle of the string
    RES_OK = 1
   Endif
  Elsif left$(PARVAL,1)="'" and right$(PARVAL,I)="'"
   J = instr(2,PARVAL,"'")
   If J = I # means there's no other ' in the middle of the string
    RES_OK = 1
   Endif
  Endif
 Endif
End RES_OK



#**
#* only allow the format "xxxx"
#* no ' is allowed, only " at the begining and at the end is allowed
#*
#* @param PARVAL
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_CHAR_BIS(PARVAL)
Value Char PARVAL
 Local Integer RES_OK, I, J
 I = len(PARVAL)
 If I >= 2 and left$(PARVAL,1)='"' and right$(PARVAL,I)='"'
  J = instr(2,PARVAL,'"')
  If J = I # means there's no other " in the middle of the string
   J = instr(2,PARVAL,"'")
    If J=0 # means there's no ' in the string
     RES_OK = 1
    Endif
  Endif
 Endif
End RES_OK


#**
#* Verify the format of PARVAL according to the type code given in PARTYPNUM
#* This Funprog verifies only for Integer, Decimal and Libelle
#*
#* PARTYPNUM takes the value of local menu 10030:
#*
#* @param PARTYPNUM
#* @param PARVAL
#* @return RES_OK  1-format is valid, 0-format is invalid
#*!
Funprog CHECK_TYPADX_NUM(PARTYPNUM, PARVAL)
Value Integer PARTYPNUM
Value Char PARVAL
 Local Integer RES_OK
 Local Char VALUE_CON(255)

 # remove the 0 at the beginning
 VALUE_CON = func REMOVE_ZERO_HEAD(PARVAL)

 Case PARTYPNUM
  When 2,3 : # Integer
   Local Integer L_VAL
   L_VAL = val(VALUE_CON)
   If num$(L_VAL)=VALUE_CON : RES_OK = 1 : Endif
  When 4,5,6 : # Decimal
   Local Decimal L_VAL
   # remove the 0 at the end after a "."
   VALUE_CON = func REMOVE_ZERO_END(VALUE_CON)
   L_VAL = val(VALUE_CON)
   If num$(L_VAL)=VALUE_CON : RES_OK = 1 : Endif
  When 1 : # Libelle  0-255
   Local Libelle L_VAL
   RES_OK = 1
   Onerrgo TYPADX_ERR
   L_VAL = val(VALUE_CON)
   Onerrgo
   # in case : VALUE_CON=12.1 and L_VAL=12
   If RES_OK=1 and num$(L_VAL)<>VALUE_CON : RES_OK = 0 : Endif
 Endcase
End RES_OK

$TYPADX_ERR
 RES_OK = 0
Resume


#**
#* Mapping between types defined in local menu 30 and types defined in local menu 33
#*
#* Here's the mapping applied:
#*  In local menu 33 :
#*  - "Char" corresponds to "Alphanumeric" in local menu 30
#*  - "Integer" corresponds to "Local Menu/Short Integer/Long Integer" in local menu 30
#*  - "Decimal" corresponds to "Decimal/Floating/Double" in local menu 30
#*  - "Date" corresponds to "Date" in local menu 30
#*  - "Libelle" corresponds to "Local Menu" in local menu 30
#*  - "Clob" corresponds to "Text file" in local menu 30
#*  - "Blob" corresponds to "Image file" in local menu 30
#*  - "Class" : no correspondance
#*  - "Uuid" corresponds to "Uuid" in local menu 30
#*  - "Datetime" corresponds to "Datetime" in local menu 30
#*
#* @param TYPX3  type code in local menu 30
#* @param TYPPAR  type code in local menu 33
#* @return RES_OK  1-match, 0-not match
#*!
Funprog MATCH_TYPX3_TYPPAR(TYPX3, TYPPAR)
Value Integer TYPX3, TYPPAR
 Local Integer RES_OK
 RES_OK = 0
 Case TYPPAR
  When 1 : # Char
   If TYPX3 = 7 : RES_OK = 1 : Endif
  When 2 : # Integer
   If find(TYPX3,1,2,3) : RES_OK = 1 : Endif
  When 3 : # Decimal
   If find(TYPX3,4,5,6) : RES_OK = 1 : Endif
  When 4 : # Date
   If TYPX3 = 8 : RES_OK = 1 : Endif
  When 5 : # Libelle
   If TYPX3 = 1 : RES_OK = 1 : Endif
  When 6 : # Clob
   If TYPX3 = 10 : RES_OK = 1 : Endif
  When 7 : # Blob
   If TYPX3 = 9 : RES_OK = 1 : Endif
  When 8 : # Class
  When 9 : # Uuid
   If TYPX3 = 11 : RES_OK = 1 : Endif
  When 10: # Datetime
   If TYPX3 = 12 : RES_OK = 1 : Endif
 Endcase
End RES_OK


#**
#* Return the internal type code(local menu 30) for a given X3 type code.
#*
#* @param CODTYP  X3 data type code, like : M, A, ADI, ATB...
#* @return RES_PARTYP  internal type code (local menu 30)
#*!
Funprog GET_INTERNAL_TYP_LM30(CODTYP)
Value Char CODTYP
 Local Integer RES_PARTYP
# Local File ATYPE [ATY]
 Read [ATY]CODTYP =  [L]CODTYP
 If !fstat
  RES_PARTYP = [ATY]TYPTYP
 Endif
# Close Local File [ATY]
End RES_PARTYP


#**
#* Format the string given in PARVAL into a valid Date
#* example:
#*   01/01/2012 -> 20120101
#*   2012/01/05 -> 20120105
#* @param PARVAL  formated result, and "00000000" is not convertible
#* @return VALINT
#*!
Funprog FORMAT_DATE(PARVAL)
Value Char PARVAL
 Local Char    FMT(80) , VALCHAR(250), VALEUR(250),VALINT(30)
 Local Integer ERR
 Local Date    VALDAT
 Local Integer DD , MM , YY , JOUR , MOIS , ANNEE
 Local Integer I , J , V1 , V2 , V3
  # TODO replace GFMDAT4 by a context code?
  DD = instr(1,GFMDAT4,"DD")
  MM = instr(1,GFMDAT4,"MM")
  YY = instr(1,GFMDAT4,"YY")
  VALEUR = PARVAL
  If DD=0 or MM=0 or YY=0
   VALINT = "00000000" : End VALINT # Format incorrect
  Endif
  I = instr(1,VALEUR,"/")
  J = instr(I+1,VALEUR,"/")
  If I & J>I
   V1 = val(left$(VALEUR,I-1))
   V2 = val(seg$(VALEUR,I+1,J-1))
   V3 = val(right$(VALEUR,J+1))
   If V1<100 : VALEUR  = format$("N0:2#",V1) : Else : VALEUR  = format$("N0:4#",V1) : Endif
   If V2<100 : VALEUR += format$("N0:2#",V2) : Else : VALEUR += format$("N0:4#",V2) : Endif
   If V3<100 : VALEUR += format$("N0:2#",V3) : Else : VALEUR += format$("N0:4#",V3) : Endif
  Else
   I = 1
   While I<=len(VALEUR)
    If !instr(1,"0123456789",mid$(VALEUR,I,1))
     VALEUR = left$(VALEUR,I-1)+right$(VALEUR,I+1)
    Else
     I += 1
    Endif
   Wend
  Endif
  Case len(VALEUR)
   When 0 : # Date nulle
    JOUR  = 0
    MOIS  = 0
    ANNEE = 0
   When 4 : # Jour + mois
    If DD<MM
     JOUR = val(left$(VALEUR,2))
     MOIS = val(right$(VALEUR,3))
    Else
     MOIS = val(left$(VALEUR,2))
     JOUR = val(right$(VALEUR,3))
    Endif
    If JOUR=0 & MOIS=0
     ANNEE = 0
    Else
     ANNEE = year(date$)
    Endif
   When 6 : # Jour + mois + année sur 2
    V1 = val(left$(VALEUR,2))
    V2 = val(mid$(VALEUR,3,2))
    V3 = val(right$(VALEUR,5))
    If DD<MM
     If    YY<DD : ANNEE = V1 : JOUR  = V2 : MOIS  = V3
     Elsif YY>MM : JOUR  = V1 : MOIS  = V2 : ANNEE = V3
     Else        : JOUR  = V1 : ANNEE = V2 : MOIS  = V3
     Endif
    Else
     If    YY<MM : ANNEE = V1 : MOIS  = V2 : JOUR  = V3
     Elsif YY>DD : MOIS  = V1 : JOUR  = V2 : ANNEE = V3
     Else        : MOIS  = V1 : ANNEE = V2 : JOUR  = V3
     Endif
    Endif
    If !(ANNEE=0 & MOIS=0 & JOUR=0)
     If ANNEE>mod(adxdcs,100)
      ANNEE += 100*int(adxdcs/100)
     Else
      ANNEE += 100*int(adxdcs/100)+100
     Endif
    Endif
   When 8 : # Date complète
    If DD<MM
     If    YY<DD : V1 = 1 : V3 = 5 : V2 = 7
     Elsif YY>MM : V3 = 1 : V2 = 3 : V1 = 5
     Else        : V3 = 1 : V1 = 3 : V2 = 7
     Endif
    Else
     If    YY<MM : V1 = 1 : V2 = 5 : V3 = 7
     Elsif YY>DD : V2 = 1 : V3 = 3 : V1 = 5
     Else        : V2 = 1 : V1 = 3 : V3 = 7
     Endif
    Endif
    ANNEE = val(mid$(VALEUR,V1,4))
    MOIS  = val(mid$(VALEUR,V2,2))
    JOUR  = val(mid$(VALEUR,V3,2))
   When Default
    VALINT = "00000000" : End VALINT # Date incorrecte
  Endcase
  If ANNEE=0 & JOUR=0 & MOIS=0
   VALDAT = [0/0/0]
  Elsif ANNEE=1599 & MOIS=12 & JOUR=31 : # année null  Oracle
   VALDAT=[0/0/0]
  Elsif  ANNEE=1753 & MOIS=01 & JOUR=01 : # année null sqlserver
   VALDAT=[0/0/0]
  Elsif ANNEE<1800 or MOIS<1 or MOIS>12 or JOUR<1 or JOUR>31
   ERR = 0
   Onerrgo ERR
   VALDAT = gdat$(VALEUR)
   Onerrgo
   If ERR
    VALINT = "00000000" : End VALINT  # Date incorrecte
   Else
    VALCHAR = VALDAT
    ANNEE = val(mid$(VALCHAR,1,4))
    MOIS  = val(mid$(VALCHAR,5,2))
    JOUR  = val(mid$(VALCHAR,7,2))
    If ANNEE<1800 or MOIS<1 or MOIS>12 or JOUR<1 or JOUR>31
     VALINT = "00000000" : End VALINT # Date incorrecte
    Endif
   Endif
  Else
   VALDAT = gdat$(JOUR,MOIS,ANNEE)
  Endif
  VALEUR = vireblc(format$(FMT,VALDAT),2)
  If VALDAT=[0/0/0]
   VALINT = "00000000"
  Else
   VALINT = format$("D:YYYYMMDD",VALDAT)
  Endif
End VALINT

$ERR
ERR = 1
Resume

#**
#* remove the 0 at the beginning
#* example :
#*    00102.01100 -> 102.01100
#*    00100 - > 100
#*
#* @param CHAINE
#* @return RES_CHAINE
#*!
Funprog REMOVE_ZERO_HEAD(CHAINE)
Value Char CHAINE
 Local Char RES_CHAINE(255)
 Local Char REST_PART(255)
 Local Integer INDEX, LENTH
 RES_CHAINE = CHAINE
 # remove the 0 at the beginning
 While left$(RES_CHAINE, 1) = "0" and len(RES_CHAINE)>1
  RES_CHAINE = right$(RES_CHAINE,2)
 Wend
End RES_CHAINE


#**
#* remove the 0 at the end if . is found
#* example :
#*    102.01100 -> 102.011
#*    100.00 - > 100
#*
#* @param CHAINE
#* @return RES_CHAINE
#*!
Funprog REMOVE_ZERO_END(CHAINE)
Value Char CHAINE
 Local Char RES_CHAINE(255)
 Local Char REST_PART(255)
 Local Integer INDEX, LENTH

 RES_CHAINE = CHAINE
 INDEX=instr(1, RES_CHAINE, ".")
 If INDEX>0
  # remove the 0 at the end since . is found
  LENTH = len(RES_CHAINE)
  While right$(RES_CHAINE,LENTH) = "0"
   RES_CHAINE = left$(RES_CHAINE,LENTH-1)
   LENTH = len(RES_CHAINE)
  Wend
  # remove the . at the end
  If  right$(RES_CHAINE,LENTH) = "."
   RES_CHAINE = left$(RES_CHAINE,LENTH-1)
  Endif
 Endif

End RES_CHAINE


#**
#* check if the type(ML 30) is compatible to be used within a formule num$()
#* incompatible types are: Blob
#*
#* @param CODTYP
#*!
Funprog CHECK_TYPE_FORMULE_NUM(CODTYP)
Value Integer CODTYP
 Local Integer RES_OK
 If CODTYP <> 9
  RES_OK = 1
 Endif
End RES_OK

#**
#* check if the type(ML 30) is compatible to be used within a formule val()
#* compatible types are: Alphanumérique, Date, Clob
#*
#* @param CODTYP
#*!
Funprog CHECK_TYPE_FORMULE_VAL(CODTYP)
Value Integer CODTYP
 Local Integer RES_OK
 If find(CODTYP, 7, 8, 10)
  RES_OK = 1
 Endif
End RES_OK


#**
#* return the class code if exists for the given type
#*
#* @param CODTYP
#*!
Funprog GET_CLASS_OF_TYPE(CODTYP)
Value Char CODTYP
Local Char RES_CLASS_COD(GLONACLA)
# Local File ATYPE [ATY]
 Read [ATY]CODTYP =  [L]CODTYP
 If !fstat
  RES_CLASS_COD = [F:ATY]CODCLA
 Endif
# Close Local File
End RES_CLASS_COD
