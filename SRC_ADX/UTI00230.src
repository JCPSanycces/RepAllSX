#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTI00230   Resynchro [F:VEP]PYRDAT & [F:HSP]DAT             Module Paie#
#            dans les bulletins de remplacement (Extourne)               #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Extourne : Resynchronisation dates de paie entre VALEMP & HISTOPAYE") From LECFIC

  Call MAJ_UTI00230(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTI00230(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

If clalev([F:VEP])=0  : Local File =DOSSIER+".VALEMP"     [VEP]  : Endif
If clalev([F:HSP])=0  : Local File =DOSSIER+".HISTOPAYE"  [HSP]  : Endif

Call ECR_TRACE("UTI00230 : Resynchronisation dates de paie entre VALEMP & HISTOPAYE: "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [HSP]
For [F:VEP]VEP5 Where ORIPYRDAT<>[0/0/0]
 For [F:HSP]HSP2 Where BUL=[F:VEP]BUL & EMP=[F:VEP]EMP & DAT<>[F:VEP]PYRDAT
  [F:HSP]DAT=[F:VEP]PYRDAT
  Rewrite [F:HSP] 
  If !fstat COMPTEUR += 1 Endif
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Break 2
  Endif
 Next
Next
If !GOK : Rollback : Endif
Commit

Close Local File [HSP]

Call ECR_TRACE("UTI00230 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # 1= Paie
If filinfo(filpath("FIL","VALEMP","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","HISTOPAYE","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTI00230(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # 1= Paie
If filinfo(filpath("FIL","VALEMP","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","HISTOPAYE","fde",APPLI),0)<=0 : End : Endif  
Call MAJ_UTI00230(APPLI)
End



