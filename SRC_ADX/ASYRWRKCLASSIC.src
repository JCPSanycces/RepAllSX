Raz GBIDC3, GBIDC1
Local Integer TYPEVT : # Type d'ÃĐvÃĻnement Workflow (objet/import/etc.)
Local Char    CODEVT(30) : # Code ÃĐvÃĻnement
Local Char    OPERAT(30) : # OpÃĐration (Modification/Bouton/etc.)
Local Char    CLEOBJ(250) : # ClÃĐ de l'objet si typevt=objet ou chrono origine/dest si typevt=signature
Local Integer REQUEST
Local Char    MESSAGE(250)
TYPEVT=2
CODEVT="TCY"
OPERAT="M"
CLEOBJ="AM"
#GBIDI1 = func WORKFLOW(GACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQUEST,MESSAGE)
#Infbox "WORKFLOW"- num$(GBIDI1)-MESSAGE-"-"-num$(REQUEST)
#End


Local Char CODE(30),FILTRE(250)
Local Integer SIMUL

CODE="TCYMAN"
SIMUL = 0
FILTRE="CRY='CM'"
GBIDI1 = func WORKMANUAL(GACTX,CODE,FILTRE,SIMUL,REQUEST,MESSAGE)
Infbox "WORKFLOW"- num$(GBIDI1)-MESSAGE-"-"-num$(REQUEST)

End



#-------------------------------------------------------------------------------------------#

Funprog WORKFLOW(ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQUEST,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer TYPEVT : # Type d'ÃĐvÃĻnement Workflow (objet/import/etc.)
Value Char    CODEVT : # Code ÃĐvÃĻnement
Value Char    OPERAT : # OpÃĐration (Modification/Bouton/etc.)
Value Char    CLEOBJ : # ClÃĐ de l'objet si typevt=objet ou chrono origine/dest si typevt=signature
Variable Integer REQUEST
Variable Char    MESSAGE

Local Integer DIFFERE , SIMUL , TYPDEC , WPLUS
Local Char    CODE(GLONAWA) , GRPDEB(GLONVCR)
Raz DIFFERE , SIMUL , TYPDEC , CODE , GRPDEB
WPLUS=1
Goto WORKSUITE

#-------------------------------------------------------------------------------------------#
Funprog WORKPLUS(ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB,REQUEST,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Integer    TYPEVT
Value Char       CODEVT
Value Char       OPERAT
Value Char       CLEOBJ
Value Char       CODE    : # Code workflow (cas du bouton W et du workflow manuel)
Value Integer    SIMUL   : # Permet de simuler OU de gÃĐnÃĐrer un workflow manuel
Value Integer    DIFFERE : # Envoi message diffÃĐrÃĐ (transactions de crÃĐation/modification d'un objet)
Value Integer    TYPDEC  : # DÃĐclenchement workflow avant/aprÃĻs mise Ã  jour classe [F] (modif objet)
Variable Char    GRPDEB  : # Premier chrono groupe (utilisÃĐ pour l'envoi diffÃĐrÃĐ)
Variable Integer REQUEST
Variable Char    MESSAGE
Local Integer WPLUS
WPLUS=2
Goto WORKSUITE

#-------------------------------------------------------------------------------------------#
Funprog WORKMANUAL(ACTX,CODE,FILTRE,SIMUL,REQUEST,MESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT : # Context where the errors messages are stored
Value Char       CODE    : # Code workflow (cas du bouton W et du workflow manuel)
Value Char       FILTRE   : # filtre Ã  utliser
Value Integer    SIMUL   : # Permet de simuler OU de gÃĐnÃĐrer un workflow manuel
Variable Integer REQUEST
Variable Char    MESSAGE
Goto WORKMANSUITE

#-------------------------------------------------------------------------------------------#

$DEFVAR
Local Char   TASK(50)
Local Integer I , ASTATUS,STAT
Local Char    TIM(10)
Local Integer NBPAR
Local Char    TBPAR(30)(1..10) , TBVAL(250)(1..10)

TIM = left$(time$,2)+mid$(time$,4,2)

ASTATUS = CST_AOK
Return

#-------------------------------------------------------------------------------------------#
$WORKSUITE
Gosub DEFVAR

# control typevt /Sage/sagedev/SUPDVLP/folders/SUPERV/STDEN/PATCH/patch_ENG.dat
If find([L]TYPEVT,1,2,10)=0
 End fmet ACTX.ASETERROR("",num$(TYPEVT)-":"-mess(203,75,1),[V]CST_AERROR) : # "Type d'ÃĐvÃĻnement incompatible"
Endif

TASK="AWRKCLA"
NBPAR  = 1 : TBPAR(NBPAR) = "ATYPEVT"    : TBVAL(NBPAR) = num$([L]TYPEVT)
NBPAR += 1 : TBPAR(NBPAR) = "ACODEVT"    : TBVAL(NBPAR) = [L]CODEVT
NBPAR += 1 : TBPAR(NBPAR) = "AOPERATION" : TBVAL(NBPAR) = [L]OPERAT
NBPAR += 1 : TBPAR(NBPAR) = "VALCLE"     : TBVAL(NBPAR) = [L]CLEOBJ
NBPAR += 1 : TBPAR(NBPAR) = "PLUS"       : TBVAL(NBPAR) = num$([L]WPLUS)
If [L]WPLUS=2
 NBPAR += 1 : TBPAR(NBPAR) = "PCODE"     : TBVAL(NBPAR) = [L]CODE
 NBPAR += 1 : TBPAR(NBPAR) = "PSIMUL"    : TBVAL(NBPAR) = num$([L]SIMUL)
 NBPAR += 1 : TBPAR(NBPAR) = "PDIFFERE"   : TBVAL(NBPAR) = num$([L]DIFFERE)
 NBPAR += 1 : TBPAR(NBPAR) = "PTYPDEC"    : TBVAL(NBPAR) = num$( [L]TYPDEC)
 NBPAR += 1 : TBPAR(NBPAR) = "PGRPDEB"    : TBVAL(NBPAR) = num$([L]GRPDEB)
Endif

Goto END_WRK

#-------------------------------------------------------------------------------------------#

$WORKMANSUITE

Gosub DEFVAR

Local File =ACTX.AFOLDER+".AWRKPAR" [AWA]

Read [AWA]AWA0 = CODE
If fstat
 End fmet ACTX.ASETERROR("",CODE-":"-mess(107,75,1),[V]CST_AERROR) : : #RÃGLE WORKFLOW INEXISTANTE
Elsif  [F:AWA]TYPEVT<>10
 End fmet ACTX.ASETERROR("",CODE-":"-mess(145,075,1),[V]CST_AERROR) : : # type DE RÃGLE WORKFLOW INCORRECT
Endif

TASK="SAIWRKMAN"
NBPAR  = 1 : TBPAR(NBPAR) = "CODE"       : TBVAL(NBPAR) = [L]CODE
NBPAR += 1 : TBPAR(NBPAR) = "SIMUL"      : TBVAL(NBPAR) = num$([L]SIMUL)
NBPAR += 1 : TBPAR(NBPAR) = "FILTRE"     : TBVAL(NBPAR) = FILTRE

Goto END_WRK

#-----------------#
$END_WRK
# create request in folder X3
ASTATUS = func ASYRMNGTREQ.CRERQT(ACTX,ACTX.AFOLDER,ACTX.USER,TASK,date$,TIM,TBPAR,TBVAL,NBPAR,REQUEST,MESSAGE)

MESSAGE = func ASYRFNC.MES1(mess(117,134,1),num$(REQUEST))

End ASTATUS

