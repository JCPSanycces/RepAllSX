#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
## Etat LISTPHAHAB
# SEGAY - 24/11/10 - EXI 66086 lot P01
## Recherche des salariés n'ayant pas les permis et habilitations requis pour leur postes
## [F:ARM]CLED1 = Date d'obtention de l'habilitation
## [F:ARM]CLED2 = Date de fin de validité
## [F:ARM]CLEA1 = Salarié
## [F:ARM]CLEA2 = Contrat
## [F:ARM]CLEA3 = Poste
## [F:ARM]CLEA4 = Habilitation
## [F:ARM]CLEA5 =
## [F:ARM]CLEA6 =
## [F:ARM]CLEN1 = flag A renouveler
## [F:ARM]CLEN2 = flag booléen Habilitation salarié OK (0,1)
## [F:ARM]CLEMD1 =
## [F:ARM]CLEMD2 =
#################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    SOCIETE(GLONCPY), SITEDEB(GLONFCY), SITEFIN(GLONFCY)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML), POTDEB(GLONPOT), POTFIN(GLONPOT)
Local Char    PARAM(20) , PROFIL(GLONPRF), SERVICE(GLONSRV) , POPULATION(GLONPOP)
Local Char    CRITCTR1(250), CRITCTR2(250), CRIT2(250), ETAT(GLONARP)
Local Char    CRIT3(250)
Local Decimal PDSREQ, PDSMAT
Local Integer NUMREQ, I, J, K, WNUMLIG
Local Char    MATRI(GLONEML), POSTE(GLONPOT)
Local Char    CTRDEB(GLONHRCTR), CTRFIN(GLONHRCTR)
Local Date    DATDEB, DATFIN
Local Integer TYPHAB, TYPSAL, FLGCTR

Local Char    SVFONCTION(GLONAFC)
Local Integer OK

If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:AD])=0     : Local File EMPLOAD    [AD]    : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
If clalev([F:EPO])=0    : Local File EMPLOPOT   [EPO]   : Endif
If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:HAB])=0    : Local File EMPLOHAB   [HAB]   : Endif
If clalev([F:PHA])=0    : Local File POSTEHAB   [PHA]   : Endif
If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
If clalev([F:ARM])=0    : Local File AREPORTM   [ARM]   : Endif
If clalev([F:ECT])=0    : Local File EMPCTR     [ECT]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN) From ETAT
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB) From ETAT
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN) From ETAT
Call GETPARAM("typsal",NBPAR,PARAMETRE,PARAM) From ETAT : TYPSAL=val(PARAM)
Call GETPARAM("srv",NBPAR,PARAMETRE,SERVICE) From ETAT
Call GETPARAM("prf",NBPAR,PARAMETRE,PROFIL) From ETAT
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION) From ETAT
Call GETPARAM("potdeb",NBPAR,PARAMETRE,POTDEB) From ETAT
Call GETPARAM("potfin",NBPAR,PARAMETRE,POTFIN) From ETAT
Call GETPARAM("ctrdeb",NBPAR,PARAMETRE,CTRDEB) From ETAT
Call GETPARAM("ctrfin",NBPAR,PARAMETRE,CTRFIN) From ETAT
Call GETPARAM("flgctr",NBPAR,PARAMETRE,PARAM) From ETAT : FLGCTR=val(PARAM)
Call GETPARAM("typhab",NBPAR,PARAMETRE,PARAM) From ETAT : TYPHAB=val(PARAM)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB=PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN=PARAM

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITCTR1 = "1=1"
CRITCTR2 = "1=1"
If [L]TYPSAL = 3
  [L]CRITCTR1 -= "& [F:ID]ENAFLG<>2"
Endif
If [L]TYPSAL = 2
  [L]CRITCTR1 -= "& [F:ID]ENAFLG=2"
Endif
If MATDEB<>""  : CRITCTR1 -= '& [F:ECT]REFNUM>="'+MATDEB+'"' : Endif
If MATFIN<>""  : CRITCTR1 -= '& [F:ECT]REFNUM<="'+MATFIN+'"' : Endif
If PROFIL<>""  : CRITCTR1 -= '& [F:ECT]PRF="'+PROFIL+'"'     : Endif
If SERVICE<>"" : CRITCTR1 -= '& [F:ECT]SRV="'+SERVICE+'"'    : Endif
If SOCIETE<>"" : CRITCTR1 -= '& [F:FGR]CPY="'+SOCIETE+'"'    : Endif
If SITEDEB<>"" : CRITCTR1 -= '& [F:ECT]FCY>="'+SITEDEB+'"'   : Endif
If SITEFIN<>"" : CRITCTR1 -= '& [F:ECT]FCY<="'+SITEFIN+'"'   : Endif
If CTRDEB<>""  : CRITCTR2 -= '& [F:ECT]CTRNUM>="'+CTRDEB+'"' : Endif
If CTRFIN<>""  : CRITCTR2 -= '& [F:ECT]CTRNUM<="'+CTRFIN+'"' : Endif
If [L]FLGCTR = 1
 [L]CRITCTR2 -='& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)'
Endif
CRIT3 = "1=1"

If [L]TYPHAB = 1
  [L]CRIT3 -= "& [F:HAB]HABFLG<>2"
Endif
If [L]TYPHAB = 2
  [L]CRIT3 -= "& [F:HAB]HABFLG=2"
# Si la date de la table HABEND n'est pas obligatoire
#    Si paramètre DATDEB n'est pas renseigné on laisse passé [L]DATDEB > gdat$(01,01,1900)
#    Si la date de la table HABEND n'est pas renseignée on laisse passé [F:HAB]HABEND < [01/01/1900])
  If [L]DATDEB > gdat$(01,01,1900)
   [L]CRIT3 -= "& (([F:HAB]HABEND >=["+format$(GFMD,[L]DATDEB)+']'
&                  +" & [F:HAB]HABEND > [01/01/1900]) | [F:HAB]HABEND < [01/01/1900])"
  Endif
  If [L]DATFIN > gdat$(01,01,1900)
   [L]CRIT3 -= "& (([F:HAB]HABEND <=["+format$(GFMD,[L]DATFIN)+']'
&                  +" & [F:HAB]HABEND > [01/01/1900]) | [F:HAB]HABEND < [01/01/1900])"
  Endif
Endif

If POPULATION<>""
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [FGR]FGR1(1)=[F:ECT]FCY
& , [HRPOA]POA0=POPULATION;[F:ID]REFNUM
& , [HRCTR]CTR0(2)=[F:ECT]REFNUM;[F:ECT]CTRNUM
& As [LID]
& Where evalue(CRITCTR1) & evalue(CRITCTR2) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [FGR]FGR1(1)=[F:ECT]FCY
& , [HRCTR]CTR0(2)=[F:ECT]REFNUM;[F:ECT]CTRNUM
& As [LID]
& Where evalue(CRITCTR1) & evalue(CRITCTR2)
Endif


CRIT2 = '1=1'
If POTDEB<>""  : CRIT2 -= '& [F:EPO]POT>="'+POTDEB+'"'  : Endif
If POTFIN<>""  : CRIT2 -= '& [F:EPO]POT<="'+POTFIN+'"'  : Endif

Call DEBTRANS From GLOCK
Gosub TR1
Raz WNUMLIG

SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION) From ETAT
Call AUTORIS From EXEFNC

Gosub TR2

GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC

End

$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR1
 Endif
Commit
Return


$TR2
GOK=1
Trbegin [ARM]

 For [LID]ECT0(2)
  # Recherche du/des poste(s) occupé(s) par le salarié
  Filter [EPO] Where REFNUM=[F:ECT]REFNUM & CTRNUM=[F:ECT]CTRNUM
  Read [EPO]EPO1 Last
  Filter [EPO]
  If !fstat & evalue(CRIT2)=1
   Read [POT]POT0=[F:EPO]POT
   If !fstat & (MATRI<>[F:ECT]REFNUM | POSTE<>[F:EPO]POT)
    MATRI = [F:ECT]REFNUM
    POSTE = [F:EPO]POT
    # Controle des droit acces salarié, site, service
    Call CONTROLE([F:ECT]REFNUM,[F:EPO]DATPOT,[F:ECT]CTRNUM,"",OK,0) From DIVPAYE
    If OK

      # Habilitations requises pour le poste
      Filter [PHA] Where COD=[F:EPO]POT

      For [F:PHA]
       Raz [F:ARM]
       Raz PDSMAT, PDSREQ
       [L]WNUMLIG   +=1
       [F:ARM]USR    = GUSER
       [F:ARM]RPTCOD = [L]ETAT
       [F:ARM]NUMREQ = [L]NUMREQ
       [F:ARM]NUMLIG = [L]WNUMLIG
       [F:ARM]CLEA1  = [F:EPO]REFNUM
       [F:ARM]CLEA2  = [F:EPO]CTRNUM
       [F:ARM]CLEA3  = [F:EPO]POT
       [F:ARM]CLEA4  = [F:PHA]HAB
       [F:ARM]CLEN2 = 0
       # Habilitations du salarié
       Filter [HAB] Where REFNUM=[F:ECT]REFNUM & HAB=[F:PHA]HAB
&    & evalue(CRIT3) Order By HABEND;NUMLIG
       Read [F:HAB] Last
       Filter [HAB]
       If !fstat
        [F:ARM]CLED1 = [F:HAB]HABSTR
        [F:ARM]CLED2 = [F:HAB]HABEND
        [F:ARM]CLEN1 = [F:HAB]HABFLG
        [F:ARM]CLEN2 = 1
       Endif
       [F:ARM]CREDAT = date$
       Write [F:ARM]
       If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break 3 : Endif
      Next
      Filter [PHA]
    Endif
   Endif
  Endif
 Next
 If GOK=0 : Goto AB_TR2 : Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR2
Rollback
Return

