#<AdxTL>@(#)7.0.0.0 $Revision$
################################################################################################
#     Exécution ciblages marketing via serveur batch      Module CRM     25 Novembre 2003
################################################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE_BATCH" : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE_DIA
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE_DIA
    When Default
  Endcase
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################
#########################################################################
$INIT
Global Char GSZMGG4SELQUR

  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  GSZMGG4SELQUR = ""
Return

#########################################################################
$INIT_DIA
  Raz [M:DIA]
Return

#########################################################################
$CONTROLE_DIA
Return

#########################################################################
$TERMINE_DIA
  Kill GSZMGG4SELQUR
Return

#########################################################################
$EXEC
Local Char SZMESS(250)
Local Integer IERRINF
Local Integer ITER
Local Integer INBRECORD

  SZMESS = ""
  IERRINF = 0
  INBRECORD = 0
  If !GSERVEUR Then
    Call OUVRE_TRACE("Marketing panels generation") From LECFIC
  Endif
  For ITER = 0 To [M]NBLIG-1
    If [M]QURNUM(ITER) <> "" Then
      #Lancement de l'exécution du ciblage n°NNN
      SZMESS = mess(737,182,1) - [M]QURNUM(ITER)
      Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
      Call ECR_TIME(".") From DOSSUB
      Call ECR_TRACE(SZMESS,0) From GESECRAN
      Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
      IERRINF = 0
      INBRECORD = 0
      Gosub OUVRE From TRTMGG
      Gosub OUVTABGLOB From TRTMGC1
      Read [MQR]MQR0=[M]QURNUM(ITER)
      If fstat Then
        #Le ciblage marketing indiqué n'a pas pu être lu.
        Call ECR_TRACE(mess(741,182,1), 1) From GESECRAN
        IERRINF = 1
       Else
        If [F:MQR]TGPNUM = "" Then
          #Aucun support de présentation n'a pu être obtenu.
          Call ECR_TRACE(mess(742,182,1), 1) From GESECRAN
          IERRINF = 1
        Else
          If [F:MQR]TGR = "" Then
            #Cible non précisée sur le ciblage.
            Call ECR_TRACE(mess(743,182,1), 1) From GESECRAN
            IERRINF = 1
          Else
            If [F:MQR]QURNAM <> "" Then
              SZMESS = mess(744,182,1) - ":" - [F:MQR]QURNAM
              Call ECR_TRACE(SZMESS,0) From GESECRAN
            Endif
            SZMGC1PARAM2 = [F:MQR]TGR
            SZMGC1PARAM4 = [F:MQR]TGPNUM
          Endif
        Endif
      Endif
      If IERRINF Then
        #L'exécution du ciblage a échoué.
        Call ECR_TRACE(mess(738,182,1), 0) From GESECRAN
      Else
        Gosub SETMGCCOL From TRTMGC1
        Call DOMGGBATCH([M]QURNUM(ITER), INBRECORD, IERRINF) From TRTMGC1
        If IERRINF Then
          #L'exécution du ciblage a échoué.
          Call ECR_TRACE(mess(738,182,1), 0) From GESECRAN
        Else
          #L'exécution du ciblage est terminée avec succès.
          Call ECR_TRACE(mess(739,182,1), 0) From GESECRAN
          INBRECORD = 0
          Filter [QTP] Where [F:QTP]QURNUM = [M]QURNUM(ITER)
          For [QTP]
            INBRECORD += 1
          Next
          Filter [QTP]
          #Nombre d'enregistrements composant l'échantillon : NNNN
          SZMESS = mess(740,182,1) - ":" - num$(INBRECORD)
          Call ECR_TRACE(SZMESS, 0) From GESECRAN
        Endif
      Endif
      Gosub KILLGLOB From TRTMGC1
      Gosub KILLGLOB From TRTMGG
    Endif
  Next
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Return
