#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return

$OUVRE
Local Char GLOBEML(GLONEML)
#Disabling the classic CUD operation - Hybrid development (ANOWRITE)
Local Integer ANOWRITE
ANOWRITE = 1

#Opening tables and declaring an instance of the main class
If clalev([F:ID2])      = 0 : Local File EMPLOID      [ID2]      : Endif
If clalev([F:HRCTR])    = 0 : Local File EMPLOCTR     [HRCTR]   : Endif
If clalev([F:BBB])      = 0 : Local File BBLOB        [BBB]     : Endif

#Instantiate global basic classes
#Get the legislation and instiate only applicable classes
GLOBEML=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1) #Site level

#-------------------------------Hybrid----------------------------------#
If GLOBEML <> AVOID.ACHAR and GCURLEG <> AVOID.ACHAR
  #Instantiate EMPLOID - All Employees
  Gosub INSTANCE_EMPESS

  #KZA - EMPLOIDSA
  If func DIVPAYE.IS_KZA(GCURLEG)>0
    Gosub INSTANCE_EMPESSSA
  Endif
Endif
#-------------------------------Hybrid----------------------------------#
Return

$INSTANCE_EMPESS
Global Instance I_EMPESS Using C_EMPESS
Return

$INSTANCE_EMPESSSA
If clalev([F:ESA2]) = 0 :   Local File EMPLOIDSA  [ESA2]      : Endif
Global Instance I_EMPESSSA  Using C_EMPESSSA
Return



$DEBUT

[M:EMPES0]WLEG = GCURLEG

#-------------------------------Hybrid----------------------------------#
#Read the data from the class and transfer to the mask (Default Values)

#EMPLOID - All employee global data
Gosub LOAD_EMPESS

#EMPLOIDSA - KZA - RSA Employee information
If func DIVPAYE.IS_KZA(GCURLEG)>0
  Gosub LOAD_EMPESSSA
Endif
#-------------------------------Hybrid----------------------------------#
Return

$LOAD_EMPESS
Local Integer MY_STATUS
If I_EMPESS <> null Then
  FreeGroup I_EMPESS
Endif

I_EMPESS = NewInstance C_EMPESS AllocGroup null
[L]MY_STATUS = fmet I_EMPESS.AINIT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_EMPESS)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING Then
    OK = 0
    Return
  Endif
Endif

#Load data from the table to the class
Read [F:ID2]ID0 = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
If !fstat
  #Transfer data to the class
  #Update picture
  Read [BBB]BBB0 = "EMPPIC";[F:ID2]REFNUM;"";""
  If !fstat
     [M:EMPES0]EMPPIC = [F:BBB]BLOB
  Endif
  SetInstance I_EMPESS With [F:ID2]

  #Update the mask
  Gosub UPDATE_EMPESS
Endif
Return


$LOAD_EMPESSSA
Local Integer MY_STATUS
If I_EMPESSSA <> null Then
  FreeGroup I_EMPESSSA
Endif

I_EMPESSSA = NewInstance C_EMPESSSA AllocGroup null
[L]MY_STATUS = fmet I_EMPESSSA.AINIT()
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_EMPESSSA)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(0009,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING Then
    OK = 0
    Return
  Endif
Endif

#Load data from the table to the class
Read [F:ESA2]ID0 = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
If !fstat
  #Transfer data to the class
  SetInstance I_EMPESSSA With [F:ESA2]

  #Update the mask
  Gosub UPDATE_EMPESSSA
Endif

Return

$UPDATE_EMPESS
#Load the data from the class to the screen
SetInstance [M:EMPES0] With I_EMPESS
Affzo [M:EMPES0]1-99
Return

$UPDATE_EMPESSSA
#Load the data from the class to the screen
SetInstance [M:EMPES0] With I_EMPESSSA
Affzo [M:EMPES0]1-99
Return


Subprog RECOVERS_ERROR_IN_CLASSIC(STRUCTURE)
Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(STRUCTURE, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#


# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(STRUCTURE) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet STRUCTURE.ADELETERRORALL()
End



