#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UUMGTRTXXX00   Squelette pour Moulinette de Migration      Module XXX   #
#            description de la moulinette                                #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTXXX00") From LECFIC
  Endif

  #Call RAZ_UUMGTRTXXX00(DOSSIER)
  Call MAJ_UUMGTRTXXX00(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTXXX00(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
If [F:ADS]MODULE(N)<>2 : End : Endif          : # N= no module

Local Char WNAMXXXM,WNAMXXDM
Call MIGTABNAME (DOSSIER,"XXXXXX",WNAMXXXM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"XXXXXXD",WNAMXXDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMXXXM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif
If filinfo(filpath("FIL",WNAMXXDM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

##2 - On vide les fichiers selon le cas
#######################################

Local File =DOSSIER+".XXXXXX"  [XXX]
Trbegin [XXX]
Delete [XXX] Where ORIMOD<>3
Commit

Call MIGTABRAZ (DOSSIER,"XXXXXXD",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTXXX00",ERR) From TRTMIG

End

##########################################################################
##########################################################################
##########################################################################
Subprog MAJ_UUMGTRTXXX00(DOSSIER)
Value Char DOSSIER

Local Integer ERR

Gosub MIG_OUVRE From TRTMIG

##1 - verifications
####################

If [F:ADS]MODULE(N)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Char WNAMXXXM,WNAMXXDM
Call MIGTABNAME (DOSSIER,"XXXXXX",WNAMXXXM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"XXXXXXD",WNAMXXDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMXXXM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

If filinfo(filpath("FIL",WNAMXXDM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################


Local Char WTAB_XXX (100) (adxwrb)
Local Char WTAB_XXD (100) (adxwrb)
Local Shortint WCPT_XXX,WCPT_XXD

Call ECR_TIME("UUMGTRTXXX00 tables XXX Process : Update XXX") From DOSSUB
Call ECR_TRACE("UUMGTRTXXX00 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"XXXXXX",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"XXXXXXD",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:XXX])  = 0 : Local File =DOSSIER+".XXXXXX"    [XXX]  : Endif   # Fichier X3 "Vide"
If clalev([F:XXD])  = 0 : Local File =DOSSIER+".XXXXXXD"    [XXD]  : Endif   # Fichier X3 "Vide"

If clalev([F:XXXM]) = 0 : Local File =DOSSIER+"."+WNAMXXXM   [XXXM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:XXDM]) = 0 : Local File =DOSSIER+"."+WNAMXXDM   [XXDM] : Endif   # Fichier X3 renommé Avant Migration

Local File =[F:ADS]DOSSIER+".ATYPE" [ATY]
Local File =[F:ADS]DOSSIER+".ACTIV" [ACV]

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE,NBCOMMIT

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTXXX00",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [XXDM] With [XXXM]XXX0~=[F:XXDM]NUM
&    As [LNK]
&    Order By Key CLE = [F:XXXM]SALFCY;[F:XXXM]NUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTXXX00" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_XXX00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:XXXM]CHP1=TABMIGKEY(1) & [F:XXXM]CHP2=TABMIGKEY(2) & [F:XXXM]CHP3>TABMIGKEY(3)"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:XXXM]CHP1=TABMIGKEY(1) & [F:XXXM]CHP2>TABMIGKEY(2)"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:XXXM]CHP1>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [XXX],[XXD]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTXXX00" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  #Raz [F:XXX]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_XXX
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_XXX
  Endif

  [F:XXX] = [F:XXXM]

  #Appel proc de migration sur entete
  # Passage en V6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_XXX
    If GOK<1 : Break : Endif
  Endif

  # Passage en V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_XXX
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de facture
    #Raz [F:XXD]
    # version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
        Gosub RAZV6_XXD
    Endif
    # version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
        Gosub RAZV7_XXD
    Endif

    [F:XXD] = [F:XXDM]

    #Appel proc de migration sur detail
    # Passage en V6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_XXD
      If GOK<1 : Break : Endif
    Endif

    # Passage en V7
    If val(VERSION)<GMIGX3VER70
      Gosub MAJV7_XXD
      If GOK<1 : Break : Endif
    Endif

    # --- écriture enreg
    Gosub XXD_STK : # pour stocker ref
    WriteB [XXD]
    If fstat
        Call ECR_TRACE("File XXXXXXD, Error ="-num$(fstat),1) From GESECRAN
        Gosub XXD_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
  Next

  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete arpès boucle sur les détails
  # Passage en V6
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_XXX_SUITE
    If GOK<1 : Break : Endif
  Endif


  # --- écriture enreg
  Gosub XXX_STK : # pour stocker ref
  WriteB [F:XXX]
  If fstat
    Call ECR_TRACE("File XXXXXX, Error ="-num$(fstat),1) From GESECRAN
    Gosub XXX_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:XXXM]CHP1
    TABMIGKEY(2) = [F:XXXM]CHP2
    TABMIGKEY(3) = [F:XXXM]CHP3
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTXXX00",7,ERR) From TRTMIG : #7=Erreur
Else
  Flush [F:XXX]
  If fstat
      Call ECR_TRACE("File XXXXXX, Error ="-num$(fstat),1) From GESECRAN
      Gosub XXX_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  Flush [F:XXD]
  If fstat
      Call ECR_TRACE("File XXXXXXD, Error ="-num$(fstat),1) From GESECRAN
      Gosub XXD_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTXXX00",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTXXX00",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_XXX00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [XXX], [XXD]
Close Local File [XXXM], [XXDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"XXXXXX",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"XXXXXXD",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTXXX00") From TRTMIG
Call ECR_TIME("UUMGTRTXXX00 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$XXX_STK
Call STK (WTAB_XXX,WCPT_XXX,[F:XXX]NUM) From TRTMIG
Return
$XXD_STK
Call STK (WTAB_XXD,WCPT_XXD,[F:XXD]NUM-'/'-num$([F:XXD]SIDLIN)) From TRTMIG
Return
##############################################################################################
$XXX_ERRTRA
Call ERRTRA (WTAB_XXX,WCPT_XXX,"File XXXXXX(NUM)=") From TRTMIG
Return
$XXD_ERRTRA
Call ERRTRA (WTAB_XXD,WCPT_XXD,"File XXXXXXD(NUM/SIDLIN)=") From TRTMIG
Return

########################################################################
# Migration entete                                                     #
########################################################################
$RAZV6_XXX
Raz [F:XXX]NEWV6CHP
Return

$MAJV6_XXX
Return

$MAJV6_XXX_SUITE
Return
################################################

$RAZV7_XXX
Raz [F:XXX]NEWV7CHP
Return

$MAJV7_XXX
Return

########################################################################
# Migration détail                                                     #
########################################################################

$RAZV6_XXD
Raz [F:XXD]NEWV6CHP
Return

$MAJV6_XXD
Return

################################################

$RAZV7_XXD
Raz [F:XXD]NEWV6CHP
Return

$MAJV7_XXD
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
#on charge [F:ADS]
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTXXX00(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
#on sait qu'on a déjà [F:ADS]
Call MAJ_UUMGTRTXXX00(APPLI)
End


