#<AdxTL>@(#)0.0.0.0 $Revision$
#class PRETURN_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"    : Gosub AREAD_AFTER
      When "AINIT"          : Gosub AINIT
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSSCODADI" : Gosub INIT_TSSCODADI
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
 Case CURPRO
    When "ADRNAM1" :
      Case [L]ARULE
        When "GET"   : Gosub ADRNAM1_GET
      Endcase
    When "ADRNAM2" :
      Case [L]ARULE
        When "GET"   : Gosub ADRNAM2_GET
      Endcase
    When "ADRNAM3" :
      Case [L]ARULE
        When "GET"   : Gosub ADRNAM3_GET
      Endcase
    When "LEG" :
      Case [L]ARULE
        When "GET"   : Gosub LEG_GET
      Endcase
  Endcase
Return

################################################################################
$AREAD_AFTER

  Local Integer TMP
  Local Integer IRET

  IRET = fmet this.INIT_TSSCODADI()

  # Read address from BPADDRESS if address has not been modified
  If this.BPAADDLIG1 = AVOID.ACHAR and
&    this.BPAADDLIG2 = AVOID.ACHAR and
&    this.BPAADDLIG3 = AVOID.ACHAR and
&    this.CTY        = AVOID.ACHAR and
&    this.POSCOD     = AVOID.ACHAR and
&    this.SAT        = AVOID.ACHAR and
&    this.CRY        = AVOID.ACHAR and
&    this.BPSNUM    <> AVOID.ACHAR

    Local Instance BPARTNER Using C_BPARTNER
    BPARTNER = NewInstance C_BPARTNER AllocGroup null
    [L]ASTATUS = fmet BPARTNER.AREAD(this.BPSNUM)
    For TMP=1 To maxtab(BPARTNER.C_BPRNAM)
      Assign "this.BPRNAM"+num$(TMP) With BPARTNER.C_BPRNAM(TMP).BPRNAM
    Next

    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup BPARTNER
    [L]ASTATUS = fmet BPADDRESS.AREAD(1, this.BPSNUM, this.BPAADD)    # 1 = BP
    If [L]ASTATUS=[V]CST_AOK
      this.BPAADDLIG1 = BPADDRESS.BPAADDLIG1
      this.BPAADDLIG2 = BPADDRESS.BPAADDLIG2
      this.BPAADDLIG3 = BPADDRESS.BPAADDLIG3
      this.CTY        = BPADDRESS.CTY
      this.POSCOD     = BPADDRESS.POSCOD
      this.SAT        = BPADDRESS.SAT
      this.CRY        = BPADDRESS.CRY
      this.CRYNAM     = BPADDRESS.CRYNAM
      this.BPADES     = BPADDRESS.BPADES
    Endif
    FreeGroup BPARTNER
    BPARTNER = null
    BPADDRESS = null

  Else

    # Separate multi-dimensional fields into individual properties
    this.BPRNAM1 = [F:PNH]BPRNAM(0)
    this.BPRNAM2 = [F:PNH]BPRNAM(1)

    this.BPAADDLIG1 = [F:PNH]BPAADDLIG(0)
    this.BPAADDLIG2 = [F:PNH]BPAADDLIG(1)
    this.BPAADDLIG3 = [F:PNH]BPAADDLIG(2)

  Endif

Return

################################################################################
$AINIT
  Local Integer IRET

  IRET = fmet this.INIT_TSSCODADI()
Return

################################################################################
$INIT_TSSCODADI
  Local Integer DIM_STS
  Local Integer NI

  DIM_STS = func ASYRFNC.ACTIV("STS")
  # -------------------
  For NI = 1 To DIM_STS
   If this.COLTSSCOD(NI)<>null
   # this.C_TSSCOD(NI).TSSCODADI = NI + 40
    this.COLTSSCOD(NI).TSSCODADI = NI + 40
    Endif
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

################################################################################
$ADRNAM1_GET

  Local Instance COUNTRY Using C_ACRY
  COUNTRY = NewInstance C_ACRY AllocGroup null
  [L]ASTATUS = fmet COUNTRY.AREAD(this.CRY)
  If [L]ASTATUS=[V]CST_AOK
    this.ADRNAM1 = COUNTRY.ADRNAM1
  Endif
  FreeGroup COUNTRY
  COUNTRY = null

Return

################################################################################
$ADRNAM2_GET
  Local Instance COUNTRY Using C_ACRY
  COUNTRY = NewInstance C_ACRY AllocGroup null
  [L]ASTATUS = fmet COUNTRY.AREAD(this.CRY)
  If [L]ASTATUS=[V]CST_AOK
    this.ADRNAM2 = COUNTRY.ADRNAM2
  Endif
  FreeGroup COUNTRY
  COUNTRY = null

Return

################################################################################
$ADRNAM3_GET
  Local Instance COUNTRY Using C_ACRY
  COUNTRY = NewInstance C_ACRY AllocGroup null
  [L]ASTATUS = fmet COUNTRY.AREAD(this.CRY)
  If [L]ASTATUS=[V]CST_AOK
    this.ADRNAM3 = COUNTRY.ADRNAM3
  Endif
  FreeGroup COUNTRY
  COUNTRY = null

Return

################################################################################
$LEG_GET
  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.LEG = [F:CPY]LEG
    LogicClose File [CPY]
  Endif
Return

