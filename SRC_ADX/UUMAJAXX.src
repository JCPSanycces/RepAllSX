#---- fin MAJ Table WORKSTATIO
#---- Màj des intitulés traduisibles de la table des Lieux de pesage STATION
If filinfo(filpath("FIL","STATION","fde",DOSSIER),0)>0
  Local File =DOSSIER+".STATION"   [STX] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Lieux de pesage : Début",0) From GESECRAN        

  For [STX]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"STATION","STXDESAXX",[F:STX]STI,"") From ATEXTRA
