&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [MWC]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Sections de valorisation : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table WORKCOST
#---- Màj des intitulés traduisibles de la table des Saisonalités SEASON 
If filinfo(filpath("FIL","SEASON","fde",DOSSIER),0)>0
  Local File =DOSSIER+".SEASON"   [SES] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Saisonalités : Début",0) From GESECRAN        

  For [SES]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"SEASON","SESDESAXX",[F:SES]SESCOD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
