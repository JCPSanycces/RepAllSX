&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [SES]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Saisonalités : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table SEASON
#---- Màj des intitulés traduisibles de la table des Questions QLYCRDQST 
If filinfo(filpath("FIL","QLYCRDQST","fde",DOSSIER),0)>0
  Local File =DOSSIER+".QLYCRDQST"   [QLQ] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Questions : Début",0) From GESECRAN        

  For [QLQ]
    Raz WKLIBELLE
