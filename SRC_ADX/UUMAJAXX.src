  Close Local File [TWC]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Centres de charge : FIN",0) From GESECRAN
Endif
#---- fin MAJ Table TABWRKCTR
#---- Màj des intitulés traduisibles de la table des Postes de charge WORKSTATIO
If filinfo(filpath("FIL","WORKSTATIO","fde",DOSSIER),0)>0
  Local File =DOSSIER+".WORKSTATIO"   [MWS] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Postes de charge : Début",0) From GESECRAN        

