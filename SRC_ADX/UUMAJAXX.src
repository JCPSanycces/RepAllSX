    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"TABLOCTYP","TYPSHOAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA
    If WKLIBELLE=""
