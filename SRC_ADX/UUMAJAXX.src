  Call ECR_TRACE("Mise à jour ATEXTRA pour les Lieux de pesage : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table STATION
#---- Màj des intitulés traduisibles de la table des Lieux box STATIONBOX
If filinfo(filpath("FIL","STATIONBOX","fde",DOSSIER),0)>0
  Local File =DOSSIER+".STATIONBOX"   [SBX] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Lieux box : Début",0) From GESECRAN        

  For [SBX]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"STATIONBOX","DESAXX",[F:SBX]BOX,[F:SBX]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:SBX]DES,"STATIONBOX","DESAXX",[F:SBX]BOX,[F:SBX]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"STATIONBOX DESAXX"-[F:SBX]BOX-[F:SBX]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"STATIONBOX","SHOAXX",[F:SBX]BOX,[F:SBX]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:SBX]SHO,"STATIONBOX","SHOAXX",[F:SBX]BOX,[F:SBX]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"STATIONBOX SHOAXX"-[F:SBX]BOX-[F:SBX]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [SBX]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Lieux box : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table STATIONBOX
#---- Màj des intitulés traduisibles de la table des Affectations cuve vanne TANKS
If filinfo(filpath("FIL","TANKS","fde",DOSSIER),0)>0
  Local File =DOSSIER+".TANKS"   [TKS] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Affectations cuve vanne : Début",0) From GESECRAN        

  For [TKS]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"TANKS","TKSDESAXX",[F:TKS]TKS,[F:TKS]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:TKS]TKSDES,"TANKS","TKSDESAXX",[F:TKS]TKS,[F:TKS]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"TANKS TKSDESAXX"-[F:TKS]TKS-[F:TKS]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"TANKS","TKSSHOAXX",[F:TKS]TKS,[F:TKS]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:TKS]TKSSHO,"TANKS","TKSSHOAXX",[F:TKS]TKS,[F:TKS]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"TANKS TKSSHOAXX"-[F:TKS]TKS-[F:TKS]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [TKS]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Affectations cuve vanne : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table TANKS
#---- Màj des intitulés traduisibles de la table des Balances SCALES
If filinfo(filpath("FIL","SCALES","fde",DOSSIER),0)>0
  Local File =DOSSIER+".SCALES"   [SLE] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Balances : Début",0) From GESECRAN        

  For [SLE]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"SCALES","DESAXX",[F:SLE]SLE,[F:SLE]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:SLE]DES,"SCALES","DESAXX",[F:SLE]SLE,[F:SLE]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"SCALES DESAXX"-[F:SLE]SLE-[F:SLE]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"SCALES","SHOAXX",[F:SLE]SLE,[F:SLE]FCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:SLE]SHO,"SCALES","SHOAXX",[F:SLE]SLE,[F:SLE]FCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"SCALES SHOAXX"-[F:SLE]SLE-[F:SLE]FCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [SLE]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Balances : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table SCALES

#--- Restitution du code langue de connexion -----#
GLANGUE=SAV_GLANGUE
Close Local File [AXX]

End
