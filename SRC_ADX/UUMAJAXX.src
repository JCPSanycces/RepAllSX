      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"SEASON SESDESAXX"-[F:SES]SESCOD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"SEASON","SESSHOAXX",[F:SES]SESCOD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
