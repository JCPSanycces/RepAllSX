#---- fin MAJ Table TABCTL
#---- Màj des intitulés traduisibles de la table des Types d'emplacement TABLOCTYP
If filinfo(filpath("FIL","TABLOCTYP","fde",DOSSIER),0)>0
  Local File =DOSSIER+".TABLOCTYP"   [TLO] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Types d'emplacement : Début",0) From GESECRAN        

  For [TLO]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"TABLOCTYP","TYPDESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:TLO]TYPDES,"TABLOCTYP","TYPDESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"TABLOCTYP TYPDESAXX"-[F:TLO]STOFCY-[F:TLO]LOCTYP+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
