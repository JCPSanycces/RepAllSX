&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif    
  Next 
     
  Close Local File [QLQ]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Questions : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table QLYCRDQST
#---- Màj des intitulés traduisibles de la table des Réponses TABCTL 
If filinfo(filpath("FIL","TABCTL","fde",DOSSIER),0)>0
  Local File =DOSSIER+".TABCTL"   [TCT] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Réponses : Début",0) From GESECRAN        

  For [TCT]
    Raz WKLIBELLE
