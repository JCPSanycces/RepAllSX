Endif
#---- fin MAJ Table TABLOCTYP
#---- Màj des intitulés traduisibles de la table des Centres de charge TABWRKCTR
If filinfo(filpath("FIL","TABWRKCTR","fde",DOSSIER),0)>0
  Local File =DOSSIER+".TABWRKCTR"   [TWC] 
