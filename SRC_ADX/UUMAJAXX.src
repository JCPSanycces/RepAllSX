#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
## Mise à jour des intitulés traduisibles
## - Remplacement des textes de désignation par des textes traduits
##############################################################################
Call PATCH(nomap)

End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UUMAJAXX - Mise à jour des intitulés traduisibles",0) From GESECRAN
Call EXE_UUMAJAXX(DOSSIER)

End

Subprog EXE_UUMAJAXX(DOSSIER)
Value Char DOSSIER
Local Char WKLIBELLE(250)
#---- Màj des intitulés traduisibles des différentes tables
If filinfo(filpath("FIL","ATEXTRA","fde",DOSSIER),0)<=0 : End : Endif

Call ECR_TRACE(mess(81,125,1)-": ATEXTRA"-time$,0) From GESECRAN : # maj table

Local File =DOSSIER+".ATEXTRA"   [AXX] 

#--- Pour la lecture de la langue du dossier
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

#--- Sauvegarde puis récupération de la langue du dossier à migrer -----#
Local Char SAV_GLANGUE(GLONLAN)
SAV_GLANGUE=GLANGUE
GLANGUE=[F:ADS]LANDEF 
  
#---- Màj des intitulés traduisibles de la table des Règles d'affectation PARMTO 
If filinfo(filpath("FIL","PARMTO","fde",DOSSIER),0)>0
  Local File =DOSSIER+".PARMTO"   [PTO] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Règles d'affectation : Début",0) From GESECRAN        

  For [PTO]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"PARMTO","PTODESAXX",[F:PTO]PTOCOD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:PTO]PTODES,"PARMTO","PTODESAXX",[F:PTO]PTOCOD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"PARMTO PTODESAXX"-[F:PTO]PTOCOD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"PARMTO","PTOSHOAXX",[F:PTO]PTOCOD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:PTO]PTOSHO,"PARMTO","PTOSHOAXX",[F:PTO]PTOCOD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"PARMTO PTOSHOAXX"-[F:PTO]PTOCOD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [PTO]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Règles d'affectation : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table PARMTO
#---- Màj des intitulés traduisibles de la table des Guides opérateurs USERGUIDES 
If filinfo(filpath("FIL","USERGUIDES","fde",DOSSIER),0)>0
  Local File =DOSSIER+".USERGUIDES"   [UGD] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Guides opérateurs : Début",0) From GESECRAN        

  For [UGD]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"USERGUIDES","UGDDESAXX",[F:UGD]UGD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:UGD]UGDDES,"USERGUIDES","UGDDESAXX",[F:UGD]UGD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"USERGUIDES UGDDESAXX"-[F:UGD]UGD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"USERGUIDES","UGDSHOAXX",[F:UGD]UGD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:UGD]UGDSHO,"USERGUIDES","UGDSHOAXX",[F:UGD]UGD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"USERGUIDES UGDSHOAXX"-[F:UGD]UGD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [UGD]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Guides opérateurs : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table USERGUIDES
#---- Màj des intitulés traduisibles de la table des Guides étalonnage CALIGUIDES 
If filinfo(filpath("FIL","CALIGUIDES","fde",DOSSIER),0)>0
  Local File =DOSSIER+".CALIGUIDES"   [CGD] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Guides étalonnage : Début",0) From GESECRAN        

  For [CGD]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"CALIGUIDES","CGDDESAXX",[F:CGD]CGD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:CGD]CGDDES,"CALIGUIDES","CGDDESAXX",[F:CGD]CGD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"CALIGUIDES CGDDESAXX"-[F:CGD]CGD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"CALIGUIDES","CGDSHOAXX",[F:CGD]CGD,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:CGD]CGDSHO,"CALIGUIDES","CGDSHOAXX",[F:CGD]CGD,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"CALIGUIDES CGDSHOAXX"-[F:CGD]CGD+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [CGD]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Guides étalonnage : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table CALIGUIDES
#---- Màj des intitulés traduisibles de la table des Récipients CONTAINERS 
If filinfo(filpath("FIL","CONTAINERS","fde",DOSSIER),0)>0
  Local File =DOSSIER+".CONTAINERS"   [CTN] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Récipients : Début",0) From GESECRAN        

  For [CTN]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"CONTAINERS","CTNDESAXX",[F:CTN]CTN,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:CTN]CTNDES,"CONTAINERS","CTNDESAXX",[F:CTN]CTN,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"CONTAINERS CTNDESAXX"-[F:CTN]CTN+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"CONTAINERS","CTNSHOAXX",[F:CTN]CTN,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:CTN]CTNSHO,"CONTAINERS","CTNSHOAXX",[F:CTN]CTN,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"CONTAINERS CTNSHOAXX"-[F:CTN]CTN+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [CTN]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Récipients : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table CONTAINERS
#---- Màj des intitulés traduisibles de la table des Fiches ISM HANDLING 
If filinfo(filpath("FIL","HANDLING","fde",DOSSIER),0)>0
  Local File =DOSSIER+".HANDLING"   [HSH] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Fiches ISM : Début",0) From GESECRAN        

  For [HSH]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"HANDLING","DESAXX",[F:HSH]HSH,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:HSH]DES,"HANDLING","DESAXX",[F:HSH]HSH,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"HANDLING DESAXX"-[F:HSH]HSH+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"HANDLING","SHOAXX",[F:HSH]HSH,"") From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:HSH]SHO,"HANDLING","SHOAXX",[F:HSH]HSH,"") From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"HANDLING SHOAXX"-[F:HSH]HSH+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
  Next 
     
  Close Local File [HSH]
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Fiches ISM : Fin",0) From GESECRAN
Endif
#---- fin MAJ Table HANDLING
#---- Màj des intitulés traduisibles de la table des Sections de valorisation WORKCOST 
If filinfo(filpath("FIL","WORKCOST","fde",DOSSIER),0)>0
  Local File =DOSSIER+".WORKCOST"   [MWC] 
  Call ECR_TRACE("Mise à jour ATEXTRA pour les Sections de valorisation : Début",0) From GESECRAN        

  For [MWC]
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"WORKCOST","WCTDESAXX",[F:MWC]VLTCCE,[F:MWC]VLTFCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
      Call MAJTEXTRA([F:MWC]WCTDES,"WORKCOST","WCTDESAXX",[F:MWC]VLTCCE,[F:MWC]VLTFCY) From ATEXTRA
      If GOK<1
        Call ECR_TRACE("File ATEXTRA"-"WORKCOST WCTDESAXX"-[F:MWC]VLTCCE-[F:MWC]VLTFCY+
&                    ",Error ="-num$(fstat),1) From GESECRAN
        GOK=1 : Break
      Endif
    Endif
    Raz WKLIBELLE
    Call LECTEXTRA(WKLIBELLE,"WORKCOST","WCTSHOAXX",[F:MWC]VLTCCE,[F:MWC]VLTFCY) From ATEXTRA
    If WKLIBELLE=""
      #---La transaction est gérée dans le ATEXTRA
