#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
    When 'OUVRE' : Gosub OUVRE
    When 'DEBUT'  : Gosub DEBUT
    When 'OK' : Gosub OK
  Endcase
Return


#-----------------------------------------------------------------------------#

$DEBUT

Call LECMEMO("STD","[M:DIA]","wht") From GMEMO

 Diszo [M:WHT0]CPY
 Diszo [M:WHT0]FCY
 Affzo [M:WHT0]

Return

#-----------------------------------------------------------------------------#
$OUVRE

If clalev([F:WHT]) = 0 Local File WHT[WHT] : Endif
If clalev([F:WDL]) = 0 Local File WHTDTL[WDL] : Endif
If clalev([F:WHR]) = 0 Local File WHTHDR[WHR] : Endif

Return

#-----------------------------------------------------------------------------#
$SYNCDATA

Local Integer VALID
VALID = 1
If rowcount([F:WHT]) > 0
Trbegin [F:WDL]
  For[F:WHT]
    [F:WDL] = [F:WHT]
    [F:WDL]VAT = [F:WHT]VAT
    Write[F:WDL]
    If fstat <> 0
      VALID = 0
      Break
    Endif
  Next

  If VALID = 0
        Rollback
        GMESSAGE = mess(14,7704,1)
        GERR = 1
  Else
    Commit
  Endif

Endif

Return

#-----------------------------------------------------------------------------#

$OK
  Gosub SYNCDATA

  Gosub GENREPORT

Return

#-----------------------------------------------------------------------------#

$GENREPORT

Local Libelle QREP
Local Char     SFCY(GLONFCY)(2)
Local Char     SCPY(GLONCPY)(2)
Local Char RPTNUM

If clalev([F:WHR]) = 0 Local File WHTHDR[WHR] : Endif
If clalev([F:WDL]) = 0 Local File WHTDTL[WDL] : Endif



#validate that all the needed fields were filled out.
If func VALIDATEPARAM = 0
  Return
Endif

#Validate if the report is an actual or simmulation
If [M:WHT0]RPTTYP = 1
  #if the report is actual confirm that the simmulation was for the same search criteria.
  Read[F:WHR]WHR1 = [M:WHT0]STRDAT;[M:WHT0]ENDDAT;[M:WHT0]FCY;[M:WHT0]CPY;[M:WHT0]ALLFCY;[M:WHT0]ALLCPY
  If fstat = 0

    Variable Integer OK

    Call OUINON(mess(15,7704,1),OK)  From GESECRAN
      Case OK
         When 2: Goto ACTUAL #yes
         When 1: FIN = 0 : Return# no
      Endcase
  Else
    GMESSAGE = mess(2,7704,1)
    GERR = 1
    FIN = 0
    Return

  Endif

  #run the actual report and finilize entries
  $ACTUAL
  #assign the report number to the header
  [L]RPTNUM = func CREATERPTNUM
  If [L]RPTNUM <> ""
    Trbegin[F:WHR],[F:WDL]
    [F:WHR]RPTNUM =  [L]RPTNUM
    [F:WHR]RPTTYP = 1
    Rewrite[F:WHR]
    If fstat = 0
      Update [F:WDL] Where RPTNUM = "SIM" With RPTNUM = [L]RPTNUM
      If fstat = 0
        Commit
        Call GENRPT([L]RPTNUM)
      Else
        GMESSAGE = mess(3,7704,1)
        GERR = 1
        Rollback
        FIN = 0
        Return
      Endif
    Endif
  Else
    GMESSAGE = mess(4,7704,1)
    GERR = 1
    FIN = 0
    Return
  Endif
Else

  #Validate that there are no existing simmulations pending.
  #if there are, warm the user that the existing one will be over written.
  Filter[F:WHR] Where RPTTYP = 2
  If rowcount([F:WHR]) > 0
    Goto SIM
  Else
    $SIM
      #clear previous simmulation
      Trbegin [F:WDL]
      Update [F:WDL] Where RPTNUM = 'SIM' With RPTNUM = ""
      If fstat <> 0
        Rollback
        GMESSAGE = mess(5,7704,1)
        GERR = 1
        FIN = 0
        Return
      Else
        Commit
      Endif


      Trbegin[F:WHR],[F:WDL]

      #flag header and lines for simmulation
      If rowcount([F:WHR]) > 0
        Read[F:WHR]First
        [F:WHR] = [M:WHT0]
        [F:WHR]RPTNUM = 'SIM'
        [F:WHR]RUNDAT = date$
        Rewrite [F:WHR]
      Else
        [F:WHR] = [M:WHT0]
        [F:WHR]RPTNUM = 'SIM'
        [F:WHR]RUNDAT = date$
        Write [F:WHR]
      Endif


      If fstat = 0

        #set the search criteria
        #if all sites and companies selected, only apply the date filter.
        If [M:WHT0]ALLCPY = 2
          If [M:WHT0]ALLFCY = 2
            #update detail table's records to indicate a simmulation
            Update [F:WDL] Where (ACCDAT >= [M:WHT0]STRDAT and ACCDAT <= [M:WHT0]ENDDAT) and RPTNUM = "" With [F:WDL]RPTNUM = "SIM"

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("WHT") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif
          Endif
        Endif

        #if all sites and spesific companies selected, only apply the date and company filter filter.
        If [M:WHT0]ALLCPY = 1
          If [M:WHT0]ALLFCY = 2
            #update detail table's records to indicate a simmulation
            Update [F:WDL] Where (ACCDAT >= [M:WHT0]STRDAT and ACCDAT <= [M:WHT0]ENDDAT) and [F:WDL]CPY = [M:WHT0]CPY and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("WHT") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif

          Endif
        Endif

        #if all Companies and spesific sites selected, only apply the date and sites filter filter.
        If [M:WHT0]ALLCPY = 2
          If [M:WHT0]ALLFCY = 1
            #update detail table's records to indicate a simmulation
            Update [F:WDL] Where (ACCDAT >= [M:WHT0]STRDAT and ACCDAT <= [M:WHT0]ENDDAT) and [F:WDL]FCY = [M:WHT0]FCY and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("WHT") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif

          Endif
        Endif

        #if spesific Companies and spesific sites selected, apply the date and sites and company filter filter.
        If [M:WHT0]ALLCPY = 1
          If [M:WHT0]ALLFCY = 1
            #update detail table's records to indicate a simmulation
            Update [F:WDL] Where (ACCDAT >= [M:WHT0]STRDAT and ACCDAT <= [M:WHT0]ENDDAT) and [F:WDL]FCY = [M:WHT0]FCY and [F:WDL]CPY = [M:WHT0]CPY and RPTNUM = "" With RPTNUM = 'SIM'

            If fstat
              GOK = 0 : FIN = 0 :  Call FSTA("WHT") From GLOCK : Goto AB_TR1
            Else
              Commit
            Endif

          Endif
        Endif

        Call GENRPT('SIM')
      Else
        Rollback
      Endif

  Endif
  Filter[F:WHR]
Endif


Return

#-----------------------------------------------------------------------------#

Funprog VALIDATEPARAM

Local Integer VALID
VALID = 1

#Validate Company Selection
If [M:WHT0]ALLCPY = 1
  If [M:WHT0]CPY = ''
    GMESSAGE = mess(7,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif
Endif


#Validate Site Selection
If [M:WHT0]ALLFCY = 1
  If [M:WHT0]FCY = ''
    GMESSAGE = mess(9,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif
Endif



#Validate Date Selection

  If num$([M:WHT0]STRDAT) = '00/00/0000'
    GMESSAGE = mess(11,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif

  If num$([M:WHT0]ENDDAT) = '00/00/0000'
    GMESSAGE = mess(12,7704,1)
    GERR = 1
    VALID = 0
    Goto FAILED
  Endif


$FAILED

End VALID

#-----------------------------------------------------------------------------#
Subprog GENRPT(L_RPTNUM)
Value Char L_RPTNUM

  Local Integer NBPAR_MAX : NBPAR_MAX=10
  Local Char XTBPAR(20)(1..NBPAR_MAX)
  Local Char XTBVAL(250)(1..NBPAR_MAX)
  Local Char XREPNUM : XREPNUM = 'AUSWHT'
  Local Char XDESTINATION : XDESTINATION = 'PREVIEW' #3 PREVISU / MESSPDF

  XTBPAR(1)="RPTNUM" : XTBVAL(1) = L_RPTNUM
  XTBPAR(2)="ALLCPY" : XTBVAL(2) = num$([M:WHT0]ALLCPY)
  XTBPAR(3)="ALLFCY" : XTBVAL(3) = num$([M:WHT0]ALLFCY)
  XTBPAR(4)="SELCPY" : XTBVAL(4) = [M:WHT0]CPY
  XTBPAR(5)="SELFCY" : XTBVAL(5) = [M:WHT0]FCY

  Call ETAT(XREPNUM,"",XTBPAR,XTBVAL) From ETAT

Call GENLOG(L_RPTNUM)

End

#-----------------------------------------------------------------------------#

Funprog CREATERPTNUM

    Local Char    L_FCY, L_PAYTYP
    Local Date    L_DAT
    Local Integer OSTAT
    Local Char L_TASKID          # must be char - if integer then see below

    L_PAYTYP = ''
    L_FCY    = ""

    L_DAT = date$

    Call NUMERO ("WHT", L_FCY, L_DAT, L_PAYTYP, L_TASKID, OSTAT) From SUBANM

End L_TASKID

#-----------------------------------------------------------------------------#

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2
     Diszo [M:WHT0]CPY
     Affzo [M:WHT0]
  Else
    Actzo [M:WHT0]CPY
    Affzo [M:WHT0]
  Endif

End

#-----------------------------------------------------------------------------#

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2
     Diszo [M:WHT0]FCY
     Affzo [M:WHT0]
  Else
    Actzo [M:WHT0]FCY
    Affzo [M:WHT0]
  Endif

End

#-----------------------------------------------------------------------------#

$AB_TR1
Rollback
Return

#-----------------------------------------------------------------------------#

Subprog GENLOG(L_RPTNUM)
Value Char L_RPTNUM

Local Char     SFCY(GLONFCY)
Local Char     SCPY(GLONCPY)
Local Char     RPTTYP
Local Char     DETAIL(250)

#open log file
 If !GSERVEUR :
    Call OUVRE_TRACE (time$ + "WHT Report Log file") From LECFIC
Else
     Call ECR_TRACE (time$ + "WHT Report Log file",0) From GESECRAN
Endif

If [M:WHT0]ALLCPY= 2
  SCPY = 'ALL'
Else
  SCPY = [M:WHT0]CPY
Endif

If [M:WHT0]ALLFCY = 2
  SFCY = 'ALL'
Else
  SFCY = [M:WHT0]FCY
Endif

If [M:WHT0]RPTTYP = 1
  RPTTYP = 'ACTUAL'
Else
  RPTTYP = 'SIMULATION'
Endif

Call ECR_TRACE('#########################################################################',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00049,00110,1) + '       : ' + mess(19,7704,1)+ space$(50-len(mess(19,7704,1)))+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00001,00786,1) + '     : ' + date$ + space$(52-len(num$(date$)))+'#',0) From GESECRAN
Call ECR_TRACE('#-----------------------------------------------------------------------#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00014,00103,1) + '          : '+ space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00002,10489,1) + '         : '+ SCPY + space$(50-len(SCPY))+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00242,00190,1) + '             : '+ SFCY + space$(50-len(SFCY))+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(18,7704,1) + '         : '+ [M:WHT0]STRDAT + space$(52-len(num$([M:WHT0]STRDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(19,7704,1) + '           : '+ [M:WHT0]ENDDAT + space$(52-len(num$([M:WHT0]ENDDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# ' + mess(00000,09125,1) + '       : '+ RPTTYP + space$(50-len(RPTTYP))+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#-----------------------------------------------------------------------# ',0) From GESECRAN
Call ECR_TRACE('##########################################################################',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
#Call ECR_TRACE('#Detail             : '+ space$(50)+'#',0) From GESECRAN
#Call ECR_TRACE('#                     '+ space$(50)+'#',0) From GESECRAN

Filter [F:WDL] Where RPTNUM = L_RPTNUM
For[F:WDL]

Raz DETAIL

DETAIL = + '# ' + [F:WDL]BPR
DETAIL += '   ' + [F:WDL]NUM
DETAIL += '   ' + num$([F:WDL]AMTATI)
DETAIL += '   ' + num$([F:WDL]NETPRINOT) #num$([F:WDL]NETPRINOT)
DETAIL += '   ' + num$([F:WDL]AMTVAT) #num$([F:WDL]AMTVAT)
DETAIL += '   ' + [F:WDL]VAT #[F:WDL]VAT

If [F:WDL]WCAT = ''
  DETAIL += ' : No retention code assigned'

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',1) From GESECRAN
Else

  If [F:WDL]WCAT <> ''
    DETAIL +=  ' : ' + [F:WDL]WCAT
  Endif

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',0) From GESECRAN

Endif

Next

Call ECR_TRACE('###########################################################################',0) From GESECRAN


#close log file
If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

#display log file
Call LEC_TRACE() From LECFIC

End




