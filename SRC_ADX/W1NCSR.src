#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:32"
A_USER  = "DOC"
A_STAMP = "20181109230532"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSR [NCSR]
Gosub HORODAT
Local Inpbox "NCSR" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSR] As [SIM_]
Grizo [NCSR]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSR]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=27 : X2(0)=86 : Y1(0)=12 : Y2(0)=17
Return

$ON_REJECTCOD
Onevent INIT_AREA Call D_REJECTCOD(zc) From W1NCSR
Onevent CONTROL Call C_REJECTCOD(zc) From W1NCSR
Onevent BEFORE_INPUT Call AS_REJECTCOD(zc) From W1NCSR
Onevent AFTER_CHANGE Gosub AMM_REJECTCOD From W1NCSR
Return

Subprog D_REJECTCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]REJECTCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"808","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_REJECTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_REJECTCOD(zc) From W1NCSR
Onkey 144 Titled GBOUTP Call P_REJECTCOD(zc) From W1NCSR
Onkey 146 Titled GBOUTA Call SA_REJECTCOD(zc) From W1NCSR
Gosub _AFF
End

Subprog C_REJECTCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"808","") From SUBADI
If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"808",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
 If !mkstat
  ## Action STD
  Call C_REJECTCOD(VALEUR) From SUBNCSR
  If mkstat : GERR = 1 : GZONE = "REJECTCOD" : GZNUM = 52263 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_REJECTCOD
Call AM_REJECTCOD(zc)
If !mkstat & GOBJET
 zoncou = "REJECTCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_REJECTCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZREJECTCOD)")>indice
 [M]REJECTCOD(indice) = VALEUR
 Affzo ZREJECTCOD(indice)
Endif
Gosub _AFF
End

Subprog S_REJECTCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "808"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_REJECTCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "808"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_REJECTCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "808"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZREJECTCOD
Onevent BEFORE_AREA Gosub AV_ZREJECTCOD From W1NCSR
Return

$AV_ZREJECTCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","808",num$([M]REJECTCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


