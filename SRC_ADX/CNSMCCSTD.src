#<AdxTL>@(#)7.0.0.0 $Revision$ Consultation MCC
#############################################################################################################
# Consultation du parc client.                                          Module CRM          17 novembre 2000.
#############################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "FERME"      : Gosub FERME
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "AV_MAGNETO" : Gosub AV_MAGNETO
    When "SET_DERLU"  : Gosub SET_DERLU
    When "SETBOUT"    : Gosub SETBOUT
    When "DEB_CRIT"   : Gosub DEB_CRIT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When Default
  Endcase
Return

##########################################################################################################
$AUTORIS
Return

##########################################################################################################
$OUVRE
Local Char WFIL(250)(50)      # Conditions saisies
Local Char WFIL1(250)(50)     # Conditions de gestions de pages
Local Char WFIL2(250)(50)     # Conditions spécifiques
Local Char WORDER(250)(2)     # Ordre de tri pour l'agrégé
Local Integer INBFIL
Local Integer INBFIL1
Local Integer INBFIL2
Local Integer INBORDER

Local Char DEBMACNUM(GLONMAC)
Local Char FINMACNUM(GLONMAC)

Local Char DEBCHAFIE(250)
Local Char FINCHAFIE(250)
Local Integer DEBINTFIE
Local Integer FININTFIE
Local Decimal DEBDECFIE
Local Decimal FINDECFIE
Local Date DEBDATFIE
Local Date FINDATFIE

Local Char SZFIETYP(10)
Local Integer RUPTFIE

Local Char PRECHAFIE(250)
Local Char CURCHAFIE(250)
Local Integer PREINTFIE
Local Integer CURINTFIE
Local Decimal PREDECFIE
Local Decimal CURDECFIE
Local Date PREDATFIE
Local Date CURDATFIE

Local Integer IADINUM

Global Char GSZMCCBRACLA(250)
Local Char SZTXTNUM(100)

  # ------------------------------------------------
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  # ------------------------------------------------
  IADINUM = 19 + GFAMCIA
  # ------------------------------------------------
  [M:MCC1]CNSMCCCPY = ""
  [M:MCC1]CNSMCCFCY = ""
  [M:MCC1]BPCNUM = PARAM(1)
  [M:MCC1]BPACOD = ""
  [M:MCC1]CCNNUM = ""
  [M:MCC1]FIE = "MACPDTCOD"
  # ------------------------------------------------
  GSZMCCBRACLA = ""
  #Obtention du libellé du champ Marque
  Call PARAM("", "MACBRAUSE", SZTXTNUM) From ADOVAL
  Call TEXTE(val(SZTXTNUM), GSZMCCBRACLA) From OBJDIV
  If GSZMCCBRACLA = "" Then
    Call TEXTE(14543, GSZMCCBRACLA) From OBJDIV
  Endif
  # ------------------------------------------------
  Raz DEBMACNUM
  Raz FINMACNUM
  # ------------------------------------------------
  NAVIG = "CONSMCC"
Return

##########################################################################################################
$FERME
  Kill GSZMCCBRACLA
Return

##########################################################################################################
$AV_MAGNETO
Return

##########################################################################################################
$SET_DERLU
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$DEB_CRIT
Return

##########################################################################################################
$FIN_CRIT
Return

##########################################################################################################
$LECTURE
Local Integer ISPEFLG

  ISPEFLG = 0
  SZFIETYP = ""
  # -----------------------------------
  #-- Changement d'écran paramétrable
  Gosub CHANGE_MSK From GCONSULT
  #Affiche le nom du client en en-tête.
  Read [BPC]BPC0=[M:MCC1]BPCNUM
  # -----------------------------------
  [M:MCC1]FIECLA = ""
  If [M:MCC1]FIE <> "" Then
    Read [ATZ]CODZONE="MACHINES";[M:MCC1]FIE
    If !fstat Then
      Call TEXTE([F:ATZ]NOCOURT, [M:MCC1]FIECLA) From OBJDIV
    Endif
  Endif
  # -----------------------------------
  If [M:MCC1]FIE = "" Then
    #Pas d'agrégation
    # ---------------------
    Gosub LECTURE_NO_AGREG
  Else
    #Avec agrégation
    # ---------------------
    Gosub LECTURE_AGREG
  Endif
Return

##########################################################################################################
##########################################################################################################
##########################################################################################################
$LECTURE_NO_AGREG
  # -------------------------------------------------------
  #-- Positionnement des Filtres
  Gosub LOAD_FILTER_NO_AGREG
  If PROGSPE <> "" Then
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # -------------------------------------------------------
  # ------------------------------------------------------- #
  # CHGPAG = 1    :    Recherche                            #
  # ------ = 2    :    Suite                                #
  #        = 3    :    F5 (Rafraichissement page courante)  #
  # CHGPAG = -1   :    Dernier                              #
  # ------ = -2   :    Retour (Page précédente)             #
  # ------------------------------------------------------- #
  Default File [MAC]
  # ----------------------------
  #-- Application des Filtres
  If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
      RETOUR = 1
    Elsif CHGPAG = 2 Then
      RETOUR = 2
    Endif
    # ----------------------------
    Filter [MAC] Where evalue(WFIL) and evalue(WFIL1) and evalue(WFIL2) Order By [F:MAC]MACNUM
  Else
    RETOUR = 1
    If CHGPAG = -1 Then
      SUITE = 1
    Else
      SUITE = 2
    Endif
    # ----------------------------
    Filter [MAC] Where evalue(WFIL) and evalue(WFIL1) and evalue(WFIL2) Order By [F:MAC]MACNUM Desc
  Endif
  #-- raz du masque
  If CHGPAG <> 2 and CHGPAG <> -2 Then
    Raz [M:MCC2]
  Endif
  # ----------------------------
$BOUCLE_NO_AGREG
  nolign = 0
  For [MAC]
    If func ADDFLTCPYFCY = 1 Then
      # ----------------------------------------------------------------
      If NBLU = 1 Then
        If CHGPAG = 2 or CHGPAG = -2 Then
          Raz [M:MCC2]
        Endif
         NBLU = 2
      Endif
      If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 Then
          SUITE = 2
          Break
        Endif
        NOL += 1
        If NOL = 0 Then
          Gosub PLANQUE_BEGIN_NO_AGREG
        Endif
        Gosub PLANQUE_END_NO_AGREG
      Else
        If NOL <= 0 Then
          RETOUR = 2
          Break
        Endif
        NOL -= 1
        If NOL = MAXLIG-1 Then
          Gosub PLANQUE_END_NO_AGREG
        Endif
        Gosub PLANQUE_BEGIN_NO_AGREG
      Endif
      # ----------------------------------------------------------------
      nolign = NOL + 1
      [M:MCC2] = [F:MAC]
      Gosub ADDCPLTOTC # Gestion des compléments au transclass
      # ----------------------------------------------------------------
    Endif
  Next
  Filter [MAC]
Return

##########################################################################################################
$LOAD_FILTER_NO_AGREG
  Raz PRECHAFIE
  Raz CURCHAFIE
  Raz PREINTFIE
  Raz CURINTFIE
  Raz PREDECFIE
  Raz CURDECFIE
  Raz PREDATFIE
  Raz CURDATFIE
  # ----------------------------------------------------------------
  Raz WFIL
  Raz WFIL1
  Raz WFIL2
  INBFIL = 0
  INBFIL1 = 0
  INBFIL2 = 0
  WFIL(INBFIL) = "1=1"
  WFIL1(INBFIL1) = "1=1"
  WFIL2(INBFIL2) = "1=1"
  # ----------------------------------------------------------------
  If [M:MCC1]BPACOD = "" Then
    INBFIL += 1
    WFIL(INBFIL) -= "&((MACITNTYP=1 and BPCNUM=[M:MCC1]BPCNUM) or (MACITNTYP>=2 and MACITNTYP<=3 and MACRSL=[M:MCC1]BPCNUM))"
  Else
    INBFIL += 1
    WFIL(INBFIL) -= "&((MACITNTYP=1 and BPCNUM=[M:MCC1]BPCNUM and FCYITN=[M:MCC1]BPACOD) or (MACITNTYP>=2 and MACITNTYP<=3 and MACRSL=[M:MCC1]BPCNUM and FCYITN=[M:MCC1]BPACOD))"
  Endif
  # ---
  If [M:MCC1]CNSMCCFCY <> "" Then
    INBFIL += 1 : WFIL(INBFIL) -= "&[F:MAC]SALFCY=[M:MCC1]CNSMCCFCY"
  Endif
  # Autorisation site
  If GUSRFCY(1) <> "\" and [M:MCC1]CNSMCCFCY = "" and GNBAUZ <> GNBSITE Then
    INBFIL += 1 : WFIL(INBFIL) -= "& find([F:MAC]SALFCY,GUSRFCY(1..GNBAUZ))"
  Endif
  # ----------------------------------------------------------------
  Case CHGPAG
    When 3
      # rafraichissement
      INBFIL1 += 1
      WFIL1(INBFIL1) -= "&[F:MAC]MACNUM>=DEBMACNUM"
    When 2
       # suite
      INBFIL1 += 1
      WFIL1(INBFIL1) -= "&[F:MAC]MACNUM>FINMACNUM"
    When -2
      # retour
      INBFIL1 += 1
      WFIL1(INBFIL1) -= "&[F:MAC]MACNUM<DEBMACNUM"
    When Default
  Endcase
Return

##########################################################################################################
$PLANQUE_BEGIN_NO_AGREG
  DEBMACNUM = [F:MAC]MACNUM
Return

##########################################################################################################
$PLANQUE_END_NO_AGREG
  FINMACNUM = [F:MAC]MACNUM
Return

##########################################################################################################
##########################################################################################################
##########################################################################################################
$LECTURE_AGREG
  # -------------------------------------------------------
  #-- Positionnement des Filtres
  Gosub LOAD_FILTER_AGREG
  If PROGSPE <> "" Then
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # -------------------------------------------------------
  # ------------------------------------------------------- #
  # CHGPAG = 1    :    Recherche                            #
  # ------ = 2    :    Suite                                #
  #        = 3    :    F5 (Rafraichissement page courante)  #
  # CHGPAG = -1   :    Dernier                              #
  # ------ = -2   :    Retour (Page précédente)             #
  # ------------------------------------------------------- #
  Default File [MAC]
  # ----------------------------
  If ISPEFLG Then
    Gosub PE_MACMCC From TRTCRMPE
    Return
  Endif
  # ----------------------------
  #-- Application des Filtres
  If CHGPAG > 0 Then
    SUITE = 1
    If CHGPAG = 1 Then
      RETOUR = 1
    Elsif CHGPAG = 2 Then
      RETOUR = 2
    Endif
    # ----------------------------
    Filter [MAC] Where evalue(WFIL) and evalue(WFIL1) and evalue(WFIL2) Order With WORDER(0)
  Else
    RETOUR = 1
    If CHGPAG = -1 Then
      SUITE = 1
    Else
      SUITE = 2
    Endif
    # ----------------------------
    Filter [MAC] Where evalue(WFIL) and evalue(WFIL1) and evalue(WFIL2) Order With WORDER(1)
  Endif
  #-- raz du masque
  If CHGPAG <> 2 and CHGPAG <> -2 Then
    Raz [M:MCC2]
  Endif
  # ----------------------------
$BOUCLE_AGREG
  nolign = 0
  For [MAC]
    If func ADDFLTCPYFCY = 1 Then
      Gosub SETCURFIE
      # ----------------------------------------------------------------
      If NBLU = 1 Then
        If CHGPAG = 2 or CHGPAG = -2 Then
          Raz [M:MCC2]
        Endif
         NBLU = 2
      Endif
      If CHGPAG > 0 Then
        If NOL >= MAXLIG-1 Then
          SUITE = 2
          Break
        Endif
        # ------------------------------------------------
        If (SZFIETYP = "A" and PRECHAFIE <> CURCHAFIE) or
&          (SZFIETYP = "L" and PREINTFIE <> CURINTFIE) or
&          (SZFIETYP = "DCB" and PREDECFIE <> CURDECFIE) or
&          (SZFIETYP = "D" and PREDATFIE <> CURDATFIE)
&       Then
          # A ne faire que si on va rajouter une ligne. Pas dans le cas où on va agréger.
          NOL += 1
          If NOL = 0 Then
            Gosub PLANQUE_BEGIN_AGREG
          Endif
        Endif
        # ------------------------------------------------
        Gosub PLANQUE_END_AGREG
      Else
        If NOL <= 0 Then
          RETOUR = 2
          Break
        Endif
        # ------------------------------------------------
        If (SZFIETYP = "A" and PRECHAFIE <> CURCHAFIE) or
&          (SZFIETYP = "L" and PREINTFIE <> CURINTFIE) or
&          (SZFIETYP = "DCB" and PREDECFIE <> CURDECFIE) or
&          (SZFIETYP = "D" and PREDATFIE <> CURDATFIE)
&       Then
          # A ne faire que si on va rajouter une ligne. Pas dans le cas où on va agréger.
          NOL -= 1
          If NOL = MAXLIG-1 Then
            Gosub PLANQUE_END_AGREG
          Endif
        Endif
        # ------------------------------------------------
        Gosub PLANQUE_BEGIN_AGREG
      Endif
      # ----------------------------------------------------------------
      Case SZFIETYP
        When "A"
          If PRECHAFIE = CURCHAFIE Then
            [M:MCC2]MCCQTY(nolign-1) += [F:MAC]MACQTY
            Call DOBLANK
          Else
            nolign += 1
            [M:MCC2] = [F:MAC]
            Gosub ADDCPLTOTC # Gestion des compléments au transclass
          Endif
        When "L"
          If PREINTFIE = CURINTFIE Then
            [M:MCC2]MCCQTY(nolign-1) += [F:MAC]MACQTY
            Call DOBLANK
          Else
            nolign += 1
            [M:MCC2] = [F:MAC]
            Gosub ADDCPLTOTC # Gestion des compléments au transclass
          Endif
        When "DCB"
          If PREDECFIE = CURDECFIE Then
            [M:MCC2]MCCQTY(nolign-1) += [F:MAC]MACQTY
            Call DOBLANK
          Else
            nolign += 1
            [M:MCC2] = [F:MAC]
            Gosub ADDCPLTOTC # Gestion des compléments au transclass
          Endif
        When "D"
          If PREDATFIE = CURDATFIE Then
            [M:MCC2]MCCQTY(nolign-1) += [F:MAC]MACQTY
            Call DOBLANK
          Else
            nolign += 1
            [M:MCC2] = [F:MAC]
            Gosub ADDCPLTOTC # Gestion des compléments au transclass
          Endif
      Endcase
      Gosub SETPREFIE
      # ----------------------------------------------------------------
    Endif
  Next
  Filter [MAC]
Return

##########################################################################################################
$LOAD_FILTER_AGREG
  Raz PRECHAFIE
  Raz CURCHAFIE
  Raz PREINTFIE
  Raz CURINTFIE
  Raz PREDECFIE
  Raz CURDECFIE
  Raz PREDATFIE
  Raz CURDATFIE
  # ----------------------------------------------------------------
  Raz WFIL
  Raz WFIL1
  Raz WFIL2
  Raz WORDER
  INBFIL = 0
  INBFIL1 = 0
  INBFIL2 = 0
  WFIL(INBFIL) = "1=1"
  WFIL1(INBFIL1) = "1=1"
  WFIL2(INBFIL2) = "1=1"
  INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACNUM"       # Tri vers l'avant
  INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACNUM Desc"  # Tri vers l'arrière
  # ----------------------------------------------------------------
  # Where
  If [M:MCC1]BPACOD = "" Then
    INBFIL += 1 : WFIL(INBFIL) -= "&((MACITNTYP=1 and BPCNUM=[M:MCC1]BPCNUM) or (MACITNTYP>=2 and MACITNTYP<=3 and MACRSL=[M:MCC1]BPCNUM))"
  Else
    INBFIL += 1 : WFIL(INBFIL) -= "&((MACITNTYP=1 and BPCNUM=[M:MCC1]BPCNUM and FCYITN=[M:MCC1]BPACOD) or (MACITNTYP>=2 and MACITNTYP<=3 and MACRSL=[M:MCC1]BPCNUM and FCYITN=[M:MCC1]BPACOD))"
  Endif
  # ---
  If [M:MCC1]CNSMCCFCY <> "" Then
    INBFIL += 1 : WFIL(INBFIL) -= "&[F:MAC]SALFCY=[M:MCC1]CNSMCCFCY"
  Endif
  # Autorisation site
  If GUSRFCY(1) <> "\" and [M:MCC1]CNSMCCFCY = "" and GNBAUZ <> GNBSITE Then
    INBFIL += 1 : WFIL(INBFIL) -= "& find([F:MAC]SALFCY,GUSRFCY(1..GNBAUZ))"
  Endif
  # --------
  # Order by
  Case [M:MCC1]FIE
    When "FCYITN"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]FCYITN Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]FCYITN Desc; [F:MAC]MACNUM Desc"
    When "MACBPCDAT"
      SZFIETYP = "D"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACBPCDAT Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACBPCDAT Desc; [F:MAC]MACNUM Desc"
    When "MACBPCPRI"
      SZFIETYP = "DCB"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACBPCPRI Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACBPCPRI Desc; [F:MAC]MACNUM Desc"
    When "MACBRA"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACBRA Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACBRA Desc; [F:MAC]MACNUM Desc"
    When "MACCUTBPC"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACCUTBPC Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACCUTBPC Desc; [F:MAC]MACNUM Desc"
    When "MACITNDAT"
      SZFIETYP = "D"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACITNDAT Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACITNDAT Desc; [F:MAC]MACNUM Desc"
    When "MACITNLND"
      SZFIETYP = "L"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACITNLND Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACITNLND Desc; [F:MAC]MACNUM Desc"
    When "MACITNTYP"
      SZFIETYP = "L"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACITNTYP Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACITNTYP Desc; [F:MAC]MACNUM Desc"
    When "MACITSDAT"
      SZFIETYP = "D"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACITSDAT Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACITSDAT Desc; [F:MAC]MACNUM Desc"
    When "MACPDTCOD"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACPDTCOD Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACPDTCOD Desc; [F:MAC]MACNUM Desc"
    When "MACPURDAT"
      SZFIETYP = "D"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACPURDAT Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACPURDAT Desc; [F:MAC]MACNUM Desc"
    When "MACRSL"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACRSL Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACRSL Desc; [F:MAC]MACNUM Desc"
    When "MACSALPRI"
      SZFIETYP = "DCB"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACSALPRI Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACSALPRI Desc; [F:MAC]MACNUM Desc"
    When "MACSERNUM"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]MACSERNUM Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]MACSERNUM Desc; [F:MAC]MACNUM Desc"
    When "PLE"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]PLE Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]PLE Desc; [F:MAC]MACNUM Desc"
    When "SALFCY"
      SZFIETYP = "A"
      INBORDER = 0 : WORDER(INBORDER) = "[F:MAC]SALFCY Asc; [F:MAC]MACNUM Asc"
      INBORDER = 1 : WORDER(INBORDER) = "[F:MAC]SALFCY Desc; [F:MAC]MACNUM Desc"
    When Default
      ISPEFLG = 1
  Endcase
  # ----------------------------------------------------------------
  Case CHGPAG
    When 3
      # RAFRAICHISSEMENT
      # -----------------------
      INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACNUM>=DEBMACNUM"
      # -----------------------
      Case [M:MCC1]FIE
        When "FCYITN"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]FCYITN>=DEBCHAFIE"
        When "MACBPCDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCDAT>=DEBDATFIE"
        When "MACBPCPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCPRI>=DEBDECFIE"
        When "MACBRA"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBRA>=DEBCHAFIE"
        When "MACCUTBPC"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACCUTBPC>=DEBCHAFIE"
        When "MACITNDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNDAT>=DEBDATFIE"
        When "MACITNLND"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNLND>=DEBINTFIE"
        When "MACITNTYP"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNTYP>=DEBINTFIE"
        When "MACITSDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITSDAT>=DEBDATFIE"
        When "MACPDTCOD"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPDTCOD>=DEBCHAFIE"
        When "MACPURDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPURDAT>=DEBDATFIE"
        When "MACRSL"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACRSL>=DEBCHAFIE"
        When "MACSALPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSALPRI>=DEBDECFIE"
        When "MACSERNUM"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSERNUM>=DEBCHAFIE"
        When "PLE"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]PLE>=DEBCHAFIE"
        When "SALFCY"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]SALFCY>=DEBCHAFIE"
        When Default
          ISPEFLG = 1
      Endcase
      # -----------------------
    When 2
       # SUITE
       # -----------------------
      INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACNUM>FINMACNUM"
      # -----------------------
      Case [M:MCC1]FIE
        When "FCYITN"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]FCYITN>=FINCHAFIE"
        When "MACBPCDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCDAT>=FINDATFIE"
        When "MACBPCPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCPRI>=FINDECFIE"
        When "MACBRA"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBRA>=FINCHAFIE"
        When "MACCUTBPC"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACCUTBPC>=FINCHAFIE"
        When "MACITNDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNDAT>=FINDATFIE"
        When "MACITNLND"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNLND>=FININTFIE"
        When "MACITNTYP"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNTYP>=FININTFIE"
        When "MACITSDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITSDAT>=FINDATFIE"
        When "MACPDTCOD"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPDTCOD>=FINCHAFIE"
        When "MACPURDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPURDAT>=FINDATFIE"
        When "MACRSL"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACRSL>=FINCHAFIE"
        When "MACSALPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSALPRI>=FINDECFIE"
        When "MACSERNUM"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSERNUM>=FINCHAFIE"
        When "PLE"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]PLE>=FINCHAFIE"
        When "SALFCY"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]SALFCY>=FINCHAFIE"
        When Default
          ISPEFLG = 1
      Endcase
      # -----------------------
    When -2
      # RETOUR
      # -----------------------
      INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACNUM<DEBMACNUM"
      # -----------------------
      Case [M:MCC1]FIE
        When "FCYITN"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]FCYITN<=DEBCHAFIE"
        When "MACBPCDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCDAT<=DEBDATFIE"
        When "MACBPCPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBPCPRI<=DEBDECFIE"
        When "MACBRA"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACBRA<=DEBCHAFIE"
        When "MACCUTBPC"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACCUTBPC<=DEBCHAFIE"
        When "MACITNDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNDAT<=DEBDATFIE"
        When "MACITNLND"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNLND<=DEBINTFIE"
        When "MACITNTYP"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITNTYP<=DEBINTFIE"
        When "MACITSDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACITSDAT<=DEBDATFIE"
        When "MACPDTCOD"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPDTCOD<=DEBCHAFIE"
        When "MACPURDAT"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACPURDAT<=DEBDATFIE"
        When "MACRSL"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACRSL<=DEBCHAFIE"
        When "MACSALPRI"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSALPRI<=DEBDECFIE"
        When "MACSERNUM"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]MACSERNUM<=DEBCHAFIE"
        When "PLE"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]PLE<=DEBCHAFIE"
        When "SALFCY"
          INBFIL1 += 1 : WFIL1(INBFIL1) -= "&[F:MAC]SALFCY<=DEBCHAFIE"
        When Default
          ISPEFLG = 1
      Endcase
      # -----------------------
    When Default
  Endcase
Return

##########################################################################################################
$PLANQUE_BEGIN_AGREG
  DEBMACNUM = [F:MAC]MACNUM
  # -----------------------
  Case [M:MCC1]FIE
    When "FCYITN"
      DEBCHAFIE = [F:MAC]FCYITN
    When "MACBPCDAT"
      DEBDATFIE = [F:MAC]MACBPCDAT
    When "MACBPCPRI"
      DEBDECFIE = [F:MAC]MACBPCPRI
    When "MACBRA"
      DEBCHAFIE = [F:MAC]MACBRA
    When "MACCUTBPC"
      DEBCHAFIE = [F:MAC]MACCUTBPC
    When "MACITNDAT"
      DEBDATFIE = [F:MAC]MACITNDAT
    When "MACITNLND"
      DEBINTFIE = [F:MAC]MACITNLND
    When "MACITNTYP"
      DEBINTFIE = [F:MAC]MACITNTYP
    When "MACITSDAT"
      DEBDATFIE = [F:MAC]MACITSDAT
    When "MACPDTCOD"
      DEBCHAFIE = [F:MAC]MACPDTCOD
    When "MACPURDAT"
      DEBDATFIE = [F:MAC]MACPURDAT
    When "MACRSL"
      DEBCHAFIE = [F:MAC]MACRSL
    When "MACSALPRI"
      DEBDECFIE = [F:MAC]MACSALPRI
    When "MACSERNUM"
      DEBCHAFIE = [F:MAC]MACSERNUM
    When "PLE"
      DEBCHAFIE = [F:MAC]PLE
    When "SALFCY"
      DEBCHAFIE = [F:MAC]SALFCY
    When Default
      ISPEFLG = 1
  Endcase
Return

##########################################################################################################
$PLANQUE_END_AGREG
  FINMACNUM = [F:MAC]MACNUM
  # -----------------------
  Case [M:MCC1]FIE
    When "FCYITN"
      FINCHAFIE = [F:MAC]FCYITN
    When "MACBPCDAT"
      FINDATFIE = [F:MAC]MACBPCDAT
    When "MACBPCPRI"
      FINDECFIE = [F:MAC]MACBPCPRI
    When "MACBRA"
      FINCHAFIE = [F:MAC]MACBRA
    When "MACCUTBPC"
      FINCHAFIE = [F:MAC]MACCUTBPC
    When "MACITNDAT"
      FINDATFIE = [F:MAC]MACITNDAT
    When "MACITNLND"
      FININTFIE = [F:MAC]MACITNLND
    When "MACITNTYP"
      FININTFIE = [F:MAC]MACITNTYP
    When "MACITSDAT"
      FINDATFIE = [F:MAC]MACITSDAT
    When "MACPDTCOD"
      FINCHAFIE = [F:MAC]MACPDTCOD
    When "MACPURDAT"
      FINDATFIE = [F:MAC]MACPURDAT
    When "MACRSL"
      FINCHAFIE = [F:MAC]MACRSL
    When "MACSALPRI"
      FINDECFIE = [F:MAC]MACSALPRI
    When "MACSERNUM"
      FINCHAFIE = [F:MAC]MACSERNUM
    When "PLE"
      FINCHAFIE = [F:MAC]PLE
    When "SALFCY"
      FINCHAFIE = [F:MAC]SALFCY
    When Default
      ISPEFLG = 1
  Endcase
Return

##########################################################################################################
##########################################################################################################
##########################################################################################################

#############################################################
# Complément au transclass sans agrégation
#############################################################
##########################################################################################################
$ADDCPLTOTC
  # Quantité
  [M:MCC2]MCCQTY(nolign-1) = [F:MAC]MACQTY
  # Affiche la famille commerciale et la garantie applicable
  If [F:MAC]MACPDTCOD = "" Then
    [M:MCC2]MACFAMCIA(nolign-1) = ""
    [M:MCC2]MACWARTYP(nolign-1) = ""
    [M:MCC2]MACFAMCIAC(nolign-1) = ""
    [M:MCC2]MACWARTYPC(nolign-1) = ""
  Else
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If fstat Then
      [M:MCC2]MACFAMCIA(nolign-1) = ""
      [M:MCC2]MACWARTYP(nolign-1) = ""
      [M:MCC2]MACFAMCIAC(nolign-1) = ""
      [M:MCC2]MACWARTYPC(nolign-1) = ""
    Else
      [M:MCC2]MACFAMCIAC(nolign-1) = [F:ITM]TSICOD(GFAMCIA-1)
      Call GET_LIB(IADINUM, [F:ITM]TSICOD(GFAMCIA-1), [M:MCC2]MACFAMCIA(nolign-1)) From CRM_UTIL
      If [F:MAC]MACITNLND = 2 Then
        # Parc en prêt
        If [F:ITM]TPLCONLND = "" Then
          [M:MCC2]MACWARTYP(nolign-1) = ""
          [M:MCC2]MACWARTYPC(nolign-1) = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONLND
          If fstat Then
            [M:MCC2]MACWARTYPC(nolign-1) = ""
            [M:MCC2]MACWARTYP(nolign-1) = ""
          Else
            [M:MCC2]MACWARTYP(nolign-1) = [F:COT]TPLNAM
            [M:MCC2]MACWARTYPC(nolign-1) = [F:COT]CONNUM
          Endif
        Endif
      Else
        # Parc acheté
        If [F:ITM]TPLCONGUA = "" Then
          [M:MCC2]MACWARTYP(nolign-1) = ""
          [M:MCC2]MACWARTYPC(nolign-1) = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONGUA
          If fstat Then
            [M:MCC2]MACWARTYP(nolign-1) = ""
            [M:MCC2]MACWARTYPC(nolign-1) = ""
          Else
            [M:MCC2]MACWARTYP(nolign-1) = [F:COT]TPLNAM
            [M:MCC2]MACWARTYPC(nolign-1) = [F:COT]CONNUM
          Endif
        Endif
      Endif
    Endif
  Endif
  # Marque en clair
  Call GET_LIB(408, [F:MAC]MACBRA, [M:MCC2]MACBRACLA(nolign-1)) From CRM_UTIL
  # Utilisateur final en clair
  [M:MCC2]CUTBPCCLA(nolign-1) = ""
  If [F:MAC]BPCNUM <> "" Then
    Read [BPR]BPR0=[F:MAC]BPCNUM
    If !fstat Then
      [M:MCC2]CUTBPCCLA(nolign-1) = [F:BPR]BPRNAM
    Endif
  Endif
Return

#############################################################
# Renseigne la valeur courante d'agrégation
#############################################################
##########################################################################################################
$SETCURFIE
  Case [M:MCC1]FIE
    When "FCYITN"
      CURCHAFIE = [F:MAC]FCYITN
    When "MACBPCDAT"
      CURDATFIE = [F:MAC]MACBPCDAT
    When "MACBPCPRI"
      CURDECFIE = [F:MAC]MACBPCPRI
    When "MACBRA"
      CURCHAFIE = [F:MAC]MACBRA
    When "MACCUTBPC"
      CURCHAFIE = [F:MAC]MACCUTBPC
    When "MACITNDAT"
      CURDATFIE = [F:MAC]MACITNDAT
    When "MACITNLND"
      CURINTFIE = [F:MAC]MACITNLND
    When "MACITNTYP"
      CURINTFIE = [F:MAC]MACITNTYP
    When "MACITSDAT"
      CURDATFIE = [F:MAC]MACITSDAT
    When "MACPDTCOD"
      CURCHAFIE = [F:MAC]MACPDTCOD
    When "MACPURDAT"
      CURDATFIE = [F:MAC]MACPURDAT
    When "MACRSL"
      CURCHAFIE = [F:MAC]MACRSL
    When "MACSALPRI"
      CURDECFIE = [F:MAC]MACSALPRI
    When "MACSERNUM"
      CURCHAFIE = [F:MAC]MACSERNUM
    When "PLE"
      CURCHAFIE = [F:MAC]PLE
    When "SALFCY"
      CURCHAFIE = [F:MAC]SALFCY
    When Default
      ISPEFLG = 1
  Endcase
  # -----------------------
  # Pour traiter le cas des champs vides
  If CURCHAFIE = "" Then
    CURCHAFIE = "$empty$"
  Endif
  If CURINTFIE = 0 Then
    CURINTFIE = -999
  Endif
  If CURDECFIE = 0 Then
    CURDECFIE = -999
  Endif
  If CURDATFIE = [0/0/0] Then
    CURDATFIE = [01/01/1940]
  Endif
Return

#############################################################
# Renseigne la valeur précédente d'agrégation
#############################################################
##########################################################################################################
$SETPREFIE
  Case [M:MCC1]FIE
    When "FCYITN"
      PRECHAFIE = [F:MAC]FCYITN
    When "MACBPCDAT"
      PREDATFIE = [F:MAC]MACBPCDAT
    When "MACBPCPRI"
      PREDECFIE = [F:MAC]MACBPCPRI
    When "MACBRA"
      PRECHAFIE = [F:MAC]MACBRA
    When "MACCUTBPC"
      PRECHAFIE = [F:MAC]MACCUTBPC
    When "MACITNDAT"
      PREDATFIE = [F:MAC]MACITNDAT
    When "MACITNLND"
      PREINTFIE = [F:MAC]MACITNLND
    When "MACITNTYP"
      PREINTFIE = [F:MAC]MACITNTYP
    When "MACITSDAT"
      PREDATFIE = [F:MAC]MACITSDAT
    When "MACPDTCOD"
      PRECHAFIE = [F:MAC]MACPDTCOD
    When "MACPURDAT"
      PREDATFIE = [F:MAC]MACPURDAT
    When "MACRSL"
      PRECHAFIE = [F:MAC]MACRSL
    When "MACSALPRI"
      PREDECFIE = [F:MAC]MACSALPRI
    When "MACSERNUM"
      PRECHAFIE = [F:MAC]MACSERNUM
    When "PLE"
      PRECHAFIE = [F:MAC]PLE
    When "SALFCY"
      PRECHAFIE = [F:MAC]SALFCY
    When Default
      ISPEFLG = 1
  Endcase
Return

#############################################################
# Contrôle la mise à blanc des champs
#############################################################
##########################################################################################################
Subprog DOBLANK

Local Char SZFSALPRICTL(100)
Local Char SZMSALPRICTL(100)
Local Char SZMACFAMCIA(250)
Local Char SZMACWARTYP(250)

  SZMACFAMCIA = ""
  SZMACWARTYP = ""
  SZFSALPRICTL = ""
  SZMSALPRICTL = ""
  If [F:MAC]MACPDTCOD <> [M:MCC2]MACPDTCOD(nolign-1) Then
    Raz [M:MCC2]MACPDTCOD(nolign-1)
  Endif
  If [F:MAC]MACSERNUM <> [M:MCC2]MACSERNUM(nolign-1) Then
    Raz [M:MCC2]MACSERNUM(nolign-1)
  Endif
  # Affiche la famille commerciale et la garantie applicable
  If [F:MAC]MACPDTCOD = "" Then
    SZMACFAMCIA = ""
    SZMACWARTYP = ""
  Else
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If fstat Then
      SZMACFAMCIA = ""
      SZMACWARTYP = ""
    Else
      SZMACFAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
      If [F:MAC]MACITNLND = 2 Then
        #Parc en prêt
        If [F:ITM]TPLCONLND = "" Then
          SZMACWARTYP = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONLND
          If fstat Then
            SZMACWARTYP = ""
          Else
            SZMACWARTYP = [F:COT]CONNUM
          Endif
        Endif
      Else
        # Parc acheté
        If [F:ITM]TPLCONGUA = "" Then
          SZMACWARTYP = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONGUA
          If fstat Then
            SZMACWARTYP = ""
          Else
            SZMACWARTYP = [F:COT]CONNUM
          Endif
        Endif
      Endif
    Endif
  Endif
  If SZMACFAMCIA <> [M:MCC2]MACFAMCIAC(nolign-1) Then
    Raz [M:MCC2]MACFAMCIA(nolign-1)
    Raz [M:MCC2]MACFAMCIAC(nolign-1)
  Endif
  If SZMACWARTYP <> [M:MCC2]MACWARTYP(nolign-1) Then
    Raz [M:MCC2]MACWARTYP(nolign-1)
    Raz [M:MCC2]MACWARTYPC(nolign-1)
  Endif
  If [F:MAC]MACBRA <> [M:MCC2]MACBRA(nolign-1) Then
    Raz [M:MCC2]MACBRACLA(nolign-1)
    Raz [M:MCC2]MACBRA(nolign-1)
  Endif
  If [F:MAC]MACITSDAT <> [M:MCC2]MACITSDAT(nolign-1) Then
    Raz [M:MCC2]MACITSDAT(nolign-1)
  Endif
  If [F:MAC]MACITNTYP <> [M:MCC2]MACITNTYP(nolign-1) Then
    Raz [M:MCC2]MACITNTYP(nolign-1)
  Endif
  If [F:MAC]MACITNLND <> [M:MCC2]MACITNLND(nolign-1) Then
    Raz [M:MCC2]MACITNLND(nolign-1)
  Endif
  If [F:MAC]MACRSL <> [M:MCC2]MACRSL(nolign-1) Then
    Raz [M:MCC2]MACRSL(nolign-1)
  Endif
  If [F:MAC]MACCUTBPC <> [M:MCC2]MACCUTBPC(nolign-1) Then
    Raz [M:MCC2]MACCUTBPC(nolign-1)
    Raz [M:MCC2]CUTBPCCLA(nolign-1)
  Endif
  If [F:MAC]FCYITN <> [M:MCC2]FCYITN(nolign-1) Then
    Raz [M:MCC2]FCYITN(nolign-1)
  Endif
  SZFSALPRICTL = num$([F:MAC]MACSALPRI) + [F:MAC]CUR
  SZMSALPRICTL = num$([M:MCC2]MACSALPRI(nolign-1)) + [M:MCC2]CUR(nolign-1)
  If SZFSALPRICTL <> SZMSALPRICTL Then
    Raz [M:MCC2]MACSALPRI(nolign-1)
    Raz [M:MCC2]CUR(nolign-1)
  Endif
  If [F:MAC]MACPURDAT <> [M:MCC2]MACPURDAT(nolign-1) Then
    Raz [M:MCC2]MACPURDAT(nolign-1)
  Endif
  SZFSALPRICTL = num$([F:MAC]MACBPCPRI) + [F:MAC]MACBPCCUR
  SZMSALPRICTL = num$([M:MCC2]MACBPCPRI(nolign-1)) + [M:MCC2]MACBPCCUR(nolign-1)
  If SZFSALPRICTL <> SZMSALPRICTL Then
    Raz [M:MCC2]MACBPCPRI(nolign-1)
    Raz [M:MCC2]MACBPCCUR(nolign-1)
  Endif
  If [F:MAC]MACBPCDAT <> [M:MCC2]MACBPCDAT(nolign-1) Then
    Raz [M:MCC2]MACBPCDAT(nolign-1)
  Endif
  If [F:MAC]MACITNDAT <> [M:MCC2]MACITNDAT(nolign-1) Then
    Raz [M:MCC2]MACITNDAT(nolign-1)
  Endif
  If [F:MAC]PLE <> [M:MCC2]PLE(nolign-1) Then
    Raz [M:MCC2]PLE(nolign-1)
  Endif
  If [F:MAC]SALFCY <> [M:MCC2]SALFCY(nolign-1) Then
    Raz [M:MCC2]SALFCY(nolign-1)
  Endif
  If [F:MAC]MACORIVCR <> [M:MCC2]MACORIVCR(nolign-1) Then
    Raz [M:MCC2]MACORIVCR(nolign-1)
  Endif
  If [F:MAC]MACORI <> [M:MCC2]MACORI(nolign-1) Then
    Raz [M:MCC2]MACORI(nolign-1)
  Endif
  If [F:MAC]MACORIVCRL <> [M:MCC2]MACORIVCRL(nolign-1) Then
    Raz [M:MCC2]MACORIVCRL(nolign-1)
  Endif
  Raz [M:MCC2]MACNUM(nolign-1)
End

########################################################
# Filtre complémentaire sur société et site
########################################################
##########################################################################################################
Funprog ADDFLTCPYFCY

Local Integer IFLTCPYFCY

  IFLTCPYFCY = 1
  If [M:MCC1]CNSMCCCPY = "" Then
    IFLTCPYFCY = 1  # Pas de filtre société, on prend
  Else
    # Critère société
    Read [FCY]FCY0=[F:MAC]SALFCY
    If fstat Then
      IFLTCPYFCY = 0  # Le site n'existe pas on ne prend pas
    Else
      If [F:FCY]LEGCPY = [M:MCC1]CNSMCCCPY Then
        IFLTCPYFCY = 1  # C'est la société indiquée, on prend
      Else
        IFLTCPYFCY = 0  # Ce n'est pas la société indiquée, on ne prend pas
      Endif
    Endif
  Endif
End IFLTCPYFCY

# FQ 57754 Module Support client GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI="X3" End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(12)<>2 End Endif
  Call VALGTC(APPLI,"MCC") From SUBGTC
End
