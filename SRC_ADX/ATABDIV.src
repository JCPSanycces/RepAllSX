#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################################
# aim of this treatment:
# extract some key information from table ATABDIV into table AREPORTM 
# to facilitate the generation of status of miscellaneous table
###########################################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

# variables that should be static
Local Integer S_NUM_COLUMN
Local Char S_PARAM_REQUETTE
Local Char S_PARAM_X3ETA
Local Char S_PARAM_NUMEDT
Local Char S_PARAM_CODE
Local Char S_PARAM_LAN
Local Char S_PARAM_LEG
Local Char S_PARAM_COM
Local Char S_PARAM_TITLE_PREFIX

S_NUM_COLUMN = 5
S_PARAM_REQUETTE = "__REQUETE"
S_PARAM_LAN      = "X3LAN"
S_PARAM_X3ETA    = "X3ETA"
S_PARAM_NUMEDT   = "numedt"
S_PARAM_CODE     = "numtab"
S_PARAM_LEG      = "legislation"
S_PARAM_CPY      = "company"
S_PARAM_DEP      = "dependency"
S_PARAM_TITLE_PREFIX   = "title"


# variables for parameters
Local Integer NUMREQ, NUMLIG
Local Integer TABLE_CODE
Local Char    ETAT(GLONARP)
Local Char    LANG, LEG, CPY, DEP

# variables for temporary use
Local Char    PARAM(50)
Local Char    FIELDS(30)(1..S_NUM_COLUMN*2),TITLES(40)(1..S_NUM_COLUMN*2)
Local Char    TYPES(40)(1..S_NUM_COLUMN*2)
Local Integer OPTIONS(40)(1..S_NUM_COLUMN*2)
Local Decimal LNGS(40)(1..S_NUM_COLUMN*2)
Local Integer KA, KN, K
Local Char    T_TIT, T_VAL_INI, T_VAL, T_OPT
Local Char    CRITERE(250)(1..10)
Local Integer ICRITERE

# table variables
If clalev([F:ARM])=0  : Local File AREPORTM    [ARM]  : Endif
If clalev([F:ADV])=0  : Local File ATABTAB     [ADV]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV     [ADI]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE       [ATY]  : Endif

# get parameters
Call GETPARAM(S_PARAM_REQUETTE,NBPAR,PARAMETRE,PARAM) From ETAT : NUMREQ = val(PARAM)
Call GETPARAM(S_PARAM_CODE,NBPAR,PARAMETRE,PARAM) From ETAT : TABLE_CODE = val(PARAM)
Call GETPARAM(S_PARAM_LAN,NBPAR,PARAMETRE,LANG) From ETAT 
Call GETPARAM(S_PARAM_LEG,NBPAR,PARAMETRE,LEG) From ETAT 
Call GETPARAM(S_PARAM_CPY,NBPAR,PARAMETRE,CPY) From ETAT 
Call GETPARAM(S_PARAM_DEP,NBPAR,PARAMETRE,DEP) From ETAT 
Call GETPARAM(S_PARAM_X3ETA,NBPAR,PARAMETRE,ETAT) From ETAT 
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif 

# set parameters
Gosub PREPARE_PARAM

# clean and write into table AREPORTM
Gosub TR1

End


#####################################################################################################
$PREPARE_PARAM

PARAM = num$(NUMREQ)
Call SETPARAM(S_PARAM_NUMEDT,NBPAR,PARAMETRE,PARAM) From ETAT 

Raz KA, KN
Read [ADV]CODE = TABLE_CODE
If !fstat
 # get the first 5(S_NUM_COLUMN) activated alpha columns
 For I = 1 To dim([F:ADV]COLALPTYP) 
  T_TIT = func AFNC.TEXTRALAN(LANG,"ATABTAB","COLALPDES",num$(TABLE_CODE),num$(I-1))
  If T_TIT = ""
   # If no translation found for the given language, try with current language 
   T_TIT = func AFNC.TEXTRA("ATABTAB","COLALPDES",num$(TABLE_CODE),num$(I-1))
  Endif
  If T_TIT<>"" and KA < S_NUM_COLUMN
   KA += 1
   FIELDS(KA) = "A"+num$(I)
   TITLES(KA) = T_TIT
   TYPES(KA) = [ADV]COLALPTYP(I-1)
   If TYPES(KA) = "" : TYPES(KA) = "A" : Endif
   T_OPT = [ADV]COLALPSUP(I-1)
   Call GET_LNG(TYPES(KA), T_OPT, OPTIONS(KA), LNGS(KA))
  Endif
 Next

 # get the first 5(S_NUM_COLUMN) activated numerical columns
 For I = 1 To dim([F:ADV]COLNUMTYP)
  T_TIT = func AFNC.TEXTRALAN(LANG,"ATABTAB","COLNUMDES",num$(TABLE_CODE),num$(I-1))
  If T_TIT = ""
   # If no translation found for the given language, try with current language 
   T_TIT = func AFNC.TEXTRA("ATABTAB","COLNUMDES",num$(TABLE_CODE),num$(I-1))
  Endif
  If T_TIT<>"" and KN < S_NUM_COLUMN
   KN += 1
   FIELDS(KA+KN) = "N"+num$(I)
   TITLES(KA+KN) = T_TIT
   TYPES(KA+KN) = [ADV]COLNUMTYP(I-1)
   If  TYPES(KA+KN) = "" :  TYPES(KA+KN) = "L" :  Endif
   T_OPT = [ADV]COLNUMSUP(I-1)
   Call GET_LNG(TYPES(KA+KN), T_OPT, OPTIONS(KA+KN), LNGS(KA+KN))
  Endif
 Next
Endif

# set parameters

For I = 1 To S_NUM_COLUMN*2
  Call SETPARAM(S_PARAM_TITLE_PREFIX+num$(I),NBPAR,PARAMETRE,TITLES(I)) From ETAT 
Next

Return


#####################################################################################################
$TR1

GOK=1
Trbegin [ARM]

 # clean table AREPORTM
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER #Where 1=1 # ?
 
 Raz [F:ARM]
 Raz NUMLIG,CRITERE, ICRITERE
 
 # build the filter criterias
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","NUMTAB = TABLE_CODE","") From GOBJSUB
 If [L]LEG <> "" and [L]LEG <> "?????"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:ADI]LEG = [L]LEG","&") From GOBJSUB
 Endif
 If [L]CPY <> "" and [L]CPY <> "?????"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:ADI]SOC = [L]CPY","&") From GOBJSUB
 Endif
 If [L]DEP <> "" and [L]DEP <> "?????"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","[F:ADI]DEPCOD = [L]DEP","&") From GOBJSUB
 Endif
 
 Filter [ADI] Where evalue(CRITERE)
 # loop on ADI and fill ARM
 For [ADI]
  NUMLIG+=1
  [F:ARM]RPTCOD = ETAT 
  [F:ARM]USR    = GUSER
  [F:ARM]NUMREQ = NUMREQ
  [F:ARM]NUMLIG = NUMLIG
  [F:ARM]CLEA1 = [F:ADI]CODE
  For I=1 To KA
   Raz T_VAL_INI,T_VAL
   T_VAL_INI = evalue("[F:ADI]"+FIELDS(I))
   T_VAL = T_VAL_INI
   # convert "internal value" into the "display value"
   Call CHARGE(T_VAL,TYPES(I),OPTIONS(I),LNGS(I),T_VAL_INI) From FMTVAR
   Assign("[F:ARM]CLEA"+num$(I+1)) With T_VAL
  Next
  For I=1 To KN
   Raz T_VAL_INI,T_VAL
   T_VAL_INI = num$(evalue("[F:ADI]"+FIELDS(KA+I)))
   T_VAL = T_VAL_INI
   # convert "internal value" into the "display value"
   Read [ATY]CODTYP = TYPES(KA+I)
   If !fstat and [F:ATY]TYPTYP = 1
    Call GET_MES_ML(LANG,val(T_VAL_INI),OPTIONS(KA+I),T_VAL)
   Else
    Call CHARGE(T_VAL,TYPES(KA+I),OPTIONS(KA+I),LNGS(KA+I),T_VAL_INI) From FMTVAR
   Endif
   Assign("[F:ARM]CLEA"+num$(KA+I+1)) With T_VAL
  Next
  Write [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif 
 Next
 Filter
 If GOK=0 : Rollback : Return : Endif 
Commit
Return


######################################################################################################
# get the option/length of the column type
Subprog GET_LNG(TYP, OPT, RES_OPT, RES_LNG)
Value Char TYP
Value Char OPT
Variable Integer RES_OPT
Variable Decimal RES_LNG
 If clalev([F:ATY])=0  : Local File ATYPE [ATY]  : Endif
 Raz RES_OPT, RES_LNG
 Read [ATY]CODTYP = TYP
 If !fstat
  If [F:ATY]NOLIB<>0
   RES_OPT = [F:ATY]NOLIB
  Else
   RES_OPT = val(OPT)
  Endif
  
  RES_LNG = [F:ATY]LNGTYP
  If [F:ATY]LNGTYP = 0
   Case [F:ATY]TYPTYP
    When 2 : RES_LNG = 4
    When 3 : RES_LNG = 8
    When 4 : RES_LNG = 11.2
   Endcase 
  Endif
 Endif
End


########################################################################################################
# get the message of "menu local" in a given language
Subprog GET_MES_ML(LANG,NUM,CHP,MES)
Value Char LANG
Value Integer NUM
Value Integer CHP
Variable Char MES
 Raz MES
 If NUM<1 : NUM = 1 : Endif
 MES = func AFNC.MENLOC(LANG,NUM,CHP)
 If MES = "" 
  # if not found, try with current language
  MES = func AFNC.MENLOC(GLANGUE,NUM,CHP)
 Endif
End

