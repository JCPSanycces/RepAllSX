#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Local Mask TRILETTR [TLT]
Gosub INIT_TRI
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBTLT","TRILETTR",4,"") From GTRAITE
End

$ACTION
Case ACTION
  When "DEBUT"    :  Gosub DEBUT
  When "OK"       :  PARAM(1) = "2"   :# Boutons OK  de la fenetre de tri
  When "END"      :  PARAM(1) = "1"   :# Boutons FIN de la fenetre de tri
  When "CONTROLE" :  Gosub CONTROLE
  When "BOUTON"   :  Gosub BOUTON
Endcase
Return

########################################
## Style de sélection
########################################
$STYLE
Local Char STYLE(GLONASY)
STYLE = "MTC3"
Return
########################################

### KC, Bug54795 : ajout de deux chps CHPCP et CODTYPCP pour gérer le Tri  ####
### chercher ces deux champs ds le TRT : CL_DRO / CL_GAU / CL_HAU / CL_BAS ####

$DEBUT
[M:TLT]DRO = "154"
[M:TLT]GAU = "153"
[M:TLT]HAU = "030"
[M:TLT]BAS = "029"
Gosub RAZCRI
Affzo
Return

$INIT_TRI
K = -1
K += 1 : [M:TLT]CHP(K)="ACCDAT" : [M:TLT]CRITERE(K) = mess(14,105,1)  : # Date comptable
K += 1 : [M:TLT]CHP(K)="AMTLED" : [M:TLT]CRITERE(K) = mess(48,110,1)  : # montant en devise locale AMTLED
K += 1 : [M:TLT]CHP(K)="TYP"    : [M:TLT]CRITERE(K) = mess(10,105,1)  : # Type de la pièce TYP
K += 1 : [M:TLT]CHP(K)="NUM"    : [M:TLT]CRITERE(K) = mess(11,105,1)  : # numéro de la pièce NUM
K += 1 : [M:TLT]CHP(K)="DES"    : [M:TLT]CRITERE(K) = mess(49,110,1)  : # libellé écriture DES
K += 1 : [M:TLT]CHP(K)="FREREF" : [M:TLT]CRITERE(K) = mess(47,110,1)  : # référence libre FREREF
K += 1 : [M:TLT]CHP(K)="CUR"    : [M:TLT]CRITERE(K) = mess(18,105,1)  : # Devise
K += 1 : [M:TLT]CHP(K)="MTC"    : [M:TLT]CRITERE(K) = mess(11,110,1)  : # Lettre

[M:TLT]NBLIG = K+1

GPOINT = "SELDAE" : Gosub ENTREE From EXEFNC

# Suite au point d'entrée...
#    - Vérification du champ dans la table GACCENTRYD
#    - Information sur son type

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

For I=0 To [M:TLT]NBLIG-1
    [M:TLT]NUMLIG(I) = I+1
    Read [ATZ]CODZONE = "GACCENTRYD";[M:TLT]CHP(I)
    If !fstat 
        If [F:ATY]CODTYP<>[F:ATZ]CODTYP
            Read [ATY]CODTYP = [F:ATZ]CODTYP
        Endif
        Case [F:ATY]TYPTYP
             When 1 : # Menu local
                [M:TLT]CODTYP(I) = "M"
             When 2,3,4,5,6 : # Numérique
                [M:TLT]CODTYP(I) = "I"
             When 7 : # Alpha
                [M:TLT]CODTYP(I) = "A"
             When 8 : # Date
                [M:TLT]CODTYP(I) = "D"
        Endcase
    Endif
Next

Return

$BOUTON
Case BOUT
 When "M","R","E"
  Gosub RAZCRI
Endcase
Return

$RAZCRI
Chgstl [M:TLT]NBCRI,NBLIG With ""
[M:TLT]CRICUR = 0
[M:TLT]LIGCUR = 0
Return

$CONTROLE
If PARAM(1)="2"
 If [M:TLT]NBCRI=0
  GMESSAGE = mess(16,120,1) : # Ordre de tri incorrect
  GERR = 1 : SAI = 1 : FIN = 0 : Return
 Endif
Endif
FIN = 1
Return

#####################################
# ECRAN TRILETTR FENETRE DE TRI
#####################################

Subprog C_ORDRE(VALEUR)
Variable Decimal VALEUR
Local Integer I
IF VALEUR=0 : End : Endif

If !find(VALEUR,1,2,3)
 GMESSAGE = mess(16,120,1) : # Ordre de tri incorrect
 mkstat = 2 : End
Endif
For I=0 To [M]NBLIG-1
 If [M]ORDRE(I)=VALEUR & I<>nolign-1
  [M]ORDRE(I) = [M]ORDRE(nolign-1) : Affzo ORDRE(I)
 Endif
Next I
End

Subprog AV_TRI(VALEUR)
Variable Integer VALEUR
If VALEUR = 0 : VALEUR = 1 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TRILETTR) 27/06/2006 16:23:01 (BY)
######################################################################################
Subprog CL_DRO(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]LIGCUR-1
If NOL>=0
 Gosub DESELECT
 [M]CRI([M]NBCRI)      = [M]CRITERE(NOL)
 [M]NUMTRI([M]NBCRI)   = [M]NUMLIG(NOL)
 [M]CHPCP([M]NBCRI)    = [M]CHP(NOL)
 [M]CODTYPCP([M]NBCRI) = [M]CODTYP(NOL)
 [M]NBCRI += 1
 Dela NOL [M]NBLIG
 [M]NBLIG -= 1
 Affzo
 If [M]NBLIG>0
  [M]LIGCUR = min(NOL+1,[M]NBLIG)
  Chgstl [M]NBLIG([M]LIGCUR-1) With STYLE
 Endif
Endif
End

Subprog CL_GAU(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=0
 Gosub DESELECT
 [M]CRITERE([M]NBLIG)  = [M]CRI(NOL)
 [M]NUMLIG([M]NBLIG)   = [M]NUMTRI(NOL)
 [M]CHP([M]NBLIG)      = [M]CHPCP(NOL)
 [M]CODTYP([M]NBLIG)   = [M]CODTYPCP(NOL)
 [M]NBLIG += 1
 Dela NOL [M]NBCRI
 [M]NBCRI -= 1
 Affzo
 If [M]NBCRI>0
  [M]CRICUR = min(NOL+1,[M]NBCRI)
  Chgstl [M]NBCRI([M]CRICUR-1) With STYLE
 Endif
Endif
End

Subprog CL_HAU(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=1
 Local Char    SAVCRI(30),SAVCHPCP(30),SAVCODTYPCP(30)
 Local Integer SAVTRI , SAVORD
 SAVCRI            = [M]CRI(NOL)
 SAVTRI            = [M]NUMTRI(NOL)
 SAVORD            = [M]TRI(NOL)
 SAVCHPCP          = [M]CHPCP(NOL)
 SAVCODTYPCP       = [M]CODTYPCP(NOL)
 [M]CRI(NOL)       = [M]CRI(NOL-1)
 [M]NUMTRI(NOL)    = [M]NUMTRI(NOL-1)
 [M]TRI(NOL)       = [M]TRI(NOL-1)
 [M]CHPCP(NOL)     = [M]CHPCP(NOL-1)
 [M]CODTYPCP(NOL)  = [M]CODTYPCP(NOL-1)
 [M]CRI(NOL-1)     = SAVCRI
 [M]NUMTRI(NOL-1)  = SAVTRI
 [M]TRI(NOL-1)     = SAVORD
 [M]CHPCP(NOL-1)   = SAVCHPCP
 [M]CODTYPCP(NOL-1)= SAVCODTYPCP

 Affzo CRI,NUMTRI,TRI,CHPCP,CODTYPCP
 Chgstl [M]NBCRI([M]CRICUR-1) With ""
 [M]CRICUR -= 1
 Chgstl [M]NBCRI([M]CRICUR-1) With STYLE
Endif
End

Subprog CL_BAS(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
Gosub STYLE
NOL = [M]CRICUR-1
If NOL>=0 & NOL<[M]NBCRI-1
 Local Char    SAVCRI(30),SAVCHPCP(30),SAVCODTYPCP(30)
 Local Integer SAVTRI , SAVORD
 SAVCRI            = [M]CRI(NOL)
 SAVTRI            = [M]NUMTRI(NOL)
 SAVORD            = [M]TRI(NOL)
 SAVCHPCP          = [M]CHPCP(NOL)
 SAVCODTYPCP       = [M]CODTYPCP(NOL)
 [M]CRI(NOL)       = [M]CRI(NOL+1)
 [M]NUMTRI(NOL)    = [M]NUMTRI(NOL+1)
 [M]TRI(NOL)       = [M]TRI(NOL+1)
 [M]CHPCP(NOL)     = [M]CHPCP(NOL+1)
 [M]CODTYPCP(NOL)  = [M]CODTYPCP(NOL+1)
 [M]CRI(NOL+1)     = SAVCRI
 [M]NUMTRI(NOL+1)  = SAVTRI
 [M]TRI(NOL+1)     = SAVORD
 [M]CHPCP(NOL+1)   = SAVCHPCP
 [M]CODTYPCP(NOL+1)= SAVCODTYPCP

 Affzo CRI,NUMTRI,TRI,CHPCP,CODTYPCP
 Chgstl [M]NBCRI([M]CRICUR-1) With ""
 [M]CRICUR += 1
 Chgstl [M]NBCRI([M]CRICUR-1) With STYLE
Endif
End

Subprog AS_NBLIG
If nolign>0 & nolign<=[M]NBLIG
 Gosub STYLE
 Gosub DESELECT
 Chgstl [M]NBLIG(nolign-1) With STYLE
 [M]LIGCUR = nolign
Endif
End

Subprog AS_NBCRI
If nolign>0 & nolign<=[M]NBCRI
 Gosub STYLE
 Gosub DESELECT
 Chgstl [M]NBCRI(nolign-1) With STYLE
 [M]CRICUR = nolign
Endif
End

$DESELECT
If [M]LIGCUR<>0
 Chgstl [M]NBLIG([M]LIGCUR-1) With ""
 [M]LIGCUR = 0
Endif
If [M]CRICUR<>0
 Chgstl [M]NBCRI([M]CRICUR-1) With ""
 [M]CRICUR = 0
Endif
Return

######################################################################################

