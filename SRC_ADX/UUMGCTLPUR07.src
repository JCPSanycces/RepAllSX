#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLPUR07   Contrôle Pre-migration Retours              Module Achats #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
    Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLPUR07") From LECFIC
  Endif

  Call MAJ_UUMGCTLPUR07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLPUR07(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(5)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLPUR07 Purchase Returns Process : PRETURN-D") From DOSSUB
Call ECR_TRACE("UUMGCTLPUR07 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1
Gosub CTL2

$FIN
Call ECR_TIME("UUMGCTLPUR07 : Purchase Returns Process END.")  From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PRETURN")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PRETURND") : Return : Endif


REQSQL(0)="SELECT PNH.PNHNUM_0 FROM "-DOSSIER+".PRETURN PNH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PRETURND PND WHERE PNH.PNHNUM_0=PND.PNHNUM_0) "
REQSQL(2)="ORDER BY PNH.PNHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PRETURN without PRETURND",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPNHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PNHNUM="-[BXX]VPNHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 108760 - 2015-06-12 by SR : Adaptation
If func DOSVUE.ISVIEW(DOSSIER,"PRETURN")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"PRETURND") : Return : Endif


REQSQL(0)="SELECT PND.PNHNUM_0,PND.PNDLIN_0 FROM "-DOSSIER+".PRETURND PND "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".PRETURN PNH WHERE PNH.PNHNUM_0=PND.PNHNUM_0) "
REQSQL(2)="ORDER BY PND.PNHNUM_0,PND.PNDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("PRETURND without PRETURN",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VPNHNUM(50),Integer VPNDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"PNHNUM/PNDLIN="-[BXX]VPNHNUM+'/'+num$([BXX]VPNDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

