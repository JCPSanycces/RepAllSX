$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "MODIF"     : Gosub MODIF
 When "CREATION"  : Gosub CREATION
 When "FILTRE"    : Gosub FILTRE
Endcase
Return

$OUVRE
    If clalev([F:JSA])=0    : Local File JOBTYPKSA    [JSA]         : Endif
Return

$LIENS
Read [F:JSA]JSA0=[M:JOT0]COD
If !fstat
  [M:JOT3] = [F:JSA]
Endif

#If func AFNC.ACTIV("KZA")>0
If func DIVPAYE.IS_KZA(GCURLEG)
  If [M:JOT3]PDIFLG = 1
    Effzo [M:JOT3]RCEGRP        : Grizo [M:JOT3]RCEGRP
    Effzo [M:JOT3]SEX           : Grizo [M:JOT3]SEX
    Effzo [M:JOT3]PDISTR        : Grizo [M:JOT3]PDISTR
    Effzo [M:JOT3]PDIEND        : Grizo [M:JOT3]PDIEND
  Else
    Actzo [M:JOT3]PDISTR
    Actzo [M:JOT3]PDIEND
    Actzo [M:JOT3]RCEGRP
    Actzo [M:JOT3]SEX
  Endif

  If [M:JOT3]HDCFLG = 1
    Effzo [M:JOT3]HDCTYP        : Grizo [M:JOT3]HDCTYP
    Effzo [M:JOT3]HDCSTR        : Grizo [M:JOT3]HDCSTR
    Effzo [M:JOT3]HDCEND        : Grizo [M:JOT3]HDCEND
  Else
    Actzo [M:JOT3]HDCTYP
    Actzo [M:JOT3]HDCSTR
    Actzo [M:JOT3]HDCEND
  Endif
Endif

Return

$MODIF
$CREATION
  Local Integer UPDNUM  : UPDNUM = 0
  Delete [JSA] Where COD=[M:JOT0]COD
    If fstat=1
     GOK = -1
     GLOCK = "$JOBTYPKSA"-[F:JOT]COD
     Return
    Elsif fstat>5
     GOK = 0
     Call RSTA("JSA",[F:JOT]COD) From GLOCK
     Return
    Endif
    [F:JSA]COD = [F:JOT]COD
    [F:JSA]    = [M:JOT3]
    Write [JSA]
    If fstat
      GOK=0 : Return
    Endif

  #Updating all linked positions
#  If clalev([F:PSA]) = 0 : Local File POSTEKSA    [PSA]         : Endif
#  If clalev([F:POT]) = 0 : Local File POSTE       [POT]         : Endif
#
#  For [POT] Where JOBPOT = [M:JOT0]COD
