#&                                            EQUEMPTYP   = [M:JOT3]EQUEMPTYP, STG = [M:JOT3]STG, PDIFLG = [M:JOT3]PDIFLG, PDISTR = [M:JOT3]PDISTR,
#&                                            PDIEND = [M:JOT3]PDIEND, HDCFLG = [M:JOT3]HDCFLG, HDCTYP = [M:JOT3]HDCTYP, HDCSTR = [M:JOT3]HDCSTR, HDCEND = [M:JOT3]HDCEND
#  If adxuprec = 1 : UPDNUM += adxuprec : Endif
#  If adxuprec =  0 #Record not updated - does not exist in [F:PSA] - Create record
#    Read [PSA]PSA0 = [F:POT]COD # Checking again
#    If !fstat
#      [F:PSA]OCPLEV     = [M:JOT3]OCPLEV
#      [F:PSA]SCACPC     = [M:JOT3]SCACPC
#      [F:PSA]RCEGRP     = [M:JOT3]RCEGRP
#      [F:PSA]SEX        = [M:JOT3]SEX
#      [F:PSA]EQUEMPTYP  = [M:JOT3]EQUEMPTYP
#      [F:PSA]STG        = [M:JOT3]STG
#      [F:PSA]PDIFLG     = [M:JOT3]PDIFLG
#      [F:PSA]PDISTR     = [M:JOT3]PDISTR
#      [F:PSA]PDIEND     = [M:JOT3]PDIEND
#      [F:PSA]HDCFLG     = [M:JOT3]HDCFLG
#      [F:PSA]HDCTYP     = [M:JOT3]HDCTYP
#      [F:PSA]HDCSTR     = [M:JOT3]HDCSTR
#      [F:PSA]HDCEND     = [M:JOT3]HDCEND
#      Rewrite [PSA]
#      If !fstat : UPDNUM += 1 :  Endif
#      #If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif - Shouldn't stop main transaction
#    Else
#      Raz[F:PSA]
#      [F:PSA]COD        = [F:POT]COD
#      [F:PSA]OCPLEV     = [M:JOT3]OCPLEV
#      [F:PSA]SCACPC     = [M:JOT3]SCACPC
#      [F:PSA]RCEGRP     = [M:JOT3]RCEGRP
#      [F:PSA]SEX        = [M:JOT3]SEX
#      [F:PSA]EQUEMPTYP  = [M:JOT3]EQUEMPTYP
#      [F:PSA]STG        = [M:JOT3]STG
#      [F:PSA]PDIFLG     = [M:JOT3]PDIFLG
#      [F:PSA]PDISTR     = [M:JOT3]PDISTR
#      [F:PSA]PDIEND     = [M:JOT3]PDIEND
#      [F:PSA]HDCFLG     = [M:JOT3]HDCFLG
#      [F:PSA]HDCTYP     = [M:JOT3]HDCTYP
#      [F:PSA]HDCSTR     = [M:JOT3]HDCSTR
#      [F:PSA]HDCEND     = [M:JOT3]HDCEND
#      Write [PSA]
#      If !fstat : UPDNUM += 1 :  Endif
#      #If fstat : GOK = 0 : Call FSTA("CVR") From GLOCK : Break : Endif - Shouldn't stop main transaction
#    Endif
#  Endif
#  Next
#  GERR = 2  : GMESSAGE = mess(00028,00720,1) - " : " - num$(UPDNUM)
Return


$FILTRE
  If clalev([F:JSA]) = 0 : Local File JOBTYPKSA    [JSA]         : Endif
    If [F:JOT]COD <> [F:JSA]COD
      Read [JSA]JSA0 = [F:JOT]COD
    Endif
  Return


Subprog AM_CCV(VALEUR)
Variable Char VALEUR()
#If func AFNC.ACTIV("KZA")>0
If func DIVPAYE.IS_KZA(GCURLEG)
  If clalev([F:CCV]) = 0    : Local File CLASSCONV    [CCV]         : Endif
  Read [F:CCV]CCV0 = VALEUR
  If !fstat
    [M:JOT3] = [F:CCV] #also done in the main code - protecting for KSA
    Affzo [M:JOT3]OCPLEV
  Endif
  [M:JOT3]JOBGRA = VALEUR
  Affzo [M:JOT3]JOBGRA
Endif
End

Subprog AM_PDIFLG(VALEUR)
Variable Integer VALEUR()
  If [L]VALEUR = 1
    Effzo [M:JOT3]RCEGRP        : Grizo [M:JOT3]RCEGRP
    Effzo [M:JOT3]SEX           : Grizo [M:JOT3]SEX
    Effzo [M:JOT3]PDISTR        : Grizo [M:JOT3]PDISTR
    Effzo [M:JOT3]PDIEND        : Grizo [M:JOT3]PDIEND
  Else
    Actzo [M:JOT3]RCEGRP
    Actzo [M:JOT3]SEX
    Actzo [M:JOT3]PDISTR
    Actzo [M:JOT3]PDIEND
  Endif
End

Subprog AM_HDCFLG(VALEUR)
Variable Integer VALEUR()
   If [L]VALEUR = 1
    Effzo [M:JOT3]HDCTYP        : Grizo [M:JOT3]HDCTYP
    Effzo [M:JOT3]HDCSTR        : Grizo [M:JOT3]HDCSTR
    Effzo [M:JOT3]HDCEND        : Grizo [M:JOT3]HDCEND
  Else
    Actzo [M:JOT3]HDCTYP
    Actzo [M:JOT3]HDCSTR
    Actzo [M:JOT3]HDCEND
  Endif
End
