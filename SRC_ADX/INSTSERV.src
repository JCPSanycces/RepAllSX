#<AdxTL>@(#)5.0.0.0 $Revision$
#Call CLASS_OBJECT
#Call CRE_CLASS_OBJECT("SERVSUP") From DOSAPL
#End

Call INSTALL
End

#--------------------------------------------------------------------#
Subprog INSTALL

Local Char    NOMDEF(10) , NOM(10) , ORDSYS(250)
Local Char    REPERT(250) , NOMFIC(250) , NOMTRT(250) , FICH(30) , REP(10)
Local Integer I , K , STAT , DBATYP , ERREUR , PRODUIT
Local Char    BASE(30) , USER(30) , PASSE(30) , TABDAT(30) , TABIDX(30)

Local File ABATPAR [ABP]
#109897
#Local File ADOVAL [ADW]
#Read [ADW]ADW0 = "";"";"TYPDOS"
#PRODUIT = val([F:ADW]VALEUR)-1
#Case PRODUIT
# When -1 : NOMDEF = "SERVSUP"  : # Superv
# When  0 : NOMDEF = "SERVX3"   : # X3
# When  1 : NOMDEF = "SERVGX"   : # Géode
# When  2 : NOMDEF = "SERVPAIE" : # Paye
# When  3 : NOMDEF = "SERVABEL" : # Biens
# When  4 : NOMDEF = "SERVGF"   : # Loan GF
#Endcase
#109897
Call PARAM("","SUPDOS",NOMDEF) From ADOVAL

ERREUR = 0
Read [ABP]SPOOL First
If fstat
 Trbegin [ABP]
  Raz [F:ABP]
  [F:ABP]NUMREQ  = 1
  [F:ABP]APPLI   = NOMDEF
  [F:ABP]NBTACHE = 8
  [F:ABP]TEMPS   = 30
  [F:ABP]TIMOUT  = 30
  Write [ABP]
 Commit
 NOM = NOMDEF
Else
 NOM = [F:ABP]APPLI
 If NOM="" : NOM = NOMDEF : Endif
Endif

End : #109897
################################################
# Répertoire de base
# Répertoire sous runtime (ancien chemin)
REPERT = filpath("","","",NOM)
If filinfo(REPERT,0)>=0 : End : Endif : # Déjà installé

#99610 répertoire sous dossiers (volume A)
REPERT = filpath("","","",NOM,"A")
If filinfo(REPERT,0)>=0 : End : Endif : # Déjà installé

Gosub CREREP
If ERREUR : End : Endif

# Fichiers .users et .passwd (nécessaires pour que le répertoire soit reconnu comme application adonix dans un filpath)
For FICH = ".users",".passwd"
 NOMFIC = filpath("",FICH,"",NOM,"A")
 If filinfo(NOMFIC,0)<0
  Openo NOMFIC , 0
  Openo
 Endif
Next FICH

# Sous-répertoires
For REP = "TRT","FIL","TRA","tmp","job"
 REPERT = filpath(REP,"","",NOM)
 Gosub CREREP
Next REP

# Fichier adxora
Read [ADW]ADW0 = "";"";"TYPDBA"
If !fstat
 Call PASSE(nomap,BASE,USER,PASSE,TABDAT,TABIDX) From ORAPASSE
 Case val([F:ADW]VALEUR)
  When 1 : # Oracle
   ORDSYS = "adxora -b"-getenv$("ORACLE_SID")-"-u"-nomap-"-p"-PASSE-NOM
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  When 2 : # SQL-Serveur
   ORDSYS = "adxodbc -b"-getenv$("SQLS7_SID")-"-u"-nomap-"-p"-PASSE-"-d"-getenv$("DATASOURCE")-NOM
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  When 4 : # DB2
    #PC 16/12/99 parametrage adxdb2 pour serveur db2 evidement
   ORDSYS = "adxdb2 -u"-nomap-"-p"-PASSE-"-d"-getenv$("DATASOURCE")- NOM
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
 Endcase
Endif

# Fichier APL.ini
NOMFIC = filpath("","APL","ini",NOM)
Openo NOMFIC,0
adxifs = "" : adxirs = chr$(10)
Wrseq "#<AdxTJ>@(#)%I%"
Wrseq 'adxmother(0) = "'+nomap+'"'
Wrseq 'adxmother(1) = "'+nomap+'"'
Wrseq 'adxmother(2) = "'+nomap+'"'
Wrseq 'adxmso       = 10'
Wrseq 'adxmto       = 80'
Wrseq 'maxmem       = 8000'
Wrseq 'adxtct       = "APLCOM"'
Wrseq 'adxtlk       = "APLLCK"'
Wrseq 'adxtms       = "APLSTD"'
Openo

# Crétion de la classe OBJECT
#Call CRE_CLASS_OBJECT(NOM) From DOSAPL

# Suppression de de l'archive
Call EFFACE(filpath("","atx","ind",NOM,"",""),STAT) From ORDSYS

# Création version de l'archive
ORDSYS = 'archive -n -f -d'-NOM
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

# Copie du traitement menu
Call COPIE_ADX("",nomap,"SERVX3","",NOM,"MENU",STAT) From ORDSYS

End

#--------------------------------------------------#
$CREREP
If filinfo(REPERT,0)<0
 ORDSYS = 'ae_mkdir'-'"'+REPERT+'"'
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
Endif
If filinfo(REPERT,0)<0
 Call ECR_TRACE(mess(184,124,1)+"\|"+REPERT+"|",1) From GESECRAN
 ERREUR = 1
Endif
Return

