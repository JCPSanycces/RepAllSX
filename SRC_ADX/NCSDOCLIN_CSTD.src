#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: NCSDOCLIN_CSTD, Non-conformance - Document Collection
##############################################################################
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase

Return
###############################################################################

# --------------------------------------------------
# Increment collection row's line number (DOCLIN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

      this.SUBLIN = 1 + max (this.APARENT.NCSDOCLIN(1..maxtab(this.APARENT.NCSDOCLIN)).SUBLIN)

Return

