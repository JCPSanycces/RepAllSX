#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201803002
# Issue X3-15630 - 2018-03-08 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201803002(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201803002(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR

  Call ECR_TRACE("UTIPJM201803002: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ATEXTRA" [AXX]
  Local File =DOSSIER + ".PJMSNPD" [PSNPD]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [AXX]
  Filter [AXX] Where [F:AXX]CODFIC = "PJMSNPD" and [F:AXX]ZONE = "DDESAXX" and [F:AXX]IDENT2 <> ""
  For [AXX]
    Read [PSNPD]PSNPD1=[F:AXX]IDENT1;val([F:AXX]IDENT2)
    If !fstat Then
      [F:AXX]IDENT1 = [F:PSNPD]KEYEXT
      [F:AXX]IDENT2 = ""
      Rewrite [AXX]
      COMPTEUR += 1
      If fstat Then
        Call ECR_TRACE("File ATEXTRA" - [F:AXX]CODFIC - [F:AXX]ZONE - [F:AXX]IDENT1 - [F:AXX]IDENT2 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Else
      Delete [AXX]Curr
      COMPTEUR += 1
      If fstat Then
        Call ECR_TRACE("File ATEXTRA" - [F:AXX]CODFIC - [F:AXX]ZONE - [F:AXX]IDENT1 - [F:AXX]IDENT2 + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [AXX]
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201803002 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201803002 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [PSNPD]
  Close Local File [AXX]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","PJMSNPD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMSNPD") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201803002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  If filinfo(filpath("FIL","PJMSNPD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMSNPD") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201803002(APPLI)
End

