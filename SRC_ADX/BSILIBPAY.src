#-----------------------------------------------------------------------------------------------------
#*** Validate created payment using REMBAN function in background
#-----------------------------------------------------------------------------------------------------
$VALIDATE_PAYMENT
   Local Char VALEUR(10)
   Local Char PARAM2(250)(1..20) , SAVACT(10), SAVCURLEG(10), SAVFONCTION(20)
#   Local Integer SAVSERVEUR : SAVSERVEUR = GSERVEUR
#   GSERVEUR=1                     # server mode
   SAVFONCTION = GFONCTION
   GFONCTION="REMBAN" : Call AUTORIS From EXEFNC
   SAVACT = GACTION : GACTION = "BSIREMBAN"
   SAVCURLEG = GCURLEG : GCURLEG = [F:BSIIP]LEG
   Call TRAITE_CHAR(VALEUR,PARAM2,"","BSIPAYREMBAN","",3,"") From GTRAITE
   GACTION = SAVACT
   GCURLEG = SAVCURLEG
   If SAVFONCTION<>GFONCTION
     GFONCTION=SAVFONCTION : Call AUTORIS From EXEFNC
   Endif
#   GSERVEUR=SAVSERVEUR           # restore mode
Return


######################################################################################################

#**
#* Purpose: Generate payments for a whole statement.
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#* @param PSTA         Status coming from BSI_PAYMENT_CREATION (0 = OK, other values see there)
#* @param PMSG         Message corresponding to status.
#*!
Subprog BSI_PAYMENT_CREATION_STATEMENT( PSTMCOD, PSTA, PMSG )
Value Char PSTMCOD      # Statement identifier
Variable Integer PSTA   # Status of payment creation (see ...)
Variable Char PMSG      # Message corresponding to the status

    Raz PSTA, PMSG

    # Open necessary tables.
    If !clalev ([F:BSIIMPD]) Local File BSIIMPD  [BSIIMPD] Endif # Details import (transactions).

    # Check for an existing log file (FLGTRACE = 1, 0 otherwise).
    Local Integer FLGTRACE : If GTRACE = "" : FLGTRACE = 1 : Else : FLGTRACE = 0 : Endif

    # Open trace file.
    If FLGTRACE
        Call OUVRE_TRACE( mess(40,7703,1) ) From LECFIC
    Endif

    Read [F:BSIIMP]BSIIMP0 = PSTMCOD  # Read statement (import header)
    If fstat # Not found?
        PMSG =  PSTMCOD - mess(1,7703,1) # 'Statement does not exist'
        PSTA = 2
    Elsif [F:BSIIMP]FLGMTC >= 3 # Already validated?
        PMSG = PSTMCOD - mess(2,7703,1) # 'Statement already validated'
        PSTA = 1
    Else
        # Loop over set of transactions.
        For [F:BSIIMPD]BSIIMPD0 Where [F:BSIIMPD]STMCOD = PSTMCOD and [F:BSIIMPD]FLGCRE <> 2 and [F:BSIIMPD]FLGCRE <> 4 # not validated or manually closed
            Call BSI_PAYMENT_CREATION( PSTMCOD, [F:BSIIMPD]LIN, PSTA, PMSG )
            If PSTA
                Call ECR_TRACE( PMSG, 1 ) From GESECRAN
            Endif
        Next
    Endif

    # Close and show trace file.
    If FLGTRACE
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
End


#-----------------------------------------------------------------------------------------------------
#*** Get needed information for discount line creation
#-----------------------------------------------------------------------------------------------------
$WRITE_ANALYTICAL_LINES
Local Integer COUNTER, COUNTER1
Local Char ERRMES(255)
Local Char LEDC(10) : LEDC = ""
Local Char ACCC(10) : ACCC = ""
Local Instance PBDGROUP Using C_PBDGEND
  [L]PBDGROUP = NewInstance C_PBDGEND AllocGroup null

Local Integer  NBRDIE           : # Number of Dimension Types (max 20)
Local Char     DIE(GLONDIE)(20)       : # Dimension types (DIE)
Local Char     DIEFMT(10)(1..)    : # Dimension Types Formats
Local Char     DIECOLHEA(10)(1..) : # Dimension Types Column Header
Local Integer  DIEOBYFLG(1..)   : # Obligatory Flags (Y/N)
Local Char INDARR(10)(25)
Local Char CCE(GLONCCE)(20)
Local Char TMPCCE(GLONCCE)
Local Char ANACOA(10)
Local Integer CCEFOUND : CCEFOUND = 0
Local Integer  USEDACDIE
Local Integer  NBRLED
Local Tinyint  LEDTYP(20)
Local Char     LEDCOD(20)(20)
Local Char     LEDCUR(20)(20)    : # Ledger Currencies
Local Char     COA(10)(20)       : # Chart of accounts
Local Char     COAFMT(10)(1..)    : # Chart of accounts Formats
Local Char     COACOLHEA(10)(1..) : # Chart of account Column Header


#get acounting structure for the company
ASTATUS = func FINACM_SYRA.GET_FINSTC(GACTX,[F:BSIIMPD]CPY,1,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)

#return if no dimensiontype
  If NBRDIE = 0 : Return : Endif

  For COUNTER = 0 To NBRDIE - 1 #loop through dimension
    For COUNTER1 = 0 To dim(COA)-1 #loop throug coa's

      If func LEDGER_IS_ANALYTICAL(LEDCOD(COUNTER1)) = 2 and COA(COUNTER1) <> "" # if the ledger is anylyical
        #Infbox "Ledger " + LEDCOD(COUNTER1) + " is analyitical and coa is " + COA(COUNTER1)
        ANACOA = COA(COUNTER1) # set analyitcal coa
        Gosub SETINDARR        # set index array
        If INDARR(13) = "" : Break : Endif #if no discount account -> break
        ASTATUS = func BSILIBANA.INI_CCE(GACTX,PBDGROUP,[F:BSIIMPD]CPY,"PAYMENTD",LEDC,ANACOA,ACCC,DIE(COUNTER),TMPCCE,INDARR,ERRMES) #Get the associated CCEs for the dimensions and coa
        If TMPCCE <> "" : CCEFOUND = 1 : Endif
          CCE(COUNTER) = TMPCCE
      Endif
    Next
  Next
  If CCEFOUND = 0 : Return : Endif
  #write analytical line to the file
  Gosub WRITE_ANALYTICAL_LINE_TO_FILE

