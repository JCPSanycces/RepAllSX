#-----------------------------------------------------------------------------------------------------
#*** write analytical line to file
#-----------------------------------------------------------------------------------------------------
$WRITE_ANALYTICAL_LINE_TO_FILE

  Wrseq '"A"';'"'+DIE(0)+'"';'"'+CCE(0)+'"';'"'+DIE(1)+'"';'"'+CCE(1)+'"';'"'+DIE(2)+'"';'"'+CCE(2)+'"';'"'+DIE(3)+'"';'"'+CCE(3)+'"';'"'+DIE(4)+'"';'"'+CCE(4)+'"';'"'+DIE(5)+'"';'"'+CCE(5)+'"';'"'+
& DIE(6)+'"';'"'+CCE(6)+'"';'"'+DIE(7)+'"';'"'+CCE(7)+'"';'"'+DIE(8)+'"';'"'+CCE(8)+'"';'"'+DIE(9)+'"';'"'+CCE(9)+'"';'"'+DIE(10)+'"';'"'+CCE(10)+'"';'"'+DIE(11)+'"';'"'+CCE(11)+'"';'"'+DIE(12)+'"';
& '"'+
& CCE(12)+'"';'"'+DIE(13)+'"';'"'+CCE(13)+'"';'"'+DIE(14)+'"';'"'+CCE(14)+'"';'"'+DIE(15)+'"';'"'+CCE(15)+'"';'"'+DIE(16)+'"';'"'+CCE(16)+'"';'"'+DIE(17)+'"';'"'+CCE(17)+'"';'"'+DIE(18)+'"';'"'+CCE(18
& )+
& '"';'"'+DIE(19)+'"';'"'+CCE(19)+'"';func GETDISCAMOUNT(AMOUNT, TOTALAMOUNT, [F:BSIDUD]BSIDEPCUR);0 Using [TF]

Return


#-----------------------------------------------------------------------------------------------------
#*** initalyze dimension arrays
#-----------------------------------------------------------------------------------------------------
$INIT_DIE_CCE
Local Integer I
  For I = 0 To dim(DIE)-1
    DIE(I) = ""
    CCE(I) = ""
  Next
Return

#-----------------------------------------------------------------------------------------------------
#*** set index array of dimension types
#-----------------------------------------------------------------------------------------------------
$SETINDARR

   #INDARR
# 1  = Product
# 2  = Customer
# 3  = Supplier
# 4  = Sales rep
# 5  = Buyer
# 6  = Document
# 7  = Company
# 8  = Site
# 9  = Currency
# 10 = Tax
# 11 = Sales footer
# 12 = Discount
# 13 = Bank
# 14 = Account
# 15 = Fixed asset
# 16 = Purchase footer
# 17 = Miscellaneous business partner
# 18 = Costing dimensions
# 19 = Overhead costs
# 20 = Origin document
# 21 = Previous dimensions
# 22 = Requester
# 23 = Purchase costs
# 24 = None

   If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
#[F:BSIIMP]FCY = [F:BSIIMPD]FCYLIN
   Read [F:BPR]BPR0 = [F:BSIIMPD]BPRPAY
   If !fstat
     If [F:BPR]BPCFLG = 2
      INDARR(1) = [F:BPR]BPRNUM
     Else
# 2016-09-22 DNE MODIF BEGIN
      INDARR(2) = [F:BPR]BPRNUM
# 2016-09-22 DNE MODIF ORIG
#      INDAAR(2) = [F:BPR]BPRNUM
# 2016-09-22 DNE MODIF END
     Endif
   Endif
   INDARR(6) = [F:BSIIMPD]CPY
   INDARR(7) = [F:BSIIMP]FCY
   INDARR(8) = [F:BSIIMP]CUR
   INDARR(9) = [F:BSIIMPD]VAT
   INDARR(12)= [F:BSIIMP]BAN
   INDARR(13)= func GETDISCOUNTACCOUNT([F:BSIIMPD]CPY,[F:BSIIP]LEG,ANACOA,TEMPTAX,[F:BSIDUD]SNS,DENDEP)

Return

#-----------------------------------------------------------------------------------------------------
#*** Determine discount account
#*  @param COMPANY   value char     -> company
#*  @param LEG       value char     -> Legislation
#*  @param ACOA      value Char     -> chart of account (in our case analytical)#
#*  @param VATCODE   value Char     -> VAT code
#*  @param SIGN      value Integer  -> Debit-Credit Sign (1-> Debit; -1 -> Credit)
#*  @param DENDEP    value Char     ->
#*  @return RESULT   Local char     -> analytical chart of account
#-----------------------------------------------------------------------------------------------------
#*!
Funprog GETDISCOUNTACCOUNT(COMPANY, LEG ,ACOA,VATCODE, SIGN, DENDEP)
  Value Char COMPANY
  Value Char LEG
  Value Char ACOA
  Value Char VATCODE
  Value Integer SIGN
  Value Char DENDEP
  Local Char ACCCOD(30)
  Local Char DISCACC(30)

  If !clalev([F:CDA])  : Local File GACCDENCOD [CDA]  : Endif
  If !clalev([F:TVT])  : Local File TABVAT [TVT]  : Endif

  If DENDEP <> ""
    Filter [F:CDA] Where [F:CDA]COD = DENDEP
    Read [F:CDA] First
    ACCCOD = [F:CDA]ACCCOD
    Filter [F:CDA]
  Endif
  If ACCCOD <> ""
    If SIGN = 1
      DISCACC = func READ_DISCACC_FROM_ACCCOD(14, 1, ACOA, ACCCOD)
    Else
# 2017-10-11 X3-56107 Bader MODIF BEGIN
      DISCACC = func READ_DISCACC_FROM_ACCCOD(14, 0, ACOA, ACCCOD)
# 2017-10-11 X3-56107 Bader MODIF ORIG
#      DISCACC = func READ_DISCACC_FROM_ACCCOD(14, 2, ACOA, ACCCOD)
# 2017-10-11 X3-56107 Bader MODIF END
    Endif
  Endif
  If DISCACC = ""
    #Read [F:TVT]TVT0 = VATCODE;LEG
    Filter [F:TVT] Where [F:TVT]VAT = VATCODE and [F:TVT]LEG = LEG
    Read [F:TVT] First
    ACCCOD = [F:TVT]ACCCOD
    Filter [F:TVT]
    If ACCCOD <> ""
      If SIGN = 1
# 2017-10-11 X3-56107 Bader MODIF BEGIN moved from 14 (-1) to 27 (-1)
        DISCACC = func READ_DISCACC_FROM_ACCCOD(10, 26, ACOA, ACCCOD)
# 2017-10-11 X3-56107 Bader MODIF ORIG
#        DISCACC = func READ_DISCACC_FROM_ACCCOD(10, 13, ACOA, ACCCOD)
# 2017-10-11 X3-56107 Bader MODIF END
      Else
# 2017-10-11 X3-56107 Bader MODIF BEGIN moved from 13 (-1) to 26 (-1)
        DISCACC = func READ_DISCACC_FROM_ACCCOD(10, 25, ACOA, ACCCOD)
# 2017-10-11 X3-56107 Bader MODIF ORIG
#        DISCACC = func READ_DISCACC_FROM_ACCCOD(10, 14, ACOA, ACCCOD) # bug!! should be 12 instead
# 2017-10-11 X3-56107 Bader MODIF END
      Endif
    Endif
  Endif
End DISCACC

#-----------------------------------------------------------------------------------------------------
#*** Read the discount account from accounting code
#*  @param VTYP      value Integer -> Typ of accounting code
#*  @param INDEX     value Integer -> Index of account in accounting code
#*  @param ACOA      value Char    -> chart of account (in our case analytical)#
#*  @param ACCCODE   value Char    -> accounting code
#*  @return RESULT   Local char    -> analytical chart of account
#-----------------------------------------------------------------------------------------------------
#*!
Funprog READ_DISCACC_FROM_ACCCOD(VTYP, INDEX, ACOA, ACCCODE)
  Value Integer VTYP
  Value Integer INDEX
  Value Char ACOA
  Value Char ACCCODE
  Local Char ACCOUNT(30)
  If !clalev([F:CAC])  : Local File GACCCODE [CAC]  : Endif
  Filter [F:CAC] Where [F:CAC]TYP = VTYP and  [F:CAC]ACCCOD = ACCCODE and [F:CAC]COA = ACOA
  Read [F:CAC] First
  ACCOUNT = [F:CAC]ACC(INDEX)
  Filter [F:CAC]
End ACCOUNT

#-----------------------------------------------------------------------------------------------------
#*** Get analytical chart of account for a given company
#*  @param COMP   Variable char -> company
#*  @return RESULT   Local char    -> analytical chart of account
#-----------------------------------------------------------------------------------------------------
#*!
Funprog GET_ANALYTICAL_COA(COMP)
  Value Char COMP
  Local Char ANACOA(10)
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
  If !clalev([F:LED]) : Local File GLED [LED] : Endif

  Read [CPY]CPY0 = [F:BSIIMPD]CPY
  If !fstat
    #this.LEG = [F:CPY]LEG  # assign legislation
    Read [GCM]GCM0 = [CPY]ACM
    If !fstat
      Read [LED]LED0 = [GCM]LED( [GCM]ANALEDTYP - 1 )
      If !fstat
        ANACOA = [LED]COA # assign coa
      Endif
    Endif
  Endif
End ANACOA


#-----------------------------------------------------------------------------------------------------
#*** Check if a ledger is analytical
#*  @param LEDGER   Variable char -> Ledger
#*  @return RESULT  Local Integer -> if analytical -> true
#-----------------------------------------------------------------------------------------------------
#*!
Funprog LEDGER_IS_ANALYTICAL(LEDGER)
Value Char LEDGER
Local Tinyint RESULT
  If !clalev([F:LED]) : Local File GLED [LED] : Endif
  Read [F:LED]LED0 = LEDGER
  If !fstat
    RESULT = [F:LED]ANA
  Endif
End RESULT


#**
#* Purpose: Closing of one transaction manually within a bank file import statement
#*
#* @param PSTMCOD      primary key for reading record in table BSIIMP.
#* @param PLIN         second part of primary key for reading record in table BSIIMPD (PSTMCOD+PLIN).
#* @param PSTA         status of closing 0:OK, 1:payments already created, 2:transaction/statement not found, 3:various
#* @param PMSG         Message corresponding to status.
#*!
Subprog BSI_CLOSE_TRANSACTION(PSTMCOD,PLIN,PSTA,PMSG)
Value Char PSTMCOD     # file number of statement, part of key to table BSIIMP/BSIIMPD
Value Integer PLIN     # line number of statement, part of key to table BSIIMPD
Variable Integer PSTA  # status of closing 0:OK, 1:payments already created, 2:transaction/statement not found, 3:various
Variable Clbfile PMSG  # Message corresponding to status

If !clalev ([F:BSIIMP])     Local File BSIIMP      [BSIIMP]  Endif # header import
If !clalev ([F:BSIIMPD])    Local File BSIIMPD     [BSIIMPD] Endif # details import

PSTA = 0

Read [F:BSIIMP]BSIIMP0 = PSTMCOD  # read statement (import header)
If !fstat
  Read [F:BSIIMPD]BSIIMPD0 = PSTMCOD;PLIN # read transaction PLIN of statement
  If !fstat
    If find ([F:BSIIMPD]FLGCRE,2,4)    # Validated or manually closed
      PSTA = 1
      PMSG = PSTMCOD - mess(46,7703,1) # "Payment already created"
    Elsif [F:BSIIMPD]LET = ""
      PSTA = 3
      PMSG = func AFNC.MES1( mess(47,7703,1), PSTMCOD+"~"+num$(PLIN)) # "Transaction $1$ not matched."
    Else
      [F:BSIIMPD]FLGCRE = 4               # Set "manually closed".
      Rewrite [F:BSIIMPD]
      If fstat
          PSTA = 3
          PMSG = [F:BSIIMPD]STMCOD + "~" + num$( [F:BSIIMPD]LIN ) - mess(27,125,1)
      Else
          [F:BSIIMP]FLGMTC = 3               # Set "Validated".
          Rewrite [F:BSIIMP]
          If fstat
              PSTA = 3
              PMSG = [F:BSIIMP]STMCOD - mess(27,125,1)
          Endif
      Endif
    Endif
  Else
     PSTA = 2
     PMSG = PSTMCOD + "~" + num$(PLIN) - mess(7,7703,1) # 'Transaction does not exist'
  Endif
Else
   PSTA = 2
   PMSG = PSTMCOD - mess(1,7703,1) # 'Statement does not exist'
Endif
End

