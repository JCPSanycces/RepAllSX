#**
#* =================================================================================
#* FXDASSETS_C_MPR : FXDASSETS Private Methods
#* =================================================================================
#* You will find hereunder a full desciption of PHYELT private methods, operations or functions.
#*     - Can fixed asset be linked to a physical asset (_IS_FAS_LINKABLE_TO_PHY)
#*     - Is fixedasset disposed (_IS_FAS_DISPOSED)
#* _______________________________________________________________________________
#*
#*!

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When Default  : Gosub METHODS From FXDASSETS_C_MPU
      Endcase
    When Default
  Endcase
Return

$OPERATIONS
  Case [L]CURPTH
    When ""
      Case [L]AOPERATION
        When "_IS_FAS_LINKABLE_TO_PHY"  : Gosub _IS_FAS_LINKABLE_TO_PHY

        #-------------
        When Default  : Gosub OPERATIONS From FXDASSETS_C_MPU
      Endcase
    When Default
  Endcase
Return

# ======================================================================
#    P R I V A T E     O P E R A T I O N S
# ======================================================================

#**
#* ==========================================
#* Private Operation: _IS_FAS_LINKABLE_TO_PHY  - Can fixed asset be linked to a physical asset
#* ------------------------------------------
#* This operation verifies that a fixed asset can be linked to a physical element.
#*      1. Fixed asset is read
#*      2- attachability is verified
#* --------------------------------
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#* @return            : Error message stack
#*!
$_IS_FAS_LINKABLE_TO_PHY

  ARET_VALUE= [V]CST_AOK

  [L]ASTATUS = fmet this.AREAD(AASREF)
  If ([L]ASTATUS >= [V]CST_AERROR)
    [L]ARET_VALUE = fmet this.ASETERROR("", mess(76,127,1)+" FXDASSETS ("+AASREF+")", [V]CST_AERROR)
    Return
  Endif

  If func FXDASSETS_C_MPR._IS_FAS_DISPOSED(this)
    #
    #**
    #* ==> AASREF > Entered fixed asset cannot be attached to Physical element if it is disposed
    #*!
    [L]ARET_VALUE = fmet this.ASETERROR("AASREF", mess(27,[V]CST_MSGPHY,1)-mess(99,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

  If not (this.FCY = [L]PHYFCY)
    #**
    #* ==> AASREF > fixed asset and physical asset must belong to the same facility
    #*!
    [L]ARET_VALUE = fmet this.ASETERROR("AASREF", mess(24,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

  If (this.OWNTYP = [V]CST_TDMODEL)
    #**
    #* ==> AASREF > Entered fixed asset cannot be attached to Physical element if its owner type is "Template"
    #*!
    [L]ARET_VALUE = fmet this.ASETERROR("AASREF", mess(27,[V]CST_MSGPHY,1)-mess(168,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

  If (this.OWNTYP = [V]CST_TDANNUL)
    #**
    #* ==> AASREF > Entered fixed asset cannot be attached to Physical element if its owner type is "Cancelled"
    #*!
    [L]ARET_VALUE = fmet this.ASETERROR("AASREF", mess(27,[V]CST_MSGPHY,1)-mess(169,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

  If not (this.ENAFAS = [V]CST_AYES)
    #**
    #* ==> AASREF > Entered fixed asset cannot be attached to Physical element if it is not active
    #*!
    [L]ARET_VALUE = fmet this.ASETERROR("AASREF", mess(27,[V]CST_MSGPHY,1)-mess(94,[V]CST_MSGPHY,1), [V]CST_AERROR)
  Endif

Return


# ======================================================================
#    P R I V A T E     F U N C T I O N S
# ======================================================================

#**
#* ===========================
#* Function : _FAS_IS_DISPOSED - Is fixedasset disposed
#* Returns "True"  if the fixed assets is disposed and if it is not a "planned" disposal.
#*         "False" if the fixed assets is not disposed or if it is a "planned" disposal.
#* ---------------------------
#* @param  PFAS :  Fixed asset data class instance
#* @return RRET :  True/False
#* ---------------------------
#*!

Funprog _IS_FAS_DISPOSED (PFAS)
Variable Instance PFAS Using C_FXDASSETS
Local Integer RRET

  If PFAS.ISSDAT <> AVOID.ADATE and not (PFAS.EXTISSFLG = [V]CST_AYES)
    [L]RRET  = [V]CST_ATRUE
  Else
    [L]RRET  = [V]CST_AFALSE
  Endif

End RRET


