#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End

######################################

$ACTION
Case ACTION
  When "SAISIE"            : Gosub SAISIE
  When "IMPRIMANTE"        : Gosub IMPRIMANTE
Endcase
Return


##################################
$SAISIE
  #To not open the parameter window
  If GFONC1 = "FUNSCA"  [M:RPT]IMPRIME = 2
                        [M:RPT]SERVEUR = [F:ARP]PRTSRV
                        OK = 0
  Endif
Return

######################################
$IMPRIMANTE
  #Parameter to open the dialog box
  NBPAR += 1
  PARAMETRE(NBPAR) = "_NoVisible="+chr$(1)+"1"
Return

