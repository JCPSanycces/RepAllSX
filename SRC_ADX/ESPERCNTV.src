#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return

$OUVRE
Gosub OUVRE_OUT From ESPERCNTAV

#Manage Localisations
Call MANAGE_LOCALISATION("ESSPERCNTV") From DIVPAYE

Return

$OUVRE_OUT
#Opening tables and declaring an instance of the main class
If clalev([F:EWID1])      = 0 : Local File ESSWRKEMP    [EWID1]     : Endif
Return

$DEBUT
Gosub DEBUT_OUT From ESPERCNTAV

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSPERCNTVHIDE
Call SHOW_LEGACTCALLS From WESSPERCNTVSHOW

Affzo [M:ESPRC]1-99
Return




