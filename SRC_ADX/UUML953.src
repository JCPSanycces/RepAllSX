#<AdxTL>@(#)7.0.0.0 $Revision$ Ritenzione, Insertion menu local 953 Type de charge
#CHECK UNUSED_SOURCE
Onerrgo ERREUR From CONTROLE
Local Mask UUML953 [DIA]
Local File RITENZIONE [RTZ], GACCOUNT [GAC]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
Local Integer OK    

Raz [M:DIA]
Call DES_TRAIT("UUML953",GMESSAGE) From EXETRT
Call DIALO(OK,GMESSAGE) From GESECRAN
If OK=2
 Call DEBTRANS From GLOCK
 Gosub TR1
Endif
End

$TR1
GOK=1
Trbegin [RTZ], [GAC]

 For [RTZ]RTZ0
  For I=dim([F:RTZ]BAS)-1 To [M:DIA]TYP Step -1
   [F:RTZ]BAS(I) = [F:RTZ]BAS(I-1)
  Next I
  [F:RTZ]BAS([M:DIA]TYP-1)=1 : # Non
  Rewrite [RTZ]
  If fstat>2
   GOK=0 : Call FSTA("RTZ") From GLOCK : Break
  Endif
 Next : # [RTZ]
 If GOK<1 : Goto AB_TR1 : Endif

 For [GAC]GAC0 Where RITTYP>=[M:DIA]TYP
  [F:GAC]RITTYP += 1
  Rewrite [GAC]
  If fstat>2
   GOK=0 : Call FSTA("GAC") From GLOCK : Break
  Endif
 Next : # [GAC]
 If GOK<1 : Goto AB_TR1 : Endif

Commit
Call MESSAGE(mess(16,187,1)) From GESECRAN : # Fin normale
Return

$AB_TR1
Rollback
Return

