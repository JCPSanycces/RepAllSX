#########################################
$GEN_CTR
NBCLAUSE=0
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
Local Char CRITLEG(250)
CRITLEG="1=1"
If [L]ONLEG = 1 Then
  CRITLEG-="& [F:HRCLC]LEG = GCURLEG"
Else
  CRITLEG-='& ( [F:HRCLC]LEG = GCURLEG | [F:HRCLC]LEG="" )'
Endif
#If [M:DIA]FLGUPD=2 :# MAJ Contrats existants
#   Call DEBTRANS From GLOCK
#   Gosub SUPP_CTR
#  # fin LS
#Endif
#Parcours des clauses du document à générer sur le rang...
#For[HRCLC]CLC1
For[HRCLC]CLC1 Where evalue(CRITLEG)
 ###55423
 #IDOC=find(DOCUMENT,[F:HRCLC]DOCCLA(0..dim([F:HRCLC]DOCCLA)-1))
 #If IDOC
   If find(DOCUMENT,[F:HRCLC]DOCCLA(0..dim([F:HRCLC]DOCCLA)-1))
   ###
      GOK=1

      #Si la condition de la présence de la clause est vérifiée
      If [F:HRCLC]CDNCLA="" | evalue ([F:HRCLC]CDNCLA)


        #Check if the legilation matches the contract or if it is blank
        Look[F:HRCLC]CLC0=[F:HRCLC]CODCLA;[F:FCY]LEG

        #If ([F:HRCLC]LEG=[F:FCY]LEG|([F:FCY]LEG<>"" & [F:HRCLC]LEG="" & [S]fstat=5)) | [F:HRCLC]TYPCLA=2
        If ([F:HRCLC]LEG=[F:FCY]LEG|([F:FCY]LEG<>"" & [F:HRCLC]LEG="" & [S]fstat=5))
           #Traitement de la clause si elle générale ou si elle est spécifique au salarié courant
           If [F:HRCLC]TYPCLA<>2 | evalue(CRITPART)
    #           #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
    #          pca addittional check with legislation needed
    #              Case DOCUMENT
    #               When 1 :
    #                I = 0
    #                If [F:HRCLC]TYPCLA=2
    #                  While I<10
    #                    If find([F:HRCLC]CODCLA,[F:HRCTR]CLACTRSPE(I))
    #                     If (find([F:HRCLC]LEG,[F:HRCTR]CLACTRSPELEG(I)))
    #                        I=100
    #                     Else
    #                        I+=1
    #                     Endif
    #                    Else
    #                        I+=1
    #                    Endif
    #                  Wend
    #                Endif
    #
    #              When 2 :
    #              I = 0
    #              If [F:HRCLC]TYPCLA=2
    #              While I<10
    #               If find([F:HRCLC]CODCLA,[F:HRCTR]CLALETSPE(I))
    #               If (find([F:HRCLC]LEG,[F:HRCTR]CLALETSPELEG(I)))
    #               I=100
    #               Else
    #               I+=1
    #               Endif
    #               Else
    #               I+=1
    #               Endif
    #              Wend
    #              Endif
    #
    #               When 3 :
    #              I = 0
    #              If [F:HRCLC]TYPCLA=2
    #              While I<10
    #               If find([F:HRCLC]CODCLA,[F:HRCTR]CLAAVNSPE(I))
    #               If (find([F:HRCLC]LEG,[F:HRCTR]CLAAVNSPELEG(I)))
    #               I=100
    #               Else
    #               I+=1
    #               Endif
    #               Else
    #               I+=1
    #               Endif
    #              Wend
    #              Endif
    #
    #           When Default : I=100
    #          Endcase
              I = 0
              If [F:HRCLC]TYPCLA=2
                While I<10
                  If find([F:HRCLC]CODCLA,[F:HRDOC]CLAUSESPE(I))
                   If (find([F:HRCLC]LEG,[F:HRDOC]CLAUSESPELEG(I)))
                      I=100
                   Else
                      I+=1
                   Endif
                  Else
                      I+=1
                  Endif
                Wend
              Endif
              If [F:HRCLC]TYPCLA<>2 | I=100
                DESTCLB=[F:HRCLC]TXTCLA
                POS=0
                I=func ACB.INSTR_(POS,DESTCLB, "[")
                While I
                   POS=I+1
                   J=func ACB.INSTR_(I,DESTCLB, "]")
                   If J
                      FORMULE=func ACB.CHAR_(func ACB.SEG_(DESTCLB,I+1,J-1))
                      Read[F:FOC]FOC0=FORMULE
                      If !fstat
                         Case [F:FOC]TYPFOR
                          When 1 :#Type Salarié
                           Gosub EVALFOR
                          When 2 :#Type Organisme
                           ORGMAT="" : Raz [F:ORG]
                           If GPAYE
                            Call ORGANISME ([F:ID]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,ORGMAT,[F:FOC]CAIFOR-1) From SUBORG
                            If ORGMAT<>""
                             Read [F:ORG]ORG0=[F:FCY]LEG;ORGMAT
                             If !fstat
                              Gosub EVALFOR
                             Else
                              #Erreur de lecture sur le fichier
                              Call ECR_TRACE(mess(4,10707,1)-"ORGANISME [ORG] :"-ORGMAT,1) From GESECRAN
                              GOK=0 : Break
                             Endif
                            Else
                             #Organisme : valeur non renseignée
                             Call ECR_TRACE(mess(89,10702,1)-":"-mess(7,10707,1),1) From GESECRAN
                             GOK=0 : Break
                            Endif
                           Else
                            #72094
                            #Organisme : Opération impossible ; Module paie inactif
                            Call ECR_TRACE(mess(89,10702,1)-":"-mess(157,123,1)-";"-mess(18,10715,1),1) From GESECRAN
                            GOK=0 : Break
                           Endif
                          When 3 :           :#Type Table Diverse
                           Raz [F:ADI] : Raz [F:AXX]
                           Read [F:ADI]CODE=[F:FOC]ADIFOR;evalue([F:FOC]CTRFOR)
                           If !fstat
                            Read[F:AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;num$([F:FOC]ADIFOR);evalue([F:FOC]CTRFOR)
                            If !fstat
                             VALFOR=ctrans([F:AXX]TEXTE)
                            Else
                             #Erreur de lecture sur le fichier
                             Call ECR_TRACE(mess(4,10707,1)-"ATEXTRA [AXX] :"-num$([F:FOC]ADIFOR)-";"-evalue([F:FOC]CTRFOR),1) From GESECRAN
                             GOK=0 : Break
                            Endif
                           Else
                            #Erreur de lecture sur le fichier
                            Call ECR_TRACE(mess(4,10707,1)-"ATABDIV [ADI] :"-num$([F:FOC]ADIFOR)-";"-evalue([F:FOC]CTRFOR),1) From GESECRAN
                            GOK=0 : Break
                           Endif
                         Endcase
                         DEBCLB=func ACB.LEFT_(DESTCLB,I-1)
                         FINCLB=func ACB.RIGHT_(DESTCLB,J+1)
                         DESTCLB=func ACB.PLUS_(DEBCLB,VALFOR,FINCLB)
                      Endif
                   Endif
                   I=func ACB.INSTR_(POS,DESTCLB, "[")
                Wend
                If GOK
                 Call DEBTRANS From GLOCK
                 Gosub ECRIT_CTR
                 If GOK<0 : Break : Endif
                Else
                 #AAA  : Clause non générée
                 Call ECR_TRACE([F:HRCLC]CODCLA-":"-mess(4,10715,1),1) From GESECRAN
                Endif
               Endif
             Endif
        Endif
          # LS


#      Elsif [M:DIA]FLGUPD=2 :# MAJ Contrats existants
#         Call DEBTRANS From GLOCK
#         Gosub SUPP_CTR
#        # fin LS
      Endif
   Endif

Next
# Si pb sur génération des clauses du contrat et du document
#    -> Doc non généré -> on supprime les 1ere clauses déjà générées
If GOK = 0 Then
    If [M:DIA]FLGUPD=2 :# MAJ Contrats existants
       Call DEBTRANS From GLOCK
       Gosub SUPP_CTR
       GOK = 0
      # fin LS
   Endif
Endif
Return

#LS
$SUPP_CTR
GOK = 1
Trbegin [HRTXC]
 # La condition ne se vérifie plus mais la clause existe dans TXTCTR
 ###55423
 #Delete [HRTXC]TXC0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[F:HRCLC]DOCCLA(IDOC);[F:HRCLC]CODCLA

#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
# Delete toutes les anciennes clauses TXTCTR du document
# Delete [HRTXC]TXC2=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT;[F:HRCLC]CODCLA;[F:HRCLC]LEG
 Delete [HRTXC]TXC2(4)=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT
 ###
 If fstat=1
  GOK = -1 : GLOCK = "$TXTCTR" : Goto ROLL_SUPP_CTR
 Endif
Commit
Return

$ROLL_SUPP_CTR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto SUPP_CTR : Endif
Return
# fin LS

#########################################
$EVALFOR
Onerrgo ERREUR
Raz VALFOR
If evalue([F:FOC]CTRFOR)=""
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
#'Clause document'
 #XXX : valeur non renseignée
# Call ECR_TRACE([F:FOC]CODFOR-":"-mess(7,10707,1),1) From GESECRAN
  Call ECR_TRACE(mess(4,10712,1) -":"-[F:HRCLC]CODCLA-"/"-mess(7,10707,1)-":"-[F:FOC]CODFOR,1) From GESECRAN

Else
 If [F:FOC]FMTFOR<>""
  VALFOR=format$([F:FOC]FMTFOR,ctrans(evalue([F:FOC]CTRFOR)))
 Else
  VALFOR=ctrans(evalue([F:FOC]CTRFOR))
 Endif
Endif
Onerrgo
Return

#46230
#########################################
#Erreur en évaluation de la formule
$ERREUR
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
# 'Clause document'
# Call ECR_TRACE([F:FOC]CODFOR-":"-mess(65,106,1),1) From GESECRAN
  Call ECR_TRACE(mess(4,10712,1) -":"-[F:HRCLC]CODCLA-"/"-mess(65,106,1)-":"-[F:FOC]CODFOR,1) From GESECRAN
Resume
Resume


#########################################
$ECRIT_CTR
GOK = 1
Trbegin [HRTXC]
 ###55423
 #Readlock[F:HRTXC]TXC0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;[F:HRCLC]DOCCLA(IDOC);[F:HRCLC]CODCLA
 Readlock[F:HRTXC]TXC0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT;[F:HRCLC]CODCLA
 ###
 If !fstat
  If [M:DIA]FLGUPD=2 :# MAJ Contrats existants
   [F:HRTXC]ROWCLA=[F:HRCLC]ROWCLA
   [F:HRTXC]DESCTRCLA=[F:HRCLC]DESCTRCLA
   ###55423
   #[F:HRTXC]DOCCLA=[F:HRCLC]DOCCLA(IDOC)
   [F:HRTXC]DOCCLA=DOCUMENT
   ###
   [F:HRTXC]TXTCLA=DESTCLB
   If dim([F:HRTXC]UPDDAT)>0 : [F:HRTXC]UPDDAT = date$ : Endif
   If dim([F:HRTXC]UPDUSR)>0 : [F:HRTXC]UPDUSR = GUSER : Endif
   If dim([F:HRTXC]UPDTIM)>0 : [F:HRTXC]UPDTIM = time  : Endif
   ###DBA le 27/05/05
   [F:HRTXC]FLGPRN=[M:DIA]FLGPRN
   ###
   Rewrite[F:HRTXC]
   If fstat
    GOK = 0 : Call FSTA("HRTXC") From GLOCK : Goto ROLL_ECRIT_CTR
   Else
    NBCLAUSE+=1
   Endif
  Endif
 Elsif fstat=1
  ###55423
  #GOK = -1 : GLOCK = "$TXTCTR"-[F:HRCTR]REFNUM-[F:HRCTR]CTRNUM-num$([F:HRCTR]CTRDAT)-num$([F:HRCLC]DOCCLA(IDOC))-[F:HRCLC]CODCLA
  GOK = -1 : GLOCK = "$TXTCTR"-[F:HRCTR]REFNUM-[F:HRCTR]CTRNUM-num$([F:HRCTR]CTRDAT)-num$(DOCUMENT)-[F:HRCLC]CODCLA
  ###
  Goto ROLL_ECRIT_CTR
 Else
  Raz[F:HRTXC]
  [F:HRTXC]REFNUM=[F:HRCTR]REFNUM
  [F:HRTXC]CTRNUM=[F:HRCTR]CTRNUM
  [F:HRTXC]CTRDAT=[F:HRCTR]CTRDAT
  [F:HRTXC]ETRFCY=[F:HRCTR]ETRFCY
  [F:HRTXC]CODCLA=[F:HRCLC]CODCLA
  [F:HRTXC]ROWCLA=[F:HRCLC]ROWCLA
  [F:HRTXC]LEG=[F:HRCLC]LEG
  #59319
  [F:HRTXC]ORDCLA=format$("N0:4#",[F:HRCLC]ROWCLA)+[F:HRCLC]CODCLA
  ###55423
  #[F:HRTXC]DOCCLA=[F:HRCLC]DOCCLA(IDOC)
  [F:HRTXC]DOCCLA=DOCUMENT
  ###
  [F:HRTXC]DESCTRCLA=[F:HRCLC]DESCTRCLA
  [F:HRTXC]TXTCLA=DESTCLB
  If dim([F:HRTXC]CREDAT)>0 : [F:HRTXC]CREDAT = date$ : Endif
  If dim([F:HRTXC]CREUSR)>0 : [F:HRTXC]CREUSR = GUSER : Endif
  If dim([F:HRTXC]CRETIM)>0 : [F:HRTXC]CRETIM = time  : Endif
   ###DBA le 27/05/05
   [F:HRTXC]FLGPRN=[M:DIA]FLGPRN
   ###

  Write[F:HRTXC]
  If fstat
   GOK = 0 : Call FSTA("HRTXC") From GLOCK : Goto ROLL_ECRIT_CTR
  Else
   NBCLAUSE+=1
  Endif
 Endif
Commit
Return


$ROLL_ECRIT_CTR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto ECRIT_CTR : Endif
Return


Subprog IMPRIME (TYPDOCD, TYPDOCF)
Value Integer TYPDOCD
Value Integer TYPDOCF
Local Char TBVAL(20)(1..14), TBPAR(80)(1..14)
TBPAR(1)="CPY"    : TBVAL(1)=[M:DIA]CPY
TBPAR(2)="FCYDEB" : TBVAL(2)=[M:DIA]FCY
TBPAR(3)="FCYFIN" : TBVAL(3)=[M:DIA]FCY
TBPAR(4)="PRF"    : TBVAL(4)=[M:DIA]PRF
TBPAR(5)="SRV"    : TBVAL(5)=[M:DIA]SRV
TBPAR(6)="MATDEB" : TBVAL(6)=[M:DIA]MATDEB
TBPAR(7)="MATFIN" : TBVAL(7)=[M:DIA]MATFIN
#59319: insertion des contrats
TBPAR(8)="CTRDEB" : TBVAL(8)=[M:DIA]CTRDEB
TBPAR(9)="CTRFIN" : TBVAL(9)=[M:DIA]CTRFIN

TBPAR(10)="DATDEB" : TBVAL(10)=[M:DIA]DATSTR
TBPAR(11)="DATFIN" : TBVAL(11)=[M:DIA]DATEND
#59319: changement code DOCCLA en DOCDEB & DOCFIN
TBPAR(12)="DOCDEB" : TBVAL(12)=num$(TYPDOCD)
TBPAR(13)="DOCFIN" : TBVAL(13)=num$(TYPDOCF)
TBPAR(14)="FLGPRN" : TBVAL(14)=num$([M:DIA]FLGPRN)
GIMPRIME = 1
Call ETAT("DOCENTREE","PREVISU",GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
GIMPRIME = 0
End


#########################################################################################################
## Contrôle en saisie des paramètres CNTSOC, CNTSIT
#########################################################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM()
Value    Char    VALEUR()
Variable Integer OK
Local Char CRITERE(100)
If VALEUR="" : End : Endif
If clalev([F:CNT])=0 : Local File CONTACT [CNT] : Endif
CRITERE = '1=1'
Case PARAM
 When "CNTSIT" : Gosub CTL_CNTSIT
 When "CNTSOC" : Gosub CTL_CNTSOC
Endcase
If OK=0 : mkstat=2 : End : Endif
End

$CTL_CNTSIT
If [M]FCY<>"" : CRITERE -= '& FCY="'+[M]FCY+'"'    : Endif
If [M]CMP<>"" : CRITERE -= '& LEGCPY="'+[M]CMP+'"' : Endif
For [FCY]FCY1 Where evalue(CRITERE)
 Read[CNT]CNT0=3;[F:FCY]FCY;VALEUR
 If fstat
  # Contact inexistant dans le site
  GMESSAGE = mess(122,10702,1)-[F:FCY]FCY-[F:FCY]FCYNAM
  OK = 0 : Break
 Endif
Next
Return

$CTL_CNTSOC
If [M]CMP<>"" : CRITERE -= '& CPY="'+[M]CMP+'"' : Endif
For [CPY] Where evalue(CRITERE)
 Read[CNT]CNT0=2;[F:CPY]CPY;VALEUR
 If fstat
  # Contact inexistant dans la société
  GMESSAGE = mess(123,10702,1)-[F:CPY]CPY-[F:CPY]CPYNAM
  OK = 0 : Break
 Endif
Next
Return

######################################################################################
Subprog AV_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then Grizo [M:DIA]CPY : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CPY",VALEUR,"") From CONTOBJ

If dim([M]LEG)>0
 # If [M]LEG<>[F:CPY]LEG :#MABOS-08/08/13-FQ81085-US1833
  If GCURLEG<>[F:CPY]LEG
     Call C_LEG([F:CPY]LEG)
  Endif
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

#MABOS-08/08/13-FQ81085-US1833
#If dim([F:CPY]LEG)>0
#  Call LECTURE("CPY",VALEUR,"") From CONTOBJ : # already read in C_CPY
#  GCURLEG = [F:CPY]LEG : #- done later in AM_LEG From DIVPAYE
#Endif

If dim([M]LEG)>0 & VALEUR<>""  Then
  If [M]LEG <>"" & [M]LEG<>GCURLEG
     Call AM_LEG([M]LEG) :#MABOS-25/01/2013
  Endif
Endif
#end MABOS-08/08/13-FQ81085-US1833
End

Subprog AV_ALLFCY(VALEUR)
Variable Integer VALEUR
  If [M:DIA]ALLCPY=2 Then
    Grizo [M:DIA]ALLFCY, FCY
  Endif
  If VALEUR=2 Then Grizo [M:DIA]FCY : Endif
  Call GRISE_LEG([M]CPY,[M]FCY) From DIVPAYE
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
 If dim([M]LEG)>0 & VALEUR<>""  Then
    Read [F:FCY]FCY0=VALEUR
    If !fstat Then
      Read [F:CPY]CPY0=[F:FCY]LEGCPY
      If !fstat Then
           Call C_LEG([F:CPY]LEG)
           If !mkstat
              [M]LEG=[F:CPY]LEG
           Else
              mkstat=2 : End
           Endif
      Endif
    Endif
  Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If dim([M]LEG)>0 & VALEUR<>""  Then
  If [M]LEG<>GCURLEG
     Call AM_LEG([M]LEG) :#MABOS-25/01/2013
  Endif
Endif
End

Subprog C_LEG(VALEUR)
Variable Char VALEUR()
Local Integer ONLEG

Call CTR_LEG_TYPDOC(VALEUR,ONLEG,GMESSAGE) : :# MABOS-08/08/13-FQ81085-US1833 : CTR_LEG remplacé par CTR_LEG_TYPDOC
If GMESSAGE<>"" Then
  mkstat=2
Endif
End

#MABOS-08/08/13-FQ81085-US1833 : CTR_LEG remplacé par CTR_LEG_TYPDOC
#**
#* Control Parameter TYPDOC defined
#*
#* @param WLEG   Législation
#* @param ONLEG  -> On the leg (1) or  Not (0)
#* @param WMESS  -> Error message
#*!
Subprog CTR_LEG_TYPDOC(WLEG,ONLEG,WMESS)
Value Char WLEG()
Variable Integer ONLEG
Variable Char WMESS
Local Char    NUMLIB(10)
  Call PARAM([L]WLEG,"TYPDOC",[L]NUMLIB,[L]ONLEG) From SUBHRCLC
  [M:DIA]NOLIB=0
  [L]WMESS=""
  If [L]NUMLIB<>"0" & [L]NUMLIB<>"" Then
    If mess(1,val([L]NUMLIB),1)="" Then
       [L]WMESS =  (mess(156,10701,1)-"("+[L]NUMLIB+")") : # Le menu local du paramètre TYPDOC n'est pas correctement renseigné
    Else
       [M:DIA]NOLIB=val([L]NUMLIB)
    Endif
  Else
    [L]WMESS = mess(157,10701,1) :# Le paramètre TYPDOC n'est pas correctement renseigné
  Endif
  Affzo [M:DIA]NOLIB
End


Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

[M:DIA]DOCDEB=0
#[M:DIA]DOCFIN=len(mess(0,[M:DIA]NOLIB,1))
#[M:DIA]DOCDEBA = mess([M:DIA]DOCDEB,[M:DIA]NOLIB,1)
#[M:DIA]DOCFINA = mess([M:DIA]DOCFIN,[M:DIA]NOLIB,1)
Call PRE_DOC(VALEUR,1)
Affzo [M:DIA]DOCDEB, DOCFIN, DOCDEBA, DOCFINA
#GCURLEG = VALEUR :#MABOS-08/08/13-FQ81085-US1833- done later in AM_LEG From DIVPAYE

End


