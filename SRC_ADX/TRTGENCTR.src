  Raz [F:BPA]
 Endif
Else
 #Adresse : valeur non renseignée
 Call ECR_TRACE(mess(4,9007,1)-[F:CPY]CPY-":"-mess(7,10707,1),1) From GESECRAN
Endif
#Contact société
Raz VALPAR
Call PARAM([F:CPY]CPY,"CNTSOC",VALPAR)From ADOVAL
If VALPAR="" :  VALPAR=[F:CPY]CNTNAM : Endif
If VALPAR<>""
 Read [CNT]CNT0=2;[F:CPY]CPY;VALPAR
 If fstat
  #Erreur de lecture sur le fichier
  Call ECR_TRACE(mess(4,10707,1)-"CONTACT [CNT] :"-VALPAR,1) From GESECRAN
