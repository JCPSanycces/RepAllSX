 Endif
Else
 #Contact : valeur non renseignée
 Call ECR_TRACE(mess(183,197,1)-[F:FCY]FCY-":"-mess(7,10707,1),1) From GESECRAN
Endif
#Société
Read [F:CPY]CPY0=[F:FCY]LEGCPY
If fstat
