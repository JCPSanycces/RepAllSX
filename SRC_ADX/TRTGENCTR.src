#########################################
## Traitement des actions : TRTSUP
#########################################
$ACTION


Case ACTION
 When "INIT"        : Gosub INIT  :#MABOS-08/08/13-FQ81085-US1833
# When "INIT"       : Gosub OUVRE :#MABOS-08/08/13-FQ81085-US1833
# When "INIT_DIA"    : Gosub INIT_DIA : #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
 When "CONTROLE"    : Gosub CONTROLE
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "EXEC"        : Gosub EXEC
 When "BOUTON"      : Gosub BOUTON :#MABOS-08/08/13-FQ81085-US1833
 When "OK"          :  #FIN=1 : GOK = 1 :##MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
# When "END"         : FIN=1 : #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
# When "FIN" :
#  Infbox (ACTION)
#   When "FINSAI" :
#    Infbox (ACTION)
Endcase
Return


#########################################
$OUVRE
Gosub OUVRE From WPDEFTABLE
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif

If clalev([F:HRTXC])=0  : Local File TXTCTR     [HRTXC] : Endif
If clalev([F:FOC])=0    : Local File FORCTR     [FOC]   : Endif
If clalev([F:HRCLC])=0  : Local File CLACTR     [HRCLC] : Endif

If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
#JASMI - 2016-04-11 - Req 114309 - START
###If clalev([F:SIT])=0 : Local File SITEPAYE [SIT] : Endif
#JASMI - 2016-04-11 - Req 114309 - END
If clalev([F:PRF])=0    : Local File PROFIL     [PRF]   : Endif
If clalev([F:SRV])=0    : Local File SERVICE    [SRV]   : Endif
If clalev([F:HRPOP])=0  : Local File POPUL      [HRPOP] : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
If clalev([F:POB])=0    : Local File POPULB     [POB]   : Endif
If clalev([F:WAC])=0    : Local File TRVACC     [WAC]   : Endif
If clalev([F:WAR])=0    : Local File TRVACCRAT  [WAR]   : Endif
#65866
If GPAYE
 If clalev([F:PCA])=0   : Local File CAISSE     [PCA]   : Endif
Endif
If clalev([F:ORG])=0    : Local File ORGANISME  [ORG]   : Endif

If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:CNT])=0    : Local File CONTACT    [CNT]   : Endif
If clalev([F:AIN])=0    : Local File CONTACTCRM [AIN]   : Endif

If clalev([F:BPAF])=0   : Local File BPADDRESS  [BPAF]  : Endif
If clalev([F:CNTF])=0   : Local File CONTACT    [CNTF]  : Endif
If clalev([F:AINF])=0   : Local File CONTACTCRM [AINF]  : Endif

If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif
If clalev([F:AXX])=0    : Local File ATEXTRA    [AXX]   : Endif

#71739+71773
If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif
If clalev([F:IDR])=0    : Local File EMPLOID    [IDR]   : Endif

If clalev([F:HRDOC])=0  : Local File HRCTRDOC   [HRDOC] : Endif : # SEGAY 18/01/13 US 1233 81085

#JASMI - 2016-04-11 - Req 114309 - START
# BRBAN - Portuguese legislation
If func AFNC.ACTIV('KPO')>0
  If clalev([F:CPYPO])=0 : Local File HRCOMPANYPO  [CPYPO] : Endif
  If clalev([F:FCYPO])=0 : Local File HRFACILITYPO [FCYPO] : Endif
Endif
#JASMI - 2016-04-11 - Req 114309 - END

Return


########################################
#$DEBUT :#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
$INIT
#$INIT_DIA
Local Mask TRTGENCTR [DIA]

Local Char WMESS(250)
Local Integer ONLEG   :#- 1 : Parameter TYPDOC on the leg or 0: Not


Local Char FORMULE (250)
Local Char RESULTAT (250)
Local Integer POS
Local Clbfile DESTCLB (6)
Local Clbfile DEBCLB (6)
Local Clbfile FINCLB (6)

Local Char CRITID (250)
Local Char CRITCTR (250)
Local Char CRITPART (250)
Local Char CRITCTRDOC (250) # SEGAY 18/01/13 US 1233 81085

Local Date DATMAT
Local Char MATRI (GLONEML)
Local Char ORGMAT (GLONORG)
Local Char CTR (GLONHRCTR)
Local Char VALFOR (250)
Local Char VALPAR (50)
Local Integer  NBCTR, NBCLAUSE, DOCUMENT, WLINE

Gosub OUVRE

If ([M:DIA]DATSTR =[0/0/0]) Then
  Raz [M:DIA]
  Raz CRITCTR, CRITID, CRITPART
  Raz CRITCTRDOC  # SEGAY 18/01/13 US 1233 81085
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG - local -> global
# If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  If dim(GCURLEG)>0 : Global Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
  If PARAM(1)<>""
   [M:DIA]MATDEB=PARAM(1)
   [M:DIA]MATFIN=PARAM(1)
  Endif
  If GFONCTION = "GESCTR"
    If gdat$(PARAM(2))<>[0/0/0]
     [M:DIA]DATSTR=gdat$(PARAM(2))
     [M:DIA]DATEND=gdat$(PARAM(2))
    Endif
    If PARAM(3)<>""
     [M:DIA]CTRDEB=PARAM(3)
     [M:DIA]CTRFIN=PARAM(3)
    Endif
  Endif

  # SEGAY 18/01/13 US 1233 81085
  #If val(PARAM(4))=2
  # [M:DIA]DOCDEB=1
  # [M:DIA]DOCFIN=1
  #Endif
  #If val(PARAM(5))=2
  # If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,2) : Else : [M:DIA]DOCDEB=2 : Endif
  # [M:DIA]DOCFIN=max([M:DIA]DOCFIN,2)
  #Endif
  #If val(PARAM(6))=2
  # If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,3) : Else : [M:DIA]DOCDEB=3 : Endif
  # [M:DIA]DOCFIN=max([M:DIA]DOCFIN,3)
  #Endif

  #MABOS-08/08/13-FQ81085-US1833-mémo
#  If GCURLEG = "" Then GCURLEG = GLEGFIL:Endif
#  If dim([M:DIA]LEG)> 0 : [M:DIA]LEG=GCURLEG :Endif
  Call INI_LEG From DIVPAYE

  Raz [M:DIA]DOCDEB, DOCFIN
  Raz ONLEG
  #MABOS-08/08/13-FQ81085-US1833-mémo
  If GFONCTION ="TRTGENCTR"
    Call LECMEMO("STD","[M:DIA]","gdo") From GMEMO
    Call AFF_MEMO2(1) From DIVPAYE
  Endif

  Call CTR_LEG_TYPDOC(GCURLEG,ONLEG,WMESS):# MABOS-08/08/13-FQ81085-US1833 : CTR_LEG remplacé par CTR_LEG_TYPDOC
#   If [L]WMESS<>"" Then
#      Call MESSAGE([L]WMESS) From GESECRAN
#  Endif

  If  [L]WMESS ="" Then
    If [M:DIA]MATDEB <>"" Then
      If GFONCTION <> "GESCTR"
      #  If val(PARAM(4))=2
      #   [M:DIA]DOCDEB=1
      #   [M:DIA]DOCFIN=1
      #  Endif
      #  If val(PARAM(5))=2
      #   If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,2) : Else : [M:DIA]DOCDEB=2 : Endif
      #   [M:DIA]DOCFIN=max([M:DIA]DOCFIN,2)
      #  Endif
      #  If val(PARAM(6))=2
      #   If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,3) : Else : [M:DIA]DOCDEB=3 : Endif
      #   [M:DIA]DOCFIN=max([M:DIA]DOCFIN,3)
      #  Endif

  #     From GESHRENT - 1 or N contracts - --------------------------------
        For [HRDOC] Where REFNUM=[M:DIA]MATDEB
        #For nolign=1 To dim(NBDOC)
          If [F:HRDOC]FLGCRE=2
               If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,[F:HRDOC]COD) : Else : [M:DIA]DOCDEB=[F:HRDOC]COD : Endif
               [M:DIA]DOCFIN=max([M:DIA]DOCFIN,[F:HRDOC]COD)
               If [M:DIA]DATSTR > [0/0/0] : [M:DIA]DATSTR=min([M:DIA]DATSTR,[F:HRDOC]CTRDAT) : Else : [M:DIA]DATSTR=[F:HRDOC]CTRDAT : Endif
               [M:DIA]DATEND=max([M:DIA]DATEND,[F:HRDOC]CTRDAT)
    #           If [M:DIA]CTRDEB : [M:DIA]CTRDEB=min([M:DIA]CTRDEB,[F:HRDOC]CTRNUM) : Else : [M:DIA]CTRDEB=[F:HRDOC]CTRNUM : Endif
    #           [M:DIA]CTRFIN=max([M:DIA]CTRFIN,[F:HRDOC]CTRNUM)

          Endif
        Next
      Else
       # From GESCTR : Only 1 contract - ------------------------------------------
       For [HRDOC] Where REFNUM=[M:DIA]MATDEB & CTRNUM=[M:DIA]CTRDEB & CTRDAT=[M:DIA]DATSTR
       #For nolign=1 To dim(NBDOC)
          If [F:HRDOC]FLGCRE=2
               If [M:DIA]DOCDEB : [M:DIA]DOCDEB=min([M:DIA]DOCDEB,[F:HRDOC]COD) : Else : [M:DIA]DOCDEB=[F:HRDOC]COD : Endif
               [M:DIA]DOCFIN=max([M:DIA]DOCFIN,[F:HRDOC]COD)
          Endif
        Next
      Endif
    Endif

    Call PRE_DOC(GCURLEG, 1 )
  Endif
Endif
Return

#MABOS-08/08/13-FQ81085-US1833
$DEBUT
Case BOITE
  When "TRTGENCTR"
  Affzo [DIA]: Setmok [DIA] With 0
Endcase
Return
#end MABOS-08/08/13-FQ81085-US1833

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Raz [M:DIA] :#MABOS-08/08/13-FQ81085-US1833
Return

########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#########################################
$EXEC
TIT=mess(1,10715,1)    : #Génération des documents
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
Local Char NUMLIB(10)
Local Integer ONLEG, NBDOC

If dim([M:DIA]LEG)> 0 :GCURLEG=[M:DIA]LEG : Endif

Call PARAM(GCURLEG,"TYPDOC",[L]NUMLIB,[L]ONLEG) From SUBHRCLC


If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Raz [L]NBDOC

For DOCUMENT= [M:DIA]DOCDEB To  [M:DIA]DOCFIN
 Gosub GENEREDOC
Next

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call TEMPOFF() From GESECRAN:#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
 Call LEC_TRACE From LECFIC :#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
Endif
#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
#If [M:DIA]FLGPRN=2 & [L]NBDOC :Call IMPRIME ([M:DIA]DOCDEB,[M:DIA]DOCFIN):Endif
If [M:DIA]FLGPRN=2 & [L]NBDOC
TIT=mess(2,10715,1)    : # impression des documents
Call TEMPON(TIT) From GESECRAN
Call IMPRIME ([M:DIA]DOCDEB,[M:DIA]DOCFIN)
Call TEMPOFF() From GESECRAN:# MABOS
Endif
If GFONCTION = "TRTGENCTR"
# Go back in Criteria entry,  only in function TRTGENTCTR
  SAI=1
Endif
#end MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
Return

##########################################
$GENEREDOC
GOK=1
Gosub ADD_CRIT
If [M:DIA]FLGPRN=2 : Call DEBTRANS From GLOCK : Gosub RAZ_FLGPRN : Endif
If GOK=1
 Gosub TR1
Endif
Return

##########################################
$RAZ_FLGPRN
Local Char CRITERE (250)
CRITERE="[F:HRTXC]DOCCLA="+num$(DOCUMENT)
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:HRTXC]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:HRTXC]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif

If [M:DIA]CTRDEB<>"" #borne début contrat
 CRITERE -= '& [F:HRTXC]CTRNUM>="'+[M:DIA]CTRDEB+'"'
Endif
If [M:DIA]CTRFIN<>"" #borne fin du contrat
 CRITERE -= '& [F:HRTXC]CTRNUM<="'+[M:DIA]CTRFIN+'"'
Endif

Trbegin [HRTXC]
For [F:HRTXC]TXC0 Where CTRDAT>=[M:DIA]DATSTR & CTRDAT<=[M:DIA]DATEND & evalue(CRITERE)
 [F:HRTXC]FLGPRN=1
 Rewrite [F:HRTXC]
 If fstat<>0
  GOK = 0 : Call FSTA("HRTXC") From GLOCK : Break
 Endif
Next
If GOK=0 : Goto ROLL_RAZ_FLGPRN : Endif
Commit
Return

$ROLL_RAZ_FLGPRN
Rollback
Return

#########################################
$ADD_CRIT
CRITID ="([F:ID]ENAFLG=2 | [F:ID]FLGNEWSAL=2)" :# Salarié Actif ou nouvel embauché
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITID -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITID -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
# SEGAY 18/01/13 US 1233 81085
CRITCTRDOC="1=1"
#If GFONCTION <> "GESCTR" & GFONCTION <> "TRTGENCTR"
#Case DOCUMENT
# When 1 : CRITCTR="FLGCRECTR=2" : CRITPART="find([F:HRCLC]CODCLA,[F:HRCTR]CLACTRSPE(0..9))"
# When 2 : CRITCTR="FLGCRELET=2" : CRITPART="find([F:HRCLC]CODCLA,[F:HRCTR]CLALETSPE(0..9))"
# When 3 : CRITCTR="FLGCREAVN=2" : CRITPART="find([F:HRCLC]CODCLA,[F:HRCTR]CLAAVNSPE(0..9))"
# When Default : CRITCTR="1=1" : CRITPART="1=1"
#Endcase
#Else
 CRITCTR="1=1"
 CRITCTR-="& [FCY]LEG = GCURLEG"
 CRITPART="1=1"
 CRITCTRDOC+=" &[F:HRDOC]FLGCRE=2 & [F:HRDOC]COD=DOCUMENT"
 CRITPART+=" & ([F:HRDOC]CLAUSESPE='' | find([F:HRCLC]CODCLA,[F:HRDOC]CLAUSESPE(0..9)))"
#Endif

If [M:DIA]CTRDEB<>"" #borne début contrat
 CRITCTR -= '& [F:HRCTR]CTRNUM>="'+[M:DIA]CTRDEB+'"'
Endif
If [M:DIA]CTRFIN<>"" #borne fin contrat
 CRITCTR -= '& [F:HRCTR]CTRNUM<="'+[M:DIA]CTRFIN+'"'
Endif

#MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
#If [M:DIA]POP<>""
#    # Link [ID] With
#    #&  [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
#    #&   As [LNK]
#    #&   Where evalue(CRITID) & [F:HRPOA]REFNUM<>""
#
##[HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
#   Link [ID] With
#&  [HRPOA]POA0(2) ~= [M:DIA]POP;[F:ID]REFNUM
#&   As [LNK]
#&   Where evalue(CRITID) & [F:HRPOA]REFNUM<>"" & [F:HRPOA]CTRNUM<>""
#  #end MABOS-23/01/2013-FQ 81085-US1232
#Else
#   Link [ID] With
#&   [HREXM]EXM0=[F:ID]REFNUM;1
#&   As [LNK]
#&   Where evalue(CRITID)
#Endif

If [M:DIA]POP<>""
# SEGAY 18/01/13 US 1233 81085
 #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG + new Popula Key
Link [HRCTR] With
&   [ID]ID0 = [F:HRCTR]REFNUM,
&   [HRDOC]DOC1 ~= [F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT,
&   [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT,
&   [FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LN2]
&   Where  evalue(CRITCTR) & evalue(CRITCTRDOC) &  evalue(CRITID) &
&   [F:HRPOA]REFNUM<>"" & [F:HRPOA]CTRNUM<>""

# END SEGAY 18/01/13 US 1233 81085

Else
#JASMI - 2017-08-10 - X3-48900 - START
#Link [HRCTR] With
#&   [HRDOC]DOC1 ~= [F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT
#&   ,[ID]ID0 = [F:HRCTR]REFNUM
#&   ,[FCY]FCY0 = [F:HRCTR]ETRFCY
#&   As [LN2]
#&   Where evalue(CRITCTR) & evalue(CRITCTRDOC) &  evalue(CRITID)
Link [HRCTR] With
&   [HRDOC]DOC1 ~= [F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT;DOCUMENT
&   ,[ID]ID0 = [F:HRCTR]REFNUM
&   ,[FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LN2]
&   Where evalue(CRITCTR) & evalue(CRITCTRDOC) & evalue(CRITID)
#JASMI - 2017-08-10 - X3-48900 - END
Endif

Return


#########################################
$TR1
GOK=1 : OK=0 : Raz [L]NBCTR
Raz WLINE
 #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
#For [F:LNK]
 #Mise en ligne des infos salarié
# MATRI = [F:ID]REFNUM

 For [F:LN2]
&  Where                    [F:HRCTR]CTRDAT>=[M:DIA]DATSTR & [F:HRCTR]CTRDAT<=[M:DIA]DATEND
# Where [F:HRCTR]REFNUM=[F:ID]REFNUM & evalue(CRITCTRDOC) &
#&                      [F:HRCTR]CTRDAT>=[M:DIA]DATSTR & [F:HRCTR]CTRDAT<=[M:DIA]DATEND
   MATRI = [F:ID]REFNUM
   #MABOS -
   If [M:DIA]FLGUPD=2 :# MAJ Contrats existants
       Call DEBTRANS From GLOCK
       Gosub SUPP_CTR
      # fin LS
   Endif
  #Contrôle critère Société, Site, Service & profil
  Gosub CONTEMP
  If GOK
   DATMAT = [F:HRCTR]CTRDAT
   CTR    = [F:HRCTR]CTRNUM
   Gosub LECEMP From WPDEFTABLE
   #Controle critère libre Pas de ctrl s/flag actif car on a le cas du nouvel embauché
   #73157
   #Call CONTROLE([F:ID]REFNUM,datesyst,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,0) From DIVPAYE
   Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OK,0) From DIVPAYE
   If OK
#    If WLINE > 0 | GFONCTION = "GESHRENT" Then
     Call ECR_TRACE(space$(5),0) From GESECRAN
 #   Endif
    WLINE+=1
    #Matricule XXX
    Call ECR_TRACE(mess(80,10703,1)-":"-[F:ID]REFNUM-mess(156,10702,1)-":"-[F:HRCTR]CTRNUM-"-"-num$([F:HRCTR]CTRDAT),0) From GESECRAN
    #Mise en ligne société, site, adresse, contact...
    Gosub LECDIV
    Gosub GEN_CTR
    # 47568
    #If NBCLAUSE
    If NBCLAUSE & GOK=1
     #Document d'entrée généré
     Call ECR_TRACE(mess(DOCUMENT,[M]NOLIB,1)-":"-mess(3,10715,1),0) From GESECRAN : #MABOS-10398
     [L]NBDOC+=1
     [L]NBCTR+=1
    Else
     #Document d'entrée non généré
#     Call ECR_TRACE(mess(DOCUMENT,10398,1)-":"-mess(6,10715,1)-":"-num$([F:LN2]CTRDAT),1) From GESECRAN :#MABOS
     Call ECR_TRACE(mess(DOCUMENT,[M]NOLIB,1)-":"-mess(6,10715,1),1) From GESECRAN
    # Break
    Endif
   Endif
  Endif
 Next :#LN2
# Endif
#Next  :#LNK  #MABOS-23/01/2013-FQ 81085-US1232- Add leg + local menus by LEG
#If NBCTR > 0 Then :#MABOS
#  Call ECR_TRACE(space$(5)+"fin boucle LN2",0) From GESECRAN
#Endif
## Pour ne pas faire le prochain ECR_TRACE dans la fonction Entrée d'un salarié
If GFONCTION = "GESHRENT" | GFONCTION = "GESCTR" : Return : Endif

#n Document(s) d'entrée généré(s)
#MABOS
If WLINE =0 Then
  Call ECR_TRACE(space$(5),0) From GESECRAN
Endif
#Call ECR_TRACE(mess(DOCUMENT,10398,1)-":"-num$(NBCTR)-mess(5,10715,1),0) From GESECRAN
Call ECR_TRACE(string$(10,"-")-mess(DOCUMENT,[M]NOLIB,1)-":"-num$([L]NBCTR)-mess(5,10715,1),0) From GESECRAN: #MABOS


If !GOK : Return : Endif
Return


