Subprog AS_MATFIN(VALEUR)
Variable Char    VALEUR()
  If [M:DIA]MATDEB<>"" and VALEUR="" Then
    VALEUR=[M:DIA]MATDEB
  Endif
End

Subprog AS_CTRFIN(VALEUR)
Variable Char    VALEUR()
  If [M:DIA]CTRDEB<>"" and VALEUR="" Then
    VALEUR=[M:DIA]CTRDEB
  Endif
End

Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR
If [M]DATEND =[0/0/0]
   [M]DATEND = VALEUR
Endif
End

Subprog IB_DOCDEBA
End

Subprog C_DOCDEBA(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_DOCDEBA(VALEUR)
Variable Char    VALEUR()
  [M:DIA]DOCDEB=val([M]VALDEBINT)
  If [M:DIA]DOCFIN=0 Then
    [M:DIA]DOCFIN = val([M]VALDEBINT)
    [M:DIA]DOCFINA = mess(val([M]VALDEBINT),[M:DIA]NOLIB,1)
    Affzo [M:DIA]DOCFINA
  Endif
End

Subprog IB_DOCFINA
End

Subprog C_DOCFINA(VALEUR)
Variable Char    VALEUR()
Call CTLLIBV(val([M]VALFININT), [M:DIA]DOCDEB) From CONTDIV
End

Subprog AM_DOCFINA(VALEUR)
Variable Char    VALEUR()
  [M:DIA]DOCFIN=val([M]VALFININT)
End

Subprog PRE_DOC(WLEG, LEG_OBLIG )
Value Char WLEG()
Value Integer LEG_OBLIG
If ([L]LEG_OBLIG & [L]WLEG="") | ([M:DIA]NOLIB =0)
  [M:DIA]DOCDEBA=""
  [M:DIA]DOCFINA=""
Else
  If [M:DIA]DOCDEB=0 Then
    [M:DIA]DOCDEB=1
    [M:DIA]DOCFIN=len(mess(0,[M:DIA]NOLIB,1))
  Endif
  [M:DIA]DOCDEBA = mess([M:DIA]DOCDEB,[M:DIA]NOLIB,1)
  [M:DIA]DOCFINA = mess([M:DIA]DOCFIN,[M:DIA]NOLIB,1)
Endif
End

Subprog AV_ALLSRV(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then  Grizo [M:DIA] SRV : Endif
End

Subprog AV_ALLPRF(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then  Grizo [M:DIA]PRF : Endif
End

