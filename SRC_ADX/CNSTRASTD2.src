Subprog C_DATDEB(VALEUR)
Variable Date VALEUR

    Call TESTDATE( VALEUR, [M:TRA5]DATFIN(nolign - 1) )
End



# ###############################################################################################################
# ##########
# ########## Check ...
# ##########
# ###############################################################################################################

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR

    Call TESTDATE( [M:TRA5]DATDEB(nolign - 1), VALEUR )
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog TESTDATE( DATDEB, DATFIN )
Variable Date DATDEB
Variable Date DATFIN

    If ( DATDEB <> [0/0/0] ) and ( day( DATDEB ) <> 1 )
        Call ERREURT( mess(264,107,1), 1 ) From GESECRAN      # "Invalid date range"
        mkstat = 2
        End
    Endif

    If DATFIN <> [0/0/0] and ( gdat$( 0, month( DATFIN ) + 1, year( DATFIN ) ) <> DATFIN )
        Call ERREURT( mess(264,107,1), 1 ) From GESECRAN      # "Invalid date range"
        mkstat = 2
        End
    Endif

    If ( DATDEB <> [0/0/0] ) and ( DATFIN <> [0/0/0] )
        If DATFIN < DATDEB
&         or year(DATDEB) <> year(DATFIN)
            Call ERREURT( mess(264,107,1), 1 ) From GESECRAN      # "Invalid date range"
            mkstat = 2
            End
        Endif
        If!( (month(DATDEB) = month(DATFIN))
&         or (month(DATDEB)=1  and month(DATFIN)=3)
&         or (month(DATDEB)=4  and month(DATFIN)=6)
&         or (month(DATDEB)=7  and month(DATFIN)=9)
&         or (month(DATDEB)=10 and month(DATFIN)=12)
&         or (month(DATDEB)=1  and month(DATFIN)=12) )
            Call ERREURT( mess(264,107,1), 1 ) From GESECRAN      # "Invalid date range"
            mkstat = 2
            End
        Endif
    Endif
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog AM_FLGTRN(VALEUR)
Variable Integer VALEUR

  If VALEUR - 1
      Actzo [M:TRA5]AMTTRN
      Actzo [M:TRA5]CRN
      Actzo [M:TRA5]TAXCEN
      Actzo [M:TRA5]FLGTRN2 : Call AM_FLGTRN2( [M:TRA5]FLGTRN2 )
  Else
      Grizo [M:TRA5]AMTTRN
      Grizo [M:TRA5]CRN
      Grizo [M:TRA5]TAXCEN
      Grizo [M:TRA5]FLGTRN2 : Call AM_FLGTRN2( VALEUR )
  Endif

End

Subprog AM_FLGTRN2(VALEUR)
Variable Integer VALEUR

  If VALEUR - 1
      Actzo [M:TRA5]AMTTRN2
      Actzo [M:TRA5]CRN2
      Actzo [M:TRA5]TAXCEN2
  Else
      Grizo [M:TRA5]AMTTRN2
      Grizo [M:TRA5]CRN2
      Grizo [M:TRA5]TAXCEN2
  Endif
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog C_CRN(VALEUR)
Variable Char    VALEUR()

    If len(VALEUR) <> 9 or val(VALEUR) <= 30000000 or val(VALEUR) >= 990000000
        mkstat = 2
    Endif
End


Subprog C_CRN2(VALEUR)
Variable Char    VALEUR()

    Call C_CRN( VALEUR )
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog AM_FLGREI(VALEUR)
Variable Integer VALEUR

    If VALEUR - 1
        Actzo [M:TRA5]AMTREI
        Actzo [M:TRA5]BAN
        Actzo [M:TRA5]BICCOD
        Actzo [M:TRA5]IBACOD
        Actzo [M:TRA5]FLGREI2 : Call AM_FLGREI2( [M:TRA5]FLGREI2 )
    Else
        Grizo [M:TRA5]AMTREI
        Grizo [M:TRA5]BAN
        Grizo [M:TRA5]BICCOD
        Grizo [M:TRA5]IBACOD
        Grizo [M:TRA5]FLGREI2 : Call AM_FLGREI2( VALEUR )
    Endif
  End

Subprog AM_FLGREI2(VALEUR)
Variable Integer VALEUR

  If VALEUR - 1
      Actzo [M:TRA5]AMTREI2
      Actzo [M:TRA5]BAN2
      Actzo [M:TRA5]BICCOD2
      Actzo [M:TRA5]IBACOD2
  Else
      Grizo [M:TRA5]AMTREI2
      Grizo [M:TRA5]BAN2
      Grizo [M:TRA5]BICCOD2
      Grizo [M:TRA5]IBACOD2
  Endif
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog AM_AMT(VALEUR)
Variable Decimal VALEUR

    [M:TRA5]AMT( nolign - 1 )= VALEUR
    [M:TRA5]AMTTOT = sum( [M:TRA5]AMT(0..( [M:TRA5]NBLIG ) ) )
    Affzo [M:TRA5]AMTTOT
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog C_BAN(VALEUR)
Variable Char VALEUR()
    Char LECOMP(255)

    If clalev([BAN])=0 : Local File BANK [BAN] : Endif

    If [M:TRG0]GRP <> ""
        Call PARAM( [M:TRG0]GRP, "VATLECMP", LECOMP ) From ADOVAL
        If LECOMP = ""
            GMESSAGE = mess(318,107,1) # "This is not a company's bank."
            mkstat = 2
        Endif
        Filter [F:BAN] Where BAN = VALEUR and CPY = LECOMP
    Else
        Filter [F:BAN] Where BAN = VALEUR and CPY = [M:TRG0]CPY
    Endif
    Read [F:BAN] First
    If fstat
        GMESSAGE = mess(318,107,1) # "This is not a company's bank."
        mkstat = 2
    Endif
    Filter [F:BAN] # Good housekeeping ;-)
End

Subprog C_BAN2(VALEUR)
Variable Char VALEUR()

    Call C_BAN( VALEUR )
End



# ###############################################################################################################
# ##########
# ########## ...
# ##########
# ###############################################################################################################

Subprog AM_BAN(VALEUR)
Variable Char VALEUR()

    # Update BIC and IBAN
    #
    # Note: The record is already positioned on the correct bank record in C_BAN().
    #
    [M:TRA5]BANDES = [F:BAN]DES
    [M:TRA5]BICCOD = [F:BAN]BICCOD
    [M:TRA5]IBACOD = [F:BAN]IBACOD
    Affzo [M:TRA5]BICCOD, IBACOD
End

Subprog AM_BAN2(VALEUR)
Variable Char VALEUR()

    # Update BIC and IBAN
    #
    # Note: The record is already positioned on the correct bank record in C_BAN2().
    #
    [M:TRA5]BANDES2 = [F:BAN]DES
    [M:TRA5]BICCOD2 = [F:BAN]BICCOD
    [M:TRA5]IBACOD2 = [F:BAN]IBACOD
    Affzo [M:TRA5]BICCOD2, IBACOD2
End

Subprog IB_NBLIG
    [M:TRA5]AMTTOT = sum( [M:TRA5]AMT(0..( [M:TRA5]NBLIG ) ) )
    Affzo [M:TRA5]AMTTOT
End
