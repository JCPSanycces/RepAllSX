# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "TRA", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################



#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "LECTURE"
            Gosub LECTURE
        When "EXEBOUT"
            If BOUT = "4" # RECALL button
                [M:TRA5]AMTTOT = sum( [M:TRA5]AMT(0..( [M:TRA5]NBLIG - 1 ) ) )
                Affzo [M:TRA5]AMTTOT
            Endif
        When "SEL_TABLE"
            If COUZON = "BAN"
                OBJET = "BAN"
                If [M:TRG0]GRP <> ""
                    CRITERE = "CPY='" + [M:TRG0]GRP + "'"
                Else
                    CRITERE = "CPY='" + [M:TRG0]CPY + "'"
                Endif
            Endif
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  LECTURE
#*
#* Purpose:    ...
#*
#*! #############################################################################################################

$LECTURE
    Grizo [M:TRA5]AMTTRN
    Grizo [M:TRA5]CRN
    Grizo [M:TRA5]TAXCEN
    Grizo [M:TRA5]FLGTRN2
    Grizo [M:TRA5]AMTTRN2
    Grizo [M:TRA5]CRN2
    Grizo [M:TRA5]TAXCEN2

    Grizo [M:TRA5]AMTREI
    Grizo [M:TRA5]BAN
    Grizo [M:TRA5]FLGREI2
    Grizo [M:TRA5]AMTREI2
    Grizo [M:TRA5]BAN2
Return



