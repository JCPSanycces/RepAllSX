#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# ACTION - PJMACTAFCP
# Duplication of Project
##########################################################################################################
$ACTION
  Case ACTION
    When "DEBUT"     :  Gosub DEBUT
    When "FIN"       :  Gosub FIN
    When "OK"        :  Gosub OK
    When "OUVRE"     :  Gosub OUVRE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Instance GZINSPJMCOP Using C_OPPOR        # project class
Global Instance GZTECPJMCOP Using C_PJMACOPY     # project copy (instance) class

  NAVIG = GACTION
  GOK = 1
Return

##########################################################################################################
$DEBUT
Local Char SPJMCOPYOPPNUM(GLONPIM)
Local Integer IPJMCOPY

  # PARAM(1) => Project code (could be empty)
  # PARAM(2) => Facility code (I don't know why this information is given as parameter ?)
  # PARAM(3) => Project status (I don't know why this information is given as parameter ?)
  # PARAM(4) => Silence (I don't know why this information is given as parameter ?)
  Effzo [M:PJMAC0]
  Effzo [M:PJMAC0A]          # Issue X3-99916 - 2018-07-16 by FGR
  Effzo [M:PJMAC1]
  Effzo [M:PJMAC2]
  Effzo [M:PJMAC3]
  IPJMCOPY = [V]CST_ANO
  [M:PJMAC0]CRMFLG = [V]CST_ANO
  Call MANAGE_CRMFLG([M:PJMAC0]CRMFLG)
  SPJMCOPYOPPNUM = PARAM(1)
  Call INIT_ENVIRONMENT(SPJMCOPYOPPNUM)
  If GERR = 1 Then
    FIN = 1
    Return
  Endif
  If GZINSPJMCOP <> null Then
    [M:PJMAC0]OPPNUM = GZINSPJMCOP.OPPNUM
    [M:PJMAC0]SALFCY = GZINSPJMCOP.SALFCY
    Diszo [M:PJMAC0]OPPNUM
  Endif
Return

##########################################################################################################
$FIN
  If IPJMCOPY = [V]CST_ANO Then
    GBIDC1 = [M:PJMAC0]OPPNUM
  Else
    GBIDC1 = [M:PJMAC0]DESTAFF
  Endif
  If GZINSPJMCOP <> null Then
    FreeGroup GZINSPJMCOP
  Endif
  Kill GZINSPJMCOP
  If GZTECPJMCOP <> null Then
    FreeGroup GZTECPJMCOP
  Endif
  Kill GZTECPJMCOP
  If dim(GPIMLSTFCY) > 0 Then
    Kill GPIMLSTFCY
  Endif
Return

##########################################################################################################
$OK
Local Integer MY_STATUS
Local Char NEWSEQNUM(GLONPIM)
Local Char SLOGFILE(250)
Local Char ZMESS(250)

  GZTECPJMCOP.TCHREPDIECCE = func GET_IANSWER_CCE()
  # -------------------------
  Call SCREEN_CLASS_TO_COPY()
  If GOK = 0 Then
    Return
  Endif
  # -------------------------
  Raz SLOGFILE
  If [M:PJMAC0]CRMFLG = [V]CST_AYES Then
    Call OUVRE_TRACE(mess(533,2260,1)) From LECFIC
    ZMESS = mess(534,2260,1) - [M:PJMAC0]CRMOPP
    Call ECR_TRACE (ZMESS,0) From GESECRAN
    ZMESS = mess(535,2260,1)
    Call ECR_TRACE (ZMESS,0) From GESECRAN
    Call PRTSCR("PJMACOPY0", "PJMAC0", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY0A","PJMAC0A", AVOID.ACHAR, 0, 1) From ATRTX3         # Issue X3-99916 - 2018-07-16 by FGR
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY2", "PJMAC2", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY1", "PJMAC1", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY3", "PJMAC3", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    SLOGFILE = GTRACE
    Call FERME_TRACE From LECFIC
  Else
    Call OUVRE_TRACE(mess(536,2260,1)) From LECFIC
    ZMESS = mess(537,2260,1) - GZTECPJMCOP.OPPNUM
    Call ECR_TRACE (ZMESS,0) From GESECRAN
    ZMESS = mess(538,2260,1) - GZTECPJMCOP.DESTAFF
    Call ECR_TRACE (ZMESS,0) From GESECRAN
    ZMESS = mess(539,2260,1)
    Call ECR_TRACE (ZMESS,0) From GESECRAN
    Call PRTSCR("PJMACOPY0", "PJMAC0", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY0A","PJMAC0A", AVOID.ACHAR, 0, 1) From ATRTX3         # Issue X3-99916 - 2018-07-16 by FGR
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY2", "PJMAC2", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY1", "PJMAC1", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    Call PRTSCR("PJMACOPY3", "PJMAC3", AVOID.ACHAR, 0, 1) From ATRTX3
    Call ECR_TRACE (string$(80,"-"),0) From GESECRAN
    SLOGFILE = GTRACE
    Call FERME_TRACE From LECFIC
  Endif
  # ------------------------------------------------------
  [L]MY_STATUS = fmet GZINSPJMCOP.PJM_COPY(GZTECPJMCOP, NEWSEQNUM, SLOGFILE)
  # ------------------------------------------------------
  If [L]MY_STATUS < [V]CST_AERROR Then
    IPJMCOPY = [V]CST_AYES
    [M:PJMAC0]DESTAFF = NEWSEQNUM
    Affzo [M:PJMAC0]DESTAFF
  Else
    IPJMCOPY = [V]CST_ANO
  Endif
  GTRACE = SLOGFILE
  Call LEC_TRACE From LECFIC
Return

##########################################################################################################
Subprog READ_PROJECT(SOPPNUM)
Value Char SOPPNUM

Local Integer MY_STATUS

  If SOPPNUM <> AVOID.ACHAR Then
    If GZINSPJMCOP <> null Then
      FreeGroup GZINSPJMCOP
    Endif
    GZINSPJMCOP = NewInstance C_OPPOR AllocGroup null
    GZINSPJMCOP.TCHTOREAD = "PJM"
    [L]MY_STATUS = fmet GZINSPJMCOP.AREAD(SOPPNUM)
    If [L]MY_STATUS >= [V]CST_AERROR Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJMCOP)
      GOK = 0
      GERR = 1
      Return
    Endif
  Else
    If GZINSPJMCOP <> null Then
      FreeGroup GZINSPJMCOP
    Endif
  Endif
End

##########################################################################################################
Subprog INIT_ENVIRONMENT(SOPP)
Value Char SOPP

Local Integer MY_STATUS

  If GZTECPJMCOP <> null Then
    FreeGroup GZTECPJMCOP
  Endif
  If SOPP <> AVOID.ACHAR Then
    Call READ_PROJECT(SOPP)
    If GERR = 1 Then
      End
    Endif
    GZTECPJMCOP = NewInstance C_PJMACOPY AllocGroup null
    [L]MY_STATUS = fmet GZTECPJMCOP.INIT_FROM_PROJECT(GZINSPJMCOP)
    If [L]MY_STATUS >= [V]CST_AERROR Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZTECPJMCOP)
      GOK = 0
      GERR = 1
      End
    Endif
    Call COPY_CLASS_TO_SCREEN()
  Endif
End

##########################################################################################################
Subprog COPY_CLASS_TO_SCREEN()

Local Integer NI
Local Integer MAX_NBLIGT
Local Integer MAX_NBLIGB

  #-------------------------------------------
  # PJMACOPY HEADER [M:PJMAC0]
  #-------------------------------------------
  [M:PJMAC0]SALFCY     = GZTECPJMCOP.SALFCY
  [M:PJMAC0]CUR        = GZINSPJMCOP.CUR
  [M:PJMAC0]OPPNUM     = GZTECPJMCOP.OPPNUM
  [M:PJMAC0]OPPDES     = GZTECPJMCOP.OPPDES
  [M:PJMAC0]OPPSTATE   = GZTECPJMCOP.OPPSTATE
  [M:PJMAC0]DESTAFF    = GZTECPJMCOP.DESTAFF
  [M:PJMAC0]DESDES     = GZTECPJMCOP.DESDES
  #-------------------------------------------
  # PJMACOPY HEADER [M:PJMAC0]
  #-------------------------------------------
  [M:PJMAC0A]TSALFCY    = GZTECPJMCOP.SALFCY     # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]TOPEDEFFCY = [M:PJMAC0A]TSALFCY     # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]TCUR       = [M:PJMAC0]CUR          # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]CHGTYP     = GZINSPJMCOP.CHGTYP     # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]DATECUR    = date$                  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  Call GET_CUR_CHANGE([M:PJMAC0A]TCUR)           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  #-------------------------------------------
  # PJMACOPY BLOCKS [M:PJMAC0A]
  #-------------------------------------------
  [M:PJMAC0A]AFFDESC   = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]AFFCOM    = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]BUDALL    = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]BLIGNES   = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now and not [V]CST_AYES
  [M:PJMAC0A]TACALL    = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]TASASSL   = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]TASOPL    = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now and not [V]CST_AYES
  [M:PJMAC0A]TASPRL    = [V]CST_ANO              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  [M:PJMAC0A]TACDUEDAT = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  [M:PJMAC0A]TACDAT    = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  [M:PJMAC0A]TASPRDAT  = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  [M:PJMAC0A]TASOPDAT  = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  [M:PJMAC0A]TASASSDAT = [V]CST_AYES             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  #-------------------------------------------
  # PJMACOPY TASK GRID [M:PJMAC2]
  #-------------------------------------------
  MAX_NBLIGT = maxtab(GZTECPJMCOP.TASK)
  If MAX_NBLIGT = 0 Then
    Diszo [M:PJMAC2]NBLIGT
  Else
    For NI = 1 To MAX_NBLIGT
      [M:PJMAC2]SELTAC(NI-1)     = GZTECPJMCOP.TASK(NI).SELTAC       #--Select Task
      [M:PJMAC2]TASCOD(NI-1)     = GZTECPJMCOP.TASK(NI).TASCOD       #--Task Code
      [M:PJMAC2]TASDES(NI-1)     = GZTECPJMCOP.TASK(NI).TASDES       #--Task Description
      [M:PJMAC2]TASNCOD(NI-1)    = GZTECPJMCOP.TASK(NI).TASNCOD      #--New Task Code
      [M:PJMAC2]TASNDES(NI-1)    = GZTECPJMCOP.TASK(NI).TASNDES      #--New Task Description
      [M:PJMAC2]TASFCY(NI-1)     = GZTECPJMCOP.TASK(NI).TASFCY       #--Task Site
      [M:PJMAC2]TASPBU(NI-1)     = GZTECPJMCOP.TASK(NI).TASPBU       #--Linked Budget
      [M:PJMAC2]TASSTATE(NI-1)   = GZTECPJMCOP.TASK(NI).TASSTATE     #--Task Status
      [M:PJMAC2]TASPAE(NI-1)     = GZTECPJMCOP.TASK(NI).TASPAE       #--Parent Task
      [M:PJMAC2]TASLINE(NI-1)    = GZTECPJMCOP.TASK(NI).TASLINE      #--Task Line
    Next NI
  Endif
  [M:PJMAC2]NBLIGT = MAX_NBLIGT
  #-------------------------------------------
  # PJMACOPY BUDGET GRID [M:PJMAC1]
  #-------------------------------------------
  MAX_NBLIGB = maxtab(GZTECPJMCOP.BUDGET)
  If MAX_NBLIGB = 0 Then
    Diszo [M:PJMAC1]NBLIGB
  Else
    For NI = 1 To MAX_NBLIGB
      [M:PJMAC1]SELBUD(NI-1)    = GZTECPJMCOP.BUDGET(NI).SELBUD
      [M:PJMAC1]PBUCOD(NI-1)    = GZTECPJMCOP.BUDGET(NI).PBUCOD
      [M:PJMAC1]PBUDES(NI-1)    = GZTECPJMCOP.BUDGET(NI).PBUDES
      [M:PJMAC1]DESTCOD(NI-1)   = GZTECPJMCOP.BUDGET(NI).DESTCOD
      [M:PJMAC1]DESTDES(NI-1)   = GZTECPJMCOP.BUDGET(NI).DESTDES
      [M:PJMAC1]PBUSTATE(NI-1)  = GZTECPJMCOP.BUDGET(NI).PBUSTATE
      [M:PJMAC1]PBUPAE(NI-1)    = GZTECPJMCOP.BUDGET(NI).PBUPAE
      [M:PJMAC1]PBUFCY(NI-1)    = GZTECPJMCOP.BUDGET(NI).PBUFCY
      [M:PJMAC1]BUDLINE(NI-1)   = GZTECPJMCOP.BUDGET(NI).BUDLINE
    Next NI
  Endif
  [M:PJMAC1]NBLIGB = MAX_NBLIGB
  #-------------------------------------------
  # PJMACOPY ADDITIONAL CRITERIA [M:PJMAC3]
  #-------------------------------------------
  [M:PJMAC3]TASPRDES    = [V]CST_AYES
  [M:PJMAC3]TASPRCOM    = [V]CST_ANO
  [M:PJMAC3]TASOPDES    = [V]CST_AYES
  [M:PJMAC3]TASOPCOM    = [V]CST_ANO
  [M:PJMAC3]TASASSDES   = [V]CST_AYES
  [M:PJMAC3]TASASSCOM   = [V]CST_ANO
  [M:PJMAC3]BUDDES      = [V]CST_AYES
  [M:PJMAC3]BUDCOM      = [V]CST_ANO
  [M:PJMAC3]BUDDAT      = [V]CST_AYES
  [M:PJMAC3]BUDLDES     = [V]CST_AYES
  [M:PJMAC3]BUDLCOM     = [V]CST_ANO
  [M:PJMAC3]TACDES      = [V]CST_AYES
  [M:PJMAC3]TACCOM      = [V]CST_ANO
  [M:PJMAC3]TACLNK      = [V]CST_ANO
  [M:PJMAC3]TASOPLNK    = [V]CST_ANO
  #
  Affzo [M:PJMAC0]1-99
  Affzo [M:PJMAC0A]1-99                # Issue X3-99916 - 2018-07-16 by FGR
  Affzo [M:PJMAC1]1-99
  Affzo [M:PJMAC2]1-99
  Affzo [M:PJMAC3]1-99
End

##########################################################################################################
Subprog SCREEN_CLASS_TO_COPY()

Local Integer NI

  #Header screen [M:PJMAC0]
  GZTECPJMCOP.OPPSTATE         = [M:PJMAC0]OPPSTATE
  GZTECPJMCOP.OPPNUM           = [M:PJMAC0]OPPNUM
  GZTECPJMCOP.SALFCY           = [M:PJMAC0A]TSALFCY        # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.OPEDEFFCY        = [M:PJMAC0A]TOPEDEFFCY     # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.CUR              = [M:PJMAC0A]TCUR           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.CHGTYP           = [M:PJMAC0A]CHGTYP         # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.DATECUR          = [M:PJMAC0A]DATECUR        # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.OPPDES           = [M:PJMAC0]OPPDES
  If [M:PJMAC0]CRMFLG          = [V]CST_AYES Then
    GZTECPJMCOP.DESTAFF        = [M:PJMAC0]CRMOPP
  Else
    GZTECPJMCOP.DESTAFF        = [M:PJMAC0]DESTAFF
  Endif
  GZTECPJMCOP.DESDES    = [M:PJMAC0]DESDES
  #-------------------------------------------
  # PJMACOPY BLOCKS [M:PJMAC0A]
  #-------------------------------------------
  GZTECPJMCOP.AFFDESC   = [M:PJMAC0A]AFFDESC               # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.AFFCOM    = [M:PJMAC0A]AFFCOM                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.TACALL    = [M:PJMAC0A]TACALL                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.TASPRL    = [M:PJMAC0A]TASPRL                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.TASOPL    = [M:PJMAC0A]TASOPL                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.TASASSL   = [M:PJMAC0A]TASASSL               # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.BUDALL    = [M:PJMAC0A]BUDALL                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.BLIGNES   = [M:PJMAC0A]BLIGNES               # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  GZTECPJMCOP.TACDUEDAT = [M:PJMAC0A]TACDUEDAT             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  GZTECPJMCOP.TACDAT    = [M:PJMAC0A]TACDAT                # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  GZTECPJMCOP.TASPRDAT  = [M:PJMAC0A]TASPRDAT              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  GZTECPJMCOP.TASOPDAT  = [M:PJMAC0A]TASOPDAT              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  GZTECPJMCOP.TASASSDAT = [M:PJMAC0A]TASASSDAT             # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC3] from now
  # ------------------------------------------------------
  #Budget screen [M:PJMAC1]
  For NI = 1 To [M:PJMAC1]NBLIGB
    GZTECPJMCOP.BUDGET(NI).PBUCOD    = [M:PJMAC1]PBUCOD(NI-1)
    GZTECPJMCOP.BUDGET(NI).SELBUD    = [M:PJMAC1]SELBUD(NI-1)
    GZTECPJMCOP.BUDGET(NI).PBUDES    = [M:PJMAC1]PBUDES(NI-1)
    GZTECPJMCOP.BUDGET(NI).DESTCOD   = [M:PJMAC1]DESTCOD(NI-1)
    GZTECPJMCOP.BUDGET(NI).DESTDES   = [M:PJMAC1]DESTDES(NI-1)
    GZTECPJMCOP.BUDGET(NI).PBUPAE    = [M:PJMAC1]PBUPAE(NI-1)
    GZTECPJMCOP.BUDGET(NI).PBUFCY    = [M:PJMAC1]PBUFCY(NI-1)
    GZTECPJMCOP.BUDGET(NI).BUDLINE   = [M:PJMAC1]BUDLINE(NI-1)
  Next NI
  # ------------------------------------------------------
  #Task screen [M:PJMC2]
  For NI = 1 To [M:PJMAC2]NBLIGT
    GZTECPJMCOP.TASK(NI).SELTAC    = [M:PJMAC2]SELTAC(NI-1)
    GZTECPJMCOP.TASK(NI).TASCOD    = [M:PJMAC2]TASCOD(NI-1)
    GZTECPJMCOP.TASK(NI).TASDES    = [M:PJMAC2]TASDES(NI-1)
    GZTECPJMCOP.TASK(NI).TASNCOD   = [M:PJMAC2]TASNCOD(NI-1)
    GZTECPJMCOP.TASK(NI).TASNDES   = [M:PJMAC2]TASNDES(NI-1)
    GZTECPJMCOP.TASK(NI).TASFCY    = [M:PJMAC2]TASFCY(NI-1)
    GZTECPJMCOP.TASK(NI).TASPAE    = [M:PJMAC2]TASPAE(NI-1)
    GZTECPJMCOP.TASK(NI).TASLINE   = [M:PJMAC2]TASLINE(NI-1)
  Next NI
  # ------------------------------------------------------
  #Additional selection criteria [M:PJMC3]
  GZTECPJMCOP.TACDES    = [M:PJMAC3]TACDES
  GZTECPJMCOP.TACCOM    = [M:PJMAC3]TACCOM
  GZTECPJMCOP.TACLNK    = [M:PJMAC3]TACLNK
  GZTECPJMCOP.TASPRDES  = [M:PJMAC3]TASPRDES
  GZTECPJMCOP.TASPRCOM  = [M:PJMAC3]TASPRCOM
  GZTECPJMCOP.TASOPLNK  = [M:PJMAC3]TASOPLNK
  GZTECPJMCOP.TASOPDES  = [M:PJMAC3]TASOPDES
  GZTECPJMCOP.TASOPCOM  = [M:PJMAC3]TASOPCOM
  GZTECPJMCOP.TASASSDES = [M:PJMAC3]TASASSDES
  GZTECPJMCOP.TASASSCOM = [M:PJMAC3]TASASSCOM
  GZTECPJMCOP.BUDDES    = [M:PJMAC3]BUDDES
  GZTECPJMCOP.BUDCOM    = [M:PJMAC3]BUDCOM
  GZTECPJMCOP.BUDDAT    = [M:PJMAC3]BUDDAT
  GZTECPJMCOP.BUDLDES   = [M:PJMAC3]BUDLDES
  GZTECPJMCOP.BUDLCOM   = [M:PJMAC3]BUDLCOM
End

##########################################################################################################
Subprog MANAGE_CRMFLG(ICRM)
Value Integer ICRM

  Raz [M:PJMAC0]CRMOPP
  If ICRM = [V]CST_AYES Then
    Grizo [M:PJMAC0]DESTAFF
    Raz [M:PJMAC0]DESDES
    Actzo [M:PJMAC0]CRMOPP
    Grizo [M:PJMAC0]DESDES
    Grizo [M:PJMAC0A]TSALFCY           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0A]TOPEDEFFCY        # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0A]TCUR              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0A]CHGTYP            # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0A]DATECUR           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  Else
    Actzo [M:PJMAC0]DESTAFF
    Actzo [M:PJMAC0]DESDES
    Actzo [M:PJMAC0A]TSALFCY           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Actzo [M:PJMAC0A]TOPEDEFFCY        # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Actzo [M:PJMAC0A]TCUR              # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Actzo [M:PJMAC0A]CHGTYP            # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Actzo [M:PJMAC0A]DATECUR           # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0]CRMOPP
    If dim([M:PJMAC0]ZOPPNUM) > 0 Then
      [M:PJMAC0]DESDES = [M:PJMAC0]ZOPPNUM
    Endif
  Endif
  Affzo [M:PJMAC0]1-99
  Affzo [M:PJMAC0A]1-99                # Issue X3-99916 - 2018-07-16 by FGR
End

##########################################################################################################
Funprog GET_IANSWER_CCE()

Local Integer NI
Local Integer BPJMFND
Local Integer L_PJTAUTCRE
Local Integer I_FCY
Local Char    L_CPY(GLONCPY)
Local Integer IANSWER
Local Integer IPIMTYP
Local Char SMESSAGE(250)

  IANSWER = 0
  If [M:PJMAC0]CRMOPP <> AVOID.ACHAR Then
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(GZINSPJMCOP.ACTX, [M:PJMAC0]DESTAFF, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
    If IPIMTYP <> 1 Then
      IANSWER = [V]CST_ANO
    Endif
  Endif
  If IANSWER = 0 Then
    # -----------------------
    Local File GDIE [DIE]
    # -----------------------
    BPJMFND = [V]CST_AFALSE
    For NI = 1 To maxtab(GZINSPJMCOP.PJM(1).CDIE)
      If GZINSPJMCOP.PJM(1).CDIE(NI) <> null and find(GZINSPJMCOP.PJM(1).CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        Call LEC_DIE(GZINSPJMCOP.PJM(1).CDIE(NI).DIE) From CPTLEC
        If [F:DIE]PJMFLG = [V]CST_AYES Then
          BPJMFND = [V]CST_ATRUE
          Break
        Endif
      Endif
    Next NI
    I_FCY = fmet GZINSPJMCOP.ACTX.ACACHE.AFCY.AGETINDEX([M:PJMAC0]SALFCY)
    If I_FCY <> [V]CST_ANOTDEFINED Then
      L_CPY = fmet GZINSPJMCOP.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJMAC0]SALFCY, "LEGCPY")
    Endif
    L_PJTAUTCRE = fmet GZINSPJMCOP.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, L_CPY, "PJTAUTCRE")
    If find(L_PJTAUTCRE,[V]CST_ANO,[V]CST_AYES) = 0 Then
      L_PJTAUTCRE = [V]CST_AYES      # Confirmation
    Endif
    If BPJMFND = [V]CST_ATRUE Then
      IANSWER = [V]CST_AYES
      If L_PJTAUTCRE = [V]CST_AYES Then
         # Confirmation message
         MSG = func ASYRFNC.MES2(mess(115,103,1), [M:PJMAC0]DESTAFF, GZINSPJMCOP.PJM(1).CDIE(NI).DIE)
         Call YESNO_CHX(MSG, mess(114,103,1), mess(2,1,1), mess(1,1,1), IANSWER) From GESECRAN
      Endif
    Endif
  Endif
End IANSWER

##########################################################################################################
Funprog GET_CUR_CHANGE(SCUR)
Variable Char SCUR

  If [M:PJMAC0]CUR = SCUR Then
    Grizo [M:PJMAC0A]CHGTYP  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Grizo [M:PJMAC0A]DATECUR # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  Else
    Actzo [M:PJMAC0A]CHGTYP  # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
    Actzo [M:PJMAC0A]DATECUR # Issue X3-99916 - 2018-07-16 by FGR : not [M:PJMAC0] from now
  Endif
End

