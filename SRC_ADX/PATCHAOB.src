#<AdxTL>@(#)12.0.0.0 $Revision$
###################################################
## Intégration d'un objet
###################################################
$AOBJET
FICHIER = "AOBJET" : ABR = "AOB"
Read [AOB]ABREV = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AOB
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
         If dim([F:AOB]CODACT)>0 & [F:AOB]CODACT>="X" & !find([F:AOB]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              [F:AOB2] = [F:AOB]
              Read [AOL]AOL0  = NOMOBJ
              Gosub TR_AOB
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          [F:AOB2] = [F:AOB]
          Read [AOL]AOL0  = NOMOBJ
          Gosub TR_AOB
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:AOB]
      Gosub TR_AOB
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_AOB
Call DEBTRANS From GLOCK

Trbegin [AOB],[AOT],[AOL]
 Delete [AOT] Where ABREV=[L]NOMOBJ
 Delete [AOL] Where ABREV=[L]NOMOBJ
 Delete [AOB] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "AOBJET"-NOMOBJ : Rollback : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AOB",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------#
#-------------------#
$TR_AOB
Call DEBTRANS From GLOCK
Trbegin [AOB]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AOB"   : Gosub AOB1
     When "AOT"   : Gosub AOB2
     When "AOL"   : Gosub AOB3
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit

## Validation de l'objet
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AOB",[F:AOB]ABREV,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
# 119695: si patch SCM, on valide toujours
If GPRODUIT<>0 | APPLI<>GDOSX3 | find([F:AOB]MODULE,1,9,10) | (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD = 2)
 Call VALID(NOMOBJ,APPLI,1,MOK) From VALOBJ
Endif
Gosub REST_OPENI From PATCH
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

#---------------------------------#

$AOB1
FICHIER = "AOBJET" : ABR = "AOB"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AOB]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
# test about code act on header Doesn't apply to a SCM environ. on root folder
# but no need to test ISFULLMOD here because test with GDOSX3 is done.
ACVOBJ = [F:AOB]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
   Read [ACV]CODACT = ACVOBJ
   If fstat | [F:ACV]FLACT<>2
        OKOBJ = 0 : Return
   Endif
Endif
If NEWOBJ
  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("AOB") From OBJDIV
   Endif
   Write [AOB]
   If fstat
        Call LOG_ERROR_DETAILS(1, "AOB",num$([F:AOB]ABREV),"") From GLOCK
   Endif
Else
  # Zones attribuées à l'utilisateur (+ toute la table AOBJLST)
  If APPLI<>GDOSX3 and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
      [F:AOB]SELCLE  = [F:AOB2]SELCLE
      [F:AOB]SELORD  = [F:AOB2]SELORD
      [F:AOB]SELTREE = [F:AOB2]SELTREE
      [F:AOB]SELCAR  = [F:AOB2]SELCAR
      If [F:AOB2]RPT1<>""
        [F:AOB]RPT1   = [F:AOB2]RPT1
      Endif
      If [F:AOB2]RPT2<>""
        [F:AOB]RPT2   = [F:AOB2]RPT2
      Endif
      [F:AOB]LIBSHO  = [F:AOB2]LIBSHO
  Endif
  [F:AOB]STA      = [F:AOB2]STA
  If dim([F:AOB]MLOCK)>0
      [F:AOB]MLOCK   = [F:AOB2]MLOCK
  Endif
  If dim([F:AOB]ARCURL)>0
      [F:AOB]ARCURL  = [F:AOB2]ARCURL
  Endif
  For B=0 To [F:AOB2]NBOPT-1
      If [F:AOB2]OPTCOD(B)>="X" & !find([F:AOB2]OPTCOD(B),[F:AOB]OPTCOD(0..[F:AOB]NBOPT-1))
            [F:AOB]OPTCOD([F:AOB]NBOPT) = [F:AOB2]OPTCOD(B)
            [F:AOB]OPTCND([F:AOB]NBOPT) = [F:AOB2]OPTCND(B)
            [F:AOB]OPTERR([F:AOB]NBOPT) = [F:AOB2]OPTERR(B)
            [F:AOB]OPTLIB([F:AOB]NBOPT) = [F:AOB2]OPTLIB(B)
            [F:AOB]NBOPT += 1
      Endif
  Next B
  # Vues
  For B=0 To [F:AOB2]NBVUE-1
      If [F:AOB2]VUEACT(B)>="X" & find([F:AOB2]VUEACT(B),ACTIV(1..NBACT))
            K = 0
            For L=0 To [F:AOB]NBVUE-1
                  If [F:AOB]VUECOD(L)=[F:AOB2]VUECOD(B) & [F:AOB]VUEABR(L)=[F:AOB2]VUEABR(B)
                      [F:AOB]VUEACT(B) = [F:AOB2]VUEACT(B) : K = 1 : Break
                  Endif
            Next L
            If !K
                  [F:AOB]VUECOD([F:AOB]NBVUE) = [F:AOB2]VUECOD(B)
                  [F:AOB]VUEABR([F:AOB]NBVUE) = [F:AOB2]VUEABR(B)
                  [F:AOB]VUEACT([F:AOB]NBVUE) = [F:AOB2]VUEACT(B)
                  [F:AOB]NBVUE += 1
            Endif
      Endif
  Next B

  If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("AOB") From OBJDIV
  Endif
  Rewrite [AOB]
  If fstat
        Call LOG_ERROR_DETAILS(2, "AOB",num$([F:AOB]ABREV),"") From GLOCK
  Endif

 # Effacement des AOT non spécifiques, et renum des autres
 LIGNUM = 0
 For [AOT]ABREV Where ABREV=[F:AOB]ABREV
  If [F:AOT]TABACT>="X" & !find([F:AOT]TABACT,ACTIV(1..NBACT))
   LIGNUM += 1
   [F:AOT]NUMLIG = LIGNUM
   Rewrite [AOT]
  Else
   Delete [AOT]
  Endif
 Next AOT
Endif
If fstat
      GOK = 0 : ER = 99 : ERFIC = "AOBJET"-NOMOBJ : Return
Endif
Return

$AOB2
FICHIER = "AOBJTAB" : ABR = "AOT"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AOB]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 Return
Endif
ACVOBJ = [F:AOT]TABACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  Return
 Endif
Endif
If NEWOBJ
 Write [AOT]
Else
 Read [AOT2]TABFIC = ABREV;[F:AOT]TABFIC;[F:AOT]TABABR
 If fstat
  LIGNUM += 1
  [F:AOT]NUMLIG = LIGNUM
  Write [AOT]
 Endif
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AOBJTAB"-NOMOBJ : Return
Endif
Return

$AOB3
FICHIER = "AOBJLST" : ABR = "AOL"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:AOB]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
If NEWOBJ
 Write [AOL]
Elsif APPLI=GDOSX3
 Rewrite [AOL]
Elsif find([F:AOB]CODACT,ACTIV(1..NBACT))
 Rewrite [AOL]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AOBJLST"-NOMOBJ : Return
Endif
Return

$ABORT
Rollback
Return

##########################################################################
Subprog MAJ_SEL(APPLI,OBJET)
Value Char APPLI
Value Char OBJET
Local Integer OK , ER
If APPLI="" or APPLI=GDOSX3 : End : Endif
Onerrgo ER
Local File =GDOSX3+".AOBJET" [GO__] , =GDOSX3+".AOBJLST" [GL__]
Local File =APPLI+".AOBJET" [AO__] , =APPLI+".AOBJLST" [AL__] , =APPLI+".ALSTRD" [AS__]
Local File =APPLI+".AFONCTION" [AF__]
Onerrgo
If ER : End : Endif
Trbegin [AL__] , [AO__]
 Read [AO__]ABREV=OBJET
 If !fstat
  Read [GO__]ABREV=OBJET
  If !fstat
   [F:AO__]SELCLE  = [F:GO__]SELCLE
   [F:AO__]SELORD  = [F:GO__]SELORD
   [F:AO__]SELTREE = [F:GO__]SELTREE
   [F:AO__]SELCAR  = [F:GO__]SELCAR
   [F:AO__]RPT1    = [F:GO__]RPT1
   [F:AO__]RPT2    = [F:GO__]RPT2
   [F:AO__]STA     = [F:GO__]STA
   [F:AO__]LIBSHO  = [F:GO__]LIBSHO
   Rewrite [AO__]
   If fstat
    Call ERREUR("AOBJET"-OBJET,2) From DOSDIC
   Endif
   OK = 1
  Endif
 Endif
 Read [AL__]AOL0=OBJET
 If !fstat
  Read [GL__]AOL0=OBJET
  If !fstat
   [F:AL__] = [GL__]
   Rewrite [AL__]
   If fstat
    Call ERREUR("AOBLST"-OBJET,2) From DOSDIC
   Endif
   OK = 1
  Endif
 Endif
 Delete [AS__] Where OBJ=OBJET
 If [F:AO__]TYPGES<>4
  Read [AF__]CODINT = "GES"+OBJET
  If !fstat
   [F:AF__]RPT1 = [F:AO__]RPT1
   [F:AF__]RPT2 = [F:AO__]RPT2
   Rewrite [AF__]
   If fstat
    Call ERREUR("AFONCTION"-OBJET,2) From DOSDIC
   Endif
  Endif
 Endif
Commit
If OK
 Call ECR_TRACE(mess(251,139,1)-OBJET,0) From GESECRAN : # Mise à jour onglet sélection objet
Endif
Close Local File
End

$ER
ER = errn
Resume

