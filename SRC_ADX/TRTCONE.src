#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################################
# Traitement d'affichage des contrats associés à une ligne de commande                     Module CRM          20 octobre 2000
##############################################################################################################################
##############################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##############################################################################################################################
$OUVRE
Global Char GSZCSENUM
Global Char GSZORD(GLONVCR)
Global Integer GIORDLIN

  #PARAM(1) = Code commande.
  #PARAM(2) = Code ligne de commande.
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
  GSZCSENUM = ""
  GSZORD = PARAM(1)
  GIORDLIN = val(PARAM(2))
Return

##############################################################################################################################
$DEFBOUT
Return

##############################################################################################################################
$SETBOUT
Return

##############################################################################################################################
$OUVRE_BOITE
Return

##############################################################################################################################
$DEBUT
Local Integer ISEMPTY

  ISEMPTY = 0
  Call LOADCSE(ISEMPTY)
  If ISEMPTY > 0 Then
    GMESSAGE = mess(336,196,1) #Il n' y a aucun contrat de service associé à cette ligne de commande.
    GERR = 2
    FIN = 1
    Return
  Endif
  [M:CONE]ORDNUM = GSZORD
  GSZCSENUM = [M:CONE]CONNUM(0)
  Affzo [M:CONE]
Return

##############################################################################################################################
$AV_CHOIX
Return

##############################################################################################################################
AP_CHOIX
Return

##############################################################################################################################
$AVANT_BOUTON
Return

##############################################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CONE]
  Kill GSZCSENUM
  Kill GSZORD
  Kill GIORDLIN
Return

##############################################################################################################################
$FIN
Return

##############################################################################################################################
$ABANDON
Return

##############################################################################################################################
$APRES_MODIF
Return

##############################################################################################################################
$BOUTON
Return
##############################################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
#########################################################################
# Chargement du tableau des contrat de service
#########################################################################
Subprog LOADCSE(EMPTY)
Variable Integer EMPTY

Local Integer IB

  IB = 0
  Raz [M:CONE]NBCSE
  Raz [M:CONE]CONNUM
  Raz [M:CONE]STRDAT
  Raz [M:CONE]ENDDAT
  Raz [M:CONE]AMT
  Raz [M:CONE]CUR
  Filter [CON] Where [F:CON]CONORI = 2 and [F:CON]CONORIVCR = GSZORD and [F:CON]CONORIVCRL = GIORDLIN Order By [F:CON]CONNUM Desc
  For [CON] Hint Key CON5
    [M:CONE]CONNUM(IB) = [F:CON]CONNUM
    [M:CONE]CONNAM(IB) = [F:CON]CONNAM
    [M:CONE]STRDAT(IB) = [F:CON]CONSTRDAT
    [M:CONE]ENDDAT(IB) = [F:CON]CONENDDAT
    [M:CONE]AMT(IB) = [F:CON]CONAMT
    [M:CONE]CUR(IB) = [F:CON]CUR
    IB += 1
  Next
  Filter [CON]
  If IB = 0 Then
    EMPTY = 1
  Else
    EMPTY = 0
    [M:CONE]NBCSE = IB
    Affzo [M:CONE]
  Endif
End
