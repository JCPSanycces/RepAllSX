#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC 
 When "TERMINE"  : Gosub FIN
Endcase
Return

$INIT
If clalev([JST]) = 0 : Local File GAJOUSTA [JST] : Endif
If clalev([JOU]) = 0 : Local File GJOURNAL [JOU] : Endif
If clalev([CPY]) = 0 : Local File COMPANY  [CPY] : Endif
Local Char TABJOU(GLONJOU)(nbrecord([JOU]))
Local Integer NBJOU,I,J
# SUBJOU updates GCURLEG. In this process GCURLEG=0
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Raz GCURLEG
Return

$CONTROLE
TMP = 1 : # Pour afficher des tempon/tempoff
Return

$FIN
TRA = 1 : # Pour lire la trace
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$EXEC
Call OUVRE_TRACE(mess(93,104,1)) From LECFIC : # Paramètrage Ouverture des journaux
Gosub FILT_JST
Filter [JST] Where evalue(CRITERE)
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Filter [JST]
Call FERME_TRACE From LECFIC
Return

$FILT_JST
CRITERE = "1=1"
If [M:JST2]ALLCPY <> 2 
 CRITERE += ' & CPY="'+[M:JST2]CPY+'"'
Endif
If [M:JST2]ALLJOU <> 2 
 CRITERE += ' & JOU="'+[M:JST2]JOU+'"'
Endif
If [M:JST2]ALLTYPJOU <> 2 
 Gosub REMPLIT_JOU
 CRITERE += ' & find([F:JST]JOU,TABJOU(0..NBJOU))'
Endif
Return

$REMPLIT_JOU
Filter [JOU] Where TYP = [M:JST2]TYPJOU
NBJOU = 0
For [JOU]JOU0(1)
 TABJOU(NBJOU) = [F:JOU]JOU
 NBJOU +=1
Next
Filter [JOU]
Return

$TR_EXEC
Local Char TABJOU4TRACE (GLONJOU)(nbrecord([JOU]))
Local Char TABCPY4TRACE (GLONCPY)(nbrecord([CPY]))
GOK = 1
I=0
J=0
# Périodes du ... au ...
Call ECR_TRACE(mess(12,101,1)-mess(40,101,1)-format$("D:"+GFMDAT,[M:JST2]OPGSTRDAT)-mess(41,101,1)-format$("D:"+GFMDAT,[M:JST2]OPGENDDAT)-":",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 

Trbegin [JST]
 ## Boucle sur JST avec readlock ET maj des champs OPGSTRDAT ET OPGENDDAT
 For [JST]JST0
  Readlock [JST]JST0 = [F:JST]CPY;[F:JST]JOU
  If fstat=1
   GOK = -1 : GLOCK = "$GAJOUSTA"-[F:JST]CPY-[F:JST]JOU : Break
  Endif
  If !fstat
   [F:JST]OPGSTRDAT = [M:JST2]OPGSTRDAT
   [F:JST]OPGENDDAT = [M:JST2]OPGENDDAT
   [F:JST]UPDUSR    = GUSER
   [F:JST]UPDDAT    = date$
   Rewrite [JST]
   If fstat
    GOK=0 : Call FSTA("JST") From GLOCK : Break
   Endif
   If !find([F:JST]JOU,TABJOU4TRACE(0..nbrecord([JOU])-1)) & I < nbrecord([JOU])
    TABJOU4TRACE(I)=[F:JST]JOU
    I+=1
   Endif
   If !find([F:JST]CPY,TABCPY4TRACE(0..nbrecord([CPY])-1)) & J < nbrecord([CPY])
    TABCPY4TRACE(J)=[F:JST]CPY
    J+=1
   Endif
  Endif
 Next
 If GOK<0   : Goto ROLL_EXEC
 Elsif !GOK : Goto AB_EXEC
 Endif
 I=0
 While I<nbrecord([JOU]) & TABJOU4TRACE(I)<>""
  Call ECR_TRACE(mess(94,104,1)-TABJOU4TRACE(I)-":",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
  I+=1
  J=0
  While J<nbrecord([CPY]) & TABCPY4TRACE(J)<>""
   Call ECR_TRACE("Société"-":"-TABCPY4TRACE(J),0) From GESECRAN
   J+=1
  Wend
  Call ECR_TRACE("",0) From GESECRAN  
 Wend
Commit
Return

$AB_EXEC
Rollback
Return

$ROLL_EXEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXEC : Endif
Return


######################################################################################
## Etiquette du masque [JST2]
######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 Effzo CPY : Grizo CPY
Else
 Actzo CPY
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If ALLCPY = 2
 mkstat = 1 : End
Endif
End

Subprog C_ALLTYPJOU(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 [M]TYPJOU=0 : Grizo TYPJOU
Else
 [M]TYPJOU = [M:JOU1]TYP : Actzo TYPJOU
Endif
End

Subprog AS_TYPJOU(VALEUR)
Variable Integer VALEUR
If ALLTYPJOU = 2
 mkstat = 1 : End
Else
 VALEUR = [M:JOU1]TYP
Endif
End

Subprog C_ALLJOU(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
 [M]JOU = "" : Grizo JOU
Else
 [M]JOU = [M:JOU0]JOU : Actzo JOU
Endif
End

Subprog AS_JOU(VALEUR)
Variable Char    VALEUR()
# GCURLEG - utile pour la sélection SELJOU
If [M]ALLCPY=2
 Raz GCURLEG 
Else
 GCURLEG = [F:CPY]LEG
Endif
If ALLJOU = 2
 mkstat = 1 : End
Endif
End

Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
If [M:JST2]ALLJOU<>2 & [M:JST2]ALLTYPJOU<>2
 Filter [JOU] Where JOU=VALEUR
 For [JOU]JOU0
  If [F:JOU]TYP=[M:JST2]TYPJOU
   OK=1: Break 
  Endif
 Next
 Filter [JOU]
 If !OK
  # Ce journal n'est pas de type
  GMESSAGE=mess(91,104,1)-mess([M:JST2]TYPJOU,613,1)
  mkstat = 2 : End
 Endif
 Call CONTEXE([F:JOU]ACS) From CPTSUB
Endif
End


