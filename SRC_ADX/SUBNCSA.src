#<AdxTL>@(#)0.0.0.0 $Revision$ Object management NCSA
######################################################################################
## Section automatically added (Object NCSA) 21/11/2017 12:02:58 (YARAM)
######################################################################################
# Issue X3-64604 : Redevelop Non Conformance Actions for corrective plans in Hybrid mode
# Issue X3-94378 - 2018-06-06 by JUSYN : DB structure changes to seperate NCS: WNCSACTION to WPLANACT; C_CCMACTION to C_PLANACT
#                                        CCMACT to PLAACT IN WHOLE CODE
# Issue X3-105283 - 2018-08-29 by BAKHA : Local menus changed to misc table for transaction type and actions

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "FERME"     : Gosub FERME
 When "INICRE"    : Gosub INICRE
 When "CREATION"  : Gosub CREATION
 When "APRES_CRE" : Gosub APRES_CRE
 When "LIENS"     : Gosub LIENS
 When "MODIF"     : Gosub MODIF
 When "APRES_MOD" : Gosub APRES_MOD
 When "SETBOUT"   : Gosub SETBOUT
 When "ABANDON"   : Gosub ABANDON
 When "FILTRE"    : Gosub FILTRE
 When "AV_ANNULE" : Gosub AV_ANNULE
 When "ANNULE"    : Gosub ANNULE
 When "SEL_TABLE" : Gosub SEL_TABLE   # Issue X3-69118 - 2018-01-19 by JUSYN : Automatic table selection for actions.
 When Default
Endcase
Return

$OUVRE
ANOWRITE=1
Local Integer MY_STATUS
Global Instance WPLANACT Using C_PLANACT
Return

$RAZCRE
  If(WPLANACT <> null) : FreeGroup WPLANACT : Endif
  WPLANACT = NewInstance C_PLANACT AllocGroup null
  [L]MY_STATUS = fmet WPLANACT.AINIT()
  If [L]MY_STATUS >= [V]CST_AERROR
    GMESSAGE = func LCCLIB.MAXMSG(WPLANACT)
    If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
    Endif
  Endif
  SetInstance [M:NCSA] With WPLANACT
  [M:NCSA]ACTIONID = ""
  [M:NCSA]TRANACTION = "" # X3-105283
  [M:NCSA]TRANTYPE = ""   # X3-105283
  Affzo [M:NCSA]
Return

$FERME
If(WPLANACT <> null) : FreeGroup WPLANACT : Endif
Kill WPLANACT
Return

$INICRE
Return

$CREATION
If(WPLANACT <> null) : FreeGroup WPLANACT : Endif
WPLANACT = NewInstance C_PLANACT AllocGroup null
SetInstance WPLANACT With [M:NCSA]
[L]MY_STATUS = fmet WPLANACT.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
  GMESSAGE = func LCCLIB.MAXMSG(WPLANACT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
SetInstance [F:PLAACT] With WPLANACT
Gosub LIENS
Return

$APRES_CRE
Gosub RELIT From GOBJSUB
Return

$LIENS
  If(WPLANACT <> null) : FreeGroup WPLANACT : Endif
  WPLANACT = NewInstance C_PLANACT AllocGroup null
  WPLANACT.ACTIONID = [M:NCSA]ACTIONID
  [L]MY_STATUS = fmet WPLANACT.AREAD([M:NCSA]ACTIONID)
  If [L]MY_STATUS >= [V]CST_AERROR
    GMESSAGE = func LCCLIB.MAXMSG(WPLANACT)
    If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
    Endif
  Endif
  SetInstance [M:NCSA] With WPLANACT
  Affzo [M:NCSA]
Return

$MODIF
If(WPLANACT <> null) : FreeGroup WPLANACT : Endif
WPLANACT = NewInstance C_PLANACT AllocGroup null
SetInstance WPLANACT With [M:NCSA]
[L]MY_STATUS = fmet WPLANACT.AUPDATE()
If [L]MY_STATUS >= [V]CST_AERROR
  GMESSAGE = func LCCLIB.MAXMSG(WPLANACT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
SetInstance [M:NCSA] With WPLANACT
Return

$APRES_MOD
Gosub RELIT From GOBJSUB
Return

$SETBOUT
Call VIREBOUT(CHAINE,"D") From GOBJET
Return

$ABANDON
If GREP="C" & BOUT="A"
  Raz [M:NCSA]
  Actzo [NCSA]
Endif
Return

$FILTRE
# Issue X3-69118 - 2018-01-24 by JUSYN : Filter for GESNCSP
If GFONCTION = "GESNCSP"
    FILTSUP = "[F:PLAACT]TRANTYPE = [M:NCSP1]TRANTYPE(nolign-1)"
Endif
Return

$AV_ANNULE
ANOWRITE = 1
Return

$ANNULE
If(WPLANACT <> null)
  MY_STATUS = fmet WPLANACT.ADELETE()
  If [L]MY_STATUS >= [V]CST_AERROR
    GMESSAGE = func LCCLIB.MAXMSG(WPLANACT)
    If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
    Endif
  Endif
Endif
Return

######################################################################################
# Issue X3-69118 - 2018-01-19 by JUSYN : Automatic table selection for actions.
$SEL_TABLE
Case TABLE
    When "NCSACHOICE"     : Gosub SEL_NCSA
Endcase
Return

$SEL_NCSA
    OBJET = "NCSA"
Return
# End issue X3-69118
######################################################################################

