$ON_CCECRE
Onevent INIT_AREA Call D_CCECRE(zc) From W1DIE1
Onevent CONTROL Call C_CCECRE(zc) From W1DIE1
Onevent BEFORE_INPUT Call AS_CCECRE(zc) From W1DIE1
Onevent AFTER_CHANGE Gosub AMM_CCECRE From W1DIE1
Return

Subprog D_CCECRE(VALEUR)
Variable Char    VALEUR()
If varinit([M]CCECRE,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"326","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CCECRE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CCECRE(zc) From W1DIE1
Onkey 144 Titled GBOUTP Call P_CCECRE(zc) From W1DIE1
Onkey 146 Titled GBOUTA Call SA_CCECRE(zc) From W1DIE1
Gosub _AFF
End

Subprog C_CCECRE(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"326","") From SUBADI
If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"326",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
 If !mkstat
  ## Action STD
  Call C_CCECRE(VALEUR) From SUBDIE
  If mkstat : GERR = 1 : GZONE = "CCECRE" : GZNUM = 29369 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CCECRE
Call AM_CCECRE(zc)
If !mkstat & GOBJET
 zoncou = "CCECRE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CCECRE(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCCECRE)")>indice
 [M]CCECRE(indice) = VALEUR
 Affzo ZCCECRE(indice)
Endif
Gosub _AFF
End

Subprog S_CCECRE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "326"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CCECRE(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "326"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CCECRE(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "326"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCCECRE
Onevent BEFORE_AREA Gosub AV_ZCCECRE From W1DIE1
Return

$AV_ZCCECRE
Call LECTEXTRA(zc,"ATABDIV","LNGDES","326",num$([M]CCECRE(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_EXECUTE
Onevent BEFORE_INPUT Call AS_EXECUTE(zc) From W1DIE1
Onevent INIT_AREA Call D_EXECUTE(zc) From W1DIE1
Return

Subprog D_EXECUTE(VALEUR)
Variable Char    VALEUR()
If varinit([M]EXECUTE,indice)=0
 VALEUR = 258
Endif
Gosub _AFF
End

Subprog AS_EXECUTE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(42422,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_EXECUTE(zc) From W1DIE1
Gosub _AFF
End

Subprog CL_EXECUTE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TRTDIEEXE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTDIEEXE"
 PARMSK(1) = [M:DIE0]DIE
 PARMSK(2) = [M:DIE1]CCECRE
 Call TRAITE_CHAR(VALEUR,PARMSK,"","TRTDIEDEF","DDIEDEF",3,"XYTRTDIEDEF") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


