Subprog C_CCEFMT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CCEFMT" : GZNUM = 29368 : Endif
If !mkstat
 ## Action STD
 Call C_CCEFMT(VALEUR) From SUBDIE
 If mkstat : GERR = 1 : GZONE = "CCEFMT" : GZNUM = 29368 : Endif
Endif
Gosub _AFF
End

