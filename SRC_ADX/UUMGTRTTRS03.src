#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRS03                              Module   A/P-A/R Accounting  #
#                                                                        #
#                    Migration Process                                   #
#                                                                        #
#      Flow for Paymenth                                                 #
#                                                                        #
#            PAYMENTH/PAYMENTHD/PAYMENTHA                                #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   PAYMENTH  : CPY;NUM                                                  #
#   PAYMENTD  : CPY;NUM;LIN                                              #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   PAYMENTH  : NUM                                                      #
#   PAYMENTD  : NUM;LIN                                                  #
#   PAYMENTA  : NUM;LIN;LINANA                                           #
#                                                                        #
##########################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRS03") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRS03(DOSSIER)
  Call MAJ_UUMGTRTTRS03(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
Subprog RAZ_UUMGTRTTRS03(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(2)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMPYHM,WNAMPYDM,WNAMPYAM
Call MIGTABNAME (DOSSIER,"PAYMENTH",WNAMPYHM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"PAYMENTD",WNAMPYDM,ERR) From TRTMIG : If ERR : End : Endif
Call MIGTABNAME (DOSSIER,"PAYMENTA",WNAMPYAM,ERR) From TRTMIG : If ERR : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPYHM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMPYDM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif
If filinfo(filpath("FIL",WNAMPYAM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"PAYMENTH",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PAYMENTD",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PAYMENTA",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRS03",ERR) From TRTMIG

End

########################################################################
Subprog MAJ_UUMGTRTTRS03(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(2)<>2
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMPYHM,WNAMPYDM,WNAMPYAM
Call MIGTABNAME (DOSSIER,"PAYMENTH",WNAMPYHM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"PAYMENTD",WNAMPYDM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",7,ERR) From TRTMIG : End : Endif
Call MIGTABNAME (DOSSIER,"PAYMENTA",WNAMPYAM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed Files...  -----#
If filinfo(filpath("FIL",WNAMPYHM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMPYDM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",3,ERR) From TRTMIG : End
Endif
If filinfo(filpath("FIL",WNAMPYAM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGTRTTRS03 Payment Process : Update PAYMENTH/PAYMENTD/PAYMENTA") From DOSSUB
Call ECR_TRACE("UUMGTRTTRS03 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"PAYMENTH",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PAYMENTD",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PAYMENTA",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:PYH]) = 0 :  Local File =DOSSIER+".PAYMENTH"  [PYH]   : Endif      # Paymenth Header
If clalev([F:PYD]) = 0 :  Local File =DOSSIER+".PAYMENTD"  [PYD]   : Endif      # Paymenth Line
If clalev([F:PYA]) = 0 :  Local File =DOSSIER+".PAYMENTA"  [PYA]   : Endif      # Analytical Paymenth Line

# X3 Renamed File
If clalev([F:PYHM]) = 0 :  Local File =DOSSIER+"."+WNAMPYHM  [PYHM]  : Endif    # Paymenth Header
If clalev([F:PYDM]) = 0 :  Local File =DOSSIER+"."+WNAMPYDM  [PYDM]  : Endif    # Paymenth Line
If clalev([F:PYAM]) = 0 :  Local File =DOSSIER+"."+WNAMPYAM  [PYAM]  : Endif    # Analytical Paymenth Line

# X3 Commun File
Gosub OPEN_FILE From UUMGTRTCPT00

#-----  Declaration of Variables
Gosub DECLARE From UUMGTRTCPT00

# Variables to manage Flush instruction
Local Char WTAB_PYH (100) (adxwrb)
Local Char WTAB_PYD (100) (adxwrb)
Local Char WTAB_PYA (100) (adxwrb)
Local Shortint WCPT_PYH,WCPT_PYD,WCPT_PYA

# Variables to Handle Loops Ruptures
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Variables linked to the migration process
Local Integer ACCNUM_IAS, NBESSAI, STAT
Local Char    NUM_IAS
Local Char    MESSA(80), GMESSAGE(80)

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRS03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(3))

#-----  Link of Head Table & Line Table (except Analytic, including in For)
#-----  We don't have the line number in the key !
Link [PYDM] With [PYHM]PYH0~=[F:PYDM]NUM
&    As [LNK]
&    Order By Key CLE = [F:PYHM]CPY;[F:PYHM]NUM


# EP to add a criteria in the "where"
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRS03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRS03
Raz NB

If STOP = 1
 STOP = 2
 CRITERE = "[F:PYHM]CPY='"+TABMIGKEY(1)+"' & [F:PYHM]NUM>'"+TABMIGKEY(2)+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:PYHM]CPY>'"+TABMIGKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [PYH],[PYD],[PYA]
GOK = 1

For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

 # By company - Initialization of Variables linked to the Account Core Model
 [L]COMPANY = [F:PYHM]CPY
 Gosub INI_CPY From UUMGTRTCPT00
 If !GOK : Break : Endif

 For [LNK]CLE(2)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRS03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # Update PAYMENTH Table - Head of Paymenth
  Gosub MAJ30_PYH
  If GOK<1 : Break 2 : Endif

  For [LNK]CLE

   # Update PAYMENTD Table - Generals Lines of Paymenth
   Gosub MAJ30_PYD
   If !GOK : Break 3 : Endif
  Next

  # Update PAYMENTA Table - Analyticals Lines of Paymenth -  (Only DIE Field = same all records)
  Gosub MAJ30_PYA
  If !GOK : Break 2 : Endif

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1)= [F:PYHM]CPY
   TABMIGKEY(2)= [F:PYHM]NUM
   STOP=1
   Break 2
  Endif
 $SUITE_BOUCLE
 Next
Next

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRS03",7,ERR) From TRTMIG : #7=Erreur
Else
 Flush [F:PYH]
 If fstat
  Call ECR_TRACE("File PAYMENTH, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PYH_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:PYD]
 If fstat
  Call ECR_TRACE("File PAYMENTD, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PYD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 Flush [F:PYA]
 If fstat
  Call ECR_TRACE("File PAYMENTA, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub PYA_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
  TABMIGKEY(3)=num$(STOP)
 Else
  Raz TABMIGKEY
 Endif
 Call MIGSTKKEY(DOSSIER,"UUMGTRTTRS03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRS03",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRS03
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PYH], [PYD], [PYA]
Close Local File [PYHM], [PYDM], [PYAM]
Close Local File [GCM], [LED], [CPY]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"PAYMENTH",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PAYMENTD",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PAYMENTA",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRS03") From TRTMIG
Call ECR_TIME("UUMGTRTTRS03 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


#############################################################################################################
$MAJ30_PYH
#--- Transclass
#Raz [PYH]  # expensive... must RAZ new V6 fields
[PYH] = [PYHM]


#--- New fields's assignation : FIY/PER/COA
#       Update FIY/PER Fields on Post-Migration UPOSMIGCOM01 Process
[F:PYH]COA = [L]COAGEN

Gosub WRI_PYH
Return


#############################################################################################################
$MAJ30_PYD
#--- Transclass
#Raz [PYD]  # expensive... must RAZ new V6 fields
[F:PYD] = [F:PYDM]

#--- New fields's assignation : LED/COA/ACC
For IREF=1 To dim([F:GCM]LED)
 If [F:GCM]LED(IREF-1)<>""
  [F:PYD]LED(IREF-1) = [F:GCM]LED(IREF-1)
  If find(IREF,1,2,3)
   If [F:PYD]LED(IREF-1)=LEDGEN
    [F:PYD]COA(IREF-1) = COAGEN
    [F:PYD]ACC(IREF-1) = [F:PYDM]ACCLIN
   Elsif [F:PYD]LED(IREF-1)=LEDANA
    [F:PYD]COA(IREF-1) = COAANA
    [F:PYD]ACC(IREF-1) = [F:PYDM]CNA
   Elsif [F:PYD]LED(IREF-1)=LEDIAS
    [F:PYD]COA(IREF-1) = COAIAS
   Endif
  Else # useful to delete intruction RAZ
   [F:PYD]COA(IREF-1) = ""
   [F:PYD]ACC(IREF-1) = ""
  Endif
 Else # useful to delete intruction RAZ
  [F:PYD]COA(IREF-1) = ""
  [F:PYD]ACC(IREF-1) = ""
 Endif
Next
Gosub WRI_PYD
Return

#############################################################################################################
$MAJ30_PYA
#--- Reading of the Analytics Lines
For [PYAM]PYA0 Where NUM=[F:PYDM]NUM #& LIN=[F:PYDM]LIN

 #--- Transclass
 #Raz [F:PYA] # expensive... must RAZ new V6 fields
 [F:PYA] = [F:PYAM]

 For AXE=1 To dim([F:PYA]DIE)
  If AXE<10
   If [L]AXEA(AXE)<>""
    [F:PYA]DIE(AXE-1) = [L]AXEA(AXE)
   Elsif [L]AXEI(AXE-NBAAXE)<>""
    [F:PYA]DIE(AXE-1) = [L]AXEI(AXE-NBAAXE)
   Else  # useful to delete intruction RAZ
    [F:PYA]DIE(AXE-1) = ""
   Endif
  Else  # useful to delete intruction RAZ
   [F:PYA]DIE(AXE-1) = ""
  Endif
 Next

 Gosub WRI_PYA
 If GOK<1 : Break : Endif
Next
Return


# Write Instruction
$WRI_PYH
# To Save reference
Gosub PYH_STK
WriteB [F:PYH]
If fstat
 Call ECR_TRACE("File PAYMENTH, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PYH_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_PYD
# To Save reference
Gosub PYD_STK
WriteB [F:PYD]
If fstat
 Call ECR_TRACE("File PAYMENTD, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PYD_ERRTRA
 GOK=0 : Return
Endif
Return

$WRI_PYA
# To Save reference
Gosub PYA_STK
WriteB [F:PYA]
If fstat
 Call ECR_TRACE("File PAYMENTA, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub PYA_ERRTRA
 GOK=0 : Return
Endif
Return

##############################################################################################
$PYH_STK
Call STK (WTAB_PYH,WCPT_PYH,[F:PYH]NUM) From TRTMIG
Return
$PYD_STK
Call STK (WTAB_PYD,WCPT_PYD,[F:PYD]NUM-'/'-num$([F:PYD]LIN)) From TRTMIG
Return
$PYA_STK
Call STK (WTAB_PYA,WCPT_PYA,[F:PYA]NUM-'/'-num$([F:PYA]LIN)-'/'-num$([F:PYA]LINANA)) From TRTMIG
Return
##############################################################################################
$PYH_ERRTRA
Call ERRTRA (WTAB_PYH,WCPT_PYH,"File PAYMENTH(NUM)=") From TRTMIG
Return
$PYD_ERRTRA
Call ERRTRA (WTAB_PYD,WCPT_PYD,"File PAYMENTD(NUM/LIN)=") From TRTMIG
Return
$PYA_ERRTRA
Call ERRTRA (WTAB_PYA,WCPT_PYA,"File PAYMENTA(NUM/LIN/LINANA)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRS03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRS03(APPLI)
End

