#<AdxTL>@(#)4.0.0.0 $Revision$
##############################################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

##############################################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()

Local Integer IMAX
Local Integer ICOUNT
Local Integer IAFFOK
Local Char SZMESS

  #----------------------------------------------------------------
  #   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
  #   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
  #----------------------------------------------------------------
  Gosub OUVRE 
  If GERREUR Then
    GERREUR = 0
    End
  Endif 
  Gosub DECLARE 
  Raz WNUMLIG 
  [L]CRITERE  = "1=1"
  [L]CRITERE1 = "& 1=1"
  [L]CRITERE2 = "& 1=1"
  [L]CRITERE3 = "& 1=1"
  [L]CRITERE4 = "& 1=1"
  For I = 1 To NBPAR
    J = instr(1,[L]PARAMETRE(I),"=")
    If J Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
        When "X3ETA"           : [L]ETAT = [L]VALEUR
        When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
        When "numedt"          : [L]PARAMETRE(I) = "numedt=" + num$([L]NUMREQ)
        When "cur"             : [L]SZCURDES = [L]VALEUR
        When "clo"             : [L]ICLOVAL = val([L]VALEUR)
     Endcase
   Endif
  Next
  SZMESS = mess(392,196,1)  #Préparation des données
  If !GINTRA Then
    IMAX = nbrecord([F:OPP])
    IMAX += nbrecord([F:CMG])
    IMAX += nbrecord([F:OMM])
    IMAX += nbrecord([F:OMP])
    IMAX += nbrecord([F:OMN])
    IMAX += nbrecord([F:OMT])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN
  Endif
  Gosub TRT_CMG
  Gosub TRT_OMM  
  Gosub TRT_OMP
  Gosub TRT_OMN 
  Gosub TRT_OMT
  If !GINTRA Then
    Call FERME_BOITE From GESECRAN
  Endif
End

##############################################################################################################
# Campagne marketing
###################################################################
$TRT_CMG
  If ICLOVAL = 1 Then
    #Filtre utilisé par l'état RETCMG1
    Filter [CMG] Where [F:CMG]CLO <> 2
  Elsif ICLOVAL = 2 Then
    #Filtre utilisé par l'état RETCMG5
    Filter [CMG] Where [F:CMG]CLO = 2
  Endif
  For [F:CMG]
    If [F:CMG]CUR = "" Then
      WBUD = 0
    Else
      WBUD = 0
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:CMG]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:CMG]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Budget
        Call CONVERT([F:CMG]CUR,SZCURDES,CODDEVSOC,2,date$,[F:CMG]BUD,WBUD,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD = 0
        Endif
      Else
        WBUD = [F:CMG]BUD
      Endif
    Endif
    Call TR_PPP([F:CMG]NUM, "CMG", SZCURDES, WBUD)
    Call TRT_OPP([F:CMG]NUM, SZCURDES, WBUD)
  Next 
  Filter [CMG]
Return

##############################################################################################################
# Affaires
###################################################################
Subprog TRT_OPP(SZCMGNUM, SZCUR, IBUD)
Value Char SZCMGNUM
Value Char SZCUR
Value Decimal IBUD

Local Integer INOTOK
Local Char SZDEVSOC

  SZDEVSOC = ""
  Filter [OPP] Where [F:OPP]OPPCMGNUM = SZCMGNUM
  For [F:OPP]OPP2
    If [F:OPP]CUR = "" Then
      IBUD = 0
    Else
      IBUD = 0
      #Conversion des montants dans la devise de l'état
      If [F:OPP]CUR <> SZCUR Then
        Call GETDEVCPY("", [F:OPP]SALFCY, SZDEVSOC, INOTOK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Budget
        Call CONVERT([F:OPP]CUR,SZCUR,SZDEVSOC,2,date$,[F:OPP]OPPAMT,IBUD,INOTOK) From TRTDEV
        If INOTOK Then
          IBUD = 0
        Endif
      Else
        IBUD = [F:OPP]OPPAMT
      Endif
    Endif
    Call TR_PPP([F:OPP]OPPNUM, "OPP", SZCUR, IBUD)
  Next 
  Filter [OPP]
End

##############################################################################################################
# Mailing
###################################################################
$TRT_OMM
  For [F:OMM]
    WNUM = [F:OMM]OMMNUM 
    WSTRDAT = [F:OMM]SHIDAT
    WENDDAT = [00/00/00]
    WOMTYP = 1
    WCMG = [F:OMM]CMGNUM
    If [F:OMM]CUR = "" Then
      WBUD = 0
    Else
      WBUD = 0
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OMM]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OMM]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Budget
        Call CONVERT([F:OMM]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OMM]BUD,WBUD,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD = 0
        Endif
      Else
        WBUD = [F:OMM]BUD
      Endif
    Endif
    Call TR_PPP([F:OMM]OMMNUM, "OMG", SZCURDES, WBUD)
    Gosub TR_ARM
  Next 
Return

##############################################################################################################
# Phoning
###################################################################
$TRT_OMP
  For [F:OMP]
    WNUM = [F:OMP]OMPNUM 
    WSTRDAT = [F:OMP]OMPSTR
    WENDDAT = [F:OMP]OMPEND
    WOMTYP = 2
    WCMG = [F:OMP]CMGNUM
    If [F:OMP]CUR = "" Then
      WBUD = 0
    Else
      WBUD = 0
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OMP]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OMP]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Budget
        Call CONVERT([F:OMP]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OMP]BUD,WBUD,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD = 0
        Endif
      Else
        WBUD = [F:OMP]BUD
      Endif
    Endif
    Call TR_PPP([F:OMP]OMPNUM, "OMG", SZCURDES, WBUD)
    Gosub TR_ARM
  Next 
Return

##############################################################################################################
# Media
###################################################################
$TRT_OMN
  For [F:OMN]
    WNUM = [F:OMN]OMNNUM 
    WSTRDAT = [F:OMN]OMNSTR
    WENDDAT = [F:OMN]OMNEND
    WOMTYP = 4
    WCMG = [F:OMN]CMGNUM
    If [F:OMN]CUR = "" Then
      WBUD = 0
    Else
      WBUD = 0
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OMN]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OMN]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Budget
        Call CONVERT([F:OMN]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OMN]BUD,WBUD,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD = 0
        Endif
      Else
        WBUD = [F:OMN]BUD
      Endif    
    Endif
    Call TR_PPP([F:OMN]OMNNUM, "OMG", SZCURDES, WBUD)
    Gosub TR_ARM
  Next 
Return

##############################################################################################################
# Tradeshow
###################################################################
$TRT_OMT
  For [F:OMT]
    WNUM = [F:OMT]OMTNUM 
    WSTRDAT = [F:OMT]OMTSTR
    WENDDAT = [F:OMT]OMTEND
    WOMTYP = 3
    WCMG = [F:OMT]CMGNUM
    If [F:OMT]CUR = "" Then
      WBUD = 0
    Else
      WBUD = 0
      WBUD1 = 0
      WBUD2 = 0
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:OMT]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:OMT]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Cout stand
        Call CONVERT([F:OMT]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OMT]BOOCST,WBUD1,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD1 = 0
        Endif
        #Autres frais
        Call CONVERT([F:OMT]CUR,SZCURDES,CODDEVSOC,2,date$,[F:OMT]OTHCST,WBUD2,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          WBUD2 = 0
        Endif
        WBUD = WBUD1 + WBUD2
      Else
        WBUD = [F:OMT]BOOCST + [F:OMT]OTHCST
      Endif
    Endif
    Call TR_PPP([F:OMT]OMTNUM, "OMG", SZCURDES, WBUD)
    Gosub TR_ARM
  Next 
Return

##############################################################################################################
$TR_ARM
  Call DEBTRANS From GLOCK 
  Trbegin [ARM]
  #Création de l'enregistrement dans la table AREPORTM
  WNUMLIG      += 1
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = WNUMLIG
  [F:ARM]CLEA1   = WNUM
  [F:ARM]CLEA2   = WCMG
  [F:ARM]CLEN1   = WOMTYP
  [F:ARM]CLED1   = WSTRDAT
  [F:ARM]CLED2   = WENDDAT
  [F:ARM]CREDAT  = date$
  Write [F:ARM]   
  If fstat Then
    Rollback
  Else
    Commit 
  Endif
  If !GINTRA Then
    ICOUNT += 1
    Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
  Endif
Return 
 
##############################################################################################################
Subprog TR_PPP(SZOMMNUM, SZTYP, SZCUR, IBUD)
Value Char SZOMMNUM
Value Char SZTYP
Value Char SZCUR
Value Decimal IBUD

  Call DEBTRANS From GLOCK 
  Trbegin [PPP]
  Readlock [PPP]PPP0=SZOMMNUM;SZTYP;SZCUR
  If fstat = 5 Then
    #Création de l'enregistrement dans la table OPPREPORT
    [F:PPP]NUM = SZOMMNUM
    [F:PPP]TYPOBJ = SZTYP
    [F:PPP]CUR = SZCUR
    [F:PPP]AMT1 = IBUD
    Write [F:PPP]   
    If fstat Then
      Rollback
    Else
      Commit
    Endif 
  Else
    [F:PPP]NUM = SZOMMNUM
    [F:PPP]TYPOBJ = SZTYP
    [F:PPP]CUR = SZCUR
    [F:PPP]AMT1 = IBUD
    Rewrite [F:PPP]   
    If fstat Then
      Rollback
    Else
      Commit
    Endif 
  Endif
End

##############################################################################################################
$OUVRE 
  If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:PPP]) : Local File PREREPORT [PPP] : Endif
  If !clalev([F:ARM]) : Local File AREPORTM [ARM] : Endif
Return 
 
##############################################################################################################
$DECLARE 
Local Char    CRITERE(255),CRITERE1(50),CRITERE2(50),CRITERE3(50), CRITERE4(50)
Local Char    PARAM(30),VALEUR(30),ETAT(GLONARP),WNUM(GLONVCR)
Local Integer WTYP, NUMREQ 
Local Integer WNUMLIG
Local Decimal WBUD, WBUD1, WBUD2
Local Date WSTRDAT, WENDDAT
Local Integer WOMTYP
Local Char WCMG
Local Char SZCURDES
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Integer ICLOVAL
Local Char CODDEVSOC

  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 0
  SZCURDES = ""
  WBUD = 0
  WOMTYP = 0
  WCMG = ""
  ICLOVAL = 1
Return 
