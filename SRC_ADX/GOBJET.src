$OUVRE_MSK
Raz RESTMSK
For MA=0 To NBMASK
 If NOMMSK(MA)<>""
  For MA2=0 To 25
   If NOMMSK(MA)=masknam(MA2) & ABMSK(MA)=maskabr(MA2)
    Gosub SAVMSK : Break
   Endif
  Next MA2
  Local Mask =NOMMSK(MA)
  If ABMSK(MA)="" : ABMSK(MA) = ABREV+num$(MA) : Endif : # Temporaire
 Else
  AMA(MA) = 0
 Endif
Next MA
If dim(NBMSKCMP)>0 & NBMSKCMP>0
 Gosub OUVMSKCMP From =WINPROG
Endif
Return

$FERME_MSK
For MA=0 To NBMASK
 If RESTMSK(MA)<>0
  Gosub RESTMSK
 Endif
Next MA
Return

$SAVMSK
GNBMASK += 1
Case GNBMASK
 When 1  : Local Mask =NOMMSK(MA) [SV01]
 When 2  : Local Mask =NOMMSK(MA) [SV02]
 When 3  : Local Mask =NOMMSK(MA) [SV03]
 When 4  : Local Mask =NOMMSK(MA) [SV04]
 When 5  : Local Mask =NOMMSK(MA) [SV05]
 When 6  : Local Mask =NOMMSK(MA) [SV06]
 When 7  : Local Mask =NOMMSK(MA) [SV07]
 When 8  : Local Mask =NOMMSK(MA) [SV08]
 When 9  : Local Mask =NOMMSK(MA) [SV09]
 When 10 : Local Mask =NOMMSK(MA) [SV10]
 When 11 : Local Mask =NOMMSK(MA) [SV11]
 When 12 : Local Mask =NOMMSK(MA) [SV12]
 When 13 : Local Mask =NOMMSK(MA) [SV13]
 When 14 : Local Mask =NOMMSK(MA) [SV14]
 When 15 : Local Mask =NOMMSK(MA) [SV15]
 When 16 : Local Mask =NOMMSK(MA) [SV16]
Endcase
Gosub SETMASK From =WINPROG
Case GNBMASK
 When 1  : [M:SV01] = [M]
 When 2  : [M:SV02] = [M]
 When 3  : [M:SV03] = [M]
 When 4  : [M:SV04] = [M]
 When 5  : [M:SV05] = [M]
 When 6  : [M:SV06] = [M]
 When 7  : [M:SV07] = [M]
 When 8  : [M:SV08] = [M]
 When 9  : [M:SV09] = [M]
 When 10 : [M:SV10] = [M]
 When 11 : [M:SV11] = [M]
 When 12 : [M:SV12] = [M]
 When 13 : [M:SV13] = [M]
 When 14 : [M:SV14] = [M]
 When 15 : [M:SV15] = [M]
 When 16 : [M:SV16] = [M]
Endcase
RESTMSK(MA) = GNBMASK
Return

$RESTMSK
Gosub SETMASK From =WINPROG
Case RESTMSK(MA)
 When 1  : [M] = [M:SV01]
 When 2  : [M] = [M:SV02]
 When 3  : [M] = [M:SV03]
 When 4  : [M] = [M:SV04]
 When 5  : [M] = [M:SV05]
