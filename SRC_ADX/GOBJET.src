#<AdxTL>@(#)10.0.0.0 $Revision$
##################################################
##  Appel par TRT GOBJET                        ##
##################################################
Call OBJET(GBIDC1,GBIDC2,GBIDC3)
End

##################################################
##  Appel par Call OBJET                        ##
##################################################

Subprog OBJET_CHAR(CLE1,OBJET,CLE2)
Variable Char    CLE1
Value    Char    OBJET
Value    Char    CLE2
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLE1,CLETAB)
 Gosub RESET_CLETAB
Elsif CLE2="" & instr(1,CLE1,"~")
 Gosub SET_CLEVAL
 Call OBJET(OBJET,CLEVAL,CLETAB)
 Gosub RESET_CLEVAL
Else
 Call OBJET(OBJET,CLE1,CLE2)
Endif
End

Subprog OBJET_NUM(CLE1,OBJET,CLE2)
Variable Decimal CLE1
Value    Char    OBJET
Value    Char    CLE2
Local Char CLECHAR(20)
CLECHAR = num$(CLE1)
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLECHAR,CLETAB)
 Gosub RESET_CLETAB
Else
 Call OBJET(OBJET,CLECHAR,CLE2)
Endif
CLE1 = val(CLECHAR)
End

Subprog OBJET_DAT(CLE1,OBJET,CLE2)
Variable Date    CLE1
Value    Char    OBJET
Value    Char    CLE2
Local Char CLECHAR(20)
CLECHAR = num$(CLE1)
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLECHAR,CLETAB)
 Gosub RESET_CLETAB
Else
 Call OBJET(OBJET,CLECHAR,CLE2)
Endif
If instr(1,CLECHAR,"/") & !instr(1,CLECHAR,"]")
 CLE1 = evalue("["+CLECHAR+"]")
Else
 CLE1 = gdat$(CLECHAR)
Endif
End

Subprog OBJET_LIB(CLE1,OBJET,CLE2)
Variable Integer CLE1
Value    Char    OBJET
Value    Char    CLE2
Local Char CLECHAR(20)
CLECHAR = num$(CLE1)
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLECHAR,CLETAB)
 Gosub RESET_CLETAB
Else
 Call OBJET(OBJET,CLECHAR,CLE2)
Endif
CLE1 = val(CLECHAR)
End

Subprog OBJET_BLOB(CLE1,OBJET,CLE2)
Variable Blbfile CLE1
Value    Char    OBJET
Value    Char    CLE2
Local Char CLECHAR(20)
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLECHAR,CLETAB)
 Gosub RESET_CLETAB
Else
 Call OBJET(OBJET,CLECHAR,CLE2)
Endif
End

Subprog OBJET_CLOB(CLE1,OBJET,CLE2)
Variable Clbfile CLE1
Value    Char    OBJET
Value    Char    CLE2
Local Char CLECHAR(20)
If dim(CLE2)=1 & instr(1,CLE2,"~")
 Gosub SET_CLETAB
 Call OBJET(OBJET,CLECHAR,CLETAB)
 Gosub RESET_CLETAB
Else
 Call OBJET(OBJET,CLECHAR,CLE2)
Endif
End

$SET_CLETAB
Local Char CHAINE(255) , CLE(50)(1..16)
Local Integer I , NBCLE
CHAINE = CLE2
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
I = type(CLE2)-10
Local Char CLETAB(I)(NBCLE)
For I=1 To NBCLE
 CLETAB(I-1) = CLE(I)
Next I
Return

$RESET_CLETAB
CLE2 = CLETAB(0)
For I=1 To dim(CLETAB)-1
 CLE2 += "~"+CLETAB(I)
Next I
Return

$SET_CLEVAL
Local Char CHAINE(255) , CLE(50)(1..16)
Local Integer I , NBCLE
I = type(CLE1)-10
Local Char CLEVAL(I)
CHAINE = CLE2
I = instr(1,CHAINE,"~")
If I
 CLEVAL = left$(CHAINE,I-1)
 CHAINE = right$(CHAINE,I+1)
Else
 CLEVAL = CHAINE
 CHAINE = ""
Endif
NBCLE = 0
While CHAINE<>""
 NBCLE += 1
 I = instr(1,CHAINE,"~")
 If I
  CLE(NBCLE) = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
I = type(CLE2)-10
Local Char CLETAB(I)(NBCLE)
For I=1 To NBCLE
 CLETAB(I-1) = CLE(I)
Next I
Return

$RESET_CLEVAL
CLE1 = CLEVAL
CLE2 = CLETAB(0)
For I=1 To dim(CLETAB)-1
 CLE2 += "~"+CLETAB(I)
Next I
Return

###################################################################
# Exigence 73847
Subprog OBJET_FILTRE(ABREV,SAVCLE1,SAVCLE2,AIT_FILTRE,AIT_TRANSAC, AIT_REDOLY)
Value    Char    ABREV
Variable Char    SAVCLE1()
Value    Char    SAVCLE2
Value    Char    AIT_FILTRE
Value    Char    AIT_TRANSAC
Value    Integer AIT_REDOLY
Goto OBJET_STANDARD
# End Exigence 73847
###########################################
Subprog OBJET(ABREV,SAVCLE1,SAVCLE2)
Value    Char    ABREV
Variable Char    SAVCLE1()
Value    Char    SAVCLE2
Goto OBJET_STANDARD

########################
$OBJET_STANDARD

Local Integer PASLIEN

If GPILLNK>0
 PASLIEN = 1 : # Pour ne pas dépiler l'explorateur de liaisons
Endif

###########################################
$DEBUT
# Si abrev est vide, on se casse
If ABREV="" : End : Endif

# Si objet géré dans un autre dossier
If find(ABREV,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
 Call MESSAGE(mess(181,133,1)-GDOSCPT) From GESECRAN : # Objet géré dans le dossier
 End
Endif

# Détection de l'auto-tunnel
If GFONCTION="ADOTRT"
 Raz GPILOBJ, GPILCOD
Endif
If find(ABREV,GPILCOD(1..GPILOBJ))
 Call MESSAGE(ABREV-":"-mess(116,126,1)) From GESECRAN : # Objet déjà en cours de gestion
 mkstat = 2 : End
Endif

# Pas de tunnel en picking
If dim([V]GPICK)>0 & GPICK
 Call MESSAGE(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
 End
Endif

#  A-t-on le droit de naviguer vers cette action
Local Char MESSAG(100)
Call CNAVIG(2,"","",ABREV,"","","",MESSAG) From EXEFNC
If MESSAG<>"" : End : Endif

# Variables locales
Gosub DEFVAR
If NOMFIC="" : End : Endif : # Y'a un problème
SAVGFLAG = GFLAG
TUNCLE   = SAVCLE1
CLE1     = SAVCLE1
If CLE1<>"" | GPILOBJ
 TUNNEL = 1
 If dim(GNAVEXEFNC)<0 or GNAVEXEFNC<>1   : #  CC 24/01/2007 pour pouvoir naviguer à partir du navigateur
   Raz GFLAG : # TS le 22.09.99
 Endif
Endif
If dim(GNAVEXEFNC)>0 : GNAVEXEFNC=0 : Endif

If dim([L]CLEVALEUR)>0 & (instr(1,adxpno(1),"GESUSER") | !TUNNEL) : ## GEODE
 CHGENV  = 1+([L]CLEDEP<>"")
 GCHGENV = CHGENV
Endif

# Sauvegarde du contexte
SAVNOL2      = nolign
SAVIND2      = indice
SAVBOX       = currbox
SAVOBJET     = GOBJET
SAVTITCOL    = GORITITCOL
SAVABR       = GABREV
SAVTRAITE    = GTRAITE
SAVFONC      = GFONCTION
SAVFONC1     = GFONC1
SAVPROG      = GPROGRAMME
SAVGREP      = GREP
SAVGGRPFCY   = GGRPFCY
SAVGCHAINE   = GCHAINE
SAVFCYDEF    = GFCYDEF(0)
SAVSOCIETE   = GSOCIETE
SAVCURLEG    = GCURLEG
SAVCURFCY    = GCURFCY
SAVBOITE     = GBOITE
SAVVARIANTE  = GVARIANTE
SAVLOCALDEV  = GLOCALDEV
SAVGCONSULT = GCONSULT # exigence 73847
If GPRODUIT=1 : ## GEODE
 SAVDEP       = GDEP
 SAVFCY       = GFCY
 If maskcou<>""
  If    dim([M]DEP)>1 : GDEP = [M]DEP(nolign-1)
  Elsif dim([M]DEP)>0 : GDEP = [M]DEP
  Endif
  If    dim([M]FCY)>1 : GFCY = [M]FCY(nolign-1)
  Elsif dim([M]FCY)>0 : GFCY = [M]FCY
  Endif
  If GDEP<>SAVDEP | GFCY<>SAVFCY
   SAVENV = 1
  Endif
 Endif
Endif
Call SAVBOUT From GESECRAN
For I=1 To dim(GSTAIMG)
 SAVIMG(I) = GSTAIMG(I)
 If GSTAIMG(I)<>0
  Call RESET_IMAGE(I) From GESECRAN
 Endif
Next I
SAVTXT = GSTATXT
Call SET_TEXTE(0) From GOBJET

# Exigence 73847
# Initialisation d'après contexte
If dim(AIT_TRANSAC)>0
 GFLAG = AIT_TRANSAC
Endif

If dim(AIT_REDOLY)>0
 If AIT_REDOLY = 2
  GCONSULT = 1
 Endif
Endif
# End Exigence 73847

# Affect variables globales
GOBJET     = 1
GORITITCOL = 0
GABREV     = ABREV
GPROGRAMME = "GOBJSUB"
GTRAITE    = "GOBJET"
If GFONCTION<>"GES"+ABREV
 MENFON=GFONCTION
 Call MENFONOBJ(MENFON,ABREV) From INTRUTILA
Endif
If dim(FLDLEG)<=0 or FLDLEG="" : Raz GCURLEG  : Endif
If dim(FLDGRF)<=0 or FLDGRF="" : Raz GCURFCY  : Endif
If dim(FLDGRC)<=0 or FLDGRC="" : Raz GSOCIETE : Endif
GFONCTION  = "GES"+ABREV
GPILOBJ += 1
If GPILOBJ<=0
 GPILOBJ = 1
Endif
GPILCOD(GPILOBJ) = ABREV
Call SET_MENU("GES"+GABREV) From EXEFNC

# Choix d'une fenêtre disponible
Call CONT_FEN(ABREV,FENETRE)
If FENETRE=""
 Call ERREUR(mess(107,133,1)) From GESECRAN : # Il n'y pas de fenêtre disponible pour cet objet
 Goto SORT
Else
 Call NOMTRTWINOPT(FENETRE,WINPROG) From MSKDIV
Endif

If dim([L]CLEVALEUR)>0 & (([L]CLEDEP<>"" & GDEP="") | ([L]CLEFCY<>"" & GFCY="")) : ## GEODE
 # Fonction incompatible avec l'environnement
 Call ERREUR(mess(1,133,1)) From GESECRAN
 Goto SORT
Endif

# Autorisations
Call CONT_WRK(ABREV,OPTWRK)
Call CONT_LCK(OPTLCK)
Call CONT_ENA(NOMFIC,OPTENA)
Call CONT_DOC(OPTDOC)
Call CONT_SIG(OPTSIG)
Call AUTORIS From EXEFNC
Raz CRE, MODI, SUPPR, AUTENA
If GNBAUZ=0
 If GNBSITE=0
  Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans le dossier
  Goto SORT
 Else
  Call ERREUR(GFONCTION-":"-mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
  Goto SORT
 Endif
Elsif GUSRFCY(1)="\"
 CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
 MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
 SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
 AUTENA = (instr(1,GUSRAUZ(1),"N")<>0)
Endif
If clalev([M:DIA])>0
 SUPPR = 0 : # mb 16.6.8 bug 47919 Pour éviter de rentrer en conflit avec le masque DIA de la boîte ANUCOD
Endif
Call AFF_MES_LIC(GFONCTION,[V]CST_AFALSE) From ASYRLIC
# Ouverture des fichiers
Gosub INIT From GOBJNAV

INDGES = 1 : # No de l'index pour la gestion des boutons magnétos
If evalue("clalev([F:"+ABFIC+"])")=0
 Gosub OUVFIC From =PROGOBJ
Endif

OK = 1 : Raz GMESSAGE
ACTION = "AVANT_OUVRE" : Gosub ACTION : # mb 31.5.1  (ts)
If !OK
 If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
 Goto SORT
Endif

Onerrgo ERREUR From CONTROLE
Gosub OUVRE From =PROGOBJ
Gosub OUVFIC_DERLU From =PROGOBJ
Gosub OUVOBJ
Onerrgo
If GERREUR : GERREUR=0 : Goto SORT : Endif

Raz CLE2
If dim(CLEVALEUR)>0 : ## GEODE
 For CL = 0 To dim(SAVCLE2)-1 : SCLE2(CL) = SAVCLE2(CL): Next CL
 Raz CL
 If CLE1<>""
  CLE = CLE1
  CL = find(CLEPRIM,CLEVALEUR,CLEFCY,CLEDEP,CLESUPP(0..dim(CLESUPP)-1))
  Case CL
   When 0       : CLE1 = ""
   When 2       : CLE1 = GFCY
   When 3       : CLE1 = GDEP
   When Default : If CL>3 : CLE1 = SCLE2(CL-4): Endif
  Endcase
  If CLE1<>""
   For I=0 To dim(CLESEC)-1
    CL = find(CLESEC(I),CLEVALEUR,CLEFCY,CLEDEP,CLESUPP(0..dim(CLESUPP)-1))
    Case CL
     When 1       : CLE2(I) = CLE
                    If !GFUSION : # bug 107514
                     If adxpam<>"" and CLE2(I)=GDEP     : # Bug 86955 - clé passée pour vignette portail pas bonne
                      CLE2(I)=SCLE2(I)
                     Endif
                    Endif
     When 2       : CLE2(I) = GFCY
     When 3       : CLE2(I) = GDEP
     When Default : If CL>3 : CLE2(I) = SCLE2(CL-4) : Endif
    Endcase
   Next I
  Endif
 Endif
Else
 For CL=0 To dim(SAVCLE2)-1 : CLE2(CL) = SAVCLE2(CL) : Next CL
Endif

#
# Recherche dernière clé utilisée
#
If CLE1="" & CLE2="" & GLECOBJ=2
 If GNBDERNIER>0
  Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
  For [ALS]ALS0
   CLE = [F:ALS]CLES
   K = instr(1,CLE,"~")
   If K
    CLE1 = left$(CLE,K-1)
    CLE = right$(CLE,K+1)
    For I =0 To dim(CLESEC)-1
     If CLESEC(I)="" : Break : Endif
     K = instr(1,CLE,"~")
     If K
      CLE2(I) = left$(CLE,K-1)
      CLE = right$(CLE,K+1)
     Endif
    Next I
   Endif
   OK=1
   If dim(CLEVALEUR)>0 : ## GEODE
    If CLEFCY<>""
     CL = find(CLEFCY,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     If (CL=1 & GFCY<>CLE1) | (CL>1 & GFCY<>CLE2(CL-2)): OK=0 : Endif
    Endif
    If CLEDEP<>"" & K
     CL = find(CLEDEP,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     If (CL=1 & GDEP<>CLE1) | (CL>1 & GDEP<>CLE2(CL-2)): OK=0 : Endif
    Endif
   Endif
   If GPRODUIT=4 & GFONCTION<>"GESBUD" & GFONCTION<>"GESEXO"
    CL = find("BUD",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
    If (CL=1 & GBUD<>CLE1) | (CL>1 & GBUD<>CLE2(CL-2)): OK=0 : Endif
    CL = find("EXO",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
    If (CL=1 & num$(GEXO)<>CLE1) | (CL>1 & num$(GEXO)<>CLE2(CL-2)): OK=0 : Endif
    CL = find("NUMFIC",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
    If CL>=1
     Call PARAM(GBUD,0,"",GUSER,"FIC"+ABREV,[L]VALNUMFIC) From PARVAL
     If (CL=1 & num$(CLE1)<>[L]VALNUMFIC) | (CL>1 & num$(CLE2(CL-2))<>[L]VALNUMFIC)
       OK = 0
     Endif
    Endif
   Endif
   If OK : Break : Endif
  Next
  Filter [ALS]
  If CLE1<>"" & !OK : Raz CLE1, CLE2 : Endif
 Endif
 If CLE1="" & CLE2=""
  For I=1 To GNBDERCLE
   If ABREV=GDEROBJ(I)
    CLE = GDERCLE(I)
    K = instr(1,CLE,"\")
    If !K
     CLE1 = CLE
     CLE  = ""
    Else
     CLE1 = left$(CLE,K-1)
     CLE  = right$(CLE,K+1)
    Endif
    CL = 0
    Repeat
     K = instr(1,CLE,"\")
     If K
      CLE2(CL) = left$(CLE,K-1)
      CLE      = right$(CLE,K+1)
      CL += 1
     Else
      CLE2(CL) = CLE
     Endif
    Until K=0
    OK = 1
    If dim(CLEVALEUR)>0 : ## GEODE
     If CLEFCY<>""
      CL = find(CLEFCY,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
      If (CL=1 & GFCY<>CLE1) | (CL>1 & GFCY<>CLE2(CL-2)): OK = 0 : Endif
     Endif
     If CLEDEP<>"" & K
      CL = find(CLEDEP,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
      If (CL=1 & GDEP<>CLE1) | (CL>1 & GDEP<>CLE2(CL-2)): OK = 0 : Endif
     Endif
    Endif
    If GPRODUIT=4 & GFONCTION<>"GESBUD" & GFONCTION<>"GESEXO"
     CL = find("BUD",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     If (CL=1 & GBUD<>CLE1) | (CL>1 & GBUD<>CLE2(CL-2)): OK = 0 : Endif
     CL = find("EXO",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     If (CL=1 & num$(GEXO)<>CLE1) | (CL>1 & num$(GEXO)<>CLE2(CL-2)): OK = 0 : Endif
     CL = find("NUMFIC",CLEPRIM,CLESEC(0..dim(CLESEC)-1))
     If CL>=1
      Call PARAM(GBUD,0,"",GUSER,"FIC"+ABREV,[L]VALNUMFIC) From PARVAL
      If (CL=1 & num$(CLE1)<>[L]VALNUMFIC) | (CL>1 & num$(CLE2(CL-2))<>[L]VALNUMFIC)
       OK = 0
      Endif
     Endif
    Endif
    If OK : Break : Endif
   Endif
  Next
  If CLE1<>"" & !OK : Raz CLE1, CLE2 : Endif
 Endif
Endif
##

Raz AMA
For MA=0 To dim(AMA)-1 : AMA(MA) = 1 : Next MA

# Gestion des objets à variante
$VARIANTE
VARIANTE = 0
GVARIANTE = 0
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
OK = 1 : GMESSAGE = ""
ACTION = "DEFTRANS" : Gosub ACTION
If !OK
 If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
 Goto SORT
Endif
If GFLAG<>"" & left$(GFLAG,1)<>"\"
 Read [AWI]AWI2(2) = ABREV;GFLAG
 #105147 transaction control
 #If fstat or [F:AWI]ENAFLG<>2
 If fstat or [F:AWI]ENAFLG<>2 or [F:AWI]MDL=2
  GFLAG = "\"
 Else
  GBOITE = [F:AWI]WIN
  #105147 transaction control
  Gosub CTL_VARIANTE
 Endif
Endif
If GFLAG="" or left$(GFLAG,1)="\"
 Gosub SAI_VARIANTE
 If GFLAG="" : GFLAG = OGFLAG : Endif : # Pour ne pas sortir si on est déjà entré !
Endif
If GFLAG="" : Goto SORT : Endif
VARIANTE = 1
GVARIANTE = 1 : # Globale à cause d'ANUCOD et CHGCOD
If GFLAG="1-3-5-7-9-"
 GFLAG = "" : # TS pas de code transaction si objet sans variante
Endif
Call NOMTRTWINOPT(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
ACTION = "SETTRANS" : Gosub ACTION

# Ouvertures
Onerrgo ERREUR From CONTROLE
Gosub OUVRE_MSK
Gosub SETMASK
NRMASK = sum(AMA(1..NBMASK))
Onerrgo
If GERREUR : GERREUR=0 : Goto SORT : Endif

# Index de gestion liste gauche
INDCUR = 1
If dim([L]NOMKEY)>0 & [L]NOMKEY<>""
 For I=0 To evalue("[G:"+ABFIC+"]nbind")-1
  If [L]NOMKEY=evalue("[G:"+ABFIC+"]keyname("+num$(I)+")")
   INDCUR = I+1 : Break
  Endif
 Next I
Endif

##
## Ancien pavé d'init des clés
##

If sum(AMA)=0 : Goto SORT : Endif

# Ouverture des fichiers
OK = 1 : Raz GMESSAGE
ACTION = "OUVRE" : Gosub ACTION
If !OK
 If GMESSAGE<>"" : Call ERREUR(GMESSAGE) From GESECRAN : Endif
 Goto FERME_SORT
Endif
Gosub SETMASK

# Connexion à un module
If MODULE<>0
#X3BY à traiter plus tard... Call CONNECT(MODULE,CONNECT) From MULTI
 If !CONNECT : Goto FERME_SORT : Endif
Endif

# Types des clés
# Gosub DEFAUT From =PROGOBJ # mb Inutile à ce niveau
If evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")>10
 TPCLE1 = 1
Elsif evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")=3
 TPCLE1 = 3
Else
 TPCLE1 = 2
Endif
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>""
  If evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")>10
   TPCLE2(CL) = 1
  Elsif evalue("type([F:"+ABFIC+"]"+CLESEC(CL)+")")=3
   TPCLE2(CL) = 3
  Else
   TPCLE2(CL) = 2
  Endif
 Endif
Next CL

# Définition initiale des boutons
Raz NBBOUT
Raz NBTEX , TEX

Gosub BOUTON From =WINPROG
For BOUT = "E" , "C" , "S" , "A" , "O"
 If instr(1,STDBOUT,BOUT)
  NBBOUT += 1
  Case BOUT
   When "E" : CODBOUT(NBBOUT) = GSTAENR : # Enregistrer
   When "C" : CODBOUT(NBBOUT) = GSTACRE : # Créer
   When "S" : CODBOUT(NBBOUT) = GSTAANU : # Supprimer
   When "A" : CODBOUT(NBBOUT) = GSTAFIN : # Abandon
   When "O" : CODBOUT(NBBOUT) = GSTAOK  : # OK
  Endcase
 Endif
Next BOUT
NBOUTSTD = NBBOUT
For I=1 To NBTEX
 If I<dim(GSTASPE)
  NBBOUT += 1
  CODBOUT(NBBOUT) = LBOUT(I)
  GSTASPE(I)      = LBOUT(I)
 Endif
Next I
NBBOUT += 1 : CODBOUT(NBBOUT) = GSTAEND : # Fin

Raz K, N
For I=1 To NBMEN
 If int(NMEN(I)/10)<>N : # Menu principal
  N += 1
  GPILOBJ += 1
  J = GSTAMEN+GPILOBJ
 Elsif CMEN(I)="" : # Sous-menu
  GPILOBJ += 1
 Else : # Lignes
  K += 1
  XMEN(K) = CMEN(I)
  GETAMEN(K) = 2
 Endif
Next I
NBRMEN = K

# Chargement de menu signature
If OPTSIG : Gosub DEFMENSIG : Endif

# Chargement du menu mémos sélections
If instr(1,STDBOUT,"R") or instr(1,STDBOUT,"X")
 NUMITM = -1
 Gosub CHARGEMEMOS
Endif

# Menus documentation
If OPTDOC : Gosub CHARGE_MENDOC : Endif

# Avant d'ouvrir la fenêtre, on lit devise et pays à tout hasard
If clalev([F:TCU])>0 : Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ : Endif
If clalev([F:TCY])>0 : Call LECTURE("TCY",GPAYS,"") From CONTOBJ : Endif
If dim([L]CLEVALEUR)>0 : ## GEODE
 If [L]CLEFCY<>""
  If clalev([F:FCY])>0 : Call LECTURE("FCY",GFCY,"") From CONTOBJ : Endif
  If clalev([F:SIT])>0 : Call LECTURE("SIT",GFCY,"") From CONTOBJ : Endif
 Endif
 If [L]CLEDEP<>"" & clalev([F:DEP])>0 & ([F:DEP]FCY<>GFCY or [F:DEP]DEP<>GDEP)
  Read [DEP]DEP0 = GFCY;GDEP
  If fstat : Raz [F:DEP] : Endif
 Endif
Endif

OK = 1
ACTION = "BOITE" : Gosub ACTION
If OK
 Assign "[G:"+ABFIC+"]currind" With INDCUR
 Assign "[G:"+ABFIC+"]currlen" With 0
 If MENFON<>"" : OGFONCTION=GFONCTION : GFONCTION=MENFON : Endif    : #  Pour traiter la navigation V5 il faut le rattachement
 Gosub OUVRE_BOITE From =WINPROG
 If MENFON<>"" : GFONCTION=OGFONCTION : Endif
Endif

ACTION = "OUVRE_BOITE" : Gosub ACTION

If dim(BOX1)>0 : BOXCURR = BOX1 : currbox = BOX1 : Endif

If SAVENV
 Call AFF_ENV From MENU
Endif

Gosub RAZMASK From GOBJSUB
If dim(NBMSKCMP)>0 & NBMSKCMP>0
 Gosub RAZMSKCMP From =WINPROG
Endif
Gosub SETNOK  From GOBJSUB
For MA=0 To NBMASK
 Gosub TITMASK From =WINPROG
Next MA
ACTION = "AFFMASK" : Gosub ACTION

# Recherche d'un enregistrement à afficher
Gosub DEFAUT From =PROGOBJ
If dim(GCHXCREMOD)>0 & GCHXCREMOD="C" & (CRE<>0 or GUSRFCY(1)<>"\") & !GCONSULT
 Goto BOXTUN
Endif
If CLE1<>"" or CLE2<>""
 CLECUR1 = CLE1
 For CL=0 To dim(CLESEC)-1 : CLECUR2(CL) = CLE2(CL) : Next CL
 Gosub AFF_CLE From GOBJSUB
 Gosub FIL_ROLE From GOBJSUB
 FILTRE = ""
 If !TUNNEL : # mb 18.9.2 bug 15788
  Call FILTRE(NOMFIC,FILTRE) From ASELOBJ : # mb 10.10.1 bug 10920
 Endif
 Gosub CRITERE From GOBJSUB
 # mb 17.12.2012 bug 86137 Les deux filtres suivant ne peuvent être faits que sur la classe liée
 #If FILACC<>"" & FILACC<>"1=1"
 # Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILACC+")","&") From GOBJSUB
 #Endif
 #If FILGRP<>"" & FILGRP<>"1=1"
 # Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILGRP+")","&") From GOBJSUB
 #Endif
 If FILLEG<>"" & FILLEG<>"1=1"
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+FILLEG+")","&") From GOBJSUB : # mb 6.8.12 bug 82383
 Endif
 Onerrgo ERR_REMP From GOBJSUB
 If CRITERE="" : CRITERE = "1=1" : Endif
 If FILTSUP="" : FILTSUP = "1=1" : Endif
 If FILROLE="" : FILROLE = "1=1" : Endif
 Filter [F] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE)
 Gosub DEFAUT From =PROGOBJ
 Onerrgo
 Assign "[G:"+ABFIC+"]currind" With 1
 Assign "[G:"+ABFIC+"]currlen" With 0
 Case TYPGES
  When 1
   Read =
   If fstat=0
    Gosub DROIT From GOBJSUB
   Else
    OK = 0
   Endif
   If OK
    NEWCLE1 = CLE1
    For CL=0 To dim(CLESEC)-1 : NEWCLE2(CL) = CLE2(CL) : Next CL
    Gosub LECTURE From GOBJSUB
    OK = 1
   Else
    Raz CLECUR , CLECUR1 , CLECUR2 , CLE1
    If SAVCLE2="" : Raz CLE2 : Endif
   Endif
  When 3
   Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC)
   Read =
   If fstat=0
    Gosub DROIT From GOBJSUB
   Else
    OK = 0
   Endif
   If OK
    Gosub LECTURE From GOBJSUB
    OK = 1
   Endif
 Endcase
 Gosub DEFAUT From =PROGOBJ
 Filter [F]
 If !OK & TYPGES<>2
  Raz CLECUR , CLECUR1 , CLECUR2 , CLE1 , CLE2
  If SAVCLE2<>""
   If dim(CLEVALEUR)>0 : ## GEODE
    For I=0 To dim(CLESEC)-1
     CL=find(CLESEC(I),CLEVALEUR,CLEFCY,CLEDEP,CLESUPP(0..dim(CLESUPP)-1))
     Case CL
      When 2       : CLE2(I) = GFCY
      When 3       : CLE2(I) = GDEP
      When Default : If CL>3 : CLE2(I) = SCLE2(CL-4) : Endif
     Endcase
    Next I
   Else
    CLE2(0) = SAVCLE2
   Endif
  Endif
  Gosub RAZMASK From GOBJSUB
 Endif
Endif
If TYPGES=2
 Gosub LECTURE From GOBJSUB
Elsif CLECUR=0 & GLECOBJ=2
 K = 0
 If GPRODUIT=1 : # mb 22.10.10 bug 68173
  K = 1
 Else
  I = func AFNC.GET_NBREC(NOMFIC) : # mb 29.5.12 bug 82163
  J = val(func AFNC.PARAM("NXTREC",""))
  If J=0 or I<J
   K = 1
  Endif
 Endif
 If K
  If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
   Gosub SET_FIRST From GOBJACT
  Endif
  Gosub DEFAUT From =PROGOBJ
  Gosub FIL_ROLE From GOBJSUB :#X3-98930
  Gosub SET_FILTRE From GOBJSUB
  If dim([L]SELORD)>0 & [L]SELORD=2
   Read Last
   Gosub PREC2 From GOBJSUB
  Else
   Read First
   Gosub SUIV2 From GOBJSUB
  Endif
  Local Integer STATLOC
  STATLOC=fstat
  If GTYPDBA=1 & dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
   Gosub UNSET_FIRST From GOBJACT
  Endif
  If STATLOC<=2
   Gosub SUIVPREC From GOBJSUB
  Endif
 Endif
Endif
REP = ""  : GREP = "" : # Consultation

$BOXTUN
LFTBOXTUN=0
If dim(GLFTBOXTUN)<=0 | GLFTBOXTUN=2 | !TUNNEL | TUNCLE=""
 LFTBOXTUN=1
Elsif dim([L]CLEVALEUR)>0
 CL = find(CLEVALEUR,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
 If CL=1    & TUNCLE<>CLE1       : LFTBOXTUN=1
 Elsif CL>1 & TUNCLE<>CLE2(CL-2) : LFTBOXTUN=1
 Endif
Elsif TUNCLE<>CLE1
 LFTBOXTUN=1
Endif

#####################################################
# Boxinp
#####################################################

Gosub CHOI From GOBJSUB


# Stockage dernière clé utilisée
If CLECUR & TYPGES<>4
 CLE1 = CLECUR1
 For CL=0 To dim(CLESEC)-1 : CLE2(CL) = CLECUR2(CL) : Next CL
 If TYPGES=2 & nolign>0 : # Pour récupérer la bonne ligne du tableau
  If evalue("dim([M]"+CLEPRIM+")")>0 & nolign<=evalue("dim([M]"+CLEPRIM+")")
   CLE1 = num$(evalue("[M]"+CLEPRIM+"("+num$(nolign-1)+")"))
  Endif
  For CL=0 To dim(CLESEC)-1
   If CLESEC(CL)="" : Break : Endif
   If evalue("dim([M]"+CLESEC(CL)+")")>nolign-1 & nolign<=evalue("dim([M]"+CLESEC(CL)+")")
    CLE2(CL) = num$(evalue("[M]"+CLESEC(CL)+"("+num$(nolign-1)+")"))
   Endif
  Next CL
 Endif
 K = find(ABREV,GDEROBJ(1..GNBDERCLE))
 If K=0 & GNBDERCLE<dim(GDERCLE)
  GNBDERCLE += 1 : K = GNBDERCLE : GDEROBJ(K) = ABREV
 Endif
 If K
  GDERCLE(K) = CLE1
  For CL=0 To dim(CLESEC)-1
   If CLESEC(CL)<>""
    GDERCLE(K) += "\"+CLE2(CL)
   Endif
  Next CL
 Endif
 Gosub AFF_CLE From GOBJSUB
 Gosub DEFAUT From =PROGOBJ
 Read =
 If dim(CLEVALEUR)>0 : ## GEODE
  For I=0 To dim(CLESUPP)-1
   CL = find(CLESUPP(I),CLEPRIM,CLESEC(0..dim(CLESEC)-1))
   If CL=1    : OCLECUR2(I) = CLE1
   Elsif CL>1 : OCLECUR2(I) = CLE2(CL-2)
   Endif
  Next I
  CL = find(CLEVALEUR,CLEPRIM,CLESEC(0..dim(CLESEC)-1))
  If CL=0    : CLE1 = ""
  Elsif CL>1 : CLE1 = CLE2(CL-2)
  Endif
  J=1
  For I=0 To dim(CLESUPP)-1
   If CLESUPP(I)<>"" & !(TYPGES=3 & CLESUPP(I)=CLELIG) & OCLECUR2(I)<>SCLE2(I)
    J=0 : Break
   Endif
  Next I
  If J : SAVCLE1 = CLE1 : Endif
 Elsif CLE2=SAVCLE2 | (TYPGES=3 & CLELIG=CLESEC)
  SAVCLE1 = CLE1
 Endif
Endif

# On ferme et on se casse
OK = 1
ACTION = "FERME" : Gosub ACTION
If OK
 If SAVENV & !(VARIANTE & left$(GFLAG,1)="\")
  GDEP       = SAVDEP
  GFCY       = SAVFCY
  Call AFF_ENV From MENU
 Endif
 Gosub FERME_BOITE From =WINPROG
Endif
Gosub DEFAUT From =PROGOBJ
Filter [F]

If VARIANTE & left$(GFLAG,1)="\"
 Gosub FERME_MASK From =WINPROG
 If dim(NBMSKCMP)>0 & NBMSKCMP>0
  Gosub FERMSKCMP From =WINPROG
 Endif
 For I=1 To GNBBOU
  GETABOU(I) = 2
 Next I
 For I=1 To dim(GETAMEN)
  GETAMEN(I) = 2
 Next I
 GPILOBJ   -= (NBMEN-NBRMEN)
 If GPILOBJ<0 : GPILOBJ=0 : Endif : #99921
 Goto VARIANTE
Endif

#####################################################
# Fin
#####################################################

$SORT
Gosub FERME_MSK
# Restauration du contexte
For I=1 To dim(GSTAIMG)
 If SAVIMG(I)<>GSTAIMG(I)
  If SAVIMG(I)<>0
   Call SET_IMAGE(I) From GESECRAN
  Else
   Call RESET_IMAGE(I) From GESECRAN
  Endif
 Endif
Next I
Call SET_TEXTE(SAVTXT) From GOBJET
Call RESTBOUT From GESECRAN
Call RESET_MENU("GES"+GABREV) From EXEFNC
GREP       = SAVGREP
GGRPFCY    = SAVGGRPFCY
GSOCIETE   = SAVSOCIETE
GCURLEG    = SAVCURLEG
GCURFCY    = SAVCURFCY
GCHAINE    = SAVGCHAINE
GOBJET     = SAVOBJET
GORITITCOL = SAVTITCOL
GABREV     = SAVABR
GTRAITE    = SAVTRAITE
GFONCTION  = SAVFONC
GFONC1     = SAVFONC1
GPROGRAMME = SAVPROG
GBOITE     = SAVBOITE
GVARIANTE  = SAVVARIANTE
GFLAG      = SAVGFLAG : # TS le 22.09.99
currbox    = SAVBOX
GFCYDEF(0) = SAVFCYDEF
nolign     = SAVNOL2
indice     = SAVIND2
GCONSULT   = SAVGCONSULT # exigence 73847
GPILOBJ   -= (NBMEN-NBRMEN)+1
If GPILOBJ<0 : GPILOBJ=0 : Endif : #99921
For I=1 To (NBMEN-NBRMEN)+1
 GPILCOD(GPILOBJ+I) = ""
Next I
GPILNAV -= 1
GPILNAV = max(GPILNAV,0)
Call AUTORIS From EXEFNC : # pour recharger GUSRFCY, GUSRAUZ, GNBAUZ
GLOCALDEV  = SAVLOCALDEV
If CONNECT=1
#X3BY à traiter plus tard... Call DECONNECT(MODULE) From MULTI
Endif

# Empilements de l'explorateur de liaisons
If LNKFLG
 Read [ALI]ALI0 =
 K = instr(1,[F:ALI]DSTXXX,"|")
 If K
  ABREV = left$([F:ALI]DSTXXX,K-1)
  SAVCLE1  = right$([F:ALI]DSTXXX,K+1)
  Gosub CLE_LNK
  GNBMASKOUV-=1
  GNBMASKOUV=max(0,GNBMASKOUV)
  Goto DEBUT
 Endif
Elsif GPILLNK>0 & !PASLIEN
 ABREV = GOBJLNK(GPILLNK)
 GFLAG = GFLGLNK(GPILLNK)
 SAVCLE1  = GCLELNK(GPILLNK)
 GPILLNK -= 1
 Gosub CLE_LNK
#     Cas particulier de l'explorateur de liaison
 GNBMASKOUV-=1
 GNBMASKOUV=max(0,GNBMASKOUV)
 Goto DEBUT
Elsif REAFF_BOITE
 GNBMASKOUV -= 1
 GNBMASKOUV=max(0,GNBMASKOUV)
 If !TUNNEL
  Raz SAVCLE1 , SAVCLE2
 Endif
 Goto DEBUT
Endif

If find(ABREV,"AMK","AWI","ACN") & !TUNNEL
 Close Mask : # mb 16.4.3 Flush des masques
Endif

If SAVENV
 GDEP = SAVDEP
 GFCY = SAVFCY
 Call AFF_ENV From MENU
Endif

If dim(GNBMASKOUV)>0
  GNBMASKOUV-=1
  GNBMASKOUV=max(0,GNBMASKOUV)
Endif

End

#####################################################
# Sous-programmes
#####################################################

$CLE_LNK
Gosub SETCLE From ="WO"+ABREV
If CLESEC(0)<>""
 I = instr(1,SAVCLE1,"~")
 If I
  SAVCLE2 = right$(SAVCLE1,I+1)
  SAVCLE1  = left$(SAVCLE1,I-1)
 Else
  SAVCLE2 = ""
 Endif
Endif
LNKFLG = 0
Close Local File
Close Local Mask
Return

$FERME_SORT
ACTION = "FERME" : Gosub ACTION
Goto SORT

$DEVERROU
OK = 1
ACTION = "AVANT_DEVERROU" : Gosub ACTION : # mb 24.1.2 pb du lock posé avant tunnel
If !OK : Return : Endif
If !OVERROU
 Unlock =SYMBOLE
 ACTION = "DEVERROU" : Gosub ACTION
Endif
VERROU = 0
Return

$VERROU
If VERROU : Return : Endif
If dim(AIMGLCK)<0
 Local Integer AIMGLCK
 AIMGLCK = 3
Endif
OVERROU = 0
Gosub SYMBOLE
OK = 1
ACTION = "AVANT_VERROU" : Gosub ACTION
If !OK : Return : Endif
If TUNNEL
 Read [ALK]LCKCLE = SYMBOLE;0
 If !fstat & [F:ALK]LCKPID=adxuid(2)
  OVERROU = 1
 Endif
Endif
If GCONSULT
 VERROU = 0
 Return
Endif
OK = 1
If OVERROU=0
 If dim(VERROU_CRE)>0 & VERROU_CRE=11
  fstat=0
 Else
  Lock =SYMBOLE With lockwait=0
 Endif
 If fstat
  OK = 0 : GLOCK="%"+SYMBOLE
 Else
  ACTION = "VERROU" : Gosub ACTION
  If !OK : Unlock =SYMBOLE : Endif
 Endif
Endif
If OK
 VERROU = 1
 #If find(TYPGES,1,3)
 If find(TYPGES,1,2,3)
  Call RESET_IMAGE(AIMGLCK) From GESECRAN
 Endif
Else
 VERROU = 0
 OVERROU = 0
 If find(TYPGES,1,2,3) or (dim([L]MLOCK)>0 & [L]MLOCK)
  If (dim([L]MLOCK)>0 & [L]MLOCK)
   Read [ALK]LCKCLE = SYMBOLE;0
   If !fstat & [F:ALK]LCKPID<>adxuid(2)
    Call RESET_IMAGE(11) From GESECRAN
   Endif
  Endif
  Call SET_IMAGE(3) From GESECRAN
 Endif
Endif
Return

$SYMBOLE
Case TYPGES
 When 1
  SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,CLECUR1)
 When 2
  SYMBOLE = NOMFIC
  If dim([L]CLEFCY)>0 & [L]CLEPRIM=[L]CLEFCY
   SYMBOLE += "\"+[V]GFCY
  Elsif dim([L]CLEDEP)>0 & [L]CLEPRIM=[L]CLEDEP
   SYMBOLE += "\"+[V]GDEP
  Endif
 When 3
  SYMBOLE = ""
  If dim([L]CLEFCY)>0 & [L]CLEPRIM=[L]CLEFCY
   SYMBOLE += [V]GFCY
  Elsif dim([L]CLEDEP)>0 & [L]CLEPRIM=[L]CLEDEP
   SYMBOLE += [V]GDEP
  Else
   SYMBOLE += CLECUR1
  Endif
  SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,SYMBOLE)
Endcase
For CL=0 To dim(CLESEC)-1
 If TYPGES=3 & CLESEC(CL)=CLELIG : Break : Endif
 If CLESEC(CL)<>"" & (TYPGES<>2 | evalue("dim([M]"+CLESEC(CL)+")")<2)
  If dim([L]CLEFCY)>0 & CLESEC(CL)=[L]CLEFCY
   SYMBOLE += "\"+[V]GFCY
  Elsif dim([L]CLEFCY)>0 & CLESEC(CL)=[L]CLEDEP
   SYMBOLE += "\"+[V]GDEP
  Elsif TYPGES<>2 | dim([L]CLEVALEUR)<0 | CLESEC(CL)<>[L]CLEVALEUR
   SYMBOLE += "\"+CLECUR2(CL)
  Endif
 Endif
Next CL
Return

Subprog SET_TEXTE(NUM)
Value Integer NUM
If GSTATXT<>NUM
 Case NUM
  When 0 : Inftxt "  " At 2            : # Consultation
  When 1 : Inftxt mess(59,123,1) At 2  : # Création
  When 2 : Inftxt mess(172,123,1) At 2 : # Duplication
  When 3 : Inftxt mess(60,123,1) At 2  : # Modification
 Endcase
 GSTATXT = NUM
Endif
End

###############################################################
Subprog C_CLE(OBJET)
Value Char OBJET
If !GIMPORT & (type(zc)>10 & zc="") : # | (type(zc)<10 & zc=0)
 mkstat = 1
Endif
End : # Le reste n'a plus lieu d'être

###############################################################
Subprog CONT_WRK(ABREV,OPTWRK)
Value Char ABREV
Variable Integer OPTWRK
Local File AWRKPAR [AW__]
OPTWRK = 0
For [AW__]AWA1
 OPTWRK =  ([F:AW__]TYPEVT=1 & [F:AW__]CODEVT="BUT")
 OPTWRK += ([F:AW__]TYPEVT=2 & [F:AW__]CODEVT=ABREV & instr(1,[F:AW__]OPERATION,"W"))
 OPTWRK *= ([F:AW__]ENAFLG=2 & ([F:AW__]ENAMES=2 | [F:AW__]ENASUI=2 | [F:AW__]ENAACT=2))
 If OPTWRK : Break : Endif
Next AW__
Close Local File[AW__]
End

###############################################################
Subprog CONT_ENA(NOMFIC,OPTENA)
Value    Char    NOMFIC
Variable Integer OPTENA
Local File =NOMFIC [NF__]
OPTENA = (dim([F:NF__]ENAFLG)>0)
Close Local File [NF__]
End

###############################################################
Subprog CONT_SIG(OPTSIG)
Variable Integer OPTSIG
Local File AWRKPAR [AW__] , AWRKPARF [AF__]
Link [AW__]
& With [AF__]AWF0=[F:AW__]CODE
& As [LN__]
& Where [F:AW__]ENAFLG=2 & [F:AW__]TYPEVT=2 & find([F:AW__]CODEVT,GABREV,"")<>0 & [F:AF__]NBRSIG>0
OPTSIG = 0
For [LN__]
 OPTSIG = 1
 Break
Next LN__
Close Local File [AW__] , [AF__]
End

###############################################################
Subprog CONT_LCK(OPTLCK)
Variable Integer OPTLCK
Local File AWRKPAR [AW__]
OPTLCK = 0
For [AW__]AWA1 Where [F:AW__]TYPEVT=1 & [F:AW__]CODEVT="ALK" & [F:AW__]ENAFLG=2 & [F:AW__]ENAMES=2
 OPTLCK = 1 : Break
Next AW__
Close Local File[AW__]
End

###############################################################
Subprog CONT_DOC(OPTDOC)
Variable Integer OPTDOC
Local File ATABDIV   [AD__]
Filter [AD__] Where N1<>2
Look [AD__]CODE = 910;GABREV
OPTDOC = !fstat
Filter [AD__]
End

###############################################################
Subprog CONT_FEN(ABREV,FENETRE)
Value Char ABREV
Variable Char FENETRE
Local File AWINDOW [AWI]
Local File ACTIV   [ACV]
Filter [AWI] Where OBJ=ABREV & ENAFLG=2 & MDL<>2
Read [AWI]AWI0 = "O"+ABREV
If fstat
 [F:AWI]WIN = ""
Elsif [F:AWI]CODACT<>""
 Read [ACV]CODACT = [F:AWI]CODACT
 If fstat or [F:ACV]FLACT<>2
  [F:AWI]WIN = ""
 Endif
Endif
If [F:AWI]WIN<>"" & [F:AWI]ACS<>"" & GUSRACS<>2
 If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
 Read [ACC]CODACC = GUSER;[F:AWI]ACS
 If fstat or [F:ACC]EXEC<>2
  [F:AWI]WIN = ""
 Endif
Endif
If [F:AWI]WIN=""
 For [AWI]
  If [F:AWI]CODACT<>""
   Read [ACV]CODACT = [F:AWI]CODACT
   If fstat or [F:ACV]FLACT<>2
    [F:AWI]WIN = ""
   Endif
  Endif
  If [F:AWI]WIN<>"" & [F:AWI]ACS<>"" & GUSRACS<>2
   If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
   Read [ACC]CODACC = GUSER;[F:AWI]ACS
   If fstat or [F:ACC]EXEC<>2
    [F:AWI]WIN = ""
   Endif
  Endif
  If [F:AWI]WIN<>"" : Break : Endif
 Next AWI
Endif
Filter [AWI]
FENETRE = [F:AWI]WIN
Close Local File [AWI] , [ACV]
End

###############################################################
$ACTION
Gosub ACTION From GOBJSUB
Return

Subprog VIREBOUT(CHAINE,LISTE)
Variable Char CHAINE()
Value    Char LISTE
Local Integer I, K
For I=1 To len(LISTE)
 K = instr(1,CHAINE,mid$(LISTE,I,1))
 If K : CHAINE = left$(CHAINE,K-1)+right$(CHAINE,K+1) : Endif
Next I
End

#################################################################
$DEFVAR
Local Integer MAXBOU : MAXBOU = 80                       : # 114910 Nb max de boutons spéciaux
Local Integer  NUMESPION
Local Integer  MA , MAMAX , MANEW , NRMASK , MA2
Local Integer  CRE , OK , PRMASK , IMA , MACUR , DUP , RET , ERR , FOK , SUPPR , FIN
Local Integer  AUTENA , OPTENA , SAVENA , OPTDOC , OPTSIG , OPTWRK , OPTLCK
Local Integer  I , J , K , L , N , RELIT
Local Integer  NPAG , NBTEX , PPAG
Local Integer  AMA(0..16) , MODI , RESTMSK(0..16)
Local Integer  CHX , SVSTA , TEMPON
Local Integer  CLECUR , CL , TYPGES , INDCUR , INDGES
Local Integer  CONNECT , MODULE , ISITE
Local Char     CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16) , SITCUR(GLONFCY)
Local Char     OCLECUR1(GLONID1) , OCLECUR2(GLONID2)(0..16) , CLE(250)
Local Char     CLE2(GLONID2)(0..16), CLECRE(GLONAVA)
Local Char     NEWCLE1(GLONID1) , NEWCLE2(GLONID2)(0..16)
Local Integer  TPCLE1 , TPCLE2(0..16)
Local Char     REP(1) , SAVREP(1) , SAVGREP(1) , SAVGGRPFCY(GLONAGF)
Local Char     SAVSOCIETE(GLONCPY) , SAVCURLEG(GLONADI) , SAVCURFCY(GLONFCY)
Local Char     CHAINE(60) , SAVGCHAINE(60) , OPTION(10) , SYMBOLE(GLONASYM)
Local Char     TEX(20)(30) , TEXTE(30)(30) , CBOUT(1)(30) , STDBOUT(60) , CBOUTD(1)
Local Integer  LBOUT(MAXBOU) :#114910
Local Char     PROGOBJ(GLONADC) , PROGVAR(GLONADC) , PROGOBJL(GLONADC)
Local Char     PROGSPV(GLONADC)(1..50) , PROGSUB(GLONADC) , PROGSPE(GLONADC)
Local Char     ACTION(20), ERRMES(50)
Local Integer  PSPE , PSUB , PSPV
Local Char     CRITTAB(250) , CRITSEL(250)
Local Char     FILTRE(240) , FILTSUP(240) , CRITERE(250)
