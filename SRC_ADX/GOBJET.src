Endif

Addmen GSTAMEO+GPILOBJ Titled mess(18,100,1) To 307 At 80              : # Sélection
Additm GSTASEL Titled mess(173,124,1)        To GSTAMEO+GPILOBJ At 10  : # Sélection avancée
If instr(1,STDBOUT,"Q")
 Addmen GSTAMEO2+GPILOBJ Titled mess(39,310,1) To GSTAMEO+GPILOBJ At 11  : # Sélection picking
 Additm GSTAPCK  Titled mess(173,124,1)        To GSTAMEO2+GPILOBJ At 10 : # Sélection avancée
 Additm GSTAPCK1 Titled mess(43,310,1)         To GSTAMEO2+GPILOBJ At 11 : # Tout cocher
 Additm GSTAPCK2 Titled mess(44,310,1)         To GSTAMEO2+GPILOBJ At 12 : # Tout décocher
Endif

Raz SEL_MEMO2, MEMGLO2, J, K, CHAINE

If [L]MEMPCKCOD<>""
 # Mémos globaux
 Filter [AOS] Where CODE=[L]MEMPCKCOD & ALL=2  Order By Key AOS1 Desc
 For [AOS]
  If J>=dim(SEL_MEMO2)/2 : Break : Endif
  Call LECTEXTRA([L]CHAINE,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
& From ATEXTRA
  If J=0
   K += 1 : Additm GSTAITO2 Titled "" To GSTAMEO2+GPILOBJ At 50+K : # Trait de séparation
  Endif
  J += 1 : K += 1
  Additm GSTAITO2+J Titled [L]CHAINE To GSTAMEO2+GPILOBJ At 50+K
  SEL_MEMO2(J) = [F:AOS]MEMO
  INT_MEMO2(J) = [L]CHAINE
 Next AOS
 If J>0 : K += 1 : Additm GSTAITO2 Titled "" To GSTAMEO2+GPILOBJ At 50+K : Endif : # Trait de séparation
 MEMGLO2 = J

 # Mémos utilisateur
 Filter [AOS] Where CODE=[L]MEMPCKCOD & ALL<>2 & USR=GUSER Order By Key AOS1 Desc
 For [AOS]
  If J>=dim(SEL_MEMO2)-1 : Break : Endif : # Le dernier est réservé à 'Tous'
  Call LECTEXTRA([L]CHAINE,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
& From ATEXTRA
  If J=0
   K += 1 : Additm GSTAITO2 Titled "" To GSTAMEO2+GPILOBJ At 50+K : # Trait de séparation
  Endif
  J += 1 : K += 1
  Additm GSTAITO2+J Titled [L]CHAINE To GSTAMEO2+GPILOBJ At 50+K
  SEL_MEMO2(J) = [F:AOS]MEMO
  INT_MEMO2(J) = [L]CHAINE
 Next AOS
 If J>0
  If J>MEMGLO2
   Additm GSTAITO2 Titled "" To GSTAMEO2+GPILOBJ At 50+K+1 : # Trait de séparation
  Endif
  Additm GSTAITO2+J+1 Titled mess(210,133,1) To GSTAMEO2+GPILOBJ At 50+K+2 : # Tous
 Endif
Endif

##

Additm GSTAMOT Titled mess(89,126,1) To GSTAMEO+GPILOBJ At 12 : # Sélection mot-clé

# Recherche nombre total de mémos
Filter [AOS] Where CODE=[L]NOMFIC  Order By Key AOS1 Desc
L = rowcount([F:AOS])
If L>dim(SEL_MEMO)
 L = dim(SEL_MEMO)
Else
 L = dim(SEL_MEMO)/2
Endif

Raz SEL_ALL, SEL_MEMO, MEMGLO, J, K, N

Filter [AOS] Where CODE=[L]NOMFIC & ALL=2  Order By Key AOS1 Desc : # Mémos globaux
For [AOS]
 If J>=L-1 : Break : Endif
 Call LECTEXTRA([L]CHAINE,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
& From ATEXTRA
 If J=0 : Additm GSTAITO Titled "" To GSTAMEO+GPILOBJ At 49 : Endif : # Trait de séparation
 J += 1 : K += 1
 Additm GSTAITO+J Titled [L]CHAINE To GSTAMEO+GPILOBJ At 50+K
 SEL_MEMO(J) = [F:AOS]MEMO
 INT_MEMO(J)  = [L]CHAINE
 If [F:AOS]MEMO="STD" & NUMITM<0 : N = J : Endif
Next AOS
If J>0 : K += 1 : Additm GSTAITO Titled "" To GSTAMEO+GPILOBJ At 50+K : Endif : # Trait de séparation
MEMGLO = J
Filter [AOS] Where CODE=[L]NOMFIC & ALL<>2 & USR=GUSER Order By Key AOS1 Desc : # Mémos utilisateur
For [AOS]
 If J>=L-1 : Break : Endif : # Le dernier est réservé à 'Tous'
 Call LECTEXTRA([L]CHAINE,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
& From ATEXTRA
 If J=0 : Additm GSTAITO Titled "" To GSTAMEO+GPILOBJ At 49 : Endif : # Trait de séparation
 J += 1 : K += 1
 Additm GSTAITO+J Titled [L]CHAINE To GSTAMEO+GPILOBJ At 50+K
 SEL_MEMO(J) = [F:AOS]MEMO
 INT_MEMO(J) = [L]CHAINE
 If [F:AOS]MEMO="STD" & NUMITM<0 : N = J : Endif
Next AOS
Filter [AOS]
If !OK : Close Local File [AOS] : Endif
If J>0
 If J>MEMGLO
  Additm GSTAITO Titled "" To GSTAMEO+GPILOBJ At 50+K+1
 Endif
 Additm GSTAITO+J+1 Titled mess(210,133,1) To GSTAMEO+GPILOBJ At 50+K+2 : # Tous
 SEL_ALL = GSTAITO+J+1
Elsif NUMITM=99
 Additm GSTAITO Titled "" To GSTAMEO+GPILOBJ At 50+1
 Additm GSTAITO+1 Titled mess(210,133,1) To GSTAMEO+GPILOBJ At 50+2 : # Tous
Endif

If NUMITM<0 : NUMITM = N : Endif : # Mémo standard chargé au début

Return

# Définition contextuelle des menus de workflow
$DEFMENSIG
Addmen 40000+GPILOBJ Titled mess(71,75,1)   To 307 At 104             : # Signature
Additm GSTASIG       Titled mess(71,75,1)   To 40000+GPILOBJ At 10    : # Signature
Additm GSTAHSG       Titled mess(118,75,1)  To 40000+GPILOBJ At 20    : # Historique signature
Additm GSTACSG       Titled mess(161,75,1)  To 40000+GPILOBJ At 30    : # Circuit de signature
Return

# Menu documentation
$CHARGE_MENDOC
Addmen GSTAMED+GPILOBJ Titled mess(108,139,1) To 307 At 102             : # Documentation
Additm GSTADOC1 Titled mess(109,139,1)        To GSTAMED+GPILOBJ At 10  : # Paragraphes
Additm GSTADOC2 Titled mess(130,133,1)        To GSTAMED+GPILOBJ At 11  : # Liens
If !GCONSULT
 Additm GSTADOC3 Titled mess(29,115,1)         To GSTAMED+GPILOBJ At 12 : # Génération
Endif
Return

