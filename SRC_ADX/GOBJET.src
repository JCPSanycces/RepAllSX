$RELIT
Gosub RELIT From GOBJSUB
Return

$CTL_VARIANTE
Local Integer OK
 OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat | [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK & [F:AWI]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:AWI]ACS
  If fstat | [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If !OK
  GFLAG = "\"
 Endif
Return

$SAI_VARIANTE
Local Integer VARINB , VARIREP
Local Char    VARITEX(GLONDES+10)(500) : #107616
Local Char    VARICOD(GLONATN)(500)
Local Char    VARIBOI(GLONFEN)(500)
Local Char    VARCOD(GLONATN)

VARINB = 0
GFLAG = right$(GFLAG,2)
For [AWI]AWI2 Where OBJ=ABREV & ENAFLG=2 & MDL<>2
 OK = 1
 If [F:AWI]CODACT<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Read [ACV]CODACT = [F:AWI]CODACT
  If fstat | [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK & [F:AWI]ACS<>"" & GUSRACS<>2
  If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
  Read [ACC]CODACC = GUSER;[F:AWI]ACS
  If fstat | [F:ACC]EXEC<>2
   OK = 0
  Endif
 Endif
 If OK
  VARCOD = [F:AWI]TRN
  ACTION = "VARIANTE" : Gosub ACTION
 Endif
 If OK
  If VARINB<dim(VARIBOI)-2
   CHAINE = ""
   Call TITTRN(VARCOD,CHAINE) From =PROGOBJ
   If CHAINE<>"!"
    VARINB += 1
    VARIBOI(VARINB) = [F:AWI]WIN
    VARICOD(VARINB) = VARCOD
    If CHAINE<>""
     VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
    Elsif dim([F:AWI]LIBEL)>0 & [F:AWI]LIBEL<>""
     VARITEX(VARINB) = format$("K:8X",VARCOD)+[F:AWI]LIBEL
    Else
     Call TEXTE([F:AWI]DES,CHAINE) From OBJDIV
     VARITEX(VARINB) = format$("K:8X",VARCOD)+CHAINE
    Endif
    ACTION = "L_VARIANTE" : Gosub ACTION
    If GFLAG=VARICOD(VARINB) : VARIREP = VARINB : Endif
   Endif
   ACTION = "P_VARIANTE" : Gosub ACTION
  Endif
 Endif
Next AWI
If VARINB=0
 Call MESSAGE(mess(4,126,1)) From GESECRAN : # Aucune transaction autorisée
 GFLAG = ""
Elsif VARINB=1
 GFLAG  = VARICOD(1)
 GBOITE = VARIBOI(1)
 If GFLAG="" GFLAG="1-3-5-7-9-" Endif : # TS pas de code transaction si objet sans variante
Else
 If VARIREP=0 : VARIREP = 1 : Endif
 Call SAITRANS(VARINB,VARITEX,VARIREP,mess(3,126,1)) From GOBJACT
 If status<>7 & VARIREP<>0
  GFLAG  = VARICOD(VARIREP)
  GBOITE = VARIBOI(VARIREP)
 Else
  GFLAG = ""
 Endif
Endif
Return

######################################################
# Marquage objets modifiés Sophia/Gaillard
######################################################

Subprog TRACE_COR(OBJET,CLE1,CLE2,TRA)
Value Char OBJET, CLE1, CLE2, TRA
#CHECK UNUSED_BEGIN
Local Char ERRMES(250)
Local Integer STAT
If GSOPHIA & filinfo(filpath("FIL","XXCORT","fde"),0)>0
 Call TRACE_COR(OBJET,CLE1,CLE2,TRA) From SUBXCB
Endif
If func ASYRFNC.IS_UPDATE_MONGO>[V]CST_AFALSE
 # Issue X3-59645 - 2018-01-22 by CCC : display the error
 #Call UPD_META(OBJET,CLE1,CLE2,TRA) From ASYRMETA
 STAT = func ASYRMETA.UPD_META(OBJET,CLE1,CLE2,TRA,ERRMES)
 If STAT<>[V]CST_AOK
    Call ECR_TRACE("ASYRMETA.UPD_META error code"-num$(STAT)-ERRMES,1) From GESECRAN
 Endif
Endif
#CHECK UNUSED_END
End

Subprog TRACE_COR_PATCH(OBJET,CLE1,CLE2,TRA)
Value Char OBJET, CLE1, CLE2, TRA
#CHECK UNUSED_BEGIN
Call TRACE_COR(OBJET,CLE1,CLE2,TRA)
#CHECK UNUSED_END
End

Subprog VERIF_GRP(OBJET,CLE1,CLE2,OK)
Value Char OBJET, CLE1, CLE2
Variable Integer OK
#CHECK UNUSED_BEGIN
If GSOPHIA & filinfo(filpath("FIL","AOBJGRPDEV","fde"),0)>0 & func APRODUCT.AGETRELEASESUP<"R080.001"
 Call VERIF_GRP(OBJET,CLE1,CLE2,OK) From SUBXCB
Endif
#CHECK UNUSED_END
End

#########################################################################
# Les objets Superviseur doivent être modifiés dans l'appli superviseur
#########################################################################

Subprog CRE_SUP(MODULE)
Value Integer MODULE
Local Integer CRE
CRE = 1
Goto CREMOD

Subprog MODIF_SUP(MODULE)
Value Integer MODULE
Local Integer CRE
CRE = 0

$CREMOD
#CHECK UNUSED_BEGIN
If !(GSOPHIA & MODULE=1 & (GPRODUIT=-1 or nomap="GX3APP"))
 End
Endif
Local File XXCORU [XCU]
Read [XCU]XCU0(1)=GUSER
If fstat or [F:XCU]MODULE<>1
 Local Char MESSA(200)
 MESSA = ""
 If GPRODUIT=-1 & CRE
  MESSA = "You just create an object with the module 'Supervisor'"
  MESSA += "\If you don't want this object to be integrated in other products,"
  MESSA += "\you have to assign it to 'Internal' module"
 Elsif nomap="GX3APP"
  Case CRE
   When 1       : MESSA = "You just create an object"-mess(1,14,1)
                  MESSA += "\You have to backport this creation in the 'supervisor' application"
   When Default : MESSA = "You just update an object"-mess(1,14,1)
                  MESSA += "\You have to backport this update in the 'supervisor' application"
  Endcase
 Endif
 If MESSA<>""
  Call MESSAGE(MESSA) From GESECRAN
 Endif
Endif
#CHECK UNUSED_END
End

######################################################
# Pour la gestion auto du Nohint
######################################################

Subprog GESNOH(NOMFIC,A_INDEX,CLELISTE,ILIS,A_TRELIS,CRITERE,FILGAUSUP,FILSUITE,FILTSUP,FILROLE,A_NOH)
Value    Char    NOMFIC,A_INDEX,CLELISTE
Value    Integer ILIS,A_TRELIS
Value    Char    CRITERE,FILGAUSUP,FILSUITE,FILTSUP,FILROLE
Variable Integer A_NOH
Gosub NOH
End

# Etiquettes appelées depuis les traitements WGO* pour les Fillbox
$CALNOH
$CALNOHOBJ
Local Integer A_TRELIS , A_NOH
Local Char    A_INDEX(250)
A_TRELIS = [L]TRELIS(ILIS)
A_INDEX  = [L]DESLIS(ILIS)

$NOH
Local Char    A_CAR(30), A_BLC(30), A_CLES(GLONAVA)(1..16), A_CLE(20)
Local Integer N_CLES, A_TROUVE
Local Char    A_PRIM(250)
If dim(GORAOPTMIZ)>0 & GORAOPTMIZ=2
 A_NOH = 0 : Return
Endif
A_CAR = "<>=+-*/^()'&|[],:$"+'"' : # Caractères à remplacer dans les filtres
A_BLC = space$(len(A_CAR))
A_NOH = 0
# Hiérarchisée/Picking/Récursive
If (find(A_TRELIS,2,3,4)<>0 & A_INDEX<>"") or dim(CLELISTE)<0 or CLELISTE=""
 A_PRIM = A_INDEX
 I = instr(1,A_PRIM,"+")
 J = instr(1,A_PRIM,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  A_PRIM = left$(A_PRIM,I-1) : # La première partie de clé
 Endif
Else
 A_PRIM = CLELISTE
 I = instr(1,A_PRIM,";")
 If I
  A_PRIM = left$(A_PRIM,I-1)
 Endif
 A_PRIM = vireblc(A_PRIM,2)
 I = instr(1,A_PRIM," ") : # Pour virer Asc ou Desc
 If I
  A_PRIM = left$(A_PRIM,I-1)
 Endif
Endif
A_CLE = " "+A_PRIM+" "
If ILIS : # Listes de gauche secondaires
 A_NOH += (sum(CRITERE,FILGAUSUP,FILSUITE)=string$(3,"1=1"))
 A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+CRITERE+" ")),A_CAR,A_BLC),A_CLE))
 For I=0 To dim(FILGAUSUP)-1
  A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILGAUSUP(I)+" ")),A_CAR,A_BLC),A_CLE))
 Next I
 For I=0 To dim(FILSUITE)-1
  A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILSUITE(I)+" ")),A_CAR,A_BLC),A_CLE))
 Next I
Else : # Liste de gauche principale
 A_NOH += (sum(CRITERE,FILTSUP,FILROLE,FILSUITE)=string$(4,"1=1"))
 A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+CRITERE+" ")),A_CAR,A_BLC),A_CLE))
 A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILTSUP+" ")),A_CAR,A_BLC),A_CLE))
 For I=0 To dim(FILROLE)-1
  A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILROLE(I)+" ")),A_CAR,A_BLC),A_CLE))
 Next I
 For I=0 To dim(FILSUITE)-1
  A_NOH += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILSUITE(I)+" ")),A_CAR,A_BLC),A_CLE))
 Next I
 If A_NOH
  Call CLES(NOMFIC,A_CLES,N_CLES)
  For I=1 To N_CLES
   If A_CLES(I)<>A_PRIM
    A_CLE = " "+A_CLES(I)+" "
    A_TROUVE = 0
    A_TROUVE += (instr(1,ctrans(format$("KT:250X",tolower(" "+CRITERE+" ")),A_CAR,A_BLC),A_CLE))
    A_TROUVE += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILTSUP+" ")),A_CAR,A_BLC),A_CLE))
    For J=0 To dim(FILROLE)-1
     A_TROUVE += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILROLE(J)+" ")),A_CAR,A_BLC),A_CLE))
    Next J
    For J=0 To dim(FILSUITE)-1
     A_TROUVE += (instr(1,ctrans(format$("KT:250X",tolower(" "+FILSUITE(J)+" ")),A_CAR,A_BLC),A_CLE))
    Next J
    If A_TROUVE
     A_NOH = 0 : Break
    Endif
   Endif
  Next I
 Endif
Endif
Return

Subprog CLES(NOMFIC,A_CLES,N_CLES)
Value    Char    NOMFIC
Variable Char    A_CLES()(1..)
Variable Integer N_CLES
Local Integer I , J , K
Local Char    A_CHAINE(250)
Local File ATABIND [AI__] , AINDEX [AX__] , ACTIV [AC__]
Raz A_CLES , N_CLES
For [AI__] Where CODFIC=NOMFIC
 K = 1
 If [F:AI__]CODACT<>""
  Read [AC__]CODACT = [F:AI__]CODACT
  If fstat | [F:AC__]FLACT<>2
   K = 0
  Endif
 Endif
 If K
  A_CHAINE = [F:AI__]DESCRIPT
  I = instr(1,A_CHAINE,"+")
  J = instr(1,A_CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  If I
   A_CHAINE = left$(A_CHAINE,I-1)
  Endif
  If !find(A_CHAINE,A_CLES)
   N_CLES += 1
   A_CLES(N_CLES) = A_CHAINE
  Endif
 Endif
Next AI__
For [AX__]ANX1 Where TABLE=NOMFIC & FLACT=2
 A_CHAINE= [F:AX__]DESCRIPT
 I = instr(1,A_CHAINE,"+")
 J = instr(1,A_CHAINE,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  A_CHAINE = left$(A_CHAINE,I-1)
 Endif
 If !find(A_CHAINE,A_CLES)
  N_CLES += 1
  A_CLES(N_CLES) = A_CHAINE
 Endif
Next AX__
Close Local File [AI__] , [AX__] , [AC__]
End

