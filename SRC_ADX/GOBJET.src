 When 11 : [M] = [M:SV11]
 When 12 : [M] = [M:SV12]
 When 13 : [M] = [M:SV13]
 When 14 : [M] = [M:SV14]
 When 15 : [M] = [M:SV15]
 When 16 : [M] = [M:SV16]
Endcase
GNBMASK -= 1
