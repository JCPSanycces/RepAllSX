#<AdxTL>@(#)8.0.0.0 $Revision$
#####################################################
## Datamart
#####################################################
$DICABM
# MAJ dictionnaire - Datamart
Call ECR_TIME(mess(15,125,1)-mess(41,127,1)) From DOSSUB

Local File =GDOSREF+".ABIDATMRT"         [ABM]
Local File =[F:ADS]DOSSIER+".ABIDATMRT"  [DABM]
Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]
Local Char    A_CODABF(GLONABF)(0..dim([DABM]CODABF))
Local Char    A_ACTABF(GLONABF)(0..dim([DABM]CODABF))
Local Integer A_NBRABF
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(41,127,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DABM]
  For [DABM] Where COD<GXX
   Call SPEC([F:DABM]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ABM]ABM0 = [F:DABM]COD
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DABM]COD,0) From GESECRAN
     Delete [DABM] Where COD=[F:DABM]COD
     If fstat=1 : Call ERREUR("ABIDATMRT"-[F:DABM]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next DABM
 Commit
Endif
For [ABM] Where COD<GXX
 ACTIV = 0
 Trbegin [DABM]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DABM]ABM0 = [F:ABM]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DABM]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ABM]CODACT,[F:ABM]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:ABM]COD,0) From GESECRAN
    Delete [DABM] Where COD=[F:ABM]COD
    If fstat=1 : Call ERREUR("ABIDATMRT"-[F:ABM]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DABM]
    [F:DABM] = [F:ABM]
    If dim([F:DABM]CREDAT)>0 : [F:DABM]CREDAT = date$ : Endif
    If dim([F:DABM]CREUSR)>0 : [F:DABM]CREUSR = GUSER : Endif
    If dim([F:DABM]CRETIM)>0 : [F:DABM]CRETIM = time  : Endif
    Write [DABM]
    If fstat : Call ERREUR("ABIDATMRT"-[F:DABM]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    DIFF = 0
    Raz A_NBRABF,A_CODABF,A_ACTABF
    For I=0 To dim([F:DABM]CODABF)-1
     If [DABM]ACTABF(I) <> ""
      Call SPEC([F:DABM]ACTABF(I),SPEC) From DOSSUB
      If SPEC
       A_CODABF(A_NBRABF) = [DABM]CODABF(I)
       A_ACTABF(A_NBRABF) = [DABM]ACTABF(I)
       A_NBRABF +=1
      Endif
     Endif
    Next I
    Call DIFFACT([F:ADS]DOSSIER,[F:ABM]CODACT,ACTIV) From DOSSUB
    If [F:ABM]CODACT    <> [F:DABM]CODACT     : DIFF = 1  : Endif
    If [F:ABM]MODULE    <> [F:DABM]MODULE     : DIFF = 3  : Endif
    If [F:ABM]NBRABF    <> [F:DABM]NBRABF     : DIFF = 4  : Endif
    If [F:ABM]ABR       <> [F:DABM]ABR        : DIFF = 5  : Endif
    If [F:ABM]AUZFCY    <> [F:DABM]AUZFCY     : DIFF = 6  : Endif
    If [F:ABM]FNC       <> [F:DABM]FNC        : DIFF = 7  : Endif
    If [F:ABM]INTIT     <> [F:DABM]INTIT      : DIFF = 8  : Endif
    If [F:ABM]ANSI      <> [F:DABM]ANSI       : DIFF = 9  : Endif
    If [F:ABM]MESURE    <> [F:DABM]MESURE     : DIFF = 10 : Endif
    If [F:ABM]DATNUL    <> [F:DABM]DATNUL     : DIFF = 11 : Endif
    If [F:ABM]PREFIX    <> [F:DABM]PREFIX     : DIFF = 12 : Endif
    If [F:ABM]COMPL     <> [F:DABM]COMPL      : DIFF = 12 : Endif
    If [F:ABM]SCLASS    <> [F:DABM]SCLASS     : DIFF = 13 : Endif
    For I=0 To min(dim([F:ABM]CODABF)-1,dim([F:DABM]CODABF)-1)
     If [F:ABM]CODABF(I)    <> [F:DABM]CODABF(I)     : DIFF = 5  : Break  : Endif
     If [F:ABM]ACTABF(I)    <> [F:DABM]ACTABF(I)     : DIFF = 5  : Break  : Endif
    Next I
    If !DIFF : Call TXT([F:ABM]INTIT,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff datamart"-[F:ABM]COD-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DABM] = [F:ABM]
     Raz [F:DABM]NBRABF,[F:DABM]CODABF,[F:DABM]ACTABF
     For K=0 To [F:ABM]NBRABF-1
      If !find([F:ABM]CODABF(K),A_CODABF(0..A_NBRABF))
       A_CODABF(A_NBRABF) = [F:ABM]CODABF(K)
       A_ACTABF(A_NBRABF) = [F:ABM]ACTABF(K)
       A_NBRABF += 1
      Endif
     Next K
     [F:DABM]NBRABF = A_NBRABF
     For I=0 To A_NBRABF-1
      [F:DABM]CODABF(I) = A_CODABF(I)
      [F:DABM]ACTABF(I) = A_ACTABF(I)
     Next I
     If dim([F:DABM]UPDDAT)>0 : [F:DABM]UPDDAT = date$ : Endif
     If dim([F:DABM]UPDUSR)>0 : [F:DABM]UPDUSR = GUSER : Endif
     If dim([F:DABM]UPDTIM)>0 : [F:DABM]UPDTIM = time : Endif
     Rewrite [DABM]
    Elsif ACTIV
     If dim([F:DABM]UPDDAT)>0 : [F:DABM]UPDDAT = date$ : Endif
     If dim([F:DABM]UPDUSR)>0 : [F:DABM]UPDUSR = GUSER : Endif
     If dim([F:DABM]UPDTIM)>0 : [F:DABM]UPDTIM = time : Endif
     Rewrite [DABM]
    Endif
    If fstat : Call ERREUR("ABIDATMRT"-[F:DABM]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [ABM] , [DABM] , [DACV]
Return

#####################################################
## Hierarchie
#####################################################
$DICAHH
# MAJ dictionnaire - Hierarchie
Call ECR_TIME(mess(15,125,1)-mess(43,127,1)) From DOSSUB
Local File =GDOSREF+".ABIHIERA" [AHH]
Local File =[F:ADS]DOSSIER+".ABIHIERA"   [DAHH]
Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]

Local Integer WMODULE

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(43,127,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DAHH]
  For [DAHH] Where COD<GXX
   Call SPEC([F:DAHH]ACV,SPEC) From DOSSUB
   If !SPEC
    Read [AHH]AHH0 = [F:DAHH]COD
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DAHH]COD,0) From GESECRAN
     Delete [DAHH] Curr
     If fstat=1 : Call ERREUR("ABIHIERA"-[F:DAHH]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next DAHH
 Commit
Endif
For [AHH] Where COD<GXX
 ACTIV = 0
 Trbegin [DAHH]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAHH]AHH0 = [F:AHH]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DAHH]ACV,SPEC) From DOSSUB
  Endif
  If dim([F:AHH]MODULE)<0 : WMODULE=0 : Else : WMODULE=[F:AHH]MODULE : Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AHH]ACV,WMODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:AHH]COD,0) From GESECRAN
    Delete [DAHH] Where COD=[F:AHH]COD
    If fstat=1 : Call ERREUR("ABIHIERA"-[F:AHH]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DAHH]
    [F:DAHH] = [F:AHH]
    If dim([F:DAHH]CREDAT)>0 : [F:DAHH]CREDAT = date$ : Endif
    If dim([F:DAHH]CREUSR)>0 : [F:DAHH]CREUSR = GUSER : Endif
    If dim([F:DAHH]CRETIM)>0 : [F:DAHH]CRETIM = time : Endif
    Write [DAHH]
    If fstat : Call ERREUR("ABIHIERA"-[F:DAHH]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    DIFF = 0
    Call DIFFACT([F:ADS]DOSSIER,[F:AHH]ACV,ACTIV) From DOSSUB
    If [F:AHH]ABM       <> [F:DAHH]ABM        : DIFF = 1  : Endif
    If [F:AHH]ACV       <> [F:DAHH]ACV        : DIFF = 2  : Endif
    If [F:AHH]NBAHH     <> [F:DAHH]NBAHH      : DIFF = 3  : Endif
    For I=0 To [F:AHH]NBAHH-1
     If [F:AHH]CODABF(I)      <> [F:DAHH]CODABF(I)      : DIFF = 4  : Break  : Endif
     If [F:AHH]CODFLD(I)      <> [F:DAHH]CODFLD(I)      : DIFF = 4  : Break  : Endif
     If [F:AHH]TYPOPT(I)      <> [F:DAHH]TYPOPT(I)      : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM1(I)     <> [F:DAHH]CODDIM1(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM1(I)     <> [F:DAHH]FLDDIM1(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM2(I)     <> [F:DAHH]CODDIM2(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM2(I)     <> [F:DAHH]FLDDIM2(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM3(I)     <> [F:DAHH]CODDIM3(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM3(I)     <> [F:DAHH]FLDDIM3(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM4(I)     <> [F:DAHH]CODDIM4(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM4(I)     <> [F:DAHH]FLDDIM4(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM5(I)     <> [F:DAHH]CODDIM5(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM5(I)     <> [F:DAHH]FLDDIM5(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]CODDIM6(I)     <> [F:DAHH]CODDIM6(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM6(I)     <> [F:DAHH]FLDDIM6(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM7(I)     <> [F:DAHH]FLDDIM7(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM8(I)     <> [F:DAHH]FLDDIM8(I)     : DIFF = 4  : Break  : Endif
     If [F:AHH]FLDDIM9(I)     <> [F:DAHH]FLDDIM9(I)     : DIFF = 4  : Break  : Endif
    Next I
    If dim([F:AHH]MODULE)>0 & dim([F:DAHH]MODULE)>0
     If [AHH]MODULE<> [DAHH]MODULE : DIFF = 5 : Endif  : # module
    Endif
    If !DIFF : Call TXT([F:AHH]DES,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff hierarchie"-[F:AHH]COD-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DAHH] = [F:AHH]
     If dim([F:DAHH]UPDDAT)>0 : [F:DAHH]UPDDAT = date$ : Endif
     If dim([F:DAHH]UPDUSR)>0 : [F:DAHH]UPDUSR = GUSER : Endif
     If dim([F:DAHH]UPDTIM)>0 : [F:DAHH]UPDTIM = time : Endif
     Rewrite [DAHH]
    Elsif ACTIV
     If dim([F:DAHH]UPDDAT)>0 : [F:DAHH]UPDDAT = date$ : Endif
     If dim([F:DAHH]UPDUSR)>0 : [F:DAHH]UPDUSR = GUSER : Endif
     If dim([F:DAHH]UPDTIM)>0 : [F:DAHH]UPDTIM = time : Endif
     Rewrite [DAHH]
    Endif
    If fstat : Call ERREUR("ABIHIERA"-[F:DAHH]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [AHH] , [DAHH] , [DACV]
Return


#####################################################
## Condition predefinies
#####################################################
$DICAII
# MAJ dictionnaire - Condition predefinies
Call ECR_TIME(mess(15,125,1)-mess(44,127,1)) From DOSSUB
Local File =GDOSREF+".ABICOND" [AII]
Local File =[F:ADS]DOSSIER+".ABICOND"  [DAII]
Local File =[F:ADS]DOSSIER+".ACTIV"    [DACV]
Local Integer WMODULE

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(44,127,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DAII]
  For [DAII] Where COD<GXX
   Call SPEC([F:DAII]ACV,SPEC) From DOSSUB
   If !SPEC
    Read [AII]AII0 = [F:DAII]COD
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DAII]COD,0) From GESECRAN
     Delete [DAII] Curr
     If fstat=1 : Call ERREUR("ABICOND"-[F:DAII]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next DAII
 Commit
Endif
For [AII] Where COD<GXX
 ACTIV = 0
 Trbegin [DAII]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DAII]AII0 = [F:AII]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DAII]ACV,SPEC) From DOSSUB
  Endif
  If dim([F:AII]MODULE)<0 : WMODULE=0 : Else : WMODULE=[F:AII]MODULE : Endif
  Call NEWREC([F:ADS]DOSSIER,[F:AII]ACV,WMODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:AII]COD,0) From GESECRAN
    Delete [DAII] Where COD=[F:AII]COD
    If fstat=1 : Call ERREUR("ABICOND"-[F:AII]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DAII]
    [F:DAII] = [F:AII]
    If dim([F:DAII]CREDAT)>0 : [F:DAII]CREDAT = date$ : Endif
    If dim([F:DAII]CREUSR)>0 : [F:DAII]CREUSR = GUSER : Endif
    If dim([F:DAII]CRETIM)>0 : [F:DAII]CRETIM = time : Endif
    Write [DAII]
    If fstat : Call ERREUR("ABICOND"-[F:DAII]COD,1) From DOSDIC : Endif
   Elsif NEWREC & OLD
    DIFF = 0
    Call DIFFACT([F:ADS]DOSSIER,[F:AII]ACV,ACTIV) From DOSSUB
    If [F:AII]ABM           <> [F:DAII]ABM           : DIFF = 1  : Endif
    If [F:AII]ACV           <> [F:DAII]ACV           : DIFF = 2  : Endif
    If [F:AII]CNDORA        <> [F:DAII]CNDORA        : DIFF = 3  : Endif
    If [F:AII]CNDSQL        <> [F:DAII]CNDSQL        : DIFF = 4  : Endif
    If [F:AII]CODABF        <> [F:DAII]CODABF        : DIFF = 5  : Endif
    If [F:AII]CODLNK        <> [F:DAII]CODLNK        : DIFF = 6  : Endif
    If [F:AII]CNDDEF        <> [F:DAII]CNDDEF        : DIFF = 6  : Endif
    If [F:AII]ORD           <> [F:DAII]ORD           : DIFF = 7  : Endif
    If [F:AII]DES           <> [F:DAII]DES           : DIFF = 8  : Endif
    If [F:AII]TEX           <> [F:DAII]TEX           : DIFF = 9  : Endif
    If [F:AII]EXPLNK        <> [F:DAII]EXPLNK        : DIFF = 10 : Endif
    For I=0 To 1
     If [F:AII]CODABF1(I)    <> [F:DAII]CODABF1(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODFLD1(I)    <> [F:DAII]CODFLD1(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]TYPOPT(I)     <> [F:DAII]TYPOPT(I)      : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM1(I)    <> [F:DAII]CODDIM1(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM1(I)    <> [F:DAII]FLDDIM1(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM2(I)    <> [F:DAII]CODDIM2(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM2(I)    <> [F:DAII]FLDDIM2(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM3(I)    <> [F:DAII]CODDIM3(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM3(I)    <> [F:DAII]FLDDIM3(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM4(I)    <> [F:DAII]CODDIM4(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM4(I)    <> [F:DAII]FLDDIM4(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM5(I)    <> [F:DAII]CODDIM5(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM5(I)    <> [F:DAII]FLDDIM5(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]CODDIM6(I)    <> [F:DAII]CODDIM6(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM6(I)    <> [F:DAII]FLDDIM6(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM7(I)    <> [F:DAII]FLDDIM7(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM8(I)    <> [F:DAII]FLDDIM8(I)     : DIFF = 14  : Break  : Endif
     If [F:AII]FLDDIM9(I)    <> [F:DAII]FLDDIM9(I)     : DIFF = 14  : Break  : Endif
    Next I
    If dim([F:AII]MODULE)>0 & dim([F:DAII]MODULE)>0
     If [AII]MODULE<> [DAII]MODULE : DIFF = 15 : Endif  : # module
    Endif
    If !DIFF : Call TXT([F:AII]DES,DIFF)  From DOSSUB : Endif
    If !DIFF : Call TXT([F:AII]TEX,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff conditions predifinies"-[F:AII]COD-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DAII] = [F:AII]
     If dim([F:DAII]UPDDAT)>0 : [F:DAII]UPDDAT = date$ : Endif
     If dim([F:DAII]UPDUSR)>0 : [F:DAII]UPDUSR = GUSER : Endif
     If dim([F:DAII]UPDTIM)>0 : [F:DAII]UPDTIM = time : Endif
     Rewrite [DAII]
    Elsif ACTIV
     If dim([F:DAII]UPDDAT)>0 : [F:DAII]UPDDAT = date$ : Endif
     If dim([F:DAII]UPDUSR)>0 : [F:DAII]UPDUSR = GUSER : Endif
     If dim([F:DAII]UPDTIM)>0 : [F:DAII]UPDTIM = time : Endif
     Rewrite [DAII]
    Endif
    If fstat : Call ERREUR("ABICOND"-[F:DAII]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [AII] , [DAII] , [DACV]
Return

#####################################################
## Règles synchronisation
#####################################################
$DICABV
# MAJ dictionnaire - Règles synchronisation
Call ECR_TIME(mess(15,125,1)-mess(10,148,1)) From DOSSUB
Local File =GDOSREF+".ABIREGORG" [ABV]
Local File =GDOSREF+".ABIREGDES" [ABY]
Local File =[F:ADS]DOSSIER+".ABIREGORG"  [DABV]
Local File =[F:ADS]DOSSIER+".ABIREGDES"  [DABY]
Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]
Local Integer WMODULE

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(10,148,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DABV]
  For [DABV] Where CODREG<GXX
   Call SPEC([F:DABV]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ABV]ABV0 = [F:DABV]CODREG
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DABV]CODREG,0) From GESECRAN
     Delete [DABV] Curr
     If fstat=1 : Call ERREUR("ABIREGORG"-[F:DABV]CODREG,3) From DOSDIC : Endif
     Delete [DABY] Where CODREG = [DABV]CODREG
     If fstat=1 : Call ERREUR("ABIREGDES"-[F:DABV]CODREG,3) From DOSDIC : Endif
    Endif
   Endif
  Next DABV
 Commit
Endif
For [ABV] Where CODREG<GXX
 ACTIV = 0
 Trbegin [DABV]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DABV]ABV0 = [F:ABV]CODREG
  If !fstat
   OLD = 1
   Call SPEC([F:DABV]CODACT,SPEC) From DOSSUB
  Endif
  If dim([F:ABV]MODULE)<0 : WMODULE=0 : Else : WMODULE=[F:ABV]MODULE : Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ABV]CODACT,WMODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:ABV]CODREG,0) From GESECRAN
    Delete [DABY] Where CODREG=[F:ABV]CODREG
    If fstat=1 : Call ERREUR("ABIREGDES"-[F:ABV]CODREG,3) From DOSDIC : Endif
    Delete [DABV] Where CODREG=[F:ABV]CODREG
    If fstat=1 : Call ERREUR("ABIREGORG"-[F:ABV]CODREG,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DABV]
    [F:DABV] = [F:ABV]
    Raz [F:DABV]ADXDOS
    Raz [F:DABV]NBRDOS
    If dim([F:DABV]CREDAT)>0 : [F:DABV]CREDAT = date$ : Endif
    If dim([F:DABV]CREUSR)>0 : [F:DABV]CREUSR = GUSER : Endif
    If dim([F:DABV]CRETIM)>0 : [F:DABV]CRETIM = time : Endif
    Write [DABV]
    If fstat : Call ERREUR("ABIREGORG"-[F:DABV]CODREG,1) From DOSDIC : Endif

    ## Destinations
    For [ABY]ABY0 Where CODREG = [DABV]CODREG
     Raz [F:DABY]
     [DABY] = [ABY]
     Write [DABY]
     If fstat : Call ERREUR("ABIREGDES"-[F:DABY]CODREG,1) From DOSDIC : Endif
    Next ABY

   Elsif NEWREC & OLD
    ## Destinations
    Delete [DABY] Where CODREG = [ABV]CODREG
    If fstat=1 : Call ERREUR("ABIREGDES"-[F:DABY]CODREG,3) From DOSDIC : Endif
    For [ABY]ABY0 Where CODREG = [DABV]CODREG
     Raz [F:DABY]
     [DABY] = [ABY]
     Write [DABY]
     If fstat : Call ERREUR("ABIREGDES"-[F:DABY]CODREG,1) From DOSDIC : Endif
    Next ABY

    DIFF = 0
    Call DIFFACT([F:ADS]DOSSIER,[F:ABV]CODACT,ACTIV) From DOSSUB
    If [F:ABV]TABORG       <> [F:DABV]TABORG        : DIFF = 1  : Endif
    If [F:ABV]CODACT       <> [F:DABV]CODACT        : DIFF = 4  : Endif
    If [F:ABV]NBRLNK       <> [F:DABV]NBRLNK        : DIFF = 5  : Endif
    For I=0 To min(dim([F:ABV]TABLNK)-1,dim([F:DABV]TABLNK)-1)
     If [F:ABV]TABLNK(I)      <> [F:DABV]TABLNK(I)     : DIFF = 6  : Break  : Endif
     If [F:ABV]ABRLNK(I)      <> [F:DABV]ABRLNK(I)     : DIFF = 6  : Break  : Endif
     If [F:ABV]CLELNK(I)       <> [F:DABV]CLELNK(I)     : DIFF = 6  : Break  : Endif
     If [F:ABV]EXPLNK(I)      <> [F:DABV]EXPLNK(I)     : DIFF = 6  : Break  : Endif
     If [F:ABV]TYPLNKTAB(I) <> [F:DABV]TYPLNKTAB(I)     : DIFF = 6  : Break  : Endif
    Next I
    If [F:ABV]FILTRE       <> [F:DABV]FILTRE        : DIFF = 7  : Endif
    If [F:ABV]TYPLNK       <> [F:DABV]TYPLNK        : DIFF = 8  : Endif
    If [F:ABV]FLDDEC       <> [F:DABV]FLDDEC        : DIFF = 9  : Endif
    If [F:ABV]CNDLIG       <> [F:DABV]CNDLIG        : DIFF = 10 : Endif
    If [F:ABV]AJOUT        <> [F:DABV]AJOUT         : DIFF = 11  : Endif
    If [F:ABV]MODIF        <> [F:DABV]MODIF         : DIFF = 12  : Endif
    If [F:ABV]ANNUL        <> [F:DABV]ANNUL         : DIFF = 13  : Endif
    If [F:ABV]INTIT        <> [F:DABV]INTIT         : DIFF = 14  : Endif
    If [F:ABV]TRTSTD       <> [F:DABV]TRTSTD        : DIFF = 15  : Endif
    If [F:ABV]TRTSPE       <> [F:DABV]TRTSPE        : DIFF = 17  : Endif
    If [F:ABV]TRTSPV       <> [F:DABV]TRTSPV        : DIFF = 18  : Endif
    If [F:ABV]INDLEC       <> [F:DABV]INDLEC        : DIFF = 16  : Endif
    If dim([F:ABV]MODULE)>0 & dim([F:DABV]MODULE)>0
     If [ABV]MODULE<> [DABV]MODULE : DIFF = 17 : Endif  : # module
    Endif
    If !DIFF : Call TXT([F:ABV]INTIT,DIFF)  From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff regle de synchro"-[F:ABV]CODREG-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     Local Integer NBRDOS2
     Local Char    ADXDOS2(GLONADD)(0..dim([F:DABV]ADXDOS))
     [L]NBRDOS2 = [F:DABV]NBRDOS
     [L]ADXDOS2 = [F:DABV]ADXDOS
     [F:DABV] = [F:ABV]
     [F:DABV]NBRDOS   =  [L]NBRDOS2
     [F:DABV]ADXDOS   =  [L]ADXDOS2
     If dim([F:DABV]UPDDAT)>0 : [F:DABV]UPDDAT = date$ : Endif
     If dim([F:DABV]UPDUSR)>0 : [F:DABV]UPDUSR = GUSER : Endif
     If dim([F:DABV]UPDTIM)>0 : [F:DABV]UPDTIM = time : Endif
     Rewrite [DABV]
     If fstat : Call ERREUR("ABIREGORG"-[F:DABV]CODREG,2) From DOSDIC : Endif
    Elsif ACTIV
     If dim([F:DABV]UPDDAT)>0 : [F:DABV]UPDDAT = date$ : Endif
     If dim([F:DABV]UPDUSR)>0 : [F:DABV]UPDUSR = GUSER : Endif
     If dim([F:DABV]UPDTIM)>0 : [F:DABV]UPDTIM = time : Endif
     Rewrite [DABV]
     If fstat : Call ERREUR("ABIREGORG"-[F:DABV]CODREG,2) From DOSDIC : Endif
    Endif
   Endif
  Endif
 Commit
Next
Close Local File [ABV] , [DABV] , [DACV] , [ABY] , [DABY]
Return

#####################################################
## Etats buissness objets
#####################################################
$DICABO
# MAJ dictionnaire - Etats Business Objects
Call ECR_TIME(mess(15,125,1)-mess(42,127,1)) From DOSSUB
Local File =GDOSREF+".ABIREPORT"  [ABO]
Local File =GDOSREF+".ABIREPORTD" [ABQ]
Local File =GDOSREF+".ABITRAUNV"  [ATV]
Local File =[F:ADS]DOSSIER+".ABIREPORT"   [DABO]
Local File =[F:ADS]DOSSIER+".ABIREPORTD"  [DABQ]
Local File =[F:ADS]DOSSIER+".ABITRAUNV"   [DATV]

Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(42,127,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DABO]
  For [DABO] Where COD<GXX
   Call SPEC([F:DABO]ACV,SPEC) From DOSSUB
   If !SPEC
    Read [ABO]ABO0 = [F:DABO]COD
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DABO]COD,0) From GESECRAN
     Delete [DABQ] Where COD=[F:DABO]COD
     If fstat=1 : Call ERREUR("ABIREPORTD"-[F:DABO]COD,3) From DOSDIC : Endif
     Delete [DABO] Curr
     If fstat=1 : Call ERREUR("ABIREPORT"-[F:DABO]COD,3) From DOSDIC : Endif
    Endif
   Endif
  Next DABO
 Commit
Endif
For [ABO] Where COD<GXX
 ACTIV = 0
 Trbegin [DABO],[ABQ]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DABO]ABO0 = [F:ABO]COD
  If !fstat
   OLD = 1
   Call SPEC([F:DABO]ACV,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ABO]ACV,[F:ABO]MODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:ABO]COD,0) From GESECRAN
    Delete [DABQ] Where COD=[F:ABO]COD
    If fstat=1 : Call ERREUR("ABIREPORTD"-[F:ABO]COD,3) From DOSDIC : Endif
    Delete [DABO] Where COD=[F:ABO]COD
    If fstat=1 : Call ERREUR("ABIREPORT"-[F:ABO]COD,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DABO]
    [F:DABO] = [F:ABO]
    If dim([F:DABO]CREDAT)>0 : [F:DABO]CREDAT = date$ : Endif
    If dim([F:DABO]CREUSR)>0 : [F:DABO]CREUSR = GUSER : Endif
    If dim([F:DABO]CRETIM)>0 : [F:DABO]CRETIM = time : Endif
    Write [DABO]
    If fstat : Call ERREUR("ABIREPORT"-[F:DABO]COD,1) From DOSDIC : Endif

    ## Destinations
    Delete [DABQ] Where COD = [ABO]COD
    If fstat=1 : Call ERREUR("ABIREPORTD"-[ABO]COD,3) From DOSDIC : Endif
    For [ABQ]ABQ0 Where COD = [ABO]COD
     Raz [F:DABQ]
     [DABQ] = [ABQ]
     Write [DABQ]
     If fstat : Call ERREUR("ABIREPORTD"-[F:ABQ]COD-num$([F:ABQ]LIG),1) From DOSDIC : Endif
    Next ABQ

    ## Copie des textes pour la traduction
    Delete [DATV] Where ABM = [DABO]DATAM & RAPORT = [DABO]REPCOD
    If fstat=1 : Call ERREUR("ABITRAUNV"-[DABO]DATAM-[DABO]REPCOD,3) From DOSDIC : Endif
    For [ATV]ATV0 Where ABM = [DABO]DATAM & RAPORT = [DABO]REPCOD
     Raz [F:DATV]
     [DATV] = [ATV]
     Write [DATV]
     If fstat : Call ERREUR("ABITRAUNV"-[DATV]DATAM-[DATV]RAPORT,1) From DOSDIC : Endif
    Next A

   Elsif NEWREC & OLD
    ## Destinations
    Delete [DABQ] Where COD = [ABO]COD
    If fstat=1 : Call ERREUR("ABIREPORTD"-[ABO]COD,3) From DOSDIC : Endif
    For [ABQ]ABQ0 Where COD = [ABO]COD
     Raz [F:DABQ]
     [DABQ] = [ABQ]
     Write [DABQ]
     If fstat : Call ERREUR("ABIREPORTD"-[F:ABQ]COD-num$([F:ABQ]LIG),1) From DOSDIC : Endif
    Next ABQ

    ## Copie des textes pour la traduction
    Delete [DATV] Where ABM = [ABO]DATAM & RAPORT = [ABO]REPCOD
    If fstat=1 : Call ERREUR("ABITRAUNV"-[ABO]DATAM-[ABO]REPCOD,3) From DOSDIC : Endif
    For [ATV]ATV0 Where ABM = [ABO]DATAM & RAPORT = [ABO]REPCOD
     Raz [F:DATV]
     [DATV] = [ATV]
     Write [DATV]
     If fstat : Call ERREUR("ABITRAUNV"-[DATV]DATAM-[DATV]RAPORT,1) From DOSDIC : Endif
    Next ATV

    DIFF = 0
    Call DIFFACT([F:ADS]DOSSIER,[F:ABO]ACV,ACTIV) From DOSSUB
    If [F:ABO]ENAFLG       <> [F:DABO]ENAFLG        : DIFF = 1  : Endif
    If [F:ABO]MODULE       <> [F:DABO]MODULE        : DIFF = 2  : Endif
    If [F:ABO]ACV          <> [F:DABO]ACV           : DIFF = 4  : Endif
    If [F:ABO]ACS          <> [F:DABO]ACS           : DIFF = 5  : Endif
    If [F:ABO]REPCOD       <> [F:DABO]REPCOD        : DIFF = 7  : Endif
    If [F:ABO]DATAM        <> [F:DABO]DATAM         : DIFF = 9  : Endif
    If [F:ABO]ETAREF       <> [F:DABO]ETAREF        : DIFF = 9  : Endif
    If [F:ABO]DES          <> [F:DABO]DES           : DIFF = 10 : Endif
    If [F:ABO]DES1         <> [F:DABO]DES1          : DIFF = 10 : Endif
    If [F:ABO]DES2         <> [F:DABO]DES2          : DIFF = 10 : Endif
    If [F:ABO]DES3         <> [F:DABO]DES3          : DIFF = 10 : Endif
    If [F:ABO]SHO          <> [F:DABO]SHO           : DIFF = 10 : Endif
    If !DIFF : Call TXT([F:ABO]DES,DIFF)   From DOSSUB : Endif
    If !DIFF : Call TXT([F:ABO]DES1,DIFF)  From DOSSUB : Endif
    If !DIFF : Call TXT([F:ABO]DES2,DIFF)  From DOSSUB : Endif
    If !DIFF : Call TXT([F:ABO]DES3,DIFF)  From DOSSUB : Endif
    If !DIFF : Call TXT([F:ABO]SHO,DIFF)   From DOSSUB : Endif
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff Etats Business Objects"-[F:ABO]COD-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DABO] = [F:ABO]
     If dim([F:DABO]UPDDAT)>0 : [F:DABO]UPDDAT = date$ : Endif
     If dim([F:DABO]UPDUSR)>0 : [F:DABO]UPDUSR = GUSER : Endif
     If dim([F:DABO]UPDTIM)>0 : [F:DABO]UPDTIM = time : Endif
     Rewrite [DABO]
    Elsif ACTIV
     If dim([F:DABO]UPDDAT)>0 : [F:DABO]UPDDAT = date$ : Endif
     If dim([F:DABO]UPDUSR)>0 : [F:DABO]UPDUSR = GUSER : Endif
     If dim([F:DABO]UPDTIM)>0 : [F:DABO]UPDTIM = time : Endif
     Rewrite [DABO]
    Endif
    If fstat : Call ERREUR("ABIREPORT"-[F:DABO]COD,2) From DOSDIC : Endif
   Endif
  Endif
 Commit
Next
Close Local File [ABO] , [DABO] , [DACV] , [ABQ] , [DABQ] , [ATV] , [DATV]
Return

##############################################################
# Tablde de faits
##############################################################
$DICABF
Call ECR_TIME(mess(15,125,1)-mess(63,148,1) ) From DOSSUB
# MAJ dictionnaire -  Table de fait
Local File =GDOSREF+".ABITABDAT"    [ABF]
&         ,=GDOSREF+".ABITABFLD"    [ABZ]
&         ,=GDOSREF+".ABITABIND"    [ABX]
&         ,=GDOSREF+".ABITABLNK"    [ABK]
&         ,=GDOSREF+".ABITABAGG"    [ABE]
Local File =[F:ADS]DOSSIER+".ABITABDAT"    [DABF]
&         ,=[F:ADS]DOSSIER+".ABITABFLD"    [DABZ]
&         ,=[F:ADS]DOSSIER+".ABITABIND"    [DABX]
&         ,=[F:ADS]DOSSIER+".ABITABLNK"    [DABK]
&         ,=[F:ADS]DOSSIER+".ABITABAGG"    [DABE]

Local File =[F:ADS]DOSSIER+".ACTIV"        [DACV]
Local Char    CHAINE(80),CHAINE2(GLONAVA)(0..100)
# Issue X3-88892 - 2018-07-09 by CCC : dynamic dimensioning to avoid error
Local Char    TBAGG(GLONAVA)(0..)
Local Integer NBAGG
Local Char    TBIND(80)(0..)
Local Integer NBINDS
Local Char    TBLNK(100)(0..)
Local Integer NBLNK,WMODULE



If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(63,148,1),"") From GESECRAN
Endif

## Effacement anciennes table de faits

If !GCRE
 Trbegin [DABF] , [DABZ] , [DABX] , [DABK] , [DABE]
  For [DABF]ABF0 Where CODABF<GXX
   Call SPEC([F:DABF]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ABF]ABF0 = [F:DABF]CODABF
    If fstat
     Call EFFACE([F:DABF]CODABF)
    Endif
   Endif
  Next
 Commit
Endif

## Mise à jour

Filter [ABF] Where CODABF<GXX
Read [ABF]ABF0 First
While fstat<=2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(63,148,1),[F:ABF]CODABF) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DABF] , [DABZ] , [DABX] , [DABK] , [DABE]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DABF]ABF0 = [F:ABF]CODABF
  If !fstat
   OLD = 1
   Call SPEC([F:DABF]CODACT,SPEC) From DOSSUB
  Endif
  If dim([F:ABF]MODULE)<0 : WMODULE=0 : Else : WMODULE=[F:ABF]MODULE : Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ABF]CODACT,WMODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC : # On le vire

    Call EFFACE([F:ABF]CODABF)

   Elsif NEWREC & !OLD : # nouveau

    Raz [F:DABF]
    RWO = 1
    [F:DABF] = [F:ABF]
    [F:DABF]CREDAT = date$
    [F:DABF]CREUSR = GUSER
    If dim([F:DABF]CRETIM)>0 : [F:DABF]CRETIM = time : Endif
    Write [DABF]
    If fstat : Call ERREUR("ABITABDAT"-[F:DABF]CODABF,1) From DOSDIC : Endif
    For [ABZ]ABZ0 Where CODABF=[F:ABF]CODABF
     [F:DABZ] = [F:ABZ]
     Write [DABZ]
     If fstat : Call ERREUR("ABITABFLD"-[F:DABZ]CODABF-[F:DABZ]CODFLD,1) From DOSDIC : Endif
    Next
    For [ABX]ABX0 Where CODABF=[F:ABF]CODABF
     [F:DABX] = [F:ABX]
     Write [DABX]
     If fstat : Call ERREUR("ABITABIND"-num$([F:DABX]NUMIND),1) From DOSDIC : Endif
    Next
    For [ABK]ABK0 Where CODABF=[F:ABF]CODABF
     [F:DABK] = [F:ABK]
     Write [DABK]
     If fstat : Call ERREUR("ABITABLNK"-num$([F:DABK]NUMLNK),1) From DOSDIC : Endif
    Next
    For [ABE]ABE0 Where CODABF=[F:ABF]CODABF
     [F:DABE] = [F:ABE]
     Write [DABE]
     If fstat : Call ERREUR("ABITABAGG"-[F:DABE]CODAGG,1) From DOSDIC : Endif
    Next

   Elsif  NEWREC & OLD

    ### Comparaison description
    DIFF = 0
    Call DIFFACT([F:ADS]DOSSIER,[F:ABF]CODACT,ACTIV) From DOSSUB
    If [ABF]ABRABF <> [DABF]ABRABF : DIFF = 1 : Endif  : # "AbrÃ©viation"
    If [ABF]CODACT <> [DABF]CODACT : DIFF = 1 : Endif  : # "Code activitÃ©"
    If [ABF]NBRABF <> [DABF]NBRABF : DIFF = 1 : Endif  : # "Nombre"
    If [ABF]AUZFCY <> [DABF]AUZFCY : DIFF = 1 : Endif  : # "Autorisation site"
    If [ABF]FLDFCY <> [DABF]FLDFCY : DIFF = 1 : Endif  : # "Champ site"
    If [ABF]FNC    <> [DABF]FNC    : DIFF = 1 : Endif  : # "Fonction"
    If [ABF]TYPMAJ <> [DABF]TYPMAJ : DIFF = 1 : Endif  : # "Type de mise Ã  jour"
    If [ABF]FLDDAT <> [DABF]FLDDAT : DIFF = 1 : Endif  : # "Champ date"
    If [ABF]STK    <> [DABF]STK    : DIFF = 1 : Endif  : # "Stockage"
    If [ABF]INTIT  <> [DABF]INTIT  : DIFF = 1 : Endif  : # Libellé
    If dim([F:ABF]MODULE)>0 & dim([F:DABF]MODULE)>0
     If [ABF]MODULE<> [DABF]MODULE : DIFF = 1 : Endif  : # module
    Endif
    If !DIFF : Call TXT([F:ABF]INTIT,DIFF) From DOSSUB : Endif

    ## Comparaison et mise à jour des zones
    NBZONE = 0 : Raz TBZONE
    For [ABZ]ABZ0 Where CODABF=[F:ABF]CODABF
     NBZONE += 1
     TBZONE(NBZONE) = [F:ABZ]CODFLD
     Read [DABZ]ABZ1 = [F:ABF]CODABF;[F:ABZ]CODFLD
     If fstat

      # Nouveau champ ABZ
      DIFF = 1
      [F:DABZ]      = [F:ABZ]
      Write [DABZ]
      If fstat : Call ERREUR("ABITABFLD"-[F:ABF]CODABF-[F:DABZ]CODFLD,1) From DOSDIC : Endif

     Elsif !find([F:DABZ]ACTFLD,GSPE(1..GNBSPE))

      # Ancienne zone existante et non spécifique, on compare
      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ABZ]ACTFLD,ACTIV) From DOSSUB
      If [F:ABZ]NUMFLD    <> [F:DABZ]NUMFLD    : RW = 1 : Endif : # "Num ligne"
      If [F:ABZ]CODTYP    <> [F:DABZ]CODTYP    : RW = 1 : Endif : # "Type de donnÃ©es"
      If [F:ABZ]TYPDAT    <> [F:DABZ]TYPDAT    : RW = 1 : Endif : # "Type date"
      If [F:ABZ]LNGFLD    <> [F:DABZ]LNGFLD    : RW = 1 : Endif : # "Longueur"
      If [F:ABZ]MENLOC    <> [F:DABZ]MENLOC    : RW = 1 : Endif : # "NumÃ©ro menu local"
      If [F:ABZ]TABDIV    <> [F:DABZ]TABDIV    : RW = 1 : Endif : # "Table diverse"
      If [F:ABZ]ACTFLD    <> [F:DABZ]ACTFLD    : RW = 1 : Endif : # "Code activitÃ©"
      If [F:ABZ]TYPFLD    <> [F:DABZ]TYPFLD    : RW = 1 : Endif : # "Type de champ"
      If [F:ABZ]TYPOPE    <> [F:DABZ]TYPOPE    : RW = 1 : Endif : # "Compte distinct"
      If [F:ABZ]INTFLD    <> [F:DABZ]INTFLD    : RW = 1 : Endif : # "Libellé
      If [F:ABZ]INTVALFLD <> [F:DABZ]INTVALFLD : RW = 1 : Endif : # Libellé evalué
      If !RW : Call TXT([F:ABZ]INTFLD,DIFF) From DOSSUB : Endif
      If RW
       DIFF  = 1
       [F:DABZ]      = [F:ABZ]
       Rewrite [DABZ]
       If fstat : Call ERREUR("ABITABFLD"-[F:DABZ]CODABF-[F:DABZ]CODFLD,2) From DOSDIC : Endif
      Endif
     Endif : # ABZ
    Next ABZ

    ## Liens
    NBLNK = 0 : Raz TBLNK
    For [ABK]ABK0 Where CODABF=[F:ABF]CODABF
     NBLNK +=1
     TBLNK(NBLNK)    = [ABK]CODLNK+"~"+[ABK]EXPLNK
     Read [DABK]ABK0 = [F:ABF]CODABF;[F:ABK]NUMLNK

     If fstat

      # Nouveau lien
      DIFF = 1
      [F:DABK] = [F:ABK]
      Write [DABK]
      If fstat : Call ERREUR("ABITABLNK"-[F:ABF]CODABF-[F:DABK]NUMLNK,1) From DOSDIC : Endif

     Else
      J=0 : RW = 1
      CHAINE = [F:DABK]EXPLNK
      While instr(0,CHAINE,";")
       CHAINE2(J) = left$(CHAINE,instr(0,CHAINE,";")-1)
       CHAINE     = right$(CHAINE,instr(0,CHAINE,";")+1)
       J+=1
      Wend
      CHAINE2(J) = CHAINE
      For I=0 To J
       Read [DABZ]ABZ1 = [F:ABF]CODABF;CHAINE2(J)
       If !fstat & !find([F:DABZ]ACTFLD,GSPE(1..GNBSPE))
        RW=0 : Break
       Endif
      Next I
      If !RW
       # Ancienne zone existante, on compare
       RW = 0
       If [F:ABK]CODLNK <> [F:DABK]CODLNK       : RW = 1 : Endif : # "Dimension"
       If [F:ABK]EXPLNK <> [F:DABK]EXPLNK       : RW = 1 : Endif : # "Expression de lien"
       If [F:ABK]OPTJNT <> [F:DABK]OPTJNT       : RW = 1 : Endif : # "Option de jointure"
       If [F:ABK]TYPJNT <> [F:DABK]TYPJNT       : RW = 1 : Endif : # "Type de jointure"
       If [F:ABK]INTLNK <> [F:DABK]INTLNK       : RW = 1 : Endif : # Libellé evalué
       If [F:ABK]INTVALLNK <> [F:DABK]INTVALLNK : RW = 1 : Endif : # Libellé evalué
       If [F:ABK]INTCOMP <> [F:DABK]INTCOMP       : RW = 1 : Endif : # complement
       If [F:ABK]INTVALCOMP <> [F:DABK]INTVALCOMP : RW = 1 : Endif : # complementevalué
       If RW
        DIFF  = 1
        [F:DABK] = [ABK]
        Rewrite [DABK]
        If fstat : Call ERREUR("ABITABLNK"-[F:ABF]CODABF-[F:DABK]NUMLNK,2) From DOSDIC : Endif
       Endif
      Else
       NBLNK +=1
       TBLNK(NBLNK)    = [DABK]CODLNK+"~"+[DABK]EXPLNK
      Endif
     Endif : # ABK
    Next ABK

   ## Comparaison et mise à jour des index
    NBINDS =0 : Raz TBIND

    For [ABX]ABX0 Where CODABF=[F:ABF]CODABF
     NBINDS +=1
     TBIND(NBINDS) = [ABX]EXPIND
     Read [DABX]ABX0 = [F:ABF]CODABF;[F:ABX]NUMIND

     If fstat

      # Nouveau index
      DIFF = 1
      [F:DABX]     = [F:ABX]
      Write [DABX]
      If fstat : Call ERREUR("ABITABIND"-[F:ABF]CODABF-[F:DABX]NUMIND,1) From DOSDIC : Endif

     Elsif !find([F:DABX]ACTIND,GSPE(1..GNBSPE))

      # Ancien index existante et non spécifique, on compare
      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ABX]ACTIND,ACTIV) From DOSSUB
      If [F:ABX]EXPIND <> [F:ABX]EXPIND : RW = 1  : Endif : # Expression de liens
      If [F:ABX]ACTIND <> [F:ABX]ACTIND : RW = 1  : Endif : # Code activitée
      If RW
       DIFF  = 1
       [F:DABX] = [ABX]
       Rewrite [DABX]
       If fstat : Call ERREUR("ABITABIND"-[F:ABF]CODABF-[F:DABX]NUMIND,2) From DOSDIC : Endif
      Endif
     Endif : # ABX
    Next ABX

   ## Comparaison et mise à jour des aggregats
    NBAGG =0 : Raz TBAGG
    For [ABE]ABE0 Where CODABF=[F:ABF]CODABF
     NBAGG +=1
     TBAGG(NBAGG) = [F:ABE]CODAGG
     Read [DABE]ABE1 = [F:ABF]CODABF;[F:ABE]CODAGG

     If fstat

      # Nouvelle zone, on la créé si le bloc n'est pas spécifique
      DIFF = 1
      [F:DABE]       = [F:ABE]
      Write [DABE]
      If fstat : Call ERREUR("ABITABAGG"-[F:ABF]CODABF-[F:DABE]CODAGG,1) From DOSDIC : Endif

     Elsif !find([F:DABE]ACTAGG,GSPE(1..GNBSPE))

      # Ancien index existante et non spécifique, on compare
      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ABE]ACTAGG,ACTIV) From DOSSUB
      If [F:ABE]NUMAGG <> [F:DABE]NUMAGG : RW = 1 : Endif : #  "Num agg"
      If [F:ABE]ACTAGG <> [F:DABE]ACTAGG : RW = 1 : Endif : #  "Code activitÃ©"
      If [F:ABE]NBRAGD <> [F:DABE]NBRAGD : RW = 1 : Endif : #  "Nb dimensions"
      For I=0 To min(dim([F:ABE]TYPAGG)-1,dim([F:DABE]TYPAGG)-1)
       If [F:ABE]TYPAGG <> [F:DABE]TYPAGG : RW = 1  : Break : Endif : #  "Type dimension"
       If [F:ABE]DIMAGG <> [F:DABE]DIMAGG : RW = 1  : Break : Endif : #  "Dimension"
       If [F:ABE]LNKAGG <> [F:DABE]LNKAGG : RW = 1  : Break : Endif : #  "Champs"
       If [F:ABE]NIVAGG <> [F:DABE]NIVAGG : RW = 1  : Break : Endif : #  "Niveau d'agrÃ©gation"
       If [F:ABE]FLDAGG <> [F:DABE]FLDAGG : RW = 1  : Break : Endif : #  "Nom du champ"
      Next I
      If [F:ABE]NBRAGI <> [F:DABE]NBRAGI : RW = 1 : Endif : #  "Nb index"
      For I=0 To min(dim([F:ABE]INDAGG)-1,dim([F:DABE]INDAGG)-1)
       If [F:ABE]INDAGG <> [F:DABE]INDAGG : RW = 1  : Break : Endif : #  "Index"
      Next I
      If RW
       DIFF  = 1
       [F:DABE]       = [F:ABE]
       Rewrite [DABE]
       If fstat : Call ERREUR("ABITABAGG"-[F:ABF]CODABF-[F:DABE]CODAGG,2) From DOSDIC : Endif
      Endif
     Endif : # ABE
    Next ABE

    # On vire les liens incorrectes
    For [DABK]ABK0 Where CODABF=[F:ABF]CODABF
      CHAINE = [F:DABK]EXPLNK
      While instr(0,CHAINE,";")
       CHAINE2(J) = left$(CHAINE,instr(0,CHAINE,";")-1)
       CHAINE     = right$(CHAINE,instr(0,CHAINE,";")+1)
       J+=1
      Wend
      CHAINE2(J) = CHAINE
      For I=0 To J
       Read [DABZ]ABZ1 = [F:ABF]CODABF;CHAINE2(I)
       If fstat
        DIFF = 1
        Delete [DABK] Curr
       If fstat=1 : Call ERREUR("ABITABLNK"-[F:ABF]CODABF-CHAINE2(I),3) From DOSDIC : Endif
       Endif
      Next J
    Next DABK

    # On vire les aggregats incorrectes
    For [DABE]ABE0 Where CODABF=[F:ABF]CODABF
     If  !find([F:DABE]ACTAGG,GSPE(1..GNBSPE)) : # pas spe
      For I=0 To dim([F:DABE]TYPAGG)-1
        CHAINE = [F:DABE]LNKAGG
        While instr(0,CHAINE,";")
         CHAINE2(J) = left$(CHAINE,instr(0,CHAINE,";")-1)
         CHAINE     = right$(CHAINE,instr(0,CHAINE,";")+1)
         J+=1
        Wend
        CHAINE2(J) = CHAINE
      Next I
      For I=0 To J
       Read [DABZ]ABZ1 = [F:ABF]CODABF;CHAINE2(I)
       If fstat
        DIFF = 1
        Delete [DABE] Curr
        If fstat=1 : Call ERREUR("ABITABAGG"-[F:ABF]CODABF-CHAINE2(I),3) From DOSDIC : Break : Endif
       Endif
      Next J
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABE]ACTAGG,ACTIV) From DOSSUB
    Next DABE

    # On vire les index incorrectes
    For [DABX]ABX0 Where CODABF=[F:ABF]CODABF
     If  !find([F:DABX]ACTIND,GSPE(1..GNBSPE)) : # pas spe
      CHAINE = [F:DABX]EXPIND
      While instr(0,CHAINE,"+")
       CHAINE2(J) = left$(CHAINE,instr(0,CHAINE,"+")-1)
       CHAINE     = right$(CHAINE,instr(0,CHAINE,"+")+1)
       J+=1
      Wend
      CHAINE2(J) = CHAINE
      For I=0 To J
       Read [DABZ]ABZ1 = [F:ABF]CODABF;CHAINE2(I)
       If fstat
        DIFF = 1
        Delete [DABX] Curr
       If fstat=1 : Call ERREUR("ABITABIND"-[F:ABF]CODABF-CHAINE2(I),3) From DOSDIC : Endif
       Endif
      Next J
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABX]ACTIND,ACTIV) From DOSSUB
    Next DABX

    ### suppresion des champs inutiles ABZ
    For [DABZ]ABZ0 Where CODABF=[F:ABF]CODABF
     If !find([F:DABZ]ACTFLD,GSPE(1..GNBSPE))
      If !find([F:DABZ]CODFLD,TBZONE(1..NBZONE))
       DIFF = 1
       Delete [DABZ]
       If fstat=1 : Call ERREUR("ABITABFLD"-[F:ABF]CODABF-[F:DABZ]CODFLD,3) From DOSDIC : Endif
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABZ]ACTFLD,ACTIV) From DOSSUB
    Next DABZ

    ### suppresion des liens inutiles ABK

    For [DABK]ABK0 Where CODABF=[F:ABF]CODABF
     If !find([F:DABK]CODLNK+"~"+[F:DABK]EXPLNK,TBLNK(1..NBLNK))
      DIFF = 1
      Delete [DABK]
      If fstat=1 : Call ERREUR("ABITABFLD"-[F:ABF]CODABF-[F:DABZ]CODFLD,3) From DOSDIC : Endif
     Endif
    Next DABZ

    ### suppresion des champs inutiles ABE
    For [DABE]ABE0 Where CODABF=[F:ABF]CODABF
     If !find([F:DABE]ACTAGG,GSPE(1..GNBSPE))
      If !find([F:DABE]CODAGG,TBAGG(1..NBAGG))
       DIFF = 1
       Delete [DABE]
       If fstat=1 : Call ERREUR("ABITABAGG"-[F:ABF]CODABF-[F:DABE]CODAGG,3) From DOSDIC : Endif
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABE]ACTAGG,ACTIV) From DOSSUB
    Next DABE

    ### suppresion des champs inutiles ABX
    For [DABX]ABX0 Where CODABF=[F:ABF]CODABF
     If !find([F:DABX]ACTIND,GSPE(1..GNBSPE))
      If !find([F:DABX]EXPIND,TBIND(1..NBINDS))
       DIFF = 1
       Delete [DABX]
       If fstat=1 : Call ERREUR("ABITABIND"-[F:ABF]CODABF-[F:DABX]NUMIND,3) From DOSDIC : Endif
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABX]ACTIND,ACTIV) From DOSSUB
    Next DABX

    # Réécriture de ABF

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff table de faits"-[F:ABF]CODABF-num$(DIFF),0) From GESECRAN
     Endif
     [F:DABF] = [F:ABF]
     [F:DABF]UPDDAT = date$
     If dim([F:DABF]UPDTIM)>0 : [F:DABF]UPDTIM = time : Endif
     [F:DABF]UPDUSR = GUSER
     Rewrite [DABF]
     If fstat : Call ERREUR("ABITABDAT"-[F:ABF]CODABF,2) From DOSDIC : Endif
    Elsif ACTIV
     [F:DABF]UPDDAT = date$
     If dim([F:DABF]UPDTIM)>0 : [F:DABF]UPDTIM = time : Endif
     [F:DABF]UPDUSR = GUSER
     Rewrite [DABF]
     If fstat : Call ERREUR("ABITABDAT"-[F:ABF]CODABF,2) From DOSDIC : Endif
    Endif : # ABF
   Endif : # NEWREC & OLD
  Endif : # (spec)
 Commit
 Read [ABF]ABF0 Next
Wend
Close Local File [ABF],[ABZ],[ABX],[ABK],[ABE],[DABF],[DABZ],[DABX],[DABK],[DABE],[DACV]
Return

## Effacement d'une table de fait

Subprog EFFACE(TDF)
Value Char TDF
Local Integer W
Call ECR_TRACE(mess(54,125,1)-TDF,0) From GESECRAN
Delete [DABE] Where CODABF = TDF
If fstat=1 : Call ERREUR("ABITABAGG"-TDF,3) From DOSDIC : Endif
Delete [DABK] Where CODABF = TDF
If fstat=1 : Call ERREUR("ABITABLNK"-TDF,3) From DOSDIC : Endif
Delete [DABX] Where CODABF = TDF
If fstat=1 : Call ERREUR("ABITABIND"-TDF,3) From DOSDIC : Endif
Delete [DABZ] Where CODABF = TDF
If fstat=1 : Call ERREUR("ABITABFLD"-TDF,3) From DOSDIC : Endif
Delete [DABF] Where CODABF = TDF
If fstat=1 : Call ERREUR("ABITABDAT"-TDF,3) From DOSDIC : Endif
End

#####################################################
## Dimensions
#####################################################
$DICABI
# MAJ dictionnaire - Dimensions
Call ECR_TIME(mess(15,125,1)-mess(24,148,1)) From DOSSUB
Local File =GDOSREF+".ABIDIM"     [ABI]
Local File =GDOSREF+".ABIDIMFLD"  [ABJ]
Local File =[F:ADS]DOSSIER+".ABIDIM"     [DABI]
Local File =[F:ADS]DOSSIER+".ABIDIMFLD"  [DABJ]

Local File =[F:ADS]DOSSIER+".ACTIV"      [DACV]
Local Integer WMODULE

If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(24,1487,1),"") From GESECRAN
Endif
If !GCRE
 Trbegin [DABI]
  For [DABI] Where CODDIM<GXX
   Call SPEC([F:DABI]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ABI]ABI0 = [F:DABI]CODDIM
    If fstat
     Call ECR_TRACE(mess(53,123,1)-[F:DABI]CODDIM,0) From GESECRAN
     Delete [DABI] Curr
     If fstat=1 : Call ERREUR("ABIDIM"-[F:DABI]CODDIM,3) From DOSDIC : Endif
     Delete [DABJ] Where CODDIM = [F:DABI]CODDIM
     If fstat=1 : Call ERREUR("ABIDIMFLD"-[F:DABI]CODDIM,3) From DOSDIC : Endif
    Endif
   Endif
  Next DABI
 Commit
Endif
For [ABI] Where CODDIM<GXX
 ACTIV = 0
 Trbegin [DABI] ,[DABJ]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DABI]ABI0 = [F:ABI]CODDIM
  If !fstat
   OLD = 1
   Call SPEC([F:DABI]CODACT,SPEC) From DOSSUB
  Endif
  If dim([F:ABI]MODULE)<0 : WMODULE=0 : Else : WMODULE=[F:ABI]MODULE : Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ABI]CODACT,WMODULE,NEWREC) From DOSSUB
  If !SPEC
   If OLD & !NEWREC
    Call ECR_TRACE(mess(53,123,1)-[F:ABI]CODDIM,0) From GESECRAN
    Delete [DABI] Where CODDIM=[F:ABI]CODDIM
    If fstat=1 : Call ERREUR("ABIDIM"-[F:ABI]CODDIM,3) From DOSDIC : Endif
    Delete [DABJ] Where CODDIM = [F:ABI]CODDIM
    If fstat=1 : Call ERREUR("ABIDIMFLD"-[F:ABI]CODDIM,3) From DOSDIC : Endif
   Elsif NEWREC & !OLD
    RWO = 1
    Raz [F:DABI]
    [F:DABI] = [F:ABI]
    If dim([F:DABI]CREDAT)>0 : [F:DABI]CREDAT = date$ : Endif
    If dim([F:DABI]CREUSR)>0 : [F:DABI]CREUSR = GUSER : Endif
    If dim([F:DABI]CRETIM)>0 : [F:DABI]CRETIM = time : Endif
    Write [DABI]
    If fstat : Call ERREUR("ABIDIM"-[F:DABI]CODDIM,1) From DOSDIC : Endif

    Delete [DABJ] Where CODDIM = [F:DABI]CODDIM
    If fstat=1 : Call ERREUR("ABIDIMFLD"-[F:DABI]CODDIM,3) From DOSDIC : Endif
    ## Champs
    For [ABJ]ABJ0 Where CODDIM = [DABI]CODDIM
     Raz [F:DABJ]
     [DABJ] = [ABJ]
     Write [DABJ]
     If fstat : Call ERREUR("ABIDIMFLD"-[F:DABJ]CODDIM,1) From DOSDIC : Endif
    Next ABJ

   Elsif NEWREC & OLD

    DIFF = 0
    If [F:ABI]ABRDIM <> [F:DABI]ABRDIM : DIFF = 1 : Endif : # AbrÃ©viation"
    If [F:ABI]CODACT <> [F:DABI]CODACT : DIFF = 1 : Endif : # Code activitÃ©"
    If [F:ABI]TABORG <> [F:DABI]TABORG : DIFF = 1 : Endif : # Table origine"
    If [F:ABI]NBRLNK <> [F:DABI]NBRLNK : DIFF = 1 : Endif : # Nb de tables"
    For I=0 To min(dim([F:ABI]TABLNK)-1,dim([F:DABI]TABLNK)-1)
     If [F:ABI]TABLNK(I) <> [F:DABI]TABLNK(I) : DIFF = 1 : Break : Endif : # Tables liÃ©es"
     If [F:ABI]ABRLNK(I) <> [F:DABI]ABRLNK(I) : DIFF = 1 : Break : Endif : # AbrÃ©viation"
     If [F:ABI]CLELNK(I) <> [F:DABI]CLELNK(I) : DIFF = 1 : Break : Endif : # ClÃ© de lien"
     If [F:ABI]EXPLNK(I) <> [F:DABI]EXPLNK(I) : DIFF = 1 : Break : Endif : # Expression de lien"
     If [F:ABI]TYPLNK(I) <> [F:DABI]TYPLNK(I) : DIFF = 1 : Break : Endif : # Expression de lien"
    Next
    If [F:ABI]FILTRE <> [F:DABI]FILTRE : DIFF = 1 : Endif : # Filtre"
    If [F:ABI]CLE    <> [F:DABI]CLE    : DIFF = 1 : Endif : # ClÃ©"
    If [F:ABI]NOMBRE <> [F:DABI]NOMBRE : DIFF = 1 : Endif : # Nombre"
    If [F:ABI]TRTSTD <> [F:DABI]TRTSTD : DIFF = 1 : Endif : # Traitement"
    If [F:ABI]TRTSPE <> [F:DABI]TRTSPE : DIFF = 1 : Endif : # Traitement"
    If [F:ABI]TRTSPV <> [F:DABI]TRTSPV : DIFF = 1 : Endif : # Traitement"
    If [F:ABI]TYPMAJ <> [F:DABI]TYPMAJ : DIFF = 1 : Endif : # Type de mise Ã  jour"
    If [F:ABI]INTIT  <> [F:DABI]INTIT  : DIFF = 1 : Endif : # Libellé
    If [F:ABI]SUPVID <> [F:DABI]SUPVID : DIFF = 1 : Endif : # Suppresion enregistrement vide
    If [F:ABI]INTEVAL<> [F:DABI]INTEVAL: DIFF = 1 : Endif : # Libellé evalué
    If [F:ABI]MULDOS <> [F:DABI]MULDOS   DIFF = 1 : Endif : # Multi dossier
    If dim([F:ABI]MODULE)>0 & dim([F:DABI]MODULE)>0
     If [ABI]MODULE<> [DABI]MODULE : DIFF = 1 : Endif  : # module
    Endif
    If !DIFF : Call TXT([F:ABI]INTIT,DIFF)  From DOSSUB : Endif

    ## Comparaison et mise à jour des zones
    NBZONE = 0 : Raz TBZONE
    For [ABJ]ABJ0 Where CODDIM=[F:ABI]CODDIM
     NBZONE += 1
     TBZONE(NBZONE) = [F:ABJ]FLDDIM
     Read [DABJ]ABJ1 = [F:ABI]CODDIM;[F:ABJ]FLDDIM
     If fstat

      # Nouveau champ ABZ
      DIFF = 1
      [F:DABJ]      = [F:ABJ]
      Write [DABJ]
      If fstat : Call ERREUR("ABIDIMFLD"-[F:ABI]CODDIM-[F:DABJ]FLDDIM,1) From DOSDIC : Endif

     Elsif !find([F:DABJ]ACTDIM,GSPE(1..GNBSPE))

      # Ancienne zone existante et non spécifique, on compare
      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ABJ]ACTDIM,ACTIV) From DOSSUB
      If [F:ABJ]NUMDIM <> [F:DABJ]NUMDIM : RW = 1 : Endif  : # NumÃ©ro de ligne"
      If [F:ABJ]ACTDIM <> [F:DABJ]ACTDIM : RW = 1 : Endif  : # Code activitÃ©"
      If [F:ABJ]LNG    <> [F:DABJ]LNG    : RW = 1 : Endif  : # Longueur"
      If [F:ABJ]CODTYP <> [F:DABJ]CODTYP : RW = 1 : Endif  : # Type de donnÃ©es"
      If [F:ABJ]TYPDAT <> [F:DABJ]TYPDAT : RW = 1 : Endif  : # Type date"
      If [F:ABJ]MENLOC <> [F:DABJ]MENLOC : RW = 1 : Endif  : # NumÃ©ro du menu local"
      If [F:ABJ]TABDIV <> [F:DABJ]TABDIV : RW = 1 : Endif  : # Table diverse"
      If [F:ABJ]TYPFLD <> [F:DABJ]TYPFLD : RW = 1 : Endif  : # Type de champ"
      If [F:ABJ]DIMFAT <> [F:DABJ]DIMFAT : RW = 1 : Endif  : # Dimension pÃ¨re"
      If [F:ABJ]DIMINT <> [F:DABJ]DIMINT : RW = 1 : Endif  : # intit dimfat
      If [F:ABJ]DIMVALINT <> [F:DABJ]DIMVALINT : RW = 1 : Endif  : # intit dimfat
      If [F:ABJ]DIMFLD <> [F:DABJ]DIMFLD : RW = 1 : Endif  : # Nom du champ"
      If [F:ABJ]FLDORG <> [F:DABJ]FLDORG : RW = 1 : Endif  : # Formule alimentation"
      If [F:ABJ]FLDLIE <> [F:DABJ]FLDLIE : RW = 1 : Endif  : # Objet liÃ©"
      If [F:ABJ]INTDIM <> [F:DABJ]INTDIM : RW = 1 : Endif  : # Libellé
      If [F:ABJ]OPTJNT <> [F:DABJ]OPTJNT : RW = 1 : Endif  : # Option de jointure
      If [F:ABJ]AUTOEVAL <> [F:DABJ]AUTOEVAL : RW = 1 : Endif  : # auto jointure evalue
      If !RW : Call TXT([F:ABJ]INTDIM,RW) From DOSSUB : Endif
      If !RW : Call TXT([F:ABJ]AUTO,RW) From DOSSUB : Endif
      If RW
       DIFF  = 1
       [F:DABJ]      = [F:ABJ]
       Rewrite [DABJ]
       If fstat : Call ERREUR("ABIDIMFLD"-[F:DABJ]CODDIM-[F:DABJ]FLDDIM,2) From DOSDIC : Endif
      Endif
     Endif : # ABJ
    Next ABJ

    ### suppresion des champs inutiles ABJ
    For [DABJ]ABJ0 Where CODDIM=[F:ABI]CODDIM
     If !find([F:DABJ]ACTDIM,GSPE(1..GNBSPE))
      If !find([F:DABJ]FLDDIM,TBZONE(1..NBZONE))
       DIFF = 1
       Delete [DABJ]
       If fstat=1 : Call ERREUR("ABIDIMFLD"-[F:ABI]CODDIM-[F:DABJ]FLDDIM,3) From DOSDIC : Endif
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DABJ]ACTDIM,ACTIV) From DOSSUB
    Next DABZ

    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff dimensions"-[F:ABI]CODDIM-num$(DIFF),0) From GESECRAN
     Endif
     [F:DABI] = [F:ABI]
     If dim([F:DABI]UPDDAT)>0 : [F:DABI]UPDDAT = date$ : Endif
     If dim([F:DABI]UPDUSR)>0 : [F:DABI]UPDUSR = GUSER : Endif
     If dim([F:DABI]UPDTIM)>0 : [F:DABI]UPDTIM = time : Endif
     Rewrite [DABI]
     If fstat : Call ERREUR("ABIDIM"-[F:DABI]CODDIM,2) From DOSDIC : Endif
    Elsif ACTIV
     If dim([F:DABI]UPDDAT)>0 : [F:DABI]UPDDAT = date$ : Endif
     If dim([F:DABI]UPDUSR)>0 : [F:DABI]UPDUSR = GUSER : Endif
     If dim([F:DABI]UPDTIM)>0 : [F:DABI]UPDTIM = time : Endif
     Rewrite [DABI]
     If fstat : Call ERREUR("ABIDIM"-[F:DABI]CODDIM,2) From DOSDIC : Endif
    Endif
   Endif
  Endif
 Commit
Next
Close Local File [ABI] , [DABI]  , [ABJ] , [DABJ] , [DACV]
Return

