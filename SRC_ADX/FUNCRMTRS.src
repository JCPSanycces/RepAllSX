#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################################
# FUNCRMTRS : Contient                                       CRM javier 2006 #
#     - Le S/P de validation des transactions de saisie                      #
#     - Le traitement permettant de lancer manuellemnt le S/P de validation  #
#                            x = 1 pour agenda action commercial             #
#                                                                            #
#                                                                            #
#                         (menu local 3050)                                  #
##############################################################################
Local Integer OK

  Local File    CRMTRS [CTR]
  Local Mask    CRMTRS [DIA]
  Raz [M:DIA]
  Call DIALWIN(OK,mess(100,196,1),"ICRMTRS") From GESECRAN
  If OK = 2 Then
    Call OUVRE_TRACE(mess(100,196,1) - [M]LIB - [M]CTRNUM) From LECFIC
    Call VAL_CRMTRS([M]CTRTYP,[M]CTRNUM,nomap)
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC   
  Endif
  Close Local File [CTR]
  Close Local Mask [DIA]
End

##########################################################################################################
#-------------------------------------------#
# Actions sur champ de l'écran CRMTRS [DIA] #
#-------------------------------------------#
Subprog AV_LIB(VALEUR)
Variable Char    VALEUR()

  If [M]CTRTYP > 0 and [M]CTRTYP <= len(mess(0,3050,1)) Then
    VALEUR = mess([M]CTRTYP,3050,1)
  Else 
    VALEUR = mess(19,197,1)
  Endif
End

##########################################################################################################
Subprog AV_CTRDES(VALEUR)
Variable Char    VALEUR()

  If [M]CTRNUM <> "" and [M]CTRTYP > 0 and [M]CTRTYP <= len(mess(0,3050,1)) Then
    Read [CTR]CTR0=[M]CTRTYP;[M]CTRNUM
    If fstat Then
      Raz [F:CTR]
    Endif
    VALEUR = [F:CTR]CTRDES
  Endif
End

##################################################################################
# Traitement appelé par TRTCRMAGD
##################################################################################
##########################################################################################################
$GENDOS
#----- Variable locales -----#
Local Char    FENETRE(GLONFEN)(0..2)
Local Char    ECRAN  (GLONAMK)(0..10)
Local Integer I, TOK(1..10)
  #-----
  If clalev([F:CTR])<=0 Local File =APPLI+".CRMTRS"    [CTR] : Endif
  If clalev([F:CTV])<=0 Local File =APPLI+".CRMTRSVAL" [CTV] : Endif
  Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrit !
  Local File =APPLI+".AWINBRO"   [AWB] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINBOUT"  [AWT] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"      [AMK] : Endif
  #  If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON"   [AMZ] : Endif
  #  If clalev([F:AMA])<=0 Local File =APPLI+".AMSKACT"   [AMA] : Endif
  #  If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR"   [AMP] : Endif
  #  If clalev([F:ATY])<=0 Local File =APPLI+".ATYPE"     [ATY] : Endif
  #  If clalev([F:ACT])<=0 Local File =APPLI+".ACTION"    [ACT] : Endif
  #  If clalev([F:ATR])<=0 Local File =APPLI+".ACTPAR"    [ATR] : Endif
  #  If clalev([F:AAR])<=0 Local File =APPLI+".ACTCODPAR" [AAR] : Endif
  #  If clalev([F:ATB])<=0 Local File =APPLI+".ATABLE"    [ATB] : Endif
  #  If clalev([F:ATZ])<=0 Local File =APPLI+".ATABZON"   [ATZ] : Endif
  Local File =APPLI+".AMSK"      [AMK]
  Local File =APPLI+".AMSKZON"   [AMZ]
  Local File =APPLI+".AMSKACT"   [AMA]
  Local File =APPLI+".AMSKPAR"   [AMP]
  Local File =APPLI+".ATYPE"     [ATY]
  Local File =APPLI+".ACTION"    [ACT]
  Local File =APPLI+".ACTPAR"    [ATR]
  Local File =APPLI+".ACTCODPAR" [AAR]
  Local File =APPLI+".ATABLE"    [ATB]
  Local File =APPLI+".ATABZON"   [ATZ]
  Local File =APPLI+".ACTIV"     [ACV] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AOBJET"    [AOB] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
  #  If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
  Local File =APPLI+".ATEXTE"    [ATX]
  Local File =APPLI+".ATABTAB"   [ADV]
  #-----
  Raz TOK
  If TYP = 0 Then
    For I = 1 To 10
      TOK(I) = 1
    Next I
  Elsif dim(GVALTRANS) > 10 and GVALTRANS(11) = 2 Then
    TOK(TYP) = 1
  Else
    Raz FENETRE, ECRAN
    Case TYP
      When 1 : 
        #----- Agenda co
        FENETRE(0) = "OCRA"
        ECRAN(0) = "CRMAGD0"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(1) = "CRMAGD1"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(2) = "CRMAGD7"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(3) = "CRMAGD2"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(4) = "CRMAGD3"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(5) = "CRMAGD4"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(6) = "CRMAGD8"  # FGR 22/10/2008 : X3SUIVI49904
        ECRAN(7) = "CRMAGD6"  # FGR 22/10/2008 : X3SUIVI49904
    Endcase
    Raz I
    While FENETRE(I) <> "" and  I < 2
      Read [AWI]AWI0=FENETRE(I)
      If fstat Then
        Raz [F:AWI]
      Endif
      If [F:AWI]UPDFLG = 1 Then
        TOK(TYP) = 1
        Break
      Endif
      I += 1
    Wend
    If TOK(TYP) <> 1 Then
      Raz I
      While ECRAN(I) <> "" and I < 10
        Read [AMK]CODMSK=ECRAN(I)
        If fstat Then
          Raz [F:AMK]
        Endif
        If [F:AMK]UPDFLG = 1 Then
          TOK(TYP) = 1
          Break
        Endif
        I += 1
      Wend
    Endif
  Endif
  #----- Appels des validations de transaction -----#
  If sum(TOK(1..10)) > 2 Then
    Call VAL_CRMTRS(0,"",APPLI) From FUNCRMTRS
  Else
    If TOK(1) = 1 Then
      Call VAL_CRMTRS(1,"",APPLI) From FUNCRMTRS
    Endif
    If TOK(2) = 1 Then
      Call VAL_CRMTRS(2,"",APPLI) From FUNCRMTRS
    Endif
    If TOK(3) = 1 Then
      Call VAL_CRMTRS(3,"",APPLI) From FUNCRMTRS
    Endif
    If TOK(4) = 1 Then
      Call VAL_CRMTRS(4,"",APPLI) From FUNCRMTRS
    Endif
    If TOK(5) = 1 Then
      Call VAL_CRMTRS(5,"",APPLI) From FUNCRMTRS
    Endif
    If TOK(6) = 1 Then
      Call VAL_CRMTRS(6,"",APPLI) From FUNCRMTRS
    Endif   # FGR 22/10/2008 : X3SUIVI49904
    If TOK(7) = 1 Then
      Call VAL_CRMTRS(7,"",APPLI) From FUNCRMTRS
    Endif   # FGR 22/10/2008 : X3SUIVI49904
  Endif
Return

##################################################################################
# Traitement appelé par SUBMAC, SUBSRE, SUBITN
##################################################################################
$GENPATCH
  If clalev([F:CTR])<=0 Local File =APPLI+".CRMTRS"    [CTR] : Endif
  If clalev([F:CTV])<=0 Local File =APPLI+".CRMTRSVAL" [CTV] : Endif
  Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"      [AMK] : Endif
  #  If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON"   [AMZ] : Endif
  #  If clalev([F:AMA])<=0 Local File =APPLI+".AMSKACT"   [AMA] : Endif
  #  If clalev([F:AMP])<=0 Local File =APPLI+".AMSKPAR"   [AMP] : Endif
  #  If clalev([F:ATY])<=0 Local File =APPLI+".ATYPE"     [ATY] : Endif
  #  If clalev([F:ACT])<=0 Local File =APPLI+".ACTION"    [ACT] : Endif
  #  If clalev([F:ATR])<=0 Local File =APPLI+".ACTPAR"    [ATR] : Endif
  #  If clalev([F:AAR])<=0 Local File =APPLI+".ACTCODPAR" [AAR] : Endif
  #  If clalev([F:ATB])<=0 Local File =APPLI+".ATABLE"    [ATB] : Endif
  #  If clalev([F:ATZ])<=0 Local File =APPLI+".ATABZON"   [ATZ] : Endif
  Local File =APPLI+".AMSK"      [AMK]
  Local File =APPLI+".AMSKZON"   [AMZ]
  Local File =APPLI+".AMSKACT"   [AMA]
  Local File =APPLI+".AMSKPAR"   [AMP]
  Local File =APPLI+".ATYPE"     [ATY]
  Local File =APPLI+".ACTION"    [ACT]
  Local File =APPLI+".ACTPAR"    [ATR]
  Local File =APPLI+".ACTCODPAR" [AAR]
  Local File =APPLI+".ATABLE"    [ATB]
  Local File =APPLI+".ATABZON"   [ATZ]
  Local File =APPLI+".ACTIV"     [ACV] : # Déjà ouvert en local, le réouvrir !
  Local File =APPLI+".AOBJET"    [AOB] : # Déjà ouvert en local, le réouvrir !
  #  If clalev([F:ATX])<=0 Local File =APPLI+".ATEXTE"    [ATX] : Endif
  #  If clalev([F:ADV])<=0 Local File =APPLI+".ATABTAB"   [ADV] : Endif
  Local File =APPLI+".ATEXTE"    [ATX]
  Local File =APPLI+".ATABTAB"   [ADV]
  #
  Call VAL_CRMTRS(TYP,"",APPLI) From FUNCRMTRS
Return

#========================================================================================
# FGR 16/11/2009 : X3SUIVI57491 (début)
#----------------------------------------------------------------------------------------
$DYN_TRTCRMTRS
Local Char SZWIN(GLONFEN)
Local Char SZABRFIC(GLONABR)
Local Char SZONGLET(250)

  SZABRFIC = 'CTR'
  # 1
  SZWIN = 'OCBA'
  SZONGLET = '"[CBA0]","[CBA1]","[CBA2]","[CBA3]","[CBA4]","[CBA6]","[CBA7]","[CBA8]","[CBA9]"'
  Call GET_TRTSALTRS(SZWIN, SZABRFIC, SZONGLET, SZREQ1, IREQ1) From FUNSALTRS
Return

#----------------------------------------------------------------------------------------
$GEN_TRTCRMTRS
Local Char SZADXIFS
Local Char SZADXIRS
Local Integer IVALIDOK
Local Integer IEXIST
Local Char SZPROGNAME(GLONADC)
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer NI
# 20 lignes
#  5 colonnes :
#               (0) = Complément "Close Local Mask" et "Default Mask"
#               (1) = Listes des autres Mask à ouvrir
#               (2) = Complément affectation classe [F] dans classe [M]
Local Char SZREQ1(250)(20,5)
Local Integer IREQ1
  #------------------------------------------
  Raz SZREQ1
  IREQ1 = 0
  #------------------------------------------
  Gosub DYN_TRTCRMTRS
  #------------------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #------------------------------------------
  SZPROGNAME = "WCRM" + num$(adxpid)
  SZFULLSRC = filpath("TRT", SZPROGNAME, "src", APPLI)
  SZFULLADX = filpath("TRT", SZPROGNAME, "adx", APPLI)
  #------------------------------------------
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [TRS_]
  #------------------------------------------
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"  Using [TRS_]
  Wrseq "#Traitement généré pour les transactions CRM en masse"  Using [TRS_]
  Wrseq "$TRANSAC_CRM"  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '  If clalev([F:ADS1])=0  Local File ADOSSIER [ADS1] : Endif'  Using [TRS_]
  Wrseq '  Read [ADS1]DOSSIER=APPLI : If fstat Then Raz [F:ADS1] : Endif'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '  For [CTR] Where' - CRITERES  Using [TRS_]
  Wrseq '    If [F:CTR]CTRTYP <> WTYP Then'  Using [TRS_]
  Wrseq '      Case WTYP'  Using [TRS_]
  Wrseq '        When 1'  Using [TRS_]
  Wrseq '          Close Local Mask [CBA0],[CBA1],[CBA2],[CBA3],[CBA4],[CBA6],[CBA7],[CBA8],[CBA9]' + SZREQ1(0,0)  Using [TRS_]
  Wrseq '        When Default'  Using [TRS_]
  Wrseq '      Endcase'  Using [TRS_]
  Wrseq '      Case [F:CTR]CTRTYP'  Using [TRS_]
  Wrseq '        When 1'  Using [TRS_]
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  Wrseq '          Local Integer W_O'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA6", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA7", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA8", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
  Wrseq '          Call VALIDDIRECT ("CBA9", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK'  Using [TRS_]
   # FGR 21/10/2011 : X3SUIVI77325 (fin)
  Wrseq '          Local Mask =APPLI+".CBA0" [CBA0],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA1" [CBA1],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA2" [CBA2],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA3" [CBA3],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA4" [CBA4],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA6" [CBA6],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA7" [CBA7],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA8" [CBA8],'  Using [TRS_]
  Wrseq '&                    =APPLI+".CBA9" [CBA9]'  Using [TRS_]
  For NI = 0 To IREQ1-1
    Wrseq '          ' + SZREQ1(NI,1)  Using [TRS_]
  Next NI
  Wrseq '        When Default'  Using [TRS_]
  Wrseq '      Endcase'  Using [TRS_]
  Wrseq '      WTYP = [F:CTR]CTRTYP'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '    WDIE_DTRTYP = [F:CTR]CTRTYP'  Using [TRS_]
  Wrseq '    ACTION = "OUVRE"'  Using [TRS_]
  Wrseq '    Gosub TRT_DIETRS From SUBDST'  Using [TRS_]
  Wrseq '    Call DEBTRANS From GLOCK'  Using [TRS_]
  Wrseq '    Trbegin [CTR]'  Using [TRS_]
  Wrseq '    Case [F:CTR]CTRTYP'  Using [TRS_]
  Wrseq '      When 1'  Using [TRS_]
  Wrseq '        [M:CBA0] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA1] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA2] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA3] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA4] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA6] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA7] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA8] = [F:CTR]'  Using [TRS_]
  Wrseq '        [M:CBA9] = [F:CTR]'  Using [TRS_]
  Wrseq '        ' + SZREQ1(0,2)  Using [TRS_]
  Wrseq '        Gosub LOADDATA From SUBCBAB'  Using [TRS_]
  Wrseq '        Gosub TRT_ECRAN From SUBCBA'  Using [TRS_]
  Wrseq '      When Default'  Using [TRS_]
  Wrseq '    Endcase'  Using [TRS_]
  Wrseq '    If GOK < 1 Then'  Using [TRS_]
  Wrseq '      Call ECR_TRACE(mess(21,123,1) - mess([F:CTR]CTRTYP,3050,1) - [F:CTR]CTRNUM,1) From GESECRAN'  Using [TRS_]
  Wrseq '      Rollback'  Using [TRS_]
  Wrseq '    Else'  Using [TRS_]
  Wrseq '      Call ECR_TRACE(mess(14,123,1) - mess([F:CTR]CTRTYP,3050,1) - [F:CTR]CTRNUM,0) From GESECRAN'  Using [TRS_]
  Wrseq '      Commit'  Using [TRS_]
  Wrseq '    Endif'  Using [TRS_]
  Wrseq '  Next'  Using [TRS_]
  Wrseq 'Return'  Using [TRS_]
  Wrseq ''  Using [TRS_]
  Openo Using [TRS_]
  #------------------------------------------
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #------------------------------------------
  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, APPLI, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur lors de la génération : on appelle l'ancien pour que ça fonctionne au moins en standard
    # Je ne l'efface pas. Ca permettrait de trouver ce qui ne va pas
    #IEXIST = 1
    #Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
    Call OLD_VAL_CRMTRS(TYP,NUM,APPLI)
    Return
  Endif
  #------------------------------------------
  Gosub TRANSAC_CRM From =APPLI + "." + SZPROGNAME
  #------------------------------------------
  # A mettre dans l'appelant
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
Return
# FGR 16/11/2009 : X3SUIVI57491 (fin)
#========================================================================================

##############################################################################
# VAL_CRMTRS : S/P Validation en masse des transactions de saisie CRM        #
# -------------------------------------------------------------------------- #
# Subprog VAL_CRMTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0 = Toutes                                                       #
#           1 = Agenda commercial                                            #
#           2 =                                                              #
#           3 =                                                              #
#    NUM  : Code de la transaction à valider (3c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:CTR]CRMTRS   Table des transactions                            #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_CRMTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
Local  Integer  WTYP, OK
Local  Char     ACTION(20), CRITERES(30)
Local Char W_DIE_ABRFIC(3)

  WDIE_ABRFIC = "CRM"
  ACTION = "MASSE"
  Case TYP
     When 0       : CRITERES = "1=1"
     When 1       : CRITERES = "CTRTYP=1"
     When 2       : CRITERES = "CTRTYP=2"
     When 3       : CRITERES = "CTRTYP=3"
     When 4       : CRITERES = "CTRTYP=4"
     When 5       : CRITERES = "CTRTYP=5"
     When 6       : CRITERES = "CTRTYP=6" # FGR 22/10/2008 : X3SUIVI49904
     When 7       : CRITERES = "CTRTYP=7" # FGR 22/10/2008 : X3SUIVI49904
     When Default : CRITERES = ""
  Endcase
  If NUM <> "" and CRITERES <> "" Then
    CRITERES += " and CTRNUM=NUM"
  Endif
  If clalev([F:CTR])<=0 Local File =APPLI+".CRMTRS"    [CTR] : Endif
  If clalev([F:CTV])<=0 Local File =APPLI+".CRMTRSVAL" [CTV] : Endif

  Gosub GEN_TRTCRMTRS
End

#====================================
Subprog OLD_VAL_CRMTRS(TYP,NUM,APPLI)
Value Integer  TYP
Value Char     NUM
Value Char     APPLI
Local Integer  WTYP, OK
Local Char     ACTION(20), CRITERES(30)
Local Char W_DIE_ABRFIC(3)
Local Integer W_O                         # FGR 21/10/2011 : X3SUIVI77325

  WDIE_ABRFIC = "CRM"
  ACTION = "MASSE"
  Case TYP
     When 0       : CRITERES = "1=1"
     When 1       : CRITERES = "CTRTYP=1"
     When 2       : CRITERES = "CTRTYP=2"
     When 3       : CRITERES = "CTRTYP=3"
     When 4       : CRITERES = "CTRTYP=4"
     When 5       : CRITERES = "CTRTYP=5"
     When 6       : CRITERES = "CTRTYP=6" # FGR 22/10/2008 : X3SUIVI49904
     When 7       : CRITERES = "CTRTYP=7" # FGR 22/10/2008 : X3SUIVI49904
     When Default : CRITERES = ""
  Endcase
  If NUM <> "" and CRITERES <> "" Then
    CRITERES += " and CTRNUM=NUM"
  Endif
  If clalev([F:CTR])<=0 Local File =APPLI+".CRMTRS"    [CTR] : Endif
  If clalev([F:CTV])<=0 Local File =APPLI+".CRMTRSVAL" [CTV] : Endif
  # FGR 21/10/2011 : X3SUIVI77325 (début)
  If clalev([F:ADS1])=0  Local File ADOSSIER [ADS1] : Endif
  Read [ADS1]DOSSIER=APPLI : If fstat Then Raz [F:ADS1] : Endif
  # FGR 21/10/2011 : X3SUIVI77325 (fin)
  For [CTR] Where evalue(CRITERES)
    If [F:CTR]CTRTYP <> WTYP Then
      Case WTYP
        When 1
          Close Local Mask [CBA0], [CBA1], [CBA2], [CBA3], [CBA4], [CBA6], [CBA7], [CBA8], [CBA9]  # FGR 22/10/2008 : X3SUIVI49904 : manquait CBA8 et CBA9
        When Default
      Endcase
      #
      Case [F:CTR]CTRTYP
        When 1
          # FGR 21/10/2011 : X3SUIVI77325 (début)
          Call VALIDDIRECT ("CBA0", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA1", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA2", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA3", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA4", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA6", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA7", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA8", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          Call VALIDDIRECT ("CBA9", APPLI, [F:ADS1]NBRLAN, [F:ADS1]LAN, 0, W_O) From VALMSK
          # FGR 21/10/2011 : X3SUIVI77325 (fin)
          Local Mask =APPLI+".CBA0" [CBA0],
&                    =APPLI+".CBA1" [CBA1],
&                    =APPLI+".CBA2" [CBA2],
&                    =APPLI+".CBA3" [CBA3],
&                    =APPLI+".CBA4" [CBA4],
&                    =APPLI+".CBA6" [CBA6],
&                    =APPLI+".CBA7" [CBA7],
&                    =APPLI+".CBA8" [CBA8],
&                    =APPLI+".CBA9" [CBA9]   # FGR 22/10/2008 : X3SUIVI49904 : manquait CBA8 et CBA9
        When Default
      Endcase
      WTYP = [F:CTR]CTRTYP
    Endif
    WDIE_DTRTYP = [F:CTR]CTRTYP
    ACTION = "OUVRE"
    Gosub TRT_DIETRS From SUBDST
    Call DEBTRANS From GLOCK
    Trbegin [CTR]
    Case [F:CTR]CTRTYP
      When 1
        [M:CBA0] = [F:CTR]
        [M:CBA1] = [F:CTR]
        [M:CBA2] = [F:CTR]
        [M:CBA3] = [F:CTR]
        [M:CBA4] = [F:CTR]
        [M:CBA6] = [F:CTR]
        [M:CBA7] = [F:CTR]
        [M:CBA8] = [F:CTR]   # FGR 22/10/2008 : X3SUIVI49904 : manquait CBA8 et CBA9
        [M:CBA9] = [F:CTR]   # FGR 22/10/2008 : X3SUIVI49904 : manquait CBA8 et CBA9
        Gosub LOADDATA From SUBCBAB
        Gosub TRT_ECRAN From SUBCBA
      When Default
    Endcase
    If GOK < 1 Then
      Call ECR_TRACE(mess(21,123,1) - mess([F:CTR]CTRTYP,3050,1) - [F:CTR]CTRNUM,1) From GESECRAN
      Rollback
    Else
      Call ECR_TRACE(mess(14,123,1) - mess([F:CTR]CTRTYP,3050,1) - [F:CTR]CTRNUM,0) From GESECRAN
      Commit
    Endif
  Next
End
