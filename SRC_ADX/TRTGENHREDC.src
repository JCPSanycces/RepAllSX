$ACTION
Case ACTION
    When "OK"                :    Gosub OK
    When "END"               :    Gosub END_DEC
    When "DEBUT"             :    Gosub DEBUT
    ##When "EXEC"            :    Gosub EXEC
    ##When "TERMINE"         :    Gosub TERMINE
    When Default
Endcase
Return


$DEBUT

  [M:HRSGE0]ALLSIT = 2
  If !GIMPORT Then Affzo [M:HRSGE0]ALLSIT : Endif
  Grizo [M:HRSGE0]FCY
  [M:HRSGE0]EMPLOC =1 : Affzo [M:HRSGE0]EMPLOC
  Call GENHRLOCAM([M:HRSGE0]EMPLOC) From TRTGENHRLOCAM

Return

$OK

Local Mask XMJ[XMJ]

#######################

Local Char ENREG(19)
Local Char ENREG1(241)
Local Char TYP
Local Char SOC

Local Date XDATPAY
Local Integer LPERIODE
Local Integer LNUMAFFIL
Local Integer I
Local Integer MM
Local Integer AAAA
Local Decimal REVERS ,REL , PLAF  ########variable  bloc B02
Local Char PATH (250)

#Période

LPERIODE=val(format$("N0:6X",format$("D:YYYYMM", [M:HRSGE0]ENDDAT)))

#N0 CNSS Société
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif

Read[CPY]CPY0=[XMJ]CPY
If fstat=0
    SOC=[F:CPY]XG_NUMSSC
Endif

#------<Début> Z.Meryame 05/03/2014
# Variables pour Poste Client
Local Char FICDON(GDIMFIC),FICHIER(GDIMFIC),NOMFIC(GDIMFIC),URL(GDIMFIC)
Local Char    FILBAL(250) , NAM(250) , FICHIER(GDIMFIC) , CHEMIN(GDIMFIC) , MACHINE(GDIMFIC) , CRITSPE(250)
Local Char  EXT(5)
Local Char  POINT(1)

Local Integer STAT

NAM    = "DS_"+num$(val(SOC))+"_"+num$(LPERIODE) # Nom du fichier
EXT    = "txt"                                   # Extension du fichier

If left$([M:HRSGE0]XG_FICHE,1)="#"
[M:HRSGE0]EMPLOC =1
 Call SET_NAMCLI([M:HRSGE0]XG_FICHE) From ORDSYS
Else
 [M:HRSGE0]EMPLOC =2
 If [M:HRSGE0]XG_FICHE="" : [M:HRSGE0]XG_FICHE= filpath("tmp","","",nomap,"","") : Endif
Endif

FICHIER = [M:HRSGE0]XG_FICHE
Call MACHINE(FICHIER,MACHINE,CHEMIN) From ORDSYS
NOMFIC  = NAM
If [M:HRSGE0]EMPLOC = 1 : # Client
 FICHIER = filpath(CHEMIN,NOMFIC,EXT)
 Call SET_FICNAM(FICHIER,FICDON,URL) From ORDSYS
Else
 FICDON = filpath(CHEMIN,NOMFIC,EXT,"","",MACHINE)
Endif
Call GENERER(val(SOC),LPERIODE,FICDON)

If [M:HRSGE0]EMPLOC = 1
 Call COPCLI(FICDON,FICHIER,STAT) From ORDSYS
 If STAT=1
  # Fichier non copiÃ© sur le poste client
   Return
 Elsif STAT>1
  # Fichier inexistant
    Return
 Endif
Endif
Infbox ("Génération Fichier : DS_"+num$(val(SOC))+"_"+num$([L]LPERIODE)+".TXT ok")
#------<Fin> Z.Meryame 05/03/2014
Return

################################################################################
$OK_DEC
FIN=1
Return

################################################################################
$END_DEC
Raz [M:HRSGE0]
FIN=1
Return

############################
$OPEN_FILE
    If clalev([F:HRSDM])=0 : Local File HRSTADLM [HRSDM] : Endif
    If clalev([F:HRSSA])=0 : Local File HRSOCSECSET1 [HRSSA] : Endif
    If clalev([F:HRSSC])=0 : Local File HRSOCSECSET3 [HRSSC] : Endif
    If clalev([F:HRSSB])=0 : Local File HRSOCSECSET2 [HRSSB] : Endif
    If clalev([F:HRSIB])=0 : Local File HRSOCSECINC2 [HRSIB] : Endif
    If clalev([F:HRSIA])=0 : Local File HRSOCSECINC1 [HRSIA] : Endif
    If clalev([F:HRSSS])=0 : Local File HRSOCSECSETS [HRSSS] : Endif

Return

Subprog GENERER(LNUMAFFIL,LPERIODE,LFICH)
    Value Char LFICH
    Value Integer LNUMAFFIL
    Value Integer LPERIODE

    Local Integer A,B,C,D,E,OK4,OK5
    Local Char LIGNE1 (250)
    Local Char LIGNE2 (250)
    Local Char XCRITE (250)
    Local Char XCRITE1(250)
    Gosub OPEN_FILE

    OK=0
######################EXPORT DU FICHIER SORTIE###############
XCRITE="1=1"
If [M:HRSGE0]CPY<>""
   XCRITE +="& [HRSSC]CPY=[M:HRSGE0]CPY"
Endif
If [M:HRSGE0]FCY<>""
   XCRITE +="& [HRSSC]FCY=[M:HRSGE0]FCY"
Endif
If [M:HRSGE0]CRI <> "" Then
   XCRITE1 = [M:HRSGE0]CRI
Else
   XCRITE1 ="1=1"
Endif
Local Char XSALREEL,XSALPLAF, XTSALREEL,XTSALPLAF
#Openo "#@C:\DEC_CNSS\CNSS_ENVOI\DS_"+num$(LNUMAFFIL)+"_"+num$(LPERIODE)+".TXT"
 Openo LFICH, 0 Using[XXX]  #Z.Meryame 05/03/2014
  adxirs = chr$(13)+chr$(10)
  For[HRSDM] Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL
           Wrseq [HRSDM]LTYPENR,[HRSDM]NIDTR,[HRSDM]LCAT,space$(241) Using[XXX]
  Next


 For[HRSSA]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL

  Wrseq[HRSSA]LTYPENR,format$("N0:7X",[HRSSA]NUMAFFIL), format$("N0:6X",[HRSSA]LPERIOD),
&     format$("K:40X",[HRSSA]LRAISSOC),format$("K:40X",[HRSSA] LACTIV),format$("K:120X",[HRSSA]LADRESS),
&     format$("K:20X",[HRSSA]LVILLE),format$("K:6X",[HRSSA]CODEPOS), format$("K:2X",[HRSSA]CODAGENCE),format$("K:8X",format$("DDMMYYYY",[HRSSA]DATEMISS)),format$("K:8X",format$("DDMMYYYY",[HRSSA]
& DATEXIG)) Using
& [XXX]
 Next

For[HRSSC]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL and evalue(XCRITE) and evalue(XCRITE1)
#--------------------
Raz XSALREEL,XSALPLAF
XSALREEL=num$([HRSSC]SALREL)
XSALPLAF=num$([HRSSC]SALPLAF)
Call XCALC_SAL(XSALREEL)
Call XCALC_SAL(XSALPLAF)

  Wrseq [HRSSC]LTYPENR,format$("N0:7X",[HRSSC]NUMAFFIL),format$("N0:6X",[HRSSC]LPERIOD),format$("N0:9X",[HRSSC]NUMASSUR),format$("K:60X",[HRSSC] LNOMPRE),
&    format$("N0:2X",[HRSSC]NENFANT),format$("N0:6X",[HRSSC]AFPAYER),format$("N0:6X",[HRSSC]AFDEDUIRE),format$("N0:6X",[HRSSC]AFNETPAYER),
&    format$("N0:6X",[HRSSC] AFREVERSER),format$("N0:2X",[HRSSC]NJOURDEC),format$("N0:13X",XSALREEL)
&    ,format$("N0:9X",XSALPLAF),format$("K:2X",[HRSSC]LSITUATION),format$("N0:19X", [HRSSC]SCTR),space$(104) Using[XXX]

Next

 For[HRSSB]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL
    Raz XTSALREEL,XTSALPLAF
    XTSALREEL=num$([HRSSB]TSALREL)
    XTSALPLAF=num$([HRSSB]TSALPLAF)
    Call XCALC_SAL(XTSALREEL)
    Call XCALC_SAL(XTSALPLAF)
 Wrseq [HRSSB]LTYPENR, format$("N0:7X",[HRSSB]NUMAFFIL),format$("N0:6X",[HRSSB]LPERIOD),format$("N0:6X",[HRSSB]NBSAL),
&      format$("N0:6X",[HRSSB] NBENFANT),format$("N0:12X",[HRSSB]TAFPAYER),format$("N0:12X",[HRSSB]TAFDEDUIRE),format$("N0:12X",[HRSSB]TAFNETPAYR)
&      ,format$("N0:15X",[HRSSB] TNUMMAT),format$("N0:12X",[HRSSB]TAFREVERSE),format$("N0:6X",[HRSSB]TNJOURDEC),format$("N0:15X",XTSALREEL)
&      ,format$("N0:13X",XTSALPLAF),format$("N0:19X", [HRSSB]TSCTR) ,space$(116) Using[XXX]
  Next


 For[HRSIB]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL
    Raz XSALREEL,XSALPLAF
    XSALREEL=num$([HRSIB]SALREL)
    XSALPLAF=num$([HRSIB]SALPLAF)
    Call XCALC_SAL(XSALREEL)
    Call XCALC_SAL(XSALPLAF)

     Wrseq "B04", format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:9X",[HRSIB]NUMASSUR),format$("K:60X",[HRSIB]LNOMPRE)
&         ,format$("K:8X",[HRSIB] LNUMCIN),format$("N0:2X",[HRSIB]NJOURDEC),format$("N0:13X",XSALREEL),format$("N0:9X",XSALPLAF)
&         ,format$("N0:19X",[HRSIB]SCTR) ,space$(124) Using[XXX]
  OK4=1
Next
If OK4=0
  Wrseq "B04",format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),space$(9),space$(60),space$(8),format$("N0:2X",0)
&       ,format$("N0:13X",0),format$("N0:9X",0),format$("N0:19X",0) ,space$(124) Using[XXX]
Endif

OK5=0
For[HRSIA]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL
   Raz XTSALREEL,XTSALPLAF
    XTSALREEL=num$([HRSIA]TSALREL)
    XTSALPLAF=num$([HRSIA]TSALPLAF)
    Call XCALC_SAL(XTSALREEL)
    Call XCALC_SAL(XTSALPLAF)
  Wrseq "B05",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",[HRSIA]NBSAL),format$("N0:15X",[HRSIA]TNUMMAT)
&      ,format$("N0:6X",[HRSIA] TNJOURDEC),format$("N0:15X",XTSALREEL),
&    format$("N0:13X",XTSALPLAF),format$("N0:19X",[HRSIA]TSCTR),space$(170) Using[XXX]
OK5=1
Next

If OK5=0  Then
 Wrseq "B05",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",0),format$("N0:15X",0)
&      ,format$("N0:6X",0),format$("N0:15X",0),
&    format$("N0:13X",0),format$("N0:19X",0),space$(170) Using[XXX]
Endif

 For[HRSSS]  Where LPERIOD=[L]LPERIODE and NUMAFFIL=[L]LNUMAFFIL
   Raz XTSALREEL,XTSALPLAF
    XTSALREEL=num$([HRSSS]TSALREL)
    XTSALPLAF=num$([HRSSS]TSALPLAF)
    Call XCALC_SAL(XTSALREEL)
    Call XCALC_SAL(XTSALPLAF)

  Wrseq "B06",  format$("N0:7X",LNUMAFFIL),format$("N0:6X",LPERIODE),format$("N0:6X",[HRSSS]NBSAL),format$("N0:15X",[HRSSS]TNUMMAT)
&       ,format$("N0:6X",[HRSSS] TNJOURDEC),
&    format$("N0:15X",XTSALREEL),format$("N0:13X",XTSALPLAF),format$("N0:19X",[HRSSS]TSCTR),space$(170) Using[XXX]

  Next
                  Openo Using[XXX]    ##### Using [BUF0]

#Infbox ("Génération Fichier : C:\DEC_CNSS\CNSS_ENVOI\DS_"+num$(LNUMAFFIL)+"_"+num$([L]LPERIODE)+".TXT ok")



End

#=====================================================================================================
Subprog XCALC_SAL(XSALR)
Variable Char XSALR
If val(XSALR)<>0 Then

    Local Integer XI,XU : Raz XI,XU
    Local Char XDCM  : Raz XDCM
    For XI=1  To len(XSALR)
       If mid$(XSALR,XI,1)="." Then
          XU=XI
          XDCM=mid$(XSALR,XI+1,2) : Break
       Endif
    Next
    If val(XDCM)=0 Then
       XDCM="00"
    Else
      If len(XDCM)=1 Then
         XDCM=XDCM+"0"
      Elsif len(XDCM)>2 Then
         XDCM=mid$(XDCM,1,2)
      Endif
    Endif

    If XU>0 Then
       XSALR=mid$(XSALR,1,XU-1)+XDCM
    Else
       XSALR=XSALR+XDCM
    Endif
Else
    XSALR="0"
Endif
End

