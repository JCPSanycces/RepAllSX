End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "RAZCRE"       : Gosub RAZCRE
    When "SETBOUT"      : Gosub SETBOUT
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$RAZCRE
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET    
Return

##########################################################################################################
$LIENS
  #Charge une description standard ou personnalisée des critères
  Call LOADCRIT([M:FID0]CRITAB, [M:FID0]CAT) From SUBFIDB
  Affzo [M:FID1]1-99
  Affzo [M:FID2]1-99
Return

##########################################################################################################
$VERIF_CRE
Return

##########################################################################################################
$VERIF_MOD
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call MAJTEXTRA([M:FID0]CRITABAXX, "FIEDIC", "CRITABAXX", [M:FID0]CRITAB, [M:FID0]CAT) From ATEXTRA
  #Enregistre une description standard ou personnalisée des critères
  Gosub SAVECRIT From SUBFIDB
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
Return

##########################################################################################################
$ANNULE
Local Integer ITER

  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call SUPTEXTRA("FIEDIC", "CRITABAXX", [M:FID0]CRITAB, [M:FID0]CAT) From ATEXTRA
  For ITER = 0 To [M:FID1]NBFIE-1
    Call SUPTEXTRA("FIEDICFIE", "SELCRIAXX", [M:FID0]CRITAB, [M:FID1]SELCRIFIE(ITER) + "~" + [M:FID0]CAT) From ATEXTRA
  Next
  For ITER = 0 To [M:FID2]NBFIEX-1
    Call SUPTEXTRA("FIEDICFIE", "SELCRIAXX", [M:FID0]CRITAB, [M:FID2]SELCRIFIEX(ITER) + "~" + [M:FID0]CAT) From ATEXTRA
  Next
  # FGR 23/12/2009 : X3SUIVI61144
  Delete [FDF] Where [F:FDF]CRITAB = [M:FID0]CRITAB and [F:FDF]CAT = [M:FID0]CAT
  If fstat Then
    IFIDPBL = 1
    GOK = 0
    Call FSTA("FDF") From GLOCK
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  #Charge une description standard ou personnalisée des critères
  Call LOADCRIT([M:FID0]CRITAB, [M:FID0]CAT) From SUBFIDB
  Affzo [M:FID1]1-99
  Affzo [M:FID2]1-99
Return

##########################################################################################################
$APRES_MOD
  #Charge une description standard ou personnalisée des critères
  Call LOADCRIT([M:FID0]CRITAB, [M:FID0]CAT) From SUBFIDB
  Affzo [M:FID1]1-99
  Affzo [M:FID2]1-99
Return

##########################################################################################################
Subprog AM_CRITAB(VALEUR)
Variable Char    VALEUR()

  [M:FID0]CRITAB = VALEUR
  If VALEUR = "" Then
    [M:FID0]CRITABAXX = ""
  Else
    Read [ATB]CODFIC=[M:FID0]CRITAB
    If fstat Then
      [M:FID0]CRITABAXX = [M:FID0]CRITAB
    Else
      Call TEXTE([F:ATB]INTITFIC, [M:FID0]CRITABAXX) From OBJDIV
    Endif
  Endif
  #Charge une description standard ou personnalisée des critères
  Call LOADCRIT([M:FID0]CRITAB, [M:FID0]CAT) From SUBFIDB
  Affzo [M:FID0]1-99
  Affzo [M:FID1]1-99
  Affzo [M:FID2]1-99
End

##########################################################################################################
Subprog IB_NBFIE

  Gosub ACTIVEPSS From SUBTGLB
End

##########################################################################################################
Subprog B1_NBFIE

  Gosub SETPSS From SUBTGLB
End

##########################################################################################################
Subprog AM_SELCRISRT(VALEUR)
Variable Decimal VALEUR

  #Vérifie si le calcul des positions est activé
  Read [DVA]DVA0="PSS";GUSER
  If fstat Then
    [M:FID1]SELCRISRT(nolign-1) = VALEUR
    Affzo [M:FID1]SELCRISRT(nolign-1)
    End
  Else
    If [F:DVA]INTX(0) = 0 Then
      [M:FID1]SELCRISRT(nolign-1) = VALEUR
      Affzo [M:FID1]SELCRISRT(nolign-1)
      End
    Endif
  Endif

#Maintien une suite logique de numéros d'ordres
Local Integer INOL
Local Integer ITERTAB
Local Integer ITERWHOLE
Local Integer ITERMORE
Local Integer ITERLACK
Local Integer INUMFOUND
Local Integer IMINI
Local Integer ITESTMINI
Local Integer IVALEXIST
Local Integer IHOMONYME
Local Integer IPHOTO(250)
Local Integer ITERPHOTO
Local Integer IMAXPHOTO
Local Integer IGOODINDEX
Local Integer ICOMPUTE(250)
Local Integer ICOUNT
Local Integer IVALPASSED
Local Integer ITEROCC

  INOL = nolign-1
  INUMFOUND = 0
  ITESTMINI = 0
  IMINI = 0
  Call TEMPON(mess(44,182,1)) From GESECRAN
  If VALEUR >= dim([M:FID1]SELCRISRT) Then
    VALEUR = dim([M:FID1]SELCRISRT)-1
  Endif
  [M:FID1]SELCRISRT(nolign-1) = VALEUR
  #Charge IPHOTO
  Raz IPHOTO
  For ITERWHOLE = 0 To dim([M:FID1]SELCRISRT)-1
    IPHOTO(ITERWHOLE) = [M:FID1]SELCRISRT(ITERWHOLE)
  Next
  For ITERWHOLE = 1 To dim([M:FID1]SELCRISRT)-1
    #Compte les occurences de chaque chiffre
    Raz ICOMPUTE
    For ITEROCC = 1 To dim([M:FID1]SELCRISRT)-1
      ICOUNT = 0
      For ITERTAB = 0 To [M:FID1]NBFIE-1
        If [M:FID1]SELCRISRT(ITERTAB) = ITEROCC Then
          ICOUNT += 1
        Endif
      Next
      ICOMPUTE(ITEROCC) = ICOUNT
    Next
    #Cherche si VALEUR est égale à ITERWHOLE
    IVALEXIST = 0
    For ITERTAB = 0 To [M:FID1]NBFIE-1
      If [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE Then
        If ITERTAB = INOL Then
          IVALEXIST = 1
          Break
        Endif
      Endif
    Next
    #Réalise les contrôles nécessaires à la priorité des incrémentations
    If ICOMPUTE(ITERWHOLE) > 1 Then
      If ITERWHOLE <> [M:FID1]SELCRISRT(INOL) Then
        #On recherche le chiffre avec le poids initiale le plus fort
        IMAXPHOTO = 0
        For ITERPHOTO = 0 To dim(IPHOTO)-1
          If [M:FID1]SELCRISRT(ITERPHOTO) = ITERWHOLE Then
            If IPHOTO(ITERPHOTO) > IMAXPHOTO Then
              IMAXPHOTO = IPHOTO(ITERPHOTO)
              IGOODINDEX = ITERPHOTO
            Endif
          Endif
        Next
      Endif
    Endif
    #Cherche ITERWHOLE dans le tableau
    ITERMORE = ITERWHOLE
    IVALPASSED = 0
    INUMFOUND = 0
    For ITERTAB = 0 To [M:FID1]NBFIE-1
      If [M:FID1]SELCRISRT(ITERTAB) > 0 Then
        If [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE Then
          If ITERTAB = INOL Then
            VALEUR = ITERWHOLE
            [M:FID1]SELCRISRT(ITERTAB) = VALEUR
          Else
            If ICOMPUTE(ITERWHOLE) > 1 Then
              If ITERWHOLE = [M:FID1]SELCRISRT(INOL) Then
                [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE + 1
              Else
                If ITERTAB = IGOODINDEX Then
                  [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE + 1
                Else
                  [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE
                Endif
              Endif
            Else
              [M:FID1]SELCRISRT(ITERTAB) = ITERWHOLE
            Endif
          Endif
          ITERMORE += 1
          INUMFOUND = 1
        Endif
      Endif
    Next
    If !INUMFOUND Then
      #On recherche le chiffre immédiatement supérieur à ITERWHOLE
      IMINI = 250
      INUMFOUND = 0
      For ITERTAB = 0 To [M:FID1]NBFIE-1
        If [M:FID1]SELCRISRT(ITERTAB) > 0 Then
          ITESTMINI = [M:FID1]SELCRISRT(ITERTAB) - ITERWHOLE
          If ITESTMINI > 0 Then
            If ITESTMINI < IMINI Then
              IMINI = ITESTMINI
              ITERMORE = [M:FID1]SELCRISRT(ITERTAB)
            Endif
          Endif
        Endif
      Next
      #Cherche si VALEUR est égale à ITERMORE
      #Cherche également si un homonyme de valeur est présent
      IVALEXIST = 0
      IHOMONYME = 0
      For ITERTAB = 0 To [M:FID1]NBFIE-1
        If [M:FID1]SELCRISRT(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            IVALEXIST = 1
          Else
            IHOMONYME = 1
          Endif
        Endif
      Next
      ITERLACK = ITERMORE - IMINI
      For ITERTAB = 0 To [M:FID1]NBFIE-1
        If [M:FID1]SELCRISRT(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            If IHOMONYME Then
              VALEUR = (ITERMORE - IMINI) + 1
            Else
              VALEUR = ITERMORE - IMINI
            Endif
            [M:FID1]SELCRISRT(ITERTAB) = VALEUR
          Else
            If IVALEXIST Then
              If ITERLACK = [M:FID1]SELCRISRT(INOL) Then
                ITERLACK += 1
                [M:FID1]SELCRISRT(ITERTAB) = ITERLACK
              Else
                [M:FID1]SELCRISRT(ITERTAB) = ITERLACK
              Endif
            Else
              [M:FID1]SELCRISRT(ITERTAB) = ITERLACK
            Endif
          Endif
          ITERLACK += 1
        Endif
      Next
    Endif
  Next
  Call TEMPOFF From GESECRAN
  Affzo [M:FID1]1-99
End

##########################################################################################################
Subprog C_SELCRIFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:FID0]CRITAB, VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 1
    GERR = 2
    End
  Else
    Read [ATZ]CODZONE=[M:FID0]CRITAB;SZLEFTCRIFIE
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog C_SELCRIFIEX(VALEUR)
Variable Char    VALEUR()

Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:FID0]CRITAB, VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 1
    GERR = 2
    End
  Else
    Read [ATZ]CODZONE=[M:FID0]CRITAB;SZLEFTCRIFIE
    If fstat Then
      #Valeur incorrecte
      GMESSAGE = mess(83,123,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un critère de ciblage            #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File FIEDIC [FID1]
    Local File FIEDICFIE [FDF1]
    Local File ATEXTRA [AXX1]
  Else
    Local File =[M]DOSORG+".FIEDIC" [FID1]
    Local File =[M]DOSORG+".FIEDICFIE" [FDF1]
    Local File =[M]DOSORG+".ATEXTRA" [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File FIEDIC [FID2]
    Local File FIEDICFIE [FDF2]
    Local File ATEXTRA [AXX2]
  Else
    Local File =[M]DOSDES+".FIEDIC" [FID2]
    Local File =[M]DOSDES+".FIEDICFIE" [FDF2]
    Local File =[M]DOSORG+".ATEXTRA" [AXX2]
  Endif
  OK = 1
  Look [FID2]FID0=TABLE;TABLE2
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [FID1], [FDF1], [FID2], [FDF2], [AXX1], [AXX2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'un critère de ciblage     #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [FID2]
  Delete [FDF2] Where CRITAB=TABLE and CAT=TABLE2
  If fstat = 1  Then
    GOK = -1
    GLOCK = "$"+[M]DOSDES+".FIEDICFIE"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("FDF2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  Delete [FID2] Where CRITAB=TABLE and CAT=TABLE2
  If fstat = 1 Then
    GOK = -1  
    GLOCK = "$"+[M]DOSDES+".FIEDIC"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("FID",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  If GOK = 1 Then
    Read [FID1]FID0=TABLE;TABLE2
    If !fstat Then
      [F:FID2] = [F:FID1]
      Write [FID2]
      If fstat Then
        GOK = 0
        Call FSTA("FID2") From GLOCK  
        Goto AB_COPIE  
      Endif
      # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
      Call COPTEXTRA("FIEDIC", "CRITABAXX", [M:FID0]CRITAB, [M:FID0]CAT) From ATEXTRA
      If GOK = 0 Then
        Goto AB_COPIE  
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [FDF1] Where [F:FDF1]CRITAB=TABLE and [F:FDF1]CAT=TABLE2
    For [FDF1]
      [F:FDF2] = [F:FDF1]
      Write [FDF2]
      If fstat Then
        GOK = 0
        Call FSTA("FDF2") From GLOCK  
        Goto AB_COPIE  
      Endif
    Next
    Filter [FDF1]
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback 
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback 
  Call ROLL From GLOCK  
  If !GROLL Then
    Goto TRT_COPIE 
  Endif 
Return
