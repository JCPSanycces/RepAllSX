#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FSYNSER","FUNSYNSER","DSYNSER",3,"") From GTRAITE
End


#########################################################################
#                                                                       #
# ACTION  : TRTSYNSER  : Resynchronisation manuelle des numéros séries  #
#                        d'un article                                   #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION

#--- Actions liées au traitement standard
Case ACTION
 When "INIT"         : Gosub INIT
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie criteres DSYNSER
If GBOITE="DSYNSER"
   Case ACTION
    When "DEBUT"      : Affzo [DIA]1-99
    When "OK"         : GOK=1
    When "END"        : GOK=0 : FIN=1
    When Default
   Endcase
Endif

#--- Actions liées à la fenêtre de saisie principale FMANALL
If GBOITE="FSYNSER"
   Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "DEBUT"      : Gosub DEBUT
    When "SETBOUT"    : Gosub SETBOUT
    When "BOUTON"     : Gosub BOUTON
    When "PRE"        : Gosub PRECEDENT
    When "SUI"        : Gosub SUIVANT
    When "FIN"        : Gosub FIN
    When Default
   Endcase
Endif

Return

#########################################################################
#    Actions liés au type traitement                                    #
#########################################################################
$INIT
Local File ITMMASTER  [ITM]
Local File STOCK      [STO]
Local File STOSER     [STS]
Local File STOLOT     [STL]

Local Mask SYNSERS [DIA]
Raz [M:DIA]

Return

$TERMINE
# Fermeture de la trace
Call FERME_TRACE From LECFIC
TRA=1

Close Local File  [ITM]
Close Local File  [STO]
Close Local File  [STS]

Return

#########################################################################
#    Actions liés à la fenêtre FSYNSER                                  #
#########################################################################
$OUVRE
Local Integer OK, NOL, WFIN
Local Char    WITMREFSTR(GLONITM), WITMREFEND(GLONITM)
WITMREFSTR = [M]ITMREFSTR
WITMREFEND = [M]ITMREFEND

Return

$DEBUT
# Ouverture de la trace
Call OUVRE_TRACE("FUNSYNSER") From LECFIC

[M:SS0]STOFCY = [M:DIA]STOFCY
# Lecture du premier et du dernier article à traiter
Filter [ITM] Where ITMREF>=WITMREFSTR & ITMREF<=WITMREFEND & SERMGTCOD=4
&            Order By Key ITM0
OK=0 : WFIN=0
Read [ITM] First
If !fstat
  Gosub CONTROL_ITM
  While OK=0
    Read [ITM] Next
    If !fstat
      Gosub CONTROL_ITM
    Else
      WFIN=1 : Break
    Endif
  Wend
Else
  WFIN=1
Endif

If WFIN=0
  [M]ITMREF  = [F:ITM]ITMREF
  WITMREFSTR = [F:ITM]ITMREF
  Read [ITM] Last
  If !fstat
    Gosub CONTROL_ITM
    While OK=0
      Read [ITM] Prev
      If !fstat
        Gosub CONTROL_ITM
      Else
        OK=1 : Break
      Endif
    Wend
  Else
    WFIN=1
  Endif
  If OK=1
    WITMREFEND = [F:ITM]ITMREF
  Endif
Endif

Filter [ITM]

If [M]ITMREF<>""
  Gosub CHARGE_ITM
Else
  # Rien à traiter
  GERR=2 : GMESSAGE=mess(300,139,1)
  FIN=1
Endif

Return

$SETBOUT
If !instr(1,CHBOU,"<") CHBOU+= "<" Endif
If !instr(1,CHBOU,">") CHBOU+= ">" Endif

If [M]ITMREF = WITMREFSTR
  Call VIREBOUT(CHBOU, "<") From GOBJET
  Call VIREBOUT(CHMEN, "1") From GOBJET
Endif

If [M]ITMREF = WITMREFEND
  Call VIREBOUT(CHBOU, ">") From GOBJET
  Call VIREBOUT(CHMEN, "2") From GOBJET
Endif
Return

$BOUTON
Case BOUT
    When "1"  :  Gosub PRECEDENT    : # Article précédent
    When "2"  :  Gosub SUIVANT      : # Article suivant
Endcase

Return

$PRECEDENT
Filter [ITM] Where ITMREF>=WITMREFSTR & ITMREF<[M]ITMREF & SERMGTCOD=4
&            Order By Key ITM0
OK=0
Read [ITM] Last
If !fstat
  Gosub CONTROL_ITM
  While OK=0
    Read [ITM] Prev
    If !fstat
      Gosub CONTROL_ITM
    Else
      WFIN=1 : Break
    Endif
  Wend
Else
  WFIN=1
Endif
Filter [ITM]
If OK=1
  [M]ITMREF = [F:ITM]ITMREF
  Gosub CHARGE_ITM
Endif

Return

$SUIVANT
Filter [ITM] Where ITMREF>[M]ITMREF & ITMREF<=WITMREFEND & SERMGTCOD=4
&            Order By Key ITM0
OK=0
Read [ITM] First
If !fstat
  Gosub CONTROL_ITM
  While OK=0
    Read [ITM] Next
    If !fstat
      Gosub CONTROL_ITM
    Else
      WFIN=1 : Break
    Endif
  Wend
Else
  WFIN=1
Endif
Filter [ITM]
If OK=1
  [M]ITMREF = [F:ITM]ITMREF
  Gosub CHARGE_ITM
Endif

Return

$FIN
Return

$CONTROL_ITM
OK=0
For [STO]STO3 Where ITMREF=[F:ITM]ITMREF & STOFCY=[M]STOFCY & LOCCAT<>2
  Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
  If rowcount([F:STS])<>[F:STO]QTYSTUACT
    OK=1 : Break
  Endif
  Filter [STS]
Next
Filter [STS]

Return

$CHARGE_ITM
nolign=0 : [M:SS1]NBLIG=0
J=-1     : [M:SS1]NBSTO=0
Raz [M:SS0]ITMQTYINI, [M:SS0]ITMQTYNEW
Raz [M:SS0]ITMSERINI, [M:SS0]ITMSERNEW
[M:SS0]ITMSTU1 = [F:ITM]STU
[M:SS0]ITMSTU2 = [F:ITM]STU

For [STO]STO3 Where ITMREF=[M]ITMREF & STOFCY=[M]STOFCY & LOCCAT<>2

  Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
  If [M:DIA]FLGSTO=2 & rowcount([F:STS])=[F:STO]QTYSTU
    Goto STO_SUI
  Endif
  nolign += 1
  NOL     = nolign-1
  [M:SS1] = [F:STO]
  [M:SS0]ITMQTYINI += [F:STO]QTYSTU
  [M:SS0]ITMQTYNEW += [F:STO]QTYSTU

  [M:SS1]SERINI(NOL)  = rowcount([F:STS])
  [M:SS1]SERNEW(NOL)  = [M:SS1]SERINI(NOL)
  [M:SS0]ITMSERINI   += [M:SS1]SERINI(NOL)
  [M:SS0]ITMSERNEW   += [M:SS1]SERNEW(NOL)
  # Stockage des chrono stocks ayant trop de no séries
  If [M:SS1]SERNEW(NOL)>[F:STO]QTYSTU
    J += 1
    [M:SS1]STOCOU2(J) = [F:STO]STOCOU
  Endif

  $STO_SUI
  Filter [STS]
Next

[M:SS1]NBLIG = nolign
[M:SS1]NBSTO = J+1
Affzo [M:SS0]1-99
Affzo [M:SS1]1-99

Return

######################################################################################
## Ecran SYNSERS
######################################################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ITMREFEND=[M:DIA]ITMREFSTR | [M:DIA]ITMREFEND<VALEUR
  [M:DIA]ITMREFEND = VALEUR
  Affzo [M:DIA]ITMREFEND
Endif
End

######################################################################################
## Ecran SYNSER1
######################################################################################
Subprog IB_NBLIG
If [M:SS1]SERNEW(nolign-1)=[M:SS1]QTYSTU(nolign-1)
  Raz GBOUT1
Endif
End

Subprog AV_STOCOU(VALEUR)
Variable Decimal VALEUR
If [M:SS1]SERNEW(nolign-1)<>[M:SS1]QTYSTU(nolign-1)
  Chgstl [M:SS1]NBLIG(nolign-1) With "STKSERDSY"
Else
  Chgstl [M:SS1]NBLIG(nolign-1) With ""
Endif
End

