#<AdxTL>@(#)11.0.0.0 $Revision$ Consultation SOE
Local Char PARAM(20)(1..3)
PARAM(1) = "0"
PARAM(2) = "GAL"
PARAM(3) = ""
Call GCONSULT("SOE","",PARAM) From GCONSULT
End
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Raz [M:CSOE] : Transmask [M:SOE1] To [M:CSOE]# Issue 25606[M:CSOE] = [M:SOE1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "GRAPH_SET"  : Gosub GRAPH_SET
  When "GRAPH"      : Gosub GRAPH
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:TLO])=0 : Local File TABLOCTYP  [TLO] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
#--- Dem 69600
If GWRHACT=2
  If clalev([F:STC])=0 : Local File STOLOC    [STC] : Endif
  If clalev([F:WRH])=0 : Local File WAREHOUSE [WRH] : Endif
Endif
#---
Local Char    WFIL(250)
Local Char    WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
#
Local Integer OK, I, J, RETOUR
Local Integer SAVOBJET
Local Char    SAVPROG
Local Integer CHOIX
Local Integer WFSTAT
Local Integer WBOU(1..GNBBOU)
Local Char    WITM(GLONITM)
Local Char    WTIT(60)
Local Char    WMSG(120)
Local Char    WTXT(120)
Local Decimal WPRO
Local Decimal WTOT
Local Integer WBAT
Local Decimal WOCP

Gosub LOAD_SCREEN
#
NAVIG="CONSSOE"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SOE1]FLG = 0
[M:SOE1] = [M:CSOE]
Return
############################################################
$AP_MAGNETO
[M:SOE1]FLG = 0
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 :  GCONSULT = WGCONSULT : Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SOE1]STOFCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSOE]) <> 0 & [M:CSOE]MEMO = "STD"  : # <MG> 26/04/00
  [M:SOE1] = [M:CSOE]                            : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
Return
############################################################
$LECTURE
SUITE  = 1
RETOUR = 1
NBLU   = 2
If [M:SOE1]STOFCY = "" | [M:SOE1]FLG = 2
  [M:SOE1]FLG = 0
  NBLU = 0
  Return
Endif
#
Gosub TRAITEMENT
Return
############################################################
$GRAPH_SET
# Calcul nombre de valeurs
WROW = 1
For I = 0 To [M:SOE2]NBLIG-1
  WROW += 1
Next I
Return
############################################################
$GRAPH
WTIT = mess(83,196,1)
WFOO = [F:FCY]FCY-[F:FCY]FCYNAM
#
Local Decimal WTOTO, WTOTT
#
WORD(0) = mess(2,703,1)
WORD(1) = mess(1,703,1)
#
For I = 0 To [M:SOE2]NBLIG-1
  WTOTO += [M:SOE2]OCPLOC(I)
  WTOTT += [M:SOE2]TOTLOC(I)
Next I
If WTOTT > 0
  WAMT(0,0) = arr(((WTOTO*100)/WTOTT),0.01)
  WAMT(0,1) = 100 - WAMT(0,0)
  WABS(0)   = "***"
Endif
J = 1
For I = 0 To [M:SOE2]NBLIG-1
  WAMT(J,0) = arr([M:SOE2]PERLOA(I),0.01)
  WAMT(J,1) = 100 - WAMT(J,0)
  WABS(J)   = [M:SOE2]LOCTYP(I)
  J += 1
Next I
Return
############################################################
#Recalcul des statuts occupes / libres
$TRAITEMENT
#--- Dem 69600
Local Decimal WFRGLOC, WOCPLOC, WFULLOC, WLOKLOC, WPERLOA
Local Integer WOK
#---
Raz [M:SOE2]

WFIL = "STOFCY=[M:SOE1]STOFCY"
#
If [M:SOE1]LOCTYPSEL <> ""
   WFIL += "& pat([F:TLO]LOCTYP,[M:SOE1]LOCTYPSEL)"
Endif
#
If [M:SOE1]MONITMFLG = 2
  WFIL += "&[F:TLO]MONITMFLG=2"
Elsif [M:SOE1]MONITMFLG = 1
  WFIL += "&[F:TLO]MONITMFLG<>2"
Endif
#
If [M:SOE1]DEDFLG = 2
  WFIL += "&[F:TLO]DEDFLG=2"
Elsif [M:SOE1]DEDFLG = 1
  WFIL += "&[F:TLO]DEDFLG<>2"
Endif
#
If [M:SOE1]REAFLG = 2
  WFIL += "&[F:TLO]REAFLG=2"
Elsif [M:SOE1]REAFLG = 1
  WFIL += "&[F:TLO]REAFLG<>2"
Endif
#
If [M:SOE1]FILMGTFLG = 2
  WFIL += "&[F:TLO]FILMGTFLG=2"
Elsif [M:SOE1]FILMGTFLG = 1
  WFIL += "&[F:TLO]FILMGTFLG<>2"
Endif
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Filter [TLO] Where evalue (WFIL) & evalue(WFILS) & evalue(WFILSPE)
&            Order By Key TLO0

nolign = 0
For [TLO]
  If nolign < dim([M:SOE2]LOCTYP)-1
    #--- Dem 69600 puis 71324 (dim()>0)
    Raz WFRGLOC, WOCPLOC, WFULLOC, WLOKLOC, WPERLOA, WOK
    If dim([M:SOE1]WRH)>0 & [M:SOE1]WRH<>""
      For [STC]STC3 Where STOFCY=[M:SOE1]STOFCY & LOCTYP=[F:TLO]LOCTYP & WRH=[M:SOE1]WRH
        Case [F:STC]OCPCOD
         When 1: WFRGLOC += 1
         When 2: WOCPLOC += 1
         When 3: WFULLOC += 1
        Endcase
        If [F:STC]LOKSTA=2 WLOKLOC += 1 Endif
        WOK+=1
      Next
      If WOK>0
        nolign += 1
        NOL    += 1
        [M:SOE2] = [F:TLO]
        Call LECTEXTRA([M:SOE2]TYPDES(nolign-1),"TABLOCTYP","TYPDESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA  # hcb 74228
        [M:SOE2]FRGLOC(nolign-1) = WFRGLOC
        [M:SOE2]OCPLOC(nolign-1) = WOCPLOC
        [M:SOE2]FULLOC(nolign-1) = WFULLOC
        [M:SOE2]TOTLOC(nolign-1) = WFRGLOC+WOCPLOC+WFULLOC
        [M:SOE2]LOKLOC(nolign-1) = WLOKLOC
        [M:SOE2]PERLOA(nolign-1) = (WOCPLOC+WFULLOC)/max(1,WFRGLOC+WOCPLOC+WFULLOC)
        Gosub TRT_RECWRH
      Endif
    Else
      #---
      nolign += 1
      NOL    += 1
      [M:SOE2] = [F:TLO]
      Call LECTEXTRA([M:SOE2]TYPDES(nolign-1),"TABLOCTYP","TYPDESAXX",[F:TLO]STOFCY,[F:TLO]LOCTYP) From ATEXTRA  # hcb 74228
      Gosub TRT_REC
    #--- Dem 69600
    Endif
  Endif
Next
Filter [TLO]
#
Return

###########################################################
#--- Dem 69600
$TRT_RECWRH
[M:SOE2]FRGLOCTOT   += WFRGLOC
[M:SOE2]OCPLOCTOT   += WOCPLOC
[M:SOE2]FULLOCTOT   += WFULLOC
[M:SOE2]LOKLOCTOT   += WLOKLOC
[M:SOE2]TOTLOCTOT   += WFRGLOC+WOCPLOC+WFULLOC
Return
#---

###########################################################
$TRT_REC
[M:SOE2]FRGLOCTOT   += [F:TLO]FRGLOC
[M:SOE2]OCPLOCTOT   += [F:TLO]OCPLOC
[M:SOE2]FULLOCTOT   += [F:TLO]FULLOC
[M:SOE2]LOKLOCTOT   += [F:TLO]LOKLOC
[M:SOE2]TOTLOCTOT   += [F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC
Return

############################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
[M:SOE1]FLG = 0
End
###########################################################
#--- Dem 69600
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site
If [M]STOFCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End
#---
###########################################################
Subprog AV_NBLIG
End
###########################################################
Subprog AV_TOTLOC(VALEUR)
Variable Decimal  VALEUR
VALEUR =[M]FRGLOC(nolign-1)+[M]OCPLOC(nolign-1)+[M]FULLOC(nolign-1)
End
###########################################################
Subprog AV_TOTLOCTOT(VALEUR)
Variable Decimal  VALEUR
VALEUR = [M]OCPLOCTOT+[M]FRGLOCTOT+[M]FULLOCTOT
End
###########################################################
Subprog AV_PERLOA(VALEUR)
Variable Decimal  VALEUR
If [M]TOTLOC(nolign-1) <> 0
  VALEUR = (([M]OCPLOC(nolign-1)+[M]FULLOC(nolign-1))/[M]TOTLOC(nolign-1))*100
Else
  VALEUR = 0
Endif
End
###########################################################
Subprog AV_PERLOATOT(VALEUR)
Variable Decimal  VALEUR
If [M]TOTLOCTOT <> 0
  VALEUR = (([M]OCPLOCTOT+[M]FULLOCTOT)/[M]TOTLOCTOT)*100
Else
  VALEUR = 0
Endif
End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SOE") From SUBGTC

End

