#<AdxTL>@(#)0.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 28 Mars      2011 16:29:21
# Moulinette pour initialiser le code activité PSE
# FQ75577
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM029: Initialisation du code activité PSE") From LECFIC
  Call EXE_UTIIMM029(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM029(APPLI)
 Value Char APPLI
  If clalev([F:ACV]) : Close Local File [ACV] : Endif
  Local File =APPLI+".ACTIV"    [ACV]
  Local File =GDOSX3+".ADOSACT" [ADA]
  Call ECR_TRACE("UTIIMM029: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM029
  Call ECR_TRACE("UTIIMM029: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM029
  Trbegin [F:ACV]  
  Local Integer LKRU,LKPL
  Read [F:ACV]CODACT="KRU"
  If !fstat
   LKRU=[F:ACV]FLACT
  Endif
  Read [F:ACV]CODACT="KPL"
  If !fstat
   LKPL=[F:ACV]FLACT
  Endif
  Read [F:ACV]CODACT="PSE"
  If LKRU=G_OUI | LKPL=G_OUI
   [F:ACV]FLACT=G_OUI
   Call ECR_TRACE("New activity code PSE : active",0) From GESECRAN
  Else
   [F:ACV]FLACT=G_NON
   Call ECR_TRACE("New activity code PSE : inactive",0) From GESECRAN
  Endif    
  Rewrite [F:ACV]
  If fstat
   GOK=0
  Else
  Endif
  Read [ADA]ADA0=APPLI;"PSE"
  If (fstat) Then
    GOK=0
    Call ECR_TRACE("UTIIMM029 - "-" Activity code PSE not found in table ADOSACT ", 1) From GESECRAN
  Else
    [F:ADA]FLACT = [F:ACV]FLACT
    Rewrite [ADA]
    If (fstat) Then
      GOK=0
      BERROR = 1
      Call ECR_TRACE("UTIIMM029 - "-" ADOSACT table ====> I/O Error - FSTAT="-num$(fstat), 1) From GESECRAN
    Endif
  Endif  
  
  If !GOK Then
    Goto AB_UTIIMM029
  Else
    Commit
  Endif
Return

$AB_UTIIMM029
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ACTIV","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","ADOSACT","fde",GDOSX3),0) < 0 : End : Endif
    
  Call EXE_UTIIMM029(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","ACTIV","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","ADOSACT","fde",GDOSX3),0) < 0 : End : Endif
  Call EXE_UTIIMM029(APPLI)
End
