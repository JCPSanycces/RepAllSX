#<AdxTL>@(#)4.0.0.0 $Revision$
# Issue 107498/18 - 2016-07-18 by JUSYN : Treatment for PJT related orders without existing project management material record
# Issue 107498/18 - 2016-08-15 by JUSYN : Using existing functions and check for activity code PJM
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTOF : Action lancement automatique                    #
#                                                                       #
#########################################################################
$ACTION
# actions liées au traitement standard
Case ACTION
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "CONTROLE"     : Gosub CONTROLE
  When "CONT_BATCH"   : Gosub CONT_BATCH
  When "EXEC"         : Gosub EXEC
  When "TERMINE"      : Gosub TERMINE
Endcase

# actions liées à la saisie fenêtre
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "AVANT_OK"     : Gosub AVANT_OK
  When "OK"           : Gosub OK
Endcase

Return

#########################################################################
$OUVRE_BATCH
# Issue 84721 GA 10/2012 autoriser impression en batch
#Global Integer GMAUTRB
Return

#########################################################################
$INIT

# Issue 84721 GA 10/2012 autoriser impression en batch
#If (dim(GMAUTRB) > 0 & GMAUTRB>1) : Kill GMAUTRB : Endif

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

If !clalev([M:DIA])
  If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
  Read [AWI]AWI0 = BCRIT
  MASQUE = [F:AWI]NOMMSK(0)
  Close Local File [AWI]
  Local Mask =MASQUE [DIA]
Endif

Gosub OUVRE

ACTION = "INIT_DIA" : Gosub ACTION From =PROG
Return

########################################################################
$INIT_DIA
## GH 27/03/2014 bug 84721 GMAUTRB plus utilisé, on passe toujours par le même écran même en batch
#If dim(GMAUTRB) > 0 & GMAUTRB>1
#    If clalev([M:DIA]) <> 0 : Close Local Mask [DIA] : Endif
#    BCRIT = "DAUTOFB"
#    GBOITE = BCRIT
#    Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT) From GTRAITE : # Recherche infos écran critère
#    # sr 08.05 demande 31774
#    If MSKCRIT <> ""
#        If evalue("clalev([M:"+ABRCRIT+"])")=0 : Local Mask =MSKCRIT [DIA] : Endif
#    Else
#        MASQUE = "MAUTRELB"
#        Local Mask =MASQUE [DIA]
#    Endif
#Else
#    If !clalev([M:DIA]) : Local Mask MAUTRELB [DIA] : Endif
#Endif

If dim([L]PRT)<0
   Gosub OUVRE
Endif

# En exécution/visualisation batch, l'écran va être chargé par les paramètres batch après cette action
If GSERVEUR | (GBATCH & GCONSDIA=1) : Return : Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
[M:DIA]MFGFCY = GFCY
[M:DIA]AVSTA = 1
[M:DIA]APSTA = 1
[M:DIA]OPTIMFLG = 1

#If GUSER<>"" & [F:MTS]MODDOS=2 & dim([M:DIA]PRT)=1 # Suite Issue 84721 GA 09/2013
If GUSER<>"" & !(dim([M:DIA]PRT)<0 | varmode([M:DIA]PRT)=3) : # GH 27/03/2014 bug 84721
    ETAT = "DOSFAB"
    Read [ARP]ARP0 = ETAT
    If fstat : Raz [F:ARP] : Endif

    # lecture utilisateur pour récupération imprimante par défaut
    Call DEFIMP(ETAT, GUSER, "", LPRT, LOBL) From IMPRIME
    [M:DIA]OBL = LOBL
    [M:DIA]PRT = LPRT : Affzo [DIA]PRT
    If [M:DIA]PRT<>""
       Call C_PRT([M:DIA]PRT)
       GMESSAGE=""
       If mkstat & [M:DIA]OBL=1 : [M:DIA]OBL=2 : Endif
    Endif
    If [M:DIA]OBL=1 : Diszo [DIA]PRT : Endif
Endif
Return

########################################################################
## GH 27/03/2014 bug 84721
########################################################################

$DEBUT
# En saisie(batch/non batch) ou En visualisation des paramètres batch
Gosub CONTEXTE

Affzo [DIA]
If !GCONSDIA & !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3)
   [M:DIA]IMPFLG = 1+([F:MTS]MODDOS=2 & [M:DIA]APSTA=2)
   Affzo [DIA] IMPFLG
Endif
Return

$CONTROLE
$CONT_BATCH
If GSERVEUR
  # En éxécution batch ou absence de saisie de paramètre
  Gosub CONTEXTE
  If !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3)
     [M:DIA]IMPFLG = 1 +([F:MTS]MODDOS = 2) : # pour le print screen
  Endif
Endif
Return

$CONTEXTE
GFCY = [M:DIA]MFGFCY
Gosub CHARG_PARAM

 # Suite Issue 84721 GA 09/2013
If dim([M:DIA]MFGTRS)<0 | [M:DIA]MFGTRS = ""
    Read [MTS]MTS0=1;GMFGMTSNUM
Else
    Read [MTS]MTS0=1;[M:DIA]MFGTRS
Endif
If fstat : Raz [F:MTS] : Endif

#Call ECR_TRACE("CONTEXTE"-GFCY-[F:MTS]MTSNUM,0) From GESECRAN
Return

########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOF
Local Integer  WFLGALL
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)
#
Local Char     FORMULE1(255)
Local Char     WMESS(100)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WITMREF(GLONITM)
Local Char     WSTOFCY(GLONFCY)
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRLIN
Local Date     WSTRDAT
Local Integer  WSTA
Local Char     WROUNUM(GLONVCR)
Local Decimal  WROUALT                # llc 09.01 10266
Local Char     WLOT(GLONLOT)
Local Char     ETAT(20)
Global Char    GDEFIMP(50)            # llc 01.01 7063
Local  Decimal WBOMALT
Local Integer  STOP : STOP = 0
Local Integer  DOSOK

# impression 140
Local Char    LPRT(GLONAIM)
Local Integer LOBL
Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFP])  = 0 : Local File MFGPRN      [MFP]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING     [ROH]  : Endif    # llc 09.01 10266
If clalev([F:TRO])  = 0 : Local File TABROUALT   [TRO]  : Endif    # llc 09.01 10266
If clalev([F:MTS])  = 0 : Local File MFGTRS      [MTS]  : Endif    # llc 01.01 7063
If clalev([F:ARP])  = 0 : Local File AREPORT     [ARP]  : Endif    # llc 01.01 7063
If clalev([F:AUS])  = 0 : Local File AUTILIS     [AUS]  : Endif    # llc 01.01 7063
If clalev([F:BOH])  = 0 : Local File BOM         [BOH]  : Endif
If clalev([F:TBO])  = 0 : Local File TABBOMALT   [TBO]  : Endif
If clalev([F:AIM])  = 0 : Local File APRINTER    [AIM]  : Endif
If clalev([F:AID])  = 0 : Local File APRINTDES   [AID]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask ORCK    [ORCK]
Local Mask MFGK    [MFGK]

TIT = mess(130,195,1)

Raz [M:DIA]
Return

#########################################################################
$EXEC

If [M:DIA]TRTAUTO<>1 : Return : Endif

# Suite Issue 84721 GA 09/2013 déplacé en $INIT_DIA
#If GSERVEUR      # 36039 mm 05.06
#    If [M:DIA]MFGTRS = ""
#        Read [MTS]MTS0=1;GMFGMTSNUM
#        If fstat : Raz [MTS] : Endif
#    Else
#        Read [MTS]MTS0=1;[M:DIA]MFGTRS
#        If fstat : Raz [MTS] : Endif
#    Endif
#Endif

If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTREL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# préparation des critères de filtre
Gosub SEL_OF

# traitement des OF
Gosub TRT_OF
Return

#########################################################################
$TERMINE

If !GSERVEUR & [M:DIA]TRTAUTO =1
    Call TEMPOFF From GESECRAN
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBOF
         GERR = 2 : GMESSAGE = mess(88,193,1)
    Endif
    # lecture trace
    Call LEC_TRACE From LECFIC
Endif

If GFONC1 = "FUNMAUT" : Raz GFONC1 : Endif
Return

#########################################################################
$SETBOUT
If GBATCH = 1     # Batch lancé
    Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return

#########################################################################
$BOUTON
Case BOUT
    When "1"       :     FIN = 1
Endcase
Return

#########################################################################
$AVANT_OK
If !GSERVEUR  & !GBATCH  &
&  [M:DIA]MFGNUMDEB = "" &
&  [M:DIA]MFGNUMFIN = "" &
&  [M:DIA]PJTDEB    = "" &
&  [M:DIA]PJTFIN    = "" &
&  [M:DIA]BPCNUMDEB = "" &
&  [M:DIA]BPCNUMFIN = "" &
&  [M:DIA]VCRNUMDEB = "" &
&  [M:DIA]VCRNUMFIN = "" &
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]STRDATDEB = [0/0/0] &
&  [M:DIA]STRDATFIN = [0/0/0] &
&  [M:DIA]FORMULE   = ""
   OK = 2
   Call AVERTIR(mess(64,190,1), OK) From GESECRAN
   If OK = 2 : Return
   Else : FOK = 0 : GERR = 1 :  FIN = 0 : Endif
Endif
Return

#########################################################################
$OK
# [M:DIA]TRTAUTO= 0 :  pas de lancement automatique effectué
# [M:DIA]TRTAUTO= 1 :  on conserve le fait qu'on a effectué un lancement auto.

If [M:DIA]TRTAUTO = 0 : [M:DIA]TRTAUTO =1 : Endif
Return

########################################################################
# Préparation du filtre sur la table encours (WOx)                     #
########################################################################
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

CRITERE1 = "WIPTYP=5"                                   # OF

If [M:DIA]AVSTA = 1
    CRITERE  = "WIPSTA=3"                               # statut = suggéré
Else
    CRITERE  = "WIPSTA=2"                               # statut = planifié
Endif
Gosub LOAD_CRITERE2

CRITERE  = "STOFCY = [M:DIA]MFGFCY"                     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""                               # borne début OF
   CRITERE = "VCRNUM >= [M:DIA]MFGNUMDEB"
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]MFGNUMFIN <> ""                               # borne fin   OF
   CRITERE = "VCRNUM <= [M:DIA]MFGNUMFIN"
   Gosub LOAD_CRITERE2
Endif

# affaire
If [M:DIA]PJTDEB <> ""
   CRITERE = "PJT >= [M:DIA]PJTDEB"                     # borne début affaire
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]PJTFIN <> ""
   CRITERE = "PJT <= [M:DIA]PJTFIN"                     # borne fin   affaire
   Gosub LOAD_CRITERE2
Endif

# destinataire
If [M:DIA]BPCNUMDEB <> ""
   CRITERE = "BPRNUM >= [M:DIA]BPCNUMDEB"               # borne début destin.
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]BPCNUMFIN <> ""
   CRITERE = "BPRNUM <= [M:DIA]BPCNUMFIN"               # borne fin   destin.
   Gosub LOAD_CRITERE2
Endif

# no commande
If [M:DIA]VCRNUMDEB <> ""
   CRITERE = "VCRNUMORI >= [M:DIA]VCRNUMDEB"            # borne début n° commande
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE = "VCRNUMORI <= [M:DIA]VCRNUMFIN"            # borne fin   n° commande
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"               # borne début article lancé
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"               # borne fin   matière
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]
   CRITERE = "STRDAT >= [M:DIA]STRDATDEB"               # borne début date
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]STRDATFIN <> [0/0/0]
   CRITERE = "STRDAT <= [M:DIA]STRDATFIN"               # borne fin   date
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]OPTIMFLG=2                                    # 14783 06.02 MM
  CRITERE = "OPTFLG = 2"                                # ordres optimisés
  Gosub LOAD_CRITERE2
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif
Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OF
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

# Issue 72161 - 2011-03-08 by CCC : Lien avec les tables ITM et ITF qui peuvent être utilisées dans la formule
#If CRITERE2 <> ""
#    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
#&                      Order By Key ORD0
#Else
#    Filter [ORD] Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
#&                      Order By Key ORD0
#Endif
If CRITERE2 <> ""
    Link [ORD] With [ITM]ITM0~=[F:ORD]ITMREF, [F:ITF]ITF0~=[F:ORD]ITMREF;[F:ORD]STOFCY
&              As [LNK]
&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key KLNK=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
Else
    Link [ORD] With [ITM]ITM0~=[F:ORD]ITMREF, [F:ITF]ITF0~=[F:ORD]ITMREF;[F:ORD]STOFCY
&              As [LNK]
&              Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key KLNK=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
Endif

# boucle de lecture
For  [LNK] With Nohint
      Read [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WSTRDAT = [F:ORD]STRDAT
      WSTA    = [F:ORD]WIPSTA

      # PE permettant de choisir les OF en fonction de critères supplémentaires - 36732 mm 06.06
      GPE = 0
      GPOINT="CHECKORD" : Gosub ENTREE From EXEFNC
      If GPE : Goto NXT2 : Endif
      #
      Gosub TRTREL
$NXT2
Next
#
Filter [ORD]
#
Return

#-----------------------------------------------------------------------#
# Traitement lancement                                                  #
#-----------------------------------------------------------------------#
$TRTREL
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
Gosub MAJREL
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+WVCRNUM
## GH 27/03/2014 bug 84721 pour ne pas delocker l'OF si locké en amont
Call TESTLOCK(SYMBOLE,OK) From GLOCKM
If OK
   SYMBOLE=""
   Return
Endif
##
Lock = SYMBOLE With lockwait = 0
If fstat
    Call ECR_TRACE(WVCRNUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Else
    OK = 1
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
## GH 27/03/2014 bug 84721 ne pas delocker l'OF si locké en amont
# Unlock=SYMBOLE
If SYMBOLE<>""
   Unlock=SYMBOLE
   SYMBOLE=""
Endif
Return

#-----------------------------------------------------------------------#
# Lancement                                                             #
#-----------------------------------------------------------------------#
$MAJREL
#
WMESS   = mess(156,197,1)-mess(WSTA,317,1)-WVCRNUM-mess(179,197,1)-mess([M:DIA]APSTA,309,1)
#

# Issue 107498/109 - 2016-06-01 by JUSYN : Project management. Filter out WOS that
#                                          shall not be released because project taskline not launched.
# check flag for project management treatment 1 = okay 0 = not okay
Local Integer LMTXFLG
# Issue number 107498/18 - 2016-08-15 by JUSYN : Only when activity code PJM active
If func AFNC.ACTIV("PJM")
    Gosub CHECK_PROJECT_CONDITIONS
Else
    LMTXFLG = 1
Endif
If LMTXFLG = 0 : Return : Endif
#
#
Trbegin [MFG]
    Raz [M:MFGK]
    Case WSTA
        When 1,2:  Read [MFG]MFG0 = WVCRNUM
                   If !fstat
                   # Si Mode lcmt OF ="Matières seules" et seul mode lcmt autorisé par
                   # la transaction = "OP seules" ou l'inverse
                   # ou si mode de lcmt complet et la transaction n'autorise pas le mode de lcmt complet
                       If [F:MFG]MFGMOD = 2 & ([F:MTS]MFGMODM=1 & [F:MTS]MFGMODC=1) |
&                      [F:MFG]MFGMOD = 3 & ([F:MTS]MFGMODO=1 & [F:MTS]MFGMODC=1) |
&                      [F:MFG]MFGMOD = 1 & [F:MTS]MFGMODC=1
                           STOP =1 : Goto ERR
                       Endif
                   Endif

                   [M:MFGK]CODMAJ = "M"
                   Raz WROUNUM,WROUALT
                   For [SCH]SCH0 Where MFGNUM = WVCRNUM
                       WROUNUM = [F:SCH]ROUNUM
                       WROUALT = [F:SCH]ROUALT
                       Break
                   Next
                   # Si Mode lcmt OF ="Matières seules" et seul mode lcmt autorisé par
                   # la transaction = "Complet"
                   If WROUNUM="" & WROUALT=0 & [F:MTS]MFGMODC = 2 & [F:MTS]MFGMODM = 1
                     STOP = 1 : Goto ERR
                   Endif

                   Read [MFI]MFI0=WVCRNUM;WVCRLIN
                   If fstat : Goto AB_TRTREL : Endif
                   WLOT = [F:MFI]LOT

        When 3:    # si mode de lcmt complet et la transaction n'autorise pas le mode de lcmt complet
                   # GH 16/09/2015 bug 109221 to admit transaction with only materials
                   # If [F:MTS]MFGMODC=1
                   #    STOP =1 : Goto ERR
                   #Endif

                   Raz WROUNUM,WROUALT                      # sr 06.01 demande 9758
                   [M:MFGK]CODMAJ = "R"
                   For [SCH]SCH0 Where MFGNUM = WVCRNUM
                       WROUNUM = [F:SCH]ROUNUM
                       WROUALT = [F:SCH]ROUALT
                       Break
                   Next

                   If [F:ORD]BOMALT = 0 | WROUNUM = "" | WROUALT = 0
                       Read [ITF]ITF0=WITMREF;WSTOFCY
                       If fstat : Raz [F:ITF] : Endif
                   Endif
                   # 45423 mm 02.08
                   If WITMREF <> [F:ITM]ITMREF
                       Read [ITM]ITM0=WITMREF
                       If fstat : Raz [F:ITM] : Endif
                   Endif

                   If [F:ORD]BOMALT = 0
                       Call RECH_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT,2) From BENCHLIB
                       [F:ORD]BOMALT = WBOMALT
                   Else
                       WBOMALT = [F:ORD]BOMALT
                       Call CHECK_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT) From BENCHLIB
                       If WBOMALT = 0 : Call RECH_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT,2) From BENCHLIB : Endif
                       [F:ORD]BOMALT = WBOMALT
                   Endif
                   # 45423 mm 02.08 - 50356 GA 04/03/2009 - Si mode de lancement = opérations seules, on autorise BOMALT =0
                   # If WBOMALT = 0
                   If [F:MTS]MFGMODO=1 & WBOMALT = 0
                       Call ECR_TRACE(mess(156,197,1)-mess(WSTA,317,1)-WVCRNUM-mess(154,193,1),0) From GESECRAN
                       Goto AB_TRTREL
                   Endif

                   If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1 # GH 16/09/2015 bug 109221
                       Raz WROUNUM, WROUALT
                   Elsif WROUNUM = "" | WROUALT = 0           # llc 09.01 10266
                       If [F:ITF]MFGROU = ""
                           WROUNUM = WITMREF
                       Else
                           WROUNUM = [F:ITF]MFGROU
                       Endif
                       Call RECH_GAM(WSTOFCY, WSTRDAT, WROUNUM, [F:ORD]EXTQTY,
&                                    [F:ITM]STU, [F:ORD]BOMALT, WROUALT) From BENCHLIB
                       If WROUALT = 0 : WROUNUM = "" : Endif        # llc 06.04 22880
                   Endif

                   WLOT=""
    Endcase
    #
    $ERR
    If STOP =1
        Call ECR_TRACE(mess(156,197,1)-mess(WSTA,317,1)-WVCRNUM-mess(257,193,1)-[F:MTS]MTSNUM,0) From GESECRAN
        STOP = 0
        Goto AB_TRTREL
    Endif

    # maj historique si WOP vers WOF
    If WSTA = 2 & [M:DIA]APSTA = 2
        Raz [M:ORCK]
        [M:ORCK]MAJCOD = "C"
        [M:ORCK]WIPNUM = [F:ORD]WIPNUM
        [M:ORCK]WIPTYP = [F:ORD]WIPTYP
        [M:ORCK]ITMREF = [F:ORD]ITMREF
        [M:ORCK]COVQTY = [F:ORD]EXTQTY
        [M:ORCK]VCRTYPDST = 10
        [M:ORCK]VCRNUMDST = [F:ORD]VCRNUM
        [M:ORCK]VCRLINDST = [F:ORD]VCRLIN
        [M:ORCK]VCRSEQDST = 0
        [M:ORCK]WIPSTADST = 1
        [M:ORCK]WIPTYPDST = 5
        Read [MFG]MFG0=WVCRNUM
        If !fstat
            [M:ORCK]ROUNUM = [F:MFG]ROUNUM
            [M:ORCK]ROUALT = [F:MFG]ROUALT
        Endif
        Call COVER From TRTWIP
    Endif

    [M:MFGK]CODTRS = 0
    [M:MFGK]MFGNUM = WVCRNUM
    [M:MFGK]MFGLIN = [F:ORD]VCRLIN
    [M:MFGK]MFGFCY = WSTOFCY
    Case [M:DIA]APSTA
        When 1: [M:MFGK]MFGSTA = 2
        When 2: [M:MFGK]MFGSTA = 1
        When Default: [M:MFGK]MFGSTA = 1
    Endcase
    [M:MFGK]ITMREF = WITMREF
    [M:MFGK]PRVQTY = [F:ORD]EXTQTY
    [M:MFGK]EXTQTY = [F:ORD]EXTQTY
    [M:MFGK]STRDAT = [F:ORD]STRDAT
    [M:MFGK]ENDDAT = [F:ORD]ENDDAT
    [M:MFGK]BOMALT = [F:ORD]BOMALT
    [M:MFGK]ROUNUM = WROUNUM
    [M:MFGK]ROUALT = WROUALT
    [M:MFGK]PJT    = [F:ORD]PJT
    [M:MFGK]LOT    = WLOT
    [M:MFGK]FMI    = [F:ORD]FMI
    [M:MFGK]BPRNUM = [F:ORD]BPRNUM
    [M:MFGK]PIO    = [F:ORD]PIO
    [M:MFGK]VCRTYPORI = [F:ORD]VCRTYPORI
    [M:MFGK]VCRNUMORI = [F:ORD]VCRNUMORI
    [M:MFGK]VCRLINORI = [F:ORD]VCRLINORI
    [M:MFGK]VCRSEQORI = [F:ORD]VCRSEQORI
    [M:MFGK]WIPTYP = [F:ORD]WIPTYP
    [M:MFGK]WIPNUM = [F:ORD]WIPNUM
    [M:MFGK]AUTOTRT= 2                        # llc 7063 12.00
    # llc 03.02 12520
    Case [F:MTS]SCDMODSAI
        When 1:    [M:MFGK]SCDMOD = 1
        When 2:    [M:MFGK]SCDMOD = 2
        When Default: [M:MFGK]SCDMOD = 1
    Endcase
# Issue 111414/104 - 2016-01-21 by JUSYN : Transfer BOM versions to WO buffer
    [M:MFGK]ECCVALMAJ = [F:ORD]ECCVALMAJ
    [M:MFGK]ECCVALMIN = [F:ORD]ECCVALMIN

    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTREL : Endif

    # llc 02.02 13047
    If WSTA = 3 : WMESS1 = "("+[M:MFGK]MFGNUM+")" : Endif

    # traces
    If [M:DIA]TRTAUTO = 1
        Call ECR_TRACE(WMESS,0) From GESECRAN
        If WMESS1 <> "" :     Call ECR_TRACE(WMESS1,0) From GESECRAN : Endif
    Endif
    Raz WMESS, WMESS1, WMESS2
    NBOF += 1
Commit

# Issue 84721 GA 10/2012 autoriser impression en batch
## llc 01.01 7063
#If GFONC1 = "FUNMAUT" & (dim(GMAUTRB) <= 0) & [M:MFGK]MFGSTA = 1
# GH 27/03/2014 bug 84721 ajout du test sur AUTOTRT par sécurité
If [M:MFGK]MFGSTA = 1 & [M:MFGK]AUTOTRT=2 & dim([M:DIA]IMPFLG)>0 & [M:DIA]IMPFLG = 2
    DOSOK = 0
    Call TEST_DOSSIER(DOSOK) From MFGAUTLIB
    If DOSOK =1
       If dim([M:DIA]PRT)=1 : GDEFIMP = [M:DIA]PRT : Else GDEFIMP = "" : Endif
       Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
       Read [F:MFP]MFP0 = [M:MFGK]MFGNUM
       If fstat : Raz [F:MFP] : Endif
       TBPAR(1)="codimp"        : TBVAL(1) = num$([F:MFP]MFGFDRFLG)
       TBPAR(2)="mfgfcydeb"     : TBVAL(2) = [M:MFGK]MFGFCY
       TBPAR(3)="mfgfcyfin"     : TBVAL(3) = [M:MFGK]MFGFCY
       TBPAR(4)="mfgnumdeb"     : TBVAL(4) = [M:MFGK]MFGNUM
       TBPAR(5)="mfgnumfin"     : TBVAL(5) = [M:MFGK]MFGNUM
       If GSERVEUR
          TBPAR(6)="_nolispar"   : TBVAL(6) = "1" : # GH 27/03/2014 bug 84721 pour schinter les infos techniques imprimées dans la trace
       Endif
       Call ETAT("DOSFAB",GDEFIMP,"",1,"",TBPAR,TBVAL) From AIMP3
       GOK=1 : # GH 27/03/2014 bug 84721 pour ne pas avoir une erreur inconnue sur la requête batch
   Endif
Endif

