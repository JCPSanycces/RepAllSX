End

########################################
Subprog C_MFGTRS(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Read [MTS]MTS0=1;VALEUR
If fstat
   GMESSAGE = mess(23,100,1) : mkstat = 2
Elsif [F:MTS]TRSAUTO <> 2
   GMESSAGE = mess(194,193,1) : mkstat = 2
Endif
End

########################################
Subprog AM_MFGTRS(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
    Read [MTS]MTS0=1;GMFGMTSNUM
Else
    Read [MTS]MTS0=1;VALEUR
Endif
If fstat : Raz [F:MTS] : Endif

# GH 27/03/2014 bug 84721 GMAUTRB plus utilisé
# If (dim(GMAUTRB) > 0 & GMAUTRB>1) : End : Endif    # 36039 mm 05.06
If dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3 | GCONSDIA : End : Endif

If [F:MTS]MODDOS = 2 &  [M:DIA]APSTA = 2
   Actzo [DIA]35
   If dim([M:DIA]PRT)=1 & [M:DIA]OBL=1 :  Diszo [DIA]PRT : Endif
Else
   [M:DIA]IMPFLG = 1 : Affzo [DIA] IMPFLG
   Diszo [DIA]35
Endif
End

########################################
# GH 27/03/2014 bug 84721 si pas d'édition, ne pas effacer l'imprimante qui peut être obligatoire
Subprog AS_PRT(VALEUR)
Variable Char    VALEUR()
If !(dim([M:DIA]IMPFLG)<0 | varmode([M:DIA]IMPFLG)=3) & [M:DIA]IMPFLG<>2 : mkstat=2 : Endif
End

########################################
Subprog C_PRT(VALEUR)
Variable Char    VALEUR()
# Issue 84721 GA 10/2012 autoriser impression en batch
#If (dim(GMAUTRB) > 0 & GMAUTRB>1) : End : Endif
Call LECTURE("AIM",VALEUR,"") From CONTOBJ
If [F:AIM]PRT = 2 & [F:AIM]PRTNAT > 1 & [F:AIM]PRTNAT <> [F:ARP]PRTNAT
    GMESSAGE = mess(5,133,1)-"("+mess([F:AIM]PRTNAT,22,1)+")" : # Imprimante de type incorrect
    mkstat = 2 : End
Endif
If [F:AIM]ACS <> ""
    # FQ 71395 GA 02/2011
    If clalev ([F:ACC])<=0 Local File ACCES   [ACC] : Endif
    Read [ACC]CODACC=GUSER;[F:AIM]ACS
    If fstat or [F:ACC]EXEC <> 2
        GMESSAGE = mess(7,133,1) : # Imprimante non autorisée
        mkstat = 2 : End
    Endif
Endif
If GBATCH
    If find([F:AIM]PRT,1)
        GMESSAGE = mess(12,135,1) : # Pas de prévisu en batch
        mkstat = 2 : End
    Endif
    If [F:AIM]PRTSRV = ""
       GMESSAGE = mess(13,135,1) : # Serveur d'impression non défini
       mkstat = 2 : End
    Endif
Endif
[M:DIA]SERIMP    = [F:AIM]PRTSRV
[M:DIA]DEFIMP    = [F:AIM]PRTNAM
[M:DIA]PRTPOR    = [F:AIM]PRTPOR
[M:DIA]PRTDRV    = [F:AIM]PRTDRV
Raz [M:DIA]PRTDES
For [AID]AID0 Where COD=[F:AIM]COD
 [M:DIA]PRTDES  = [F:AID]PRTDES
Next
End

# Issue 107498/109 - 2016-06-01 by JUSYN : treatment to check WOS concerning project management conditions
# returned field LMTXFLG 1 for okay 0 for not okay

$CHECK_PROJECT_CONDITIONS
# Issue number 107498/18 - 2016-07-18 by JUSYN : Project task status
Local Integer LPIMSTA
# Issue number 107498/18 - 2016-08-15 by JUSYN : Using existing func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE
Local Char BUDGET(15)
Local Char TASK(15)
Local Char SMESSAGE(250)

# SEPARATE File ORDERS For PROJECT MANAGEMENT TREATMENT
If clalev([F:ORDM])  = 0 : Local File ORDERS [ORDM]  : Endif
If clalev([F:ORDM2]) = 0 : Local File ORDERS [ORDM2] : Endif

LMTXFLG = 1
# only WOS
If [F:ORD]WIPTYP = 5 & WSTA = 3
    # only when project related
    If [F:ORD]PJT <> ""
        LMTXFLG = 0

        # Issue 98766 - 2018-07-19 by STLIG : Filter for MTx (project task demand) or
        #                                     SOx (sales order replaces project task demand)
        # check for requirement origin MTx/SOx or MWx
        # MTx/SOx
        Filter [ORDM]
        Filter [ORDM] Where [F:ORDM]STOFCY = [F:ORD]STOFCY and
&                           [F:ORDM]ITMREF = [F:ORD]ITMREF and
&                           [F:ORDM]PJT = [F:ORD]PJT and
&                           find([F:ORDM]VCRTYP,2,40)<>0 and
&                           find([F:ORDM]WIPTYP,1,14)<>0 and
&                           [F:ORDM]VCRLIN = [F:ORD] VCRLINORI
        Read [ORDM] First
        If !fstat
            # material demand from project material task = MTx = wiptyp 14 and launched
            # demand from sales order (vcrtyp = 2, wiptyp = 1) - replaces project demand
            If [F:ORDM]WIPSTA = 1 : LMTXFLG = 1 : Endif
        Else
            # material demand from project material task = MWx = wiptyp 6 = materials from BOM explosion
            # select corresponding MTx record originated from product in project task, check whether launched (WIPSTA = 1)
            Filter [ORDM]
            # MWx
            Filter [ORDM] Where [F:ORDM]STOFCY = [F:ORD]STOFCY and [F:ORDM]PJT = [F:ORD]PJT and [F:ORDM]WIPTYP = 6 and [F:ORDM]ITMREF = [F:ORD]ITMREF
            Read [ORDM] First
            If !fstat
              # management mode = by order
              If [F:ITM]STDFLG = 4
                Filter [ORDM2] Where [F:ORDM2]STOFCY = [F:ORD]STOFCY and [F:ORDM2]VCRTYP = 40 and [F:ORDM2]PJT = [F:ORD]PJT and [F:ORDM2]WIPTYP = 14 and [F:ORDM2]VCRLIN = [F:ORD]VCRLINORI
                Read [ORDM2] First
                # Issue number 107498/18 - 2016-07-18 by JUSYN : Order with PJT but without already existing project management material record
                If !fstat
                  If [F:ORDM2]WIPSTA = 1 : LMTXFLG = 1 : Endif
                Else
                  # Issue number 107498/18 - 2016-08-15 by JUSYN : Using existing func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE
                  LPIMSTA = func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE (GACTX, [F:ORD]PJT, BUDGET, TASK, SMESSAGE)
                  If LPIMSTA = 2 : LMTXFLG = 1 : Endif
                Endif
                Filter[ORDM2]
              Endif
              # management mode = Available stock
              If [F:ITM]STDFLG = 3
                # material demand with product in management mode = available stock can be processed generally
                LMTXFLG = 1
              Endif
            Endif
        Endif
        Filter [ORDM]
   Endif
Endif

Return

