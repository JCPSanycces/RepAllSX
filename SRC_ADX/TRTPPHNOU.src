Subprog AV_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM([V]GLONEML)
[L]REFNUM = [M:DIA]REFNUM([L]NOL)
If [L]REFNUM <> ""
    If [L]REFNUM <> [F:ID]REFNUM
        Read [F:ID]ID0 = [L]REFNUM
    Endif
    If [F:ID]FLGMULCTR <> 2
        Grizo [M:DIA]CTRNUM([L]NOL)
    Else
        Actzo [M:DIA]CTRNUM([L]NOL)
    Endif
Endif
End

Subprog AV_NAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM([V]GLONEML)
[L]REFNUM = [M:DIA]REFNUM([L]NOL)
[L]VALEUR = func SUBHRPPH.GET_NAM([L]REFNUM, 3)
End

$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM([V]GLONEML), CTRNUM([V]GLONHRCTR)
Local Char MESSA(250)
Local Integer OK

Local Integer TTYPMGR(len(mess(0,50,1))), NBCTR
Gosub SETFLX From SUBHRPPH
Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If [F:ID]FLGMULCTR <> 2
    ##**82073
    Call CHERCHE_CTRPER([L]VALEUR, [M:DIA]APLSTR, [M:DIA]APLDAT, [M:DIA]CTRNUM([L]NOL)) From DIVPAYE
    [L]REFNUM = [L]VALEUR
    [L]CTRNUM = [M:DIA]CTRNUM([L]NOL)
    Gosub CTRL_CTR
    If mkstat=2 : Raz [M:DIA]CTRNUM([L]NOL) : Raz [M:DIA]CTRDAT([L]NOL) : End: Endif
    [M:DIA]REFNUM([L]NOL) = [L]REFNUM
    Affzo [M:DIA]CTRNUM([L]NOL)
    Affzo [M:DIA]CTRDAT([L]NOL)
    Call C_CTRNUM([M:DIA]CTRNUM([L]NOL))
    If mkstat=2 : Raz [M:DIA]CTRNUM([L]NOL) : End: Endif
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
Gosub SETNOL
If [L]VALEUR = 2
    Actzo [M:DIA]CTRNUM([L]NOL)
Else
    Diszo [M:DIA]CTRNUM([L]NOL)
Endif
Affzo [M:DIA]CTRNUM([L]NOL)
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:DIA]CTRNUM([L]NOL) = ""
  ##**82073
  Call SELCTR([M:DIA]REFNUM([L]NOL),[M:DIA]APLSTR,[M:DIA]APLDAT,VALEUR) From DIVPAYE
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM(GLONEML), CTRNUM(GLONHRCTR)
Local Integer I, OK
Local Char MESSA(250)

Local Integer TTYPMGR(len(mess(0,50,1))), NBCTR
Gosub SETFLX From SUBHRPPH
Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY

[L]REFNUM = [M:DIA]REFNUM([L]NOL)
[L]CTRNUM = VALEUR
Gosub CTRL_CTR
If mkstat=2 : End: Endif

For [L]I=0 To [M:DIA]NBLIG-1
    If [L]I <> [L]NOL
        If [M:DIA]REFNUM([L]NOL) = [M:DIA]REFNUM([L]I)
&                & [L]VALEUR = [M:DIA]CTRNUM([L]I)
&                & [M:DIA]CTRDAT([L]NOL) = [M:DIA]CTRDAT([L]I)         :#**82073
            [V]GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
            mkstat=2 : Break
        Endif
    Endif
Next
If mkstat : End : Endif


End

Subprog AS_CTRDAT(VALEUR)
Variable Date VALEUR
If VALEUR<>[0/0/0] : End : Endif
Gosub SETNOL
If [M:DIA]REFNUM([L]NOL) <> "" & [M:DIA]CTRNUM([L]NOL) <> ""
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [M:DIA]REFNUM([L]NOL)
&                    & [F:HRCTR]CTRNUM = [M:DIA]CTRNUM([L]NOL)
&                    & [F:HRCTR]CTRDAT <= [M:DIA]APLDAT
&                    & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT >= [M:DIA]APLSTR)    :##**83073
    Read [F:HRCTR]CTR0 Last
    If fstat <= 2
        [L]VALEUR = [F:HRCTR]CTRDAT
    Endif
    Filter [F:HRCTR]
Endif
End

$CTRL_CTR

MESSA = ""

##**82073
If [F:HRCTR]CTRDAT <= [M:DIA]APLDAT
&  & ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT >= [M:DIA]APLSTR)
    # Ok
Else
    # mess(191,10702,1) : Contrat non valide à la date d'application
    Call ERREUR(mess(191,10702,1)) From GESECRAN
    mkstat = 2
    Return
Endif
If not func TRTPREPAY.ISCHEF([M:DIA]MGR, [L]TTYPMGR,
&                                    [F:HRCTR]REFNUM, [F:HRCTR]CTRNUM, [F:HRCTR]CTRDAT, "1234")
    # mess(192,10702,1) : Ce salarié n'est pas suivi par ce manager
    Call ERREUR(mess(192,10702,1)) From GESECRAN
    mkstat = 2
    Return
Endif

If [M:DIA]CRICPY<>""
 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M:DIA]CRICPY
  MESSA += mess(42,10702,1)-":"-[F:FCY]LEGCPY : # Société
 Endif
 If [M:DIA]CRIFCY<>"" & [F:HRCTR]ETRFCY<>[M:DIA]CRIFCY
  If MESSA<>"" : MESSA += "\" : Endif
  MESSA += mess(43,10702,1)-":"-[F:HRCTR]ETRFCY : # Site
 Endif
Endif
If [M:DIA]CRISRV<>"" & [M:DIA]CRISRV<>[F:HRCTR]ETRSRV
 If MESSA<>"" : MESSA += "\" : Endif
 MESSA += mess(44,10702,1)-[F:HRCTR]ETRSRV : # Service
Endif
If [M:DIA]CRIPRF<>"" & [M:DIA]CRIPRF<>[F:HRCTR]PROPRF
If MESSA<>"" : MESSA += "\" : Endif
MESSA += mess(45,10702,1)-[F:HRCTR]PROPRF : # Profil
Endif
If MESSA<>""
 OK = 2 : Call AVERTIR([F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN+"\"+MESSA,OK) From GESECRAN
 If OK<>2 : mkstat = 2 : Return : Endif
Endif

Return

Subprog CHARGE_TABLO(SILENCE)
Value Integer SILENCE
#LIPET - 2017-06-14 - START
If dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "HRPPH"
  End
Endif
#LIPET - 2017-06-14 - END
If not [L]SILENCE
    Call TEMPON("O") From GESECRAN
Endif

Effzo [M:DIA] 20

Local Integer TTYPMGR(len(mess(0,50,1))), NBCTR
Gosub SETFLX From SUBHRPPH

Call GET_TTYPMGR([L]FLUX_METIER, [L]TTYPMGR) From TRTPREPAY

##**82073
Call GET_CTRLIST([M:DIA]MGR, [L]TTYPMGR,
&        [M:DIA]CRICPY, [M:DIA]CRIFCY, [M:DIA]CRISRV, [M:DIA]CRIPOP, [M:DIA]CRIPRF , [M:DIA]APLSTR, [M:DIA]APLDAT,
&            [M:DIA]REFNUM, [M:DIA]CTRNUM, [M:DIA]CTRDAT, [L]NBCTR) From TRTPREPAY

[M:DIA]NBLIG = [L]NBCTR

If not [L]SILENCE
    Call TEMPOFF From GESECRAN
    Affzo [M:DIA] 20
Endif

End

Subprog CL_LOAD(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-06-14 - START
#Call CHARGE_TABLO(0)
Local Integer SILENT
If(GWEBSERV=1) :SILENT =1 :Endif
Call CHARGE_TABLO(SILENT)
#LIPET - 2017-06-14 - END
End

Subprog AS_LOAD(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-06-14 - START
Local Integer SILENT
If(GWEBSERV=1) :SILENT =1 :Endif
#LIPET - 2017-06-14 - END
Read [F:PVH]PVH0 = GCURLEG;[M:DIA]PVHCOD
If fstat = 0 & [F:PVH]FLGLOA = 2 & [M:DIA]NBLIG = 0
    #LIPET - 2017-06-14 - START
#    Call CHARGE_TABLO(0)
     Call CHARGE_TABLO(SILENT)
     #LIPET - 2017-06-14 - END
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog C_CTRDAT(VALEUR)
Variable Date    VALEUR
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

Look [F:HRCTR]CTR0=[M:DIA]REFNUM(nolign-1);[M:DIA]CTRNUM(nolign-1);VALEUR
If fstat
 GMESSAGE=mess(26,10701,1) #: Contrat inexistant
 mkstat=2 : End
Endif
End

######################################################################################
## Section automatically added (screen TRTPPHNOU) 05/23/2017 15:25:54 (LIPET)
######################################################################################
Subprog AP_PERCOD(VALEUR)
Variable Char    VALEUR()
Local Char VALBOUT : VALBOUT = ""
Local Char PARBOUT : PARBOUT = "HRPER0"
Global Char GFRQCOD
Local Date STR2, END2
Local Date STR2, END2
Local Integer TAXYEA, TAXMON
Local Integer NBPERNUM,NUMPERNUM
Local Char LIBHRPEO(130)(0..100)
Local Integer    TBPERNUM(GLONVCR)(0..100)
Local Char    TITBOITE(250)

GFRQCOD=VALEUR
If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
If !clalev([F:HRPEOH]) : Local File HRPEOHEA [HRPEOH] : Endif

[L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))

Link [F:HRPEOD]
&  With [F:HRPEOH]HRPEOH0 = [F:HRPEOD]PERYEA;[F:HRPEOD]PERCOD
&  As [LNK]
&  Where [F:HRPEOD]PERCOD=VALEUR & [F:HRPEOH]FLGENA=2
&        & (month([F:HRPEOD]PERSTR(1))=month([L]STR2) or month([F:HRPEOD]PEREND(1))=month([L]END2))
&        & (year([F:HRPEOD]PERSTR(1))=year([L]STR2) or year([F:HRPEOD]PEREND(1))=year([L]END2))

If rowcount([LNK]) = 0
  GERR = 2 : GMESSAGE = VALEUR + " - " + mess(00164,00107,1)+ " " + format$(GFMD,[L]STR2) + " to " + format$(GFMD,[L]END2) + " " + mess(00002,00126,1)
  Raz [M:DIA]PERCOD : Affzo [M:DIA]PERCOD
  mkstat=2
Endif

[L]TAXMON = [F:HRPEOD]TAXMON
[L]TAXYEA = [F:HRPEOD]PERYEA

For [LNK]
  NBPERNUM+=1
  TBPERNUM(NBPERNUM) = [F:HRPEOD]PERNUM
  LIBHRPEO(NBPERNUM) = num$([F:HRPEOD]PERNUM)-num$([F:HRPEOD]PERSTR(1))-"-"-num$([F:HRPEOD]PEREND(1))
Next

Call SAITEX(NBPERNUM,LIBHRPEO,NUMPERNUM,TITBOITE) From TRTAUT: # Choose period
End


######################################################################################

