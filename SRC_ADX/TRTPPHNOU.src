Call C_ALLFCY([L]VALEUR) From DIVPPH
End

Subprog C_CRIFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M]ALLFCY <> 2
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2
Endif
End

Subprog AM_CRIFCY(VALEUR)
Variable Char    VALEUR()
Call SET_PYRDAT([M:DIA]APLDAT)
If mkstat=3 : Raz mkstat : Endif :#78701
Affzo PYRDAT, DATDEB,DATFIN,FMOIS
End

