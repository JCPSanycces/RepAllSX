Call C_ALLCPY([L]VALEUR) From DIVPPH
End

Subprog C_CRICPY(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" & [M]ALLCPY <> 2
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2
Endif
End

