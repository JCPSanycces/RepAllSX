#<AdxTL>@(#)9.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#-------------------------------------------------------------------------------------------------------------
# TRTPPHNOU : Gestion de la mini boite "nouveau" sur objet PPH
#             => demande des critères de la demande
#-------------------------------------------------------------------------------------------------------------
End


$ACTION
Case [L]ACTION
    When "DEBUT"  : Gosub DEBUT
    When "SORTIE" : Gosub SORTIE
    When "OK"     : Gosub OK
    When "FIN"    : Raz [M:DIA]
    When Default
Endcase
Return

$DEBUT

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif

Local Char VOIDCHAR(250)
Local Integer INDICE_DEBUT_SALARIE : [L]INDICE_DEBUT_SALARIE = 21

If GPAYE=1
 ##**82073
 [M:DIA]APLDAT = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
 [M:DIA]APLSTR = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
 Call SET_PYRDAT(gdat$(func DIVPAYE.INIPARUSR("DATPAY","","")))
Endif

[M:DIA]ALLCPY = 2 : [M:DIA]ALLFCY = 2 : [M:DIA]ALLSRV = 2 : [M:DIA]ALLPRF = 2

Gosub SET_GRIZO

Affzo [M:DIA]
#JOJAC - 2016-09-07 - X3PEOP-919 - START
If GCURLEG <> ""  : SAV_GCURLEG = GCURLEG
  GCURLEG = [M:DIA]LEG
Endif
#JOJAC - 2016-09-07 - X3PEOP-919 - END

Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$OK

# Retourner les paramètres saisis.

[L]VALEUR = "OK"
[L]PARAM(1) = [M:DIA]PVHCOD
[L]PARAM(2) = [M:DIA]CRICPY
[L]PARAM(3) = [M:DIA]CRIFCY
[L]PARAM(4) = [M:DIA]CRISRV
[L]PARAM(5) = [M:DIA]CRIPOP
[L]PARAM(6) = [M:DIA]CRIPRF
[L]PARAM(9) = num$([M:DIA]ALLCPY)+num$([M:DIA]ALLFCY)+num$([M:DIA]ALLSRV)+num$([M:DIA]ALLPRF)
[L]PARAM(10) = [M:DIA]DES
[L]PARAM(11) = [M:DIA]MGR
[L]PARAM(12) = format$("D:YYYYMMDD", [M:DIA]DEMDAT)
[L]PARAM(13) = format$("D:YYYYMMDD", [M:DIA]APLDAT)
[L]PARAM(14) = format$("D:YYYYMMDD", [M:DIA]APLSTR)

If (dim([M:DIA]LEG) >= 0)
 [L]PARAM(15) = [M:DIA]LEG
Endif

If [M:DIA]NBLIG > 0
    [L]J = [L]INDICE_DEBUT_SALARIE
    For [L]I = 0 To [M:DIA]NBLIG - 1
        [L]VOIDCHAR = [M:DIA]REFNUM([L]I) + "~" +
&                        [M:DIA]CTRNUM([L]I) + "~" +
&                        format$("D:YYYYMMDD", [M:DIA]CTRDAT([L]I))
        [L]PARAM([L]J) = [L]VOIDCHAR
        [L]J += 1
    Next
Endif
Return

$SET_GRIZO
If [M:DIA]ALLCPY = 2
    Grizo [M:DIA]CRICPY
Else
    Actzo [M:DIA]CRICPY
Endif
#JOJAC 2016-08-02 - X3PEOP-910 - START
If  [M:DIA]CRICPY = ""
    Grizo [M:DIA]ALLFCY
Else
    Actzo [M:DIA]ALLFCY
Endif
#JOJAC 2016-08-02 - X3PEOP-910 - END
If [M:DIA]ALLFCY = 2
    Grizo [M:DIA]CRIFCY
Else
    Actzo [M:DIA]CRIFCY
Endif
If [M:DIA]ALLSRV = 2
    Grizo [M:DIA]CRISRV
Else
    Actzo [M:DIA]CRISRV
Endif
If [M:DIA]ALLPRF = 2
    Grizo [M:DIA]CRIPRF
Else
    Actzo [M:DIA]CRIPRF
Endif
Return


# ---------------------------- ECRAN --------------------------------------------------
Subprog AS_MGR(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR = "" : [L]VALEUR = [V]GREFNUM : Endif
End

Subprog AS_PVHCOD(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR = ""
    [L]VALEUR = func SUBPVH.GET_DFLTPVHCOD([V]GUSER, [M:DIA]MGR)
Endif
If rowcount([F:PVH]) = 1
    Diszo [M:DIA]PVHCOD
    Call AM_PVHCOD([L]VALEUR)
Else
    Actzo [M:DIA]PVHCOD
Endif
End

Subprog AM_PVHCOD(VALEUR)
Variable Char    VALEUR()
If [L]VALEUR = "" : mkstat = 2 : End : Endif
Read [F:PVH]PVH0 = GCURLEG;[L]VALEUR
If fstat = 0
    [M:DIA] = [F:PVH]
    Gosub SET_GRIZO
    Affzo [M:DIA]
Endif
End


Subprog AS_DEMDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR = [0/0/0] : [L]VALEUR = datesyst : Endif
End

Subprog AS_APLSTR(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  VALEUR= gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
Endif
End

Subprog AS_APLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  VALEUR= gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
Endif
End

Subprog C_APLDAT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR < [M:DIA]DEMDAT
    GMESSAGE = mess(200,126,1)-'"'+mess(164,10701,1)+'"' : # Valeur inférieure à Date de la demande
    mkstat = 2 : End
Endif
End

Subprog AM_APLDAT(VALEUR)
Variable Date    VALEUR
Call SET_PYRDAT([L]VALEUR)
Affzo PYRDAT, DATDEB,DATFIN,FMOIS
#LIPET - 2017-06-14 - START
If dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "HRPPH" & dim(G_WPYRDAT) >= 0 & G_WPYRDAT = [0/0/0]
  G_WPYRDAT= [M]PYRDAT
Endif
#LIPET - 2017-06-14 - END
End

#89736
Subprog SET_PYRDAT(PYRDAT)
Value Date PYRDAT

Raz [M]PYRDAT, [M]DATDEB, [M]DATFIN, [M]FMOIS
#LIPET - 2017-06-14 - START
If dim(G_WFLUXPOR) >= 0 & G_WFLUXPOR = "HRPPH" & dim(G_WPYRDAT) >= 0 & G_WPYRDAT <>[0/0/0]
   [M]PYRDAT= G_WPYRDAT
   End
Endif
#LIPET - 2017-06-14 - END
#It's mandatory to set [M]PYRDAT before to call CADRE_PYRDAT because
#[L]PYRDAT is a value and not a variable to not modify the variable sended by the caller
[M]PYRDAT = [L]PYRDAT

#LIPET - 2017-05-20 - START
If dim([M]PERCOD)>0 Then
#Call CADRE_PYRDAT([M]PYRDAT, [M]CRIFCY) From TPSSUB
Call CADRE_PYRDAT([M]PYRDAT, [M]PERCOD) From TPSSUB
Endif
#LIPET - 2017-05-20 - END
If mkstat
  GMESSAGE=""
  #LIPET - 2017-06-14 - START
  mkstat = 0
  #LIPET - 2017-06-14 - END
  End
Endif
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#[M]DATDEB = [F:HRPEO]PERSTR(0)
#[M]DATFIN = [F:HRPEO]PEREND(0)
#[M]FMOIS  = [F:HRPEO]PEREND(1)

[M]DATDEB = [F:HRPEOD]PERSTR(0)
[M]DATFIN = [F:HRPEOD]PEREND(0)
[M]FMOIS  = [F:HRPEOD]PEREND(1)
#LIPET - 2017-05-20 - END
End
#End 89736

