            Chgfmt [M:RCPC]WEI14 With "-N:4#" : Chgfmt [M:RCPC]WEI15 With "-N:4#"

            Chgfmt [M:RCPC]NIV2 With "-N:4#"   : Chgfmt [M:RCPC]NIV3 With "-N:4#"
            Chgfmt [M:RCPC]NIV4 With "-N:4#"   : Chgfmt [M:RCPC]NIV5 With "-N:4#"
            Chgfmt [M:RCPC]NIV6 With "-N:4#"   : Chgfmt [M:RCPC]NIV7 With "-N:4#"
            Chgfmt [M:RCPC]NIV8 With "-N:4#"   : Chgfmt [M:RCPC]NIV9 With "-N:4#"
            Chgfmt [M:RCPC]NIV10 With "-N:4#"  : Chgfmt [M:RCPC]NIV11 With "-N:4#"
            Chgfmt [M:RCPC]NIV12 With "-N:4#"  : Chgfmt [M:RCPC]NIV13 With "-N:4#"
            Chgfmt [M:RCPC]NIV14 With "-N:4#"  : Chgfmt [M:RCPC]NIV15 With "-N:4#"
   When 2 : Chgfmt [M:RCPC]CRIT3 With "-Nz+:4.2#"  : Chgfmt [M:RCPC]CRIT4 With "-Nz+:4.2#"
