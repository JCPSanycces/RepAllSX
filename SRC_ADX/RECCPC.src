Funprog  ALLUTI()
Local Integer RES
RES=1
If(!instr(1,GUSRAUZ,"1") and instr(1,GUSRAUZ,"2") )
  RES=0
Endif
End RES

$GESBUTTON
If func ALLUTI()
#  If zoncou="REFNUM"
#    Raz GBOUT2
#  Endif
Else
  Raz GBOUT1
#  If(zoncou="REFNUM")
#     #Raz GBOUTS
#  Endif
Endif
Return
