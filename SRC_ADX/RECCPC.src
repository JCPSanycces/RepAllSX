###################################################################################################################################
# JML 27/08/10 LOT P02
# SEGAY - 25/11/10 - BUG bug 69399 LOT P02 Echelle globale(0 à 100%) sur le niveaux de compétence (5 niveaux ML 480)
# MABOS - 11/03/13 - FQ81085 - US1436 - Add leg in the screen
# SBA   - 21/08/2013 FQ: 91298 - US 1835 : suppression des maskcou dans ini_byleg
###################################################################################################################################
# Gestion du masque RECCPC
## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"RECCPC","RECCPC","DRECCPC",4,"XYRECCPC") From GTRAITE
End
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "END"      : FIN = 1
 When "OK"       : Gosub BOUTON_OK
 When "CONTROLE" : Gosub CONTROLE
 When "AVANT_BOUTON"   : Gosub AVANT_BOUTON : #MABOS-FQ81085-US1833 - manage mémo
 When "BOUTON"   : Gosub BOUTON
 When "TERMINE"  : Gosub TERMINE
 When "SORTIE"   : Gosub SORTIE ##ADNGO - 2017-03-15 - X3-29328
 When Default
Endcase
Return
########
$INIT
Local Mask RECCPCLIS [RCPC]
Local Mask RECCPC    [DIA]
Raz [M:DIA]
#MABOS:06/08/13-affectation de GCURLEG
## MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
#If dim([M:DIA]LEG)>0  & [M:DIA]LEG = "" Then
#  [M:DIA]LEG =GLEGFIL
#  GCURLEG = [M:DIA]LEG
#Endif
Call INI_LEG From DIVPAYE
#end MABOS:06/08/13-affectation de GCURLEG
Return
########
$OUVRE
If clalev([F:CPE1])=0   : Local File CPCEMP     [CPE1]  : Endif
If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP   [FGR]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:ECT])=0    : Local File EMPCTR     [ECT]   : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif
# FQ82920 - MABON 15/06/12
If clalev([F:EPO])=0  : Local File EMPLOPOT   [EPO]  : Endif
# Fin MABON
If clalev([F:ID3])=0    : Local File EMPLOID    [ID3]   : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom

###################################################################################################################################
# JML 28/07/10 LOT P02 New method, with a link and a filter, always based on CTR
# JML 24/09/10 CG uniquement pour les contrats avec suivi de carrière
Link [ECT] With  [ID]ID0=[F:ECT]REFNUM
&             , [FCY]FCY0=[F:ECT]FCY
&             , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
&          As [LECT]
&          Where [F:ID]ENAFLG=2 & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>date$)
&              & [F:HRCTR]SUICAR=2


Local Integer I, J, K, CTL
Local Decimal PDSMAT
#SEGAY 25/11/10 bug 69399
Local Decimal COEFPDSMAT : # Coefficient
Local Decimal PDSMATCOEF : # Application du coef sur le niveau
Local Decimal PCTMATCOEF : # Application du pourcentage

Local Decimal PDSREF
Local Char    MATRI(GLONEML)
Local Char    L_CRITERE(GDIMFIC)
Local Integer L_IJ, L_JK, L_NBCPC, L_NB

If dim([M]LEG)> 0 : GCURLEG=[M]LEG :Endif:  #MABOS-FQ81085-US1833 - manage memo
Return
########
$SORTIE
#ADNGO - 2017-03-15 - X3-29328 - START
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#ADNGO - 2017-03-15 - X3-29328 - END
$DEBUT
#ADNGO - 2017-03-15 - X3-29328 - START
If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif
#ADNGO - 2017-03-15 - X3-29328 - END
Case BOITE
 When "DRECCPC"
  If [M:DIA]REFNUM="" & [M:DIA]JOT="" & [M:DIA]POT=""
   Call LECMEMO("STD","[M:DIA]","rcpc") From GMEMO
   Call AFF_MEMO2(1) From DIVPAYE : #MABOS:06/08/13-afectation de GCURLEG
  Endif
  Gosub GRISE
  #ADNGO - 2017-03-15 - X3-29328 - START
  If !func ALLUTI() and GREFNUM=""
   Grizo REFNUM
  Endif
  #ADNGO - 2017-03-15 - X3-29328 - END
  Affzo [M:DIA]
 When "RECCPC"
  Raz [M:RCPC]
  Gosub CHARGE
