###################################################################################################################################
$CHARGE
#################################################################################
# JML 28/07/10 LOT P02 New method, with a link and a filter, always based on CTR
#SEGAY 25/11/10 bug 69399
#COEFPDSMAT = 4 : # Coefficient
Local Char    DESCPC(GLONDES):#MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
COEFPDSMAT = func CALCSCALE : # Coefficient
If dim([M:DIA]LEG)>0 Then GCURLEG=[M:DIA]LEG :Endif

L_CRITERE = ""
If [M:DIA]JOT<>""
 L_CRITERE += "&[F:HRCTR]JOBPOT='"+[M:DIA]JOT+"'"
Endif
If [M:DIA]POT<>""
 L_CRITERE += "&[F:HRCTR]POT='"+[M:DIA]POT+"'"
Endif

L_CRITERE = right$(L_CRITERE,2)
If L_CRITERE=""
 L_CRITERE = "1=1"
Endif
#################################################################################
#ADNGO - 2017-03-15 - X3-29328 - START
If !clalev([F:CPE1])   : Local File CPCEMP     [CPE1]  : Endif
#ADNGO - 2017-03-15 - X3-29328 - END
Raz [M:DIA]CPC, [M:DIA]ZCPC, [M:DIA]NBRCPC
L_NBCPC = dim([M:DIA]CPC)
If [M:DIA]REFNUM<>""
 For [CPE1]CPE1 Where [CPE1]REFNUM=[M:DIA]REFNUM & [CPE1]CPCDAT<>[0/0/0]
  I = find([F:CPE1]CPC,[M:DIA]CPC(0..[M:DIA]NBRCPC-1))
  If !I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   If [M:DIA]NBRCPC>=L_NBCPC
    Call ERREUR([M:DIA]REFNUM-mess(48,10720,1)) From GESECRAN
    #### Trop de compétences à analyser
    Break
   Endif
   Call LECTURE("CPC",[F:CPE1]CPC,"") From CONTOBJ

   If find(GCURLEG,[F:CPC]LEG,"") | find([F:CPC]LEG,"",GCURLEG) Then   :# #MABOS-FQ81085-US1436
     [M:DIA]CPC([M:DIA]NBRCPC)    = [F:CPE1]CPC
     #MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
     #   [M:DIA]ZCPC([M:DIA]NBRCPC)   = [F:CPC]DES
     Call LECTEXTRA(DESCPC,"COMPETENCE","DES",[F:CPE1]CPC,"") From ATEXTRA
     [M:DIA]ZCPC([M:DIA]NBRCPC)   = DESCPC
     [M:DIA]REQUIS([M:DIA]NBRCPC) = 1
     [M:DIA]NBRCPC += 1
   Endif  :#MABOS-FQ81085-US1436
  Endif
 Next : # [CPE1]CPE1
Endif
#
If [M:DIA]JOT<>"" & [M:DIA]NBRCPC<L_NBCPC
 Call LECTURE("JOT",[M:DIA]JOT,"") From CONTOBJ
 For L_IJ=0 To dim([F:JOT]CPC)-1
  If [F:JOT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:JOT]CPC(L_IJ),"") From CONTOBJ
  I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1))
  If !I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   If [M:DIA]NBRCPC>=L_NBCPC
    Call ERREUR([M:DIA]REFNUM-mess(48,10720,1)) From GESECRAN
    #### Trop de compétences à analyser
    Break
   Endif
   [M:DIA]CPC([M:DIA]NBRCPC)    = [F:CPC]COD
   #MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
#   [M:DIA]ZCPC([M:DIA]NBRCPC)   = [F:CPC]DES
   Call LECTEXTRA(DESCPC,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
   [M:DIA]ZCPC([M:DIA]NBRCPC)   = DESCPC
   [M:DIA]REQUIS([M:DIA]NBRCPC) = 2
   [M:DIA]NBRCPC += 1
  Elsif I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   [M:DIA]REQUIS(I-1) = 2
  Endif
 Next L_IJ
Endif
#
If [M:DIA]JOT2<>"" & [M:DIA]NBRCPC<L_NBCPC
 Call LECTURE("JOT",[M:DIA]JOT2,"") From CONTOBJ
 For L_IJ=0 To dim([F:JOT]CPC)-1
  If [F:JOT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:JOT]CPC(L_IJ),"") From CONTOBJ
  I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1))
  If !I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   If [M:DIA]NBRCPC>=L_NBCPC
    Call ERREUR([M:DIA]REFNUM-mess(48,10720,1)) From GESECRAN
    #### Trop de compétences à analyser
    Break
   Endif
   [M:DIA]CPC([M:DIA]NBRCPC)    = [F:CPC]COD
   #MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
#   [M:DIA]ZCPC([M:DIA]NBRCPC)   = [F:CPC]DES
   Call LECTEXTRA(DESCPC,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
   [M:DIA]ZCPC([M:DIA]NBRCPC)   = DESCPC
   [M:DIA]REQUIS([M:DIA]NBRCPC) = 2
   [M:DIA]NBRCPC += 1
  Elsif I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   [M:DIA]REQUIS(I-1) = 2
  Endif
 Next L_IJ
Endif
#
If [M:DIA]POT<>"" & [M:DIA]NBRCPC<L_NBCPC
 Call LECTURE("POT",[M:DIA]POT,"") From CONTOBJ
 For L_IJ=0 To dim([F:POT]CPC)-1
  If [F:POT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:POT]CPC(L_IJ),"") From CONTOBJ
  I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1))
  If !I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   If [M:DIA]NBRCPC>=L_NBCPC
    Call ERREUR([M:DIA]REFNUM-mess(48,10720,1)) From GESECRAN
    #### Trop de compétences à analyser
    Break
   Endif
   [M:DIA]CPC([M:DIA]NBRCPC)    = [F:CPC]COD
   #MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
   #   [M:DIA]ZCPC([M:DIA]NBRCPC)   = [F:CPC]DES
   Call LECTEXTRA(DESCPC,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
   [M:DIA]ZCPC([M:DIA]NBRCPC)   = DESCPC
   [M:DIA]REQUIS([M:DIA]NBRCPC) = 2
   [M:DIA]NBRCPC += 1
  Elsif I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   [M:DIA]REQUIS(I-1) = 2
  Endif
 Next L_IJ
Endif
#
If [M:DIA]POT2<>"" & [M:DIA]NBRCPC<L_NBCPC
 Call LECTURE("POT",[M:DIA]POT2,"") From CONTOBJ
 For L_IJ=0 To dim([F:POT]CPC)-1
  If [F:POT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:POT]CPC(L_IJ),"") From CONTOBJ
  I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1))
  If !I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   If [M:DIA]NBRCPC>=L_NBCPC
    Call ERREUR([M:DIA]REFNUM-mess(48,10720,1)) From GESECRAN
    #### Trop de compétences à analyser
    Break
   Endif
   [M:DIA]CPC([M:DIA]NBRCPC)    = [F:CPC]COD
   #MABOS-11/03/13-FQ81085-US1436-Add leg in the screen
   #   [M:DIA]ZCPC([M:DIA]NBRCPC)   = [F:CPC]DES
   Call LECTEXTRA(DESCPC,"COMPETENCE","DES",[F:CPC]COD,"") From ATEXTRA
   [M:DIA]ZCPC([M:DIA]NBRCPC)   = DESCPC
   [M:DIA]REQUIS([M:DIA]NBRCPC) = 2
   [M:DIA]NBRCPC += 1
  Elsif I & ([M:DIA]FLGKEY<>2 | [F:CPC]FLGKEY=2)
   [M:DIA]REQUIS(I-1) = 2
  Endif
 Next L_IJ
Endif
Sorta [M:DIA]NBRCPC [M:DIA]CPC, [M:DIA]ZCPC Order By [M:DIA]CPC([S]indice)
#################################################################################

If [M:DIA]REFNUM<>""
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID    : # JML 28/07/10 LOT P02
 [M:RCPC]DES([M:RCPC]NBRID-1) = mess(51,10720,1) : # Compétences requises collaborateur
 For [CPE1]CPE1 Where [CPE1]REFNUM=[M:DIA]REFNUM & [CPE1]CPCDAT<>[0/0/0]
  OK = 1
  I = find([F:CPE1]CPC,[M:DIA]CPC(0..[M:DIA]NBRCPC-1)) - 1
  If I>=0
   # Calcul de la pondération
   Call LECTURE("CPC",[F:CPE1]CPC,"") From CONTOBJ
   If find(GCURLEG,[F:CPC]LEG,"") | find([F:CPC]LEG,"",GCURLEG) Then :#MABOS-FQ81085-US1436
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     J = find([F:CPE1]LEVCPC,[F:HRSCA]LEV)
     If J=0
      PDSMAT = 0
      PDSREF = 0
     Else
      PDSMAT = [F:HRSCA]LEVREF(J-1)*1
      For L_IJ=0 To dim([F:HRSCA]LEVREF)-1
       If [F:HRSCA]LEVREF(L_IJ)<>0
        PDSREF = [F:HRSCA]LEVREF(L_IJ)*1
       Endif
      Next L_IJ
     Endif

     If evalue("dim([M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1))")>0
      #SEGAY 25/11/10 bug 69399
  #    Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT
      PDSMATCOEF=0
      PCTMATCOEF=0
      If PDSREF > 0
        PDSMATCOEF=ar2((PDSMAT/PDSREF)*COEFPDSMAT)
        PCTMATCOEF=ar2((PDSMAT/PDSREF)*100)
      Endif
      Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PCTMATCOEF
      Assign "[M:RCPC]COEF"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMATCOEF
      Assign "[M:RCPC]WEI"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT

      If PDSMAT
       Assign "[M:RCPC]NIV"+num$(I+1)+"([M:RCPC]NBRID-1)"  With num$(PDSMAT)+"/"+num$(PDSREF)
      Endif
     Endif : # If evalue

     [M:RCPC]WEI([M:RCPC]NBRID-1) = 0
     For L_IJ=1 To [M:DIA]NBRCPC
      If evalue("dim([M:RCPC]CRIT"+num$(L_IJ)+"([M:RCPC]NBRID-1))")<=0
       Break
      Endif
      #SEGAY 25/11/10 bug 69399
  #    [M:RCPC]WEI([M:RCPC]NBRID-1) += evalue("[M:RCPC]CRIT"+num$(L_IJ)+"([M:RCPC]NBRID-1)")
      [M:RCPC]WEI([M:RCPC]NBRID-1) += evalue("[M:RCPC]WEI"+num$(L_IJ)+"([M:RCPC]NBRID-1)")

     Next L_IJ
   Endif :#MABOS-FQ81085-US1436
  Endif : # If I>=0
 Next : # [CPE1]CPE0
Endif : # If [M:DIA]REFNUM<>""
#
If [M:DIA]JOT<>""
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID
 [M:RCPC]DES([M:RCPC]NBRID-1) = [M:DIA]JOT-mess(49,10720,1) : # Compétences requises Emploi type
 Call LECTURE("JOT",[M:DIA]JOT,"") From CONTOBJ
 Gosub CHARGE_JOT
Endif
#
If [M:DIA]JOT2<>""
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID
 [M:RCPC]DES([M:RCPC]NBRID-1) = [M:DIA]JOT2-mess(49,10720,1) : # Compétences requises Emploi type"
 Call LECTURE("JOT",[M:DIA]JOT2,"") From CONTOBJ
 Gosub CHARGE_JOT
Endif
#
If [M:DIA]POT<>""
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID
 [M:RCPC]DES([M:RCPC]NBRID-1) = [M:DIA]POT-mess(50,10720,1) : # Compétences requises Poste"
 Call LECTURE("POT",[M:DIA]POT,"") From CONTOBJ
 Gosub CHARGE_POT
Endif
#
If [M:DIA]POT2<>""
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID
 [M:RCPC]DES([M:RCPC]NBRID-1) = [M:DIA]POT2-mess(50,10720,1) : # Compétences requises Poste"
 Call LECTURE("POT",[M:DIA]POT2,"") From CONTOBJ
 Gosub CHARGE_POT
Endif
##
# Average of competence
If [M:DIA]AVGCPC=2
 [M:RCPC]NBRID += 1
 nolign = [M:RCPC]NBRID
 [M:RCPC]DES([M:RCPC]NBRID-1) = mess(55,10720,1) : # Moyenne des compétences requises
# For L_IJ=0 To [M:DIA]NBRCPC
#   # JML 14/09/10 Ce tableau étant invisible, on oubli REQUIS
##  If [M:DIA]REQUIS(L_IJ)=2
#   L_NB = 0
#   Raz PDSMAT, PDSREF
#   Call LECTURE("CPC",[M:DIA]CPC(L_IJ),"") From CONTOBJ
#   Call LECTURE("SCA",[F:CPC]CODSCA,"") From CONTOBJ
#   I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1)) - 1
#   If I>=0
#    For L_JK=0 To dim([F:SCA]LEVREF)-1
#     If [F:SCA]LEVREF(L_JK)<>0
#      PDSREF = [F:SCA]LEVREF(L_JK)*1
#     Endif
#    Next L_JK
#    For [CPE1]CPE2 Where [CPE1]CPC=[M:DIA]CPC(L_IJ) & [CPE1]CPCDAT<>[0/0/0]
#     # Calcul de la pondération
#     J = find([F:CPE1]LEVCPC,[F:SCA]LEV)
#     If J
#      L_NB += 1
#      PDSMAT += [F:SCA]LEVREF(J-1)*1
#     Endif
#    Next : # [CPE1]CPE2
#    If L_NB>0
#     If evalue("dim([M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1))")>0
#      Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With ar2(PDSMAT/L_NB)
#      If PDSMAT
#       Assign "[M:RCPC]NIV"+num$(I+1)+"([M:RCPC]NBRID-1)"  With num$(ar2(PDSMAT/L_NB))+"/"+num$(PDSREF)
#      Endif
#     Endif : # If evalue
#    Endif : # If L_NB>0
#   Endif : # If I>=0
##  Endif
# Next L_IJ
 # JML 20/09/10 CG Calcul sur contrat
 Gosub AVG_CPC
Endif
Return
###################################################################################################################################
$CHARGE_JOT

 For L_IJ=0 To dim([F:JOT]CPC)-1
  If [F:JOT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:JOT]CPC(L_IJ),"") From CONTOBJ

    I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1)) - 1
    If I>=0
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     J = find([F:JOT]NIV(L_IJ),[F:HRSCA]LEV)
     If J=0
      PDSMAT = 0
      PDSREF = 0
     Else
      PDSMAT = [F:HRSCA]LEVREF(J-1)*[F:JOT]WEI(L_IJ)
      For L_JK=0 To dim([F:HRSCA]LEVREF)-1
       If [F:HRSCA]LEVREF(L_JK)<>0
       #SEGAY 25/11/10 bug 69399
  #      PDSREF = [F:HRSCA]LEVREF(L_JK)*[F:JOT]WEI(L_JK)
        PDSREF = [F:HRSCA]LEVREF(L_JK)*[F:JOT]WEI(L_IJ)
       Endif
      Next L_JK
     Endif
  # Test si le champ CRITx existe (Limite à 15 dans écran RECCPCLIS)
     If evalue("dim([M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1))")>0
     #SEGAY 25/11/10 bug 69399
  #    Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT
      PDSMATCOEF=0
      PCTMATCOEF=0
      If PDSREF > 0
        PDSMATCOEF=ar2((PDSMAT/PDSREF)*COEFPDSMAT)
        PCTMATCOEF=ar2((PDSMAT/PDSREF)*100)
      Endif
      Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PCTMATCOEF
      Assign "[M:RCPC]COEF"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMATCOEF
      Assign "[M:RCPC]WEI"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT

      If PDSMAT
       Assign "[M:RCPC]NIV"+num$(I+1)+"([M:RCPC]NBRID-1)"  With num$(PDSMAT)+"/"+num$(PDSREF)
      Endif
     Endif : # If evalue
    Endif : # If I>=0

Next L_IJ
Return
###################################################################################################################################
$CHARGE_POT
 For L_IJ=0 To dim([F:POT]CPC)-1
  If [F:POT]CPC(L_IJ)="" : Break : Endif
  Call LECTURE("CPC",[F:POT]CPC(L_IJ),"") From CONTOBJ
    I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1)) - 1
    If I>=0
     Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
     J = find([F:POT]NIV(L_IJ),[F:HRSCA]LEV)
     If J=0
      PDSMAT = 0
      PDSREF = 0
     Else
      PDSMAT = [F:HRSCA]LEVREF(J-1)*[F:POT]WEI(L_IJ)
      For L_JK=0 To dim([F:HRSCA]LEVREF)-1
       If [F:HRSCA]LEVREF(L_JK)<>0
        #SEGAY 25/11/10 bug 69399
  #      PDSREF = [F:SCA]LEVREF(L_JK)*[F:POT]WEI(L_JK)
        PDSREF = [F:HRSCA]LEVREF(L_JK)*[F:POT]WEI(L_IJ)
       Endif
      Next L_JK
     Endif

  # Test si le champ CRITx existe (Limite à 15 dans écran RECCPCLIS)
     If evalue("dim([M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1))")>0
      #SEGAY 25/11/10 bug 69399
  #    Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT
      PDSMATCOEF=0
      PCTMATCOEF=0
      If PDSREF > 0
        PDSMATCOEF=ar2((PDSMAT/PDSREF)*COEFPDSMAT)
        PCTMATCOEF=ar2((PDSMAT/PDSREF)*100)
      Endif
      Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PCTMATCOEF
      Assign "[M:RCPC]COEF"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMATCOEF
      Assign "[M:RCPC]WEI"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMAT

      If PDSMAT
       Assign "[M:RCPC]NIV"+num$(I+1)+"([M:RCPC]NBRID-1)"  With num$(PDSMAT)+"/"+num$(PDSREF)
      Endif
     Endif : # If evalue
    Endif : # If I>=0
 Next L_IJ
Return
###################################################################################################################################
# JML 28/07/10 LOT P02 New method, with a link and a filter, always based on CTR
$AVG_CPC
Local Integer OKCPC
If GTEST
 Call OUVRE_TRACE("RECCPC : $AVG_CPC") From LECFIC
Endif
OK = 0
For L_IJ=0 To [M:DIA]NBRCPC - 1
  L_NB = 0
  Raz PDSMAT, PDSREF
  Call LECTURE("CPC",[M:DIA]CPC(L_IJ),"") From CONTOBJ
  Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ
  I = find([F:CPC]COD,[M:DIA]CPC(0..[M:DIA]NBRCPC-1)) - 1
  If I>=0
   For L_JK=0 To dim([F:HRSCA]LEVREF)-1
    If [F:HRSCA]LEVREF(L_JK)<>0
     PDSREF = [F:HRSCA]LEVREF(L_JK)*1
    Endif
   Next L_JK
  # FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
  # exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
#   For [LECT]ECT0 Where evalue(L_CRITERE)
   For [LECT]ECT0
    For [CPE1]CPE2 Where [CPE1]CPC=[M:DIA]CPC(L_IJ) & [CPE1]CPCDAT<>[0/0/0] & [CPE1]REFNUM=[F:HRCTR]REFNUM
     # FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
     # exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
     Filter [F:EPO] Where [EPO]REFNUM=[F:HRCTR]REFNUM & [EPO]CTRNUM=[F:HRCTR]CTRNUM Order By DATPOT
     Read [F:EPO] Last
     Filter [F:EPO]
     OKCPC=2
     If [M:DIA]JOT<>""
      If [F:EPO]JOBPOT<>"" & [F:EPO]JOBPOT<>[M:DIA]JOT Then OKCPC=1
      Elsif [F:HRCTR]JOBPOT<>[M:DIA]JOT Then OKCPC=1 : Endif
     Endif
     If [M:DIA]POT<>""
      If [F:EPO]POT<>"" & [F:EPO]POT<>[M:DIA]POT Then OKCPC=1
      Elsif [F:HRCTR]POT<>[M:DIA]POT Then OKCPC=1 : Endif
     Endif
     # Fin MABON
     # Calcul de la pondération
     J = find([F:CPE1]LEVCPC,[F:HRSCA]LEV)
#     If J
     If OKCPC=2 & J
      L_NB += 1
      PDSMAT += [F:HRSCA]LEVREF(J-1)*1
      If GTRACE<>""
       Call ECR_TRACE("CPC="+[F:CPE1]CPC-"CPCDAT="+format$("DD2",[F:CPE1]CPCDAT)
&                    -"REFNUM="+[F:CPE1]REFNUM-"CTRNUM="+[F:HRCTR]CTRNUM
&                    -"LEVCPC="+[F:CPE1]LEVCPC-"LEVREF="+num$([F:HRSCA]LEVREF(J-1)*1), 0) From GESECRAN
      Endif
     Else
      If GTRACE<>""
       Call ECR_TRACE("CPC="+[F:CPE1]CPC-"CPCDAT="+format$("DD2",[F:CPE1]CPCDAT)
&                    -"REFNUM="+[F:CPE1]REFNUM-"CTRNUM="+[F:HRCTR]CTRNUM
&                    -"LEVCPC="+[F:CPE1]LEVCPC-"LEVREF=Non défini", 0) From GESECRAN
      Endif
     Endif
    Next : # [CPE1]CPE2
   Next : # [LECT]ECT0

   If L_NB>0
# Test si le champ CRITx existe (Limite à 15 dans écran RECCPCLIS)
    If evalue("dim([M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1))")>0
     #SEGAY 25/11/10 bug 69399
#     Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With ar2(PDSMAT/L_NB)
     PDSMATCOEF=0
     PCTMATCOEF=0
     If PDSREF > 0
      PDSMATCOEF=ar2(((PDSMAT/L_NB)/PDSREF)*COEFPDSMAT)
      PCTMATCOEF=ar2(((PDSMAT/L_NB)/PDSREF)*100)
     Endif
     Assign "[M:RCPC]CRIT"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PCTMATCOEF
     Assign "[M:RCPC]COEF"+num$(I+1)+"([M:RCPC]NBRID-1)"  With PDSMATCOEF
     Assign "[M:RCPC]WEI"+num$(I+1)+"([M:RCPC]NBRID-1)"  With ar2(PDSMAT/L_NB)

     If PDSMAT
      Assign "[M:RCPC]NIV"+num$(I+1)+"([M:RCPC]NBRID-1)"  With num$(ar2(PDSMAT/L_NB))+"/"+num$(PDSREF)
     Endif
    Endif : # If evalue
   Endif : # If L_NB>0
  Endif : # If I>=0

Next L_IJ
If GTEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
Return
###################################################################################################################################

$CONTROLE
If GSTATUT=GSTAOK
 TMP = 1
Else
 FIN = 1
Endif
Return

#MABOS-FQ81085-US1833 - manage mémo
$AVANT_BOUTON
  Case BOITE
    When "DRECCPC"
     Case BOUT
       When "M" : # Button "Mémo"
         Gosub BOUTON_OK
     Endcase
  Endcase
Return
#end MABOS-FQ81085-US1833 - manage mémo

$BOUTON
If BOUT="O" : # Bouton Critères
 FIN = 1
Endif
Case BOITE
  When "DRECCPC"
    If BOUT="R"
     # Rappel Mémo
     Call AFF_MEMO2(1) From DIVPAYE : #MABOS:06/08/13-afectation de GCURLEG
     Gosub GRISE
    Endif
Endcase
Return

$TERMINE
If GSTATUT=7 : # Bouton Fin
 FIN = 1 : Return
Endif
If GSTATUT=1801 : # Bouton critères
 SAI = 1
Endif
Return

$BOUTON_OK
If [M:DIA]REFNUM="" & [M:DIA]JOT="" & [M:DIA]POT=""
 GERR = 1 : GMESSAGE = mess(52,10720,1) : # Il faut saisir au moins un élément"
 FIN = 0
Elsif [M:DIA]REFNUM<>"" & !([M:DIA]JOT<>"" | [M:DIA]POT<>"" | [M:DIA]JOT2<>"" | [M:DIA]POT2<>"")
 GERR = 1 : GMESSAGE = mess(53,10720,1) : # Il faut saisir au moins un poste ou un emploi"
 FIN = 0
Elsif [M:DIA]REFNUM="" & !(([M:DIA]JOT<>""  & [M:DIA]JOT2<>"") | ([M:DIA]POT<>"" & [M:DIA]POT2<>""))
 GERR = 1 : GMESSAGE = mess(54,10720,1) : # Il faut saisir au moins un poste/poste2 ou un emploi/emploi2"
 FIN = 0
Endif
Return

#**
#* Récupére l'échelle en paramètre de l'écran RECCPCLIS
#* SEGAY 25/11/10 bug 69399
#*!
Funprog CALCSCALE()
Local Integer NBSCALE, IND1, IND2
Local Char WSCALE
If clalev([F:AMK]) = 0 : Local File AMSK     [AMK] : Endif
Raz WSCALE
Read [AMK]CODMSK="RECCPCLIS"
If !fstat
  IND1 = instr(1,[F:AMK]BLOCACT1(0),"?")
  If IND1
     IND2 = instr(IND1+1,[F:AMK]BLOCACT1(0),"?")
     If IND2 & IND1+1 <= IND2-1
       WSCALE = seg$([F:AMK]BLOCACT1(0),IND1+1,IND2-1)
     Endif
  Endif
Endif
If WSCALE <> ""
  NBSCALE = val(WSCALE)
Else
  NBSCALE = 5
Endif
End NBSCALE

