 #MABOS-FQ81085-US1436
Subprog C_JOT2(VALEUR)
Variable Char    VALEUR()
Call NOT_SAME(VALEUR ,[M:DIA]JOT)
End

Subprog C_POT2(VALEUR)
Variable Char    VALEUR()
Call NOT_SAME(VALEUR ,[M:DIA]POT)
End

Subprog NOT_SAME(VAL1,VAL2)
Value Char VAL1, VAL2
If [L]VAL2<>"" & [L]VAL2 = [L]VAL1 Then
 GERR=1
 GMESSAGE = mess(126,10720,1)- [L]VAL2 : # 'Attention, vous avez déjà sélectionné ce code
 mkstat=2 : End
Endif
End

Subprog AFF(WREFNUM, WPOT, WJOT, WPOT2, WJOT2)
Value Char WREFNUM, WPOT, WJOT, WPOT2, WJOT2

If [L]WPOT <> "" : Effzo  [M:DIA]JOT,ZJOT, JOT2,ZJOT2 : Grizo [M:DIA]JOT, JOT2
Else Actzo [M:DIA]JOT : Effzo  [M:DIA]ZPOT, POT2,ZPOT2 : Grizo [M:DIA]POT2  :Endif

If [L]WJOT <> "" : Effzo  [M:DIA]POT,ZPOT, POT2,ZPOT2 : Grizo [M:DIA]POT, POT2
Else Actzo [M:DIA]POT : Effzo  [M:DIA]ZJOT, JOT2,ZJOT2 : Grizo [M:DIA] JOT2  :Endif

If [L]WREFNUM <>""
  Effzo  [M:DIA]JOT2,ZPOT2, POT2,ZJOT2 : Grizo [M:DIA]JOT2, POT2
Else
  If [L]WPOT <> "" : Actzo  [M:DIA]POT2 : Endif
  If [L]WJOT <> "" : Actzo  [M:DIA]JOT2  :Endif
Endif
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(WREFNUM,"[M:DIA]","NAM","SRN",0,0) From DIVPAYE
Affzo [M:DIA]
End

# end  MABOS-FQ81085-US1436
