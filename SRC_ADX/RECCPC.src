   When 13: Chgfmt [M:RCPC]CRIT14 With "-Nz+:4.2#" : Chgfmt [M:RCPC]CRIT15 With "-Nz+:4.2#"

            Chgfmt [M:RCPC]COEF14 With "-Nz+:4.2#" : Chgfmt [M:RCPC]COEF15 With "-Nz+:4.2#"

            Chgfmt [M:RCPC]WEI14 With "-N:4#" : Chgfmt [M:RCPC]WEI15 With "-N:4#"

            Chgfmt [M:RCPC]NIV14 With "-N:4#"  : Chgfmt [M:RCPC]NIV15 With "-N:4#"
   When 14: Chgfmt [M:RCPC]CRIT15 With "-Nz+:4.2#"

            Chgfmt [M:RCPC]COEF15 With "-Nz+:4.2#"

            Chgfmt [M:RCPC]WEI15 With "-N:4#"

            Chgfmt [M:RCPC]NIV15 With "-N:4#"
  Endcase
  Affzo [M:RCPC]
  If [M:RCPC]NBRID>0
   REPORT1="PRTSCR"
  Endif
Endcase
Return

