#ADNGO - 2017-03-15 - X3-29328 - START
Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()

If !func ALLUTI() and !(VALEUR ="" or VALEUR=GREFNUM)
  Local Integer NIVREQ(0..20)
  # on factorise pour être cohérent dans divpaye
  Call GET_NIVREQ_RECCPC(NIVREQ)

  If(find(0,NIVREQ)=1) : End : Endif

  If ! func DIVPAYE.ISCHEF(GREFNUM,NIVREQ,VALEUR,"",[0/0/0],"1234")
    GMESSAGE=  VALEUR-":"-mess(31,10702,1)
    mkstat=2
  Endif
Endif
End
#ADNGO - 2017-03-15 - X3-29328 - END

#ADNGO - 2017-03-15 - X3-29328 - START
Subprog GET_NIVREQ_RECCPC(NIVREQ)
Variable Integer NIVREQ()
Local Char FLUX(20)

If( !func ALLUTI())
  [L]FLUX=func DIVPAYE.GET_FLUX(func GET_NAMFLUX(),1)
  Call GET_NIVREQ(FLUX,NIVREQ) From DIVPAYE
Endif
End
#ADNGO - 2017-03-15 - X3-29328 - END

