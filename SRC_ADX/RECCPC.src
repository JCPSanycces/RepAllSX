            Chgfmt [M:RCPC]COEF14 With "-Nz+:4.2#" : Chgfmt [M:RCPC]COEF15 With "-Nz+:4.2#"

            Chgfmt [M:RCPC]WEI2 With "-N:4#"  : Chgfmt [M:RCPC]WEI3 With "-N:4#"
            Chgfmt [M:RCPC]WEI4 With "-N:4#"  : Chgfmt [M:RCPC]WEI5 With "-N:4#"
