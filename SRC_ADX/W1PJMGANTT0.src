#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMGANTT0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:48"
A_USER  = "DOC"
A_STAMP = "20181109230548"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMGANTT0 [PGANT0]
Gosub HORODAT
Local Inpbox "PJMGANTT0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PGANT0] As [SIM_]
Grizo [PGANT0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PGANT0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_EVRLEV
Onevent INIT_AREA Call D_EVRLEV(zc) From W1PJMGANTT0
Onevent BEFORE_INPUT Call AS_EVRLEV(zc) From W1PJMGANTT0
Return

Subprog D_EVRLEV(VALEUR)
Variable Integer VALEUR
If varinit([M]EVRLEV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EVRLEV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

