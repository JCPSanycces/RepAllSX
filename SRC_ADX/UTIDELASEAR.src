#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Clear ASEAR module
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Clear module Exalead") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJ
Local Char WMAC(250),FICHIER(250),TRTFILE(250)
Local Integer STAT

WMAC=adxmac(0)
ORDSYS="" + WMAC +'@lsadx -a'-DOSSIER-'TRT src'+""

For TRTFILE = "ATRTASRCAL","ATRTASRGEN","ATRTASRIND","ATRTASRLEC","ATRTASRMAJ","ATRTASRSUB","ATRTASRVAL","SUBASR"
  Call EFFACE_ADX(WMAC,DOSSIER,TRTFILE,STAT) From ORDSYS
  FICHIER = filpath("TRT",TRTFILE,"src",DOSSIER,"",WMAC)
  Call EFFACE(FICHIER,STAT) From ORDSYS
Next

Return
