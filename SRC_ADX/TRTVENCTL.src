###################################################################################
#      TRAITEMENTS de CONTROLE dans les VENTES                                    #
###################################################################################

###################################################################################
#---------------------------------------------------------------------------------#
# Traitements e_commerce                                                          #
#---------------------------------------------------------------------------------#
# Actions traitements divers                                                      #
#---------------------------------------------------------------------------------#
# CTLITV    : Ctrl existence article-client / article-vente                       #
# CTLVAT    : Ctrl existence d'un code taxe sur le niveau correspondant           #
#---------------------------------------------------------------------------------#
# Actions affichages divers                                                       #
#---------------------------------------------------------------------------------#
# CTLITF    : Contrôle existence article-site                                     #
# CTLLEGCPY : Contrôle société juridique entre 2 sites                            #
# CTLNUM    : Contrôle sur le n° document                                         #
# CTLSALFCY : Contrôle sur le site de vente                                       #
# CTLSTOFCY : Contrôle sur le site expédition                                     #
# CTLSAU    : Contrôle sur l'unité de vente                                       #
# CTLUVYBPD : Contrôle des jours et periode indispo d'un client livré             #
# CTLUVYFCY : Contrôle des jours et periode indispo d'un site                     #
# CTLDATORD : Contrôle d'une date par rapport a la date de commande               #
# CTLGFYLEG : Controle cohérence entre un groupe de site/soc est une législation  #
# CTLGFYGRP : Contrôle cohérence entre groupes : au moins un société en commun    #
# CTL_ML_CONSISTENCY : Contrôle de cohérence pour objets déclinés multi-lég       #
###################################################################################
Subprog CTLITV (LITM,LBPC)
Variable Char  LITM
Value    Char  LBPC

# Issue X3-48042 - 2017-10-10 by CPO : Dysfonctionnement saisie article non renouvelé en gestion commande de vente
#If LITM="" & (instr(1,dbgstr(1),"SRH1")|instr(1,dbgstr(1),"SRL1")) End Endif
If LITM="" : End : Endif
# End issue X3-48042

If clalev ([F:ITS]) <= 0 Local File ITMSALES [ITS] : Endif
If clalev ([F:ITU]) <= 0 Local File ITMBPC   [ITU] : Endif

Read [ITU]ITU1 = LBPC;LITM
If !fstat
   LITM=[F:ITU]ITMREF
Else
   LITM=toupper(LITM)
Endif
Local Shortint STAT
If !GIMPORT   : # Bug 75300 : Action interactive à ne pas executer en import
  Call CONTSEL("ITS","",LITM,"",STAT) From CONTOBJ
Endif

Read [ITS]ITS0 = LITM
If fstat mkstat=2 : GMESSAGE=mess(5,192,1) Endif

End

#########################################################################
$ACTION
#--- Actions liés au type affichage divers
Case ACTION
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return
#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$TRT_DIV
Case TRAIT
    When "CTLITF"      : Gosub C_ITF
    When "CTLLEGCPY"   : Gosub C_LEGCPY
    When "CTLNUM"      : Gosub C_NUM
    When "CTLSALFCY"   : Gosub C_SALFCY
    When "CTLSTOFCY"   : Gosub C_STOFCY
    When "CTLSAU"      : Gosub C_SAU
    When "CTLUVYBPD"   : Gosub C_UVYBPD
    When "CTLUVYFCY"   : Gosub C_UVYFCY
    When "CTLDATORD"   : Gosub C_DATDATORD
Endcase
Return
########################################################################
#    C_ITF                                                             #
########################################################################
$C_ITF

Local Char    WART         :    WART=PARAM(1)
Local Char    WSITE        :    WSITE = PARAM(2)
Local Integer WSTOMGTCOD   :    WSTOMGTCOD=val(PARAM(3))

If clalev ([F:ITM]) <= 0 Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF <> WART
    Read [ITM]ITM0 = WART
    If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]STOMGTCOD <> 1
   If clalev ([F:ITF]) <= 0 Local File ITMFACILIT [ITF] : Endif
   Read [ITF]ITF0 = WART;WSITE
   If fstat mkstat = 2 : GMESSAGE = mess(25,192,1) : Endif
Endif
Return

########################################################################
#    C_LEGCPY                                                          #
#            Vérification de la société juridique entre 2 sites        #
########################################################################
$C_LEGCPY
Local    Char    WFCY1    :    WFCY1=VALEUR
Local    Char    WFCY2    :    WFCY2=PARAM(1)
Local    Char    WLEGCPY
# Contrôle que FCY2 est bien sur la même société juridique que FCY1
If WFCY2<>"" & WFCY2 <> WFCY1
    If [F:FCY]FCY <> WFCY1
        Read [FCY]FCY0=WFCY1
        If fstat Raz [FCY] Endif
    Endif
#   Nouvelle société juridique
    WLEGCPY=[F:FCY]LEGCPY
    Read [FCY]FCY0=WFCY2
    If fstat Raz [FCY] Endif
    If [F:FCY]LEGCPY <> WLEGCPY
        Raz WFCY2
    Endif
Endif
PARAM(2)=WFCY2
Return
########################################################################
#    C_NUM                                                             #
#       PARAM(1) = WCLE : Clé primaire de l'objet à controler          #
#       PARAM(2) = WABR : Abréviation de l'objet                       #
########################################################################
$C_NUM
Local Char WCLE      :    WCLE   = PARAM(1)
Local Char WABR      :    WABR   = PARAM(2)
#If GREP = "C" & GMANCOU = 2 & VALEUR = ""
# On accepte un numero non renseigné pour les imports
#    If !GIMPORT mkstat = 2 Endif
If GREP <> "C" & GREP <> "D"
    Default File "[F:"+WABR+"]"
    # On est pas passé par Fichier Nouveau
    If evalue ("[M]"+WCLE) <> ""
        Assign "[F]"+WCLE With evalue ("[M]"+ WCLE )
        Look [F] =
        If fstat
           Assign "[F]"+WCLE With VALEUR
           Look [F] =
        Endif
    Else
        Assign "[F]"+WCLE With VALEUR
        Look [F] =
    Endif
    # Il n'y avait pas d'enreg.en ligne et la clé saisie n'existe pas --> Création interdite
    If fstat GMESSAGE=mess(178,199,1) : mkstat=2 : Endif
Endif

Return
########################################################################
#    C_SALFCY                                                          #
########################################################################
$C_SALFCY

If [F:FCY]LEGCPY <> GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=2 : Endif

Return
########################################################################
#    C_STOFCY                                                          #
########################################################################
$C_STOFCY

If [F:FCY]LEGCPY <> GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=2 : Endif

Return
########################################################################
#    C_SAU                                                             #
#       PARAM(1) = ART    : Référence article                          #
#       PARAM(2) = CLI    : Numéro de client                           #
########################################################################
$C_SAU

Local Char    ART    :    ART = PARAM(1)
Local Char    CLI    :    CLI = PARAM(2)
Local Char    UNIVEN

Local    Integer I,J

Gosub CHARGSAU

For I = 0 To J-1
   If VALEUR = vireblc(left$(LUV(I),GLONUOM),1)
      UNIVEN = VALEUR
   Endif
Next I

If UNIVEN = ""
   GMESSAGE = mess(9,192,1) : mkstat=2
Endif

Return
########################################################################
#    C_UVYBPD                                                          #
########################################################################
$C_UVYBPD

Local Char    WORIBPD : WORIBPD=PARAM(1)
Local Char    WORIBPC : WORIBPC=PARAM(2)
Local Integer WSENS   : WSENS=val(PARAM(3))

Local    Integer  UVYDAY (0..6)

Local    Integer  I
If clalev ([F:BPD]) <= 0 Local File BPDLVCUST [BPD] : Endif
If [F:BPD]BPCNUM <> WORIBPC | [F:BPD]BPAADD <> WORIBPD
    Read [BPD]BPD0 = WORIBPC;WORIBPD
    If fstat Return : Endif
Endif
For I=0 To 6
    UVYDAY(I) = evalue ("[F:BPD]UVYDAY"+num$(I+1))
Next
Call CTL_JOU (VALEUR, UVYDAY, [F:BPD]UVYCOD, WSENS) From CONTX3
Return
########################################################################
#    C_UVYFCY                                                          #
########################################################################
$C_UVYFCY

Local Char    WORIFCY : WORIFCY=PARAM(1)
Local Integer WSENS   : WSENS = val(PARAM(2))

If clalev ([F:FCY]) <= 0 Local File FACILITY [FCY] : Endif
If [F:FCY]FCY <> WORIFCY
    Read [FCY]FCY0 = WORIFCY
    If fstat Return : Endif
Endif
Call CTL_JOU (VALEUR, [F:FCY]UVYDAY, [F:FCY]UVYCOD, WSENS) From CONTX3

Return
########################################################################
#    C_DATDATORD                                                       #
########################################################################
$C_DATDATORD
Local Date WDAT      :    WDAT = VALEUR
Local Date WORDDAT   :    WORDDAT = PARAM(1)

If WDAT <  WORDDAT GMESSAGE=format$(GFMDAT4,WDAT)-":"-mess(349,192,1): mkstat=2 : Endif

Return
#########################################################################
## Obsolète en V6                                                       #
#########################################################################
##    C_VACITM                                                          #
#########################################################################
#$C_VACITM

#Local Char    WVACITM : WVACITM=VALEUR
