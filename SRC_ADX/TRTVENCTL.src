#########################################################################
#-----------------------------------------------------------------------#
# Traitements non e_commerce                                            #
#-----------------------------------------------------------------------#
#                                                                       #
#      TRAITEMENTS de CONTROLE dans les VENTES                          #
#                                                                       #
#########################################################################
#                                                                       #
# Subprog CTLUVYFCY(DAT, ORIFCY, SENS)                                  #
#      Controle des jours et periode indispo d'un site                  #
#                                                                       #
# Subprog CTLUVYBPD(DAT, ORIBPD, ORIBPC, SENS)                          #
#      Controle des jours et periode indispo d'un client livre          #
#                                                                       #
# Subprog CTLSBSITM(ITMREF, DAT, RET)                                   #
#      Contrôle de l'article de substitution                            #
#                                                                       #
# Subprog CONTSALFCY(VALEUR)                                            #
#      Controle du site de vente                                        #
#                                                                       #
# Subprog CONTITF(ITMREF, STOFCY, STOMGTCOD)                            #
#      Contrôle existence article-site si un article est géré en stock  #
#                                                                       #
# Subprog CTLACC(CODACC)                                                #
#      Contrôle d'un code accés sur zone (Accés interdit si mkstat=2)   #
#                                                                       #
#                                                                       #
#########################################################################

#------------------------------
# Contrôle de l'unité de vente
#------------------------------
# Entrée  ART      : Article
#         CLI      : Client
# Sortie  UNIVEN   : Unité de vente
#---
Subprog CONTSAUIMP(VALEUR, ART,CLI,UNIVEN)
Value    Char    VALEUR
Value    Char    ART
Value    Char    CLI
Variable Char    UNIVEN

Local    Integer I,J

Gosub CHARGSAU

For I = 0 To J-1
   If VALEUR = vireblc(left$(LUV(I),GLONUOM),1)
      UNIVEN    = VALEUR
   Endif
Next I
End

# Cette étiquette a été traité en  e_commerce
$CHARGSAU

Local Integer K, WDIM
WDIM = dim([F:ITM]PCU)+5
Local Char    UV(GLONUOM)(WDIM+3)
Local Char    DUV(30)(WDIM+3)
Local Char    LUV(48)(WDIM+3)
Local Char    WTEXTE(80)

UNIVEN = ""
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM] : Endif
If clalev([F:ITU]) = 0 Local File ITMBPC [ITU]    : Endif
If clalev([F:TUN]) = 0 Local File TABUNIT [TUN]   : Endif
If clalev([F:AXX]) = 0 Local File ATEXTRA [AXX]   : Endif

If [F:ITM]ITMREF <> ART
   Read [ITM] ITM0=ART
   If fstat Raz [F:ITM]: Endif
Endif

UV(0) = [F:ITM]SAU
UV(4) = [F:ITM]STU
For K=5 To WDIM-1
   UV(K) = [F:ITM]PCU(K-5)
Next K

# Si article de type main d'oeuvre
If [F:ITM]HDKITMTYP=3
   If [F:ITM]DAYUOM<>"" UV(WDIM)  =[F:ITM]DAYUOM Endif
   If [F:ITM]HOUUOM<>"" UV(WDIM+1)=[F:ITM]HOUUOM Endif
   If [F:ITM]MNTUOM<>"" UV(WDIM+2)=[F:ITM]MNTUOM Endif
Endif
#-----------------------------------

If UV(0) <> ""
   If [F:TUN]UOM <> UV(0)
      Read [TUN] TUN0=UV(0)
      If fstat Raz [F:TUN] : Endif
   Endif
   Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
   DUV(0) = [L]WTEXTE
Endif
If UV(4) <> ""
   If [F:TUN]UOM <> UV(4)
      Read [TUN] TUN0=UV(4)
      If fstat Raz [F:TUN] : Endif
   Endif
   Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
   DUV(4) = [L]WTEXTE
Endif

For K=5 To WDIM-1
   If UV(K)<>""
      If [F:TUN]UOM<>UV(K)
         Read [TUN] TUN0=UV(K)
         If fstat Raz [F:TUN] : Endif
      Endif
      Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
      DUV(K) = [L]WTEXTE
   Endif
Next K

# Si article de type main d'oeuvre
If UV(WDIM) <> ""
   If [F:TUN]UOM <> UV(WDIM)
      Read [TUN] TUN0=UV(WDIM)
      If fstat Raz [F:TUN] : Endif
   Endif
   Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
   DUV(WDIM) = [L]WTEXTE
Endif
If UV(WDIM+1) <> ""
   If [F:TUN]UOM <> UV(WDIM+1)
      Read [TUN] TUN0=UV(WDIM+1)
      If fstat Raz [F:TUN] : Endif
   Endif
   Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
   DUV(WDIM+1) = [L]WTEXTE
Endif
If UV(WDIM+2) <> ""
   If [F:TUN]UOM <> UV(WDIM+2)
      Read [TUN] TUN0=UV(WDIM+2)
      If fstat Raz [F:TUN] : Endif
   Endif
   Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
   DUV(WDIM+2) = [L]WTEXTE
Endif
#-----------------------------------

If CLI <> ""
   If [F:ITU]ITMREF <> ART | [F:ITU]BPCNUM <> CLI
      Read [ITU] ITU0=ART;CLI
      If fstat Raz [F:ITU] Endif
   Endif
   UV(1)  = [F:ITU]SAU
   UV(2)  = [F:ITU]PCU1
   UV(3)  = [F:ITU]PCU2
   If UV(1) <> ""
      If [F:TUN]UOM <> UV(1)
         Read [TUN] TUN0=UV(1)
         If fstat Raz [F:TUN] : Endif
      Endif
      Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
      DUV(1) = [L]WTEXTE
   Endif
   If UV(2) <> ""
      If [F:TUN]UOM <> UV(2)
         Read [TUN] TUN0=UV(2)
         If fstat Raz [F:TUN] : Endif
      Endif
      Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
      DUV(2) = [L]WTEXTE
   Endif
   If UV(3) <> ""
      If [F:TUN]UOM <> UV(3)
         Read [TUN] TUN0=UV(3)
         If fstat Raz [F:TUN] : Endif
      Endif
      Call GET_ATEXTRA ("TABUNIT","DES",GLANGUE,[L]WTEXTE) From TRTX3TEX
      DUV(3) = [L]WTEXTE
   Endif
Endif

#Sorta UV
J=0
For I=0 To WDIM+2
   If UV(I)<>""
      If I=0
         LUV(I)  = format$("K:"+num$(GLONUOM)+"X",UV(I))+"  "+format$("K:20X",DUV(I))
         J += 1
      Elsif !find(UV(I),UV(0..I-1))
         LUV(J) = format$("K:"+num$(GLONUOM)+"X",UV(I))+"  "+format$("K:20X",DUV(I))
         J += 1
      Endif
   Endif
Next I
Return

#----------------------------------------------------------------#
# Controle des jours et periode indispo d'un site                #
#----------------------------------------------------------------#
# Entrée  DAT      : Date origine                                #
#         ORIFCY   : Site                                        #
#         SENS     : Sens décalage si jours indisponibilité      #
#----------------------------------------------------------------#
Subprog CTLUVYFCY(CTLDAT, ORIFCY, SENS)

Variable Date    CTLDAT
Value    Char    ORIFCY
Value    Integer SENS

Call LECTURE ("FCY", ORIFCY, "") From CONTOBJ
If fstat:End:Endif
Call CTL_JOU (CTLDAT, [F:FCY]UVYDAY, [F:FCY]UVYCOD, SENS) From CONTX3

End

#----------------------------------------------------------------#
# Controle des jours et periode indispo d'un client livre        #
#----------------------------------------------------------------#
# Entrée  DAT      : Date origine                                #
#         ORIBPD   : Adresse de livraison                        #
#         ORIBPC   : Client                                      #
#         SENS     : Sens décalage si jours indisponibilité      #
#----------------------------------------------------------------#
Subprog CTLUVYBPD(CTLDAT, ORIBPD, ORIBPC, SENS)
Variable Date    CTLDAT
Value    Char    ORIBPD, ORIBPC
Value    Integer SENS

Local    Integer  UVYDAY (0..6)
Local    Integer  I

Call LECTURE ("BPD", ORIBPD, ORIBPC) From CONTOBJ
If fstat:End:Endif
For I=0 To 6
    UVYDAY(I) = evalue ("[F:BPD]UVYDAY"+num$(I+1))
Next
Call CTL_JOU (CTLDAT, UVYDAY, [F:BPD]UVYCOD, SENS) From CONTX3

End

#----------------------------------------------------------------#
# Contrôle de l'article de substitution                          #
#----------------------------------------------------------------#
# Entrée  WITMREF  : Article                                     #
#         DAT      : Date de référence                           #
# Sortie  RET      : Code retour                                 #
#----------------------------------------------------------------#
# Prérequis : Le fichier ITS doit être ouvert                    #
#             Le buffet [ITS] doit être chargé                   #
#----------------------------------------------------------------#
Subprog CTLSBSITM(WITMREF, DAT, RET)
Value    Char     WITMREF
Value    Date     DAT
Variable Integer  RET
# Si RET = 0 --> pas de substitution
# Si RET = 1 --> substitution mais pb en lecture article de substitution
# Si RET = 2 --> substitution OK
Raz RET
If DAT >= [F:ITS]SBSDAT & [F:ITS]SBSITM <> ""
   Read [ITS]ITS0 = [F:ITS]SBSITM
   If fstat <> 0 : RET=1 : Read [ITS]ITS0=WITMREF : End : Endif
   RET = 2
   #---------------------------------------------------------------------#
   # Point d'entree contrôle article de substitution                     #
   #---------------------------------------------------------------------#
   GPOINT="CTLSBSITM" : Gosub ENTREE From EXEFNC
Endif
End

#----------------------------------------------------------------------#
# CONTSALFCY : Controle site de vente sur société du site de réception #
#----------------------------------------------------------------------#
Subprog CONTSALFCY(VALEUR)
Variable Char     VALEUR

#Call CONTROLE ("FCY","F",VALEUR,"",mkstat) From CONTOBJ
#If mkstat End Endif
If [F:FCY]LEGCPY <> GSOCIETE : GMESSAGE=mess(2,194,1) : mkstat=2 : End
Endif
End

#------------------------------------------------------------------#
# Contrôle existence article-site si un article est géré en stock  #
#------------------------------------------------------------------#
# Entrée   ART       : Référence article                           #
#          SITE      : Site de stockage                            #
#          STOMGTCOD : Article géré en stock                       #
#------------------------------------------------------------------#
Subprog CONTITF(ART, SITE, STOMGTCOD)
Value    Char    ART
Value    Char    SITE
Value    Integer STOMGTCOD

If STOMGTCOD <> 1
   If clalev ([F:ITF]) <= 0 Local File ITMFACILIT [ITF] :Endif
   If [F:ITF]ITMREF <> ART | [F:ITF]STOFCY <> SITE
       Read [ITF]ITF0 = ART;SITE
       If fstat mkstat = 2 : GMESSAGE = ART-mess(25,192,1)-SITE : Endif
   Endif
Endif

End

#------------------------------------------------------------------#
# Controle d'un code accés utilisateur (Accés interdit si mkstat=2)#
#------------------------------------------------------------------#
Subprog CTLACC (CACC)
Value    Char    CACC
mkstat=2
If clalev ([F:ACC])<=0 Local File ACCES   [ACC] : Endif
If clalev ([F:AUS])<=0 Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = GUSER
If fstat=0 & [F:AUS]ALLACS=2
   mkstat=0 : End
Endif
Read [ACC]CODACC = GUSER;CACC
If fstat = 0
   Case CACC
    When "/SPRIMOD","/SCDTUNL" : If [F:ACC]MODIF=2 mkstat=0 Endif
    When "/SDACLOK","/SAUZRET" : If [F:ACC]EXEC=2  mkstat=0 Endif
    When Default
   Endcase
Endif
End

