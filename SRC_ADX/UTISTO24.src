#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTISTO24   Initializing parameter ACCCSTADJ                            #
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Initialization of ACCCSTADJ parameter") From LECFIC
    Call MAJ_UTISTO24(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

########################################################################
# For automatic execution when applying a patch                        #
########################################################################
Subprog MAJ_UTISTO24(DOSSIER)
Value Char DOSSIER

 Call ECR_TRACE("UTISTO24: Process Start on : "+DOSSIER,0) From GESECRAN

  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL" [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"ACCCSTADJ"
  If fstat
    Raz [F:ADW]
    [F:ADW]PARAM = "ACCCSTADJ"
    [F:ADW]CREDAT = date$
    [F:ADW]CREUSR = GUSER
    [F:ADW]VALEUR = "STKUV"
    Write [F:ADW]
    If fstat
      Call ECR_TRACE("ACCCSTADJ can't be initialized",1) From GESECRAN
    Endif
  Endif
  Commit

  Close Local File [ADW]
  Call ECR_TRACE("UTISTO24 : finish",0) From GESECRAN

End
########################################################################
# For automatic execution when applying a patch                        #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTISTO24(APPLI)

End

########################################################################
# For execution in dosmaj (Folder validation)                          #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTISTO24(APPLI)
End




