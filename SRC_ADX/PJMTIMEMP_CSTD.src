#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMTIMEMP
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                From PJMTIMEMP_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE  From PJMTIMEMP_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE  From PJMTIMEMP_CSTD_EVENTS
        #When "AINSERT_AFTER"          : Gosub AINSERT_AFTER           From PJMTIMEMP_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR : Move at PJMTIMEMPH level
        #When "AUPDATE_AFTER"          : Gosub AUPDATE_AFTER           From PJMTIMEMP_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR : Move at PJMTIMEMPH level
        #When "ADELETE_AFTER"          : Gosub ADELETE_AFTER           From PJMTIMEMP_CSTD_EVENTS   # Issue X3-111733 - 2018-10-08 by FGR : Move at PJMTIMEMPH level
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                     From PJMTIMEMP_CSTD_METHODS # Issue X3-62154 - 2017-11-06 by TEJAC
    #
    When "GET_PJMPCC"                  : Gosub GET_PJMPCC                   From PJMTIMEMP_CSTD_METHODS
    When "_GET_PJMPCC_OPER"            : Gosub _GET_PJMPCC_OPER             From PJMTIMEMP_CSTD_METHODS
    When "_GET_PJMPCC_TASK"            : Gosub _GET_PJMPCC_TASK             From PJMTIMEMP_CSTD_METHODS
    When "_GET_PJMPCC_EMPLOYEE"        : Gosub _GET_PJMPCC_EMPLOYEE         From PJMTIMEMP_CSTD_METHODS
    When "_GET_PJMPCC_DEFAULT"         : Gosub _GET_PJMPCC_DEFAULT          From PJMTIMEMP_CSTD_METHODS
    When "GET_PTEUOM"                  : Gosub GET_PTEUOM                   From PJMTIMEMP_CSTD_METHODS
    When "GET_CLBPCC"                  : Gosub GET_CLBPCC                   From PJMTIMEMP_CSTD_METHODS
    When "GET_PJMCST"                  : Gosub GET_PJMCST                   From PJMTIMEMP_CSTD_METHODS
    When "GET_CLBCST"                  : Gosub GET_CLBCST                   From PJMTIMEMP_CSTD_METHODS
    When "CTRL_PTEDAT"                 : Gosub CTRL_PTEDAT                  From PJMTIMEMP_CSTD_METHODS
    When "_CTRL_PTEDAT_RAFFT"          : Gosub _CTRL_PTEDAT_RAFFT           From PJMTIMEMP_CSTD_METHODS
    When "_CTRL_PTEDAT_OPER"           : Gosub _CTRL_PTEDAT_OPER            From PJMTIMEMP_CSTD_METHODS
    When "_CTRL_PTEDAT_TASK"           : Gosub _CTRL_PTEDAT_TASK            From PJMTIMEMP_CSTD_METHODS
    When "_CTRL_PTEDAT_BUDGET"         : Gosub _CTRL_PTEDAT_BUDGET          From PJMTIMEMP_CSTD_METHODS
    When "_PJM_TASK_TIMEENTRY"         : Gosub _PJM_TASK_TIMEENTRY          From PJMTIMEMP_CSTD_METHODS
    When "_PJM_TASK_TIMEENTRY_TOUPDATE": Gosub _PJM_TASK_TIMEENTRY_TOUPDATE From PJMTIMEMP_CSTD_METHODS # Issue X3-69372 - 2018-03-28 by SINGC
    #
    When "CDIE_DELETE"                 : Gosub CDIE_DELETE                  From PJMTIMEMP_CSTD_METHODS # Issue X3-66474 - 2018-02-08 by SINGC
    When "DIE_LOAD_INPUT_VALUES"       : Gosub DIE_LOAD_INPUT_VALUES        From PJMTIMEMP_CSTD_METHODS # Issue X3-81871 - 2018-03-08 by FGR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "PTEDAT"                      : Gosub PTEDAT                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEQTY"                      : Gosub PTEQTY                  From PJMTIMEMP_CSTD_PROPERTIES
    When "OPPNUM"                      : Gosub OPPNUM                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PIMTASCOD"                   : Gosub PIMTASCOD               From PJMTIMEMP_CSTD_PROPERTIES
    When "PIMPBUCOD"                   : Gosub PIMPBUCOD               From PJMTIMEMP_CSTD_PROPERTIES
    When "OPENUM"                      : Gosub OPENUM                  From PJMTIMEMP_CSTD_PROPERTIES
    When "CUR"                         : Gosub CUR                     From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEUOM"                      : Gosub PTEUOM                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEDAT"                      : Gosub PTEDAT                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEINV"                      : Gosub PTEINV                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PJMPCC"                      : Gosub PJMPCC                  From PJMTIMEMP_CSTD_PROPERTIES
    When "CLBPCC"                      : Gosub CLBPCC                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PJMCST"                      : Gosub PJMCST                  From PJMTIMEMP_CSTD_PROPERTIES
    When "CLBCST"                      : Gosub CLBCST                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTETYP"                      : Gosub PTETYP                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEVAL"                      : Gosub PTEVAL                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTESTA"                      : Gosub PTESTA                  From PJMTIMEMP_CSTD_PROPERTIES
    When "PTEORI"                      : Gosub PTEORI                  From PJMTIMEMP_CSTD_PROPERTIES
    When "KEYCONCAT"                   : Gosub KEYCONCAT               From PJMTIMEMP_CSTD_PROPERTIES
    #
    When "CDIE.CCE"                    : Gosub CDIE_CCE                From PJMTIMEMP_CSTD_PROPERTIES # Issue X3-66474 - 2018-02-02 by SINGC
  Endcase
Return

