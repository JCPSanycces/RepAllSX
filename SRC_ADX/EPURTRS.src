#<AdxTL>@(#)0.0.0.0 $Revision$
## Epurations comptables Version V130 (cf HISTOTRS pour la version V140)


$ACTION
Case ACTION
 When "OUVRE_EPURE"    : Gosub OUVRE
 When "FERME_EPURE"    : Gosub FERME
 When "VERF_EPURE"     : Gosub VERIF
 When "EPURE"          : Gosub EPURE
Endcase
Return


$OUVRE
Case [F:AEP]COD
 When "SINVOICE" , "PINVOICE" : # Factures tiers
  Local Integer NUMACC, FLGHDUD
  FLGHDUD=0
  If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
  If clalev ([F:ACV])=0  : Local File ACTIV   [ACV] : Endif
  Read [ACV]CODACT="HDU"
  If !fstat & [ACV]FLACT=2    :#Code activité actif
   #DBA le 20/09/04 : Bug no 25031 
   #Si code activité inactif, ne pas tenter d'ouvrir HISTODUD...
   If clalev ([F:HDU])=0  : Local File HISTODUD   [HDU] : Endif
   FLGHDUD=1
  Endif
 When "PAY"              : # Règlements
  If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif
  If clalev([F:PRO])=0 : Local File PROROG     [PRO] : Endif
  If clalev([F:UNP])=0 : Local File UNPAID     [UNP] : Endif
 When "PAYFRM"                : # Bordereaux
  If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif
  If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
  If clalev([F:BES])=0 : Local File BILSTA     [BES] : Endif
 When "PAYLOT" : # Lots de règlements
  If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
 ###DBA le 22/01/03 : Epuration de l'historique des échéances
 When "HISTODUD"
  Local Integer OLDCLE, OLDNUM, OLDLIG, FLGHDUD
  OLDCLE=0 : OLDNUM=0 : OLDLIG=0 : FLGHDUD=0
  If clalev ([F:ACV])=0  : Local File ACTIV   [ACV] : Endif
  Read [ACV]CODACT="HDU"
  If !fstat & [ACV]FLACT=2    :#Code activité actif
   #DBA le 20/09/04 : Bug no 25031 
   #Si code activité inactif, ne pas tenter d'ouvrir HISTODUD...
   If clalev([F:HDU2])=0 
    Local File HISTODUD [HDU2] Order By Key CLE=ACCNUM;DUDLIG;CREDAT;NUMHDU
   Endif
   If clalev([F:HDU3])=0 : Local File HISTODUD  [HDU3] : Endif
   FLGHDUD=1
  Endif
Endcase
Return

$FERME
Case [F:AEP]COD
 When "SINVOICE" , "PINVOICE" : # Factures tiers
  If clalev([F:DUD])>0 : Close Local File [DUD] : Endif
  #DBA 20/09/04 : Bug no 25031 : test code activité HDU via FLGHDUD
  If FLGHDUD=1
   If clalev([F:HDU])>0 : Close Local File [HDU] : Endif
  Endif
 When "PAY"              : # Règlements
  If clalev([F:PAN])>0 : Close Local File [PAN] : Endif
  If clalev([F:PRO])>0 : Close Local File [PRO] : Endif
  If clalev([F:UNP])>0 : Close Local File [UNP] : Endif
 When "PAYFRM"                : # Bordereaux
  If clalev([F:PAN])>0 : Close Local File [PAN] : Endif
  If clalev([F:PYH])>0 : Close Local File [PYH] : Endif
  If clalev([F:BES])>0 : Close Local File [BES] : Endif
 When "PAYLOT"                : # Lots de règlements
  If clalev([F:PYH])>0 : Close Local File [PYH] : Endif
 ###DBA le 22/01/03 : Epuration de l'historique des échéances
 When "HISTODUD"
  #DBA 20/09/04 : Bug no 25031 : test code activité HDU via FLGHDUD
  If FLGHDUD=1
   If clalev([F:HDU2])>0 : Close Local File [HDU2] : Endif
   If clalev([F:HDU3])>0 : Close Local File [HDU3] : Endif
  Endif
  If clalev([F:ACV])>0 : Close Local File [ACV] : Endif
Endcase
Return

$VERIF
# Le code épuration des règlements doit venir avant ceux des bordereaux et lots
# sinon on n'épurera jamais ces derniers
Case [F:AEP]COD
 When "SINVOICE","PINVOICE" : # On n'épure que les factures soldées
  NUMACC = [F:WWW]ACCNUM
  For [DUD]DUD6 Where FLGCLE=1 & ACCNUM=[L]NUMACC
   OK = 0 : Break
  Next
 When "PAYFRM" : # On n'épure que les bordereaux vides
  Read [PYH]PYH1(2) = [F:WWW]FRMFLG;[F:WWW]FRMNUM
  If !fstat
   OK = 0
  Endif
 When "PAYLOT" : # On n'épure le lot que s'il est vide
  Read [PYH]PYH2(1) = [F:WWW]COD
  If !fstat
   OK = 0
  Endif
Endcase
#DBA 20/09/04 : Bug no 25031 : test code activité HDU via FLGHDUD
If FLGHDUD=1
 ###DBA le 22/01/03 : Epuration de l'historique des échéances
 If OK & [F:AEP]COD="HISTODUD"
  OK=0
  If OLDCLE=0 : Gosub EPUR_ECH : Endif
 Endif
Endif
Return

# On épure les échéances et l'historique de celles-ci
# des factures à supprimer 
# Gestion (complexe) du fichier PAN
$EPURE
Case [F:AEP]COD
 When "SINVOICE","PINVOICE" : 
  Delete [DUD] Where ACCNUM=[F:WWW]ACCNUM
  If fstat=1
   GOK = -1 : GLOCK = "$GACCDUDATE"-[F:WWW]ACCNUM : Return
  Endif
  #DBA 20/09/04 : Bug no 25031 : test code activité HDU via FLGHDUD
  If FLGHDUD=1
   Delete [HDU] Where ACCNUM=[F:WWW]ACCNUM
   If fstat=1
    GOK = -1 : GLOCK = "$HISTODUD"-[F:WWW]ACCNUM : Return
   Endif
  Endif
 When "PAY"
 #Ici on ne doit pas supprimer les échéances de type "facture", liées au règlement
 #car c'est l'épuration des factures qui le fera...
 #On ne supprime pas non plus les échénaces de type "règlement" car c'est
 #l'épuration des pièces comptable dans EPURCPT qui le fera...
  Delete [PAN] Where TYPNUM=3 & NUM=[F:WWW]NUM
  If fstat=1
   GOK = -1 : GLOCK = "$PAYACCNUM"-[F:WWW]NUM : Return
  Endif
  Delete [PRO] Where NUM=[F:WWW]NUM
  If fstat=1
   GOK = -1 : GLOCK = "$PROROG"-[F:WWW]NUM : Return
  Endif
  Delete [UNP] Where NUM=[F:WWW]NUM
  If fstat=1
   GOK = -1 : GLOCK = "$UNPAID"-[F:WWW]NUM : Return
  Endif
 When "PAYFRM"
  Delete [PAN] Where TYPNUM=[F:WWW]FRMFLG & NUM=[F:WWW]FRMNUM
  If fstat=1
   GOK = -1 : GLOCK = "$PAYACCNUM"-[F:WWW]FRMNUM : Return
  Endif
  Delete [BES] Where FRMNUM=[F:WWW]FRMNUM
  If fstat=1
   GOK = -1 : GLOCK = "$PAYACCNUM"-[F:WWW]FRMNUM : Return
  Endif
Endcase
Return

###DBA le 22/01/03 : Epuration de l'historique des échéances
# On garde dans l'historique :
# 1)les enreg créés aprés la date d'épuration
# 2)les enreg représentant la "dernière image" d'une échéance même créés avant la date
# d'épuration.
$EPUR_ECH
For [F:HDU2]CLE Where evalue (FILTRE)
 If OLDCLE<>0
  If [F:HDU2]ACCNUM=OLDNUM & [F:HDU2]DUDLIG=OLDLIG
   Read[F:HDU3]HDU0=OLDCLE
   If !fstat : Delete [F:HDU3]: Endif
   NBEPU += 1
  Endif
 Endif
 OLDCLE=[F:HDU2]NUMHDU
 OLDNUM=[F:HDU2]ACCNUM
 OLDLIG=[F:HDU2]DUDLIG
Next
Return






