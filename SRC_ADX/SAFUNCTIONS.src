#    For I = 1 To 12
#      If I < 11
#        [L]TAXMONTH=gdat$(1,I+2,year([L]TAXYEARSTART))
#      Else
#        [L]TAXMONTH=gdat$(1,I-10,year([L]TAXYEAREND))
#      Endif
#
#    #only calc YTD
#      If eomonth([L]TAXMONTH)>eomonth(THISPAYMONTH)
#        Break
#      Endif
#
#    #left in this month
#      If [CTRAFR7]TAXENDDAT>=[L]TAXMONTH & [CTRAFR7]TAXENDDAT<=eomonth([L]TAXMONTH)
#        [L]RESULT_VALUE=([CTRAFR7]TAXENDDAT-[CTRAFR7]TAXSTRDAT+1)
#        End [L]RESULT_VALUE
#      Endif
#
#      [L]CALCSTR=[0/0/0] : [L]CALCEND=[0/0/0]
#
#    #started during month
#      If [CTRAFR7]TAXSTRDAT>=[L]TAXMONTH & [CTRAFR7]TAXSTRDAT<=eomonth([L]TAXMONTH)
#        [L]CALCSTR=[CTRAFR7]TAXSTRDAT
#      Endif
#
#    #full month
#      If [CTRAFR7]TAXSTRDAT<[L]TAXMONTH
#        [L]CALCSTR=[L]TAXMONTH
#      Endif
#      If [CTRAFR7]TAXENDDAT>eomonth([L]TAXMONTH)
#        [L]CALCEND=eomonth([L]TAXMONTH)
#      Endif
#
#      If ([L]CALCSTR<>[0/0/0]) & ([L]CALCEND<>[0/0/0])
#      #full month
#        If day([L]CALCSTR)=1 & day([L]CALCEND)=day(eomonth([L]CALCEND))
#          [L]RESULT_VALUE=RESULT_VALUE+(([L]TAXYEAREND-[L]TAXYEARSTART+1)/12)
#        Else
#          [L]RESULT_VALUE=[L]RESULT_VALUE+([L]CALCEND-[L]CALCSTR+1)
#        Endif
#      Endif
#    Next I
#
#    Break
#  Next
#
#End RESULT_VALUE
#JASMI - 2017-09-11 - X3-55480 - END
Funprog PRORATAFR()
Local Decimal RESULT_VALUE
Local Date    TAXYEARSTART, TAXYEAREND, CALCSTR, CALCEND
Local Date    TAXMONTH

  [L]RESULT_VALUE=0

#calc tax year strat and end
  If month([VEP]STRDAT)>=3
    [L]TAXYEARSTART=gdat$(1,3,year([VEP]STRDAT))
  Else
    [L]TAXYEARSTART=gdat$(1,3,year([VEP]STRDAT)-1)
  Endif
  [L]TAXYEAREND=(gdat$(1,3,year([L]TAXYEARSTART)+1)-1)

#worked until end of tax year and in Feb
  If [ETA]TAXENDDAT=[L]TAXYEAREND & month([VEP]STRDAT)=2
    [L]RESULT_VALUE=([ETA]TAXENDDAT-[ETA]TAXSTRDAT+1)
    End [L]RESULT_VALUE
  Endif

  For I = 1 To 12
    If I < 11
      [L]TAXMONTH=gdat$(1,I+2,year([L]TAXYEARSTART))
    Else
      [L]TAXMONTH=gdat$(1,I-10,year([L]TAXYEAREND))
    Endif

#JASMI - 2017-05-25 - Future terminations - START
    If [HRCTR]XITFNL=2
      [L]RESULT_VALUE=([ETA]TAXENDDAT-[ETA]TAXSTRDAT+1)
      End [L]RESULT_VALUE
    Endif
#JASMI - 2017-05-25 - Future terminations - END

  #only calc YTD
    If eomonth([L]TAXMONTH)>eomonth([VEP]STRDAT)
      Break
    Endif

  #left in this month
    If [ETA]TAXENDDAT>=[L]TAXMONTH & [ETA]TAXENDDAT<=eomonth([L]TAXMONTH)
      [L]RESULT_VALUE=([ETA]TAXENDDAT-[ETA]TAXSTRDAT+1)
      End [L]RESULT_VALUE
    Endif

    [L]CALCSTR=[0/0/0] : [L]CALCEND=[0/0/0]

  #started during month
    If [ETA]TAXSTRDAT>=[L]TAXMONTH & [ETA]TAXSTRDAT<=eomonth([L]TAXMONTH)
      [L]CALCSTR=[ETA]TAXSTRDAT
    Endif

  #full month
    If [ETA]TAXSTRDAT<[L]TAXMONTH
      [L]CALCSTR=[L]TAXMONTH
    Endif
    If [ETA]TAXENDDAT>eomonth([L]TAXMONTH)
      [L]CALCEND=eomonth([L]TAXMONTH)
    Endif

    If ([L]CALCSTR<>[0/0/0]) & ([L]CALCEND<>[0/0/0])
    #full month
      If day([L]CALCSTR)=1 & day([L]CALCEND)=day(eomonth([L]CALCEND))
        [L]RESULT_VALUE=RESULT_VALUE+(([L]TAXYEAREND-[L]TAXYEARSTART+1)/12)
      Else
        [L]RESULT_VALUE=[L]RESULT_VALUE+([L]CALCEND-[L]CALCSTR+1)
      Endif
    Endif
  Next I

End RESULT_VALUE

#THRAM - 2017-10-10 - X3-58207 - START
Funprog CALDATMM_SRVPER(LATDAT,SMLDAT,PARAM1,PARAM2)
Value Date LATDAT,SMLDAT
Value Integer PARAM1,PARAM2
Local Integer SMLDATMON,LATDATMON
Local Integer MONADD
Local Integer INIYY
Local Decimal INIMM
SMLDATMON = month(SMLDAT)
LATDATMON = month(LATDAT)
INIYY = year(LATDAT)-year(SMLDAT)
MONADD = LATDATMON-SMLDATMON
If INIYY < 0 : End 0 : Endif
If INIYY = 0 # same year check months
  If MONADD < 0 : End 0 : Endif
  MONADD+=1
  INIMM = MONADD/100
Else
  #Check months again to add/sub to/from the year
  If  MONADD = -1
    INIMM = INIYY #Full years
  Elsif MONADD < -1
    INIYY-=1
    INIMM = INIYY+(MONADD+13)/100
  Else
    MONADD+=1
    INIMM = INIYY+(MONADD/100)
  Endif
Endif
End INIMM
#THRAM - 2017-10-10 - X3-58207 - END

