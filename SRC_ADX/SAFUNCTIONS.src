#        [L]DEBTOL = [F:CNE]EMPLEASTR
#      Endif
#      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNE]EMPLEAEND
#        [L]FINTOL = [F:CNE]EMPLEAEND
#      Endif
#     Else
#      If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNG]DEBDAT
#        [L]DEBTOL = [F:CNG]DEBDAT
#      Endif
#      If [L]FINTOL = [0/0/0] | [L]FINTOL < [F:CNG]FINDAT
#        [L]FINTOL = [F:CNG]FINDAT
#      Endif
#     Endif
##JASMI - 2014/08/31 - END
#     # END 77494 - 31/10/2011
#    Next
#    If I
#      [L]NBJ-=sum([L]JOUR2)
#     # fiche 72061 - 07/03/2011 : ajout du test sur le contrat
#     # fiche 77494 - 31/10/2011
#     # FQ82397 - 25/05/12 -   contrôle des demandes avec STA 2(Demande) ou 3(accepte)
#     For [F:DCG] Where REFNUM=[M:DCG1]REFNUM & (STA=2 or STA=3) & UID>0 & UID<>[M:DCG1]UID(nolign-1)
#&                    & find([M:DCG1]CTRNUM(nolign-1),"",CTRNUM)
#&                    & TIM=[L]VALEUR
#&                    & ((STRDAT >= [L]DEBTOL & STRDAT <= [L]FINTOL )
#&                     | (ENDDAT <= [L]FINTOL & ENDDAT >= [L]DEBTOL))
#&                    & !find(UID,[M:DCG1]UID)  : # on regardera l'écran après
## END 77494 - 31/10/2011
#      [L]NBJ-=[F:DCG]NBRDAY
#     Next
#
#     # On inclue les autres nouvelles lignes de la saisie courante
#     For F = 0 To [M:DCG1]NBLIG-1
#       # fiche 72061 - 07/03/2011 : ajout du test sur le contrat
#       # fiche 77494 - 31/10/2011
#       If F <> nolign-1 & [M:DCG1]TIM(F) = VALEUR & find([M:DCG1]STA(F),2,3)
#&      and ([M:DCG1]CTRNUM(F) = "" or [M:DCG1]CTRNUM(F) = [F:CTR]CTRNUM)
#&      and (([M:DCG1]STRDAT(F) >= [L]DEBTOL & [M:DCG1]STRDAT(F) <= [L]FINTOL )
#&         | ([M:DCG1]ENDDAT(F) <= [L]FINTOL & [M:DCG1]ENDDAT(F) >= [L]DEBTOL))
## END 77494 - 31/10/2011
#        [L]NBJ-=[M:DCG1]NBRDAY(F)
#       Endif
#     Next
#
#     #64506
#     #[L]SOLNEG=min([L]SOLNEG,[L]NBJ)
#     [L]SOLNEG=[L]NBJ
#     [L]L_CTRNUM = [F:CTR]CTRNUM # fiche 72061 - 07/03/2011
#    Else
#     GMESSAGE -= '\'-mess(319,199,1)-[F:TIM]COD  : # Fiche période de congé inexistante pour l'évènement
#     mkstat = 2 : Break 2
#    Endif
#   Endif
#  Endif
#------------------------------------------------------------------------------------------#

  For I=1 To N
   If VENDDAY=2 | (I=N & VSTRDAY=2)
    [L]NBJ=0.5
   Else
    [L]NBJ=1
   Endif
   If [L]JOUR(I)+[L]JOUR2(I)<=[L]NBJ : [L]JOUR(I)+=[L]JOUR2(I) : Endif
  Next
 [L]NBRDAY=max([L]NBRDAY,sum([L]JOUR))
 # fiche 72061 - 07/03/2011 : on s'arrête au premier solde négatif
 If [F:TIM]FLGBLC=2 & [L]SOLNEG<[F:TIM]BLCMIN
   Break 2
 Endif
 Next
Next
#MIPEA - 2016-11-07 - X3PEOP-773- END
If mkstat=2 : End : Endif

