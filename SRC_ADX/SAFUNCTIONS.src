If VENDDAT < VSTRDAT : End [L]NBRDAY : Endif
N=(VENDDAT-VSTRDAT)+1

Local Decimal JOUR(1..N), HEURE(1..N), JOUR2(1..N)

#Read [F:TIM]TIM0 = NATCON
#If fstat : End  :Endif

Call CONTEXE([F:TIM]ACS) From CPTSUB
If mkstat : End : Endif

#Checking if the nature of event is compatible with the employee
If dim(ACTPOR) >= 0 and  ACTPOR="ANNUL" Then
  # Pas de contrôle si Portail est ACTION="ANNUL"
Else
  If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
    Local Integer RET
    Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,VREFNUM,VCTRNUM,RET) From DIVPAYE
    If RET>0 Then
      End
    Endif
  Endif
Endif

#Checking if it's entered through the portal - Ignore
#------------------------------------------------------------------------------#
#If ([V]GWEBSERV & [F:TIM]AUZPRH<2)
#&| ( ![V]GWEBSERV
#&  & (!find([F:TIM]CATTIM,2,3) | ([V]GTPS & [F:TIM]CTLDAC=2))
#&  )
# [V]GMESSAGE=mess(83,123,1) : # Valeur incorrecte
