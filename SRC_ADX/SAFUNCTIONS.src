Funprog NBRWRKDAY(VSTRDAT,VENDDAT,NATCON,VENDDAY,VSTRDAY,VPHI)
Value Char NATCON
Value Date VSTRDAT,VENDDAT
Value Integer VENDDAY,VSTRDAY,VPHI
Local Integer I, N, J , F
Local Decimal NBJ, NBRDAY, SOLNEG , D
Local Date    DEB, FIN
Local Date    DEBTOL, FINTOL
Local Char    VALPAR(20)
Local Char     AM(4), PM(4), C(1)
Local Char L_CTRNUM(GLONCTR)
Local Date VCTRDAT
