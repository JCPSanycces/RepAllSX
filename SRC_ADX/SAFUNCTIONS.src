#TIVAN 2017/03/22
Funprog CONVERTRATE(AMT,RATETYP,FROMCUR,TOCUR, RATEDAT)
Value Decimal AMT
Value Integer RATETYP
Value Char FROMCUR
Value Char TOCUR
Value Date RATEDAT
#JASMI - 2017-10-26 - X3-55593 - START
#Local Decimal RATE
Local Decimal RATE : RATE=0
#JASMI - 2017-10-26 - X3-55593 - END

#MIPEA - 2017-10-12- US X3-59605- START
    Local Decimal EXCHFIXRATE
    Local Decimal INVERSERATE

    If !clalev([F:TCUC]) : Local File TABCUR [TCUC] : Endif
    If !clalev([F:TCHC]) : Local File TABCHANGE [TCHC] : Endif

    Read [TCUC]TCU0 = TOCUR
    If [F:TCUC]EURFLG=2 # Fixed EURO rate flagged
#MIPEA - 2017-11-06- US X3-59606- START
      EXCHFIXRATE = ([F:TCUC]EURRAT/1)
#      EXCHFIXRATE = (1/[F:TCUC]EURRAT)
#MIPEA - 2017-11-06- US X3-59606- END
       Filter [TCHC] Where CURDEN=FROMCUR & CHGTYP=RATETYP & CUR="EUR" & CHGSTRDAT<=RATEDAT
       Read [TCHC]TCH0 Last
#MIPEA - 2017-11-06- US X3-59606- START
      If !fstat
        INVERSERATE = [F:TCHC]REVCOURS/[F:TCHC]CHGDIV
      Else
        INVERSERATE = 0
      Endif
#      INVERSERATE = [F:TCHC]CHGRAT
#MIPEA - 2017-11-06- US X3-59606- END
      RATE = AMT*(EXCHFIXRATE * INVERSERATE)
    Else
      Filter [TCHC] Where CURDEN=FROMCUR & CHGTYP=RATETYP & CUR=TOCUR & CHGSTRDAT<=RATEDAT
      Read [TCHC]TCH0 Last
#MIPEA - 2017-11-04- US X3-59605- START
#MIPEA - 2017-11-06- US X3-59606- START
      If !fstat
        RATE = AMT*([F:TCHC]REVCOURS/[F:TCHC]CHGDIV)
      Else
        RATE = 0
      Endif
#      RATE = AMT/[F:TCHC]CHGRAT
#MIPEA - 2017-11-06- US X3-59606- START
#      RATE = AMT*[F:TCHC]CHGRAT
#MIPEA - 2017-11-04- US X3-59605- END
    Endif
#JASMI - 2017-10-26 - X3-55593 - START
  Filter [TCHC]
#JASMI - 2017-10-26 - X3-55593 - END

#If !clalev([F:ZTCH])  Local File TABCHANGE [F:ZTCH] Endif
#Read [F:ZTCH]TCH0=RATETYP;TOCUR;FROMCUR;RATEDAT
#
#RATE = AMT*[F:ZTCH]CHGRAT
#
#Close File [F:ZTCH]

#MIPEA - 2017-10-12- US X3-59605- END

End RATE
