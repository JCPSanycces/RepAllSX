#  If [L]VALEUR=func AFNC.PARAM("CPA",[F:CTR]ETRFCY)
#&  & func TPSSTD1.OUVRABLE(VREFNUM,VENDDAT+1,[F:CTR]CTRNUM)
#   #Call AVERTIR(mess(70,709,1),I) From GESECRAN : # Reprise d'activité un jour ouvrable
#   If I<>2 : Endif
#   Break
#  Endif
# Next
# If mkstat : End : Endif
#Endif


# FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
Local Date DATDEBCTR
#MIPEA - 2016-11-07 - X3PEOP-773- START
For [HRCTR]CTR0(2) Where REFNUM=VREFNUM & CTRNUM = VCTRNUM
&                    & (CTRDAT<=VENDDAT | (FLGRET=2 & RETDATEFF<=VENDDAT))
&                    & (XITDAT=[0/0/0] | XITDAT>=VSTRDAT)
#For [CTR]CTR0(2) Where REFNUM=VREFNUM & CTRNUM = VCTRNUM
#&                    & (CTRDAT<=VENDDAT | (FLGRET=2 & RETDATEFF<=VENDDAT))
#&                    & (XITDAT=[0/0/0] | XITDAT>=VSTRDAT)
#MIPEA - 2016-11-07 - X3PEOP-773- END
 Raz [L]JOUR
 #MIPEA - 2016-11-07 - X3PEOP-773- START - CHANGED ALL "CTR" TO "HRCTR"
 For [HRCTR]CTR0
  # FQ85820 - 12/11/12 - On doit aussi tester la date de rétroactivité au lieu de la date du contrat
  DATDEBCTR=[F:HRCTR]CTRDAT
  If [F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<>[0/0/0] Then
   DATDEBCTR=[F:HRCTR]RETDATEFF
  Endif
  [L]DEB=max(VSTRDAT,DATDEBCTR)
  If [F:HRCTR]XITDAT=[0/0/0] : [L]FIN=VENDDAT
  Else                       [L]FIN=min(VENDDAT,[F:HRCTR]XITDAT)
  Endif
  I=[L]DEB-VSTRDAT+1
  Raz [L]JOUR2

  If [F:HRCTR]PLNTYP=""
   For J=I To N : [L]JOUR2(J)=1 : Next
  Else
#   Call VALORDETWKD( [L]DEB,[L]FIN,VREFNUM,NATCON,[L]JOUR2(I..N),[L]HEURE(I..N)
#&               , [F:CTR]ETRFCY,[F:CTR]CTRNUM,VPHI
#&               ) From SUBPLN

  Call VALORDETWKD( [L]DEB,[L]FIN,VREFNUM,"",[L]JOUR2(I..N),[L]HEURE(I..N)
&               , [F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,VPHI
&               ) From SUBPLN
  Endif

#GTPS = Presence of the temps module - Time not managed using hourly range
# Si on a pas les temps on ne gère pas les plages horaires
# On se contente des nombres renvoyés par le VALORDET ci-dessus
  If GTPS : # 69211
  If VENDDAY=2 & [L]DEB=VSTRDAT
     #Divide if there is more than one track in the planning
   # On divise si il existe plus d'une plage dans le planning
   Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]DEB,[L]DEB,C,[L]DEB,C,F,D,[L]AM,C,[L]PM
&                   , C,C,C
&                   ) From PORTPS   : # 62965
   If [L]AM<>"" & [L]PM<>""
    [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
    [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))
   Endif
   If [L]PM = ""
    F = 1
    If !GWEBSERV
     #Call AVERTIR(mess(194,709,1),F) From GESECRAN : # La demi-journée posée est chômée
     [L]HEURE(1)=0
     [L]JOUR2(1)=0
    Endif
    If F<>2
     mkstat = 2
    Endif
   Endif
  Endif

  If VSTRDAY=2 & [L]FIN=VENDDAT
   Call GETSEMTYP( [F:HRCTR]PLNTYP,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,[L]FIN,[L]FIN,C,[L]FIN,C,F,D,[L]AM,C,[L]PM
&                 , C,C,C
&                 ) From PORTPS   : # 62965

   If [L]AM<>"" & [L]PM<>""
     [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
     [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
   Endif

   If [L]AM = ""
    F = 1
    If !GWEBSERV
    # Call AVERTIR(mess(194,709,1),F) From GESECRAN : # La demi-journée posée est chômée
     [L]HEURE(N)=0
     [L]JOUR2(N)=0
    Endif
    If F<>2
     mkstat = 2
    Endif
   Endif

  Endif

  Else : # 69211

   If VENDDAY=2
    [L]HEURE(1)-=min(0.5,[L]JOUR2(1))*[L]HEURE(1)
    [L]JOUR2(1)-=min(0.5,[L]JOUR2(1))
   Endif

   If VSTRDAY=2
    [L]HEURE(N)-=min(0.5,[L]JOUR2(N))*[L]HEURE(N)
    [L]JOUR2(N)-=min(0.5,[L]JOUR2(N))
   Endif

  Endif

# CATTIM=3 (Leave transaction) - Skip check
#------------------------------------------------------------------------------------------#
#  If [F:TIM]CATTIM=3
#   If [F:TIM]FLGBLC=2 & [M:DCG1]STA(nolign-1) <> 1
#    Raz I, [L]NBJ
