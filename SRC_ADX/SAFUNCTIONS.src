#THRAM - 2018-04-10 - X3-85906 - START
#DESNY - 2018-08-21 - X3-90776 - START
Funprog GET_PAY_PERIOD(IRPSTRDAT,IRPENDDAT,THISPERCOD,YEA,IND,XITDAT,XITFNL)
Value Char THISPERCOD
Value Date    IRPSTRDAT, IRPENDDAT, XITDAT
Value Integer IND, YEA, XITFNL
Local Decimal RESULT_VALUE
Local Integer PAYFRQ
Local Date DATEMIN,DATEMAX
Local Decimal PERMON, PERWEEK
Local Integer DIFFWEEK
Local Integer DIFFMON

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
If clalev([F:HRPEOD2])=0 : Local File HRPEODET [HRPEOD2] : Endif

If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif

DATEMIN = date$

Filter [HRPEOH] Where PERCOD=THISPERCOD & PERYEA=YEA
Read [HRPEOH]HRPEOH0 = YEA;THISPERCOD

Filter [HRPEOD] Where  PERCOD=THISPERCOD & PERYEA=YEA

If !fstat Then
PAYFRQ = [HRPEOH]PAYFRQ
Endif

If IND = 1 Then   #Get Total number of periods

  RESULT_VALUE = rowcount([HRPEOD])
Else
  If IND = 2 #Get Active periods
      Filter [HRPEOD]

      Filter [HRPEOD] Where PERSTR(1) = IRPSTRDAT  and PERCOD=THISPERCOD & PERYEA=YEA    # find the start date
      Read [F:HRPEOD]HRPEOD0  Last

      Filter [HRPEOD2] Where PEREND(1)  = IRPENDDAT and PERCOD=THISPERCOD & PERYEA=YEA
      Read [F:HRPEOD2]HRPEOD0  Last

     If rowcount([HRPEOD])= 1  and rowcount([HRPEOD2])= 1  Then
        If PAYFRQ = 1 #weekly then
          DIFFWEEK = ((IRPENDDAT -IRPSTRDAT)) + 1
          RESULT_VALUE= DIFFWEEK / 7
        Elsif PAYFRQ = 6 #Monthly
              RESULT_VALUE= func GET_PAY_PERIOD_MON(IRPSTRDAT,IRPENDDAT,YEA,XITDAT,XITFNL)
        Endif
     Else
         If PAYFRQ = 1 #weekly then
            DIFFWEEK = ((IRPENDDAT -IRPSTRDAT))
            RESULT_VALUE= (DIFFWEEK + 1)/ 7
         Elsif PAYFRQ = 6 #Monthly
           # DIFFMON = IRPENDDAT -IRPSTRDAT
            RESULT_VALUE= func GET_PAY_PERIOD_MON(IRPSTRDAT,IRPENDDAT,YEA,XITDAT,XITFNL)
        Endif
     Endif

 Endif


Endif

End RESULT_VALUE
#DESNY - 2018-08-21 - X3-90776 - END
#THRAM - 2018-04-10 - X3-85906 - END



Funprog GTMIN(INPUTYEAR, INPUTMONTH)
Value Integer INPUTYEAR
Value Integer INPUTMONTH
Local Date   RESULT_VALUE

RESULT_VALUE = date$

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif

Link [HRPEOH] With
&   [HRPEOD]HRPEOD0(1) = [HRPEOH]PERCOD
& As [LNK]
& Where [F:HRPEOD]PERYEA =[F:HRPEOH]PERYEA & [F:HRPEOH]PERYEA = INPUTYEAR & [F:HRPEOH]LEG = "ZAF" & [F:HRPEOD]TAXMON = INPUTMONTH & [F:HRPEOH]FLGENA = 2
& Order By [F:HRPEOD]PERSTR Asc

#Filter [F:HRPEOH]
#Filter [F:HRPEOH] Where  PERYEA=INPUTYEAR and LEG="ZAF" and FLGENA =2

For [LNK]
  RESULT_VALUE = [F:HRPEOD]PERSTR
  If ([F:HRPEOD]PERSTR < RESULT_VALUE) Then
    RESULT_VALUE = [F:HRPEOD]PERSTR
  Endif
  #RESULT_VALUE= min(RESULT_VALUE,[F:HRPEOD]PERSTR)
Next
#
#SELECT  max(HRPEOD.PEREND_0) From
#HRPEOHEA HRPEOH
#INNER JOIN HRPEODET HRPEOD ON HRPEOH.PERCOD_0 = HRPEOD.PERCOD_0 and HRPEOH.PERYEA_0 = HRPEOD.PERYEA_0
#Where HRPEOH.PERYEA_0 = '2018' and HRPEOH.LEG_0 = 'ZAF' and HRPEOD.TAXMON_0 =12 and HRPEOH.FLGENA_0 =2;

End RESULT_VALUE



