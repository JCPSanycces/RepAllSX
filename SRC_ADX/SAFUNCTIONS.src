#FRLAA 2015-06-03 - Requirement 105483 US 3675 - START
Funprog CALDATYY(LATDAT,SMLDAT)
Value Date LATDAT,SMLDAT
Local Integer RETVAL
Local Integer INIYY
INIYY = year(LATDAT)-year(SMLDAT)
If INIYY < 1 : End 0 : Endif
If month(LATDAT) < month(SMLDAT)
  INIYY-=1
Elsif month(LATDAT) = month(SMLDAT)
   If day(LATDAT) < day(SMLDAT)
    INIYY-=1
   Endif
Endif
End INIYY
#FRLAA 2015-06-03 - Requirement 105483 US 3675 - END


#FRLAA 2015-06-03 - Requirement 105483 US 3675 - START
Funprog CALDATMM(LATDAT,SMLDAT)
Value Date LATDAT,SMLDAT : SMLDAT+=1
Local Integer MONADD
Local Integer INIYY
Local Integer INIMM
INIYY = year(LATDAT)-year(SMLDAT)

If INIYY > 0
  MONADD = (INIYY * 12)
Else
  MONADD = 0
Endif

INIMM = month(LATDAT)-month(SMLDAT)
INIMM = INIMM+MONADD
If day(LATDAT) < day(SMLDAT)
  INIMM-=1
Endif
If INIMM < 0 Then : INIMM = 0 : Endif
End INIMM
#FRLAA 2015-06-03 - Requirement 105483 US 3675 - END

Funprog GET_DIRECTIVE_NO(THISREFNUM, THISCTRNUM, THISCTRDAT, LAST_DIRECTIVE_NUMBER,TAX_YEAR, EXTRACT_TEMPLATE)
Value Char THISREFNUM, THISCTRNUM, LAST_DIRECTIVE_NUMBER, EXTRACT_TEMPLATE
Value Date THISCTRDAT
Value Integer TAX_YEAR
Local Char RESULT_VALUE(15)
Local Date USESTRDAT, USEENDDAT

  RESULT_VALUE=""

#first check directive number on contract and use if present
  If LAST_DIRECTIVE_NUMBER="first"
    If [ETR]TAXDIRNUM<>""
      RESULT_VALUE=[ETR]TAXDIRNUM
      End RESULT_VALUE
    Endif
  Endif

#if previous number were blank, return ""
  If LAST_DIRECTIVE_NUMBER=""
    End RESULT_VALUE
  Else
  #if directive number existed on contract, start using aditiona directive numbers
    If [ETR]TAXDIRNUM=LAST_DIRECTIVE_NUMBER or LAST_DIRECTIVE_NUMBER="first"
      LAST_DIRECTIVE_NUMBER=""
    Endif
  Endif

#set check dates for additional directive number effective dates
  [L]USESTRDAT=gdat$(1,3,TAX_YEAR-1)
  If EXTRACT_TEMPLATE="TAXRUN_MIDYEAR"
    [L]USEENDDAT=gdat$(1,9,TAX_YEAR-1)
  Else
    [L]USEENDDAT=gdat$(1,3,TAX_YEAR)
  Endif
  If clalev([F:EDM])=0 : Local File EMPLODIRNUM [EDM] : Endif

#get next additional directive number
  For [EDM]EDM1 Where [EDM]REFNUM=THISREFNUM&[EDM]CTRNUM=THISCTRNUM
& &                   [EDM]STRDAT>=[L]USESTRDAT&[EDM]STRDAT<[L]USEENDDAT
& &                   [EDM]DIRNUM>LAST_DIRECTIVE_NUMBER
    If [EDM]DIRNUM<>[ETR]TAXDIRNUM
      RESULT_VALUE=[EDM]DIRNUM
      Break
    Endif
  Next

End RESULT_VALUE

Funprog GET_COUNTRY_ISOA3(THISCOUNTRY)
Value Char THISCOUNTRY
Local Char RESULT_VALUE(3)

  RESULT_VALUE=""

  If THISCOUNTRY<>""
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
    Read [TCY]TCY0 = THISCOUNTRY
    If !fstat
      [L]RESULT_VALUE=[TCY]ISOA3
    Endif
  Endif

End RESULT_VALUE

#JASMI - 2016-05-19 - REQ 115892 - START
#function to allocate the next WPS number
Funprog NEW_WPS_NUMBER(THIS_FCY)
Value Char THIS_FCY
Local Char RESULT_VALUE(16)
Local Integer STAT


#initialize
  RESULT_VALUE=""


#call to retreive next sequence number
  Call NUMERO("WPS",THIS_FCY, date$, "", RESULT_VALUE, STAT) From SUBANM
  If STAT
  #display message if error
    GMESSAGE = mess(104,117,1)-"WPS"
    End val(RESULT_VALUE)
  Endif

End RESULT_VALUE

#DESNY X3-61007 2017-10-25 BEGIN
#function to calculate the NAPSA Gross extract total
Funprog GET_NAPSAGROS_TOTAL(THIS_EMP,THIS_PAYDATE,THIS_RUB)
Value Char THIS_EMP
Value Date THIS_PAYDATE
Value Char THIS_RUB
Local Decimal RESULT_VALUE

#initialize
  RESULT_VALUE=0

#open instances of required tables
  If clalev([F:HSP9])=0 : Local File HISTOPAYE [HSP9] : Endif
  If clalev([F:VEP9])=0 : Local File VALEMP [VEP9] : Endif
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif

#construct link with all the required tables
  Link    [HSP9]
&   With  [VEP9]VEP5 = [HSP9]BUL,
&         [CTR9]CTR0 = [VEP9]EMP ; [VEP9]CTRNUM ; [VEP9]CTRDAT
&   As    [LNK9]
&   Where [HSP9]EMP=THIS_EMP & [VEP9]PYRDAT=THIS_PAYDATE & [HSP9]TYP=6 &
&         ([HSP9]RUB=THIS_RUB)

#loop and calculate
  For [LNK9]
    RESULT_VALUE=RESULT_VALUE+[HSP9]AMT
  Next

End RESULT_VALUE
#DESNY X3-61007 2017-10-25 END

#function to calculate the WPS extract total
Funprog GET_WPS_TOTAL(THIS_CPY,THIS_PAYDATE,THIS_RUB)
Value Char THIS_CPY
Value Date THIS_PAYDATE
Value Char THIS_RUB
Local Decimal RESULT_VALUE

#initialize
  RESULT_VALUE=0

#open instances of required tables
  If clalev([F:HSP9])=0 : Local File HISTOPAYE [HSP9] : Endif
  If clalev([F:VEP9])=0 : Local File VALEMP [VEP9] : Endif
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif
  If clalev([F:FCY9])=0 : Local File FACILITY [FCY9] : Endif

#construct link with all the required tables
  Link    [HSP9]
&   With  [VEP9]VEP5 = [HSP9]BUL,
&         [CTR9]CTR0 = [VEP9]EMP ; [VEP9]CTRNUM ; [VEP9]CTRDAT,
&         [FCY9]FCY0 = [CTR9]ETRFCY
&   As    [LNK9]
&   Where [FCY9]LEGCPY=THIS_CPY & [VEP9]PYRDAT=THIS_PAYDATE & [HSP9]TYP=6 &
&         ([HSP9]RUB=THIS_RUB)

#loop and calculate
  For [LNK9]
    RESULT_VALUE=RESULT_VALUE+[HSP9]AMT
  Next

End RESULT_VALUE
#JASMI - 2016-05-19 - REQ 115892 - END

#JASMI - 2016-05-26 - REQ 116041 - START
#function to calculate the WPS extract total
Funprog CHK_EMP_STA(THIS_REF,THIS_DAT,THIS_FCY,THIS_PRF,THIS_DEP)
Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP
Value Date THIS_DAT
Local Char RESULT_VALUE(10)

#initialize
  RESULT_VALUE="Active"

#open instances of required tables
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif

#construct link with all the required tables
  Filter [CTR9] Where [CTR9]REFNUM=THIS_REF & ([CTR9]ETRFCY = THIS_FCY | THIS_FCY='') &
& ([CTR9]PROPRF = THIS_PRF| THIS_PRF='') & ([CTR9]ETRSRV = THIS_DEP| THIS_DEP='')
& Order By Key THIS_CTR9 = XITDAT Desc

#loop and calculate

Read [CTR9]THIS_CTR9 Last
  If !fstat
    If [CTR9]XITDAT<=THIS_DAT and [CTR9]XITDAT<>[0/0/0]
      RESULT_VALUE="Terminated"
    Endif
  Endif

  Filter [CTR9]

End RESULT_VALUE
#JASMI - 2016-05-26 - REQ 116041 - END

Funprog COUNT_REC(THIS_CPY,THIS_PAYDATE)
Value Char THIS_CPY
Value Date THIS_PAYDATE
Local Decimal RESULT_VALUE
Local Char TEMP(30)
#initialize
  RESULT_VALUE=0
  TEMP = ''

#open instances of required tables
  If clalev([F:HSP9])=0 : Local File HISTOPAYE  [HSP9] : Endif
  If clalev([F:RUB9])=0 : Local File RUBRIQUE   [RUB9] : Endif
  If clalev([F:VEP9])=0 : Local File VALEMP     [VEP9] : Endif
  If clalev([F:CTR9])=0 : Local File EMPLOCTR   [CTR9] : Endif
  If clalev([F:FCY9])=0 : Local File FACILITY   [FCY9] : Endif

#construct link with all the required tables
  Link    [HSP9]
&   With  [RUB9]RUB0 = [HSP9]RUB,
&         [VEP9]VEP5 = [HSP9]BUL,
&         [CTR9]CTR0 = [VEP9]EMP ; [VEP9]CTRNUM ; [VEP9]CTRDAT,
&         [FCY9]FCY0 = [CTR9]ETRFCY
&   As    [LNK9]
&   Where [FCY9]LEGCPY=THIS_CPY & [VEP9]PYRDAT=THIS_PAYDATE & [HSP9]TYP<>6 & ([RUB9]ATTASS='BS' | [RUB9]ATTASS='OD' |
&         [RUB9]ATTASS='OE' ) | [RUB9]COD='NETT_PAY'
&         Order By [CTR9]REFNUM ;[CTR9]CTRNUM ; [CTR9]CTRDAT ;[HSP9]BUL Asc

  For [LNK9]
    If TEMP ='' & [VEP9]PYRDAT=THIS_PAYDATE & ([RUB9]ATTASS='BS' | [RUB9]ATTASS='OD' | [RUB9]ATTASS='OE')
      TEMP = [VEP9]EMP-[VEP9]CTRNUM
      RESULT_VALUE+=1
    Else
      If TEMP <> [VEP9]EMP-[VEP9]CTRNUM & [VEP9]PYRDAT=THIS_PAYDATE & ([RUB9]ATTASS='BS' | [RUB9]ATTASS='OD' | [RUB9]ATTASS='OE')
        TEMP = [VEP9]EMP-[VEP9]CTRNUM
        RESULT_VALUE+=1
      Endif
    Endif
  Next
End RESULT_VALUE

Funprog CHK_EMP_PRF(THIS_REF,THIS_DAT,THIS_FCY,THIS_PRF,THIS_DEP,THIS_CPY)
#Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP,THIS_CPY
Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP,THIS_CPY
Value Date THIS_DAT
Local Char RESULT_VALUE(10)

#initialize
  RESULT_VALUE=''

#open instances of required tables
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif
  If clalev([F:FCY9])=0 : Local File FACILITY [FCY9] : Endif
  If clalev([F:FGR9])=0 : Local File FACGROUP [FGR9] : Endif

##construct link with all the required tables
#  Filter [CTR9] Where [CTR9]REFNUM=THIS_REF & ([CTR9]ETRFCY = THIS_FCY | THIS_FCY='') &
#& ([CTR9]PROPRF = THIS_PRF| THIS_PRF='') & ([CTR9]ETRSRV = THIS_DEP| THIS_DEP='')
#& Order By [CTR9]CTRDAT Desc

  Link    [CTR9]
&   With  [F:FCY9]FCY0 = [CTR9]ETRFCY,
&         [FGR9]FGR1(1)= [FCY9]FCY0
&   As    [LNK1]
&   Where [CTR9]REFNUM=THIS_REF & ([CTR9]ETRFCY = THIS_FCY | THIS_FCY='') &
&         ([CTR9]PROPRF = THIS_PRF| THIS_PRF='') & ([CTR9]ETRSRV = THIS_DEP| THIS_DEP='')
& Order By[CTR9]CTRDAT Desc



#loop and calculate
For [LNK1]
  If [CTR9]CTRDAT <= THIS_DAT & THIS_PRF<>''& [CTR9]PROPRF = THIS_PRF
    RESULT_VALUE=[CTR9]PROPRF
    Break
  Else
    If [CTR9]CTRDAT <= THIS_DAT & THIS_FCY<>'' & [CTR9]ETRFCY = THIS_FCY
      RESULT_VALUE=[CTR9]PROPRF
      Break
    Else
      If [CTR9]CTRDAT <= THIS_DAT & THIS_DEP<>'' & [CTR9]ETRSRV = THIS_DEP
        RESULT_VALUE=[CTR9]PROPRF
        Break
      Else
        If [CTR9]CTRDAT <= THIS_DAT
          RESULT_VALUE=[CTR9]PROPRF
          Break
        Endif
      Endif
    Endif
  Endif
Next

  Filter [CTR9]
End RESULT_VALUE

Funprog CHK_EMP_DEP(THIS_REF,THIS_DAT,THIS_FCY,THIS_PRF,THIS_DEP)
Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP
Value Date THIS_DAT
Local Char RESULT_VALUE(30)
Local Char DEPART(30)

#initialize
  RESULT_VALUE=''
  DEPART=''
#open instances of required tables
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif
  If clalev([F:SRV9])=0 : Local File SERVICE [SRV9] : Endif

#construct link with all the required tables
  Filter [CTR9] Where [CTR9]REFNUM=THIS_REF & ([CTR9]ETRFCY = THIS_FCY | THIS_FCY='') &
& ([CTR9]PROPRF = THIS_PRF| THIS_PRF='') & ([CTR9]ETRSRV = THIS_DEP| THIS_DEP='')
& Order By [CTR9]CTRDAT Desc

#loop and calculate
For [CTR9]
  If [CTR9]CTRDAT <= THIS_DAT & THIS_DEP<>'' & [CTR9]ETRSRV = THIS_DEP
    DEPART=[CTR9]ETRSRV
    Break
  Else
    If [CTR9]CTRDAT <= THIS_DAT & THIS_FCY<>'' & [CTR9]ETRFCY = THIS_FCY
      DEPART=[CTR9]ETRSRV
      Break
    Else
      If [CTR9]CTRDAT <= THIS_DAT & THIS_PRF<>''& [CTR9]PROPRF = THIS_PRF
        DEPART=[CTR9]ETRSRV
        Break
      Else
        If [CTR9]CTRDAT <= THIS_DAT
          DEPART=[CTR9]ETRSRV
          Break
        Endif
      Endif
    Endif
  Endif
Next

  Filter [CTR9]

For [SRV9]
  If [SRV9]COD = DEPART
    RESULT_VALUE = [SRV9]DES
    Break
  Endif
Next

End RESULT_VALUE

Funprog CHK_EMP_FCY(THIS_REF,THIS_DAT,THIS_FCY,THIS_PRF,THIS_DEP)
Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP
Value Date THIS_DAT
Local Char RESULT_VALUE(30)
Local Char FCYCOD(30)

#initialize
  RESULT_VALUE=''
  FCYCOD=''

#open instances of required tables
  If clalev([F:CTR9])=0 : Local File EMPLOCTR [CTR9] : Endif
  If clalev([F:FCY9])=0 : Local File FACILITY [FCY9] : Endif

#construct link with all the required tables
  Filter [CTR9] Where [CTR9]REFNUM=THIS_REF & ([CTR9]ETRFCY = THIS_FCY | THIS_FCY='') &
& ([CTR9]PROPRF = THIS_PRF| THIS_PRF='') & ([CTR9]ETRSRV = THIS_DEP| THIS_DEP='')
& Order By [CTR9]CTRDAT Desc

#loop and calculate
For [CTR9]
  If [CTR9]CTRDAT <= THIS_DAT & THIS_FCY<>'' & [CTR9]ETRFCY = THIS_FCY
    FCYCOD=[CTR9]ETRFCY
    Break
  Else
    If [CTR9]CTRDAT <= THIS_DAT & THIS_PRF<>''& [CTR9]PROPRF = THIS_PRF
      FCYCOD=[CTR9]ETRFCY
      Break
    Else
      If [CTR9]CTRDAT <= THIS_DAT & THIS_DEP<>'' & [CTR9]ETRSRV = THIS_DEP
        FCYCOD=[CTR9]ETRFCY
        Break
      Else
        If [CTR9]CTRDAT <= THIS_DAT
          FCYCOD=[CTR9]ETRFCY
          Break
        Endif
      Endif
    Endif
  Endif
Next
  Filter [CTR9]

For [FCY9]
  If [FCY9]FCY = FCYCOD
    RESULT_VALUE = [FCY9]FCYNAM
    Break
  Endif
Next
End RESULT_VALUE

Funprog CHK_EMP_JOB(THIS_REF,THIS_DAT,THIS_FCY,THIS_PRF,THIS_DEP)
Value Char THIS_REF,THIS_FCY,THIS_PRF,THIS_DEP
