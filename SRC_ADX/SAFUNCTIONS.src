#FRLAA X3-90587 2018-05-29 - START
#**
#* Round any decimal value up to the nearest integer.
#* @param VALEUR Value Decimal , The value to be rounded
#* @param ROUNDVAL Value Decimal , The nearest integer value needed
#* @return NEW_VALUER Local Decimal
#*!
Funprog RNDUPINT(VALEUR,ROUNDVAL)
Value Decimal VALEUR
Value Integer ROUNDVAL
Local Decimal NEW_VALUER
Local Integer INT_VALEUR

If VALEUR <0
  NEW_VALUER = int(VALEUR)
Else
  NEW_VALUER = int(VALEUR)+ROUNDVAL
Endif

End NEW_VALUER
#FRLAA X3-90587 2018-05-29 - END


#THRAM 2016-10-24 - US X3PEOP-512 - START
Funprog GET_EMP_STATUS(THIS_CRTNUM,THS_STR,THS_END, LEG)
Value Char THIS_CRTNUM
Value Date THS_STR,THS_END
Value Char LEG
Local Date STRDAT, ENDDAT, THIS_STRDAT,THIS_ENDDAT

Local Char RESULT_VALUE(2)
#initialize
  RESULT_VALUE=''
  STRDAT = [0/0/0] : ENDDAT = [0/0/0]
  THIS_STRDAT=gdat$(day(THS_STR),month(THS_STR),year(THS_STR))
  THIS_ENDDAT=gdat$(day(THS_END),month(THS_END),year(THS_END))
#open instances of required tables

  If clalev([F:CTR6])=0 : Local File EMPLOCTR [CTR6] : Endif
  Filter [CTR6]
&     Where  CTRNUM=THIS_CRTNUM & [F:CTR6]CTRNUM<>""

#calculate
  Read [F:CTR6]CTR0 Last
  If !fstat
    Gosub GET_DAT

    Gosub GET_STATUS
  Endif
  Filter [CTR6]

End RESULT_VALUE

$GET_DAT
#get start date
  If [F:CTR6]DATANC >[F:CTR6]DATCRE
    STRDAT =gdat$(day([F:CTR6]DATANC),month([F:CTR6]DATANC),year([F:CTR6]DATANC))
  Else
    If [F:CTR6]DATANC <=[F:CTR6]DATCRE
      STRDAT =gdat$(day([F:CTR6]DATCRE),month([F:CTR6]DATCRE),year([F:CTR6]DATCRE))
    Endif
  Endif

#get end date
  If  LEG = "ZAF"
    If [F:CTR6]XITFNL = 2 & [F:CTR6]XITDAT >[F:CTR6]DATXITFNL
      ENDDAT =gdat$(day([F:CTR6]XITDAT),month([F:CTR6]XITDAT),year([F:CTR6]XITDAT))
    Else
      ENDDAT = gdat$(day([F:CTR6]DATXITFNL),month([F:CTR6]DATXITFNL),year([F:CTR6]DATXITFNL))
    Endif
 Else
    If [F:CTR6]XITFNL = 2 & [F:CTR6]XITDAT >[F:CTR6]DATXITFNL
      ENDDAT = gdat$(day([F:CTR6]DATXITFNL),month([F:CTR6]DATXITFNL),year([F:CTR6]DATXITFNL))
    Else
      ENDDAT = gdat$(day([F:CTR6]DATXITFNL),month([F:CTR6]DATXITFNL),year([F:CTR6]DATXITFNL))
    Endif
  Endif
Return
$GET_STATUS
#Return an employee status

  If STRDAT > THIS_ENDDAT
    RESULT_VALUE ='FT'
  Else
    If (STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT) &
&      ((ENDDAT > THIS_ENDDAT)| (ENDDAT =[0/0/0]))
      RESULT_VALUE ='NW'
    Else
      If (STRDAT < THIS_STRDAT & ENDDAT =[0/0/0])|
&        (STRDAT < THIS_STRDAT & ENDDAT > THIS_ENDDAT)
        RESULT_VALUE ='AT'
      Else
        If STRDAT >= THIS_STRDAT & STRDAT <= THIS_ENDDAT & ENDDAT<>[0/0/0] &
&          ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
          RESULT_VALUE ='NT'
        Else
          If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] &
&            ENDDAT >= THIS_STRDAT & ENDDAT <= THIS_ENDDAT
            RESULT_VALUE ='CT'
          Else
            If STRDAT < THIS_STRDAT & ENDDAT<>[0/0/0] & ENDDAT < THIS_STRDAT
              RESULT_VALUE ='OT'
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

Return
#THRAM 2016-10-24 - US X3PEOP-512 - END

#PITRU 2018-07-03 - X3-97668
#**
#* Calculate periods in service from the date specified by parameter - PERINSERV
#* to the pay date of the last payslip based on the extraction periods for the contract.\
#* Missing extraction periods are added using the period frequency (currently only weekly and monthly)
#*
#* @param REFNUM : Char : Employee number
#* @param CTRNUM : Char : Contract number
#*
#* @return RETVAL : Integer : The number of periods in service
#*
#* Usage example: func SAFUNCTIONS.CALCPERINSERV("CP001", "Z100000010")
#*!
Funprog CALCPERINSERV(REFNUM, CTRNUM)
  Value Char REFNUM()
  Value Char CTRNUM()

  Local Integer RETVAL
  Local Date DATFROM
  Local Date DATTO
  Local Char DATPARM(30)

  [L]DATPARM = func AFNC.PARAM("PERINSERV","")

  [L]RETVAL = 0

  If clalev([F:HRCTR01])=0  : Local File EMPLOCTR   [HRCTR01]  : Endif
  Filter [HRCTR01] Where REFNUM = [L]REFNUM and CTRNUM = [L]CTRNUM & FLGVAR <> 2
  Read [HRCTR01] Last

  Case [L]DATPARM
    When "DATCPY": [L]DATFROM = [HRCTR01]DATCPY
    When "DATFCY": [L]DATFROM = [HRCTR01]DATFCY
    When "DATLIB": [L]DATFROM = [HRCTR01]DATLIB
    When "CTRDAT": [L]DATFROM = [HRCTR01]CTRDAT
    When Default: [L]DATFROM = [HRCTR01]DATANC
  Endcase

  If clalev([F:VEP01])=0  : Local File VALEMP   [VEP01]  : Endif
  Filter [VEP01] Where CTRNUM = [HRCTR01]CTRNUM & REFNUM = [HRCTR01]REFNUM

  Read [VEP01] Last
  [L]DATTO = [VEP01]PYRDAT
  Filter [VEP01]

  If [HRCTR01]XITFNL = 2 & [HRCTR01]XITDAT < [L]DATTO
    [L]DATTO = [HRCTR01]XITDAT
  Endif

  If clalev([F:HRPEOD01])=0 : Local File HRPEODET [HRPEOD01] : Endif
  Filter [HRPEOD01] Where PERCOD = [HRCTR01]PERCOD & [HRPEOD01]PEREND(1) >= [L]DATFROM & [HRPEOD01]PERSTR(1) <= [L]DATTO Order By [HRPEOD01]PYRDAT

  Read [HRPEOD01] First
  If [HRPEOD01]PERSTR > [L]DATFROM
    [L]RETVAL = func CALCMISSINGPERIODS(DATFROM, [HRPEOD01]PERSTR, [HRPEOD01]PERCOD, [HRPEOD01]PERYEA)
  Endif

  [L]RETVAL += rowcount([HRPEOD01])

  Filter [HRCTR01]
  Filter [HRPEOD01]

End [L]RETVAL

#**
#* Calculate periods where extraction periods were not generated based on period frequency
#* (currently only weekly and monthly)
#*
#* @param DATFROM : Date : From date (Should be a date before the first generated extraction period)
#* @param DATTO : Date : To date (Should be period start date from the first extraction period)
#* @param PERCOD: Char : Extraction period code
#* @param PERYEA: Integer : Extraction period year
#*
#* @return RETVAL : Integer : The number of periods in service
#*
#* Usage example: func SAFUNCTIONS.CALCMISSINGPERIODS("20160101", "20160229", "CP01", 2017)
#*!
Funprog CALCMISSINGPERIODS(DATFROM, DATTO, PERCOD, PERYEA)
  Value Date DATFROM
  Value Date DATTO
  Value Char PERCOD
  Value Integer PERYEA

  Local Date DATCALC
  Local Integer RETVAL

  If clalev([F:HRPEOH01])=0 : Local File HRPEOHEA [HRPEOH01] : Endif
  Filter [HRPEOH01] Where PERCOD = [L]PERCOD & PERYEA = [L]PERYEA
  Read [HRPEOH01] Last

  [L]DATCALC = DATTO

  While DATCALC > DATFROM
    Case [HRPEOH01]PAYFRQ
      When 1: DATCALC -= 7
      When 6: DATCALC = addmonth(DATCALC, -1)
      When Default: DATCALC = addmonth(DATCALC, -1)
    Endcase
    RETVAL += 1
  Wend

  Filter [HRPEOH01]

End [L]RETVAL
#PITRU 2018-07-03 - X3-97668 - END

#DESNY 2018-08-13 - X3-100224 - START
Funprog EMAIL_VAL(PARAM_EMAIL,IND)
Value Char PARAM_EMAIL()
Value Char IND
Local Integer K
Local Integer I
Local Integer COUNT
Local Integer COUNT2
Local Integer COUNT3

If IND ='A'
  For K = 1 To len(PARAM_EMAIL)
    If mid$(PARAM_EMAIL,K,1) = '@' Then
      COUNT+=1
    Endif
  Next
Endif

If IND ='B'
  For K = 1 To len(PARAM_EMAIL)
    If mid$(PARAM_EMAIL,K,1) = '@' Then
      COUNT+=1
      If COUNT = 1
        If mid$(PARAM_EMAIL,K+1,1) = '.'
          COUNT2 += 1
        Endif
      Endif
    Endif
  Next
COUNT = COUNT2
Endif


If IND ='C'
  For K = 1 To len(PARAM_EMAIL)
    If mid$(PARAM_EMAIL,K,1) = '@' Then
      COUNT3 += K
    Endif
  Next

COUNT3 += 1

  For I=COUNT3  To len(PARAM_EMAIL)
    If mid$(PARAM_EMAIL,I+1,1) = '.' Then
      COUNT += 1
    Endif
  Next

Endif
End COUNT

Funprog NAT_OF_PRSN(TAXSTA,PARAM_PASNUM,PARAM_RSAID,PARAM_HAB,PARAM_HABEND,PARAM_RECON)
Value Integer TAXSTA
Value Integer PARAM_HABEND
Value Integer PARAM_RECON
Value Char PARAM_RSAID
Value Char PARAM_HAB
Value Char PARAM_PASNUM
Local Char RETVAL(1)

RETVAL=' '

If find(TAXSTA,1,2,3,8,11,13,16,18,19,20,21) <>0
  If (PARAM_HAB <>'AS' and PARAM_HAB <>'RA') or ((PARAM_HAB ='AS'or PARAM_HAB ='RA') and PARAM_HABEND < PARAM_RECON)
    If PARAM_RSAID <>'' or PARAM_PASNUM <>''
      RETVAL ='A'
    Else
      If PARAM_RSAID ='' or PARAM_PASNUM =''
          RETVAL ='B'
      Endif
    Endif
  Endif
Else
    If find(TAXSTA,4,5,6,7,17)<>0
      If (PARAM_HAB <>'AS' and PARAM_HAB <>'RA') or ((PARAM_HAB ='AS'or PARAM_HAB ='RA') and PARAM_HABEND < PARAM_RECON)
          RETVAL ='C'
      Endif
    Endif
Endif



If find(TAXSTA,14,15) <>0
  RETVAL ='H'
Else
  If find(TAXSTA,14,15) =0
    If PARAM_HAB ='AS' and PARAM_HABEND >= PARAM_RECON
      RETVAL ='M'
    Else
      If PARAM_HAB ='RA' and PARAM_HABEND >= PARAM_RECON
        RETVAL ='R'
      Endif
    Endif
  Endif
Endif

End RETVAL
