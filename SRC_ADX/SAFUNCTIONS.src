Funprog PRORAT()
Local Decimal RESULT_VALUE
Local Date    TAXYEARSTART, TAXYEAREND, CALCSTR, CALCEND
Local Date    TAXMONTH

  [L]RESULT_VALUE=0

#calc tax year strat and end
  If month([VEP]STRDAT)>=3
    [L]TAXYEARSTART=gdat$(1,3,year([VEP]STRDAT))
  Else
    [L]TAXYEARSTART=gdat$(1,3,year([VEP]STRDAT)-1)
  Endif
  [L]TAXYEAREND=(gdat$(1,3,year([L]TAXYEARSTART)+1)-1)

#worked until end of tax year and in Feb
  If [ETR]IRPENDDAT=[L]TAXYEAREND & month([VEP]STRDAT)=2
    [L]RESULT_VALUE=([ETR]IRPENDDAT-[ETR]IRPSTRDAT+1)
    End [L]RESULT_VALUE
  Endif

  For I = 1 To 12
    If I < 11
      [L]TAXMONTH=gdat$(1,I+2,year([L]TAXYEARSTART))
    Else
      [L]TAXMONTH=gdat$(1,I-10,year([L]TAXYEAREND))
    Endif

#JASMI - 2017-05-25 - Future terminations - START
    If [HRCTR]XITFNL=2
      [L]RESULT_VALUE=([ETR]IRPENDDAT-[ETR]IRPSTRDAT+1)
      End [L]RESULT_VALUE
    Endif
#JASMI - 2017-05-25 - Future terminations - END

  #only calc YTD
    If eomonth([L]TAXMONTH)>eomonth([VEP]STRDAT)
      Break
    Endif

  #left in this month
    If [ETR]IRPENDDAT>=[L]TAXMONTH & [ETR]IRPENDDAT<=eomonth([L]TAXMONTH)
      [L]RESULT_VALUE=([ETR]IRPENDDAT-[ETR]IRPSTRDAT+1)
      End [L]RESULT_VALUE
    Endif

    [L]CALCSTR=[0/0/0] : [L]CALCEND=[0/0/0]

  #started during month
    If [ETR]IRPSTRDAT>=[L]TAXMONTH & [ETR]IRPSTRDAT<=eomonth([L]TAXMONTH)
      [L]CALCSTR=[ETR]IRPSTRDAT
    Endif

  #full month
    If [ETR]IRPSTRDAT<[L]TAXMONTH
      [L]CALCSTR=[L]TAXMONTH
    Endif
    If [ETR]IRPENDDAT>eomonth([L]TAXMONTH)
      [L]CALCEND=eomonth([L]TAXMONTH)
    Endif

    If ([L]CALCSTR<>[0/0/0]) & ([L]CALCEND<>[0/0/0])
    #full month
      If day([L]CALCSTR)=1 & day([L]CALCEND)=day(eomonth([L]CALCEND))
        [L]RESULT_VALUE=RESULT_VALUE+(([L]TAXYEAREND-[L]TAXYEARSTART+1)/12)
      Else
        [L]RESULT_VALUE=[L]RESULT_VALUE+([L]CALCEND-[L]CALCSTR+1)
      Endif
    Endif
  Next I

End RESULT_VALUE

#THRAM - 2017-06-06 - X3PEOP-21996 - START
Funprog GETRPTSTRDAT(THISPAYMONTH)
Value Date THISPAYMONTH
Local Date RESULT_VALUE

  If month(THISPAYMONTH)<> 12
    RESULT_VALUE = gdat$(01,month(THISPAYMONTH)+1,year(THISPAYMONTH)-1)
  Else
    RESULT_VALUE = gdat$(01,01,year(THISPAYMONTH))
  Endif
End RESULT_VALUE
#THRAM - 2017-06-06 - X3PEOP-21996 - END

#JASMI - 2017-09-11 - X3-55480 - START
#Funprog PRORATAFR(THISREFNUM, THISCTRNUM, THISPAYMONTH)
#Value Char    THISREFNUM, THISCTRNUM
#Value Date    THISPAYMONTH
#
#Local Decimal RESULT_VALUE
#Local Date    TAXYEARSTART, TAXYEAREND, CALCSTR, CALCEND
#Local Date    TAXMONTH
