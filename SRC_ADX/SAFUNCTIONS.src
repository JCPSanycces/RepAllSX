##################################################################################
#Return the day number from a date
Funprog RETURNDAY(PARSEDATE)
Value Date PARSEDATE
Local Integer DAYNUM

DAYNUM=day(PARSEDATE)

End DAYNUM

#####################################################################################
#Return the month number from a date
Funprog RETURNDMON(PARSEDATE)
Value Date PARSEDATE
Local Integer MONNUM

MONNUM=month(PARSEDATE)

End MONNUM

####################################################################################
Funprog RETURNFRACPERIOD(FRACDATE,DATEIND)
Value Date FRACDATE
Value Integer DATEIND
Local Integer DIFFFRACMON
Local Decimal FRACMON
Local Integer STARTDAY
Local Integer STARTMON
Local Date ENDDATE
Local Integer ENDDAY

#Get the start day and month of FRACDATE.
STARTDAY=func RETURNDAY(FRACDATE)
STARTMON=func RETURNDMON(FRACDATE)

#Get the last day of of the month
ENDDATE = eomonth(FRACDATE)

ENDDAY = func RETURNDAY(ENDDATE)
#Get difference between days in the month

If DATEIND = 1 #using start of month
   If STARTDAY = 1# indicats start of month return full 1
      FRACMON = 1
   Else
      DIFFFRACMON = (ENDDAY - STARTDAY) + 1
      FRACMON = DIFFFRACMON/ENDDAY # Get fraction of month
   Endif
Elsif DATEIND = 2
    If STARTDAY = ENDDAY# indicats end of month return full 1
       FRACMON = 1
   Else
       FRACMON = STARTDAY/ENDDAY # Get fraction of month
   Endif
Else
FRACMON = 0#Error
Endif

End FRACMON

#MAPAD - 02/08/2018 - END -X3-86779
#######################################################################################
Funprog GET_PAY_PERIOD_MON(IRPSTRDAT,IRPENDDAT,YEA,XITDAT,XITFNL)
Value Date    IRPSTRDAT, IRPENDDAT,XITDAT
Value Integer  YEA,XITFNL
Local Decimal RESULT_VALUE


Local Integer STARTMON #Start month
Local Integer ENDMON   #End month
Local Integer DIFFMON  #Difference in months
Local Decimal FRACSTARTMON #Fraction of start month
Local Decimal FRACENDMON #Fraction of end month

#Find the min value of either IRPENDDAT or XITDAT

If XITDAT <> [00/00/0000] and XITFNL > 1 Then
IRPENDDAT = min(IRPENDDAT,XITDAT)
Endif


#Get decimal of IRPSTRDAT and IRPENDDAT
FRACSTARTMON = func RETURNFRACPERIOD(IRPSTRDAT,1)
FRACENDMON = func RETURNFRACPERIOD(IRPENDDAT,2)

#Get diff between the months
DIFFMON= (func RETURNDMON(IRPENDDAT) - func RETURNDMON(IRPSTRDAT)) - 1


# check if difference -2 is 12 periods -1 is 11 periods and else is differnce
If DIFFMON <-1 Then
  DIFFMON = DIFFMON + 12
Endif

#faction of first month + fraction of end month + difference in months = Total periods worked
RESULT_VALUE = FRACSTARTMON + FRACENDMON + DIFFMON

End RESULT_VALUE

