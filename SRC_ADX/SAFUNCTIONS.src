#<AdxTL>@(#)0.0.0.0 $Revision$
#MIPEA SOURCE REMERGE
Funprog MODULUS_10_STATUTORY_NUMBERS(INCOMING_NUMBER, NUMBER_TYPE)
Value Char    INCOMING_NUMBER
Value Char    NUMBER_TYPE        #valid types = "PAYE", "SDL", "UIF", "UIFREG",  "ID", "TAX"
Local Integer MESSAGE_NUMBER
Local Integer TEMP_TAX_NUM(1..10)
Local Integer TEMP_RSA_ID_NUM(1..13)
Local Integer CHAR_COUNTER
Local Integer TEMP_CALC1, TEMP_CALC2, TEMP_CALC3
Local Char    TEMP_CHAR1
Local Char    RESULT_VALUE(100)

  RESULT_VALUE = ""

  Case NUMBER_TYPE
    When "PAYE"
      Case left$(INCOMING_NUMBER, 1)
      When "0", "1", "2", "3", "7", "9"
      When Default
        RESULT_VALUE=mess(11, 11662, 1)
        End RESULT_VALUE
      Endcase
      MESSAGE_NUMBER=12
      Gosub PAYE_SDL_UIF
    When "SDL"
      If left$(INCOMING_NUMBER, 1)<>"L"
        RESULT_VALUE=mess(8, 11662, 1)
        End RESULT_VALUE
      Endif
      MESSAGE_NUMBER=9
      Gosub PAYE_SDL_UIF
    When "UIF"
      If left$(INCOMING_NUMBER, 1)<>"U"
        RESULT_VALUE=mess(6, 11662, 1)
        End RESULT_VALUE
      Endif
      MESSAGE_NUMBER=7
      Gosub PAYE_SDL_UIF
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
    When "UIFREG"
      MESSAGE_NUMBER=7
      Gosub UIF_REG_NUM
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - END
    When "ID"
      Gosub RSA_ID_NUMBER
    When "TAX"
      Gosub EMPLOYEE_TAX_NUMBER
    When Default
      RESULT_VALUE=mess(99, 123, 1)
  Endcase

End RESULT_VALUE

$PAYE_SDL_UIF
  If len(vireblc(INCOMING_NUMBER,2))<>10
    RESULT_VALUE=mess(MESSAGE_NUMBER, 11662, 1)
    Return
  Endif

  CHAR_COUNTER=0
  For CHAR_COUNTER = 2 To 10
    If ascii(mid$(INCOMING_NUMBER, CHAR_COUNTER, 1))>=48 & ascii(mid$(INCOMING_NUMBER, CHAR_COUNTER, 1))<=57
      TEMP_TAX_NUM(CHAR_COUNTER)=val(mid$(INCOMING_NUMBER, CHAR_COUNTER, 1))
    Else
      RESULT_VALUE=mess(3, 11662, 1)-num$(CHAR_COUNTER)-mess(4, 11662, 1)
      Return
    Endif
  Next

  TEMP_TAX_NUM(1)=4
  TEMP_CALC1 = TEMP_TAX_NUM(2)+TEMP_TAX_NUM(4)+TEMP_TAX_NUM(6)+TEMP_TAX_NUM(8)

  For CHAR_COUNTER=1 To 9
    TEMP_CALC2=(TEMP_TAX_NUM(CHAR_COUNTER)*2)
    If TEMP_CALC2>9
      TEMP_CALC2=TEMP_CALC2-9
    Endif
    TEMP_CALC1=TEMP_CALC1+TEMP_CALC2
    CHAR_COUNTER=CHAR_COUNTER+1
  Next
  TEMP_CALC2=(10-mod(TEMP_CALC1,10))

#MIPEA - 2018-04-04 X3-85261  START
  If TEMP_CALC2=10
    TEMP_CALC2=0
  Endif
#MIPEA - 2018-04-04 X3-85261  END

  If TEMP_CALC2<>TEMP_TAX_NUM(10)
    RESULT_VALUE=mess(MESSAGE_NUMBER, 11662, 1)
    Return
  Endif

Return

#JASMI - 2015-06-09 - Requirement 108198 US 3581 - START
$UIF_REG_NUM
  If len(vireblc(INCOMING_NUMBER,2))<>8
    RESULT_VALUE=mess(111, 123, 1)
    Return
  Endif

  TEMP_CALC1=0
  CHAR_COUNTER=0
  For CHAR_COUNTER = 1 To 7
    Case CHAR_COUNTER
      When 1
        TEMP_CALC2=1
      When 2
        TEMP_CALC2=2
      When 3
        TEMP_CALC2=4
      When 4
        TEMP_CALC2=5
      When 5
        TEMP_CALC2=7
      When 6
        TEMP_CALC2=8
      When 7
        TEMP_CALC2=2
    Endcase
    TEMP_CALC1+=mod(val(mid$(INCOMING_NUMBER, CHAR_COUNTER, 1))*TEMP_CALC2, 11)
  Next

  TEMP_CALC2=mod(TEMP_CALC1,10)

  If TEMP_CALC2<>val(mid$(INCOMING_NUMBER, 8, 1))
    RESULT_VALUE=mess(MESSAGE_NUMBER, 11662, 1)
    Return
  Endif

Return
#JASMI - 2015-06-09 - Requirement 108198 US 3581 - END

$RSA_ID_NUMBER
  If len(vireblc(INCOMING_NUMBER,2))<>13
    RESULT_VALUE=mess(1,11662,1)
    Return
  Endif

  CHAR_COUNTER=0
  For CHAR_COUNTER=1 To 13
    If ascii(mid$(INCOMING_NUMBER,CHAR_COUNTER,1))>=48 &ascii(mid$(INCOMING_NUMBER,CHAR_COUNTER,1)) <=57
      TEMP_RSA_ID_NUM(CHAR_COUNTER)=val(mid$(INCOMING_NUMBER,CHAR_COUNTER,1))
    Else
      RESULT_VALUE=mess(3,11662,1)-num$(CHAR_COUNTER)-mess(4,11662,1)
      Return
    Endif
  Next

  TEMP_CALC1=TEMP_RSA_ID_NUM(1)+TEMP_RSA_ID_NUM(3)+TEMP_RSA_ID_NUM(5)+TEMP_RSA_ID_NUM(7)+TEMP_RSA_ID_NUM(9)+TEMP_RSA_ID_NUM(11)
  TEMP_CALC2=(TEMP_RSA_ID_NUM(2)*100000)+(TEMP_RSA_ID_NUM(4)*10000)
&           +(TEMP_RSA_ID_NUM(6)*1000)+(TEMP_RSA_ID_NUM(8)*100)+(TEMP_RSA_ID_NUM(10)*10)+(TEMP_RSA_ID_NUM(12))
  TEMP_CALC2=TEMP_CALC2*2
  TEMP_CHAR1=num$(TEMP_CALC2)

  For CHAR_COUNTER=1 To val(string$(TEMP_CALC2<1000000,"6")+string$(TEMP_CALC2>=1000000,"7"))
    TEMP_CALC3+=val(mid$(TEMP_CHAR1,CHAR_COUNTER,1))
  Next

  TEMP_CALC3+=TEMP_CALC1
  TEMP_CALC3=mod(TEMP_CALC3,10)

  If TEMP_CALC3<>0
    TEMP_CALC3=10-TEMP_CALC3
  Endif

  If TEMP_CALC3<>TEMP_RSA_ID_NUM(13)
    RESULT_VALUE=mess(1,11662,1)
  Endif

Return

$EMPLOYEE_TAX_NUMBER
  If len(vireblc(INCOMING_NUMBER,2))<>10
    RESULT_VALUE=mess(2,11662,1)
    Return
  Endif

  CHAR_COUNTER=0
  For CHAR_COUNTER=1 To 10
    If ascii(mid$(INCOMING_NUMBER,CHAR_COUNTER,1))>=48 &ascii(mid$(INCOMING_NUMBER,CHAR_COUNTER,1)) <=57
      TEMP_TAX_NUM(CHAR_COUNTER)=val(mid$(INCOMING_NUMBER,CHAR_COUNTER,1))
    Else
      RESULT_VALUE=mess(3,11662,1)-num$(CHAR_COUNTER)-mess(4,11662,1)
      Return
    Endif
  Next

  TEMP_CALC1=(TEMP_TAX_NUM(1)*100)+(TEMP_TAX_NUM(2)*10)+TEMP_TAX_NUM(3)
  If TEMP_CALC1<799 & TEMP_CALC1>700
    TEMP_TAX_NUM(1)=4
  Endif

  TEMP_CALC2=TEMP_TAX_NUM(2)+TEMP_TAX_NUM(4)+TEMP_TAX_NUM(6)+TEMP_TAX_NUM(8)

  For CHAR_COUNTER=1 To 9
    TEMP_CALC3=(TEMP_TAX_NUM(CHAR_COUNTER)*2)
    If TEMP_CALC3>9
      TEMP_CALC3=TEMP_CALC3-9
    Endif
    TEMP_CALC2=TEMP_CALC2+TEMP_CALC3
    CHAR_COUNTER=CHAR_COUNTER+1
  Next

  TEMP_CALC3=(10-mod(TEMP_CALC2,10))
#JASMI - 2015-05-21 - Requirement number: 108372 - START
  If TEMP_CALC3=10
    TEMP_CALC3=0
  Endif
#JASMI - 2015-05-21 - Requirement number: 108372 - END

  If TEMP_CALC3<>TEMP_TAX_NUM(10)
    RESULT_VALUE=mess(2,11662,1)
  Endif

Return

#JASMI - 2015-11-18 - REQ. 104630 - START
Funprog NEW_IPR5_CERT_NO(EXTRACT_TEMPLATE, CPY_PAYE_NO, TAX_PERIOD,
& CPY_CODE, THISREFNUM, THISCTRNUM, THISCTRDAT, LIVE_IND, CURR_CERT_NUM, XITDAT, XITFNL)
Value Char    EXTRACT_TEMPLATE, CPY_PAYE_NO, TAX_PERIOD, CPY_CODE
Value Char    THISREFNUM, THISCTRNUM, LIVE_IND, CURR_CERT_NUM
Value Date    THISCTRDAT
Value Date    XITDAT
Value Integer XITFNL
Local Char    RESULT_VALUE(30)
Local Integer LAST_NUMBER

  RESULT_VALUE=""
  LAST_NUMBER=0

  If CURR_CERT_NUM<>""
    RESULT_VALUE=CURR_CERT_NUM
    End RESULT_VALUE
  Endif

  If CPY_PAYE_NO="" or TAX_PERIOD="" or CPY_CODE=""
    End RESULT_VALUE
  Endif

  If clalev([F:ETR2])=0 : Local File EMPLOTAXREC [ETR2] : Endif

  If EXTRACT_TEMPLATE="TAXRUN_MIDYEAR"
    Filter [ETR2] Where REFNUM= THISREFNUM and CTRNUM=THISCTRNUM and TAXYEA=(val(left$(TAX_PERIOD,4))+1)
    Read [ETR2]ETR0 Last
  Else
      Filter [ETR2] Where REFNUM= THISREFNUM and CTRNUM=THISCTRNUM and TAXYEA=(val(left$(TAX_PERIOD,4)))
    Read [ETR2]ETR0 Last
  Endif



  If fstat
  #no tax record found
    RESULT_VALUE="No tax record"
    End RESULT_VALUE
  Else
#  #if validation run, skip number generation
#    If EXTRACT_TEMPLATE="TAXRUN_VALIDATIONS"
#      RESULT_VALUE="Validation run only"
#      End RESULT_VALUE
#    Endif
    If EXTRACT_TEMPLATE="TAXRUN_MIDYEAR"
      If [F:ETR2]CERNUMEND=""
        If [F:ETR2]CERNUMMID=""
          Gosub NEW_IPR5_CERT_NO_ALLOCATION
        Else
          RESULT_VALUE=[F:ETR2]CERNUMMID
        Endif
      Else
        RESULT_VALUE=[F:ETR2]CERNUMEND
        End RESULT_VALUE
      Endif
    Else
      If [F:ETR2]CERNUMEND=""
      #for resub runs, live run must exist, else generate new number
        Case EXTRACT_TEMPLATE
          When "TAXRUN_RESUB_NEW_NO", "TAXRUN_RESUB_SAME_NO"
            RESULT_VALUE="No previous live run"
            End RESULT_VALUE
          When Default
            Gosub NEW_IPR5_CERT_NO_ALLOCATION
        Endcase
      Else
      #for resub new number run, generate new number, else use existing
        If EXTRACT_TEMPLATE="TAXRUN_RESUB_NEW_NO"
          Gosub NEW_IPR5_CERT_NO_ALLOCATION
        Else
          RESULT_VALUE=[F:ETR2]CERNUMEND
          End RESULT_VALUE
        Endif
      Endif
    Endif
  Endif

End RESULT_VALUE

$NEW_IPR5_CERT_NO_ALLOCATION
#get last certificate numbers
  Filter [F:ETR2]
  If EXTRACT_TEMPLATE="TAXRUN_MIDYEAR"
  #THRAM - 2018-08-16 - Requirement number: X3-98007 - START
    STRDAT = gdat$(01,03,val(left$(TAX_PERIOD,4)))
    STREND = gdat$(31,08,val(left$(TAX_PERIOD,4)))
    If XITDAT >= STRDAT & XITDAT <= STREND & XITFNL = 2
      TAX_PERIOD = num$((val(left$(TAX_PERIOD,4))+1))+'02'
    Else
      TAX_PERIOD = num$((val(left$(TAX_PERIOD,4))+1))+num$((right$(TAX_PERIOD,5)))
    Endif
    #THRAM - 2018-08-16 - Requirement number: X3-98007 - END
    Filter [F:ETR2]
&     Where  left$([F:ETR2]CERNUMMID,24)=CPY_PAYE_NO+TAX_PERIOD+"SGEX3"+left$(CPY_CODE,3)
    If rowcount([F:ETR2])>0
      Read [F:ETR2]ETR2 Last
      If !fstat
        LAST_NUMBER=val(mid$([F:ETR2]CERNUMMID,25,6))
      Endif
    Endif
    Filter [F:ETR2]
  Else
    Filter [F:ETR2]
&     Where  left$([F:ETR2]CERNUMEND,24)=CPY_PAYE_NO+TAX_PERIOD+"SGEX3"+left$(CPY_CODE,3)
    If rowcount([F:ETR2])>0
      Read [F:ETR2]ETR3 Last
      If !fstat
        LAST_NUMBER=val(mid$([F:ETR2]CERNUMEND,25,6))
      Endif
    Endif
    Filter [F:ETR2]
  Endif

#assign new certificate number
  LAST_NUMBER+=1
  RESULT_VALUE=CPY_PAYE_NO+TAX_PERIOD+"SGEX3"+left$(CPY_CODE,3)+format$("N0:6",LAST_NUMBER)

#store new number
  If EXTRACT_TEMPLATE="TAXRUN_MIDYEAR"
    Update [F:ETR2]
&   Where  [F:ETR2]REFNUM=THISREFNUM & [F:ETR2]CTRNUM=THISCTRNUM
&   With   [F:ETR2]CERNUMMID=RESULT_VALUE
  Else
    Update [F:ETR2]
&   Where  [F:ETR2]REFNUM=THISREFNUM & [F:ETR2]CTRNUM=THISCTRNUM
&   With   [F:ETR2]CERNUMEND=RESULT_VALUE
  Endif

Return
#JASMI - 2015-11-18 - Req. 104630 - END

Funprog MOD_10_NEDBANK(THIS_USER, ACTION)
Value Char    THIS_USER
Value Char    ACTION
Local Char    STORED_VALUE(32)
Local Integer CHAR_COUNTER
Local Integer TEMP_CALC_CHAR_1(1..32), TEMP_CALC_CHAR_2(1..32), TEMP_CALC_CHAR_3(1..32)
Local Char    RESULT_VALUE(32)
Local Char    VALUE_TO_ADD(32)

  If ACTION=""
    RESULT_VALUE="Error - No action supplied"
    End RESULT_VALUE
  Endif

  If clalev([F:HRTNM])=0 : Local File HRTMPNBMOD10 [HRTNM] : Endif

  Case ACTION
    When "START"
      STORED_VALUE = "00000000000000000000000000000000"
      VALUE_TO_ADD = format$("N0:32", [F:BAN]IBACOD)
      Gosub MOD_10_NEDBANK_ADD_VALUES
    When "NEXT"
      Read [F:HRTNM]HRTNM0 = THIS_USER
      If !fstat
        STORED_VALUE = [F:HRTNM]TMPVAL
        VALUE_TO_ADD = format$("N0:10", [F:STL]AMT*100)+
&                      format$("N0:16", [F:STL]BIDNUM)+
&                      format$("N0:6",  [F:STL]BANBRCNUM)
        Gosub MOD_10_NEDBANK_ADD_VALUES
        VALUE_TO_ADD = format$("N0:10", [F:BAN]BIDNUM)+
&                      format$("N0:16", 0)+
&                      format$("N0:6",  0)
        Gosub MOD_10_NEDBANK_ADD_VALUES
      Else
        RESULT_VALUE="Error - No temp vaue"
        End RESULT_VALUE
      Endif
    When "LAST"
      Read [F:HRTNM]HRTNM0 = THIS_USER
      If !fstat
        STORED_VALUE = [F:HRTNM]TMPVAL
      Else
        RESULT_VALUE="Error - No temp vaue"
        End RESULT_VALUE
      Endif
    When Default
      RESULT_VALUE="Error - Incorrect action"
      End RESULT_VALUE
  Endcase

  Read [F:HRTNM]HRTNM0 = THIS_USER
  [F:HRTNM]TMPUSR = THIS_USER
  If ACTION="LAST"
    [F:HRTNM]TMPVAL = "00000000000000000000000000000000"
  Else
    [F:HRTNM]TMPVAL = STORED_VALUE
  Endif
  If !fstat
    Rewrite [F:HRTNM]
  Else
    Write [F:HRTNM]
  Endif
  If fstat
    RESULT_VALUE="Error - Update failed"
    End RESULT_VALUE
  Endif

  RESULT_VALUE=STORED_VALUE

End RESULT_VALUE

$MOD_10_NEDBANK_ADD_VALUES
  For CHAR_COUNTER = 1 To 32
    If ascii(mid$(STORED_VALUE, CHAR_COUNTER, 1))>=48 & ascii(mid$(STORED_VALUE, CHAR_COUNTER, 1))<=57
      TEMP_CALC_CHAR_1(CHAR_COUNTER)=val(mid$(STORED_VALUE, CHAR_COUNTER, 1))
    Else
      RESULT_VALUE="Error - Non-numeric character"
      End RESULT_VALUE
    Endif
    If ascii(mid$(VALUE_TO_ADD, CHAR_COUNTER, 1))>=48 & ascii(mid$(VALUE_TO_ADD, CHAR_COUNTER, 1))<=57
      TEMP_CALC_CHAR_2(CHAR_COUNTER)=val(mid$(VALUE_TO_ADD, CHAR_COUNTER, 1))
    Else
      RESULT_VALUE="Error - Non-numeric character"
      End RESULT_VALUE
    Endif
    TEMP_CALC_CHAR_3(CHAR_COUNTER)=mod(TEMP_CALC_CHAR_1(CHAR_COUNTER)
&                                     +TEMP_CALC_CHAR_2(CHAR_COUNTER),10)
  Next CHAR_COUNTER

  STORED_VALUE=""
  For CHAR_COUNTER = 1 To 32
    STORED_VALUE+=num$(TEMP_CALC_CHAR_3(CHAR_COUNTER))
  Next CHAR_COUNTER

Return

#FRLAA  - 2015/09/07 - REQUIREMENT 110018 - US 3897 - START
Funprog EXTFUNORG(VCTRNUM,VREFNUM, VCTRDAT,VORG329, VTYP)
Value Char VCTRNUM, VREFNUM
Value Integer VORG329, VTYP
Value Date VCTRDAT
Local Char EMP : EMP = VREFNUM
Local Char CTR : CTR = VCTRNUM
Local Char MORG(10) : MORG = ""
Local Char MNUMAFF(35) : MNUMAFF = ""
Local Char MNUMCTR(35) : MNUMCTR = ""
Local Integer I : I = VORG329
Local Integer MLEVAFF : MLEVAFF = 0
#MIPEA - 2016-11-07 - X3PEOP-773- START
Filter [HRCTR] Where REFNUM=EMP & CTRNUM=CTR & CTRDAT = VCTRDAT
Read [HRCTR]CTR1 Last
Filter [HRCTR]
#Filter [CTR] Where REFNUM=EMP & CTRNUM=CTR & CTRDAT = VCTRDAT
#Read [CTR]CTR1 Last
#Filter [CTR]
#MIPEA - 2016-11-07 - X3PEOP-773- END
If !fstat
#MIPEA - 2016-11-07 - X3PEOP-773- START
  Call ORGANISME_LEV([F:HRCTR]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,MORG,I-1,MLEVAFF) From SUBORG
  If MORG <>""
   Call ORGAFFIL_LEV(MORG,[F:HRCTR]ETRFCY,[F:HRCTR]REFNUM,[F:HRCTR]CTRNUM,MNUMAFF,
&                    MNUMCTR,MLEVAFF) From SUBORA
#  Call ORGANISME_LEV([F:CTR]REFNUM,[F:CTR]ETRFCY,[F:CTR]CTRNUM,MORG,I-1,MLEVAFF) From SUBORG
#  If MORG <>""
#   Call ORGAFFIL_LEV(MORG,[F:CTR]ETRFCY,[F:CTR]REFNUM,[F:CTR]CTRNUM,MNUMAFF,
#&                    MNUMCTR,MLEVAFF) From SUBORA
#MIPEA - 2016-11-07 - X3PEOP-773- END

    If VTYP = 2 : End MNUMAFF : Endif
  Endif
Endif

End MORG
#FRLAA  - 2015/09/07 - REQUIREMENT 110018 - US 3897 - END

