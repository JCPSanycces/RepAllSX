#     If [F:CNE]TIM<>VALEUR
#      GMESSAGE = mess(165,709,1)-num$([F:CNG]YEA) : # Fiche congé par employé inexistante pour l'année
#      mkstat = 2 : Break 3
#     Endif
#     [L]NBJ+=[F:CNE]NBRDAY-[F:CNE]NBRPRI
#     I      =1
#     # fiche 77494 - 31/10/2011
##JASMI - 2014/08/31 - START
##     If [L]DEBTOL = [0/0/0] | [L]DEBTOL > [F:CNG]DEBDAT
##       [L]DEBTOL = [F:CNG]DEBDAT
