#& &          [CTRAFR7]TAXSTRDAT>=[L]TAXYEARSTART & [CTRAFR7]TAXENDDAT<=[L]TAXYEAREND
#&   Order By [CTR7]CTRDAT Desc
#
##worked until end of tax year and in Feb
#  If [CTRAFR7]TAXENDDAT=[L]TAXYEAREND & month(THISPAYMONTH)=2
#    [L]RESULT_VALUE=([CTRAFR7]TAXENDDAT-[CTRAFR7]TAXSTRDAT+1)
#    End [L]RESULT_VALUE
#  Endif
