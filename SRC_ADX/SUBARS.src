#<AdxTL>@(#)6.0.0.0 $Revision$
Call OBJET("ARS",GBIDC2,GBIDC3) From GOBJET
End

#--------------------------------#  
#--------------------------------#  
$ACTION
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "TIROIR"      : Gosub TIROIR
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "GAUCHE"      : Gosub GAUCHE
 When "SETBOUT"     : Gosub SETBOUT 
 When "EXEBOUT"     : Gosub EXEBOUT  
 When default
Endcase
Return


#--------------------------------#  
#--------------------------------#  
$OUVRE_BOITE
Local Char BROWA(20) , BROWB(20)
I = find("AR1",OBJLIS(1..dim(OBJLIS)-1))
If I
 BROWA = "GAU_CHE"+num$(I)
Endif
I = find("AR3",OBJLIS(1..dim(OBJLIS)-1))
If I
 BROWB = "GAU_CHE"+num$(I)
Endif
Return

#--------------------------------#  
#--------------------------------#  
$TIROIR  
If currbox = BROWA
  Gosub FILGAUCHE
  # comme GOBJSUB bug 17798 (28/03/03)
  FILTREG = 1     
  Gosub REMPLIT_1 From ="WG"+GBOITE  
Endif
Return


#--------------------------------#  
#--------------------------------#  
$GAUCHE  
Return  

#--------------------------------#  
#--------------------------------#  

$FILGAUCHE  
If currbox = BROWA
    # liste des manquants : sans correspondance et inexistant dans ATEXTE
    # TYP = 1 et FLGTXT = 1
    FILGAUSUP(0) = '[F:ARS]TYP= 1 & [F:ARS]FLG <> 2 & [F:ARS]FLGTXT <> 2'
Elsif currbox = BROWB
    FILGAUSUP(0) = '[F:ARS]TYP= 2 & [F:ARS]FLG <> 2'
Endif
Return


#------------------------------------------#  
# Désactivation bouton "Creation texte"    #  
#------------------------------------------#  
$SETBOUT  
If GREP="C" or GREP="M" or !CLECUR 
    Call virebout(chaine,"13") From GOBJET 
Else
    CHMEN = "A"
    If [M]FLG = 2
        Call virebout(chaine,"13") From GOBJET 
    Endif
    If [M]TYP = 2
        Call virebout(CHAINE,"3") From GOBJET 
    Endif
Endif  
Return  

#-------------------------------#  
# Après appui sur bouton "Test" #  
#-------------------------------#  
$EXEBOUT  
Case REP  
  When "1" :   Call FLAG_ENREG
  When Default  
Endcase  
Return  


Subprog FLAG_ENREG
# on flague enreg  apres creation du texte
If GOK = 1
    [M]FLG = 2
    Update [ARS] Where lan = [M]LAN and NUMERO = [M]NUMERO and VERORI = [M]VERORI With FLG = [M]FLG
    Affzo [M]
Endif

End





