#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# Traitement TRTSTCD -  Gestion de l'écran de saisie de la structure-V7 #
#                       à la ligne de document           MUARN 16/05/13 #
#########################################################################

$ACTION
Case ACTION
  When "INIT"          : Gosub INIT
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "AVANT_MOD"     : Gosub AVANT_MOD
  When "APRES_MODIF"   : Gosub APRES_MODIF
  When "ENR"           : Gosub ENR
  When "ABA"           : Gosub ABA
  When "SETBOUT"       : Gosub SETBOUT
  When "FIN"           : Gosub FIN
  When "FINSAI"        : Gosub FINSAI
  When "APRES_MODI"    : Gosub APRES_MODIF
  When Default
Endcase
Return


#########################################################################
$INIT
#si variable globale GOUVSTC < 1 on sort
If GOUVSTC < 1
  FIN = 1
  Return
Endif
Return

#########################################################################
$OUVRE

Global Integer GNOLIG
Global Char    GLABR
Global Char    GBPSNUM
Global Date    GDAT
Global Decimal WSTCAMT, WSTCAMTVAL
Global Char    GICT           # code incoterm
# Issue 89349-4 - 2013-12-17 by SR : Rapprochement
Global Char     GFLGFMT(20) : GFLGFMT = "NP:1#"

Local Integer SAVSTCLIN
Local Char    LABR            # abréviation écran
Local Integer LNOL            # No ligne courante (nolign-1) masque origine
Local Integer LRET
Local Integer WGENR           # 1 si on a enregistré , 0 sinon
Local Char    CURDOC
Local Integer LCHGTYP
Local Integer LVCRTYP
Local Char    LVCRNUM
Local Integer LVCRLIN
Local Integer LVCRSEQ

If clalev([F:FCS])=0     Local File FRECST       [FCS]    Endif
If clalev([F:STCD])=0    Local File COSTSTCD     [STCD]   Endif
If clalev([F:STCL])=0    Local File COSTSTCL     [STCL]   Endif
If clalev([F:TUN])=0     Local File TABUNIT      [TUN]    Endif
# Issue 89349-4 - 2013-12-23 by SR : Mauvais clalev
If clalev([F:TCU])=0     Local File TABCUR       [TCU]    Endif
If clalev([F:ICTD])=0    Local File INCOTERMD    [ICTD]   Endif

If clalev([M:STCDW])=0
  Local Mask STCDW   [STCDW]
Endif

Raz WGENR
LABR      = PARAM(1)
LNOL      = val(PARAM(2))
CURDOC    = PARAM(3)
LCHGTYP   = val(PARAM(4))
LVCRTYP   = val(PARAM(5))
LVCRNUM   = PARAM(6)
LVCRLIN   = val(PARAM(7))
LVCRSEQ   = val(PARAM(8))
GLABR     = LABR
GNOLIG    = LNOL
GICT      = PARAM(9)
GBPSNUM   = PARAM(10)
GDAT      = PARAM(11)

Call INIVAR From GLOBTC

For I=1 To 20
  If I<= GNBDIE
    Assign "GWSINVCCE"+num$(I) With evalue("GSINVCCE"+num$(I))
  Else
    Assign "GWSINVCCE"+num$(I) With "-"+evalue("GSINVCCE"+num$(I))
  Endif
Next
Return

#########################################################################
$DEBUT
#-----------------------------------------------------------------------
# Traitement à alimenter pour les différentes fonctions
#-----------------------------------------------------------------------
Local Integer LNBLIG
# Issue 89349-4 - 2013-12-17 by SR : Rapprochement
# flag rapproché invisible en commande
If LABR <> "PTH1"
  GFLGFMT = "-NP:1#"
Else
  GFLGFMT = "NP:1#"
Endif

Raz [M:STCD]
Affzo [M:STCD]
[M:STCD]NBLIG = 0
Call CHARGE_PARAM(LABR,LNOL,LRET,GICT) From STCLIB
# Si ligne existante(déjà créée) ou en cours de saisie(fin de ligne éxécutée)
# on regarde si [M:STCDW] est déjà chargé,
# dans le cas contraire on l'alimente à partir de la table COSTSTCD
# Le [STCDW] est-il déjà chargé pour cette ligne ?
WCHARGSTCW=1
If [M:STCD]WSTCSEQ<>0 & [M:STCDW]NBLIG>0
   If find(evalue("[M:"+LABR+"]WSTCSEQ(LNOL)"),[M:STCDW]WSTCSEQ(0,[M:STCDW]NBLIG-1))<>0
      Raz WCHARGSTCW
   Endif
   #---
Endif

LNBLIG = evalue("[M:"+LABR+"]NBLIG")
# Il n'est pas déjà chargé --> on l'alimente à partir de la table COSTSTCD
If WCHARGSTCW=1
   Call WSTCSEQ (LABR,LNOL,LNBLIG,LRET) From STCLIB
   [M:STCD]WSTCSEQ = evalue("[M:"+LABR+"]WSTCSEQ(LNOL)")
   Call COSTSTCD_STCDW(LABR,LNOL,LVCRTYP,LVCRNUM,LVCRLIN,LVCRSEQ,GICT,LRET) From STCLIB
Endif

# Alimentation du masque STCD
Call STCDW_STCD(LABR,LNOL,LRET) From STCLIB

If FIN=1 Return Endif

# On affiche une première fois avant d'affecter les styles, sinon, ça ne marche pas correctement
If [M:STCD]NBLIG>0
   Affzo [M:STCD]1-99
Endif

# une commande partiellement ou totalement réception ou facturée,
# et une réception partiellement ou totalement facturée
# les charges sont non modifiables
# si elles le deviennent modifier la gestion des charges lors de la modification
# d'une ligne de réception de commande

If (LABR = "POH2" & evalue("[M:"+LABR+"]LINRCPNBR(LNOL)")=0 & evalue("[M:"+LABR+"]LININVNBR(LNOL)")=0)
& | (LABR = "PTH1" & evalue("[M:"+LABR+"]POHNUM(LNOL)")="" & (evalue("[M:"+LABR+"]INVQTYSTU(LNOL)")=0) )
  For I=0 To [M:STCD]NBLIG-1
    # Issue 89349-4 - 2013-12-17 by SR : Pas de modif si charge rapprochée
    If [M:STCD]CSTPYR(I) = 1 | [M:STCD]CSTPYR(I)=3 | [M:STCD]STCRFLG(I) = 2
      Grizo [M:STCD]PRINETPRC(I)
      Grizo [M:STCD]UNTPRI(I)
      Grizo [M:STCD]CURIMP2(I)
      Grizo [M:STCD]QTY(I)
      Grizo [M:STCD]UOM(I)
      Grizo [M:STCD]WEIPRC(I)
      Grizo [M:STCD]FORFCS(I)
      Grizo [M:STCD]PRCBUY(I)
      Grizo [M:STCD]BAS(I)
      Grizo [M:STCD]FCSAMT(I)
      If [M:STCD]STCLIN(I)=0
        Actzo [M:STCD]FCSCOD(I)
      Else
        Diszo [M:STCD]FCSCOD(I)
      Endif
    Else
      Gosub GRISE
    Endif
  Next I
Elsif (LABR = "POH2" & (evalue("[M:"+LABR+"]LINRCPNBR(LNOL)")<>0 | evalue("[M:"+LABR+"]LININVNBR(LNOL)")<>0)) |
& ( LABR ="PTH1" & (evalue("[M:"+LABR+"]INVQTYSTU(LNOL)")<>0) ) | LABR="PIH3"
  Grizo [M:STCD]
Else
  For I=0 To [M:STCD]NBLIG-1
    Grizo [M:STCD]PRINETPRC(I)
    Grizo [M:STCD]UNTPRI(I)
    Grizo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Grizo [M:STCD]UOM(I)
    Grizo [M:STCD]WEIPRC(I)
    Grizo [M:STCD]FORFCS(I)
    Grizo [M:STCD]PRCBUY(I)
    Grizo [M:STCD]BAS(I)
    # Issue 89349 - 2014-01-16 by SR : Rapprochement
    If [M:STCD]STCRFLG(I) = 2 : Grizo [M:STCD]FCSAMT(I) : Endif
  Next I
Endif
# Issue 89160 - 2018-05-03 by SR :Avec la nouvelle méthode, en cours de création de réception,
# on peut arriver ici avec une qté facturée = 0 mais on aura quand même des factures à
# prendre en compte,  donc les charges ne doivent pas être modifiables
If LABR = "PTH1" & [M:PTH1]POHNUM(LNOL) <> "" & [M:PTH1]CREFLG(LNOL) = 0 & GPRIFLG = 2
  If [F:POH]POHNUM <> [M:PTH1]POHNUM(LNOL)
    Read [F:POH]POH0 = [M:PTH1]POHNUM(LNOL)
    If fstat : Raz [F:POH] : Endif
  Endif
  If GPSVSTRDAT <= [F:POH]CREDAT
      Filter [PID] Where TYPORI=1
&                  & NUMORI=[M:PTH1]POHNUM(LNOL)
&                  & LINORI=[M:PTH1]POPLIN(LNOL)
&                  & SEQORI=[M:PTH1]POQSEQ(LNOL)
&                  & PIHTYP=1
&                  Order By Key PID1
     For [PID]
        Read [PIH] PIH0=[F:PID]NUM : If fstat  Raz [F:PIH] : Endif
        # La ligne de réception en cours de création sera au moins partiellement facturée par une facture sur commande
        # Les charges ne doivent pas être modifiables
        If [F:POQ]INVQTYSTU-[F:POQ]RCPQTYSTU > 0 : Grizo [M:STCD] : Break : Endif
      Next
      Filter [F:PID]
  Endif
Endif
# End issue 89160
# Somme de tous les montants
[M:STCD]FCSCSTPUR    = sum([M:STCD]FCSAMTSOC(0..[M:STCD]NBLIG-1))
# Somme des montants valorisés
[M:STCD]FCSCPR = sigma(I=0,[M:STCD]NBLIG-1, [M:STCD]FCSAMTSOC(I) *([M:STCD]STKVLT(I) = 2))

If [M:STCD]NBLIG>0
   Affzo [M:STCD]1-99
Endif


Diszo [M:STCD]EECICT2

Return

#########################################################################
$AVANT_MOD
If OK=0 & (GSTAIMG(3) | GSTAIMG(11))
  If GSTAIMG(11)
    GMESSAGE=mess(11,139,1) : GERR=2
  Endif
Endif
Return


#########################################################################
$APRES_MODIF
If OK=0 & (GSTAIMG(3) | GSTAIMG(11))
  If GSTAIMG(11)
    GMESSAGE=mess(11,139,1) : GERR=2
  Endif
Endif

If find(COUZON,"UNTPRI","CURIMP2","QTY","UOM","PRINETPRC","WEIPRC","PRCBUY")
  [M:STCD]STCUPD(nolign-1)=1
Endif

# Si type de cours document, récupération de celui-ci
If COUZON="FCSCOD"
  If [M:STCD]DOCCHGTYP(nolign-1)=2
    [M:STCD]CHGTYP(nolign-1)=LCHGTYP
  Endif
Endif

Return


#########################################################################
$ABA

WPICK=1
GCHARGRUPT = ""
Call STCDW_STCD(LABR,LNOL,LRET) From STCLIB
# Somme de tous les montants
[M:STCD]FCSCSTPUR    = sum([M:STCD]FCSAMTSOC(0..[M:STCD]NBLIG-1))
# Somme des montants valorisés
[M:STCD]FCSCPR = sigma(I=0,[M:STCD]NBLIG-1, [M:STCD]FCSAMTSOC(I) *([M:STCD]STKVLT(I) = 2))
Affzo [M]1-99
WPICK=2
Return

#########################################################################
$ENR

# Issue X3-94027 - 2018-06-27 by MUARN : faire un raz de STCDW avant
Call DELSTCDW(LNOL,LNOL,LABR,LRET) From STCLIB

Call STCD_STCDW(LABR,LNOL,LRET) From STCLIB


# On a enregistré
WGENR = 1
FIN   = 1

Assign "[M:"+LABR+"]FCSCSTPUR(LNOL)" With [M:STCD]FCSCSTPUR
Assign "[M:"+LABR+"]FCSCPR(LNOL)"    With [M:STCD]FCSCPR

Return

#########################################################################
$AB_TRT
Rollback
Return

#########################################################################
$SETBOUT

If (LABR = "POH2" & (evalue("[M:"+LABR+"]LINRCPNBR(LNOL)")<>0 | evalue("[M:"+LABR+"]LININVNBR(LNOL)")<>0))
& | (LABR = "PTH1" & (evalue("[M:"+LABR+"]INVQTYSTU(LNOL)")<>0)) | (LABR = "PIH3")
  Call VIREBOUT(CHAINE,"A") From GOBJET
  Call VIREBOUT(CHAINE,"E") From GOBJET
Else
  If !find("=",CHBOU) CHBOU+="=" Endif
  If !find("A",CHBOU) CHBOU+="A" Endif
  If !find("E",CHBOU) CHBOU+="E" Endif
Endif

Return


#########################################################################
$FIN
# Si on a pas enregistré
If WGENR<>1
   Goto FIN_SUI
Endif
Raz [M:STCD]

$FIN_SUI

Return


#########################################################################
$FINSAI

Assign "[M:"+LABR+"]UPDFLG(LNOL)" With 1


# SI ON A ENREGISTRÉ & ACCÉS PAR BOUTON --> BOUTON 'Enregistrer' DANS LE DOCUMENT
# Ne pas positionner mkstat dans les autres cas, car les actions suivantes ne
# seraient pas exécutées (ex: TRTCRENOM dans les livraisons)
If WGENR=1 & GREP="" mkstat=4 Endif

Return

######################################################################
$GRISE
If [M:STCD]STCLIN(I)=0
  Actzo [M:STCD]FCSCOD(I)
Else
  Diszo [M:STCD]FCSCOD(I)
Endif
Case [M:STCD]DIRCLCMOD(I)
  When 1    #prix net
    Actzo [M:STCD]FCSAMT(I)
    Actzo [M:STCD]PRINETPRC(I)
    Grizo [M:STCD]UNTPRI(I)
    Grizo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Grizo [M:STCD]UOM(I)
    Grizo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When 2    #forfait
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Actzo [M:STCD]UNTPRI(I)
    Actzo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Grizo [M:STCD]UOM(I)
    Grizo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When 3    #montant unitaire
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Actzo [M:STCD]UNTPRI(I)
    Actzo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Actzo [M:STCD]UOM(I)
    Actzo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When 4    #Montant par tranche
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Actzo [M:STCD]UNTPRI(I)
    Actzo [M:STCD]CURIMP2(I)
    Actzo [M:STCD]QTY(I)
    Actzo [M:STCD]UOM(I)
    Actzo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When 5    #Montant par barême
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Grizo [M:STCD]UNTPRI(I)
    Grizo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Grizo [M:STCD]UOM(I)
    Grizo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When 6    #Montant pondéré
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Actzo [M:STCD]UNTPRI(I)
    Actzo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Actzo [M:STCD]UOM(I)
    Actzo [M:STCD]BAS(I)
    Actzo [M:STCD]WEIPRC(I)
  When 7    #Formule
    Actzo [M:STCD]FCSAMT(I)
    Grizo [M:STCD]PRINETPRC(I)
    Grizo [M:STCD]UNTPRI(I)
    Grizo [M:STCD]CURIMP2(I)
    Grizo [M:STCD]QTY(I)
    Grizo [M:STCD]UOM(I)
    Grizo [M:STCD]BAS(I)
    Grizo [M:STCD]WEIPRC(I)
  When Default
Endcase
If [M:STCD]CSTPYR(I)=1 | [M:STCD]CSTPYR(I)=3 | [M:STCD]CSTPYR(I)=2
  Grizo [M:STCD]PRCBUY(I)
Else
  Actzo [M:STCD]PRCBUY(I)
Endif
Return

#############################################################################
Subprog C_FCSCOD(VALEUR)
Variable Char    VALEUR()
If [M:STCD]STCLIN(nolign-1)<>0 End Endif
# Issue 94299 - 2013-11-15 by SR : contrôle d'unicité
Call UNICITE(VALEUR,[M:STCD]FCSCOD(0..[M:STCD]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
#--- On ne peut pas ajouter de charge de type : barèmes et formule
If find([F:FCS]DIRCLCMOD,5,7)
  GMESSAGE=mess(454,194,1) : mkstat=2 : End
Endif

#--- On ne peut pas ajouter de charge non à la charge de l'acheteur
If [F:ICTD]CSTNAT<>[F:FCS]FCSNAT | [F:ICTD]ICTCOD<>GICT
    Read [ICTD]ICTD0=GICT;[F:FCS]FCSNAT
Endif
If ([F:ICTD]CSTPYR = 1 | [F:ICTD]CSTPYR=3) & !fstat
  GMESSAGE=mess(458,194,1) : mkstat=2 : End
Endif

End

#############################################################################
Subprog AM_FCSCOD(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : :NOL=nolign-1
Local Char    WANA, WSECTION
Local Integer STAT
Local Date    LDAT

Global Integer GNOL : Raz GNOL

Case GLABR
  When "POH2" : WANA="PCOSTPOH" : LDAT=[M:POH0]ORDDAT
  When "PTH1" : WANA="PCOSTPTH" : LDAT=[M:PTH0]RCPDAT
  When "PIH3" : WANA="PCOSTPIH" : LDAT=[M:PIH0]ACCDAT
  # MAE, landed cost, 110325
  When "SHIP1" : WANA="PCOSTPOH" : LDAT=[M:SHIP0]SHIPDAT
  When Default
    WANA = "PCOSTPOH" : LDAT=[M:POH0]ORDDAT
Endcase

Raz [M:STCD]QTY(NOL), UOM(NOL), BAS(NOL), UNTPRI(NOL), PRINETPRC(NOL), DESAXX(NOL), WEIPRC(NOL)

[M:STCD] = [F:FCS]

[M:STCD]CURIMP(NOL)  = [M:STCD]CUR
[M:STCD]CURIMP2(NOL) = [M:STCD]CUR
[M:STCD]CURSOC(NOL)  = [M:STCD]CUR

# Si % prix net alors devise document
If [M:STCD]DIRCLCMOD(NOL)=1
  [M:STCD]CURIMP(NOL)  = [M:STCD]CURDOC
  [M:STCD]CURIMP2(NOL) = [M:STCD]CURDOC
# Si formule alors devise dossier
Elsif [M:STCD]DIRCLCMOD(NOL)=7
  [M:STCD]CURIMP(NOL)  = GSYSCUR
  [M:STCD]CURIMP2(NOL) = GSYSCUR
Endif
If [M:STCD]CURIMP(NOL) <> [M:STCD]CUR
  Call COURSITE([M:STCD]CURIMP(NOL),GFCY,[M:STCD]CHGTYP(NOL),LDAT,[M:STCD]CHGCOE(NOL),STAT) From TRTDEV
Else
  [M:STCD]CHGCOE(NOL) = 1
Endif

#--- Si montant unitaire ou pondéré
If find([F:FCS]DIRCLCMOD,3,6)
  [M:STCD]QTY(NOL) = 1
Endif

#--- Lecture de l'incoterm
If GICT=""
  [M:STCD]PRCBUY(NOL) = 100
  [M:STCD]CSTPYR(NOL)=0
Else
  If [F:ICTD]CSTNAT<>[M:STCD]FCSNAT(NOL) | [F:ICTD]ICTCOD<>GICT
    Read [ICTD]ICTD0=GICT;[M:STCD]FCSNAT(NOL)
  Endif
  If !fstat
    [M:STCD]CSTPYR(NOL) = [F:ICTD]CSTPYR
    If find([M:STCD]CSTPYR(NOL),1,3)
      [M:STCD]PRCBUY(NOL) = 0
    Elsif [M:STCD]CSTPYR(NOL)=2
      [M:STCD]PRCBUY(NOL)=100
    Else
      [M:STCD]PRCBUY(NOL)=50
    Endif
  Else
    [M:STCD]CSTPYR(NOL)=0
    [M:STCD]PRCBUY(NOL)=100
  Endif
Endif

I = nolign-1
If [M:STCD]CSTPYR(I) = 1 | [M:STCD]CSTPYR(I)=3
  Grizo [M:STCD]PRINETPRC(I)
  Grizo [M:STCD]UNTPRI(I)
  Grizo [M:STCD]CURIMP2(I)
  Grizo [M:STCD]QTY(I)
  Grizo [M:STCD]UOM(I)
  Grizo [M:STCD]WEIPRC(I)
  Grizo [M:STCD]FORFCS(I)
  Grizo [M:STCD]PRCBUY(I)
  Grizo [M:STCD]BAS(I)
  Grizo [M:STCD]FCSAMT(I)
Else
  Gosub GRISE
Endif
#--- Initialisation des axes analytiques
Raz WSECTION
# Alimentation du nolig de la ligne document
nolign=GNOLIG+1
For K=1 To GNBDIE
  GNOL = NOL
  Call INISEC(WSECTION,WANA,K) From TRTX3CPT
  Assign "[M:STCD]CCE"+num$(K)+"("+num$(NOL)+")" With WSECTION
Next K
# Restitution du nolign de la charge
nolign=NOL+1
# MAE, landed cost, 110325
If NOL=0
  [M:STCD]NUMSEQ(NOL) = [M:STCD]NUMSEQ(NOL)+1000
Else
  [M:STCD]NUMSEQ(NOL) = [M:STCD]NUMSEQ(NOL-1)+1000
Endif
[M:STCD]STCUPD(NOL) = 1

Affzo [M:STCD]10

End

######################################################################################
Subprog AM_FCSAMT(VALEUR)
Variable Decimal VALEUR

Local Integer STAT

If [M:STCD]CUR = [M:STCD]CURIMP(nolign-1)
  [M:STCD]FCSAMTSOC(nolign-1) = VALEUR
Else
  [M:STCD]FCSAMTSOC(nolign-1) = VALEUR * [M:STCD]CHGCOE(nolign-1)
  Call ARRDEV([M:STCD]FCSAMTSOC(nolign-1),GLOCALDEV) From TRTDIV
Endif
Affzo [M:STCD]FCSAMTSOC(nolign-1)

End

######################################################################################
Subprog C_PRINETPRC(VALEUR)
Variable Decimal VALEUR
If VALEUR >100
 GMESSAGE = mess(623,199,1) : # Le pourcentage doit être inférieur ou égal à 100 %
 mkstat     =2
Endif
End

######################################################################################
Subprog C_WEIPRC(VALEUR)
Variable Decimal VALEUR
If VALEUR >100
 GMESSAGE = mess(623,199,1) : # Le pourcentage doit être inférieur ou égal à 100 %
 mkstat = 2
Endif
End

######################################################################################
Subprog C_PRCBUY(VALEUR)
Variable Decimal VALEUR
If VALEUR >100
 GMESSAGE = mess(623,199,1) : # Le pourcentage doit être inférieur ou égal à 100 %
 mkstat = 2
Endif
End

######################################################################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
# Issue 91193 - 2013-09-12 by SR
# appel du nouveau sous-pro de contrôle
Local Integer WRET
Local Char    WFCY(GLONFCY),WBPS(GLONBPS),WWEU(GLONUOM),WVOU(GLONUOM)
Case GLABR
  When "POH2" WFCY = [M:POH0]POHFCY
              WBPS = [M:POH0]BPSNUM
              WWEU = [M:POH2]LINWEU(GNOLIG)
              WVOU = [M:POH2]LINVOU(GNOLIG)
  When "PTH1" WFCY = [M:PTH0]PRHFCY
              WBPS = [M:PTH0]BPSNUM
              WWEU = [M:PTH1]LINWEU(GNOLIG)
              WVOU = [M:PTH1]LINVOU(GNOLIG)
  When "PIH3" WFCY = [M:PIH0]FCY
              WBPS = [M:PIH0]BPR
              WWEU = [M:PIH3]LINWEU(GNOLIG)
              WVOU = [M:PIH3]LINVOU(GNOLIG)
  When "SHIP1"WFCY = [M:SHIP1]POHFCY(GNOLIG)
              WBPS = [M:SHIP1]BPSNUM(GNOLIG)
              WWEU = [M:SHIP1]LINWEU(GNOLIG)
              WVOU = [M:SHIP1]LINVOU(GNOLIG)
Endcase
Call CONTROL_UOM_STCD(WFCY,[M:STCD]ITMREF,WBPS,[M:STCD]BAS(nolign-1),VALEUR,WWEU,WVOU,WRET) From STCCTL
If WRET = 1 : mkstat = 1 : End : Endif
End

######################################################################################
Subprog AM_CURIMP2(VALEUR)
Variable Char    VALEUR()
Local    Integer STAT, NOL
NOL=nolign-1
[M]CURIMP(NOL)=VALEUR
If [M]CURIMP(NOL)<>[M:STCD]CUR
  Call COURSITE([M:STCD]CURIMP(NOL),GFCY,[M:STCD]CHGTYP(NOL),GDAT,[M:STCD]CHGCOE(NOL),STAT) From TRTDEV
Else
  [M:STCD]CHGCOE(NOL)=1
Endif
Affzo [M]CURIMP(NOL)
End

######################################################################################
Subprog C_NBLIG

If status=82
  If (GLABR="POH2"&(evalue("[M:"+GLABR+"]LINRCPNBR(GNOLIG)")<>0 | evalue("[M:"+GLABR+"]LININVNBR(GNOLIG)")<>0))
&   |(GLABR="PTH1"&(evalue("[M:"+GLABR+"]INVQTYSTU(GNOLIG)")<>0)) | GLABR="PIH3"
    GMESSAGE=mess(255,194,1) : mkstat=1
  Endif
Endif
End

Subprog APRES_NBLIG
Local Shortint NOL : NOL=nolign-1
#          LNETPRI = Prix net ligne document
#          LQTYPUU = Quantité UA ligne document
#          LQTYVOU = Volume ligne document
#          LQTYWEU = Poids ligne document
#          LPUU    = Unité achat
#          LVOU    = Unité volume
#          LWEU    = Unité poids
#          LDAT    = Date document
#          LBPS    = Fournisseur
Local Decimal  LNETPRI
Local Decimal  LQTYPUU
Local Decimal  LQTYVOU
Local Decimal  LQTYWEU
Local Char     LPUU
Local Char     LVOU
Local Char     LWEU
Local Date     LDAT
Local Char     LBPS
Local Shortint MAXLIG

LNETPRI = evalue("[M:"+GLABR+"]NETPRI(GNOLIG)")
# MAE, landed cost, 110325
If GLABR = "SHIP1"
  LQTYPUU = evalue("[M:"+GLABR+"]SHIQTYPUU(GNOLIG)")
Else
  LQTYPUU = evalue("[M:"+GLABR+"]QTYPUU(GNOLIG)")
Endif
# MAE, end landed cost, 110325
LQTYVOU = evalue("[M:"+GLABR+"]QTYVOU(GNOLIG)")
LQTYWEU = evalue("[M:"+GLABR+"]QTYWEU(GNOLIG)")
LPUU    = evalue("[M:"+GLABR+"]PUU(GNOLIG)")

If [M:STCD]STCUPD(NOL) = 1
  Call CALC_COSTSTCD (NOL,LNETPRI,LQTYPUU,LQTYVOU,LQTYWEU,LPUU,GSALDSPVOU,GSALDSPWEU,GDAT,GBPSNUM,GFCY,left$(GLABR,3),0) From STCCLC
  Affzo [M:STCD]FCSAMT(NOL), FCSAMTCLC(NOL), FCSAMTSOC(NOL)
Endif

MAXLIG = max(nolign-1,[M:STCD]NBLIG-1)

# Somme de tous les montants
[M:STCD]FCSCSTPUR    = sum([M:STCD]FCSAMTSOC(0..MAXLIG))
# Somme des montants valorisés
[M:STCD]FCSCPR = sigma(I=0,MAXLIG, [M:STCD]FCSAMTSOC(I) *([M:STCD]STKVLT(I) = 2))
Affzo [M:STCD]FCSCSTPUR, FCSCPR

[M:STCD]STCUPD(NOL)=0
End

######################################################################################
## gestion des axes analytiques
######################################################################################
$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If [M:STCD]CSTPYR(nolign-1) = 1 | [M:STCD]CSTPYR(nolign-1)=3
  mkstat = 2
Else
  Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Endif
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Local Date WDATE
Case GLABR
  When "POH2" WDATE=[M:POH0]ORDDAT
  When "PTH1" WDATE=[M:PTH0]RCPDAT
  When "PIH3" WDATE=[M:PIH0]ACCDAT
  When Default
    WDATE = date$()
Endcase

Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:POH2]ITMREF(nolign-1)
  #----- Simple warning si migration Intégrale -----#
  If clalev([F:XEPA]) & clalev([F:XLPA])
    Call ECR_TRACE(GMESSAGE,-1) From GESECRAN : Raz GMESSAGE, mkstat
  Endif
  #-----
Endif
Return

