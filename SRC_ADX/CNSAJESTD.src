#<AdxTL>@(#)1.0.0.0 $Revision$ Consultation AJE
######################################################################################
## SData:  Gestion des exceptions 
#            Consultation AJE - Table AJSEXCEPT [AJE]
#
#  Version 0003_S
#   Base CNSAUDSTD
#
#
#  Subprog-Funprog - information issues de la table d'exception
#          AJE_RESEXC                          # Lecture / Maj ressources en exception
#
######################################################################################
### Lct interne
# ressource
#Gosub TST_RESEXC : End

# test consultation
Gosub TST_CNS : End
End


$ACTION
#Infbox ACTION
Case ACTION
 When "OUVRE"         :    Gosub OUVRE
 When "LECTURE"       :    Gosub LECTURE
 When "EXEBOUT"       :    Gosub EXEBOUT
 When default
Endcase
Return

$OUVRE
#---------------------------------------------------------------#
If clalev([F:AJE])=0 : Local File AJSEXCEPT [AJE] : Endif
Local Clbfile      CRITENT(0) , CRITSUI(0)

Local Char    CRITENT(250) , CRITSUI(250)
Local Integer MAXLIG 
Local Char    W_ALS(type([F:AJE]ALS)-10), W_RESNAM(type([F:AJE]RESNAM)-10), W_CLE(type([F:AJE]CLE)-10)

MAXLIG = dim([M:AJE2]SEQ)
Gosub DEFCRIT

Local Char WTRT_NAM(GLONADC)
Local Integer WTRT_OK
Call PARAM("","ASDTRTAPP",WTRT_NAM) From ADOVAL
Call EXISTE_ADX("","",WTRT_NAM,WTRT_OK) From ORDSYS
Return


$EXEBOUT
#---------------------------------------------------------------#
Case BOUT
When "A"        # Suppression
  If find(2,  [M:AJE2]WSEL)
    WNBSUP=0
    For WI=0 To [M:AJE2]NBLIG-1
      If [M:AJE2]WSEL(WI)=2
        WNBSUP+=1
      Endif
    Next
    Local Integer   W_S_ERRLEV(1..WNBSUP)            # Message: niveau erreur
    Local Char      W_S_ERRID(20)(1..WNBSUP)             # Message: identifiant
    Local Char      W_S_ERRMES(200)(1..WNBSUP)            # Message 
    Local Char      W_S_ACT(2)(1..WNBSUP)          #  Action "CU", "R", "D"
    Local Char      W_S_RESNAM(30)(1..WNBSUP)      #  Ressource name
    Local Char      W_S_KEYERP(150)(1..WNBSUP)       
    Local Char      W_S_ALS(3)(1..WNBSUP)          #  Alias
    Local Shortint  W_S_RESFLGEXC(1..WNBSUP)       #  
    Local Shortint  W_S_FLGUPD 
    WNBSUP=0
    For WI=0 To [M:AJE2]NBLIG-1
      If [M:AJE2]WSEL(WI)=2
        WNBSUP+=1
        W_S_ACT(WNBSUP)     = "D"
        W_S_RESNAM(WNBSUP)  = [M:AJE2]RESNAM(WI)
        W_S_KEYERP(WNBSUP)  = [M:AJE2]CLE(WI)
        W_S_ALS(WNBSUP)     = [M:AJE2]ALS(WI)
      Endif
    Next
    Call AJE_RESEXC("", 0, 0, W_S_ERRLEV, W_S_ERRID, W_S_ERRMES, W_S_ACT, W_S_RESNAM, W_S_KEYERP, 
&              W_S_ALS, W_S_RESFLGEXC, W_S_FLGUPD)
    OK=1    # Réaffichage page courante
  Endif
Endcase
Return


$DEFCRIT
#---------------------------------------------------------------#
For I=1 To dim(PARAM)
 Case I
   When 1 : # Type de ressource
    [M:AJE1]RESNAM = toupper(PARAM(I))
   When 2 : # Cle ERP
    [M:AJE1]CLESTR = PARAM(I)
   When 3 : # Alias
    [M:AJE1]ALS    = toupper(PARAM(I))
  Endcase
Next
Return


$LECTURE
#---------------------------------------------------------------#
Gosub CRITENT
Gosub CRITSUI
NOL = 0
SUITE  = 1
RETOUR = 1

#Link [AUL] With [AUD]AUD0=[F:AUL]SEQ As [LAUL]
If CHGPAG>0
 Filter [AJE] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key AJE0   # CLE=[F:AJE]RESNAM;[F:AJE]CLE;[F:AJE]ALS
 NOL = 0
 For [AJE]AJE0
  If NOL>=MAXLIG
   SUITE = 2 : Break
  Else
   If CHGPAG=2 : RETOUR = 2 : Endif
   NOL += 1
   Gosub CHARGE
  Endif
 Next
 [M:AJE2]NBLIG = NOL
Else
 Filter [AJE] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key AJE0 Desc    #CLE=[F:AJE]RESNAM Desc;[F:AJE]CLE Desc;[F:AJE]ALS Desc
 NOL = MAXLIG+1
 For [AJE]AJE0
  If NOL<=1
   RETOUR = 2 : Break
  Else
   If CHGPAG=-2 : SUITE = 2 : Endif
   NOL -= 1
   Gosub CHARGE
  Endif
 Next
 [M:AJE2]NBLIG = MAXLIG
Endif
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:AJE2] : Endif
Endif
nolign = NOL
[M:AJE2] = [F:AJE]
[M:AJE2]WSEL(NOL-1)=1
If WTRT_OK
    #Onerrgo ERR_CHARGE
    Call ASD_AJEINF  With  [M:AJE2]RESNAM(NOL-1), [M:AJE2]CLE(NOL-1),[M:AJE2]DES(NOL-1), [M:AJE2]HASTUN(NOL-1) From =WTRT_NAM
    Onerrgo
Endif
Return

$ERR_CHARGE
    [M:AJE2]DES(NOL-1)=""
    [M:AJE2]HASTUN(NOL-1)=0
Resume

$CRITENT
CRITENT = ""
If [M:AJE1]ALS<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '([AJE]ALS="' +[M:AJE1]ALS+ '" or [AJE]ALS="ALL")'
Endif
If [M:AJE1]RESNAM<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AJE]RESNAM="'+[M:AJE1]RESNAM+'"'
Endif
If [M:AJE1]CLESTR<>""
 If CRITENT<>"" : CRITENT -= "&" : Endif
 CRITENT -= '[AJE]CLE >="'+[M:AJE1]CLESTR+'"'
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:AJE2]NBLIG>0
   W_ALS       = [M:AJE2]ALS([M:AJE2]NBLIG-1)
   W_RESNAM    = [M:AJE2]RESNAM([M:AJE2]NBLIG-1)
   W_CLE       = [M:AJE2]CLE([M:AJE2]NBLIG-1)
   CRITSUI     = '( [AJE]RESNAM > "' +W_RESNAM+ '"'
&             -'or ([AJE]RESNAM = "' +W_RESNAM+ '" and [AJE]CLE > "' +W_CLE+ '")' 
&             -'or ([AJE]RESNAM = "' +W_RESNAM+ '" and [AJE]CLE = "' +W_CLE+ '" and [AJE]ALS > "' +W_ALS+ '")'  
&             -')'
  Endif
 When -2
  If [M:AJE2]NBLIG>0
   W_ALS       = [M:AJE2]ALS(0)
   W_RESNAM    = [M:AJE2]RESNAM(0)
   W_CLE       = [M:AJE2]CLE(0)
   CRITSUI     = '( [AJE]RESNAM < "' +W_RESNAM+ '"'
&             -'or ([AJE]RESNAM = "' +W_RESNAM+ '" and [AJE]CLE < "' +W_CLE+ '")' 
&             -'or ([AJE]RESNAM = "' +W_RESNAM+ '" and [AJE]CLE = "' +W_CLE+ '" and [AJE]ALS < "' +W_ALS+ '")'  
&             -')'
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return



######################################################################################
## Utilitaires table d'exceptions
######################################################################################

# - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - # - - #
#  Infos ressource (maj)
# - - - - - - - - - - - - - - - - - - - - - -
Subprog AJE_RESEXC(DBGHST, DBGPRT, DBGOPN, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT, A_RESNAM, A_KEYERP, 
&              A_ALS, A_RESFLGEXC, A_UPDFLG)
Value    Char      DBGHST              # Debug: host
Value    Integer   DBGPRT              # Debug: port
Value    Shortint  DBGOPN              # Debug: dbgaff
Variable Integer   A_ERRLEV(1..)            # Message: niveau erreur
Variable Char      A_ERRID()(1..)             # Message: identifiant
Variable Char      A_ERRMES()(1..)            # Message 

# Par ligne
Value    Char      A_ACT()(1..)          #  Action "CU", "R", "D" - "" = fin de demande
Variable Char      A_RESNAM()(1..)       #  Ressource name
Variable Char      A_KEYERP()(1..)       
Variable Char      A_ALS()(1..)          #  Alias   "CUR" endpoint courant - "ALL" l'exception est pour tous les endpoints
Variable Shortint  A_RESFLGEXC(1..)      #  1: trouvé en lecture avec alias "ALL"  - 2: trouvé en lecture avec alias demandé

Variable Shortint  A_UPDFLG              #  1: Maj globale OK

Call JAVA_DEBUG(DBGHST, DBGPRT, DBGOPN)  From ASDUTIA

# Message
Local Char      WC_MSGPRF : WC_MSGPRF="RESexc_"   # Prefixe ID message
Local Char      WERRCTX(100)                      # Contexte erreur fstat
Local Integer   WERRLEV
Local Char      WERRMES(200), WERRID(20)
Local Integer   WOK, WOKCTL

If clalev([AJE])=0 :  Local File AJSEXCEPT[AJE] : Endif
Local Char    WRESNAM(type([AJE]RESNAM)-10)
Local Integer NBMAXLINES, NBLINES, WCUR : NBLINES=0
NBMAXLINES = dim(A_ACT)
Local Shortint HAS_READ, HAS_MAJ, RESMAJFLG(1..NBMAXLINES ), RESREADFLG(1..NBMAXLINES )
Raz A_ERRLEV, A_ERRID, A_ERRMES

# Ctls
WOKCTL=1
For WCUR = 1 To dim(A_ACT)
  If A_ACT(WCUR)="" : Break : Endif
  NBLINES +=1
  WOK=1
  A_ACT(WCUR)=toupper(A_ACT(WCUR)) :  A_RESNAM(WCUR) = toupper(A_RESNAM(WCUR)) : A_ALS(WCUR) = toupper(A_ALS(WCUR))
  Repeat
      A_ACT(WCUR)=toupper(A_ACT(WCUR))
      Case A_ACT(WCUR)
      When "CU","D"
        If A_RESNAM(WCUR)=""     : WOK=0 : WERRCTX="A_RESNAM=''"    : Break : Endif
        If A_ALS(WCUR)=""        : WOK=0 : WERRCTX="A_ALS=''"       : Break : Endif
        If A_KEYERP(WCUR)=""     : WOK=0 : WERRCTX="A_KEYFLG='"-A_KEYFLG(WCUR)-"' A_KEYERP=''"     : Break : Endif
        HAS_MAJ=1 : RESMAJFLG(WCUR)=1
      When "R"
        If A_ACT(WCUR)="R" : HAS_READ=1 : Endif
        If A_RESNAM(WCUR)=""     : WOK=0 : WERRCTX="A_RESNAM=''"    : Break : Endif
        If A_KEYERP(WCUR)=""     : WOK=0 : WERRCTX="A_KEYFLG='"-A_KEYFLG(WCUR)-"' A_KEYERP=''"     : Break : Endif
        HAS_READ=1 : RESREADFLG(WCUR)=1
      When Default
        WOK=0 : WERRCTX="A_ACT='"-A_ACT(WCUR)-"'"    : Break
      Endcase
  Until 1=1
  If !WOK
    WOKCTL = 0
    A_ERRLEV(WCUR)=4 : A_ERRID(WCUR)=WC_MSGPRF+"143_56" : A_ERRMES(WCUR)=mess(56,143,1)-WERRCTX      # Par. incorrects
  Endif
Next
If !WOKCTL : A_UPDFLG=0 : Gosub RESEXC_F : Endif

# Gestion maj
If HAS_MAJ
  A_UPDFLG=1
  Call DEBTRANS From GLOCK
  Trbegin [AJE]  
  For WCUR = 1 To NBLINES
    If RESMAJFLG(WCUR)
        Case A_ACT(WCUR)
        When "CU"
          Gosub RESEXC_ST_CU
        When "D"
          Gosub RESEXC_ST_D
        Endcase
        If GOK<1
          If A_ERRLEV(WCUR)=0 and WERRLEV<>0 : A_ERRLEV(WCUR)=WERRLEV : A_ERRMES(WCUR)=WERRMES : A_ERRID(WCUR)=WERRID : Endif      # Recup erreur 
          Break
        Endif 
        GNBROL=0
    Endif 
  Next
  If GOK<1
    A_UPDFLG=0
    Rollback 
  Else
    Commit
  Endif
Endif

# Gestion read
If HAS_READ
  For WCUR = 1 To NBLINES
    If RESREADFLG(WCUR)
        WOK=1
        Gosub RESEXC_ST_R
        If WOK<1 
          If A_ERRLEV(WCUR)=0 and WERRLEV<>0 : A_ERRLEV(WCUR)=WERRLEV : A_ERRMES(WCUR)=WERRMES : A_ERRID(WCUR)=WERRID : Endif      # Recup erreur 
        Endif 
    Endif 
  Next
Endif

$RESEXC_F
End

 

# Read
#  Renvoit A_RESFLGEXC(WCUR)
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_ST_R
    A_RESFLGEXC(WCUR)=0
    Read [AJE]AJE0=A_RESNAM(WCUR);A_KEYERP(WCUR);A_ALS(WCUR)
    If fstat 
        If A_ALS(WCUR)<>"ALL"
            Read [AJE]AJE0=A_RESNAM(WCUR);A_KEYERP(WCUR);"ALL"
            If !fstat
                A_RESFLGEXC(WCUR)=1          # Avec alias "ALL"
            Endif
        Endif
    Else
        A_RESFLGEXC(WCUR)=2                  # Avec alias demandé
    Endif
Return 


# Creation-Modification
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_ST_CU
Gosub RESEXC_ST_R
If A_RESFLGEXC(WCUR)=2  # existe déjà
    # RAF
Else
    # Création
    Gosub RESEXC_ST_C
Endif
Return

# Creation
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_ST_C 
GOK=1
Raz WERRLEV, WERRID, WERRMES
#Trbegin [AJE]  
Gosub RESEXC_SETAJE
[AJE]CREUSR = GUSER
Write [AJE]
If fstat
    GOK=0 : WERRCTX="Write [AJE] - "-[AJE]LININF-[AJE]RESNAM-[AJE]CLE -"or"-[AJE]RESUUID : Gosub SETFILERR From AJSSYNCA 
    Goto RESEXC_AB
Endif
#Commit
Return

# Update  (garder pour evolution)
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_ST_U 
GOK=1
Raz WERRLEV, WERRID, WERRMES
#Trbegin [AJE]  
Readlock [AJE]AJE0=A_RESNAM(WCUR);A_KEYERP(WCUR);A_ALS(WCUR)
If fstat=1
    GOK=-1 : WERRCTX="Read [AJE]AJS0"-A_RESNAM(WCUR)+";"+A_RESNAM(WCUR)+";"+A_ALS(WCUR)  : Gosub SETFILERR From AJSSYNCA  
    Goto RESEXC_ROLL
Elsif fstat
    GOK=0 : WERRCTX="Read [AJE]AJS0"-A_RESNAM(WCUR)+";"+A_RESNAM(WCUR)+";"+A_ALS(WCUR) : Gosub SETFILERR From AJSSYNCA  
    Goto RESEXC_AB
Endif
Gosub RESEXC_SETAJE
Rewrite [AJE]
If fstat
    GOK=0 : WERRCTX="Rewrite [AJE]AJS0"-WC_INF+";"+WRESNAM+";''" : Gosub SETFILERR From AJSSYNCA  
    Goto RESEXC_AB
Endif
#Commit
Return

# Delete
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_ST_D 
GOK=1
Raz WERRLEV, WERRID, WERRMES
#Trbegin [AJE]  
Delete [AJE]AJE0 = A_RESNAM(WCUR);A_KEYERP(WCUR);A_ALS(WCUR)
If fstat=1
    GOK=-1 : WERRCTX="Delete [AJE]AJE0"-A_RESNAM(WCUR)+";"+A_RESNAM(WCUR)+";"+A_ALS(WCUR)  :  : Gosub SETFILERR From AJSSYNCA  
    Goto RESEXC_ROLL
Elsif fstat>5
    GOK=0 : WERRCTX="Delete [AJE]AJE0"-A_RESNAM(WCUR)+";"+A_RESNAM(WCUR)+";"+A_ALS(WCUR)  :  : Gosub SETFILERR From AJSSYNCA  
    Goto RESEXC_AB
Endif
#Commit
Return

# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_AB
#Rollback
Return

$RESEXC_ROLL      
#Rollback
GNBROL += 1
If mod(GNBROL,GROLLBACK)=0
  Return 
Else 
  Case A_ACT
   When "CU" : Goto RESEXC_ST_U
   When "D" : Sleep(lockwait) : Goto RESEXC_ST_D
  Endcase
Endif
Return

#  Chargement table ajs
# - - - - - - - - - - - - - - - - - - - - - -
$RESEXC_SETAJE
[AJE]RESNAM      = A_RESNAM(WCUR)            
[AJE]CLE         = A_KEYERP(WCUR)         
[AJE]ALS         = A_ALS(WCUR)   
[AJE]UPDUSR  = GUSER
[AJE]UPDDAT  = date$
[AJE]UPDTIM  = time
Return


######################################################################################
# SData:  Section TESTS
######################################################################################

# - - - - - - - - - - - - - - - - - -
$TST_CNS
Local Char PARAM(40)(1..8)
PARAM(1)= ""
PARAM(2)= "P1~P"
PARAM(3) = ""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
PARAM(8) =""
GCONSULT = 0
Raz GNBMASKOUV
Call GCONSULT("AJE","",PARAM) From GCONSULT
Return


# - - - - - - - - - - - - - - - - - -
$TST_RESEXC
Call OUVRE_TRACE("Test RESEXP") From LECFIC
Local Char DBGHST(50)
Local Integer DBGPRT
DBGHST = "ecjullienc.sagefr.adinternal.com"   # dns #DBGHST="172.28.9.11" # @ip du pc
DBGPRT=1789

# Par ligne
Local Integer NBL : NBL=10
Local Integer   A_ERRLEV(1..NBL)            # Message: niveau erreur
Local Char      A_ERRID(20)(1..NBL)             # Message: identifiant
Local Char      A_ERRMES(200)(1..NBL)            # Message 

Local Char      A_ACT(2)(1..NBL)          #  Action "CU", "R", "D"
Local Char      A_RESNAM(30)(1..NBL)      #  Ressource name
Local Char      A_KEYERP(150)(1..NBL)       
Local Char      A_ALS(3)(1..NBL)          #  Alias
Local Shortint  A_RESFLGEXC(1..NBL)       #  Flag lecture
Local Shortint  A_FLGUPD 

WI=1
For WI=1 To 10
    A_ACT(WI)      ="CU"
    A_RESNAM(WI)   ="Trading"
    A_KEYERP(WI)   ="P1~P"+num$(WI)
    A_ALS(WI)      ="ALL"
Next 

Call AJE_RESEXC(DBGHST, DBGPRT, 0, A_ERRLEV, A_ERRID, A_ERRMES, A_ACT, A_RESNAM, A_KEYERP, 
&              A_ALS, A_RESFLGEXC, A_FLGUPD)

Call ECR_TRACE(" flag gestion mise à jour réussie (0=maj non faite):"-num$(A_FLGUPD),A_FLGUPD=0) From GESECRAN


For WI=1 To 10
 If A_ERRLEV(WI)
  Call ECR_TRACE("Erreur - line:"-num$(WI)-"A_ACT"-A_ACT(WI),0) From GESECRAN
  Call ECR_TRACE("Level:"-num$(A_ERRLEV(WI))-"ID"-A_ERRID(WI),1) From GESECRAN
  Call ECR_TRACE("              message:"-A_ERRMES(WI),0) From GESECRAN
 Endif
 If toupper(A_ACT(WI)) = "R"
  Call ECR_TRACE("Lecture - Ressource " -A_RESNAM(WI) -A_KEYERP(WI) -"flag exception" -num$(A_RESFLGEXC(WI)) ,0) From GESECRAN
 Endif
Next

Call ECR_TRACE("Fin",0) From GESECRAN


$TST_RESINF_F
Call FERME_TRACE From LECFIC
Call SUPP_TRACE  From LECFIC
Return





# Gestion du masque CONSAJE2
######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSAJE2) 24/06/2010 12:04:06 (JPJ)
######################################################################################
Subprog B1_NBLIG
Local Integer FLGSEL : FLGSEL=2
Gosub SEL_NBLIG
End

Subprog B2_NBLIG
Local Integer FLGSEL : FLGSEL=1
Gosub SEL_NBLIG
End

$SEL_NBLIG
Local Integer WI
Local Integer  SAVNOL
SAVNOL=nolign
Local Integer WNEW
For WI=SAVNOL-1 To [M:AJE2]NBLIG-1
    WNEW=1
    [M:AJE2]WSEL(WI)=FLGSEL : nolign=WI+1
Next
nolign=SAVNOL

If WNEW
 Affzo [M:AJE2]WSEL
Endif
Return


Subprog B3_NBLIG   # Tunel
Local Char WTRT_NAM(GLONADC)
Local Integer WTRT_OK
Call PARAM("","ASDTRTAPP",WTRT_NAM) From ADOVAL
Onerrgo ERR_B3_NBLIG
  Call ASD_AJETUN( [M:AJE2]RESNAM(nolign-1), [M:AJE2]CLE(nolign-1) ) From =WTRT_NAM
Onerrgo
End
$ERR_B3_NBLIG
Resume

Subprog IB_NBLIG
If [M:AJE2]HASTUN(nolign-1)=0 :  GBOUT3="" : Endif
End


######################################################################################


