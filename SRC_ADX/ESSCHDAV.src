#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase

Return

$SETBOUT
If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return


$OUVRE
Gosub OUVRE_OUT

#Manage Localisations
Call MANAGE_LOCALISATION("ESSCHDAV") From DIVPAYE

Return

$OUVRE_OUT
#Opening tables and declaring an instance of the main class
If clalev([F:EWCHD1])      = 0 : Local File ESSWRKCHD    [EWCHD1]     : Endif
If clalev([F:ESWD2])      = 0 : Local File ESSWRKFLWDET     [ESWD2]     : Endif
Return


$DEBUT
Gosub DEBUT_OUT
#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSCHDAVHIDE
Call SHOW_LEGACTCALLS From WESSCHDAVSHOW
Affzo [M:ESCHD]1-99
Return

$DEBUT_OUT
Local Char GLOBEML(GLONEML)
nolign = 0

Raz [M:ESCHD]
Read [EWCHD1]EWCHD0 = val(PARAM(2))
If fstat : Return : Endif

nolign = 1
[M:ESCHD] = [F:EWCHD1]
[M:ESCHD]NBRCHD = nolign

GLOBEML   = [F:EWCHD1]REFNUM
GCURLEG = func DIVPAYE_SOA.GET_LEG_EMP(GLOBEML, 1)

[M:ESCHD]DEST = PARAM(3)
[M:ESCHD]CHRONO = PARAM(4)


#Style
Gosub DECLARE_EMPSTYLE From ESS_FUNCTIONS

WFILENAME = "WESSCHDDETSTYLE_"+GUSER

 Gosub CREATE_STYLE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS
  #Indicate changed fields
  If [F:EWCHD1]WRK = "M"
    WSTYLECODE = "ECCBODC"
    [M:ESCHD]WRKREQ = 2
    Chgstl [M:ESCHD]WRKREQ With "ECCBODC"
    Filter [F:ESWD2] Where UID = [F:EWCHD1]UID and WRK = "M" and MAIREC <> 2
    For [F:ESWD2]
      If evalue("dim([M:ESCHD]"+[F:ESWD2]FLDNAM+")")>0
        WFIELDNAME = "[M:ESCHD]"+[F:ESWD2]FLDNAM+"(nolign-1)"
        #WFIELDNAME = [F:ESWD2]FLDNAM+"nolign(-1)"
        STYLESTAT+=1
        Gosub CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL From ESS_FUNCTIONS
      Endif
    Next
    Filter [F:ESWD2]
  Elsif [F:EWCHD1]WRK = "D"
    WSTYLECODE = "ECCBODA"
    [M:ESCHD]WRKREQ = 3
    Chgstl [M:ESCHD]WRKREQ With "ECCBODA"
    Chgstl NBRCHD(nolign-1) With "ECCBODA"
  Elsif [F:EWCHD1]WRK = "C"
    WSTYLECODE = "ECCBODC"
    [M:ESCHD]WRKREQ = 1
    Chgstl [M:ESCHD]WRKREQ With "ECCBODC"
    Chgstl NBRCHD(nolign-1) With "ECCBODC"
  Endif
  #Close script
  Gosub CLOSE_SCRIPT_EMPDETAIL From ESS_FUNCTIONS

  If STYLESTAT
    #Run script
    Call STYLE_FIELDS() From =WFILENAME
  Endif
Return

