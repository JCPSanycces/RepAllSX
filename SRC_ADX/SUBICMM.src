######################################################################################
#X3-101694 MJH
Subprog AM_VARPER(VALEUR)
Variable Decimal VALEUR
  If VALEUR=0
    Actzo [M:ICMM]VARAMT(nolign-1)
  Else
    Diszo [M:ICMM]VARAMT(nolign-1)
  Endif
End

Subprog AM_VARAMT(VALEUR)
Variable Decimal VALEUR
  If VALEUR=0
    Actzo [M:ICMM]VARPER(nolign-1)
  Else
    Diszo [M:ICMM]VARPER(nolign-1)
  Endif
End




