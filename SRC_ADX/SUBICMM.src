######################################################################################
## Etiquette ajoutée par le superviseur (écran ITCMATCHM) 17/02/2009 14:36:08 (CCC)
######################################################################################
Subprog C_DAT2(VALEUR)
Variable Date    VALEUR
If  [M:ICMM]STOFCY1=[M:ICMM]STOFCY2
& & [M:ICMM]CSTTYP1=[M:ICMM]CSTTYP2
& & [M:ICMM]DAT1   =VALEUR
    GMESSAGE=mess(89,187,1) # Tous les critères de comparaison sont identiques
    mkstat=2
Endif


End

######################################################################################
#X3-101694 MJH
Subprog AV_LSTFLD(VALEUR)
Variable Char    VALEUR()

  If [M:ICMM]SELFLG(5) = 2
    Actzo [M:ICMM]VARAMT(5)
    Actzo [M:ICMM]VARPER(5)
  Endif
End


