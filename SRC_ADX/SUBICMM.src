#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
$ACTION
Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "DEBUT" : Gosub DEBUT
    When "OK"    : Gosub OK
Endcase
Return

############################################################
# ACTIONS
############################################################
$OUVRE
If !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER  [ITM]  : Endif
If !clalev([F:ITF1]) : Local File ITMFACILIT [ITF1] : Endif
If !clalev([F:ITF2]) : Local File ITMFACILIT [ITF2] : Endif
If !clalev([F:ITC])  : Local File ITMCOST    [ITC]  : Endif
If !clalev([F:IMC])  : Local File ITCMATCH   [IMC]  : Endif
Return

############################################################
$DEBUT
Local Date    DATDEB, DATFIN
Local Char    LFIN
Local Decimal LEXE
Local Char TXT(20)

Call RAZPRONUM From SUBICMCOM


[M:ICMM]STOFCY1 = GFCYDEF(0)
[M:ICMM]STOFCY2 = GFCYDEF(0)

[M:ICMM]CSTTYP1 = 1
[M:ICMM]CSTTYP2 = 1

Call GETSOC([M:ICMM]STOFCY1) From DEVSUB
Call GETEXE(GSOCIETE,GTYPGEN,date$,LEXE)  From CPTSUB
Call DATEXE(GSOCIETE,GTYPGEN,LEXE,DATDEB,DATFIN) From CPTSUB


[M:ICMM]NBLIG = 6

Call TEXTE(11249,[M:ICMM]LINE(0)) From OBJDIV
Call TEXTE(1071, [M:ICMM]LINE(1)) From OBJDIV
Call TEXTE(8757, [M:ICMM]LINE(2)) From OBJDIV
Call TEXTE(5727, [M:ICMM]LINE(3)) From OBJDIV
Call TEXTE(1888, [M:ICMM]LINE(4)) From OBJDIV
Call TEXTE(3569, [M:ICMM]LINE(5)) From OBJDIV


For I = 0 To 4
  [M:ICMM]SELFLG(I) = 1
Next
[M:ICMM]SELFLG(5) = 2
Diszo [M:ICMM]VARAMT
Diszo [M:ICMM]VARPER

Affzo [M:ICMM]


Return

############################################################
$OK
Local Integer NC, LNB : Raz LNB
Local Char    NO_COUT
Local Char    CRIT(250)
If !clalev([M:ICM0]) : Local Mask ITCMATCH0 : Endif
If !clalev([M:ICM1]) : Local Mask ITCMATCH1 : Endif
If !clalev([M:ICM2]) : Local Mask ITCMATCH2 : Endif
If !clalev([M:ICM3]) : Local Mask ITCMATCH3 : Endif
If !clalev([M:ICM4]) : Local Mask ITCMATCH4 : Endif

Call RAZIMC From SUBICMCOM
Trbegin [IMC]

Gosub FILTRE
For [LNK]
 If func TESTFLT()
  Raz [M:ICM0]
  Raz [M:ICM1]
  Raz [M:ICM2]
  Raz [M:ICM3]
  Raz [M:ICM4]
  [M:ICM0]UNTFLG = 2
  [M:ICM0] = [M:ICMM]
  For NC=1 To 2
    NO_COUT=num$(NC)
    Assign "[M:ICM0]CSTTYP"+NO_COUT With evalue("[M:ICMM]CSTTYP"+NO_COUT)
    If evalue("[M:ICMM]CSTTYP"+NO_COUT)<5
      If evalue("[M:ICMM]CSTTYP"+NO_COUT)=2
        CRIT="ITCSTRDAT>=[M:ICMM]DAT1"
      Else
        CRIT="1=1"
      Endif

        If NC=1 #Find first cost
          [M:ICM0] = [F:ITF1]
          Filter [ITC] Where STOFCY = [F:ITF1]STOFCY
&                          & ITMREF = [F:ITF1]ITMREF
&                          & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                          & (ITCSTRDAT<=[M:ICMM]DAT1 & [M:ICMM]DAT1<=ITCENDDAT)
&                          & UID = 0
          Read [ITC]ITC0 First

          If fstat #Find first cost after selected date
            Filter [ITC] Where STOFCY = [F:ITF1]STOFCY
&                            & ITMREF = [F:ITF1]ITMREF
&                            & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                                    & ITCSTRDAT>=[M:ICMM]DAT1
&                                    & UID = 0
&                     Order By STOFCY;ITMREF;CSTTYP;ITCSTRDAT;ITCSEQ Desc
            Read [ITC] First

            #111872.SN MJH 20/12/2016
            If fstat #Find first cost before selected date
              Filter [ITC] Where STOFCY = [F:ITF1]STOFCY
&                              & ITMREF = [F:ITF1]ITMREF
&                              & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                              & ITCSTRDAT<=[M:ICMM]DAT1
&                              & UID = 0
              Read [ITC]ITC1 Last
            Endif #111872.en MJH 20/12/2016

          Endif
        Else #Find second cost
          [M:ICM0] = [F:ITF2]
          Filter [ITC] Where STOFCY = [F:ITF2]STOFCY
&                          & ITMREF = [F:ITF2]ITMREF
&                          & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                          & (ITCSTRDAT<=[M:ICMM]DAT2 & [M:ICMM]DAT2<=ITCENDDAT)
&                          & UID = 0
          Read [ITC]ITC0 First
          If fstat #Find second cost after selected date
            Filter [ITC] Where STOFCY = [F:ITF2]STOFCY
&                            & ITMREF = [F:ITF2]ITMREF
&                            & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                            & ITCSTRDAT>=[M:ICMM]DAT2
&                            & UID = 0
&                     Order By STOFCY;ITMREF;CSTTYP;ITCSTRDAT;ITCSEQ Desc
            Read [ITC] First

            #111872.SN MJH 20/12/2016
            If fstat #Find second cost before selected date
              Filter [ITC] Where STOFCY = [F:ITF2]STOFCY
&                              & ITMREF = [F:ITF2]ITMREF
&                              & CSTTYP = evalue("[M:ICMM]CSTTYP"+NO_COUT)
&                              & ITCSTRDAT<=[M:ICMM]DAT2
&                              & UID = 0
              Read [ITC]ITC1 Last
            Endif#111872.en MJH 20/12/2016

          Endif
        Endif
        #Read [ITC]ITC1 First
        Filter [ITC]
        If !fstat
          Assign "[M:ICM0]ITCDAT"+NO_COUT With [F:ITC]ITCDAT
          Default File [ITC]
          Gosub CHARGE_COUT From SUBICM

# Issue 78458 - 2012-01-06 by CCC : Déplacé dans le cas où le 2ème coût ne serait pas trouvé
#                    If NC=2 & func COMPECART() = 1
#                        Call WRIIMC From SUBICMCOM
#                        Call ECR_TRACE("    fstat="+num$(fstat),0) From GESECRAN
#                        LNB +=1
#                    Endif
        Endif

        #This was moved out of the loop so we only display comparisons that have valid dates
        #111872.so MJH 20/12/2016
#        If NC=2 & func COMPECART() = 1 and GUSER  <> "MIHAL"
#          Call WRIIMC From SUBICMCOM
#          LNB +=1
#        Endif
         #111872.eo MJH 20/12/2016

      Endif
    Next #For NC

    #111872.sn MJH 20/12/2016
    If func COMPECART() = 1 and [M:ICM0]ITCDAT1 <> [0/0/0] and [M:ICM0]ITCDAT2 <> [0/0/0]
      Call WRIIMC From SUBICMCOM
      LNB +=1
    Endif
    #111872.en MJH 20/12/2016
  Endif
Next

If LNB>0
  Commit
  Call IMPRIME("ITCMATCHM","COMPCOUTM") From ETAT
Else
  Rollback
Endif


FIN = 0
Return

############################################################
# Gestion du masque ITCMATCHM
############################################################

############################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
If [M:ICMM]TCLCODSTR = [M:ICMM]TCLCODEND | VALEUR > [M:ICMM]TCLCODEND
    [M:ICMM]TCLCODEND = VALEUR
    Affzo [M:ICMM]TCLCODEND
Endif
End

############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:ICMM]ITMREFSTR = [M:ICMM]ITMREFEND | VALEUR > [M:ICMM]ITMREFEND
    [M:ICMM]ITMREFEND = VALEUR
    Affzo [M:ICMM]ITMREFEND
Endif
End

############################################################
Subprog AM_VLTSTR(VALEUR)
Variable Char    VALEUR()
If [M:ICMM]VLTSTR = [M:ICMM]VLTEND | VALEUR > [M:ICMM]VLTEND
    [M:ICMM]VLTEND = VALEUR
    Affzo [M:ICMM]VLTEND
Endif
End

############################################################
Subprog AM_BUYSTR(VALEUR)
Variable Char    VALEUR()
If [M:ICMM]BUYSTR = [M:ICMM]BUYEND | VALEUR > [M:ICMM]BUYEND
    [M:ICMM]BUYEND = VALEUR
    Affzo [M:ICMM]BUYEND
Endif
End

############################################################
Subprog AM_TSICODSTR(VALEUR)
Variable Char    VALEUR()
If [M:ICMM]TSICODSTR(indice) = [M:ICMM]TSICODEND(indice) | VALEUR > [M:ICMM]TSICODEND(indice)
    [M:ICMM]TSICODEND(indice) = VALEUR
    Affzo [M:ICMM]TSICODEND(indice)
Endif
End

############################################################
Subprog AS_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]TCLCODSTR
Endif
End

############################################################
Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End

############################################################
Subprog AS_VLTEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]VLTSTR
Endif
End

############################################################
Subprog AS_BUYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]BUYSTR
Endif
End
############################################################
Subprog AS_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]TSICODSTR(indice)
Endif
End

######################################################################################
Subprog AS_CSTTYP1(VALEUR)
Variable Integer VALEUR
GMENLOC(5) = 1
GMENLOC(6) = 1
GMENLOC(7) = 1
GMENLOC(8) = 1
End

######################################################################################
Subprog AM_CSTTYP1(VALEUR)
Variable Integer VALEUR
    Case VALEUR
        When 1,2,3,4:
            Actzo [M:ICMM]DAT1
        When Default :
            Effzo [M:ICMM]DAT1
            Diszo [M:ICMM]DAT1
    Endcase
End

######################################################################################
Subprog AS_CSTTYP2(VALEUR)
Variable Integer VALEUR
GMENLOC(5) = 1
GMENLOC(6) = 1
GMENLOC(7) = 1
GMENLOC(8) = 1
End

######################################################################################
Subprog AM_CSTTYP2(VALEUR)
Variable Integer VALEUR
    Case VALEUR
        When 1,2,3,4:
            Actzo [M:ICMM]DAT2
        When Default :
            Effzo [M:ICMM]DAT2
            Diszo [M:ICMM]DAT2
    Endcase
End


######################################################################################

$FILTRE
Local Integer I,I1,I2,I3
Local Char FIL1(250)(5),FIL2(250)(5),FILTSI(250)(5)

#---- Filtre sites ----#  --> fait dans le lien
#Call ADDCRIT(FIL1,I1,"","[F:ITF1]STOFCY=[M:ICMM]STOFCY1","&") From GOBJSUB
#Call ADDCRIT(FIL1,I1,"","[F:ITF2]STOFCY=[M:ICMM]STOFCY2","&") From GOBJSUB

#---- Filtre articles ----#
FIL2="1=1"
If [M:ICMM]TCLCODSTR<>""
    Call ADDCRIT(FIL2,I2,"","TCLCOD>=[M:ICMM]TCLCODSTR","&") From GOBJSUB
Endif
If [M:ICMM]TCLCODEND<>""
    Call ADDCRIT(FIL2,I2,"","TCLCOD<=[M:ICMM]TCLCODEND","&") From GOBJSUB
Endif

If [M:ICMM]ITMREFSTR<>""
    Call ADDCRIT(FIL2,I2,"","ITMREF>=[M:ICMM]ITMREFSTR","&") From GOBJSUB
Endif
If [M:ICMM]ITMREFEND<>""
    Call ADDCRIT(FIL2,I2,"","ITMREF<=[M:ICMM]ITMREFEND","&") From GOBJSUB
Endif

If [M:ICMM]BUYSTR<>"" | [M:ICMM]BUYEND<>""
    Call ADDCRIT(FIL2,I2,"","([F:ITF1]BUY>=[M:ICMM]BUYSTR | [F:ITF2]BUY>=[M:ICMM]BUYSTR)","&") From GOBJSUB
Endif
If [M:ICMM]BUYEND<>""
    Call ADDCRIT(FIL2,I2,"","([F:ITF1]BUY<=[M:ICMM]BUYEND | [F:ITF2]BUY<=[M:ICMM]BUYEND)","&") From GOBJSUB
Endif

#---- Filtre familles statistiques ----#
FILTSI="1=1"
If dim([M:ICMM]TSICODSTR) > 0
  For I = 0 To dim([M:ICMM]TSICODSTR)-1
    If [M:ICMM]TSICODSTR(I) <> ""
       Call ADDCRIT(FILTSI,I3,"","[F:ITM]TSICOD("+num$(I)+")>='"+[M:ICMM]TSICODSTR(I)+"'","&") From GOBJSUB
    Endif
    If [M:ICMM]TSICODEND(I) <> ""
       Call ADDCRIT(FILTSI,I3,"","[F:ITM]TSICOD("+num$(I)+")<='"+[M:ICMM]TSICODEND(I)+"'","&") From GOBJSUB
    Endif
  Next I
Endif

#---- Liens fichiers ----#
Link [ITM] With [ITF1]ITF0~=[F:ITM]ITMREF;[M:ICMM]STOFCY1,[ITF2]ITF0~=[F:ITM]ITMREF;[M:ICMM]STOFCY2
&          As [LNK]
&          Where evalue(FIL2) & evalue(FILTSI)

Return

################################################################
# TESTFLT : Teste que l'enregistrement dans [lnk]
#           correspond aux critères de filtre
################################################################
Funprog TESTFLT()
Local Char LTCM(GLONTCM)
Local Integer LRET, LERR
LRET = 1

If [M:ICMM]VLTSTR<>"" | [M:ICMM]VLTEND<>""
    LRET=0
    Call GETTCM([F:ITF1]ITMREF, [F:ITF1]STOFCY, LTCM, LERR) From STKVAL
    If LERR : End 0 : Endif
    If [M:ICMM]VLTSTR<>"" & [M:ICMM]VLTSTR<=LTCM
        LRET=1
    Endif
    If [M:ICMM]VLTEND<>"" & [M:ICMM]VLTEND<LTCM
        LRET=1
    Endif
    Call GETTCM([F:ITF1]ITMREF, [F:ITF2]STOFCY, LTCM, LERR) From STKVAL
    If LERR : End 0 : Endif
    If [M:ICMM]VLTSTR<>"" & [M:ICMM]VLTSTR>LTCM
        LRET=1
    Endif
    If [M:ICMM]VLTEND<>"" & [M:ICMM]VLTEND<LTCM
        LRET=1
    Endif
Endif

End LRET

########################################################
# COMPECART : Comparaison des écarts avec les filtres
########################################################
Funprog COMPECART
If [M:ICMM]SELFLG(0)=2
    If [M:ICM1]COST1(0)=0
        If [M:ICM1]COST2(0)<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(0)=0 & [M:ICMM]VARAMT(0)=0
        End ([M:ICM1]COST1(0)<>[M:ICM1]COST2(0))
    Elsif [M:ICMM]VARPER(0)<>0
        If abs(([M:ICM1]COST1(0)-[M:ICM1]COST2(0))*100/[M:ICM1]COST1(0)) >= [M:ICMM]VARPER(0)
            End 1
        Endif
    Elsif abs([M:ICM1]COST1(0)-[M:ICM1]COST2(0)) >= [M:ICMM]VARAMT(0)
        End 1
    Endif
Endif
#If [M:ICMM]SELFLG(0)=2
#    If [M:ICM1]MATTOT1=0
#        If [M:ICM1]MATTOT2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]VARPER(0)=0 & [M:ICMM]VARAMT(0)=0
#        End ([M:ICM1]COST2(0)<>[M:ICM1]MATTOT2)
#    Elsif [M:ICMM]VARPER(0)<>0
#        If abs(([M:ICM1]MATTOT1-[M:ICM1]MATTOT2)*100/[M:ICM1]MATTOT1) >= [M:ICMM]VARPER(0)
#            End 1
#        Endif
#    Elsif abs([M:ICM1]MATTOT1-[M:ICM1]MATTOT2) >= [M:ICMM]VARAMT(0)
#        End 1
#    Endif
#Endif

If [M:ICMM]SELFLG(1)=2
    If [M:ICM1]COST1(1)=0
        If [M:ICM1]COST2(1)<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(1)=0 & [M:ICMM]VARAMT(1)=0
        End ([M:ICM1]COST1(1)<>[M:ICM1]COST2(1))
    Elsif [M:ICMM]VARPER(1)<>0
        If abs(([M:ICM1]COST1(1)-[M:ICM1]COST2(1))*100/[M:ICM1]COST1(1)) >= [M:ICMM]VARPER(1)
            End 1
        Endif
    Elsif abs([M:ICM1]COST1(1)-[M:ICM1]COST2(1)) >= [M:ICMM]VARAMT(1)
        End 1
    Endif
Endif
#If [M:ICMM]SELFLG(1)=2
#    If [M:ICM1]MACTOT1=0
#        If [M:ICM1]MACTOT2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]VARPER(1)=0 & [M:ICMM]VARAMT(1)=0
#        End ([M:ICM1]MACTOT1<>[M:ICM1]MACTOT2)
#    Elsif [M:ICMM]VARPER(1)<>0
#        If abs(([M:ICM1]MACTOT1-[M:ICM1]MACTOT2)*100/[M:ICM1]MACTOT1) >= [M:ICMM]VARPER(1)
#            End 1
#        Endif
#    Elsif abs([M:ICM1]MACTOT1-[M:ICM1]MACTOT2) >= [M:ICMM]VARAMT(1)
#        End 1
#    Endif
#Endif

If [M:ICMM]SELFLG(2)=2
    If [M:ICM1]COST1(2)=0
        If [M:ICM1]COST2(2)<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(2)=0 & [M:ICMM]VARAMT(2)=0
        End ([M:ICM1]COST1(2)<>[M:ICM1]COST2(2))
    Elsif [M:ICMM]VARPER(2)<>0
        If abs(([M:ICM1]COST1(2)-[M:ICM1]COST2(2))*100/[M:ICM1]COST1(2)) >= [M:ICMM]VARPER(2)
            End 1
        Endif
    Elsif abs([M:ICM1]COST1(2)-[M:ICM1]COST2(2)) >= [M:ICMM]VARAMT(2)
        End 1
    Endif
Endif
#If [M:ICMM]SELFLG(2)=2
#    If [M:ICM1]LABTOT1=0
#        If [M:ICM1]LABTOT2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]VARPER(2)=0 & [M:ICMM]VARAMT(2)=0
#        End ([M:ICM1]LABTOT1<>[M:ICM1]LABTOT2)
#    Elsif [M:ICMM]VARPER(2)<>0
#        If abs(([M:ICM1]LABTOT1-[M:ICM1]LABTOT2)*100/[M:ICM1]LABTOT1) >= [M:ICMM]VARPER(2)
#            End 1
#        Endif
#    Elsif abs([M:ICM1]LABTOT1-[M:ICM1]LABTOT2) >= [M:ICMM]VARAMT(2)
#        End 1
#    Endif
#Endif

If [M:ICMM]SELFLG(3)=2
    If [M:ICM1]COST1(3)=0
        If [M:ICM1]COST2(3)<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(3)=0 & [M:ICMM]VARAMT(3)=0
        End ([M:ICM1]COST1(3)<>[M:ICM1]COST2(3))
    Elsif [M:ICMM]VARPER(3)<>0
        If abs(([M:ICM1]COST1(3)-[M:ICM1]COST2(3))*100/[M:ICM1]COST1(3)) >= [M:ICMM]VARPER(3)
            End 1
        Endif
    Elsif abs([M:ICM1]COST1(3)-[M:ICM1]COST2(3)) >= [M:ICMM]VARAMT(3)
        End 1
    Endif
Endif
#If [M:ICMM]SELFLG(3)=2
#    If [M:ICM1]SCOTOT1=0
#        If [M:ICM1]SCOTOT2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]VARPER(3)=0 & [M:ICMM]VARAMT(3)=0
#        End ([M:ICM1]SCOTOT1<>[M:ICM1]SCOTOT2)
#    Elsif [M:ICMM]VARPER(3)<>0
#        If abs(([M:ICM1]SCOTOT1-[M:ICM1]SCOTOT2)*100/[M:ICM1]SCOTOT1) >= [M:ICMM]VARPER(3)
#            End 1
#        Endif
#    Elsif abs([M:ICM1]SCOTOT1-[M:ICM1]SCOTOT2) >= [M:ICMM]VARAMT(3)
#        End 1
#    Endif
#Endif

#If [M:ICMM]DEVINVFLG=2
#    If [M:ICM1]INVDTA1=0
#        If [M:ICM1]INVDTA2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]PERINV=0 & [M:ICMM]AMTINV=0
#        End ([M:ICM1]INVTOT1<>[M:ICM1]INVTOT2)
#    Elsif [M:ICMM]PERINV<>0
#        If abs(([M:ICM1]INVDTA1-[M:ICM1]INVDTA2)*100/[M:ICM1]INVDTA1) >= [M:ICMM]PERINV
#            End 1
#        Endif
#    Elsif abs([M:ICM1]INVDTA1-[M:ICM1]INVDTA2) >= [M:ICMM]AMTINV
#        End 1
#    Endif
#Endif

If [M:ICMM]SELFLG(4)=2
    If [M:ICM1]COST1(3)=0
        If [M:ICM1]COST2(3)<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(4)=0 & [M:ICMM]VARAMT(4)=0
        End ([M:ICM1]COST1(3)<>[M:ICM1]COST2(3))
    Elsif [M:ICMM]VARPER(4)<>0
        If abs(([M:ICM1]COST1(3)-[M:ICM1]COST2(3))*100/[M:ICM1]COST1(3)) >= [M:ICMM]VARPER(4)
            End 1
        Endif
    Elsif abs([M:ICM1]COST1(3)-[M:ICM1]COST2(3)) >= [M:ICMM]VARAMT(4)
        End 1
    Endif
Endif
#If [M:ICMM]SELFLG(4)=2
#    If [M:ICM1]OVETOT1=0
#        If [M:ICM1]OVETOT2<>0
#            End 1
#        Endif
#    Elsif [M:ICMM]VARPER(4)=0 & [M:ICMM]VARAMT(4)=0
#        End ([M:ICM1]OVETOT1<>[M:ICM1]OVETOT2)
#    Elsif [M:ICMM]VARPER(4)<>0
#        If abs(([M:ICM1]OVETOT1-[M:ICM1]OVETOT2)*100/[M:ICM1]OVETOT1) >= [M:ICMM]VARPER(4)
#            End 1
#        Endif
#    Elsif abs([M:ICM1]OVETOT1-[M:ICM1]OVETOT2) >= [M:ICMM]VARAMT(4)
#        End 1
#    Endif
#Endif

If [M:ICMM]SELFLG(5)=2
    If [M:ICM1]CSTTOT1=0
        If [M:ICM1]CSTTOT2<>0
            End 1
        Endif
    Elsif [M:ICMM]VARPER(5)=0 & [M:ICMM]VARAMT(5)=0
        End ([M:ICM1]CSTTOT1<>[M:ICM1]CSTTOT2)
    Elsif [M:ICMM]VARPER(5)<>0
        If abs(([M:ICM1]CSTTOT1-[M:ICM1]CSTTOT2)*100/[M:ICM1]CSTTOT1) >= [M:ICMM]VARPER(5)
            End 1
        Endif
    Elsif abs([M:ICM1]CSTTOT1-[M:ICM1]CSTTOT2) >= [M:ICMM]VARAMT(5)
        End 1
    Endif
Endif
End 0
