######################################################################################
Subprog AM_SELFLG(VALEUR) #X3-101694 MJH
Variable Integer VALEUR

  If VALEUR=2
    Actzo [M:ICMM]VARPER(nolign-1), VARAMT(nolign-1)
  Else
    Effzo [M:ICMM]VARPER(nolign-1), VARAMT(nolign-1)
    Diszo [M:ICMM]VARPER(nolign-1), VARAMT(nolign-1)
  Endif

End


