#<AdxTL>@(#)3.0.0.0 $Revision$
#-----------------------------------------------------------------#
# Rénumérotation des paragraphes de la documentation
#-----------------------------------------------------------------#

Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "AFC"
PARAM(2) = "AIMP"
Call TRAITE_CHAR(VALEUR,PARAM,"","ADOCREN","ADOCREN",3,"") From GTRAITE
End

#---------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "TERMINE"  : Gosub TERMINE
Endcase
Return

#---------------------------------------------#
$INIT
Local Mask ADOCREN [DIA]
Local Char    CRITERE(250)
Local Integer ICRITERE , NUMLEV , NUMSUB
[M]TYP = PARAM(1)
[M]COD = PARAM(2)
Return

#---------------------------------------------#
$CONTROLE
If [M]LEVSTP=0 & [M]SUBLEVSTP=0
 FIN = 1 : Return
Endif

Raz CRITERE , ICRITERE
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'TYP="'+[M]TYP+'"',"&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'COD="'+[M]COD+'"',"&") From GOBJSUB
If [M]LEVSTR<>0
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEV>='+num$([M]LEVSTR),"&") From GOBJSUB
Endif
If [M]LEVEND<>0
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'LEV<='+num$([M]LEVEND),"&") From GOBJSUB
Endif
If [M]SUBLEVSTR<>0
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'SUBLEV>='+num$([M]SUBLEVSTR),"&") From GOBJSUB
Endif
If [M]SUBLEVEND<>0
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'SUBLEV<='+num$([M]SUBLEVEND),"&") From GOBJSUB
Endif
Local File ADOCUMENT [AD_] Where evalue(CRITERE) Order By Key CLE=TYP;COD;LEV;SUBLEV;LAN

#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
If !func AGENLIBA.ALLLAN_GROUPE_OK("ADO", [M]TYP, [M]COD)
  GERR=1 :  FIN=1  :  Return
Endif

If [M]SIMUL<>2
 # Renumérotation des paragraphes
 Call AVERTIR(mess(31,176,1)-"("+num$(rowcount([F:AD_]))+")",OK) From GESECRAN
 If OK<>2 : FIN = 1 : Return : Endif
Endif

Return

#---------------------------------------------#
$EXEC
Local File ADOCUMENT [ADO] , ADOCBLB [ADB] , ADOCCLB [ADH]

TRA = 1
Call OUVRE_TRACE(mess(31,176,1)) From LECFIC

If [M]SIMUL=2
 Call ECR_TRACE(mess(6,115,1)+"\"+string$(40,"-"),0) From GESECRAN : # Simulation
Endif

Call DEBTRANS From GLOCK
Gosub TR1

Call FERME_TRACE From LECFIC

Close Local File [ADO] , [ADB] , [ADH] , [AD_]
Return

#---------------------------------------------#
$TERMINE
If [M]SIMUL=2
 SAI = 1
Endif
Return

#------------------------------------#
$TR1
Trbegin [ADO]
 Delete [ADO] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADO") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADO") From GLOCK : Goto AB_TR1
 Endif
 Delete [ADB] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADB") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADB") From GLOCK : Goto AB_TR1
 Endif
 Delete [ADH] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADH") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADH") From GLOCK : Goto AB_TR1
 Endif
 NUMLEV = 0
 NUMSUB = 0
 For [AD_]CLE(3)
  If [M]LEVSTP>0
   If NUMLEV=0
    NUMLEV = [M]LEVNUM
   Elsif [M]RUPT=2
    NUMLEV += [M]LEVSTP
    NUMSUB = 0
   Endif
  Else
   If [M]RUPT=2
    NUMLEV = [F:AD_]LEV
    NUMSUB = 0
   Elsif NUMLEV=0
    NUMLEV = [F:AD_]LEV
   Endif
  Endif
  For [AD_]CLE(4)
   If [M]SUBLEVSTP>0
    If NUMSUB=0
     NUMSUB = [M]SUBLEVNUM
    Else
     NUMSUB += [M]SUBLEVSTP
    Endif
   Else
    NUMSUB = [F:AD_]SUBLEV
   Endif
   MESSA = [F:AD_]TYP-[F:AD_]COD-num$([F:AD_]LEV)-num$([F:AD_]SUBLEV)
   MESSA -= "---->"-num$(NUMLEV)-num$(NUMSUB)
   Call ECR_TRACE(MESSA,0) From GESECRAN
   For [AD_]CLE
    If [M]SIMUL<>2
     [F:ADO] = [F:AD_]
     [F:ADO]LEV    = 0
     [F:ADO]SUBLEV = NUMSUB*10000+NUMLEV
     Write [ADO]
     If fstat
      GOK=0 : Call FSTA("ADO") From GLOCK : Break 3
     Endif
     For [ADB] Where LAN=[F:AD_]LAN & TYP=[F:AD_]TYP & COD=[F:AD_]COD & LEV=[F:AD_]LEV & SUBLEV=[F:AD_]SUBLEV
      [F:ADB]LEV    = 0
      [F:ADB]SUBLEV = NUMSUB*10000+NUMLEV
      Write [ADB]
      If fstat
       GOK=0 : Call FSTA("ADB") From GLOCK : Break 4
      Endif
     Next ADB
     For [ADH] Where LAN=[F:AD_]LAN & TYP=[F:AD_]TYP & COD=[F:AD_]COD & LEV=[F:AD_]LEV & SUBLEV=[F:AD_]SUBLEV
      [F:ADH]LEV    = 0
      [F:ADH]SUBLEV = NUMSUB*10000+NUMLEV
      Write [ADH]
      If fstat
       GOK=0 : Call FSTA("ADH") From GLOCK : Break 4
      Endif
     Next ADH
    Endif
   Next AD_
  Next AD_4
 Next AD_3
 If GOK<1 : Goto AB_TR1 : Endif
 If [M]SIMUL<>2
  Delete [ADO] Where evalue(CRITERE)
  If fstat=1
   GOK=-1 : Call FSTA("ADO") From GLOCK : Goto ROLL_TR1
  Elsif fstat
   GOK=0 : Call FSTA("ADO") From GLOCK : Goto AB_TR1
  Endif
  Delete [ADB] Where evalue(CRITERE)
  If fstat=1
   GOK=-1 : Call FSTA("ADB") From GLOCK : Goto ROLL_TR1
  Elsif fstat
   GOK=0 : Call FSTA("ADB") From GLOCK : Goto AB_TR1
  Endif
  Delete [ADH] Where evalue(CRITERE)
  If fstat=1
   GOK=-1 : Call FSTA("ADH") From GLOCK : Goto ROLL_TR1
  Elsif fstat
   GOK=0 : Call FSTA("ADH") From GLOCK : Goto AB_TR1
  Endif
  For [ADO] Where LEV=0
   [F:ADO]LEV = mod([F:ADO]SUBLEV,10000)
   [F:ADO]SUBLEV = int([F:ADO]SUBLEV/10000)
   Write [ADO]
   If fstat
    GOK=0 : Call FSTA("ADO") From GLOCK : Break
   Endif
  Next ADO
  If GOK<1 : Goto AB_TR1 : Endif
  For [ADB] Where LEV=0
   [F:ADB]LEV = mod([F:ADB]SUBLEV,10000)
   [F:ADB]SUBLEV = int([F:ADB]SUBLEV/10000)
   Write [ADB]
   If fstat
    GOK=0 : Call FSTA("ADB") From GLOCK : Break
   Endif
  Next ADB
  If GOK<1 : Goto AB_TR1 : Endif
  For [ADH] Where LEV=0
   [F:ADH]LEV = mod([F:ADH]SUBLEV,10000)
   [F:ADH]SUBLEV = int([F:ADH]SUBLEV/10000)
   Write [ADH]
   If fstat
    GOK=0 : Call FSTA("ADH") From GLOCK : Break
   Endif
  Next ADH
  If GOK<1 : Goto AB_TR1 : Endif
 Endif
 Delete [ADO] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADO") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADO") From GLOCK : Goto AB_TR1
 Endif
 Delete [ADB] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADB") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADB") From GLOCK : Goto AB_TR1
 Endif
 Delete [ADH] Where LEV=0
 If fstat=1
  GOK=-1 : Call FSTA("ADH") From GLOCK : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call FSTA("ADH") From GLOCK : Goto AB_TR1
 Endif
 For [AD_]CLE(3)
    Call MAJ_ENVINDUS_DOC ([F:AD_]LAN,[F:AD_]TYP,[F:AD_]COD,2) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
 Next AD_3
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#---------------------------------------------#
Subprog C_LEVEND(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]LEVSTR : mkstat = 1 : Endif
End

Subprog C_SUBLEVEND(VALEUR)
Variable Decimal VALEUR
If VALEUR<[M]SUBLEVSTR : mkstat = 1 : Endif
End

Subprog AM_LEVSTR(VALEUR)
Variable Decimal VALEUR
Effzo [M]LEVEND
End

Subprog D_LEVEND(VALEUR)
Variable Decimal VALEUR
If [M]LEVSTR<>0 : VALEUR = [M]LEVSTR : Endif
End

Subprog AM_SUBLEVSTR(VALEUR)
Variable Decimal VALEUR
Effzo [M]SUBLEVEND
End

Subprog D_SUBLEVEND(VALEUR)
Variable Decimal VALEUR
If [M]SUBLEVSTR<>0 : VALEUR = [M]SUBLEVSTR : Endif
End
