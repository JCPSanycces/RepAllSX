#<AdxTL>@(#)0.0.0.0 $Revision$ Import catégorie article
#########################################################################
# IMPITG : Import/Export des catégorie article              HN 02/08/04 #
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
#########################################################################
$ACTION
Case ACTION
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMP_DEFTRT"    : Gosub IMP_DEFTRT
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_ZONE
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE
  When "EXPORT"        : Gosub EXPORT
  When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return
#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
$SETMODE_OFF
Setmode
Return

$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return

##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################
#Pas de gestion de texte


##########################################################################
#                                  IMPORT                                #
##########################################################################

#--------------------------#
# Début de l'import/export #
#--------------------------#
$OUVRE
Local  Integer   OKCHAMP
Local  Shortint  WNOL
Local  Integer   W_I
Local  Integer   SVGNOLIGN
Global Shortint  GNBINT
Global Shortint  GNBLOC
Global Shortint  GNBENT
Global Integer   GNBRINT
Global Integer   GNBRLOC
Global Integer   GNBRENT
Return

#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Local Char    NOMCHAMP(30)
Local Integer OKCHAMP, WNBELEMENT, W_I, LOCDESN, WFLG
Case IMPFIC
  When "ITG" :
      Raz GNBINT, GNBLOC, GNBENT, GNBRINT, GNBRLOC, GNBRENT
       Raz [M:ITG2]NBINT, LOCDES                 # hcb X3-71908
      #Raz [M:ITG9]NBINT, LOCDES                 # hcb X3-71908
      Raz GNBRINT, GNBINT
      # --------------------------------------  #
      # Traitement du tableau des coefficients  #
      # --------------------------------------  #
      Raz W_I, WNBELEMENT
      For W_I=0 To dim([F:ITG]PCU)-1
        NOMCHAMP = "PCU("+num$(W_I)+")"
        Raz OKCHAMP
        Call TST_CHAMP("ITG",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & evalue("[F:ITG]"+NOMCHAMP) <> ""
          # La ligne a été paramétrée
          WNBELEMENT +=1
        Elsif [M:ITG3]PCU(W_I) <> ""
          WNBELEMENT +=1
        Endif
      Next W_I
      [M:ITG3]BASTAB = WNBELEMENT

      # ---------------------------------------  #
      # Traitement du tableau des frais généraux #
      # ---------------------------------------  #
      Raz W_I, WNBELEMENT
      For W_I=0 To dim([F:ITG]OVECOD)-1
        NOMCHAMP = "OVECOD("+num$(W_I)+")"
        Raz OKCHAMP
        Call TST_CHAMP("ITG",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & evalue("[F:ITG]"+NOMCHAMP) <> ""
          # La ligne a été paramétrée
          WNBELEMENT +=1
        Endif
      Next W_I
      [M:ITG5]NBTYP = WNBELEMENT

      Raz WNBELEMENT
      If [F:ITG]LOCMGTCOD=1
        Raz [M:ITG2]NBINT, LOCDES, GNBINT         # hcb X3-71908
        #Raz [M:ITG9]NBINT, LOCDES                  # hcb X3-71908
        Raz GNBINT
      Else
        #----------------------------------#
        # Le tableau emplacements dédiés   #
        #----------------------------------#
        NOMCHAMP = "LOCDES(0)"
        Raz OKCHAMP
        Call TST_CHAMP("ITG",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & [M:ITG2]NBINT<>0                        # hcb X3-71908
        #If OKCHAMP & [M:ITG9]NBINT<>0                       # hcb X3-71908
          Raz [M:ITG2]NBINT, LOCDES                          # hcb X3-71908
          #Raz [M:ITG9]NBINT, LOCDES                         # hcb X3-71908
          GNBINT=1
        Endif
      Endif
      Raz W_I
      Raz WFLG
      If [F:ITG]LOCMGTCOD=2
        For W_I=0 To dim([F:ITG]LOCDES)-1
          NOMCHAMP = "LOCDES("+num$(W_I)+")"
          Raz OKCHAMP
          Call TST_CHAMP("ITG",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
          If OKCHAMP
            If evalue("[F:ITG]"+NOMCHAMP)>1
              WNBELEMENT +=1
            Elsif evalue("[F:ITG]"+NOMCHAMP)=1 & WFLG=0
              WFLG=1
              WNBELEMENT +=1
            Endif
          Endif
        Next W_I
        [M:ITG2]NBINT = WNBELEMENT           # hcb X3-71908
        #[M:ITG9]NBINT = WNBELEMENT            # hcb X3-71908
      Else
        Raz [M:ITG2]LOCDES, NBINT           # hcb X3-71908
      Endif

  When "SRU"
      If GREP="C"
        NOMCHAMP = "TRSTYP"
        Raz OKCHAMP
        Call TST_CHAMP("SRU",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
        If OKCHAMP
          If GNBLOC=0
            If [M:ITG4]NBLOC<>0
              Raz [M:ITG4]NBLOC, TRSTYPS, TRSCODS, AUZSTAS, AUZSSTS, FORSTAS, CONCATKEYS
              If dim([M:ITG4]LOCNUM)>0 : Raz [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3 : Endif
              If dim([M:ITG4]SHLLOT)>0 : Raz [M:ITG4]SHLLOT : Endif
            Endif
            GNBLOC=1
            GNBRLOC=0
          Endif
          If GNBENT=0
            If [M:ITG8]NBENT<>0
              Raz [M:ITG8]NBENT, TRSTYPE, TRSCODE, AUZSTAE, AUZSSTE, DEFSTA,
&                 FORSTAE, QLYCTLFLG, CONCATKEYE
              If dim([M:ITG8]LOCNUME)>0 : Raz [M:ITG8]LOCNUME : Endif
              If dim([M:ITG8]DACLOT)>0  : Raz [M:ITG8]DACLOT, LOTSUPINH : Endif
            Endif
            GNBENT=1
            GNBRENT=0
          Endif
        Else
          Raz [M:ITG4]NBLOC, TRSTYPS, TRSCODS, AUZSTAS, AUZSSTS, FORSTAS, CONCATKEYS
          If dim([M:ITG4]LOCNUM)>0 : Raz [M:ITG4]LOCNUM, LOCNUM2, LOCNUM3 : Endif
          If dim([M:ITG4]SHLLOT)>0 : Raz [M:ITG4]SHLLOT : Endif
          Raz [M:ITG8]NBENT, TRSTYPE, TRSCODE, AUZSTAE, AUZSSTE, DEFSTA,
&             FORSTAE, QLYCTLFLG, CONCATKEYE
          If dim([M:ITG8]LOCNUME)>0 : Raz [M:ITG8]LOCNUME : Endif
          If dim([M:ITG8]DACLOT)>0  : Raz [M:ITG8]DACLOT, LOTSUPINH : Endif
        Endif
      Endif

      If GREP="M"
        NOMCHAMP = "TRSTYP"
        Raz OKCHAMP
        Call TST_CHAMP("SRU",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
        If OKCHAMP
          NOMCHAMP = "TRSCOD"
          Raz OKCHAMP
          Call TST_CHAMP("SRU",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
          If OKCHAMP
            W_I=1
            Case evalue("[F:SRU]TRSTYP")
              When 1,3,5,8,12,16,18,19,26,28,33
                  While W_I-1<[M:ITG8]NBENT
                    If [M:ITG8]TRSTYPE(W_I-1)=evalue("[F:SRU]TRSTYP") & [M:ITG8]TRSCODE(W_I-1)=evalue("[F:SRU]TRSCOD")
                      Break
                    Else
                      W_I+=1
                    Endif
                  Wend
                  If W_I-1=[M:ITG8]NBENT : Raz W_I : Endif
                  If W_I=0
                    [M:ITG8]NBENT+=1
                    GNBRENT=[M:ITG8]NBENT
                    nolign =[M:ITG8]NBENT
                  Else
                    nolign=W_I
                  Endif
                  indice=nolign-1
              When 2,4,6,11,17,20,24,25,27,29,32
                  While W_I-1<[M:ITG4]NBLOC
                    If [M:ITG4]TRSTYPS(W_I-1)=evalue("[F:SRU]TRSTYP") & [M:ITG4]TRSCODS(W_I-1)=evalue("[F:SRU]TRSCOD")
                      Break
                    Else
                      W_I+=1
                    Endif
                  Wend
                  If W_I-1=[M:ITG4]NBLOC : Raz W_I : Endif
                  If W_I=0
                    [M:ITG4]NBLOC+=1
                    GNBRLOC=[M:ITG4]NBLOC
                    nolign =[M:ITG4]NBLOC
                  Else
                    nolign=W_I
                  Endif
                  indice=nolign-1
            Endcase
          Endif
        Endif
      Endif
Endcase


Return

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Local Char    NOMCHAMP(30)
Local Integer OKCHAMP
Local Integer WNBELEMENT
Local Integer W_I
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "SRU"
      If GREP="C"
        Case IMPZON
          When "TRSTYPE"
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                WNBELEMENT =GNBRENT
                WNBELEMENT+=1
                [M:ITG8]NBENT=WNBELEMENT
                GNBRENT=[M:ITG8]NBENT
                nolign=GNBRENT
                indice=nolign-1
                Gosub IMP_TAB
              Endif
          When "TRSTYPS"
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                WNBELEMENT =GNBRLOC
                WNBELEMENT+=1
                [M:ITG4]NBLOC=WNBELEMENT
                GNBRLOC=[M:ITG4]NBLOC
                nolign=GNBRLOC
                indice=nolign-1
                Gosub IMP_TAB
              Endif
          When "LOCNUME"
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                nolign=GNBRENT
                indice=nolign-1
                Gosub IMP_TAB
              Endif
          When "LOCNUM","LOCNUM2","LOCNUM3"
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                nolign=GNBRLOC
                indice=nolign-1
                Gosub IMP_TAB
              Endif
          When "TRSCODE", "AUZSTAE", "AUZSSTE", "DEFSTA", "QLYCTLFLG", "DACLOT", "LOTSUPINH"
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                nolign=GNBRENT
                indice=nolign-1
                Gosub IMP_TAB
              Endif
          When "TRSCODS", "AUZSTAS", "AUZSSTS", "SHLLOT"
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                nolign=GNBRLOC
                indice=nolign-1
                Gosub IMP_TAB
              Endif
        Endcase
      Endif
      If GREP="M"
        Case IMPZON
          When "TRSTYPS", "TRSTYPE", "LOCNUM", "LOCNUM2", "LOCNUM3", "LOCNUME",
&              "TRSCODS", "TRSCODE", "AUZSTAS", "AUZSTAE", "AUZSSTS", "AUZSSTE",
&              "DEFSTA", "QLYCTLFLG", "DACLOT", "LOTSUPINH", "SHLLOT"
              Gosub IMP_TAB
        Endcase
      Endif
Endcase
Return


#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
Local Integer  OKCHAMP
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "SRU"
      indice = nolign-1
      Case IMPZON
        When "TRSTYPS"
            #----------------#
            # Type mouvement #
            #----------------#
            Call TST_CHAMP("SRU","TRSTYP",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                [M:ITG4]TRSTYPS(nolign-1)=[F:SRU]TRSTYP
              Endif
            Endif
            Raz OKCHAMP
        When "TRSTYPE"
            #----------------#
            # Type mouvement #
            #----------------#
            Call TST_CHAMP("SRU","TRSTYP",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]TRSTYPE(nolign-1)=[F:SRU]TRSTYP
              Endif
            Endif
            Raz OKCHAMP
        When "TRSCODS"
            #----------------#
            # Code mouvement #
            #----------------#
            Call TST_CHAMP("SRU","TRSCOD",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                [M:ITG4]TRSCODS(nolign-1)=[F:SRU]TRSCOD
              Endif
            Endif
            Raz OKCHAMP
        When "TRSCODE"
            #----------------#
            # Code mouvement #
            #----------------#
            Call TST_CHAMP("SRU","TRSCOD",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]TRSCODE(nolign-1)=[F:SRU]TRSCOD
              Endif
            Endif
            Raz OKCHAMP
        When "LOCNUM"
           If [M:ITG2]LOCMGTCOD=2                # hcb X3-71908
           # If [M:ITG9]LOCMGTCOD=2
              #----------------#
              # Emplacement    #
              #----------------#
              Call TST_CHAMP("SRU","LOCNUM",OKCHAMP) From SUBIMPOBJ
              If OKCHAMP
                If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                  If dim([M:ITG4]LOCNUM)>0
                    [M:ITG4]LOCNUM(nolign-1)=[F:SRU]LOCNUM
                  Endif
                Endif
                Raz OKCHAMP
              Endif
            Else
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                If dim([M:ITG4]LOCNUM)>0
                  Raz [M:ITG4]LOCNUM(nolign-1)
                Endif
              Endif
            Endif
        When "LOCNUM2"
             If [M:ITG2]LOCMGTCOD=2                # hcb X3-71908
           # If [M:ITG9]LOCMGTCOD=2
              #----------------#
              # Emplacement    #
              #----------------#
              Call TST_CHAMP("SRU","LOCNUM2",OKCHAMP) From SUBIMPOBJ
              If OKCHAMP
                If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                  If dim([M:ITG4]LOCNUM2)>0
                    [M:ITG4]LOCNUM2(nolign-1)=[F:SRU]LOCNUM2
                  Endif
                Endif
                Raz OKCHAMP
              Endif
            Else
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                If dim([M:ITG4]LOCNUM2)>0
                  Raz [M:ITG4]LOCNUM2(nolign-1)
                Endif
              Endif
            Endif
        When "LOCNUM3"
          If [M:ITG2]LOCMGTCOD=2                # hcb X3-71908
           # If [M:ITG9]LOCMGTCOD=2
              #----------------#
              # Emplacement    #
              #----------------#
              Call TST_CHAMP("SRU","LOCNUM3",OKCHAMP) From SUBIMPOBJ
              If OKCHAMP
                If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                  If dim([M:ITG4]LOCNUM3)>0
                    [M:ITG4]LOCNUM3(nolign-1)=[F:SRU]LOCNUM3
                  Endif
                Endif
                Raz OKCHAMP
              Endif
            Else
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                If dim([M:ITG4]LOCNUM3)>0
                  Raz [M:ITG4]LOCNUM3(nolign-1)
                Endif
              Endif
            Endif
        When "LOCNUME"
             If [M:ITG2]LOCMGTCOD=2                # hcb X3-71908
           # If [M:ITG9]LOCMGTCOD=2
              #----------------#
              # Emplacement    #
              #----------------#
              Call TST_CHAMP("SRU","LOCNUM",OKCHAMP) From SUBIMPOBJ
              If OKCHAMP
                If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                  If dim([M:ITG8]LOCNUME)>0
                    [M:ITG8]LOCNUME(nolign-1)=[F:SRU]LOCNUM
                  Endif
                Endif
                Raz OKCHAMP
              Endif
            Else
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                If dim([M:ITG8]LOCNUME)>0
                  Raz [M:ITG8]LOCNUME(nolign-1)
                Endif
              Endif
            Endif
        When "AUZSTAS"
            #------------------#
            # Statut autorisés #
            #------------------#
            Call TST_CHAMP("SRU","AUZSTA",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                [M:ITG4]AUZSTAS(nolign-1)=[F:SRU]AUZSTA
              Endif
            Endif
            Raz OKCHAMP
        When "AUZSTAE"
            #------------------#
            # Statut autorisés #
            #------------------#
            Call TST_CHAMP("SRU","AUZSTA",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]AUZSTAE(nolign-1)=[F:SRU]AUZSTA
              Endif
            Endif
            Raz OKCHAMP
        When "AUZSSTS"
            #----------------#
            # Statut défaut  #
            #----------------#
            Call TST_CHAMP("SRU","AUZSST", OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                [M:ITG4]AUZSSTS(nolign-1)=[F:SRU]AUZSST
              Endif
            Endif
            Raz OKCHAMP
        When "AUZSSTE"
            #----------------#
            # Statut défaut  #
            #----------------#
            Call TST_CHAMP("SRU","AUZSST", OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]AUZSSTE(nolign-1)=[F:SRU]AUZSST
              Endif
            Endif
            Raz OKCHAMP
        When "DEFSTA"
            #----------------#
            # Statut défaut  #
            #----------------#
            Call TST_CHAMP("SRU","DEFSTA", OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]DEFSTA(nolign-1)=[F:SRU]DEFSTA
              Endif
            Endif
            Raz OKCHAMP
        When "QLYCTLFLG"
            #-------------#
            # Dde analyse #
            #-------------#
            Call TST_CHAMP("SRU","QLYCTLFLG",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                [M:ITG8]QLYCTLFLG(nolign-1)=[F:SRU]QLYCTLFLG
              Endif
            Endif
            Raz OKCHAMP
        When "DACLOT"
            #------------#
            # Saisie lot #
            #------------#
            Call TST_CHAMP("SRU","DACLOT",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & dim([M:ITG8]DACLOT)>0
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                If dim([M:ITG8]DACLOT)>0
                  [M:ITG8]DACLOT(nolign-1)=[F:SRU]DACLOT
                Endif
              Endif
            Endif
            Raz OKCHAMP
        When "LOTSUPINH"
            #----------------#
            # Lot par défaut #
            #----------------#
            Call TST_CHAMP("SRU","LOTSUPINH",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & dim([M:ITG8]LOTSUPINH)>0
              If find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)
                If dim([M:ITG8]LOTSUPINH)>0
                  [M:ITG8]LOTSUPINH(nolign-1)=[F:SRU]LOTSUPINH
                Endif
              Endif
            Endif
            Raz OKCHAMP
        When "SHLLOT"
            #-------------------#
            # Sortie lot périmé #
            #-------------------#
            Call TST_CHAMP("SRU","SHLLOT",OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & dim([M:ITG4]SHLLOT)>0
              If find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)
                If dim([M:ITG4]SHLLOT)>0
                  [M:ITG4]SHLLOT(nolign-1)=[F:SRU]SHLLOT
                Endif
              Endif
            Endif
            Raz OKCHAMP
        Endcase
Endcase
Return

#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
Kill  GNBINT
Kill  GNBLOC
Kill  GNBENT
Kill  GNBRINT
Kill  GNBRLOC
Kill  GNBRENT
If clalev([F:ITGI])>0 Close Local File [ITGI] : Endif
Return

#------------------------------------#
# Traitements de IMP_ZONE et IMP_TAB #
#------------------------------------#
$TRT_IMP_ZONE
Return

$IMP_DEFTRT

# Si niveau 2 (SRU), changement du nom de traitement pour ne pas exécuter
# les SAIMSK, SAI_NBLOC et SAI_NBENT des traitements W0ITG4 ou W0ITG8 selon
# le type de transaction (E/S)
If SEPNUM=2 &
&  ((TRTMSK="W0ITG4" & !find([F:SRU]TRSTYP,2,4,6,11,17,20,24,25,27,29,32)) |
&  (TRTMSK="W0ITG8" & !find([F:SRU]TRSTYP,1,3,5,8,12,16,18,19,26,28,33)))
   TRTMSK="IMPITGB"
Endif

Return

##########################################################################
#                                   EXPORT                               #
##########################################################################

#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
Return


#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Return

#------------------------------------------#
