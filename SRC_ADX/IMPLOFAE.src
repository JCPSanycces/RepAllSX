#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################
#    TRAITEMENT D'IMPORT DES PIECES ABEL ENTREPRISE
#
#    Création le : 16.04.2010
#
#*********************************************************************
#    Modification
#    CBO  28.11.2014 FQ104360 : Undo a linked expense when balance sht val is changed
#    CBO - 29.04.2014 FQ69690 : Objet FAM
#    GLE - 04.01.2011 FQ70360 : erreur "SCT1 inexistant" si la dépense est liée à un bien
################################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"            : Gosub IMP_OUVRE
 When "IMPORT"               : Gosub IMPORT
 When "IMP_VERIF_CRE"        : Gosub IMP_VERIF_CRE
 When "IMP_INICRE"           : Gosub IMP_INICRE
 When "IMP_ZONE"             : Gosub IMP_ZONE      #--> Exécuté pour chaque zone de l'enr
 When "IMP_TAB"              : Gosub IMP_TAB
 When Default
Endcase
Return

$IMP_OUVRE
  Local Integer L_I
  Local Shortint INDIC_RAE : # Indique si le lancement se fair par la fenêtre de reprise dédiée REPRISEAE
  If clalev([M:RAE]) : INDIC_RAE = 1 : Endif

  Global Integer CRESAC               : # Indicateur de création auto du secteur d'activité
  Global Integer CREGAC               : # Indicateur de création auto du compte comptable
  Global Integer CREACGGRP            : # Indicateur de création auto de la famille

  Global Char    AEAXE(GLONDIE)(1..4) : # Correspondance entre les 4 axes gérés par Abel Entreprise et les axes du modèle comptable de la société

  Gosub IMP_OUVRE From IMPLOF

  If !clalev([F:FAS])  : Local File FXDASSETS            [FAS]  : Endif
  If !clalev([F:GAC])  : Local File =GTABCPT+"GACCOUNT"  [GAC]  : Endif
  If !clalev([F:SAC])  : Local File SECACT               [SAC]  : Endif
  If !clalev([F:LLOF]) : Local File LAYOUTFAS            [LLOF] : Endif
  If !clalev([F:WLOF]) : Local File LAYOUTFAS            [WLOF] : Endif

  # Flags de création automatique du référentiel
  If INDIC_RAE
    CREITMREF = [M:RAE]FLGITM
    CREBPR    = [M:RAE]FLGBPR
    CREGAC    = [M:RAE]FLGGAC
    CRESAC    = [M:RAE]FLGSAC
    CREACGGRP = [M:RAE]FLGFAM
    For L_I = 0 To GOPTCANA-1
      CRECCE(L_I) = G_NON : # on court-circuite la création automatique dans IMPLOF pour s'en occuper dans ce traitement
    Next
  Else
    CREITMREF = G_OUI
    CREBPR    = G_OUI
    CREGAC    = G_OUI
    CRESAC    = G_OUI
    CREACGGRP = G_OUI
    For L_I = 0 To GOPTCANA-1
      CRECCE(L_I) = G_NON : # on court-circuite la création automatique dans IMPLOF pour s'en occuper dans ce traitement
    Next
  Endif
  CREPLNINV = G_OUI
  CREBUDINV = G_OUI
  CREDEMINV = G_OUI

  GCOUSIT = ""
Return

$IMPORT
  If [F:LOF]FCY <> GCOUSIT
    Call ACTION_FCY([F:LOF]FCY,[F:LOF]CPY) From GLOFCYCPY
    Gosub LEC_PARAM_AE
  Else
    [F:LOF]CPY = GCOUSOC
  Endif

  Gosub IMPORT From IMPLOF

  [F:WLOF]          = [F:LOF]
  [F:WLOF]CODLOFORI = [F:LOF]CODLOF
  [F:WLOF]LINLOFORI = [F:LOF]LINLOF
Return

$IMP_VERIF_CRE
  Local Integer ACN

  ##########################################
  # Alimentation des champs non saisissables
  #
  # Il faut travailler avec une sauvegarde de la classe [F:LOF] car ici le Superviseur a déjà
  # chargé l'enregistrement suivant dans la classe [F:LOF]

  # Lien vers un bien comptable
  If [F:WLOF]AASREF <> ""
    # Contrôle de l'existence du bien par rapport à la société et à la référence d'origine
    Filter [F:FAS] Where AASREFORI=[F:WLOF]AASREF
    Read [F:FAS]FAS1(1)=[F:WLOF]CPY
    Filter [F:FAS]
    If fstat
      GMESSAGE=mess(8,GML_MSGMIS,1)-[F:WLOF]CPY-"/"-[F:WLOF]AASREF
      OK = 0
      Return
    Endif

    [M:LOF1]AASREF    = [F:FAS]AASREF
    [M:LOF1]FLGLIKAAS = G_OUI
    Filter [F:LLOF] Where AASREF=[F:FAS]AASREF
    If rowcount([F:LLOF])
      [M:LOF1]FLGLOFMAI = G_NON
    Else
      [M:LOF1]FLGLOFMAI = G_OUI
    Endif
  Endif
  [M:LOF1]FLGDETEXP = G_OUI # FQ104360

  # Montants : on force tous les montants issus d'Abel Entreprise !
  [M:LOF1]AMTNOTCUR  = [F:WLOF]AMTNOTCUR
  [M:LOF1]AMTVATCUR  = [F:WLOF]AMTVATCUR
  [M:LOF1]RATVAT     = [F:WLOF]RATVAT * 100
  [M:LOF1]FLGVATFCR  = G_OUI
  [M:LOF1]RATVATREC  = [F:WLOF]RATVATREC * 100
  [M:LOF1]AMTVATRCUR = [F:WLOF]AMTVATRCUR
  [M:LOF1]FLGRECFVR  = G_OUI
  [M:LOF1]AMTNOTCPY  = [F:WLOF]AMTNOTCPY
  [M:LOF1]AMTVATCPY  = [F:WLOF]AMTVATCPY
  [M:LOF1]AMTVATRCPY = [F:WLOF]AMTVATRCPY

  # Les taux sont toujours validés
  [M:LOF1]FLGVAL = G_OUI

  # Imputations comptables
  [M:LOF1]GACORI = [F:WLOF]GACORI
  If CREGAC = G_OUI
    [L]ACN         = func GLOFUNCIMP.CONV_CLS_AE(val(GIMP(28)))
    Call CRE_ACC([M:FPC]COA([M:FPC]GENLEDTYP-1),[F:WLOF]GACORI,GIMP(27),[L]ACN) From GLOFUNCIMP
  Endif
  If [M:LOF1]IASACC <> ""
    [M:LOF1]IASACCORI = [F:WLOF]IASACCORI
    If CREGAC = G_OUI
      [L]ACN            = func GLOFUNCIMP.CONV_CLS_AE(val(GIMP(31)))
      Call CRE_ACC([M:FPC]COA([M:FPC]IASLEDTYP-1),[F:WLOF]IASACCORI,GIMP(29),[L]ACN) From GLOFUNCIMP
    Endif
  Endif

  # Héritage du bien si la dépense est liée
  If [M:LOF1]FLGLIKAAS = G_OUI and [M:LOF1]AASREF<>""
    Read [F:FAS]FAS0=[M:LOF1]AASREF
    If !fstat
      [M:LOF2]IASCGU = [F:FAS]IASCGU
      # Début FQ70360
      #[M:LOF2]SCT1   = [F:FAS]SCT1
      #[M:LOF2]SCT2   = [F:FAS]SCT2
      If [M:FPC]FLGIAS = G_OUI
        Local Shortint N_AXE
        Local Char     C_DIE
        For N_AXE = 1 To 9
          C_DIE = evalue("[M:FPC]CCE"+num$(N_AXE)+"("+num$(IASLEDTYP-1)+")")
          If C_DIE <> ""
            [M:LOF2]CCE(find(C_DIE,[M:LOF2]DIE)-1) = [F:FAS]CCE(find(C_DIE,[F:FAS]DIE)-1)
          Endif
        Next
      Endif
      # Fin FQ70360
    Endif
  Endif

  # Si la dépense est un avoir on vérifie que les montants sont négatifs
  If [M:LOF1]TYPVCR = GVML_TDAVOIR
    If [M:LOF1]AMTNOTCUR  > 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATCUR  > 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATRCUR > 0 : OK = 0  : Endif
    If [M:LOF1]AMTNOTCPY  > 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATCPY  > 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATRCPY > 0 : OK = 0  : Endif
    If OK = 0 : GMESSAGE = mess(9,GML_MSGMIS,1) : Endif
  Endif
  If [M:LOF1]TYPVCR = GVML_TDACOMP or [M:LOF1]TYPVCR = GVML_TDARECE or [M:LOF1]TYPVCR = GVML_TDREPRI
    If [M:LOF1]AMTNOTCUR  < 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATCUR  < 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATRCUR < 0 : OK = 0  : Endif
    If [M:LOF1]AMTNOTCPY  < 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATCPY  < 0 : OK = 0  : Endif
    If [M:LOF1]AMTVATRCPY < 0 : OK = 0  : Endif
    If OK = 0 : GMESSAGE = mess(8,GML_MSGMIS,1) : Endif
  Endif
Return

$IMP_INICRE
  [F:LOF]CODLOFORI = [F:WLOF]CODLOFORI
  [F:LOF]LINLOFORI = [F:WLOF]LINLOFORI
Return

$IMP_ZONE
  Case IMPZON
    When "DES"
      # On récupère la société déduite du site dans ACTION_FCY de GLOFCYCPY en AP_FCY et on l'affecte à la classe [F]
      [F:LOF]CPY  = [M:LOF0]CPY
      [F:WLOF]CPY = [M:LOF0]CPY
      If [F:LOF]DES = ""
        [F:LOF]DES = [F:LOF]CODLOF
      Endif
    When "GAC"
      # On ne passe pas par le traitement standard qui va chercher la nature à partir du compte
      If CREGAC = G_OUI
        Call CRE_ACC([M:FPC]COA([M:FPC]GENLEDTYP-1),[F:LOF]GAC,GIMP(26),[F:LOF]GACACN) From GLOFUNCIMP
      Endif
      Return
    When "IASACC"
      # On ne passe pas par le traitement standard qui va chercher la nature à partir du compte
      If CREGAC = G_OUI
        Call CRE_ACC([M:FPC]COA([M:FPC]IASLEDTYP-1),[F:LOF]IASACC,GIMP(29),[F:LOF]IASACN) From GLOFUNCIMP
      Endif
      Return
    When "PLNINV"
      # On ne passe pas par le traitement standard car le plan est passé sous la forme CPY|PLAN
      Local Char L_PLNINV(20)
      Local Char L_CPY(GLONCPY)

      If instr(1,GIMP(11),"|")
        L_CPY    = left$(GIMP(11),instr(1,GIMP(11),"|")-1)
        L_PLNINV = right$(GIMP(11),instr(1,GIMP(11),"|")+1)
      Else
        L_PLNINV = GIMP(11)
      Endif
      Call TRT_TABDIV(614,L_PLNINV,GIMP(12),L_CPY,"",0,0) From GLOFUNCIMP
      [M:LOF2]PLNINV=L_PLNINV
      Return
    When "RATCUR"
      If [F:LOF]RATCUR = 0
        If[F:LOF]AMTNOTCUR <> 0
          [F:LOF]RATCUR = [F:LOF]AMTNOTCPY / [F:LOF]AMTNOTCUR
        Else
          [F:LOF]RATCUR = 1
        Endif
      Endif
    When "CCE"
      Local Integer N_I
      For N_I = 1 To 4
        If [M:LOF2]DIE(nolign-1) = AEAXE(N_I)
          [M:LOF2]CCE(nolign-1) = [F:LOF]CCE(N_I-1)
          If !clalev([M:RAE]) or (clalev([M:RAE]) and [M:RAE]FLGCCE=G_OUI)
            Call CRE_CCE([M:LOF2]DIE(nolign-1),[M:LOF2]CCE(nolign-1),GIMP(3+nolign-1)) From GLOFUNCIMP
          Endif
          Break
        Endif
      Next
      OK = 0
  Endcase

  Gosub IMP_ZONE From IMPLOF

  Case IMPZON
    When "TYPVCR"
      [F:LOF]TYPVCR = func GLOFUNCIMP.CONV_TYPVCR_AE([F:LOF]TYPVCR)
    When "GACACN"
      [F:LOF]GACACN = func GLOFUNCIMP.CONV_ACN_AE([F:LOF]GACACN)
    When "IASACN"
      [F:LOF]IASACN = func GLOFUNCIMP.CONV_ACN_AE([F:LOF]IASACN)
    When "ACGGRP"
      If CREACGGRP = G_OUI
        Call CRT_FAM([F:LOF]ACGGRP, GIMP(7)) From SUBFAM
#        Call TRT_TABDIV(611,[F:LOF]ACGGRP,GIMP(7),"","",0,0) From GLOFUNCIMP
      Endif
    When "CONNUM"
      Call TRT_TABDIV(620,[F:LOF]CONNUM,[F:LOF]CONNUM,"","",0,0) From GLOFUNCIMP
    When "ACT"
      If CRESAC = G_OUI
        Call CRE_SAC([F:LOF]CPY,[F:LOF]ACT,GIMP(32),val(GIMP(33)),val(GIMP(34)),val(GIMP(35)),val(GIMP(36))) From GLOFUNCIMP
      Endif
    When "USRFLDA1","USRFLDA2","USRFLDA3","USRFLDA4","USRFLDA5","USRFLDA6"
      Local Char NZ
      NZ = right$(IMPZON,8)
      Call TRT_TABDIV(evalue("GABLIADI"+NZ),evalue("[F:LOF]USRFLDA"+NZ),GIMP(15+val(NZ)),"","",0,0) From GLOFUNCIMP
  Endcase
Return

$IMP_TAB
  Case IMPTAB
  Endcase
Return

####################################################################
# Lecture de paramètres propres à l'import AE
#
$LEC_PARAM_AE
  Local Shortint N_PARAM
  Local Char     LPARM

  Call ECR_TRACE("----------------------------------------------------------------",0) From GESECRAN
  Call ECR_TRACE(mess(49,126,1)-[F:LOF]CPY,0) From GESECRAN

  For N_PARAM = 1 To 4
    Call PARAM([F:LOF]CPY,"AEAXE"+num$(N_PARAM),LPARM) From ADOVAL
    AEAXE(N_PARAM) = LPARM
    Call ECR_TRACE("  "+mess(82,GML_MSGPHY,1)-"AEAXE"+num$(N_PARAM)-":"-AEAXE(N_PARAM),0) From GESECRAN
  Next
  Call ECR_TRACE("----------------------------------------------------------------",0) From GESECRAN
Return
