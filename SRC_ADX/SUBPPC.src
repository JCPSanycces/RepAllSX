#########################################################################
##################### SUBPROG dans PPC3 #################################
#########################################################################
Subprog AS_NBREM
[M:PPC3]NBREM=GNBREM
For nolign=1 To [M:PPC3]NBREM
  [M:PPC3]COLDES(nolign-1)=GLIBDES(nolign-1)
  If [F:PRS]CLCRUL(nolign-1)=3 & [M:PPC0]PLITYP<> 2 : [M:PPC3]DISCRGPRO(nolign-1) = 2 : Endif
  If [M:PPC3]DISCRGPRO(nolign-1)=0 : [M:PPC3]DISCRGPRO(nolign-1)=1 : Endif
Next nolign
End

############################################################
Subprog AS_DISCRGPRO(VALEUR)
Variable Integer VALEUR
If [F:PRS]CLCRUL(nolign-1)=3 & [M:PPC0]PLITYP<>2 : VALEUR = 2 : mkstat = 3 : Endif
End

########################################
Subprog C_PLISTC(VALEUR)
Variable Char    VALEUR()
Local  Integer I
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif
Raz GLIBDES
Read [PRS] PRS0=2;VALEUR
If fstat  mkstat=1 : End : Endif
For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)=0 : Break : Endif
  Call LECTEXTRA(GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")",
&                "2",[F:PRS]PLISTC) From ATEXTRA
Next I
If I > dim([M:PPC3]DISCRGPRO)
     GNBREM = max(dim([M:PPC3]DISCRGPRO),0)
Else GNBREM=I
Endif
End

########################################
Subprog AM_PLISTC(VALEUR)
Variable Char    VALEUR()
#-----
Local Integer I
#-----
If dim([M:PPC3]NBREM)>0
  [M:PPC3]NBREM=GNBREM
  For I=0 To [M:PPC3]NBREM-1  [M:PPC3]DISCRGPRO(I)=2 : Next I
Endif
#-----
If !GIMPORT & dim([M:PPC3]NBREM)>0
  Actzo [PPC3]1-99 : Affzo [PPC3]1-99
Endif
End


#########################################################################
# COPIE : S/P de copie du paramétrage vers un autre dossier             #
# --------------------------------------------------------------------- #
# Subprog COPIE (TARIF)                                                 #
#    TARIF  : code tarif                                                #
# --------------------------------------------------------------------- #
# Remplacé par l'action ACOPIE                                          #
#########################################################################

$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie paramétrage tarif                  #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File PPRICCONF [PPC1]
  Local File ATEXTRA   [AXX1]
Else
  Local File =[M]DOSORG+".PPRICCONF" [PPC1]
  Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
  Local File PPRICCONF [PPC2]
  Local File ATEXTRA   [AXX2]
Else
  Local File =[M]DOSDES+".PPRICCONF" [PPC2]
  Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif
OK=1
Look [PPC2] PPC0=TABLE
If !fstat
   OK= 2 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK<>2  OK=0 : Endif
Endif
If OK
  Gosub OUVDOS From ATEXTRA
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
Endif
# Issue X3-46673 - 2017-09-14 by SR : Fermer les classes [AXX1] et [AXX2]
Close Local File [PPC1], [PPC2], [AXX1], [AXX2]
Return

#-------------------------------------------#
# Transaction de copie du paramétrage tarif #
#-------------------------------------------#
$TRT_COPIE
GOK=1
Trbegin [PPC2]
  Delete [PPC2] Where PLI=TABLE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".PPRICCONF"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("PPC2",TABLE) From GLOCK     : Goto AB_COPIE
  Endif
  Read [PPC1] PPC0=TABLE
  If !fstat
    [F:PPC2]=[F:PPC1]

    Call COPTEXTRA("PPRICCONF","DESAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif

    Write [PPC2]
    If fstat GOK=0 : Call FSTA("PPC2") From GLOCK : Goto AB_COPIE : Endif
  Endif
Commit
Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback : Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif : Return


##################################################################
# Pour exécution de la validation des tarifs en gestion de patch #
##################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call GENDOS(APPLI) From FUNPPCVAL
End


##########################################################################
# Pour éxécution de la validation des transactions en gestion de dossier #
#                par l'utilitaire de revalidation DOSWWW                 #
#                à partir du dictionnaire des types de transaction (ATN) #
##########################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer TOK
Local File =APPLI+".AWINDOW" [AWI] : # Déjà ouvert en local, le réouvrir !
If clalev ([F:AMK])<=0 : Local File =APPLI+".AMSK" [AMK] : Endif
Raz TOK
If dim(GVALTRANS)>5 & GVALTRANS(6)=2
  TOK=1
Else
  Read [AWI] AWI0="A1" : If fstat Raz [F:AWI] : Endif
  If [F:AWI]UPDFLG=1
    TOK=1
  Else
    Read [AWI] AWI0="A2" : If fstat Raz [F:AWI] : Endif
    If [F:AWI]UPDFLG=1
      TOK=1
    Else
      Read [AMK] CODMSK="PPLV" : If fstat Raz [F:AMK] : Endif
      If [F:AMK]UPDFLG=1
        TOK=1
      Else
        Read [AMK] CODMSK="PPLW" : If fstat Raz[F:AMK] : Endif
        If [F:AMK]UPDFLG=1
          TOK=1
        Endif
      Endif
    Endif
  Endif
Endif
Close Local File [AWI]
If TOK=1  Call GENDOS(APPLI) From FUNPPCVAL : Endif
End

########################################
Subprog AS_FIL(VALEUR)
Variable Char    VALEUR()
Local  Integer NOL
# --- préparation du tableau des tables accessibles
Raz JGFICFIC
Raz JGNBFIC
JGFICFIC(NOL)="ITMMASTER"    : NOL +=1 : # Articles
JGFICFIC(NOL)="ITMBPS"       : NOL +=1 : # Articles - fournisseur
JGFICFIC(NOL)="ITMSALES"     : NOL +=1 : # Articles - ventes
JGFICFIC(NOL)="ITMFACILIT"   : NOL +=1 : # Articles - sites
JGFICFIC(NOL)="BPARTNER"     : NOL +=1 : # Business Partner
JGFICFIC(NOL)="BPSUPPLIER"   : NOL +=1 : # Fournisseurs
JGFICFIC(NOL)="BPSUPPMVT"    : NOL +=1 : # Mouvements fourn   (site financier)
JGFICFIC(NOL)="PPRICLINK"    : NOL +=1 : # Rech tarif (Link)
If [M]PLIBPRCNR=2
  JGFICFIC(NOL)="BPCUSTOMER" : NOL +=1 : # Clients
  JGFICFIC(NOL)="BPCUSTMVT"  : NOL +=1 : # Mouvements clients (site financier)
  JGFICFIC(NOL)="BPDLVCUST"  : NOL +=1 : # Clients livrés
Endif
JGNBFIC=NOL
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran PPC0) 13/12/2005 10:48:15 (JL)
######################################################################################
Subprog AS_PLIBPRCNR(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

Subprog C_PLIBPRCNR(VALEUR)
Variable Integer VALEUR
Local Integer DANSVENTES  # dans les ventes : 0=absent /1=present /2=present inter-societes
If clalev ([F:SPC])<=0 : Local File SPRICCONF [SPC] : Endif
#            Controle avec le paramétrage des tarifs ventes
Read [SPC] SPC0=[M:PPC0]PLI
If !fstat : DANSVENTES=[F:SPC]PLIBPRCNR : Endif

If VALEUR=1
   If find(DANSVENTES,2,3)
#            Présence d'un tarif ventes de même code mais avec regle applications diiferentes
      GMESSAGE=mess(907,196,1) : GERR=3
   Endif
Endif

If VALEUR=2
   If !find(DANSVENTES,2,3)
#            Absence d un tarif correspondant
      GMESSAGE=mess(906,196,1) : GERR=3
   Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran PPC1) 15/12/2005 09:04:51 (JL)
######################################################################################
Subprog AS_LIEN(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=max(0,nolign-1)
If !find([M]FLDTYP(NOL),"ITM","ITS","BPR","BPS","BPC","BPD","ADI") : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]FLDTYP(NOL),"") From CONTOBJ
If [F:ATY]OBJLIEN="" : mkstat=1 : End : Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]NOMFIC="" : mkstat=1 : End : Endif
Call LECTURE ("ATB",[F:AOB]NOMFIC,"") From CONTOBJ
If [F:ATB]INTIT="" & [F:ATB]INTITC="" : mkstat=1 : End : Endif
If [F:ATB]INTIT="" : GMENLOC(2)=1 : Endif
If [F:ATB]INTITC="" : GMENLOC(3)=1 : Endif
End

