#<AdxTL>@(#)5.0.0.0 $Revision$
########################################################################
# SUBPPC : Gestion du paramétrage tarifs ACHATS   Créé    JLS et SR    #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:PPC]PPRICCONF                                #
########################################################################
Call OBJET("PPC",GBIDC1,GBIDC2) From GOBJET
End

#########################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "LIENS"        : Gosub LIENS
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INICRE
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "CREATION"     : Gosub GEN_ECR : Default File [PPC]
 When "AVANT_MOD"    : Gosub AVANT_MOD
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "VERF_ANU"     : Gosub AVANT_MOD
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "RAZCRE"       : Gosub RAZCRE
 When "FERME"        : Gosub FERME
 When "CHANGE"       : Call CHANGE_AXX ("PPRICCONF", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When  Default
Endcase
Return

#########################################################################
############################# ACTIONS ###################################
#########################################################################
$OUVRE
Local  Integer I_MOD
Local  Integer DESTARIFS

Local Char APPLI : APPLI = nomap

Global Char    JGFICFIC (30) (0..10)
Global Integer JGNBFIC

GNBREM=0

Local  Integer ACVOPEN, NBRCOLONNE

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : ACVOPEN=1 : Endif
Read [ACV]CODACT="PPR"
NBRCOLONNE=[F:ACV]DIME
If fstat : NBRCOLONNE=0 : Endif
If ACVOPEN=1 : Close Local File [ACV] : Endif

Raz GLIBDES

Raz JGFICFIC
Raz JGNBFIC
Local  Integer NOL
# --- préparation du tableau des tables accessibles
JGFICFIC(NOL)="ITMMASTER"  : NOL +=1 : # Articles
JGFICFIC(NOL)="ITMBPS"     : NOL +=1 : # Articles - fournisseur
JGFICFIC(NOL)="BPARTNER"   : NOL +=1 : # Business Partner
JGFICFIC(NOL)="BPSUPPLIER" : NOL +=1 : # Fournisseurs
JGFICFIC(NOL)="BPSUPPMVT"  : NOL +=1 : # Mouvements fourn   (site financier)
JGFICFIC(NOL)="PPRICLINK"  : NOL +=1 : # Rech tarif (Link)
JGNBFIC=NOL
Return


#------------------------------------------------------------------------
# Désactivation des boutons "Validation" et "Copie"
#------------------------------------------------------------------------
$SETBOUT

#--- si acces par tunnel : Cré / Mod / Sup / Dupli interdits
If GFONC1<>"GESPPC" : Call VIREBOUT(CHAINE,"CMAD") From GOBJET : Endif

#--- pas de changement de cle
Call VIREBOUT(CHAINE,"H") From GOBJET

#----- Boutons "Validation" et "Copie" -----#
If GREP<>"" | !CLECUR | GHISTO
  Call VIREBOUT(CHAINE,"12") From GOBJET
Endif

Return


#------------------------------------
# Après appui sur bouton "Validation"
#------------------------------------
$EXEBOUT
Case REP
  When "1" : Gosub DEL_ECR
             Default File [PPC]
             Gosub GEN_ECR
             Default File [PPC]
  When Default
Endcase
Return


#------------------------------------------------------------------------
# Activation / Desactivation zones (Grizo/Actzo)
#------------------------------------------------------------------------
$APRES_MODIF
Case COUZON
 When "PLITYP"       : Gosub G_PLITYP
 When "PRIPRO"       : Gosub G_PRIPRO
 When "FOCPRO"       : Gosub G_FOCPRO
 When Default
Endcase
Return

$G_PLITYP

# si Tarif Normal
If val(CZ) = 1
  Actzo [M:PPC0]PLISEA
  If [M]PRIPRO<1    : [M]PRIPRO=2    : Raz PRIFLD   : Endif
  If [M]PRITYP<1    : [M]PRITYP=1    : Endif
  If [M]PRIQTYFLG<1 : [M]PRIQTYFLG=2 : Endif
  If [M]ATICNVFLG<1 : [M]ATICNVFLG=1 : Endif
  If [M]UOMCNVFLG<1 : [M]UOMCNVFLG=1 : Endif
  If [M]CURCNVFLG<1 : [M]CURCNVFLG=1 : Endif
  If [M]FOCPRO<1    : [M]FOCPRO=1    : Raz FOCTYP   : Endif
  If [M]COMPRO<1    : [M]COMPRO=2    : Endif
  For I=0 To GNBREM-1
    If [M]DISCRGPRO(I)=0 : [M]DISCRGPRO(I)=2 : Endif
  Next I
  Raz [M:PPC2]UPDNULPRI
  If !GIMPORT
    Actzo [M:PPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, UOMCNVFLG, CURCNVFLG,
&         FOCPRO, COMPRO
    If dim([M]NBREM)>0 : Actzo [M:PPC3]DISCRGPRO : Endif
    If [M]PRITYP<4  Grizo [M:PPC2]PRIFLD
      Else          Actzo [M:PPC2]PRIFLD
    Endif
    If [M]FOCPRO=1  Grizo [M:PPC2]FOCTYP
      Else          Actzo [M:PPC2]FOCTYP
    Endif
    Grizo [M:PPC2]UPDNULPRI
  Endif

Endif

# si Tarif Groupé
If val(CZ) = 2
  Raz [M:PPC0]PLISEA
  Grizo [M:PPC0]PLISEA
  If [M]PRIPRO<1    : [M]PRIPRO=2    : Raz PRIFLD   : Endif
  If [M]PRITYP<1    : [M]PRITYP=1    : Endif
  If [M]PRIQTYFLG<1 : [M]PRIQTYFLG=2 : Endif
  If [M]ATICNVFLG<1 : [M]ATICNVFLG=1 : Endif
  If [M]UOMCNVFLG<1 : [M]UOMCNVFLG=1 : Endif
  If [M]CURCNVFLG<1 : [M]CURCNVFLG=1 : Endif
  If [M]FOCPRO<1    : [M]FOCPRO=1    : Raz FOCTYP   : Endif
  Raz COMPRO
  For I=0 To GNBREM-1
    If [M]DISCRGPRO(I)=0 : [M]DISCRGPRO(I)=2 : Endif
  Next I
  If !GIMPORT
    Actzo [M:PPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, UOMCNVFLG, CURCNVFLG, FOCPRO
    If dim([M]NBREM)>0 : Actzo [M:PPC3]DISCRGPRO : Endif
    If [M]PRITYP<4  Grizo [M:PPC2]PRIFLD
      Else          Actzo [M:PPC2]PRIFLD
    Endif

    If [M]FOCPRO=1  Grizo [M:PPC2]FOCTYP
      Else          Actzo [M:PPC2]FOCTYP
                    Grizo [M:PPC2]COMPRO
    Endif
  Actzo [M:PPC2]UPDNULPRI
  Endif
Endif

# si Tarif Interdit
If val(CZ) = 3
  Raz [M:PPC0]PLISEA
  Grizo [M:PPC0]PLISEA
  Raz [M]PRIPRO, [M]PRIFLD, [M]PRITYP, [M]PRIQTYFLG, [M]CUR, [M]ATICNVFLG, [M]UOMCNVFLG,
&     [M]CURCNVFLG, [M]FOCPRO, [M]FOCTYP, [M]COMPRO, [M]UPDNULPRI
  If dim([M]NBREM)>0 : Raz [M]DISCRGPRO : Endif
  If !GIMPORT
    Grizo [M:PPC2]PRIPRO, PRIFLD, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG,
&         FOCPRO, FOCTYP, COMPRO, UPDNULPRI
    If dim([M]NBREM)>0 : Grizo [M:PPC3] : Endif
  Endif
Endif

# si Tarif Composant
If val(CZ) = 4
  Actzo [M:PPC0]PLISEA
  If [M]PRIPRO<1    : [M]PRIPRO=2    : Raz PRIFLD   : Endif
  If [M]PRITYP<1    : [M]PRITYP=1    : Endif
  If [M]PRIQTYFLG<1 : [M]PRIQTYFLG=2 : Endif
  If [M]ATICNVFLG<1 : [M]ATICNVFLG=1 : Endif
  If [M]UOMCNVFLG<1 : [M]UOMCNVFLG=1 : Endif
  If [M]CURCNVFLG<1 : [M]CURCNVFLG=1 : Endif
  Raz [M]FOCPRO, [M]FOCTYP
  If [M]COMPRO<1    : [M]COMPRO=2    : Endif
  For I=0 To GNBREM-1
    If [M]DISCRGPRO(I)=0 : [M]DISCRGPRO(I)=2 : Endif
  Next I
  Raz [M:PPC2]UPDNULPRI
  If !GIMPORT
    Actzo [M:PPC2]PRIPRO, PRITYP, PRIQTYFLG, CUR, UOMCNVFLG, CURCNVFLG,
&         COMPRO
    If dim([M]NBREM)>0 : Actzo [M:PPC3]DISCRGPRO : Endif
    Grizo [M:PPC2]FOCPRO, FOCTYP
    If [M]PRITYP<4  Grizo [M:PPC2]PRIFLD
      Else          Actzo [M:PPC2]PRIFLD
    Endif
    Grizo [M:PPC2]UPDNULPRI
  Endif
Endif
If !GIMPORT
  Affzo [PPC2]PRIPRO, PRIFLD, PRITYP, PRIQTYFLG, CUR, ATICNVFLG, UOMCNVFLG, CURCNVFLG,
&       FOCPRO, FOCTYP, COMPRO, UPDNULPRI
  If dim([M]NBREM)>0 : Affzo [PPC3]DISCRGPRO : Endif
Endif
Return

$G_PRIPRO
If !GIMPORT
  Actzo [M:PPC2]PRITYP, PRIFLD, CUR, ATICNVFLG
  If [M:PPC0]PLITYP=2  Actzo [PPC2]UPDNULPRI : Endif
Endif
If val(CZ) = 0
  Raz   [M]PRITYP, [M]PRIFLD, [M]CUR, [M]ATICNVFLG, [M]UPDNULPRI
  If !GIMPORT : Grizo [M:PPC2]PRITYP, PRIFLD, CUR, ATICNVFLG, UPDNULPRI : Endif
Else
  If [M]PRITYP=0 : [M]PRITYP=1 : Endif
  If [M]ATICNVFLG=0 : [M]ATICNVFLG=1 : Endif
Endif
If val(CZ) = 1 or val(CZ) = 2 or val(CZ) = 3
  Raz PRIFLD
  If !GIMPORT : Grizo [M:PPC2]PRIFLD : Endif
Endif
If val(CZ) = 1
   Raz [M:PPC2]UPDNULPRI
   Grizo [M:PPC2]UPDNULPRI
Endif
If !GIMPORT : Affzo [PPC2]PRITYP, PRIFLD, CUR, ATICNVFLG, UPDNULPRI : Endif
Return

$G_FOCPRO
If !GIMPORT : Actzo [M:PPC2]FOCTYP : Endif
If val(CZ) < 2
    Raz [M]FOCTYP
    If !GIMPORT : Grizo [M:PPC2]FOCTYP : Endif
  Else
    If [M]FOCTYP=0 : [M]FOCTYP=1 : Endif
    If !GIMPORT : Actzo [M:PPC2]FOCTYP : Endif
Endif
If !GIMPORT : Affzo [PPC2]FOCTYP : Endif
Return

#------------------------------------------------------------------------
# Chargement des libellés Remises/Frais
#------------------------------------------------------------------------
$LIENS
Local  Integer I
If !clalev ([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
Raz GLIBDES
Read [PRS] PRS0=2;[M:PPC0]PLISTC
If fstat : Return : Endif

If [M:PPC0]PLITYP=2 | [M:PPC0]PLITYP=3
  Grizo [PPC0]PLISEA
Else
  Actzo [PPC0]PLISEA
Endif

If [M:PPC0]PLITYP=2 & [M:PPC2]PRIPRO>1
  Actzo [PPC2]UPDNULPRI
Else
  Grizo [PPC2]UPDNULPRI
Endif

For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)=0 : Break : Endif
  Call LECTEXTRA(GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")",
&                "2",[F:PRS]PLISTC) From ATEXTRA
Next I
GNBREM=max(I,0)
If dim([M:PPC3]NBREM)>0
  If I>dim([M:PPC3]DISCRGPRO)  GNBREM=max(dim([M:PPC3]DISCRGPRO),0) : Endif
Else
  I=0 : GNBREM=0
Endif
If dim([M:PPC3]NBREM)>0  [M:PPC3]NBREM=GNBREM : Endif
For RG=1 To GNBREM
  [M:PPC3]COLDES(RG-1) = GLIBDES(RG-1)
Next RG
For nolign=1 To 5
  If [M:PPC1]FIL(nolign-1) = "" : Break : Endif
  [M:PPC1]BASTAB += 1
  Call CHARFIC(1,"INTFIC","ABB","PPC1",[M:PPC1]FIL(nolign-1)) From TRTPARAM
  Call CHARCRIDES([M:PPC1]FIL(nolign-1),[M:PPC1]FLD(nolign-1),[M:PPC1]CRIDES(nolign-1)) From TRTPARAM
Next nolign
If !GIMPORT
  If dim([M:PPC3]NBREM)>0 : Affzo [PPC3]1-99 : Endif
Endif
If [M:PPC2]PRIPRO<4  Grizo [PPC2]PRIFLD  Else  Actzo [PPC2]PRIFLD : Endif
Grizo [PPC2]ATICNVFLG
Return

#------------------------------------------------------------------------
# Chargement de BASTAB (nbre critères) et NBREM (nbre colonnes frais/rem)
#------------------------------------------------------------------------
$RAZCRE
# Valeur par défaut
[M:PPC0]PIO = 50
[M:PPC2]PRITYP = 2
For RG = 1 To 5
    If [M]FIL(RG-1) = "" : Break : Endif
    [M]BASTAB += 1
Next RG

[M]PRIPRO=2 : [M]PRITYP = 1 : [M]PRIQTYFLG=2 : [M]ATICNVFLG=2
[M]UOMCNVFLG=1 : [M]CURCNVFLG=1 : [M]FOCPRO=1 : [M]FOCTYP=0 : [M]COMPRO=2
If !GIMPORT
  Affzo [PPC2]1-99
Endif
If !GIMPORT Grizo [M:PPC2]ATICNVFLG : Endif
#----- Chargement intitulés lignes tableau frais/remises pour structure par défaut -----#
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
If dim([M:PPC3]NBREM)>0  Raz [M:PPC3]NBREM     : Endif
If dim([M:PPC3]NBREM)>0  Raz [M:PPC3]DISCRGPRO : Endif
Raz GLIBDES
Read [PRS] PRS0=2;"" : If fstat  Raz [F:PRS] : Endif
For RG=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(RG)=0 : Break : Endif
  Call LECTEXTRA(GLIBDES(RG),"PRICSTRUCT","DESAXX("+num$(RG)+")","2",[F:PRS]PLISTC) From ATEXTRA
Next RG
If RG>dim([M:PPC3]DISCRGPRO)
  GNBREM=max(dim([M:PPC3]DISCRGPRO),0)
Else
  GNBREM=RG
Endif
#-----
If dim([M:PPC3]NBREM)>0
  [M:PPC3]NBREM=GNBREM
  For RG=0 To [M:PPC3]NBREM-1  [M:PPC3]DISCRGPRO(RG)=2 : Next RG
Endif
#-----
If !GIMPORT & dim([M:PPC3]NBREM)>0
  Actzo [PPC3]1-99 : Affzo [PPC3]1-99
Endif
Return


#------------------------------------------------------------------------
# Chargement des champs annexes
#------------------------------------------------------------------------
$INICRE
Local Char CRIITM_A (5), CRIBPR_A(5)
Raz [F:PPC]CRIITM,[F:PPC]CRIBPR

#   les champs de la table ITMBPS sont des critères articles et fournisseurs
#   recherche des champs des tables ITMSALES, ITMBPC, BPCUSTOMER pour intersociété
For I=0 To dim([F:PPC]FIL)-1
    If find([F:PPC]FIL(I),"ITMMASTER","ITMBPS","ITMSALES","ITMBPC")
       CRIITM_A += num$(I+1)
    Endif
    If find([F:PPC]FIL(I),"BPARTNER","BPSUPPLIER","ITMBPS","BPCUSTOMER","ITMBPC")
       CRIBPR_A += num$(I+1)
    Endif
Next I
[F:PPC]CRIITM=val(CRIITM_A) : [F:PPC]CRIBPR=val(CRIBPR_A)

GNBREM=max(GNBREM,0)
For I=GNBREM To 8
  Assign "[F:PPC]DISCRGPRO("+num$(I)+")" With 0
Next I
If [F:PPC]PRITYP=0 [F:PPC]PRITYP=1 : Endif

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:PPC0]DESAXX,"PPRICCONF","DESAXX",[M:PPC0]PLI,"") From ATEXTRA

#    SOS libellés
If dim([F:PPC]LANDESSHO)>0
   [F:PPC]LANDESSHO=GLANGUE+"~"+[M:PPC0]DESAXX
Endif


Return

#------------------------------------------------------------------------
# Controle avant modif : si tarifs déjà créés avec ce paramétrage
#------------------------------------------------------------------------
$AVANT_MOD
DESTARIFS=1
OK=1
Filter [PPL] Where PLI=[M:PPC0]PLI
Read [PPL] PPL0 First
If fstat : Return :Endif
DESTARIFS=2
Call OUINON(mess(55,199,1),OK) From GESECRAN
# ce tarif contient des lignes.oulez-vous continuer?
If OK<>2 : OK=0 : Endif
Return

#------------------------------------------------------------------------
# Pour mise a jour des zones initialisées pour un autre masque
#------------------------------------------------------------------------
$AVANT_MODFIC
[F:PPC]=[M:PPC2]
Return

#------------------------------------------------------------------------
# Suppression des Tarifs associés et création de l'écran
#------------------------------------------------------------------------
$MODIF
Gosub DEL_ECR
Gosub GEN_ECR
Default File [PPC]
Return

#------------------------------------------------------------------------
# Suppression du parametrage
#------------------------------------------------------------------------
$ANNULE
I_MOD=4
Gosub DEL_ECR
Delete [AXX]Where CODFIC="PPRICCONF" & IDENT1=[F:PPC]PLI
Return

#------------------------------------------------------------------------
# Vérification au moins un critère
#------------------------------------------------------------------------
$VERIF_CRE
If [M]ABB(0)= ""
  GERR = 1 : GMESSAGE =mess(183,199,1)
# aucun critère dans ce paramétrage
  OK = 0
Endif
Return

#------------------------------------------------------------------------
# Vérification qu'une modification a bien été effectuée
#------------------------------------------------------------------------
$VERIF_MOD
If [M]ABB(0)= ""
  GERR = 1 : GMESSAGE =mess(183,199,1)
# aucun critère dans ce paramétrage
  OK = 0
  Return
Endif

I_MOD=0
If [M]PLISTC<>[F:PPC]PLISTC : I_MOD=1 : Return : Endif
If [M]PLITYP<>[F:PPC]PLITYP : I_MOD=1 : Return : Endif
For I=0 To 4
  If [M]ABB(I)<>[F:PPC]ABB(I)        : I_MOD=1 : Break : Endif
  If [M]FLD(I)<>[F:PPC]FLD(I)        : I_MOD=1 : Break : Endif
  If [M]CRIDIE(I)<>[F:PPC]CRIDIE(I)  : I_MOD=1 : Break : Endif
  If [M]CRIIND(I)<>[F:PPC]CRIIND(I)  : I_MOD=1 : Break : Endif
  If [M]CRIDES(I)<>[F:PPC]CRIDES(I)  : I_MOD=1 : Break : Endif
  If [M]FIL(I)<>[F:PPC]FIL(I)        : I_MOD=1 : Break : Endif
  If [M]PPUMNU(I)<>[F:PPC]PPUMNU(I)  : I_MOD=1 : Break : Endif
Next I
If I_MOD <> 0 : Return : Endif
  If [M]PRIPRO<>[F:PPC]PRIPRO : I_MOD=2 : Return : Endif
  If [M]PRIFLD<>[F:PPC]PRIFLD : I_MOD=2 : Return : Endif
  If [M]PRITYP<>[F:PPC]PRITYP : I_MOD=2 : Return : Endif
  If [M]PRIQTYFLG<>[F:PPC]PRIQTYFLG : I_MOD=2 : Return : Endif
  If [M]CUR<>[F:PPC]CUR : I_MOD=2 : Return : Endif
  If [M]ATICNVFLG<>[F:PPC]ATICNVFLG : I_MOD=2 : Return : Endif
  If [M]UOMCNVFLG<>[F:PPC]UOMCNVFLG : I_MOD=2 : Return : Endif
  #If [M]FOCPRO<>[F:PPC]FOCPRO : I_MOD=2 : Return : Endif
  #If [M]FOCTYP<>[F:PPC]FOCTYP : I_MOD=2 : Return : Endif
  #If [M]COMPRO<>[F:PPC]COMPRO : I_MOD=3 : Return : Endif
For I=0 To dim([M]DISCRGPRO)-1
  If [M]DISCRGPRO(I)<>[F:PPC]DISCRGPRO(I) : I_MOD=3 : Break : Endif
Next I
Return

#------------------------------------------------------------------------
# Suppression des globales internes
#------------------------------------------------------------------------
$FERME
If dim(JGFICFIC)>0 : Kill JGFICFIC : Endif
If dim(JGNBFIC)>0  : Kill JGNBFIC  : Endif
Return

#------------------------------------------------------------------------
# Suppression des écrans associés au paramétrage
#------------------------------------------------------------------------
$DEL_ECR
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO  (GLONAMK)
Local Integer TBLOC (15)
Local Char    TZONE (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer TMOD (200)
Local Char    TINT (35) (200)
Local Char    TTAB (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Char    TFLD (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer OPT1,OPT2,OPT3,RETOUR
Local Integer IBLO,IZON

# Sup. des enr. fiches et tarifs par liens suppression des tables
If I_MOD=1 & DESTARIFS=2 : # modif. critères
  OK = 2
#   Call OUINON("Modif type,critères : Supp des lignes?",OK) From GESECRAN
  Call OUINON(mess(160,199,1)+"\"+mess(161,199,1)+"\"+mess(162,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif
If I_MOD=2 & DESTARIFS=2 : # modif. attribution prix, conversion
  OK = 2
#   Call OUINON("Modif prix,conditions : Supp lignes?",OK) From GESECRAN
  Call OUINON(mess(165,199,1)+"\"+mess(167,199,1)+"\"+mess(168,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif
If I_MOD=3 & DESTARIFS=2 : # modif. remises/frais.
  OK = 1
#   Call OUINON("Modif frais-remises : Supp lignes?",OK) From GESECRAN
  Call OUINON(mess(169,+199,1)+"\"+mess(171,199,1)+"\"+
&             mess(163,199,1),OK) From GESECRAN
  If OK<>2 : I_MOD=0  : Endif
Endif

If I_MOD<>0
  Delete [F:PPF] Where PLI=[M:PPC0]PLI
  If fstat=1 : GOK=-1 : GLOCK="$PPRICFICH"-[M:PPC0]PLI : Return : Endif
  Delete [F:PPL] Where PLI=[M:PPC0]PLI
  If fstat=1 : GOK=-1 : GLOCK="$PPRICLIST"-[M:PPC0]PLI : Return : Endif
Endif

# Suppression écran
For I = 1 To 3
   Raz MFROM,MTO,TBLOC,TZONE,TMOD,OPT2,OPT3
   MTO="WA1"+num$([M:PPC0]PLI)+"1"
   OPT1=9
   Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
   If RETOUR<>0 : GOK=0 : Endif
Next I

# Suppression des traitements générés
Local Char    NOMTRT(GLONADC), FICTRT(GDIMFIC), EXT(4)
Local Integer STAT
NOMTRT="WAT"+num$([M:PPC0]PLI)
#----- Suppression du source (src) -----#
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FICTRT,0)>=0
  Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
#----- Suppression de l'exécutable (adx) -----#
Call EXISTE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
If STAT
  Call EFFACE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
Endif
#-----
#--EWI 93062 Price search in mobility
NOMTRT="WAT"+num$([M:PPC0]PLI)+"_SY"
# Suppression "src"
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)
If filinfo(FICTRT,0)>=0
    Call EFFACE(FICTRT,STAT) From ORDSYS
Endif
# Suppression "adx"
Call EXISTE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
If STAT = 1
     Call EFFACE_ADX("",APPLI,NOMTRT,STAT) From ORDSYS
Endif
#--/

# Suppression des fenetres
Gosub DEL_FEN
If GOK<>1 : Return : Endif
Return

#------------------------------------------------------------------------
# Génération des écrans associés au paramétrage
#------------------------------------------------------------------------
$GEN_ECR
If dim(APPLI)<0 Local Char    APPLI : Endif
If dim(OK)<0    Local Integer OK    : Endif
If APPLI="" APPLI=nomap : Endif
Local Char    MFROM(GLONAMK)
Local Char    MTO  (GLONAMK)
Local Integer TBLOC (15)
Local Char    TZONE (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer TMOD (200)
Local Char    TINT (35) (200)
Local Char    TTAB (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Char    TFLD (GLONAVA) (200) : #VPO 17/03/11 utiliser GLONAVA au lieu de 10
Local Integer OPT1,OPT2,OPT3,RETOUR
Local Integer IBLO,IZON
Local Integer ITZ
Local Integer ZZ (35)
Local Char    ZCHAMP (GLONAVA) (0..35)
# --- Garnissage des zones communes aux 3 écrans
MFROM="PPLW"
ZCHAMP(0)="CRIT"       :ZCHAMP(1)="LIBCRIT"    :ZCHAMP(2)="CRIT1"
ZCHAMP(3)="CRIT2"      :ZCHAMP(4)="CRIT3"      :ZCHAMP(5)="CRIT4"
ZCHAMP(6)="CRIT5"      :ZCHAMP(7)="CUR"        :ZCHAMP(8)="UOM"
ZCHAMP(9)="MINQTY"     :ZCHAMP(10)="MAXQTY"    :ZCHAMP(11)="LTI"
ZCHAMP(12)="PRIDIV"    :ZCHAMP(13)="PRI"       :ZCHAMP(14)="XFRAREM1"
ZCHAMP(15)="XFRAREM2"  :ZCHAMP(16)="XFRAREM3"  :ZCHAMP(17)="XFRAREM4"
ZCHAMP(18)="XFRAREM5"  :ZCHAMP(19)="XFRAREM6"  :ZCHAMP(20)="XFRAREM7"
ZCHAMP(21)="XFRAREM8"  :ZCHAMP(22)="XFRAREM9"  :ZCHAMP(23)="FOCQTYMIN"
#ZCHAMP(24)="FOCBKT"    :ZCHAMP(25)="FOCITMREF" :ZCHAMP(26)="FOCUOM"
ZCHAMP(25)="FOCITMREF" :ZCHAMP(26)="FOCUOM"
ZCHAMP(27)="FOCQTY"    :ZCHAMP(28)="COMCOE"    :ZCHAMP(29)="MINAMT"
ZCHAMP(30)="MAXAMT"
ZCHAMP(31)="FOCAMTMIN" :ZCHAMP(32)="FOCQTYBKT" :ZCHAMP(33)="FOCAMTBKT"
Raz TBLOC,TZONE,TTAB,TFLD,TMOD,TINT,ZZ

# ---------- Garnissage table décision de m.a.j. des rubriques
#            ( uniquement les rubriques hors critères )
# --- Tarif Normal ---
If [F:PPC]PLITYP=1
 If [F:PPC]PRIPRO=2 : ZZ(7)=1 : ZZ(8)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=3 : ZZ(7)=1 : ZZ(8)=1 : ZZ(12)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=4 : ZZ(8)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=5 : ZZ(8)=1 : Endif
 If [F:PPC]PRIQTYFLG=2 : ZZ(9)=1 : ZZ(10)=1 : ZZ(11) = 1 : Endif
 If [F:PPC]CURCNVFLG=2 : ZZ(7)=1 : Endif
 If [F:PPC]FOCPRO=2 : ZZ(26)=1 : ZZ(27)=1 : Endif
 If [F:PPC]FOCPRO=3 : ZZ(25)=1 : ZZ(26)=1 : ZZ(27)=1 : Endif
 If [F:PPC]FOCTYP=1 : ZZ(23)=1 : Endif
 If [F:PPC]FOCTYP=2 : ZZ(23)=1 : ZZ(32)=1 : Endif
 For I=0 To GNBREM-1
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : ZZ(14+I)=2 : Endif
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1
    ZZ(7)=1 : ZZ(14+I)=1
    If [F:PRS]CLCRUL(I)=1 :                  : # base de calcul = par unité
      ZZ(8)=1
    Endif
  Endif
 Next I
 If [F:PPC]COMPRO=1 : ZZ(28)=1 : Endif
Endif

# --- Tarif Groupé ---
If [F:PPC]PLITYP=2
 If [F:PPC]PRIPRO=2 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=3 : ZZ(12)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=4 : ZZ(13)=1 : Endif
 If [F:PPC]PRIQTYFLG=3 : ZZ(8)=1 : ZZ(9)=1 : ZZ(10)=1 : ZZ(11)=1 : Endif
 If [F:PPC]PRIQTYFLG=4 : ZZ(7)=1 : ZZ(29)=1 : ZZ(30) = 1 : Endif
 If [F:PPC]PRIQTYFLG=5 : ZZ(7)=1 : ZZ(29)=1 : ZZ(30) = 1 : Endif
 If [F:PPC]UOMCNVFLG=2 : ZZ(8)=1 : Endif
 If [F:PPC]CURCNVFLG=2 : ZZ(7)=1 : Endif
 If [F:PPC]FOCPRO=3 : ZZ(9)=1 : ZZ(10)=1 : ZZ(11)=1 : Endif
 If [F:PPC]FOCPRO=4 : ZZ(7)=1 : ZZ(25)=1 : ZZ(26)=1 : ZZ(27)=1 : Endif
 If [F:PPC]FOCTYP=1 : ZZ(23)=1 : Endif
 If [F:PPC]FOCTYP=2 : ZZ(23)=1 : ZZ(32)=1 : Endif
 For I=0 To GNBREM-1
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : ZZ(14+I)=2 : Endif
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1 : ZZ(14+I)=1 : Endif
 Next I
 If [F:PPC]COMPRO=1 : ZZ(28)=1 : Endif
Endif

# --- Tarif Interdit ---
If [F:PPC]PLITYP=3
Endif

# --- Tarif Composant ---
If [F:PPC]PLITYP=4
 If [F:PPC]PRIPRO=2 : ZZ(7)=1 : ZZ(8)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=3 : ZZ(7)=1 : ZZ(8)=1 : ZZ(12)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=4 : ZZ(8)=1 : ZZ(13)=1 : Endif
 If [F:PPC]PRIPRO=5 : ZZ(8)=1 : Endif
 If [F:PPC]PRIQTYFLG=2 : ZZ(9)=1 : ZZ(10)=1 : ZZ(11) = 1 : Endif
 If [F:PPC]CURCNVFLG=2 : ZZ(7)=1 : Endif
 For I=0 To GNBREM-1
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)<>1 : ZZ(14+I)=2 : Endif
  If [F:PPC]DISCRGPRO(I)=1 & [F:PRS]VALTYP(I)=1
    ZZ(7)=1 : ZZ(14+I)=1
    If [F:PRS]CLCRUL(I)=1 :                  : # base de calcul = par unité
      ZZ(8)=1
    Endif
  Endif
 Next I
 If [F:PPC]COMPRO=1 : ZZ(28)=1 : Endif
Endif

# --- Si Devise / Unité achat dans critères
#     pas de saisie dans autre colonne
If [F:PPC]CRICURNUM<>0 : ZZ(7)=0 : Endif
If [F:PPC]CRICURNUM<>0 | ZZ(7)<>0 SAISIEDEV=1 Else SAISIEDEV=0: Endif
If [F:PPC]CRIUOMNUM<>0 : ZZ(8)=0 : Endif

# ------ Création de l'écran de saisie et traitement --------------------
#
Gosub ECR_SAISIE
Gosub ECR_VISU
Gosub GEN_TRT From SUBPPCT
Gosub GEN_TRT From SUBPPCT_SYRA :#--EWI 93062 Price search in mobility
Return

#------------------------------------------------------------------------
#       Ecran de saisie des tarifs
#------------------------------------------------------------------------
$ECR_SAISIE
MFROM="PPLW" : MTO="WA1"+num$([F:PPC]PLI)+"1"
TZONE(0)=ZCHAMP(0) :TMOD(0)=3 : # zones supprimées
TZONE(1)=ZCHAMP(1) :TMOD(1)=3
ITZ=1
For I=0 To 4
  If [F:PPC]FLD(I)=""
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=3
  Else
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=5
             TTAB(ITZ)=[F:PPC]FIL(I) : TFLD(ITZ)=[F:PPC]FLD(I)
    Case [F:PPC]FLDTYP(I)
      When "CCE" : ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
                            TINT(ITZ)="func TRTX3FNC.GETCOLDIE('"+[F:PPC]CRIDIE(I)+"')"
      When "ADI"
           If find([F:PPC]FLDTYPCPL(I),"20","21","22","23","24")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-19)+",206,1)"
           Endif
           If find([F:PPC]FLDTYPCPL(I),"30","31","32","33","34")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-29)+",207,1)"
           Endif
           If find([F:PPC]FLDTYPCPL(I),"40","41","42","43","44")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-39)+",208,1)"
           Endif
      When Default
    Endcase
    If [F:PPC]FLDTYP(I)="ITM" | [F:PPC]FLDTYP(I)="BPS"
      ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=8
               TINT(ITZ)=[F:PPC]FLDTYP(I)
    Endif
  Endif
Next I
Gosub CHAMPS_COMMUNS
Gosub SUP_AMA     # Issue 71069 - 2016-01-29 by SR : PJT
Gosub CRE_AMP
Gosub UN_MASQUE
Gosub GEN_FEN
Gosub CRE_AMA     # Issue 71069 - 2016-01-29 by SR : PJT
Gosub SUP_AMP
Return

#------------------------------------------------------------------------
#       Ecran de visu des tarifs
#------------------------------------------------------------------------
$ECR_VISU
MFROM = "PPLV" : MTO = "WA2"+num$([F:PPC]PLI)+"1"
TZONE(0)=ZCHAMP(0) :TMOD(0)=3 : # zones supprimées
TZONE(1)=ZCHAMP(1) :TMOD(1)=3
ITZ=1
For I=0 To 4
  If [F:PPC]FLD(I)=""
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=3
  Else
    ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=5
             TTAB(ITZ)=[F:PPC]FIL(I) : TFLD(ITZ)=[F:PPC]FLD(I)
    Case [F:PPC]FLDTYP(I)
      When "CCE" : ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
                            TINT(ITZ)="func TRTX3FNC.GETCOLDIE('"+[F:PPC]CRIDIE(I)+"')"
      When "ADI"
           If find([F:PPC]FLDTYPCPL(I),"20","21","22","23","24")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-19)+",206,1)"
           Endif
           If find([F:PPC]FLDTYPCPL(I),"30","31","32","33","34")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-29)+",207,1)"
           Endif
           If find([F:PPC]FLDTYPCPL(I),"40","41","42","43","44")
              ITZ+=1 : TMOD(ITZ)=7 : TZONE(ITZ)=ZCHAMP(I+2)
              TINT(ITZ)="mess("+num$(val([F:PPC]FLDTYPCPL(I))-39)+",208,1)"
           Endif
      When Default
    Endcase

    If [F:PPC]FLDTYP(I)="ITM" | [F:PPC]FLDTYP(I)="BPS"
      ITZ+=1 : TZONE(ITZ)=ZCHAMP(I+2) : TMOD(ITZ)=8
               TINT(ITZ)=[F:PPC]FLDTYP(I)
    Endif
  Endif
Next I
Gosub CHAMPS_COMMUNS
Gosub CRE_AMP
Gosub UN_MASQUE
Gosub GEN_FEN
Gosub SUP_AMP
Return

# Issue 71069 - 2016-01-29 by SR : PJT
# Suppression des actions inutiles
$SUP_AMA
If clalev ([F:AMA]) <= 0 : Local File = APPLI+".AMSKACT" [AMA] : Endif
For I = 1 To 5
     # Suppression de la sélection objet. On laisse la sélection du type de donnée fonctionner
      Update [AMA] Where ACTION="SELOBJ1" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=8
&                    With CODAFF="PPLW_"
    If [F:PPC]FLDTYP(I-1)="PJT"
        # Suppression des actions qui sont gérées par le type de données PJT
        Gosub SUP_AMA_PJT From TRTPJTPUR
    Endif
    If [F:PPC]FLDTYP(I-1)="SAT"
        # Suppression des actions qui sont gérées par le type de données SAT
        Gosub SUP_AMA_SAT
    Endif
Next
Return

# ---------------------------------------------------------------------------------------------
# Suppression des actions dans AMSKACT
$SUP_AMA_SAT
# Suppression des actions qui se trouvent sur l'écran PPLW pour les chps CRIT1 à CRIT5
# et qui seront remplacées par les actions du type de données SAT sur l'écran généré
# Les actions seront recréées sur l'écran PPLW après génération de l'écran généré

# Sur tous les champs critère :
# Suppression de l'action IB_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=1
&                    With CODAFF="PPLW_"
# Suppression de l'action AS_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=4
&                    With CODAFF="PPLW_"
# Suppression de l'action C_
Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=5
&                    With CODAFF="PPLW_"
# Suppression de l'action B1_
Update [AMA] Where ACTION="GOBJETC" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=9
&                    With CODAFF="PPLW_"

# Sur le 1er champ critère CRIT1
If I=1
  # Suppression des boutons B2 à B4
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=10
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=11
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=12
&                      With CODAFF="PPLW_"
  # Suppression des boutons B5 à B8
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=15
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=16
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=17
&                      With CODAFF="PPLW_"
  Update [AMA] Where ACTION="STD" & CODAFF="PPLW" & CODZON="CRIT"+num$(I) & TYPACT=18
&                      With CODAFF="PPLW_"
Endif
Return

# Récupération des actions supprimées
$CRE_AMA
If clalev ([F:AMA]) <= 0 : Local File = APPLI+".AMSKACT" [AMA] : Endif
Update [AMA] Where CODAFF="PPLW_"
&            With CODAFF="PPLW"
Return
# End issue 71069

#------------------------------------------------------------------------
# --- Champs communs à tous les écrans (si plusieurs écrans ?)
#------------------------------------------------------------------------
$CHAMPS_COMMUNS
For I=7 To dim(ZCHAMP)-1
    If ZCHAMP(I)<>""
       If ZZ(I)=0 : ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=3 : Endif
       If ZZ(I)<>0 & I>13 & I<23
#               dans champs rem/frais chgt de l'intitulé de atextra
#         ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=4 : TINT(ITZ)= GLIBDES(I-17)
        Endif
#               dans champs rem/frais si % : chgt type de donnée RAT
       If ZZ(I)=2 & I>13 & I<23
          ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=8 : TINT(ITZ)="RAT"
       Endif
#non géré dans les achats
#               si champ article gratuit   : chgt type de donnée ITS
#      If ZZ(I)<>0 & I=25
#      ITZ +=1 : TZONE(ITZ)=ZCHAMP(I) : TMOD(ITZ)=8 : TINT(ITZ)="ITS"
#      Endif
    Endif
Next I
Return

#------------------------------------------------------------------------
# --- Création temporaire dans AMSKPAR des données pour type ADI CCE ...
#------------------------------------------------------------------------
$CRE_AMP
If clalev ([F:AMZ]) <= 0 : Local File = APPLI+".AMSKZON" [AMZ] : Endif
If clalev ([F:AMP]) <= 0 : Local File = APPLI+".AMSKPAR" [AMP] : Endif
Default File [PPC]

For I = 1 To 5
    Case [F:PPC]FLDTYP(I-1)
         When "ADI"
             If find([F:PPC]FLDTYPCPL(I-1),"20","21","22","23","24",
&                                          "30","31","32","33","34",
&                                          "40","41","42","43","44")
                Gosub CRE_AMP_STT    : If GOK=0 : Break : Endif
              Else
                Gosub CRE_AMP_ADI    : If GOK=0 : Break : Endif
             Endif

         When "CCE"    Gosub CRE_AMP_CCE    : If GOK=0 : Break : Endif

         When "CAC"    Gosub CRE_AMP_CAC    : If GOK=0 : Break : Endif
        # Issue 71069 - 2016-01-29 by SR : PJT
         When "PJT"    Gosub CRE_AMP_ATY_PJT  : If GOK=0 : Break : Endif
         When "SAT"    Gosub CRE_AMP_ATY_SAT  : If GOK=0 : Break : Endif
        # End issue 71069
        # Issue 114400 - 2016-02-09 by SR : ERROR While Using INCOTERM CITY ICTCTY
         When "CTY"    Gosub CRE_AMP_ATY_CTY  : If GOK=0 : Break : Endif

         When Default
    Endcase

    If [F:PPC]LIEN(I-1)>0
       Read [AMZ]CODE="PPLW";"CRIT"+num$(I)
       If !fstat
          [F:AMZ]LIEN=[F:PPC]LIEN(I-1)
          Rewrite [AMZ]
       Endif
       Read [AMZ]CODE="PPLV";"CRIT"+num$(I)
       If !fstat
          [F:AMZ]LIEN=[F:PPC]LIEN(I-1)
          Rewrite [AMZ]
       Endif
    Endif

Next I

If [F:PPC]PRIPRO=4
  Read [AMZ]CODE="PPLW";"PRI"
  If !fstat
    If [F:AMZ]INTIT=1871 : [F:AMZ]INTIT=3377 : Endif
    Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="PPLV";"PRI"
  If !fstat
    If [F:AMZ]INTIT=1871 : [F:AMZ]INTIT=3377 : Endif
    Rewrite [AMZ]
  Endif
Endif

Return

#---
$CRE_AMP_ADI
[F:AMP]CODPAR = "ADI"
Read [ATZ] CODZONE = [F:PPC]FIL(I-1);[F:PPC]FLD(I-1)
If fstat : GOK = 0 : Call FSTA("ATZ") From GLOCK : Return : Endif
J = instr(1,[F:ATZ]EXPLIEN,";")
If J <> 0 : [F:AMP]VALPAR = left$([F:ATZ]EXPLIEN,J-1) : Endif
Gosub CRE_AMP_WRITE
Return

#--- axes analytiques
$CRE_AMP_CCE
[F:AMP]CODPAR = "CCE"
If [F:PPC]FLD(I-1)="CCE"
   [F:AMP]VALPAR = '"'+[F:PPC]CRIDIE(I-1)+'"'
Else [F:AMP]VALPAR = '"'+right$([F:PPC]FLD(I-1),4)+'"'
Endif
Gosub CRE_AMP_WRITE
Return

#--- codes stat articles / clients / fournisseurs
$CRE_AMP_STT
[F:AMP]CODPAR = "ADI"
[F:AMP]VALPAR = [F:PPC]FLDTYPCPL(I-1)
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = "TABDIV"
[F:AMP]VALPAR = '""'
Gosub CRE_AMP_WRITE
Return

#--- code comptable
$CRE_AMP_CAC
[F:AMP]CODPAR = "CAC"
Case [F:PPC]FIL(I-1)
     When "ITMMASTER"     : [F:AMP]VALPAR= "1"
     When "BPARTNER"      : [F:AMP]VALPAR= "17"
     When "BPSUPPLIER"    : [F:AMP]VALPAR= "3"
     When "BPCUSTOMER"    : [F:AMP]VALPAR= "2"
     When "SALESREP"      : [F:AMP]VALPAR= "4"
Endcase
Gosub CRE_AMP_WRITE
Return
# Issue 71069 - 2016-01-29 by SR : PJT
#--- Type de donnée PJT
$CRE_AMP_ATY_PJT
Gosub CRE_AMP_ATY_PJT From TRTPJTPUR
Return

#--- Type de donnée SAT
#  Création temporaires des paramètres liés au type de données SAT
$CRE_AMP_ATY_SAT

Local Char WCODPAR_SAT(GLONAAR) (0..20)
WCODPAR_SAT(0)  = "PAYS"        : # Pays
WCODPAR_SAT(1)  = "CONTEXT"     : # Context

Local Integer WIND_FLD

[F:AMP]CODPAR = WCODPAR_SAT(0)     : # Code pays
[F:AMP]VALPAR = '""'
# Si le pays est paramétré comme critère de tarif, on l'utilise comme paramètre pour le type de données SAT
WIND_FLD=find("CRY",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE
[F:AMP]CODPAR = WCODPAR_SAT(1)     : # Contexte
[F:AMP]VALPAR = '"2"'
Gosub CRE_AMP_WRITE
Return
# End issue 71069

# Issue 114400 - 2016-02-09 by SR :  Error while using incoterm city ICTCTY
$CRE_AMP_ATY_CTY
Local Char WCODPAR_CTY(GLONAAR) (0..3)
#--Labels of CTY data type actions parameters
WCODPAR_CTY(0) = "PAYS" :# Pays        (Country)
WCODPAR_CTY(1) = "CP"   :# Code postal (Postal code)

Local Integer WIND_FLD

[F:AMP]CODPAR = WCODPAR_CTY(0)     :# Pays        (Country)
[F:AMP]VALPAR = '""'
WIND_FLD=find("CRY",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE

[F:AMP]CODPAR = WCODPAR_CTY(1)     :# Code postal (Postal code)
[F:AMP]VALPAR = '[M]WPOSCOD(nolign-1)'
WIND_FLD=find("POSCOD",[F:PPC]FLD(0..dim([F:PPC]FLD)-1))
If WIND_FLD
   [F:AMP]VALPAR = "[M]CRIT"+num$(WIND_FLD)+"(nolign-1)"
Endif
Gosub CRE_AMP_WRITE

Return
# End issue 114400

#---
$CRE_AMP_WRITE
[F:AMP]TYPAFF = 1
[F:AMP]CODAFF = MFROM
[F:AMP]CODZON = "CRIT"+num$(I)
Write [AMP]
If fstat
   GOK = 0 : Call FSTA("AMP") From GLOCK : Return
Endif
Return

#------------------------------------------------------------------------
# --- Suppression dans AMSKPAR masque racine des données pour type ADI CCE ...
$SUP_AMP
If !clalev([F:AMZ])  Local File = APPLI+".AMSKZON" [AMZ] : Endif
For I = 1 To 5
  If [F:PPC]FLDTYP(I-1)="CCE"
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="CCE"
  Endif
  If [F:PPC]FLDTYP(I-1)="ADI"
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="ADI"
    If find([F:PPC]FLDTYPCPL(I-1),"20","21","22","23","24",
&                                 "30","31","32","33","34",
&                                 "40","41","42","43","44")
       Delete [F:AMP]Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="TABDIV"
    Endif
  Endif
  If [F:PPC]FLDTYP(I-1)="CAC"
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR="CAC"
  Endif

 # Issue 71069 - 2016-01-29 by SR : PJT
  If [F:PPC]FLDTYP(I-1)="PJT"
    Gosub SUP_AMP_PJT From TRTPJTPUR
  Endif

  If [F:PPC]FLDTYP(I-1)="SAT"
    Gosub SUP_AMP_SAT
  Endif
  # End issue 71069

   # Issue 114400 - 2016-02-09 by SR  : Error while using incoterm city ICTCTY
  If [F:PPC]FLDTYP(I-1)="CTY"
    Gosub SUP_AMT_CTY
  Endif
  # End issue 114400

  Read [AMZ]CODE="PPLW";"CRIT"+num$(I)
  If !fstat
     [F:AMZ]LIEN=0
     Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="PPLV";"CRIT"+num$(I)
  If !fstat
     [F:AMZ]LIEN=0
     Rewrite [AMZ]
  Endif

Next I

If [F:PPC]PRIPRO=4
  Read [AMZ]CODE="PPLW";"PRI"
  If !fstat
    If [F:AMZ]INTIT=3377 : [F:AMZ]INTIT=1871 : Endif
    Rewrite [AMZ]
  Endif
  Read [AMZ]CODE="PPLV";"PRI"
  If !fstat
    If [F:AMZ]INTIT=3377 : [F:AMZ]INTIT=1871 : Endif
    Rewrite [AMZ]
  Endif
Endif

Return

# Issue 71069 - 2016-01-29 by SR : PJT
# Suppression des paramètres dans AMSKPAR
$SUP_AMP_SAT
Local Integer WIND_SAT

For WIND_SAT=0 To dim(WCODPAR_SAT)-1
    If WCODPAR_SAT(WIND_SAT)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR_SAT(WIND_SAT)
Next
Return
# End issue 71069

# Issue 114400 - 2016-02-09 by SR  : Error while using incoterm city ICTCTY
$SUP_AMT_CTY
Local Integer WIND_CTY

For WIND_CTY=0 To dim(WCODPAR_CTY)-1
    If WCODPAR_CTY(WIND_CTY)="" Break Endif
    Delete [F:AMP] Where TYPAFF=1 & CODAFF=MFROM & CODZON="CRIT"+num$(I) & CODPAR=WCODPAR_CTY(WIND_CTY)
Next

Return
# End issue 114400

#------------------------------------------------------------------------
# --- génération un écran
#------------------------------------------------------------------------
$UN_MASQUE
OPT1=0
OPT2=0                    : # pas affichage du masque genere
OPT3=0
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 : GOK=0 : Endif
Return


#######################################################################
# Génération de la fenêtre par copie de la fenetre standard           #
#                                                                     #
#  - La fenêtre standard doit exister                                 #
#    -    A1        :    Saisie tarif                                 #
#    -    A2        :    Visualisation tarif                          #
#         Elle n'est utilisée que pour la copie                       #
#                                                                     #
#  - Création enr. ds TABLE AWINDOW  [AWI]                            #
#                     TABLE AWINPAR  [AWP]                            #
#                     TABLE AWINBRO  [AWB]                            #
#                     TABLE AWINBOUT [AWT]                            #
#  - Génération du traitement lié à la fenêtre                        #
#                                                                     #
#######################################################################
$GEN_FEN
Local Char    NOMWIN(GLONFEN), WINREF(GLONFEN)

Case MFROM
  When "PPLW"    :
        WINREF = "A1"
        NOMWIN = "WA1"+num$([F:PPC]PLI)

  When "PPLV"    :
        WINREF = "A2"
        NOMWIN = "WA2"+num$([F:PPC]PLI)
  When Default : Return
Endcase

# suppression de la fenetre (sauf si celle de base)
If NOMWIN<>WINREF
  Delete [AWI] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINDOW"-NOMWIN  : Return : Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINPAR"-NOMWIN  : Return : Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINBRO"-NOMWIN  : Return : Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat=1 : GOK=-1 : GLOCK="$AWINBOUT"-NOMWIN : Return : Endif
Endif

# lecture de la fenêtre de référence
Read [AWI] AWI0 = WINREF
If !fstat
    [F:AWI]WIN=NOMWIN
    [F:AWI]NOMMSK(0)=NOMWIN+"1"
#    [F:AWI]LIBEL=[F:PPC]PLIDES             : #ts
    Call LECTEXTRA ([F:AWI]LIBEL,"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
    [F:AWI]ENAFLG=2                        : #ts
    [F:AWI]TRN=[F:PPC]PLI                  : #ts
    If NOMWIN<>WINREF
        # Issue 104224 - 2014-12-01 by SR
#CHECK IGNORE BEGIN
        GPOINT="CPLWINPPL" : Gosub ENTREE From EXEFNC
#CHECK IGNORE END
        Write [AWI]
        If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
        For [AWP] AWP0 Where WIN=WINREF
            [F:AWP]WIN=NOMWIN
            Write [AWP]
            If fstat : GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
        Next
        If GOK<1 : Return : Endif
        For [AWB]AWB0 Where WIN=WINREF
            [F:AWB]WIN=NOMWIN
            Write [AWB]
            If fstat : GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
        Next
        If GOK<1 : Return : Endif
        For [AWT]AWT0 Where WIN=WINREF
            [F:AWT]WIN=NOMWIN
            Write [AWT]
            If fstat : GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
        Next
        If GOK<1 : Return : Endif
    Else
        Rewrite [AWI]
        If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
    Endif
    Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
    If !OK  GOK=0 : Return : Endif
Endif

Return


#######################################################################
# Suppression des fenêtres liés a un code tarif                       #
#  - TABLE AWINDOW  [AWI]                                             #
#  - TABLE AWINPAR  [AWP]                                             #
#  - TABLE AWINBRO  [AWP]                                             #
#  - TABLE AWINBOUT [AWT]                                             #
#  - Traitement lié à la fenetre                                      #
#######################################################################
$DEL_FEN
Local Char    NOMWIN(GLONFEN), NOMTRTWIN(GLONADC)
#-----
If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif
If clalev([F:AWP])=0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif
If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif
If clalev([F:AWT])=0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif
#-----
For I=1 To 2
  NOMWIN    = "WA"+num$(I)+num$([F:PPC]PLI)
  NOMTRTWIN = "WGA"+num$(I)+num$([F:PPC]PLI)
  Call DELWIN(NOMWIN,APPLI) From MSKDIV
Next
Return


#########################################################################
######## SUBPROG dans PPC0 : Généralités de paramétrage #################
#########################################################################

########################################
#PAs de gratuits ni de composants dans les achats
Subprog AS_PLITYP(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
End

######################################## type de tarif
Subprog AM_PLITYP(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
[M:PPC0]PLITYP=VALEUR
If VALEUR=2     : # Groupé
  Raz [M:PPC2]PRIPRO, [M:PPC2]PRIFLD, [M:PPC2]PRITYP
  [M:PPC2]PRIQTYFLG=2
  Raz [M:PPC2]CUR, [M:PPC2]ATICNVFLG, [M:PPC2]UOMCNVFLG
  Raz [M:PPC2]FOCPRO, [M:PPC2]FOCTYP, [M:PPC2]COMPRO
Endif
If VALEUR=3     : # interdit
  Raz [M:PPC2]PRIPRO, [M:PPC2]PRIFLD, [M:PPC2]PRITYP, [M:PPC2]PRIQTYFLG
  Raz [M:PPC2]CUR, [M:PPC2]ATICNVFLG, [M:PPC2]UOMCNVFLG
  Raz [M:PPC2]FOCPRO, [M:PPC2]FOCTYP, [M:PPC2]COMPRO
Endif
End

######################################## priorité
Subprog AM_PIO(VALEUR)
Variable Decimal  VALEUR
If VALEUR<1 | VALEUR>99 : mkstat=1 : Endif
End

#########################################################################
######## SUBPROG dans PPC1 : les critères ###############################
#########################################################################
# --- si sortie du tableau recherche crit. devise, unité, article, client
Subprog C_BASTAB
Local Integer I
[M:PPC1]CRICURNUM=0 : [M:PPC1]CRIUOMNUM=0 : [M:PPC1]CRIITMNUM=0 : [M:PPC1]CRIBPSNUM=0
If status=1  | status=4  | status=5  | status=20 |
&  status=21 | status=26 | status=92 | status=93
  For I=0 To 4
    If [M:PPC1]ABB(I)="ITM" & [M:PPC1]FLD(I)="ITMREF"  : [M:PPC1]FLDTYP(I)="ITM" : Endif
    If [M:PPC1]ABB(I)="BPR" & [M:PPC1]FLD(I)="BPRNUM"  : [M:PPC1]FLDTYP(I)="BPS" : Endif
    If [M:PPC1]FLDTYP(I)="BPR" : [M:PPC1]FLDTYP(I)="BPS" : Endif
    If [M:PPC1]FLDTYP(I)="CUR" : [M:PPC1]CRICURNUM=I+1 : Endif
    If [M:PPC1]FLDTYP(I)="UOM" : [M:PPC1]CRIUOMNUM=I+1 : Endif
    If [M:PPC1]FLDTYP(I)="ITM" : [M:PPC1]CRIITMNUM=I+1 : Endif
    If [M:PPC1]FLDTYP(I)="BPS" : [M:PPC1]CRIBPSNUM=I+1 : Endif
#   Chargement Complement type de donnee
    Raz [M:PPC1]FLDTYPCPL(I)
#   - si ADI : no table diverse statistique
    If [M:PPC1]FLDTYP(I)="ADI"
       Case [M:PPC1]FLD(I)
            When "TSICOD"  : [M:PPC1]FLDTYPCPL(I)=num$([M:PPC1]CRIIND(I)+20)
            When "TSICOD1" : [M:PPC1]FLDTYPCPL(I)="20"
            When "TSICOD2" : [M:PPC1]FLDTYPCPL(I)="21"
            When "TSICOD3" : [M:PPC1]FLDTYPCPL(I)="22"
            When "TSICOD4" : [M:PPC1]FLDTYPCPL(I)="23"
            When "TSICOD5" : [M:PPC1]FLDTYPCPL(I)="24"
            When "TSCCOD"  : [M:PPC1]FLDTYPCPL(I)=num$([M:PPC1]CRIIND(I)+30)
            When "TSCCOD1" : [M:PPC1]FLDTYPCPL(I)="30"
            When "TSCCOD2" : [M:PPC1]FLDTYPCPL(I)="31"
            When "TSCCOD3" : [M:PPC1]FLDTYPCPL(I)="32"
            When "TSCCOD4" : [M:PPC1]FLDTYPCPL(I)="33"
            When "TSCCOD5" : [M:PPC1]FLDTYPCPL(I)="34"
            When "TSSCOD"  : [M:PPC1]FLDTYPCPL(I)=num$([M:PPC1]CRIIND(I)+40)
            When "TSSCOD1" : [M:PPC1]FLDTYPCPL(I)="40"
            When "TSSCOD2" : [M:PPC1]FLDTYPCPL(I)="41"
            When "TSSCOD3" : [M:PPC1]FLDTYPCPL(I)="42"
            When "TSSCOD4" : [M:PPC1]FLDTYPCPL(I)="43"
            When "TSSCOD5" : [M:PPC1]FLDTYPCPL(I)="44"
       Endcase
    Endif


  Next I
Endif
End


Subprog C_FIL(VALEUR)
Variable Char    VALEUR()
Local Integer NUMLIB, OK
If VALEUR="" : mkstat=1 : End : Endif
OK=find(VALEUR,JGFICFIC(0..JGNBFIC-1))
If OK=0 : mkstat=1 : GMESSAGE=mess(6,141,1) : End : Endif
CZ=num$(VALEUR)
End

Subprog AM_FIL(VALEUR)
Variable Char    VALEUR()
# --- appel s/p récupération libellé et abréviation de la table
Call CHARFIC(1,"INTFIC","ABB","PPC1",VALEUR) From TRTPARAM
Affzo [PPC1]INTFIC(nolign-1)
End

Subprog S_FIL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
If VALEUR="" : VALEUR=JGFICFIC(0) : Endif
# --- appel s/p de choix d'une table dans la liste
Call CHXFIC(2,JGNBFIC,JGFICFIC,VALEUR) From TRTPARAM
If VALEUR="" : mkstat=1 : End :Endif
End

######################################## champ fichier
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=1 : End :Endif
Local Integer I, NOL
Local Char    WVAL
VALEUR=toupper(VALEUR)
NOL=nolign-1
WVAL=VALEUR
I=instr(1,WVAL,"(")
If I
  VALEUR=left$(WVAL,I-1)
  [M:PPC1]CRIIND(NOL)=val(right$(WVAL,I+1))
Endif
Read [ATZ] CODZONE=[M:PPC1]FIL(NOL); VALEUR
If fstat : mkstat=1 : GMESSAGE=mess(41,100,1) : End : Endif

# Issue 71069 - 2016-01-29 by SR : PJT
# Vérification exclusivité entre les champs PJT et PJTNUM de la table PPRICLINK
If [F:ATZ]CODTYP="PJT"
  Gosub C_FLD_PJT From TRTPJTPUR
Endif

# Issue X3-62638 - 2017-11-03 by SR : Autoriser ECCVALMAJ par point d'entrée
GPE = 1
GPOINT="CTRLECC" : Gosub ENTREE From EXEFNC
If GPE = 1
  # Version fields in PPRINCLINK are used only for price processing (Factor or Calculation)
  If [M:PPC1]FIL(NOL)="PPRICLINK" &  find(VALEUR, "ECCVALMAJ", "ECCVALMIN")
      mkstat=1 : GMESSAGE=mess(642,199,1) : End
  Endif
Else
  # ECCVALMIN field in PPRINCLINK is used only for price processing (Factor or Calculation)
  If [M:PPC1]FIL(NOL)="PPRICLINK" &  VALEUR = "ECCVALMIN"
      mkstat=1 : GMESSAGE=mess(642,199,1) : End
  Endif
Endif
# End issue X3-62638
# End issue 71069
End

##################################
Subprog AM_FLD(VALEUR)
Variable Char    VALEUR()
Local Integer NOL, TOTLNG, TOTMAX, OK
NOL=nolign-1

[M:PPC1]CRIIND(NOL)=0
# --- récup. libellé, longueur, indice, menu local type donnée  Rubrique
Call CHARCRIT(1,[M:PPC1]FIL(NOL),"CRIDES","CRILEN","FLDTYP","PPUMNU","PPC1",VALEUR) From TRTPARAM
If !mkstat : Affzo [PPC1]CRIDES(NOL) : Endif

# --- controle si longueur totale des critères > longueur type donnée PPX
#     (15 = 10 type alpha + 5 sépateurs)
TOTMAX=mod(type([F:PPL]PLICRI)-15,256) : # Bug UNICODE
TOTLNG=sum([M:PPC1]CRILEN)
If TOTLNG>TOTMAX
  Call AVERTIR(mess(239,199,1)-"("+num$(TOTLNG)+")"+"\"+mess(240,199,1)-":"-num$(TOTMAX),OK) From GESECRAN
  If OK<>2 : mkstat=2 : Endif
Endif
End

Subprog S_FLD(VALEUR)
Variable Char    VALEUR()
Local Char    WVAL
Local Integer NOL, I
NOL=nolign-1
# --- appel s/p choix d'une rubrique table
Call CHXCRIT(1,[M:PPC1]FIL(NOL),[M:PPC1]ABB(NOL),"CRIIND","PPC1",VALEUR) From TRTPARAM
If VALEUR="" : mkstat=1 : End : Endif
End

######################################## code axe analytique critère
Subprog AS_CRIDIE(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Read [ATZ] CODZONE=[M:PPC1]FIL(NOL);[M:PPC1]FLD(NOL)
If fstat  mkstat=1 : End : Endif
If !find([M:PPC1]FLD(NOL),"CCE")  mkstat=2 : End : Endif
End

Subprog C_CRIDIE(VALEUR)
Variable Char    VALEUR()
If VALEUR=""  mkstat=1 : End : Endif
End

######################################## indice critère
Subprog AS_CRIIND(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
Read [ATZ] CODZONE=[M:PPC1]FIL(NOL) ; [M:PPC1]FLD(NOL)
If fstat : mkstat=1 : End : Endif
If [F:ATZ]DIME<2 & !find([M:PPC1]FLD(NOL),"TSICOD","TSSCOD","TSCCOD")  mkstat=2 : End : Endif
End

Subprog C_CRIIND(VALEUR)
Variable Decimal VALEUR
Local Integer NOL
NOL=nolign-1
Read [ATZ] CODZONE=[M:PPC1]FIL(NOL) ; [M:PPC1]FLD(NOL)
If fstat : mkstat=1 : End : Endif
If [M:PPC1]FLD(NOL) = "TSSCOD" & VALEUR < 5 : End : Endif
If [M:PPC1]FLD(NOL) = "TSICOD" & VALEUR < 5 : End : Endif
If [M:PPC1]FLD(NOL) = "TSCCOD" & VALEUR < 5 : End : Endif
If VALEUR>[F:ATZ]DIME-1 : mkstat=1 : GMESSAGE=mess(35,199,1) : Endif
End

#########################################################################
######## SUBPROG dans PPC2 : Conditions prix / gratuit / commission #####
#########################################################################
Subprog AV_PRIPRO(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : Raz VALEUR : End : Endif
If VALEUR=0 : VALEUR=1 : Endif
End

########################################
Subprog AS_PRIPRO(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : mkstat=2 : End : Endif
If [M:PPC0]PLITYP=2 : GMENLOC(3)=1 : GMENLOC(5)=1 : Endif
End

######################################## traitement prix
Subprog AP_PRIPRO(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
# --- Si traitement prix = Non / Valeur / Valeur pour n
If VALEUR=1 | VALEUR=2 | VALEUR=3
  If !GIMPORT : Effzo [PPC2]PRIFLD : Endif
Endif
End

######################################## champ prix base
Subprog AV_PRIFLD(VALEUR)
Variable Char    VALEUR()
If [M:PPC0]PLITYP=3 | [M:PPC2]PRIPRO=1 | [M:PPC2]PRIPRO=2 | [M:PPC2]PRIPRO=3
  Raz VALEUR
Endif
End

########################################
Subprog AS_PRIFLD(VALEUR)
Variable Char    VALEUR()
If [M:PPC0]PLITYP=3 | [M:PPC2]PRIPRO=1 | [M:PPC2]PRIPRO=2 | [M:PPC2]PRIPRO=3 : mkstat=2 : End : Endif
Raz [M:PPC2]FLTTAB, XXCONV, XXVAR
Case [M:PPC2]PRIPRO
  When 4
    If [M:PPC0]PLIBPRCNR=2
      [M:PPC2]FLTTAB="find(ABRFIC,'ITM','ITP','ITC','ITV','ITS')"
    Else
      [M:PPC2]FLTTAB="find(ABRFIC,'ITM','ITP','ITC','ITV','ITS')"
    Endif
  When 5
    If [M:PPC0]PLIBPRCNR=2
#      [M:PPC2]FLTTAB="find(ABRFIC,'ITM','ITP','ITC','ITV','BPR','BPS','MVS','PPK','ITS','BPC','BPD','MVC')"
      # Issue 96730 - 2014-02-13 by SR : enlever la , à la fin
      [M:PPC2]FLTTAB="find(ABRFIC,'ITM','ITP','ITC','ITV','BPR','BPS','MVS','PPK','ITS','BPC','BPD')"
    Else
      [M:PPC2]FLTTAB="find(ABRFIC,'ITM','ITP','ITC','ITV','BPR','BPS','MVS','PPK','ITS')"
    Endif
Endcase
End

######################################## prix ht/ttc
Subprog AV_PRITYP(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : Raz VALEUR : End : Endif
If VALEUR=0 : VALEUR=1 : Endif
End

########################################
Subprog AS_PRITYP(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : mkstat=2 : End : Endif
End

######################################## prix/qté
Subprog AV_PRIQTYFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
If [M:PPC0]PLITYP=3 : Raz VALEUR : End : Endif
If [M:PPC0]PLITYP=2 & VALEUR<3 : VALEUR=3 : Endif
End

########################################
Subprog AS_PRIQTYFLG(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : mkstat=2 : End : Endif
Raz GMENLOC
If [M:PPC0]PLITYP=2
  GMENLOC(1)=1 : GMENLOC(2)=1
Else
  GMENLOC(3)=1 : GMENLOC(4)=1 : GMENLOC(5) = 1
Endif
If VALEUR=0 : VALEUR=1 : Endif
End

########################################
Subprog AP_PRIQTYFLG(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End

######################################## devise
Subprog AV_CUR(VALEUR)
Variable Char    VALEUR()
If [M:PPC1]CRICURNUM<>0 | [M:PPC0]PLITYP=3 : Raz VALEUR : End : Endif
End

########################################
Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
If [M:PPC1]CRICURNUM<>0 | [M:PPC0]PLITYP=3 : mkstat=2 : End : Endif
End

######################################## conversion ht/ttc
Subprog AV_ATICNVFLG(VALEUR)
Variable Integer VALEUR
If [M:PPC0]PLITYP=3 : Raz VALEUR : End : Endif
#If VALEUR=0 : VALEUR=1 : Endif
VALEUR = 2
End

