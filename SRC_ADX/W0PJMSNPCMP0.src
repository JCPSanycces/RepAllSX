#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNPCMP0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone KEYEXTN1
mkstat = 0
zoncou = "KEYEXTN1"
indice = 0
WCHAR = [M]KEYEXTN1
If varmode([M]KEYEXTN1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "KEYEXTN1" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]KEYEXTN1,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PJMSNPD","",[M]KEYEXTN1,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]KEYEXTN1 or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_KEYEXTN1([M]KEYEXTN1) From PJMSNPCMP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "KEYEXTN1" : GZNUM = 1003799 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone KEYEXTN
mkstat = 0
zoncou = "KEYEXTN"
indice = 0
WCHAR = [M]KEYEXTN
If varmode([M]KEYEXTN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "KEYEXTN" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PJMSNPD","!",[M]KEYEXTN,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "KEYEXTN" : GZNUM = 1003800 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]KEYEXTN or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_KEYEXTN([M]KEYEXTN) From PJMSNPCMP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "KEYEXTN" : GZNUM = 1003800 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CURRSIT
mkstat = 0
zoncou = "CURRSIT"
indice = 0
IMPENT = [M]CURRSIT
WNUM = IMPENT
If varinit([M]CURRSIT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CURRSIT,indice)=0
 [M]CURRSIT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CURRSIT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CURRSIT(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CURRSIT" : GZNUM = 1003781 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_CURRSIT(IMPENT) From PJMSNPCMP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CURRSIT" : GZNUM = 1003781 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]CURRSIT = IMPENT

## Zone SHOWGRP
mkstat = 0
zoncou = "SHOWGRP"
indice = 0
If varinit([M]SHOWGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SHOWGRP,"388","") From SUBADI
 GACTION = SAVACT
Endif

## Zone SHOWQTY
mkstat = 0
zoncou = "SHOWQTY"
indice = 0
IMPENT = [M]SHOWQTY
WNUM = IMPENT
If varinit([M]SHOWQTY,indice)=0
 IMPENT = 1
Endif
If varmode([M]SHOWQTY,indice)=0
 [M]SHOWQTY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SHOWQTY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SHOWQTY(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_SHOWQTY(IMPENT) From PJMSNPCMP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SHOWQTY" : GZNUM = 271 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SHOWQTY = IMPENT

## Zone SHOWAMT
mkstat = 0
zoncou = "SHOWAMT"
indice = 0
IMPENT = [M]SHOWAMT
WNUM = IMPENT
If varinit([M]SHOWAMT,indice)=0
 IMPENT = 1
Endif
If varmode([M]SHOWAMT,indice)=0
 [M]SHOWAMT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SHOWAMT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SHOWAMT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_SHOWAMT(IMPENT) From PJMSNPCMP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SHOWAMT" : GZNUM = 3603 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SHOWAMT = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMSNPCMP0"
Return

