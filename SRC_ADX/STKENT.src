###############################################################################
#
#    SOUS PROGRAMMES DEDIES A LA GESTION DE STOENTW
#
################################################################################
################################################################################

################################################################################
# DELSTOENTW     Supprimme les lignes du tableau STOENTW dont WSTOSEQ=LLIG
#
# Paramètres E : LLIG  = indice de la ligne à partir de laquelle
#                        va s'effectuer la suppression
#                LLIG1 = indice de la ligne jusqu'à laquelle
#                        va s'effectuer la suppression (facultatif si LLIG=-1)
#                LABR  = Masque dans lequel s'effectue la suppression
#                        (facultatif si LLIG=-1)
#                LLOC  = Suppression des réservations d'emplacements (0 = non, 1 = oui)
#                LPRI  = Suppression des prix dans VALW (0 = non, 1 = oui)
#                LFCY  = Site de stock
#                LFRE  = Gestion Fréquence (0 = non, 1 = oui)
#                LSUP  = Parametre supplémentaire
#
################################################################################
Subprog DELSTOENTW (LLIG, LLIG1, LABR, LLOC, LPRI, LFCY, LFRE, LSUP)
Value Integer LLIG
Value Integer LLIG1
Value Char    LABR
Value Integer LLOC
Value Integer LPRI
Value Char    LFCY
Value Integer LFRE
Value Char    LSUP

Local Integer I, J, K, NOL
Local Integer LRET, OK
Local Integer LQUA
Local Integer LITP
Local Char    WITM(GLONITM)      # hcb V6CQ
# Si tunnel depuis plan de rangement, pas de raz du masque
If GFONCTION1="FUNSSL" & GFONCTION<>"FUNSSL" End Endif
# Si traitement de toutes les lignes (abandon de la saisie document)

If LLIG=-1
    If LLOC
        Call STKDELRES(0, "", "", LRET) From STKLOC
    Endif
    # hcb V6CQ deb
    If !LRET & LFRE = 1
       For I = 0 To [M:ENTW]NBLIG-1
           If left$([M:ENTW]STA(I),1) = "Q" & [M:ENTW]QLYCTLFLG(I) = 2
              Call STKFREQCQ(LABR,LFCY,I,[M:ENTW]ITMREF(I),"","A",LQUA,LITP) From STKACT
              If !GOK
                 End
              Endif
           Endif
       Next
    Endif
    # hcb V6CQ deb
    If !LRET
        Local Char LSAVEZON(10)(6)
        LSAVEZON(0) = [M:ENTW]WZONPCU
        LSAVEZON(1) = [M:ENTW]WZONQUC
        LSAVEZON(2) = [M:ENTW]WZONCCS
        LSAVEZON(3) = [M:ENTW]WZONSTU
        LSAVEZON(4) = [M:ENTW]WZONQUS
        LSAVEZON(5) = [M:ENTW]WZONSTOUPD
        Raz [M:ENTW]
        [M:ENTW]WZONPCU    = LSAVEZON(0)
        [M:ENTW]WZONQUC    = LSAVEZON(1)
        [M:ENTW]WZONCCS    = LSAVEZON(2)
        [M:ENTW]WZONSTU    = LSAVEZON(3)
        [M:ENTW]WZONQUS    = LSAVEZON(4)
        [M:ENTW]WZONSTOUPD = LSAVEZON(5)
        If LPRI = 1
            If clalev([M:VALW])
                Local Char LTMP1(30), LTMP2(30)    # ZONPRI contient aussi l'abréviation du masque
                LTMP1 = [M:VALW]ZONPRI
                LTMP2 = [M:VALW]ZONPRIORD
                Raz [M:VALW]
                [M:VALW]ZONPRI = LTMP1
                [M:VALW]ZONPRIORD = LTMP2
            Endif
        Endif
    Endif
    End
Endif

For I=LLIG To LLIG1
   Raz J, K, OK
   Raz WITM                 # hcb V6CQ
   While OK<>1
      J=evalue("find([M:"+LABR+"]WSTOSEQ(I),[M:ENTW]WSTOSEQ(K..[M:ENTW]NBLIG-1))")
      If J>0
         NOL=K+J-1
         K=NOL+1
         Raz [M:ENTW]WSTOSEQ(NOL)
         Raz [M:ENTW]QTYPCU(NOL),[M:ENTW]QTYSTU(NOL)
         WITM = [M:ENTW]ITMREF(NOL)        # hcb V6CQ
         If LLOC
            Call STKDELRES([M:ENTW]WLOCSEQ(NOL), "", "", LRET) From STKLOC
         Endif
         If K>[M:ENTW]NBLIG-1 OK=1 Endif
      Else
         OK=1
      Endif
   Wend
   If LFRE = 1 & WITM <> "" & evalue("dim([M:"+LABR+"]QUAFLG)")>0 & evalue("[M:"+LABR+"]QUAFLG(LLIG)")= 2
      Z = sigma(0,[M:ENTW]NBLIG-1,(([M:ENTW]ITMREF(indcum)= WITM)*([M:ENTW]WSTOSEQ(indcum) <> 0)))
      If Z = 0
         Call STKFREQCQ(LABR,LFCY,I,WITM,"","A",LQUA,LITP) From STKACT
      Endif
   Endif
Next I

If LPRI = 1
    If clalev([M:VALW])
        For I=LLIG To LLIG1
            J=evalue("find([M:"+LABR+"]WSTOSEQ(I),[M:VALW]WSTOSEQ)")
            If J>0
                Raz [M:VALW]WSTOSEQ(J-1)
            Endif
        Next
    Endif
Endif
End

################################################################################
# STKFILLENTW    Remplit une ligne de STOENTW à partir du masque passé en param
################################################################################
# Paramètres E : LFCY     = site
#                LABR     = abréviation écran
#                LTRS     = type mouvement stock (m704)
#                LTRSCOD  = code transaction particulière
#                LBPS     = tiers
#                LVCR     = type piece       (m701)
#                LDAT     = date imputation
#                LLIG     = n° de ligne dans le tableau de l'écran
#                LNBLIG   = Nombre de ligne dans LABR
#                LTABTRS  = Abréviation de la table transaction
#                           (elle doit être positionnée)
#
# Prérequis : Les champs [M:ENTW]WZONxxx doivent être renseignés
#
# Ce sous programme n'est appelé que dans le cas d'une nouvelle ligne de document
# ou dans le cas où il n'y a déjà qu'une seule ligne de détail. (Cf. OUVENT)
################################################################################
Subprog STKFILLENTW(LFCY,LABR,LTRS,LTRSCOD,LBPS,LVCR,LDAT,LLIG,LNBLIG,LTABTRS)
Value    Char     LFCY
Value    Char     LABR
Value    Integer  LTRS
Value    Char     LTRSCOD
Value    Char     LBPS
Value    Integer  LVCR
Value    Date     LDAT
Value    Integer  LLIG
Value    Integer  LNBLIG
Value    Char     LTABTRS

Local    Integer  LBID
Local    Integer  LRET
Local    Shortint WRET
Local    Decimal LOLDQTYSTU, LOLDQTYPCU
# Memorisation de l indice la ligne supprimée
Local    Integer WSUP : Raz WSUP
#--- Issue 85577 by TS
Local    Char LBPSLOT(GLONLOT)

If evalue("[M:"+LABR+"]WSTOSEQ(LLIG)") > 0
    WSUP = find ( evalue("[M:"+LABR+"]WSTOSEQ(LLIG)"),[M:ENTW]WSTOSEQ(0..[M:ENTW]NBLIG))
# Suppression de l'ancienne ligne
    If WSUP>0
        LOLDQTYSTU = [M:ENTW]QTYSTU(WSUP-1)
        LOLDQTYPCU = [M:ENTW]QTYPCU(WSUP-1)
    Endif
    Call DELSTOENTW( LLIG, LLIG, LABR, 1,0,LFCY,0,"")
Else
    Call STKWSTOSEQ(LABR, LLIG, LNBLIG, 0, LBID, LRET) From STKECR
Endif

# Chargement de STOENTW avec les elements de l ecran document

Local Integer WMAX
WMAX = dim([M:ENTW]PCU)     # mémorisation nombre de ligne maxi

Local Integer WLIG

WLIG = [M:ENTW]NBLIG

Local Char    LSLO(GLONSLO)
Local Char    LLOT(GLONLOT)
#                                  # hcb 71276 deb
Local Char    LMAJ(GLONECS)
Local Char    LMIN(GLONEVL)
Local Char    PZONMAJ(GLONECS)
Local Char    PZONMIN(GLONEVL)
Local Integer TYPTIERS
Local Char    BPRNUM
Local Char    PZONMAJORI
Local Char    PZONMINORI
#                                  # hcb 71276 fin

Local Integer LECC
Local Integer I
Local Integer LNB
Local Char    PLBEFMT
Local Char    LUSCAV(5)
Local Integer LMODIF
Local Decimal PCOE
Local Integer LLIGLOT, LLIGCCE
Local Integer LWRNSLO     # 0=Ok/1=Sous lot incorrect
Local Char    WLOC(GLONEMP)
Local Decimal WOVF        # Quantité ne pouvant pas aller sur l'emplacement

Local Integer WTYPQUAI    # hcb 45909

Local Integer LNBLPN      # hcb X3-64504 ajout par TS 2018/06/18

Raz LWRNSLO

If evalue("dim([M:"+LABR+"]LOT)")>=1    # bien tester ">=" car l'assemblage n'a qu'une seule ligne !!!
    LLOT = evalue("[M:"+LABR+"]LOT(LLIG)")
Endif

If evalue("dim([M:"+LABR+"]SLO)")>=1    # bien tester ">=" car l'assemblage n'a qu'une seule ligne !!!
    LSLO = evalue("[M:"+LABR+"]SLO(LLIG)")
#                                                        # hcb 48816 deb
    Raz [F:TLO]    # Il faut se positionner correctement avant de tester: il y a des cas où on n'est pas forcément bon
    WTYPQUAI = 0
    If evalue("dim([M:"+LABR+"]LOCTYP(LLIG))") > 0
        Read [TLO]TLO0=LFCY;evalue("[M:"+LABR+"]LOCTYP(LLIG)")
    Endif
    WTYPQUAI = [F:TLO]LOCCAT
#                                                          # hcb 48816 fin
#                                                          # hcb 45909 deb
    If LSLO = ""  & [F:ITM]LOTMGTCOD = 4  & WTYPQUAI <> 2  # hcb 45909
       If LABR<>"MBR"   # Issue 73500 - 2015-01-21 by CCC : Don't init SLO if reintegration
           LSLO = format$("N0:"+num$(GLONSLO),1)
           #point d'entrée  demande 53457
           GPOINT = "STKENTSLO"
           Gosub ENTREE From EXEFNC
           Default Mask "["+LABR+"]"
           Assign "[M:"+LABR+"]SLO(LLIG)" With LSLO
           Affzo[M]SLO(LLIG)
           If mod(GOUVENT,8) >= 4                              # hcb 45909
                  GOUVENT -= 4                                 # hcb 45909
           Endif                                               # hcb 45909
       Endif
    Endif
#                                                          # hcb 45909 fin
Else
    Raz LSLO
Endif
#                                                      # hcb 71276 deb
# dans le cas ou la rubrique lot est invisible il faut peut etre calculer les ecc
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>=1    # bien tester ">=" car l'assemblage n'a qu'une seule ligne !!!
   If [F:ITM]ECCSTO > 1
      Raz PZONMAJORI                     # hcb 71276
      Raz PZONMINORI                     # hcb 71276
      PZONMAJ = "ECCVALMAJ"              # hcb 71276
      PZONMIN = "ECCVALMIN"              # hcb 71276
      If LABR = "ENT" | LABR = "ENM"     # hcb 71276
         PZONMAJ    = "ECCVALMAJAFF"     # hcb 71276
         PZONMIN    = "ECCVALMINAFF"     # hcb 71276
         PZONMAJORI = "ECCVALMAJORI"     # hcb 71276
         PZONMINORI = "ECCVALMINORI"     # hcb 71276
      Endif                              # hcb 71276
      LMAJ = evalue("[M:"+LABR+"]ECCVALMAJ(LLIG)")
      If LMAJ = ""
         Call PAR_AMSKZON_LOT(LABR,TYPTIERS,BPRNUM,PZONMAJORI,PZONMINORI) From STKACT
         If PZONMAJORI= '""'
            Raz PZONMAJORI
         Endif
         If PZONMINORI= '""'
            Raz PZONMINORI
         Endif

         Call STKINIECC([F:ITM]ITMREF,LLOT,LABR,2,2,LLIG,2,LMAJ,PZONMAJ,PZONMIN,PZONMAJORI,PZONMINORI,TYPTIERS,evalue(BPRNUM)) From STKACT  # hcb 71276
      Endif
      LMAJ = evalue("[M:"+LABR+"]ECCVALMAJ(LLIG)")
      LMIN = evalue("[M:"+LABR+"]ECCVALMIN(LLIG)")
      LECC = evalue("[M:"+LABR+"]ECCSAIFLG(LLIG)")
   Endif
Endif
#                                                      # hcb 71276 fin

If evalue("dim([M:"+LABR+"]NBSLO)")>0 & evalue("[M:"+LABR+"]NBSLO(LLIG)")>=1
    LNB = evalue("[M:"+LABR+"]NBSLO(LLIG)")
Else
    LNB = 1
Endif
If WLIG+LNB >= WMAX
   Call ERREUR(mess(10,184,1)) From GESECRAN
   Raz GOUVENT
   End
Endif

Local Decimal  LTABQTY(LNB)
If LNB>1
    Local Decimal LQTY
    If evalue("dim([M:"+LABR+"]"+[M:ENTW]WZONPCU+")")>=0
       LQTY = evalue("[M:"+LABR+"]"+[M:ENTW]WZONQUC+"(LLIG)")
       #--- Issue 117545
       #Call CUTLIGSLO(LABR,LLIG,LQTY,LNB,evalue("[M:"+LABR+"]"+[M:ENTW]WZONPCU+"(LLIG)"),LTABQTY)
       Call CUTLIGSLO(LABR,LLIG,LQTY,LNB,evalue("[M:"+LABR+"]"+[M:ENTW]WZONPCU+"(LLIG)"),LTABQTY) From STKENTA
       #---
    Endif
Else
    If evalue("dim([M:"+LABR+"]"+[M:ENTW]WZONPCU+")")>=0
       LTABQTY(0) = evalue("[M:"+LABR+"]"+[M:ENTW]WZONQUC+"(LLIG)")
    Endif
Endif
If evalue("dim([M:"+LABR+"]LOC(LLIG))") >0
    WLOC = evalue("[M:"+LABR+"]LOC(LLIG)")
Endif
For I=0 To LNB-1
    [M:ENTW]NBLIG   += 1

    [M:ENTW]ORILIG    (WLIG)          = 3

    [M:ENTW]WSTOSEQ(WLIG)                = evalue("[M:"+LABR+"]WSTOSEQ(LLIG)")

    If evalue("dim([M:"+LABR+"]ITMREF)") > 0
            [M:ENTW]ITMREF (WLIG)        = evalue("[M:"+LABR+"]ITMREF(LLIG)")
    Endif
    If evalue("dim([M:"+LABR+"]QUAFLG)") > 0                                            # hcb V6CQ
            [M:ENTW]QUAFLG (WLIG)        = evalue("[M:"+LABR+"]QUAFLG(LLIG)")           # hcb V6CQ
    Endif                                                                               # hcb V6CQ
    If evalue("dim([M:"+LABR+"]QUAFRE)") > 0                                            # hcb V6CQ
            [M:ENTW]QUAFRE (WLIG)        = evalue("[M:"+LABR+"]QUAFRE(LLIG)")           # hcb V6CQ
    Endif                                                                               # hcb V6CQ
# hcb 30962 deb
    #------ S'il y avait déjà une ligne de détail et qu'on a augmenté la quantité sur la ligne de doc ------#
    # il faut recuperer la ligne complement lot correspondante
    If WSUP > 0  & [M:ENTW]NUMLIGLOT  (WSUP-1) <> 0
       [M:ENTW]NUMLIGLOT (WLIG) = [M:ENTW]NUMLIGLOT (WSUP-1)
    Endif
# hcb 30962 fin

    #------ S'il y avait déjà une ligne de détail et qu'on a augmenté la quantité sur la ligne de doc ------#
    #------ ou que le document fait référence à un document qui a généré des mouvements avec n° de série ------#
    #------ on doit conserver l'ancienne quantité mais prendre les nouvelles valeurs de statut, d'emplacement... ---#
# hcb 31498 deb
    If (WSUP>0)
& & ( LOLDQTYSTU<>(LTABQTY(I)*[M:ENTW]PCUSTUCOE (WSUP-1))
&         & evalue("dim([M:"+LABR+"]SERNUM)")>0
&         & evalue("[M:"+LABR+"]SERNUM(LLIG)")<>""
&         & find(LVCR,13,18))
# hcb 31498 fin
        GOUVENT = GOUVENT-mod(GOUVENT,128)+mod(GOUVENT,64)+64
        [M:ENTW]PCU       (WLIG)        = [M:ENTW]PCU(WSUP-1)
        [M:ENTW]PCUSTUCOE (WLIG)        = [M:ENTW]PCUSTUCOE(WSUP-1)
        [M:ENTW]QTYPCU    (WLIG)        = LOLDQTYPCU
        [M:ENTW]QTYSTU    (WLIG)        = LOLDQTYSTU
    #--- Issue X3-89211
    Elsif WSUP>0 & LOLDQTYSTU = evalue("[M:"+LABR+"]"+[M:ENTW]WZONQUS+"(LLIG)")
        [M:ENTW]PCU       (WLIG)        = [M:ENTW]PCU(WSUP-1)
        [M:ENTW]PCUSTUCOE (WLIG)        = [M:ENTW]PCUSTUCOE(WSUP-1)
        [M:ENTW]QTYPCU    (WLIG)        = LOLDQTYPCU
        [M:ENTW]QTYSTU    (WLIG)        = LOLDQTYSTU
    #--- End issue X3-89211
    Else
        If evalue("dim([M:"+LABR+"]"+[M:ENTW]WZONPCU+"(LLIG))") > 0
           [M:ENTW]PCU       (WLIG)        = evalue("[M:"+LABR+"]"+[M:ENTW]WZONPCU+"(LLIG)")
        Endif
        If evalue("dim([M:"+LABR+"]"+[M:ENTW]WZONCCS+"(LLIG))") > 0
           [M:ENTW]PCUSTUCOE (WLIG)        = evalue("[M:"+LABR+"]"+[M:ENTW]WZONCCS+"(LLIG)")
           #--- Bug 89131
           If [M:ENTW]WZONPCU="STU" [M:ENTW]PCUSTUCOE(WLIG)=1 Endif
        Endif
        [M:ENTW]QTYPCU    (WLIG)        = LTABQTY(I)
        [M:ENTW]QTYSTU    (WLIG)        = LTABQTY(I)*[M:ENTW]PCUSTUCOE (WLIG)
    Endif
    Call QTEARR([M:ENTW]QTYSTU(WLIG), [F:ITM]STU) From TRTDIV

    #--- par sécurité, on efface GESLOT si le lot est renseigné ---#
    If evalue("dim([M:"+LABR+"]GESLOT)") > 0 & evalue("dim([M:"+LABR+"]LOT)") > 0 & evalue("[M:"+LABR+"]LOT(LLIG)")<>""
        Assign "[M:"+LABR+"]GESLOT(LLIG)" With ""
    Endif
# On affecte un complément lot ssi
# -pas de réception à quai
    Raz [F:TLO]    # Il faut se positionner correctement avant de tester: il y a des cas où on n'est pas forcément bon
    If evalue("dim([M:"+LABR+"]LOCTYP(LLIG))") > 0
        Read [TLO]TLO0=LFCY;evalue("[M:"+LABR+"]LOCTYP(LLIG)")
    Endif

    #--- Issue X3-58974 : si GPE=1 le lot sera affecté si emp quai
    GPE=0
    GPOINT="AFFECT_LOT"
    Gosub ENTREE From EXEFNC
    If GPE<>1
    #---
      #--- Issue 119655
      # On efface GESLOT s'il est différent de "" et si emplacement en attente de rangement (car sinon il sera affecté)
      If [F:TLO]LOCCAT=2 & evalue("dim([M:"+LABR+"]GESLOT)") > 0 & evalue("[M:"+LABR+"]GESLOT(LLIG)")<>""
        #--- Issue X3-53322
        # Et s'il n'y a pas de gestion de LPN ou pas de LPN renseigné et le LPN est facultatif
        If evalue("dim([M:"+LABR+"]LPNNUM)")<0 | [F:ITF]LPNMGTCOD<>2 |
&         (evalue("dim([M:"+LABR+"]LPNNUM)")>=0 & evalue("[M:"+LABR+"]LPNNUM(LLIG)")="" & [F:SRU]DACCTR<>2)
        #---
          Assign "[M:"+LABR+"]GESLOT(LLIG)" With ""
        #--- Issue X3-53322
        Endif
        #---
      Endif
      #---
    #--- Issue X3-58974
    Endif

    #--- Issue X3-53322
#    If evalue("dim([M:"+LABR+"]LOT(LLIG))") > 0 & !([F:TLO]LOCCAT=2
#&      & evalue("dim([M:"+LABR+"]GESLOT(LLIG))") > 0 & evalue("[M:"+LABR+"]GESLOT(LLIG)")="" & evalue("[M:"+LABR+"]LOT(LLIG)")=""
#&      & evalue("dim([M:"+LABR+"]BPSLOT(LLIG))") > 0 & evalue("[M:"+LABR+"]BPSLOT(LLIG)")="")
    If evalue("dim([M:"+LABR+"]LOT(LLIG))") > 0
      If evalue("[M:"+LABR+"]GESLOT(LLIG)")<>""
&      | evalue("[M:"+LABR+"]LOT(LLIG)")   <>""
&      | (evalue("dim([M:"+LABR+"]BPSLOT(LLIG))")>0 & evalue("[M:"+LABR+"]BPSLOT(LLIG)")<>"")
&      |  [F:TLO]LOCCAT<>2
&      | ([F:TLO]LOCCAT =2 & (evalue("dim([M:"+LABR+"]LPNNUM)")>=0 & evalue("[M:"+LABR+"]LPNNUM(LLIG)")<>"" | ([F:ITF]LPNMGTCOD=2 & [F:SRU]DACCTR=2)))
    #--- End issue X3-53322
        If (evalue("[M:"+LABR+"]GESLOT(LLIG)")="C" | evalue("[M:"+LABR+"]LOT(LLIG)")<>"") & ([F:ITM]LOTMGTCOD=2 | [F:ITM]LOTMGTCOD=3)
          Raz LSLO
        Endif

        # On récupère directement l'ancien cpt lot seulement pour la 1ère ligne de détail
        # et si le lot est un compteur
        If evalue("dim([M:"+LABR+"]GESLOT(LLIG))") > 0
&        & evalue("[M:"+LABR+"]GESLOT(LLIG)") = "C"
&        & WSUP>0
&        & [M:ENTW]NUMLIGLOT(WSUP-1) > 0
&        & [M:ENTW]GESLOT([M:ENTW]NUMLIGLOT(WSUP-1)) = "C"
&        & I=0
            [M:ENTW]NUMLIGLOT(WLIG) = [M:ENTW]NUMLIGLOT(WSUP-1)
            If evalue("dim([M:"+LABR+"]BPSLOT)")>0
                [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(WLIG)) = evalue("[M:"+LABR+"]BPSLOT(LLIG)")
            Endif

#                                                      # hcb 71276 deb

            If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
                [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(WLIG)) = evalue("[M:"+LABR+"]ECCVALMAJ(LLIG)")
            Endif
            If evalue("dim([M:"+LABR+"]ECCVALMIN)")>0
                [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(WLIG)) = evalue("[M:"+LABR+"]ECCVALMIN(LLIG)")
            Endif
            If evalue("dim([M:"+LABR+"]ECCSAIFLG)")>0
                [M:ENTW]ECCSAIFLG([M:ENTW]NUMLIGLOT(WLIG)) = evalue("[M:"+LABR+"]ECCSAIFLG(LLIG)")
            Endif
            If evalue("dim([M:"+LABR+"]SLO)")>0
                [M:ENTW]SLO([M:ENTW]NUMLIGLOT(WLIG))    = LSLO
            Endif
        Elsif evalue("dim([M:"+LABR+"]BPSLOT(LLIG))") > 0
            Call SETCPTLOTAUTO ( evalue("[M:"+LABR+"]ITMREF(LLIG)"),
&                                "ENTW", WLIG,
&                                evalue("[M:"+LABR+"]LOT(LLIG)"),
&                                LSLO,
&                                evalue("[M:"+LABR+"]BPSLOT(LLIG)"),
&                                evalue("[M:"+LABR+"]GESLOT(LLIG)"),
&                                LMAJ,
&                                LMIN,
&                                LECC,
&                                LRET)
        Else
            #--- Issue 85577 by TS
            LBPSLOT=""
            Read [STL]STL0=evalue("[M:"+LABR+"]ITMREF(LLIG)");evalue("[M:"+LABR+"]LOT(LLIG)");LSLO
            If !fstat LBPSLOT=[F:STL]BPSLOT Endif
            # Remplacement de "" par LBPSLOT
            Call SETCPTLOTAUTO ( evalue("[M:"+LABR+"]ITMREF(LLIG)"),
&                                "ENTW", WLIG,
&                                evalue("[M:"+LABR+"]LOT(LLIG)"),
&                                LSLO,
&                                LBPSLOT,
&                                evalue("[M:"+LABR+"]GESLOT(LLIG)"),
&                                LMAJ,
&                                LMIN,
&                                LECC,
&                                LRET)
            #---
        Endif

        GOUVENT = GOUVENT-mod(GOUVENT,2)+LRET-1
        If evalue("dim([M:"+LABR+"]SLO(LLIG))") > 0  & [F:ITM]LOTMGTCOD=4 & LSLO<>""
            If I<LNB-1
                Call PLUS_UN(LSLO, LSLO, LRET) From STKLIB
                If LRET
                    LWRNSLO = 1
                Endif
            Endif
        Endif
      #--- Issue X3-53322
      Endif
    Else
        [M:ENTW]NUMLIGLOT(WLIG) = -1
    Endif

    [M:ENTW]SAIACTFLG(WLIG) = 1+(LTRS=19 & [F:ITF]STOMGTCOD>2)

    If evalue("dim([M:"+LABR+"]STOCOU(LLIG))") > 0
            [M:ENTW]STOCOU    (WLIG)        = evalue("[M:"+LABR+"]STOCOU(LLIG)")
    Endif
    If evalue("dim([M:"+LABR+"]SERNUM(LLIG))") > 0
            If dim([M:ENTW]SERNUM(WLIG)) > 0
               [M:ENTW]SERNUM    (WLIG)        = evalue("[M:"+LABR+"]SERNUM(LLIG)")
            Endif
    Endif
    If [F:ITM]SERMGTCOD > 1          # hcb 32069
       If evalue("dim([M:"+LABR+"]SERNUMF(LLIG))") > 0
          If dim([M:ENTW]SERNUMF(WLIG)) > 0
# Dans le cas des retours clients sur livraison, on peut saisir tous les champs sauf le lot et le n° de série.
# Mais on ne peut pas choisir automatiquement les n° de série si la quantité est diminuée => il faut les conserver
#            [M:ENTW]SERNUMF   (WLIG)        = evalue("[M:"+LABR+"]SERNUMF(LLIG)")
             Call PLUS_NB([M:ENTW]SERNUM(WLIG),[M:ENTW]QTYSTU(WLIG),[M:ENTW]SERNUMF(WLIG),LRET) From STKLIB
          Endif
       Endif
    Endif                            # hcb 32069
    If evalue("dim([M:"+LABR+"]STA(LLIG))") > 0
            [M:ENTW]STA       (WLIG)        = evalue("[M:"+LABR+"]STA(LLIG)")
    Endif

    If evalue("[F:"+LTABTRS+"]PRNCOD1")>1
        If evalue("[F:"+LTABTRS+"]PRNNBFLG1")<>2
            #--- Bug 59444 puis 62071 (remplacement de LLIG par WLIG)
            #[M:ENTW]LBENBR(LLIG) = LTABQTY(I)
            If int(LTABQTY(I)) = LTABQTY(I)
               [M:ENTW]LBENBR(WLIG) = LTABQTY(I)
            Else
               [M:ENTW]LBENBR(WLIG) = int(LTABQTY(I))+1
            Endif
            #---
        Endif
        If evalue("dim([M:"+LABR+"]LBENBR)") > 0
              [M:ENTW]LBENBR    (WLIG)        = evalue("[M:"+LABR+"]LBENBR")
        Else
           If [M:ENTW]LBEFMT    (WLIG) <> ""
              #--- Bug 59444 puis 62071 (remplacement de LLIG par WLIG)
              #[M:ENTW]LBENBR(LLIG) = LTABQTY(I)
              If int(LTABQTY(I)) = LTABQTY(I)
                 [M:ENTW]LBENBR(WLIG) = LTABQTY(I)
              Else
                 [M:ENTW]LBENBR(WLIG) = int(LTABQTY(I))+1
              Endif
              #---
           Endif
        Endif
        If evalue("dim([M:"+LABR+"]LBEFMT)") > 0
            [M:ENTW]LBEFMT    (WLIG)        = evalue("[M:"+LABR+"]LBEFMT")
        Else
            #--- Bug 81757 TS
            #Call CTLUOM ([M:ENTW]ITMREF(WLIG), 3, "", [M:ENTW]PCU(WLIG),PCOE, LUSCAV, PLBEFMT, LMODIF) From STKACT
            Call CTLUOM ([M:ENTW]ITMREF(WLIG), 3, LBPS, [M:ENTW]PCU(WLIG),PCOE, LUSCAV, PLBEFMT, LMODIF) From STKACT
            #---
            If LUSCAV <> "S"
               If LUSCAV <> "C"
                  Raz GMESSAGE
                  Raz GERR
                  [M:ENTW]PCU      (WLIG) = [F:ITM]STU
                  [M:ENTW]PCUSTUCOE(WLIG) = 1
                  [M:ENTW]QTYPCU   (WLIG) = [M:ENTW]QTYSTU(WLIG)
                  [M:ENTW]QTYPCU   (WLIG) = [M:ENTW]QTYSTU(WLIG)
                  PLBEFMT                 = [F:ITM]STULBEFMT
               Endif
            Endif
            [M:ENTW]LBEFMT    (WLIG) = PLBEFMT
        Endif
    Endif

    If evalue("dim([M:"+LABR+"]PALNUM)") > 0
            [M:ENTW]PALNUM    (WLIG)       = evalue("[M:"+LABR+"]PALNUM(LLIG)")     # hcb 27200
    Elsif WSUP>0
            [M:ENTW]PALNUM    (WLIG)       = [M:ENTW]PALNUM(WSUP-1)
    Endif
    If evalue("dim([M:"+LABR+"]CTRNUM)") > 0
            [M:ENTW]CTRNUM    (WLIG)       = evalue("[M:"+LABR+"]CTRNUM(LLIG)")     # hcb 27200
    Elsif WSUP>0
            [M:ENTW]CTRNUM    (WLIG)       = [M:ENTW]CTRNUM(WSUP-1)
    Endif
    If evalue("dim([M:"+LABR+"]LBEFMT)") > 0
            [M:ENTW]LBEFMT    (WLIG)       = evalue("[M:"+LABR+"]LBEFMT(LLIG)")     # hcb 27200
    Elsif WSUP>0
            [M:ENTW]LBEFMT    (WLIG)       = [M:ENTW]LBEFMT(WSUP-1)
    Endif
    If WSUP>0
            [M:ENTW]STOCOU    (WLIG)       = [M:ENTW]STOCOU(WSUP-1)
    Endif
    #--- Issue 53322
    If evalue("dim([M:"+LABR+"]LPNNUM)") > 0
            [M:ENTW]LPNNUM    (WLIG)       = evalue("[M:"+LABR+"]LPNNUM(LLIG)")
    Elsif WSUP>0
            [M:ENTW]LPNNUM    (WLIG)       = [M:ENTW]LPNNUM(WSUP-1)
    Endif
    If evalue("dim([M:"+LABR+"]TCTRNUM)") > 0
            [M:ENTW]TCTRNUM    (WLIG)       = evalue("[M:"+LABR+"]TCTRNUM(LLIG)")
    Elsif WSUP>0
            [M:ENTW]TCTRNUM    (WLIG)       = [M:ENTW]TCTRNUM(WSUP-1)
    Endif
    #                                                               # hcb X3-64504 deb

   If evalue("dim([M:"+LABR+"]LPNNUM)") > 0
       Call CALCUL_NBLPN([M:ENTW]LPNNUM(WLIG),[M:ENTW]TCTRNUM(WLIG),[M:ENTW]ITMREF(WLIG),LFCY,[M:ENTW]PCU(WLIG),[M:ENTW]QTYPCU(WLIG),LNBLPN) From STKLPN
      [M:ENTW]NBLPN(WLIG) = LNBLPN
   Endif
#                                                               # hcb X3-64504 deb

    #---

#recuperation demande analyse du fichier SRU
    If left$([M:ENTW]STA(WLIG),1)="Q"
        [M:ENTW]QLYCTLFLG (WLIG)        = [F:SRU]QLYCTLFLG
    Else
        [M:ENTW]QLYCTLFLG (WLIG)        = 1
    Endif

    #---- On traite les emplacements en dernier car s'il y a overflow sur -------#
    #---- l'emplacement, on copie la ligne avec la quantité en trop        -------#
    If [F:ITF]LOCMGTCOD=2
        If evalue("dim([M:"+LABR+"]LOCTYP(LLIG))") > 0
                [M:ENTW]LOCTYP    (WLIG)        = evalue("[M:"+LABR+"]LOCTYP(LLIG)")
        Endif
        If evalue("dim([M:"+LABR+"]LOC(LLIG))") > 0
                [M:ENTW]LOC       (WLIG)        = WLOC
        Endif
        If evalue("dim([M:"+LABR+"]WRH(LLIG))") > 0
                If evalue("[M:"+LABR+"]WRH(LLIG)") <> ""
                   [M:ENTW]WRH(WLIG) = evalue("[M:"+LABR+"]WRH(LLIG)")
                   # Contrôle emplacement par rapport au dépôt
                   Read [STC]STC0=LFCY;WLOC
                   If fstat | [F:STC]WRH<>[M:ENTW]WRH(WLIG)
                     Raz [M:ENTW]LOC(WLIG)
                     GOUVENT = GOUVENT-mod(GOUVENT,32)+mod(GOUVENT,16)+16
                   Endif
                Else
                   Read [STC]STC0=LFCY;WLOC
                   If !fstat [M:ENTW]WRH(WLIG)=[F:STC]WRH Endif
                Endif
        Endif

        If I=0
          If evalue("[M:"+LABR+"]WLOCSEQ(LLIG)")>100000
            [M:ENTW]WLOCSEQ(WLIG) = evalue("[M:"+LABR+"]WLOCSEQ(LLIG)")-100000
          Else
            [M:ENTW]WLOCSEQ(WLIG) = evalue("[M:"+LABR+"]WLOCSEQ(LLIG)")
          Endif
        Else
          Call STKWLOCSEQ("ENTW", WLIG, LRET) From STKECR
        Endif
        # Récupération de l'emplacement par défaut de l'art-site pour le type mouvement
        Call STKSUGEMP([M:ENTW]WLOCSEQ(WLIG),LTRS,LTRSCOD,LFCY,
&                      evalue("[M:"+LABR+"]ITMREF(LLIG)"),[M:ENTW]PCU(WLIG),
&                      [M:ENTW]QTYPCU(WLIG),[M:ENTW]STA(WLIG),[M:ENTW]LOCTYP(WLIG),
&                      [M:ENTW]LOC(WLIG),"","QU","",[M:ENTW]WRH(WLIG)) From STKLOC

        Call STKDELRES([M:ENTW]WLOCSEQ(WLIG), LFCY,"",LRET) From STKLOC

        Call STKCTRTLO([M:ENTW]WLOCSEQ(WLIG),LTRS,LTRSCOD,LFCY,
&                      evalue("[M:"+LABR+"]ITMREF(LLIG)"),[M:ENTW]PCU(WLIG),
&                      [M:ENTW]QTYPCU(WLIG),[M:ENTW]STA(WLIG),0,[M:ENTW]LOCTYP(WLIG),
&                      WRET,"","",[M:ENTW]WRH(WLIG)) From STKLOC

        # S'il y a des erreurs on continue quand même de remplir, mais il faudra ouvrir la fenêtre de détail
        If WRET
            GOUVENT = GOUVENT-mod(GOUVENT,32)+mod(GOUVENT,16)+16
        Endif
        Call STKCTREMP([M:ENTW]WLOCSEQ(WLIG),LTRS,LTRSCOD,LFCY,
&                      evalue("[M:"+LABR+"]ITMREF(LLIG)"),[M:ENTW]PCU(WLIG),
&                      [M:ENTW]QTYPCU(WLIG),[M:ENTW]STA(WLIG),[M:ENTW]LOCTYP(WLIG),
&                      [M:ENTW]LOC(WLIG),LBPS,0,WRET,WOVF,"","",[M:ENTW]WRH(WLIG))
&                      From STKLOC

        [M:ENTW]WLOCSEQCUR = 99999999    # Variable utilisée en cas d'"echap", car on n'a pas la main pour déréserver
        # S'il y a des erreurs on continue quand même de remplir, mais il faudra ouvrir la fenêtre de détail
        If WRET
            GOUVENT = GOUVENT-mod(GOUVENT,32)+mod(GOUVENT,16)+16
            Raz WLOC
            If WLOC <>"" & WOVF>=[M:ENTW]QTYPCU(WLIG)
                [M:ENTW]LOC(WLIG) = ""
            Elsif WOVF>0
                [M:ENTW]QTYPCU(WLIG+1) = WOVF
                [M:ENTW]LOC   (WLIG+1) = ""
                #--- Issue 117545
                #Call COPYENTWLIG(WLIG, WLIG+1, "QPCU,EMP", LTRS, LTRSCOD, LFCY, LBPS)
                Call COPYENTWLIG(WLIG, WLIG+1, "QPCU,EMP", LTRS, LTRSCOD, LFCY, LBPS) From STKENTA
                #---
                WLIG += 1
                [M:ENTW]NBLIG   += 1
            Endif
        Elsif [M:ENTW]WRH(WLIG)=""
            # Lecture emplacement pour alimentation dépôt
            Read [STC]STC0=LFCY;[M:ENTW]LOC(WLIG)
            If !fstat [M:ENTW]WRH(WLIG)=[F:STC]WRH Endif
        Endif
    Endif

    # Transfert zones d'une ligne de document vers l'écran STOENTW
    GPOINT="DOC_ENTW" : Gosub ENTREE From EXEFNC

    WLIG += 1
Next


If LWRNSLO
    Call MESSAGE (mess(724,196,1)) From GESECRAN  # Saisie des numéros de /s lot incorrect
Endif
End

#--- Issue 117545
# Passage de COPYENTWLIG dans STKENTA
# Subprog COPYENTWLIG( PFROM, PTO, PFIELDEX, PTRS, PTRSCOD, PFCY, PBPS)
#---

#########################################################################
# LOAD_FROM_ENTW    Chargement restitution ligne document
#                   à partir de STOENTW
#########################################################################
Subprog LOAD_FROM_ENTW( LABR, LLIGDOC, LFCY, LWSTOSEQ, LITMREF, LTYPORI )
Value Char    LABR
Value Integer LLIGDOC
Value Char    LFCY
Value Integer LWSTOSEQ
Value Char    LITMREF
Value Integer LTYPORI

Local Decimal LQTY
Local Char    LSTA(GLONSTA)
Local Char    LLOF(GLONLOT)
Local Char    LLOT(GLONLOT)
Local Char    LGESLOT(1)
Local Integer LNBSLO
Local Char    LSLO(GLONSLO)
Local Char    LSLOF(GLONSLO)
Local Char    LLOCTYP(GLONTLO)
Local Char    LLOC(GLONLOC)
Local Char    LWRH(GLONWRH)
Local Char    LSER(GLONSER)
Local Char    LSERF(GLONSER)
Local Char    LPCU(GLONUOM)
Local Char    LPAL(GLONPAL)       # hcb 27200
Local Char    LCTR(GLONCTR)       # hcb 27200
Local Char    LMAJ(GLONECS)
Local Char    LMIN(GLONECS)
Local Integer LECC
#--- Issue 53322
Local Char    LLPN(GLONLPN)
Local Char    LTCTR(GLONTCTR)
#---
Local Integer I : I=0
Local Integer LNBLIGDET
Local Integer LWLOCSEQ
# Regarde si, sur la ligne dont le detail vient d'etre modifie,
# le lot et/ou l'emplacement sont décomposés
# et/ou les numéros de séries sont discontinus...
If LWSTOSEQ <= 0
   End
Endif

Local Char LMSKCOU : LMSKCOU = func STKLIB.MSKDEF

#--- Issue X3-53322 : ajout LLPN et LTCTR
Call RECSTO_M (LFCY,LWSTOSEQ,LITMREF,"",LWLOCSEQ,LQTY,LSTA,
&              LLOF,LLOT,LGESLOT,LNBSLO,LSLO,LSLOF,LLOCTYP,LLOC,
&              LSER,LSERF,LPCU,LNBLIGDET,LPAL,LCTR,LMAJ,LMIN,LLPN,LTCTR) From STKECR
If LNBLIGDET>0
    Default Mask "["+LABR+"]"    # Nécessaire pour être cohérent entre les "dim" et les *zo qui fonctionnent uniquement pour le masque courant

#------ Affectation + Grisage des champs stock de la ligne de document ------------#
    If evalue("dim([M:"+LABR+"]ITMREF)")>=0
        Diszo [M]ITMREF(LLIGDOC)
        Affzo [M]ITMREF(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]STA)")>=0
        [M]STA(LLIGDOC)     = LSTA
        If LNBLIGDET=1
            Actzo [M]STA(LLIGDOC)
        Else
            Diszo[M]STA(LLIGDOC)
        Endif
        Affzo [M]STA(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]PALNUM)")>=0
        [M]PALNUM(LLIGDOC)     = LPAL
        If LNBLIGDET=1
            Actzo [M]PALNUM(LLIGDOC)
        Else
            Diszo[M]PALNUM(LLIGDOC)
        Endif
        Affzo [M]PALNUM(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]CTRNUM)")>=0
        [M]CTRNUM(LLIGDOC)     = LCTR
        If LNBLIGDET=1
            Actzo [M]CTRNUM(LLIGDOC)
        Else
            Diszo[M]CTRNUM(LLIGDOC)
        Endif
        Affzo [M]CTRNUM(LLIGDOC)
    Endif

    If evalue("dim([M:"+LABR+"]BPSLOT)")>=0 & [F:ITM]LOTMGTCOD>1
        [M]BPSLOT(LLIGDOC)  = LLOF
        If varmode([M]BPSLOT,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]BPSLOT(LLIGDOC)
            Else
                Diszo [M]BPSLOT(LLIGDOC)
            Endif
        Endif
        Affzo [M]BPSLOT(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]LOT)")>=0 & [F:ITM]LOTMGTCOD>1
        [M]LOT(LLIGDOC)      = LLOT
        If varmode([M]LOT,LLIGDOC)<>1 & [F:SRU]DACLOT>1
            If LNBLIGDET=1
                Actzo [M]LOT(LLIGDOC)
            Else
                Diszo [M]LOT(LLIGDOC)
            Endif
        Endif
        Affzo [M]LOT(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]LOCTYP)")>=0 & [F:ITF]LOCMGTCOD=2
        [M]LOCTYP(LLIGDOC)   = LLOCTYP
        If varmode([M]LOCTYP,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]LOCTYP(LLIGDOC)
            Else
                Diszo [M]LOCTYP(LLIGDOC)
            Endif
        Endif
        Affzo [M]LOCTYP(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]LOC)")>=0 & [F:ITF]LOCMGTCOD=2
        [M]LOC(LLIGDOC)      = LLOC
        If varmode([M]LOC,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]LOC(LLIGDOC)
            Else
                Diszo [M]LOC(LLIGDOC)
            Endif
        Endif
        Affzo [M]LOC(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]WRH)")>0
        If [F:FCY]WRHGES=2
            #[M]WRH(LLIGDOC) = LWRH
            If varmode([M]WRH,LLIGDOC)<>1
                #--- Bug 77918
                # Une seule ligne, dépôt entête non obligatoire et pas désassemblage
                #If LNBLIGDET=1 & GWRHOBY<>2
                If LNBLIGDET=1 & GWRHOBY<>2 & LABR<>"DBY1" & LTYPORI<>32
                #---
                    Actzo WRH(LLIGDOC)
                Else
                    Diszo WRH(LLIGDOC)
                Endif
            Endif
        Else
            Raz [M]WRH(LLIGDOC) : Grizo WRH(LLIGDOC)
        Endif
    Endif
    If evalue("dim([M:"+LABR+"]SERNUM)")>=0 & [F:ITM]SERMGTCOD>1
        [M]SERNUM(LLIGDOC)  = LSER
        If varmode([M]SERNUM,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]SERNUM(LLIGDOC)
            Else
                Diszo [M]SERNUM(LLIGDOC)
            Endif
        Endif
        Affzo [M]SERNUM(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]SERNUMF)")>=0 & [F:ITM]SERMGTCOD>1
        [M]SERNUMF(LLIGDOC) = LSERF
        Affzo [M]SERNUMF(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]NBSLO)")>=0 & [F:ITM]LOTMGTCOD=4
        [M]NBSLO(LLIGDOC)   = LNBSLO
        If varmode([M]NBSLO,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]NBSLO(LLIGDOC)
            Else
                Diszo [M]NBSLO(LLIGDOC)
            Endif
        Endif
        Affzo [M]NBSLO(LLIGDOC)
    Endif

#                                                      # hcb 71276 deb

    If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>=0 & [F:ITM]ECCSTO > 1
        [M]ECCVALMAJ(LLIGDOC)  = LMAJ
        If varmode([M]ECCVALMAJ,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]ECCVALMAJ(LLIGDOC)
            Else
                Diszo [M]ECCVALMAJ(LLIGDOC)
            Endif
        Endif
        Affzo [M]ECCVALMAJ(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]ECCVALMIN)")>=0 & [F:ITM]ECCSTO =3
        [M]ECCVALMIN(LLIGDOC)  = LMIN
        If varmode([M]ECCVALMIN,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]ECCVALMIN(LLIGDOC)
            Else
                Diszo [M]ECCVALMIN(LLIGDOC)
            Endif
        Endif
        Affzo [M]ECCVALMIN(LLIGDOC)
    Endif
#                                                      # hcb 71276 deb

    If evalue("dim([M:"+LABR+"]SLO)")>=0 & [F:ITM]LOTMGTCOD=4
        [M]SLO(LLIGDOC)     = LSLO
        If varmode([M]SLO,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]SLO(LLIGDOC)
            Else
                Diszo [M]SLO(LLIGDOC)
            Endif
        Endif
        Affzo [M]SLO(LLIGDOC)
    Endif
    If evalue("dim([M:"+LABR+"]SLOF)")>=0 & [F:ITM]LOTMGTCOD=4
        [M]SLOF(LLIGDOC)    = LSLOF
        Affzo [M]SLOF(LLIGDOC)
    Endif

    [M]GESLOT(LLIGDOC)      = LGESLOT

    If evalue("dim([M:"+LABR+"]WLOCSEQ)")>=0
        [M]WLOCSEQ(LLIGDOC)     = LWLOCSEQ
    Endif

    #--- Issue X3-53322
    If evalue("dim([M:"+LABR+"]LPNNUM)")>=0 & [F:ITF]LPNMGTCOD=2
        [M]LPNNUM(LLIGDOC)  = LLPN
        [M]TCTRNUM(LLIGDOC) = LTCTR
        If varmode([M]LPNNUM,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]LPNNUM(LLIGDOC)
            Else
                Diszo [M]LPNNUM(LLIGDOC)
            Endif
        Endif
        If varmode([M]TCTRNUM,LLIGDOC)<>1
            If LNBLIGDET=1
                Actzo [M]TCTRNUM(LLIGDOC)
            Else
                Diszo [M]TCTRNUM(LLIGDOC)
            Endif
        Endif
        Affzo [M]LPNNUM(LLIGDOC)
        Affzo [M]TCTRNUM(LLIGDOC)
    Endif
    #---

Endif

Default Mask LMSKCOU

End


#########################################################################
# LOAD_FROM_ENTM    Chargement restitution ligne document à partir de STOENTM
#########################################################################
$LOAD_FROM_ENTM

Local Decimal LQTY
Local Char    LSTA(GLONSTA)
Local Char    LLOF(GLONLOT)
Local Char    LLOT(GLONLOT)
Local Char    LGESLOT(1)
Local Integer LNBSLO
Local Char    LSLO(GLONSLO)
Local Char    LSLOF(GLONSLO)
Local Char    LLOCTYP(GLONEMP)
Local Char    LLOC(GLONEMP)
Local Char    LWRH(GLONWRH)
Local Char    LSER(GLONSER)
Local Char    LSERF(GLONSER)
Local Char    LPCU(GLONUOM)
Local Char    LPAL(GLONPAL)
Local Char    LCTR(GLONCTR)
Local Char    LMAJ(GLONECS)
Local Char    LMIN(GLONECS)
#--- Issue 53322
Local Char    LLPN(GLONLPN)
Local Char    LTCTR(GLONTCTR)
#---
Local Integer LECC

Local Integer I : I=0
Local Integer LNBLIGDET
# Regarde si, sur la ligne dont le detail vient d'etre modifie,
# le lot et/ou l'emplacement sont décomposés
# et/ou les numéros de séries sont discontinus...
#--- Issue X3-53322 : ajout LLPN et LTCTR
Call RECSTO_ENM ([M:ENM]STOFCY,[M:ENM]ITMREF ,"", LQTY, LSTA,
&                LLOF, LLOT, LGESLOT, LNBSLO, LSLO, LSLOF, LLOCTYP, LLOC,
&                LSER, LSERF, LPCU, LNBLIGDET,LPAL,LCTR,LMAJ,LMIN,LLPN,LTCTR) From STKECR

Assign "[M:"+LABR+"]STA("+num$(LLIGDOC)+")"         With LSTA
If evalue("dim([M:"+LABR+"]BPSLOT)")>=0
    Assign "[M:"+LABR+"]BPSLOT("+num$(LLIGDOC)+")"  With LLOF
Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>=0
    Assign "[M:"+LABR+"]PALNUM("+num$(LLIGDOC)+")"  With LPAL
Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>=0
    Assign "[M:"+LABR+"]CTRNUM("+num$(LLIGDOC)+")"  With LCTR
Endif
Assign "[M:"+LABR+"]MVTDES("+num$(LLIGDOC)+")"      With [M:ENM]MVTDES
If evalue("dim([M:"+LABR+"]LOT)")>=0
   Assign "[M:"+LABR+"]LOT("+num$(LLIGDOC)+")"      With LLOT
   Assign "[M:"+LABR+"]GESLOT("+num$(LLIGDOC)+")"   With LGESLOT
Endif
If evalue("dim([M:"+LABR+"]LOC)")>=0
   Assign "[M:"+LABR+"]LOCTYP("+num$(LLIGDOC)+")"   With LLOCTYP
   Assign "[M:"+LABR+"]LOC("+num$(LLIGDOC)+")"      With LLOC
Endif
#If evalue("dim([M:"+LABR+"]WRH)")>=0
#   Assign "[M:"+LABR+"]WRH("+num$(LLIGDOC)+")"      With LWRH
#Endif
If evalue("dim([M:"+LABR+"]SERNUM)")>=0
   Assign "[M:"+LABR+"]SERNUM("+num$(LLIGDOC)+")"   With LSER
   Assign "[M:"+LABR+"]SERNUMF("+num$(LLIGDOC)+")"  With LSERF
Endif
#                                                      # hcb 71276 deb

If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>=0
   Assign "[M:"+LABR+"]ECCVALMAJ("+num$(LLIGDOC)+")"  With LMAJ
   Assign "[M:"+LABR+"]ECCVALMIN("+num$(LLIGDOC)+")"  With LMIN
Endif
#                                                      # hcb 71276 fin
#--- Issue X3-53322
If evalue("dim([M:"+LABR+"]LPNNUM)")>=0
   Assign "[M:"+LABR+"]LPNNUM("+num$(LLIGDOC)+")"   With LLPN
Endif
#---
If evalue("dim([M:"+LABR+"]SLO)")>=0
   Assign "[M:"+LABR+"]SLO("+num$(LLIGDOC)+")"      With LSLO
   Assign "[M:"+LABR+"]NBSLO("+num$(LLIGDOC)+")"    With LNBSLO
   Assign "[M:"+LABR+"]SLOF("+num$(LLIGDOC)+")"     With LSLOF
Endif

Default Mask "["+LABR+"]"
Affzo [M]

Return

########################################################################
# OUVENT        Controle ouverture fenetre saisie des entrées
#               Pour cela aliment les variables GOUVENT et GOUVLOT
########################################################################
# Paramètres E : LFCY     = site
#                LABR     = abréviation écran
#                LTRS     = type transaction (m704)
#                LTRSCOD  = code transaction particulière
#                LBPS     = tiers
#                LVCR     = type piece       (m701)
#                LDAT     = date imputation
#                LLIG     = n° de ligne dans le tableau de l'écran
#                LTAB     = Abréviation de la table de transactions
#                LSUP     = Option : "O"=Même si WSTOFLG=0, garder
#                                        ce qui se trouve déjà dans STOENTW (à utiliser avec précaution!!)
#                                    "A"=Chargement auto du tableau (pas de saisie en cours)
#            S : LRET     = Code retour : 0 = pas d'ouverture
#                                         1 = ouverture          lot
#                                         2 = ouverture détail
#                                         3 = ouverture détail & lot
#
# Prérequis    : Ces classes [F:] doivent être chargées ITMMASTER, ITMFACILIT
#                Les champs [M:ENTW]WZONxxx doivent être renseignés
#
########################################################################
Subprog OUVENT(LFCY,LABR,LTRS,LTRSCOD,LBPS,LVCR,LDAT,LLIG,LNBLIG,LTAB,LSUP, LRET)
Value    Char     LFCY
Value    Char     LABR
Value    Integer  LTRS
Value    Char     LTRSCOD
Value    Char     LBPS
Value    Integer  LVCR
Value    Date     LDAT
Value    Integer  LLIG
Value    Integer  LNBLIG
Value    Char     LTAB
Value    Char     LSUP
Variable Shortint LRET
Local    Integer  NBENTW
Local    Shortint WK
Local    Decimal  LQTYPRE
Local    Char     LABRMSK
Local    Integer  OUV_RET
Local    Integer  LLIGW
Local    Integer  LWSTOSEQ
LABRMSK  = "[M:"+LABR+"]"

Raz GOUVENT
Raz GOUVLOT
LRET = 0

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If [F:ITM]ITMREF<>evalue(LABRMSK+"ITMREF(LLIG)")
    Read [ITM]ITM0=evalue(LABRMSK+"ITMREF(LLIG)")
    If fstat : PRET = 2 : End : Endif
Endif

If [F:ITM]ITMREF<>[F:ITF]ITMREF | LFCY<>[F:ITF]STOFCY
      Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
Endif

# Sécurité : Si article non géré en stock, on n'ouvre rien.
If [F:ITF]STOMGTCOD=1
    End
Endif

#--- Issue 110327
If [F:ITM]SERMGTCOD>1 & fix(evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)"))<>evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)")
   Call ERREUR(mess(470,197,1)) From GESECRAN
   PRET=2 : End
Endif
#---

# hcb V6CQ freq  deb
If evalue("dim([M:"+LABR+"]QUAFRE)")>0 & evalue(LABRMSK+"QUAFRE(LLIG)") <> 0 & LABR <> "SSL1"
   Local Integer LQUA
   Call STKFREQCQ(LABR,LFCY,LLIG,[F:ITM]ITMREF,"","F",LQUA,evalue(LABRMSK+"QUAFRE(LLIG)")) From STKACT
   If !GOK
      End
   Endif
Endif
# hcb V6CQ freq  fin


LWSTOSEQ = evalue(LABRMSK+"WSTOSEQ(LLIG)")
# ADC
If dim(GSERIALADC)>0 & GSERIALADC<>"" & [M:ENTW]NBLIG<>0
   Local Integer I,J
   I=find(LWSTOSEQ,[M:ENTW]WSTOSEQ(0..[M:ENTW]NBLIG-1))
   If I<>0
      I-=1
      J =[M:ENTW]NBLIG
      #--- Issue 117545
      #Call COPYENTWLIG(I,J,"QPCU",LTRS,LTRSCOD,LFCY,LBPS)
      Call COPYENTWLIG(I,J,"QPCU",LTRS,LTRSCOD,LFCY,LBPS) From STKENTA
      #---
      [M:ENTW]SERNUM(J)   =GSERIALADC
      [M:ENTW]SERNUMF(J)  =GSERIALADCF
      [M:ENTW]QTYPCU(J)   =GQTYPCUADC
      [M:ENTW]PCUSTUCOE(J)=GPCUSTUADC
      [M:ENTW]QTYSTU(J)   =GQTYSTUADC
      [M:ENTW]NBLIG +=1
      End
   Endif
Endif
#---

If !instr(1,LSUP,"A")
  If !GIMPORT
    If adxgtb=1 | find(status,65,68,83)
        If LWSTOSEQ >0
            NBENTW = func STKENT.CAL_NBENTW(LWSTOSEQ)
        Endif
        If NBENTW=1 & [M:ENTW]WLOCSEQCUR>100000 | NBENTW=0
            Call STKDELRES([M:ENTW]WLOCSEQCUR, "", "", OUV_RET) From STKLOC
            [M:ENTW]WLOCSEQCUR = 99999999   # Variable utilisée en cas d'"echap", car on n'a pas la main pour déréserver
        Endif
#        mis en commentaire le 08/07/03 par LD
#        QTYSTU est raz si on est en modif d'une ligne de document et qu'on fait esc pour annuler la modif.
#        If evalue("dim("+LABRMSK+"QTYSTU(LLIG))")>0
#            Assign (LABRMSK+"QTYSTU(LLIG)") With 0
#        Endif
        End
    Endif
  Endif
Endif
# enregistrement deja créé ?
#      test sur l existence creflg rajouté pour le plan de rangement
If evalue("dim([M:"+LABR+"]CREFLG(LLIG))") >= 0
    # Dans WZONSTOUPD, se trouve le nom du champ (facultatif) qui indique la valeur complémentaire à prendre en compte
    # lors des tests sur CREFLG : test= (CREFLG=0 | ZONSTOUPD>0)
    If evalue(LABRMSK+"CREFLG(LLIG)")>0  & !([M:ENTW]WZONSTOUPD<>"" & evalue(LABRMSK+[M:ENTW]WZONSTOUPD+"(LLIG)")>0)
        End
    Endif
Endif

If evalue(LABRMSK+"ITMREF(LLIG)") = ""
   Assign LABRMSK+"WSTOFLG(LLIG)" With 2
   End
Endif

#--- Issue X3-53322
Local Integer WRET
Call LECSRU(LFCY,[F:ITM]TCLCOD,LTRS,LTRSCOD,"",WRET) From STKLIB
If WRET=1 End Endif
#---

#----------------- Calcul de GOUVENT et de GOUVLOT ------------------#
#----------------- Remplissage de STOENTW si nécessaire -------------#
Call INIT_GOUVLOT(LTAB) From STKENT
If LABR = "SSL1"
   If [M:SSL1]QTYSTU(LLIG) > [M:SSL1]QTYSTUORI(LLIG)
      GOUVENT = 64
   Endif
Endif
NBENTW = func STKENT.CAL_NBENTW( LWSTOSEQ )
If  NBENTW>1  | instr(1,LSUP,"O")                                         # hcb X3-89211 tst
    # On teste un changement de quantité
    # car elle seule est modifiable s'il n'y a qu'une seule ligne de détail
    LQTYPRE = sigma (I=0,[M:ENTW]NBLIG,[M:ENTW]QTYSTU(I)*([M:ENTW]WSTOSEQ(I)=LWSTOSEQ))
    If LQTYPRE=evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)")
        If [M:ENTW]WZONSTOUPD<>"" & evalue(LABRMSK+[M:ENTW]WZONSTOUPD+"(LLIG)")>0 & evalue(LABRMSK+"UPDFLG(LLIG)")=0
            End
        Else
            #CCC:23/09/03 Je ne vois pas à quoi ça sert, par contre il vaut mieux faire End
            #HCB:300606 voici la reponse : 36782
             If evalue("dim("+LABRMSK+"NBSLO(LLIG))")>0
                If evalue(LABRMSK+"NBSLO(LLIG)") > 1
                   Call CTR_COHERENCE_LIG(LABR, LFCY, LLIG, LVCR, LRET)
                   GOUVENT = LRET
                Endif
            Endif
            End
        Endif
    Endif
    # Si la quantité est modifiée et le nombre de lignes de détails > 1 on ouvre la fenêtre détail
    If LQTYPRE<>evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)")
        GOUVENT = 64
    Endif
Else
    #--- Issue 109115
    # Une seule  ligne de stock
    If NBENTW=1
      #--- Issue 111564 by TS
      If evalue(LABRMSK+"WSTOFLG(LLIG)")=1
      #--- End issue 111564
        I=find(LWSTOSEQ,[M:ENTW]WSTOSEQ(0..[M:ENTW]NBLIG-1))
        LQTYPRE = [M:ENTW]QTYSTU(I-1)
        #--- Issue 111450 by TS
        GPOINT="RECHARGE_STOENTW" : GPE=0
        Gosub ENTREE From EXEFNC
        If GPE=1
          LQTYPRE=0 : GPE=0
        Endif
        #--- End issue 111450
        #--- Issue 111146 by TS
        If LQTYPRE=0    # On efface tout et on recharge STOENTW
          Assign LABRMSK+"WSTOFLG(LLIG)" With 0
				#--- Issue 113851
        ## Si la nouvelle quantité est supérieure on ouvre la fenêtre détail
        ##If evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)") > LQTYPRE
        # Elsif evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)") > LQTYPRE
        ##---  End issue 111146
        #   GOUVENT = 64
        ## Sinon si on diminue la quantité dans STOENTW
        ##--- Issue 112589 by TS
        ##Else
        # Elsif evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)") < LQTYPRE
        Elsif evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)") <> LQTYPRE
        #--- End issue 113851
          If [M:ENTW]QTYPCU(I-1)=[M:ENTW]QTYSTU(I-1)
            [M:ENTW]QTYSTU(I-1) = evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)")
            [M:ENTW]QTYPCU(I-1)=[M:ENTW]QTYSTU(I-1)
          Else
            [M:ENTW]QTYSTU(I-1) = evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)")
            [M:ENTW]QTYPCU(I-1)=[M:ENTW]QTYSTU(I-1)/[M:ENTW]PCUSTUCOE(I-1)
            Call QTEARR([M:ENTW]QTYPCU(I-1),[M:ENTW]PCU(I-1)) From TRTDIV
          Endif
          #--- Issue 112654 by TS
          #End
          #---
        Endif
      #--- Issue 111564 by TS
      Endif
      #--- End issue 111564
    Endif
    #If NBENTW=1    # On efface tout et on recharge STOENTW
    #    Assign LABRMSK+"WSTOFLG(LLIG)" With 0
    #Endif
    #--- End issue 109115
Endif

If GOUVENT > 1
    If evalue(LABRMSK+"WSTOFLG(LLIG)")=1 | instr(1,LSUP,"O")
        Assign LABRMSK+"WSTOFLG(LLIG)" With 0
        End
    Else
        If GOUVENT = 64 & LABR <> "SSL1"  # hcb 39343
           End                            # hcb 39343
        Else                              # hcb 39343
          Goto SUIT10
        Endif                             # hcb 39343
    Endif
Endif


#--- 81757
# Si l unite n est pas l unite de stock ou ne fait pas partie des conditionnements = ouverture
#If evalue("dim([M:"+LABR+"]"+[M:ENTW]WZONPCU+"(LLIG))") >= 0
#   If evalue(LABRMSK+[M:ENTW]WZONPCU+"(LLIG)")<>[F:ITM]STU
#      WK=find(evalue(LABRMSK+[M:ENTW]WZONPCU+"(LLIG)"),[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
#      If WK = 0
#         GOUVENT = 512
#      Endif
#   Endif
# Ce qui suit doit être inutile... CCC 02/10/03
#Elsif evalue("dim([M:"+LABR+"]UOM(LLIG))") >= 0
#   If evalue(LABRMSK+"UOM(LLIG)")<>[F:ITM]STU
#      WK=find(evalue(LABRMSK+"UOM(LLIG)"),[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
#      If WK = 0
#         GOUVENT = 512
#      Endif
#   Endif
#Endif
#---

# hcb 34084
If evalue(LABRMSK+[M:ENTW]WZONQUS+"(LLIG)") = 0
   GOUVENT = 512
Endif
# hcb 34084


If GOUVENT > 1
    Goto SUIT10
Endif
If evalue("dim("+LABRMSK+"LOCTYP(LLIG))")>0 & ( [F:TLO]LOCTYP<>evalue(LABRMSK+"LOCTYP(LLIG)") | [F:TLO]STOFCY<>LFCY )
    Read [TLO]TLO0=LFCY;evalue(LABRMSK+"LOCTYP(LLIG)")
Endif
Call CTR_COHERENCE_LIG(LABR, LFCY, LLIG, LVCR, LRET)
#--- Issue X3-53322
#If mod(LRET,2048)>=1024                             # 38647
If mod(mod(LRET,4096),2048)>=1024
#---
    Call MESSAGE(mess(67,184,1)) From GESECRAN
Endif
GOUVENT = LRET

If mod(GOUVENT,2)=1    # Si l'ouverture du complément lot est possible
   If GOUVLOT=0    # Aucun champ dans complément lot n'est à saisir => on n'ouvre pas la fenêtre
      GOUVENT -=1
   Endif
# L'ouverture du complément lot devrait être auto (==> 1er bit de GOUVLOT à 1)
   GOUVLOT = GOUVLOT+1
Endif
# inutile car le contrôle se fait dans la fenêtre de sétail
#If GOUVLOT>1 & mod(GOUVENT,256)>=128
#   Call MESSAGE(mess(5, 184, 1)) From GESECRAN # Attention! Ne pas oublier de renseigner le complément lot
#Endif

$SUIT10

Default Mask "["+LABR+"]"

#Affzo [M]
If evalue("dim("+LABRMSK+"WSTOFLG)")>LLIG
    Assign LABRMSK+"WSTOFLG(LLIG)" With !(GOUVENT>1)
Endif
Call STKFILLENTW(LFCY,LABR,LTRS,LTRSCOD,LBPS,LVCR,LDAT,LLIG,LNBLIG,LTAB)
#                                                      # hcb 71276 deb

If [F:ITM]ECCSTO > 1 & evalue("dim([M:"+LABR+"]ECCVALMAJ(LLIG))") >= 0
# si le lot est un lot blanc pas d affectation des versions
   If evalue(LABRMSK+"ECCVALMAJ(LLIG)") = ""
      If GVTMOD<>1 GOUVLOT += 256 Endif
   Endif
   If [F:ITM]ECCSTO = 3 & evalue(LABRMSK+"ECCVALMIN(LLIG)") = ""
       If GVTMOD<>1 GOUVLOT += 256 Endif
   Endif
Endif
#                                                      # hcb 71276 fin

If GOUVENT < 2
    Assign LABRMSK+"WSTOFLG(LLIG)" With 1
    If [M:ENTW]NBLIG>0 & [M:ENTW]NUMLIGLOT([M:ENTW]NBLIG-1)>=0
        If [M:ENTW]VALIDE([M:ENTW]NUMLIGLOT([M:ENTW]NBLIG-1))=2
            GOUVLOT = 1
        Endif
    Endif
    If func CAL_NBENTW(evalue(LABRMSK+"WSTOSEQ(LLIG)")) > 1
        Default Mask "["+LABR+"]"
        Call STKDISLIG( LLIG ) From STKECR
    Endif
Else
    Assign LABRMSK+"WSTOFLG(LLIG)" With 0
Endif

#                                                      # hcb 71276 deb

If (LABR = "PTH1" | LABR = "SRH1") & [F:ITM]ECCSTO > 1 &  evalue("dim("+LABRMSK+"ECCVALMAJ)")>0 & GREP <> "M" &
&                                    evalue(LABRMSK+"ECCVALMAJ(LLIG)") = "" &
&                                    [M:ENTW]NUMLIGLOT(LLIG)>0
    Assign LABRMSK+"ECCVALMAJ(LLIG)" With [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(LLIG))
    Assign LABRMSK+"ECCVALMIN(LLIG)" With [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(LLIG))
    Assign LABRMSK+"ECCSAIFLG(LLIG)" With [M:ENTW]ECCSAIFLG([M:ENTW]NUMLIGLOT(LLIG))

Endif
#                                                      # hcb 71276 fin

End

########################################################################
# CAL_NBENTW   : Indique s'il exite plusieurs lignes de détail
#                pour une ligne de document
#
# Paramètres E : PWSTOSEQ = Valeur WSTOSEQ à rechercher
#                LRET     = Code retour : 0 = pas de détail
#                                         1 = une seule ligne de détail
#                                         2 = plusieurs lignes de détails
########################################################################
Funprog CAL_NBENTW ( PWSTOSEQ )
Value    Integer PWSTOSEQ

If PWSTOSEQ=0 : End 0 : Endif

End sigma(0,[M:ENTW]NBLIG-1,[M:ENTW]WSTOSEQ(indcum)=PWSTOSEQ)




###############################################################################
# STKINIBTN : Active ou non les boutons communs:
#                    - "Détails" : Affiché si CREFLG=0
#                    - "Modification détails" : Affiché si CREFLG<>0 et GREP<>"M"
#                    - "Info Lot" : Affiché si WSTOSEQ>0 et
#                         ( lot renseigné unique ou lot=compteur ou = n° pièce )
#                    - "Complément lot" : idem "Info lot"
#                         et transaction permet de saisir le complément
###############################################################################
# Paramètres E : PBTNDET  = Numéro du bouton "Détails" (0 si pas de bouton)
#                PBTNMOD  = Numéro du bouton "Modifications" (0 si pas de bouton)
#                PBTNINF  = Numéro du bouton "Info lot" (0 si pas de bouton)
#                PBTNCOMP = Numéro du bouton "Complément lot" (0 si pas de bouton)
#                PABR     = Abréviation de l'écran
#                PTABTRS  = Abréviation de la table transaction du document
#                PITM     = Article
#                PFCY     = Societe
#
# Prérequis : On considère que la variable nolign correspond
#              au numéro de ligne concerné
#             La table PTABTRS doit être positionnée
###############################################################################
Subprog STKINIBTN(PBTNDET, PBTNMOD, PBTNINF, PBTNCOMP, PABR, PTABTRS, PITM, PFCY)
Value Integer PBTNDET
Value Integer PBTNMOD
Value Integer PBTNINF
Value Integer PBTNCOMP
Value Char    PABR
Value Char    PTABTRS
Value Char    PITM
Value Char    PFCY

    If PITM<>"" & [F:ITM]ITMREF<>PITM
       Read [ITM]ITM0=PITM
       If fstat Call RSTA("ITM",PITM) From GLOCK Endif
    Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
    If [F:ITF]STOFCY <> PFCY  | [F:ITF]ITMREF <> PITM
       Read [ITF]ITF0 = PITM;PFCY
       If fstat Raz [F:ITF] Endif
    Endif

    Local Integer LNOL
    LNOL = nolign-1

    Local Char LMABR(10)
    LMABR="[M:"+PABR+"]"

    # Dans WZONSTOUPD, se trouve le nom du champ (facultatif) qui indique la valeur complémentaire à prendre en compte
    # lors des tests sur CREFLG : test= (CREFLG=0 | ZONSTOUPD>0)
    If !evalue(LMABR+"CREFLG([L]LNOL)") | ([M:ENTW]WZONSTOUPD<>"" & evalue(LMABR+[M:ENTW]WZONSTOUPD+"(LNOL)")>0)
        If PBTNMOD>0
            Assign "GBOUT"+num$(PBTNMOD) With ""
        Endif
    Elsif GREP <> "M"
        # a partir du moment ou l on a cree une nouvelle ligne on ne peut plus modifier une ligne existante
        # sans enregistrer le document
        If PBTNDET>0
            Assign "GBOUT"+num$(PBTNDET) With ""    # Détail
        Endif
    Else
        If PBTNDET>0
            Assign "GBOUT"+num$(PBTNDET) With ""    # Détail
        Endif
        If PBTNMOD>0
            Assign "GBOUT"+num$(PBTNMOD) With ""
        Endif
    Endif

    Call INIT_GOUVLOT(PTABTRS) From STKENT

    If (evalue(LMABR+"WSTOFLG([L]LNOL)")>0) & evalue("dim("+LMABR+"LOT)")>0 & evalue("dim("+LMABR+"GESLOT)")>0
&    & (  evalue([L]LMABR+"LOT([L]LNOL)")<>"$" &  evalue(LMABR+"LOT(LNOL)")<>"" & !(evalue("dim("+LMABR+"SLO)")>0 & evalue(LMABR+"SLO(LNOL)")="$")
&       | evalue([L]LMABR+"GESLOT([L]LNOL)")="C"
&       | evalue([L]LMABR+"GESLOT([L]LNOL)")="V" )

        If evalue([L]LMABR+"GESLOT([L]LNOL)")="" | PBTNINF<=0
            Assign "GBOUT"+num$(PBTNINF) With ""
        Endif
        If GOUVLOT>0
            # Complément lot : Visible uniquement si ligne de doc
            # n'est pas encore enregistrée et n'a qu'une seule ligne de détail
            Local Integer LRET
            [L]LRET = func STKENT.CAL_NBENTW( evalue([L]LMABR+"WSTOSEQ([L]LNOL)") )
            If [L]LRET<>1 | PBTNCOMP<=0
                Assign "GBOUT"+num$(PBTNCOMP) With  ""
            Endif
        Else
            Assign "GBOUT"+num$(PBTNCOMP) With  ""
        Endif
    Else
        Assign "GBOUT"+num$(PBTNINF) With ""
        Assign "GBOUT"+num$(PBTNCOMP) With ""
    Endif
End




###############################################################################
# STKCTRNBLIG: Controle la variable "status" sur une ligne de document
#                sur l'action champ "C_NBLIG"
###############################################################################
# Le masque par defaut doit être positionné correctement, ainsi que nolign
# mkstat est positionné à 2 si erreur
###############################################################################
Subprog STKCTRNBLIG (PABR,PFCY)
Value Char PABR
Value Char PFCY
    Case status
        When 65     :                                # Suppression d'une ligne
            # Dans WZONSTOUPD, se trouve le nom du champ (facultatif) qui indique la valeur complémentaire à prendre en compte
            # lors des tests sur CREFLG : test= (CREFLG=0 | ZONSTOUPD>0)
            If  evalue("[M:"+PABR+"]CREFLG(nolign-1)")=0
&            | ([M:ENTW]WZONSTOUPD<>"" & evalue("[M:"+PABR+"]"+[M:ENTW]WZONSTOUPD+"(nolign-1)")>0)
                Call DELSTOENTW(nolign-1, nolign-1, PABR, 1,1,PFCY,1,"") From STKENT

            Else
                GMESSAGE = mess (6,184,1)            # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                mkstat = 2
            Endif

        When 68, 83 :                                # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                If evalue("[M:"+PABR+"]CREFLG(I)")<>0
                    GMESSAGE = mess (6,184,1)            # La suppression d'une ligne validée doit se faire via la fenêtre de modification
                    mkstat=2
                    Break
                Endif
            Next
            If !mkstat
                Call DELSTOENTW(nolign-1, nolign1-1, PABR, 1,1,PFCY,1,"") From STKENT

            Endif

        When 75     :
            If PABR = "BBY0"
               If [M:BBY0]CREFLG(0)<>0
                mkstat=2
               Endif
            Else
               If PABR = "DBY1"
                  If [M:DBY1]CREFLG(nolign-1)<>0 & [M:DBY1]STOMGTCOD (nolign-1) > 1   # hcb 28654
                     mkstat=2
                  Endif
               Else
                  If evalue("[M:"+PABR+"]CREFLG(nolign-1)")<>0
                     mkstat=2
                  Endif : # MBT 22/10/2002
               Endif
            Endif
    Endcase
End

Subprog STKCTRNBLIG2 (PABR, PVCRTYP, PTRSTAB, PFCY, PBPR, PTRSTYP, PTRSCOD)
Value Char    PABR
Value Integer PVCRTYP
Value Char    PTRSTAB
Value Char    PFCY
Value Char    PBPR
Value Integer PTRSTYP
Value Char    PTRSCOD

    Case status
        When 65     :                                # Suppression d'une ligne
            # Dans WZONSTOUPD, se trouve le nom du champ (facultatif) qui indique la valeur complémentaire à prendre en compte
            # lors des tests sur CREFLG : test= (CREFLG=0 | ZONSTOUPD>0)
            If  evalue("[M:"+PABR+"]CREFLG(nolign-1)")=0
&            | ([M:ENTW]WZONSTOUPD<>"" & evalue("[M:"+PABR+"]"+[M:ENTW]WZONSTOUPD+"(nolign-1)")>0)
                Call DELSTOENTW(nolign-1, nolign-1, PABR, 1,1,PFCY,1,"") From STKENT
            Else
                Call DELETEMVT( PABR, nolign-1, nolign-1, PVCRTYP, PTRSTAB, PFCY, PBPR, PTRSTYP, PTRSCOD )
            Endif

        When 68, 83 :                                # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                If evalue("[M:"+PABR+"]CREFLG(I)")<>0
                    Call DELETEMVT( PABR, nolign-1, nolign1-1, PVCRTYP, PTRSTAB, PFCY, PBPR, PTRSTYP, PTRSCOD )
                Else
                    Call DELSTOENTW(I, I, PABR, 1,1,PFCY,1,"") From STKENT
                Endif
            Next
            If [M:ENTW]NBLIG>0 & sigma(0,[M:ENTW]NBLIG-1,[M:ENTW]WSTOSEQ(indcum))=0
                Call DELSTOENTW(-1, -1, PABR, 1,1,PFCY,1,"") From STKENT
            Endif

        When 75     :
            If PABR = "BBY0"
               If [M:BBY0]CREFLG(0)<>0
                mkstat=2
               Endif
            Else
               If evalue("[M:"+PABR+"]CREFLG(nolign-1)")<>0
                  mkstat=2
               Endif : # MBT 22/10/2002
            Endif
    Endcase

End

########################################################################
# STJSTOENTW  Lecture des mouvements de stock d'une ligne de document
#             pour stockage dans écran de travail STOENTW
#             Ex: picking livraison                en retour liv
#                 picking livraison prêt           en retour liv prêt
#                 picking livraison s-traitance    en retour liv s-traitance
#                 désassemblage d'un assemblage (traitement des composants)
#                 réintégration en stock
#                 Si inter-sites
#                   picking retour réception       en retour liv
#                   picking retour réc s-traitance en retour liv s-traitance
#                   picking livraison              en réception
#                   picking livraison prêt         en réception
#                   picking livraison s-raitance   en réception s-traitance
########################################################################

########################################################################
# Prérequis    : L'écran de travail STOENTW [ENTW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LTRS    = Type de mouvement (m704)
#                LTYP    = Type de document  (m701)
#                LDAT    = Date d'imputation
#                LLIGDOC = No ligne écran (nolign-1 de LABR)
#                LNBLIG  = Nb ligne écran (LABR)
#                LFIC = Nom du fichier de transaction
#                LCUN    = Message d'avertissement
#                           Si appel dans une transaction, mettre 0
#                           Si allocation mettre 0 ou 2
#                           0=non
#                           1=oui si article bloqué pour inventaire
#                           2=oui si article inutilisable
#                           3=oui si article bloqué pour inventaire ou inutilisable
#
#            S : LRET = Code retour (0=OK / 1=Erreur)
#                       0   pas d'erreur bloquante, mais GMESSAGE peut être positionné
#                       1   erreur, ne pas générer la ligne document (ou si ce n'est pas possible
#                            faire en sorte que rien ne soit saisissable)
#                       2   aucune ligne de détail n'a été ajoutée
#                       3   il existe des mouvements en attente sur le doc d'origine
#                GOUVENT = ouverture automatique de la fenetre d entrée
#                       2    ouverture
#                GTOTQTY qty total en US
#                GQQQQTY qty en statut "Q" en US
#                GRRRQTY qty en statut "R" en US
#                Recuperation des elements plus affichage de la ligne de document
########################################################################
# Entrée       : Ecran STOENT [ENT] (Bloc 1)
#                [M:ENT]TRSTYP     = Type mouvement(M.704)
#                [M:ENT]TRSCOD     = Code mouvement
#                [M:ENT]VCRTYPORI  = Type pièce origine (M.701)
#                [M:ENT]VCRNUMORI  = Numéro pièce origine
#                [M:ENT]VCRLINORI  = Numero ligne pièce origine
#                [M:ENT]STOFCYORI  = Site stock origine
#                [M:ENT]ITMREF     = Article
#                [M:ENT]BPRNUM     = Numero fournisseur
#                [M:ENT]TRSCOD     = code transaction
#                [M:ENT]TABLE1     = table parametrage transaction
########################################################################
# Sortie       : LRET 0=OK
#                     1=Erreur pour stockage dans ENTW
#                     2=Aucune ligne d'origine chargée
#                     3=Mouvements en attentes dans la pièce d'origine
#                Ecran STOENTW [ENTW]
###############################################################################
Subprog STJSTOENTW(LABR,LTRS,LTYP,LDAT,LLIGDOC,LNBLIG,LFIC,LCUN,LRET)
Value    Char     LABR
Value    Integer  LTRS
Value    Integer  LTYP
Value    Date     LDAT
Value    Integer  LLIGDOC
Value    Integer  LNBLIG
Value    Char     LFIC
Value    Integer  LCUN
Variable Integer  LRET

Local Integer   WNBSER
Local Char      WSERNUM(GLONSER), WSERNUMF(GLONSER), WSERNUMW(GLONSER)
Local Decimal   WPCUDIS, WSTUDIS, WSTUACTDIS, WQTYSTU, WQTYPRET
Local Decimal   WSTOCOU, WSTOCOUBPC, WSTOCOULIV
Local Integer   I, ACTENW
Local Decimal   LLOCSEQ
Local Char      LLOCTYP(GLONTLO)
Local Char      LLOC(GLONLOC)
Local Char      LWRH(GLONWRH)
Local Shortint  WRET
Local Decimal   LOVF
Local Char      LUSCAV
Local Integer   LMODIF
Local Decimal   PCOE
Local Char      PLBEFMT
Local Integer   LLIGLOT
Local Integer   WLIG, WSVGLIG
Local Char      WFILORI(240), WFILORI2(240), WFILPE(240)
Local Integer   WNBNEWLIG
Local Char      LABRMSK : LABRMSK="[M:"+LABR+"]"
Local Integer   LRETTMP
Local Char      LMESSAGE(type(GMESSAGE)-10)
Local Char      LSEC        # Section analytique
Local Char      LCCEDEF
Local Integer   LLIGCCE
Local Decimal   LPRIORD

Local Decimal LQTY
Local Char    LSTA(GLONSTA)
Local Char    LLOF(GLONLOT)
Local Char    LLOT(GLONLOT)
Local Char    LGESLOT(1)
Local Integer LNBSLO
Local Char    LSLO(GLONSLO)
Local Char    LSLOF(GLONSLO)
Local Char    LSER(GLONSER)
Local Char    LSERF(GLONSER)
Local Char    LPCU(GLONUOM)
Local Char    LPAL(GLONPAL)                # hcb 27200
Local Char    LCTR(GLONCTR)                # hcb 27200
Local Char    LMAJ(GLONECS)
Local Char    LMIN(GLONECS)
#--- Issue 53322
Local Char    LLPN(GLONLPN)
Local Char    LTCTR(GLONTCTR)
#---
Local Integer LECC
Local Integer LNBLIGDET
Local Integer LWLOCSEQ
Local Integer WQTYRET, WQTYSTUSVG
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
#--- Issue 110327 : remplacement WSERNUM par WSER
Local Char    WSER(GLONSER)
Local Char    WPALNUM(GLONPAL)
Local Char    WCTRNUM(GLONCTR)
Local Char    WECCMAJ(GLONECS)                # hcb 71276
Local Char    WECCMIN(GLONECS)                # hcb 71276
Local Char    WOWNER(GLONBPF)
Local Char    WSTOFLD1(GLONSF1)
Local Char    WSTOFLD2(GLONSF2)
Local Integer WSPACE
Local Integer WQUAFLG       # hcb V6CQ
Local Char    WKEYSTJ(5)    # CCC (2010-01-12) Bug 61121 : Clé de lecture fonction du filtre
#--- Issue 116813
Local Char    WSTJLOC(GLONLOC)
#--- Issue 117545
Local Char    WSRGLOCDEF(GLONLOC)
Local Integer LNBLPN      # hcb X3-64504

If clalev([F:STL])=0 Local File STOLOT     [STL]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP]  Endif
If clalev([F:TUN])=0 Local File TABUNIT    [TUN]  Endif
If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
If find(LTRS,12,18,3,16,33,19) | LABR = "DBY1"
   If clalev([F:STJ1])=0 Local File STOJOU [STJ1] Endif
Endif
If find(LTRS,33) & LABR = 'SRS1'
   If clalev([F:STJ2])=0 Local File STOJOU [STJ2] Endif
Endif
If clalev([F:STO])=0 Local File STOCK      [STO]  Endif
If clalev([F:STS])=0 Local File STOSER     [STS]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:SRU])=0 Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST])=0 Local File TABSTASTO  [TST]  Endif
If clalev([F:TLO])=0 Local File TABLOCTYP  [TLO]  Endif
If clalev([F:ACV])=0 Local File ACTIV      [ACV]  Endif
# N'est pas à faire!!
#If clalev([F:SRT])=0 Local File STKTRS     [SRT]  Endif
# Ne semblent pas utiles
#If clalev([F:STA])=0 Local File STOALL     [STA]  Endif
#If clalev([F:STC])=0 Local File STOLOC     [STC]  Endif

If clalev([M:ENTL])=0 Local Mask STOENTLOT [ENTL] Endif  #  ecran saisie complement lot

# Important : l écran STOENTW doit etre ouvert par le document appelant
If clalev([M:ENTW])=0 Local Mask STOENTW   [ENTW] Endif  #  ecran stockage mvt du document

If clalev([M:ENT])=0 Local Mask STOENT    [ENT] Endif  #  ecran stockage

# Chargement des blocs ENTETE / PARAMETRAGE  ecran STOENT
Local Char LBOI(GLONFEN)
LBOI=""
Gosub CHARG_PARAM_STOENT  From TRTSTOENTA
Kill LBOI

Read [ACV]CODACT="ENW"
If !fstat ACTENW=[F:ACV]DIME Endif
If ACTENW = 0
   GOK=0  : Call ERREUR (mess(339,199,1)-'ENW') From GESECRAN
   LRET=1 : End
Endif

# Positionnement sur les fichiers
Default Mask "["+LABR+"]"
Call LECFICENT( [M:ENT]STOFCY, [M:ENT]BPRNUM, "", LLIGDOC, [M:ENT]TRSTYP, [M:ENT]TRSCOD, LCUN ) From STKECR

Local Integer LNOL
# Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
Call STKWSTOSEQ(LABR,LLIGDOC, LNBLIG, 0,LNOL,LRET) From STKECR
If LRET<>0
    LRET=1
    End
Endif

Raz I
Raz GOUVENT
If dim (GTOTQTY) >= 0
   Raz GTOTQTY
Endif
If dim (GQQQQTY) >= 0
   Raz GQQQQTY
Endif
If dim (GRRRQTY) >= 0
   Raz GRRRQTY
Endif

#--- Bug 66232
GPOINT="FIL_STJENTW"
Gosub  ENTREE From EXEFNC
If WFILPE="" WFILPE="1=1" Endif
#---

#--- Issue 116813
## Si retour (mat sst sur retour fournisseur, on prend directement le mvt stock
## de la livraison (aucune info nécessaire sur le mvt du retour)
#If [M:ENT]TRSTYP=33 & [M:ENT]VCRTYPORI=8 & LABR = 'SRS1'
#    WFILORI  = 'STOFCY=[M:ENT]STOFCY & VCRTYP=4'
#    WFILORI += '& VCRNUM=[M:SRS1]DETSDHNUM(LLIGDOC) & VCRLIN=[M:SRS1]SDDLIN(LLIGDOC)'
#    WFILORI += '& ITMREF=[M:ENT]ITMREF & REGFLG<>2'
#    #--- Issue 93527 by TS
#    WFILORI += '& QTYSTU>0'
#    WFILORI2 = WFILORI
#   WKEYSTJ = "STJ1"
# Si réintégration de stock, on prend les mvts de stock de type sortie OF
# avec l'OF commme pièce origine
# Si réintégration de stock, suite à annulation pesée --> fonctionnement normal
# car la référence est le suivi et non l'OF
#Elsif LTRS=19 & [M:ENT]VCRTYPORI=10
If LTRS=19 & [M:ENT]VCRTYPORI=10
#--- End issue 116813
    WFILORI  = 'STOFCY=[M:ENT]STOFCYORI & TRSTYP=6 & VCRTYPORI=[M:ENT]VCRTYPORI'
    WFILORI += '& VCRNUMORI=[M:ENT]VCRNUMORI & VCRLINORI=[M:ENT]VCRLINORI'
  # FQ 62773 GA 04/2010 pb de reintégration si plusieurs fois la meme matière dans l'OF
    WFILORI += '& VCRSEQORI=[M:ENT]VCRSEQORI'
    WFILORI += '& ITMREF=[M:ENT]ITMREF & REGFLG<>2'

    WFILORI2 = WFILORI + "&UPDCOD=2"

    WKEYSTJ = ""
Else
    WFILORI  = 'STOFCY=[M:ENT]STOFCYORI & VCRTYP=[M:ENT]VCRTYPORI'
    WFILORI += '& VCRNUM=[M:ENT]VCRNUMORI & VCRLIN=[M:ENT]VCRLINORI'
    WFILORI += '& ITMREF=[M:ENT]ITMREF & REGFLG<>2'
    # Si retour liv prêt/s-traitance on ne prend que le mvt positif
    If find([M:ENT]TRSTYP,18,33) & [M:ENT]VCRTYPORI = 4
        WFILORI += '& QTYSTU>0'
    Endif
    # Si réception liv (normale/prêt/s-traitance)
    # on ne prend que le mvt négatif (un seul mvt si liv normale)
    If find([M:ENT]TRSTYP,3,16) & [M:ENT]VCRTYPORI=4
       WFILORI +='& QTYSTU<0'
    Endif

    WFILORI2 = WFILORI

    WKEYSTJ = "STJ1"

    # Si réception d'une livraison inter-site
    If [M:ENT]TRSTYP=3 WFILORI2+='&UPDCOD=2' Endif
Endif

If find([M:ENT]TRSTYP,18,33)
    WQTYPRET = evalue("[M:"+LABR+"]QTYSTU(LLIGDOC)")
Endif

#--- On tient aussi compte des mouvements en attente ----#
#--- Nécessaire par ex, quand on cherche à sélectionner une livraison qui n'a qu'un mouvement en attente ---#
Filter [STJ] Where evalue(WFILORI2)
I = rowcount([F:STJ])
Filter [STJ]

# Peut on ajouter les lignes dans l'écran de travail
If ACTENW=0 | [M:ENTW]NBLIG+I >= ACTENW
   Call ERREUR(mess(394,199,1)) From GESECRAN
   LRET=1
   End
Endif
# S'il n'y a pas de mouvement de stock associé au document d'origine,
# aucun champ stock ne peut être récupéré.
# On appelle donc OUVENT pour stocker les infos de quantité, en particulier, dans STOENTW
If I=0
    If evalue("dim("+LABRMSK+"LOC)")>0 & [F:ITF]LOCMGTCOD=2
        Call STKWLOCSEQ(LABR, LLIGDOC, LRET) From STKECR
        If LRET
            LRET = 1
            End
        Endif
        LLOCSEQ = evalue(LABRMSK+"WLOCSEQ(LLIGDOC)")
        # Il est possible qu'un emplacement quai soit renseigné (via INIZONENT)
        # Il faut donc conserver la valeur
        LLOC    = evalue(LABRMSK+"LOC(LLIGDOC)")
        LLOCTYP = evalue(LABRMSK+"LOCTYP(LLIGDOC)")
        # Récupération du dépôt de la ligne de document
        If evalue("dim("+LABRMSK+"WRH(LLIGDOC))")>0
          LWRH=evalue(LABRMSK+"WRH(LLIGDOC)")
        Else
          LWRH=""
        Endif
        Call STKSUGEMP(LLOCSEQ,LTRS,[M:ENT]TRSCOD,[M:ENT]STOFCY,[M:ENT]ITMREF,
&                      evalue(LABRMSK+[M:ENTW]WZONPCU+"(LLIGDOC)"),
&                      evalue(LABRMSK+[M:ENTW]WZONQUC+"(LLIGDOC)"),
&                      evalue(LABRMSK+"STA(LLIGDOC)"),LLOCTYP,LLOC,
&                      [M:ENT]BPRNUM,"",
&                      string$(evalue("[F:"+LFIC+"]SRGWAIFLG")<>2,'[F:TLO]LOCCAT<>2'),
&                      LWRH) From STKLOC
        #----- On fait le contrôle afin de récupérer le type d'emplacement -----#
        Call STKCTREMP(LLOCSEQ,LTRS,[M:ENT]TRSCOD,[M:ENT]STOFCY,[M:ENT]ITMREF,
&                      evalue(LABRMSK+[M:ENTW]WZONPCU+"(LLIGDOC)"),
&                      evalue(LABRMSK+[M:ENTW]WZONQUC+"(LLIGDOC)"),
&                      evalue(LABRMSK+"STA(LLIGDOC)"),LLOCTYP,LLOC,
&                      [M:ENT]BPRNUM,0,WRET,LOVF,"",
&                      string$(evalue("[F:"+LFIC+"]SRGWAIFLG")<>2,'[F:TLO]LOCCAT<>2'),
&                      LWRH) From STKLOC

        Assign LABRMSK+"WLOCSEQ(LLIGDOC)" With LLOCSEQ
        Assign LABRMSK+"LOCTYP(LLIGDOC)"  With LLOCTYP
        Assign LABRMSK+"LOC(LLIGDOC)"     With LLOC
    Endif
    #--- Issue X3-53322
    If evalue("dim("+LABRMSK+"TCTRNUM)")>0
        LTCTR=evalue(LABRMSK+"TCTRNUM(LLIGDOC)")
    Endif
    #---

    Call OUVENT([M:ENT]STOFCY, LABR, LTRS, [M:ENT]TRSCOD, [M:ENT]BPRNUM, LTYP, LDAT, LLIGDOC, LNBLIG, LFIC, "A", WRET) From STKENT
    If !WRET
        # calcul  qtés saisies et total Q et R ----#
        If dim (GTOTQTY) >= 0
               GTOTQTY +=[M:ENTW]QTYSTU(WLIG)
        Endif
        If dim (GQQQQTY) >=0
               If left$([M:ENTW]STA(WLIG),1)= "Q"
                  GQQQQTY += [M:ENTW]QTYSTU(WLIG)
               Else
                  If left$([M:ENTW]STA(WLIG),1)= "R"
                      GRRRQTY += [M:ENTW]QTYSTU(WLIG)
                  Endif
               Endif
        Endif
    Endif

    # Si réception d'une livraison inter-site
    # recherche d'éventuels mouvements en attente
    If [M:ENT]TRSTYP=3
       LRET=0
       Filter [STJ] Where evalue(WFILORI) & UPDCOD=1
       Look [STJ]STJ1 First
       Filter [STJ]
       If !fstat
          LRET=4
       Endif
    Endif

    End
Endif

WLIG    = [M:ENTW]NBLIG
WSVGLIG = [M:ENTW]NBLIG
# hcb 22993 deb
If LTYP = 32 & LABR = "DBY1"
   Local Decimal WQTY
   WQTY = [M:ENT]QTYTOENT
   WQTY = WQTY * -1

Endif
# hcb 22993 fin


Raz WNBNEWLIG
Raz LMESSAGE

#--- Issue 110327 : remplacement WSERNUM par WSER
Raz WQTYRET, WLOT, WSLO, WSER, WPALNUM, WCTRNUM, WSTOFLD1, WSTOFLD2, WECCMAJ, WECCMIN             # hcb 71276

#--- Issue 116813
# Récupération emplacement sst de la livraison pour sst origine
If [M:ENT]TRSTYP=33 & [M:ENT]VCRTYPORI=8 & LABR = 'SRS1'
   Filter [STJ2] Where STOFCY=[M:ENT]STOFCY & VCRTYP=4 & VCRNUM=[M:SRS1]DETSDHNUM(LLIGDOC) &
&                      VCRLIN=[M:SRS1]SDDLIN(LLIGDOC) & ITMREF=[M:ENT]ITMREF & REGFLG<>2 & QTYSTU>0
&                Order By Key STJ1
   For [STJ2]
      WSTJLOC = [F:STJ2]LOC
      Break
   Next
   Filter [STJ2]
Endif
#--- End issue 116813

#--- Issue 110327
If [F:ITM]SERMGTCOD=4
  Filter [STJ] Where evalue(WFILORI) & UPDCOD=2 & evalue(WFILPE)
&              Order By LOT;SLO;SERDEB;PALNUM;CTRNUM;OWNER
Else
#---
  Filter [STJ] Where evalue(WFILORI) & UPDCOD=2 & evalue(WFILPE)
&             Order By LOT;SLO;SERNUM;PALNUM;CTRNUM;OWNER
#--- Issue 110327
Endif
#---

WSPACE=0
#--- Seuls les mouvements non en attente sont sélectionnables ----#

For [STJ] Hint Key =WKEYSTJ   # CCC (2010-01-12) Bug 61121

    # Alimentation en positif de la quantité à traiter
    WQTYSTU = abs([F:STJ]QTYSTU)

    [M:ENTW]SAIACTFLG(WLIG) = 1+(LTRS=19 & [F:ITM]STOMGTCOD>2)
    # 96266 mm 01.2014 - récupération de la quantité en UA
    If [M:ENTW]SAIACTFLG(WLIG)= 2
        WQTYSTU = abs([F:STJ]ACTQTY)
    Endif

    If find([M:ENT]TRSTYP,18,33)
       #MAE If WQTYPRET<=0 Break Endif
#       If (WQTYPRET<=0 & [M:ENT]TRSTYP = 18) Break Endif       # hcb 110327

       #--- Issue 116813
       # Récupération emplacement sst de la livraison pour sst origine
       If [M:ENT]TRSTYP=33 & [M:ENT]VCRTYPORI=8 & LABR = 'SRS1'
          [F:STJ]LOC    = WSTJLOC
          [F:STJ]STOFCY = [M:ENT]STOFCY
       Endif
       #--- End issue 116813

      #MAE/TS, on cherche la ligne de stock en faisant 2 passes :
       #une 1ere avec le statut de renseigné(bug 87750:une livraison avec 2 lignes de stock identiques hormis le statut)
       #une 2eme avec le statut a blanc (bug 77336:changement de statut possible sur emplacement tiers)
       #--- Issue X3-53322 : Ajout LPN
       Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                  [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                  [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                  [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU)
&                  From STKLIB
       If WSTOCOU=0
        #--- Issue X3-53322 : Ajout LPN
        Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                  [F:STJ]PALNUM,[F:STJ]CTRNUM,"",[F:STJ]LOC,[F:STJ]PCU,
&                  [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                  [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU)
&                  From STKLIB
       Endif
       #---
       If WSTOCOU=0
           Goto STJSTOENTW_NEXT
       Else
           If [M:ENT]VCRTYPORI=8 & LABR="SRS1"
               Read [STO]STO0=[F:STJ]STOFCY;WSTOCOU
           Else
               Read [STO]STO0=[M:ENT]STOFCY;WSTOCOU
           Endif
           If fstat
               Goto STJSTOENTW_NEXT
           Else
               #--- Issue 105775
               #WQTYSTU = min(WQTYSTU,[F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)
               If [M:ENT]TRSTYP=33
                 WQTYSTU = min(WQTYSTU,[F:STO]QTYSTU-[F:STO]CUMWIPQTY)
               Else
                 WQTYSTU = min(WQTYSTU,[F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)
               Endif
               #---
           Endif
       Endif
       WQTYSTU   = min(WQTYSTU,WQTYPRET)
#       WQTYPRET -= WQTYSTU                  # hcb 110327
       Goto STJSTOENTW_SUI
    Endif

    #--- Issue 110327 : remplacement WSERNUM par WSER
    If [F:STJ]LOT=WLOT & [F:STJ]SLO=WSLO & [F:STJ]SERNUM=WSER &
&      [F:STJ]PALNUM=WPALNUM & [F:STJ]CTRNUM=WCTRNUM & [F:STJ]OWNER=WOWNER &
&      [F:STJ]STOFLD1=WSTOFLD1 & [F:STJ]STOFLD2=WSTOFLD2 & WSPACE<>0
       If WQTYRET<>0
          WQTYSTUSVG = WQTYSTU
          WQTYSTU    = max(0,WQTYSTU-WQTYRET)
          WQTYRET   -= min(WQTYSTUSVG,WQTYRET)
       Endif
       Goto STJSTOENTW_SUI
    Endif
    WLOT    = [F:STJ]LOT
    WSLO    = [F:STJ]SLO
    #--- Issue 110327 : remplacement WSERNUM par WSER
    WSER    = [F:STJ]SERNUM
    If [F:ITM]SERMGTCOD = 4                   # hcb 110327
       WSER    = [F:STJ]SERDEB                # hcb 110327
    Endif                                     # hcb 110327
    WPALNUM = [F:STJ]PALNUM
    WCTRNUM = [F:STJ]CTRNUM
    WOWNER  = [F:STJ]OWNER
    WSTOFLD1= [F:STJ]STOFLD1
    WSTOFLD2= [F:STJ]STOFLD2
    WSPACE  = 1
    # Si réception liv inter-site, retour client ou réception pour sous-traitance ou réintégration
    # recherche s'il y a déjà eu des réceptions ou retours sur cette ligne
    If find([M:ENT]TRSTYP,3,12,16,19,33) |
&          (LABR="DBY1" & [M:ENT]VCRTYP=32 & [M:ENT]VCRTYPORI=31)
       WQTYRET = 0

       #--- PE 56490 pour améliorer les performances notamment si no série
       GPE=0
       GPOINT="NEWFORSTJ" : Gosub ENTREE From EXEFNC
# hcb 110327  *2 : [F:STJ1]SERDEB >=[F:STJ]SERDEB & [F:STJ1]SERFIN<=[F:STJ]SERFIN
       If GPE<>1
         For [STJ1]STJ2 Where UPDCOD    = 2                  &
&                             ITMREF    = [M:ENT]ITMREF      &
&                             IPTDAT    >=[F:STJ]IPTDAT      &
&                             VCRTYPORI = [M:ENT]VCRTYPORI   &
&                             VCRNUMORI = [M:ENT]VCRNUMORI   &
&                             VCRLINORI = [M:ENT]VCRLINORI   &
&                             REGFLG    <>2                  &
&                             QTYSTU    > 0
           # Si données stock identiques, on déduit la qté déjà retournée/réceptionnée
           #--- Bug 73441
           # Si inter-site (réception d'une livraison ou retour client d'un retour fournisseur)
           # il ne faut pas prendre en compte le propriétaire
           If (find([M:ENT]TRSTYP,3,16) & [M:ENT]VCRTYPORI=4) | (find([M:ENT]TRSTYP,12,33) & [M:ENT]VCRTYPORI=8)
             If [F:STJ1]LOT=[F:STJ]LOT & [F:STJ1]SLO=[F:STJ]SLO &
&               [F:STJ1]BPSLOT=[F:STJ]BPSLOT & [F:STJ1]SERNUM=[F:STJ]SERNUM &
&               [F:STJ1]PALNUM=[F:STJ]PALNUM & [F:STJ1]CTRNUM=[F:STJ]CTRNUM &
&                [F:STJ1]SERDEB >=[F:STJ]SERDEB & [F:STJ1]SERFIN<=[F:STJ]SERFIN &
&               [F:STJ1]STOFLD1=[F:STJ]STOFLD1 & [F:STJ1]STOFLD2=[F:STJ]STOFLD2
                 WQTYRET+= [F:STJ1]QTYSTU
                 WQTYRET-= min(WQTYSTU,[F:STJ1]QTYSTU)
                 WQTYSTU = max(0,WQTYSTU-[F:STJ1]QTYSTU)
             Endif
           Elsif [F:STJ1]LOT=[F:STJ]LOT & [F:STJ1]SLO=[F:STJ]SLO &
&                [F:STJ1]BPSLOT=[F:STJ]BPSLOT & [F:STJ1]SERNUM=[F:STJ]SERNUM &
&                [F:STJ1]PALNUM=[F:STJ]PALNUM & [F:STJ1]CTRNUM=[F:STJ]CTRNUM &
&                [F:STJ1]SERDEB >=[F:STJ]SERDEB & [F:STJ1]SERFIN<=[F:STJ]SERFIN &
&                [F:STJ1]STOFLD1=[F:STJ]STOFLD1 & [F:STJ1]STOFLD2=[F:STJ]STOFLD2 &
&                [F:STJ1]OWNER =[F:STJ]OWNER
              WQTYRET+= [F:STJ1]QTYSTU
              WQTYRET-= min(WQTYSTU,[F:STJ1]QTYSTU)
              WQTYSTU = max(0,WQTYSTU-[F:STJ1]QTYSTU)
           Endif
#           If [F:STJ1]LOT=[F:STJ]LOT & [F:STJ1]SLO=[F:STJ]SLO &
#&             [F:STJ1]BPSLOT=[F:STJ]BPSLOT & [F:STJ1]SERNUM=[F:STJ]SERNUM &
#&             [F:STJ1]PALNUM=[F:STJ]PALNUM & [F:STJ1]CTRNUM=[F:STJ]CTRNUM &
#&             [F:STJ1]OWNER =[F:STJ]OWNER
#             WQTYRET+= [F:STJ1]QTYSTU
#             WQTYRET-= min(WQTYSTU,[F:STJ1]QTYSTU)
#             WQTYSTU = max(0,WQTYSTU-[F:STJ1]QTYSTU)
#           Endif
            #---
         Next
       Endif
       #---
    Endif

$STJSTOENTW_SUI

    # Restitution en négatif de la quantité à traiter
    WQTYSTU = WQTYSTU * -1

    If WQTYSTU=0 Goto STJSTOENTW_NEXT Endif

    # hcb 22993 deb
    If LTYP = 32 & LABR = "DBY1"
       If WQTYSTU >= WQTY
          WQTY -= WQTYSTU
       Else
          WQTYSTU = WQTY
          WQTY    = 0
       Endif
    Endif
    # hcb 22993 fin


    LPRIORD = [F:STJ]PRIORD

    # Il n'est pas possible de faire un transclasse à cause du lot et du complément
    # car ceux-ci sont stockés dans un 2ème tableaux de ENTW
    # nolign = WLIG+1
    # [M:ENTW] = [F:STJ]


    If find([M:ENT]TRSTYP,18,33)
       [M:ENTW]STOCOU(WLIG)=WSTOCOU
    Endif
    #MAE, retour sous traitance
#    If find([M:ENT]TRSTYP,33) & [M:ENT]VCRTYPORI=8 & LABR="SRS1"
#        # Si retour de matière sous traitance sur retour fournisseur (inter site)
#        # recherche du mouvement sur la livraison pour récupérer l'emplacement sous  traitant
#        For [STJ2]STJ1 Where UPDCOD    = 2                 &
#&                           ITMREF    = [M:ENT]ITMREF      &
#&                           VCRTYP    = 4                  &
#&                           VCRNUM    = [F:SDD]SDHNUM      &
#&                           VCRLIN    = [F:SDD]SDDLIN      &
#&                           REGFLG    <>2                  &
#&                           QTYSTU    > 0



        #on récupère le chrono stock de la ligne de stock de la livraison avecles infos stocks du mouvement de retour fournisseur
#        Call CLESTO([F:STJ2]STOFCY,[F:STJ2]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
#&                  [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ2]STA,[F:STJ2]LOC,[F:STJ2]PCU,
#&                  [F:STJ2]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ2]QLYCTLDEM,[F:STJ]OWNER,[L]WSTOCOULIV)
#&                  From STKLIB

#           [M:ENT]LOC=[F:STJ2]LOC
#           [M:ENTW]STOCOU(WLIG)=WSTOCOULIV
#       Next
#    Endif
    #Fin MAE, retour sous traitance


    [M:ENTW]ORILIG   (WLIG) = 2
    [M:ENTW]PCU      (WLIG) = [F:STJ]PCU
    [M:ENTW]PCUSTUCOE(WLIG) = [F:STJ]PCUSTUCOE
    If abs([F:STJ]QTYSTU) <> abs(WQTYSTU)
       If [F:STJ]PCUSTUCOE=0 [F:STJ]PCUSTUCOE=1 Endif
       [M:ENTW]QTYSTU(WLIG) = WQTYSTU * -1
       [M:ENTW]QTYPCU(WLIG) = (WQTYSTU / [F:STJ]PCUSTUCOE) * -1
       Call QTEARR([M:ENTW]QTYPCU(WLIG), [M:ENTW]PCU) From TRTDIV
       If [M:ENTW]QTYPCU(WLIG) <> (WQTYSTU / [F:STJ]PCUSTUCOE) * -1
           [M:ENTW]PCU      (WLIG) = [F:ITM]STU
           [M:ENTW]QTYPCU   (WLIG) = WQTYSTU * -1
           [M:ENTW]PCUSTUCOE(WLIG) = 1
       Endif
    Else
       [M:ENTW]QTYSTU(WLIG) = abs([F:STJ]QTYSTU)
       [M:ENTW]QTYPCU(WLIG) = abs([F:STJ]QTYPCU)
    Endif
    # controle UC  si pas us et ne faisant pas partie des conditionnements conversion en US
    Call CTLUOM ([M:ENT]ITMREF,3,[M:ENT]BPRNUM, [M:ENTW]PCU(WLIG),PCOE, LUSCAV, PLBEFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          [M:ENTW]PCU      (WLIG) = [F:ITM]STU
          [M:ENTW]PCUSTUCOE(WLIG) = 1
          [M:ENTW]QTYPCU   (WLIG) = [M:ENTW]QTYSTU(WLIG)
          [M:ENTW]QTYPCU   (WLIG) = [M:ENTW]QTYSTU(WLIG)
          PLBEFMT                 = [F:ITM]STULBEFMT
       Endif
    Endif
    [M:ENTW]PALNUM(WLIG) = [F:STJ]PALNUM
    [M:ENTW]CTRNUM(WLIG) = [F:STJ]CTRNUM
    [M:ENTW]OWNER(WLIG)  = [F:STJ]OWNER
    [M:ENTW]STOFLD1(WLIG)= [F:STJ]STOFLD1
    [M:ENTW]STOFLD2(WLIG)= [F:STJ]STOFLD2
    If LTYP = 32 & LABR = "DBY1"                         # hcb X3-71295
       [M:ENTW]WRH(WLIG)= [F:STJ]WRH
    Endif

    If [M:ENTW]LBEFMT(WLIG) = ""
       [M:ENTW]LBEFMT(WLIG) = PLBEFMT
    Endif
    If [M:ENTW]LBENBR(WLIG) = 0 & [M:ENTW]LBEFMT(WLIG) <> ""
       [M:ENTW]LBENBR(WLIG) = 1
    Endif
    If [F:ITM]LOTMGTCOD<>1
       #--- Demande 64647
       GPE=0
       GPOINT="NEW_LOT" : Gosub ENTREE From EXEFNC
       If GPE<>1
          Call SETCPTLOTAUTO([F:STJ]ITMREF,"ENTW",WLIG,[F:STJ]LOT,[F:STJ]SLO,
&                            [F:STJ]BPSLOT,string$([F:STJ]LOT="","B"),[F:STJ]ECCVALMAJ,[F:STJ]ECCVALMIN,1,LRETTMP)
       Endif
       #---
    Endif


    #[M:ENTW]SAIACTFLG(WLIG) = 1+(LTRS=19 & [F:ITF]STOMGTCOD>2)

    #-------------------------------------------------------------------------------------
    # Récupération des no série
    #-------------------------------------------------------------------------------------
    # Attention, si no série gérés en sortie, on ne récupère que la 1ère séquence
    # de numéros à retourner --> la qté préalimenté peut être < à ce qui est retournable
    # Ex : Livraison de no série de S01 à S10
    #      Retour de 3 no série S01, S07 et S08
    #      Alimentation d'un nouveau retour --> Qté=5 avec no série S02 à S06
    #      alors que l'on devrait avoir     --> Qté=7 avec no série S02 à S06 et S09, S10
    #-------------------------------------------------------------------------------------
    If dim([M:ENTW]SERNUM)>0

      #--- Issue 110327
      If [F:ITM]SERMGTCOD=4
      # si réception d'une livraison on recupere les series globales si qte réceptionnée = qty livrée
      # si retour client , pret , sous traitance on recupere les series globales si qte retounée = qty livrée
      # desassemblage les series globales au picking de l assemblage
         If (find([M:ENT]TRSTYP,3,12,16,18,33) & find([M:ENT]VCRTYPORI,4,8)) | (find([M:ENT]TRSTYP,1) & [M:ENT]VCRTYPORI = 31)
            If [M:ENTW]QTYSTU(WLIG) <> abs([F:STJ]QTYSTU)
               Raz WSERNUM
               Raz WSERNUMF
            Else
               LRETTMP=0
               WSERNUMW=[F:STJ]SERDEB
               For I=1 To [M:ENTW]QTYSTU(WLIG)
                  If I>1
                     Call PLUS_UN(WSERNUMW,WSERNUMW,LRETTMP) From STKLIB
                     # Si problème d'incrémentation, on s'arrête là
                     If LRETTMP Break Endif
                  Endif
                  Read [STS]STS0=[M:ENT]ITMREF;WSERNUMW
                  # Si no série inexistant, ou non sorti par la pièce origine, on s'arrête là
                  If fstat | [F:STS]SDHNUM<>[M:ENT]VCRNUMORI
                     LRETTMP=1 : Break
                  Endif
               Next
               # On alimente les no séries uniquement si l'on est sûr qu'ils sont ok
               If LRETTMP=0
                  WSERNUM  = [F:STJ]SERDEB
                  WSERNUMF = [F:STJ]SERFIN
               Else
                  Raz WSERNUM
                  Raz WSERNUMF
               Endif
            Endif
         Endif

      ######################################################################
      # si liv de 100 avec 2 STOJOU avec même caractéristiques stock
      #    qté 20 no série S001 à S020
      #    qté 80 no série S101 à S180
      # et retour de 30 avec 1 STOJOU
      #    qté 30 no série S111 à S140
      # pour un nouveau retour, on va proposer par défaut
      #    qté 20-30 déjà retourné         = 0
      #              (avec 10 déjà retourné restant à prendre en compte)
      #    qté 80-10 déjà retourné restant = 70
      #    --> on initialise un STOENTW avec qté 70, mais on ne sait pas proposer
      #        les no série S001 à S020, puis S101 à S110, puis S141 à S180
      #----------------------------------------------------------------------
      # à terminer :
      # - soit on fait comme série en sortie, uniquement la 1ère séquence
      #   --> refaire ce qui suit dans le elsif (en utilisant [F:STJ]NUMDEB
      #       dans l'exemple précédent, on obtient
      #       qté 10 no série S101 à S110
      # - soit on ne fait rien
      #   --> pas de récupération des no série
      #       dans l'exemple précédent, on obtient
      #       qté 70 sans no série
      #       il faut peut être proposer une sélection des no série retournables
      #######################################################################

      Elsif [F:STJ]SERNUM<>""
      #If [F:STJ]SERNUM<>""
      #--- End issue 110327

         # Quantité de 1 : Ok
         #--- Bug 86970
         #If [M:ENTW]QTYSTU(WLIG)=1
         If [M:ENTW]QTYSTU(WLIG)=1 & abs([F:STJ]QTYSTU)=1
         #---
            Read [STS]STS0=[M:ENT]ITMREF;[F:STJ]SERNUM
            # No série inexistant ou déjà revenu
            #--- Bug 67698 : ajout valeur 3 (reception)
            If fstat | ([F:STS]SDHNUM="" & !find([M:ENT]TRSTYP,3,16,18,33))
&                    | ([M:ENT]TRSTYP=18 & [F:STS]SDHNUM<>[M:ENT]VCRNUMORI)  : #--- Issue 120429
#               If [M:ENT]TRSTYP=18  WQTYPRET+=[M:ENTW]QTYSTU(WLIG)  Endif   # hcb 110327
               Goto STJSTOENTW_NEXT
            Else
               WNBSER   = 1
               WSERNUM  = [F:STJ]SERNUM
               WSERNUMF = [F:STJ]SERNUM
            Endif
         # Quantité > 1 : les no séries sont-ils déjà revenus ?
         Else
            WSERNUMW = [F:STJ]SERNUM
            $STJSTOENTW_SER
            Read [STS]STS0=[M:ENT]ITMREF;WSERNUMW
            # No série inexistant ou déjà revenu --> passage au suivant
            #--- Bug 67698 : ajout valeur 3 (reception)
            If fstat | ([F:STS]SDHNUM="" & !find([M:ENT]TRSTYP,3,16,18,33))
&                    | ([M:ENT]TRSTYP=18 & [F:STS]SDHNUM<>[M:ENT]VCRNUMORI)     : #--- Issue 120429
               Call PLUS_UN(WSERNUMW,WSERNUMF,LRETTMP) From STKLIB
               If LRETTMP
#                  If [M:ENT]TRSTYP=18  WQTYPRET+=[M:ENTW]QTYSTU(WLIG)  Endif  # hcb 110327
                  Goto STJSTOENTW_NEXT
               Else
                  WSERNUMW = WSERNUMF
                  Raz WSERNUMF
                  Goto STJSTOENTW_SER
               Endif
            # On connait le 1er no série qui est OK
            # --> détermination du dernier
            Else
               WNBSER   = 1
               WSERNUM  = WSERNUMW
               For I=2 To [M:ENTW]QTYSTU(WLIG)
                  Call PLUS_UN(WSERNUMW,WSERNUMF,LRETTMP) From STKLIB
                  # Si problème d'incrémentation, on s'arrête là
                  If LRETTMP Break Endif
                  Read [STS]STS0=[M:ENT]ITMREF;WSERNUMF
                  # Si no série inexistant ou déjà revenu, on s'arrête là
                  #--- Bug 67698 : ajout valeur 3 (reception)
                  If fstat | ([F:STS]SDHNUM="" & !find([M:ENT]TRSTYP,3,16,18,33))
&                          | ([M:ENT]TRSTYP=18 & [F:STS]SDHNUM<>[M:ENT]VCRNUMORI)  : #--- Issue 120429
                     Break
                  Endif
                  # Passage au suivant
                  WSERNUMW = WSERNUMF
                  WNBSER  += 1
               Next
               # Calcul du no série fin
               If WNBSER=1
                  WSERNUMF = WSERNUM
               Else
                  Call PLUS_NB(WSERNUM,WNBSER,WSERNUMF,LRETTMP) From STKLIB
                  If LRETTMP
#                    If [M:ENT]TRSTYP=18  WQTYPRET+=[M:ENTW]QTYSTU(WLIG)  Endif  # hcb 110327
                     Goto STJSTOENTW_NEXT
                  Endif
               Endif
            Endif
         Endif
         # Si nb no série < quantité retournable, recalcul de cette quantité
         If WNBSER<>[M:ENTW]QTYSTU(WLIG)
            If [F:STJ]PCUSTUCOE=0 [F:STJ]PCUSTUCOE=1 Endif
            [M:ENTW]QTYSTU(WLIG) = WNBSER
            [M:ENTW]QTYPCU(WLIG) = (WNBSER/[F:STJ]PCUSTUCOE)
         Endif
      Endif
      # Alimentation des no série début et fin
      [M:ENTW]SERNUM(WLIG)  = WSERNUM
      [M:ENTW]SERNUMF(WLIG) = WSERNUMF
    Endif
    # Initialisation statut selon règle de gestion
    #--- Issue 93893 by TS
    #WQUAFLG = 1
    WQUAFLG=0
    #---
    If evalue("dim("+LABRMSK+"QUAFRE)")>0 &  evalue(LABRMSK+"QUAFRE(LLIGDOC)") <> 0   # hcb V6CQ
       If evalue("dim("+LABRMSK+"QUAFLG)")>0
          WQUAFLG = evalue("[M:"+LABR+"]QUAFLG(LLIGDOC)")
       Endif
    Endif

    Call STKINISTA([M:ENTW]STA(WLIG),[M:ENT]BPRNUM,WQUAFLG) From STKACT
    # Si pas de statut par défaut, on récupère le statut du mouvement
    If [M:ENTW]STA(WLIG)=""
       [M:ENTW]STA(WLIG)=[F:STJ]STA
       If [M:ENT]QUAFLG=2 & left$([M:ENTW]STA(WLIG),1)<>"Q"
          [M:ENTW]STA(WLIG)=""
       Endif
       # Contrôle statut autorisé
       If !([M:ENT]QUAFLG=2 & pat([M:ENTW]STA(WLIG),"Q*")=1)
          If [M:ENTW]STA(WLIG)<>""
             Call STKCTRSTA([M:ENTW]STA(WLIG),[F:SRU]AUZSST,[M:ENT]QUAFLG,0,0,mkstat) From STKACT
             If mkstat  [M:ENTW]STA(WLIG)="" : Endif
          Endif
       Endif
    Endif

    #emplacement
    If [F:ITF]LOCMGTCOD > 1
        Raz I

        #--- Issue 117545
        Raz WSRGLOCDEF
        If LABR="PTH1"
           If dim([M:PTH0]SRGLOCDEF)>0
              WSRGLOCDEF=[M:PTH0]SRGLOCDEF
           Endif
        Elsif dim([M]SRGLOCDEF)>0
           WSRGLOCDEF=[M]SRGLOCDEF
        Endif
        If WSRGLOCDEF<>""
           Read [STC]STC0=[M:ENT]STOFCY;WSRGLOCDEF
           Call STKCTRSTA([M:ENTW]STA(WLIG),[F:STC]AUZSST,0,1,0,WRET) From STKACT
           If WRET=0
              [M:ENTW]LOC(WLIG)    = WSRGLOCDEF
              [M:ENTW]LOCTYP(WLIG) = [F:STC]LOCTYP
           Endif
        #If dim([M]SRGLOCDEF)>0
#&        & [M]SRGLOCDEF<>""
            # L'emplacement quai est forcément bon (illimité, multi-article...)
            # le contrôle du site a été fait à la saisie

            #Read [STC]STC0=[M:ENT]STOFCY;[M]SRGLOCDEF
            #Call STKCTRSTA([M:ENTW]STA(WLIG),[F:STC]AUZSST,0,1,0,WRET) From STKACT
            #If WRET=0
            #   [M:ENTW]LOC(WLIG)    = [M]SRGLOCDEF
            #   [M:ENTW]LOCTYP(WLIG) = [F:STC]LOCTYP
            #Endif
        #---

        Else
            Call STKWLOCSEQ("ENTW", WLIG, LRETTMP) From STKECR
            If LRETTMP
                Goto STJSTOENTW_NEXT
            Endif
            Call STKSUGEMP([M:ENTW]WLOCSEQ(WLIG),LTRS,[M:ENT]TRSCOD,
&                          [M:ENT]STOFCY,[F:STJ]ITMREF,[M:ENTW]PCU(WLIG),
&                          [M:ENTW]QTYPCU(WLIG),[M:ENTW]STA(WLIG),
&                          [M:ENTW]LOCTYP(WLIG),[M:ENTW]LOC(WLIG),
&                          [M:ENT]BPRNUM,"",
&                          string$(evalue("[F:"+LFIC+"]SRGWAIFLG")<>2,'[F:TLO]LOCCAT<>2'),
&                          [M:ENTW]WRH(WLIG)) From STKLOC
            #----- On fait le contrôle afin de récupérer le type d'emplacement -----#
            Raz WRET
            Call STKCTREMP([M:ENTW]WLOCSEQ(WLIG),LTRS,[M:ENT]TRSCOD,
&                          [M:ENT]STOFCY,[F:STJ]ITMREF,[M:ENTW]PCU(WLIG),
&                          [M:ENTW]QTYPCU(WLIG),[M:ENTW]STA(WLIG),
&                          [M:ENTW]LOCTYP(WLIG),[M:ENTW]LOC(WLIG),
&                          [M:ENT]BPRNUM,0,WRET,LOVF,"",
&                          string$(evalue("[F:"+LFIC+"]SRGWAIFLG")<>2,'[F:TLO]LOCCAT<>2'),
&                          [M:ENTW]WRH(WLIG)) From STKLOC
        Endif
        #--- Issue X3-53322
        If evalue("dim("+LABRMSK+"TCTRNUM)")>0
            [M:ENTW]TCTRNUM(WLIG)=evalue(LABRMSK+"TCTRNUM(LLIGDOC)")
            Call CALCUL_NBLPN([M:ENTW]LPNNUM(WLIG),[M:ENTW]TCTRNUM(WLIG),[F:STJ]ITMREF,[M:ENT]STOFCY,[M:ENTW]PCU(WLIG),[M:ENTW]QTYPCU(WLIG),LNBLPN) From STKLPN # hcb X3-64504
           [M:ENTW]NBLPN(WLIG) = LNBLPN                                                                                                                         # hcb X3-64504
        Endif
        #---
    Endif

#recuperation demande analyse du fichier SRU
    If left$([M:ENTW]STA(WLIG),1)="Q"
        [M:ENTW]QLYCTLFLG (WLIG)        = [F:SRU]QLYCTLFLG
    Else
        [M:ENTW]QLYCTLFLG (WLIG)        = 1
    Endif

    # controle coherence des lignes
    If GOUVENT = 0
      # La table TLO doit être positionnée correctement grâce au contrôle précédent
      Call CTR_COHERENCE_LIG("ENTW", [M:ENT]STOFCY, WLIG, LTYP, WRET) From STKENT
      #--- Issue X3-53322
      #If mod(LRET,1024)>=512
      If mod(mod(LRET,4096),2048)>=1024
      #---
          Call MESSAGE(mess(67,184,1)) From GESECRAN
      Endif
      GOUVENT = WRET
    Endif

    # calcul  qtés saisies et total Q et R ----#
    If dim (GTOTQTY) >= 0
           GTOTQTY +=[M:ENTW]QTYSTU(WLIG)
    Endif
    If dim (GQQQQTY) >=0
           If left$([M:ENTW]STA(WLIG),1)= "Q"
              GQQQQTY += [M:ENTW]QTYSTU(WLIG)
           Else
              If left$([M:ENTW]STA(WLIG),1)= "R"
                  GRRRQTY += [M:ENTW]QTYSTU(WLIG)
              Endif
           Endif
    Endif

    #disponible
    #--- Issue X3-53322 : Ajout LPN
    Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&               [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&               [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&               [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
    If WSTOCOU <> 0
        Read [STO]STO0=[F:STJ]STOFCY;WSTOCOU
        # Disponible sur la ligne de stock
        Call STODIS("[F:STO]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
        [M:ENTW]STUDIS(WLIG)        = WSTUDIS
    Endif

    [M:ENTW]WSTOSEQ   (WLIG)        = evalue("[M:"+LABR+"]WSTOSEQ(LLIGDOC)")

    [M:ENTW]NBLIG += 1

    WLIG += 1
    WNBNEWLIG += 1

    If LMESSAGE = ""
        LMESSAGE = GMESSAGE
    Endif

$STJSTOENTW_NEXT
    If LTYP = 32 & LABR = "DBY1"        # hcb 22993
        Break (WQTY=0)                  # hcb 22993
    Endif                               # hcb 22993
Next

Filter [STJ]

# hcb V6CQ freq  deb
If evalue("dim([M:"+LABR+"]QUAFRE)")>0 & evalue(LABRMSK+"QUAFRE(LLIGDOC)") <> 0
   Local Integer LQUA
   Call STKFREQCQ(LABR,[M:ENT]STOFCY,LLIGDOC,[F:ITM]ITMREF,"","F",LQUA,evalue(LABRMSK+"QUAFRE(LLIGDOC)")) From STKACT
   If !GOK
      End
   Endif
Endif
# hcb V6CQ freq  fin


If LMESSAGE<>""
    Raz GMESSAGE
    Call ERREUR(LMESSAGE) From GESECRAN
Endif

# Aucune ligne n'a été ajoutée => erreur, la ligne de document ne peut exister
If WNBNEWLIG=0
# Ce n'est pas au composant de dire que ce n'est pas bon
#    # réception nulle => supprimer la ligne
#    Call ERREUR(mess(202,194,1)) From GESECRAN
    LRET = 2
    # Recherche d'éventuels mouvements en attente
    Filter [STJ] Where evalue(WFILORI) & UPDCOD=1
    #--- Bug 66996 (réactiver le look lorsque le moteur sera en 16r.2xx)
    #Look [STJ] First Hint Key =WKEYSTJ    # CCC (2010-01-12) Bug 61121
    Read [STJ] First Hint Key =WKEYSTJ
    #---
    Filter [STJ]
    If !fstat
        LRET+=4
    Endif
    End
Else
    # Recherche d'éventuels mouvements en attente
    Filter [STJ] Where evalue(WFILORI) & UPDCOD=1
    #--- Bug 66996 (réactiver le look lorsque le moteur sera en 16r.2xx)
    #Look [STJ] First Hint Key =WKEYSTJ    # CCC (2010-01-12) Bug 61121
    Read [STJ] First Hint Key =WKEYSTJ
    #---
    Filter [STJ]
    If !fstat
        LRET=4
    Endif
Endif

# Pour les retours liv prêt/s-traitance et réception liv :
# on conserve la quantité saisie  et non pas celle provenant des mouvements.
# en effet celle-ci peut être saisie (et différente du mouvement) avant l'appel à STJSTOENTW
# Ceci n'est valable que pour ces retours, dans les autres cas cela peut poser problème en particulier s'il
# y a plusieurs mouvements d'origine mais qu'un seul non en attente.
If WNBNEWLIG=1 & find(LTYP,6,13) & evalue("[M:"+LABR+"]"+[M:ENTW]WZONQUS+"(LLIGDOC)")<[M:ENTW]QTYSTU(WLIG-1)
    [M:ENTW]QTYSTU(WLIG-1) = evalue("[M:"+LABR+"]"+[M:ENTW]WZONQUS+"(LLIGDOC)")
    [M:ENTW]QTYPCU(WLIG-1) = [M:ENTW]QTYSTU(WLIG-1)/[M:ENTW]PCUSTUCOE(WLIG-1)
    Call QTEARR([M:ENTW]QTYPCU(WLIG-1), [M:ENTW]PCU(WLIG-1) ) From TRTDIV
Endif

#----- Alimentation des sections analytiques avec les valeurs par défaut ----#
# L'alimentation des sections analytiques n'a lieu qu'à l'ouverture de la fenêtre de détail
# ou à l'enregistrment. C'est donc inutile ici.

# recuperation des info pour la ligne du document
[M:ENT]WSTOSEQ                      = evalue("[M:"+LABR+"]WSTOSEQ(LLIGDOC)")

LQTYSTU = sigma (I=WLIG-WNBNEWLIG,[M:ENTW]NBLIG-1,[M:ENTW]QTYSTU(I))
LPCU    = string$( !!( sigma(I=WLIG-WNBNEWLIG,[M:ENTW]NBLIG-1,([M:ENTW]PCU(WLIG-WNBNEWLIG)=[M:ENTW]PCU(I))) = WNBNEWLIG), [M:ENTW]PCU(WLIG-WNBNEWLIG))
LCOEF   = !!( sigma(I=WLIG-WNBNEWLIG,[M:ENTW]NBLIG-1,([M:ENTW]PCUSTUCOE(WLIG-WNBNEWLIG)=[M:ENTW]PCUSTUCOE(I))) = WNBNEWLIG)* [M:ENTW]PCUSTUCOE(WLIG-WNBNEWLIG)
If LTRS<>19 : # Issue 117565 GH 24/11/2016 - no to do for reintegration
  # Contrôles effectués par les documents
  Gosub CTL_LIGNE_DOCUMENT From TRTSTOENTB
  If mkstat
      LRET=1
      #----- Suppression logique des lignes crées -----#
      For I=WLIG-WNBNEWLIG To [M:ENTW]NBLIG-1
          [M:ENTW]WSTOSEQ(I) = 0
          [M:ENTW]NBLIG = WLIG-WNBNEWLIG
      Next
      End
  Endif
Endif

If evalue("dim([M:"+LABR+"]WSTOFLG)")>LLIGDOC
    Assign "[M:"+LABR+"]WSTOFLG(LLIGDOC)" With !(GOUVENT>1)
Endif

# Donne la main au document origine
Gosub MAJ_LIGNE_DOCUMENT From TRTSTOENTA

#--- Issue X3-53322 : ajout LLPN et LTCTR
Call RECSTO_M ([M:ENT]STOFCY, [M:ENT]WSTOSEQ, [M:ENT]ITMREF,"", LWLOCSEQ,
&              LQTY, LSTA, LLOF, LLOT, LGESLOT, LNBSLO, LSLO, LSLOF,
&              LLOCTYP, LLOC, LSER, LSERF, LPCU, LNBLIGDET,LPAL,LCTR,LMAJ,LMIN,LLPN,LTCTR) From STKECR    # hcb 27200

#------ Affectation des champs stock de la ligne de document ------------#
# CCC (2010-01-26) Bug 61961 : S'il n'y a qu'un seul mouvement en réintégration, on n'écrase pas ce qui a déjà été saisi
If LNBLIGDET>0 & LTRS<>19 | LNBLIGDET>1
    If evalue("dim([M:"+LABR+"]STA)")>=0
      Assign "[M:"+LABR+"]STA(LLIGDOC)" With LSTA
    Endif
    If evalue("dim([M:"+LABR+"]PALNUM)")>=0
      Assign "[M:"+LABR+"]PALNUM(LLIGDOC)" With LPAL
    Endif
    If evalue("dim([M:"+LABR+"]CTRNUM)")>=0
      Assign "[M:"+LABR+"]CTRNUM(LLIGDOC)" With LCTR
    Endif
    If evalue("dim([M:"+LABR+"]BPSLOT)")>=0 & [F:ITM]LOTMGTCOD>1
      Assign "[M:"+LABR+"]BPSLOT(LLIGDOC)" With LLOF
    Endif
    If evalue("dim([M:"+LABR+"]LOT)")>=0 & [F:ITM]LOTMGTCOD>1
      Assign "[M:"+LABR+"]LOT(LLIGDOC)" With LLOT
    Endif
    If evalue("dim([M:"+LABR+"]LOCTYP)")>=0 & [F:ITF]LOCMGTCOD=2
      Assign "[M:"+LABR+"]LOCTYP(LLIGDOC)" With LLOCTYP
    Endif
    If evalue("dim([M:"+LABR+"]LOC)")>=0 & [F:ITF]LOCMGTCOD=2
      Assign "[M:"+LABR+"]LOC(LLIGDOC)" With LLOC
    Endif
    #If evalue("dim([M:"+LABR+"]WRH)")>=0 & [F:FCY]WRHGES=2
    #  Assign "[M:"+LABR+"]WRH(LLIGDOC)" With LWRH
    #Endif
    If evalue("dim([M:"+LABR+"]SERNUM)")>=0 & [F:ITM]SERMGTCOD>1
      Assign "[M:"+LABR+"]SERNUM(LLIGDOC)" With LSER
    Endif
    If evalue("dim([M:"+LABR+"]SERNUMF)")>=0 & [F:ITM]SERMGTCOD>1
      Assign "[M:"+LABR+"]SERNUMF(LLIGDOC)" With LSERF
    Endif
#                                                      # hcb 71276 deb
    If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>=0 & [F:ITM]ECCSTO >1
      Assign "[M:"+LABR+"]ECCVALMAJ(LLIGDOC)" With LMAJ
    Endif
    If evalue("dim([M:"+LABR+"]ECCVALMIN)")>=0 & [F:ITM]ECCSTO = 3
      Assign "[M:"+LABR+"]ECCVALMIN(LLIGDOC)" With LMIN
    Endif
#                                                      # hcb 71276 deb
    #--- Issue X3-53322
    If evalue("dim([M:"+LABR+"]LPNNUM)")>=0 & [F:ITF]LPNMGTCOD=2
      Assign "[M:"+LABR+"]LPNNUM(LLIGDOC)"    With LLPN
      Assign "[M:"+LABR+"]TCTRNUM(LLIGDOC)"  With LTCTR
    Endif
    #---
    If evalue("dim([M:"+LABR+"]NBSLO)")>=0 & [F:ITM]LOTMGTCOD=4
      Assign "[M:"+LABR+"]NBSLO(LLIGDOC)" With LNBSLO
    Endif
    If evalue("dim([M:"+LABR+"]SLO)")>=0 & [F:ITM]LOTMGTCOD=4
      Assign "[M:"+LABR+"]SLO(LLIGDOC)" With LSLO
    Endif
    If evalue("dim([M:"+LABR+"]SLOF)")>=0 & [F:ITM]LOTMGTCOD=4
      Assign "[M:"+LABR+"]SLOF(LLIGDOC)" With LSLOF
    Endif
    Assign "[M:"+LABR+"]GESLOT(LLIGDOC)" With LGESLOT
    If evalue("dim([M:"+LABR+"]WLOCSEQ)")>=0
      Assign "[M:"+LABR+"]WLOCSEQ(LLIGDOC)" With LWLOCSEQ
    Endif
Endif

End


############################################################
# RECPRISTJ : Recherche le prix d'ordre de la ligne d'un document
############################################################
# Paramètres E : PFCY    = Site
#                PVCRTYP = Type de document
#                PVCRNUM = N° de document
#                PVCRLIN = N° de ligne du document
#
#            S : PPRI    = Prix de l'ordre
#
############################################################
Subprog RECPRISTJ(PFCY,PVCRTYP,PVCRNUM,PVCRLIN,PPRI)
Value Char    PFCY
Value Integer PVCRTYP
Value Char    PVCRNUM
Value Integer PVCRLIN
Variable Decimal PPRI

Columns [F:STJ](PRIORD)
For [STJ]STJ1 Where STOFCY = PFCY
&                 & VCRTYP = PVCRTYP
&                 & VCRNUM = PVCRNUM
&                 & VCRLIN = PVCRLIN
&                 & REGFLG <> 2
    PPRI = [F:STJ]PRIORD
    Break
Next
Columns [F:STJ]
End


#--- Issue 117545
# Passage de ADDLOTBLANC dans STKENTA
#Subprog ADDLOTBLANC( PABR )
#---


###############################################################################
# SETCPTLOT : Alimentation du complément lot dans STOENTW
###############################################################################
# Paramètres E : PABR    = Abréviation écran
#                PLIGLOT = Indice de la ligne à renseigner
#                PPOT    = Titre
#                PACT    = Titre UI
#                PREFPER = Date référence péremption
#                PSHL    = Délai de péremption
#                PSHLDAT = Date de péremption
#                PUSRFLDn= Rubrique utilisateur n
#                PMODIF  = Complément modifiable (1=non, 2=oui)
#                PVALIDE = Complément validé (1=non, 2=oui)
#
###############################################################################
Subprog SETCPTLOT(PABR, PLIGLOT, PLOT,PSLO,PLOF,PGES, PPOT,PACT,PREFPER,PSHL,
&                 PSHLDAT,PSHLUOM,PSHLLTI,PSHLLTIUOM,PNEWLTIDAT,PDLU,PDLUDAT,
&                 PUSRFLD1,PUSRFLD2,PUSRFLD3,PUSRFLD4, PMODIF,PMAJ,PMIN,PECC,PVALIDE)
Value Char    PABR
Value Integer PLIGLOT
Value Char    PLOT
Value Char    PSLO
Value Char    PLOF
Value Char    PGES
Value Decimal PPOT
Value Decimal PACT
Value Date    PREFPER
Value Integer PSHL
Value Date    PSHLDAT
Value Integer PSHLUOM              # hcb V6per
Value Integer PSHLLTI              # hcb V6per
Value Integer PSHLLTIUOM           # hcb V6per
Value Date    PNEWLTIDAT           # hcb V6per
Value Decimal PDLU                 # hcb V6per
Value Date    PDLUDAT              # hcb V6per
Value Char    PUSRFLD1
Value Char    PUSRFLD2
Value Decimal PUSRFLD3
Value Date    PUSRFLD4
Value Integer PMODIF
Value Char    PMAJ
Value Char    PMIN
Value Integer PECC
Value Integer PVALIDE

If PLIGLOT+1 > evalue("dim([M:"+PABR+"]LOT)")   # hcb 53297
   Call MESSAGE(mess(70,184,1)) From GESECRAN   # hcb 53297
   End                                          # hcb 53297
Endif                                           # hcb 53297

    Assign "[M:"+PABR+"]LOT       (PLIGLOT)" With PLOT
   # Issue 109614 - 2015-07-17 by SR
    If evalue("dim([M:"+PABR+"]SLO)")>0
      Assign "[M:"+PABR+"]SLO       (PLIGLOT)" With PSLO
    Endif
    # End issue 109614
    Assign "[M:"+PABR+"]BPSLOT    (PLIGLOT)" With PLOF
    Assign "[M:"+PABR+"]GESLOT    (PLIGLOT)" With PGES
    Assign "[M:"+PABR+"]POT       (PLIGLOT)" With PPOT
    Assign "[M:"+PABR+"]ACT       (PLIGLOT)" With PACT
    Assign "[M:"+PABR+"]REFPER    (PLIGLOT)" With PREFPER
    Assign "[M:"+PABR+"]SHL       (PLIGLOT)" With PSHL
    Assign "[M:"+PABR+"]SHLDAT    (PLIGLOT)" With PSHLDAT
    Assign "[M:"+PABR+"]SHLUOM    (PLIGLOT)" With PSHLUOM      # hcb V6per
    Assign "[M:"+PABR+"]SHLLTI    (PLIGLOT)" With PSHLLTI      # hcb V6per
    Assign "[M:"+PABR+"]SHLLTIUOM (PLIGLOT)" With PSHLLTIUOM   # hcb V6per
    Assign "[M:"+PABR+"]NEWLTIDAT (PLIGLOT)" With PNEWLTIDAT   # hcb V6per
    Assign "[M:"+PABR+"]DLU       (PLIGLOT)" With PDLU         # hcb V6per
    Assign "[M:"+PABR+"]DLUDAT    (PLIGLOT)" With PDLUDAT      # hcb V6per
    Assign "[M:"+PABR+"]USRFLD1   (PLIGLOT)" With PUSRFLD1
    Assign "[M:"+PABR+"]USRFLD2   (PLIGLOT)" With PUSRFLD2
    Assign "[M:"+PABR+"]USRFLD3   (PLIGLOT)" With PUSRFLD3
    Assign "[M:"+PABR+"]USRFLD4   (PLIGLOT)" With PUSRFLD4
    Assign "[M:"+PABR+"]MODIF     (PLIGLOT)" With PMODIF
#                                                      # hcb 71276 deb

    If evalue("dim([M:"+PABR+"]ECCVALMAJ)")>0
       Assign "[M:"+PABR+"]ECCVALMIN (PLIGLOT)" With PMIN
       Assign "[M:"+PABR+"]ECCVALMAJ (PLIGLOT)" With PMAJ
       If evalue("dim([M:"+PABR+"]ECCSAIFLG)")>0
          Assign "[M:"+PABR+"]ECCSAIFLG (PLIGLOT)" With PECC
       Endif
    Endif
    Assign "[M:"+PABR+"]VALIDE    (PLIGLOT)" With PVALIDE
#                                                      # hcb 71276 fin

End


###############################################################################
# SETCPTLOTAUTO : Renseigne le complément lot en fin de saisie d'une ligne
###############################################################################
# Paramètres E : PITM    = Article
#                PABR    = Masque de l'écran concerné (ENT, ENM ou ENTW)
#                PNOLNUM = Indice de la ligne du masque qui contient NUMLIGLOT
#                PLOT    = Numéro de lot
#                PSLO    = Numéro de sous lot
#                PLOF    = Numéro de lot fournisseur
#                PGESLOT = Type de n° de lot: ""  -> N° lot saisi
#                                             "B" -> N° lot = Blanc
#                                             "C" -> N° lot = N° de compteur
#                                             "V" -> N° lot = N° de pièce
#
#            S : PRET    = Indique s'il faut ouvrir la fenêtre complément lot
#                       (1=Non, 2=Oui)
#
# Appelé dans STKFILLENTW ou en APRES_LIGNE dans STOENT et STOENTM
#
# Attention: Il faut que GOUVLOT soit positionnée
###############################################################################
Subprog SETCPTLOTAUTO ( PITM, PABR, PNOLNUM, PLOT, PSLO, PLOF, PGESLOT, PMAJ, PMIN,PECC, PRET)
Value    Char    PITM
Value    Char    PABR
Value    Integer PNOLNUM
Value    Char    PLOT
Value    Char    PSLO
Value    Char    PGESLOT
Value    Char    PLOF
Value    Char    PMAJ
Value    Char    PMIN
Value    Integer PECC
Variable Integer PRET


Local Integer WMODIF     # hcb unicite
Local Integer WVALID     # hcb unicite
Raz WMODIF , WVALID      # hcb unicite
Local Integer LNUMLIGLOT
LNUMLIGLOT = -1

Default Mask "["+PABR+"]"

PRET = 1

If [M]NBLIGLOT=0
    #--- Issue 117545
    #Call ADDLOTBLANC(PABR) From STKENT
    Call ADDLOTBLANC(PABR) From STKENTA
    #---
Endif

If PGESLOT="B"
    [M]NUMLIGLOT(PNOLNUM) = 0
    End
Endif

If PLOT="" and PSLO="" and PGESLOT=""
    If PLOF=""
        [M]NUMLIGLOT(PNOLNUM) = -1
        End
    Else
        [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
        Gosub DEFLOT
        PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
        [M]NBLIGLOT += 1
    Endif
Endif
# test si lot geré avec compteur et origine  ligne du document
# dans ce cas il faut un complement lot <> par ligne de document
If PGESLOT = "C"
    If PABR="ENT" | PABR = "ENM"
        Call SEARCHGESLOT( PABR, PGESLOT, PLOF, PSLO, -1, LNUMLIGLOT) From STKENTA
        If LNUMLIGLOT>=0
            # Il faut récupérer le lot fournisseur au cas où il n'y ai que ce champ qui ait été modifié
            [M]BPSLOT(LNUMLIGLOT) = PLOF
            [M]NUMLIGLOT(PNOLNUM) = LNUMLIGLOT
            PRET = !([M]VALIDE(LNUMLIGLOT)-1)+1
            End
        Endif
        If PABR="ENT"
            Call SEARCHGESLOTW( "C", PLOF, PSLO, [M]WSTOSEQ, LNUMLIGLOT ) From STKENTA
            If LNUMLIGLOT>=0
                Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                           PLOT, PSLO, PLOF, PGESLOT,
&                           [M:ENTW]POT       (LNUMLIGLOT),
&                           [M:ENTW]ACT       (LNUMLIGLOT),
&                           [M:ENTW]REFPER    (LNUMLIGLOT),
&                           [M:ENTW]SHL       (LNUMLIGLOT),
&                           [M:ENTW]SHLDAT    (LNUMLIGLOT),
&                           [M:ENTW]SHLUOM    (LNUMLIGLOT),
&                           [M:ENTW]SHLLTI    (LNUMLIGLOT),
&                           [M:ENTW]SHLLTIUOM (LNUMLIGLOT),
&                           [M:ENTW]NEWLTIDAT (LNUMLIGLOT),
&                           [M:ENTW]DLU       (LNUMLIGLOT),
&                           [M:ENTW]DLUDAT    (LNUMLIGLOT),
&                           [M:ENTW]USRFLD1   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD2   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD3   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD4   (LNUMLIGLOT),
&                           [M:ENTW]MODIF     (LNUMLIGLOT),
&                           PMAJ,
&                           PMIN,
&                           PECC,
&                           [M:ENTW]VALIDE    (LNUMLIGLOT))
                [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
                PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
                [M]NBLIGLOT += 1
#               End                                                                # hcb 53297
                Goto CTR_NBLIG                                                     # hcb 53297
            Endif
        Endif
        Call SEARCHGESLOT( PABR, PGESLOT, PLOF, "", -1, LNUMLIGLOT) From STKENTA
        If LNUMLIGLOT>=0
            Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                           PLOT, PSLO, PLOF, PGESLOT,
&                           [M]POT       (LNUMLIGLOT),
&                           [M]ACT       (LNUMLIGLOT),
&                           [M]REFPER    (LNUMLIGLOT),
&                           [M]SHL       (LNUMLIGLOT),
&                           [M]SHLDAT    (LNUMLIGLOT),
&                           [M]SHLUOM    (LNUMLIGLOT),
&                           [M]SHLLTI    (LNUMLIGLOT),
&                           [M]SHLLTIUOM (LNUMLIGLOT),
&                           [M]NEWLTIDAT (LNUMLIGLOT),
&                           [M]DLU       (LNUMLIGLOT),
&                           [M]DLUDAT    (LNUMLIGLOT),
&                           [M]USRFLD1   (LNUMLIGLOT),
&                           [M]USRFLD2   (LNUMLIGLOT),
&                           [M]USRFLD3   (LNUMLIGLOT),
&                           [M]USRFLD4   (LNUMLIGLOT),
&                           [M]MODIF     (LNUMLIGLOT),
&                           PMAJ,
&                           PMIN,
&                           PECC,
&                           [M]VALIDE    (LNUMLIGLOT))
            [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
            PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
            [M]NBLIGLOT += 1
#           End                                                                # hcb 53297
            Goto CTR_NBLIG                                                     # hcb 53297
        Endif
    Endif
#------- Si on pointe déjà sur un lot qui ne correspond pas on passe par DEFLOT --------#
    If [M]NUMLIGLOT(PNOLNUM) = -1 | [M]NUMLIGLOT(PNOLNUM) = 0
&     | [M]GESLOT([M]NUMLIGLOT(PNOLNUM))<>"C" | [M]SLO([M]NUMLIGLOT(PNOLNUM))<>PSLO
        [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
        Gosub DEFLOT
        PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
        [M]NBLIGLOT += 1
    Endif
#   End                                                                # hcb 53297
    Goto CTR_NBLIG                                                     # hcb 53297
Endif

Case PABR
    When "ENT" : Call SEARCHLOTENT ( PLOT, PSLO, -1, LNUMLIGLOT) From STKENTA
    When "ENM" : Call SEARCHLOTENM ( PLOT, PSLO, -1, LNUMLIGLOT) From STKENTA
Endcase

#--- Issue 109931 puis issue 111715 (ajout test [M:ENTW]...)
If PNOLNUM>0 & PABR="ENTW" & [M:ENTW]NUMLIGLOT(PNOLNUM-1)>=0
   If PLOT=[M:ENTW]LOT([M:ENTW]NUMLIGLOT(PNOLNUM-1)) & PSLO=[M:ENTW]SLO([M:ENTW]NUMLIGLOT(PNOLNUM-1))  & PITM=[M:ENTW]ITMREF(PNOLNUM-1)     # hcb 121452
      LNUMLIGLOT = [M:ENTW]NUMLIGLOT(PNOLNUM-1)
      # Issue 118402 - 2016-09-12 by SR : Récupérer le lot fournisseur
      [M]BPSLOT(LNUMLIGLOT) = PLOF        # Le lot fournisseur est bon (contrôlé avant) et doit donc être récupéré tel quel
      [M:ENTW]NUMLIGLOT(PNOLNUM) = LNUMLIGLOT
      PRET = !([M]VALIDE(LNUMLIGLOT)-1)+1
      Goto CTR_NBLIG
   Endif
Endif
#---

If LNUMLIGLOT>=0
    [M]BPSLOT(LNUMLIGLOT) = PLOF        # Le lot fournisseur est bon (contrôlé avant) et doit donc être récupéré tel quel
    [M]NUMLIGLOT(PNOLNUM) = LNUMLIGLOT
    PRET = !([M]VALIDE([M]NUMLIGLOT)-1)+1
    End
Else
    Call SEARCHLOTENTW ( PITM, PLOT, PSLO, -1, LNUMLIGLOT) From STKENTA
    # Lot trouvé dans stoentw

    If LNUMLIGLOT>=0
        # ajouter le complément lot dans ENT ou ENM ou le lien po
        If PABR<>"ENTW"
            Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                           PLOT, PSLO, PLOF, PGESLOT,
&                           [M:ENTW]POT       (LNUMLIGLOT),
&                           [M:ENTW]ACT       (LNUMLIGLOT),
&                           [M:ENTW]REFPER    (LNUMLIGLOT),
&                           [M:ENTW]SHL       (LNUMLIGLOT),
&                           [M:ENTW]SHLDAT    (LNUMLIGLOT),
&                           [M:ENTW]SHLUOM    (LNUMLIGLOT),
&                           [M:ENTW]SHLLTI    (LNUMLIGLOT),
&                           [M:ENTW]SHLLTIUOM (LNUMLIGLOT),
&                           [M:ENTW]NEWLTIDAT (LNUMLIGLOT),
&                           [M:ENTW]DLU       (LNUMLIGLOT),
&                           [M:ENTW]DLUDAT    (LNUMLIGLOT),
&                           [M:ENTW]USRFLD1   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD2   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD3   (LNUMLIGLOT),
&                           [M:ENTW]USRFLD4   (LNUMLIGLOT),
&                           [M:ENTW]MODIF     (LNUMLIGLOT),
&                           PMAJ ,
&                           PMIN ,
&                           PECC ,
&                           [M:ENTW]VALIDE    (LNUMLIGLOT))
            [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
            PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
            [M]NBLIGLOT += 1
        Else
            [M]BPSLOT(LNUMLIGLOT) = PLOF    # Le lot fournisseur a été contrôlé, il est donc considéré ici comme correct
            [M]NUMLIGLOT(PNOLNUM) = LNUMLIGLOT
            PRET = !([M]VALIDE(LNUMLIGLOT)-1)+1
        Endif
#       End                                                                # hcb 53297
        Goto CTR_NBLIG                                                     # hcb 53297
    Else # LOT+SLO introuvable dans les masques
        # => On cherche dans le fichier STOLOT si lot n'est pas numéro de pièce
        If PLOT <>""
            Filter [F:STL] Where ITMREF = PITM    &
&                                LOT    = PLOT &
&                                SLO    = PSLO
&                                Order By Key STL0
            Read [STL] First
            If !fstat
                Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                               PLOT, PSLO, [F:STL]BPSLOT, PGESLOT,
&                               [F:STL]POT,
&                               [F:STL]ACT,
&                               [F:STL]REFPER,
&                               [F:STL]SHL,
&                               [F:STL]SHLDAT,
&                               [F:STL]SHLUOM,
&                               [F:STL]SHLLTI,
&                               [F:STL]SHLLTIUOM,
&                               [F:STL]NEWLTIDAT,
&                               [F:STL]DLU,
&                               [F:STL]DLUDAT,
&                               [F:STL]USRFLD1,
&                               [F:STL]USRFLD2,
&                               [F:STL]USRFLD3,
&                               [F:STL]USRFLD4,
&                               1,
&                               PMAJ,
&                               PMIN,
&                               PECC,
&                               2)
                [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
                PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
                [M]NBLIGLOT += 1

                Filter [F:STL]
#               End                                                                # hcb 53297
                Goto CTR_NBLIG                                                     # hcb 53297
            Endif
            Filter [F:STL]
        Endif
        If PSLO<>""

            # Si LOT+SLO n'a pas été trouvé dans le fichier
            # on regarde si LOT existe dans le masque courant, ENTW ou le fichier STOLOT
            # S'il est trouvé, il sera considéré comme validé et modifiable
            Case PABR
                When "ENT" : Call SEARCHLOTENT ( PLOT, "", -1, LNUMLIGLOT) From STKENTA
                When "ENM" : Call SEARCHLOTENM ( PLOT, "", -1, LNUMLIGLOT) From STKENTA
            Endcase
            If LNUMLIGLOT>=0
                WMODIF = 2                               # hcb unicite
                If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV = 2   # hcb unicite
                   WMODIF = 1                            # hcb unicite
                Endif
                Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                               PLOT, PSLO, PLOF, PGESLOT,
&                               [M]POT       (LNUMLIGLOT),
&                               [M]ACT       (LNUMLIGLOT),
&                               [M]REFPER    (LNUMLIGLOT),
&                               [M]SHL       (LNUMLIGLOT),
&                               [M]SHLDAT    (LNUMLIGLOT),
&                               [M]SHLUOM    (LNUMLIGLOT),
&                               [M]SHLLTI    (LNUMLIGLOT),
&                               [M]SHLLTIUOM (LNUMLIGLOT),
&                               [M]NEWLTIDAT (LNUMLIGLOT),
&                               [M]DLU       (LNUMLIGLOT),
&                               [M]DLUDAT    (LNUMLIGLOT),
&                               [M]USRFLD1   (LNUMLIGLOT),
&                               [M]USRFLD2   (LNUMLIGLOT),
&                               [M]USRFLD3   (LNUMLIGLOT),
&                               [M]USRFLD4   (LNUMLIGLOT),
&                               WMODIF,
&                               PMAJ,
&                               PMIN,
&                               PECC,
&                               [M]VALIDE    (LNUMLIGLOT))
                [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
                PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
                [M]NBLIGLOT += 1
#               End                                                                # hcb 53297
                Goto CTR_NBLIG                                                     # hcb 53297
            Else
                Call SEARCHLOTENTW ( PITM, PLOT, "", -1, LNUMLIGLOT) From STKENTA

                # Lot trouvé dans stoentw
                If LNUMLIGLOT>=0
                   WMODIF = 2                                # hcb unicite
                   If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV = 2    # hcb unicite
                      WMODIF = [M:ENTW]MODIF    (LNUMLIGLOT) # hcb unicite
                   Endif
                    Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                                   PLOT, PSLO, PLOF, PGESLOT,
&                                   [M:ENTW]POT       (LNUMLIGLOT),
&                                   [M:ENTW]ACT       (LNUMLIGLOT),
&                                   [M:ENTW]REFPER    (LNUMLIGLOT),
&                                   [M:ENTW]SHL       (LNUMLIGLOT),
&                                   [M:ENTW]SHLDAT    (LNUMLIGLOT),
&                                   [M:ENTW]SHLUOM    (LNUMLIGLOT),
&                                   [M:ENTW]SHLLTI    (LNUMLIGLOT),
&                                   [M:ENTW]SHLLTIUOM (LNUMLIGLOT),
&                                   [M:ENTW]NEWLTIDAT (LNUMLIGLOT),
&                                   [M:ENTW]DLU       (LNUMLIGLOT),
&                                   [M:ENTW]DLUDAT    (LNUMLIGLOT),
&                                   [M:ENTW]USRFLD1   (LNUMLIGLOT),
&                                   [M:ENTW]USRFLD2   (LNUMLIGLOT),
&                                   [M:ENTW]USRFLD3   (LNUMLIGLOT),
&                                   [M:ENTW]USRFLD4   (LNUMLIGLOT),
&                                   WMODIF,
&                                   PMAJ,
&                                   PMIN,
&                                   PECC,
&                                   [M:ENTW]VALIDE    (LNUMLIGLOT))
                    [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
                    PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
                    [M]NBLIGLOT += 1
#                   End                                                                # hcb 53297
                    Goto CTR_NBLIG                                                     # hcb 53297
                Endif
            Endif
            If PLOT<>""
                Filter [F:STL] Where ITMREF = PITM    &
&                                LOT    = PLOT
&                                Order By Key STL0
                Read [STL] First
                If !fstat
                    WMODIF = 2                               # hcb unicite
                    WVALID = 2                               # hcb unicite
                    If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV = 2   # hcb unicite
                       WMODIF = 1                            # hcb unicite
                    Endif
                    Call SETCPTLOT( PABR, [M]NBLIGLOT,
&                                   PLOT, PSLO, [F:STL]BPSLOT, PGESLOT,
&                                   [F:STL]POT,
&                                   [F:STL]ACT,
&                                   [F:STL]REFPER,
&                                   [F:STL]SHL,
&                                   [F:STL]SHLDAT,
&                                   [F:STL]SHLUOM,
&                                   [F:STL]SHLLTI,
&                                   [F:STL]SHLLTIUOM,
&                                   [F:STL]NEWLTIDAT,
&                                   [F:STL]DLU,
&                                   [F:STL]DLUDAT,
&                                   [F:STL]USRFLD1,
&                                   [F:STL]USRFLD2,
&                                   [F:STL]USRFLD3,
&                                   [F:STL]USRFLD4,
&                                   WMODIF,
&                                   PMAJ,
&                                   PMIN,
&                                   PECC,
&                                   WVALID)


                    If [F:ITM]LOTMGTCOD=4 & GFEALOTLEV <> 2                              # hcb unicite
                       If [F:ITM]EXYMGTCOD > 1 & [F:STL]REFPER < date$
                          [M]REFPER([M]NBLIGLOT) = date$
                          Gosub CAL_PEREMPTION
                       Endif
                    Endif                                                                # hcb unicite
                    [M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
                    PRET = !([M]VALIDE([M]NBLIGLOT)-1)+1
                    [M]NBLIGLOT += 1

                    Filter [F:STL]
#                   End                                                                # hcb 53297
                    Goto CTR_NBLIG                                                     # hcb 53297
                Endif
                Filter [F:STL]
            Endif
        Endif # Si PSLO<>""
    Endif    # Si LOT + SLO trouvé dans masque ENTW
Endif    # Si LOT+SLO trouvé dans le masque passé en paramètre (ENT ou ENM)

[M]NUMLIGLOT(PNOLNUM) = [M]NBLIGLOT
[M]NBLIGLOT += 1
Gosub DEFLOT

PRET = 2
If [M]NBLIGLOT >= dim([M]LOT)                                  # hcb 53297
   Call MESSAGE(mess(70,184,1)) From GESECRAN                  # hcb 53297
Endif                                                          # hcb 53297
End                                                            # hcb 53297
$CTR_NBLIG                                                     # hcb 53297
If [M]NBLIGLOT >= dim([M]LOT)                                  # hcb 53297
   Call MESSAGE(mess(70,184,1)) From GESECRAN                  # hcb 53297
Endif                                                          # hcb 53297

End

###########################################################
# DEFLOT : Affectation de valeurs par defaut au complément lot
###########################################################
# Attention!
# Si GOUVLOT<2, ce complément par défaut est considéré comme validé
###########################################################
$DEFLOT
Local Char    PZONMAJ              # hcb 71276
Local Char    PZONMIN              # hcb 71276
Local Integer TYPTIERS             # hcb 71276
Local Char    BPRNUM               # hcb 71276
Local Char    PZONMAJORI           # hcb 71276
Local Char    PZONMINORI           # hcb 71276

If [M]NUMLIGLOT(PNOLNUM) >= dim([M]LOT)                        # hcb 53297
   Call MESSAGE(mess(70,184,1)) From GESECRAN                  # hcb 53297
   Return                                                      # hcb 53297
Endif                                                          # hcb 53297

[M]LOT([M]NUMLIGLOT(PNOLNUM))    = PLOT
[M]SLO([M]NUMLIGLOT(PNOLNUM))    = PSLO
[M]ECCVALMAJ([M]NUMLIGLOT(PNOLNUM))  = PMAJ
[M]ECCVALMIN([M]NUMLIGLOT(PNOLNUM))  = PMIN
[M]ECCSAIFLG([M]NUMLIGLOT(PNOLNUM))  = PECC
[M]GESLOT([M]NUMLIGLOT(PNOLNUM)) = PGESLOT
[M]BPSLOT([M]NUMLIGLOT(PNOLNUM)) = PLOF
[M]MODIF ([M]NUMLIGLOT(PNOLNUM)) = 2
If GOUVLOT<2
    [M]VALIDE([M]NUMLIGLOT(PNOLNUM)) = 2
Else
    [M]VALIDE([M]NUMLIGLOT(PNOLNUM)) = 1
Endif
Raz [M]USRFLD1([M]NUMLIGLOT(PNOLNUM))
Raz [M]USRFLD2([M]NUMLIGLOT(PNOLNUM))
Raz [M]USRFLD3([M]NUMLIGLOT(PNOLNUM))
Raz [M]USRFLD4([M]NUMLIGLOT(PNOLNUM))
[M]SHL        ([M]NUMLIGLOT(PNOLNUM)) = [F:ITM]SHL
[M]SHLUOM     ([M]NUMLIGLOT(PNOLNUM)) = [F:ITM]SHLUOM
[M]SHLLTI     ([M]NUMLIGLOT(PNOLNUM)) = [F:ITF]SHLLTI
[M]SHLLTIUOM  ([M]NUMLIGLOT(PNOLNUM)) = [F:ITF]SHLLTIUOM
[M]DLU        ([M]NUMLIGLOT(PNOLNUM)) = [F:ITF]DLU
[M]POT        ([M]NUMLIGLOT(PNOLNUM)) = 100
[M]ACT        ([M]NUMLIGLOT(PNOLNUM)) = 1

Case [F:ITF]STOMGTCOD
    When 3 : [M]POT([M]NUMLIGLOT(PNOLNUM)) = [F:ITM]DEFPOT
Endcase
If [F:ITM]EXYMGTCOD > 1
   Gosub CAL_PEREMPTION
Endif
#                                            # hcb 71276  deb

If [F:ITM]ECCSTO > 1 & PMAJ = "" & PABR <> "ENTW" & PECC = 0

   Local Integer NOL
   NOL = [M]NUMLIGLOT(PNOLNUM)
   Raz PZONMAJORI
   Raz PZONMINORI
   PZONMAJ = "ECCVALMAJ"
   PZONMIN = "ECCVALMIN"
   If PABR = "ENT" | PABR = "ENM"
      PZONMAJ    = "ECCVALMAJAFF"
      PZONMIN    = "ECCVALMINAFF"
      PZONMAJORI = "ECCVALMAJORI"
      PZONMINORI = "ECCVALMINORI"
      TYPTIERS   = [M]TYPBPR
      BPRNUM     = [M]BPRNUM
      Call STKINIECC([F:ITM]ITMREF,PLOT,PABR,2,2,NOL,2,PMAJ,PZONMAJ,PZONMIN,PZONMAJORI,PZONMINORI,TYPTIERS,BPRNUM) From STKACT
   Else
 # recherche parametres typtiers et tiers  de la zone lot dans amskpar
      Call PAR_AMSKZON_LOT(PABR,TYPTIERS,BPRNUM,PZONMAJORI,PZONMINORI) From STKACT
      Call STKINIECC([F:ITM]ITMREF,PLOT,PABR,2,2,NOL,2,PMAJ,PZONMAJ,PZONMIN,PZONMAJORI,PZONMINORI,TYPTIERS,evalue(BPRNUM)) From STKACT
   Endif
Endif
#                                            # hcb 71276  fin

#CHECK IGNORE_BEGIN
GPOINT = "DEFLOT"                        # hcb 105057
Gosub  ENTREE From EXEFNC                # hcb 105057
#CHECK IGNORE_END


Return

###########################################################
$CAL_PEREMPTION
Local    Integer  WCOD
Local    Date     WREF
Local    Integer  WSHL
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


If [M]REFPER([M]NUMLIGLOT(PNOLNUM)) = [0/0/0]
    [M]REFPER([M]NUMLIGLOT(PNOLNUM)) = date$
Endif
If dim([F:ITM]EXYMGTCOD) > 0
    If [F:ITM]EXYMGTCOD < 2
        [M]SHLDAT    ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
        [M]NEWLTIDAT ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
        [M]DLUDAT    ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
    Else
        WCOD = [F:ITM]EXYMGTCOD
        WREF = [M]REFPER    ([M]NUMLIGLOT(PNOLNUM))
        WSHL = [M]SHL       ([M]NUMLIGLOT(PNOLNUM))
        WUOM = [M]SHLUOM    ([M]NUMLIGLOT(PNOLNUM))
        WDLU = [M]DLU       ([M]NUMLIGLOT(PNOLNUM))

        Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
        [M]SHLDAT           ([M]NUMLIGLOT(PNOLNUM))   = WPER
        WEXY = WPER
        Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
        [M]DLUDAT           ([M]NUMLIGLOT(PNOLNUM))   = WPER

        WSHL = [M]SHLLTI    ([M]NUMLIGLOT(PNOLNUM))
        WUOM = [M]SHLLTIUOM ([M]NUMLIGLOT(PNOLNUM))
        Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
        [M]NEWLTIDAT        ([M]NUMLIGLOT(PNOLNUM))   = WPER

#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
        If [M]NEWLTIDAT ([M]NUMLIGLOT(PNOLNUM)) <> [31/12/2999]
           If [M]NEWLTIDAT ([M]NUMLIGLOT(PNOLNUM)) > [M]DLUDAT  ([M]NUMLIGLOT(PNOLNUM))
              [M]NEWLTIDAT ([M]NUMLIGLOT(PNOLNUM)) = [M]DLUDAT  ([M]NUMLIGLOT(PNOLNUM))
           Endif
        Endif

    Endif
Else
    [M]SHLDAT    ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
    [M]NEWLTIDAT ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
    [M]DLUDAT    ([M]NUMLIGLOT(PNOLNUM))     = [31/12/2999]
Endif

Return


##################################################
Subprog DIVENTLOT()
#---------------------------------------------------------------------#
# Avant ouverture de la fenêtre complément lot                        #
#---------------------------------------------------------------------#
GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT = 1                         # permet de passer le test de l'ouverture de la fenetre complément lot
End

#########################################################################
# DELETEMVT    : Supprime les mouvements de lignes de documents d'entrées
#------------------------------------------------------------------------
#
#########################################################################
Subprog DELETEMVT( PABR, PLIG, PLIG1, PVCRTYP, PTRSTAB, PFCY, PBPR, PTRSTYP, PTRSCOD )
Value Integer PLIG    # Indice 1ère ligne à supprimer
Value Integer PLIG1   # Indice dernière ligne à supprimer
Value Char    PABR    # Abéviation masque document
Value Integer PVCRTYP
Value Char    PTRSTAB
Value Char    PFCY
Value Char    PBPR
Value Integer PTRSTYP
Value Char    PTRSCOD

Local Integer LOK
Local Integer WSAVSTATUS, WSAVNOLIGN
Global Integer GDELMVT  # Signale qu'on est en contrôle sur la ligne de document (utilisé pour éviter les message en suppression de ligne)

Local Integer FIN : Raz FIN
Local Char    LMESSAGE(255) : Raz LMESSAGE
Local Char PARAM(30)(10)
PARAM(1) = num$(PVCRTYP)
PARAM(2) = PABR
PARAM(3) = ""
PARAM(5) = PFCY
PARAM(6) = PBPR
PARAM(7) = num$(PTRSTYP)
PARAM(8) = PTRSCOD


If clalev([M:ENM])=0 Local Mask STOENTM   [ENM] Endif  #  ecran stockage
Default Mask "["+PABR+"]"

WSAVSTATUS = status
WSAVNOLIGN = nolign
GDELMVT    = 1

If dim(GDELDOC)<=0 | GDELDOC<>1
    LOK = 2
    Call AVERTIR(mess(88,184,1),LOK) From GESECRAN
    If LOK<>2
        GOK=0
        mkstat=2
        Goto FIN_DELETEMVT
    Endif
Endif

For I=PLIG To PLIG1
    Raz mkstat
    Raz GMESSAGE
    Raz FIN
    PARAM(4) = num$(I)
    Gosub OUVRE_BOITE From TRTSTOENM
    If !FIN
        Gosub DEBUT From TRTSTOENM
        If !FIN
            nolign = 1
            nolign1 = [M:ENM]NBLIG
            status = 68
            Call C_NBLIG From TRTSTOENM
            If !mkstat
                If [M:ENM]NBLIG>0
                    Dela 0,[M:ENM]NBLIG,[M:ENM]NBLIG-1 [M:ENM]NBLIG
                Endif
                [M:ENM]NBLIG = 0
                Gosub ENR From TRTSTOENM
            Endif
            If GMESSAGE<>"" & LMESSAGE=""
                LMESSAGE = GMESSAGE
            Endif
        Endif
    Endif
Next

Raz GDELMVT
status = WSAVSTATUS
nolign = WSAVNOLIGN

GOK = !mkstat

GMESSAGE = LMESSAGE

$FIN_DELETEMVT

Kill GDELMVT

End

#########################################################################
# CTR_STK_RETCLI : Contrôle du stock retourné saisi dans STOENT
#                  Doit être appelé en vérification d'enregistrement
#                  Ex: retour client sur livraison
#                      retour prêt sur livraison
#                      retour client d'un retour fournisseur (inter-site)
#------------------------------------------------------------------------
# Paramètres S : LRET = 0    OK
#                LRET = 1    Erreur
#########################################################################
Subprog CTR_STK_RETCLI(LRET)
Variable Integer LRET

Local  Integer I,J,K,WRET
Local  Char    WSERNUM(GLONSER)
Local  Char    WSER(GLONSER)
Local  Char    WFILORI(240), WLIB(100)

Raz LRET

If dim([M:ENT]NBLIG)<0 | [M:ENT]NBLIG=0 End Endif # hcb 91307

#--- Bug 89915
# Si article-site du mouvement origine non géré en stock, pas de contrôle
If [F:ITF]STOFCY<>[M:ENT]STOFCYORI | [F:ITF]ITMREF<>[M:ENT]ITMREF
   Read [ITF]ITF0=[M:ENT]ITMREF;[M:ENT]STOFCYORI
Endif
If [F:ITF]STOMGTCOD<2 End Endif
#---

#If dim([M:ENT]NBLIG)<0 | [M:ENT]NBLIG=0 End Endif # hcb 91307


WFILORI  = 'STOFCY=[M:ENT]STOFCYORI & VCRTYP=[M:ENT]VCRTYPORI'
WFILORI += '& VCRNUM=[M:ENT]VCRNUMORI & VCRLIN=[M:ENT]VCRLINORI'
WFILORI += '& ITMREF=[M:ENT]ITMREF & REGFLG<>2 & UPDCOD=2'
# Si retour de prêt on ne prend que le mvt négatif
#MAE, le 28/05/08, idem pour retour de sous traitance
#If [M:ENT]TRSTYP=18
If find([M:ENT]TRSTYP,18,33)
   WFILORI +='& QTYSTU<0'
Endif

# Si gestion no série
If [F:ITM]SERMGTCOD>=2
   For I=0 To [M:ENT]NBLIG-1
      For J=1 To [M:ENT]QTYSTU(I)
         If J=1
            WSERNUM = [M:ENT]SERNUM(I)
         Else
            Call PLUS_UN(WSERNUM,WSER,WRET) From STKLIB
            If WRET<>0 Break Endif
            WSERNUM = WSER
         Endif
         Read [STS]STS0=[M:ENT]ITMREF;WSERNUM
         If fstat
            Call ERREUR(WSERNUM-":"-mess(43,196,1)) From GESECRAN
            LRET=1
            Break
         #MAE, 28/05/08
         #Elsif [F:STS]ISSDAT=[0/0/0] & [M:ENT]TRSTYP<>18
         Elsif [F:STS]ISSDAT=[0/0/0] & !find([M:ENT]TRSTYP,18,33)
            Call ERREUR(WSERNUM-":"-mess(168,192,1)) From GESECRAN
            LRET=1
            Break
#--- Issue 110327
#         Elsif [F:STS]SDHTYP<>[M:ENT]VCRTYPORI |
#&              [F:STS]SDHNUM<>[M:ENT]VCRNUMORI | [F:STS]SDDLIN<>[M:ENT]VCRLINORI
         Elsif [F:STS]SDHNUM<>"" &
&             ([F:STS]SDHTYP<>[M:ENT]VCRTYPORI |[F:STS]SDHNUM<>[M:ENT]VCRNUMORI | [F:STS]SDDLIN<>[M:ENT]VCRLINORI)
#--- End issue 110327
            Call ERREUR(WSERNUM-":"-mess(115,192,1)) From GESECRAN
            LRET=1
            Break
         Endif
      Next J
      If LRET<>0 Break Endif
   Next I
# Pas de gestion de no série
Else
   Local Char    WLOT(GLONLOT)
   Local Char    WSLO(GLONSLO)
   Local Char    WFLO(GLONLOT)
   Local Char    WPAL(GLONPAL)
   Local Char    WCTR(GLONCTR)
   # Issue 120720 - 2017-01-05 by MAE : variables non déclarées
   Local Char    WSF1(GLONSF1)
   Local Char    WSF2(GLONSF2)
   # End issue 120720
   Local Decimal WQTY, WQTYSTU, WQTYSTURET

   Local Char    TLOT(GLONLOT)([M:ENT]NBLIG)
   Local Char    TSLO(GLONSLO)([M:ENT]NBLIG)
   Local Char    TFLO(GLONLOT)([M:ENT]NBLIG)
   Local Char    TPAL(GLONPAL)([M:ENT]NBLIG)
   Local Char    TCTR(GLONCTR)([M:ENT]NBLIG)
   # Issue 120720 - 2017-01-05 by MAE : variables non déclarées
   Local Char    TSF1(GLONSF1)([M:ENT]NBLIG)
   Local Char    TSF2(GLONSF2)([M:ENT]NBLIG)
   # End issue 120720
   Local Decimal TQTY([M:ENT]NBLIG)

   If clalev([F:STJ1])=0 Local File STOJOU [STJ1] Endif

   For I=0 To [M:ENT]NBLIG-1
      If dim([M:ENT]LOTAFF)>0    TLOT(I)=[M:ENT]LOTAFF(I)    Endif
      If dim([M:ENT]SLOAFF)>0    TSLO(I)=[M:ENT]SLOAFF(I)    Endif
      If dim([M:ENT]BPSLOTAFF)>0 TFLO(I)=[M:ENT]BPSLOTAFF(I) Endif
      If dim([M:ENT]PALNUM)>0    TPAL(I)=[M:ENT]PALNUM(I)    Endif
      If dim([M:ENT]CTRNUM)>0    TCTR(I)=[M:ENT]CTRNUM(I)    Endif
      If dim([M:ENT]STOFLD1)>0   TSF1(I)=[M:ENT]STOFLD1(I)   Endif
      If dim([M:ENT]STOFLD2)>0   TSF2(I)=[M:ENT]STOFLD2(I)   Endif
      TQTY(I)=[M:ENT]QTYSTU(I)
   Next I
   Sorta TLOT,TSLO,TFLO,TPAL,TCTR,TQTY

   I = 0
   WLOT = TLOT(I)
   WSLO = TSLO(I)
   WFLO = TFLO(I)
   WPAL = TPAL(I)
   WCTR = TCTR(I)
   # Issue 120720 - 2017-01-05 by MAE
   WSF1 = TSF1(I)
   WSF2 = TSF2(I)
   # End issue 120720
   WQTY = TQTY(I)
   If [M:ENT]NBLIG>0
      For I=1 To [M:ENT]NBLIG-1
         If TLOT(I)<>WLOT|TSLO(I)<>WSLO|TFLO(I)<>WFLO
            # Contrôle quantité par rapport aux mouvements pièce origine
            Gosub CTR_STJ
            If LRET=1 Break Endif
            WLOT  = TLOT(I)
            WSLO  = TSLO(I)
            WFLO  = TFLO(I)
            WPAL  = TPAL(I)
            WCTR  = TCTR(I)
            # Issue 120720 - 2017-01-05 by MAE
            WSF1  = TSF1(I)
            WSF2  = TSF2(I)
            # End issue 120720
            WQTY  = TQTY(I)
         Else
            WQTY += TQTY(I)
         Endif
      Next I
   Endif
   # Contrôle quantité par rapport aux mouvements pièce origine
   If LRET<>1 Gosub CTR_STJ Endif
Endif

End

#########################################################################
$CTR_STJ

Raz K, WQTYSTU, WQTYSTURET
For [STJ]STJ1 Where evalue(WFILORI)
   # Si données stock identiques
   If [F:STJ]LOT=WLOT & [F:STJ]SLO=WSLO & [F:STJ]BPSLOT=WFLO
      # On a trouvé du stock livré correspondant au stock retourné
      K=1
      # Alimentation en positif de la quantité à traiter
      WQTYSTU += [F:STJ]QTYSTU * -1
   Endif
Next

If K=1
   # Recherche s'il y a déjà eu des retours sur cette ligne
   For [STJ1]STJ2 Where UPDCOD    = 2                 &
&                       ITMREF    = [M:ENT]ITMREF     &
&                       IPTDAT   >= [F:STJ]IPTDAT     &
&                       VCRTYPORI = [M:ENT]VCRTYPORI  &
&                       VCRNUMORI = [M:ENT]VCRNUMORI  &
&                       VCRLINORI = [M:ENT]VCRLINORI  &
&                       REGFLG   <> 2                 &
&                       QTYSTU    > 0
      # Si données stock identiques, on déduit la qté déjà retournée
      If [F:STJ1]LOT=WLOT & [F:STJ1]SLO=WSLO & [F:STJ1]BPSLOT=WFLO
         WQTYSTURET += [F:STJ1]QTYSTU
      Endif
   Next
   # Erreur, le stock retourné est supérieur au stock restant à retourner
   If WQTY > WQTYSTU-WQTYSTURET
      Raz WLIB
      If dim([M:ENT]LOTAFF)>0    WLIB+=mess(43,197,1)-":"-WLOT-" "   Endif
      If dim([M:ENT]SLOAFF)>0    WLIB+=mess(456,197,1)-":"-WSLO-" "  Endif
      If dim([M:ENT]BPSLOTAFF)>0 WLIB+=mess(2,2708,1)-":"-WFLO-" "   Endif
      Call ERREUR(WLIB-"\"-mess(90,184,1)-":"-num$(WQTYSTU-WQTYSTURET)) From GESECRAN
      LRET=1
   Endif
Endif

# Erreur, le stock retourné ne correspond pas au stock livré
If K=0
   Raz WLIB
   If dim([M:ENT]LOTAFF)>0    WLIB+=mess(43,197,1)-":"-WLOT-" "   Endif
   If dim([M:ENT]SLOAFF)>0    WLIB+=mess(456,197,1)-":"-WSLO-" "  Endif
   If dim([M:ENT]BPSLOTAFF)>0 WLIB+=mess(2,2708,1)-":"-WFLO-" "   Endif
   Call ERREUR(WLIB-"\"-mess(90,184,1)-":"-num$(WQTYSTU)) From GESECRAN
   LRET=1
Endif

Return

