#<AdxTL>@(#)0.0.0.0 $Revision$ Composants d'entrées

# Traitement STKENT - Librairie de composants communs entrées     V140 #
########################################################################
# Sous-programmes
#-----------------------------------------------------------------------
#
# OUVENT              Détermination ouverture fenêtre de saisie des entrées
# CTR_COHERENCE_LIG   Controle coherence ligne saisie
# INIT_GOUVLOT        Remplit la variable globale GOUVLOT en fonction des rubriques à saisir
#                      dans la fenêtre complément lot
# STKINIBTN           Active ou non les boutons communs:
#
# INFOLOT             Indique si le lot est blanc ou numéroté par compteur
# DELSTOENTW          Supprime les lignes du tableau STOENTW dont WSTOSEQ=LLIG
# STKFILLENTW         Remplit une ligne de STOENTW à partir du masque passé en param
# STJSTOENTW          Lecture des mouvements de stock d'une ligne de document
# LOAD_FROM_ENTW      Chargement restitution ligne document
#                      à partir de STOENTW
# LOAD_FROM_ENTM      Chargement restitution ligne document à partir de STOENTM
#
#        LECTURE des mouvements de stock d'une ligne de document suite à Picking
# DIVENTLOT           Avant ouverture de la fenêtre complément lot
# CTR_STK_RETCLI      Contrôle du stock retourné saisi dans STOENT
#
########################################################################

################################################################################
# CTR_COHERENCE_LIG   Controle coherence ligne saisie
# Attention ce programme est prévu pour les entrées.
# Parametres E : LABRECR = Abréviation de l'écran dans lequel se trouve
#                          la ligne à controler
#                LLIG    = N° de la ligne à controler
#                LTRS    = Abréviation du fichier de transaction
#            S : LRET    = construit ainsi: bit 1(1)   = complément lot NOK (oui/non)
#                                           bit 2(2)   = N° de lot   à renseigner (oui/non)
#                                           bit 3(4)   = N° de /s lot   à renseigner (oui/non)
#                                           bit 4(8)   = N° de série à renseigner (oui/non)
#                                           bit 5(16)  = Emplacement à renseigner (oui/non)
#                                           bit 6(32)  = Statut      à renseigner (oui/non)
#                                           bit 8(128) = Etiquette absente à tord
#                                           bit 9(256) = Nombre de sous lots non multiple de la quantité
#                                           bit10(512) = Type d'emplacement quai mais pas d'emplacement renseigné
#                                           bit11(1024)= Entrée sur une ligne de stock en cours d'inventaire
#                                           bit12(2048)= version(s) absente(s) à tord
#                                           bit13(4096)= Contenant ou no contenant à renseigner
# Prérequis    : Ces classes [F:] doivent être chargées TABLOCTYP, TABSTORUL
#
################################################################################
Subprog CTR_COHERENCE_LIG(LABRECR, LFCY, LLIG, LVCRTYP, LRET)
Value    Char     LABRECR
Value    Char     LFCY
Value    Integer  LLIG
Value    Integer  LVCRTYP # FGR 18/01/2010 : X3SUIVI60986
Variable Shortint LRET

Local Char    LLBEFMT
Local Char    LUSCAV
Local Integer LMODIF
Local Integer WTYPQUAI
Local Integer WLOC
Local Char    LOTAFF(3)    # Pour les écran ENT et ENM, il faut ajouter "AFF" au nom des champs LOT, SLO et GESLOT
Local Char    LABRMSK
Local Integer LLIGLOT
Local Decimal LSTOCOU
Local Decimal LCOE
Local Char    LPCU(GLONUOM)
Local Integer WLPN         : #--- Issue X3-53322

#--- Issue X3-53322
If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>LFCY
  Read [ITF]ITF0=[F:ITM]ITMREF;LFCY
Endif
#---

LABRMSK  = "[M:"+LABRECR+"]"
#lecture type emplacement
WTYPQUAI = 0
If evalue("dim([M:"+LABRECR+"]LOCTYP(LLIG))") >= 0 &
&  evalue("[M:"+LABRECR+"]LOCTYP(LLIG)") <> ""
    WTYPQUAI = [F:TLO]LOCCAT
Endif
#--- Issue X3-53322
If evalue("dim("+LABRMSK+"LPNNUM)")>=0
  WLPN=1
Else
  WLPN=0
Endif
#---
LRET = 0
If LABRECR="ENT" | LABRECR="ENM"
    LOTAFF="AFF"
Else
    Raz LOTAFF
Endif
If LABRECR="ENTW"    # Le lot n'est pas directement sur la ligne dans entw
    LLIGLOT = [M:ENTW]NUMLIGLOT(LLIG)
Else
    LLIGLOT = LLIG
Endif
# gestion LOT
# L'article est géré par lot et la rubrique lot présente(Code activité LOT OK)
If [F:ITM]LOTMGTCOD <> 1 & evalue("dim("+LABRMSK+"LOT"+LOTAFF+")") >= 0
    Case LABRECR
        When "MBR" :
            If evalue("[M:"+LABRECR+"]LOT"+LOTAFF+"(LLIGLOT)")=""  # en réintégration le lot doit être saisi
                LRET += 2
            Endif
        When Default :
            If !(GIMPORT  &  [F:ITM]LOTMGTCOD = 2)
               If evalue("[M:"+LABRECR+"]LOT"+LOTAFF+"(LLIGLOT)")="" &
&                 evalue("[M:"+LABRECR+"]GESLOT"+LOTAFF+"(LLIGLOT)") =""     # rubrique LOT vide, et lot non géré par compteur, et pas blanc
                  LRET += 2                                    # Rubrique lot à renseigner
               Else
                  LRET += 1                                    # Complément lot à ouvrir (peut-être)
               Endif
            Endif
    Endcase
    If [F:ITM]LOTMGTCOD =4 & evalue("dim([M:"+LABRECR+"]SLO"+LOTAFF+"(LLIGLOT))") >= 0
        #--- Issue X3-53322
        # Si emp interne ou LPN renseigné ou LPN obligatoire
        If evalue("[M:"+LABRECR+"]SLO"+LOTAFF+"(LLIGLOT)")="" &
&          (WTYPQUAI<>2 | (WLPN=1 & evalue(LABRMSK+"LPNNUM(LLIG)")<>"") | ([F:ITF]LPNMGTCOD=2 & [F:SRU]DACCTR=2))
#        If evalue("[M:"+LABRECR+"]SLO"+LOTAFF+"(LLIGLOT)")="" &
#&          WTYPQUAI <> 2
        #---
           LRET += 4
        Endif
    Endif
Endif
#                                                                    # hcb 71276 deb
If [F:ITM]ECCSTO > 1 & evalue("dim("+LABRMSK+"ECCVALMAJ"+LOTAFF+")") >= 0
#  SI le lot est un lot blanc pas d affectation des versions
   If evalue("[M:"+LABRECR+"]ECCVALMAJ"+LOTAFF+"(LLIGLOT)")="" | ([F:ITM]ECCSTO = 3 & evalue("[M:"+LABRECR+"]ECCVALMIN"+LOTAFF+"(LLIGLOT)")="")
      GOUVLOT += 2048
   Endif
Endif
#                                                                    # hcb 71276 deb

# gestion STATUT    : Obligatoire même pour une entrée à quai (10/12/03)
If evalue("[M:"+LABRECR+"]STA(LLIG)")  = ""   # rubrique STA à blanc
   LRET += 32
Endif

If WTYPQUAI=2 & (evalue("dim("+LABRMSK+"BPSLOT"+LOTAFF+")")>0 & evalue(LABRMSK+"BPSLOT"+LOTAFF+"(LLIGLOT)")="")
#If WTYPQUAI=2  & (evalue("dim([M:"+LABRECR+"]BPSLOT"+LOTAFF+")")>0 & evalue("[M:"+LABRECR+"]BPSLOT"+LOTAFF+"(LLIGLOT)")="")
    #--- Issue X3-53322
    If WLPN=0 | [F:ITF]LPNMGTCOD<>2 | (WLPN=1 & evalue(LABRMSK+"LPNNUM(LLIG)")="" & [F:SRU]DACCTR<>2)
    #---
        If LRET>1 | (evalue("dim([M:"+LABRECR+"]GESLOT"+LOTAFF+")")>0 & evalue("[M:"+LABRECR+"]GESLOT"+LOTAFF+"(LLIGLOT)")<>"")
            LRET = (mod(LRET,64)>=32)*32    # Si on entre à quai, seul le statut est obligatoire
        Endif
    #--- Issue X3-53322
    Endif
    #---
    If evalue("[M:"+LABRECR+"]LOC(LLIG)") = ""
        LRET += 512
    Endif
    #--- Issue X3-53322 : Pas de End, sinon on ne contrôle pas le contenant obligatoire
    #End
Endif

# hcb # 96916 deb
#CHECK IGNORE_BEGIN
Raz GPE
GPOINT = "CTRSERSOR"
Gosub  ENTREE From EXEFNC
#CHECK IGNORE_END
# hcb # 96916 deb


# gestion SERIE
If evalue("dim([M:"+LABRECR+"]SERNUM(LLIG))") >= 0   # si rubrique SERNUM présente (Code activité SER OK)
    Case LABRECR :
        When "MBR" :
             If [F:ITM]SERMGTCOD > 1 &
&               evalue("[M:"+LABRECR+"]SERNUM(LLIG)")=""      # En réintégration le n° de série doit être renseigné
               LRET += 8
            Endif
        When Default :
            If evalue("[M:"+LABRECR+"]SERNUM(LLIG)")=""      # si rubrique SERNUM à blanc on vérifie qu'il y a un compteur associé
                If (func STKLIB.SENSVCR(LVCRTYP))=1 | LVCRTYP=31
                    #--- Issue 110327
                    #If [F:ITM]SERMGTCOD = 3                  # si article géré par n° de série en entrée
                    If [F:ITM]SERMGTCOD >= 3                  # si article géré en n° de série E/S globale ou non
                    #---

												#--- Issue X3-53322
                        If [F:ITM]SERCOU="" & (WTYPQUAI<>2 | (WLPN=1 & evalue(LABRMSK+"LPNNUM(LLIG)")<>""))
                        #If [F:ITM]SERCOU="" &
#&                          WTYPQUAI <> 2                     # s'il n'y a pas de compteur série la ligne est incomplète
                        #---
                            LRET += 8
                        Endif
                    Endif
# hcb 96916
                Elsif (func STKLIB.SENSVCR(LVCRTYP))=-2 | LVCRTYP=32
										#--- Issue X3-53322
                    If [F:ITM]SERMGTCOD>1 & GPE=0 & (WTYPQUAI<>2 | (WLPN=1 & evalue(LABRMSK+"LPNNUM(LLIG)")<>""))
                    #If [F:ITM]SERMGTCOD > 1 & GPE = 0 &
#&                      WTYPQUAI <> 2                         # si article géré par n° de série en sortie
                    #---
                        LRET += 8
                        #--- Bug 84738
                        # si retour inter-site intra-société
                        # et série géré en sortie, le no série est facultatif
                        If dim([M:SRH1]BETFCY)>0 & [M:SRH1]BETFCY=2
&                            & [M:SRH1]BETCPY=1  & [F:ITM]SERMGTCOD=2
                           LRET-=8
                        Endif
                        #---
                    Endif
                Endif
            Endif
    Endcase
Endif

# gestion EMPLACEMENT
WLOC = 0
#--- Issue X3-53322
# Si emplacement externe saisi et LPN saisie --> erreur emplacement incorrect
If WTYPQUAI>2 & WLPN=1 & evalue("[M:"+LABRECR+"]LPNNUM(LLIG)")<>""
  Assign "[M:"+LABRECR+"]LOCTYP(LLIG)" With ""
  Assign "[M:"+LABRECR+"]LOC(LLIG)" With ""
  LRET += 16
  WLOC = 1
Endif
If WLOC = 0
#---
  If evalue("dim([M:"+LABRECR+"]LOCTYP(LLIG))") >= 0
    If [F:ITF]LOCMGTCOD = 2
      If evalue("[M:"+LABRECR+"]LOCTYP(LLIG)") = ""
        LRET += 16
        WLOC = 1
      Endif
    Endif
  Endif
#--- Issue X3-53322
Endif
#---
If WLOC = 0
  If evalue("dim([M:"+LABRECR+"]LOC(LLIG))") >= 0
    If [F:ITF]LOCMGTCOD = 2
      If evalue("[M:"+LABRECR+"]LOC(LLIG)") = ""
        LRET += 16
        WLOC = 1
      Endif
    Endif
  Endif
Endif

#--- X3-53322
# Si contenant obligatoire et pas de (no)contenant saisi --> ouverture détail
If evalue("dim([M:"+LABRECR+"]LPNNUM)")>=0 & [F:ITF]LPNMGTCOD=2 & [F:SRU]DACCTR=2
  #--- Si moteur de modif, c'est le no contenant qui doit être renseigné
  If LABRECR="ENM"
    If evalue("[M:"+LABRECR+"]LPNNUM(LLIG)")=""
      LRET+=4096
    Endif
  #--- Si détail entrée, le no contenant ou le contenant doivent être renseignés
  Elsif LABRECR="ENT"
    If evalue("[M:"+LABRECR+"]LPNNUM(LLIG)")="" & evalue("[M:"+LABRECR+"]TCTRNUM(LLIG)")=""
      LRET+=4096
    Endif
  #--- Dans les autres cas, le no contenant ou le contenant doivent être renseignés
  Else
    If evalue("[M:"+LABRECR+"]LPNNUM(LLIG)")="" & evalue("[M:"+LABRECR+"]TCTRNUM(LLIG)")=""
      LRET+=4096
    Endif
  Endif
Endif
#---

#--- Issue X3-53322
# gestion ETIQUETTE : Contrôle désactivé car on peut avoir des cas d'articles avec impression et d'autres sans
# et ceci dans un même document. De toute façon les étiquettes pourront être saisie dans la fenêtre d'impression.
#If 0 & dim([F]PRNCOD1)>0 & [F]PRNCOD1 > 1     # Etiquette absente à tord
#   If LABRECR = "ENT"
#      If [M:ENT]LBEFMT(LLIG) = "" &
#&        WTYPQUAI     <> 2
#         LRET +=128
#      Endif
#   Else
#      If LABRECR = "ENM"
#         If [M:ENM]LBEFMT(LLIG) = "" &
#&           WTYPQUAI     <> 2
#            LRET +=128
#         Endif
#      Elsif evalue("[M:"+LABRECR+"]WSTOSEQ(LLIG)")=0
#            If evalue("dim([M:"+LABRECR+"]"+[M:ENTW]WZONPCU+")")>=0
#                LPCU = evalue("[M:"+LABRECR+"]"+[M:ENTW]WZONPCU+"(LLIG)")
#            # Ce qui suit ne doit plus servir CCC 02/10/03
#            Elsif evalue("dim([M:"+LABRECR+"]UOM)")>=0
#                LPCU = evalue("[M:"+LABRECR+"]UOM(LLIG)")
#            Endif
#            Call CTLUOM ( evalue("[M:"+LABRECR+"]ITMREF(LLIG)"), 3, "",  LPCU,LCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT
#            If LLBEFMT = "" &
#&              WTYPQUAI     <> 2
#               LRET += 128
#            Endif
#      Else
#         If   sigma(0,[M:ENTW]NBLIG-1,([M:ENTW]WSTOSEQ(indcum)=evalue("[M:"+LABRECR+"]WSTOSEQ(LLIG)"))*([M:ENTW]LBEFMT(indcum)=""))
#&           & WTYPQUAI     <> 2
#            LRET += 128
#         Endif
#      Endif
#   Endif
#Endif
#---

If LABRECR<>"ENT" & LABRECR<>"ENM" & GVTMOD<>1
   # Quand il y a plus d'1 sous lot on déclenche l'ouverture de fenêtre
   If LRET<2 & evalue("dim([M:"+LABRECR+"]NBSLO)")>0 & evalue("[M:"+LABRECR+"]NBSLO(LLIG)")>1
      LRET+=256
   Endif
Endif
#-------- Teste si la ligne de stock destination est en inventaire ---------------#

If LRET<2
   # S'il y a un n° de série, on n'aura pas pu le sélectionner s'il est en inventaire => pas de test
   # On utilise LLIG+1 et indcum-1 car sinon on plante sur la première ligne
   If evalue("string$(dim("+LABRMSK+"SERNUM)>0,"
&            +"sigma(LLIG+1,"
&            +"(LLIG+1)*(dim("+LABRMSK+"SERNUM)>0),"
&            + LABRMSK+"SERNUM(indcum-1)))") = ""
      If find(LABRECR,"ENT","ENM","ENTW")
         LPCU = evalue(LABRMSK+"PCU(LLIG)")
         LCOE = evalue(LABRMSK+"PCUSTUCOE(LLIG)")
      Else
         LPCU = evalue(LABRMSK+[M:ENTW]WZONPCU+"(LLIG)")
         LCOE = evalue(LABRMSK+[M:ENTW]WZONCCS+"(LLIG)")
         #--- Bug 89131
         If [M:ENTW]WZONPCU="STU" LCOE=1 Endif
      Endif
      #--- Issue X3-53322 : Ajout LPN
      LSTOCOU = func STKLIB.CLESTOFUN(LFCY,
&                    evalue(LABRMSK+"ITMREF(LLIG*(dim("+LABRMSK+"ITMREF)>1))"),
&                    evalue("string$(dim("+LABRMSK+"LOT"+LOTAFF+")>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"LOT"+LOTAFF+")>0),"+LABRMSK+"LOT"+LOTAFF+"(indcum-1)))"),
&                    evalue("string$(dim("+LABRMSK+"SLO"+LOTAFF+")>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"SLO"+LOTAFF+")>0),"+LABRMSK+"SLO"+LOTAFF+"(indcum-1)))"),
&                    evalue("string$(dim("+LABRMSK+"PALNUM)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"PALNUM)>0),"+LABRMSK+"PALNUM(indcum-1)))"),
&                    evalue("string$(dim("+LABRMSK+"CTRNUM)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"CTRNUM)>0),"+LABRMSK+"CTRNUM(indcum-1)))"),
&                    evalue(LABRMSK+"STA(LLIG)"),
&                    evalue("string$(dim("+LABRMSK+"LOC)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"LOC)>0),"+LABRMSK+"LOC(indcum-1)))"),
&                    LPCU,LCOE,"","",LFCY,
&                    evalue("string$(dim("+LABRMSK+"STOFLD1)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"STOFLD1)>0),"+LABRMSK+"STOFLD1(indcum-1)))"),
&                    evalue("string$(dim("+LABRMSK+"STOFLD2)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"STOFLD2)>0),"+LABRMSK+"STOFLD2(indcum-1)))"),
&                    "STO",
&                    evalue("string$(dim("+LABRMSK+"LPNNUM)>0,sigma(LLIG+1,(LLIG+1)*(dim("+LABRMSK+"LPNNUM)>0),"+LABRMSK+"LPNNUM(indcum-1)))"))
      If LSTOCOU
         Read [STO]STO0=LFCY;LSTOCOU
         If [STO]CUNLOKFLG = 2
            LRET += 1024
         Endif
      Endif
   Endif
Endif

End


#$INI_GESLOT
#If evalue("[M:"+LABRECR+"]LOT(LLIG)") <> ""
#   Return
#Endif
#If  evalue("[M:"+LABRECR+"]GESLOT(LLIG)") <> ""
#    Return
#Endif

#If [F:ITM]LOTCOU = ""
#   If [F:SRU]LOTVCRINH=2 & GSTKCPT(9)<>""
#       Assign(LABRMSK+"GESLOT(LLIG)")     With "V"
#   Else
#      If [F:ITM]LOTMGTCOD = 2
#         Assign(LABRMSK+"GESLOT(LLIG)")   With "B"
#      Endif
#   Endif
#Else
#   Assign(LABRMSK+"GESLOT(LLIG)")         With "C"
#Endif

#Return

################################################################################
# Remplit la variable globale GOUVLOT en fonction des rubriques à saisir
# dans la fenêtre complément lot:
# GOUVLOT += 1   si clic droit --> déterminé après cette fonction
#         += 2   si Rubrique 1 à saisir
#         += 4   si rubrique 2 à saisir
#         += 8   si rubrique 3 à saisir
#         += 16  si rubrique 4 à saisir
#         += 32  si Titre à saisir
#         += 64  si Titre UI à saisir
#         += 128 si Péremption à saisir (référence, délai et date)
#         += 256 si version à saisir                  # hcb 71276
#
# Paramètres E : LTRS    = Abréviation de la table transaction
#
# Prérequis : Tables ouvertes et positionnées:
#               ITMMASTER [ITM]
#               table transaction passée en paramètre
################################################################################
Subprog INIT_GOUVLOT( LTRSFILE)
Value Char LTRSFILE
    Raz GOUVLOT
    If [F:ITM]LOTMGTCOD=1
        End
    Endif

    If evalue("dim([F:"+LTRSFILE+"]SRUB1FLG)")>0 & evalue("[F:"+LTRSFILE+"]SRUB1FLG")=2
        GOUVLOT += 2
    Endif
    If evalue("dim([F:"+LTRSFILE+"]SRUB2FLG)")>0 & evalue("[F:"+LTRSFILE+"]SRUB2FLG")=2
        GOUVLOT += 4
    Endif
    If evalue("dim([F:"+LTRSFILE+"]SRUB3FLG)")>0 & evalue("[F:"+LTRSFILE+"]SRUB3FLG")=2
        GOUVLOT += 8
    Endif
    If evalue("dim([F:"+LTRSFILE+"]SRUB4FLG)")>0 & evalue("[F:"+LTRSFILE+"]SRUB4FLG")=2
        GOUVLOT += 16
    Endif

    If evalue("dim([F:"+LTRSFILE+"]SPOTFLG)")>0 & evalue("[F:"+LTRSFILE+"]SPOTFLG")<>1
        If [F:ITM]STOMGTCOD=3
            GOUVLOT += 32
        Elsif [F:ITM]STOMGTCOD=4
            GOUVLOT += 64
        Endif
    Endif
    If ([F:ITM]EXYMGTCOD>1 & evalue("dim([F:"+LTRSFILE+"]SPERFLG)")>0 & evalue("[F:"+LTRSFILE+"]SPERFLG")<>1)
&     | [F:ITM]EXYMGTCOD = 5 |  [F:ITM]EXYMGTCOD = 6
       If GVTMOD<>1 GOUVLOT += 128 Endif
    Endif
#                                                                    # hcb 71276 deb
    If ([F:ITM]ECCSTO >1 & evalue("dim([F:"+LTRSFILE+"]ECCFLG)")>0 & evalue("[F:"+LTRSFILE+"]ECCFLG")<>1)
       If GVTMOD<>1 GOUVLOT += 256 Endif

#                                                                    # hcb 71276 deb




    Endif
End
################################################################################
# INFOLOT        Indique si le lot est blanc ou numéroté par compteur
################################################################################
# Paramètres E : LABRECR = abréviation du masque d'écran dans lequel
#                          se trouve le champ GESLOT qui contient l'information
#              : LLIG    = numéro de la ligne dans le tableau de l'écran
#                          où se trouve le champ GESLOT
################################################################################
Subprog INFOLOT(LABRECR, LLIG)
Value Char    LABRECR
Value Integer LLIG

Local Char LNOMZONGES(GLONAVA)

If evalue("dim([M:"+LABRECR+"]GESLOTAFF)")>0
    LNOMZONGES = "GESLOTAFF"
Else
    LNOMZONGES = "GESLOT"
Endif

Case evalue("[M:"+LABRECR+"]"+LNOMZONGES+"(LLIG)")
    When "B" :
        Call MESSAGE(mess(440,198,1)) From GESECRAN  #lot blanc
    When "C" :
        Call MESSAGE(mess(439,198,1)) From GESECRAN  # lot numéroté par compteur
    When "V" :
        Call MESSAGE(mess(444,198,1)) From GESECRAN  # lot numéroté par document
    When Default:
Endcase

End

#--- Issue 117545
# Passage de CUTLIGSLO dans STKENTA
#Subprog CUTLIGSLO(LABR,LLIG,PQTY,PNBSLO,PUOM,PTABQTY)
