#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour droit sur la table ADICTRT
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update acces ADICTRT file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub RIGADC
End

#-------------------#
$RIGADC

If nomap<>GDOSX3 : Return : Endif

Local Char COMMAND(250)

System COMMAND=adxmac(0)+'@valfil -r'-DOSSIER-'ADICTRT'

# Mise à jour de la table ADICTRT
Call ECR_TRACE(mess(81,125,1)-"ADICTRT:"-time$,0) From GESECRAN

Return
