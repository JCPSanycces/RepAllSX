[L]CURPRO = "CCNREF"
$_LNKPRO_CCNREF
If vireblc(this.CCNREF,2)<>""
 # Link CONCESSION
 Local File CONCESSION [WCCN]
 Read [F:WCCN]CCN0 = this.CCNREF
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CCNREF","$title",[F:WCCN]CCNDES1)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CCNREF","$description",[F:WCCN]CCNDES1)
