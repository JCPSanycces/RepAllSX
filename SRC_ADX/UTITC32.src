##########################################################################
# UTITC32   Dissociation type prestation et conflit horaire    Module SC #
#                                                                        #
##########################################################################
# FGR 22/02/2010 : X3SUIVI62662
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC32(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC32(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTITC32: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:ADI]) = 0 : Local File =DOSSIER + ".ATABDIV"  [ADI] : Endif
  Raz COMPTEUR
  B_OK = 1
  Trbegin [ADI]
  #
  Filter [ADI] Where [F:ADI]NUMTAB = 407
  For [ADI]CODE
    If [F:ADI]N2 = 0 Then
      Case [F:ADI]N1
        When 1
          [F:ADI]N2 = 2 # Oui
        When 2
          [F:ADI]N2 = 1 # Non
        When 3
          [F:ADI]N2 = 2 # Oui
        When Default
          [F:ADI]N2 = 1 # Non
      Endcase
      Rewrite [ADI]
      If fstat Then
        Call ECR_TRACE("UTITC32 :" - num$([F:ADI]NUMTAB) - "/" - [F:ADI]CODE - num$(fstat) - "Rewrite error",1) From GESECRAN
        B_OK = 0
        Break
      Endif
      COMPTEUR += 1
    Endif
  Next
  Filter [ADI]
  If B_OK = 1 Then
    Commit
  Else
    Rollback
  Endif
  Close Local File [ADI]
  Call ECR_TRACE("UTITC32 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATABDIV") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC32(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"ATABDIV") : End : Endif
  Call MAJ_UTITC32(APPLI)
End

