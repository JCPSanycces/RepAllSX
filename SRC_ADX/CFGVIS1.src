#<AdxTL>@(#)5.0.0.0 $Revision$
If clalev([F:PSW])  = 0 : Local File PRTSCRWRK     [PSW]  : Endif
Local Integer W_I
W_I=1
#Infbox(num$(nbrecord([F:PSW])))
#End
Local Char VALEUR
Local Char PARAM(30)(1..5) , VALEUR(10)
Local Char    SAVACT(GLONACT)
Local Char SAVFONC1(30)
Local Integer FLGEXE
SAVACT = GACTION
SAVFONC1=GFONC1
GACTION="VISUSYMSCE"
PARAM(1) = "JPTsT"
PARAM(2) = "1"
PARAM(3) = "JWQa1"
Call TRAITE_CHAR(VALEUR,PARAM,"IVISUSYMSC","CFGVIS1","",1,"XYCFGVIS1")  From GTRAITE
GACTION = SAVACT
GFONC1=SAVFONC1
End

############################################################
# Cas d'emploi symboles dans un scénario donné
#
# Action: VISUSYMSCE
#            E     P1:Scénario
#                  P2:Type symbole
#                  P3:Symbole
#                  P4 et P5: non utilisés
#
############################################################
$ACTION
Case ACTION
  When "OUVRE" :
    Case GACTION
      When "VISUSYMSCE"   : Gosub OUVRE_SYMSCE
    Endcase
  When "DEBUT" :
    Case GACTION
      When "VISUSYMSCE"   : Gosub DEBUT_SYMSCE
    Endcase
  When "BOUTON" :
    Case GACTION
      When "VISUSYMSCE"   : Gosub BOUTON_SYMSCE
    Endcase
  When "FIN" :
    Case GACTION
      When "VISUSYMSCE"   : Gosub FIN_SYMSCE
    Endcase
Endcase
Return
#
############################################################
# Action: VISUSYMSCE
############################################################
$OUVRE_symsce
#
Local Char    W_SYM    # Code symbole
Local Integer W_TYP    # Type symbole
Local Char    W_PRESYM # Prefixe symbole
Local Integer W_HASSYM        # flag présence symbole
Local Char    W_FOR(250)      # formule
Local Char    W_FORFMT(250)      # formule tokennisé (la donnée peut être en minuscule)

Local Integer W_HASSYMLINE    # flag présence symbole dans ligne de scénario
Local Integer WNBLIG
#
If clalev([F:CSL])  = 0 : Local File CFGSCELIN     [CSL]  : Endif
#If clalev([F:ATX])  = 0 : Local File ATEXTE    [ATX]  : Endif
Return
############################################################
$DEBUT_symsce
Raz [M:vsyu]
#
If PARAM(1)  <> ""
  [M:VSYU]SCENUM = toupper(PARAM(1))
Endif
If PARAM(2)  <> "" & PARAM(3)  <> ""
    [M:VSYU]SYMTYP = val(PARAM(2))
    Case  [M:VSYU]SYMTYP
      When  1 : [M:vsyu]QSTNUM = toupper( PARAM(3) )
      When  2 : [M:vsyu]VARNUM = toupper( PARAM(3) )
    Endcase
    Gosub UTISYMB
Else
    [M:vsyu]SYMTYP=1    # défaut: question
Endif
Affzo [M:vsyu]
Grizo [M:VSYU]QSTNUM,VARNUM
Case [M:VSYU]SYMTYP
  When  1 : Actzo [M:VSYU]QSTNUM
  When  2 : Actzo [M:VSYU]VARNUM
Endcase
Return
############################################################
$SETBOUT_symsce
Return
############################################################
$BOUTON_symsce
Case BOUT
  When "a" : Gosub UTISYMB
  When "b" : Call PRTSCR("VISUSYMSCE","VSYU","",0,0) From ATRTX3
Endcase
Return
############################################################
#  Recherche de l'utilisation des symboles pour un scénario
$UTISYMB    
W_TYP = [M:vsyu]SYMTYP
Case W_TYP
  When  1 : W_SYM = [M:vsyu]QSTNUM
  When  2 : W_SYM = [M:vsyu]VARNUM
Endcase
#
Effzo [M:vsyu]20
#
Gosub UTISYMBTR
#
Affzo [M:vsyu]
If [M:vsyu]NBLIG = 0
  GERR = 2
  GMESSAGE = mess(W_TYP,752,1)-W_SYM+" : "+mess(82,188,1)
Endif
Return
############################################################
$FIN_SYMSCE
Call IMPSCR From ATRTX3
Return
############################################################
$UTISYMBTR
W_PRESYM="S_"
Raz WNBLIG, [M:VSYU]NBLIG
# Omettre la liste composant et des opérations
Filter [CSL] Where (SCENUM = [M:VSYU]SCENUM  &
& SCENUMTYP <> 4 & SCENUMTYP <> 7)        
& Order By Key CSL0
#& instr(1,toupper(FORFOR),W_PRESYM+W_SYM) |
#& instr(1,toupper(CNDFOR),W_PRESYM+W_SYM) |
#& instr(1,toupper(CNDFORLIN),W_PRESYM+W_SYM) )
#Dbgaff
For [CSL]
    Raz W_HASSYMLINE,[M:VSYU]SYMTYP1(WNBLIG),[M:VSYU]SYMTYP2(WNBLIG),[M:VSYU]SYMTYP3(WNBLIG)
    Raz [M:VSYU]SYMTYP4(WNBLIG),[M:VSYU]FORFOR(WNBLIG),[M:VSYU]CNDFOR(WNBLIG)
    Raz [M:VSYU]SCETXT(WNBLIG), [M:VSYU]ABQNUM(WNBLIG)
    # Recherche condition ou formule
    # Commentaire
    [M:VSYU]SCETXT(WNBLIG) = [F:CSL]SCETXT
    # Contexte 1 
    [M:VSYU]SYMTYP1(WNBLIG) = mess([F:CSL]SCENUMTYP,764,1)
    # Contexte 2
    Case [F:CSL]SCENUMTYP 
    When 1        # CFG2
        [M:VSYU]SYMTYP2(WNBLIG) = [F:CSL]SYMNUM
    When 2        # CFG4
        [M:VSYU]SYMTYP2(WNBLIG) = mess([F:CSL]SYMTYP,752,1)-"/"-[F:CSL]SYMNUM
    When 3        # CFG5
        [M:VSYU]SYMTYP2(WNBLIG) = mess([F:CSL]SYMTYP,752,1)-"/"-[F:CSL]SYMNUM
    When 5        # CFG6
        [M:VSYU]SYMTYP2(WNBLIG) = num$([F:CSL]SCENUMSEQ)-"/"-[F:CSL]ITMREF
        # Contexte 3
        If mod([F:CSL]SCENUMLIN,1000)         # Onglet CFGW
            [M:VSYU]SYMTYP3(WNBLIG) = mess(224,188,1)
        Endif
    When 8        # CFG8
        If [F:CSL]STDOPENUM<>0
            [M:VSYU]SYMTYP2(WNBLIG) = num$([F:CSL]OPENUM)-"/"-num$([F:CSL]STDOPENUM)
        Else
            [M:VSYU]SYMTYP2(WNBLIG) = num$([F:CSL]OPENUM)
        Endif
        # Contexte 3
        If !mod([F:CSL]SCENUMLIN,1000)         # Onglet CFGX
            [M:VSYU]SYMTYP3(WNBLIG) = mess(225,188,1)
        Endif
    When 9        # CFG9
        [M:VSYU]SYMTYP2(WNBLIG) = mess([F:CSL]SYMTYP,752,1)-"/"-[F:CSL]SYMNUM
    Endcase

    # Cas Symbole
    If [F:CSL]SYMNUM=W_SYM : W_HASSYMLINE=1 : Endif

    # Cas Abaque
    If ([F:CSL]ABQVAL=W_SYM | [F:CSL]ABQVALY=W_SYM) 
        W_HASSYMLINE=1
        [M:VSYU]ABQNUM(WNBLIG) = [F:CSL]ABQNUM
    Endif

    # Formule
    W_FOR=[F:CSL]FORFOR : Gosub ANALYZE         
    If W_HASSYM : W_HASSYMLINE=1 : [M:VSYU]FORFOR(WNBLIG)=W_FORFMT : Endif
    # Condition
    If !mod([F:CSL]SCENUMLIN,1000)         # Onglet CFG6
        W_FOR=[F:CSL]CNDFORLIN : Gosub ANALYZE 
        If W_HASSYM : W_HASSYMLINE=1 : [M:VSYU]CNDFOR(WNBLIG)=W_FORFMT : Endif
    Else                                   # onglet CFGW
        W_FOR=[F:CSL]CNDFOR : Gosub ANALYZE 
        If W_HASSYM : W_HASSYMLINE=1 : [M:VSYU]CNDFOR(WNBLIG)=W_FORFMT : Endif
    Endif
    # ecriture 
    If W_HASSYMLINE : Gosub $ECRLINE : Endif
Next
Filter [CSL]

Return

############################################################
$ECRLINE
If [M:VSYU]NBLIG < dim([M:VSYU]SYMTYP1)-1
  [M:VSYU]NBLIG += 1
  WNBLIG=[M:VSYU]NBLIG
Endif
Return


############################################################
# Analyse d'une formule pour tester la présence d'un symbole
#    E:    W_FOR    la formule
#          W_SYM    le symbole
#          W_PRESYM prefixe symbole
# 
#    S:    W_HASSYM : flag présence du symbole 
#          w_forfmt : formule passée en tokenisation
#
$ANALYZE
Raz W_HASSYM
W_FORFMT=format$("KT:250X",W_FOR)
If vireblc(W_FORFMT,4) <> ""
    W_K = instr(1,W_FORFMT,W_PRESYM+W_SYM)
    If W_K <> 0
        # Vérification si pas un symbole de même racine
        W_NEXTCAR=mid$(W_FORFMT, W_K+len(W_PRESYM+W_SYM),1)
        If not(W_NEXTCAR >= "A" & W_NEXTCAR <= "Z" | W_NEXTCAR >= "0" & W_NEXTCAR <= "9")
        W_HASSYM=1
       Endif
      Endif
Endif
Return
