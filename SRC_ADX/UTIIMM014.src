#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 09 Septembre 2010 10:02:04
# Moulinette pour mettre à jour la liste gauche de l'objet GPC
# FQ66710
# FQ68628
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM014: Consultation de pièces : adaptations au multiréférentiel") From LECFIC
  Call EXE_UTIIMM014(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

 Subprog EXE_UTIIMM014(APPLI)
 Value Char APPLI
 If clalev([F:ZAOL]) : Close Local File [ZAOL] : Endif
 Local File =APPLI+".AOBJLST" [ZAOL]
  Call ECR_TRACE("UTIIMM014: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM014

  Call ECR_TRACE("UTIIMM014: Process End on : "+APPLI,0) From GESECRAN

 End

########################################
#### Corps de la moulinette - début ####
########################################
$TR_UTIIMM014

  Trbegin [ZAOL]
  
  Read [F:ZAOL]AOL0="GPC"
  If fstat
   Call ECR_TRACE("Error : The GPC object doesn't exist.",-1) From GESECRAN
   GOK=0 : Goto AB_UTIIMM014
  Endif 
  Raz [F:ZAOL]
  [F:ZAOL]ABREV     = "GPC"
  [F:ZAOL]DELDEF    = 1
  [F:ZAOL]NBSEL     = 6

  [F:ZAOL]SELEXP(0) = "[F:LCA]CPY+' '+[F:CPY]CPYNAM"
  [F:ZAOL]SELEXP(1) = "[F:LCA]FCY+' '+[F:FCY]FCYNAM"
  [F:ZAOL]SELEXP(2) = "[F:LCA]TYP+' '+[F:GTE]DES"
  [F:ZAOL]SELEXP(3) = ""
  [F:ZAOL]SELEXP(4) = ""
  [F:ZAOL]SELEXP(5) = ""

  [F:ZAOL]SELFIC(0) = ""
  [F:ZAOL]SELFIC(1) = ""
  [F:ZAOL]SELFIC(2) = ""
  [F:ZAOL]SELFIC(3) = "LNKCPTABX3"
  [F:ZAOL]SELFIC(4) = "LNKCPTABX3"
  [F:ZAOL]SELFIC(5) = "LNKCPTABX3"

  [F:ZAOL]SELINT(0) = 1343 
  [F:ZAOL]SELINT(1) = 1344
  [F:ZAOL]SELINT(2) = 4969
  [F:ZAOL]SELINT(3) = 4970
  [F:ZAOL]SELINT(4) = 171
  [F:ZAOL]SELINT(5) = 1470   

  [F:ZAOL]SELTYP(0) = "A"
  [F:ZAOL]SELTYP(1) = "A"
  [F:ZAOL]SELTYP(2) = "A"
  [F:ZAOL]SELTYP(3) = ""
  [F:ZAOL]SELTYP(4) = ""

  [F:ZAOL]SELZON(0) = ""
  [F:ZAOL]SELZON(1) = ""
  [F:ZAOL]SELZON(2) = ""
  [F:ZAOL]SELZON(3) = "ACCDAT"
  [F:ZAOL]SELZON(4) = "NUM"
  [F:ZAOL]SELZON(5) = "DES"

  Rewrite [F:ZAOL]

  If fstat
   GOK=0
   Call ECR_TRACE("   Error Rewrite [F:ZAOL] fstat="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("Left list of the GPC object modified",0) From GESECRAN
  Endif

  If !GOK Then
    Goto AB_UTIIMM014
  Else
    Commit
  Endif

  Call VALFEN(APPLI,"GPC") From SUBAOB

Return

$AB_UTIIMM014
 Rollback
Return
########################################
#### Corps de la moulinette - fin ######
########################################

#######################################################################
# Pour exécution depuis passage de patch
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM014(APPLI)
End

#######################################################################
# Pour exécution depuis dosmajx (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM014(APPLI)
End
