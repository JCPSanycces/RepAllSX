#<AdxTL>@(#)0.0.0.0 $Revision$
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIPIT Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

################################################################################
Subprog UTIPIT_UPG(DOSSIER)
Value Char DOSSIER

Local Char LTCM(GLONTCM)
Local Integer LRET, LMVTTYP
Local Decimal LFIYNUM, LPERENDNUM

Local Date FISC_YEAR_START, LPEREND
Local Integer COST_METHOD
Local Char SKIP_SITE(255)(0..)
Local Char SKIP_ITM_FCY(255)(0..)
Local Char LST_FCY(255)
Local Char CRIT(255), LACCIFA(2)
Local Integer SKIP_SITE_INDEX, SKIP_PRODUCT_SITE_INDEX, IERR

  Local File =DOSSIER+".ITMFACILIT"   [ITF]
  Local File =DOSSIER+".FISCALYEAR"   [FIY]
  Local File =DOSSIER+".STOJOU"       [STJ]
  Local File =DOSSIER+".STOJOU"       [STJ2]
  Local File =DOSSIER+".TABCOSTMET"   [TCM]
  Local File =DOSSIER+".STKMVTADJ"    [SMA]
  Local File =DOSSIER+".ITMMVTPIT"    [ITVP]
  Local File =DOSSIER+".STOLOTFCYPIT" [SLFP]
  Local File =DOSSIER+".ITMCOSTPIT"   [ITCP]
  Local File =DOSSIER+".STOCOSTPIT"   [STPP]
  Local File =DOSSIER+".STOMVTCOST"   [SMC]
  Local File =DOSSIER+".STOMVTCOST"   [SMC2]
  Local File =DOSSIER+".ITMMASTER"    [ITM]
  Local File =DOSSIER+".ITMCATEG"     [ITG]
  Local File =DOSSIER+".PERIOD"       [PER]
  Local File =DOSSIER+".ITMCOST"      [ITC]
  Local File =DOSSIER+".CGVDET"       [CGVD]
  Local File =DOSSIER+".FACILITY"     [FCY]

Global Char GDOS(30)

  GDOS = [L]DOSSIER + '.'

  SKIP_SITE_INDEX  = 0
  ITM_FCY_INDEX  = 0

  #Creating log header
  Call ECR_TRACE('PIT UPGRADE START',0) From GESECRAN     # Labor entry validation
  IERR = 0
  Trbegin [STJ]
  # Start by making sure that all of the PIT tables are empty
  Delete [F:ITCP] Where 1=1
  If fstat <> [V]CST_AOK Then
    Call ECR_TRACE("File ITMCOSTPIT delete Error =" - num$(fstat), 1) From GESECRAN
    IERR = 1
  Endif
  Delete [F:SLFP] Where 1=1
  If fstat <> [V]CST_AOK Then
    Call ECR_TRACE("File STOLOTFCYPIT delete Error =" - num$(fstat), 1) From GESECRAN
    IERR = 1
  Endif
  Delete [F:STPP] Where 1=1
  If fstat <> [V]CST_AOK Then
    Call ECR_TRACE("File STOCOSTPIT delete Error =" - num$(fstat), 1) From GESECRAN
    IERR = 1
  Endif
  Delete [F:ITVP] Where 1=1
  If fstat <> [V]CST_AOK Then
    Call ECR_TRACE("File ITMMVTPIT delete Error =" - num$(fstat), 1) From GESECRAN
    IERR = 1
  Endif
  If IERR = 0 Then
    If dim([F:STJ]PITVALFLG2) > 0 Then
      Update [F:STJ] Where [F:STJ]PITVALFLG=2 | [F:STJ]PITVALFLG2=2 With [F:STJ]PITVALFLG=0, [F:STJ]PITVALFLG2=0
    Else
      Update [F:STJ] Where [F:STJ]PITVALFLG=2 With [F:STJ]PITVALFLG=0
    Endif
    If fstat <> [V]CST_AOK Then
      Call ECR_TRACE("File STOJOU PITVALFLG reset. Error =" - num$(fstat), 1) From GESECRAN
      IERR = 1
    Endif
  Endif
  If IERR = 0 Then
    #loop through all the product site records
    For [F:ITF]ITF1
      If find([F:ITF]STOFCY,SKIP_SITE) <> 0
        Goto $NEXT_ITM
      Endif
      # Skip sites that do not have Acc Interface turned on
      If LST_FCY <> [F:ITF]STOFCY
        LST_FCY = [F:ITF]STOFCY
        LACCIFA = func ADP_TOOL.GET_PARAM([L]DOSSIER, 3, [F:ITF]STOFCY, "ACCIFA")
        If val(LACCIFA)<2
          Call ECR_TRACE([F:ITF]STOFCY - ". " + mess(173,196,1) ,0) From GESECRAN
          SKIP_SITE(SKIP_SITE_INDEX) = [F:ITF]STOFCY
          SKIP_SITE_INDEX += 1
          If dim([F:STJ]PITVALFLG2)>0
            Update [F:STJ] Where [F:STJ]STOFCY=[F:ITF]STOFCY & ([F:STJ]PITVALFLG<>2 | [F:STJ]PITVALFLG2<>2) With [F:STJ]PITVALFLG=2, [F:STJ]PITVALFLG2=2
            If fstat <> [V]CST_AOK
              Call ECR_TRACE("File STOJOU PITVALFLG set. Error =" - num$(fstat), 1) From GESECRAN
              IERR = 1
            Endif
          Else
            Update [F:STJ] Where [F:STJ]STOFCY=[F:ITF]STOFCY & [F:STJ]PITVALFLG<>2 With [F:STJ]PITVALFLG=2
            If fstat <> [V]CST_AOK
              Call ECR_TRACE("File STOJOU PITVALFLG set. Error =" - num$(fstat), 1) From GESECRAN
              IERR = 1
            Endif
          Endif
          Goto $NEXT_ITM
        Endif
      Endif
      Filter [F:SMA] Where [F:SMA]ITMREF = [F:ITF]ITMREF and [F:SMA]STOFCY = [F:ITF]STOFCY
      Look [F:SMA] First
      Filter [F:SMA]
      If !fstat
        If find([F:ITF]ITMREF+";"+[F:ITF]STOFCY,SKIP_ITM_FCY) = 0
          #add product/site to the skip array
          SKIP_ITM_FCY(ITM_FCY_INDEX) = [F:ITF]ITMREF+";"+[F:ITF]STOFCY
        Endif
        Call ECR_TRACE(mess(4,198,1) - [F:ITF]ITMREF+ "/"- [F:ITF]STOFCY + ". "+ mess(675,199,1) ,0) From GESECRAN
        ITM_FCY_INDEX += 1
        Goto $NEXT_ITM
      Endif
      #Check if the product has a valuation method
      Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,LTCM,LRET) From STKVAL
      If LRET or LTCM=""
        If find([F:ITF]ITMREF+";"+[F:ITF]STOFCY,SKIP_ITM_FCY) = 0
          #add product/site to the skip array
          SKIP_ITM_FCY(ITM_FCY_INDEX) = [F:ITF]ITMREF+";"+[F:ITF]STOFCY
        Endif
        ITM_FCY_INDEX += 1
        Goto $NEXT_ITM
      Endif
      #Get the Company for the site
      Read [F:FCY]FCY0 = [F:ITF]STOFCY
      If fstat : Goto $NEXT_ITM : Endif
      GSOCIETE = [F:FCY]LEGCPY
      #Get the financial year start date for the company
      Filter [F:FIY] Where [F:FIY]CPY = GSOCIETE and [F:FIY]LEDTYP = 1 and [F:FIY]FIYSTR < date$
      Read [F:FIY]FIY0 Last
      If fstat : Goto $NEXT_ITM : Endif
      Filter [FIY]
      LFIYNUM = [F:FIY]FIYNUM -1
      # If no previous fiscal year exists or
      # The fiscal year is not closed, skip
      Read [F:FIY]FIY0 = [F:FIY]CPY;[F:FIY]LEDTYP;LFIYNUM
      If fstat or [F:FIY]FIYSTA <> 3
        Call ECR_TRACE(  [F:ITF]STOFCY - ". " +mess(00676,00199,1) ,0) From GESECRAN
        SKIP_SITE(SKIP_SITE_INDEX) = [F:ITF]STOFCY
        SKIP_SITE_INDEX += 1
        Goto $NEXT_ITM
      Endif
      #Get the period end date for last fiscal year
      Filter [F:PER] Where [F:PER]CPY = [F:FIY]CPY and [F:PER]FIYNUM = LFIYNUM
      Read [F:PER]PER0 Last
      Filter [PER]
      If fstat : Goto $NEXT_ITM : Endif
      LPERENDNUM = [F:PER]PERNUM
      LPEREND    = [F:PER]PEREND
      #Create PIT records for primary cost method
      COST_METHOD = 1
      Case [F:TCM]ISSVLTCOD(0)
        When 1, 2 #Standard
          Gosub REG_STD
        When 4 # Average Cost
          Gosub REG_AVC
        When 5 #FIFO
          Gosub REG_FIFO
        When 6 # Average Lot Cost
          Gosub REG_ALC
        When 8 #LIFO
          Gosub REG_FIFO
        When Default
      Endcase
      If IERR : Goto $NEXT_ITM : Endif
      #Create PIT records for Secondary cost method
      If  dim([F:STJ]PITVALFLG2)>0
        If [F:TCM]ISSVLTCOD(1)>0 & [F:TCM]ISSVLTCOD(1)<>[F:TCM]ISSVLTCOD(0) & !(find([F:TCM]ISSVLTCOD(0),5,8) & find([F:TCM]ISSVLTCOD(1),5,8))
          Raz LRET
          COST_METHOD = 2
          Case [F:TCM]ISSVLTCOD(1)
            When 1, 2 #Standard
              Gosub REG_STD
            When 4 # Average Cost
              Gosub REG_AVC
            When 5 #FIFO
              Gosub REG_FIFO
            When 6 # Average Lot Cost
              Gosub REG_ALC
            When 8 #LIFO
              Gosub REG_FIFO
            When Default
          Endcase
        Endif
      Endif
      If IERR : Goto $NEXT_ITM : Endif
      # Update all beg balance records as posted in PIT
      # Set PIT posted flag to true for all posted records that are not processed
      Raz CRIT
      CRIT  = '(([F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <= LPEREND) | ([F:STJ]ACCDAT=[0/0/0] & [F:STJ]IPTDAT <= LPEREND))'
      CRIT -= 'and [F:STJ]ITMREF = [F:ITF]ITMREF and [F:STJ]STOFCY = [F:ITF]STOFCY and [F:STJ]AGGIFAFLG = 2'
      If dim([F:STJ]PITVALFLG2)>0
        Update [F:STJ] Where evalue(CRIT) With [F:STJ]PITVALFLG=2, [F:STJ]PITVALFLG2=2
        If fstat <> [V]CST_AOK
          Call ECR_TRACE("File STOJOU PITVALFLG set. Error =" - num$(fstat), 1) From GESECRAN
          IERR = 1
        Endif
      Else
        Update [F:STJ] Where evalue(CRIT) With [F:STJ]PITVALFLG=2
        If fstat <> [V]CST_AOK
          Call ECR_TRACE("File STOJOU PITVALFLG set. Error =" - num$(fstat), 1) From GESECRAN
          IERR = 1
        Endif
      Endif
      # -----------------------
      $NEXT_ITM
      If IERR
        # If there was an error processing this product/site, add to our skip list so we ignore for rest of process
        If find([F:ITF]ITMREF+";"+[F:ITF]STOFCY,SKIP_ITM_FCY) = 0
          #add product/site to the skip array
          SKIP_ITM_FCY(ITM_FCY_INDEX) = [F:ITF]ITMREF+";"+[F:ITF]STOFCY
        Endif
        ITM_FCY_INDEX += 1
      Endif
      # -----------------------
    Next
    Filter [F:ITF]
    Raz CRIT
    If dim([F:STJ]PITVALFLG2)>0
      CRIT = "[F:STJ]AGGIFAFLG=2 & ([F:STJ]PITVALFLG <> 2 | [F:STJ]PITVALFLG2 <> 2)"
    Else
      CRIT = "[F:STJ]AGGIFAFLG=2 & [F:STJ]PITVALFLG <> 2"
    Endif
    CRIT += " & ([F:STJ]ENTCOD<>'' | [F:STJ]TRSTYP=22)"
    #Create PIT records for all other STOJOU records
    Filter [F:STJ] Where evalue(CRIT) Order By [F:STJ]STOFCY;[F:STJ]IPTDAT;[F:STJ]ITMREF;[F:STJ]MVTSEQ;[F:STJ]MVTIND
    For [F:STJ]
      If find([F:STJ]STOFCY,SKIP_SITE) = 0 and find([F:STJ]ITMREF+";"+[STJ]STOFCY,SKIP_ITM_FCY) = 0
        Call PITUPDATE From STKPITLIB
      Endif
    Next
    Filter [F:STJ]
  Endif
  If IERR Then
    Rollback
  Else
    Commit
  Endif
  If dim(GDOS)>0 Then
    Kill GDOS
  Endif
  Call ECR_TRACE('PIT UPGRADE END',0) From GESECRAN
End

################################################################################
#Standard Cost
################################################################################
$REG_STD
Local Decimal RECEIPT_AMT, ISSUE_AMT, RECEIPT_QTY, ISSUE_QTY, VALCHG, AMTDEV
Local Decimal LVARVAL, LAMTDEV
Local Char    LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

Local Char    CRIT(255), CRIT2(255)

  #CRIT = 'IPTDAT <= LPEREND and ITMREF = [ITF]ITMREF and STOFCY = [ITF]STOFCY'
  CRIT  = '(([F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <= LPEREND) | ([F:STJ]ACCDAT=[0/0/0] & [F:STJ]IPTDAT <= LPEREND))'
  CRIT -= 'and [F:STJ]ITMREF = [F:ITF]ITMREF and [F:STJ]STOFCY = [F:ITF]STOFCY'

  If COST_METHOD = 1
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG <> [V]CST_AYES'
  Else
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG2 <> [V]CST_AYES'
  Endif

  CRIT2 = "([F:STJ]NUMVCR<>'' | find([F:STJ]TRSTYP,15,22))"
  #CRIT2 = 'find(TRSTYP,7,8,9,10,15,16,17,18,20,21,22,25,26,27,28,30,31,32,33,34) = 0'

  Filter [F:STJ] Where evalue(CRIT) and evalue(CRIT2) Order By [F:STJ]ECCVALMAJ;[F:STJ]ECCVALMIN
  For [F:STJ]
    #First pass or using the same major/minor version
    If (LECCMAJ = [F:STJ]ECCVALMAJ and LECCMIN = [F:STJ]ECCVALMIN) or LECCMAJ = ""
      Gosub ADD_ITCP

    Else #different major/minor version

      Gosub WRITE_ITCP
      Raz [L]RECEIPT_QTY, [L]RECEIPT_AMT, [L]ISSUE_QTY, [L]ISSUE_AMT, [L]VALCHG, [L]AMTDEV
      Gosub ADD_ITCP
    Endif

  Next
  Filter [STJ]

  Gosub WRITE_ITCP

Return

##############################
$ADD_ITCP

  Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB

  If COST_METHOD = 1
    [L]LAMTDEV = [F:STJ]AMTDEV
    [L]LVARVAL = [F:STJ]VARVAL
  Else
    [L]LAMTDEV = [F:STJ]AMTDEV2
    [L]LVARVAL = [F:STJ]VARVAL2
  Endif

  Case LMVTTYP
    When 1 # Receipt
      RECEIPT_QTY += [F:STJ]QTYSTU
      RECEIPT_AMT += [L]LVARVAL
    When 2 # Issue
      ISSUE_QTY += [F:STJ]QTYSTU
      ISSUE_AMT += [L]LVARVAL
    When 3 #Value Change
      VALCHG += [L]LVARVAL
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>0
        RECEIPT_QTY += [F:STJ]QTYSTU
        RECEIPT_AMT += [L]LVARVAL
      Else
        ISSUE_QTY += [F:STJ]QTYSTU
        ISSUE_AMT += [L]LVARVAL
      Endif
  Endcase

  # Sum up AMTDEV for the period.
  [L]AMTDEV += [L]LAMTDEV

  LECCMAJ = [F:STJ]ECCVALMAJ
  LECCMIN = [F:STJ]ECCVALMIN

Return

##############################
$WRITE_ITCP

  Filter [F:ITC] Where [F:ITC]STOFCY = [F:STJ]STOFCY and [F:ITC]ITMREF = [F:STJ]ITMREF and
&                      [F:ITC]CSTTYP = [F:TCM]ISSVLTCOD(COST_METHOD-1) and [F:ITC]ITCSTRDAT <= LPEREND
  Read [F:ITC]ITC1 Last
  Filter [F:ITC]
  If fstat
    Raz [F:ITC]
  Endif

  #Store record keys
  [F:ITCP]ITMREF    = [F:STJ]ITMREF
  [F:ITCP]STOFCY    = [F:STJ]STOFCY
  [F:ITCP]PERSTR    = [0/0/0]
  [F:ITCP]PEREND    = LPEREND
  [F:ITCP]CSTCHGDAT = [0/0/0]
  [F:ITCP]STDCST    = [F:ITC]CSTTOT
  [F:ITCP]ECCVALMAJ = LECCMAJ
  [F:ITCP]ECCVALMIN = LECCMIN
  [F:ITCP]CSTTYP    = [F:TCM]ISSVLTCOD(COST_METHOD-1)
  [F:ITCP]VLTNUM    = COST_METHOD

  [F:ITCP]FIYNUM    = LFIYNUM
  [F:ITCP]PERNUM    = LPERENDNUM

  #Beginning starts at 0
  [F:ITCP]PERBEGCST = 0
  [F:ITCP]PERBEGQTY = 0

  #Store summed values
  [F:ITCP]PERRCPQTY = RECEIPT_QTY
  [F:ITCP]PERRCPCST = RECEIPT_AMT
  [F:ITCP]PERISSQTY = ISSUE_QTY
  [F:ITCP]PERISSCST = ISSUE_AMT
  [F:ITCP]PERVALCHG = VALCHG
  [F:ITCP]PERAMTDEV = [L]AMTDEV

  #Calculate cumulatives
  [F:ITCP]PERCUMQTY = RECEIPT_QTY+ISSUE_QTY
  [F:ITCP]PERCUMCST = RECEIPT_AMT+ISSUE_AMT+VALCHG

  #End balance is equal to cumulative balance
  [F:ITCP]PERENDCST = [F:ITCP]PERCUMCST
  [F:ITCP]PERENDQTY = [F:ITCP]PERCUMQTY

  If [F:ITCP]PERENDQTY <> 0 or [F:ITCP]PERENDCST <> 0
    Write [F:ITCP]
    If fstat <> [V]CST_AOK
      Call ECR_TRACE("Write ITMCOSTPIT. Error =" - num$(fstat), 1) From GESECRAN
      IERR = 1
    Endif
  Endif

Return


################################################################################
#Average Cost
################################################################################
$REG_AVC
Local Decimal RECEIPT_AMT, ISSUE_AMT, RECEIPT_QTY, ISSUE_QTY, AMTDEV, VALCHG
Local Decimal LVARVAL, LAMTDEV
Local Char    CRIT(255), CRIT2(255)

  CRIT  = '(([F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <= LPEREND) or ([F:STJ]ACCDAT=[0/0/0] & [F:STJ]IPTDAT <= LPEREND))'
  CRIT -= 'and [F:STJ]ITMREF = [F:ITF]ITMREF and [F:STJ]STOFCY = [F:ITF]STOFCY'

  If COST_METHOD = 1
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG <> [V]CST_AYES'
  Else
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG2 <> [V]CST_AYES'
  Endif

  CRIT2 = "([F:STJ]NUMVCR<>'' | find([F:STJ]TRSTYP,15,22))"

  Filter [STJ] Where evalue(CRIT) and evalue(CRIT2)
  For [STJ]
    Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB

    If COST_METHOD = 1
      LVARVAL = [F:STJ]VARVAL
      LAMTDEV = [F:STJ]AMTDEV
    Else
      LVARVAL = [F:STJ]VARVAL2
      LAMTDEV = [F:STJ]AMTDEV2
    Endif

    Case LMVTTYP
      When 1 # Receipt
        RECEIPT_QTY += [F:STJ]QTYSTU
        RECEIPT_AMT += LVARVAL
      When 2 # Issue
        ISSUE_QTY   += [F:STJ]QTYSTU
        ISSUE_AMT   += LVARVAL
      When 3 # Value changes
        VALCHG      += LVARVAL
      When Default  # Misc - base the movement type on the sign
        If [F:STJ]QTYSTU>0
          RECEIPT_QTY += [F:STJ]QTYSTU
          RECEIPT_AMT += LVARVAL
        Else
          ISSUE_QTY   += [F:STJ]QTYSTU
          ISSUE_AMT   += LVARVAL
        Endif
    Endcase
    [L]AMTDEV += [L]LAMTDEV
    If [F:STJ]TRSTYP = 35
      [F:ITVP]PERCUMAMT += [L]LAMTDEV
    Endif

  Next
  Filter [STJ]

  [F:ITVP]ITMREF    = [F:STJ]ITMREF
  [F:ITVP]STOFCY    = [F:STJ]STOFCY
  [F:ITVP]PERSTR    = [0/0/0]
  [F:ITVP]PEREND    = LPEREND
  [F:ITVP]VLTNUM    = COST_METHOD

  [F:ITVP]FIYNUM    = LFIYNUM
  [F:ITVP]PERNUM    = LPERENDNUM

  [F:ITVP]BEGBASAMT = 0
  [F:ITVP]BEGBASQTY = 0
  [F:ITVP]BEGAVC    = 0

  [F:ITVP]PERRCPQTY = RECEIPT_QTY
  [F:ITVP]PERRCPAMT = RECEIPT_AMT
  [F:ITVP]PERISSQTY = ISSUE_QTY
  [F:ITVP]PERISSAMT = ISSUE_AMT
  [F:ITVP]PERVALCHG = VALCHG
  [F:ITVP]PERAMTDEV = [L]AMTDEV

  [F:ITVP]PERCUMQTY = RECEIPT_QTY+ISSUE_QTY
  [F:ITVP]PERCUMAMT = RECEIPT_AMT+ISSUE_AMT
  If [F:ITVP]PERCUMQTY <> 0
    [F:ITVP]PERCUMAVC = [F:ITVP]PERCUMAMT / [F:ITVP]PERCUMQTY
  Else
    Raz [F:ITVP]PERCUMAVC
  Endif

  [F:ITVP]ENDBASAMT = [F:ITVP]PERCUMAMT
  [F:ITVP]ENDBASQTY = [F:ITVP]PERCUMQTY
  [F:ITVP]ENDAVC    = [F:ITVP]PERCUMAVC

  If [F:ITVP]ENDBASQTY <> 0 or [F:ITVP]ENDBASAMT <> 0
    Write [F:ITVP]
    If fstat <> [V]CST_AOK
      Call ECR_TRACE("Write ITMMVTPIT. Error =" - num$(fstat), 1) From GESECRAN
      IERR = 1
    Endif
  Endif
Return

################################################################################
#FIFO/LIFO
################################################################################
$REG_FIFO
Local Decimal RECEIPT_AMT, ISSUE_AMT, RECEIPT_QTY, ISSUE_QTY, AMTDEV, VALCHG
Local Decimal LVARVAL, LAMTDEV
Local Char    CRIT(255), CRIT2(255)
Local Integer CURRENT_TIER
Local Date  COST_DATE
Local Char TIER_TIME(6)
TIER_TIME = '0'

  FIRST_PASS = 1

  #CRIT = 'IPTDAT <= LPEREND and ITMREF = [ITF]ITMREF and STOFCY = [ITF]STOFCY'
  CRIT  = '(([F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <= LPEREND) | ([F:STJ]ACCDAT=[0/0/0] & [F:STJ]IPTDAT <= LPEREND))'
  CRIT -= 'and [F:STJ]ITMREF = [F:ITF]ITMREF and [F:STJ]STOFCY = [F:ITF]STOFCY'

  If COST_METHOD = 1
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG <> [V]CST_AYES'
  Else
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG2 <> [V]CST_AYES'
  Endif

  CRIT2 = "([F:STJ]NUMVCR<>'' | find([F:STJ]TRSTYP,15,22))"
  #CRIT2 = 'find(TRSTYP,7,8,9,10,15,16,17,18,20,21,22,25,26,27,28,30,31,32,33,34) = 0'

  Filter [STJ] Where evalue(CRIT) and evalue(CRIT2) Order By [F:STJ]CSTCOU
  For [STJ]

    If COST_METHOD = 1
      LVARVAL = [F:STJ]VARVAL
      LAMTDEV = [F:STJ]AMTDEV
    Else
      LVARVAL = [F:STJ]VARVAL2
      LAMTDEV = [F:STJ]AMTDEV2
    Endif

    If CURRENT_TIER <> [F:STJ]CSTCOU and CURRENT_TIER <> 0

      Gosub WRITE_STPP

      Raz [F:STPP]
      Raz RECEIPT_QTY, RECEIPT_AMT, ISSUE_QTY, ISSUE_AMT, VALCHG, [L]AMTDEV
    Endif

    Gosub ADD_STPP

  Next
  Filter [STJ]

  Gosub WRITE_STPP

Return

############################################
$ADD_STPP

  CURRENT_TIER = [F:STJ]CSTCOU
  TIER_TIME    = [F:STJ]CSTTIM
  COST_DATE    = [F:STJ]CSTDAT
  FIRST_PASS   = 0

  Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB

  Case LMVTTYP
    When 1 # Receipt.
      If [F:STJ]QTYSTU < 0#X3-58152.s MJH receipts with negative QTY and a record in SMC are deleted and treated as issues
        Filter [F:SMC2] Where [F:SMC2]STOFCY = [F:STJ]STOFCY and [F:SMC2]VCRTYP = [F:STJ]VCRTYP and [F:SMC2]VCRNUM = [F:STJ]VCRNUM and [F:SMC2]VCRLIN = [F:STJ]VCRLIN
        Look [F:SMC2]First
        Filter [SMC2]
        If fstat
          RECEIPT_QTY += [F:STJ]QTYSTU
          RECEIPT_AMT += LVARVAL
        Endif
      Else#X3-58152.e
        RECEIPT_QTY += [F:STJ]QTYSTU
        RECEIPT_AMT += LVARVAL
      Endif
    When 2 # Issues
      #Do Nothing
    When 3 # Value changes
      VALCHG      += LVARVAL
    When Default  # Misc - base the movement type on the sign
      If [F:STJ]QTYSTU>=0
        RECEIPT_QTY += [F:STJ]QTYSTU
        RECEIPT_AMT += LVARVAL
      Endif
  Endcase
  [L]AMTDEV += [L]LAMTDEV

Return

############################################
$WRITE_STPP
  Gosub GET_ISSUE_VAL

  [F:STPP]ITMREF    = [F:STJ]ITMREF
  [F:STPP]STOFCY    = [F:STJ]STOFCY
  [F:STPP]CSTCOU    = CURRENT_TIER
  [F:STPP]CSTDAT    = COST_DATE
  [F:STPP]CSTTIM    = TIER_TIME
  [F:STPP]PERSTR    = [0/0/0]
  [F:STPP]PEREND    = LPEREND
  [F:STPP]VLTNUM    = COST_METHOD

  [F:STPP]FIYNUM    = LFIYNUM
  [F:STPP]PERNUM    = LPERENDNUM

  [F:STPP]PERBEGCST = 0
  [F:STPP]PERBEGQTY = 0

  [F:STPP]PERRCPQTY = RECEIPT_QTY
  [F:STPP]PERRCPCST = RECEIPT_AMT
  [F:STPP]PERISSQTY = ISSUE_QTY
  [F:STPP]PERISSCST = ISSUE_AMT
  [F:STPP]PERVALCHG = VALCHG
  [F:STPP]PERAMTDEV = [L]AMTDEV

  [F:STPP]PERCUMQTY = RECEIPT_QTY+ISSUE_QTY
  [F:STPP]PERCUMCST = RECEIPT_AMT+ISSUE_AMT+[L]AMTDEV

  [F:STPP]PERENDCST = [F:STPP]PERCUMCST
  [F:STPP]PERENDQTY = [F:STPP]PERCUMQTY

  If [F:STPP]PERENDQTY <> 0 or [F:STPP]PERENDCST <> 0
    Write [F:STPP]
    If fstat <> [V]CST_AOK
      Call ECR_TRACE("Write STOCOSTPIT. Error =" - num$(fstat), 1) From GESECRAN
      IERR = 1
    Endif
  Endif
Return

############################################
$GET_ISSUE_VAL
  Local Char VCRLIST(GLONVCR) (255), VCRNEXT(GLONVCR)
  Local Integer COUNTER, CONTINUE
  CONTINUE = 1

  While CONTINUE = 1
    #Get list of all VCRNUMs in that period
    Raz COUNTER, VCRLIST
    Filter [STJ2] Where [F:STJ2]STOFCY = [F:ITF]STOFCY and [F:STJ2]ITMREF = [F:ITF]ITMREF and [F:STJ2]IPTDAT <= LPEREND
    For [STJ2] Where [F:STJ2]VCRNUM > VCRNEXT
      If !find([STJ2]VCRNUM,VCRLIST)
        VCRLIST(COUNTER) = [F:STJ2]VCRNUM
        COUNTER +=1
        If COUNTER = 255#Our list is at max capacity
          VCRNEXT = [F:STJ2]VCRNUM
          Break
        Endif
      Endif
    Next
    Filter [STJ]

    #Sum all QTY and AMT that are in that list for the current CSTCOU
    For [F:SMC2] Where find([F:STJ2]VCRNUM,VCRLIST) and [F:SMC2]CSTCOU = [F:STJ]CSTCOU
      ISSUE_QTY -= [F:SMC2]QTYSTU
      ISSUE_AMT -= [F:SMC2]CST
    Next

    #If our list was not at max, we have finished
    If COUNTER < 255
      CONTINUE = 0
    Endif
  Wend

Return
################################################################################
#Average Lot Cost
################################################################################
$REG_ALC
Local Decimal RECEIPT_AMT, ISSUE_AMT, RECEIPT_QTY, ISSUE_QTY, AMTDEV, VALCHG
Local Decimal LVARVAL
Local Char    CRIT(255), CRIT2(255)

Local Char CURRENT_LOT(15), CURRENT_SLO(5)
Local Integer FIRST_PASS

  FIRST_PASS = 1

  CRIT  = '(([F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <= LPEREND) | ([F:STJ]ACCDAT=[0/0/0] & [F:STJ]IPTDAT <= LPEREND))'
  CRIT -= 'and [F:STJ]ITMREF = [F:ITF]ITMREF and [F:STJ]STOFCY = [F:ITF]STOFCY'

  If COST_METHOD = 1
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG <> [V]CST_AYES'
  Else
    CRIT -= 'and [F:STJ]AGGIFAFLG = 2 and [F:STJ]PITVALFLG2 <> [V]CST_AYES'
  Endif

  CRIT2 = "([F:STJ]NUMVCR<>'' | find([F:STJ]TRSTYP,15,22))"

  #Average lot needs to create a different record for each lot/sublot combination
  Filter [STJ] Where evalue(CRIT) and evalue(CRIT2) Order By [F:STJ]LOT;[F:STJ]SLO
  For [STJ]

    If COST_METHOD = 1
      LVARVAL = [F:STJ]VARVAL
      LAMTDEV = [F:STJ]AMTDEV
    Else
      LVARVAL = [F:STJ]VARVAL2
      LAMTDEV = [F:STJ]AMTDEV2
    Endif

    #write the record for the current lot/sublot combination
    If (CURRENT_LOT <> [F:STJ]LOT or CURRENT_SLO <> [F:STJ]SLO) and FIRST_PASS <> 1
      [F:SLFP]ITMREF    = [F:STJ]ITMREF
      [F:SLFP]STOFCY    = [F:STJ]STOFCY
      [F:SLFP]LOT       = CURRENT_LOT
      [F:SLFP]SLO       = CURRENT_SLO
      [F:SLFP]PERSTR    = [0/0/0]
      [F:SLFP]PEREND    = LPEREND
      [F:SLFP]VLTNUM    = COST_METHOD

      [F:SLFP]FIYNUM    = LFIYNUM
      [F:SLFP]PERNUM    = LPERENDNUM

      [F:SLFP]BEGBASAMT = 0
      [F:SLFP]BEGBASQTY = 0
      [F:SLFP]BEGAVC    = 0

      [F:SLFP]PERRCPQTY = RECEIPT_QTY
      [F:SLFP]PERRCPAMT = RECEIPT_AMT
      [F:SLFP]PERISSQTY = ISSUE_QTY
      [F:SLFP]PERISSAMT = ISSUE_AMT
      [F:SLFP]PERVALCHG = VALCHG
      [F:SLFP]PERAMTDEV = [L]AMTDEV

      [F:SLFP]PERCUMQTY = RECEIPT_QTY+ISSUE_QTY
      [F:SLFP]PERCUMAMT = RECEIPT_AMT+ISSUE_AMT+[L]AMTDEV
      If [F:SLFP]PERCUMQTY <> 0
        [F:SLFP]PERCUMAVC = [F:SLFP]PERCUMAMT / [F:SLFP]PERCUMQTY
      Else
        Raz [F:SLFP]PERCUMAVC
      Endif

      [F:SLFP]ENDBASAMT = [F:SLFP]PERCUMAMT
      [F:SLFP]ENDBASQTY = [F:SLFP]PERCUMQTY
      [F:SLFP]ENDAVC    = [F:SLFP]PERCUMAVC

      If [F:SLFP]ENDBASQTY <> 0 or [F:SLFP]ENDBASAMT <> 0
        Write [F:SLFP]
        If fstat <> [V]CST_AOK
          Call ECR_TRACE("Write STOLOTFCYPIT. Error =" - num$(fstat), 1) From GESECRAN
          IERR = 1
        Endif
      Endif

      Raz [F:SLFP]
      Raz RECEIPT_QTY, RECEIPT_AMT, ISSUE_QTY, ISSUE_AMT,VALCHG, [L]AMTDEV
    Endif

    FIRST_PASS = 0

    #Get the Current Lot/Sublot
    CURRENT_LOT = [STJ]LOT
    CURRENT_SLO = [STJ]SLO

    Call GETMVTTYP([F:STJ]TRSTYP, LMVTTYP) From STKPITLIB

    Case LMVTTYP
      When 1 # Receipt
        RECEIPT_QTY += [F:STJ]QTYSTU
        RECEIPT_AMT += LVARVAL
      When 2 # Issue
        ISSUE_QTY   += [F:STJ]QTYSTU
        ISSUE_AMT   += LVARVAL
      When 3 # Value changes
        VALCHG      += LVARVAL
      When Default  # Misc - base the movement type on the sign
        If [F:STJ]QTYSTU>0
          RECEIPT_QTY += [F:STJ]QTYSTU
          RECEIPT_AMT += LVARVAL
        Else
          ISSUE_QTY   += [F:STJ]QTYSTU
          ISSUE_AMT   += LVARVAL
        Endif
    Endcase
    [L]AMTDEV += [L]LAMTDEV

  Next
  Filter [STJ]

  [F:SLFP]ITMREF    = [F:STJ]ITMREF
  [F:SLFP]STOFCY    = [F:STJ]STOFCY
  [F:SLFP]LOT       = CURRENT_LOT
  [F:SLFP]SLO       = CURRENT_SLO
  [F:SLFP]PERSTR    = [0/0/0]
  [F:SLFP]PEREND    = LPEREND

  [F:SLFP]FIYNUM    = LFIYNUM
  [F:SLFP]PERNUM    = LPERENDNUM

  [F:SLFP]BEGBASAMT = 0
  [F:SLFP]BEGBASQTY = 0
  [F:SLFP]BEGAVC    = 0

  [F:SLFP]PERRCPQTY = RECEIPT_QTY
  [F:SLFP]PERRCPAMT = RECEIPT_AMT
  [F:SLFP]PERISSQTY = ISSUE_QTY
  [F:SLFP]PERISSAMT = ISSUE_AMT

  [F:SLFP]PERVALCHG = VALCHG
  [F:SLFP]PERAMTDEV = [L]AMTDEV

  [F:SLFP]PERCUMQTY = RECEIPT_QTY+ISSUE_QTY
  [F:SLFP]PERCUMAMT = RECEIPT_AMT+ISSUE_AMT+[L]AMTDEV
  If [F:SLFP]PERCUMQTY <> 0
    [F:SLFP]PERCUMAVC = [F:SLFP]PERCUMAMT / [F:SLFP]PERCUMQTY
  Else
    Raz [F:SLFP]PERCUMAVC
  Endif

  [F:SLFP]ENDBASAMT = [F:SLFP]PERCUMAMT
  [F:SLFP]ENDBASQTY = [F:SLFP]PERCUMQTY
  [F:SLFP]ENDAVC    = [F:SLFP]PERCUMAVC

  If [F:SLFP]ENDBASQTY <> 0 or [F:SLFP]ENDBASAMT <> 0
    Write [F:SLFP]
    If fstat <> [V]CST_AOK
      Call ECR_TRACE("Write STOLOTFCYPIT. Error =" - num$(fstat), 1) From GESECRAN
      IERR = 1
    Endif
  Endif

Return

################################################################################
Subprog PATCH(DOSSIER)
Value Char    DOSSIER

Local Integer RCOMMIT

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=[L]DOSSIER
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  # Check that all tables exist and are not views
  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  # -------------------------
  Call ECR_TRACE("UTIPIT Start",0) From GESECRAN
  Call UTIPIT_UPG([L]DOSSIER)
  Call ECR_TRACE("UTIPIT End",0) From GESECRAN
End

################################################################################
# Pour exécution depuis dosmaj (validation dossier)
################################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  # Check that all tables exist and are not views
  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  Call ECR_TRACE("UTIPIT Start",0) From GESECRAN
  Call UTIPIT_UPG([L]DOSSIER)
  Call ECR_TRACE("UTIPIT End",0) From GESECRAN
End

################################################################################
Subprog PATCHR7(DOSSIER)
Value Char    DOSSIER

Local Integer RCOMMIT

  If [L]DOSSIER = GDOSX3 and GADONIX <> 2 Then
    End
  Endif

  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=[L]DOSSIER
  If fstat Then
    Raz [F:ADS]
  Endif

  # Check that all tables exist and are not views
  If !func TABLE_CHECK([L]DOSSIER) Then
    End
  Endif

  # -------------------------
  Local File =DOSSIER+".STOJOU"       [STJ]
  # -------------------------

  Filter [STJ] Where [F:STJ]ACCDAT<>[0/0/0] & [F:STJ]ACCDAT <> [F:STJ]IPTDAT
  Look [STJ] First
  Filter [STJ]
  If !fstat
    # -------------------------
    # Records exist where ACCDAT is not the same as IPTDAT
    # We need to wipe out the PIT tables and re-run the upgrade

    # Call the upgrade script
    Call UTIPIT_UPG([L]DOSSIER)

  Endif
  Call ECR_TRACE("UTIPIT End",0) From GESECRAN
End

################################################################################
Funprog TABLE_CHECK(DOSSIER)
Value Char DOSSIER

  # Check for the existence of every table needed
  # Verify that the tables are not a view - indicates historic folder
  # If any fail this check, do not run the upgrade
  If filinfo(filpath("FIL","ITMFACILIT","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMFACILIT")                  : End 0 : Endif
  If filinfo(filpath("FIL","FISCALYEAR","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "FISCALYEAR")                  : End 0 : Endif
  If filinfo(filpath("FIL","STOJOU","fde",DOSSIER),0)<=0        : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STOJOU")                      : End 0 : Endif
  If filinfo(filpath("FIL","TABCOSTMET","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "TABCOSTMET")                  : End 0 : Endif
  If filinfo(filpath("FIL","STKMVTADJ","fde",DOSSIER),0)<=0     : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STKMVTADJ")                   : End 0 : Endif
  If filinfo(filpath("FIL","ITMMVTPIT","fde",DOSSIER),0)<=0     : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMMVTPIT")                   : End 0 : Endif
  If filinfo(filpath("FIL","STOLOTFCYPIT","fde",DOSSIER),0)<=0  : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STOLOTFCYPIT")                : End 0 : Endif
  If filinfo(filpath("FIL","ITMCOSTPIT","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMCOSTPIT")                  : End 0 : Endif
  If filinfo(filpath("FIL","STOCOSTPIT","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STOCOSTPIT")                  : End 0 : Endif
  If filinfo(filpath("FIL","STOMVTCOST","fde",DOSSIER),0)<=0    : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "STOMVTCOST")                  : End 0 : Endif
  If filinfo(filpath("FIL","ITMMASTER","fde",DOSSIER),0)<=0     : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMMASTER")                   : End 0 : Endif
  If filinfo(filpath("FIL","ITMCATEG","fde",DOSSIER),0)<=0      : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMCATEG")                    : End 0 : Endif
  If filinfo(filpath("FIL","PERIOD","fde",DOSSIER),0)<=0        : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "PERIOD")                      : End 0 : Endif
  If filinfo(filpath("FIL","ITMCOST","fde",DOSSIER),0)<=0       : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "ITMCOST")                     : End 0 : Endif
  If filinfo(filpath("FIL","CGVDET","fde",DOSSIER),0)<=0        : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "CGVDET")                      : End 0 : Endif
  If filinfo(filpath("FIL","FACILITY","fde",DOSSIER),0)<=0      : End 0 : Endif
  If func DOSVUE.ISVIEW(DOSSIER, "FACILITY")                    : End 0 : Endif

End 1

