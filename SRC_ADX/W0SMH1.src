#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SMH1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "SMH"
  Local Char    VALEUR(250)
  VALEUR = [M]COD
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]COD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBSMH
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varinit([M]DES,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DES,"SCREMPH","DES",GCURLEG,[M]COD) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DES,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone CODACS
mkstat = 0
zoncou = "CODACS"
indice = 0
If varmode([M]CODACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]CODACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTACC"
  Call CONTACC([M]CODACS) From SUBACS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CODACT
mkstat = 0
zoncou = "CODACT"
indice = 0
If varmode([M]CODACT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODACT" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACV","!",[M]CODACT,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CODACT" : GZNUM = 4 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone ENAFLG
mkstat = 0
zoncou = "ENAFLG"
indice = 0
IMPENT = [M]ENAFLG
If varinit([M]ENAFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]ENAFLG,indice)=0
 [M]ENAFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLG(indice)
 Endif
Endif
[M]ENAFLG = IMPENT

## Zone FLGMAT
mkstat = 0
zoncou = "FLGMAT"
indice = 0
IMPENT = [M]FLGMAT
If varinit([M]FLGMAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGMAT,indice)=0
 [M]FLGMAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGMAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGMAT(indice)
 Endif
Endif
[M]FLGMAT = IMPENT

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
indice = 0
status = 1
zoncou = "NBRLIG"
If varmode([M]NBRLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRLIG = nolign
   status = 75
   Call SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRFIL
mkstat = 0
zoncou = "NBRFIL"
indice = 0
status = 1
zoncou = "NBRFIL"
If varmode([M]NBRFIL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRFIL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRFIL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRFIL = nolign
   status = 75
   Call SAI_NBRFIL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
SAVACT = GACTION : GACTION = "STD"
Call AVANT_NBRLIG From SUBSMH
GACTION = SAVACT

## Zone FLD
mkstat = 0
zoncou = "FLD"
If varmode([M]FLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]FLD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_FLD([M]FLD(indice)) From SUBSMH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLD" : GZNUM = 1261 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone TITFLG
mkstat = 0
zoncou = "TITFLG"
IMPENT = [M]TITFLG(indice)
If varinit([M]TITFLG,indice)=0
 IMPENT = 1
Endif
[M]TITFLG(indice) = IMPENT

## Zone TIT
mkstat = 0
zoncou = "TIT"
WCHAR = [M]TIT(indice)
If varmode([M]TIT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIT" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]TIT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TIT([M]TIT(indice)) From SUBSMH
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIT" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone IND
mkstat = 0
zoncou = "IND"
If varmode([M]IND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "IND" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_IND([M]IND(indice)) From SUBSMH
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "IND" : GZNUM = 5300 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone OPT
mkstat = 0
zoncou = "OPT"
IMPENT = [M]OPT(indice)
If varinit([M]OPT,indice)=0
 IMPENT = 1
Endif
If varmode([M]OPT,indice)=0
 Call INICOMBO(35) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_OPT(IMPENT) From SUBSMH
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,35,1))))
 Endif
 [M]OPT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]OPT(indice)
 Endif
 If !mkstat
  If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
   mkstat = 1 : GMESSAGE = mess(99,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "OPT" : GZNUM = 662 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]OPT(indice) = IMPENT

## Zone TYPFRM
mkstat = 0
zoncou = "TYPFRM"
IMPENT = [M]TYPFRM(indice)
If varinit([M]TYPFRM,indice)=0
 IMPENT = 1
Endif
[M]TYPFRM(indice) = IMPENT

## Zone TYPTPS
mkstat = 0
zoncou = "TYPTPS"
IMPENT = [M]TYPTPS(indice)
If varinit([M]TYPTPS,indice)=0
 IMPENT = 1
Endif
[M]TYPTPS(indice) = IMPENT

## Zone PRDTYP
mkstat = 0
zoncou = "PRDTYP"
IMPENT = [M]PRDTYP(indice)
If varinit([M]PRDTYP,indice)=0
 IMPENT = 1
Endif
[M]PRDTYP(indice) = IMPENT

## Zone PRDMTH
mkstat = 0
zoncou = "PRDMTH"
IMPENT = [M]PRDMTH(indice)
If varinit([M]PRDMTH,indice)=0
 IMPENT = 1
Endif
[M]PRDMTH(indice) = IMPENT

## Zone PRDQTR
mkstat = 0
zoncou = "PRDQTR"
IMPENT = [M]PRDQTR(indice)
If varinit([M]PRDQTR,indice)=0
 IMPENT = 1
Endif
[M]PRDQTR(indice) = IMPENT

## Zone PRDHLF
mkstat = 0
zoncou = "PRDHLF"
IMPENT = [M]PRDHLF(indice)
If varinit([M]PRDHLF,indice)=0
 IMPENT = 1
Endif
[M]PRDHLF(indice) = IMPENT

## Zone PRDANN
mkstat = 0
zoncou = "PRDANN"
IMPENT = [M]PRDANN(indice)
If varinit([M]PRDANN,indice)=0
 IMPENT = 1
Endif
[M]PRDANN(indice) = IMPENT

## Zone TOTTYP
mkstat = 0
zoncou = "TOTTYP"
IMPENT = [M]TOTTYP(indice)
If varinit([M]TOTTYP,indice)=0
 IMPENT = 1
Endif
[M]TOTTYP(indice) = IMPENT

## Zone TOTTYPELM
mkstat = 0
zoncou = "TOTTYPELM"
IMPENT = [M]TOTTYPELM(indice)
If varinit([M]TOTTYPELM,indice)=0
 IMPENT = 1
Endif
[M]TOTTYPELM(indice) = IMPENT

## Zone FLGFRM
mkstat = 0
zoncou = "FLGFRM"
IMPENT = [M]FLGFRM(indice)
If varinit([M]FLGFRM,indice)=0
 IMPENT = 1
Endif
[M]FLGFRM(indice) = IMPENT

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRFIL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRFIL
mkstat = 0
zoncou = "NBRFIL"

## Zone FILTRE
mkstat = 0
zoncou = "FILTRE"
If varmode([M]FILTRE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FILTRE" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBRFIL
mkstat = 0
zoncou = "NBRFIL"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SMH1"
Return

