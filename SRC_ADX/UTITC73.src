#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################
# UTITC73                                                                              #
#                                                                                      #
# Common Data module - Starting date for exporting SAF-T working documents             #
#                      and all payments.                                               #
#                                                                                      #
#                                                                                      #
########################################################################################
Call MAJ_UTITC73
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTITC73
Local Char DOSSIER(30)
  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTITC73 - Starting date for exporting SAF-T working documents and all payments.") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTITC73 - Starting date for exporting SAF-T working documents and all payments.") From LECFIC
    Call EXE_UTITC73(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTITC73(DOSSIER)
Value Char    DOSSIER
  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTITC73 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
    End
  Endif
  Call ECR_TIME("UTITC73: Starting date for exporting SAF-T working documents and all payments:"-DOSSIER) From DOSSUB
  Gosub TRT_STRDATWD
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTITC73 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
#   Initialization of the new field STRDATWD for dkskey    #
#-------------------------------------------------------------------------------#
$TRT_STRDATWD

If GTRACE=""
 Call OUVRE_TRACE("UTITC73 - Starting date for exporting SAF-T working documents and all payments.") From LECFIC
 Local Integer LTRACE
Endif

If filinfo(filpath("FIL","DKSKEY","fde",DOSSIER),0) <= 0 Then
  Return
Endif

If func AFNC.ACTIV("KPO")
  Local File = DOSSIER+".DKSKEY"      [F:DKK]
  Local Tinyint COUNT, UPDFLG

  Trbegin [DKK]

  Filter [F:DKK] Where [F:DKK]KEYCODE = "SAFT-PT" #Order By STRDAT Desc; KEYVER Desc
  For [F:DKK]
    UPDFLG = 0
    If [F:DKK]STRDATWD = [0/0/0]
      [F:DKK]STRDATWD = date$ : UPDFLG += 1
    Endif
    If [F:DKK]STRDATPAY = [0/0/0]
      [F:DKK]STRDATPAY = date$ : UPDFLG += 1
    Endif
    If UPDFLG > 0 : Rewrite [F:DKK] : COUNT += 1 : Endif
  Next

  If COUNT = 0
    [F:DKK]KEYCODE = "SAFT-PT"
    [F:DKK]KEYVER  = 1
    [F:DKK]STRDAT  = gdat$(01,01,2011)
    [F:DKK]STRDATWD =date$
    Write   [F:DKK]
  Endif
  Filter [F:DKK]

  If GOK<1
    Rollback
  Else
    Commit
  Endif
Endif

If dim(LTRACE)>0
  Call LEC_TRACE From LECFIC
Endif

Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If func DOSSUB.FILL_ADS(APPLI)=0    : End : Endif

  If filinfo(filpath("FIL","DKSKEY","fde",APPLI),0)<=0  : End : Endif

  Call EXE_UTITC73(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif

  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If filinfo(filpath("FIL","DKSKEY","fde",APPLI),0)<=0  : End : Endif

  Call EXE_UTITC73(APPLI)
End

