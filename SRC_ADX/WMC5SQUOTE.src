#<AdxTL>@(#)0.0.0.0 $Revision$Class Quote header
# Supervisor
## ACLA-CLASSE ## SQUOTE
# 2018-11-06 07:15:33 125

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 123 : SFISSTCOD SST tax code ( Field Miscellaneous table number)
####################################################################

$SET_SFISSTCOD
If [L]_AOLDVAL<>this.SFISSTCOD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_SFISSTCOD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.SFISSTCOD
 Gosub PROPAGATE_SFISSTCOD
Endif
Return

$INIT_SFISSTCOD
Gosub DECLARE_VAR From WMC0SQUOTE
[L]CURPRO = "SFISSTCOD"
[L]ASTATUS =  func ADI_TOOL.ADI_INI(this,"SFISSTCOD",this.SFISSTCOD,203)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_SFISSTCOD
Gosub DECLARE_VAR From WMC0SQUOTE
[L]CURPRO = "SFISSTCOD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_SFISSTCOD             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_SFISSTCOD             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_SFISSTCOD
[L]CURPRO = "SFISSTCOD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.SFISSTCOD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_SFISSTCOD
[L]CURPRO = "SFISSTCOD"
If vireblc(this.SFISSTCOD,2)<>vireblc(format$("K:20B",this.SFISSTCOD),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_SFISSTCOD
[L]CURPRO = "SFISSTCOD"
[L]ASTATUS =  func ADI_TOOL.ADI_CONT(this,"SFISSTCOD",this.SFISSTCOD,203,AVOID.ACHAR)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_SFISSTCOD
[L]CURPRO = "SFISSTCOD"
Return

$PROPAGATE_SFISSTCOD
this.isReadonly = 0
[L]CURPRO = "SFISSTCOD"
Gosub _LNKPRO_SFISSTCOD
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_SFISSTCOD
Gosub DECLARE_VAR From WMC0SQUOTE
[L]CURPRO = "SFISSTCOD"
$_LNKPRO_SFISSTCOD
If vireblc(this.SFISSTCOD,2)<>""
 # Link ATABDIV
 Local File ATABDIV [WADI]
 Read [F:WADI]CODE = 203;this.SFISSTCOD
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="SHODES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SFISSTCOD","$title",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ATABDIV" & ZONE="LNGDES" & IDENT1=num$([F:WADI]NUMTAB) & IDENT2=[F:WADI]CODE & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SFISSTCOD","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WADI]
Endif
Return




