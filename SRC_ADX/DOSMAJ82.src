  # 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)
  Call AMAJ From TRCMAJ82
  # 107888 : Scheduled invoices : X3-21402 (LD:18/01/17)
Endif

#----- Ensuite les autres modules

Onerrgo
End


