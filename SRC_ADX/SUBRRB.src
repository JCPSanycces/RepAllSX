#<AdxTL>@(#)2.0.0.0 $Revision$
Call OBJET("RRB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_MOD"   : Gosub VERIF
 When "VERIF_CRE"   : Gosub VERIF
 When Default
Endcase
Return

$OUVRE
If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif
Return

$LIENS
If [F:RRB]IPTTYP=2
  [M]NBRACC = max(0,find ("", [F:RRB]COA(0..dim([F:RRB]COA)-1))-1)
  Actzo [M]NBRACC
Else
  Grizo [M]NBRACC
Endif
Return

$VERIF
If [M]IPTTYP=2
  If [M]COA(0)=""
    # Champ plan de compte obligatoire
    GMESSAGE=mess(76,104,1)
    OK=0
    zonsui="COA"
  Endif
Endif
Return

########################################
# Verif validité param BELRUBDEF       #
########################################
#-not used- géré/slection sur l'objet RRB
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value    Char    PARAM
Value    Char    VALEUR
Variable Integer OK
OK = 1
If clalev([F:RRB])=0 : Local File RBKRUBBEL [RRB] : Endif
Call LECTURE("RRB",VALEUR,"") From CONTOBJ
If !fstat & [F:RRB]IPTTYP <> 2
 # La rubrique par défaut doit être imputable
 GMESSAGE = mess(180,121,1)
 OK=0
Endif
End

########################################
## Ecran RRB1                         ##
########################################
Subprog C_RUB(VALEUR)
Variable Char    VALEUR()
If len(VALEUR)=GLONRRB : End : Endif
Local Char CAR(1)
Local Integer I, WOK
WOK=1
For I = 1 To len(VALEUR)
  CAR=mid$(VALEUR,I,1)
  If CAR>="A" & CAR<="ZZZ" : Raz WOK : Break : Endif
Next
If WOK=1 : VALEUR=format$("N0:3",VALEUR) : Endif
End

Subprog C_COA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]COA) From OBJDIV
End

Subprog C_IPTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 2
  For [F:ADW] Where PARAM="BELRUBDEF" & VALEUR=[M]RUB
    # La rubrique par défaut doit être imputable
    GMESSAGE=[M]RUB+" : "+mess(180,121,1)
    mkstat=2 : Break
  Next
Endif
End

Subprog AP_IPTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
 Raz [M]NBRACC, [M]COA, [M]ACC
 Grizo [M]NBRACC
Else
 Actzo [M]NBRACC
Endif
Affzo [M]NBRACC
End
