#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
#
#  RPC CALLS :
Funprog _EXPORTED() : End 1

#
# Entry point for RPC calls
#
$ACTION
Case ACTION
 When "PATCH" : Gosub PATCH
 Endcase
Return

#
# HANDLE RPC calls  to the PATCH function:
$PATCH
Local Integer LEVEL : LEVEL=1
Local Instance  NODE(1..)         Using C_ASYRJSO  : NODE=null
Local Char FOLD(50),DIRECTORY(250),VERSION(20),NAME(30),INTEGRATE(20),FULLMODE(20),SYNCHRONIZE(20)
Local Char SYRSTAMAINT(2),SYRMAINT(30)
Local Char PRONAME(250),PROVALUE(250)
Local Integer DIAG_SEVERITY : DIAG_SEVERITY = [V]CST_AOK
Local Char DIAG_MESSAGE(250)
Local Char ACTION(20)

Local Mask PATCH [DIA]

Raz [M:DIA]
[M:DIA]TYPEXP= 2 : #2= Patch stored on the server
#{SAM 117628 [M:DIA]ALNKSYNC= 1 : #1= No synchronisation of links
[M:DIA]ALNKSYNC= 2 : #2= Synchronisation of links
#SAM 117628}
[M:DIA]AVALDIF= 2 :#SAM 120763: default behavior = deferred validation
[M:DIA]AFLGSYNCH=2:#SAM 120763: default behavior = synchronization
[M:DIA]REM= 1 :#1=Do not erase comments
[M:DIA]NBDOS= 1
[M:DIA]SYRSTAMAINT = 1
[M:DIA]FULLMOD = 1
NODE(LEVEL) = JSON

While NODE(LEVEL) <> null
 PRONAME=tolower(NODE(LEVEL).PRO)
 PROVALUE = fmet NODE(LEVEL).AGETCNT

 If(left$(PROVALUE,1)) = '"'
  PROVALUE= seg$(fmet NODE(LEVEL).AGETCNT,2,len(fmet NODE(LEVEL).AGETCNT)-1)
 Endif


 #Call ADDDIAGNOSE(ACTX, PRONAME + ":" + PROVALUE, [V]CST_AINFO) From ASYRASYNC
 Case PRONAME
  When 'folder': FOLD = PROVALUE
  When 'directory': DIRECTORY = PROVALUE
  When "version": VERSION= PROVALUE
  When "name": NAME= PROVALUE
  When "integrate": INTEGRATE= PROVALUE
  When "statusMaintenance": [M:DIA]SYRSTAMAINT= val(PROVALUE)
  When "maintenance": [M:DIA]SYRMAINT= PROVALUE
  When "fullmode": FULLMODE= PROVALUE
  When "synchronize": SYNCHRONIZE = PROVALUE
 Endcase
 NODE(LEVEL) = NODE(LEVEL).NEX
Wend

If !len(FOLD)
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = func ASYRFNC.MES1(mess(59,149,1),"folder")
 Gosub HANDLER_RPATCH_EXIT
Endif

Local File ADOSSIER [ADS]
If func DOSSUB.FILL_ADS(FOLD)=0
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = func ASYRFNC.MES1(mess(71,149,1),FOLD)
 Gosub HANDLER_RPATCH_EXIT
Endif

If !len(DIRECTORY)
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = func ASYRFNC.MES1(mess(59,149,1),"directory")
 Gosub HANDLER_RPATCH_EXIT
Endif

If !len(VERSION)
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = func ASYRFNC.MES1(mess(59,149,1),"version")
 Gosub HANDLER_RPATCH_EXIT
Endif

If !len(NAME)
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = func ASYRFNC.MES1(mess(59,149,1),"name")
 Gosub HANDLER_RPATCH_EXIT
Endif

If len(SYNCHRONIZE) and SYNCHRONIZE = "false"
 [M:DIA]AFLGSYNCH=1:#X3-58948 : Valdico on last patch
Endif

[M:DIA]FICHIER=  filpath("","","",nomap)+"/"+DIRECTORY:#Directory
[M:DIA]DOSSIER(0)= FOLD

If tolower(INTEGRATE)= "true"
 If tolower(FULLMODE) = "true" :# FOR SCM
  [M:DIA]INTEG= 2 : #1= No integration of the PATCH
  [M:DIA]SYRFLGUPD= 1 : # 2-< OK pour updates.
  [M:DIA]SYRUPDATE= "" : # version 9.0.1
  [M:DIA]SYRIDENT= "" : # X3V7_P1 ou INDV7_P1
  [M:DIA]FULLMOD= 2 : # fullmod for scm

  #{SAM 120763 : No synchronization for SCM
  [M:DIA]AFLGSYNCH=1
  #SAM 120763}

 Else
  [M:DIA]INTEG= 2 : #1= No integration of the PATCH
  [M:DIA]SYRFLGUPD= 2 : # 2-< OK pour updates.
  [M:DIA]SYRUPDATE= VERSION : # version 9.0.1
  [M:DIA]SYRIDENT= NAME : # X3V7_P1 ou INDV7_P1
 Endif
 Call ADDDIAGNOSE(ACTX, [L]NAME+" for "+VERSION+" being integrated on "+[L]FOLD, [V]CST_AINFO) From ASYRASYNC
Else
 [M:DIA]INTEG= 1 : #1= No integration of the PATCH
 [M:DIA]SYRFLGUPD= 1 : # 2-< OK pour updates.
 [M:DIA]SYRUPDATE= "" : # version 9.0.1
 [M:DIA]SYRIDENT= "" : # X3V7_P1 ou INDV7_P1
 Call ADDDIAGNOSE(ACTX, [L]NAME+" for "+VERSION+" being tested on "+[L]FOLD, [V]CST_AINFO) From ASYRASYNC
Endif

#Call ADDDIAGNOSE(ACTX, "AFLGSYNCH:"+num$([M:DIA]AFLGSYNCH), [V]CST_AINFO) From ASYRASYNC
#Call ADDDIAGNOSE(ACTX, "FULLMOD:"+num$([M:DIA]FULLMOD), [V]CST_AINFO) From ASYRASYNC

Local Char    TEXTE(250)
Local Integer SAVSERV: SAVSERV = GSERVEUR
GSERVEUR=1
Call OUVRE_TRACE("Patch Integration ("+[L]NAME-"for"-VERSION-"on"-[L]FOLD+")") From LECFIC
ACTION="EXEC"

##If fmet ACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
## DIAG_SEVERITY = [V]CST_AERROR
## DIAG_MESSAGE = mess(327,139,1) #Expired licence
## Gosub HANDLER_RPATCH_EXIT
##Endif

Onerrgo HANDLER_RPATCH_ABORT
Gosub ACTION From PATCH
Onerrgo

GSERVEUR =SAVSERV
Call FERME_TRACE From LECFIC

Local File APATCHLOG [APL]
Read [F:APL]APT0=[L]FOLD;[M:DIA]SYRUPDATE;[M:DIA]SYRIDENT
If !fstat
 If !find([F:APL]FLGPAT,3,0)
  DIAG_SEVERITY = [V]CST_AERROR
  DIAG_MESSAGE=  "Integration of "+SYRIDENT+ " for "+SYRUPDATE+" failed on "+FOLD
 Endif
Endif
Close Local File [APL]

$HANDLER_RPATCH_EXIT
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE          Using C_ASYRJSO  : NODE=null
Local Instance  DIAGS          Using C_ASYRJSO  : NODE=null
Local Instance  DIAG          Using C_ASYRJSO  : NODE=null
Local Instance  LINKS          Using C_ASYRJSO  : NODE=null
Local Instance  LNKTRA          Using C_ASYRJSO  : NODE=null
Local Char FICTRA(250) : FICTRA = filpath("TRA",GTRACE,"tra",0)

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'trace',escJson([L]FICTRA))  From ASYRJSO
Call JSON_ADDARRAY(NODES,ROOT,"$diagnoses",DIAGS) From ASYRJSO
Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO

If DIAG_SEVERITY = [V]CST_AERROR
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
 Call JSON_ADDSTRING(NODES,DIAG,'$message',DIAG_MESSAGE)  From ASYRJSO
 Call ADDDIAGNOSE(ACTX, [L]DIAG_MESSAGE, [V]CST_AERROR) From ASYRASYNC
Else
 Call JSON_ADDSTRING(NODES,DIAG,'$severity',"success")  From ASYRJSO
 If tolower(INTEGRATE)= "true"
  Call JSON_ADDSTRING(NODES,DIAG,'$message',"The integration succeeded on "+[L]FOLD)  From ASYRJSO
 Else
  Call JSON_ADDSTRING(NODES,DIAG,'$message',"The test succeeded on "+[L]FOLD)  From ASYRJSO
 Endif
Endif
Call JSON_ADDOBJECT(NODES,DIAG,"$links",LINKS) From ASYRJSO
Call JSON_ADDOBJECT(NODES,LINKS,"$trace",LNKTRA) From ASYRJSO
Call JSON_ADDSTRING(NODES,LNKTRA,'$title',"Trace")  From ASYRJSO
Call JSON_ADDSTRING(NODES,LNKTRA,'$url',baseUrl+"/CDOC(%27R_ATRACE~%C2%A8~TRACEFILE~%C2%A8~TRA~%C2%A8~"+GTRACE) From ASYRJSO

Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO
Return


$HANDLER_RPATCH_ABORT
 DIAG_SEVERITY = [V]CST_AERROR
 DIAG_MESSAGE = errmes$(errn)-errm
 Gosub HANDLER_RPATCH_EXIT
 Resume


###################################
#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO


Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE          Using C_ASYRJSO  : NODE=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

Local Integer ERROR : ERROR=[V]CST_AOK

Local Char FOLD(50),DIRECTORY(250),VERSION(20),NAME(15),INTEGRATE(20),SYRSTAMAINT(2),SYRMAINT(30),FULLMOD(20)
FOLD =  func ASYRMAIN.PARVAL(ARCV,"folder")
If !len(FOLD)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"folder"))
 Gosub HANDLER_POST_EXIT
Endif

Local File ADOSSIER [ADS]
#107271
#Read [ADS]DOSSIER = FOLD
#If fstat
If func DOSSUB.FILL_ADS(FOLD)=0
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(71,149,1),FOLD))
 Gosub HANDLER_POST_EXIT
Endif

DIRECTORY=  func ASYRMAIN.PARVAL(ARCV,"directory")
If !len(DIRECTORY)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"directory"))
 Gosub HANDLER_POST_EXIT
Endif

VERSION=  func ASYRMAIN.PARVAL(ARCV,"version")
If !len(VERSION)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"version"))
 Gosub HANDLER_POST_EXIT
Endif

NAME=  func ASYRMAIN.PARVAL(ARCV,"name")
If !len(NAME)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"name"))
 Gosub HANDLER_POST_EXIT
Endif

INTEGRATE=  func ASYRMAIN.PARVAL(ARCV,"integrate")
If !len(INTEGRATE) : INTEGRATE="false" :Endif

SYRSTAMAINT=  func ASYRMAIN.PARVAL(ARCV,"statusMaintenance")
If !len(SYRSTAMAINT) : SYRSTAMAINT= "1" : Endif

SYRMAINT=  func ASYRMAIN.PARVAL(ARCV,"maintenance")

FULLMOD=  func ASYRMAIN.PARVAL(ARCV,"fullmode")
If !len(FULLMOD) : FULLMOD="false" :Endif


# create request in folder X3
Local Integer NBPAR , REQUETE ,ILAN
Local Char TBPAR(30)(1..20) , TBVAL(250)(1..20) , TIM(8) , MESSAGE(250),LANGUES(250),SEP(1)
Local Date DAT
#DAT = date$
TIM = left$(time$,5)

NBPAR = 0

If tolower(INTEGRATE) = "true"
 If tolower(FULLMOD) = "false"
  NBPAR += 1 : TBPAR(NBPAR) = "INTEG"     : TBVAL(NBPAR) = "2" : #1 = No integration of the PATCH
  NBPAR += 1 : TBPAR(NBPAR) = "SYRFLGUPD" : TBVAL(NBPAR) = "2" : # 2-< OK pour updates.
  NBPAR += 1 : TBPAR(NBPAR) = "SYRUPDATE" : TBVAL(NBPAR) = VERSION : # version 9.0.1
  NBPAR += 1 : TBPAR(NBPAR) = "SYRIDENT" : TBVAL(NBPAR) = NAME : # X3V7_P1 ou INDV7_P1
  NBPAR += 1 : TBPAR(NBPAR) = "FULLMOD" : TBVAL(NBPAR) =  "1" : # fullmod for scm
 Else
  NBPAR += 1 : TBPAR(NBPAR) = "INTEG"     : TBVAL(NBPAR) = "2" : #1 = No integration of the PATCH
  NBPAR += 1 : TBPAR(NBPAR) = "SYRFLGUPD" : TBVAL(NBPAR) = "1" : # 2-< OK pour updates.
  NBPAR += 1 : TBPAR(NBPAR) = "SYRUPDATE" : TBVAL(NBPAR) = "" : # version 9.0.1
  NBPAR += 1 : TBPAR(NBPAR) = "SYRIDENT" : TBVAL(NBPAR) = "" : # X3V7_P1 ou INDV7_P1
  NBPAR += 1 : TBPAR(NBPAR) = "FULLMOD" : TBVAL(NBPAR) =  "2" : # fullmod for scm
 Endif
Else
 NBPAR += 1 : TBPAR(NBPAR) = "INTEG"     : TBVAL(NBPAR) = "1" : #1 = No integration of the PATCH
 NBPAR += 1 : TBPAR(NBPAR) = "SYRFLGUPD" : TBVAL(NBPAR) = "1" : # 2-< OK pour updates.
 NBPAR += 1 : TBPAR(NBPAR) = "SYRUPDATE" : TBVAL(NBPAR) = "" : # version 9.0.1
 NBPAR += 1 : TBPAR(NBPAR) = "SYRIDENT" : TBVAL(NBPAR) = "" : # X3V7_P1 ou INDV7_P1
Endif

NBPAR += 1 : TBPAR(NBPAR) = "TYPEXP"     : TBVAL(NBPAR) = "2" : #2 = Patch stored on the server
NBPAR += 1 : TBPAR(NBPAR) = "FICHIER"     : TBVAL(NBPAR) =  filpath("","","",nomap)+"/"+DIRECTORY:#Directory
NBPAR += 1 : TBPAR(NBPAR) = "ALNKSYNC"     : TBVAL(NBPAR) = "2" : #SAM 113870 2 = synchronisation of links
NBPAR += 1 : TBPAR(NBPAR) = "AVALDIF"     : TBVAL(NBPAR) = "2" :#2=Delayed validation
NBPAR += 1 : TBPAR(NBPAR) = "AFLGSYNCH"     : TBVAL(NBPAR) = "2" :#SAM 120763 (AFLGSYNCH=2) => SYNCHDICO

NBPAR += 1 : TBPAR(NBPAR) = "REM"     : TBVAL(NBPAR) = "1" :#1=Do not erase comments
NBPAR += 1 : TBPAR(NBPAR) = "NBDOS"      : TBVAL(NBPAR) = "1"
NBPAR += 1 : TBPAR(NBPAR) = "DOSSIER(0)" : TBVAL(NBPAR) = FOLD
NBPAR += 1 : TBPAR(NBPAR) = "SYRMAINT" : TBVAL(NBPAR) = SYRMAINT
NBPAR += 1 : TBPAR(NBPAR) = "SYRSTAMAINT" : TBVAL(NBPAR) = SYRSTAMAINT


For ILAN=0 To [F:ADS]NBRLAN-1
 If len([F:ADS]LAN(ILAN))
  LANGUES  += SEP + [F:ADS]LAN(ILAN)
  SEP =';'
 Endif
Next ILAN
NBPAR += 1 : TBPAR(NBPAR) = "LANGUES(0)" : TBVAL(NBPAR) = LANGUES
ERROR  = func ASYRMNGTREQ.CRERQT(ACTX,nomap,ACTX.USER,"PATCH",date$,TIM,TBPAR,TBVAL,NBPAR,REQUETE,MESSAGE)

If ERROR = [V]CST_AOK
 Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
 Call JSON_ADDSTRING(NODES,ROOT,"requestId",num$(REQUETE))  From ASYRJSO
 Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO
Endif

$HANDLER_POST_EXIT
ASND.URL      = PSYR.PREFIX+'/patch'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".patch"
End ERROR



Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Char FOLD(50),DIRECTORY(GDIMFIC)
Local Char FICTRA(GDIMFIC)
Local Integer EXIST,STAT
Local Char P_REQUESTID(12)
Local Integer REQUESTID

Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE          Using C_ASYRJSO  : NODE=null
Local Instance  DIAGS          Using C_ASYRJSO  : NODE=null
Local Instance  LINKS          Using C_ASYRJSO  : NODE=null
Local Instance  LNKTRA          Using C_ASYRJSO  : NODE=null
Local Instance  DIAG          Using C_ASYRJSO  : NODE=null
Local Instance  INFO          Using C_ASYRJSO  : NODE=null
Local Instance  ROOT          Using C_ASYRJSO  : ROOT=null
Local Instance  JNULL          Using C_ASYRJSO  : JNULL=null

# chemin de la trace TRA/namefile
#Local File ABATPAR [ABP]
Local File ABATRQTL [ABL]
Local File APATCHLOG [APL]
Local Char MESSAGE(250)

FOLD =  func ASYRMAIN.PARVAL(ARCV,"folder")
If !len(FOLD)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"folder"))
 Goto HANDLER_GET_EXIT
Endif

P_REQUESTID  =  func ASYRMAIN.PARVAL(ARCV,"requestId")
If !len(P_REQUESTID)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func ASYRFNC.MES1(mess(59,149,1),"requestId"))
 Goto HANDLER_GET_EXIT
Endif
REQUESTID= val(P_REQUESTID)
#TEST Call TRACK(ACTX,REQUESTID)

#Read [ABP]SPOOL First
FICTRA = func SERVSYS.GET_FILE_RQT(format$("N0:8#",[L]REQUESTID),"tra") : #109897   # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
If FICTRA=""
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_OK,mess(86,133,1)-func SERVSYS.GET_BATCH_TRA_DIRECTORY("",""))
 Goto HANDLER_GET_EXIT
Endif

Call JSON_ADDOBJECT(NODES,JNULL,"",ROOT) From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'trace',escJson([L]FICTRA))  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'folder',[L]FOLD)  From ASYRJSO
Call JSON_ADDSTRING(NODES,ROOT,'requestId',num$([L]REQUESTID))  From ASYRJSO

Local File ABATRQT [ABR]
Filter [ABR] Where NUMREQ=[L]REQUESTID
Read [ABR] Last
If !fstat
  Filter[ABL] Where NUMREQ=[L]REQUESTID & PARAM="INTEG"
  Read [ABL] Last
  If !fstat
   Call JSON_ADDARRAY(NODES,ROOT,"$diagnoses",DIAGS) From ASYRJSO
   Call JSON_ADDOBJECT(NODES,DIAGS,"",DIAG) From ASYRJSO
   If find([ABR]FLAG,1,2) :#in progress

    Filter [APL] Where AFOLDER=[L]FOLD
    Read [APL] Last
    MESSAGE = "Patch"
    If !fstat
     MESSAGE = [F:APL]MAINTENANCE
    Endif

    If [ABL]VALEUR = "2"
     Call JSON_ADDSTRING(NODES,DIAG,"$message",[L]MESSAGE+ " being integrated on "+[L]FOLD)  From ASYRJSO
    Else
     Call JSON_ADDSTRING(NODES,DIAG,"$message",+"Patch being tested on "+[L]FOLD)  From ASYRJSO
    Endif
    Call JSON_ADDSTRING(NODES,DIAG,'$severity',"info")  From ASYRJSO
   Elsif [ABR]FLAG = 3 :# Success
    If [ABL]VALEUR = "2"
     Call JSON_ADDSTRING(NODES,DIAG,"$message","The integration succeeded on "+[L]FOLD)  From ASYRJSO
    Else
     Call JSON_ADDSTRING(NODES,DIAG,"$message","The test succeeded on "+[L]FOLD)  From ASYRJSO
    Endif
    Call JSON_ADDSTRING(NODES,DIAG,'$severity',"success")  From ASYRJSO
    Call JSON_ADDOBJECT(NODES,DIAG,"$links",LINKS) From ASYRJSO
    Call JSON_ADDOBJECT(NODES,LINKS,"$trace",LNKTRA) From ASYRJSO
    Call JSON_ADDSTRING(NODES,LNKTRA,'$title',"Trace")  From ASYRJSO
    Call JSON_ADDSTRING(NODES,LNKTRA,'$url',baseUrl+"/CDOC(%27R_ATRACE~%C2%A8~TRACEFILE~%C2%A8~TRA~%C2%A8~"+format$("N0:8#",[L]REQUESTID)+"%27)") From ASYRJSO
   Else :#Error and other status
    If [ABL]VALEUR = "2"
     Call JSON_ADDSTRING(NODES,DIAG,"$message","The integration failed on "+[L]FOLD)  From ASYRJSO
    Else
     Call JSON_ADDSTRING(NODES,DIAG,"$message","The test failed on "+[L]FOLD)  From ASYRJSO
    Endif
    Call JSON_ADDSTRING(NODES,DIAG,'$severity',"error")  From ASYRJSO
    Call JSON_ADDOBJECT(NODES,DIAG,"$links",LINKS) From ASYRJSO
    Call JSON_ADDOBJECT(NODES,LINKS,"$trace",LNKTRA) From ASYRJSO
    Call JSON_ADDSTRING(NODES,LNKTRA,'$title',"Trace")  From ASYRJSO
    Call JSON_ADDSTRING(NODES,LNKTRA,'$url',baseUrl+"/CDOC(%27R_ATRACE~%C2%A8~TRACEFILE~%C2%A8~TRA~%C2%A8~"+format$("N0:8#",[L]REQUESTID)+"%27)") From ASYRJSO
  Endif
 Endif
Endif

$HANDLER_GET_EXIT
Call GENERATE_JSON(NODES,ASND.DATA) From ASYRJSO
LogicClose  File [ABR]
LogicClose File [ABL]
LogicClose File [APL]

ASND.URL      = PSYR.PREFIX+'/patch'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".patch"
End ERROR

