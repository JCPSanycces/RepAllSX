#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return

$OPERATIONS
Case [L]AOPERATION
  When "INTEGRATION"        : Gosub INTEGRATION
  When "UPDATE_ALL"         : Gosub UPDATE_ALL
  When "CLEAR_STAGE"        : Gosub CLEAR_STAGE
Endcase
Return

$CLEAR_STAGE
#Parameter - INTUID
[L]ARET_VALUE = func DELETE_STG_TABLE_INTUID(INTUID)
If [L]ARET_VALUE = [V]CST_AOK
  [L]ARET_VALUE = fmet this.ASETERROR("","All staging tables cleared"-num$(INTUID),[V]CST_AINFO)
Else
  [L]ARET_VALUE = fmet this.ASETERROR("","Error encountered"-num$(INTUID),[V]CST_AERROR)
Endif

Return

#**
#* Label for deleting the staging table(s)
#* @param Local char (GLONATB) VERRTABLE, returns the first table that could not be cleared
#* @return CST_AERROR or CST_AOK
#*!
Funprog DELETE_STG_TABLE_INTUID(VINTUID)
Value Integer VINTUID
Local Integer TRANSACTION_PENDING,DEL_OK

DEL_OK = [V]CST_AOK

Local File PIHRMFAIRERR [PHFE1]
Local File EMPLOIDSTG   [ESTG1]
Local File EMPLOCTRSTG  [HRCSG1]
Local File EMPUKISTG    [IDUSG1]
Local File EMPCTRUKISTG [CTRUSG1]
Local File EMPLORIBSTG  [RIBSG1]

TRANSACTION_PENDING=adxlog
If TRANSACTION_PENDING=0
  Trbegin [PHFE1],[ESTG1],[HRCSG1],[IDUSG1],[CTRUSG1],[RIBSG1]
Endif

#Detele all records from the table

  Delete [PHFE1] Where [F:PHFE1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPLOIDSTG
  Delete [ESTG1] Where [F:ESTG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPLOCTRSTG
  Delete [HRCSG1] Where [F:HRCSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPUKISTG
  Delete [IDUSG1] Where [F:IDUSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPCTRUKISTG
  Delete [CTRUSG1] Where [F:CTRUSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPLORIBSTG
  Delete [RIBSG1] Where [F:RIBSG1]INTUID = VINTUID
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

If TRANSACTION_PENDING=0
  If DEL_OK <> [V]CST_AOK
    Rollback
    End [V]CST_AERROR
  Else
    Commit
  Endif
Endif

LogicClose File     [PHFE1]
LogicClose File     [ESTG1]
LogicClose File     [HRCSG1]
LogicClose File     [IDUSG1]
LogicClose File     [CTRUSG1]
LogicClose File     [RIBSG1]

End [V]CST_AOK


$INTEGRATION

#INTUID - Key from Representation
Local Integer ALL_PROCESSES(1..len(mess(0,11817,1)))
Local Integer I,PAYINFO,READ_PIHRMF,FUNC_RETVAL, PROC
Local Char BID_DATA(250)
Local Char BID_SERVID(250)

#Set the return value of the method
[L]ARET_VALUE = [V]CST_AOK

#Clear the error class
If func DELETE_ERR_TABLE() = [V]CST_AERROR
  [L]ARET_VALUE = fmet this.ASETERROR("",mess(00010,11820,1)-"PIHRMFAIRERR",[V]CST_AERROR)
  Return
Endif

Gosub DECLARE_INSTANCE_VARIABLES  From PIHRMFAIR_FUNCTIONS
Gosub DECLARE_TOKENVAL

#Get all the details/token value and credentials
#Declare the class instance PIHRMFAIR containing all the integration *setup details
Local Instance  I_PIHRMFAIR  Using C_PIHRMFAIR
I_PIHRMFAIR = NewInstance C_PIHRMFAIR AllocGroup null
[L]READ_PIHRMF = fmet I_PIHRMFAIR.AREAD(INTUID)
If [L]READ_PIHRMF >= [V]CST_AERROR
  FreeGroup I_PIHRMFAIR
  [L]ARET_VALUE = fmet this.ASETERROR("",mess(00001,11820,1)+ " : "+num$(INTUID),[V]CST_AERROR)
  Return #No further execution allowed
Endif

#Get the token value and validate
FUNC_RETVAL = func TOKEN_REQUEST(I_PIHRMFAIR,TOKENVAL,HTTP_FUNC,W_MESS_FUNC)
If FUNC_RETVAL = [V]CST_AOK
  #Store the token back into the DB
  FUNC_RETVAL = func STORE_TKNVAL(TOKENVAL,I_PIHRMFAIR.COD)
  If FUNC_RETVAL = [V]CST_AOK
    ASTATUS = fmet this.ASETERROR("",mess(00002,11820,1),[V]CST_AINFO)
  Else
    ASTATUS = fmet this.ASETERROR("",mess(00003,11820,1),[V]CST_AINFO)
  Endif
Else
  FreeGroup I_PIHRMFAIR
  [L]ARET_VALUE = fmet this.ASETERROR("",mess(00004,11820,1)-num$(HTTP_FUNC)-":"-W_MESS_FUNC,[V]CST_AERROR)
  Return #No further execution allowed
Endif

#Start the integration - Check processes to excecute
#Each Process will handle it's own error management
If I_PIHRMFAIR.SRV <> null
  For PROC = 1 To maxtab(I_PIHRMFAIR.SRV)
    If I_PIHRMFAIR.SRV(PROC).SRVINC = [V]CST_AYES
      Gosub PROCESS_INTEGRATION
    Endif
  Next
Endif
Return


$PROCESS_INTEGRATION
Local Integer PROCESSNUM
Local Char SERVLEG(GLONADI)
Local Char BIDSERV(250)
Local Char INTCOD(GLONPICF)
PROCESSNUM  = I_PIHRMFAIR.SRV(PROC).SRVTYP
INTCOD      = I_PIHRMFAIR.COD

Case PROCESSNUM #Local menu 11817
  When 1    :  Gosub EMPLOID_INSERT
Endcase
Return


$EMPLOID_INSERT
Local Char VCLASS_ERROR(255)

#The integration per process will be done per legislation
Local File PIHRMEMPSET [PIES2]

#Instantiate employee staging table
#TODO Extension notes: Instantiate staging class for the process
Gosub INIT_EMPSTG_METH

For [PIES2]PIES0 Where TYP = PROCESSNUM and COD = INTCOD
  SERVLEG = [F:PIES2]LEG
  BIDSERV = [F:PIES2]SRVID

  #Invoke the integration method on the class
  #TODO Extension notes: Add a staging class for the process. Add method on the class, example:I_EMPLOIDSTG_METH.EMPLOID_AINSERT
  [L]ARET_VALUE = fmet I_EMPLOIDSTG_METH.EMPLOID_AINSERT(I_PIHRMFAIR.PAYBATCFG,I_PIHRMFAIR,I_PIHRMFAIR.INTUID,TOKENVAL,BIDSERV,PROCESSNUM,SERVLEG)
  If [L]ARET_VALUE = [V]CST_AERROR
    VCLASS_ERROR = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE_INST(I_EMPLOIDSTG_METH) #TODO Extension notes: Add own class in parameter
    ASTATUS = fmet this.ASETERROR("",VCLASS_ERROR,[V]CST_AERROR)
  Elsif [L]ARET_VALUE = [V]CST_AWARNING
    ASTATUS = fmet this.ASETERROR("","("+SERVLEG+"-"+mess(PROCESSNUM,11817,1)+")"-mess(00005,11820,1) -":"- mess(00006,11820,1),[V]CST_AWARNING)
  Elsif [L]ARET_VALUE = [V]CST_AOK
     ASTATUS = fmet this.ASETERROR("","("+SERVLEG+"-"+mess(PROCESSNUM,11817,1)+")"-mess(00005,11820,1) -":"- mess(00007,11820,1),[V]CST_AINFO)
  Endif
Next
#TODO Extension notes: Free staging class for the process
Gosub FREE_EMPSTG_METH
LogicClose File [PIES2]
Return

$INIT_EMPSTG_METH
Local Integer EMPSTGINIT_METHOD
Local Instance  I_EMPLOIDSTG_METH  Using C_EMPLOIDSTG
I_EMPLOIDSTG_METH  = NewInstance C_EMPLOIDSTG AllocGroup null
EMPSTGINIT_METHOD  = fmet I_EMPLOIDSTG_METH.AINIT()
Return

$FREE_EMPSTG_METH
FreeGroup I_EMPLOIDSTG_METH
Return

Funprog TOKEN_REQUEST(I_PCLASS,V_TOKENVAL,HTTP_RET,MSG_RET_FUNC)
Variable Instance I_PCLASS Using C_PIHRMFAIR
Variable Char V_TOKENVAL
Variable Char MSG_RET_FUNC
Variable Integer HTTP_RET

Local Integer RETVAL : RETVAL = [V]CST_AOK

Gosub DECLARE_TOKENVAL
Gosub DECLARE_CLASSES_WSERV From PIHRMFAIR_FUNCTIONS

#Get the stored value before requesting a new one
TOKENVAL = func GET_STORED_TOKEN(I_PCLASS.COD)

#Test the token
HTTP_STATUS = func TEST_TKNVALID(I_PCLASS.TKNVALURL,TOKENVAL,RESBODY_FUNC,RESHEAD_FUNC)
#Test the HTTP status returned from the function
If (int(HTTP_STATUS/100)<>2)
  #Do a new request
  HTTP_STATUS = func GET_TOKEN(I_PCLASS.COD,I_PCLASS.TKNSUBURL,RESBODY_FUNC,RESHEAD_FUNC)
  #Test the HTTP status returned from the function
  If (int(HTTP_STATUS/100)<>2)
    End [V]CST_AERROR
  Else
    #Process Json file to get token value
    #Parse the response body (Json file)
    RETVAL = func PARSE_JSON_TOKEN(I_PCLASS,RESBODY_FUNC,TOKENVAL)
    If RETVAL = [V]CST_AOK
      #Validate requested token
      HTTP_STATUS = func TEST_TKNVALID(I_PCLASS.TKNVALURL,TOKENVAL,RESBODY_FUNC,RESHEAD_FUNC)
      #Test the HTTP status returned from the function
      If (int(HTTP_STATUS/100)<>2)
        #We know it is an error, we will let the function always return error
        HTTP_RET = HTTP_STATUS
        RETVAL = func PIHRMFAIR_FUNCTIONS.HANDLE_HTTP_ERROR(RESHEAD_FUNC,RESBODY_FUNC,MSG_RET_FUNC,HTTP_RET)
      Endif
    Endif
  Endif
Endif

#Set return token value
V_TOKENVAL = TOKENVAL

End RETVAL

Funprog GET_TOKEN(V_PCLASS_COD,V_PCLASS_TKNSUBURL,RETBODY_RET,RETHEAD_RET)
Variable Clbfile RETBODY_RET, RETHEAD_RET
Value Char V_PCLASS_COD,V_PCLASS_TKNSUBURL

#Declare variables to use in web service call
Gosub DECLARE_CLASSES_WSERV From PIHRMFAIR_FUNCTIONS
#Declare all variables to use for the web service call and define all values
Gosub SET_GET_TOKEN

#Call web service
HTTP_STATUS=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, DATA_SENT, FUTURE, "", RESHEAD_FUNC, RESBODY_FUNC)

#Set the return values of the CLOB files to the variable CLOB files passed in the function
Gosub SET_RETURN_VALUE From PIHRMFAIR_FUNCTIONS
End HTTP_STATUS

$DECLARE_TOKENVAL
Local Char TOKENVAL(250)
Return

$SET_GET_TOKEN

Local Char TOKENBODYCOD(250)(1..5)
Local Char TOKENBODYVAL(250)(1..5)
Local Char TOKENBODY(250)

#TODO: Handle the data - encryption and setup
WEBSERNAME = "FAIRSALETKN"
HTTPMETHOD = "POST"
SUBURL =  V_PCLASS_TKNSUBURL #V_PCLASS_TKNSUBURL from Funprog GET_TOKEN

HCOD(1) = "accept"
HVAL(1) = '"application/json"'
HCOD(2)=  "Content-Type"
HVAL(2)= '"application/x-www-form-urlencoded"'

#Build up the token body
##** The Encoding must always be checked against something like postman to make sure the encoding rules apply
##* for example the @ sign becomes %40 etc
#V_PCLASS_COD from Funprog GET_TOKEN

#Get the TOKENVODYVAL values
Local File PIHRMFAIRCFG   [PICF3]
Read [PICF3]PICF0 = V_PCLASS_COD
If fstat <> [V]CST_AOK
 Return
Endif

TOKENBODYCOD(1) = "grant_type"
TOKENBODYVAL(1) = "password"

TOKENBODYCOD(2) = "client_id"
TOKENBODY =[F:PICF3]BPCID
TOKENBODYVAL(2) = func PIHRMFAIR_FUNCTIONS.ENCODE_URL(TOKENBODY)

TOKENBODYCOD(3) = "client_secret"
TOKENBODY =[F:PICF3]BPCSCT
TOKENBODYVAL(3) = func PIHRMFAIR_FUNCTIONS.ENCODE_URL(TOKENBODY)

TOKENBODYCOD(4) = "username"
TOKENBODY =[F:PICF3]USR
TOKENBODYVAL(4) = func PIHRMFAIR_FUNCTIONS.ENCODE_URL(TOKENBODY)

#Concatenate Password and Token - PVAL
TOKENBODYCOD(5) = "password"
TOKENBODY =[F:PICF3]PWD
TOKENBODYVAL(5) = func PIHRMFAIR_FUNCTIONS.ENCODE_URL(TOKENBODY)

DATA_SENT='"' + TOKENBODYCOD(1)+"="+TOKENBODYVAL(1)+"&"+TOKENBODYCOD(2)+"="+TOKENBODYVAL(2)+"&"+TOKENBODYCOD(3)+"="+TOKENBODYVAL(3)+"&"+TOKENBODYCOD(4)+"="+TOKENBODYVAL(4)+"&"+TOKENBODYCOD(5)+"="+
& TOKENBODYVAL(5)+ '"'

FUTURE=0 : # We wait for the answer
LogicClose File [PICF3]
Return




#**
#* Label for parsing the json (response body) and getting the token needed
#* @param I_PCLASS Instance , the current class instance (this)
#* @param JSONDBODY Clbfile, response body that will be parsed
#* @param TOKENVAL Char(255), token value from parsed json file "access_token"
#* @return RETVAL Integer - CST_AERROR or CST_AOK
#*!
Funprog PARSE_JSON_TOKEN(I_PCLASS,JSONDBODY,VTOKENVAL)
Value Clbfile JSONDBODY
Variable Char VTOKENVAL
Variable Instance I_PCLASS Using C_PIHRMFAIR
Local Integer RETVAL : RETVAL = [V]CST_AERROR

#Local variables
Local Integer   I_NODE

#Declare NODES
Gosub INIT_NODE From PIHRMFAIR_FUNCTIONS

#Insert the Json file into the ASYRJSO (Supervisor) class
If func ASYRJSONPARSE.PARSEJSON(I_PCLASS.ACTX,JSONDBODY,NODES,NODE) = [V]CST_AOK
  RETVAL = [V]CST_AOK
  For [L]I_NODE = 1 To maxtab(NODES)
    If (NODES([L]I_NODE) <> null)
      #Check for "access_token"
      If NODES([L]I_NODE).PRO = "access_token"
        #Set the token value to variable char TOKENVAL
        VTOKENVAL = mid$(NODES([L]I_NODE).CLB.CLB,NODES([L]I_NODE).START+1,NODES([L]I_NODE).LENGTH-2)
      Endif
    Endif
  Next
Endif

#Gosub FREE_NODE
End RETVAL


#**
#* Label for getting the stored token value - last successful token stored
#* @param COD Char(10), Key for integration setup in table PIHRMFAIRCFG
#* @return FTOKENVAL Local char - Stored token value
#*!
Funprog GET_STORED_TOKEN(VCOD)
Value Char VCOD
Local File PIHRMFAIRSET [PIFS1]
Local Char FTOKENVAL(250)
Read [PIFS1]PIFS0 = VCOD
If fstat = [V]CST_AOK
  FTOKENVAL = [F:PIFS1]TKNVAL
Endif
End FTOKENVAL

#**
#* Label for getting the token needed to call Fairsail(Salesforce) to obtain new URL
#* @param TOKENVAL Char(255), token value from parsed json file "access_token"
#* @param RETBODY_RET Local Clbfile, response body that will be populated by the web service call and can be used by the program calling the function
#* @param RETHEAD_RET Local Clbfile, response header that will be populated by the web service call and can be used by the program calling the function
#* @return HTTP_STATUS Local Integer - see https://en.wikipedia.org/wiki/List_of_HTTP_status_codes for possible return codes
#*!
Funprog TEST_TKNVALID(VTKNVALURL,VTOKENVAL,RETBODY_RET,RETHEAD_RET)
Variable Clbfile RETBODY_RET,RETHEAD_RET
Value Char VTOKENVAL,VTKNVALURL

#Declare variables to use in wserv call
Gosub DECLARE_CLASSES_WSERV From PIHRMFAIR_FUNCTIONS

Gosub SET_TKN_VALID
HTTP_STATUS = func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, DATA_SENT, FUTURE, "", RESHEAD_FUNC, RESBODY_FUNC)
#Set the return values of the CLOB files to the variable CLOB files passed in the function
Gosub SET_RETURN_VALUE From PIHRMFAIR_FUNCTIONS
End HTTP_STATUS


$SET_TKN_VALID
AUTHOR = "Bearer"

WEBSERNAME = "FAIRSAILTKNVAL"
HTTPMETHOD = "GET"
SUBURL =  VTKNVALURL #From Funprog TEST_TKNVALID

HCOD(1) = "Content-Type"
HVAL(1) = '"application/json"'

###Bearer fixed + get from URL"
HCOD(2) = "Authorization"
HVAL(2) ='"'+AUTHOR + " " +VTOKENVAL+'"'

DATA_SENT ="{}"

FUTURE=0 : # We wait for the answer
Return

Funprog STORE_TKNVAL(VTOKENVAL,VCOD)
Value Char VTOKENVAL,VCOD
Local File PIHRMFAIRSET   [PIFS2]
Update [PIFS2] Where COD = VCOD With TKNVAL = VTOKENVAL
End fstat

$UPDATE_ALL
#INTUID - Key from Representation
Local Integer ALL_PROCESSES(1..len(mess(0,11817,1)))
Local Integer I,PAYINFO,READ_PIHRMF,FUNC_RETVAL, PROC,PROCESSNUM
Local Char BID_DATA(250)
Local Char BID_SERVID(250)
Local Integer PICLASS_INIT, PICLASS_READ
Local Integer PINTUID
PINTUID = INTUID

#Set the return value of the method
[L]ARET_VALUE = [V]CST_AOK

#Read the integration class
Local Instance  I_PIHRMFAIR  Using C_PIHRMFAIR
If (I_PIHRMFAIR <> null) : FreeGroup I_PIHRMFAIR : Endif
I_PIHRMFAIR  = NewInstance C_PIHRMFAIR AllocGroup null

PICLASS_READ = fmet I_PIHRMFAIR.AREAD(PINTUID)
If PICLASS_READ <> [V]CST_AOK
  [L]ARET_VALUE = fmet this.ASETERROR("","PIHRMFAIR"-"Can not be read on key"-num$(PINTUID),[V]CST_AERROR)
  Return
Endif

If I_PIHRMFAIR.SRV <> null
  For PROC = 1 To maxtab(I_PIHRMFAIR.SRV)
    If I_PIHRMFAIR.SRV(PROC).SRVINC = [V]CST_AYES
      PROCESSNUM = I_PIHRMFAIR.SRV(PROC).SRVTYP
      Case PROCESSNUM #Local menu 11817
        When 1    :  Gosub EMPLOYEE_UPDATE
      Endcase
    Endif
  Next
Endif
Return

$EMPLOYEE_UPDATE
Local Char UPD_CLASSES(GLONACLA)(1..)
Local Char CLASSES(GLONACLA)
Local Integer CLASS_NUM, I

#Populate all classes used for employee integration
Gosub POPUL_EMP_CLASSES

#Loop through the array and perform the updates
For I = 1 To maxtab(UPD_CLASSES)
  [L]ARET_VALUE = [V]CST_AOK
  CLASS_NUM+=1
  CLASSES = UPD_CLASSES(CLASS_NUM)
  Gosub CLASS_UPDATE From =CLASSES+"_CSTD_MPU"
Next

Return

$POPUL_EMP_CLASSES
UPD_CLASSES(1) = "EMPLOIDSTG"
UPD_CLASSES(2) = "EMPLORIBSTG"
UPD_CLASSES(3) = "EMPUKISTG"
UPD_CLASSES(4) = "EMPLOCTRSTG"
UPD_CLASSES(5) = "EMPCTRUKISTG"
Return



#**
#* Label for deleting the error handling table(s)
#* @return CST_AERROR or CST_AOK
#*!
Funprog DELETE_ERR_TABLE()
Local File PIHRMFAIRERR [PHFE]

#Detele all records from the table
Lock [PHFE]
If fstat = [V]CST_AOK
  Delete [PHFE] Where INTUID >= ""
  If fstat <> [V]CST_AOK
    End [V]CST_AERROR
  Endif
  Unlock [PHFE]
Else
  End [V]CST_AERROR
Endif
End [V]CST_AOK

