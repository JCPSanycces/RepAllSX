#<AdxTL>@(#)3.0.0.0 $Revision$
## GH 03/2015
# Issue X3-25054 - 2017-07-06 by BAKHA : new action to allow entry of field if user has permissions and
#                                        released product is versioned
#
# Issue X3-48941 - 2017-07-31 by BAKHA : check if audit exists for a work order
#                                        Check new GMFGREV parameter for audit
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking versioning fields, make sure Versioning is in use
# Issue X3-55431 - 2017-09-14 by BAKHA : remove information message for critical field changes

$ACTION
Case ACTION
 When "SEL_TABLE"        : Case TABLE
                             When "SELECCVAL" : Gosub SELECCVAL2
                             When "SELECCLOT" : Gosub SELECCLOT
                           Endcase
 When "VERF_TABLE"       : Case TABLE
                             When "SELECCVAL" : Gosub VERF_ECCVAL
                             When "SELECCLOT" : Gosub VERF_ECCLOT
                           Endcase
Endcase
Return

#**----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @return Number of components to enter for a version of the article ITM</br>
#*         0 => Item or folder with no versioning<br/>
#*         1 => Item with only major version</br>
#*         2 => Item with major and minor version
#**<br/>----------------------------------------------------------------
#*!

Funprog NBRCPN(ITM)
Value Char ITM()
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]ITM
   Read [ITM]ITM0 = [L]ITM
   If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]ECCMIN<>"" : End 2
Elsif [F:ITM]ECCMAJ<>"" : End 1
Endif
End 0

#**----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @return Number of components in version number of the item for cost management</br>
#*         0 => Item with no versioning<br/>
#*         1 => Item with only major version</br>
#*         2 => Item with major and minor version
#**<br/>----------------------------------------------------------------
#*!
Funprog NBRCPNCST(ITM)
Value Char ITM()

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If [F:ITM]ITMREF<>[L]ITM
   Read [ITM]ITM0 = [L]ITM
   If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]ECCFLG=2 & [F:ITM]ECCSTO>1
        # # If version management, return Stock version management if managed
        End [F:ITM]ECCSTO-1
Endif
End 0

#**----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @param N   = 1 if CPN is the major version, = 2 if CPN is a minor version
#* @param CPN = Version number
#* @param FMT = Expected format
#* @return Check if the version number ECC is compatible to the version counter set for the product ITM</br>
#*         0 => No (error message set in GMESSAGE) <br/>
#*         1 => Yes
#**<br/>----------------------------------------------------------------
#*!

Funprog CTLCPN(ITM,N,CPN,FMT)
Value    Char    ITM()
Value    Integer N
Value    Char    CPN()
Variable Char    FMT()

FMT="" : GMESSAGE=""
If !find(N,1,2) : End 0 : Endif

If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If func ECCLIB.NBRCPN(ITM)<N : End (CPN="") : Endif

If !clalev([F:ICV]) : Local File ITMCPTVER [ICV] : Endif
Local Char    ICVCOD(GLONICV), CAR(1)
Local Integer I, OK, OKBEG, OKEND

If N=1 : ICVCOD =  [F:ITM]ECCMAJ : Else ICVCOD = [F:ITM]ECCMIN : Endif
Read [ICV]ICV0=ICVCOD
If fstat : End 0 : Endif

OK=1 : OKBEG=1 : OKEND=1
# Constant
If [F:ICV]CNSVAL<>""
   If [F:ICV]CNSVAL<>left$(CPN,len([F:ICV]CNSVAL))
      OK=0
   Else
      CPN=right$(CPN,len([F:ICV]CNSVAL)+1)
   Endif
Endif

# Sequence length
If OK & len(CPN)<>[F:ICV]SEQLNG : OK=0 : Endif

# Sequence start
If OK & [F:ICV]SEQBEG<>"" & CPN<string$([F:ICV]SEQLNG-1,"0")+[F:ICV]SEQBEG : OK=0 : OKBEG=0 : Endif

# Séquence
For I=[F:ICV]SEQLNG To 1 Step -1
  CAR = mid$(CPN,I,1)
  Case [F:ICV]SEQTYP
    When 1       : If !(CAR >="0" & CAR<="9") : OK=0 : Endif
                   FMT="#"+FMT
    When 2       : If !(CAR >="a" & CAR<="z") : OK=0 : Endif
                   FMT="a"+FMT
    When 3       : If !(CAR >="A" & CAR<="Z") : OK=0 : Endif
                   FMT="A"+FMT
    When 4       : If !((CAR >="0" & CAR<="9") | (CAR >="a" & CAR<="z")) : OK=0 : Endif
                   FMT="b"+FMT
    When 5       : If !((CAR >="0" & CAR<="9") | (CAR >="A" & CAR<="Z")) : OK=0 : Endif : # GH 11/08/2016 bug 117942 - ! added to identify a wrong format
                   FMT="B"+FMT
    When Default : OK = 0
                   FMT="?"+FMT
  Endcase
  # Sequence end
  If OK & [F:ICV]SEQEND<>"" & CAR>[F:ICV]SEQEND : OK=0 : OKEND=0 : Endif

  #If !OK : Break : Endif
Next I
If !OK
   If [F:ICV]CNSVAL<>""
      Call TEXTFIC("ITMCPTVER","CNSVAL",2,GMESSAGE) From OBJDIV
      GMESSAGE="\+ "+GMESSAGE-[F:ICV]CNSVAL
   Endif
   If instr(1,FMT,"#")  : GMESSAGE+="\+ "+mess(2,9093,1)-"(#)" : Endif
   If instr(1,FMT,"A")  : GMESSAGE+="\+ "+mess(4,9093,1)-"(A)" : Endif
   If instr(1,FMT,"a")  : GMESSAGE+="\+ "+mess(5,9093,1)-"(a)" : Endif
   If instr(1,FMT,"B")  : GMESSAGE+="\+ "+mess(11,9093,1)-"(B)" : Endif
   If instr(1,FMT,"b")  : GMESSAGE+="\+ "+mess(12,9093,1)-"(b)" : Endif
   If GMESSAGE<>"" & !OKBEG | !OKEND : GMESSAGE+="\" : Endif
   If !OKBEG
      GMESSAGE +="\"+mess(27,105,1)-">="-string$([F:ICV]SEQLNG-1,"0")+[F:ICV]SEQBEG
   Endif
   If !OKEND
      GMESSAGE +="\"+mess(94,123,1)-"<="-[F:ICV]SEQEND
   Endif
   If GMESSAGE<>"" : GMESSAGE="\= "+right$(GMESSAGE,4) : Endif
Endif
FMT=[F:ICV]CNSVAL+FMT

End OK

#**----------------------------------------------------------------<br/>
#* @param ITM  = Product
#* @param VMAJ = Major version
#* @param VMIN = Minor version
#* @return Indicates if the version for stock has to be deleted in table ECCVAL </br>
#*         0 => Yes<br/>
#*         1 => No, because a BOM version still exists</br>
#*         2 => No, because stock is relative this version</br>
#*         3 => No, because orders are relative to this version</br>
#**<br/>----------------------------------------------------------------
#*!

Funprog TSTEVL4DEL(ITM,VMAJ,VMIN)
Value Char ITM(), VMAJ(), VMIN()

If !clalev([F:STL])  : Local File STOLOT    [STL]  : Endif
If !clalev([F:ORD])  : Local File ORDERS    [ORD]  : Endif
If !clalev([F:EVL2]) : Local File ECCVAL    [EVL2] : Endif

Filter [EVL2] Where ECCTYP<4
Look [EVL2]EVL1(3) = [L]ITM;[L]VMAJ;[L]VMIN
Filter [EVL2]
If fstat<=2 : End 1 : Endif

Filter [STL] Where ECCVALMAJ=[L]VMAJ & ECCVALMIN=[L]VMIN
Look [STL]STL0(1) = [L]ITM
Filter [STL]
If fstat<=2 : End 2 : Endif

Filter [ORD] Where ECCVALMAJ=[L]VMAJ & ECCVALMIN=[L]VMIN
Look [ORD]ORD2(1) = [L]ITM
Filter [ORD]
If fstat<=2 : End 3 : Endif

End 0

#**----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @param VMAJ = Major version
#* @return Indicates if the version for stock has to be deleted in table ECCSTA </br>
#*         0 => Yes<br/>
#*         1 => No</br>
#**<br/>----------------------------------------------------------------
#*!

Funprog TSTECSDEL(ITM,VMAJ)
Value Char ITM(), VMAJ()

If !clalev([F:EVL2]) : Local File ECCVAL    [EVL2] : Endif

Look [EVL2]EVL1(2) = [L]ITM;[L]VMAJ
If fstat<=2 : End 1 : Endif

End 0

#**----------------------------------------------------------------<br/>
#* Creates a record for the version in table ECCVAL with flow = Stock, if it doesn't already exist </br>
#* Creates a record for the major version in table ECCSTA, if it doesn't already exist<br/>
#*
#* @param ITM = Product
#* @param VMAJ = Major version
#* @param VMIN = Minor version
#* @param STADEF = Stock status (menu local 2776) if record creation in table ECCSTA
#**<br/>----------------------------------------------------------------
#*!

Subprog CREEVL4(ITM, VMAJ, VMIN, STADEF)
Value Char ITM(), VMAJ(),VMIN()
Value Integer STADEF

If !clalev([F:EVL]) : Local File ECCVAL   [EVL]  : Endif
If !clalev([F:ECS]) : Local File ECCSTA   [ECS]  : Endif

Local Integer I

If !adxlog
   GOK=1
   Trbegin [ECS],[EVL]
     Gosub TR_CREEVL4
     If GOK<1 : Rollback : End : Endif
   Commit
Else
  Gosub TR_CREEVL4
Endif
End

$TR_CREEVL4
Look [EVL]EVL1 = [L]ITM;[L]VMAJ;[L]VMIN;4
If fstat
  Filter [EVL] Where ITMREF=[L]ITM & ECCTYP=4
  Read [EVL]EVL0 Last
  Filter [EVL]
  If fstat<=2 : I = [F:EVL]ECCSEQ : Else I=0 : Endif
  Raz [F:EVL]
  [F:EVL]ITMREF    = [L]ITM
  [F:EVL]ECCSEQ    = I+1
  [F:EVL]ECCTYP    = 4 : # stock
  [F:EVL]USESTA    = 2 : # exploitation
  [F:EVL]ECCVALMAJ = [L]VMAJ
  [F:EVL]ECCVALMIN = [L]VMIN
  [F:EVL]EXNFLG    = 1
  Write [EVL]
  If fstat
     GOK=0 : Call FSTA("EVL") From GLOCK : Return
  Endif
Endif

Look [ECS]ECS0 = [L]ITM; [L]VMAJ
If fstat
   Raz [F:ECS]
   [F:ECS]ITMREF    = [L]ITM
   [F:ECS]ECCVALMAJ = [L]VMAJ
   [F:ECS]ECCSTA    = [L]STADEF
   [F:ECS]EXNFLG    = 1
   [F:ECS]SPSFLG    = 1
   Write [ECS]
   If fstat
     GOK=0 : Call FSTA("EVL") From GLOCK : Return
  Endif
Endif
Return

#**----------------------------------------------------------------<br/>
#* Sets an new ID to the BOM line, or returns it if already set </br>
#*
#* @param ITM    = Parent item
#* @param ALT    = BOM code
#* @param TYPALT = BOM type (menu local 224)
#* @param CPN    = Component
#* @param SEQ    = Sequence
#* @param ID     = Uniq number of BOM line for a BOM parent item (stable even if BOMSEQ changed)
#*
#**<br/>----------------------------------------------------------------
#*!

Subprog BOMLINID(ITM,ALT,TYPALT,CPN,SEQ,ID)
Value Char       ITM(), CPN()
Value Integer    ALT, TYPALT, SEQ
Variable Integer ID

If !clalev([F:BOD]) : Local File BOMD [BOD] : Endif
[L]ID=0
Read [BOD]BOD0 = [L]ITM;[L]ALT;[L]SEQ;[L]CPN;TYPALT
If fstat
   GOK=0 : Call RSTA("BOD",[L]ITM-num$([L]ALT)-num$([L]SEQ)-[L]CPN-num$([L]TYPALT)) From GLOCK : End
Elsif [F:BOD]BOMLINID<>0
   [L]ID = [F:BOD]BOMLINID
Else
   If !clalev([F:BOH]) : Local File BOM [BOH] : Endif
   Read [BOH]BOH0 = [L]ITM;[L]ALT;[L]TYPALT
   If fstat
      GOK=0 : Call RSTA("BOH",[L]ITM-num$([L]ALT)-num$([L]TYPALT)) From GLOCK : End
   Endif
   [F:BOH]MAXLINID+= 1
   Rewrite [BOH]
   If fstat
      GOK=0 : Call FSTA("BOH") From GLOCK : End
   Endif
   #
   [F:BOD]BOMLINID = [F:BOH]MAXLINID
   Rewrite [BOD]
   If fstat
      GOK=0 : Call FSTA("BOD") From GLOCK : End
   Endif
   [L]ID = [F:BOD]BOMLINID
Endif
End

#**----------------------------------------------------------------<br/>
#* Lock BOM symbole, if it is not already done by the current session </br>
#*
#* @param ITM    = Parent item
#* @param ALT    = BOM code
#* @param TYPALT = BOM type (menu local 224)
#* @return 1 if lock is done, 0 if there is a lock issue
#**<br/>----------------------------------------------------------------
#*!

Funprog LCKBOH(ITM,ALT,TYPALT)
Value Char    ITM()
Value Integer ALT, TYPALT

Local Char SYMBOLE(100)
Local Integer VERROU

SYMBOLE="BOH"+num$([L]ALT)+"\"+[L]ITM+"\"+num$([L]TYPALT)
Call TESTLOCK(SYMBOLE,VERROU) From GLOCKM
If !VERROU
  Lock =SYMBOLE With lockwait=0
  If !fstat : VERROU=1 : Endif
Endif
End VERROU

######################################################################################################
# Before entry action to inhibite the entry of the field
# except during the developement of the first version
######################################################################################################

Subprog PASBUTECC1

If dim([M:BOH0]ECCSEQ)=1 & [M:BOH0]ECCSEQ<>0
&  & !([M:BOH0]ECCSEQ=-1 | ([M:BOH0]ECCSEQ=1 & [M:BOH0]USESTA=1))
   # GH 23/02/2016 PE 114750 to enable to enter a field even if versioning
   GPE=0 : GPOINT = "PASBUTECC1" : Gosub  ENTREE From EXEFNC
   If !GPE : mkstat=2 : Endif
Endif

End

######################################################################################################
# Before entry action to inhibite the entry of the field
# for a version avalailable to use
######################################################################################################

Subprog PASECCUSE2
If dim([M:BOH0]ECCSEQ)<>1 | [M:BOH0]ECCSEQ=0 : End : Endif

Local Integer NOL
If dim([M]CPNITMREF)=1 : NOL=0 : Else NOL=nolign-1 : Endif
If [M]CPNTYP(NOL)<>1 | [M]CREFLG(NOL)=0 : End : Endif

# Existing line with Normal type
# Version available to use & line with Normal type
# or Version in development & line with impact on previous versions
If ([M:BOH0]USESTA=2 & [M]CPNTYP(NOL)=1) | ([M:BOH0]USESTA=1 & [M]BOMSTRDAT(NOL)<>[M:BOH0]ECCDAT)
   # GH 23/02/2016 PE 114750 to enable to entre a field even if versioning
   GPE=0 : GPOINT = "PASECCUSE2" : Gosub  ENTREE From EXEFNC
   If !GPE : mkstat=2 : Endif
Endif

End

######################################################################################################
# Before entry action to inhibite the entry of the field
# if the component is linked to at least 1 product managed by version
######################################################################################################
Subprog PASECCMFM
If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif : # Issue 118954 GH 07/10/2016 - it just concerns folders with versioning

# Issue X3-28781 - 2017-06-27 by JUSYN : Info: critical changes can be made on fields: RETQTY, BOMOPE, PKC

Local Integer I, NOL
If dim([M]MFGLIN)>1 : NOL= nolign-1 : Else : NOL=0 : Endif
If [M]MFGLIN(NOL)>0
    I = find([M]MFGLIN(NOL),[M:MFG1]MFGLIN)
    If I>0 & [M:MFG1]ECCVALMAJ(I-1)<>""
        mkstat=2
        # Issue X3-28781 - 2017-06-27 by JUSYN : Do not lock certain fields if user has permission to do critical changes on components
        If GWOCRICHG & zoncou <> "ECCVALMAJ" & zoncou <> "ECCVALMIN" & GREP<>"C" # Issue X3-48941 - 2017-08-25 by JUSYN : Not during creation of WO
            mkstat = 0
        Endif
        # End issue X3-28781
    Endif
Else
    For I=0 To [M:MFG1]NBLIG-1
        If [M:MFG1]ECCVALMAJ(I)<>""
            mkstat=2
            # Issue X3-28781 - 2017-06-27 by JUSYN : Do not lock certain fields if user has permission to do critical changes on components
            If GWOCRICHG & zoncou <> "ECCVALMAJ" & zoncou <> "ECCVALMIN"
                mkstat = 0
            Endif
            # End issue X3-28781
            Break
        Endif
    Next
Endif
# Issue 111417 - 2015-10-01 by CCC : do not allow entering if item not managed by version
If !mkstat
    If (zoncou="ECCVALMAJ" & func ECCLIB.NBRCPN([M]ITMREF(NOL))<1)
&    | (zoncou="ECCVALMIN" & func ECCLIB.NBRCPN([M]ITMREF(NOL))<2)
        mkstat=2
    Endif
Endif
End

######################################################################################################
# Issue X3-25054 - Before entry action to allow entry of field if user has permissions and
# released product is versioned
######################################################################################################

Subprog MFGCRICHG(PIND)
Value Integer PIND
  Local Integer I
  If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif
  mkstat=2
  # Issue X3-48941 - use new global parameter for audit
  If GMFGREV=2 and GWOCRICHG
    # if adding By-product then reason not needed
    If (instr(1,dbgstr(1),"MFMW"))
      If [M:MFMW]CPNTYP <> 1
        End
      Endif
    Endif
    # for adding assembly, get MFGLIN
    If (instr(1,dbgstr(1),"MFMF"))
      For I=0 To [M:MFG1]NBLIG-1
        If [M:MFG1]ITMTYP=1 and [M:MFG1]ECCVALMAJ(I)<>""
          PIND = [M:MFG1]MFGLIN(I)
          Break
        Endif
      Next
    Endif

    # check released product is versioned
    If PIND > 0 & GREP <> "C"   # Issue X3-48941 - 2017-08-25 by JUSYN : No revreason needed during creation of WO
      I = find(PIND,[M:MFG1]MFGLIN)
      If I>0 & [M:MFG1]ECCVALMAJ(I-1)<>""
        mkstat = 0
      Endif
    Endif
  Endif

End
# End issue X3-25054

######################################################################################################
## Selection using browser EVL3
######################################################################################################

$SELECCVAL3
OBJET="EVL3"
Gosub SELBROWSER From OBJSIM
OBJET=""
If !PSTD : Return : Endif
Return

######################################################################################################
## Selection using object EVL2/EVL4
######################################################################################################
# PARAM(1) = ITMREF = Item
# PARAM(2) = ECCMAJ = value of major version
# PARAM(3) = ZONECCMIN = name (not the value) of minor version field if action called from major version field
#                        must to be null if called from the minor version field
# PARAM(4) = ECCTYP = flow type of version
# PARAM(5) = DAT = start date to show versions list
# PARAM(6) = ABREV = abreviation of screen (could be used for specific selection)
######################################################################################################
$SELECCVAL2
Local Char    LITM(GLONITM)             : LITM = PARAM(1)
Local Char    LECCMAJ(GLONICVVAL)       : LECCMAJ = PARAM(2)
Local Char    LZONECCMIN(len(PARAM(3))) : LZONECCMIN = PARAM(3)
Local Integer LECCTYP                   : LECCTYP = val(PARAM(4))
Local Date    LECCDAT                   : LECCDAT = PARAM(5)
Local Char    LABR(10)                  : LABR = PARAM(6)

Local Integer ICRIT

# Select versions usable from today : active, not suspended or in derogation period
Raz CRITERE, ICRIT
Call ADDCRIT(CRITERE,ICRIT,"","[EVL]USESTA=2","&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRIT,"","[ECS]ECCSTA<>3","&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRIT,"","[EVL]ITMREF='"+LITM+"' & [EVL]ECCTYP="+num$(LECCTYP),"&") From GOBJSUB
# If flow type is stock, the control has to be done on ECCSTA table
If LECCTYP=4
    Call ADDCRIT(CRITERE,ICRIT,"","([ECS]ENDDAT>=LECCDAT | [ECS]ENDDAT=[0/0/0] | ([ECS]EXNFLG=2 & ([ECS]EXNDAT>=LECCDAT | [ECS]EXNDAT=[0/0/0])))","&") From GOBJSUB
    OBJET="EVL4"
Else
    Call ADDCRIT(CRITERE,ICRIT,"","([EVL]ENDDAT>=LECCDAT | [EVL]ENDDAT=[0/0/0] | ([EVL]EXNFLG=2 & ([EVL]EXNDAT>=LECCDAT | [EVL]EXNDAT=[0/0/0])))","&") From GOBJSUB
    OBJET="EVL2"
Endif
Gosub SELBROWSER From OBJSIM
OBJET=""

If LZONECCMIN=""
    Call ADDCRIT(CRITERE,ICRIT,"","ECCVALMAJ='"+LECCMAJ+"'","&") From GOBJSUB
    EXPSTART="ECCVALMAJ='"+LECCMAJ+"' & ECCVALMIN='"+VALEUR+"'"
    START="ECCVALMIN"
Else
    EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+evalue(LZONECCMIN)+"'"
Endif
Return

$VERF_ECCVAL
START=""

If LZONECCMIN<>""
    VALEUR = [F:EVL]ECCVALMAJ
    If [F:EVL]ECCVALMIN<>evalue(LZONECCMIN)
        Assign LZONECCMIN With [F:EVL]ECCVALMIN
        Affzo =LZONECCMIN
        mkstat=4
    Endif
Else
    VALEUR = [F:EVL]ECCVALMIN
Endif
Return

#**----------------------------------------------------------------<br/>
#* CTRECC : Control if a version number can be used in a WO or EO for a date
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = product
#* @param PABR = abreviation of current screen
#* @param PFLDCOD = field code name
#* @param PECCMAJ = major version number
#* @param PECCMIN = minor version number
#* @param PDAT = date to control (if [0/0/0] => no control)
#* @param PRET (return) = error code (0=OK, 1=Error, 2=Message, 3=Warning, 4=blocking error) (like GERR for values up to 3)
#* @param PMSG (return) = the error message or all warning messages (void if PRET=0)
#**<br/>----------------------------------------------------------------
#*!
Subprog CTRECC(PITM,PABR,PFLDCOD,PECCMAJ,PECCMIN,PDAT,PRET,PMSG)
Value Char    PITM
Value Char    PABR
Value Char    PFLDCOD
Value Char    PECCMAJ
Value Char    PECCMIN
Value Date    PDAT
Variable Integer PRET
Variable Char PMSG

Raz PRET, PMSG

Local Integer LCTL
Local Char LCTLFLG(20)
Local Integer LECCTYP
Local Integer LNBCPN

# number of components for version number (0=no version/ 1=major / 2=major+minor)
LNBCPN = func ECCLIB.NBRCPN(PITM)
If LNBCPN=0
    End
Endif

# Issue 111235 - 2016-03-10 by JUSYN : flag position 7 to check whether version is valid today or in the future
LCTLFLG = "1313110"  # Default : Blocking on existence of version, Warning if suspended, Warning if "to activate", Blocking if stopped, Error if date not OK
LECCTYP=4       # Default : stock flow

Case PABR
    When "MFI" : # Product of an auto WO
                 If [F:MFI]ITMTYP<>2
                    LECCTYP=2
                 Endif

    When "MFG1" : # Product of a WO
                 If [M:MFG1]ITMTYP(nolign-1)<>2
                    LECCTYP=2
                 Endif
                 # If control is done on ECCVALMAJ or ECCVALMIN field, date validity is just a warning
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,5)+"3"+right$(LCTLFLG,7)
                 Endif

    When "MFMF" : # Add of a sub-assembly (ghost)
                 If find(PFLDCOD,"GHTECCMAJ","GHTECCMIN")
                     LECCTYP=2
                     # For ghost BOM use, we need to have an available BOM
                     LCTLFLG=left$(LCTLFLG,3)+"4"+right$(LCTLFLG,5)
                 Endif

    When "SCO0" : # Product of a EO
                 LECCTYP=3
                 # If control is done on ECCVALMAJ or ECCVALMIN field, date validity is just a warning
                 # Issue 111235 - 2016-03-10 by JUSYN : date validity is no warning any more 0 instead of 3; date will be updated with version
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,5)+"0"+right$(LCTLFLG,7)
                 Endif
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,6)+"1"+right$(LCTLFLG,8)
                 Endif

    When "MBW1", "MBW3", "MBW4", "DIA" , "MUX1" : # Product of a WO # Issue 111414/113 - 2016-03-21 by JUSYN : Same for MUX1 Multilevel planning
                 LECCTYP=2
                 # If control is done on ECCVALMAJ or ECCVALMIN field, date validity is just a warning
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,5)+"3"+right$(LCTLFLG,7)
                 Endif

    When "PBW1", "PBW5", "PBW3", "PBW4", "SMW1", "SMW3" : # Purchase Order, Subcontracting Order
                 If PABR="SMW3" | PABR="SMW1"
                     LECCTYP=3
                 Else
                     LECCTYP=4
                 Endif
                 # If control is done on ECCVALMAJ or ECCVALMIN field, date validity is just a warning
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,5)+"3"+right$(LCTLFLG,7)
                 Endif

    When "VIS1"
                 LECCTYP=2

    # Issue 115680 - 2016-04-06 by BEEBE : Validation of Version fields when tracking material
    When "MTK3" : # Production Tracking
                 LECCTYP=4
                 # If control is done on ECCVALMAJ or ECCVALMIN field, date validity is just a warning
                 If find(PFLDCOD,"ECCVALMAJ","ECCVALMIN")
                    LCTLFLG=left$(LCTLFLG,5)+"3"+right$(LCTLFLG,7)
                 Endif
Endcase

If LNBCPN=2 & find(PFLDCOD,"ECCVALMAJ","GHTECCMAJ")
    LCTLFLG = left$(LCTLFLG,1)+"00000"   # Default : On major version we control only existence of the version if minor version is available for the item
Endif

If mid$(LCTLFLG,1,2)<>"00" # Issue 119469 GH 04/11/16 - performance enhancement
  # 1 - Control of major version existence
  If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
  Read [ECS]ECS0=PITM;PECCMAJ
  If fstat
      LCTL = val(mid$(LCTLFLG,1,1))
      If LCTL
          Call ADDMSG(PRET,PMSG,LCTL,mess(406,184,1)) # Version inexistante !
      Endif
  Endif
  If find(PRET,4,1) : End : Endif

  # 2 - Is the version suspended ?
  LCTL = val(mid$(LCTLFLG,2,1))
  If LCTL & [F:ECS]SPSFLG = 2
      Call ADDMSG(PRET,PMSG,LCTL,mess(424,184,1))
  Endif
  If find(PRET,4,1) : End : Endif
Endif

If mid$(LCTLFLG,3,5)<>"00000" # Issue 119469 GH 04/11/16 - performance enhancement
  # 3 - existence Major/Minor version for current flow type
  If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
  Read [EVL]EVL1=PITM;PECCMAJ;PECCMIN;LECCTYP
  If fstat
      LCTL = val(mid$(LCTLFLG,3,1))
      If LCTL
          Call ADDMSG(PRET,PMSG,LCTL,mess(406,184,1)-mess(LECCTYP,2059,1)) # Version inexistante !
      Endif
  Else
        # 4 - Is the version active ?
        LCTL = val(mid$(LCTLFLG,4,1))
        If LCTL
            If [F:ECS]ECCSTA=4 # | [F:EVL]USESTA=1 : # GH 04/04/2016 bug 115713 to have a specific error message for BOM in development that stops the entry
                Call ADDMSG(PRET,PMSG,LCTL,mess(397,184,1)) # 'This version is not active'
            Endif
        Endif
        # 5 - Is the version stopped ? or Is BOM in development ?
        LCTL = val(mid$(LCTLFLG,5,1))
        If LCTL
           If  [F:ECS]ECCSTA=3
               Call ADDMSG(PRET,PMSG,LCTL,mess(425,184,1)) # 'Stopped version forbidden'
           Elsif [F:EVL]USESTA=1 : # GH 04/04/2016 bug 115713 to have a specific error message for BOM in development that stops the entry
               Call ADDMSG(PRET,PMSG,LCTL,mess(51,193,1))  # 'BOM in development'
           Endif
        Endif

        If find(PRET,4,1) : End : Endif

        # 6 - Is the version valid for the date ?
        LCTL = val(mid$(LCTLFLG,6,1))
        If LCTL & PDAT<>[0/0/0]
            Local Date WDATE : WDATE=PDAT
            If WDATE=[0/0/0] : WDATE = date$ : Endif
            If LECCTYP=4  & ( WDATE<[F:ECS]STRDAT
&                           | ([F:ECS]ENDDAT<>[0/0/0] & [F:ECS]ENDDAT<WDATE & [F:ECS]EXNFLG=1)
&                           | ([F:ECS]EXNDAT<>[0/0/0] & [F:ECS]EXNDAT<WDATE & [F:ECS]EXNFLG=2) )
&            | LECCTYP<>4 & ( WDATE<[F:EVL]STRDAT
&                           | ([F:EVL]ENDDAT<>[0/0/0] & [F:EVL]ENDDAT<WDATE & [F:EVL]EXNFLG=1)
&                           | ([F:EVL]EXNDAT<>[0/0/0] & [F:EVL]EXNDAT<WDATE & [F:EVL]EXNFLG=2) )
                Call ADDMSG(PRET,PMSG,LCTL,mess(432,184,1)-format$("D:"+GFMDAT,WDATE)) # 'Unavailable version at'
            Endif
        Endif
        # 7 - Is the version valid for today or the future
        LCTL = val(mid$(LCTLFLG,7,1))
        If LCTL
            If LECCTYP=4  & (
&                             ([F:ECS]ENDDAT<>[0/0/0] & [F:ECS]ENDDAT<date$ & [F:ECS]EXNFLG=1)
&                           | ([F:ECS]EXNDAT<>[0/0/0] & [F:ECS]EXNDAT<date$ & [F:ECS]EXNFLG=2) )
&            | LECCTYP<>4 & (
&                             ([F:EVL]ENDDAT<>[0/0/0] & [F:EVL]ENDDAT<date$ & [F:EVL]EXNFLG=1)
&                           | ([F:EVL]EXNDAT<>[0/0/0] & [F:EVL]EXNDAT<date$ & [F:EVL]EXNFLG=2) )
                Call ADDMSG(PRET,PMSG,LCTL,mess(432,184,1)-format$("D:"+GFMDAT,date$)) # 'Unavailable version at'
            Endif
        Endif
  Endif
Endif
If find(PRET,4,1) : End : Endif

End

#########################################
# Add a message to another one or replace it if PERR=1 or 4 (error, blocking error)
Subprog ADDMSG(PERR,PMSG,PNEWERR,PNEWMSG)
Variable Integer PERR
Variable Char PMSG
Value Integer PNEWERR
Value Char PNEWMSG

If PNEWERR=0 : End : Endif

If find(PNEWERR,1,4)
    PMSG = PNEWMSG
Else
    PMSG += string$(PMSG<>"","\") + PNEWMSG
Endif

If PERR<>1
    If find(PNEWERR,1,4)
        PERR = PNEWERR
    Else
        PERR = max(PERR,PNEWERR)    # Warning has higher priority than message
    Endif
Endif
End

######################################################################################################
# What is the document line status ?
# ERRCOD returns a code number
# ERRCODORI returns a code number & the origin of error
######################################################################################################
#**----------------------------------------------------------------<br/>
#* ERRCOD : return status of the line
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR = abreviation of the screen
#* @param PIND = line index
#* @return highest kind of error between status of the item and the version<br/>
#* 0=no error, 1=error, 3=warning
#**<br/>----------------------------------------------------------------
#*!
Funprog ERRCOD(PABR,PIND)
Value Char PABR
Value Integer PIND
Local Char LORI(3)
End func ERRCODORI(PABR, PIND, LORI)

#**----------------------------------------------------------------<br/>
#* ERRCOD : return status of the line
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR = abreviation of the screen
#* @param PIND = line index
#* @param PORI = origin of error ("" if no error, "ITM" if status of the item, "ECC" if version number)
#* @return highest kind of error between status of the item and the version<br/>
#* 0=no error, 1=error, 3=warning
#**<br/>----------------------------------------------------------------
#*!
Funprog ERRCODORI(PABR,PIND,PORI)
Value Char PABR
Value Integer PIND
Variable Char PORI

Local Integer I, J, LNB
Local Char LORI(3)(2), FLD(GLONAVA)

# Priority 1 : status of the item
# Priority 2 : status of the version
For FLD="ITMERRCOD","ECCERRCOD"
    If  evalue("dim([M:"+PABR+"]"+FLD+")")>0
        LORI(LNB) = left$(FLD,3)        # Get "ITM", "ECC"
        LNB+=1
    Endif
Next

Local Integer LRET
For I=4,1,3
    For J=0 To LNB-1
        If evalue("[M:"+PABR+"]"+LORI(J)+"ERRCOD(PIND)")=I
            PORI = LORI(J)
            LRET=I
            Break 2 : # Break   # Issue 122638 GH 15/05/2017 - performance enhancement
        Endif
    Next
Next

End LRET

#**----------------------------------------------------------------<br/>
#* HIGHLIGHT : Refresh style of a line in function of line status
#**<br/>----------------------------------------------------------------<br/>
#* @param PABR = Screen abeviation
#* @param PIND = line index (if -1 -> refresh all lines)
#**<br/>----------------------------------------------------------------
#*!
Subprog HIGHLIGHT(PABR,PIND)
Value Char PABR
Value Integer PIND

Local Char LWRNSTY(20) : LWRNSTY = "BACKORANGE"
Local Char LERRSTY(20) : LERRSTY = "BACKRED"

Local Integer I, LINDSTR, LINDEND, LERR
LINDSTR=max(0,PIND)
LINDEND = PIND

Case PABR
    When "MFG1" : # List of products
        If PIND<>-2  # Issue 119469 GH 04/11/16 - performance enhancement
           # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
           Affzo [MFG1]1-99 : # GH 14/03/2016 bug 114747 to do before applying styles
        Endif
        If PIND<0
            LINDEND=[M:MFG1]NBLIG-1
            Chgstl [M:MFG1]NBLIG With "" : # Issue 119469 GH 04/11/16 - performance enhancement
        Endif
        For I=LINDSTR To LINDEND
            # Affzo [MFG1]NBLIG(I) : # GH 14/03/2016 bug 114747 this instruction generates a fatal error
            LERR = func ECCLIB.ERRCOD(PABR, I)
            Case LERR
                When 1, 4: # Error
                    Chgstl [M:MFG1]NBLIG(I) With LERRSTY
                When 3: # Warning
                    Chgstl [M:MFG1]NBLIG(I) With LWRNSTY
                When Default
                    # Issue 119469 GH 04/11/16 - test PIND for performance enhancement
                    If PIND>-1 : Chgstl [M:MFG1]NBLIG(I) With "" : Endif
            Endcase
        Next
    When "MFG2" : # List of components
        If PIND<>-2  # Issue 119469 GH 04/11/16 - performance enhancement
          # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
          Affzo [MFG2]1-99 : # GH 14/03/2016 bug 114747 to do before applying styles
        Endif

        # Issue 122638 GH 15/05/2017 - performance enhancement
        Local Integer LZ1, LZ2, J
        If dim([M:MFG2]ITMERRCOD)>0                            : LZ1=1 : Endif
        If dim([M:MFG2]ECCVALMAJ)>0 & dim([M:MFG2]ECCERRCOD)>0 : LZ2=1 : Endif
        If LZ1+LZ2=0 : End : Endif

        If PIND<0
            LINDEND=[M:MFG2]NBLIG-1
            Chgstl [M:MFG2]NBLIG With "" : # Issue 119469 GH 04/11/16 - performance enhancement
        Endif
        For I=LINDSTR To LINDEND
            # Affzo [MFG2]NBLIG(I) : # GH 14/03/2016 bug 114747 this instruction generates a fatal error
            # LERR = func ECCLIB.ERRCOD(PABR, I) : # Issue 122638 GH 15/05/2017 - performance enhancement
            LERR = 0
            For J=4,1,3
                If (LZ1 & [M:MFG2]ITMERRCOD(I)=J) | (LZ2 & [M:MFG2]ECCERRCOD(I)=J)
                   LERR=J : Break
                Endif
            Next
            Case LERR
                When 1,4: # Error
                    Chgstl [M:MFG2]NBLIG(I) With LERRSTY
                When 3: # Warning
                    Chgstl [M:MFG2]NBLIG(I) With LWRNSTY
                When Default
                    # Issue 119469 GH 04/11/16 - test PIND for performance enhancement
                    If PIND>-1 : Chgstl [M:MFG2]NBLIG(I) With "" : Endif
            Endcase
        Next
    When "MFMF" : # List of components of a ghost
        If PIND=-1
            LINDEND=[M:MFG2]NBLIG-1
        Endif
        # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
        Affzo [MFMF]1-99 : # GH 14/03/2016 bug 114747 to do before applying styles
        For I=LINDSTR To LINDEND
            # Affzo [MFMF]NBLIG(I) : # GH 14/03/2016 bug 114747 this instruction generates a fatal error
            LERR = func ECCLIB.ERRCOD(PABR, I)
            Case LERR
                When 1,4: # Error
                    Chgstl [M:MFMF]NBLIG(I) With LERRSTY
                When 3: # Warning
                    Chgstl [M:MFMF]NBLIG(I) With LWRNSTY
                When Default
                    Chgstl [M:MFMF]NBLIG(I) With ""
            Endcase
        Next
    When "SCO1" : # One single product for EO
        Affzo [SCO1]ECCVALMAJ
        LERR = func ECCLIB.ERRCOD(PABR, 0)
        Case LERR
            When 1,4: # Error
                Chgstl [M:SCO1]ECCVALMAJ With LERRSTY
                Chgstl [M:SCO1]ECCVALMIN With LERRSTY
                Chgstl [M:SCO1]ORDDAT    With LERRSTY
            When 3: # Warning
                Chgstl [M:SCO1]ECCVALMAJ With LWRNSTY
                Chgstl [M:SCO1]ECCVALMIN With LWRNSTY
                Chgstl [M:SCO1]ORDDAT    With LWRNSTY
            When Default
                Chgstl [M:SCO1]ECCVALMAJ With ""
                Chgstl [M:SCO1]ECCVALMIN With ""
                Chgstl [M:SCO1]ORDDAT    With ""
        Endcase
    When "SCO2" : # List of components
        If PIND=-1
            LINDEND=[M:SCO2]NBLIG-1
        Endif
        # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
        Affzo [SCO2]1-99 : # GH 14/03/2016 bug 114747 to do before applying styles
        For I=LINDSTR To LINDEND
            # Affzo [SCO2]NBLIG(I) : # GH 14/03/2016 bug 114747 this instruction generates a fatal error
            LERR = func ECCLIB.ERRCOD(PABR, I)
            Case LERR
                When 1,4: # Error
                    Chgstl [M:SCO2]NBLIG(I) With LERRSTY
                When 3: # Warning
                    Chgstl [M:SCO2]NBLIG(I) With LWRNSTY
                When Default
                    Chgstl [M:SCO2]NBLIG(I) With ""
            Endcase
        Next
Endcase
End

######################################################################################################
## Selection using browser ECCL : allow to select a Lot number for a specific version number of item
######################################################################################################
# PARAM(1) = ITMREF = Item
# PARAM(2) = ECCMAJ = value of major version
# PARAM(3) = ECCMIN = value of minor version
######################################################################################################
$SELECCLOT
Local Char LITM(GLONITM) : LITM = PARAM(1)
Local Char LECCMAJ(GLONICVVAL) : LECCMAJ=PARAM(2)
Local Char LECCMIN(GLONICVVAL) : LECCMIN=PARAM(3)
Local Integer ICRIT

OBJET="ECCL"
Gosub SELBROWSER From OBJSIM
OBJET=""
TIT(0) = mess(18,7,1)-LITM
If LECCMAJ<>""
    TIT(0) -= mess(126,105,1)-LECCMAJ-LECCMIN
Endif
Raz CRITERE, ICRIT
Call ADDCRIT(CRITERE, ICRIT, "", "ITMREF='"+LITM+"'", "&") From GOBJSUB
If LECCMAJ<>""
    Call ADDCRIT(CRITERE, ICRIT, "", "ECCVALMAJ='"+LECCMAJ+"'", "&") From GOBJSUB
Endif
If LECCMIN<>""
    Call ADDCRIT(CRITERE, ICRIT, "", "ECCVALMIN='"+LECCMIN+"'", "&") From GOBJSUB
Endif
Return

$VERF_ECCLOT
START=""
VALEUR = [F:ECCL]LOT
Return

#**----------------------------------------------------------------<br/>
#* change a date not included in the validity period of a version<br/>
#* either to the start date of the version if the date was before<br/>
#* or to the end date of the version if the date was after
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM = Product
#* @param ECCMAJ = Major version number
#* @param ECCMIN = Minor version number
#* @param TYP = Flow type (2=Production, 3=Subcontract)
#* @param DAT (return) = Date
#**<br/>----------------------------------------------------------------
#*!
Subprog CORDAT(ITM,ECCMAJ,ECCMIN,TYP,DAT)
Value Char    ITM()
Value Char    ECCMAJ()
Value Char    ECCMIN()
Value Integer TYP
Variable Date DAT

If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Read [EVL]EVL1 = [L]ITM;[L]ECCMAJ;[L]ECCMIN;[L]TYP
If !fstat
   If    [L]DAT<[F:EVL]STRDAT                          : [L]DAT = [F:EVL]STRDAT
   Elsif [F:EVL]ENDDAT<>[0/0/0] & [L]DAT>[F:EVL]ENDDAT : [L]DAT = [F:EVL]ENDDAT
   Endif
Endif
End

# Issue 111235 - 2016-03-07 by JUSYN : Control needed just to check whether version exists
#**----------------------------------------------------------------<br/>
#* CTRECCVER : Control to see whether version exists, is active and not stopped
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = product
#* @param PABR = abreviation of current screen
#* @param PECCMAJ = major version number
#* @param PECCMIN = minor version number
#* @param PRET (return) = error code (0=OK, 1=Error, 2=Message, 3=Warning, 4=blocking error) (like GERR for values up to 3)
#* @param PMSG (return) = the error message or all warning messages (void if PRET=0)
#**<br/>----------------------------------------------------------------
#*!
Subprog CTRECCVER(PITM,PABR,PECCMAJ,PECCMIN,PRET,PMSG)
Value Char    PITM
Value Char    PABR
Value Char    PECCMAJ
Value Char    PECCMIN
Variable Integer PRET
Variable Char PMSG

Raz PRET, PMSG

Local Integer LCTL
Local Integer LECCTYP

LECCTYP= 3       # Default : subcontract
LCTL = 1

Case PABR
    When "SCO0" : # Product of a EO
                 LECCTYP=3
Endcase

# 0 - major version existence
If !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
Read [ECS]ECS0=PITM;PECCMAJ
If fstat
    Call ADDMSG(PRET,PMSG,LCTL,mess(406,184,1))     # Version inexistante  !
Endif
If find(PRET,4,1) : End : Endif

# 1- existence Major/Minor version for current flow type
If !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
Read [EVL]EVL1=PITM;PECCMAJ;PECCMIN;LECCTYP
If fstat
    Call ADDMSG(PRET,PMSG,LCTL,mess(406,184,1)-mess(LECCTYP,2059,1)) # Version inexistante !
Else
    # 2 - Is the version active ?
    If [F:EVL]USESTA=1 | [F:ECS]ECCSTA=4
        Call ADDMSG(PRET,PMSG,LCTL,mess(397,184,1)) # 'This version is not active'
    Endif
    # 3 - Is the version stopped ?
    If [F:ECS]ECCSTA=3
        Call ADDMSG(PRET,PMSG,LCTL,mess(425,184,1)) # 'Stopped version forbidden'
    Endif
Endif
If find(PRET,4,1) : End : Endif

End

# Issue X3-25054 - 2017-07-05 by JUSYN : Control user permission for ctritical changes WO components
#**----------------------------------------------------------------<br/>
#* CTRECCWCO : Control if user has permission to do critical changes in WO components
#**<br/>----------------------------------------------------------------<br/>
#* Sets global parameter GWOCRICHG 0 = no permission 1 = permission
#**<br/>----------------------------------------------------------------
#*!
Subprog CTRECCWCO()
Local Integer LRET
Local Char ECCWOCOM(30)

# Issue X3-55832
If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif
# End issue X3-55832

Call PARAMUTIL("ECCWOCOM",ECCWOCOM,GUSER,"") From SUBAUS
If ECCWOCOM = "2"
    GWOCRICHG=1   # = Yes
Else
    GWOCRICHG=0   # = No
Endif

End

# Issue X3-25054 - 2017-07-05 by JUSYN : Control user permission for ctritical changes WO components
# Issue X348941 - 2017-08-18 by JUSYN : If a versioned product has been deleted in MFG1 Header check if product was BOM versioned (see with read MFIC)
#**----------------------------------------------------------------<br/>
#* CTRECCPROD : Control if BOM line belongs to versioned product
#**<br/>----------------------------------------------------------------<br/>
#* 0 = belongs to unversioned product  |  1 = belongs to versioned product
#**<br/>----------------------------------------------------------------
#*!
Funprog CTRECCPROD(PIND)
Value Integer PIND

Local Shortint LRET  :  LRET = 0

If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif
If !clalev([F:MFIC]) : Local File MFGITM [MFIC] : Endif

Local Integer I, NOL
If dim([M:MFG2]MFGLIN)>1 : NOL= PIND : Else : NOL=0 : Endif
If [M:MFG2]MFGLIN(NOL)>0
    I = find([M:MFG2]MFGLIN(NOL),[M:MFG1]MFGLIN)
    If I>0 & [M:MFG1]ECCVALMAJ(I-1)<>""
        LRET = 1
    Endif
    If I=0
        Read [F:MFIC]MFI0=[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(NOL)
        If !fstat
            If [F:MFIC]ECCVALMAJ<>"" : LRET = 1 : Endif
        Endif
    Endif
Endif

Close Local File [F:MFIC]
End LRET

# Issue X3-48941 - Check if audit exists for a Work order
#**----------------------------------------------------------------<br/>
#* CHECKWOAUDIT : Check if audit exists for a Work order
#**<br/>----------------------------------------------------------------<br/>
#* 0 = there is no audit  |  1 = there is audit for this WO
#**<br/>----------------------------------------------------------------
#*!
Funprog CHECKWOAUDIT()

Local Shortint LRET  :  LRET = 0

If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif

Local File MFGMATREV [MMR]

Filter [MMR] Where [MMR]MFGNUM=[M:MFG0]MFGNUM
Look [MMR]MFM0 First
If !fstat
  LRET = 1
Endif
Filter [MMR]
Close Local File [F:MMR]

End LRET

# Issue end X3-48941

