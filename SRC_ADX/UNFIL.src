#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: UNFIL
# Description : Unfilled Orders Report by Customer or Product
# Author      : Carlos R Tuason
# Date        : Sept 17, 2013
####################################################################################

####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End


####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)

  Case [L]PARAM
   When "__REQUETE"       : [L]REQNUM = val([L]VALEUR)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "sitedeb"         : [L]SSITE = [L]VALEUR
   When "sitefin"         : [L]ESITE = [L]VALEUR
   When "clientdeb"       : [L]SCUST = [L]VALEUR
   When "clientfin"       : [L]ECUST = [L]VALEUR
   When "itmrefdeb"       : [L]SPROD = [L]VALEUR
   When "itmreffin"       : [L]EPROD = [L]VALEUR
   When "rptcod"          : [L]RPTCODE = [L]VALEUR
   When "inclasgmnt"      : [L]ASNFLG = [L]VALEUR
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]REQNUM)
   When "datedeb"         :
    [L]SDATE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "datefin"         :
    [L]EDATE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
 Endcase
 Endif
Next

# Initialize the UNF table to prepare to load it with new information.
Lock [UNF]
##Delete[UNF] Where (USER=GUSER & RPTCOD=RPTCODE) | CREDAT<date$-7
Delete[UNF] Where (REQNUM=[L]REQNUM) | CREDAT<date$-7
Unlock [UNF]

Gosub BUILD_UNFILWRK

End


####################################################################################
$OUVRE

If !clalev([F:UNF])  : Local File UNFILWRK   [UNF]  : Endif
If !clalev([F:SOH])  : Local File SORDER     [SOH]  : Endif
If !clalev([F:SOQ])  : Local File SORDERQ    [SOQ]  : Endif
If !clalev([F:SOP])  : Local File SORDERP    [SOP]  : Endif
If !clalev([F:POH])  : Local File PORDER     [POH]  : Endif
If !clalev([F:POQ])  : Local File PORDERQ    [POQ]  : Endif
If !clalev([F:ORD])  : Local File ORDERS     [ORD]  : Endif
If !clalev([F:MLK])  : Local File MTOLINK    [MLK]  : Endif

Return


####################################################################################
$DECLARE

Local Char    PARAM(30),VALEUR(30)
Local Integer REQNUM, NUMLIG
Local Char    SSITE(GLONFCY),ESITE(GLONFCY),SCUST(GLONBPC),ECUST(GLONBPC),SPROD(GLONITM),EPROD(GLONITM)
Local Char    RPTCODE(1)   #  C = Customer, P = Product
Local Char    ASNFLG(1)
Local Date    SDATE,EDATE
Local Decimal OPENQTY       #  Open Quantity to Ship

Return


####################################################################################
$BUILD_UNFILWRK

# Get all of the sales order detail records that are not closed, have an open quantity,
# and have sales site, customer, product, and order date within the selection parameters
# to find a matching open purchase order for the item, and write UNFILWRK record.
Link [SOQ] With [SOH]SOH0=SOHNUM,[SOP]SOP0=SOHNUM;SOPLIN;SOQSEQ As [SOL]
& Where STOFCY>=SSITE & STOFCY<=ESITE & BPCORD>=SCUST & BPCORD<=ECUST
&     & ITMREF>=SPROD & ITMREF<=EPROD & ORDDAT>=SDATE & ORDDAT<=EDATE
&     & SOQSTA<>3 & QTY>(ALLQTY+PREQTY+OPRQTY+DLVQTY+ODLQTY) & [SOH]ORDSTA=1
& Order By ITMREF;SOHNUM

# Loop records from SO Link
For [SOL]
  Raz [ORD],[POQ],OPENQTY

  If ASNFLG = "1"
##    Link [ORD] With [MLK]MLK0(2)=STOFCY;ITMREF As [ORL]
##&   Where WIPTYP=1 & WIPSTA<>4 & MTOQTY>0 & ITMREF=[SOQ]ITMREF & WIPNUM=[SOQ]DEMNUM
##&   & VCRNUM=[MLK]DEMNUM & VCRLIN=[MLK]DEMLIN
##    For [ORL]
##      Link [POQ] With [POH]POH0=POHNUM As [POL]
##&     Where POHNUM=[MLK]RESSNUM & POPLIN=[MLK]RESSLIN & [POH]CLEFLG=1
##&     Order By EXTRCPDAT;POHNUM
##      Read [POL] First
##      If fstat : Raz [POQ] : Endif
##      Break
##    Next

    # Link [ORD],[MLK],[POQ],[POH]
    # Retrieve assigned quantity from WIP table (ORDERS[ORD]) and open PO number from demand/resource assignment table (MTOLINK[MLK])
    Link [ORD] With [MLK]MLK0(2)=STOFCY;ITMREF,[POQ]POQ0=[MLK]RESSNUM;[MLK]RESSLIN;[MLK]RESSSEQ,[POH]POH0=[MLK]RESSNUM As [ORK]
&   Where WIPTYP=1 & WIPSTA<>4 & MTOQTY>0 & ITMREF=[SOQ]ITMREF & WIPNUM=[SOQ]DEMNUM
&   & VCRNUM=[MLK]DEMNUM & VCRLIN=[MLK]DEMLIN & [POH]CLEFLG=1

    Read [ORK] First
    If fstat : Raz [ORD],[POQ] : Endif
  Endif

  # Check if its a direct order
  # 107888 : Scheduled invoices : (LD:31/05/16)
  #If [SOH]SOHCAT = 3
  If [F:SOH]SOHCAT=3 | ([F:SOH]SOHCAT=1 & [F:SOQ]DLVFLG=1)
  # 107888 : Scheduled invoices : (LD:31/05/16)
    OPENQTY = [SOQ]QTY - [SOQ]ALLQTY - [SOQ]ODLQTY - [SOQ]INVQTY - [ORD]MTOQTY
  Else
    OPENQTY = [SOQ]QTY - [SOQ]ALLQTY - [SOQ]PREQTY - [SOQ]OPRQTY - [SOQ]DLVQTY - [SOQ]ODLQTY - [ORD]MTOQTY
  Endif



  If OPENQTY > 0
    Gosub WRITE_UNFILWRK
  Endif

Next
Return


####################################################################################
$WRITE_UNFILWRK

[L]NUMLIG += 1

Look [UNF]UNF0=[L]REQNUM;GUSER;[L]RPTCODE;[L]NUMLIG
If !fstat : Return : Endif

Trbegin [UNF]

# Create new record
Raz [UNF]
[UNF]REQNUM    = [L]REQNUM
[UNF]USER      = GUSER
[UNF]RPTCOD    = [L]RPTCODE
[UNF]NUMLIG    = [L]NUMLIG
[UNF]SOHNUM    = [SOQ]SOHNUM
[UNF]SOPLIN    = [SOQ]SOPLIN
[UNF]SOQSEQ    = [SOQ]SOQSEQ
[UNF]SALFCY    = [SOQ]SALFCY
[UNF]STOFCY    = [SOQ]STOFCY
[UNF]BPCORD    = [SOQ]BPCORD
[UNF]NETPRINOT = [SOP]NETPRINOT
[UNF]CUR       = [SOH]CUR
[UNF]CHGRAT    = [SOH]CHGRAT
[UNF]POHNUM    = [POQ]POHNUM
[UNF]EXTRCPDAT = [POQ]EXTRCPDAT
[UNF]POHFCY    = [POQ]POHFCY
[UNF]PRHFCY    = [POQ]PRHFCY
[UNF]ITMREF    = [SOQ]ITMREF
[UNF]ORDDAT    = [SOQ]ORDDAT
[UNF]SHIDAT    = [SOQ]SHIDAT
[UNF]BKOQTY    = OPENQTY
[UNF]SAU       = [SOP]SAU


Write [UNF]
If fstat
    Rollback
Else
    Commit
Endif

Return

