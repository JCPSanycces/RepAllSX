#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################
# LOAD_FROM_SGW : Charge l'écran STOCHG [SCD] à partir de STOCHGW [SGW]
###############################################################################
$LOAD_FROM_SGW

Local Integer I, J
Local Char    WSTOFCY(GLONFCY)

#                                                          # hcb 110327 deb
Local Char LMSKCOU
LMSKCOU = func STKLIB.MSKDEF
If LMSKCOU = "[CHGS]"
   [M:SCD]WSTOSEQ = [M:CHGS]WSTOSEQ
Else
   [M:SCD]WSTOSEQ = evalue(LMABR+"WSTOSEQ(LLIGDOC)")
Endif
#                                                          # hcb 110327 end

#------ Se positionne dans SGW ------#
I = find([M:SCD]WSTOSEQ, [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
If I>=0
    #--- Récupération des sections ana ----------#
    Local Char    LSECE, LSECS
    If [M:SCD]STOFCY<>[M:SCD]FCYDES
        # Sauvegarde STOFCY
        WSTOFCY=[M:SCD]STOFCY
        If [M:SCD]BETCPY=1
            For J=1 To GNBDIE
                If evalue("[M:SGW]CCE"+num$(J)+"(I)")=""
                    # Forçage site destination dans STOFCY pour init section
                    [M:SCD]STOFCY = [M:SCD]FCYDES
                    Call INISEC (LSECE, "STJTRSE", J) From TRTX3CPT

                    [M:SCD]CCE(J-1) = LSECE
                    # Restitution STOFCY
                    [M:SCD]STOFCY = WSTOFCY
                Else
                    [M:SCD]CCE(J-1) = evalue("[M:SGW]CCE"+num$(J)+"(I)")
                Endif
                If evalue("[M:SGW]CCS"+num$(J)+"(I)")=""
                    Call INISEC (LSECS, "STJTRSI", J) From TRTX3CPT

                    [M:SCD]CCS(J-1) = LSECS
                Else
                    [M:SCD]CCS(J-1) = evalue("[M:SGW]CCS"+num$(J)+"(I)")
                Endif
            Next
        Else
            If GFCY<>[M:SCD]FCYDES GFCY=[M:SCD]FCYDES : Gosub CHARG_PARAM From SUBSCSA : Endif    # Ana

            # Call GETDEV([M:SCD]FCYDES) From DEVSUB
            For J=1 To GNBDIE
                If evalue("[M:SGW]CCE"+num$(J)+"(I)")=""
                    # Forçage site destination dans STOFCY pour init section
                    [M:SCD]STOFCY = [M:SCD]FCYDES
                    Call INISEC (LSECE, "STJICOE", J) From TRTX3CPT
                    [M:SCD]CCE(J-1) = LSECE
                    # Restitution STOFCY
                    [M:SCD]STOFCY = WSTOFCY
                Else
                    [M:SCD]CCE(J-1) = evalue("[M:SGW]CCE"+num$(J)+"(I)")
                Endif
            Next
            If GFCY<>[M:SCD]STOFCY GFCY=[M:SCD]STOFCY : Gosub CHARG_PARAM From SUBSCSA  : Endif    # Ana

           # Call GETDEV([M:SCD]STOFCY) From DEVSUB
            For J=1 To GNBDIE
                If evalue("[M:SGW]CCS"+num$(J)+"(I)")=""
                    Call INISEC (LSECS, "STJICOI", J) From TRTX3CPT
                    [M:SCD]CCS(J-1) = LSECS
                Else
                    [M:SCD]CCS(J-1) = evalue("[M:SGW]CCS"+num$(J)+"(I)")
                Endif
            Next
        Endif
    Endif

    While I<[M:SGW]NBLIG & [M:SCD]WSTOSEQ=[M:SGW]WSTOSEQ(I)
                If I>0 & [M:SCD]WSTOSEQ=[M:SGW]WSTOSEQ(I-1) & [M:SGW]WLIGDET(I-1)=[M:SGW]WLIGDET(I) & [M:SGW]WSTOSEQIND(I) = 0   # hcb 110327
            [M:SCD]SERNUMF([M:SCD]NBLIG)   = [M:SGW]WSERNUMF(I)
            [M:SCD]QTYPCUDES([M:SCD]NBLIG) += [M:SGW]WQTYPCUDES(I)
            [M:SCD]QTYSTUDES([M:SCD]NBLIG) += [M:SGW]WQTYSTUDES(I)
        Else
            [M:SCD]PCUDES([M:SCD]NBLIG)    = [M:SGW]WPCUDES(I)
            [M:SCD]QTYPCUDES([M:SCD]NBLIG) = [M:SGW]WQTYPCUDES(I)
            [M:SCD]COEDES([M:SCD]NBLIG)    = [M:SGW]WCOEDES(I)
            Local Char LUSCAV
            Local Char LFMT
            Local Integer LMODIF
            Local Decimal LCOE
            Call CTLUOM([M:SCD]ITMREF,3,"",[M:SCD]PCUDES([M:SCD]NBLIG),LCOE, LUSCAV, LFMT, LMODIF) From STKACT
            If LMODIF=2
                Diszo [M:SCD]COEDES([M:SCD]NBLIG)
            Endif
            If GIMPORT                                            # hcb X3-59992
               Raz LFMT                                           # hcb X3-59992
            Endif                                                 # hcb X3-59992
            [M:SCD]QTYSTUDES([M:SCD]NBLIG) = [M:SGW]WQTYSTUDES(I)
            [M:SCD]STADES([M:SCD]NBLIG)    = [M:SGW]WSTADES(I)
            [M:SCD]QLYCTLFLG([M:SCD]NBLIG) = [M:SGW]QLYCTLFLG(I)
            If dim([M:SCD]SERNUM)>0
                [M:SCD]SERNUM([M:SCD]NBLIG)    = [M:SGW]WSERNUM(I)
                [M:SCD]SERNUMF([M:SCD]NBLIG)   = [M:SGW]WSERNUMF(I)
            Endif
            If dim([M:SCD]WRHDES)>0
                [M:SCD]WRHDES([M:SCD]NBLIG)    = [M:SGW]WWRHDES(I)
            Endif
            If dim([M:SCD]LPNNUMDES)>0                                          # hcb X3-67989
                [M:SCD]LPNNUMDES([M:SCD]NBLIG) = [M:SGW]WLPNNUMDES(I)           # hcb X3-67989
            Endif                                                               # hcb X3-67989
            If dim([M:SCD]LOCTYPDES)>0
                [M:SCD]LOCTYPDES([M:SCD]NBLIG) = [M:SGW]WLOCTYPDES(I)
            Endif
            If dim([M:SCD]LOCDES)>0
                [M:SCD]LOCDES([M:SCD]NBLIG)    = [M:SGW]WLOCDES(I)
            Endif
            If dim([M:SCD]WLOCSEQ)>0
                [M:SCD]WLOCSEQ([M:SCD]NBLIG)    = [M:SGW]WLOCSEQ(I)
            Endif
       #                                                                             # hcb 110327 deb
            If dim([M:SCD]WSTOSEQIND)>0
               [M:SCD]WSTOSEQIND([M:SCD]NBLIG)    = [M:SGW]WSTOSEQIND(I)
            Endif
#                                                                                    # hcb 110327 fin
            If dim([M:SCD]PALNUMDES)>0
                [M:SCD]PALNUMDES([M:SCD]NBLIG)    = [M:SGW]WPALNUMDES(I)
            Endif
            If dim([M:SCD]CTRNUMDES)>0
                [M:SCD]CTRNUMDES([M:SCD]NBLIG)    = [M:SGW]WCTRNUMDES(I)
            Endif
            #--- Bug 83135
            If dim([M:SCD]LBEFMT)>0
                [M:SCD]LBEFMT([M:SCD]NBLIG)    = LFMT
            Endif
            #---
            # Transfert zones de l'écran STOCHGW vers l'écran STOCHG
            GPOINT="SGW_SCD" : Gosub ENTREE From EXEFNC

        Endif
        If [M:SCD]NBLIG=0 | [M:SCD]WSTOSEQ=[M:SGW]WSTOSEQ(I-1) & [M:SGW]WSTOCOU(I)<>[M:SGW]WSTOCOU(I-1)
            [M:SCD]WSTOCOU([M:SCD]NBCOU)  = [M:SGW]WSTOCOU(I)
            [M:SCD]WLIGDET2([M:SCD]NBCOU) = [M:SCD]NBLIG
            [M:SCD]NBCOU += 1
        Endif
        If I+1>=[M:SGW]NBLIG
&        | [M:SCD]WSTOSEQ<>[M:SGW]WSTOSEQ(I+1)
&        | [M:SCD]WSTOSEQ=[M:SGW]WSTOSEQ(I+1) & [M:SGW]WLIGDET(I)<>[M:SGW]WLIGDET(I+1)
&        | [M:SGW]WSTOSEQIND(I) <> 0                                                     # hcb 110327
            [M:SCD]NBLIG += 1
        Endif
        I+=1
    Wend
Endif
If [F:ITM]SERMGTCOD>1
    Actzo [M:SCD]SERNUM
    If [F:ITM]SERMGTCOD=3
        Diszo [M:SCD]SERNUM(0)    #Le premier n° de série est fixé
    Endif
    If [F:ITM]SERMGTCOD=3 | [M:SCD]BETCPY=2
        Diszo [M:SCD]PCUDES,COEDES
    Endif
Endif

Return


###############################################################################
# LOAD_FROM_STJ : Charge l'écran STOCHG [SCD] à partir du fichier STOJOU [STJ]
###############################################################################
$LOAD_FROM_STJ

    If evalue(LMABR+"BETFCYCOD")=2
       WFCY=[M:SCD]FCYDES
    Else
       WFCY=[M:SCD]STOFCY
    Endif
    For [STJ]STJ1 Where STOFCY = WFCY
&                     & VCRTYP = [M:SCD]VCRTYP
&                     & VCRNUM = [M:SCD]VCRNUM
&                     & VCRLIN = [M:SCD]VCRLIN
&                     & REGFLG = 1
&                     & QTYSTU > 0

        [M:SCD]PCUDES([M:SCD]NBLIG)        = [F:STJ]PCU
        [M:SCD]QTYPCUDES([M:SCD]NBLIG)     = [F:STJ]QTYPCU
        [M:SCD]COEDES([M:SCD]NBLIG)        = [F:STJ]PCUSTUCOE
        [M:SCD]QTYSTUDES([M:SCD]NBLIG)     = [F:STJ]QTYSTU
        [M:SCD]STADES([M:SCD]NBLIG)        = [F:STJ]STA
        If dim([M:SCD]SERNUM)>0
        #                                                                          # hcb 110327 deb
           If [F:ITM]SERMGTCOD = 4
              [M:SCD]SERNUM ([M:SCD]NBLIG) = [F:STJ]SERDEB
              [M:SCD]SERNUMF([M:SCD]NBLIG) = [F:STJ]SERFIN
           Else
#                                                                          # hcb 110327 end
              [M:SCD]SERNUM([M:SCD]NBLIG)     = [F:STJ]SERNUM
              [M:SCD]SERNUMF([M:SCD]NBLIG)    = [F:STJ]SERNUM
           Endif                                                           # hcb 110327
        Endif
        If dim([M:SCD]WRHDES)>0
           [M:SCD]WRHDES([M:SCD]NBLIG)     = [F:STJ]WRH
        Endif
        If dim([M:SCD]LPNNUMDES)>0                                  # hcb X3-67989
           [M:SCD]LPNNUMDES([M:SCD]NBLIG)  = [F:STJ]LPNNUM          # hcb X3-67989
        Endif                                                       # hcb X3-67989
        If dim([M:SCD]LOCDES)>0
           [M:SCD]LOCDES([M:SCD]NBLIG)     = [F:STJ]LOC
        Endif
        If dim([M:SCD]LOCTYPDES)>0
            If [F:STC]STOFCY<>[F:STJ]STOFCY | [F:STC]LOC <> [F:STJ]LOC
                Read [STC]STC0=[F:STJ]STOFCY;[F:STJ]LOC
            Endif
            [M:SCD]LOCTYPDES([M:SCD]NBLIG) = [F:STC]LOCTYP
        Endif
        # hcb 110505 28601 deb
        If dim([M:SCD]PALNUMDES)>0
           [M:SCD]PALNUMDES([M:SCD]NBLIG)  = [F:STJ]PALNUM
        Endif
        If dim([M:SCD]CTRNUMDES)>0
           [M:SCD]CTRNUMDES([M:SCD]NBLIG)  = [F:STJ]CTRNUM
        Endif
        # hcb 110505 28601 fin

        #--- PE 60717
        # Transfert zones de l'enregistrement STOJOU vers l'écran STOCHG
        GPOINT="STJ_SCD" : Gosub ENTREE From EXEFNC

        # Récupération des sections analytiques d'entrée
        If [M:SCD]NBLIG=0 & evalue(LMABR+"BETFCYCOD")=2
           For J=1 To GNBDIE
              [M:SCD]CCE(J-1) = [F:STJ]CCE(J-1)
           Next
        Endif
        [M:SCD]NBLIG += 1
    Next

    # Récupération des sections analytiques de sortie
    If evalue(LMABR+"BETFCYCOD")=2
       For [STJ]STJ1 Where STOFCY = [M:SCD]STOFCY
&                        & VCRTYP = [M:SCD]VCRTYP
&                        & VCRNUM = [M:SCD]VCRNUM
&                        & VCRLIN = [M:SCD]VCRLIN
&                        & REGFLG = 1
&                        & QTYSTU < 0
          For J=1 To GNBDIE
             [M:SCD]CCS(J-1) = [F:STJ]CCE(J-1)
          Next
          Break
       Next
    Endif
    Diszo [M:SCD]20
    Diszo [M:SCD]MVTDES
Return

##################################################
$MAJ_PECQTY
    [M:SCD]PECQTYSTU     = sum([M:SCD]QTYSTUDES)
    [M:SCD]PECQTYPCU     = sum([M:SCD]QTYSTUDES)/[M:SCD]PCUSTUCOE
    Affzo [M:SCD]PECQTYSTU,PECQTYPCU
Return

##################################################
# Contrôle qu'on ne dépasse pas la quantité de départ
# Et si l'article est géré en n° série E/S recalcule le n° série fin
##################################################
Subprog CTRNEWQTY( PNOL, PQTYN, PCOEN )
Value Integer PNOL
Value Decimal PQTYN
Value Decimal PCOEN

Local Integer I
Local Decimal LQTYSTUN
Local Integer LRET
Local Char LSERF(GLONSER)

LQTYSTUN = PQTYN*PCOEN

If sum([M:SCD]QTYSTUDES)-[M:SCD]QTYSTUDES(PNOL) + LQTYSTUN > [M:SCD]QTYSTU
    mkstat = 2
    GMESSAGE = mess( 393, 199, 1)
Elsif [F:ITM]SERMGTCOD=3
    LSERF=[M:SCD]SERNUM(PNOL)
    For I=2 To LQTYSTUN
        Call PLUS_UN(LSERF,LSERF,LRET) From STKLIB
    Next
    [M:SCD]SERNUMF(PNOL) = LSERF
    Affzo [M:SCD]SERNUMF(PNOL)
Endif
End

##################################################
Subprog CTRSERNUM( PNOL, PSER, PSERF )
Value    Integer PNOL
Value    Char    PSER
Variable Char    PSERF

Local Integer I
Local Integer LRET

Local Char LLOC(GLONLOC)
Local Char LLOT(GLONLOT)
Local Char LSLO(GLONSLO)
#              hcb 120505 38601 deb
Local Char LPAL(GLONPAL)
Local Char LCTR(GLONCTR)
Local Char LSF1(GLONSF1)
Local Char LSF2(GLONSF2)
Local Char LLPN(GLONLPN)                                     # hcb X3-77043
Raz LLOC, LLOT, LSLO, LPAL, LCTR, LSF1, LSF2, LLPN           # hcb X3-77043
If dim([M:SCD]LPNNUM)>0                                      # hcb X3-77043
   LLPN = [M:SCD]LPNNUM                                      # hcb X3-77043
Endif                                                        # hcb X3-77043
#                                                  # hcb x3-64421 deb
If dim([M:SCD]LOC)>0
   LLOC = [M:SCD]LOC
Endif
If dim([M:SCD]LOT)>0
   LLOT = [M:SCD]LOT
Endif
If dim([M:SCD]SLO)>0
   SLO = [M:SCD]SLO
Endif
#                                                  # hcb x3-64421 fin
If dim([M:SCD]PALNUM)>0
   LPAL = [M:SCD]PALNUM
Endif
If dim([M:SCD]CTRNUM)>0
   LCTR = [M:SCD]CTRNUM
Endif
#              hcb 120505 38601 fin
If dim([M:SCD]STOFLD1)>0
   LSF1 = [M:SCD]STOFLD1
Endif
If dim([M:SCD]STOFLD2)>0
   LSF2 = [M:SCD]STOFLD2
Endif

    PSERF = PSER
    Repeat
        I+=1
        # Est-ce que le numéro est utilisé dans SCD?
        F = sigma(0, [M:SCD]NBLIG-1, ( indcum<>PNOL )
&                                  & ( len([M:SCD]SERNUM(indcum)) = len(PSERF) )
&                                  & ( [M:SCD]SERNUM(indcum)  <= PSERF )
&                                  & ( [M:SCD]SERNUMF(indcum) >= PSERF ) )
        If F
            LRET=1
        Else
#                         rajout LLPN                                             # hcb X3-77043
            Call CTRSERNUM([M:SCD]ITMREF,[M:SCD]STOFCY,PSERF,[M:SCD]WSTOSEQ,
&                          [M:SCD]PCU,[M:SCD]STA,LLOC,LLOT,LSLO,LPAL,LCTR,
&                          LSF1,LSF2,LLPN,0,LRET) From SUBSCSB
        Endif
        Case LRET
            When 0 :
                If I<[M:SCD]QTYSTUDES(PNOL)
                    Call PLUS_UN( PSERF, PSERF, LRET ) From STKLIB
                Endif
            When 1 :
                GMESSAGE = PSERF-":"-mess( 32, 184, 1) # N° de série déjà utilisé
                Raz PSERF
            When 2 :
                GMESSAGE = PSERF-":"-mess( 43, 196, 1 )    # N° de série inexistant
                Raz PSERF
            When 3 :
                GMESSAGE = PSERF-":"-mess( 367, 199, 1 )    # Pas de stock disponible
                Raz PSERF
            When 4 :
                GMESSAGE = PSERF-":"-mess( 31, 184, 1 )    # Caractéristiques stock incorrectes
                Raz PSERF
        Endcase
    Until PSERF="" | I>=[M:SCD]QTYSTUDES(PNOL)

End



########################################################################
# AVANT_ENRCHG  Controle enregistrement
########################################################################
# appeler depuis TRTSTOCHG (avant_enr) et l import STKIMPC
#
########################################################################
Subprog AVANT_ENRCHG
Local Integer  LRET
Local Shortint WRET
Local Integer  LLIG
Local Integer  J, K, L                      # hcb X3-67989
Local Char     MES(255)

#---------------------------#
# Vérification que toutes les lignes saisies peuvent être entrées dans STOCHGW
#---------------------------#
If [M:SGW]NBLIG+[M:SCD]NBLIG > dim([M:SGW]WSTOSEQ)
    Call ERREUR(mess(36,184,1)+"\"+mess(353,199,1)) From GESECRAN
    mkstat = 2
    End
Endif

#---------------------------#
# controle saisie lignes entrées
#---------------------------#
LRET = 0
For LLIG = 0 To [M:SCD]NBLIG-1
    Call CTRLIG("SCD",LLIG, LRET) From SUBSCSB
    If LRET > 0
        MES  = mess(93,100,1)+":"+num$(LLIG+1)+"\"
        If LRET = 256
            MES += mess(67,184,1)+"\"    # Ligne stock en inventaire
        Else
            MES += mess(7,111,1) +":\"
            If mod(LRET ,2)>=1
                MES += mess(23,197,1)+"\"    # Unités
            Endif
            If mod(LRET ,4)>=2
                MES += mess(9,184,1)+"\"    # Quantité doit être >0
            Endif
            If mod(LRET ,8)>=4
                MES += mess(398,198,1)+"\"    # Coeff
            Endif
            If mod(LRET ,16)>=8
                MES += mess(24,197,1)+"\"    # Statut
            Endif
            If mod(LRET ,32)>=16 | mod(LRET ,64)>=32
                MES += mess(2,181,1)+"\"    # Emplacement / Type Emplacement
            Endif
            If mod(LRET ,128)>=64
                MES += mess(47,197,1)        # N° de série non saisi
            Endif
            If mod(LRET ,256)>=128
                MES += mess(180,199,1)        # Pas de mouvement de stock saisi
            Endif
#                                                                                       # hcb 110327 deb
            If mod(LRET ,1024)>=512
                MES += mess(246,199,1)        # # Le nb de no série ne correspond pas à la qté à traiter
            Endif
#                                                                                       # hcb 110327 end

        Endif
        mkstat = 2
    Endif
    If LRET : Break : Endif

#                                                             # hcb X3-67989 deb
# controle meme emplacement pour chaque contenant
    If find([F:SRT]BETFCYCOD,2,5) & [F:ITFD]LPNMGTCOD = 2 & [F:SRT]CHGEMPCOD = 2 & [M:SCD]LPNNUMDES(LLIG) <> ""
#--- Contrôle du mono-emplacement par LPN
       K=sigma(LLIG+1,[M:SCD]NBLIG-1,1*([M:SCD]LPNNUMDES(indcum)=[M:SCD]LPNNUMDES(LLIG)))
       L=sigma(LLIG+1,[M:SCD]NBLIG-1,1*([M:SCD]LPNNUMDES(indcum)=[M:SCD]LPNNUMDES(LLIG)
&                & [M:SCD]LOCDES(indcum)=[M:SCD]LOCDES(LLIG)))
       If K<>L
          Call ERREUR(func AFNC.MES2(mess(521,184,1),[M:SCD]LPNNUMDES(LLIG),[M:SCD]LOCDES(LLIG))) From GESECRAN
          mkstat = 2
          Break
       Endif
    Endif
#                                                                                         # hcb X3-67989 deb

Next
#If mkstat = 2                                                                             # hcb X3-67989
#   End                                                                                    # hcb X3-67989
#Endif                                                                                     # hcb X3-67989

If dim([M:SCD]SERNUMDEP)>0 & mkstat <> 2 # hcb X3-67989
   If [M:SCD]SERNUMDEP<>""
      Local Char LTABSER(GLONSER)([M:SCD]NBLIG)
      Local Char LTABSERF(GLONSER)([M:SCD]NBLIG)
      For J=0 To [M:SCD]NBLIG-1
          LTABSER(J)  = [M:SCD]SERNUM(J)
          LTABSERF(J) = [M:SCD]SERNUMF(J)
      Next
      Sorta LTABSER, LTABSERF
      PSER  = LTABSER(0)
      PSERF = LTABSERF(0)
      For J=1 To [M:SCD]NBLIG-1
          Call PLUS_UN(LTABSERF(J-1),LTABSERF(J-1), LRET) From STKLIB
          If LTABSER(J) <> LTABSERF(J-1)
             LRET=1
             MES = mess(35,184,1)    # Suite dicontinue des n° de série
          Else
             PSERF = LTABSERF(J)
          Endif
      Next
   Endif
Endif

If LRET
    Call ERREUR(MES) From GESECRAN  # Ligne incomplete
    mkstat = 2
    End
Endif

#---------------------------#
# Si quantité saisie nulle
#---------------------------#
If sum([M:SCD]QTYSTUDES)=0
    # Message d'erreur, car il est impossible de supprimer une ligne en cours de création
    Call ERREUR(mess(9,184,1)) From GESECRAN    # La quantité dans le détail doit être différente de 0
    mkstat = 2
    End
Endif

End


########################################################################
# ENR_CHG  Controle enregistrement
########################################################################
# appeler depuis TRTSTOCHG (enr) et l import STKIMPC
#
########################################################################
Subprog ENR_CHG(LABR,LLIGDOC)
Value Char    LABR
Value Integer LLIGDOC
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Local Char    LPCU(GLONUOM)
Local Decimal LCOEF
Local Char    LSTA(GLONSTA)
Local Char    LWRH(GLONWRH)
Local Char    LLOCTYP(GLONTLO)
Local Char    LLOC(GLONLOC)
Local Char    LSER(GLONSER), LSERF(GLONSER)
Local Integer LQLYFLG
Local Char    LMABR(10)
Local Char    LLPN(GLONLPN)               # hcb X3-77043
Local Char    LPAL(GLONPAL)               # hcb 110505 28601
Local Char    LCTR(GLONCTR)               # hcb 110505 28601
Raz LPAL, LCTR                            # hcb 110505 28601
Local Integer I                           # hcb 110505 28601
LMABR = "[M:"+LABR+"]"

Default Mask LMABR

LPCU    = string$( !!( sigma(I=0,[M:SCD]NBLIG-1,([M:SCD]PCUDES(0)=[M:SCD]PCUDES(I))) = [M:SCD]NBLIG), [M:SCD]PCUDES(0))
LCOEF   = !!( sigma(I=0,[M:SCD]NBLIG-1,([M:SCD]COEDES(0)=[M:SCD]COEDES(I))) = [M:SCD]NBLIG)* [M:SCD]COEDES(0)

# Il ne faudrait pas effacer les réservations d'emplacements (puisqu'elles sont correctes
# mais pour l'instant c'est comme ça!
# Issue 120553 - 2017-01-17 by CCC : No need to reset price
#Call DELSTOCHGW(LABR, [M:SCD]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
Call DELSTOCHGW2(LABR, [M:SCD]STOFCY, LLIGDOC, LLIGDOC, 0, 0, LRET) From SUBSCSB
LSEQ = [M:SCD]WSTOSEQ
Call FILLCHGW("SCD", 0, [M:SCD]NBLIG, LSEQ, [M:SCD]STOFCY, LRET, LQTYSTU) From SUBSCSB


# TS le 07.05.04
# La ligne chargée n'est pas correcte
If LRET<>0 | GERR=2
   Assign LMABR+"WSTOFLG(LLIGDOC)" With 0
Else
   Assign LMABR+"WSTOFLG(LLIGDOC)" With 1
Endif

If LQTYSTU=0
   Call ERREUR(mess(367,199,1)) From GESECRAN
Elsif LQTYSTU<[M:SCD]PECQTYSTU
   Call MESSAGE( mess(275,198,1)-":"-num$(LQTYSTU)-"/"-num$([M:SCD]PECQTYSTU) ) From GESECRAN
Endif
#                                         rajout LLPN            # hcb X3-77043
Call RECCHG_M( [M:SCD]WSTOSEQ, LSTA, LLOCTYP, LLOC, LSER, LSERF, LQLYFLG, LABR, LLIGDOC, LPAL, LCTR, LLPN) From SUBSCSB
Assign LMABR+"STADES(LLIGDOC)"    With LSTA
If evalue("dim("+LMABR+"WRHDES)")>0
   Assign LMABR+"WRHDES(LLIGDOC)"    With LWRH
Endif
If evalue("dim("+LMABR+"LPNNUMDES)")>0                           # hcb X3-77043
   Assign LMABR+"LPNNUMDES(LLIGDOC)" With LLPN                   # hcb X3-77043
Endif                                                            # hcb X3-77043
If evalue("dim("+LMABR+"LOCTYPDES)")>0
   Assign LMABR+"LOCTYPDES(LLIGDOC)" With LLOCTYP       # hcb 28638
Endif
If evalue("dim("+LMABR+"LOCDES)")>0
   Assign LMABR+"LOCDES(LLIGDOC)"    With LLOC          # hcb 28638
Endif
If evalue("dim("+LMABR+"SERNUM)")>0
   Assign LMABR+"SERNUM(LLIGDOC)"    With LSER
Endif
If evalue("dim("+LMABR+"SERNUMF)")>0
   Assign LMABR+"SERNUMF(LLIGDOC)"   With LSERF
Endif
If evalue("dim("+LMABR+"QLYCTLFLG)")>0
   Assign LMABR+"QLYCTLFLG(LLIGDOC)" With LQLYFLG
Endif
If evalue("dim("+LMABR+"MVTDES)")>0
   Assign LMABR+"MVTDES(LLIGDOC)" With [M:SCD]MVTDES
Endif
If evalue("dim("+LMABR+"PALNUMDES)")>0                     # hcb 110505 28601
   Assign LMABR+"PALNUMDES(LLIGDOC)"    With LPAL          # hcb 110505 28601
Endif                                                      # hcb 110505 28601
If evalue("dim("+LMABR+"CTRNUMDES)")>0                     # hcb 110505 28601
   Assign LMABR+"CTRNUMDES(LLIGDOC)"    With LCTR          # hcb 110505 28601
Endif                                                      # hcb 110505 28601

Gosub MAJ_LIG_DOC From SUBSCSB

End

