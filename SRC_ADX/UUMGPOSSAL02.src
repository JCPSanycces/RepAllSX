#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# UUMGPOSSAL02   Moulinette de Migration des contremarques   Module Ventes #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0 :  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSSAL02") From LECFIC
  Endif

  Call MAJ_UUMGPOSSAL02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

###################################################################################
## GH 20/05/2014 bug 100128

Subprog RAZ_UUMGPOSSAL02(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(4)<>2 : End : Endif

Call MIGRAZKEY(DOSSIER,"UUMGPOSSAL02",ERR) From TRTMIG
End

###################################################################################
Subprog MAJ_UUMGPOSSAL02(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER)
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 106947 - 20150811 by LD

If [F:ADS]MODULE(4)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# 90029
#----- Récupération du n° de version
Local Char CVERSION(3)
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL02",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

# Issue 106947 - 20150811 by LD : Migration of historic folder
Gosub MIG_OUVRE From TRTMIG
# Issue 106947 - 20150811 by LD

# La moulinette de postmigration concerne la création des affectations pour les contremarques
# Elle doit se faire uniquement lors du passage en V6
# Gbn.X3-15185 Modification of the execution condition. This process has to be executed even if the source folder
#              version is greater than V6.
#If VERSION>=30
#    Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL02",3,ERR) From TRTMIG : #3=Terminée
#    End
#Endif

Call MIGSTKENDFLG (DOSSIER,"UUMGPOSSAL02",2,ERR) From TRTMIG : #2=En cours

#Gbn.X3-15185
If VERSION<GMIGX3VER60
    Call EXE_UTIGPA25(DOSSIER,0) From UTIGPA25
Endif
If VERSION<GMIGX3VER112
    Call EXE_UTIVEN82(DOSSIER) From UTIVEN82
Endif

Call MIGTRTEND (DOSSIER,"UUMGPOSSAL02") From TRTMIG
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGPOSSAL02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGPOSSAL02(APPLI)
End

