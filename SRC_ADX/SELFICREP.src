GBIDC1 = "/home/mb/patch_amk"
GBIDC1 = "/home/mbeinat"
#GBIDC1 = "#@C:\temp"
#GBIDC1 = "#@"
Raz GNBMASKOUV
Call SELFICREP(GBIDC1)
Infbox num$(GSTATUT)-GBIDC1
End
