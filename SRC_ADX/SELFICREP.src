###########################################################################
$ACTION
Case ACTION
 When "TITRE"       : Gosub TIT
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "FINSAI"      : Gosub FINSAI
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return

#########################
$TRT_DIV
Case TRAIT
 When "CONTFIC" : Gosub CONTFIC
Endcase
Return

###########################
$CONTFIC
If vireblc(VALEUR,4)<>VALEUR
# Call ERREUR(mess(71,133,1)) From GESECRAN : # Caractère <ESPACE> interdit
# mkstat = 1
Endif
Return

###############################################
## Sélection d'un chemin de fichier          ##
###############################################

Subprog SELFICREP(VALEUR)
Variable Char    VALEUR()
Local Integer OLD
OLD = 0
Goto F
Subprog SELFICREPOLD(VALEUR)
Variable Char    VALEUR()
Local Integer OLD
OLD = 1
$F
Local Char PARAM(250)(1..2) , OGACTION(20),PARAM2(250)(1..1)
GACTION = "SELFICREP"
If left$(VALEUR,1)="#" & (GRELCLI>="15c.007" or GBROWS) & !OLD
 For PREF="#@","#"
  If left$(VALEUR,len(PREF))=PREF
   VALEUR = right$(VALEUR,len(PREF)+1) : Break
  Endif
 Next PREF
 PARAM(1) = "1"
Endif
PARAM(2) = num$(OLD)
If GFUSION = 0
  Call SAISIE_CHAR(VALEUR,PARAM,"DFICREP","SELFICREP","") From GSAISIE
Else
   GACTION = "ASELFILFLD"
   Call SAISIE_CHAR(VALEUR,PARAM2,"ASELHIERA","ASELHIERA","") From GSAISIE
   #GACTION = "ASYRVOLFIL"
   #Call SAISIE_CHAR(VALEUR,PARAM,"DSYRFICREP","ASYRVOLFIL","") From GSAISIE
Endif
GACTION = OGACTION
End

$AVANT_OUVRE
If GFUSION
 # BOITE = "DSYRFICREP"
 #GBOITE = BOITE
 # PROG = "ASYRVOLFIL"
  BOITE = "ASELHIERA"
  GBOITE = BOITE
  PROG = "ASELHIERA"
Endif
Return

###############################################
## Sélection d'un chemin de répertoire       ##
###############################################

Subprog SELREPREP(VALEUR)
Variable Char    VALEUR()
Local Integer OLD
OLD = 0
Goto R
Subprog SELREPREPOLD(VALEUR)
Variable Char    VALEUR()
Local Integer OLD
OLD = 1
$R
Local Char PARAM(250)(1..3) , OGACTION(20)
GACTION = "SELREPREP"
If left$(VALEUR,1)="#" & (GRELCLI>="15c.007" or GBROWS) & !OLD
 For PREF="#@","#"
  If left$(VALEUR,len(PREF))=PREF
   VALEUR = right$(VALEUR,len(PREF)+1) : Break
  Endif
 Next PREF
 PARAM(1) = "1"
Endif
PARAM(2) = num$(OLD)
Call SAISIE_CHAR(VALEUR,PARAM,"DFICREP","SELFICREP","") From GSAISIE
GACTION = OGACTION
End

###########################################################################
$APRES_MODIF
Case zoncou
 When "REPVISU"
  If [M]MACHINE<>"" & !instr(1,zc,"@")
   zc = [M]MACHINE+"@"+zc
  Endif
  VALEUR = zc
  Effzo 5,10
  Gosub OUVRE
  Gosub DEBUT
  zc = [M]REPVISU
Endcase
Return

###########################################################################
$TIT
Local Integer ONLYREP
Case GACTION
 When "SELREPREP" : [L]ONLYREP = 1 : TIT = mess(206,124,1) : # Sélection répertoire
 When Default     : [L]ONLYREP = 0 : TIT = mess(122,124,1) : # Sélection fichier
Endcase
If instr(1,VALEUR,"@")
 TIT -= "("+left$(VALEUR,instr(1,VALEUR,"@")-1)+")"
Endif
Return

###########################################################################
$OK
VALEUR  = [M]REPREP([M]LIGSEL)
If right$(VALEUR,len(VALEUR))<>SEP
 VALEUR += SEP
Endif
VALEUR += vireblc([M]REPERT([M]LIGSEL),2)+SEP
If filinfo(filpath(VALEUR+[M]FICTEST,"","","","",[M]MACHINE),0)>0
 VALEUR += [M]FICTEST
Endif
If [M]MACHINE<>"" & !instr(1,VALEUR,"@")
 VALEUR = [M]MACHINE+"@"+VALEUR
Endif
Return

###########################################################################
$FINSAI
mkstat = 2
Return

###########################################################################
$OUVRE
Local Integer STAT , OLD
Local Char    PREF(2)
OLD = val(PARAM(2))
If PARAM(1)="1"
 If left$(VALEUR,2)="#@"
  VALEUR = right$(VALEUR,3)
 Endif
 Call EXICLI(VALEUR,STAT) From ORDSYS
 FIN = 1 : Return
Endif
If left$(VALEUR,2)="#@" & (GRELCLI>="15c.007" or GBROWS) & !OLD
 VALEUR = right$(VALEUR,3)
 FIN = 1 : Return
Endif
Return

###########################################################################
$DEBUT
Local Char     RACINE(GDIMFIC) , SEP(1)
Local Char     NOMFIC(GDIMFIC) , FICTEST(GDIMFIC)
Local Char     EXT(1) , REPERT(GDIMFIC) , EXTFIC(GDIMFIC) , REPSEL(GDIMFIC)
Local Char     REPSEL(GDIMFIC), REPBASE(GDIMFIC), REPFIC(GDIMFIC)
Local Char     L_MACHINE(GDIMFIC)
Local Char     L_OS(250)(1..3)
Local Integer  I , J , K , L

NOMFIC = VALEUR
Call MACHINE(NOMFIC,L_MACHINE,REPERT) From ORDSYS
Call GET_OS(L_MACHINE,L_OS) From ORDSYS

Case L_OS
 When "dos"
  SEP = "\"
  Case L_MACHINE
   When "#"
    REPFIC = REPERT
    If mid$(REPFIC,2,1)=":"
     RACINE = left$(REPERT,2)
    Else
     RACINE = left$(L_OS(3),2)
    Endif
   When Default
    If mid$(REPERT,2,1)=":"
     REPFIC = REPERT
     RACINE = left$(REPERT,2)
    Else
     REPFIC = filpath("","","","","",L_MACHINE)
     If mid$(REPFIC,2,1)=":"
      RACINE = left$(REPFIC,2)
     Else
      RACINE = left$(L_OS(3),2)
     Endif
    Endif
  Endcase
 When "unix"
  SEP = "/"
  REPFIC = REPERT
  RACINE = "/"
Endcase

Raz [M]
[M]MACHINE = L_MACHINE
[M]OS      = L_OS
[M]FORFIC  = "K:30X>220X"
[M]FORREP  = "K:30X>220X"
[M]ONLYREP = [L]ONLYREP

If [M]ONLYREP
 Titcol [M]NBFIC mess(116,139,1) For FICHIER : # Répertoires
Endif

REPBASE = RACINE
Call EXISTE(NOMFIC,K) From ORDSYS
If K=2 & right$(NOMFIC,len(NOMFIC))<>SEP
 NOMFIC += SEP
 REPERT += SEP
 REPFIC += SEP
Endif
Call LISREP([M]OS,[M]MACHINE,REPBASE,[M]NBREP,[M]REPERT)
Raz [M]LIGSEL
I = instr(1,NOMFIC,SEP)
J = instr(I+1,NOMFIC,SEP)
If I
 If J
  REPSEL = seg$(NOMFIC,I+1,J-1)
  NOMFIC = right$(NOMFIC,J+1)
 Else
  REPSEL = right$(NOMFIC,I+1)
 Endif
 K = 0
 For L=0 To [M]NBREP-1
  If toupper(REPSEL)=toupper([M]REPERT(L))
   K = L : Break
  Endif
 Next L
 If K>=0 : [M]LIGSEL = K : Endif
Endif
For I=0 To [M]NBREP-1
 [M]NIVEAU(I) = 0
 [M]REPREP(I) = RACINE
Next I
J = instr(1,NOMFIC,SEP)
While J<>0
 nolign = [M]LIGSEL+1
 Gosub DEPLIE
 REPSEL = left$(NOMFIC,J-1)
 NOMFIC = right$(NOMFIC,J+1)
 OK = 0
 For I=[M]LIGSEL+1 To [M]NBREP-1
  If toupper(REPSEL)=vireblc(toupper([M]REPERT(I)),2)
   OK = 1 : Break
  Endif
 Next I
 If OK : [M]LIGSEL = I : Endif
 J = instr(1,NOMFIC,SEP)
Wend
If [M]NBREP>0
 nolign = [M]LIGSEL+1
 Gosub OUVREP
 Affzo
 If NOMFIC<>""
  nolign = find(NOMFIC,[M]FICHIER)
 Endif
 If NOMFIC<>"" & nolign<>0
  Gosub SELFIC
  zonsui = "NBFIC("+num$([M]LIGFIC)+")"
 Else
  zonsui = "NBREP("+num$([M]LIGSEL)+")"
 Endif
Endif
Raz GMODIF
Return

#####################################################################
$SELFIC
[M]FORFIC = "Kc:30X>220X"
pcolor = GCOUL(0)
Affzo [M]FICHIER([M]LIGFIC)
If nolign<>0
 [M]LIGFIC  = nolign-1
 [M]FICTEST = vireblc([M]FICHIER([M]LIGFIC),2)
 pcolor = GCOUL(2)
 Affzo [M]FICHIER([M]LIGFIC)
Endif
[M]FORFIC = "K:30X>220X"
Return

#####################################################################
$SELREP
[M]FORREP = "Kc:30X>220X"
pcolor = GCOUL(0)
Affzo [M]REPERT([M]LIGSEL)
pcolor = GCOUL(2)
Affzo [M]REPERT([M]NEWSEL)
[M]FORREP = "K:30X>220X"
[M]FORFIC = "Kc:30X>220X"
pcolor = GCOUL(0)
Affzo [M]FICHIER([M]LIGFIC)
[M]FORFIC = "K:30X>220X"
Return

#####################################################################
$OUVREP
[M]NEWSEL = nolign-1
REPSEL    = vireblc([M]REPERT([M]NEWSEL),2)
REPBASE   = filpath([M]REPREP([M]NEWSEL),"","","","",[M]MACHINE)
Case [M]OS
 When "unix" : If right$(REPBASE,len(REPBASE))<>"/" : REPBASE += "/" : Endif : REPBASE += REPSEL
 When "dos"  : If right$(REPBASE,len(REPBASE))<>"\" : REPBASE += "\" : Endif : REPBASE += REPSEL
Endcase
If instr(1,REPBASE,"@")
 REPBASE = right$(REPBASE,instr(1,REPBASE,"@")+1)
Endif
If [M]ONLYREP
 Call LISREP([M]OS,[M]MACHINE,REPBASE,[M]NBFIC,[M]FICHIER)
Else
 Call LISFIC([M]OS,[M]MACHINE,REPBASE,[M]NBFIC,[M]FICHIER)
Endif
Affzo [M]REPERT([M]NEWSEL)
Gosub SELREP
[M]LIGSEL = [M]NEWSEL
[M]REPVISU = [M]REPREP([M]LIGSEL)
If right$([M]REPVISU,len([M]REPVISU))<>SEP
 [M]REPVISU += SEP
Endif
[M]REPVISU += vireblc([M]REPERT([M]LIGSEL),2)
Affzo REPVISU
Return

#####################################################################
$DEPLIE
[M]NEWSEL = nolign-1
If [M]NEWSEL>=dim([M]NIVEAU)-1 or [M]NIVEAU([M]NEWSEL+1)>[M]NIVEAU([M]NEWSEL)
 Goto REPLIE
Endif
REPSEL  = vireblc([M]REPERT([M]NEWSEL),2)
REPBASE = filpath([M]REPREP([M]NEWSEL),"","","","",[M]MACHINE)
Case [M]OS
 When "unix" : If right$(REPBASE,len(REPBASE))<>"/" : REPBASE += "/" : Endif : REPBASE += REPSEL
 When "dos"  : If right$(REPBASE,len(REPBASE))<>"\" : REPBASE += "\" : Endif : REPBASE += REPSEL
Endcase
If instr(1,REPBASE,"@")
 REPBASE = right$(REPBASE,instr(1,REPBASE,"@")+1)
Endif
Call LISREP([M]OS,[M]MACHINE,REPBASE,[M]NBLISTE,[M]LISTEFIC)
[M]NBLISTE = min([M]NBLISTE,dim([M]LISTEFIC))
If [M]NBLISTE>0
 If [M]NBLISTE+[M]NBREP>dim([M]REPERT)
  Call ERREUR(mess(38,139,1)) From GESECRAN : # Trop de sous-répertoires
 Else
  Insa [M]NEWSEL+1,[M]NBLISTE [M]NBREP
  For K=1 To [M]NBLISTE
   [M]NIVEAU([M]NEWSEL+K) = [M]NIVEAU([M]NEWSEL)+1
   [M]REPERT([M]NEWSEL+K) = space$([M]NIVEAU([M]NEWSEL)+1)+[M]LISTEFIC(K-1)
   [M]REPREP([M]NEWSEL+K) = REPBASE
  Next K
  [M]NBREP += [M]NBLISTE
 Endif
Endif
Gosub SELREP
If [M]LIGSEL<>[M]NEWSEL
 nolign = [M]NEWSEL+1 : Gosub OUVREP
Endif
Return

#####################################################################
$REPLIE
K = 0
While [M]NIVEAU([M]NEWSEL+K+1)>[M]NIVEAU([M]NEWSEL)
 K += 1
Wend
If K>0
 Dela [M]NEWSEL+1,K [M]NBREP
 [M]NBREP -= K
Endif
If [M]LIGSEL<>[M]NEWSEL
 nolign = [M]NEWSEL+1 : Gosub OUVREP
Endif
Return

#####################################################################
Subprog LISREP(OS,MACHINE,REPBASE,NBREP,LISTEREP)
Value    Char     OS
Value    Char     MACHINE
Value    Char     REPBASE
Variable Shortint NBREP
Variable Char     LISTEREP()(1..)

Local Char        LISTE(GDIMFIC)(1..dim(LISTEREP)) , ORDSYS(250)
Local Integer     STAT , I , J
Case OS
 When "unix"
  # ls -p pour que les répertoires apparaissent avec un / à la fin
  Call SYSTEME2(MACHINE,'ls -p "'+vireblc(REPBASE,2)+'"','',STAT,LISTE) From ORDSYS
  STAT = min(STAT,dim([L]LISTE))
  NBREP = 0
  For I=1 To STAT
   If right$(LISTE(I),len(LISTE(I)))="/"
    NBREP += 1
    LISTEREP(NBREP) = left$(LISTE(I),len(LISTE(I))-1)
   Endif
  Next I
 When "dos"
  # dir /a:d  pour lister seulement les répertoires
  # dir /b    pour n'afficher que le nom des fichiers sur une seule colonne
  Case MACHINE
   When "#"     : ORDSYS = 'cmd /c dir /a:d /b "'+vireblc(REPBASE,2)+'\"'
   When Default : ORDSYS = 'dir /a:d /b "'+vireblc(REPBASE,2)+'\"'
  Endcase
  Call SYSTEME2(MACHINE,ORDSYS,'',STAT,LISTE) From ORDSYS
  STAT = min(STAT,dim([L]LISTE))
  NBREP = 0
  For I=1 To STAT
   NBREP += 1
   LISTEREP(NBREP) = LISTE(I)
  Next I
Endcase
End

#####################################################################
Subprog LISFIC(OS,MACHINE,REPBASE,NBREP,LISTEREP)
Value    Char     OS
Value    Char     MACHINE
Value    Char     REPBASE
Variable Shortint NBREP
Variable Char     LISTEREP()(1..)

Local Integer     STAT , I , EXISTE
Local Char        LISTE(GDIMFIC)(1..dim(LISTEREP)) , ORDSYS(250)

Case OS
 When "unix"
  # ls -p pour que les répertoires apparaissent avec un / à la fin
  Call SYSTEME2(MACHINE,'ls -p "'+vireblc(REPBASE,2)+'"','',STAT,LISTE) From ORDSYS
  STAT = min(STAT,dim([L]LISTE))
  NBREP = 0
  For I=1 To STAT
   If right$([L]LISTE(I),len([L]LISTE(I)))<>"/"
    NBREP += 1
    LISTEREP(NBREP) = [L]LISTE(I)
   Endif
  Next I
 When "dos"
  # dir /a:-d pour lister tous les fichiers sauf les répertoires
  # dir /b    pour n'afficher que le nom des fichiers sur une seule colonne
  Case MACHINE
   When "#"     : ORDSYS = 'cmd /c dir /a:-d /b "'+vireblc(REPBASE,2)+'"'
   When Default : ORDSYS = 'dir /a:-d /b "'+vireblc(REPBASE,2)+'"'
  Endcase
  Call SYSTEME2(MACHINE,ORDSYS,'',STAT,LISTE) From ORDSYS
  STAT = min(STAT,dim([L]LISTE))
  NBREP = 0
  For I=1 To STAT
   NBREP += 1
   LISTEREP(NBREP) = LISTE(I)
  Next I
Endcase
End

###################################################################
Subprog AS_NBREP
GMODIF = 1
End

Subprog C_NBREP
Local Char     REPSEL(GDIMFIC), REPBASE(GDIMFIC)
Local Integer  I , J , K , L
If adxgtb | status<>75 : End : Endif
Gosub SET_SEP
Gosub DEPLIE
Affzo
mkstat = 2
End

$SET_SEP
Local Char SEP(1)
SEP = string$(instr(1,[M]REPREP(nolign-1),"\")<>0,"\")
SEP += string$(instr(1,[M]REPREP(nolign-1),"\")=0,"/")
Return

Subprog B2_NBREP
Local Char     REPSEL(GDIMFIC), REPBASE(GDIMFIC)
Local Integer  I , J , K , L
Gosub SET_SEP
Gosub OUVREP
Affzo
End

Subprog B3_NBREP
Local Char     REPSEL(GDIMFIC), REPBASE(GDIMFIC)
Local Integer  I , J , K , L
Gosub SET_SEP
Gosub DEPLIE
Affzo
End

Subprog AS_REPERT(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

Subprog B2_NBFIC
Gosub SELFIC
End

Subprog C_NBFIC
# Kroche aztuze pour se positionner sur la ligne du répertoire demandé
# au début, si la ligne est dans la partie non visible du tableau
If adxgtb & GMODIF=0 & [M]LIGSEL>11
 zonsui = "NBREP("+num$([M]LIGSEL)+")" : End
Elsif adxgtb | status<>75
 End
Endif
Gosub SELFIC
mkstat = 2
End

Subprog AS_FICHIER(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End
