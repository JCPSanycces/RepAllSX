#<AdxTL>@(#)2.0.0.0 $Revision$
Call VALIDATION("QATABLE",nomap,1,GBIDI1) From ASHWVAL
End

#-------------------------------------------------------#
$VALTRT
Gosub TRT_VERF
If OK
 Raz CLOB
 Gosub TRT_DEB
 Gosub REMPLIT
 Gosub TRT_FIN
 Raz CLOB
Endif
Return

#-------------------------------------------------------#
$TRT_VERF
OK = 0
If find(1,PRESENT.FLD(1..maxtab(PRESENT.FLD)).QRYFLD) or find(2,PRESENT.FLD(1..maxtab(PRESENT.FLD)).QRYFLD)
 OK = 1
Endif
Gosub LOAD_ENTITY_FOR_QUERY
If !OK : Return : Endif
Return

#-------------------------------------------------------#
$TRT_DEB
FICSRC = filpath("TRT",func SUBASW.PREFIX_QRY+PRESENT.CODPRE,"src",APPLI,"",MACHINE)
Openo FICSRC , 0 Using [SSS_]
Iomode adxifs "" Using [SSS_]
Iomode adxirs chr$(10) Using [SSS_]
Iomode adxium GUTF8 Using [SSS_]
Wrseq TITETA+mess(3,140,1)-func AFNC.TEXTE(PRESENT.INTSTR) Using [SSS_] : # Structure
Wrseq "#"-MAGIC Using [SSS_]
Wrseq PRESENT.IDENT-func SUBASW.PREFIX_QRY+PRESENT.CODPRE Using [SSS_]
Wrseq Using [SSS_]
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq CLOB Using [SSS_]
Wrseq Using [SSS_]
Openo Using [SSS_]
Call VALID("TRT",func SUBASW.PREFIX_QRY+PRESENT.CODPRE,DOSSIER,OK) From ASTRVALSUB
Return

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$LOAD_ENTITY_FOR_QUERY
# Load entity stucture if typrep is "Requete"
If clalev([F:ATI_])=0 : Local File =DOSSIER+".ATABIND" [ATI_] : Endif
If clalev([F:ATB_])=0 : Local File =DOSSIER+".ATABLE"  [ATB_] : Endif
If clalev([F:ATZ_])=0 : Local File =DOSSIER+".ATABZON" [ATZ_] : Endif
If clalev([F:AMP_])=0 : Local File =DOSSIER+".AMSKPAR" [AMP_] : Endif
If clalev([F:AEM_])=0 : Local File =DOSSIER+".AENTLNK" [AEM_] : Endif
If clalev([F:ATY_])=0 : Local File =DOSSIER+".ATYPE"   [ATY_] : Endif

Local Instance ERROR Using C_AERROR
Local Instance PMODEL Using C_AMODEL    : # Parameters of the model
PMODEL = NewInstance C_AMODEL

Local Integer NBABRUSED,NBCHPS,WNBTBLFLD
Local Char    WABRUSED(GLONABR)(1..16),WTBLUSED(GLONATB)(1..16)
Local Char    CHPS(30)(1..16),WABR(GLONABR),WTAB(GLONATB)

Call LOAD_ENTITY(DOSSIER,PRESENT.MODELE,PRESENT.ENT,ERROR) From ASTRLECAEM
If ERROR<>null & maxtab(ERROR)>0 & ERROR.STA
 Call ECR_TRACE(ERROR.MES,1) From GESECRAN
 OK=0 : Return
Endif

# Load abreviation
For J=1 To maxtab(PRESENT.FLD)
 If PRESENT.FLD(J).ABRFLD="" & PRESENT.FLD(J).EXPFLD=""
  For I=1 To maxtab(PRESENT.ENT.STR)
   Read [ATZ_]CODZONE = PRESENT.ENT.STR(I).TABLNK;PRESENT.FLD(J).CODFLD
   If !fstat
    PRESENT.FLD(J).ABRFLD = PRESENT.ENT.STR(I).ABRLNK
    Break
   Endif
  Next
 Endif
 If PRESENT.FLD(J).ABRFLD="" & PRESENT.FLD(J).EXPFLD=""
  For I=1 To maxtab(PRESENT.ENT.CPL)
   Read [ATZ_]CODZONE = PRESENT.ENT.CPL(I).TABLNK;PRESENT.FLD(J).CODFLD
   If !fstat
    PRESENT.FLD(J).ABRFLD = PRESENT.ENT.CPL(I).ABRLNK
    Break
   Endif
  Next
 Endif
Next
Return

#----------------------------------------------#
$REMPLIT
J = 1
K = 0
LIGNE = " " : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Tables list to open" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$OPEN_QUERY" : Gosub ADDCLB
NBABRUSED = 1
WABRUSED(NBABRUSED) = PRESENT.ENT.STR(J).ABRLNK
WTBLUSED(NBABRUSED) = PRESENT.ENT.STR(J).TABLNK
# Parcours des tables du modeles pour voir celles utilisées
For J=2 To maxtab(PRESENT.ENT.STR)
 I =0
 For F=1 To maxtab(PRESENT.FLD)
  If PRESENT.ENT.STR(J).ABRLNK=PRESENT.FLD(F).ABRFLD & (PRESENT.FLD(F).QRYFLD=1 or PRESENT.FLD(F).QRYFLD=2)
   I =1
   Break
  Endif
 Next
 If I
  If !find(PRESENT.ENT.STR(J).ABRLNK,[L]WABRUSED(1..NBABRUSED))
   NBABRUSED += 1
   WABRUSED(NBABRUSED) = PRESENT.ENT.STR(J).ABRLNK
   WTBLUSED(NBABRUSED) = PRESENT.ENT.STR(J).TABLNK
   K +=1
  Endif
  Call RECHERCHE_TABLE(DIF,J,PRESENT.ENT,WABRUSED,WTBLUSED,NBABRUSED,K,CLOB)
 Endif
Next
# On ajoute les table 1,1
For J=1 To  maxtab(PRESENT.ENT.CPL)
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = PRESENT.ENT.CPL(J).ABRLNK
 WTBLUSED(NBABRUSED) = PRESENT.ENT.CPL(J).TABLNK
Next
# Si champ site , on rajoute AFCTFCY
If PRESENT.ENT.FCYSTR<>""
 If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = "AFF"
 WTBLUSED(NBABRUSED) = "AFCTFCY"
Endif
# Si aucune table n'a été rajouté on rajoute la table principale avec un abrev dif pour le link
If NBABRUSED = 0 : # If
 NBABRUSED += 1
 WABRUSED(NBABRUSED) = "A_"
 WTBLUSED(NBABRUSED) = PRESENT.ENT.STR(1).TABLNK
Endif
For I=1 To NBABRUSED
 LIGNE =  "If clalev([F:"+WABRUSED(I)+"])=0 : Local File"-WTBLUSED(I)-"["+WABRUSED(I)+"] : Endif" : Gosub ADDCLB
Next
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB

LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Tables list to close" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$CLOSE_QUERY" : Gosub ADDCLB
For I=1 To NBABRUSED
 If !find(WABRUSED(I),"ATX","AXX","AEM","ASW")
  LIGNE = "Close Local File ["+WABRUSED(I)+"]" : Gosub ADDCLB
 Endif
Next I
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB

LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Link for the query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$LINK_QUERY" : Gosub ADDCLB
B = 0
LIGNE = "Link ["+PRESENT.ENT.STR(1).ABRLNK+"] With" : Gosub ADDCLB
For J=2 To maxtab(PRESENT.ENT.STR)
 OK = find(PRESENT.ENT.STR(J).ABRLNK,WABRUSED(1..NBABRUSED))
 If OK
  If B>0 : LIGNE += "," : Gosub ADDCLB : Endif
  B +=1
  LIGNE = "& ["+PRESENT.ENT.STR(J).ABRLNK+"]"+PRESENT.ENT.STR(J).CLELNK
  If find(PRESENT.ENT.STR(J).TYPLNK,3,4)
   LIGNE += " ~= "
  Else
   LIGNE += " = "
  Endif
  LIGNE += PRESENT.ENT.STR(J).EXPLNK
 Endif
Next
For F=1 To  maxtab(PRESENT.ENT.CPL)
 If B>0 & F=1 : LIGNE += "," : Gosub ADDCLB : Endif
 B +=1
 If F>1 : LIGNE += "," : Gosub ADDCLB : Endif
 LIGNE = "& ["+PRESENT.ENT.CPL(F).ABRLNK+"]"+PRESENT.ENT.CPL(F).CLELNK
 If find(PRESENT.ENT.CPL(F).TYPLNK,3,4)
  LIGNE += " ~= "
 Else
  LIGNE += " = "
 Endif
 LIGNE += PRESENT.ENT.CPL(F).EXPLNK
Next
If PRESENT.ENT.FCYSTR<>""
 If B>0 : Gosub ADDCLB : Endif
 B +=1
 LIGNE = "& [AFF]AFF0~= [F:"+PRESENT.ENT.STR(1).ABRLNK+"]"+PRESENT.ENT.FCYSTR+";GPROFIL;GUSRFCT," : Gosub ADDCLB
Endif
If !B :# Aucune jointure on fait une auto jointure
 Read [ATI_]NUMLIG=PRESENT.ENT.STR(1).TABLNK;1
 Call SETCLE(NBCHPS ,CHPS,[F:ATI_]DESCRIPT) From LNKSUB
 LIGNE = "& [A_]"+[F:ATI_]CODIND+"="
 For I=1 To NBCHPS
  If I>1 : LIGNE += ";" : Endif
  LIGNE += "["+PRESENT.ENT.STR(1).ABRLNK+"]"+CHPS(I)
 Next I
Endif
Gosub ADDCLB
LIGNE = '& As [LNK_]'                     : Gosub ADDCLB
LIGNE = '& Where evalue(PQUERY.QWHERE)'   : Gosub ADDCLB
LIGNE = '& Order With PQUERY.QORDER'      : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB

LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# Transclass of fields of query" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$TRANS_QUERY" : Gosub ADDCLB
For I=1 To NBABRUSED
 J = find(WABRUSED(I),PRESENT.ENT.STR(1..maxtab(PRESENT.ENT.STR)).ABRLNK)
 If J
  LIGNE = "SETSTC QRYSTC(NBPRE) With [F:"+WABRUSED(I)+"]" : Gosub ADDCLB
 Endif
Next
LIGNE = "" : Gosub ADDCLB

## Gestion of field expression EXPFLD
LIGNE = "### FIELD EXPRESSION" : Gosub ADDCLB
For F=1 To maxtab(PRESENT.FLD)
 If PRESENT.FLD(F).EXPFLD<>"" & (PRESENT.FLD(F).QRYFLD=1 or PRESENT.FLD(F).QRYFLD=2)
  LIGNE  = "QRYSTC(NBPRE)."+PRESENT.FLD(F).CODFLD-"="-PRESENT.FLD(F).EXPFLD :  Gosub ADDCLB
 Endif
Next
LIGNE = "" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB

LIGNE = " " : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "# INIT_QUERY" : Gosub ADDCLB
LIGNE = "#-------------------------------------------------------------------#" : Gosub ADDCLB
LIGNE = "$INIT_QUERY" : Gosub ADDCLB
LIGNE = 'Return' : Gosub ADDCLB
Return

#----------------------------------------------#
Subprog RECHERCHE_TABLE(DIF,LIGNES,ENTITY,WABRUSED,WTBLUSED,NBABRUSED,K,CLOB)
Value Integer    DIF
Value Integer    LIGNES
Value    Instance  ENTITY Using C_AENTLNK
Variable Char    WABRUSED()(1..)
Variable Char    WTBLUSED()(1..)
Variable Integer NBABRUSED
Variable Integer K
Variable Clbfile CLOB

Local Integer J,M
Local Char    LIGNE(250)

For KK =1 To ENTITY.STR(LIGNES).NBINDS
 J = instr(1,ENTITY.STR(LIGNES).INDS(KK),"]")-1
 If J>=0 & !find(seg$(ENTITY.STR(LIGNES).INDS(KK),4,J),WABRUSED(1..NBABRUSED))
& & seg$(ENTITY.STR(LIGNES).INDS(KK),4,J)<>ENTITY.STR(1).ABRLNK
  M = find(seg$(ENTITY.STR(LIGNES).INDS(KK),4,J),ENTITY.STR(1..maxtab(ENTITY.STR)).ABRLNK)
  If M
   LIGNE = "Local File"-ENTITY.STR(M).TABLNK-"["+ENTITY.STR(M).ABRLNK+"]" : Gosub ADDCLB
   NBABRUSED += 1
   WABRUSED(NBABRUSED) = ENTITY.STR(M).ABRLNK
   WTBLUSED(NBABRUSED) = ENTITY.STR(M).TABLNK
   Call RECHERCHE_TABLE(DIF,M,ENTITY,WABRUSED,WTBLUSED,NBABRUSED,K,CLOB)
   K += 1
  Endif
 Endif
Next
End
