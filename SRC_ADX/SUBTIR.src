Subprog C_PYRDAT(VALEUR)
Variable Date VALEUR()
#MIPEA - 2017-01-25- X3-12033- START
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]

Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
If mkstat : End : Endif
If [F:ID]FLGMULCTR=2
 # FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  GMESSAGE = "Contrat non valide à cette date"
  mkstat = 2 : GERR = 1 : End
 Endif
Endif
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#If mkstat : End : Endif
#If [F:ID]FLGMULCTR=2
# # FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
# Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
# Read [CTR]CTR0 Last
# Filter [CTR]
# If fstat
#  GMESSAGE = "Contrat non valide à cette date"
#  mkstat = 2 : GERR = 1 : End
# Endif
#Endif
#MIPEA - 2017-01-25- X3-12033- END
End

Subprog AM_PYRDAT(VALEUR)
Variable Date VALEUR()
#MIPEA - 2017-01-25- X3-12033- START
 Filter [HRCTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read [HRCTR]CTR1 Last
 Filter [HRCTR]

Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
If mkstat : End : Endif
If [F:ID]FLGMULCTR<>2
 # FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
 Filter [HRCTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
 Read [HRCTR]CTR1 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY    = [F:HRCTR]ETRFCY
  [M]SRV    = [F:HRCTR]ETRSRV
  [M]CTRNUM = [F:HRCTR]CTRNUM
  Affzo [M]CTRNUM
 Endif
Endif
#Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#If mkstat : End : Endif
#If [F:ID]FLGMULCTR<>2
# # FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
# Filter [CTR] Where REFNUM=[M]REFNUM & ((FLGRET<>2 & CTRDAT<=VALEUR) | (FLGRET=2 & RETDATEFF<=VALEUR))
# Read [CTR]CTR1 Last
# Filter [CTR]
# If !fstat
#  [M]FCY    = [F:CTR]ETRFCY
#  [M]SRV    = [F:CTR]ETRSRV
#  [M]CTRNUM = [F:CTR]CTRNUM
#  Affzo [M]CTRNUM
# Endif
#Endif
#MIPEA - 2017-01-25- X3-12033- END
[M]PYRDAT = VALEUR
Gosub SETSEM
Affzo [TIR1]WEK1,WEK2,WEK3,WEK4,WEK5,WEK6,WEK7,WEK8,WEK9
Affzo [M:TIR3]NBLIGS,TEXTE(0),SW1(0),SW2(0),SW3(0),SW4(0),SW5(0),SW6(0),SW7(0),SW8(0),SW9(0)
End

