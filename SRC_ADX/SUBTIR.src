Subprog DECOMPVAL(CHAINE,DATDEB,DATFIN)
Value    Char    CHAINE
Variable Date    DATDEB,DATFIN
Local    Integer I1,I2,LENYEAR

  I1=len(mess(94,100,1))+2
  I2=instr(1,CHAINE,mess(95,100,1))
  If I2>0 Then
    DATDEBC=mid$(CHAINE,I1,I2-I1-1)
    DATFINC=mid$(CHAINE,I2+len(mess(95,100,1))+1,len(CHAINE))
  Else
    DATDEBC=mid$(CHAINE,I1,len(CHAINE))
  Endif
  If len(DATDEBC)=8 Then LENYEAR=2 Elsif len(DATDEBC)=10 Then LENYEAR=4 : Endif
  # FQ92146 - 05/09/13 - Ajout du >= au lieu du > strict, pour gérer l'année 2000
#  If val(mid$(DATDEBC,1,2))>0 & val(mid$(DATDEBC,4,2))>0 & val(mid$(DATDEBC,7,LENYEAR))>0 Then
  If val(mid$(DATDEBC,1,2))>0 & val(mid$(DATDEBC,4,2))>0 & ((val(mid$(DATDEBC,7,LENYEAR))>=0 & LENYEAR=2) | (val(mid$(DATDEBC,7,LENYEAR))>0 & LENYEAR=4)) Then
    DATDEB=gdat$(val(mid$(DATDEBC,1,2)),val(mid$(DATDEBC,4,2)),val(mid$(DATDEBC,7,LENYEAR)))
    If DATFINC<>"" Then
      If len(DATFINC)=8 Then LENYEAR=2 Elsif len(DATFINC)=10 Then LENYEAR=4 : Endif
      # FQ92146 - 05/09/13 - Ajout du >= au lieu du > strict, pour gérer l'année 2000
#      If val(mid$(DATFINC,1,2))>0 & val(mid$(DATFINC,4,2))>0  & val(mid$(DATFINC,7,LENYEAR))>0 Then
      If val(mid$(DATFINC,1,2))>0 & val(mid$(DATFINC,4,2))>0  & ((val(mid$(DATFINC,7,LENYEAR))>=0 & LENYEAR=2) | (val(mid$(DATFINC,7,LENYEAR))>0 & LENYEAR=4)) Then
        DATFIN=gdat$(val(mid$(DATFINC,1,2)),val(mid$(DATFINC,4,2)),val(mid$(DATFINC,7,LENYEAR)))
      Else
        DATFIN=[0/0/0]
        GMESSAGE="Erreur Date incorrecte"
      Endif
    Else
      DATFIN=[0/0/0]
    Endif
  Else
    DATDEB=[0/0/0]
    GMESSAGE="Erreur Date incorrecte"
  Endif
End

Subprog C_SW(IND,VALEUR)
Value    Integer IND
Variable Char    VALEUR()
Local    Date    DATDEB,DATFIN,XITDAT

  If VALEUR="" Then
    If evalue("[M]SWEK"+num$(IND))<>"" Then
      mkstat = 1 : GMESSAGE = mess(10,123,1) : # Zone obligatoire
    Endif
    End
  Endif
  If instr(1,VALEUR,mess(94,100,1))=0 | instr(1,VALEUR,mess(95,100,1))=0 Then
    mkstat=2 : GMESSAGE = mess(140,701,1): # Votre saisie doit être au format 'Du DD/MM/YY au DD/MM/YY'
    End
  Endif
  # Décomposition de la valeur saisie afin d'obtenir les dates début et fin de contrat
  Call DECOMPVAL(VALEUR,DATDEB,DATFIN)
  # Contrôle des valeurs saisies
  Call CONTROL_CTRDAT([M]REFNUM,[M]CTRNUM,DATDEB,evalue("[M]SDAT"+num$(IND)),[M]PYRDAT,2,[L]XITDAT) From TPSSTD
  If !mkstat & ((DATFIN<>[0/0/0] & XITDAT<>DATFIN) | (DATFIN=[0/0/0] & XITDAT<>[0/0/0])) Then
#MIPEA - 2017-01-25- X3-12033- START
    mkstat=2 : GMESSAGE = mess(26,10701,1): # Contrat inexistant
#    mkstat=2 : GMESSAGE = mess(26,701,1): # Contrat inexistant
#MIPEA - 2017-01-25- X3-12033- END
    End
  Endif
# Pas de test de Verrouillé US 2022 65062 en saisie manuelle car deflag le bulletin  Gosub CTR_VEP_FLGLOCK
#  If mkstat=2 and [L]WMESSAGE <> ""
#     GMESSAGE=[L]WMESSAGE
#     End
#  Endif
# END Verrouillé US 2022 65062
End

Subprog C_SW1(VALEUR)
Variable Char    VALEUR()

  Call C_SW(1,VALEUR)
End

Subprog C_SW2(VALEUR)
Variable Char    VALEUR()

  Call C_SW(2,VALEUR)
End

