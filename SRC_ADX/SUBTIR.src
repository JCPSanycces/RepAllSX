#<AdxTL>@(#)0.0.0.0 $Revision$
# Modification :
#     SEGAY 05/09/11 Bug 74962
#      On passe de 50 à L_NBVAR de l'écran TIR1 les tableaux des variables de temps
#     FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#     FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#     FQ99390 - 19/05/14 - Ajout de 3 semaines possibles supplémentaires
######################################################################################
Raz GPILOBJ
Call OBJET("TIR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "FILTRE"     : Gosub FILTRE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "AV_IMPRIME" : Gosub AV_IMPRIME # FQ89616 SEGAY 25/04/13
Endcase
Return

$OUVRE
Local Char FILTAUS(80)
#MIPEA - 2017-01-25- X3-12033- START
Local Char PARMAT(GLONEML)
#Local Char PARMAT(GLONMAT)
#MIPEA - 2017-01-25- X3-12033- END
Local Char LESITE(GLONFCY) : #59323

#JOJAC - 2017-01-06 - START
#If clalev([F:PEO])=0 : Local File PERIOD    [PEO] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA    [HRPEOH] : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET    [HRPEOD] : Endif
#JOJAC - 2017-01-06 - END
If clalev([F:ID])=0  : Local File EMPLOID   [ID]  : Endif
If clalev([F:TID])=0 : Local File TIMEMPDAT [TID] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
#48793
If GPAYE=1
 If clalev([F:VEP])=0 : Local File VALEMP    [VEP] : Endif
Endif
If !instr(1,GUSRAUZ(1),"1")
 Call PARAMUTIL("REFNUM",PARMAT,GUSER,"") From SUBAUS
 FILTAUS = 'REFNUM="'+PARMAT+'"'
Endif

Return

$FILTRE
If !instr(1,GUSRAUZ(1),"1")
 FILTSUP = FILTAUS
Elsif GUSRACS<>2
 FILTSUP  = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find(SRV,GAUTSRV(1..GNBSERV))"
Endif
Return

$SETBOUT
#39925
#If REP<>""
If REP<>"" | CLECUR=0 | !VERROU
 Call VIREBOUT (CHAINE,"1") From GOBJET
Endif
#Objet à 3 éléments de clé : ajout du btn suppression
If CLECUR  CHAINE+="A"  Endif
CHMEN=""
#39925
#If CLECUR & GREP=""
If CLECUR & GREP="" & VERROU=1
 CHMEN = "689"    : # Saisies des temps
Endif
#48793
If GPAYE=1
 Filter [VEP] Where EMP=[M:TIR0]REFNUM & PYRDAT=[M:TIR0]PYRDAT & CTRNUM=[M:TIR0]CTRNUM
 Read [VEP]VEP0 First
 Filter [VEP]
 If !fstat & [F:VEP]PST>1
  Call VIREBOUT(CHAINE,"M") From GOBJET
 Endif
Endif
Return
# fin 48793
Return

$EXEBOUT
Case REP
 When "1" :
  Read [TIR]TIR0 = [M:TIR0]REFNUM;[M:TIR0]CTRNUM;[M:TIR0]PYRDAT
  Gosub LECTURE From GOBJSUB
Endcase
Return

$AV_IMPRIME # FQ89616 SEGAY 25/04/13
Read [TIR]TIR0 = [M:TIR0]REFNUM;[M:TIR0]CTRNUM;[M:TIR0]PYRDAT
Read [FCY]FCY0 = [M:TIR0]FCY
Return

$LIENS
Gosub SETSEM
Gosub SETZON
For I=1 To NBVAR
 If TBVAR(I)="QTY1"
  [M:TIR1]TEXTE(I-1) = mess(1,403,1)
 Elsif TBVAR(I)="QTY2"
  [M:TIR1]TEXTE(I-1) = mess(2,403,1)
  Else
  [M:TIR1]TEXTE(I-1) = LIBVAR(I)
 Endif
 [M:TIR1]W1(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(0)")
 [M:TIR1]W2(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(1)")
 [M:TIR1]W3(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(2)")
 [M:TIR1]W4(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(3)")
 [M:TIR1]W5(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(4)")
 [M:TIR1]W6(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(5)")
 [M:TIR1]W7(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(6)")
 [M:TIR1]W8(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(7)")
 [M:TIR1]W9(I-1) = evalue("[F:TIR]"+TBVAR(I)+"(8)")
Next I
[M:TIR1]NBLIG = NBVAR
Read [ID]ID0 = [F:TIR]REFNUM
[M:TIR0]NAM = [F:ID]NAM-[F:ID]SRN
Read [TID]TID0 = [F:TIR]REFNUM;[F:TIR]CTRNUM
If !fstat
 For I=1 To NBDAT
  [M:TIR2]LIBEL(I-1) = LIBDAT(I)
  [M:TIR2]DAT(I-1)   = evalue("[F:TID]DAT"+TBDAT(I))
 Next I
Else
 For I=1 To NBDAT
  [M:TIR2]LIBEL(I-1) = LIBDAT(I)
  Raz [M:TIR2]DAT(I-1)
 Next I
Endif
[M:TIR2]NBRDAT = NBDAT
Return

$RAZCRE
Gosub SETZON
For I=1 To NBVAR
 If TBVAR(I)="QTY1"
  [M:TIR1]TEXTE(I-1) = mess(1,403,1)
 Elsif TBVAR(I)="QTY2"
  [M:TIR1]TEXTE(I-1) = mess(2,403,1)
  Else
  [M:TIR1]TEXTE(I-1) = LIBVAR(I)
 Endif
Next I
[M:TIR1]NBLIG = NBVAR
For I=1 To NBDAT
 [M:TIR2]LIBEL(I-1) = LIBDAT(I)
Next I
[M:TIR2]NBRDAT = NBDAT
Affzo [TIR1]20
Affzo [TIR2]
# FQ82073 - MABON 11/12/12 - Nouvel onglet Périodes
Raz [M:TIR3]
Affzo [TIR3]
# Fin MABON
Gosub GRISE
Return

$RAZDUP
# FQ82073 - MABON 11/12/12 - Nouvel onglet Périodes
#Raz [M:TIR3]
#Affzo [TIR3]
# Fin MABON
Gosub GRISE
Return

$GRISE
If [F:ID]FLGMULCTR<>2
 Diszo [TIR0]CTRNUM
Else
 Actzo [TIR0]CTRNUM
Endif
Affzo [TIR0]CTRNUM
Return

$INICRE
$INIMOD
Gosub SETZON
For I=1 To NBVAR
 Assign "[F:TIR]"+TBVAR(I)+"(0)" With [M:TIR1]W1(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(1)" With [M:TIR1]W2(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(2)" With [M:TIR1]W3(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(3)" With [M:TIR1]W4(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(4)" With [M:TIR1]W5(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(5)" With [M:TIR1]W6(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(6)" With [M:TIR1]W7(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(7)" With [M:TIR1]W8(I-1)
 Assign "[F:TIR]"+TBVAR(I)+"(8)" With [M:TIR1]W9(I-1)
Next I
# FQ82073 - MABON 11/12/12 - Nouvel onglet Périodes
Local Date DATDEB,DATFIN
For I=1 To 9
  If evalue("[M]SWEK"+num$(I))<>"" Then
    Call DECOMPVAL(evalue("[M:TIR3]SW"+num$(I)+"(0)"),DATDEB,DATFIN)
    If DATDEB<>[0/0/0] Then
      [F:TIR]CTRDAT(I-1)=DATDEB
    Endif
  Endif
Next
# Fin MABON
Return

$CREATION
$MODIF
Readlock [TID]TID0 = [F:TIR]REFNUM;[F:TIR]CTRNUM
If fstat=1
 GOK = -1 : GLOCK = "$TIMEMPDAT"-[F:TIR]REFNUM-[F:TIR]CTRNUM : Return
Elsif fstat
 Raz [F:TID]
 [F:TID]REFNUM = [F:TIR]REFNUM
 [F:TID]CTRNUM = [F:TIR]CTRNUM
 Gosub AFF_DATE
 Write [TID]
Else
 Gosub AFF_DATE
 Rewrite [TID]
Endif
If fstat
 GOK = 0 : Call FSTA("TID") From GLOCK : Return
Endif
#DBA le 14/10/04 : Maj des flags temps pour le suivi...
If GPAYE & GOK
 #64333 : Ajout param [0/0/0]
# Call MAJFLGTPS ([F:TIR]REFNUM,[F:TIR]PYRDAT,[F:TIR]CTRNUM,2,1,[0/0/0]) From SUBVEP
  # FQ91472 US2857/58 - SEGAY 02/09/14
  Local Date DATDEB,DATFIN
  Local Date WCTRD(0..8)
  Local Integer WI,WJ
  Raz DATDEB,DATFIN
  For WI=1 To 9
    If evalue("[M]SWEK"+num$(WI))<>"" Then
      Call DECOMPVAL(evalue("[M:TIR3]SW"+num$(WI)+"(0)"),DATDEB,DATFIN)
      GMESSAGE=""
      If DATDEB<>[0/0/0] Then
        If !find([L]DATDEB,[L]WCTRD(0..WJ)) : [L]WCTRD(WJ)=[L]DATDEB : WJ+=1 : Endif
      Endif
    Endif
  Next
  # FQ98507 - 26/05/14 - Ajout paramètre sur appel de TRTSYN.MAJ
  If [L]WCTRD(0) <> [0/0/0]
    For WI = 0 To WJ-1
      If [L]WCTRD(WI) <> [0/0/0]
#MIPEA - 2017-01-25- X3-12033- START
        Read[F:HRCTR]CTR0=[F:TIR]REFNUM;[F:TIR]CTRNUM;[L]WCTRD(WI)
#        Read[F:CTR]CTR0=[F:TIR]REFNUM;[F:TIR]CTRNUM;[L]WCTRD(WI)
#MIPEA - 2017-01-25- X3-12033- END
        If !fstat : Gosub FLGVEP : Endif
      Endif
    Next
  Else
    Call MAJFLGTPS ([F:TIR]REFNUM,[F:TIR]PYRDAT,[F:TIR]CTRNUM,2,1,[0/0/0]) From SUBVEP
  Endif
Endif
Return
#En modif je décoche tous les flags de VEP
####################################
# FQ91472 US2857/58 - SEGAY 02/09/14
$FLGVEP
#OK = 1
#GPOINT = "MAJFLGTPS" : Gosub ENTREE From EXEFNC
#If !OK
# OK = 1 : Return
#Endif
If GPAYE & GOK
 Local Date DATPAY2
 Local Date CTRDAT_VEP
 [L]DATPAY2=[F:TIR]PYRDAT
 CTRDAT_VEP=[L]WCTRD(WI)
#MIPEA - 2017-01-25- X3-12033- START
 Call TPSDATPAY([F:TIR]REFNUM,[F:TIR]CTRNUM,[L]WCTRD(WI),[F:HRCTR]XITDAT,[F:TIR]PYRDAT,[F:HRCTR]ETRFCY,[L]DATPAY2,[F:HRCTR]PERCOD) From TRTTPS
# Call TPSDATPAY([F:TIR]REFNUM,[F:TIR]CTRNUM,[L]WCTRD(WI),[F:CTR]XITDAT,[F:TIR]PYRDAT,[F:CTR]ETRFCY,[L]DATPAY2) From TRTTPS
#MIPEA - 2017-01-25- X3-12033- END
 Gosub FILTRE_VEP From TRTTPS
 Filter [VEP] Where EMP=[F:TIR]REFNUM & PYRDAT=[L]DATPAY2 & CTRNUM=[F:TIR]CTRNUM & evalue(CRITVEP)
 Read [VEP]VEP0 Last
 Filter [VEP]
 If !fstat
   Global Char GNUMBUL (GLONVCR)
   GNUMBUL=[F:VEP]BUL
   Call MAJFLGTPS ([F:TIR]REFNUM,[L]DATPAY2,[F:TIR]CTRNUM,2,1,[0/0/0]) From SUBVEP :#Synthèse
   Kill GNUMBUL
 Endif
Endif
Return

$AFF_DATE
For I=1 To NBDAT
 Assign "[F:TID]DAT"+TBDAT(I) With [M:TIR2]DAT(I-1)
Next I
Return

$SETSEM
Local Integer NBSEM , ANNEE , SEMAINE, EXITSAL
Local Date    DAT, DATFINC, FINMOISC
Raz [M:TIR1]WEK1,WEK2,WEK3,WEK4,WEK5,WEK6,WEK7,WEK8,WEK9
# FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#MIPEA - 2017-01-25- X3-12033- START
Filter [HRCTR] Where REFNUM=[M:TIR0]REFNUM & CTRNUM=[M:TIR0]CTRNUM & ((FLGRET<>2 & CTRDAT<=[M:TIR0]PYRDAT) | (FLGRET=2 & RETDATEFF<=[M:TIR0]PYRDAT))
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#Filter [CTR] Where REFNUM=[M:TIR0]REFNUM & CTRNUM=[M:TIR0]CTRNUM & ((FLGRET<>2 & CTRDAT<=[M:TIR0]PYRDAT) | (FLGRET=2 & RETDATEFF<=[M:TIR0]PYRDAT))
#Read [CTR]CTR0 Last
#Filter [CTR]
#MIPEA - 2017-01-25- X3-12033- END
#59323
#MIPEA - 2017-01-25- X3-12033- START
LESITE = [F:HRCTR]ETRFCY
#LESITE = [F:CTR]ETRFCY
#MIPEA - 2017-01-25- X3-12033- END
#JOJAC - 2017-01-06 - START
#Call PERIO(LESITE,[F:ID]REFNUM) From SUBPEO
Call PERIO(LESITE,[F:ID]REFNUM) From SUBHRPEO
#JOJAC - 2017-01-06 - END
#Read [PEO]PEO0(1) = [F:CTR]ETRFCY
#JOJAC - 2017-01-06 - START
Read [HRPEOD]PEO0(1) = [F:HRCTR]PERCOD
#JOJAC - 2017-01-06 - END
#fin 59323
If fstat<=2
 #59323
 #Read [PEO]PEO0 = [F:CTR]ETRFCY;[M:TIR0]PYRDAT
 #JOJAC - 2017-01-06 - START
 #Read [PEO]PEO0 = LESITE;[M:TIR0]PYRDAT
 Read [HRPEOD]HRPEOD0 = [F:HRCTR]PERCOD;[M:TIR0]PYRDAT
 #JOJAC - 2017-01-06 - END
 #If fstat Then
 # Read [PEO]PEO0 = "";[M:TIR0]PYRDAT
 #Endif
#Else
 #Read [PEO]PEO0 = "";[M:TIR0]PYRDAT
Endif
NBSEM = 0
#JOJAC - 2017-01-06 - START
#DAT     = [F:PEO]PERSTR(0)
#DATFINC = [F:PEO]PEREND(0)
#FMOISC  = [F:PEO]PEREND(1)
DAT     = [F:HRPEOD]PERSTR(0)
DATFINC = [F:HRPEOD]PEREND(0)
FMOISC  = [F:HRPEOD]PEREND(1)

#JOJAC - 2017-01-06 - END
# FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#MIPEA - 2017-01-20- X3-12122- START
Call CALC_DATEND(LESITE, [M:TIR0]PYRDAT, [F:HRCTR]XITDAT, [F:HRCTR]XITFNL, [F:HRCTR]CLEEVETIM, DAT, DATFINC, FMOISC, EXITSAL, [F:HRCTR]PERCOD) From TRTTPS
#Call CALC_DATEND(LESITE, [M:TIR0]PYRDAT, [F:CTR]XITDAT, [F:CTR]XITFNL, [F:CTR]CLEEVETIM, DAT, DATFINC, FMOISC, EXITSAL) From TRTTPS
#MIPEA - 2017-01-20- X3-12122- END
Repeat
#MIPEA - 2017-11-27- US X3-63170- START
 Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
 Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN
 NBSEM += 1
 Case NBSEM
  When 1 : [M:TIR1]WEK1 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK1 = [M:TIR1]WEK1  : [M:TIR3]SDAT1 = DAT+6
  When 2 : [M:TIR1]WEK2 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK2 = [M:TIR1]WEK2  : [M:TIR3]SDAT2 = DAT+6
  When 3 : [M:TIR1]WEK3 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK3 = [M:TIR1]WEK3  : [M:TIR3]SDAT3 = DAT+6
  When 4 : [M:TIR1]WEK4 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK4 = [M:TIR1]WEK4  : [M:TIR3]SDAT4 = DAT+6
  When 5 : [M:TIR1]WEK5 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK5 = [M:TIR1]WEK5  : [M:TIR3]SDAT5 = DAT+6
  When 6 : [M:TIR1]WEK6 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK6 = [M:TIR1]WEK6  : [M:TIR3]SDAT6 = DAT+6
  When 7 : [M:TIR1]WEK7 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK7 = [M:TIR1]WEK7  : [M:TIR3]SDAT7 = DAT+6
  When 8 : [M:TIR1]WEK8 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK8 = [M:TIR1]WEK8  : [M:TIR3]SDAT8 = DAT+6
  When 9 : [M:TIR1]WEK9 = num$(SEMAINE)-"-"-format$("D:DD[/]MM",DAT)  : [M:TIR3]SWEK9 = [M:TIR1]WEK9  : [M:TIR3]SDAT9 = DAT+6
 Endcase
 DAT += 7
#Until DAT>[F:PEO]PEREND(0)
Until DAT>DATFINC
[M:TIR1]NBSEM = NBSEM

# FQ82073 - MABON 11/12/12 - Nouvel onglet Périodes
Local Date DATMAX,CTRDATREF
Local Char SWD(50)
[M:TIR3]TEXTE(0)  = mess(139,701,1) : # Périodes d'activité
Raz [M:TIR3]SW1,SW2,SW3,SW4,SW5,SW6,SW7,SW8,SW9
For I=1 To 9
  If evalue("[M]SWEK"+num$(I))<>"" Then
    If [F:TIR]REFNUM=[M:TIR0]REFNUM & [F:TIR]PYRDAT=[M:TIR0]PYRDAT & [F:TIR]CTRDAT(I-1)<>[0/0/0] Then
#MIPEA - 2017-01-25- X3-12033- START
      Read [F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIR]CTRDAT(I-1)
#      Read [F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;[F:TIR]CTRDAT(I-1)
#MIPEA - 2017-01-25- X3-12033- END
      If !fstat Then
        SWD = mess(94,100,1)-format$("D:DD[/]MM[/]YY",[F:TIR]CTRDAT(I-1))-mess(95,100,1)
#MIPEA - 2017-01-25- X3-12033- START
        If [F:HRCTR]XITDAT<>[0/0/0] Then
#        If [F:CTR]XITDAT<>[0/0/0] Then
#MIPEA - 2017-01-25- X3-12033- END
#MIPEA - 2017-01-25- X3-12033- START
          SWD -= format$("D:DD[/]MM[/]YY",[F:HRCTR]XITDAT)
#          SWD -= format$("D:DD[/]MM[/]YY",[F:CTR]XITDAT)
#MIPEA - 2017-01-25- X3-12033- END
        Endif
        Assign "[M:TIR3]SW"+num$(I)+"(0)" With SWD
      Endif
    Endif
    If evalue("[M:TIR3]SW"+num$(I)+"(0)")=""
      DATMAX=evalue("[M:TIR3]SDAT"+num$(I))
      CTRDATREF=func TPSSTD.CALC_CTRDATDEF([M]REFNUM,[M]CTRNUM,DATMAX,[M]PYRDAT,DATMAX,3)
#MIPEA - 2017-01-25- X3-12033- START
      Read [F:HRCTR]CTR0=[M]REFNUM;[M]CTRNUM;CTRDATREF
#      Read [F:CTR]CTR0=[M]REFNUM;[M]CTRNUM;CTRDATREF
#MIPEA - 2017-01-25- X3-12033- END
      If !fstat
        SWD = mess(94,100,1)-format$("D:DD[/]MM[/]YY",[F:CTR]CTRDAT)-mess(95,100,1)
#MIPEA - 2017-01-25- X3-12033- START
        If [F:HRCTR]XITDAT<>[0/0/0] Then
#        If [F:CTR]XITDAT<>[0/0/0] Then
#MIPEA - 2017-01-25- X3-12033- END
#MIPEA - 2017-01-25- X3-12033- START
          SWD -= format$("D:DD[/]MM[/]YY",[F:HRCTR]XITDAT)
#          SWD -= format$("D:DD[/]MM[/]YY",[F:CTR]XITDAT)
#MIPEA - 2017-01-25- X3-12033- END
        Endif
        Assign "[M:TIR3]SW"+num$(I)+"(0)" With SWD
      Endif
    Endif
  Endif
Next
[M:TIR3]NBLIGS=1
# Fin MABON
Return

$SETZON
Local Integer NBVAR
#SEGAY 05/09/11 Bug 74962
#If GPAYE : # 69329
# Local Char    TBVAR(GLONVRA)(1..50)
#Else
# Local Char    TBVAR(10)(1..50)
#Endif
#
#Local Char    LIBVAR(50)(1..50)
#Gosub VARTEMPS From DEFTABLE
#Local Integer NBDATE
#Local Char    TBDAT(10)(1..50)
#Local Char    LIBDAT(50)(1..50)
#Gosub DATETEMPS From DEFTABLE
Local Integer L_NBVAR

If dim([M:TIR1]TEXTE)>0
  L_NBVAR=dim([M:TIR1]TEXTE)
Else
  L_NBVAR=50
Endif
If GPAYE : # 69329
 Local Char    TBVAR(GLONVRA)(1..L_NBVAR)
Else
 Local Char    TBVAR(10)(1..L_NBVAR)
Endif

Local Char    LIBVAR(50)(1..L_NBVAR)
Gosub VARTEMPS From DEFTABLE
Local Integer NBDATE
Local Char    TBDAT(10)(1..L_NBVAR)
Local Char    LIBDAT(50)(1..L_NBVAR)
#MIPEA - 2017-01-25- X3-12033- START
Gosub DATETEMPS From WPDEFTABLE
#Gosub DATETEMPS From DEFTABLE
#MIPEA - 2017-01-25- X3-12033- END
#END SEGAY 05/09/11 Bug 74962
Return

# Pas de test de Verrouillé US 2022 65062 en saisie manuelle car deflag le bulletin
#$CTR_VEP_FLGLOCK
#Local Date CTRDAT_VEP,DATPAY
#Local Char MATRI(GLONMAT),CTR(GLONCTR)
#Local Char WMESSAGE(250)
#Local Char WBULLETIN(GLONVCR)
#MATRI=[M]REFNUM
