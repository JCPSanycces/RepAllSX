Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read [ID]ID0 = VALEUR
[M]NAM = [F:ID]NAM-[F:ID]SRN
Affzo NAM
Raz [M]CTRNUM
If [F:ID]FLGMULCTR<>2
 Effzo CTRNUM
 Diszo CTRNUM
Else
 Actzo CTRNUM
Endif
If [F:ID]FLGMULCTR<>2
 If [M]PYRDAT<>[0/0/0]
  # FQ81491 - 17/12/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
#MIPEA - 2017-01-25- X3-12033- START
  Filter [HRCTR] Where REFNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=[M]PYRDAT) | (FLGRET=2 & RETDATEFF<=[M:TIR0]PYRDAT))
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
  Endif
  Call CADRE_PYRDAT([M]PYRDAT,[F:HRCTR]PERCOD) From TPSSUB
 Else
  Filter [HRCTR] Where REFNUM=VALEUR
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
  Endif
 Endif
Endif
Affzo CTRNUM
Effzo [M:TIR3]
#  Filter [CTR] Where REFNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=[M]PYRDAT) | (FLGRET=2 & RETDATEFF<=[M:TIR0]PYRDAT))
#  Read[CTR]CTR1 Last
#  Filter [CTR]
#  If !fstat
#   [M]FCY    = [F:CTR]ETRFCY
#   [M]SRV    = [F:CTR]ETRSRV
#   [M]CTRNUM = [F:CTR]CTRNUM
#  Endif
#  Call CADRE_PYRDAT([M]PYRDAT,[M]FCY) From TPSSUB
# Else
#  Filter [CTR] Where REFNUM=VALEUR
#  Read[CTR]CTR1 Last
#  Filter [CTR]
#  If !fstat
#   [M]FCY    = [F:CTR]ETRFCY
#   [M]SRV    = [F:CTR]ETRSRV
#   [M]CTRNUM = [F:CTR]CTRNUM
#  Endif
# Endif
#Endif
#Affzo CTRNUM
#Effzo [M:TIR3]
#MIPEA - 2017-01-25- X3-12033- END

# BRBAN 18/06/2014 SAM 96364
If func AFNC.PARAM("WEEK",[M]FCY)="1"
  Call ERREUR(mess(18,11553,1)) From GESECRAN
  mkstat = 2
Endif
End

