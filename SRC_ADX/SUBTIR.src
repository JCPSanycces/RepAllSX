Subprog AS_SW(IND)
Value   Integer IND

  If evalue("[M:TIR3]SWEK"+num$(IND))="" Then
    mkstat=2 : End
  Endif

  # FQ81491 - 17/12/13 - Recherche date selon rétroactivité
  Local Date    DATMAX
  #MIPEA - 2017-01-25- X3-12033- START
  Local Char    CRITERE(250), MATRI(GLONEML), CTR(GLONHRCTR)
#  Local Char    CRITERE(250), MATRI(GLONMAT), CTR(GLONCTR)
  #MIPEA - 2017-01-25- X3-12033- END
  Local Integer WEEKP, XITNOTDEF
  Gosub OUVRE_SELCTRDAT From DIVPAYE
#MIPEA - 2017-01-25- X3-12033- START
  CRITERE="(([F:HRCTR]FLGRET<>2 & [F:HRCTR]CTRDAT<=[M]PYRDAT) | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=[M]PYRDAT))"
#  CRITERE="(([F:CTR]FLGRET<>2 & [F:CTR]CTRDAT<=[M]PYRDAT) | ([F:CTR]FLGRET=2 & [F:CTR]RETDATEFF<=[M]PYRDAT))"
#MIPEA - 2017-01-25- X3-12033- END
  Case IND
    When 1 : DATMAX=[M:TIR3]SDAT1
    When 2 : DATMAX=[M:TIR3]SDAT2
    When 3 : DATMAX=[M:TIR3]SDAT3
    When 4 : DATMAX=[M:TIR3]SDAT4
    When 5 : DATMAX=[M:TIR3]SDAT5
    When 6 : DATMAX=[M:TIR3]SDAT6
    When 7 : DATMAX=[M:TIR3]SDAT7
    When 8 : DATMAX=[M:TIR3]SDAT8
    When 9 : DATMAX=[M:TIR3]SDAT9
  Endcase
  MATRI=[M:TIR0]REFNUM : CTR=[M:TIR0]CTRNUM : WEEKP=2
  Gosub FILTER_SELCTRDAT From DIVPAYE
  If NBDAT=0 Then mkstat=2 : Endif
End

Subprog AS_SW1(VALEUR)
Variable Char    VALEUR()

  Call AS_SW(1)
End

Subprog AS_SW2(VALEUR)
Variable Char    VALEUR()

  Call AS_SW(2)
