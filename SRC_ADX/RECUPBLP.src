#<AdxTL>@(#)0.0.0.0 $Revision$
#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)

Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBLP","UTIRECBLP",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

##########################################################################################################
$OUVRE
If dim(DOSSIER)<1
 Local Char DOSSIER(GLONADP)
 DOSSIER = nomap
Endif

If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif
If clalev([F:PER])=0 : Local File =DOSSIER+".PERIOD"        [PER] : Endif
If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:GAC])=0 : Local File =DOSSIER+".GACCOUNT"      [GAC] : Endif
If clalev([F:BLP])=0 : Local File =DOSSIER+".BALPRECSL"     [BLP] : Endif

If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0 : Local File =DOSSIER+".GLED"          [LED] : Endif
If clalev([F:COA])=0 : Local File =DOSSIER+".GCOA"          [COA] : Endif

If clalev([F:CLS])=0 : Local File =DOSSIER+".GACCCLS"       [CLS] : Endif
If clalev([F:CCE])=0 : Local File =DOSSIER+".CACCE"         [CCE] : Endif
If clalev([F:IDTC])=0: Local File =DOSSIER+".IDTCCE"       [IDTC] : Endif
If clalev([F:TCU])=0 : Local File =DOSSIER+".TABCUR"        [TCU] : Endif

If clalev([F:HAE])=0 : Local File =DOSSIER+".GACCENTRY"     [HAE] : Endif
If clalev([F:DAE])=0 : Local File =DOSSIER+".GACCENTRYD"    [DAE] : Endif
If clalev([F:DAA])=0 : Local File =DOSSIER+".GACCENTRYA"    [DAA] : Endif

If clalev([F:HAT])=0 : Local File =DOSSIER+".GACCTMP"       [HAT] : Endif
If clalev([F:DAT])=0 : Local File =DOSSIER+".GACCTMPD"      [DAT] : Endif

If clalev([F:ADW9])=0: Local File =DOSSIER+".ADOVAL"        [ADW9] : Endif
Return

##########################################################################################################
$INIT
Gosub OUVRE
TMP = 1
Return

##########################################################################################################
$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Return

##########################################################################################################
$EXEC
Local Integer NBRERR
NBRERR = 0
Call RECUPBLP([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]LEDTYP,[M:DIA]EXERCICE,[M:DIA]DEVISE,
&             [M:DIA]BALCSL,[M:DIA]COMPTE,GSERVEUR,NBRERR)
TRA = 1
Return

##########################################################################################################
Subprog RECUPBLP(COMPANY,ALLSITE,SITE,LEDTYP,FIY,CUR,BALCSL,ACC,BATCH,NBRERR)
Value    Char    COMPANY
Value    Integer ALLSITE
Value    Char    SITE
Value    Integer LEDTYP
Value    Integer FIY
Value    Char    CUR
Value    Integer BALCSL
Value    Char    ACC
Value    Integer BATCH
Variable Integer NBRERR             # Number of errors

Local Char DOSSIER(GLONADP)
DOSSIER = nomap

If dim(GEXEAN)<0 : Call EXEAN From GLOBCPT : Endif

$RECUP
Gosub OUVRE
Local Integer MAXPER             # Max number of period
MAXPER = func AFNC.ACTIV("PER")
Local Integer TEST               # Variable allowing to add elements to the log file
Local Integer FLGL               # Flag to make difference between balance verification and ledger verification
Local Integer OK                 # Flag to check the mono company.

Local Char    FILTECT(250)(0..4) # Criteria to filter the entries
Local Integer IFILE              # Index of the criteria that filters the entries

Local Char    FILTHAT(250)(0..4) # Criteria to filter in the temporary tables, the remaining recordings to be posted
Local Integer IFILH              # Index of the criteria

Local Date    DATDEB , DATFIN    # Start date and end date of the fiscal year
Local Char    CURBAL(GLONCUR)    # Currency of the balance recording
Local Char    SITBAL(GLONFCY)    # Site of the balance recording
Local Char    ACCBAL(GLONGAC)    # Account of the balance recording
Local Char    BPRBAL(GLONBPR)    # Bpartner of the balance recording

# Detailed log file if TEST=1
TEST  = 0

#-- Balance verification : No criteria for the account
If BALCSL=1 : ACC = "" :  Endif

If !BATCH
 If BALCSL=3
  Call OUVRE_TRACE(mess(54,116,1)) From LECFIC
 Else
  Call OUVRE_TRACE(mess(182,116,1)) From LECFIC
 Endif
Endif

If !TEST & BALCSL=3
 Call MONOCPY(COMPANY, OK) From AX3MONO
 If !OK : Goto FIN : Endif
Endif

If COMPANY<>[F:FIY]CPY | [L]LEDTYP<>[F:FIY]LEDTYP | FIY<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = COMPANY;[L]LEDTYP;FIY
 If fstat
  Call ECR_TRACE(COMPANY-num$(FIY)-mess(52,116,1),1) From GESECRAN  # Exercice incorrect
  NBRERR = 1 : Goto FIN
 Endif
Endif

DATDEB = [F:FIY]FIYSTR
DATFIN = [F:FIY]FIYEND

Gosub VERF_HAT

Read [LNK] First
If !fstat
 If BALCSL=3
  Call ECR_TRACE(mess(186,123,1)+"."-mess(49,114,1),1) From GESECRAN
  Goto FIN
 Else
  Call ECR_TRACE(mess(43,187,1)+"."-mess(49,114,1),-1) From GESECRAN
 Endif
Endif

Case BALCSL
 When 1
  FLGL = 0 : Gosub TSTBLP # Balance Verification
 When 2
  FLGL = 1 : Gosub TSTBLP # Ledger Verification
 When 3
  Gosub RECBLP
Endcase


$FIN
If BALCSL=3
 Call MULTICPY(COMPANY) From AX3MONO
Endif
If !BATCH
 Call FERME_TRACE From LECFIC
Endif
End


#########################################################################################################
## Balance Verification / Ledger Verification
#########################################################################################################
$TSTBLP
NBRERR = 0

#-- Log file head
Call ECR_TRACE(mess(182,116,1),0) From GESECRAN                       # Balance verification
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(format$("K:30X",mess(2,116,1))+" : "+COMPANY,0) From GESECRAN                # Company
Call ECR_TRACE(format$("K:30X",mess(208,111,1))+" : "+mess([L]LEDTYP,2644,1),0) From GESECRAN : # Ledger
Call ECR_TRACE(format$("K:30X",mess(3,116,1))+" : "+num$(FIY),0) From GESECRAN              # Fiscal year
If ALLSITE=2
 Call ECR_TRACE(format$("K:30X",mess(5,116,1))+" : "+mess(4,116,1),0) From GESECRAN                       # All sites
Elsif SITE<>""
 Call ECR_TRACE(format$("K:30X",mess(5,116,1))+" : "+SITE,0) From GESECRAN                  # Site
Endif
If CUR<>""
 Call ECR_TRACE(format$("K:30X",mess(55,116,1))+" : "+CUR,0) From GESECRAN                  # Currency
Endif
If ACC<>""
 Call ECR_TRACE(format$("K:30X",mess(56,116,1))+" : "+ACC,0) From GESECRAN                  # Account
Endif
Call ECR_TRACE(format$("K:30X",mess(108,197,1))+" : "+mess(BALCSL,643,1),0) From GESECRAN   # Balance / Ledger
Call ECR_TRACE("",0) From GESECRAN

#-- Beginning of the verification
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Gosub VERIF

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- End of the verification
If NBRERR
 Call ECR_TRACE(num$(NBRERR)-mess(7,116,1),0) From GESECRAN
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN
Endif
Return

######################################################################################
$VERIF

Local Decimal BALDEB(0..MAXPER), BALCRE(0..MAXPER)       # Amounts in transcation currency in the balance table
Local Decimal BALDEBLED(0..MAXPER), BALCRELED(0..MAXPER) # Amounts in ledger currency in the balance table
Local Decimal GLDEB(0..MAXPER) , GLCRE(0..MAXPER)        # Amounts in transcation currency in DAE
Local Decimal GLDEBLED(0..MAXPER) , GLCRELED(0..MAXPER)  # Amounts in ledger currency in DAE
Local Integer P                                          # Index
Local Integer FLG1, FLG2                                 # Type of unbalanced amounts(transaction/ledger)
Local Integer ILED                                       # Index
Local Char    CODLED(GLONLED)                            # Code of the ledger
Local Char    CURLED(GLONCUR)                            # Currency of the ledger
Local Integer ASTATUS                                    # Return status
Local Integer IND                                        # Start index

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,COMPANY,LEDTYP,CODLED,CURLED,GMESSAGE)
If FLGL=1
 # Ledger Verification
 IND = 1
 ILED = find(CODLED,GLED(1..GLEDNBR))
 If !ILED : Return : Endif
 If GLEDFLGGEN(ILED)=2
  Call ECR_TRACE(mess(183,116,1),0) From GESECRAN
  Gosub VERIF_LED_GEN
 Endif
 If GLEDFLGANA(ILED)=2
  If GLEDFLGGEN(ILED)=2
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Endif
  Call ECR_TRACE(mess(184,116,1),0) From GESECRAN
  Gosub VERIF_LED_ANA
 Endif
Elsif FLGL=0
 # Balance Verification
 Call LEC_LED(CODLED) From CPTLEC
 Gosub VERIF_BAL
Endif
Return

######################################################################################
## Ledger Verification
$VERIF_LED_GEN

Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAE]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAE]CPY="'+COMPANY+'"'," & ") From GOBJSUB
If SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAE]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
If ACC<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAE]ACC="'+ACC+'"'," & ") From GOBJSUB
Endif
If CUR<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAE]CUR="'+CUR+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

Link [DAE] With [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM As [LNK]
& Where evalue(FILTECT) & [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE = [F:DAE]ACC;[F:DAE]BPR;[F:DAE]FCYLIN;[F:DAE]CUR

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(1)       : # Account
 ACCBAL = [F:DAE]ACC
 For [LNK]CLE(2)      : # Bpartner
  BPRBAL = [F:DAE]BPR
  For [LNK]CLE(3)     : # Site
   SITBAL = [F:DAE]FCYLIN
   For [LNK]CLE(4)    : # Currency
    CURBAL = [F:DAE]CUR
    Raz GLDEB, GLDEBLED, GLCRE, GLCRELED
    For [LNK]CLE
     If [F:DAE]SNS>0
      GLDEB([F:DAE]PER)    += [F:DAE]AMTCUR
      GLDEBLED([F:DAE]PER) += [F:DAE]AMTLED
     Else
      GLCRE([F:DAE]PER)    += [F:DAE]AMTCUR
      GLCRELED([F:DAE]PER) += [F:DAE]AMTLED
     Endif
    Next
    Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
    Filter [BLP] Where LEDTYP=[L]LEDTYP & CPY=COMPANY & CUR=CURBAL & FCY=SITBAL & ACC=ACCBAL & BPR=BPRBAL & IDTCCE=0 & FIY=[L]FIY
    Gosub TST_VERIF_LED
    Filter [BLP]
   Next
  Next
 Next
Next
Gosub UNSET_FIRST From TRTFIRST
Return

##

$VERIF_LED_ANA

Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+COMPANY+'"'," & ") From GOBJSUB
If SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAA]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
If ACC<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAA]ACC="'+ACC+'"'," & ") From GOBJSUB
Endif
If CUR<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+CUR+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

Link [DAA] With [F:HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM,
&               [F:DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP
& As [LNK]
& Where evalue(FILTECT) & [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE = [F:DAA]ACC;[F:DAA]BPR;[F:DAA]FCYLIN;[F:DAA]CUR

Gosub SET_FIRST From TRTFIRST

For [LNK]CLE(1)       : # Account
 ACCBAL = [F:DAE]ACC
 For [LNK]CLE(2)      : # Bpartner
  BPRBAL = [F:DAE]BPR
  For [LNK]CLE(3)     : # Site
   SITBAL = [F:DAE]FCYLIN
   For [LNK]CLE(4)    : # Currency
    CURBAL = [F:DAE]CUR
    Raz GLDEB, GLDEBLED, GLCRE, GLCRELED
    For [LNK]CLE
     If [F:DAA]SNS>0
      GLDEB([F:DAE]PER)    += [F:DAA]AMTCUR
      GLDEBLED([F:DAE]PER) += [F:DAA]AMTLED
     Else
      GLCRE([F:DAE]PER)    += [F:DAA]AMTCUR
      GLCRELED([F:DAE]PER) += [F:DAA]AMTLED
     Endif
    Next
    Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
    Filter [BLP] Where LEDTYP=[L]LEDTYP & CPY=COMPANY & CUR=CURBAL & FCY=SITBAL & ACC=ACCBAL & BPR=BPRBAL & IDTCCE<>0 & FIY=[L]FIY
    Gosub TST_VERIF_LED
    Filter [BLP]
   Next
  Next
 Next
Next
Gosub UNSET_FIRST From TRTFIRST
Return

######################################################################################
$TST_VERIF_LED
If TEST : Call ECR_TRACE(time$-"TST_VERIF_LED"-ACCBAL-BPRBAL-SITBAL-CURBAL,0) From GESECRAN : Endif
For [BLP]
 For P=IND To MAXPER-1
  BALDEB(P)    += [F:BLP]DEB(P)
  BALCRE(P)    += [F:BLP]CDT(P)
  BALDEBLED(P) += [F:BLP]DEBLED(P)
  BALCRELED(P) += [F:BLP]CDTLED(P)
 Next
Next

For P=IND To MAXPER-1
 # Montant Transaction et Montant référentiel
 Raz FLG1, FLG2
 If BALDEB(P)<>GLDEB(P) | BALCRE(P)<>GLCRE(P)             : FLG1=1 : Endif
 If BALDEBLED(P)<>GLDEBLED(P) | BALCRELED(P)<>GLCRELED(P) : FLG2=1 : Endif

 If FLG1 or FLG2
  Read [PER]PER0 = COMPANY;LEDTYP;FIY;P
  Call ECR_TRACE(mess(58,116,1)-ACCBAL-BPRBAL-SITBAL-CURBAL,1) From GESECRAN
  NBRERR +=1
  Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)-format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN

  If FLG1
   Call LEC_TCU(CURBAL) From CPTLEC
   Call ECR_TRACE(format$("K:60X",mess(60,116,1)-mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(86,115,1))
&                +format$("N:"+[F:TCU]CURFMT1,BALDEB(P))+" "+CURBAL+"   "
&                +format$("N:"+[F:TCU]CURFMT1,BALCRE(P))+" "+CURBAL,0) From GESECRAN
   Call ECR_TRACE(format$("K:60X",mess(61,116,1)-mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(86,115,1))
&                +format$("N:"+[F:TCU]CURFMT1,GLDEB(P))+" "+CURBAL+"   "
&                +format$("N:"+[F:TCU]CURFMT1,GLCRE(P))+" "+CURBAL,0) From GESECRAN
  Endif

  If FLG2
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:60X",mess(60,116,1)-mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(1,2619,1))
&                 +format$("N:"+[F:TCU]CURFMT1,BALDEBLED(P))+" "+CURLED+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,BALCRELED(P))+" "+CURLED,0) From GESECRAN

   Call ECR_TRACE(format$("K:60X",mess(61,116,1)-mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(1,2619,1))
&                 +format$("N:"+[F:TCU]CURFMT1,GLDEBLED(P))+" "+CURLED+"   "
&                 +format$("N:"+[F:TCU]CURFMT1,GLCRELED(P))+" "+CURLED,0) From GESECRAN
   Endif
  Endif
 Next P
Return

######################################################################################
## Balance Verification
$VERIF_BAL

Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:BLP]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:BLP]CPY="'+COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FIY",'[F:BLP]FIY='+num$(FIY)," & ") From GOBJSUB
If CUR<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:BLP]CUR="'+CUR+'"'," & ") From GOBJSUB
Endif
If [F:LED]FCYBAL=2 & ALLSITE<>2 :# There is also the control in C_BALCSL
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:BLP]FCY="'+SITE+'"'," & ") From GOBJSUB
Endif

 If [F:LED]EQLRANANA=2 : # Balance carry forward / Equilibre report à nouveau
  IND = 0
 Else
  IND = 1
 Endif

# idtcce = 0 : General
If [F:LED]GEN=2
 Call ECR_TRACE(mess(180,116,1),0) From GESECRAN
 Filter [BLP] Where evalue(FILTECT) & IDTCCE=0
 Gosub SET_FIRST From TRTFIRST
 Gosub CAL_VERIF_BAL
 Gosub UNSET_FIRST From TRTFIRST
 Filter [BLP]
Endif

# idtcce<>0 : Analytical
If [F:LED]ANA=2 & [F:LED]DIEIPT=2 : # Stockage des imputations vides = Oui / Summarize empty allocations = Yes
 If [F:LED]GEN=2
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
 Call ECR_TRACE(mess(181,116,1),0) From GESECRAN
 Filter [BLP] Where evalue(FILTECT) & IDTCCE<>0
 Gosub SET_FIRST From TRTFIRST
 Gosub CAL_VERIF_BAL
 Gosub UNSET_FIRST From TRTFIRST
 Filter [BLP]
Endif
Return

######################################################################################
$CAL_VERIF_BAL

For [BLP]BLP2(3) : # Currency
 CURBAL = [F:BLP]CUR
 Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
 For [BLP]BLP2(4) : # Site
  SITBAL = [F:BLP]FCY
  If [F:LED]FCYBAL=2
   Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
  Endif
  For [BLP]BLP2
   For P=IND To MAXPER-1
    BALDEB(P)    += [F:BLP]DEB(P)
    BALCRE(P)    += [F:BLP]CDT(P)
    BALDEBLED(P) += [F:BLP]DEBLED(P)
    BALCRELED(P) += [F:BLP]CDTLED(P)
   Next
  Next
  If [F:LED]FCYBAL=2
   Gosub TST_VERIF_BAL
  Endif
 Next
 If [F:LED]FCYBAL<>2
  Gosub TST_VERIF_BAL
 Endif
Next
Return

######################################################################################
$TST_VERIF_BAL

If TEST : Call ECR_TRACE(time$-"VERIF_BAL"-CURBAL-SITBAL,0) From GESECRAN : Endif
For P=IND To MAXPER-1
 Raz FLG1, FLG2
 If BALDEB(P)<>BALCRE(P)       : FLG1=1 : Endif : # Unbalanced for transaction amount
 If BALDEBLED(P)<>BALCRELED(P) : FLG2=1 : Endif : # Unbalanced for ledger amount

 If FLG1 or FLG2
  Read [PER]PER0 = COMPANY;LEDTYP;FIY;P
  # Error
  If [F:LED]FCYBAL=2
   Call ECR_TRACE(mess(58,116,1)-CURBAL-SITBAL-mess(64,116,1),1) From GESECRAN
  Else
   Call ECR_TRACE(mess(58,116,1)-CURBAL-mess(64,116,1),1) From GESECRAN
  Endif
  NBRERR += 1
  If P=0
   Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN
  Else
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)-format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN
  Endif

  If FLG1 : # Unbalanced for transaction amount
   Call LEC_TCU(CURBAL) From CPTLEC
   Call ECR_TRACE(format$("K:50X",mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(86,115,1))+num$(BALDEB(P))+" "+CURBAL+"   "+num$(BALCRE(P))+" "+CURBAL,0) From GESECRAN
  Endif

  If FLG2 : # Unbalanced for ledger amount
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:50X",mess(32,109,1)+"/"+mess(33,109,1)-"-"-mess(1,2619,1))+num$(BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                +num$(BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN
  Endif
 Endif
Next
Return

######################################################################################
# Check if there are recordings to be posted, in the temporary tables
$VERF_HAT

Raz FILTHAT, IFILH

Call ADDCRIT(FILTHAT,IFILH,"LEDTYP",'[F:DAT]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTHAT,IFILH,"CPY",'[F:DAT]CPY="'+COMPANY+'"'," & ") From GOBJSUB
If SITE<>""
 Call ADDCRIT(FILTHAT,IFILH,"FCY",'[F:DAT]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTHAT,IFILH,"FIY",'FIY='+num$(FIY)," & ") From GOBJSUB
If ACC<>""
 Call ADDCRIT(FILTHAT,IFILH,"ACC",'[F:DAT]ACC="'+ACC+'"'," & ") From GOBJSUB
Endif
If CUR<>""
 Call ADDCRIT(FILTHAT,IFILH,"CUR",'[F:DAT]CUR="'+CUR+'"'," & ") From GOBJSUB
Endif

Link [DAT] With [HAT]HAT0~=[F:DAT]TYP;[F:DAT]NUM As [LNK]
&              Where [F:HAT]FLG>=100 & evalue(FILTHAT)
Return

#########################################################################################################
## Resynchronisation de la balance  / Balance  Resynchronisation
#########################################################################################################
$RECBLP
NBRERR = 0

# Common variable declaration
Local Integer ILED                    # Index
Local Char    CODLED(GLONLED)         # Code of the ledger
Local Char    CURLED(GLONCUR)         # Currency of the ledger
Local Integer ASTATUS                 # Return status
Local Integer IND                     # Start index

[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX,COMPANY,LEDTYP,CODLED,CURLED,GMESSAGE)
ILED = find(CODLED,GLED(1..GLEDNBR))
If !ILED : Return : Endif
Call LEC_LED([L]CODLED) From CPTLEC
Call LEC_COA([F:LED]COA) From CPTLEC

# Variables to Update Balance
Local Decimal DEBCUR(0..MAXPER),CRECUR(0..MAXPER)   # Amounts in transcation currency in the balance table
Local Decimal DEBLED(0..MAXPER),CRELED(0..MAXPER)   # Amounts in ledger currency in the balance table
Local Integer BALFIY, BALRAN, BALIDT
Local Char    BALFCY(GLONFCY),BALBPR(GLONBPR), BALACC(GLONGAC),BALCSLFLO(GLONADI), BALCSLBPR(GLONBPR)
Local Char    BALCCE1(GLONCCE),BALCCE2(GLONCCE),BALCCE3(GLONCCE),BALCCE4(GLONCCE)
Local Char    BALCCE5(GLONCCE),BALCCE6(GLONCCE),BALCCE7(GLONCCE),BALCCE8(GLONCCE),BALCCE9(GLONCCE)

# Variables linked to the filter
Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

# Variables to Handle Loops Ruptures
Local Char    CRITERE(255), CRITERE2(255)
Local Char    TABKEY(30)(1..16)
Local Integer STOP, NBR

## Variables linked to the Carry-Forward
Local Integer ISOC, WRAN, WRANA, NBRPER
Local Char    RANCSLFLO(GLONADI), RANACC(GLONGAC)
WRAN = 1
Read [ADW9]ADW0 = "";"";"FRWGAC"
If !fstat : WRAN = val([F:ADW9]VALEUR) : Endif
WRANA = 1
Read [ADW9]ADW0 = "";"";"FRWANA"
If !fstat : WRANA = val([F:ADW9]VALEUR) : Endif
ISOC   = find([L]COMPANY,GSOC(1..GNBSOC))
If ISOC = 0 : Return : Endif

If (WRAN=2 or WRANA=2) & GEXEAN(ISOC,LEDTYP)=[L]FIY
 If [F:LED]EQLRANANA=2
  If fstat or [F:COA]ACCMIS(10)=""
   GOK = 0 : Call ECR_TRACE(mess(106,106,1)-"("+[F:LED]COA+")",1) From GESECRAN : Return
  Else
   [L]RANACC = [F:COA]ACCMIS(10)
  Endif
 Endif

 Local Integer LPRCSL : # X3-104535
 LPRCSL = func AFNC.ACTIV("PRCSL")
 If LPRCSL = G_OUI
  [L]RANCSLFLO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,[L]COMPANY,"CSLFRWFLO")
 Endif : # X3-104535
Endif

# Variables to Update Analytical Balance
Local Integer NBRAXI, LNKKEY, AXE
Local Char    WCCE(GLONCCE)
Local Char    TDIE(GLONDIE)(0..dim([F:LED]DIE)-1)
Local Char    TCCE(GLONCCE)(0..dim([F:LED]DIE)-1)

#-- Log file head
Call ECR_TRACE(mess(54,116,1),0) From GESECRAN                       # Balance recovery
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(format$("K:30X",mess(2,116,1))+" : "+[L]COMPANY,0) From GESECRAN                # Company
Call ECR_TRACE(format$("K:30X",mess(208,111,1))+" : "+mess([L]LEDTYP,2644,1),0) From GESECRAN : # Ledger
Call ECR_TRACE(format$("K:30X",mess(3,116,1))+" : "+num$([L]FIY),0) From GESECRAN              # Fiscal year
If ALLSITE=2
 Call ECR_TRACE(format$("K:30X",mess(5,116,1))+" : "+mess(4,116,1),0) From GESECRAN         # All sites
Elsif SITE<>""
 Call ECR_TRACE(format$("K:30X",mess(5,116,1))+" : "+SITE,0) From GESECRAN                  # Site
Endif
If CUR<>""
 Call ECR_TRACE(format$("K:30X",mess(55,116,1))+" : "+CUR,0) From GESECRAN                  # Currency
Endif
If ACC<>""
 Call ECR_TRACE(format$("K:30X",mess(56,116,1))+" : "+ACC,0) From GESECRAN                  # Account
Endif
Call ECR_TRACE(format$("K:30X",mess(108,197,1))+" : "+mess(BALCSL,643,1),0) From GESECRAN   # Balance / Ledger
Call ECR_TRACE("",0) From GESECRAN

#-- Beginning of the resynchronization
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#-- Reset to Zero
Gosub RAZBLP
If GOK<1 : Return : Endif

#-- Resynchronization by site
If ALLSITE=2 or SITE=""
 For [FCY]FCY0 Where LEGCPY=COMPANY & FINFLG=2
  SITE = [F:FCY]FCY
  If GLEDFLGGEN(ILED)=2 : Gosub REC_LED_GEN : Endif
  If GLEDFLGANA(ILED)=2 : Gosub REC_LED_ANA : Endif
 Next
Else
 If GLEDFLGGEN(ILED)=2 : Gosub REC_LED_GEN : Endif
 If GLEDFLGANA(ILED)=2 : Gosub REC_LED_ANA : Endif
Endif
Return

#-- End of the verification
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Return


#------------------------------------------------------------------------------------------------
## Resynchronisation de la balance générale (DAE) / General Balance Resynchronisation
#------------------------------------------------------------------------------------------------

$REC_LED_GEN
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAE]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAE]CPY="'+[L]COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAE]FCYLIN="'+[L]SITE+'"'," & ") From GOBJSUB
If ACC<>"" : Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAE]ACC="'+[L]ACC+'"'," & ") From GOBJSUB : Endif
If CUR<>"" : Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAE]CUR="'+[L]CUR+'"'," & ") From GOBJSUB : Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

Link [DAE] With [F:HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM, [F:GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC, [F:CLS]CLS0~=[F:COA]LEGCLS;[F:GAC]CLSCOD As [LNK]
& Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE =  [F:DAE]CPY;[F:DAE]FCYLIN;[F:DAE]LEDTYP;[F:DAE]ACC;[F:DAE]BPR;[F:DAE]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;[F:DAE]PER;[F:DAE]ACCNUM

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST


$LOOP_BLP_GEN
Raz NBR

If STOP = 1
 STOP = 2
 CRITERE = "[F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAE]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"'"
&      +" & [F:DAE]CSLBPR='"+TABKEY(5)+"' & [F:DAE]PER="+TABKEY(6)+" & [F:DAE]ACCNUM>"+TABKEY(7)
Elsif STOP = 2
 STOP = 3
 CRITERE = "  [F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR='"+TABKEY(2)+"'"
&        +" & [F:DAE]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"'"
&        +" & [F:DAE]CSLBPR='"+TABKEY(5)+"' & [F:DAE]PER>"+TABKEY(6)
Elsif STOP = 3
 STOP = 4
 CRITERE = "  [F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR='"+TABKEY(2)+"'"
&        +" & [F:DAE]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR>'"+TABKEY(5)+"'"
Elsif STOP = 4
 STOP = 5
 CRITERE = "  [F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR='"+TABKEY(2)+"'"
&        +" & [F:DAE]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO>'"+TABKEY(4)+"'"
Elsif STOP = 5
 STOP = 6
 CRITERE = "[F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR='"+TABKEY(2)+"' & [F:DAE]CUR>'"+TABKEY(3)+"'"
Elsif STOP = 6
 STOP = 7
 CRITERE = "[F:DAE]ACC='"+TABKEY(1)+"' & [F:DAE]BPR>'"+TABKEY(2)+"'"
Elsif STOP = 7
 STOP = 0
 CRITERE = "[F:DAE]ACC>'"+TABKEY(1)+"'"
Else
 CRITERE = "1=1"
Endif

GOK = 1
Trbegin [BLP]

For [LNK]CLE(5) Where evalue(CRITERE)        : # Company/Site/Ledger/Account/Buiness Partner
 If TEST : Call ECR_TRACE(time$-"bal gen"-[F:DAE]FCYLIN-[F:DAE]ACC-[F:DAE]BPR,0) From GESECRAN : Endif
 For [LNK]CLE(8)
  Raz DEBCUR, DEBLED
  Raz CRECUR, CRELED
  For [LNK]CLE
   If [F:DAE]SNS>0
    DEBCUR([F:DAE]PER) += [F:DAE]AMTCUR
    DEBLED([F:DAE]PER) += [F:DAE]AMTLED
   Else
    CRECUR([F:DAE]PER) += [F:DAE]AMTCUR
    CRELED([F:DAE]PER) += [F:DAE]AMTLED
   Endif
  Next
  BALRAN = 0 : Gosub MAJBLP_GEN
  If GOK<1 : Break 2 : Endif

  #-- Carry-forward in real time
  If WRAN=2 & GEXEAN(ISOC,LEDTYP)=[L]FIY
   BALRAN = 1 : Gosub MAJBLP_GEN
   If GOK<1 : Break 2 : Endif
  Endif

  NBR+=1
  If NBR>GMAXUPDTRS
   TABKEY(1)= [F:DAE]ACC
   TABKEY(2)= [F:DAE]BPR
   TABKEY(3)= [F:DAE]CUR
   TABKEY(4)= [F:DAE]CSLFLO
   TABKEY(5)= [F:DAE]CSLBPR
   TABKEY(6)= num$([F:DAE]PER)
   TABKEY(7)= num$([F:DAE]ACCNUM)
   STOP=1
   Break 2
  Endif
 Next
Next
If GOK<1
 Rollback
Else
 Commit
Endif
If STOP
 If TEST : Call ECR_TRACE(time$-"break"-num$(STOP)-"/"-TABKEY(1)-TABKEY(2)-TABKEY(3)-TABKEY(4)-TABKEY(5)-TABKEY(6)-TABKEY(7),0) From GESECRAN : Endif
 Goto LOOP_BLP_GEN
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [DAE]
Return

$MAJBLP_GEN
If !BALRAN
 [L]BALFIY    = [L]FIY
 [L]BALACC    = [F:DAE]ACC
 [L]BALBPR    = [F:DAE]BPR
 [L]BALCSLFLO = [F:DAE]CSLFLO
 [L]BALCSLBPR = [F:DAE]CSLBPR
Else
 #-- Carry-forward in real time
 [L]BALFIY = [L]FIY+1
 If [F:CLS]ERA <> 2
  If  [F:LED]EQLRANANA=2
   [L]BALACC    = [L]RANACC
   [L]BALBPR    = ""
   [L]BALCSLFLO = [L]RANCSLFLO
   [L]BALCSLBPR = ""
  Else
   Return
  Endif
 Else
  [L]BALACC    = [F:DAE]ACC
  [L]BALBPR    = [F:DAE]BPR
  [L]BALCSLFLO = [L]RANCSLFLO
  [L]BALCSLBPR = [F:DAE]CSLBPR
 Endif
Endif

Readlock [BLP]BLP0 = [L]LEDTYP;[L]COMPANY;[L]SITE;[L]BALFIY;[L]BALACC;[L]BALBPR;[L]BALCSLFLO;[L]BALCSLBPR;0;[F:DAE]CUR
If fstat
 Raz [F:BLP]
 [F:BLP]LEDTYP = [L]LEDTYP
 [F:BLP]CPY    = [L]COMPANY
 [F:BLP]FCY    = [L]SITE
 [F:BLP]FIY    = [L]BALFIY
 [F:BLP]ACC    = [L]BALACC
 [F:BLP]BPR    = [L]BALBPR
 [F:BLP]CSLFLO = [L]BALCSLFLO
 [F:BLP]CSLBPR = [L]BALCSLBPR
 [F:BLP]CUR    = [F:DAE]CUR
 [F:BLP]ACCNUM = uniqid([F:BLP])
 [F:BLP]LED    = [L]CODLED
 [F:BLP]COA    = GLEDCOA(ILED)
 [F:BLP]CURLED = [L]CURLED
 Gosub CALBLP
 Write [BLP]
Else
 [F:BLP]LED    = [L]CODLED
 [F:BLP]COA    = GLEDCOA(ILED)
 [F:BLP]CURLED = [L]CURLED
 [F:BLP]CCE1   = ""
 [F:BLP]CCE2   = ""
 [F:BLP]CCE3   = ""
 [F:BLP]CCE4   = ""
 [F:BLP]CCE5   = ""
 [F:BLP]CCE6   = ""
 [F:BLP]CCE7   = ""
 [F:BLP]CCE8   = ""
 [F:BLP]CCE9   = ""
 Gosub CALBLP
 Rewrite [BLP]
Endif
If fstat
 GOK=0 : Call FSTA("BLP") From GLOCK : Return
Endif
Return

$CALBLP
If !BALRAN
 For K=1 To MAXPER-1
  [F:BLP]DEB(K)    += DEBCUR(K)
  [F:BLP]CDT(K)    += CRECUR(K)
  [F:BLP]DEBLED(K) += DEBLED(K)
  [F:BLP]CDTLED(K) += CRELED(K)
 Next K
Else
 #-- Carry-forward in real time
 [F:BLP]DEB(0)    += sum(DEBCUR(1..MAXPER-1))
 [F:BLP]CDT(0)    += sum(CRECUR(1..MAXPER-1))
 [F:BLP]DEBLED(0) += sum(DEBLED(1..MAXPER-1))
 [F:BLP]CDTLED(0) += sum(CRELED(1..MAXPER-1))
 If [F:BLP]DEB(0)>[F:BLP]CDT(0)
  [F:BLP]DEB(0) = [F:BLP]DEB(0) - [F:BLP]CDT(0)
  [F:BLP]CDT(0) = 0
 Else
  [F:BLP]CDT(0) = [F:BLP]CDT(0) - [F:BLP]DEB(0)
  [F:BLP]DEB(0) = 0
 Endif
 If [F:BLP]DEBLED(0)>[F:BLP]CDTLED(0)
  [F:BLP]DEBLED(0) = [F:BLP]DEBLED(0) - [F:BLP]CDTLED(0)
  [F:BLP]CDTLED(0) = 0
 Else
  [F:BLP]CDTLED(0) = [F:BLP]CDTLED(0) - [F:BLP]DEBLED(0)
  [F:BLP]DEBLED(0) = 0
 Endif
Endif
Return

$RAZBLP
# NBRPER = Number of period
# Perf of Loop...
Filter [PER] Where CPY=[L]COMPANY & FIYNUM=[L]FIY & LEDTYP=[L]LEDTYP
Read [PER]PER0 Last
If !fstat : NBRPER=[F:PER]PERNUM : Endif
Filter [PER]

If ALLSITE=2 or SITE=""
 For [FCY]FCY0 Where LEGCPY=[L]COMPANY & FINFLG=2
  BALFCY = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<1 : Break : Endif
  If WRAN=2 & GEXEAN(ISOC,LEDTYP)=[L]FIY : # Carry-forward in real time
   Gosub TR11
   If GOK<1 : Break : Endif
  Endif
 Next
 If GOK<1 : Return : Endif
Else
 BALFCY = SITE
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<1 : Return : Endif
 If WRAN=2 & GEXEAN(ISOC,LEDTYP)=[L]FIY : # Carry-forward in real time
  Gosub TR11
  If GOK<1 : Return : Endif
 Endif
Endif
Return

$TR1
If TEST : Call ECR_TRACE(time$-"raz n"-BALFCY-"/"-num$(NBRPER),0) From GESECRAN : Endif
GOK = 1

Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+[L]COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FCY",'FCY="'+[L]BALFCY+'"'," & ") From GOBJSUB
If ACC<>"" : Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+[L]ACC+'"'," & ") From GOBJSUB : Endif
If CUR<>"" : Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+[L]CUR+'"'," & ") From GOBJSUB : Endif

Trbegin [BLP]
For I=1 To NBRPER
 Update [BLP] Where evalue(FILTBAL) & [F:BLP]FIY=[L]FIY
&             With DEB(I)=0 , CDT(I)=0 , DEBLED(I)=0 , CDTLED(I)=0
 If fstat=1
  GOK = -1 : Break
 Endif
Next
If GOK = -1  :  GLOCK = "$BALPRECSL" : Goto ROLL_TR1 : Endif
Commit
Return

$TR11
If TEST : Call ECR_TRACE(time$-"raz n+1"-BALFCY-"/0",0) From GESECRAN : Endif
GOK = 1

Trbegin [BLP]
Update [BLP] Where evalue(FILTBAL) & [F:BLP]FIY=[L]FIY+1
&            With DEB(0)=0 , CDT(0)=0 , DEBLED(0)=0 , CDTLED(0)=0
If fstat
 GOK = 0 : Call FSTA("BLP") From GLOCK : Goto AB_TR11
Endif

Commit
Return

$AB_TR1
$AB_TR11
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

#------------------------------------------------------------------------------------------------
## Resynchronisation de la balance analytique (DAA) / Analytical Balance Resynchronisation
#------------------------------------------------------------------------------------------------

$REC_LED_ANA
NBRAXI = GLEDDIENBR(ILED)
If !NBRAXI : Return : Endif

Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAA]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAA]CPY="'+[L]COMPANY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAA]FCYLIN="'+[L]SITE+'"'," & ") From GOBJSUB
If ACC<>"" : Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAA]ACC="'+[L]ACC+'"'," & ") From GOBJSUB : Endif
If CUR<>"" : Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAA]CUR="'+[L]CUR+'"'," & ") From GOBJSUB : Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAA]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

Filter [DAA] Where evalue(FILTECT)
Look [DAA] First
If fstat : Return : Endif

Link [DAA] With [F:HAE]HAE0~=[F:DAA]TYP;[F:DAA]NUM, [F:DAE]DAE0~=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP,
&                 [F:GAC]GAC0~=[F:DAA]COA;[F:DAA]ACC, [F:CLS]CLS0~=[F:COA]LEGCLS;[F:GAC]CLSCOD
& As [LNK]

Case NBRAXI
 When 1
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 6
 When 2
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 7
 When 3
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 8
 When 4
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 9
 When 5
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]CCE(4);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 10
 When 6
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]CCE(4);[F:DAA]CCE(5);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 11
 When 7
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]CCE(4);[F:DAA]CCE(5);[F:DAA]CCE(6);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 12
 When 8
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]CCE(4);[F:DAA]CCE(5);[F:DAA]CCE(6);[F:DAA]CCE(7);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 13
 When 9
  Filter [LNK] Where evalue(FILTECT) and [F:HAE]CAT<>3 & [F:HAE]CAT<>5
& Order By Key CLE=[F:DAA]ACC;[F:DAA]BPR;[F:DAA]CUR;[F:DAE]CSLFLO;[F:DAE]CSLBPR;
&                  [F:DAA]CCE(0);[F:DAA]CCE(1);[F:DAA]CCE(2);[F:DAA]CCE(3);[F:DAA]CCE(4);[F:DAA]CCE(5);[F:DAA]CCE(6);[F:DAA]CCE(7);[F:DAA]CCE(8);[F:DAA]ACCNUM;[F:DAA]ANALIN
  LNKKEY = 14
Endcase

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BLP_ANA
Raz NBR

If STOP = 1
 STOP = 2
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)='"+TABKEY(11)+"' & [F:DAA]CCE(6)='"+TABKEY(12)+"' & [F:DAA]CCE(7)='"+TABKEY(13)+"'"
&      +" & [F:DAA]CCE(8)='"+TABKEY(14)+"' & [F:DAA]ACCNUM="+TABKEY(15)+" & [F:DAA]ANALIN>"+TABKEY(16)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)='"+TABKEY(11)+"' & [F:DAA]CCE(6)='"+TABKEY(12)+"' & [F:DAA]CCE(7)='"+TABKEY(13)+"'"
&      +" & [F:DAA]CCE(8)='"+TABKEY(14)+"' & [F:DAA]ACCNUM>"+TABKEY(15)
Elsif STOP = 3
 STOP = 4
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)='"+TABKEY(11)+"' & [F:DAA]CCE(6)='"+TABKEY(12)+"' & [F:DAA]CCE(7)='"+TABKEY(13)+"'"
&      +" & [F:DAA]CCE(8)>'"+TABKEY(14)+"'"
Elsif STOP = 4
 STOP = 5
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)='"+TABKEY(11)+"' & [F:DAA]CCE(6)='"+TABKEY(12)+"' & [F:DAA]CCE(7)>'"+TABKEY(13)+"'"
Elsif STOP = 5
 STOP = 6
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)='"+TABKEY(11)+"' & [F:DAA]CCE(6)>'"+TABKEY(12)+"'"
Elsif STOP = 6
 STOP = 7
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)='"+TABKEY(10)+"'"
&      +" & [F:DAA]CCE(5)>'"+TABKEY(11)+"'"
Elsif STOP = 7
 STOP = 8
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)='"+TABKEY(9)+"' & [F:DAA]CCE(4)>'"+TABKEY(10)+"'"
Elsif STOP = 8
 STOP = 9
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)='"+TABKEY(8)+"'"
 CRITERE2 ="[F:DAA]CCE(3)>'"+TABKEY(8)+"'"
Elsif STOP = 9
 STOP = 10
CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"' & [F:DAE]CSLBPR='"+TABKEY(5)+"'"
&      +" & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)='"+TABKEY(7)+"' & [F:DAA]CCE(2)>'"+TABKEY(8)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 10
 STOP = 11
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"'"
&      +" & [F:DAE]CSLBPR='"+TABKEY(5)+"' & [F:DAA]CCE(0)='"+TABKEY(6)+"' & [F:DAA]CCE(1)>'"+TABKEY(7)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 11
 STOP = 12
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"'"
&      +" & [F:DAE]CSLBPR='"+TABKEY(5)+"' & [F:DAA]CCE(0)>'"+TABKEY(6)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 12
 STOP = 13
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO='"+TABKEY(4)+"'"
&      +" & [F:DAE]CSLBPR>'"+TABKEY(5)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 13
 STOP = 14
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR='"+TABKEY(3)+"' & [F:DAE]CSLFLO>'"+TABKEY(4)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 14
 STOP = 15
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR='"+TABKEY(2)+"'"
&      +" & [F:DAA]CUR>'"+TABKEY(3)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 15
 STOP = 16
 CRITERE = "[F:DAA]ACC='"+TABKEY(1)+"' & [F:DAA]BPR>'"+TABKEY(2)+"'"
 CRITERE2 ="1=1"
Elsif STOP = 16
 STOP = 0
 CRITERE = "[F:DAA]ACC>'"+TABKEY(1)+"'"
 CRITERE2 ="1=1"
Else
 CRITERE = "1=1"
 CRITERE2 ="1=1"
Endif

GOK = 1
Trbegin [BLP]

For [LNK]CLE(2) Where evalue(CRITERE) & evalue(CRITERE2)        : # Company/Site/Ledger/Account/Buiness Partner
 If TEST : Call ECR_TRACE(time$-"bal ana"-[F:DAA]FCYLIN-[F:DAA]ACC-[F:DAA]BPR,0) From GESECRAN : Endif
 For [LNK]CLE(LNKKEY)
  Raz DEBCUR, DEBLED
  Raz CRECUR, CRELED
  For [LNK]CLE
   If [F:DAA]SNS>0
    DEBCUR([F:DAE]PER) += [F:DAA]AMTCUR
    DEBLED([F:DAE]PER) += [F:DAA]AMTLED
   Else
    CRECUR([F:DAE]PER) += [F:DAA]AMTCUR
    CRELED([F:DAE]PER) += [F:DAA]AMTLED
   Endif
  Next
  BALRAN = 0 : Gosub MAJBLP_ANA
  If GOK<1 : Break 2 : Endif

  #-- Carry-forward in real time
  If WRAN=2 & GEXEAN(ISOC,LEDTYP)=[L]FIY
   BALRAN = 1 : Gosub MAJBLP_ANA
   If GOK<1 : Break 2 : Endif
  Endif

  NBR+=1
  If NBR>GMAXUPDTRS
   TABKEY(1) = [F:DAA]ACC
   TABKEY(2) = [F:DAA]BPR
   TABKEY(3) = [F:DAA]CUR
   TABKEY(4) = [F:DAE]CSLFLO
   TABKEY(5) = [F:DAE]CSLBPR
   TABKEY(6) = [F:DAA]CCE(0)
   TABKEY(7) = [F:DAA]CCE(1)
   TABKEY(8) = [F:DAA]CCE(2)
   TABKEY(9) = [F:DAA]CCE(3)
   TABKEY(10)= [F:DAA]CCE(4)
   TABKEY(11)= [F:DAA]CCE(5)
   TABKEY(12)= [F:DAA]CCE(6)
   TABKEY(13)= [F:DAA]CCE(7)
   TABKEY(14)= [F:DAA]CCE(8)
   TABKEY(15)= num$([F:DAA]ACCNUM)
   TABKEY(16)= num$([F:DAA]ANALIN)
   STOP=1
   Break 2
  Endif
 Next
Next
If GOK<1
 Rollback
Else
 Commit
Endif
If STOP
 If TEST :
  Call ECR_TRACE(time$-"break"-num$(STOP)-"/"-TABKEY(1)-TABKEY(2)-TABKEY(3)-TABKEY(4)-TABKEY(5)-TABKEY(6)-TABKEY(7)
&     -TABKEY(8)-TABKEY(9)-TABKEY(10)-TABKEY(11)-TABKEY(12)-TABKEY(13)-TABKEY(14)-TABKEY(15)-TABKEY(16),0) From GESECRAN
 Endif
 Goto LOOP_BLP_ANA
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [DAA]
Return

$MAJBLP_ANA
TDIE(0) = [F:DAA]DIE(0) : TCCE(0) = ""
TDIE(1) = [F:DAA]DIE(1) : TCCE(1) = ""
TDIE(2) = [F:DAA]DIE(2) : TCCE(2) = ""
TDIE(3) = [F:DAA]DIE(3) : TCCE(3) = ""
TDIE(4) = [F:DAA]DIE(4) : TCCE(4) = ""
TDIE(5) = [F:DAA]DIE(5) : TCCE(5) = ""
TDIE(6) = [F:DAA]DIE(6) : TCCE(6) = ""
TDIE(7) = [F:DAA]DIE(7) : TCCE(7) = ""
TDIE(8) = [F:DAA]DIE(8) : TCCE(8) = ""

If !BALRAN
 [L]BALFIY    = [L]FIY
 [L]BALACC    = [F:DAA]ACC
 [L]BALBPR    = [F:DAA]BPR
 [L]BALCSLFLO = [F:DAE]CSLFLO
 [L]BALCSLBPR = [F:DAE]CSLBPR
 [L]BALCCE1   = [F:DAA]CCE(0) : TCCE(0) = [F:DAA]CCE(0)
 [L]BALCCE2   = [F:DAA]CCE(1) : TCCE(1) = [F:DAA]CCE(1)
 [L]BALCCE3   = [F:DAA]CCE(2) : TCCE(2) = [F:DAA]CCE(2)
 [L]BALCCE4   = [F:DAA]CCE(3) : TCCE(3) = [F:DAA]CCE(3)
 [L]BALCCE5   = [F:DAA]CCE(4) : TCCE(4) = [F:DAA]CCE(4)
 [L]BALCCE6   = [F:DAA]CCE(5) : TCCE(5) = [F:DAA]CCE(5)
 [L]BALCCE7   = [F:DAA]CCE(6) : TCCE(6) = [F:DAA]CCE(6)
 [L]BALCCE8   = [F:DAA]CCE(7) : TCCE(7) = [F:DAA]CCE(7)
 [L]BALCCE9   = [F:DAA]CCE(8) : TCCE(8) = [F:DAA]CCE(8)
Else
 #-- Carry-forward in real time
 [L]BALFIY = [L]FIY+1
 If [F:CLS]ERA <> 2
  If [F:LED]EQLRANANA=2
   [L]BALACC    = [L]RANACC
   [L]BALBPR    = ""
   [L]BALCSLFLO = [L]RANCSLFLO
   [L]BALCSLBPR = ""
   Raz BALCCE1,BALCCE2,BALCCE3,BALCCE4,BALCCE5,BALCCE6,BALCCE7,BALCCE8,BALCCE9
  Else
   Return
  Endif
 Else
  [L]BALACC    = [F:DAA]ACC
  [L]BALBPR    = [F:DAA]BPR
  [L]BALCSLFLO = [L]RANCSLFLO
  [L]BALCSLBPR = [F:DAE]CSLBPR
  [L]BALCCE1   = [F:DAA]CCE(0)
  [L]BALCCE2   = [F:DAA]CCE(1)
  [L]BALCCE3   = [F:DAA]CCE(2)
  [L]BALCCE4   = [F:DAA]CCE(3)
  [L]BALCCE5   = [F:DAA]CCE(4)
  [L]BALCCE6   = [F:DAA]CCE(5)
  [L]BALCCE7   = [F:DAA]CCE(6)
  [L]BALCCE8   = [F:DAA]CCE(7)
  [L]BALCCE9   = [F:DAA]CCE(8)
 Endif
 For AXE=1 To dim([F:LED]DIE)
  WCCE  = evalue("[L]BALCCE"+num$(AXE))
  If TDIE(AXE-1)<>"" & WCCE<>""
   J = find(TDIE(AXE-1),GDIECOD(1..GDIENBR))
   If GDIEPRJ(J)=2
    WCCE = ""
   Else
    Call LEC_CCE(WCCE,TDIE(AXE-1)) From CPTLEC
    If [F:CCE]FRW<>2
     WCCE = ""
    Endif
   Endif
  Endif
  Case AXE
   When 1 : TCCE(0)= WCCE
   When 2 : TCCE(1)= WCCE
   When 3 : TCCE(2)= WCCE
   When 4 : TCCE(3)= WCCE
   When 5 : TCCE(4)= WCCE
   When 6 : TCCE(5)= WCCE
   When 7 : TCCE(6)= WCCE
   When 8 : TCCE(7)= WCCE
   When 9 : TCCE(8)= WCCE
  Endcase
 Next AXE
Endif

#-- Index BALIDT
Call GETIDTCCE([L]CODLED,[F:LED]DIE,TCCE,BALIDT) From CPTBAL
If GOK<1 : Return : Endif

Readlock [BLP]BLP0 = [L]LEDTYP;[L]COMPANY;[L]SITE;[L]BALFIY;[L]BALACC;[L]BALBPR;[L]BALCSLFLO;[L]BALCSLBPR;[L]BALIDT;[F:DAA]CUR
If fstat
 Raz [F:BLP]
 [F:BLP]LEDTYP = [L]LEDTYP
 [F:BLP]CPY    = [L]COMPANY
 [F:BLP]FCY    = [L]SITE
 [F:BLP]FIY    = [L]BALFIY
 [F:BLP]ACC    = [L]BALACC
 [F:BLP]BPR    = [L]BALBPR
 [F:BLP]CSLFLO = [L]BALCSLFLO
 [F:BLP]CSLBPR = [L]BALCSLBPR
 [F:BLP]IDTCCE = [L]BALIDT
 [F:BLP]CUR    = [F:DAA]CUR
 [F:BLP]ACCNUM = uniqid([F:BLP])
 Gosub INI_DATA
 Gosub CALBLP
 Write [BLP]
Else
 Gosub INI_DATA
 Gosub CALBLP
 Rewrite [BLP]
Endif
If fstat
 GOK=0 : Call FSTA("BLP") From GLOCK : Return
Endif
Return

$INI_DATA
[F:BLP]LED    = [L]CODLED
[F:BLP]COA    = GLEDCOA(ILED)
[F:BLP]CURLED = [L]CURLED
[F:BLP]DIE(0) = TDIE(0) :  [F:BLP]CCE1   = TCCE(0)
[F:BLP]DIE(1) = TDIE(1) :  [F:BLP]CCE2   = TCCE(1)
[F:BLP]DIE(2) = TDIE(2) :  [F:BLP]CCE3   = TCCE(2)
[F:BLP]DIE(3) = TDIE(3) :  [F:BLP]CCE4   = TCCE(3)
[F:BLP]DIE(4) = TDIE(4) :  [F:BLP]CCE5   = TCCE(4)
[F:BLP]DIE(5) = TDIE(5) :  [F:BLP]CCE6   = TCCE(5)
[F:BLP]DIE(6) = TDIE(6) :  [F:BLP]CCE7   = TCCE(6)
[F:BLP]DIE(7) = TDIE(7) :  [F:BLP]CCE8   = TCCE(7)
[F:BLP]DIE(8) = TDIE(8) :  [F:BLP]CCE9   = TCCE(8)
Return

######################################################################################
## Gestion du masque RECUPBLP
######################################################################################

Subprog AM_SOCIETE(VALEUR)
Variable Char    VALEUR()
GSOCIETE = VALEUR
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Filter [FIY] Where CPY=VALEUR & LEDTYP=GTYPGEN & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
[M]EXERCICE = [F:FIY]FIYNUM
[M]DATDEB   = [F:FIY]FIYSTR
[M]DATFIN   = [F:FIY]FIYEND
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

Subprog AS_TOUSITE(VALEUR)
Variable Integer VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
If VALEUR=2 : Effzo SITE : Grizo SITE : Else : Actzo SITE : Endif
End

Subprog C_TOUSITE(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo SITE : Grizo SITE
Else
 Actzo SITE
Endif
End

Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
If [M]TOUSITE=2 :  mkstat = 1 : End : Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M:DIA]SOCIETE,11) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char    CODLED(GLONLED)
Local Char    CURLED(GLONCUR)
Local Integer ILED
Local Integer ASTATUS
If VALEUR <= 0 :  GMESSAGE = func AFNC.MES1(mess(284,7711,1),[M]SOCIETE) : mkstat = 2 :  Endif
[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:DIA]SOCIETE, VALEUR, CODLED, CURLED, GMESSAGE)
ILED = find(CODLED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M:DIA]COA = GLEDCOA(ILED)
End

Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Filter [FIY] Where CPY=[M]SOCIETE & LEDTYP=[M:DIA]LEDTYP & FIYSTA=2
 Read [FIY]FIY0 First
 Filter [FIY]
 VALEUR = [F:FIY]FIYNUM
 [M]DATDEB = [F:FIY]FIYSTR
 [M]DATFIN = [F:FIY]FIYEND
Endif
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;[M:DIA]LEDTYP;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : # Exercice incorrect
 mkstat = 2 : End
Endif
If [F:FIY]FIYSTA=1
 GMESSAGE = mess(20,101,1) : # Exercice non ouvert
 mkstat = 2 : End
Elsif [F:FIY]FIYSTA>2
 GMESSAGE = mess(21,101,1) : # Exercice déjà clôturé
 mkstat = 2 : End
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End

Subprog C_BALCSL(VALEUR)
Variable Integer VALEUR
Local Char    CODLED(GLONLED)
Local Char    CURLED(GLONCUR)
Local Integer ASTATUS
If VALEUR=1
 [L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(GACTX, [M:DIA]SOCIETE, [M:DIA]LEDTYP, CODLED, CURLED, GMESSAGE)
 Call LEC_LED([L]CODLED) From CPTLEC
 If [M:DIA]TOUSITE<>2 & [F:LED]FCYBAL<>2
  ## CODLED : Le référentiel n'est pas coché 'Equilibre par site'
  GMESSAGE = mess(207,107,1)
  mkstat = 2 : End
 Endif
 If [F:LED]BAL<>2
  ## CODLED : Le référentiel n'est pas coché 'Equilibre'
  GMESSAGE = mess(179,116,1)
  mkstat = 2 : End
 Endif
 Raz [M:DIA]COMPTE : # No balance by account
 Affzo [M:DIA]COMPTE
Endif
End

