#<AdxTL>@(#)8.0.0.0 $Revision$
$ACTION
Case ACTION
 When default
Endcase
Return

########################################
Subprog AS_MFGFCY(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog C_MFGFCY(VALEUR)
Variable Char    VALEUR()
Call VERFCY(VALEUR) From CONTX3
Read [PJA]PJA0=VALEUR
End

########################################
Subprog AP_MFGFCY(VALEUR)
Variable Char    VALEUR()
Affzo [M:PJA1]
End

########################################
Subprog C_WKLMONNBR(VALEUR)
Variable Decimal VALEUR
Local Integer WNBJ,WNBP
If VALEUR = 0 & [M:PJA1]WKLDAYNBR = 0 & [M:PJA1]WKLWEENBR = 0 
  mkstat = 2
  GMESSAGE = mess(109,193,1)
Else
  WNBJ = [M:PJA1]WKLDAYNBR
  WNBJ += ([M:PJA1]WKLWEENBR*7)    
  WNBJ += (VALEUR*31)    
  WNBP = [M:PJA1]WKLDAYNBR
  WNBP += [M:PJA1]WKLWEENBR    
  WNBP += VALEUR
  If WNBJ > 2000
    mkstat = 2
    GMESSAGE = mess(110,193,1)
  Endif     
  If WNBP > 1000
    mkstat = 2
    GMESSAGE = mess(111,193,1)
  Endif     
Endif
End

