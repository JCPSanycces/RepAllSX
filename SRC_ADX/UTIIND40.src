##########################################################################
# UTIIND40 
# ---------------------------------------------------------------------- #
#         Suppression des trts QLF ne pas les livrer
##########################################################################
Infbox "only update folder by patch"
#Call PATCH ("X3")
End


##########################################################################
# Pour exécution automatique en gestion de patch                         #
##########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

# mettre a jour uniquement sur tous les dossiers 
if GADONIX = 2   : End  : endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat = 0
    Call EXE_UTIIND40(APPLI)
Endif
End


##########################################################################
## Suppression ou MAJ ecrans HRESUB*
##########################################################################
Subprog EXE_UTIIND40(DOSSIER)
Value Char    DOSSIER

Local Char    TRT(30)
Local Integer STAT


Call ECR_TRACE("UTIIND40 Start of Update : Update screens in the folder"+DOSSIER,0) From GESECRAN

#  
If clalev([F:ZAMK])=0 : Local File =DOSSIER+".AMSK"  [ZAMK] : Endif
If clalev([F:ZWWW])=0 : Local File =DOSSIER+".AMSK"  [ZWWW] : Endif

# sur le dossier mère on met a jour mais sur dossiers filles il faut virer ces ecrans car ne doivent pas etre presnet si module non actif
Filter [ZAMK] Where CODMSK > "HRESUB" and CODMSK < "HRESUBZ" and MODULE  = 1
# pas de update pour avoir trace de la modif dans la log
Trbegin [ZAMK]
For [ZAMK]
      Call ECR_TRACE("Update screen "+[F:ZAMK]CODMSK,0) From GESECRAN
      # si module inactif on vire screens sinon on modifie et on ecrit sur X3
      Read [ZWWW]CODMSK = [F:ZAMK]CODMSK
      If fstat = 0
            If DOSSIER = "X3" or [F:ADS]MODULE(14)=2
                [F:ZWWW]MODULE = 15
                [F:ZWWW]CODACT = "FUKPH"
                Rewrite [ZWWW]
            Else
                [F:ZWWW]MODULE = 15
                [F:ZWWW]CODACT = "FAL"
                Rewrite [ZWWW]
            Endif
      Endif
Next
Commit
Filter [ZAMK]
Call ECR_TRACE("UTIIND40 End of Update",0) From GESECRAN

Close Local File

End



