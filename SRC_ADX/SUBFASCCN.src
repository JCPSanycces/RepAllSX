#
#                GESTION DES BIENS COMPTABLES - CONCESSIONS
#
#*********************************************************************
#    Modification
#    GLE - 17.02.2014 FQ105441: Correction affichage de la valeur de renouvellement
#    MWA - 24.10.2012 FQ75616 : Reprise avancée
#    CFF - 22.10.2013 FQ93306 : Import des informations de concession
#*********************************************************************

###########################################
$VERF_ANU_CCN
  If G_ACTCCN=G_OUI & [M:FAS1]OWNTYP=GVML_TDCONCE
   Case func  GLOCCN.RNW_ENCOURS_NOT_DONE([M:FAS0]CPY,[M:FAS0]FCY,[M:FAS0]AASREF)
    When 2 : GERR= 1 : GMESSAGE= mess(54,123,1)+"\"+mess(769,7773,1)                                            : OK = 0 : GOK = 0
    When 3 : GERR= 1 : GMESSAGE= mess(54,123,1)+"\"+mess(749,7773,1)+"\"+mess(747,7773,1)-":"-[M:FAS6]RNWAASREF  : OK = 0 : GOK = 0
   Endcase
  Endif
Return

###########################################
$ALIM_CCNTYPPLN
 If G_ACTCCN=G_OUI
  If !clalev([F:ATX]) : Local File ATEXTE [ATX] : Endif
  If    [M:FAS3]DPRPLN(nolign-1)=G_CCNPLNIND
   Read [F:ATX]NUMERO=GLANGUE;41632
  Elsif [M:FAS3]DPRPLN(nolign-1)=G_CCNPLNCAD
   Read [F:ATX]NUMERO=GLANGUE;41631
  Elsif [M:FAS3]DPRPLN(nolign-1)=G_CCNPLNSUB
   Read [F:ATX]NUMERO=GLANGUE;34718
  Else
   [F:ATX]TEXTE=""
  Endif
  [M:FAS3]CCNTYPPLN(nolign-1)=[F:ATX]TEXTE
 Endif
Return


###########################################
$CHARGE_FAS6_ELT_RPR
  # FQ54343
  Read [RPR]RPR0=[M:FAS0]AASREF;GFINEXECPF;GFINPERCPF
  If (fstat) Then
    # Lecture CCNRPR pour l'exercice et la période correspondant au dernier mouvement
    Filter [RPR] Where AASREF= [M:FAS0]AASREF
    Read [RPR]RPR0 Last
    Filter [RPR]
    If ( fstat ) Then
      Infbox mess(274,7770,1)
    Endif
  Endif
  # FQ75616
  If (!fstat) Then
    [M:FAS6]          = [F:RPR]
    [M:FAS6]RNWVAL    = [F:FAS]RNWVAL    : # FQ105441 : c'est ce qui est stocké dans FXDASSETS qui prime
    [M:FAS6]RNWVALFLG = [F:FAS]RNWVALFLG : # FQ105441 : c'est ce qui est stocké dans FXDASSETS qui prime
  Endif
Return

#*********************************************************************
#         *FAS6            E C R A N      F A S 6
#*********************************************************************


########################################
Subprog C_CCNREF(VALEUR)
Variable Char    VALEUR()

  # FQ50972
  # If clalev([F:CCN]) =0    : Local File CONCESSION     [CCN]    : Endif

  # FQ54343
  Read [CCN]CCN1= [M:FAS0]CPY;VALEUR
  If (fstat) Then
    GERR= 1: GMESSAGE = mess(271,7773,1)
    mkstat = 2 : End
  Endif

  If ([F:CCN]CCNSTA <> GVML_CSACTI) Then
    GERR= 1: GMESSAGE = mess(271,7773,1)
    mkstat = 2 : End
  Endif

End

###################################################################
Subprog C_CCNACTCOD(VALEUR)
Variable Char    VALEUR()

  # FQ54343
  Look[COE]COE0= [M:FAS0]CPY;VALEUR
  If (fstat) Then
    Look[COE]COE0= "";VALEUR
    If (fstat) Then
      GERR= 1: GMESSAGE = mess(692,7773,1)
      mkstat = 2 : End
    Endif
  Endif
End

########################################
Subprog AS_CCNETRTYP(VALEUR)
Variable Integer VALEUR
  If ( [M:FAS6]CCNETRNAT = GVML_NECONCD ) Then
    # Si l'apport est "Concédant" alors le type d'apport ne peut être que "1er bien concession"
    GMENLOC(GVML_NARENEW) = 1
  Endif
End

########################################
Subprog AM_CCNACTCOD(VALEUR)
Variable Char    VALEUR()

Local Char LLOCK (200)
Local Char LLOCK2(200)


  # FQ54343
  If (G_ACTCCN = G_OUI and  VALEUR <> "" and  VALEUR <> [M:FAS6]CCNACTCOD ) Then
    LLOCK  = func GLOBIENS.GET_KEY_CCNCOE ([M:FAS0]CPY, VALEUR)
    LLOCK2 = func GLOBIENS.GET_KEY_CCNCOE ("", VALEUR)
    If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("COE", [M:FAS0]CPY, LLOCK)  = 0 or
&        func GLOBIENS.IS_SYMBOLE_LOCKED ("COE", [M:FAS0]CPY, LLOCK2) = 0      ) Then
      # Test si le nouveau code actualisation est verrouillée par la transaction "Gestion des Codes actualisations"
      GERR= 1: GMESSAGE = mess(690,7773,1)
      mkstat = 2 : End
    Endif

  Endif
End

###################################################################
Subprog AV_RNWDAT(VALEUR)
Variable Date    VALEUR

  # Gestion du code forçage
  If ([M:FAS6]RNWDATFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS6]RNWDAT With "FORCAGE"
    Else
      Chgstl [M:FAS6]RNWDAT With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FAS6]RNWDAT With ""
  Endif
End

########################################
Subprog AS_RNWDAT(VALEUR)
Variable Date    VALEUR
  # Gestion du code forçage
  If ( [M:FAS6]RNWDATFLG <> G_OUI  or
&      func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]RNWDAT", 0) <> G_OUI ) Then
    GBOUT1 = ""
  Endif
End

########################################
Subprog C_RNWDAT(VALEUR)
Variable Date    VALEUR

  Local Integer I_AI
  I_AI = find ( G_CCNPLNIND, [M:FAS3]DPRPLN )


  # La date de début d'amortissement de plan gérant l'amort. industriel doit être saisie.
  If ( VALEUR <> [0/0/0] and [M:FAS3]STRDPRDAT(I_AI-1) = [0/0/0] ) Then
      GERR= 1: GMESSAGE = mess(696,7773,1)
    mkstat = 2 : End
  Endif
  # La date de renouvellement saisie ne peut pas être antérieure à la date de début d'amortissement gérant l'amort. industriel
  If ( VALEUR <> [0/0/0] and VALEUR < [M:FAS3]STRDPRDAT(I_AI-1) ) Then
      GERR= 1: GMESSAGE = mess(697,7773,1)
    mkstat = 2 : End
  Endif
  # La date de renouvellement saisie ne peut pas être antérieure à la date de début d'exercice du contexte gérant l'amort. industriel
  # FQ93306: Ajout de "and [M:FAS0]PRVSITUPD <> G_OUI"
  If ( VALEUR <> [0/0/0] and VALEUR < [M:FAS3]FIYSTRDAT(I_AI-1) and [M:FAS0]PRVSITUPD <> G_OUI) Then
      GERR= 1: GMESSAGE = mess(698,7773,1)
    mkstat = 2 : End
  Endif

End

########################################
Subprog AM_RNWDAT(VALEUR)
Variable Date    VALEUR
  #FQ54343
  # La date de renouvellement a été modifiée alors recalcul forcé
  G_ARECALCULER = 1

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR")  ) Then
    G_DEFORCE = 0
  Else
    Affzo [M:FAS6]RNWDAT
    If (VALEUR <> [0/0/0]) Then
      [M:FAS6]RNWDATFLG = G_OUI:  Affzo [M:FAS6]RNWDATFLG
      If ( GBROWS = 0 ) Then
        Chgstl [M:FAS6]RNWDAT With "FORCAGE"
      Else
        Chgstl [M:FAS6]RNWDAT With "TFORCAGE"
      Endif
    Else
      [M:FAS6]RNWDATFLG = G_NON:  Affzo [M:FAS6]RNWDATFLG
      Chgstl [M:FAS6]RNWDAT With ""
    Endif
  Endif
End

########################################
Subprog B1_RNWDAT(VALEUR)
Variable Date    VALEUR
  # Gestion du code forçage
  [M:FAS6]RNWDATFLG = G_NON
  Affzo [M:FAS6]RNWDATFLG

  Raz [M:FAS6]RNWDAT
  Raz VALEUR


  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS6]RNWDAT  With ""
  Affzo [M:FAS6]RNWDAT
  mkstat = 99
End

###################################################################
Subprog AV_RNWVAL(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  If ([M:FAS6]RNWVALFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FAS6]RNWVAL With "FORCAGE"
    Else
      Chgstl [M:FAS6]RNWVAL With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FAS6]RNWVAL With ""
  Endif

End

########################################
Subprog AS_RNWVAL(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  If ( [M:FAS6]RNWVALFLG <> G_OUI  or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FAS6]RNWVAL", 0) <> G_OUI ) Then
    GBOUT1 = ""
  Endif
End

########################################
Subprog C_RNWVAL(VALEUR)
Variable Decimal VALEUR

End

########################################
Subprog AM_RNWVAL(VALEUR)
Variable Decimal VALEUR

  # La valeur de renouvellement a été modifiée alors recalcul forcé
  G_ARECALCULER = 1

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR")  ) Then
    G_DEFORCE = 0
  Else
    If (VALEUR <> 0) Then
      [M:FAS6]RNWVALFLG = G_OUI:  Affzo [M:FAS6]RNWVALFLG
      If ( GBROWS = 0 ) Then
        Chgstl [M:FAS6]RNWVAL With "FORCAGE"
      Else
        Chgstl [M:FAS6]RNWVAL With "TFORCAGE"
      Endif
    Else
      [M:FAS6]RNWVALFLG = G_NON:  Affzo [M:FAS6]RNWVALFLG
      Chgstl [M:FAS6]RNWVAL With ""
    Endif
  Endif
End

########################################
Subprog B1_RNWVAL(VALEUR)
Variable Decimal VALEUR


  # Gestion du code forçage
  [M:FAS6]RNWVALFLG = G_NON
  Affzo [M:FAS6]RNWVALFLG

  Raz [M:FAS6]RNWVAL
  Raz VALEUR


  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FAS6]RNWVAL  With ""
  Affzo [M:FAS6]RNWVAL
  mkstat = 99
End

########################################
Subprog AM_CCNETRNAT(VALEUR)
Variable Integer VALEUR

  If (VALEUR = GVML_NECONCD and [M:FAS6]RNWDONFLG = G_OUI ) Then
    # Apport "Concédant" et Indicateur "Renouvellement effectué" positionné sont incomptabiles
    GERR= 1: GMESSAGE = mess(791,7773,1)
    mkstat = 2 : End
  Endif

  If (VALEUR = GVML_NECONCD ) Then
    # Si la nature d'apport est concédant, le bien ne peut pas être remis contre indemnité
    [M:FAS6]TPAFLG = G_NON
    Affzo [M:FAS6]TPAFLG
  Endif

  [M:FAS6]CCNETRNAT = VALEUR
  Gosub MODIF_REDUITE From SUBFAS2
End



########################################
Subprog AM_RNWDONFLG(VALEUR)
Variable Integer VALEUR

  If (CCNETRNAT = GVML_NECONCD and VALEUR = G_OUI ) Then
    # Apport "Concédant" et Indicateur "Renouvellement effectué" positionné sont incomptabiles
    GERR= 1: GMESSAGE = mess(791,7773,1)
    mkstat = 2 : End
  Endif
End
