#<AdxTL>@(#)1.0.0.0 $Revision$
####################################################################################
# Program Name: XAPT
# Description : ADC Production Tracking
# Date        : Fev 22, 2007
# Type        :
####################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VXAPT","VXAPT","XVWXAPT") From GSAISIE
End

########################################################
# Production tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# MFGNUM, MFGLIN, BOMSEQ, ITMREF, UOM, UOMCPLQTY, STU, CPLQTY, UOMSTUCOE,
# STA, LOC, LOCTYP, LOT, SLO, SLOF, GESLOT, CLEFLG, FCY,PALNUM,
# CTRNUM, SERNUM, SERNUMF, TCLCOD, WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Block 'Lot': all field --> No
#
########################################################

########################################################
$ACTION
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase
Return


########################################################
$OUVRE
Global Char    GMILNUM(GLONTRS)
Local Char CRIT1
Local Integer  VALOK

If clalev([F:BTS]) =0 : Local File BENCHTRS [BTS]  : Endif


GVTMOD=1

# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC

Raz GMILNUM
#Filter [F:BTS] Where BTSTYP = 62 and SPERFLG = 1 and SPOTFLG = 1
#&    and SRUB1FLG = 1 and SRUB2FLG = 1 and SRUB3FLG = 1 and SRUB4FLG = 1

#Read [F:BTS] First
#If fstat = 0
#    GMILNUM = [F:BTS]BTSNUM
#Endif

#Filter [F:BTS]

#GMILNUM contains the production transaction
GMILNUM = func ENVADC.SETMFGTRANS(62)

Gosub OUVRE_MBI From ENVADC

Return


########################################################
$DEBUT
Local Integer WOK, WCPT
Global Char GTRAVT(250)

Gosub DEBUT_MBI From ENVADC
# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return
Endif
Gosub INIT_SCREEN

Return

########################################################
$SETBOUT

If !find("1",CHMEN) CHMEN+="1" Endif

Return

########################################################
$AVANT_OK

If [M]MFGNUM="" |  [M]ITMREF="" | [M]UOM="" | [M]UOMCPLQTY<=0
    GERR=1
    # CCC (2010-03-09) Bug 63134
    #GMESSAGE=mess(52,8016,1)
    GMESSAGE=mess(17,7750,1)
    FIN = 0
    zonsui = "[M:XAPT]MFGNUM"
    Return
Endif

Return


########################################################
$OK
Gosub OK_MBI From ENVADC
If GOUVENT>1
    Call GETERR_GOUVENT(GOUVENT, GMESSAGE) From ENVADC
    GERR=1
    zonsui = "[M:XAPT]MFGNUM"
    Return
Endif

If [F:ITM]LOTMGTCOD>1
   Call PEREMPTION_LOT("XAPT","MBI") From ENVADC
Endif

[L]WCPT = [M:XAPT]WCPT
Effzo [M:XAPT]1-99
[M:XAPT]WCPT   = [L]WCPT+1

[M:XAPT]MILNUM = GMILNUM

[M:XAPT]FCY    = GXAFCY
[M:XAPT]IPTDAT = date$
Affzo [M:XAPT]1-99
Grizo [M:XAPT]MILNUM
Return

########################################################
$BOUTON

# Création
If BOUT="1" : Gosub CRE : Endif
# Abandon
If BOUT="2" Gosub ABA Endif

Return

########################################################
$ABA

Gosub INIT_SCREEN
Return

########################################################
$CRE
# Si article renseigné, enregistrement de la saisie (bouton OK)
If [M]ITMREF<>""
  Gosub AVANT_OK
  If GERR=1 Return Endif
  Gosub OK
  If GERR=1 Return Endif
Endif

If [M:MBI]NBLIG=0
    GERR=1
    # CCC (2010-03-09) Bug 63134
    #GMESSAGE=mess(52,8016,1)
    GMESSAGE=mess(17,7750,1)
    FIN = 0
    Return
Endif

Gosub CRE_MBI From ENVADC
If [M:MBI]NBLIG<>0 : # GH 02/2016 bug 108954 if the validation transaction failed, give the opportunity to make a new try
   [M:XAPT]WCPT = [M:MBI]NBLIG : Affzo [XAPT]WCPT
   WOK=2
   # Tracking creation failed. New try ?
   Call OUINON(mess(254,193,1)+"\"+mess(182,188,1)-"?",WOK) From GESECRAN
   If WOK=2 : GNOLIG=[M:MBI]NBLIG : Goto CRE : Endif
Endif

#--- Lot V01
#-----impression des étiquettes ----#
If [F:BTS]PRNCOD1 = 2
   Call PRINT_ETI(GXAFCY ,15,[F:MTK]MFGTRKNUM) From STKADC
Endif

#-----impression des étiquettes ----#
#If [F:BTS]PRNCOD1 = 2
#  Local Char WPARAM(GLONVCR)(1..3) , WVALEUR(10)
#  WPARAM(1) = GXAFCY
#  WPARAM(2) = "15"
#  WPARAM(3) = [F:MTK]MFGTRKNUM
#  Call SAISIE_CHAR(WVALEUR,WPARAM,"VXSTOLB","VXSTOLB","SPEVXAPR") From GSAISIE
#Endif


Gosub INIT_SCREEN

Return

########################################################
$CHECK
Local Integer WOK
If [M:MBI]NBLIG<>0
   WOK=1
   # Pièce en cours de saisie non enregistrée
   Call OUINON(mess(38,7750,1),WOK) From GESECRAN
   If WOK<>2
      FIN=0 : zonsui="[M:XAPT]MFGNUM" : Return
   Endif
Endif

Return

########################################################
$FIN
Gosub FIN_MBI From ENVADC
GVTMOD=0
Kill GTRAVT
Return

########################################################
$INIT_SCREEN
Gosub RAZ_MBI From ENVADC
Raz [M:XAPT]
[M:XAPT]TRSTYP = 5
[M:XAPT]MILNUM = GMILNUM
[M:XAPT]FCY    = GXAFCY
[M:XAPT]IPTDAT = date$
Actzo [XAPT]1-99
Affzo [XAPT]1-99
nolign=0
Default Mask [XAPT]
GREP="" : REP=""

Return

######################################################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()

# Gosub AS_ITMREF_MBI From ENVADC : # GH 04/12/2013 bug 90177

Filter [MFI] Where MFGNUM = [M:XAPT]MFGNUM and MFGFCY = GXAFCY and CPLQTY < EXTQTY
Read [MFI] First
If fstat = 0
    VALEUR = [F:MFI]ITMREF
Endif
Filter [MFI]

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0 = VALEUR
Endif

If VALEUR<>[M]ITMREF : # GH 04/12/2013 bug 90177 ssi on change d'article
  Actzo [M]LOT

  If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
      Grizo [M]SLO
  Else
      Actzo [M]SLO
  Endif

  If [F:ITM]SERMGTCOD<3
      Grizo [M]SERNUM
  Else
      Actzo [M]SERNUM
  Endif
Endif

Gosub AS_ITMREF_MBI From ENVADC : # GH 04/12/2013 bug 90177

End

######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET
If VALEUR=""
   mkstat=2 : End
Endif

Gosub C_ITMREF_MBI From ENVADC
# Issue 66849 - 2010-09-06 by CCC : si l'article n'est pas bon sortir tout de suite sinon mkstat sera remis à 0 par l'Affzo

# GH 19/12/11 bug 78746
# If mkstat=2 : End : Endif
If mkstat : End : Endif

[M:XAPT]UOM    = [F:MFI]UOM
[M:XAPT]MFILOT = [F:MFI]LOT
Affzo [XAPT] UOMCPLQTY, UOM, STA, LOC, LOT, SLO, CLEFLG
End

######################################################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Gosub C_SLO_MBI From ENVADC
End

######################################################################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   mkstat=2 : End
Endif
Gosub C_MFGNUM_MBI From ENVADC
End

######################################################################################
Subprog AM_UOMCPLQTY(VALEUR)
Variable Decimal VALEUR
Gosub AM_UOMCPLQTY_MBI From ENVADC
Affzo [M]CLEFLG
End

######################################################################################
Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()

# GH 20/12/11 bug 78687
# If [M:XAPT]LOT <> "" : mkstat = 2 : End : Endif
If VALEUR <> "" & VALEUR = [M:XAPT]MFILOT : mkstat = 2 : End : Endif

End

######################################################################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
Local Char    LUSCAV
Local Char    LFMT
Local Integer LMODIF

Gosub AM_UOM_MBI From ENVADC

End

######################################################################################
Subprog AM_MILNUM(VALEUR)
Variable Char    VALEUR()
GMILNUM = VALEUR
If [F:BTS]SPERFLG <> 2   # hcb 60191
   Diszo  [M:XAPT]SHLDAT
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VXAPT) 11/07/2008 11:19:19 (MAE)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET
If [F:ITM]LOTMGTCOD>1
   If [F:BTS]SPERFLG =  2            # hcb  60322
       Actzo [M]SHLDAT
   Else
       Diszo [M]SHLDAT
   Endif
Else
   Grizo [M]SHLDAT
Endif

# Le lot a pu être initialisé par Inizonent

# GH 20/12/11 bug 78454
If [M:XAPT]LOT<>[M:XAPT]MFILOT
 [M:XAPT]LOT =[M:XAPT]MFILOT : Affzo LOT
Endif

# Issue 77510 - 2011-11-04 by CCC
If [M:XAPT]LOT<>""
    [M:XAPT]ITMREF=VALEUR
    # Issue 113021 - 2015-12-09 by GH : to increment the sub-lot number
    If dim([M:XAPT]SLO)>0
      Raz [M:XAPT]SLO
      Call STKAMLOT([M:XAPT]LOT,"XAPT",0,[M:XAPT]ITMREF,"SLO") From STKACT
    Endif
    Call AM_LOT([M:XAPT]LOT)
Endif
End

Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
# Si uniquement gestion de lot et lot existant, pas d'accès à la péremption
If find([F:ITM]LOTMGTCOD,2,3)
   Read [F:STL]STL0=[M]ITMREF;VALEUR;""
   If fstat
      Call CALPER([F:ITM]EXYMGTCOD,date$,[F:ITM]SHL,[F:ITM]SHLUOM,"",[M:XAPT]SHLDAT) From STKLIB
      If [F:BTS]SPERFLG <> 2            # hcb  60322
         Diszo  [M:XAPT]SHLDAT
      Else
         Actzo  [M:XAPT]SHLDAT
      Endif
   Else
      [M]SHLDAT = [F:STL]SHLDAT
      Diszo [M]SHLDAT
   Endif
   Affzo [M]SHLDAT
Endif
End

Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
# Si gestion de lot/sous-lot et lot existant, pas d'accès à la péremption
If [F:ITM]LOTMGTCOD=4
   Read [F:STL]STL0=[M]ITMREF;[M]LOT;VALEUR
   If fstat
      Call CALPER([F:ITM]EXYMGTCOD,date$,[F:ITM]SHL,[F:ITM]SHLUOM,"",[M:XAPT]SHLDAT) From STKLIB
      If [F:BTS]SPERFLG <> 2            # hcb  60322
         Diszo  [M:XAPT]SHLDAT
      Else
         Actzo  [M:XAPT]SHLDAT
      Endif
   Else
      [M]SHLDAT = [F:STL]SHLDAT
      Diszo [M]SHLDAT
   Endif
   Affzo [M]SHLDAT
Endif

End

########################################################
Subprog AS_SHLDAT(VALEUR)
Variable Date    VALEUR

If [F:ITM]EXYMGTCOD > 1 & VALEUR = [0/0/0]
   Call CALPER([F:ITM]EXYMGTCOD,date$,[F:ITM]SHL,[F:ITM]SHLUOM,"",VALEUR) From STKLIB
Endif
End

Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999]
  mkstat = 2
Endif
If [F:ITM]EXYMGTCOD > 1 & VALEUR = [0/0/0]
   mkstat = 2
Endif
End


######################################################################################

