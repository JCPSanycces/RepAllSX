#<AdxTL>@(#)0.0.0.0 $Revision$

$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                      : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"      : Gosub AINSERT_CONTROL_BEFORE
    Endcase
Endcase
Return


$AINIT
Return

$AINSERT_CONTROL_BEFORE
#Set the line number
Gosub SET_LIGNUM
Return

$SET_LIGNUM
If this.NUMLIG <> 0 : Return: Endif
Local Integer MAXLIGNUM
Local File EMPLOEXM [EXM2]
Filter [EXM2] Where REFNUM = this.REFNUM
For [EXM2]
  If [F:EXM2]NUMLIG > MAXLIGNUM
    MAXLIGNUM = [F:EXM2]NUMLIG
  Endif
Next

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
LogicClose File [EXM2]
Return

