$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog WRKSIG(VEVT,VUID)
Value Char VEVT(), VUID()

#Check EVT variable
#A Generic function can be WRKSIG = Extension
Case VEVT
  When "VIS" : Call WRKSIGVIS(VEVT,VUID)
  When "REF" : Call WRKSIGREF(VEVT,VUID)
Endcase
End

Subprog ESWDCHRODEST(CHRONO,UID,DEST)
Value Char CHRONO(), UID(), DEST()


If !clalev([F:ESWD3]) : Local File ESSWRKFLWDET [ESWD3] : Endif

Update [ESWD3] Where UID=val([L]UID)
&             With CHRONO=[L]CHRONO
If fstat
 [V]GOK=0
 Call RSTA("ESWD3","CHRONO=-"+num$(adxuid(2))) From GLOCK
 End
Endif

Update [ESWD3] Where UID=val([L]UID)
&             With CHRONO2=[L]CHRONO
If fstat
 [V]GOK=0
 Call RSTA("ESWD3","CHRONO2=-"+num$(adxuid(2))) From GLOCK
 End
Endif


Update [ESWD3] Where UID=val([L]UID)
&             With CHEF=[L]DEST
If fstat
 [V]GOK=0
 Call RSTA("ESWD3","DEST"+num$(DEST)) From GLOCK
 End
Endif

End


Subprog WRKSIGVIS(REF_EVT, REF_VUID)
Local Char EVT(250), VUID(250)
EVT = REF_EVT
VUID = REF_VUID

Local Integer RETVAL
Local Char PROG(100)
Local Char VMAIN(5) : VMAIN="MAIN"
Local Integer TABLEUPDATE,TRANSACTION_PENDING,STAT,PROGRET,COLIND
COLIND = 1

Local Integer ORIGINTIME,ELAPSETIME
Local Integer RND_VAL
Local Char UIDLAST_STRING(3)
Local Integer UIDLAST_INT

#Open the employee workflow detail table
If !clalev([F:ESWD1]) : Local File ESSWRKFLWDET [ESWD1] : Endif

#Read the Employee workflow detail record to determine which table/class to update
Filter [F:ESWD1] Where UID = val(VUID) and MAIREC = 2
Read [ESWD1] First
Filter [ESWD1]
If fstat  : End : Endif

#FRLAA|PEVAN - 2018-05-08 - X3-76275 - START
#Set wait
Local Integer TOTWAIT
Local Integer ELAPSE # Maybe set as parameter value #TODO: PEVAN
ELAPSE = 3
TOTWAIT = func SET_WAIT([F:ESWD1]REFNUM,[F:ESWD1]CODFIC,[F:ESWD1]UID,ELAPSE)


#Timer
ORIGINTIME = time
ELAPSETIME = time
While ELAPSETIME-ORIGINTIME < TOTWAIT
  ELAPSETIME = time
Wend



#Set the function to use
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".UPDATE_TABLES"

#FRLAA|PEVAN - 2018-05-08 - X3-76275 - END


#Call the UPDATE_TABLES function
If evalue(PROG+"_"+[F:ESWD1]CODFIC +"("+num$([F:ESWD1]MAIREC)+",'"+num$([F:ESWD1]REFNUM)+"','"+num$([F:ESWD1]CLA)+"','"+num$([F:ESWD1]UID)+"','"+num$([F:ESWD1]FLDNAM)+"','"+VMAIN+"','"+EVT+"','"+num$(
& [F:ESWD1]WRK)+"')") = 0 #Success

#Update employee workflow detail
  Update [ESWD1] Where UID=val(VUID)
&             With STA=3 #Accepted

  If fstat : STAT = 1 : Endif
Else
  STAT = 1
Endif



If STAT = 1
 [V]GOK=0
 Call RSTA("ESWD",num$(UID)) From GLOCK
 End
Endif


LogicClose File [ESWD1]

End


#FRLAA|PEVAN - 2018-05-08 - X3-76275 - START
Funprog SET_WAIT(VREFNUM,VCODFIC,VUID,ELAPSE)
Value Char VREFNUM, VCODFIC
Value Integer VUID, ELAPSE

#Local variables
Local Integer RETVAL
Local Integer REC_COUNT

If !clalev([F:ESWD5]) : Local File ESSWRKFLWDET [ESWD5] : Endif
Filter [F:ESWD5] Where REFNUM = VREFNUM and CODFIC = VCODFIC and MAIREC = 2 and STA <> 3
For [F:ESWD5]ESWD0
  REC_COUNT+=1
  If [F:ESWD5]UID = VUID
    RETVAL = REC_COUNT*ELAPSE
    Break
  Endif
Next
Filter [F:ESWD5]
End RETVAL
#FRLAA|PEVAN - 2018-05-08 - X3-76275 - END

Subprog WRKSIGREF(REF_EVT, REF_VUID)
Local Char EVT(250), VUID(250)
EVT = REF_EVT
VUID = REF_VUID



Local Char PROG(100)
Local Integer TABLEUPDATE,TRANSACTION_PENDING,STAT,PROGRET
Local Char VMAIN(5) : VMAIN="MAIN"
COLIND = 1

If !clalev([F:ESWD1]) : Local File ESSWRKFLWDET [ESWD1] : Endif

#Read the Employee workflow detail record to determine which table/class to update
Filter [F:ESWD1] Where UID = val(VUID) and MAIREC = 2
Read [ESWD1] First

If fstat : Filter [ESWD1]: End : Endif

#FRLAA|PEVAN - 2018-05-08 - X3-76275 - START
#Set wait
Local Integer TOTWAIT
Local Integer ELAPSE # Maybe set as parameter value #TODO: PEVAN
ELAPSE = 3
TOTWAIT = func SET_WAIT([F:ESWD1]REFNUM,[F:ESWD1]CODFIC,[F:ESWD1]UID,ELAPSE)

#Timer
ORIGINTIME = time
ELAPSETIME = time
While ELAPSETIME-ORIGINTIME < TOTWAIT
  ELAPSETIME = time
Wend
#FRLAA|PEVAN - 2018-05-08 - X3-76275 - END

#Set the function to use
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".UPDATE_TABLES"

#Call the UPDATE_TABLES function
If evalue(PROG+"_"+[F:ESWD1]CODFIC +"("+num$([F:ESWD1]MAIREC)+",'"+num$([F:ESWD1]REFNUM)+"','"+num$([F:ESWD1]CLA)+"','"+num$([F:ESWD1]UID)+"','"+num$([F:ESWD1]FLDNAM)+"','"+VMAIN+"','"+EVT+"','"+num$
& ([F:ESWD1]WRK)+"')") = 0 #Success
  #Update employee workflow detail
Update [ESWD1] Where UID=val(VUID)
&             With STA=4 #Rejected
  If fstat : STAT = 1 : Endif
Else
  STAT = 1
Endif

If STAT = 1
 [V]GOK=0
 Call RSTA("ESWD",num$(UID)) From GLOCK
 End
Endif

LogicClose File [ESWD1]


End

#EMPLORIB
Funprog UPDATE_TABLES_EMPLORIB(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT,INITSTAT
RETVAL = [V]CST_AOK


Local File ESSWRKFLWDET [ESWD7]

If VEVT = "VIS"


  Local Instance I_EMPLORIB Using C_EMPLORIB
  If (I_EMPLORIB <> null) : FreeGroup I_EMPLORIB : Endif
  I_EMPLORIB = NewInstance C_EMPLORIB AllocGroup null


  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKRIB Using C_ESSWRKRIB
  If (I_ESSWRKRIB <> null) : FreeGroup I_ESSWRKRIB : Endif
  I_ESSWRKRIB = NewInstance C_ESSWRKRIB AllocGroup null


  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKRIB.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING

  #Read the main class with correct key
  #REFNUM+NUMLIG
  READSTAT = fmet I_EMPLORIB.AREAD(I_ESSWRKRIB.REFNUM,I_ESSWRKRIB.NUMLIG)
    If READSTAT >= [V]CST_AERROR
      #Test VWRK for new record
      If VWRK = "C"
        #Initialize new instance
        INITSTAT = fmet I_EMPLORIB.AINIT()
        RETVAL = INITSTAT
#        If INITSTAT  = [V]CST_AOK
        If INITSTAT <= [V]CST_AWARNING
          #Class transfer
          Local File EMPLORIB [RIB5]
          Raz [RIB5]
          SetInstance [F:RIB5] With I_ESSWRKRIB
          SetInstance I_EMPLORIB With [F:RIB5]
          Onerrgo ERR_CRE
          UPDATESTAT = fmet I_EMPLORIB.AINSERT()
          RETVAL = UPDATESTAT
          LogicClose File [RIB5]
        Else
          RETVAL = [V]CST_AERROR
        Endif
      Else
        RETVAL = [V]CST_AERROR
      Endif
    Endif
  Else
    RETVAL = [V]CST_AERROR
  Endif


#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0

        For K = 1 To I_EMPLORIB.ObjectNbs
          If I_EMPLORIB.ObjectVar(K) = [F:ESWD7]FLDNAM

            Assign "I_EMPLORIB."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKRIB."+[F:ESWD7]FLDNAM+")")
            Break
          Endif
        Next K
      Next

      Filter [ESWD7]

      Onerrgo ERR_CRE
      UPDATESTAT = fmet I_EMPLORIB.AUPDATE()
    Elsif VWRK = "D"
      UPDATESTAT = fmet I_EMPLORIB.ADELETE()
    Endif

    RETVAL = UPDATESTAT

  Endif
Endif

Gosub FREE_EMPLORIB
#Gosub DELETE_ESSWRKRIB
End RETVAL


$ERR_CRE

Resume


#JOJAC - 2017-06-06 - START
#EMPLOID
Funprog UPDATE_TABLES_EMPLOID(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT
RETVAL = [V]CST_AOK

Local Char MYFIELD(50)
Local Char ERRMSG(250)

Local File ESSWRKFLWDET [ESWD7]

If VEVT = "VIS"

  #Instantiate the main class in the system
  Local Instance I_EMPLOID Using C_EMPLOID
  If (I_EMPLOID <> null) : FreeGroup I_EMPLOID : Endif
  I_EMPLOID = NewInstance C_EMPLOID AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKEMP Using C_ESSWRKEMP
  If (I_ESSWRKEMP <> null) : FreeGroup I_ESSWRKEMP : Endif
  I_ESSWRKEMP = NewInstance C_ESSWRKEMP AllocGroup null

  #Instantiate the EMPLOIDESS CLass
  Local Instance I_EMPLOIDESS Using C_EMPLOIDESS
  If (I_EMPLOIDESS <> null) : FreeGroup I_EMPLOIDESS : Endif
  I_EMPLOIDESS = NewInstance C_EMPLOIDESS AllocGroup null

  #Read the Main class
  READSTAT = fmet I_EMPLOID.AREAD(VREFNUM)
#  If READSTAT <> [V]CST_AOK
  If READSTAT > [V]CST_AWARNING
    Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
    End READSTAT
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKEMP.AREAD(val(VUID))


#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Record found - Process
    #Check all the changes made and apply
    #Loop through all possible records on the workflow detail - Excluding the main record
    Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
    For [ESWD7]ESWD0
      For K = 1 To I_EMPLOID.ObjectNbs
        If I_EMPLOID.ObjectVar(K) = [F:ESWD7]FLDNAM
          MYFIELD = [F:ESWD7]FLDNAM
          Assign "I_EMPLOID."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKEMP."+[F:ESWD7]FLDNAM+")")
          Break
        Endif
      Next K
    Next
  Else
    End READSTAT
  Endif
  RETVAL = fmet I_EMPLOID.AUPDATE()
  If RETVAL > [V]CST_AWARNING
    Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
  Endif
  #The EMPLOIDESS Class must also be updated toghether with the EMPLOID Class
  If clalev([F:IDES])=0  : Local File EMPLOIDESS     [IDES]  : Endif

  Read [IDES]IDES0 = VREFNUM
  If !fstat
    [F:IDES]REFNUM  = I_EMPLOID.REFNUM
    [F:IDES]NAM     = I_EMPLOID.NAM
    [F:IDES]SRN     = I_EMPLOID.SRN
    [F:IDES]PSD     = I_EMPLOID.PSD
    [F:IDES]DATBRN  = I_EMPLOID.DATBRN
    [F:IDES]ENAFLG  = I_EMPLOID.ENAFLG

    Rewrite [F:IDES]
    If fstat
      GOK = 0 : Call FSTA("IDES") From GLOCK : Return
    Endif
  Endif

  Filter [ESWD7]

  Gosub FREE_EMPLOID
Endif


#Gosub DELETE_ESSWRKEMP #FRLAA X3-94079 2018-06-12

End RETVAL


#EMPLOIDAFR
