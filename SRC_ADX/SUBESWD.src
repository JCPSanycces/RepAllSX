Funprog UPDATE_TABLES_EMPLOIDPAS(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT,L,INTROW,X,INITSTAT
RETVAL = [V]CST_AOK

Local File EMPLOID [ID3]

If VEVT = "VIS"
  Local File ESSWRKFLWDET [ESWD7]


  #Instantiate the main class in the system
  Local Instance I_EMPLOID Using C_EMPLOID
  If (I_EMPLOID <> null) : FreeGroup I_EMPLOID : Endif
  I_EMPLOID = NewInstance C_EMPLOID AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKEMP Using C_ESSWRKEMP
  If (I_ESSWRKEMP <> null) : FreeGroup I_ESSWRKEMP : Endif
  I_ESSWRKEMP = NewInstance C_ESSWRKEMP AllocGroup null

  Read [ESWD7]ESWD0 = val(VUID);VCLA;VREFNUM;VMAIREC;VFIELD
  If !fstat
    INTROW = [ESWD7]INTKEY1
    If INTROW = 0
      #End [V]CST_AERROR
    Endif
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKEMP.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM
    READSTAT = fmet I_EMPLOID.AREAD(I_ESSWRKEMP.REFNUM)
#    If READSTAT = [V]CST_AOK
    If READSTAT <= [V]CST_AWARNING
      #Test VWRK for new record
      If VWRK = "C"
        #Check the collection
        INITSTAT = [V]CST_AFALSE
        If I_EMPLOID.PASDET <> null
          For X = 1 To maxtab(I_EMPLOID.PASDET)
            If I_EMPLOID.PASDET(X).ESSUIDPAS = I_ESSWRKEMP.ESSUIDPAS
              INITSTAT = [V]CST_ATRUE
              Break
            Endif
          Next X
          If  INITSTAT <> [V]CST_ATRUE
            Gosub ADD_EMPLOID_PASDET
          Endif
        Else
          Gosub ADD_EMPLOID_PASDET
        Endif
      Endif
    Else
      Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
      RETVAL = [V]CST_AERROR
    Endif
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKEMP) From ESS_WRKFLOW_FUNC_HYBRID
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOID.PASDET <> null
          For X = 1 To maxtab(I_EMPLOID.PASDET)
            If I_EMPLOID.PASDET(X).ESSUIDPAS = I_ESSWRKEMP.ESSUIDPAS
              For K = 1 To I_EMPLOID.PASDET(X).ObjectNbs
                If I_EMPLOID.PASDET(X).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOID.PASDET("+num$(X)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKEMP."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
              Next K
            Endif
          Next X
        Endif
        If I_EMPLOID.EMPLOIDSA.PASDET <> null
         For X = 1 To maxtab(I_EMPLOID.EMPLOIDSA.PASDET)
          If I_EMPLOID.EMPLOIDSA.PASDET(X).ESSUIDPAS = I_ESSWRKEMP.ESSUIDPAS
            For K = 1 To I_EMPLOID.EMPLOIDSA.PASDET(X).ObjectNbs
              If I_EMPLOID.EMPLOIDSA.PASDET(X).ObjectVar(K) = [F:ESWD7]FLDNAM
               Assign "I_EMPLOID.EMPLOIDSA.PASDET("+num$(X)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKEMP."+[F:ESWD7]FLDNAM+")")
               Break
              Endif
            Next K
          Endif
        Next X
      Endif
      Next
      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOID.AUPDATE()
      If UPDATESTAT > [V]CST_AWARNING
        Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKEMP) From ESS_WRKFLOW_FUNC_HYBRID
      Endif
    Elsif VWRK = "D"
      If I_EMPLOID.PASDET <> null
        For X = 1 To maxtab(I_EMPLOID.PASDET)
          If I_EMPLOID.PASDET(X).ESSUIDPAS = I_ESSWRKEMP.ESSUIDPAS
            UPDATESTAT=fmet I_EMPLOID.ADELLINE("PASDET",X)
            If UPDATESTAT <= [V]CST_AWARNING
              #FRLAA X3-96827 2018-08-02 - START
              If I_EMPLOID.EMPLOIDSA <> null
                #If I_EMPLOID.EMPLOIDSA.PASDET(X).ESSUIDPAS <> null
                  If I_EMPLOID.EMPLOIDSA.PASDET(X).ESSUIDPAS = I_ESSWRKEMP.ESSUIDPAS
                    UPDATESTAT=fmet I_EMPLOID.EMPLOIDSA.ADELLINE("PASDET",X)
                  Endif
                #Endif
              Endif
              If UPDATESTAT <= [V]CST_AWARNING
                Read [F:ID3]ID0 = VREFNUM
                  If !fstat
                    If [F:ID3]NBRPAS > 0
                      I_EMPLOID.NBRPAS=I_EMPLOID.NBRPAS-1
                      If I_EMPLOID.EMPLOIDSA <> null
                        I_EMPLOID.EMPLOIDSA.NBRPAS = I_EMPLOID.NBRPAS
                      Endif
                    Endif
                  Endif
              Endif
              #Update the NBRPAS property
              #I_EMPLOID.NBRPAS =  I_ESSWRKEMP.NBRPAS
               #FRLAA X3-96827 2018-08-02 - END
              UPDATESTAT = fmet I_EMPLOID.AUPDATE()
            Endif
          Endif
        Next X
      Endif
    Endif
    RETVAL = UPDATESTAT
    If UPDATESTAT > [V]CST_AWARNING
      Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
    Endif
  Endif
  Gosub FREE_EMPLOID
Endif

#Gosub DELETE_ESSWRKEMP #FRLAA X3-94079 2018-06-12
End RETVAL



Funprog UPDATE_TABLES_EMPLOIDSPAS(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT,L,INTROW,X,INITSTAT
RETVAL = [V]CST_AOK

If VEVT = "VIS"
  Local File ESSWRKFLWDET [ESWD7]


  #Instantiate the main class in the system
  Local Instance I_EMPLOIDSA Using C_EMPLOIDSA
  If (I_EMPLOIDSA <> null) : FreeGroup I_EMPLOIDSA : Endif
  I_EMPLOIDSA = NewInstance C_EMPLOIDSA AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKSA Using C_ESSWRKSA
  If (I_ESSWRKSA <> null) : FreeGroup I_ESSWRKSA : Endif
  I_ESSWRKSA = NewInstance C_ESSWRKSA AllocGroup null

  Read [ESWD7]ESWD0 = val(VUID);VCLA;VREFNUM;VMAIREC;VFIELD
  If !fstat
    INTROW = [ESWD7]INTKEY1
    If INTROW = 0
      #End [V]CST_AERROR
    Endif
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKSA.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM
    READSTAT = fmet I_EMPLOIDSA.AREAD(I_ESSWRKSA.REFNUM)
#    If READSTAT = [V]CST_AOK
    If READSTAT <= [V]CST_AWARNING
      #Test VWRK for new record
      If VWRK = "C"
        #Check the collection
        INITSTAT = [V]CST_AFALSE
        If I_EMPLOIDSA.PASDET <> null
          For X = 1 To maxtab(I_EMPLOIDSA.PASDET)
            If I_EMPLOIDSA.PASDET(X).ESSUIDPAS = I_ESSWRKSA.ESSUIDPAS
              INITSTAT = [V]CST_ATRUE
              Break
            Endif
          Next X
          If  INITSTAT <> [V]CST_ATRUE
            Gosub ADD_EMPLOIDSA_PASDET
          Endif
        Else
          Gosub ADD_EMPLOIDSA_PASDET
        Endif
      Endif
    Else
      RETVAL = [V]CST_AERROR
    Endif
  Else
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOIDSA.PASDET <> null
          For X = 1 To maxtab(I_EMPLOIDSA.PASDET)
            If I_EMPLOIDSA.PASDET(X).ESSUIDPAS = I_ESSWRKSA.ESSUIDPAS
              For K = 1 To I_EMPLOIDSA.PASDET(X).ObjectNbs
               If I_EMPLOIDSA.PASDET(X) <> null
                If I_EMPLOIDSA.PASDET(X).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOIDSA.PASDET("+num$(X)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKSA."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
    Elsif VWRK = "D"
      If I_EMPLOIDSA.PASDET <> null
        For X = 1 To maxtab(I_EMPLOIDSA.PASDET)
          If I_EMPLOIDSA.PASDET(X).ESSUIDPAS = I_ESSWRKSA.ESSUIDPAS
            UPDATESTAT=fmet I_EMPLOIDSA.ADELLINE("PASDET",X)
#            If UPDATESTAT = [V]CST_AOK
            If UPDATESTAT <= [V]CST_AWARNING
              #Update the NBRPAS property
              I_EMPLOIDSA.NBRPAS =  I_ESSWRKSA.NBRPAS
              UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
              Gosub UPDATE_EMPLOID_NBRPAS
            Endif
          Endif
        Next X
      Endif
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOIDSA
Endif



Gosub DELETE_ESSWRKSA
End RETVAL

$ADD_EMPLOIDSA_ADDADR
#Collection does not exist and can be created
#Class transfer
Local File EMPLOIDSART [ESAR5]
Raz [ESAR5]
SetInstance [F:ESAR5] With I_ESSWRKSA
L = fmet I_EMPLOIDSA.ADDLINE("ADDADR",INTROW)
SetInstance I_EMPLOIDSA.ADDADR(INTROW) With [F:ESAR5]
I_EMPLOIDSA.NBRADD =  I_ESSWRKSA.NBRADD
UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
RETVAL = UPDATESTAT
LogicClose File [ESAR5]
Gosub UPDATE_EMPLOID_NBRPAS
Return


$ADD_EMPLOIDSA_PASDET
#Collection does not exist and can be created
#Class transfer
Local File EMPLOIDSART [ESAR5]
Raz [ESAR5]
SetInstance [F:ESAR5] With I_ESSWRKSA
L = fmet I_EMPLOIDSA.ADDLINE("PASDET",[V]CST_ALASTPOS)
SetInstance I_EMPLOIDSA.PASDET(L) With [F:ESAR5]
I_EMPLOIDSA.NBRPAS =  I_ESSWRKSA.NBRPAS
UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
Gosub UPDATE_EMPLOID_NBRPAS
RETVAL = UPDATESTAT
LogicClose File [ESAR5]
Return

$ADD_EMPLOID_PASDET
#Collection does not exist and can be created
#Class transfer
Local File EMPLOIDRT [IDRT5]
Raz [IDRT5]
SetInstance [F:IDRT5] With I_ESSWRKEMP
L = fmet I_EMPLOID.ADDLINE("PASDET",[V]CST_ALASTPOS)
SetInstance I_EMPLOID.PASDET(L) With [F:IDRT5]
#FRLAA X3-96827 2018-08-02 - START
If I_EMPLOID.EMPLOIDSA <> null
  #For I = 1 To maxtab(I_EMPLOID.EMPLOIDSA) #Extend
    L = fmet I_EMPLOID.EMPLOIDSA.ADDLINE("PASDET",[V]CST_ALASTPOS)
    SetInstance I_EMPLOID.EMPLOIDSA.PASDET(L) With [F:IDRT5]
Endif

Read [F:ID3]ID0 = VREFNUM
If !fstat
  If [F:ID3]NBRPAS < dim([F:ID3]PASCRY)
    I_EMPLOID.NBRPAS+=1
    If I_EMPLOID.EMPLOIDSA <> null
      I_EMPLOID.EMPLOIDSA.NBRPAS = I_EMPLOID.NBRPAS
    Endif
  Endif
Endif
#I_EMPLOID.NBRPAS =  I_ESSWRKEMP.NBRPAS
#FRLAA X3-96827 2018-08-02 - END
UPDATESTAT = fmet I_EMPLOID.AUPDATE()
RETVAL = UPDATESTAT
LogicClose File [IDRT5]
Return

$UPDATE_EMPLOID_NBRPAS
Local File EMPLOID [ID7]
Update [ID7] Where REFNUM = I_ESSWRKSA.REFNUM With NBRPAS = I_ESSWRKSA.NBRPAS
Return

#Africa - Additional addresses
Funprog UPDATE_TABLES_EMPLOIDAFRRT(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT, L,INTROW,X,INITSTAT
RETVAL = [V]CST_AOK

If VEVT = "VIS"
  Local File ESSWRKFLWDET [ESWD7]

  #Instantiate the main class in the system
  Local Instance I_EMPLOIDAFR Using C_EMPLOIDAFR
  If (I_EMPLOIDAFR <> null) : FreeGroup I_EMPLOIDAFR : Endif
  I_EMPLOIDAFR = NewInstance C_EMPLOIDAFR AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKAFR Using C_ESSWRKAFR
  If (I_ESSWRKAFR <> null) : FreeGroup I_ESSWRKAFR : Endif
  I_ESSWRKAFR = NewInstance C_ESSWRKAFR AllocGroup null

  Read [ESWD7]ESWD0 = val(VUID);VCLA;VREFNUM;VMAIREC;VFIELD
  If !fstat
    INTROW = [ESWD7]INTKEY1
    If INTROW = 0
      End [V]CST_AERROR
    Endif
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKAFR.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM
    READSTAT = fmet I_EMPLOIDAFR.AREAD(I_ESSWRKAFR.REFNUM)
#    If READSTAT = [V]CST_AOK
    If READSTAT <= [V]CST_AWARNING
      #Test VWRK for new record
      If VWRK = "C"
        #Check the collection
        INITSTAT = [V]CST_AFALSE
        If I_EMPLOIDAFR.ADDADR <> null
          For X = 1 To maxtab(I_EMPLOIDAFR.ADDADR)
            If X = INTROW
              INITSTAT = [V]CST_ATRUE
              Break
            Endif
          Next X
          If  INITSTAT <> [V]CST_ATRUE
            Gosub ADD_EMPLOIDAFR_ADDADR
          Endif
        Else
          Gosub ADD_EMPLOIDAFR_ADDADR
        Endif
      Endif
    Else
      RETVAL = [V]CST_AERROR
    Endif
  Else
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOIDAFR.ADDADR <> null
          For X = 1 To maxtab(I_EMPLOIDAFR.ADDADR)
            If X = INTROW
              For K = 1 To I_EMPLOIDAFR.ADDADR(INTROW).ObjectNbs
               If I_EMPLOIDAFR.ADDADR(INTROW) <> null
                If I_EMPLOIDAFR.ADDADR(INTROW).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOIDAFR.ADDADR("+num$(INTROW)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKAFR."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOIDAFR.AUPDATE()
    Elsif VWRK = "D"
      If I_EMPLOIDAFR.ADDADR <> null
        For X = 1 To maxtab(I_EMPLOIDAFR.ADDADR)
          If X = INTROW
            UPDATESTAT=fmet I_EMPLOID.I_EMPLOIDAFR.ADELLINE("ADDADR",INTROW)
#            If UPDATESTAT = [V]CST_AOK
            If UPDATESTAT <= [V]CST_AWARNING
              UPDATESTAT = fmet I_EMPLOIDAFR.AUPDATE()
            Endif
          Endif
        Next X
      Endif
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOIDAFR
Endif


Gosub DELETE_ESSWRKAFR
End RETVAL

$ADD_EMPLOIDAFR_ADDADR
#Collection does not exist and can be created
#Class transfer
Local File EMPLOIDAFRRT [EAFR5]
Raz [EAFR5]
SetInstance [F:EAFR5] With I_ESSWRKAFR
L = fmet I_EMPLOIDAFR.ADDLINE("ADDADR",INTROW)
SetInstance I_EMPLOIDAFR.ADDADR(INTROW) With [F:EAFR5]
I_EMPLOIDAFR.NBRAFR =  I_ESSWRKAFR.NBRAFR
UPDATESTAT = fmet I_EMPLOIDAFR.AUPDATE()
RETVAL = UPDATESTAT
LogicClose File [EAFR5]
Return


