#EMPLOIDSA
Funprog UPDATE_TABLES_EMPLOIDSA(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID,VFIELD
Local Integer READSTAT,K,RETVAL,UPDATESTAT,INITSTAT
RETVAL = [V]CST_AOK

Local File ESSWRKFLWDET [ESWD7]

If VEVT = "VIS"
  #Instantiate the main class in the system
  Local Instance I_EMPLOIDSA Using C_EMPLOIDSA
  If (I_EMPLOIDSA <> null) : FreeGroup I_EMPLOIDSA : Endif
  I_EMPLOIDSA = NewInstance C_EMPLOIDSA AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKSA Using C_ESSWRKSA
  If (I_ESSWRKSA <> null) : FreeGroup I_ESSWRKSA : Endif
  I_ESSWRKSA = NewInstance C_ESSWRKSA AllocGroup null

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKSA.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
  #Read the main class with correct key
  #REFNUM
  READSTAT = fmet I_EMPLOIDSA.AREAD(I_ESSWRKSA.REFNUM)
    If READSTAT >= [V]CST_AERROR
      #Test VWRK for new record
      If VWRK = "C"
        #Initialize new instance
        INITSTAT = fmet I_EMPLOIDSA.AINIT()
        RETVAL = INITSTAT
#        If INITSTAT  = [V]CST_AOK
        If INITSTAT <= [V]CST_AWARNING
          #Class transfer
          Local File EMPLOIDSA [ESA5]
          Raz [ESA5]
          SetInstance [F:ESA5] With I_ESSWRKSA
          SetInstance I_EMPLOIDSA With [F:ESA5]
          UPDATESTAT = fmet I_EMPLOIDSA.AINSERT()
          RETVAL = UPDATESTAT
          LogicClose File [ESA5]
        Else
          Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOIDSA) From ESS_WRKFLOW_FUNC_HYBRID
          RETVAL = [V]CST_AERROR
        Endif
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOIDSA) From ESS_WRKFLOW_FUNC_HYBRID
        RETVAL = [V]CST_AERROR
      Endif
    Endif
   Else
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKSA) From ESS_WRKFLOW_FUNC_HYBRID
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        For K = 1 To I_EMPLOIDSA.ObjectNbs
          If I_EMPLOIDSA.ObjectVar(K) = [F:ESWD7]FLDNAM
            Assign "I_EMPLOIDSA."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKSA."+[F:ESWD7]FLDNAM+")")
            Break
          Endif
        Next K
      Next

      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
    Elsif VWRK = "D"
      UPDATESTAT = fmet I_EMPLOIDSA.ADELETE()
    Endif
    If UPDATESTAT > [V]CST_AWARNING
      Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOIDSA) From ESS_WRKFLOW_FUNC_HYBRID
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOIDSA
Endif


#Gosub DELETE_ESSWRKSA #FRLAA X3-94079 2018-06-12
End RETVAL

