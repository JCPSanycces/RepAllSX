    If VWRK = "M"
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        For K = 1 To I_EMPLOIDUKI.ObjectNbs
          If I_EMPLOIDUKI.ObjectVar(K) = [F:ESWD7]FLDNAM
            Assign "I_EMPLOIDUKI."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKUKI."+[F:ESWD7]FLDNAM+")")
