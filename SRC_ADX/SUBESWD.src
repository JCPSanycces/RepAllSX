        Endif
      Endif
    Else
      RETVAL = [V]CST_AERROR
    Endif
  Else
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOIDSA.ADDADR <> null
          For X = 1 To maxtab(I_EMPLOIDSA.ADDADR)
            If X = INTROW
              For K = 1 To I_EMPLOIDSA.ADDADR(INTROW).ObjectNbs
               If I_EMPLOIDSA.ADDADR(INTROW) <> null
                If I_EMPLOIDSA.ADDADR(INTROW).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOIDSA.ADDADR("+num$(INTROW)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKSA."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOIDSA.AUPDATE()
    Elsif VWRK = "D"
      If I_EMPLOIDSA.ADDADR <> null
        For X = 1 To maxtab(I_EMPLOIDSA.ADDADR)
          If X = INTROW
            UPDATESTAT=fmet I_EMPLOID.I_EMPLOIDSA.ADELLINE("ADDADR",INTROW)
