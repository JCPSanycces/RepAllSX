##EMPLOCHD
Funprog UPDATE_TABLES_EMPLOCHD(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT, INITSTAT
RETVAL = [V]CST_AOK

Local File ESSWRKFLWDET [ESWD7]

If VEVT = "VIS"
  #Instantiate the main class in the system
  Local Instance I_EMPLOCHD Using C_EMPLOCHD
  If (I_EMPLOCHD <> null) : FreeGroup I_EMPLOCHD : Endif
  I_EMPLOCHD = NewInstance C_EMPLOCHD AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKCHD Using C_ESSWRKCHD
  If (I_ESSWRKCHD <> null) : FreeGroup I_ESSWRKCHD : Endif
  I_ESSWRKCHD = NewInstance C_ESSWRKCHD AllocGroup null

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKCHD.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM+NUMLIG
    READSTAT = fmet I_EMPLOCHD.AREAD(I_ESSWRKCHD.REFNUM,I_ESSWRKCHD.NUMLIG)
    If READSTAT >= [V]CST_AERROR
      #Test VWRK for new record
      If VWRK = "C"
        #Initialize new instance
        INITSTAT = fmet I_EMPLOCHD.AINIT()
        RETVAL = INITSTAT
#        If INITSTAT  = [V]CST_AOK
        If INITSTAT <= [V]CST_AWARNING
          #Class transfer
          Local File EMPLOCHD [CHD5]
          Raz [CHD5]
          SetInstance [F:CHD5] With I_ESSWRKCHD
          SetInstance I_EMPLOCHD With [F:CHD5]
          UPDATESTAT = fmet I_EMPLOCHD.AINSERT()
          RETVAL = UPDATESTAT
          LogicClose File [CHD5]
        Else
          Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOCHD) From ESS_WRKFLOW_FUNC_HYBRID
          RETVAL = [V]CST_AERROR
        Endif
      Else
        Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOCHD) From ESS_WRKFLOW_FUNC_HYBRID
        RETVAL = [V]CST_AERROR
      Endif
   Endif
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKCHD) From ESS_WRKFLOW_FUNC_HYBRID
    RETVAL = [V]CST_AERROR
  Endif


  #The actual action can now be tested and handled
#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        For K = 1 To I_EMPLOCHD.ObjectNbs
          If I_EMPLOCHD.ObjectVar(K) = [F:ESWD7]FLDNAM
           Assign "I_EMPLOCHD."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKCHD."+[F:ESWD7]FLDNAM+")")
           Break
          Endif
        Next K
      Next

      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOCHD.AUPDATE()
    Elsif VWRK = "D"
      UPDATESTAT = fmet I_EMPLOCHD.ADELETE()
    Endif
    If UPDATESTAT > [V]CST_AWARNING
      Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOCHD) From ESS_WRKFLOW_FUNC_HYBRID
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOCHD
Endif


#Gosub DELETE_ESSWRKCHD #FRLAA X3-94079 2018-06-12
End RETVAL

#PERCNT
Funprog UPDATE_TABLES_EMPLOIDRT(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT, INTROW,X,INITSTAT,L
RETVAL = [V]CST_AOK

If VEVT = "VIS"
  If !clalev([F:ESWD7]) : Local File ESSWRKFLWDET [ESWD7] : Endif

  #Instantiate the main class in the system
  Local Instance I_EMPLOID Using C_EMPLOID
  If (I_EMPLOID <> null) : FreeGroup I_EMPLOID : Endif
  I_EMPLOID = NewInstance C_EMPLOID AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKEMP Using C_ESSWRKEMP
  If (I_ESSWRKEMP <> null) : FreeGroup I_ESSWRKEMP : Endif
  I_ESSWRKEMP = NewInstance C_ESSWRKEMP AllocGroup null

  Read [ESWD7]ESWD0 = val(VUID);VCLA;VREFNUM;VMAIREC;VFIELD
  If !fstat
    INTROW = [ESWD7]INTKEY1
    If INTROW = 0
      End [V]CST_AERROR
    Endif
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKEMP.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM
    READSTAT = fmet I_EMPLOID.AREAD(I_ESSWRKEMP.REFNUM)
#    If READSTAT = [V]CST_AOK
    If READSTAT <= [V]CST_AWARNING
      #Test VWRK for new record
      If VWRK = "C"
        #Check the collection
        INITSTAT = [V]CST_AFALSE
        If I_EMPLOID.PERCNT <> null
          For X = 1 To maxtab(I_EMPLOID.PERCNT)
            If I_EMPLOID.PERCNT(X).ESSUIDCNT = I_ESSWRKEMP.ESSUIDCNT
              INITSTAT = [V]CST_ATRUE
              Break
            Endif

          Next X
          If  INITSTAT <> [V]CST_ATRUE
            Gosub ADD_EMPLOID_PERCNT
          Endif
        Else
          Gosub ADD_EMPLOID_PERCNT
        Endif
      Endif
    Else
      Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
      RETVAL = [V]CST_AERROR
    Endif
  Else
    Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKEMP) From ESS_WRKFLOW_FUNC_HYBRID
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    #Use the ESSUID to check NU
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOID.PERCNT <> null
          For X = 1 To maxtab(I_EMPLOID.PERCNT)
            If I_EMPLOID.PERCNT(X).ESSUIDCNT = I_ESSWRKEMP.ESSUIDCNT
              For K = 1 To I_EMPLOID.PERCNT(X).ObjectNbs
               If I_EMPLOID.PERCNT(X) <> null and [F:ESWD7]FLDNAM <> "CNTTYP"

                If I_EMPLOID.PERCNT(X).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOID.PERCNT("+num$(X)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKEMP."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      If func AFNC.ACTIV("KGZA")>0
        For [ESWD7]ESWD0
        If I_EMPLOID.EMPLOIDSA.PERCNT <> null
          For X = 1 To maxtab(I_EMPLOID.EMPLOIDSA.PERCNT)
            If I_EMPLOID.EMPLOIDSA.PERCNT(X).ESSUIDCNT = I_ESSWRKEMP.ESSUIDCNT
              For K = 1 To I_EMPLOID.EMPLOIDSA.PERCNT(X).ObjectNbs
               If I_EMPLOID.EMPLOIDSA.PERCNT(X) <> null and [F:ESWD7]FLDNAM = "CNTTYP"
                If I_EMPLOID.EMPLOIDSA.PERCNT(X).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOID.EMPLOIDSA.PERCNT("+num$(X)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKEMP."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      Endif
      Filter [ESWD7]
      I_EMPLOID.NBCNT =  I_ESSWRKEMP.NBCNT
      UPDATESTAT = fmet I_EMPLOID.AUPDATE()
      If UPDATESTAT > [V]CST_AWARNING
        Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
      Endif

    Elsif VWRK = "D"
      If I_EMPLOID.PERCNT <> null
        For X = 1 To maxtab(I_EMPLOID.PERCNT)
          If I_EMPLOID.PERCNT(X).ESSUIDCNT = I_ESSWRKEMP.ESSUIDCNT
            UPDATESTAT=fmet I_EMPLOID.ADELLINE("PERCNT",X)
#              If UPDATESTAT = [V]CST_AOK
              If UPDATESTAT <= [V]CST_AWARNING
                I_EMPLOID.NBCNT =  I_ESSWRKEMP.NBCNT
                UPDATESTAT = fmet I_EMPLOID.AUPDATE()
                  If UPDATESTAT > [V]CST_AWARNING
                    Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
                  Endif
              Endif
          Endif
        Next X
      Endif
      If func AFNC.ACTIV("KGZA")>0
        If I_EMPLOID.EMPLOIDSA.PERCNT <> null
          For X = 1 To maxtab(I_EMPLOID.EMPLOIDSA.PERCNT)
            If I_EMPLOID.EMPLOIDSA.PERCNT(X).ESSUIDCNT = I_ESSWRKEMP.ESSUIDCNT
              UPDATESTAT=fmet I_EMPLOID.EMPLOIDSA.ADELLINE("PERCNT",X)
#                If UPDATESTAT = [V]CST_AOK
                If UPDATESTAT <= [V]CST_AWARNING
                  UPDATESTAT = fmet I_EMPLOID.AUPDATE()
#                  If UPDATESTAT = [V]CST_AOK
                  If UPDATESTAT <= [V]CST_AWARNING
                    I_EMPLOID.NBCNT =  I_ESSWRKEMP.NBCNT
                    UPDATESTAT = fmet I_EMPLOID.AUPDATE()
                      If UPDATESTAT > [V]CST_AWARNING
                        Call RECOVERS_ERROR_IN_CLASSIC(I_EMPLOID) From ESS_WRKFLOW_FUNC_HYBRID
                      Endif
                  Endif
                Endif
            Endif
          Next X
        Endif
      Endif
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOID
Endif


#Gosub DELETE_ESSWRKEMP #FRLAA X3-94079 2018-06-12
End RETVAL

$ADD_EMPLOID_PERCNT
#Collection does not exist and can be created
#Class transfer
Local File EMPLOIDRT [IDRT5]
Raz [IDRT5]
SetInstance [F:IDRT5] With I_ESSWRKEMP
L = fmet I_EMPLOID.ADDLINE("PERCNT",[V]CST_ALASTPOS)

SetInstance I_EMPLOID.PERCNT(L) With [F:IDRT5]
If func AFNC.ACTIV("KGZA")>0
  Gosub ADD_EMPLOID_PERCNT_KZA
Endif

I_EMPLOID.NBCNT =  I_ESSWRKEMP.NBCNT
UPDATESTAT = fmet I_EMPLOID.AUPDATE()
RETVAL = UPDATESTAT
LogicClose File [IDRT5]
Return

$ADD_EMPLOID_PERCNT_KZA
Local Integer I
If I_EMPLOID.EMPLOIDSA <> null
  #For I = 1 To maxtab(I_EMPLOID.EMPLOIDSA) #Extend
    L = fmet I_EMPLOID.EMPLOIDSA.ADDLINE("PERCNT",[V]CST_ALASTPOS)
    SetInstance I_EMPLOID.EMPLOIDSA.PERCNT(L) With [F:IDRT5]
Endif
Return

#Middle east - Additional addresses
Funprog UPDATE_TABLES_EMPLOIDMIDRT(VMAIREC,VREFNUM,VCLA,VUID,VFIELD,VMAIN,VEVT,VWRK)
Value Integer VMAIREC
Value Char VFIELD,VREFNUM,VCLA,VMAIN,VEVT,VWRK
Value Char VUID
Local Integer READSTAT,K,RETVAL,UPDATESTAT, INTROW,X,INITSTAT,L
RETVAL = [V]CST_AOK

If VEVT = "VIS"
  Local File ESSWRKFLWDET [ESWD7]


  #Instantiate the main class in the system
  Local Instance I_EMPLOIDMID Using C_EMPLOIDMID
  If (I_EMPLOIDMID <> null) : FreeGroup I_EMPLOIDMID : Endif
  I_EMPLOIDMID = NewInstance C_EMPLOIDMID AllocGroup null

  #Instantiate the respective ESS class in the system
  Local Instance I_ESSWRKMID Using C_ESSWRKMID
  If (I_ESSWRKMID <> null) : FreeGroup I_ESSWRKMID : Endif
  I_ESSWRKMID = NewInstance C_ESSWRKMID AllocGroup null

  Read [ESWD7]ESWD0 = val(VUID);VCLA;VREFNUM;VMAIREC;VFIELD
  If !fstat
    INTROW = [ESWD7]INTKEY1
    If INTROW = 0
      End [V]CST_AERROR
    Endif
  Endif

  #Read the ESS class using VUID
  READSTAT = fmet I_ESSWRKMID.AREAD(val(VUID))
#  If READSTAT = [V]CST_AOK
  If READSTAT <= [V]CST_AWARNING
    #Read the main class with correct key
    #REFNUM
    READSTAT = fmet I_EMPLOIDMID.AREAD(I_ESSWRKMID.REFNUM)
#    If READSTAT = [V]CST_AOK
    If READSTAT <= [V]CST_AWARNING
      #Test VWRK for new record
      If VWRK = "C"
        #Check the collection
        INITSTAT = [V]CST_AFALSE
        If I_EMPLOIDMID.ADDADR <> null
          For X = 1 To maxtab(I_EMPLOIDMID.ADDADR)
            If X = INTROW
              INITSTAT = [V]CST_ATRUE
              Break
            Endif
          Next X
          If  INITSTAT <> [V]CST_ATRUE
            Gosub ADD_EMPLOIDMID_ADDADR
          Endif
        Else
          Gosub ADD_EMPLOIDMID_ADDADR
        Endif
      Endif
    Else
      RETVAL = [V]CST_AERROR
    Endif
  Else
    RETVAL = [V]CST_AERROR
  Endif

#  If RETVAL = [V]CST_AOK
  If RETVAL <= [V]CST_AWARNING
    If VWRK = "M"
      Filter [ESWD7]
      #Loop through all possible records on the workflow detail - Excluding the main record
      Filter [F:ESWD7] Where UID = val(VUID) and MAIREC <> VMAIREC
      For [ESWD7]ESWD0
        If I_EMPLOIDMID.ADDADR <> null
          For X = 1 To maxtab(I_EMPLOIDMID.ADDADR)
            If X = INTROW
              For K = 1 To I_EMPLOIDMID.ADDADR(INTROW).ObjectNbs
               If I_EMPLOIDMID.ADDADR(INTROW) <> null
                If I_EMPLOIDMID.ADDADR(INTROW).ObjectVar(K) = [F:ESWD7]FLDNAM
                 Assign "I_EMPLOIDMID.ADDADR("+num$(INTROW)+")."+[F:ESWD7]FLDNAM With evalue("(I_ESSWRKMID."+[F:ESWD7]FLDNAM+")")
                 Break
                Endif
               Endif
              Next K
            Endif
          Next X
        Endif
      Next
      Filter [ESWD7]
      UPDATESTAT = fmet I_EMPLOIDMID.AUPDATE()
    Elsif VWRK = "D"
      If I_EMPLOIDMID.ADDADR <> null
        For X = 1 To maxtab(I_EMPLOIDMID.ADDADR)
          If X = INTROW
            UPDATESTAT=fmet I_EMPLOID.I_EMPLOIDMID.ADELLINE("ADDADR",INTROW)
#            If UPDATESTAT = [V]CST_AOK
            If UPDATESTAT <= [V]CST_AWARNING
              UPDATESTAT = fmet I_EMPLOIDMID.AUPDATE()
            Endif
          Endif
        Next X
      Endif
    Endif
    RETVAL = UPDATESTAT
  Endif
  Gosub FREE_EMPLOIDMID
Endif


Gosub DELETE_ESSWRKMID

End RETVAL

$ADD_EMPLOIDMID_ADDADR
