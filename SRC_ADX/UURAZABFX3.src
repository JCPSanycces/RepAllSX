#<AdxTL>@(#)2.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Raz table BI avant intégration du dico V6.1 standard
#----------------------------------------------------------------------------------------#
Call OUVRE_TRACE("Raz table BI pour la V6.1") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call OUINON("Raz table ABF pour la V6.1 sur le dossier"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 Call PATCH(nomap)
Else
 Call OUINON("Raz table ABF pour la V6.1 sur tous les dossiers filles de"-nomap,GBIDI1) From GESECRAN
 If GBIDI1<>2 : End : Endif
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If GPRODUIT <> 0 : End : Endif
Gosub RAZBI
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
If GPRODUIT <> 0 : End : Endif
Gosub RAZBI
End

#-------------------#
$RAZBI

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS([L]DOSSIER,"ABI") 
 Return
Endif

Local File =DOSSIER+".ABITABFLD"    [ABZ]
Local File =DOSSIER+".ABITABLNK"    [ABK]
Local File =DOSSIER+".ABITABIND"    [ABX]
Local File =DOSSIER+".ABITABDAT"    [ABF]
Local File =DOSSIER+".ABITABAGG"    [ABE]

# Raz des tables ABF
Trbegin [ABF]

  ### Table de fait
  Call ECR_TRACE(mess(81,125,1)-"ABITABDAT:"-time$,0) From GESECRAN
  For [ABF] Where  CODABF<"X" and CODACT<"X"
   # Champs 
   Delete [ABZ] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABFLD",3) From DOSDIC : Endif
   # Liens 
   Delete [ABK] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABLNK",3) From DOSDIC : Endif
   # Index 
   Delete [ABX] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABIND",3) From DOSDIC : Endif
   # Index 
   Delete [ABE] Where CODABF=[F:ABF]CODABF
   If fstat : Call ERREUR("ABITABAGG",3) From DOSDIC : Endif
   # table de fait
   Delete [ABF]Curr
   If fstat : Call ERREUR("ABITABDAT",3) From DOSDIC : Endif
  Next 

Commit

Close Local File [ABZ],[ABK],[ABX],[ABE],[ABF]

Return





