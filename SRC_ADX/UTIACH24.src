#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################
# UTIACH24      Utilitaire de réajustement des tables       Module ACHAT #
#               achats en v6 suite à la non exécution                    #
#               des AP_ de la migration v130 -> v140/v5       21/09/2010 #
# ---------------------------------------------------------------------- #
#                                                                        #
##########################################################################


Call MAJ_UTIACH24
End


Subprog MAJ_UTIACH24
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle WSIMUL  : WSIMUL=1     : # 0=normale, 1=simulation (pas de màj)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTIACH24 - Réajustement tables achats en v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTIACH24 : Réjustement tables achats en v6") From LECFIC
    Call ECR_TIME("UTIACH24 : Starting process on folder "+WDOSSIER) From DOSSUB
  Endif
  Call EXE_UTIACH24(WDOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTIACH24(WDOSSIER,WTRACE,WSIMUL)
Value Char     WDOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL
#----- Variables locales -----#
Local Char     WMSG(90)
Local Integer  NBENR, NBCOR, WNBR
Local Char     CLE1(GLONVCR)
Local Integer  CLE2
Local Integer  CLE3
Local Char     CRITERE(150)
Local Integer COMPTEUR, STOP
Local Libelle  WFLAG1, WFLAG2
Local Integer  WINVLINCTR
Local Decimal  WMT
Local Decimal  WCOEFF
Local Char     VAT(GLONVAT)(3)
Local Integer  I
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If dim(GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
Gosub TRT_POH
Gosub TRT_PTH 
Gosub TRT_PTD
Gosub TRT_PNH
Gosub TRT_PND
Gosub TRT_PIV
Gosub TRT_PID
#-----
$FIN_UTIACH24
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Endif
#-----
End


#-----------------------------------------------------------------------#
# Alimentation des nouvelles zones du PORDER, PORDERQ, PORDERC          #
# --------------------------------------------------------------------- #
# Fichier PORDER                                                        #
#      Pour les contrats inter-sites existants uniquement               #
#         OCNNUM    : numéro de commande vente  issu de ORDREF          #
#         OCNDAT    : date de commande de vente issu de ORDDAT          #
#         OCNREM    : libelle                                           #
#         BETCPY    : inter-société                                     #
#         STOFCY    : Site d'expé                                       #
#         BPCORD    : Client commande issu de la commande               #
#         DME       : Livraison partielle                               #
#         SOHCAT    : Type commande vente                               #
#      Pour les autres commandes                                        #
#         CLELINNBR : Nbre de lignes soldées                            #
#         CLEFLG    : Indicateur commande soldée                        #
# Fichier PORDERQ                                                       #
#      Pour les contrats inter-sites existants uniquement               #
#         LINSTOFCY : Site d'expé. issu du site de vente SALFCY         #
#         LINOCNNUM : Numéro de commande de vente issu de SOHNUM        #
#         LINOCNDAT : Date de commande de vente issu date de commande   #
#         OCNLIN    : Numéro de lg cde de vente issu SOPLIN             #
#         OCNSEQ    : Numéro de seq cde de vente issu SOQSEQ            #
#         Raz SOHNUM, SOPLIN, SOQSEQ : zones réservées contremarque     #
# Fichier PORDERC                                                       #
#      Pour les contrats inter-sites existants uniquement               #
#         LINSTOFCY : # Site d'expé. issu du site de vente de l'entête  #
#-----------------------------------------------------------------------#
$TRT_POH
Local File =[F:ADS]DOSSIER+".PORDER"   [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"  [POQ]
Local File =[F:ADS]DOSSIER+".PORDERC"  [POC]
Local File =[F:ADS]DOSSIER+".BPARTNER" [BPR]
If [F:ADS]MODULE(5)=2
  Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR2]
  Local File =[F:ADS]DOSSIER+".BPDLVCUST"  [BPD]
  Local File =[F:ADS]DOSSIER+".SORDER"     [SOH]
Endif
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTIACH24 : Purchase Order Process 1 : Update PORDER-Q-C") From DOSSUB
Endif
Raz CLE1, STOP, NBENR, NBCOR
#-----
$BOUCLE_POH
If  STOP=1
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [POH],[POQ],[POC]
  For [POH] POH0 Where evalue(CRITERE)
    Raz WFLAG1, WFLAG2
    NBENR+=1
    If [F:POH]BETFCY=0
      If WTRACE=2
        WMSG=[F:POH]POHNUM-"- BETFCY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:POH]BETFCY=1 : WFLAG1=1
    Endif
    If [F:POH]BETCPY=0
      If WTRACE=2
        WMSG=[F:POH]POHNUM-"- BETCPY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:POH]BETCPY=1 : WFLAG1=1
    Endif
    If [F:POH]POHTYP=2 & [F:POH]BETFCY=2
      If [F:POH]STOFCY=""
        If WTRACE=2
          WMSG=[F:POH]POHNUM-"- STOFCY : -->"-[F:POH]SALFCY
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:POH]STOFCY=[F:POH]SALFCY  : WFLAG1=1
      Endif
      If [F:POH]OCNNUM=""
        Look [SOH] SOH0=[F:POH]ORDREF
      Else
        Look [SOH] SOH0=[F:POH]OCNNUM
      Endif
      #----- Si la commande de vente existe -----#
      If !fstat
        If [F:POH]OCNNUM=""
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- OCNNUM : -->"-[F:POH]ORDREF
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]OCNNUM=[F:POH]ORDREF  : WFLAG1=1 : # Numéro de commande vente
        Endif
        If [F:POH]OCNDAT<>[F:POH]ORDDAT
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- OCNDAT :"-num$([F:POH]OCNDAT)-"-->"-num$([F:POH]ORDDAT)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]OCNDAT=[F:POH]ORDDAT  : WFLAG1=1 : # Date de commande de vente
        Endif
        If [F:POH]OCNREM<>mess(74,187,1)
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- OCNREM :"-[F:POH]OCNREM-"-->"-mess(74,187,1)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]OCNREM=mess(74,187,1) : WFLAG1=1 : # Libelle
        Endif
        If [F:SOH]SOHNUM<>[F:POH]OCNNUM
          Read [SOH] SOH0=[F:POH]OCNNUM : If fstat  Raz [F:SOH] : Endif
        Endif
        If [F:POH]SOHCAT<>[F:SOH]SOHCAT
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- SOHCAT :"-num$([F:POH]SOHCAT)-"-->"-num$([F:SOH]SOHCAT)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]SOHCAT=[F:SOH]SOHCAT  : WFLAG1=1
        Endif
        If [F:POH]BPCORD<>[F:SOH]BPCORD
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- BPCORD :"-[F:POH]BPCORD-"-->"-[F:SOH]BPCORD
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]BPCORD=[F:SOH]BPCORD  : WFLAG1=1
        Endif
        If [F:POH]DME<>[F:SOH]DME
          If WTRACE=2
            WMSG=[F:POH]POHNUM-"- DME    :"-num$([F:POH]DME)-"-->"-num$([F:SOH]DME)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]DME   =[F:SOH]DME     : WFLAG1=1
        Endif
        #-----
        For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
          NBENR+=1
          If [F:POQ]LINSTOFCY=""
            If WTRACE=2
              WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
              WMSG-="- LINSTOFCY :"-[F:POQ]LINSTOFCY-"-->"-[F:POH]SALFCY
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POQ]LINSTOFCY=[F:POH]SALFCY : WFLAG2=1
          Endif
          If [F:POQ]SOHNUM<>""
            If WTRACE=2
              WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
              WMSG-="- LINOCNNUM :"-[F:POQ]LINOCNNUM-"-->"-[F:POQ]SOHNUM
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POQ]LINOCNNUM=[F:POQ]SOHNUM : WFLAG2=1
          Endif
          If [F:POQ]LINOCNDAT<>[F:POQ]ORDDAT
            If WTRACE=2
              WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
              WMSG-="- LINOCNDAT :"-num$([F:POQ]LINOCNDAT)-"-->"-num$([F:POQ]ORDDAT)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POQ]LINOCNDAT=[F:POQ]ORDDAT : WFLAG2=1
          Endif
          If [F:POQ]SOPLIN<>0
            If WTRACE=2
              WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
              WMSG-="- OCNLIN    :"-num$([F:POQ]OCNLIN)-"-->"-num$([F:POQ]SOPLIN)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POQ]OCNLIN=[F:POQ]SOPLIN : WFLAG2=1
          Endif
          If [F:POQ]SOQSEQ<>0
            If WTRACE=2
              WMSG =[F:POQ]POHNUM-num$([F:POQ]POPLIN)-num$([F:POQ]POQSEQ)
              WMSG-="- OCNSEQ    :"-num$([F:POQ]OCNSEQ)-"-->"-num$([F:POQ]SOQSEQ)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POQ]OCNSEQ=[F:POQ]SOQSEQ : WFLAG2=1
          Endif
          Raz [F:POQ]SOHNUM, [F:POQ]SOPLIN, [F:POQ]SOQSEQ
          If WFLAG2
            COMPTEUR+=1 : NBCOR+=1
            Rewrite [POQ]
            If fstat & WTRACE
              Call ECR_TRACE("File PORDERQ, Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Next 
        #----- Boucle sur les lignes article du contrat -----#
        For [POC] POC0 Where POHNUM=[F:POH]POHNUM
          NBENR+=1
          If [F:POC]STOFCY=""
            If WTRACE=2
              WMSG =[F:POC]POHNUM-num$([F:POC]POPLIN)
              WMSG-="- STOFCY    :"-[F:POC]STOFCY-"-->"-[F:POH]SALFCY
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:POC]STOFCY=[F:POH]SALFCY
            COMPTEUR+=1 : NBCOR+=1
            Rewrite [POC]
            If fstat & WTRACE
              Call ECR_TRACE("File PORDERC, Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Next
        #-----
      Endif
    Elsif [F:POH]POHTYP=1
      Raz WNBR
      For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
        If [F:POQ]LINCLEFLG=2  WNBR+=1 : Endif   
      Next
      If [F:POH]CLELINNBR<>WNBR
        If WTRACE=2
          WMSG =[F:POH]POHNUM-"- CLELINNBR :"-num$([F:POH]CLELINNBR)-"-->"-num$(WNBR)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:POH]CLELINNBR=WNBR : WFLAG1=1
      Endif
      If [F:POH]CLELINNBR>=[F:POH]LINNBR 
        If [F:POH]CLEFLG<>2
          If WTRACE=2
            WMSG =[F:POH]POHNUM-"- CLEFLG    :"-num$([F:POH]CLEFLG)-"--> 2"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]CLEFLG=2 : WFLAG1=1
        Endif
      Else
        If [F:POH]CLEFLG<>1
          If WTRACE=2
            WMSG =[F:POH]POHNUM-"- CLEFLG    :"-num$([F:POH]CLEFLG)-"--> 1"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:POH]CLEFLG=1 : WFLAG1=1
        Endif
      Endif
    Endif
    #-----
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [POH]
      If fstat & WTRACE
        Call ECR_TRACE("File PORDER, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:POH]POHNUM : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP  Goto BOUCLE_POH : Endif
#-----
Close Local File [POH], [POQ], [POC], [BPR]
If [F:ADS]MODULE(5)=2
  Close Local File  [BPR2], [BPD], [SOH]
Endif
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------------------#
# Chargement du nombre de lignes facturées INVLINCTR dans la table PRECEIPT #
# Mise à jour de l'indicateur "Facturée"   INVFLG    dans la table PRECEIPT #
#---------------------------------------------------------------------------#
$TRT_PTH
Local File =[F:ADS]DOSSIER+".PRECEIPT"   [PTH]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24:  Purchase Receipt Process 1 : Update PRECEIPT") From DOSSUB
Endif
Raz CLE1, STOP, NBENR, NBCOR
#-----
$BOUCLE_PTH
If STOP=1
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PTH]
  For [PTH] PTH0 Where evalue(CRITERE)
    Raz WFLAG1
    NBENR+=1
    If [F:PTH]BETFCY=0
      If WTRACE=2
        WMSG=[F:PTH]PTHNUM-"- BETFCY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PTH]BETFCY=1 : WFLAG1=1
    Endif
    If [F:PTH]BETCPY=0
      If WTRACE=2
        WMSG=[F:PTH]PTHNUM-"- BETCPY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PTH]BETCPY=1 : WFLAG1=1
    Endif
    Raz WINVLINCTR
    For [PTD] Where PTHNUM=[F:PTH]PTHNUM & INVQTYPUU<>0
      WINVLINCTR+=1
    Next
    If WINVLINCTR>[F:PTH]INVLINCTR
      If WTRACE=2
        WMSG=[F:PTH]PTHNUM-"- INVLINCTR :"-num$([F:PTH]INVLINCTR)-"-->"-num$(WINVLINCTR)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PTH]INVLINCTR=WINVLINCTR : WFLAG1=1
    Endif
    #----- Ne pas modifier l'indicateur si valeur = totalement facturé ! -----#
    If [F:PTH]INVFLG<>3
      If [F:PTH]LINNBR<=[F:PTH]INVLINNBR
        If [F:PTH]INVFLG<>3
          If WTRACE=2
            WMSG=[F:PTH]PTHNUM-"- INVFLG    :"-num$([F:PTH]INVFLG)-"--> 3"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTH]INVFLG=3 : WFLAG1=1
        Endif
      Elsif [F:PTH]INVLINNBR<>0 | [F:PTH]INVLINCTR<>0
        If [F:PTH]INVFLG<>2
          If WTRACE=2
            WMSG=[F:PTH]PTHNUM-"- INVFLG    :"-num$([F:PTH]INVFLG)-"--> 2"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTH]INVFLG=2 : WFLAG1=1
        Endif
      Else
        If [F:PTH]INVFLG<>1
          If WTRACE=2
            WMSG=[F:PTH]PTHNUM-"- INVFLG    :"-num$([F:PTH]INVFLG)-"--> 1"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTH]INVFLG=1 : WFLAG1=1
        Endif
      Endif
    Endif
    #----- Réécriture de l'entête de réception -----#
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PTH]
      If fstat & WTRACE
        Call ECR_TRACE("File PRECEIPT, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTH]PTHNUM : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PTH : Endif
#-----
Close Local File [PTH], [PTD]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#-------------------------------------------------------------------------#
# Alimentation des nouvelles zones table PRECEIPTD                        #
# ----------------------------------------------------------------------- #
# GROPRI         : Prix brut   Repris de la commande si on en a un POP    #
# PRIREN         : Motif prix  Repris de la commande si on en a un POP    #
# DISCRGVAL1 à 9               Repris de la commande si on en a un POP    #
# DISCRGREN1 à 9               Repris de la commande si on en a un POP    #
# SDHNUM         : N.Livraison Issu de la commande POQ                    #
# SDDLIN         : Lg Livrais  Issu de la commande POQ                    #
# UOMSTUCOE      : Coeff       UOM-STU                                    #
# QUAFLG         : Soumis CTL  Issu de la commande POP,si pas de commande #
#                              issu de l'article fourni ou article        #
# NETPRI                       Calculé à partir du NETPRIPUU de la récept #
#                              et du coeff UOMPUUCOE de la réception      #
# NETCUR         : Devise      Si non renseigné issu de la commande POQ   #
#                              ou de l'entête de réception                #
# LINAMT         : Montant HT  Calculé                                    #
# LINATIAMT      : Montant TTC Calculé                                    #
# LINSTOFCY      : Site d'exp  Pour intersite seulement                   #
#                              Reprise du site lié au fournisseur         #
# RRRQTYPUU      : Raz pour les articles gérés en stock                   #
# RRRQTYSTU      : Raz pour les articles gérés en stock                   #
# CPRCOE         : Initialisation à 1 si on a 0                           #
# CLCAMT1        : Base taxe1 Issu de la commande POQ                     #
# CLCAMT2        : Base taxe2 Issu de la commande POQ                     #
# STOMGTCOD      : Issu de ITM                                            #
#-------------------------------------------------------------------------#
$TRT_PTD
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
Local File =[F:ADS]DOSSIER+".PRECEIPT"    [PTH]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"     [POP]
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
Local File =[F:ADS]DOSSIER+".ITMBPS"      [ITP]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
#----- Pour Call CLCTAXEMNT et ARRDEV -----#
Local File =[F:ADS]DOSSIER+".TABVAT"      [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"   [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24 : Purchase Receipt Process 2 : Update PRECEIPTD") From DOSSUB
Endif
Raz CLE1, CLE2, STOP, NBENR, NBCOR
#-----
$BOUCLE_PTD
If STOP=1
  CRITERE='PTHNUM="'+CLE1+'" & PTDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PTHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PTD]
  For [PTD] PTD0 Where evalue(CRITERE)
    Raz WFLAG2
    NBENR+=1
    #----- Calcul du coefficient UOM/STU -----#
    If [F:PTD]QTYUOM<>0 & [F:PTD]UOMSTUCOE=0
      [F:PTD]UOMSTUCOE=arr([F:PTD]QTYSTU/[F:PTD]QTYUOM,0.000001) : WFLAG2=1
      If [F:PTD]UOMSTUCOE=0  [F:PTD]UOMSTUCOE=1 : Endif
      If WTRACE=2
        WMSG=[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"- UOMSTUCOE : 0 -->"-num$([F:PTD]UOMSTUCOE)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:PTD]PRHFCY<>GFCY
      GFCY=[F:PTD]PRHFCY
      Call DEFSITE(GFCY)  From TRTACHDEF1
    Endif   
    #----- Lecture entête commande si nécessaire -----# 
    If [F:POH]POHNUM<>[F:PTD]POHNUM & [F:PTD]POHNUM<>""
      Raz [F:POQ], [F:POP]
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat
        Raz [F:POH]
        If WTRACE
          Call ECR_TRACE("File PORDER"-[F:PTD]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
    #----- Lecture ligne commande quantités si nécessaire -----#
    If [F:POH]POHNUM<>"" & [F:PTD]POPLIN<>0
      If [F:POH]BETFCY<>2
        If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&          [F:POQ]POPLIN<>[F:PTD]POPLIN |
&          [F:POQ]POQSEQ<>[F:PTD]POQSEQ
          Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
          If fstat
            Raz [F:POQ]
            If WTRACE
              Call ECR_TRACE("File PORDERQ"-[F:POH]POHNUM-num$([F:PTD]POPLIN)+", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Endif
      Else
        If [F:POQ]POHNUM<>[F:PTD]POHNUM |
&          [F:POQ]POPLIN<>[F:PTD]POPLIN |
&          [F:POQ]PTHNUM<>[F:PTD]PTHNUM |
&          [F:POQ]PTDLIN<>[F:PTD]PTDLIN |
&          [F:POQ]ITMREF<>[F:PTD]ITMREF
          Raz [F:POQ]
          For [POQ] POQ0 Where POHNUM=[F:PTD]POHNUM
&                            & POPLIN=[F:PTD]POPLIN
&                            & PTHNUM=[F:PTD]PTHNUM
&                            & PTDLIN=[F:PTD]PTDLIN
&                            & ITMREF=[F:PTD]ITMREF
            Break
          Next
        Endif
      Endif
    Endif
    If [F:POH]POHNUM<>"" & [F:POQ]POHNUM<>""
      #----- Lecture ligne commande prix si nécessaire -----#
      If [F:POH]POHTYP<>2
        If [F:POP]POHNUM<>[F:PTD]POHNUM | [F:POP]POPLIN<>[F:PTD]POPLIN
&        | [F:POP]POPSEQ<>1
         Read [POP] POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;1
         If fstat  Raz [F:POP] : Endif
        Endif
      Else
         Filter [POP] Where POHNUM =[F:PTD]POHNUM
&                         & POPLIN =[F:PTD]POPLIN
&                         & POPDAT>=[F:POQ]DEMRCPDAT
         Read [POP] POP1 First
         Filter [POP] 
         If fstat  Raz [F:POP]  : Endif
      Endif
    Else 
      Raz [F:POP]
    Endif
    If [F:ITM]ITMREF<>[F:PTD]ITMREF
      Read [ITM] ITM0=[F:PTD]ITMREF
      If fstat
        Raz [F:ITM]
        If WTRACE & [F:PTD]ITMREF<>""
          Call ECR_TRACE("File ITMMASTER"-[F:PTD]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Endif
    Endif
    If [F:ITP]ITMREF<>[F:PTD]ITMREF | [F:ITP]BPSNUM<>[F:PTH]BPSNUM
      Read [ITP] ITP0=[F:PTD]ITMREF;[F:PTH]BPSNUM
      If fstat  Raz [F:ITP] : Endif
    Endif 
    #----- On a une commande -----#
    If [F:PTD]POHNUM<>""
      #----- On a un POP récupération des prix -----#
      If [F:POP]POHNUM<>""
        If [F:PTD]PRIREN=0 & [F:PTD]PRIREN<>[F:POP]PRIREN
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- PRIREN    :"-num$([F:PTD]PRIREN)-"-->"-num$([F:POP]PRIREN)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]PRIREN    =[F:POP]PRIREN     : WFLAG2=1
        Endif
        If [F:PTD]GROPRI=[F:POP]GROPRI
          If [F:PTD]DISCRGVAL1=0 & [F:PTD]DISCRGVAL1<>[F:POP]DISCRGVAL1
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL1:"-num$([F:PTD]DISCRGVAL1)-"-->"-num$([F:POP]DISCRGVAL1)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL1=[F:POP]DISCRGVAL1 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL2=0 & [F:PTD]DISCRGVAL2<>[F:POP]DISCRGVAL2
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL2:"-num$([F:PTD]DISCRGVAL2)-"-->"-num$([F:POP]DISCRGVAL2)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL2=[F:POP]DISCRGVAL2 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL3=0 & [F:PTD]DISCRGVAL3<>[F:POP]DISCRGVAL3
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL3:"-num$([F:PTD]DISCRGVAL3)-"-->"-num$([F:POP]DISCRGVAL3)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL3=[F:POP]DISCRGVAL3 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL4=0 & [F:PTD]DISCRGVAL4<>[F:POP]DISCRGVAL4
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL4:"-num$([F:PTD]DISCRGVAL4)-"-->"-num$([F:POP]DISCRGVAL4)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL4=[F:POP]DISCRGVAL4 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL5=0 & [F:PTD]DISCRGVAL5<>[F:POP]DISCRGVAL5
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL5:"-num$([F:PTD]DISCRGVAL5)-"-->"-num$([F:POP]DISCRGVAL5)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL5=[F:POP]DISCRGVAL5 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL6=0 & [F:PTD]DISCRGVAL6<>[F:POP]DISCRGVAL6
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL6:"-num$([F:PTD]DISCRGVAL6)-"-->"-num$([F:POP]DISCRGVAL6)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL6=[F:POP]DISCRGVAL6 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL7=0 & [F:PTD]DISCRGVAL7<>[F:POP]DISCRGVAL7
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL7:"-num$([F:PTD]DISCRGVAL7)-"-->"-num$([F:POP]DISCRGVAL7)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL7=[F:POP]DISCRGVAL7 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL8=0 & [F:PTD]DISCRGVAL8<>[F:POP]DISCRGVAL8
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL8:"-num$([F:PTD]DISCRGVAL8)-"-->"-num$([F:POP]DISCRGVAL8)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL8=[F:POP]DISCRGVAL8 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGVAL9=0 & [F:PTD]DISCRGVAL9<>[F:POP]DISCRGVAL9
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGVAL9:"-num$([F:PTD]DISCRGVAL9)-"-->"-num$([F:POP]DISCRGVAL9)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGVAL9=[F:POP]DISCRGVAL9 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN1=0 & [F:PTD]DISCRGREN1<>[F:POP]DISCRGREN1
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN1:"-num$([F:PTD]DISCRGREN1)-"-->"-num$([F:POP]DISCRGREN1)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN1=[F:POP]DISCRGREN1 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN2=0 & [F:PTD]DISCRGREN2<>[F:POP]DISCRGREN2
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN2:"-num$([F:PTD]DISCRGREN2)-"-->"-num$([F:POP]DISCRGREN2)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN2=[F:POP]DISCRGREN2 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN3=0 & [F:PTD]DISCRGREN3<>[F:POP]DISCRGREN3
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN3:"-num$([F:PTD]DISCRGREN3)-"-->"-num$([F:POP]DISCRGREN3)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN3=[F:POP]DISCRGREN3 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN4=0 & [F:PTD]DISCRGREN4<>[F:POP]DISCRGREN4
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN4:"-num$([F:PTD]DISCRGREN4)-"-->"-num$([F:POP]DISCRGREN4)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN4=[F:POP]DISCRGREN4 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN5=0 & [F:PTD]DISCRGREN5<>[F:POP]DISCRGREN5
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN5:"-num$([F:PTD]DISCRGREN5)-"-->"-num$([F:POP]DISCRGREN5)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN5=[F:POP]DISCRGREN5 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN6=0 & [F:PTD]DISCRGREN6<>[F:POP]DISCRGREN6
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN6:"-num$([F:PTD]DISCRGREN6)-"-->"-num$([F:POP]DISCRGREN6)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN6=[F:POP]DISCRGREN6 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN7=0 & [F:PTD]DISCRGREN7<>[F:POP]DISCRGREN7
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN7:"-num$([F:PTD]DISCRGREN7)-"-->"-num$([F:POP]DISCRGREN7)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN7=[F:POP]DISCRGREN7 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN8=0 & [F:PTD]DISCRGREN8<>[F:POP]DISCRGREN8
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN8:"-num$([F:PTD]DISCRGREN8)-"-->"-num$([F:POP]DISCRGREN8)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN8=[F:POP]DISCRGREN8 : WFLAG2=1
          Endif
          If [F:PTD]DISCRGREN9=0 & [F:PTD]DISCRGREN9<>[F:POP]DISCRGREN9
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- DISCRGREN9:"-num$([F:PTD]DISCRGREN9)-"-->"-num$([F:POP]DISCRGREN9)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]DISCRGREN9=[F:POP]DISCRGREN9 : WFLAG2=1
          Endif
        Endif
        #-----
        If [F:PTD]QUAFLG=0
          If [F:ITP]ITMREF<>""
            If [F:PTD]QUAFLG<>[F:ITP]QUAFLG
              If WTRACE=2
                WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"-->"-num$([F:ITP]QUAFLG)
                Call ECR_TRACE(WMSG,0) From GESECRAN
              Endif
              [F:PTD]QUAFLG=[F:ITP]QUAFLG : WFLAG2=1
            Endif
         #Else
         #  If [F:PTD]QUAFLG<>[F:ITM]QUAFLG
         #    If WTRACE=2
         #      WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
         #      WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"-->"-num$([F:ITM]QUAFLG)
         #      Call ECR_TRACE(WMSG,0) From GESECRAN
         #    Endif
         #    [F:PTD]QUAFLG=[F:ITM]QUAFLG : WFLAG2=1
         #  Endif
          Endif
          If [F:PTD]QUAFLG<>2
            If [F:POP]QUAFLG=2
              If [F:PTD]QUAFLG<>3
                If WTRACE=2
                  WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                  WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"--> 3"
                  Call ECR_TRACE(WMSG,0) From GESECRAN
                Endif
                [F:PTD]QUAFLG=3 : WFLAG2=1
              Endif
            Else
              If [F:PTD]QUAFLG<>1
                If WTRACE=2
                  WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                  WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"--> 1"
                  Call ECR_TRACE(WMSG,0) From GESECRAN
                Endif
                [F:PTD]QUAFLG=1 : WFLAG2=1
              Endif
            Endif
          Endif
        Endif
        #-----
        If dim([F:PTD]LINTYP)<1 | [F:PTD]LINTYP<>2
          If [F:PTD]NETPRI=0 & [F:PTD]NETPRI<>[F:POP]NETPRI
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- NETPRI    :"-num$([F:PTD]NETPRI)-"-->"-num$([F:POP]NETPRI)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]NETPRI    =[F:POP]NETPRI : WFLAG2=1
            If [F:POQ]QTYUOM<>0
              WCOEFF=arr([F:POQ]QTYSTU/[F:POQ]QTYUOM,0.000001)
            Else
              [F:POQ]QTYUOM=[F:POQ]QTYSTU
              WCOEFF=1
            Endif
            If WCOEFF=0            WCOEFF=1           : Endif
            If [F:PTD]UOMSTUCOE=0
              If WTRACE=2
                WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)-"- UOMSTUCOE : 0 --> 1"
                Call ECR_TRACE(WMSG,0) From GESECRAN
              Endif
              [F:PTD]UOMSTUCOE=1 : WFLAG2=1
            Endif
            If WCOEFF=[F:PTD]UOMSTUCOE
              If [F:PTD]GROPRI<>arr([F:POP]GROPRI,10^-GDECPRI)
                If WTRACE=2
                  WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                  WMSG-="- GROPRI    :"-num$([F:PTD]GROPRI)-"-->"-num$(arr([F:POP]GROPRI,10^-GDECPRI))
                  Call ECR_TRACE(WMSG,0) From GESECRAN
                Endif
                [F:PTD]GROPRI=arr([F:POP]GROPRI,10^-GDECPRI) : WFLAG2=1
              Endif
            Else
              If [F:PTD]GROPRI<>arr([F:POP]GROPRI/WCOEFF*[F:PTD]UOMSTUCOE,10^-GDECPRI)
                If WTRACE=2
                  WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                  WMSG-="- GROPRI    :"-num$([F:PTD]GROPRI)-"-->"-num$(arr([F:POP]GROPRI/WCOEFF*[F:PTD]UOMSTUCOE,10^-GDECPRI))
                  Call ECR_TRACE(WMSG,0) From GESECRAN
                Endif
                [F:PTD]GROPRI=arr([F:POP]GROPRI/WCOEFF*[F:PTD]UOMSTUCOE,10^-GDECPRI) : WFLAG2=1
                If [F:PTD]NETPRI=0 & [F:PTD]NETPRI<>[F:PTD]GROPRI
                  If WTRACE=2
                    WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
                    WMSG-="- NETPRI    :"-num$([F:PTD]NETPRI)-"-->"-num$([F:PTD]GROPRI)
                    Call ECR_TRACE(WMSG,0) From GESECRAN
                  Endif
                  [F:PTD]NETPRI=[F:PTD]GROPRI : WFLAG2=1
                Endif
                If [F:BPS]BPSNUM<>[F:PTD]BPSNUM
                  Read [BPS] BPS0=[F:PTD]BPSNUM : If fstat  Raz [F:BPS] : Endif
                Endif
                Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
                For I=0 To 8
                  If GNPRNOTFLG(I)=2
                    Assign "[F:PTD]DISCRGVAL"+num$(I+1) With 0 : WFLAG2=1
                  Endif
                Next I
              Endif
            Endif
          Endif
        Endif
      Endif
      #----- Récupération des numéros livraison (inter-sites) -----#
      If [F:PTD]SDHNUM="" & [F:PTD]SDHNUM<>[F:POQ]SDHNUM
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- SDHNUM    :"-[F:PTD]SDHNUM-"-->"-[F:POQ]SDHNUM
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]SDHNUM=[F:POQ]SDHNUM : WFLAG2=1
      Endif
      If [F:PTD]SDDLIN=0 & [F:PTD]SDDLIN<>[F:POQ]SDDLIN
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- SDDLIN    :"-num$([F:PTD]SDDLIN)-"-->"-num$([F:POQ]SDDLIN)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]SDDLIN=[F:POQ]SDDLIN : WFLAG2=1
      Endif
      If [F:POQ]SDHNUM<>"" & [F:POQ]SDDLIN<>0 & [F:PTD]LINSTOFCY=""
        If [F:BPR]BPRNUM<>[F:PTD]BPSNUM
          Read [BPR] BPR0=[F:PTD]BPSNUM : If fstat  Raz [F:BPR] : Endif
        Endif
        If [F:PTD]LINSTOFCY<>[F:BPR]FCY
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- LINSTOFCY :"-[F:PTD]LINSTOFCY-"-->"-[F:BPR]FCY
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]LINSTOFCY=[F:BPR]FCY : WFLAG2=1
        Endif
      Endif
      If [F:PTD]CLCAMT1=0 & [F:PTD]CLCAMT1<>[F:POQ]CLCAMT1
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- CLCAMT1   :"-num$([F:PTD]CLCAMT1)-"-->"-num$([F:POQ]CLCAMT1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]CLCAMT1=[F:POQ]CLCAMT1 : WFLAG2=1
      Endif
      If [F:PTD]CLCAMT2=0 & [F:PTD]CLCAMT2<>[F:POQ]CLCAMT2
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- CLCAMT2   :"-num$([F:PTD]CLCAMT2)-"-->"-num$([F:POQ]CLCAMT2)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]CLCAMT2=[F:POQ]CLCAMT2 : WFLAG2=1
      Endif
      If dim([F:PTD]CLCAMT3)>0 & [F:PTD]CLCAMT3=0 & [F:PTD]CLCAMT3<>[F:POQ]CLCAMT3
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- CLCAMT3    :"-num$([F:PTD]CLCAMT3)-"-->"-num$([F:POQ]CLCAMT3)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]CLCAMT3  =[F:POQ]CLCAMT3 : WFLAG2=1
      Endif
      If [F:PTD]LINPURTYP=0 & [F:PTD]LINPURTYP<>[F:POQ]LINPURTYP
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- LINPURTYP :"-num$([F:PTD]LINPURTYP)-"-->"-num$([F:POQ]LINPURTYP)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]LINPURTYP=[F:POQ]LINPURTYP : WFLAG2=1
      Endif
    Endif
    If [F:PTD]QUAFLG=0
      If [F:ITP]ITMREF<>""
        If [F:PTD]QUAFLG<>[F:ITP]QUAFLG
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"-->"-num$([F:ITP]QUAFLG)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]QUAFLG=[F:ITP]QUAFLG : WFLAG2=1
        Endif
     #Else
     #  If [F:PTD]QUAFLG<>[F:ITM]QUAFLG
     #    If WTRACE=2
     #      WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
     #      WMSG-="- QUAFLG    :"-num$([F:PTD]QUAFLG)-"-->"-num$([F:ITM]QUAFLG)
     #      Call ECR_TRACE(WMSG,0) From GESECRAN
     #    Endif
     #    [F:PTD]QUAFLG=[F:ITM]QUAFLG : WFLAG2=1
     #  Endif
      Endif
    Endif
    #-----
    If [F:PTD]STOMGTCOD=0
      If [F:PTD]STOMGTCOD<>[F:ITM]STOMGTCOD
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- STOMGTCOD :"-num$([F:PTD]STOMGTCOD)-"-->"-num$([F:ITM]STOMGTCOD)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]STOMGTCOD=[F:ITM]STOMGTCOD : WFLAG2=1
      Endif
    Endif
    #-----
    If [F:PTD]NETPRIPUU<>0
      If [F:PTD]NETCUR=""
        If [F:POH]POHNUM<>""
          If [F:PTD]NETCUR<>[F:POH]CUR
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- NETCUR    :"-[F:PTD]NETCUR-"-->"-[F:POH]NETCUR
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]NETCUR=[F:POH]CUR : WFLAG2=1
          Endif
        Else
          If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
            Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
          Endif
          If [F:PTD]NETCUR<>[F:PTH]CUR
            If WTRACE=2
              WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
              WMSG-="- NETCUR    :"-[F:PTD]NETCUR-"-->"-[F:PTH]CUR
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PTD]NETCUR=[F:PTH]CUR : WFLAG2=1
          Endif
        Endif
      Endif
      If [F:PTD]NETPRI=0 & [F:PTD]NETPRI<>arr([F:PTD]NETPRIPUU*[F:PTD]UOMPUUCOE,10^-GDECPRI)
        If WTRACE=2
          WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
          WMSG-="- NETPRI    :"-num$([F:PTD]NETPRI)-"-->"-num$(arr([F:PTD]NETPRIPUU*[F:PTD]UOMPUUCOE,10^-GDECPRI))
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PTD]NETPRI=arr([F:PTD]NETPRIPUU*[F:PTD]UOMPUUCOE,10^-GDECPRI) : WFLAG2=1
      Endif
      If [F:PTD]LINAMT=0
        WMT=[F:PTD]NETPRI*[F:PTD]QTYUOM
        Call ARRDEV(WMT,[F:PTD]NETCUR) From TRTDIV
        If [F:PTD]LINAMT<>WMT
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- LINAMT    :"-num$([F:PTD]LINAMT)-"-->"-num$(WMT)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]LINAMT=WMT : WFLAG2=1
        Endif
      Endif
      If [F:PTD]LINATIAMT=0
        VAT(0)=[F:PTD]VAT(0) : VAT(1)=[F:PTD]VAT(1) : VAT(2)=[F:PTD]VAT(2)
        Raz WMT
        If GSOCIETE<>""
          Call CLCTAXEMNT([F:PTD]LINAMT,VAT,1,GSOCIETE,[F:PTD]RCPDAT,[F:PTD]CLCAMT1,
&                         [F:PTD]CLCAMT2,WMT) From TRTX3
          Call ARRDEV(WMT,[F:PTD]NETCUR) From TRTDIV
        Endif
        If [F:PTD]LINATIAMT<>WMT
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- LINATIAMT :"-num$([F:PTD]LINATIAMT)-"-->"-num$(WMT)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]LINATIAMT=WMT : WFLAG2=1
        Endif
      Endif
    Endif
    If [F:PTD]RRRQTYPUU<>0
      If [F:ITM]STOMGTCOD<2
        Call PCAL_QTY([F:PTD]RRRQTYPUU,[F:PTD]PUU,WMT,[F:ITM]STU,
&                     [F:ITM]ITMREF,[F:PTD]BPSNUM,1,GBIDD3) From TRTACHQTE1
        If [F:PTD]RRRQTYSTU<>WMT
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- RRRQTYSTU :"-num$([F:PTD]RRRQTYSTU)-"-->"-num$(WMT)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PTD]RRRQTYSTU=WMT : WFLAG2=1
        Endif
      Else
        If [F:PTD]RRRQTYPUU<>0
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- RRRQTYPUU :"-num$([F:PTD]RRRQTYPUU)-"--> 0"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          Raz [F:PTD]RRRQTYPUU : WFLAG2=1
        Endif
        If [F:PTD]RRRQTYSTU<>0
          If WTRACE=2
            WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
            WMSG-="- RRRQTYSTU :"-num$([F:PTD]RRRQTYSTU)-"--> 0"
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          Raz [F:PTD]RRRQTYSTU : WFLAG2=1
        Endif
      Endif
    Endif
    If [F:PTD]CPRCOE=0
      If WTRACE=2
        WMSG =[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)
        WMSG-="- CPRCOE    : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PTD]CPRCOE=1 : WFLAG2=1
    Endif
    #-----
    If WFLAG2
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PTD]
      If fstat & WTRACE
        Call ECR_TRACE("File PRECEITPD"-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN)+
&                      ", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PTD]PTHNUM : CLE2=[F:PTD]PTDLIN : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PTD : Endif
#-----
Close Local File [PTD], [PTH], [POH], [POQ], [POP], [ITM], [ITP], [BPS]
Close Local File [TVT], [TRA], [TCU]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#----------------------------------------------------------------#
# Initialisation des zone BETCPY et BETFCY dans la table PRETURN #
#----------------------------------------------------------------#
$TRT_PNH
Local File =[F:ADS]DOSSIER+".PRETURN"   [PNH]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24 : Purchase Return Process 1 : Update PRETURN") From DOSSUB
Endif
Raz CLE1, STOP, NBENR, NBCOR
#-----
$BOUCLE_PNH
If STOP=1
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE+=' & (BETFCY=0 | BETCPY=0)'
Raz COMPTEUR
Trbegin [PNH]
  For [PNH] PNH0 Where evalue(CRITERE)
    Raz WFLAG1
    NBENR+=1
    If [F:PNH]BETFCY=0
      If WTRACE=2
        WMSG=[F:PNH]PNHNUM-"- BETFCY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PNH]BETFCY=1 : WFLAG1=1
    Endif
    If [F:PNH]BETCPY=0
      If WTRACE=2
        WMSG=[F:PNH]PNHNUM-"- BETCPY : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PNH]BETCPY=1 : WFLAG1=1
    Endif
    #----- Réécriture de la ligne de retour fournisseur -----#
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PNH]
      If fstat & WTRACE
        Call ECR_TRACE("File PRETURN, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PNH]PNHNUM : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PNH : Endif
#-----
Close Local File [PNH]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------#
# Mise à jour lignes retours fournisseurs, table PRETURND       #
# ------------------------------------------------------------- #
# - Récupération du libellé motif retour                        #
#   RTNDES       : Libellé du motif     Récupéré de RTNREN      #
# - Alimentation des nouveaux champs                            #
#   UOMSTUCOE    : Coef UOM/US          Calculé                 #
#   GROPRI       : Prix unitaire        Repris de la réception  #
#   PRIREN       : Motif prix           Repris de la réception  #
#   DISCRGVAL1-9 : Frais/remises        Repris de la réception  #
#   DISCRGREN1-9 : Motif frais/remises  Repris de la réception  #
#   NETPRI       : Prix unitaire net    Repris de la réception  #
#   LINAMT       : Mt ligne HT          Calculé                 #
#   LINATIAMT    : Mt ligne TTC         Calculé                 #
#   CLCAMT1      : Base 1 calcul taxe   Aucune action           #
#   CLCAMT2      : Base 2 calcul taxe   Aucune action           #
#   LINPURTYP    : Type d'achat         Repris de la réception  #
#   STOMGTCOD    : Gestion stock        Repris de l'article     #
#---------------------------------------------------------------#
$TRT_PND
Local File =[F:ADS]DOSSIER+".PRETURN"    [PNH]
Local File =[F:ADS]DOSSIER+".PRETURND"   [PND]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"  [PTD]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
#----- Pour Call CLCTAXEMNT et ARRDEV -----#
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24 : Purchase Return Process 2 : Update PRETURND") From DOSSUB
Endif
Raz CLE1, CLE2, STOP, NBENR, NBCOR
#-----
$BOUCLE_PND
If STOP=1
  CRITERE='PNHNUM="'+CLE1+'" & PNDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='PNHNUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PND]
  For [PND] PND0 Where evalue(CRITERE) & ((RTNREN<>"" & RTNDES="") | UOMSTUCOE=0)
    Raz WFLAG2
    NBENR+=1
    #----- Récupération libellé du motif de retour -----#
    If [F:PND]RTNREN<>"" & [F:PND]RTNDES=""
      If WTRACE=2
        WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- RTNDES : -->"-[F:PND]RTNREN
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PND]RTNDES=[F:PND]RTNREN : WFLAG2=1
    Endif
   #Raz [F:PND]RTNREN
    #----- Calcul du coefficient UOM/STU -----#
    If [F:PND]UOMSTUCOE=0
      If [F:PND]QTYUOM<>0
        If WTRACE=2
          WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- UOMSTUCOE : 0 -->"-num$(arr([F:PND]QTYSTU/[F:PND]QTYUOM,0.000001))
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PND]UOMSTUCOE=arr([F:PND]QTYSTU/[F:PND]QTYUOM,0.000001) : WFLAG2=1
      Else
        If WTRACE=2
          WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- UOMSTUCOE : 0 --> 1"
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
        [F:PND]UOMSTUCOE=1 : WFLAG2=1
      Endif
    Endif
    #----- Si retour sur réception, récupération valeurs de la réception -----#
    If [F:PND]PTHNUM<>""
      If [F:PTD]PTHNUM<>[F:PND]PTHNUM | [F:PTD]PTDLIN<>[F:PND]PTDLIN
        Read [PTD] PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN : If fstat  Raz [F:PTD] : Endif
      Endif
      If [F:PND]GROPRI=0 & [F:PND]NETPRI=0 & [F:PND]LINAMT=0
        If [F:PTD]GROPRI<>[F:PTD]GROPRI
          If WTRACE=2
            WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- GROPRI    : 0 -->"-num$([F:PTD]GROPRI)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PND]GROPRI=[F:PTD]GROPRI : WFLAG2=1
        Endif
        [F:PND]PRIREN    =[F:PTD]PRIREN
        [F:PND]DISCRGVAL1=[F:PTD]DISCRGVAL1
        [F:PND]DISCRGVAL2=[F:PTD]DISCRGVAL2
        [F:PND]DISCRGVAL3=[F:PTD]DISCRGVAL3
        [F:PND]DISCRGVAL4=[F:PTD]DISCRGVAL4
        [F:PND]DISCRGVAL5=[F:PTD]DISCRGVAL5
        [F:PND]DISCRGVAL6=[F:PTD]DISCRGVAL6
        [F:PND]DISCRGVAL7=[F:PTD]DISCRGVAL7
        [F:PND]DISCRGVAL8=[F:PTD]DISCRGVAL8
        [F:PND]DISCRGVAL9=[F:PTD]DISCRGVAL9
        [F:PND]DISCRGREN1=[F:PTD]DISCRGREN1
        [F:PND]DISCRGREN2=[F:PTD]DISCRGREN2
        [F:PND]DISCRGREN3=[F:PTD]DISCRGREN3
        [F:PND]DISCRGREN4=[F:PTD]DISCRGREN4
        [F:PND]DISCRGREN5=[F:PTD]DISCRGREN5
        [F:PND]DISCRGREN6=[F:PTD]DISCRGREN6
        [F:PND]DISCRGREN7=[F:PTD]DISCRGREN7
        [F:PND]DISCRGREN8=[F:PTD]DISCRGREN8
        [F:PND]DISCRGREN9=[F:PTD]DISCRGREN9
        If [F:PTD]NETPRI<>[F:PTD]NETPRI
          If WTRACE=2
            WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- NETPRI    : 0 -->"-num$([F:PTD]NETPRI)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PND]NETPRI=[F:PTD]NETPRI : WFLAG2=1
        Endif
        [F:PND]LINPURTYP =[F:PTD]LINPURTYP
        #----- Conversion tarif si coefficients unités différents -----#
        If [F:PND]UOMSTUCOE<>[F:PTD]UOMSTUCOE
          If [F:PND]NETPRI<>arr([F:PND]NETPRI*[F:PTD]UOMPUUCOE/[F:PND]UOMPUUCOE,10^-GDECPRI)
            If WTRACE=2
              WMSG =[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- NETPRI    :"
              WMSG-=num$([F:PND]NETPRI)-"-->"-num$(arr([F:PND]NETPRI*[F:PTD]UOMPUUCOE/[F:PND]UOMPUUCOE,10^-GDECPRI))
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PND]NETPRI=arr([F:PND]NETPRI*[F:PTD]UOMPUUCOE/[F:PND]UOMPUUCOE,10^-GDECPRI) : WFLAG2=1
          Endif
          If [F:PND]GROPRI<>[F:PND]NETPRI
            If WTRACE=2
              WMSG =[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- GROPRI    :"
              WMSG-=num$([F:PND]GROPRI)-"-->"-num$([F:PND]NETPRI)
              Call ECR_TRACE(WMSG,0) From GESECRAN
            Endif
            [F:PND]GROPRI=[F:PND]NETPRI : WFLAG2=1
          Endif
          If [F:BPS]BPSNUM<>[F:PND]BPSNUM
            Read [BPS] BPS0=[F:PND]BPSNUM : If fstat  Raz [F:BPS] : Endif
          Endif
          Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
          For I=0 To 8
            If GNPRNOTFLG(I)=2
              Assign "[F:PND]DISCRGVAL"+num$(I+1) With 0
            Endif
          Next I
        Endif
        #----- Calcul montant ligne HT et TTC -----#
        [F:PND]LINAMT=[F:PND]NETPRI*[F:PND]QTYUOM
        Call ARRDEV([F:PND]LINAMT,[F:PND]NETCUR)   From TRTDIV
        Call GETSOC([F:PND]PNHFCY) From DEVSUB
        Call CLCTAXEMNT([F:PND]LINAMT,[F:PND]VAT,1,GSOCIETE,[F:PND]RTNDAT,[F:PND]CLCAMT1,
&                       [F:PND]CLCAMT2,[F:PND]LINATIAMT) From TRTX3
        Call ARRDEV([F:PND]LINATIAMT,[F:PND]NETCUR) From TRTDIV
      Endif
    Endif
    If [F:PTD]LINPURTYP=0
      If WTRACE=2
        WMSG=[F:PND]PNHNUM-num$([F:PND]PNDLIN)-"- LINPURTYP : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PTD]LINPURTYP=1 : WFLAG2=1
    Endif
    #----- Récupération code gestion stock -----#
   #If [F:ITM]ITMREF<>[F:PND]ITMREF
   #  Read [ITM] ITM0=[F:PND]ITMREF : If fstat  Raz [F:ITM] : Endif
   #Endif
   #[F:PND]STOMGTCOD=[F:ITM]STOMGTCOD
    #----- Réécriture de la ligne de retour fournisseur -----#
    If WFLAG2
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PND]
      If fstat & WTRACE
        Call ECR_TRACE("File PRETURND, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PND]PNHNUM : CLE2=[F:PND]PNDLIN : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PND : Endif
#-----
Close Local File [PNH], [PND], [PTD], [BPS], [POP], [ITM]
Close Local File [TVT], [TRA], [TCU]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#----------------------------------------------------------#
# Initialisation de la zone BETCPY dans la table PINVOICEV #
#----------------------------------------------------------#
$TRT_PIV
Local File =[F:ADS]DOSSIER+".PINVOICEV"   [PIV]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24 : Purchase Invoice Process 1 : Update PINVOICEV") From DOSSUB
Endif
Raz CLE1, STOP, NBENR, NBCOR
#-----
$BOUCLE_PIV
If STOP=1
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
CRITERE+=' & (BETCPY=0)'
Raz COMPTEUR
Trbegin [PIV]
  For [PIV] PIV0 Where evalue(CRITERE)
    Raz WFLAG1
    NBENR=1
    If [F:PIV]BETCPY=0
      If WTRACE=2
        WMSG=[F:PIV]NUM-"- BETCPY    : 0 --> 1"
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PIV]BETCPY=1 : WFLAG1=1
    Endif
    #----- Réécriture de la ligne de retour fournisseur -----#
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PIV]
      If fstat
        Call ECR_TRACE("File PINVOICEV, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PIV]NUM : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PIV : Endif
#-----
Close Local File [PIV]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#-------------------------------------------------------------------------------------#
# Chargement des champs POHNUM, POPLIN et POQSEQ si origine ligne réception ou retour #
#-------------------------------------------------------------------------------------#
$TRT_PID
Local File =[F:ADS]DOSSIER+".PINVOICED"   [PID]
Local File =[F:ADS]DOSSIER+".PRECEIPTD"   [PTD]
Local File =[F:ADS]DOSSIER+".PRETURND"    [PND]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTIACH24 : Purchase Invoice Process 2 : Update PINVOICED") From DOSSUB
Endif
Raz CLE1, CLE2, STOP, NBENR, NBCOR
#-----
$BOUCLE_PID
If STOP=1
  CRITERE='NUM="'+CLE1+'" & PIDLIN>'+num$(CLE2)
  STOP=2
Elsif STOP=2
  CRITERE='NUM>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif 
Raz COMPTEUR
Trbegin [PID]
  For [PID] PID0 Where evalue(CRITERE) & TYPORI>1 & TYPORI<4
    Raz WFLAG2
    NBENR+=1
    Case [F:PID]TYPORI
      When 2
        Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
        If fstat  Raz [F:PTD] : Endif
        If [F:PID]POHNUM="" & [F:PID]POHNUM<>[F:PTD]POHNUM
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POHNUM    : -->"-[F:PTD]POHNUM
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]POHNUM=[F:PTD]POHNUM : WFLAG2=1
        Endif
        If [F:PID]POPLIN=0 & [F:PID]POPLIN<>[F:PTD]POPLIN
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POPLIN    : 0 -->"-num$([F:PTD]POPLIN)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
        : [F:PID]POPLIN=[F:PTD]POPLIN : WFLAG2=1
        Endif
        If [F:PID]POQSEQ=0 & [F:PID]POQSEQ<>[F:PTD]POQSEQ
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POQSEQ    : 0 -->"-num$([F:PTD]POQSEQ)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]POQSEQ=[F:PTD]POQSEQ : WFLAG2=1
        Endif
      When 3
        Read [PND] PND0=[F:PID]PNHNUM;[F:PID]PNDLIN
        If fstat  Raz [F:PND] : Endif
        If [F:PID]PTHNUM="" & [F:PID]PTHNUM<>[F:PND]PTHNUM
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- PTHNUM    : -->"-[F:PND]PTHNUM
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]PTHNUM=[F:PND]PTHNUM : WFLAG2=1
        Endif
        If [F:PID]PTDLIN=0 & [F:PID]PTDLIN<>[F:PND]PTDLIN
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- PTDLIN    : -->"-num$([F:PND]PTDLIN)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]PTDLIN=[F:PND]PTDLIN : WFLAG2=1
        Endif
        If [F:PID]POHNUM="" & [F:PID]POHNUM<>[F:PND]POHNUM
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POHNUM    : -->"-[F:PND]POHNUM
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]POHNUM=[F:PND]POHNUM : WFLAG2=1
        Endif
        If [F:PID]POPLIN=0 & [F:PID]POPLIN<>[F:PND]POPLIN
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POPLIN    : 0 -->"-num$([F:PND]POPLIN)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]POPLIN=[F:PND]POPLIN : WFLAG2=1
        Endif
        If [F:PID]POQSEQ=0 & [F:PID]POQSEQ<>[F:PND]POQSEQ
          If WTRACE=2
            WMSG=[F:PID]NUM-num$([F:PID]PIDLIN)-"- POQSEQ    : 0 -->"-num$([F:PND]POQSEQ)
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          [F:PID]POQSEQ=[F:PND]POQSEQ : WFLAG2=1
        Endif
    Endcase
    #----- Réécriture de la ligne de facture d'achat -----#
    If WFLAG2
      COMPTEUR+=1 : NBCOR+=1
      Rewrite [PID]
      If fstat & WTRACE
        Call ECR_TRACE("File PINVOICED, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:PID]NUM : CLE2=[F:PID]PIDLIN : STOP=1 : Break : Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PID : Endif
#-----
Close Local File [PID], [PTD], [PND]
#-----
If WTRACE
  WMSG ="UTIACH24 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH24 - Réajustement tables achats en v6",0) From GESECRAN
  Call EXE_UTIACH24(DOSSIER,1,0)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call ECR_TRACE("UTIACH24 - Réajustement tables achats en v6",0) From GESECRAN
  Call EXE_UTIACH24(DOSSIER,1,0)
Endif
#-----
End
