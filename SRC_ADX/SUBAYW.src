#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion objet AYW
Call OBJET("AYW",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
## Xtend:  Gestion Bloc conditionné
#
#   Table AYTLINES  (AYN)
#        LINCODTYP = 5     Bloc conditionné
#        LINTYP
#                  = 50    Critères
#
#
#  Utilitaires
#       
#  Version 0001
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "AVANT_OUVRE"    : Gosub AVANT_OUVRE
 When "ANNULE"         : Gosub ANNULE
 When "CREATION"       : Gosub CREATION
 When "FERME"          : Gosub FERME
 When "FILTRE"         : Gosub FILTRE
 #When "FILGAUCHE"     : Gosub FILGAUCHE
 When "INICRE"         : Gosub INICRE
 When "INIMOD"         : Gosub INIMOD
 When "LIENS"          : Gosub LIENS
 When "MODIF"          : Gosub MODIF
 When "OUVRE"          : Gosub OUVRE
 #When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "RAZCRE"         : Gosub RAZCRE
 When "SETBOUT"        : Gosub SETBOUT
 When default
Endcase
Return

$AVANT_OUVRE
#---------------------------------------------------------------#
Call AYT_DEBUG From AYTUTIA   # Activation debug java
Gosub INICTLFCY From SUBAYS
Return

$OUVRE
#---------------------------------------------------------------#
Local Char WSTR1 (250), KEYLNK(30)
Local Integer WI, AYNPOS21
Gosub DSYFCY From SUBAYS     # Infos site
Return

$OUVRE_BOITE
#----- Chargement des noms des Currbox de chaque tiroir -----#
Global Char GBOXAY0(10)
GBOXAY0="GAU_CHE"+num$(find("AY0",OBJLIS(1..8))) 
Return

#---------------------------------------------------------------#
$FERME
Gosub DSYCLRFCY From SUBAYS # Clear affichage site
Return

$FILGAUCHE
#---------------------------------------------------------------#
If currbox=GBOXAY0
  FILGAUSUP(0)=func SUBAYS.FILTFCY
  FILGAUSUP(1)=""
  Return
Endif
Return

$SETBOUT
#---------------------------------------------------------------#
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V2") From GOBJET : # Validation, copie
Endif
Return

#---------------------------------------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="AYTELTBLCW" & ZONE = "INTIT"   & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK 
Endif
$ANNULE2
Delete [AYN]AYN0=[M]FCYCOD;5;toupper([M]BLCWHNCOD)
If fstat=1 : GOK=-1 : GLOCK="$AYTLINES ("-[M]FCYCOD-"5"-[M]BLCWHNCOD+")" : Return : Endif
Return

#---------------------------------------------------------------#
$CREATION
$MODIF
# Sup. avant recréation Sélection 
Gosub ANNULE2 : If GOK<>1 : Return : Endif
# Formule
Call AYW50_AYL()

#  textes AXX
Call MAJTEXTRA([M]INTIT,"AYTELTBLCW","INTIT",[M]FCYCOD,[M]BLCWHNCOD) From  ATEXTRA
Return

#---------------------------------------------------------------#
$INICRE
$INIMOD
# Clé browser X3
[F]BRWX3=[F]FCYCOD+"_"+[F]BLCWHNCOD 
Return

#---------------------------------------------------------------#
$LIENS
Gosub DSYFCY From SUBAYS     # Infos site
#
WI=[F:AYW]WHNTYP : Call AM_WHNTYP(WI)
If WI=1    # Chgt Formule

 # Chgt tableau AYW50 par AytLines - 
 #   Rq: Dans le tableau: Donnée à gauche (VBLCCOD50) -> table indice 2 (VA2BLCCOD)
 #                        et à droite indice A (VBLCCOD50A) -> table (VALBLCOD)
 ######################################################################################
 Local Char WFMT 
 [M]NUM50=dim([M]VBLCCOD50)    # Pour eviter pb sur grizo (AM_VALTYP50_)

 Raz [F:AYN] :  WI=0
 For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 5
&                     and LINCOD = toupper([M]BLCWHNCOD) and  LINTYP = 50
      [M]VBLCCOD50(WI)   = [F:AYN]VA2BLCCOD : Call SETZENTCOD50([F:AYN]VA2BLCCOD, "[M]ZENTCOD50",WI)
      [M]VFIELNKE50(WI)  = [F:AYN]VA2FIELNKE
      [M]VFIECOD50(WI)   = [F:AYN]VA2FIECOD

      Call FIEKEY_COD([F:AYN]VA2FIELNKE, [F:AYN]VA2FIECOD, [M]VFIEKEY50(WI)) From SUBAYF
      Call AYF_INFOS([M]FCYCOD, [M]VFIECOD50(WI),
&                [M]VFIXTTYP50(WI),[M]VFIX3TYP50(WI),[M]VFILON50(WI),
&                [M]VFINOLIB50(WI), WFMT) From SUBAYF
      If WI : [M]ANDOR50(WI)     = [F:AYN]ANDOR : Endif
      [M]BRKLFTM50(WI)   = [F:AYN]BRKLFT + 1
      [M]BRKRGTM50(WI)   = [F:AYN]BRKRGT + 1
      [M]OPE50(WI)       = [F:AYN]OPE
      [M]VALTYP50(WI)    = [F:AYN]VALTYP
      [M]VALEUR50(WI)    = [F:AYN]VALEUR
      If [M]VFIX3TYP50(WI)<>"A"
           Call CONTROLE([M]VALEUR50(WI),[M]VFIX3TYP50(WI),[M]VFINOLIB50(WI),
&                        [M]VFILON50(WI),[M]VALINT50(WI)) From FMTVAR
           mkstat=0
      Endif

      [M]VBLCCOD50A(WI)  = [F:AYN]VALBLCCOD : Call SETZENTCOD50([F:AYN]VALBLCCOD, "[M]ZENTCOD50A",WI)
      [M]VFIELNKE5A(WI)  = [F:AYN]VALFIELNKE
      [M]VFIECOD50A(WI)  = [F:AYN]VALFIECOD
      Call FIEKEY_COD([F:AYN]VALFIELNKE, [F:AYN]VALFIECOD, [M]VFIEKEY50A(WI)) From SUBAYF
      #
      Call SETLIN([M]VALTYP50(WI) , WI)
      WI+=1
 Next
 [M]NUM50=WI

 # Synthèse
 Call RES50()
Endif
Return

#---------------------------------------------------------------#
$FILTRE
FILTSUP+=func SUBAYS.FILTFCY
Return

#---------------------------------------------------------------#
$RAZCRE
Gosub DSYFCY From SUBAYS     # Infos site
#[M]CODACT=WFCY_CODACT        # Code activité site
[M]WHNTYP = 1 # Défaut: formule
Call AM_WHNTYP([M]WHNTYP)
Return

######################################################################################
## Utilitaires
######################################################################################

### Synthèse sélection
Subprog RES50
Local Integer WLG
Local Clbfile WRES50
For WLG = 0 To [M]NUM50-1
    If WLG<>0 : WRES50-=mess([M]ANDOR50(WLG),56,1) : Endif
    WRES50-=mess([M]BRKLFTM50(WLG),7930,1)-[M]VBLCCOD50(WLG)+"."+[M]VFIEKEY50(WLG)
&          -mess([M]OPE50(WLG),7926,1)
    Case [M]VALTYP50(WLG)
    When 1 # cst
         Case [M]VFIX3TYP50(WLG)
         When "M","D"
            WRES50-='"'+[M]VALINT50(WLG)+'" ('+[M]VALEUR50(WLG)+')'
         When "L","DCB"
            WRES50-='"'+[M]VALINT50(WLG)+'"'
         When Default
            WRES50-='"'+[M]VALEUR50(WLG)+'"'
         Endcase
    When 2 # Chp Xtend
            WRES50-=[M]VBLCCOD50A(WLG)+"."+[M]VFIEKEY50A(WLG)
    When 3 # Chp Web
            WRES50-=[M]VALEUR50(WLG)
    When 4 # Javascript
            WRES50-="JScript"
    Endcase
    WRES50-=mess([M]BRKRGTM50(WLG),7932,1)
Next
[M]RES50=WRES50 : Affzo [M]RES50
End

### Gestion des chps d'une ligne de critère en fonction du type de valeur
Subprog SETLIN(VALTYP, NOL)    
Value Integer VALTYP
Value Integer NOL
Case VALTYP
When 1     # cste
    Effzo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL) : Grizo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL)
    Actzo [M]VALEUR50(NOL)
When 2    # chp xtend
    #Infbox "num "-num$(NOL)-"nb"-num$([M]NUM50)
    Actzo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL)
    Effzo [M]VALEUR50(NOL) : Grizo [M]VALEUR50(NOL)
When 3    # chp web
    Effzo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL) : Grizo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL)
    Actzo [M]VALEUR50(NOL)
When 4    # javascript
    Effzo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL),VALEUR50(NOL)
    Grizo [M]VBLCCOD50A(NOL),VFIEKEY50A(NOL),VALEUR50(NOL)
Endcase 
End


### Gestion du code entité en fonction du bloc sur la ligne
Subprog SETZENTCOD50(BLCCOD, FLDCOD, NOL)
Value Char    BLCCOD
Value Char    FLDCOD
Value Integer NOL
Local Char WBLCCOD(GLONAYB)
If BLCCOD<>""    
    If !clalev([F:AYB1]) : Local File AYTELTBLC [AYB1] : Endif
    Read [AYB1]AYB0 = [M]FCYCOD;[L]BLCCOD
    If !fstat                
        WBLCCOD=[F:AYB1]ENTCOD
    Endif
Endif
Assign (FLDCOD+"("+num$(NOL)+")") With WBLCCOD
Local Char WSTR
Affzo =FLDCOD+"("+num$(NOL)+")"
End


######################################################################################
# Chgt AytLines par le tableau AYW50
#   Rq: Dans le tableau: Donnée à gauche (VBLCCOD50) -> table indice 2 (VA2BLCCOD)
#                        et à droite indice A (VBLCCOD50A) -> table (VALBLCOD)
#   La sup. des AYN doit avoir été faites au préalable
Subprog AYW50_AYL()
# 
# Formule
For WI=0 To [M]NUM50-1
 Raz [F:AYN]
 [F:AYN]FCYCOD    = [M]FCYCOD
 [F:AYN]LINCODTYP = 5
 [F:AYN]LINCODSTD = [M]BLCWHNCOD
 [F:AYN]LINCOD    = toupper([M]BLCWHNCOD)
 [F:AYN]LINTYP    = 50
 [F:AYN]LINNUM    = WI

 [F:AYN]VA2BLCCOD   = [M]VBLCCOD50(WI)
 [F:AYN]VA2FIELNKE  = [M]VFIELNKE50(WI)
 [F:AYN]VA2FIECOD   = [M]VFIECOD50(WI)

 If WI : [F:AYN]ANDOR       = [M]ANDOR50(WI) : Else : [F:AYN]ANDOR=1 : Endif
 [F:AYN]BRKLFT      = [M]BRKLFTM50(WI)-1
 [F:AYN]BRKRGT      = [M]BRKRGTM50(WI)-1
 [F:AYN]OPE         = [M]OPE50(WI)  
 [F:AYN]VALTYP      = [M]VALTYP50(WI)
 Case [F:AYN]VALTYP
 When 1      # cste
    If [M]VFIX3TYP50(WI)="A"
        [F:AYN]VALEUR = [M]VALEUR50(WI)
    Else
        [F:AYN]VALEUR = [M]VALINT50(WI)
    Endif
 When 3      # chps web
    [F:AYN]VALEUR = [M]VALEUR50(WI)
 When 2    # chp xtend
    [F:AYN]VALBLCCOD   = [M]VBLCCOD50A(WI)
    [F:AYN]VALFIELNKE  = [M]VFIELNKE5A(WI)
    [F:AYN]VALFIECOD   = [M]VFIECOD50A(WI)
 Endcase

 Write [AYN]
 If fstat
  GOK=0 : Call FSTA("AYN") From GLOCK : Break
 Endif
Next
If GOK<>1 : Goto AYW1_AYL_E : Endif

$AYW1_AYL_E
End


######################################################################################
## écran AYW1
######################################################################################
Subprog AM_WHNTYP(VALEUR)
Variable Integer VALEUR
Case VALEUR
When 1 # formule
    Actzo [AYW2]30 : Effzo [AYW1]15 : Grizo [AYW1]15
    Effzo [AYW1]20 : Grizo [AYW1]20
    zonsui = "[M:AYW2]NUM50"
When 2 # bloc vide
    Actzo [AYW1]BLCCOD 
    Effzo [AYW1]BLCPAG,DLKCOD,PAGCOD
    Grizo [AYW1]BLCPAG,DLKCOD,PAGCOD
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 3 # pagination bloc
    Actzo [AYW1]BLCCOD, BLCPAG 
    Effzo [AYW1]DLKCOD,PAGCOD
    Grizo [AYW1]DLKCOD,PAGCOD
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 4 # dernier lien
    Actzo [AYW1]DLKCOD
    Effzo [AYW1]BLCPAG,BLCCOD,PAGCOD
    Grizo [AYW1]BLCPAG,BLCCOD,PAGCOD
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 5 # page précédente
    Actzo [AYW1]PAGCOD
    Effzo [AYW1]BLCPAG,BLCCOD,DLKCOD
    Grizo [AYW1]BLCPAG,BLCCOD,DLKCOD
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 6 # Utilisateur signé
    Effzo [AYW1]15 : Grizo [AYW1]15
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 7 # Profil
    Effzo [AYW1]15 : Grizo [AYW1]15
    Actzo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 8 # Etiquette vide
    Effzo [AYW1]15 : Grizo [AYW1]15
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 9 # Ligne sélectionnée
    Actzo [AYW1]BLCCOD 
    Effzo [AYW1]DLKCOD,PAGCOD,BLCPAG
    Grizo [AYW1]DLKCOD,PAGCOD,BLCPAG
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
When 10 # Page courante
    Effzo [AYW1]15 : Grizo [AYW1]15
    Effzo [AYW1]20 : Grizo [AYW1]20
    Effzo [AYW2]30 : Grizo [AYW2]30
Endcase
End

## 50: suffixe formule (sans suffixe A: partie gauche du tableau sinon droite) ##
Subprog C_NUM50
# Synthèse
#Call RES50()
# Verif nb ( et     )
If adxgtb=2
    # Vérif ()
    Local Integer WL, WR
    WL=sum([M]BRKLFTM50) : WR=sum([M]BRKRGTM50) 
    If WL<> WR
        mkstat=2 : GMESSAGE = mess(74,7900,1)    #-" '('="+num$(WL)-" ')'="+num$(WR) 
        GERR=1
        End
    Endif
Endif
End

Subprog D_ANDOR50(VALEUR)
Variable Integer VALEUR
If nolign=1 : VALEUR=0 : Else : VALEUR=1 : Endif
End

Subprog AS_ANDOR50(VALEUR)
Variable Integer VALEUR
If nolign=1 : mkstat=1 : Endif
End

Subprog AM_VBLCCOD50(VALEUR)
Variable Char    VALEUR()
Call SETZENTCOD50(VALEUR, "[M]ZENTCOD50",nolign-1)
End

Subprog AS_OPE50(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1    # Indifférent
#
Case [M]VFIXTTYP50(nolign-1)
When 2,3,4,5,8
  GMENLOC(8)=1 : GMENLOC(9)=1 : GMENLOC(10)=1
Endcase
End

Subprog AS_VALTYP50(VALEUR)
Variable Integer VALEUR
Local Integer LST(len(mess(0,GCOMBO,1))),WI
LST(WI)=1 : WI+=1    # Cst
LST(WI)=2 : WI+=1    # Chp XTend
LST(WI)=3 : WI+=1    # Chp Web
Call MNLCHX(GCOMBO,LST) From AYTUTIA
End

Subprog AM_VALTYP50(VALEUR)
Variable Integer VALEUR
Local Integer NOL
NOL=nolign-1
Call SETLIN(VALEUR, NOL)
End

Subprog AM_VBLCCOD50A(VALEUR)
Variable Char    VALEUR()
Call SETZENTCOD50(VALEUR, "[M]ZENTCOD50A",nolign-1)
End

Subprog AM_VFIEKEY50(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M]VFIELNKE50(nolign-1),[M]VFIECOD50(nolign-1)) From SUBAYF
Local Char WFMT
Call AYF_INFOS([M]FCYCOD, [M]VFIECOD50(nolign-1),
&                [M]VFIXTTYP50(nolign-1),[M]VFIX3TYP50(nolign-1),[M]VFILON50(nolign-1),
&                [M]VFINOLIB50(nolign-1), WFMT) From SUBAYF
End

Subprog AM_VFIEKEY50A(VALEUR)
Variable Char    VALEUR()
Call FIEKEY_ANA(VALEUR, [M]VFIELNKE5A(nolign-1),[M]VFIECOD50A(nolign-1)) From SUBAYF
End

Subprog C_VALEUR50(VALEUR)
Variable Char    VALEUR()
If [M]VALTYP50(nolign-1)<>1     # <> Cst
    If vireblc(VALEUR,2)=""
        mkstat = 1 : GMESSAGE = mess(10,123,1)
    Endif
Endif
End



