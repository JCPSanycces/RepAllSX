#<AdxTL>@(#)3.0.0.0 $Revision$
Subprog UNICITE(VALEUR,TABLO)
Local Integer I, NOL
NOL = nolign-1
I = find(VALEUR,TABLO(0..NOL-1),TABLO(NOL+1..dim(TABLO)-1))
If I
 If I>NOL
  I += 1
 Endif
 GERR=1
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat=2 : End
Endif
End

Subprog UNICITE2(VALEUR,LIGTABLO,TABLO)
Local Integer I, NOL
NOL = nolign-1
I = find(VALEUR,TABLO(0..NOL-1),TABLO(NOL+1..LIGTABLO-1))
If I
 If I>NOL
  I += 1
 Endif
 GERR=1
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
 mkstat=2 : End
Endif
End

## Accès en modif
Subprog ACCES(CODE)
Value Char CODE
If CODE="" | GUSRACS=2 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
If [F:ACC]CODACC<>CODE
 Read [ACC]CODACC = GUSER;CODE
 If fstat : mkstat = 2 : End : Endif
Endif
If inpmode=2
 If [F:ACC]MODIF<>2
  mkstat = 2
 Endif
Endif
End

## Accès en consult
Subprog ACCES2(CODE)
Value Char CODE
If CODE="" | GUSRACS=2 : End : Endif
If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
If [F:ACC]CODACC<>CODE
 Read [ACC]CODACC = GUSER;CODE
 If fstat : mkstat = 2 : End : Endif
Endif
If [F:ACC]CONSUL<>2
 mkstat = 2 : # En avant_champ, mkstat=2 permet de ne pas afficher le champ
Endif
End

########################################################
## Gestion des textes                                 ##
########################################################
Subprog TEXTE(NUM,VALEUR)
Value    Integer NUM
Variable Char    VALEUR
Onerrgo ERMAC
Local Integer K
K = find(GLANGUE+num$([L]NUM),GTXNUM(1..GTXNB))
If K
 [L]VALEUR = GTXMES(K)
 #GTXOK += 1
Else
 Gosub TEXTEB
 If GTXNB<dim(GTXNUM)
  GTXNB += 1
  K = GTXNB
 Else
  GTXPT = mod(GTXPT,dim(GTXNUM))+1
  K = GTXPT
 Endif
 GTXNUM(K) = GLANGUE+num$([L]NUM)
 GTXMES(K) = WTEXTE
 [L]VALEUR=WTEXTE
 #GTXNOK += 1
Endif
End

$TEXTEB
Local Char WTEXTE(80) : #106040 use local variable
If clalev([LDB])>0 : # On est dans le debugger
 If clalev([F:ATXZ])=0 : Local File ATEXTE [ATXZ] : Endif
 Read [ATXZ]NUMERO = GLANGUE;[L]NUM
 If fstat=0
  WTEXTE = [F:ATXZ]TEXTE
 Else
  Read [ATXZ]NUMERO = GLANDEF;[L]NUM
  If fstat=0
   WTEXTE = [F:ATXZ]TEXTE
  Else
   WTEXTE = ""
  Endif
 Endif
Else
 If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
 Read [ATX]NUMERO = GLANGUE;[L]NUM
 If fstat=0
  WTEXTE = [F:ATX]TEXTE
 Else
  Read [ATX]NUMERO = GLANDEF;[L]NUM
  If fstat=0
   WTEXTE = [F:ATX]TEXTE
  Else
   WTEXTE = ""
  Endif
 Endif
Endif
Return

$ERMAC
#If adxmac(-2)="sow7mbeinat.sagefr.adinternal.com" : Dbgaff : Endif
Resume

Subprog TEXTELAN(NUM,VALEUR,LAN)
Value    Integer NUM
Value Char LAN
Variable Char    VALEUR()
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Read [ATX]NUMERO = LAN;NUM
If fstat=0
 VALEUR = [F:ATX]TEXTE
Else
 Read [ATX]NUMERO = GLANDEF;NUM
 If fstat=0
  VALEUR = [F:ATX]TEXTE
 Else
  VALEUR = ""
 Endif
Endif
End

Subprog TEXTE2(NUM,VALEUR)
Value    Integer NUM
Variable Char    VALEUR()
Call TEXTE(NUM,VALEUR)
End

Subprog NUMTEXLAN(TEXTE,LANGUE,NUM)
Value    Char    TEXTE
Value    Char    LANGUE
Variable Integer NUM
NUM = 0
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
Read [ATX]TEXTE = GLANGUE;TEXTE
If !fstat
 NUM = [F:ATX]NUMERO
Endif
End

$SET_TBLAN
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN
Raz NBLAN , TBLAN
For [ATX]NUMERO(1) Where LAN<>"" & LAN<>"XXX" & LAN<>GLANGUE & NUMERO<100
 NBLAN += 1
 TBLAN(NBLAN) = [F:ATX]LAN
Next ATX
Return

Subprog NUMEROFRA(VALEUR,NUM)
Value    Char    VALEUR
Variable Integer NUM
Local Char LANG(10)
LANG=GLANGUE
GLANGUE="FRA"
Call NUMERO(VALEUR,NUM)
GLANGUE=LANG
End

Subprog NUMERO(VALEUR,NUM)
Value    Char    VALEUR
Variable Integer NUM
Local Integer PREM , DERN , NOLAN
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
If VALEUR="" : NUM = 0 : End : Endif
Read [ATX]TEXTE = GLANGUE;VALEUR
If fstat=0
 NUM = [F:ATX]NUMERO
Else
 If !adxlog
  Call DEBTRANS From GLOCK
  Gosub TR_NUM
 Else
  Gosub MAJ_NUM
 Endif
 If GOK<1 : NUM=0 : Endif
Endif
End

$TR_NUM
GOK=1
Trbegin [ATX]
 Gosub MAJ_NUM
 If GOK=-1 : Goto ROLL_TR_NUM
 Elsif GOK=0 : Goto AB_TR_NUM
 Endif
Commit
Return

$AB_TR_NUM
Rollback
Return

$ROLL_TR_NUM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_NUM : Endif

$MAJ_NUM
Local Char MESSAGE(250)
Lock [ATX]
Local Integer ASTATUS

If fstat
 GOK=-1 : GLOCK = "$ATEXTE" : Return
Endif
If dim([V]GADONIX)>0 & GADONIX<>2
 PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
Else
 PREM = 0 : DERN = GMAXTXTSTD
Endif
If dim([F:ATX]LANORI)>0
 Gosub SET_TBLAN
Endif
If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
 ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,GLANGUE,TBLAN,VALEUR, "",NUM, MESSAGE)
 If ASTATUS <> [V]CST_AOK
  Call ERREUR(MESSAGE-"\"+mess(274,133,1)) From GESECRAN
  GMESSAGE=MESSAGE : GOK=0 : Return
 Endif
Else
 Filter [ATX] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
 Read [ATX] Last
 Filter [ATX]
 If fstat : NUM = PREM+1 : Else : NUM = [F:ATX]NUMERO+1 : Endif
Endif
Raz [F:ATX]
[F:ATX]NUMERO = NUM
[F:ATX]TEXTE  = VALEUR
[F:ATX]LONG   = 30
[F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
[F:ATX]LAN = GLANGUE
Call FLDCRE("ATX") From OBJDIV
Write [ATX]
If fstat
 GOK=0 : Call FSTA("ATX") From GLOCK : Return
Endif
If dim([F:ATX]LANORI)>0
 For NOLAN=1 To NBLAN
  Readlock [ATX]NUMERO = TBLAN(NOLAN);NUM
  If fstat
   Read [ATX]NUMERO = GLANGUE;NUM
   [F:ATX]LAN = TBLAN(NOLAN)
   [F:ATX]LANORI = GLANGUE
   Write [ATX]
   If fstat
    GOK=0 : Call FSTA("ATX") From GLOCK : Break
   Endif
  Elsif !fstat & [F:ATX]LANORI<>""
   [F:ATX]TEXTE = VALEUR
   [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
   [F:ATX]LANORI = GLANGUE
   Call FLDUPD("ATX") From OBJDIV
   Rewrite [ATX]
   If fstat
    GOK=0 : Call FSTA("ATX") From GLOCK : Break
   Endif
  Endif
 Next NOLAN
 If GOK=0 : Return : Endif
Endif
Return

Subprog TEXTFIC(FICH,ZONE,TYP,VALEUR)
Value    Char    FICH
Value    Char    ZONE
Value    Integer TYP
Variable Char    VALEUR()
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
Read [ATZ]CODZONE = FICH;ZONE
If fstat=0
 Case TYP
  When 1 : Call TEXTE([F:ATZ]NOLONG ,VALEUR)
  When 2 : Call TEXTE([F:ATZ]NOCOURT,VALEUR)
  When 3 : Call TEXTE([F:ATZ]NOABREG,VALEUR)
 Endcase
Else
 VALEUR = ""
Endif
End

Subprog TITAWI(AWI,TIT)
Variable Char TIT()
Value    Char AWI()
TIT=""
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0 = AWI
If fstat=0
 Call TEXTE([F:AWI]DES,TIT) From OBJDIV
Endif
End

Subprog TXTCONT(NVAL,OVAL,NUM,LNG,OBJTYP,OBJNOM,ZONE)
Variable Char    NVAL
Value    Char    OVAL
Variable Decimal NUM
Value    Integer LNG
Value    Libelle OBJTYP
Value    Char    OBJNOM
Value    Char    ZONE
Goto CONT_TEX

Subprog CONTTEX(OVAL,NVAL,NUM,LNG,OBJTYP,OBJNOM,ZONE)
Value    Char    OVAL
Variable Char    NVAL
Variable Decimal NUM
Value    Integer LNG
Value    Libelle OBJTYP
Value    Char    OBJNOM
Value    Char    ZONE

$CONT_TEX
# cg 27 sep 2011
Local File ATEXTE [ATX2]

# cg oct 2012
Local Integer WNBRECORD
WNBRECORD= 0
# taille des mots et texte 80 par defaut
Local Integer WLENTEX
WLENTEX = 80
# on charge un alphabet les lettres en minuscule
Local Integer WINDICE
Local Char WALPHABET (1)(1..35)
For WINDICE = 1 To 26
        WALPHABET(WINDICE)= chr$(WINDICE+96)
Next I
#ajout des é è etc.. pour le francais
WALPHABET(27)= "é"
WALPHABET(28)= "è"
WALPHABET(29)= "ç"
WALPHABET(30)= "à"
WALPHABET(31)= "ê"
WALPHABET(32)= "ô"
WALPHABET(33)= "û"
WALPHABET(34)= "â"
WALPHABET(35)= "î"
# uniquement en interne pour x3
If GSOPHIA and GADONIX = 2
        If filinfo(filpath("FIL","ZGLOSSARY","fde", nomap),0) >= 0
            Local File ZGLOSSARY [ZZZ]
            WNBRECORD= 0
            Filter [ZZZ] Where LAN = GLANGUE and VALID = 2
            WNBRECORD = rowcount ([F:ZZZ])
            Filter [ZZZ]
            If WNBRECORD <>0
                # liste des mots corrects
                Local Char WORDS(WLENTEX)(1..WNBRECORD)
                I = 1
                For [ZZZ] Where LAN = GLANGUE and VALID = 2
                    WORDS(I) = [F:ZZZ]MOT
                    I +=1
                Next I
            Else
                # liste des mots corrects
                # ici pour ne pas planter dans le call plus loin
                Local Char WORDS(WLENTEX)
            Endif
        Else
           # liste des mots corrects
           # ici pour ne pas planter dans le call plus loin
           Local Char WORDS(WLENTEX)
        Endif
Endif



Local Integer RECH
NVAL = vireblc(NVAL,2)
If status=2 | status=138
 RECH = 1
Else
 If NVAL="" : NUM = 0 : End : Endif
 If OVAL=NVAL & NUM<>0 : End : Endif
Endif
Local Integer TYP , MAXTEX
TYP = 150

# cg juin 2012
# MAXTEX = 100
MAXTEX = 300

Local Integer NBTEX , VALEUR , NUMTEX(MAXTEX) , PREM , DERN
Local Char    TEX(TYP)(MAXTEX) , LIBTEX(TYP)(MAXTEX) , TIT(30) , MESSA(250)
Local Integer OK , OKTEX
Local Integer CNEW , CMOD , CREC , CABD
Local Integer NOL
Local Char    OCLE(20)
Local Integer NOLAN
NOL = nolign-1
NBTEX = 0
For [ATX]TEXTE Where LAN=GLANGUE & TEXTE=NVAL
 NBTEX += 1
 TEX(NBTEX) = format$("N:7#",[F:ATX]NUMERO)-"("
 If dim([F:ATX]COMMENT)>0 : TEX(NBTEX) += [F:ATX]COMMENT : Endif
 # cg 27 sep 2011
 # ajout du texte dans glandef si doublon snas commentaire
 # pour aiguiller le cod dev.
 If [F:ATX]COMMENT = "" and GLANGUE <> GLANDEF
        Read [ATX2]NUMERO=GLANDEF;[F:ATX]NUMERO
        If fstat = 0
           TEX(NBTEX) += GLANDEF +" : " +[F:ATX2]TEXTE
        Endif
 Endif
 TEX(NBTEX) += ")"
 If NBTEX+1>=MAXTEX : Break : Endif
Next
If NBTEX=1 & !RECH
 If GSOPHIA & [F:ATX]NUMERO>GMAXTXTSTD & [F:ATX]NUMERO<GNEWTXTSTD :#115210/6
  Gosub TEXSUPSTD
  If mkstat=2 : End : Endif
 Endif
 NUM = [F:ATX]NUMERO
 End
Elsif NBTEX>1
 Call SAITEX(NBTEX,TEX,VALEUR,NVAL) From GESECRAN
 If VALEUR<>0
  If GSOPHIA & val(left$(TEX(VALEUR),7))>GMAXTXTSTD  & val(left$(TEX(VALEUR),7))<GNEWTXTSTD :#115210/6
   Gosub TEXSUPSTD
   If mkstat=2 : End : Endif
  Endif
  NUM = val(left$(TEX(VALEUR),7))
 Else
  mkstat = 2
 Endif
 End
Endif

$CHTEX
Local Integer SIMILAR : SIMILAR=1 : #text server search
NBTEX = 0
# cg juin 2012
If GADONIX = 2 and GSOPHIA
    # on force la recherche sur une creation de texte
    NBTEX += 1 : TEX(NBTEX) = mess(27,123,1) : CREC = NBTEX : # Recherche
    RECH = 1 : VALEUR = CREC
Endif
$CHTEXBIS
# mb 21.9.7 Les distris n'ont pas le droits de créer de nouveaux textes pour les tâches/groupes batch
If left$(OBJNOM,4)<>"ABT~" or GADONIX=2 or nomap=GDOSX3
 NBTEX += 1 : TEX(NBTEX) = mess(25,123,1) : CNEW = NBTEX : # Nouveau texte
Endif
#115210/6
#If NUM>=GMAXTXTSTD | (NUM>0 & NUM<GMAXTXTSTD & dim([V]GADONIX)>0 & GADONIX=2) : # mb 15.7.2 bug 13668
If (NUM>=GMAXTXTSTD & NUM<GNEWTXTSTD) | (NUM>0 & (NUM<GMAXTXTSTD | NUM>GNEWTXTSTD )& dim([V]GADONIX)>0 & GADONIX=2) : # mb 15.7.2 bug 13668
 NBTEX += 1 : TEX(NBTEX) = mess(26,123,1) : CMOD = NBTEX : # Modif texte
Endif
If SIMILAR : #text server search
 NBTEX += 1 : TEX(NBTEX) = mess(27,123,1) : CREC = NBTEX : # Recherche
Endif
NBTEX += 1 : TEX(NBTEX) = mess(5,123,1) : CABD = NBTEX : # Abandon
VALEUR = CREC
TIT = mess(28,123,1) : # Texte
If NUM<>0
 TIT -= num$(NUM)
Endif
If OVAL<>"" : #U11 add the search text
 TIT -= OVAL
Endif
If !RECH
 Call SAITEX(NBTEX,TEX,VALEUR,TIT) From GESECRAN
Else
 RECH = 0 : VALEUR = CREC
Endif
Case VALEUR
 When 0
  mkstat = 2
 When CNEW
  Call DEBTRANS From GLOCK
  Gosub TR_TEX
  If GOK=1
   Call MESSAGE(mess(29,123,1)-num$(NUM)) From GESECRAN : # Texte numéro
  Endif
 When CMOD
  OK = 1
  Read [ATX]NUMERO = GLANGUE;NUM
  OCLE = [F:ATX]CLEREC
  For [ATX]TEXTE Where LAN=GLANGUE & TEXTE=NVAL
   If [F:ATX]CLEREC=OCLE
    OK = 0 : Break
   Endif
  Next ATX
  If !OK
   # Le texte "$1$" existe déjà sous le numéro $2$\Voulez-vous utiliser ce numéro ?
   Call AVERTIR(func AFNC.MES2(mess(245,125,1),NVAL,num$([F:ATX]NUMERO)),OK) From GESECRAN
   If OK=2
    NUM = [F:ATX]NUMERO
   Else
    OK = 0
   Endif
  Endif
  If OK=1 & GSOPHIA & GPRODUIT<>-1
   Read [ATX]NUMERO = GLANGUE;NUM
   If [F:ATX]UPDDAT<>date$
    # Confirmez-vous la modification du texte No $1$ ($2$) du $3$ par le texte $4$
    # Attention : Un changement de signification sur un texte ancien est à proscrire
    MESSA = func AFNC.MES4(mess(239,125,1),num$(NUM),OVAL,format$(GFMD,[F:ATX]UPDDAT),NVAL)
    MESSA += "\"+mess(240,125,1)
    Call AVERTIR(MESSA,OK) From GESECRAN
    OK = (OK=2)
   Endif
  Endif
  If !OK
   If OVAL<>"" : NVAL = OVAL : Endif
   mkstat = 2
  Elsif OK<>2 : # On prend un autre numéro mais on ne change pas de texte
   Call DEBTRANS From GLOCK
   Gosub TR_MTEX
   If GSOPHIA & GPRODUIT=-1
    # Vous venez de modifier ce texte.
    MESSA = mess(241,125,1)
    # Si vous transférez l'objet courant, l'ancien texte ne sera pas modifié et un nouveau texte sera être créé
    # dans les applis de développement
    MESSA += "\"+mess(242,125,1)+mess(243,125,1)
    If MESSA<>""
     Call MESSAGE(MESSA) From GESECRAN
    Endif
   Endif
  Endif
 When CREC
  Gosub RECHTEX
  Case OK
   When 1 : #THE TEXT IS FOUND IN TEXT SERVER BUT WE HAVE To CHECK If IT'S OK in ATEXTE
    If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6 :#For the new texts server
     Read [ATX]NUMERO = GLANGUE;NUM
     If fstat | [F:ATX]TEXTE<>NVAL
       Call DEBTRANS From GLOCK
       Gosub CHECK_TEX
     Endif
    Endif
   When 0
    # cg juin 2012
    If GADONIX = 2 and GSOPHIA
        NBTEX =0
        Goto CHTEXBIS
    Else
        Goto CHTEX
    Endif
   When -2 : #don't launch text server search
    SIMILAR=0
    # cg juin 2012
    If GADONIX = 2 and GSOPHIA
        NBTEX =0
        Goto CHTEXBIS
    Else
        Goto CHTEX
    Endif
   When -1
    If OVAL<>"" : NVAL = OVAL : Endif
    mkstat = 2
  Endcase
 When CABD
  If OVAL<>"" : NVAL = OVAL : Endif
  mkstat = 2
Endcase
nolign = NOL+1
indice = NOL
End

$TEXSUPSTD
OKTEX = 1
# Attention, le numéro de ce texte est supérieur à $1$\
# Voulez-vous continuer ?
#Call AVERTIR(func AFNC.MES1(mess(244,125,1),num$(GMAXTXTSTD))+"\"+mess(205,100,1),OKTEX) From GESECRAN
Call AVERTIR(func AFNC.MES2(mess(292,125,1),num$(GMAXTXTSTD),num$(GNEWTXTSTD))+"\"+mess(205,100,1),OKTEX) From GESECRAN
If OKTEX<>2 : mkstat = 2 : Endif
Return

$CHECK_TEX
Local Integer ASTATUS
Local Char MESSAGE(250)
Local Integer COUNT,ICOUNT
Local Char WTBLAN(3)(1..), WTBLANORI(3)(1..)
Local Char WTBTEXT(250) (1..), WTBCOM(250) (1..)

ASTATUS = func ATXTSVC.GET_TEXTINFO(GPRODUIT, NUM, COUNT, WTBLAN, WTBTEXT, WTBCOM, WTBLANORI, MESSAGE)
GOK=1
Trbegin [ATX]
 Lock [ATX]
 If fstat
  GOK=-1 : GLOCK = "$ATEXTE" : Goto ROLL_CHECK_TEX
 Endif
 For ICOUNT=1 To COUNT
  Read [ATX]NUMERO = WTBLAN(ICOUNT);NUM
  If fstat
   Raz [F:ATX]
   [F:ATX]LAN    = WTBLAN(ICOUNT)
   [F:ATX]NUMERO = NUM
   [F:ATX]TEXTE  = WTBTEXT(ICOUNT)
   [F:ATX]COMMENT  = WTBCOM(ICOUNT)
   [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
   If dim([F:ATX]LANORI)>0
    [F:ATX]LANORI    = WTBLANORI(ICOUNT)
   Endif
   Call FLDCRE("ATX") From OBJDIV
   Write [ATX]
   If fstat
    GOK=0 : Call FSTA("ATX") From GLOCK : Goto AB_CHECK_TEX
   Endif
  Elsif [F:ATX]TEXTE<>WTBTEXT(ICOUNT) | [F:ATX]COMMENT<>WTBCOM(ICOUNT)
   [F:ATX]TEXTE  = WTBTEXT(ICOUNT)
   [F:ATX]COMMENT  = WTBCOM(ICOUNT)
   If dim([F:ATX]LANORI)>0
    [F:ATX]LANORI    = WTBLANORI(ICOUNT)
   Endif
   Call FLDUPD("ATX") From OBJDIV
   Rewrite [ATX]
   If fstat
    GOK=0 : Call FSTA("ATX") From GLOCK : Break
   Endif
  Elsif dim([F:ATX]LANORI)>0 & [F:ATX]LANORI<>WTBLANORI(ICOUNT)
   [F:ATX]TEXTE  = WTBTEXT(ICOUNT)
   [F:ATX]COMMENT  = WTBCOM(ICOUNT)
   If dim([F:ATX]LANORI)>0
    [F:ATX]LANORI    = WTBLANORI(ICOUNT)
   Endif
   Call FLDUPD("ATX") From OBJDIV
   Rewrite [ATX]
   If fstat
    GOK=0 : Call FSTA("ATX") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK=0 : Goto AB_CHECK_TEX : Endif
Commit
Return

$AB_CHECK_TEX
Rollback
Return

$ROLL_CHECK_TEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto CHECK_TEX : Endif

$TR_TEX
Local Integer WNUM
Local Char MESSAGE(250)
GOK=1
Trbegin [ATX]
 Lock [ATX]
 If fstat
  GOK=-1 : GLOCK = "$ATEXTE" : Goto ROLL_TR_TEX
 Endif
 If dim([V]GADONIX)>0 & GADONIX<>2
  PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
 Else
  PREM = 0 : DERN = GMAXTXTSTD
 Endif
 If dim([F:ATX]LANORI)>0
  Gosub SET_TBLAN
 Endif
 If DERN = GMAXTXTSTD & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
  ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,GLANGUE,TBLAN,NVAL, "",WNUM, MESSAGE)
  NUM=WNUM
  If ASTATUS <> [V]CST_AOK
   Call ERREUR(MESSAGE-"\"+mess(274,133,1)) From GESECRAN
   GMESSAGE=MESSAGE : GOK=0 : Return
  Endif
 Else
  Filter [ATX] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
  Read [ATX] Last
  Filter [ATX]
  If fstat : NUM = PREM+1 : Else : NUM = [F:ATX]NUMERO+1 : Endif
 Endif
 Raz [F:ATX]
 [F:ATX]NUMERO = NUM
 [F:ATX]TEXTE  = NVAL
 [F:ATX]LONG   = LNG
 [F:ATX]TYPOBJ = OBJTYP
 [F:ATX]NOMOBJ = OBJNOM
 [F:ATX]NOMZON = ZONE
 [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
 [F:ATX]LAN    = GLANGUE
 Call FLDCRE("ATX") From OBJDIV
 Write [ATX]
 If fstat
  GOK=0 : Call FSTA("ATX") From GLOCK : Goto AB_TR_TEX
 Endif
 If dim([F:ATX]LANORI)>0
  For NOLAN=1 To NBLAN
   Readlock [ATX]NUMERO = TBLAN(NOLAN);NUM
   If fstat
    Read [ATX]NUMERO = GLANGUE;NUM
    [F:ATX]LAN = TBLAN(NOLAN)
    [F:ATX]LANORI = GLANGUE
    Write [ATX]
    If fstat
     GOK=0 : Call FSTA("ATX") From GLOCK : Break
    Endif
   Elsif !fstat & [F:ATX]LANORI<>""
    [F:ATX]TEXTE  = NVAL
    [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
    [F:ATX]LANORI = GLANGUE
    Call FLDUPD("ATX") From OBJDIV
    Rewrite [ATX]
    If fstat
     GOK=0 : Call FSTA("ATX") From GLOCK : Break
    Endif
   Endif
  Next NOLAN
  If GOK=0 : Goto AB_TR_TEX : Endif
 Endif
Commit
Return

$AB_TR_TEX
Rollback
Return

$ROLL_TR_TEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_TEX : Endif

$TR_MTEX
Local Integer ASTATUS
Local Char MESSAGE(250)
GOK=1
Trbegin [ATX]
 If dim([F:ATX]LANORI)>0
  Gosub SET_TBLAN
 Endif
 Readlock [ATX]NUMERO = GLANGUE;NUM
 If fstat=1
  GOK=-1 : GLOCK="$ATEXTE"-num$(NUM) : Goto ROLL_TR_MTEX
 Elsif fstat
  GOK=0 : Call RSTA("ATX",num$(NUM)) From GLOCK : Goto AB_TR_MTEX
 Endif
 [F:ATX]TEXTE = NVAL
 If dim([F:ATX]LANORI)>0 : [F:ATX]LANORI="" : Endif :#22/11/16 fix LANORI on changes
 [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
 Call FLDUPD("ATX") From OBJDIV
 Rewrite [ATX]
 If fstat
  GOK=0 : Call FSTA("ATX") From GLOCK : Goto AB_TR_MTEX
 Endif
 If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210
  ASTATUS=func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, NUM, GLANGUE, [F:ATX]TEXTE, [F:ATX]COMMENT, [F:ATX]LANORI, MESSAGE)
  If ASTATUS<>[V]CST_AOK
   Call ERREUR(MESSAGE-"\"+mess(274,133,1)) From GESECRAN
   GMESSAGE=MESSAGE : GOK=0 : Goto AB_TR_MTEX
  Endif
 Endif
 #
 If dim([F:ATX]LANORI)>0
  For NOLAN=1 To NBLAN
   Readlock [ATX]NUMERO = TBLAN(NOLAN);NUM
   If fstat
    Read [ATX]NUMERO = GLANGUE;NUM
    [F:ATX]LAN = TBLAN(NOLAN)
    [F:ATX]LANORI = GLANGUE
    Call FLDCRE("ATX") From OBJDIV
    Write [ATX]
    If fstat
     GOK=0 : Call FSTA("ATX") From GLOCK : Break
    Endif
   Elsif [F:ATX]LANORI<>""
    [F:ATX]TEXTE = NVAL
    [F:ATX]LANORI = GLANGUE
    [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
    Call FLDUPD("ATX") From OBJDIV
    Rewrite [ATX]
    If fstat
     GOK=0 : Call FSTA("ATX") From GLOCK : Break
    Endif
   Endif
   If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
    ASTATUS=func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT, NUM, TBLAN(NOLAN), [F:ATX]TEXTE, [F:ATX]COMMENT, [F:ATX]LANORI, MESSAGE)
    If ASTATUS<>[V]CST_AOK
     Call ERREUR(MESSAGE-"\"+mess(274,133,1)) From GESECRAN
     GMESSAGE=MESSAGE : GOK=0 : Break
    Endif
   Endif
  Next NOLAN
  If GOK=-1 : Goto ROLL_TR_MTEX
  Elsif GOK=0 : Goto AB_TR_MTEX
  Endif
 Endif
 If dim(GTXNB)>0 : Raz GTXNB : Raz GTXMES : Raz GTXNUM : Endif :#115210
Commit
Return

$AB_TR_MTEX
Rollback
Return

$ROLL_TR_MTEX
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_TEX : Endif

$RECHTEX

# cg oct 2012
If GADONIX = 2 and GSOPHIA
    Local Char WLAN(GLONLAN)
    Local Integer WVALEUR
    Local Char    WLIBTEX_AFF(TYP)(1..MAXTEX,1..4) , WTIT(40) (0..4)
    Local Char    WLIBCOM(TYP)(MAXTEX)
    Local Char    WLIBENG(TYP)(MAXTEX)

    If GLANGUE = GLANDEF
        WLAN = "ENG"
    Else
        WLAN = GLANDEF
    Endif
    NBTEX = 0
    RECHCLE = left$(vireblc(toupper(ctrans(NVAL)),4),20)
    If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6 :#For the new texts server
     Local Instance  NODES(1..)  Using C_ASYRJSO
     Local Instance  NODE        Using C_ASYRJSO
     Local Instance  NODELAN        Using C_ASYRJSO
     Local Instance  NODETEXT        Using C_ASYRJSO
     Local Char WTEXT(250), WCOMMENT(250)
     Local Clbfile RESULT
     Local Integer ASTATUS
     Local Integer INC

     ASTATUS = func ATXTSVC.SEARCH_SIMILAR("ATEXTE",GLANGUE, NVAL,RESULT)
     If ASTATUS=[V]CST_AHTTP_OK
      ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,RESULT,NODES,NODE)
      INC = 1
      While NODE <> null & NBTEX < MAXTEX
       NBTEX += INC :#little trick to filter texts which are empty for the main language
       INC = 1
       NUMTEX(NBTEX) =val(NODE.PRO)
       TEX(NBTEX) =""
       WLIBCOM(NBTEX) =""
       WLIBENG(NBTEX) =""
       NODELAN  = NODE.SUB
       While NODELAN <> null
        If NODELAN.PRO = GLANGUE
         NODETEXT = NODELAN.SUB
         While NODETEXT <> null
          Case NODETEXT.PRO
           When "TEXTE": TEX(NBTEX) = seg$(fmet NODETEXT.AGETCNT,2,len(fmet NODETEXT.AGETCNT)-1)
           If len(TEX(NBTEX)) : INC = 1 : Else : INC=0: Endif
           When "COMMENT":
            WLIBCOM(NBTEX) = seg$(fmet NODETEXT.AGETCNT,2,len(fmet NODETEXT.AGETCNT)-1)
            If WLIBCOM(NBTEX) <> '' & WLIBCOM(NBTEX) <> ' ' : WLIBCOM(NBTEX) = "## ("+WLIBCOM(NBTEX)+") ##" : Endif
          Endcase
          NODETEXT = NODETEXT.NEX
         Wend
        Elsif   NODELAN.PRO = WLAN
         NODETEXT = NODELAN.SUB
         While NODETEXT <> null
          Case NODETEXT.PRO
           When "TEXTE": WTEXT = seg$(fmet NODETEXT.AGETCNT,2,len(fmet NODETEXT.AGETCNT)-1)
           When "COMMENT": WCOMMENT = seg$(fmet NODETEXT.AGETCNT,2,len(fmet NODETEXT.AGETCNT)-1)
          Endcase
          NODETEXT = NODETEXT.NEX
         Wend
         If len(WTEXT) : WLIBENG(NBTEX) ="("+WLAN+":"+WTEXT+") " : Endif
         If WCOMMENT<>'' & WCOMMENT<>' ' : WLIBENG(NBTEX) += "## ("+WCOMMENT+") ##" :Endif
         Endif
        NODELAN = NODELAN.NEX
       Wend
       NODE = NODE.NEX
      Wend
     Else : # error on text server
      OK = -1
      GMESSAGE = "Error text server : "+RESULT
      Return
     Endif
    Else
     For I=len(RECHCLE) To 1 Step -1
         Filter [ATX] Where LAN=GLANGUE and (LANORI= "" or LANORI = GLANGUE)
&          and CLEREC>=left$(RECHCLE,I) & CLEREC<left$(RECHCLE,I)+chr$(255)
&          and (NUMERO < GMAXTXTSTD or NUMERO>GNEWTXTSTD) #115210/6
         For [ATX]CLEREC
             If !find([F:ATX]NUMERO,NUMTEX(1..NBTEX))
                NBTEX += 1
                TEX(NBTEX) = [F:ATX]TEXTE
                NUMTEX(NBTEX) = [F:ATX]NUMERO
                If [F:ATX]COMMENT<>""
                         WLIBCOM(NBTEX) = "   ## ("+[F:ATX]COMMENT+") ##"
                Endif
                Read [ATX2]NUMERO=WLAN;[F:ATX]NUMERO
                If fstat = 0
                     If [F:ATX2]LANORI = ""
                        WLIBENG(NBTEX) = "   ("+WLAN+" : " +[F:ATX2]TEXTE+")"
                        If [F:ATX2]COMMENT<>""
                             WLIBENG(NBTEX) += "   ## ("+[F:ATX2]COMMENT+") ##"
                        Endif
                     Endif
               Endif
               If NBTEX+1>=MAXTEX :
                        Filter [ATX]
                        Break 2
               Endif
             Endif
         Next
         Filter [ATX]
         If I=len(RECHCLE)
             # on ne sait pas trier des tableaux a +siuers dim, on le remplit plus loin
             Sorta NBTEX TEX(1..NBTEX),WLIBCOM(1..NBTEX),NUMTEX(1..NBTEX),WLIBENG(1..NBTEX)
         Endif
     Next I
    Endif
    If NBTEX>0
        # on ne sait pas trier des tableaux a +siuers dim
        # donc on remplit le tableau là.
        WVALEUR = 0
        Raz WLIBTEX_AFF
        WTIT(0) = mess(92,115,1) : # Recherche texte
        WTIT(1) = mess(29,123,1): #"Text Number"
        WTIT(3) = mess(123,124,1) : #"comment"
        If WLAN = "FRA"
            WTIT(2) = mess(299,123,1)  : #"Text in english"
            WTIT(4) = mess(300,123,1)+" ## "+mess(123,124,1)+" ## "
        Else
            WTIT(2) = mess(300,123,1) :#"Text in french"
            WTIT(4) = mess(299,123,1)+" ## "+mess(123,124,1)+" ## "
        Endif
        For I = 1 To NBTEX
           WLIBTEX_AFF(I,1) =  format$("N:7#",NUMTEX(I))
           WLIBTEX_AFF(I,2) = TEX(I)
           WLIBTEX_AFF(I,3) = WLIBCOM(I)
           WLIBTEX_AFF(I,4) = WLIBENG(I)
        Next I
        Call SAITEX_COL_MAX(NBTEX,WLIBTEX_AFF,WVALEUR,WTIT,400,MAXTEX) From GESECRAN

        If status<>7 & WVALEUR<>0
              NVAL = TEX(WVALEUR)
              NUM  = NUMTEX(WVALEUR)
              OK = 1
        Else
             OK = 0
              # controle norme
             Call CONTROL_TEXT (NVAL,nomap,WORDS,WNBRECORD,WLENTEX,WALPHABET) From OBJDIV
        Endif
    Else
        #don't launch text server search the next time
        #OK = -1
        OK = -2
        # controle norme
        Call CONTROL_TEXT (NVAL,nomap,WORDS,WNBRECORD,WLENTEX,WALPHABET) From OBJDIV
    Endif
Else
    # cg oct 2012 - comme avant
    NBTEX = 0
    RECHCLE = left$(vireblc(toupper(ctrans(NVAL)),4),20)
    For I=len(RECHCLE) To 1 Step -1
         For [ATX]CLEREC Where LAN=GLANGUE & CLEREC>=left$(RECHCLE,I) & CLEREC<left$(RECHCLE,I)+chr$(255)
              If !find([F:ATX]NUMERO,NUMTEX(1..NBTEX))
                   NBTEX += 1
                   TEX(NBTEX) = [F:ATX]TEXTE : NUMTEX(NBTEX) = [F:ATX]NUMERO
                   LIBTEX(NBTEX) = format$("N:7#",[F:ATX]NUMERO)-[F:ATX]TEXTE
                   If [F:ATX]COMMENT<>""
                        LIBTEX(NBTEX) += "   ## ("+[F:ATX]COMMENT+") ##"
                   Endif
                   If NBTEX+1>=MAXTEX : Break 2 : Endif
              Endif
         Next
         If I=len(RECHCLE)
              Sorta NBTEX TEX(1..NBTEX), LIBTEX(1..NBTEX), NUMTEX(1..NBTEX)
         Endif
     Next I
     If NBTEX>0
         VALEUR = 1
         TIT = mess(30,123,1) : # Choix message
         Call SAITEX(NBTEX,LIBTEX,VALEUR,TIT) From GESECRAN
         If status<>7 & VALEUR<>0
              If GSOPHIA & NUMTEX(VALEUR)>GMAXTXTSTD & NUMTEX(VALEUR)<GNEWTXTSTD :#115210/6
                   Gosub TEXSUPSTD
                   If mkstat=2 : OK = 0 : Return : Endif
              Endif
              NVAL = TEX(VALEUR)
              NUM  = NUMTEX(VALEUR)
              OK = 1
         Else
              OK = 0
         Endif
    Else
         OK = -1
    Endif
Endif

Return


## Pour la copie d'objet

Subprog COPTEXTE(NUM1,NUM2)
Value    Integer NUM1
Variable Integer NUM2
Local Integer PREM, DERN, NUM3, NOLAN
Local Char VALEUR1(10),VALEUR2(10)
Local Char MESSAGE(250)
NUM2 = 0 : NUM3 = 0
If NUM1=0 : End : Endif
Read [ATX1]NUMERO = GLANGUE;NUM1
If fstat : End : Endif
# Issue 86467 - 2012-12-20 by VPO : on teste les dossiers de copie
If dim([M:DIA_]DOSORG)>0 & dim([M:DIA_]DOSDES)>0
  VALEUR1=func AFNC.PARAMDOS([M:DIA_]DOSORG,"TYPDOS")
  VALEUR2=func AFNC.PARAMDOS([M:DIA_]DOSDES,"TYPDOS")
Elsif dim([M]DOSORG)>0 & dim([M]DOSDES)>0
  VALEUR1=func AFNC.PARAMDOS([M]DOSORG,"TYPDOS")
  VALEUR2=func AFNC.PARAMDOS([M]DOSDES,"TYPDOS")
Endif
# Si même produit et pas superviseur et numero standard
If val(VALEUR1)=val(VALEUR2) & val(VALEUR1)<>0 & val(VALEUR2)<>0 & (NUM1<GMAXTXTSTD | NUM1>GNEWTXTSTD) :#115210/6
 #on garde le même numéro
 NUM2=NUM1
 # si on trouve le bon texte, on sort
 Read [ATX2]NUMERO = GLANGUE;NUM2
 If !fstat
  If [F:ATX2]TEXTE=[F:ATX1]TEXTE & vireblc(toupper(ctrans([F:ATX1]COMMENT)),2)=vireblc(toupper(ctrans([F:ATX2]COMMENT)),2)
    End
  Else
    NUM2=0
  Endif
 Endif
Endif
#119211
If dim([F:ATX2]LANORI)>0
 Gosub SET_TBLAN2
Endif
If NUM2=0
 For [ATX2]TEXTE Where LAN=GLANGUE & TEXTE=[F:ATX1]TEXTE
   If vireblc(toupper(ctrans([F:ATX1]COMMENT)),2)=vireblc(toupper(ctrans([F:ATX2]COMMENT)),2)
    NUM2 = [F:ATX2]NUMERO
    Break
   Elsif NUM3=0
    NUM3 = [F:ATX2]NUMERO
   Endif
 Next
 If NUM2=0 : NUM2 = NUM3 : Endif
 # si on trouve le texte, on sort
 If NUM2<>0 : End : Endif

 Lock [ATX2]
 If fstat
  GOK=-1 : GLOCK="$ATEXTE"
 Else
  If dim([V]GADONIX)>0 & GADONIX<>2
   PREM = GMAXTXTSTD : DERN = GMAXTXTSPE
  Else
   PREM = 0 : DERN = GMAXTXTSTD
  Endif
  Onerrgo ERW
  If DERN = GMAXTXTSTD & func AFNC.PARAMDOS([M]DOSDES,"ATXTSRV")="2" :#115210/6
    ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(val(VALEUR2)-1,GLANGUE,TBLAN,[F:ATX1]TEXTE, [F:ATX1]COMMENT,NUM2,MESSAGE)
    If ASTATUS  <> [V]CST_AOK
     Call ERREUR(MESSAGE-"\"+mess(274,133,1)) From GESECRAN
     GMESSAGE=MESSAGE : GOK=0 : Return
    Endif
  Else
    Filter [ATX2] Where NUMERO>PREM & NUMERO<DERN Order By Key CLE=NUMERO;LAN
    Read [ATX2] Last
    Filter [ATX2]
    If fstat : NUM2 = PREM+1 : Else : NUM2 = [F:ATX2]NUMERO+1 : Endif
  Endif
  Onerrgo
 Endif
Endif
If GOK<1 : End : Endif
Onerrgo ERW
[F:ATX2] = [F:ATX1]
[F:ATX2]NUMERO = NUM2
Call FLDCRE("ATX2") From OBJDIV
Write [ATX2]
If fstat
 GOK=0 : Call FSTA("ATX2") From GLOCK
Endif
If GOK>0 & dim([F:ATX2]LANORI)>0
 #Gosub SET_TBLAN2
 For NOLAN=1 To NBLAN
  Readlock [ATX2]NUMERO = TBLAN(NOLAN);NUM2
  If fstat
   [F:ATX2] = [F:ATX1]
   [F:ATX2]NUMERO = NUM2
   [F:ATX2]LAN    = TBLAN(NOLAN)
   [F:ATX2]LANORI = GLANGUE
   Call FLDCRE("ATX2") From OBJDIV
   Write [ATX2]
   If fstat
    GOK=0 : Call FSTA("ATX2") From GLOCK : Break
   Endif
  Elsif !fstat & [F:ATX2]LANORI<>""
   [F:ATX2]TEXTE  = [F:ATX1]TEXTE
   [F:ATX2]CLEREC = [F:ATX1]CLEREC
   [F:ATX2]LANORI = GLANGUE
   Call FLDUPD("ATX2") From OBJDIV
   Rewrite [ATX2]
   If fstat
    GOK=0 : Call FSTA("ATX2") From GLOCK : Break
   Endif
  Endif
 Next NOLAN
Endif
Onerrgo
If GOK<1 : End : Endif
End

$SET_TBLAN2
Local Char    TBLAN(GLONLAN)(1..50)
Local Integer NBLAN
Raz NBLAN , TBLAN
For [ATX2]NUMERO(1) Where LAN<>"" & LAN<>"XXX" & LAN<>GLANGUE & NUMERO<100
 NBLAN += 1
 TBLAN(NBLAN) = [F:ATX2]LAN
Next ATX2
Return

$ERW
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
# Erreur d'écriture/Texte numéro
GMESSAGE = mess(26,125,1)-'ATEXTE : "'+[F:ATX1]TEXTE+'"'-mess(29,123,1)-num$(NUM2)
Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Raz GMESSAGE , GOK
Resume

Subprog PARAMATEXTE(LNG,OBJTYP,OBJNOM,ZONE)
Value Integer LNG
Value Char OBJTYP,OBJNOM,ZONE
End


Subprog PARAMATT(NUM)
Value Integer NUM
End


#####################################################
Subprog CONTHM(HEURE)
Variable Char HEURE
Local Integer HH, MM
Local Char    WH(50)
WH = HEURE
Case len(WH)
 When 0
  WH = "0000"
 When 1
  WH = "0" + WH + "00"
 When 2
  WH = WH + "00"
 When 3
  WH = "0" + WH
Endcase
HH = val(left$(WH,2))
MM = val(right$(WH,3))
If HH > 23 | MM > 59
 mkstat = 1 : GMESSAGE = mess(69,134,1) : End : # Heure incorrecte
Endif
HEURE = WH
End

Subprog INIHM(HEURE)
Variable Char HEURE
If HEURE<>""
 HEURE = left$(HEURE+"0000",4)
Endif
End

#####################################################
Subprog ACODIF(CODE)
Value Char CODE
Local Integer I
Local Char    COD(3)(1..3)
Local File ACODIF [ACO]
Local Mask ACODIF

Raz [M]
[M]CODE = CODE
If find(left$(CODE,2),"X_","Y_","Z_")
 CODE = right$(CODE,3)
Endif
COD(1) = left$(CODE,3)
COD(2) = mid$(CODE,4,3)
COD(3) = mid$(CODE,7,3)
For I=1 To 3
 If COD(I)<>""
  Read [ACO]ACO0 = COD(I)
  If !fstat
   [M]FRANCAIS += [F:ACO]FREDES+" / "
   [M]ANGLAIS  += [F:ACO]ENGDES+" / "
  Else
   [M]FRANCAIS += "<"+COD(I)+"> "
   [M]ANGLAIS  += "<"+COD(I)+"> "
  Endif
 Endif
Next I
Call AFFWIN(mess(96,123,1),"ACODIF") From GESECRAN : # Signification
End

Subprog CONTEXP(VALEUR)
Value Char VALEUR
If VALEUR="" : End : Endif
Local Integer E
E = abs(parse(VALEUR))
If E
 GMESSAGE = mess(37,124,1)+"\"+errmes$(abs(E))+"\"+errm
# Expression incorrecte
 mkstat = 2
Endif
End

#############################################
## Contrôle du code activité
#############################################
Subprog CONTACT(NEWREC,OLD)
Variable Char NEWREC()
Value    Char OLD
If GADONIX<>2
# BY 3/11/99 Les gens trouvent ça trop dur!
 If OLD<>"" & OLD<"X" & NEWREC="" : # NEWREC<>OLD
  NEWREC = OLD
  GMESSAGE = mess(9,123,1) : # Modification impossible
  mkstat = 2 : End
 Elsif OLD<>NEWREC & NEWREC<"X" & NEWREC<>""
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

########################################################
## Qui locke quoi avec email sur un dossier ?
########################################################
Subprog QUILOCKMAIL(DOSSIER,SYMBOLE,MACHINE,USER,MAIL)
Value    Char DOSSIER
Value    Char SYMBOLE
Variable Char MACHINE()
Variable Char USER()
Variable Char MAIL()
Goto QUILOCK

#############################################
## Qui locke quoi sur un dossier ?
#############################################
Subprog QUILOCKDOS(DOSSIER,SYMBOLE,MACHINE,USER)
Value    Char DOSSIER
Value    Char SYMBOLE
Variable Char MACHINE()
Variable Char USER()
Local Char MAIL(GLONMAI)
Goto QUILOCK

#############################################
## Qui locke quoi ?
#############################################
Subprog QUILOCKE(SYMBOLE,MACHINE,USER)
Value    Char SYMBOLE
Variable Char MACHINE()
Variable Char USER()
Local Char MAIL(GLONMAI) , DOSSIER(GLONADS)
Goto QUILOCK

$QUILOCK
Local Char    PROCESS(20)
If DOSSIER="" or DOSSIER=nomap
 Local File APLLCK [ALK]
Else
 Local File =DOSSIER+".APLLCK" [ALK]
Endif
USER = ""
Read [ALK]LCKCLE(1) = SYMBOLE
If fstat=0
 PROCESS = num$([F:ALK]LCKPID)
 Call USER_QUI(PROCESS,DOSSIER,MACHINE,USER,MAIL) From PSADX
Endif
End

#############################################
# C'est moi qui locke ?
#############################################
Subprog JELOCKE(SYMBOLE,OK)
Value    Char    SYMBOLE
Variable Integer OK
Local Char    PROCESS(20)
Local File APLLCK [ALK]
OK = 0
Read [ALK]LCKCLE(1) = SYMBOLE
If fstat=0
 PROCESS = num$([F:ALK]LCKPID)
 If PROCESS = num$(adxuid(2))
  OK = 1
 Endif
Endif
Close Local File [ALK]
End

Subprog JELOCKEDOS(DOSSIER,SYMBOLE,OK)
Value    Char    DOSSIER,SYMBOLE
Variable Integer OK
Local Char    PROCESS(20)
If DOSSIER="" or DOSSIER=nomap
 Local File APLLCK [ALK]
Else
 Local File =DOSSIER+".APLLCK" [ALK]
Endif
OK = 0
Read [ALK]LCKCLE(1) = SYMBOLE
If fstat=0
 PROCESS = num$([F:ALK]LCKPID)
 If PROCESS = num$(adxuid(2))
  OK = 1
 Endif
Endif
Close Local File [ALK]
End

###############################################
## Référence croisée d'un texte (M Giet)
## LNUM = Numéro du texte
###############################################
Subprog XREFTXT(LNUM)
Value Integer LNUM
#
Local Char    WINT(20)(6)
Local Char    WTXT(60)
Local Char    WTIT(60)
Local Char    WCLE(30)
Local Char    TFIC(GLONATB)(1..50)
Local Char    TZON(GLONAVA)(1..50)
Local Char    TNOF(30)(1..50)
Local Char    TNOZ(30)(1..50)
Local Char    TCLE(30)(1..50)
Local Char    TMOD(15)(1..50)
Local Integer IART, IATB, IATZ, IATX, ILIG
Local Integer I
#
Raz IART, IATB, IATZ, IATX
If clalev([F:ART]) = 0 : Local File AREFTXT [ART] : IART = 1 : Endif
If clalev([F:ATB]) = 0 : Local File ATABLE  [ATB] : IATB = 1 : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON [ATZ] : IATZ = 1 : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE  [ATX] : IATX = 1 : Endif
Local File (Char ZFIC(10), Char ZZON(10), Char ZNOF(30), Char ZNOZ(30),Char ZCLE(30),
&           Char ZMOD(15))
&     From Variable TFIC, TZON, TNOF, TNOZ, TCLE, TMOD As [SEL]
#
Call TEXTFIC("AREFTXT","CODFIC",2,WINT(0))   From OBJDIV
Call TEXTFIC("AREFTXT","CODZONE",2,WINT(1))  From OBJDIV
Call TEXTFIC("ATABLE","INTITFIC",2,WINT(2))  From OBJDIV
Call TEXTFIC("ATABZON","NOCOURT",2,WINT(3))  From OBJDIV
Call TEXTFIC("AREFTXT","CLES",2,WINT(4))     From OBJDIV
Call TEXTFIC("AREFTXT","MODULE",2,WINT(5))   From OBJDIV
Call TEXTE(LNUM,WTXT) From OBJDIV
WTIT = mess(29,123,1)-":"-num$(LNUM)-WTXT
#
ILIG = 1
Filter [ART] Where TXTNUM = LNUM
&            Order By Key ART0
For [ART]
  If ILIG < dim(TFIC)
    TFIC(ILIG) = [F:ART]CODFIC
    TZON(ILIG) = [F:ART]CODZONE
    TNOF(ILIG) = ""
    Read [ATB]CODFIC = [F:ART]CODFIC
      If fstat = 0
        Call TEXTE([F:ATB]INTITFIC,TNOF(ILIG)) From OBJDIV
      Endif
    Call TEXTFIC([F:ART]CODFIC,[F:ART]CODZONE,2,TNOZ(ILIG)) From OBJDIV
    WCLE       = [F:ART]CLES
    I = 1
    While instr(I,WCLE,"~") <> 0
      I    = instr(I,WCLE,"~")
      WCLE = left$(WCLE,I-1)+" "+right$(WCLE,I+1)
    Wend
    TCLE(ILIG) = WCLE
    If [F:ART]MODULE = 0
      TMOD(ILIG) = " "
    Else
      TMOD(ILIG) = mess([F:ART]MODULE,14,1)
    Endif
    ILIG += 1
  Endif
Next
Filter [ART]
If ILIG = 1
  Call MESSAGE(mess(210,100,1)) From GESECRAN
Else
  Choose [SEL]  Where ZFIC <> ""
&    Using  [F:SEL]ZFIC  Titled WINT(0),
&           [F:SEL]ZZON  Titled WINT(1),
&           [F:SEL]ZNOF  Titled WINT(2),
&           [F:SEL]ZNOZ  Titled WINT(3),
&           [F:SEL]ZCLE  Titled WINT(4),
&           [F:SEL]ZMOD  Titled WINT(5)
&    Sized(80,300)
&    Titled WTIT
Endif
If IART = 1 : Close Local File [ART] : Endif
If IATB = 1 : Close Local File [ATB] : Endif
If IATZ = 1 : Close Local File [ATZ] : Endif
If IATX = 1 : Close Local File [ATX] : Endif
End


#--------------------------------------------------------------------#
# Permet de recuperer les colonnes d'une selection d'un objet
#--------------------------------------------------------------------#

Subprog TRANSCOL(OBJET,NBCOL,COL,TIT,FMTCOL)
Value Char OBJET
Variable Integer NBCOL
Variable Char    COL()(1..)
Variable Char    TIT()(0..)
Variable Schar   FMTCOL()(1..)

Local Integer PSUB, PSPE, PSTD, PSPV , J , I
Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGSPE(GDIMFIC) , PROGSPV(GDIMFIC)(1..50)


Call SETPROG(OBJET,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
If !PSTD : End : Endif

Gosub OUVFIC From =PROGOBJ

Gosub OUVRE_LISTE From =PROGOBJ

For I=1 To NBSEL
 J = I+NBCOL
 If SELEXP(I)<>""
  COL(J) = SELEXP(I)
 Else
  COL(J) = SELZON(I)
 Endif
 TIT(J) = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(J) = "mess("+COL(J)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
 If dim(SELFOR)>0
  FMTCOL(J) = SELFOR(I)
 Endif
Next I
NBCOL += NBSEL
End


#----------------------------------------------------------------#
# Mise à jour des champs standard en création d'une fiche
#----------------------------------------------------------------#

Subprog FLDCRE(ABFIC)
Value Char ABFIC
If evalue("dim([F:"+ABFIC+"]CREDAT)")>0
    Assign "[F:"+ABFIC+"]CREDAT" With date$
Endif
If evalue("type([F:"+ABFIC+"]CRETIM)")=4
    Assign "[F:"+ABFIC+"]CRETIM" With time
Endif
If evalue("dim([F:"+ABFIC+"]CREUSR)")>0
 If dim(GUSRSD)>0 & GUSRSD<>""
    Assign "[F:"+ABFIC+"]CREUSR" With GUSRSD
 Else
    Assign "[F:"+ABFIC+"]CREUSR" With GUSER
 Endif
Endif
If evalue("dim([F:"+ABFIC+"]EXPNUM)")>0
    Assign "[F:"+ABFIC+"]EXPNUM" With [C]EXPORT
Endif
If evalue("dim([F:"+ABFIC+"]UPDDAT)")>0
    Assign "[F:"+ABFIC+"]UPDDAT" With date$
Endif
If evalue("type([F:"+ABFIC+"]UPDTIM)")=4
    Assign "[F:"+ABFIC+"]UPDTIM" With time
Endif
If evalue("dim([F:"+ABFIC+"]UPDUSR)")>0
   If dim(GUSRSD)>0 & GUSRSD<>""
      Assign "[F:"+ABFIC+"]UPDUSR" With GUSRSD
  Else
      Assign "[F:"+ABFIC+"]UPDUSR" With GUSER
  Endif
Endif
End

#----------------------------------------------------------------#
# Mise à jour des champs standard en modification d'une fiche
#----------------------------------------------------------------#

Subprog FLDUPD(ABFIC)
Value Char ABFIC
If evalue("dim([F:"+ABFIC+"]UPDDAT)")>0
     Assign "[F:"+ABFIC+"]UPDDAT" With date$
Endif
If evalue("type([F:"+ABFIC+"]UPDTIM)")=4
     Assign "[F:"+ABFIC+"]UPDTIM" With time
Endif
If evalue("dim([F:"+ABFIC+"]UPDUSR)")>0
 If dim(GUSRSD)>0 & GUSRSD<>""
     Assign "[F:"+ABFIC+"]UPDUSR" With GUSRSD
 Else
     Assign "[F:"+ABFIC+"]UPDUSR" With GUSER
 Endif
Endif
If evalue("dim([F:"+ABFIC+"]EXPNUM)")>0
     Assign "[F:"+ABFIC+"]EXPNUM" With [C]EXPORT
Endif
End

#----------------------------------------------------------------#
# Redeclencle l'init bouton après l'éxécution d'une action
# sur bouton droit
#----------------------------------------------------------------#
Subprog REIB
If mkstat=0 : mkstat=3 : Endif
End

################################################
Subprog CONTROL_TEXT (RVALEUR,RDOSSIER,RWORDS,RNBRECORD,RLENTEX,RALPHABET)
Value Char RVALEUR
Value Char RDOSSIER
Value Char RWORDS ()(1..)
Value Integer RNBRECORD
Value Integer RLENTEX
Value Char RALPHABET ()(1..)


#-----------------------------------------------#
# controle du texte en fonction des normes de x3
# uniquement en interne , juste pour nous
#-----------------------------------------------#

Local Integer WINDICE
Local Clbfile WCLOB (4)

# uniquement en interne pour x3
If GSOPHIA and GADONIX = 2
    Raz WCLOB

    Local Integer THRESHOLD
    THRESHOLD =1

    Local Char WCHAINE(RLENTEX), WMOT(RLENTEX)
    Local Integer WRESULT

    # analyse du texte , mot par mot avec les règles de x3 uniquement en interne
    Gosub ANA_TXT From OBJDIV
    #
    If WCLOB <> ""
        If clalev( [M:AFF] ) = 1
            # cas gestion des tables ou mask AFF est deja ouvert
            [M:AFF]AFFCLB = WCLOB
            Local Integer WOK
            #Call DIALWIN(WOK,"","AFFCLOB") From GESECRAN
            Call AFFWIN("","AFFCLOB") From GESECRAN
        Else
            Call AFFMES(WCLOB) From GESECRAN
        Endif
    Endif
Endif


End


#######################################
# analyse du texte
#######################################
$ANA_TXT
Local Integer WBREAK
WAFFICH = 0
Local Char WTEXTE(RLENTEX)
Local Char WCAR(1)
# longueur du texte si zero on sort
Local Integer WLEN
WLEN = len (RVALEUR)
If WLEN = 0 : Return : Endif


#
WTEXTE = RVALEUR

If pat (RVALEUR,"*.*")
        #WCLOB += "Attention norme = éviter le(s) point(s) dans le texte."+chr$(13)
        WCLOB += mess(306,123,1)+chr$(13)

Endif

If pat (RVALEUR,"*:*")
        #WCLOB += "Attention norme = éviter le(s) : dans le texte."+chr$(13)
        WCLOB += mess(307,123,1)+chr$(13)
Endif

WCAR =right$(RVALEUR,len (RVALEUR))
If WCAR = " "
        #WCLOB += "Attention norme = éviter le caractère blanc à la fin du texte."+chr$(13)
        WCLOB += mess(308,123,1)+chr$(13)

Endif

# on vire les blancs devant et à la fin du texte
WTEXTE = vireblc (WTEXTE,2)

# combien de blanc dans le texte pour compter les mots
Local Integer  WINDICE, WNBRE
WNBRE = 1

Local Char WTAB_TEXT (1) (1..WLEN)
Local Char WTAB_MOT (RLENTEX) (1..WLEN)
Local Integer WTAB_LENMOT (1..WLEN)

Local Integer WLEN_MOT , WBOUCLE
Local Char WMOT (RLENTEX)


Raz WTAB_TEXT
WLEN_MOT = 0
WTAB_LENMOT = 0

For WINDICE = 1 To WLEN
    WTAB_TEXT (WINDICE)= mid$(WTEXTE,WINDICE,1)
    If WTAB_TEXT (WINDICE )= " "
        # cas du blanc comme separateur de mot
        WLEN_MOT = WTAB_LENMOT (WNBRE)
        WTAB_MOT (WNBRE) = mid$(WTEXTE,WINDICE-WLEN_MOT,WLEN_MOT)
        WNBRE +=1
    Elsif WTAB_TEXT (WINDICE )= "'"
        # cas de apostrophe comme separateur de mot
        WLEN_MOT = WTAB_LENMOT (WNBRE)
        WTAB_MOT (WNBRE) = mid$(WTEXTE,WINDICE-WLEN_MOT,WLEN_MOT)
        WNBRE +=1
    Else
        WTAB_LENMOT (WNBRE) +=1
    Endif
Next WINDICE
# le dernier mot a recuperer
If WNBRE <> 0
    WLEN_MOT = WTAB_LENMOT (WNBRE)
    WTAB_MOT (WNBRE) = mid$(WTEXTE,WLEN-WLEN_MOT+1,WLEN_MOT)
Endif


# nombre de mots = wnbre
For WBOUCLE = 1 To WNBRE
    WMOT     = WTAB_MOT (WBOUCLE)
    WLEN_MOT = WTAB_LENMOT (WBOUCLE)

    Gosub ANA_MOT

    If WAFFICH =1
            #WCLOB += "Attention norme = le mot Nø n'est pas autorisé."+chr$(13)
            WCLOB += mess (301,123,1) +chr$(13)
    Elsif WAFFICH =2
            #WCLOB += "Attention norme = le premier mot doit commencer par une majuscule."+chr$(13)
            WCLOB += mess (302,123,1)+chr$(13)

    Elsif WAFFICH =3
            #WCLOB += "Attention norme = les autres mots doivent commencer par une minuscule sauf pour les abréviations."+chr$(13)
            WCLOB += mess (303,123,1)+chr$(13)
    Endif
    # il faut avant verifier que ce mot n'appartient à la liste
    # et unquement ou dans le cas d un retour sur ana-mot avec waffich = 2 ou 3
    # si waffich = 5 --> exception on passe
    # si waffich = 1 --> on passe aussi
    # ne fonctionne que pour un texte avec un seul mot.
    # et on n affiche que les retour < 1  (au plus une opération pour passer à un autre mot)
    # on recherche mot en minuscule (le dico zgloassary contient les mots x3 en minuscules
    # si rien dasn zglossayre on passe
    # dans cette table il y a aussi les abreviations deja utilisees comme ttc
    # on ne test que sur des mots de plus de 2 car
    # idem sur des mots avec des car autre que alphabet comme des mot comme tri: on passe ou tri1 --- a faie?????????
    # ici le mot est sans blanc devant et derriere
    If RNBRECORD <>0
      If WAFFICH=2 or WAFFICH = 3 or WAFFICH = 0
        WCHAINE = tolower(WMOT)
        If len(WMOT) > 2

                If !find(WCHAINE,RWORDS (1..RNBRECORD))
                    # on regarde si premier en fra est E car il faudrait aussi chercher sur le é
                    # cas du mot Evaluation par exemple en tolower devient evaluation
                    Local Char WSCHAINE (RLENTEX)
                    WSCHAINE=""
                    If left$(WMOT,1) = "E"
                        WSCHAINE = "é"+right$(WCHAINE,2)
                        If !find(WSCHAINE,RWORDS (1..RNBRECORD))
                            WSCHAINE = ""
                        Endif
                    Endif
                    If WSCHAINE = ""
                        #WCLOB += time$ + chr$(13)
                        For I = 1 To RNBRECORD
                          If WCHAINE <> RWORDS(I) and RWORDS(I) <> ""
                            #WRESULT = func OBJDIV.DAMERAU_LEVENSHTEIN(WCHAINE, RWORDS(I))
                            # on evite les func et call car moins rapide que le gosub de pas beaucoup
                            # mais bon 6 s pour traiter 6735 mots dans glossaire contre 7 s si func
                            Gosub LEVENSHTEIN
                            If WRESULT <= THRESHOLD
                                 #APPEND WCLOB, "Vérifier le mot -> " +WCHAINE + " //  Vous voulez peut-être saisir -> " + RWORDS(I) + chr$(13)
                                 Append WCLOB, mess(304,123,1)+" -> " +WCHAINE + " //  "+mess(305,123,1)+" -> " + RWORDS(I) + chr$(13)
                            Endif
                          Endif
                        Next T
                        #WCLOB += time$ + chr$(13)
                    Endif
                Endif
          Endif
        Endif
    Endif
Next WBOUCLE


Return


#############################
$ANA_MOT
# analyse d'un seul mot
# il faut simplement la premiere lettre en majuscule sur le premier mot
# attention aux exceptions

WAFFICH= 0
Local Char WMOTMAJ(100)
# si le mot est entierement en majuscule on laisse tel quel
WMOTMAJ = toupper( WMOT)
If WMOTMAJ = WMOT
    # c'est une exception
    WAFFICH= 5
    Return
Endif

If WMOT = "No."
    # c'est une exception
    # mais on signale quand même le .
    WAFFICH= 5
    Return
Endif
If WMOT = "no."
    # c'est une exception
    # mais on signale quand même le .
    WAFFICH= 5
    Return
Endif


# on alerte sur le mot Nø car devrait etre No
# en eng ou fra c'est idem
If WMOT ="Nø"
    # c'est pas bon
    WAFFICH = 1
    Return
Endif
If WMOT = "Nø."
    # c'est pas bon
    WAFFICH = 1
    Return
Endif

# ici il faut simplement une majuscule sur 1 iere et le reste en minuscule uniqueùent sur le premier mot
# de 65 à 95 c'est les majuscules
# de 97 à 122 c'est les minuscules
# en francais alphabet aussi avec des é à etc...
# le reste des caracteres on laisse
# "abc   z"
WCAR = left$ (WMOT,1)
If WBOUCLE =1
    # première lettre en maj on alerte sur les autres
    # de 65 à 95 c'est les majuscules
    # de 97 à 122 c'est les minuscules ---> là cest ok le reste est mauvais
    # le reste des caracteres attention au é etc...
    If find (WCAR,RALPHABET(1..35))
        # c'est mauvais, le mot commence par une minuscule
        WAFFICH = 2
        Return
    Endif
Else
    # autres mots , pas de maj en premiere lettre
    For WINDICE = 65 To 95
        # "ABC  Z"
        If WCAR = chr$(WINDICE)
            # c'est pas bon
            WAFFICH = 3
            Break
        Endif
    Next WINDICE
Endif

Return

######################################################################################
#  Algo de levenshtein
#* Returns the Damerau Levenshtein distance to determine if two strings are approximatly equal.<br>
#* This code is base on pseudo code from
#* <a href="http://en.wikipedia.org/wiki/Damerau%E2%80%93Levenshtein_distance">wikipedia</a>
# insertion : cot-> coat
# deletion : coat-> cot
# substition coat -> cost

# Afin de trouver les mots susceptibles de remplacer le mot erroné, on calcule sa distance d'édition avec les mots de notre glossaire.
# Dans notre cas, nous utilisons la distance de Damerau-Levenshtein qui consiste à calculer le nombre minimum d'opérations simples à effectuer
# pour passer d'un mot à l'autre. Ces opérations consistent en la suppression de caractère, l'ajout de caractère, la substitution du caractère
# par un autre et la transposition de deux caractères connexes (à savoir l'échange de leur position dans le mot).
#
# La distance de Levenshtein mesure la similarité entre deux chaînes de caractères.
# Elle est égale au nombre minimal de caractères qu'il faut supprimer, insérer, ou remplacer pour passer d’une chaîne à l’autre.
# CETTE distance est d'autant plus grande que le nombre de différences entre les deux chaînes est grand.


#*
#* @param STR1
#* @param STR2
#*!
$LEVENSHTEIN

Local Char STR1(RLENTEX), STR2(RLENTEX)
Local Integer L1, L2

WRESULT =0
STR1=WCHAINE
STR2=RWORDS(I)


  L1 = len(STR1)
  L2 = len(STR2)
  # on compare avec des mots de taille < L1+2 car si mot plus grand de toute maniere 2 insertions
  # et donc pas la peine
  # idem si le mot a comparer est de taille trop petit si mot a taille L2 < L1-2 pas la peine
  # voir si on veut encore ganger du temps... ajouter uen colonne au tabelau qui donne taille du mot
  # trier ce tableau en fct de la taille des mots
  # et ne commencer la comparaison que sur des mots de bonnes tailles.
  If L2  > L1 + 2
        WRESULT =10
        Return
  Endif
  If L2  < L1 - 2
        WRESULT =10
        Return
  Endif


  # attention a ne pas changer de place
  Local Integer D(0..L1, 0..L2)
  Local Integer IND, JND, COST

  For IND = 0 To L1
    D(IND, 0) = IND
  Next IND
  For JND = 0 To L2
    D(0, JND) = JND
  Next JND
  For IND = 1 To L1
    For JND = 1 To L2
      #
      # lettre identique le cout est 0
      If mid$(STR1, IND, 1) = mid$(STR2, JND, 1) Then
        COST = 0
      Else
        COST = 1
      Endif
      # on prend le minimum entre
      #     l element directement avant lui +1
      #     l element directement au dessus de lui +1
      #     l element diagonale predecent + cout
      # min of deletion, insertion, substitution
      D(IND, JND) = min(min(
&                   D(IND-1, JND) + 1,
&                   D(IND, JND-1) + 1),
&                   D(IND-1, JND-1) + COST
&                   )
      If (IND > 1 and JND > 1 and mid$(STR1, IND, 1) = mid$(STR2, JND-1, 1) and mid$(STR1, IND-1, 1) = mid$(STR2, JND, 1)) Then
        # min of current and transposition
        D(IND, JND) = min(
&                     D(IND, JND),
&                     D(IND-2, JND-2) + COST
&                     )
      Endif


    Next JND
  Next IND
WRESULT=D(L1, L2)

Return

