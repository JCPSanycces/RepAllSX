Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB

adxirs = SAVIRS
adxifs = SAVIFS

## Plan valide

If TRANS
 Update [ADW] Where CMP="*" & FCY=[L]LEGPLAN & PARAM="PLANMS" With VALEUR="0"
Else
 Trbegin [ADW]
  Update [ADW] Where CMP="*" & FCY=[L]LEGPLAN & PARAM="PLANMS" With VALEUR="0"
 Commit
Endif
If APPLI=nomap
 GPLANMSOK(ILEG) = 0
 GPRFRUB = ""
Endif
Call TEMPOFF From GESECRAN
If TEMPON
 Call TEMPON("O") From GESECRAN
Endif
End


##############################################################################
## Génération des WPMS*PLAN* : Plan de paie
##############################################################################

##################################
$ECRIT_CALRUB
FLIF = 0

If [F:RUB]ROW <= 15000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB1("+num$([F:RUB]ROW)+")=1)"
Elsif[F:RUB]ROW <= 30000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB2("+num$([F:RUB]ROW-15000)+")=1)"
Elsif[F:RUB]ROW <= 45000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB3("+num$([F:RUB]ROW-30000)+")=1)"
Elsif[F:RUB]ROW <= 60000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB4("+num$([F:RUB]ROW-45000)+")=1)"
Elsif[F:RUB]ROW <= 75000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB5("+num$([F:RUB]ROW-60000)+")=1)"
Elsif[F:RUB]ROW <= 90000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB6("+num$([F:RUB]ROW-75000)+")=1)"
Elsif[F:RUB]ROW < 100000
 Wrseq space$(SPA);"OKRUB  = (GPRFTAB7("+num$([F:RUB]ROW-90000)+")=1)"
Endif

For [ECD]ECD0 Where LEG=LEGPLAN and RUB=[F:RUB]COD
 Read [ECH]ECH0 = LEGPLAN;[F:ECD]COD
 If [F:ECD]CCL=2
  Wrseq space$(SPA);"If !OKRUB";
 Else
  Wrseq space$(SPA);"If OKRUB";
 Endif
 If [F:ECD]DATSTR<>[0/0/0]
  Wrseq " & DATPAY>=["+format$(GFMD,[F:ECD]DATSTR)+"]";
 Endif
 If [F:ECD]DATEND<>[0/0/0]
  Wrseq " & DATPAY<=["+format$(GFMD,[F:ECD]DATEND)+"]";
 Endif
 Wrseq " : # Exception"-[F:ECH]COD
 SPA += 1

 # (C) PROSPER 19/07/10 - Exception sur contrat
 # P06 / 66101

 If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
   Wrseq space$(SPA);'Read [F:ECH]ECH0 = "' + LEGPLAN + '";"' + [F:ECH]COD + '"'
 Endif

 Gosub EXCEPTION
 If FLCRIT : SPA += 1 : Endif
 If [F:ECH]POP<>""
  Wrseq space$(SPA);'Read [HRPOA]POA0 = "';[F:ECH]POP;'";MATRI'
  Wrseq space$(SPA);'If !fstat'
  SPA += 1
 Endif
 If [F:ECD]CCL=2
  Wrseq space$(SPA);"OKRUB = 1"
 Else
  Wrseq space$(SPA);"OKRUB = 0"
 Endif
 If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
 If FLCRIT : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
 SPA -= 1
 Wrseq space$(SPA);"Endif"
Next

If [F:RUB]VLYSTR<>[0/0/0]
 Wrseq space$(SPA);"OKRUB *= (DATDEB>=["+format$(GFMD,[F:RUB]VLYSTR)+"])"
Endif
If [F:RUB]VLYEND<>[0/0/0]
 Wrseq space$(SPA);"OKRUB *= (DATFIN<=["+format$(GFMD,[F:RUB]VLYEND)+"])"
Endif
For I=1 To dim([F:RUB]CNDCAL)
 If [F:RUB]CNDCAL(I-1)<>""
  Call CONVERT([F:RUB]CNDCAL(I-1))
  Wrseq space$(SPA);"OKRUB *= (";vireblc(format$("KT:250X",[F:RUB]CNDCAL(I-1)),2);")"
 Endif
Next I
Wrseq space$(SPA);"If OKRUB"
SPA += 1 : FLIF = 1
Case [F:RUB]TYPRUB
  When 1 : # Montant=base

   If [F:RUB]BAS<>""
    Call CONVERT([F:RUB]BAS)
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]BAS),2);
    If [F:RUB]DEC=0
     Wrseq ",";num$(ARO);")"
    Else
     Wrseq ",";num$([F:RUB]DEC);")"
    Endif
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = 0"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = '+PRUB+[F:RUB]COD
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"


  When 2 : # Montant=base*taux
   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   #45948
   Wrseq space$(SPA);'TYP  = 1'
   # fin 45948
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   #45948
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS

   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   # fin 45948

  When 3 : # Montant=base*taux/100

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   #45948 Bis
   Wrseq space$(SPA);'TYP  = 1'
   # fin 45948 Bis
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   #45948 bis
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS

   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   # fin 45948 Bis

  When 4 : # Intervalle
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   For I=1 To [F:RUB]ITVNBR
    Wrseq space$(SPA);
    If I=1 : Wrseq "If "; : Else : Wrseq "Elsif "; : Endif
    ## 22693
    If num$([F:RUB]ITVLIM(I))=num$(val(num$([F:RUB]ITVLIM(I))))
     Wrseq "BASE<";num$([F:RUB]ITVLIM(I))
    Elsif num$([F:RUB]ITVLIM(I))=""
     Wrseq "BASE<";num$(0)
    Else
     Wrseq "BASE<V_";num$([F:RUB]ITVLIM(I))
    Endif
    If [F:RUB]ITVAMT(I-1)<>""
     Call CONVERT([F:RUB]ITVAMT(I-1))
     If [F:RUB]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT(I-1)),2);",";num$(ARO);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT(I-1)),2);",";num$([F:RUB]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = 0"
    Endif
   Next I
   If [F:RUB]ITVNBR>0
    Wrseq space$(SPA);"Else"
    #44900
    #If [F:RUB]ITVAMT([F:RUB]ITVNBR-1)<>""
    If [F:RUB]ITVNBR>1 & [F:RUB]ITVAMT([F:RUB]ITVNBR-1)<>""
     Call CONVERT([F:RUB]ITVAMT([F:RUB]ITVNBR-1-1))
     If [F:RUB]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT([F:RUB]ITVNBR-1)),2);",";num$(ARO);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = arr(";vireblc(format$("KT:250X",[F:RUB]ITVAMT([F:RUB]ITVNBR-1)),2);",";num$([F:RUB]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUB]COD;" = 0"
    Endif
    Wrseq space$(SPA);"Endif"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2 or find(5,[F:RUB]OPTCUM(0..[F:RUB]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 5 : # Assiette

   Gosub DEBEXO
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If NEXO2
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+" = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOS"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+" = BASE-PEXOS"
    Wrseq space$(SPA);"Endif"
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+"(2) = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOP"
    Wrseq space$(SPA);" "+PRUB+[F:RUB]COD+"(2) = BASE-PEXOP"
    Wrseq space$(SPA);"Endif"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD+" = BASE"
    Wrseq space$(SPA);PRUB+[F:RUB]COD+"(2) = BASE"
   Endif
   If [F:RUB]CUMBAS<>""
    Wrseq space$(SPA);PCUM+[F:RUB]CUMBAS+" += BASE"
   Endif
   If [F:RUB]REG<>2
    Wrseq space$(SPA);"SOMTR = 0"
   Endif
   OK = 0
   For K=0 To dim([F:RUB]AMTMAX)-1
    If [F:RUB]AMTMAX(K)<>""
     OK = 1
     Call CONVERT([F:RUB]AMTMAX(K))
     Wrseq space$(SPA);"PLAFOND = ";vireblc(format$("KT:250X",[F:RUB]AMTMAX(K)),2)
     If [F:RUB]REG=2
      #Tax band
      #Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),";PCUM;[F:RUB]CUMMAX(K);"(1)+PLAFOND)";
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),";PCUM;[F:RUB]CUMMAX(K);"(1)+PLAFOND)"
      For J=0 To K
       If [F:RUB]CUMAMT(J)<>""
        #Tax band
        #Wrseq " - ";PCUM;[F:RUB]CUMAMT(J);
        Wrseq space$(SPA);"TRANCHE -= ";PCUM;[F:RUB]CUMAMT(J)
       Endif
      Next J
      Wrseq
     Else
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),PLAFOND)-SOMTR : SOMTR += TRANCHE"
     Endif
     If [F:RUB]DEC=0
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$(ARO);")"
     Else
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$([F:RUB]DEC);")"
     Endif
     Wrseq space$(SPA);'MEM    = 1'
     Wrseq space$(SPA);'RANG   = '+num$([F:RUB]ROW)
     Wrseq space$(SPA);'TAUX   = PLAFOND'
     Wrseq space$(SPA);'MONT   = TRANCHE'
     #Tax Band
     #Wrseq space$(SPA);'[L]TYP = '+num$(K+3)
     If K<3
      Wrseq space$(SPA);'[L]TYP = '+num$(K+3)
     Else
      Wrseq space$(SPA);'[L]TYP = '+num$(K+7)
     Endif
     Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
     Wrseq space$(SPA);"If GOK<1 : Return : Endif"
###########################################"
     Gosub FINEXO
     If FLIF
      SPA -= 1
      Wrseq space$(SPA);"Endif"
     Endif
     Gosub ENTREEPAS
     Gosub DEBEXO
##################################################################################

     If [F:RUB]CUMMAX(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUB]CUMMAX(K);" += PLAFOND"
     Endif
     If [F:RUB]CUMAMT(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUB]CUMAMT(K);" += TRANCHE"
     Endif
     If NEXO2
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOS"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUB]COD;" = TRANCHE-PEXOS : PEXOS = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOS -= TRANCHE"
      Wrseq space$(SPA);"Endif"
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOP"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUB]COD;" = TRANCHE-PEXOP : PEXOP = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOP -= TRANCHE"
      Wrseq space$(SPA);"Endif"
     Else
      Wrseq space$(SPA);PTRS(K);[F:RUB]COD;" = TRANCHE"
      Wrseq space$(SPA);PTRP(K);[F:RUB]COD;" = TRANCHE"
     Endif
    Endif
   Next I
   If !OK
    Wrseq space$(SPA);'MEM     = 1'
    Wrseq space$(SPA);'RANG    = '+num$([F:RUB]ROW)
    #Tax Band
    #Wrseq space$(SPA);'[L]TYP  = 3'
    Wrseq space$(SPA);'[L]TYP  = dim([F:RUB]AMTMAX)'
    Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
    Wrseq space$(SPA);"If GOK<1 : Raz BASE : Return : Endif"
   Endif
   Wrseq space$(SPA);"Raz BASE"  : # car BASE non RAZ dans $MEMRUB quand Assiette
   Gosub FINEXO

  When 6 : # Cotisation
   Gosub DEBEXO
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUB]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOS<>0 : BASE = max(0,BASE-PEXOS) : Endif"
    # 53756
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOS<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOS/100)"
   Endif
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;" = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD
   If [F:RUB]TMPCAL<>2
    If [F:RUB]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

###########################################"
   Gosub FINEXO

   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS
   Gosub DEBEXO
##################################################################################

   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUB]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOP<>0 : BASE = max(0,BASE-PEXOP) : Endif"
    # 53756
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOP<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOP/100)"
   Endif
   If [F:RUB]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUB]COD;"(2) = arr(BASE*TAUX/100,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUB]COD+'(2)'
   If [F:RUB]TMPCAL<>2
    If [F:RUB]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub FINEXO


  When 7 : # Grille

   Wrseq space$(SPA);'GRILLE = "';[F:RUB]TBLCOD;'"'
   Wrseq space$(SPA);'GRICOL = ';num$([F:RUB]TBLCOL)
   Wrseq space$(SPA);"Raz GRICLE"
   For I=0 To 2
    If [F:RUB]TBLFRM(I)<>""
     Wrseq space$(SPA);"GRICLE(";num$(I);") = num$(";vireblc(format$("KT:250X",[F:RUB]TBLFRM(I)),2);")"
    Endif
   Next I
   Wrseq space$(SPA);"Gosub GRILLE From GPLAN"
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUB]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
  When 8 : # Historique

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"DATED = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"DATED = [0/0/0]"
   Endif
   If [F:RUB]RAT2<>""
    Wrseq space$(SPA);"DATEF = ";
    Gosub WR_RAT2
    Wrseq space$(SPA);"If DATEF>=DATPAY : DATEF = DATPAY-1 : Endif"
   Else
    Wrseq space$(SPA);"DATEF = DATPAY-1"
   Endif
   Call HISTO(SPA)
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUB]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 9 : # Spécifique

   If [F:RUB]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_RAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUB]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_BAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   #65041
   Wrseq space$(SPA);PBAS+[F:RUB]COD;' = BASE'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB]ROW)
   Wrseq space$(SPA);'If STDPLAN : ACTION = "CALRUB" : Gosub ACTION From STDPLAN : Endif'
   Wrseq space$(SPA);'If SPEPLAN : ACTION = "CALRUB" : Gosub ACTION From SPEPLAN : Endif'
   If [F:RUB]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUB]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUB]COD;' = MONT'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"


  When 10 : # Régularisation

   Wrseq space$(SPA);'K = find("';[F:RUB]RGL;'",REGRUB1(1..NBREGUL))'
   Wrseq space$(SPA);'OKRUB *= (K<>0) & REGUL=0'
   Wrseq space$(SPA);"If OKRUB"
   SPA += 1
   Read [RGL]RGL0  = [F:RUB]LEG;[F:RUB]RGL
   Read [RUB2]RUB0 = [F:RGL]LEG;[F:RGL]RUB
   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL1(K)"
   Wrseq space$(SPA);"TYP  = 7"
   Wrseq space$(SPA);PRUB+[F:RUB]COD;'(1) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   SPA -=1
   Wrseq space$(SPA);'Endif'
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS

   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL2(K)"
   Wrseq space$(SPA);"TYP  = 8"
   Wrseq space$(SPA);PRUB+[F:RUB]COD;'(2) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

Endcase

## Cumuls
############################################################################
If [F:RUB]NBRCUM<>0
 If FLIF
  SPA -= 1
  Wrseq space$(SPA);"Endif"
 Endif
 Gosub ENTREEPAS
Endif
###########################################################################
For I=0 To [F:RUB]NBRCUM-1
 #91750
   If [F:RUH]CNDCUM(I)<>""
    Call CONVERT([F:RUH]CNDCUM(I))
    Wrseq space$(SPA);"OKCUM = (";vireblc(format$("KT:250X",[F:RUH]CNDCUM(I)),2);")"
    Wrseq space$(SPA);"If OKCUM"
    SPA +=1
   Endif
   #
   Case [F:RUB]OPTCUM(I)
    When 1 : # -PS
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" -= ";PRUB;[F:RUB]COD
    When 2 : # -PP
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" -= ";PRUB;[F:RUB]COD;"(2)"
    When 3 : # +PS
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" += ";PRUB;[F:RUB]COD
    When 4 : # +PP
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" += ";PRUB;[F:RUB]COD;"(2)"
    When 5 : # RAZ
     Wrseq space$(SPA);PCUM;[F:RUB]CUM(I);" = 0"
   Endcase
   #91750
   If [F:RUH]CNDCUM(I)<>""
    SPA -=1
    Wrseq space$(SPA);"Endif"
   Endif
   #
Next I
If FLIF
 SPA -= 1
 Wrseq space$(SPA);"Endif"
Endif
Return

$WR_BAS
Call CONVERT([F:RUB]BAS)
Wrseq vireblc(format$("KT:250X",[F:RUB]BAS),2)
Return

$WR_RAT1
Call CONVERT([F:RUB]RAT1)
Wrseq vireblc(format$("KT:250X",[F:RUB]RAT1),2)
Return

$WR_RAT2
Call CONVERT([F:RUB]RAT2)
Wrseq vireblc(format$("KT:250X",[F:RUB]RAT2),2)
Return

$ENTREEPAS
Wrseq
Wrseq "## Suite Rubrique ";[F:RUB]COD
Wrseq
Wrseq space$(SPA);"If OKRUB"
SPA += 1 : FLIF = 1
Return

$ENTREEPAS2
Wrseq
Wrseq "## Suite Rubrique ";[F:RUH]LEG;" ";[F:RUH]COD
Wrseq
Wrseq space$(SPA);"If OKRUB"
SPA += 1 : FLIF = 1
Return

#### Exonérations
$DEBEXO
NEXO1 = 0
NEXO2 = 0
FLIF2 = 0
For [EXO]EXO1 Where LEG=[L]LEGPLAN & RUBCOD=[F:RUB]COD
 If [F:EXO]FLG=2
  NEXO2 += 1
  Wrseq space$(SPA);'CEXO('+num$(NEXO2)+') = "'+[F:EXO]COD+'"'
  Wrseq space$(SPA);'TEXO1('+num$(NEXO2)+') = '+num$([F:EXO]RAT1);
  If [F:EXO]RAT1=100 & [F:EXO]MAX1<>""
   Wrseq space$(SPA);' : PEXO1('+num$(NEXO2)+') = max(0,'+PRUB+[F:EXO]MAX1+')'
  Else
   Wrseq
  Endif
  Wrseq space$(SPA);'TEXO2('+num$(NEXO2)+') = '+num$([F:EXO]RAT2);
  If [F:EXO]RAT2=100 & [F:EXO]MAX2<>""
   Wrseq space$(SPA);' : PEXO2('+num$(NEXO2)+') = max(0,'+PRUB+[F:EXO]MAX2+')'
  Else
   Wrseq
  Endif
  CEXO2(NEXO2) = [F:EXO]COD
 Else
  NEXO1 += 1
  CEXO1(NEXO1) = [F:EXO]COD
 Endif
Next
If NEXO1 or NEXO2
 Wrseq space$(SPA);"OK = 1"
Endif
If NEXO1
 For J=1 To 4
  Wrseq space$(SPA);' If [F:HRCTR]EXOCOD'+num$(J)+'<>"" & find([F:HRCTR]EXOCOD'+num$(J);
  For I=1 To NEXO1
   Wrseq ',"'+CEXO1(I)+'"';
  Next I
  Wrseq ')'
  Wrseq "&  & ([F:HRCTR]EXOSTR"+num$(J)+"=[0/0/0] | DATPAY>=[F:HRCTR]EXOSTR"+num$(J)+")"
  Wrseq "&  & ([F:HRCTR]EXOEND"+num$(J)+"=[0/0/0] | DATPAY<=[F:HRCTR]EXOEND"+num$(J)+")"
  Wrseq space$(SPA);"  OK = 0"
  Wrseq space$(SPA);" Endif"
 Next J
Endif
If NEXO2
 Wrseq space$(SPA);'NEXO = '+num$(NEXO2)
 Wrseq space$(SPA);'Gosub TSTEXO From GPLAN'
Endif
If NEXO1 or NEXO2
 Wrseq space$(SPA);"If OK"
 SPA += 1 : FLIF2 = 1
Endif
Return

$FINEXO
If FLIF2
 SPA -= 1
 Wrseq space$(SPA);"Endif"
Endif
Return

$OUVRE
NBPLAN += 1
PROG = "WPMS"+[L]LEGPLAN+"PLAN"+num$(NBPLAN)
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
Wrseq "$PLAN"
Return

$FERME
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

Subprog ADDCRIT(CRITERE,SUBCRIT)
Variable Char CRITERE
Value    Char SUBCRIT
If CRITERE<>""
 CRITERE -= "&"-SUBCRIT
Else
 CRITERE = SUBCRIT
Endif
End

#############################################################################################
Subprog SETPAR
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Local Integer ILEG
Local Char LEGPLAN (GLONADI)
[L]LEGPLAN=GCURLEG
ILEG=find([L]LEGPLAN,GDOSLEG(1..GNBLEG))
Local Integer VALPAR
VALPAR = 1
Call DEBTRANS From GLOCK
Gosub TR_PAR
GPLANMSOK(ILEG) = VALPAR
End

$TR_PAR
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "*";[L]LEGPLAN;"PLANMS"
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL PLANMS" : Goto ROLL_PAR
 Elsif fstat
  Raz [F:ADW]
  [F:ADW]CMP = "*"
  [F:ADW]FCY = [L]LEGPLAN
  [F:ADW]PARAM = "PLANMS"
  [F:ADW]VALEUR = num$(VALPAR)
  Write [ADW]
 Elsif [F:ADW]VALEUR<>num$(VALPAR)
  [F:ADW]VALEUR = num$(VALPAR)
  Rewrite [ADW]
#MIPEA - 2018-03-15- US X3-81875- START
  If dim(GACTX)>=0
    Local Integer WIND_RESULT
    WIND_RESULT= fmet GACTX.APARAM._ACLEAN
  Endif
#MIPEA - 2018-03-15- US X3-81875- END
 Endif
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_PAR
 Endif
Commit
Return

$AB_PAR
Rollback
Return

$ROLL_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif

#############################################################################################

$EXCEPTION
FLCRIT = 0
If [F:ECH]FCY<>""
 Gosub EXCEPT
 Wrseq 'SITE="'+[F:ECH]FCY+'"'
Endif
If [F:ECH]PRF<>""
 Gosub EXCEPT
 Wrseq 'PROFIL="'+[F:ECH]PRF+'"'
Endif
If [F:ECH]SRV<>""
 Gosub EXCEPT
 Wrseq 'SERVICE="'+[F:ECH]SRV+'"'
Endif
If [F:ECH]EMPSTR<>""
 Gosub EXCEPT
 Wrseq 'MATRI>="'+[F:ECH]EMPSTR+'"'
Endif
If [F:ECH]EMPEND<>""
 Gosub EXCEPT
 Wrseq 'MATRI<="'+[F:ECH]EMPEND+'"'
Endif
If [F:ECH]CRI<>""
 Gosub EXCEPT
 Wrseq "(";vireblc(format$("KT:250X",[F:ECH]CRI),2);")"
Endif

# (C) PROSPER 19/07/10 - Ajout d'une liste de contrat dans les exceptions
# P06 / 66101

If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
    Gosub EXCEPT
    Wrseq 'find([F:HRCTR]REFNUM+"~"+[F:HRCTR]CTRNUM, [F:ECH]CTRCRI)'
Endif

Return

$EXCEPT
If FLCRIT
 Wrseq "&";space$(SPA);"& ";
Else
 Wrseq space$(SPA);"If ";
 FLCRIT = 1
Endif
Return

#Tax band
Subprog CONVERT(FORMULE)
Variable Char FORMULE()
Local Integer I , J , T , OK
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 1
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  If find(OP,"R_","C_") & mid$(FORMULE,I+1,1)<>"("
   FORMULE = left$(FORMULE,I)+"(1)"+right$(FORMULE,I+1)
   I += 3
  Endif
  I += 1
 Else
  I += 1
 Endif
Wend
End

Subprog HISTO(SPA)
Value Integer SPA
Local Integer I , J , K
Local Char    FORMULE(250) , EXPRESS(250)
Local Char    OPE(2) , CODE(20)
FORMULE = vireblc(format$("KT:250X",[F:RUB]BAS),2)
I = 1
EXPRESS = ""
K = 0
While I<=len(FORMULE)
 OPE = mid$(FORMULE,I,2)
 If find(OPE,"R_","V_","C_")
  J = I+2 : I += 2
#  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_()",mid$(FORMULE,I+1,1))
  #63718 : ajout recherche des caractères () - 65289 : ajout ) seulement si ( deux positions avant
  While I<len(FORMULE) & (instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_(",mid$(FORMULE,I+1,1))
&                      | (instr(1,")",mid$(FORMULE,I+1,1)) & instr(1,"(",mid$(FORMULE,I-1,1)) ))

   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Wrseq space$(SPA);'RUBHIS = "';CODE;'"'
  Case OPE
   When "R_"
    Wrseq space$(SPA);"Gosub HISTORUB From GPLAN"
    #63718 : Pour la PP
    If mid$ (CODE,len(CODE)-2,3)='(2)' : K+=1 : Endif
   When "C_"
    Wrseq space$(SPA);"Gosub HISTOCUM From GPLAN"
   When "V_"
    Wrseq space$(SPA);"Gosub HISTOVAR From GPLAN"
  Endcase
  K += 1
  Wrseq space$(SPA);"HVAR("+num$(K)+") = MONT"
  EXPRESS += "HVAR("+num$(K)+")"
 Else
  EXPRESS += mid$(FORMULE,I,1)
 Endif
 I += 1
Wend
Wrseq space$(SPA);"MONT = ";EXPRESS
End

#64879
Subprog HISTOMS(SPA)
Value Integer SPA
Local Integer I , J , K
Local Char    FORMULE(250) , EXPRESS(250)
Local Char    OPE(2) , CODE(20)
FORMULE = vireblc(format$("KT:250X",[F:RUB]BAS),2)
I = 1
EXPRESS = ""
K = 0
While I<=len(FORMULE)
 OPE = mid$(FORMULE,I,2)
 If find(OPE,"R_","V_","C_")
  J = I+2 : I += 2
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Wrseq space$(SPA);'RUBHIS = "';CODE;'"'
  Case OPE
   When "R_"
    Wrseq space$(SPA);"Gosub HISTORUB From GPLAN"
   When "C_"
    Wrseq space$(SPA);"Gosub HISTOCUM From GPLAN"
   When "V_"
    Wrseq space$(SPA);"Gosub HISTOVAR From GPLAN"
  Endcase
  K += 1
  Wrseq space$(SPA);"HVAR("+num$(K)+") = MONT"
  EXPRESS += "HVAR("+num$(K)+")"
 Else
  EXPRESS += mid$(FORMULE,I,1)
 Endif
 I += 1
Wend
Wrseq space$(SPA);"MONT = ";EXPRESS
End

###########################################################################################################################
# MASSE SALARIALE
###########################################################################################################################

##################################
## Effacement plan de paye MS
##################################
$EFFMSR
For [F:RUH]RUH0
 Call EFFACE_ADX("",nomap,"WPMSRUH"+[F:RUH]LEG+[F:RUH]COD,STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMSRUH"+[F:RUH]LEG+[F:RUH]COD,"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMSRUH"+[F:RUH]LEG+[F:RUH]COD,"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMSRUH"+[F:RUH]LEG+[F:RUH]COD,"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next

Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLAN",STAT) From ORDSYS
If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN","src",0),0)>=0
 Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN","src",0),STAT) From ORDSYS
 Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN","adx",0),STAT) From ORDSYS
Endif

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLAN"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLAN"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

For I=0 To 500
 Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

For I=1 To 500
 Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

For I=1 To 3
 Call EFFACE_ADX("",nomap,"WPMS"+[L]LEGPLAN+"PLANCUM"+num$(I),STAT) From ORDSYS
 If filinfo(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANCUM"+num$(I),"src",0),0)>=0
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANCUM"+num$(I),"src",0),STAT) From ORDSYS
  Call EFFACE(filpath("TRT","WPMS"+[L]LEGPLAN+"PLANCUM"+num$(I),"adx",0),STAT) From ORDSYS
 Else
  Break
 Endif
Next I

Return

##################################################################################
## Rubriques historisées
##################################################################################

##################################
## Evaluation des rubriques historisées
##################################
$CALRUH
#61289
#Filter [RUH] Order By Key CLE = COD Asc;DAT Desc
#Filter [RUH] Order By Key CLE = COD Asc;DAT Asc
#For [RUH]CLE (1)
For [RUH]RUH0 (2)
 NBRUB = 0
# NBPLAN = 0 - WGA 15/07/2009
 Gosub OUVRUH
 #For [RUH]CLE
 For [RUH]RUH0
  SPA = 0
  Gosub TAB_RUHPRF
  Gosub ECRIT_CALRUH
 Next
 Gosub FERME
Next
Filter [RUH]
Return

##################################
$OUVRUH
#NBPLAN += 1 - WGA 15/07/2009
PROG = "WPMSRUH"+[F:RUH]LEG+[F:RUH]COD
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(55,10702,1)-[F:RUH]LEG-[F:RUH]COD    :# Rubrique XXX
Wrseq "$CALRUH"
#61289
Wrseq "OKRMP = 0"
Return

##################################
$WR_HBAS
Call CONVERT([F:RUH]BAS)
Wrseq vireblc(format$("KT:250X",[F:RUH]BAS),2)
Return

##################################
$WR_HRAT1
Call CONVERT([F:RUH]RAT1)
Wrseq vireblc(format$("KT:250X",[F:RUH]RAT1),2)
Return

##################################
$WR_HRAT2
Call CONVERT([F:RUH]RAT2)
Wrseq vireblc(format$("KT:250X",[F:RUH]RAT2),2)
Return

##################################
$TAB_RUHPRF
Raz RUHPRF
NBRPRF=0
For [CRH]CRH0 Where COD=[F:RUH]COD & DAT=[F:RUH]DAT & LEG=[F:RUH]LEG
 RUHPRF(NBRPRF)=[F:CRH]PRFCOD
 NBRPRF+=1
Next
Return

##################################
$ECRIT_CALRUH
OKRUB = 1
If [F:RUH]CODACT<>""
 Read [ACV]CODACT = [F:RUH]CODACT
 If fstat or [F:ACV]FLACT<>2
  OKRUB = 0
 Endif
Endif
If OKRUB
 NBRUB += 1
 If NBRUB>MAXRUB
  Gosub FERME
  NBRUB = 1
  Gosub OUVRUH
 Endif
 Wrseq
 Wrseq "## Rubrique historisée"-[F:RUH]LEG-[F:RUH]COD
 Wrseq
 Wrseq "If DATREF<=["+format$(GFMD,[F:RUH]DAT)+"]"
 SPA +=1
 Wrseq space$(SPA);'RUB = "'+[F:RUH]COD+'"'
 #57410
 #If [F:RUH]CUMNUM>1 & RAZCUMRUB([F:RUH]CUMNUM)<>len(mess(0,334,1))
 # Wrseq space$(SPA);'CUMNUM = ';num$([F:RUH]CUMNUM-1)
 #Endif
 # fin 57410
 FLIF = 0

 #Profil à tester
 #61289
 #Wrseq space$(SPA);"OKRUB *= (find(PROFIL, RUHPRF(0..NBRPRF-1)))"
 Wrseq space$(SPA);"OKRUB *= (find(PROFIL";
 If NBRPRF=0
  Wrseq ",''";
 Else
  For I=0 To NBRPRF-1
   Wrseq ",'"+RUHPRF(I)+"'";
  Next
 Endif
 Wrseq "))"
 # fin 61289

 For [ECD]ECD0 Where LEG=LEGPLAN and RUB=[F:RUH]COD
  Read [ECH]ECH0 = LEGPLAN;[F:ECD]COD
  If [F:ECD]CCL=2
   Wrseq space$(SPA);"If !OKRUB";
  Else
   Wrseq space$(SPA);"If OKRUB";
  Endif
  If [F:ECD]DATSTR<>[0/0/0]
   Wrseq " & DATREF>=["+format$(GFMD,[F:ECD]DATSTR)+"]";
  Endif
  If [F:ECD]DATEND<>[0/0/0]
   Wrseq " & DATREF<=["+format$(GFMD,[F:ECD]DATEND)+"]";
  Endif
  Wrseq " : # Exception"-[F:ECH]COD
  SPA += 1
  Gosub EXCEPTION
  If FLCRIT : SPA += 1 : Endif
  If [F:ECH]POP<>""
   Wrseq space$(SPA);'Read [HRPOA]POA0 = "';[F:ECH]POP;'";MATRI'
   Wrseq space$(SPA);'If !fstat'
   SPA += 1
  Endif
  If [F:ECD]CCL=2
   Wrseq space$(SPA);"OKRUB = 1"
  Else
   Wrseq space$(SPA);"OKRUB = 0"
  Endif
  If [F:ECH]POP<>"" : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  If FLCRIT : SPA -= 1 : Wrseq space$(SPA);"Endif" : Endif
  SPA -= 1
  Wrseq space$(SPA);"Endif"
 Next

 If [F:RUH]VLYSTR<>[0/0/0]
  Wrseq space$(SPA);"OKRUB *= (DATDEB>=["+format$(GFMD,[F:RUH]VLYSTR)+"])"
 Endif
 If [F:RUH]VLYEND<>[0/0/0]
  Wrseq space$(SPA);"OKRUB *= (DATFIN<=["+format$(GFMD,[F:RUH]VLYEND)+"])"
 Endif
 For I=1 To dim([F:RUH]CNDCAL)
  If [F:RUH]CNDCAL(I-1)<>""
   Call CONVERT([F:RUH]CNDCAL(I-1))
   Wrseq space$(SPA);"OKRUB *= (";vireblc(format$("KT:250X",[F:RUH]CNDCAL(I-1)),2);")"
  Endif
 Next I
 Wrseq space$(SPA);"If OKRUB"
 SPA += 1 : FLIF = 1

 Case [F:RUH]TYPRUB
  When 1 : # Montant=base
   If [F:RUH]BAS<>""
    Call CONVERT([F:RUH]BAS)
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(";vireblc(format$("KT:250X",[F:RUH]BAS),2);
    If [F:RUH]DEC=0
     Wrseq ",";num$(ARO);")"
    Else
     Wrseq ",";num$([F:RUH]DEC);")"
    Endif
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = 0"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'BASE = '+PRUB+[F:RUH]COD
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD
   If [F:RUH]TMPCAL<>2 or find(5,[F:RUH]OPTCUM(0..[F:RUH]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 2 : # Montant=base*taux
   If [F:RUH]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:RUH]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD
   If [F:RUH]TMPCAL<>2 or find(5,[F:RUH]OPTCUM(0..[F:RUH]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS2

   If [F:RUH]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:RUH]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUH]COD;"(2) = arr(BASE*TAUX,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;"(2) = arr(BASE*TAUX,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD+'(2)'
   If [F:RUH]TMPCAL<>2 or find(5,[F:RUH]OPTCUM(0..[F:RUH]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 3 : # Montant=base*taux/100
   If [F:RUH]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:RUH]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX/100,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD
   If [F:RUH]TMPCAL<>2 or find(5,[F:RUH]OPTCUM(0..[F:RUH]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 4 : # Intervalle
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   For I=1 To [F:RUH]ITVNBR
    Wrseq space$(SPA);
    If I=1 : Wrseq "If "; : Else : Wrseq "Elsif "; : Endif
    ## 22693
    If num$([F:RUH]ITVLIM(I))=num$(val(num$([F:RUH]ITVLIM(I))))
     Wrseq "BASE<";num$([F:RUH]ITVLIM(I))
    Elsif num$([F:RUH]ITVLIM(I))=""
     Wrseq "BASE<";num$(0)
    Else
     Wrseq "BASE<V_";num$([F:RUH]ITVLIM(I))
    Endif
    If [F:RUH]ITVAMT(I-1)<>""
     Call CONVERT([F:RUH]ITVAMT(I-1))
     If [F:RUH]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = arr(";vireblc(format$("KT:250X",[F:RUH]ITVAMT(I-1)),2);",";num$(ARO);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = arr(";vireblc(format$("KT:250X",[F:RUH]ITVAMT(I-1)),2);",";num$([F:RUH]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = 0"
    Endif
   Next I
   If [F:RUH]ITVNBR>0
    Wrseq space$(SPA);"Else"
    If [F:RUH]ITVNBR>1 & [F:RUH]ITVAMT([F:RUH]ITVNBR-1)<>""
     Call CONVERT([F:RUH]ITVAMT([F:RUH]ITVNBR-1-1))
     If [F:RUH]DEC=0
      Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = arr(";vireblc(format$("KT:250X",[F:RUH]ITVAMT([F:RUH]ITVNBR-1)),2);",";num$(ARO);")"
     Else
      Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = arr(";vireblc(format$("KT:250X",[F:RUH]ITVAMT([F:RUH]ITVNBR-1)),2);",";num$([F:RUH]DEC);")"
     Endif
    Else
     Wrseq space$(SPA+1);PRUB+[F:RUH]COD;" = 0"
    Endif
    Wrseq space$(SPA);"Endif"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD
   If [F:RUH]TMPCAL<>2 or find(5,[F:RUH]OPTCUM(0..[F:RUH]NBRCUM-1))
    Wrseq space$(SPA);'MEM  = (MONT<>0)'
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 5 : # Assiette
   Gosub DEBEXO
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUH]COD+" = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOS"
    Wrseq space$(SPA);" "+PRUB+[F:RUH]COD+" = BASE-PEXOS"
    Wrseq space$(SPA);"Endif"
    Wrseq space$(SPA);"If BASE<0"
    Wrseq space$(SPA);" "+PRUB+[F:RUH]COD+"(2) = BASE"
    Wrseq space$(SPA);"Elsif BASE>PEXOP"
    Wrseq space$(SPA);" "+PRUB+[F:RUH]COD+"(2) = BASE-PEXOP"
    Wrseq space$(SPA);"Endif"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD+" = BASE"
    Wrseq space$(SPA);PRUB+[F:RUH]COD+"(2) = BASE"
   Endif
   If [F:RUH]CUMBAS<>""
    Wrseq space$(SPA);PCUM+[F:RUH]CUMBAS+" += BASE"
   Endif
   If [F:RUH]REG<>2
    Wrseq space$(SPA);"SOMTR = 0"
   Endif
   OK = 0
   For K=0 To dim([F:RUH]AMTMAX)-1
    If [F:RUH]AMTMAX(K)<>""
     OK = 1
     Call CONVERT([F:RUH]AMTMAX(K))
     Wrseq space$(SPA);"PLAFOND = ";vireblc(format$("KT:250X",[F:RUH]AMTMAX(K)),2)
     If [F:RUH]REG=2
      #Tax band
      #Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),";PCUM;[F:RUB]CUMMAX(K);"(1)+PLAFOND)";
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUB]CUMBAS;"(1),";PCUM;[F:RUB]CUMMAX(K);"(1)+PLAFOND)"
      For J=0 To K
       If [F:RUH]CUMAMT(J)<>""
        #Tax band
        #Wrseq " - ";PCUM;[F:RUB]CUMAMT(J);
        Wrseq space$(SPA);"TRANCHE -= ";PCUM;[F:RUB]CUMAMT(J)
       Endif
      Next J
      Wrseq
     Else
      Wrseq space$(SPA);"TRANCHE = min(";PCUM;[F:RUH]CUMBAS;"(1),PLAFOND)-SOMTR : SOMTR += TRANCHE"
     Endif
     If [F:RUH]DEC=0
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$(ARO);")"
     Else
      Wrseq space$(SPA);"TRANCHE = arr(TRANCHE,";num$([F:RUH]DEC);")"
     Endif
     Wrseq space$(SPA);'MEM    = 1'
     Wrseq space$(SPA);'RANG   = '+num$([F:RUH]ROW)
     Wrseq space$(SPA);'TAUX   = PLAFOND'
     Wrseq space$(SPA);'MONT   = TRANCHE'
     #Tax Band
     #Wrseq space$(SPA);'[L]TYP = '+num$(K+3)
     If K<3
      Wrseq space$(SPA);'[L]TYP = '+num$(K+3)
     Else
      Wrseq space$(SPA);'[L]TYP = '+num$(K+7)
     Endif
     Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
     Wrseq space$(SPA);"If GOK<1 : Return : Endif"
###########################################"
     Gosub FINEXO
     If FLIF
      SPA -= 1
      Wrseq space$(SPA);"Endif"
     Endif
     Gosub ENTREEPAS2
     Gosub DEBEXO
##################################################################################
     If [F:RUH]CUMMAX(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUH]CUMMAX(K);" += PLAFOND"
     Endif
     If [F:RUH]CUMAMT(K)<>""
      Wrseq space$(SPA);PCUM;[F:RUH]CUMAMT(K);" += TRANCHE"
     Endif
     If NEXO2
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUH]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOS"
      Wrseq space$(SPA);" ";PTRS(K);[F:RUH]COD;" = TRANCHE-PEXOS : PEXOS = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOS -= TRANCHE"
      Wrseq space$(SPA);"Endif"
      Wrseq space$(SPA);"If TRANCHE<0"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUH]COD;" = TRANCHE"
      Wrseq space$(SPA);"Elsif TRANCHE>PEXOP"
      Wrseq space$(SPA);" ";PTRP(K);[F:RUH]COD;" = TRANCHE-PEXOP : PEXOP = 0"
      Wrseq space$(SPA);"Else"
      Wrseq space$(SPA);" PEXOP -= TRANCHE"
      Wrseq space$(SPA);"Endif"
     Else
      Wrseq space$(SPA);PTRS(K);[F:RUH]COD;" = TRANCHE"
      Wrseq space$(SPA);PTRP(K);[F:RUH]COD;" = TRANCHE"
     Endif
    Endif
   Next I
   If !OK
    Wrseq space$(SPA);'MEM     = 1'
    Wrseq space$(SPA);'RANG    = '+num$([F:RUH]ROW)
    #Tax Band
    #Wrseq space$(SPA);'[L]TYP  = 3'
    Wrseq space$(SPA);'[L]TYP  = dim([F:RUB]AMTMAX)'
    Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
    Wrseq space$(SPA);"If GOK<1 : Raz BASE : Return : Endif"
   Endif
   Wrseq space$(SPA);"Raz BASE"  : # car BASE non RAZ dans $MEMRUB quand Assiette
   Gosub FINEXO

  When 6 : # Cotisation
   Gosub DEBEXO
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUH]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUH]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOS<>0 : BASE = max(0,BASE-PEXOS) : Endif"
    # 53756
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOS<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:RUH]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOS/100)"
   Endif
   If [F:RUH]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;" = arr(BASE*TAUX/100,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD
   If [F:RUH]TMPCAL<>2
    If [F:RUH]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
###########################################"
   Gosub FINEXO
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS2
   Gosub DEBEXO
##################################################################################
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:RUH]BAS)
    Wrseq vireblc(format$("KT:250X",[F:RUH]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOP<>0 : BASE = max(0,BASE-PEXOP) : Endif"
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOP<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:RUH]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOP/100)"
   Endif
   If [F:RUH]DEC=0
    Wrseq space$(SPA);PRUB+[F:RUH]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:RUH]COD;"(2) = arr(BASE*TAUX/100,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'MONT = '+PRUB+[F:RUH]COD+'(2)'
   If [F:RUH]TMPCAL<>2
    If [F:RUH]AMTNUL=2
     Wrseq space$(SPA);"MEM  = (BASE<>0)"
    Else
     Wrseq space$(SPA);"MEM  = (MONT<>0)"
    Endif
   Endif
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   Gosub FINEXO

  When 7 : # Grille
   Wrseq space$(SPA);'GRILLE = "';[F:RUH]TBLCOD;'"'
   Wrseq space$(SPA);'GRICOL = ';num$([F:RUH]TBLCOL)
   Wrseq space$(SPA);"Raz GRICLE"
   For I=0 To 2
    If [F:RUH]TBLFRM(I)<>""
     Wrseq space$(SPA);"GRICLE(";num$(I);") = num$(";vireblc(format$("KT:250X",[F:RUH]TBLFRM(I)),2);")"
    Endif
   Next I
   Wrseq space$(SPA);"Gosub GRILLE From GPLAN"
   If [F:RUH]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUH]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUH]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 8 : # Historique
   If [F:RUH]RAT1<>""
    Wrseq space$(SPA);"DATED = ";
    Gosub WR_HRAT1
   Else
    Wrseq space$(SPA);"DATED = [0/0/0]"
   Endif
   If [F:RUH]RAT2<>""
    Wrseq space$(SPA);"DATEF = ";
    Gosub WR_HRAT2
    Wrseq space$(SPA);"If DATEF>=DATREF : DATEF = DATREF-1 : Endif"
   Else
    Wrseq space$(SPA);"DATEF = DATREF-1"
   Endif
   #64879
   #Call HISTO(SPA)
   Call HISTOMS(SPA)
   If [F:RUH]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUH]COD;" = MONT"
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'BASE = MONT'
   Wrseq space$(SPA);'TYP  = 1'
   If [F:RUH]TMPCAL<>2
    Wrseq space$(SPA);"MEM  = (MONT<>0)"
   Endif
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 9 : # Spécifique
   If [F:RUH]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_HRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:RUH]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_HBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);'RANG = '+num$([F:RUH]ROW)
   Wrseq space$(SPA);'If STDPLAN : ACTION = "CALRUB" : Gosub ACTION From STDPLAN : Endif'
   Wrseq space$(SPA);'If SPEPLAN : ACTION = "CALRUB" : Gosub ACTION From SPEPLAN : Endif'
   If [F:RUH]DEC=0
    Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Else
    Wrseq space$(SPA);"MONT = arr(MONT,";num$([F:RUH]DEC);")"
   Endif
   Wrseq space$(SPA);PRUB+[F:RUH]COD;' = MONT'
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 10 : # Régularisation
   Wrseq space$(SPA);'K = find("';[F:RUH]RGL;'",REGRUB1(1..NBREGUL))'
   Wrseq space$(SPA);'OKRUB *= (K<>0) & REGUL=0'
   Wrseq space$(SPA);"If OKRUB"
   SPA += 1
   Read [RGL]RGL0  = [F:RUH]LEG;[F:RUH]RGL
   Read [RUB2]RUB0 = [F:RGL]LEG;[F:RGL]RUB
   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL1(K)"
   Wrseq space$(SPA);"TYP  = 7"
   Wrseq space$(SPA);PRUB+[F:RUH]COD;'(1) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
   #57693
   SPA -= 1
   Wrseq space$(SPA);"Endif"
   # fin 57693
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS2
   Wrseq space$(SPA);'RUB  = "'+[F:RGL]RUB+'"'
   Wrseq space$(SPA);'RANG = '+num$([F:RUB2]ROW)
   Wrseq space$(SPA);"MONT = REGVAL2(K)"
   Wrseq space$(SPA);"TYP  = 8"
   Wrseq space$(SPA);PRUB+[F:RUH]COD;'(2) = MONT'
   Wrseq space$(SPA);"MEM = (MONT<>0)"
   Wrseq space$(SPA);"Gosub MEMRUB From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  Endcase

## Cumuls
############################################################################
  If [F:RUH]NBRCUM<>0
   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
   Endif
   Gosub ENTREEPAS2
  Endif
###########################################################################
  For I=0 To [F:RUH]NBRCUM-1
   Case [F:RUH]OPTCUM(I)
    When 1 : # -PS
     Wrseq space$(SPA);PCUM;[F:RUH]CUM(I);" -= ";PRUB;[F:RUH]COD
    When 2 : # -PP
     Wrseq space$(SPA);PCUM;[F:RUH]CUM(I);" -= ";PRUB;[F:RUH]COD;"(2)"
    When 3 : # +PS
     Wrseq space$(SPA);PCUM;[F:RUH]CUM(I);" += ";PRUB;[F:RUH]COD
    When 4 : # +PP
     Wrseq space$(SPA);PCUM;[F:RUH]CUM(I);" += ";PRUB;[F:RUH]COD;"(2)"
    When 5 : # RAZ
     Wrseq space$(SPA);PCUM;[F:RUH]CUM(I);" = 0"
   Endcase
  Next I

  If FLIF
   SPA -= 1
   Wrseq space$(SPA);"Endif"
  Endif
 #61289
 Wrseq space$(SPA);"If OKRUB : OKRMP = 1 : Return : Endif"
 Wrseq "Endif"
Endif
Return

##################################
## Evaluation des rubriques MS
##################################
$CALMSR
SPA = 0
NBRUB = 0
NBPLAN = 0
NBPAS = 0
Gosub OUVRE
For [RUB]RUB1 Where LEG=LEGPLAN

 OKRUB = 1
 If [F:RUB]CODACT<>""
  Read [ACV]CODACT = [F:RUB]CODACT
  If fstat or [F:ACV]FLACT<>2
   OKRUB = 0
  Endif
 Endif
 If OKRUB
  NBRUB += 1
  NBPAS +=1
  If NBRUB>MAXRUB
   Gosub FERME
   NBRUB = 1
   Gosub OUVRE
  Endif
  Wrseq
  Wrseq "## Rubrique ";[F:RUB]COD
  Wrseq
  Wrseq 'RUB = "'+[F:RUB]COD+'"'

  INDENT=0
  # Rubrique de remplacement
  Read[MSR]MSR0=[F:RUB]COD
  If !fstat
   Gosub ECRIT_CALMSR
   Wrseq
   Wrseq space$(INDENT);"If !OKRMP"
   INDENT += 1
  Endif

  # Rubrique std historisé
  NOMTRT='WPMSRUH'+[F:RUB]LEG+[F:RUB]COD
  Call EXISTE_ADX("","",NOMTRT,R) From ORDSYS
  If R>0
   Wrseq space$(INDENT);"Gosub CALRUH From"-NOMTRT
   If INDENT
    INDENT -= 1
    Wrseq space$(INDENT);'Endif'
    Wrseq
   Endif
   Wrseq space$(INDENT);"If !OKRMP"
   INDENT += 1
  Endif

  SPA=INDENT
  Gosub ECRIT_CALRUB    :# Rubrique standard à calculer que si la rubrique MS de remplacement n'a pas été déclenchée
  If INDENT
   INDENT -= 1
   Wrseq space$(INDENT);'Endif'
  Endif
  Wrseq

  # Rubrique MS a déclencher après la Rubrique std courante
  For [MSR]MSR2 Where CODREF=[F:RUB]COD
   Gosub ECRIT_CALMSR
  Next

 Endif
Next
Wrseq
Gosub FERME
Return

##################################
$ECRIT_CALMSR
### DBA le 13/05/09
Wrseq
Wrseq "# Ne pas calculer les rubrique de remplacement en ATM & en AIA sauf si flag FLGMCHINI"
If [F:MSR]FLGMCHINI<>2
 Wrseq "If GIHYP>1"
 SPA += 1
Endif
###

Wrseq space$(SPA);"## Rubrique MS ";[F:MSR]COD
Wrseq
Wrseq space$(SPA);'RUB = "'+[F:MSR]COD+'"'
Wrseq space$(SPA);'OKRMP = 0'
FLIF = 0
Wrseq space$(SPA);"OKRUB = (GPRFMSR("+num$([F:MSR]ROW)+")=1)"
If [F:MSR]VLYSTR<>[0/0/0]
 Wrseq space$(SPA);"OKRUB *= (DATDEB>=["+format$(GFMD,[F:MSR]VLYSTR)+"])"
Endif
If [F:MSR]VLYEND<>[0/0/0]
 Wrseq space$(SPA);"OKRUB *= (DATFIN<=["+format$(GFMD,[F:MSR]VLYEND)+"])"
Endif
For I=1 To dim([F:MSR]CNDCAL)
 If [F:MSR]CNDCAL(I-1)<>""
  Call CONVERT([F:MSR]CNDCAL(I-1))
  Wrseq space$(SPA);"OKRUB *= (";vireblc(format$("KT:250X",[F:MSR]CNDCAL(I-1)),2);")"
 Endif
Next I
If [F:MSR]FLGMCHINI=2
 Wrseq space$(SPA);"If GIHYP>1"
 Wrseq space$(SPA);" OKRMP = (GHYPMSR("+num$([F:MSR]ROW)+")=1)"
 Wrseq space$(SPA);"Else"
 Wrseq space$(SPA);" OKRMP = 1"
 Wrseq space$(SPA);"Endif"
Else
 Wrseq space$(SPA);"OKRMP = (GHYPMSR("+num$([F:MSR]ROW)+")=1)"
Endif
Wrseq space$(SPA);"If OKRUB & OKRMP"
SPA += 1 : FLIF = 1
Case [F:MSR]TYPRUB
  When 1 : # Montant=base
   If [F:MSR]BAS<>""
    Call CONVERT([F:MSR]BAS)
    Wrseq space$(SPA);PRUB+[F:MSR]COD;" = arr(";vireblc(format$("KT:250X",[F:MSR]BAS),2);
    Wrseq ",";num$(ARO);")"
   Else
    Wrseq space$(SPA);PRUB+[F:MSR]COD;" = 0"
   Endif
   Wrseq space$(SPA);'BASE = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"


  When 2 : # Montant=base*taux
   If [F:MSR]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_MSRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_MSBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PRUB+[F:MSR]COD;" = arr(BASE*TAUX,";num$(ARO);")"
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   Wrseq
   Wrseq space$(SPA);"## Suite Rubrique MS ";[F:MSR]COD
   Wrseq

   If [F:MSR]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_MSRAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_MSBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PRUB+[F:MSR]COD;"(2) = arr(BASE*TAUX,";num$(ARO);")"
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD+'(2)'
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

   If FLIF
    SPA -= 1
    Wrseq space$(SPA);"Endif"
    FLIF=0
   Endif

  When 3 : # Montant=base*taux/100
   If [F:MSR]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_MSRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_MSBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   Wrseq space$(SPA);PRUB+[F:MSR]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 4 : # Intervalle
   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Gosub WR_MSBAS
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   For I=1 To [F:MSR]ITVNBR
    Wrseq space$(SPA);
    If I=1 : Wrseq "If "; : Else : Wrseq "Elsif "; : Endif
    If num$([F:MSR]ITVLIM(I))=num$(val(num$([F:MSR]ITVLIM(I))))
     Wrseq "BASE<";num$([F:MSR]ITVLIM(I))
    Elsif num$([F:MSR]ITVLIM(I))=""
     Wrseq "BASE<";num$(0)
    Else
     Wrseq "BASE<V_";num$([F:MSR]ITVLIM(I))
    Endif
    If [F:MSR]ITVAMT(I-1)<>""
     Call CONVERT([F:MSR]ITVAMT(I-1))
     Wrseq space$(SPA+1);PRUB+[F:MSR]COD;" = arr(";vireblc(format$("KT:250X",[F:MSR]ITVAMT(I-1)),2);",";num$(ARO);")"
    Else
     Wrseq space$(SPA+1);PRUB+[F:MSR]COD;" = 0"
    Endif
   Next I
   If [F:MSR]ITVNBR>0
    Wrseq space$(SPA);"Else"
    If [F:MSR]ITVNBR>1 & [F:MSR]ITVAMT([F:MSR]ITVNBR-1)<>""
     Call CONVERT([F:MSR]ITVAMT([F:MSR]ITVNBR-1-1))
     Wrseq space$(SPA+1);PRUB+[F:MSR]COD;" = arr(";vireblc(format$("KT:250X",[F:MSR]ITVAMT([F:MSR]ITVNBR-1)),2);",";num$(ARO);")"
    Else
     Wrseq space$(SPA+1);PRUB+[F:MSR]COD;" = 0"
    Endif
    Wrseq space$(SPA);"Endif"
   Endif
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  When 6 : # Cotisation
   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:MSR]BAS)
    Wrseq vireblc(format$("KT:250X",[F:MSR]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOS<>0 : BASE = max(0,BASE-PEXOS) : Endif"
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOS<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:MSR]RAT1<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_MSRAT1
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOS/100)"
   Endif
   Wrseq space$(SPA);PRUB+[F:MSR]COD;" = arr(BASE*TAUX/100,";num$(ARO);")"
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"

  #
  # If FLIF
  #  SPA -= 1
  #  Wrseq space$(SPA);"Endif"
  #  FLIF=0
  # Endif

   If [F:MSR]BAS<>""
    Wrseq space$(SPA);"BASE = ";
    Call CONVERT([F:MSR]BAS)
    Wrseq vireblc(format$("KT:250X",[F:MSR]BAS),2)
    Wrseq space$(SPA);"If BASE>0 & PEXOP<>0 : BASE = max(0,BASE-PEXOP) : Endif"
    # Base négative (cause IJSS) et exonération à hauteur d'une limite
    Wrseq space$(SPA);"If BASE<0 & PEXOP<>0 : BASE = 0 : Endif"
   Else
    Wrseq space$(SPA);"BASE = 0"
   Endif
   If [F:MSR]RAT2<>""
    Wrseq space$(SPA);"TAUX = ";
    Gosub WR_MSRAT2
   Else
    Wrseq space$(SPA);"TAUX = 0"
   Endif
   If NEXO2
    Wrseq space$(SPA);"TAUX *= (1-TEXOP/100)"
   Endif
   Wrseq space$(SPA);PRUB+[F:MSR]COD;"(2) = arr(BASE*TAUX/100,";num$(ARO);")"
   Wrseq space$(SPA);'MONT = '+PRUB+[F:MSR]COD+'(2)'
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);'TYP  = 2'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"


  When 7 : # Grille
   Wrseq space$(SPA);'GRILLE = "';[F:MSR]TBLCOD;'"'
   Wrseq space$(SPA);'GRICOL = ';num$([F:MSR]TBLCOL)
   Wrseq space$(SPA);"Raz GRICLE"
   For I=0 To 2
    If [F:MSR]TBLFRM(I)<>""
     Wrseq space$(SPA);"GRICLE(";num$(I);") = num$(";vireblc(format$("KT:250X",[F:MSR]TBLFRM(I)),2);")"
    Endif
   Next I
   Wrseq space$(SPA);"Gosub MSGRILLE From GPLAN"
   Wrseq space$(SPA);"If STAT"
   Wrseq space$(SPA);" Gosub GRILLE From GPLAN"
   Wrseq space$(SPA);"Endif"
   Wrseq space$(SPA);"MONT = arr(MONT,";num$(ARO);")"
   Wrseq space$(SPA);PRUB+[F:MSR]COD;" = MONT"
   Wrseq space$(SPA);'BASE = MONT'
   Wrseq space$(SPA);'TYP  = 1'
   Wrseq space$(SPA);'MEM  = 1    :# On stocke toujours tout !'
   Wrseq space$(SPA);"Gosub MEMMSR From GPLAN"
   Wrseq space$(SPA);"If GOK<1 : Return : Endif"
Endcase
If FLIF
 SPA -= 1
 Wrseq space$(SPA);"Endif"
 FLIF=0
Endif
## Cumuls
For I=0 To [F:MSR]NBRCUM-1
 Case [F:MSR]OPTCUM(I)
   When 1 : # -PS
    Wrseq space$(SPA);PCUM;[F:MSR]CUM(I);" -= ";PRUB;[F:MSR]COD
   When 2 : # -PP
    Wrseq space$(SPA);PCUM;[F:MSR]CUM(I);" -= ";PRUB;[F:MSR]COD;"(2)"
   When 3 : # +PS
    Wrseq space$(SPA);PCUM;[F:MSR]CUM(I);" += ";PRUB;[F:MSR]COD
   When 4 : # +PP
    Wrseq space$(SPA);PCUM;[F:MSR]CUM(I);" += ";PRUB;[F:MSR]COD;"(2)"
   When 5 : # RAZ
    Wrseq space$(SPA);PCUM;[F:MSR]CUM(I);" = 0"
 Endcase
Next I
Wrseq
If [F:MSR]FLGMCHINI<>2
 SPA -= 1
 Wrseq space$(SPA);"Endif"
Endif
Return


$WR_MSBAS
Call CONVERT([F:MSR]BAS)
Wrseq vireblc(format$("KT:250X",[F:MSR]BAS),2)
Return

$WR_MSRAT1
Call CONVERT([F:MSR]RAT1)
Wrseq vireblc(format$("KT:250X",[F:MSR]RAT1),2)
Return

$WR_MSRAT2
Call CONVERT([F:MSR]RAT2)
Wrseq vireblc(format$("KT:250X",[F:MSR]RAT2),2)
Return

##############################################################################
## Génération des WPMS*PLANVRA* : Lecture des variables de paie
##############################################################################
$OUVRE_VRA
NBPLANVRA += 1
PROG = "WPMS"+[L]LEGPLAN+"PLANVRA"+num$(NBPLANVRA)
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
Wrseq "$LECTURE"
If NBPLANVRA=1
 #90804
 ##Commun GENPLAN & GENPLANMS
 #Gosub COMMUN_LECVAR
 Wrseq "## Valeurs dossier"
 Wrseq " Gosub LECTURE from WPMS"+[L]LEGPLAN+"PLANVLA1"
 Wrseq
 Wrseq "## Valeurs société"
 Wrseq " Gosub LECTURE from WPMS"+[L]LEGPLAN+"PLANVLA2"
 Wrseq
 Wrseq "## Valeurs site"
 Wrseq " Gosub LECTURE from WPMS"+[L]LEGPLAN+"PLANVLA3"
 Wrseq
 Wrseq "## Valeurs salarié"
Endif
Return

#########################################
$LECVARMS
NBRUB=0
NBPLANVRA=0
#90804
For IPLANVLA=1 To 3
 PROG = "WPMS"+[L]LEGPLAN+"PLANVLA"+num$(IPLANVLA)
 Gosub COMMUN_LECVAR From GENPLAN
Next
#
Gosub OUVRE_VRA
For [VRA]VRA0 Where FLGEXS<>2 & FLGEMP=2 & LEG=LEGPLAN
 OKVAR=1
 If [F:VRA]CODACT<>''
  Read [ACV]CODACT = [F:VRA]CODACT
  If fstat | [F:ACV]FLACT<>2
   OKVAR=0
  Endif
 Endif
 If OKVAR
  NBRUB +=1
  If NBRUB>MAXRUB
   Gosub FERME
   NBRUB = 1
   Gosub OUVRE_VRA
  Endif
  Wrseq
  Wrseq "##### Variable"-[F:VRA]COD
  Wrseq
  Wrseq "CODVAR='"+[F:VRA]COD+"'"
  FLGPRO=0 : SPA=0
  For [CVR]CVR1 Where COD=[F:VRA]COD & ENAFLG<>2 & LEG=[F:VRA]LEG
   If !FLGPRO
    Wrseq "If PROFIL<>'"-[F:CVR]PRFCOD+"'"
    FLGPRO=1
   Else
    Wrseq "& & PROFIL<>'"-[F:CVR]PRFCOD+"'"
   Endif
  Next

  If FLGPRO=1 : SPA+=1 : Endif
  Wrseq space$(SPA)+"INITYP ="-num$([F:VRA]TYPINI)
  Wrseq space$(SPA)+"STDVAL ="-num$([F:VRA]VALSTD)
  Wrseq space$(SPA)+"OKVAR  = 0"
  For [ECV]ECV1 Where LEG=LEGPLAN and VRA=[F:VRA]COD
   Wrseq
   Wrseq space$(SPA)+"## Exceptions"-[F:ECV]COD
   OK=1
   Read [ECH]ECH0 = LEGPLAN;[F:ECV]COD
   If !fstat
    Wrseq space$(SPA)+"OKVAR = 1"
    If [F:ECV]DATSTR<>[0/0/0]
     Wrseq space$(SPA)+"OKVAR *=(DATPAY>=["+format$(GFMD,[F:ECV]DATSTR)+"])"
    Endif
    If [F:ECV]DATEND<>[0/0/0]
     Wrseq space$(SPA)+"OKVAR *=(DATPAY<=["+format$(GFMD,[F:ECV]DATEND)+"])"
    Endif
    If [F:ECH]FCY<>''
     Wrseq space$(SPA)+"OKVAR *= (SITE ='"-[F:ECH]FCY+"')"
    Endif
    If [F:ECH]PRF<>''
     Wrseq space$(SPA)+"OKVAR *= (PROFIL ='"-[F:ECH]PRF+"')"
    Endif
    If [F:ECH]SRV<>''
     Wrseq space$(SPA)+"OKVAR *= (SERVICE ='"-[F:ECH]FCY+"')"
    Endif
    If [F:ECH]EMPSTR<>''
     Wrseq space$(SPA)+"OKVAR *= (MATRI>='"-[F:ECH]EMPSTR+"')"
    Endif
    If [F:ECH]EMPEND<>''
     Wrseq space$(SPA)+"OKVAR *= (MATRI<='"-[F:ECH]EMPEND+"')"
    Endif
    If [F:ECH]CRI<>''
     Wrseq space$(SPA)+"OKVAR *= evalue('";vireblc(format$("KT:250X",[F:ECH]CRI),2)+"')"
    Endif
    If [F:ECH]POP<>''
     Wrseq space$(SPA)+"Read [HRPOA]POA0 = [F:ECH]POP;MATRI"
     Wrseq space$(SPA)+"If fstat : OKVAR = 0 : Endif"
    Endif
    Wrseq space$(SPA)+"If OKVAR"
    Wrseq space$(SPA)+" INITYP ="- num$([F:ECV]TYPINI)
    Wrseq space$(SPA)+" STDVAL ="- num$([F:ECV]VALSTD)
    Wrseq space$(SPA)+"Endif"
    Wrseq
   Endif
  Next
  Wrseq space$(SPA)+"Case INITYP"
  Wrseq space$(SPA)+" When 1 : # Conservation"
  Wrseq space$(SPA)+"  Read [VLA]VLA0 = 4;'';'';'';MATRI;DATPAY;CODVAR;BULLETIN"
  Wrseq space$(SPA)+"  If !fstat"
  Wrseq space$(SPA)+"   NEWVAL = [F:VLA]VARVAL"
  Wrseq space$(SPA)+"   OKVAR = 1"
  Wrseq space$(SPA)+"  Endif"
  Wrseq space$(SPA)+" When 3,5 : # Valeur standard"
  Wrseq space$(SPA)+"  NEWVAL = STDVAL"
  Wrseq space$(SPA)+"  OKVAR = 1"
  Wrseq space$(SPA)+"Endcase"
  If [F:VRA]GNRFRC=2 : # Génération forcée, on prend la valeur standard"
   Wrseq space$(SPA)+"If !OKVAR"
   Wrseq space$(SPA)+" NEWVAL = STDVAL"
   Wrseq space$(SPA)+" OKVAR= 1"
   Wrseq space$(SPA)+"Endif"
  Endif
  If [F:ADI]CODE<>[F:VRA]PAGEMP
   Read [ADI]CODE = 10337;[F:VRA]PAGEMP
  Endif
  Wrseq space$(SPA)+"If OKVAR"
  #Wrseq space$(SPA+1)+format$("K:15X",PVAR+[F:VRA]COD)+" = arr(NEWVAL,"+num$(10^(-[F:ADI]N1))+")"
  Wrseq space$(SPA+1)+PVAR+[F:VRA]COD+" = arr(NEWVAL,"+num$(10^(-[F:ADI]N1))+")"
  Wrseq space$(SPA)+"Endif"
  If FLGPRO :  Wrseq "Endif" : Endif
  Wrseq
 Endif
Next
Gosub FERME
Return

#########################################################################################
## Génération du WPMS*PLANVR0 : Ecriture des variables dans MSVALEUR masse salariale
#########################################################################################
$ECRVARMS
PROG = "WPMS"+[L]LEGPLAN+"PLANVRA0"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye
Wrseq "## Ecriture des variables dans MSVALEUR"
Wrseq "$ECRITURE"
For [VRA]VRA0 Where FLGEXS<>2 & LEG=LEGPLAN
 Wrseq 'RUB  = "';[F:VRA]COD;'" : ';
 Wrseq "MONT = ";PVAR;[F:VRA]COD;" : ";
 Wrseq "Gosub MSMAJVRA From GPLAN"
 Wrseq "If GOK<1 : Return : Endif"
Next
Wrseq
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

# 54837 WGA
##############################################################################
## Génération du WPMS*PLANDEC : Déclaration et raz des rubriques
##############################################################################
$DECRUBMS
SAVRUB = ""
J=0

For I=1 To 500

 PROG = "WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(18,26,1) : # Plan de paye
 Wrseq "## Déclaration rubriques"
 Wrseq "$DECLARE"
 K = 0

 For [RUB]RUB0 Where COD > SAVRUB & LEG=LEGPLAN
  J+=1
  If J>MAXDEC
   J=0 : Break
  Endif
  SAVRUB = [F:RUB]COD

  If K>6 : Wrseq : K = 0 : Endif
  If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
  Wrseq PRUB+[F:RUB]COD;"(1..2)";
  #65041
  Wrseq ",";
  Wrseq PBAS+[F:RUB]COD;
  K += 2
 Next

 If J = 0
  Wrseq
  Wrseq "Return"
  Openo
  Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
  If OK
   NBDECPLAN += 1
  Endif
 Endif

 If [F:RUB]COD = "" or J <> 0 : # plus rien à traiter
  Break
 Endif

Next I
If J=0
 I+=1
 PROG = "WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(18,26,1) : # Plan de paye
 Wrseq "## Déclaration rubriques"
 Wrseq "$DECLARE"
Endif
