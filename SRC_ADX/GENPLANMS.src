Wrseq "###################################"
Wrseq "$CHARGE_VAR"
Wrseq "MULCTR  = [F:ID]FLGMULCTR"
#56017
##Wrseq "Read [F:ADI]CODE=10358;[F:HRCTR]CLLCVT"
##Wrseq "If !fstat & [F:ADI]N1>0"
##Wrseq " DIFHOU = [F:ADI]N1"
Wrseq "Call LECTURE('FCY',[F:VEP]FCY,'') From CONTOBJ"
Wrseq "Call LECTURE('CPY',[F:FCY]LEGCPY,'') From CONTOBJ"
Wrseq "GSOCIETE=[F:CPY]CPY"
Wrseq "[L]LEGPLAN=[F:CPY]LEG"
Wrseq "If clalev([F:HRCLV])=0 : Local File HRCLLCVT [HRCLV] : Endif"
Wrseq "Call SIMPLEREAD([F]CLLCVT, [L]LEGPLAN, GERRHRM) From SUBHRCLV"
Wrseq "If !GERRHRM & [F:HRCLV]HERDIF>0"
Wrseq " DIFHOU = [F:HRCLV]HERDIF"
Wrseq "Elsif func AFNC.ACTIV('FRT')"
Wrseq " DIFHOU =val(func AFNC.PARAM('HRSDIF',[F:HRCTR]ETRFCY))"
Wrseq "Else"
Wrseq " DIFHOU=0"
Wrseq "Endif"
#
Wrseq "CODRISK = [F]RSKWRK"
Wrseq "Read [WAC]WAC0=CODRISK"
Wrseq "Filter [F:WAR] Where CODWAC=CODRISK & DATWAC<=DATPAY"
Wrseq "Read [F:WAR]WAR0 Last"
Wrseq "Filter [F:WAR]"
Wrseq "If !fstat : TXRISK = [F:WAR]RATWAC : Else : TXRISK =0  : Endif"
Wrseq "PROFIL  = [F:HRCTR]PROPRF"
Wrseq "SERVICE = [F:HRCTR]ETRSRV"
Wrseq "If PROFIL<>[F:PRF]PRFCOD : Read [PRF]PRF0 = [L]LEGPLAN;PROFIL  : Endif"
Wrseq "SITE    = [F:HRCTR]ETRFCY"
Wrseq "If SITE<>[F:FCY]FCY       : Read [FCY]FCY0 = SITE    : Endif"
Wrseq "If SITE<>[F:DFC]FCY"
Wrseq " Filter [DFC] where FCY=SITE & YEA<=num$(year(DATPAY)) & FLGDNA=1"
Wrseq " Read [DFC]DFC0 Last"
Wrseq " Filter [DFC]"
Wrseq "Endif"
Wrseq "SOCIETE = [F:FCY]LEGCPY"
Wrseq "If SOCIETE<>[F:CPY]CPY    : Read [CPY]CPY0 = SOCIETE : Endif"
Wrseq "Call PARAM(SITE,'DMA',PARA) From ADOVAL"
Wrseq "DMA = val(PARA)"
Wrseq "POSTE     = [F:HRCTR]POT"
Wrseq "EMPLOITYP = [F:HRCTR]JOBPOT"
Wrseq "Return"
Wrseq

