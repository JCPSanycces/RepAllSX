#*********************************#

#--------------------------------------------------------------------------------
# GENPLANMS : Génération plan de paie masse salariale
#--------------------------------------------------------------------------------
# (C) PROSPER 16/07/10 - Découpage technique suite à erreur 128 à la compilation
#                        GENPLANMS fait désormais appel à un GENPLANMS01 qui
#                        contient les étiquettes MAJCUMMSx
# -> Validé par DBA le 19/07/10 : #66116
#--------------------------------------------------------------------------------
#If nomap <> GDOSX3 & GMAS
If GMAS
# Call GENPLANMS(nomap,0,"FRA")
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "GENPLANMS"
Call TRAITE_CHAR(VALEUR,PARAM,"","GENPLANMS","GENPLAN",3,"") From GTRAITE
Endif
End

$ACTION
Case ACTION
 When "INIT_DIA": Gosub INIT_DIA
 When "TIT_DIA" : TITCRIT = mess(22,10722,1) : # Génération plan de paie masse salariale
 When "EXEC" :
 If dim([M:DIA]ALLLEG)>0 & [M:DIA]ALLLEG=2
  Call GENDOS (nomap)
 Else
   If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
   Call GENPLANMS(nomap,0,GCURLEG)
 Endif
 When "SORTIE"  : Gosub SORTIE
Endcase
Return

$INIT_DIA
Raz [M:DIA]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

Subprog GENDOS(APPLI)
Value Char APPLI
Local Integer I
For I=1 To GNBLEG
 Call GENPLANMS(APPLI,0, GDOSLEG(I))
Next
End

Subprog GENPLANMS(APPLI,TRANS,LEGPLAN)
Value Char    APPLI
Value Integer TRANS
Value Char LEGPLAN
Local Integer I , J , K , P , OK , NIV , TEMPON, INIV, R
Local Integer SPA , FLIF , FLIF2 , STAT, INDENT
Local Char    CRITERE(250) , PROG(30) , FICSRC(250)
Local Char    SAVIFS(5) , SAVIRS(5) , TETADO(50)
Local Integer NBPLAN , NBPLANVRA , NBRUB , MAXRUB , DIMRUB, NBPAS , MAXCAT
Local Char    PRUB(5) , PVAR(5) , PHIS(10) , PCUM(5) , PTRS(5)(0..8) , PTRP(5)(0..8) :#Tax band
Local Char    PBAS(5)
Local Char    PHISMS(10) , PGRP(5) , PCAT(5) , PTMS(5)
Local Integer NEXO1 , NEXO2
Local Char    CEXO1(GLONEXO)(1..100) , CEXO2(GLONEXO)(1..100)
Local Char    TCAT_GRP(GLONADI)(1..100) , TCAT_CAT(GLONADI)(1..100)
Local Decimal ARO
Local Char    INICUM(30)(1..len(mess(0,10334,1)))
Local Char    PARAM(250)
Local Char    PCUMSVG(5)

Local Char    SAVRUB(GLONRUB)
Local Integer NBDECPLAN  : # nb traitements de déclaration générés
Local Integer MAXDEC     : # nb de rubriques par traitement de déclaration
Local Integer NBRAZPLAN  : # nb traitements de déclaration générés
Local Integer MAXRAZ     : # nb de rubriques par traitement de déclaration
Local Integer INDRAZMSR  : # indice de départ du traitement qui contient $RAZMSR
MAXDEC = 1000
MAXRAZ = 1000

#90804
Local Integer IPLANVLA

Local Char    RUHPRF(GLONPRF)(0..49)
Local Integer NBRRUH


TEMPON = GTEMPON
Call TEMPON(mess(22,10722,1)) From GESECRAN

Local Char    PMAXRUB(10)
Call PARAM("","MAXRUB",PMAXRUB) From ADOVAL
MAXRUB  = val(PMAXRUB)

Local Integer ILEG
ILEG=find([L]LEGPLAN,GDOSLEG(1..GNBLEG))

DIMRUB  = 10000     : # Nb max de rubriques
PRUB    = "R_"      : # Préfixe rubrique
PVAR    = "V_"      : # Préfixe variable
PCUM    = "C_"      : # Préfixe cumul
PCUMSVG = "X_"      : # Préfixe réinitialisation des cumuls # 31083
PTRS(0) = "TA_"     : # Tranche A salarié
PTRS(1) = "TB_"     : # Tranche B salarié
PTRS(2) = "TC_"     : # Tranche C salarié
PTRP(0) = "EA_"     : # Tranche A employeur
PTRP(1) = "EB_"     : # Tranche B employeur
PTRP(2) = "EC_"     : # Tranche C employeur
#Tax band
PTRS(3) = "TD_"     : # Tranche D salarié
PTRS(4) = "TE_"     : # Tranche E salarié
PTRS(5) = "TF_"     : # Tranche F salarié
PTRS(6) = "TG_"     : # Tranche G salarié
PTRS(7) = "TH_"     : # Tranche H salarié
PTRS(8) = "TI_"     : # Tranche I salarié
PTRP(3) = "ED_"     : # Tranche D employeur
PTRP(4) = "EE_"     : # Tranche E employeur
PTRP(5) = "EF_"     : # Tranche F employeur
PTRP(6) = "EG_"     : # Tranche G employeur
PTRP(7) = "EH_"     : # Tranche H employeur
PTRP(8) = "EI_"     : # Tranche I employeur

PHIS    = "[F:HSP]" : # Historique de paye
PHISMS  = "[F:MHS]" : # Historique de paye masse salariale
PGRP    = "GRP_"    : # Groupe de rubrique
PCAT    = "CAT_"    : # Catégorie groupe de rubrique
PTMS    = "TMS_"    : # Type masse salariale pour la toutee
ARO     = 0.01      : # Arrondi par défaut
MAXCAT  = 0
#65041
PBAS    = "B_"      : # Préfixe base de rubrique

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"

Local File =APPLI+".RUBRIQUE"  [RUB]
Local File =APPLI+".RUBRIQUE"  [RUB2]
Local File =APPLI+".VARIA"     [VRA]
Local File =APPLI+".EXOPAY"    [EXO]
Local File =APPLI+".CUMUL"     [CUM]
Local File =APPLI+".EXCEPTH"   [ECH]
Local File =APPLI+".EXCEPTD"   [ECD]
Local File =APPLI+".EXCEPTC"   [ECC]
Local File =APPLI+".REGUL"     [RGL]
Local File =APPLI+".ADOVAL"    [ADW]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".ATABIND"   [ATI]
Local File =APPLI+".ATABDIV"   [ADI] : #LS
Local File =APPLI+".CALVAR"    [CVR]
Local File =APPLI+".EXCEPTV"   [ECV]
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**Local File =APPLI+".TIMCOD"   [TIM]
#**
Local File =APPLI+".TIMCOD"   [TIM]
#ADNGO - 2017-05-20 - END
Local File =APPLI+".MSRUB"     [MSR]
Local File =APPLI+".RUBHIS"    [RUH]
Local File =APPLI+".CALRUBHIS" [CRH]

Local Integer  VTPS
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#VTPS=func AFNC.ACTIV("TPS")
#VTPS=0
#**
VTPS=func AFNC.ACTIV("TPS")
#ADNGO - 2017-05-20 - END
GNBEMPTAB = 0
For [ATB]CODFIC Where left$(CODFIC,5)="EMPLO"
 GNBEMPTAB += 1
 GEMPTAB(GNBEMPTAB) = [F:ATB]CODFIC
 Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
 Case [F:ATI]DESCRIPT
  When "REFNUM"        : GTYPTAB(GNBEMPTAB) = 1
  When "REFNUM+NUMLIG" : GTYPTAB(GNBEMPTAB) = 2
  When Default         : GTYPTAB(GNBEMPTAB) = 3
 Endcase
Next
Sorta GNBEMPTAB GEMPTAB,GTYPTAB Order By GTYPTAB(indice+1)


For I=1 To len(mess(0,10334,1))
 Call PARAM([L]LEGPLAN,"PERCUM"+num$(I),INICUM(I)) From ADOVAL
 INICUM(I) = left$(INICUM(I)+INICUM(I)+string$(24,"N"),24)
Next I

#82486 : Amélio des perfs
If dim(GNBRMSC)>=0 : Call KILL_PROFIL(1) From GPLAN : Endif

Gosub EFFMSR      : # Effacement plan précédent MS
Gosub DECRUBMS    : # Déclaration des rubriques - 54837 WGA
Gosub RAZRUBMS    : # RAZ des rubriques - 69990
Gosub CALRUH      : # Génération des rubriques histo
Gosub CALMSR      : # Génération des rubriques MS
Gosub LECVARMS    : # Génération lecture des variables MS
Gosub ECRVARMS    : # Génération écriture des variables MS
Gosub DECLARE_VAR From GENPLANMS01 :#93072 Déclaration des variables
Gosub MAJCUMMS1 From GENPLANMS01 : # Génération lecture/ecriture cumuls MS
Gosub MAJCUMMS2 From GENPLANMS01 : # Génération lecture/écritures cumuls réels
Gosub DECCUM      : #93072 Déclaration des cumuls

#######################################
## Génération WPMS*PLAN
#######################################

PROG = "WPMS"+[L]LEGPLAN+"PLAN"

FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1) : # Plan de paye

Wrseq "Subprog PLAN(FLGFIRST,TYPMCH,NBES,CHREMP,OKSIM)"
Wrseq "Variable Integer FLGFIRST"
Wrseq "Variable Integer OKSIM"
Wrseq "Value    Integer TYPMCH"
Wrseq "Value    Integer NBES"
Wrseq "Value    Char    CHREMP ()(1..)"
Wrseq

Wrseq "Gosub CPLAN"
Wrseq

Wrseq "End"
Wrseq

#Gosub DECLARE_VAR From GENPLANMS01 :93072

Wrseq "###################################"
Wrseq "$CPLAN"
Wrseq "## Tables"
Wrseq "Local Char TABLE(10)"
Wrseq "Gosub OUVFIC"
Wrseq "For TABLE = ";
For I=1 To GNBEMPTAB
 If I>1 : Wrseq ","; : Endif
 Wrseq '"';GEMPTAB(I);'"';
Next I
Wrseq
Wrseq " Gosub DEFAUT From WPDEFTABLE"
Wrseq "Next"
If VTPS
 Wrseq "Default File [TIR]"
 Wrseq "Default File [TID]"
Endif

Wrseq

Wrseq "## Variables locales"
Gosub DECLARE_VARLOC From GENPLANMS01

Wrseq

Wrseq "## Divers"
Call PARAM("","NBRDEC",PARAM) From ADOVAL
Wrseq "AROVAR = "+num$(10^(-val(PARAM)))
Call PARAM([L]LEGPLAN,"PAENBR",PARAM) From ADOVAL
Wrseq "MAXESSAI = "+num$(val(PARAM)) : # Au cas où...
Call PARAM([L]LEGPLAN,"PAETOL",PARAM) From ADOVAL
Wrseq "PAETOL = "+num$(val(PARAM))
Call PARAM([L]LEGPLAN,"PAERUB",PARAM) From ADOVAL
Wrseq 'PAERUB = "'+PARAM+'"'
Call PARAM([L]LEGPLAN,"PAEVAR",PARAM) From ADOVAL
Wrseq 'PAEVAR = "'+PARAM+'"'
Call PARAM([L]LEGPLAN,"PAEVAL",PARAM) From ADOVAL
Wrseq 'PAEVAL = "'+PARAM+'"'
K = 0
For I=1 To 9
 Call PARAM([L]LEGPLAN,"NETVAR"+num$(I),PARAM) From ADOVAL
 If PARAM="" : Break : Endif
 K += 1
 Wrseq 'NETVAR('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETAJS"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETAJS('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETRUB"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETRUB('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETTIM"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETTIM('+num$(K)+') = "'+PARAM+'"'
 Call PARAM([L]LEGPLAN,"NETRUBCAL"+num$(I),PARAM) From ADOVAL
 Wrseq 'NETRUBCAL('+num$(K)+') = "'+PARAM+'"'
Next I
Wrseq "NETENBRUT = "+num$(K)
Wrseq "RECAL = 3 : PASAPAS = 0 : SIMUL = 0"
Wrseq 'Call EXISTE_ADX("","","STDPLAN",R) From ORDSYS'
Wrseq "If R>0 : STDPLAN = 1 : Endif"
Wrseq 'Call EXISTE_ADX("","","SPEPLAN",R) From ORDSYS'
Wrseq "If R>0 : SPEPLAN = 1 : Endif"
Wrseq

Wrseq "## Rubriques"
For I = 1 To NBDECPLAN
 Wrseq "Gosub DECLARE From WPMS"+[L]LEGPLAN+"PLANDEC"+num$(I)+" : # Déclaration des rubriques " : # 54837 WGA
Next I
Wrseq

Wrseq "## Variables"
Wrseq "Gosub DECLARE From WPMSPLANDECV" :#93072 Déclaration des variables
Wrseq

Wrseq "## Cumuls"
Wrseq "Gosub DECLARE From WPMSPLANDECC" :#93072 Déclaration des cumuls
Wrseq

#Tax band
Wrseq "## Tranches"
For [RUB]RUB0 Where TYPRUB=5 & LEG=LEGPLAN
 Wrseq "Local Decimal ";PTRS(0);[F:RUB]COD;",";PTRS(1);[F:RUB]COD;",";PTRS(2);[F:RUB]COD
 Wrseq "Local Decimal ";PTRS(3);[F:RUB]COD;",";PTRS(4);[F:RUB]COD;",";PTRS(5);[F:RUB]COD
 Wrseq "Local Decimal ";PTRS(6);[F:RUB]COD;",";PTRS(7);[F:RUB]COD;",";PTRS(8);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(0);[F:RUB]COD;",";PTRP(1);[F:RUB]COD;",";PTRP(2);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(3);[F:RUB]COD;",";PTRP(4);[F:RUB]COD;",";PTRP(5);[F:RUB]COD
 Wrseq "Local Decimal ";PTRP(6);[F:RUB]COD;",";PTRP(7);[F:RUB]COD;",";PTRP(8);[F:RUB]COD
Next
Wrseq

Wrseq "Gosub MSTR1"

Wrseq "Return"
Wrseq

Wrseq "###################################"
Wrseq "$MSTR1"
Wrseq "## Lecture tables pour MS"
Wrseq "Raz BULLETIN"
Wrseq "SCENARIO = [F:MCH]COD"
Wrseq "MATRI    = [F:HRCTR]REFNUM"
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#Wrseq "DATPAY   = [F:HRPEO]PYRDAT"
#**
Wrseq "DATPAY   = [F:HRPEOD]PYRDAT"
#ADNGO - 2017-05-20 - END
Wrseq "CTR      = [F:HRCTR]CTRNUM"
Wrseq "DATREF   = [M:MCH1]MTHREF"
Wrseq "DATREV   = [M:MCH1]DATREVBUD"
#ADNGO - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#Wrseq "# Inutile de prendre max([F:HRPEO]PERSTR(1),[F:HRCTR]CTRDAT)"
#Wrseq "PERDEB   = [F:HRPEO]PERSTR(1)"
#Wrseq "# Si PERFIN= min([F:HRPEO]PEREND(1),[F:HRCTR]XITDAT) on exclut les salariés partis le mois de réf: le 31/12/N"
#Wrseq "PERFIN   = [F:HRPEO]PEREND(1)"
#**
Wrseq "# Inutile de prendre max([F:HRPEOD]PERSTR(1),[F:HRCTR]CTRDAT)"
Wrseq "PERDEB   = [F:HRPEOD]PERSTR(1)"
Wrseq "# Si PERFIN= min([F:HRPEOD]PEREND(1),[F:HRCTR]XITDAT) on exclut les salariés partis le mois de réf: le 31/12/N"
Wrseq "PERFIN   = [F:HRPEOD]PEREND(1)"
#ADNGO - 2017-05-20 - END
Wrseq "If TYPMCH=3 & DATPAY<=DATREV: # Révision budgétaire"
Wrseq " DATREF = DATPAY"
Wrseq " ## Paye réelle sur le mois courant "
Wrseq " Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & PYRDAT=DATPAY"
Wrseq " Read [VEP]VEP0 Last"
Wrseq " Filter[VEP]"
Wrseq " If !fstat"
Wrseq "  BULLETIN = [F:VEP]BUL"
Wrseq "  For [F:MCL]MCL2 Where COD=SCENARIO & STAHYP<>3 & STRHYP<PERFIN & ENDHYP>PERDEB"
Wrseq "   GIHYP = [F:MCL]NUMLIG+1"
Wrseq "   Gosub INI_VARHYP"
Wrseq "   Gosub ECR_REEL From WPMS"+[L]LEGPLAN+"PLANCUM2"
Wrseq "  Next"
Wrseq "  FLGFIRST = 1"
Wrseq "  Return"
Wrseq " Else"
Wrseq "  # Pas de paie au"
Wrseq "  Call ECR_TRACE(MATRI-'('+CTR+')'-':'-mess(12,10722,1)-num$(DATPAY),0) From GESECRAN"
Wrseq "  FLGFIRST = -1"
Wrseq "  Return"
Wrseq " Endif"
Wrseq "Elsif TYPMCH=3"
Wrseq " DATREF = DATREV"
Wrseq "Endif"
Wrseq "## Initialisation variables diverses"
Wrseq "Gosub INIVARMS"
Wrseq "Gosub MSTR2"
Wrseq "Return"
Wrseq

Gosub INSERT_FILE From GENPLANMS01

Wrseq "##################################"
Wrseq "$MSTR2"
Wrseq "## Recherche de la dernière paie réelle. Dernière paie<=DATREF"
Wrseq "## DATREF = Mois de référence dans Scénario initial et budgétaire"
Wrseq "## DATREF = Date de la révision budgétaire"

Wrseq "Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & PYRDAT<=DATREF"
Wrseq "Read [VEP]VEP0 Last"
Wrseq "Filter [VEP]"
Wrseq "If fstat<=2"
Wrseq : Wrseq " Gosub CHARGE_VAR" : Wrseq
Wrseq " DATREF   = DATPAY"
Wrseq " DATPAY   = [F:VEP]PYRDAT"
Wrseq " BULLETIN = [F:VEP]BUL"
Wrseq " BULREF   = [F:VEP]BUL"
For I=1 To NBPLANVRA
 Wrseq " Gosub LECTURE From WPMS"+[L]LEGPLAN+"PLANVRA"+num$(I)
Next
If VTPS
 Wrseq " Read [TIR]TIR0 = MATRI;CTR;DATPAY"
 Wrseq " If fstat : Raz [F:TIR] : Endif"
 Wrseq " Read [TID]TID0 = MATRI;CTR"
 Wrseq " If fstat : Raz [F:TID] : Endif"
Endif
Wrseq " DATPAY = DATREF"
Wrseq " DATREF = [F:VEP]PYRDAT"
Wrseq "Else"
Wrseq " Raz BULREF"
Wrseq " # Pas de paie au"
Wrseq " Call ECR_TRACE(MATRI-'('+CTR+')'-':'-mess(12,10722,1)-num$(DATREF),0) From GESECRAN"
Wrseq " FLGFIRST = -1"
Wrseq " Return"
Wrseq "Endif"
Wrseq
Wrseq "## Pas de relecture des variables car ce sont toujours celles du mois de référence"
Wrseq "## GIHYP=0 : Scénario initial ATM-Augmentation avant toute mesure"
Wrseq "## GIHYP=1 : Scénario initial AIA-Augmentation Individuelle Auto"
Wrseq "## GIHYP>=2 : Scénario budgétaire ou de révision budgétaire"
Wrseq
Wrseq "If GIHYP=0 or GIHYP=1 "
Wrseq " LISHYP(GIHYP)  = GBUDHYP(GIHYP)"
Wrseq " If GIHYP=0"
Wrseq "  TYPHYP(GIHYP)  = '7'"
Wrseq '  NOMTRT = "WPMS0"+[M:MCH1]BUD1'
Wrseq '  Call EXISTE_ADX("","",NOMTRT,R) From ORDSYS'
Wrseq "  If R>0"
Wrseq "   Gosub LECTURE From =NOMTRT : # Maj des champs salariés pour annuler vieillisement"
Wrseq "  Endif"
Wrseq " Else"
Wrseq "  TYPHYP(GIHYP)  = '8'"
Wrseq " Endif"
Wrseq
Wrseq "# modif WGA -  Gosub CHARGE_VAR"
Wrseq
Wrseq " ## Chargement profils"
Wrseq " If GPRFRUB<>PROFIL"
Wrseq "  Gosub CHARGE_PROFIL From GPLAN"
#58494
Wrseq "  Gosub CHARGE_PROMSR From GPLAN"
Wrseq " Endif"
Wrseq
Wrseq " ## Raz cumuls"
Wrseq " Gosub RAZCUM From WP"+[L]LEGPLAN+"PLANCUM1 : # Pour raz cumuls intermédiaires"
Wrseq
Wrseq " ## Lecture cumuls"
Wrseq " Gosub LECTURE From WPMS"+[L]LEGPLAN+"PLANCUM1"
Wrseq
Wrseq " ## Calcul de paye"
Wrseq " Gosub CALPAY"
Wrseq " If GOK<1 : Return : Endif"
Wrseq
Wrseq " ## Ecriture cumuls Masse salariale"
Wrseq " Gosub ECRITURE From WPMS"+[L]LEGPLAN+"PLANCUM3"
Wrseq " If GOK<1 : Return : Endif"
Wrseq
Wrseq " ## Ecriture variables Masse salariale"
Wrseq " Gosub ECRITURE From WPMS"+[L]LEGPLAN+"PLANVRA0"
Wrseq " If GOK<1 : Return : Endif"
Wrseq

Wrseq "Else       : ## Boucle pour empiler les hypothèses non annulées du scénario"

Wrseq
Wrseq " Local Integer MODIFVAR : MODIFVAR=1"
Wrseq " For [F:MCL]MCL2 Where COD=SCENARIO & STAHYP<>3 & STRHYP<PERFIN & ENDHYP>PERDEB"
Wrseq "  GIHYP = [F:MCL]NUMLIG+1"
Wrseq
Wrseq "  # FQ76040 - MABON 04/10/11 - Si le site ou le profil ou le service change, il faut recalculer les variables"
Wrseq "  If MODIFVAR=2 & find([F:MCL]TYPHYP,4,5)>0 Then"
Wrseq "    Gosub RELIT_VAR"
Wrseq "    MODIFVAR=1"
Wrseq "  Endif"
Wrseq "  # Fin MABON"
Wrseq
Wrseq "  If LIGHYPO=0 | LIGHYPO<=[F:MCL]NUMLIG"
Wrseq "   ## Initialisation LISHYP TYPHYP GBUDHYP"
Wrseq "   Gosub INI_VARHYP"
Wrseq
Wrseq "   ## Raz cumuls"
Wrseq "   Gosub RAZCUM From WP"+[L]LEGPLAN+"PLANCUM1 : # Pour raz cumuls intermédiaires"
Wrseq
Wrseq "   ## Lecture cumuls"
Wrseq "   Gosub LECTURE From WPMS"+[L]LEGPLAN+"PLANCUM1"
Wrseq
Wrseq "   For I=2 To GIHYP"
Wrseq "    # Parcours des hypothèses précédentes actives de modif contrat & E/S salarié"
#57202
#Wrseq '    If LISHYP(I)<>"" & ( (LIGHYPO=0 & find(TYPHYP(I),"5","6")) | (LIGHYPO<>0 & find(TYPHYP(I),"4","5")) )'
Wrseq '    If LISHYP(I)<>"" & ( (LIGHYPO=0 & find(TYPHYP(I),"5","6")) |'
Wrseq '&     (LIGHYPO<>0 & TYPHYP(I)=TYPHYP(LIGHYPO+1) & LISHYP(I)=LISHYP(LIGHYPO+1) & find(TYPHYP(I),"4","5")) )'
Wrseq "     NOMTRT='WPMS'+TYPHYP(I)+LISHYP(I)"
Wrseq '     Call EXISTE_ADX("","",NOMTRT,R) From ORDSYS'
Wrseq "     If R>0"
Wrseq "      If LIGHYPO=0 & find(TYPHYP(I),'5','6')"
Wrseq "       ## Prise en compte des hypothèses : modifs contrat, sortie salarié uniquement pour salariés réels"
Wrseq "       Gosub LECTURE From =NOMTRT"
Wrseq "      Else"
Wrseq "       ## Prise en compte des hypothèses : entrée salarié ou remplacement salarié"
Wrseq "       Gosub LIRE From =NOMTRT"
Wrseq "      Endif"
Wrseq "      If OKSIM=0 : Break 2 : Endif"
Wrseq "      # FQ76040 - MABON 04/10/11 - Si le site ou le profil ou le service change, il faut recalculer les variables"
Wrseq "      Gosub RELIT_VAR"
Wrseq "      # Fin MABON"
Wrseq "     Endif"
Wrseq "    Endif"
Wrseq "   Next"
Wrseq
Wrseq "# modif WGA -     Gosub CHARGE_VAR"
Wrseq

Wrseq "   ## Affectation des variables en fonction des hypothèses du scénario"
Wrseq '   If TYPHYP(GIHYP)="1"| TYPHYP(GIHYP)="4" | TYPHYP(GIHYP)="5" | TYPHYP(GIHYP)="6" | TYPHYP(GIHYP)="9"'
Wrseq "    NOMTRT='WPMS'+TYPHYP(GIHYP)+LISHYP(GIHYP)"
Wrseq '    Call EXISTE_ADX("","",NOMTRT,R) From ORDSYS'
Wrseq "    If R>0"
Wrseq "     Gosub HYPOVAR From =NOMTRT"
Wrseq "     MODIFVAR=2"
Wrseq "    Endif"
Wrseq "   Endif"
Wrseq

Wrseq "   ## Chargement profils"
Wrseq "   If GPRFRUB<>PROFIL"
Wrseq "    Gosub CHARGE_PROFIL From GPLAN"
Wrseq "    Gosub CHARGE_PROMSR From GPLAN"
Wrseq "   Endif"
Wrseq

Wrseq "   ## Chargement critère d'activation d'une hypothèse de rubrique"
Wrseq "   Gosub CHARGE_ACTMHR From GPLAN"
Wrseq

Wrseq "   ## Calcul de paye"
Wrseq "   Gosub CALPAY"
Wrseq "   If GOK<1 : Return : Endif"
Wrseq

Wrseq "   ## Ecriture cumuls Masse salariale"
Wrseq "   Gosub ECRITURE From WPMS"+[L]LEGPLAN+"PLANCUM3"
Wrseq "   If GOK<1 : Return : Endif"
Wrseq

Wrseq "   ## Ecriture variables Masse salariale"
Wrseq "   Gosub ECRITURE From WPMS"+[L]LEGPLAN+"PLANVRA0"
Wrseq "   If GOK<1 : Return : Endif"
Wrseq
Wrseq "  Else"
Wrseq
Wrseq "   ## LIGHYPO<>0 : Traitement d'un nouveau salarié car hypothèse entrée / remplacement / modif contrat"
Wrseq "   ## Tenir compte des hypothèses de rubriques et de variables qui précèdent l'hypothèse"
Wrseq '   If num$([F:MCL]TYPHYP)="2" : # Pour que le CHARGE_ACTMHR fonctionne'
Wrseq "    LISHYP(GIHYP) = [F:MCL]CODHYP"
Wrseq "    TYPHYP(GIHYP) = num$([F:MCL]TYPHYP)"
Wrseq "   Endif"
Wrseq
Wrseq '   If num$([F:MCL]TYPHYP)="1" | num$([F:MCL]TYPHYP)="9"'
Wrseq "    LISHYP(GIHYP) = [F:MCL]CODHYP"
Wrseq "    TYPHYP(GIHYP) = num$([F:MCL]TYPHYP)"
Wrseq "    NOMTRT='WPMS'+TYPHYP(GIHYP)+LISHYP(GIHYP)"
Wrseq '    Call EXISTE_ADX("","",NOMTRT,R) From ORDSYS'
Wrseq "    If R>0"
Wrseq "     Gosub HYPOVAR From =NOMTRT"
Wrseq "    Endif"
Wrseq "   Endif"
Wrseq "  Endif"

Wrseq " Next"

Wrseq "Endif"
Wrseq "FLGFIRST = 0"
Wrseq "Return"
Wrseq

#Wrseq "###################################"  : 66638
#Wrseq "## Initialisation des variables LISHYP TYPHYP GBUDHYP"
#Wrseq "$INI_VARHYP"
#Wrseq "LISHYP(GIHYP) = [F:MCL]CODHYP"
#Wrseq "TYPHYP(GIHYP) = num$([F:MCL]TYPHYP)"
#Wrseq
#Wrseq "#Lecture hypothèse courante pour récup son code budgétaire"
#Wrseq "Case TYPHYP(GIHYP)"
#Wrseq " When '1' : Default File [MHV]"
#Wrseq " When '2' : Default File [MHR]"
#Wrseq " When '3' : Default File [MHP]"
#Wrseq " When '4' : Default File [MHE]"
#Wrseq " When '5' : Default File [MHX]"
#Wrseq " When '6' : Default File [MHC]"
#Wrseq "Endcase"
#Wrseq "Read [F]=[F:MCL]CODHYP"
#Wrseq "If !fstat : GBUDHYP(GIHYP)=[F]BUD : Endif"
Wrseq "###################################"
Wrseq "## Initialisation des variables LISHYP TYPHYP GBUDHYP"
Wrseq "$INI_VARHYP"
Wrseq "LISHYP(GIHYP) = [F:MCL]CODHYP"
Wrseq "TYPHYP(GIHYP) = num$([F:MCL]TYPHYP)"
Wrseq "Local Char    SAVFILE (250)"
Wrseq "SAVFILE=dbgstr(2)"
Wrseq "Case TYPHYP(GIHYP)"
Wrseq " When '1' : Local File MSHYPVAH [MHZZ]"
Wrseq " When '2' : Local File MSHYPRUB [MHZZ]"
Wrseq " When '3' : Local File MSHYPENP [MHZZ]"
Wrseq " When '4' : Local File MSENTEML [MHZZ]"
Wrseq " When '5' : Local File MSXITEML [MHZZ]"
Wrseq " When '6' : Local File MSMODCTR [MHZZ]"
Wrseq " When '9' : Local File MSHYPTXAT [MHZZ]"
Wrseq "Endcase"
Wrseq "Read [F:MHZZ]=[F:MCL]CODHYP"
Wrseq "If !fstat : GBUDHYP(GIHYP)=[F:MHZZ]BUD : Endif"
Wrseq "Close File [F:MHZZ]"
Wrseq "Default File SAVFILE"
Wrseq "Return"
Wrseq

Wrseq "###################################"
Wrseq "## Calcul complet de la paye"
Wrseq "$CALPAY"
Wrseq "## Paye à l'envers"
Wrseq "If [F:HRCTR]TWDPAY=2"
Wrseq " SAVPAS  = PASAPAS"
Wrseq " PASAPAS = 0"
Wrseq " Gosub ENVERS From ENVERS"
Wrseq " PASAPAS = SAVPAS"
Wrseq " If !OK : Return : Endif"
Wrseq "Endif"
Wrseq
Wrseq "## Pré calcul des IJSS"
Wrseq "Call PARAM(SITE,'GARANTNET',PARA) From ADOVAL"
Wrseq "If val(PARA)=2"
Wrseq " SAVPAS  = PASAPAS"
Wrseq " PASAPAS = 0"
Wrseq " OK = 0"
Wrseq " For N=1 to NETENBRUT"
Wrseq "  If NETVAR(N)<>'' and NETAJS(N)<>'' and NETRUB(N)<>'' and NETTIM(N)<>'' and evalue(NETTIM(N))=1"
Wrseq "   OK = 1 : Break"
Wrseq "  Endif"
Wrseq " Next N"
Wrseq " If OK"
Wrseq "  ENVERS = 1"
Wrseq "  Gosub CALPLANMS"
###
Wrseq "  For N=1 to NETENBRUT"
Wrseq "   NETRUBC(N) = evalue('R_'+NETRUBCAL(N))"
Wrseq "   Assign ('V_'+NETVAR(N)) With evalue('V_'+NETVAR(N))+evalue('R_'+NETRUBCAL(N))"
Wrseq "  Next N"
Wrseq "  Gosub RAZRUB"
Wrseq "  Gosub RAZMSR"
Wrseq "  Gosub AFFCUM"
Wrseq "  ENVERS = 0"
Wrseq " Endif"
Wrseq " OK = 1"
Wrseq " PASAPAS = SAVPAS"
Wrseq "Endif"
Wrseq
Wrseq "## Calculs de net en brut"
Wrseq "SAVPAS  = PASAPAS"
Wrseq "PASAPAS = 0"
Wrseq "For N=1 to NETENBRUT"
Wrseq " Gosub NETENBRUT From ENVERS"
Wrseq "Next N"
Wrseq "PASAPAS = SAVPAS"
Wrseq
Wrseq "Call PARAM(SITE,'GARANTNET',PARA) From ADOVAL"
Wrseq "If val(PARA)=2"
Wrseq " Call PARAM(SITE,'SUBROG',PARA) From ADOVAL"
Wrseq " Call PARAM(SITE,'TEMSUBRO',PARA1) From ADOVAL"
Wrseq " If val(PARA)=1 | evalue('V_'+PARA1)=0"
Wrseq "  For N=1 to NETENBRUT"
Wrseq "   Assign ('V_'+NETVAR(N)) With evalue('V_'+NETVAR(N))-NETRUBC(N)"
Wrseq "  Next N"
Wrseq " Endif"
Wrseq "Endif"
Wrseq

Wrseq "## Calcul"
Wrseq "Gosub CALPLANMS"
###

Wrseq "Return"
Wrseq

Wrseq "###################################"
Wrseq "# Exécution plan de paye MS"
Wrseq "$CALPLANMS"
Wrseq "Raz"-PHISMS
Wrseq "Onerrgo ERRPLAN From GPLAN"
For I=1 To NBPLAN
 Wrseq "Gosub PLAN From WPMS"+[L]LEGPLAN+"PLAN"+num$(I)
 Wrseq "If GOK<1 : Return : Endif"
Next I
Wrseq "Onerrgo"
Wrseq "Return"
Wrseq
###

