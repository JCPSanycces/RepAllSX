#69990
##############################################################################
## Génération du WPMS*PLANRAZ : Déclaration et raz des rubriques
##############################################################################
$RAZRUBMS
SAVRUB = ""
J=0

For I=1 To 500

 PROG = "WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(18,26,1) : # Plan de paye
 Wrseq "## Raz rubriques"
 Wrseq "$RAZRUB"
 K = 0
 For [RUB]RUB0 Where COD > SAVRUB & LEG=LEGPLAN
  J+=1
  If J>MAXRAZ
   J=0 : Break
  Endif
  SAVRUB = [F:RUB]COD

  If K>6 : Wrseq : K = 0 : Endif
  If K=0 : Wrseq "Raz "; : Else : Wrseq ","; : Endif
  Wrseq PRUB+[F:RUB]COD;
  #65041
  Wrseq ",";
  Wrseq PBAS+[F:RUB]COD;
  K += 2
 Next
 Wrseq

 If J = 0
  Wrseq
  Wrseq "Return"
  Openo
  Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
  If OK
   NBRAZPLAN += 1
  Endif
 Endif

 If [F:RUB]COD = "" or J <> 0 : # plus rien à traiter
  Break
 Endif

Next I

If J=0
 I+=1
 PROG = "WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
 FICSRC = filpath("TRT",PROG,"src",APPLI)
 Openo FICSRC , 0
 Wrseq TETADO-mess(18,26,1) : # Plan de paye
 Wrseq "## Raz rubriques"
 Wrseq "$RAZRUB"
Endif

Wrseq "## Raz tranches"
For [RUB]RUB0 Where TYPRUB=5 & LEG=LEGPLAN
 J+=1
 If J > MAXRAZ
  Wrseq
  Wrseq "Return"
  Openo
  Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
  If OK
   NBRAZPLAN += 1
  Endif
  J=0
  I+=1
  PROG = "WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
  FICSRC = filpath("TRT",PROG,"src",APPLI)
  Openo FICSRC , 0
  Wrseq TETADO-mess(18,26,1) : # Plan de paye
  Wrseq "## Raz tranches"
  Wrseq "$RAZRUB"
 Endif

 #Tax band
 Wrseq "Raz ";PTRS(0);[F:RUB]COD;",";PTRS(1);[F:RUB]COD;",";PTRS(2);[F:RUB]COD
 Wrseq "Raz ";PTRS(3);[F:RUB]COD;",";PTRS(4);[F:RUB]COD;",";PTRS(5);[F:RUB]COD
 Wrseq "Raz ";PTRS(6);[F:RUB]COD;",";PTRS(7);[F:RUB]COD;",";PTRS(8);[F:RUB]COD
 Wrseq "Raz ";PTRP(0);[F:RUB]COD;",";PTRP(1);[F:RUB]COD;",";PTRP(2);[F:RUB]COD
 Wrseq "Raz ";PTRP(3);[F:RUB]COD;",";PTRP(4);[F:RUB]COD;",";PTRP(4);[F:RUB]COD
 Wrseq "Raz ";PTRP(6);[F:RUB]COD;",";PTRP(7);[F:RUB]COD;",";PTRP(8);[F:RUB]COD

Next
Wrseq

Wrseq "Return"
Wrseq

INDRAZMSR = I  : # On sauvegarde l'indice du traitement qui contient cette étiquette
Wrseq "###################################"
Wrseq "## Raz rubriques MSR"
Wrseq "$RAZMSR"
K = 0
For [MSR]MSR0
 J+=1
 If J > MAXRAZ
  Wrseq
  Wrseq "Return"
  Openo
  Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
  If OK
   NBRAZPLAN += 1
  Endif
  J=0
  I+=1
  PROG = "WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
  FICSRC = filpath("TRT",PROG,"src",APPLI)
  Openo FICSRC , 0
  Wrseq TETADO-mess(18,26,1) : # Plan de paye
  Wrseq "## Raz rubriques MSR"
  Wrseq "$RAZMSR"
 Endif

 If K>6 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Raz "; : Else : Wrseq ","; : Endif
 Wrseq PRUB+[F:MSR]COD;
 #65041
 Wrseq ",";
 Wrseq PBAS+[F:RUB]COD;
 K += 2
Next
Wrseq
Wrseq "Return"

Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
If OK
 NBRAZPLAN += 1
Endif

Return

##################################
# 93072 : Déclaration des cumuls #
##################################
$DECCUM
PROG = "WPMSPLANDECC"
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(18,26,1)-mess(0,10722,1) : # Plan de paye Masse salariale
Wrseq "## Déclaration cumuls"
Wrseq "$DECLARE"
K = 0
For [CUM]CUM0 Where LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PCUM+[F:CUM]CUMCOD;"(1..2)";
 K += 1
Next
Wrseq
K = 0
For [CUM]CUM0 Where [F:CUM]CUMINI<>"" & [F:CUM]CUMTMP<>2 & LEG=LEGPLAN
 If K>5 : Wrseq : K = 0 : Endif
 If K=0 : Wrseq "Local Decimal "; : Else : Wrseq ","; : Endif
 Wrseq PCUMSVG+[F:CUM]CUMCOD;
 K += 1
Next
Wrseq
Wrseq "Return"
Wrseq
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB
Return

