For I = 1 To NBRAZPLAN
 Wrseq "Gosub RAZRUB From WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
Next I
Wrseq "Return"

Wrseq
Wrseq "###################################"
Wrseq "## Raz rubriques MSR"
Wrseq "$RAZMSR"
For I = INDRAZMSR To NBRAZPLAN
 Wrseq "Gosub RAZMSR From WPMS"+[L]LEGPLAN+"PLANRAZ"+num$(I)
Next I
Wrseq "Return"
Wrseq

Wrseq "###################################"
Wrseq "# Réaffectation des cumuls"
Wrseq "$AFFCUM"
For [CUM]CUM1 Where CUMTMP<>2 & LEG=LEGPLAN
 Wrseq format$('K:18X',PCUM+[F:CUM]CUMCOD+'(1)');' = ';PCUM;[F:CUM]CUMCOD;'(2)'
Next
For [CUM]CUM1 Where CUMTMP=2 & LEG=LEGPLAN
 Wrseq "Raz "+PCUM+[F:CUM]CUMCOD
Next
Wrseq "Return"
Wrseq


