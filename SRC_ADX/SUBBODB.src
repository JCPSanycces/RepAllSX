#<AdxTL>@(#)10.0.0.0 $Revision$
# Gestion du masque BOS2:
# appelûˋ par SUBBODA si ûˋcran OBODS => nomenc de sous-traitance
# appelûˋ par SUBBOC  si ûˋcran FBODS => copie nomenc de sous-traitance
# GA 22/03/2006 table BOMS remplacûˋe par BOMD avec CPNTYP=7 & BOMALTTYP=3 (BOMALTTYP dans la clûˋ primaire)

$ACTION
Case ACTION
   When Default :   # FQ 61907 GA 01/2010 nûˋcessaire pour l'import IMPBOMS
Endcase
Return

#######################################################
# Nomenclature de sous-traitance: liste des services  #
#######################################################
$LIENS_BOMS
Local Integer I : I=0
Raz [M:BOS2]
# Article lancûˋ
If [F:ITM]ITMREF<>[M:BOH0]ITMREF
    Read [ITM]ITM0=[M:BOH0]ITMREF
    If fstat : GOK=0 : Call FSTA("ITM") From GLOCK : Return : Endif
Endif
nolign=0
# Tenir compte de GDATEREF
#For [BOD]BOD0 Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP=3 & CPNTYP=7
If GDATEREF <> [0/0/0]
 For [BOD] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&               & (BOMSTRDAT <= GDATEREF)
&               & (BOMENDDAT >= GDATEREF | BOMENDDAT = [0/0/0])
&               & CPNTYP=7
   nolign += 1
   Gosub ZAFF
   I += 1
 Next
Else   : # la date de rûˋfûˋrence est nulle
 For [BOD] Where ITMREF = [M:BOH0]ITMREF & BOMALT = [M:BOH0]BOMALT & BOMALTTYP = [M:BOH0]BOMALTTYP
&               & CPNTYP=7
   nolign += 1
   Gosub ZAFF
   I += 1
 Next
Endif
[M:BOS2]NBLIG = nolign
# Issue 77371 - 2011-11-23 by MUARN : alimentation deuxiû´me variable pour sous traitance
MAXLIG2 = nolign
# Fin Issue 77371 - 2011-11-23 by MUARN : alimentation deuxiû´me variable pour sous traitance
Affzo [M:BOS2]1-99
Return
# zones affichûˋes dans les lignes
$ZAFF
[M:BOS2] = [F:BOD]
#
#
Read [ITM2]ITM0=[F:BOD]CPNITMREF
If fstat : GOK=0 : Call FSTA("ITM2") From GLOCK : Return : Endif
#
# Issue 87115 GA 01/2013 raz de la modif 77611 [F:ITM2]STU
# Issue 77611 GA 11/2012 Unitûˋ opûˋration = US de l'article Service
# Unitûˋ opûˋration = US de l'article lancûˋ [M:BOH0]BOMSTU
If [M:BOS2]STU(I)   ="" : [M:BOS2]STU(I) = [M:BOH0]BOMSTU   : Endif
If [M:BOS2]LIKQTY(I)=0  : [M:BOS2]LIKQTY(I)=1           : Endif

If dim([M:BOS2]BOMUOM(nolign-1))>0    # UML actif
   # Unitûˋ sous-traitance = UA du Service
   If [M:BOS2]BOMUOM(I)="" : [M:BOS2]BOMUOM(I)=[F:ITM2]PUU : Endif
Endif
If dim([M:BOS2]BOMQTY)>0 & [M:BOS2]BOMQTY(I)=0  : [M:BOS2]BOMQTY(I)=1           : Endif
#
If dim([M:BOS2]BOMSTUCOE)>0 # UML actif ?   # FQ 77611 GA 11/2011
   [M:BOS2]WBOMSTUCOE(I)=[M:BOS2]BOMSTUCOE(I)
Endif
# [M:BOS2]ITMDES1 (I) = [F:ITM2]ITMDES1
# Prûˋparation de la clûˋ
[M:BOS2]CONCATKEY(I) = num$([M:BOS2]BOMSEQ(I)) + [M:BOS2]CPNITMREF(I)
[M:BOS2]UPDFLG(nolign-1) = 0
[M:BOS2]CREFLG(nolign-1) = nolign
OSEQS(nolign-1)          = [F:BOD]BOMSEQ
OCPNS(nolign-1)          = [F:BOD]CPNITMREF
Return

$CREATION_BOMS
Raz [F:BOD]
For I=0 To [M:BOS2]NBLIG-1
    nolign = I + 1
    [F:BOD] = [M:BOS2]
    [F:BOD]ITMREF    = [M:BOH0]ITMREF
    [F:BOD]BOMALT    = [M:BOH0]BOMALT
    [F:BOD]BOMALTTYP = 3       : # Alternative de nomenclature de sous-traitance
    [F:BOD]CPNTYP    = 7       : # Composant de type Service
    If dim([M:BOS2]BOMUOM(nolign-1))<0  |  [M:BOS2]BOMUOM(I)=""  # UML inactif ou unitûˋ non renseignûˋe
      [F:BOD]BOMUOM   =[M:BOS2]STU(I)
      [F:BOD]BOMSTUCOE=1
      If dim([M:BOS2]BOMQTY)>0 [F:BOD]BOMQTY=[M:BOS2]LIKQTY(I) Endif
    Endif
    Gosub INICRE_LIG From TABLEAUX
    Gosub WRITE_BOD From SUBBODA
    If fstat : GOK=0 : Call FSTA("BOD") From GLOCK : Break : Endif
    # Issue 94401 - 2014-01-27 by CCC : ITMBOM update
    J=GOK : GOK=1
    Call UPDLLC([M:BOH0]BOMALTTYP,[M:BOH0]BOMALT,[M:BOH0]ITMREF,[M:BOS2]CPNITMREF(I),[F:BOD]CPNTYP,+1)
    If GOK<1 : SYNCLLC=1 : Endif
    GOK=J
Next
Return

$MODIF_BOMS
# On supprime les anciens dûˋtails, et on recrûˋe les lignes
###  Delete [BOD] Where ITMREF=[M:BOH0]ITMREF & BOMALT=[M:BOH0]BOMALT & BOMALTTYP=3 & CPNTYP=7
###  Gosub CREATION_BOMS

#? Gosub DEFLIG
## Premiû´re passe, lignes annulûˋes
# Issue 77371 - 2011-11-23 by MUARN : fin avec deuxiû´me variable pour sous traitance
#For nolign=1 To MAXLIG
For nolign=1 To MAXLIG2
# Fin Issue 77371 - 2011-11-23 by MUARN : fin avec deuxiû´me variable pour sous traitance
 If !find(nolign,[M:BOS2]CREFLG(0..[M:BOS2]NBLIG-1))
  Readlock [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;OSEQS(nolign-1);OCPNS(nolign-1);[M:BOH0]BOMALTTYP
  If fstat=1
   GOK = -1
   GLOCK = "$BOMS"-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)-num$(OSEQS(nolign-1))-OCPNS(nolign-1)
   Break
  Elsif !fstat : # Au cas oû¿
   Delete [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;OSEQS(nolign-1);OCPNS(nolign-1);[M:BOH0]BOMALTTYP
   # Issue 118021 GH 07/09/2016 - delete the BOM lines records before updating ITMBOM records
   #Call UPDLLC([M:BOH0]BOMALTTYP,[M:BOH0]BOMALT,[M:BOH0]ITMREF,OCPNS(nolign-1),[F:BOD]CPNTYP,-1)
  Endif
 Endif
Next nolign
If GOK<1 : Return : Endif

For nolign=1 To MAXLIG2
 If !find(nolign,[M:BOS2]CREFLG(0..[M:BOS2]NBLIG-1))
   # Issue 94401 - 2014-01-27 by CCC : ITMBOM update
   J=GOK : GOK=1
   Call UPDLLC([M:BOH0]BOMALTTYP,[M:BOH0]BOMALT,[M:BOH0]ITMREF,OCPNS(nolign-1),0,-1)
   If GOK<1 : SYNCLLC=1 : Endif
   GOK=J
  Endif
Next

## Deuxiû´me passe, crûˋations et modifications
Raz [F:BOD] : # Issue 119341 GH 21/11/16 - reset to blank before transclass
For nolign=1 To [M:BOS2]NBLIG
 If [M:BOS2]BOMTEXNUM(nolign-1) <> ""
     Call CRE_CLOB([M:BOS2]BOMTEXNUM(nolign-1),GOK) From TRTX3TEX
     [F:BOD]BOMTEXNUM = [M:BOS2]BOMTEXNUM(nolign-1)
 Endif
 If [M:BOS2]CREFLG(nolign-1)=0  : # C'est une nouvelle ligne
  [F:BOD]          = [M:BOS2]
  [F:BOD]ITMREF    = [M:BOH0]ITMREF
  [F:BOD]BOMALT    = [M:BOH0]BOMALT
  [F:BOD]BOMALTTYP = [M:BOH0]BOMALTTYP
  Gosub INICRE_LIG From TABLEAUX
  Gosub WRITE_BOD  From SUBBODA
  If GOK<1 : Break : Endif
  #
  # Issue 94401 - 2014-01-27 by CCC : ITMBOM update
  J=GOK : GOK=1
  Call UPDLLC([M:BOH0]BOMALTTYP,[M:BOH0]BOMALT,[M:BOH0]ITMREF,[M:BOS2]CPNITMREF(nolign-1),[F:BOD]CPNTYP,+1)
  If GOK<1 : SYNCLLC=1 : Endif
  GOK=J
 Elsif [M:BOS2]UPDFLG(nolign-1)>0 : # La ligne a ûˋtûˋ modifiûˋe
  Readlock [BOD]BOD0=[M:BOH0]ITMREF;[M:BOH0]BOMALT;[M:BOS2]BOMSEQ(nolign-1);[M:BOS2]CPNITMREF(nolign-1);[M:BOH0]BOMALTTYP
  If fstat=1
   GOK = -1
   GLOCK = "$BOMS"-[M:BOH0]ITMREF-num$([M:BOH0]BOMALT)-[M:BOS2]CONCATKEY(nolign-1)
   Break
  Endif
  # on a virûˋ le texte
  # on ne vire jamais les textes sur les donnûˋes de base pour l'instant
  If [M:BOS2]BOMTEXNUM(nolign-1)="" & [F:BOD]BOMTEXNUM <> ""
#       Call SUP_CLOB([F:BOD]BOMTEXNUM,WRET) From TRTX3TEX
  Endif
  [F:BOD] = [M:BOS2]
  Gosub INIMOD_LIG  From TABLEAUX
  Gosub REWRITE_BOD From SUBBODA
  If GOK<1 : Break : Endif
  #
 Endif
Next nolign

Return

$VERIF_BOMS
# FQ 53781
Local Integer IBOMS
Local Char    WBOMUOM(GLONUOM)
For IBOMS=0 To [M:BOS2]NBLIG-1
   If [M:BOS2]LIKQTYCOD(IBOMS)=2
      If dim([M:BOS2]BOMUOM(IBOMS))<0  |  [M:BOS2]BOMUOM(IBOMS)=""  # UML inactif ou unitûˋ non renseignûˋe
         WBOMUOM   =[M:BOS2]STU(IBOMS)
      Else
         WBOMUOM   =[M:BOS2]BOMUOM(IBOMS)
      Endif
      If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif
      Read [TUN]TUN0=WBOMUOM
      If !fstat & [F:TUN]UOMDEC = 0 & !GIMPORT
      # "Quantitûˋ forfaitaire: l'unitûˋ choisie doit comporter des dûˋcimales pour permettre certains proratas."
         Call MESSAGE(WBOMUOM - mess(556,199,1)) From GESECRAN
      Endif
   Endif
Next

If [M:BOS2]NBLIG=0 & !(dim([L]TRTGBM)=1 & [L]TRTGBM="VALEVL")
     OK = 0
     GMESSAGE = mess(508,199,1) : # Au moins une prestation de sous-traitance doit ûˆtre choisie
     If !GIMPORT : Affzo [BOS2] : Endif
Endif
Return


######################################################################################
## Etiquette ajoutûˋe par le superviseur (ûˋcran BOS2) 04/07/2005 09:48:04 (GA)
######################################################################################
Subprog AVANT_NBLIG
End

Subprog APRES_NBLIG
If instr(1,dbgstr(1),"BOS2")      # Mode tableau
   [M:BOS2]UPDFLG(nolign-1) = 1
Endif
End

Subprog D_BOMSEQ(VALEUR)
Variable Decimal VALEUR
# initialisation selon le paramû´tre BOMSTE
If !GIMPORT
    If nolign > 1
       If instr(1,dbgstr(1),"BOS2")      # Mode tableau
          VALEUR = [M:BOS2]BOMSEQ(nolign-2) + GBOMSTE
       Endif
    Else
        VALEUR = GBOMSTE
    Endif
Endif
End

Subprog AS_BOMSEQ(VALEUR)
Variable Decimal VALEUR
If (GREP = "M" | GREP = "") & VALEUR <> 0
&            & (( instr(1,dbgstr(1),"BOS2") & [M:BOS2]CREFLG(nolign-1) > 0)
&             | ( instr(1,dbgstr(1),"BOS3") ))
   mkstat = 2
Endif
End

Subprog AS_CPNITMREF(VALEUR)
Variable Char    VALEUR()
# clûˋ non modifiable
If (GREP = "M" | GREP = "") & VALEUR <> "" & [M:BOS2]CREFLG(nolign-1) > 0
   mkstat = 2
Endif
End

Subprog C_CPNITMREF(VALEUR)
Variable Char    VALEUR()
#

End

Subprog AM_CPNITMREF(VALEUR)
Variable Char    VALEUR()
# Issue 77611 toujours vûˋrifier ...
#If (GREP = "C" | GREP = "D")
    Read [ITM2]ITM0=VALEUR
    If fstat : GOK=0 : Call FSTA("ITM2") From GLOCK : mkstat = 2 : End : Endif
#
    # autoriser uniquement les art de type sous-traitance
    # If [F:ITM2]SCSFLG <> 2 & !GIMPORT  # FQ 55649 GA 01/2010
    #If [F:ITM2]SCSFLG <> 2 # GH 06/05/2013 bug 89818
    # Issue 112531 - 2015-11-18 by MAE :type sous traitance : service + achetûˋ
    If [F:ITM2]SCSFLG <> 2 | [F:ITM2]PURFLG <> 2
        GMESSAGE = mess(510,199,1) : # "Article de type 'service' Obligatoire"
        # If find(GREP,"C","D") mkstat = 2 : End : Endif : # GH 06/05/2013
       mkstat=2 : End
    Endif
    If [F:ITM2]PHAFLG= 2 : # Issue 98871 GA 05/2014 no ghost
        GMESSAGE = mess(92,184,1) : # FantûÇme interdit !
       mkstat=2 : End
    Endif

   # Issue 94884 GA 12/2013 pas d'alerte en import/connecteur/etc ...
    If [F:ITM2]ITMSTA > 3 & !GIMPORT
       Local Integer WRET : WRET=2
       Call AVERTIR(mess(382,199,1),WRET) From GESECRAN
       If WRET <> 2 mkstat=2 : Endif
    Endif
   #
    If instr(1,dbgstr(1),"BOS2")      # Mode tableau
      # Issue 87115 - raz Issue 77611 GA 11/2012 Unitûˋ opûˋration = US de l'article lancûˋ
        If [M:BOS2]STU(nolign-1)   ="" : [M:BOS2]STU(nolign-1)=[M:BOH0]BOMSTU : Affzo [M:BOS2]STU(nolign-1) : Endif
        If [M:BOS2]LIKQTY(nolign-1)=0  : [M:BOS2]LIKQTY(nolign-1)=1        : Affzo [M:BOS2]LIKQTY(nolign-1)   : Endif
        If dim([M:BOS2]BOMQTY)>0              # UML actif
           If [M:BOS2]BOMQTY(nolign-1)=0  : [M:BOS2]BOMQTY(nolign-1)=1 : Endif
           Affzo [M:BOS2]BOMQTY(nolign-1)
        Endif
       # Unitûˋ sous-traitance = UA du Service (û  prendre sur [F:ITM2])
        If dim([M:BOS2]BOMUOM(nolign-1))>0    # UML actif
           If [M:BOS2]BOMUOM(nolign-1)="" : [M:BOS2]BOMUOM(nolign-1)=[F:ITM2]PUU : [M:BOS2]BOMSTUCOE(nolign-1)=[F:ITM2]PUUSTUCOE : Endif
           Call AM_BOMSTUCOE([M:BOS2]BOMSTUCOE(nolign-1) )       # Issue 87021 GA 01/2013
           Affzo [M:BOS2]BOMUOM(nolign-1): Affzo [M:BOS2]BOMSTUCOE(nolign-1)
        Else
           [M:BOS2]WBOMSTUCOE(nolign-1)=1
        Endif
    Elsif instr(1,dbgstr(1),"BOS3")      # Mode fiche
      # Issue 87115 - raz Issue 77611 GA 11/2012 Unitûˋ opûˋration = US de l'article Service
        If [M:BOS3]STU   ="" : [M:BOS3]STU=[M:BOH0]BOMSTU : Affzo [M:BOS3]STU      : Endif
        If [M:BOS3]LIKQTY=0  : [M:BOS3]LIKQTY=1        : Affzo [M:BOS3]LIKQTY   : Endif
        If dim([M:BOS3]BOMQTY)>0              # UML actif
           If [M:BOS3]BOMQTY=0  : [M:BOS3]BOMQTY=1 : Endif
           Affzo [M:BOS3]BOMQTY
        Endif
       # Unitûˋ sous-traitance = UA du Service (û  prendre sur [F:ITM2])
        If dim([M:BOS3]BOMUOM)>0              # UML actif
           If [M:BOS3]BOMUOM="" : [M:BOS3]BOMUOM=[F:ITM2]PUU : [M:BOS3]BOMSTUCOE=[F:ITM2]PUUSTUCOE  Endif
           Call AM_BOMSTUCOE([M:BOS3]BOMSTUCOE )       # Issue 87021 GA 01/2013
           Affzo [M:BOS3]BOMUOM : Affzo [M:BOS3]BOMSTUCOE
        Else
           [M:BOS3]WBOMSTUCOE=1
        Endif
   Endif
#Endif
End

Subprog D_BOMSTRDAT(VALEUR)
Variable Date    VALEUR
VALEUR = [M:BOH0]BOHSTRDAT
End

Subprog C_BOMSTRDAT(VALEUR)
Variable Date    VALEUR
  Call C_BOMSTRDAT(VALEUR) From SUBBOD
End

Subprog D_BOMENDDAT(VALEUR)
Variable Date    VALEUR
VALEUR = [M:BOH0]BOHENDDAT
End

Subprog C_BOMENDDAT(VALEUR)
Variable Date    VALEUR
  Call C_BOMENDDAT(VALEUR) From SUBBOD
End

Subprog AS_CSTFLG(VALEUR)
Variable Integer VALEUR
  Call AS_CSTFLG(VALEUR) From SUBBOD
End

######################################################################################
Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()

Local Integer    TYP
Local Char       WSTU(GLONUOM)

If instr(1,dbgstr(1),"BOS2")
    WSTU=[M:BOS2]STU(nolign-1)
Elsif  instr(1,dbgstr(1),"BOS3")
    WSTU=[M:BOS3]STU
Endif
If VALEUR = "" : VALEUR = WSTU : Endif

# Issue 77611 inutile voir trop contraignant ?
###TYP=0
