######################################################################################
Subprog IB_NBLIG
If [M:BOS2]CPNITMREF(nolign-1) <> ""
    GBOUT2 = mess(385,198,1) : # chgt nô¯ sûˋquence
Else
    GBOUT2 = ""
    GBOUT5 = "" # texte ligne  (dûˋsactivûˋ sur ligne vide 01/10/01)
Endif
If [M:BOH0]DATREF = [0/0/0]  GBOUT3 = mess(408,198,1) Else GBOUT3="" Endif
If find("GESITM", GNAVIG(1..GPILNAV)) Then
  GBOUT6=""
Endif
End

######################################################################################
Subprog IB_CPNITMREF
Call IB_NOTECHECK([M:BOH0]ITMREF,"ITMREF",3) From TRTNTSCTL # product notes
End
######################################################################################
## Issue 87115 GA 01/2013 remplace ancienne action LIKQTY, on calcule plutûÇt BOMSTUCOE
######################################################################################
Subprog AM_BOMQTY(VALEUR)
Variable Decimal VALEUR

# Issue 115658 - 2016-10-17 by CCC : Coefficient has to be calculated during import too
#If !GIMPORT
    If instr(1,dbgstr(1),"BOS2")      # Mode tableau
      If [M:BOS2]LIKQTY(nolign-1)=1 & VALEUR<>0  # Issue 87115 GA 01/2013
         Local Decimal WBOMSTUCOE :     WBOMSTUCOE = arr(1/VALEUR,10^-6)
         [M:BOS2]BOMSTUCOE(nolign-1)  = WBOMSTUCOE
         [M:BOS2]WBOMSTUCOE(nolign-1) = WBOMSTUCOE
         Affzo [M:BOS2]BOMSTUCOE(nolign-1)
      Else
         Call LIKQTY(VALEUR,[M:BOS2]WBOMSTUCOE(nolign-1),[M:BOS2]STU(nolign-1),"BOS2") From UOMLIB
         Affzo [M:BOS2]LIKQTY(nolign-1)
      Endif
    Elsif  instr(1,dbgstr(1),"BOS3")  # Mode fiche
      If [M:BOS3]LIKQTY=1 & VALEUR<>0  # Issue 87115 GA 01/2013
         Local Decimal WBOMSTUCOE :     WBOMSTUCOE = arr(1/VALEUR,10^-6)
         [M:BOS3]BOMSTUCOE            = WBOMSTUCOE
         [M:BOS3]WBOMSTUCOE           = WBOMSTUCOE
         Affzo [M:BOS3]BOMSTUCOE
      Else
         Call LIKQTY(VALEUR,[M:BOS3]WBOMSTUCOE,[M:BOS3]STU,"BOS3") From UOMLIB
         Affzo [M:BOS3]LIKQTY
      Endif
    Endif
#Endif
End

######################################################################################
# Issue 94401 - 2014-01-27 by CCC : ITMBOM update
Subprog UPDLLC(PALTTYP, PALT,PITM, PCPN, PCPNTYP, PSIGN)
Value Integer PALTTYP
Value Integer PALT
Value Char    PITM
Value Char    PCPN
Value Integer PCPNTYP
Value Integer PSIGN

# Issue 118298 GH 05/09/2016 -  don't generate ITMBOM records with no ITMREF
If PCPN="" : End : Endif

Local Integer WRET

# La variable PSIGN vaut +1 ou -1 selon
# qu'il s'agit d'une crûˋation ou d'une annulation
# L'enregistrement "ligne" est en ligne
# Mû j de ITMBOM pour composants(code plus bas niveau, cas d'utilis.)
Local Integer AUTREBOH
Local Integer NIVEGAL
Local Char    BOHEGAL(20)
# sr 04.02 perte des textes en renumûˋrotation  demande 13861
Local Integer I, WOK_SUPP_TEXTE
Local Integer WLLCTYP, OLDLLC, LLCMAX, LLCITM
Local  Char    BOHMAX(GLONITM) : # article maûÛtre pour LLCMAX (en annulation)
Local Char    FLTBOM(50)

If clalev([F:ITB])=0 : Local File ITMBOM [ITB] : Endif

WLLCTYP = func LLCLIB.LLCTYP(PALTTYP)

Read [ITB]ITB0=PITM;PALT;WLLCTYP
If fstat
    GOK=0
    Call RSTA("ITB",PITM-num$(PALT)-num$(WLLCTYP)) From GLOCK
    End
Endif
LLCITM = [F:ITB]LLC

If PSIGN = +1
    # Lecture LLC du composant
     Readlock [ITB]ITB0 = PCPN;PALT;WLLCTYP
     If fstat = 5
       Raz [F:ITB]
       [F:ITB]ITMREF = PCPN
       [F:ITB]BOMALT = PALT
       [F:ITB]LLCTYP = WLLCTYP
       [F:ITB]BOHITM = PITM
       [F:ITB]BOMEXIFLG = 1
       [F:ITB]WUSEXIFLG = 2
       # Issue 104223 - 2015-03-30 by CCC : If by-product => LLC=0
       If PCPNTYP=4 : [F:ITB]LLC = 0
       Else         : [F:ITB]LLC = LLCITM + 1
       Endif
       [F:ITB]CREDAT    = date$
       [F:ITB]CREUSR    = GUSER
       Write [ITB]
     Elsif fstat = 1  : # enreg dûˋjû  lockûˋ
       GOK = -1 : GLOCK = "$ITMBOM"-[F:ITB]ITMREF-num$([F:ITB]BOMALT)-num$([F:ITB]LLCTYP) : End    # llc 07.01 9881
     # Elsif PCPNTYP <> 4       # Issue 104223 - 2015-04-02 by CCC : If by-product, don't change LLC
       Elsif !fstat & [F:ITB]LLC < LLCITM+1 & PCPNTYP<>4
           [F:ITB]WUSEXIFLG = 2
           [F:ITB]LLC = LLCITM + 1
           [F:ITB]BOHITM = PITM
           Rewrite [ITB]
           If [F:ITB]BOMEXIFLG=2 # Issue 118021 GH 07/09/2016 - optimization
              GNIV = 1 : # car on part du composant en lanûÏant le sous-pro
              GBOHLLC = LLCITM
              Call CALCLLC(PCPN,PALT,PALTTYP,"+") From LLCLIB
           Endif
         Elsif !fstat & [F:ITB]LLC = LLCITM+1 & !find([F:ITB]BOHITM,"",PITM)
            # Issue 118021 GH 07/09/2016 - optimization : # [F:ITB]BOHITM<>PITM
            #                            - should be done for a component used as a by product
           [F:ITB]BOHITM = "" : # plusieurs liens au mûˆme LLC
           Rewrite [ITB]
         Elsif !fstat & [F:ITB]LLC=0 & PCPNTYP=4
           # Issue 118021 GH 07/09/2016 - addition of a by-product, already compound but not component
           #                                                     or already used once as a by-product
           If [F:ITB]WUSEXIFLG<>2
              [F:ITB]WUSEXIFLG = 2
              [F:ITB]BOHITM = PITM
              Rewrite [ITB]
           Elsif !find([F:ITB]BOHITM,"",PITM)
              [F:ITB]BOHITM = PITM
              Rewrite [ITB]
           Endif
         Endif
     # Endif
Else   : # cas de l'annulation  PSIGN  = -1
 If PCPNTYP=-4
   # Issue 118021 GH 07/09/2016 - The component becomes by-product, but there is another line for the same BOM
   #                              with the same component not by-product => nothing to change
   Filter [BOD2] Where CPNTYP<>4
   Look [BOD2]BOD3(4) = PALT;PCPN;PALTTYP;PITM
   Filter [BOD2]
 Else
   # Issue 118021 GH 07/09/2016 - If the component used in several lines of the same BOM is not totally deleted
   #                              => nothing to change
   Look [BOD2]BOD3(4) = PALT;PCPN;PALTTYP;PITM
 Endif
 If fstat<=2 : End : Endif

# Lecture LLC du composant otûˋ
 Readlock [ITB]ITB0 = PCPN;PALT;WLLCTYP
 If !fstat : OLDLLC = [F:ITB]LLC : Else End: Endif          # FQ 67833 GA 10/2010 sortir si ligne [F:ITB] dûˋja supprimûˋe (cf ANNULE)
# S'il existe un lien avec niveau plus bas : Rien faire
 If OLDLLC > LLCITM + 1 : Unlock [ITB] : End : Endif

# Issue 118021 GH 07/09/2016 - The component becomes by-product, still consider the parent item is correct
 If PCPNTYP=-4
    BOHMAX=[F:ITB]BOHITM
 Endif
# Issue 118021 GH 07/09/2016 - consider the right BOM type
 Case WLLCTYP
    When 1 : FLTBOM   =  "BOMALTTYP=1"
    When 2 : FLTBOM   =  "BOMALTTYP>="+num$(WLLCTYP)
 Endcase
 For [BOD2]BOD3 Where CPNITMREF=PCPN & BOMALT=PALT & evalue(FLTBOM)
# Issue 118021 GH 07/09/2016 - It can be used by compound PITM but for another type of BOM
#  If [F:BOD2]ITMREF <> PITM #| [F:BOD2]BOMSEQ <> OSEQ(nolign-1)
     AUTREBOH += 1
#  Endif
#  If [F:BOD2]ITMREF <> PITM
     # Issue 118021 GH 07/09/2016 - The component becomes by-product, the LLC calculated previously is to forget
     If [F:BOD2]ITMREF=PITM & [F:BOD2]BOMALTTYP=PALTTYP & PCPNTYP=-4
        fstat=5
     Else
        Read [ITB]ITB0=[F:BOD2]ITMREF;[F:BOD2]BOMALT;WLLCTYP
     Endif
# Issue 104223 - 2015-03-30 by CCC : by-product -> LLC=0
#     If !fstat & [F:ITB]LLC+1 > LLCMAX
#         LLCMAX = [F:ITB]LLC + 1
     If !fstat & [F:BOD2]CPNTYP<>4 & [F:ITB]LLC+1 > LLCMAX
         LLCMAX = [F:ITB]LLC+1
         BOHMAX = [F:BOD2]ITMREF
     Endif
     If !fstat & [F:ITB]LLC+1 = LLCMAX & AUTREBOH > 1 & [F:ITB]ITMREF <> BOHMAX
         BOHMAX = "" : # dû´s qu'il y en a 2 au mûˆme niveau
     Endif
     If !fstat & [F:ITB]LLC+1 = OLDLLC : # mûˆme niv que le lien otûˋ
         BOHEGAL = [F:BOD2]ITMREF
         NIVEGAL += 1
     Endif
#  Endif
 Next
 Readlock [ITB]ITB0 = PCPN;PALT;WLLCTYP
 If fstat = 1  : # enreg dûˋjû  lockûˋ
    GOK=-1 : GLOCK="$ITMBOM"-PCPN-num$(PALT)-num$(WLLCTYP) : End
 Elsif fstat =0
    If AUTREBOH = 0
      If [F:ITB]BOMEXIFLG = 2
          [F:ITB]LLC       = 0
          [F:ITB]WUSEXIFLG = 1
          [F:ITB]BOHITM    = ""
          Rewrite [ITB]
          If fstat > 2
             GOK = 0 : End
          Endif
          GNIV = 0 : # ce n'est plus un composûˋ !
          GBOHLLC = 0
          Call CALCLLC(PCPN,PALT,PALTTYP,"-") From LLCLIB
          If GOK = -1 : End : Endif
      Else
          # plus de cas d'emploi ni composant ni composûˋ, on supprime (bug 7523)
          Delete [ITB]
      Endif
    Elsif LLCMAX < OLDLLC
#     -> mettre û  jour le LLC du composant otûˋ et de ses sous-composants
#       sauf s'il le niveau trouvûˋ est identique û  l'ancien
      [F:ITB]LLC    = LLCMAX
      [F:ITB]BOHITM = BOHMAX
      Rewrite [ITB]
      If fstat > 2 : GOK = 0 : End : Endif
      GNIV = 1
      GBOHLLC = LLCMAX - 1
      Call CALCLLC(PCPN,PALT,PALTTYP,"-") From LLCLIB
      If GOK = -1 : End : Endif
    Elsif LLCMAX = OLDLLC & NIVEGAL = 1 : # un seul autre lien de mûˆme LLC
      [F:ITB]BOHITM = BOHEGAL
      Rewrite [ITB]
      If fstat > 2 : GOK = 0 : End : Endif
    Else : # en principe impossible
      Unlock [ITB]
    Endif
 Endif
Endif

End

