###      If dim([M:BOS2]BOMQTY)>0    [M:BOS2]BOMQTY(nolign-1)   =[M:BOS2]LIKQTY(nolign-1) Endif
###  Elsif  instr(1,dbgstr(1),"BOS3")
###      If dim([M:BOS3]BOMSTUCOE)>0 [M:BOS3]BOMSTUCOE=1               Endif
###      If dim([M:BOS3]BOMQTY)>0    [M:BOS3]BOMQTY   =[M:BOS3]LIKQTY  Endif
###  Endif
###  mkstat=2
###Endif

End

######################################################################################

Subprog C_BOMUOM(VALEUR)
Variable Char    VALEUR()

If !GIMPORT
   If VALEUR = ""
      GMESSAGE = mess(10,123,1) : mkstat = 2 : End
   Endif
   # FQ 53781 ajout d'un ctrl non bloquant
   If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif
   Read [TUN]TUN0=VALEUR
   If !fstat & [F:TUN]UOMDEC = 0
&            & (( instr(1,dbgstr(1),"BOS2") & [M:BOS2]LIKQTYCOD(nolign-1)=2)
&             | ( instr(1,dbgstr(1),"BOS3") & [M:BOS3]LIKQTYCOD=2))
   # "Quantitûˋ forfaitaire: l'unitûˋ choisie doit comporter des dûˋcimales pour permettre certains proratas."
      GMESSAGE = mess(556,199,1)
   Endif
Endif
End

######################################################################################
# Note : voir action BOMCOE sur le champ pour recherche du coef de conversion
#        entre BOMUOM et STU (ûˋventuellement repris sur l'article Service)
######################################################################################
Subprog AM_BOMUOM(VALEUR)
Variable Char    VALEUR()

If !GIMPORT
    If instr(1,dbgstr(1),"BOS2")      # Mode tableau
      If [M:BOS2]BOMUOM(nolign-1)<>VALEUR
        # Issue 77611 ne pas Raz les zones dûˋjû  saisies
        #If dim([M:BOS2]BOMQTY)>0 [M:BOS2]BOMQTY(nolign-1)=0 : Affzo [M:BOS2]BOMQTY(nolign-1) : Endif
        #[M:BOS2]LIKQTY(nolign-1)=1  : Affzo [M:BOS2]LIKQTY(nolign-1)
      Endif
    Elsif  instr(1,dbgstr(1),"BOS3")  # Mode fiche
      If [M:BOS3]BOMUOM<>VALEUR
        # Issue 77611 ne pas Raz les zones dûˋjû  saisies
        #If dim([M:BOS3]BOMQTY)>0 [M:BOS3]BOMQTY=0 : Affzo [M:BOS3]BOMQTY : Endif
        #[M:BOS3]LIKQTY=1  : Affzo [M:BOS3]LIKQTY
      Endif
    Endif
Endif

End
######################################################################################
Subprog AM_BOMSTUCOE(VALEUR)             # FQ 77611 GA 11/2011 BOMSTUCOE saisissable
Variable Decimal    VALEUR
# Issue 115658 - 2016-10-17 by CCC : Coefficient has to be calculated during import too
#If !GIMPORT
    If instr(1,dbgstr(1),"BOS2")      # Mode tableau
      [M:BOS2]WBOMSTUCOE(nolign-1) = VALEUR
      If [M:BOS2]LIKQTY(nolign-1)=1 & VALEUR<>1   # Issue 86856 & 87115 GA 01/2013
         Call BOMQTY([M:BOS2]LIKQTY(nolign-1),VALEUR,"BOS2") From UOMLIB
         Affzo [M:BOS2]BOMQTY(nolign-1)
      Else
         Call LIKQTY([M:BOS2]BOMQTY(nolign-1),[M:BOS2]WBOMSTUCOE(nolign-1),[M:BOS2]STU(nolign-1),"BOS2") From UOMLIB
         Affzo [M:BOS2]LIKQTY(nolign-1)
      Endif
    Elsif  instr(1,dbgstr(1),"BOS3")  # Mode fiche
      [M:BOS3]WBOMSTUCOE = VALEUR
      If [M:BOS3]LIKQTY=1 & VALEUR<>1             # Issue 86856 & 87115 GA 01/2013
         Call BOMQTY([M:BOS3]LIKQTY,VALEUR,"BOS3") From UOMLIB
         Affzo [M:BOS3]BOMQTY
      Else
         Call LIKQTY([M:BOS3]BOMQTY,[M:BOS3]WBOMSTUCOE,[M:BOS3]STU,"BOS3") From UOMLIB
         Affzo [M:BOS3]LIKQTY
      Endif
    Endif
#Endif

End
######################################################################################
# Issue 87021 code inutile:l'ûˋcran appelle directement l'action BOMQTY
###Subprog AM_LIKQTY(VALEUR)                # FQ 77611 GA 11/2011
###Variable Decimal VALEUR
###If instr(1,dbgstr(1),"BOS2")
###    If [M:BOS2]CPNTYP(nolign-1) <> 1 : mkstat = 1 : End : Endif
