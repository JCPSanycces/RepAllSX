#92876_US2757
$SAICCE
If [M]DSPTYP="£" : mkstat=1 : Return : Endif
#Call LECTURE("TIM",[M]TIM,"") From CONTOBJ
#If [F:TIM]CCEDAC(AXE-1)<>2
# mkstat = 2 : End
#Endif
If AXE>[M:VTL]NBDIE : mkstat=1 : Return : Endif
Local Char SAU_GSOCIETE(GLONCPY)
SAU_GSOCIETE=GSOCIETE
If clalev([F:TIP])=0  : Local File TIMEMP    [TIP]  : Endif
#Control if the dimension type is following by the company (site)
Local Integer OK, J
Call CPY_AXE (AXE, [M]FCY, OK) From TPSDIV

If !OK
 GMESSAGE=[M]INTDIE(AXE-1)+" : "+mess(75,103,1) : # Axe incompatible avec ce site
 mkstat =   1 : Return
Endif
#Control if the dimension type is following by the time event
#ADNGO - 2017-01-26 - X3-11347 - START
#Call LECTURE("TIM",[M]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[M]TIM,GCURLEG) From CONTOBJ
#ADNGO - 2017-01-26 - X3-11347 - END
J=find([M:VTL]VDIE(AXE-1),[F:TIM]DIE(0..dim([F:TIP]DIE)-1))
If J
 GSOCIETE=func DIVPAYE.GETSOC([M]FCY)
 If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
 If [F:TIM]CCEDAC(J-1)<>2
  VALEUR = ""
  Call INICCE("",[M]TIM,J,VALEUR) From TPSDIV
  GSOCIETE=SAU_GSOCIETE
  mkstat = 2 : Return
 Endif
 If [F:TIM]CCEDAC(J-1)=2 & VALEUR=""
  Call INICCE("",[M]TIM,J,VALEUR) From TPSDIV
 Endif
 GSOCIETE=SAU_GSOCIETE
Endif
Return

