#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..16) , VALEUR(10)
Local Decimal PTV,PTF
PARAM(1)  = "%"
PARAM(2)  = "[M]PTV"
PARAM(3)  = "[M]PTF"
PARAM(4)  = num$(100)
PARAM(5)  = num$(3)
PARAM(6)  = num$(1000)
Call SAISIE_CHAR(VALEUR,PARAM,"TPSVENT","TPSVENT","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "DEBUT"   : Gosub DEBUT
 When "SETBOUT" : Gosub SETBOUT
 When "END"     :               mkstat=2
 When "OK"      : Gosub ENREG
 When "FIN"     : Gosub FIN
 When Default
Endcase
Return


$OUVRE
Local Char     TYPREP   : # Type de répartition %, $, £ ou répatition connue
Local Char     PTV      : # Pointeur début
Local Char     PTF      : # Pointeur fin
Local Integer  NBPTV    : # Nb de lignes de ventilation
Local Integer  NOL      : # No de la ligne d'écriture
Local Decimal  MONTANT  : # Montant à répartir

Local Integer  I, J
Local Shortint NBLIG, PTVD, PTVF, NBVENT
Local Char     CLEREP(10)

#92876_US2757
If clalev([F:CDT])=0  : Local File CADIETPS    [CDT]  : Endif
If clalev([F:STH])=0  : Local File SCRTPSH   [STH]  : Endif
Local Integer NBAXE

## sauvegarde du contexte si "consultation" (param(1)="£")
If left$(PARAM(1),1)="£"
 Local Integer OCONSULT, I
 Local Char    OBOUT(50)(1..12)
 OCONSULT = GCONSULT
 For I=1 To dim(OBOUT)
  OBOUT(I) = evalue("GBOUT"+num$(I))
 Next I
Endif
Return

$DEBUT
# Initialiation des variables

TYPREP  = PARAM(1)
NBPTV   = val(PARAM(4))
NOL     = val(PARAM(5))
MONTANT = val(PARAM(6))

CLEREP = right$(TYPREP,2)
TYPREP = left$(TYPREP,1)



# Mémorisation du pointeur début et pointeur fin
NBLIG=evalue("dim("+PARAM(2)+")")
Local Decimal PTV(NBLIG)
Local Decimal PTF(NBLIG)

For I=0 To NBLIG-1
 PTV(I) = evalue(PARAM(2)+"("+num$(I)+")")
 PTF(I) = evalue(PARAM(3)+"("+num$(I)+")")
Next

NBVENT = GMAXVANA
PTVD   = PTV(NOL)
PTVF   = PTF(NOL)

## récupération de la clé de répartition si celle ci est une clé existante (autre que $,%)
## remarque : si TYPREP="£" alors VALEUR=0 (son type est DCB --> plantage)
If TYPREP<>"£" & type(VALEUR)>10 & VALEUR<>"" & VALEUR<>"$" : TYPREP += VALEUR : Endif

# contrôles
If PTVD = 0
 If [M:VT2]PTVENT+NBVENT>dim([M:VT2]TBAMT)
 #ADNGO - 2017-01-12 - X3-11347 - START
  #GMESSAGE = mess(43,709,1) : # Trop de ventilations analytiques
  GMESSAGE = mess(43,10709,1) : # Trop de ventilations analytiques
 #ADNGO - 2017-01-12 - X3-11347 - END
  GERR = 1 : FIN = 1 : Return
 Endif
Endif

# Affichage
Effzo [VTL]10-40
[M:VTL]FCY = PARAM(7)
[M:VTL]DAT = PARAM(8)
[M:VTL]TIM = PARAM(9)
[M:VTL]DSPTYP  = left$(PARAM(1),1)
[M:VTL]TOTREP  = val(PARAM(6))

#92876_US2757
## Identifie le nombre des axes à gérer
If dim([M:VTL]NBDIE)>=0
 Read[F:STH]STH0=GFLAG
 If !fstat & [F:STH]CODCDT<>""
  Read [CDT]CDT0=[F:STH]CODCDT
  If ! fstat
   [M:VTL]NBDIE=[F:CDT]NBRDIE
   For NBAXE=0 To [M:VTL]NBDIE-1
    [M:VTL]VDIE(NBAXE)=[F:CDT]DIE(NBAXE)
    # Affiché ou saisie
    If [F:CDT]OPT(NBAXE)=2
     [M:VTL]DIEFMT(NBAXE)="KP:"
    Else
     [M:VTL]DIEFMT(NBAXE)="K:"
    Endif
    Call INICCEFMT([F:CDT]DIE(NBAXE)) From SETGLBDIE
    [M:VTL]DIEFMT(NBAXE)+=GCCEFMT
    Call LECTEXTRA([M:VTL]INTDIE([L]NBAXE),"GDIE","COLHEA",[M:VTL]VDIE([L]NBAXE),"") From ATEXTRA
   Next
  Endif
 Endif
Endif

Gosub CHG_FMT From W1TPSVENT

I = 0
If PTVD<>0
 For J=PTVD To PTVF
  [M:VTL]AMT(I) = [M:VT2]TBAMT(J)
  If [M:VTL]TOTREP<>0
   [M:VTL]PRC(I) = ar2([M:VTL]AMT(I)*100/[M:VTL]TOTREP)
  Endif
 #92876_US2757
 #For K=1 To GOPTCANA
  For K=1 To [M:VTL]NBDIE
   If K>GOPTCANA : Break : Endif
   #Il faut récupérer uniquement les valeurs des axes correspondant à ceux affichés
   Assign "[M:VTL]CCE"+num$(K)+"("+num$(I)+")" With evalue("[M:VT2]TBCCE"+num$(K)+"("+num$(J)+")")
  Next K
  I += 1
 Next J

Elsif CLEREP<>""
 Call CHARGE_VTE(CLEREP)
 I = [M:VTL]BAS
 [M:VTL]DSP = CLEREP
Endif
[M:VTL]BAS = I
[M:VTL]TOTAL  = sum([M:VTL]AMT(0..I-1))
Affzo [VTL]10-40
If GCONSULT<>0 : Grizo [VTL] : Endif
#--- Positionnement des paramètres de saisie analytique
#Call SETANA([M:VTL]FCY) From SETANASAI
Return



$SETBOUT
If left$(PARAM(1),1) = "£"
 ETABOU(GVALI) = 0
Else
 ETABOU(GVALI) = 1
Endif
Return

$ENREG
If GCONSULT=0
 If [M:VTL]TOTAL<>[M:VTL]TOTREP
 #ADNGO - 2017-01-12 - X3-11347 - START
  #GMESSAGE = mess(54,709,1) : # Total des ventilations incorrect
  GMESSAGE = mess(54,10709,1) : # Total des ventilations incorrect
 #ADNGO - 2017-01-12 - X3-11347 - END
  GERR = 1 : FIN=0 : Return
 Else
  Gosub VALVENT
 Endif
Endif

PTV(NOL) = PTVD
PTF(NOL) = PTVF
# Mise à jour du pointeur début et pointeur fin
For I=0 To NBLIG-1
 Assign PARAM(2)+"("+num$(I)+")" With PTV(I)
 Assign PARAM(3)+"("+num$(I)+")" With PTF(I)
Next
nolign = NOL+1
FIN = 1 : ## sort de la fenetre
If type(VALEUR)>10
 VALEUR = "$"
Endif
Return

$VALVENT
If [M:VT2]PTVENT=0 : [M:VT2]PTVENT=1 : Endif
If PTVD=0
 PTVD = [M:VT2]PTVENT
 [M:VT2]PTVENT += [M:VTL]BAS
Elsif [M:VTL]BAS>PTVF-PTVD+1
 Call ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVF-PTVD+1)
 #102487
 #PTVD = [M:VT2]PTVENT
 PTVD = [M:VT2]PTVENT+1
 #
 [M:VT2]PTVENT += [M:VTL]BAS
Elsif [M:VTL]BAS<PTVF-PTVD+1
 Call ANUVENTIL(PTV,PTF,NBPTV,PTVD,PTVF-PTVD+1-[M:VTL]BAS)
Endif
PTVF = PTVD+[M:VTL]BAS-1
For I=0 To [M:VTL]BAS-1
 [M:VT2]TBAMT(PTVD+I) = [M:VTL]AMT(I)

 #92876_US2757
 #For K=1 To GOPTCANA
 For K=1 To [M:VTL]NBDIE
  If K>GOPTCANA : Break : Endif
   Assign "[M:VT2]TBCCE"+num$(K)+"("+num$(PTVD+I)+")"  With evalue("[M:VTL]CCE"+num$(K)+"("+num$(I)+")")
 Next K
Next I
Return

$FIN
## restaure du contexte si "consultation" (param(1)="£")
If left$(PARAM(1),1)="£"
 GCONSULT = OCONSULT
 For I=1 To dim(OBOUT)
  Assign "GBOUT"+num$(I) With OBOUT(I)
 Next I
Endif
# Pour passer en modif en retour du clic droit sur un champ de bloc liste et dégriser le bouton enregistrer
If GSTATUT=GSTAOK : mkstat = 4 : Endif
Return


$SETNOL
NOL=nolign-1
Return


###########################################################
## Masque VENTILE
###########################################################
Subprog AS_PRC(PCENT)
Variable Decimal PCENT
If [M]DSPTYP<>"%" : mkstat=2 : Endif
End

Subprog C_PRC(PCENT)
Variable Decimal PCENT
Gosub SETNOL
[M]PRC(NOL) = PCENT
Gosub TOTTBL
End

Subprog AS_AMT(MONT)
Variable Decimal MONT
If [M]DSPTYP="%" | [M]DSPTYP="£" : mkstat=2 : End : Endif
End

Subprog AP_AMT(MONT)
Variable Decimal MONT
Gosub SETNOL
[M:VTL]AMT(NOL) = MONT
If [M:VTL]TOTREP<>0
 [M:VTL]PRC(NOL) = ar2([M:VTL]AMT(NOL)*100/[M:VTL]TOTREP)
 Affzo PRC(NOL)
Endif
Gosub TOTTBL
End

Subprog B2_AMT(MONT)
Variable Decimal MONT
Gosub SETNOL
MONT = [M]TOTREP - sum([M]AMT(0..NOL-1)) - sum([M]AMT(NOL+1..[M]BAS-1))
End

Subprog AP_DSP(VALEUR)
Variable Char VALEUR
If VALEUR="" : End : Endif
Local Integer NOL
Call CHARGE_VTE(VALEUR)
Affzo 20-40
NOL = [M]BAS-1
Gosub TOTTBL
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR
If [M]BAS<>0 : mkstat=2 : Endif
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
End

Subprog AS_BAS
If find(status,65,68,83,71)
 Local Integer NOL : NOL=-1
 Gosub TOTTBL
Endif
If [M]DSPTYP = "£" : mkstat=2 : Endif
End

Subprog C_BAS
If status>=65 & status<=90
 # On reste dans le tableau
Elsif status<>7 & status<1792
 Call CONTVENT
Endif
End

