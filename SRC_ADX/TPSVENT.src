#92876_US2757
$INICCE
If AXE>[M:VTL]NBDIE : Return : Endif
Local Integer OK
Local Integer AXE_CCE
Call CPY_AXE (AXE, [M:VTL]FCY, OK) From TPSDIV
If OK
 Local Char SAU_GSOCIETE(GLONCPY)
 SAU_GSOCIETE=GSOCIETE
 GSOCIETE=func DIVPAYE.GETSOC([M]FCY)
 If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
 # FQ92876 - 26/09/14 - Il faut initialiser la section en fonction de l'axe
# Call INICCE("",[M]TIM,AXE,VALEUR) From TPSDIV
 If clalev([F:TIM])=0  : Local File TIMCOD    [TIM]  : Endif
 #ADNGO - 2017-01-12 - X3-11347 - START
 #Call LECTURE("TIM",[M]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[M]TIM,GCURLEG) From CONTOBJ
 #ADNGO - 2017-01-12 - X3-11347 - END
 AXE_CCE=find([M:VTL]VDIE(AXE-1),[F:TIM]DIE)
 If AXE_CCE Then
   Call INICCE("",[M]TIM,AXE_CCE,VALEUR) From TPSDIV
 Endif
 # Fin FQ92876
 GSOCIETE=SAU_GSOCIETE
Endif
Return

