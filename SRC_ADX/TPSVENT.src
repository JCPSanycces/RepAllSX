#92876_US2757
If AXE>[M]NBRDIE : End : Endif
Gosub SETNOL
Call CONTCCEOBG (VALEUR,AXE) From TPSDIV
If mkstat : End : Endif
Call CONTCCE(VALEUR,AXE,[M]FCY,[M]DAT,[M]TIM,"[M]CCE#",NOL) From TPSSTD
If mkstat : End : Endif
Return

#################################################################
$TOTTBL
If [M]DSPTYP="%"
 Local Decimal SOMPOUR , SOMP , ARONDI
 Local Integer I, N
 ARONDI = 0.01
 N = max(NOL+1,[M]BAS)-1
 SOMPOUR = sum([M]PRC(0..N))
 If SOMPOUR<>0
  SOMP=0
  For I=0 To N
   [M]AMT(I) = arr((SOMP+[M]PRC(I))*[M]TOTREP/SOMPOUR,ARONDI)
&             -arr(SOMP*[M]TOTREP/SOMPOUR,ARONDI)
   SOMP += [M]PRC(I)
  Next I
 Else
  SOMPOUR=0
  For I=0 To N
   If [M]PRC(I)>0 : SOMPOUR += [M]PRC(I) : Endif
  Next I
  If SOMPOUR<>0
   SOMP=0
   For I=0 To N
    If [M]PRC(I)>0
     [M]AMT(I) = arr((SOMP+[M]PRC(I))*[M]TOTREP/SOMPOUR,ARONDI)
&               -arr(SOMP*[M]TOTREP/SOMPOUR,ARONDI)
     SOMP += [M]PRC(I)
    Endif
   Next I
  Endif
  SOMPOUR=0
  For I=0 To N
   If [M]PRC(I)<0 : SOMPOUR -= [M]PRC(I) : Endif
  Next I
  If SOMPOUR<>0
   SOMP=0
   For I=0 To N
    If [M]PRC(I)<0
     [M]AMT(I) =-arr((SOMP-[M]PRC(I))*[M]TOTREP/SOMPOUR,ARONDI)
&               +arr(SOMP*[M]TOTREP/SOMPOUR,ARONDI)
     SOMP -= [M]PRC(I)
    Endif
   Next I
  Endif
 Endif
 [M]TOTAL  = sum([M]AMT(0..N))
 Affzo AMT,TOTAL
Elsif [M]DSPTYP="$"
 N = max(NOL+1,[M]BAS)-1
 [M]TOTAL = sum([M]AMT(0..N))
 Affzo TOTAL
Endif
Return

