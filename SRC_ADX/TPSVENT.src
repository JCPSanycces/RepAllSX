End


Subprog CHARGE_VTE(RPA)
Value Char    RPA
Local Decimal SUMP , SUMPOI , ARONDI
ARONDI = 0.01
Local Integer I , N , K
If clalev([F:TIP])=0  : Local File TIMEMP    [TIP]  : Endif :#92876_US2757
Raz SUMPOI, SUMP
[M:VTL]BAS = 0
I = 0
For [DSP]DSP0 Where DSP=[L]RPA
 I += 1

#92876_US2757
# For K=1 To GOPTCANA
 For K=1 To [M:VTL]NBDIE
  #103311 : Il faut récupérer uniquement les axes de la DSP correspondant à ceux affichés
  If find([F:DSP]DIE(K-1),[M:VTL]VDIE)
   Assign "[M:VTL]CCE"+num$(K)+"("+num$(I-1)+")" With evalue("[F:DSP]CCE"+num$(K))
  Endif
 Next
 [M:VTL]PRC(I-1) = [F:DSP]COE
 SUMPOI += [F:DSP]COE
 [M:VTL]BAS += 1
 If I>=GMAXVANA : Break : Endif
Next
If SUMPOI<>0
 For I=0 To [M:VTL]BAS-1
  [M:VTL]AMT(I) = arr([M:VTL]TOTREP*(SUMP+[M:VTL]PRC(I))/SUMPOI,ARONDI)
&            -arr([M:VTL]TOTREP*SUMP/SUMPOI,ARONDI)
  SUMP += [M:VTL]PRC(I)
  If [M:VTL]TOTREP<>0
   [M:VTL]PRC(I) = ar2([M:VTL]AMT(I)*100/[M:VTL]TOTREP)
  Endif
 Next I
Endif
End

Subprog CONTVENT
Local Integer I, J
Local Char    BID(20)
For J=1 To [M:VTL]BAS
 For I=1 To GOPTCANA
  BID = evalue("[M:VTL]CCE"+num$(I)+"("+num$(J-1)+")")
  Call CONTCCE(BID,I,[M:VTL]FCY,[M:VTL]DAT,[M:VTL]TIM,"[M:VTL]CCE#",J-1) From TPSSTD
  If mkstat : Break 2 : Endif
 Next I
Next J
If mkstat
#ADNGO - 2017-01-12 - X3-11347 - START
 #GMESSAGE = mess(55,709,1)-num$(J)-":\"+GMESSAGE : # Ligne no
 GMESSAGE = mess(55,10709,1)-num$(J)-":\"+GMESSAGE : # Ligne no
#ADNGO - 2017-01-12 - X3-11347 - END
Endif
End

