#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################################################################################
# Affectation des valeurs pour la création d'un contrat de garantie depuis la saisie d'une livraison de vente
######################################################################################################################
$SET_HEA_INFO
  # FGR 29/04/2008 : X3SUIVI46864
  Case IMPZON
    When "CONNUM"  #[M:CON0]
    When "CPY"
      # FGR 16/06/2008 : X3SUIVI48039 Déduire la société du site ... (début)
      #If [M:CON0]CPY = "" Then    # FGR 19/11/2010 : X3SUIVI69227
      If [M:MACW]CPY <> "" Then    # FGR 19/11/2010 : X3SUIVI69227
        [M:CON0]CPY = [M:MACW]CPY
      Endif
      # FGR 16/06/2008 : X3SUIVI48039 Déduire la société du site ... (fin)
    When "SALFCY"
      [M:CON0]SALFCY = [M:MACW]SALFCY
    When "CONBPC"
      [M:CON0]CONBPC = [M:MACW]BPCNUM
    When "CUR"
      [M:CON0]CUR = [M:MACW]CUR
    When "CONCCN"

    ######################################
    #[M:CON1]
    When "CONNAM"
      [M:CON1]CONNAM = GSZWARNAMRULE
      [M:CON0]COVLOWLEV = 1
      [M:CON1]CONORI = 3
      [M:CON1]CONORIVCR = [M:MACW]MACORIVCR
      [M:CON1]CONORIVCRL = [M:MACW]MACORIVCRL
    When "CONTYP"
    When "CONCAT"
      [M:CON1]CONCAT = 1 # Garantie
    When "EVRPBL"
    When "EVRMAC"
    When "CRSCOVSAM"
    When "SALREP"
      [M:CON1]SALREP = [F:BPC]REP
    When "CONORIVCR"
      # fait dans CONNAM
    When "CONORI"
      # fait dans CONNAM
    When "CONCOT"
      [M:CON1]CONCOT = GSZWARMACRULE

    ######################################
    #[M:CON4]
    When "SIUDAT"
      [M:CON4]SIUDAT = [M:MACW]MACPURDAT
    When "CONSTRDAT"
    When "CONENDDAT"
    When "REWFRY"
    When "REWFRYBAS"
    When "CONREW"
    When "MANREWFLG"
    When "CONAMT"
      [M:CON4]CONAMT = 0
    When "PITCDT"
      [M:CON4]PITCDT = GSZCOTPITCDT
    When "RVAFRY"
    When "RVAFRYBAS"
    When "RVAMET"
    When "RVASSP"
    When "CONBASIDX"
    When "LASVALIDX"
    When "LASIDXDAT"
    When "CONBASFOR"
    When "RSILTI"
    When "RSILTIBAS"
    When "PITTOL"

    ######################################
    #[M:CON8]
    When "INVFRY"
    When "INVFRYBAS"
    When "INVMET"
    When "INVFRYCOE"
    When "INVLTI"
    When "INVLTIBAS"
    When "PTE"
      #[M:CON8]PTE = GSZCOTPTE # non saisissable sur contrat de garantie (il est gratuit)
    When "NBDPT"  # variable bas de tableau
    When "NBAXE"  # variable bas de tableau
      # mais pour les axes ne rien faire, c'est a priori bon !
    When "CCE"
      #[M:CON8]CCE(indice) = [F:SIH]CCE(indice)

    ######################################
    #[M:CONG]
    When "CONBPCINV"
    When "CONBPCPYR"
    When "CONBPCGRU"
    When "CONPJT"
    When "CONCHGTYP"
    When "ITMREF"
    When "CONPRITYP"
    When "CONVACBPR"
      # Issue X3-68002 - 2018-02-22 by FGR : BEGIN
      #[M:CONG]CONVACBPR = [F:BPC]VACBPR
      If [M:MACW]VACBPR <> "" Then
        [M:CONG]CONVACBPR = [M:MACW]VACBPR
      Else
        [M:CONG]CONVACBPR = [F:BPC]VACBPR
      Endif
      # Issue X3-68002 - 2018-02-22 by FGR : END
    When "NBFAC"  # variable bas de tableau

    ######################################
    #[M:CON2]
    When "NBINV"  # variable bas de tableau
    When "NBDUD"  # variable bas de tableau
    When "NBPAY"  # variable bas de tableau

    ######################################
    #[M:CON5]
    When "NBAMT"  # variable bas de tableau
    When "NBREW"  # variable bas de tableau
    When "RSIFLG"
    When "RSIREN"
      # Note FGR : je ne sais pas pourquoi, mais un ADI est initialisé à  "000"
      # Du coup ensuite ça plante parce que le code d'existe pas dans la table !
      [M:CON5]RSIREN = ""
    When "FDDFLG"
    When "RSIDAT"
    When "PRERSIFLG"

    ######################################
    When Default
  Endcase
Return

