TEABF(77)="SDD"  : TEATZ(77)="STA"           : TEABM (77)="SIAL"  : TEAMZ (77)="YSTA"
                                               TEABMO(77)="SDH1"  : TEAMZO(77)="STA"

# pour données CEE 
TEABF(80)="SDH"  : TEATZ(80)="EECNAT"        : TEABM (80)="SCEE"  : TEAMZ (80)="XEECNAT"
                                               TEABMO(80)="SDH0"  : TEAMZO(80)="EECNAT"
TEABF(81)="SDH"  : TEATZ(81)="EECSCH"        : TEABM (81)="SCEE"  : TEAMZ (81)="XEECSCH"
                                               TEABMO(81)="SDH0"  : TEAMZO(81)="EECSCH"
TEABF(82)="SDH"  : TEATZ(82)="EECTRN"        : TEABM (82)="SCEE"  : TEAMZ (82)="XEECTRN"
                                               TEABMO(82)="SDH0"  : TEAMZO(82)="EECTRN"
TEABF(83)="SDH"  : TEATZ(83)="EECICT"        : TEABM (83)="SCEE"  : TEAMZ (83)="XEECICT"
                                               TEABMO(83)="SDH0"  : TEAMZO(83)="EECICT"
TEABF(84)="SDH"  : TEATZ(84)="EECLOC"        : TEABM (84)="SCEE"  : TEAMZ (84)="XEECLOC"
                                               TEABMO(84)="SDH0"  : TEAMZO(84)="EECLOC"


Gosub TRTSUP_IS From TRTX3IMPS

Return

#######################################################################

$AP_IMPORT

Gosub IMPORT_TEXTE From IMPSDH

If IMPFIC="SDD"
  If [F:SDH]CFMFLG<>2     : # pas de no. de commande si livraison non validee
    [F:SDD]SOHNUM=""  
  Endif 
Endif

Return

#######################################################################

$IMP_FERME
GREP=""
Return

#######################################################################
#                        
#######################################################################

$OUVRE
#                             Presence des champs dans le modele (0=non / 1=oui)
Local Integer OK_SERNUM    : # - presence no serie 
Local Char    ACTIONSVG    : # zone de sauvegarde (pour appel action std)
Local Char    ACTIONSTD    : # action standard appelée
Local Integer NOL, STAT
Local Char    MESSA (80)

Local Integer CPT_SEQNUM   : # compteur no sequence fichier travail

ACTIONSTD="OUVRE" : Gosub ACTIONSTD

If clalev([STS])=0    : Local File STOSER     [STS]  : Endif
If clalev([STY])=0    : Local File STOSERW    [STY]  : Endif
If clalev([TCY])=0    : Local File TABCOUNTRY [TCY]  : Endif
If clalev([SPR])=0    : Local File SPREASON   [SPR]  : Endif

If clalev([M:IET])=0  : Local Mask IMPEXPTEX  [IET]  : Endif 

If clalev([M:SNU])=0  : Local Mask STOCKSNU   [SNU]  : Endif 
If clalev([M:SREN])=0 : Local Mask SALREN     [SREN] : Endif 
If clalev([M:SIAL])=0 : Local Mask SINFOALL   [SIAL] : Endif 
If clalev([M:SCEE])=0 : Local Mask SCEE       [SCEE] : Endif 

If clalev([M:ADB2])=0 : Local Mask ADRBPC     [ADB2] : Endif 
If clalev([M:ADB3])=0 : Local Mask ADRBPC     [ADB3] : Endif 

# Local Inpbox Mask [SNU]   As [SN0]   : voir bug 17775
# Local Inpbox Mask [SREN]  As [SR0]   : voir bug 17775
# Local Inpbox Mask [SIAL]  As [SI0]   : voir bug 17775
# Local Inpbox Mask [SCEE]  As [SC0]   : voir bug 17775
# Local Inpbox Mask [ADB2]  As [AD2]   : voir bug 17775
# Local Inpbox Mask [ADB3]  As [AD3]   : voir bug 17775

If clalev([M:SDH0])>0 : Default Mask [SDH0] : Endif
If clalev([M:SDH1])>0 : Default Mask [SDH1] : Endif
If clalev([M:SDH2])>0 : Default Mask [SDH2] : Endif
If clalev([M:SDH3])>0 : Default Mask [SDH3] : Endif

# recherche si presence dans modèle paramétrage
Call TST_CHAMP("STS","SERNUM",OK_SERNUM)    From SUBIMPOBJ    : # no serie

ACTIONSVG=ACTION : ACTION="IMP_OUVRE" : Gosub OUVRE_TEXTE From IMPSDH : ACTION=ACTIONSVG

Gosub PRESENCE_IS From TRTX3IMPS
If OK=0 : Return : Endif 

# creation des variables de traitement AUTxxx(permet de faire appel à autre AUTxxx
Gosub FROM_W1 From=NOMTRT

Return

#######################################################################

$RAZCRE
TISVALID=1 
Raz [M:SDH0], [M:SDH1], [M:SDH2], [M:SDH3], [M:SNU], [M:ADB2], [M:ADB3], [M:SREN], [M:SIAL]
GREP="C" : Raz GCLE
ACTIONSTD="SETBOUT" : Gosub ACTIONSTD

ACTIONSTD="RAZCRE" : Gosub ACTIONSTD

Gosub SDH_RAZCRE From=NOMTRT

# si paramétrage du no de série : raz de table stockage STOSERW
If OK_SERNUM : Delete [STY] Where PRONUM=adxuid(1) : Endif 

Return

#######################################################################

$SAIMSK

Case IMPFIC
  When "SDH"
    Default File [SDH]
    Raz [M:SDH1]NBLIG
    Gosub SDH_SAIMSK From=NOMTRT
    If mkstat : TISVALID=0 : Return : Endif 
    Gosub IMP_ZONE_TEXTE From IMPSDH
  When "SDD"
    Default File [SDD]
    Raz CPT_SEQNUM
    [M:SDH1]NBLIG +=1 : nolign=[M:SDH1]NBLIG : indice=nolign-1
    Gosub SDD_RAZCRE From=NOMTRT 
    Gosub SDH1_NBLIG From=NOMTRT
    If mkstat : TISVALID=0 : Return : Endif 
    Gosub IMP_TAB_TEXTE From IMPSDH
  When "STS"
    Trbegin [STY]
    If [F:ITM]ITMREF <> [M:SDH1]ITMREF(NBLIG-1) 
       Read [ITM]ITM0=[M:SDH1]ITMREF(NBLIG-1) 
    Endif 
    Raz [F:STY]  
    [F:STY]PRONUM    = adxuid(1)
    [F:STY]LINNUM    = [M:SDH1]NBLIG-1 
    [F:STY]SCRLINNUM = 0 
    [F:STY]SERNUM    = [F:STS]SERNUM 
    [F:STY]SCRLINNEW = 0 
    [F:STY]VCRTYP    = 4 
    [F:STY]STOCOU    = 0
    [F:STY]FLGGLO    = 1 
    If [F:ITM]SERMGTCOD=3
       Read [STS]STS0=[F:ITM]ITMREF;[F:STS]SERNUM 
#       If !fstat                             : # bug 12765
#          CPT_SEQNUM   +=1                   : # bug 12765 
#          [F:STY]SEQNUM = CPT_SEQNUM         : # bug 12765
#          [F:STY]STOCOU = [F:STS]STOCOU      : # bug 12765
#          Write [STY]                        : # bug 12765
#       Endif                                 : # bug 12765
       If !fstat                              : # bug 12765
          [F:STY]STOCOU = [F:STS]STOCOU       : # bug 12765
       Endif                                  : # bug 12765
       CPT_SEQNUM   +=1                       : # bug 12765
       [F:STY]SEQNUM = CPT_SEQNUM             : # bug 12765
       Write [STY]                            : # bug 12765
    Else
       CPT_SEQNUM   +=1
       [F:STY]SEQNUM = CPT_SEQNUM 
       Write [STY]
    Endif
    Commit
  When Default
Endcase    

Return

#######################################################################
# si présence du no de série dans le paramétrage : maj de la table 
#   - après ecriture de la livraison
#     - si erreur transaction (delete des enregistrements dans STOSERW)
#   - ecriture des no de série à partir de STOSERW
#     (appel de MAJ_SERIE_IMPORT From SUBSDH qui :
#     (         - boucle à partir de chaque ligne de SDH1 )   
$VALID

If !TISVALID : GOK=0 : Return : Endif
#ACTIONSTD="VERIF_CRE" : Gosub ACTIONSTD : # inutile pour les livraisons

If [M:SDH1]NBLIG=0 : Return : Endif
Raz STAT, MESSA

GOK=1
Call DEBTRANS From GLOCK
Gosub TR1
GCLE=[M:SDH0]SDHNUM  
If GOK=1
  Call TRACE(0,GCLE) From SUBIMPOBJ
  NBCRE +=1
Endif
If OK_SERNUM 
  If GOK=1
#    Gosub MAJ_SERIE_IMPORT From SUBSDH 
  Endif  
  Delete [STY] Where PRONUM=adxuid(1)
Endif

Return

#----------------------------------------------------------------------
$TR1
Trbegin [SDH]

# on ecrit l'entête de livraison

[F:SDH]=[M:SDH0] : [F:SDH]=[M:SDH1] : [F:SDH]=[M:SDH2] : [F:SDH]=[M:SDH3]
ACTIONSTD="INICRE" : Gosub ACTIONSTD
[F:SDH]CREUSR=GUSER
[F:SDH]CREDAT=date$ 
Write [SDH]
If fstat
 GOK=0 : Call FSTA("SDH") From GLOCK : Goto AB_TR1
Endif

# on ecrit les lignes
ACTIONSTD="CREATION" : Gosub ACTIONSTD
If    GOK<0 : Goto ROLL_TR1
Elsif !GOK  : Goto AB_TR1
Endif

Commit
Return

#---
$AB_TR1
# si paramétrage du no de série : raz de table stockage STOSERW
#STAT=1
If OK_SERNUM : Delete [STY] Where PRONUM=adxuid(1) : Endif 
Rollback
Return

#---
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


#######################################################################
#######################################################################
#######################################################################
#######################################################################
$AV_ZONE
# MSK_ABR  contient l'abreviation du masque
# MSK_ZONE contient le nom de la zone du masque
Return

#----------------------------------------------------------------------
$AP_ZONE
# MSK_ABR  contient l'abreviation du masque
# MSK_ZONE contient le nom de la zone du masque
Return


#######################################################################
#######################################################################


