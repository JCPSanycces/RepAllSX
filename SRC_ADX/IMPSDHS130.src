#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#######################################################################
# IMPSDHS130 : Import Spécifique des Livraisons
#----------------------------------------------------------------------
#
#######################################################################
$ACTION
Case ACTION
 When "IMP_COMPILE"    : Gosub IMP_COMPILE  
 When "IMP_TRTSUP"     : Gosub IMP_TRTSUP 
 When "AP_IMPORT"      : Gosub AP_IMPORT 
 When "IMP_FERME"      : Gosub IMP_FERME 

 When "EXP_OUVRE"      : Gosub EXP_OUVRE From IMPSDH 
 When "EXPORT"         : Gosub EXPORT    From IMPSDH 
 When "EXP_ZONE"       : Gosub EXP_ZONE  From IMPSDH 

 When Default     
Endcase

Return

#----------------------------------------------------------------------
# appel des actions standards de l'objet  
$ACTIONSTD
ACTIONSVG=ACTION
ACTION=ACTIONSTD : Gosub ACTION From SUBSDH
ACTION=ACTIONSVG
Return

#######################################################################
#                        IMPORT
#######################################################################

$IMP_COMPILE
Return

#######################################################################

$IMP_TRTSUP

Gosub DEFINE_IS From TRTX3IMPS
# --- les masques
TISABMR(0)=1 : TISMSK(0)="SDH0"     : TISABM(0)="SDH0"
TISABMR(1)=2 : TISMSK(1)="ADRBPC"   : TISABM(1)="ADB2"                     : # adr livraison
TISABMR(2)=3 : TISMSK(2)="ADRBPC"   : TISABM(2)="ADB3"                     : # adr facture 
TISABMR(3)=4 : TISMSK(3)="SDH1"     : TISABM(3)="SDH1"
TISABMR(4)=5 : TISMSK(4)="SALREN"   : TISABM(4)="SREN" : TISMSKO(4)="SDH1" : # motifs
TISABMR(5)=6 : TISMSK(5)="SINFOALL" : TISABM(5)="SIAL" : TISMSKO(5)="SDH1" : # info allocations
TISABMR(6)=7 : TISMSK(6)="SDH2"     : TISABM(6)="SDH2"
TISABMR(7)=8 : TISMSK(7)="SDH3"     : TISABM(7)="SDH3"
TISABMR(8)=9 : TISMSK(8)="SCEE"     : TISABM(8)="SCEE" : TISMSKO(8)="SDH0" : # info cee

# --- les tables
TISFIC(0)="SDELIVERY" : TISFIC(1)="SDELIVERYD" 

# --- les zones tables obligatoires dans le modèle
TOABF(0)="SDH"   : TOATZ(0)="STOFCY"         : # Site expedition  
TOABF(1)="SDH"   : TOATZ(1)="SALFCY"         : # Site de vente  
TOABF(2)="SDH"   : TOATZ(2)="BPCORD"         : # Client commande  
TOABF(3)="SDD"   : TOATZ(3)="ITMREF"         : # Article
TOABF(4)="SDD"   : TOATZ(4)="QTY"            : # Quantite

# --- les exceptions table - masque ( sauf les adresses gérées à part ) 
TEABF(0) ="SDD"  : TEATZ(0) ="VAT(0)"        : TEABM(0)  ="SDH1"  : TEAMZ(0) ="VAT1" 
TEABF(1) ="SDD"  : TEATZ(1) ="VAT(1)"        : TEABM(1)  ="SDH1"  : TEAMZ(1) ="VAT2" 
TEABF(2) ="SDD"  : TEATZ(2) ="VAT(2)"        : TEABM(2)  ="SDH1"  : TEAMZ(2) ="VAT3" 
TEABF(3) ="SDD"  : TEATZ(3) ="VACITM(0)"     : TEABM(3)  ="SDH1"  : TEAMZ(3) ="VACITM1" 
TEABF(4) ="SDD"  : TEATZ(4) ="VACITM(1)"     : TEABM(4)  ="SDH1"  : TEAMZ(4) ="VACITM2" 
TEABF(5) ="SDD"  : TEATZ(5) ="VACITM(2)"     : TEABM(5)  ="SDH1"  : TEAMZ(5) ="VACITM3" 
TEABF(6) ="SDD"  : TEATZ(6) ="SOHNUM"        : TEABM(6)  ="SDH1"  : TEAMZ(6) ="XSOHNUM" 
TEABF(7) ="SDD"  : TEATZ(7) ="WEU"           : TEABM(7)  ="SDH1"  : TEAMZ(7) ="XWEU" 
TEABF(8) ="SDD"  : TEATZ(8) ="TSICOD(0)"     : TEABM(8)  ="SDH1"  : TEAMZ(8) ="TSICOD1" 
TEABF(9) ="SDD"  : TEATZ(9) ="TSICOD(1)"     : TEABM(9)  ="SDH1"  : TEAMZ(9) ="TSICOD2" 
TEABF(10)="SDD"  : TEATZ(10)="TSICOD(2)"     : TEABM(10) ="SDH1"  : TEAMZ(10)="TSICOD3" 
TEABF(11)="SDD"  : TEATZ(11)="TSICOD(3)"     : TEABM(11) ="SDH1"  : TEAMZ(11)="TSICOD4" 
TEABF(12)="SDD"  : TEATZ(12)="TSICOD(4)"     : TEABM(12) ="SDH1"  : TEAMZ(12)="TSICOD5" 

# pour adresse livraison 
TEABF(30)="SDH"  : TEATZ(30)="BPDNAM(0)"     : TEABM(30) ="ADB2"  : TEAMZ(30)="BPRNAM(0)"
TEABF(31)="SDH"  : TEATZ(31)="BPDNAM(1)"     : TEABM(31) ="ADB2"  : TEAMZ(31)="BPRNAM(1)"
TEABF(32)="SDH"  : TEATZ(32)="BPDADDLIG(0)"  : TEABM(32) ="ADB2"  : TEAMZ(32)="BPAADDLIG(0)"
TEABF(33)="SDH"  : TEATZ(33)="BPDADDLIG(1)"  : TEABM(33) ="ADB2"  : TEAMZ(33)="BPAADDLIG(1)"
TEABF(34)="SDH"  : TEATZ(34)="BPDADDLIG(2)"  : TEABM(34) ="ADB2"  : TEAMZ(34)="BPAADDLIG(2)"
TEABF(35)="SDH"  : TEATZ(35)="BPDCRY"        : TEABM(35) ="ADB2"  : TEAMZ(35)="CRY"
TEABF(36)="SDH"  : TEATZ(36)="BPDCRYNAM"     : TEABM(36) ="ADB2"  : TEAMZ(36)="CRYNAM"
TEABF(37)="SDH"  : TEATZ(37)="BPDSAT"        : TEABM(37) ="ADB2"  : TEAMZ(37)="SAT"
TEABF(38)="SDH"  : TEATZ(38)="BPDPOSCOD"     : TEABM(38) ="ADB2"  : TEAMZ(38)="POSCOD"
TEABF(39)="SDH"  : TEATZ(39)="BPDCTY"        : TEABM(39) ="ADB2"  : TEAMZ(39)="CTY"
TEABF(40)="SDH"  : TEATZ(40)="CNDNAM"        : TEABM(40) ="ADB2"  : TEAMZ(40)="CNTNAM"

# pour adresse facture 
TEABF(45)="SDH"  : TEATZ(45)="BPINAM(0)"     : TEABM(45) ="ADB3"  : TEAMZ(45)="BPRNAM(0)"
TEABF(46)="SDH"  : TEATZ(46)="BPINAM(1)"     : TEABM(46) ="ADB3"  : TEAMZ(46)="BPRNAM(1)"
TEABF(47)="SDH"  : TEATZ(47)="BPIADDLIG(0)"  : TEABM(47) ="ADB3"  : TEAMZ(47)="BPAADDLIG(0)"
TEABF(48)="SDH"  : TEATZ(48)="BPIADDLIG(1)"  : TEABM(48) ="ADB3"  : TEAMZ(48)="BPAADDLIG(1)"
TEABF(49)="SDH"  : TEATZ(49)="BPIADDLIG(2)"  : TEABM(49) ="ADB3"  : TEAMZ(49)="BPAADDLIG(2)"
TEABF(50)="SDH"  : TEATZ(50)="BPICRY"        : TEABM(50) ="ADB3"  : TEAMZ(50)="CRY"
TEABF(51)="SDH"  : TEATZ(51)="BPICRYNAM"     : TEABM(51) ="ADB3"  : TEAMZ(51)="CRYNAM"
TEABF(52)="SDH"  : TEATZ(52)="BPISAT"        : TEABM(52) ="ADB3"  : TEAMZ(52)="SAT"
TEABF(53)="SDH"  : TEATZ(53)="BPIPOSCOD"     : TEABM(53) ="ADB3"  : TEAMZ(53)="POSCOD"
TEABF(54)="SDH"  : TEATZ(54)="BPICTY"        : TEABM(54) ="ADB3"  : TEAMZ(54)="CTY"
TEABF(55)="SDH"  : TEATZ(55)="CNINAM"        : TEABM(55) ="ADB3"  : TEAMZ(55)="CNTNAM"
TEABF(56)="SDH"  : TEATZ(56)="BPIEECNUM"     : TEABM(56) ="ADB3"  : TEAMZ(56)="EECNUM"

# pour motifs 
TEABF(60)="SDD"  : TEATZ(60)="PRIREN"        : TEABM (60)="SREN"  : TEAMZ (60)="GROPRICOD" 
                                               TEABMO(60)="SDH1"  : TEAMZO(60)="PRIREN"
TEABF(61)="SDD"  : TEATZ(61)="DISCRGREN1"    : TEABM (61)="SREN"  : TEAMZ (61)="DISCRGCOD1"
                                               TEABMO(61)="SDH1"  : TEAMZO(61)="DISCRGREN1"
TEABF(62)="SDD"  : TEATZ(62)="DISCRGREN2"    : TEABM (62)="SREN"  : TEAMZ (62)="DISCRGCOD2"
                                               TEABMO(62)="SDH1"  : TEAMZO(62)="DISCRGREN2"
TEABF(63)="SDD"  : TEATZ(63)="DISCRGREN3"    : TEABM (63)="SREN"  : TEAMZ (63)="DISCRGCOD3"
                                               TEABMO(63)="SDH1"  : TEAMZO(63)="DISCRGREN3"
TEABF(64)="SDD"  : TEATZ(64)="DISCRGREN4"    : TEABM (64)="SREN"  : TEAMZ (64)="DISCRGCOD4"
                                               TEABMO(64)="SDH1"  : TEAMZO(64)="DISCRGREN4"
TEABF(65)="SDD"  : TEATZ(65)="DISCRGREN5"    : TEABM (65)="SREN"  : TEAMZ (65)="DISCRGCOD5"
                                               TEABMO(65)="SDH1"  : TEAMZO(65)="DISCRGREN5"
TEABF(66)="SDD"  : TEATZ(66)="DISCRGREN6"    : TEABM (66)="SREN"  : TEAMZ (66)="DISCRGCOD6"
                                               TEABMO(66)="SDH1"  : TEAMZO(66)="DISCRGREN6"
TEABF(67)="SDD"  : TEATZ(67)="DISCRGREN7"    : TEABM (67)="SREN"  : TEAMZ (67)="DISCRGCOD7"
                                               TEABMO(67)="SDH1"  : TEAMZO(67)="DISCRGREN7"
TEABF(68)="SDD"  : TEATZ(68)="DISCRGREN8"    : TEABM (68)="SREN"  : TEAMZ (68)="DISCRGCOD8"
                                               TEABMO(68)="SDH1"  : TEAMZO(68)="DISCRGREN8"
TEABF(69)="SDD"  : TEATZ(69)="DISCRGREN9"    : TEABM (69)="SREN"  : TEAMZ (69)="DISCRGCOD9"
                                               TEABMO(69)="SDH1"  : TEAMZO(69)="DISCRGREN9"

# pour allocations 
TEABF(75)="SDD"  : TEATZ(75)="LOT"           : TEABM (75)="SIAL"  : TEAMZ (75)="YLOT"
                                               TEABMO(75)="SDH1"  : TEAMZO(75)="LOT"
TEABF(76)="SDD"  : TEATZ(76)="LOC"           : TEABM (76)="SIAL"  : TEAMZ (76)="YLOC"
