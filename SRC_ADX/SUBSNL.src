Subprog ACT_VALSNL

Local Char LFILTRE(115)
Local Char CRITER1(100)
Local Char LCUL
Local Decimal I

CRITER1 = "1=1"
# filtre :
#       site , session , liste , detail compté
LFILTRE = "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM"

Call TRT_VALIDATION(LFILTRE,CRITER1,0,LCUL,[M:SNL0]CUNSSSNUM,[M:SNL0]CUNLISNUM) From STKINV
If LCUL <> ""
   Effzo [M:SNL0]25
   Gosub LOAD_SNL0   From SUBSNL
Endif
