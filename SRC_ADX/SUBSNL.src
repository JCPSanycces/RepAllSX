## Etiquette ajoutée par le superviseur (écran SNL0) 21/01/2011 16:57:55 (HCB)
######################################################################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
Local Integer LRET
Raz LRET
If VALEUR > date$
   mkstat = 2
   GMESSAGE = mess(380,184,1) # date d imputation superieure à la date du jour
   End
Endif
If VALEUR < [M:SNL0]CREDAT
   Call TRT_CTR_IPTDAT([M:SNL0]STOFCY,"",[M:SNL0]CUNSSSNUM,[M:SNL0]CUNLISNUM,VALEUR,[M:SNL0]CREDAT,"SAI","",LRET) From STKINV
   If LRET = 9
      mkstat = 2
     End
   Endif
Endif

End


