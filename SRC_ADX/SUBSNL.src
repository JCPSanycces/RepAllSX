Subprog AP_QTYPCUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
If [M:SNL0]PCU(NOL) <> ""
  [M:SNL0]QTYSTUNEW1(NOL) = VALEUR * [M:SNL0]PCUSTUCOE(NOL)
  Call QTEARR( [M:SNL0]QTYSTUNEW1(NOL),[M:SNL0]STU(NOL)) From TRTDIV
# Controle qté allouée si le parametrage le demande.
   If [M:SNL0]QTYSTUNEW1(NOL) <> 0
      If [M:SNL0]NBDETAIL(NOL)  = 1
         If [M:SNL0]CUMALLQTY(NOL)>[M:SNL0]QTYSTUNEW1(NOL)
             mkstat = 2
# La qté allouée est supérieure à la qte comptée
             Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL0]ITMREF(NOL),[M:SNL0]STOCOU(NOL),"") From STKINV
             End
         Endif
      Endif
   Endif
  Affzo [M:SNL0]QTYSTUNEW1(NOL)

Endif
End

Subprog AM_QTYPCUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
If [F:ITM]ITMREF<>[M:SNL0]ITMREF(NOL)
   Read [ITM]ITM0=[M:SNL0]ITMREF(NOL)
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif
If [M:SNL0]NBDETAIL(NOL) = 1 & [F:ITM]SERMGTCOD = 3  & VALEUR <> 0 & VALEUR <> 1    # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif
[M:SNL0]MODFLG(NOL) = 2
[M:SNL0]QTYPCUNEW1(NOL) = VALEUR

End

Subprog C_QTYSTUNEW1(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 2
Endif
Gosub SET_NOL From STKINV

If [F:ITM]ITMREF<>[M:SNL0]ITMREF(NOL)
   Read [ITM]ITM0=[M:SNL0]ITMREF(NOL)
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif
If [M:SNL0]NBDETAIL(NOL) = 1 & [F:ITM]SERMGTCOD = 3 & VALEUR <> 0 & VALEUR <> 1  # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif

# Controle qté allouée si le parametrage le demande.
If VALEUR <> 0
   If [M:SNL0]NBDETAIL(NOL)  = 1
      If [M:SNL0]CUMALLQTY(NOL)>VALEUR
         mkstat = 2
# La qté allouée est supérieure à la qte comptée
         Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL0]ITMREF(NOL),[M:SNL0]STOCOU(NOL),"") From STKINV
         End
      Endif
   Endif
Endif

If [M:SNL0]PCU(NOL) <> ""
   [M:SNL0]QTYPCUNEW1(NOL) = VALEUR / [M:SNL0]PCUSTUCOE(NOL)
    Call QTEARR( [M:SNL0]QTYPCUNEW1(NOL),[M:SNL0]PCU(NOL)) From TRTDIV
    Affzo [M:SNL0]QTYPCUNEW1(NOL)
Endif
End

Subprog AM_QTYSTUNEW1(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
[M:SNL0]MODFLG(NOL) = 2
[M:SNL0]QTYSTUNEW1(NOL) = VALEUR
End

