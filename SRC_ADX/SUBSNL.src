   If fstat
      Raz [F:CUN]
   Endif
Endif
End


Subprog C_ZERSTOFLG(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL From STKINV
## controle qté allouée si le parametre le demande
If  VALEUR = 2
    If [M:SNL0]NBDETAIL(NOL)  = 1
       If  [M:SNL0]CUMALLQTY(NOL)>0
           mkstat = 2
# LA qté allouée est supérieure à la qte comptée
           Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL0]ITMREF(NOL),[M:SNL0]STOCOU(NOL),"") From STKINV
           End
       Endif
    Endif
Endif

End

########################################
$AB2_NBLIG
If [M:SNL0]CUNLISNUM<>""
  SYMBOLE2="SNL"+[M:SNL0]CUNSSSNUM+[M:SNL0]CUNLISNUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:SNL0]CUNLISNUM-mess(10,100,1)
    GOUVINV=0
    Return
  Endif
Endif
Return

########################################
$BB2_NBLIG
If [M:SNL0]CUNLISNUM<>""
  SYMBOLE2="SNL"+[M:SNL0]CUNSSSNUM+[M:SNL0]CUNLISNUM
  Unlock=SYMBOLE2
Endif
Return


$AB4_NBLIG
Gosub SET_NOL From STKINV
If clalev([M:SNL1])=0 Global  Mask SNL1   [SNL1] Endif  #  ecran stockage mvt du document


Local Integer Y
Local Integer WSECTION
Local Char    SECTION
#chargement parametrage saisie sections analytiques
[M:SNL1]CCECODS    = [F:DTR]STOCCECOD

#chargement bloc 1
[M:SNL1]STOFCY    = [M:SNL0]STOFCY
[M:SNL1]CUNSSSNUM = [M:SNL0]CUNSSSNUM
[M:SNL1]CUNLISNUM = [M:SNL0]CUNLISNUM
[M:SNL1]ITMREF    = [M:SNL0]ITMREF(NOL)


#---- Récupération des sections analytiques ----#
Filter [CUD] Where STOFCY     = [M:SNL1]STOFCY             &
&                  ITMREF     = [M:SNL1]ITMREF             &
&                  CUNLISNUM  = [M:SNL1]CUNLISNUM          &
&                  CUNSSSNUM  = [M:SNL1]CUNSSSNUM
&            Order By Key CUD1
For [CUD]
    For Y=1 To GNBDIE
       [M:SNL1]CCE(Y-1) =  [F:CUD]CCE(Y-1)          # Ana
    Next
    WSECTION = 2
    Break
Next


Filter [CUD]
If WSECTION <> 2
   For Y=1 To GNBDIE
       If dim([M:SNL1]CCE(Y-1)) >0
          Call INISEC(SECTION, "STKINVD", Y) From TRTX3CPT
          [M:SNL1]CCE(Y-1) =  SECTION
       Endif
   Next
Endif

Return

$BB4_NBLIG

If clalev([M:SNL1])<> 0
   Close Global Mask  [SNL1]
Endif

Return
Subprog B4_NBLIG
End

Subprog AM_MVTDES(VALEUR)
Variable Char    VALEUR()
If VALEUR <> [F:CUL]MVTDES
   #maj  liste inventaire
   Readlock [CUL]CUL0=[M:SNL0]CUNSSSNUM;[M:SNL0]CUNLISNUM
   If  fstat
        GMESSAGE = mess(12,100,1)-"CUNLISTE"-[M:SNL0]CUNLISNUM
        End
   Endif
   [F:CUL]MVTDES    = VALEUR
   [F:CUL]UPDUSR    = GUSER
   [F:CUL]UPDDAT    = date$
   [F:CUL]USR       = [M:SNL0]USR
   Rewrite  [CUL]
   If fstat
      Call FSTA("CUL") From GLOCK
      End
   Endif
Endif


End

Subprog AM_CUNLISNUM(VALEUR)
Variable Char    VALEUR()
End




# Suppression ligne(s)
Subprog B5_NBLIG

Gosub SET_NOL From STKINV
Local Char LFILTRE(250)
Local Char LCRITER1(250)(3)
Local Decimal LG
LG = NOL
Local Char RGP_FILTRE (250)                                                               # hcb 71659
Local Char RGP_FILTRE1(250)                                                               # hcb 71659
Local Char RGP_FILTRE2(250)                                                               # hcb 71659


LFILTRE =  "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM"
LFILTRE += "& [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM &[F:CUD]ITMREF=[M:SNL0]ITMREF(LG)"

#filtre regroupement
Call DEF_CRITERE_RGP("SNL0",LG,LCRITER1,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2) From STKINV                             # hcb 71659

Call TRT_SUPPRESSION(LFILTRE,LCRITER1,[M:SNL0]ITMREF(LG),[M:SNL0]CUNLISNUM,[M:SNL0]STOFCY,LG) From STKINV
Effzo [M:SNL0]25
Gosub LOAD_SNL0 From SUBSNL
End

# Suppression article
Subprog B6_NBLIG
Gosub SET_NOL From STKINV
Local Char LFILTRE(250)
Local Char LCRITER1(250)
Local Decimal LG
LG = NOL
LCRITERE1 = "1=1"

LFILTRE =  "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM"
LFILTRE += "& [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM &[F:CUD]ITMREF=[M:SNL0]ITMREF(LG)"

Call TRT_SUPPRESSION(LFILTRE,LCRITER1,[M:SNL0]ITMREF(LG),[M:SNL0]CUNLISNUM,[M:SNL0]STOFCY,LG) From STKINV
Effzo [M:SNL0]25
Gosub LOAD_SNL0 From SUBSNL

End


Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If [F:CUN]CUNITMWRH =  2
   Read  [STC]STC0=[M:SNL0]STOFCY;VALEUR
   If fstat
      mkstat = 2
      GMESSAGE = mess(233,192,1)       # emplacement non cree sur le site
      End
# L'emplacement n'appartient pas au dépôt
   Elsif [F:STC]WRH<>[M:SNL0]WRHCUL
      mkstat = 2
      GMESSAGE = mess(341,184,1)       # Emplacement n appartenant pas au depot
      End
   Endif
Endif

End


