   GMESSAGE = mess(50,184,1)       # liste non génerée
   End
Endif

If [F:CUN]CUNSSSTYP = 2 & [M:SNL0]LOCCOD  <> 1   # hcb 50197
   mkstat = 2
   GMESSAGE = mess(49,184,1)       # parametrage erroné pource type de session ( rubrique emplacement invisible)
   End
Endif

End


Subprog AV_NBLIG
