Subprog C_CUNLISNUM(VALEUR)
Variable Char    VALEUR()
Local Integer WLIGSNU3

Read [CUL]CUL0=[M:SNL0]CUNSSSNUM;VALEUR
If fstat
   mkstat = 2
   End
Endif
# hcb 74380 deb
Raz  GSNLSTAIMG3
# verrouillage logique nouvelle liste / deverrouillage logique ancienne liste
If VALEUR <> [M:SNL0]CUNLISNUM
   SYMBOLE2 = "CUL"+[M:SNL0]CUNSSSNUM+"\"+VALEUR
   Lock = SYMBOLE2
# modification en cours sur un autre poste
   If fstat
       GERR=1
       Call ERREUR(mess(10,100,1)) From GESECRAN
       mkstat = 2
       OK=0
       VALEUR = [M:SNL0]CUNLISNUM
       mkstat = 2
       OK=0
       End
   Endif
   If [M:SNL0]CUNLISNUM <> ""
      SYMBOLE2 = "CUL"+[M:SNL0]CUNSSSNUM+"\"+[M:SNL0]CUNLISNUM
      Unlock = SYMBOLE2
   Endif
#Endif                                                                     # hcb 110327

# hcb 74380 fin

   Raz [M:SNL0]
   [M:SNL0]CUNLISNUM = [F:CUL]CUNLISNUM
   [M:SNL0]CUNLISDES = [F:CUL]CUNLISDES
   [M:SNL0]CUNLISSTA = [F:CUL]CUNLISSTA
   [M:SNL0]NBRLIG    = [F:CUL]NBRLIG
   Gosub LOAD_SNL0 From SUBSNL
Endif                                                                      # hcb 110327

End

#                                                                                         # hcb 71659 deb
#Subprog AS_QTYPCUNEW(VALEUR)
#Variable Decimal VALEUR
#Call PASSAISNL0 From STKINV
# si comptage present pas de saisie
#Gosub CTR_COMPTAGE
#If [M:SNL0]PCU(NOL) = ""
#  mkstat = 2
#Endif
#end
#                                                                                         # hcb 71659 fin
Subprog AP_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV
If [M:SNL0]PCU(NOL) <> ""
  [M:SNL0]QTYSTUNEW(NOL) = VALEUR * [M:SNL0]PCUSTUCOE(NOL)
  Call QTEARR( [M:SNL0]QTYSTUNEW(NOL),[M:SNL0]STU(NOL)) From TRTDIV
# Controle qté allouée si le parametrage le demande.
   If [M:SNL0]QTYSTUNEW(NOL) <> 0
      If [M:SNL0]NBDETAIL(NOL)  = 1
         If [M:SNL0]CUMALLQTY(NOL)>[M:SNL0]QTYSTUNEW(NOL)
             mkstat = 2
# La qté allouée est supérieure à la qte comptée
             Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL0]ITMREF(NOL),[M:SNL0]STOCOU(NOL),"") From STKINV
             End
         Endif
      Endif
   Endif
#                                                                                 # hcb 110327 deb
   If [M:SNL0]SERSEQ(NOL) <> 0 & [M:SNL0]QTYSTUDEV(NOL) <> 0
      Gosub CTR_SENS From STKINV1
   Endif
#                                                                                 # hcb 110327 deb
  Affzo [M:SNL0]QTYSTUNEW(NOL)

Endif
End

Subprog AM_QTYPCUNEW(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From STKINV

# hcb 55481 deb
If [F:ITM]ITMREF<>[M:SNL0]ITMREF(NOL)
   Read [ITM]ITM0=[M:SNL0]ITMREF(NOL)
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif
If [M:SNL0]NBDETAIL(NOL) = 1 & [F:ITM]SERMGTCOD = 3  & VALEUR <> 0 & VALEUR <> 1    # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif
# hcb 55481 fin

[M:SNL0]MODFLG(NOL) = 2
[M:SNL0]QTYPCUNEW(NOL) = VALEUR

End

Subprog C_QTYSTUNEW(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 2
Endif
Gosub SET_NOL From STKINV

If [F:ITM]ITMREF<>[M:SNL0]ITMREF(NOL)
   Read [ITM]ITM0=[M:SNL0]ITMREF(NOL)
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif
If [M:SNL0]NBDETAIL(NOL) = 1 & [F:ITM]SERMGTCOD = 3  & VALEUR <> 0 & VALEUR <> 1                # hcb 110327
   mkstat = 2
# il est interdit de saisir une quantité <> DE  1 sur UN ARTICLE géré en numéro de série.
  GMESSAGE = mess(47,184,1)
   End
Endif

# Controle qté allouée si le parametrage le demande.
If VALEUR <> 0
   If [M:SNL0]NBDETAIL(NOL)  = 1
      If [M:SNL0]CUMALLQTY(NOL)>VALEUR
         mkstat = 2
# La qté allouée est supérieure à la qte comptée
         Call RECH_STOALL([M:SNL0]STOFCY,[M:SNL0]ITMREF(NOL),[M:SNL0]STOCOU(NOL),"") From STKINV
         End
      Endif
   Endif
Endif

If [M:SNL0]PCU(NOL) <> ""
   [M:SNL0]QTYPCUNEW(NOL) = VALEUR / [M:SNL0]PCUSTUCOE(NOL)
    Call QTEARR( [M:SNL0]QTYPCUNEW(NOL),[M:SNL0]PCU(NOL)) From TRTDIV
    Affzo [M:SNL0]QTYPCUNEW(NOL)
Endif


End

