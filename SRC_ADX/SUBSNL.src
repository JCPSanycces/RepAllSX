Subprog B7_NBLIG
#Ouverture fenêtre de saisie série globale par clic droit
GOUVSNLS = 2
# si <> "A compter" ou "Comptée"
If [M:SNL0]CUNLISSTAD(nolign-1)  > 2
   GOUVSNLS = 9
Endif

End

