#<AdxTL>@(#)1.0.0.0 $Revision$

Call OBJET("SNL",GBIDC1,GBIDC2) From GOBJET
End

# Gestion du masque SNL0

##########################################################################
## Etiquette ajoutée par le superviseur 30/04/2003 10:44:47 (HCB)
##########################################################################
$ACTION

Case ACTION
  When "AVANT_OUVRE"   : Gosub AVANT_OUVRE       # hcb 117298
  When "DEFTRANS"      : Gosub DEFTRANS     From SUBSNLA
  When "VARIANTE"      : Gosub VARIANTE     From SUBSNLA
  When "SETTRANS"      : Gosub SETTRANS     From SUBSNLA
  When "OUVRE"         : Gosub OUVRE        From SUBSNLA
  When "FERME"         : Gosub FERME        From SUBSNLA
  When "LIENS"         : Gosub LIENS        From SUBSNLA
  When "FILGAUCHE"     : Gosub FILGAUCHE    From SUBSNLA
  When "SETBOUT"       : Gosub SETBOUT      From SUBSNLA
  When "AVANT_MODFIC"  : Gosub AVANT_MODFIC From SUBSNLA
  When "APRES_MOD"     : Gosub APRES_MOD    From SUBSNLA
  When "FIN"           : Gosub FIN          From SUBSNLA
  When "AVANTBOUT"     : Gosub AVANTBOUT    From SUBSNLA

  When "VERROU"        : Gosub VERROU      From SUBSNLA     # hcb 74380
  When "DEVERROU"      : Gosub DEVERROU    From SUBSNLA     # hcb 74380


  When "AB2_NBLIG"     : Gosub AB2_NBLIG
  When "BB2_NBLIG"     : Gosub BB2_NBLIG

  When "AB4_NBLIG"     : Gosub AB4_NBLIG
  When "BB4_NBLIG"     : Gosub BB4_NBLIG
  When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG

 When Default
Endcase
Return

#                          hcb  117298 deb
$AVANT_OUVRE
ANOUPDTICK = 1
Return

#                          hcb  117298 end

#########################################################################
# Calcul et chargement des regroupements
#########################################################################
$LOAD_SNL0

# Raz [M:SNL0]                                                        # hcb 110327
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

[M:SNL0]CCECODS   = [F:DTR]HEACCECOD
[M:SNL0]LOCCOD    = [F:SRT]LOCCOD
[M:SNL0]LOTCOD    = [F:SRT]LOTCOD
If dim([M:SNL0]SLOCOD) > 0
   [M:SNL0]SLOCOD    = [F:SRT]SLOCOD
Endif
[M:SNL0]STACOD    = [F:SRT]STACOD
[M:SNL0]SERCOD    = [F:SRT]SERCOD
[M:SNL0]IDECOD1   = [F:SRT]IDECOD1
[M:SNL0]IDECOD2   = [F:SRT]IDECOD2
 #---- Récupération des sections analytiques ----#
Local Integer Y
For Y=1 To GNBDIE                                # Ana
    [M:SNL0]CCE(Y-1) =  [F:CUL]CCE(Y-1)          # Ana
Next                                             # Ana

# c est la date de creation des enregistrement bidon stojou

[M:SNL0]CREDAT    = [F:CUL]CREDAT
If [F:CUL]IPTDAT  = [0/0/0]
   [M:SNL0]IPTDAT = [F:CUL]CREDAT
Else
   [M:SNL0]IPTDAT = [F:CUL]IPTDAT
Endif

[M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT   # sert à determiner si la date imputation à été modifiée

[M:SNL0]USR       = GUSER

Read [CUN]CUN0=[F:CUL]CUNSSSNUM
If fstat
   Raz [F:CUN]
Endif
If [F:CUN]CUNSSSTYP = 2 & [F:SRT]LOCCOD  <> 1
   mkstat = 2
   GMESSAGE = mess(49,184,1)       # parametrage erroné pource type de session ( rubrique emplacement invisible)
   Return
Endif

[M:SNL0]STOFCY    = [F:CUN]STOFCY
[M:SNL0]CUNSSSNUM = [F:CUN]CUNSSSNUM
[M:SNL0]CUNSSSDES = [F:CUN]CUNSSSDES
[M:SNL0]CUNSSSTYP = [F:CUN]CUNSSSTYP
[M:SNL0]CUNSSSSTA = [F:CUN]CUNSSSSTA
[M:SNL0]CUNITMWRH = [F:CUN]CUNITMWRH

[M:SNL0]CUNLISNUM = [F:CUL]CUNLISNUM
[M:SNL0]CUNLISDES = [F:CUL]CUNLISDES
[M:SNL0]NBRLIG    = [F:CUL]NBRLIG
[M:SNL0]CUNLISSTA = [F:CUL]CUNLISSTA
[M:SNL0]MVTDES    = [F:CUL]MVTDES
[M:SNL0]WRHCUL    = [F:CUL]WRH
#                                                                                         # hcb 71659 deb
[M:SNL0]MULCTGFLG = [F:CUN]MULCTGFLG  # multi-comptages
Call LECTEXTRA([M:SNL0]CTGUSR,"CUNLISTE","CTGUSR",[F:CUN]CUNSSSNUM,"[F:CUL]CUNLISNUM")   From ATEXTRA
If [F:CUN]MULCTGFLG = 2
   Call LECTEXTRA([M:SNL0]CTGUSR1,"CUNLISTE","CTGUSR1",[F:CUN]CUNSSSNUM,"[F:CUL]CUNLISNUM") From ATEXTRA
   Call LECTEXTRA([M:SNL0]CTGUSR2,"CUNLISTE","CTGUSR2",[F:CUN]CUNSSSNUM,"[F:CUL]CUNLISNUM") From ATEXTRA
Endif
#                                                                                         # hcb 71659 fin

If [M:SNL0]CUNLISSTA  > 5
   [M:SNL0]USR    = [F:CUL]USR
Endif

If [M:SNL0]MVTDES = ""
   [M:SNL0]MVTDES = [F:SRT]MVTDESTXT
Endif
Call GETDEV([M:SNL0]STOFCY) From DEVSUB
[M:SNL0]CUR       = GLOCALDEV

Gosub AFF_RGP_SNL0 From SUBSNL

Return


#########################################################################
# AFF_RGP_SNL0                           Affichage blos regroupement SNL0
#########################################################################
$AFF_RGP_SNL0

# recherche clef regroupement
Gosub TRT_CLE_REGROUPEMENT From STKINV
# traitement regroupement
Gosub TRT_TRT_REGROUPEMENT From STKINV

#activation de toutes les rubriques saisissables
Actzo [M:SNL0]

# on dessactive les rubriques itmref et emplacement
Diszo  [M:SNL0]ITMREF
If dim([M:SNL0]LOC1) > 0
   Diszo  [M:SNL0]LOC1
Endif
If dim([M:SNL0]LOC) > 0
   Diszo  [M:SNL0]LOC
Endif
If dim([M:SNL0]WRH) > 0
   Diszo  [M:SNL0]WRH
Endif
If dim([M:SNL0]LPNNUM) > 0                                     # hcb x3-68147
   Diszo  [M:SNL0]LPNNUM
Endif
# si liste cloturée modif interdite
If [M:SNL0]CUNLISSTA  > 5 |  GSTAIMG(3) = 1    # hcb 74380
   Diszo [M:SNL0]25
   Diszo [M:SNL0]IPTDAT
   Diszo [M:SNL0]USR
   Diszo [M:SNL0]MVTDES
   Diszo [M:SNL0]CTGUSR                                                                   # hcb 71659
   Diszo [M:SNL0]CTGUSR1                                                                  # hcb 71659
   Diszo [M:SNL0]CTGUSR2                                                                  # hcb 71659
Endif

Affzo [M:SNL0]


# si liste non cloturée ajout de ligne permis : activation des rubriques itmref et emplacement
If [M:SNL0]CUNLISSTA  < 6
   Local Integer NOL
   NOL = [M:SNL0]NBLIG
   Gosub AZO_SNL0_RGP From STKINV
#                                                                # hcb 110327 deb
     For Y = 0 To [M:SNL0]NBLIG-1
          If  [M:SNL0]SERSEQ (Y) <> 0 & [M:SNL0]CUNLISSTAD (Y) = 1  & [M:SNL0]NBDETAIL (Y) = 1 & [M:SNL0]STOCOU (Y) <> 0
              Local Char    LMSK
              Local Integer LLLG
              LMSK = "SNL0"
              LLLG = Y
              Gosub VERIF_DESYNCHRO From STKINV1
          Endif
      Next
#                                                                # hcb 110327 deb

Endif
# si liste annulée ,validée partielle, validée ou cloturée modification date imputation interdite
# seuls à compter et comptée l autorisent
If !find([M:SNL0]CUNLISSTA,1,3)
   Grizo  [M:SNL0]IPTDAT
Endif
# hcb 74380 deb
If GSTAIMG(3) = 1
   GSNLSTAIMG3 = 2
Else
   Raz GSNLSTAIMG3
Endif
# hcb 74380 fin

Return

#########################################################################
# CTR_COMPTAGE      Controle comptage si oui desactivation de la rubrique
#########################################################################
$CTR_COMPTAGE
Gosub SET_NOL From STKINV
If [M:SNL0]MODFLG(NOL) = 2
   Return
Endif
If [M:SNL0]QTYSTUNEW(NOL) <> 0
   mkstat = 2
Endif
If [M:SNL0]ZERSTOFLG(NOL) = 2
  mkstat = 2
Endif

Return
#                                                                                         # hcb 71659 deb
#########################################################################
# CTR_COMPTAGE1    Controle comptage1 si oui desactivation de la rubrique
#########################################################################
$CTR_COMPTAGE1
Gosub SET_NOL From STKINV
If [M:SNL0]MODFLG(NOL) = 2
   Return
Endif
If [M:SNL0]QTYSTUNEW1(NOL) <> 0
   mkstat = 2
Endif
If [M:SNL0]ZERSTOFLG1(NOL) = 2
   mkstat = 2
Endif
Return

#########################################################################
# CTR_COMPTAGE2    Controle comptage1 si oui desactivation de la rubrique
#########################################################################
$CTR_COMPTAGE2
Gosub SET_NOL From STKINV
If [M:SNL0]MODFLG(NOL) = 2
   Return
Endif
If [M:SNL0]QTYSTUNEW2(NOL) <> 0
   mkstat = 2
Endif
If [M:SNL0]ZERSTOFLG2(NOL) = 2
   mkstat = 2
Endif
Return

##################################################
Subprog ACT_RAZCUN
Local Integer WI
Local Integer WRAZ
Raz WRAZ
If [M:SNL0]MULCTGFLG = 2
   MES = mess(439,184,1)+"\"            # Attention l'effacement du dernier comptage est directement exécuté
Else
   MES = mess(440,184,1)+"\"            # Attention l'effacement du comptage est directement exécuté
Endif
MES += mess(438,184,1)                  # Confirmation Raz comptage(s)  Oui/Non
Call OUINON(MES,WI) From GESECRAN
If WI <> 2
   End
Endif

If [M:SNL0]MULCTGFLG <> 2
   WRAZ = 3
Else
   If find(2,[SNL0]CUNLISSTAD(0..[M:SNL0]NBLIG-1)) | find(8,[SNL0]CUNLISSTAD(0..[M:SNL0]NBLIG-1))
      WRAZ = 3
   Else
      If find("*2",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1)) | find("+2",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1)) |find("",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1))
         WRAZ = 2
      Else
        If find("*1",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1)) | find("+1",[M:SNL0]SAICOD(0..[M:SNL0]NBLIG-1))
           WRAZ = 1
        Endif
      Endif
   Endif
Endif
If WRAZ <> 0
   Call DEBTRANS From GLOCK
   Trbegin [CUD]
   Filter [CUD] Where CUNSSSNUM = [M:SNL0]CUNSSSNUM &
&                     CUNLISNUM = [M:SNL0]CUNLISNUM
&               Order By Key CUD0
   For [CUD]
   Readlock [CUD] Curr
   If fstat
      GOK = 0
      Call FSTA("CUD") From GLOCK
      Gosub AB_TRT From STKINV
      Break
   Endif

   Case WRAZ
        When 2,3
           Raz [F:CUD]QTYPCUNEW
           Raz [F:CUD]QTYSTUNEW
           Raz [F:CUD]DEPRAT
           Raz [F:CUD]DEPAMT
           Raz [F:CUD]MATCST
           Raz [F:CUD]OVEMATCST
           Raz [F:CUD]MACCST
           Raz [F:CUD]OVEMACCST
           Raz [F:CUD]LABCST
           Raz [F:CUD]OVELABCST
           Raz [F:CUD]SCOCST
           Raz [F:CUD]OVESCOCST
           Raz [F:CUD]INVDTACST
           Raz [F:CUD]PRIORD
           [F:CUD]ZERSTOFLG = 1
           [F:CUD]CUNLISSTA = 1
           If WRAZ = 2
              Raz [F:CUD]QTYPCUNEW2
              Raz [F:CUD]QTYSTUNEW2
              [F:CUD]ZERSTOFLG2 = 1
           Endif
#                                                                        # hcb 110327 deb
           If [F:CUD]SERSEQ <> 0
              Call DEL_CSD([F:CUD]STOFCY,[F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]SERSEQ,WI) From STKINV1
           Endif
#                                                                        # hcb 110327 end
        When 1
           Raz [F:CUD]QTYPCUNEW1
           Raz [F:CUD]QTYSTUNEW1
           [F:CUD]ZERSTOFLG1 = 1
   Endcase

   [F:CUD]UPDUSR    = GUSER
   [F:CUD]UPDDAT    = date$
   Rewrite [F:CUD]
   If fstat
      GOK = 0
      Call FSTA("CUD") From GLOCK
      Gosub AB_TRT From STKINV
      Break
   Endif
   Next
   Filter [CUD]
   Commit
   Effzo [M:SNL0]25
# pour ne pas precharger dans le cas du multi-comptages
   Local Integer WLODCOD1
   WLODCOD1 = [F:SRT]LODCOD1
   Raz [F:SRT]LODCOD1
   Gosub AFF_RGP_SNL0 From SUBSNL

Endif
End
#                                                                                         # hcb 71659 fin

##########################################################################
##                                                       Actions rubriques
##########################################################################
# Appelé avant l'action SAISNLINV
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Gosub SET_NOL From STKINV

Local Shortint WRET

#                                                                                         # hcb 71659  deb
Local Decimal   WQTYSTUNEW
Local Integer   WZERSTOFLG
Raz WQTYSTUNEW
Raz WZERSTOFLG


If [M:SNL0]MULCTGFLG <> 2
   WQTYSTUNEW = [M:SNL0]QTYSTUNEW(NOL)
   WZERSTOFLG = [M:SNL0]ZERSTOFLG(NOL)
Else
   If find([M:SNL0]SAICOD(NOL),"*1","+2")
      WQTYSTUNEW = [M:SNL0]QTYSTUNEW2(NOL)
      WZERSTOFLG = [M:SNL0]ZERSTOFLG2(NOL)
   Elsif find([M:SNL0]SAICOD(NOL),"+ ","+1")
         WQTYSTUNEW = [M:SNL0]QTYSTUNEW1(NOL)
         WZERSTOFLG = [M:SNL0]ZERSTOFLG1(NOL)
   Elsif find([M:SNL0]SAICOD(NOL),"*2"," ")
         WQTYSTUNEW = [M:SNL0]QTYSTUNEW(NOL)
         WZERSTOFLG = [M:SNL0]ZERSTOFLG(NOL)
   Endif
Endif
#                                                                                         # hcb 71659  fin

GIMPINV = 0
GOUVINV = 0
GOUVSNLS = 0                                                          # hcb 110327

Raz GPE                              # hcb 103419
GPOINT = "APRESNBLIG"                # hcb 103419
Gosub  ENTREE From EXEFNC            # hcb 103419


# sur ligne existante
If [M:SNL0]LINFLG(NOL) = 2
# si pas de modif sur la ligne pas d ouverture détail
   If [M:SNL0]MODFLG(NOL) <> 2
      Return
   Endif
# si stock nul et pas d alloué pas d ouverture
   If WZERSTOFLG= 2                                                                       # hcb 71659
      If  [M:SNL0]CUMALLQTY(NOL) = 0
          If [M:SNL0]SERSEQ(NOL) = 0                               # hcb 110327
             Return
          Endif                                                    # hcb 110327
      Else
          GOUVINV = 1
      Endif
   Endif
# si quantite comptée inferieure et detail = 1 controle allouée
#                                  si allouée superieur on ouvre
   If WQTYSTUNEW < [M:SNL0]QTYSTU(NOL)                                                    # hcb 71659
      If [M:SNL0]NBDETAIL(NOL)  = 1
         If  [M:SNL0]CUMALLQTY(NOL) > WQTYSTUNEW                                          # hcb 71659
             GOUVINV = 1
         Endif
      Endif
   Endif

# hcb 57285  deb
# si qtysstunew pas un multiple de pcustucoe on ouvre
   If [M:SNL0]NBDETAIL(NOL)  = 1 & GPE = 0              # hcb 103419
      If (mod(WQTYSTUNEW , [M:SNL0]PCUSTUCOE(NOL)) <> 0) & [M:SNL0]PCUSTUCOE(NOL) <> 1    # hcb 71659
             GOUVINV = 1
             Raz GPE                                    # hcb 103419
       Endif
   Endif
# hcb 57285 fin

# hcb     65339 deb
# si quantite à comptée = 0 et qte comptée <> 0 on ouvre  (import inventaire) si
#    # si pas gestion lot et pas Gestion des no série et pas Gestion des emplacements

   If [M:SNL0]QTYSTU(NOL) = 0 & [M:SNL0]QTYSTUNEW1(NOL) = 0 & [M:SNL0]QTYSTUNEW2(NOL) = 0 &  WQTYSTUNEW <> 0   # hcb 71659
      If [F:ITM]ITMREF<>[M:SNL0]ITMREF(NOL)
         Read [ITM]ITM0=[M:SNL0]ITMREF(NOL)
         If fstat
            Raz [F:ITM]
         Endif
      Endif
      If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SNL0]STOFCY
         Read [ITF]ITF0=[F:ITM]ITMREF;[M:SNL0]STOFCY
         If fstat
            Raz [F:ITF]
         Endif
      Endif
# si pas gestion lot et pas Gestion des no série et pas Gestion des emplacements
     If [F:ITM]LOTMGTCOD = 1 & [F:ITM]SERMGTCOD<2 & [F:ITF]LOCMGTCOD<>2
#       creation lot blanc si besoin
        Read [STL]STL0=[F:ITM]ITMREF;"";""
        If  fstat
            [F:STL]ITMREF    = [F:ITM]ITMREF
            [F:STL]LOT       = ""
            [F:STL]SLO       = ""
            [F:STL]VCRTYP    = 9
            [F:STL]VCRNUM    = [M:SNL0]CUNLISNUM
            [F:STL]VCRLIN    = 0
            [F:STL]REFPER    = date$
            [F:STL]LOTCREDAT = date$
            [F:STL]DLUDAT    = [31/12/2999]     # v6
            [F:STL]NEWLTIDAT = [31/12/2999]     # v6
            [F:STL]POT       = 100
            [F:STL]ACT       = 1
            Call ECRSTL From STKLIB
            If fstat
               Call FSTA("STL") From GLOCK
               Return
            Endif
        Endif
        #                                                                     # hcb 110327 deb
#       ouverture fenetre saisie serie globale ?
        If [M:SNL0]NBDETAIL(NOL)  = 1 & [M:SNL0]SERSEQ(NOL) <> 0 & GOUVINV = 0
           Call CAL_GOUVSNLS("SNL0",NOL) From STKINV1
        Endif
#                                                                     # hcb 110327 end
        Return
     Else
        GOUVINV = 1      # hcb ouverture pour creation du stolot à blanc  si pas geré en lot .....
        GIMPINV = 1
     Endif
   Endif
# hcb          65339 fin

# si quantite differente ouverture si le nombre de détail est <> de 1
   If [M:SNL0]QTYSTU(NOL) <> WQTYSTUNEW                                                   # hcb 71659
      If [M:SNL0]NBDETAIL(NOL)  = 1
#                                                                     # hcb 110327 deb
#       ouverture fenetre saisie serie globale ?
        If [M:SNL0]SERSEQ(NOL) <> 0 &  GOUVINV = 0
           Call CAL_GOUVSNLS("SNL0",NOL) From STKINV1
        Endif
#                                                                     # hcb 110327 end
         Return
      Else
         GOUVINV = 1
      Endif
   Endif

Else
# si nouvelle ligne on ouvre
   If [M:SNL0]ITMREF(NOL) <> "" & [M:SNL0]MODFLG(NOL) = 2
      GOUVINV = 4
   Endif
Endif
Return

Subprog IB_NBLIG
Gosub SET_NOL From STKINV
# Déblocage
GBOUT1 = mess(425,199,1)
# Inventaire
GBOUT2 = mess(439,199,1)
# Ajout ligne(s)
GBOUT3 = mess(442,199,1)
# sections analytique ligne
#GBOUT4
# Suppression ligne(s)
GBOUT5 = mess(504,199,1)
# Suppression article
GBOUT6 = mess(505,199,1)
# No série à inventorier                                              # hcb 110327
GBOUT7 = mess(650,199,1)                                              # hcb 110327

# pas de suppression ligne si la session et en traitement global
If [F:CUN]CUNLASFLG  = 2
   GBOUT5 = ""
Endif

# pas de suppression article ni ligne si le code etat est different de "A compter"
If [M:SNL0]CUNLISSTAD (NOL) <> 1 | GSNLSTAIMG3 = 2       # hcb 74380
   GBOUT5 = ""
   GBOUT6 = ""
Endif
# pas de suppression article si un code etat est different de "A compter" pour cet article
If sigma(0,[M:SNL0]NBLIG-1,[M:SNL0]CUNLISSTAD(indcum) > 1 & [M:SNL0]ITMREF(indcum)=[M:SNL0]ITMREF(NOL))
   GBOUT6 = ""
Endif

# Pas de sections analytiques si invisible

If [F:DTR]STOCCECOD = 3
   GBOUT4 = ""
Endif

If  [M:SNL0]CUNLOKFLG(NOL)  = 1 | GSNLSTAIMG3 = 2       # hcb 74380
    GBOUT1 = ""
Endif
If [M:SNL0]ITMREF(NOL)  = ""
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT7 = ""                                                       # hcb 110327
Endif
#                                                                     # hcb 110327 deb
# l article ne gère pas les séries "globale"  pas de saisie des numéros de séries
If [M:SNL0]SERSEQ(NOL) = 0
    GBOUT7 = ""
Endif
# si pas d'écart pas de saisie des numéros de séries
If [M:SNL0]QTYSTU (NOL) = [M:SNL0]QTYSTUNEW (NOL)
    GBOUT7 = ""
Endif
# si pas de comptage
If [M:SNL0]QTYSTUNEW (NOL) = 0 & [M:SNL0]QTYPCUNEW (NOL) = 0
    GBOUT7 = ""
Endif
# si multicomptage comptage 1 et comtage 2 doit etre fait
If [M:SNL0]MULCTGFLG = 2 & ([M:SNL0]CTG1(NOL) <>  2 | [M:SNL0]CTG2(NOL) <>  2)
   GBOUT7 = ""
Endif

# si nombre de détails > 1  pas de saisie des numéros de séries
If [M:SNL0]NBDETAIL(NOL)  > 1
   GBOUT7 = ""
Endif
# si multicomptage  est que l enregistrement a ete fait sur le comptage 2 il faut ressortir avant
If dim(GSNLSERE) > 0
   GBOUT7 = ""
Endif
#                                                                     # hcb 110327 fin
# si liste cloturée ajout ligne interdit
If [M:SNL0]CUNLISSTA  = 6
    GBOUT3 = ""
Endif
# si GCONSULT = 2  ajout ligne interdit
If  GCONSULT = 2  | GSNLSTAIMG3 = 2       # hcb 74380
    GBOUT3 = ""
Endif


# si regroupement = Ajout nul pas de clic droit
If [M:SNL0]CUNLISSTAD(NOL)  = 7
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT1 = ""
Endif
End
Subprog B1_NBLIG
Gosub SET_NOL From STKINV

Local Char LFILTRE(250)
Local Char CRITER1(250)(3)
Local Char LCUL
Local Char RGP_FILTRE (250)                                                               # hcb 71659
Local Char RGP_FILTRE1(250)                                                               # hcb 71659
Local Char RGP_FILTRE2(250)                                                               # hcb 71659

Local Decimal LG
LG = NOL


LFILTRE = "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM & [F:CUD]CUNLOKFLG=2"

#filtre regroupement
Call DEF_CRITERE_RGP("SNL0",LG,CRITER1,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2) From STKINV    # hcb 71659
Call TRT_DEBLOCAGE(LFILTRE,CRITER1,LG,LCUL) From STKINV

If LCUL <>  " "
  [M:SNL0]CUNLOKFLG(NOL) = 1
  Affzo [M:SNL0]CUNLOKFLG(NOL)
Endif

End


Subprog B2_NBLIG
Gosub SET_NOL From STKINV

#Ouverture fenêtre de saisie inventaire  par clic droit
GOUVINV = 2
If [M:SNL0]QTYSTU(NOL) = 0 & [M:SNL0]QTYSTUNEW(NOL) = 0
   GIMPINV = 1
Endif
End

Subprog B3_NBLIG
#Ouverture fenêtre de saisie inventaire  par clic droit ajout de ligne
GOUVINV = 3

End
