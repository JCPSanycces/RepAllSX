Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
[M:SNL0]MODFLG(NOL) = 2

End

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From STKINV
# hcb 33092 deb
Local Integer WI
WI = find(2,[M:SNL0]MODFLG(0..[M:SNL0]NBLIG-1))
If WI > 0
      mkstat = 2
      GMESSAGE = mess(251,184,1)       # il faut d'abord enregistrer !
      End
Endif
# hcb 33092 fin

If [F:ITM]ITMREF <> VALEUR
   Read [F:ITM]ITM0=VALEUR
   If fstat
      mkstat = 2
      GMESSAGE = mess(212,199,1)       # article inexistant
      End
   Endif
Endif

#statut article
If [F:CUN]ITMSTA006 = 1
   If [F:ITM]ITMSTA = 6
      mkstat = 2
      GMESSAGE = mess(557,199,1)       # l article est non utilisable   (hcb 64807)
      End
   Endif
Endif

If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SNL0]STOFCY
   Read [ITF]ITF0=[F:ITM]ITMREF;[M:SNL0]STOFCY
   If fstat
      mkstat = 2
      GMESSAGE = mess(260,199,1)       # article inexistant sur le site
      End
   Endif
Endif

#gestion stock
If [F:ITF]STOMGTCOD < 2
   mkstat = 2
   GMESSAGE = mess(137,194,1)          # non gere  en stock
   End
Endif

#controle mode inventaire

Local Integer WOK
WOK = 2
If [F:CUN]CUNITMWRH =  2
   Read [ITW]ITW0=VALEUR;[M:SNL0]WRHCUL
   If fstat
      mkstat=2
      GMESSAGE=VALEUR-":"-mess(343,184,1)
      End
   Endif
   If [F:ITW]CUNWRHFLG=2
      Case [F:CUN]CUNSSSMOD
         When 2 :
           If [F:ITW]CUNCOD <> 1
              WOK = 9
           Endif
         When 3 :
           If [F:ITW]CUNCOD <> 2
              WOK = 9
           Endif
         When Default
           If [F:ITW]CUNCOD = 3
              WOK = 9
           Endif
      Endcase
   Else
      Case [F:CUN]CUNSSSMOD
         When 2 :
           If [F:ITF]CUNCOD <> 1
              WOK = 9
           Endif
         When 3 :
           If [F:ITF]CUNCOD <> 2
              WOK = 9
           Endif
         When Default
           If [F:ITF]CUNCOD = 3
              WOK = 9
           Endif
      Endcase
   Endif
Else
   Case [F:CUN]CUNSSSMOD
      When 2 :
        If [F:ITF]CUNCOD <> 1
           WOK = 9
        Endif
      When 3 :
        If [F:ITF]CUNCOD <> 2
           WOK = 9
        Endif
      When Default
        If [F:ITF]CUNCOD = 3
           WOK = 9
        Endif
   Endcase
Endif
If WOK = 9
   mkstat = 2
   GMESSAGE = mess(444,199,1)       # Cet article est de  mode d inventaire non défini pour la session !
   End
Endif
# controle classe abc
WOK = 2
Case [F:ITF]ABCCLS
  When 1 : If [F:CUN]ABCCLSA <> 2
              WOK = 9
           Endif
  When 2 : If [F:CUN]ABCCLSB <> 2
              WOK = 9
           Endif
  When 3 : If [F:CUN]ABCCLSC <> 2
              WOK = 9
           Endif
  When 4 : If [F:CUN]ABCCLSD <> 2
              WOK = 9
           Endif
Endcase
If WOK = 9
   mkstat = 2
   GMESSAGE = mess(443,199,1)       # class abc non coché
   End
Endif
If dim([M:SNL0]ITMDES1)    > 0
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SNL0]ITMDES1(NOL), "[F:ITM]") From TRTX3
Endif

[M:SNL0]STU(NOL)        = [F:ITM]STU
[M:SNL0]ABC(NOL)        = [F:ITF]ABCCLS
Affzo [M:SNL0]STU(NOL)
Affzo [M:SNL0]ABC(NOL)
Affzo [M:SNL0]ITMDES1(NOL)

End

Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()

[M:SNL0]FILTREITF  = "[F:ITF]STOFCY=[M:SNL0]STOFCY"

#mode inventaire
# cunsssmod 1 manuel
# cunsssmod 2 tournant
# cunsssmod 3 annuel
If [F:CUN]CUNITMWRH = 2
   [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&[F:ITW]WRH=[M:SNL0]WRHCUL"
   Case [F:CUN]CUNSSSMOD
      When 2 :
          [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD=1)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD=1))"   # 1 = tournant
      When 3 :
          [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD=2)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD=2))"   # 2 = annuel
      When Default
          [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&(([F:ITW]CUNWRHFLG=2&[F:ITW]CUNCOD<>3)|([F:ITW]CUNWRHFLG=1&[F:ITF]CUNCOD<>3))"   # 3 = pas inventaire
   Endcase
Else
   Case [F:CUN]CUNSSSMOD
     When 2 :
       [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&[F:ITF]CUNCOD=1"   # 1 = tournant
     When 3 :
       [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&[F:ITF]CUNCOD=2"   # 2 = annuel
     When Default
       [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&[F:ITF]CUNCOD<>3"  # 3 = pas inventaire
   Endcase
Endif
#classe abcd sauf tournant
If [F:CUN]CUNSSSMOD <> 2
   If !([F:CUN]ABCCLSA = 1 & [F:CUN]ABCCLSB = 1 & [F:CUN]ABCCLSC = 1& [F:CUN]ABCCLSD = 1)
      [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&find([F:ITF]ABCCLS"
      If [F:CUN]ABCCLSA = 2
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",1"
      Endif
      If [F:CUN]ABCCLSB = 2
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",2"
      Endif
      If [F:CUN]ABCCLSC = 2
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",3"
      Endif
      If [F:CUN]ABCCLSD = 2
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",4"
      Endif
      [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+")"
   Endif
Endif
#classe abcd tournant
If [F:CUN]CUNSSSMOD = 2
   If !([F:CUN]ABCCLSA = 1 & [F:CUN]ABCCLSB = 1 & [F:CUN]ABCCLSC = 1& [F:CUN]ABCCLSD = 1)
      [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+"&find([F:ITF]ABCCLS"
      If [F:CUN]ABCCLSA = 2 & [F:CUN]CUNNBRA <> 0
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",1"
      Endif
      If [F:CUN]ABCCLSB = 2 & [F:CUN]CUNNBRB <> 0
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",2"
      Endif
      If [F:CUN]ABCCLSC = 2 & [F:CUN]CUNNBRC <> 0
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",3"
      Endif
      If [F:CUN]ABCCLSD = 2 & [F:CUN]CUNNBRC <> 0
         [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+",4"
      Endif
      [M:SNL0]FILTREITF = [M:SNL0]FILTREITF+")"
   Endif
Endif


End


Subprog C_NBLIG

Gosub SET_NOL From STKINV
Case status
    When 73,82:          Gosub TEST_INSERT_SNL0 From STKINV   # Insertion
Endcase

End


##################################################
Subprog ACT_BLOSNL
Gosub SET_NOL From STKINV
Local Char LFILTRE(250)
Local Char CRITER1(250)(3)
Local Char LCUL
Local Decimal LG
Local Decimal I
LG = NOL
CRITER1 = "1=1"
LFILTRE = "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM & [F:CUD]CUNLOKFLG=2"

Call TRT_DEBLOCAGE(LFILTRE,CRITER1,LG,LCUL) From STKINV
If LCUL <> ""
   For I = 0 To [M:SNL0]NBLIG-1
       [M:SNL0]CUNLOKFLG  (I) = 1
   Next I
   Affzo [M:SNL0]CUNLOKFLG
Endif


End


##################################################
Subprog ACT_CLOSNL

Local Char LFILTRE(250)
Local Char CRITER1(250)
Local Char LCUL
Local Decimal I

CRITER1 = "1=1"
LFILTRE = "[F:CUD]STOFCY=[M:SNL0]STOFCY & [F:CUD]CUNSSSNUM=[M:SNL0]CUNSSSNUM & [F:CUD]CUNLISNUM=[M:SNL0]CUNLISNUM & [F:CUD]CUNLISSTA < 3"

Call TRT_CLOTURE(LFILTRE,CRITER1,0,LCUL,[M:SNL0]CUNSSSNUM,[M:SNL0]CUNLISNUM) From STKINV
If LCUL <> ""
   Effzo [M:SNL0]25
   Gosub LOAD_SNL0   From SUBSNL

Endif

End

