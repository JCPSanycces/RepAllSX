#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque RSAQ 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CRN
mkstat = 0
zoncou = "CRN"
indice = 0
If varmode([M]CRN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRN" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CRN,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CRN" : GZNUM = 29314 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CRN2
mkstat = 0
zoncou = "CRN2"
indice = 0
If varmode([M]CRN2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRN2" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CRN2,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CRN2" : GZNUM = 49207 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone FLGWDR
mkstat = 0
zoncou = "FLGWDR"
indice = 0
IMPENT = [M]FLGWDR
If varinit([M]FLGWDR,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGWDR,indice)=0
 [M]FLGWDR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGWDR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGWDR(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FLGWDR" : GZNUM = 44204 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGWDR = IMPENT

## Zone NOTECUST
mkstat = 0
zoncou = "NOTECUST"
indice = 0
If varmode([M]NOTECUST,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOTECUST" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NOPKG
mkstat = 0
zoncou = "NOPKG"
indice = 0
If varinit([M]NOPKG,indice)=0
 [M]NOPKG = "1"
Endif
If varmode([M]NOPKG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOPKG" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NOPKG,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NOPKG([M]NOPKG) From RSAQ
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NOPKG" : GZNUM = 3126 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NOREC
mkstat = 0
zoncou = "NOREC"
indice = 0
If varinit([M]NOREC,indice)=0
 [M]NOREC = "1"
Endif
If varmode([M]NOREC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NOREC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]NOREC,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_NOREC([M]NOREC) From RSAQ
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NOREC" : GZNUM = 26811 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone TYPEXP
mkstat = 0
zoncou = "TYPEXP"
indice = 0
IMPENT = [M]TYPEXP
WNUM = IMPENT
If varinit([M]TYPEXP,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPEXP,indice)=0
 [M]TYPEXP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPEXP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPEXP(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYPEXP(IMPENT) From RSAQ
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPEXP" : GZNUM = 32516 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPEXP = IMPENT

## Zone VOLFIL
mkstat = 0
zoncou = "VOLFIL"
indice = 0
If varmode([M]VOLFIL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VOLFIL" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_VOLFIL([M]VOLFIL) From RSAQ
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "VOLFIL" : GZNUM = 15179 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "RSAQ"
Return

