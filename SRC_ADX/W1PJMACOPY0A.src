#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY0A 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:42"
A_USER  = "DOC"
A_STAMP = "20181109230542"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMACOPY0A [PJMAC0A]
Gosub HORODAT
Local Inpbox "PJMACOPY0A" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJMAC0A] As [SIM_]
Grizo [PJMAC0A]10
Grizo [PJMAC0A]11
Grizo [PJMAC0A]15
Grizo [PJMAC0A]20
Grizo [PJMAC0A]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJMAC0A]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=137 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=137 : Y1(1)=5 : Y2(1)=10
X1(2)=1 : X2(2)=137 : Y1(2)=11 : Y2(2)=12
X1(3)=1 : X2(3)=137 : Y1(3)=13 : Y2(3)=14
X1(4)=1 : X2(4)=137 : Y1(4)=15 : Y2(4)=16
Return

$ON_TSALFCY
Onevent CONTROL Call C_TSALFCY(zc) From W1PJMACOPY0A
Onevent AFTER_CHANGE Gosub AMM_TSALFCY From W1PJMACOPY0A
Onevent BEFORE_INPUT Call AS_TSALFCY(zc) From W1PJMACOPY0A
Return

Subprog AS_TSALFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TSALFCY(zc) From W1PJMACOPY0A
Onkey 144 Titled GBOUTP Call P_TSALFCY(zc) From W1PJMACOPY0A
Onkey 146 Titled GBOUTA Call SA_TSALFCY(zc) From W1PJMACOPY0A
Gosub _AFF
End

Subprog C_TSALFCY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","F",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TSALFCY
Call AM_TSALFCY(zc)
If !mkstat & GOBJET
 zoncou = "TSALFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TSALFCY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TSALFCY(VALEUR) From SUBPJMACOPY
If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZTSALFCY)")>indice
 [M]TSALFCY(indice) = VALEUR
 Affzo ZTSALFCY(indice)
Endif
Gosub _AFF
End

Subprog S_TSALFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "F"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_TSALFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TSALFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTSALFCY
Onevent BEFORE_AREA Gosub AV_ZTSALFCY From W1PJMACOPY0A
Return

$AV_ZTSALFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]TSALFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

