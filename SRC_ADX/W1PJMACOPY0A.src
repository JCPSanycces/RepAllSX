 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TOPEDEFFCY" : GZNUM = 48539 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "TOPEDEFFCY" : GZNUM = 48539 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","F",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TOPEDEFFCY" : GZNUM = 48539 : Endif
  If !mkstat
   ## Action STD
   Call C_TOPEDEFFCY(VALEUR) From SUBPJMACOPY
   If mkstat : GERR = 1 : GZONE = "TOPEDEFFCY" : GZNUM = 48539 : Endif
