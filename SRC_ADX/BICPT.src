#####################################################
#  Traitement des Funprog utiles à la BI compta V6
#####################################################

#############################################
#  Vérificatio saisie du paramètre BILEDTYP
#############################################
Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM
Value Char VALEUR
Variable Integer OK
If PARAM<>"BILEDTYP"
 #Erreur dans le code paramètre
 GMESSAGE = mess(204, 196, 2)
 GERR = 1
 OK = 0
 End
Endif
If dim([M:ADWP]NBVAR)
 If [M:ADWP]CMP<>""
  If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
  Local Char MODELE(GLONGCM)
  Call SETGCM([M:ADWP]CMP,MODELE) From CPTDIV
  Read [GCM]GCM0 = MODELE
  If !fstat & [F:GCM]CFMAUT(val(VALEUR)-1)=2
   #Référentiel automatique non autorisé ici
   GMESSAGE=mess(207,105,1)
   mkstat=2
   GERR=1
   OK=0
   End
  Endif
 Else
  Local Char VALAUTO(20)
  Local Integer I,TYPAUTO(0..9) : I=0
  Call PARAM("","LEDTYPAUT",VALAUTO) From ADOVAL
  While len(VALAUTO)>0
   If val(left$(VALAUTO,1))<>1
    TYPAUTO(I)=val(left$(VALAUTO,1))
    I+=1
    VALAUTO=right$(VALAUTO,2)
   Elsif val(left$(VALAUTO,1))=1
    TYPAUTO(I)=val(left$(VALAUTO,2))
    I+=1
    VALAUTO=right$(VALAUTO,3)    
   Endif
  Wend
  If find(val(VALEUR),TYPAUTO(0..I))
   #Référentiel automatique non autorisé ici
   GMESSAGE=mess(207,105,1)
   mkstat=2
   GERR=1
   OK=0
   End
  Endif
 Endif
Endif
OK=1
End


####################################
## Montants  écritures copmptables
####################################
Funprog MONTANT(SENS,DEVISE)
Value Char SENS
Value Char DEVISE
Local Decimal MONTANT , SIGNE
If dim([F:DAA]ANALIN)<0
 SIGNE = [F:DAE]SNS
 Case DEVISE
  When "CUR" : MONTANT = [F:DAE]AMTCUR
  When "LED" : MONTANT = [F:DAE]AMTLED
  When "QTY" : MONTANT = [F:DAE]QTY
 Endcase
Else
 SIGNE = [F:DAA]SNS
 Case DEVISE
  When "CUR" : MONTANT = [F:DAA]AMTCUR
  When "LED" : MONTANT = [F:DAA]AMTLED
  When "QTY" : MONTANT = [F:DAA]QTY
 Endcase
Endif
If (SENS="D" & SIGNE>0) or (SENS="C" & SIGNE<0)
 End MONTANT
Else
 End 0
Endif
End

Funprog SOLDE(DEVISE)
Value Char DEVISE
Local Decimal SOLDE, DEBIT , CREDIT
Raz SOLDE, DEBIT, CREDIT
Case DEVISE
 When "CUR"
  DEBIT  = func BICPT.MONTANT("D","CUR")
  CREDIT = func BICPT.MONTANT("C","CUR")
 When "LED"
  DEBIT  = func BICPT.MONTANT("D","LED")
  CREDIT = func BICPT.MONTANT("C","LED")
 When "QTY"
  DEBIT  = func BICPT.MONTANT("D","QTY")
  CREDIT = func BICPT.MONTANT("C","QTY")
Endcase 
SOLDE  = DEBIT - CREDIT
End SOLDE

Funprog MONTANTL(SENS,DEVISE,LEDTYP)
Value Char SENS
Value Char DEVISE
Value Integer LEDTYP
Local Decimal MONTANT , SIGNE

If dim([F:DAA]ANALIN)<0
 SIGNE = [F:DAE]SNS
 Case DEVISE
  When "CUR" : MONTANT = [F:DAE]AMTCUR
  When "LED" 
   If [F:DAE]LEDTYP=LEDTYP
    MONTANT = [F:DAE]AMTLED
   Endif
  When "QTY"
   If [F:DAE]LEDTYP=LEDTYP
    MONTANT = [F:DAE]QTY
   Endif
 Endcase
Else
 SIGNE = [F:DAA]SNS
 Case DEVISE
  When "CUR" : MONTANT = [F:DAA]AMTCUR
  When "LED"
   If [F:DAA]LEDTYP=LEDTYP
    MONTANT = [F:DAA]AMTLED
   Endif
  When "QTY"
   If [F:DAA]LEDTYP=LEDTYP
    MONTANT = [F:DAA]QTY
   Endif
 Endcase
Endif
If (SENS="D" & SIGNE>0) or (SENS="C" & SIGNE<0)
 End MONTANT
Else
 End 0
Endif
End

Funprog SOLDEL(DEVISE,LEDTYP)
Value Char DEVISE
Value Integer LEDTYP
Local Decimal SOLDE, DEBIT , CREDIT
Raz SOLDE, DEBIT, CREDIT
Case DEVISE
 When "CUR"
  DEBIT  = func BICPT.MONTANT("D","CUR")
  CREDIT = func BICPT.MONTANT("C","CUR")
 When "LED"
  DEBIT  = func BICPT.MONTANTL("D","LED",LEDTYP)
  CREDIT = func BICPT.MONTANTL("C","LED",LEDTYP)
 When "QTY"
  DEBIT  = func BICPT.MONTANTL("D","QTY",LEDTYP)
  CREDIT = func BICPT.MONTANTL("C","QTY",LEDTYP)
Endcase 
SOLDE  = DEBIT - CREDIT
End SOLDE

#################################### 
## Sous-programme d'alimentation des champs Axe et Section de l'univers comptabilité 
## Funprog SETDIE(NUMERO)
## Funprog GETDIENAM(NUMERO)
## Funprog SETCCE(NUMERO)
## Funprog GETCCENAM(NUMERO)
####################################

$SETGLBDIE
If dim([V]GBIDIELIST)<0
 Global Char    GBIDIELIST(GLONDIE)(1..20)
 For I=1 To 20
  If I<10
   Call PARAM("","BIDIE0"+num$(I),GBIDIELIST(I)) From ADOVAL
  Else
   Call PARAM("","BIDIE"+num$(I),GBIDIELIST(I)) From ADOVAL
  Endif
 Next
Endif
Return

############################################################
# Alimentation des DIE1 à 9 de la table de fait
############################################################
Funprog GETDIENAM(NUMERO)
Value Integer NUMERO
Local Char NAME
Gosub SETGLBDIE
Call LECTEXTRA(NAME,"GDIE","DESTRA",GBIDIELIST(NUMERO),"") From ATEXTRA
If NAME="" : NAME=num$(NUMERO) : Endif
End NAME

Funprog GETCCENAM(NUMERO,ABREV)
Value Integer NUMERO
Value Char    ABREV
Local Char CCE,NAME
Raz NAME
Gosub SETGLBDIE
CCE = func BICPT.SETCCE(NUMERO,ABREV)
If CCE<>""
 Call LECTEXTRA(NAME,"CACCE","DESTRA",GBIDIELIST(NUMERO),CCE) From ATEXTRA
 If NAME="" : NAME=num$(NUMERO) : Endif
Endif
End NAME


Funprog GETPYRDES(TYP,PYRAMIDE)
Value Integer TYP
Value Char    PYRAMIDE
Local Char DES
Case TYP
 When 1 : #Compte
  Call LECTEXTRA(DES,"GACCPYM","DESTRA",PYRAMIDE,"") From ATEXTRA
 When 2 : #Section
  Call LECTEXTRA(DES,"GCCEPYM","DESTRA",PYRAMIDE,"") From ATEXTRA
Endcase
End DES

Funprog GETGRPDES(TYP,PYRAMIDE,GROUPE)
Value Integer TYP
Value Char    PYRAMIDE
Value Char    GROUPE
Local Char DES
Case TYP
 When 1 : #Compte
  Call LECTEXTRA(DES,"GACCGRUPYM","DESTRA",PYRAMIDE,GROUPE) From ATEXTRA
 When 2 : #Section
  Call LECTEXTRA(DES,"GCCEGRUPYM","DESTRA",PYRAMIDE,GROUPE) From ATEXTRA
Endcase
End DES

############################################################
# Synchronisation Alimentation des DIE1 à 9 & CCE 1 à 9
# NUMERO = N° d'axe
# ABREV  = Abreviation de la table d'origine
############################################################
Funprog SETDIE(NUMERO,ABREV)
Value Integer NUMERO
Value Char    ABREV
Local Char DIE
Gosub SETGLBDIE
For I=0 To evalue("dim([F:"+ABREV+"]DIE)")-1
 If GBIDIELIST(NUMERO)= evalue("[F:"+ABREV+"]DIE("+num$(I)+")")
  DIE=evalue("[F:"+ABREV+"]DIE("+num$(I)+")")
  Break
 Endif
Next
End DIE

Funprog SETCCE(NUMERO,ABREV)
Value Integer NUMERO
Value Char    ABREV
Local Char CCE
Gosub SETGLBDIE
For I=0 To evalue("dim([F:"+ABREV+"]DIE)")-1
 If GBIDIELIST(NUMERO)=evalue("[F:"+ABREV+"]DIE("+num$(I)+")")
  CCE=evalue("[F:"+ABREV+"]CCE("+num$(I)+")")
  Break
 Endif
Next
End CCE

Funprog GETPLAN(SOCIETE,LEDTYP)
Value Char SOCIETE
Value Integer LEDTYP
Local Char PLAN(GLONCOA)
Call LECPLAN(SOCIETE,LEDTYP,PLAN)From CPTDIV
End PLAN

Funprog SETCOA(NUM,LEDTYP)
Value Integer NUM
Value Integer LEDTYP
Local Char PLAN
If NUM=LEDTYP
 PLAN=[F:DAE]COA
Else
 Raz PLAN
Endif
End PLAN

Funprog SETACC(NUM,LEDTYP)
Value Integer NUM
Value Integer LEDTYP
Local Char ACC
If NUM=LEDTYP
 ACC=[F:DAE]ACC
Else
 Raz ACC
Endif
End ACC

#Pour filtre synchronisation EXPENSES
# Récupération du référentiel à partir de la société et du type de référentiel
Funprog GETLED(CPY,LEDTYP) 
Value Char CPY
Value Integer LEDTYP
#
Local Char DOSSIER
If GDOSSIER<>"" : DOSSIER=GDOSSIER:  Else : DOSSIER=nomap : Endif  
If !clalev([F:CPY]) : Local File =DOSSIER+".COMPANY"  [CPY] : Endif
If !clalev([F:GCM]) : Local File =DOSSIER+".GACM"     [GCM] : Endif

Local Char LED(GLONLED)
Call LECTURE ("CPY",CPY,"") From CONTOBJ
Call LECTURE ("GCM",[F:CPY]ACM,"") From CONTOBJ
LED=[F:GCM]LED(LEDTYP-1)
End LED


###############################################################
## Conversion devise
############################################################### 
Funprog BUDCNV(MTORG,DEVORG,DEVDES,TYPCOURS)
Value Decimal MTORG
Value Char    DEVORG
Value Char    DEVDES
Value Integer TYPCOURS
Local Decimal MTDES
Local Integer STAT
If DEVORG="" or DEVDES=""
 End 0
Else
 Call CONVERT3(DEVORG,DEVDES,DEVDES,TYPCOURS,datesyst,MTORG,MTDES,0,STAT) From CPTSUB
 End MTDES
Endif
End 0


###############################################################
## Nombre de période pour une société
############################################################### 
Funprog PERNBR(COMPANY,LEDGER_TYPE,FISCALYEAR)
Value Char    COMPANY
Value Integer LEDGER_TYPE
Value Integer FISCALYEAR
#
Local Char DOSSIER
If GDOSSIER<>"" : DOSSIER=GDOSSIER:  Else : DOSSIER=nomap : Endif  
If !clalev([PER]) : Local File =DOSSIER+".PERIOD" [PER] : Endif

Local Integer PERIOD : PERIOD=0
Filter [PER] Where CPY=COMPANY & LEDTYP=LEDGER_TYPE & FIYNUM=FISCALYEAR
For [PER]PER0
 PERIOD+=1
Next
Filter [PER]
End PERIOD

###############################################################
## Date de la période
############################################################### 
Funprog GETPERDAT(COMPANY,LEDGER_TYPE,FISCALYEAR,PERNUM)
Value Char    COMPANY
Value Integer LEDGER_TYPE
Value Integer FISCALYEAR
Value Integer PERNUM
#
Local Char DOSSIER
If GDOSSIER<>"" : DOSSIER=GDOSSIER:  Else : DOSSIER=nomap : Endif  
If !clalev([PER]) : Local File =DOSSIER+".PERIOD" [PER] : Endif

Local Date DATPER : DATPER=[0/0/0]
Read [PER]PER0 = COMPANY;LEDGER_TYPE;FISCALYEAR;PERNUM
If !fstat
 DATPER=[F:PER]PERSTR
Endif
End DATPER
