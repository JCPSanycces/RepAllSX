#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe EDIPURGE

#$GATEWAYS #US 116198/10 ETNA
#  Case AGATEWAY:
#    When "MET_PURGE" Gosub MET_PURGE_GATEWAY
#  Endcase
#Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AINIT"            :         Gosub AINIT
          When "AREAD"            :         Gosub AREAD
        Endcase
  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
   When "NUMBATCHDEB" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub NUMBATCHDEB_CONTROL
       When 'PROPAGATE'    : Gosub NUMBATCHDEB_PROPAGATE
     Endcase
   When "NUMBATCHFIN" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub NUMBATCHFIN_CONTROL
       When 'PROPAGATE'    : Gosub NUMBATCHFIN_PROPAGATE
     Endcase
   When "CREDATDEB" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub CREDATDEB_CONTROL
       When 'PROPAGATE'    : Gosub CREDATDEB_PROPAGATE
     Endcase
   When "CREDATFIN" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub CREDATFIN_CONTROL
       When 'PROPAGATE'    : Gosub CREDATFIN_PROPAGATE
     Endcase
   When "PARCODDEB" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub PARCODDEB_CONTROL
       When 'PROPAGATE'    : Gosub PARCODDEB_PROPAGATE
     Endcase
   When "PARCODFIN" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub PARCODFIN_CONTROL
       When 'PROPAGATE'    : Gosub PARCODFIN_PROPAGATE
     Endcase
   When "CATCODDEB" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub CATCODDEB_CONTROL
       When 'PROPAGATE'    : Gosub CATCODDEB_PROPAGATE
     Endcase
   When "CATCODFIN" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub CATCODFIN_CONTROL
       When 'PROPAGATE'    : Gosub CATCODFIN_PROPAGATE
     Endcase
   When "STA2" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub STA2_CONTROL
     Endcase
   When "STA3" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub STA3_CONTROL
     Endcase
   When "STA4" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub STA4_CONTROL
     Endcase
   When "TESTFLGYES" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub TESTFLGYES_CONTROL
     Endcase
   When "TESTFLGNO" :
     Case [L]ARULE
       When 'CONTROL'      : Gosub TESTFLGNO_CONTROL
     Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "MET_PURGE" Gosub MET_PURGE
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

######################################################################################

$NUMBATCHDEB_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("NUMBATCHFIN")
Return

$NUMBATCHDEB_PROPAGATE
  If this.NUMBATCHFIN = ""
    this.NUMBATCHFIN = this.NUMBATCHDEB
  Endif
  Gosub NUMBATCHFIN_CONTROL
Return

$NUMBATCHFIN_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("NUMBATCHFIN")
  If this.NUMBATCHFIN < this.NUMBATCHDEB
    ASTATUS = fmet this.ASETERROR("NUMBATCHFIN",mess(44,199,1),[V]CST_AERROR)
  Endif
Return

$NUMBATCHFIN_PROPAGATE
Return

######################################################################################

$CREDATDEB_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("CREDATFIN")
Return

$CREDATDEB_PROPAGATE
  If this.CREDATFIN = [0/0/0]
    this.CREDATFIN = this.CREDATDEB
  Endif
  Gosub CREDATFIN_CONTROL
Return

$CREDATFIN_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("CREDATFIN")
  If this.CREDATFIN < this.CREDATDEB
    ASTATUS = fmet this.ASETERROR("CREDATFIN",mess(44,199,1),[V]CST_AERROR)
  Endif
Return

$CREDATFIN_PROPAGATE
Return

######################################################################################

$PARCODDEB_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("PARCODFIN")
Return

$PARCODDEB_PROPAGATE
  If this.PARCODFIN = ""
    this.PARCODFIN = this.PARCODDEB
  Endif
  Gosub PARCODFIN_CONTROL
Return

$PARCODFIN_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("PARCODFIN")
  If this.PARCODFIN < this.PARCODDEB
    ASTATUS = fmet this.ASETERROR("PARCODFIN",mess(44,199,1),[V]CST_AERROR)
  Endif
Return

$PARCODFIN_PROPAGATE
Return

######################################################################################

$CATCODDEB_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("CATCODFIN")
Return

$CATCODDEB_PROPAGATE
  If this.CATCODFIN = ""
    this.CATCODFIN = this.CATCODDEB
  Endif
  Gosub CATCODFIN_CONTROL
Return

$CATCODFIN_CONTROL
  Local Integer WOK
  WOK = fmet this.ADELETERROR("CATCODFIN")
  If this.CATCODFIN < this.CATCODDEB
    ASTATUS = fmet this.ASETERROR("CATCODFIN",mess(44,199,1),[V]CST_AERROR)
  Endif
Return

$CATCODFIN_PROPAGATE
Return

######################################################################################

$STA2_CONTROL
  Gosub STAX_DELETEERROR
Return

$STA3_CONTROL
  Gosub STAX_DELETEERROR
Return

$STA4_CONTROL
  Gosub STAX_DELETEERROR
Return

$STAX_DELETEERROR
  Local Integer WOK
  WOK = fmet this.ADELETERROR("STA2")
  WOK = fmet this.ADELETERROR("STA3")
  WOK = fmet this.ADELETERROR("STA4")
Return

######################################################################################

$TESTFLGYES_CONTROL
  Gosub TESTFLGX_DELETEERROR
Return

$TESTFLGNO_CONTROL
  Gosub TESTFLGX_DELETEERROR
Return

$TESTFLGX_DELETEERROR
  Local Integer WOK
  WOK = fmet this.ADELETERROR("TESTFLGYES")
  WOK = fmet this.ADELETERROR("TESTFLGNO")
Return

######################################################################################

$AINIT
  Gosub LOAD_DEFAULT
Return

$AREAD
  Gosub LOAD_DEFAULT
Return

$LOAD_DEFAULT
  this.TESTFLGYES = [V]CST_AYES
  this.TESTFLGNO  = [V]CST_ANO
  this.STA2       = [V]CST_ANO
  this.STA3       = [V]CST_ANO
  this.STA4       = [V]CST_ANO
  this.CREDATDEB  = func GET_DATEDEB()
  this.CREDATFIN  = func GET_DATEFIN()
Return

#$MET_PURGE_GATEWAY #US 116198/10 ETNA
#  Local Integer RETMETH, RET
#  Local Char WTRACEFILE(20) #parameter for the MET_PURGE() method
#  Local Instance EDIPURGE Using C_EDIPURGE
#  EDIPURGE = NewInstance C_EDIPURGE AllocGroup null
#
#  RET = fmet this.AGETVALINST("EDIPURGE", EDIPURGE)
#
#  RET = fmet this.AGETVALCHAR("WTRACEFILE", WTRACEFILE)
#
#  RETMETH = fmet EDIPURGE.MET_PURGE(WTRACEFILE)
#  # Return the result value of MET_PURGE() method + parameter
#  RET = fmet this.ASETVALCHAR("WTRACEFILE", WTRACEFILE)
#  RET = fmet this.ASETVALINTEGER("RETMETH", RETMETH)
#  FreeGroup EDIPURGE
#Return

######################################################################################
#    @variable char WTRACEFILE(100)
$MET_PURGE
  Local Integer WRET_VALUE, WOK
  Local Char WERR(250)
  WRET_VALUE = [V]CST_AOK
  Local Char WFIL1(250) : WFIL1 = "1=1" #NUMBATCH
  Local Char WFIL2(250) : WFIL2 = "1=1" #PARCOD + CATCOD
  Local Char WFIL3(250) : WFIL3 = "1=1" #STAx
  Local Char WFIL4(250) : WFIL4 = "1=1" #CREDAT
  Local Char WFIL5(250) : WFIL5 = "1=1" #TESTFLGx

#------------------------------------------------#
# Controls
#------------------------------------------------#

  If WRET_VALUE = [V]CST_AOK
    #test : at least one testflg is checked
    If func TEST_TESTFLG(this.TESTFLGYES, this.TESTFLGNO, WERR, this.ACTX.LAN) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("TESTFLGYES",WERR,[V]CST_AERROR)
      ASTATUS = fmet this.ASETERROR("TESTFLGNO",WERR,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Endif
   #test : at least one status is checked
    If func TEST_STA(this.STA2, this.STA3, this.STA4, WERR) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("STA2",WERR,[V]CST_AERROR)
      ASTATUS = fmet this.ASETERROR("STA3",WERR,[V]CST_AERROR)
      ASTATUS = fmet this.ASETERROR("STA4",WERR,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Endif
  Endif

  #test : NUMBATCH start/end values are OK
  If WRET_VALUE = [V]CST_AOK
    If this.NUMBATCHFIN < this.NUMBATCHDEB
      WRET_VALUE = [V]CST_AERROR
    Else
      If this.NUMBATCHDEB <> ""
        WFIL1 += "&[F:EST]NUMBATCH>='"+this.NUMBATCHDEB+"'"
      Endif
      If this.NUMBATCHFIN <> ""
        WFIL1 += "&[F:EST]NUMBATCH<='"+this.NUMBATCHFIN+"'"
      Endif
    Endif
  Endif

  #test : CREDAT start/end values are OK
  If WRET_VALUE = [V]CST_AOK
    If this.CREDATFIN < this.CREDATDEB
      WRET_VALUE = [V]CST_AERROR
    Else
      If this.CREDATDEB <> [0/0/0]
        WFIL4 += "&[F:EST]CREDATTIM>=gdatetime$('"+format$("D:4Y[-]2M[-]2D[T]",this.CREDATDEB)+'00:00:00Z'+"')"
      Endif
      If this.CREDATFIN <> [0/0/0]
        WFIL4 += "&[F:EST]CREDATTIM<=gdatetime$('"+format$("D:4Y[-]2M[-]2D[T]",this.CREDATFIN)+'23:59:59Z'+"')"
      Endif
    Endif
  Endif

  #test : PARCOD start/end values are OK
  If WRET_VALUE = [V]CST_AOK
    If this.PARCODFIN < this.PARCODDEB
      WRET_VALUE = [V]CST_AERROR
    Else
      If this.PARCODDEB <> ""
        WFIL2 += "&[F:EST]PARCOD>='"+this.PARCODDEB+"'"
      Endif
      If this.PARCODFIN <> ""
        WFIL2 += "&[F:EST]PARCOD<='"+this.PARCODFIN+"'"
      Endif
    Endif
  Endif

  #test : CATCOD start/end values are OK
  If WRET_VALUE = [V]CST_AOK
    If this.CATCODFIN < this.CATCODDEB
      WRET_VALUE = [V]CST_AERROR
    Else
      If this.CATCODDEB <> ""
        WFIL2 += "&[F:EST]CATCOD>='"+this.CATCODDEB+"'"
      Endif
      If this.CATCODFIN <> ""
        WFIL2 += "&[F:EST]CATCOD<='"+this.CATCODFIN+"'"
      Endif
    Endif
  Endif

  #test : STAx
  Local Integer WSTA(1..), I
  If WRET_VALUE = [V]CST_AOK
    I = 1
    If this.STA2 = [V]CST_AYES : WSTA(I) = 2 : I = I + 1 : Endif
    If this.STA3 = [V]CST_AYES : WSTA(I) = 3 : I = I + 1 : Endif
    If this.STA4 = [V]CST_AYES : WSTA(I) = 4 : I = I + 1 : Endif
    WFIL3 += "&find([F:EST]STA,WSTA())"
  Endif

  #test : TESTFLGx
  Local Integer WTESTFLG(1..), I
  If WRET_VALUE = [V]CST_AOK
    I = 1
    If this.TESTFLGYES = [V]CST_AYES : WTESTFLG(I) = 2 : I = I + 1 : Endif
    If this.TESTFLGNO  = [V]CST_AYES : WTESTFLG(I) = 1 : I = I + 1 : WTESTFLG(I) = 0 : I = I + 1 : Endif #par securité on ajoute le 0 pour No
    WFIL5 += "&find([F:EST]TESTFLG,WTESTFLG())"
  Endif

#------------------------------------------------#
# Create Query
#------------------------------------------------#
  #All tests are passed then create the query
  If WRET_VALUE = [V]CST_AOK
    Local Integer WRET_VALUE_MET : WRET_VALUE_MET = [V]CST_AOK
    Local Integer WNB_FAILED : WNB_FAILED = 0

    Local Char WSTR(250)
    Local Char WSTR1(100), WSTR2(100), WSTR3(100)
    Local Char WVAL1(100), WVAL2(100)
    Local Char WTXT(50)
    Local Char WLAN(3) : WLAN=this.ACTX.LAN

    #------------------------------------------------#
    # Log file header
    #------------------------------------------------#
    Local Instance WMYLOG Using C_ALOG
    WMYLOG = NewInstance C_ALOG AllocGroup null

    WTRACEFILE = func GET_EDIPURGE_COUNTER()
    WOK = fmet WMYLOG.ASETNAME(WTRACEFILE)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
    Call TEXTELAN(54976,WTXT,WLAN) From OBJDIV #EDI Purge
    WERR = WTXT-num$(WTRACEFILE) #+mess(40,2007,1)-num$(WNUMBATCH) #Launching EDI issue processing
    WOK = fmet WMYLOG.APUTLINE(string$(abs((115-len(WERR))/2)," ")+WERR+string$(115-len(WERR)-abs((115-len(WERR))/2)," "),[V]CST_AINFO)
    Call TEXTELAN(212,WTXT,WLAN) From OBJDIV #Date
    WERR = WTXT+":"-num$(date$)
    WOK = fmet WMYLOG.APUTLINE(string$(abs((115-len(WERR))/2)," ")+WERR+string$(115-len(WERR)-abs((115-len(WERR))/2)," "),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)

    #------------------------------------------------#
    # Log file parameters
    #------------------------------------------------#
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)
    Call TEXTELAN(881,WERR,WLAN) From OBJDIV #Parameters
    WOK = fmet WMYLOG.APUTLINE(string$(abs((115-len(WERR))/2)," ")+WERR+string$(115-len(WERR)-abs((115-len(WERR))/2)," "),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)

    Call TEXTELAN(54966,WSTR1,WLAN) From OBJDIV #Start lot number
    Call TEXTELAN(54967,WSTR2,WLAN) From OBJDIV #End lot number
    WVAL1 = this.NUMBATCHDEB
    WVAL2 = this.NUMBATCHFIN
    WSTR = "   "+format$("25X", WSTR1)+": "+format$("25X", WVAL1)+string$(6," ")+format$("25X", WSTR2)+": "+format$("25X", WVAL2)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    Call TEXTELAN(54968,WSTR1,WLAN) From OBJDIV #Start creation date
    Call TEXTELAN(54969,WSTR2,WLAN) From OBJDIV #End creation date
    WVAL1 = this.CREDATDEB
    WVAL2 = this.CREDATFIN
    WSTR = "   "+format$("25X", WSTR1)+": "+format$("25X", WVAL1)+string$(6," ")+format$("25X", WSTR2)+": "+format$("25X", WVAL2)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    Call TEXTELAN(55008,WSTR1,WLAN) From OBJDIV #Start EDI partner
    Call TEXTELAN(55009,WSTR2,WLAN) From OBJDIV #End EDI partner
    WVAL1 = this.PARCODDEB
    WVAL2 = this.PARCODFIN
    WSTR = "   "+format$("25X", WSTR1)+": "+format$("25X", WVAL1)+string$(6," ")+format$("25X", WSTR2)+": "+format$("25X", WVAL2)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    Call TEXTELAN(55010,WSTR1,WLAN) From OBJDIV #Start EDI category code
    Call TEXTELAN(55011,WSTR2,WLAN) From OBJDIV #End EDI category code
    WVAL1 = this.CATCODDEB
    WVAL2 = this.CATCODFIN
    WSTR = "   "+format$("25X", WSTR1)+": "+format$("25X", WVAL1)+string$(6," ")+format$("25X", WSTR2)+": "+format$("25X", WVAL2)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    Call TEXTELAN(1485,WSTR1,WLAN) From OBJDIV #Test No
    If this.TESTFLGNO = [V]CST_AYES : WVAL1 = mess(2,1,1) : Else WVAL1 = mess(1,1,1) : Endif
    WSTR = "   "+format$("25X", WSTR1-mess(1,1,1))+": "+format$("25X", WVAL1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)
    Call TEXTELAN(1485,WSTR1,WLAN) From OBJDIV #Test Yes
    If this.TESTFLGYES = [V]CST_AYES : WVAL1 = mess(2,1,1) : Else WVAL1 = mess(1,1,1) : Endif
    WSTR = "   "+format$("25X", WSTR1-mess(2,1,1))+": "+format$("25X", WVAL1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    Call TEXTELAN(33100,WSTR1,WLAN) From OBJDIV #Status
    WSTR1 = WSTR1+":"
    WSTR = "   "+format$("25X", WSTR1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    WSTR1 = mess(2,2003,1) #In progress
    If this.STA2 = [V]CST_AYES : WVAL1 = mess(2,1,1) : Else WVAL1 = mess(1,1,1): Endif
    WSTR = "       "+format$("21X", WSTR1)+": "+format$("25X", WVAL1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    WSTR1 = mess(3,2003,1) #Completed
    If this.STA3 = [V]CST_AYES : WVAL1 = mess(2,1,1) : Else WVAL1 = mess(1,1,1) : Endif
    WSTR = "       "+format$("21X", WSTR1)+": "+format$("25X", WVAL1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)

    WSTR1 = mess(4,2003,1) #Error
    If this.STA4 = [V]CST_AYES : WVAL1 = mess(2,1,1) : Else WVAL1 = mess(1,1,1) : Endif
    WSTR = "       "+format$("21X", WSTR1)+": "+format$("25X", WVAL1)
    WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)


    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)

#    WERR = "Processing"
    Call TEXTELAN(60,WERR,WLAN) From OBJDIV #Processing
    WOK = fmet WMYLOG.APUTLINE(string$(abs((115-len(WERR))/2)," ")+WERR+string$(115-len(WERR)-abs((115-len(WERR))/2)," "),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)

    Local Instance MYEDISTO Using C_EDISTO
    MYEDISTO = NewInstance C_EDISTO AllocGroup null
    I = 0
    #------------------------------------------------#
    # Loop
    #------------------------------------------------#
    Local File EDISTO  [EST]
    Local File EDISTOF [ESTF]
    Local File EDISTOU [ESTU]
    Local File EDISTOE [ESTE]
    Local File EDISTOJ [ESTJ]

    Trbegin [EST]
    Filter [EST] Where evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) & evalue(WFIL4) & evalue(WFIL5) Order By Key EST0
    For [EST]
      I = I + 1
      For [ESTF] Where NUMBATCH=[F:EST]NUMBATCH & KEYDOC=[F:EST]KEYDOC & FLOCOD=[F:EST]FLOCOD & FLOREL=[F:EST]FLOREL
        Delete [ESTF] Curr
      Next
      For [ESTU] Where NUMBATCH=[F:EST]NUMBATCH & KEYDOC=[F:EST]KEYDOC
        Delete [ESTU] Curr
      Next
      For [ESTE] Where NUMBATCH=[F:EST]NUMBATCH & KEYDOC=[F:EST]KEYDOC
        Delete [ESTE] Curr
      Next
      For [ESTJ] Where NUMBATCH=[F:EST]NUMBATCH & KEYDOC=[F:EST]KEYDOC
        Delete [ESTJ] Curr
      Next

      Delete [EST] Curr     # X3-6341 SAS purge improvement
      If fstat= [V]CST_AOK
          #supprimé

          Call TEXTELAN(36719,WSTR1,WLAN) From OBJDIV #SAS
          WSTR1 = WSTR1+":"
          WVAL1 = [EST]NUMBATCH+"~"+[EST]KEYDOC
#          WSTR2 = "Deleted"
          Call TEXTELAN(50497,WSTR2,WLAN) From OBJDIV #Deleted
          WSTR3 = ""
          WSTR = "   "+format$("20X", WSTR1)+format$("50X", WVAL1)+string$(6," ")+format$("15X", WSTR2) #+"- "+format$("25X", WSTR3)
          WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AINFO)
      Else
          #erreur pas supprimé
          WNB_FAILED = WNB_FAILED + 1
          Call TEXTELAN(36719,WSTR1,WLAN) From OBJDIV #SAS
          WSTR1 = WSTR1+":"
          WVAL1 = [EST]NUMBATCH+"~"+[EST]KEYDOC
#          WSTR2 = "Not deleted"
          WSTR2 = ""
#          WSTR3 = "Error"
          Call TEXTELAN(7243,WSTR3,WLAN) From OBJDIV #failed
          WSTR = "   "+format$("20X", WSTR1)+format$("50X", WVAL1)+string$(6," ")+format$("15X", WSTR2)+"- "+format$("25X", WSTR3)
          WOK = fmet WMYLOG.APUTLINE(WSTR,[V]CST_AERROR)
          WRET_VALUE_MET = [V]CST_AWARNING
      Endif
#      #/tmp
    Next
    Commit    # X3-6341 SAS purge improvement

    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
    Call TEXTELAN(18468,WERR,WLAN) From OBJDIV #total number of record
    WERR = WERR+":"-num$(I)
    WOK = fmet WMYLOG.APUTLINE("   "+WERR,[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)

    If I = 0
      #no record treaten
      WRET_VALUE_MET = [V]CST_AOK
      WERR = mess(171,2006,1) #"Aucun enregistrement correspondant aux critères n'a été trouvé"
      WOK = fmet WMYLOG.APUTLINE("   "+WERR,[V]CST_AINFO)
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
    Else
      WERR = mess(172,2006,1)+":"-num$(I) #"Nombre d'enregistrement traité"+":"-num$(I)
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AINFO)

      If WRET_VALUE_MET = [V]CST_AWARNING
        WERR = mess(173,2006,1)+":"-num$(WNB_FAILED) #"Nombre de suppression d'enregistrement échoué"+":"-num$(WNB_FAILED)
        WOK = fmet WMYLOG.APUTLINE("   "+WERR,[V]CST_AERROR)
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
      Else
        #no error
        WRET_VALUE_MET = [V]CST_AOK
        WERR = mess(174,2006,1)+":"-num$(I) #"Nombre de suppression d'enregistrement effectué"+":"-num$(I)
        WOK = fmet WMYLOG.APUTLINE("   "+WERR,[V]CST_AINFO)
        ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AINFO)
      Endif
    Endif
    LogicClose File [EST], [ESTF], [ESTU], [ESTE], [ESTJ]
    WRET_VALUE = WRET_VALUE_MET

    WOK = fmet WMYLOG.APUTLINE(string$(115,"-"),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)

    #------------------------------------------------#
    # Log file footer
    #------------------------------------------------#
    WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
    WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
    WERR = "["+mess(55,2007,1)+"]" #"End of log file"
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    WOK = fmet WMYLOG.AENDLOG()
    FreeGroup WMYLOG : WMYLOG = null

    Call TEXTELAN(22703,WERR,WLAN) From OBJDIV #Log file
    ASTATUS = fmet this.ASETERROR("",WERR+":"+WTRACEFILE+".tra",[V]CST_AINFO)

  Endif

  ARET_VALUE = WRET_VALUE
Return

######################################################################################

Funprog TEST_STA(WSTA2, WSTA3, WSTA4, WERR)
Value Integer WSTA2
Value Integer WSTA3
Value Integer WSTA4
Variable Char WERR
  Local Integer WOK
  WOK = [V]CST_ATRUE
  WERR = ""
  If WSTA2 = [V]CST_ANO and WSTA3 = [V]CST_ANO and WSTA4 = [V]CST_ANO
    WOK = [V]CST_AFALSE
    WERR = mess(175,2006,1) #"Selectionner au moins un status"
  Endif
End WOK

Funprog TEST_TESTFLG(WTESTFLGYES, WTESTFLGNO, WERR, WLAN)
Value Integer WTESTFLGYES
Value Integer WTESTFLGNO
Variable Char WERR
Value Char WLAN
  Local Integer WOK
  WOK = [V]CST_ATRUE
  WERR = ""
  If WTESTFLGYES = [V]CST_ANO and WTESTFLGNO = [V]CST_ANO
    WOK = [V]CST_AFALSE
    Call TEXTELAN(1485,WERR,WLAN) From OBJDIV #Test
    WERR = mess(175,2006,1)-"("+WERR+")" #"Selectionner au moins un status (test)"
  Endif
End WOK

######################################################################################

Funprog GET_EDIPURGE_COUNTER()
  Local Char    WCOUNTER(20)
  Local Decimal WTIMESTAMP_IN_MILLISECOND #trop grand pour un integer donc decimal
  Local Decimal WTIMESTAMP_IN_DAY
  Local Date    WDATE
  Local Decimal WTIME
  Local Decimal WMILLISECOND

  WTIMESTAMP_IN_MILLISECOND = val(timestamp$)
  WTIMESTAMP_IN_DAY         = WTIMESTAMP_IN_MILLISECOND/(24*3600*1000)
  WDATE                     = [1/1/1970] + int(WTIMESTAMP_IN_DAY)
  WTIME                     = mod(WTIMESTAMP_IN_MILLISECOND/1000,24*3600)
  WMILLISECOND              = WTIME-int(WTIME)

  WCOUNTER        = "EDIPURGE-"
&                  + format$("D:2Y2M2D",WDATE)
&                  + "-"
&                  + format$("N0:2#",int(WTIME/3600))
&                  + format$("N0:2#",int(mod(WTIME,3600)/60))
&                  + format$("N0:2#",int(mod(WTIME,60)))
&                  + format$("N0:3#",right$(left$(num$(WMILLISECOND), 5), 3))

#WCOUNTER = "EDIPURGE"
End WCOUNTER

######################################################################################

Funprog GET_DATEDEB()
  Local Date WDATEDEB
#  Local Date WDATEFIN
#  WDATEFIN = date$ - val(format$("D:2D",date$))
#  WDATEDEB = format$("D:2Y2M",WDATEFIN)+"01"
  WDATEDEB = [0/0/0]
End WDATEDEB

######################################################################################

Funprog GET_DATEFIN()
  Local Date WDATEFIN
#  Local Date DATETEST : DATETEST = date$ +30
#  WDATEFIN = DATETEST - val(format$("D:2D",DATETEST)) - 60
  WDATEFIN = date$ - val(format$("D:2D",date$)) - 60
End WDATEFIN

