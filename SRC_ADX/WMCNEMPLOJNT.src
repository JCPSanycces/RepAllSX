# Supervisor
## ACLA-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:05 455

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOJNT
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SSITFAM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SJNTREFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SJNTNAM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SJNTSRN From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SJNTDATBRN From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_SJNTTEL From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOJNT : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOJNT
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIG From WMC1EMPLOJNT : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOJNT
Gosub LNKPRO_REFNUM From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub LNKPRO_SJNTTEL From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOJNT : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



