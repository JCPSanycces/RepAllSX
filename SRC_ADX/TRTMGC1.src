          Wrseq "While IFEEDMGC1" Using [CRM3]
          Wrseq "If IFIRLOOP" Using [CRM3]
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          If [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) = "" Then
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
          Else
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) + '"' Using [CRM3]
          Endif
          Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " = GIMGC1LAS" Using [CRM3]
          Wrseq "IFIRLOOP = 0" Using [CRM3]
          Wrseq "Else" Using [CRM3]
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " < GIMGC1LAS" Using [CRM3]
          Wrseq "IFEEDMGC1 = 0" Using [CRM3]
          Wrseq "Endif" Using [CRM3]
        Endif
      Elsif ISRTDATATYP >= 10 and ISRTDATATYP < 500 Then # FGR 04/02/2015 : X3SUIVI105938 : on ignore les type > 500
        #Alpha
        If IONLY1KEY Then
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          If [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) = "" Then
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
          Else
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) + '"' Using [CRM3]
          Endif
        Else
          Wrseq "While IFEEDMGC1" Using [CRM3]
          Wrseq "If IFIRLOOP" Using [CRM3]
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          If [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) = "" Then
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
          Else
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY([M:MGC1]NBPNL-1) + '"' Using [CRM3]
          Endif
          Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " = GSZMGC1LAS" Using [CRM3]
          Wrseq "IFIRLOOP = 0" Using [CRM3]
          Wrseq "Else" Using [CRM3]
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " < GSZMGC1LAS" Using [CRM3]
          Wrseq "IFEEDMGC1 = 0" Using [CRM3]
          Wrseq "Endif" Using [CRM3]
        Endif
      Endif
    Endif
  Elsif IWHATTODO = 4 Then
    #Dernier
    Wrseq "IZ = dim([M:MGC1]MGCCOLKEY) - 1" Using [CRM3]
    Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' + " and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  Endif
  Wrseq "For [LNK] KBID" Using [CRM3]
  If IWHATTODO = 1 or IWHATTODO = 3 Then
    #Premier / Suivant
    Wrseq "If IZ < dim([M:MGC1]MGCCOL1)" Using [CRM3]
  Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
    #Premier / Suivant
    Wrseq "If IZ >= 0" Using [CRM3]
  Endif
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITER > dim(GMGCCOL) Then  # FGR 08/09/2008 : X3SUIVI30129 : Limitation dynamique. Avant bornée à 15  en dur
      Break
    Endif
    #
    Read [ATB]CODFIC=[F:TLF]TGRTABLNK
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      Break
    Else
      ICRIFIETYP = evalue("type([F:" + [F:ATB]ABRFIC + "]" + [F:TLF]TGRFIE + ")")
      If ICRIFIETYP < 500 Then                                 # FGR 04/02/2015 : X3SUIVI105938
        # Type de données > 500 ignorés : on ne les traite pas
        If ICRIFIETYP = 1 or ICRIFIETYP = 2 Then
          If ITER = ISRTMGC1 Then
            #Renseigne les variable FIR et LAS
            If IWHATTODO = 1 or IWHATTODO = 3 Then
              #Premier / Suivant
              Wrseq "If IZ = 0" Using [CRM3]
              Wrseq "GIMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GIMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
              #Précédent / Dernier
              Wrseq "If [M:MGC1]NBPNL = 0" Using [CRM3]
              Wrseq "GIMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GIMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
          Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
          If fstat Then
            Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          Else
            If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
              Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = " + '"' + '"' Using [CRM3]
              Wrseq "Else" Using [CRM3]
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = mess([F:" + [F:ATB]ABRFIC + ']'+ [F:TLF]TGRFIE + "," + num$([F:ATZ]NOLIB) + ",1)" Using [CRM3]
              Wrseq "Endif" Using [CRM3]
            Else
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            Endif
          Endif
        Elsif ICRIFIETYP = 3 Then
          If ITER = ISRTMGC1 Then
            #Renseigne les variable FIR et LAS
            If IWHATTODO = 1 or IWHATTODO = 3 Then
              #Premier / Suivant
              Wrseq "If IZ = 0" Using [CRM3]
              Wrseq "GDMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GDMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
              #Précédent / Dernier
              Wrseq "If [M:MGC1]NBPNL = 0" Using [CRM3]
              Wrseq "GDMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GDMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
          Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = format$(GFMD,[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
        Elsif ICRIFIETYP >= 4 and ICRIFIETYP <= 9 Then
          If ITER = ISRTMGC1 Then
            #Renseigne les variable FIR et LAS
            If IWHATTODO = 1 or IWHATTODO = 3 Then
              #Premier / Suivant
              Wrseq "If IZ = 0" Using [CRM3]
              Wrseq "GIMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GIMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
              #Précédent / Dernier
              Wrseq "If [M:MGC1]NBPNL = 0" Using [CRM3]
              Wrseq "GIMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GIMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
          Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
          If fstat Then
            Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
          Else
            If [F:ATZ]CODTYP = "M" or [F:ATZ]CODTYP = "MM" Then
              Wrseq "If [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + " = 0" Using [CRM3]
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = " + '"' + '"' Using [CRM3]
              Wrseq "Else" Using [CRM3]
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = mess([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", " + num$([F:ATZ]NOLIB) + ", 2)" Using [CRM3]
              Wrseq "Endif" Using [CRM3]
            Else
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = num$([F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ')' Using [CRM3]
            Endif
          Endif
        Elsif ICRIFIETYP >= 10 Then
          If ITER = ISRTMGC1 Then
            #Renseigne les variable FIR et LAS
            If IWHATTODO = 1 or IWHATTODO = 3 Then
              #Premier / Suivant
              Wrseq "If IZ = 0" Using [CRM3]
              Wrseq "GSZMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GSZMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
              #Précédent / Dernier
              Wrseq "If [M:MGC1]NBPNL = 0" Using [CRM3]
              Wrseq "GSZMGC1LAS = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Endif" Using [CRM3]
              Wrseq "GSZMGC1FIR = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
          Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE
          If fstat Then
            Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
          Else
            If [F:ATZ]CODTYP = "ADI" Then
              IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
              IADISEPARATOR -= 1
              Wrseq "Read [ADI] CODE = " + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ";[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "If fstat" Using [CRM3]
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
              Wrseq "Else" Using [CRM3]
              Wrseq "Call GET_LIB(" + left$([F:ATZ]EXPLIEN, IADISEPARATOR) + ",[F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE + ", [M:MGC1]MGCCOL" + num$(ITER) + "(IZ)) From CRM_UTIL" Using [CRM3]
              Wrseq "Endif" Using [CRM3]
            Else
              Wrseq "[M:MGC1]MGCCOL" + num$(ITER) + "(IZ) = [F:" + [F:ATB]ABRFIC + ']' + [F:TLF]TGRFIE Using [CRM3]
            Endif
          Endif
        Endif
      Endif
      ITER += 1
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  ICRIFIETYP = evalue("Type(SZFIEZOOM)")
  If ICRIFIETYP >= 10 Then
    Wrseq "[M:MGC1]MGCCOLKEY(IZ) = " + SZFIEZOOM Using [CRM3]
  Else
    Wrseq "[M:MGC1]MGCCOLKEY(IZ) = " + '"' + '"' Using [CRM3]
  Endif
  If IWHATTODO = 1 or IWHATTODO = 3 Then
    #Premier or Suivant
    Wrseq "IZ += 1" Using [CRM3]
    If ITOTPNL = 0 Then
      Wrseq "[M:MGC1]TOTPNL += 1" Using [CRM3]
    Endif
  Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
    #Précédent or Dernier
    Wrseq "IZ -= 1" Using [CRM3]
  Endif
  Wrseq "[M:MGC1]NBPNL += 1" Using [CRM3]
  Wrseq "Else" Using [CRM3]
  If ITOTPNL > 0 Then
    Wrseq "Break" Using [CRM3]
  Else
    Wrseq "[M:MGC1]TOTPNL += 1" Using [CRM3]
  Endif
  Wrseq "Endif" Using [CRM3]
  Wrseq "Next" Using [CRM3]
  If IWHATTODO = 2 Then
    If !IONLY1KEY Then
      Wrseq "Endif" Using [CRM3]
    Endif
  Endif
  Wrseq "Filter [LNK]" Using [CRM3]
  If IWHATTODO = 2 Then
    If !IONLY1KEY Then
      Wrseq "Wend" Using [CRM3]
    Endif
  Endif
  If IWHATTODO = 3 Then
    If !IONLY1KEY Then
      Wrseq "If [M:MGC1]NBPNL >= dim([M:MGC1]MGCCOLKEY) : Break : Endif" Using [CRM3]
      Wrseq "Wend" Using [CRM3]
    Endif
  Endif
  #On ferme les tables utilisées pour le contrôle de type
  Gosub CLOSETAB From =SZPROG2NAME
  #
  #On supprime le traitement SZPROG2NAME
  I2EXIST = 1
  Call EFFACE(SZFULL2SRC, I2EXIST) From ORDSYS
  I2EXIST = 1
  Call EFFACE(SZFULL2ADX, I2EXIST) From ORDSYS
  #
  #On termine le traitement SZPROGNAME
  Wrseq "End" Using [CRM3]
  Wrseq "#Fin du traitement généré" Using [CRM3]
  #
  #Fermeture du traitement généré
  Openo Using [CRM3]
  #
  #Compilation du traitement généré
  Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    End
  Endif
  #
  #Exécution du traitement généré
  Call DISPMGG From =SZPROGNAME
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10110111"
    Gosub QDISPRESULT
    End
  Endif
  #Suppression du traitement généré après service rendu
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
End

##########################################################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans DISPRESULT
##################################################################
$QDISPRESULT
#---------------------------------------------------#
#Table des tâches de nettoyage :
# 0 : On restaure les variables adxifs et adxirs
# 1 : On ferme le fichier CRMRDXXX
# 2 : Suppression physique du fichier CRMRDXXX.src
# 3 : Suppression physique du fichier CRMRDXXX.adx
# 4 : On ferme le fichier CRMRFNNN
# 5 : Suppression physique du fichier CRMRFNNN.src
# 6 : Suppression physique du fichier CRMRFNNN.adx
# 7 : Suppression de toutes les populations du ciblage dans QURTMP
#---------------------------------------------------#
  #On signale toujours l'erreur
  GERR = 1
  #On restaure les variables adxifs et adxirs
  If val(mid$(SZQUITMASK, 1, 1)) Then
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  #On ferme le fichier CRMRDXXX
  If val(mid$(SZQUITMASK, 2, 1)) Then
    Openo Using [CRM3]
  Endif
  #Suppression physique du fichier CRMRDXXX.src
  If val(mid$(SZQUITMASK, 3, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRDXXX.adx
  If val(mid$(SZQUITMASK, 4, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  Endif
  #On ferme le fichier CRMRFNNN
  If val(mid$(SZQUITMASK, 5, 1)) Then
    Openo Using [CRM4]
  Endif
  #Suppression physique du fichier CRMRFNNN.src
  If val(mid$(SZQUITMASK, 6, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2SRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRFNNN.adx
  If val(mid$(SZQUITMASK, 7, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULL2ADX, IEXIST) From ORDSYS
  Endif
  #Suppression de toutes les populations du ciblage dans QURTMP
  If val(mid$(SZQUITMASK, 8, 1)) Then
    Call DEBTRANS From GLOCK
    Trbegin [QTP]
    Delete [QTP] Where [F:QTP]QURNUM = SZQURNUM
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Calcul le nombre d'éléments précédents à afficher avec un tri ascendant sur la clé primaire
#################################################################
$ASCLOOP1
  Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
  Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  If [M:MGC1]MGCCOLKEY(0) = "" Then
    Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
  Else
    Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY(0) + '"' Using [CRM3]
  Endif
  Wrseq "For [LNK] KBID" Using [CRM3]
    Wrseq "If IZ >= dim([M:MGC1]MGCCOLKEY)-1 : Break : Endif" Using [CRM3]
    Wrseq "IZ += 1" Using [CRM3]
  Wrseq "Next" Using [CRM3]
  Wrseq "Filter [LNK]" Using [CRM3]
  Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
  Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  If [M:MGC1]MGCCOLKEY(0) = "" Then
    Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
  Else
    Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY(0) + '"' Using [CRM3]
  Endif
Return

##########################################################################################################
# Calcul le nombre d'éléments précédents à afficher avec un tri descendant sur la clé primaire
#################################################################
$DESCLOOP1
  Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
  Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  If [M:MGC1]MGCCOLKEY(0) = "" Then
    Wrseq "& and [F:QTP]KEYTGR >= " + '"' + '"' Using [CRM3]
  Else
    Wrseq "& and [F:QTP]KEYTGR >= " + '"' + [M:MGC1]MGCCOLKEY(0) + '"' Using [CRM3]
  Endif
  Wrseq "For [LNK] KBID" Using [CRM3]
  Wrseq "  If IZ >= dim([M:MGC1]MGCCOLKEY)-1 : Break : Endif" Using [CRM3]
  Wrseq "  IZ += 1" Using [CRM3]
  Wrseq "Next" Using [CRM3]
  Wrseq "Filter [LNK]" Using [CRM3]
  Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
  Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  If [M:MGC1]MGCCOLKEY(0) = "" Then
    Wrseq "& and [F:QTP]KEYTGR >= " + '"' + '"' Using [CRM3]
  Else
    Wrseq "& and [F:QTP]KEYTGR >= " + '"' + [M:MGC1]MGCCOLKEY(0) + '"' Using [CRM3]
  Endif
Return

##########################################################################################################
# Calcul le nombre d'éléments précédents à afficher avec un tri sur un champ quelconque
#################################################################
$ASCLOOP2
  Wrseq "If !ICANFOR" Using [CRM3]
  Wrseq "  IFEEDMGC1 = 1" Using [CRM3]
  Wrseq "  For [LNK] KBID" Using [CRM3]
  Wrseq "    If IZ >= dim([M:MGC1]MGCCOL1)-1" Using [CRM3]
  Wrseq "      ICANFOR = 1" Using [CRM3]
  Wrseq "      IFIRLOOP = 1" Using [CRM3]
  Wrseq "      Break" Using [CRM3]
  Wrseq "    Endif" Using [CRM3]
  Wrseq "    IZ += 1" Using [CRM3]
  Wrseq "  Next" Using [CRM3]
  Wrseq "  IPRECNT += 1" Using [CRM3]
  Wrseq "  If IPRECNT >= 2" Using [CRM3]
  Wrseq "    ICANFOR = 1" Using [CRM3]
  Wrseq "    IFIRLOOP = 1" Using [CRM3]
  Wrseq "  Endif" Using [CRM3]
  Wrseq "Else" Using [CRM3]
Return

##########################################################################################################
#Nettoyage des fichiers de traitements résiduels suite à d'eventuels plantages.
###################################################################################
Subprog CLEANHDD
Local Char SZPRGPREFIX
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST
Local Integer ITOTMGG
Local Integer ITYPFIC
Local Integer ILOOPSECURE

  Raz SZPRGPREFIX
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  ITOTMGG = 0
  ITYPFIC = 1
  ILOOPSECURE = 0
  #Enregistre le nouveau ciblage
  Read [DVA]DVA0="MGC";"CLEANFRY"
  If fstat Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    [F:DVA]OBC = "MGC"
    [F:DVA]PARAM = "CLEANFRY"
    [F:DVA]INTX(0) = 0
    Write [DVA]
    If fstat Then
      #Erreur lors de la vérification des traitements.
      GMESSAGE = mess(714,196,1)
      GERR = 1
      Rollback
    Else
      Commit
    Endif
    End
  Else
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
    Readlock [DVA]DVA0="MGC";"CLEANFRY"
    If fstat Then
      #Erreur lors de la vérification des traitements.
      GMESSAGE = mess(714,196,1)
      GERR = 1
      Rollback
      End
    Else
      ITOTMGG = [F:DVA]INTX(0)
      [F:DVA]OBC = "MGC"
      [F:DVA]PARAM = "CLEANFRY"
      If ITOTMGG >= 1000 Then
        [F:DVA]INTX(0) = 0
      Else
        [F:DVA]INTX(0) = [F:DVA]INTX(0) + 1
      Endif
      Rewrite [DVA]
      If fstat Then
        #Erreur lors de la vérification des traitements.
        GMESSAGE = mess(714,196,1)
        GERR = 1
        Rollback
      Else
        Commit
        Unlock [DVA]
      Endif
    Endif
  Endif
  #Vérifie si un nettoyage doit être effectué
  If ITOTMGG >= 1000 Then
    If !GSERVEUR Then
      Call TEMPON(mess(713,196,1)) From GESECRAN   #Vérification des traitements.
    Endif
    #On nettoie
    ITYPFIC = 1
    While ITYPFIC < 10
      Case ITYPFIC
        When 1
          SZPRGPREFIX = "CRMRT"
        When 2
          SZPRGPREFIX = "CRMRX"
        When 3
          SZPRGPREFIX = "CRMRD"
        When 4
          SZPRGPREFIX = "CRMRF"
        When 5
          SZPRGPREFIX = "CRMRM"
        When 6
          SZPRGPREFIX = "CRMRJ"
        When 7
          SZPRGPREFIX = "CRMRK"
        When 8
          SZPRGPREFIX = "CRMRB"
        When 9
          SZPRGPREFIX = "CRMRC"
      Endcase
      IPRGSUFIX = 1
      For IPRGSUFIX = 1 To 999
        SZPROGNAME = SZPRGPREFIX + num$(IPRGSUFIX)
        SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
        SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
        # SRC
        IEXIST = 0
        Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
        If IEXIST Then
          IEXIST = 1
          Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
        Endif
        # ADX
        IEXIST = 0
        Call EXISTE(SZFULLADX, IEXIST) From ORDSYS
        If IEXIST Then
          IEXIST = 1
          Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
        Endif
      Next
      ITYPFIC += 1
      ILOOPSECURE += 1
      If ILOOPSECURE > 1000 Then
        Break
      Endif
    Wend
    If !GSERVEUR Then
      Call TEMPOFF From GESECRAN
    Endif
  Endif
End

##########################################################################################################
# Crée la tache batch de d'exécution des ciblages si elle n'existe pas.
###########################################################################
Subprog CREABTMGG
  If !clalev([F:ABT]) : Local File ABATTAC [ABT] : Endif
  Read [ABT]CODTAC="CRMMGG"
  If !fstat Then
    End
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [ABT]
  #
  [F:ABT]CODTAC = "CRMMGG"               #Code tâche
  [F:ABT]CREDAT = date$                  #Date de création
  [F:ABT]CRETIM = time                   #Heure de création
  [F:ABT]CREUSR = GUSER                  #Créé par
  [F:ABT]DES = 23710                     #Intitulé
  [F:ABT]DOSPAR = ""
  [F:ABT]ENAFLG = 2                      #Actif
  [F:ABT]FONCTION = "FUNMGG4"            #Fonction
  [F:ABT]MESSAGE = 1                     #Message utilisateur
  [F:ABT]MODULE = 13                     #Module Action commerciale
  [F:ABT]MONO = 1                        #Mono-utilisateur
  [F:ABT]MULTIDOS = 1                    #Multi-dossier
  [F:ABT]NIVEAU = 0                      #Niveau autorisation
  [F:ABT]PARAM = ""                      #Paramètre
  [F:ABT]PRIO = 0                        #Priorité
  [F:ABT]PROGPAR = ""                    #Programme paramètre
  [F:ABT]SERVICE = ""                    #Service
  [F:ABT]TIMOUT = ""                     #Time-out
  [F:ABT]TRAIT = ""                      #Code traitement
  [F:ABT]TYPTAC = 1                      #Type de tâche
  #
  Write [ABT]
  If fstat Then
    Rollback
  Else
    Commit
  Endif
End

##########################################################################################################
# Exécution d'un ciblage marketing en mode batch
######################################################################
Subprog DOMGGBATCH(SZQURCOD, INBMGGRECORD, IERRINF)
Value Char SZQURCOD
Variable Integer INBMGGRECORD
Variable Integer IERRINF

Local Char SZTRACEMESS(250)

  IERRINF = 0
  INBMGGRECORD = 0
  SZTRACEMESS = ""
  #
  Call CLEANHDD
  #
  Gosub DOLKPONLY
  If IERRINF Then
    INBMGGRECORD = 0
    End
  Endif
End
