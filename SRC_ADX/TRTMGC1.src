#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#  Traitement de gestion de la vérification d'un ciblage marketing     Module CRM          18 mars 2002  #
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "TITRE"        : Gosub TITREWND
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "MEN"          : Gosub ONMENU
    When "RAF"          : Gosub REFRESH
    When Default
  Endcase
Return

##########################################################################################################
$TITREWND
  If PARAM(1) = "" Then
    Call TEXTE(18716, TIT) From OBJDIV        #Vérification ciblage
  Else
    If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
    Read [MQR]MQR0=PARAM(1)
    If fstat Then
      Call TEXTE(18716, TIT) From OBJDIV      #Vérification ciblage
    Else
      If [F:MQR]QURNAM = "" Then
        Call TEXTE(18716, TIT) From OBJDIV    #Vérification ciblage
      Else
        TIT = [F:MQR]QURNAM
      Endif
    Endif
  Endif
Return

##########################################################################################################
$REFRESH
  Raz [M:MGC1]
  Gosub DEBUT
Return

##########################################################################################################
$PREMIER
  If [M:MGC1]TOTPNL <= dim([M:MGC1]MGCCOLKEY) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call DISPRESULT(1, SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGC1]1-99
Return

##########################################################################################################
$PRECEDENT
  If [M:MGC1]TOTPNL <= dim([M:MGC1]MGCCOLKEY) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call DISPRESULT(2, SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGC1]1-99
Return

##########################################################################################################
$SUIVANT
  If [M:MGC1]TOTPNL <= dim([M:MGC1]MGCCOLKEY) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call DISPRESULT(3, SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGC1]1-99
Return

##########################################################################################################
$DERNIER
  If [M:MGC1]TOTPNL <= dim([M:MGC1]MGCCOLKEY) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call TEMPON("L") From GESECRAN
  Call DISPRESULT(4, SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL)
  Call TEMPOFF From GESECRAN
  Affzo [M:MGC1]1-99
Return

##########################################################################################################
$OUVTABGLOB
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
  If !clalev([F:SSC]) : Local File SELSSPCPN [SSC] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:QCR]) : Local File QURCRI [QCR] : Endif
  If !clalev([F:QCV]) : Local File QURCRIVAL [QCV] : Endif
  If !clalev([F:FID]) : Local File FIEDIC [FID] : Endif
  If !clalev([F:MQR]) : Local File MKGQUR [MQR] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:TGL]) : Local File TGRLIS [TGL] : Endif
  If !clalev([F:TLF]) : Local File TGRLISFIE [TLF] : Endif
  If !clalev([F:TLL]) : Local File TGRLISLNK [TLL] : Endif
  If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
  If !clalev([F:QTX]) : Local File QUREXTRACT [QTX] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  If !clalev([F:TGP]) : Local File TGRSSP [TGP] : Endif
  If !clalev([F:FDF]) : Local File FIEDICFIE [FDF] : Endif

Local Integer ITERCOL
########################################################################################################################
# FGR 09/09/2008 : X3SUIVI30129. Nombre maxi de colonnes porté à 99.
#                  S'il faut encore augmenter, maintenant deux modifications :
#                       a. Augmenter la valeur de l'indice (99) au nombre de colonnes souhaitées
#                       b. Créer les nouvelles colonnes dans l'écran MGC1. Autant que nécessaires.
#                  Le programme a été modifié afin d'être dynamique par rapport à dim(GMGCCOL), au lieu du 15 mis en dur
#                  jusque là.
Global Char GMGCCOL(50)(99)  # FGR 08/09/2008 : X3SUIVI30129 : Augmenter le nombre de colonne (>15). Porté à 99
Global Char GMGCCOLX(50)(99) # FGR 08/09/2008 : X3SUIVI30129 : Augmenter le nombre de colonne (>15). Porté à 99
########################################################################################################################
Global Char GSZMGCZOOM
Global Integer GIFINALPPL
Global Integer GIMGC1HBD
Global Char GSZMGC1FIR(100)
Global Char GSZMGC1LAS(100)
Global Integer GIMGC1FIR
Global Integer GIMGC1LAS
Global Date GDMGC1FIR
Global Date GDMGC1LAS
  ITERCOL = 0
  GSZMGCZOOM = ""
  GIFINALPPL = 0
  GSZMGC1FIR = ""
  GSZMGC1LAS = ""
  GIMGC1FIR = 0
  GIMGC1LAS = 0
  GDMGC1FIR = [00/00/00]
  GDMGC1LAS = [00/00/00]
  GIMGC1HBD = 0
  Raz GMGCCOL
  Raz GMGCCOLX

Local Char SZMGC1PARAM2
Local Char SZMGC1PARAM4
  SZMGC1PARAM2 = ""
  SZMGC1PARAM4 = ""
Return

##########################################################################################################
$OUVRE
  Gosub OUVTABGLOB
  #Vérifie si un support de présentation peut être utilisé
  If PARAM(4) = "" Then
    If PARAM(1) = "" Then
      #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
      GMESSAGE = mess(770,196,1)
      GERR = 1
      FIN = 1
      Return
    Else
      Read [MQR]MQR0=PARAM(1)
      If fstat Then
        #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
        GMESSAGE = mess(770,196,1)
        GERR = 1
        FIN = 1
        Return
      Else
        If [F:MQR]TGPNUM = "" Then
          #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
          GMESSAGE = mess(770,196,1)
          GERR = 1
          FIN = 1
          Return
        Else
          PARAM(4) = [F:MQR]TGPNUM
        Endif
      Endif
    Endif
  Endif
  If PARAM(2) = "" Then
    If PARAM(1) = "" Then
      #Aucune cible n'est précisée. Impossible d'effectuer une recherche.
      GMESSAGE = mess(145,177,1)
      GERR = 1
      FIN = 1
      Return
    Else
      Read [MQR]MQR0=PARAM(1)
      If fstat Then
        #Aucune cible n'est précisée. Impossible d'effectuer une recherche.
        GMESSAGE = mess(145,177,1)
        GERR = 1
        FIN = 1
        Return
      Else
        If [F:MQR]TGR = "" Then
          #Aucune cible n'est précisée. Impossible d'effectuer une recherche.
          GMESSAGE = mess(145,177,1)
          GERR = 1
          FIN = 1
          Return
        Else
          PARAM(2) = [F:MQR]TGR
        Endif
      Endif
    Endif
  Endif
  #
  SZMGC1PARAM2 = PARAM(2)
  SZMGC1PARAM4 = PARAM(4)
  #
  Gosub SETMGCCOL
Return

##########################################################################################################
$SETMGCCOL
Local Char SZLEFTCRIFIE(GLONAVA)
Local Char SZTEXTE(GLONDCO)

  ITERCOL = 0
  Filter [TLF] Where [F:TLF]TGRTAB = SZMGC1PARAM2 and [F:TLF]TGRSSPNUM = SZMGC1PARAM4 Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITERCOL >= dim(GMGCCOL) Then
      Break
    Endif
    #On prend d'abord le nom du champ depuis la définition des critères de ciblage
    #Sinon depuis ATABZON
    Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;GAUSCRMI
    If fstat Then
      Read [FDF]FDF0=[F:TLF]TGRTABLNK;[F:TLF]TGRFIE;""
      If fstat Then
        # FGR 12/01/2009 : X3SUIVI51579
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([F:TLF]TGRFIE)
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;SZLEFTCRIFIE
        If fstat Then
          GMGCCOL(ITERCOL) = [F:TLF]TGRFIE
        Else
          Call TEXTE([F:ATZ]NOLONG, GMGCCOL(ITERCOL)) From OBJDIV
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        If SZTEXTE = "" Then
          # FGR 12/01/2009 : X3SUIVI51579
          SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([F:TLF]TGRFIE)
          Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;SZLEFTCRIFIE
          If fstat Then
            GMGCCOL(ITERCOL) = [F:TLF]TGRFIE
          Else
            Call TEXTE([F:ATZ]NOLONG, GMGCCOL(ITERCOL)) From OBJDIV
          Endif
        Else
          GMGCCOL(ITERCOL) = SZTEXTE
        Endif
      Endif
    Else
      Call LECTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      If SZTEXTE = "" Then
        # FGR 12/01/2009 : X3SUIVI51579
        SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([F:TLF]TGRFIE)
        Read [ATZ]CODZONE=[F:TLF]TGRTABLNK;SZLEFTCRIFIE
        If fstat Then
          GMGCCOL(ITERCOL) = [F:TLF]TGRFIE
        Else
          Call TEXTE([F:ATZ]NOLONG, GMGCCOL(ITERCOL)) From OBJDIV
        Endif
      Else
        GMGCCOL(ITERCOL) = SZTEXTE
      Endif
    Endif
    ITERCOL += 1
  Next
  Filter [TLF]
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
#---------------------------------------------------#
# Détail des paramètres :
# PARAM(1) : Code ciblage
# PARAM(2) : Cible
# PARAM(3) : Détermine s'il faut effectuer une recherche ou simplement afficher le contenu d'un échantillon.
# PARAM(4) : Code support de présentation à utiliser pour l'affichage.
#---------------------------------------------------#
Local Char SZPARAM1
Local Char SZTEXTE(GLONDCO)

  SZPARAM1 = PARAM(1)
  [M:MGC1]QURNUMX = PARAM(1)
  [M:MGC1]TGRPNL = PARAM(2)
  [M:MGC1]TGPNUMX = PARAM(4)
  Read [TGL]TGL0=[M:MGC1]TGRPNL
  If fstat Then
    [M:MGC1]TGRPNLCLA = ""
  Else
    Call LECTEXTRA(SZTEXTE, "TGRLIS", "TGRNAMAXX", [F:TGL]TGRTAB, "") From ATEXTRA
    [M:MGC1]TGRPNLCLA = SZTEXTE
  Endif
  If [M:MGC1]TGPNUMX = "" Then
    If SZPARAM1 = "" Then
      #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
      GMESSAGE = mess(770,196,1)
      GERR = 1
    Else
      Read [MQR]MQR0=SZPARAM1
      If fstat Then
        #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
        GMESSAGE = mess(770,196,1)
        GERR = 1
      Else
        If [F:MQR]TGPNUM = "" Then
          #Aucun support de présentation n'est précisé. Impossible d'effectuer une recherche.
          GMESSAGE = mess(770,196,1)
          GERR = 1
        Else
          [M:MGC1]TGPNUMX = [F:MQR]TGPNUM
        Endif
      Endif
    Endif
  Endif
  If !GERR Then
    If SZPARAM1 = "" Then
      #Aucun code de ciblage n'est précisé. Impossible d'effectuer une recherche.
      GMESSAGE = mess(696,196,1)
      GERR = 1
    Else
      If PARAM(3) = "" Then
        #Pas de recalcul de l'échantillon, juste un afichage
        Read [MQR]MQR0=SZPARAM1
        If fstat Then
          #Erreur lors de la lecture des informations du ciblage consulté.
          GMESSAGE = mess(760,196,1)
          GERR = 1
        Endif
        GIFINALPPL = [F:MQR]FINPPL
        If !GERR Then
          Call TEMPON("L") From GESECRAN
          Call DISPRESULT(1, SZPARAM1, [F:MQR]FINPPL, [M:MGC1]TOTPNL)
          Call TEMPOFF From GESECRAN
          #Une erreur s'est produite lors de l'affichage du résultat. On affiche une alerte.
          If GERR Then
            #Erreur lors de l'affichage du résultat du ciblage.
            GMESSAGE = mess(707,196,1)
            GERR = 1
          Endif
        Endif
      Else
        #Nettoyage des fichiers de traitements résiduels suite à d'eventuels plantages.
        Call CLEANHDD
        #Exécution de la recherche
        Call GENLKPTRT(SZPARAM1)
      Endif
    Endif
  Endif
  GIMGC1HBD = 1
  Affzo [M:MGC1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie les écrans avant de partir.
  If GIMGC1HBD Then
    #Nettoyage de la table QUREXTRACT
    Call DEBTRANS From GLOCK
    Trbegin [QTX]
    Delete [QTX] Where [F:QTX]QURNUM = SZPARAM1
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    Raz [M:MGC1]
  Endif
  Gosub KILLGLOB
Return

##########################################################################################################
$KILLGLOB
  Kill GMGCCOL
  Kill GMGCCOLX
  Kill GSZMGCZOOM
  Kill GIFINALPPL
  Kill GSZMGC1FIR
  Kill GSZMGC1LAS
  Kill GIMGC1FIR
  Kill GIMGC1LAS
  Kill GDMGC1FIR
  Kill GDMGC1LAS
  Kill GIMGC1HBD
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
  Case BOUT
    When "H"
      Call PRINTVISU(SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL, 0) From TRTMGC1C
    When "I"
      Call PRINTVISU(SZPARAM1, GIFINALPPL, [M:MGC1]TOTPNL, 1) From TRTMGC1C
    When Default
  Endcase
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# GENLKPTRT    : Routage global de l'exécution des différentes étapes d'un ciblage
# MERGEPPL     : Fusion des populations d'un ciblage
# QMERGEPPL    : Programme de remise en état des ressources suite à une arrêt sur erreur dans MERGEPPL
# DISPRESULT   : Affichage du résultat d'une requête pour une cible
# QDISPRESULT  : Programme de remise en état des ressources suite à une arrêt sur erreur dans DISPRESULT
##########################################################################################################
##########################################################################################################
# Routage global de l'exécution des différentes étapes
###################################################
Subprog GENLKPTRT(SZQURCOD)
Value Char SZQURCOD

  Gosub DOLKPONLY
  If GERR Then
    End
  Endif
  #Affichage du résultat
  SZMESSPPL = mess(702,196,1)
  Call TEMPON(SZMESSPPL) From GESECRAN
  Call DISPRESULT(1, SZQURCOD, IFINALPPL, [M:MGC1]TOTPNL)
  Call TEMPOFF From GESECRAN
  #Une erreur s'est produite lors de l'affichage du résultat. On affiche une alerte.
  If GERR Then
    #Erreur lors de l'affichage du résultat du ciblage.
    GMESSAGE = mess(707,196,1)
    GERR = 1
    End
  Endif
End

##########################################################################################################
# Exécution de la recherche
########################################################################
$DOLKPONLY
Local Integer IFINALPPL
Local Integer IMESSPPLNUM
Local Char SZMESSPPL(100)
Local Integer INBPROPPL

  #On donne la main par point d'entrée pour effectuer tout travail complémentaire sur l'échantillon généré.
  Gosub PE_PRECUSMGG From TRTCRMPE
  #On effectue une recherche pour chaque population du ciblage
  Filter [MQP] Where [F:MQP]QURNUM = SZQURCOD
  IMESSPPLNUM = 1
  INBPROPPL = 0
  For [MQP]MQP1
    #On détermine le type de recherche à appliquer
    Read [SSP]SSP0=[F:MQP]PPLSELSPT
    If fstat Then
      GERR = 1
    Else
      If [F:SSP]SPTTYP = 0 Then
        #Type inconnu
        GERR = 1
      Elsif [F:SSP]SPTTYP = 1 Then
        #Regroupement de tables
        # FGR 29/08/2012 : X3SUIVI83551 (début)
        #Call GENRTTAB(SZQURCOD, [F:MQP]PPLORD, IMESSPPLNUM, [F:MQP]PPLSELSPT, [F:MQP]CRIGRUDIO) From TRTMGC1A
        Call GENERE_TRT(SZQURCOD, [F:SSP]SPTNUM, [F:MQP]PPLORD) From TRTMGC1A
        # FGR 29/08/2012 : X3SUIVI83551 (fin)
      Elsif [F:SSP]SPTTYP = 2 Then
        #Traitement
        #Recherche des populations
        SZMESSPPL = mess(700,196,1) - '(' + num$(IMESSPPLNUM) + ')'
        If !GSERVEUR Then
          Call TEMPON(SZMESSPPL) From GESECRAN
        Endif
        Call GENRTTRT(SZQURCOD, [F:MQP]PPLORD, [F:MQP]PPLSELSPT) From TRTMGC1B
        If !GSERVEUR Then
          Call TEMPOFF From GESECRAN
        Endif
      Elsif [F:SSP]SPTTYP = 3 Then
        #Tous les enregistrements
        #Recherche des populations
        SZMESSPPL = mess(700,196,1) - '(' + num$(IMESSPPLNUM) + ')'
        If !GSERVEUR
          Call TEMPON(SZMESSPPL) From GESECRAN
        Endif
        Call GENRTFLEV(SZQURCOD, [F:MQP]PPLORD, 1, [F:MQP]CRIGRUDIO) From TRTMGC1D
        If !GSERVEUR Then
          Call TEMPOFF From GESECRAN
        Endif
      Elsif [F:SSP]SPTTYP = 4 Then
        #Liaison de premier niveau
        #Recherche des populations
        SZMESSPPL = mess(700,196,1) - '(' + num$(IMESSPPLNUM) + ')'
        If !GSERVEUR Then
          Call TEMPON(SZMESSPPL) From GESECRAN
        Endif
        Call GENRTFLEV(SZQURCOD, [F:MQP]PPLORD, 0, [F:MQP]CRIGRUDIO) From TRTMGC1D
        If !GSERVEUR Then
          Call TEMPOFF From GESECRAN
        Endif
      Endif
    Endif
    IFINALPPL = [F:MQP]PPLORD
    GIFINALPPL = IFINALPPL
    INBPROPPL += 1
    If GERR Then
      Break
    Endif
    IMESSPPLNUM += 1
  Next
  Filter [MQP]
  #
  #Une erreur s'est produite dans la recherche des populations. Pas la peine d'aller plus loin
  If GERR Then
    If GSERVEUR Then
      #Erreur lors de la recherche de la population n°XXXX. Recherche abandonnée.
      SZTRACEMESS = mess(705,196,1) + num$(IMESSPPLNUM) + '.' - mess(706,196,1)
      Call ECR_TRACE(SZTRACEMESS, 1) From GESECRAN
      IERRINF = 1
      Return
    Else
      #Erreur lors de la recherche de la population n°XXXX. Recherche abandonnée.
      GMESSAGE = mess(705,196,1) + num$(IMESSPPLNUM) + '.' - mess(706,196,1)
      GERR = 1
      Return
    Endif
  Endif
  #Il n'y a rien eu à traiter. Pas la peine d'aller plus loin
  If !INBPROPPL Then
    If GSERVEUR Then
      #Aucune population n'a été identifiée. Aucune recherche n'a été effectuée.
      SZTRACEMESS = mess(703,196,1)
      Call ECR_TRACE(SZTRACEMESS, 1) From GESECRAN
      IERRINF = 1
      Return
    Else
      #Aucune population n'a été identifiée. Aucune recherche n'a été effectuée.
      GMESSAGE = mess(703,196,1)
      GERR = 1
      Return
    Endif
  Endif
  #Détermine si une fusion des populations doit être effectuée.
  If INBPROPPL >= 2 Then
    #Fusion des populations
    IFINALPPL = 0
    SZMESSPPL = mess(701,196,1)
    If !GSERVEUR Then
      Call TEMPON(SZMESSPPL) From GESECRAN
    Endif
    Call MERGEPPL(SZQURCOD, IFINALPPL)
    If !GSERVEUR Then
      Call TEMPOFF From GESECRAN
    Endif
    If IFINALPPL = 0 Then
      GERR = 1
    Else
      GIFINALPPL = IFINALPPL
    Endif
    #Une erreur s'est produite dans la fusion des populations. Pas la peine d'aller plus loin
    If GERR Then
      If GSERVEUR Then
        #Erreur lors de la fusion des populations. Recherche abandonnée.
        SZTRACEMESS = mess(704,196,1) - mess(706,196,1)
        Call ECR_TRACE(SZTRACEMESS, 1) From GESECRAN
        IERRINF = 1
        Return
      Else
        #Erreur lors de la fusion des populations. Recherche abandonnée.
        GMESSAGE = mess(704,196,1) - mess(706,196,1)
        GERR = 1
        Return
      Endif
    Endif
  Endif
  #On enregistre le code de la population finale sur le ciblage
  Read [MQR]MQR0=SZQURCOD
  If fstat Then
    If GSERVEUR Then
      #Erreur lors de l'enregistrement de la population finale. Recherche abandonnée.
      SZTRACEMESS = mess(759,196,1) - mess(706,196,1)
      Call ECR_TRACE(SZTRACEMESS, 1) From GESECRAN
      IERRINF = 1
      Return
    Else
      #Erreur lors de l'enregistrement de la population finale. Recherche abandonnée.
      GMESSAGE = mess(759,196,1) - mess(706,196,1)
      GERR = 1
      Return
    Endif
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [MQR]
  [F:MQR]FINPPL = IFINALPPL
  Rewrite [MQR]
  If fstat Then
    Rollback
    If GSERVEUR Then
      #Erreur lors de l'enregistrement de la population finale. Recherche abandonnée.
      SZTRACEMESS = mess(759,196,1) - mess(706,196,1)
      Call ECR_TRACE(SZTRACEMESS, 1) From GESECRAN
      IERRINF = 1
      Return
    Else
      #Erreur lors de l'enregistrement de la population finale. Recherche abandonnée.
      GMESSAGE = mess(759,196,1) - mess(706,196,1)
      GERR = 1
      Return
    Endif
  Else
    Commit
  Endif
  #On donne la main par point d'entrée pour effectuer tout travail complémentaire sur l'échantillon généré.
  Gosub PE_CUSMGG From TRTCRMPE
Return

##########################################################################################################
# Fusion des populations d'un ciblage
#########################################################################
Subprog MERGEPPL(SZQURNUM, IRESULTPPL)
Value Char SZQURNUM
Variable Integer IRESULTPPL

Local Char SZADXIFS
Local Char SZADXIRS

#Variables traitement généré n°1
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

Local Char SZQUITMASK(5)
Local Char SZTARGET
Local Char SZABRTARGET
Local Char SZKEYTARGET
Local Char SZPPLGRUDIO(250)
Local Char SZGRUDEFR(250)
Local Char SZGRUDEFL(250)
Local Char SZPARTGRU(250)
Local Char SZMSTOPD(2)(10)   #Opérateurs logiques traduits
Local Char SZCRIL
Local Char SZOPER
Local Integer IOPENPTH
Local Integer IOPENPTH2
Local Integer ICLOSEPTH
Local Integer ILASCRIPOS
Local Integer ITER
Local Integer ITER2
Local Integer ITERCRI
Local Integer ICURPPLL
Local Integer ICRIPPLL
Local Integer ICURPPLR
Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILOOPSECURE

Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT

  SZQUITMASK = "00000"
  SZPPLGRUDIO = ""
  SZPARTGRU = ""
  SZGRUDEFR = ""
  SZGRUDEFL = ""
  SZCRIL = ""
  SZOPER = ""
  SZTARGET = ""
  SZABRTARGET = ""
  SZKEYTARGET = ""
  Raz SZMSTOPD
  ITER = 0
  ITER2 = 0
  ITERCRI = 0
  IOPENPTH = 0
  IOPENPTH2 = 0
  ICLOSEPTH = 0
  ILASCRIPOS = 0
  ICURPPLL = 0
  ICRIPPLL = 0
  ICURPPLR = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILOOPSECURE = 0

  Local File QURTMP [QTP1]
  Local File QURTMP [QTP2]
  Local File QURTMP [QTP3]
  #On obtient le regroupement des populations sans espaces
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    Gosub QMERGEPPL
    End
  Endif
  SZPPLGRUDIO = vireblc([F:MQR]PPLGRUDIO, 4)
  #Traduction des opérateurs
  ITER = 1
  Filter [MQP] Where [F:MQP]QURNUM = SZQURNUM
  For [MQP] MQP1
    Case [F:MQP]PPLOPD
      When 1
        SZMSTOPD(ITER) = '.'
      When 2
        SZMSTOPD(ITER) = '&'
      When 3
        SZMSTOPD(ITER) = '|'
      When 4
        SZMSTOPD(ITER) = '+'
      When 5
        SZMSTOPD(ITER) = '-'
      When Default
    Endcase
    ITER += 1
  Next
  Filter [MQP]
  ITER = 1
  While ITER < len(SZPPLGRUDIO)
    If !instr(1, "()&|!0123456789", mid$(SZPPLGRUDIO, ITER, 1)) Then
      While !instr(1, "()&|!0123456789", mid$(SZPPLGRUDIO, ITER, 1))
        If ITER >= len(SZPPLGRUDIO) Then
          Break 2
        Endif
        SZGRUDEFL = left$(SZPPLGRUDIO, ITER-1)
        SZGRUDEFR = right$(SZPPLGRUDIO, ITER+1)
        SZPPLGRUDIO = SZGRUDEFL + SZGRUDEFR
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
      SZGRUDEFL = left$(SZPPLGRUDIO, ITER-1)
      SZGRUDEFR = right$(SZPPLGRUDIO, ITER)
      ITER2 = 1
      SZCRIL = ""
      While 1
        If instr(1, "0123456789", mid$(SZGRUDEFR, ITER2, 1)) Then
          SZCRIL = SZCRIL + mid$(SZGRUDEFR, ITER2, 1)
          ITER2 += 1
        Else
          If SZCRIL = "" Then
            ITER2 += 1
          Else
            Break
          Endif
        Endif
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
      SZPPLGRUDIO = SZGRUDEFL + SZMSTOPD(val(SZCRIL)) + SZGRUDEFR
    Endif
    ITER += 1
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
  If ILOOPSECURE > 50000 Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    Gosub QMERGEPPL
    End
  Endif
  #Tant qu'il reste au moins une parenthèse fermante, il y a des populations à regrouper
  #While instr(1, SZPPLGRUDIO, ')')
  While 1
    ICLOSEPTH = instr(1, SZPPLGRUDIO, ')')
    If ICLOSEPTH = 0 Then
      If len(SZPPLGRUDIO) > 1 Then
        SZPARTGRU = SZPPLGRUDIO
      Else
        Break
      Endif
    Endif
    #On cherche la parenthèse ouvrante de ce groupe
    If ICLOSEPTH Then
      IOPENPTH2 = 0
      While 1
        IOPENPTH2 += 1
        IOPENPTH2 = instr(IOPENPTH2, SZPPLGRUDIO, '(')
        If IOPENPTH2 > ICLOSEPTH Then
          Break
        Endif
        IOPENPTH = instr(IOPENPTH2, SZPPLGRUDIO, '(')
        If !instr(IOPENPTH2+1, SZPPLGRUDIO, '(') Then
          Break
        Endif
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
      SZPARTGRU = mid$(SZPPLGRUDIO, IOPENPTH+1, (ICLOSEPTH-IOPENPTH)-1)
    Endif
    If len(SZPARTGRU) = 1 Then
      ILASCRIPOS = 1
      ITERCRI = val(mid$(SZPARTGRU, instr(ILASCRIPOS, SZPARTGRU, mid$(SZPARTGRU, ILASCRIPOS, 1)), 1))
      ICRIPPLL = ITERCRI
    Else
      #On fusionne les populations d'un groupe de parenthèse une à une
      While 1
        ILASCRIPOS = 0
        ITERCRI = 0
        If instr(1, SZPARTGRU, mid$(SZPARTGRU, 1, 1)) Then
          #Obtient le code de la population de gauche
          ILASCRIPOS += 1
          ITERCRI = val(mid$(SZPARTGRU, instr(ILASCRIPOS, SZPARTGRU, mid$(SZPARTGRU, ILASCRIPOS, 1)), 1))
          Filter [MQP] Where [F:MQP]QURNUM = SZQURNUM
          ITER = 1
          ICRIPPLL = 0
          ICURPPLL = 0
          For [MQP] MQP1
            If ITER = ITERCRI Then
              ICRIPPLL = ITERCRI
              ICURPPLL = [F:MQP]PPLORD
              Break
            Endif
            ITER += 1
          Next
          Filter [MQP]
          If !ICURPPLL Then
            GERR = 1
            Break
          Endif
          If !ICRIPPLL Then
            GERR = 1
            Break
          Endif
          #Obtient l'opérateur logique
          ILASCRIPOS += 1
          SZOPER = ""
          SZOPER = mid$(SZPARTGRU, instr(ILASCRIPOS, SZPARTGRU, mid$(SZPARTGRU, ILASCRIPOS, 1)), 1)
          If SZOPER = "" Then
            GERR = 1
            Break
          Endif
          #Obtient le code de la population de droite
          ILASCRIPOS += 1
          ITERCRI = val(mid$(SZPARTGRU, instr(ILASCRIPOS, SZPARTGRU, mid$(SZPARTGRU, ILASCRIPOS, 1)), 1))
          Filter [MQP] Where [F:MQP]QURNUM = SZQURNUM
          ITER = 1
          ICURPPLR = 0
          For [MQP] MQP1
            If ITER = ITERCRI Then
              ICURPPLR = [F:MQP]PPLORD
              Break
            Endif
            ITER += 1
          Next
          Filter [MQP]
          If !ICURPPLR Then
            GERR = 1
            Break
          Endif
          #Effectue la fusion demandée
          Case SZOPER
            When "&"
              Gosub DOAND
            When "|"
              Gosub DOOR
            When "+"
              Gosub DOANDNOT
            When "-"
              Gosub DOORNOT
          Endcase
        Endif
        ILASCRIPOS += 1
        If ILASCRIPOS > len(SZPARTGRU) Then
          Break
        Endif
        SZGRUDEFL = left$(SZPARTGRU, 1)
        SZGRUDEFR = right$(SZPARTGRU, ILASCRIPOS)
        SZPARTGRU = SZGRUDEFL + SZGRUDEFR
        If GERR Then
          Break
        Endif
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
    Endif
    #On remplace dans SZPPLGRUDIO le groupe de population traité par le numéro de la population résultante
    If ICLOSEPTH Then
      If IOPENPTH = 0 Then
        SZGRUDEFL = ""
      Else
        SZGRUDEFL = left$(SZPPLGRUDIO, IOPENPTH-1)
      Endif
      SZGRUDEFR = right$(SZPPLGRUDIO, ICLOSEPTH+1)
      SZPPLGRUDIO = SZGRUDEFL + num$(ICRIPPLL) + SZGRUDEFR
    Else
      SZPPLGRUDIO = left$(SZPARTGRU, 1)
    Endif
    If GERR Then
      Break
    Endif
    ILOOPSECURE += 1
    If ILOOPSECURE > 50000 Then
      Break
    Endif
  Wend
  If ILOOPSECURE > 50000 Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    Gosub QMERGEPPL
    End
  Endif
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    Gosub QMERGEPPL
    End
  Endif
  #Retourne le numéro de population représentant l'échantillon final
  If len(SZPPLGRUDIO) > 1 Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    IRESULTPPL = 0
    Gosub QMERGEPPL
    End
  Else
    If len(SZPPLGRUDIO) > 0 Then
      ITERCRI = val(SZPPLGRUDIO)
      Filter [MQP] Where [F:MQP]QURNUM = SZQURNUM
      ITER = 1
      For [MQP] MQP1
        If ITER = ICRIPPLL Then
          IRESULTPPL = [F:MQP]PPLORD
          Break
        Endif
        ITER += 1
      Next
      Filter [MQP]
    Else
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      IRESULTPPL = 0
      Gosub QMERGEPPL
      End
    Endif
  Endif
  Close Local File [QTP1]
  Close Local File [QTP2]
  Close Local File [QTP3]
End

##########################################################################################################
# Effectue une fusion de type ET
##################################################################
$DOAND
  #Contrôle l'existence d'un enregistrement de la population de gauche dans celle de droite
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [QTP1] Where [F:QTP1]QURNUM = SZQURNUM and [F:QTP1]PPLORD = ICURPPLL and [F:QTP1]KEYTGR > SZLOOPCLE
    For [QTP1] QTP1
      SZLOOPCLE = [F:QTP1]KEYTGR
      Read [QTP2]QTP1=SZQURNUM;ICURPPLR;[F:QTP1]KEYTGR
      If fstat Then
        #On supprime cet enregistrement dans la population de gauche
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [QTP1]
          INTR = 1
        Endif
        Delete [QTP1] Curr
        If fstat Then
          Rollback
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
    Filter [QTP1]
    If GERR  Then
      Break
    Endif
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If GERR Then
    Return
  Endif
  #On supprime la population de droite qui ne sert plus à rien
  Call DEBTRANS From GLOCK
  Trbegin [QTP2]
  Delete [QTP2] Where [F:QTP2]QURNUM = SZQURNUM and [F:QTP2]PPLORD = ICURPPLR
  If fstat Then
    Rollback
    GERR = 1
  Else
    Commit
  Endif
Return

##########################################################################################################
# Effectue une fusion de type OU
##################################################################
$DOOR
  #Transfère le complèment résident dans la population de droite dans celle de gauche et supprime les doublons
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [QTP2] Where [F:QTP2]QURNUM = SZQURNUM and [F:QTP2]PPLORD = ICURPPLR and [F:QTP2]KEYTGR > SZLOOPCLE
    For [QTP2] QTP1
      SZLOOPCLE = [F:QTP2]KEYTGR
      Read [QTP1]QTP1=SZQURNUM;ICURPPLL;[F:QTP2]KEYTGR
      If fstat Then
        #On ajoute cet enregistrement dans la population de gauche
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [QTP1]
          INTR = 1
        Endif
        [F:QTP1]QURNUM = SZQURNUM
        [F:QTP1]PPLORD = ICURPPLL
        [F:QTP1]CRINUM = 0
        [F:QTP1]CRIVALNUM = 0
        [F:QTP1]WKGTAB = ""
        [F:QTP1]SPTLEV = 0
        [F:QTP1]KEYREC = ""
        [F:QTP1]KEYTGR = [F:QTP2]KEYTGR
        [F:QTP1]SPTTYP = 0
        Write [QTP1]
        If fstat Then
          Rollback
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
    Filter [QTP2]
    If GERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If GERR Then
    Return
  Endif
  #On supprime la population de droite qui ne sert plus à rien
  Call DEBTRANS From GLOCK
  Trbegin [QTP2]
  Delete [QTP2] Where [F:QTP2]QURNUM = SZQURNUM and [F:QTP2]PPLORD = ICURPPLR
  If fstat Then
    Rollback
    GERR = 1
  Else
    Commit
  Endif
Return

##########################################################################################################
# Effectue une fusion de type ET PAS
##################################################################
$DOANDNOT
  #Supprime l'enregistrement de la population de gauche en cas de présence dans celle de droite
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [QTP1] Where [F:QTP1]QURNUM = SZQURNUM and [F:QTP1]PPLORD = ICURPPLL and [F:QTP1]KEYTGR > SZLOOPCLE
    For [QTP1] QTP1
      SZLOOPCLE = [F:QTP1]KEYTGR
      Read [QTP2]QTP1=SZQURNUM;ICURPPLR;[F:QTP1]KEYTGR
      If !fstat Then
        #On supprime cet enregistrement dans la population de gauche
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [QTP1]
          INTR = 1
        Endif
        Delete [QTP1] Curr
        If fstat Then
          Rollback
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
    Filter [QTP1]
    If GERR Then
      Break
    Endif
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  If GERR Then
    Return
  Endif
  #On supprime la population de droite qui ne sert plus à rien
  Call DEBTRANS From GLOCK
  Trbegin [QTP2]
  Delete [QTP2] Where [F:QTP2]QURNUM = SZQURNUM and [F:QTP2]PPLORD = ICURPPLR
  If fstat Then
    Rollback
    GERR = 1
  Else
    Commit
  Endif
Return

##########################################################################################################
# Effectue une fusion de type OU PAS
##################################################################
$DOORNOT
  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #---------------------------------------------------#
  #On génère un fichier de code d'exécution de la fusion
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  While 1
    SZPROGNAME = "CRMRM" + num$(IPRGSUFIX)
    SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
    SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRGSUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      IEXIST = 0
      Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
      If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [CRM5]
  #
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM5]
  Wrseq "#Traitement généré de fusion de population de type OU PAS" Using [CRM5]
  #
  Wrseq "$RUNORNOT" Using [CRM5]
  #Ouvre la table cible
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101"
    Gosub QDOORNOT
    Return
  Endif
  SZTARGET = [F:MQR]TGR
  Read [ATB]CODFIC=SZTARGET
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101"
    Gosub QDOORNOT
    Return
  Endif
  #On obtient l'abréviation de la cible
  SZABRTARGET = [F:ATB]ABRFIC
  #On obtient la clé primaire de la cible
  Read [TGL]TGL0=SZTARGET
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101"
    Gosub QDOORNOT
    Return
  Else
    If [F:TGL]TGRMAIKEY = "" Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11101"
      Gosub QDOORNOT
      Return
    Else
      SZKEYTARGET = [F:TGL]TGRMAIKEY
    Endif
  Endif
  Wrseq "If !clalev([F:" + SZABRTARGET + "]) : Local file " + SZTARGET + ' [' + SZABRTARGET + '] : Endif' Using [CRM5]
  #
  Wrseq "Local Char SZLOOPCLE" Using [CRM5]
  Wrseq "Local Integer ILOOPCLECOUNT" Using [CRM5]
  Wrseq "Local Integer ILOOPCUT" Using [CRM5]
  #
  Wrseq "Local Integer IPERF" Using [CRM5]
  Wrseq "Local Integer INTR" Using [CRM5]
  Wrseq "Local Integer IPBL" Using [CRM5]
  #
  Wrseq "  IPERF = 0" Using [CRM5]
  Wrseq "  INTR = 0" Using [CRM5]
  Wrseq "  IPBL = 0" Using [CRM5]
  #
  Wrseq "  SZLOOPCLE = " + '"' + '"' Using [CRM5]
  Wrseq "  ILOOPCUT = 2750" Using [CRM5]
  Wrseq "  ILOOPCLECOUNT = ILOOPCUT" Using [CRM5]
  #
  Wrseq "  While ILOOPCLECOUNT >= ILOOPCUT" Using [CRM5]
  Wrseq "    ILOOPCLECOUNT = 0" Using [CRM5]
  Wrseq "    Filter [" + SZABRTARGET + "] Where [F:" + SZABRTARGET + "]" + SZKEYTARGET + "> SZLOOPCLE" Using [CRM5]
  Wrseq "& Order By [F:" + SZABRTARGET + ']' + SZKEYTARGET + " Asc" Using [CRM5]
  Wrseq "    For [" + SZABRTARGET + "]" Using [CRM5]
  Wrseq "      SZLOOPCLE = [F:" + SZABRTARGET + "]" + SZKEYTARGET Using [CRM5]
  Wrseq "      Read [QTP2] QTP1 = SZQURNUM;ICURPPLR;[F:" + SZABRTARGET + ']' + SZKEYTARGET Using [CRM5]
  Wrseq "      If fstat" Using [CRM5]
  #On vérifie si l'enregistrement n'existe pas déjà dans la population de gauche
  Wrseq "        Read [QTP1] QTP1 = SZQURNUM;ICURPPLL;[F:" + SZABRTARGET + ']' + SZKEYTARGET Using [CRM5]
  Wrseq "        If fstat" Using [CRM5]
  #On ajoute cet enregistrement dans la population de gauche
  Wrseq "          If IPERF = 0" Using [CRM5]
  Wrseq "            Call DEBTRANS From GLOCK" Using [CRM5]
  Wrseq "            Trbegin [QTP1]" Using [CRM5]
  Wrseq "            INTR = 1" Using [CRM5]
  Wrseq "          Endif" Using [CRM5]
  Wrseq "          [F:QTP1]QURNUM = SZQURNUM" Using [CRM5]
  Wrseq "          [F:QTP1]PPLORD = ICURPPLL" Using [CRM5]
  Wrseq "          [F:QTP1]CRINUM = 0" Using [CRM5]
  Wrseq "          [F:QTP1]CRIVALNUM = 0" Using [CRM5]
  Wrseq "          [F:QTP1]WKGTAB = " + '"' + '"' Using [CRM5]
  Wrseq "          [F:QTP1]SPTLEV = 0" Using [CRM5]
  Wrseq "          [F:QTP1]KEYREC = " + '"' + '"' Using [CRM5]
  Wrseq "          [F:QTP1]KEYTGR = [F:" + SZABRTARGET + ']' + SZKEYTARGET Using [CRM5]
  Wrseq "          [F:QTP1]SPTTYP = 0" Using [CRM5]
  Wrseq "          Write [QTP1]" Using [CRM5]
  Wrseq "          If fstat" Using [CRM5]
  Wrseq "            Rollback" Using [CRM5]
  Wrseq "            GERR = 1" Using [CRM5]
  Wrseq "            IPBL = 1" Using [CRM5]
  Wrseq "            INTR = 0" Using [CRM5]
  Wrseq "            Break" Using [CRM5]
  Wrseq "          Else" Using [CRM5]
  Wrseq "            If IPERF >= 500" Using [CRM5]
  Wrseq "              Commit" Using [CRM5]
  Wrseq "              IPERF = 0" Using [CRM5]
  Wrseq "              INTR = 0" Using [CRM5]
  Wrseq "            Else" Using [CRM5]
  Wrseq "              IPERF += 1" Using [CRM5]
  Wrseq "            Endif" Using [CRM5]
  Wrseq "          Endif" Using [CRM5]
  Wrseq "        Endif" Using [CRM5]
  Wrseq "      Endif" Using [CRM5]
  Wrseq "      ILOOPCLECOUNT += 1" Using [CRM5]
  Wrseq "      If ILOOPCLECOUNT >= ILOOPCUT : Break : Endif" Using [CRM5]
  Wrseq "    Next" Using [CRM5]
  Wrseq "    Filter [" + SZABRTARGET + ']' Using [CRM5]
  Wrseq "    If GERR : Break : Endif" Using [CRM5]
  Wrseq "  Wend" Using [CRM5]
  Wrseq "  If INTR"  Using [CRM5]
  Wrseq "    If !IPBL" Using [CRM5]
  Wrseq "      Commit" Using [CRM5]
  Wrseq "    Endif" Using [CRM5]
  Wrseq "  Endif" Using [CRM5]
  Wrseq "Return" Using [CRM5]
  Wrseq "#Fin du traitement généré" Using [CRM5]
  #
  #Fermeture du traitement généré
  Openo Using [CRM5]
  #
  #Compilation du traitement généré
  Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROGNAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10111"
    Gosub QDOORNOT
    Return
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10111"
    Gosub QDOORNOT
    Return
  Endif
  #
  #Exécution du traitement généré
  Gosub RUNORNOT From =SZPROGNAME
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "10111"
    Gosub QDOORNOT
    Return
  Endif
  #Suppression du traitement généré après service rendu
  IEXIST = 1
  Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  IEXIST = 1
  Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  #On supprime la population de droite qui ne sert plus à rien
  Call DEBTRANS From GLOCK
  Trbegin [QTP2]
  Delete [QTP2] Where [F:QTP2]QURNUM = SZQURNUM and [F:QTP2]PPLORD = ICURPPLR
  If fstat Then
    Rollback
    GERR = 1
  Else
    Commit
  Endif
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "00001"
    Gosub QDOORNOT
    Return
  Endif
Return

##########################################################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans DOORNOT
##################################################################
$QDOORNOT
#---------------------------------------------------#
#Table des tâches de nettoyage :
# 0 : On restaure les variables adxifs et adxirs
# 1 : On ferme le fichier CRMRMXXX
# 2 : Suppression physique du fichier CRMRMXXX.src
# 3 : Suppression physique du fichier CRMRMXXX.adx
# 4 : Suppression de toutes les populations du ciblage dans QURTMP
#---------------------------------------------------#
  #On signale toujours l'erreur
  GERR = 1
  #On restaure les variables adxifs et adxirs
  If val(mid$(SZQUITMASK, 1, 1)) Then
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  #On ferme le fichier CRMRMXXX
  If val(mid$(SZQUITMASK, 2, 1)) Then
    Openo Using [CRM5]
  Endif
  #Suppression physique du fichier CRMRMXXX.src
  If val(mid$(SZQUITMASK, 3, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLSRC, IEXIST) From ORDSYS
  Endif
  #Suppression physique du fichier CRMRMXXX.adx
  If val(mid$(SZQUITMASK, 4, 1)) Then
    IEXIST = 1
    Call EFFACE(SZFULLADX, IEXIST) From ORDSYS
  Endif
  #Suppression de toutes les populations du ciblage dans QURTMP
  If val(mid$(SZQUITMASK, 5, 1)) Then
    Call DEBTRANS From GLOCK
    Trbegin [QTP]
    Delete [QTP] Where [F:QTP]QURNUM = SZQURNUM
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
Return

##########################################################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans MERGEPPL
##################################################################
$QMERGEPPL
  #On signale toujours l'erreur
  GERR = 1
  #Suppression de toutes les populations du ciblage dans QURTMP
  Call DEBTRANS From GLOCK
  Trbegin [QTP]
  Delete [QTP] Where [F:QTP]QURNUM = SZQURNUM
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  #On referme les tables utilisées
  Close Local File [QTP1]
  Close Local File [QTP2]
  Close Local File [QTP3]
Return

##########################################################################################################
# Affichage du résultat d'une requête pour une cible
#########################################################################
Subprog DISPRESULT(IWHATTODO, SZQURNUM, IDISPPPL, ITOTPNL)
Value Integer IWHATTODO
Value Char SZQURNUM
Value Integer IDISPPPL
Value Integer ITOTPNL

Local Char SZTGR
Local Char SZPRETAB
Local Char SZFIEZOOM
Local Char SZKEYLNK
Local Integer ITER
Local Integer ICRIFIETYP
Local Char SZQUITMASK(8)
Local Char SZTABSRT
Local Char SZABRSRT
Local Char SZFIESRT
Local Char SZABRTGR
Local Integer ISRTTYP
Local Integer ISRTMGC1
Local Integer ISRTDATATYP
Local Integer IONLY1KEY
Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  SZKEYLNK = ""
  SZFIEZOOM = ""
  SZTABSRT = ""
  SZABRSRT = ""
  SZFIESRT = ""
  SZABRTGR = ""
  IONLY1KEY = 0
  ISRTTYP = 0
  ISRTMGC1 = 0
  ISRTDATATYP = 0
  SZQUITMASK = "00000000"

Local Char SZADXIFS
Local Char SZADXIRS

#Variables traitement généré n°1
Local Char SZPROGNAME
Local Integer IPRGSUFIX
Local Char SZFULLSRC(250)
Local Char SZFULLADX(250)
Local Integer IEXIST

#Variables traitement généré n°2
Local Char SZPROG2NAME
Local Integer IPRG2SUFIX
Local Char SZFULL2SRC(250)
Local Char SZFULL2ADX(250)
Local Integer I2EXIST

  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #---------------------------------------------------#
  #On génère un fichier de code d'exécution d'un affichage de ciblage
  Raz SZPROGNAME
  Raz SZFULLSRC
  Raz SZFULLADX
  Raz IEXIST
  IPRGSUFIX = 1
  #
  While 1
    SZPROGNAME = "CRMRD" + num$(IPRGSUFIX)
    SZFULLSRC = filpath("TRT", SZPROGNAME, "src", nomap)
    SZFULLADX = filpath("TRT", SZPROGNAME, "adx", nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZFULLSRC,IEXIST) From ORDSYS
    If IEXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRGSUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      IEXIST = 0
      Call EXISTE(SZFULLADX,IEXIST) From ORDSYS
      If IEXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRGSUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #Ouverture du traitement à générer
  Openo SZFULLSRC, 0 Using [CRM3]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM3]
  Wrseq "#Traitement généré d'exécution de l'affichage du résultat d'un ciblage marketing" Using [CRM3]
  #
  Wrseq "Subprog DISPMGG" Using [CRM3]
  #---------------------------------------------------#
  #On génére un sous-programme d'ouverture de tables pour effectuer des contrôles de types
  Raz SZPROG2NAME
  Raz SZFULL2SRC
  Raz SZFULL2ADX
  Raz I2EXIST
  IPRG2SUFIX = 1
  #
  #Détermine un nom disponible pour le traitement
  While 1
    SZPROG2NAME = "CRMRF" + num$(IPRG2SUFIX)
    SZFULL2SRC = filpath("TRT", SZPROG2NAME, "src", nomap)
    SZFULL2ADX = filpath("TRT", SZPROG2NAME, "adx", nomap)
    #Contrôle de l'existence du src
    I2EXIST = 0
    Call EXISTE(SZFULL2SRC,I2EXIST) From ORDSYS
    If I2EXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRG2SUFIX += 1
    Else
      #Contrôle de l'existence de l'adx
      I2EXIST = 0
      Call EXISTE(SZFULL2ADX,I2EXIST) From ORDSYS
      If I2EXIST Then
        #Calcul un nouveau suffixe pour le traitement
        IPRG2SUFIX += 1
      Else
        Break
      Endif
    Endif
  Wend
  #
  #Ouverture du traitement à générer
  Openo SZFULL2SRC, 0 Using [CRM4]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM4]
  Wrseq "#Traitement généré d'ouverture de tables pour contrôle de type" Using [CRM4]
  #
  Wrseq "$OPENTAB" Using [CRM4]
  #
  #Ouvre toutes les tables à utiliser
  #D'abord la table QURTMP
  Wrseq "If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif" Using [CRM3]
  #
  #Ensuite la table cible
  Read [MQR]MQR0=SZQURNUM
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    End
  Endif
  SZTGR = [F:MQR]TGR
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    End
  Endif
  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
  Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:MQR]TGR + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]
  #
  #Ensuite les tables de critères
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101101"
            Gosub QDISPRESULT
            Break
          Else
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM3]
            Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + SZPRETAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM4]
  #
  #Génération du sous-programme de fermeture des tables utilisées pour le contrôle de type.
  #D'abord la table cible
  Wrseq "$CLOSETAB" Using [CRM4]
  #
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11101101"
    Gosub QDISPRESULT
    End
  Else
    Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
  Endif
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  SZPRETAB = ""
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [ATB]CODFIC=SZPRETAB
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11101101"
            Gosub QDISPRESULT
            Break
          Else
            Wrseq "Close Local File [" + [F:ATB]ABRFIC + ']' Using [CRM4]
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR Then
    End
  Endif
  Wrseq "Return" Using [CRM4]
  Wrseq "#Fin du traitement généré" Using [CRM4]
  #
  #Fermeture du traitement généré
  Openo Using [CRM4]
  #
  #Compilation du traitement généré
  Local Integer IVALIDOK

  IVALIDOK = 1
  Call VALID("TRT", SZPROG2NAME, nomap, IVALIDOK) From VALMSKSUB
  If !IVALIDOK Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    End
  Endif
  If GMESSAGE <> "" Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    End
  Endif
  #Création du Link
  Read [ATB]CODFIC=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    End
  Else
    SZABRTGR = [F:ATB]ABRFIC
    Read [TGL]TGL0=SZTGR
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      End
    Else
      GSZMGCZOOM = [F:TGL]TGRAOB
      Read [TGP]TGP0=[M:MGC1]TGPNUMX
      If fstat Then
        #Erreur. Il faut nettoyer les ressources avant de dépiler.
        SZQUITMASK = "11100111"
        Gosub QDISPRESULT
        End
      Else
        SZTABSRT = [F:TGP]TABSRT
        SZFIESRT = [F:TGP]FIESRT
        ISRTTYP = [F:TGP]FIESRTTYP
        Wrseq "Link [" + [F:ATB]ABRFIC + "] With" Using [CRM3]
        #On link toujours avec QURTMP
        Wrseq "& [QTP]QTP2 = [F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY Using [CRM3]
        SZFIEZOOM = "[F:" + [F:ATB]ABRFIC + ']' + [F:TGL]TGRMAIKEY
      Endif
    Endif
  Endif
  #Génération des expressions de lien
  SZPRETAB = ""
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX
  For [TLF] TLF1
    If [F:TLF]TGRTABLNK <> "" Then
      If [F:TLF]TGRTABLNK <> SZTGR Then
        If [F:TLF]TGRTABLNK <> SZPRETAB Then
          SZPRETAB = [F:TLF]TGRTABLNK
          Read [TLL]TLL0=SZTGR;[F:TLF]TGRTABLNK
          If fstat Then
            #Erreur. Il faut nettoyer les ressources avant de dépiler.
            SZQUITMASK = "11100111"
            Gosub QDISPRESULT
            Break
          Else
            Read [ATB]CODFIC=[F:TLL]TGRLNK
            If fstat Then
              #Erreur. Il faut nettoyer les ressources avant de dépiler.
              SZQUITMASK = "11100111"
              Gosub QDISPRESULT
              Break
            Else
              Wrseq "& ,[" + [F:ATB]ABRFIC + ']' + [F:TLL]TGRLNKIDX + ' = ' + [F:TLL]TGREXPLNK Using [CRM3]
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [TLF]
  If GERR  Then
    End
  Endif
  Wrseq "& As [LNK]" Using [CRM3]
  #
  #Définit l'ordre de tri pour l'affichage du résultat.
  Read [TGL]TGL0=SZTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "11100111"
    Gosub QDISPRESULT
    End
  Else
    Read [ATB]CODFIC=SZTABSRT
    If fstat Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "11100111"
      Gosub QDISPRESULT
      End
    Else
      SZABRSRT = [F:ATB]ABRFIC
      SZKEYLNK = "[F:" + [F:ATB]ABRFIC + ']' + SZFIESRT
      If SZKEYLNK = SZFIEZOOM Then
        IONLY1KEY = 1
        If IWHATTODO = 1 or IWHATTODO = 3 Then
          #Premier / Suivant
          If ISRTTYP = 1 Then
            #Tri ascendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc" Using [CRM3]
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc" Using [CRM3]
          Endif
        Endif
        If IWHATTODO = 2 or IWHATTODO = 4 Then
          #Précédent / Dernier
          If ISRTTYP = 1 Then
            #Tri ascendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc" Using [CRM3]
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc" Using [CRM3]
          Endif
        Endif
      Else
        IONLY1KEY = 0
        If IWHATTODO = 1 or IWHATTODO = 3 Then
          #Premier / Suivant
          If ISRTTYP = 1 Then
            #Tri ascendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc; " + SZFIEZOOM + " Asc" Using [CRM3]
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc; " + SZFIEZOOM + " Desc" Using [CRM3]
          Endif
        Elsif IWHATTODO = 2 or IWHATTODO = 4 Then
          #Précédent / Dernier
          If ISRTTYP = 1 Then
            #Tri ascendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Desc; " + SZFIEZOOM + " Desc" Using [CRM3]
          Elsif ISRTTYP = 2 Then
            #Tri descendant
            Wrseq "& Order By Key KBID = " + SZKEYLNK + " Asc; " + SZFIEZOOM + " Asc" Using [CRM3]
          Endif
        Endif
      Endif
    Endif
  Endif
  #
  Wrseq "Raz [M:MGC1]NBPNL" Using [CRM3]
  For ITER = 1 To dim(GMGCCOL)
    Wrseq "Raz [M:MGC1]MGCCOL" + num$(ITER) Using [CRM3]
  Next ITER
  #
  Wrseq "Raz [M:MGC1]MGCCOLKEY" Using [CRM3]
  Wrseq "Local Integer IZ" Using [CRM3]
  Wrseq "Local Integer IFEEDMGC1" Using [CRM3]
  Wrseq "Local Integer IFIRLOOP" Using [CRM3]
  Wrseq "Local Integer IPRECNT" Using [CRM3]
  Wrseq "Local Integer ICANFOR" Using [CRM3]
  Wrseq "IFEEDMGC1 = 1" Using [CRM3]
  Wrseq "IFIRLOOP = 1" Using [CRM3]
  Wrseq "IPRECNT = 0" Using [CRM3]
  Wrseq "ICANFOR = 0" Using [CRM3]
  #
  #Détermine quelle est la colonne qui contient le champ de tri
  ITER = 1
  Filter [TLF] Where [F:TLF]TGRTAB = SZTGR and [F:TLF]TGRSSPNUM = [M:MGC1]TGPNUMX Order By [F:TLF]TGRFIEORD Asc
  For [TLF] Hint Key TLF0
    If ITER > dim(GMGCCOL) Then # FGR 08/09/2008 : X3SUIVI30129 : Rendu la rupture dynmaique. Avant 15 en dur
      Break
    Endif
    #
    If [F:TLF]TGRFIE = SZFIESRT Then
      If [F:TLF]TGRTABLNK = SZTABSRT Then
        ISRTMGC1 = ITER
        Break
      Endif
    Endif
    ITER += 1
  Next
  Filter [TLF]
  #
  #On ouvre les tables nécessaires aux contrôles de type des champs
  Gosub OPENTAB From =SZPROG2NAME
  #
  #Détermine le type du champ de tri
  ISRTDATATYP = evalue("type([F:" + SZABRSRT + "]" + SZFIESRT + ")")
  #
  #Les liens sont posés
  #On place le filtre sur QURTMP
  If IWHATTODO = 1 Then           #Premier
    Wrseq "IZ = 0" Using [CRM3]
    Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' + " and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
  Elsif IWHATTODO = 2 Then
    #Précédent
    Wrseq "IZ = 0" Using [CRM3]
    If ISRTTYP = 1 Then
      #Ascendant
      If ISRTDATATYP = 1 or ISRTDATATYP = 2 Then
        #Numérique
        If IONLY1KEY Then
          Gosub ASCLOOP1
        Else
          Wrseq "While IFEEDMGC1" Using [CRM3]
          Wrseq "If IFIRLOOP" Using [CRM3]
          Wrseq "Filter [LNK] Where [F:QTP]QURNUM = " + '"' + SZQURNUM + '"' Using [CRM3]
          Wrseq "& and [F:QTP]PPLORD = " + num$(IDISPPPL) Using [CRM3]
          If [M:MGC1]MGCCOLKEY(0) = "" Then
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + '"' Using [CRM3]
          Else
            Wrseq "& and [F:QTP]KEYTGR <= " + '"' + [M:MGC1]MGCCOLKEY(0) + '"' Using [CRM3]
          Endif
          Wrseq "& and [F:" + SZABRSRT + ']' + SZFIESRT + " = GIMGC1FIR" Using [CRM3]
          Wrseq "IFIRLOOP = 0" Using [CRM3]
