#<AdxTL>@(#)12.0.0.0 $Revision$
#CHECK IGNORE_SOURCE

###################################################################################
## Paie des intermittents
###################################################################################
## Initialisation des variables de paye en fonction du contrat
###################################################################################
Subprog INIVAR(CONTRAT,NBPREST,PRESTAT,NBVAR,TBVAR,VALEUR)
Value    Char    CONTRAT      : # No de contrat
Value    Integer NBPREST      : # Nombre de prestation
Value    Integer PRESTAT(1..) : # No des prestations
Variable Integer NBVAR        : # Nb de variables
Variable Char    TBVAR()(1..) : # Codes des variables
Variable Decimal VALEUR(1..)  : # Valeur des variables

Onerrgo ERREUR

Local Decimal BUDGET , FRAASU , FRAEXO
Local Decimal JOURS1, JOURS2, HEURES1, HEURES2 , CACISO , CACGRP
Local Char    DATJOURS1(21)(1..100), DATJOURS2(21)(1..100)
Local Integer I

NBVAR =0
GPE = 0
GPOINT = "INIVAR" : Gosub ENTREE From EXEFNC        #CHECK IGNORE_LINE
If GPE : End : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
If clalev([F:CTRI])=0 : Local File EMPLOCTR   [CTRI] : Endif
If clalev([F:CTR])=0  : Local File CONTRAT    [CTR] : Endif
If clalev([F:PSN])=0  : Local File PRESTATION [PSN] : Endif

#72068 : Les intermittents ont 1 contrat (chrono unique) avec n prestations...
Filter [CTRI] Where CTRNUM=CONTRAT
Read [CTRI]CTR0 Last
Filter [CTRI]
#Read [CTR]CTR0 = CONTRAT
#Filter [CTR] Where CTRNUM=CONTRAT
#Read [CTR]CTR0 Last
#Filter [CTR]
#
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
Raz BUDGET, FRAASU , FRAEXO , JOURS1 , JOURS2 , HEURES1 , HEURES2 , CACISO , CACGRP
Raz DATJOURS1, DATJOURS2
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
For [PSN]PSN0 Where CTRNUM=CONTRAT & CTRDAT=[F:CTRI]CTRDAT
#For [PSN]PSN0 Where CTRNUM=CONTRAT
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
 If find([F:PSN]PSNNUM,PRESTAT(1..NBPREST))
  If !find(num$([F:PSN]PSNSTRDAT)-num$([F:PSN]PSNENDDAT),DATJOURS1)
   I = find("",DATJOURS1)
   DATJOURS1(I) = num$([F:PSN]PSNSTRDAT)-num$([F:PSN]PSNENDDAT)
   JOURS1  += [F:PSN]NBRDAY
  Endif
  If [F:PSN]NBRCAC<>0 & !find(num$([F:PSN]PSNSTRDAT)-num$([F:PSN]PSNENDDAT),DATJOURS2)
   I = find("",DATJOURS2)
   DATJOURS2(I) = num$([F:PSN]PSNSTRDAT)-num$([F:PSN]PSNENDDAT)
   JOURS2  += [F:PSN]NBRDAY
  Endif
  If [F:PSN]NBRCAC=0
   HEURES1 += [F:PSN]NBRTIM
  Else
   HEURES2 += [F:PSN]NBRTIM
  Endif
  #MIPEA - 2016-08-05 - REQ 114309 US274 - START
  #Case [F:CTR]TYPCAC
  Case [F:CTRI]TYPCAC
   When 1 : CACISO += [F:PSN]NBRCAC
   When 2 : CACGRP += [F:PSN]NBRCAC
  Endcase
  #MIPEA - 2016-08-05 - REQ 114309 US274 - END
  BUDGET += [F:PSN]AMTBUD
  FRAASU += [F:PSN]AMTCRG
  FRAEXO += [F:PSN]AMTCRGEXO
 Endif
Next

#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Prise en compte de l'éventuel paramétrage de l'arrêté des intermittents
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Read [F:FCY]FCY0=[F:CTRI]ETRFCY
If clalev([F:PVA])=0 : Local File PARVARAEM [PVA] : Endif
Local Char ELTAMT(10), WVRACOD(GLONVRA)
# Fin FQ92316
#MIPEA - 2016-08-05 - REQ 114309 US274 - END

# Nb jours de prestations
NBVAR +=1
TBVAR(NBVAR) = "PRSJOUNBR1"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRDAY" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= JOURS1

# Nb jours de prestations
NBVAR +=1
TBVAR(NBVAR) = "PRSJOUNBR2"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRDAY" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= JOURS2

# Nb heures de prestations
NBVAR +=1
TBVAR(NBVAR) = "PRSHEUNBR1"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRTIM" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= HEURES1

# Nb heures de prestations
NBVAR +=1
TBVAR(NBVAR) = "PRSHEUNBR2"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRTIMCAC" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= HEURES2

# Nb de cachets groupés
NBVAR +=1
TBVAR(NBVAR) = "CACGRPNBR"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRCACGRP" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= CACGRP

# Nb de cachets isolés
NBVAR +=1
TBVAR(NBVAR) = "CACISONBR"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="NBRCACISO" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= CACISO

# Frais assujettis
NBVAR +=1
TBVAR(NBVAR) = "FRAASU"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="AMTCRG" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= FRAASU

# Frais exonérés
NBVAR +=1
TBVAR(NBVAR) = "FRAEXO"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="AMTCRGEXO" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= FRAEXO

# Budget
NBVAR +=1
TBVAR(NBVAR) = "BUDOBJ"
#MIPEA - 2016-08-05 - REQ 114309 US274 - START
# FQ92316 - 14/11/13 - Récupération du paramétrage de l'arrêté des intermittents
ELTAMT="AMTBUD" : Gosub CALC_VRA : If [L]WVRACOD<>"" Then TBVAR(NBVAR) = [L]WVRACOD : Endif
#MIPEA - 2016-08-05 - REQ 114309 US274 - END
VALEUR(NBVAR)= BUDGET

End

$ERREUR
Call ERREUR("INIVAR"-errmes$(errn)-num$(errl)) From GESECRAN
Resume

#MIPEA - 2016-08-05 - REQ 114309 US274 - START
#**
#* FQ92316 - 14/11/13 - Récupération paramétrage arrêté intermitent par élément montant et par niveau
#*!
$CALC_VRA

  [L]WVRACOD=""

  ## Recherche au niveau contrat
  If CONTRAT<>"" Then
    Read [F:PVA]PVA0=ELTAMT;6;"";"";"";"";"";CONTRAT;"";"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Salarié
  If [L]WVRACOD="" & [F:CTRI]REFNUM<>"" Then
    Read [F:PVA]PVA0=ELTAMT;5;"";"";"";"";[F:CTRI]REFNUM;"";"";"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Profil
  If [L]WVRACOD="" & [F:CTRI]PROPRF<>"" Then
    Read [F:PVA]PVA0=ELTAMT;9;"";"";"";"";"";"";"";"";[F:CTRI]PROPRF
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Service
  If [L]WVRACOD="" & [F:CTRI]ETRSRV<>"" Then
    Read [F:PVA]PVA0=ELTAMT;7;"";"";"";"";"";"";[F:CTRI]ETRSRV;"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Convention collective
  If [L]WVRACOD="" & [F:CTRI]CLLCVT<>"" Then
    Read [F:PVA]PVA0=ELTAMT;8;"";"";"";"";"";"";"";[F:CTRI]CLLCVT;""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Site
  If [L]WVRACOD="" & [F:CTRI]ETRFCY<>"" Then
    Read [F:PVA]PVA0=ELTAMT;4;"";"";"";[F:CTRI]ETRFCY;"";"";"";"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif
  ## Recherche au niveau Société
  If [L]WVRACOD="" & [F:FCY]LEGCPY<>"" Then
    Read [F:PVA]PVA0=ELTAMT;3;"";"";[F:FCY]LEGCPY;"";"";"";"";"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif

  ## Recherche au niveau population
  If [L]WVRACOD="" & [F:CTRI]REFNUM<>"" Then
    If !clalev([F:POA]) : Local File POPULA [POA] : Endif
    Link [POA] With [PVA]PVA0~=ELTAMT;2;"";COD;"";"";"";"";"";"";""
&                As [VAK]
&             Where REFNUM=[F:CTRI]REFNUM & COD>"" & [F:PVA]VRACOD>""
    Read [VAK]POA1 First
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif

  ## Recherche au niveau Dossier
  If [L]WVRACOD="" Then
    Read [F:PVA]PVA0=ELTAMT;1;nomap;"";"";"";"";"";"";"";""
    If !fstat Then
      [L]WVRACOD = [F:PVA]VRACOD
    Endif
  Endif

  fstat=0
Return
#MIPEA - 2016-08-05 - REQ 114309 US274 - END

