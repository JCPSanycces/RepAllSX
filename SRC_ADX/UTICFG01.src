#<AdxTL>@(#)0.0.0.0 $Revision$
# Configurator - Issue 89191 Textes traduits GA 04/2013
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTICFG01: Configurator - Issue 89191 Translated texts") From LECFIC
#-----
  Call MAJ_UTICFG001(nomap)
#-----
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  Call MAJ_UTICFG001(APPLI)
End

########################################################################
Subprog MAJ_UTICFG001(DOSSIER)
Value Char DOSSIER

Local Integer IERR
Local Integer B_OK

  If DOSSIER = "X3" End Endif
  If filinfo(filpath("FIL","CFGQST","fde",DOSSIER),0) < 0 : End : Endif

  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("UTICFG01: Folder "+DOSSIER) From DOSSUB
  #------------------------------------------------------
  IERR = 0
  #Call MAJFIC("CFGQST",DOSSIER,1) From VALDIC
  Gosub CTL_ATEXTRA
  Call ECR_TIME("UTICFG01: End of check for Configurator - Issue 89191 Translated texts") From DOSSUB
  #------------------------------------------------------
End

$CTL_ATEXTRA
# Issue 84095
If DOSSIER<>nomap
  Local File =DOSSIER+".CFGQST"  [CQU]
  Local File =DOSSIER+".BOM"     [BOH]
  Local File =DOSSIER+".ROUTING" [ROH]
  Local File =DOSSIER+".ATEXTE"  [ATX]
  Local File =DOSSIER+".APLSTD"  [AST]
  Local File =DOSSIER+".ATEXTRA" [AXX]
Else
  Local File CFGQST  [CQU]
  Local File BOM     [BOH]
  Local File ROUTING [ROH]
  Local File ATEXTE  [ATX]
  Local File APLSTD  [AST]
  Local File ATEXTRA [AXX]
Endif
Trbegin [ATX]
  Local Shortint WCPT1, WCPT2
  Local Char     WIDENT1_KO(50)
  Local Char     WIDENT2_OK(50)
  WCPT1=0 : WCPT2=0
  Filter [F:BOH] Where CFGVCRNUM<>""
  For [F:BOH]
     WIDENT1_KO="_"+[F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
     WIDENT1_OK=[F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
     If [F:BOH]IDENT1=WIDENT1_KO
       Call CHGTEXTRA("BOM","BOMDESAXX",WIDENT1_KO,num$([F:BOH]BOMALTTYP),WIDENT1_OK,num$([F:BOH]BOMALTTYP)) From ATEXTRA
       If adxuprec>0  WCPT1+=1 Endif
       [F:BOH]IDENT1 = WIDENT1_OK
       Rewrite [F:BOH]
     Else
       Call SUPTEXTRA("BOM","BOMDESAXX",WIDENT1_KO,num$([F:BOH]BOMALTTYP)) From ATEXTRA
       If adxdlrec>0  WCPT2+=1 Endif
     Endif
  Next
  Filter [F:BOH]
#
  Filter [F:ROH] Where CFGVCRNUM<>""
  For [F:ROH]
     WIDENT1_KO="_"+[F:ROH]ITMREF
     WIDENT1_OK=[F:ROH]ITMREF
     If [F:BOH]IDENT1=WIDENT1_KO
       Call CHGTEXTRA("ROUTING","ROUDESAXX",WIDENT1_KO,num$([F:ROH]ROUALT),WIDENT1_OK,num$([F:ROH]ROUALT)) From ATEXTRA
       If adxuprec>0  WCPT1+=1 Endif
       [F:ROH]IDENT1 = WIDENT1_OK
       Rewrite [F:ROH]
     Else
       Call SUPTEXTRA("ROUTING","ROUDESAXX",WIDENT1_KO,num$([F:ROH]ROUALT)) From ATEXTRA
       If adxdlrec>0  WCPT2+=1 Endif
     Endif
  Next
  Filter [F:ROH]

Commit
If WCPT1>0
  Call ECR_TIME("UTICFG01:"-num$(WCPT1)-"texts updated") From DOSSUB
  Call ECR_TIME("UTICFG01:"-num$(WCPT2)-"texts deleted") From DOSSUB
Endif
Close Local File [CQU]
Return
