#######################################################################################
$AUPDATE_CONTROL_AFTER
  #Le demandeur n'est pas modifiable
  If this.REQUSR <> this.snapshot.REQUSR
    WMESSAGE = mess(156,154,1)+ " : " + mess(9,123,1)
    [L]ASTATUS = fmet this.ASETERROR ("REQUSR", WMESSAGE, [V]CST_AERROR)
    Return
  Endif
  #Mise à jour de l'entête de DA
  If fmet this._MET_MAJPSH() <> CST_AOK
    [L]ASTATUS = fmet this.ASETERROR ("", mess(2,7772,1), [V]CST_AERROR)
    Return
  Endif
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  Local Integer I(maxtab(this.PSD))
  # DA no modifiable if CLEFLG = 2
  If this.CLEFLG = 2 & !sigma(I=0,this.PSD(1..maxtab(this.PSD)),this.PSD(I).LINCLEFLG=1)
     [L]ASTATUS = fmet this.ASETERROR ("", mess(24,194,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
#Init PSDLIN
$AUPDATE_BEFORE
  Local Integer I, WPSDLIN, SIGN
  Local Decimal WCOEUOM
  # statistics
#  SIGN=-1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif

  WPSDLIN = 1000 + max(this.PSD(1..maxtab(this.PSD)).PSDLIN)
  #Init PSDLIN for each new line
  For I = 1 To maxtab(this.PSD)
    If this.PSD(I)<>null and find(this.PSD(I).ASTALIN,[V]CST_ANEW)>0
      this.PSD(I).PSDLIN = WPSDLIN
      WPSDLIN += 1000
    Endif
    # for all lines not deleted
    If  this.PSD(I)<>null and find(this.PSD(I).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)<1
      #----- Stock quantity calculation -----#
      Call PCAL_QTY(this.PSD(I).QTYPUU,this.PSD(I).PUU,this.PSD(I).QTYSTU,this.PSD(I).STU,
&             this.PSD(I).ITMREF,this.PSD(I).BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
      #----- Line amount calculation -----------------------------------------#
      this.PSD(I).LINAMT=this.PSD(I).QTYPUU*this.PSD(I).NETPRI
      Call ARRDEV(this.PSD(I).LINAMT,this.PSD(I).CUR,this.PSD(I).CPY) From TRTDIV_SYRA
    Endif
  Next I

  #On ne peut pas enregistrer une DA en Syracuse
  [L]ASTATUS = fmet this.ASETERROR ("ITMREF", "Impossible d'enregistrer une DA, fonction prototype", [V]CST_AERROR)

Return

#######################################################################################
$AUPDATE_AFTER
  Local Integer SIGN
  # statistics
  #SIGN=1 : Call VALSTA("PSH",SIGN) From SUBPS2 : If GOK<1 Return : Endif
Return



#######################################################################################
$ADELETE_CONTROL_BEFORE
  #-------------------------------------------------------#
  # It's forbidden to supress a Pruchase Request :        #
  #Approved or ordered                                    #
  #With at least one line orderded or Approved or solved  #
  #With at least one line partialy approved               #
  #-------------------------------------------------------#
  If this.ORDFLG = 2 | this.CLEFLG = 2 | this.ORDLINNBR <> 0 | this.CLELINNBR <> 0
    If this.ORDLINNBR <> 0
       [L]ASTATUS = fmet this.ASETERROR ("", mess(20,194,1), [V]CST_AERROR)
    Endif
    If this.CLELINNBR <> 0
      [L]ASTATUS = fmet this.ASETERROR ("", mess(21,194,1), [V]CST_AERROR)
    Endif
    If this.ORDFLG = 2
      [L]ASTATUS = fmet this.ASETERROR ("", mess(23,194,1), [V]CST_AERROR)
    Endif
    If this.CLEFLG = 2
      [L]ASTATUS = fmet this.ASETERROR ("", mess(24,194,1), [V]CST_AERROR)
    Endif
  Endif
  #--- Purchase Request Approved
  If this.APPFLG = 3
     [L]ASTATUS = fmet this.ASETERROR ("", mess(22,194,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
$PSD_ADDLINE_BEFORE
  # site has to have been chosen before adding a new line
  If this.PSHFCY = ""
     [L]ASTATUS = fmet this.ASETERROR("", mess(632,199,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
$PSD_ADDLINE_AFTER
  Local Integer CTX_PURCHGTYP(1)

  #Init Fields from Head class
  this.CPY         = this.APARENT.CPY
  this.PSHFCY      = this.APARENT.PSHFCY
  this.LEG         = this.APARENT.LEG
  #------ Init other fields -----#
  this.CUR       = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"ACCCUR")
  CTX_PURCHGTYP  = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PURCHGTYP")
  this.CHGTYP    = CTX_PURCHGTYP
  this.FBUFLG    = 1
  this.LINORDFLG = 1
  this.LINFLG    = 0
  this.BLOMSG    = 0
  this.PRIFLG    = 1
  # Init Receipt Site
  Call DEFRCPFCY(this.PSHFCY,this.PRHFCY) From TRTACHDEF1_SYRA
  #init key
  this.PSHNUM = this.APARENT.PSHNUM
  this.PSDLIN = 1 + max(this.APARENT.PSD(1..maxtab(this.APARENT.PSD)).PSDLIN)

 #-------TEST
 #this.ITMREF = "SKI170"
 #this.BPSNUM = "SALOMON"
 #this.QTYPUU = 7
 #this.EXTORDDAT = [03/11/2014]
 #this.EXTRCPDAT = [03/11/2014]
 #this.TAXRCP    = "001"
 #--/

Return
#######################################################################################
$PSD_ADELLINE_BEFORE
  If this.PSD.BLOMSG <> 0
    ASTATUS = fmet this.ASETERROR("", mess(this.BLOMSG,194,1), [V]CST_AERROR)
  Endif
Return

#######################################################################################
$PSD_AINSERT_CONTROL_AFTER
  #Controle sur l'approvisionneur et l'article
  If  func TRTACHCTL1_SYRA.CTL_PLANNER_ITM(this.ACTX, this.ITMREF, this.APARENT.REQUSR, WMESSAGE ) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("REQUSR", WMESSAGE, [V]CST_AERROR)
     Return
  Endif
  #Controle sur la date de fin de vie de l'article
  If func TRTACHCTL1_SYRA.CTL_LIFENDDAT(this.ITMREF,this.APARENT.PRQDAT, WMESSAGE) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("ITMREF", WMESSAGE, [V]CST_AERROR)
     Return
  Endif
  #Controle sur l'approvisionneur et l'article site
  If func TRTACHCTL1_SYRA.CTL_PLANNER_ITF(this.ACTX, this.PSHFCY, this.ITMREF, this.APARENT.REQUSR, WMESSAGE) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("REQUSR", WMESSAGE, [V]CST_AERROR)
     Return
  Endif

  Local Decimal WCOEUOM
  If find(this.ASTALIN,[V]CST_ANEW,[V]CST_ANEWDEL)>0
    #----- Stock quantity calculation -----#
    Call PCAL_QTY(this.QTYPUU,this.PUU,this.QTYSTU,this.STU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
    #----- Line amount calculation -----------------------------------------#
    this.LINAMT=this.QTYPUU*this.NETPRI
    Call ARRDEV(this.LINAMT,this.CUR,this.CPY) From TRTDIV_SYRA
  Endif
Return

#######################################################################################
$PSD_AINSERT_BEFORE
  Local Integer CTX_APPPSH,CTX_PURCMMTAX
  Local Date    WDATE
  Local Char    WCUR(GLONCUR)
  Local Char    WLAN(GLONLAN)
  WDAT = gdat$(31,12,adxdcs+99)
  Local File ITMFACILIT [ITF]
  Local File ITMMASTER  [ITM]
  this.PSHNUM = this.APARENT.PSHNUM
  WLAN        = this.ACTX.LAN
  #------------------------- Item designation -------------------#
  If this.BPSNUM<>AVOID.ACHAR & (this.ITMDES = AVOID.ACHAR | this.ITMDES1= AVOID.ACHAR)
     #lecture BPR
     Local File BPARTNER [BPR]
     If [F:BPR]BPRNUM<>this.BPSNUM
       Read [BPR] BPR0=this.BPSNUM
       If fstat Raz [F:BPR] : Endif
     Endif
     If [F:BPR]LAN<> AVOID.ACHAR : WLAN=[F:BPR]LAN : Endif
     LogicClose File [BPR]
  Endif
  If this.ITMDES = AVOID.ACHAR
    Call CHARGE_DEFITMDES("DES1AXX",WLAN,this.ITMREF,this.ITMDES, "[F:ITM]") From TRTX3_SYRA
  Endif
  If this.ITMDES1 = AVOID.ACHAR
    Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,this.ITMDES1, "[F:ITM]") From TRTX3_SYRA
  Endif
  CTX_APPPSH  = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "APPSH")
  If CTX_APPPSH>1  & this.LINCLEFLG<>2  this.LINAPPFLG=0 : Endif
  CTX_PURCMMTAX  = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "PURCMMTAX")
  this.CMMPRPTAX = max(CTX_PURCMMTAX,1) : # Indicateur Type d'engagement
  Read [F:ITF]ITF0 = this.ITMREF;this.PSHFCY
  If fstat | [F:ITF]BUY = ""
     Read [F:ITM]ITM0 = this.ITMREF
     If fstat | [F:ITM]BUY = ""
         this.LINBUY = ""
     Else
        this.LINBUY =  [F:ITM]BUY
     Endif
  Else
     this.LINBUY =  [F:ITF]BUY
  Endif
  this.ORI = 1
  WCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"ACCCUR")
  If this.CUR  <> WCUR
    Call COURSITE(this.ACTX,this.CUR,this.PSHFCY,this.CHGTYP,WDATE,this.CHGCOE,WSTAT) From TRTDEV_SYRA
  Else
    this.CHGCOE = 1
  Endif
  #----- Récupération du chrono pour les encours -----#
  If [F:ITF]STOMGTCOD>1
  # Brancher nouveau SUBANM
  #  Call NUMERO(GWIP,[F:PSD]PRHFCY,[F:PSD]EXTORDDAT,"",[F:PSD]WIPNUM,WSTAT) From SUBANM
  #  If GOK<0
  #    Return
  #  Elsif GOK<1 | WSTAT<>0
  #    Local Char MESSA(80)
  #    Local Integer SAUV_STAT
  #    If dim(STAT)<0 : Local Integer STAT : Endif
  #    SAUV_STAT=STAT : STAT=WSTAT
  #    GMESSAGE=mess(60,199,1)-"("+GWIP+") : "
  #    Gosub MESSAGE From SUBANM
  #    STAT=SAUV_STAT
  #    GMESSAGE-=MESSA : GOK=0 : GERR=1
  #    Return
  #  Endif
  Endif
  #----------------------------------------#
  # Création ou duplication du texte ligne #
  #----------------------------------------#
  #Gosub CHARG_TEXT_LIGNE
Return

#######################################################################################
$PSD_AUPDATE_CONTROL_AFTER
  #Controle sur l'approvisionneur et l'article
  If func TRTACHCTL1_SYRA.CTL_PLANNER_ITM(this.ACTX, this.ITMREF, this.APARENT.REQUSR, WMESSAGE) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("REQUSR", WMESSAGE, [V]CST_AERROR)
     Return
  Endif
  #Controle sur la date de fin de vie de l'article
  If func TRTACHCTL1_SYRA.CTL_LIFENDDAT(this.ITMREF,this.APARENT.PRQDAT, WMESSAGE) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("ITMREF", WMESSAGE, [V]CST_AERROR)
     Return
  Endif
  #Controle sur l'approvisionneur et l'article site
  If func TRTACHCTL1_SYRA.CTL_PLANNER_ITF(this.ACTX, this.PSHFCY, this.ITMREF, this.APARENT.REQUSR, WMESSAGE) = [V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR ("REQUSR", WMESSAGE, [V]CST_AERROR)
     Return
  Endif
Return

