############################################################
#
# Library of Legislation procedures for Training period screens
#
# Window  : OSTG
# Screens : STG0, STG1, STG3, STG4, STG5
#
############################################################


########################################
#16/05/12 - DKA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
#ADNGO - 2017-07-19 - X3-34429 - START
  Case GCURLEG
   When "FRA", ""
     ##STG2 - Show fields
     #Chgfmt [M:STG2]NATFIS       With "LA:10452"  #Fiscal nature
     Chgfmt [M:STG2]NATFIS       With "K:5X"  #Fiscal nature
     #Chgfmt [M:STG2]CATACN       With "LA:10453"  #Action category
     Chgfmt [M:STG2]CATACN       With "K:5X"  #Action category
     #Chgfmt [M:STG2]TYPFRT       With "LA:10455"  #Systems used
     Chgfmt [M:STG2]TYPFRT       With "K:5X"  #Systems used
     Chgfmt [M:STG2]CATTRG       With "K:20BX"    #Category 2483
     Chgfmt [M:STG2]DIFTRG       With "LA:1"      #DIF
   When Default
     ##STG2 - Hide fields
     #Chgfmt [M:STG2]NATFIS       With "-LA:10452"  : Raz [M:STG2]NATFIS : #Fiscal nature
     Chgfmt [M:STG2]NATFIS       With "-K:5X"  : Raz [M:STG2]NATFIS : #Fiscal nature
     #Chgfmt [M:STG2]CATACN       With "-LA:10453"  : Raz [M:STG2]CATACN : #Action category
     Chgfmt [M:STG2]CATACN       With "-K:5X"  : Raz [M:STG2]CATACN : #Action category
     #Chgfmt [M:STG2]TYPFRT       With "-LA:10455"  : Raz [M:STG2]TYPFRT : #Systems used
     Chgfmt [M:STG2]TYPFRT       With "-K:5X"  : Raz [M:STG2]TYPFRT : #Systems used
     Chgfmt [M:STG2]CATTRG       With "-K:20BX"    : Raz [M:STG2]CATTRG : #Category 2483
     Chgfmt [M:STG2]DIFTRG       With "-LA:1"      : Raz [M:STG2]DIFTRG : #DIF
  Endcase
#ADNGO - 2017-07-19 - X3-34429 - END
End

