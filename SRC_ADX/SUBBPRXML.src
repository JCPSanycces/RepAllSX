#<AdxTL>@(#)5.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'un Tiers                                                                Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################
###############################################################################################################
Subprog BPRINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(19569, SZHTMLTITLE) From OBJDIV      #Tiers
  SZSUBPROG = "BPRINXML"
  SZAOBABREV = "BPR"
  Gosub XMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

#########################################################################################################################
Subprog BPRLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZFILTER = "" Then
    SZFILTER = "1=1"
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(1500, SZHTMLTITLE) From OBJDIV      #Tiers
  SZSUBPROG = "BPRLISTXML"
  SZAOBABREV = "BPR"
  Gosub XMLPART2B From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOLISTXML
  Gosub XMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML
  Gosub SETBPREXCEPT From CRMEXCEPT
  #On extrait
  Filter [BPR] Where evalue(SZFILTER)
  For [BPR]
    SZCTAOB = "BPR"
    SZCTAOBNUM = [F:BPR]BPRNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLBPR From CRMEXCEPT
  Next
  Filter [BPR]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML
  If !clalev([F:MAD]) : Local File MARASSDEF [MAD] : Endif
  Gosub SETBPREXCEPT From CRMEXCEPT
  Gosub SETBPCEXCEPT From CRMEXCEPT
  Gosub SETBPAEXCEPT From CRMEXCEPT
  Gosub SETMSTEXCEPT From CRMEXCEPT
  Gosub SETREPEXCEPT From CRMEXCEPT
  Gosub SETRSEEXCEPT From CRMEXCEPT
  Gosub SETMAREXCEPT From CRMEXCEPT
  Gosub SETCNTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [BPR] Where [F:BPR]BPRNUM = SZRECNUM
  For [BPR]
    SZCTAOB = "BPR"
    SZCTAOBNUM = [F:BPR]BPRNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLBPR From CRMEXCEPT
    #Client
    If IDISPLAYBPC Then
      Gosub ADDBPC
    Endif
    #Adresse
    If IDISPLAYBPA Then
      Gosub ADDBPA
    Endif
    #Contacts
    If IDISPLAYCNT Then
      Gosub ADDCNT
    Endif
  Next
  Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC
  Filter [BPC] Where [F:BPC]BPCNUM = [F:BPR]BPRNUM
  For [BPC]
    SZCTAOB = "BPC"
    SZCTAOBNUM = [F:BPC]BPCNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BPR"
    SZCTPARENTNUM = [F:BPR]BPRNUM
    Gosub XMLBPC From CRMEXCEPT
  Next
  Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:BPR]BPRNUM
  For [BPA]
    SZCTAOB = "BPA"
    SZCTAOBNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BPR"
    SZCTPARENTNUM = [F:BPR]BPRNUM
    Gosub XMLBPA From CRMEXCEPT
    If IDISPLAYMST Then
      Read [MAD]MAD0=[F:BPR]BPRNUM;[F:BPA]BPAADD;"BPR"
      If !fstat Then
        If [F:MAD]MARSCTNUM <> "" Then
          Read [MST]MST0=[F:MAD]MARSCTNUM
          If !fstat Then
            SZCTAOB = "MST"
            SZCTAOBNUM = [F:MST]MARSCTNUM
            SZCTLEVEL = "2"
            SZCTPARENTAOB = "BPA"
            SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
            Gosub XMLMST From CRMEXCEPT
          Endif
        Endif
      Endif
    Endif
    If [F:BPA]BPAADD = [F:BPR]BPAADD Then
      If IDISPLAYREP Then
        #Adresse par défaut
        Read [BPC]BPC0=[F:BPR]BPRNUM
        If !fstat Then
          #Représentant principaux
          If type([F:BPC]REP(0)) > 0 Then
            If [F:BPC]REP(0) <> "" Then
              Read [REP]REP0=[F:BPC]REP(0)
              If !fstat Then
                SZCTAOB = "REP"
                SZCTAOBNUM = [F:REP]REPNUM
                SZCTLEVEL = "2"
                SZCTPARENTAOB = "BPA"
                SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
                Gosub XMLREP From CRMEXCEPT
              Endif
            Endif
          Endif
          If type([F:BPC]REP(1)) > 0 Then
            If [F:BPC]REP(1) <> "" Then
              Read [REP]REP0=[F:BPC]REP(1)
              If !fstat Then
                SZCTAOB = "REP"
                SZCTAOBNUM = [F:REP]REPNUM
                SZCTLEVEL = "2"
                SZCTPARENTAOB = "BPA"
                SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
                Gosub XMLREP From CRMEXCEPT
              Endif
            Endif
          Endif
          If IDISPLAYRSE Then
            #Représentant secondaires
            Filter [RSE] Where [F:RSE]BPCNUM = [F:BPC]BPCNUM Order By [F:REP]REPNUM Asc
            For [RSE]
              SZCTAOB = "RSE"
              SZCTAOBNUM = [F:RSE]REPNUM
              SZCTLEVEL = "2"
              SZCTPARENTAOB = "BPA"
              SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
              Gosub XMLRSE From CRMEXCEPT
            Next
            Filter [RSE]
          Endif
        Endif
      Endif
    Else
      If IDISPLAYMST Then
        #Chargement des représentants principaux
        Filter [MAR] Where [F:MAR]RECORDNUM = [F:BPR]BPRNUM and [F:MAR]RECORDADD = [F:BPA]BPAADD and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP > 0
        For [MAR]MAR2
          Read [REP]REP0=[F:MAR]REPNUM
          If !fstat Then
            If IDISPLAYREP Then
              SZCTAOB = "REP"
              SZCTAOBNUM = [F:REP]REPNUM
              SZCTLEVEL = "2"
              SZCTPARENTAOB = "BPA"
              SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
              Gosub XMLREP From CRMEXCEPT
            Endif
          Endif
        Next
        Filter [MAR]
        #Chargement des représentants secondaires
        Filter [MAR] Where [F:MAR]RECORDNUM = [F:BPR]BPRNUM and [F:MAR]RECORDADD = [F:BPA]BPAADD and [F:MAR]RECORDTYP = "BPR" and [F:MAR]REPTYP = 0
        For [MAR]MAR2
          If IDISPLAYMAR Then
            SZCTAOB = "MAR"
            SZCTAOBNUM = [F:MAR]REPNUM
            SZCTLEVEL = "2"
            SZCTPARENTAOB = "BPA"
            SZCTPARENTNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
            Gosub XMLMAR From CRMEXCEPT
          Endif
        Next
        Filter [MAR]
      Endif
    Endif
  Next
  Filter [BPA]
Return

##########################################################
# Contact
##########################################################
$ADDCNT
  Filter [CNT] Where [F:CNT]BPATYP = 1 and [F:CNT]BPANUM = [F:BPR]BPRNUM Order By [F:CNT]CCNCRM Asc
  For [CNT]
    SZCTAOB = "CNT"
    SZCTAOBNUM = num$([F:CNT]BPATYP) + [F:CNT]BPANUM + [F:CNT]CCNCRM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "BPR"
    SZCTPARENTNUM = [F:BPR]BPRNUM
    Gosub XMLCNT From CRMEXCEPT
  Next
  Filter [CNT]
Return
