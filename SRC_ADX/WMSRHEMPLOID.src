# Supervisor
#WMSRHEMPLOID EMPLOID
# 2018-11-06 07:05:44 209

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","EMPLOID","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOID [ID]
If filinfo(filpath("FIL","EMPLOIDSA","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOIDSA [ESA]
If filinfo(filpath("FIL","EMPLOIDUKI","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOIDUKI [IDUKI]
If filinfo(filpath("FIL","EMPLORIB","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLORIB [RIB]
If filinfo(filpath("FIL","EMPLOCHD","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOCHD [CHD]
If filinfo(filpath("FIL","EMPLOJNT","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOJNT [JNT]
If filinfo(filpath("FIL","EMPLOEXM","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOEXM [EXM]
If filinfo(filpath("FIL","EMPLOTRY","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File EMPLOTRY [TRY]
Local File EMPLOID [ID_]
Local Char KEY_ID(120)(1..3)
Local Char KEY_ESA(120)(1..3)
Local Char KEY_IDUKI(120)(1..3)
Local Char KEY_RIB(120)(1..3)
Local Char KEY_CHD(120)(1..3)
Local Char KEY_JNT(120)(1..3)
Local Char KEY_EXM(120)(1..3)
Local Char KEY_TRY(120)(1..3)
#Empty keys :
KEY_ID(3) = ""
KEY_ESA(3) = ""
KEY_IDUKI(3) = ""
KEY_RIB(3) = "+0"
KEY_CHD(3) = "+0"
KEY_JNT(3) = "+0"
KEY_EXM(3) = "+0"
KEY_TRY(3) = "+0"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [ID]
LogicClose File [ESA]
LogicClose File [IDUKI]
LogicClose File [RIB]
LogicClose File [CHD]
LogicClose File [JNT]
LogicClose File [EXM]
LogicClose File [TRY]
LogicClose File [ID_]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [ID] With
& [ESA]ESA0=[F:ID]REFNUM,
& [IDUKI]IDUKI0=[F:ID]REFNUM,
& [RIB]RIB0=[F:ID]REFNUM,
& [CHD]CHD0=[F:ID]REFNUM,
& [JNT]JNT0=[F:ID]REFNUM,
& [EXM]EXM0=[F:ID]REFNUM,
& [TRY]TRY0=[F:ID]REFNUM
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [ID] With
& [ESA]ESA0=[F:ID]REFNUM,
& [IDUKI]IDUKI0=[F:ID]REFNUM,
& [RIB]RIB0=[F:ID]REFNUM,
& [CHD]CHD0=[F:ID]REFNUM,
& [JNT]JNT0=[F:ID]REFNUM,
& [EXM]EXM0=[F:ID]REFNUM,
& [TRY]TRY0=[F:ID]REFNUM
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_ID(2) = [F:ID]REFNUM
KEY_ESA(2) = [F:ESA]REFNUM
KEY_IDUKI(2) = [F:IDUKI]REFNUM
KEY_RIB(2) = [F:RIB]REFNUM+"+"+num$([F:RIB]NUMLIG)
KEY_CHD(2) = [F:CHD]REFNUM+"+"+num$([F:CHD]NUMLIG)
KEY_JNT(2) = [F:JNT]REFNUM+"+"+num$([F:JNT]NUMLIG)
KEY_EXM(2) = [F:EXM]REFNUM+"+"+num$([F:EXM]NUMLIG)
KEY_TRY(2) = [F:TRY]REFNUM+"+"+num$([F:TRY]NUMLIG)

If (KEY_ID(2) <> KEY_ID(3)) & (KEY_ID(1) <> KEY_ID(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_EMPLOID(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:ID]
FINS = 1
Local Integer PASDET_MAXI:PASDET_MAXI= 0
Local Integer PASDET_MAXI:PASDET_MAXI= 0
Local Integer PASDET_MAX:PASDET_MAX=0
If dim([F:ID]PASCRY)>0
    If PASDET_MAXI = 0
        PASDET_MAXI = dim([F:ID]PASCRY)
    Else
        PASDET_MAXI = min(PASDET_MAXI,dim([F:ID]PASCRY))
    Endif
Endif
If dim([F:ID]PASCRY)>0
    If PASDET_MAXI = 0
        PASDET_MAXI = dim([F:ID]PASCRY)
    Else
        PASDET_MAXI = min(PASDET_MAXI,dim([F:ID]PASCRY))
    Endif
Endif
CJ1=1
For CI1 = 0 To PASDET_MAXI-1
 Break ([F:ID]PASCRY(CI1)="")
 PASDET_MAX+=1
 #Create a new instance
 INS.PASDET(CJ1) = NewInstance C_EMPLOID_PASDET(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
 INS.PASDET(CJ1).setaccessorEnabled = 0
 INS.PASDET(CJ1).PASCRY=[F:ID]PASCRY(CI1)
 CJ1+=1
Next CI1
Local Integer PERCNT_MAXI:PERCNT_MAXI= 0
Local Integer PERCNT_MAXI:PERCNT_MAXI= 0
Local Integer PERCNT_MAX:PERCNT_MAX=0
If dim([F:ID]CRYCNT)>0
    If PERCNT_MAXI = 0
        PERCNT_MAXI = dim([F:ID]CRYCNT)
    Else
        PERCNT_MAXI = min(PERCNT_MAXI,dim([F:ID]CRYCNT))
    Endif
Endif
If dim([F:ID]CRYCNT)>0
    If PERCNT_MAXI = 0
        PERCNT_MAXI = dim([F:ID]CRYCNT)
    Else
        PERCNT_MAXI = min(PERCNT_MAXI,dim([F:ID]CRYCNT))
    Endif
Endif
CJ1=1
For CI1 = 0 To PERCNT_MAXI-1
 Break ([F:ID]CRYCNT(CI1)="")
 PERCNT_MAX+=1
 #Create a new instance
 INS.PERCNT(CJ1) = NewInstance C_EMPLOID_PERCNT(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
 INS.PERCNT(CJ1).setaccessorEnabled = 0
 INS.PERCNT(CJ1).CRYCNT=[F:ID]CRYCNT(CI1)
 CJ1+=1
Next CI1
 KEY_ID(1) = KEY_ID(2)
Endif : # KEY_ID(1) <> KEY_ID(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"REFNUM":'          +'"'+escJson(INS.REFNUM)+'"'
Append ASND.DATA ,',"NAM":'            +'"'+escJson(INS.NAM)+'"'
Append ASND.DATA ,',"SRN":'            +'"'+escJson(INS.SRN)+'"'
Append ASND.DATA ,',"CODPOS":'         +'"'+escJson(INS.CODPOS)+'"'
Append ASND.DATA ,',"CRY":'            +'"'+escJson(INS.CRY)+'"'
Append ASND.DATA ,',"DATBRN":'          + func ASYRSRH.DATE_TO_SYR(INS.DATBRN)
Append ASND.DATA ,',"CRYBRN":'         +'"'+escJson(INS.CRYBRN)+'"'
Append ASND.DATA ,',"NTT":'            +'"'+escJson(INS.NTT)+'"'
Append ASND.DATA ,',"JNTCRY":'         +'"'+escJson(INS.JNTCRY)+'"'
Append ASND.DATA ,',"FCY":'            +'"'+escJson(INS.FCY)+'"'
Append ASND.DATA ,',"CPY":'            +'"'+escJson(INS.CPY)+'"'
Append ASND.DATA ,',"CODACS":'         +'"'+escJson(INS.CODACS)+'"'
Append ASND.DATA ,',"PSD":'            +'"'+escJson(INS.PSD)+'"'
Append ASND.DATA ,',"FCYORI":'         +'"'+escJson(INS.FCYORI)+'"'
Append ASND.DATA ,',"CREUSR":'         +'"'+escJson(INS.CREUSR)+'"'
Append ASND.DATA ,',"UPDUSR":'         +'"'+escJson(INS.UPDUSR)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"PASDET":['
For CI1=1 To PASDET_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"PASCRY":'          +'"'+escJson(INS.PASDET(CJ1).PASCRY)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
IS1=""
CJ1=1
Append ASND.DATA ,',"PERCNT":['
For CI1=1 To PERCNT_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"CRYCNT":'          +'"'+escJson(INS.PERCNT(CJ1).CRYCNT)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_ID(1),KEY_ESA(1),KEY_IDUKI(1),KEY_RIB(1),KEY_CHD(1),KEY_JNT(1),KEY_EXM(1),KEY_TRY(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:ID]REFNUM"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From EMPLOID_CSTD
 Gosub METHODS From EMPLOID_CSTD
Gosub METHODS From EMPLOID_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="EMPLOID" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EMPLOID")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"EMPLOID")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,16058)+'"'
Append WCLOB,',"$url":"{$baseUrl}/EMPLOID'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,16058)+' {$key}"'
Append WCLOB,',"$key":"{REFNUM}"'
Append WCLOB,',"$url":"{$baseUrl}/EMPLOID('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'EMPLOID.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"REFNUM":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,10793)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"NAM":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,46083)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"SRN":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,46126)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"CODPOS":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,210)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":10'
Append WCLOB,"}"
Append WCLOB,',"CRY":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,46043)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":3'
Append WCLOB,"}"
Append WCLOB,',"DATBRN":{'
