#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
#                                                                               #
# GACTION  : TRTSYNCWGG  : Action resynchronisation du flag Plan de pesée       #
#                                                                               #
#################################################################################

$ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "INIT"          : Gosub INIT
  When "INIT_DIA"      : Gosub INIT_DIA
  When "EXEC"          : Gosub EXEC
  When "TERMINE"       : Gosub TERMINE
Endcase
Return


##################################################################################
$OUVRE
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    WMFGNUM(GLONVCR)
Local Integer NBMAJ
Local Integer TRA   : TRA = 0
Local Char    TIT(50)
Local Char    WMESS(85)

If clalev ([F:WGG]) <= 0 : Local File WEIGHING [WGG] : Endif
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD [MFG]  : Endif
If clalev ([F:MFM]) <= 0 : Local File MFGMAT  [MFM]  : Endif

TIT = mess(72,2324,1)
TRA=0
Call OUVRE_TRACE(TIT) From LECFIC
Return

##################################################################################
$INIT

Call FIND_GFCYDEF(8) From TRTX3
Gosub OUVRE

Return

###################################################################################
$INIT_DIA

Local    Char    LFCY(30) : LFCY = PARAM(1)
Raz [M:DIA]
If LFCY <> "" : [M:DIA]MFGFCY = LFCY Else [M:DIA]MFGFCY = GFCY : Endif

Return

###################################################################################
$EXEC

Call OUVRE_TRACE(TIT) From LECFIC

# filtres
Gosub LOAD_FILTER

Link [WGG] With [MFG]MFG0 =  [F:WGG]MFGNUM
&  As [LIE]
&  Where  evalue(CRITERE1)
  # récupération de l'ensemble des OFs
  # dont la situation = plan de pesée
  # dont dates de pesée des matières sont comprises dans la fourchette
  # précisée en critère
  For [LIE]
    OK = 9
    Filter[MFM] Where [MFM]MFGNUM = [F:LIE]MFGNUM
     If   WMFGNUM <> [F:LIE]MFGNUM
       WMFGNUM = [F:LIE]MFGNUM
       For [MFM]
          # suite 92125 mm  02.2014
          # il y a au moins une matière non pesée dans l'OF -> l'OF doit resrer dans le plan de pesée
          If find ([F:MFM]WGGSTA,1,2)  & ([F:MFM]PKC >1 ) : OK = 3 : Break : Endif
       Next
       # toutes les matières sont pesées/réconciliées/engagées
       # -> l'OF ne doit plus apparaître dans le plan de pesée
       If OK = 9 Gosub TRT_RESYNCHRO Endif
     Endif
    Filter
  Next

Return

#-----------------------------------------------------------------------#
# Traitement de la mise à jour du flag plan de pesée                    #
#-----------------------------------------------------------------------#
$TRT_RESYNCHRO
 Gosub MAJ_RESYNCHRO

 If NBMAJ
    WMESS = "        "+num$(NBMAJ)-mess(260,197,1)
    Call ECR_TRACE(WMESS,0) From GESECRAN
 Endif
Return

#-----------------------------------------------------------------------#
# Mise à jour du flag plan de pesée                                     #
#-----------------------------------------------------------------------#
$MAJ_RESYNCHRO
Call DEBTRANS From GLOCK
Trbegin [MFG]

Call MAJ_FICHIERS ("MFG", 5, 8, WMFGNUM, "", 0, 0) From SCALEXCHAN
If GOK < 1
 Gosub AB_TRT
Else
  NBMAJ += 1
  Raz WMESS
  WMESS = mess(73,2324,1) -WMFGNUM
  Call ECR_TRACE(WMESS,0) From GESECRAN

  Commit
Endif

Return

###################################################################################
$TERMINE

  If !NBMAJ
     Call ECR_TRACE( mess(264,199,1), 0) From GESECRAN
  Endif
  # fermeture trace
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC


Return

###########################################################################
# abandon
###########################################################################
$AB_TRT
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
# Préparation du filtre sur la table des pesées                        #
########################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
CRITERE1 = ""

# situation OF  = plan de pesée
CRITERE =  "[F:MFG]WGGFLG = 3"
Gosub LOAD_CRITERE1

# site
If [M:DIA]MFGFCY <> ""
   CRITERE = "[F:WGG]FCY=[M:DIA]MFGFCY"
   Gosub LOAD_CRITERE1
Endif

# date de pesée
If [M:DIA]CBTDATSTR <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT>=[M:DIA]CBTDATSTR"       # borne debut date pesee
   Gosub LOAD_CRITERE1
Endif

If [M:DIA]CBTDATEND <> [0/0/0]
   CRITERE = "[F:WGG]CBTDAT<=[M:DIA]CBTDATEND"       # borne fin date pesee
   Gosub LOAD_CRITERE1
Endif

Return

#############################################################################
$LOAD_CRITERE1
If len(CRITERE1)<>0 : CRITERE1 += "&" : Endif
CRITERE1 += CRITERE
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran SYNWGG) 26/08/2013 11:07:38 (MM)
######################################################################################
Subprog C_CBTDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]CBTDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


######################################################################################
