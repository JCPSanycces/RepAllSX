#<AdxTL>@(#)10.0.0.0 $Revision$
###################################################
## Intégration d'un menu local
###################################################
$MENLOC
FICHIER = "AMENLOC" : ABR = "AML"
Read [AML]MENLOC = val(NOMOBJ)
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_AML
      Gosub FIN_OBJ From PATCH
  Else
      # Patch not for scm - ISFULLMOD = 2 when SCM
      If [L]ISFULLMOD<>2
          # specific objet ? only on not scm mode and only on header
          If dim([F:AML]CODACT)>0 & [F:AML]CODACT>="X" & !find([F:AML]CODACT,ACTIV(1..NBACT))
              # specific Objet
              Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
              OKSPE = 1
              Gosub FIN_OBJ From PATCH
          Else
              NEWOBJ = 0
              Gosub TR_AML
          Endif
      Else
          #ISFULLMOD = 2 when SCM always rewrite no test about spe activity code.
          NEWOBJ = 0
          Gosub TR_AML
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Gosub TR_AML
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif
Return

$DEL_AML
Call DEBTRANS From GLOCK
Local Integer CHAPITRE , MENU
[L]CHAPITRE=[AML]MENLOC
[L]MENU = [AML]MENLOCAL
Gosub TR_ANNU From APLSTD
If GOK<1
 GOK = 0 : ER = 99 : ERFIC = "AMENLOC"-NOMOBJ : Return
Endif
Call SUPMENL(DOSSIER(D),[L]CHAPITRE) From INTRUTILB
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AML",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$TR_AML
Call DEBTRANS From GLOCK
Trbegin [AML] , [AST]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "AML"   : Gosub AML1
     When "AST"   : Gosub AML2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER : Break : Endif
 Until 1=0
 If ER : Goto ABORT : Endif
Commit
If[L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("AML",num$([F:AML]MENLOC),"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
Return

$AML1
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If dim(ISMENVALMOD)>0 & find([F:AML]MENLOC,9137,9138)
 ISMENVALMOD = 1
Endif
If dim(ISMENMOD)>0
 ISMENMOD += 1
Endif
If NEWOBJ
 Write [AML]
 If fstat
    Call LOG_ERROR_DETAILS(1, "AML",num$([F:AML]MENLOC),"") From GLOCK
 Endif
Else
 Rewrite [AML]
 If fstat
    Call LOG_ERROR_DETAILS(2, "AML",num$([F:AML]MENLOC),"") From GLOCK
 Endif
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "AMENLOC"-NOMOBJ : Return
Endif
If !NEWOBJ and [F:AML]AUZMOD=2 and APPLI<>GDOSX3
 Return
Endif
For L=1 To NLANP
 Delete [AST] Where LAN=LANPATCH(L) & LANCHP=[F:AML]MENLOC
 If fstat
    Call LOG_ERROR_DETAILS(3, "AST",num$([F:AML]MENLOC)+"~0~"+LANPATCH(L),"") From GLOCK
    GOK = 0 : ER = 99 : ERFIC = "APLSTD"-num$([F:AML]MENLOC)+"~0~"+LANPATCH(L) : Break
 Endif
 If [F:AML]MENLOC<200
  Delete [AST] Where LAN=LANPATCH(L) & LANCHP=0 & LANNUM=[F:AML]MENLOC
  If fstat
     Call LOG_ERROR_DETAILS(3, "AST","0~"+num$([F:AML]MENLOC)+"~"+LANPATCH(L),"") From GLOCK
     GOK = 0 : ER = 99 : ERFIC = "APLSTD"-"0~"+num$([F:AML]MENLOC)+"~"+LANPATCH(L) : Break
  Endif
 Else
  Delete [AST] Where LAN=LANPATCH(L) & LANCHP=200 & LANNUM=[F:AML]MENLOC-200
  If fstat
     Call LOG_ERROR_DETAILS(3, "AST","200~"+num$([F:AML]MENLOC-200)+"~"+LANPATCH(L),"") From GLOCK
     GOK = 0 : ER = 99 : ERFIC = "APLSTD"-"200~"+num$([F:AML]MENLOC-200)+"~"+LANPATCH(L) : Break
  Endif
 Endif
Next L
If GOK=0
    Return
Endif
Return

$AML2
FICHIER = "APLSTD" : ABR = "AST"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If !NEWOBJ and [F:AML]AUZMOD=2 and APPLI<>GDOSX3
 Return
Endif
L = find([F:AST]LAN,LANPATCH(1..NLANP))
If L
 Read [AVO]AVO0(1) = [F:AST]LAN
 If !fstat & dim([F:AVO]CUR)>0 & [F:AVO]CUR<>0
  Read [AVO]AVO0 = [F:AST]LAN;[F:AVO]CUR;2;[F:AST]LANCHP;[F:AST]LANNUM
  If !fstat
   [F:AST]LANMES = [F:AVO]TXT
  Endif
 Endif
 Write [AST]
 If fstat
  Call LOG_ERROR_DETAILS(1, "AST",num$([F:AST]LANCHP)+"~"+num$([F:AST]LANNUM)+"~"+[F:AST]LAN,"") From GLOCK
  GOK = 0 : ER = 99 : ERFIC = "APLSTD"-NOMOBJ-[F:AST]LAN-num$([F:AST]LANNUM) : Return
 Endif
Endif
Return

$ABORT
Rollback
Return

