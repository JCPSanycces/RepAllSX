#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
Endcase
Return

 # SAM # 111399 $METHODS outcommented content is now implemented in $EVENT
#$METHODS
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
#      Endcase
#Endcase
#Return


$PROPERTIES
Case [L]CURPRO
Endcase
Return


$AQUERY_TRANS_AFTER
Return                              # doesn't work for platform reasons -> deactivated
Local Char FILTERSTRING(250)
   Gosub GETFILTERSTRING            # build string for additional filtering

#   this.PBDGEND.CRITERIA = "CODE eq " + this.PBDGEND.CODE + " and LEG eq " + this.PBDGEND.LEG
#   this.PBDGEND.CRITERIA += " and ISDETAIL eq 2 and ISOITEM eq " + num$(this.PBDGEND.ISOITEM) + " and "
#   this.PBDGEND.CRITERIA += FILTERSTRING
   this.CRITERIA = FILTERSTRING
Return


$GETFILTERSTRING
Local Instance UICONF Using C_PBDUICONF
Local Integer GROUPBY, K, NUMGRP

   [L]UICONF = NewInstance C_PBDUICONF  AllocGroup null  # to read "displayed fields" configuration for legislation

   ASTATUS = fmet [L]UICONF.AREAD(this.PBDGEND.LEG)
   If ASTATUS = [V]CST_AOK     # "displayed fields" configuration found for legislation
     NUMGRP = 0
     For K=1 To maxtab([L]UICONF.LINES)
       If [L]UICONF.LINES(K)<>null
          GROUPBY = [L]UICONF.LINES(K).GRPBYS = 2        # should be grouped by
          If GROUPBY
             If NUMGRP > 0
                FILTERSTRING += " and "
             Endif
             Case func TYPEOF( evalue("this.PBDGEND."+[L]UICONF.LINES(K).FLD) )
             When 1, 2, 4, 5, 6, 7, 9
                 FILTERSTRING += [L]UICONF.LINES(K).FLD + " eq " + num$( evalue("this.PBDGEND."+[L]UICONF.LINES(K).FLD) )
             #When 3
             #    ... (Date necessary?)
             When Default
                 FILTERSTRING += [L]UICONF.LINES(K).FLD + " eq '" + evalue("this.PBDGEND."+[L]UICONF.LINES(K).FLD) + "'"
             Endcase
             NUMGRP += 1
          Endif
       Endif
     Next K
   Endif
   FreeGroup [L]UICONF
Return


# ======== DO === NOT === DELETE ==================================
# NOTE (DNE): We need this function as a replacement for type() for type() function only handles variables. So in our case
#             type( evalue(...) ) does not work. Funprog TYPEOF() creates a non-static typed variable ARGUMENT so type()
#             can test its type.
#             Please do not change this function. Especially do not give ARGUMENT a type!!!
Funprog TYPEOF(ARGUMENT)
End type( ARGUMENT )
