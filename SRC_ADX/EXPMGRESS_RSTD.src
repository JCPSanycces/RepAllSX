#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return
########################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "EXSH.TCH_EMPSBD" : Gosub EXSH_TCH_EMPSBD
  When "EXSH.REFNUM"     : Gosub EXSH_REFNUM
Endcase
Return
########################################################################################
$EXSH_REFNUM
  Case ARULE
    When "CONTROL" : Gosub EXSH_REFNUM_CONTROL
  Endcase
Return


$EXSH_REFNUM_CONTROL
  If this.REFNUM = AVOID.ACHAR : Return : Endif

  Local File EMPLOID [F:ID2]

  Read [F:ID2]ID0 = this.REFNUM
  If !fstat
    If [F:ID2]FLGMULCTR = 1 : #No
      ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","true")
    Elsif [F:ID2]FLGMULCTR = 1 : #Yes
      ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","false")
    Endif
  Endif

  LogicClose File [F:ID2]
Return
########################################################################################
$EXSH_TCH_EMPSBD
  Case ARULE
    When "INIT"       : Gosub EXSH_TCH_EMPSBD_INIT
    When "CONTROL"    : Gosub EXSH_TCH_EMPSBD_CONTROL
    When "PROPAGATE"  : Gosub EXSH_TCH_EMPSBD_PROPAGATE
  Endcase
Return
#------------------------------------------
$EXSH_TCH_EMPSBD_INIT
  ASTATUS = fmet this.ASETATTRIBUTE("TCH_EMPSBD", "$isMandatory", "true")
Return
#------------------------------------------
$EXSH_TCH_EMPSBD_CONTROL
If this.TCH_EMPSBD = AVOID.ACHAR
  #The refnum will always be updated for DEMCONGEESS
  ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(00010,00123,1),[V]CST_AERROR)# : MANDATORY Field
Endif
Return

$EXSH_TCH_EMPSBD_PROPAGATE
If this.TCH_EMPSBD <> AVOID.ACHAR
  #The refnum will always be updated for DEMCONGEESS
   ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM", "$isHidden", "false")
Endif
Return


########################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return
########################################################################################
$AQUERY_CRITERIA_AFTER

  Local Char ESS_REFNUM : ESS_REFNUM = fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,'REFNUM')

  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (EXSSTA eq 2 or EXSSTA eq 5 or EXSSTA eq 1) and (CHEF eq '"+ESS_REFNUM+"')"
  Else
    PQRY.QWHERE = "(EXSSTA eq 2 or EXSSTA eq 5 or EXSSTA eq 1) and (CHEF eq '"+ESS_REFNUM+"')"
  Endif

Return

########################################################################################

