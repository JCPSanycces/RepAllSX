#<AdxTL>@(#)43.0.0.0 $Revision$
$ACTION
Case ACTION
 When "INIT_DIA"
  Case GACTION
   When "DEPOINTPRO"  : Gosub INIT_PRO
  Endcase
 When "CONTROLE"
  Case GACTION
   When "DEPOINTPRO"  : Gosub CONTROLE_PRO
  Endcase
 When "EXEC"
  Case GACTION
   When "DEPOINTPRO"  : Gosub EXEC_PRO
  Endcase
Endcase
Return

################################################################
# ETIQUETTES DEPOINT1    DEPOINTAGE AUTOMATIQUE
################################################################
Subprog AS_BANK(VALEUR)   
Variable Char    VALEUR()   
If VALEUR="" & [M:SAI1]BAN<>""
 VALEUR = [M:SAI1]BAN
 mkstat = 2
 End
Endif
If VALEUR="" : Call BANDEF(VALEUR) From SUBCHK : Endif   
End  
 
Subprog C_CHKFIN(VALEUR) 
Variable Char    VALEUR() 
If VALEUR < [M]CHKDEB 
 GMESSAGE = mess(29,120,1) : #Code pointage incorrect 
 mkstat = 2 
Endif 
End 
 
Subprog AS_CHKFIN(VALEUR) 
Variable Char    VALEUR() 
If VALEUR="" 
 VALEUR = [M]CHKDEB  
Endif  
End  

$INIT_PRO
Raz [M:DIA]
TMP = 1 : TRA = 1
Return

$CONTROLE_PRO
[M:DP1] = [M:DIA]
Return

$EXEC_PRO
Call OUVRE_TRACE(mess(28,120,1)+"  "+mess(45,120,1)+" "+[M:DP1]BANK) From LECFIC
# Dépointage automatique  BANQUE :
Call ECR_TRACE(mess(59,100,1)+space$(7)+mess(88,100,1)+space$(10)+mess(19,120,1)+
&              space$(6)+mess(32,105,1)+space$(10)+mess(29,159,1),0) From GESECRAN
# type     Date          Pointage      Montant          Désignation
Call ECR_TRACE(string$(72,"="),0) From GESECRAN
Call PARAM("","SNSBNQ",[M:SAI1]SNSBNQ) From ADOVAL
Call DEBTRANS From GLOCK
Gosub TR2 From DEPOINTAGE
Call FERME_TRACE From LECFIC
If !GIMPORT : Effzo [M:SAI1] : Endif
Return

