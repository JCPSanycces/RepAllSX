#<AdxTL>@(#)3.0.0.0 $Revision$
Gosub TEST From SUBAYIWSRGEN
End
######################################################################################
## Site Web:  Gestion des Interface 
#          GÃĐnÃĐration fiche sous-programme et AccÃĻs table pour un type AccÃĻs table gÃĐnÃĐrÃĐ
#  Version interne: 0002
#
#  Nota:    Mask AYIWSRGEN est utilisÃĐ par l'action AYIWSRGEN sous [DIA] pour la sÃĐlection des chps
#                et par le subprog GENSUBPRG sous [WRK] pour avoir les infos sur les chps
#
######################################################################################

######################################################################################
### Utilitaires
##    GENSUBPRG       GÃĐnÃĐration sous-prgrm accÃĻs table ou vue
#
#   E46683 AccÃĻs table et vue - Rubrique avec code activitÃĐ pour dim
#
######################################################################################

#------------------------------------------------------------#
# GÃĐnÃĐration sous-prgrm accÃĻs table ou vue
#    et publication
#------------------------------------------------------------#
#
#  Partie commune table et vue
#------------------------------------------------------------#

Subprog GENSUBPRG(DOSDES, INTTYP, OBJCOD, WEBSRCCOD, RET)
Value Char DOSDES, OBJCOD, WEBSRCCOD        # Dossier, ClÃĐ objet table ou vue, code webservice 
Value Integer INTTYP                        # Type interface (menu 7912)
Variable Integer RET                        # Code retour 0:Ko 1=Ok
RET=1
Local Char WSPRG(GLONADC), WSUBPRG (GLONASU)        # Code trt et sous-programme interface
Local Char NOMFIC (250), WLINE(250), WLINEEND(10), WLINE2(250), WLINEADD(250), WTIT(200)
Local Char XTVER : XTVER="1.0.3"
Local Char MACDES(GDIMFIC), DOSNAMDES(GDIMFIC)        # sodaix01:5000
Local Char HORDAT(14)
Local Char Q1(1), Q2(1), Q3(3) : Q1="'" : Q2='"' : Q3=Q1+Q2+Q1
#Local Clbfile WTABCLB(2)(1..6)
Local Integer WI, WFLGLINE, WDIAIND, WFLGUSERDATA, MAXFIL
Local Integer WLNKFLG, WLNKATXNB, WLNKAXXNB  # flag lien atx (atexte) ou axx (atextra)
Local Char AXXCL1(20)(1..100),AXXCL2(20)(1..100),AXXTAB(20)(1..100),AXXZON(80)(1..100) # infos liÃĐes Ã  axx (atextra)
Local Char WLNKTAB (200)(1..50)
Local Integer OKCREWS
#

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR   [AMP] : Endif
Local Mask AWE2 [AWE2]
#
HORDAT = func AYTGEN.TIMESTAMP

# Traitement   
WSPRG="WT"+[L]WEBSRCCOD
# Sous-prgrm
Case INTTYP
When 1
    WSUBPRG = "ACCTAB"
When 4
    WSUBPRG = "ACCVIEW"
When Default
    GMESSAGE="Erreur interne GENSUBPRG - Interface type unknown: "+num$(INTTYP)
Endcase
#
WTIT=mess(61,7900,1)-WSPRG-"/"-WSPRG
Call ECR_TRACE(WTIT,0) From GESECRAN
Call TEMPON(WTIT) From GESECRAN
#
Read [ASU]ASU0 = WSPRG;WSUBPRG
If fstat
    Call ECR_TRACE(" "+mess(45,7900,1)-WEBSRCCOD+"~"+WSUBPRG,1) From GESECRAN
    # Call RSTA("ASU",WEBSRCCOD+"~"+WSUBPRG) From GLOCK 
    RET=0 : End
Endif

# Alimentation mask (mask propre pour autonomie subprog)
Local Mask AYIWSRGEN [WRK]    # Pas la mÃŠme abrev car contrairement Ã  la doc le local mask n'ouvre pas en local
    #Infbox "[M:WRK]NBZONE"-num$([M:WRK]NBZONE)  --> Il faut faire un close ou un raz
[M:WRK]DOSDES        =[L]DOSDES
[M:WRK]WEBSRCCOD     =[L]WEBSRCCOD         
[M:WRK]SUBPRG        =[L]WSUBPRG           
[M:WRK]OBJCOD        =[L]OBJCOD
[M:WRK]TYP           =[L]INTTYP

[M:WRK]RESMAX        =100
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG & PUBLI="RES"
 [M:WRK]RESMAX=[F:ASP]DIME
  Break
Next ASP
MAXFIL=dim([M:DIA]CODX3IND)

Case INTTYP
When 1
    Gosub DIALOAD_TAB
When 4
    Gosub DIALOAD_VUE
Endcase

# Source WSPRG
Call MACHINE(DOSDES,MACDES,DOSNAMDES) From ORDSYS
NOMFIC=func AYTGESFILE.GETPATH(MACDES, DOSNAMDES, "FILTRT","","",WSPRG)

Onerrgo ERR_OPEN
Openo NOMFIC,0  
Onerrgo
If !RET : Goto GEN_F : Endif
Iomode adxifs ""    
Iomode adxirs chr$(10)    
Iomode adxium GUTF8    

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.1  $"   
Wrseq " "   
Wrseq "#########################################################################"    

Case INTTYP
When 1
 Wrseq "## Genarated program to acces X3 table: " + [WRK]OBJCOD    
When 4
 Wrseq "## Genarated program to acces X3 view: " + [WRK]OBJCOD    
Endcase

Wrseq "## Program name             : " + WSPRG   
Wrseq "## Subprogram name          : " + [WRK]SUBPRG    

Wrseq "## Generator version        :"-XTVER
Wrseq "## TimeStamp                :"-HORDAT
Wrseq "#########################################################################"   
Wrseq "# Remark: To make a personnalized access program:"
Wrseq "#         - Set a new name to this source"
Wrseq "#         - Change ACCTAB or ACCVIEW by ACCESS for Call, Subprog and messages lines"
Wrseq "#         - Search and modify lines with the token XT_SPE"
Wrseq "#         - Create a new document in the X3 subprogram function and publish the Web Service"
Wrseq "# "
Wrseq "# Test "   
Wrseq "Goto TSTCALL "   
Gosub SPRGCALL
Gosub PRGINI
Gosub PRGLNK
Gosub SPRGFLT
Gosub SPRGRES
Wrseq ''
Gosub DBGPAR
Wrseq ''
Gosub TSTCALL
Openo   

# Validation
WTIT=mess(62,7900,1)-[L]WSPRG
Call ECR_TRACE(WTIT,0) From GESECRAN
Call TEMPON(WTIT) From GESECRAN
Call VALID("TRT",[L]WSPRG,DOSDES,RET) From VALMSKSUB
If !RET : Goto GEN_F : Endif

# Publication
WTIT=mess(63,7900,1)-[L]WEBSRCCOD
Call ECR_TRACE(WTIT,0) From GESECRAN
Call TEMPON(WTIT) From GESECRAN
If MACDES=""
    #Call CRESP(DOSDES,[L]WSPRG,[WRK]SUBPRG,[L]WEBSRCCOD, 0,HORDAT) From AGENWEB # pas de code retour
    Call CREWS(DOSDES,[L]WEBSRCCOD,"","","",[L]WSPRG,[WRK]SUBPRG,2,OKCREWS) From AGENWEB
    RET=(OKCREWS=0)
Else
    Call ECR_TRACE(mess(191,7900,1)-MACDES,1) From GESECRAN
#    Call ECR_TRACE("CRESP/AGENWEB (SUBAYIWSRGE1) non executable sur dossier distant"-MACDES,1) From GESECRAN
Endif

$GEN_F
Close Local Mask [WRK] 
End

# Trace
$ERR_OPEN
Call ECR_TRACE(mess(13,100,1)-NOMFIC, 1) From GESECRAN
RET=0
Resume


# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Ecriture subprog sous-prgrm 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$SPRGCALL
Wrseq "# Subprogram  "   
Wrseq "#########################################################################"   
WI=0

WLINE="Subprog " +[WRK]SUBPRG+ "(  "

WI = 0
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    
    If WI : WLINE+="," : Endif
    WLINE+=[ASP]PARAM
    If len(WLINE)>80 or [ASP]PARAM="AXORDTYP" 
        Wrseq WLINE 
        WLINE="&                "
    Endif
    WI = 1
Next
WLINE+=')'
Wrseq WLINE

WI = 0
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    If WI=0 
      Wrseq "# Begining of compulsory technical section"
    Endif

    If [ASP]ADRVAL=2 : WLINE='Value ': Else : WLINE='Variable ' : Endif
    Case [ASP]TYPPAR   # Menu 33
    When 1   
        WLINE+='Char    '+[ASP]PARAM+'()'
    When 2   
        WLINE+='Integer '+[ASP]PARAM
    When 3   
        WLINE+='Decimal '+[ASP]PARAM
    When 4
        WLINE+='Date    '+[ASP]PARAM
    When 6
        WLINE+='ClbFile '+[ASP]PARAM+'()'
    When 7
        WLINE+='Blbfile '+[ASP]PARAM+'()'
    Endcase
    If [ASP]DIME > 1  : WLINE+="(1.."+num$([ASP]DIME)+")" : Endif
    Wrseq WLINE
    If [ASP]PARAM="AXORDTYP" 
      Wrseq "# End of compulsory technical section"
      Wrseq "# <XT_SPE>Set new arguments"
    Endif
    WI = 1
Next
Wrseq "# </XT_SPE>"
#
Wrseq 'Local char TRT_TIT(50)'
Case INTTYP
When 1
 Wrseq  'TRT_TIT=" - Subprog ' +[L]WSPRG+ '( table ' +[WRK]OBJCOD+ ')"  # <XT_SPE/>'
When 4
 Wrseq  'TRT_TIT=" - Subprog ' +[L]WSPRG+ '( view ' +[WRK]OBJCOD+ ')"  # <XT_SPE/>'
Endcase

Wrseq 'Local Integer WI'
Wrseq ''
Wrseq '# Debug - Activate line and modify $SETDEBUGJON  '
Wrseq '# Gosub SETDEBUGJON : Dbgaff'
Wrseq ''
Wrseq ''
Wrseq 'Gosub CL_INI'    # Initialisation clause '
Wrseq ''
Wrseq 'Gosub CL_LNK'    # Link clause '
Wrseq ''
Wrseq 'Gosub CL_FLT'    # Filtre clause '
Wrseq ''
Wrseq 'Gosub CL_RES'    # Results clause '
Wrseq ''
Wrseq '# Gestion timing'
Wrseq 'If GTRACE<>""'
Wrseq '   Gosub TIMING_STOP From AYTUTIA        # Timing stop'
Wrseq 'Endif '
Wrseq ''
Wrseq 'End'
Wrseq ''
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '# Utilities   '
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq ''


Return     ## - - - - Fin ÃĐcriture subprog sous-prgrm 

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# Ecriture Clause Init 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
$PRGINI
Wrseq '# Initialisation clause'
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '$CL_INI'
Wrseq '# Gestion trace '
Wrseq 'If GTRACE=""    # No trace active'
Wrseq '  WI = find ("$X3TRACE", AXPARCOD) '
Wrseq '  If WI'
Wrseq '    Onerrgo ERR_PARNUM'
Wrseq '    WJ = val(AXPARVAL(WI))'
Wrseq '    Onerrgo : If GW_STAT : Return : Endif'
Wrseq '    If WJ=1        # Trace asked'
Wrseq '      Call OUVRE_TRACE("Test: '+[L]WSPRG+'/' +[WRK]SUBPRG+ '") From LECFIC'
Wrseq '      AXPARVAL(WI)=GTRACE'
Wrseq '      Call ECR_TRACE("### Trace from subprog ' +[WRK]SUBPRG+ '" ,0) From GESECRAN'
Wrseq '      Call ECR_TRACE("X3 Trace reference:"  +GTRACE ,0) From GESECRAN'
Wrseq '    Endif '
Wrseq '  Endif '
Wrseq 'Else'
Wrseq '   Call ECR_TRACE("### Trace from subprog ' +[WRK]SUBPRG+ '" ,0) From GESECRAN'
Wrseq 'Endif '
Wrseq ''

Wrseq '# Messge and timing'
Wrseq 'If GTRACE<>""'
Wrseq '   Gosub TIMING_START From AYTUTIA        # Timing start'
Wrseq 'Endif '
Wrseq ''

Wrseq '# Optimalisation'
Wrseq 'Local Integer P_OPTIMISE   # Asked optimalisation (menu 7633) for interface'
Wrseq 'WI = find ("$OPTIMISE", AXPARCOD) '
Wrseq 'If WI'
Wrseq '  P_OPTIMISE=val(AXPARVAL(WI))'
Wrseq '  If P_OPTIMISE<1 : P_OPTIMISE=1 : Endif'
Wrseq '  If GTRACE<>""'
Wrseq '      Call ECR_TRACE("Optimalisation:"-mess(P_OPTIMISE,7933,1)-" ("+num$(P_OPTIMISE)+")" ,0) From GESECRAN'
Wrseq '  Endif'
Wrseq 'Endif '
Wrseq ''

For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    Case [ASP]TYPPAR    # Menu 33
    When 6  # Clob
        Wrseq '# Optimalisation clob '+[ASP]PARAM
        Wrseq 'Local integer '+[ASP]PARAM+'_Y'
        Wrseq 'If find(P_OPTIMISE,2,4) # No clob, Noclob or blob  '  # 2 mode de fonctionnement
        Wrseq '  ' +[ASP]PARAM+'_Y = 0'        
        Wrseq 'Else'
        Wrseq '  ' +[ASP]PARAM+'_Y = (len(' +[ASP]PARAM +'(1))=0)'
        Wrseq 'Endif'
    When 7  # Blob
        Wrseq '# Optimalisation blob '+[ASP]PARAM
        Wrseq 'Local integer '+[ASP]PARAM+'_Y'
        Wrseq 'If find(P_OPTIMISE,3,4) # No blob, Noclob or blob  '  # 2 mode de fonctionnement
        Wrseq '  ' +[ASP]PARAM+'_Y = 0'        
        Wrseq 'Else'
        Wrseq '  ' +[ASP]PARAM+'_Y = (len(' +[ASP]PARAM +'(1))=0)'
        Wrseq 'Endif'
    Endcase
Next
Wrseq 'Return'
Wrseq ''
Return     
## - - - - Fin ÃĐcriture Clause Initialisation 

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# Ecriture Clause Link 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
$PRGLNK
Wrseq '# Link clause'
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '$CL_LNK'

Case INTTYP
When 1
    Gosub PRGLNK_TAB
When 4
    Gosub PRGLNK_VUE
Endcase
Return     
## - - - - Fin ÃĐcriture Clause Link 

# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Ecriture filtre sous-prgrm 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$SPRGFLT
Wrseq '# Filter clause'
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '$CL_FLT'
Wrseq 'Local Clbfile WFLTWHR(2)     # Where Filter - 2046 car.'
Wrseq 'Local Char WFLTORD(250)      # Order Filter'
Wrseq 'Local Char WWHRX3FLD(20)     # Temp X3 Field Code'
Wrseq 'Local Char WORDX3FLD(20)     # Temp X3 Field Code'
Wrseq 'Local Char WVALUE(250)       # Temp value'
Wrseq 'Raz GW_STAT'    # Utile en mode test interactif car AddMessErr ne positionne pas le flag dans ce cas
###     Clause Where
Wrseq 'For WNBPAR=1 To 10'
Wrseq '    If AXWHRCOD(WNBPAR) = "" : Break : Endif '
Wrseq '    Gosub LINFLTWHR'
Wrseq '    If GW_STAT=1 : Break : Endif'
Wrseq 'Next'
Wrseq 'If GW_STAT=1 : Return : Endif'
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Filter (Where): "+WFLTWHR ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq ''
###     Clause Order
Wrseq 'For WNBPAR=1 To 12'
Wrseq '    If AXORDCOD(WNBPAR) = "" : Break : Endif '
Wrseq '    Gosub LINFLTORD'
Wrseq '    If GW_STAT=1 : Break : Endif'
Wrseq 'Next'
Wrseq 'If GW_STAT=1 : Return : Endif'
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Filter (Order): "+WFLTORD ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq ''
###     Clause Filter
Wrseq 'Onerrgo ERR_EVAL'
Wrseq 'If WFLTWHR<>"" and WFLTORD<>""'
Wrseq '  Filter [' +[WRK]OBJABR+ '_] Where evalue(WFLTWHR) Order With WFLTORD'
Wrseq 'Elsif WFLTWHR<>""'
Wrseq '  Filter [' +[WRK]OBJABR+ '_] Where evalue(WFLTWHR)'
Wrseq 'Elsif WFLTORD<>""'
Wrseq '  Filter [' +[WRK]OBJABR+ '_] Order With WFLTORD'
Wrseq 'Else'
Wrseq '  Filter [' +[WRK]OBJABR+ '_]'
Wrseq 'Endif'
Wrseq 'Onerrgo : If GW_STAT : End : Endif'
Wrseq ''
Wrseq 'Return'
Wrseq ''
Wrseq '$ERR_EVAL'
Wrseq 'Call ADDMESSERR("Filter: Evalue error "-TRT_TIT) From AWEB'
Wrseq 'Call ADDMESSERR("Filter where: "+WFLTWHR) From AWEB'
Wrseq 'Call ADDMESSERR("Filter order: "+WFLTORD) From AWEB'
Wrseq 'Call ADDMESSERR("errn:"-num$(errn)-" errl:"-num$(errl)) From AWEB'
Wrseq 'Call ADDMESSERR(errmes$(errn)-errm) From AWEB'
Wrseq 'GW_STAT=1'    # Utile en mode test interactif car AddMessErr ne positionne pas le flag dans ce cas
Wrseq 'Resume'
Wrseq ''
Wrseq ''
#
Wrseq '##### Calcul du filtre (Where)'
Wrseq '$LINFLTWHR'
Wrseq 'Gosub FLTM56'
Wrseq 'Gosub FLTM7926'
Wrseq 'Return'
Wrseq ''
Wrseq '## Menu 56 Et/ou '
Wrseq '$FLTM56  '
Wrseq 'If WNBPAR=1 : Return : Endif '
Wrseq 'Case AXWHRANDOR(WNBPAR)'
Wrseq 'When 1 : WFLTWHR+=" and "'
Wrseq 'When 2 : WFLTWHR+=" or "'
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq ''
Wrseq '## Menu 7926 Ope '
Wrseq '$FLTM7926 '
Wrseq 'Gosub VAL_VHRSET : If GW_STAT=1 : Return : Endif'
Wrseq 'Case AXWHROPE(WNBPAR)'
Wrseq 'When 2 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' = '+Q1+'   + WVALUE'
Wrseq 'When 3 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' <> '+Q1+'  + WVALUE'
Wrseq 'When 4 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' > '+Q1+'   + WVALUE'
Wrseq 'When 5 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' >= '+Q1+'  + WVALUE'
Wrseq 'When 6 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' < '+Q1+'   + WVALUE'
Wrseq 'When 7 : WFLTWHR+=    WWHRX3FLD     +'+Q1+' <= '+Q1+'  + WVALUE'
# Algo utilitaire recherche messages
Wrseq 'When 8 : WFLTWHR+='+Q1+'pat(toupper('+Q1+' + WWHRX3FLD  + '+Q1+'),"'+Q1+'  + toupper(AXWHRCODVAL(WNBPAR)) + '+Q1+'*")=1'+Q1+''
Wrseq 'When 9 : WFLTWHR+='+Q1+'pat(toupper('+Q1+' + WWHRX3FLD  + '+Q1+'),"*'+Q1+' + toupper(AXWHRCODVAL(WNBPAR)) + '+Q1+'*")=1'+Q1+''
Wrseq 'When 10: WFLTWHR+='+Q1+'pat(toupper('+Q1+' + WWHRX3FLD  + '+Q1+'),"*'+Q1+' + toupper(AXWHRCODVAL(WNBPAR)) + '+Q1+'*")=0'+Q1+''
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq ''

#
Wrseq ''
Wrseq '##  Manage Where datas '
Wrseq '##  Input  :  AXWHRCOD  Code of Site Web field'
Wrseq '##  Output :  WWHRX3FLD Code of X3 field '
Wrseq '##            WVALUE   Value to compare  '
Wrseq '$VAL_VHRSET'
Wrseq 'Raz WWHRX3FLD , WVALUE'
Wrseq 'Local Integer R'
Wrseq "R =instr(1,AXWHRCODVAL(WNBPAR),'"+'"'+"')"
Wrseq 'While R>0'
Wrseq ' AXWHRCODVAL(WNBPAR)= left$(AXWHRCODVAL(WNBPAR),R-1)-right$(AXWHRCODVAL(WNBPAR),R+1)'
Wrseq " R =instr(1,AXWHRCODVAL(WNBPAR),'"+'"'+"')"
Wrseq 'Wend'

Wrseq "# <XT_SPE>Set selection information according the argument name</XT_SPE>"
Wrseq 'Case AXWHRCOD(WNBPAR)'
#                 
Raz WFLGUSERDATA, WLNKATXNB , WLNKAXXNB
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
  Raz WLINE, WLINE2
  If WFLGUSERDATA
     WDIAIND = find([ASP]PARAM,[WRK]CODXTD)-1
     If WDIAIND >= 0
        WLINE = ' When "'+[ASP]PARAM+'"'
        WLINEEND=''
        If [WRK]CODDIM(WDIAIND) <> 1 : WLINEEND += '(' +num$([WRK]CODX3IND(WDIAIND))+ ')' : Endif
        WLINEEND += '"'

        Case [WRK]CODTYPTYP(WDIAIND)
           When 7                                     # Alpha
             WLINE2 = '    WVALUE= ' +Q3+ ' +AXWHRCODVAL(WNBPAR)+ ' +Q3
             If !find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3")
&                  or !INTTYP=1        # Gestion particuliÃĻre uniquement sur accÃĻs table
    Wrseq WLINE + '   # Alpha'
                WLINE2 += ' : WWHRX3FLD = "' +[WRK]CODX3(WDIAIND)
             Else
    Wrseq WLINE + '   # type AXX'  
                WLNKAXXNB +=1
                WLINE2 += ' : WWHRX3FLD = "[AXX' +num$(WLNKAXXNB)+ ']TEXTE'
             Endif
    Wrseq WLINE2 + WLINEEND

          When 1                               # Menu local
    Wrseq WLINE + '   # Local menu'
    Wrseq '        If find(AXWHROPE(WNBPAR),8,9,10) '
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [local menu] - Operator not allowed: ["-mess(AXWHROPE(WNBPAR),7926,1)-"]"-TRT_TIT) From AWEB'
    Wrseq '            GW_STAT=1 : Return'
    Wrseq '        Endif'
                WLINE2 = '    WVALUE= AXWHRCODVAL(WNBPAR)'
                WLINE2 += ' : WWHRX3FLD = "' +[WRK]CODX3(WDIAIND)
    Wrseq WLINE2 + WLINEEND

                # "_L": RÃĐservÃĐ libellÃĐ menu local <M001>
    #Wrseq ' When "'+[ASP]PARAM+'_L"   # Label of local menu'
    #Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Label of local menu] - No operator allowed" -TRT_TIT) From AWEB'
    #Wrseq '            GW_STAT=1 : Return'
    #            WLINE2 = '    WWHRX3FLD = "'
    #Wrseq WLINE2 + WLINEEND

          When 2,3,4,5,6                       # Num
             If !find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3") 
&               or !INTTYP=1        # Gestion particuliÃĻre uniquement sur accÃĻs table
    Wrseq WLINE + '   # Num'
    Wrseq '        If find(AXWHROPE(WNBPAR),8,9,10) '
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Integer] - Operator not  allowed: ["-mess(AXWHROPE(WNBPAR),7926,1)-"]"-TRT_TIT) From AWEB'
    Wrseq '            GW_STAT=1 : Return'
    Wrseq '        Endif'
                WLINE2 = '    WVALUE= AXWHRCODVAL(WNBPAR)'
                WLINE2 += ' : WWHRX3FLD = "' +[WRK]CODX3(WDIAIND)
             Else
   Wrseq WLINE + '   # type ATX'
                WLNKATXNB +=1
                WLINE2 = '    WVALUE= ' +Q3+ ' +AXWHRCODVAL(WNBPAR)+ ' +Q3
                WLINE2 += ' : WWHRX3FLD = "[ATX' +num$(WLNKATXNB)+ ']TEXTE'
             Endif
    Wrseq WLINE2 + WLINEEND

           When 8                                     # Date
    Wrseq WLINE + '   # Date'
    Wrseq '        If find(AXWHROPE(WNBPAR),8,9,10) '
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Date] - Operator not allowed: ["-mess(AXWHROPE(WNBPAR),7926,1)-"]"-TRT_TIT)  From AWEB'
    Wrseq '            GW_STAT=1 : Return'
    Wrseq '        Endif'
                WLINE2 = '    WVALUE=  "["+right$(AXWHRCODVAL(WNBPAR),7)+"/"+mid$(AXWHRCODVAL(WNBPAR),5,2)+"/"+left$(AXWHRCODVAL(WNBPAR),4)+"]"'
                WLINE2 += ' : WWHRX3FLD = "' +[WRK]CODX3(WDIAIND)
    Wrseq WLINE2 + WLINEEND

           When 9                                     # Blob
    Wrseq WLINE + '   # Blob'
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Blob] - No operator allowed"-TRT_TIT) From AWEB'
    Wrseq '            GW_STAT=1 : Return'
                WLINE2 = '    WWHRX3FLD = "'
    Wrseq WLINE2 + WLINEEND

           When 10                                     # Clob
    Wrseq WLINE + '   # Clob'
             WLINE2 = '    WVALUE= ' +Q3+ ' +AXWHRCODVAL(WNBPAR)+ ' +Q3
             WLINE2 += ' : WWHRX3FLD = "' +[WRK]CODX3(WDIAIND)
    Wrseq WLINE2 + WLINEEND
              
           When Default
                Call ECR_TRACE([ASP]PARAM-"Type non gÃĐrÃĐ"-num$([WRK]CODTYPTYP(WDIAIND)),1) From GESECRAN
         Endcase
     Endif
  Endif
  WFLGUSERDATA += ([ASP]PARAM="AXORDTYP")     # on entre dans la partie utilisateur
Next

#
Wrseq 'When Default'
Wrseq '        Call ADDMESSERR("Compute Where: Unknown variable:"-AXWHRCOD(WNBPAR)-TRT_TIT ) From AWEB'
Wrseq '        GW_STAT=1 '
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq ''

###   Ajout ligne Order
Wrseq '## Add Filter order line '
Wrseq '$LINFLTORD  '
Wrseq 'Gosub VAL_ORDSET : If GW_STAT=1 : Return : Endif'
Wrseq 'If WFLTORD <> "" : WFLTORD +=" ; " : Endif'
Wrseq 'WFLTORD += WORDX3FLD'
Wrseq 'If AXORDTYP(WNBPAR)=2 : WFLTORD += " Desc" : Else : WFLTORD += " Asc" : Endif'
Wrseq 'Return  '

Wrseq ''
Wrseq '##  Manage order field '
Wrseq '##  Input  :  AXORDCOD   Code of Site Web field'
Wrseq '##  Output :  WORDX3FLD  X3 field to order  '
Wrseq '$VAL_ORDSET'
Wrseq 'Raz WVALUE'
Wrseq "# <XT_SPE>Set order information according argument name</XT_SPE>"
Wrseq 'Case AXORDCOD(WNBPAR)'

#
Raz WFLGUSERDATA, WLNKATXNB , WLNKAXXNB
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG  
Raz WLINE, WLINE2
  If WFLGUSERDATA
     WDIAIND = find([ASP]PARAM,[WRK]CODXTD)-1
     If WDIAIND >= 0
        WLINE = ' When "'+[ASP]PARAM+'"'
        WLINEEND=''
        If [WRK]CODDIM(WDIAIND) <> 1 : WLINEEND += '(' +num$([WRK]CODX3IND(WDIAIND))+ ')' : Endif
        WLINEEND += '"'

        Case [WRK]CODTYPTYP(WDIAIND)
           When 7                                     # Alpha
             If !find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3")  
&                  or !INTTYP=1        # Gestion particuliÃĻre uniquement sur accÃĻs table
    Wrseq WLINE + '   # Alpha'
                WLINE2 = '     WORDX3FLD  = "' +[WRK]CODX3(WDIAIND)
#             Elsif (right$([ASP]PARAM,len([ASP]PARAM)-1)="_L")    # RÃĐservÃĐ libellÃĐ menu local <M001>
#    Wrseq WLINE + '   # Menu local'
#    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Menu] - Sort not allowed" -TRT_TIT) From AWEB'
#    Wrseq '            GW_STAT=1 : Return'
             Else
    Wrseq WLINE + '   # Type AXX'
                WLNKAXXNB +=1
                WLINE2 = '     WORDX3FLD = "[AXX' +num$(WLNKAXXNB)+ ']TEXTE'
             Endif
    Wrseq WLINE2 + WLINEEND

          When 1                               # Menu local
    Wrseq WLINE + '   # Local menu'
                WLINE2 = '     WORDX3FLD  = "' +[WRK]CODX3(WDIAIND)
    Wrseq WLINE2 + WLINEEND

                # "_L": RÃĐservÃĐ libellÃĐ menu local <M001>
#    Wrseq ' When "'+[ASP]PARAM+'_L"   # Label of local menu'
#    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Label of local menu] - No operator allowed" -TRT_TIT) From AWEB'
#    Wrseq '            GW_STAT=1 : Return'
#                WLINE2 = '     WORDX3FLD  = "'
#    Wrseq WLINE2 + WLINEEND

          When 2,3,4,5,6                       # Num
             If !find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3") 
&                  or !INTTYP=1        # Gestion particuliÃĻre uniquement sur accÃĻs table
    Wrseq WLINE + '   # Num'
                WLINE2 = '     WORDX3FLD  = "' +[WRK]CODX3(WDIAIND)
             Else
    Wrseq WLINE + '   # Type ATX'
                WLNKATXNB +=1
                WLINE2 = '     WORDX3FLD = "[ATX' +num$(WLNKATXNB)+ ']TEXTE'
             Endif
    Wrseq WLINE2 + WLINEEND

           When 8                                     # Date
    Wrseq WLINE + '   # Type Date'
                WLINE2 = '     WORDX3FLD  = "' +[WRK]CODX3(WDIAIND)
    Wrseq WLINE2 + WLINEEND

           When 9                                     # Blob
    Wrseq WLINE + '   # Blob'
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Blob] - Sort not allowed" -TRT_TIT) From AWEB'
    Wrseq '            GW_STAT=1 : Return'
                WLINE2 = '    WORDX3FLD  = "'
    Wrseq WLINE2 + WLINEEND

           When 10                                     # Clob
    Wrseq WLINE + '   # Type Clob'
    Wrseq '            Call ADDMESSERR("'+[ASP]PARAM+': Type [Clob] - Sort not allowed"-TRT_TIT) From AWEB'
    Wrseq '            GW_STAT=1 : Return'
                WLINE2 = '     WORDX3FLD  = "'
    Wrseq WLINE2 + WLINEEND
              
           When Default
                Call ECR_TRACE([ASP]PARAM-"Type non gÃĐrÃĐ"-num$([WRK]CODTYPTYP(WDIAIND)),1) From GESECRAN
         Endcase
     Endif
  Endif
  WFLGUSERDATA += ([ASP]PARAM="AXORDTYP")     # on entre dans la partie utilisateur
Next

#
Wrseq 'When Default'
Wrseq '        Call ADDMESSERR("Compute Order: Unknown variable:"-AXORDCOD(WNBPAR)-TRT_TIT) From AWEB'
Wrseq '        GW_STAT=1 '
Wrseq 'Endcase'
Wrseq 'Return'
Wrseq ''                

Return   ## - - - Ecriture filtre sous-prgrm 

#   Add data on a When clause  
#     Input :   WLINEADD   Variable temporaire Ã  ajouter sur la ligne
#     Output:   WLINE
#         WFLGLINE = 0:pas de ligne ecrite;  1:buffer ÃĐcrit; 2: buffer non ÃĐcrit
$WHENLINE
If WFLGLINE=0 : WLINE   ="When   "     : WFLGLINE=2 
Elsif WFLGLINE=1 : WLINE="&     ,"     : WFLGLINE=2 
Else : WLINE+="," : Endif
WLINE+=WLINEADD
If len(WLINE)>80 
    Wrseq WLINE 
    WLINE="" : WFLGLINE=1
Endif
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Activation debug java
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$DBGPAR
Wrseq '# Remote Debug parameters'
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '$SETDEBUGJON'
Wrseq 'If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif'
Wrseq '[V]GIAADXCTX = "X3_CS:NA1:"                # entÃŠte "X3_CS:session client X3" + "NA1:session primaire"'
Wrseq 'Call SET_DEBUG_ON(1) From DEBUGGERJ        # 0=debugger socket "off"'
Wrseq 'Call SET_PORT("1789") From DEBUGGERJ       # Port*'
Wrseq '#Call SET_HOST("172.16.9.153") From DEBUGGERJ  # @ip du pc'
Wrseq 'Call SET_HOST("Boris.ech.adx") From DEBUGGERJ  '
Wrseq 'Return'
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Ecriture RÃĐsultat ss-prgrm
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$SPRGRES
Wrseq '# Results'
Wrseq '# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #'
Wrseq '$CL_RES'
Wrseq 'Local Integer WNBREAD  : WNBREAD=0         # Request: Number of read records'
Wrseq 'Local Integer WSTART   : WSTART=1          # Request: Rank of first row to be returned (standard mode)'
Wrseq 'Local Integer WMAXREC                      # Request: Maximun number of records to be returned'
Wrseq 'Local Integer WTOTALCOUNT                  # Request: Total number of rows returned by request'
Wrseq 'Local Integer WACCTYP                      # Type of access: 0-standard  1-random'
Wrseq ''
Wrseq 'Local Integer WROWPOS                      # Current row in returned data tables'
Wrseq ''
Wrseq 'Local Integer WHASNEXT : WHASNEXT=0        # Output: Has next row (0: no more)'
Wrseq 'Local Integer WNBREC   : WNBREC=0          # Output: Number of returned records'
Wrseq 'Local Integer WRNDNB                       # Output: Number of records in random access (=0: standard access mode)      '
Wrseq ''
Wrseq ''
Wrseq '# Type of access '
Wrseq 'WACCTYP=0    # standard'
Wrseq 'WI = find ("$RANDOM", AXPARCOD) '
Wrseq 'If WI'
Wrseq '    Onerrgo ERR_PARNUM'
Wrseq '    WJ = val(AXPARVAL(WI))'
Wrseq '    Onerrgo : If GW_STAT : Return : Endif'
Wrseq '    If WJ=1  : WACCTYP=1 : Endif  # random access'
Wrseq 'Endif'
Wrseq ''
Wrseq '# Output:  TotalCount'
Wrseq 'WTOTALCOUNT = rowcount([' +[WRK]OBJABR+ '_])'
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Total Count of request ($TOTAL_COUNT): " +num$(WTOTALCOUNT ) ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq 'WI = find ("$TOTAL_COUNT", AXPARCOD) '
Wrseq 'If WI'
Wrseq '    AXPARVAL(WI)=num$(WTOTALCOUNT)'
Wrseq 'Endif'
Wrseq ''
Wrseq '# Request infos'
Wrseq 'Case WACCTYP'
Wrseq 'When 0    # Standard '
Wrseq '    If GTRACE<>""'
Wrseq '        Call ECR_TRACE("Standard access" ,0) From GESECRAN'
Wrseq '    Endif'
Wrseq ''
Wrseq '    # Input:  Rank of first row'
Wrseq '    WI = find ("$REC_STARTAT", AXPARCOD)'
Wrseq '    If WI'
Wrseq '     Onerrgo ERR_PARNUM'
Wrseq '     WSTART = val(AXPARVAL(WI))'
Wrseq '     Onerrgo : If GW_STAT : Return : Endif'
Wrseq '    Endif'
Wrseq '    If WSTART < 1'
Wrseq '     Call ADDMESSERR("Parameter $REC_STARTAT - Incorrect value:" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq '     GW_STAT=1 : return '
Wrseq '    Endif'
Wrseq '    If GTRACE<>""'
Wrseq '        Call ECR_TRACE("Input - Start position($REC_STARTAT): " +num$(WSTART ) ,0) From GESECRAN'
Wrseq '    Endif'
Wrseq '    '
Wrseq '    # Input:  Maximun number of records'
Wrseq '    WMAXREC = ' +num$([M:WRK]RESMAX)+ ' # default value'
Wrseq '    WI = find ("$REC_MAX", AXPARCOD) '
Wrseq '    If WI'
Wrseq '     Onerrgo ERR_PARNUM'
Wrseq '     WMAXREC = val(AXPARVAL(WI))'
Wrseq '     Onerrgo : If GW_STAT : Return : Endif'
Wrseq '    Endif'
Wrseq '    If WMAXREC <1 or WMAXREC > '+num$([M:WRK]RESMAX) 
# Wrseq '     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to '-num$(RESMAX)-'):" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq '     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to '-num$([M:WRK]RESMAX)-'):" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq '     GW_STAT=1 : return '
Wrseq '    Endif'
Wrseq '    If GTRACE<>""'
Wrseq '        Call ECR_TRACE("Input - Maximun number of records($REC_MAX): " +num$(WMAXREC) ,0) From GESECRAN'
Wrseq '    Endif'
Wrseq ''
Wrseq 'When 1    # Random'
Wrseq '    If GTRACE<>""'
Wrseq '        Call ECR_TRACE("Random access" ,0) From GESECRAN'
Wrseq '    Endif'
Wrseq ''
Wrseq '    # Input:  Maximun number of records'
Wrseq '    WMAXREC = 1    # default value'
Wrseq '    WI = find ("$REC_MAX", AXPARCOD) '
Wrseq '    If WI'
Wrseq '     Onerrgo ERR_PARNUM'
Wrseq '     WMAXREC = val(AXPARVAL(WI))'
Wrseq '     Onerrgo : If GW_STAT : Return : Endif'
Wrseq '    Endif'
Wrseq '    If WMAXREC <1 or WMAXREC > '+num$([M:WRK]RESMAX) 
# Wrseq '     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to '-num$(RESMAX)-'):" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq '     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to '-num$([M:WRK]RESMAX)-'):" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq '     GW_STAT=1 : return '
Wrseq '    Endif'
Wrseq '    If GTRACE<>""'
Wrseq '        Call ECR_TRACE("Input - Maximun number of records($REC_MAX): " +num$(WMAXREC) ,0) From GESECRAN'
Wrseq '    Endif'
Wrseq ''
Wrseq '    # '
Wrseq '    If WTOTALCOUNT > WMAXREC'
Wrseq '        WRNDNB = WMAXREC'
Wrseq '    Else'
Wrseq '        WRNDNB = WTOTALCOUNT '
Wrseq '    Endif'
Wrseq '    Local Integer  RNDTABPOS(1..WRNDNB)'
Wrseq '    WK=1'
Wrseq '    Repeat'
Wrseq '        WRND=int(rnd(WTOTALCOUNT))+1 '
Wrseq '        If !find(WRND, RNDTABPOS)'
Wrseq '            RNDTABPOS(WK)=WRND'
Wrseq '            WK+=1'
Wrseq '        Endif'
Wrseq '    Until WK>WRNDNB '
Wrseq ''
Wrseq 'When Default'
Wrseq '    Call ADDMESSERR("Access type is incorrect:" -num$(WACCTYP)-TRT_TIT ) From AWEB'
Wrseq '    GW_STAT=1 : return '
Wrseq 'Endcase'
Wrseq ''
Wrseq '# Results'
Wrseq 'Case WACCTYP'
Wrseq 'When 0    # Standard '
Wrseq '  If WTOTALCOUNT >= WSTART  '
Wrseq '    For [' +[WRK]OBJABR+ '_]'
Wrseq '      WNBREAD+=1'
Wrseq '      # Job finished'
Wrseq '      If WNBREC >= WMAXREC  : WHASNEXT=1 : Break : Endif'
Wrseq '      # Row selection '
Wrseq '      If WSTART <= WNBREAD  '
Wrseq '        WNBREC+=1'
Wrseq '        WROWPOS=WNBREC : Gosub LOADLINE'
Wrseq '      Endif'
Wrseq '    Next'
Wrseq '  Endif'
Wrseq 'When 1    # Random'
Wrseq '    For [' +[WRK]OBJABR+ '_]'
Wrseq '      WNBREAD+=1'
Wrseq '      # Row selection'
Wrseq '      WROWPOS = find(WNBREAD, RNDTABPOS) '
Wrseq '      If  WROWPOS '
Wrseq '        WNBREC+=1'
Wrseq '        Gosub LOADLINE'
Wrseq '      Endif'
Wrseq '      # Job finished'
Wrseq '      If WNBREC >= WRNDNB : Break : Endif'
Wrseq '    Next'
Wrseq 'Endcase'
Wrseq ''
Wrseq '# Number of read records'
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Request - Number of read records: " +num$(WNBREAD) ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq ''
Wrseq '# Output HasNext'
Wrseq 'If WACCTYP=0 and GTRACE<>""'
Wrseq '    Call ECR_TRACE("Request - Has next($HAS_NEXT): " +num$(WHASNEXT) ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq 'WI = find ("$HAS_NEXT", AXPARCOD)'
Wrseq 'If WI : AXPARVAL(WI)= num$(WHASNEXT) : Endif'
Wrseq ''
Wrseq '# Output: Number of returned records'
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Output - Number of returned records ($RET_COUNT): " +num$(WNBREC) ,0) From GESECRAN'
Wrseq 'Endif'
Wrseq 'WI = find ("$RET_COUNT", AXPARCOD) '
Wrseq 'If WI : AXPARVAL(WI)= num$(WNBREC) : Endif'
Wrseq 'Return'
Wrseq ''

# Manage a line
Raz WLNKATXNB, WLNKAXXNB
Wrseq '# Returned data for a row'
Wrseq '# <XT_SPE>SpÃĐcifier les arguments renvoyÃĐes</XT_SPE>'
Wrseq '$LOADLINE'

For WDIAIND=0 To [WRK]NBZONE-1
  If [M:WRK]CODXTD(WDIAIND)="" : Break : Endif
  #If [WRK]WSEL(WDIAIND)=2 
    If [WRK]CODTYP(WDIAIND)="ATX"   
&                  and INTTYP=1       # ATEXTE: Langue+Numero - Gestion particuliÃĻre uniquement sur accÃĻs table
        WLNKATXNB+=1
        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [ATX' +num$(WLNKATXNB)+ ']TEXTE'
    Elsif find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3")
&                  and INTTYP=1        # Gestion particuliÃĻre uniquement sur accÃĻs table
        WLNKAXXNB+=1
        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [AXX' +num$(WLNKAXXNB)+ ']TEXTE'
#    Elsif [WRK]CODTYPTYP(WDIAIND)=1    # Menu local    <M001>
#      If [M:WRK]CODDIM(WDIAIND)=1
#        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND) 
#        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'_L(WROWPOS) = mess([F]' +[WRK]CODX3(WDIAIND)+ ',' 
#&                +num$([WRK]CODNOLIB(WDIAIND))+ ',1)'
#      Else
#        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND)+ '(' + num$([WRK]CODX3IND(WDIAIND)) + ')'
#        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'_L(WROWPOS) = mess([F]' +[WRK]CODX3(WDIAIND)+ '(' + num$([WRK]CODX3IND(WDIAIND)) 
#&                + '),' +num$([WRK]CODNOLIB(WDIAIND))+ ',1)'
#      Endif
    Elsif find([WRK]CODTYPTYP(WDIAIND),9,10)    # Blob (AccÃĻs image), Clob (AccÃĻs P.J.)
      If [M:WRK]CODDIM(WDIAIND)=1
        Wrseq '      If ' +[WRK]CODX3(WDIAIND)+ '_Y : ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND)+ ' : Endif' 
      Else
        Wrseq '      If ' +[WRK]CODX3(WDIAIND)+ '_Y : ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND)+ '(' +  num$([WRK]CODX3IND(WDIAIND)) + ') : Endif'
      Endif
    Else
      If [M:WRK]CODDIM(WDIAIND)=1
        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND) 
      Else
        Wrseq '      ' +[WRK]CODXTD(WDIAIND) +'(WROWPOS) = [F]' +[WRK]CODX3(WDIAIND)+ '(' + num$([WRK]CODX3IND(WDIAIND)) + ')'
      Endif
    Endif
  #Endif
Next

Wrseq 'Return'
Wrseq ''
Wrseq '$ERR_PARNUM'
Wrseq ' Call ADDMESSERR("Parameter" -AXPARCOD(WI)- "Value not numeric:" -AXPARVAL(WI)-TRT_TIT ) From AWEB'
Wrseq 'GW_STAT=1'    # Utile en mode test interactif car AddMessErr ne positionne pas le flag dans ce cas
Wrseq 'Resume'

Return    ## - - - Ecriture RÃĐsultat ss-prgrm


# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Ecriture partie Test
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$TSTCALL
Wrseq "# Appel pour test   "   
Wrseq "#########################################################################" 
Wrseq '$TSTCALL' 
Wrseq '# Maximum memory'
Wrseq '# maxmem=100000'
Wrseq '# Infbox ("maxmem"-num$(maxmem))'
Wrseq ''
Wrseq '# <XT_SPE>Set arguments of the test</XT_SPE>'
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    WLINE='Local '
    Case [ASP]TYPPAR    # Menu 33
    When 1   
        WLINE+='Char    '
    When 2   
        WLINE+='Integer '
    When 3   
        WLINE+='Decimal '
    When 4
        WLINE+='Date    ' 
    When 6
        WLINE+='ClbFile ' 
    When 7
        WLINE+='Blbfile ' 
    Endcase
    WLINE+= [ASP]PARAM
    If [ASP]LONG <> 0 : WLINE+="("+num$([ASP]LONG)+")" : Endif
    If [ASP]DIME > 1  : WLINE+="(1.."+num$([ASP]DIME)+")" : Endif
    Wrseq WLINE
Next
Wrseq ''
Wrseq "# Set values of the test  "   
Wrseq "####  -->"   
WFLGUSERDATA=0 
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    If WFLGUSERDATA : Break : Endif
    WLINE="# "+[ASP]PARAM
    If [ASP]PARAM="AXPARCOD"
        Wrseq  '# AXPARCOD(1)="$RANDOM" '
        Wrseq  '# AXPARCOD(1)="$REC_STARTAT" : AXPARCOD(2)="$REC_MAX"'
        Wrseq  '# AXPARCOD(3)="$TOTAL_COUNT" : AXPARCOD(4)="$HAS_NEXT" : AXPARCOD(5)="$RET_COUNT"'
        Wrseq  '# AXPARCOD(6)="$X3TRACE"'
        Wrseq  '# AXPARCOD(1)="$OPTIMISE" '
    Endif
    If [ASP]PARAM="AXWHROPE"
        Wrseq  '# AXWHROPE -  2:= 3:<> 4:> 5:>= 6:< 7:<= 8:xx* 9:*xx* 10:<>*xx*'
    Endif
    If [ASP]PARAM="AXORDTYP"
        Wrseq  '# AXORDTYP -  1: asc 2:=desc'
    Endif
    If [ASP]DIME > 1 
        For WJ=1 To 6    # maxi 6 pour tests
            WLINE2 = WLINE+"("+num$(WJ)+")"
            WLINE2+= space$(20)
            If find([ASP]PARAM,"AXPARCOD","AXPARVAL","AXWHRCOD","AXWHRCODVAL","AXORDCOD")
                Wrseq  left$(WLINE2,20)+'= "?"' 
            Else
                Wrseq  left$(WLINE2,20)+"= ?" 
            Endif
        Next
    Else
        WLINE+= space$(20)
            If find([ASP]PARAM,"AXPARCOD","AXPARVAL","AXWHRCOD","AXWHRCODVAL","AXORDCOD")
                Wrseq  left$(WLINE2,20)+'= "?"' 
            Else
                Wrseq  left$(WLINE2,20)+"= ?" 
            Endif
    Endif
    WFLGUSERDATA += ([ASP]PARAM="AXORDTYP")     # on entre dans la partie utilisateur
Next
Wrseq "####  <--"   

Wrseq '# Trace '
Wrseq 'Call OUVRE_TRACE("Test: '+[L]WSPRG+'/' +[WRK]SUBPRG+ '") From LECFIC'
Wrseq ''
Wrseq '# <XT_SPE>Modify arguments</XT_SPE>'
WLINE="Call " +[WRK]SUBPRG+ "(  "
WI =0
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    If WI : WLINE+="," : Endif
    WLINE+=[ASP]PARAM
    If len(WLINE)>80 or [ASP]PARAM="AXORDTYP" 
        Wrseq WLINE 
        WLINE="&                "
    Endif
    WI = 1
Next
WLINE+=')'
Wrseq WLINE

# Dump des valeurs 
Local Integer DUMPMAX : DUMPMAX=6  # maxi pour tests
Wrseq  'Call ECR_TRACE("### Dump of values - Indice max: ' +num$(DUMPMAX)+ '" ,0) From GESECRAN'
Wrseq  'Call ECR_TRACE("###   Technical section",0) from GESECRAN'

For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    WLINE='Call ECR_TRACE("'+[ASP]PARAM
    Case [ASP]TYPPAR
    When 6 # Clob
     If [ASP]DIME > 1 
        For WJ=1 To DUMPMAX   
            Wrseq 'WSTR = left$(' + [ASP]PARAM +'('+num$(WJ)+'),30)+" <-- 30 first characters"'
            WLINE2 = WLINE+'('+num$(WJ)+')'
            WLINE2+= space$(40)
            Wrseq   left$(WLINE2,40)+'=" + WSTR,0) From GESECRAN'
        Next
     Else
        WLINE+= space$(20)
        Wrseq 'WSTR = left$(' + [ASP]PARAM +'),30)+" <-- 30 first characters"'
        Wrseq  left$(WLINE,20)+'=" + WSTR,0) From GESECRAN'
     Endif
    When 7 # Blob
     If [ASP]DIME > 1 
        For WJ=1 To DUMPMAX   
          WLINE+= space$(20)
          Wrseq  left$(WLINE,20)+'= Type blob - len: " +num$(len(' + [ASP]PARAM +'('+ num$(WJ) + '))),0) From GESECRAN'
        Next
     Endif
    When Default
      If [ASP]DIME > 1 
        For WJ=1 To DUMPMAX   
            WLINE2 = WLINE+'('+num$(WJ)+')'
            WLINE2+= space$(40)
            Wrseq  left$(WLINE2,40)+'="+ num$('+[ASP]PARAM+'('+num$(WJ)+')) ,0) From GESECRAN'
        Next
      Else
        WLINE+= space$(20)
        Wrseq  left$(WLINE,20)+'="+num$('+[ASP]PARAM+',0) From GESECRAN'
      Endif
    Endcase
    If [ASP]PARAM="AXORDTYP" 
      Wrseq  'Call ECR_TRACE("###   User section",0) from GESECRAN'
      Wrseq "# <XT_SPE>SpÃĐcifier les arguments Ã  visualiser</XT_SPE>"
    Endif
Next


Wrseq 'Call FERME_TRACE From LECFIC'
Wrseq 'Call LEC_TRACE   From LECFIC'
Wrseq 'End'
Wrseq ''
#
Return   ########### Fin ÃĐcriture partie Test ###########



#------------------------------------------------------------#
#  Partie spÃĐcifique AccÃĻs table
#------------------------------------------------------------#


# Alimentation mask WRK
#    Le mask contient uniquement les champs utilisÃĐs
#----------------------------------------------------
$DIALOAD_TAB
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Call LECTURE("ATB",[L]OBJCOD,"") From CONTOBJ
[M:WRK]OBJABR =[ATB]ABRFIC

# Liste des champs
For [F:ATZ]CODZONE Where CODFIC=[M:WRK]OBJCOD
   If [F:ATZ]DIME=1
     Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:ATZ]CODZONE
     If !fstat
         [M:WRK]CODXTD([M:WRK]NBZONE)=[F:ATZ]CODZONE
         [M:WRK]CODX3IND([M:WRK]NBZONE)=1  
         Gosub LINESPG_TAB
         If [M:WRK]NBZONE = MAXFIL : Break : Endif
     Endif
   Elsif [F:ATZ]DIME=0   # Voir nb dans le code activitÃĐ  E46683
     Call LECTURE("ACV",[F:ATZ]CODACT ,"") From CONTOBJ
     If !fstat
         For WI=0 To [F:ACV]DIME-1
           Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:ATZ]CODZONE+num$(WI)
           If !fstat
             [M:WRK]CODXTD([M:WRK]NBZONE)=[F:ATZ]CODZONE+num$(WI)    
             [M:WRK]CODX3IND([M:WRK]NBZONE)=WI
             [F:ATZ]DIME = [F:ACV]DIME    # Surcharge
             Gosub LINESPG_TAB
             If [M:WRK]NBZONE = MAXFIL : Break 2 : Endif
           Endif
         Next
     Endif
   Else
     For WI=0 To [F:ATZ]DIME-1
       Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:ATZ]CODZONE+num$(WI)
       If !fstat
         [M:WRK]CODXTD([M:WRK]NBZONE)=[F:ATZ]CODZONE+num$(WI)    
         [M:WRK]CODX3IND([M:WRK]NBZONE)=WI   
         Gosub LINESPG_TAB
         If [M:WRK]NBZONE = MAXFIL : Break 2 : Endif
       Endif
     Next
   Endif
Next
Filter [F:ATZ] 
Return

#--
$LINESPG_TAB
 [M:WRK]CODX3([M:WRK]NBZONE)        =[F:ATZ]CODZONE
 [M:WRK]CODDIM([M:WRK]NBZONE)       =[F:ATZ]DIME
 [M:WRK]NOCOURT([M:WRK]NBZONE)      =[F:ATZ]NOCOURT
 Call TEXTE([F:ATZ]NOCOURT,[M:WRK]INTITCOURT([M:WRK]NBZONE)) From OBJDIV
 [M:WRK]CODTYP([M:WRK]NBZONE)       =[F:ATZ]CODTYP
 Call LECTURE("ATY",[F:ATZ]CODTYP,"") From CONTOBJ
 [M:WRK]CODTYPTYP([M:WRK]NBZONE)    =[F:ATY]TYPTYP
 If [F:ATZ]LONG<>0
    [M:WRK]CODLNG([M:WRK]NBZONE)    =[F:ATZ]LONG
 Else
    [M:WRK]CODLNG([M:WRK]NBZONE)    =[F:ATY]LNGTYP
 Endif
 If [F:ATY]TYPTYP=1     # Menu local
    [M:WRK]CODNOLIB([M:WRK]NBZONE)  =[F:ATZ]NOLIB
 Endif
# [WRK]WSEL([M:WRK]NBZONE)           = 2
 [M:WRK]NBZONE+=1
Return

# Clause link - AccÃĻs table: automatisation accÃĻs table AXX et ATX
#-----------------------------------
$PRGLNK_TAB
WLNKFLG = 0 : WLNKATXNB = 0 : WLNKAXXNB = 0
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Main table: ' +[WRK]OBJCOD+ '",0) From GESECRAN'
Wrseq 'Endif'
Wrseq '# <XT_SPE>Set access to tables</XT_SPE>'

# Recherche table ATEXTRA et ATEXTE
For WDIAIND=0 To [WRK]NBZONE-1
  If [M:WRK]CODXTD(WDIAIND)="" : Break : Endif
  #If [WRK]WSEL(WDIAIND)=2 
    If [WRK]CODTYP(WDIAIND)="ATX"   # ATEXTE: Langue+Numero
        WLNKFLG += 1  : WLNKATXNB+=1
        Wrseq 'If !clalev([ATX' +num$(WLNKATXNB)+ ']) : Local File ATEXTE ' 
&           +           ' [ATX' +num$(WLNKATXNB)+ '] : Endif'
        WLNKTAB(WLNKFLG) = '&    [ATX' +num$(WLNKATXNB)+ ']NUMERO=GLANGUE;[F:' +[WRK]OBJABR+']'+[WRK]CODX3(WDIAIND)

    Elsif find([WRK]CODTYP(WDIAIND),"AXX","AX1","AX2","AX3")
        WLNKFLG += 1  : WLNKAXXNB+=1
        # Param liÃĐs
        For [AMP]CODPAR Where TYPAFF=2 & CODAFF=[M:WRK]OBJCOD & CODZON=[M:WRK]CODXTD(WDIAIND)
            Case [AMP]CODPAR 
            When "CLECUR1" 
                AXXCL1(WLNKAXXNB)=[AMP]VALPAR
                If !instr(1,AXXCL1(WLNKAXXNB),'"')
                    AXXCL1(WLNKAXXNB)='[F:' +[WRK]OBJABR+']'+AXXCL1(WLNKAXXNB)
                Endif
            When "CLECUR2" 
                AXXCL2(WLNKAXXNB)=[AMP]VALPAR
                If !instr(1,AXXCL2(WLNKAXXNB),'"')
                    AXXCL2(WLNKAXXNB)='[F:' +[WRK]OBJABR+']'+AXXCL2(WLNKAXXNB)
                Endif
            When "TABLE1"  : AXXTAB(WLNKAXXNB)=[AMP]VALPAR
            When "ZONE"    : AXXZON(WLNKAXXNB)=[AMP]VALPAR
            Endcase
        Next
        Wrseq 'If !clalev([AXX' +num$(WLNKAXXNB)+ ']) : Local File ATEXTRA ' 
&             +         ' [AXX' +num$(WLNKAXXNB)+ '] : Endif'
        WLNKTAB(WLNKFLG) = '&    [AXX' +num$(WLNKAXXNB)+ ']AXX0=' +AXXTAB(WLNKAXXNB)+ ';' +AXXZON(WLNKAXXNB)+ 
&            ';GLANGUE;'+AXXCL1(WLNKAXXNB)+';' +AXXCL2(WLNKAXXNB)

    Endif
  #Endif
Next
If WLNKFLG=0
    Wrseq 'If !clalev([' +[WRK]OBJABR+ '_]) : Local File ' +[WRK]OBJCOD+ ' [' +[WRK]OBJABR+ '_] : Endif'
Else     
    Wrseq 'If !clalev([' +[WRK]OBJABR+ ']) : Local File ' +[WRK]OBJCOD+ ' [' +[WRK]OBJABR+ '] : Endif'
    Wrseq 'Link [' +[WRK]OBJABR+ '] With'
    For WI=1 To WLNKFLG
        WLINE =  WLNKTAB(WI) : If WI<>WLNKFLG : WLINE+=',' : ENDIf
        Wrseq WLINE
    Next
    Wrseq '&    As [' +[WRK]OBJABR+ '_]'
Endif  

Wrseq 'Default File ['+[WRK]OBJABR+ '_]'
Wrseq 'Return'
Wrseq ''
Return


#------------------------------------------------------------#
#  Partie spÃĐcifique AccÃĻs vue
#------------------------------------------------------------#

# Alimentation mask WRK
#-----------------------------------
$DIALOAD_VUE
If clalev([F:AVW])=0 : Local File AVIEW  [AVW] : Endif
If clalev([F:AVD])=0 : Local File AVIEWD [AVD] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
Call LECTURE("AVW",[L]OBJCOD ,"") From CONTOBJ
[M:WRK]OBJABR    =[AVW]ABRVUE
[M:WRK]SUBPRG    ="ACCVIEW"
# Liste des champs possibles
For [F:AVD]AVD1 Where CODVUE=[M:WRK]OBJCOD
    If [F:AVD]DIME=1
      Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:AVD]FLDVUE
      If !fstat
           [M:WRK]CODXTD([M:WRK]NBZONE)=[F:AVD]FLDVUE
           [M:WRK]CODX3IND([M:WRK]NBZONE)=1  
           Gosub LOADLINE_VUE
           If [M:WRK]NBZONE = MAXFIL : Break : Endif
      Endif
   Elsif [F:AVD]DIME=0  # Voir nb dans le code activitÃĐ  E46683
        Call LECTURE("ACV",[F:AVD]FLDACT ,"") From CONTOBJ
        If !fstat
         For WI=0 To [F:ACV]DIME-1
            Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:AVD]FLDVUE+num$(WI)
            If !fstat
               [M:WRK]CODXTD([M:WRK]NBZONE)=[F:AVD]FLDVUE+num$(WI)    
               [M:WRK]CODX3IND([M:WRK]NBZONE)=WI   
               [F:AVD]DIME = [F:ACV]DIME    # Surcharge
               Gosub LOADLINE_VUE
               If [M:WRK]NBZONE = MAXFIL : Break 2 : Endif
            Endif
         Next
        Endif
    Else
      For WI=0 To [F:AVD]DIME-1
        Read [F:ASP]ASP1 = [F:ASU]PRG;[F:ASU]SUBPRG;[F:AVD]FLDVUE+num$(WI)
        If !fstat
           [M:WRK]CODXTD([M:WRK]NBZONE)=[F:AVD]FLDVUE+num$(WI)    
           [M:WRK]CODX3IND([M:WRK]NBZONE)=WI   
           Gosub LOADLINE_VUE
           If [M:WRK]NBZONE = MAXFIL : Break 2 : Endif
        Endif
      Next
    Endif
Next
Filter [F:AVD] 
Return

$LOADLINE_VUE
 [M:WRK]CODX3([M:WRK]NBZONE)        =[F:AVD]FLDVUE
 [M:WRK]CODDIM([M:WRK]NBZONE)       =[F:AVD]DIME
 [M:WRK]NOCOURT([M:WRK]NBZONE)      =[F:AVD]FLDINT
 Call TEXTE([F:AVD]FLDINT,[M:WRK]INTITCOURT([M:WRK]NBZONE)) From OBJDIV
 [M:WRK]CODTYP([M:WRK]NBZONE)       =[F:AVD]CODTYP
 Call LECTURE("ATY",[F:AVD]CODTYP,"") From CONTOBJ
 [M:WRK]CODTYPTYP([M:WRK]NBZONE)    =[F:ATY]TYPTYP
 If [F:AVD]LNG<>0
    [M:WRK]CODLNG([M:WRK]NBZONE)    =[F:AVD]LNG
 Else
    [M:WRK]CODLNG([M:WRK]NBZONE)    =[F:ATY]LNGTYP
 Endif
 If [F:ATY]TYPTYP=1     # Menu local
    [M:WRK]CODNOLIB([M:WRK]NBZONE)       =[F:AVD]NOLIB
 Endif
 [M:WRK]NBZONE+=1
Return

# Clause link - AccÃĻs vue
#-----------------------------------
$PRGLNK_VUE
WLNKFLG = 0 : WLNKATXNB = 0 : WLNKAXXNB = 0
Wrseq 'If GTRACE<>""'
Wrseq '    Call ECR_TRACE("Main view: ' +[WRK]OBJCOD+ '",0) From GESECRAN'
Wrseq 'Endif'
Wrseq '# <XT_SPE>Set access to tables</XT_SPE>'

Wrseq 'If !clalev([' +[WRK]OBJABR+ '_]) : Local File ' +[WRK]OBJCOD+ ' [' +[WRK]OBJABR+ '_] : Endif'

Wrseq 'Default File ['+[WRK]OBJABR+ '_]'
Wrseq 'Return'
Wrseq ''
Return
