#<AdxTL>@(#)0.0.0.0 $Revision$
# Class EMPCTRSTG


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$EMPLOID_UPDATE
  #Instantiate EMPCTRSTG
  Local Instance  I_EMPCTRSTG  Using C_EMPCTRSTG
  If (I_EMPCTRSTG  <> null) : FreeGroup I_EMPCTRSTG  : Endif
  I_EMPCTRSTG  = NewInstance C_EMPCTRSTG AllocGroup null
  READSTATUS = fmet I_EMPCTRSTG.AREAD(I_EMPCTRINS.REFNUM,I_EMPCTRINS.CTRNUM)
  If READSTATUS = [V]CST_AOK
    #Record exist - Update
    Gosub UPDATE_FIELD
    #Setting write status to update status
    [L]WRITESTATUS = [L]UPDSTATUS
  Else
    [L]INITEMPCTR   = fmet I_EMPCTRSTG.AINIT()
    If [L]INITEMPCTR  = [V]CST_AOK
      Gosub DUPLICATE
    Endif
  Endif
Return

$UPDATE_FIELD
Local Integer J,K,Z,Y,RETVAL
Local Char SYSPROP(GLONAVA)(1..)

[L]ARET_VALUE = [V]CST_AOK
RETVAL = func PIHRMFAIR_FUNCTIONS.SET_SYPROP(SYSPROP)

For K = 1 To I_EMPLOCTRSTG_UPD.ObjectNbs
  If find(I_EMPLOCTRSTG_UPD.ObjectVar(K),SYSPROP)=0
    If evalue("DIM(I_EMPCTRSTG."+I_EMPLOCTRSTG_UPD.ObjectVar(K)+")")>0
      Assign "I_EMPCTRSTG."+I_EMPLOCTRSTG_UPD.ObjectVar(K) With evalue("(I_EMPLOCTRSTG_UPD."+I_EMPLOCTRSTG_UPD.ObjectVar(K)+")")
    Endif
  Endif
Next K

#Write
[L]UPDSTATUS = fmet I_EMPCTRSTG.AUPDATE()

Return

$DUPLICATE
#Open the linked table to the main(this) class
Local File EMPCTR [ECT2]

#Fill/Set the file instance to the parameter class
Raz [F:ECT2]
SetInstance [F:ECT2] With I_EMPLOCTRSTG_UPD

#Now we can fill the main(this) class from the table
SetInstance I_EMPCTRSTG With [F:ECT2]

#Write
[L]WRITESTATUS = fmet I_EMPCTRSTG.AINSERT()

LogicClose File        [ECT2]
Return

