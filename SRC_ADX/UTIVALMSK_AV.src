#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Revalidation des écrans utilisant un type de données AV
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update mask with AV type") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub VALMSK
End

#-------------------#
$VALMSK

Local Integer OK

Local Char ODOSSIER(GLONADS)

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>DOSSIER
 ODOSSIER = [F:ADS]DOSSIER
 Read [ADS]DOSSIER=DOSSIER
Endif

Local File =DOSSIER+".AMSKZON" [AM__]

Filter [AM__] Where CODTYP="AV"

For [AM__]CODE(1)
 Call VALID([F:AM__]CODMSK,[F:ADS]DOSSIER,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
Next AM__

Close Local File

If clalev([F:ADS])>0 & ODOSSIER<>[F:ADS]DOSSIER
 Read [ADS]DOSSIER=ODOSSIER
Endif
Return
