#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
## Xtend: Gestion Message 
## Actions
#  Version 0001
#
######################################################################################
### Actions
##     Code          Identifiant
##     AYMCATSEL     CATSEL     Sélection catégorie
######################################################################################
#------------------------------------------------------------#
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "SEL_LISTE"        : Gosub SEL_LISTE
Endcase
Return

$SEL_LISTE
Case LISTE
When "CATSEL"
     Gosub SEL_CAT
Endcase
Return


#    AYMCATSEL     Sélection categorie 
######################################################################################
# VALEUR        Adresse       Categorie     
# PARAM    1    Valeur        Site Xtend
#
$SEL_CAT
#---------------------------------------------------------------#
Local Integer WCATLON : WCATLON=20
Local Char FCYWRK(GLONAYG), CATCOD(WCATLON)
Local Integer WI, WFLG
If clalev([F:AYM])=0 : Local File AYTMES [AYM] : Endif

[L]CATCOD    = VALEUR     # Categorie
[L]FCYWRK    = PARAM(1)   # Site 

Filter [AYM] Where FCYCOD=[L]FCYWRK
WI = max(rowcount([AYM]),1)
Local Char     TEX(WCATLON)(1..WI) , TEXTE(WCATLON)(1..WI,1..1)
TIT(0)=mess(124,7900,1)
TIT(1)=""

For [AYM]
  WFLG=!find([AYM]CAT, TEX)
  If WFLG    # eligible
     NBTEX+=1
     TEX(NBTEX)=[AYM]CAT
     TEXTE(NBTEX,1)=[AYM]CAT
  Endif
Next
Filter [AYM]

If NBTEX=0
    GERR=2 : GMESSAGE =mess(99,100,1) : mkstat=2
Endif
Return

