#<AdxTL>@(#)6.0.0.0 $Revision$ Back to back orders modifications
###########################################################################################################
# UTIVEN18 : Modification des fausses contremarques en vraies fausses contremarques      Module Ventes    #
###########################################################################################################
# GH 09/07/11                                                                            Bug 101361       #
###########################################################################################################

Call MAJ_UTIVEN18
End

##################################
Subprog MAJ_UTIVEN18
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIVEN18 : Back to Back orders modifications") From LECFIC
Call EXE_UTIVEN18(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIVEN18(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","SORDERQ","fde",DOSSIER),0) <= 0
&  | filinfo(filpath("FIL","ORDERS","fde",DOSSIER),0) <= 0
&  | filinfo(filpath("FIL","MTOLINK","fde",DOSSIER),0) <= 0
  End
Endif

Call ECR_TRACE("UTIVEN18 : Process Start on : "+DOSSIER,0) From GESECRAN

Local File =[L]DOSSIER+".SORDERQ"  [SOQ]
Local File =[L]DOSSIER+".ORDERS"   [ORD]
Local File =[L]DOSSIER+".ORDERS"   [ORDB]
Local File =[L]DOSSIER+".MTOLINK"  [MLK]

Local Integer MAJ, RET, TEST
Local Char TSTMSG(80)
TEST = 0

For [MLK] Where FMIFLG=2
    Read [SOQ]SOQ0 = [F:MLK]DEMNUM;[F:MLK]DEMLIN;[F:MLK]DEMSEQ

    If !fstat & [F:SOQ]FMINUM="" & find([F:SOQ]FMI,3,5)
      Trbegin [SOQ]
        Call MAJFMISOQ([F:MLK]DEMNUM, [F:MLK]DEMLIN, [F:MLK]DEMSEQ,
&                      [F:MLK]RESSNUM, [F:MLK]RESSLIN, [F:MLK]RESSSEQ, 1, RET) From TRTVENMAJ
        TSTMSG = "Set [SOQ]FMINUM" :  Gosub TEST
       If RET : Rollback
       Else   : Commit
       Endif
       Read [SOQ]SOQ0 = [F:MLK]DEMNUM;[F:MLK]DEMLIN;[F:MLK]DEMSEQ
    Endif

    If !fstat & [F:SOQ]FMINUM=[F:MLK]RESSNUM & find([F:SOQ]FMI,3,5)
      Filter [ORDB] Where ITMREF=[F:MLK]ITMREF
      Read [ORDB]ORD3 = [F:MLK]STOFCY;[F:MLK]RESSTYP;[F:MLK]RESSNUM;[F:MLK]RESSLIN;[F:MLK]RESSSEQ
      If !fstat & [F:ORDB]FMI=1 & [F:ORDB]MTOQTY=[F:MLK]LIKQTY : # fausse contremarque
         Trbegin [SOQ]
           Gosub TRT_MAJ
           TSTMSG = "" :  Gosub TEST
         If RET : Rollback
         Else   : Commit : MAJ+=1
         Endif
      Endif
    Elsif !fstat & [F:SOQ]FMINUM<>[F:MLK]RESSNUM
      Trbegin [MLK]
       [F:MLK]FMIFLG=1
       Rewrite [MLK]
       RET=(fstat<>0)
       TSTMSG = "Reset [MLK]FMIFLG to 1" :  Gosub TEST
       If RET : Rollback
       Else   : Commit
       Endif
    Endif
Next
Filter [ORDB]

If MAJ>0
   GMESSAGE=":"-num$(MAJ)-"Records updated"
Endif
Call ECR_TRACE("UTIVEN18 : Process End on : "+DOSSIER-GMESSAGE,0) From GESECRAN
GMESSAGE=""
End

#######################################################################################################
## Mode test

$TEST
If !TEST : Return : Endif

Call ECR_TRACE(string$(TSTMSG<>"",TSTMSG-": ")
&             +[F:MLK]STOFCY-[F:MLK]ITMREF-num$([F:SOQ]FMI)-num$([F:MLK]LIKQTY)-":"
&             -num$([F:MLK]DEMTYP)-[F:MLK]DEMNUM-num$([F:MLK]DEMLIN)-num$([F:MLK]DEMSEQ)-"=>"
&             -num$([F:MLK]RESSTYP)-[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)-num$([F:MLK]RESSSEQ)
&             ,RET<>0) From GESECRAN

RET=1 : # transaction non rollbackée
Return

#######################################################################################################
$TRT_MAJ
RET=0
Case [F:SOQ]FMI
  When 3
    If !clalev ([F:POQ]) : Local File =[L]DOSSIER+".PORDERQ" [POQ] : Endif
    Readlock [POQ]POQ0 = [F:MLK]RESSNUM;[F:MLK]RESSLIN;[F:MLK]RESSSEQ
    If fstat
       #Call RSTA("POQ",[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)-num$([F:MLK]RESSSEQ)) From GLOCK
       RET=1 : Return
    Endif

    [F:POQ]SOHNUM = [F:SOQ]SOHNUM
    [F:POQ]SOPLIN = [F:SOQ]SOPLIN
    [F:POQ]SOQSEQ = [F:SOQ]SOQSEQ
    [F:POQ]ORI = 3

    Rewrite [POQ]
    If fstat : Call FSTA("POQ") From GLOCK : RET=1 : Return : Endif

    If [F:POQ]WIPNUM <> ""
       Readlock [ORD]ORD0 = 2;[F:POQ]WIPNUM;[F:POQ]ITMREF
       If fstat
          Call RSTA("ORD","2"-[F:POQ]WIPNUM-[F:POQ]ITMREF) From GLOCK : RET=1 : Return
       Elsif [F:ORD]MTOQTY<>[F:MLK]LIKQTY
          RET=1 : Return
       Endif

       [F:ORD]FMI = 3

       Rewrite [ORD]
       If fstat
          Call FSTA("ORD") From GLOCK : RET=1 : Return
       Endif
    Endif

  When 5
    Filter [ORD] Where ITMREF=[F:SOQ]ITMREF
    Read [ORD]ORD3 = [F:SOQ]STOFCY;2;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
    Filter [ORD]
    If fstat
       #Call RSTA("ORD","2"-[F:POQ]WIPNUM-[F:POQ]ITMREF) From GLOCK
       RET=1 : Return
    Endif

    If !clalev ([F:MFI]) : Local File =[L]DOSSIER+".MFGITM" [MFI]   : Endif
    Readlock [MFI]MFI0 = [F:MLK]RESSNUM;[F:MLK]RESSLIN
    If fstat
       #Call RSTA("MFI",[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)) From GLOCK
       RET=1 : Return
    Elsif [F:MFI]MFGSTA = 4 : # Si l'OF est clos, on n'y touche plus
       RET=1 : Return
    Endif

    [F:MFI]FMI = 5
    [F:MFI]BPCTYPDEN = 2
    [F:MFI]BPCNUM    = [F:ORD]BPRNUM
    [F:MFI]VCRTYPORI = [F:ORD]VCRTYP
    [F:MFI]VCRNUMORI = [F:ORD]VCRNUM
    [F:MFI]VCRLINORI = [F:ORD]VCRLIN
    [F:MFI]VCRSEQORI = [F:ORD]VCRSEQ

    Rewrite [MFI]
    If fstat : Call FSTA("MFI") From GLOCK : RET=1 : Return : Endif

    If [F:MFI]WIPNUM<>"" & [F:MFI]MFITRKFLG<=4  & [F:MFI]CPLQTY < [F:MFI]EXTQTY     # 38020 mm 10.06
       Readlock [ORD]ORD0 = 5;[F:MFI]WIPNUM;[F:MFI]ITMREF
       If fstat
          Call RSTA("ORD","5"-[F:MFI]WIPNUM-[F:MFI]ITMREF) From GLOCK : RET=1 : Return
       Elsif [F:ORD]MTOQTY<>[F:MLK]LIKQTY
          RET=1 : Return
       Endif

       [F:ORD]FMI = 5
       [F:ORD]BPRNUM = [F:MFI]BPCNUM
       [F:ORD]VCRTYPORI = [F:MFI]VCRTYPORI
       [F:ORD]VCRNUMORI = [F:MFI]VCRNUMORI
       [F:ORD]VCRLINORI = [F:MFI]VCRLINORI
       [F:ORD]VCRSEQORI = [F:MFI]VCRSEQORI

       Rewrite [ORD]
       If fstat : Call FSTA("ORD") From GLOCK : RET=1 : Return : Endif
    Endif
Endcase
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIVEN18(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIVEN18(APPLI)
End

