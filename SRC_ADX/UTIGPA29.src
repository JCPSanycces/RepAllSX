#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# UTIGPA29  Module GPAO     Table HANDLING,  Initialisation du champ SVRITMWEI    #
###################################################################################
Local Char DOSSIER(30)

 DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("UTIGPA29: Update field of HANDLING table") From LECFIC
      Call MAJ_UTIGPA29(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIGPA29: Update field of HANDLING table") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTIGPA29(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif

##########################################################################
# Initialisation du champ [F:HSH] SVRITMWEI
##########################################################################
Subprog MAJ_UTIGPA29(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA29: Process Start on : "+DOSSIER, 0) From GESECRAN

If filinfo(filpath("FIL","HANDLING","fde",DOSSIER),0) <= 0     End Endif
#----- Ouverture des fichiers -----#
If clalev([F:HSH])  =0  Local File =DOSSIER+".HANDLING"       [HSH] : Endif

Call DEBTRANS From GLOCK
Trbegin [HSH]
For [HSH]
 Readlock [HSH] Curr
    If !fstat
      If [F:HSH]SVRITMWEI = 0 : [F:HSH]SVRITMWEI =1 : Endif
      Rewrite [HSH]
      If fstat
         Call ECR_TRACE("File HANDLING"-[F:HSH]SVRITMWEI+", ERROR ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
Next
Commit
Close Local File [HSH]

Call ECR_TRACE("UTIGPA29 : End Process",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA29(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTIGPA29(APPLI)
End
