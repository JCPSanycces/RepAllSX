#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################
# UTICRM01   Modification gestion champs origine              Module CRM #
#                                                                        #
##########################################################################
# FGR 11/03/2010 : X3SUIVI62924
##########################################################################
# Issue 106947 - 20151105 by LD : Migration of historic folder

  DOSSIER = nomap
  # Issue 106947
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # End issue 106947
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 106947
#    Read [ADS]DOSSIER=[L]DOSSIER
#    If fstat THEN
#      Raz [F:ADS]
#    Endif
    If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
    # End issue 106947
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTICRM01(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICRM01(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer B_OK
Local Char SCODEADI(GLONADI)

  Call ECR_TRACE("UTICRM01: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ATABDIV" [ADI]
  Local File =DOSSIER + ".AOBJET"  [AOB]
  IERR = 0
  #------------------------------------------------------------
  # APPELS
  # Issue 106947
  # For historic folder, to do only if PHONECALL is not a view
  Raz COMPTEUR
  If func DOSVUE.ISVIEW(DOSSIER,"PHONECALL")<> 1
  # End issue 106947
      Local File =DOSSIER + ".PHONECALL" [CLL]
      If dim([F:CLL]CLLORI) > 0 and dim([F:CLL]CLLORIADI) > 0  Then
        Call ECR_TRACE("UTICRM01 : PHONECALL",0) From GESECRAN
        Trbegin [CLL]
        Filter [CLL] Where [F:CLL]CLLORIADI = ""
        For [CLL]CLL0
          If [F:CLL]CLLORI = 1 Then
            [F:CLL]CLLORIADI = "MAN1"
            Raz [F:CLL]CLLORIAOB
            Raz [F:CLL]CLLORIVCR
            Raz [F:CLL]CLLORIVCRL
          Elsif [F:CLL]CLLORI > 1 Then
            Case [F:CLL]CLLORI
              When 2
                SCODEADI = "MKT2"  # Publipostage
              When 3
                SCODEADI = "MKT3"  # Campagne d'appels
              When 4
                SCODEADI = "MKT4"  # Salon professionnel
              When 5
                SCODEADI = "MKT5"  # Campagne presse
              When 6
                SCODEADI = "MKT6"  # Campagne marketing
              When Default
                SCODEADI = "MAN1"  # On traite comme 1
            Endcase
            If SCODEADI = "MAN1" Then
              [F:CLL]CLLORIADI = SCODEADI
              Raz [F:CLL]CLLORIAOB
              Raz [F:CLL]CLLORIVCR
              Raz [F:CLL]CLLORIVCRL
            Else
              [F:CLL]CLLORIADI = SCODEADI
              Read [ADI]CODE=439;[F:CLL]CLLORIADI
              [F:CLL]CLLORIAOB = [F:ADI]A1
            Endif
          Else
            [F:CLL]CLLORIADI = "MAN1"
            Raz [F:CLL]CLLORIAOB
            Raz [F:CLL]CLLORIVCR
            Raz [F:CLL]CLLORIVCRL
          Endif
          #
          Rewrite [CLL]
          COMPTEUR += 1
        Next
        Filter [CLL]
        If IERR = 0 Then
          Commit
        Else
          Rollback
        Endif
        Call ECR_TRACE("UTICRM01 : PHONECALL" - num$(COMPTEUR) - "records processed",0) From GESECRAN

        # Issue 106947
        # Not to do in a historic folder
        Raz COMPTEUR
        If func DOSSUB.ISHISTFOLD(DOSSIER)=0
        # End issue 106947
            For WOBJET="CLL", "CL2", "CL3", "CL4", "CL5"
              Read [AOB]ABREV=WOBJET
              If !fstat Then
                Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
                #
                If [F:AOB]TYPGES <> 4 Then
                  # Pas de fenêtre pour les browsers
                  Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
                  If B_OK <> 1 Then
                    Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
                  Endif
                Endif
                #
                Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
                If B_OK <> 1 Then
                  Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
                Endif
                #
                COMPTEUR += 1
              Endif
            Next WOBJET
            Call ECR_TRACE("UTICRM01 : PHONECALL" - num$(COMPTEUR) - " objects updated",0) From GESECRAN
        # Issue 106947
        Endif
        # End issue 106947
      Endif
      Close Local File [CLL]
  # Issue 106947
  Endif
  # End issue 106947

  #------------------------------------------------------------
  # TACHES
  # Issue 106947
  # For historic folder, to do only if TASK is not a view
  Raz COMPTEUR
  If func DOSVUE.ISVIEW(DOSSIER,"TASK")<> 1
  # End issue 106947
      Local File =DOSSIER + ".TASK" [TSK]
      If dim([F:TSK]TSKORI) > 0 and dim([F:TSK]TSKORIADI) > 0  Then
        Call ECR_TRACE("UTICRM01 : TASK",0) From GESECRAN
        Trbegin [TSK]
        Filter [TSK] Where [F:TSK]TSKORIADI = ""
        For [TSK]TSK0
          If [F:TSK]TSKORI = 1 Then
            [F:TSK]TSKORIADI = "MAN1"
            Raz [F:TSK]TSKORIAOB
            Raz [F:TSK]TSKORIVCR
            Raz [F:TSK]TSKORIVCRL
          Elsif [F:TSK]TSKORI > 1 Then
            Case [F:TSK]TSKORI
              When 2
                SCODEADI = "HDK1"  # Demande de service
              When 3
                SCODEADI = "MKT2"  # Publipostage
              When 4
                SCODEADI = "MKT3"  # Campagne d'appels
              When 5
                SCODEADI = "MKT4"  # Salon professionnel
              When 6
                SCODEADI = "MKT5"  # Campagne presse
              When 7
                SCODEADI = "CPT4"  # Campagne de relance
              When 8
                SCODEADI = "MKT6"  # Campagne marketing
              When Default
                SCODEADI = "MAN1"  # On traite comme 1
            Endcase
            If SCODEADI = "MAN1" Then
              [F:TSK]TSKORIADI = SCODEADI
              Raz [F:TSK]TSKORIAOB
              Raz [F:TSK]TSKORIVCR
              Raz [F:TSK]TSKORIVCRL
            Else
              [F:TSK]TSKORIADI = SCODEADI
              Read [ADI]CODE=439;[F:TSK]TSKORIADI
              [F:TSK]TSKORIAOB = [F:ADI]A1
            Endif
          Else
            [F:TSK]TSKORIADI = "MAN1"
            Raz [F:TSK]TSKORIAOB
            Raz [F:TSK]TSKORIVCR
            Raz [F:TSK]TSKORIVCRL
          Endif
          #
          Rewrite [TSK]
          COMPTEUR += 1
        Next
        Filter [TSK]
        If IERR = 0 Then
          Commit
        Else
          Rollback
        Endif
        Call ECR_TRACE("UTICRM01 : TASK" - num$(COMPTEUR) - "records processed",0) From GESECRAN
        # Issue 106947
        # Not to do in a historic folder
        Raz COMPTEUR
        If func DOSSUB.ISHISTFOLD(DOSSIER)=0
        # End issue 106947
            For WOBJET="TSK", "TS2", "TS3", "TS4"
              Read [AOB]ABREV=WOBJET
              If !fstat Then
                Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
                #
                If [F:AOB]TYPGES <> 4 Then
                  # Pas de fenêtre pour les browsers
                  Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
                  If B_OK <> 1 Then
                    Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
                  Endif
                Endif
                #
                Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
                If B_OK <> 1 Then
                  Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
                Endif
                #
                COMPTEUR += 1
              Endif
            Next WOBJET
            Call ECR_TRACE("UTICRM01 : TASK" - num$(COMPTEUR) - " objects updated",0) From GESECRAN
        # Issue 106947
        Endif
        # End issue 106947
      Endif
      Close Local File [TSK]
  # Issue 106947
  Endif
  # End issue 106947

  #------------------------------------------------------------
  # RENDEZ-VOUS
  # Issue 106947
  # For historic folder, to do only if BAPPOINT is not a view
  Raz COMPTEUR
  If func DOSVUE.ISVIEW(DOSSIER,"BAPPOINT")<> 1
  # End issue 106947
      Local File =DOSSIER + ".BAPPOINT" [BAP]
      If dim([F:BAP]APTORI) > 0 and dim([F:BAP]APTORIADI) > 0  Then
        Call ECR_TRACE("UTICRM01 : BAPPOINT",0) From GESECRAN
        Trbegin [BAP]
        Filter [BAP] Where [F:BAP]APTORIADI = ""
        For [BAP]APP0
          If [F:BAP]APTORI = 1 Then
            [F:BAP]APTORIADI = "MAN1"
            Raz [F:BAP]APTORIAOB
            Raz [F:BAP]APTORIVCR
            Raz [F:BAP]APTORIVCRL
          Elsif [F:BAP]APTORI > 1 Then
            Case [F:BAP]APTORI
              When 2
                SCODEADI = "MKT2"  # Publipostage
              When 3
                SCODEADI = "MKT3"  # Campagne d'appels
              When 4
                SCODEADI = "MKT4"  # Salon professionnel
              When 5
                SCODEADI = "MKT5"  # Campagne presse
              When 6
                SCODEADI = "MKT6"  # Campagne marketing
              When Default
                SCODEADI = "MAN1"  # On traite comme 1
            Endcase
            If SCODEADI = "MAN1" Then
              [F:BAP]APTORIADI = SCODEADI
              Raz [F:BAP]APTORIAOB
              Raz [F:BAP]APTORIVCR
              Raz [F:BAP]APTORIVCRL
            Else
              [F:BAP]APTORIADI = SCODEADI
              Read [ADI]CODE=439;[F:BAP]APTORIADI
              [F:BAP]APTORIAOB = [F:ADI]A1
            Endif
          Else
            [F:BAP]APTORIADI = "MAN1"
            Raz [F:BAP]APTORIAOB
            Raz [F:BAP]APTORIVCR
            Raz [F:BAP]APTORIVCRL
          Endif
          #
          Rewrite [BAP]
          COMPTEUR += 1
        Next
        Filter [BAP]
        If IERR = 0 Then
          Commit
        Else
          Rollback
        Endif
        Call ECR_TRACE("UTICRM01 : BAPPOINT" - num$(COMPTEUR) - "records processed",0) From GESECRAN
        # Issue 106947
        # Not to do in a historic folder
        Raz COMPTEUR
        If func DOSSUB.ISHISTFOLD(DOSSIER)=0
        # End issue 106947
            For WOBJET="BAP", "BA2"
              Read [AOB]ABREV=WOBJET
              If !fstat Then
                Call MAJ_SEL(DOSSIER, WOBJET) From PATCHAOB
                #
                If [F:AOB]TYPGES <> 4 Then
                  # Pas de fenêtre pour les browsers
                  Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
                  If B_OK <> 1 Then
                    Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
                  Endif
                Endif
                #
                Call VALID (WOBJET, DOSSIER, 1, B_OK) From VALOBJ
                If B_OK <> 1 Then
                  Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
                Endif
                #
                COMPTEUR += 1
              Endif
            Next WOBJET
            Call ECR_TRACE("UTICRM01 : BAPPOINT" - num$(COMPTEUR) - " objects updated",0) From GESECRAN
        # Issue 106947
        Endif
        # End issue 106947
      Endif
      Close Local File [BAP]
    # Issue 106947
  Endif
  # End issue 106947

  #------------------------------------------------------------
  Close Local File [ADI]
  Close Local File [AOB]
  Call ECR_TRACE("UTICRM01: Process on :" - DOSSIER - "finished",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 106947
#  Read [ADS]DOSSIER=APPLI
#  If fstat THEN
#    Raz [F:ADS]
#  Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  # End issue 106947
  Call MAJ_UTICRM01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTICRM01(APPLI)
End

