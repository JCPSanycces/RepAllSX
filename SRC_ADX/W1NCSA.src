Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TRANTYPE(zc) From W1NCSA
Onkey 144 Titled GBOUTP Call P_TRANTYPE(zc) From W1NCSA
Onkey 146 Titled GBOUTA Call SA_TRANTYPE(zc) From W1NCSA
If VALEUR="" : Call INIADI(VALEUR,"807") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_TRANTYPE(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"807","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"807",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TRANTYPE" : GZNUM = 3209 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TRANTYPE
Call AM_TRANTYPE(zc)
If !mkstat & GOBJET
 zoncou = "TRANTYPE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

