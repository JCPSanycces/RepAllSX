#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:29"
A_USER  = "DOC"
A_STAMP = "20181109230529"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSA [NCSA]
Gosub HORODAT
Local Inpbox "NCSA" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSA] As [SIM_]
Grizo [NCSA]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=28
Return

$ON_ACTIONID
Onevent BEFORE_INPUT Call AS_ACTIONID(zc) From W1NCSA
Onevent CONTROL Call C_ACTIONID(zc) From W1NCSA
Return

Subprog AS_ACTIONID(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ACTIONID(zc) From W1NCSA
Gosub _AFF
End

Subprog C_ACTIONID(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACTIONID" : GZNUM = 89 : Endif
Gosub _AFF
End

Subprog S_ACTIONID(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action NCSACHOICE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "NCSACHOICE"
 Call S_TAB_CHAR(VALEUR,PARMSK,"NCSACHOICE","SUBNCSA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_TRANACTION
Onevent INIT_AREA Call D_TRANACTION(zc) From W1NCSA
Onevent CONTROL Call C_TRANACTION(zc) From W1NCSA
Onevent BEFORE_INPUT Call AS_TRANACTION(zc) From W1NCSA
Onevent AFTER_CHANGE Gosub AMM_TRANACTION From W1NCSA
Return

Subprog D_TRANACTION(VALEUR)
Variable Char    VALEUR()
If varinit([M]TRANACTION,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"806","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_TRANACTION(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TRANACTION(zc) From W1NCSA
Onkey 144 Titled GBOUTP Call P_TRANACTION(zc) From W1NCSA
Onkey 146 Titled GBOUTA Call SA_TRANACTION(zc) From W1NCSA
If VALEUR="" : Call INIADI(VALEUR,"806") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_TRANACTION(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"806","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"806",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TRANACTION" : GZNUM = 90 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TRANACTION
Call AM_TRANACTION(zc)
If !mkstat & GOBJET
 zoncou = "TRANACTION" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TRANACTION(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTRANACTION)")>indice
 [M]TRANACTION(indice) = VALEUR
 Affzo ZTRANACTION(indice)
Endif
Gosub _AFF
End

Subprog S_TRANACTION(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "806"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_TRANACTION(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "806"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TRANACTION(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "806"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTRANACTION
Onevent BEFORE_AREA Gosub AV_ZTRANACTION From W1NCSA
Return

$AV_ZTRANACTION
Call LECTEXTRA(zc,"ATABDIV","LNGDES","806",num$([M]TRANACTION(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_TRANTYPE
Onevent INIT_AREA Call D_TRANTYPE(zc) From W1NCSA
Onevent CONTROL Call C_TRANTYPE(zc) From W1NCSA
Onevent BEFORE_INPUT Call AS_TRANTYPE(zc) From W1NCSA
Onevent AFTER_CHANGE Gosub AMM_TRANTYPE From W1NCSA
Return

