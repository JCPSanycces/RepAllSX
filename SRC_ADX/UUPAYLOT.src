#<AdxTL>@(#)12.0.0.0 $Revision$ Règlements, Affectation lots de saisie
#CHECK IGNORE_SOURCE
## GH 01/08/00 Attribution des lots de saisie de règlements au passage 120->130
## Lancement prévu par Développement / Utilitaires / Divers / Exécution traitements
 
Onerrgo ERREUR From CONTROLE
Local File TABCOUAFF [TCA]
Local File PAYMENTH  [PYH]
Local File PAYMENTH  [PYH2]
Local File PAYLOT    [PYL]
Local File ACODNUM   [ANM]
Local File TABPAYTYP [TPY]
Local File COMPANY   [CPY]
# Pour la trace
Local File PAYMENTH  [PYH9]
Local File GACCOUNT  [GAC]
Local File BPARTNER  [BPR]
# Pour optimiser
Local File TABCHANGE [TCH]
Local File TABCUR    [TCU]
Local File AVALNUM   [AVN]

Local Mask UUPAYLOT  [DIA]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char    COMPTLOT(20), FILTRE(255), CRITERE(255)
Local Char    COMP(5), USR(5), DEVSOC(5), SEP(2), SIT(5), PER(4)
Local Char    CLE1(5), CLE2(3), CLE4(5), MESSA(100)
Local Integer I, J, K, STAT, CAS, PERIODE, NBLOT, X1, SEQNB
Local Date    DAT, CLE3
Local Libelle PRO, FLTRC
Local Decimal MT
I=100 : # Nbre de année/mois de création différents pour les règlt de même type, société, 
      : # éventuellement même auteur de création
J=max(1,I*GNBSITE) 
Local Integer LOTX(I), SEQNUM(J)
Local Char    LOTID(4)(I), LOTCOD(20)(I), SEQID(10)(I)
Local Decimal TOTLOT(I)

Call LECTURE("TCA","3","") From CONTOBJ
If !fstat
 COMPTLOT = [F:TCA]CODNUM(6) : # Lots de saisie
Endif
If COMPTLOT=""
 # Lots de saisie règlements \ Compteur inexistant
 Call ERREUR(mess(7,865,1)+"\"+mess(12,114,1)) From GESECRAN
 End
Endif
Read [ANM]ANM0 = COMPTLOT
If fstat
 Call FSTA("ANM") From GLOCK
 End
Endif

Call DES_TRAIT("UUPAYLOT",MESSA) From EXETRT
Call DIALO(STAT,MESSA) From GESECRAN
If STAT<>2 : End : Endif

Local Mask PAY4 [PAY4]
X1 = dim([M:PAY4]PAYNUM)
Close Local Mask [PAY4]

SEP=", "
If [M:DIA]TEST=2 : MESSA-="-"-mess(194,124,1) : Else PRO=1 : Endif : # Mode test
Call OUVRE_TRACE(MESSA) From LECFIC
Call TEMPON("O") From GESECRAN

CRITERE = "PAYLOT=''"
If [M:DIA]ALLCPY<>2
 CRITERE += " & CPY='"+[M:DIA]CPY+"'"
Endif
If [M:DIA]ALLTPY<>2
 CRITERE += " & PAYTYP='"+[M:DIA]TPY+"'"
Endif
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE += " & CREDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"]"
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE += " & CREDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"
Endif
If !find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
 Filter [PYH2] Where evalue(CRITERE) Order By Key CLE = CREDAT;PAYTYP;CPY;NUM
 CAS=4
Else
 Filter [PYH2] Where evalue(CRITERE) Order By Key CLE = CREUSR;CREDAT;PAYTYP;CPY;NUM
 CAS=5
Endif
CLE4="*"
Read [PYH2]CLE First
While fstat<4
 CLE1 = [F:PYH2]PAYTYP
 CLE2 = [F:PYH2]CPY
 CLE3 = [F:PYH2]CREDAT
 If (CAS=5 & CLE4<>[F:PYH2]CREUSR) | CAS=4
  CLE4 = [F:PYH2]CREUSR
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<1 : Break : Endif
 Endif
 Call LECTURE("TPY",[F:PYH2]PAYTYP,"") From CONTOBJ
 I = find([F:PYH2]CPY,GSOC(1..GNBSOC))
 If I
  DEVSOC=GDEVSOC(I)
  Call DEBTRANS From GLOCK
  Gosub TR2
  If GOK<1 : Break : Endif
 Endif
 Unlock [AVN]
 If CAS=5
  Read [PYH2]CLE(4) > CLE4;CLE3;CLE1;CLE2
 Else
  Read [PYH2]CLE(3) > CLE3;CLE1;CLE2
 Endif
Wend
Filter [PYH2]
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$TR1
GOK=1 : SEQNB=0
FILTRE="PAYTYP='"+[L]CLE1+"' & CPY='"+[L]CLE2+"'"
If [L]CLE3=[0/0/0] : FILTRE+=" & CREDAT=[0/0/0]"
Else               : FILTRE+=" & CREDAT=["+format$(GFMD,[L]CLE3)+"]"
Endif
If CAS=5 : FILTRE+=" & CREUSR='"+[L]CLE4+"'" : Endif
For [PYH]PYH0 Where evalue(FILTRE) & evalue(CRITERE)
 USR=[F:PYH]CREUSR
 DAT=[F:PYH]CREDAT
 Case [F:ANM]NIVRAZ
  When 1 : PERIODE=0
  When 2 : PERIODE=mod(year(DAT),100)
  When 3 : PERIODE=100*mod(year(DAT),100)+month(DAT)
 Endcase
 PER=num$(PERIODE)
 Case [F:ANM]NIVDEF
  When 1   : SIT = ""
  When 2   : SIT = [F:PYH]CPY
  When 3   : SIT = [F:PYH]FCY
 Endcase
 If CAS=5 : COMP=USR
 Else     : COMP=""
 Endif
 J=find(SIT+"\"+PER,SEQID(0..SEQNB-1))-1
 If J<0
  Readlock [AVN]AVN0 = COMPTLOT;SIT;PERIODE;COMP
  If fstat=1
   GOK=-1 : Call RSTA("AVN",COMPTLOT-SIT-num$(PERIODE)-COMP) From GLOCK : Break
  Elsif fstat
   K=1
  Else
   K=[F:AVN]VALEUR
  Endif
  J=SEQNB
  SEQID(J)=SIT+"\"+PER
  SEQNUM(J)=K
  SEQNB+=1
 Endif
Next : # [PYH]
If GOK<0
 Unlock [AVN]
 Call ROLL From GLOCK
 If !GROLL : Goto TR1 : Endif
Endif
Return

$TR2
NBLOT=0
GOK=1
Trbegin [PYH], [PYL]
 FILTRE="PAYTYP='"+[L]CLE1+"' & CPY='"+[L]CLE2+"' & CREDAT=["+format$(GFMD,[L]CLE3)+"]"
 If CAS=5 : FILTRE+=" & CREUSR='"+[L]CLE4+"'" : Endif
 For [PYH]PYH0 Where evalue(FILTRE) & evalue(CRITERE)
  K=1
  Readlock [PYH]PYH0 Curr
  If fstat=1
   If PRO
    GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH]NUM : Break
   Else 
    K=0
   Endif
  Endif
  If K
   Gosub TR
   If GOK<1 : Break : Endif
  Endif
 Next : # [PYH]
 If GOK<0 : Goto ROLL_TR2 : Elsif !GOK : Goto AB_TR2 : Endif
 Gosub TRACE
If !PRO : Goto AB_TR2 : Else Commit : Endif
Return

$AB_TR2
Rollback
Unlock [AVN]
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Unlock [AVN] : Return
Else Goto TR2
Endif

$TR
USR=[F:PYH]CREUSR
DAT=[F:PYH]CREDAT
Case [F:ANM]NIVRAZ
 When 1 : PERIODE=0
 When 2 : PERIODE=mod(year(DAT),100)
 When 3 : PERIODE=100*mod(year(DAT),100)+month(DAT)
Endcase
PER=num$(PERIODE)
I=find(PER,LOTID(0..NBLOT-1))-1
If I<0 | LOTX(I)>=X1
 If !PRO
  Case [F:ANM]NIVDEF
   When 1   : SIT = ""
   When 2   : SIT = [F:PYH]CPY
   When 3   : SIT = [F:PYH]FCY
  Endcase
  If CAS=5 : COMP=USR
  Else     : COMP=""
  Endif
  J=find(SIT+"\"+PER,SEQID(0..SEQNB-1))-1
  If J<0 : GOK=2 : Return : Endif
  K=SEQNUM(J) : SEQNUM(J)+=1
  Call NUMERO2([F:PYH]CPY,[F:PYH]FCY,[L]DAT,[L]USR,K,[F:PYH]PAYLOT,STAT)
 Else
  Call NUMERO(COMPTLOT,[F:PYH]FCY,[L]DAT,[L]USR,[F:PYH]PAYLOT,STAT) From SUBANM
  If GOK<0 : Return : Endif
 Endif
 If STAT
  Case STAT
   When 1 : # Compteur inexistant
    Call ECR_TRACE(COMPTLOT-":"-mess(2,114,1),1) From GESECRAN
   When 2 : # Dépassement de compteur
    Call ECR_TRACE(COMPTLOT-":"-mess(13,114,1),1) From GESECRAN
   When 99 : # Transaction abandonnée
    Call ECR_TRACE(COMPTLOT-":"-mess(18,114,1),1) From GESECRAN
  Endcase
  GOK=0 : Return
 Endif
 [F:PYH]PAYLOTLIG=1
 If I<0
  I=NBLOT : NBLOT+=1
  [L]LOTID(I)=PER
 Endif
 [L]LOTCOD(I)=[F:PYH]PAYLOT
 [L]LOTX(I)=1
 [L]TOTLOT(I)=0
 J=0
Else
 [F:PYH]PAYLOT=LOTCOD(I) : [F:PYH]PAYLOTLIG=LOTX(I)+1
 LOTX(I)+=1
 J=1
Endif
Rewrite [PYH]
If fstat
 GOK=0 : Call FSTA("PYH") From GLOCK : Return
Endif

If [F:TPY]SNS<3 & [F:PYH]SNS=[F:TPY]SNS : K=1
Elsif [F:TPY]SNS<3 & [F:PYH]SNS<>[F:TPY]SNS : K=-1
Elsif [F:PYH]SNS=2 : K=1
Else K=-1
Endif

# Montant du lot en devise société
If DEVSOC=[F:PYH]CUR
 [L]MT=[F:PYH]AMTCUR
Else
 Call CONVERT([F:PYH]CUR,DEVSOC,DEVSOC,[F:TPY]RATTYP,
&             [F:PYH]ACCDAT,[F:PYH]AMTCUR,[L]MT,STAT) From TRTDEV
 If STAT : [L]MT=0 : Endif
Endif
[L]TOTLOT(I)+=K*[L]MT
 
If !PRO : Return : Endif

If !J 
 Raz [F:PYL]
 [F:PYL]COD   =[F:PYH]PAYLOT   
 [F:PYL]CPY   =[F:PYH]CPY
 [F:PYL]PAYTYP=[F:PYH]PAYTYP
 If dim([F:PYL]CREDAT)>0 : [F:PYL]CREDAT=date$ : Endif
 If dim([F:PYL]CREUSR)>0 : [F:PYL]CREUSR=GUSER : Endif
Else
 Read [PYL]PYL0 = [F:PYH]PAYLOT
 If fstat
  GOK=0 : Call RSTA("PYL",[F:PYH]PAYLOT) From GLOCK : Return
 Endif 
Endif
[F:PYL]NBRPAY+=1
# Montant du lot en devise société
[F:PYL]TOTLOC+=K*[L]MT
# Montant du lot en devise reporting
If GSYSCUR=[F:PYH]CUR
 [L]MT=[F:PYH]AMTCUR
Elsif DEVSOC<>GSYSCUR
 Call CONVERT([F:PYH]CUR,GSYSCUR,DEVSOC,[F:TPY]RATTYP,
&             [F:PYH]ACCDAT,[F:PYH]AMTCUR,[L]MT,STAT) From TRTDEV
 If STAT : [L]MT=0 : Endif
Endif
[F:PYL]TOTRPT+=K*[L]MT
If !J : Write [PYL]
Else  : Rewrite [PYL]
Endif
If fstat
 GOK=0 : Call FSTA("PYL") From GLOCK : Return
Endif
Return

$TRACE
If FLTRC
 Call ECR_TRACE(" ",0) From GESECRAN
 FLTRC=0
Endif
For I=0 To NBLOT-1
 For [PYH9]PYH2 Where PAYLOT = LOTCOD(I)
  If FLTRC<>1
   # Lot de saisie PAYLOT : (CREUSR,) CREDAT, PAYTYP, CPY, TOTLOC DEVSOC
   If CAS=5 : GMESSAGE=[F:PYH9]CREUSR+SEP : Else GMESSAGE="" : Endif
   GMESSAGE+=format$("D:"+GFMDAT,[F:PYH9]CREDAT)+SEP+[F:PYH9]PAYTYP+SEP+[F:PYH9]CPY
   GMESSAGE+=SEP+num$(TOTLOT(I))-DEVSOC
   Call ECR_TRACE(mess(109,121,1)-[F:PYH9]PAYLOT-":"-GMESSAGE,0) From GESECRAN
   FLTRC=1
  Endif

  # Règlement NUM : BPRNAM, AMTCUR CUR
  If [F:PYH9]BPR<>""
   Call LECTURE("BPR",[F:PYH9]BPR,"") From CONTOBJ
   GMESSAGE=[F:BPR]BPRNAM
  Elsif [F:PYH9]ACC<>""
   Call LECTURE("GAC",[F:PYH9]ACC,"") From CONTOBJ
   GMESSAGE=[F:GAC]DES
  Endif
  If [F:TPY]SNS<3 & [F:PYH9]SNS=[F:TPY]SNS : K=1
  Elsif [F:TPY]SNS<3 & [F:PYH9]SNS<>[F:TPY]SNS : K=-1
  Elsif [F:PYH9]SNS=2 : K=1
  Else K=-1
  Endif
  GMESSAGE += ","-num$(K*[F:PYH9]AMTCUR)-[F:PYH9]CUR
  Call ECR_TRACE(mess(27,117,1)-[F:PYH9]NUM-":"-GMESSAGE,0) From GESECRAN
 Next : # [PYH9]
Next I
GMESSAGE=""
Return

######################################################
Subprog NUMERO2(SOC,SIT,DAT,COMP,SEQUENCE,VALEUR,STAT)
######################################################
Value    Date    DAT
Value    Char    SOC(), SIT(), COMP()
Value    Integer SEQUENCE
Variable Char    VALEUR()
Variable Integer STAT
Local File [ANM]
Local Integer I

VALEUR = "" : STAT=0
For I=0 To [F:ANM]NBPOS-1
 Case [F:ANM]POSTYP(I)
  When 1 : # Constante
   VALEUR += [F:ANM]POSCTE(I)
  When 2 : # Année
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(mod(year(DAT),10))
    When 2 : VALEUR += format$("N0:2#",mod(year(DAT),100))
    When 4 : VALEUR += format$("N0:4#",year(DAT))
   Endcase
  When 3 : # Mois
   Case [F:ANM]POSLNG(I)
    When 2 : VALEUR += format$("N0:2#",month(DAT))
    When 3 : VALEUR += format$("D:MMM",DAT)
   Endcase
  When 4 : # Semaine
   VALEUR += format$("N0:2#",week(DAT))
  When 5 : # Jours
   Case [F:ANM]POSLNG(I)
    When 1 : VALEUR += num$(dayn(DAT))
    When 2 : VALEUR += format$("N0:2#",day(DAT))
    When 3 : VALEUR += format$("N0:3#",DAT-gdat$(1,1,year(DAT))+1)
   Endcase
  When 6 : # Société
   VALEUR += left$(SOC,[F:ANM]POSLNG(I))
  When 7 : # Site
   VALEUR += left$(SITE,[F:ANM]POSLNG(I))
  When 8 : # Séquence
   If SEQUENCE>val(string$([F:ANM]POSLNG(I),"9"))
    STAT = 2 : GOK = 0
   Endif
   VALEUR += format$("N0:"+num$([F:ANM]POSLNG(I))+"#",SEQUENCE)
  When 9 : # Complément
   If [F:ANM]POSLNG(I)=0 
    VALEUR += COMP
   Else
    VALEUR += left$(COMP,[F:ANM]POSLNG(I))
   Endif
  When 10 : # Exercice
   Local Decimal PER , EXE
   If clalev([F:PER])=0  : Local File PERIOD [PER] : Endif
   Call GETPERSOC(SOC,DAT,EXE,PER) From CPTSUB
   If EXE>0
    VALEUR = format$("N0:"+num$([F:ANM]POSLNG(I))+"#",EXE)
   Else
    STAT=3 : GOK = 0
   Endif
 Endcase
Next I
If [F:ANM]TYP=2
 VALEUR = num$(val(VALEUR))
Endif
End

## Etiquettes de l'écran UUPAYLOT ##

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]ALLCPY=2 : mkstat=1 : Endif
End

Subprog AS_TPY(VALEUR)
Variable Char    VALEUR()
If [M]ALLTPY=2 : mkstat=1 : Endif
End

