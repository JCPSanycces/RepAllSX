###############################################################
# Construit une synthèse
###############################################################
################################################################################################################
$BUILDSYN
  If SZSYNBUFFER = "" Then
    Return
  Endif

Local Integer INBLINCLOB

  Call TEXTE(23819, SZSYNTXT) From OBJDIV
  SZSYNCTL = chr$(13) + chr$(10) + "*****" - SZSYNTXT - ": "
  If len(SZSYNBUFFER) > 148 Then
    INBLINCLOB = 3
    If IRECDONE Then
      Gosub ASSERT10
      If ICURSOR1OK = 0 Then
        Return
      Endif
    Else
      Gosub ASSERT20
      If ICURSOR2OK = 0 Then
        Return
      Endif
    Endif
    SZBUFFER = SZSYNCTL + chr$(13) + chr$(10)
    Gosub WRITEBUFFER
    SZBUFFER = left$(SZSYNBUFFER, 148) + chr$(13) + chr$(10)
    Gosub WRITEBUFFER
    SZBUFFER = right$(SZSYNBUFFER, 149) + chr$(13) + chr$(10)
    Gosub WRITEBUFFER
  Else
    INBLINCLOB = 2
    If IRECDONE Then
      Gosub ASSERT10
      If ICURSOR1OK = 0 Then
        Return
      Endif
    Else
      Gosub ASSERT20
      If ICURSOR2OK = 0 Then
        Return
      Endif
    Endif
    SZBUFFER = SZSYNCTL + chr$(13) + chr$(10)
    Gosub WRITEBUFFER
    SZBUFFER = SZSYNBUFFER + chr$(13) + chr$(10)
    Gosub WRITEBUFFER
  Endif
Return

###############################################################
# Construit un clob commentaires
###############################################################
################################################################################################################
$BUILDCOMMENT
  Filter [ACB] Where [F:ACB]CODBLB = SZKEYCOMMENT and [F:ACB]IDENT1 = [F:HST]RECNUM
  For [ACB]
    #Commentaires
    Call TEXTE(1677, SZBUFFER) From OBJDIV
    SZCLOBCLA = chr$(13) + chr$(10) + "*****" - SZBUFFER - ":" - chr$(13) + chr$(10)
    Raz SZHBUFFER
    Setlob SZHBUFFER With [F:ACB]CLOB
    If SZHBUFFER(0) <> "" Then
      If !instr(1, SZHBUFFER(0), SZRTFCTL) Then
        Gosub WRITEHBUFFER
      Endif
    Endif
  Next
  Filter [ACB]
Return

###############################################################
# Construit une ligne de séparation
###############################################################
################################################################################################################
$BUILDEND
  SZBUFFER = chr$(13) + chr$(10)
  SZBUFFER += "--------------------------------------------------------------------"
  SZBUFFER += "--------------------------------------------------------------------"
  SZBUFFER += chr$(13) + chr$(10)
  SZBUFFER += chr$(13) + chr$(10)
  Gosub WRITEBUFFER
Return

###############################################################
# Ecrit un buffer monoligne
###############################################################
################################################################################################################
$WRITEBUFFER
  If IRECDONE Then
    Gosub ASSERT1
    If ICURSOR1OK = 0 Then
      Return
    Endif
    SZDONEBUF(ICLOB1CURSOR) = SZBUFFER
    ICLOB1CURSOR += 1
  Else
    Gosub ASSERT2
    If ICURSOR2OK = 0 Then
      Return
    Endif
    SZTODOBUF(ICLOB2CURSOR) = SZBUFFER
    ICLOB2CURSOR += 1
  Endif
Return

###############################################################
# Ecrit un buffer multiligne
###############################################################
################################################################################################################
$WRITEHBUFFER
Local Integer INBLINCLOB
Local Integer ITERCLOB

  INBLINCLOB = 1
  For ITERCLOB = 0 To dim(SZHBUFFER)-1
    If SZHBUFFER(ITERCLOB) = "" Then
      Break
    Endif
    INBLINCLOB += 1
  Next
  If IRECDONE Then
    Gosub ASSERT10
    If ICURSOR1OK = 0 Then
      Return
    Endif
    SZDONEBUF(ICLOB1CURSOR) = SZCLOBCLA
    ICLOB1CURSOR += 1
    For ITERCLOB = 0 To INBLINCLOB-2
      SZDONEBUF(ICLOB1CURSOR) = SZHBUFFER(ITERCLOB)
      ICLOB1CURSOR += 1
    Next
  Else
    Gosub ASSERT20
    If ICURSOR2OK = 0 Then
      Return
    Endif
    SZTODOBUF(ICLOB2CURSOR) = SZCLOBCLA
    ICLOB2CURSOR += 1
    For ITERCLOB = 0 To INBLINCLOB-2
      SZTODOBUF(ICLOB2CURSOR) = SZHBUFFER(ITERCLOB)
      ICLOB2CURSOR += 1
    Next
  Endif
Return

################################################
# Vérifie si le clob 1 est complet
################################################
################################################################################################################
$ASSERT1
  If ICURSOR1OK = 0 Then
    Return
  Endif
  If ICLOB1CURSOR >= dim(SZDONEBUF)-6 Then
    ICURSOR1OK = 0
  Endif
Return

################################################
# Vérifie si le clob 2 est complet
################################################
################################################################################################################
$ASSERT2
  If ICURSOR2OK = 0 Then
    Return
  Endif
  If ICLOB2CURSOR >= dim(SZTODOBUF)-6 Then
    ICURSOR2OK = 0
  Endif
Return

################################################
# Vérifie si le clob 1 est complet
################################################
################################################################################################################
$ASSERT10
  If ICURSOR1OK = 0 Then
    Return
  Endif

Local Integer IMAXCLOB

  IMAXCLOB = INBLINCLOB + 6
  If ICLOB1CURSOR >= dim(SZDONEBUF)-IMAXCLOB Then
    ICURSOR1OK = 0
  Endif
Return

################################################
# Vérifie si le clob 2 est complet
################################################
################################################################################################################
$ASSERT20
  If ICURSOR2OK = 0 Then
    Return
  Endif

Local Integer IMAXCLOB

  IMAXCLOB = INBLINCLOB + 6
  If ICLOB2CURSOR >= dim(SZTODOBUF)-IMAXCLOB Then
    ICURSOR2OK = 0
  Endif
Return

