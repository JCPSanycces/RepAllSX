###############################################################
# Construit une ligne d'affectation de demande de service
###############################################################
################################################################################################################
Subprog BUILDSREASS(IASS, SZDETASS, SZREP, SZLINE)
Value Integer IASS
Value Char SZDETASS
Value Char SZREP
Variable Char SZLINE

Local Char SZDES(GLONDCO) # FGR 23/09/2009 : X3SUIVI58037

  Raz SZLINE
  Case IASS
    When 1
      If SZDETASS = "" Then
        SZLINE = mess(987,182,1)                      #Demande affectée au dispatching global.
      Else
        Read [FCY]FCY0=SZDETASS
        If fstat Then
          SZLINE = mess(986,182,1) - ":" - SZDETASS   #Demande affectée au dispatching : XXXX
        Else
          SZLINE = mess(986,182,1) - ": (" + SZDETASS + ")" - [F:FCY]FCYNAM
        Endif
      Endif
    When 2
      If SZDETASS = "" Then
        SZLINE = mess(988,182,1)                      #Demande affectée à un collaborateur
      Else
        Read [AUS]CODUSR=SZDETASS
        If fstat Then
          SZLINE = mess(989,182,1) - ":" - SZDETASS   #Demande affectée au collaborateur : XXXX
        Else
          SZLINE = mess(989,182,1) - ": (" + SZDETASS + ")" - [F:AUS]NOMUSR
        Endif
      Endif
    When 3
      If SZDETASS = "" Then
        SZLINE = mess(990,182,1)                      #Demande affectée à une queue.
      Else
        Read [QUE]QUE0=SZDETASS
        If fstat Then
          SZLINE = mess(991,182,1) - ":" - SZDETASS   #Demande affectée à la queue : XXXX
        Else
          # FGR 23/09/2009 : X3SUIVI58037
          #SZLINE = mess(991,182,1) - ": (" + SZDETASS + ")" - [F:QUE]TTR
          Call LECTEXTRA(SZDES,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
          SZLINE = mess(991,182,1) - ": (" + SZDETASS + ")" - SZDES
        Endif
      Endif
    When 4
      SZLINE = mess(992,182,1)                      #Demande affectée au service commercial.
    When 5
      If SZREP = "" Then
        SZLINE = mess(993,182,1)                      #Demande clôturée.
      Else
        Read [AUS]CODUSR=SZREP
        If fstat Then
          SZLINE = mess(994,182,1) - ":" - SZREP      #Demande clôturée. Demande traitée par : XXXX
        Else
          SZLINE = mess(994,182,1) - ": (" + SZREP + ")" - [F:AUS]NOMUSR
        Endif
      Endif
  Endcase
  SZLINE += chr$(13) + chr$(10)
End

