###################################################################################################
# Classe TECPJMCOPY
# Issue X3-29531 - 2017-04-21 by FGR
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param [L]CURPTH Local Char(250), contains the class path
#* @param [L]AEVENT Local Char(20), contains the event code
#* @return [L]ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param [L]AMETHOD Local Char(20), contains the method code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "_LOAD"                       : Gosub _LOAD
    When "LOAD"                        : Gosub LOAD
    When "LOAD_AXX"                    : Gosub LOAD_AXX
    When "LOAD_CUR"                    : Gosub LOAD_CUR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param [L]AOPERATION Local Char(20), contains the operation code
#* @return [L]ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param [L]CURPRO Local Char(50), contains the property code
#* @param [L]ARULE Local Char(20), contains the action code requested
#* @return [L]ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

###################################################################################################
###################################################################################################
$LOAD
#Value Char SFROM ()
#Value Char STARGET ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = fmet this._LOAD(SFROM, STARGET, 1, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, 0, [0/0/0], AVOID.ACHAR)
Return

###################################################################################################
$LOAD_AXX
#Value Char SFROM ()
#Value Char STARGET ()
#Value Char SCODFIC ()
#Value Char SZONE ()
#Value Char SID1 ()
#Value Char SID2 ()
#Local Integer ARET_VALUE

  [L]ARET_VALUE = fmet this._LOAD(SFROM, STARGET, 2, SCODFIC, SZONE, SID1, SID2, AVOID.ACHAR, 0, [0/0/0], AVOID.ACHAR)
Return

###################################################################################################
$LOAD_CUR
#Value Char SFROM ()
#Value Char STARGET ()
#Value Char SCUR ()
#Value Shortint ICHGTYP
#Value Date DDATECUR
#Value Char SPROCUR ()
#Local Integer ARET_VALUE

  If ICHGTYP <= 0 Then
    ICHGTYP = 1
  Endif
  If DDATECUR = [0/0/0] Then
    DDATECUR = date$
  Endif
  [L]ARET_VALUE = fmet this._LOAD(SFROM, STARGET, 3, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, AVOID.ACHAR, SCUR, ICHGTYP, DDATECUR, SPROCUR)
Return

###################################################################################################
$_LOAD
#Value Char SFROM ()
#Value Char STARGET ()
#Value Shortint ICASEPROP
#Value Char SCODFIC ()
#Value Char SZONE ()
#Value Char SID1 ()
#Value Char SID2 ()
#Value Char SCUR ()
#Value Shortint ICHGTYP
#Value Date DDATECUR
#Value Char SPROCUR ()
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------------
  ILINE = fmet this.ADDLINE("LIST", [V]CST_ALASTPOS)
  If ILINE = [V]CST_ANOTDEFINED Then
    [L]ARET_VALUE = fmet this.ASETERROR("", func AFNC.MES2(mess(528,2260,1), SFROM, STARGET), [V]CST_AERROR)
    Return
  Endif
  # ---------------------------------
  If STARGET = AVOID.ACHAR Then
    STARGET = SFROM
  Endif
  # ---------------------------------
  this.LIST(ILINE).FROPROP = SFROM
  this.LIST(ILINE).TARGPROP = STARGET
  this.LIST(ILINE).CASEPROP = ICASEPROP
  this.LIST(ILINE).CODFIC = SCODFIC
  this.LIST(ILINE).ZONE = SZONE
  this.LIST(ILINE).IDENT1 = SID1
  this.LIST(ILINE).IDENT2 = SID2
  this.LIST(ILINE).CUR = SCUR
  this.LIST(ILINE).CHGTYP = ICHGTYP
  this.LIST(ILINE).DATECUR = DDATECUR
  this.LIST(ILINE).PROCUR = SPROCUR
  # ---------------------------------
Return

###################################################################################################
###################################################################################################
# FUNCTIONS
###################################################################################################
###################################################################################################
Funprog DO_COPY(TECPJMCOPY, TECCLA, CLAFROM, CLATARGET)
Variable Instance TECPJMCOPY Using C_TECPJMCOPY
Variable Instance TECCLA Using C_PJMACOPY
Variable Instance CLAFROM Using OBJECT
Variable Instance CLATARGET Using OBJECT

Local Integer IARENDRE
Local Integer NI
Local Char SFROMPRO(250)
Local Char STARGPRO(250)
Local Char STARGPROCUR(250)
Local Char STARGPROVAL(GLONCUR)
Local Decimal NFROMNT
Local Decimal NTARMNT
Local Integer ISTAT

  IARENDRE = [V]CST_AOK
  # ---------------------------------
  # The "COPY_LOAD_PROPERTIES" method have to be created in all classes to be copied.
  # At the beginning the idea was to call the method from here. But this is too resrictive to manage many cases.
  # It's easier to let call this method from the COPY method, in each class.
  # I let that here, commented, to remember that.
  #IRET = fmet CLAFROM.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA)
  #If IRET >= [V]CST_AERROR Then
  #  [L]ARET_VALUE = fmet TECPJMCOPY.ASETERROR("", mess(524,2260,1), [V]CST_AERROR)
  #  Return
  #Endif
  # ------------------------------------------------------------------------------------------------------------------------------------
  For NI = 1 To maxtab(TECPJMCOPY.LIST)
    If TECPJMCOPY.LIST(NI) <> null and find(TECPJMCOPY.LIST(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      # Copy the property value
      If left$(TECPJMCOPY.LIST(NI).FROPROP, 1) = "#" Then
        # If the first characer is #, the property value is in an available class in DO_COPY function
        SFROMPRO = mid$(TECPJMCOPY.LIST(NI).FROPROP,2,len(TECPJMCOPY.LIST(NI).FROPROP))
      Elsif left$(TECPJMCOPY.LIST(NI).FROPROP, 1) = ">" Then
        # If the first characer is >, the value is directly given
        SFROMPRO = mid$(TECPJMCOPY.LIST(NI).FROPROP,2,len(TECPJMCOPY.LIST(NI).FROPROP))
      Else
        # If the first character is not #, the property value is in the CLAFROM class
        SFROMPRO = "CLAFROM." + TECPJMCOPY.LIST(NI).FROPROP
      Endif
      STARGPRO = "CLATARGET." + TECPJMCOPY.LIST(NI).TARGPROP
      # ---------------------------------
      If dim(SFROMPRO) <= 0 Then
        IARENDRE = fmet TECPJMCOPY.ASETERROR("", func AFNC.MES1(mess(525,2260,1), SFROMPRO), [V]CST_AERROR)
        Break
      Endif
      If left$(TECPJMCOPY.LIST(NI).FROPROP, 1) <> ">" and dim(STARGPRO) <= 0 Then
        IARENDRE = fmet TECPJMCOPY.ASETERROR("", func AFNC.MES1(mess(526,2260,1), STARGPRO), [V]CST_AERROR)
        Break
      Endif
      # ---------------------------------
      Case TECPJMCOPY.LIST(NI).CASEPROP
        When 1
          # Basic property
          If left$(TECPJMCOPY.LIST(NI).FROPROP, 1) = ">" Then
            Assign STARGPRO With SFROMPRO
          Else
            Assign STARGPRO With evalue(SFROMPRO)
          Endif
        When 2
          # Translated property
          Assign STARGPRO With evalue(SFROMPRO)
        When 3
          # Amount property
          STARGPROCUR = "CLATARGET." + TECPJMCOPY.LIST(NI).PROCUR
          If dim(STARGPROCUR) <= 0 Then
            IARENDRE = fmet TECPJMCOPY.ASETERROR("", func AFNC.MES1(mess(526,2260,1), STARGPROCUR), [V]CST_AERROR)
            Break
          Endif
          STARGPROCUR = evalue(STARGPROCUR)
          If STARGPROCUR = TECPJMCOPY.LIST(NI).CUR Then
            # Same currency : get it directly
            Assign STARGPRO With evalue(SFROMPRO)
          Else
            # Currencies not equal : to convert
            NFROMNT = evalue(SFROMPRO)
            Call CONVERT(TECPJMCOPY.ACTX, TECPJMCOPY.LIST(NI).CUR, STARGPROCUR, STARGPROCUR, TECPJMCOPY.LIST(NI).CHGTYP, TECPJMCOPY.LIST(NI).DATECUR, NFROMNT, NTARMNT, ISTAT) From TRTDEV_SYRA
            If ISTAT <> 0 Then
              IARENDRE = fmet TECPJMCOPY.ASETERROR("", mess(236,2260,1) - STARGPRO, [V]CST_AERROR)
              Break
            Endif
            Assign STARGPRO With NTARMNT
          Endif
        When Default
          Assign STARGPRO With evalue(SFROMPRO)
      Endcase
      # ---------------------------------
    Endif
  Next NI
End IARENDRE

###################################################################################################
Funprog DO_COPY_AXX(TECPJMCOPY, TECCLA, CLAFROM, CLATARGET)
Variable Instance TECPJMCOPY Using C_TECPJMCOPY
Variable Instance TECCLA Using C_PJMACOPY
Variable Instance CLAFROM Using OBJECT
Variable Instance CLATARGET Using OBJECT

Local Integer IARENDRE
Local Integer NI
Local Integer IADXLOG
Local Integer INOTTRANSLATED
Local Char SFROMID1(250)
Local Char SFROMID2(250)
Local Char STARGID1(250)
Local Char STARGID2(250)

  IARENDRE = [V]CST_AOK
  # ---------------------------------
  # If this is a translated text property : copy all the existing translated texts (not possible when left$(TECPJMCOPY.LIST(NI).TARGPROP, 1) = "#")
  # Translated are managed in a second step because all TARGET properties received their value
  INOTTRANSLATED = [V]CST_ANO
  IADXLOG = (adxlog<>0)
  Local File ATEXTRA [FAXX]  # From
  Local File ATEXTRA [TAXX]  # Target
  For NI = 1 To maxtab(TECPJMCOPY.LIST)
    If TECPJMCOPY.LIST(NI) <> null and find(TECPJMCOPY.LIST(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECPJMCOPY.LIST(NI).CASEPROP = 2 and left$(TECPJMCOPY.LIST(NI).TARGPROP, 1) <> "#" Then
        INOTTRANSLATED = [V]CST_AYES
        # ---------------------------------
        If adxlog = 0 and IADXLOG = [V]CST_AFALSE Then
          Trbegin [F:TAXX]
        Endif
        # ---------------------------------
        SFROMID1 = num$(evalue("CLAFROM." + TECPJMCOPY.LIST(NI).IDENT1))
        If TECPJMCOPY.LIST(NI).IDENT2 <> AVOID.ACHAR Then
          SFROMID2 = num$(evalue("CLAFROM." + TECPJMCOPY.LIST(NI).IDENT2))
        Else
          SFROMID2 = AVOID.ACHAR
        Endif
        # ---------------------------------
        STARGID1 = num$(evalue("CLATARGET." + TECPJMCOPY.LIST(NI).IDENT1))
        If TECPJMCOPY.LIST(NI).IDENT2 <> AVOID.ACHAR Then
          STARGID2 = num$(evalue("CLATARGET." + TECPJMCOPY.LIST(NI).IDENT2))
        Else
          STARGID2 = AVOID.ACHAR
        Endif
        # ---------------------------------
        Filter [FAXX] Where [F:FAXX]CODFIC = TECPJMCOPY.LIST(NI).CODFIC
&                       and [F:FAXX]ZONE = TECPJMCOPY.LIST(NI).ZONE
&                       and [F:FAXX]LANGUE <> TECPJMCOPY.ACTX.LAN
&                       and [F:FAXX]IDENT1 = SFROMID1
&                       and [F:FAXX]IDENT2 = SFROMID2
        For [FAXX]
          [F:TAXX] = [F:FAXX]
          [F:TAXX]IDENT1 = STARGID1
          [F:TAXX]IDENT2 = STARGID2
          Write [TAXX]
          If fstat Then
            IARENDRE = fmet TECPJMCOPY.ASETERROR("", func AFNC.MES4( mess(527,2260,1), TECPJMCOPY.LIST(NI).CODFIC, TECPJMCOPY.LIST(NI).ZONE, STARGID1, STARGID2), [V]CST_AERROR)
            Break
          Endif
        Next
        Filter [FAXX]
        If IARENDRE <> [V]CST_AOK Then
          Break
        Endif
        # ---------------------------------
      Endif
    Endif
  Next NI
  If IADXLOG = [V]CST_AFALSE and INOTTRANSLATED = [V]CST_AYES Then
    If IARENDRE <= [V]CST_AWARNING Then
      Commit
    Else
      Rollback
    Endif
  Endif
  # ---------------------------------
End IARENDRE

###################################################################################################
Funprog DO_COPY_CHAIN(TECPJMCOPY, TECCLA, CLAFROM, CLATARGET)
Variable Instance TECPJMCOPY Using C_TECPJMCOPY
Variable Instance TECCLA Using C_PJMACOPY
Variable Instance CLAFROM Using OBJECT
Variable Instance CLATARGET Using OBJECT

  IARENDRE = [V]CST_AOK
  # ---------------------------------
  IARENDRE = func DO_COPY(TECPJMCOPY, TECCLA, CLAFROM, CLATARGET)
  If IARENDRE = [V]CST_AOK Then
    IARENDRE = func DO_COPY_AXX(TECPJMCOPY, TECCLA, CLAFROM, CLATARGET)
  Endif
  # ---------------------------------
End IARENDRE

