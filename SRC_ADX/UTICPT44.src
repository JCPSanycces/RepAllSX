#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# UTICPT44   Suppression du paramètre OPTCMM             Module CPT   #
#######################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Demande 68007 : Suppresion Param OPTCMM") From LECFIC
  Call MAJ_UTICPT44(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT44(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTICPT44 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
Local File =DOSSIER+".ADOPAR"    [ADP]

Call DEBTRANS From GLOCK

Trbegin [ADP]
 Readlock [ADP]ADP0 = "CPT";"OPTCMM"
 If !fstat
  Delete [ADP] Curr
  If fstat=1
   # Erreur d'effacement
   GOK = 0 : Call ECR_TRACE(mess(28,125,1)-"ADOPAR : OPTCMM",-1) From GESECRAN : Goto AB_UTICPT44 
  Endif
 Endif
Commit
Close Local File [ADP]

Call ECR_TRACE("UTICPT44 : record processed",0) From GESECRAN
End

$AB_UTICPT44
Rollback
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
Call MAJ_UTICPT44(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call MAJ_UTICPT44(APPLI)
End
