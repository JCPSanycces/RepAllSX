    # 91606 :(04/08/14) Transportation notes (Sales part dev)
    When "SIH" :
        Case WZONCOU
            When "VATDAT" :                           : # 95785 : Recalcul tarif/taxe si modification VATDAT
                GTARFLG="2"                           : # 95785
                Gosub RECALC_LIGNE From SUBSIHB       : # 95785
            When Default
        Endcase

    When Default
Endcase
Raz GTARFLG
mkstat=SAVMKSTAT

End
