#<AdxTL>@(#)7.0.0.0 $Revision$
##################################################################
#                                                                #
# VISUGAM : visualisation gamme multi-niveaux                    #
# action : VISUROU                                               #
#                                                      MM  05.02 #
##################################################################
# V6 remplacé par Action VISUROHG 
##################################################################

$ACTION
#-- action liées à la saisie fenêtre
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When "APRES_MODIF": Gosub APRES_MODIF
  When "FIN"        : Gosub FIN
  When Default 
Endcase 

Return

##################################################################
$OUVRE
# sr 08.04 demande 24266
# ouverture systématique afin de s'affranchir des éventuels filtres positionnés par les fonctions appelantes et
# risquant de perturber le multi-niveau
# If clalev([F:ROH])=0 : Local File ROUTING[ROH] : Endif
Local File ROUTING [ROH]
 If clalev([F:ROO])=0 : Local File ROUOPE     [ROO] : Endif
 If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
 If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
 If clalev([F:TRO])=0 : Local File TABROUALT  [TRO] : Endif
 If clalev([F:BOH])=0 : Local File BOM        [BOH] : Endif
 If clalev([F:BOD])=0 : Local File BOMD       [BOD] : Endif
 If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
 If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI58337

Local Integer LEVEL

Local Char    WFCY (GLONFCY), WROU(GLONITM), WCOMP(GLONITM)
Local Integer WROUALT 

Return 

##################################################################
$BOUTON
 Case BOUT
     When "a" :
        Call PRTSCR("VISUROU","VROU", "",0 ,0) From ATRTX3
 Endcase
Return

##################################################################
$FIN
 Call IMPSCR From ATRTX3
Return

##################################################################
$DEBUT
#Initialisation de l'entête
Raz [M:VROU]

If PARAM(1)<>"" [M:VROU]ITMREF    = evalue(PARAM(1)) Endif
If PARAM(1)<>"" [M:VROU]ROUALT    = evalue(PARAM(2)) Endif
If PARAM(1)<>"" [M:VROU]DATREF    = evalue(PARAM(3)) Endif
If PARAM(1)<>"" [M:VROU]FCY       = evalue(PARAM(4)) Endif
If [M:VROU]ITMREF<>"" & [M:VROU]FCY<>""
  Read [ITF]ITF0 = [M:VROU]ITMREF;[M:VROU]FCY
  If fstat 
     GMESSAGE=[M:VROU]ITMREF-"("+[M:VROU]FCY+")"-":"-mess(45,193,1): Return 
  Endif
  [M:VROU]MFGLOTQTY = [F:ITF]MFGLOTQTY 
Endif

If [M:VROU]ROUALT <>0
 Gosub TRT_AFFROU
Endif

Return
############################################################
$APRES_MODIF
Case COUZON
  When "FCY"       : [M:VROU]FCY    = CZ
  When "ROUALT"    : [M:VROU]ROUALT = val(CZ)
  When "ITMREF"    : [M:VROU]ITMREF = CZ
  When "DATREF"    : [M:VROU]DATREF = CZ
Endcase
If [M:VROU]ROUALT <> 0 & [M:VROU]ITMREF<> "" & [M:VROU]FCY<>""
  Gosub TRT_AFFROU
Endif
Return
############################################################

##################################################################
$TRT_AFFROU
# FGR 02/10/2009 : X3SUIVI58337 : tant que j'y suis, ici mauvais index
#Read [ROH]ROH1=[M:VROU]ITMREF;[M:VROU]ROUALT;[M:VROU]FCY        : # Beryl Site en fin de clé primaire
Read [ROH]ROH0=[M:VROU]ITMREF;[M:VROU]ROUALT;[M:VROU]FCY        : # Beryl Site en fin de clé primaire
If fstat :
 GMESSAGE = [M:VROU]ITMREF-"("+[M:VROU]FCY+")"-mess(153,196,1)
 GERR =1 : FIN=1 : Return 
Endif
# FGR 02/10/2009 : X3SUIVI58337
#[M:VROU]ROUDES    = [F:ROH]ROUDES
Call LECTEXTRA([M:VROU]ROUDES,"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA

[M:VROU]USESTA    = [F:ROH]USESTA
[M:VROU]TIMUOMCOD = [F:ROH]TIMUOMCOD
Affzo [M:VROU]5-15

#Contrôle de validité de l'entête de gamme du PF
If [F:ROH]ROUENDDAT = [0/0/0]
    [F:ROH]ROUENDDAT= [31/12/2999]
Endif
If (([M:VROU]DATREF >= [F:ROH]ROUSTRDAT | [M:VROU]DATREF= [0/0/0]) & ([M:VROU]DATREF<=[F:ROH]ROUENDDAT))
   Gosub DIS_ROU
Else
   GMESSAGE = mess(8,193,1)
   GERR =2 
Endif



Return
##################################################################
$DIS_ROU
Local Char    TEMPITM(GLONITM)
Local Integer TEMPALT
Local Integer VALFLG

LEVEL = 0
VALFLG =0

Effzo [M:VROU]20

# RECHERCHE DES NOMENCLATURES ASSOCIEES AU COUPLE GAMME+ALT
Read [TRO]TRO0= [M:VROU]ROUALT
If fstat : FIN = 1 : Return : Endif

# sauvegerade des valeurs (on les perd sinon)
TEMPITM = [M:VROU]ITMREF
TEMPALT = [M:VROU]ROUALT

WROU=[M:VROU]ITMREF
WFCY=[M:VROU]FCY

Look [BOH]BOH0=[M:VROU]ITMREF;[F:TRO]BOMALT1;2
If fstat
    Look [BOH]BOH0=[M:VROU]ITMREF;[F:TRO]BOMALT2;2
    If fstat 
        Look [BOH]BOH0=[M:VROU]ITMREF;[F:TRO]BOMALT3;2
        If fstat : GMESSAGE =mess(200,193,1) : Return 
        Else
             If [M:VROU]DATREF <>[0/0/0]
                 Call VERIF_BOM ([M:VROU]DATREF , [M:VROU]ITMREF , [F:TRO]BOMALT3, VALFLG)
             Endif
             If (VALFLG =0)
               Call GENERE_LISTE(LEVEL, [M:VROU]DATREF , [M:VROU]ITMREF , [F:TRO]BOMALT3 , WFCY, WROU , WROUALT) 
             Endif
        Endif
    Else
        If [M:VROU]DATREF <>[0/0/0]
            Call VERIF_BOM ([M:VROU]DATREF , [M:VROU]ITMREF , [F:TRO]BOMALT2 , VALFLG)
        Endif
        If (VALFLG =0)
            Call GENERE_LISTE(LEVEL,[M:VROU]DATREF ,[M:VROU]ITMREF , [F:TRO]BOMALT2 , WFCY, WROU , WROUALT)
        Endif
    Endif
Else
 If [M:VROU]DATREF <>[0/0/0]
     Call VERIF_BOM ([M:VROU]DATREF , [M:VROU]ITMREF , [F:TRO]BOMALT1 , VALFLG)
 Endif
 If (VALFLG =0)
    Call GENERE_LISTE(LEVEL,[M:VROU]DATREF ,[M:VROU]ITMREF , [F:TRO]BOMALT1 , WFCY, WROU , WROUALT)
 Endif 
Endif

[M:VROU]ITMREF = TEMPITM
[M:VROU]ROUALT = TEMPALT 
Affzo [M:VROU]20


Return

##################################################################
# Nomenclature valide ?
Subprog VERIF_BOM (LDAT , LITMREF , LBOMALT , VALFLG )
# LDAT : date référence
# LITMREF : article parent
# LBOMALT : alternative de nomenclature
# VALFLG : flag indicateur de validité de la nomenclature. Si VALFGL=1, nomenclature non valide; VALFGL=0,valide 
Value Date LDAT        # FGR 14/01/2010 : X3SUIVI60986
Value Char LITMREF     # FGR 14/01/2010 : X3SUIVI60986 
Value Integer LBOMALT  # FGR 14/01/2010 : X3SUIVI60986
Variable Integer VALFLG

Read [BOH]BOH0 =LITMREF;LBOMALT;2
If ([BOH]BOHSTRDAT<>[0/0/0] & LDAT < [BOH]BOHSTRDAT)|([BOH]BOHENDDAT<>[0/0/0] & LDAT>[BOH]BOHENDDAT)
    VALFLG = 1
    GMESSAGE = LITMREF+"/"+num$(LBOMALT)-":"-mess(54,199,1)
Endif

End
##################################################################
$AFF_ROU
Local Char WFIL(80)
# Affichage des gammes de chaque semi-fini
If NBLIG=0 : nolign=0 : Endif

# selection des opérations valides
If DATREF <>[0/0/0]
    WFIL = "(VALSTRDAT=[0/0/0] | VALSTRDAT<=LDAT) and  (VALENDDAT=[0/0/0] | VALENDDAT>=LDAT)" 
Else 
    WFIL = "1=1"
Endif


Filter [ROO] Where FCY = WFCY and ITMREF=WROU and ROUALT=WROUALT and evalue(WFIL)
For [ROO]
    nolign +=1
    [M:VROU]=[F:ROO]
    [M:VROU]LEV(nolign-1) = num$(LEVEL)
    [M:VROU]CODITM(nolign-1) = WCOMP
    [M:VROU]CODROU(nolign-1) = WROU
    # recherche du statut d'utilisation de la gamme
    Read[ROH]ROH0=WROU;WROUALT;WFCY        : # Beryl Site en fin de clé primaire
    If !fstat 
        [M:VROU]USESTASF(nolign-1)  = [F:ROH]USESTA
    Endif
    # recherche du type + centre des postes principaux
    Read [MWS]WST0=[F:ROO]WST;WFCY
    If !fstat 
        [M:VROU]WCR(nolign-1)       = [F:MWS]WCR
        [M:VROU]WSTTYP(nolign-1)    = [F:MWS]WSTTYP
    Endif
    # recherche du type + centre des postes M-O
    If [F:ROO]LABWST <> ""
        Read [MWS]WST0=[F:ROO]LABWST;WFCY
        If !fstat 
            [M:VROU]LABWCR(nolign-1)       = [F:MWS]WCR
            [M:VROU]LABWSTTYP(nolign-1)    = [F:MWS]WSTTYP
        Endif
    Else
       [M:VROU]LABWSTTYP(nolign-1) = 0
    Endif
    # recherche du type + centre des postes SST
    If [F:ROO]SCOCOD <>1    # pas de SST
        Read [MWS]WST0=[F:ROO]SCOWST;WFCY
        If !fstat 
            [M:VROU]SCOWCR(nolign-1)       = [F:MWS]WCR
            [M:VROU]SCOWSTTYP(nolign-1)    = [F:MWS]WSTTYP
        Endif
    Endif
Next 
Filter [ROO]

[M]NBLIG = nolign

Return

##################################################################
# lecture fichiers
$LEC_FILES

# lecture entete nomenclature 
Read [BOH]BOH0=LITM;LBOMALT;2 
If fstat : Return : Endif  

Return
##################################################################
# lecture récursive de la nomenclature 
Subprog GENERE_LISTE (LEVEL, LDAT, LITM , LBOMALT, WFCY, WROU, WROUALT)
# LITM = produit fini à fabriquer
# LDAT = date de référence gamme
# LBOMALT = alternative de nomenclature
# WFCY = site de production du produit fini
# LEVEL = niveau du composant dans la nomenclature
# WROUALT = gamme à déterminer
# WROU = alt de gamme à déterminer

Variable Integer LEVEL
Value    Date    LDAT
Value    Char    LITM
Value    Integer LBOMALT
Value    Char    WFCY 
Variable Integer WROUALT 
Variable Char WROU

# GHOSFLG = flag qui indique la présence de fantômes parmi les articles de la nomenclature
# Si GHOSTFLG <> 0 : présence de fantômes , sinon  GHOSTFLG = 0 : absence de fantômes 

Local Integer ITMFLG
#ITMFLG = flag article site. Si l'article a un site de rattachement WITMFLG=0, sinon,  WITMFLG=1

LEVEL  += 1


# lecture entête
Gosub LEC_FILES                   
# selection des articles valides
If  LDAT =[0/0/0]
    Local File BOMD[BOD] Where ITMREF=LITM & BOMALT=LBOMALT & BOMALTTYP = 2
Else
    Local File BOMD[BOD] Where ITMREF=LITM & BOMALT=LBOMALT &  BOMALTTYP = 2 &
&       (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&       (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT)) 
Endif 


# lecture premier enregistrement 
Read [BOD] First  
While !fstat 
    WROU ="" : WROUALT=0
 
    If [F:BOD]CPNTYP <> 5
        # Catégorie article ?
        Read [ITM]ITM0 = [F:BOD]CPNITMREF
        If fstat : GMESSAGE =mess(18,7,1)-[F:BOD]CPNITMREF-mess(0,9060,1): End : Endif
        If [F:ITM]MFGFLG = 2   # Article fabriqué
    
            # Traversée des fantômes
            If ([F:ITM]PHAFLG=2)
                If [M:VROU]GHOSTFLG=0 : [M:VROU]GHOSTFLG =1 : [M:VROU]GHOST=[F:BOD]CPNITMREF  : Endif     
                Goto NEXT_ITM   
            Endif
    
            ITMFLG =0
            Call SEARCH_ROU ([F:BOD]CPNITMREF, WFCY,[M:VROU]ROUALT, WROUALT ,WROU, ITMFLG) 
            If WROU<>"" & WROUALT<>0  
    
                # Gamme du sous-produit valide ?
                Read [ROH]ROH1 = WFCY;WROU;WROUALT 
                If fstat : GMESSAGE = WROU+"/"+num$(WROUALT)-":"-mess(153,196,1): End
                Else
                    If LDAT =[0/0/0] 
                        WCOMP = [F:BOD]CPNITMREF 
                        If [M:VROU]GHOSTFLG =1 : LEVEL -=1 :[M:VROU]GHOSTFLG=2 : Endif
                        Gosub AFF_ROU  
                    Else
                    # Controle de validité de l'entête de gamme du sous-produit 
                        If ([F:ROH]ROUSTRDAT = [0/0/0] | ([F:ROH]ROUSTRDAT<> [0/0/0] & [F:ROH]ROUSTRDAT <=LDAT ))&
&                       ([F:ROH]ROUENDDAT = [0/0/0] | ([F:ROH]ROUENDDAT<> [0/0/0] & [F:ROH]ROUENDDAT>= LDAT))
                             WCOMP = [F:BOD]CPNITMREF
                             If [M:VROU]GHOSTFLG =1 : LEVEL -=1 :[M:VROU]GHOSTFLG=2 : Endif
                             Gosub AFF_ROU  
                        Else 
                             GMESSAGE =[F:BOD]CPNITMREF+"/"+num$(WROUALT)-":"-mess(8,193,1)
                             Goto NEXT_ROU
                        Endif
                    Endif
                Endif 
            Else
                If ITMFLG =1 :  GMESSAGE =[F:BOD]CPNITMREF-mess(45,193,1): End
                Else :  GMESSAGE=[F:BOD]CPNITMREF-mess(167,190,1) :  End  : Endif
            Endif
    
            # Nomenclature du sous-produit valide ?
            Read [BOH]BOH0 =[F:BOD]CPNITMREF;LBOMALT;2
            If  LDAT <>[0/0/0] 
                If ([BOH]BOHSTRDAT<>[0/0/0] & LDAT < [BOH]BOHSTRDAT)|([BOH]BOHENDDAT<>[0/0/0] & 
&            LDAT>[BOH]BOHENDDAT)
                    Goto NEXT_ROU
                Endif
            Endif
    
        Else 
            # l'article n'est pas fabriqué, donc pas de gamme de fabrication à afficher
            Goto NEXT_ROU
        Endif
    Endif    
$NEXT_ITM
# si [M]GHOSTFLG <> 0, présence de fantômes parmi les articles de la nomenclature
# ([M]GHOSTFLG=0, absence de fantôme)
# Pour réinitialiser [M]GHOSTFLG à 0, 2 cas
# 1- soit la nomenclature du fantôme ne  comporte aucun sous-produit : réinitialisation en sortant de la branche
# 2- soit il y a parmi les composants de la nomenclature du fantôme des sous produits fabriqués : 
# [M:VROU]GHOSTFLG = 2 lors de l'affichage de leurs gammes. 
# Qd [M:VROU]GHOSTFLG = 2 : remise à jour du niveau + réinitialisation à 0 de [M:VROU]GHOSTFLG
    
    Call GENERE_LISTE (LEVEL, LDAT, [F:BOD]CPNITMREF , LBOMALT, WFCY,WROU,WROUALT)
    If ( ([M:VROU]GHOST = [F:BOD]CPNITMREF)  & ([M:VROU]GHOSTFLG = 1)) :  [M:VROU]GHOSTFLG=0 : Endif
    If [M:VROU]GHOSTFLG = 2 : LEVEL +=1 : [M:VROU]GHOSTFLG = 0 : Endif
    LEVEL -=1
    WROU=""
    WROUALT= 0
    Gosub LEC_FILES                  

$NEXT_ROU
    Read [BOD] Next 

Wend
Close Local File


End

##################################################################
#RECUPERE GAMME+ALTERNATIVE PERMETTANT DE FABRIQUER CHAQUE PRODUIT SEMI-FINI
Subprog SEARCH_ROU(COMPOSANT, FCY , LALT, WROUALT ,WROU,WITMFLG )
# COMPOSANT = article pour lequel on cherche gamme+alt 
# FCY = site de la gamme initiale
# LALT =  gamme initiale
# WROUALT = gamme à déterminer
# WROU = alt de gamme à déterminer
# WITMFLG = flag aticle site. Si l'article a un site de rattachement WITMFLG=0, sinon,  WITMFLG=1
Value    Char    COMPOSANT
Value    Char    FCY
Value    Integer LALT   
Variable Integer  WROUALT 
Variable Char WROU
Variable Integer WITMFLG

Local Integer WMSG
Local Integer WALT



# recherche de la gamme mère du composant
Read [ITF]ITF0 = COMPOSANT;FCY
If fstat : WITMFLG =1 : End : Endif
WROUALT = [ITF]MFGROUALT
WROU    = [ITF]MFGROU
# si composant n'a pas de gamme mère, recherche de la première gammme compatible et valide
If WROUALT=0 | WROU=""
    For [ROH] Where FCY = FCY & ITMREF=COMPOSANT 
        Read [TRO]TRO0 = [F:ROH]ROUALT
        If !fstat   
            WALT= LALT            
            Call CONTMFGGAM(FCY,WALT,[F:ROH]ROUSTRDAT,[F:ROH]WORMAXQTY , [F:ITM]STU, WMSG) From MFGLIB
            If WALT<>0
                WROU = COMPOSANT
                WROUALT = WALT
                Break
            Endif
       Endif
    Next
Endif



End
