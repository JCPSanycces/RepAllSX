#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Exécution d'un script d'appel                                     Module CRM           3 janvier 2001  #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GICANNEXT
Global Char GXSZCNDTYP
Global Integer GXICNDTYP
Global Integer GIMUSTSAVE
Global Char GSZFQST    # Code première question
Global Char GSZLQST    # Code dernière question
Global Char GSZCQST    # Code question courante.

  If clalev ([F:SCP])<=0 Local File SCRIPT [SCP] : Endif
  If clalev ([F:SCQ])<=0 Local File SCPQST [SCQ] : Endif
  If clalev ([F:SQC])<=0 Local File SCPQSTCND [SQC] : Endif
  If clalev ([F:SCA])<=0 Local File SCPASW [SCA] : Endif
  GICANNEXT = 0
  GXSZCNDTYP = ""
  GXICNDTYP = 0
  GIMUSTSAVE = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Bouton Précédent
  If GSZCQST = GSZFQST Then
    ETABOU(GSPE1) = 0
  Else
    ETABOU(GSPE1) = 1
  Endif
  #Bouton Suivant
  If GSZCQST = GSZLQST Then
    ETABOU(GSPE2) = 0
  Else
    ETABOU(GSPE2) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Affectation de PARAM(1) Référence script appel
  [M:SCP1]SCPNUM= PARAM(1) #Code script
  #Affectation de PARAM(2) Référence appel
  [M:SCP1]CLLNUM= PARAM(2) #Code script
  #Affectation de PARAM(3) Simulation ou non
  If PARAM(3) = "" Then
    [M:SCP1]SCPFLGSIM = 1
  Else
    If PARAM(3) = "NON" Then
      [M:SCP1]SCPFLGSIM = 0
    Else
      [M:SCP1]SCPFLGSIM = 1
    Endif
  Endif
  #Détection des boucles sans fin en simulation.
  If [M:SCP1]SCPFLGSIM = 1
    Gosub ONCHECKSCP
    If FIN Then
      Return
    Endif
  Endif
  Call LOADFIRQST
  Call SETSCP1ZO([M:SCP1]QSTTYP)
  Affzo [M:SCP1]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:SCP1]
  Kill GICANNEXT
  Kill GXSZCNDTYP
  Kill GXICNDTYP
  Kill GIMUSTSAVE
  Kill GSZFQST    # Code première question
  Kill GSZLQST    # Code dernière question
  Kill GSZCQST    # Code question courante.
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONPREV
    When "B"
      Gosub ONNEXT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Gestion du bouton Précédent
#########################################################
$ONPREV
Local Integer ITSOK

  ITSOK = 1
  Read [SQC]SQC1=[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
  If !fstat Then
    Call RAZASW
    Call LOADQST([F:SQC]QSTNUM, ITSOK)
    If !ITSOK Then
      GMESSAGE = mess(373,196,1) #Erreur lors du chargement de la question précédente.
      GERR = 1
    Endif
    GSZCQST = [M:SCP1]QSTNUM
  Endif
Return

##########################################################################################################
# Gestion du bouton Suivant
#########################################################
$ONNEXT
Local Integer ITWOROUND
Local Integer ITISOK
Local Char SZNEXQST
Local Integer IQUIT
Local Integer INEXT
Local Integer ICNDFOUND
Local Integer ICNDSTRLEN
Local Integer ISTRLENRIG
Local Integer IRANG
Local Integer IOKREP

  ITWOROUND = 0
  SZNEXQST = ""
  IQUIT = 0
  INEXT = 0
  ITISOK = 1
  ICNDFOUND = 0
  ICNDSTRLEN = 0
  ISTRLENRIG = 0
  IRANG = 0
  IOKREP = 0
  #Enregistre la réponse si on n'est pas en simulation et qu'une modif a été saisie.
  If [M:SCP1]SCPFLGSIM = 0 Then
    If [M:SCP1]QSTTYP = 4 Then
      Call SAVEASW
      GIMUSTSAVE = 0
    Else
      If GIMUSTSAVE Then
        Call SAVEASW
        GIMUSTSAVE = 0
      Endif
    Endif
  Endif
  #Détermine la question suivante à charger.
  Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM
  While ITWOROUND <> 2
    For [SQC]SQC2
      If ITWOROUND = 0 Then
        #Recherche de la condition Quitter
        If [F:SQC]CND = 2 Then
          IQUIT = 1
          Break 2
        Endif
      Elsif ITWOROUND = 1 Then
        #Recherche de la condition Suivante
        If [F:SQC]CND = 1 Then
          INEXT = 1
          SZNEXQST = [F:SQC]NEXQST
          Break 2
        Endif
      Endif
    Next
    ITWOROUND += 1
  Wend
  Filter [SQC]
  #Condition Quitter trouvée
  If IQUIT Then
    FIN = 1
    Return
  Endif
  #Condition Suivante trouvée
  If INEXT Then
    #Efface les réponses précédentes
    Call RAZASW
    Call LOADQST(SZNEXQST, ITISOK)
    If !ITISOK Then
      GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
      GERR = 1
    Endif
    GSZCQST = [M:SCP1]QSTNUM
    Return
  Endif
  #Autres conditions à tester
  #---------------------------------------------------#
  If [M:SCP1]QSTTYP = 1 Then
    #Alphanumérique
    #---------------------------------------------------#
    #####Condition = Commence par
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 3
    ICNDFOUND = 0
    For [SQC]SQC2
      ICNDSTRLEN = len([F:SQC]ALHCND)
      If left$([M:SCP1]ASWALH, ICNDSTRLEN) = [F:SQC]ALHCND Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Contient
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 4
    ICNDFOUND = 0
    For [SQC]SQC2
      If instr(1, [M:SCP1]ASWALH, [F:SQC]ALHCND) Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Se termine par
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 5
    ICNDFOUND = 0
    For [SQC]SQC2
      ICNDSTRLEN = len([F:SQC]ALHCND)
      ISTRLENRIG = len([M:SCP1]ASWALH)
      If ICNDSTRLEN <= ISTRLENRIG  Then
        IRANG = ISTRLENRIG - ICNDSTRLEN
        If right$([M:SCP1]ASWALH, IRANG) = [F:SQC]ALHCND Then
          ICNDFOUND = 1
          SZNEXQST = [F:SQC]NEXQST
          Break
        Endif
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
  Elsif [M:SCP1]QSTTYP = 2 Then
    #Numérique
    #---------------------------------------------------#
    #####Condition = Supérieur à
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 6
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWNUM > [F:SQC]NUMCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Supérieur ou égal à
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 7
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWNUM >= [F:SQC]NUMCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Inférieur à
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 8
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWNUM < [F:SQC]NUMCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Inférieur ou égal à
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 9
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWNUM <= [F:SQC]NUMCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Compris entre (numérique)
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 10
    ICNDFOUND = 0
    For [SQC]SQC2
      Read [SCQ]SCQ0=[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
      If !fstat Then
        If [F:SCQ]QSTTYP = 2 Then
          If [M:SCP1]ASWNUM > [F:SQC]NUMCNDMIN and [M:SCP1]ASWNUM < [F:SQC]NUMCNDMAX Then
            ICNDFOUND = 1
            SZNEXQST = [F:SQC]NEXQST
            Break
          Endif
        Endif
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
  Elsif [M:SCP1]QSTTYP = 4 Then
    #Booléen
    #---------------------------------------------------#
    #####Condition = Vrai
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 11
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWBOL = 2 Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Faux
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 12
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWBOL = 1 Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
  Elsif [M:SCP1]QSTTYP = 3 Then
    #Date
    #---------------------------------------------------#
    #####Condition = Compris entre (date)
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 10
    ICNDFOUND = 0
    For [SQC]SQC2
      Read [SCQ]SCQ0=[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
      If !fstat Then
        If [F:SCQ]QSTTYP = 3 Then
          If [M:SCP1]ASWDAT > [F:SQC]DATCNDMIN and [M:SCP1]ASWDAT < [F:SQC]DATCNDMAX Then
            ICNDFOUND = 1
            SZNEXQST = [F:SQC]NEXQST
            Break
          Endif
        Endif
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Avant le
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 13
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWDAT < [F:SQC]DATCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
    #---------------------------------------------------#
    #####Condition = Après le
    Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 14
    ICNDFOUND = 0
    For [SQC]SQC2
      If [M:SCP1]ASWDAT > [F:SQC]DATCNDMIN Then
        ICNDFOUND = 1
        SZNEXQST = [F:SQC]NEXQST
        Break
      Endif
    Next
    Filter [SQC]
    If ICNDFOUND Then
      ITISOK = 1
      #Efface les réponses précédentes
      Call RAZASW
      Call LOADQST(SZNEXQST, ITISOK)
      If !ITISOK Then
        GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
        GERR = 1
      Endif
      GSZCQST = [M:SCP1]QSTNUM
      Return
    Endif
  Endif
  #---------------------------------------------------#
  #####Condition = Autre
  Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM and [F:SQC]QSTNUM = [M:SCP1]QSTNUM and [F:SQC]CND = 15
  ICNDFOUND = 0
  For [SQC]SQC2
    ICNDFOUND = 1
    SZNEXQST = [F:SQC]NEXQST
  Next
  Filter [SQC]
  If ICNDFOUND Then
    ITISOK = 1
    #Efface les réponses précédentes
    Call RAZASW
    Call LOADQST(SZNEXQST, ITISOK)
    If !ITISOK Then
      GMESSAGE = mess(372,196,1) #Erreur lors du chargement de la question suivante.
      GERR = 1
    Endif
    GSZCQST = [M:SCP1]QSTNUM
    Return
  Endif
  Call OUINON(mess(377,196,1), IOKREP) From GESECRAN #Votre réponse ne permet pas de poursuivre le script. Voulez-vous abandonner le script ?
  If IOKREP = 2 Then
    FIN = 1
  Endif
  GICANNEXT = 0
Return

##########################################################################################################
# Chargement d'une question
##########################################################################################################
Subprog LOADQST(SZQSTCOD, IOK)
Value Char SZQSTCOD
Variable Integer IOK

Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  IOK = 1
  Read [SCQ]SCQ0=[M:SCP1]SCPNUM;SZQSTCOD
  If fstat Then
    IOK = 0
    End
  Endif
  [M:SCP1]QST = [F:SCQ]QST
  [M:SCP1]QSTTYP = [F:SCQ]QSTTYP
  [M:SCP1]QSTNUM = [F:SCQ]QSTNUM
  [M:SCP1]ASWTAB = [F:SCQ]ASWTAB
  [M:SCP1]ASWFIE = [F:SCQ]ASWFIE
  [M:SCP1]ASWKEY = [F:SCQ]ASWKEY
  #Chargement des éventuelles réponses déjà enregistrées.
  If [M:SCP1]SCPFLGSIM = 0 Then
    Read [SCA]SCA0=[M:SCP1]CLLNUM;[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
    If !fstat Then
      If [F:SCA]ASWTYP = 1 Then
        [M:SCP1]ASWALH = [F:SCA]ASWALH
      Else
        [M:SCP1]ASWALH = ""
      Endif
      [M:SCP1]ASWNUM = [F:SCA]ASWNUM
      [M:SCP1]ASWDAT = [F:SCA]ASWDAT
      [M:SCP1]ASWBOL = [F:SCA]ASWBOL
    Endif
  Endif
  #Initialise les variables nécessaires à la gestion des listes de réponses possibles
  GXSZCNDTYP = ""
  GSZCNDTYP = 0
  If [M:SCP1]ASWTAB > 0 Then
    If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
    If [M:SCP1]ASWTAB = 1 Then
      Read [ATZ]CODZONE="BPARTNER";[M:SCP1]ASWFIE
    Elsif [M:SCP1]ASWTAB = 2 Then
      Read [ATZ]CODZONE="BPCUSTOMER";[M:SCP1]ASWFIE
    Elsif [M:SCP1]ASWTAB = 3 Then
      Read [ATZ]CODZONE="CONTACTCRM";[M:SCP1]ASWFIE
    Endif
    If !fstat Then
      If [F:ATZ]CODTYP = "ADI" Then
        IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
        IADISEPARATOR -= 1
        GXSZCNDTYP = "ADI"
        GXICNDTYP = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR))
      Elsif [F:ATZ]CODTYP = "M" Then
        If [F:ATZ]NOLIB = 1 Then
          End
        Else
          GXSZCNDTYP = "M"
          GXICNDTYP = [F:ATZ]NOLIB
        Endif
      Endif
    Endif
  Endif
  Call SETSCP1ZO([M:SCP1]QSTTYP)
  Affzo [M:SCP1]1-99
End

##########################################################################################################
# Enregistrement d'une réponse
#########################################################
Subprog SAVEASW
Local Char SZNOMFIE
Local Char SZRECKEY
Local Char SZTESTVAR
Local Integer ITRGTYP
Local Integer IFIETYP
Local Integer IDOASSIGN
Local Integer IMONCTL
Local Char SZMONCTL
Local Integer IDAYCTL
Local Char SZDAYCTL

  SZDAYCTL = ""
  IDAYCTL = 0
  SZMONCTL = ""
  IMONCTL = 0
  SZNOMFIE = ""
  ITRGTYP = 0
  IFIETYP = 0
  IDOASSIGN = 0
  SZRECKEY = ""
  SZTESTVAR = ""
  #Enregistrement de la réponse dans le questionnaire.
  Call DEBTRANS From GLOCK
  Trbegin [SCA]
  Readlock [SCA]SCA0=[M:SCP1]CLLNUM;[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
  #Il s'agit d'un nouvel enregistrement
  If fstat Then
    [F:SCA]CLL = [M:SCP1]CLLNUM
    [F:SCA]SCP = [M:SCP1]SCPNUM
    [F:SCA]QST = [M:SCP1]QSTNUM
    [F:SCA]ASWTYP = [M:SCP1]QSTTYP
    [F:SCA]ASWALH = [M:SCP1]ASWALH
    [F:SCA]ASWNUM = [M:SCP1]ASWNUM
    [F:SCA]ASWDAT = [M:SCP1]ASWDAT
    [F:SCA]ASWBOL = [M:SCP1]ASWBOL
    #Renseigne le champ alpha dans tous les cas
    Case [F:SCA]ASWTYP
      When 2
        [F:SCA]ASWALH = num$([F:SCA]ASWNUM)
      When 3
        If [F:SCA]ASWDAT = [00/00/00] Then
          [F:SCA]ASWALH = mess(26,197,1) #Indéterminé
        Else
          IDAYCTL = day([F:SCA]ASWDAT)
          If IDAYCTL = 0 Then
            SZDAYCTL = "00"
          Elsif IDAYCTL < 10 Then
              SZDAYCTL = '0' + num$(IDAYCTL)
          Else
            SZDAYCTL = num$(IDAYCTL)
          Endif
          IMONCTL = month([F:SCA]ASWDAT)
          If IMONCTL = 0 Then
            SZMONCTL = "00"
          Elsif IMONCTL < 10 Then
            SZMONCTL = '0' + num$(IMONCTL)
          Else
            SZMONCTL = num$(IMONCTL)
          Endif
          If GLANGUE = "FRA" Then
            [F:SCA]ASWALH = SZDAYCTL - month$([F:SCA]ASWDAT) - num$(year([F:SCA]ASWDAT))
          Else
            [F:SCA]ASWALH = month$([F:SCA]ASWDAT) + ',' - SZDAYCTL + ',' - num$(year([F:SCA]ASWDAT))
          Endif
        Endif
      When 4
        Call GET_LIBM(1, [F:SCA]ASWBOL, GLANGUE, [F:SCA]ASWALH) From CRM_UTIL
    Endcase
    Write [SCA]
    If fstat Then
      GMESSAGE = mess(100,141,1)
      GERR = 1
      Unlock [SCA]
      Rollback
      End
    Endif
  Else
    # Il s'agit d'une modification
    [F:SCA]CLL = [M:SCP1]CLLNUM
    [F:SCA]SCP = [M:SCP1]SCPNUM
    [F:SCA]QST = [M:SCP1]QSTNUM
    [F:SCA]ASWTYP = [M:SCP1]QSTTYP
    [F:SCA]ASWALH = [M:SCP1]ASWALH
    [F:SCA]ASWNUM = [M:SCP1]ASWNUM
    [F:SCA]ASWDAT = [M:SCP1]ASWDAT
    [F:SCA]ASWBOL = [M:SCP1]ASWBOL
    #Renseigne le champ alpha dans tous les cas
    Case [F:SCA]ASWTYP
      When 2
        [F:SCA]ASWALH = num$([F:SCA]ASWNUM)
      When 3
        If [F:SCA]ASWDAT = [00/00/00] Then
          [F:SCA]ASWALH = mess(26,197,1) #Indéterminé
        Else
          IDAYCTL = day([F:SCA]ASWDAT)
          If IDAYCTL = 0 Then
            SZDAYCTL = "00"
          Elsif IDAYCTL < 10 Then
            SZDAYCTL = '0' + num$(IDAYCTL)
          Else
            SZDAYCTL = num$(IDAYCTL)
          Endif
          IMONCTL = month([F:SCA]ASWDAT)
          If IMONCTL = 0 Then
            SZMONCTL = "00"
          Elsif IMONCTL < 10 Then
            SZMONCTL = '0' + num$(IMONCTL)
          Else
            SZMONCTL = num$(IMONCTL)
          Endif
          If GLANGUE = "FRA" Then
            [F:SCA]ASWALH = SZDAYCTL - month$([F:SCA]ASWDAT) - num$(year([F:SCA]ASWDAT))
          Else
            [F:SCA]ASWALH = month$([F:SCA]ASWDAT) + ',' - SZDAYCTL + ',' - num$(year([F:SCA]ASWDAT))
          Endif
        Endif
      When 4
        Call GET_LIBM(1, [F:SCA]ASWBOL, GLANGUE, [F:SCA]ASWALH) From CRM_UTIL
    Endcase
    Rewrite [SCA]
    If fstat Then
      GMESSAGE = mess(101,141,1)
      GERR = 1
      Unlock [SCA]
      Rollback
      End
    Endif
  Endif
  Commit
  #Enregistrement de la réponse dans un champs de la base de données.
  If [M:SCP1]ASWFIE = "" Then
    End
  Endif
  #Stocker dans BPARTNER
  If [M:SCP1]ASWTAB = 1 Then
    Read [CLL]CLL0=[M:SCP1]CLLNUM
    If !fstat Then
      SZRECKEY = "[F:CLL]" + [M:SCP1]ASWKEY
      SZTESTVAR = evalue(SZRECKEY)
      If SZTESTVAR = "" Then
        End
      Endif
      Call DEBTRANS From GLOCK
      Trbegin [BPR]
      Readlock [BPR]BPR0=evalue(SZRECKEY)
      If fstat Then
        Rollback
        Unlock [BPR]
      Else
        SZNOMFIE = "[F:BPR]" + [M:SCP1]ASWFIE
        IFIETYP = evalue("Type([F:BPR]" + [M:SCP1]ASWFIE + ")")
        If [M:SCP1]QSTTYP = 1 Then
          #Alphanumérique
          If GXSZCNDTYP = "" Then
            If IFIETYP > 10 and IFIETYP < 500 Then    # FGR 04/02/2015 : X3SUIV105938
              Assign SZNOMFIE With [M:SCP1]ASWALH
              IDOASSIGN = 1
            Else                                      # FGR 04/02/2015 : X3SUIV105938
              IDOASSIGN = 0                           # FGR 04/02/2015 : X3SUIV105938
            Endif
          Else
            If GXSZCNDTYP = "ADI" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                If IFIETYP > 10 Then
                  Assign SZNOMFIE With [M:SCP1]ASWALHBAS
                  IDOASSIGN = 1
                Endif
              Endif
            Elsif GXSZCNDTYP = "M" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                Case IFIETYP
                  When 1,2,4,5,6,7,9
                    Assign SZNOMFIE With val([M:SCP1]ASWALHBAS)
                    IDOASSIGN = 1
                  When Default
                    IDOASSIGN = 0
                Endcase
              Endif
            Endif
          Endif
        Elsif [M:SCP1]QSTTYP = 2 Then
          #Numérique
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWNUM
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Elsif [M:SCP1]QSTTYP = 3 Then
          #Date
          If IFIETYP = 3 Then
            Assign SZNOMFIE With [M:SCP1]ASWDAT
            IDOASSIGN = 1
          Endif
        Elsif [M:SCP1]QSTTYP = 4 Then
          #Booléen
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWBOL
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Endif
        If IFIETYP < 0 Then
          IDOASSIGN = 0
        Endif
        If IDOASSIGN Then
          Rewrite [BPR]
          If fstat Then
            GMESSAGE = mess(101,141,1)
            GERR = 1
            Unlock [BPR]
            Rollback
          Else
            Commit
          Endif
        Else
          # La réponse n'a pas pu être stockée dans le champs hors questionnaire indiqué.
          # Incompatibilité de type.
          Rollback
          Unlock [BPR]
        Endif
      Endif
    Endif
  Endif
  #Stocker dans BPCUSTOMER
  If [M:SCP1]ASWTAB = 2 Then
    Read [CLL]CLL0=[M:SCP1]CLLNUM
    If !fstat Then
      SZRECKEY = "[F:CLL]" + [M:SCP1]ASWKEY
      SZTESTVAR = evalue(SZRECKEY)
      If SZTESTVAR = "" Then
        End
      Endif
      Call DEBTRANS From GLOCK
      Trbegin [BPC]
      Readlock [BPC]BPC0=evalue(SZRECKEY)
      If fstat Then
        Rollback
        Unlock [BPC]
      Else
        SZNOMFIE = "[F:BPC]" + [M:SCP1]ASWFIE
        IFIETYP = evalue("Type([F:BPC]" + [M:SCP1]ASWFIE + ")")
        If [M:SCP1]QSTTYP = 1 Then
          #Alphanumérique
          If GXSZCNDTYP = "" Then
            If IFIETYP > 10 and IFIETYP < 500 Then    # FGR 04/02/2015 : X3SUIV105938
              Assign SZNOMFIE With [M:SCP1]ASWALH
              IDOASSIGN = 1
            Else                                      # FGR 04/02/2015 : X3SUIV105938
              IDOASSIGN = 0                           # FGR 04/02/2015 : X3SUIV105938
            Endif
          Else
            If GXSZCNDTYP = "ADI" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                If IFIETYP > 10 Then
                  Assign SZNOMFIE With [M:SCP1]ASWALHBAS
                  IDOASSIGN = 1
                Endif
              Endif
            Elsif GXSZCNDTYP = "M" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                Case IFIETYP
                  When 1,2,4,5,6,7,9
                    Assign SZNOMFIE With val([M:SCP1]ASWALHBAS)
                    IDOASSIGN = 1
                  When Default
                    IDOASSIGN = 0
                Endcase
              Endif
            Endif
          Endif
        Elsif [M:SCP1]QSTTYP = 2 Then
          #Numérique
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWNUM
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Elsif [M:SCP1]QSTTYP = 3 Then
          #Date
          If IFIETYP = 3 Then
            Assign SZNOMFIE With [M:SCP1]ASWDAT
            IDOASSIGN = 1
          Endif
        Elsif [M:SCP1]QSTTYP = 4 Then
          #Booléen
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWBOL
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Endif
        If IFIETYP < 0 Then
          IDOASSIGN = 0
        Endif
        If IDOASSIGN Then
          Rewrite [BPC]
          If fstat Then
            GMESSAGE = mess(101,141,1)
            GERR = 1
            Unlock [BPC]
            Rollback
          Else
            Commit
          Endif
        Else
          # La réponse n'a pas pu être stockée dans le champs hors questionnaire indiqué.
          # Incompatibilité de type.
          Rollback
          Unlock [BPC]
        Endif
      Endif
    Endif
  Endif
  #Stocker dans CONTACTCRM
  If [M:SCP1]ASWTAB = 3 Then
    Read [CLL]CLL0=[M:SCP1]CLLNUM
    If !fstat Then
      SZRECKEY = "[F:CLL]" + [M:SCP1]ASWKEY
      SZTESTVAR = evalue(SZRECKEY)
      If SZTESTVAR = "" Then
        End
      Endif
      Call DEBTRANS From GLOCK
      Trbegin [AIN]
      Readlock [AIN]AIN0=evalue(SZRECKEY)
      If fstat Then
        Rollback
        Unlock [AIN]
      Else
        SZNOMFIE = "[F:AIN]" + [M:SCP1]ASWFIE
        IFIETYP = evalue("Type([F:AIN]" + [M:SCP1]ASWFIE + ")")
        If [M:SCP1]QSTTYP = 1 Then
          #Alphanumérique
          If GXSZCNDTYP = "" Then
            If IFIETYP > 10 and IFIETYP < 500 Then    # FGR 04/02/2015 : X3SUIV105938
              Assign SZNOMFIE With [M:SCP1]ASWALH
              IDOASSIGN = 1
            Else                                      # FGR 04/02/2015 : X3SUIV105938
              IDOASSIGN = 0                           # FGR 04/02/2015 : X3SUIV105938
            Endif
          Else
            If GXSZCNDTYP = "ADI" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                If IFIETYP > 10 Then
                  Assign SZNOMFIE With [M:SCP1]ASWALHBAS
                  IDOASSIGN = 1
                Endif
              Endif
            Elsif GXSZCNDTYP = "M" Then
              If [M:SCP1]ASWALHBAS <> "" Then
                Case IFIETYP
                  When 1,2,4,5,6,7,9
                    Assign SZNOMFIE With val([M:SCP1]ASWALHBAS)
                    IDOASSIGN = 1
                  When Default
                    IDOASSIGN = 0
                Endcase
              Endif
            Endif
          Endif
        Elsif [M:SCP1]QSTTYP = 2 Then
          #Numérique
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWNUM
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Elsif [M:SCP1]QSTTYP = 3 Then
          #Date
          If IFIETYP = 3 Then
            Assign SZNOMFIE With [M:SCP1]ASWDAT
            IDOASSIGN = 1
          Endif
        Elsif [M:SCP1]QSTTYP = 4 Then
          #Booléen
          Case IFIETYP
            When 1,2,4,5,6,7,9
              Assign SZNOMFIE With [M:SCP1]ASWBOL
              IDOASSIGN = 1
            When Default
              IDOASSIGN = 0
          Endcase
        Endif
        If IFIETYP < 0 Then
          IDOASSIGN = 0
        Endif
        If IDOASSIGN Then
          Rewrite [AIN]
          If fstat Then
            GMESSAGE = mess(101,141,1)
            GERR = 1
            Unlock [AIN]
            Rollback
          Else
            Commit
          Endif
        Else
          # La réponse n'a pas pu être stockée dans le champs hors questionnaire indiqué.
          # Incompatibilité de type.
          Rollback
          Unlock [AIN]
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Charge la première question d'un script
#########################################################
Subprog LOADFIRQST
Local Integer IADISEPARATOR

  IADISEPARATOR = 0
  Filter [SCQ] Where [F:SCQ]SCPNUM = [M:SCP1]SCPNUM and [F:SCQ]STRQST = 2
  For [SCQ]
    [M:SCP1]QST = [F:SCQ]QST
    [M:SCP1]QSTTYP = [F:SCQ]QSTTYP
    [M:SCP1]QSTNUM = [F:SCQ]QSTNUM
    [M:SCP1]ASWTAB = [F:SCQ]ASWTAB
    [M:SCP1]ASWFIE = [F:SCQ]ASWFIE
    [M:SCP1]ASWKEY = [F:SCQ]ASWKEY
    Break
  Next
  Filter [SCQ]
  #Chargement des éventuelles réponses déjà enregistrées.
  If [M:SCP1]SCPFLGSIM = 0 Then
    Read [SCA]SCA0=[M:SCP1]CLLNUM;[M:SCP1]SCPNUM;[M:SCP1]QSTNUM
    If !fstat Then
      If [F:SCA]ASWTYP = 1 Then
        [M:SCP1]ASWALH = [F:SCA]ASWALH
      Else
        [M:SCP1]ASWALH = ""
      Endif
      [M:SCP1]ASWNUM = [F:SCA]ASWNUM
      [M:SCP1]ASWDAT = [F:SCA]ASWDAT
      [M:SCP1]ASWBOL = [F:SCA]ASWBOL
    Endif
  Endif
  GSZFQST = [M:SCP1]QSTNUM
  GSZCQST = [M:SCP1]QSTNUM
  #Initialise les variables nécessaires à la gestion des listes de réponses possibles
  GXSZCNDTYP = ""
  GSZCNDTYP = 0
  If [M:SCP1]ASWFIE <> "" Then
    If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
    If [M:SCP1]ASWTAB = 1 Then
      Read [ATZ]CODZONE="BPARTNER";[M:SCP1]ASWFIE
    Elsif [M:SCP1]ASWTAB = 2 Then
      Read [ATZ]CODZONE="BPCUSTOMER";[M:SCP1]ASWFIE
    Elsif [M:SCP1]ASWTAB = 3 Then
      Read [ATZ]CODZONE="CONTACTCRM";[M:SCP1]ASWFIE
    Endif
    If !fstat Then
      If [F:ATZ]CODTYP = "ADI" Then
        IADISEPARATOR = instr(1, [F:ATZ]EXPLIEN, ";")
        IADISEPARATOR -= 1
        GXSZCNDTYP = "ADI"
        GXICNDTYP = val(left$([F:ATZ]EXPLIEN, IADISEPARATOR))
      Elsif [F:ATZ]CODTYP = "M" Then
        If [F:ATZ]NOLIB = 1 Then
          End
        Else
          GXSZCNDTYP = "M"
          GXICNDTYP = [F:ATZ]NOLIB
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Gère le grisement des zones.
#########################################################
Subprog SETSCP1ZO(ITYP)
Value Integer ITYP

  If ITYP = 1 Then
    #Alphanumérique
    Actzo [M:SCP1]ASWALH
    Grizo [M:SCP1]ASWNUM
    Grizo [M:SCP1]ASWDAT
    Grizo [M:SCP1]ASWBOL
  Elsif ITYP = 2 Then
    #Numérique
    Grizo [M:SCP1]ASWALH
    Actzo [M:SCP1]ASWNUM
    Grizo [M:SCP1]ASWDAT
    Grizo [M:SCP1]ASWBOL
  Elsif ITYP = 3 Then
    #Date
    Grizo [M:SCP1]ASWALH
    Grizo [M:SCP1]ASWNUM
    Actzo [M:SCP1]ASWDAT
    Grizo [M:SCP1]ASWBOL
  Elsif ITYP = 4 Then
    #Booléen
    Grizo [M:SCP1]ASWALH
    Grizo [M:SCP1]ASWNUM
    Grizo [M:SCP1]ASWDAT
    Actzo [M:SCP1]ASWBOL
  Endif
End

##########################################################################################################
# Efface les réponse précédentes
#########################################################
Subprog RAZASW
  Raz [M:SCP1]ASWALH
  Raz [M:SCP1]ASWALHBAS
  Raz [M:SCP1]ASWNUM
  Raz [M:SCP1]ASWDAT
  Raz [M:SCP1]ASWBOL
End

##########################################################################################################
# Vérifie si SZVALEUR correspond à un code de table diverse ou à un code de menu local
#########################################################
Subprog CHKBAS(IMADINUM, SZVAL, SZMADITYP, IUSE)
Value Integer IMADINUM
Value Char SZVAL
Value Char SZMADITYP
Variable Integer IUSE

  IUSE = 0
  If SZMADITYP = "ADI" Then
    #Contrôle de conformité d'un code de table diverse
    If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [F:ADI]NUMTAB = IMADINUM Order By [F:ADI]CODE Asc
    For [ADI]
      If [F:ADI]CODE = SZVAL Then
        IUSE = 1
        Break
      Endif
    Next
    Filter [ADI]
  Elsif SZMADITYP = "M" Then
    #Contrôle de conformité d'un code de menu local
    If !clalev([F:AST]) : Local File APLSTD [AST] : Endif
    Filter [AST] Where [F:AST]LANCHP = IMADINUM and [F:AST]LAN = GLANGUE Order By [F:AST]LANNUM Asc
    For [AST]
      If [F:AST]LANNUM > 0 Then
        If [F:AST]LANNUM = val(SZVAL) Then
          IUSE = 1
          Break
        Endif
      Endif
    Next
    Filter [AST]
  Endif
End

##########################################################################################################
# Vérifie le script à simuler
################################################################
$ONCHECKSCP
Local Integer INBQSTCND
Local Integer ITERCHECK
Local Integer IETERLOOP
Local Integer ICNDLESS
Local Integer IQSTREP
Local Integer ICHGTREE
Local Char SZMESSX(250)
Local Integer ISTRFLG
Local Integer ISTRFLGPOS
Local Integer IPROTECTLOOP
Local Integer IKEEPPROCEED
Local Integer ITERPARSE
Local Integer ITERALONE
Local Integer ITERFINAL
Local Integer ITERPART
Local Integer IALONEFOUND
Local Integer IDEEPLEVEL
Local Char SZCURQST
Local Integer IREMAINQST
Local Integer IATLEASTQUIT
Local Integer ICANSCAN

  ICANSCAN = 1
  IATLEASTQUIT = 0
  IDEEPLEVEL = 0
  INBQSTCND = 0
  ITERCHECK = 0
  IETERLOOP = 0
  IQSTREP = 0
  SZMESSX = ""
  ICHGTREE = 30
  ISTRFLG = 0
  ISTRFLGPOS = 0
  IPROTECTLOOP = 0
  ICNDLESS = 0
  IKEEPPROCEED = 1
  ITERPARSE = 0
  ITERALONE = 0
  ITERFINAL = 0
  ITERPART = 0
  IALONEFOUND = 0
  SZCURQST = ""
  IREMAINQST = 0
  #Calcul le nombre de cheminements dans le script
  Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM
  For [SQC]
    INBQSTCND += 1
  Next
  Filter [SQC]
  #S'il n'y a aucun cheminement, il n'y a rien à vérifier
  If !INBQSTCND Then
    Return
  Endif
  Call TEMPON("F") From GESECRAN
  #
  #Constitution du tableau de travail
Local Char IORICOL(30)(INBQSTCND)
Local Char IDESCOL(30)(INBQSTCND)
Local Integer ISTRCOL(INBQSTCND)
Local Integer IENDCOL(INBQSTCND)
Local Integer IPROCOL(INBQSTCND)
Local Integer IPROALOCOL(INBQSTCND)
Local Char SZPRECURQST(30)(INBQSTCND)
Local Char SZALONEMEM(30)(INBQSTCND)

  Filter [SQC] Where [F:SQC]SCPNUM = [M:SCP1]SCPNUM
  For [SQC]
    If ITERCHECK >= dim(IORICOL) Then
      Break
    Endif
    IORICOL(ITERCHECK) = [F:SQC]QSTNUM
    IDESCOL(ITERCHECK) = [F:SQC]NEXQST
    If [F:SQC]NEXQST = "" and [F:SQC]CND <> 2 Then
      IPROCOL(ITERCHECK) = 1
      IQSTREP = 0
      SZMESSX = ""
      #La question n° XXX comporte un cheminement incorrect. Voulez-vous continuez ?
      SZMESSX = mess(642,196,1) - [F:SQC]QSTNUM - mess(643,196,1) - mess(641,196,1)
      Call OUINON(SZMESSX, IQSTREP) From GESECRAN
      If IQSTREP <> 2 Then
        FIN = 1
        Break
      Endif
    Endif
    Read [SCQ]SCQ0=[M:SCP1]SCPNUM;[F:SQC]QSTNUM
    If fstat Then
      ISTRCOL(ITERCHECK) = 0
    Else
      If [F:SCQ]STRQST = 2 Then
        ISTRCOL(ITERCHECK) = 1
      Else
        ISTRCOL(ITERCHECK) = 0
      Endif
    Endif
    If [F:SQC]CND = 2 Then
      IATLEASTQUIT = 1
      IENDCOL(ITERCHECK) = 1
    Else
      IENDCOL(ITERCHECK) = 0
    Endif
    ITERCHECK += 1
  Next
  Filter [SQC]
  #Si on ne veut pas continuer, on sort
  If FIN Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  #Le script ne comporte pas de question de sorties.
  If !IATLEASTQUIT Then
    IQSTREP = 0
    SZMESSX = ""
    #Le script ne comporte aucune question de sortie. Voulez-vous continuez ?
    SZMESSX = mess(655,196,1) - mess(641,196,1)
    Call OUINON(SZMESSX, IQSTREP) From GESECRAN
    If IQSTREP <> 2 Then
      FIN = 1
    Endif
  Endif
  #Si on ne veut pas continuer, on sort
  If FIN Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  #Détection des questions isolées
  Gosub CHECKALONE
  #Si on ne veut pas continuer, on sort
  If FIN Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  #Détection des cheminements pointant vers une question inexistante
  Gosub CHECKQSTEXT
  #Si on ne veut pas continuer, on sort
  If FIN Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  #Détection de parties entières de scripts isolées
  Gosub CHKALOPART
  #On ne fait pas la détection de boucles sans fin des questions sont isolées dans le script.
  If !ICANSCAN Then
    #La détection de boucles sans fin n'est pas réalisée en présence de questions isolées.
    #Le script doit au préalable étre corrigé pour effectuer cette vérification.
    GMESSAGE = mess(660,196,1) - mess(661,196,1)
    GERR = 3
    Call TEMPOFF From GESECRAN
    Return
  Endif
  #Détection de boucles sans fin
  While 1
    ISTRFLG = 0
    ISTRFLGPOS = 0
    For ITERCHECK = 0 To dim(IORICOL)-1
      If IENDCOL(ITERCHECK) and !IPROCOL(ITERCHECK) Then
        IGODOWN = 1
        IDEEPLEVEL = 0
        IKEEPPROCEED = 1
        ISTRFLG = 1
        ISTRFLGPOS = ITERCHECK
        SZCURQST = IORICOL(ITERCHECK)
        SZPRECURQST(IDEEPLEVEL) = SZCURQST
        Break
      Endif
    Next
    If ISTRFLG Then
      #Une branche sortante a été trouvée. On traite toutes les brindilles jusqu'a la racine.
      Gosub PARSEQST
    Else
      #Recherche d'un cheminement non traité
      ISTRFLG = 0
      For ITERCHECK = 0 To dim(IORICOL)-1
        If !IPROCOL(ITERCHECK) Then
          ISTRFLG += 1
          Break
        Endif
      Next
      If ISTRFLG Then
        #Il reste des cheminements non traités qui n'aboutissent pas à la fin du script
        #On est donc en présence d'une boucle sans fin
        IETERLOOP = 1
      Endif
      Break
    Endif
    #Protection contre les boucles infinies
    IPROTECTLOOP += 1
    If IPROTECTLOOP > 50000 Then
      Break
    Endif
  Wend
  #Une boucle sans fin a été trouvée
  If IETERLOOP Then
    IQSTREP = 0
    SZMESSX = ""
    SZMESSX = mess(640,196,1) - mess(641,196,1)
    Call OUINON(SZMESSX, IQSTREP) From GESECRAN
    If IQSTREP <> 2 Then
      FIN = 1
    Endif
  Endif
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
$CHECKALONE
  #Examine si la question n'est pas isolée
  Raz SZALONEMEM
  For ITERPARSE = 0 To dim(IORICOL)-1
    If !ISTRCOL(ITERPARSE) Then
      IALONEFOUND = 1
      For ITERALONE = 0 To dim(IORICOL)-1
        If IDESCOL(ITERALONE) = IORICOL(ITERPARSE) Then
          IALONEFOUND = 0
          Break
        Endif
      Next
      If IALONEFOUND Then
        #Détermine si la question n'a pas déjà été détectée
        For ITERALONE = 0 To dim(SZALONEMEM)-1
          If SZALONEMEM(ITERALONE) <> "" Then
            If SZALONEMEM(ITERALONE) = IORICOL(ITERPARSE) Then
              IALONEFOUND = 0
            Endif
          Endif
        Next
        If IALONEFOUND Then
          #Recherche une place de libre dans SZALONEMEM
          For ITERALONE = 0 To dim(SZALONEMEM)-1
            If SZALONEMEM(ITERALONE) = "" Then
              SZALONEMEM(ITERALONE) = IORICOL(ITERPARSE)
              Break
            Endif
          Next
          ICANSCAN = 0
          IQSTREP = 0
          SZMESSX = ""
          #La question n° XXX est isolée. Aucun cheminement ne permet d'y accéder. Voulez-vous continuez ?
          SZMESSX = mess(642,196,1) - IORICOL(ITERPARSE) - mess(656,196,1) - mess(657,196,1) - mess(641,196,1)
          Call OUINON(SZMESSX, IQSTREP) From GESECRAN
          If IQSTREP <> 2 Then
            FIN = 1
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$CHECKQSTEXT
  #Détection des cheminements pointant vers une question inexistante
  Raz SZALONEMEM
  For ITERPARSE = 0 To dim(IORICOL)-1
    If !IENDCOL(ITERPARSE) Then
      If IDESCOL(ITERPARSE) <> "" Then
        Read [SCQ]SCQ0=[M:SCP1]SCPNUM;IDESCOL(ITERPARSE)
        If fstat Then
          #Détermine si la question n'a pas déjà été détectée
          IALONEFOUND = 1
          For ITERALONE = 0 To dim(SZALONEMEM)-1
            If SZALONEMEM(ITERALONE) <> "" Then
              If SZALONEMEM(ITERALONE) = IDESCOL(ITERPARSE) Then
                IALONEFOUND = 0
              Endif
            Endif
          Next
          If IALONEFOUND Then
            #Recherche une place de libre dans SZALONEMEM
            For ITERALONE = 0 To dim(SZALONEMEM)-1
              If SZALONEMEM(ITERALONE) = "" Then
                SZALONEMEM(ITERALONE) = IDESCOL(ITERPARSE)
                Break
              Endif
            Next
            IQSTREP = 0
            SZMESSX = ""
            #La question n° XXX n'est pas définie dans le script.
            #Elle est néanmoins mentionnée dans certains cheminements. Voulez-vous continuez ?
            SZMESSX = mess(642,196,1) - IDESCOL(ITERPARSE) - mess(658,196,1) - mess(659,196,1) - mess(641,196,1)
            Call OUINON(SZMESSX, IQSTREP) From GESECRAN
            If IQSTREP <> 2 Then
              FIN = 1
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$PARSEQST
  While 1
    #On coupe toutes les branches qui partent de la question courante
    For ITERPARSE = 0 To dim(IORICOL)-1
      If IORICOL(ITERPARSE) = SZCURQST and !IPROCOL(ITERPARSE) Then
        IPROCOL(ITERPARSE) = 1
      Endif
    Next
    If IGODOWN Then
      #On recherche une autre question à analyser
      IREMAINQST = 0
      For ITERPARSE = 0 To dim(IORICOL)-1
        If IDESCOL(ITERPARSE) = SZCURQST and !IPROCOL(ITERPARSE) Then
          IREMAINQST = 1
          SZCURQST = IORICOL(ITERPARSE)
          IDEEPLEVEL += 1
          SZPRECURQST(IDEEPLEVEL) = SZCURQST
          If ISTRCOL(ITERPARSE) Then
            #On est arrivé sur une question de départ
            IGODOWN = 0
          Else
            IGODOWN = 1
          Endif
        Endif
      Next
      If !IREMAINQST Then
        If IDEEPLEVEL = 0 Then
          Break
        Endif
        SZPRECURQST(IDEEPLEVEL) = ""
        IDEEPLEVEL -= 1
        IGODOWN = 1
        SZCURQST = SZPRECURQST(IDEEPLEVEL)
      Endif
    Else
      SZPRECURQST(IDEEPLEVEL) = ""
      IDEEPLEVEL -= 1
      IGODOWN = 1
      SZCURQST = SZPRECURQST(IDEEPLEVEL)
    Endif
    #Protection contre les boucles infinies
    IPROTECTLOOP += 1
    If IPROTECTLOOP > 50000 Then
      Break
    Endif
  Wend
Return
##########################################################################################################
# Détection de parties entières de scripts isolées
######################################################
$CHKALOPART
  #Pour chaque question, on détermine si on aboutit à une question de départ.
  Raz IPROALOCOL
  For ITERPART = 0 To dim(IORICOL)-1
    IGODOWN = 1
    IDEEPLEVEL = 0
    IKEEPPROCEED = 1
    ISTRFLG = 1
    ISTRFLGPOS = ITERCHECK
    SZCURQST = IORICOL(ITERPART)
    SZPRECURQST(IDEEPLEVEL) = SZCURQST
    If !ISTRCOL(ITERPART) Then
      Raz IPROALOCOL
      IPROALOCOL(ITERPART) += 1
      Gosub REACHSTR
    Endif
    If !ICANSCAN Then
      Break
    Endif
  Next
Return

##########################################################################################################
$REACHSTR
  While 1
    IREMAINQST = 0
    For ITERPARSE = 0 To dim(IORICOL)-1
      If IDESCOL(ITERPARSE) = SZCURQST and !IPROALOCOL(ITERPARSE) Then
        IPROALOCOL(ITERPARSE) += 1
        IREMAINQST = 1
        SZCURQST = IORICOL(ITERPARSE)
        IDEEPLEVEL += 1
        SZPRECURQST(IDEEPLEVEL) = SZCURQST
        If ISTRCOL(ITERPARSE) Then
          #On est arrivé sur une question de départ
          IGODOWN = 0
          Break
        Endif
      Endif
    Next
    If !IGODOWN Then
      Break
    Endif
    If !IREMAINQST Then
      If IDEEPLEVEL = 0 Then
        ICANSCAN = 0
        Break
      Endif
      SZPRECURQST(IDEEPLEVEL) = ""
      IDEEPLEVEL -= 1
      IGODOWN = 1
      SZCURQST = SZPRECURQST(IDEEPLEVEL)
    Endif
    #Protection contre les boucles infinies
    IPROTECTLOOP += 1
    If IPROTECTLOOP > 50000 Then
      Break
    Endif
  Wend
Return
