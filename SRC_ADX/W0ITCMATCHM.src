####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone SELFLG
mkstat = 0
zoncou = "SELFLG"
IMPENT = [M]SELFLG(indice)
WNUM = IMPENT
If varinit([M]SELFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]SELFLG,indice)=0
 [M]SELFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SELFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SELFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_SELFLG(IMPENT) From SUBICMM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SELFLG" : GZNUM = 10104 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]SELFLG(indice) = IMPENT

## Zone VARPER
mkstat = 0
zoncou = "VARPER"
WNUM = [M]VARPER(indice)
If varmode([M]VARPER,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VARPER" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]VARPER(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_VARPER([M]VARPER(indice)) From SUBICMM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VARPER" : GZNUM = 3568 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone VARAMT
mkstat = 0
zoncou = "VARAMT"
WNUM = [M]VARAMT(indice)
If varmode([M]VARAMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VARAMT" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]VARAMT(indice) or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_VARAMT([M]VARAMT(indice)) From SUBICMM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "VARAMT" : GZNUM = 3603 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITCMATCHM"
Return

