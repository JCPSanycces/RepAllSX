#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet AFJ
Raz GPILOBJ
Call OBJET("AFJ",GBIDC1,GBIDC2) From GOBJET
End

#-------------------------------------#
$ACTION
Case ACTION
 When "LIENS" : Gosub LIENS
Endcase
Return

#-------------------------------------#
$LIENS
Call TEXTE([F:AFJ]INTTAG,[M]AZINTTAG(nolign-1)) From OBJDIV
Return

#-------------------------------------#
Subprog AS_CODTAG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Look [AFJ]AFJ0 = VALEUR
 If !fstat : mkstat = 2 : Endif
Endif
End

Subprog C_CODTAG(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CODTAG) From OBJDIV
End


