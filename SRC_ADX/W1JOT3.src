#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque JOT3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:16"
A_USER  = "DOC"
A_STAMP = "20181109230516"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask JOT3 [JOT3]
Gosub HORODAT
Local Inpbox "JOT3" From GFONCTION At A_STAMP With A_WINDPREV Mask [JOT3] As [SIM_]
Grizo [JOT3]5
Grizo [JOT3]10
Grizo [JOT3]15
Grizo [JOT3]20
Grizo [JOT3]25
Grizo [JOT3]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [JOT3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=80 : Y1(1)=3 : Y2(1)=5
X1(2)=1 : X2(2)=80 : Y1(2)=6 : Y2(2)=7
X1(3)=1 : X2(3)=80 : Y1(3)=8 : Y2(3)=9
X1(4)=1 : X2(4)=80 : Y1(4)=10 : Y2(4)=11
X1(5)=1 : X2(5)=80 : Y1(5)=12 : Y2(5)=24
Return

$ON_CCV
Onevent CONTROL Call C_CCV(zc) From W1JOT3
Onevent AFTER_CHANGE Gosub AMM_CCV From W1JOT3
Onevent BEFORE_INPUT Call AS_CCV(zc) From W1JOT3
Return

Subprog AS_CCV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45527,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CCV(zc) From W1JOT3
Onkey   2 Titled GBOUTS Call S_CCV(zc) From W1JOT3
Onkey 144 Titled GBOUTP Call P_CCV(zc) From W1JOT3
Onkey 146 Titled GBOUTA Call SA_CCV(zc) From W1JOT3
Gosub _AFF
End

Subprog C_CCV(VALEUR)
Variable Char    VALEUR()
## Action CONTHRCCV
Call CONTHRCCV(VALEUR,GCURLEG) From SUBHRCCV
If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
Endif
Gosub _AFF
End

$AMM_CCV
Call AM_CCV(zc)
If !mkstat & GOBJET
 zoncou = "CCV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CCV(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CCV(VALEUR) From SUBJOT
If mkstat : GERR = 1 : GZONE = "CCV" : GZNUM = 11208 : Endif
Gosub _AFF
End

Subprog S_CCV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCCV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCCV"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCCV","SUBHRCCV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CCV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRCCV
 Call TUNHRCCV(VALEUR,GCURLEG) From SUBHRCCV
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_CCV(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCCV"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CCV(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCCV",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DES
Onevent INIT_AREA Call D_DES(zc) From W1JOT3
Return

Subprog D_DES(VALEUR)
Variable Char    VALEUR()
If varinit([M]DES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"CLASSCONV","DES",[M:JOT3]CCV,GCURLEG) From ATEXTRA
Endif
Gosub _AFF
End

