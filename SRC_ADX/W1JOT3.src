Subprog D_SCACPC(VALEUR)
Variable Char    VALEUR()
If varinit([M]SCACPC,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11702","SCACPC") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_SCACPC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11702") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_SCACPC(zc) From W1JOT3
Onkey   2 Titled GBOUTS Call S_SCACPC(zc) From W1JOT3
Onkey 144 Titled GBOUTP Call P_SCACPC(zc) From W1JOT3
Onkey 146 Titled GBOUTA Call SA_SCACPC(zc) From W1JOT3
Gosub _AFF
End

Subprog C_SCACPC(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11702","SCACPC") From SUBADI
If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11702",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "SCACPC" : GZNUM = 55065 : Endif
Endif
Gosub _AFF
End

$AMM_SCACPC
Call AM_SCACPC(zc)
If !mkstat & GOBJET
 zoncou = "SCACPC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SCACPC(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZSCACPC)")>indice
 [M]SCACPC(indice) = VALEUR
 Affzo ZSCACPC(indice)
Endif
Gosub _AFF
End

Subprog S_SCACPC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11702"
 PARMSK(2) = "SCACPC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_SCACPC(VALEUR)
