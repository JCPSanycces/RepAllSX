#<AdxTL>@(#)0.0.0.0 $Revision$ 
###########################################################################################
#  generation des json pour les livrables
#  action a lancer en batch
###########################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AJSONADLV","",2,"") From GTRAITE

End
##################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "AVANT_PAR"   : TIT = mess(61,7999,1)
 When "EXEC"        : Gosub EXEC
Endcase
Return

##################################################################
$INIT
Return

##################################################################
$EXEC
Local Integer WOK
WOK = 0
Local Integer WTYPE
WTYPE = 1
# generation json tous livrables actifs
Call JSON_ALL_ADLV (WOK,WTYPE) From SUBADLV
Return

#########################################################################################################
#                         sous prog SUBPROG
#########################################################################################################

Subprog WRITE_JSON_POLICY (RERROR_GLOBLAN)
Variable Char RERROR_GLOBLAN

RERROR_GLOBLAN = ""
Gosub INIT_JSON
If RERROR_GLOBLAN ="KO"
    End
Endif

# tabelau des modules etc...
Raz WTAB_ASWFNC
Raz WTAB_MODULE
Raz WTAB_CODBDG

WIND_BDG = 0
Filter [ADLB] Where COD = [F:ADLV]COD
For [ADLB]
    Read [AFC]CODINT = [F:ADLB]CODFNC
    If fstat = 0
        WIND_BDG +=1
        If WIND_BDG > WNBR_RECORD 
                WIND_DBG = WNBR_RECORD    
                Break
        Endif
        WTAB_ASWFNC (WIND_BDG) = [F:ADLB]CODFNC
        WTAB_MODULE (WIND_BDG) = num$([F:AFC]MODULE)
        WTAB_CODBDG (WIND_BDG) = [F:ADLB]CODBDG
    Endif
Next
Filter [ADLB]
Filter [ADLR] Where COD = [F:ADLV]COD
For [ADLR]
    Read [ASW]ASW0 = [F:ADLR]CODASW
    If fstat = 0
        WIND_BDG +=1
        If WIND_BDG > WNBR_RECORD 
                WIND_DBG = WNBR_RECORD    
                Break
        Endif
        WTAB_ASWFNC (WIND_BDG) = [F:ADLR]CODASW
        WTAB_MODULE (WIND_BDG) = num$([F:ASW]MODULE)
        WTAB_CODBDG (WIND_BDG) = [F:ADLR]CODBDG
    Endif
Next
Filter [ADLR]
#

WJSON_POLICY = "Policy"+toupper([F:ADLV]COD)

# Ouverture du fichier json ecriture sous x3_pub directement pour l instant
WJSON_NAMEFIC = filpath("",WJSON_POLICY,"json","X3_PUB")

Openo WJSON_NAMEFIC,0   Using [JSO_]
Iomode adxifs ""       Using [JSO_]
Iomode adxirs chr$(10) Using [JSO_]
Iomode adxium GUTF8    Using [JSO_]


# Ecriture entête
Wrseq '{'  Using [JSO_]
Wrseq '"fileType": "Policy",'  Using [JSO_]
JSONPROP="generationStamp" : JSONVALUE=num$(WADATTIM)   : Gosub ADDJSONPROPV
Wrseq '"partnerId": "",'  Using [JSO_]

# code produit
Wrseq '"product":{'  Using [JSO_]
JSONPROP="code"    : JSONVALUE=num$([F:ADLV]PDT) : Gosub ADDJSONPROPV
WTYP_ATBTEX = "APLSTD"
WCODFIC     = ""
WCOD_TEX    = "7884"
WCOD_INDICE = [F:ADLV]PDT
WIDENT1     = ""
WIDENT2     = ""
Gosub JSON_TITLE
#
Local Char WVERSION(2)
#WVERSION = right$(GVERSION,3)
# cg changement depuis la U10 le gversion n est plus à jour
WVERSION = func APRODUCT.AGETVERSLIC
JSONPROP="version" : JSONVALUE= WVERSION          : Gosub ADDJSONPROP
Wrseq "},"  Using [JSO_]

# policy
Wrseq '"policy":{'  Using [JSO_]
JSONPROP="code"    : JSONVALUE=num$([F:ADLV]COD) : Gosub ADDJSONPROPV
WTYP_ATBTEX = "ATEXTRA"
WCODFIC     = "ADELIVER"
WCOD_TEX    = "DLVDES"
WCOD_INDICE = 0
WIDENT1     = [F:ADLV]COD
WIDENT2     = ""
Gosub JSON_TITLE
# pour instant en dur version qui correspond à la version du fichier json généré.
JSONPROP="version" : JSONVALUE="1.0"             : Gosub ADDJSONPROP
Wrseq "},"  Using [JSO_]
#
Wrseq '"baseProduct":"",'  Using [JSO_]
# modules
Wrseq '"modules":[{'  Using [JSO_]
Gosub JSON_MODULES
Wrseq "}],"  Using [JSO_]

# codes activites
Wrseq '"activityCodes":[{'  Using [JSO_]
Gosub JSON_ACT
Wrseq "}],"  Using [JSO_]

# languages
Wrseq '"languages":[{'  Using [JSO_]
Gosub JSON_LAN
Wrseq "}],"  Using [JSO_]
# legislations
Wrseq '"legislations":[{'  Using [JSO_]
Gosub JSON_LEG
Wrseq "}],"  Using [JSO_]

# setups kit
Wrseq '"parameterKits":['  Using [JSO_]
Gosub JSON_KIT
Wrseq "],"  Using [JSO_]

# session types 
Wrseq '"sessionTypes":['  Using [JSO_]
Gosub JSON_SESSION_TYP
Wrseq "],"  Using [JSO_]

# badges
Wrseq '"badges":['  Using [JSO_]
Gosub JSON_BDG
Wrseq "],"  Using [JSO_]

# parameters - parametres dela licence comme nbr immmos
Wrseq '"parameters":['  Using [JSO_]
Gosub JSON_LIMIT_LICENCE
Wrseq "],"  Using [JSO_]


# Fermeture fichier
Wrseq '"signature":"",'  Using [JSO_]
Wrseq '"signatureText":""'  Using [JSO_]
Wrseq "}"  Using [JSO_]
Openo Using [JSO_]


End

#########################################################################################################
Subprog WRITE_JSON_SETTINGS

# cg fev 2014 , on ne genere plus ces fihciers car on livre les tables
# on ne passe plus par ce subprog
# mais on a gardé l ecriture dans ce prog  quand même au cas ou .....

Gosub INIT_JSON

WJSON_POLICY = "Settings"+toupper([F:ADLV]COD)

# Ouverture du fichier json ecriture sous x3_pub directement pour l instant
WJSON_NAMEFIC = filpath("",WJSON_POLICY,"json","X3_PUB")

Openo WJSON_NAMEFIC,0   Using [JSO_]
Iomode adxifs ""       Using [JSO_]
Iomode adxirs chr$(10) Using [JSO_]
Iomode adxium GUTF8    Using [JSO_]


# Ecriture entête
Wrseq '{'  Using [JSO_]
Wrseq '"filetype": "Settings",'  Using [JSO_]
Wrseq '"partnerId": "",'  Using [JSO_]



# code produit
Wrseq '"product":{'  Using [JSO_]

JSONPROP="code"    : JSONVALUE=[F:ADLV]COD       : Gosub ADDJSONPROPV
WTYP_ATBTEX = "ATEXTRA"
WCODFIC     = "ADELIVER"
WCOD_TEX    = "DLVDES"
WCOD_INDICE = 0
WIDENT1     = [F:ADLV]COD
WIDENT2     = ""
Gosub JSON_TITLE
JSONPROP="version" : JSONVALUE=GVERSION          : Gosub ADDJSONPROP
Wrseq "},"  Using [JSO_]

# policy
Wrseq '"settings":{'  Using [JSO_]
JSONPROP="type"        : JSONVALUE=num$([F:ADLV]ADLVTYP)  : Gosub ADDJSONPROPV
If [F:ADLV]ADLVTYP <> 2
    JSONPROP="language"    : JSONVALUE=num$([F:ADLV]LANDEF)  : Gosub ADDJSONPROPV
    JSONPROP="currency"    : JSONVALUE=num$([F:ADLV]RPTCUR)  : Gosub ADDJSONPROPV
    JSONPROP="country"     : JSONVALUE=num$([F:ADLV]CRYDEF)  : Gosub ADDJSONPROPV
Endif
JSONPROP="responsable" : JSONVALUE=num$([F:ADLV]RPBUSR)  : Gosub ADDJSONPROPV
JSONPROP="comment"     : JSONVALUE=num$([F:ADLV]COMMENT) : Gosub ADDJSONPROPV
If [F:ADLV]ADLVTYP <> 2
    JSONPROP="edition"     : JSONVALUE=num$([F:ADLV]EDT)     : Gosub ADDJSONPROPV
    WTYP_ATBTEX = "APLSTD"
    WCODFIC     = ""
    WCOD_TEX    = "2906"
    WCOD_INDICE = [F:ADLV]EDT
    WIDENT1     = ""
    WIDENT2     = ""
    Gosub JSON_TITLE
Endif
# pour instant en dur version qui correspond à la version du fichier json généré.
JSONPROP="version" : JSONVALUE="1.0"             : Gosub ADDJSONPROP
Wrseq "},"  Using [JSO_]

# options pour kit
If [F:ADLV]ADLVTYP = 2
    Wrseq '"options":[{'  Using [JSO_]
    Gosub JSON_OPT
    Wrseq "}],"  Using [JSO_]
Endif

# codes activites
Wrseq '"dimensions":[{'  Using [JSO_]
Gosub JSON_DIM
Wrseq "}],"  Using [JSO_]

# parameters
Wrseq '"parameters":[{'  Using [JSO_]
Gosub JSON_PARAM
Wrseq "}],"  Using [JSO_]


# elements paramétrage
Wrseq '"setupelements":[{'  Using [JSO_]
Gosub JSON_ELT
Wrseq "}],"  Using [JSO_]



# Fermeture fichier
Wrseq '"signature":"",'  Using [JSO_]
Wrseq '"signatureText":""'  Using [JSO_]
Wrseq "}"  Using [JSO_]
Openo Using [JSO_]

End

#########################################################################################################
Subprog GLOBLLAN
#         GI_LLAN   : langues à utiliser pour la génération
#         GI_NBLAN  : nombre de langues du dossier

Global Integer GI_NBLAN
Local Integer I


If clalev([F:ADS])<>0 and [F:ADS]DOSSIER=nomap
  Global Char GI_LLAN(3)(1..dim([F:ADS]LAN))
  Global Char GISOLAN(6)(1..dim([F:ADS]LAN))
  Global Integer GI_VLAN(1..dim([F:ADS]LAN))

  Raz GI_LLAN,GI_NBLAN
  For I=0 To [F:ADS]NBRLAN-1
        GI_LLAN(I+1)=[F:ADS]LAN(I)
  Next I
  GI_NBLAN=[F:ADS]NBRLAN
Else
  If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif

  Global Char GI_LLAN(3)(1..dim([F:ADSW]LAN))
  Global Char GISOLAN(6)(1..dim([F:ADSW]LAN))
  Global Integer GI_VLAN(1..dim([F:ADSW]LAN))

  Raz GI_LLAN,GI_NBLAN

  Read [ADSW]DOSSIER=nomap
  If fstat & filinfo(filpath("","histo","",0),0)>=0
   Read [ADSW]DOSSIER=adxmother(0)
  Endif
  If fstat<>0    
        Call ECR_TRACE(mess(52,150,1)-nomap,1) From GESECRAN 
        RERROR_GLOBLAN = "KO"
        End 
  Endif

  For I=0 To [F:ADSW]NBRLAN-1
    GI_LLAN(I+1)=[F:ADSW]LAN(I)
  Next I
  GI_NBLAN=[F:ADSW]NBRLAN
Endif

For I=1 To GI_NBLAN
  Case GI_LLAN(I)
    When "FRA" : GISOLAN(I)="fr-FR"
    When "ENG" : GISOLAN(I)="en-US"
    When "BRI" : GISOLAN(I)="en-GB"
    When "GER" : GISOLAN(I)="de-DE"
    When "ITA" : GISOLAN(I)="it-IT"
    When "POL" : GISOLAN(I)="pl-PL"
    When "POR" : GISOLAN(I)="pt-PT"
    When "RUS" : GISOLAN(I)="ru-RU"
    When "SPA" : GISOLAN(I)="es-ES"
    When Default
                If clalev([F:TLA])=0  : Local File TABLAN [TLA]  : Endif
                Read [TLA]TLA0=GI_LLAN(I)
                If fstat=0 and [F:TLA]LANISO<>"" and len([F:TLA]LANISO)>=3
                  GISOLAN(I)=toupper(ctrans([F:TLA]LANISO,"_","-"))
                Else
                  # on fait quoi si code langue sans code iso ?????
                  # on tombe sur des codes sans code iso.
                    RERROR_GLOBLAN = "KO"
                    Break 
                Endif
  Endcase
Next I

End

#########################################################################################################
#                 Etiquettes gosub
#########################################################################################################
$INIT_JSON
# init des variables pour codes langue dossier
# on n utilise pas intrutila (globweb) car le format du code iso n est pas celui qu on va utiliser
#If dim(GI_NBLAN)<0 : Call GLOBWEB(nomap) From INTRUTILA : Endif
Call GLOBLLAN
If RERROR_GLOBLAN= "KO"
    Return
Endif

# tous les fichiers adlv sont deja ouverts, les classes f sont en ligne
Local Char JSONPROP(250),JSONVALUE(250)
Local Char WJSON_NAMEFIC (250)
Local Char WJSON_POLICY (250)
#
Local Char WTYP_ATBTEX (GLONATB)
Local Char WCOD_TEX (30)
Local Char WCODFIC (GLONATB)
Local Char WIDENT1 (80)
Local Char WIDENT2 (80)

Local Integer WCOD_INDICE
Local Integer WIND
Local Integer WMODULE
Local Char    WCODBDG(50)
Local Char    WCODSES(50)
Local Char    WCODASW (50)
Local Integer WIND_LANG
Local Char    WTXTLANG (123)
Local Integer WRETOUR

Local Integer WNBR_RECORD
WNBR_RECORD = 0
#
Filter [ADLB] Where COD = [F:ADLV]COD
WNBR_RECORD = rowcount([ADLB])
Filter [ADLB]
Filter [ADLR] Where COD = [F:ADLV]COD
WNBR_RECORD += rowcount([ADLR])
Filter [ADLR]

If WNBR_RECORD = 0
    Local Char WTAB_CODBDG (50) 
    Local Char WTAB_ASWFNC (50) 
    Local Char WTAB_MODULE (2)
Else
    Local Char WTAB_CODBDG (50) (1..WNBR_RECORD)
    Local Char WTAB_ASWFNC (50) (1..WNBR_RECORD)
    Local Char WTAB_MODULE (2)  (1..WNBR_RECORD)
Endif
Local Integer WIND_BDG
Local Integer WWIND
Local Integer WWJJ
Local Char    WCODE(2)

# tabulations de 3 caracteres
Local Char WTAB (4)
WTAB = "   "

# timestamp dans fichier
Local DATETIME WADATTIM
WADATTIM = DATETIME$

Local Char W_ALWAYS (30)
Local Char W_NEVER (30)
Local Char W_LICENSE (30)
W_ALWAYS  = "always"
W_NEVER   = "never"
W_LICENSE = "license"

Return
#########################################################################################################
$JSON_TITLE
WTXTLANG = ""
WIND_LANG = 0

Wrseq WTAB+'"title":{'  Using [JSO_]
For WIND_LANG=1 To GI_NBLAN
    WTXTLANG = ""
    If WTYP_ATBTEX = "ATEXTE"
        Gosub READ_LANGATX
    Elsif WTYP_ATBTEX = "APLSTD"
        Gosub READ_LANGAML
    Elsif WTYP_ATBTEX = "ATEXTRA"
        Gosub READ_LANGATEXTRA
    Endif
    # on vire les caract indesirable en json comme le "
    WTXTLANG= ESCJSON(WTXTLANG)
    #si pas dernier on met une virgule
    If WIND_LANG<>GI_NBLAN
        Wrseq WTAB+WTAB+'"'+GISOLAN(WIND_LANG)+'":"'+WTXTLANG+'",'                   Using [JSO_]
    Else
        Wrseq WTAB+WTAB+'"'+GISOLAN(WIND_LANG)+'":"'+WTXTLANG+'"'                    Using [JSO_]
    Endif
Next WIND_LANG
Wrseq WTAB+WTAB+"},"  Using [JSO_]
Return

#########################################################################################################
#  lecture du texte associée au code langue
$READ_LANGATX
#  Texte normal  atexte
Read [ATXJ]NUMERO = GI_LLAN(WIND_LANG);val(WCOD_TEX)
If fstat=0
     WTXTLANG  =[F:ATXJ]TEXTE
Else
     If GI_LLAN(WIND_LANG)<>GLANGUE
           Read [ATXJ]NUMERO = GLANGUE;val(WCOD_TEX)
     Else
           Read [ATXJ]NUMERO = GLANDEF;val(WCOD_TEX)
     Endif
     If fstat=0
         WTXTLANG  =[F:ATXJ]TEXTE
     Else
         WTXTLANG  =""
     Endif
Endif
Return
#########################################################################################################
#  lecture du texte associée au code langue
$READ_LANGAML
#  Texte normal  aplstd
Read [ASTJ]CLE =val(WCOD_TEX);WCOD_INDICE;GI_LLAN(WIND_LANG)
If fstat=0
     WTXTLANG  =[F:ASTJ]LANMES
Else
     If GI_LLAN(WIND_LANG)<>GLANGUE
           Read [ASTJ]CLE =val(WCOD_TEX);WCOD_INDICE;GLANGUE
     Else
           Read [ASTJ]CLE =val(WCOD_TEX);WCOD_INDICE;GLANDEF
     Endif
     If fstat=0
         WTXTLANG  =[F:ASTJ]LANMES
     Else
         WTXTLANG  =""
     Endif
Endif
Return

#########################################################################################################
#  lecture du texte associée au code langue
$READ_LANGATEXTRA
#  Texte normal  atextra
Read [AXXJ]AXX0 =WCODFIC;WCOD_TEX;GI_LLAN(WIND_LANG);WIDENT1;WIDENT2
If fstat=0
     WTXTLANG  =[F:AXXJ]TEXTE
Else
     If GI_LLAN(WIND_LANG)<>GLANGUE
           Read [AXXJ]AXX0 =WCODFIC;WCOD_TEX;GLANGUE;WIDENT1;WIDENT2
     Else
           Read [AXXJ]AXX0 =WCODFIC;WCOD_TEX;GLANDEF;WIDENT1;WIDENT2
     Endif
     If fstat=0
         WTXTLANG  =[F:AXXJ]TEXTE
     Else
         WTXTLANG  =""
     Endif
Endif

Return

#########################################################################################################
$JSON_MODULES

WWJJ     = 0
WIND_BDG = 0
WWIND    = 0

Sorta WNBR_RECORD WTAB_MODULE(1..WNBR_RECORD),WTAB_ASWFNC(1..WNBR_RECORD),WTAB_CODBDG(1..WNBR_RECORD)

For WIND =1 To len(mess(0,14,1))
     If left$(mess(WIND,14,1),1)="#"
              Break
     Else
         # pas sur le dernier , ni avant le premier
         If WIND <> 1
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         WMODULE = WIND -1
         If [F:ADLV]MODULE (WMODULE) <> 0
                JSONPROP="code"      : JSONVALUE=num$([F:ADLV]MODULE (WMODULE)) : Gosub ADDJSONPROPV
                WTYP_ATBTEX = "APLSTD"
                WCOD_TEX    = "14"
                WCOD_INDICE = WIND
                WIDENT1     = ""
                WIDENT2     = ""
                WCODFIC     = ""
                Gosub JSON_TITLE
                #
                Wrseq WTAB+WTAB+'"keyFunctions": ['  Using [JSO_]
                WCODE     = num$([F:ADLV]MODULE (WMODULE))
                WIND_BDG  = find (WCODE,WTAB_MODULE(1..WNBR_RECORD)) 
                If WIND_BDG <> 0
                    WWJJ    = 1
                    WCODASW = ""
                    For WWIND = WIND_BDG To WNBR_RECORD
                        If WCODE <>WTAB_MODULE(WWIND)
                            Break
                        Else
                            If WCODASW = "" or WCODASW <> WTAB_ASWFNC(WWIND)
                                If WWJJ <> 1
                                    Wrseq WTAB+WTAB+WTAB+',"'+WTAB_ASWFNC(WWIND)+'"'   Using [JSO_]
                                Else
                                    Wrseq WTAB+WTAB+WTAB+'"'+WTAB_ASWFNC(WWIND)+'"'   Using [JSO_]
                                Endif
                                WCODASW = WTAB_ASWFNC(WWIND)
                            Endif
                        Endif
                        WWJJ+=1
                    Next WWIND
                Endif
                Wrseq WTAB+WTAB+WTAB+"],"            Using [JSO_]
                #
                JSONPROP="condition" :
                If [F:ADLV]LICMODULE(WMODULE)  = 2
                    JSONVALUE=W_LICENSE
                Elsif [F:ADLV]MODNOTAVA(WMODULE) = 2
                    JSONVALUE=W_NEVER
                Else
                    JSONVALUE=W_ALWAYS
                Endif
                Gosub ADDJSONPROP
                # la valeur par defaut ne se trouve pas dans le policy
                # on livre les tabels donc on recuperera la valeur du defaut direcement dans la table
                # on n a pas besoin de cette notion dans policy
         Endif
     Endif
Next WIND
Return

#########################################################################################################
$JSON_KIT
WWIND = 0
If dim ([F:ADLV]ITYKIT)-1 <> 0
    For WIND = 0 To dim ([F:ADLV]ITYKIT)-1
        If [F:ADLV]ITYKIT (WIND) <> ""
             # pas sur le dernier , ni avant le premier
             If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
             Else
                    Wrseq WTAB+"{"  Using [JSO_]
                    WWIND = 1
             Endif
             JSONPROP="code"   : JSONVALUE=num$([F:ADLV]ITYKIT (WIND)) : Gosub ADDJSONPROPV
             WTYP_ATBTEX = "ATEXTRA"
             WCODFIC     = "ADELIVER"
             WCOD_TEX    = "DLVDES"
             WCOD_INDICE = 0
             WIDENT1     = [F:ADLV]ITYKIT (WIND)
             WIDENT2     = ""
             Gosub JSON_TITLE
             # tjs cette valeur car rien dans livrable comme info
             # NON sousmis a licence pour  l instant
             JSONPROP="condition" :   JSONVALUE=W_ALWAYS           : Gosub ADDJSONPROP
             # on ne met plus dans le json
             #JSONPROP="row"       :   JSONVALUE=num$([F:ADLV]ITYKITROW (WIND))  : Gosub ADDJSONPROP
        Else
            Break
        Endif
    Next WIND
    If WWIND <> 0
        Wrseq WTAB+"}"  Using [JSO_]
    Endif
Endif

Return
#########################################################################################################
$JSON_LEG
For WIND = 0 To dim ([F:ADLV]DOSLEG)-1
    If [F:ADLV]DOSLEG (WIND) <> ""
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLV]DOSLEG (WIND)) : Gosub ADDJSONPROPV
         # read code adi leg  ?????????
         WTYP_ATBTEX = "ATEXTRA"
         WCODFIC     = "ATABDIV"
         WCOD_TEX    = "LNGDES"
         WCOD_INDICE = 0
         WIDENT1     = "909"
         WIDENT2     = num$([F:ADLV]DOSLEG (WIND))
         Gosub JSON_TITLE
         # tjs cette valeur car rien dans livrable comme info
         JSONPROP="condition" :   JSONVALUE=W_LICENSE           : Gosub ADDJSONPROP
    Else
        Break
    Endif
Next WIND

Return

#########################################################################################################
$JSON_LAN
For WIND = 0 To dim ([F:ADLV]LAN)-1
    If [F:ADLV]LAN (WIND) <> ""
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLV]LAN (WIND)) : Gosub ADDJSONPROPV
         # read code langue tablan ..... ????????? avoir si on fait
         WTYP_ATBTEX = "ATEXTRA"
         WCODFIC     = "TABLAN"
         WCOD_TEX    = "INTDES"
         WCOD_INDICE = 0
         WIDENT1     = num$([F:ADLV]LAN (WIND))
         WIDENT2     = ""
         Gosub JSON_TITLE
         # tjs cette valeur car rien dans livrable comme info 
         # Depuis la v11 et plus : anglais en always cf JIRA ....X3-26732 demande du product management
         If [F:ADLV]LAN(WIND) = "ENG"
            JSONPROP="condition" :   JSONVALUE=W_ALWAYS       : Gosub ADDJSONPROP
        Else
            JSONPROP="condition" :   JSONVALUE=W_LICENSE      : Gosub ADDJSONPROP
        Endif
    Else
        Break
    Endif
Next WIND
Return

#########################################################################################################
$JSON_ACT
#----------------------#
# codes act typ = 1 (options) typ = 2 localisations
#----------------------#
Filter [ADLD] Where COD=[F:ADLV]COD and TYPACV <> 2
WIND = 0
For [ADLD]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLD]CODACT) : Gosub ADDJSONPROPV
         Call READ_ACTIV ([F:ADLD]CODACT,"F",WRETOUR) From SUBADLV
         WTYP_ATBTEX = "ATEXTE"
         WCODFIC     = ""
         WCOD_TEX    = num$([F:ACV]LIBACT)
         WCOD_INDICE = 0
         WIDENT1     = ""
         WIDENT2     = ""
         Gosub JSON_TITLE
         # 1 options - 3 localisations
         # on ne met pas le type dans le json
         #JSONPROP="type"   : JSONVALUE=num$([F:ADLD]TYPACV) : Gosub ADDJSONPROPV
         #
         JSONPROP="condition" :
         If [F:ADLD]LICACT  = 2
                    JSONVALUE = W_LICENSE
         Elsif [F:ADLD]NOTAVAACT = 2
                    JSONVALUE = W_NEVER
         Else
                    JSONVALUE = W_ALWAYS
         Endif
         Gosub ADDJSONPROP
         #
         WIND +=1
Next
Filter [ADLD]
Return

#########################################################################################################
$JSON_OPT
#----------------------#
# pour les kits
# codes act typ = 1 (options) typ = 2 localisations
#----------------------#
Filter [ADLD] Where COD=[F:ADLV]COD and TYPACV <> 2
WIND = 0
For [ADLD]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLD]CODACT) : Gosub ADDJSONPROPV
         Call READ_ACTIV ([F:ADLD]CODACT,"F",WRETOUR) From SUBADLV
         WTYP_ATBTEX = "ATEXTE"
         WCODFIC     = ""
         WCOD_TEX    = num$([F:ACV]LIBACT)
         WCOD_INDICE = 0
         WIDENT1     = ""
         WIDENT2     = ""
         Gosub JSON_TITLE
         # 1 options - 3 localisations
         JSONPROP="type"   : JSONVALUE=num$([F:ADLD]TYPACV) : Gosub ADDJSONPROPV
         #
         JSONPROP="default"
         If [F:ADLD]FLGACT = 2
                    JSONVALUE="true"
         Else
                    JSONVALUE="false"
         Endif
         Gosub ADDJSONPROP
         #
         WIND +=1
Next
Filter [ADLD]
Return

#########################################################################################################
$JSON_BDG

WWJJ     = 0
WIND_BDG = 0
WWIND    = 0

Sorta WNBR_RECORD WTAB_CODBDG(1..WNBR_RECORD),WTAB_ASWFNC(1..WNBR_RECORD),WTAB_MODULE(1..WNBR_RECORD)

WCODBDG = ""
WIND = 0
If WNBR_RECORD <> 0 
    Wrseq WTAB+"{"  Using [JSO_]
    For WWIND = 1 To WNBR_RECORD
        If WTAB_CODBDG(WWIND) <> ""
            # en fct du code bagde
            If WCODBDG = "" or WCODBDG <> WTAB_CODBDG(WWIND)
                # pas sur le dernier , ni avant le premier
                 If WIND <> 0
                    Wrseq WTAB+WTAB+WTAB+"]"     Using [JSO_]
                    Wrseq WTAB+"}, {"  Using [JSO_]
                 Endif
                 JSONPROP="code"   : JSONVALUE=num$(WTAB_CODBDG(WWIND)) : Gosub ADDJSONPROPV
                 #
                 WCODBDG = WTAB_CODBDG(WWIND)
                 WTYP_ATBTEX = "ATEXTRA"
                 WCODFIC     = "ATABDIV"
                 WCOD_TEX    = "LNGDES"
                 WCOD_INDICE = 0
                 WIDENT1     = "83"
                 WIDENT2     = WTAB_CODBDG(WWIND)
                 Gosub JSON_TITLE
                 #
                 Wrseq WTAB+WTAB+'"functions": ['  Using [JSO_]
                 WIND    = 1
            Endif
            If WIND <> 1
                Wrseq WTAB+WTAB+WTAB+',"'+WTAB_ASWFNC(WWIND)+'"'   Using [JSO_]
            Else
                Wrseq WTAB+WTAB+WTAB+'"'+WTAB_ASWFNC(WWIND)+'"'   Using [JSO_]
            Endif
            WIND +=1
        Endif
    Next WWIND
    If WIND <> 0
         Wrseq WTAB+WTAB+WTAB+"]"  Using [JSO_]
    Endif
    Wrseq WTAB+"}"  Using [JSO_]
Endif

Return

#########################################################################################################
$JSON_SESSION_TYP
Filter [ADLT] Where COD=[F:ADLV]COD Order By Key ADLT0
WCODSES = ""
WIND = 0

If rowcount ([ADLT]) <> 0
    Wrseq WTAB+"{"  Using [JSO_]
    # en fct du code session type
    For [ADLT]
        If WCODSES = "" or WCODSES <> [F:ADLT]CODSES
             # pas sur le dernier , ni avant le premier
             If WIND <> 0
                    Wrseq WTAB+WTAB+WTAB+"]"     Using [JSO_]
                    Wrseq WTAB+"}, {"  Using [JSO_]
             Endif
             JSONPROP="code"   : JSONVALUE=tolower(num$([F:ADLT]CODSES)) : Gosub ADDJSONPROPV
             #
             WCODSES = [F:ADLT]CODSES
             WTYP_ATBTEX = "ATEXTRA"
             WCODFIC     = "ATABDIV"
             WCOD_TEX    = "LNGDES"
             WCOD_INDICE = 0
             WIDENT1     = "924"
             WIDENT2     = [F:ADLT]CODSES
             Gosub JSON_TITLE
             #
             Wrseq WTAB+WTAB+'"devices": ['  Using [JSO_]
             WIND    = 1
        Endif
        If WIND <> 1
            Wrseq WTAB+WTAB+WTAB+',"'+tolower([F:ADLT]CODDVC)+'"'   Using [JSO_]
        Else
            Wrseq WTAB+WTAB+WTAB+'"'+tolower([F:ADLT]CODDVC)+'"'   Using [JSO_]
        Endif
        WIND +=1
    Next
    If WIND <> 0
         Wrseq WTAB+WTAB+WTAB+"]"  Using [JSO_]
    Endif
    Wrseq WTAB+"}"  Using [JSO_]
Endif

Filter [ADLT]
Return
#########################################################################################################
$JSON_LIMIT_LICENCE
Filter [ADLL] Where COD=[F:ADLV]COD
WIND = 0
If rowcount ([ADLL]) <> 0
    Wrseq WTAB+"{"  Using [JSO_]
    For [ADLL]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLL]FNCLIM) : Gosub ADDJSONPROPV
         WTYP_ATBTEX = "ATEXTRA"
         WCODFIC     = "ATABDIV"
         WCOD_TEX    = "LNGDES"
         WCOD_INDICE = 0
         WIDENT1     = "926"
         WIDENT2     = [F:ADLL]FNCLIM
         Gosub JSON_TITLE
         #
         JSONPROP="type" :    JSONVALUE=tolower(num$([F:ADLL]TYPFNCLIM)):  Gosub ADDJSONPROP
         #
         WIND +=1
    Next
    Wrseq WTAB+"}"  Using [JSO_]
Endif

Filter [ADLL]
Return

#########################################################################################################
$JSON_DIM
#----------------------#
# codes act typ = 3 dimension
#----------------------#
Filter [ADLD] Where COD=[F:ADLV]COD and TYPACV = 2
WIND = 0
For [ADLD]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLD]CODACT) : Gosub ADDJSONPROPV
         Call READ_ACTIV ([F:ADLD]CODACT,"D",WRETOUR) From SUBADLV
         WTYP_ATBTEX = "ATEXTE"
         WCODFIC     = ""
         WCOD_TEX    = num$([F:ACV]LIBACT)
         WCOD_INDICE = 0
         WIDENT1     = ""
         WIDENT2     = ""
         Gosub JSON_TITLE
         #
         JSONPROP="value" :    JSONVALUE=num$([F:ADLD]DIMACT):  Gosub ADDJSONPROP
