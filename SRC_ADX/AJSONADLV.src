#########################################################################################################
$JSON_PARAM
Filter [ADLP] Where COD=[F:ADLV]COD
WIND = 0
For [ADLP]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"   : JSONVALUE=num$([F:ADLP]PARAM) : Gosub ADDJSONPROPV
         Call READ_ADOPAR ([F:ADLP]PARAM,[F:ADLP]TYPPARAM,WRETOUR) From SUBADLV
         WTYP_ATBTEX = "ATEXTE"
         WCODFIC     = ""
         WCOD_TEX    = num$([F:ADP]NAM)
         WCOD_INDICE = 0
         WIDENT1     = ""
         WIDENT2     = ""
         Gosub JSON_TITLE
         #
         JSONPROP="key"   :    JSONVALUE=num$([F:ADLP]CLEPARAM) :  Gosub ADDJSONPROPV
         JSONPROP="type"  :    JSONVALUE=num$([F:ADLP]TYPPARAM) :  Gosub ADDJSONPROPV
         JSONPROP="value" :    JSONVALUE=num$([F:ADLP]VALPARAM) :  Gosub ADDJSONPROP
         #
         WIND +=1
Next
Filter [ADLP]
Return
#########################################################################################################
$JSON_ELT
Filter [ADLO] Where COD=[F:ADLV]COD
WIND = 0
For [ADLO]
         # pas sur le dernier , ni avant le premier
         If WIND <> 0
                    Wrseq WTAB+"}, {"  Using [JSO_]
         Endif
         JSONPROP="code"    : JSONVALUE=num$([F:ADLO]TABCOD)    : Gosub ADDJSONPROPV
         JSONPROP="key"     : JSONVALUE=num$([F:ADLO]TABKEY)    :  Gosub ADDJSONPROPV
         JSONPROP="keyname" : JSONVALUE=num$([F:ADLO]TABKEYNAM) :  Gosub ADDJSONPROPV
         JSONPROP="format"  : JSONVALUE=num$([F:ADLO]TABKEYFMT) :  Gosub ADDJSONPROPV
         JSONPROP="modele"  : JSONVALUE=num$([F:ADLO]TABAWM)    :  Gosub ADDJSONPROPV
         JSONPROP="leg"     : JSONVALUE=num$([F:ADLO]TABLEG)    :  Gosub ADDJSONPROPV
         JSONPROP="record"  : JSONVALUE=num$([F:ADLO]NULRECFLG) :  Gosub ADDJSONPROPV
         JSONPROP="numero"  : JSONVALUE=num$([F:ADLO]TABADINUM) :  Gosub ADDJSONPROP
         #
         WIND +=1
Next
Filter [ADLO]
Return

#########################################################################################################
$ADDJSONPROP
JSONVALUE= ESCJSON(JSONVALUE)
If JSONVALUE<>"true" and JSONVALUE<>"false"
    Wrseq WTAB+'"'+JSONPROP+'": "'+JSONVALUE+'"'  Using [JSO_]
Else
     Wrseq WTAB+'"'+JSONPROP+'" :'+JSONVALUE  Using [JSO_]
Endif
Return

$ADDJSONPROPV
JSONVALUE= ESCJSON(JSONVALUE)
If JSONVALUE<>"true" and JSONVALUE<>"false"
    Wrseq WTAB+'"'+JSONPROP+'": "'+JSONVALUE+'",'  Using [JSO_]
Else
     Wrseq WTAB+'"'+JSONPROP+'" :'+JSONVALUE+','  Using [JSO_]
Endif
Return

$ADDJSONPROPN
JSONVALUE= ESCJSON(JSONVALUE)
Wrseq WTAB+'"'+JSONPROP+'": '+JSONVALUE  Using [JSO_]
Return

$ADDJSONPROPNV
JSONVALUE= ESCJSON(JSONVALUE)
Wrseq WTAB+'"'+JSONPROP+'": '+JSONVALUE+','  Using [JSO_]
Return














