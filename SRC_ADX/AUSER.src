#<AdxTL>@(#)1.0.0.0 $Revision$
Call AUSER
End

#################################################################################
Subprog CHGUSER
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FUSER","AUSER","") From GSAISIE
End

Subprog AUSER
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FUSER","AUSER","") From GSAISIE
End

#################################################################################
$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "FIN","OK"    : Gosub FIN
 When Default
Endcase
Return


#################################################################################
$DEBUT
 Raz [M]
 If dim(CONFUSER)>0 and CONFUSER>0 and dim(ASK_USER)>0
   [M]USR=ASK_USER
   Affzo [M]USR
 Endif
 [M]LANG=GLANGUE
 [M]DATC=date$
 [M]APPLI=nomap
 Affzo [M]LANG,DATC,APPLI
 zonsui="USR"    
Return


$FIN
  Global Char ASK_USER(30) : ASK_USER=[M]USR
  Global Char ASK_PASS(30) : ASK_PASS=[M]PAS
  Global Date ASK_DATE     : ASK_DATE=[M]DATC
  Global Char ASK_LANG     : ASK_LANG=[M]LANG
Return

##########################################################################
Subprog C_USR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  GMESSAGE=mess(24,100,1)
  mkstat=2
Endif
End

Subprog C_LANG(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Local Char DOSSIER : DOSSIER=nomap
If GHISTO : DOSSIER=adxmother(0) : Endif
Read [ADS]DOSSIER=DOSSIER
If !find(VALEUR,[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  mkstat=2
  GMESSAGE=mess(138,124,1)   : # Code langue incorrect
Endif
End

Subprog AV_TYPPAG(VALEUR)
Variable Integer VALEUR
Local Char WEBPAG
#Call PARAM("","WEBPAGE",WEBPAG) From ADOVAL
VALEUR=1
#If !GBROWS or WEBPAG<>"2"
Diszo [M]TYPPAG
#Endif
End

Subprog AP_TYPPAG(VALEUR)
Variable Integer VALEUR
Global Integer ASK_TYPPAG
ASK_TYPPAG=VALEUR
End

Subprog AS_LANG(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Local Char DOSSIER : DOSSIER=nomap
If GHISTO : DOSSIER=adxmother(0) : Endif
Read [ADS]DOSSIER=DOSSIER
If [F:ADS]NBRLAN=1
  mkstat=2
Endif
End


######################################################################################

