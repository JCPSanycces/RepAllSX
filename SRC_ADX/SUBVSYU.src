# Gestion du masque VISUSYMSCE

##########################################################################
## Etiquette ajoutée par le superviseur 01/03/2004 11:34:01 (JPJ1)
##########################################################################
Subprog AS_SYMTYP(VALEUR)
Variable Integer VALEUR
Call CFGASSYM("12") From CFGLIB
End

Subprog AM_SYMTYP(VALEUR)
Variable Integer VALEUR
Effzo [M:VSYU]QSTNUM, VARNUM
Grizo [M:VSYU]QSTNUM, VARNUM
Case VALEUR
  When 1 :
    Actzo [M:VSYU]QSTNUM
  When 2 :
    Actzo [M:VSYU]VARNUM
Endcase
Affzo [M:VSYU]
End


