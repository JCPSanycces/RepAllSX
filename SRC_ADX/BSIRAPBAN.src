#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Bank statement import
# File          : BSIRAPBAN
# Version       : 1.0
# Author        : Daniel Nell
# Creation Date : 2017-09-19
######################################################################################################
# Module        : ACCOUNTING
# Description   : Glue to open RAPBAN function (Classic mode) from BSIIMP (Syracuse)
######################################################################################################
# Updates :
# Date          | Author | Version | Description
# 2017-09-19    | DNE    | 2017 R6 | Handle selection date for RAPBAN function (aka. BSIRAPBAN).
######################################################################################################


$ACTION
   Case ACTION
        When "INIT"  : Gosub INIT
        When Default : Gosub ACTION From SUBRAB
    Endcase
Return

$INIT
    # Do all the standard INITialization from the RAPBAN function and stop in case of errors.
    Gosub ACTION From SUBRAB
    If GERR : Return : Endif

    # Get statement identifier.
    Local Char STMCOD(GLONVCR) : STMCOD = PARAM(1)

    # Open additonal tables
    If !clalev([F:BSIIMP]) : Local File BSIIMP [BSIIMP]   : Endif
    If !clalev([F:BSIIP])  : Local File BSIIMPPAR [BSIIP] : Endif

    # Read statement header
    Read [F:BSIIMP]BSIIMP0 = STMCOD
    If fstat
        GMESSAGE = STMCOD - "~" - mess(1,7703,1) # 'Statement does not exist'
        GERR = 1
        SAI = 1
        Return
    Endif

    # Read corresponding import settings
    Read [F:BSIIP]BSIIP0 = [F:BSIIMP]CODIMPPAR
    If fstat
        GMESSAGE = [F:BSIIMP]CODIMPPAR - "~" - mess(6,7703,1) # 'Import settings not found'
        GERR = 1
        SAI = 1
        Return
    Endif

    # Check that flow type is 'Reconciliation only'
    If [F:BSIIP]FLOTYP <> 2
        GMESSAGE = func AFNC.MES1( mess(241,7703,1), mess(max(1, [F:BSIIP]FLOTYP),3694,1) ) # "Action not possible for bank statements with flow type '$1$'"
        GERR = 1
        SAI = 1
        Return
    Endif

    # Fill in filter screen data (DRAPBAN) from statement header
    Raz [M:RB0]
    [M:RB0]BAN = [F:BSIIMP]BAN                    # Bank
    Call C_BAN( [M:RB0]BAN ) From SUBRAB2         # BANACC and BANBPR
    If mkstat
        GERR = 1
        SAI = 1
        Return
    Endif
    Call AS_DATRBK( [M:RB0]DATRBK ) From SUBRAB2  # Last statement date
    [M:RB0]DATACE = date$                         # Last entry date
Return

