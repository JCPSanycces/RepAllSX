#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","BALCONSO","BALCONSO",4,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#######################################################
$CONTROLE
If GOK<1
 FIN = 1 : Return
Endif
TMP = 1 : # Pour afficher des tempon/tempoff
Return

#######################################################
$SEL_LISTE
Case LISTE
 When "SELCPYCNS" : Gosub SELSOC
Endcase
Return

$SELSOC
For [AGC] Where GRP=[M]GRUGPY
 Read [CPY]CPY0 = [F:AGC]CPY
 NBTEX += 1
 TEX(NBTEX)   = [F:AGC]CPY
 TEXTE(NBTEX) = [F:AGC]CPY-[F:CPY]CPYNAM
Next
Return

#######################################################
$OUVRE
Gosub OUVFIC
Local Mask BALCONSO [DIA]
Local Char    TIT(50)
Local Char    CPTATT(GLONGAC)              : # Compte d'attente qui reçoit la contrepartie des pièces multi groupes
Local Char    CPTANV(GLONGAC)              : # Compte d'à nouveaux
Local Char    CRITCYD(100),CRITHAE(250)
Local Integer NBTYP
NBTYP = max(1,nbrecord([F:GTE]))
Local Char    TPCE(GLONGTE)(1..NBTYP) : # Table types pièces
Local Char    TPCE2(GLONGTE)(1..NBTYP): # Table types pièces pour les soldes antérieurs
Local Char    XCONSBPR(15)            : # Code consolidation tiers
Local Char    CONSCPT(15)             : # Code consolidation compte
Local Char    CONSBPR(15)             : # Code consolidation tiers
Local Char    CONSCPY(15)             : # Code consolidation société
Local Char    SOC(GLONCPY)            : # Société courante
Local Char    GRP(15)                 : # Groupe conso tiers
Local Char    VALCRIT(30)             : # Valeur du critère libre en ligne d'écriture
Local Char    CURCPY(GLONCUR)         : # Devise de la société
Local Char    CURLED(GLONCUR)         : # Devise du référentiel
Local Integer OK, OKK , OKC , ARRET
Local Integer NBTIERS                 : # Nb de tiers par pièce
Local Integer HGROUPE                 : # Indicateur hors-groupe
Local Integer NBTPCE,NBTPCE2
Local Integer I , J , K
Local Decimal PERDEB,PERFIN           : # Périodes pour le calcul de la balance
Local Decimal EXODEB,EXOFIN           : # Exercices pour le calcul de la balance
Local Decimal MONTANT
Local Date    DATD,DATF               : # Date début et fin du premier exo
Local Char    PLAN(GLONCOA)
Local Integer IATT , IANV
Local Integer NBBLC, NBGLC
Local Integer IAXE , JAXE , FLANA , FLINV , FLCRI , FLGL , FLCPTATT
Local Char    SEC(GLONCCE)(1..dim([M:DIA]AXE))
Local Decimal MNTTRS , DEBTRS , CDTTRS
Local Decimal MNTCNS , DEBCNS , CDTCNS
Local Decimal MNTLED , SOLDE
Local Char    DEVTRS(GLONCUR) , DEVLED(GLONCUR) , DEVISE(GLONCUR)
Local Char    MESSA(250)
Local Integer MAXCPT : MAXCPT = 3000
Local Char    TBCPT(GLONGAC+GLONBPR+1)(1..MAXCPT)
Local Integer TBSOLDE(1..MAXCPT)
Local Integer NBCPT , ICPT
Local Char    SUBCRIT(250)
Local Char    COMPTE(GLONGAC) , TIERS(GLONBPR)

# Bug 20521 #
Local Integer PCEMAX : PCEMAX = 10000
Local Char    TYPDEB(GLONGTE)
Local Char    NUMDEB(GLONVCR)
Local Integer NB_PCE, STOP
Local Char    FILPCE(250)
##

# EMERAUDE - Feature MULTILEG- Requirement 71216
Local Integer INDCPY, NBRLEG
Local Char TABCPY(GLONCPY)(1..GNBSOC)
Local Char TABLEG(GLONADI)(1..GNBSOC)
Local Char WLEG(GLONADI)


TIT = mess(74,107,1) : # Extraction pour la consolidation
Return

#######################################################
$DEBUT
If GCONSDIA : Return : Endif
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cno") From GMEMO
If [M]ANA=2
 Actzo 20
Else
 Effzo 20
 Grizo 20
Endif
If [M]ALLCPY=2
 Effzo CPYDEB,CPYFIN
 Grizo CPYDEB,CPYFIN
Else
 Actzo CPYDEB,CPYFIN
Endif
If [M]GRUGPY=""
 Filter [AGC] Where CPY=GDEFSOC
 Read [AGC]First
 Filter [AGC]
 If fstat<=2
  [M]GRUGPY = [F:AGC]GRP
 Endif
Endif
If [M]CRITERE=""
 Local Integer LCSL : # X3-104535
 LCSL = func AFNC.ACTIV("CSL")
 If LCSL = G_OUI
  Call PARAM("","CRITCSL",[M]CRITERE) From ADOVAL
 Endif : # X3-104535
Endif
Affzo [DIA]
Return

#######################################################
$OUVFIC
If clalev([F:BLC])=0  : Local File BALCONSO   [BLC]  : Endif
If clalev([F:GLC])=0  : Local File GLCONSO    [GLC]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif
If clalev([F:CLS])=0  : Local File GACCCLS    [CLS]  : Endif
If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif
If clalev([F:DAE0])=0 : Local File GACCENTRYD [DAE0] : Endif
If clalev([F:DAA])=0  : Local File GACCENTRYA [DAA]  : Endif
If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif
If clalev([F:AGC])=0  : Local File AGRPCPY    [AGC]  : Endif
If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:ADW])=0  : Local File ADOVAL     [ADW]  : Endif
Return

#######################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT-":"-[M]GRUGPY-[F:AGF]DES,0) From GESECRAN
Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
If [M]ALLCPY=2
 Call ECR_TRACE(mess(28,129,1),0) From GESECRAN
Else
 Call ECR_TRACE(mess(26,113,1)-[M]CPYDEB-[M]CPYFIN,0) From GESECRAN
Endif
Call ECR_TRACE(mess(4,197,1)-format$("D:"+GFMDAT4,[M]STRDAT)-mess(38,197,1)-format$("D:"+GFMDAT4,[M]ENDDAT),0) From GESECRAN
Call ECR_TRACE(mess(208,111,1)-mess([M]LEDTYP,2644,1)-"("+[M]CUR+")",0) From GESECRAN
Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
MESSA = ""
If [M]ANOBLC=2 : If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(139,107,1) : Endif : # A-nouveaux
If [M]CLOBLC=2 : If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(140,107,1) : Endif : # Clôtures
If [M]STABLC=2 : If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(141,107,1) : Endif : # Ecr provisoires
If [M]CATBLC=2 : If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(142,107,1) : Endif : # Simul actives
If [M]BILBLC=2 : If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(143,107,1) : Endif : # Hors bilan
If MESSA<>""
 Call ECR_TRACE(mess(138,107,1)-":"-MESSA,0) From GESECRAN : # Sélections
Endif
If [M]ANA=2 & [M]NBAXE>0
 MESSA = mess(144,107,1)-":"
 For I=0 To [M]NBAXE-1
  MESSA -= [M]AXE(I)
 Next I
 Call ECR_TRACE(MESSA,0) From GESECRAN
Endif
MESSA = ""
If [M]DEV=2
 If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(146,107,1) : # Par devise
Endif
If [M]ANV=2
 If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(147,107,1) : # Soldes antérieurs
Endif
If [M]DEL=2
 If MESSA<>"" : MESSA -= "," : Endif : MESSA -= mess(148,107,1) : # Effacement
Endif
If MESSA<>""
 Call ECR_TRACE(mess(145,107,1)-":"-MESSA,0) From GESECRAN : # Options
Endif
If [M]CRITERE<>""
 Call ECR_TRACE(mess(149,107,1)-":"-[M]CRITERE,0) From GESECRAN
Endif
Call ECR_TRACE(string$(100,"-"),0) From GESECRAN

IATT = 0 : # Indice compte d'attente
IANV = 3 : # Indice compte d'à-nouveaux

Gosub CRITERES

Raz NBRLEG, INDCPY
For [AGC]AGC0 Where evalue(CRITCYD)
 INDCPY+=1
 TABCPY(INDCPY) = [F:AGC]CPY
Next
Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV
If NBRLEG=1
 WLEG=TABLEG(1)
 Gosub TYPPIECE
Endif

If [M]NBAXE=0
 [M]ANA = 1
Endif

Call DEBTRANS From GLOCK :  Gosub TRDEL   : If !GOK : Return : Endif
Call DEBTRANS From GLOCK :  Gosub TRCONS  : If !GOK : Return : Endif
Call DEBTRANS From GLOCK :  Gosub TREND   : If !GOK : Return : Endif
Return

#######################################################
$FIN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

#######################################################
$CRITERES
CRITCYD = "GRP=[M]GRUGPY"
If [M]ALLCPY=1
 If [M]CPYDEB<>"" : CRITCYD -= ' & CPY>="'+[M]CPYDEB+'"' : Endif
 If [M]CPYFIN<>"" : CRITCYD -= ' & CPY<="'+[M]CPYFIN+'"' : Endif
Endif

CRITHAE = ""
If STABLC=1
 If CRITHAE<>"" : CRITHAE -= '&' : Endif
 CRITHAE -= '[F:HAE]STA=2' : # Ecritures définitives
Endif

SUBCRIT = '[F:HAE]CAT=1' : # Ecritures réelles
If [M]CATBLC=2
 If SUBCRIT<>"" : SUBCRIT -= '|' : Endif
 SUBCRIT -= '[F:HAE]CAT=2' : # Simulations actives
Endif
If [M]BILBLC=2
 If SUBCRIT<>"" : SUBCRIT -= '|' : Endif
 SUBCRIT -= '[F:HAE]CAT=4' : # Hors bilan
Endif
If SUBCRIT<>""
 If CRITHAE<>"" : CRITHAE -= '&' : Endif
 CRITHAE -= '('+SUBCRIT+')'
Endif
Return

#######################################################
$TYPPIECE
Raz NBTPCE,NBTPCE2
Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
For [GTE]CLE(1)
 # Période: Normale ou A nouveaux
 If [F:GTE]PER=1 | ([F:GTE]PER=2 & [M]ANV=2)
  NBTPCE2 +=1
  TPCE2(NBTPCE2) = [F:GTE]TYP
 Endif
 # Période: Normale ou anouveau ou cloture selon options
 If [F:GTE]PER=1 | ([F:GTE]PER=2 & [M]ANOBLC=2) | ([F:GTE]PER=3 & [M]CLOBLC=2)
  NBTPCE += 1
  TPCE(NBTPCE) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
Return

#######################################################
## Effacement préalable
#######################################################
$TRDEL
If [M]DEL=2
 Call SYSTEME(adxmac(0),"valfil -z"-nomap-"BALCONSO","",OK) From ORDSYS
 Call SYSTEME(adxmac(0),"valfil -z"-nomap-"GLCONSO","",OK) From ORDSYS
Else
 Trbegin [BLC]
  Delete [BLC] Where GRUGPY=[M]GRUGPY & LEDTYP=[M]LEDTYP
 Commit
 Trbegin [GLC]
  Delete [GLC] Where GRUGPY=[M]GRUGPY & LEDTYP=[M]LEDTYP
 Commit
Endif
Return

#######################################################
## Remplissage balance + grand-livre
#######################################################
$TRCONS
 # Parcourt les sociétés du périmètre de consolidation

 For [AGC]AGC0 Where evalue(CRITCYD)
  # Recherche du code conso de la société

  SOC = [F:AGC]CPY
  Call LEC_CPY(SOC) From CPTLEC
  If !fstat
   Call MONOCPY(SOC,OK) From AX3MONO
   If !OK : Break : Endif
   CONSCPY = func GRPCPY
  Else
   # xxx : Société inexistante
   Call ECR_TRACE(SOC-":"-mess(16,104,1),1) From GESECRAN
   GOK = 0
   Break
  Endif
  Call ECR_TRACE([F:AGC]CPY-[F:CPY]CPYNAM,0) From GESECRAN
  Call ECR_TRACE(string$(100,"-"),0) From GESECRAN
  NBBLC = 0
  NBGLC = 0
  NBCPT = 0

  # Types de pièce
  If NBRLEG>1 : WLEG=[F:CPY]LEG :  Gosub TYPPIECE : Endif

  # Plan de comptes et comptes divers
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
  Call LEC_COA([F:LED]COA) From CPTLEC

  CPTATT = [F:COA]ACCMIS(IATT)
  CPTANV = [F:COA]ACCMIS(IANV)
  If CPTATT="" | CPTANV=""
   If CPTATT="" : Call ECR_TRACE(mess(132,107,1)-":"-mess(1,2649,1),1) From GESECRAN : Endif : # Compte non renseigné
   If CPTANV="" : Call ECR_TRACE(mess(132,107,1)-":"-mess(4,2649,1),1) From GESECRAN : Endif
   GOK = 0 : Break
  Endif

 # On ne traite que si la compta commence avant la date de fin

  If [F:CPY]STRPER<[M]ENDDAT
   Gosub PERIODE
   If !GOK : Break : Endif

   Filter [HAE] Where CPY=SOC & ACCDAT>=[M]STRDAT & ACCDAT<=[M]ENDDAT &
&                     find(TYP,TPCE(1..NBTPCE))>0 & evalue(CRITHAE)

   Raz NUMDEB

   $BOUCLE_PCE

   NB_PCE  = 0
   STOP    = 0

   If NUMDEB<>""
    FILPCE = '(TYP="'+TYPDEB+'"'+'& NUM>="'+NUMDEB+'") | TYP>"'+TYPDEB+'"'
   Else
    FILPCE = "1=1"
   Endif

   # Parcourt pièce par pièce
   Trbegin [BLC] , [GLC]
    For [HAE]HAE0 Where evalue(FILPCE)
     If NB_PCE>=PCEMAX
      STOP = 1 : TYPDEB = [F:HAE]TYP : NUMDEB = [F:HAE]NUM :  Break
     Endif
     NB_PCE += 1

     # Parcourt pièce par pièce
     Gosub TRTPCE
     If !GOK
      Rollback
      Call ECR_TRACE(mess(14,100,1),1) From GESECRAN : # Transaction interrompue
      Break 2
     Endif

    Next : # HAE
   Commit
   If STOP
    Goto BOUCLE_PCE
   Endif

   Filter [HAE]
  Endif
  Call MULTICPY(SOC) From AX3MONO
  Call ECR_TRACE("BALCONSO :"-num$(NBBLC)-mess(103,141,1),0) From GESECRAN : # Enregistrements créés
  Call ECR_TRACE("GLCONSO  :"-num$(NBGLC)-mess(103,141,1),0) From GESECRAN : # Enregistrements créés
 Next : # AGC

Return

$AB_TR
Rollback
Return

#######################################################
$TREND

Trbegin [BLC]

# Raz BALCONSO des mouvements nuls
 Delete [BLC] Where DEBCNS=0 & CDTCNS=0
 If fstat=1 | fstat>5
  GOK = 0
  Call RSTA("BLC","") From GLOCK
  Goto AB_TR
 Endif

 For [BLC]BLC0(4) # (LEDTYP+GRUGPY+CPYGRU+ACCGRU) => Le premier est le groupe vide
  If [F:BLC]BPRGRU<>""
   Raz [F:BLC]BPRGRU,[F:BLC]DEBCNS,[F:BLC]CDTCNS,[F:BLC]SNSBLC,[F:BLC]BLC,[F:BLC]DEBTRS,[F:BLC]CDTTRS
   NBBLC += 1
   Write [BLC]
   If fstat
    GOK = 0 : Call FSTA("BLC") From GLOCK : Break
   Endif
  Endif
 Next
 If !GOK : Goto AB_TR : Endif
Commit
Return

#######################################################
$TRTPCE
OK = 1
Gosub CTLMULGRP
If (NBTIERS>1) or (NBTIERS=1 & HGROUPE)
 Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-":"-mess(75,107,1),0) From GESECRAN
 # Pièce multi-groupe
Endif
If OK

 Filter [DAE] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=[M]LEDTYP
 For [DAE]DAE0

  PLAN = [F:DAE]COA
  Read [GAC]GAC0 = PLAN;[F:DAE]ACC
  If fstat
   Call ECR_TRACE([F:DAE]TYP-[F:DAE]NUM-"-"-[F:DAE]ACC-":"-mess(44,102,1),1) From GESECRAN
   # Compte inexistant
  Else
   COMPTE = [F:DAE]ACC
   TIERS  = [F:DAE]BPR
   Gosub SOLDE
   If !NBTIERS
    Gosub HORS_GROUPE
   Else  : # Groupe : traitement des flux intra périmètre
    If (NBTIERS>1) | (NBTIERS=1 & HGROUPE)
     Gosub MULTI_GROUPE
    Elsif NBTIERS=1 & GRP<>"" & !HGROUPE
     Gosub MONO_GROUPE
    Endif
   Endif
   If !GOK : Break : Endif
  Endif : # !fstat
 Next
 Filter [DAE]
Endif
Return

#######################################################
## Pièce hors-groupe
#######################################################
$HORS_GROUPE
Raz CONSBPR
Gosub MAJ_BALCONSO
Return

#######################################################
## Pièce mono-groupe
#######################################################
$MONO_GROUPE
If [F:GAC]CSLFLG=2 : # Détail suivi conso
 CONSBPR = GRP
 FLGL = 1
 Gosub MAJ_BALCONSO
 If !GOK : Return  : Endif
Endif
# On MAJ le hors groupe (<=> Total balance)
Raz CONSBPR
Gosub MAJ_BALCONSO
If !GOK : Return  : Endif
Return

#######################################################
## Pièce multi-groupe
#######################################################
$MULTI_GROUPE
If [F:DAE]BPR<>""
 Read [BPR]BPR0 = [F:DAE]BPR
 If !fstat
  If [F:BPR]GRUGPY=[M]GRUGPY : # Tiers du groupe
   If [F:GAC]CSLFLG=2 : # Analyse du détail conso
    CONSBPR = func GRPBPR
    FLGL = 1
    Gosub MAJ_BALCONSO
    If !GOK : Return  : Endif
    # On MAJ le hors groupe (<=> Total balance)
    XCONSBPR = CONSBPR
    Raz CONSBPR
    Gosub MAJ_BALCONSO
    If !GOK : Return  : Endif
    CONSBPR = XCONSBPR
    # On passe la contrepartie des comptes tiers dans le compte attente
    # en les ventilant par groupe s'ils sont :
    # analysés en conso, du même périmètre mais pas du même groupe conso
    COMPTE = CPTATT
    FLINV = 1 : FLCPTATT = 1
    Gosub MAJ_BALCONSO
    FLINV = 0 : FLCPTATT = 0
    If !GOK : Return : Endif
   Else : # Pas de détail
    Raz CONSBPR
    Gosub MAJ_BALCONSO
    If !GOK : Return : Endif
   Endif
  Else : # Compte tiers hors groupe
   Raz CONSBPR
   Gosub MAJ_BALCONSO
   If !GOK : Return  : Endif
  Endif
 Endif
Else : # Compte général dans une pièce multi groupe
 Raz CONSBPR
 Gosub MAJ_BALCONSO
 If !GOK : Return : Endif
Endif
Return

#######################################################
$PERIODE
Call GETPERSOC(SOC,[M]LEDTYP,[M]STRDAT,EXODEB,PERDEB) From CPTSUB
Call GETPERSOC(SOC,[M]LEDTYP,[M]ENDDAT,EXOFIN,PERFIN) From CPTSUB
If PERFIN=0
 # Période incorrecte
 Call ECR_TRACE(SOC-":"-mess(10,116,1),1) From GESECRAN
 GOK = 0
 Return
Endif
If EXOFIN-EXODEB>1
 # La consolidation ne peut concerner plus de 2 exercices
 Call ECR_TRACE(SOC-":"-mess(77,107,1),1) From GESECRAN
 GOK = 0
 Return
Endif
If EXODEB<>0 & (EXODEB+1=EXOFIN) & [M]ANV=2
 Gosub ANOUV
Endif
Return

$ANOUV
# On calcule le solde cumulé à la fin de la période précédent l'extraction pour
# les comptes de bilan. On s'équilibre sur le compte CPTANV.
Call DATEXE(SOC,[M]LEDTYP,EXODEB,DATD,DATF) From CPTSUB
Raz CONSBPR

Trbegin [BLC] : # Bug 20521 #
 For [HAE] Where ACCDAT>=DATD & ACCDAT<=[M]STRDAT-1 & CPY=SOC
&              & find(TYP,TPCE2(1..NBTPCE2))>0 & [F:HAE]CAT<3
  For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=[M]LEDTYP
   Read[GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
   If fstat
    Call ECR_TRACE([F:DAE]TYP-[F:DAE]NUM-"-"-[F:DAE]ACC-":"-mess(44,102,1),1) From GESECRAN
    # Compte inexistant
   Else
    Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
    If [F:CLS]TYP<>2 : # Non remis à zéro <=>find([F:GAC]CLS,1,2,3,4,5)
     COMPTE = [F:GAC]ACC
     TIERS  = ""
     Gosub SOLDE
     Gosub MAJ_BALCONSO
     If !GOK : Break : Endif
     COMPTE = CPTANV
     TIERS  = ""
     FLINV = 1
     FLCRI = 1
     Gosub SOLDE
     Gosub MAJ_BALCONSO
     If !GOK : Break : Endif
     FLINV = 0
    Endif
   Endif
  Next
 Next
Commit  # Bug 20521 #
Return

###############################################################################
## MAJ Balance
###############################################################################
$MAJ_BALCONSO
FLANA = 0
If [M]ANA=2
 For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & LEDTYP=[F:DAE]LEDTYP
  Raz SEC
  For IAXE=1 To [M]NBAXE
   JAXE = find([M]AXE(IAXE-1),[F:DAA]DIE)
   If JAXE
    SEC(IAXE) = [F:DAA]CCE(JAXE-1)
   Endif
  Next IAXE
  Gosub MONTANA
  If OKK
   Gosub MAJ_BAL
  Endif
  FLANA = 1
 Next
Endif
If !FLANA
 Raz SEC
 Gosub MONTANT
 If OKK
  Gosub MAJ_BAL
 Endif
Endif
FLGL  = 0
FLCRI = 0
Return

$SOLDE
ICPT = find(COMPTE-TIERS,TBCPT(1..NBCPT))
If ICPT
 SOLDE = TBSOLDE(ICPT)
Else
 SOLDE = 0
 For [BAL] Where LEDTYP=[M]LEDTYP & CPY=SOC & FCY="" & FIY=EXOFIN & ACC=COMPTE & BPR=TIERS
  SOLDE += sum([F:BAL]DEBLED(0..PERFIN))-sum([F:BAL]CDTLED(0..PERFIN))
 Next
 If NBCPT<dim(TBCPT)
  NBCPT += 1
  TBCPT(NBCPT)   = COMPTE-TIERS
  TBSOLDE(NBCPT) = sgn(SOLDE)
 Endif
Endif
Return

$MAJ_BAL
If [M]CRITERE<>"" & !FLCRI
 Onerrgo PBCRIT
 VALCRIT = evalue([M]CRITERE)
 Onerrgo
 If !GOK : Return : Endif
Else
 VALCRIT = ""
Endif
If dim([L]FLCPTATT)>0 & FLCPTATT=1
 CONSCPT = COMPTE
Else
 CONSCPT = func GRPGAC(SOLDE)
Endif
If [M]DEV=2
 DEVISE = DEVTRS
Else
 DEVISE = ""
Endif
GCLE = [M]GRUGPY-CONSCPY-CONSCPT-CONSBPR
Readlock [BLC]BLC0 = [M]LEDTYP;[M]GRUGPY;CONSCPY;CONSCPT;CONSBPR
&                    ;SEC(1);SEC(2);SEC(3);SEC(4);SEC(5);SEC(6);SEC(7);SEC(8);SEC(9)
&                    ;DEVISE;VALCRIT
If fstat=1
 GOK = 0 : Call RSTA("BLC",GCLE) From GLOCK : Return
Elsif fstat
 Raz [F:BLC]
 [F:BLC]LEDTYP = [M]LEDTYP
 [F:BLC]GRUGPY = [M]GRUGPY
 [F:BLC]DATDEB = [M]STRDAT
 [F:BLC]DATFIN = [M]ENDDAT
 [F:BLC]CURCNS = [M]CUR
 [F:BLC]CURTRS = DEVISE
 [F:BLC]ANOUV  = [M]ANV
 [F:BLC]CPYGRU = CONSCPY
 [F:BLC]BPRGRU = CONSBPR
 [F:BLC]ACCGRU = CONSCPT
 [F:BLC]CREUSR = GUSER
 [F:BLC]CREDAT = date$
 [F:BLC]CRETIM = time
 [F:BLC]CRI    = VALCRIT
 For IAXE=1 To [M]NBAXE
  Case IAXE
   When 1 : [F:BLC]DIE1 = [M]AXE(IAXE-1) : [F:BLC]CCE1 = SEC(1)
   When 2 : [F:BLC]DIE2 = [M]AXE(IAXE-1) : [F:BLC]CCE2 = SEC(2)
   When 3 : [F:BLC]DIE3 = [M]AXE(IAXE-1) : [F:BLC]CCE3 = SEC(3)
   When 4 : [F:BLC]DIE4 = [M]AXE(IAXE-1) : [F:BLC]CCE4 = SEC(4)
   When 5 : [F:BLC]DIE5 = [M]AXE(IAXE-1) : [F:BLC]CCE5 = SEC(5)
   When 6 : [F:BLC]DIE6 = [M]AXE(IAXE-1) : [F:BLC]CCE6 = SEC(6)
   When 7 : [F:BLC]DIE7 = [M]AXE(IAXE-1) : [F:BLC]CCE7 = SEC(7)
   When 8 : [F:BLC]DIE8 = [M]AXE(IAXE-1) : [F:BLC]CCE8 = SEC(8)
   When 9 : [F:BLC]DIE9 = [M]AXE(IAXE-1) : [F:BLC]CCE9 = SEC(9)
  Endcase
 Next IAXE
 Gosub DESIG
 Gosub CUMUL
 NBBLC += 1
 Write [BLC]
Else
 Gosub CUMUL
 Rewrite [BLC]
Endif
If fstat
 GOK = 0 : Call FSTA("BLC") From GLOCK : Return
Endif
If FLGL
 Gosub MAJ_GL
Endif
Return

$CUMUL
If [M]DEV=2
 [F:BLC]DEBTRS += DEBTRS
 [F:BLC]CDTTRS += CDTTRS
Endif
[F:BLC]DEBCNS += DEBCNS
[F:BLC]CDTCNS += CDTCNS
If [F:BLC]CDTCNS>[F:BLC]DEBCNS
 [F:BLC]SNSBLC = -1
 [F:BLC]BLC    = [F:BLC]CDTCNS-[F:BLC]DEBCNS
Else
 [F:BLC]SNSBLC = 1
 [F:BLC]BLC    = [F:BLC]DEBCNS-[F:BLC]CDTCNS
Endif
Return

$DESIG
OK = 1
[F:BLC]DES = ""
Filter [GAC2] Where COA=PLAN & left$(ACC,len(CONSCPT))=CONSCPT
Read [GAC2]GAC0 First
Filter [GAC2]
If fstat<=2
 Call LECTEXTRA([F:BLC]DES,"GACCOUNT","DESTRA",PLAN,[F:GAC2]ACC) From ATEXTRA
Endif
If [F:BLC]DES=""
 [F:BLC]DES = mess(78,107,1)-CONSCPT : # Consolidation code xxx
Endif
Return

$PBCRIT
Call ECR_TRACE(mess(81,107,1),1) From GESECRAN
# Critère libre de consolidation mal défini
GOK = 0
Resume

###################################################################
## MAJ Grand-livre
###################################################################
$MAJ_GL
Raz [F:GLC]
[F:GLC]LEDTYP = [M]LEDTYP
[F:GLC]GRUGPY = [M]GRUGPY
[F:GLC]DATDEB = [M]STRDAT
[F:GLC]DATFIN = [M]ENDDAT
[F:GLC]ANOUV  = [M]ANV
[F:GLC]CPYGRU = CONSCPY
[F:GLC]BPRGRU = CONSBPR
[F:GLC]ACCGRU = CONSCPT
[F:GLC]DES    = [F:BLC]DES
[F:GLC]ACCNUM = [F:DAE]ACCNUM
[F:GLC]ANALIN = [F:DAA]ANALIN
[F:GLC]CRI    = VALCRIT
[F:GLC]CURCNS = [M]CUR
[F:GLC]CURTRS = DEVTRS
[F:GLC]AMTCNS = DEBCNS-CDTCNS
[F:GLC]AMTTRS = DEBTRS-CDTTRS
For IAXE=1 To [M]NBAXE
 Case IAXE
  When 1 : [F:GLC]DIE1 = [M]AXE(IAXE-1) : [F:GLC]CCE1 = SEC(1)
  When 2 : [F:GLC]DIE2 = [M]AXE(IAXE-1) : [F:GLC]CCE2 = SEC(2)
  When 3 : [F:GLC]DIE3 = [M]AXE(IAXE-1) : [F:GLC]CCE3 = SEC(3)
  When 4 : [F:GLC]DIE4 = [M]AXE(IAXE-1) : [F:GLC]CCE4 = SEC(4)
  When 5 : [F:GLC]DIE5 = [M]AXE(IAXE-1) : [F:GLC]CCE5 = SEC(5)
  When 6 : [F:GLC]DIE6 = [M]AXE(IAXE-1) : [F:GLC]CCE6 = SEC(6)
  When 7 : [F:GLC]DIE7 = [M]AXE(IAXE-1) : [F:GLC]CCE7 = SEC(7)
  When 8 : [F:GLC]DIE8 = [M]AXE(IAXE-1) : [F:GLC]CCE8 = SEC(8)
  When 9 : [F:GLC]DIE9 = [M]AXE(IAXE-1) : [F:GLC]CCE9 = SEC(9)
 Endcase
Next IAXE
[F:GLC]CREUSR = GUSER
[F:GLC]CREDAT = date$
[F:GLC]CRETIM = time
NBGLC += 1
Write [GLC]
If fstat
 GOK = 0 : Call FSTA("GLC") From GLOCK : Return
Endif
Return

###################################################################
## Montant en fonction de la devise
###################################################################
$MONTANT
MNTTRS = [F:DAE]AMTCUR
MNTLED = [F:DAE]AMTLED
DEVTRS = [F:DAE]CUR
DEVLED = [F:DAE]CURLED
Goto MONTCNS

$MONTANA
MNTTRS = [F:DAA]AMTCUR
MNTLED = [F:DAA]AMTLED
DEVTRS = [F:DAA]CUR
DEVLED = [F:DAA]CURLED
Goto MONTCNS

$MONTCNS
OKK = 1
Raz DEBTRS,CDTTRS,DEBCNS,CDTCNS
Case [M]CUR
 When DEVTRS
  MNTCNS = MNTTRS
 When DEVLED
  MNTCNS = MNTLED
 When Default
  Call CONVERT(DEVTRS,[M]CUR,DEVLED,[F:HAE]TYPRAT,[F:DAE]ACCDAT,MNTTRS,MNTCNS,OKC) From TRTDEV
  If OKC
   Call ECR_TRACE([F:DAE]TYP-[F:DAE]NUM-"-"-[F:DAE]ACC-":"-mess(34,110,1),1) From GESECRAN
   # Erreur en conversion devise
   OKK = 0 : Return
  Endif
Endcase

If !FLINV
 If [F:DAE]SNS=1
  DEBTRS = MNTTRS
  DEBCNS = MNTCNS
 Else
  CDTTRS = MNTTRS
  CDTCNS = MNTCNS
 Endif
Else
 If [F:DAE]SNS=1
  CDTTRS = MNTTRS
  CDTCNS = MNTCNS
 Else
  DEBTRS = MNTTRS
  DEBCNS = MNTCNS
 Endif
Endif
OKK = (DEBTRS<>0)+(CDTTRS<>0)+(DEBCNS<>0)+(CDTCNS<>0)
Return

#############################################################################
# Contrôle si la pièce contient :
# plusieurs groupes tiers pour le périmètre
# plusieurs tiers de périmètres différents
#############################################################################
$CTLMULGRP
HGROUPE = 0  : # 0=intra-groupe, 1=Présence de tiers hors-groupe
NBTIERS = 0  : # 0=hors-groupe,  1=Présence tiers GRP, >1=plusieurs tiers
GRP     = ""
Filter [DAE0] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=[M]LEDTYP & BPR<>""
For [DAE0]DAE0
 Read [BPR]BPR0 = [F:DAE0]BPR
 If fstat
  Call ECR_TRACE([F:DAE0]TYP-[F:DAE0]NUM-"-"-[F:DAE0]BPR-":"-mess(31,105,1)-mess(87,100,1),1) From GESECRAN
  # Tiers inexistant
  OK = 0
 Else
  If [F:BPR]GRUGPY=[M]GRUGPY : # Il est dans le périmètre de conso
   If NBTIERS=0
    NBTIERS = 1
    GRP   = func GRPBPR
   Else
    NBTIERS += 1
   Endif
  Else
   HGROUPE = 1
  Endif
 Endif
Next : # DAE0
Return

###################################################################################
## Renvoie les codes groupes
###################################################################################
Funprog GRPBPR
If [F:BPR]GRUCOD<>""
 End [F:BPR]GRUCOD
Else
 End [F:BPR]BPRNUM
Endif

Funprog GRPGAC(MONTANT)
Value Decimal MONTANT
If MONTANT>=0
 If [F:GAC]CSLDEB<>""
  End [F:GAC]CSLDEB
 Else
  End [F:GAC]ACC
 Endif
Else
 If [F:GAC]CSLCDT<>""
  End [F:GAC]CSLCDT
 Else
  End [F:GAC]ACC
 Endif
Endif

Funprog GRPCPY
If [F:CPY]GRUCOD<>""
 End [F:CPY]GRUCOD
Else
 End [F:CPY]CPY
Endif

Funprog FLUX
If [F:DAE]SNS=1
 End [F:GAC]FLODEB
Else
 End [F:GAC]FLOCDT
Endif

