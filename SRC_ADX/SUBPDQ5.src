#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# ------------------------------------------------------------------- #
# VISUETASHD : Affichage situation ligne d'expédition                 #
#######################################################################
$ACTION
#---------------------------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)                          #
# VISUETASHD : Affichage situation ligne d'expédition                 #
#---------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TITRE_FEN
 When "DEBUT"       : Gosub DEBUT
 When "FINSAI"      : Gosub FINSAI
Endcase
Return
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Case GACTION
 When "VISUETASHD" : Gosub OUV_VISUETASHD
Endcase
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
Case GACTION
 When "VISUETASHD" : TIT=mess(304,195,1)-NUMSHIP-num$(LINSHIP)
Endcase
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Case GACTION
 When "VISUETASHD" : Gosub DEB_VISUETASHD
Endcase
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
Case GACTION
 When "VISUETASHD" : Gosub FINSAI_VISUETASHD
Endcase
Return


#############################################################################
# Action VISUETASHD avec paramètres :                           MAE 05/01/17#
#   PARAM(1) = NUM    : Numéro   de l'expédition à traiter                  #
#   PARAM(2) = LIN    : Numéro   de la ligne d'expédition à traiter         #
#   PARAM(3) = WABMSK : Abréviation du masque écran contenant les lignes    #
#   PARAM(4) = NOLIG  : Numéro de ligne tableau lignes commande (nolign-1)  #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_VISUETASHD
#----- Variables locales -----#
Local Char     NUMSHIP(GLONSHIP) : NUMSHIP=PARAM(1)
Local Integer  LINSHIP           : LINSHIP=val(PARAM(2))
Local Char     WABMSK(5)       : WABMSK =PARAM(3)
Local Shortint NOL             : NOL=val(PARAM(4))
Local Shortint SAVGNOLIGN, I, J, K
Local Integer  WPNDLIN(30)
Local Char     WPNHNUM(GLONPNH)(30)
SAVNOLIGN=nolign
If evalue("[M:"+WABMSK+"]NBLIG=0") |
&  evalue("[M:"+WABMSK+"]ITMREF(NOL)=''") | GREP="C" | GREP="D"
  FIN=1
Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_VISUETASHD
Local Char WQLYCTLDEM(GLONVCR) : #VPO 09/12/10 69709
# Issue 106506 - 2015-05-07 by SR : Landed Cost
Local Decimal WQTYSHD

Raz [M:PDQ5]
Call TEMPON("O") From GESECRAN
#----- Lecture ligne commande à traiter si nécessaire -----#
If [F:SHD]SHIPNUM<>NUMSHIP | [F:SHD]SHIPLIN<>LINSHIP
  Read [SHD] SHD0=NUMSHIP;LINSHIP : If fstat Raz [F:SHD] : Endif
Endif
#----- Ouverture des fichiers si nécessaire ----#
If clalev([F:PTD])<=0 Local File PRECEIPTD [PTD] : Endif
If clalev([F:POQ])<=0 Local File PORDERQ   [POQ] : Endif
If clalev([F:PND])<=0 Local File PRETURND  [PND] : Endif
If clalev([F:PIH])<=0 Local File PINVOICE  [PIH] : Endif
If clalev([F:PID])<=0 Local File PINVOICED [PID] : Endif
# Issue 75928 - 2011-09-01 by SR : Travailler sur une autre abréviation
If clalev([F:STJ1])<=0 Local File STOJOU    [STJ1] : Endif
#If clalev([F:STJ])<=0 Local File STOJOU    [STJ] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER [ITM] : Endif
# Issue 106506 - 2015-05-07 by SR : Landed Cost
#If clalev([F:SHD])<=0 Local File SHIPMENTD [SHD] : Endif
# Issue 110325 - 2016-02-11 by SR : Pré réception de commande
#If clalev([F:SHH])<=0 Local File SHIPMENT [SHH] : Endif


#----- Chargement des zones dans le masque -----#
[M:PDQ5]ITMREF   =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PDQ5]ITMDES   =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PDQ5]PUU      =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ5]PUU2     =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ5]PUU3     =evalue("[M:"+WABMSK+"]PUU(NOL)")
# Issue 106506 - 2015-05-07 by SR : Landed Cost
[M:PDQ5]PUU4     =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ5]SHDQTYPUU = evalue("[M:"+WABMSK+"]SHIQTY(NOL)")

#-----
[M:PDQ5]NETPRI1  =evalue("[M:"+WABMSK+"]NETPRI(NOL)")
[M:PDQ5]CUR1     =evalue("[M:"+WABMSK+"]NETCUR")
[M:PDQ5]CUR2     =evalue("[M:"+WABMSK+"]NETCUR")
[M:PDQ5]CUR3     =evalue("[M:"+WABMSK+"]NETCUR")
#----infos de l'expédition
[M:PDQ5]CTRNUM = [F:SHD]CTRNUM
[M:PDQ5]CLEFLG = [F:SHD]CLEFLG


#----- Chargement des infos de la commande -----#
If [F:POQ]POHNUM<>[F:SHD]POHNUM | [F:POQ]POPLIN<>[F:SHD]POPLIN | [F:POQ]POQSEQ<>[F:SHD]POQSEQ
  Read [POQ] POQ0=[F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ : If fstat Raz [F:POQ] : Endif
Endif

[M:PDQ5]POHNUM = [F:SHD]POHNUM
[M:PDQ5]POPLIN = [F:SHD]POPLIN

[M:PDQ5]QTYPUU   =[F:POQ]QTYPUU
[M:PDQ5]LINCLEFLG=[F:POQ]LINCLEFLG
[M:PDQ5]LINCLELIB=mess([M:PDQ5]LINCLEFLG,1,1)
[M:PDQ5]RCPQTYPUU=[F:SHD]RCPQTYPUU
[M:PDQ5]LINATI   =[F:POQ]LINATI


#----- Chargement des réceptions effectuées sur la ligne d'expédition -----#
Filter [PTD] Where SHIPNUM=NUMSHIP & SHIPLIN=LINSHIP
Raz I
For [PTD]
  [M:PDQ5]PTHNUM(I)     =[F:PTD]PTHNUM
  [M:PDQ5]PTDLIN(I)     =[F:PTD]PTDLIN
  [M:PDQ5]RCPDAT(I)     =[F:PTD]RCPDAT
  [M:PDQ5]PRHFCY(I)     =[F:PTD]PRHFCY
  [M:PDQ5]RCPNETPRI(I)  =[F:PTD]NETPRI
  [M:PDQ5]RCPLINAMT(I)  =[F:PTD]LINAMT
  [M:PDQ5]NETCUR(I)     =[F:PTD]NETCUR

  If [F:ITM]ITMREF<>[F:PTD]ITMREF
    Read [ITM]ITM0=[F:PTD]ITMREF
    If fstat : Raz [F:ITM]ITMREF : Endif
  Endif
  If [F:PTD]STOMGTCOD>1
    Raz WQLYCTLDEM : #VPO 09/12/10 69709
    Raz GBIDD1, GBIDD2, GBIDD3
    For [STJ1]STJ1 Where STOFCY = [F:PTD]PRHFCY   &
&                       VCRTYP = 6               &
&                       VCRNUM = [F:PTD]PTHNUM   &
&                       VCRLIN = [F:PTD]PTDLIN   &
&                       ITMREF = [F:PTD]ITMREF   &
&                       UPDCOD = 2               &
&                       REGFLG <>2
      If [F:STJ1]QTYSTU>0
        If left$([F:STJ1]STA,1)="A"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD1+=[F:STJ1]QTYPCU
          Else
            GBIDD1+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="Q"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD2+=[F:STJ1]QTYPCU
          Else
            GBIDD2+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
          #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
          # on récupère demande d'analyse
          If [F:STJ1]QLYCTLDEM<>""  WQLYCTLDEM=[F:STJ1]QLYCTLDEM : Endif
        Elsif left$([F:STJ1]STA,1)="R"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD3+=[F:STJ1]QTYPCU
          Else
            GBIDD3+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Endif
      Endif
    Next
    #VPO 09/12/10 69709 ajuster les quantites par statut en fonction des mouvements de stock
    # selon demande d'analyse
    If WQLYCTLDEM<>""
      For [STJ1] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                    & VCRNUM=WQLYCTLDEM
&                    & VCRTYPORI=6
&                    & VCRNUMORI=[F:PTD]PTHNUM
&                    & VCRLINORI=[F:PTD]PTDLIN
&                    & ITMREF = [F:PTD]ITMREF
&                    & UPDCOD = 2
&                    & REGFLG<>2
        If left$([F:STJ1]STA,1)="A"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD1+=[F:STJ1]QTYPCU
          Else
            GBIDD1+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="Q"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD2+=[F:STJ1]QTYPCU
          Else
            GBIDD2+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Elsif left$([F:STJ1]STA,1)="R"
          If [F:STJ1]PCU=[M:PDQ5]PUU
            GBIDD3+=[F:STJ1]QTYPCU
          Else
            GBIDD3+=[F:STJ1]QTYSTU*[F:PTD]QTYPUU/[F:PTD]QTYSTU
          Endif
        Endif
      Next
    Endif
    If [F:PTD]UOMSTUCOE=0 : [F:PTD]UOMSTUCOE=1 : Endif
    #----- Quantité en A en PUU -----#
    Call QTEARR(GBIDD1, [F:PTD]PUU) From TRTDIV
    [M:PDQ5]AAAQTYPUU(I)=GBIDD1
    #----- Quantité en Q en PUU -----#
    Call QTEARR(GBIDD2, [F:PTD]PUU) From TRTDIV
    [M:PDQ5]QQQQTYPUU(I)=GBIDD2
    #----- Quantité en R en PUU -----#
    Call QTEARR(GBIDD3, [F:PTD]PUU) From TRTDIV
    [M:PDQ5]RRRQTYPUU(I)=GBIDD3
  Else
    [M:PDQ5]AAAQTYPUU(I)=[F:PTD]QTYPUU-[F:PTD]RRRQTYPUU
    Raz [M:PDQ5]QQQQTYPUU(I)
    [M:PDQ5]RRRQTYPUU(I)=[F:PTD]RRRQTYPUU
  Endif
  [M:PDQ5]RTNQTYPUU(I)=[F:PTD]RTNQTYPUU
  I+=1 : [M:PDQ5]NBRCP=I
  If I>dim([M:PDQ5]PTHNUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
[M:PDQ5]LINAMT =sigma(I=0,[M:PDQ5]NBRCP-1,[M:PDQ5]RCPLINAMT(I))
Filter [PTD]
#Nombre de lignes de réception
[M:PDQ5]LINRCPNBR=[M:PDQ5]NBRCP

#----- Chargement des factures complémentaires sur expédition-----#
Filter [PID] Where TYPORI=6 & NUMORI=NUMSHIP & LINORI=LINSHIP
Raz I
For [PID]
  Gosub CHARG_LIG_FAC
  If I>dim([M:PDQ5]NUM)-1 GMESSAGE=mess(26,100,1) : GERR=2 : Break : Endif
Next
If I>dim([M:PDQ5]NUM)-1 Goto AFFICH_SITUATION_LIG_CDE : Endif
#Nombre de lignes de facture
[M:PDQ5]LININVNBR=[M:PDQ5]NBFAC
[M:PDQ5]CUR4      =evalue("[M:"+WABMSK+"]NETCUR")
#quantité facturée
#[M:PDQ5]INVQTYPUU=sigma(I=0,[M:PDQ5]NBFAC-1,
#&                  [M:PDQ5]FACQTYPUU(I))
#---
[M:PDQ5]AMTPIHFCC =sigma(I=0,[M:PDQ5]NBFAC-1,[M:PDQ5]AMTNOTLIN(I))
#---


#----- Affichage foreground -----#
$AFFICH_SITUATION_LIG_CDE
Filter [PID] : Filter [PND]
Affzo [PDQ5]
Call TEMPOFF From GESECRAN
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_VISUETASHD
nolign=SAVNOLIGN
Return

#--------------------------#
# Chargement ligne facture #
#--------------------------#
$CHARG_LIG_FAC
[M:PDQ5]NUM(I)      =[F:PID]NUM
[M:PDQ5]PIDLIN(I)   =[F:PID]PIDLIN

If [F:PIH]NUM<>[F:PID]NUM
  Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
Endif
[M:PDQ5]ACCDAT(I)   =[F:PIH]ACCDAT
[M:PDQ5]FCY(I)      =[F:PID]FCY
#[M:PDQ5]FACQTYPUU(I)=[F:PID]QTYPUU
#[M:PDQ5]NETPRI(I)   =[F:PID]NETPRI
[M:PDQ5]CUR(I)      =[F:PIH]CUR
[M:PDQ5]AMTNOTLIN(I)=[F:PID]AMTNOTLIN
I+=1 : [M:PDQ5]NBFAC=I

Return

##########################################################################

Subprog IB_NBRCP
#--------------------------------------------#
# Avant zone : Activation bouton "Réception" #
#--------------------------------------------#
Raz GBOUT1
If [M:PDQ5]PTHNUM(nolign-1)<>"" & GFONC1<>"GESPTH"
  GBOUT1=mess(117,198,1)-[M:PDQ5]PTHNUM(nolign-1)
Endif
End

Subprog IB_NBFAC
#------------------------------------------#
# Avant zone : Activation bouton "Facture" #
#------------------------------------------#
Raz GBOUT1
If [M:PDQ5]NUM(nolign-1)<>"" & GFONC1<>"GESPIH"
  GBOUT1=mess(55,198,1)-[M:PDQ5]NUM(nolign-1)
Endif
End

