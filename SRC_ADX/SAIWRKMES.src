#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(250)(1..4) , VALEUR(GLONAWA)
PARAM(1) = "AMK"
PARAM(2) = "AOB"
PARAM(3) = "1"
Local File AMSK [AMK]
Local Mask AMK0 [AMK0]
GBIDC1 = "AOB0"
Read [AMK]CODMSK = GBIDC1
[M] = [F]
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIWRKMES","",5,"") From GTRAITE
End

#------------------------------------------------------------------------------------------------------#
# Le GTRAITE permet de choisir un code workflow (SEL_LISTE) et de lancer le workflow sur ce code
# Il est appelé notamment par le bouton "Workflow" de la gestion d'objet (trt GOBJACT)
# Le GSAISIE permet de modifier éventuellement (texte et destinataires) le mail généré par le workflow
# Il est appelé par le traitement AWRK
#------------------------------------------------------------------------------------------------------#

$ACTION
Case ACTION

 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC

 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE

 When "OUVRE"       : Gosub OUVRE
 When "TITRE"       : Gosub TIT
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABA
 When "OK"          : Gosub OK

Endcase
Return

#--------------- GTRAITE -----------------------------------#
$INIT
Local Char    ABREV(GLONAOB) , CLEOBJ(250) , GRPDEB(GLONVCR)
ABREV  = PARAM(1)
CLEOBJ = PARAM(2)
Return

#----------------------------#
$CONTROLE
If PARAM(3)="0"
 FIN = 1
Endif
Return

#----------------------------#
$EXEC
Read [AWA]AWA0 = VALEUR
Call WORKPLUS([F:AWA]TYPEVT,[F:AWA]CODEVT,"W",CLEOBJ,[F:AWA]CODE,0,0,0,GRPDEB) From AWRK
Return

#--------------- GACTION -----------------------------------#
$SEL_LISTE
Local Char    ABREV(GLONAOB) , TIT(30)
If clalev([F:AWA])=0  : Local File AWRKPAR [AWA]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA [AXX]  : Endif
ABREV = PARAM(1)
Raz NBTEX
Filter [AWA] Where TYPEVT=2 & CODEVT=[L]ABREV
&                & ENAFLG=2 & (ENAMES=2 | ENASUI=2 | ENAACT=2)
For [AWA]AWA1
 If instr(1,[F:AWA]OPERATION,"W")
  If NBTEX>=dim(TEX)-1 : Break : Endif
  NBTEX += 1
  TEX(NBTEX) = [F:AWA]CODE
  Call LECTEXTRA(TEXTE(NBTEX),"AWRKPAR","INTIT",[F:AWA]CODE,"") From ATEXTRA
  TEXTE(NBTEX) = [F:AWA]CODE-TEXTE(NBTEX)
 Endif
Next
Filter [AWA]
If NBTEX=0
 Read [AWA]AWA1(2) = 1;"BUT"
 If !fstat
  NBTEX += 1
  TEX(NBTEX) = [F:AWA]CODE
 Else
  PARAM(3) = "0"
 Endif
Endif
TIT = mess(112,75,1) : # Choix d'un workflow
Return

#----------------------------#
$FIN_LISTE
If status=7
 PARAM(3) = "0"
Else
 PARAM(3) = "1"
Endif
Return

#--------------- GSAISIE -----------------------------------#
$OUVRE
If clalev([M:AWAY])=0 : FIN = 1 : Return : Endif
If clalev([F:AWA])=0  : Local File AWRKPAR [AWA]  : Endif
Read [AWA]AWA0 = VALEUR
If fstat : Raz [F:AWA] : Endif
Return

#----------------------------#
$TIT
TIT -= [F:AWA]CODE
Call LECTEXTRA(GMESSAGE,"AWRKPAR","INTIT",[F:AWA]CODE,"") From ATEXTRA
If GMESSAGE<>""
 TIT -= "("+GMESSAGE+")"
 GMESSAGE = ""
Endif
Return

#----------------------------#
$DEBUT
[M] = [M:AWAY]

# TYPMES  Paramètre workflow (Indifférent/Serveur/Client)
# GTYPMES Paramètre général (Client/Serveur)

If [M]TYPMES=3 | (GTYPMES=1 & [M]TYPMES=1)
 Actzo [AWAX]REQREC
Else
 [M]REQREC = 0
 Affzo [AWAX]REQREC
 Grizo [AWAX]REQREC
Endif
Affzo
Return

#----------------------------#
$APRES_MODIF
REP = "M"
Return

#----------------------------#
$ABA
[M:AWAX] = [M:AWAY]
Affzo
REP = ""
Return

#----------------------------#
$OK
[M:AWAY] = [M]
FIN = 1
Return

#----------------------------------------------------------------#
# Etiquettes écran AWAX
#----------------------------------------------------------------#

Subprog C_NBDEST
If adxgtb=2 & [M]NBDEST=0
 Call ERREUR(mess(3,75,1)) From GESECRAN : # Un destinataire principal , au moins, est nécessaire !
 mkstat = 2 : End
Endif
End

Subprog IB_DEST
# TYPMES  Paramètre workflow (Indifférent/Serveur/Client)
# GTYPMES Paramètre général (Client/Serveur)
If (GBROWS | GSERVEUR | [M]TYPMES=2 | dim(GTYPMES)<=0 | (GTYPMES=2 & [M]TYPMES=1))
 GBOUT1 = ""
Endif
End

Subprog C_DEST(VALEUR)
Variable Char    VALEUR()
Local Char    CHAINE(250) , EMAIL(GLONMAI)
Local Integer NOL , I , K
Local Char    SAVUSR(GLONAUS)
If clalev([F:AUS])=0
 Local File AUTILIS [AUS]
Else
 SAVUSR = [F:AUS]USR
Endif
CHAINE = VALEUR
NOL = nolign
I = 0
While CHAINE<>""
 I += 1
 K = instr(1,CHAINE,";")
 If K
  EMAIL = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  EMAIL = CHAINE
  CHAINE = ""
 Endif
 If left$(EMAIL,1)='"' : EMAIL = right$(EMAIL,2) : Endif
 If right$(EMAIL,len(EMAIL))='"' : EMAIL = left$(EMAIL,len(EMAIL)-1) : Endif
 Read [AUS]CODUSR = EMAIL
 If !fstat & [F:AUS]ADDEML<>""
  EMAIL = [F:AUS]ADDEML
 Endif
 If I=1
  VALEUR = EMAIL
  [M]DEST(NOL-1) = EMAIL
 Elsif [M]NBDEST<dim([M]DEST)
  Insa NOL+I-2,1 [M]NBDEST
  [M]NBDEST += 1
  [M]DEST(NOL+I-2) = EMAIL
 Endif
Wend
Affzo 5
If SAVUSR<>"" & SAVUSR<>[F:AUS]USR
 Read [AUS]CODUSR = SAVUSR
Endif
End

Subprog IB_COP
# TYPMES  Paramètre workflow (Indifférent/Serveur/Client)
# GTYPMES Paramètre général (Client/Serveur)
If (GBROWS | GSERVEUR | [M]TYPMES=2 | dim(GTYPMES)<=0 | (GTYPMES=2 & [M]TYPMES=1))
 GBOUT1 = ""
Endif
End

Subprog C_COP(VALEUR)
Variable Char    VALEUR()
Local Char    CHAINE(250) , EMAIL(GLONMAI)
Local Integer NOL , I , K
Local Char    SAVUSR(GLONAUS)
If clalev([F:AUS])=0
 Local File AUTILIS [AUS]
Else
 SAVUSR = [F:AUS]USR
Endif
CHAINE = VALEUR
NOL = nolign
I = 0
While CHAINE<>""
 I += 1
 K = instr(1,CHAINE,";")
 If K
  EMAIL = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  EMAIL = CHAINE
  CHAINE = ""
 Endif
 If left$(EMAIL,1)='"' : EMAIL = right$(EMAIL,2) : Endif
 If right$(EMAIL,len(EMAIL))='"' : EMAIL = left$(EMAIL,len(EMAIL)-1) : Endif
 Read [AUS]CODUSR = EMAIL
 If !fstat & [F:AUS]ADDEML<>""
  EMAIL = [F:AUS]ADDEML
 Endif
 If I=1
  VALEUR = EMAIL
  [M]COP(NOL-1) = EMAIL
 Elsif [M]NBCOP<dim([M]COP)
  Insa NOL+I-2,1 [M]NBCOP
  [M]NBCOP += 1
  [M]COP(NOL+I-2) = EMAIL
 Endif
Wend
Affzo 10
If SAVUSR<>"" & SAVUSR<>[F:AUS]USR
 Read [AUS]CODUSR = SAVUSR
Endif
End
