#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRSUS1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:46"
A_USER  = "DOC"
A_STAMP = "20181109230446"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRSUS1 [HRSUS1]
Gosub HORODAT
Local Inpbox "HRSUS1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRSUS1] As [SIM_]
Grizo [HRSUS1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRSUS1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=25
Return

$ON_TIMSUS
Onevent CONTROL Call C_TIMSUS(zc) From W1HRSUS1
Onevent BEFORE_INPUT Call AS_TIMSUS(zc) From W1HRSUS1
Onevent AFTER_CHANGE Gosub AMM_TIMSUS From W1HRSUS1
Return

Subprog AS_TIMSUS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47937,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_TIMSUS(zc) From W1HRSUS1
Onkey   2 Titled GBOUTS Call S_TIMSUS(zc) From W1HRSUS1
Onkey 144 Titled GBOUTP Call P_TIMSUS(zc) From W1HRSUS1
Onkey 146 Titled GBOUTA Call SA_TIMSUS(zc) From W1HRSUS1
Gosub _AFF
End

Subprog C_TIMSUS(VALEUR)
Variable Char    VALEUR()
## Action CONTHRTIM
Call CONTHRTIM(VALEUR) From SUBHRTIM
If mkstat : GERR = 1 : GZONE = "TIMSUS" : GZNUM = 47937 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TIMSUS" : GZNUM = 47937 : Endif
Endif
Gosub _AFF
End

$AMM_TIMSUS
Call AM_TIMSUS(zc)
If !mkstat & GOBJET
 zoncou = "TIMSUS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TIMSUS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZTIMSUS)")>indice
 [M]TIMSUS(indice) = VALEUR
 Affzo ZTIMSUS(indice)
Endif
Gosub _AFF
End

Subprog S_TIMSUS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRTIM
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRTIM"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRTIM","SUBHRTIM","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_TIMSUS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRTIM
 Call TUNHRTIM(VALEUR) From SUBHRTIM
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_TIMSUS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRTIM"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TIMSUS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("HRTIM",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZTIMSUS
Onevent BEFORE_AREA Gosub AV_ZTIMSUS From W1HRSUS1
Return

$AV_ZTIMSUS
Call LECTEXTRA(zc,"TIMCOD","DES",num$(GCURLEG),num$([M]TIMSUS(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


