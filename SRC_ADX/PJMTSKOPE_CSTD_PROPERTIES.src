#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################################
# Classe PJMTSKOPE
####################################################################################################
# PROPERTIES
####################################################################################################
$KEYCONCAT
  Case [L]ARULE
    When "GET"       : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  # Issue X3-68131 - 2018-02-12 by FGR : add context : BEGIN
  #this.KEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(this.OPPNUM, this.TASCOD, this.OPENUM, this.OPESPLNUM)
  this.KEYCONCAT = func PJMTSKOPE_CSTD_PROGS.GET_KEYCONCAT_VARIABLES(this.ACTX, this.OPPNUM, this.TASCOD, this.OPENUM, this.OPESPLNUM)
  # Issue X3-68131 - 2018-02-12 by FGR : add context : END
Return

###################################################################################################
$EXTWST
  Case [L]ARULE
    When "CONTROL"   : Gosub EXTWST_CONTROL
    When "PROPAGATE" : Gosub EXTWST_PROPAGATE
  Endcase
Return

$EXTWST_CONTROL
Local Char SFCY(GLONFCY)
Local Integer IFOUND

  If this.EXTWST <> AVOID.ACHAR Then
    Local File WORKSTATIO [MWS]
    # -------------------------------------
    IFOUND = [V]CST_ANO
    For SFCY = this.TASFCY, ""
      Read [MWS]WST0=this.EXTWST;SFCY
      If !fstat Then
        IFOUND = [V]CST_AYES
        Break
      Endif
    Next
    If IFOUND = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTWST", func AFNC.MES1(mess(247,2260,1), this.EXTWST), [V]CST_AERROR))
    Endif
    # -------------------------------------
  Endif
Return

$EXTWST_PROPAGATE
  [L]ASTATUS = fmet this.GET_OPEUOM(this.OPEUOM2)
  this.OPECST = 0
  this.OPECST2 = 0
Return

###################################################################################################
$EXTWSTNBR
  Case [L]ARULE
    When "INIT"      : Gosub EXTWSTNBR_INIT
  Endcase
Return

$EXTWSTNBR_INIT
  this.EXTWSTNBR = 1
Return

###################################################################################################
$OPEUOM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPEUOM_CONTROL
    When "PROPAGATE" : Gosub OPEUOM_PROPAGATE
  Endcase
Return

$OPEUOM_CONTROL
Local Integer IUOMTYP

  If this.OPEUOM <> AVOID.ACHAR Then
    IUOMTYP = fmet this.ACTX.ACACHE.ATUN.AGETVALNUM(this.OPEUOM, "UOMTYP")
    If IUOMTYP <> 5 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEUOM", mess(190,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

$OPEUOM_PROPAGATE
  If this.OPEUOM <> AVOID.ACHAR Then
    If this.ASTALIN = [V]CST_AUPD and this.OPEUOM <> this.snapshot.OPEUOM Then
      If this.TCHOPEUOM2AN = [V]CST_AYES Then
        # Compute quantities
        Call CONVERT_QTY(this.ACTX, this.snapshot.OPEUOM, this.OPEUOM, this.EXTQTY) From TRTX3_SYRA
      Endif
    Endif
  Endif
Return

###################################################################################################
$OPEUOM2
  Case [L]ARULE
    When "INIT"      : Gosub OPEUOM2_INIT
    When "CONTROL"   : Gosub OPEUOM2_CONTROL
    When "PROPAGATE" : Gosub OPEUOM2_PROPAGATE
  Endcase
Return

$OPEUOM2_INIT
Local Char STIMUOM(GLONUOM)
  If this.OPEUOM2 = AVOID.ACHAR
    STIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
    this.OPEUOM2 = STIMUOM
  Endif
Return

$OPEUOM2_CONTROL
Local Integer IUOMTYP
Local Char STIMUOM(GLONUOM)

  Local File TABCOEFF [TCO]
  # ---------------------------------------
  IUOMTYP = fmet this.ACTX.ACACHE.ATUN.AGETVALNUM(this.OPEUOM2, "UOMTYP")
  If IUOMTYP <> 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEUOM2", mess(190,2260,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  STIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
  # ---------------------------------------
  Read [TCO]TCO0=this.OPEUOM2;STIMUOM
  If fstat and IUOMTYP <> 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEUOM2", func AFNC.MES1(mess(298,2260,1), STIMUOM), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  # FGR agrees with using CSMQTY on the PROPERTIES level.
  # Context: this.CSMQTY is updated by Time Entries.
  If this.OPEUOM2 <>  this.snapshot.OPEUOM2 Then
    If this.CSMQTY > 0
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEUOM2", mess(414,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

$OPEUOM2_PROPAGATE
Local Decimal NSVRMNQTY

  If this.ASTALIN = [V]CST_AUPD Then
    If this.TCHOPEUOM2AN = [V]CST_AYES Then
      # Compute quantities
      If this.snapshot.OPEUOM2 <> this.OPEUOM2 Then
        NSVRMNQTY = this.RMNQTY
        Call CONVERT_QTY(this.ACTX, this.snapshot.OPEUOM2, this.OPEUOM2, this.EXTQTY) From TRTX3_SYRA
        Call CONVERT_QTY(this.ACTX, this.snapshot.OPEUOM2, this.OPEUOM2, NSVRMNQTY) From TRTX3_SYRA
        this.RMNQTY = NSVRMNQTY
      Else
        this.EXTQTY = this.snapshot.EXTQTY
        this.RMNQTY = this.snapshot.RMNQTY
      Endif
    Endif
  Endif
Return

###################################################################################################
$EXTQTY
  Case [L]ARULE
    When "CONTROL"   : Gosub EXTQTY_CONTROL
    When "PROPAGATE" : Gosub EXTQTY_PROPAGATE
  Endcase
Return

$EXTQTY_CONTROL
  If this.EXTQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
Return

$EXTQTY_PROPAGATE
Local Integer IRET

  # CSMQTY can change its value only on Time entries. So it's value is true here
  If this.OPESTA <> 5 Then
    If this.CSMQTY = 0 Then
      this.RMNQTY = this.EXTQTY
    Else
      If this.EXTQTY < this.CSMQTY Then
        this.RMNQTY = 0
      Else
        this.RMNQTY = this.EXTQTY - this.CSMQTY
      Endif
    Endif
  Endif
Return

###################################################################################################
$RMNQTY
  Case [L]ARULE
    When "CONTROL"   : Gosub RMNQTY_CONTROL
  Endcase
Return

$RMNQTY_CONTROL
  If this.RMNQTY < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("RMNQTY", mess(232,2260,1), [V]CST_AERROR))
  Endif
  If this.OPESTA = 5 Then
    If this.RMNQTY <> 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("RMNQTY", mess(474,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$OPESTA
  Case [L]ARULE
    When "CONTROL"   : Gosub OPESTA_CONTROL
    When "PROPAGATE" : Gosub OPESTA_PROPAGATE
  Endcase
Return

$OPESTA_CONTROL
  # ---------------------------------------
  If this.OPESTA <> 1 and this.OPESTA <> 4 and this.OPESTA <> 5 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(301,2260,1), [V]CST_AERROR))
  Endif
  # ---------------------------------------
  If this.ASTALIN = [V]CST_ANEW Then
    If this.TCHTASSTATE = 1 and this.OPESTA <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
    Elsif (this.TCHTASSTATE = 2 or this.TCHTASSTATE = 3) and this.OPESTA <> 4 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
    Elsif this.TCHTASSTATE = 9 and this.OPESTA <> 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    Case this.TCHACTION
      When "IN_PROGRESS"
        If this.OPESTA <> 4 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
        Endif
      When "CLOSING"
        If this.OPESTA <> 5 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
        Endif
      When "SUSPENSION"
        If this.OPESTA <> 1 Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
        Endif
      When "REACTIVATE"
        # TODO see to add control here
      When Default
        If this.OPESTA <> this.snapshot.OPESTA Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTA", mess(18,9804,1), [V]CST_AERROR))
        Endif
    Endcase
  Endif
  # ---------------------------------------
Return

$OPESTA_PROPAGATE
Local Integer NI

  For NI = 1 To maxtab(this.RAFFT)
    If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.RAFFT(NI).TCHOPESTA <> this.OPESTA Then
        this.RAFFT(NI).TCHOPESTA = this.OPESTA
      Endif
    Endif
  Next NI
  If this.TCHACTION = "CLOSING" and this.OPESTA = 5 Then
    For NI = 1 To maxtab(this.RAFFT)
      If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.RAFFT(NI).POARMNQTY <> 0 Then
          this.RAFFT(NI).POARMNQTY = 0
        Endif
      Endif
    Next NI
  Endif
Return

###################################################################################################
$OPEDATS
  Case [L]ARULE
    When "CONTROL"   : Gosub OPEDATS_CONTROL
  Endcase
Return

$OPEDATS_CONTROL
  If this.TCHACTION <> "CLOSING" and this.TCHACTION <> "REACTIVATE" Then
    If this.OPEDATS <> this.snapshot.OPEDATS Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEDATS", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$OPEDATH
  Case [L]ARULE
    When "CONTROL"   : Gosub OPEDATH_CONTROL
  Endcase
Return

$OPEDATH_CONTROL
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "REACTIVATE" Then
    If this.OPEDATH <> this.snapshot.OPEDATH Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEDATH", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$STDOPENUM
  Case [L]ARULE
    When "CONTROL"   : Gosub STDOPENUM_CONTROL
  Endcase
Return

$STDOPENUM_CONTROL
  If this.STDOPENUM <> AVOID.AINT Then
    Local File ROUOPESTD [ROT]
    Read [ROT]ROT0=this.STDOPENUM;this.TASFCY
    If fstat Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STDOPENUM", mess(296,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$OPESPLNUM
  Case [L]ARULE
    When "CONTROL"   : Gosub OPESPLNUM_CONTROL
  Endcase
Return

$OPESPLNUM_CONTROL
  If this.OPESPLNUM <> 1 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("STDOPENUM", mess(18,9804,1), [V]CST_AERROR))
  Endif
Return

###################################################################################################
$EXTLAB
  Case [L]ARULE
    When "CONTROL"   : Gosub EXTLAB_CONTROL
    When "PROPAGATE" : Gosub EXTLAB_PROPAGATE
  Endcase
Return

$EXTLAB_CONTROL
Local Char SFCY(GLONFCY)
Local Integer IFOUND

  If this.EXTLAB <> AVOID.ACHAR Then
    Local File WORKSTATIO [MWS]
    # ------------------------------------
    IFOUND = [V]CST_ANO
    For SFCY = this.TASFCY, ""
      Read [MWS]WST0=this.EXTLAB;SFCY
      If !fstat Then
        IFOUND = [V]CST_AYES
        If [F:MWS]WSTTYP <> 2 Then
         [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTLAB", func AFNC.MES1(mess(247,2260,1), this.EXTLAB), [V]CST_AERROR))
        Endif
        Break
      Endif
    Next
    If IFOUND = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("EXTLAB", func AFNC.MES1(mess(247,2260,1), this.EXTLAB), [V]CST_AERROR))
    Endif
    # ------------------------------------
  Endif
Return

$EXTLAB_PROPAGATE
  If this.EXTLAB <> AVOID.ACHAR Then
    this.EXTLABNBR = 1
  Else
    this.EXTLABNBR = 0
  Endif
  [L]ASTATUS = fmet this.GET_OPEUOM(this.OPEUOM2)
  this.OPECST = 0
  this.OPECST2 = 0
Return

###################################################################################################
$EXTLABNBR
  Case [L]ARULE
    When "INIT"      : Gosub EXTLABNBR_INIT
  Endcase
Return

$EXTLABNBR_INIT
  this.EXTLABNBR = 0
Return

###################################################################################################
# TODO FGR : at the moment I don't know how to manage this property as read only.
#            When I will now how the property is assigned, I will know how to do.
$OPECST
  Case [L]ARULE
    When "CONTROL"   : Gosub OPECST_CONTROL
    When "PROPAGATE" : Gosub OPECST_PROPAGATE
  Endcase
Return

$OPECST_CONTROL
  If this.OPECST < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPECST", mess(234,2260,1), [V]CST_AERROR))
  Endif
Return

$OPECST_PROPAGATE
Local Integer NI

  If this.OPECST <> this.snapshot.OPECST Then
    For NI = 1 To maxtab(this.RAFFT)
      If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        this.RAFFT(NI).TCHOPECST = this.OPECST
      Endif
    Next NI
  Endif
Return

###################################################################################################
# TODO FGR : at the moment I don't know how to manage this property as read only.
#            When I will now how the property is assigned, I will know how to do.
$OPECST2
  Case [L]ARULE
    When "CONTROL"   : Gosub OPECST2_CONTROL
    When "PROPAGATE" : Gosub OPECST2_PROPAGATE   # Issue X3-28427/122128 - 2017-03-21 by FGR
  Endcase
Return

$OPECST2_CONTROL
  If this.OPECST2 < 0 Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPECST2", mess(234,2260,1), [V]CST_AERROR))
  Endif
Return

$OPECST2_PROPAGATE
Local Integer NI

  If this.OPECST2 <> this.snapshot.OPECST2 Then
    For NI = 1 To maxtab(this.RAFFT)
      If this.RAFFT(NI) <> null and find(this.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        this.RAFFT(NI).TCHOPECST2 = this.OPECST2
      Endif
    Next NI
  Endif
Return

###################################################################################################
$OPESTARTDT
  Case [L]ARULE
    When "CONTROL"   : Gosub OPESTARTDT_CONTROL
  Endcase
Return

$OPESTARTDT_CONTROL
  If this.TCHACTION <> "TIMEENTRY" Then
    If this.OPESTARTDT <> this.snapshot.OPESTARTDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPESTARTDT", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$OPEENDDT
  Case [L]ARULE
    When "CONTROL"   : Gosub OPEENDDT_CONTROL
  Endcase
Return

$OPEENDDT_CONTROL
  If this.TCHACTION <> "TIMEENTRY" Then
    If this.OPEENDDT <> this.snapshot.OPEENDDT Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("OPEENDDT", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$CSMQTY
  Case [L]ARULE
    When "INIT"            : Gosub CSMQTY_INIT
    When "CONTROL"         : Gosub CSMQTY_CONTROL
  Endcase
Return

$CSMQTY_INIT
  this.CSMQTY = 0
Return

$CSMQTY_CONTROL
  If this.TCHACTION <> "TIMEENTRY" Then
    If this.CSMQTY <> this.snapshot.CSMQTY Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CSMQTY", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Else
    If this.CSMQTY < 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("CSMQTY", mess(232,2260,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$TCHOPEUOM2AN
  Case [L]ARULE
    When "INIT"      : Gosub TCHOPEUOM2AN_INIT
  Endcase
Return

$TCHOPEUOM2AN_INIT
  this.TCHOPEUOM2AN = [V]CST_AYES
Return

###################################################################################################
$TCHOPESTRAN
  Case [L]ARULE
    When "INIT"      : Gosub TCHOPESTRAN_INIT
  Endcase
Return

$TCHOPESTRAN_INIT
  this.TCHOPESTRAN = 1
Return

###################################################################################################
$TCHOPEENDAN
  Case [L]ARULE
    When "INIT"      : Gosub TCHOPEENDAN_INIT
  Endcase
Return

$TCHOPEENDAN_INIT
  this.TCHOPEENDAN = 1
Return

###################################################################################################
$RAFFT_POACLB
  Case [L]ARULE
    When "CONTROL"   : Gosub RAFFT_POACLB_CONTROL
  Endcase
Return

$RAFFT_POACLB_CONTROL
Local Integer NI

  For NI = 1 To maxtab(this.APARENT.RAFFT)
    If this.APARENT.RAFFT(NI) <> null and find(this.APARENT.RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.RAFFT(NI) <> this Then
        If this.APARENT.RAFFT(NI).POACLB = this.POACLB Then
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("POACLB", func AFNC.MES1(mess(173,2260,1), this.POACLB), [V]CST_AERROR))
          Break
        Endif
      Endif
    Endif
  Next NI
Return

