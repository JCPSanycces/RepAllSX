#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#Fichier complémentaire gestion des scripts appels
##########################################################################################################
##########################################################################################################
Subprog AFFICHE_QUESTION(NUMLIG)
Value Integer NUMLIG

Local Integer INBCND
Local Integer INBCNA
Local Char SZSVCNDNUM(GLONVCR)
Local Char SZTOASSIGN(100)

  Effzo [M:SCP8]10
  Effzo [M:SCP8]15
  Effzo [M:SCP8]45
  #
  [M:SCP8]QSTNUMX = [M:SCP8]QSTNUM(NUMLIG)
  [M:SCP8]QSTX    = [M:SCP8]QST(NUMLIG)
  [M:SCP8]STRQSTX = [M:SCP8]STRQST(NUMLIG)
  [M:SCP8]QSTTYPX = [M:SCP8]QSTTYP(NUMLIG)
  [M:SCP8]ASWTABX = [M:SCP8]ASWTAB(NUMLIG)
  [M:SCP8]ASWFIEX = [M:SCP8]ASWFIE(NUMLIG)
  [M:SCP8]ASWKEYX = [M:SCP8]ASWKEY(NUMLIG)
  Affzo [M:SCP8]10
  Affzo [M:SCP8]45
  #
  INBCND = 0
  INBCNA = 0
  SZSVCNDNUM = ""
  Filter [SQC] Where SCPNUM=[M:SCP0]SCPNUM and QSTNUM=[M:SCP8]QSTNUMX Order By CNDNUM
  For [SQC]
    If [M:SCP8]QSTTYPX = 1 Then
      # L'alpha est traité différemment
      If SZSVCNDNUM <> [F:SQC]CNDNUM Then
        If SZSVCNDNUM <> "" Then
          # pour ne pas le faire la première fois
          INBCNA = 0
          INBCND = INBCND + 1
        Endif
        SZSVCNDNUM = [F:SQC]CNDNUM
        #
        [M:SCP8]CND(INBCND) = [F:SQC]CND
        [M:SCP8]NEXQST(INBCND) = [F:SQC]NEXQST
      Endif
      #
      SZTOASSIGN = "[M:SCP8]ALHCND"+num$(INBCNA)+"("+num$(INBCND)+")"
      Assign SZTOASSIGN With [F:SQC]ALHCND
      INBCNA = INBCNA + 1
    Else
      [M:SCP8]CND(INBCND)       = [F:SQC]CND
      [M:SCP8]NEXQST(INBCND)    = [F:SQC]NEXQST
      [M:SCP8]NUMCNDMIN(INBCND) = [F:SQC]NUMCNDMIN
      [M:SCP8]NUMCNDMAX(INBCND) = [F:SQC]NUMCNDMAX
      [M:SCP8]DATCNDMIN(INBCND) = [F:SQC]DATCNDMIN
      [M:SCP8]DATCNDMAX(INBCND) = [F:SQC]DATCNDMAX
      INBCND = INBCND + 1
    Endif
  Next
  Filter [SQC]
  #
  If [M:SCP8]QSTTYPX = 1 Then
    # Pour l'alpha il faut le faire ici une dernière fois.
    # on n'a pas incrémenté puor la dernière condition
    INBCND = INBCND + 1
  Endif
  [M:SCP8]NBCND = INBCND
  Affzo [M:SCP8]15
  #
  Call AFFICHE_CONDITION (0)
End

##########################################################################################################
Subprog AFFICHE_CONDITION(NUMLIG)
Value Integer NUMLIG

Local Integer INBCNA
Local Char SZTOASSIGN(100)

  Effzo [M:SCP8]20
  Effzo [M:SCP8]25
  Effzo [M:SCP8]30
  Effzo [M:SCP8]35
  Effzo [M:SCP8]40
  If [M:SCP8]QSTTYPX = 1 Then
    # Alphabétique
    # ------------
    For INBCNA = 0 To 9
      SZTOASSIGN = "[M:SCP8]ALHCND"+num$(INBCNA)+"("+num$(NUMLIG)+")"
      If evalue(SZTOASSIGN) <> "" Then
        [M:SCP8]ALHCND(INBCNA) = evalue(SZTOASSIGN)
      Else
        Break
      Endif
    Next INBCNA
    [M:SCP8]NBCNA = INBCNA
    Affzo [M:SCP8]20
  ElsIf [M:SCP8]QSTTYPX = 2 Then
    # Numérique
    # ---------
    If [M:SCP8]CND(NUMLIG) = 6 or [M:SCP8]CND(NUMLIG) = 7 or [M:SCP8]CND(NUMLIG) = 8 or [M:SCP8]CND(NUMLIG) = 9 Then
      # 6:Supérieur à // 7:Sup. ou égal à // 8:Inférieur à // 9:Inf. ou égal à
      [M:SCP8]NUMCND5 = [M:SCP8]NUMCNDMIN(NUMLIG)
      Affzo [M:SCP8]25
    Elsif [M:SCP8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      [M:SCP8]NUMCNDMIN6 = [M:SCP8]NUMCNDMIN(NUMLIG)
      [M:SCP8]NUMCNDMAX6 = [M:SCP8]NUMCNDMAX(NUMLIG)
      Affzo [M:SCP8]30
    Endif
  ElsIf [M:SCP8]QSTTYPX = 3 Then
    # Date
    # ----
    If [M:SCP8]CND(NUMLIG) = 13 or [M:SCP8]CND(NUMLIG) = 14 Then
      # 13:Avant le // 14:Après le
      [M:SCP8]DATCND7 = [M:SCP8]DATCNDMIN(NUMLIG)
      Affzo [M:SCP8]35
    Elsif [M:SCP8]CND(NUMLIG) = 10 Then
      # 10:Compris entre
      [M:SCP8]DATCNDMIN8 = [M:SCP8]DATCNDMIN(NUMLIG)
      [M:SCP8]DATCNDMAX8 = [M:SCP8]DATCNDMAX(NUMLIG)
      Affzo [M:SCP8]40
    Endif
  ElsIf [M:SCP8]QSTTYPX = 4 Then
    # Boolean
    # -------
    # rien a faire de spécial
  Endif
End

##########################################################################################################
# Chargement des questions
$LOAD_SCQ
Local Integer ILIGNE

  ILIGNE = 0
  Effzo [M:SCP8]5
  [M:SCP8]NBSCQ = 0
  Filter [SCQ] Where SCPNUM=[M:SCP0]SCPNUM Order By [F:SCQ]QSTNUM
  For [SCQ]
    nolign = ILIGNE + 1
    [M:SCP8] = [F:SCQ]
    ILIGNE = ILIGNE + 1
  Next
  Filter [SCQ]
  [M:SCP8]NBSCQ = ILIGNE
  #
  nolign = 0
  Call AFFICHE_QUESTION(nolign)
Return
