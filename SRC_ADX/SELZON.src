#<AdxTL>@(#)86.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
 When "SEL_TABLE"  : Gosub SEL_TABLE
Endcase
Return

###################################
$SEL_LISTE
If [M:AMK1]NBFIC=0 : OK = 0 : Return : Endif
NBTEX = 0
For I=0 To [M:AMK1]NBFIC-1
 NBTEX += 1
 TEX(NBTEX) = [M:AMK1]FICREF(I)
 If NBTEX>=dim(TEX)-1 : Break : Endif
Next I
Return

$FIN_LISTE
mkstat = 99
Return

###################################
$SEL_TABLE
CRITERE = ""
For I=0 To [M:AMK1]NBFIC-1
 If CRITERE=""
  CRITERE = '('
 Else
  CRITERE += '|'
 Endif
 CRITERE += '[F:ATZ]CODFIC="'+[M:AMK1]FICREF(I)+'"'
Next I
If CRITERE=""
 OK = 0 : Return
Else
 CRITERE += ')'
Endif
OBJET = "ATZ"
ORDRE = "CODFIC;CODZONE"
START = "[F:ATZ]CODZONE"
EXPSTART = START+'>""'
Return

###################################
Subprog IB_FICHIER
If [M:AMK1]NBFIC=0 : GBOUT2 = "" : Endif
End

Subprog IB_NBLIG
GBOUT2 = mess(2,1,1) : # Oui
GBOUT3 = mess(1,1,1) : # Non
End

Subprog B2_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 10
End

Subprog B3_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 10
End

