#<AdxTL>@(#)212.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "GDPDU"
Call TRAITE_CHAR(VALEUR,PARAM,"","GEXPENCH","DEXPENCH",4,"XYGEXPENCH") From GTRAITE
End

#######################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "OUVRE_BATCH"  : Gosub OUVRE
 When Default
Endcase
Return

#######################################################
$INIT
Local Integer I , J , NBFIC, IMPSTA, DIME
Local Integer REGROUP
Local Char    MESSAGE(80), CHEMIN0(GDIMFIC)
Local Char    NOMFIC(GDIMFIC) , FICBAS(GDIMFIC)
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC)

Local Mask AEN1    [AEN1]
Local Mask EXPENCH [DIA] : # Saisie des paramètres
DIME = dim([M:AEN1]MODELE)
Local Char    FICDON(GDIMFIC)(1..DIME) , FICTMP(GDIMFIC)(1..DIME)

Local Char    TIT(50)
TIT  = mess(45,141,1)-mess(93,141,1)-PARAM(1) : # Enchaînement Exportation de données
Gosub OUVRE
Raz [M:EXP2]
Raz [M:DIA]
[M:DIA]CODE = PARAM(1)
Return

#########################################################################
$OUVRE
If clalev([F:AEN])=0  : Local File AENCHAINE  [AEN]  : Endif
If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET     [AOB]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON    [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File ATABIND    [ATI]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR    [AMP]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE     [ATX]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE      [ATY]  : Endif
If clalev([F:AFC])=0  : Local File AFONCTION  [AFC]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif

If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ     [EXP1] : Endif : # Pour charger le modèle
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2    [EXP2] : Endif : # Ecran de référence
If clalev([F:ARV])=0  : Local File AREPORTV   [ARV]  : Endif
Return

#########################################################################
$CONTROLE
If !GSERVEUR
 TMP = 1
Endif
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
Endif
Return

#########################################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

If [M:DIA]CHRONO=2
 Gosub INC_EXPORT From GEXPOBJ
 If [M:EXP2]STAT=6
  IMPSTA = [M:EXP2]STAT : Goto FIN_EXEC
 Endif
Else
 [M:EXP2]FINCHRONO = [C]EXPORT
Endif

Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
If REPERT=""
 For [AEN]CODE Where CODE=[M:DIA]CODE & NUMLIG>0 & CHEMIN=""
  [M:EXP2]STAT=20
  # Modele import/export
  GBIDC3 = mess(97,141,1)-[F:AEN]MODELE
  IMPSTA = 20 : Break
 Next AEN
 If IMPSTA : Goto FIN_EXEC : Endif
Endif

Raz NBFIC, REGROUP
Read [AEN]CODE = [M:DIA]CODE ; 0
If !fstat & [F:AEN]CHEMIN<>""
 REGROUP = 1
 CHEMIN0 = [F:AEN]CHEMIN
 # No chrono
 I = instr(1,CHEMIN0,"#")
 If I
  If [M:EXP2]FINCHRONO>99999
   CHEMIN0 = left$(CHEMIN0,I-1)+format$("N0:"+num$(len(num$(func GEXPOBJ.MAXCPTEXP)))+"#",[M:EXP2]FINCHRONO)+right$(CHEMIN0,I+1)
  Else
   CHEMIN0 = left$(CHEMIN0,I-1)+format$("N0:5#",[M:EXP2]FINCHRONO)+right$(CHEMIN0,I+1)
  Endif
 Endif
 Openo CHEMIN0,0 Using [AEXP]
 Openo Using [AEXP]
Endif

For [AEN]CODE Where CODE=[M:DIA]CODE & NUMLIG>0
 Raz [M:AOE0], [M:AOE1], [M:AOE2]
 NBFIC += 1
 Call CHARGE_MODELE([F:AEN]MODELE,IMPSTA) From GEXPOBJ
 If IMPSTA : Break : Endif
 [M:EXP2] = [M:EXP1]
 If [F:AOE]OBJ<>""
  Read [AOB]ABREV = [F:AOE]OBJ
  If fstat : Break : Endif
 Endif
 NOMFIC = [F:AEN]CHEMIN
 If NOMFIC=""
  If [M:EXP2]NOMEXP<>""
   If GOS="unix" & !pat(left$([M:EXP2]NOMEXP,3),"!:\") & left$([M:EXP2]NOMEXP,1)<>"\"
    NOMFIC = [M:EXP2]NOMEXP
   Elsif GOS<>"unix" & left$([M:EXP2]NOMEXP,1)<>"/"
    NOMFIC = [M:EXP2]NOMEXP
   Endif
  Endif
 Endif
 If !instr(1,NOMFIC,"@") & !find(left$(NOMFIC,1),"/") & !pat(left$(NOMFIC,3),"!:\")
  Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
  If REPERT<>""
   Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
   Call SETFIC(REPERT,NOMFIC,MACHINE,NOMFIC) From SUBEXPOBJ
  Endif
 Endif
 [M:EXP2]MODELE = [F:AEN]MODELE
 # Issue X3-43015 - 2017-06-20 by CCC : final file name must be determined to check its existence
 #[M:EXP2]NOMEXP = NOMFIC
 NOMFIC = func GEXPOBJ.GET_EXPFILE_NAME(NOMFIC)
 [M:EXP2]TYPEXP = 2
 Gosub SET_NOMEXP

 # Issue X3-43015 - 2017-06-20 by CCC : avoid export if an error has already been detected
 If !IMPSTA
     [M:EXP2]CHRONO = [M:DIA]CHRONO

     Call WORKFLOW(8,[M:EXP2]MODELE,"ED","") From AWRK
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTEXPOBJ","",4,"XYTRTEXPOBJ") From GTRAITE
     Call WORKFLOW(8,[M:EXP2]MODELE,"EF","") From AWRK

     FICDON(NBFIC) = [M:EXP2]FICDON
     FICTMP(NBFIC) = [M:EXP2]FICTMP
     IMPSTA        = [M:EXP2]STAT
 Endif
 If IMPSTA : Break : Endif
 If REGROUP=1
  Call SYSTEME(adxmac(0),'ae_cat "'+FICTMP(NBFIC)+'" >> "'+CHEMIN0+'"',"",IMPSTA) From ORDSYS
  If IMPSTA : Break : Endif
 Endif
Next AEN
If IMPSTA
 Goto FIN_EXEC
Elsif [M:DIA]CHRONO=2
 Gosub TR1
 If GOK<1 : IMPSTA = 11 : Goto FIN_EXEC : Endif
Endif
If IMPSTA=0
 If REGROUP=1
  Call ECR_TRACE(mess(68,141,1)-tolower(mess(75,124,1))-"|"+CHEMIN0,0) From GESECRAN
  # Génération du fichier regroupement
 Endif
 For I=1 To NBFIC
  Call ECR_TRACE(mess(68,141,1)-"|"+FICDON(I),0) From GESECRAN
  If FICDON(I)<>FICTMP(I)
   Read [AEN]CODE = [M:DIA]CODE;I
   Call MOVE(FICTMP(I),FICDON(I),IMPSTA) From ORDSYS
   If IMPSTA | filinfo(FICDON(I),0)<0
    IMPSTA = 5 : GBIDC3 = FICDON(I) : Break
   Endif
  Endif
 Next I
 If IMPSTA : Goto FIN_EXEC : Endif
 GPOINT = "NOMFICHIER" : Gosub ENTREE From EXEFNC : # mb 12.4.2 demande 13660
Endif

$FIN_EXEC
If IMPSTA
 Gosub ERR_EXEC
Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$ERR_EXEC
Call ERR_EXPORT(IMPSTA,MESSAGE) From GEXPOBJ
Call ECR_TRACE(mess(93,141,1)-[M:DIA]CODE-"-"-[F:AEN]MODELE,0) From GESECRAN : # Exportation de données
Call ECR_TRACE(MESSAGE,1) From GESECRAN
Return

$SET_NOMEXP
Local Integer ASTATUS
Local Char MESSAGE(250)

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
ASTATUS = func ASYRSTO.CTL_VOLFIL([M:EXP2]TYPEXP, NOMFIC,[M:EXP2]NOMEXP,E_TYPE_FILEWRITE,MESSAGE)

# Issue X3-43015 - 2017-06-20 by CCC : maybe the file exists but it has been confirmed to delete it => try to delete
 If [M:EXP2]NOMEXP<>""
    IMPSTA = Delfile([M:EXP2]NOMEXP)
    If IMPSTA=-27
        IMPSTA = 4
    Else
        Raz IMPSTA
    Endif
 Else
    If MESSAGE<>""
        GMESSAGE = MESSAGE-NOMFIC
        IMPSTA = 100
    Else
        GBIDC3 = NOMFIC
        IMPSTA = 20
    Endif
 Endif

Return

###############################################################
$TR1
GOK = 1
Call ECR_TRACE("",0) From GESECRAN
Trbegin [AOE]
 For [AEN]CODE Where CODE=[M:DIA]CODE & MODELE<>"" With Lock
  If fstat = 1
   GLOCK = "$AENCHAINE"-num$([M:DIA]CODE) : GOK =-1 : Break
  Endif
  Readlock [AOE]AOE0 = [F:AEN]MODELE
  If fstat=1
   GOK=-1 : GLOCK="$AOBJEXT"-[F:AEN]MODELE : Break
  Elsif fstat
   GOK=0 : Call RSTA("AOE",[F:AEN]MODELE) From GLOCK : Break
  Endif
  # Mise à jour chrono
  Call ECR_TRACE(mess(106,141,1)-[F:AOE]EXT-num$([F:AOE]CHRNUM)+"->"-num$([M:EXP2]FINCHRONO),0) From GESECRAN
  [F:AOE]CHRNUM = [M:EXP2]FINCHRONO
  Rewrite [AOE]
  If fstat
   GOK=0 : Call RSTA("AOE",[F:AOE]EXT) From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Call ECR_TRACE("",0) From GESECRAN
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

#######################################################
$TERMINE
If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

########################################
## Etiquettes ecran EXPENCH           ##
########################################
Subprog IB_CODE
If GADONIX<>2
 GBOUT2 = ""
Endif
End

Subprog C_CODE(VALEUR)
Value   Char VALEUR()
Look [AEN]CODE(1) = VALEUR
If fstat
 GMESSAGE = mess(23,100,1) :  # Fiche inexistante
 mkstat = 2 : End
Endif
For [AEN] Where CODE=VALEUR & NUMLIG>0
 Read [AOE]AOE0 = [F:AEN]MODELE
 If !fstat & [F:AOE]EXPORT<>2
  GMESSAGE = [F:AEN]MODELE-":"-mess(110,141,1) : # Export impossible sur ce modèle
  mkstat = 1 : Break
 Endif
 Call CONTEXE([F:AOE]ACS) From SUBACS
 If mkstat : GMESSAGE = mess(97,141,1)-[F:AOE]EXT-":"-GMESSAGE : Break : Endif : # Modèle import-export
Next AEN
End

