#<AdxTL>@(#)4.0.0.0 $Revision$
#* ################################################################################################
#*                P H Y B U I    -     B u i l d i n g s
#* ################################################################################################

$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE
      Endcase
    When "BPA"
       Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub BPA_AINSERT_CONTROL_BEFORE
      Endcase
  Endcase
Return

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When Default  : Gosub METHODS From PHYBUI_C_MPR
      Endcase
    When Default
  Endcase
Return

$OPERATIONS
  Case [L]CURPTH
    When ""
      Case [L]AOPERATION
        When "GET_PROPERTIES_VALUE"    : Gosub GET_PROPERTIES_VALUE
        #-------------
        When Default  : Gosub OPERATIONS From PHYBUI_C_MPR
      Endcase
    When Default
  Endcase
Return

$PROPERTIES
  Case CURPRO
    When "GEOLOC"           : Gosub GEOLOC
    When "BPA.BPAADDFLG"    : Gosub BPA_BPAADDFLG
  Endcase
Return
# -------------------------------------
# PHYBUI standard data class methods
# -------------------------------------
#######################################################################################

##########################################################################################################
## Assign the values by default to the properties of the BUI class before the controls of the properties
##########################################################################################################
$AINSERT_CONTROL_BEFORE
Local Char  MSG(100)
Local Char  ERRMSG(100)

  Local File PHYBUI [BUI]
  Read [F:BUI]BUI0=this.BUICOD
  If fstat = [V]CST_AOK
    # BUI001 Object already exists
    [L]ASTATUS = fmet this.ASETERROR("BUICOD", mess(54,[V]CST_MSGMIS, 1), [V]CST_AERROR)
  Endif

  Gosub _INSERT_UPDATE_CONTROL_BEFORE

Return
#------------------------
$AUPDATE_CONTROL_BEFORE
Local Char  MSG(100)
Local Char  ERRMSG(100)

Gosub _INSERT_UPDATE_CONTROL_BEFORE

Return

#-----------------------------------------------------------------
$_INSERT_UPDATE_CONTROL_BEFORE

## At this level you can write control for insert or update.

#- GEOLOC -----

  # If the GEOLOC field is empty, we initialize it with the default address of the building
  If this.GEOLOC = AVOID.ACHAR
    Local Integer LIN
    For [L]LIN =1 To maxtab(this.BPA)
      If (this.BPA([L]LIN).BPATYP=7) and (this.BPA([L]LIN).BPAADDFLG=2) and (!find(this.BPA([L]LIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL))
        this.GEOLOC = sum(this.BPA([L]LIN).BPAADDLIG1," ", this.BPA([L]LIN).CTY," ",this.BPA([L]LIN).CRYNAM)
        Break
      Endif
     Next [L]LIN
  Endif

Return
#------------------------
$ADELETE_CONTROL_BEFORE

Local Char  ERRMSG(100)
Local Char  MSG(100)
Local Integer RET
Local Char    RLCT

  # 1 Evalue IS_BUI_USED
  If func PHYBUI_C_MPR.IS_BUI_USED (this.BUICOD , RLCT, AVOID.ACHAR)
    # BUI002 The Deletion is forbidden : The building is used by at least one object
    [L]ASTATUS = fmet this.ASETERROR("BUI", mess(145,[V]CST_MSGPHY, 1), [V]CST_AERROR)
  Endif

Return
##########################################################################################################
## Assign the values by default to the properties of the BUI class after the controls of the properties
##########################################################################################################
#------------------------
$AINSERT_CONTROL_AFTER
Local Char  ERRMSG(100)
Local Char  MSG(100)
  Gosub CONTROL_AFTER
Return
#------------------------
$AUPDATE_CONTROL_AFTER
  Gosub CONTROL_AFTER
Return
#------------------------
$CONTROL_AFTER
Return

###############################################################################################
#------------------------
$GEOLOC
  Case ARULE
    When "GET"
      # No double quote or comma in the geolocation
      Local Integer I
      For I=1 To len(this.GEOLOC)
        If find(seg$(this.GEOLOC,I,I),'"',',') : this.GEOLOC = func GLOFUNC.SETRNGSTR(this.GEOLOC,I," ") : Endif
      Next
 Endcase
Return
#------------------------
$BPA_BPAADDFLG
Case ARULE
  When "PROPAGATE"        : Gosub BPA_BPAADDFLG_PROPAGATE
Endcase
Return
#------------------------
$BPA_BPAADDFLG_PROPAGATE
Local Integer I, I_LINE

# if the "By default" flag is activated for one line, it is automatically set to 'No" for the other lines
If this.BPAADDFLG= [V]CST_AYES
  For I=1 To maxtab(this.APARENT.BPA)
    If this.APARENT.BPA(I)<> null
     If this.APARENT.BPA(I).BPAADDFLG = [V]CST_AYES
        this.APARENT.BPA(I).BPAADDFLG = [V]CST_ANO
      Endif
    Endif
  Next
  this.BPAADDFLG      = [V]CST_AYES
  this.APARENT.BPAADD = this.BPAADD
Endif

Return
#--------------------------
$BPA_AINSERT_CONTROL_BEFORE
  this.BPATYP=7
  this.BPANUM=this.APARENT.BUICOD
Return

#**
#* ========================================
#* Private Operation : GET_PROPERTIES_VALUE  -  PHYBUI value properties
#* ----------------------------------------
#* Get the value of some properties of a physical asset
#*    1- Read the physical asset reference
#*    2- Get the value of PROPERTIES (char array) into VALUES (char array)
#* #*--------------------------------------
#* @param AASREF      : Fixed asset reference
#* @param PROPERTIES  : Name of each property
#* @return VALUES     : Value of each property
#* @return ARET_VALUE : [V]CST_AOK if OK, else [V]CST_AERROR (check error message stack)
#* @return            : Error message stack
#*!

$GET_PROPERTIES_VALUE

Local Integer STACK_ERROR

  [L]ARET_VALUE  = [V]CST_AOK

  # Parameters control
  Local Shortint NB_PRO : [L]NB_PRO = dim([L]PROPERTIES)
  If not ( [L]NB_PRO > 0 )
    [L]ERRMSG = func ASYRFNC.MES2(mess(60, [V]CST_MSGMIS, 1), "PROPERTIES", "GET_PROPERTIES_VALUE")
    [L]STACK_ERROR = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
    Raz [L]VALUES
    Return
  Endif

  # Read building reference
  If fmet this.AREAD(BUICOD) <> [V]CST_AOK
    # Reading error on table PHYELT => PHYREF=xxxxxx
    [L]STACK_ERROR = fmet this.ASETERROR("", mess(76,127,1) + "PHYBUI => BUICOD =" - BUICOD, [V]CST_AERROR)
    [L]ARET_VALUE= [V]CST_AERROR
    Return
  Endif
  # Get the value of each property into VALUES
  Local Shortint PRO
  For [L]PRO = 1 To [L]NB_PRO
    If PROPERTIES([L]PRO) <> AVOID.ACHAR  # FQ113984
      Case evalue("type(this."+PROPERTIES([L]PRO)+")")
        When 1, 2, 4, 5, 6, 7, 9
          VALUES([L]PRO) = evalue("num$(this."+PROPERTIES([L]PRO)+")")
        When 3
          VALUES([L]PRO) = format$("D:DDMMYYYY", evalue("this."+PROPERTIES([L]PRO)))
        When Default
          VALUES([L]PRO) = evalue("this."+PROPERTIES([L]PRO))
      Endcase
    Endif
  Next

Return

