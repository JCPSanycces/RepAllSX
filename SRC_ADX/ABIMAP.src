#<AdxTL>@(#)12.0.0.0 $Revision$
Call EXECUTE()
End

######################################################################################
Subprog EXECUTE()
Local Char PARAM(10)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIMAP","ABIMAP",3,"") From GTRAITE
End
######################################################################################

# Gestion du masque ABIMAP

$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "EXEC"       : Gosub EXEC
 When "SORTIE"     : Gosub SORTIE From SUBATV2
 When "CONTROLE"   : Gosub CONTROLE
Endcase
Return

$INIT
Call OUINON(mess(143,148,1),GBIDI1) From GESECRAN : # Début du mapping, voulez-vous continuer ?
If GBIDI1=1 : FIN=1 : Return : Endif
Gosub INIT From SUBATV2
If FIN = 1 : Return : Endif
Local Mask ATV2 [ATV2]
Return

$INIT_DIA
Raz [M:ATV2]
Raz [M:AMP]
Diszo [M:AMP]REPBO
Local Clbfile ORDRE(2)
Local Integer STATS,OUT
Local Char    RESULT(GDIMFIC)(1..30)
Local Char    DOCPRO(GDIMFIC)
Local Char    UNIPRO(GDIMFIC)
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,STAT,OK
Local Char    RETOUR(250)
Local Integer K,L,M,BALISE,ERR
Local Char    WEBILIST(6),WEBIUNV(6),SOLCREA(6),UNIVLIST(6)
Local Char    REPBIS(80),REPBIS21(80),REPBIS22(80)
Local Char    ORDSYS(250)(1..2)

[M:ATV2]LANGDES   = GLANGUE
[M:ATV2]LANGORI   = GLANGUE
[M:ATV2]SREP      = '\TOOLS\BO\'

### init user et mdp BO
Call RECHPROP("busobj.login.adminusr",[M:ATV2]USRBI,GBIDI1) From INTRUTILA
Call INCRYPT([M:ATV2]USRBI,RETOUR) From INTRUTILA
[M:ATV2]USRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[M:ATV2]PWDBI,GBIDI1) From INTRUTILA

OK=1
Call TEMPON("F") From GESECRAN
Gosub INIT_SOLUTION From SUBATV2
If !OK : Gosub ERREUR2 From SUBATV2 : Endif
WEBILIST = "TRUE"
WEBIUNV  = "TRUE"
SOLCREA  = "FALSE"
UNIVLIST = "TRUE"
REPBIS   = GREPBI      : # Critere repertoire de recherche niveau 1
REPBIS21 = GREPSOLIND  : # Critere repertoire de recherche niveau 2
REPBIS22 = GINSTID     : # Critere repertoire de recherche niveau 2
Gosub CRE_PARAM From SUBATV2
Gosub CRE_DOCLISTFILT From SUBATV2
If !OK
 Gosub ERREUR2 From SUBATV2
Endif
If GADONIX =2
 CHEMIN = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE
  Call OUINON("Voulez-vous regenerer le fichier tool.xml ? ",GBIDI1) From GESECRAN
  If GBIDI1=2
   Gosub GENE_TOOL From SUBATV2
  Endif
 Else
  Gosub GENE_TOOL From SUBATV2
 Endif
Else
 Gosub GENE_TOOL From SUBATV2
Endif
If !OK
 Gosub ERREUR2 From SUBATV2
Elsif filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 Call ERREUR("|"+[M:ATV2]FICTOOL+"|"-":"-mess(101,100,1)) From GESECRAN
 Gosub ERREUR2 From SUBATV2
Endif
Call TEMPOFF From GESECRAN
Return

$CONTROLE
If [M:AMP]REPBO = "" | [M:AMP]REPBODES = "" : FIN=1 : Return : Endif
If [M:AMP]NBETA = 0 : FIN =1 : Return : Endif
Return

$EXEC
Call TEMPON("") From GESECRAN
OK =1
Call OUVRE_TRACE(mess(6,14,1)-":"-mess(42,127,1)) From LECFIC : # Traduction Etats Business Objects
Call ECR_TRACE(mess(034,9021,1)-":",0) From GESECRAN : # Liste des états
Gosub MAPPING
If !OK
 Gosub COP_FICHIER From SUBATV2
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
 Return
Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return

$SEL_LISTE
Gosub LIT_TOOL
If filinfo(FICHIER,7)<0
 End
Endif
Case LISTE
 When "ABISELUNV"  : Gosub SELUNV
 When "ABISELFOLD" : Gosub SELFOLD
Endcase
Return

$LIT_TOOL
FICHIER = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL
If filinfo(FICHIER,7)<0
 Return
Endif

Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM,OK
Local Clbfile CLOB(9)
Local Integer DEB,FIN,I,J,K,L
Local Integer NBREP

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Openi FICHIER,0 Using [R1 ]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB # 117220 sometimes more chr12-10
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  If !fstat : Rdseq CLOB  Using [R1] : Endif
  DEB = instr(0,CLOB,"<Folders_And_Universes")
  If !DEB
   If !fstat : Rdseq CLOB  Using [R1] : Endif
   DEB = instr(0,CLOB,"<Folders_And_Universes")
   If !DEB
    Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
    OK =0
    Return
   Endif
  Endif
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$SELFOLD
DEB = instr(DEB,CLOB,'Folders_And_Webis Id')
FIN = instr(DEB,CLOB,'/Folders_And_Webis')

If FIN<1 : Return : Endif
CLOB = seg$(CLOB,DEB+10,FIN-1)

DEB = instr(0,CLOB,'Folder CUID="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')

 DEB = instr(FIN,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 [M:AMP]REPID(NBREP) = seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(FIN,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 [M:AMP]REPNAM(NBREP) = seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(FIN,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 [M:AMP]REPFAT(NBREP) = seg$(CLOB,DEB+10,FIN-1)

 NBREP +=1
 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend

Local Char TEXTE(80)(1..200,1..4) , TIT(80)(0..4)
TIT(1) = mess(46,104,1)-": 1" :# Niveau 1
TIT(2) = mess(46,104,1)-": 2" :# Niveau 2
TIT(3) = mess(46,104,1)-": 3" :# Niveau 3
TIT(4) = mess(46,104,1)-": 4" :# Niveau 4
If zoncou = "REPBO"
 TIT    = mess(46,127,1)       :# Répertoire source
Else
 TIT    = mess(47,127,1)       :# Répertoire destination
Endif
NBTEX = 0

For I=0 To NBREP-1
 If [M:AMP]REPFAT(I) = "23" & !pat([M:AMP]REPNAM(I),"Report Conversion*")
  NBTEX += 1 :
  TEX(NBTEX) = [M:AMP]REPID(I)+"&&&"+[M:AMP]REPNAM(I)
  TEXTE(NBTEX,1) = [M:AMP]REPNAM(I)
  For J=1 To NBREP
   If [M:AMP]REPFAT(J) =[M:AMP]REPID(I)
    NBTEX += 1
    TEX(NBTEX) = [M:AMP]REPID(J)+"&&&"+[M:AMP]REPNAM(I)+"/"+[M:AMP]REPNAM(J)
    TEXTE(NBTEX,1) = [M:AMP]REPNAM(I)  :  TEXTE(NBTEX,2) = [M:AMP]REPNAM(J)
    For K=1 To NBREP
     If [M:AMP]REPFAT(K) =[M:AMP]REPID(J)
      NBTEX += 1
      TEX(NBTEX) = [M:AMP]REPID(K)+"&&&"+[M:AMP]REPNAM(I)+"/"+[M:AMP]REPNAM(J)+"/"+[M:AMP]REPNAM(K)
      TEXTE(NBTEX,1) = [M:AMP]REPNAM(I)  :  TEXTE(NBTEX,2) = [M:AMP]REPNAM(J)
      TEXTE(NBTEX,3) = [M:AMP]REPNAM(K)
      For L=1 To NBREP
       If [M:AMP]REPFAT(L) =[M:AMP]REPID(K)
        NBTEX += 1
        TEX(NBTEX) = [M:AMP]REPID(L)+"&&&"+[M:AMP]REPNAM(I)+"/"+[M:AMP]REPNAM(J)+"/"+[M:AMP]REPNAM(K)+"/"+[M:AMP]REPNAM(L)
        TEXTE(NBTEX,1) = [M:AMP]REPNAM(I)  :  TEXTE(NBTEX,2) = [M:AMP]REPNAM(J)
        TEXTE(NBTEX,3) = [M:AMP]REPNAM(K) : TEXTE(NBTEX,4) = [M:AMP]REPNAM(L)
       Endif
      Next L
     Endif
    Next K
   Endif
  Next J
 Endif
Next I
Return

$SELUNV
Gosub TAB_FOLDER_UNV
Gosub TAB_UNV

Local Char TEXTE(80)(1..200,1..3) , TIT(80)(0..3)
Local Integer I,J,K,L,M
Local Char NIV1(150),NIV2(150),NIV3(150),NIV4(150)
TIT(2) = mess(84,148,1)  : # Univers
TIT(1) = mess(37,139,1)  : # Répertoire
TIT(3) = mess(188,151,1) : # Identifiant interne
TIT    = mess(84,148,1)  : # Univers
NBTEX = 0
For I=0 To U_NBUNV-1
  Gosub FIND_FOLD
   NBTEX += 1
   TEX(NBTEX) = U_UNV(I)+"&&&"+U_UNV_ID(I)
   TEXTE(NBTEX,2) = U_UNV(I)
   TEXTE(NBTEX,1) = NIV1
   If NIV2<>"" : TEXTE(NBTEX,1) = NIV2-"/"-TEXTE(NBTEX,1) : Endif
   If NIV3<>"" : TEXTE(NBTEX,1) = NIV3-"/"-TEXTE(NBTEX,1) : Endif
   If NIV4<>"" : TEXTE(NBTEX,1) = NIV4-"/"-TEXTE(NBTEX,1) : Endif
   TEXTE(NBTEX,3) =U_UNV_ID(I)
Next I
Return

$FIND_FOLD
Raz NIV1,NIV2,NIV3,NIV4
J=find(U_UNV_FAT(I),U_FOLD_ID(0..U_NBFOLD))
If J> 0 & left$(U_FOLD(J-1),4) <> "Root"
 NIV1= U_FOLD(J-1)
 K=find(U_FOLD_FAT(J-1),U_FOLD_ID(0..U_NBFOLD))
 If K>0 & left$(U_FOLD(K-1),4) <> "Root"
  NIV2= U_FOLD(K-1)
  L=find(U_FOLD_FAT(K-1),U_FOLD_ID(0..U_NBFOLD))
  If L>0 & left$(U_FOLD(L-1),4) <> "Root"
   NIV3= U_FOLD(L-1)
   M=find(U_FOLD_FAT(L-1),U_FOLD_ID(0..U_NBFOLD))
   If M>0 & left$(U_FOLD(M-1),4) <> "Root"
    NIV4= U_FOLD(M-1)
   Endif
  Endif
 Endif
Endif
Return

$TAB_FOLDER_UNV
Local Char    U_FOLD(100)(0..100)
Local Char    U_FOLD_ID(100)(0..100)
Local Char    U_FOLD_CUID(100)(0..100)
Local Char    U_FOLD_FAT(100)(0..100)
Local Integer U_NBFOLD

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Openi FICHIER,0 Using [R1 ]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  Return
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(1,CLOB,'Folder CUID="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 U_FOLD_CUID(U_NBFOLD) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(DEB,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 U_FOLD_ID(U_NBFOLD)= seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(DEB,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 U_FOLD(U_NBFOLD)= seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(DEB,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_FOLD_FAT(U_NBFOLD)= seg$(CLOB,DEB+10,FIN-1)
 U_NBFOLD +=1
 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend
Return

$TAB_UNV
Local Char    U_UNV(100)(0..500)
Local Char    U_UNV_ID(100)(0..500)
Local Char    U_UNV_CUID(100)(0..500)
Local Char    U_UNV_FAT(100)(0..500)
Local Integer U_NBUNV

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Openi FICHIER,0 Using [R1 ]
Iomode adxifs  ""  Using [R1]
Iomode adxirs  chr$(13)+chr$(10)  Using [R1]
Iomode adxium  GUTF8  Using [R1]
Rdseq CLOB  Using [R1]
DEB = instr(0,CLOB,"<Folders_And_Universes")
If !DEB
 If !fstat : Rdseq CLOB  Using [R1] : Endif
 DEB = instr(0,CLOB,"<Folders_And_Universes")
 If !DEB
  Call ECR_TRACE(mess(36,115,1),1) From GESECRAN : # Structure fichier incorrecte
  OK =0
  Return
 Endif
Endif
Openi Using [R1]
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)
U_NBUNV = 0

DEB = instr(1,CLOB,'Universe Id="')
While DEB>0 & U_NBUNV<dim(U_UNV)-1
 FIN = instr(DEB+13,CLOB,'"')
 U_UNV_ID(U_NBUNV ) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(DEB,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_UNV_FAT(U_NBUNV )= seg$(CLOB,DEB+10,FIN-1)

 DEB = instr(DEB,CLOB,'Universe="')
 FIN = instr(DEB+10,CLOB,'"')
 U_UNV(U_NBUNV )= seg$(CLOB,DEB+10,FIN-1)
 U_NBUNV +=1
 DEB = instr(FIN,CLOB,'Universe Id="')
Wend
Return

$VERF_LISTE
Case LISTE
 When "ABISELFOLD"
  If VALEUR <> ""
   Case zoncou
    When "REPBO"
     [M]IDREP = left$(VALEUR,instr(1,VALEUR,"&&&")-1)
    When "REPBODES"
     [M]IDREPDES = left$(VALEUR,instr(1,VALEUR,"&&&")-1)
    Endcase
   VALEUR   = right$(VALEUR,instr(1,VALEUR,"&&&")+3)
  Endif
 When "ABISELUNV"
  If VALEUR <> ""
   [M]UNIVDESID = right$(VALEUR,instr(1,VALEUR,"&&&")+3)
   VALEUR       = left$(VALEUR,instr(1,VALEUR,"&&&")-1)
  Endif
Endcase
Return

$CHARGE
Local Char    DOSREF(80),DOSREFID_P(20),DOSREFID(20)
Local Integer KK

KK = find([M:AMP]IDREP,[M:AMP]REPID(0..99))
If KK
 [L]DOSREF     = [L]DOSSIER(KK-1)
 [L]DOSREFID   = [L]DOS_ID(KK-1)
 [L]DOSREFID_P = [L]DOS_P_ID(KK-1)
Endif

J=0
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = [M:AMP]IDREP & [L]ETAT_UNVID(I) <> "" & J< dim([M:AMP]ETAT)
   [M:AMP]ETAT(J)     = [L]ETAT(I)
   [M:AMP]ETATID(J)   = [L]ETAT_ID(I)
   [M:AMP]ETAIDFAT(J) = [L]ETAT_F_CUID(I)
   [M:AMP]UNIVERS(J)  = [L]ETAT_UNV(I)
   [M:AMP]ETAUNVID(J) = [L]ETAT_UNVID(I)
   [M:AMP]TRADUC(J)   = 1
   J+=1
 Endif
Next I
[M:AMP]NBETA = J
Sorta [M:AMP]NBETA [M:AMP]NBETA Order By [M:AMP]UNIVERS,[M:AMP]ETAT ([S]indice)
Affzo [M:AMP]
Return

$MAPPING
Local Char CHAINE(100)(0..100)
Local Integer NB
DOCPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocList_'+num$(adxuid(1))+'.properties'
UNIPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'UnivList_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier liste univers
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+UNIPRO ,0  Using [U1]
Iomode adxifs  ""  Using [U1]
Iomode adxirs  chr$(13)+chr$(10)  Using [U1]
Iomode adxium  GUTF8  Using [U1]

If [M:AMP]UNIVDES <> ""
 For I=0 To [M:AMP]NBETA-1
  If[M:AMP]TRADUC(I) = 2
   If !find([M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVDES+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]UNIVDESID,CHAINE(0..NB))
    Wrseq [M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVDES+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]UNIVDESID Using [U1]
    CHAINE(NB) = [M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVDES+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]UNIVDESID
    NB += 1
   Endif
  Endif
 Next I
Else
 For I=0 To [M:AMP]NBETA-1
  If[M:AMP]TRADUC(I) = 2
   If !find([M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVERS(I)+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]ETAUNVID(I),CHAINE(0..NB))
    Wrseq [M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVERS(I)+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]ETAUNVID(I) Using [U1]
    CHAINE(NB) = [M:AMP]UNIVERS(I)+';'+[M:AMP]UNIVERS(I)+';'+[M:AMP]ETAUNVID(I)+';'+[M:AMP]ETAUNVID(I)
    NB += 1
   Endif
  Endif
 Next I
Endif
Openo Using [U1]

## Ecriture fichier liste documents
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+DOCPRO , 0  Using [D1]
Iomode adxifs  ""  Using [D1]
Iomode adxirs  chr$(13)+chr$(10)  Using [D1]
Iomode adxium  GUTF8  Using [D1]
For I=0 To [M:AMP]NBETA-1
  If[M:AMP]TRADUC(I) = 2
   Wrseq [M:AMP]ETAT(I)+';'+[M:AMP]ETAT(I)+';'+[M:AMP]ETATID(I)+';'+[M:AMP]IDREPDES Using [D1]
  Endif
 Next I
Openo Using [D1]

For I=0 To [M:AMP]NBETA-1
 If[M:AMP]TRADUC(I) = 2
  Call ECR_TRACE("  -"-[M:AMP]ETAT(I),0) From GESECRAN
 Endif
Next I

Gosub GENE_UNIV2 From SUBATV2

Return

######################################################################################
Subprog AM_REPBO(VALEUR)
Variable Char    VALEUR()
Local Integer BALISE,OK
BALISE = 1 : OK =1
Gosub CRE_LIST_ETA From SUBATV2
Gosub CHARGE
End

######################################################################################
Subprog AM_REPBODES(VALEUR)
Variable Char    VALEUR()
BALISE = 1 : OK =1
Gosub CRE_LIST_ETA From SUBATV2
End
