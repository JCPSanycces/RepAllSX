#
#   Recapitulative Statements Germany
#
#   PURPOSE :    Exports recapitulative statements as XML-, CSV- and ELMA5-files.
#   AUTHORS :    DNE
#   DATE    :    2012-07-19
#   UPDATES :    2013-01-14 MAMAY/DNE - Mass data compliance
#                2014-05-16 DNE - Changes caused by interface changes in GERVATCSVLIB.src (US #729).
#                2014-05-19 DNE - Output is now volume aware and can be downloaded (US #780)
#
#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "RSG", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################


#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "DEBUT"   : Gosub DEBUT
        When "OK"      : Gosub OK
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the property window.
#*
#*! #############################################################################################################

$DEBUT
    [M] = [M:RSG0]
    Affzo [M] 1 - 99

    # If file type is CSV for ELster Online disable this section.
    If [M]TYPFIL = 2
        Diszo [M]MODSUB
    Else
        Actzo [M]MODSUB
    Endif

# 2014-05-19 DNE INSERT BEGIN
    # Disable/enable VOLFIL field and get the output volume/storage area.
    [M]TYPEXP = 1 # Client
    Call AM_TYPEXP( [M]TYPEXP )
# 2014-05-19 DNE INSERT END
Return



#** #############################################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler for the OK button.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button.
#*
#*! #############################################################################################################

$OK
    Case [M]TYPFIL
        When 1  # Sage Elster Client Export
            Gosub CREATE_RSG_CSV_ELSTERCLIENT
        When 2  # CSV Export
            Gosub CREATE_RSG_CSV
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_RSG_CSV_ELSTERCLIENT
#*
#* Purpose:    Exports a Sage ELSTER-Client complient CSV file.
#*
#*! #############################################################################################################

$CREATE_RSG_CSV_ELSTERCLIENT
    If clalev([F:RLI])=0  : Local File REPLINDEF [RLI] : Endif
    If clalev([F:RSLG1])=0  : Local File RSLINESGER1 [RSLG1] : Endif

    Local Char CPY(GLONCPY)                                # Company code
# 2014-05-19 DNE INSERT BEGIN (US #780)
    Local Char FILENAMETR(GDIMFIC)    : FILENAMETR = ""
    Local Char URL(GDIMFIC)           : URL = ""
    Local Char EXPORTNAME(GDIMFIC)    : EXPORTNAME = ""
    Local Char EXPORTFILE(GDIMFIC)    : EXPORTFILE = ""
    Local Integer YESNO               : YESNO = 1           # ... Defaults to NO.
    Local Integer FILEEXISTS
# 2014-05-19 DNE INSERT END
# 2014-05-19 DNE DELETE BEGIN (US #780)
#    Local Char PARAMETERVALUE(255)
# 2014-05-19 DNE DELETE END
    Local Char TRNTYP(8)
    Local Integer SUBMISS
    Local Integer WITHDRAWAL
    Local Integer I

    # Get company group or company.
    If [M:RSG0]GRP <> ""
        CPY = [M:RSG0]GRP
    Else
        CPY = [M:RSG0]CPY
    Endif

# 2014-05-19 DNE DELETE BEGIN (US #780)
#    # Warn if the parameter RSGFILPAT is empty.
#    PARAMETERVALUE = func AFNC.PARAM( "RSGFILPAT", CPY )
#    If PARAMETERVALUE = ""  Then
#        Call ERREURT( mess(277,107,1), 1 ) From GESECRAN  # "Parameter: RSGFILPAT\Please set an export directory."
#        End
#    Endif
# 2014-05-19 DNE DELETE END

    # ...
    If [M]MODSUB = 2 : SUBMISS = 1 : Else : SUBMISS = 0 : Endif

    # ...
    If [M]MODSUB = 3 : WITHDRAWAL = 1 : Else : WITHDRAWAL = 0 : Endif

# 2014-05-19 DNE MODIF BEGIN (US #780)
    If ( [M]TYPEXP = 2 ) & ( func GERVATCSVLIB.CHECK_PATH( [M]DIRXMLDESC ) = 0 ) : RC = 1 : Return : Endif
# 2014-05-19 DNE MODIF ORIG
#    # Check if everything is ready to export file.
#    If !func GERVATCSVLIB.CHECKFILE( PARAMETERVALUE, 3 )
#        Return
#    Endif
# 2014-05-19 DNE MODIF END

# 2014-05-19 DNE INSERT BEGIN (US #780)
    FILENAMETR = func GERVATCSVLIB.GETFILENAME( 3 )

    If [M]TYPEXP = 1 : # Client
        EXPORTNAME = FILENAMETR
        EXPORTFILE = [M]DIRXMLDESC
        Call SET_FICNAM( FILENAMETR, EXPORTFILE, URL ) From ORDSYS
        FILENAMETR = EXPORTFILE
    Else # Server
        FILENAMETR = [M]DIRXMLDESC
&                  + func GDPDU1.GETDIRSEPARATOR()
&                  + FILENAMETR

        # Validate file path in server mode.
        Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
        If FILEEXISTS = 1
            Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
            If YESNO = 1 # No --> Cancel.
                Return
            Endif
        Endif
    Endif
# 2014-05-19 DNE INSERT END

    # Open ELSTER CSV file and write header data to the file.
# 2014-05-19 DNE MODIF BEGIN
    Call INITFILE( FILENAMETR, 3, [M:RSG0]GRP, [M:RSG0]CPY,
&                  [M]DATDEB, [M]DATFIN, [M]FLGCOR - 1, SUBMISS, WITHDRAWAL ) From GERVATCSVLIB
# 2014-05-19 DNE MODIF ORIG
#    Call INITFILE( PARAMETERVALUE, 3, [M:RSG0]GRP, [M:RSG0]CPY, [M]DATDEB, [M]DATFIN, [M]FLGCOR - 1, SUBMISS, WITHDRAWAL ) From GERVATCSVLIB
# 2014-05-19 DNE MODIF END

    # Export reporting lines from table RSLINESGER1.
    Filter [F:RSLG1] Where USERID = func CNSRSGSTDLIB.GETUSERID Order By Key RSLG2
    For [F:RSLG1]
        # Suppress 0 totals.
        If [F:RSLG1]GEREECNUM <> "" and fix([F:RSLG1]AMTTRN) <> 0 Then
            # Get the turnover type from report line definition (field COD2).
            [L]TRNTYP = [F:RSLG1]TRNTYP
            Read [F:RLI]RLI0 = [M:RSG0]LEG; 2;TRNTYP
            If !fstat
              TRNTYP = [F:RLI]COD2
            Endif

            # Write turnover type/EU VAT ID/amount fields to CSV file.
            Call WRITEFILELINE( 4,  7, num$( I ), "umsatzart", TRNTYP,                               0 ) From GERVATCSVLIB
            Call WRITEFILELINE( 4,  7, num$( I ), "UStId_EG",  [F:RSLG1]GEREECNUM,                   0 ) From GERVATCSVLIB
            Call WRITEFILELINE( 4,  7, num$( I ), "Betrag",    num$( fix( [F:RSLG1]AMTTRN ) * 100 ), 2 ) From GERVATCSVLIB
        Endif
        I += 1
    Next

    # Close ELSTER CSV file
    Gosub CLOSEFILE From GERVATCSVLIB

# 2014-05-19 DNE MODIF BEGIN (US #780)
    # If the file is to be downloaded to the client initiate the download.
    Gosub DOWNLOAD_FILE_COMMON
# 2014-05-06 DNE MODIF ORIG
#    # Signal success.
#    Call MESSAGE( mess(257,107,1) ) From GESECRAN # "File succesfully created."
# 2014-05-06 DNE MODIF END
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_RSG_CSV
#*
#* Purpose:    Exports a CSV file.
#*
#*! #############################################################################################################

$CREATE_RSG_CSV
    If clalev([F:RLI])=0  : Local File REPLINDEF [RLI] : Endif
    If clalev([F:RSLG1])=0  : Local File RSLINESGER1 [RSLG1] : Endif

    Local Char TRNTYP(8)
    Local Char FILEEXTENSION(255) : FILEEXTENSION = "csv"
    Local Integer I

    # Create file name.
    Gosub CREATE_RS_FILE_COMMON
# 2014-05-19 DNE MODIF INSERT BEGIN (US #780)
    If RC : Return : Endif
# 2014-05-19 DNE MODIF INSERT END

    # Open CSV file for writing.
    Openo FILENAMETR, 0                                                  Using [XOUT]
    Iomode adxirs chr$(10)                                               Using [XOUT]
    Iomode adxifs ";"                                                    Using [XOUT]

    # Write CSV header
    #
    # Write version number.
    Wrseq "#v1.1"                                                        Using [XOUT]

    # Write header line (column titles).
    Wrseq "Laenderkennzeichen;USt-IdNr.;Betrag(EUR);Dreiecksgeschaeft"   Using [XOUT]

    # Write data lines.
    #
    # Note: We decided to implement the data lines using the following:
    #         - Field separator is semicolon (see Iomode adxifs line above).
    #         - Line separator is LF (chr$(10)).
    #         - Alphanumeric fields are wrapped in ".
    #         - The turnover field is truncated to full EURs.
    #
    Filter [F:RSLG1] Where USERID = func CNSRSGSTDLIB.GETUSERID Order By Key RSLG2
    For [F:RSLG1]
        # Suppress 0 totals.
        If [F:RSLG1]GEREECNUM <> "" and [F:RSLG1]AMTTRN <> 0 Then

            # Get the turnover type from report line definition (field COD2).
            TRNTYP = [F:RSLG1]TRNTYP
            Read [F:RLI]RLI0 = [M:RSG0]LEG; 2;TRNTYP
            If !fstat
                TRNTYP = [F:RLI]COD2
            Endif

            # Output CSV line.
            Wrseq
&               '"' + left$( [F:RSLG1]GEREECNUM, 2 ) + '"',
&               '"' + right$( [F:RSLG1]GEREECNUM, 3 ) + '"',
&               num$( fix( [F:RSLG1]AMTTRN ) ),
&               '"' + TRNTYP + '"'
&                                                                        Using [XOUT]
        Endif
        I += 1
    Next

    # Close file.
    Openo                                                                Using [XOUT]

# 2014-05-19 DNE INSERT BEGIN (US #780)
    # If the file is to be downloaded to the client initiate the download.
    Gosub DOWNLOAD_FILE_COMMON
# 2014-05-19 DNE INSERT END
# 2014-05-19 DNE DELETE BEGIN (US #780)
#    # Signal success.
#    Call MESSAGE( mess(257,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ) ) From GESECRAN # "File succesfully created."
# 2014-05-19 DNE DELETE END
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_RS_FILE_COMMON
#*
#* Purpose:    Commen export code for XML (removed) and CSV exports. Creates file name and checks for the
#*             existance of a file with that name.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param Local Char FILEEXTENSION(255)     Extension of the file to export.
#*
#*
#* Creates/Returns (as variables for the main chunk):
#*
#*        Local Char FILENAMETR(255)        Returns the final file name
#*        Local Char URL(GDIMFIC)           ...
#*        Local Char EXPORTNAME(GDIMFIC)    ...
#*        Local Char EXPORTFILE(GDIMFIC)    ...
#*        Local Integer STAT                ...
#*        Local Char CPY(GLONCPY)           Returns company code either from company group or from
#*                                          company entry in the mask [M:RSG0]
#*        Local Char QUARTDATINFO(255)      ...
#*        Local Char QUARTYEAR(255)         ...
#*
#*
#*! #############################################################################################################

$CREATE_RS_FILE_COMMON
    Local Char    QUARTDATINFO(255)   : QUARTDATINFO = ""
    Local Char    QUARTYEAR(255)      : QUARTYEAR = ""
    Local Char    FILENAMETR(255)     : FILENAMETR = ""
# 2014-05-19 DNE INSERT BEGIN (US #780)
    Local Char    URL(GDIMFIC)        : URL = ""
    Local Char    EXPORTNAME(GDIMFIC) : EXPORTNAME = ""
    Local Char    EXPORTFILE(GDIMFIC) : EXPORTFILE = ""
    Local Integer RC                  : RC = 0
# 2014-05-19 DNE INSERT END
    Local Integer YESNO               : YESNO = 1           # ... Defaults to NO.
    Local Integer FILEEXISTS
    Local Char    CPY(GLONCPY)                              # Company code
# 2014-05-19 DNE DELETE BEGIN (US #780)
#    Local Char    PARAMETERVALUE(255)
# 2014-05-19 DNE DELETE END

    # Quarter/month/year information for XML output and filename.
    If month([M]DATDEB) = 1 and month([M]DATFIN) = 3
        QUARTYEAR = "1. Quartal"
        QUARTDATINFO = "I-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month([M]DATDEB) = 4 and month([M]DATFIN) = 6
        QUARTYEAR = "2. Quartal"
        QUARTDATINFO = "II-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month([M]DATDEB) = 7 and month([M]DATFIN) = 9
        QUARTYEAR = "3. Quartal"
        QUARTDATINFO = "III-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month([M]DATDEB) = 10 and month([M]DATFIN) = 12
        QUARTYEAR = "4. Quartal"
        QUARTDATINFO = "IV-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month( [M]DATDEB ) = month( [M]DATFIN )
        QUARTYEAR = month$( [M]DATFIN )
        QUARTDATINFO = format$( "D:MM", [M]DATFIN ) + "-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month([M]DATDEB) = 1 and month([M]DATFIN) = 12
        QUARTYEAR = "Kalenderjahr"
        QUARTDATINFO = format$( "D:YYYY", [M]DATFIN )
    Endif

    # Get company group or company.
    If [M:RSG0]GRP <> ""
        CPY = [M:RSG0]GRP
    Else
        CPY = [M:RSG0]CPY
    Endif

# 2014-05-19 DNE DELETE BEGIN (US #780)
#    # Warn if the parameter RSGFILPAT is empty.
#    PARAMETERVALUE = func AFNC.PARAM( "RSGFILPAT", CPY )
#    If PARAMETERVALUE = ""  Then
#        Call ERREURT( mess(277,107,1), 1 ) From GESECRAN # "Parameter: RSGFILPAT\Please set an export directory."
#        End
#    Endif
# 2014-05-19 DNE DELETE END

    # Warn if path in parameter RSGFILPAT does not exist.
# 2014-05-19 DNE MODIF BEGIN (US #780)
    If ( [M]TYPEXP = 2 ) & ( func GERVATCSVLIB.CHECK_PATH( [M]DIRXMLDESC ) = 0 ) : RC = 1 : Return : Endif
# 2014-05-19 DNE MODIF ORIG
#    If !func GERVATCSVLIB.CHECK_PATH( PARAMETERVALUE )
#        End
#    Endif
# 2014-05-19 DNE MODIF END

    # Create the file name from parameter value of RSGFILPAT, current date and
    # year/quarter/month information.
# 2014-05-19 DNE MODIF BEGIN (US #780)
    FILENAMETR = "DCLVAT" + [M:RSG0]LEG + "_RS_"
&              + CPY
&              + "_"
&              + format$( "D:YYYYMMDD", date$ )
&              + "_"
&              + QUARTDATINFO
&              + "." + FILEEXTENSION
    If [M]TYPEXP = 1 : # Client
        EXPORTNAME = FILENAMETR
        EXPORTFILE = [M]DIRXMLDESC
        Call SET_FICNAM( FILENAMETR, EXPORTFILE, URL ) From ORDSYS
        FILENAMETR = EXPORTFILE
    Else # Server
        FILENAMETR = [M]DIRXMLDESC
&                  + func GDPDU1.GETDIRSEPARATOR()
&                  + FILENAMETR
        Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
        If FILEEXISTS = 1
            Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
            If YESNO = 1 # No --> Cancel.
                RC = 1
            Endif
        Endif
    Endif
# 2014-05-19 DNE MODIF ORIG
#    FILENAMETR = PARAMETERVALUE
#&              + func GDPDU1.GETDIRSEPARATOR()
#&              + "DCLVAT" + [M:RSG0]LEG + "_RS_"
#&              + CPY
#&              + "_"
#&              + format$( "D:YYYYMMDD", date$ )
#&              + "_"
#&              + QUARTDATINFO
#&              + "." + FILEEXTENSION
#
#    # If the file already exists ask for allowance to overwrite.
#    Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
#    If FILEEXISTS = 1
#        Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
#        If YESNO = 1 # No
#            End
#        Endif
#    Endif
# 2014-05-19 DNE MODIF END
Return



# 2014-05-19 DNE INSERT BEGIN (US #780)
#** #############################################################################################################
#*
#* Sub chunk:  DOWNLOAD_FILE_COMMON
#*
#* Purpose:    Commen export code for XML (removed) and CSV exports. In case of client export download the file.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param Local Char EXPORTNAME(GDIMFIC)    ...
#*        Local Char EXPORTFILE(GDIMFIC)    ...
#*
#* Creates/Returns (as variables for the main chunk):
#*
#*        Local Integer STAT                ...
#*
#*! #############################################################################################################

$DOWNLOAD_FILE_COMMON
    Local Integer STAT : STAT = 0

    # If the file is to be downloaded to the client initiate the download.
    If [M]TYPEXP = 1 : # Client
        Call COPCLI( EXPORTFILE, EXPORTNAME, STAT ) From ORDSYS
        If STAT = 1
            Call ERREUR( mess(164,141,1) ) From GESECRAN # 'File not copied to the client workstation'
        Elsif STAT > 1
            Call ERREUR( mess(159,141,1) - "(" +num$( STAT ) + ")" ) From GESECRAN # 'File or directory do not exist'
        Endif
    Endif
Return
# 2014-05-19 DNE INSERT END





# ###############################################################################################################
# ##########
# ########## Screen/Window handling
# ##########
# ##########
# ##########
# ###############################################################################################################

#################################################################################################################
#
#    Event: After change of field TYPFIL (export file type).
#    Does:  If file type is not XML (VALEUR = 1) disable the preview option.
#
#################################################################################################################

Subprog AM_TYPFIL(VALEUR)
Variable Integer VALEUR

    # If file type is CSV for ELster Online disable this section.
    If VALEUR = 2
        Diszo [M]MODSUB
    Else
        Actzo [M]MODSUB
    Endif
End


# 2014-05-19 DNE INSERT BEGIN (US #780)
#################################################################################################################
#
#    Event: While changing field VOLFIL
#    Does:  Checks if the volume/directory exists and that it is a directory.
#
#################################################################################################################

Subprog C_VOLFIL(VALEUR)
Variable Char VALEUR()

    Gosub ENUM_VOLFIL_TYPE From ASYRSTO
    mkstat = func ASYRSTO.CTL_VOLFIL( [M]TYPEXP, VALEUR, [M]DIRXMLDESC, E_TYPE_FOLDER, GMESSAGE )
End



#################################################################################################################
#
#    Event: After having changed the TYPEXP field
#    Does:  Updates fields after modification of the export to client/server selection
#
#################################################################################################################

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
    If VALEUR = 1
        Raz   [M]VOLFIL
        Affzo [M]VOLFIL
        Grizo [M]VOLFIL
    Else
        Local Char CPY(GLONCPY)                              # Company code

        # Get company group or company.
        If [M:RSG0]GRP <> ""
            CPY = [M:RSG0]GRP
        Else
            CPY = [M:RSG0]CPY
        Endif

        Actzo [M]VOLFIL
        [M]VOLFIL = func AFNC.PARAM( "RSGFILPAT", CPY )
        Affzo [M]VOLFIL
    Endif
End
# 2014-05-19 DNE INSERT END
