#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char VALEUR(GLONADD) , PARAM(250)(1..2)
PARAM(1) = "TEST"
PARAM(2) = "toto"
Call SAISIE_CHAR(VALEUR,PARAM,"APASSWD","APASSWD","") From GSAISIE
Infbox num$(mkstat)
End

#-----------------------------------#
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "END"   : mkstat = 1
Endcase
Return

#-----------------------------------#
$OUVRE
Local Integer K , M , ER
Local Char    DOSSIER(GDIMFIC) , USER(GLONAUS)
DOSSIER = PARAM(1)
USER    = PARAM(2)
If DOSSIER="" or (GSOPHIA & clalev([M:ADIF])>0)
 FIN = 1 : Return
Endif
Onerrgo ERRFIL
K = filinfo(filpath("FIL","AUTILIS","fde",DOSSIER),0)
M = filinfo(filpath("FIL","AFCTFCY","fde",DOSSIER),0)
If (ER | K<=0 | M<=0) & GFONCTION="DOSINTEG" & GPROFIL=GSUPER
 FIN = 1 : Return
Elsif !ER & K<=0
 ER = 20 : # Fichier inexistant
Elsif !ER
 If DOSSIER=nomap
  Local File AUTILIS [AUS]
 Else
  Local File =DOSSIER+".AUTILIS" [AUS] 
 Endif
 If !ER
  Read [AUS]CODUSR First
 Endif
Endif
Onerrgo
If ER
 Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)-"AUTILIS\"+errmes$(abs(ER))) From GESECRAN
 # Dossier x\Erreur d'accès sur la table
 FIN = 1 : mkstat = 1 : Return
Endif
If USER=""
 Call CONTPAS(DOSSIER,GUSER,OK)
 If OK
  Gosub PROFIL
  Call AUTORIS(DOSSIER,GFONCTION,GUSER,WPROFIL,OK)
 Endif
Else
 Call CONTPAS(DOSSIER,USER,OK)
 If OK
  Gosub PROFIL
  Call AUTORIS(DOSSIER,GFONCTION,USER,WPROFIL,OK)
 Endif
Endif
If OK : FIN = 1 : Endif
Return

#-----------------------------------#
$PROFIL
Local Char WPROFIL(GLONAFT)
If [F:AUS]PRFFCT<>""
 WPROFIL = [F:AUS]PRFFCT
Elsif filinfo(filpath("FIL","AMETUTI","fde",DOSSIER),0)>0
 If DOSSIER=nomap
  Local File AMETUTI [AME]
 Else
  Local File =DOSSIER+".AMETUTI" [AME]
 Endif
 Read [AME]AME0 = [F:AUS]CODMET
 WPROFIL = [F:AME]PRFFCT
Endif
Return

$ERRFIL
ER = errn
Resume

#-----------------------------------#
$DEBUT
Raz [M]
[M]DOSSIER = DOSSIER
Affzo DOSSIER
If USER<>""
 Call CONTROLE("AUS","",USER,"",mkstat) From CONTOBJ
 If !mkstat
  [M]USER = USER
  Affzo USER
  zonsui = "PASSE"
 Endif
Else
 [M]USER = GUSER
Endif
GMESSAGE = ""
Return

#-----------------------------------#
Subprog CONTPAS(DOSSIER,USER,OK)
Value Char DOSSIER , USER
Variable Integer OK
OK = 0
If DOSSIER=nomap & USER=GUSER
 OK = 1
Elsif DOSSIER<>nomap & USER=GUSER
 Read [AUS]CODUSR=USER
 If !fstat
  Local File AUTILIS [AUS2]
  Read [AUS2]CODUSR=USER
  If !fstat
   If [F:AUS2]NEWPAS<>"" & [F:AUS]NEWPAS<>""
    If [F:AUS2]NEWPAS=[F:AUS]NEWPAS
     OK = 1
    Endif
   Elsif [F:AUS2]PASSE<>""
    If [F:AUS2]PASSE=[F:AUS]PASSE
     OK = 1
    Endif
   Endif
  Endif
 Endif
Endif
End

#-----------------------------------------------------------#
Subprog AUTORIS(DOSSIER,FONCTION,USER,PROFIL,OK)
Value    Char    DOSSIER , FONCTION , USER , PROFIL
Variable Integer OK
Local    Integer K , ER
Local    Char    TABLE(GLONATB)

OK = 0
ER = 0

If DOSSIER=nomap
 OK = 1 : End
Endif

Onerrgo ERRFIL
For TABLE="AFONCTION","AFCTFCY","AFCTPRF","AFCTFCT"
 K = filinfo(filpath("FIL","AFONCTION","fde",DOSSIER),0)
 If K<=0 : ER = 20 : Endif : # Fichier inexistant
 If ER : Break : Endif
 Case TABLE
  When "AFONCTION" : Local File =DOSSIER+"."+TABLE [AFC]
  When "AFCTFCY"   : Local File =DOSSIER+"."+TABLE [AFF]
  When "AFCTPRF"   : Local File =DOSSIER+"."+TABLE [AFP]
  When "AFCTFCT"   : Local File =DOSSIER+"."+TABLE [AFT]
 Endcase
 If ER : Break : Endif
Next TABLE
Onerrgo
If ER
 Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)-TABLE+"\"+errmes$(abs(ER))) From GESECRAN
 # Dossier x\Erreur d'accès sur la table
 End
Endif
Onerrgo ERRFIL
Read [AFC]CODINT = FONCTION
If ER
 Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)+"AFONCTION\"+errmes$(abs(ER))) From GESECRAN
 # Dossier x\Erreur d'accès sur la table
Elsif fstat
 If GADONIX=2 : OK = 1 : Endif
Else
 Read [AFT]AFT0 = PROFIL
 If ER
  Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)+"AFCTFCT\"+errmes$(abs(ER))) From GESECRAN
  # Dossier x\Erreur d'accès sur la table
 Elsif !fstat & ((dim([F:AFT]ALLFCT)>0 & [F:AFT]ALLFCT=2) or (dim([F:AFT]ALLFCT)<=0 & [F:AFT]ALLACS=2))
  OK = 1
 Elsif [F:AFC]FCYAUZ<>2 : # Fonctions sans sites
  Read [AFP]AFP0 = PROFIL ; FONCTION ; ""
  If ER
   Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)+"AFCTPRF\"+errmes$(abs(ER))) From GESECRAN
   # Dossier x\Erreur d'accès sur la table
  Elsif !fstat & [F:AFP]ACS=2
   OK = 1
  Endif
 Else
  For [AFF]AFF1 Where PRFCOD=PROFIL & FNC=FONCTION & FCY<>""
   OK = 1 : Break
  Next AFF
  If ER
   Call ERREUR(mess(85,115,1)-DOSSIER+"\"+mess(73,139,1)+"AFCTFCY\"+errmes$(abs(ER))) From GESECRAN
   # Dossier x\Erreur d'accès sur la table
  Endif
 Endif
Endif
Close Local File [AFC] , [AFF] , [AFP] , [AFT]
Onerrgo
End

#-----------------------------------#
Subprog C_USER(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Read [AUS]CODUSR = VALEUR
Gosub PROFIL
Call AUTORIS([M]DOSSIER,GFONCTION,[F:AUS]USR,WPROFIL,OK)
If !OK
 GMESSAGE = mess(85,115,1)-[M]DOSSIER+"\"+GFONCTION-":"-mess(74,100,1) : # Dossier\Fonction non autorisée
 mkstat  = 2 : End
Endif
End

#-----------------------------------#
Subprog C_PASSE(VALEUR)
Variable Char    VALEUR()
Local Char    MOTPASSE(24)
Local Integer OK
Read [AUS]CODUSR = [M]USER
MOTPASSE = VALEUR
Call CTLPAS(MOTPASSE,OK) From GESUSER
If !OK
 GMESSAGE = mess(25,100,1) : # Mot de passe incorrect
 mkstat  = 2 : End
Endif
End

