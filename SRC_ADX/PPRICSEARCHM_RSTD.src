#<AdxTL>@(#)3.0.0.0 $Revision$
#Class PPRICSEARCHM_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
      Case [L]AEVENT
          When "AINIT"      :  Gosub AINIT
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "PRICESEARCHM"     :  Gosub FINDPRICE_FOR_MOBILE  # M
    When "PRICELISTM"       :  Gosub PRICELIST_MET_MOBILE  # 2/28/2014
    When "GETDEFAULT"       :  Gosub GET_DEFAULT
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "BPSNUM_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub BPSNUM_REP_PROPAGATE
      Endcase
    When "ITMREF_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub ITMREF_REP_PROPAGATE
      Endcase
    When "CURREF_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub CURREF_REP_PROPAGATE
      Endcase
    When "PUUREF_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PUUREF_REP_PROPAGATE
      Endcase
    When "VACBPR_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub VACBPR_REP_PROPAGATE
      Endcase
    When "EECICT_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EECICT_REP_PROPAGATE
      Endcase
    When "PTE_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PTE_REP_PROPAGATE
      Endcase
    When "PJT_REP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PJT_REP_PROPAGATE
      Endcase
  Endcase
Return

############################################################################
$AINIT
  this.BPSNUM_REP = "" : this.ITMREF_REP = ""
  #--Set _isdef to "false"
  this.BPSNUM_GETDF = [V]CST_AFALSE
  this.ITMREF_GETDF = [V]CST_AFALSE
  this.CURREF_ISDEF = [V]CST_AFALSE
  this.PUUREF_ISDEF = [V]CST_AFALSE
  this.VACBPR_ISDEF = [V]CST_AFALSE
  this.EECICT_ISDEF = [V]CST_AFALSE
  this.PTE_ISDEF    = [V]CST_AFALSE
  this.PJT_ISDEF    = [V]CST_AFALSE
#  Local Char WATTRIBUT_CRIT(10)   3/14/2014
#  Local Char WATTRIBUT_ADDCRIT(10)
#  Local Char WATTRIBUT_PRICERESULT(10)
#  Local Char WATTRIBUT_PRICELIST(10)
#  WATTRIBUT_CRIT        = "true"
#  WATTRIBUT_ADDCRIT     = "true"
#  WATTRIBUT_PRICERESULT = "true"
#  WATTRIBUT_PRICELIST   = "true"
#  Gosub MODIFY_ATTRIBUTS_ALL
Return

############################################################################
$BPSNUM_REP_PROPAGATE
  If this.PPRISEA.BPSNUM<>this.BPSNUM_REP
      #Gosub SET_FROM_BPSNUM_TOKEEP
     this.PPRISEA.BPSNUM = this.BPSNUM_REP :#--It triggers the propagate
     this.BPSNUM_GETDF = [V]CST_ATRUE
  Else
     this.BPSNUM_GETDF = [V]CST_AFALSE
  Endif
Return

############################################################################
$ITMREF_REP_PROPAGATE
  If this.PPRISEA.ITMREF<>this.ITMREF_REP
   # Gosub SET_FROM_ITMREF_TOKEEP
    this.PPRISEA.ITMREF = this.ITMREF_REP :#--It triggers the propagate
    this.ITMREF_GETDF = [V]CST_ATRUE
#    If this.PUUREF_REP = ""
#      If this.PPRISEA.PUUREF <> " " ###################### New test
#        this.setAccessorEnabled = [V]CST_AFALSE
#        this.PUUREF_REP        = this.PPRISEA.PUUREF
#        this.setAccessorEnabled = [V]CST_ATRUE
#      Endif
#    Endif  ########## End test
  Else
    this.ITMREF_GETDF = [V]CST_AFALSE
  Endif
Return

############################################################################
$CURREF_REP_PROPAGATE
  If (this.CURREF_ISDEF = [V]CST_ATRUE and this.CURREF_REP <>"") | this.BPSNUM_GETDF=[V]CST_AFALSE
    this.PPRISEA.CURREF = this.CURREF_REP
  Endif
Return

############################################################################
$PUUREF_REP_PROPAGATE
  If (this.PUUREF_ISDEF = [V]CST_ATRUE and this.PUUREF_REP <>"") | this.ITMREF_GETDF=[V]CST_AFALSE
    this.PPRISEA.PUUREF = this.PUUREF_REP
  Endif
Return

############################################################################
$VACBPR_REP_PROPAGATE
  If (this.VACBPR_ISDEF = [V]CST_ATRUE and this.VACBPR_REP <>"") | this.BPSNUM_GETDF=[V]CST_AFALSE
    this.PPRISEA.VACBPR = this.VACBPR_REP
  Endif
Return

############################################################################
$EECICT_REP_PROPAGATE
  If (this.EECICT_ISDEF = [V]CST_ATRUE and this.EECICT_REP <>"") | this.BPSNUM_GETDF=[V]CST_AFALSE
    this.PPRISEA.EECICT = this.EECICT_REP
  Endif
Return

############################################################################
$PTE_REP_PROPAGATE
  If (this.PTE_ISDEF = [V]CST_ATRUE and this.PTE_REP <>"") | this.BPSNUM_GETDF=[V]CST_AFALSE
    this.PPRISEA.PTE = this.PTE_REP
  Endif
Return

############################################################################
$PJT_REP_PROPAGATE
  If (this.PJT_ISDEF = [V]CST_ATRUE and this.PJT_REP <>"") | this.BPSNUM_GETDF=[V]CST_AFALSE
    this.PPRISEA.PJT = this.PJT_REP
  Endif
Return

############################################################################
$SET_FROM_BPSNUM_TOKEEP

  this.CURREF_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.CURREF=""
    this.CURREF_ISDEF = [V]CST_ATRUE
  Endif

  this.VACBPR_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.VACBPR=""
    this.CURREF_ISDEF = [V]CST_ATRUE
  Endif

  this.EECICT_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.EECICT=""
    this.EECICT_ISDEF = [V]CST_ATRUE
  Endif

  this.PTE_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.PTE=""
    this.PTE_ISDEF = [V]CST_ATRUE
  Endif

  this.PJT_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.PJT=""
    this.PJT_ISDEF = [V]CST_ATRUE
  Endif
Return

$SET_FROM_ITMREF_TOKEEP
  this.PUUREF_ISDEF = [V]CST_AFALSE
  If this.PPRISEA.PUUREF=""
    this.PUUREF_ISDEF = [V]CST_ATRUE
  Endif
Return

############################################################################
$GET_DEFAULT
  #--Default values
  Gosub SET_PROPERTIES
  Gosub LOAD_R_PRICE
  [L]ARET_VALUE = [L]ASTATUS # 98349.n

#  Local Char WATTRIBUT_CRIT(10)   3/14/2014
#  Local Char WATTRIBUT_ADDCRIT(10)
#
#  WATTRIBUT_CRIT        = "false"
#  Gosub MODIFY_ATTRIBUTS_CRITERIA
#
#  WATTRIBUT_ADDCRIT     = "false"
#  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA
Return

############################################################################
#--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
$CONTROL_PROP

  Local Integer VRET
  Local Char    VMESSA(250)

  #--Because we are still on Edit mode, the global _ACONTROL of the class is not executed
  #--It meens that controls such as mandatory fields are not done (tha _aformat and _aothers control actions are executed, but not _amandatory)
  #--All those have to be done manually

  If this.CURREF_REP=""
    [L]ASTATUS = fmet this.ASETERROR("CURREF_REP",mess(10,123,1),[V]CST_AERROR)
    Return
  Endif

 # If this.PUUREF_REP=""
 #   [L]ASTATUS = fmet this.ASETERROR("PUUREF_REP",mess(10,123,1),[V]CST_AERROR)
 #   Return
 # Endif
Return

############################################################################
$SET_PROPERTIES
  #--A way to recover the properties in the sended json
  #--We don't want accessors triggered
  this.PPRISEA.setAccessorEnabled = [V]CST_AFALSE

  this.PPRISEA.PURSALFCY  = this.PPRISEA.PURSALFCY
  this.PPRISEA.FCY        = this.PPRISEA.FCY
  this.PPRISEA.CPY        = this.PPRISEA.CPY
  this.PPRISEA.LEG        = this.PPRISEA.LEG
  this.PPRISEA.PLISTC     = this.PPRISEA.PLISTC
  this.PPRISEA.BPSNUM     = this.PPRISEA.BPSNUM
  this.PPRISEA.ITMREF     = this.PPRISEA.ITMREF
  this.PPRISEA.DATEREF    = this.PPRISEA.DATEREF

  #--Dafault values if SUPPLIER changed
  #--else (same supplier), we keep the filled values

  If this.BPSNUM_GETDF = [V]CST_ATRUE
    this.setAccessorEnabled = [V]CST_AFALSE
    this.CURREF_REP         = this.PPRISEA.CURREF
    this.PRITYP_REP         = this.PPRISEA.PRITYP
    this.VACBPR_REP         = this.PPRISEA.VACBPR
    this.PPRISEA.VACBPR_LEG = this.PPRISEA.VACBPR_LEG
    this.PTE_REP            = this.PPRISEA.PTE
    this.PPRISEA.PTE_LEG    = this.PPRISEA.PTE_LEG
    this.EECICT_REP         = this.PPRISEA.EECICT
    this.PJT_REP            = this.PPRISEA.PJT
    this.setAccessorEnabled = [V]CST_ATRUE
  Else
    this.PPRISEA.CURREF     = this.CURREF_REP
    this.PPRISEA.PRITYP     = this.PRITYP_REP
    this.PPRISEA.VACBPR     = this.VACBPR_REP
    this.PPRISEA.VACBPR_LEG = this.PPRISEA.VACBPR_LEG
    this.PPRISEA.PTE        = this.PTE_REP
    this.PPRISEA.PTE_LEG    = this.PPRISEA.PTE_LEG
    this.PPRISEA.EECICT     = this.EECICT_REP
    this.PPRISEA.PJT        = this.PJT_REP
  Endif

  #--Default values if item changed
  #--else (same item), we keep the filled values
  If this.ITMREF_GETDF = [V]CST_ATRUE
    this.setAccessorEnabled = [V]CST_AFALSE
    this.PUUREF_REP        = this.PPRISEA.PUUREF
    this.setAccessorEnabled = [V]CST_ATRUE
  Else
    this.PPRISEA.PUUREF     = this.PUUREF_REP
  Endif

  this.PPRISEA.setAccessorEnabled = [V]CST_ATRUE
  #--/
Return

############################################################################
$CAPS_PROP
#this.BPSNUM_REP         = toupper(this.BPSNUM_REP)
#this.PPRISEA.BPSNUM     = toupper(this.PPRISEA.BPSNUM)
##this.PPRISEA.PURSALFCY  = toupper(this.PPRISEA.PURSALFCY)  ### This forces the propagation in CSTD which blanks out the this.FCY !!
#
#If this.PPRISEA.FCY <> ""  : this.PPRISEA.FCY = toupper(this.PPRISEA.FCY) : Endif
##this.PPRISEA.CURREF     = toupper(this.PPRISEA.CURREF)
##this.CURREF_REP         = toupper(this.CURREF_REP)
#this.PPRISEA.ITMREF     = toupper(this.PPRISEA.ITMREF)
#this.ITMREF_REP         = toupper(this.ITMREF_REP)
Return

############################################################################
$SET_PROPERTIES_REP
  #--A way to recover the properties in the sended json
  #--We don't want accessors triggered
  #this.PPRISEA.setAccessorEnabled = [V]CST_AFALSE

  this.PPRISEA.PURSALFCY  = this.PPRISEA.PURSALFCY
  this.PPRISEA.FCY        = this.PPRISEA.FCY
  this.PPRISEA.CPY        = this.PPRISEA.CPY
  this.PPRISEA.LEG        = this.PPRISEA.LEG
  this.PPRISEA.PLISTC     = this.PPRISEA.PLISTC
  this.PPRISEA.BPSNUM     = this.PPRISEA.BPSNUM
  this.PPRISEA.ITMREF     = this.PPRISEA.ITMREF
  this.PPRISEA.DATEREF    = this.PPRISEA.DATEREF
  this.PPRISEA.CURREF     = this.CURREF_REP
  this.PPRISEA.PRITYP     = this.PRITYP_REP
  this.PPRISEA.VACBPR     = this.VACBPR_REP
  this.PPRISEA.PTE        = this.PTE_REP
  this.PPRISEA.EECICT     = this.EECICT_REP
  this.PPRISEA.PJT        = this.PJT_REP
  #If this.PUUREF_REP<>''
    this.PPRISEA.PUUREF     = this.PUUREF_REP
  #Endif

#If GACTX.USER= 'EWI'
#  If this.PUUREF_REP   = '' : this.PUUREF_REP  = this.PUUREF : Endif
#Endif

#--Dafault values if item changed
  #--else (same item), we keep the filled values
#  If this.ITMREF_GETDF = [V]CST_ATRUE
#    this.setAccessorEnabled = [V]CST_AFALSE
#    this.PUUREF_REP        = this.PPRISEA.PUUREF
#    this.setAccessorEnabled = [V]CST_ATRUE
#  Else
#    this.PPRISEA.PUUREF     = this.PUUREF_REP
#  Endif

#  this.PPRISEA.setAccessorEnabled = [V]CST_ATRUE
  #--/
Return

############################################################################
$FINDPRICE_FOR_MOBILE

Local Char WPROP(30)
#--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
  Gosub CONTROL_PROP
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif
#--/
#--A way to recover the properties in the sended json
  #--As oposite to the Get_default, we do not change the filled values
  #--Accessors must be triggered
  Gosub SET_PROPERTIES_REP
  #--/
  [L]ASTATUS = fmet this.PPRISEA.PRICESEARCH_MET()
  If [L]ASTATUS>=[V]CST_AERROR
    If fmet this.PPRISEA.AGETMAXERROR("")=[V]CST_AWARNING
      WPROP = this.PPRISEA.AERROR.PRO
      If this.PPRISEA.AERROR.PRO="ITMREF"
        WPROP = "ITMREF_REP"
      Endif
      [L]ASTATUS = fmet this.ASETERROR (WPROP, this.PPRISEA.AERROR.MES, [V]CST_AERROR)
    Else
      #[L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"PRICESEARCHM_MET", [L]ASTATUS) # 98394.o
      [L]ASTATUS = fmet this.ASETERROR ("", " ", [L]ASTATUS) #98394.n
    Endif
    [L]ARET_VALUE = [L]ASTATUS
  Endif
#  #--A way to recover the properties in the sended json
#  #--We don't want accessors triggered
#  Gosub SET_PROPERTIES_REP
#  #--/
#
#  [L]ASTATUS = fmet this.PPRISEA.PRICESEARCH_MET()
#  If [L]ASTATUS>=[V]CST_AERROR
#    [L]ASTATUS = fmet this.ASETERROR ("", "$METHODS Représentation SPRICESEAM : ACTION="+ACTION-"/"-"CURPTH="+CURPTH-"Error after call this.PPRISEA.PRICESEARCHM_MET()", [L]ASTATUS)
#  Endif
  Gosub LOAD_R_PRICE
#  Local Char WATTRIBUT_PRICERESULT(10)  3/14/2014
#  Local Char WATTRIBUT_PRICELIST(10)
#
#  WATTRIBUT_PRICERESULT = "false"
#  WATTRIBUT_PRICELIST   = "false"
#
#  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
#  Gosub MODIFY_ATTRIBUTS_PRICE_LIST
Return

############################################################################
$LOAD_R_PRICE
  Local Integer INBRPRICE

  If this.PPRISEA.C_PRICE(1)=null and this.PPRISEA.C_PRICE(2)=null
    Return
  Endif

  Gosub INST_R_PRICE # 3/14/2014
  INBRPRICE = 1

    #--Fill the presentation
  #  Local Integer I,WRET   3/14/2014
  #
  #  For I=1 To 4
  #    If this.R_PRICE(I)=null
  #      WRET = fmet this.ADDLINE("R_PRICE",I)
  #      If WRET = [V]CST_ANOTDEFINED
  #        #--The insertion was not possible
  #        [L]ASTATUS = fmet this.ASETERROR ("", "Représentation PPRICESEAM : Method call FINDPRICE_FOR_MOBILE result error for this.ADDLINE 'R_PRICE'"-num$(I), [V]CST_AERROR)
  #        Return
  #      Endif
  #    Endif
  #  Next I

  #  If this.PPRISEA.C_PRICE(1)<>null   3/14/2014
  #
  #    this.R_PRICE(1).LIBPRIX_REP = mess(294,197,1) #"Prix brut"
  #    this.R_PRICE(1).VALUE_REP   = this.PPRISEA.C_PRICE(1).GROPRI
  #    this.R_PRICE(2).LIBPRIX_REP = mess(295,197,1) #"Prix net"
  #    this.R_PRICE(2).VALUE_REP   = this.PPRISEA.C_PRICE(1).NETPRI
  #    this.R_PRICE(3).LIBPRIX_REP = mess(167,123,1) #"Divers"
  #    this.R_PRICE(3).VALUE_REP   = this.PPRISEA.C_PRICE(1).AUTRE
  #    this.R_PRICE(4).LIBPRIX_REP = mess(155,121,1) #"Total"
  #    this.R_PRICE(4).VALUE_REP   = this.PPRISEA.C_PRICE(1).TOTAL
  #
  #  Endif
  #
  #  If this.PPRISEA.C_PRICE(2)<>null
  #
  #    this.R_PRICE(1).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).GROPRI
  #    this.R_PRICE(2).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).NETPRI
  #    this.R_PRICE(3).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).AUTRE
  #    this.R_PRICE(4).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).TOTAL
  #
  #  Endif

  If this.PPRISEA.C_PRICE(1)<>null
     If INBRPRICE<=maxtab(this.PPRISEA.R_PRICE)-3
        this.PPRISEA.R_PRICE(INBRPRICE).LIBPRIX_REP   = mess(294,197,1) #"Prix brut"
        this.PPRISEA.R_PRICE(INBRPRICE).VALUE_REP     = this.PPRISEA.C_PRICE(1).GROPRI
        this.PPRISEA.R_PRICE(INBRPRICE+1).LIBPRIX_REP = mess(295,197,1) #"Prix net"
        this.PPRISEA.R_PRICE(INBRPRICE+1).VALUE_REP   = this.PPRISEA.C_PRICE(1).NETPRI
        this.PPRISEA.R_PRICE(INBRPRICE+2).LIBPRIX_REP = mess(167,123,1) #"Divers"
        this.PPRISEA.R_PRICE(INBRPRICE+2).VALUE_REP   = this.PPRISEA.C_PRICE(1).AUTRE
        this.PPRISEA.R_PRICE(INBRPRICE+3).LIBPRIX_REP = mess(155,121,1) #"Total"
        this.PPRISEA.R_PRICE(INBRPRICE+3).VALUE_REP   = this.PPRISEA.C_PRICE(1).TOTAL
      Endif
  Else
  Endif

  If this.PPRISEA.C_PRICE(2)<>null
      If INBRPRICE<=maxtab(this.PPRISEA.R_PRICE)-3
        this.PPRISEA.R_PRICE(INBRPRICE).AMOUNT_REP     = this.PPRISEA.C_PRICE(2).GROPRI
        this.PPRISEA.R_PRICE(INBRPRICE+1).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).NETPRI
        this.PPRISEA.R_PRICE(INBRPRICE+2).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).AUTRE
        this.PPRISEA.R_PRICE(INBRPRICE+3).AMOUNT_REP   = this.PPRISEA.C_PRICE(2).TOTAL
      Endif
  Else
  Endif

  # 99095.sn   To display default PUU on click of Search
  If this.PUUREF_REP = "" & this.PPRISEA.PUUREF <> " "
    this.setAccessorEnabled = [V]CST_AFALSE
    this.PUUREF_REP        = this.PPRISEA.PUUREF
    this.setAccessorEnabled = [V]CST_ATRUE
  Endif

  If this.PUUREF_REP <> this.PPRISEA.PUUREF
    this.setAccessorEnabled = [V]CST_AFALSE
    this.PUUREF_REP        = this.PPRISEA.PUUREF
    this.setAccessorEnabled = [V]CST_ATRUE
  Endif
  # 99095.en
Return

############################################################################
$INST_R_PRICE
  #--Fill the presentation   3/14/2014 new
  Local Integer I,WRET

  For I=1 To 4
    If this.PPRISEA.R_PRICE(I)=null
      WRET = fmet this.PPRISEA.ADDLINE("R_PRICE",I)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", func ASYRFNC.MES2(mess(266,133,1),"R_PRICE","PPRICESEARCH"), [V]CST_AERROR)
        Return
      Endif
    Endif
  Next I
Return

############################################################################
$PRICELIST_MET_MOBILE
 #--CPO 97965 Because of some properties defined within representation and in order to have a well formed error message
  Gosub CONTROL_PROP
  If [L]ASTATUS >= [V]CST_AERROR : [L]ARET_VALUE = [L]ASTATUS : Return : Endif
  #--/

  [L]ASTATUS = fmet this.PPRISEA.PRICELIST_MET()
  If [L]ASTATUS>=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("", mess(68,123,1)-":"-mess(1,7845,1)-"PRICELIST_MET()", [L]ASTATUS)
    [L]ARET_VALUE = [L]ASTATUS
  Endif

#  [L]ASTATUS = fmet this.PPRISEA.PRICELIST_MET()
#  If [L]ASTATUS>=[V]CST_AERROR
#    [L]ASTATUS = fmet this.ASETERROR ("", "$METHODS Représentation PPRICESEAM : ACTION="+ACTION-"/"-"CURPTH="+CURPTH-"Error after call this.PPRISEA.PRICELIST_MET()", [L]ASTATUS)
#  Endif
  Gosub LOAD_R_PRICE
Return

############################################################################
$MODIFY_ATTRIBUTS_ALL
  Gosub MODIFY_ATTRIBUTS_CRITERIA
  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA
  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
  Gosub MODIFY_ATTRIBUTS_PRICE_LIST
Return

############################################################################
$MODIFY_ATTRIBUTS_CRITERIA
#  [L]ASTATUS = fmet this.ASETATTRIBUTE("PPRISEA.FCY" ,"$isHidden",WATTRIBUT_CRIT)
#  [L]ASTATUS = fmet this.ASETATTRIBUTE("PPRISEA.DATEREF","$isHidden",WATTRIBUT_CRIT)
#  [L]ASTATUS = fmet this.ASETATTRIBUTE("PPRISEA.QTYREF" ,"$isHidden",WATTRIBUT_CRIT)
