#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion objet ANU
Local Char PARAM(10)(1..4) , VALEUR(10)
PARAM(1) = ""
PARAM(2) = "2"
Call TRAITE_CHAR(VALEUR,PARAM,"","ASSOMAJ","ASSOMAJ",3,"") From GTRAITE
End

#------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#------------------------------------------------#
$INIT
Local Integer TEST , PORT , AERR
Local Char    MESSAG(250)

If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:ANU])=0 : Local File ANNUAIRE  [ANU] : Endif

TIT = mess(53,130,1) : # Mise à jour des utilisateurs

Return

#------------------------------------------------#
$INIT_DIA
If PARAM(1)=""
 [M]FILTRE = '[F:AUS]USR>="A" & [F:AUS]USR<="ZZZZZ"'
Else
 [M]FILTRE = PARAM(1)
Endif
[M]SIMUL  = 2
Return

#------------------------------------------------#
$CONTROLE
Call VERIF(0,"",PORT,AERR,MESSAG) From ASSOCODE
If AERR
 Call ECR_TRACE(MESSAG,1) From GESECRAN
 FIN = 1 : Return
Endif

# En mise jour de l'utilisateur à la connexion, la boite de dialogue n'est pas ouverte

TEST = ([M]SIMUL=2)

Return

#-----------------------------------#
$EXEC
If TEST
 TIT -= "("+mess(6,115,1)+")" : # Simulation
Endif

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Else
 Call ECR_TRACE(TIT,0) From GESECRAN
Endif
TRA  = 1

Call MAJUSR([M]FILTRE,1,TEST,"","","",1,AERR,MESSAG)

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

#-----------------------------------------------------------------------------#
Subprog MAJUSR(CRITERE,TRACE,TEST,ADDN,IDAC,PASSE,OPTMAJ,AERR,MESSAG)
Value Char CRITERE
Value Integer TRACE    : # 0 pas de trace
Value Integer TEST     : # 1 simultation sans rewrite
Value Char    ADDN     : # <>"" -> recherche forcée sur distinguishedName
Value Char    IDAC     : # Identifiant LDAP
Value Char    PASSE    : # Mot de passe pour l'accés à LDAP
Value Integer OPTMAJ   : # 0 maj uniquement "distinguishedName", 1 maj complète
Variable Integer AERR  : # 0 pas d'erreur
Variable Char MESSAG   : # Message d'erreur en clair

Local Char    PREF(10) , TRTANU(GLONADC) , SYMBOLE(30) , CLAOBJ(30)
Local Char    ANAME(250) , CHAINE(250) , MESCRIT(250)
Local Integer I , J , K , L , M , ER , PORT , REFMAJ1 , REFMAJ2
Local Integer MODIF , MODFLD , NBRADD

If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR    [ADP] : Endif
If clalev([F:ANU])=0 : Local File ANNUAIRE  [ANU] : Endif

If GHISTO : End : Endif

Raz AERR , MESSAG
Call VERIF(0,"",PORT,AERR,MESSAG) From ASSOCODE
If AERR : End : Endif

Call SET_PREF(PREF) From SUBANU
TRTANU = PREF+[F:ANU]COD
Gosub INIT From =TRTANU

If IDAC=""
 IDAC  = [F:ANU]CONNEC
 PASSE = [F:ANU]PASSE
Endif

Call OUVRE([F:ANU]SERV1,PORT,IDAC,PASSE,AERR,MESSAG) From ASSOCODE
If AERR=4 : Gosub ERR_MES : End : Endif

ABASE   = [F:ANU]PARAM1
ASCOPE  = [F:ANU]PARAM2
Call PARAM("","SSOREFMAJ",CHAINE) From ADOVAL
REFMAJ1 = max(val(CHAINE),1)

If REFMAJ1=1
 REFMAJ2 = 2
Else
 REFMAJ2 = 1
Endif

Call PARAM("","SSOCLAOBJ",CHAINE) From ADOVAL
If CHAINE<>""
 CLAOBJ = CHAINE
Else
 CLAOBJ = "user"
Endif

If TRACE
 # Options
 Call ECR_TRACE(mess(127,124,1)-"Scope="+ASCOPE+" Base="+ABASE,0) From GESECRAN
Endif

If ADDN<>""
 Gosub REC_ADDN
Else
 Gosub REC_GLOB
Endif

Call FERME From ASSOCODE
End

#-----------------------------------------------------------------------------#
$REC_ADDN
For [AUS]CODUSR Where evalue(CRITERE) & !find(USR,GSUPER)
 AFILTRE = "(&(objectclass="+CLAOBJ+")"
 CHAINE = ADDN
 While CHAINE<>""
  K = instr(1,CHAINE,",")
  If K>1
   While mid$(CHAINE,K-1,1)="\"
    CHAINE = left$(CHAINE,K-2)+right$(CHAINE,K)
    K = instr(K,CHAINE,",")
   Wend
  Endif
  If K
   AFILTRE += "("+left$(CHAINE,K-1)+")"
   CHAINE = right$(CHAINE,K+1)
  Else
   AFILTRE += "("+CHAINE+")"
   CHAINE = ""
  Endif
 Wend
 AFILTRE += ")"
 Gosub RECHERCHE
 Break
Next AUS
If NBRADD<>1 & AERR=0
 AERR = 2
 MESSAG = func AFNC.MES2(mess(56,130,1),[F:AUS]USR,[F:ANU]COD) : # Impossible de retrouver l'utilisateur $1$ dans la base $2$
Endif
Return

#-----------------------------------------------------------------------------#
$REC_GLOB
For [AUS]CODUSR Where evalue(CRITERE) & !find(USR,GSUPER)
 Raz MESCRIT
 For ESSAI=find(REFMAJ1,[F:ANU]TYPFLD),find(REFMAJ2,[F:ANU]TYPFLD)
  If ESSAI
   AFILTRE = ""
   K = [F:ANU]TYPFLD(ESSAI-1)
   If dim([F:ANU]FORFLD)>0 & [F:ANU]FORFLD(K-1)<>""
    AFILTRE = [F:ANU]FORFLD(K-1)
    # On essai d'abord d'évaluer les formules (%%)
    I = instr(1,AFILTRE,"%%") 
    While I
     J = instr(I+2,AFILTRE,"%%")
     If J<=0 : Break : Endif
     CHAINE = seg$(AFILTRE,I+2,J-1)
     L = instr(1,CHAINE,"$$") : # Séparateur de champ
     While L
      M = instr(L+2,CHAINE,"$$")
      If M<=0 : Break : Endif
      K = val(seg$(CHAINE,L+2,M-1))
      If K>0
       ANAME = vireblc(num$(evalue("[F:AUS]"+[F:ANU]CODFLD(K-1))),2)
      Else
       ANAME = ""
      Endif
      CHAINE = left$(CHAINE,L-1)+ANAME+right$(CHAINE,M+2)
      L = instr(1,CHAINE,"$$")
     Wend
     ER = 0
     Onerrgo ERVAL
     ANAME = vireblc(num$(evalue(CHAINE)),2)
     Onerrgo
     If !ER
      CHAINE = ANAME
     Endif
     AFILTRE = left$(AFILTRE,I-1)+CHAINE+right$(AFILTRE,J+2)
     I = instr(1,AFILTRE,"%%")
    Wend 
    # On traite ensuite les $$ s'il en reste
    I = instr(1,AFILTRE,"$$") : # Séparateur de champ
    While I
     J = instr(I+2,AFILTRE,"$$")
     If J<=0 : Break : Endif
     K = val(seg$(AFILTRE,I+2,J-1))
     If K>0
      ANAME = vireblc(num$(evalue("[F:AUS]"+[F:ANU]CODFLD(K-1))),2)
     Else
      ANAME = ""
     Endif
     AFILTRE = left$(AFILTRE,I-1)+ANAME+right$(AFILTRE,J+2)
     I = instr(1,AFILTRE,"$$")
    Wend
   Else
    ANAME = vireblc(evalue("[F:AUS]"+[F:ANU]CODFLD(ESSAI-1)),2)
    If ANAME<>""
     If [F:ANU]TYPFLD(ESSAI-1)=1 : # distinguishedName
      I = instr(1,ANAME,"=")
      J = instr(I,ANAME,"\")
      If I & J
       AFILTRE = "(&(objectclass="+CLAOBJ+")(SN="+vireblc(seg$(ANAME,I+1,J-1),2)+")"
       I = instr(J,ANAME,",")
       J = instr(I+1,ANAME,",")
       If I & J
        AFILTRE += "(givenName="+vireblc(seg$(ANAME,I+1,J-1),2)+"))"
       Else
        AFILTRE += ")"
       Endif
      Endif
     Else
      AFILTRE = "(&(objectclass="+CLAOBJ+")("+[F:ANU]ADDFLD(ESSAI-1)+"="+ANAME+"))"
     Endif
    Endif
   Endif  
   If AFILTRE<>""
    Gosub RECHERCHE
    If AERR or NBRADD=1 : Break : Endif
    MESCRIT += "\"+AFILTRE
   Endif
  Endif
 Next ESSAI
 If NBRADD<>1 & AERR=0
  AERR = 2
  MESSAG = func AFNC.MES2(mess(56,130,1),[F:AUS]USR,[F:ANU]COD) : # Impossible de retrouver l'utilisateur $1$ dans la base $2$
  If TRACE : MESSAG += MESCRIT : Endif
  Gosub ERR_MES
 Endif
Next AUS
Return

$ERVAL
ER = errn
Resume

#----------------------------------------#
$RECHERCHE
Raz AERR , fstat
Onerrgo ERR_LIRE
Gosub LIRE From =TRTANU
Onerrgo
If AERR<>2
 NBRADD = 0
 While !fstat
  Gosub MAJ
  If AERR : Break : Endif 
  Onerrgo ERR_SUITE
  Gosub SUITE From =TRTANU
  Onerrgo
  If AERR : AERR = 0 : Break : Endif
  NBRADD += 1 
 Wend
Endif
If NBRADD>1
 MESSAG = mess(55,130,1)-AFILTRE : # Trop d'utilisateurs correspondent au critère
 Gosub ERR_MES
 MESSAG = ""
Endif
If AERR
 Gosub ERR_MES
Endif
Return

#-------------------------#
$ERR_MES
If TRACE
 Call ECR_TRACE(MESSAG,1) From GESECRAN 
Endif
Return

#-------------------------#
$MAJ
SYMBOLE = "AUS"+[F:AUS]USR
Lock =SYMBOLE
If fstat
 AERR = 2
 MESSAG = [F:AUS]USR-":"-mess(98,126,1) : # La fiche est utilisée par un autre utilisateur
Else
 If TRACE
  # Mise à jour de l'utilisateur
  Call ECR_TRACE("***"-mess(52,130,1)-[F:AUS]USR-"***",0) From GESECRAN
 Endif
 Gosub TR_MAJ
 If AERR or GOK=0
  If TRACE
   # Erreur lors de la mise à jour
   Call ECR_TRACE("***"-mess(50,176,1)-"***",-1) From GESECRAN
  Endif
 Elsif MODIF
  If TRACE
   # Mise à jour effectuée
   Call ECR_TRACE("***"-mess(102,130,1)+string$(len(mess(102,130,1))=0,"Update completed")-"***",0) From GESECRAN
  Endif
 Else
  If TRACE
   # Aucune modification effectuée
   Call ECR_TRACE("***"-mess(101,130,1)+string$(len(mess(101,130,1))=0,"No update")-"***",0) From GESECRAN
  Endif
 Endif
 Unlock =SYMBOLE
Endif
Return

$TR_MAJ
GOK = 1
Trbegin [AUS]
 Readlock [AUS]CODUSR Curr
 If fstat=1
  GOK=-1 : GLOCK="$ADOVALAUS"-[F:AUS]USR : Goto ROLL_MAJ
 Elsif !fstat
  MODIF = 0
  For I=1 To [F:ANU]NBRFLD
   Case [F:ANU]TYPFLD(I-1)
    When 1,2,3 : # Fiche
     If OPTMAJ=1 or (OPTMAJ=0 & [F:ANU]TYPFLD(I-1)=1)
      Raz ER , MODFLD
      Onerrgo ERR_EVAL
      If find([F:ANU]CODFLD(I-1),"INTUSR","NOMUSR")
       If dim([F:AUS]NOMUSR)>0 & [F:AUS]NOMUSR<>evalue(AVALEUR(I))
        MODFLD = 1
       Else
        Call LECTEXTRA(CHAINE,"AUTILIS","INTUSR",[F:AUS]USR,"") From ATEXTRA
        If CHAINE<>evalue(AVALEUR(I))
         MODFLD = 1
        Endif
       Endif
       If MODFLD
        CHAINE = evalue(AVALEUR(I))
        If dim([F:AUS]NOMUSR)>0
         [F:AUS]NOMUSR = CHAINE
        Endif
        Call MAJTEXTRA(CHAINE,"AUTILIS","INTUSR",[F:AUS]USR,"") From ATEXTRA
        MODIF = 1
       Endif
      Elsif evalue("dim([F:AUS]"+[F:ANU]CODFLD(I-1)+")")>0
       Case evalue("type([F:AUS]"+[F:ANU]CODFLD(I-1)+")")
        When 1,2,4,5,6,7,8
         CHAINE = num$(evalue(AVALEUR(I)))
         If evalue("[F:AUS]"+[F:ANU]CODFLD(I-1))<>val(CHAINE)
          Assign "[F:AUS]"+[F:ANU]CODFLD(I-1) With val(CHAINE) : MODIF = 1 : MODFLD = 1
         Endif 
        When 3
         CHAINE = evalue(AVALEUR(I))
         If len(CHAINE)>=8
          CHAINE = left$(CHAINE,8)
          If gdat$(CHAINE)<>evalue("[F:AUS]"+[F:ANU]CODFLD(I-1))
           Assign "[F:AUS]"+[F:ANU]CODFLD(I-1) With gdat$(CHAINE) : MODIF = 1 : MODFLD = 1
          Endif
         Endif
        When Default
         CHAINE = evalue(AVALEUR(I))
         If [F:ANU]CODFLD(I-1)="LOGIN"
          CHAINE = toupper(CHAINE)
         Endif
         If evalue("[F:AUS]"+[F:ANU]CODFLD(I-1))<>CHAINE
          Assign "[F:AUS]"+[F:ANU]CODFLD(I-1) With CHAINE : MODIF = 1 : MODFLD = 1
         Endif
       Endcase
      Endif
      Onerrgo
      If !ER & TRACE & MODFLD
       # Nouvelle valeur du champ
       Call ECR_TRACE(mess(51,130,1)-[F:ANU]CODFLD(I-1)-":|"-CHAINE,0) From GESECRAN
      Endif
     Endif
    When 4 : # Paramètre
     If OPTMAJ
      Read [ADP]ADP1=[F:ANU]CODFLD(I-1)
      If !fstat
       Readlock [ADU]ADU0=[F:AUS]USR;[F:ANU]CODFLD(I-1)
       If fstat=1
        GOK=-1 : GLOCK="$ADOVALAUS"-[F:AUS]USR : Break
       Elsif fstat
        Raz [F:ADU]
        [F:ADU]CODUSR = [F:AUS]USR
        [F:ADU]PARAM  = [F:ANU]CODFLD(I-1)
        Gosub MAJPAR
        [F:ADU]CREUSR = GUSER
        [F:ADU]CREDAT = date$
        If dim([F:ADU]CRETIM)>0 : [F:ADU]CRETIM = time : Endif
        If !TEST
         Write [ADU]
         If fstat
          GOK=0 : Call FSTA("ADU") From GLOCK : Break
         Endif
        Endif
       Else
        Gosub MAJPAR
        [F:ADU]UPDUSR = GUSER
        [F:ADU]UPDDAT = date$
        If dim([F:ADU]UPDTIM)>0 : [F:ADU]UPDTIM = time : Endif
        If !TEST
         Rewrite [ADU]
         If fstat
          GOK=0 : Call FSTA("ADU") From GLOCK : Break
         Endif
        Endif
       Endif
       If !ER & TRACE & MODFLD
        # Nouvelle valeur du paramètre
        Call ECR_TRACE(mess(50,130,1)-[F:ANU]CODFLD(I-1)-":|"-[F:ADU]VALEUR,0) From GESECRAN
       Endif
      Endif
     Endif
   Endcase
   If ER : AERR = 3 : Break : Endif
  Next I
  If AERR or GOK=0
   Goto AB_MAJ
  Elsif GOK=-1
   Goto ROLL_MAJ
  Elsif MODIF
   [F:AUS]UPDUSR = GUSER
   [F:AUS]UPDDAT = date$
   If dim([F:AUS]UPDTIM)>0 : [F:AUS]UPDTIM = time : Endif
   If !TEST
    Rewrite [AUS]
    If fstat
     GOK=0 : Call FSTA("ADU") From GLOCK : Goto AB_MAJ
    Endif
   Endif
  Endif
 Endif
Commit

Filter [AUS]
Return

#-------------------------#
$ROLL_MAJ
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR_MAJ : Endif
Return

$AB_MAJ
Rollback
Return

#-------------------------#
$MAJPAR
Raz ER , MODFLD
Onerrgo ERR_EVAL
CHAINE = evalue(AVALEUR(I))
Case [F:ADP]TYPVAL
 When 3 : # Date
  If len(CHAINE)>=8
   CHAINE = left$(CHAINE,8)
   If CHAINE<>[F:ADU]VALEUR
    [F:ADU]VALEUR = CHAINE : MODIF = 1 : MODFLD = 1
   Endif
  Endif
 When Default
 If CHAINE<>[F:ADU]VALEUR
  [F:ADU]VALEUR = CHAINE : MODIF = 1 : MODFLD = 1
 Endif
Endcase
Onerrgo
Return

#-------------------------#
$ERR_LIRE
AERR = 2
ER = errn
MESSAG = "("+mess(6,123,1)-num$(ER)-errmes$(ER)-errm+")"
Resume

$ERR_SUITE
AERR = 2
Resume

$ERR_EVAL
ER = errn
MESSAG = "("+errp+"("+num$(errl)+")"-mess(6,123,1)-num$(ER)-errmes$(ER)-errm+")"
Resume
