#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management VXRUNI
$ACTION

Case ACTION
  When "DEBUT"         : Gosub DEBUT
  When "OUVRE"         : Gosub OUVRE
  When "OK"            : Gosub OK
Endcase

Return
####################################################################################
$OUVRE

  Global Char    GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([SFTX])  : Local File SFTTXN     [SFTX]  : Endif
  If !clalev([SFTH])  : Local File SFTTXNH    [SFTH]  : Endif
  If !clalev([F:MFG]) : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([F:MFO]) : Local File MFGOPE     [MFO]   : Endif
  If !clalev([F:TMA]) : Local File TABMAT     [TMA]   : Endif
  If !clalev([SCH])   : Local File SCHEDULING [SCH]   : Endif
  If !clalev([MWS])   : Local File WORKSTATIO [MWS]   : Endif

Return
####################################################################################
$DEBUT

Raz [M:VXRUNI]
Affzo [M:VXRUNI]

Return
####################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal  VALEUR

  Local Integer EMPTYP

  #Check if employee exist
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  # Check if employee is active
  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 2
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB
  [M:VXRUNI]EMPLST = EMPLIST(1) #CT-1992

  #Check if an employee or team is on a break or on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Raz [M:VXRUNI]VCRNUM
  Call CLEAR_FIELDS

  #Get the employee default site (if it exists)
  Read [TMA]TMA0=VALEUR
  If !fstat
    # Default employee description and the site if populated
    [M:VXRUNI]EMPDES = [F:TMA]EMPDES
    [M:VXRUNI]FCY=[F:TMA]DEFFCY
    [M:VXRUNI]EMPTYP = [F:TMA]EMPTYP

    Affzo [M:VXRUNI]FCY, EMPDES
  Else    # Employee not found
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  Local Integer  EMP_LIST(1..)

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Local Char PARAMRET(4)
  Raz PARAMRET

  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:VXRUNI]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:VXRUNI]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:VXRUNI]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:VXRUNI]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:VXRUNI]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:VXRUNI]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif

End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Raz [M:VXRUNI]VCRNUM
  Call CLEAR_FIELDS

End
######################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  Call CLEAR_FIELDS

  Read [F:MFG]MFG0=VALEUR
  If !fstat
      #Work order does not exist at the site
      If [F:MFG]MFGFCY<>[M:VXRUNI]FCY : Call ERREUR(mess(51,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO Status cannot be tracked
      If [F:MFG]MFGSTA<>1 : Call ERREUR(mess(19,190,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO is suspended: tracking is not possible
      If [F:MFG]SUSFLG=2  : Call ERREUR(mess(180,190,1)) From GESECRAN :  mkstat = 2 : End : Endif

      #Allocation incomplete. Tracking not possible
      If GMTKALLMGT = [V]CST_AYES & !find([F:MFG]ALLSTA,3,5)  # Alloc status: 3-Complete; 5-Complete/Shortage
          Call ERREUR(mess(18,190,1)) From GESECRAN
          mkstat = 2
          End
      Endif

      #The WO is not printed: tracking not possible
      If [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Call ERREUR(mess(20,190,1)) From GESECRAN : mkstat = 2 : End : Endif
  Else
      #Record does not exist
      Call ERREUR(mess(23,100,1)) From GESECRAN
      mkstat = 2
      End
  Endif

End
######################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR

  Local Integer OPERPREC, ALLOW_IT

  # Verify the operation is running
  Filter [F:SFTX] Where EMPNUM = [M:VXRUNI]EMPLST & SFTTYP = 5 &
&                       VCRNUM = [M:VXRUNI]VCRNUM &
&                       OPENUM = VALEUR &
&                       UTCENDDATTIM = AVOID.ADATTIM #CT-1992
  Look [F:SFTX] First
  Filter [F:SFTX]
  If fstat = 0     # Record found
    GERR=1 : GMESSAGE = mess(83,2422,1)   # Operation already started
    mkstat = 2
    End
  Endif

  # Verify the operation complete
  Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXRUNI]VCRNUM &
&                       [F:SFTX]OPENUM = VALEUR &
&                       [F:SFTX]CLEFLG = [V]CST_AYES
  Look [F:SFTX] First
  Filter [F:SFTX]
  If fstat = 0  # Found
    GERR=1 : GMESSAGE = mess(84,2422,1)   # Operation closed
    mkstat = 2
    End
  Endif

  # Operation is valid?
  If [M:VXRUNI]VCRNUM <> AVOID.ACHAR
    Filter [MFO] Where MFGNUM = [M:VXRUNI]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      #Operation status cannot be closed, excluded, or ordered
      If [F:MFO]OPESTA >= 5 : Call ERREUR(mess(50,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #Work center type cannot be subcontract
      If [F:MFO]EXTWST <> AVOID.ACHAR
        Read [MWS]WST0 = [F:MFO]EXTWST;[M:VXRUNI]FCY
        If !fstat
          If [F:MWS]WSTTYP = 3
            Call ERREUR(mess(52,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      #Labor center type cannot be subcontract
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Read [MWS]WST0=[F:MFO]EXTLAB;[M:VXRUNI]FCY
        If !fstat
          If [F:MWS]WSTTYP=3
            Call ERREUR(mess(55,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      # 53701 - JOBRO
      # See if they can start this based on the type of employee and
      # if someone already started it
      If func SFTLIB.CAN_START_OPERATION([M:VXRUNI]EMPTYP, [M:VXRUNI]EMPNUM, 5, [M:VXRUNI]VCRNUM, VALEUR) = [V]CST_ANO
        GERR=1
        If [M:VXRUNI]EMPTYP = 1
          GMESSAGE = mess(1,7727,1) # Employee cannot join an operation already started by a team
        Else
          GMESSAGE = mess(2,7727,1) # Team cannot join an operation already started
        Endif
        mkstat = 2 : End
      Endif
      # 53701 - JOBRO

      #Invalid if GCTLOPEPRE = 3 and prior operation has not been run.
      If GCTLOPEPRE > 1
        OPERPREC = 0
        # Find the prior operation number
        Filter [SCH] Where MFGNUM = [M:VXRUNI]VCRNUM & NEXOPENUM = VALEUR
        Read [SCH]SCH0 First
        Filter [SCH]
        If !fstat : OPERPREC = [F:SCH]OPENUM : Endif
        If OPERPREC<>0
          # Check if prior marked complete in MFG Operations table
           Filter [MFO] Where MFGNUM = [M:VXRUNI]VCRNUM & OPENUM = OPERPREC
           Read [MFO]MFO0 First
           Filter [MFO]
           If !fstat & [F:MFO]OPESTA < 5
             # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
             Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXRUNI]VCRNUM &
&                                      [F:SFTX]OPENUM = OPERPREC &
&                                      [F:SFTX]CLEFLG = [V]CST_AYES
             Read [F:SFTX]SFT0 First
             Filter [F:SFTX]
             If fstat <> 0
               ALLOW_IT = [V]CST_ANO
               If GCTLOPEPRE=2
                 Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC),ALLOW_IT) From GESECRAN
               Else
                 Call ERREUR(mess(22,190,1)-num$([L]OPERPREC)) From GESECRAN
               Endif
               If ALLOW_IT=[V]CST_ANO : mkstat = 2 : End : Endif
             Endif
           Endif
         Endif
      Endif
    Else
       #Invalid Operation
      Call ERREUR(mess(58,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif

End
####################################################################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR

  #---------------------------------------------------------------
  # Default work center, labor center, # of machines and Time unit
  # from the work order operation table. Also, enable/disable
  # the Labor center field bases on the default value.
  #---------------------------------------------------------------
  If [M:VXRUNI]VCRNUM <> AVOID.ACHAR & VALEUR <> 0
    Filter [MFO] Where MFGNUM = [M:VXRUNI]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat   # Found
      [M:VXRUNI]WCENTER   = [F:MFO]EXTWST     # Primary work center
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Actzo [M:VXRUNI]LCENTER
        [M:VXRUNI]LCENTER   = [F:MFO]EXTLAB   # Labor center
      Else
        Raz [M:VXRUNI]LCENTER
        Grizo [M:VXRUNI]LCENTER
      Endif
#      [M:VXRUNI]NUMMAC    = [F:MFO]EXTWSTNBR  # Expected machines    # TODAN-119090
      [M:VXRUNI]OPEUOM    = [F:MFO]OPEUOM     # Operation unit
    Endif
  Endif

  #---------------------------------------------------------------
  # Get default WC and LC from the SFTTXN table
  #---------------------------------------------------------------
  Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:VXRUNI]FCY

  # Get WC & LC that was selected by SFT when running the operation, if any.
  Call GET_SFT_WC_LC([M:VXRUNI]VCRNUM, VALEUR, [F:MWS]WSTTYP, [F:MFO]EXTWST,
&                    [F:MFO]EXTLAB, [M:VXRUNI]WCENTER, [M:VXRUNI]LCENTER) From SFTLIB

  #---------------------------------------------------------------
  # If someone else has this operation running at same Workstation
  # Default NUMMAC to uncheck.
  #---------------------------------------------------------------

  # TODAN-119090.so
  # Assign work center type
  [M:VXRUNI]WSTTYP = [F:MWS]WSTTYP
  # Machine type...
  If [F:MWS]WSTTYP = 1
      [M:VXRUNI]NUMMAC = [V]CST_AYES  #53701.n - JOBRO
# 53701
#    If func SFTLIB.OPERATION_RUN([M:VXRUNI]VCRNUM, VALEUR, [M:VXRUNI]WCENTER) = [V]CST_ANO
#      [M:VXRUNI]NUMMAC = [V]CST_AYES
#    Else    # Yes, this operation already running...
#      If [M:VXRUNI]LCENTER = AVOID.ACHAR  # If this is Machine only, default to Yes
#        [M:VXRUNI]NUMMAC = [V]CST_AYES
#      Else
#        [M:VXRUNI]NUMMAC = [V]CST_ANO
#      Endif
#    Endif
#    Actzo [M:VXRUNI]NUMMAC
# 53701
  Else    # Labor type
    [M:VXRUNI]NUMMAC = [V]CST_ANO
#    Grizo [M:VXRUNI]NUMMAC         # 53701
  Endif
  # TODAN-119090.eo

  Affzo [M:VXRUNI]WCENTER, LCENTER, NUMMAC, OPEUOM, WSTTYP

End
######################################################################################
# TODAN-119090.so
Subprog C_NUMMAC(VALEUR)
Variable Integer VALEUR

  # Get out if the Machine included is checked.
  # The only time the Machine included is manually checked when the machine/labor operation
  # already been run so the the Machine included option is unchecked when loaded
  If VALEUR = [V]CST_AYES : End : Endif

  # Get out if the work center is not machine type.
  If [M:VXRUNI]WSTTYP <> 1 : End : Endif

  # If it come to here that mean the Machine included option is unchecked and
  # the work center is machine type.

  # Do not allow Machine only operation with the Machines included option is unchecked or
  # or machine/labor operation that has not been run yet
  If [M:VXRUNI]LCENTER = AVOID.ACHAR |
&    func SFTLIB.OPERATION_RUN([M:VXRUNI]VCRNUM, [M:VXRUNI]OPENUM, [M:VXRUNI]WCENTER) = [V]CST_ANO

    Call ERREUR(mess(30,2422,1)) From GESECRAN
    mkstat = 2
    End

  Endif

End
# TODAN-119090.eo
######################################################################################
Subprog C_WCENTER(VALEUR)
Variable Char    VALEUR()

  Read [MWS]WST0 = VALEUR; [M:VXRUNI]FCY
  If fstat
    GERR=1 : GMESSAGE = VALEUR - tolower(mess(196,193,1))      # Work center does not exist at the site.
    mkstat = 2
    End
  Else
    If [F:MWS]WSTTYP <> [M:VXRUNI]WSTTYP
      #CT-1797.sn
      #GERR=1 : GMESSAGE = VALEUR - mess(47,2422,1) : mkstat=2 : End
      Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN
      mkstat = 2
      End
      #CT-1797.en
    Endif
  Endif

End
######################################################################################
Subprog C_LCENTER(VALEUR)
Variable Char    VALEUR()

  If VALEUR = AVOID.ACHAR & [M:VXRUNI]LCENTER <> AVOID.ACHAR
    GERR=1 : GMESSAGE = mess(48,2422,1) : mkstat = 2 : End             # Labor center is required
  Endif

  If VALEUR <> AVOID.ACHAR & [M:VXRUNI]LCENTER <> AVOID.ACHAR
    If VALEUR = [M:VXRUNI]WCENTER : GMESSAGE=mess(26,193,1) : mkstat=2 : End : Endif  # The Labor work center must not be identical to main work center
    Read [MWS]WST0 = VALEUR; [M:VXRUNI]FCY
    If fstat
      GERR=1 : GMESSAGE = VALEUR - tolower(mess(44,2422,1))      # Labor center does not exist at the site.
      mkstat=2
      End
    Else
      If [F:MWS]WSTTYP <> 2
         GERR=1 : GMESSAGE = VALEUR - mess(4,193,1) : mkstat = 2 : End   # ...is not a Labor work center
      Endif
    Endif
  Endif

End
######################################################################################
Subprog CLEAR_FIELDS

  Raz [M:VXRUNI]OPENUM, NUMMAC, WCENTER, LCENTER
  Affzo [M:VXRUNI]OPENUM, NUMMAC, WCENTER, LCENTER

End
######################################################################################
$OK

  Local Char      IVCRNUM(20)(1), IWCENTER(8)(1), ILCENTER(8)(1), IOPEUOM(3)(1)
  Local Integer   I, ICOUNT, IOPENUM(1), INUMMAC(1)
  Local Integer   OPTYPE, SETUP_STOP, RESTART_COUNT
  Local Datetime  STARTTIME
  Local Date      ODATE
  Local Char      OTIME(5)
  Local Integer   YESNO : YESNO = [V]CST_AYES
  Local Char      ERRMSG(125)
  Local Integer   ERRNUM, MY_STATUS
  Local Char      STRYEAR(4), STRMONTH(2), STRDAY(2), STRHOUR(2), STRMIN(2)
  Local Integer   EMPTEAMNUM

  # Initialization
  OPTYPE      = 5 # Run start
  START_COUNT = 0
  ISTOP       = [V]CST_ANO
  SETUP_STOP  = [V]CST_ANO
  STARTTIME   = datetime$

  If !clalev([SFTXNS]) : Local File SFTTXN [SFTXNS] : Endif

# Check if employee is in a team and if he has any team activities running
  Call EMP_TEAM_NUM ([M:VXRUNI]EMPNUM, EMPTEAMNUM) From SFTLIB
  If EMPTEAMNUM <> 0   # Employee is part of the team
    Filter [F:SFTXNS] Where (EMPNUM = [M:VXRUNI]EMPNUM & TEAMNUM = EMPTEAMNUM) &
&                            SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM
    Look [F:SFTXNS] First
    If fstat = 0    # Found open team activities...
      Call OUINON(mess(107,2422,1), YESNO) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
      If YESNO <> [V]CST_AYES    # No
        mkstat = 2
        Return
      Endif

      # Stop open activities...
      Call STOP_OPEN_ACTIVITIES(EMPTEAMNUM, [M:VXRUNI]EMPNUM, ERRNUM, ERRMSG) From SFTLIB
      If ERRNUM
        GERR=1 : GMESSAGE = ERRMSG
        mkstat = 2
        Return
      Endif
    Endif
  Endif

  # Verify if setup is running
  Filter [F:SFTXNS] Where (EMPNUM = [M:VXRUNI]EMPNUM | TEAMNUM = [M:VXRUNI]EMPNUM) & SFTTYP = 4 & VCRNUM = [M:VXRUNI]VCRNUM &
&                         OPENUM = [M:VXRUNI]OPENUM & UTCENDDATTIM = AVOID.ADATTIM
  Look [F:SFTXNS] First #CT-2287
  If fstat = 0 #CT-2287
    # Begin transaction
    Trbegin [F:SFTXNS]
    #Needed for teams
    For [F:SFTXNS]
      If ICOUNT <> 1
        Call OUINON(mess(7,2422,1), YESNO) From GESECRAN    # Selected operation(s) has an active setup.  Do you want to stop the setup to start run activity?
        If YESNO = 2    # Yes
          # Yes, stop the setup
          SETUP_STOP = [V]CST_AYES
        Endif
      Endif

      If SETUP_STOP = [V]CST_AYES
        # Update the Setupstop field for restart operation
        [F:SFTXNS]SETUPSTOP = [V]CST_AYES

        # Update the record
        Rewrite[F:SFTXNS]
      Endif

      ICOUNT = 1
    Next

    If fstat <> 0
      Rollback
      Call ERREUR(mess(68,111,1)) From GESECRAN
      [L]ERRNUM = [V]CST_AERROR
      Return
    Else
      Commit
    Endif
  Endif
  #Check Setup_Stop

  LogicClose File [SFTXNS] #CT-2287

  ICOUNT = 1

  # Add the record to a collection
  IVCRNUM(0)   = [M:VXRUNI]VCRNUM
  IOPENUM(0)   = [M:VXRUNI]OPENUM
  INUMMAC(0)   = [M:VXRUNI]NUMMAC
  IWCENTER(0)  = [M:VXRUNI]WCENTER
  ILCENTER(0)  = [M:VXRUNI]LCENTER
  IOPEUOM(0)   = [M:VXRUNI]OPEUOM

  If ILCENTER(0) <> AVOID.ACHAR or INUMMAC(0) = [V]CST_ANO    # TODAN-119090
#  If ILCENTER(0) <> "" or INUMMAC(0) = 0                     # TODAN-119090
    RESTART_COUNT = 1
  Endif

  # 53701 - JOBRO - determine what the true value for NUMMAC should be
  INUMMAC(0) = func SFTLIB.START_MACHINE([M:VXRUNI]EMPTYP,
&   [M:VXRUNI]EMPNUM,OPTYPE,IVCRNUM(0),IOPENUM(0),IWCENTER(0),ILCENTER(0),
&   [M:VXRUNI]FCY)
  # 53701 - JOBRO

#  # Start the operations
  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  MY_STATUS = fmet SFTTXN.OPERATION_START([M:VXRUNI]EMPNUM, [M:VXRUNI]FCY, [M:VXRUNI]EMPTYP, OPTYPE, STARTTIME, IVCRNUM,
&                                           IOPENUM, INUMMAC, IWCENTER, ILCENTER, IOPEUOM, SETUP_STOP, ICOUNT, RESTART_COUNT)

  # Check if the operation successfully started
  If MY_STATUS >= [V]CST_AERROR
    Call ERREUR(SFTTXN.AERROR.MES) From GESECRAN
    Return
  Endif

  # display confirmation message
  Call TIMESTAMP([M:VXRUNI]FCY, ODATE, OTIME) From SFTLIB
  Call MESSAGE(func AFNC.MES2(mess(77,2422,1), [M:VXRUNI]VCRNUM+" "+num$([M:VXRUNI]OPENUM), left$(OTIME,2) + ":" + right$(OTIME,3))) From GESECRAN

  FreeGroup SFTTXN
  Kill SFTTXN
Return
######################################################################################

