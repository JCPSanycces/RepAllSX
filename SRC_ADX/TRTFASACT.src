# ECRAN : FASACT2
################################################################################
################################################
# ECRAN : FASACT2 - PCG
################################################
########################################
Subprog AV_UPDPLNPCG(VALEUR)
Variable Integer VALEUR
#V5 Local Integer LNCNX

  #V5 Call GET_CNX_FROM_PLN ([M:FASB]PLNPCG(nolign-1), LNCNX) From GLOBIENS
  #If  [M:FASB]PLNPCG(nolign-1) = G301CPT
  #  pcolor = GCOUL(3) : # Bleu
  #Else
  #  pcolor = GCOUL(0) : # Normal
  #Endif
End

########################################
Subprog AS_UPDPLNPCG(VALEUR)
Variable Integer VALEUR
Local Integer N_I
# Témoin d'actualisation d'un plan (PCG)

  If [M:FASA]ACGETRNOA <> 0 and [M:FASB]ORIBASDPR(nolign-1) <> GVML_OBSAI
    VALEUR = 2
    mkstat = 2
    End
  Endif

  If [M:FASA]ACGETRNOA = 0 and [M:FASB]ORIBASDPR(nolign-1) <> GVML_OBSAI
    # Impossible de sélectionner ce plan. l'actualisation PCG est à 0
    GMESSAGE = mess(102,GML_MSGFAS,1)-"("+mess(PLNPCG(nolign-1),GML_NPLAN,1)+")"
    GERR     = 1
    mkstat   = 2 : End
  Endif

  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNPCG") From GLOBIENS
End

########################################
Subprog AM_UPDPLNPCG(VALEUR)
Variable Integer VALEUR

# Témoin d'actualisation d'un plan (PCG)
   #*>>>>>>>>> +V5
   If  VALEUR = G_OUI and [M:FASB]ORIBASDPR(nolign-1) = GVML_OBSAI
      Actzo   [M:FASB]DPRBASPCGN(nolign-1)
   Else
      Diszo   [M:FASB]DPRBASPCGN(nolign-1)
   Endif
  [M:FASB]UPDPLNPCG(nolign-1) = VALEUR
  Call ACTUALISE_UN_PLN_PCG (nolign)
  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNPCG") From GLOBIENS

End
########################################
Subprog AS_CURTYPPCG(VALEUR)
Variable Integer VALEUR
# Type de cours d'un plan (PCG)

  If [M:FASB]UPDPLNPCG(nolign-1) <> G_OUI
    mkstat = 2
  Endif
  If [M:FASB]CURPLNPCG(nolign-1) = GCNXCURCPF
    mkstat = 2
  Endif
End

########################################
Subprog AM_CURTYPPCG(VALEUR)
Variable Integer VALEUR
# Type de cours d'un plan (PCG)

  [M:FASB]RATCURPCG(nolign-1) = 0
  Call ACTUALISE_UN_PLN_PCG(nolign)
  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNPCG") From GLOBIENS
End

########################################
Subprog AS_RATCURPCG(VALEUR)
Variable Decimal VALEUR
# Cours d'un plan (PCG)

  If [M:FASB]UPDPLNPCG(nolign-1) <> G_OUI
    mkstat = 2
  Endif
End

########################################
Subprog AM_RATCURPCG(VALEUR)
Variable Decimal VALEUR
# Cours d'un plan (PCG)

Local Decimal LSVRATCUR, LSVDPRBAS

  LSVRATCUR      = [M:FASB]RATCURPCG(nolign-1)
  LSVDPRBAS      = [M:FASB]DPRBASPCGN(nolign-1)

  [M:FASB]RATCURPCG(nolign-1) = VALEUR
  Call ACTUALISE_UN_PLN_PCG(nolign)
  If (sgn([M:FASB]DPRBASPCG(nolign-1)) + sgn([M:FASB]DPRBASPCGN(nolign-1)) = 0) and (sgn([M:FASB]DPRBASPCG(nolign-1)) <> 0)
    [M:FASB]RATCURPCG(nolign-1)  = LSVRATCUR
    [M:FASB]DPRBASPCGN(nolign-1) = LSVDPRBAS
    # L'actualisation ne peut aboutir à une valorisation d'un plan négative
    GMESSAGE = mess(101,GML_MSGFAS,1)-"("+mess(PLNPCG(nolign-1),GML_NPLAN,1)+")"
    GERR     = 1
    mkstat   = 2
    End
  Else
    Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNPCG") From GLOBIENS
  Endif
End
########################################
Subprog AS_DPRBASPCGN(VALEUR)
Variable Decimal VALEUR

# Nouvelle Base : saisissable si ORIBAS = "montant à saisir"
   If   [M:FASB]UPDPLNPCG(nolign-1)= G_OUI  and [M:FASB]ORIBASDPR(nolign-1) =  GVML_OBSAI
      Actzo  [M:FASB]DPRBASPCGN(nolign-1)
   Else
      Diszo  [M:FASB]DPRBASPCGN(nolign-1)
   Endif

 Affzo  [M:FASB]DPRBASPCGN(nolign-1)

End
######################################################################################
Subprog AM_DPRBASPCGN(VALEUR)
Variable Decimal VALEUR

If ( VALEUR <> [M:FASB]DPRBASPCG(nolign-1)) &  ([M:FASB]ORIBASDPR(nolign-1)  =  GVML_OBSAI)
   [M:FASB]DPRBASPCGN(nolign-1) = VALEUR
   Affzo [M:FASB]DPRBASPCGN(nolign-1)
Endif

End
