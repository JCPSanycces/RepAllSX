Variable Decimal VALEUR
  If ([M:FASA]DEDVATFLGA <> G_OUI or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASA]DEDVATAMtA", 0) <> G_OUI )
    GBOUT1 = ""
  Endif
End

########################################
Subprog B1_DEDVATAMTA(VALEUR)
Variable Decimal VALEUR

Local Char    LMSG(200)
Local Integer LVALEUR

  LVALEUR            = [M:FASA]DEDVATFLGA
  [M:FASA]DEDVATFLGA = G_NON
  Call CALCUL_TVAS_IAS ([M:FASA]IVCVATRATA, [M:FASA]IVCVATFLGA, [M:FASA]DEDVATRATA, G_NON)
  Gosub CALCUL_NOUVELLE_VALEUR
  #--------------------------
  If func TRTFASACT.CONTROLE_TAB_PLN_IAS (LMSG) > 0
    [M:FASA]DEDVATFLGA = LVALEUR
    GMESSAGE = LMSG
    GERR     = 1
    mkstat   = 2
    End
  Endif
  #--------------------------


  VALEUR = [M:FASA]DEDVATAMTA
  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FASA]DEDVATAMTA  With ""
  Affzo [M:FASA]DEDVATAMTA
  mkstat = 99
End

########################################
Subprog C_DEDVATAMTA(VALEUR)
Variable Decimal VALEUR
# Actualisation TVA récupérée (IAS)

  If ([M:FASA]IASETRNOA < 0 and VALEUR > 0) or ([M:FASA]IASETRNOA > 0 and VALEUR < 0)
    # La TVA récupérée IAS est obligatoirement du même signe que la valeur entrée HT saisie
    GMESSAGE = mess(96,GML_MSGFAS,1)  :
    GERR     = 1
    mkstat   = 2
    End
  Endif

  If (sgn([M:FASA]DEDVATAMTI) + sgn([M:FASA]DEDVATAMTI+VALEUR) = 0) and (sgn([M:FASA]DEDVATAMTI) <> 0)
    GMESSAGE = mess(98,GML_MSGFAS,1)  : # L'actualisation ne peut aboutir à une TVA récupérée IAS négative
    GERR     = 1
    mkstat   = 2
    End
  Endif

  If abs(VALEUR) > abs([M:FASA]IVCVATAMTA)
    # La TVA récupérée IAS ne peut être supérieure à la TVA facturée IAS
    GMESSAGE = mess(100,GML_MSGFAS,1)
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AM_DEDVATAMTA(VALEUR)
Variable Decimal VALEUR
# Actualisation TVA récupérée (IAS)

Local Char LMSG(200)

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE = 0
  Else
    [M:FASA]DEDVATFLGA = G_OUI:  Affzo [M:FASA]DEDVATFLGA
    Affzo [M:FASA]DEDVATAMTA
    If ( GBROWS = 0 )
      Chgstl [M:FASA]DEDVATAMTA With "FORCAGE"
    Else
      Chgstl [M:FASA]DEDVATAMTA With "TFORCAGE"
    Endif
  Endif

  [M:FASA]DEDVATAMTA = VALEUR
  Call CALCUL_TVAS_IAS ([M:FASA]IVCVATRATA, [M:FASA]IVCVATFLGA, [M:FASA]DEDVATRATA, [M:FASA]DEDVATFLGA)
  Gosub CALCUL_NOUVELLE_VALEUR
  #--------------------------
  If func TRTFASACT.CONTROLE_TAB_PLN_IAS (LMSG) > 0
    GMESSAGE = LMSG
    GERR     = 1
    mkstat   = 2
    End
  Endif
  #--------------------------
End

