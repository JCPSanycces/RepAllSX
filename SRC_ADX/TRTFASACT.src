Subprog AV_IVCVATAMTA(VALEUR)
Variable Decimal VALEUR
  If ([M:FASA]IVCVATFLGA = G_OUI )
    If ( GBROWS = 0 )
      Chgstl [M:FASA]IVCVATAMTA With "FORCAGE"
    Else
      Chgstl [M:FASA]IVCVATAMTA With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FASA]IVCVATAMTA With ""
  Endif
End

########################################
Subprog AS_IVCVATAMTA(VALEUR)
Variable Decimal VALEUR
  If ([M:FASA]IVCVATFLGA <> G_OUI or func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASA]IVCVATAMTA", 0) <> G_OUI )
    GBOUT1 = ""
  Endif
End

########################################
Subprog B1_IVCVATAMTA(VALEUR)
Variable Decimal VALEUR


Local Char    LMSG(200)
Local Integer LVALEUR

  LVALEUR            = [M:FASA]IVCVATFLGA
  [M:FASA]IVCVATFLGA = G_NON
  Call CALCUL_TVAS_IAS ([M:FASA]IVCVATRATA, G_NON, [M:FASA]DEDVATRATA, [M:FASA]DEDVATFLGA)
  Gosub CALCUL_NOUVELLE_VALEUR
  #--------------------------
  If func TRTFASACT.CONTROLE_TAB_PLN_IAS (LMSG) > 0
    [M:FASA]IVCVATFLGA = LVALEUR
    GMESSAGE           = LMSG
    GERR               = 1
    mkstat             = 2
    End
  Endif
  #--------------------------

  VALEUR = [M:FASA]IVCVATAMTA
  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FASA]IVCVATAMTA  With ""
  Affzo [M:FASA]IVCVATAMTA
  mkstat = 99

End


########################################
Subprog C_IVCVATAMTA(VALEUR)
Variable Decimal VALEUR
# Actualisation TVA facturée (IAS)

  If ([M:FASA]IASETRNOA < 0 and VALEUR > 0) or ([M:FASA]IASETRNOA > 0 and VALEUR < 0)
    # La TVA facturée IAS est obligatoirement du même signe que la valeur entrée HT saisie
    GMESSAGE = mess(92,GML_MSGFAS,1)
    GERR     = 1
    mkstat   = 2
    End
  Endif

  If (sgn([M:FASA]IVCVATAMTI) + sgn([M:FASA]IVCVATAMTI+VALEUR) = 0) and (sgn([M:FASA]IVCVATAMTI) <> 0)
    GMESSAGE = mess(94,GML_MSGFAS,1)  : # L'actualisation ne peut aboutir à une TVA facturée IAS négative
    GERR     = 1
    mkstat   = 2
    End
  Endif
End

########################################
Subprog AM_IVCVATAMTA(VALEUR)
Variable Decimal VALEUR
# Actualisation TVA facturée (IAS)

Local Char LMSG(200)

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") )
    G_DEFORCE = 0
  Else
    [M:FASA]IVCVATFLGA = G_OUI:  Affzo [M:FASA]IVCVATFLGA
    Affzo [M:FASA]IVCVATAMTA
    If ( GBROWS = 0 )
      Chgstl [M:FASA]IVCVATAMTA With "FORCAGE"
    Else
      Chgstl [M:FASA]IVCVATAMTA With "TFORCAGE"
    Endif
  Endif


  [M:FASA]IVCVATAMTA = VALEUR
  Call CALCUL_TVAS_IAS ([M:FASA]IVCVATRATA, [M:FASA]IVCVATFLGA, [M:FASA]DEDVATRATA, [M:FASA]DEDVATFLGA)
  Gosub CALCUL_NOUVELLE_VALEUR
  #--------------------------
  If func TRTFASACT.CONTROLE_TAB_PLN_IAS (LMSG) > 0
    GMESSAGE = LMSG
    GERR     = 1
    mkstat   = 2
    End
  Endif
  #--------------------------
End

