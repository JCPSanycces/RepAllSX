Variable Integer VALEUR

End

########################################
Subprog AS_UPDPLNIAS(VALEUR)
Variable Integer VALEUR
# Témoin d'actualisation d'un plan (IAS)

  If [M:FASA]IASETRNOA <> 0 and [M:FASB]ORIBASIAS(nolign-1) <> GVML_OBSAI
    VALEUR = 2
    mkstat = 2
    End
  Endif

  If [M:FASA]IASETRNOA = 0 and [M:FASB]ORIBASIAS(nolign-1) <> GVML_OBSAI
    # Impossible de sélectionner ce plan. l'actualisation IAS est à 0
    GMESSAGE = mess(103,GML_MSGFAS,1)-"("+mess(PLNIAS(nolign-1),GML_NPLAN,1)+")"
    GERR     = 1
    mkstat   = 2 : End
  Endif

  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNIAS") From GLOBIENS

End

########################################
Subprog AM_UPDPLNIAS(VALEUR)
Variable Integer VALEUR

#FQ-81004
# Témoin d'actualisation d'un plan (IAS)
   #FQ-81004
   If  VALEUR = G_OUI and [M:FASB]ORIBASIAS(nolign-1) = GVML_OBSAI
      Actzo   [M:FASB]DPRBASIASN(nolign-1)
   Else
      Diszo   [M:FASB]DPRBASIASN(nolign-1)
   Endif  #Fq-81004

  [M:FASB]UPDPLNIAS(nolign-1) = VALEUR
  Call ACTUALISE_UN_PLN_IAS(nolign)
  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNIAS") From GLOBIENS

End
########################################
Subprog AS_DPRBASIASN(VALEUR)
Variable Decimal VALEUR

   # Nouvelle Base : saisissable si ORIBASIAS = "montant à saisir"
   If   [M:FASB]UPDPLNIAS(nolign-1)= G_OUI  and [M:FASB]ORIBASIAS(nolign-1) =  GVML_OBSAI
      Actzo  [M:FASB]DPRBASIASN(nolign-1)
   Else
      Diszo  [M:FASB]DPRBASIASN(nolign-1)
   Endif


End
######################################################################################
Subprog AM_DPRBASIASN(VALEUR)
Variable Decimal VALEUR

If ( VALEUR <> [M:FASB]DPRBASIAS(nolign-1)) &  ([M:FASB]ORIBASIAS(nolign-1)  =  GVML_OBSAI)
   [M:FASB]DPRBASIASN(nolign-1) = VALEUR
   Affzo [M:FASB]DPRBASIASN(nolign-1)
Endif

End
########################################
Subprog AS_CURTYPIAS(VALEUR)
Variable Integer VALEUR
# Type de cours d'un plan (IAS)

  If [M:FASB]UPDPLNIAS(nolign-1) <> G_OUI
    mkstat = 2
  Endif
  If [M:FASB]CURPLNIAS(nolign-1) = GCNXCURIAS
    mkstat = 2
  Endif
End

########################################
Subprog AM_CURTYPIAS(VALEUR)
Variable Integer VALEUR
# Type de cours d'un plan (IAS)

  [M:FASB]RATCURIAS(nolign-1) = 0
  Call ACTUALISE_UN_PLN_IAS(nolign)
  Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNIAS") From GLOBIENS
End

########################################
Subprog AS_RATCURIAS(VALEUR)
Variable Decimal VALEUR
# Cours d'un plan (IAS)

  If [M:FASB]UPDPLNIAS(nolign-1) <> G_OUI
    mkstat = 2
  Endif
End

########################################
Subprog AM_RATCURIAS(VALEUR)
Variable Decimal VALEUR
# Cours d'un plan (IAS)

Local Decimal LSVRATCUR, LSVDPRBAS

  LSVRATCUR                   = [M:FASB]RATCURIAS(nolign-1)
  LSVDPRBAS                   = [M:FASB]DPRBASIASN(nolign-1)

  [M:FASB]RATCURIAS(nolign-1) = VALEUR
  Call ACTUALISE_UN_PLN_IAS(nolign)
  If (sgn([M:FASB]DPRBASIAS(nolign-1)) + sgn([M:FASB]DPRBASIASN(nolign-1)) = 0) and (sgn([M:FASB]DPRBASIAS(nolign-1)) <> 0)
    [M:FASB]RATCURIAS(nolign-1)  = LSVRATCUR
    [M:FASB]DPRBASIASN(nolign-1) = LSVDPRBAS
    # L'actualisation ne peut aboutir à une valorisation d'un plan négative
    GMESSAGE = mess(101,GML_MSGFAS,1)-"("+mess(PLNIAS(nolign-1),GML_NPLAN,1)+")"  :
    GERR     = 1
    mkstat   = 2
    End
  Else
    Call ACTION_BLOCK (ACB_AFFZO, "FASACT2", "NBPLNIAS") From GLOBIENS
  Endif
End

######################################################################################

