################################################################################
#    SELECTION DANS LISTE CONCERNANT LES BIENS COMPTABLES
#
#    Modification  :
#
# XXXXX XX.XX.XXXX XXXXXX_XX XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
#
# MDJ   19.10.2016 119214    Traduction des modes d'amortissements non OK
#-------------------------------------------------------------------------------
#    ****  SELECTION DANS LISTE *****
#
#    SELCPYDPP      Plans d'une société
#    SELSETFAS      Biens ensembles
#    SELCMPFAS      Biens pricipaux
#    SELDPM         Mode d'amortissement
#    SELPROJ        Projets d'investissement
#    SELCNXPLN      Plans non encore rattachés à un contexte
#
#-------------------------------------------------------------------------------
#  Appel direct d'une sélection sur table
   Local Char VALEUR(10),PARAM(10)(1..2)
   PARAM(1) = "Z02"
   PARAM(2) = "01"
   Call S_LIS_CHAR(VALEUR,PARAM,"SELCMPFAS","SELLISFAS","") From GACTION
   End


################################################################################
$ACTION
# Infbox num$(ACTION)

  Case ACTION
    When  "SEL_LISTE"       : Gosub SEL_LISTE
    When  "VERF_LISTE"      : Gosub VERF_LISTE
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_LISTE
  Case LISTE
    When "SELCPYDPP"    : Gosub SET_CPYDPP
    When "SELSETFAS"    : Gosub SET_SETFAS
    When "SELCMPFAS"    : Gosub SET_CMPFAS
    When "SELDPM"       : Gosub SET_DPM
    When "SELFASTVS"    : Gosub SET_FASTVS
    When "SELPROJ"      : Gosub SET_PROJ
    When "SELCNXPLN"    : Gosub SET_CNXPLN
    When "SELCPYACT"    : Gosub SET_CPYACT
  Endcase
Return

#-------------------------------------------------------------------------------

$VERF_LISTE
  Case LISTE
    When "SELCPYDPP"    : Gosub VERF_CPYDPP
    When "SELCNXPLN"    : Gosub VERF_CNXPLN
  Endcase
Return


#-------------------------------------------------------------------------------
$SET_FASTVS
  Local Integer NBTEX
  Local Integer N_I

  N_I = 0
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB=GTD_TAX_VS Order By [F:ADI]CODE Asc
  For [ADI]
    If func GLOBIENS.CTRL_CHAR_NUM_0_254([F:ADI]CODE)=G_OUI Then
      N_I    += 1
      TEX(I)  = [F:ADI]CODE
      IDENT2  = [F:ADI]CODE
      Call LECTEXTRA (TEXTE(N_I),"ATABDIV","LNGDES",num$(GTD_TAX_VS),IDENT2) From ATEXTRA
      TEXTE(N_I) = format$("Kbn:4X",TEX(N_I))+ " "+ TEXTE(N_I)
    Endif
    # ------------------
    # Suite de la boucle
  Next
  TIT = mess(131,7770,1) : # Choix Code TVS
  Filter [ADI]
  NBTEX = N_I
Return
##-------------------------------------------------------------------------------
$SET_PROJ
Local Char LNUMTAB
Local Char LSOC
Local Integer NBTEX

If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

LNUMTAB = PARAM(1) : # table diverse
LSOC    = PARAM(2) : # code société

  NBTEX = 0
  TIT = mess(540,7773,1) : # Choix Projets d'investissement

  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB=val(LNUMTAB)  Order By [F:ADI]A1 Asc

  Local Integer NBADI
  NBADI = rowcount([F:ADI])
  If (NBADI > 200 ) Then
    Local Char     TEX(50)(0..NBADI) , TEXTE(80)(0..NBADI)
  Endif

 If LSOC <> ""
  # on sélectionne les projets à partir de l'écran des subventions
  For [ADI]
    If [F:ADI]A1 = LSOC or  [F:ADI]A1 = ""
      NBTEX += 1
      TEX(NBTEX)  = [F:ADI]CODE
      IDENT2      = [F:ADI]CODE
      Call LECTEXTRA (TEXTE(NBTEX),"ATABDIV","LNGDES",num$(LNUMTAB  ),IDENT2) From ATEXTRA
      If [F:ADI]A1 = ""
         TEXTE(NBTEX) = format$("Kbn:5X",TEX(NBTEX))+ "  "+ format$("Kbn:40X",TEXTE(NBTEX))
      Else
      TEXTE(NBTEX) = format$("Kbn:5X",TEX(NBTEX))+ "  "+ format$("Kbn:40X",TEXTE(NBTEX))+ mess(143,7773,1)+ "  " +[F:ADI]A1
    Endif
    Endif
    # ------------------
    # Suite de la boucle
  Next

Else
  I = find(G_OUI,[M:GRTC]CLC(0..[M:GRTC]NBCPY-1))
  If I > 0  # ajout du 18/03/2008
     # on sélectionne les projets à partir de l'écran du traitement de calcul des subventions
     For [ADI]
       If  [F:ADI]A1 <>  ""   and [F:ADI]A1=[M:GRTC]CPY(I-1)
         If find([F:ADI]A1,[M:GRTC]CPY(0..[M:GRTC]NBCPY-1)) <> 0
            NBTEX += 1
            TEX(NBTEX)  = [F:ADI]CODE
            IDENT2      = [F:ADI]CODE
            Call LECTEXTRA (TEXTE(NBTEX),"ATABDIV","LNGDES",num$(LNUMTAB  ),IDENT2) From ATEXTRA
            TEXTE(NBTEX) = format$("Kbn:5X",TEX(NBTEX))+ "  "+ format$("Kbn:40X",TEXTE(NBTEX))+ mess(143,7773,1)+ "  " +[F:ADI]A1
         Endif
       Endif
       # ------------------
       # Suite de la boucle
     Next
  Else
     For [ADI]
       If  [F:ADI]A1 <>  ""
         If find([F:ADI]A1,[M:GRTC]CPY(0..[M:GRTC]NBCPY-1)) <> 0
            NBTEX += 1
            TEX(NBTEX)  = [F:ADI]CODE
            IDENT2      = [F:ADI]CODE
            Call LECTEXTRA (TEXTE(NBTEX),"ATABDIV","LNGDES",num$(LNUMTAB  ),IDENT2) From ATEXTRA
            TEXTE(NBTEX) = format$("Kbn:5X",TEX(NBTEX))+ "  "+ format$("Kbn:40X",TEXTE(NBTEX))+ mess(143,7773,1)+ "  " +[F:ADI]A1
         Endif
       Endif
       # ------------------
       # Suite de la boucle
     Next
  Endif
Endif # ajout du 18/03/2008
Filter [ADI]


Return
#-------------------------------------------------------------------------------
$SET_CPYDPP


  # ******  Liste des plans d'amortissements gérés par une société  *************
  Local Shortint I
  Local Char LCPY

  Local Integer BPLN(1..G301MAX)
  Local Integer NBTEX

  LCPY    = PARAM(1) : # Récupération paramètre
  TIT = mess(26,7773,1) # Liste des Plans d'amortissement

  Raz BPLN

  If clalev([F:CNX]) =0 : Local File CONTEXT    [CNX]  : Endif        : # Contextes
  #------------------------------------
  For [CNX]CNX0 Where [F:CNX]CPY=LCPY
    # Plans du contexte
    For I = 1 To [F:CNX]NBPLC
      BPLN([F:CNX]PLNCAA(I-1)) = 1
    Next I
  Next CNX0

  NBTEX = 0
  For I=1 To 15
    If ( BPLN(I) ) Then
      NBTEX += 1
      TEX(NBTEX)   = num$(I)
      TEXTE(NBTEX) = mess(I,3101,1)
    Endif
  Next I

Return

#-------------------------------------------------------------------------------
$SET_CNXPLN

 # ******  Liste des plans d'amortissements non encore gérés dans un contexte   *************
 Local Integer N_I, I
 Local Char    LCPY

 Local Integer BPLN(1..G301MAX)
 Local Integer NBTEX

  LCPY    = PARAM(1) : # Récupération paramètre

  TIT = mess(26,7773,1) # Liste des Plans d'amortissement


  Raz BPLN

  If clalev([F:CNX]) =0 : Local File CONTEXT    [CNX]  : Endif        : # Contextes
  #------------------------------------
  # Contextes
  For [CNX]CNX0 Where [F:CNX]CPY=LCPY
    # Plans du contexte
    For I = 1 To [F:CNX]NBPLC
      BPLN([F:CNX]PLNCAA(I-1)) = 1
    Next I
  Next CNX0

  NBTEX = 0
  For I=1 To 15
    If not( BPLN(I) ) Then
      NBTEX += 1
      TEX(NBTEX)   = num$(I)
      TEXTE(NBTEX) = mess(I,3101,1)
    Endif
  Next I

Return

#-------------------------------------------------------------------------------
$VERF_CPYDPP

  # Paramètre de l'action associée au bouton "Autres plans" de la fenêtre ODPP
  PARAM(2) = VALEUR

Return
#-------------------------------------------------------------------------------
$VERF_CNXPLN

  # Paramètre de l'action associée au bouton "Autres plans" de la fenêtre ODPP
 # PARAM(2) = VALEUR

Return

#-------------------------------------------------------------------------------
$SET_SETFAS
 # ******  Liste des ensemble potentiel d'une société   *************

  Local Char LCPY
  Local Char LFCY
  LCPY = PARAM(1)
  LFCY = PARAM(2)

  If clalev([F:FA1])=0 : Local File FXDASSETS [FA1] : Endif
  If clalev([F:FA2])=0 : Local File FXDASSETS [FA2] : Endif

  NBTEX = 0
  TIT = mess(7,7773,1) # Liste des biens - Ensembles

  Filter [FA1]
& Where CPY= LCPY and FCY= LFCY and SET <> AASREF and
&       ISSDAT = [0/0/0] and OWNTYP <> 4 and OWNTYP <> 6
& Order By Key CLE= SET

  Local Integer LNBSET
  For [FA1]CLE(1)
   LNBSET+=1
  Next
  If LNBSET>200
   Local Char TEXTE(50)(1..LNBSET+1)
   Local Char TEX(50)(1..LNBSET+1)
  Endif

  For [FA1]CLE(1)
    Read [FA2]FAS0=[F:FA1]SET
    NBTEX += 1
    TEX(NBTEX)   = [F:FA1]SET
    If (fstat > 0 ) Then
    TEXTE(NBTEX) = [F:FA1]SET
    Else
    TEXTE(NBTEX) = [F:FA1]SET -[F:FA2]AASDES1
    Endif
  Next

  Filter [FA1]


Return

#-------------------------------------------------------------------------------
$SET_CMPFAS
 # ******  Liste des biens principaux d'une société   *************


  Local Char LCPY, LFCY, LAASREF, LIASSEC, LIASCGU
  LCPY = PARAM(1):      # Récupération paramètre
  LFCY = PARAM(2)

  If clalev([F:FA1])=0 : Local File FXDASSETS [FA1] : Endif
  If clalev([F:FA2])=0 : Local File FXDASSETS [FA2] : Endif

  NBTEX = 0
  TIT = mess(6,7773,1) # Liste des biens - Principaux

  Filter [FA1]
& Where CPY= LCPY and FCY= LFCY and CMP <> AASREF
&       and CMPSTA = GVML_SBPRINC and
&       ISSDAT = [0/0/0] and OWNTYP <> GVML_TDPREVU and OWNTYP <> GVML_TDMODEL
& Order By Key CLE= CMP

  For [FA1]CLE(1)
    Read [FA2]FAS0=[F:FA1]CMP
    NBTEX += 1
    TEX(NBTEX)   = [F:FA1]CMP
    TEXTE(NBTEX) = [F:FA1]CMP -[F:FA2]AASDES1
  Next

  Filter [FA1]

Return


#-------------------------------------------------------------------------------
$SET_DPM

 # ******  Mode d'amortissement  *************

 # ******  Liste des mode d'amortissements utilisable par le plan d'une société  *************

  Local Shortint I
  Local Char LCPY, LCRY(GLONCRY)
  Local Char LLEG
  Local Integer LDPRPLN


  LCPY    = PARAM(1) : # Récupération paramètre
  LDPRPLN = val(PARAM(2))

  # Infbox "Société = "+ LCPY

  If clalev([F:DPM])=0 : Local File DPRMOD  [DPM] : Endif

  LCRY = func GLOFCYCPY.GET_SOC_PAYS(LCPY)
  LLEG = func GLOFCYCPY.GET_SOC_LEG(LCPY)

  NBTEX = 0

  TIT = mess(9,7773,1) # Liste des modes d'amortissement
  Filter [DPM] Where ( CPY= LCPY or CPY= '') and ( CRY= LCRY or CRY= '') and ( LEG= LLEG or LEG= '') and ENAFLG = G_OUI
&              Order By Key CLE=DPM; CPY Desc
  For [DPM] CLE(1)
    For [DPM] CLE
      If ([F:DPM]APLPLNFLG(LDPRPLN-1) = G_OUI) Then
        NBTEX += 1
        TEX(NBTEX)   = [F:DPM]DPM
        # YYFIN_119214
        If [F:DPM]DPRMODTYP = GVML_TMSTAND
#           TEXTE(NBTEX) = format$("Kbn:15X",TEX(NBTEX))+ " "+ format$("Kbn:40X",TEXTE(NBTEX))-mess([F:DPM]STDDPMNUM,3228,1)
            TEXTE(NBTEX) = left$( [F:DPM]DPM+string$(20,'_'),20)-mess([F:DPM]STDDPMNUM,3228,1)
        Else
#          TEXTE(NBTEX) = [F:DPM]DPM-[F:DPM]DES
          TEXTE(NBTEX) = left$( [F:DPM]DPM+string$(20,'_'),20)-[F:DPM]DES
        Endif #End  YYFIN_119214
      Endif
      Break 1
    Next
  Next
  Filter [DPM]

Return



#-------------------------------------------------------------------------------
$SET_CPYACT

 # ******  Liste des secteurs d'activité gérés par une société  *************
  Local Shortint I
  Local Char LCPY

  LCPY = PARAM(1) : # Récupération paramètre

  NBTEX = 0
  TIT = mess(637, 7773,1) # Liste des secteurs d'activité

  If clalev([F:SEA])=0 : Local File SECACT [SEA] : Endif
  Filter [SEA] Where CPY=LCPY Order By SAC

  Local Integer NBACT
  NBACT = rowcount([F:SEA])
  If (NBACT > 200 ) Then
  Local Char     TEX(50)(0..NBACT) , TEXTE(80)(0..NBACT)
  Endif

  For [SEA]
    NBTEX += 1
    TEX(NBTEX)   = [F:SEA]SAC
    TEXTE(NBTEX) = left$([F:SEA]SAC+string$(20,'.'),20)+[F:SEA]SACDES
  Next
  Filter [SEA]

Return

