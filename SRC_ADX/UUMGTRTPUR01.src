#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTPUR01   Migration des DA                           Module Achats#
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS  # Issue 108760 - 2015-06-12 by SR : Adaptation
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-06-12 by SR : adaptation
   #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif


  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTPUR01") From LECFIC
  Endif

  #Call RAZ_UUMGTRTPUR01(DOSSIER)
  Call MAJ_UUMGTRTPUR01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
Subprog RAZ_UUMGTRTPUR01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPSHM,WNAMPSDM
Call MIGTABNAME (DOSSIER,"PREQUIS",WNAMPSHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PREQUISD",WNAMPSDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPSHM,"fde",DOSSIER),0) < 0
  End
Endif
If filinfo(filpath("FIL",WNAMPSDM,"fde",DOSSIER),0) < 0
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################

Call MIGTABRAZ (DOSSIER,"PREQUIS",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"PREQUISD",ERR) From TRTMIG

# Issue 101446 - 2014-07-11 by MUARN : Prise en compte des versions
If val(VERSION)<GMIGX3VER60
  Local File =DOSSIER+".CPTANALIN"  [CAL]
  Trbegin [CAL]
  Delete [CAL] Where ABRFIC="PSD"
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTPUR01",ERR) From TRTMIG

End

##########################################################################
Subprog MAJ_UUMGTRTPUR01(DOSSIER)
Value Char DOSSIER

# Issue 108760 - 2015-06-12 by SR : adaptation
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1


Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(5)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# Issue 89740 - 2013-05-06 by MAE : Prise en compte des versions
#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMPSHM,WNAMPSDM
Call MIGTABNAME (DOSSIER,"PREQUIS",WNAMPSHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"PREQUISD",WNAMPSDM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMPSHM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMPSDM,"fde",DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",2,ERR) From TRTMIG : #2=En cours
# Issue 108857 - 2015-06-15 by SR : Déplacé avant définition des variables qui utilisent adxwrb
Gosub MIG_OUVRE From TRTMIG

###################

Local Char WTAB_PSH (100) (adxwrb)
Local Char WTAB_PSD (100) (adxwrb)
Local Char WTAB_CAL (120) (adxwrb)
Local Shortint WCPT_PSH,WCPT_PSD,WCPT_CAL

Call ECR_TIME("UUMGTRTPUR01 Purchase Requests Process : Update PREQUIS-D") From DOSSUB
Call ECR_TRACE("UUMGTRTPUR01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#

Call MIGTABINIT (DOSSIER,"PREQUIS",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"PREQUISD",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (DOSSIER,"CPTANALIN",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:PSH])  = 0 : Local File =DOSSIER+".PREQUIS"    [PSH]  : Endif   # Fichier X3 "Vide"
If clalev([F:PSD])  = 0 : Local File =DOSSIER+".PREQUISD"    [PSD]  : Endif   # Fichier X3 "Vide"

If clalev([F:PSHM]) = 0 : Local File =DOSSIER+"."+WNAMPSHM   [PSHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:PSDM]) = 0 : Local File =DOSSIER+"."+WNAMPSDM   [PSDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

Gosub OUVRE_PUR From UUMGTRTPUR00
Gosub OUVRE_PUR01

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTPUR01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [PSDM] With [PSHM]PSH0~=[F:PSDM]PSHNUM, [ITM]ITM0=[F:PSDM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:PSHM]PSHFCY;[F:PSHM]PSHNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTPUR01" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_PSH00
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:PSHM]PSHFCY=TABMIGKEY(1) & [F:PSHM]PSHNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PSHM]PSHFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [PSH],[PSD]
GOK = 1

For [LNK]CLE(2) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTPUR01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

#  version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
    Gosub RAZV6_PSH
  Endif
#  version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
    Gosub RAZV7_PSH
  Endif
  [F:PSH] = [F:PSHM]

  If WSITE<>[F:PSH]PSHFCY
    #----- Alimentation de la société sur l'entête de demande d'achat -----#
      Call RECUP_GLOBAL_CPT(DOSSIER,[F:PSH]PSHFCY) From TRTX3CPT
      WSITE=[F:PSH]PSHFCY
  Endif

  [F:PSH]CPY=GSOCIETE
  Raz WFBULINNBR
  WAPPFLG=1
  ############################
  #-- Boucle sur les lignes
  ############################
  For [LNK]CLE
    #rupture par ligne de DA
    #  version < V6, raz des champs v6
    If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_PSD
    Endif
    #  version < V7, raz des champs v7
    If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_PSD
    Endif
    # Issue 112754 - 2016-12-19 by SR : Services en V12
    #  version < V12, raz des champs v12
    If val(VERSION)<GMIGX3VER120
      Gosub RAZV12_PSD
    Endif
    [F:PSD] = [F:PSDM]

    #Appel proc de migration sur detail
     #  version < V6, traitement v6
    If val(VERSION)<GMIGX3VER60
      Gosub MAJV6_PSD
      If GOK<1 : Break : Endif
    Endif
    #  version < V7, traitement v7
    If val(VERSION)<GMIGX3VER70
      #Gosub MAJV7_PSD
      If GOK<1 : Break : Endif
    Endif
   # Issue 112754 - 2016-12-19 by SR : Services en V12
   #  version < V12, traitement v12
    If val(VERSION)<GMIGX3VER120
       Gosub MAJV12_PSD
       If GOK<1 : Break : Endif
    Endif
# Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#    If NEWMOTEUR
#        Gosub PSD_STK : # pour stocker ref
#        WriteB [PSD]
#    Else
#        Write [PSD]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File PREQUISD, Error ="-num$(fstat),1) From GESECRAN
#          Gosub PSD_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File PREQUISD(PSHNUM/PSDLIN)"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
        Gosub PSD_STK : # pour stocker ref
        WriteB [PSD]
        If fstat
          Call ECR_TRACE("File PREQUISD, Error ="-num$(fstat),1) From GESECRAN
          Gosub PSD_ERRTRA : # pour afficher les ref
          GOK=0
          Break
        Endif
        # End issue 108760
  Next

  If GOK<1 : Break : Endif

  #Appel proc de migration sur entete
  #  version < V6, traitement v6
 If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_PSH
    If GOK<1 : Break : Endif
 Endif

#  version < V7, traitement v7
 If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_PSH
    If GOK<1 : Break : Endif
 Endif

   # --- alimentation des champs et écriture enreg
# Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub PSH_STK : # pour stocker ref
#      WriteB [F:PSH]
#  Else
#      Write [F:PSH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File PREQUIS, Error ="-num$(fstat),1) From GESECRAN
#      Gosub PSH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File PREQUIS(PSHNUM)"-[F:PSH]PSHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif

  Gosub PSH_STK : # pour stocker ref
  WriteB [F:PSH]
  If fstat
     Call ECR_TRACE("File PREQUIS, Error ="-num$(fstat),1) From GESECRAN
     Gosub PSH_ERRTRA : # pour afficher les ref
     GOK=0
     Break
  Endif
  # End issue 108760

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:PSHM]PSHFCY
    TABMIGKEY(2) = [F:PSHM]PSHNUM
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTPUR01",7,ERR) From TRTMIG : #7=Erreur
Else
# Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR & adxwrb>1
    Flush [F:PSH]
    If fstat
        Call ECR_TRACE("File PREQUIS, Error ="-num$(fstat),1) From GESECRAN
        Gosub PSH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:PSD]
    If fstat
        Call ECR_TRACE("File PREQUISD, Error ="-num$(fstat),1) From GESECRAN
        Gosub PSD_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTPUR00: # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
#  Endif
# End issue 108760
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTPUR01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTPUR01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_PSH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [PSH], [PSD]
Close Local File [PSHM], [PSDM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"PREQUIS",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"PREQUISD",ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (DOSSIER,"CPTANALIN",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTPUR01") From TRTMIG
Call ECR_TIME("UUMGTRTPUR01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


################################################
$PSH_STK
Call STK (WTAB_PSH,WCPT_PSH,[F:PSH]PSHNUM) From TRTMIG
Return
$PSD_STK
Call STK (WTAB_PSD,WCPT_PSD,[F:PSD]PSHNUM-'/'-num$([F:PSD]PSDLIN)) From TRTMIG
Return
##############################################################################################
$PSH_ERRTRA
Call ERRTRA (WTAB_PSH,WCPT_PSH,"File PREQUIS(PSHNUM)=") From TRTMIG
Return
$PSD_ERRTRA
Call ERRTRA (WTAB_PSD,WCPT_PSD,"File PREQUIS(PSHNUM/PSDLIN)=") From TRTMIG
Return


##############################################################################################
$OUVRE_PUR01
Local File =DOSSIER+".ATABDIV"    [ADI1]
Local File =DOSSIER+".ATABDIV"    [ADI2]
Local File =DOSSIER+".ATABDIV"    [ADI3]

  Filter [ADI1] Where NUMTAB=1 & LEG="" & N1=1
  Read [ADI1] CODE First
  Filter [ADI1]
  If fstat : Raz [F:ADI1] : Endif

  Filter [ADI2] Where NUMTAB=1 & DEFVAL=2
  Read [ADI2] CODE First
  Filter [ADI2]
  If fstat : Raz [F:ADI2] : Endif

# Déclaration des variables de travail
Local Char WBPS(GLONBPS),WITM(GLONITM)
Local Integer  WFBULINNBR,WAPPFLG
Return
############
$RAZV6_PSH
#nouveaux champs V6
Raz [F:PSH]CPY
Raz [F:PSH]DIE
Raz [F:PSH]FBULINNBR
Return
############
$RAZV7_PSH
Return
############
$RAZV6_PSD
#nouveaux champs V6
Raz [F:PSD]AMTTAXISS
Raz [F:PSD]AMTTAXLIN1
Raz [F:PSD]AMTTAXLIN2
Raz [F:PSD]AMTTAXLIN3
Raz [F:PSD]AMTTAXOTH1
Raz [F:PSD]AMTTAXOTH2
Raz [F:PSD]AMTTAXRCP
Raz [F:PSD]BASTAXLIN1
Raz [F:PSD]CLCAMT1
Raz [F:PSD]CLCAMT2
Raz [F:PSD]CLCAMT3
Raz [F:PSD]CLCAMT4
Raz [F:PSD]CLCAMT5
Raz [F:PSD]CLCAMT6
Raz [F:PSD]CLCAMT7
Raz [F:PSD]CMMPRPFLG
Raz [F:PSD]CMMPRPTAX
Raz [F:PSD]CPY
Raz [F:PSD]DEDTAXISS
Raz [F:PSD]DEDTAXLIN1
Raz [F:PSD]DEDTAXLIN2
Raz [F:PSD]DEDTAXLIN3
Raz [F:PSD]DEDTAXOTH1
Raz [F:PSD]DEDTAXOTH2
Raz [F:PSD]DEDTAXRCP
Raz [F:PSD]LINATIAMT
Raz [F:PSD]TAXISS
Raz [F:PSD]TAXOTH1
Raz [F:PSD]TAXOTH2
Raz [F:PSD]TAXRCP
Raz [F:PSD]VACBPR
Raz [F:PSD]VACTYP
Raz [F:PSD]VAT
Return
############
$RAZV7_PSD
Return
################################################
# Issue 112754 - 2016-12-19 by SR : Services en V12
$RAZV12_PSD
Raz [F:PSD]ITMKND
Return

#########################################################################
$MAJV6_PSH
    #----- Réajustement indicateur signature si nécessaire -----#
    If [F:PSH]APPFLG<2
       [F:PSH]APPFLG=WAPPFLG
    Endif
    #----- Màj nombre de lignes en dépassement budgétaire -----#
    [F:PSH]FBULINNBR=WFBULINNBR
    #----- Alimentation des codes axes pour le multi-référenciels comptabilité -----#
    If dim([F:PSH]DIE)>0 & [F:PSH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:PSH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #-----
Return
#########################################################################
$MAJV7_PSH
Return
#########################################################################
$MAJV6_PSD
     #----- Màj nombre de lignes en dépassement budgétaire -----#
      If [F:PSD]FBUFLG=2  WFBULINNBR+=1 : Endif
     #----- Réajustement indicateur signature si nécessaire -----#
      If [F:PSH]APPFLG<2
        If [F:PSD]LINAPPFLG>1
          WAPPFLG=2
        Endif
      Endif
      #----- Alimentation de la société sur les lignes de demande d'achat -----#
      [F:PSD]CPY=[F:PSH]CPY
      #----- Alimentation du régime de taxe -----#
      If [F:PSD]VACBPR=""
        If [F:PSD]BPSNUM<>""
          Gosub LECT_BPSPSD
          [F:PSD]CHGTYP=[F:BPS]CHGTYP
          [F:PSD]VACBPR=[F:BPS]VACBPR
          Call INIT_REGIME([F:PSD]BPSNUM,[F:PSH]PSHFCY,"F",[F:PSD]VACBPR) From CPTSUB
        Else
          Call PARAML([F:PSH]PSHFCY,"PURVACBPR",WPARAM) From ADOVAL
          If WPARAM<>""
            [F:PSD]VACBPR=WPARAM
          Else
            If [F:ADI2]NUMTAB=1 & [F:ADI2]DEFVAL=2
              [F:PSD]VACBPR=[F:ADI2]CODE
              [F:ADI]=[F:ADI2]
            Else
              If [F:ADI3]NUMTAB<>1 | [F:ADI3]LEG<>GCURLEG | [F:ADI3]N1<>1
                Filter [ADI3] Where NUMTAB=1 & LEG=GCURLEG & N1=1
                Read [ADI3] CODE First
                Filter [ADI3]
              Endif
              If [F:ADI3]NUMTAB=1 & [F:ADI3]LEG=GCURLEG & [F:ADI3]N1=1
                [F:PSD]VACBPR=[F:ADI3]CODE
                [F:ADI]=[F:ADI3]
              Else
                If [F:ADI1]NUMTAB=1 & [F:ADI1]LEG="" & [F:ADI1]N1=1
                  [F:PSD]VACBPR=[F:ADI1]CODE
                  [F:ADI]=[F:ADI1]
                Endif
              Endif
            Endif
          Endif
        Endif
        If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>[F:PSD]VACBPR
          Read [ADI] CODE=1;[F:PSD]VACBPR : If fstat Raz [F:ADI] : Endif
        Endif
        [F:PSD]VACTYP=[F:ADI]N1
      Endif
      #----- Alimentation des codes taxe -----#
      If [F:PSD]VAT(0)=""
        Raz [F:PSD]VAT
        Gosub LECT_ITMPSD
        If [F:ITM]VACITM(0)<>""
          WJTVC=find([F:PSD]VACBPR+'/'+[F:ITM]VACITM(0),WTVCCLE(0..NBTVC))
          If WJTVC>0
            [F:PSD]VAT(0)=WTVCVAT(WJTVC-1)
          Endif
        Endif
        If [F:ITM]VACITM(1)<>""
          WJTVC=find([F:PSD]VACBPR+'/'+[F:ITM]VACITM(1),WTVCCLE(0..NBTVC))
          If WJTVC>0
            [F:PSD]VAT(1)=WTVCVAT(WJTVC-1)
          Endif
        Endif
        If [F:ITM]VACITM(2)<> ""
          WJTVC=find([F:PSD]VACBPR+'/'+[F:ITM]VACITM(2),WTVCCLE(0..NBTVC))
          If WJTVC>0
            [F:PSD]VAT(2)=WTVCVAT(WJTVC-1)
          Endif
        Endif
        #----- Calcul des bases et taxes de la ligne de DA -----#
        ABREV="PSD" : Gosub MAJ_CALTAX_LIG
      Endif
      #----- Mise à jour indicateur de pré-engagement (0=inactif, 1=actif) -----#
      If [F:PSD]CMMPRPNUM<>"" & [F:PSD]LINCLEFLG<>2
        [F:PSD]CMMPRPFLG=1
      Else
        [F:PSD]CMMPRPFLG=0
      Endif
      #-----
      If [F:PSD]CMMPRPTAX=0  [F:PSD]CMMPRPTAX=1 : Endif
      #----- Création lignes comptables analytiques -----#
      Gosub WRITE_CAL
Return
#########################################################################
$MAJV7_PSD
Return
# Issue 112754 - 2016-12-19 by SR : Services en v12
########################################################################
$MAJV12_PSD
[F:PSD]ITMKND = 1
Return
#########################################################################
$LECT_ITMPSD
  If [F:ITM]ITMREF<>[F:PSD]ITMREF
    WITM=[F:PSD]ITMREF
    Gosub LECT_ITM
  Endif
Return

$LECT_ITM
    Read [ITM] ITM0=WITM : If fstat  Raz [F:ITM] : Endif
Return

#########################################################################
$LECT_BPSPSD
  If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
    WBPS=[F:PSD]BPSNUM
    Gosub LECT_BPS
  Endif
Return

$LECT_BPS
    Read [BPS] BPS0=WBPS : If fstat  Raz [F:BPS] : Endif
Return

#########################################################################
$WRITE_CAL
#----- Création lignes comptables analytiques -----#
  Raz [F:CAL]
  [F:CAL]ABRFIC="PSD"
  [F:CAL]VCRNUM=[F:PSD]PSHNUM
  [F:CAL]VCRLIN=[F:PSD]PSDLIN
  [F:CAL]ANALIG=1
  For I=1 To max(GNBCOA,2)
    [F:CAL]LED(I-1)=GLEDSOC(I)
    [F:CAL]COA(I-1)=GCOA(I)
  Next I
  [F:CAL]ACC(0)=[F:PSDM]LINACC
  [F:CAL]ACC(1)=[F:PSDM]LINCNA
  For I=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(I-1)=GDIE(I)
    ##If evalue("dim([F:PSD]CCE"+num$(I)+")")>0
    ##  [F:CAL]CCE(I-1)=evalue("[F:PSD]CCE"+num$(I))
    ##Endif
    Case I
    When 1 : [F:CAL]CCE(I-1)=[F:PSDM]CCE1
    When 2 : [F:CAL]CCE(I-1)=[F:PSDM]CCE2
    When 3 : [F:CAL]CCE(I-1)=[F:PSDM]CCE3
    When 4 : [F:CAL]CCE(I-1)=[F:PSDM]CCE4
    When 5 : [F:CAL]CCE(I-1)=[F:PSDM]CCE5
    When 6 : [F:CAL]CCE(I-1)=[F:PSDM]CCE6
    When 7 : [F:CAL]CCE(I-1)=[F:PSDM]CCE7
    When 8 : [F:CAL]CCE(I-1)=[F:PSDM]CCE8
    When 9 : [F:CAL]CCE(I-1)=[F:PSDM]CCE9
    When Default
    Endcase
  Next I

# Issue 108760 - 2015-06-12 by SR : adaptation : no more NEWMOTEUR
#  If NEWMOTEUR
#      Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
#      WriteB [F:CAL]
#  Else
#      Write [F:CAL]
#  Endif
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#      Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
#    Else
#    Call ECR_TRACE("File CPTANALIN PSD 0"-[F:PSD]PSHNUM-num$([F:PSD]PSDLIN)+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
  Gosub CAL_STK From UUMGTRTPUR00 : # pour stocker ref
  WriteB [F:CAL]
  If fstat
    Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
    Gosub CAL_ERRTRA From UUMGTRTPUR00 : # pour afficher les ref
    GOK=0 : Return
  Endif
# End issue 108760
Return



#########################################################################
# MAJ_CALTAX_LIG   : S/P de calcul des bases et des taxes  MBT 02/10/09 #
#                     de la ligne de DA ou de retour                    #
#########################################################################
$MAJ_CALTAX_LIG
#-----
WCUR   =[F:PSD]CUR
WITMREF=[F:PSD]ITMREF
WBPSNUM=[F:PSD]BPSNUM
WQTYPUU=[F:PSD]QTYPUU
WDOCDAT=[F:PSH]PRQDAT
WVACBPR=[F:PSD]VACBPR
WVACTYP=[F:PSD]VACTYP
WLINAMT=[F:PSD]LINAMT
#----- Calcul des taxes du montant ligne (marchandise) -----#
Call ALICLCAMT2(WITMREF,WQTYPUU,-1,ABREV,WCLCAMT) From TRTX3
#-----
TAXE(1)=[F:PSD]VAT(0)
TAXE(2)=[F:PSD]VAT(1)
TAXE(3)=[F:PSD]VAT(2)
#-----
Raz MONTANT,MONTDED
Call CALTAXE2(GSOCIETE,WDOCDAT,WVACBPR,WCUR,3,TAXE,1,WLINAMT,WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
[F:PSD]BASTAXLIN1= [F:PSD]LINAMT
[F:PSD]CLCAMT1   = WCLCAMT(1)
[F:PSD]AMTTAXLIN1= MONTANT(1)
[F:PSD]DEDTAXLIN1= MONTDED(1)
#-----
If [F:PSD]VAT(1)=""
  [F:PSD]CLCAMT2   =0
  [F:PSD]AMTTAXLIN2=0
  [F:PSD]DEDTAXLIN2=0
Else
  [F:PSD]CLCAMT2= WCLCAMT(2)
  [F:PSD]AMTTAXLIN2= MONTANT(2)
  [F:PSD]DEDTAXLIN2= MONTDED(2)
  # Issue 79948 - 2012-02-07 by VPO : WNBTVT -> NBTVT
  #WJ=find(TAXE(2),WTVTVAT(0..WNBTVT))
  WJ=find(TAXE(2),WTVTVAT(0..NBTVT))
  If WJ>0 & WTVTVATCHA(WJ-1)=2
    [F:PSD]BASTAXLIN1= [F:PSD]BASTAXLIN1+[F:PSD]AMTTAXLIN2
  Endif
Endif
#-----
If [F:PSD]VAT(2)=""
  [F:PSD]CLCAMT3   =0
  [F:PSD]AMTTAXLIN3=0
  [F:PSD]DEDTAXLIN3=0
Else
  [F:PSD]CLCAMT3   = WCLCAMT(3)
  [F:PSD]AMTTAXLIN3= MONTANT(3)
  [F:PSD]DEDTAXLIN3= MONTDED(3)
  # Issue 79948 - 2012-02-07 by VPO : WNBTVT -> NBTVT
  #WJ=find(TAXE(3),WTVTVAT(0..WNBTVT))
  WJ=find(TAXE(3),WTVTVAT(0..NBTVT))
  If WJ>0 & WTVTVATCHA(WJ-1)=2
    [F:PSD]BASTAXLIN1=[F:PSD]BASTAXLIN1+[F:PSD]AMTTAXLIN3
  Endif
Endif
#-----
If WVACTYP<>4
  [F:PSD]LINATIAMT=[F:PSD]LINAMT+[F:PSD]AMTTAXLIN1+[F:PSD]AMTTAXLIN2+[F:PSD]AMTTAXLIN3
Else
  [F:PSD]LINATIAMT=[F:PSD]LINAMT
Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
Gosub LECT_BPSPSD
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>[F:BPS]PLISTC
  Read [PRS] PRS0=2;[F:BPS]PLISTC : If fstat  Raz [F:PRS] : Endif
Endif
#-----
If [F:TCU]CUR<>WCUR
  Read [TCU] TCU0=WCUR
  If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#-----
For I=1 To 9
##  If evalue("dim([F:"+ABREV+"]DISCRGVAL"+num$(I)+")")>0

    If [F:PRS]NPRNOTFLG(I-1)=1 & [F:PRS]INVDTA(I-1)<>0

    Case I
    When 1 : WDISCRGVAL=[F:PSD]DISCRGVAL1
    When 2 : WDISCRGVAL=[F:PSD]DISCRGVAL2
    When 3 : WDISCRGVAL=[F:PSD]DISCRGVAL3
    When 4 : WDISCRGVAL=[F:PSD]DISCRGVAL4
    When 5 : WDISCRGVAL=[F:PSD]DISCRGVAL5
    When 6 : WDISCRGVAL=[F:PSD]DISCRGVAL6
    When 7 : WDISCRGVAL=[F:PSD]DISCRGVAL7
    When 8 : WDISCRGVAL=[F:PSD]DISCRGVAL8
    When 9 : WDISCRGVAL=[F:PSD]DISCRGVAL9
    When Default
    Endcase

      #----- C'est un montant -----#
      If [F:PRS]VALTYP(I-1)=1
        If [F:PRS]CLCRUL(I-1)=1 : # Par unité
          BASE=arr(WDISCRGVAL*[F:PSD]QTYPUU,WRND)
        Else              : # Par ligne
          BASE=WDISCRGVAL
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:PSD]LINAMT*WDISCRGVAL/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If [F:PRS]INCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      WJ=find([F:PRS]INVDTA(I-1),WPFINUM(0..WNBPFI))
      If WJ>0 & WPFIVATRUL(WJ-1)=1
##      If [F:PFI]VATRUL=1
        Raz TAXE : TAXE(1)=[F:PSD]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,WDOCDAT,WVACBPR,WCUR,1,TAXE,1,BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:PSD]BASTAXLIN1=[F:PSD]BASTAXLIN1+BASE
          [F:PSD]AMTTAXLIN1=[F:PSD]AMTTAXLIN1+MONTANT(1)
          [F:PSD]DEDTAXLIN1=[F:PSD]DEDTAXLIN1+MONTDED(1)
        Endif
      Endif
    Endif
##  Endif
Next I
#-----
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
#on charge [F:ADS]
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 108760 - 2015-06-12 by SR : adaptation
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif

Call MAJ_UUMGTRTPUR01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
#on sait qu'on a déjà [F:ADS]
Call MAJ_UUMGTRTPUR01(APPLI)
End

