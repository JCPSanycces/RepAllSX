####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOID
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub INIT_CIV From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub INIT_NAM From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub INIT_OLDNAM From WMC1EMPLOID : Gosub TESTALLSTAT
