Gosub INIT_UPDTIM From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub INIT_EXPNUM From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC3EMPLOID : Gosub TESTALLSTAT
If this.EMPLOIDSA<>null
 [L]ASTATUS = fmet this.EMPLOIDSA.AINIT : Gosub TESTALLSTAT
Endif
If this.EMPLOIDUKI<>null
 [L]ASTATUS = fmet this.EMPLOIDUKI.AINIT : Gosub TESTALLSTAT
Endif
Gosub INIT_UPDDATTIM From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub INIT_CODUE From WMC3EMPLOID : Gosub TESTALLSTAT
