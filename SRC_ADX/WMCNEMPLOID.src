Gosub INIT_FCH_SAT From WMC4EMPLOID : Gosub TESTALLSTAT
Gosub INIT_TCH_AVV From WMC4EMPLOID : Gosub TESTALLSTAT
Gosub INIT_TCH_LAN From WMC4EMPLOID : Gosub TESTALLSTAT
Gosub INIT_TCH_LEG From WMC4EMPLOID : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOID : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOID
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_FCY From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SRV From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CPY From WMC2EMPLOID : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOID
Gosub LNKPRO_REFNUM From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_ADD1 From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_ADD2 From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_ADD3 From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CODPOS From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CTY From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CRY From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_TEL From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_FAX From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_MOB From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CRYBRN From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_NTT From WMC1EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_JNTREFNUM From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_JNTCRY From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_JNTTEL From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_FCY From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_SRV From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CPY From WMC2EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CODACS From WMC2EMPLOID : Gosub TESTALLSTAT
For AINDCLA=1 To 3
 If this.PERCNT(AINDCLA)<>null& find(this.PERCNT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PERCNT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_FCYORI From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_BDFECOCOD From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC3EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC3EMPLOID : Gosub TESTALLSTAT
If this.EMPLOIDSA<>null
 [L]ASTATUS = fmet this.EMPLOIDSA._ALNKPRO : Gosub TESTALLSTAT
Endif
If this.EMPLOIDUKI<>null
 [L]ASTATUS = fmet this.EMPLOIDUKI._ALNKPRO : Gosub TESTALLSTAT
Endif
For AINDCLA=1 To maxtab(this.EMPLOCHD)
 If this.EMPLOCHD(AINDCLA)<>null& find(this.EMPLOCHD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPLOCHD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOJNT)
 If this.EMPLOJNT(AINDCLA)<>null& find(this.EMPLOJNT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPLOJNT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 3
 If this.PASDET(AINDCLA)<>null& find(this.PASDET(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.PASDET(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOEXM)
 If this.EMPLOEXM(AINDCLA)<>null& find(this.EMPLOEXM(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPLOEXM(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLOTRY)
 If this.EMPLOTRY(AINDCLA)<>null& find(this.EMPLOTRY(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPLOTRY(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To maxtab(this.EMPLORIB)
 If this.EMPLORIB(AINDCLA)<>null& find(this.EMPLORIB(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EMPLORIB(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_FCH_SAT From WMC4EMPLOID : Gosub TESTALLSTAT
Gosub LNKPRO_TCH_LEG From WMC4EMPLOID : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



