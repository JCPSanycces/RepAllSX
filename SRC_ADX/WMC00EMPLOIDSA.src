# Supervisor
## CRUD-CLASSE ## EMPLOIDSA
# 2018-11-06 07:05:54 734

Gosub TEST From WMCR_EMPLOIDSA : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,REFNUM)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# EMPLOIDSA : EMPLOIDSA
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet EMPLOIDSA._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = EMPLOIDSA.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(EMPLOIDSA.ACTX.AFOLDER,nomap,"")>0
 Local File EMPLOIDSA [ESA]
 Local File EMPLOIDSA [AAA_]
Else
 Local File =EMPLOIDSA.ACTX.AFOLDER+".EMPLOIDSA" [ESA]
 Local File =EMPLOIDSA.ACTX.AFOLDER+".EMPLOIDSA" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [ESA] With
& [AAA_]ESA0 = REFNUM
& As [LNK_]
Return

############################################################################################
### EMPLOIDSA(WESA)
############################################################################################
Funprog  _MAJSQL_EMPLOIDSA(WESA)
Variable Instance WESA Using C_EMPLOIDSA
Local Integer ASTATUS,A_I,A_J
Default File [F:ESA]
If WESA.ASTALIN=[V]CST_ANEW
 Call INICRE(WESA) From ASYRSUB
 SetInstance [F:ESA] With WESA
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.EMPADR)
   If WESA.EMPADR([L]A_I)<>null & !find(WESA.EMPADR([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.EMPADR([L]A_I).AORDER=[L]A_J
    [F:ESA]ADDPRI([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRI
    [F:ESA]ADDTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTYP
    [F:ESA]ADDSRVTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSRVTYP
    [F:ESA]ADDPOSOTH([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSOTH
    [F:ESA]ADDPOSNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNUM
    [F:ESA]ADDPOSNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNAM
    [F:ESA]ADDPOSAGN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSAGN
    [F:ESA]ADDPOSCOF([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCOF
    [F:ESA]ADDPOSINM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSINM
    [F:ESA]ADDCPX([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCPX
    [F:ESA]ADDSTRNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNUM
    [F:ESA]ADDSTRNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNAM
    [F:ESA]ADDSUB([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSUB
    [F:ESA]ADDTWN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTWN
    [F:ESA]ADDPOSCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCDE
    [F:ESA]ADDCNTCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCNTCDE
    [F:ESA]ADDPRV([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRV
    [F:ESA]ADDCOR([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCOR
    [F:ESA]ADDSTA([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTA
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PASDET)
   If WESA.PASDET([L]A_I)<>null & !find(WESA.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PASDET([L]A_I).AORDER=[L]A_J
    [F:ESA]PASCRY([L]A_J-1) = WESA.PASDET([L]A_I).PASCRY
    [F:ESA]PASNUM([L]A_J-1) = WESA.PASDET([L]A_I).PASNUM
    [F:ESA]PASDTE([L]A_J-1) = WESA.PASDET([L]A_I).PASDTE
    [F:ESA]ESSUIDPAS([L]A_J-1) = WESA.PASDET([L]A_I).ESSUIDPAS
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PERCNT)
   If WESA.PERCNT([L]A_I)<>null & !find(WESA.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ESA]CNTTYP([L]A_J-1) = WESA.PERCNT([L]A_I).CNTTYP
    [F:ESA]ESSUIDCNT([L]A_J-1) = WESA.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 Write [F:ESA]
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WESA.updTick = [F:ESA]updTick
Elsif WESA.ASTALIN=[V]CST_ALL or WESA.ASTALIN=[V]CST_AUPD
 Call INIUPD(WESA) From ASYRSUB
 SetInstance [F:ESA] With WESA
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.EMPADR)
   If WESA.EMPADR([L]A_I)<>null & !find(WESA.EMPADR([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.EMPADR([L]A_I).AORDER=[L]A_J
    [F:ESA]ADDPRI([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRI
    [F:ESA]ADDTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTYP
    [F:ESA]ADDSRVTYP([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSRVTYP
    [F:ESA]ADDPOSOTH([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSOTH
    [F:ESA]ADDPOSNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNUM
    [F:ESA]ADDPOSNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSNAM
    [F:ESA]ADDPOSAGN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSAGN
    [F:ESA]ADDPOSCOF([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCOF
    [F:ESA]ADDPOSINM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSINM
    [F:ESA]ADDCPX([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCPX
    [F:ESA]ADDSTRNUM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNUM
    [F:ESA]ADDSTRNAM([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTRNAM
    [F:ESA]ADDSUB([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSUB
    [F:ESA]ADDTWN([L]A_J-1) = WESA.EMPADR([L]A_I).ADDTWN
    [F:ESA]ADDPOSCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPOSCDE
    [F:ESA]ADDCNTCDE([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCNTCDE
    [F:ESA]ADDPRV([L]A_J-1) = WESA.EMPADR([L]A_I).ADDPRV
    [F:ESA]ADDCOR([L]A_J-1) = WESA.EMPADR([L]A_I).ADDCOR
    [F:ESA]ADDSTA([L]A_J-1) = WESA.EMPADR([L]A_I).ADDSTA
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PASDET)
   If WESA.PASDET([L]A_I)<>null & !find(WESA.PASDET([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PASDET([L]A_I).AORDER=[L]A_J
    [F:ESA]PASCRY([L]A_J-1) = WESA.PASDET([L]A_I).PASCRY
    [F:ESA]PASNUM([L]A_J-1) = WESA.PASDET([L]A_I).PASNUM
    [F:ESA]PASDTE([L]A_J-1) = WESA.PASDET([L]A_I).PASDTE
    [F:ESA]ESSUIDPAS([L]A_J-1) = WESA.PASDET([L]A_I).ESSUIDPAS
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 For [L]A_J=1 to 3
  For [L]A_I=1 To maxtab(WESA.PERCNT)
   If WESA.PERCNT([L]A_I)<>null & !find(WESA.PERCNT([L]A_I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & WESA.PERCNT([L]A_I).AORDER=[L]A_J
    [F:ESA]CNTTYP([L]A_J-1) = WESA.PERCNT([L]A_I).CNTTYP
    [F:ESA]ESSUIDCNT([L]A_J-1) = WESA.PERCNT([L]A_I).ESSUIDCNT
    Break
   Endif
  Next
 Next
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WESA,"EMPLOIDSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:ESA]ESA0 = [F:ESA]REFNUM
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WESA.updTick = [F:ESA]updTick
Elsif WESA.ASTALIN=[V]CST_ADEL
 SetInstance [F:ESA] With WESA
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WESA,"EMPLOIDSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:ESA]ESA0 = [F:ESA]REFNUM
 If fstat
  Call FSTA("ESA",WESA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



