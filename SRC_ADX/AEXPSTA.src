#<AdxTL>@(#)4.0.0.0 $Revision$
Close Local File
Raz GPILOBJ,GNBMASKOUV
GCONSULT = 0
Call OBJET("ALH",GBIDC1,GBIDC2) From GOBJET
End
#--------------------------------------------------------------#
# AEXPSTA  Statistiques : Export au format CSV
#--------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

#---------------------------------------------#
$INIT
Local Char    LISTE(GLONPS2)
Local Char    FICCLI(GDIMFIC) , FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Integer I , J , ER
LISTE   = PARAM(1)
TMP = 1
Gosub SET_INIVAR From ALHE
Return

#---------------------------------------------#
$INIT_DIA
[M:ALE]EXC = 2
Return

#---------------------------------------------#
$EXEC
FICCLI = [L]LISTE+"."+[L]EXT
Call SET_FICNAM(FICCLI,FICSRV,URL) From ORDSYS
Gosub ECR_EXLSRV
Case [M:ALE]EXC
 When 1 : # Enregistrer sur le poste client
  Call COPCLI(FICSRV,FICCLI,ER) From ORDSYS
 When 2 : # Activer Excel
  Call OPEN_HTTP(URL) From ORDSYS
Endcase
Return

$ECR_EXLSRV
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Local Char LFCY(GLONFCY), LDEP(GLONDEP)
 LFCY = GFCY : LDEP = GDEP
Endif
Onerrgo ERREUR
Openo FICSRV,0 Using [ST_]
Iomode adxifs IFS Using [ST_]
Iomode adxirs IRS Using [ST_]
Iomode adxium IUM Using [ST_]
Gosub STAT
Openo Using [ST_]
Onerrgo
Return

#---------------------------------------------#
$STAT
Wrseq '""'; Using [ST_]
Wrseq '"'+[M:STA1]LIBCRIT+'"'; Using [ST_]
For J=1 To [F:PS2]NBRFRM
 Wrseq '"'+evalue("[M:STA1]LIBAMT"+num$(J))+'"'; Using [ST_]
Next J
Wrseq Using [ST_]
For I=0 To [M:STA2]NBLIG-1
 Wrseq '"'+[M:STA2]CLE(I)+'"'; Using [ST_]
 Wrseq '"'+[M:STA2]LIBCLE(I)+'"'; Using [ST_]
 For J=1 To [F:PS2]NBRFRM
  Wrseq evalue("[M:STA2]AMT"+num$(J)+"("+num$(I)+")"); Using [ST_]
 Next J
 Wrseq Using [ST_]
Next I
Return

$ERREUR
ER = errn
Resume
