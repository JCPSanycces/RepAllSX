#<AdxTL>@(#)8.0.0.0 $Revision$ 
GBIDC1 = "BY5"
GBIDC2 = "0"
Raz GPILOBJ,GNBMASKOUV
Close Local Mask
Close Local File
Call OBJET("APN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case GACTION
 When "APNADDMEN" : Gosub ADD_MENU
 When "APNADDFCT" : Gosub ADD_FCT
 When "APNMODMEN" : Gosub MOD_MENU
 When "APNMODFCT" : Gosub MOD_FCT
 When "APNSELMEN" : Gosub SEL_MEN
 When Default     : Gosub GOBJET
Endcase
Return

$ACTIONB
If dim([L]PSUBNB)<=0
 Local Integer PSUBNB
 Call EXISTE_ADX("","","SUBAPNB",PSUBNB) From ORDSYS
Endif
If [L]PSUBNB>0
 Gosub ACTION From SUBAPNB
Endif
Return

$GOBJET
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "APRES_CRE" : Gosub APRES_CRE
 When "APRES_MOD" : Gosub APRES_MOD
 When "ANNULE"    : Gosub ANNULE
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "FILTRE"    : Gosub FILTRE
 When "SETBOUT"   : Gosub SETBOUT
 When "ABANDON"   : Gosub ABANDON
 When "CHANGE"    : Gosub CHANGE

 When "FILGAUCHE" : Gosub FILGAUCHE
 When "DEB_PICK"  : Gosub DEB_PICK
 When "FIN_PICK"  : Gosub FIN_PICK
 When "PICKE"     : Gosub PICKING
 When "DEPICK"    : Gosub DEPICK

Endcase
Return

Funprog MAXLIG
End 5000

$OUVRE
Local Mask APN2 [APN2] , APN3 [APN3]
Default Mask [APN1]
[M]MODULE = 0
Return

$FILTRE
FILTSUP = "[F]MODULE=0"
Return

$CHANGE
Update [AXX] Where CODFIC="APROFIL" & ZONE = "INTPRF" & IDENT2=[L]OCODE & IDENT1=SUPP(0) With IDENT2=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA APROFIL"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$SETBOUT
Filter [AFC]
If [M]CODPRF=GSUPER
 Call VIREBOUT(CHAINE,"AM12") From GOBJET
Endif
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"12") From GOBJET
Endif
Return

$LIENS
Local Integer RANG , OKK
Call TEMPON("L") From GESECRAN
nolign = 0
For [AMU]MENCOD(2) Where CODPRF=[F:APF]CODPRF
 RANG = 0
 For [AMU]MENCOD
  OKK = 1
  Case [F:AMU]TYPFCT
   When 4       : If [F:AMU]CODMEN=""    : OKK = 0 : Endif
   When Default : If [F:AMU]FONCTION=""  : OKK = 0 : Endif
  Endcase
  If OKK
   RANG += 1
   nolign += 1
   [M:APN1] = [F:AMU]
   [M:APN1]RANG(nolign-1) = RANG
   If [F:AMU]LIBMENU<>0
    Call TEXTE([F:AMU]LIBMENU,[M:APN1]INTIT(nolign-1)) From OBJDIV
   Endif
   If [F:AMU]FONCTION="MENU"
    [M:APN1]TYPFCT(nolign-1) = 4
   Endif
  Endif
 Next
Next
Call TEMPOFF From GESECRAN
[M:APN1]NBLIG = nolign
[M:APN1]MENVIS = [M:APN1]MENDEP
Call COMPTE([M:APN1]MENVIS)
Call CHARGE([M:APN1]MENVIS)
Gosub AFFZO_GRAPH
[M]LIGCUR = 1
[M]LIBCUR = [M]MENINT(0)
Call SET_LIGCUR([M]MENCOD(0),[M]MENFCT(0),[M]MENINT(0))
If [M]CODPRF=GSUPER
 Grizo LIBPRF,MENVIS
 Grizo 10
Else
 Actzo
Endif
Return

$SET_IMG
Local Char IMG1(20) , IMG2(20) , IMG3(20)
Local Char ICO1(20) , ICO2(20) , ICO3(20)
IMG1 = "head.gif"
IMG2 = "group.gif"
IMG3 = "element.gif"
ICO1 = "Folder.gif"
ICO2 = "Folder.gif"
ICO3 = "ico.gif"
Return

Subprog COMPTE(MENDEP)
Variable Char MENDEP
$COMPTE2
Local Integer I , J , K , NBPAPA
Local Char    PAPA(10)(1..500)
NBPAPA  = 1
PAPA(1) = MENDEP
K = find(MENDEP,[M]CODMEN(0..[M]NBLIG-1))
I = 1
K = 1
While I<=NBPAPA
 For J=0 To [M]NBLIG-1
  If [M]MENU(J)=PAPA(I)
   If [M]TYPFCT(J)=4
    If !find([M]CODMEN(J),PAPA(1..NBPAPA))
     NBPAPA += 1
     PAPA(NBPAPA) = [M]CODMEN(J)
    Endif
   Endif
   K += 1
  Endif
 Next J
 I += 1
Wend
If K>func MAXLIG
 # Le menu $1$ est trop grand pour être affiché entièrement\Affichage du menu $2$
 Call MESSAGE(func AFNC.MES2(mess(252,139,1),MENDEP,PAPA(2))) From GESECRAN
 MENDEP = PAPA(2)
 Goto COMPTE2
Endif
End

Subprog CHARGE(MENDEP)
Value Char MENDEP
Local Integer I , J , K , NBPAPA
Local Char    PAPA(10)(1..500)
Gosub SET_IMG
Effzo 20
NBPAPA  = 1
PAPA(1) = MENDEP
[M]MENMEN(0) = "MENU"
[M]MENFCT(0) = MENDEP
K = find(MENDEP,[M]CODMEN(0..[M]NBLIG-1))
If K
 [M]MENPERE = [M]MENU(K-1)
Else
 [M]MENPERE = ""
Endif
[M]MENCOD(0) = ""
[M]MENSHO(0) = MENDEP
[M]MENIMG(0) = IMG1
[M]MENICO(0) = ICO1
If MENDEP=[M]MENDEP
 [M]MENINT(0) = mess(13,130,1) : # Menu de départ
Else
 For J=0 To [M]NBLIG-1
  If [M]CODMEN(J)=MENDEP
   [M]MENINT(0) = [M]INTIT(J)
   Break
  Endif
 Next J
Endif
I = 1
K = 1
While I<=NBPAPA
 For J=0 To [M]NBLIG-1
  If [M]MENU(J)=PAPA(I)
   [M]MENMEN(K) = [M]CODMEN(J)
   [M]MENFCT(K) = [M]FONCTION(J)
   [M]MENTYP(K) = [M]TYPFCT(J)
   [M]MENCOD(K) = [M]MENU(J)
   [M]MENSYS(K) = [M]ORDSYS(J)
   [M]MENLIB(K) = [M]LIBMENU(J)
   [M]MENINT(K) = [M]INTIT(J)
#  Bug 86271     --   CC 03/12/2012
   If [M]MENMEN(K)<>"" and [M]MENFCT(K)<>"MENU" and [M]MENLIB(K)>0
    If len([M]MENINT(K))>=len([M]MENMEN(K))
     If right$( [M]MENINT(K),len([M]MENINT(K))-len([M]MENMEN(K)))<>" "+[M]MENMEN(K) : # CCL 100341
      [M]MENINT(K)-=[M]MENMEN(K)
     Endif
    Else
     If instr(1,[M]MENINT(K)," "+[M]MENMEN(K))=0
      [M]MENINT(K)-=[M]MENMEN(K)
     Endif
    Endif
   Endif
#  Bug 86271
   [M]MENRNG(K) = [M]RANG(J)
   [M]MENPTR(K) = J
   If [M]TYPFCT(J)=4
    [M]MENMEN(K) = "MENU"
    [M]MENFCT(K) = [M]CODMEN(J)
    [M]MENIMG(K) = IMG2
    [M]MENICO(K) = ICO2
    If !find([M]CODMEN(J),PAPA(1..NBPAPA))
     NBPAPA += 1
     PAPA(NBPAPA) = [M]CODMEN(J)
    Endif
   Else
    [M]MENIMG(K) = IMG3
    [M]MENICO(K) = ICO3
   Endif
   [M]MENSHO(K) = [M]MENFCT(K)
   K += 1
  Endif
 Next J
 I += 1
Wend
[M]NBMEN  = K
[M]MENVIS = MENDEP
Sorta [M]NBMEN [M]NBMEN Order By [M]MENCOD(indice) , [M]MENRNG(indice)
# Affzo 20   modif CCL
Call C_MENVIS(MENDEP)
MESSA = mess(16,130,1)-[M]CODPRF-":"-[M]LIBPRF : # Profil menu
If [M]MENDEP<>[M]MENVIS
 MESSA -= "("+mess(37,130,1)-[M]MENVIS-[M]LIBVIS+")" : # Zoom à partir de
 [M]IC1 = "010"
 [M]IC2 = "011"
Else
 MESSA -= "("+mess(38,130,1)+")" : # Complet
 [M]IC1 = ""
 [M]IC2 = ""
Endif
#Affzo IC1,IC2,20 : # modif CCL
Chgtbk 20 With MESSA
End

$AFFZO_GRAPH
If [M]MENDEP<>[M]MENVIS
 [M]IC1 = "010"
 [M]IC2 = "011"
Else
 [M]IC1 = ""
 [M]IC2 = ""
Endif
Affzo IC1,IC2,20 : # modif CCL
Return

$RAZCRE
Call INIXSL([M]XSL1,"ANOMV") From INTRUTILA
Affzo [M]XSL1
Return

$VERIF_CRE
$VERIF_MOD
GMESSAGE = ""
OK = 1
For I=0 To [M]NBLIG-1
 If [M]TYPFCT(I)=4
  If !find([M]CODMEN(I),[M]MENU(0..[M]NBLIG-1))
   GMESSAGE -= [M]CODMEN(I)
   OK = 0
  Endif
 Endif
Next I
If !OK
 GMESSAGE = mess(39,130,1)-"\"+GMESSAGE : # Menus sans fonction
 OK = 1 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
 Raz GMESSAGE
 If OK<>2
  OK = 0
 Else
  OK = 1
 Endif
Endif
If OK & [M]MENDEP<>[M]MENVIS
 Call CHARGE([M]MENDEP)
 Affzo
Endif
Return

$INICRE
$INIMOD
[F:APF]MODULE = 0
Return

$CREATION
Call MAJTEXTRA([M]INTPRF,"APROFIL","INTPRF","0",[M]CODPRF) From ATEXTRA
Sorta [M]NBLIG [M]NBLIG Order By [M]MENU(indice),[M]RANG(indice)
For nolign=1 To [M]NBLIG
 If find([M]MENU(nolign-1),[M]MENFCT(0..[M]NBMEN-1))
  [F:AMU] = [M]
  [F:AMU]CODPRF = [M]CODPRF
  [F:AMU]NUMLIG = nolign
  Write [AMU]
  If fstat
   GOK = 0 : Call FSTA("AMU") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Return

$MODIF
Delete [AMU] Where CODPRF=CLECUR1
Gosub CREATION
Return

$ANNULE
Local Integer STAT
Delete [AMU] Where CODPRF=[L]CODE
If fstat=1  : GOK = -1 : Call RSTA("AMU",[L]CODE) From GLOCK : Return : Endif
Call SUPPROF(APPLI,[L]CODE) From INTRUTILB
Delete [AXX] Where CODFIC="APROFIL" & ZONE = "INTPRF"  & IDENT1=SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=-1 : Call RSTA("AXX",[L]CODE) From GLOCK
Endif
Return

$APRES_CRE
$APRES_MOD
Call TEMPON("E") From GESECRAN
Call VALPROFAPP([M]CODPRF,nomap) From VALMENU
Gosub RAZPICK
Call TEMPOFF From GESECRAN
Call  UPDATE_RIGHTSETAG(nomap) From ASYRFNC
Return

$AP_CHANGE
Call SUPPROF(APPLI,[L]OCODE) From INTRUTILB
Call TEMPON("E") From GESECRAN
Call VALPROFAPP([L]NCODE,APPLI) From VALMENU
Call TEMPOFF From GESECRAN
Return

$ABANDON
Gosub RAZPICK
Return

$RAZPICK
For [AFC]CODINT
 Gosub DEPICK From GOBJSUB
Next
Return

##################################################################
## Traitement des modifications
##################################################################
Subprog MAJHIER(CODACT,NLIG,FATHER,RANGNIV,MESSAGE,CODRET)
Value    Char    CODACT
Value    Integer NLIG
Value    Integer FATHER
Value    Integer RANGNIV
Variable Char    MESSAGE
Variable Integer CODRET

Local Integer I , POS1 , POS2 , NEWLIG
Local Char    PAPA(20) , OPAPA(20) , FONC(20) , LIBEL(35)
Local Decimal RANG
If [M]CODPRF=GSUPER
 End
Endif
Case CODACT
 When "M"
  If NLIG=1 : # On ne peut pas déplacer la racine!!
   Call MESSAGE(mess(40,130,1)) From GESECRAN : # Déplacement impossible
   End
  Endif
  If [M]MENMEN(FATHER-1)="MENU" : # C'est un menu
   Case RANGNIV
    When 1        : # Frère après
     PAPA = [M]MENCOD(FATHER-1)
     RANG = [M]MENRNG(FATHER-1) + 0.5
    When -1       : # Frère avant
     PAPA = [M]MENCOD(FATHER-1)
     RANG = [M]MENRNG(FATHER-1) - 0.5
    When Default  : # Fils (en premier, par convention)
     PAPA = [M]MENFCT(FATHER-1)
     RANG = 0.5
   Endcase
  Else : # Ce n'est pas un menu, on met après
   PAPA = [M]MENCOD(FATHER-1)
   RANG = [M]MENRNG(FATHER-1)+0.5
  Endif

  OPAPA  = [M]MENCOD(NLIG-1)
  FONC   = [M]MENFCT(NLIG-1)
  LIBEL  = [M]MENINT(NLIG-1)
  [M]MENCOD(NLIG-1)          = PAPA
  [M]MENU([M]MENPTR(NLIG-1)) = PAPA
  [M]MENRNG(NLIG-1)          = RANG
  POS1   = 0
  POS2   = 0
  NEWLIG = 0
  Sorta [M]NBMEN [M]NBMEN Order By [M]MENCOD(indice) , [M]MENRNG(indice)
  For I=0 To [M]NBMEN-1
   If [M]MENCOD(I)=PAPA
    POS1 += 1
    [M]MENRNG(I)          = POS1
    [M]RANG([M]MENPTR(I)) = POS1
    If [M]MENFCT(I)=FONC
     NEWLIG = I
    Endif
   Elsif [M]MENCOD(I)=OPAPA
    POS2 += 1
    [M]MENRNG(I)          = POS2
    [M]RANG([M]MENPTR(I)) = POS2
   Endif
  Next I
  CODRET = 1
  Affzo 20
  Call SET_LIGCUR(PAPA,FONC,LIBEL)
#  zonsui = "NBMEN("+num$(NEWLIG)+")"
  mkstat = 4

#  Resynchro du tableau invisible     CC  23/04/2012     Bug 61539
  For I=0 To [M]NBLIG
    [M]FONCTION(I)=[M]MENFCT(I+1)
    [M]CODMEN(I)=[M]MENMEN(I+1)
    [M]TYPFCT(I)=[M]MENTYP(I+1)
    [M]MENU(I)=[M]MENCOD(I+1)
    [M]RANG(I)=[M]MENRNG(I+1)
    [M]LIBMENU(I)=[M]MENLIB(I+1)
    [M]INTIT(I)=[M]MENINT(I+1)
    [M]ORDSYS(I)=[M]MENSYS(I+1)
    If [M]TYPFCT(I)=4
      [M]CODMEN(I) = [M]MENFCT(I+1)
      [M]FONCTION(I) = "MENU"
    Endif
    [M]MENPTR(I+1) = I
  Next I


 When "E"
  nolign = NLIG
  Call B4_NBMEN From W1APN1
Endcase
End

##################################################################
## Picking
##################################################################
$FILGAUCHE
If ILIS=1
 FILGAUSUP += '[F:AFC]TYPTRAIT<>2 & [F:AFC]MENU<>""'
Endif
Return

$DEB_PICK
If find([M]CODPRF,GSUPER,"")
 OK = 0
Endif
NBPICK = 0
Return

$FIN_PICK
Call CHARGE([M]MENVIS)
Gosub AFFZO_GRAPH
# zonsui = "NBMEN("+num$([M]LIGCUR-1+NBPICK)+")"
Return

$PICKING
If [M]CODPRF=GSUPER
 OK = 0 : FIN = 1
 Return
Endif
Case currbox
 When "GAU_CHE"+num$(find("AF0",[L]OBJLIS(1..8)))
#  If find([F:AFC]CODINT,[M]FONCTION(0..[M]NBLIG-1))
#   OK = 0 : Return
#  Endif

  ## Controle sur la dimension du tableau

  If [M]NBLIG+1 > dim([M]FONCTION)
   GERR = 1 : GMESSAGE = mess(26,100,1) : # Tableau plein
   OK = 0 : FIN = 1
   Return
  Endif

  ## Ligne d'insertion
  If [M]LIGCUR<1 or [M]LIGCUR>[M]NBMEN
   GERR = 1 : GMESSAGE = mess(71,127,1) : # Sélectionnez un menu de destination
   OK = 0 : FIN =1 : Return
  Endif
  NOL = [M]LIGCUR-1

  ## Ajout dans le tableau principal

  Local Integer POS1 , POS2
  Local Char    PAPA(20)
  Local Decimal RANG
  If [M]MENMEN(NOL)="MENU"
   PAPA = [M]MENFCT(NOL)
   RANG = NBPICK+0.01
  Else
   PAPA = [M]MENCOD(NOL)
   RANG = [M]MENRNG(NOL)+NBPICK+0.01
  Endif
  If PAPA="" : PAPA = [M]MENFCT(NOL) : Endif
  Read [AFC]CODINT =
  K = [M]NBLIG
  [M]NBLIG += 1
  [M]FONCTION(K) = [F:AFC]CODINT
  [M]CODMEN(K)   = ""
  [M]TYPFCT(K)   = 1
  [M]MENU(K)     = PAPA
  [M]RANG(K)     = RANG
  [M]LIBMENU(K)  = [F:AFC]LIBMENU
  Call TEXTE([F:AFC]LIBMENU,[M]INTIT(K)) From OBJDIV
  [M]ORDSYS(K)   = ""
  Sorta [M]NBLIG [M]NBLIG Order By [M]MENU(indice),[M]RANG(indice)
  For I=0 To [M]NBLIG-1
   If [M]MENU(I)=PAPA
    POS1 += 1
    [M]RANG(I) = POS1
   Endif
  Next I
  NBPICK += 1
Endcase
Return

$DEPICK
If [M]CODPRF=GSUPER
 OK = 0
 Return
Endif
NOL = find([F:AFC]CODINT,[M]FONCTION(0..[M]NBLIG-1))
If NOL>0
 Dela NOL-1,1,[M]NBLIG-1 [M]NBLIG
 [M]NBLIG -= 1
Else
 OK = 0
Endif
Return

##################################################################
## Actions fenêtre APN2 - Ajout d'un menu
##################################################################
$ADD_MENU
Case ACTION
 When "DEBUT"
  If clalev([M:APN2])>0
   Raz [M:APN2]
  Endif
  Actzo
Endcase
Return

##################################################################
## Actions fenêtre APN3 - Ajout d'une fonction
##################################################################
$ADD_FCT
Case ACTION
 When "DEBUT"
  If clalev([M:APN3])>0
   Raz [M:APN3]
  Endif
  Actzo
Endcase
Return

##################################################################
## Actions fenêtre APN2 - Modif d'un menu
##################################################################
$MOD_MENU
Case ACTION
 When "OUVRE"
  Local Integer NOL
  NOL = nolign-1
  If [M:APN1]MENMEN(NOL)<>"MENU"
   FIN = 1
  Else
   [M:APN2]MENU    = [M:APN1]FONCTION(NOL)
   [M:APN2]INTIT   = [M:APN1]MENINT(NOL)
   [M:APN2]LIBMENU = [M:APN1]MENLIB(NOL)
  Endif
 When "DEBUT"
  Effzo FCT
  Grizo MENU,FCT
  Affzo
Endcase
Return

##################################################################
## Actions fenêtre APN3 - Modif d'une fonction
##################################################################
$MOD_FCT
Case ACTION
 When "OUVRE"
  Local Integer NOL
  NOL = nolign-1
  If [M:APN1]MENMEN(NOL)="MENU"
   FIN = 1
  Else
   [M:APN3]FONCTION = [M:APN1]MENFCT(NOL)
   [M:APN3]FINTIT   = [M:APN1]MENINT(NOL)
   [M:APN3]LIBMENU  = [M:APN1]MENLIB(NOL)
   [M:APN3]OPTIONS  = [M:APN1]MENMEN(NOL)
   #  Bug 86271     --   CC 03/12/2012
   If [M:APN3]OPTIONS<>"" and [M:APN3]OPTIONS<>"MENU" and [M:APN3]LIBMENU>0
    If len([M:APN3]FINTIT)>=len([M:APN3]OPTIONS)
     If right$([M:APN3]FINTIT,len([M:APN3]FINTIT)-len([M:APN3]OPTIONS))=" "+[M:APN3]OPTIONS : # CCL 100341
      [M:APN3]FINTIT=left$([M:APN3]FINTIT,len([M:APN3]FINTIT)-len([M:APN3]OPTIONS)-1)
     Endif
    Endif
   Endif
   #  Bug 86271
   [M:APN3]ORDSYS   = [M:APN1]MENSYS(NOL)
  Endif
 When "DEBUT"
  Grizo FONCTION
  Affzo
  Call C_FONCTION([M:APN3]FONCTION)

Endcase
Return

##################################################################
## Sélection des options
##################################################################
$SEL_MEN
Case ACTION
 When "SEL_TABLE" : Gosub SEL_OPTIONS
Endcase
Return

$SEL_OPTIONS
Gosub SETNOL
Case [M]FONCTION
 When "AIMP" : # Impression
  OBJET = "ARP"
 When "MENU" : # Menu
  CRITERE = "TYPTRAIT=2"
  OBJET = "AFC"
 When "GESADI","GESADV"
  OBJET = "ADV"
 When "GESAWV"
  OBJET = "AWV"
 When "AMIEXE"
  OBJET = "AMI"
 When "EXEALH"
  OBJET = "ALH"
 When Default
  Local Char SAVACT(20)
  SAVACT = ACTION
  ACTION  = "SEL_CODMENS" : Gosub ACTIONB
  ACTION  = SAVACT
  If OBJET<>"" or NBCOL>0 : Return : Endif
  Call LECTURE("AFC",[M]FONCTION,"") From CONTOBJ
  If [F:AFC]ACTION<>""
   If clalev([F:ACT])=0 : Local File ACTION  [ACT] : Endif
   Read [ACT]ACTION = [F:AFC]ACTION
   Case [F:ACT]TYP
    When 1 : # Objet
     If clalev([F:AWI1])=0 : Local File AWINDOW [AWI1] : Endif
     If clalev([F:ATZ1])=0 : Local File ATABZON [ATZ1] : Endif
     Default File [AWI1]
     TIT(0) = mess(3,126,1) : # Choix transaction
     CRITERE = 'OBJ="'+seg$([F:AFC]VALPAR(0),2,len([F:AFC]VALPAR(0))-1)+'"'+' & TRN <> ""'
     ORDRE   = "TRN"
     START   = "TRN"
     NBCOL = 0
     NBCOL += 1 : COL(NBCOL) = "[F:AWI1]TRN"    : Gosub TEXTE
     NBCOL += 1 : COL(NBCOL) = "[F:AWI1]LIBEL"  : Gosub TEXTE
    When 2 : # Consultation
     If clalev([F:GTC])=0 : Local File GTABACC [GTC] : Endif
     OBJET = "GTC"
     CRITERE = 'CNSCOD="'+[F:ACT]PARAM1+'"'
   Endcase
  Else
   OK = 0
  Endif
Endcase
Return

$TEXTE
Read [ATZ1]CODZONE = "AWINDOW";right$(COL(NBCOL),instr(1,COL(NBCOL),"]")+1)
Call TEXTE([F:ATZ1]NOCOURT,TIT(NBCOL)) From OBJDIV
Return

######################################################################################
## Ecran APN1 - Profils menus
######################################################################################
Subprog C_CODPRF(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]CODPRF
 Actzo
Endif
End

Subprog AS_MENDEP(VALEUR)
Variable Char    VALEUR()
End

Subprog C_MENDEP(VALEUR)
Variable Char VALEUR()
End

Subprog AM_MENDEP(VALEUR)
Variable Char    VALEUR()
Local Integer I , J , K , RG
Local Char    PAPA(10)(1..500)
PAPA(1) = VALEUR
NBPAPA  = 1
K = 0
Effzo 20
I = 1
While I<=NBPAPA
 For [AFC]MENU(1) Where MENU=PAPA(I)
  RG = 0
  For [AFC]MENU
   RG += 1
   [M]FONCTION(K) = [F:AFC]CODEXT
   Case [F:AFC]TYPTRAIT
    When 1 : [M]TYPFCT(K) = [F:AFC]TYP
    When 2 : [M]TYPFCT(K) = 4
   Endcase
   [M]LIBMENU(K) = [F:AFC]LIBMENU
   Call TEXTE([F:AFC]LIBMENU,[M]INTIT(K)) From OBJDIV
   [M]MENU(K) = [F:AFC]MENU
   [M]RANG(K) = RG
   If [F:AFC]TYPTRAIT=2
    [M]CODMEN(K) = [F:AFC]TRAIT
    NBPAPA += 1
    PAPA(NBPAPA) = [F:AFC]TRAIT
   Endif
   K += 1
  Next
 Next
 I += 1
Wend
[M]NBLIG = K
[M]MENDEP = VALEUR
[M]MENVIS = VALEUR
Affzo MENVIS
Sorta [M]NBLIG [M]NBLIG Order By [M]MENU(indice),[M]RANG(indice)
Call CHARGE([M]MENVIS)
Gosub AFFZO_GRAPH
Call SET_LIGCUR([M]MENCOD(0),[M]MENFCT(0),[M]MENINT(0))
End

Subprog CL_IC1(VALEUR)
Variable Char    VALEUR()
Local Integer J , K
Local Char    MENSUI(10)
J = 0
While J<[M]NBLIG
 If [M]CODMEN(J)=[M]MENVIS
  K = J-1
  While K>=0 & [M]MENU(K)=[M]MENU(J)
   If [M]TYPFCT(K)=4
    MENSUI = [M]CODMEN(K)
    Break 2
   Endif
   K -= 1
  Wend
 Endif
 J += 1
Wend
If MENSUI<>""
 [M]MENVIS = MENSUI
 Affzo MENVIS
 Call CHARGE(MENSUI)
 Gosub AFFZO_GRAPH
 Call SET_LIGCUR([M]MENCOD(0),[M]MENFCT(0),[M]MENINT(0))
Endif
End

Subprog CL_IC2(VALEUR)
Variable Char    VALEUR()
Local Integer J , K
Local Char    MENSUI(10)
J = 0
While J<[M]NBLIG
 If [M]CODMEN(J)=[M]MENVIS
  K = J+1
  While K<[M]NBLIG & [M]MENU(K)=[M]MENU(J)
   If [M]TYPFCT(K)=4
    MENSUI = [M]CODMEN(K)
    Break 2
   Endif
   K += 1
  Wend
 Endif
 J += 1
Wend
If MENSUI<>""
 [M]MENVIS = MENSUI
 Affzo MENVIS
 Call CHARGE(MENSUI)
 Gosub AFFZO_GRAPH
 Call SET_LIGCUR([M]MENCOD(0),[M]MENFCT(0),[M]MENINT(0))
Endif
End

Subprog CL_IC3(VALEUR)
Variable Char    VALEUR()
# Descendre
Local Integer LIG , K
Local Decimal RNG
Local Char    FNC(GLONAFC) , MENU(5) , LIB(35)
LIG = [M]LIGCUR
If [M]CODPRF<>GSUPER & LIG>1 & LIG<[M]NBMEN & [M]MENCOD(LIG-1)=[M]MENCOD(LIG)
 MENU             = [M]MENCOD(LIG-1)
 FNC              = [M]MENFCT(LIG-1)
 LIB              = [M]MENINT(LIG-1)
 RNG              = [M]MENRNG(LIG)
 [M]MENRNG(LIG)   = [M]MENRNG(LIG-1)
 [M]MENRNG(LIG-1) = RNG
 [M]RANG([M]MENPTR(LIG-1)) = [M]MENRNG(LIG-1)
 [M]RANG([M]MENPTR(LIG))   = [M]MENRNG(LIG)
 Call CHARGE([M]MENVIS)
 Gosub AFFZO_GRAPH
 Call SET_LIGCUR(MENU,FNC,LIB)
# zonsui = "NBMEN("+num$([M]LIGCUR-1)+")"
# nolign = [M]LIGCUR
 mkstat = 4
Endif
End

Subprog SET_LIGCUR(MENU,FONC,LIBEL)
Value Char MENU
Value Char FONC
Value Char LIBEL
Local Integer K
For K=1 To [M]NBMEN
 If [M]MENCOD(K-1)=MENU & [M]MENFCT(K-1)=FONC & [M]MENINT(K-1)=LIBEL
  [M]LIGCUR = K
  [M]LIBCUR = [M]MENINT(K-1)
  Affzo LIGCUR,LIBCUR
  Break
 Endif
Next K
If  [M]CODPRF<>GSUPER & [M]LIGCUR>1 & [M]LIGCUR<[M]NBMEN & [M]MENCOD([M]LIGCUR-1)=[M]MENCOD([M]LIGCUR)
 [M]IC3 = "029"
Else
 [M]IC3 = ""
Endif
If [M]CODPRF<>GSUPER & [M]LIGCUR>2 & [M]MENCOD([M]LIGCUR-1)=[M]MENCOD([M]LIGCUR-2)
 [M]IC4 = "030"
Else
 [M]IC4 = ""
Endif
Affzo IC3,IC4
End

Subprog CL_IC4(VALEUR)
Variable Char    VALEUR()
# Monter
Local Integer LIG , K
Local Decimal RNG
Local Char    FNC(GLONAFC) , MENU(5) , LIB(35)
LIG = [M]LIGCUR
If [M]CODPRF<>GSUPER & LIG>2 & [M]MENCOD(LIG-1)=[M]MENCOD(LIG-2)
 MENU             = [M]MENCOD(LIG-1)
 FNC              = [M]MENFCT(LIG-1)
 LIB              = [M]MENINT(LIG-1)
 RNG              = [M]MENRNG(LIG-2)
 [M]MENRNG(LIG-2) = [M]MENRNG(LIG-1)
 [M]MENRNG(LIG-1) = RNG
 [M]RANG([M]MENPTR(LIG-1)) = [M]MENRNG(LIG-1)
 [M]RANG([M]MENPTR(LIG-2)) = [M]MENRNG(LIG-2)
 Call CHARGE([M]MENVIS)
 Gosub AFFZO_GRAPH
 Call SET_LIGCUR(MENU,FNC,LIB)
# zonsui = "NBMEN("+num$([M]LIGCUR-1)+")"
 mkstat = 4
Endif
End

Subprog C_MENVIS(VALEUR)
Variable Char    VALEUR()
Local Integer J , K
K = 0
If VALEUR=""
 VALEUR = [M]MENDEP
Endif
If VALEUR=[M]MENDEP
 [M]LIBVIS = mess(13,130,1) : # Menu de départ
Else
 For J=0 To [M]NBLIG-1
  If [M]CODMEN(J)=VALEUR
   [M]LIBVIS = [M]INTIT(J)
   Affzo LIBVIS
   K = 1
   Break
  Endif
 Next J
Endif
If !K & VALEUR<>[M]MENDEP
 GMESSAGE = VALEUR-":"-mess(42,130,1) : # Menu inexistant
 mkstat = 2
Endif
End

Subprog AM_MENVIS(VALEUR)
Variable Char    VALEUR()
Call CHARGE(VALEUR)
Gosub AFFZO_GRAPH
Call SET_LIGCUR([M]MENCOD(0),[M]MENFCT(0),[M]MENINT(0))
End

Subprog S_MENVIS(VALEUR)
Variable Char VALEUR()
Local Integer NBLIB
Local Char    TBMEN(10)(500) , TBLIB(50)(500) , TIT(50)
Local Integer I , J , K
K = 0
For J=0 To [M]NBLIG-1
 If [M]FONCTION(J)="MENU" & !find([M]CODMEN(J),TBMEN(1..K))
  K += 1
  TBMEN(K) = [M]CODMEN(J)
  TBLIB(K) = [M]CODMEN(J)-":"-[M]INTIT(J)
 Endif
Next J
If !find([M]MENDEP,TBMEN(1..K))
 K += 1
 TBMEN(K) = [M]MENDEP
 TBLIB(K) = [M]MENDEP-":"-mess(13,130,1) : # Menu de départ
Endif
Sorta K+1 TBMEN , TBLIB Order By TBMEN(indice)
I = find(VALEUR,TBMEN(1..K))
Call SAITEX(K,TBLIB,I,TIT) From GESECRAN
If I
 VALEUR = TBMEN(I)
Endif
End

Subprog D_MODULE(VALEUR)
Onerrgo RIEN
Variable Decimal VALEUR
VALEUR = 0
End

$RIEN
Resume

Subprog AS_NBMEN
If nolign>dim([M]MENFCT) : End : Endif
Call SET_LIGCUR([M]MENCOD(nolign-1),[M]MENFCT(nolign-1),[M]MENINT(nolign-1))
End

Subprog IB_NBMEN
Gosub SETNOL
If [M]MENMEN(NOL)<>"MENU"
 GBOUT1 = ""
 GBOUT2 = ""
 GBOUT4 = ""
 GBOUT6 = ""
Else
 GBOUT5 = ""
Endif
If [M]CODPRF=GSUPER
 GBOUT1 = ""
 GBOUT2 = ""
 GBOUT3 = ""
 GBOUT4 = ""
 GBOUT5 = ""
Endif
End

# Ajouter un menu
Subprog B1_NBMEN
Gosub SETNOL
Local Integer I , J , K , RG , NBPAPA
Local Char    PAPA(10)(1..500)
If GSTATUT=GSTAOK
 K = [M]NBLIG
 [M]NBLIG += 1
 [M]FONCTION(K) = "MENU"
 [M]CODMEN(K)   = [M:APN2]MENU
 [M]TYPFCT(K)   = 4
 [M]MENU(K)     = [M]MENFCT(NOL)
 Call RANG([M]MENFCT(NOL),[M]RANG(K))
 [M]LIBMENU(K)  = [M:APN2]LIBMENU
 [M]INTIT(K)    = [M:APN2]INTIT
 If [M:APN2]FCT=2
  NBPAPA = 1
  PAPA(1) = [M:APN2]MENU
  I = 1
  While I<=NBPAPA
   RG = 0
   For [AFC]MENU Where MENU=PAPA(I)
    K = [M]NBLIG
    Case [F:AFC]TYPTRAIT
     When 1
      RG += 1
      [M]NBLIG += 1
      [M]FONCTION(K) = [F:AFC]CODINT
      [M]CODMEN(K)   = ""
      [M]TYPFCT(K)   = 1
      [M]MENU(K)     = PAPA(I)
      [M]RANG(K)     = RG
      [M]LIBMENU(K)  = [F:AFC]LIBMENU
      Call TEXTE([F:AFC]LIBMENU,[M]INTIT(K)) From OBJDIV
      [M]ORDSYS(K)   = ""
     When 2
      If !find([F:AFC]TRAIT,[M]CODMEN(0..[M]NBLIG-1))
       RG += 1
       [M]NBLIG += 1
       [M]FONCTION(K) = "MENU"
       [M]CODMEN(K)   = [F:AFC]TRAIT
       [M]TYPFCT(K)   = 4
       [M]MENU(K)     = PAPA(I)
       [M]RANG(K)     = RG
       [M]LIBMENU(K)  = [F:AFC]LIBMENU
       Call TEXTE([F:AFC]LIBMENU,[M]INTIT(K)) From OBJDIV
       NBPAPA += 1
       PAPA(NBPAPA) = [F:AFC]TRAIT
      Endif
    Endcase
   Next
   I += 1
  Wend
 Endif
 Call CHARGE([M]MENVIS)
 Gosub AFFZO_GRAPH
 mkstat = 4
Endif
End

Subprog RANG(MENU,RG)
Value    Char    MENU
Variable Decimal RG
Local Integer I
RG = 0
For I=0 To [M]NBMEN-1
 If [M]MENCOD(I)=MENU
  RG = max(RG,[M]MENRNG(I))
 Endif
Next I
RG += 1
End

# Ajouter une fonction
Subprog B2_NBMEN
Gosub SETNOL
Local Integer I , J , K
If GSTATUT=GSTAOK
 K = [M]NBLIG
 [M]NBLIG += 1
 [M]FONCTION(K) = [M:APN3]FONCTION
 [M]CODMEN(K)   = [M:APN3]OPTIONS
 [M]TYPFCT(K)   = 1
 [M]MENU(K)     = [M]MENFCT(NOL)
 Call RANG([M]MENFCT(NOL),[M]RANG(K))
 [M]LIBMENU(K)  = [M:APN3]LIBMENU
 [M]INTIT(K)    = [M:APN3]FINTIT

 #  Bug 86271     --   CC 03/12/2012
 If [M]CODMEN(K)<>"" and [M]CODMEN(K)<>"MENU" and [M]LIBMENU(K)>0 : [M]INTIT(K)-=[M]CODMEN(K) : Endif
 #  Bug 86271
 [M]ORDSYS(K)   = [M:APN3]ORDSYS
 Call CHARGE([M]MENVIS)
 Gosub AFFZO_GRAPH
 mkstat = 4
Endif
End

# Supprimer
Subprog B3_NBMEN
Local Integer I , J , K , MENU , NBPAPA , RG
Local Char    PAPA(10)(1..500) , MENPERE(10)
Gosub SETNOL
If NOL=0 : End : Endif
K = [M]MENPTR(NOL)
If [M]MENMEN(NOL)="MENU"
 NBPAPA  = 1
 PAPA(1) = [M]MENFCT(NOL)
 MENU    = 1
Else
 MENU    = 0
Endif
MENPERE = [M]MENCOD(NOL)
Dela K,1 [M]NBLIG
[M]NBLIG -= 1
RG = 0
For I=0 To [M]NBLIG-1
 If [M]MENU(I)=MENPERE
  RG += 1
  [M]RANG(I) = RG
 Endif
Next I
If MENU
 I = 1
 While I<=NBPAPA
  J = 0
  While J<=[M]NBLIG
   If [M]MENU(J)=PAPA(I)
    If [M]TYPFCT(J)=4 & !find([M]CODMEN(J),PAPA(1..NBPAPA))
     NBPAPA += 1
     PAPA(NBPAPA) = [M]CODMEN(J)
    Endif
    Dela J,1 [M]NBLIG
    [M]NBLIG -= 1
   Else
    J += 1
   Endif
  Wend
  I += 1
 Wend
Endif
Call CHARGE([M]MENVIS)
Gosub AFFZO_GRAPH
mkstat = 4
End

# Modifier
Subprog B4_NBMEN
Gosub SETNOL
Local Integer K
If GSTATUT=GSTAOK
 K = [M]MENPTR(NOL)
 [M]LIBMENU(K)  = [M:APN2]LIBMENU
 [M]INTIT(K)    = [M:APN2]INTIT
 [M]MENLIB(NOL) = [M:APN2]LIBMENU
 [M]MENINT(NOL) = [M:APN2]INTIT
 Affzo 20
 mkstat = 4
Endif
End


Subprog B5_NBMEN
Gosub SETNOL
Local Integer K
If GSTATUT=GSTAOK
 K = [M]MENPTR(NOL)
 [M]LIBMENU(K)  = [M:APN3]LIBMENU
 [M]INTIT(K)    = [M:APN3]FINTIT
 [M]ORDSYS(K)   = [M:APN3]ORDSYS
 [M]CODMEN(K)   = [M:APN3]OPTIONS
 [M]MENLIB(NOL) = [M:APN3]LIBMENU
 [M]MENINT(NOL) = [M:APN3]FINTIT
 [M]MENSYS(NOL) = [M:APN3]ORDSYS
 [M]MENMEN(NOL) = [M:APN3]OPTIONS
#  Bug 86271     --   CC 03/12/2012
 If [M]CODMEN(K)<>"" and [M]CODMEN(K)<>"MENU" and [M]MENLIB(NOL)>0 : # CCL 100341
  [M]INTIT(K)-=[M]CODMEN(K)
  [M]MENINT(NOL)-=[M]CODMEN(K)
 Endif
#  Bug 86271
 Affzo 20
 mkstat = 4
Endif
End

# Zoom
Subprog B6_NBMEN
Gosub SETNOL
If NOL=0
 If [M]MENPERE<>""
  [M]MENVIS = [M]MENPERE
 Endif
Else
 [M]MENVIS = [M]MENFCT(NOL)
Endif
Affzo MENVIS
Call CHARGE([M]MENVIS)
Gosub AFFZO_GRAPH
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
## Ecran APN2 - Ajouter un menu
######################################################################################
Subprog C_MENU(VALEUR)
Variable Char    VALEUR()
Local Integer OK , J
OK = 1
For J=0 To [M]NBLIG-1
 If [M]CODMEN(J)=VALEUR
  OK = 0 : Break
 Endif
Next J
If !OK
 GMESSAGE = VALEUR-":"-mess(9,130,1) : # Menu déjà utilisé
 mkstat = 2
Endif
End

Subprog AM_MENU(VALEUR)
Variable Char    VALEUR()
Filter [AFC] Where TRAIT=[L]VALEUR
Read [AFC] First
Filter [AFC]
If fstat<=2
 Call TEXTE([F:AFC]LIBMENU,[M]INTIT) From OBJDIV
Endif
End

Subprog C_INTIT(VALEUR)
Variable Char    VALEUR()
Read [ATX]TEXTE = GLANGUE;VALEUR
If !fstat
 [M]LIBMENU = [F:ATX]NUMERO
Else
 [M]LIBMENU = 0
Endif
End

######################################################################################
## Ecran APN3 - Ajouter une fonction
######################################################################################
Subprog C_FONCTION(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AFC",VALEUR,"") From CONTOBJ
If [F:AFC]ACTION="EXESYS"
 Actzo ORDSYS
Else
 Effzo ORDSYS
 Grizo ORDSYS
Endif
If [F:AFC]AIDE<>0
 Local Char FORMAT(10)
 Call TEXTE([F:AFC]AIDE,[M]INFO) From OBJDIV
 Actzo OPTIONS
 Affzo INFO
 Case VALEUR
  When "AIMP"            : FORMAT = num$(GLONARP)+"c"
  When "ADPVAL"          : FORMAT = num$(GLONADP)+"d"
  When "SYSTEME"         : FORMAT = "10x"
  When "GIMPOBJ"         : FORMAT = num$(GLONAOE)+"x"
  When "GEXPOBJ"         : FORMAT = num$(GLONAOE)+"x"
  When "GESADI","FONADI" : FORMAT = "30X" : # Exemple 10-100,150
  When Default           : FORMAT = "10B"
 Endcase
 Chgfmt OPTIONS With "K:"+FORMAT
Else
 Effzo INFO,OPTIONS
 Grizo OPTIONS
Endif
End

Subprog AM_FONCTION(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AFC",VALEUR,"") From CONTOBJ
Call TEXTE([F:AFC]LIBMENU,[M]FINTIT) From OBJDIV
End

Subprog C_FINTIT(VALEUR)
Variable Char    VALEUR()
Read [ATX]TEXTE = GLANGUE;VALEUR
If !fstat
 [M]LIBMENU = [F:ATX]NUMERO
Else
 [M]LIBMENU = 0
Endif
End

Subprog C_OPTIONS(VALEUR)
Variable Char    VALEUR()
Case [M]FONCTION
 When "AIMP" : # Impression
  Call CONTROLE("ARP","!",VALEUR,"",mkstat) From CONTOBJ
 When "MENU" : # Menu
  Call CONTROLE("AFC","M!",VALEUR,"",mkstat) From CONTOBJ
 When "GESADI","GESADV"
  Call CONTROLE("ADV","!",VALEUR,"",mkstat) From CONTOBJ
 When "GESAWV"
  Call CONTROLE("AWV","!",VALEUR,"",mkstat) From CONTOBJ
 When "AMIEXE"
  Call CONTROLE("AMI","!",VALEUR,"",mkstat) From CONTOBJ
 When "EXEALH"
  Call CONTROLE("ALH","!",VALEUR,"",mkstat) From CONTOBJ
 When Default
  Local Char    CRITERE(250) , ACTION(20)
  Local Integer NB , TROUVE , OK
  OK = 1
  If VALEUR<>""
   Call LECTURE("AFC",[M]FONCTION,"") From CONTOBJ
   If [F:AFC]ACTION<>""
    If clalev([F:ACT])=0 : Local File ACTION  [ACT] : Endif
    Read [ACT]ACTION = [F:AFC]ACTION
    Case [F:ACT]TYP
     When 1 : # Objet
      If clalev([F:AWI1])=0 : Local File AWINDOW [AWI1] : Endif
      CRITERE = 'OBJ="'+seg$([F:AFC]VALPAR(0),2,len([F:AFC]VALPAR(0))-1)+'"'+' & TRN <> ""'
      Raz NB , TROUVE
      For [AWI1]AWI2 Where evalue(CRITERE)
       If [F:AWI1]TRN=VALEUR
        TROUVE = 1
       Endif
       NB += 1
      Next AWI1
      If !TROUVE & NB>=1
       OK = 0
      Endif
     When 2 : # Consultation
      If clalev([F:GTC])=0 : Local File GTABACC [GTC] : Endif
      CRITERE = 'CNSCOD="'+[F:ACT]PARAM1+'"'
      Raz TROUVE
      For [GTC] Where evalue(CRITERE)
       If [F:GTC]COD=VALEUR
        TROUVE = 1 : Break
       Endif
      Next GTC
      If !TROUVE
       OK = 0
      Endif
    Endcase
   Endif
  Endif
  If !OK
   GMESSAGE = VALEUR-":"-mess(84,141,1) : # Code inexistant
   mkstat = 2
  Else
   ACTION  = "C_OPTIONS" : Gosub ACTIONB
  Endif
Endcase
End

######################################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File APROFIL  [APF1]
 Local File AMENUSER [AMU1]
 Local File ATEXTRA  [AXX1]
 Local File ATEXTE     [ATX1]
Else
 Local File =[M]DOSORG+".APROFIL"  [APF1]
 Local File =[M]DOSORG+".AMENUSER" [AMU1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
 Local File =[M]DOSORG+".ATEXTE"     [ATX1]
Endif
If [M]DOSDES=nomap
 Local File APROFIL  [APF2]
 Local File AMENUSER [AMU2]
 Local File ATEXTRA  [AXX2]
 Local File ATEXTE     [ATX2]
Else
 Local File =[M]DOSDES+".APROFIL"  [APF2]
 Local File =[M]DOSDES+".AMENUSER" [AMU2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
 Local File =[M]DOSDES+".ATEXTE"     [ATX2]
Endif
# Issue 85849 - 2012-11-16 by VPO
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [APF1], [AMU1], [APF2], [AMU2], [AXX1], [AXX2], [ATX1], [ATX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [APF2], [AMU2]
 # Issue 85849 - 2012-11-16 by VPO
 Delete [AXX2] Where CODFIC="APROFIL" & ZONE="INTPRF" & IDENT1="0" & IDENT2=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [APF2] Where CODPRF=TABLE & MODULE=0
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".APROFIL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("APF2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AMU2] Where CODPRF=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".AMENUSER" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMU2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [APF1]CODPRF Where CODPRF=TABLE & MODULE=0
  [F:APF2] = [F:APF1]
  # Issue 85849 - 2012-11-16 by VPO
  Call COPTEXTRA("APROFIL","INTPRF","0",TABLE) From ATEXTRA
  If dim([F:APF2]UPDUSR)>0 : [F:APF2]UPDUSR = GUSER : Endif
  If dim([F:APF2]UPDDAT)>0 : [F:APF2]UPDDAT = date$ : Endif
  If dim([F:APF2]UPDTIM)>0 : [F:APF2]UPDTIM = time  : Endif
  Write [APF2]
  If fstat
   GOK=0 : Call FSTA("APF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [AMU1]CODMEN Where CODPRF=TABLE
  [F:AMU2] = [F:AMU1]
  # Issue 85849 - 2012-11-16 by VPO
  Call COPTEXTE([F:AMU1]LIBMENU,[F:AMU2]LIBMENU) From OBJDIV
  Write [AMU2]
  If fstat
   GOK=0 : Call FSTA("AMU2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
