#JASMI - 2015-03-10 - BUG: 106880 - START
#$ACTION
#Case ACTION
#  When "ADD_BPA"    : Gosub ADD_BPA
#  When "REMP_ADRB"  : Gosub REMP_ADRB
#Endcase
#Return
$ACTION
Case ACTION
  When "ADD_BPA"      : Gosub ADD_BPA
  When "ADD_CNT"      : Gosub ADD_CNT
  When "REMP_ADRB"    : Gosub REMP_ADRB
  When "REMP_CNTB"    : Gosub REMP_CNTB

Endcase
Return
#JASMI - 2015-03-10 - BUG: 106880 - END

#----------------------------------#

$OUVRE
#JASMI - 2014/04/17 - START
    If clalev([F:CNTSA])=0 : Local File CONTACTSA    [CNTSA]         : Endif
#JASMI - 2014/04/17 - END
Return

Subprog CHARG_BPA_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE

  For nolign=1 To [M:BPF]NBADR
    Read [BPASA]BPASA0=TYP;ENTITE;[M]CODADR(nolign-1)
    If !fstat Then
      [M:BPF] = [F:BPASA]
    Endif
  Next

  NOL = 0
  Gosub REMP_ADR_KSA
End

#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
Subprog CHARG_BPA_CPY_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
  For nolign=1 To [M:BPA]NBADR
    Read [BPASA]BPASA0=TYP;ENTITE;[M:BPA]CODADR(nolign-1)
    If !fstat Then
      [M:BPA] = [F:BPASA]
    Endif
  Next
  NOL = 0
  Gosub REMP_ADR_KSA
End
#FRLAA - 2015/05/01 Requirement 108198 US 3580  END

#JASMI - 2015-03-10 - BUG: 106880 - START
Subprog CHARG_CNT_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE

  For nolign=1 To [M:CNF]NBCNT
    Read [CNTSA]CNTSA0=TYP;ENTITE;[M:CNF]CCNCRM(nolign-1)
    If !fstat Then
      [M:CNF] = [F:CNTSA]
    Endif
  Next

  NOL = 0
  Gosub REMP_CNT_KSA

End
#JASMI - 2015-03-10 - BUG: 106880 - END

#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
Subprog CHARG_CNT_CPY_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
  For nolign=1 To [M:CNT]NBCNT
    Read [CNTSA]CNTSA0=TYP;ENTITE;[M:CNT]CCNCRM(nolign-1)
    If !fstat Then
      [M:CNT] = [F:CNTSA]
    Endif
  Next

  NOL = 0
  Gosub REMP_CNT_KSA
End
#FRLAA - 2015/05/01 Requirement 108198 US 3580  START

$REMP_ADR_KSA

If dim([M:BPF]XADDTYPSA)> 0
  [M:BPF]XADDTYPSA    = [M:BPF]ADDTYPSA(NOL)
  [M:BPF]XADDSRVTYPSA = [M:BPF]ADDSRVTYPSA(NOL)
  [M:BPF]XADDPOSNBRSA = [M:BPF]ADDPOSNBRSA(NOL)
  [M:BPF]XADDCPXSA    = [M:BPF]ADDCPXSA(NOL)
#FLNEL - 13/05/2014 - Chenges in RSA addresses - Insert this line
  [M:BPF]XADDSUBSA    = [M:BPF]ADDSUBSA(NOL)
#  [M:BPF]XADDCRYCDESA = [M:BPF]ADDCRYCDESA(NOL)
#FLNEL END
  Affzo [M:BPF]55
 Endif
  #FRLAA - 2015/05/01 Requirement 108198 US 3580  START
  If dim([M:BPA]XADDTYPSA)> 0
    [M:BPA]XADDTYPSA    = [M:BPA]ADDTYPSA(NOL)
    [M:BPA]XADDSRVTYPSA = [M:BPA]ADDSRVTYPSA(NOL)
    [M:BPA]XADDPOSNBRSA = [M:BPA]ADDPOSNBRSA(NOL)
    [M:BPA]XADDCPXSA    = [M:BPA]ADDCPXSA(NOL)
    [M:BPA]XADDSUBSA    = [M:BPA]ADDSUBSA(NOL)
    Affzo [M:BPA]55
  Endif
  #FRLAA - 2015/05/01 Requirement 108198 US 3580  END
Return

#JASMI - 2015-03-10 - BUG: 106880 - START
$REMP_CNT_KSA
If dim([M:CNF]KRSACNTTYP)> 0
  [M:CNF]KRSACNTTYP    = [M:CNF]RSACNTTYP(NOL)
  Affzo [M:CNF]
Endif
#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
If dim([M:CNT]KRSACNTTYP)> 0
  [M:CNT]KRSACNTTYP    = [M:CNT]RSACNTTYP(NOL)
  Affzo [M:CNT]
Endif
#FRLAA - 2015/05/01 Requirement 108198 US 3580  END
Return
#JASMI - 2015-03-10 - BUG: 106880 - END

Subprog CREBPA_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
Local Integer STA ,I,J

If dim([M:BPF]NBADR)> 0
  If [M:BPF]NBADR>0 & !find(2,[M:BPF]BPAADDFLG(0..[M]NBADR-1))
    [M:BPF]BPAADDFLG(0) = 2
    [M:BPF]FLMOD(0)=1
  Endif
  For nolign=1 To [M:BPF]NBADR
    If [M:BPF]FLMOD(nolign-1)
      Readlock [F:BPASA]BPASA0 = TYP;ENTITE;[M:BPF]CODADR(nolign-1)
      STA = fstat
      If STA=1
        GOK = -1 : GLOCK = "$BPADDRESSSA"-num$(TYP)-ENTITE-[M:BPF]CODADR(nolign-1) : Break
      Endif
      [F:BPASA] = [M:BPF]
      [F:BPASA]BPATYP = TYP
      [F:BPASA]BPANUM = ENTITE
      [F:BPASA]BPAADD = [M]CODADR(nolign-1)

      If STA
        If dim([F:BPASA]CREDAT)>0 : [F:BPASA]CREDAT = date$ : Endif
        If dim([F:BPASA]CREUSR)>0 : [F:BPASA]CREUSR = GUSER : Endif
        If dim([F:BPASA]CRETIM)>0 : [F:BPASA]CRETIM = time  : Endif
        If dim([F:BPASA]UPDDAT)>0 : [F:BPASA]UPDDAT = [0/0/0] : Endif
        If dim([F:BPASA]UPDUSR)>0 : [F:BPASA]UPDUSR = "" : Endif
        If dim([F:BPASA]UPDTIM)>0 : [F:BPASA]UPDTIM = 0  : Endif
        Write [BPASA]
      Else
        If dim([F:BPASA]UPDDAT)>0 : [F:BPASA]UPDDAT = date$ : Endif
        If dim([F:BPASA]UPDUSR)>0 : [F:BPASA]UPDUSR = GUSER : Endif
        If dim([F:BPASA]UPDTIM)>0 : [F:BPASA]UPDTIM = time  : Endif
        Rewrite [BPASA]
      Endif
      If fstat
        GOK = 0 : Call FSTA("BPASA") From GLOCK : Break
      Endif
    Endif
  Next nolign
 #FRLAA 2015-07-06 - Requirement xxxxx US P#4 - START comment
#  If GOK=1
#    Raz [M:BPF]FLMOD
#  Endif
 #FRLAA 2015-07-06 - Requirement xxxxx US P#4 - END comment
Endif
End

#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
Subprog CREBPA_CPY_KSA(TYP,ENTITE)
Value Integer TYP
Value Char    ENTITE
Local Integer STA ,I,J

If dim([M:BPA]NBADR)> 0
  If [M:BPA]NBADR>0 & !find(2,[M:BPA]BPAADDFLG(0..[M]NBADR-1))
    [M:BPA]BPAADDFLG(0) = 2
    [M:BPA]FLMOD(0)=1
  Endif
  For nolign=1 To [M:BPA]NBADR
    If [M:BPA]FLMOD(nolign-1)
      Readlock [F:BPASA]BPASA0 = TYP;ENTITE;[M:BPA]CODADR(nolign-1)
      STA = fstat
      If STA=1
        GOK = -1 : GLOCK = "$BPADDRESSSA"-num$(TYP)-ENTITE-[M:BPA]CODADR(nolign-1) : Break
      Endif
      [F:BPASA] = [M:BPA]
      [F:BPASA]BPATYP = TYP
      [F:BPASA]BPANUM = ENTITE
      [F:BPASA]BPAADD = [M]CODADR(nolign-1)

      If STA
        If dim([F:BPASA]CREDAT)>0 : [F:BPASA]CREDAT = date$ : Endif
        If dim([F:BPASA]CREUSR)>0 : [F:BPASA]CREUSR = GUSER : Endif
        If dim([F:BPASA]CRETIM)>0 : [F:BPASA]CRETIM = time  : Endif
        If dim([F:BPASA]UPDDAT)>0 : [F:BPASA]UPDDAT = [0/0/0] : Endif
        If dim([F:BPASA]UPDUSR)>0 : [F:BPASA]UPDUSR = "" : Endif
        If dim([F:BPASA]UPDTIM)>0 : [F:BPASA]UPDTIM = 0  : Endif
        Write [BPASA]
      Else
        If dim([F:BPASA]UPDDAT)>0 : [F:BPASA]UPDDAT = date$ : Endif
        If dim([F:BPASA]UPDUSR)>0 : [F:BPASA]UPDUSR = GUSER : Endif
        If dim([F:BPASA]UPDTIM)>0 : [F:BPASA]UPDTIM = time  : Endif
        Rewrite [BPASA]
      Endif
      If fstat
        GOK = 0 : Call FSTA("BPASA") From GLOCK : Break
      Endif
    Endif
  Next nolign
  If GOK=1
    Raz [M:BPA]FLMOD
  Endif
Endif
End
 #FRLAA - 2015/05/01 Requirement 108198 US 3580  END

#FRLAA & JASMI - 2015/06/24 Requirement 108198 US 3580  START
Subprog CRECNT_KSA(LTYP,ENTITE)
Value Integer LTYP
Value Char    ENTITE
Local Integer STA , OLDCNT
Local Char    ACTION(20)
Local Integer NI # FGR11/02/2009 : X3SUIVI52269

OLDCNT = 0
If clalev([F:CNTSA])=0 : Local File CONTACTSA    [CNTSA]         : Endif
For [CNTSA]CNTSA0 Where BPATYP=LTYP & BPANUM=ENTITE
 OLDCNT += 1
 If !find([F:CNTSA]CCNCRM,[M]CCNCRM(0..[M]NBCNT-1))
  Delete [CNTSA]
  If fstat=1
   GOK = -1 : GLOCK = "$CONTACTSA"-num$(LTYP)-[F:CNTSA]CCNCRM : Break
  Endif
 Endif
Next
If GOK<1 : End : Endif
If [M]NBCNT>0 & !find(2,[M]CNTFLG(0..[M]NBCNT-1))
 [M]CNTFLG(0) = 2
 [M]FLMOD(0)=1
Endif
For nolign=1 To [M]NBCNT
 If (!OLDCNT or [M]FLMOD(nolign-1)) & [M]CNTLNA(nolign-1)<>""
  Readlock [CNTSA]CNTSA0 = LTYP;ENTITE;[M]CCNCRM(nolign-1)
  STA = fstat
  If STA=1
   GOK = -1 : GLOCK = "$CONTACTSA"-num$(LTYP)-ENTITE-[M]CCNCRM(nolign-1) : Break
  Elsif STA
   Raz [F:CNTSA]
  Endif

  [F:CNTSA] = [M]
  [F:CNTSA]BPATYP = LTYP
  [F:CNTSA]BPANUM = ENTITE
  [F:CNTSA]CCNCRM = [M]CCNCRM(nolign-1)

  If STA
    If dim([F:CNTSA]CREDAT)>0     : [F:CNTSA]CREDAT = date$     : Endif
    If dim([F:CNTSA]CREUSR)>0     : [F:CNTSA]CREUSR = GUSER     : Endif
    If dim([F:CNTSA]CREDATTIM)>0  : [F:CNTSA]CREDATTIM = time   : Endif
    Write [CNTSA]
  Else
    If dim([F:CNTSA]UPDDAT)>0     : [F:CNTSA]UPDDAT = date$     : Endif
    If dim([F:CNTSA]UPDUSR)>0     : [F:CNTSA]UPDUSR = GUSER     : Endif
    If dim([F:CNTSA]UPDDATTIM)>0  : [F:CNTSA]UPDDATTIM = time   : Endif
    Rewrite [CNTSA]
  Endif
  If fstat
    GOK = 0 : Call FSTA("CNTSA") From GLOCK : Break
  Endif
 Endif
Next nolign
If GOK=1
 Raz [M]FLMOD
Endif

End
#FRLAA & JASMI - 2015/06/24 Requirement 108198 US 3580  END

$ADD_BPA


#FRLAA and JASMI - Requirement 109427 - US 3711 - START
#FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - START
