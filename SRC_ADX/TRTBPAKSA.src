Subprog AM_XADDTYPSA(VALEUR)
Variable Integer VALEUR

  [M]ADDTYPSA([M]XNUMLIG) = VALEUR
  [M]FLMOD([M]XNUMLIG) = 1
  #FRLAA - 2015/05/01 - BUG xxxxx START
   If VALEUR <> 2
    Grizo [M]XADDSRVTYPSA
  Else
    Actzo [M]XADDSRVTYPSA
  Endif
  #FRLAA - 2015/05/01 - BUG xxxxx START
End

Subprog AM_XADDSRVTYPSA(VALEUR)
Variable Integer VALEUR

  [M]ADDSRVTYPSA([M]XNUMLIG) = VALEUR
  [M]FLMOD([M]XNUMLIG) = 1
End

