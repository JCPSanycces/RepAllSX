#FRLAA - 2015/05/01 Requirement 108198 US 3580  START
#FRLAA and JASMI - Requirement 109427 - US 3711 - START
  #FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - START
  If func DIVPAYE.IS_KZA(GCURLEG)>0 & dim([M:CPY0]CPY)> 0 Then
  #If func AFNC.ACTIV("KSA")>0 & func DIVPAYE.EXISTE_KXX("TRTBPAKSA") & dim([M:CPY0]CPY)> 0 Then
  #If func AFNC.ACTIV("KZA")>0 & func DIVPAYE.EXISTE_KXX("TRTBPAKSA") & dim([M:CPY0]CPY)> 0 Then
  #FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - END
#FRLAA and JASMI - Requirement 109427 - US 3711 - END
    Call CREBPA_CPY_KSA(NUMBPA,[M:CPY0]CPY) From TRTBPAKSA
 #FRLAA - 2015/05/01 Requirement 108198 US 3580  END
  Endif

Return

#JASMI - 2015-03-10 - BUG: 106880 - START
$ADD_CNT


#FRLAA and JASMI - Requirement 109427 - US 3711 - START
#FRLAA - 2016-06-03 - REQUIREMENT 114309 US 211 - START

 # If func DIVPAYE.IS_KZA(GCURLEG)>0

