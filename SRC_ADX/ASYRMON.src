#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* START
#*!
Funprog START()
Local Integer ASTATUS

ASTATUS = func ASYRTIMING.START("",1)
If !ASTATUS
 ASTATUS=1
Else
 ASTATUS=0
Endif
End ASTATUS

#**
#* STOP
#*
#* @param CLOB
#*!
Funprog STOP(CLOB)
Variable Clbfile CLOB()

Local Integer ASTATUS
Local Char     TRACE(GDIMFIC)
Local Char     LINE(250)
Local Char     ITEM(250)

Local Integer  COUNT,I,J
Local Integer  TOTAL
Local Char     SEP(1) : SEP=''

TRACE   = filpath("TRA","ASYRMAIN", "tra", 0)
ASTATUS = func ASYRTIMING.STOP(GACTX,"",1,TRACE)

If !ASTATUS & filinfo(filpath("TRA",TRACE,"tra",0),0)>0

 If(len(CLOB))
  CLOB = left$(CLOB,len(CLOB)-1)
  Append CLOB,','+chr$(10)
 Else
  Append CLOB,'{'
 Endif
 Append CLOB,'"monitoring":{'


 Openi filpath("TRA",TRACE,"tra",0),0
 adxifs=""
 adxirs=chr$(10)
 adxium=GUTF8
 While 1
  Rdseq LINE
  Break (fstat<>0)
  COUNT+=1
  If COUNT=2
   #Temps total : 59 ms -> 0:00:00:059 (hh:mm:ss:000)
   I = instr(1,LINE,":")
   J = instr(1,LINE,"ms")
   If I & J & J>I
    Append CLOB, '"time":'+vireblc(mid$(LINE,I+1,J-I-2),4)
    Append CLOB, ',"items":['
   Endif
  Elsif COUNT>2
   Append CLOB, SEP+chr$(10)+'{'
   Append CLOB, '"item":"'+vireblc(left$(LINE,60),1)+'"'
   Append CLOB,',"count":'+vireblc( mid$(LINE,60,15),4)
   Append CLOB,',"time":'+vireblc( mid$(LINE,90,7),4)
   ITEM = vireblc( mid$(LINE,99,8),4)
   If instr(1,ITEM,"*")
    Append CLOB,',"percent":100.00'
   Else
    Append CLOB,',"percent":'+ctrans(vireblc( mid$(LINE,99,8),4),",",".")
   Endif
   Append CLOB, '}'
   SEP = ','
  Endif
 Wend
 Openi
 Append CLOB, ']}}'
Endif
End ASTATUS
