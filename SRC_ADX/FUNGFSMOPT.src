    If VALEUR <> "" : [M:MGFOP1]BPCNUMFIN = VALEUR : Endif
End

Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
    If VALEUR <> "" : [M:MGFOP1]VCRNUMFIN = VALEUR : Endif
End

Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
    If VALEUR <> "" : [M:MGFOP1]ITMREFFIN = VALEUR : Endif
End



######################################################################################

######################################################################################
## Section automatically added (screen MAUTGFSOPT1) 10/17/2019 09:38:04 (ANBAB)
######################################################################################
Subprog C_WOFFLG(VALEUR)
Variable Integer VALEUR
    If ([M:MGFOP1]WOSFLG = 1 &
&       [M:MGFOP1]WOPFLG = 1 &
&       VALEUR = 1)
        mkstat = 2
        GERR = 1 : GMESSAGE = mess(77,193,1) # It is necessary to select at least one order type!
    Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen MAUTGFSOPT1) 10/17/2019 09:43:55 (ANBAB)
######################################################################################
Subprog C_WOSFLG(VALEUR)
Variable Integer VALEUR
    If ([M:MGFOP1]WOFFLG = 1 &
&       [M:MGFOP1]WOPFLG = 1 &
&       VALEUR = 1)
            mkstat = 2
            GERR = 1 : GMESSAGE = mess(77,193,1) # It is necessary to select at least one order type!
    Endif
End


