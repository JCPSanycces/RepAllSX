#<AdxTL>@(#)0.0.0.0 $Revision$
# Update WOs, suggestions for scheduling in Planner One - FUNPSMOPT
# Issue X3-26163 - 2019-10-14 by ANBAB : Improve the screen for "Submit for Scheduling"
# Added criteria fields: Start-End range - Work order, Project, Destination, Order no. and Product

$ACTION
Case ACTION
    When "OUVRE"   : Gosub OUVRE
    When "DEBUT"   : Gosub DEBUT
    When "TITRE"   : TIT = mess(177,195,1)
    When "OK"      : Gosub OK
Endcase
Return

$DEBUT
    [M:MGFOP1]WOSFLG = 1
    Grizo [M:MGFOP1]MRPFLG
    Affzo [M:MGFOP1]WOSFLG
    Affzo [M:MGFOP1]WOPFLG
    Affzo [M:MGFOP1]WOFFLG
Return

$OUVRE
    Local Char WFCY(GLONFCY) : WFCY = PARAM(1)
    Local Integer  J, K
    Local Integer  OK
    Local Integer  NBOF
    Local Char     TIT(50)
    Local Char     CRITERE(255)
    Local Char     CRITERE1(255)
    Local Char     CRITERE2(255)
    Local Char     CRITERESUG(255)          # Issue X3-26163 - 2019-10-11 by ANBAB : Criteria for suggestions
    Local Char     CRITERESUG1(255)
    Local Char     CRITERESUG2(255)
    Local Char     CUSFLT(255)
    Local Char     FORMULE1(255)
    Local Char     WMESS(150)
    Local Integer  WHDEB,WHFIN, WHWRK
    Local Integer  MFGSTA, MFGFIP, MFGSUG   # Issue X3-26163 - 2019-10-11 by ANBAB : MFGFIP flag set to 2 for Plan and Firm, MFGSUG flag set to 2 for suggestions only

    If dim(GOPTFCY) <= 0 : Global Char    GOPTFCY(GLONFCY) : Endif
    Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
    Gosub CHARG_PARAM

    # Ouverture des fichiers utilisés
    If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
    If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
    If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
    If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif

    # Issue X3-26163 - 2019-10-28 by STWIL : Need to check if there are operations for work order suggestions
    If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif

Return


$OK
    FIN = 0
    # Read the site code
    Call LECTURE ("FCY", [M:MGFOP1]MFGFCY, "") From CONTOBJ

    # Output tracing info.
    If [M:MGFOP1]TRACE1 = 2
        Call OUVRE_TRACE(TIT) From LECFIC
        Call ECR_TRACE(" ",0) From GESECRAN
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call PRTSCR("MAUTGFSOPT1","MGFOP1","",0,1) From ATRTX3
        Call ECR_TRACE(string$(82,"-"),0) From GESECRAN
        Call ECR_TRACE(" ",0) From GESECRAN
        WHDEB = time
    Endif

    # Popup 'updating' screen
    Call TEMPON(mess(195,195,1)) From GESECRAN

    # Prepare the filtering
    Gosub SEL_OF

    # traitement des OF
    NBOF = 0 :

    # Update the works orders
    Gosub TRT_OF

    # Close 'updating' screen
    Call TEMPOFF From GESECRAN

    # Output tracing information
    If [M:MGFOP1]TRACE1 = 2
        WHFIN = time
        WHWRK = WHFIN-WHDEB
        J = mod(WHWRK,60)
        K = WHWRK/60
        K = int(K)
        WMESS=mess(106,190,1)+":"-num$(K)-mess(2,301,1)-num$(J)
        Call ECR_TRACE(WMESS,0) From GESECRAN
        # fermeture trace
        Call FERME_TRACE From LECFIC
    Endif
    # Output the number of orders updated
    If NBOF
        Call MESSAGE(num$(NBOF)-mess(354,193,1)) From GESECRAN
    Else
        Call MESSAGE(mess(88,193,1)) From GESECRAN
    Endif
    # aucun OF extrait ou lecture trace
    If [M:MGFOP1]TRACE1 = 2 : Call LEC_TRACE From LECFIC : Endif
Return


Subprog AM_WOSFLG(VALEUR)
Variable Integer VALEUR
    If VALEUR = 1
        Grizo [M:MGFOP1]MRPFLG
    Else
        [M:MGFOP1]MRPFLG = 3
        Actzo [M:MGFOP1]MRPFLG
    Endif
    Affzo [M:MGFOP1]MRPFLG
End


$CHARG_PARAM
    # Variables globales stock
    Call GLOBVAR(GFCY)From WWGLOBSTO

    # Variables globales GPAO
    Call GLOBVAR(GFCY)From WWGLOBGPA
Return


########################################################################
# Préparation du filtre sur la table encours (WOx)
$SEL_OF
    Raz CRITERE
    Raz CRITERE1
    Raz CRITERE2
    Raz CRITERESUG
    Raz CRITERESUG1
    Raz CRITERESUG2

    MFGFIP = 1
    MFGSUG = 1

    GPE = 0
    GPOINT = "OPTDATSEL"
    Gosub  ENTREE From EXEFNC

    # Issue X3-26163 - 2019-10-09 by ANBAB : Criteria for Planned and Firm Work orders
    If [M:MGFOP1]WOPFLG = 2 | [M:MGFOP1]WOFFLG = 2

        If [M:MGFOP1]WOPFLG = 2
            CRITERE = "[F:MFG]MFGSTA=2"
            MFGFIP = 2
            Gosub LOAD_CRITERE
        Endif

        If [M:MGFOP1]WOFFLG = 2
            CRITERE = "[F:MFG]MFGSTA=1"
            MFGFIP = 2
            Gosub LOAD_CRITERE
        Endif

        # 2019-10-09 by ANBAB :close ")" only if the CRITERE1 is populated
        If CRITERE1 <>""
            CRITERE1 += ")"
        Endif
        # Start and End date
        If !GPE
            CRITERE = "[F:MFG]STRDAT>=[M:MGFOP1]STRDAT"
            Gosub LOAD_CRITERE2

            CRITERE = "[F:MFG]ENDDAT<=[M:MGFOP1]ENDDAT"
            Gosub LOAD_CRITERE2

            CRITERE = "[F:MFG]MFGFCY = [M:MGFOP1]MFGFCY"
            Gosub LOAD_CRITERE2
        Endif

        # Work Order
        If [M:MGFOP1]MFGNUMDEB <> ""
            CRITERE = "[F:MFG]MFGNUM >=[M:MGFOP1]MFGNUMDEB"         # Start work order
            Gosub LOAD_CRITERE2
        Endif
        If [M:MGFOP1]MFGNUMFIN <> ""
            CRITERE = "[F:MFG]MFGNUM <=[M:MGFOP1]MFGNUMFIN"         # Start work order
            Gosub LOAD_CRITERE2
        Endif

        # Project
        If [M:MGFOP1]PJTDEB <> ""
           CRITERE = "[F:MFI]PJT >= [M:MGFOP1]PJTDEB"               # Start project
           Gosub LOAD_CRITERE2
        Endif
        If [M:MGFOP1]PJTFIN <> ""
           CRITERE = "[F:MFI]PJT <= [M:MGFOP1]PJTFIN"               # End project
           Gosub LOAD_CRITERE2
        Endif

        # Destination
        If [M:MGFOP1]BPCNUMDEB <> ""
           CRITERE = "[F:MFI]BPCNUM >= [M:MGFOP1]BPCNUMDEB"         # Start destination
           Gosub LOAD_CRITERE2
        Endif
        If [M:MGFOP1]BPCNUMFIN <> ""
           CRITERE = "[F:MFI]BPCNUM <= [M:MGFOP1]BPCNUMFIN"         # End destination
           Gosub LOAD_CRITERE2
        Endif

        #Order
        If [M:MGFOP1]VCRNUMDEB <> ""
           CRITERE = "[F:MFI]VCRNUMORI >= [M:MGFOP1]VCRNUMDEB"      # Start order
           Gosub LOAD_CRITERE2
        Endif
        If [M:MGFOP1]VCRNUMFIN <> ""
           CRITERE = "[F:MFI]VCRNUMORI <= [M:MGFOP1]VCRNUMFIN"      # Start order
           Gosub LOAD_CRITERE2
        Endif

        #Product
        If [M:MGFOP1]ITMREFDEB <> ""
            CRITERE = "[F:MFI]ITMREF >= [M:MGFOP1]ITMREFDEB"        # Start product
            Gosub LOAD_CRITERE2
        Endif
        If [M:MGFOP1]ITMREFFIN <> ""
            CRITERE = "[F:MFI]ITMREF <= [M:MGFOP1]ITMREFFIN"        # Start product
            Gosub LOAD_CRITERE2
        Endif
    Endif

    # Issue X3-26163 - 2019-10-11 by ANBAB : Criteria for Suggestion
    If [M:MGFOP1]WOSFLG = 2
        CRITERESUG  = "[F:ORD]WIPSTA=3 & [F:ORD]VCRTYP = 11 & [F:ORD]WIPTYP = 5"
        MFGSUG = 2
        Gosub LOAD_CRITERESUG

        # 2019-10-09 by ANBAB :close ")" only if the Critere1 is populated
        If CRITERESUG1 <>""
            CRITERESUG1 += ")"
        Endif

        If !GPE
            CRITERESUG = "[F:ORD]STRDAT>=[M:MGFOP1]STRDAT"
            Gosub LOAD_CRITERESUG2

            CRITERESUG = "[F:ORD]ENDDAT<=[M:MGFOP1]ENDDAT"
            Gosub LOAD_CRITERESUG2

            CRITERESUG = "[F:ORD]STOFCY = [M:MGFOP1]MFGFCY"
            Gosub LOAD_CRITERESUG2
        Endif

        # Work Order
        If [M:MGFOP1]MFGNUMDEB <> ""
            CRITERESUG = "[F:ORD]VCRNUM >=[M:MGFOP1]MFGNUMDEB"        # Start work order
            Gosub LOAD_CRITERESUG2
        Endif
        If [M:MGFOP1]MFGNUMFIN <> ""
            CRITERESUG = "[F:ORD]VCRNUM <=[M:MGFOP1]MFGNUMFIN"        # Start work order
            Gosub LOAD_CRITERESUG2
        Endif

        # Project
        If [M:MGFOP1]PJTDEB <> ""
           CRITERESUG = "[F:ORD]PJT >= [M:MGFOP1]PJTDEB"               # Start project
           Gosub LOAD_CRITERESUG2
        Endif
        If [M:MGFOP1]PJTFIN <> ""
           CRITERESUG = "[F:ORD]PJT <= [M:MGFOP1]PJTFIN"               # End project
           Gosub LOAD_CRITERESUG2
        Endif
        LOAD1=CRITERESUG1

        # Destination
        If [M:MGFOP1]BPCNUMDEB <> ""
           CRITERESUG = "[F:ORD]BPRNUM >= [M:MGFOP1]BPCNUMDEB"         # Start destination
           Gosub LOAD_CRITERESUG2
        Endif
        If [M:MGFOP1]BPCNUMFIN <> ""
           CRITERESUG = "[F:ORD]BPRNUM <= [M:MGFOP1]BPCNUMFIN"         # End destination
           Gosub LOAD_CRITERESUG2
        Endif

        #Order
        If [M:MGFOP1]VCRNUMDEB <> ""
           CRITERESUG = "[F:ORD]VCRNUMORI >= [M:MGFOP1]VCRNUMDEB"       # Start order
           Gosub LOAD_CRITERESUG2
        Endif
        If [M:MGFOP1]VCRNUMFIN <> ""
           CRITERESUG = "[F:ORD]VCRNUMORI <= [M:MGFOP1]VCRNUMFIN"       # Start order
           Gosub LOAD_CRITERESUG2
        Endif

        #Product
        If [M:MGFOP1]ITMREFDEB <> ""
            CRITERESUG = "[F:ORD]ITMREF >= [M:MGFOP1]ITMREFDEB"         # Start product
            Gosub LOAD_CRITERESUG2
        Endif
        If [M:MGFOP1]ITMREFFIN <> ""
            CRITERESUG = "[F:ORD]ITMREF <= [M:MGFOP1]ITMREFFIN"         # Start product
            Gosub LOAD_CRITERESUG2
        Endif
    Endif
Return

$LOAD_CRITERE
    If len(CRITERE1)=0
        CRITERE1 += "("
    Else
        CRITERE1 += "|"
    Endif
    CRITERE1 += CRITERE
Return

$LOAD_CRITERE2
    If len(CRITERE)+len(CRITERE1)+1 < 225
    # 2019-10-09 by ANBAB :Add "&" only if the CRITERE1 is populated
        If CRITERE1 <>""
            CRITERE1 += "&"
        Endif
        CRITERE1 += CRITERE
    Else
        If CRITERE2 <> ""
            CRITERE2 += "&"
        Endif
        CRITERE2 += CRITERE
    Endif
Return

$LOAD_CRITERESUG
    If len(CRITERESUG1)=0
        CRITERESUG1 += "("
    Else
        CRITERESUG1 += "|"
    Endif
    CRITERESUG1 += CRITERESUG
Return

$LOAD_CRITERESUG2
    If len(CRITERESUG)+len(CRITERESUG1)+1 < 225
        If CRITERESUG1 <>""
            CRITERESUG1 += "&"
        Endif
        CRITERESUG1 += CRITERESUG
    Else
        If CRITERESUG2 <> ""
            CRITERESUG2 += "&"
        Endif
        CRITERESUG2 += CRITERESUG
    Endif
Return

$TRT_OF
    Raz FORMULE1
    If CRITERE2 = "" : CRITERE2 = "1=1" : Endif
    If CRITERESUG2 = "" : CRITERESUG2 = "1=1" : Endif

    Raz CUSFLT
    GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
    If CUSFLT = "" : CUSFLT = "1=1" : Endif

    If [M:MGFOP1]FORMULE  <> ""
        Read [F:TFO]TFO0=10;[M:MGFOP1]FORMULE
        If !fstat
            If FORMULE1 = ""
                FORMULE1  = [F:TFO]FORFOR
            Else
                FORMULE1 += "&"
                FORMULE1 += [F:TFO]FORFOR
            Endif
        Endif
    Endif

    GPOINT = "INIT_ACTLINK"  : Gosub ENTREE From EXEFNC
    fstat = 0

    # Issue X3-26163 - 2019-10-14 by ANBAB : Submit to schedule - records returned based on the criteria
    # For Planned WO, Firm WO and Suggestions
    If FORMULE1=""
        FORMULE1="1=1"
    Endif

    # Issue X3-26163 - 2019-10-14 by ANBAB : Planned and Firm WO records for Submission
    If MFGFIP = 2
        Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [MFX]
&           Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&           Order By Key MFI0
        For [MFX]
            OK = 2
            MFGSTA = [F:MFG]MFGSTA
            If OK
               Gosub SEL_OFCOMPL
                If OK <> 1
                    Gosub TRTEXT
                Endif
            Endif
        Next
    Endif

    # Issue X3-26163 - 2019-10-15 by ANBAB : Suggestion records for submission
    If MFGSUG = 2
        Filter [ORD]
&           Where evalue(CRITERESUG1) & evalue(CRITERESUG2) & evalue(CUSFLT) & evalue(FORMULE1)
        For [ORD] ORD3
            OK = 2
            MFGSTA = [F:ORD]WIPSTA
            If OK
                Gosub SEL_OFCOMPLSUG
                If OK <> 1
                    Gosub TRTEXT
                Endif
            Endif
        Next
    Endif
    Filter [ORD]
Return

$TRTEXT
    If !OK : Return : Endif
    Call DEBTRANS From GLOCK
    GOK = 1
    Gosub EXTRAC
Return

$EXTRAC
    Local Char MFGNUM(GLONVCR)
    Trbegin [MFG]

    If [L]MFGSTA <> 3
        Readlock [MFG]MFG0=[F:MFG]MFGNUM
        If fstat=1 & !GSERVEUR
            WTAB="MFG"
            WCLE=[F:MFG]MFGNUM
            Goto ROL_TRTEXT
        Endif
        If fstat
            WTAB="MFG"
            WCLE=[F:MFG]MFGNUM
            Goto AB_TRTEXT
        Endif
        [F:MFG]OPTFLG = 2
        [F:MFG]OPTUSR = GUSER
        Rewrite [MFG]
        Unlock [MFG]
        [L]MFGNUM = [F:MFG]MFGNUM
        [L]MFGSTA = [F:MFG]MFGSTA
    Else
        Readlock [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
        If fstat=1 & !GSERVEUR
            WTAB="ORD"
            WCLE=[F:ORD]WIPNUM
            Goto ROL_TRTEXT
        Endif
        If fstat
            WTAB="ORD"
            WCLE=[F:ORD]WIPNUM
            Goto AB_TRTEXT
        Endif
        [F:ORD]OPTFLG = 2
        [F:ORD]UPDDAT = date$
        [F:ORD]UPDUSR = GUSER
        Rewrite [ORD]
        Unlock [ORD]
        [L]MFGNUM = [F:ORD]WIPNUM
        [L]MFGSTA = [F:ORD]WIPSTA
    Endif

    If [M:MGFOP1]TRACE1 = 2
        WMESS   = mess(156,197,1)+" "+mess([L]MFGSTA,317,1)+" "+[L]MFGNUM+" "+mess(214,197,1)
        Call ECR_TRACE(WMESS,0) From GESECRAN
    Endif
    NBOF += 1

    Commit
    Raz fstat
Return

$SEL_OFCOMPL
    OK=1
    If [F:MFG]OPTFLG = 2 | [F:MFG]SCDFLG = 4
        Return
    Endif
    If !find([F:MFG]SCDFLG,2,4)

        WMESS = mess(156,197,1)+" "+mess([F:MFG]MFGSTA,317,1)+" "+[F:MFG]MFGNUM+" "+mess(1,335,1)
        If [M:MGFOP1]TRACE1 = 2
            Call ECR_TRACE(WMESS,-1) From GESECRAN
        Endif
        Return
    Endif
    If [F:MFG]MFGTRKFLG > 4 : Return : Endif
    If [F:MFG]CFMFLG <> 2
        WMESS = mess(156,197,1)+" "+mess([F:MFG]MFGSTA,317,1)+" "+[F:MFG]MFGNUM+" "+
&           mess(182,197,1)
        If [M:MGFOP1]TRACE1 = 2
            Call ECR_TRACE(WMESS,1) From GESECRAN
        Endif
        Return
    Endif
    OK=2
Return

# Check if suggestions have already been included and output a message if tracing
$SEL_OFCOMPLSUG
    OK=1
    If [F:ORD]OPTFLG = 2
        WMESS   = mess(156,197,1)+" "+mess([F:ORD]WIPSTA,317,1)+" "+[F:ORD]WIPNUM+" "+
&           mess(125,193,1)
        If [M:MGFOP1]TRACE1 = 2
            Call ECR_TRACE(WMESS,0) From GESECRAN
        Endif
        Return
    Else
        # Issue X3-26163 - 2019-10-28 by STWIL : Need to check if there are operations for this suggestion
        Filter [OPS] Where MFGNUM = [F:ORD]WIPNUM
        Look [OPS]OPS0 First
        Filter [OPS]
        If fstat <> 0
            # Issue X3-172661 - 2019-12-3 JAMCC : Replace multiple messages with single message
            # Work order 1$1 status $2$ is not scheduled
            WMESS = func AFNC.MES2(mess(447,193,1),[F:ORD]WIPNUM ,mess([F:ORD]WIPSTA,317,1))
            If [M:MGFOP1]TRACE1 = 2
                Call ECR_TRACE(WMESS,0) From GESECRAN
            Endif
            Return
        Endif
    Endif
    OK=2
Return

########################################################################
# Rollback
$ROL_TRTEXT
    Rollback
    Call ROLL From GLOCK
    If GROLL
        If [M:MGFOP1]TRACE1 = 2
            Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
        Endif
    Else Goto EXTRAC :Endif
Return

########################################################################
# Abandon
$AB_TRTEXT
    Rollback
    If [M:MGFOP1]TRACE1 = 2
        Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
    Endif
Return

######################################################################################
## Section automatically added (screen MAUTGFSOPT1) 10/08/2019 10:15:09 (ANBAB)
