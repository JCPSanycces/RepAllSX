#<AdxTL>@(#)0.0.0.0 $Revision$
# Class SCOSRV_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#      Case [L]AEVENT
#      Endcase
#  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CUR" :
      Case [L]ARULE
        When "GET"     : Gosub CUR_GET
      Endcase
    When "CURL" :
      Case [L]ARULE
        When "GET"     : Gosub CURL_GET
      Endcase
    When "SRVITMDES" :
      Case [L]ARULE
        When "GET"     : Gosub SRVITMDES_GET
      Endcase
    When "SCOPUUDES" :
      Case [L]ARULE
        When "GET"     : Gosub SCOPUUDES_GET
      Endcase
    When "PRIRENDES" :
      Case [L]ARULE
        When "GET"     : Gosub PRIRENDES_GET
      Endcase
  Endcase
Return

########################################################################################
$CUR_GET
  this.CUR = this.APARENT.APARENT.CUR
Return

########################################################################################
$CURL_GET
  this.CURL = this.APARENT.APARENT.CUR
Return

########################################################################################
$SRVITMDES_GET
  # Populate sub-contracted product description from ITMMASTER
  Call LECTEXTRA_SYR(this,AVOID.ACHAR,this.SRVITMDES,"ITMMASTER", "DES1AXX", this.SRVITMREF, AVOID.ACHAR) From ATEXTRA
Return

########################################################################################
$SCOPUUDES_GET
  # Populate non-financial unit description from TABUNIT
  Call LECTEXTRA_SYR(this,AVOID.ACHAR,this.SCOPUUDES,"TABUNIT", "DESSHO", this.SCOPUU, AVOID.ACHAR) From ATEXTRA
Return

########################################################################################
$PRIRENDES_GET
  # Populate price reason description from PPREASON
  Call LECTEXTRA_SYR(this,AVOID.ACHAR,this.PRIRENDES,"PPREASON", "DESAXX", num$(this.PRIREN), AVOID.ACHAR) From ATEXTRA
Return

