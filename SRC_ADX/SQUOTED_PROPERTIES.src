#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG properties related calls
# ----------------------- LINQUONOT --------------------------------------
$LINQUONOT

  Case [L]ARULE
    When "GET"       : Gosub GET_LINQUONOT
    When Default     : Return
  Endcase

Return
# -----------------------
$GET_LINQUONOT
  Local Decimal WMNTCALC

  # Montant net HT de la ligne
  WMNTCALC = this.QTY * this.NETPRINOT
  Call ARRDEV (WMNTCALC, this.APARENT.CUR) From TRTDIV
  this.LINQUONOT = WMNTCALC

Return
# ----------------------- LINQUOATI --------------------------------------
$LINQUOATI

  Case [L]ARULE
    When "GET"       : Gosub GET_LINQUOATI
    When Default     : Return
  Endcase

Return
# -----------------------
$GET_LINQUOATI
  Local Decimal WMNTCALC

  # Montant net TTC de la ligne
  WMNTCALC = this.QTY * this.NETPRIATI
  Call ARRDEV (WMNTCALC, this.APARENT.CUR) From TRTDIV
  this.LINQUOATI = WMNTCALC

Return
# ----------------------- LINPFM --------------------------------------
$LINPFM

  Case [L]ARULE
    When "GET"       : Gosub GET_LINPFM
    When Default     : Return
  Endcase

Return
# -----------------------
$GET_LINPFM
  Local Decimal WMNTCALC

  # Marge de la ligne
  WMNTCALC = this.QTY * this.PFM
  Call ARRDEV (WMNTCALC, this.APARENT.CUR) From TRTDIV
  this.LINPFM = WMNTCALC

Return

