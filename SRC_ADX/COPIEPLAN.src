#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","COPIEPLAN","COPIEPLAN",3,"") From GTRAITE
End

################################################
## Copie du plan de paye
################################################
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
Endcase
Return

################################################
$INIT
Local Mask COPIEPLAN [DIA]
Global Char SAV_GLEGFIL(GLONADI)
SAV_GLEGFIL = GLEGFIL
Return

$DEBUT
Raz [M:DIA]
If GABREV<>""
 Case GABREV
  When "RUB"
   [M]RUB = 2 : [M]RDEB = [M:RUB0]ROW : [M]RFIN = [M]RDEB
   Grizo VDEB,VFIN,CDEB,CFIN,EDEB,EFIN,GDEB,GFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "VRA"
   [M]VRA = 2 : [M]VDEB = [M:VRA0]COD : [M]VFIN = [M]VDEB
   Grizo RDEB,RFIN,EFFRUB,CDEB,CFIN,EDEB,EFIN,GDEB,GFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "CUM"
   [M]CUM = 2 : [M]CDEB = [M:CUM0]CUMCOD : [M]CFIN = [M]CDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,EDEB,EFIN,GDEB,GFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "EXO"
   [M]EXO = 2 : [M]EDEB = [M:EXO]COD : [M]EFIN = [M]EDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,GDEB,GFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "GRI"
   [M]GRI = 2 : [M]GDEB = [M:GRI0]COD : [M]GFIN = [M]GDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,EDEB,EFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "RGL"
   [M]REG = 2 : [M]REGDEB = [M:RGL0]COD : [M]REGFIN = [M]REGDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,GDEB,GFIN,EDEB,EFIN,CHDEB,CHFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "DCH"
   [M]DEC = 2 : [M]CHDEB = [M:DCH1]CODDCC : [M]CHFIN = [M]CHDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,GDEB,GFIN,EDEB,EFIN,REGDEB,REGFIN,LIVDEB,LIVFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "LPA"
   [M]LIV = 2 : [M]LIVDEB = [M:LPA1]COD : [M]LIVFIN = [M]LIVDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,GDEB,GFIN,EDEB,EFIN,REGDEB,REGFIN,CHDEB,CHFIN,LDEB,LFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  When "VFD"
   [M]VLA = 2 : [M]LDEB = [M:VFD0]DAT
   If [M:VFD0]DATF=[0/0/0]
    [M]LFIN = [M:VFD0]DAT
   Else
    [M]LFIN = [M:VFD0]DATF
   Endif
   Grizo RDEB,RFIN,VDEB,VFIN,EFFRUB,CDEB,CFIN,EDEB,EFIN,GDEB,GFIN,REGDEB,REGFIN,CHDEB,CHFIN,LIVDEB,LIVFIN
   #75651
   If func AFNC.ACTIV("MAS") : Grizo LPMDEB,LPMFIN : Endif
  #75651
  When "LPM"
   [M]LPM = 2 : [M]LPMDEB = [M:LPM1]COD : [M]LPMFIN = [M]LPMDEB
   Grizo RDEB,RFIN,EFFRUB,VDEB,VFIN,CDEB,CFIN,GDEB,GFIN,EDEB,EFIN,REGDEB,REGFIN,LIVDEB,LIVFIN,CHDEB,CHFIN,LDEB,LFIN
  Endcase

#MIPEA - 2016-06-14 - REQ 114309 US76 - START
Affzo
#MIPEA - 2016-06-14 - REQ 114309 US76 - END

  If GNBLEG > 1 : [M]LEG=GCURLEG : Endif

  If [M]LEG=""
    [M]ALLLEG=2 : Grizo [M]LEG
  Endif
Else
  If GLEGFIL<>"" : [M]LEG=GLEGFIL : Endif
Endif
[M]SRC = nomap
SUIZON = "DES"
#MIPEA - 2016-06-14 - REQ 114309 US76 - START
Affzo [M]SRC
#MIPEA - 2016-06-14 - REQ 114309 US76 - END
Return

################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(SAV_GLEGFIL)>0 : GLEGFIL = SAV_GLEGFIL : Kill SAV_GLEGFIL : Endif
Return

################################################
$EXEC
If GSTATUT<>GSTAOK : Return : Endif
Gosub DEFVAR

#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

DOSORG = [M:DIA]SRC
DOSDES = [M:DIA]DES
TOTAL  = ([M:DIA]CPL=2)
ACTIV  = [M:DIA]ACV
COPRUB = ([M:DIA]RUB=2)
COPVAR = ([M:DIA]VRA=2)
COPCUM = ([M:DIA]CUM=2)
COPEXO = ([M:DIA]EXO=2)
COPPAR = ([M:DIA]PAR=2)
COPGRI = ([M:DIA]GRI=2)
COPREG = ([M:DIA]REG=2)
COPDEC = ([M:DIA]DEC=2)
COPLIV = ([M:DIA]LIV=2)
COPVLA = ([M:DIA]VLA=2)
#75651
If func AFNC.ACTIV("MAS") : COPLPM = ([M:DIA]LPM=2) : Endif
RUBDEB = [M:DIA]RDEB
RUBFIN = [M:DIA]RFIN
VARDEB = [M:DIA]VDEB
VARFIN = [M:DIA]VFIN
CUMDEB = [M:DIA]CDEB
CUMFIN = [M:DIA]CFIN
GRIDEB = [M:DIA]GDEB
GRIFIN = [M:DIA]GFIN
EXODEB = [M:DIA]EDEB
EXOFIN = [M:DIA]EFIN
REGDEB = [M:DIA]REGDEB
REGFIN = [M:DIA]REGFIN
DECDEB = [M:DIA]CHDEB
DECFIN = [M:DIA]CHFIN
LIVDEB = [M:DIA]LIVDEB
LIVFIN = [M:DIA]LIVFIN
DATDEB = [M:DIA]LDEB
DATFIN = [M:DIA]LFIN
#75651
If func AFNC.ACTIV("MAS")
 LPMDEB = [M:DIA]LPMDEB
 LPMFIN = [M:DIA]LPMFIN
Endif
EFFRUB = ([M:DIA]EFFRUB=2)

Gosub BEFORECOPIE
If dim([M:DIA]ALLLEG)>0 & [M:DIA]ALLLEG=2
  Gosub COPIEDOS
Else
  GCURLEG=[M:DIA]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Gosub COPIE
Endif
Gosub AFTERCOPIE

TRA = 1
Return

$COPIEDOS
Local Integer I
CURRENTLEG = GCURLEG
For I=1 To GNBLEG
  GCURLEG=GDOSLEG(I)
  Gosub COPIE
Next
GCURLEG = CURRENTLEG
Return

$BEFORECOPIE
Call OUVRE_TRACE(mess(91,10702,1)) From LECFIC : # Copie du plan de paye
#85512
Call ECR_TRACE(mess(91,10702,1)-'('+DOSORG+'->'+DOSDES+')',0) From GESECRAN : # Copie du plan de paye (SCR->DES)
Call ECR_TRACE("",0) From GESECRAN
Local Char CURRENTLEG
Return

$COPIE
NBPRF = 0
CURRENTLEG = GCURLEG
Local File =DOSORG+".PROFIL" [PRF]
Local File =DOSDES+".PROFIL" [PRF2]
For [PRF]PRF0 Where LEG=GCURLEG
 Read [PRF2]PRF0 = [F:PRF]LEG;[F:PRF]PRFCOD
 If !fstat
  NBPRF += 1
  TBPRF(NBPRF) = [F:PRF]PRFCOD
 Endif
Next
Close Local File [PRF] , [PRF2]

If TOTAL
 Gosub EFFACE
Endif
If COPRUB : Gosub COPRUB : Endif
If COPVAR : Gosub COPVAR : Endif
If COPCUM : Gosub COPCUM : Endif
If COPEXO : Gosub COPEXO : Endif
If COPPAR : Gosub COPPAR : Endif
If COPGRI : Gosub COPGRI : Endif
If COPREG : Gosub COPREG : Endif
If COPDEC : Gosub COPDEC : Endif
If COPLIV : Gosub COPLIV : Endif
If COPVLA : Gosub COPVLA : Endif
#75651
If func AFNC.ACTIV("MAS")
 If COPLPM : Gosub COPLPM : Endif
Endif
Return

$AFTERCOPIE
  Call FERME_TRACE From LECFIC
Return

$DEFVAR
Local Integer I , J , K
Local Char    DOSORG(80) , DOSDES(80)
Local Integer TOTAL , EXISTE , COPIE , RANG
Local Integer COPRUB , COPVAR , COPCUM , COPEXO , COPPAR , COPGRI , COPREG , COPDEC , COPLIV, COPVLA, COPLPM
Local Integer RUBDEB , RUBFIN , EFFRUB
Local Char    VARDEB(GLONVRA) , VARFIN(GLONVRA)
Local Char    CUMDEB(GLONCUM) , CUMFIN(GLONCUM)
Local Char    EXODEB(GLONEXO) , EXOFIN(GLONEXO)
Local Char    GRIDEB(GLONGRI) , GRIFIN(GLONGRI)
Local Char    REGDEB(GLONRGL) , REGFIN(GLONRGL)
Local Char    DECDEB(GLONDCH) , DECFIN(GLONDCH)
Local Char    LIVDEB(GLONLPA) , LIVFIN(GLONLPA)
#79234
If func AFNC.ACTIV("MAS")
 Local Char    LPMDEB(GLONLPM) , LIVPMN(GLONLPM)
Endif
Local Date    DATDEB, DATFIN
Local Integer NBPRF
Local Char    TBPRF(GLONPRF)(1..100) , ACTIV(5)
Local Char    FICHIER(10) , CLE(10) , CRITERE(250) , BDEB(250) , BFIN(250) , TIT(80)
Return

###########################################################
$COPRUB
Local File =DOSORG+".RUBRIQUE"  [RUB]
Local File =DOSORG+".CALRUB"    [CRB]
Local File =DOSORG+".PROFIL"    [PRF]
Local File =DOSDES+".RUBRIQUE"  [RUB2]
Local File =DOSDES+".RUBRIQUE"  [RUB3]
Local File =DOSDES+".CALRUB"    [CRB2]
Local File =DOSDES+".PROFIL"    [PRF2]
Call ECR_TRACE(mess(92,10702,1),0) From GESECRAN : # Copie des rubriques
# If RUBFIN=0 : RUBFIN = 9999 : Endif #Longueur max sur 4
If RUBFIN=0 : RUBFIN = 99999 : Endif  #Longueur max sur 5
If EFFRUB
 Call DEBTRANS From GLOCK
 Gosub TR_EFFRUB
 If GOK<1 : Return : Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR_RUB
Call ECR_TRACE("",0) From GESECRAN
Close Local File [RUB] , [RUB2] , [RUB3] , [PRF] , [PRF2] , [CRB] , [CRB2]
Return

$TR_EFFRUB
GOK = 1
Trbegin [RUB2]
 If ACTIV<>""
  Filter [RUB2] Where (CODACT="" or CODACT=ACTIV) and LEG=GCURLEG
 Else
  Filter [RUB2] Where LEG=GCURLEG
 Endif
 For [RUB2]RUB1 Where ROW>=RUBDEB & ROW<=RUBFIN
  Delete [CRB2] Where COD=[F:RUB]COD & LEG=GCURLEG
  If fstat=1
   GOK = -1 : GLOCK = "$CALRUB"-[F:RUB]COD-GCURLEG : Break
  Endif
 Next
 Filter [RUB2]
 If GOK<1 : Goto ROLL_EFFRUB : Endif
 Delete [RUB2] Where ROW>=RUBDEB & ROW<=RUBFIN & LEG=GCURLEG
 If fstat=1
  GOK = -1 : GLOCK = "$RUBRIQUE" : Goto ROLL_EFFRUB
 Endif
Commit
Return

$ROLL_EFFRUB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EFFRUB : Endif

$TR_RUB
GOK = 1
NBPRF = 0
For [PRF]PRF0 Where LEG=GCURLEG
 Read [PRF2]PRF0 = [F:PRF]LEG;[F:PRF]PRFCOD
 If !fstat
  NBPRF += 1
  TBPRF(NBPRF) = [F:PRF]PRFCOD
 Endif
Next
Trbegin [RUB2]
 If ACTIV<>""
  Filter [RUB] Where CODACT=ACTIV and LEG=GCURLEG
 Else
  Filter [RUB] Where LEG=GCURLEG
 Endif
 For [RUB]RUB1 Where ROW>=RUBDEB & ROW<=RUBFIN
  Readlock [RUB2]RUB0 = [F:RUB]LEG;[F:RUB]COD
  If fstat=1
   GOK = -1 : GLOCK = "$RUBRIQUE"-[F:RUB]COD : Break
  Elsif !fstat
   EXISTE = 1
   If [F:RUB2]CODACT<>"" & [F:RUB2]CODACT<>ACTIV
    Call ECR_TRACE([F:RUB]COD-":"-mess(93,10702,1)-[F:RUB2]CODACT,1) From GESECRAN : # Code activité
    COPIE = 0
   Else
    COPIE = 1
   Endif
  Else
   EXISTE = 0
   COPIE  = 1
  Endif
  If COPIE
   Read [RUB3]RUB1 = [F:RUB]LEG;[F:RUB]ROW
#   If !fstat
#    Call ECR_TRACE([F:RUB]COD-":"-mess(94,10702,1)-num$([F:RUB]ROW)-"("+[F:RUB3]COD+")",1) From GESECRAN
#    Rang existant
#   Else
    [F:RUB2] = [F:RUB]
    If EXISTE
     Rewrite [RUB2]
    Else
     Write [RUB2]
    Endif
    If fstat
     GOK = 0 : Call FSTA("RUB2") From GLOCK : Break
    Endif
    Call ECR_TRACE(num$([F:RUB]ROW)-[F:RUB]COD-mess(95,10702,1),0) From GESECRAN : # Rubrique copiée
    For K=1 To NBPRF
     Read [CRB]CRB0 = [F:RUB]COD;TBPRF(K);[F:RUB]LEG
     If fstat
      Read [CRB2]CRB0 = [F:RUB]COD;TBPRF(K);[F:RUB]LEG
      If !fstat
       Delete [CRB2]
       If fstat=1
        GOK = 1 : GLOCK = "$CALRUB"-[F:RUB]COD-TBPRF(K)-GCURLEG : Break
       Endif
      Endif
     Else
      Read [CRB2]CRB0 = [F:RUB]COD;TBPRF(K);[F:RUB]LEG
      If fstat
       [F:CRB2] = [F:CRB]
       Write [CRB2]
       If fstat
        GOK = 0 : Call FSTA("CRB2") From GLOCK : Break
       Endif
      #63287 : si le rang de la rubrique a changé il faut maj CALRUB
      Elsif [F:CRB2]ROW <> [F:RUB]ROW
       [F:CRB2]ROW = [F:RUB]ROW
       Rewrite [CRB2]
       If fstat
        GOK = 0 : Call FSTA("CRB2") From GLOCK : Break
       Endif
      #
      Endif
     Endif
    Next K
   Endif
#  Endif
 Next
 Filter [RUB]
 If   GOK<0 : Goto ROLL_RUB
 Elsif !GOK : Goto AB_RUB
 Endif
Commit
Return

$AB_RUB
Rollback
Return

$ROLL_RUB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_RUB : Endif

###########################################################
$COPVAR
FICHIER = "VARIA"
CLE     = "COD"
BDEB    = VARDEB
BFIN    = VARFIN
TIT     = "Variable"
Gosub COPIE_FIC
###59769
FICHIER = "CALVAR"
CLE     = "COD"
BDEB    = VARDEB
BFIN    = VARFIN
TIT     = "Variable par Profil"
Gosub COPIE_FIC
####
Return

###########################################################
$COPCUM
Local File =DOSORG+".CUMUL"     [CUM]
Local File =DOSDES+".CUMUL"     [CUM2]
Local File =DOSDES+".CUMUL"     [CUM3]
Call ECR_TRACE(mess(96,10702,1),0) From GESECRAN : # Copie des cumuls
If CUMFIN="" : CUMFIN = "z" : Endif
Call DEBTRANS From GLOCK
Gosub TR_CUM
Call ECR_TRACE("",0) From GESECRAN
Close Local File [CUM] , [CUM2] , [CUM3]
Return

$TR_CUM
GOK = 1
Trbegin [CUM2]
 If ACTIV<>""
  Filter [CUM] Where CODACT=ACTIV
 Endif
 For [CUM]CUM0 Where CUMCOD>=CUMDEB & CUMCOD<=CUMFIN & LEG=GCURLEG
  Readlock [CUM2]CUM0 = [F:CUM]LEG;[F:CUM]CUMCOD
  If fstat=1
   GOK = -1 : GLOCK = "$CUMUL"-[F:CUM]CUMCOD : Break
  Elsif !fstat
   EXISTE = 1
   If [F:CUM2]CODACT<>"" & [F:CUM2]CODACT<>ACTIV
    Call ECR_TRACE([F:CUM]CUMCOD-":"-mess(93,10702,1)-[F:CUM2]CODACT,1) From GESECRAN : # Code activité
    COPIE = 0
   Else
    COPIE = 1
   Endif
  Else
   EXISTE = 0
   COPIE  = 1
  Endif
  If COPIE
   #51668
   If EXISTE
    RANG = [F:CUM2]CUMROW
   Else
   # fin 51668
    Read [CUM3]CUM1 = [F:CUM]LEG;[F:CUM]CUMROW
    If !fstat
     Read [CUM3]CUM1 Last
     RANG = [F:CUM3]CUMROW+1
    Else
     RANG = [F:CUM]CUMROW
    Endif
   Endif
   If EXISTE
    [F:CUM2] = [F:CUM]
    [F:CUM2]CUMROW = RANG
    Rewrite [CUM2]
   Else
    [F:CUM2] = [F:CUM]
    [F:CUM2]CUMROW = RANG
    Write [CUM2]
   Endif
   If fstat
    GOK = 0 : Call FSTA("CUM2") From GLOCK : Break
   Endif
   Call ECR_TRACE([F:CUM]CUMCOD-":"-mess(97,10702,1),0) From GESECRAN : # Cumul copié
  Endif
 Next
 Filter [CUM]
 If   GOK<0 : Goto ROLL_CUM
 Elsif !GOK : Goto AB_CUM
 Endif
Commit
Return

$AB_CUM
Rollback
Return

$ROLL_CUM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CUM : Endif

###########################################################
$COPEXO
FICHIER = "EXOPAY"
CLE     = "COD"
BDEB    = EXODEB
BFIN    = EXOFIN
TIT     = mess(98,10702,1) : # Exonération
Gosub COPIE_FIC
Return

###########################################################
$COPPAR
Local File =DOSORG+".ADOPAR"    [ADP]
Local File =DOSORG+".ADOVAL"    [ADW]
Local File =DOSDES+".ADOPAR"    [ADP2]
Local File =DOSDES+".ADOVAL"    [ADW2]
Call ECR_TRACE(mess(99,10702,1),0) From GESECRAN : # Copie des paramètres
Call DEBTRANS From GLOCK
Gosub TR_PAR
Call ECR_TRACE("",0) From GESECRAN
Close Local File [ADP] , [ADW] , [ADP2] , [ADW2]
Return

$TR_PAR
GOK = 1
Trbegin [ADW2]
 For [ADP]ADP0 Where CHAPITRE="PLA"
  Read [ADW]ADW0 = "";"";[F:ADP]PARAM
  If !fstat
   Readlock [ADW2]ADW0 = "";"";[F:ADP]PARAM
   If fstat=1
    GOK = -1 : GLOCK = "$ADOVAL"-[F:ADP]PARAM : Break
   Elsif !fstat
    EXISTE = 1
   Else
    EXISTE = 0
   Endif
   COPIE = 1
   If COPIE
    If EXISTE
     [F:ADW2] = [F:ADW]
     Rewrite [ADW2]
    Else
     [F:ADW2] = [F:ADW]
     Write [ADW2]
    Endif
    If fstat
     GOK = 0 : Call FSTA("ADW2") From GLOCK : Break
    Endif
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_PAR
 Elsif !GOK : Goto AB_PAR
 Endif
Commit
Return

$AB_PAR
Rollback
Return

$ROLL_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif

###########################################################
$COPGRI
FICHIER = "GRILLE"
CLE     = "COD"
BDEB    = GRIDEB
BFIN    = GRIFIN
TIT     = mess(100,10702,1) : # Grille
Gosub COPIE_FIC
Return

###########################################################
$COPREG
If filinfo(filpath("FIL","REGUL","fde",DOSORG),0)<1 | filinfo(filpath("FIL","REGUL","fde",DOSDES),0)<1
 Call ECR_TRACE(mess(142,10702,1),-1) From GESECRAN : # Régularisations non copiées
 Return
Endif
FICHIER = "REGUL"
CLE     = "COD"
BDEB    = REGDEB
BFIN    = REGFIN
TIT     = mess(101,10702,1) : # Régularisation
Gosub COPIE_FIC
Return

###########################################################
$COPDEC
FICHIER = "DECCHARGE"
CLE     = "CODDCC"
BDEB    = DECDEB
BFIN    = DECFIN
TIT     = mess(102,10702,1) : # Déclaration charges
Gosub COPIE_FIC
Return

###########################################################
$COPLIV
FICHIER = "LIVREPAYE"
CLE     = "COD"
BDEB    = LIVDEB
BFIN    = LIVFIN
TIT     = mess(103,10702,1) : # Livre de paye
Gosub COPIE_FIC
Return

###########################################################
$COPLPM
FICHIER = "MSLIVREPAY"
CLE     = "COD"
BDEB    = LPMDEB
BFIN    = LPMFIN
TIT     = mess(50,10722,1) : # Livre de paye masse salariale
Gosub COPIE_FIC
Return

###########################################################
$COPVLA
If filinfo(filpath("FIL","VALFDR","fde",DOSORG),0)<1 | filinfo(filpath("FIL","VALEUR","fde",DOSORG),0)<1
& | filinfo(filpath("FIL","VALFDR","fde",DOSDES),0)<1 | filinfo(filpath("FIL","VALEUR","fde",DOSDES),0)<1
 Call ECR_TRACE(mess(141,10702,1),-1) From GESECRAN : # Valeurs dossiers non copiées
 Return
Endif
Local File =DOSORG+".VALFDR"   [VFD]
Local File =DOSDES+".VALFDR"   [VFD2]
Local File =DOSORG+".VALEUR"   [VLA]
Local File =DOSDES+".VALEUR"   [VLA2]
Local File =DOSDES+".VARIA"    [VRA2]
Call ECR_TRACE(mess(131,10702,1),0) From GESECRAN : # Copie des valeurs dossiers
If DATFIN=[0/0/0] : DATFIN = DATDEB : Endif
Call DEBTRANS From GLOCK
Gosub TR_VLA
Call ECR_TRACE("",0) From GESECRAN
Close Local File [VFD] , [VFD2] , [VLA], [VLA2]
Return

$TR_VLA
GOK = 1
Trbegin [VFD2],[VLA2]
 For [VFD]VFD0 Where DAT>=DATDEB & DAT<=DATFIN
  Readlock [VFD2]VFD0 = [F:VFD]DAT
  If fstat=1
   GOK = -1 : GLOCK = "$VALFDR"-num$([F:VFD]DAT) : Break
  Elsif !fstat
   EXISTE = 1
  Else
   EXISTE = 0
  Endif
  If !EXISTE
   Raz [F:VFD2]
   [F:VFD2]DAT = [F:VFD]DAT
   [F:VFD2]CREUSR=GUSER
   [F:VFD2]CREDAT=date$
   [F:VFD2]CRETIM=time
   Write [VFD2]
  Else
   [F:VFD2]UPDUSR=GUSER
   [F:VFD2]UPDDAT=date$
   [F:VFD2]UPDTIM=time
   Rewrite [VFD2]
  Endif
  If fstat
   GOK = 0 : Call FSTA("VFD2") From GLOCK : Break
  Endif
  For [VLA]VLA0 Where TYP=1 & DAT=[F:VFD]DAT & LEG=GCURLEG
   Readlock [VLA2]VLA0 = [F:VLA]TYP;[F:VLA]LEG;[F:VLA]CPY;[F:VLA]FCY;[F:VLA]EMP;[F:VLA]DAT;[F:VLA]VARCOD
   If fstat=1
    GOK = -1 : GLOCK = "$VALEUR"-num$([F:VLA]TYP)-[F:VLA]CPY-[F:VLA]FCY-[F:VLA]EMP-num$([F:VLA]DAT)-[F:VLA]VARCOD : Break
   Elsif !fstat
    EXISTE = 1
   Else
    EXISTE = 0
   Endif
   If !EXISTE
    #si c'est bien une variable dossier on crée la valeur
    Read [F:VRA2]VRA0=GCURLEG;[F:VLA]VARCOD
    If !fstat & [F:VRA2]FLGFDR=2
     Raz [F:VLA2]
     [F:VLA2]VARCOD=[F:VLA]VARCOD
     [F:VLA2]DAT=[F:VLA]DAT
     [F:VLA2]TYP=[F:VLA]TYP
     [F:VLA2]VARVAL=[F:VLA]VARVAL
     [F:VLA2]LEG=[F:VLA]LEG
     Write [VLA2]
     If fstat
      GOK = 0 : Call FSTA("VLA2") From GLOCK : Break
     Endif
     # valeur dossier copiée
     Call ECR_TRACE(num$([F:VLA]DAT)-[F:VLA]VARCOD-":"-mess(132,10702,1),0) From GESECRAN
    Else
     # valeur dossier non copiée : Variable dossier inexistante dans le dossier de destination
     Call ECR_TRACE(num$([F:VLA]DAT)-[F:VLA]VARCOD-":"-mess(133,10702,1)-":"-mess(134,10702,1)-DOSDES,1) From GESECRAN
    Endif
   Else
    #Maj que si la valeur a changée
    If [F:VLA2]VARVAL<>[F:VLA]VARVAL
     [F:VLA2]VARVAL=[F:VLA]VARVAL
     Rewrite [VLA2]
     If fstat
      GOK = 0 : Call FSTA("VLA2") From GLOCK : Break
     Endif
     Call ECR_TRACE(num$([F:VLA]DAT)-[F:VLA]VARCOD-":"-mess(132,10702,1),0) From GESECRAN : # valeur dossier copiée
    Endif
   Endif
  Next
 Next
 If   GOK<0 : Goto ROLL_VLA
 Elsif !GOK : Goto AB_VLA
 Endif
Commit
Return

$AB_VLA
Rollback
Return

$ROLL_VLA
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_VLA : Endif

###########################################################
$COPIE_FIC
Call ECR_TRACE(mess(104,10702,1)-TIT,0) From GESECRAN : # Copie
Local File =DOSORG+"."+FICHIER [F1]
Local File =DOSDES+"."+FICHIER [F2]
Call DEBTRANS From GLOCK
Gosub TR_COP
Call ECR_TRACE("",0) From GESECRAN
Close Local File [F1] , [F2]
Return

$TR_COP
GOK = 1
CRITERE = "1=1"

If dim([F:F1]LEG)>=0
 CRITERE -='& LEG="'+GCURLEG+'"'
Endif

If ACTIV<>"" & dim([F:F1]CODACT)>0
 CRITERE -= '& CODACT="'+ACTIV+'"'
Endif
If BDEB<>""
 CRITERE -= '&'-CLE+'>="'+BDEB+'"'
Endif
If BFIN="" : BFIN = "zzz" : Endif
If BFIN<>""
 CRITERE -= '&'-CLE+'<="'+BFIN+'"'
Endif
Filter [F1]Where evalue(CRITERE)
Trbegin [F2]
 For [F1]
  [F:F2] = [F:F1]
  Readlock [F2] =
  If fstat=1
   GOK = -1 : GLOCK = "$"+FICHIER-evalue("[F:F1]"+CLE) : Break
  Elsif !fstat
   EXISTE = 1
   If dim([F:F1]CODACT)>0
    If [F:F2]CODACT<>"" & [F:F2]CODACT<>ACTIV
     Call ECR_TRACE(evalue("[F:F2]"+CLE)-":"-mess(93,10702,1)-[F:F2]CODACT,1) From GESECRAN : # Code activité
     COPIE = 0
    Else
     COPIE = 1
    Endif
   Else
    COPIE = 1
   Endif
  Else
   EXISTE = 0
   COPIE  = 1
  Endif
  If COPIE
   If EXISTE
    [F:F2] = [F:F1]
    Rewrite [F2]
   Else
    [F:F2] = [F:F1]
    Write [F2]
   Endif
   If fstat
    GOK = 0 : Call FSTA("F2") From GLOCK : Break
   Endif
   Call ECR_TRACE(evalue("[F:F2]"+CLE)-":"-TIT-mess(105,10702,1),0) From GESECRAN : # copié
  Endif
 Next
 Filter [F1]
 If   GOK<0 : Goto ROLL_COP
 Elsif !GOK : Goto AB_COP
 Endif
Commit
Return

$AB_COP
Rollback
Return

$ROLL_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

###########################################################
$EFFACE
For FICHIER = "VARIA","CUMUL","EXOPAY","GRILLE","REGUL","DECCHARGE","LIVREPAYE", "MSLIVREPAY"
 Gosub EFF_FIC
Next FICHIER
Local File =DOSDES+".RUBRIQUE" [RUB2]
Local File =DOSDES+".PROFIL"   [PRF2]
Local File =DOSDES+".CALRUB"   [CRB2]
Gosub EFF_RUB
Close Local File [RUB2] , [PRF2] , [CRB2]
Local File =DOSORG+".ADOPAR"   [ADP]
Local File =DOSDES+".ADOVAL"   [ADW2]
Gosub EFF_PAR
Close Local File [ADP] , [ADW2]
Return

$EFF_FIC
If filinfo(filpath("FIL",FICHIER,"fde",DOSDES),0)<1
 Return
Endif
Local File =DOSDES+"."+FICHIER [F2]
Call DEBTRANS From GLOCK
Gosub TR_EFF
Close Local File [F2]
Return

$TR_EFF
GOK = 1
Trbegin [F2]

CRITERE = "1=1"
If dim([F:F2]LEG)>=0
 CRITERE -='& LEG="'+GCURLEG+'"'
Endif
If ACTIV<>"" & dim([F:F2]CODACT)>0
 CRITERE -= '& (CODACT="'+ACTIV+'" | CODACT="")'
Endif
Delete [F2] Where evalue(CRITERE)
If fstat=1
 GOK = -1 : GLOCK = "$"+FICHIER : Goto ROLL_EFF
Endif
Filter [F2]
Commit
Return

$ROLL_EFF
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EFF : Endif

$EFF_RUB
GOK = 1
Trbegin [RUB2]

 If ACTIV<>""
  Filter [RUB2] Where (CODACT="" or CODACT=ACTIV) and LEG=GCURLEG
 Else
  Filter [RUB2] Where LEG=GCURLEG
 Endif
 If ACTIV<>""
  For [RUB2]RUB0
   For K=1 To NBPRF
    Delete [CRB2] Where PRFCOD=TBPRF(K) & COD=[F:RUB2]COD & LEG=GCURLEG
    If fstat=1
     GOK = -1 : GLOCK = "$CALRUB"-[F:RUB2]COD-TBPRF(K)-GCURLEG : Break 2
    Endif
   Next K
  Next
 Else
  For K=1 To NBPRF
   Delete [CRB2] Where PRFCOD=TBPRF(K) & LEG=GCURLEG
   If fstat=1
    GOK = -1 : GLOCK = "$CALRUB"-TBPRF(K)-GCURLEG : Break
   Endif
  Next K
 Endif
 If GOK<0 : Goto ROLL_EFF_RUB : Endif
 Delete [RUB2] Where LEG=GCURLEG
 If fstat=1
  GOK = -1 : GLOCK = "$RUBRIQUE" : Goto ROLL_EFF_RUB
 Endif
 Filter [RUB2]
Commit
Return

$ROLL_EFF_RUB
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto EFF_RUB : Endif

$EFF_PAR
GOK = 1
Trbegin [ADW2]
 For [ADP]ADP0 Where CHAPITRE="PLA"
  Delete [ADW2] Where CMP="" & FCY="" & PARAM=[F:ADP]PARAM
  If fstat=1
   GOK = -1 : GLOCK = "$ADOVAL"-[F:ADP]PARAM : Break
  Endif
 Next
 If GOK<0 : Goto ROLL_EFF_PAR : Endif
Commit
Return

$ROLL_EFF_PAR
Rollback
Call ROLL From GLOCK
If !GROLL : Goto EFF_PAR : Endif
Return

