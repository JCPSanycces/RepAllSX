Subprog AM_ALLLEG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M]LEG="" : Grizo [M]LEG
 GCURLEG="" : GLEGFIL=""
Else
 GLEGFIL=SAV_GLEGFIL
 [M]LEG=GLEGFIL : Actzo [M]LEG
 Call AM_LEG([M]LEG) From DIVPAYE
Endif
Affzo [M]LEG
End


