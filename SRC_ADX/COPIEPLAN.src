Subprog C_DES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]SRC : mkstat = 1 : Endif
End

Subprog C_CPL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo 30,40,60,70
 Grizo 30,40,60,70
 [M]RUB = 2
 [M]VRA = 2
 [M]CUM = 2
 [M]EXO = 2
 [M]PAR = 2
 [M]GRI = 2
 [M]REG = 2
 [M]DEC = 2
 [M]LIV = 2
 #75651
 If func AFNC.ACTIV("MAS") : [M]LPM = 2 : Endif
 Affzo 20,50
 Grizo 20,50
Else
 Actzo 20,50
Endif
End

#85585
Subprog AM_CPL(VALEUR)
Variable Integer VALEUR
Local Integer OK
#Attention, cette opération va écraser la totalité du plan de paie du dossier de destination, voulez-vous continuer ?
If VALEUR=2
 OK = 2
 Call AVERTIR (mess(229,10702,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : End : Endif
Endif
End

