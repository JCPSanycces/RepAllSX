#<AdxTL>@(#)0.0.0.0 $Revision$Class Project
# Supervisor
## ATY-ATYPE ## PJT
# 2018-11-09 07:14:53 250

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,PIMNUM,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char PIMNUM
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File PIMPL [PIM]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".PIMPL" [PIM]
Endif

Default File [F:PIM]
Read [F:PIM]PIM0 = [L]PIMNUM
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PIMNUM)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "FGR"
  [L]ATSTFILTER = (10=10) : [L]AMESFILTER= func ASYRFNC.TEXTE(0)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]PIMNUM)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


