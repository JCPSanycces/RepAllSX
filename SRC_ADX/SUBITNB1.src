#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des interventions                     Module CRM       aout 2000      #
##########################################################################################################
# FILITNPLC    : Renseigne le lieu de l'intervention.
# LOADITNPLC   : Charge un autre lieu de rendez-vous
# SETSREINF    : Définit les valeurs par défaut de l'intervention en cas de tunnel depuis
#                une demande de service.
# DEFPIO       : Programme de renvoi du code de niveau de priorité défini par défaut.
# CNVMILKLM    : Programme de conversion de kilomètres en miles et inversement.
# CHKAUSDISP   : Vérifie la disponibilité du technicien
# CHKDISIBAP   : Contrôle des conflits horaires avec des rendez-vous
# MNGUPDITNDAT : Assure la gestion des réservations de ressources en cas de modif de la date
#                d'une intervention
# UPDRRSORI    : On met à jour les nouvelles origine des réservations de ressources
# CLEANRRSORI  : Assure l'exactitude de l'origine des réservations de ressources.
# UPDRRSITN    : On met à jour les réservations de ressources sur la base du nouvel horaire de l'intervention.
# LOCKSRE      : Contrôle du conflit en modification avec demande de service
# UNLOCKSRE    : Libère le verrouillage d'une demande de service
# CHKLOCKSRE   : Test un conflit en modification avec demande de service
# DISPICON     : Affichage des icônes en en-tête
# SAVEHD2      : Enregistrement du CLOB compte-rendu
# DELHD2       : Suppression du CLOB compte-rendu
# LOADHD2      : Chargement du CLOB compte-rendu
# DELRRS       : Suppression des réservations de ressources
# DISPCCN      : Affichage de l'interlocuteur
# RAZITN3      : Efface la totalité du masque ITN3
# RAZITN8      : Efface la totalité du masque ITN8
# CLOITN       : Clôture d'une demande de service depuis une intervention
# SETSREDONSAT : Défini une demande de service dans l'état demande satisfaite
# GETINVFLG    : Détermine si la demande est facturable ou totalement gratuite. Classe F et M.
# GET2INVFLG   : Détermine si la demande est facturable ou totalement gratuite. Classe F uniquement
# GETHDK4SPG   : Calcul pour du beurre du temps réellement passé sur une intervention (Classe F)
# LOADTIMHDT   : Calcul du bloc de gestion du temps des consommations.
# CPTSPGTIM    : Calcul du temps réellement passé sur une intervention (Classe M)
# ITNSPGTIM    : Calcul du temps réellement passé sur une intervention (Classe F)
# DEFSPGTIM    : Propose une durée réelle par défaut pour une consommation de type main d'oeuvre
# AFF_TITCOL   : affiche les titres des  colonnes des axes analytiques
##########################################################################################################
Subprog LECTURE_RESRES (ILIGNE, SZAPTRER)
Value Integer ILIGNE
Value Char SZAPTRER

  # FGR 24/07/2009 : X3SUIVI56702
  Read [RRS]RRS0=SZAPTRER
  If !fstat Then
    Read [RSS]RSS0=[F:RRS]RSSNUM
    # FGR 24/09/2009 : X3SUIVI58059
    #[M:ITN7]RSS(ILIGNE) = left$([F:RSS]TTR, GLONNAM)
    #Call LECTEXTRA([M:ITN7]RSS(ILIGNE),"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
    # FGR 30/09/2009 : X3SUIVI57403
    [M:ITN7]RSSNUM(ILIGNE) = [F:RRS]RSSNUM
    [M:ITN7]RERSTRDAT(ILIGNE) = [F:RRS]RERDAT
    [M:ITN7]RERSTRHOU(ILIGNE) = [F:RRS]HOUSTR
    [M:ITN7]RERENDDAT(ILIGNE) = [F:RRS]RERDATEND
    [M:ITN7]RERENDHOU(ILIGNE) = [F:RRS]HOUEND
    Read [AUS]CODUSR=[F:RRS]CREUSR
    If fstat Then
      [M:ITN7]RSSREP(ILIGNE) = [F:RRS]CREUSR
    Else
      [M:ITN7]RSSREP(ILIGNE) = [F:AUS]NOMUSR
    Endif
  Endif
End

##########################################################################################################
Subprog SET_LIEU_ITN(SZTYPE, SZSALFCY, SZBPC, SZCCN)
Value Char SZTYPE
Value Char SZSALFCY
Value Char SZBPC
Value Char SZCCN

Local Char SZLIBPLC(5)

  SZLIBPLC = func GET_LIEU_ITN(SZTYPE, 0)
  If SZLIBPLC = "" Then
    #Appel ou autres ne nécessitant pas d'adresse.
    Call FILITNPLC("NOWHERE", "BPC", SZSALFCY)
  Elsif SZLIBPLC = "OUT" Then
    #Intervention sur site
    If SZBPC <> "" Then
      Call FILITNPLC(SZLIBPLC, "BPC", SZBPC)
    Elsif SZBPC = "" and SZCCN <> "" Then
      Call FILITNPLC(SZLIBPLC, "CCN", SZCCN)
    Elsif [M:ITN0]BPC = "" and [M:ITN0]CCN = "" Then
      Call FILITNPLC("NOWHERE", "", SZSALFCY)
    Endif
  Elsif SZLIBPLC = "IN" Then
    #Intervention en nos locaux
    Call FILITNPLC(SZLIBPLC, "BPC", SZSALFCY)
  Endif
End

##########################################################################################################
Funprog GET_LIEU_ITN(SZTYPE, I_DFT_OUT)
Value Char SZTYPE
Value Integer I_DFT_OUT

Local Char SZLIBPLC(5)

  # FGR 22/02/2010 : X3SUIVI62661 : Dissociation lieu intervention et gestion des conflits
  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  Read [ADI]CODE=407;SZTYPE
  If fstat Then
    SZLIBPLC = "OUT"
  Else
    Case [F:ADI]N1
      When 1
        SZLIBPLC = ""
      When 2
        SZLIBPLC = "OUT"
      When 3
        SZLIBPLC = "IN"
      When Default
        If I_DFT_OUT = 1 Then
          SZLIBPLC = "OUT"
        Else
          SZLIBPLC = ""
        Endif
    Endcase
  Endif
End SZLIBPLC

##########################################################################################################
Funprog GET_CONFLIT_ITN(SZTYPE, I_DFT_OUT)
Value Char SZTYPE
Value Integer I_DFT_OUT

Local Char SZLIBPLC(5)

  # FGR 22/02/2010 : X3SUIVI62661 : Dissociation lieu intervention et gestion des conflits
  # FGR 22/02/2010 : X3SUIVI62661 : Note conserve "OUT"/"IN" pour réduire impact/risque sur le code existant
  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  Read [ADI]CODE=407;SZTYPE
  If fstat Then
    SZLIBPLC = "OUT"
  Else
    Case [F:ADI]N2
      When 1
        SZLIBPLC = "OUT"      # Conflit interdit
      When 2
        SZLIBPLC = "IN"       # Conflit autorisé
      When Default
        If I_DFT_OUT = 1 Then
          SZLIBPLC = "OUT"    # Conflit interdit
        Else
          SZLIBPLC = "IN"     # Conflit autorisé
        Endif
    Endcase
  Endif
End SZLIBPLC

##########################################################################################################
#  FILITNPLC  : Renseigne le lieu de l'intervention.
##############################################################
Subprog FILITNPLC(CODPLC, SZPLCTYP, SZBPR)
Value Char CODPLC
Value Char SZPLCTYP
Variable Char SZBPR

Local Char CODADDDEF(GLONADR)          # FGR 27/10/2015 : X3SUIVI111913
Local Integer INOTMACBPR
Local Integer ICCNADDRESS
Local Char SZTHIRDBPR(GLONVCR)         # FGR 27/10/2015 : X3SUIVI111913

  INOTMACBPR = 0
  ICCNADDRESS = 0
  SZTHIRDBPR = ""
  [M:ITN3]ITNTYPADD = 1
  #Déroute le traitement vers la définition d'un lieu interlocuteur.
  If SZPLCTYP = "CCN" Then
    Call XCCN_ITN(SZBPR, SZPLCTYP, ICCNADDRESS)
    End
  Endif
  #Obtient le code adresse par défaut pour la société à visiter
  Case CODPLC
    When "OUT"
      #If !clalev([F:BPR]) Local File BPARTNER [BPR] : Endif         # FGR 27/10/2015 : X3SUIVI111913
      #If !clalev([F:MAC]) Local File MACHINES [MAC] : Endif         # FGR 27/10/2015 : X3SUIVI111913
      #If !clalev([F:SRE]) Local File SERREQUEST [SRE] : Endif       # FGR 27/10/2015 : X3SUIVI111913
      Local File BPARTNER [BPR]                                      # FGR 27/10/2015 : X3SUIVI111913
      Local File BPCUSTOMER [BPC]                                    # FGR 04/11/2015 : X3SUIVI111913
      Local File MACHINES [MAC]                                      # FGR 27/10/2015 : X3SUIVI111913
      Local File SERREQUEST [SRE]                                    # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]ITNTYPADD = 2
      If SZBPR = "" Then
        If [M:ITN0]BPC = "" Then
          If [M:ITN0]CCN = "" Then
            End
          Else
            Call XCCN_ITN(SZBPR, SZPLCTYP, ICCNADDRESS)
            End
          Endif
        Else
          #Read [BPR]BPR0=[M:ITN0]BPC                                # FGR 04/11/2015 : X3SUIVI111913
          Read [BPC]BPC0=[M:ITN0]BPC                                 # FGR 04/11/2015 : X3SUIVI111913
        Endif
      Else
        #Read [BPR]BPR0=SZBPR                                        # FGR 04/11/2015 : X3SUIVI111913
        Read [BPC]BPC0=SZBPR                                         # FGR 04/11/2015 : X3SUIVI111913
      Endif
      #Détermine la valeur de CODADDDEF
      If [M:ITN0]MAC = "" Then
        If [M:ITN0]SRVDEMNUM = "" Then
          #CODADDDEF = [F:BPR]BPAADD                                 # FGR 04/11/2015 : X3SUIVI111913
          CODADDDEF = [F:BPC]BPAADD                                  # FGR 04/11/2015 : X3SUIVI111913
        Else
          Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
          If fstat Then
            #CODADDDEF = [F:BPR]BPAADD                               # FGR 04/11/2015 : X3SUIVI111913
            CODADDDEF = [F:BPC]BPAADD                                # FGR 04/11/2015 : X3SUIVI111913
          Else
            If [F:SRE]SREBPAADD = "" Then
              #CODADDDEF = [F:BPR]BPAADD                             # FGR 04/11/2015 : X3SUIVI111913
              CODADDDEF = [F:BPC]BPAADD                              # FGR 04/11/2015 : X3SUIVI111913
            Else
              CODADDDEF = [F:SRE]SREBPAADD
            Endif
          Endif
        Endif
      Else
        Read [MAC]MAC0=[M:ITN0]MAC
        If fstat Then
          If [M:ITN0]SRVDEMNUM = "" Then
            #CODADDDEF = [F:BPR]BPAADD                               # FGR 04/11/2015 : X3SUIVI111913
            CODADDDEF = [F:BPC]BPAADD                                # FGR 04/11/2015 : X3SUIVI111913
          Else
            Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
            If fstat Then
              #CODADDDEF = [F:BPR]BPAADD                             # FGR 04/11/2015 : X3SUIVI111913
              CODADDDEF = [F:BPC]BPAADD                              # FGR 04/11/2015 : X3SUIVI111913
            Else
              If [F:SRE]SREBPAADD = "" Then
                #CODADDDEF = [F:BPR]BPAADD                           # FGR 04/11/2015 : X3SUIVI111913
                CODADDDEF = [F:BPC]BPAADD                            # FGR 04/11/2015 : X3SUIVI111913
              Else
                CODADDDEF = [F:SRE]SREBPAADD
              Endif
            Endif
          Endif
        Else
          If [F:MAC]FCYITN = "" Then
            If [F:MAC]BPCNUM = SZBPR Then
              If [M:ITN0]SRVDEMNUM = "" Then
                CODADDDEF = [F:BPR]BPAADD
              Else
                Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
                If fstat Then
                  #CODADDDEF = [F:BPR]BPAADD                         # FGR 04/11/2015 : X3SUIVI111913
                  CODADDDEF = [F:BPC]BPAADD                          # FGR 04/11/2015 : X3SUIVI111913
                Else
                  If [F:SRE]SREBPAADD = "" Then
                    #CODADDDEF = [F:BPR]BPAADD                       # FGR 04/11/2015 : X3SUIVI111913
                    CODADDDEF = [F:BPC]BPAADD                        # FGR 04/11/2015 : X3SUIVI111913
                  Else
                    CODADDDEF = [F:SRE]SREBPAADD
                  Endif
                Endif
              Endif
            Else
              #La machines en panne n'est pas celle du client
              If [F:MAC]BPCNUM = "" Then
                #Il ne s'agit pas d'un tiers
                #On doit aller chez un particulier
                If [F:MAC]CCNNUM = "" Then
                  #Le particulier n'est pas indiqué.
                  #On se rend finalement sur le site du client de la demande de service
                  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
                  If fstat Then
                    #CODADDDEF = [F:BPR]BPAADD                       # FGR 04/11/2015 : X3SUIVI111913
                    CODADDDEF = [F:BPC]BPAADD                        # FGR 04/11/2015 : X3SUIVI111913
                  Else
                    If [F:SRE]SREBPAADD = "" Then
                      #CODADDDEF = [F:BPR]BPAADD                     # FGR 04/11/2015 : X3SUIVI111913
                      CODADDDEF = [F:BPC]BPAADD                      # FGR 04/11/2015 : X3SUIVI111913
                    Else
                      CODADDDEF = [F:SRE]SREBPAADD
                    Endif
                  Endif
                Else
                  CODADDDEF = ""
                  INOTMACBPR = 1
                  ICCNADDRESS = 1
                  SZTHIRDBPR = [F:MAC]CCNNUM
                Endif
              Endif
            Endif
          Else
            If [F:MAC]BPCNUM = SZBPR Then
              CODADDDEF = [F:MAC]FCYITN
            Else
              #La machines en panne n'est pas celle du client
              If [F:MAC]BPCNUM = "" Then
                #Il ne s'agit pas d'un tiers
                #On doit aller chez un particulier
                If [F:MAC]CCNNUM = "" Then
                  #Le particulier n'est pas indiqué.
                  #On se rend finalement sur le site du client de la demande de service
                  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
                  If fstat Then
                    CODADDDEF = [F:BPR]BPAADD
                  Else
                    If [F:SRE]SREBPAADD = ""
                      #CODADDDEF = [F:BPR]BPAADD                     # FGR 04/11/2015 : X3SUIVI111913
                      CODADDDEF = [F:BPC]BPAADD                      # FGR 04/11/2015 : X3SUIVI111913
                    Else
                      CODADDDEF = [F:SRE]SREBPAADD
                    Endif
                  Endif
                Else
                  CODADDDEF = ""
                  INOTMACBPR = 1
                  ICCNADDRESS = 1
                  SZTHIRDBPR = [F:MAC]CCNNUM
                Endif
              Else
                CODADDDEF = [F:MAC]FCYITN
                INOTMACBPR = 1
                ICCNADDRESS = 0
                SZTHIRDBPR = [F:MAC]BPCNUM
              Endif
            Endif
          Endif
        Endif
      Endif
      #Close Local File [BPR]                                        # FGR 27/10/2015 : X3SUIVI111913
      #If !clalev([F:BPA]) Local File BPADDRESS [BPA] : Endif        # FGR 27/10/2015 : X3SUIVI111913
      Local File BPADDRESS [BPA]                                     # FGR 27/10/2015 : X3SUIVI111913
      If INOTMACBPR Then
        If ICCNADDRESS Then
          Call XCCN_ITN(SZBPR, SZPLCTYP, ICCNADDRESS)
          End
        Else
          Read [BPA]BPA0=1;SZTHIRDBPR;CODADDDEF
        Endif
      Else
        If SZBPR = "" Then
          Read [BPA]BPA0=1;[M:ITN0]BPC;CODADDDEF
        Else
          Read [BPA]BPA0=1;SZBPR;CODADDDEF
        Endif
      Endif
      If !fstat Then
        [M:ITN3]ADD(0) = [F:BPA]BPAADDLIG(0)
        [M:ITN3]ADD(1) = [F:BPA]BPAADDLIG(1)
        [M:ITN3]ADD(2) = [F:BPA]BPAADDLIG(2)
        [M:ITN3]ZIP = [F:BPA]POSCOD
        [M:ITN3]CTY = [F:BPA]CTY
        [M:ITN3]CRY = [F:BPA]CRY
        [M:ITN3]SAT = [F:BPA]SAT
        [M:ITN3]TEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        [M:ITN3]MOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
        [M:ITN3]EML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
      Endif
      Affzo [M:ITN3]1-99
      #Close Local File [BPA]                                        # FGR 27/10/2015 : X3SUIVI111913
    When "IN"
      #If !clalev([F:FCY]) Local File FACILITY [FCY] : Endif         # FGR 27/10/2015 : X3SUIVI111913
      Local File FACILITY [FCY]                                      # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]ITNTYPADD = 4
      If SZBPR = "" Then
        [M:ITN3]ADD(0) = ""
        [M:ITN3]ADD(1) = ""
        [M:ITN3]ADD(2) = ""
        [M:ITN3]ZIP = ""
        [M:ITN3]CTY = ""
        [M:ITN3]CRY = ""
        [M:ITN3]SAT = ""
        [M:ITN3]TEL = ""
        [M:ITN3]MOB = ""               # FGR 27/10/2015 : X3SUIVI111913
        [M:ITN3]EML = ""               # FGR 27/10/2015 : X3SUIVI111913
        Affzo [M:ITN3]1-99
        End
      Else
        Read [FCY]FCY0=SZBPR
        If fstat Then
          [M:ITN3]ADD(0) = ""
          [M:ITN3]ADD(1) = ""
          [M:ITN3]ADD(2) = ""
          [M:ITN3]ZIP = ""
          [M:ITN3]CTY = ""
          [M:ITN3]CRY = ""
          [M:ITN3]SAT = ""
          [M:ITN3]TEL = ""
          [M:ITN3]MOB = ""             # FGR 27/10/2015 : X3SUIVI111913
          [M:ITN3]EML = ""             # FGR 27/10/2015 : X3SUIVI111913
          Affzo [M:ITN3]1-99
          End
        Endif
      Endif
      CODADDDEF = [F:FCY]BPAADD
      #If !clalev([F:BPA]) Local File BPADDRESS [BPA] : Endif        # FGR 27/10/2015 : X3SUIVI111913
      Local File BPADDRESS [BPA]                                     # FGR 27/10/2015 : X3SUIVI111913
      Read [BPA]BPA0=3;SZBPR;CODADDDEF
      If !fstat Then
        [M:ITN3]ADD(0) = [F:BPA]BPAADDLIG(0)
        [M:ITN3]ADD(1) = [F:BPA]BPAADDLIG(1)
        [M:ITN3]ADD(2) = [F:BPA]BPAADDLIG(2)
        [M:ITN3]ZIP = [F:BPA]POSCOD
        [M:ITN3]CTY = [F:BPA]CTY
        [M:ITN3]CRY = [F:BPA]CRY
        [M:ITN3]SAT = [F:BPA]SAT
        [M:ITN3]TEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
        [M:ITN3]MOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
        [M:ITN3]EML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
      Endif
      Affzo [M:ITN3]1-99
      #Close Local File [BPA]                                        # FGR 27/10/2015 : X3SUIVI111913
    When "NOWHERE"
      [M:ITN3]ITNTYPADD = 0
      [M:ITN3]ADD(0) = ""
      [M:ITN3]ADD(1) = ""
      [M:ITN3]ADD(2) = ""
      [M:ITN3]ZIP = ""
      [M:ITN3]CTY = ""
      [M:ITN3]CRY = ""
      [M:ITN3]SAT = ""
      [M:ITN3]TEL = ""
      [M:ITN3]MOB = ""             # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]EML = ""             # FGR 27/10/2015 : X3SUIVI111913
      Affzo [M:ITN3]1-99
    When Default
  Endcase
End

##########################################################################################################
#Remplit le lieu de l'intervention pour un interlocuteur
Subprog XCCN_ITN(SZBPR, SZPLCTYP, ICCNADDRESS)
Value Char SZBPR
Value Char SZPLCTYP
Value Integer ICCNADDRESS

  If ICCNADDRESS Then
    Read [AIN]AIN0=SZTHIRDBPR
  Else
    If SZPLCTYP = "CCN" Then
      Read [AIN]AIN0=SZBPR
    Else
      Read [AIN]AIN0=[M:ITN0]CCN
    Endif
  Endif
  If fstat Then
    End
  Else
    [M:ITN3]ADD(0) = [F:AIN]ADD(0)
    [M:ITN3]ADD(1) = [F:AIN]ADD(1)
    [M:ITN3]ADD(2) = [F:AIN]ADD(2)
    [M:ITN3]ZIP = [F:AIN]ZIP
    [M:ITN3]CTY = [F:AIN]CTY
    [M:ITN3]CRY = [F:AIN]CRY
    [M:ITN3]SAT = [F:AIN]SAT
    [M:ITN3]TEL = [F:AIN]CNTETS
    [M:ITN3]MOB = [F:AIN]CNTMOB   # FGR 27/10/2015 : X3SUIVI111913
    [M:ITN3]EML = [F:AIN]CNTEMA   # FGR 27/10/2015 : X3SUIVI111913
    [M:ITN3]ITNTYPADD = 1
    Affzo [M:ITN3]1-99
  Endif
End

##########################################################################################################
# Charge un autre lieu de rendez-vous
##############################################################
Subprog LOADITNPLC
  #If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif          # FGR 27/10/2015 : X3SUIVI111913
  #If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif            # FGR 27/10/2015 : X3SUIVI111913
  #If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif           # FGR 27/10/2015 : X3SUIVI111913
  Local File BPADDRESS [BPA]                                         # FGR 27/10/2015 : X3SUIVI111913
  Local File COMPANY [CPY]                                           # FGR 27/10/2015 : X3SUIVI111913
  Local File FACILITY [FCY]                                          # FGR 27/10/2015 : X3SUIVI111913
  If [M:ITN3]ITNTYPADD = 1 Then
    Read [AIN]AIN0=[M:ITN3]ITNRECADD
    #Adresse Interlocuteur
    If fstat Then
      [M:ITN3]ADD(0) = [F:ITN]ADD(0)
      [M:ITN3]ADD(1) = [F:ITN]ADD(1)
      [M:ITN3]ADD(2) = [F:ITN]ADD(2)
      [M:ITN3]ZIP = [F:ITN]ZIP
      [M:ITN3]CTY = [F:ITN]CTY
      [M:ITN3]CRY = [F:ITN]CRY
      [M:ITN3]SAT = [F:ITN]SAT
      [M:ITN3]TEL = [F:ITN]TEL
      [M:ITN3]MOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]EML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
    Else
      [M:ITN3]ADD(0) = [F:AIN]ADD(0)
      [M:ITN3]ADD(1) = [F:AIN]ADD(1)
      [M:ITN3]ADD(2) = [F:AIN]ADD(2)
      [M:ITN3]ZIP = [F:AIN]ZIP
      [M:ITN3]CTY = [F:AIN]CTY
      [M:ITN3]CRY = [F:AIN]CRY
      [M:ITN3]SAT = [F:AIN]SAT
      [M:ITN3]TEL = [F:AIN]CNTETS
      [M:ITN3]MOB = [F:AIN]CNTMOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]EML = [F:AIN]CNTEMA   # FGR 27/10/2015 : X3SUIVI111913
    Endif
  Elsif [M:ITN3]ITNTYPADD > 1 Then
    If [M:ITN3]ITNTYPADD = 2 Then
      #Adresse Tiers
      Read [BPA]BPA0=1;[M:ITN3]ITNRECADD;[M:ITN3]ITNCODADD
    Elsif [M:ITN3]ITNTYPADD = 3 Then
      #Adresse Société
      Read [BPA]BPA0=2;[M:ITN3]ITNRECADD;[M:ITN3]ITNCODADD
    Elsif [M:ITN3]ITNTYPADD = 4 Then
      #Adresse Site
      Read [BPA]BPA0=3;[M:ITN3]ITNRECADD;[M:ITN3]ITNCODADD
    Endif
    If fstat Then
      [M:ITN3]ADD(0) = [F:ITN]ADD(0)
      [M:ITN3]ADD(1) = [F:ITN]ADD(1)
      [M:ITN3]ADD(2) = [F:ITN]ADD(2)
      [M:ITN3]ZIP = [F:ITN]ZIP
      [M:ITN3]CTY = [F:ITN]CTY
      [M:ITN3]CRY = [F:ITN]CRY
      [M:ITN3]SAT = [F:ITN]SAT
      [M:ITN3]TEL = [F:ITN]TEL
      [M:ITN3]MOB = [F:ITN]MOB   # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]EML = [F:ITN]EML   # FGR 27/10/2015 : X3SUIVI111913
    Else
      [M:ITN3]ADD(0) = [F:BPA]BPAADDLIG(0)
      [M:ITN3]ADD(1) = [F:BPA]BPAADDLIG(1)
      [M:ITN3]ADD(2) = [F:BPA]BPAADDLIG(2)
      [M:ITN3]ZIP = [F:BPA]POSCOD
      [M:ITN3]CTY = [F:BPA]CTY
      [M:ITN3]CRY = [F:BPA]CRY
      [M:ITN3]SAT = [F:BPA]SAT
      [M:ITN3]TEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:ITN3]MOB = [F:BPA]TEL(4)   # FGR 27/10/2015 : X3SUIVI111913
      [M:ITN3]EML = [F:BPA]WEB(0)   # FGR 27/10/2015 : X3SUIVI111913
    Endif
  Endif
End

##########################################################################################################
#  SETSREINF : Définit les valeurs par défaut de l'intervention en cas de tunnel depuis
#                une demande de service.
##########################################################################################################
Subprog SETSREINF(SZCONTEXT)
Value Char SZCONTEXT

Local Char SZCODPLC
Local Integer ISRE7NBMAC

  ISRE7NBMAC = 0
  SZCODPLC = ""
  If [M:ITN0]SRVDEMNUM = "" Then
    Raz [M:ITN0]BPC
    Raz [M:ITN0]CCN
    Raz [M:ITN0]MAC
    Raz [M:ITN0]MACGRU
    Raz [M:ITN0]SALFCY
    Raz [M:ITN0]SRESTOFCY
    Call RAZITN3(1)
    Call RAZITN8(1)
    End
  Endif
  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    Raz [M:ITN0]BPC
    Raz [M:ITN0]CCN
    Raz [M:ITN0]MAC
    Raz [M:ITN0]MACGRU
    Raz [M:ITN0]SALFCY
    Raz [M:ITN0]SRESTOFCY
    Call RAZITN3(1)
    Call RAZITN8(1)
    End
  Else
    #En-tête
    [M:ITN0]BPC = [F:SRE]SREBPC
    [M:ITN0]CCN = [F:SRE]SRECCN
    [M:ITN0]MAC = [F:SRE]SREMAC
    [M:ITN0]SALFCY = [F:SRE]SALFCY
    [M:ITN0]SRESTOFCY = [F:SRE]STOFCY
    #Si l'utilisateur est le responsable de la demande de service. On le reprend sur l'intervention.
    If [F:SRE]SREASS = 2 Then
      # = 2 => Collaborateur (message=975)
      [M:ITN1]SCO = 1
      [M:ITN1]SCOAMT = 0
      [M:ITN1]CUR = ""
      [M:ITN1]ITNASS = [F:SRE]SREDET
      [M:ITN1]REP = [F:SRE]SREDET
      [M:ITN1]SCONUM = ""
      Read [AUS]CODUSR=[M:ITN1]ITNASS
      If fstat Then
        [M:ITN1]ITNASSCLA = ""
      Else
        [M:ITN1]ITNASSCLA = [F:AUS]NOMUSR
      Endif
    Elsif [F:SRE]SREASS = 1 Then
      # = 1 => Dispatching (message=975)
      # FGR 23/01/2008 X3Suivi 45357
      If [F:SRE]SREDET <> "" Then
        [M:ITN1]ITNASS = [F:SRE]SREDET
      Else
        [M:ITN1]ITNASS = [M:ITN1]CREUSR
      Endif
      Read [AUS]CODUSR=[M:ITN1]ITNASS
      If fstat Then
        [M:ITN1]ITNASSCLA = ""
      Else
        [M:ITN1]ITNASSCLA = [F:AUS]NOMUSR
      Endif
    Endif
    If [M:ITN1]ITNASS <> "" Then
      Call AM_ITNASS([M:ITN1]ITNASS) From SUBITN
    Endif
    #Onglet Adresse
    Call SET_LIEU_ITN([M:ITN1]TYP, [M:ITN0]SALFCY, [M:ITN0]BPC, [M:ITN0]CCN)
    #Sortie de stock
    [M:ITN0]TRSCOD = [F:SRE]TRSCOD
    [M:ITN0]ENTCOD = [F:SRE]ENTCOD
    [M:ITN0]TRSFAM = [F:SRE]TRSFAM
    # Chargement des consommations.
    Case SZCONTEXT
      When "RAZCRE"
        If GPILNAV > 1 Then
          If GNAVIG(GPILNAV-1) = "GESSRE" Then
            If [M:SRE7]SRENAVTYP = "HDN" Then
              Call LOADHDTCRE("HDN", [M:ITN0]SRVDEMNUM, "", 0) From SUBITNB2
            Else
              Call LOADHDTCRE("", [M:ITN0]SRVDEMNUM, [M:SRE7]ITNGRUVAL, [M:SRE7]NBMAC) From SUBITNB2
            Endif
          Elsif GNAVIG(GPILNAV-1) = "FUNHDKAGD" Then
            #On détermine si il y a du parc sur la demande indiquée
            ISRE7NBMAC = 0
            Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM
            For [SRM]
              ISRE7NBMAC += 1
            Next
            Filter [SRM]
            Call LOADHDTCRE("", [M:ITN0]SRVDEMNUM, "", ISRE7NBMAC) From SUBITNB2
          Endif
        Endif
      When "AM"
        #On commence par nettoyer l'écran
        Call RAZITN8(1) From SUBITNB1
        #On détermine si il y a du parc sur la demande indiquée
        ISRE7NBMAC = 0
        Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM
        For [SRM]
          ISRE7NBMAC += 1
        Next
        Filter [SRM]
        Call LOADHDTCRE("", [M:ITN0]SRVDEMNUM, "", ISRE7NBMAC) From SUBITNB2
    Endcase
    If [F:SRE]SREASS = 5 Then
      Grizo [M:ITN8]5
    Else
      Actzo [M:ITN8]5
    Endif
  Endif
  If [M:ITN0]SALFCY <> "" Then
    GFCY = [M:ITN0]SALFCY
    Call GETDEV(GFCY) From DEVSUB
  Endif
End

##########################################################################################################
#Programme de renvoi du code de niveau de priorité défini par défaut.        #
##############################################################################
Subprog DEFPIO(CODETAB, PIODEF)
Value Integer CODETAB
Variable Char PIODEF

  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  PIODEF = ""
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB
  For [ADI]
    If [F:ADI]A2 <> "" Then
      PIODEF = [F:ADI]CODE
      Break
    Endif
  Next
  Filter [ADI]
End

##########################################################################################################
#Programme de conversion de kilomètres en miles et inversement.              #
##############################################################################
Subprog CNVMILKLM(SZITNNUM, IORIUNIT, IDESUNIT, IDTC)
Value Char SZITNNUM
Value Integer IORIUNIT
Value Integer IDESUNIT
Variable Integer IDTC

Local Integer ITER
Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
Local Char SZCLE
Local Integer ICLECOUNT
Local Integer ICUT
Local Char SZMESS(250)
Local Integer IONREP
Local Integer INEWDTC
Local Integer IJAUGE
Local Integer IBOITEOK
Local Integer IITNMAX

  IONREP = 0
  SZMESS = ""
  INEWDTC = 0
  IJAUGE = 0
  IBOITEOK = 0
  IITNMAX = nbrecord([F:ITN])
  IPERF = 0
  IPBL = 0
  INTR = 0
  ITER = 1
  SZCLE = ""
  ICUT = 1750
  ICLECOUNT = ICUT
  If IORIUNIT = 1 and IDESUNIT = 2 Then
    #Vous allez procéder à la conversion des distances de toutes les interventions de la base en Miles.
    SZMESS = mess(613,196,1) - mess(615,196,1)
  Elsif IORIUNIT = 2 and IDESUNIT = 1 Then
    #Vous allez procéder à la conversion des distances de toutes les interventions de la base en Kilomètres.
    SZMESS = mess(614,196,1) - mess(615,196,1)
  Else
    SZMESS = ""
  Endif
  If SZMESS = "" Then
    #Les informations nécessaires à la conversion sont incorrectes. Accès refusé.
    GMESSAGE = mess(616,196,1)
    GERR = 1
    End
  Else
    Call OUINON(SZMESS, IONREP) From GESECRAN
    If IONREP <> 2 Then
      End
    Endif
  Endif
  If GINTRA Then
    Call TEMPON("E") From GESECRAN
  Else
    #Conversion des distances
    Call OUVRE_BOITE(mess(618,196,1), IITNMAX) From GESECRAN
  Endif
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [ITN] Where [F:ITN]NUM > SZCLE
    For [ITN]
      SZCLE = [F:ITN]NUM
      If IPERF = 0 Then
        If !INTR Then
          Call DEBTRANS From GLOCK
          Trbegin [ITN]
          INTR = 1
        Endif
      Endif
      If [F:ITN]DTCKIL > 0 Then
        INEWDTC = 0
        If IORIUNIT = 1 and IDESUNIT = 2 Then
          #Conversion des kilomètres en miles"
          INEWDTC = int([F:ITN]DTCKIL * 0.621)
          [F:ITN]DTCKIL = INEWDTC
        Else
          #Conversion des miles en kilomètres"
          INEWDTC = int([F:ITN]DTCKIL * 1.609)
          [F:ITN]DTCKIL = INEWDTC
        Endif
        If [F:ITN]NUM = SZITNNUM Then
          IDTC = INEWDTC
        Endif
        Rewrite [ITN]
        If fstat Then
          IPBL = 1
          INTR = 0
          Rollback
          Break
        Else
          If IPERF >= 500 Then
            Commit
            INTR = 0
            IPERF = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      If !GINTRA Then
        Call AFF_BOITE (mess(618,196,1), IJAUGE, IBOITEOK) From GESECRAN
        IJAUGE += 1
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
      If IPBL Then
        Break
      Endif
    Next
    Filter [ITN]
    If IPBL Then
      Break
    Endif
  Wend
  If GINTRA Then
    Call TEMPOFF From GESECRAN
  Else
    Call FERME_BOITE From GESECRAN
  Endif
  If IPBL Then
    #Erreur lors de la conversion des distances.
    GMESSAGE = mess(617,196,1)
    GERR = 1
  Endif
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Read [ITN]ITN0=SZITNNUM
End

##########################################################################################################
#  CHKAUSDISP : Vérifie la disponibilité du technicien
########################################################################################
$CHKAUSDISP
Local Integer Y
Local Integer Y2
Local Integer Y3
Local Integer ICONFLICT
Local Char SZCODPLC(5)
Local Char SZCODPLC2(5)
Local Integer IRSFOUND
Local Char SZREPTOCTL(GLONREP)
Local Char SZCFLITNLIS(GLONVCR)(10)
Local Integer IITNINF (10)
Local Integer IFULL
Local Integer ICONFLICT

Local Integer INBCTL
Local Integer IPTPOS
Local Integer IC1DAYC
Local Decimal IC1HOURC
Local Char SZC1HOURC
Local Decimal IC1MINUTEC
Local Decimal IC1TOTC
Local Integer IC2DAYC
Local Decimal IC2HOURC
Local Char SZC2HOURC
Local Decimal IC2MINUTEC
Local Decimal IC2TOTC

Local Integer IF1DAYC
Local Decimal IF1HOURC
Local Char SZF1HOURC
Local Decimal IF1MINUTEC
Local Decimal IF1TOTC
Local Integer IF2DAYC
Local Decimal IF2HOURC
Local Char SZF2HOURC
Local Decimal IF2MINUTEC
Local Decimal IF2TOTC

  Y = 0
  Y2 = 0
  Y3 = 0
  ICONFLICT = 0
  SZCODPLC = ""
  SZCODPLC2 = ""
  IRSFOUND = 0
  SZREPTOCTL = ""
  Raz SZCFLITNLIS
  Raz IITNINF
  IFULL = 0
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  IPTPOS = 0
  IC1DAYC = nday([M:ITN1]DAT)
  IC1MINUTEC = val(mid$([M:ITN1]HOU, 3, 2)) / 60
  IC1HOURC = ((100 * val(left$([M:ITN1]HOU, 2))) / 24) + IC1MINUTEC
  IPTPOS = instr(1, num$(IC1HOURC), '.')
  If IPTPOS Then
    SZC1HOURC = left$(num$(IC1HOURC), IPTPOS-1) + right$(num$(IC1HOURC), IPTPOS+1)
  Else
    SZC1HOURC = num$(IC1HOURC)
  Endif
  IC1TOTC = val(num$(IC1DAYC) + '.' + SZC1HOURC)
  IPTPOS = 0
  IC2DAYC = nday([M:ITN1]DATEND)
  IC2MINUTEC = val(mid$([M:ITN1]HOUEND, 3, 2)) / 60
  IC2HOURC = ((100 * val(left$([M:ITN1]HOUEND, 2))) / 24) + IC2MINUTEC
  IPTPOS = instr(1, num$(IC2HOURC), '.')
  If IPTPOS Then
    SZC2HOURC = left$(num$(IC2HOURC), IPTPOS-1) + right$(num$(IC2HOURC), IPTPOS+1)
  Else
    SZC2HOURC = num$(IC2HOURC)
  Endif
  IC2TOTC = val(num$(IC2DAYC) + '.' + SZC2HOURC)
  #Détermine le type de l'intervention courante
  #SZCODPLC = func GET_LIEU_ITN([M:ITN1]TYP, 0)      # FGR 22/02/2010 : X3SUIVI62661
  SZCODPLC = func GET_CONFLIT_ITN([M:ITN1]TYP, 0)    # FGR 22/02/2010 : X3SUIVI62661
  INBCTL = 0
  Y2 = 0
  While INBCTL < 3
    If INBCTL = 0 Then
      #Effectue un filtre à la journée prêt
      Filter [ITN] Where (([F:ITN]DAT >= [M:ITN1]DAT and [F:ITN]DAT <= [M:ITN1]DATEND) or ([F:ITN]DATEND >= [M:ITN1]DAT and [F:ITN]DATEND <= [M:ITN1]DATEND))
&                      and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2
    Elsif INBCTL = 1 Then
        Filter [ITN] Where ([F:ITN]DAT < [M:ITN1]DAT and [F:ITN]DATEND > [M:ITN1]DATEND) and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2
    Elsif INBCTL = 2 Then
        Filter [ITN] Where ([F:ITN]DAT > [M:ITN1]DAT and [F:ITN]DATEND < [M:ITN1]DATEND) and [F:ITN]DAT <> [00/00/00] and [F:ITN]DON <> 2
    Endif
    Y = 0
    For [ITN]ITN6
      If [F:ITN]NUM <> [M:ITN0]NUM Then
        IPTPOS = 0
        IF1DAYC = nday([F:ITN]DAT)
        IF1MINUTEC = val(mid$([F:ITN]HOU, 3, 2)) / 60
        IF1HOURC = ((100 * val(left$([F:ITN]HOU, 2))) / 24) + IF1MINUTEC
        IPTPOS = instr(1, num$(IF1HOURC), '.')
        If IPTPOS Then
          SZF1HOURC = left$(num$(IF1HOURC), IPTPOS-1) + right$(num$(IF1HOURC), IPTPOS+1)
        Else
          SZF1HOURC = num$(IF1HOURC)
        Endif
        IF1TOTC = val(num$(IF1DAYC) + '.' + SZF1HOURC)
        IPTPOS = 0
        IF2DAYC = nday([F:ITN]DATEND)
        IF2MINUTEC = val(mid$([F:ITN]HOUEND, 3, 2)) / 60
        IF2HOURC = ((100 * val(left$([F:ITN]HOUEND, 2))) / 24) + IF2MINUTEC
        IPTPOS = instr(1, num$(IF2HOURC), '.')
        If IPTPOS Then
          SZF2HOURC = left$(num$(IF2HOURC), IPTPOS-1) + right$(num$(IF2HOURC), IPTPOS+1)
        Else
          SZF2HOURC = num$(IF2HOURC)
        Endif
        IF2TOTC = val(num$(IF2DAYC) + '.' + SZF2HOURC)
        If IC1TOTC >= IF1TOTC and IC1TOTC <= IF2TOTC Then
          If IF2TOTC <> IC1TOTC Then
            ICONFLICT = 1
          Endif
        Endif
        If IC2TOTC >= IF1TOTC and IC2TOTC <= IF2TOTC Then
          If IF1TOTC <> IC2TOTC Then
            ICONFLICT = 1
          Endif
        Endif
        If IC1TOTC <= IF1TOTC and IC2TOTC >= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If ICONFLICT Then
          If SZTYPREP = "REP" Then
            #Vérifie la disponibilité du collaborateur.
            If [F:ITN]REP = [M:ITN1]REP Then
              If Y2 >= dim(SZCFLITNLIS) Then
                IFULL = 1
                Break
              Endif
              #SZCODPLC2 = func GET_LIEU_ITN([F:ITN]TYP, 0)      # FGR 22/02/2010 : X3SUIVI62661
              SZCODPLC2 = func GET_CONFLIT_ITN([F:ITN]TYP, 0)    # FGR 22/02/2010 : X3SUIVI62661
              If SZCODPLC2 = "OUT" Then
                If SZCODPLC = "OUT" Then
                  #Intervention sur site (Conflits interdits)
                  SZCFLITNLIS(Y2) = [F:ITN]NUM
                  IITNINF(Y2) = 1
                  Y2 += 1
                Else
                  #Autres types d'interventions avec conflits autorisés
                  SZCFLITNLIS(Y2) = [F:ITN]NUM
                  IITNINF(Y2) = 0
                  Y2 += 1
                Endif
              Else
                #Autres types d'interventions avec conflits autorisés
                SZCFLITNLIS(Y2) = [F:ITN]NUM
                IITNINF(Y2) = 0
                Y2 += 1
              Endif
            Endif
          Elsif SZTYPREP = "SCO" Then
            #Vérifie la disponibilité du prestataire.
            If [F:ITN]SCONUM = [M:ITN1]SCONUM Then
              If Y2 >= dim(SZCFLITNLIS) Then
                IFULL = 1
                Break
              Endif
              SZCFLITNLIS(Y2) = [F:ITN]NUM
              IITNINF(Y2) = 0
              Y2 += 1
            Endif
          Endif
          ICONFLICT = 0
        Endif
      Endif
    Next
    Filter [ITN]
    If IFULL Then
      Break
    Endif
    INBCTL += 1
  Wend
  If IFULL Then
    #Le nombre maximum d'interventions en conflit pour un collaborateur est atteint.
    #On bloque la saisie.
    REPISDISP = 4
    Return
  Endif
  REPISDISP = 0
  #Il n'y a aucune intervention en conflit. Pas la peine d'aller plus loin.
  If SZCFLITNLIS(0) = "" Then
    Return
  Endif
  #On recherche d'abord les interventions bloquantes
  If SZTYPREP = "REP" Then
    For Y = 0 To dim(IITNINF)-1
      If IITNINF(Y) Then
        #Recherche une intervention non encore affichée
        IRSFOUND = 0
        For Y2 = 0 To dim(GITN1CFLRS)-1
          If SZCFLITNLIS(Y) <> "" Then
            If GITN1CFLRS(Y2) <> "" Then
              If GITN1CFLRS(Y2) = SZCFLITNLIS(Y)
                IRSFOUND = 1
                Break
              Endif
            Endif
          Endif
        Next
        If !IRSFOUND Then
          #Cette intervention doit être affiché
          Read [ITN]ITN0=SZCFLITNLIS(Y)
          If !fstat Then
            SZSTRDAT = day$([F:ITN]DAT) - num$(day([F:ITN]DAT)) - month$([F:ITN]DAT) - num$(year([F:ITN]DAT))
            SZSTRHOU = left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
            SZENDDAT = day$([F:ITN]DATEND) - num$(day([F:ITN]DATEND)) - month$([F:ITN]DATEND) - num$(year([F:ITN]DATEND))
            SZENDHOU = left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
            REPISDISP = 1
            #Cherche une case de libre dans GITN1CFLRS
            For Y3 = 0 To dim(GITN1CFLRS)-1
              If GITN1CFLRS(Y3) = "" Then
                GITN1CFLRS(Y3) = SZCFLITNLIS(Y)
                Break
              Endif
            Next
          Endif
          Break
        Endif
      Endif
      If REPISDISP Then
        Break
      Endif
    Next
  Endif
  If !REPISDISP Then
    #Recherche un rendez-vous non encore affiché
    For Y = 0 To dim(SZCFLITNLIS)-1
      IRSFOUND = 0
      For Y2 = 0 To dim(GITN1CFLRS)-1
        If SZCFLITNLIS(Y) <> "" Then
          If GITN1CFLRS(Y2) <> "" Then
            If GITN1CFLRS(Y2) = SZCFLITNLIS(Y) Then
              IRSFOUND = 1
              Break
            Endif
          Endif
        Endif
      Next
      If !IRSFOUND Then
        #Cette intervention doit être affichée
        Read [ITN]ITN0=SZCFLITNLIS(Y)
        If !fstat Then
          SZSTRDAT = day$([F:ITN]DAT) - num$(day([F:ITN]DAT)) - month$([F:ITN]DAT) - num$(year([F:ITN]DAT))
          SZSTRHOU = left$([F:ITN]HOU, 2) + ":" + mid$([F:ITN]HOU, 3, 2)
          SZENDDAT = day$([F:ITN]DATEND) - num$(day([F:ITN]DATEND)) - month$([F:ITN]DATEND) - num$(year([F:ITN]DATEND))
          SZENDHOU = left$([F:ITN]HOUEND, 2) + ":" + mid$([F:ITN]HOUEND, 3, 2)
          #SZCODPLC2 =  func GET_LIEU_ITN([F:ITN]TYP, 0)      # FGR 22/02/2010 : X3SUIVI62661
          SZCODPLC2 =  func GET_CONFLIT_ITN([F:ITN]TYP, 0)    # FGR 22/02/2010 : X3SUIVI62661
          If SZCODPLC2 = "OUT" Then
            #Intervention sur site
            REPISDISP = 3
          Else
            #Autres types d'interventions
            REPISDISP = 2
          Endif
          #Cherche une case de libre dans GITN1CFLRS
          For Y2 = 0 To dim(GITN1CFLRS)-1
            If GITN1CFLRS(Y2) = "" Then
              GITN1CFLRS(Y2) = SZCFLITNLIS(Y)
              Break
            Endif
          Next
        Endif
        Break
      Endif
    Next
  Endif
Return

##########################################################################################################
#  CHKDISIBAP : Contrôle des conflits horaires avec des rendez-vous
########################################################################################
Subprog CHKDISIBAP(SZDDSTR, SZDDEND, SZBUSYREP, ISDISP)
Variable Char SZDDSTR
Variable Char SZDDEND
Variable Char SZBUSYREP
Variable Integer ISDISP

Local Char SZUSRREP
Local Integer Y
Local Integer Y2
Local Integer Y3
Local Integer ICONFLICT
Local Integer INBCTL
Local Char SZCODPLC
Local Integer IRSFOUND
Local Char SZREPTOCTL(GLONREP)
Local Char SZCFLITNLIS(GLONVCR)(10)
Local Integer IITNINF (10)
Local Integer IFULL
Local Integer IPTPOS
Local Integer IC1DAYC
Local Decimal IC1HOURC
Local Char SZC1HOURC
Local Decimal IC1MINUTEC
Local Decimal IC1TOTC
Local Integer IC2DAYC
Local Decimal IC2HOURC
Local Char SZC2HOURC
Local Decimal IC2MINUTEC
Local Decimal IC2TOTC
Local Integer IF1DAYC
Local Decimal IF1HOURC
Local Char SZF1HOURC
Local Decimal IF1MINUTEC
Local Decimal IF1TOTC
Local Integer IF2DAYC
Local Decimal IF2HOURC
Local Char SZF2HOURC
Local Decimal IF2MINUTEC
Local Decimal IF2TOTC

  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  Raz SZCFLITNLIS
  Raz IITNINF
  IFULL = 0
  SZREPTOCTL = ""
  Y2 = 0
  IRSFOUND = 0
  ISDISP = 0
  IPTPOS = 0
  IC1DAYC = nday([M:ITN1]DAT)
  IC1MINUTEC = val(mid$([M:ITN1]HOU, 3, 2)) / 60
  IC1HOURC = ((100 * val(left$([M:ITN1]HOU, 2))) / 24) + IC1MINUTEC
  IPTPOS = instr(1, num$(IC1HOURC), '.')
  If IPTPOS Then
    SZC1HOURC = left$(num$(IC1HOURC), IPTPOS-1) + right$(num$(IC1HOURC), IPTPOS+1)
  Else
    SZC1HOURC = num$(IC1HOURC)
  Endif
  IC1TOTC = val(num$(IC1DAYC) + '.' + SZC1HOURC)
  IPTPOS = 0
  IC2DAYC = nday([M:ITN1]DATEND)
  IC2MINUTEC = val(mid$([M:ITN1]HOUEND, 3, 2)) / 60
  IC2HOURC = ((100 * val(left$([M:ITN1]HOUEND, 2))) / 24) + IC2MINUTEC
  IPTPOS = instr(1, num$(IC2HOURC), '.')
  If IPTPOS
    SZC2HOURC = left$(num$(IC2HOURC), IPTPOS-1) + right$(num$(IC2HOURC), IPTPOS+1)
  Else
    SZC2HOURC = num$(IC2HOURC)
  Endif
  IC2TOTC = val(num$(IC2DAYC) + '.' + SZC2HOURC)
  #Obtient le code représentant de l'utilisateur passé en paramètre
  If SZBUSYREP <> "" Then
    Read [AUS]CODUSR=SZBUSYREP
    If !fstat Then
      Call PARAMUTIL("AUSCRMF", SZUSRREP, SZBUSYREP, "") From SUBAUS
      If SZUSRREP <> "" Then
        Read [REP]REP0=SZUSRREP
        If !fstat Then
          SZREPTOCTL = [F:REP]REPNUM
        Endif
      Endif
    Endif
  Endif
  If SZREPTOCTL = "" Then
    ISDISP = 0
    End
  Endif
  Y2 = 0
  INBCTL = 0
  While INBCTL < 3
    If INBCTL = 0 Then
      Filter [BAP] Where (([F:BAP]APTDAT >= [M:ITN1]DAT and [F:BAP]APTDAT <= [M:ITN1]DATEND) or ([F:BAP]APTDATEND >= [M:ITN1]DAT and [F:BAP]APTDATEND <= [M:ITN1]DATEND))
&                    and [F:BAP]APTDAT <> [00/00/00] and [F:BAP]APTDON <> 2
    Elsif INBCTL = 1 Then
      Filter [BAP] Where ([F:BAP]APTDAT < [M:ITN1]DAT and [F:BAP]APTDATEND > [M:ITN1]DATEND) and [F:BAP]APTDAT <> [00/00/00] and [F:BAP]APTDON <> 2
    Elsif INBCTL = 2 Then
      Filter [BAP] Where ([F:BAP]APTDAT > [M:ITN1]DAT and [F:BAP]APTDATEND < [M:ITN1]DATEND) and [F:BAP]APTDAT <> [00/00/00] and [F:BAP]APTDON <> 2
    Endif
    For [BAP]APP2
      If func SUBBAPB.GET_CONFLIT_BAP([F:BAP]APTTYP) = 1 Then
        # FGR 25/03/2009 : X3SUIVI53600 : on regarde les rendez-vous ayant une catégorie n'autorisant pas les conflits
        IPTPOS = 0
        IF1DAYC = nday([F:BAP]APTDAT)
        IF1MINUTEC = val(mid$([F:BAP]APTHOU, 3, 2)) / 60
        IF1HOURC = ((100 * val(left$([F:BAP]APTHOU, 2))) / 24) + IF1MINUTEC
        IPTPOS = instr(1, num$(IF1HOURC), '.')
        If IPTPOS Then
          SZF1HOURC = left$(num$(IF1HOURC), IPTPOS-1) + right$(num$(IF1HOURC), IPTPOS+1)
        Else
          SZF1HOURC = num$(IF1HOURC)
        Endif
        IF1TOTC = val(num$(IF1DAYC) + '.' + SZF1HOURC)
        IPTPOS = 0
        IF2DAYC = nday([F:BAP]APTDATEND)
        IF2MINUTEC = val(mid$([F:BAP]APTHOUEND, 3, 2)) / 60
        IF2HOURC = ((100 * val(left$([F:BAP]APTHOUEND, 2))) / 24) + IF2MINUTEC
        IPTPOS = instr(1, num$(IF2HOURC), '.')
        If IPTPOS Then
          SZF2HOURC = left$(num$(IF2HOURC), IPTPOS-1) + right$(num$(IF2HOURC), IPTPOS+1)
        Else
          SZF2HOURC = num$(IF2HOURC)
        Endif
        IF2TOTC = val(num$(IF2DAYC) + '.' + SZF2HOURC)
        If IC1TOTC >= IF1TOTC and IC1TOTC <= IF2TOTC Then
          ICONFLICT = 1
        Elsif IC2TOTC >= IF1TOTC and IC2TOTC <= IF2TOTC Then
          ICONFLICT = 1
        Elsif IC1TOTC <= IF1TOTC and IC2TOTC >= IF2TOTC Then
          ICONFLICT = 1
        Endif
        If ICONFLICT Then
          If Y2 >= dim(SZCFLITNLIS) Then
            IFULL = 1
            Break
          Endif
          For  Y = 0 To dim([F:BAP]APTREPNUM)-1
            If [F:BAP]APTREPNUM(Y) <> "" Then
              If [F:BAP]APTREPNUM(Y) = SZREPTOCTL Then
                SZCFLITNLIS(Y2) = [F:BAP]APTNUM
                If Y = 0 Then
                  IITNINF(Y2) = 1
                Else
                  IITNINF(Y2) = 0
                Endif
                Y2 += 1
              Endif
            Endif
          Next
        Endif
        ICONFLICT = 0
      Endif
    Next
    Filter [BAP]
    If IFULL Then
      Break
    Endif
    INBCTL += 1
  Wend
  If IFULL Then
    #Le nombre maximum d'interventions en conflit pour un collaborateur est atteint.
    #On bloque la saisie.
    ISDISP = 4
    End
  Endif
  ISDISP = 0
  #Il n'y a aucune intervention en conflit. Pas la peine d'aller plus loin.
  If SZCFLITNLIS(0) = "" Then
    End
  Endif
  #Recherche s'il y a au moins une intervention bloquante.
  #SZCODPLC = func GET_LIEU_ITN([M:ITN1]TYP, 0)      # FGR 22/02/2010 : X3SUIVI62661
  SZCODPLC = func GET_CONFLIT_ITN([M:ITN1]TYP, 0)    # FGR 22/02/2010 : X3SUIVI62661
  Y2 = 0
  For Y = 0 To dim(IITNINF)-1
    If IITNINF(Y) Then
      Read [BAP]APP0=SZCFLITNLIS(Y)
      If !fstat Then
        SZDDSTR = day$([F:BAP]APTDAT) - num$(day([F:BAP]APTDAT)) - month$([F:BAP]APTDAT) - num$(year([F:BAP]APTDAT)) - left$([F:BAP]APTHOU, 2) + ":" + mid$([F:BAP]APTHOU, 3, 2)
        SZDDEND = day$([F:BAP]APTDATEND) - num$(day([F:BAP]APTDATEND)) - month$([F:BAP]APTDATEND) - num$(year([F:BAP]APTDATEND)) - left$([F:BAP]APTHOUEND, 2) + ":" + mid$([F:BAP]APTHOUEND, 3, 2)
        If SZCODPLC = "OUT" Then
          #Intervention sur site (Conflits interdits)
          ISDISP = 1
          Break
        Else
          #Autres types d'interventions avec conflits autorisés
          #Recherche si le rendez-vous n'a pas déjà été affiché
          Y2 = 0
          IRSFOUND = 0
          For Y3 = 0 To dim(GITN1CFLRS)-1
            If SZCFLITNLIS(Y) <> "" Then
              If GITN1CFLRS(Y3) <> "" Then
                If GITN1CFLRS(Y3) = SZCFLITNLIS(Y) Then
                  IRSFOUND = 1
                  Break
                Endif
              Endif
            Endif
          Next
          If !IRSFOUND Then
            #Ce rendez-vous doit être affiché
            Read [BAP]APP0=SZCFLITNLIS(Y)
            If !fstat Then
              SZDDSTR = day$([F:BAP]APTDAT) - num$(day([F:BAP]APTDAT)) - month$([F:BAP]APTDAT) - num$(year([F:BAP]APTDAT)) - left$([F:BAP]APTHOU, 2) + ":" + mid$([F:BAP]APTHOU, 3, 2)
              SZDDEND = day$([F:BAP]APTDATEND) - num$(day([F:BAP]APTDATEND)) - month$([F:BAP]APTDATEND) - num$(year([F:BAP]APTDATEND)) - left$([F:BAP]APTHOUEND, 2) + ":" + mid$([F:BAP]APTHOUEND, 3, 2)
              ISDISP = 3
              #Cherche une case de libre dans GITN1CFLRS
              For Y3 = 0 To dim(GITN1CFLRS)-1
                If GITN1CFLRS(Y3) = "" Then
                  GITN1CFLRS(Y3) = SZCFLITNLIS(Y)
                  Break
                Endif
              Next
            Endif
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  If !ISDISP Then
    #Conflits autorisés pour les intervenants secondaires
    #Recherche un rendez-vous non encore affiché
    IRSFOUND = 0
    For Y = 0 To dim(SZCFLITNLIS)-1
      IRSFOUND = 0
      For Y2 = 0 To dim(GITN1CFLRS)-1
        If SZCFLITNLIS(Y) <> "" Then
          If GITN1CFLRS(Y2) <> "" Then
            If GITN1CFLRS(Y2) = SZCFLITNLIS(Y) Then
              IRSFOUND = 1
              Break
            Endif
          Endif
        Endif
      Next
      If !IRSFOUND Then
        #Cette intervention doit être affiché
        Read [BAP] APP0 = SZCFLITNLIS(Y)
        If !fstat Then
          SZDDSTR = day$([F:BAP]APTDAT) - num$(day([F:BAP]APTDAT)) - month$([F:BAP]APTDAT) - num$(year([F:BAP]APTDAT)) - left$([F:BAP]APTHOU, 2) + ":" + mid$([F:BAP]APTHOU, 3, 2)
          SZDDEND = day$([F:BAP]APTDATEND) - num$(day([F:BAP]APTDATEND)) - month$([F:BAP]APTDATEND) - num$(year([F:BAP]APTDATEND)) - left$([F:BAP]APTHOUEND, 2) + ":" + mid$([F:BAP]APTHOUEND, 3, 2)
          ISDISP = 2
          #Cherche une case de libre dans GITN1CFLRS
          For Y2 = 0 To dim(GITN1CFLRS)-1
            If GITN1CFLRS(Y2) = "" Then
              GITN1CFLRS(Y2) = SZCFLITNLIS(Y)
              Break
            Endif
          Next
        Endif
        Break
      Endif
    Next
  Endif
End

##########################################################################################################
# Assure la gestion des réservations de ressources en cas de modif de la date d'une intervention
#######################################################
$MNGUPDITNDAT
Local Integer IAPTDATUPD
Local Integer IAPTUPDITER
Local Integer ISRRSDISP
Local Integer ISFOG
Local Date DDATFOG
Local Char SZSTRFOG
Local Char SZENDFOG
Local Char SZPROMPT(250)
Local Char SZRRSCFL
Local Integer IPROMPTREP
Local Char SZDES(GLONDCO) # FGR 24/09/2009 : X3SUIVI58059

  DDATFOG = [M:ITN1]DATX + 4
  SZSTRFOG = "0900"
  SZENDFOG = "1800"
  IAPTDATUPD = 0
  ISRRSDISP = 1
  ISFOG = 0
  SZPROMPT = ""
  IPROMPTREP = 0
  SZRRSCFL = ""
  #On vérifie si une modification de dates à eu lieu
  If [M:ITN1]DATXINI<> [M:ITN1]DATX Then
    IAPTDATUPD = 1
  Endif
  If [M:ITN1]DATENDINI <> [M:ITN1]DATEND Then
    IAPTDATUPD = 1
  Endif
  If [M:ITN1]HOUINI <> [M:ITN1]HOU Then
    IAPTDATUPD = 1
  Endif
  If [M:ITN1]HOUENDINI <> [M:ITN1]HOUEND Then
    IAPTDATUPD = 1
  Endif
  If [M:ITN1]WEEINI <> [M:ITN1]WEE Then
    IAPTDATUPD = 1
  Endif
  If !IAPTDATUPD Then
    Return
  Endif
  #On vérifie si il existe au moins une réservation en conflit horaire
  For IAPTUPDITER = 0 To dim([M:ITN7]RER)-1
    If [M:ITN7]RER(IAPTUPDITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:ITN7]RER(IAPTUPDITER)
      If !fstat Then
        ISRRSDISP = 1
        ISFOG = 0
        If [M:ITN1]DAT = [00/00/00] Then
          Call CHKRRSDISP([F:RRS]RSSNUM, [M:ITN1]DATX, DDATFOG, [F:RRS]NUM, SZSTRFOG, SZENDFOG, ISRRSDISP, ISFOG, SZRRSCFL) From SUBRRSB
        Else
          Call CHKRRSDISP([F:RRS]RSSNUM, [M:ITN1]DATX, [M:ITN1]DATEND, [F:RRS]NUM, [M:ITN1]HOU, [M:ITN1]HOUEND, ISRRSDISP, ISFOG, SZRRSCFL) From SUBRRSB
        Endif
        If !ISRRSDISP Then
          If ISFOG Then
            Read [RSS]RSS0=[F:RRS]RSSNUM
            If fstat Then
              SZPROMPT = mess(177,182,1) - mess(557,196,1)
              Call OUINON(SZPROMPT, IPROMPTREP) From GESECRAN
              If IPROMPTREP = 2 Then
                GIITN1RRSUPD = 1
              Else
                OK = 0
              Endif
            Else
              # FGR 24/09/2009 : X3SUIVI58059
              #SZPROMPT = mess(551,196,1) - [F:RSS]TTR - mess(176,182,1) - mess(557,196,1)
              Call LECTEXTRA(SZDES,"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
              SZPROMPT = mess(551,196,1) - SZDES - mess(176,182,1) - mess(557,196,1)
              Call OUINON(SZPROMPT, IPROMPTREP) From GESECRAN
              If IPROMPTREP = 2 Then
                GIITN1RRSUPD = 1
              Else
                OK = 0
              Endif
            Endif
          Else
            Read [RSS]RSS0=[F:RRS]RSSNUM
            If fstat Then
              GMESSAGE = mess(175,182,1)
            Else
              # FGR 24/09/2009 : X3SUIVI58059
              #GMESSAGE = mess(551,196,1) - [F:RSS]TTR - mess(174,182,1)
              Call LECTEXTRA(SZDES,"RESOURCES","RSSDESAXX",[F:RSS]NUM,"") From ATEXTRA
              GMESSAGE = mess(551,196,1) - SZDES - mess(174,182,1)
            Endif
            OK = 0
            GERR = 3
          Endif
          Break
        Endif
      Endif
    Endif
  Next
  If !ISRRSDISP Then
    Return
  Endif
  GIITN1RRSUPD = 1
Return

##########################################################################################################
# On met à jour les nouvelles origine des réservations de ressources
#################################################################################
Subprog UPDRRSORI
Local Integer ITER

  For ITER = 0 To dim([M:ITN7]RER)-1
    If [M:ITN7]RER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:ITN7]RER(ITER)
      If !fstat Then
        If [F:RRS]RRSORI < 2 Then
          [F:RRS]RRSORI = 3
          [F:RRS]RRSORIVCR = [M:ITN0]NUM
          [F:RRS]RRSORIVCRL = 0
        Endif
        Rewrite [RRS]
        If fstat Then
          #Rollback
          #Erreur lors la mise à jour de l'origine des réservations de ressources.
          GMESSAGE = mess(172,182,1)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next
End

##########################################################################################################
# On met à jour les réservations de ressources sur la base du nouvel horaire de l'intervention.
#################################################################################
Subprog UPDRRSITN
Local Integer ITER
Local Integer IBAP5LIG

  If !GIITN1RRSUPD Then
    End
  Endif
  IBAP5LIG = 0
  For ITER = 0 To dim([M:ITN7]RER)-1
    If [M:ITN7]RER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:ITN7]RER(ITER)
      If !fstat Then
        If [M:ITN1]DAT = [00/00/00] Then
          [F:RRS]RERDAT = [M:ITN1]DATX
          [F:RRS]RERDATEND = [M:ITN1]DATX + 4
          [F:RRS]HOUSTR = "0900"
          [F:RRS]HOUEND = "1800"
        Else
          [F:RRS]RERDAT = [M:ITN1]DATX
          [F:RRS]RERDATEND = [M:ITN1]DATEND
          [F:RRS]HOUSTR = [M:ITN1]HOU
          [F:RRS]HOUEND = [M:ITN1]HOUEND
        Endif
        Rewrite [RRS]
        If fstat Then
          #Erreur lors la mise à jour du nouvel horaire sur les réservations de ressources.
          GMESSAGE = mess(554,196,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Endif
    Endif
  Next
  If GOK < 1 Then
    End
  Endif
  #On recharge le tableau des réservations de ressources sur la base du nouvel horaire
  For ITER = 0 To dim([F:ITN]RER)-1
    If [M:ITN7]RER(ITER) = "" Then
      Break
    Else
      Read [RRS]RRS0=[M:ITN7]RER(ITER)
      If !fstat Then
        # FGR 30/09/2009 : X3SUIVI57403
        #[M:ITN7]RSS(ITER) = left$([F:RRS]RSSTTR, 30)
        [M:ITN7]RSSNUM(ITER) = [F:RRS]RSSNUM
        [M:ITN7]RERSTRDAT(ITER) = [F:RRS]RERDAT
        [M:ITN7]RERSTRHOU(ITER) = [F:RRS]HOUSTR
        [M:ITN7]RERENDDAT(ITER) = [F:RRS]RERDATEND
        [M:ITN7]RERENDHOU(ITER) = [F:RRS]HOUEND
        Read [AUS]CODUSR=[F:RRS]CREUSR
        If fstat Then
          [M:ITN7]RSSREP(ITER) = [F:RRS]CREUSR
        Else
          [M:ITN7]RSSREP(ITER) = [F:AUS]NOMUSR
        Endif
      Endif
    Endif
    IBAP5LIG += 1
  Next
  [M:ITN7]NBRER = IBAP5LIG
  Affzo [M:ITN7]1-99
End

##########################################################################################################
Funprog GET_SYMBOLE_SRE(SZSRENUM)
Value Char SZSRENUM

Local Char SYMBOLE

  SYMBOLE = "CRMSREITN" + SZSRENUM
End SYMBOLE

##########################################################################################################
# Contrôle du conflit en modification avec demande de service
###################################################################
Subprog LOCKSRE(SZSRENUM, ICANGO)
Value Char SZSRENUM
Variable Integer ICANGO

Local Char SYMBOLE

  ICANGO = 1
  SYMBOLE = func GET_SYMBOLE_SRE(SZSRENUM)
  Lock =SYMBOLE With lockwait=0
  If fstat Then
    ICANGO = 0
  Else
    ICANGO = 1
  Endif
End

##########################################################################################################
# Libère le verrouillage d'une demande de service
###################################################################
Subprog UNLOCKSRE(SZSRENUM)
Value Char SZSRENUM

Local Char SYMBOLE

  SYMBOLE = func GET_SYMBOLE_SRE(SZSRENUM)
  Unlock =SYMBOLE
End

##########################################################################################################
# Test un conflit en modification avec demande de service
###################################################################
Subprog CHKLOCKSRE(SZSRENUM, ICANGO)
Value Char SZSRENUM
Variable Integer ICANGO

Local Char SYMBOLE

  ICANGO = 1
  SYMBOLE = func GET_SYMBOLE_SRE(SZSRENUM)
  Lock =SYMBOLE With lockwait=0
  If fstat Then
    ICANGO = 0
  Else
    ICANGO = 1
    Unlock =SYMBOLE
  Endif
End

##########################################################################################################
#Affichage des icônes en en-tête
######################################################
$DISPICON
  Gosub DEFICONNUM From CRMUTIL150
  #Synthèse Compte-rendu
  If len([M:ITN4]FULRPO) > GLONCLE Then
    If [M:ITN4]RPOFLG Then
      [M:ITN4]RPOICO = SZICOSYNDON
    Else
      [M:ITN4]RPOICO = SZICOSYN
    Endif
    Actzo [M:ITN4]RPOICO
  Else
    [M:ITN4]RPOICO = "-1"
    Grizo [M:ITN4]RPOICO
  Endif
  #Synthèse Complément d'informations
  If len([M:ITN1]FULOBJ) > GLONCLE Then
    If [M:ITN1]OBJFLG Then
      [M:ITN1]OBJICO = SZICOSYNDON
    Else
      [M:ITN1]OBJICO = SZICOSYN
    Endif
    Actzo [M:ITN1]OBJICO
  Else
    [M:ITN1]OBJICO = "-1"
    Grizo [M:ITN1]OBJICO
  Endif
Return

##########################################################################################################
Subprog DISPICON_BPC(ISTCTL)
Value Integer ISTCTL

  # FGR 15/02/2010 : X3SUIVI62427
  If ISTCTL = 3 Then
    If [M:ITN0]DON <> 2 Then
      [M:ITN0]ICOBPC = "151"
    Else
      [M:ITN0]ICOBPC = ""
    Endif
  Else
    [M:ITN0]ICOBPC = ""
  Endif
End

##########################################################################################################
#Enregistrement du CLOB compte-rendu
######################################################
$SAVEHD2
  Gosub DELHD2
  If GOK < 1 Then
    Return
  Endif

Local Char SZCTLCLOB(250)

  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:ITN4]FULRPO
  If SZCTLCLOB <> "" Then
    Raz [F:HD2]
    [F:HD2]NUM = [M:ITN4]NUMFULRPO
    [F:HD2]TYP = [M:ITN4]TYPFULRPO
    [F:HD2]CLOB = [M:ITN4]FULRPO
    Write [HD2]
    If fstat Then
      #Erreur lors de l'enregistrement du compte-rendu de l'intervention. Transaction abandonnée.
      GMESSAGE = mess(840,182,1)
      GERR = 1
      Call FSTA("HD2") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:ITN1]FULOBJ
  If SZCTLCLOB <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:ITN1]NUMFULOBJ
    [F:HD6]TYP = [M:ITN1]TYPFULOBJ
    [F:HD6]CLOB = [M:ITN1]FULOBJ
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement du complément d'informations de l'intervention. Transaction abandonnée.
      GMESSAGE = mess(852,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression du CLOB compte-rendu
######################################################
$DELHD2
  Delete [HD2] Where [F:HD2]NUM = [M:ITN4]NUMFULRPO and [F:HD2]TYP = [M:ITN4]TYPFULRPO
  If fstat Then
    #Erreur lors de la suppression du compte-rendu de l'intervention. Transaction abandonnée.
    GMESSAGE = mess(841,182,1)
    GERR = 1
    Call FSTA("HD2") From GLOCK
    GOK = 0
    Return
  Endif
  Delete [HD6] Where [F:HD6]NUM = [M:ITN1]NUMFULOBJ and [F:HD6]TYP = [M:ITN1]TYPFULOBJ
  If fstat Then
    #Erreur lors de la suppression du complément d'informations de l'intervention. Transaction abandonnée.
    GMESSAGE = mess(851,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB compte-rendu
######################################################
$LOADHD2
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:ITN4]NUMFULRPO = "" Then
    Raz [M:ITN4]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If [M:ITN4]TYPFULRPO = "" Then
    Raz [M:ITN4]FULRPO
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD2]HD20=[M:ITN4]NUMFULRPO;[M:ITN4]TYPFULRPO
    If fstat Then
      Raz [M:ITN4]FULRPO
    Else
      [M:ITN4]FULRPO = [F:HD2]CLOB
    Endif
  Endif
  ILOOKFORCLOB = 1
  If [M:ITN1]NUMFULOBJ = "" Then
    Raz [M:ITN1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If [M:ITN1]TYPFULOBJ = "" Then
    Raz [M:ITN1]FULOBJ
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:ITN1]NUMFULOBJ;[M:ITN1]TYPFULOBJ
    If fstat Then
      Raz [M:ITN1]FULOBJ
    Else
      [M:ITN1]FULOBJ = [F:HD6]CLOB
    Endif
  Endif
Return

##########################################################################################################
# Suppression des réservations de ressources
##################################################################
Subprog DELRRS(SZITNNUM)
Value Char SZITNNUM

Local Integer ZB

  #Supprime les éventuelles réservations de ressources effectuées
  For ZB = 0 To [M:ITN7]NBRER-1
    If [M:ITN7]RER(ZB) <> "" Then
      Delete [RRS] Where [F:RRS]NUM = [M:ITN7]RER(ZB)
      If fstat Then
        #Erreur lors de la suppression des réservations de ressources. Suppression interrompue.
        GMESSAGE = mess(476,196,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Endif
  Next
End

##########################################################################################################
#Affichage de l'interlocuteur
######################################################
$DISPCCN
  If [M:ITN0]CCN = "" Then
    [M:ITN0]CCNCLA = ""
  Else
    Read [AIN]AIN0=[M:ITN0]CCN
    If fstat Then
      [M:ITN0]CCNCLA = ""
    Else
      Call BUILDFULNAM("AIN", [M:ITN0]CCNCLA) From CRMUTIL140
    Endif
  Endif
Return

##########################################################################################################
# Efface la totalité du masque ITN3
