  #Tableau
  Raz [M:ITN8]NBLIG
  Raz [M:ITN8]HDTMACSRE
  Raz [M:ITN8]HDTCPN
  Raz [M:ITN8]HDTTYP
  Raz [M:ITN8]HDTITM
  Raz [M:ITN8]HDTQTY
  Raz [M:ITN8]HDTUOM
  Raz [M:ITN8]HDTAVA
  Raz [M:ITN8]HDTAVAUOM
  Raz [M:ITN8]HDTDONDAT
  Raz [M:ITN8]HDTDONHOU
  Raz [M:ITN8]BHDTDONHOU
  Raz [M:ITN8]HDTINV
  Raz [M:ITN8]HDTAMT
  Raz [M:ITN8]HDTCUR
  Raz [M:ITN8]SPGTIMHOU
  Raz [M:ITN8]SPGTIMMNT
  Raz [M:ITN8]HDTNUM
  Raz [M:ITN8]MANAMTFLG
  Raz [M:ITN8]HDTMACSET
  Raz [M:ITN8]VAT1
  Raz [M:ITN8]VAT2
  Raz [M:ITN8]VAT3
  Raz [M:ITN8]CLCAMT1
  Raz [M:ITN8]CLCAMT2
  Raz [M:ITN8]PRIREN
  Raz [M:ITN8]SAUSTUCOD
  Raz [M:ITN8]SAUSTUCOE
  Raz [M:ITN8]HDTSTU
  Raz [M:ITN8]HDTSTUQTY
  Raz [M:ITN8]DACCOE
