  #Bloc total
  Raz [M:ITN8]HOUSVCPLN
  Raz [M:ITN8]MNTSVCPLN
  Raz [M:ITN8]HOUSVCDON
  Raz [M:ITN8]MNTSVCDON
  Raz [M:ITN8]HOUSVCRMN
  Raz [M:ITN8]MNTSVCRMN
  If IAFF Then
    Affzo [M:ITN8]1-99
  Endif
End

##########################################################################################################
# Clôture d'une demande de service depuis une intervention
#############################################################################
Subprog CLOITN(SZSRENUM, SZITNNUM, SZBPC, IPBLSOL, IPREPBLSOL, IWISCLO, IWISSAT, IDONDATFLG, SZCONTEXT, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZSRENUM
Value Char SZITNNUM
Value Char SZBPC
Value Libelle IPBLSOL
Value Libelle IPREPBLSOL
Value Integer IWISCLO
Value Integer IWISSAT
Value Integer IDONDATFLG
Value Char SZCONTEXT
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT
Local Integer IHDTDONHOU
Local Integer IDONEFLG
Local Integer IINVFLG
Local Integer IREP
Local Integer ILESS
Local Integer IFIRSTSTEP
Local Char SZSKILLEDREP
Local Char SZQUEUE
Local Char SZCLO
Local Char SZSRE2REP
Local Char SZADICODE
Local Char SZPBLSRE
Local Integer ICREHISTOFLG
Local Integer IBDEBTRANSFLG

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1

  SZPBLSRE = ""
  SZCLO = ""
  SZSKILLEDREP = ""
  SZQUEUE = ""
  ILESS = 0
  IFIRSTSTEP = 0
  IREP = 0
  IDONEFLG = 0
  IINVFLG = 0
  SZSRE2REP = ""
  SZADICODE = ""
  ICREHISTOFLG = 0
  IERR = 0
  If !IWISCLO Then
    End
  Endif
  If IPBLSOL <> 2 Then
    End
  Endif
  If IPREPBLSOL = 2 Then
    End
  Endif
  If adxlog = 1 Then
    #On a une transaction en cours
    IBDEBTRANSFLG = 1
  Else
    #On n'a pas de transaction en cours
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SRE]
  Endif
  If IWISSAT Then
    #On ne clôture pas, on se contente de transformer l'état de la demande en : Demande satisfaite
    Gosub SETSREDONSAT
    If IBDEBTRANSFLG = 0 Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    End
  Endif
  #On clôture
  #Etape 1 : Lecture de la demande de service
  If SZSRENUM = "" Then
    #La demande de service à clôturer n'a pas pu être identifiée. Action abandonnée.
    IERRINF = 314
    ICHAPTER = 196
    IBRETOUR = 0
    GOK = 0
  Endif
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    Read [SRE]SRE0=SZSRENUM
    If fstat Then
      #Erreur lors de l'enregistrement de la clôture de la demande de service.
      IERRINF = 319
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
    Endif
  Endif
  #Etape 2
  #Désaffectation du collaborateur ou de la queue précédente.
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If [F:SRE]SREPBLGRP = "" Then
      If [F:SRE]SREMACPBL <> "" Then
        SZPBLSRE = [F:SRE]SREMACPBL
      Endif
    Else
      SZPBLSRE = [F:SRE]SREPBLGRP
    Endif
    Call MNGPBLSTAT([F:SRE]SRENUM, SZPBLSRE, SZPBLSRE, [F:SRE]SREASS, 5, [F:SRE]SREDET, "", IERRINF,ICHAPTER,IBRETOUR) From TRTFSOL
    If IBRETOUR = 0 Then
      GOK = 0
      End
    Endif
  Endif
  #Etape 3
  #Détermine le status de facturation de la demande.
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    IINVFLG = 1
    Case SZCONTEXT
      When "ITN"
        Call GETINVFLG(SZSRENUM, SZITNNUM, IINVFLG) From SUBITNB1
      When "RPO"
        Call GET2INVFLG(SZSRENUM, SZITNNUM, IINVFLG) From SUBITNB1
    Endcase
  Endif
  #Etape 4
  #Clôture de la demande de service.
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    #Mémorise le nom du technicien qui a traité la demande.
    If [F:SRE]SREASS = 2 Then
      SZSRE2REP = [F:SRE]SREDET
    Else
      If [F:SRE]REP <> "" Then
        SZSRE2REP = ""
      Endif
    Endif
    [F:SRE]REP = SZSRE2REP
    If GCLOINV = 2 Then
      [F:SRE]SREINVFLG = IINVFLG
    Else
      [F:SRE]SREINVFLG = 1
    Endif
    [F:SRE]SREASS = 5
    [F:SRE]SREDATASS = date$
    [F:SRE]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
    [F:SRE]SREDET = ""
    If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [F:ADI]NUMTAB = 422
    For [ADI]
      If [F:ADI]N1 = 2 Then
        SZADICODE = [F:ADI]CODE
        Break
      Endif
    Next
    Filter [ADI]
    If SZADICODE <> "" Then
      If [F:SRE]SRESAT <> SZADICODE Then
        ICREHISTOFLG = 1
        [F:SRE]SRESAT = SZADICODE
      Endif
    Endif
    Rewrite [SRE]
    If fstat Then
      #Erreur lors de l'enregistrement de la clôture de la demande de service.
      IERRINF = 319
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Call FSTA("SRE") From GLOCK
    Endif
  Endif
  #Etape 5
  #Ajoute un historique d'état de la demande
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If ICREHISTOFLG Then
      Call CREHISTO([F:SRE]SRENUM, [F:SRE]SRESAT, [F:SRE]REP, 5,IERRINF,ICHAPTER,IBRETOUR)  From SUBSREB1
      If IBRETOUR = 0 Then
        GOK = 0
      Endif
    Endif
  Endif
  #Etape 6 : On passe tous les points mobilisés en consommés
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    Call RERTOCSM([F:SRE]SRENUM, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB2
    If IBRETOUR = 0 Then
      GOK = 0
    Endif
  Endif
  #Etape 7 : On transforme les consommations en effectué.
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If IDONDATFLG Then
      Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2 and [F:HDT]HDTDONDAT = [00/00/00]
      For [HDT]HDT1
        [F:HDT]HDTDONDAT = date$
        IHDTDONHOU = 0
        Call HOUTOSEC(val(left$(time$, 2)), val(mid$(time$, 4, 2)), IHDTDONHOU) From CRMUTIL140
        [F:HDT]HDTDONHOU = IHDTDONHOU
        If [F:HDT]ITNNUM = "" Then
          [F:HDT]SPGTIMHOU = 0
          [F:HDT]SPGTIMMNT = 0
        Else
          If [F:HDT]HDTTYP = 3 Then
            If [F:HDT]SPGTIMHOU = 0 Then
              If [F:HDT]SPGTIMMNT = 0 Then
                ISPGTIMHOU = 0
                ISPGTIMMNT = 0
                Call DEFSPGTIM(SZBPC, [F:HDT]HDTQTY, [F:HDT]HDTUOM, [F:HDT]HDTITM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
                [F:HDT]SPGTIMHOU = ISPGTIMHOU
                [F:HDT]SPGTIMMNT = ISPGTIMMNT
              Endif
            Endif
          Endif
        Endif
        Rewrite [HDT]
        If fstat Then
          #Erreur lors de la transformation des consommations facturables.
          IERRINF = 317
          ICHAPTER = 182
          IBRETOUR = 0
          GOK = 0
          Call FSTA("HDT") From GLOCK
          Break
        Endif
      Next
      Filter [HDT]
    Endif
  Endif
  #Etape 8 : On transforme toutes les interventions en effectué
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    Filter [ITN] Where [F:ITN]NUM <> SZITNNUM and [F:ITN]SRVDEMNUM = SZSRENUM and [F:ITN]DON <> 2
    For [ITN]
      [F:ITN]DON = 2
      [F:ITN]PBLSOL = 2
      Call ITNSPGTIM([F:ITN]NUM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
      [F:ITN]HTOTTIMSPG = ISPGTIMHOU
      [F:ITN]MTOTTIMSPG = ISPGTIMMNT
      Rewrite [ITN]
      If fstat Then
        #Erreur lors de la transformation des interventions.
        IERRINF = 318
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Call FSTA("ITN") From GLOCK
        Break
      Endif
    Next
    Filter [ITN]
    If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
      Read [ITN]ITN0=SZITNNUM
      If fstat Then
        #Erreur lors de la transformation des interventions.
        IERRINF = 318
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
      Endif
      [F:ITN]DON = 2
      [F:ITN]PBLSOL = 2
      If ![F:ITN]MANTIMFLG Then
        Call ITNSPGTIM([F:ITN]NUM, ISPGTIMHOU, ISPGTIMMNT) From SUBITNB1
        [F:ITN]HTOTTIMSPG = ISPGTIMHOU
        [F:ITN]MTOTTIMSPG = ISPGTIMMNT
      Endif
      Rewrite [ITN]
      If fstat Then
        #Erreur lors de la transformation des interventions.
        IERRINF = 318
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Call FSTA("ITN") From GLOCK
      Else
        Case SZCONTEXT
          When "ITN"
            If ![F:ITN]MANTIMFLG Then
              [M:ITN4]HTOTTIMSPG = ISPGTIMHOU
              [M:ITN4]MTOTTIMSPG = ISPGTIMMNT
             Endif
           When "RPO"
             If ![F:ITN]MANTIMFLG Then
               [M:HDK4]HTOTTIMSPG = ISPGTIMHOU
               [M:HDK4]MTOTTIMSPG = ISPGTIMMNT
             Endif
        Endcase
      Endif
    Endif
  Endif
  #Etape 9 : On alimente la table des lignes de facture.
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If IINVFLG = 2 Then
      Call FEEDHDI(SZSRENUM, IERRINF,ICHAPTER,IBRETOUR) From TRTFSOL
      If IBRETOUR = 0 Then
        GOK = 0
      Endif
    Endif
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  #Etape 10
  #Affichage de la demande de service
  If GOK Then  # FGR 20/08/2010 : X3SUIVI66745 : Pas "GOK>1"
    If SZCONTEXT = "ITN" Then
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESSRE" Then
          If [M:ITN0]SRVDEMNUM <> "" Then
            If [M:SRE0]SRENUM = [M:ITN0]SRVDEMNUM Then
              [M:SRE2]SREASS = 5
              [M:SRE2]REP = SZSRE2REP
              [M:SRE2]SREINVFLG = IINVFLG
              [M:SRE2]SREASS = 5
              [M:SRE2]SREDATASS = date$
              [M:SRE2]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
              [M:SRE2]SREDET = ""
              [M:SRE2]SRESAT = SZADICODE
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Défini une demande de service dans l'état demande satisfaite
##############################################################################
$SETSREDONSAT
  #On contrôle
  #Etape 1 : Lecture de la demande de service
  If SZSRENUM = "" Then
    #La demande de service à clôturer n'a pas pu être identifiée. Action abandonnée.
    IERRINF = 314
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    Return
  Endif
  Read [SRE]SRE0=SZSRENUM
  If fstat Then
    #La demande de service à clôturer n'a pas pu être identifiée. Action abandonnée.
    IERRINF = 314
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    Return
  Endif
  If clalev([F:ADI]) <= 0 Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where [F:ADI]NUMTAB = 422
  For [ADI]
    If [F:ADI]N1 = 2 Then
      SZADICODE = [F:ADI]CODE
      Break
    Endif
  Next
  Filter [ADI]
  If SZADICODE = "" Then
    Return
  Endif
  If [F:SRE]SRESAT = SZADICODE Then
    Return
  Else
    ICREHISTOFLG = 1
  Endif
  #Etape 2
  #Changement de l'état de la demande de service.
  [F:SRE]SRESAT = SZADICODE
  Rewrite [SRE]
  If fstat Then
    #Erreur lors de l'enregistrement de la clôture de la demande de service.
    IERRINF = 319
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    Return
  Endif
  #Etape 5
  #Ajoute un historique d'état de la demande
  Call CREHISTO([F:SRE]SRENUM, [F:SRE]SRESAT, [F:SRE]REP, 5,IERRINF,ICHAPTER,IBRETOUR)  From SUBSREB1
  If IBRETOUR = 0 Then
    GOK = 0
  Endif
Return

##########################################################################################################
# Détermine si la demande est facturable ou totalement gratuite. Classe F et M.
#############################################################################
Subprog GETINVFLG(SZSRENUM, SZITNNUM, IINVFLG)
Value Char SZSRENUM
Value Char SZITNNUM
Variable Integer IINVFLG

Local Integer ITERHDT

  IINVFLG = 1
  Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM  and [F:HDT]TPL <> 2 and [F:HDT]ITNNUM <> SZITNNUM and [F:HDT]HDTINV = 2
  For [HDT]HDT1
    IINVFLG = 2
    Break
  Next
  Filter [HDT]
  #Contrôle dans l'écran des consommations
  If IINVFLG = 1 Then
    For ITERHDT = 0 To [M:ITN8]NBLIG-1
      If [M:ITN8]HDTINV(ITERHDT) = 2 Then
        IINVFLG = 2
        Break
      Endif
    Next
  Endif
End

##########################################################################################################
# Détermine si la demande est facturable ou totalement gratuite. Classe F uniquement
#############################################################################
Subprog GET2INVFLG(SZSRENUM, SZITNNUM, IINVFLG)
Value Char SZSRENUM
Value Char SZITNNUM
Variable Integer IINVFLG

  IINVFLG = 1
  Filter [HDT] Where [F:HDT]SRENUM = SZSRENUM and [F:HDT]TPL <> 2 and [F:HDT]HDTINV = 2
  For [HDT]HDT1
    IINVFLG = 2
    Break
  Next
  Filter [HDT]
End

##########################################################################################################
# Calcul pour du beurre du temps réellement passé sur une intervention (Classe F)
##################################################################################
Subprog GETHDK4SPG(SZITNNUM, SZBPC, IHOU, IMNT)
Value Char SZITNNUM
Value Char SZBPC
Variable Integer IHOU
Variable Integer IMNT

Local Integer ISPGTIMHOU
Local Integer ISPGTIMMNT
Local Integer ITOTHOU
Local Integer ITOTMNT
Local Integer ITOTMNT2
Local Integer ITER

  ITER = 0
  ITOTHOU = 0
  ITOTMNT = 0
  ITOTMNT2 = 0
  ISPGTIMHOU = 0
  ISPGTIMMNT = 0
  Filter [HDT] Where [F:HDT]ITNNUM = SZITNNUM and [F:HDT]TPL <> 2
  For [HDT]HDT2
    If [F:HDT]HDTDONDAT = [00/00/00] Then
      If [F:HDT]HDTTYP = 3 Then
        If [F:HDT]SPGTIMHOU = 0 Then
          If [F:HDT]SPGTIMMNT = 0 Then
            ISPGTIMHOU = 0
            ISPGTIMMNT = 0
            Call DEFSPGTIM(SZBPC, [F:HDT]HDTQTY, [F:HDT]HDTUOM, [F:HDT]HDTITM, ISPGTIMHOU, ISPGTIMMNT)
            ITOTHOU += ISPGTIMHOU
            ITOTMNT += ISPGTIMMNT
          Endif
        Endif
      Endif
    Else
      ITOTHOU += [F:HDT]SPGTIMHOU
      ITOTMNT += [F:HDT]SPGTIMMNT
    Endif
  Next
  Filter [HDT]
  #Convertit les minutes en heures
  If ITOTMNT > 59 Then
    ITOTHOU += int(ITOTMNT / 60)
    ITOTMNT2 = mod(ITOTMNT, 60)
  Else
    ITOTMNT2 = ITOTMNT
  Endif
  IHOU = ITOTHOU
  IMNT = ITOTMNT2
End

##########################################################################################################
# Calcul du bloc de gestion du temps des consommations.
##################################################################################
Subprog LOADTIMHDT
Local Integer IFORMAX

Local Integer IUNITOK
Local Integer ITER
Local Integer IBIDSEC
Local Decimal INBHOUPERDAY
Local Integer ITOTSEC1
Local Integer ITOTSEC2
Local Integer ITOTSEC3

Local Integer IHOUSVCPLN
Local Integer IMNTSVCPLN
Local Integer IHOUSVCDON
Local Integer IMNTSVCDON
Local Integer IHOUSVCRMN
Local Integer IMNTSVCRMN

Local Decimal NDECDAY
Local Integer IINTDAY
Local Decimal NCOLDAY

Local Decimal NDECHOU
Local Integer IINTHOU
Local Decimal NCOLHOU

Local Decimal NDECMNT
Local Integer IINTMNT
Local Decimal NCOLMNT

Local Decimal NDECSEC
Local Integer IINTSEC

  IBIDSEC = 0
  INBHOUPERDAY = 0
  ITOTSEC1 = 0
  ITOTSEC2 = 0
  ITOTSEC3 = 0
  ITOTSEC4 = 0
  Raz [M:ITN8]HOUSVCPLN
  Raz [M:ITN8]MNTSVCPLN
  Raz [M:ITN8]HOUSVCDON
  Raz [M:ITN8]MNTSVCDON
  Raz [M:ITN8]HOUSVCRMN
  Raz [M:ITN8]MNTSVCRMN
  If nolign > [M:ITN8]NBLIG Then
    IFORMAX = [M:ITN8]NBLIG
  Else
    IFORMAX = [M:ITN8]NBLIG - 1
   Endif
  For ITER = 0 To IFORMAX
    If [M:ITN8]HDTTYP(ITER) = 3 Then
      #Prestations planifiées
      #On détermine la nature de l'unité saisie.
      Read [UOT]UOT0=[M:ITN8]HDTUOM(ITER)
      If !fstat Then
        IUNITOK = 1
        If [F:UOT]TYPUOM <= 1 Then
          IUNITOK = 0
        Elsif [F:UOT]TYPUOM >= 5 Then
          IUNITOK = 0
        Endif
        If IUNITOK Then
          Case [F:UOT]TYPUOM
            When 2
              Read [ITM]ITM0=[M:ITN8]HDTITM(ITER)
              If !fstat Then
                Call SREC_COE([F:ITM]ITMREF, [M:ITN0]BPC, [F:ITM]HOUUOM, [F:ITM]DAYUOM, INBHOUPERDAY) From TRTVENQTE
                #Calcul du nombre de secondes
                NDECDAY = [M:ITN8]HDTQTY(ITER)
                IINTDAY = int(NDECDAY)
                NCOLDAY = NDECDAY - IINTDAY
                If NCOLDAY = 0 Then
                  ITOTSEC1 += NDECDAY * INBHOUPERDAY * 3600
                  If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                    #Prestations effectuées
                    ITOTSEC2 += NDECDAY * INBHOUPERDAY * 3600
                  Endif
                Else
                  ITOTSEC1 += IINTDAY * INBHOUPERDAY * 3600
                  If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                    #Prestations effectuées
                    ITOTSEC2 += IINTDAY * INBHOUPERDAY * 3600
                  Endif
                  NDECHOU = INBHOUPERDAY * NCOLDAY
                  IINTHOU = int(NDECHOU)
                  NCOLHOU = NDECHOU - IINTHOU
                  If NCOLHOU = 0 Then
                    ITOTSEC1 += NDECHOU * 3600
                    If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                      #Prestations effectuées
                      ITOTSEC2 += NDECHOU * 3600
                    Endif
                  Else
                    ITOTSEC1 += IINTHOU * 3600
                    If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                      #Prestations effectuées
                      ITOTSEC2 += IINTHOU * 3600
                    Endif
                    NDECMNT = 60 * NCOLHOU
                    IINTMNT = int(NDECMNT)
                    NCOLMNT = NDECMNT - IINTMNT
                    If NCOLMNT = 0 Then
                      ITOTSEC1 += NDECMNT * 60
                      If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                        #Prestations effectuées
                        ITOTSEC2 += NDECMNT * 60
                      Endif
                    Else
                      ITOTSEC1 += IINTMNT * 60
                      If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                        #Prestations effectuées
                        ITOTSEC2 += IINTMNT * 60
                      Endif
                      NDECSEC = 60 * NCOLMNT
                      IINTSEC = int(NDECMNT)
                      ITOTSEC1 += IINTSEC
                      If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                        #Prestations effectuées
                        ITOTSEC2 += IINTSEC
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            When 3
              #Calcul du nombre de secondes
              NDECHOU = [M:ITN8]HDTQTY(ITER)
              IINTHOU = int(NDECHOU)
              NCOLHOU = NDECHOU - IINTHOU
              If NCOLHOU = 0 Then
               ITOTSEC1 += NDECHOU * 3600
               If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                 #Prestations effectuées
                 ITOTSEC2 += NDECHOU * 3600
               Endif
             Else
               ITOTSEC1 += IINTHOU * 3600
               If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                 #Prestations effectuées
                 ITOTSEC2 += IINTHOU * 3600
               Endif
               NDECMNT = 60 * NCOLHOU
               IINTMNT = int(NDECMNT)
               NCOLMNT = NDECMNT - IINTMNT
               If NCOLMNT = 0 Then
                 ITOTSEC1 += NDECMNT * 60
                 If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                   #Prestations effectuées
                   ITOTSEC2 += NDECMNT * 60
                 Endif
               Else
                 ITOTSEC1 += IINTMNT * 60
                 If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                   #Prestations effectuées
                   ITOTSEC2 += IINTMNT * 60
                 Endif
                 NDECSEC = 60 * NCOLMNT
                 IINTSEC = int(NDECMNT)
                 ITOTSEC1 += IINTSEC
                 If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                   #Prestations effectuées
                   ITOTSEC2 += IINTSEC
                 Endif
               Endif
             Endif
           When 4
             #Calcul du nombre de secondes
             NDECMNT = [M:ITN8]HDTQTY(ITER)
             IINTMNT = int(NDECMNT)
             NCOLMNT = NDECMNT - IINTMNT
             If NCOLMNT = 0 Then
               ITOTSEC1 += NDECMNT * 60
               If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                 #Prestations effectuées
                 ITOTSEC2 += NDECMNT * 60
               Endif
             Else
               ITOTSEC1 += IINTMNT * 60
               If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                 #Prestations effectuées
                 ITOTSEC2 += IINTMNT * 60
               Endif
               NDECSEC = 60 * NCOLMNT
               IINTSEC = int(NDECMNT)
               ITOTSEC1 += IINTSEC
               If [M:ITN8]HDTDONDAT(ITER) <> [00/00/00] Then
                 #Prestations effectuées
                 ITOTSEC2 += IINTSEC
               Endif
             Endif
         Endcase
       Endif
     Endif
   Endif
  Next
  #Conversion des prestations planifiées
  Call SECTOHOUMNT(ITOTSEC1, IHOUSVCPLN, IMNTSVCPLN, IBIDSEC) From CRMUTIL140
  [M:ITN8]HOUSVCPLN = IHOUSVCPLN
  [M:ITN8]MNTSVCPLN = IMNTSVCPLN
  #Conversion des prestations effectuées
  Call SECTOHOUMNT(ITOTSEC2, IHOUSVCDON, IMNTSVCDON, IBIDSEC) From CRMUTIL140
  [M:ITN8]HOUSVCDON = IHOUSVCDON
  [M:ITN8]MNTSVCDON = IMNTSVCDON
  #Conversion du reste à faire
  ITOTSEC3 = ITOTSEC1 - ITOTSEC2
  Call SECTOHOUMNT(ITOTSEC3, IHOUSVCRMN, IMNTSVCRMN, IBIDSEC) From CRMUTIL140
  [M:ITN8]HOUSVCRMN = IHOUSVCRMN
  [M:ITN8]MNTSVCRMN = IMNTSVCRMN
End

##########################################################################################################
# Calcul du temps réellement passé sur une intervention (Classe M)
##################################################################################
Subprog CPTSPGTIM
Local Integer ITOTHOU
Local Integer ITOTMNT
Local Integer ITOTMNT2
Local Integer ITER

  If [M:ITN4]MANTIMFLG Then
    End
  Endif
  ITOTHOU = 0
  ITOTMNT = 0
  ITOTMNT2 = 0
  For ITER = 0 To [M:ITN8]NBLIG-1
    ITOTHOU += [M:ITN8]SPGTIMHOU(ITER)
    ITOTMNT += [M:ITN8]SPGTIMMNT(ITER)
  Next
  #Convertit les minutes en heures
  If ITOTMNT > 59 Then
    ITOTHOU += int(ITOTMNT / 60)
    ITOTMNT2 = mod(ITOTMNT, 60)
  Else
    ITOTMNT2 = ITOTMNT
  Endif
  [M:ITN4]HTOTTIMSPG = ITOTHOU
  [M:ITN4]MTOTTIMSPG = ITOTMNT2
End

##########################################################################################################
# Calcul du temps réellement passé sur une intervention (Classe F)
##################################################################################
Subprog ITNSPGTIM(SZITNNUM, IHOU, IMNT)
Value Char SZITNNUM
Variable Integer IHOU
Variable Integer IMNT

Local Integer ITOTHOU
Local Integer ITOTMNT
Local Integer ITOTMNT2

  ITOTHOU = 0
  ITOTMNT = 0
  ITOTMNT2 = 0
  Filter [HDT] Where [F:HDT]ITNNUM = SZITNNUM and [F:HDT]TPL <> 2
  For [HDT]HDT2
    ITOTHOU += [F:HDT]SPGTIMHOU
    ITOTMNT += [F:HDT]SPGTIMMNT
  Next
  Filter [HDT]
  #Convertit les minutes en heures
  If ITOTMNT > 59 Then
    ITOTHOU += int(ITOTMNT / 60)
    ITOTMNT2 = mod(ITOTMNT, 60)
  Else
    ITOTMNT2 = ITOTMNT
  Endif
  IHOU = ITOTHOU
  IMNT = ITOTMNT2
End

##########################################################################################################
# Propose une durée réelle par défaut pour une consommation de type main d'oeuvre
##################################################################################
Subprog DEFSPGTIM(SZBPC, NQTY, SZUOM, SZITM, IHTIMSPG, IMTIMSPG)
Value Char SZBPC
Value Decimal NQTY
Value Char SZUOM
Value Char SZITM
Variable Integer IHTIMSPG
Variable Integer IMTIMSPG

Local Integer IUNITOK
Local Integer IBIDSEC
Local Decimal INBHOUPERDAY
Local Integer ITOTSEC1

Local Decimal NDECDAY
Local Integer IINTDAY
Local Decimal NCOLDAY

Local Decimal NDECHOU
Local Integer IINTHOU
Local Decimal NCOLHOU

Local Decimal NDECMNT
Local Integer IINTMNT
Local Decimal NCOLMNT

Local Decimal NDECSEC
Local Integer IINTSEC

  IBIDSEC = 0
  INBHOUPERDAY = 0
  ITOTSEC1 = 0
  #On détermine la nature de l'unité saisie.
  Read [UOT]UOT0=SZUOM
  If !fstat Then
    IUNITOK = 1
    If [F:UOT]TYPUOM <= 1 Then
      IUNITOK = 0
    Endif
    If [F:UOT]TYPUOM >= 5 Then
      IUNITOK = 0
    Endif
    If IUNITOK Then
      Case [F:UOT]TYPUOM
        When 2
          Read [ITM]ITM0=SZITM
          If !fstat Then
            Call SREC_COE([F:ITM]ITMREF, SZBPC, [F:ITM]HOUUOM, [F:ITM]DAYUOM, INBHOUPERDAY) From TRTVENQTE
            #Calcul du nombre de secondes
            NDECDAY = NQTY
            IINTDAY = int(NDECDAY)
            NCOLDAY = NDECDAY - IINTDAY
            If NCOLDAY = 0 Then
              ITOTSEC1 += NDECDAY * INBHOUPERDAY * 3600
            Else
              ITOTSEC1 += IINTDAY * INBHOUPERDAY * 3600
              NDECHOU = INBHOUPERDAY * NCOLDAY
              IINTHOU = int(NDECHOU)
              NCOLHOU = NDECHOU - IINTHOU
              If NCOLHOU = 0 Then
                ITOTSEC1 += NDECHOU * 3600
              Else
                ITOTSEC1 += IINTHOU * 3600
                NDECMNT = 60 * NCOLHOU
                IINTMNT = int(NDECMNT)
                NCOLMNT = NDECMNT - IINTMNT
                If NCOLMNT = 0 Then
                  ITOTSEC1 += NDECMNT * 60
                Else
                  ITOTSEC1 += IINTMNT * 60
                  NDECSEC = 60 * NCOLMNT
                  IINTSEC = int(NDECMNT)
                  ITOTSEC1 += IINTSEC
                Endif
              Endif
            Endif
          Endif
        When 3
          #Calcul du nombre de secondes
          NDECHOU = NQTY
          IINTHOU = int(NDECHOU)
          NCOLHOU = NDECHOU - IINTHOU
          If NCOLHOU = 0 Then
            ITOTSEC1 += NDECHOU * 3600
          Else
            ITOTSEC1 += IINTHOU * 3600
            NDECMNT = 60 * NCOLHOU
            IINTMNT = int(NDECMNT)
            NCOLMNT = NDECMNT - IINTMNT
            If NCOLMNT = 0 Then
              ITOTSEC1 += NDECMNT * 60
            Else
              ITOTSEC1 += IINTMNT * 60
              NDECSEC = 60 * NCOLMNT
              IINTSEC = int(NDECMNT)
              ITOTSEC1 += IINTSEC
            Endif
          Endif
        When 4
          #Calcul du nombre de secondes
          NDECMNT = NQTY
          IINTMNT = int(NDECMNT)
          NCOLMNT = NDECMNT - IINTMNT
          If NCOLMNT = 0 Then
            ITOTSEC1 += NDECMNT * 60
          Else
            ITOTSEC1 += IINTMNT * 60
            NDECSEC = 60 * NCOLMNT
            IINTSEC = int(NDECMNT)
            ITOTSEC1 += IINTSEC
          Endif
      Endcase
    Endif
  Endif
  Call SECTOHOUMNT(ITOTSEC1, IHTIMSPG, IMTIMSPG, IBIDSEC) From CRMUTIL140
End

##########################################################################################################
# AFF_TITCOL : affiche les titres des  colonnes des axes analytiques
$AFF_TITCOL
  If GSOC_UPDFLG and !GIMPORT Then
    Local Char BASPAG(10)

    BASPAG = "NBLIG"
    Gosub TIT_COL From ="W1WH3"+GHDKTRSITN+"8"
    #----- Si tableau vide, il faut forcer l'utilisation des formats évalués -----#
    If [M:ITN8]NBLIG = 0 Then
      [M:ITN8]NBLIG = 1
      Affzo [ITN8]5
      Effzo [M:ITN8]5
    Endif
  Endif
  Raz GSOC_UPDFLG
Return

