Subprog RAZITN3(IAFF)
Value Integer IAFF

  Raz [M:ITN3]ADD
  Raz [M:ITN3]ZIP
  Raz [M:ITN3]CTY
  Raz [M:ITN3]CRY
  Raz [M:ITN3]SAT
  Raz [M:ITN3]TEL
  Raz [M:ITN3]DTCKIL
  Raz [M:ITN3]TRITIM
  Raz [M:ITN3]IFFADD
  Raz [M:ITN3]ITNTYPADD
  Raz [M:ITN3]ITNCODADD
  Raz [M:ITN3]ITNRECADD
End

