#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################
#Mise à jour de la dimension maxi du code activité NUC
#########################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTINUCMAX: DIMENSION OF 'NUC' ACTIVITY CODE") From LECFIC
 Call EXE_UTINUX(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################

Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_UTINUX(APPLI)
End


#########################################################
# Màj du code activité : nombre d'unités conditionnement
#########################################################
Subprog EXE_UTINUX(APPLI)
Value Char    APPLI
Local Integer OK, WUPD

Call ECR_TRACE("UTINUX: Process Start on : "+APPLI,0) From GESECRAN

Local File =APPLI+".ACTIV" [XACV]
Trbegin [XACV]
GOK =1
Read [F:XACV]CODACT="NUC"
If !fstat 
 [F:XACV]DIMFIL = 0
 Rewrite [F:XACV]
 If fstat
   GOK=0 : Call RSTA("XACV",[F:XACV]CODACT) From GLOCK
 Endif
Endif
If GOK=1 
 Commit
Else
 Rollback
Endif

Close Local File [XACV]

Call ECR_TRACE("UTINUX: Process End on : "+APPLI,0) From GESECRAN

End
