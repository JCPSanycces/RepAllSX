If mkstat : GERR = 1 : GZONE = "PBUPAE" : GZNUM = 37740 : Endif
Gosub _AFF
End

Subprog S_PBUPAE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMBUD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMBUD"
 PARMSK(1) = [M:PJBU0]OPPNUM
 PARMSK(2) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELPJMBUD","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PBUPAE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMBUD
 Call TUNPJMBUD(VALEUR,[M:PJBU0]OPPNUM) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

