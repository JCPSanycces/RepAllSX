#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMBUD0A 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:44"
A_USER  = "DOC"
A_STAMP = "20181109230544"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMBUD0A [PJBU0A]
Gosub HORODAT
Local Inpbox "PJMBUD0A" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJBU0A] As [SIM_]
Grizo [PJBU0A]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJBU0A]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=113 : Y1(0)=1 : Y2(0)=10
Return

$ON_PBUFCY
Onevent CONTROL Call C_PBUFCY(zc) From W1PJMBUD0A
Onevent AFTER_CHANGE Gosub AMM_PBUFCY From W1PJMBUD0A
Onevent BEFORE_INPUT Call AS_PBUFCY(zc) From W1PJMBUD0A
Return

Subprog AS_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PBUFCY(zc) From W1PJMBUD0A
Onkey 144 Titled GBOUTP Call P_PBUFCY(zc) From W1PJMBUD0A
Onkey 146 Titled GBOUTA Call SA_PBUFCY(zc) From W1PJMBUD0A
Gosub _AFF
End

Subprog C_PBUFCY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action ACONTFCY
 Call CONTSITE(VALEUR) From SUBAGF
 If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("FCY","F",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_PBUFCY
Call AM_PBUFCY(zc)
If !mkstat & GOBJET
 zoncou = "PBUFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PBUFCY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PBUFCY(VALEUR) From SUBPJBU
If mkstat : GERR = 1 : GZONE = "PBUFCY" : GZNUM = 1344 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPBUFCY)")>indice
 [M]PBUFCY(indice) = VALEUR
 Affzo ZPBUFCY(indice)
Endif
Gosub _AFF
End

Subprog S_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "F"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PBUFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPBUFCY
Onevent BEFORE_AREA Gosub AV_ZPBUFCY From W1PJMBUD0A
Return

$AV_ZPBUFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]PBUFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

$ON_PBUPAE
Onevent AFTER_CHANGE Gosub AMM_PBUPAE From W1PJMBUD0A
Onevent BEFORE_INPUT Call AS_PBUPAE(zc) From W1PJMBUD0A
Return

Subprog IB_PBUPAE(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMBUD
Call IBUPJMBUD([M:PJBU0]OPPNUM) From PJMSELECT
Gosub _AFF
End

Subprog AS_PBUPAE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5262,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_PBUPAE(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PBUPAE(zc) From W1PJMBUD0A
Onkey   2 Titled GBOUTS Call S_PBUPAE(zc) From W1PJMBUD0A
Gosub _AFF
End

$AMM_PBUPAE
Call AM_PBUPAE(zc)
If !mkstat & GOBJET
 zoncou = "PBUPAE" : Gosub APRES_MODIF From =GPROGRAMME
