######################################################################################################
# Module        : Finance
# Description   : BP number definition (Class BSIBPRNUMD)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
######################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
        When ""
            Case [L]AEVENT
                When "AREAD_AFTER" : Gosub EVENT_AREAD_AFTER
            Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "LENINVSTR" : Gosub PROPERTY_LENINVSTR
        When "LENINVEND" : Gosub PROPERTY_LENINVEND
        When "DIR"       : Gosub PROPERTY_DIR
        When "OPT"       : Gosub PROPERTY_OPT
        When "LNG"       : Gosub PROPERTY_LNG
        When "STRPOS"    : Gosub PROPERTY_STRPOS
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

$EVENT_AREAD_AFTER
    Case this.DIR
        When 1
            ASTATUS = fmet this.ASETATTRIBUTE( "OPT",       "$isDisabled", "true"  )
            ASTATUS = fmet this.ASETATTRIBUTE( "LNG",       "$isDisabled", "true"  )
            ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS",    "$isDisabled", "true"  )
# 2016-09-20 DNE INSERT BEGIN
            ASTATUS = fmet this.ASETATTRIBUTE( "LENINVSTR", "$isDisabled", "false" )
            ASTATUS = fmet this.ASETATTRIBUTE( "LENINVEND", "$isDisabled", "false" )
# 2016-09-20 DNE INSERT END
        When Default
            ASTATUS = fmet this.ASETATTRIBUTE( "OPT",       "$isDisabled", "false" )
            ASTATUS = fmet this.ASETATTRIBUTE( "LNG",       "$isDisabled", "false" )
            ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS",    "$isDisabled", "false" )
# 2016-09-20 DNE INSERT BEGIN
            ASTATUS = fmet this.ASETATTRIBUTE( "LENINVSTR", "$isDisabled", "true"  )
            ASTATUS = fmet this.ASETATTRIBUTE( "LENINVEND", "$isDisabled", "true"  )
# 2016-09-20 DNE INSERT END
    Endcase
Return

$PROPERTY_LENINVSTR
    Case [L]ARULE
        When "CONTROL"
            Gosub PROPERTY_LENINVSTR_CONTROL
            # reset errors for LENINVEND property
            ASTATUS = fmet this.ADELETEERROR("LENINVEND")
            Gosub PROPERTY_LENINVEND_CONTROL
    Endcase
Return

$PROPERTY_LENINVEND
    Case [L]ARULE
        When "CONTROL"
            Gosub PROPERTY_LENINVEND_CONTROL
            # reset errors for LENINVSTR property
            ASTATUS = fmet this.ADELETEERROR("LENINVSTR")
            Gosub PROPERTY_LENINVSTR_CONTROL
    Endcase
Return

$PROPERTY_LENINVSTR_CONTROL
    If this.LENINVSTR < 0 Then
        ASTATUS = fmet this.ASETERROR("LENINVSTR", mess(29,7703,1), [V]CST_AERROR)
    Endif
    If this.LENINVSTR > this.LENINVEND Then
        ASTATUS = fmet this.ASETERROR("LENINVSTR", mess(34,7703,1), [V]CST_AERROR)
    Endif
Return

$PROPERTY_LENINVEND_CONTROL
    If this.LENINVEND < 0 Then
        ASTATUS = fmet this.ASETERROR("LENINVEND", mess(29,7703,1), [V]CST_AERROR)
    Endif
    If this.LENINVSTR > this.LENINVEND Then
        ASTATUS = fmet this.ASETERROR("LENINVEND", mess(35,7703,1), [V]CST_AERROR)
    Endif
Return

$PROPERTY_DIR
    Case [L]ARULE
        When "PROPAGATE"
            Case this.DIR
                When 1
                    ASTATUS = fmet this.ASETATTRIBUTE( "OPT",       "$isDisabled", "true"  )
                    ASTATUS = fmet this.ASETATTRIBUTE( "LNG",       "$isDisabled", "true"  )
                    ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS",    "$isDisabled", "true"  )
# 2016-09-20 DNE INSERT BEGIN
                    ASTATUS = fmet this.ASETATTRIBUTE( "LENINVSTR", "$isDisabled", "false" )
                    ASTATUS = fmet this.ASETATTRIBUTE( "LENINVEND", "$isDisabled", "false" )
# 2016-09-20 DNE INSERT END
                When Default
                    ASTATUS = fmet this.ASETATTRIBUTE( "OPT",       "$isDisabled", "false" )
                    ASTATUS = fmet this.ASETATTRIBUTE( "LNG",       "$isDisabled", "false" )
                    ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS",    "$isDisabled", "false" )
# 2016-09-20 DNE INSERT BEGIN
                    ASTATUS = fmet this.ASETATTRIBUTE( "LENINVSTR", "$isDisabled", "true"  )
                    ASTATUS = fmet this.ASETATTRIBUTE( "LENINVEND", "$isDisabled", "true"  )
# 2016-09-20 DNE INSERT END
            Endcase
# 2016-09-20 DNE INSERT BEGIN
        When "INIT"
            this.DIR = 1
# 2016-09-20 DNE INSERT END
    Endcase
Return

$PROPERTY_OPT
    Case [L]ARULE
        When "INIT"
            If this.DIR = 2 Then
                ASTATUS = fmet this.ASETATTRIBUTE( "OPT", "$isDisabled", "false" )
            Else
                ASTATUS = fmet this.ASETATTRIBUTE( "OPT", "$isDisabled", "true"  )
            Endif
    Endcase
Return

$PROPERTY_LNG
    Case [L]ARULE
        When "INIT"
            If this.DIR = 2 Then
                ASTATUS = fmet this.ASETATTRIBUTE( "LNG", "$isDisabled", "false" )
            Else
                ASTATUS = fmet this.ASETATTRIBUTE( "LNG", "$isDisabled", "true"  )
            Endif
    Endcase
Return

$PROPERTY_STRPOS
    Case [L]ARULE
        When "INIT"
            If this.DIR = 2 Then
                ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS", "$isDisabled", "false" )
            Else
                ASTATUS = fmet this.ASETATTRIBUTE( "STRPOS", "$isDisabled", "true"  )
            Endif
    Endcase
Return

########################################################################################################################

