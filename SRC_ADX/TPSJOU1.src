$AS_CPY
If evalue("[M]TIM"+num$(COL))<>GTPSW
 mkstat = 1 : Return
Endif
If VALEUR=""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 VALEUR = [F:FCY]LEGCPY
Endif
Return

$AS_BPCNUM
If evalue("[M]TIM"+num$(COL))<>GTPSW
 mkstat = 1 : Return
Endif
Return

$AM_BPCNUM
If [L]VALEUR="" : Return : Endif
Call LECTURE("CPY",evalue("[M]CPY"+num$(COL)),"") From CONTOBJ
Onerrgo FDRERR
Local File =[F:CPY]FDRX3+".BPCUSTOMER" [BPC]
Onerrgo
If mkstat=2 : Return : Endif
Read [BPC]BPC0=[L]VALEUR
If fstat
#LIPET - 11-01-2017 - X3-11322 - START
 #GMESSAGE = mess(71,709,1) : # Client inexistant
 GMESSAGE = mess(71,10709,1)
#LIPET - 11-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Else
 If evalue("dim([M]INVFLG"+num$(COL)+")")>0
  Assign "[M]INVFLG"+num$(COL) With 2
  If [M:TPSI]COP="2" & val(left$([M]NUMPLG,1))=1 & [M:TPSI]NBHOR>1 & dim([M:TPSJ]STRTIM11)>0
   #LIPET - 11-01-2017 - X3-11322 - START
   #Call LECTURE("TIM",[M:TPSJ]TIM1,"") From CONTOBJ
   Call LECTURE("HRTIM",[M:TPSJ]TIM1,GCURLEG) From CONTOBJ
   #LIPET - 11-01-2017 - X3-11322 - END
   If [F:TIM]PLGHOR=2 & evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(2)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(2))<>""
    Assign "[M:TPSI]KINVFLG2("+num$(COL-1)+")" With 2
   Endif
   If [F:TIM]PLGHOR=2 & evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(3)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(3))<>""
    Assign "[M:TPSI]KINVFLG3("+num$(COL-1)+")" With 2
   Endif
  Endif
 Endif
Endif
Return

$FDRERR
#ADNGO - 26-01-2017 - X3-11322 - START
#Call ERREUR(func AFNC.MES1(mess(189,703,1),[F:CPY]CPY)) From GESECRAN
Call ERREUR(func AFNC.MES1(mess(189,10703,1),[F:CPY]CPY)) From GESECRAN
#ADNGO - 26-01-2017 - X3-11322 - END
#           Dossier X3 incorrect pour la comptabilitÃĐ de la sociÃĐtÃĐ $1$
mkstat=2
Resume

$C_CMT
If len(VALEUR)<3
#LIPET - 11-01-2017 - X3-11322 - START
  #Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
  Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
 If [F:TIM]CMTOBG=2
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 2 : Return
 Endif
Endif
Return

$AS_STAFLG
If evalue("[M]TIM"+num$(COL))=""
 mkstat = 1 : Return
Endif
If !instr(1,GUSRAUZ(1),"2") | GVISA<>2 : # Visa
 VALEUR = "" : mkstat = 2 : Return
Else
 VALEUR = GUSER
Endif
Return

$C_STAFLG
If VALEUR<>""
 VALEUR = GUSER
Endif
Return

$AS_DSP
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If !find(2,[F:TIM]CCEDAC(0..GOPTCANA-1))
 mkstat = 1 : Return
Endif
If dim([M]NATCOD1)>0
 Call LECTURE("NAT",evalue("[M]NATCOD"+num$(COL)),GCURLEG) From CONTOBJ
Endif
Return

$C_DSP
Local Integer I
Local Decimal TOT
VALEUR=toupper(VALEUR)
If VALEUR<>"" & VALEUR<>"$"
 Call CONTROLE("DSP","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : Return : Endif
 #92876_US2757
 Call VERIF([F:DSP]FCY,[M]FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
 #
 Call CONTEXE([F:DSP]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : Return : Endif
 Call CTLVLYDAT([M]DAT(COL-1),[F:DSP]VLYSTR,[F:DSP]VLYEND) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : Return : Endif
 Call CHARGE_VTE(VALEUR) From TPSVENT
 [M:VTL]TIM = evalue("[M]TIM"+num$(COL))
 [M:VTL]DAT = [M]DAT(COL-1)
 Call CONTVENT From TPSVENT
 If mkstat : Return : Endif
 [M:TPSI]PTV(COL-1+7*(val(left$([M]NUMPLG,1))-1)) = 0
 [M:TPSI]PTF(COL-1+7*(val(left$([M]NUMPLG,1))-1)) = 0
Endif
If VALEUR="$"
 For I=[M:TPSI]PTV(COL-1+7*(val(left$([M]NUMPLG,1))-1)) To [M:TPSI]PTF(COL-1+7*(val(left$([M]NUMPLG,1))-1))
  TOT += [M:VT2]TBAMT(I)
 Next
 If TOT<>evalue("[M]NBRHOU"+num$(COL))
  I = 1
  #ADNGO - 11-01-2017 - X3-11322 - START
  #Call AVERTIR(mess(54,709,1),I) From GESECRAN
  Call AVERTIR(mess(54,10709,1),I) From GESECRAN
  #ADNGO - 11-01-2017 - X3-11322 - END
  If I=1 : # Annuler
   mkstat = 2 : End
  Endif
 Endif
Endif
#92876_US2757
If VALEUR<>""
  For I=1 To [M]NBRDIE
   If I>GOPTCANA : Break : Endif
   Assign "[M]CCE"+num$(I)+num$(COL) With ""
  Next
Endif
Return

$DEC_PLAGE
Local Integer TYPJOU, JNUIT
Local Decimal JOUR(1..2) , HEURE(1..2), TPSBRK
Local Char HREDEB (GLONHM)
Local Char HREFIN (GLONHM)
Local Char NATACT (GLONNAT)
Return

$D_CCE
#92876_US2759
If dim([M]NBRDIE)>=0 & AXE>[M]NBRDIE : Return : Endif

Local Char    SAU_GSOCIETE(GLONCPY), FCY_REF(GLONFCY)
Local Integer OK, ISEDITABLE

  SAU_GSOCIETE=GSOCIETE
  Local Integer OK
#  If evalue("dim([M]FCYT"+num$(COL)+")")>0
#    Call CPY_AXE (AXE, evalue("[M]FCYT"+num$(COL)), OK) From TPSDIV
#    GSOCIETE=func DIVPAYE.GETSOC(evalue("[M]FCYT"+num$(COL)))
#  Else
#    Call CPY_AXE (AXE, [M]FCY, OK) From TPSDIV
#    GSOCIETE=func DIVPAYE.GETSOC([M]FCY)
#  Endif
#LIPET - 11-01-2017 - X3-11322 - START
#  If evalue("dim([M]FCYT"+num$(COL)+")")<0 Then
#    Local    Date    XITDAT, CTRDAT_REF
#    If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
#    If evalue("dim([M]CTRDAT"+num$(COL)+")")>0 Then
#      CTRDAT_REF=evalue("[M]CTRDAT"+num$(COL))
#      Read [F:CTRD]CTR0=[M]REFNUM;[M]CTRNUM;CTRDAT_REF
#    Else
#      Filter [CTRD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]DAT(COL-1) | (FLGRET=2 & RETDATEFF<=[M]DAT(COL-1)))
#      Read [F:CTRD] Last
#      CTRDAT_REF=[F:CTRD]CTRDAT
#    Endif
#    FCY_REF=[F:CTRD]ETRFCY

  If evalue("dim([M]FCYT"+num$(COL)+")")<0 Then
    Local    Date    XITDAT, CTRDAT_REF
    If clalev([F:HRCTRD])=0 : Local File EMPLOCTR [HRCTRD] : Endif
    If evalue("dim([M]CTRDAT"+num$(COL)+")")>0 Then
      CTRDAT_REF=evalue("[M]CTRDAT"+num$(COL))
      Read [F:HRCTRD]CTR0=[M]REFNUM;[M]CTRNUM;CTRDAT_REF
    Else
      Filter [HRCTRD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]DAT(COL-1) | (FLGRET=2 & RETDATEFF<=[M]DAT(COL-1)))
      Read [F:HRCTRD] Last
      CTRDAT_REF=[F:HRCTRD]CTRDAT
    Endif
    FCY_REF=[F:HRCTRD]ETRFCY
#LIPET - 11-01-2017 - X3-11322 - END
  Else
    FCY_REF=evalue("[M]FCYT"+num$(COL))
  Endif
  If FCY_REF="" Then FCY_REF=[M]FCY : Endif
  If FCY_REF<>""
    Call CPY_AXE (AXE, FCY_REF, OK) From TPSDIV
    GSOCIETE=func DIVPAYE.GETSOC(FCY_REF)
  Endif
  If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
  If OK
#    Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
#    J=find([M]WDIE(AXE-1),[F:TIM]DIE(0..GOPTCANA-1))
#    If J
#      If evalue("dim([M]NATCOD"+num$(COL)+")")>0
#        Call INICCE(evalue("[M]NATCOD"+num$(COL)),evalue("[M]TIM"+num$(COL)),J,VALEUR) From TPSDIV
#      Else
#        Call INICCE("",evalue("[M]TIM"+num$(COL)),J,VALEUR) From TPSDIV
#      Endif
#    Endif
    If evalue("dim([M]NATCOD"+num$(COL)+")")>0
      Call AXECODINICCE(evalue("[M]NATCOD"+num$(COL)),evalue("[M]TIM"+num$(COL)),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
    Else
      Call AXECODINICCE("",evalue("[M]TIM"+num$(COL)),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
    Endif
  Endif
  GSOCIETE=SAU_GSOCIETE
#end 92876_US2759
Return

$AS_CCE
#92876_US2759
If AXE>[M]NBRDIE : Return : Endif
If evalue("[M:TPSJ]CCE"+num$(AXE)+num$(COL))<>"" Then Return : Endif
If evalue("dim([M]DSP"+num$(COL)+")")>0 & evalue("[M]DSP"+num$(COL))<>"" : mkstat = 1 : Return : Endif

Local Char SAU_GSOCIETE(GLONCPY), FCY_REF(GLONFCY)
Local Integer OK, ISEDITABLE

SAU_GSOCIETE=GSOCIETE
#LIPET - 11-01-2017 - X3-11322 - START
#Control if dimension type is following by the company (site)
#If evalue("dim([M]FCYT"+num$(COL)+")")<0 Then
#  Local    Date    XITDAT, CTRDAT_REF
#  If clalev([F:CTRD])=0 : Local File EMPLOCTR [CTRD] : Endif
#  If evalue("dim([M]CTRDAT"+num$(COL)+")")>0 Then
#    CTRDAT_REF=evalue("[M]CTRDAT"+num$(COL))
#    Read [F:CTRD]CTR0=[M]REFNUM;[M]CTRNUM;CTRDAT_REF
#  Else
#    Filter [CTRD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]DAT(COL-1) | (FLGRET=2 & RETDATEFF<=[M]DAT(COL-1)))
#    Read [F:CTRD] Last
#    CTRDAT_REF=[F:CTRD]CTRDAT
#  Endif
#  FCY_REF=[F:CTRD]ETRFCY
If evalue("dim([M]FCYT"+num$(COL)+")")<0 Then
  Local    Date    XITDAT, CTRDAT_REF
  If clalev([F:HRCTRD])=0 : Local File EMPLOCTR [HRCTRD] : Endif
  If evalue("dim([M]CTRDAT"+num$(COL)+")")>0 Then
    CTRDAT_REF=evalue("[M]CTRDAT"+num$(COL))
    Read [F:HRCTRD]CTR0=[M]REFNUM;[M]CTRNUM;CTRDAT_REF
  Else
    Filter [HRCTRD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M]DAT(COL-1) | (FLGRET=2 & RETDATEFF<=[M]DAT(COL-1)))
    Read [F:HRCTRD] Last
    CTRDAT_REF=[F:HRCTRD]CTRDAT
  Endif
  FCY_REF=[F:HRCTRD]ETRFCY
#LIPET - 11-01-2017 - X3-11322 - END
Else
  FCY_REF=evalue("[M]FCYT"+num$(COL))
Endif
If FCY_REF="" Then FCY_REF=[M]FCY : Endif
If FCY_REF<>""
  Call CPY_AXE(AXE,FCY_REF,OK) From TPSDIV
  GSOCIETE=func DIVPAYE.GETSOC(FCY_REF)
Endif
If GSOCIETE="" Then GSOCIETE=SAU_GSOCIETE : Endif
If !OK : mkstat = 1 : GSOCIETE=SAU_GSOCIETE : Return : Endif
######
#Control if the dimension type is following by the time event
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
#J=find([M]WDIE(AXE-1),[F:TIM]DIE(0..GOPTCANA-1))
#If J
#  If ([F:TIM]CCEDAC(J-1)<>2 | ([F:TIM]CCEDAC(J-1)=2 & VALEUR=""))
#    VALEUR = ""
#    If evalue("dim([M]NATCOD"+num$(COL)+")")>0
#      Call INICCE(evalue("[M]NATCOD"+num$(COL)),evalue("[M]TIM"+num$(COL)),J,VALEUR) From TPSDIV
#    Else
#      Call INICCE("",evalue("[M]TIM"+num$(COL)),J,VALEUR) From TPSDIV
#    Endif
#  Endif
#  If [F:TIM]CCEDAC(J-1)<>2 : mkstat = 2 : Endif
#Endif
If evalue("dim([M]NATCOD"+num$(COL)+")")>0
  Call AXECODINICCE(evalue("[M]NATCOD"+num$(COL)),evalue("[M]TIM"+num$(COL)),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
Else
  Call AXECODINICCE("",evalue("[M]TIM"+num$(COL)),[M]WDIE(AXE-1),VALEUR, ISEDITABLE) From TPSDIV
Endif
If ISEDITABLE<>2
  mkstat=2
Endif
GSOCIETE=SAU_GSOCIETE
#end 92876_US2759
Return

###########################################################################################
# ContrÃīle des sections analytiques
###########################################################################################
#92876_US2759
$C_CCE
If AXE>[M]NBRDIE : Return : Endif

Call CONTCCEOBG (VALEUR, AXE) From TPSDIV
If mkstat : Return : Endif

If evalue("dim([M]FCYT"+num$(COL)+")")>0
  Call SECTION(VALEUR,2,evalue("[M]FCYT"+num$(COL)),[M]DAT(0),[M]WDIE(AXE-1)) From SUPCPT
Else
  Call SECTION(VALEUR,2,[M]FCY,[M]DAT(0),[M]WDIE(AXE-1)) From SUPCPT
Endif
Return
