#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modifications :
#   FQ81491 - 15/11/13 - prise en compte date d'effet + fiches de rÃĐtroactivitÃĐ
######################################################################################
$AM_REFNUM
Local Integer I, STAT
Read [ID]ID0 = VALEUR
[M]NAM = [F:ID]NAM-[F:ID]SRN
Affzo NAM
[M]REFNUM = VALEUR
Raz [M]CTRNUM
If [F:ID]FLGMULCTR<>2
 Effzo CTRNUM
 Diszo CTRNUM
 Affzo CTRNUM
Else
 Actzo CTRNUM
 Affzo CTRNUM
Endif
If [F:ID]FLGMULCTR<>2
 If [M]NUMWEK<>0 & [M]YEA<>0
  #LIPET - 11-01-2017 - X3-11322 - START
  # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'oÃđ l'ajout de FLGRET et RETDATEFF
#  Filter [CTR] Where REFNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,[M]YEA)))
#  Read[CTR]CTR1 Last
#  Filter [CTR]
#  If !fstat
#   [M]FCY    = [F:CTR]ETRFCY
#   [M]SRV    = [F:CTR]ETRSRV
#   [M]CTRNUM = [F:CTR]CTRNUM
  Filter [HRCTR] Where REFNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,[M]YEA)))
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCY    = [F:HRCTR]ETRFCY
   [M]SRV    = [F:HRCTR]ETRSRV
   [M]CTRNUM = [F:HRCTR]CTRNUM
  #LIPET - 11-01-2017 - X3-11322 - END
  Endif
  Affzo FCY, SRV,CTRNUM
  Gosub CHARGE From TPSJOU
  If STAT=0 : mkstat=2 : Return : Endif
 Else
  [M]FCY = [F:ID]FCY
  [M]SRV = [F:ID]SRV
  Affzo FCY, SRV
  Call LECTURE("FCY",[F:ID]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  Call LECTURE("SRV",[F:ID]SRV,"") From CONTOBJ
 Endif
 Gosub CONGES_PARTIEL
Endif
Return

$AS_CTRNUM
If VALEUR=""
 Call SELCTR([M]REFNUM,aweek([M]NUMWEK,[M]YEA),aweek([M]NUMWEK,[M]YEA),VALEUR) From DIVPAYE
 # Maj site et service
 Gosub AM_CTRNUM
Endif
Return

$AM_CTRNUM
If [M]NUMWEK<>0 & [M]YEA<>0
 #LIPET - 11-01-2017 - X3-11322 - START
 # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'oÃđ l'ajout de FLGRET et RETDATEFF
# Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,[M]YEA)))
# Read [CTR]CTR0 Last
# Filter [CTR]
# If !fstat
#  [M]FCY    = [F:CTR]ETRFCY
#  [M]SRV    = [F:CTR]ETRSRV
#  Affzo FCY, SRV
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR & ((FLGRET<>2 & CTRDAT<=aweek([M]NUMWEK,[M]YEA)) | (FLGRET=2 & RETDATEFF<=aweek([M]NUMWEK,[M]YEA)))
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY    = [F:HRCTR]ETRFCY
  [M]SRV    = [F:HRCTR]ETRSRV
  Affzo FCY, SRV
 #LIPET - 11-01-2017 - X3-11322 - END
 Endif
 [M]CTRNUM = VALEUR
 Gosub CHARGE From TPSJOU
 If STAT=0 : mkstat=2 : Return : Endif
Else
#LIPET - 11-01-2017 - X3-11322 - START
# Filter [CTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
# Read [CTR]CTR0 Last
# Filter [CTR]
# If !fstat
#  [M]FCY    = [F:CTR]ETRFCY
#  [M]SRV    = [F:CTR]ETRSRV
#  Affzo FCY, SRV
 Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM=VALEUR
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If !fstat
  [M]FCY    = [F:HRCTR]ETRFCY
  [M]SRV    = [F:HRCTR]ETRSRV
  Affzo FCY, SRV
#LIPET - 11-01-2017 - X3-11322 - END
 Endif
Endif
Return

$D_TIM
Local Integer PLAG
PLAG = val(left$([M]NUMPLG,1))
If (evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(PLAG)+")")<=0) |
&(evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(PLAG)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(PLAG))<>"")
 VALEUR = GTPSDEF
Endif
Return

$C_TIM
If VALEUR="" :
  If clalev([F:STD])=0 : Local File SCRTPSD [STD] : Endif
  Read [F:STD]STD1=GFLAG;"TIM"
  Local Integer PLAG
  PLAG=val(left$([M]NUMPLG,1))
  If !fstat & [F:STD]OBG=2 & evalue("dim([M]STRTIM"+num$(COL)+num$(PLAG)+")")>0 & evalue("[M]STRTIM"+num$(COL)+num$(PLAG))<>"" & evalue("[M]ENDTIM"+num$(COL)+num$(PLAG))<>"" Then
    #LIPET - 11-01-2017 - X3-11322 - START
    #GMESSAGE = mess(198,709,1) : # La saisie d'un ÃĐvÃĐnement est obligatoire
    GMESSAGE = mess(198,10709,1)
    #LIPET - 11-01-2017 - X3-11322 - END
    mkstat = 2
  Endif
  Return
Endif
Local Char    VALPAR(10)
Local Integer OK

If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CNE])=0 : Local File CNGEMP   [CNE] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY   [CNG] : Endif
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]CTLDAC=2 & eomonth([M]DAT(COL-1))> eomonth(GMOIPAY)
#LIPET - 11-01-2017 - X3-11322 - START
 #GMESSAGE = mess(109,709,1) : # Saisie anticipÃĐe interdite pour ce code temps
 GMESSAGE = mess(109,10709,1)
#LIPET - 11-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Endif

If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 If fstat or [F:ACC]EXEC<>2
 #LIPET - 11-01-2017 - X3-11322 - START
  #GMESSAGE = VALEUR-":"-mess(61,709,1) : # Vous n'avez pas accÃĻs Ã  ce code
  GMESSAGE = VALEUR-":"-mess(61,10709,1)
 #LIPET - 11-01-2017 - X3-11322 - END
  mkstat = 2 : Return
 Endif
Endif
If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Local Integer RET
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M]REFNUM,[M]CTRNUM,RET) From DIVPAYE
  If RET>0 Then
    #LIPET - 13-02-2017 - X3-25371 - START
    #GMESSAGE= VALEUR-":"-mess(320,199,1) : # Nature d'ÃĐvÃĐnement incompatible avec ce salariÃĐ
    GMESSAGE= VALEUR-":"-mess(220,10709,1) : # Nature d'ÃĐvÃĐnement incompatible avec ce salariÃĐ
    #LIPET - 13-02-2017 - X3-25371 - END
    mkstat=2 : End
  Endif
Endif
If find(VALEUR,GEVT(0..3)) & evalue("dim([M]TYPPGN"+num$(COL)+")")<=0
 # La zone "Type d'arrÃŠt" n'est pas activÃĐe dans cet ÃĐcran. Veuillez choisir une autre transaction de saisie.
 #LIPET - 11-01-2017 - X3-11322 - START
  #GMESSAGE = mess(185,709,1)
  GMESSAGE = mess(185,10709,1)
 #LIPET - 11-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Endif

#LIPET - 11-01-2017 - X3-11322 - START
#If [F:PEO]STA<>2
# If !instr(1,GUSRAUZ(1),"5") and (VALEUR<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
#  GMESSAGE = mess(104,709,1) : # PÃĐriode fermÃĐe, ÃĐvÃĐnement interdit
#  mkstat = 2 : Return
# Endif
#Endif
#If VALEUR<>evalue("[M]TIM"+num$(COL)) & evalue("dim([M]CMT"+num$(COL)+")")>0
#&& evalue("[M]CMT"+num$(COL))=mess(26,709,1)
# Assign "[M]CMT"+num$(COL) With ""
# VCMT  = "CMT"+num$(COL)
# Affzo =VCMT
#Endif
If [F:HRPEOD]STA<>2
 If !instr(1,GUSRAUZ(1),"5") and (VALEUR<>GTPSW or !instr(1,GUSRAUZ(1),"6"))
  GMESSAGE = mess(104,10709,1) : # PÃĐriode fermÃĐe, ÃĐvÃĐnement interdit
  mkstat = 2 : Return
 Endif
Endif
If VALEUR<>evalue("[M]TIM"+num$(COL)) & evalue("dim([M]CMT"+num$(COL)+")")>0
&& evalue("[M]CMT"+num$(COL))=mess(26,10709,1)
 Assign "[M]CMT"+num$(COL) With ""
 VCMT  = "CMT"+num$(COL)
 Affzo =VCMT
Endif
#LIPET - 11-01-2017 - X3-11322 - END


If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Filter [CNG] Where CPY=[F:FCY]LEGCPY & TIM=VALEUR & ( (STRDAT<=[M:TPSJ]DAT(COL-1) & ENDDAT>=[M:TPSJ]DAT(COL-1)) | (DEBDAT<=[M:TPSJ]DAT(COL-1) & FINDAT>=[M:TPSJ]DAT(COL-1)) )
#JASMI - 2014-09-04 - START
#LIPET - 11-01-2017 - X3-11322 - START
# If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#LIPET - 11-01-2017 - X3-11322 - END
  Filter [F:CNE] Where TIM=VALEUR & REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EMPLEASTR<=[M:TPSJ]DAT(COL-1) & EMPLEAEND>=[M:TPSJ]DAT(COL-1)
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
    Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=VALEUR & YEA=[F:CNE]YEA
  Endif
 Endif
#JASMI - 2014-09-04 - END
 Read [CNG]CNG0 First
 Filter [CNG]
 If !fstat
  Read [CNE]CNE0=[F:CNG]YEA;[M]REFNUM;[M]CTRNUM;VALEUR
  If fstat
   #LIPET - 11-01-2017 - X3-11322 - START
   #GMESSAGE = mess(165,709,1)-num$([F:CNG]YEA) : # Fiche congÃĐ par employÃĐ inexistante pour l'annÃĐe
   GMESSAGE = mess(165,10709,1)-num$([F:CNG]YEA)
   #LIPET - 11-01-2017 - X3-11322 - END
   mkstat = 2 : End
  Endif
 Else
 #LIPET - 13-02-2017 - X3-25371 - START
   GMESSAGE = mess(663,199,1)-[F:TIM]COD : # Fiche pÃĐriode de congÃĐ inexistante pour l'ÃĐvÃĻnement
  #GMESSAGE = mess(319,199,1)-[F:TIM]COD : # Fiche pÃĐriode de congÃĐ inexistante pour l'ÃĐvÃĻnement
  #LIPET - 13-02-2017 - X3-25371 - END
  mkstat = 2 : End
 Endif
Endif

# CongÃĐs en jours ouvrables => on doit reprendre un jour ouvrÃĐ
If VALEUR=[M:TPSI]CPA : # Pour Adonix, faura peut ÃŠtre limiter aux temps partiels ??
 If func TPSSTD1.OUVRABLE([M:TPSJ]REFNUM,[M:TPSJ]DAT(COL-1)+1,[M:TPSJ]CTRNUM)
  #LIPET - 11-01-2017 - X3-11322 - START
  #OK = 1 : Call AVERTIR(mess(70,709,1),OK) From GESECRAN
  OK = 1 : Call AVERTIR(mess(70,10709,1),OK) From GESECRAN
  #LIPET - 11-01-2017 - X3-11322 - END
#                       Reprise d'activitÃĐ un jour ouvrable
  If OK<>2 : mkstat = 2 : Return : Endif
 Endif
Endif
Return


$AM_TIM
Local Integer PLAG, INI
Local Char    CCE(GLONCCE)(1..)
Local Integer RECOPIE, OK
Local Decimal NBJR
# Pas de code ÃĐvÃĻnement
 If VALEUR=""
 Gosub TIMVIDE
 Return
 Endif

If [F:TIM]CMTOBG=2 & dim([M]CMT1)<0
 # Saisie du commentaire obligatoire.
 # Transaction inadaptÃĐe Ã  la saisie de cet ÃĐvÃĻnement.
 #LIPET - 11-01-2017 - X3-11322 - START
 #GMESSAGE = mess(144,709,1)
 GMESSAGE = mess(144,10709,1)
 #LIPET - 11-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Endif

If dim([M:TPSJ]NBRDAY1)>0
 NBJR = evalue("[M:TPSJ]NBRDAY"+num$(COL))
Else
 NBJR = evalue("[M:TPSI]KNBRDAY"+left$([M:TPSJ]NUMPLG,1)+"("+num$(COL-1)+")")
Endif
If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 # Il faut maj le compteur du nouvel ÃĐvÃĻnement saisi si le ctrl est ok
 Call CTRL_CP([M:TPSJ]FCY,VALEUR,[M:TPSJ]DAT(COL-1),[M:TPSJ]DAT(COL-1),[M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,NBJR,[F:TIM]BLCMIN,OK)
 If !OK
  mkstat=2 : Return
 Else
  # Mise Ã  jour du compteur des jours de congÃĐs posÃĐs du nouvel ÃĐvÃĻnement
  Call CHERCHE_CP(VALEUR,NBJR,[M:TPSJ]DAT(COL-1),+1)
  If mkstat : Return : Endif
 Endif
Endif
# Si l'ÃĐvÃĻnement modifiÃĐ ÃĐtait de type congÃĐ il faut maj son compteur des jours de congÃĐs posÃĐs(on enlÃĻve de son compteur les CP pris)
Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),NBJR,[M:TPSJ]DAT(COL-1),-1)
If mkstat : Return : Endif

PLAG = val(left$([M]NUMPLG,1))

# On recopie sur les autres plages si modif de la plage 1
If [M:TPSI]COP="2" & PLAG=1 & [M:TPSI]NBHOR>1 & dim([M:TPSJ]STRTIM11)>0 & [F:TIM]PLGHOR=2 & VALEUR<>""
 If evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(2)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(2))<>""
  Assign "[M:TPSI]KTIM2("+num$(COL-1)+")" With VALEUR
  Assign "[M:TPSI]KLEADAY2("+num$(COL-1)+")" With 3
 Endif
 If evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(3)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(3))<>""
  Assign "[M:TPSI]KTIM3("+num$(COL-1)+")" With VALEUR
  Assign "[M:TPSI]KLEADAY3("+num$(COL-1)+")" With 3
 Endif
Endif

# Mise Ã  jour de toutes les zones qui dÃĐcoulent du code ÃĐvÃĻnement
Gosub DEC_PLAGE
Call JOUR([M]REFNUM,[M]DAT(COL-1),TYPJOU,JOUR,HEURE,JNUIT,[M]FCY,[M]CTRNUM,PLAG,HREDEB,HREFIN,TPSBRK,NATACT,
&          CCE,INI) From SUBPLN
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",VALEUR,"") From CONTOBJ
Call LECTURE("HRTIM",VALEUR,GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]PLGHOR<>2
 If evalue("dim([M]STRTIM"+num$(COL)+num$(PLAG)+")")>0
 Endif
Else
 If evalue("dim([M]STRTIM"+num$(COL)+num$(PLAG)+")")>0 & evalue("[M]STRTIM"+num$(COL)+num$(PLAG))<>""
# Si STRTIM** est vide, on transfert STRTIM** ou ENDTIM** que si on a la plage horaire Ã  Oui dans la nature d'ÃĐvÃĐnement
  Assign "[M]STRTIM"+num$(COL)+num$(PLAG) With HREDEB
  Assign "[M]ENDTIM"+num$(COL)+num$(PLAG) With HREFIN
  Affzo ="[M]STRTIM"+num$(COL)+num$(PLAG)
  Affzo ="[M]ENDTIM"+num$(COL)+num$(PLAG)
  If evalue("[M]STRTIM"+num$(COL)+num$(PLAG))=""
    #LIPET - 11-01-2017 - X3-11322 - START
    #GMESSAGE = mess(141,709,1) : # Plage horaire non saisie
    GMESSAGE = mess(141,10709,1)
    #LIPET - 11-01-2017 - X3-11322 - END
    mkstat = 2 : Return
  Endif
 Endif
 If evalue("dim([M]BRKTIM"+num$(COL)+")")>0
  Assign "[M]BRKTIM"+num$(COL) With TPSBRK
  Affzo ="[M]BRKTIM"+num$(COL)
 Endif
Endif

If evalue("dim([M]NATCOD"+num$(COL)+")")>0 & [F:TIM]NATACT=2
 Assign "[M]NATCOD"+num$(COL) With NATACT
 Affzo ="[M]NATCOD"+num$(COL)
 If NATACT<>""
  Call LECTURE("NAT",NATACT,GCURLEG) From CONTOBJ
  Gosub NATACT
 Endif
Endif

If  evalue("dim([M]TYPPGN"+num$(COL)+")")>0
 Assign "[M]TYPPGN"+num$(COL) With 0
Endif


Return

$TIMVIDE
# Si ÃĐvÃĻnement vide, on raz les zones de la plage courante
# On ne raz pas les zones des autres plages mÃŠme si plage courante=1 et paramÃĻtre COPPLG Ã  Oui
If evalue("dim([M]STRTIM"+num$(COL)+num$(PLAG)+")")>0
 Effzo ="[M]STRTIM"+num$(COL)+num$(PLAG)
 Effzo ="[M]ENDTIM"+num$(COL)+num$(PLAG)
Endif

# Zones alpha
For ZONCOP="NATCOD","FLD1","FLD2","CPY","BPCNUM","SOHNUM","CMT","STAFLG","DSP","CCE1","CCE2","CCE3",
&           "CCE4","CCE5","CCE6","CCE7","CCE8","CCE9"
 If evalue("dim([M:TPSJ]"+ZONCOP+num$(COL)+")")>0
  Effzo ="[TPSJ]"+ZONCOP+num$(COL)
 Endif
Next

# Zones numÃĐriques
For ZONCOP="BRKTIM","LEADAY","DAYNGT","TYPDAY","QTY1","QTY2","SOHLIG","INVFLG","NBRDAY","NBRHOU"
 If evalue("dim([M:TPSJ]"+ZONCOP+num$(COL)+")")>0
  Effzo ="[TPSJ]"+ZONCOP+num$(COL)
 Endif
Next
Return

$NATACT
Raz RECOPIE

If [M:TPSI]COP="2" & val(left$([M]NUMPLG,1))=1 & [M:TPSI]NBHOR>1 & dim([M:TPSJ]STRTIM11)>0 & [F:TIM]PLGHOR=2
 If evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(2)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(2))<>"" : RECOPIE = 1 : Endif
 If evalue("dim([M:TPSJ]STRTIM"+num$(COL)+num$(3)+")")>0 & evalue("[M:TPSJ]STRTIM"+num$(COL)+num$(3))<>"" : RECOPIE = 2 : Endif
Endif
If RECOPIE>=1 : Assign "[M:TPSI]KNATCOD2("+num$(COL-1)+")" With [F:NAT]COD : Endif
If RECOPIE>=2 : Assign "[M:TPSI]KNATCOD3("+num$(COL-1)+")" With [F:NAT]COD : Endif
If evalue("dim([M]DAYNGT"+num$(COL)+")")>0 & [F:TIM]NGTDAY=2
 Assign "[M]DAYNGT"+num$(COL) With [F:NAT]DAYNGT
 Affzo ="[M]DAYNGT"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KDAYNGT2("+num$(COL-1)+")" With [F:NAT]DAYNGT : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KDAYNGT3("+num$(COL-1)+")" With [F:NAT]DAYNGT : Endif
Endif
If evalue("dim([M]TYPDAY"+num$(COL)+")")>0 & [F:TIM]TYPDAY=2
 Assign "[M]TYPDAY"+num$(COL) With [F:NAT]TYPDAY
 Affzo ="[M]TYPDAY"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KTYPDAY2("+num$(COL-1)+")" With [F:NAT]TYPDAY : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KTYPDAY3("+num$(COL-1)+")" With [F:NAT]TYPDAY : Endif
Endif
If evalue("dim([M]QTY1"+num$(COL)+")")>0
 Assign "[M]QTY1"+num$(COL)   With [F:NAT]QTY1
 Affzo ="[M]QTY1"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KQTY12("+num$(COL-1)+")" With [F:NAT]QTY1 : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KQTY13("+num$(COL-1)+")" With [F:NAT]QTY1 : Endif
Endif
If evalue("dim([M]QTY2"+num$(COL)+")")>0
 Assign "[M]QTY2"+num$(COL)   With [F:NAT]QTY2
 Affzo ="[M]QTY2"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KQTY22("+num$(COL-1)+")" With [F:NAT]QTY2 : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KQTY23("+num$(COL-1)+")" With [F:NAT]QTY2 : Endif
Endif
If evalue("dim([M]FLD1"+num$(COL)+")")>0
 Assign "[M]FLD1"+num$(COL)   With [F:NAT]FLD1
 Affzo ="[M]FLD1"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KFLD12("+num$(COL-1)+")" With [F:NAT]FLD1 : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KFLD13("+num$(COL-1)+")" With [F:NAT]FLD1 : Endif
Endif
If evalue("dim([M]FLD2"+num$(COL)+")")>0
 Assign "[M]FLD2"+num$(COL)   With [F:NAT]FLD2
 Affzo ="[M]FLD2"+num$(COL)
 If RECOPIE>=1 : Assign "[M:TPSI]KFLD22("+num$(COL-1)+")" With [F:NAT]FLD2 : Endif
 If RECOPIE>=2 : Assign "[M:TPSI]KFLD23("+num$(COL-1)+")" With [F:NAT]FLD2 : Endif
Endif
Return

$AS_TYPPGN
If !find(evalue("[M]TIM"+num$(COL)),GEVT)
 mkstat=1 : Return
Endif

If VALEUR : Return : Else : VALEUR=1 : Endif

#Si un congÃĐ patho prÃĐnatal PATHM est suivi d'un congÃĐs maternitÃĐ, la maternitÃĐ doit ÃŠtre typÃĐ 'prolongation'
If evalue("[M]TIM"+num$(COL)) = func AFNC.PARAM("MATERNITE","")
 If COL>1
  If (evalue("[M]TIM"+num$(COL-1))=evalue("[M]TIM"+num$(COL)) | evalue("[M]TIM"+num$(COL-1))=func AFNC.PARAM("PATHPREN",""))
&    & [M]DAT(COL-2)=[M]DAT(COL-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,evalue("[M]TIM"+num$(COL)),func AFNC.PARAM("PATHPREN",""),[M]REFNUM,[M]DAT(COL-1)) From TPSSTD
 Endif
#Si un congÃĐ patho postnatal PATHO est suivi d'un congÃĐs maladie, la maladie doit ÃŠtre typÃĐ 'prolongation'
Elsif evalue("[M]TIM"+num$(COL)) = func AFNC.PARAM("MALADIE","")
 If COL>1
  If (evalue("[M]TIM"+num$(COL-1))=evalue("[M]TIM"+num$(COL)) | evalue("[M]TIM"+num$(COL-1))=func AFNC.PARAM("PATHPOST",""))
&    & [M]DAT(COL-2)=[M]DAT(COL-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,evalue("[M]TIM"+num$(COL)),func AFNC.PARAM("PATHPOST",""),[M]REFNUM,[M]DAT(COL-1)) From TPSSTD
 Endif
Elsif find(evalue("[M]TIM"+num$(COL)),GEVT)
If COL>1
  If evalue("[M]TIM"+num$(COL-1))=evalue("[M]TIM"+num$(COL)) & [M]DAT(COL-2)=[M]DAT(COL-1)-1
   VALEUR=2 : Else : VALEUR=1
  Endif
 Else
  Call INIT_TYPPNG(VALEUR,evalue("[M]TIM"+num$(COL)),evalue("[M]TIM"+num$(COL)),[M]REFNUM,[M]DAT(COL-1)) From TPSSTD
 Endif
Endif
Return

$AS_STRTIM
Local Integer I
Local Decimal NBH, NBJ, VALHOU
# EvÃĻnement cochÃĐ "Saisie plage horaire"
#LIPET - 11-01-2017 - X3-11322 - START
#If PLAG<>val(left$([M]NUMPLG,1))
# Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+num$(PLAG)+"("+num$(COL-1)+")"),"") From CONTOBJ
#Else
# Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
#Endif
If PLAG<>val(left$([M]NUMPLG,1))
 Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+num$(PLAG)+"("+num$(COL-1)+")"),GCURLEG) From CONTOBJ
Else
 Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
Endif
#LIPET - 11-01-2017 - X3-11322 - END
If !fstat & [F:TIM]PLGHOR<>2
 mkstat = 1 : Return
Endif
# Si on a saisi "maladie" sur 1 jour, inutile d'accÃĐder aux autres plages horaires de ce jour
If VALEUR=""
 For I=1 To [M:TPSI]NBHOR
  If I=val(left$([M]NUMPLG,1)) & evalue("dim([M]NBRHOU"+num$(COL)+")")>0
   NBH += evalue("[M]NBRHOU"+num$(COL))
  Else
   NBH += evalue("[M:TPSI]KNBRHOU"+num$(I)+"("+num$(COL-1)+")")
  Endif
 Next


 VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M]FCY))
 If VALHOU>0 & NBH>=VALHOU
  # Maximum d'heures par jour
  #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU)
  mkstat = 2 : Return
 Endif
 For I=1 To [M:TPSI]NBHOR
  If I=val(left$([M]NUMPLG,1)) & evalue("dim([M]NBRDAY"+num$(COL)+")")>0
  #LIPET - 11-01-2017 - X3-11322 - START
   #Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
   Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
  #LIPET - 11-01-2017 - X3-11322 - END
   If [F:TIM]DAYDAC=2 : # Saisie en jours
    NBJ += evalue("[M]NBRDAY"+num$(COL))
   Endif
  Else
  #LIPET - 11-01-2017 - X3-11322 - START
   #Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+num$(I)+"("+num$(COL-1)+")"),"") From CONTOBJ
   Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+num$(I)+"("+num$(COL-1)+")"),GCURLEG) From CONTOBJ
  #LIPET - 11-01-2017 - X3-11322 - END
   If [F:TIM]DAYDAC=2 : # Saisie en jours
    NBJ += evalue("[M:TPSI]KNBRDAY"+num$(I)+"("+num$(COL-1)+")")
   Endif
  Endif
 Next
 If NBJ>=1 : mkstat = 2 : Return : Endif
Endif
Return

$C_STRTIM
If VALEUR="" | GNBHOR<=1 : Return : Endif
Local Decimal DEBTIM,FINTIM
For I=1 To GNBHOR
 If I<>PLAG & evalue("[M]STRTIM"+num$(COL)+num$(I))<>""    : #Ne pas comparer avec les plages horaires vides (non encore saisies)
  DEBTIM = evalue("val([M]STRTIM"+num$(COL)+num$(I)+")")
  FINTIM = evalue("val([M]ENDTIM"+num$(COL)+num$(I)+")")
  If (DEBTIM<FINTIM & val(VALEUR)>=DEBTIM & val(VALEUR)<FINTIM)
&    |   (DEBTIM>FINTIM & (val(VALEUR)>DEBTIM | val(VALEUR)<FINTIM))
  #LIPET - 11-01-2017 - X3-11322 - START
   #GMESSAGE = mess(126,709,1)-num$(I) : # Infos dÃĐjÃ  saisie pour cette date dans la plage xx
   GMESSAGE = mess(126,10709,1)-num$(I)
  #LIPET - 11-01-2017 - X3-11322 - END
   mkstat = 2 : Break
  Endif
 Endif
Next
If mkstat : Return : Endif
Return

$AS_ENDTIM
#LIPET - 11-01-2017 - X3-11322 - START
# EvÃĻnement cochÃĐ "Saisie plage horaire"
#If PLAG<>val(left$([M]NUMPLG,1))
# Call LECTURE("TIM",evalue("[M:TPSI]KTIM"+num$(PLAG)+"("+num$(COL-1)+")"),"") From CONTOBJ
#Else
# Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
#Endif
If PLAG<>val(left$([M]NUMPLG,1))
 Call LECTURE("HRTIM",evalue("[M:TPSI]KTIM"+num$(PLAG)+"("+num$(COL-1)+")"),GCURLEG) From CONTOBJ
Else
 Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
Endif
#LIPET - 11-01-2017 - X3-11322 - END
If !fstat & [F:TIM]PLGHOR<>2
 mkstat = 1 : Return
Endif
If evalue("[M]STRTIM"+num$(COL)+num$(PLAG))=""
 mkstat = 1 : Return
Endif
Return

$C_ENDTIM
If evalue("[M]STRTIM"+num$(COL)+num$(PLAG))="" & VALEUR<>""
 Raz VALEUR
Endif
If VALEUR="" | GNBHOR<=1 : Return : Endif
Local Decimal DEBTIM,FINTIM, DEBVALEUR
DEBVALEUR = evalue("val([M]STRTIM"+num$(COL)+num$(PLAG)+")")
For I=1 To GNBHOR
 If I<>PLAG & evalue("[M]STRTIM"+num$(COL)+num$(I))<>""    : #Ne pas comparer avec les plages horaires vides (non encore saisies)
  DEBTIM = evalue("val([M]STRTIM"+num$(COL)+num$(I)+")")
  FINTIM = evalue("val([M]ENDTIM"+num$(COL)+num$(I)+")")
  If val(VALEUR)>DEBTIM & val(VALEUR)<FINTIM
&    | ( val(VALEUR)>DEBVALEUR & val(VALEUR)>DEBTIM & DEBVALEUR<FINTIM)
&    | ( val(VALEUR)<DEBVALEUR & val(VALEUR)>DEBTIM & DEBVALEUR>FINTIM)
   #ADNGO - 26-01-2017 - X3-11322 - START
   #GMESSAGE = mess(126,709,1)-num$(I) : # Infos dÃĐjÃ  saisie pour cette date dans la plage xx
   GMESSAGE = mess(126,10709,1)-num$(I) : # Infos dÃĐjÃ  saisie pour cette date dans la plage xx
   #ADNGO - 26-01-2017 - X3-11322 - END
   mkstat = 2 : Break
  Endif
 Endif
Next
If mkstat : Return : Endif
Return

$AS_BRKTIM
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]PLGHOR<>2
 mkstat = 1 : Return
Endif
Return

$AS_LEADAY
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]CATTIM<>3
 VALEUR = 3 : #JournÃĐe
 Assign "[M]NBRDAY"+num$(COL) With 1
 mkstat = 2 : End
Endif
Return

$AM_LEADAY
Local Decimal JOUR, HEURE
Local Integer OK

If [F:TIM]CATTIM=3 & (VALEUR<>3 | evalue("[M:TPSJ]NBRDAY"+num$(COL))<=0.5) : # journÃĐe
 If (VALEUR=1 | VALEUR=2) : # 1/2 journÃĐe
  Call VALORISAM([M]DAT(COL-1),[M]DAT(COL-1),[M]REFNUM,evalue("[M]TIM"+num$(COL)),JOUR,HEURE,[M]FCY,[M]CTRNUM,1) From SUBPLN
 Else
  JOUR = 1
 Endif

 ## On dÃĐcrÃĐmente le compteur de CP
 Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),evalue("[M:TPSJ]NBRDAY"+num$(COL)),[M:TPSJ]DAT(COL-1),-1)
 If mkstat : Return : Endif
 Call CTRL_CP([M:TPSJ]FCY,evalue("[M:TPSJ]TIM"+num$(COL)),[M:TPSJ]DAT(COL-1),[M:TPSJ]DAT(COL-1),[M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,JOUR,[F:TIM]BLCMIN,OK)
 If !OK
  ## Ctrl KO=>Mise Ã  jour du compteur des jours de congÃĐs posÃĐs avec l'ancienne valeur(+2)
  Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),evalue("[M:TPSJ]NBRDAY"+num$(COL)),[M:TPSJ]DAT(COL-1),+1)
  mkstat = 2 : Return
 Endif
 ## Mise Ã  jour du compteur des jours de congÃĐs posÃĐs avec la nouvelle valeur(+3)
 Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),JOUR,[M:TPSJ]DAT(COL-1),+1)
 If mkstat : Return : Endif
 Assign "[M]NBRDAY"+num$(COL) With JOUR
 If (VALEUR=1 | VALEUR=2) : # 1/2 journÃĐe
  Assign "[M]NBRHOU"+num$(COL) With HEURE
 Endif
Endif
Return

$AS_NATCOD
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]NATACT<>2
 mkstat = 1 : Return
Endif
Return

Subprog AM_NATCOD(VALEUR,COL)
Variable Char VALEUR
Value Integer COL
Local Integer RECOPIE
If VALEUR<>""
 Call LECTURE("NAT",VALEUR,GCURLEG) From CONTOBJ
 #LIPET - 11-01-2017 - X3-11322 - START
 #Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
 Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
 #LIPET - 11-01-2017 - X3-11322 - END
 Gosub NATACT
Endif
End

$AS_NBRDAY
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If fstat
 mkstat = 1 : Return
Endif
# EvÃĻnement non saisi en jours
If [F:TIM]DAYDAC<>2
 If [M:TPSI]WIOPLN=1
  mkstat = 1
 Else mkstat = 2
 Endif
 Return
Endif
Return

$C_NBRDAY
Local Integer I, J, OK
Local Decimal JOUR, HEURE
Local Char    VALPAR(10)
For I=1 To [M:TPSI]NBHOR
 If I<>val(left$([M]NUMPLG,1)) & evalue("[M:TPSI]KFLGVISU"+num$(I)+"("+num$(COL-1)+")")=0
  Case I
   When 1 : JOUR += [M:TPSI]KNBRDAY1(COL-1)
   When 2 : JOUR += [M:TPSI]KNBRDAY2(COL-1)
   When 3 : JOUR += [M:TPSI]KNBRDAY3(COL-1)
  Endcase
 Endif
Next I
If JOUR+VALEUR>1
#ADNGO - 26-01-2017 - X3-11322 - START
 #GMESSAGE = mess(3,709,1) : # Pas plus de 1 jour
 GMESSAGE = mess(3,10709,1) : # Pas plus de 1 jour
#ADNGO - 26-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Endif
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 ## Mise Ã  jour du compteur des jours de congÃĐs posÃĐs. On avait 2CP on modifie Ã  3CP
 ## => On dÃĐcrÃĐmente le compteur de CP pris de -2 et on controle avec une prise de CP de 3
 Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),evalue("[M:TPSJ]NBRDAY"+num$(COL)),[M:TPSJ]DAT(COL-1),-1)
 If mkstat : Return : Endif
 Call CTRL_CP([M:TPSJ]FCY,evalue("[M:TPSJ]TIM"+num$(COL)),[M:TPSJ]DAT(COL-1),[M:TPSJ]DAT(COL-1),[M:TPSJ]REFNUM,[M:TPSJ]CTRNUM,VALEUR,[F:TIM]BLCMIN,OK)
 If !OK
  ## Ctrl KO=>Mise Ã  jour du compteur des jours de congÃĐs posÃĐs avec l'ancienne valeur(+2)
  Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),evalue("[M:TPSJ]NBRDAY"+num$(COL)),[M:TPSJ]DAT(COL-1),+1)
  mkstat = 2 : Return
 Endif
 ## Mise Ã  jour du compteur des jours de congÃĐs posÃĐs avec la nouvelle valeur(+3)
 Call CHERCHE_CP(evalue("[M:TPSJ]TIM"+num$(COL)),VALEUR,[M:TPSJ]DAT(COL-1),+1)
 If mkstat : Return : Endif
Endif
If evalue("[M:TPSJ]TIM"+num$(COL))=GTPSW
  Call VALORIS([M:TPSJ]DAT(COL-1),[M:TPSJ]DAT(COL-1),[M:TPSJ]REFNUM,"",JOUR,
&             HEURE,[M:TPSJ]FCY,[M:TPSJ]CTRNUM) From SUBPLN
Else
  Call VALORIS([M:TPSJ]DAT(COL-1),[M:TPSJ]DAT(COL-1),[M:TPSJ]REFNUM,evalue("[M:TPSJ]TIM"+num$(COL)),JOUR,
&             HEURE,[M:TPSJ]FCY,[M:TPSJ]CTRNUM) From SUBPLN
Endif
If JOUR<>0
 If dim([M]NBRHOU1)>0
  Assign "[M:TPSJ]NBRHOU"+num$(COL) With ar2(HEURE*VALEUR/JOUR)
 Else
  Assign "[M:TPSI]KNBRHOU"+left$([M:TPSJ]NUMPLG,1)+"("+num$(COL-1)+")" With ar2(HEURE*VALEUR/JOUR)
 Endif
Endif
Return

$AS_NBRHOU
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If fstat
 mkstat = 1 : Return
Endif
# Le type de saisie de l'ÃĐvÃĻnement n'est pas en heures
If [F:TIM]HOUDAC<>2
 If [M:TPSI]WIOPLN=1
  mkstat = 1
 Else mkstat = 2
 Endif
 Return
Endif
# Si une plage horaire est saisie : Le nombre d'heures est calculÃĐ et non saisissable
If evalue("dim([M]STRTIM"+num$(COL)+left$([M]NUMPLG,1)+")")>0
&& evalue("[M]STRTIM"+num$(COL)+left$([M]NUMPLG,1))<>""
&& evalue("[M]ENDTIM"+num$(COL)+left$([M]NUMPLG,1))<>""
 mkstat=2 : Return
Endif
Return


$C_NBRHOU
Local Integer I, J
Local Decimal JOUR , HEURE, VALHOU
For I=1 To [M:TPSI]NBHOR
 If I<>PLAG
  HEURE += evalue("[M:TPSI]KNBRHOU"+num$(I)+"("+num$(COL-1)+")")
 Endif
Next I
VALHOU=val(func AFNC.PARAM("HOUDAYLEG",[M]FCY))
If VALHOU>0 & HEURE+VALEUR>VALHOU
 # Maximum d'heures par jour
 #ADNGO - 26-01-2017 - X3-11322 - START
 #GMESSAGE = mess(4,709,1)-":"-num$(VALHOU)
 GMESSAGE = mess(4,10709,1)-":"-num$(VALHOU)
 #ADNGO - 26-01-2017 - X3-11322 - END
 mkstat = 2 : Return
Endif
# Lors du controle Jour ou heure, si l'ÃĐvÃĻnement saisie est = GTPSW
# Ã  l'appel de VALORI on ne passe pas le type d'ÃĐvÃĻnement Ã  blanc
# ce qui permet de ne pas tenir compte des jours fÃĐriÃĐs pour le calcul des heures ou des jours
If evalue("[M]TIM"+num$(COL))=GTPSW
  Call VALORIS([M]DAT(COL-1),[M]DAT(COL-1),[M]REFNUM,"",JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Else
  Call VALORIS([M]DAT(COL-1),[M]DAT(COL-1),[M]REFNUM,evalue("[M]TIM"+num$(COL)),JOUR,HEURE,[M]FCY,[M]CTRNUM) From SUBPLN
Endif
If dim([M]NBRDAY1)>0
 If HEURE<>0
  Assign "[M]NBRDAY"+num$(COL) With min(JOUR,ar2(VALEUR*JOUR/HEURE))
 Else
  Assign "[M]NBRDAY"+num$(COL) With 0
 Endif
 Affzo ="[M]NBRDAY"+num$(COL)
Else
 If HEURE<>0
  Assign "[M:TPSI]KNBRDAY"+num$(PLAG)+"("+num$(COL-1)+")" With min(JOUR,ar2(VALEUR*JOUR/HEURE))
 Else
  Assign "[M:TPSI]KNBRDAY"+num$(PLAG)+"("+num$(COL-1)+")" With 0
 Endif
Endif
Return


$AS_DAYNGT
#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",evalue("[M]TIM"+num$(COL)),"") From CONTOBJ
Call LECTURE("HRTIM",evalue("[M]TIM"+num$(COL)),GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]NGTDAY<>2
 mkstat = 1 : Return
Endif
GMENLOC(3) = 1
Return

$D_TYPDAY
Case dayn([M]DAT(COL-1))
 When 6,7     : VALEUR = 2
 When Default : VALEUR = 1
Endcase
Return

