Subprog CADRE_SEM(SEM,AN,SITE,STAT)
Value Decimal    SEM
Value Decimal    AN
Value Char       SITE
Variable Integer STAT

Local Char       SITPEO(GLONFCY)
Local Integer    OK, I
Local Char       LESITE(GLONFCY)

#JOJAC - 2017-01-11 - START
#If clalev([F:PEO])=0 : Local File PERIOD [PEO] : Endif
If clalev([F:HRPEOH])=0 : Local File HRPEOHEA [HRPEOH] : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif
#JOJAC - 2017-01-11 - END

STAT = 1 : OK = 0
LESITE = SITE
#JOJAC - 2017-01-11 - START
#Call PERIO(LESITE,[M]REFNUM) From SUBPEO
#Filter [PEO] Where (FCY=LESITE | FCY="") & find(AN,YEAWEK)<>0  & find(SEM,NUMWEK)<>0 Order By FCY Desc
#For [PEO]
# I = find(SEM,[F:PEO]NUMWEK)
# If [F:PEO]YEAWEK(I-1)=AN
#  OK = 1 : Break
# Endif
#Next
#Filter [PEO]
Call PERIO(LESITE,[M]REFNUM) From SUBHRPEO

Filter [HRPEOD] Where PERCOD = [F:HRCTR]PERCOD & find(AN,YEAWEK)<>0  & find(SEM,NUMWEK)<>0 Order By PERCOD
For [HRPEOD]
 I = find(SEM,[F:HRPEOD]NUMWEK)
 If [F:HRPEOD]YEAWEK(I-1)=AN
  OK = 1 : Break
 Endif
Next
Filter [HRPEOD]
#JOJAC - 2017-01-11 - END

#LIPET - 11-01-2017 - X3-11322 - START
#If OK=0
# GMESSAGE = mess(12,709,1) : # Pas de paie dÃĐfinie Ã  cette date
# GERR = 2 : End
#Endif
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur pÃĐriode fermÃĐe
# GMESSAGE = mess(58,709,1) : # PÃĐriode non ouverte
# GERR = 2
#Else
# If GPAYE & !instr(1,GUSRAUZ(1),"3") : # Saisie sur paie calculÃĐe
#  Filter [VEP] Where EMP=[M]REFNUM & CTRNUM=[M]CTRNUM & PYRDAT=[F:PEO]PYRDAT
#  Read [VEP]VEP0 First
#  Filter [VEP]
#  If !fstat & [F:VEP]STA>=2
#   GMESSAGE = mess(15,709,1) : # Paie dÃĐjÃ  calculÃĐe
#   GERR = 2
#  Endif
# Endif
#Endif
#
#I = find(SEM,[F:PEO]NUMWEK(0..dim([F:PEO]NUMWEK)-1))
#I -=1
#[M]DAT(0) = [F:PEO]PERSTR(0)+(I*7)
#[M]DAT(1) = [M]DAT(0)+1
#[M]DAT(2) = [M]DAT(0)+2
#[M]DAT(3) = [M]DAT(0)+3
#[M]DAT(4) = [M]DAT(0)+4
#[M]DAT(5) = [M]DAT(0)+5
#[M]DAT(6) = [M]DAT(0)+6
#Call MAJ_PYRDAT([M]REFNUM,[M]CTRNUM,[F:PEO]FCY,[F:PEO]PYRDAT,[M]DAT,[M]PYRDAT, STAT) From TPSJOU
#If STAT=0 : End : Endif
If OK=0
 GMESSAGE = mess(12,10709,1) : # Pas de paie dÃĐfinie Ã  cette date
 GERR = 2 : End
Endif
#If [F:PEO]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur pÃĐriode fermÃĐe
If [F:HRPEOD]STA<>2 & !instr(1,GUSRAUZ(1),"5") & !instr(1,GUSRAUZ(1),"6") : # Saisie sur pÃĐriode fermÃĐe
 GMESSAGE = mess(58,10709,1) : # PÃĐriode non ouverte
 GERR = 2
Else
 If GPAYE & !instr(1,GUSRAUZ(1),"3") : # Saisie sur paie calculÃĐe
  Filter [VEP] Where EMP=[M]REFNUM & CTRNUM=[M]CTRNUM & PYRDAT=[F:HRPEOD]PYRDAT
  Read [VEP]VEP0 First
  Filter [VEP]
  If !fstat & [F:VEP]STA>=2
   GMESSAGE = mess(15,10709,1) : # Paie dÃĐjÃ  calculÃĐe
   GERR = 2
  Endif
 Endif
Endif

I = find(SEM,[F:HRPEOD]PERNUM(0..dim([F:HRPEOD]PERNUM)-1))
I -=1
[M]DAT(0) = [F:HRPEOD]PERSTR(0)+(I*7)
[M]DAT(1) = [M]DAT(0)+1
[M]DAT(2) = [M]DAT(0)+2
[M]DAT(3) = [M]DAT(0)+3
[M]DAT(4) = [M]DAT(0)+4
[M]DAT(5) = [M]DAT(0)+5
[M]DAT(6) = [M]DAT(0)+6
Call MAJ_PYRDAT([M]REFNUM,[M]CTRNUM,[F:HRPEOH]FCY,[F:HRPEOD]PYRDAT,[M]DAT,[M]PYRDAT, STAT) From TPSJOU
If STAT=0 : End : Endif
#LIPET - 11-01-2017 - X3-11322 - END
End

###########################################################################################
# Mise Ã  jour des CP qui sont maj dans la saisie des temps et non encore enregistrÃĐs
# TYPCP1 et TYPCP2 = ÃĐvÃĻnement congÃĐ saisi dans les temps
# NBRCP1 et NBRCP2 = nombre de jours de congÃĐ pris dans les temps
###########################################################################################

Subprog CHERCHE_CP(EVT,NBDAY,DAT,SENS)
Value    Char    EVT
Value    Decimal NBDAY
Value    Date    DAT
Value    Integer SENS
Local Integer I

If clalev([F:TIM])=0 : Local File TIMCOD [TIM] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY [CNG] : Endif

#LIPET - 11-01-2017 - X3-11322 - START
#Call LECTURE("TIM",EVT,"") From CONTOBJ
Call LECTURE("HRTIM",EVT,GCURLEG) From CONTOBJ
#LIPET - 11-01-2017 - X3-11322 - END
If [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
 Filter [CNG] Where CPY=[F:FCY]LEGCPY & TIM=EVT & DEBDAT<=DAT & FINDAT>=DAT
#JASMI - 2014-09-04 - START
#LIPET - 11-01-2017 - X3-11322 - START
 #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#LIPET - 11-01-2017 - X3-11322 - END
  Filter [F:CNE] Where TIM=EVT & REFNUM=[M:TPSJ]REFNUM & CTRNUM=[M:TPSJ]CTRNUM & EMPLEASTR<=DAT & EMPLEAEND>=DAT
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
    Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=EVT & YEA=[F:CNE]YEA
  Endif
 Endif
#JASMI - 2014-09-04 - END
 Read [CNG]CNG0 First
 If [M:TPSI]YEA1=[F:CNG]YEA | [M:TPSI]YEA1=0
  [M:TPSI]YEA1 = [F:CNG]YEA
  I = find(EVT,[M:TPSI]TYPCP1(0..dim([M:TPSI]TYPCP1)-1))
  If I
   [M:TPSI]NBRCP1(I-1) += (NBDAY*SENS)
  Else
   I = find("",[M:TPSI]TYPCP1(0..dim([M:TPSI]TYPCP1)-1))
   If I
    [M:TPSI]TYPCP1(I-1) = EVT
    [M:TPSI]NBRCP1(I-1) = NBDAY*SENS
   Else
    GMESSAGE = mess(55,9014,1) : # Trop de dimensions
    mkstat = 2 : End
   Endif
  Endif
 Elsif [M:TPSI]YEA2=[F:CNG]YEA | [M:TPSI]YEA2=0
  [M:TPSI]YEA2 = [F:CNG]YEA
  I = find(EVT,[M:TPSI]TYPCP2(0..dim([M:TPSI]TYPCP2)-1))
  If I
   [M:TPSI]NBRCP2(I-1) +=(NBDAY*SENS)
  Else
   I = find("",[M:TPSI]TYPCP2(0..dim([M:TPSI]TYPCP2)-1))
   If I
    [M:TPSI]TYPCP2(I-1) = EVT
    [M:TPSI]NBRCP2(I-1) = NBDAY*SENS
   Else
    GMESSAGE = mess(55,9014,1) : # Trop de dimensions
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
End

###########################################################################################
## ContrÃīle dispo des CP & RTT
###########################################################################################

Subprog CTRL_CP (SITE,EVT,DATDEB,DATFIN,MATRI,CTR,NBDAY,MINI,OK)
Value Char       SITE ()
Value Char       EVT ()
Value Date       DATDEB
Value Date       DATFIN
Value Char       MATRI ()
Value Char       CTR ()
Value Decimal    NBDAY
Variable Integer OK
Variable Decimal MINI
Local Decimal    DROIT,POSE
Local Integer I

OK = 1
# Si on enlÃĻve des jours posÃĐs, on ne va pas contrÃīler la dispo...
If NBDAY<0 : End : Endif

If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:CNG])=0  : Local File CNGCPY    [CNG]  : Endif
If clalev([F:CNE])=0  : Local File CNGEMP    [CNE]  : Endif

## Recherche sur la pÃĐriode de tolÃĐrance

Call LECTURE("FCY",SITE,"") From CONTOBJ
Filter [CNG] Where CPY=[F:FCY]LEGCPY & TIM=EVT & DEBDAT<=DATDEB & FINDAT>=DATFIN
#JASMI - 2014-09-04 - START
#LIPET - 11-01-2017 - X3-11322 - START
#If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#LIPET - 11-01-2017 - X3-11322 - END
 Filter [F:CNE] Where TIM=EVT & REFNUM=MATRI & CTRNUM=CTR & EMPLEASTR<=DATDEB & EMPLEAEND>=DATFIN
 Read [F:CNE]CNE0 Last
 Filter [F:CNE]
 If !fstat
   Filter [F:CNG] Where CPY=[F:FCY]LEGCPY & TIM=EVT & YEA=[F:CNE]YEA
 Endif
Endif
#JASMI - 2014-09-04 - END
For [CNG]CNG0
 Read [CNE]CNE0 = [F:CNG]YEA;MATRI;CTR;[F:CNG]TIM
 If !fstat
  DROIT +=[F:CNE]NBRDAY-[F:CNE]NBRPRI
  If [F:CNE]YEA=[M:TPSI]YEA1
   I = find(EVT,[M:TPSI]TYPCP1(0..dim([M:TPSI]TYPCP1)-1))
   If I : POSE +=[M:TPSI]NBRCP1(I-1) : Endif
  Elsif [F:CNE]YEA=[M:TPSI]YEA2
   I = find(EVT,[M:TPSI]TYPCP2(0..dim([M:TPSI]TYPCP2)-1))
   If I : POSE +=[M:TPSI]NBRCP2(I-1) : Endif
  Endif
 Endif
Next
Filter [CNG]
If DROIT-(POSE+NBDAY)<MINI
#ADNGO - 26-01-2017 - X3-11322 - START
 #GMESSAGE = EVT-mess(118,709,1)-":"-num$(DROIT-POSE)
 GMESSAGE = EVT-mess(118,10709,1)-":"-num$(DROIT-POSE)
#ADNGO - 26-01-2017 - X3-11322 - END
 OK=0 : End
Endif
End

## ContrÃīles des zones paramÃĐtrÃĐes comme obligatoires dans la transaction de saisie

Subprog CTLZONTPS (VALEUR,ZONE,TIM)
Value Char VALEUR, ZONE, TIM
Read[F:STD]STD1=GFLAG;ZONE
If [F:STD]OBG=2 & TIM<>"" & ( VALEUR="" | (num$(val(VALEUR))=VALEUR & val(VALEUR)=0) )
 # Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat = 2 : End
Endif
End

$CONGES_PARTIEL
Local Char CONTCP(10)
Call PARAM("","CPOUVRA",CONTCP) From ADOVAL
If val(CONTCP)=2
 Call PARAM([M:TPSJ]FCY,"CPA",[M:TPSI]CPA) From ADOVAL
Else
 [M:TPSI]CPA = "***"
Endif
Return

