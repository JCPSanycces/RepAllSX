#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# SUBMFX : Points d'entrée des gestions de transaction     SR  01/04/05 #
#          de saisie GPAO                                               #
# --------------------------------------------------------------------- #
# Ce traitement est commun à toutes les gestions des transactions de    #
# saisie du module GPAO il est appelé depuis les traitements :          #
#    - SUBMFL : pour les ordres de fabrication                          #
#    - SUBMTL : pour les suivis de fabrication                          #
#    - SUBMGL : pour le planning global                                 #
#    - SUBMDL : pour le plan de travail                                 #
#    - SUBMRL : pour le plan de regroupement                            #
#    - SUBMOL : pour le plan de suivi des temps                         #
#    - SUBMML : pour le plan de consommation matière                    #
#    - SUBMIL : pour le plan de production                              #
#    - SUBMRE : pour le plan de réintégration                           #
#    - SUBMPL : pour le pilotage des plans                              #
#    - SUBMCL : pour le plan des fiches techniques                      #
#    - SUBMWL : pour le plan de pesée                                   #
#########################################################################


$PE_MFGTRS
#-----------------------------------------------------------#
# Point d'entrée MFGTRS permet de gérer la présence et le   #
#        mode de saisie des champs spécifiques              #
# --------------------------------------------------------- #
# Variables utilisables par le point d'entrée :             #
#   FJL      : Type de transaction en cours de gestion      #
#     "MFL"         pour les ordres de fabrication          #
#     "MTL"         pour les suivis de fabrication          #
#     "MGL"         pour le planning global                 #
#     "MDL"         pour le plan de travail                 #
#     "MRL"         pour le plan de regroupement            #
#     "MOL"         pour le plan de suivi des temps         #
#     "MML"         pour le plan de consommation matière    #
#     "MIL"         pour le plan de production              #
#     "MRE"         pour le plan de réintégration           #
#     "MPL"         pour le pilotage des plans              #
#     "MCL"         pour le plan des fiches techniques      #
#     "MWL"         pour le plan de pesée                   #
#   PACTION  : Action du GOBJET                             #
#     "APRES_MODIF" Après saisie de chaque champ            #
#     "RAZCRE"      Initialisation après entrée en création #
#     "INICRE"      Avant l'écriture de l'enregistrement    #
#     "LIENS"       Après lecture de chaque enregistrement  #
#     "INIMOD"      Avant la réécriture de l'enregistrement #
#     "CREATION"    Avant la réécriture de l'enregistrement #
#     "MODIF"       Avant la réécriture de l'enregistrement #
#   PVERSION : Numéro de version (ex 130 ou 140)            #
#-----------------------------------------------------------#
If dim(FJL)<0      Local Char    FJL(3)      : Endif
If dim(PACTION)<0  Local Char    PACTION(20) : Endif
If dim(PVERSION)<0 Local Integer PVERSION    : Endif   

# FJL=mid$(GFONCTION,4,3) : # GH 25/11/2013 bug 94704
If GFONCTION ="GENMSKTRT"
   FJL = mid$(adxpno(1),len(adxpno(1))-6,3)
Else
   FJL =mid$(GFONCTION,4,3)
Endif
PACTION =ACTION
PVERSION=val(ctrans(GVERSION,".",""))
GPOINT="MFGTRS" : Gosub ENTREE From EXEFNC
Return

$PE_MFGTRSWIN
#-----------------------------------------------------------#
# Point d'entrée MFGTRSWIN permet de gérer la présence et   #
#       le mode de saisie des onglets spécifiques           #
# --------------------------------------------------------- #
# Variables utilisables par le point d'entrée :             #
#   FJL      : Type de transaction en cours de gestion      #
#     "MFL"         pour les ordres de fabrication          #
#     "MTL"         pour les suivis de fabrication          #
#     "MGL"         pour le planning global                 #
#     "MDL"         pour le plan de travail                 #
#     "MRL"         pour le plan de regroupement            #
#     "MOL"         pour le plan de suivi des temps         #
#     "MML"         pour le plan de consommation matière    #
#     "MIL"         pour le plan de production              #
#     "MRE"         pour le plan de réintégration           #
#     "MPL"         pour le pilotage des plans              #
#     "MCL"         pour le plan des fiches techniques      #
#     "MWL"         pour le plan de pesée                   #
#   PVERSION : Numéro de version                            #
#-----------------------------------------------------------#
If dim(FJL)<0      Local Char    FJL(3)      : Endif
If dim(PACTION)<0  Local Char    PACTION(20) : Endif
If dim(PVERSION)<0 Local Integer PVERSION    : Endif   

# FJL=mid$(GFONCTION,4,3) : # GH 25/11/2013 bug 94704
If GFONCTION ="GENMSKTRT"
   FJL = mid$(adxpno(1),len(adxpno(1))-6,3)
Else
   FJL =mid$(GFONCTION,4,3)
Endif
PACTION =ACTION
PVERSION=val(ctrans(GVERSION,".",""))
GPOINT="MFGTRSWIN" : Gosub ENTREE From EXEFNC
Return

