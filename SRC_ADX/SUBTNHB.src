#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$CHARGE_NEW_ADDRESS

If dim([M:ADB2]BPAADD)>0 : [M:ADB2]BPAADD = [M:TNH0]BPAADD : Endif
Call CHARGE_ADRMSK("ADB2", [M:TNH0]BPRNUM) From TRTVENDIV
If dim([M:ADB2]EECNUM)>0
    If [M:ADB2]EECNUM=""
        [M:ADB2]EECNUM = [F:BPR]EECNUM
    Endif
Endif

Return
######################################################################################
######################################################################################
$CHARGE_SHIFRM_NEW_ADDRESS

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
If dim([M:ADR1]BPAADD)>0 : [M:ADR1]BPAADD = [M:TNH0]SHIFRMADD : Endif
Call CHARGE_ADRMSK("ADR1", [M:TNH0]FCY)
# End issue X3-3575

Return
######################################################################################
######################################################################################
$MAJADRESSE
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [TNH]
  Readlock [TNH] TNH0=[M]TNHNUM
  If fstat=1  GOK=-1 : GLOCK="$TRANNOTE"-[M]TNHNUM           : Goto ROLL_ADR
  Elsif fstat GOK=0  : Call RSTA("TNH",[M]TNHNUM) From GLOCK : Goto AB_ADR : Endif
  If BOUT = "K"
    [F:TNH]CNDNAM = [M:ADB2]CNTNAM
    If [M:ADB2]ADBFLG = 2 Gosub CHARGE_ADRBPD Endif
  Else
    # Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
    # Issue X3-3575
    If BOUT = "2"
      If [M:ADR1]ADBFLG = 2 Gosub CHARGE_ADRSHIFR Endif
    Endif
    # End issue X3-3575
    #[F:TNH]CNINAM    = [M:ADB3]CNTNAM
    #If [M:ADB3]ADBFLG = 2 Gosub CHARGE_ADRBPI Endif
  Endif
  Rewrite [TNH]
  If fstat GOK=0 : Call FSTA("TNH") From GLOCK : Goto AB_ADR : Endif
Commit
Gosub RELIT From GOBJSUB  # FGR 24/07/2014 : X3SUIVI100377
Return
######################################################################################
######################################################################################
$ROLL_ADR

Rollback : Call ROLL From GLOCK
If !GROLL Goto TR_ADR : Endif

Return
######################################################################################
######################################################################################
$AB_ADR

Rollback

Return
######################################################################################
######################################################################################
$CHARGE_ADRBPD

[F:TNH]BPDNAM(0)    = [M:ADB2]BPRNAM(0)
[F:TNH]BPDNAM(1)    = [M:ADB2]BPRNAM(1)
[F:TNH]BPDADDLIG(0) = [M:ADB2]BPAADDLIG(0)
[F:TNH]BPDADDLIG(1) = [M:ADB2]BPAADDLIG(1)
[F:TNH]BPDADDLIG(2) = [M:ADB2]BPAADDLIG(2)
[F:TNH]BPDPOSCOD    = [M:ADB2]POSCOD
[F:TNH]BPDCTY       = [M:ADB2]CTY
[F:TNH]BPDSAT       = [M:ADB2]SAT
[F:TNH]BPDCRY       = [M:ADB2]CRY
[F:TNH]BPDCRYNAM    = [M:ADB2]CRYNAM
If dim([M:ADB2]ADRVAL)>0 and dim([F:TNH]ADRVAL)>0
 [F:TNH]ADRVAL       = [M:ADB2]ADRVAL
Endif

Return
######################################################################################
######################################################################################
$CHARGE_ADRSHIFR

[F:TNH]SHIFRMADD       = [M:ADR1]BPAADD
[F:TNH]SHIFRMNAM(0)    = [M:ADR1]NAM(0)
[F:TNH]SHIFRMNAM(1)    = [M:ADR1]NAM(1)
[F:TNH]SHIFRMADDLIG(0) = [M:ADR1]BPAADDLIG(0)
[F:TNH]SHIFRMADDLIG(1) = [M:ADR1]BPAADDLIG(1)
[F:TNH]SHIFRMADDLIG(2) = [M:ADR1]BPAADDLIG(2)
[F:TNH]SHIFRMPOSCOD    = [M:ADR1]POSCOD
[F:TNH]SHIFRMCTY       = [M:ADR1]CTY
[F:TNH]SHIFRMSAT       = [M:ADR1]SAT
[F:TNH]SHIFRMCRY       = [M:ADR1]CRY
[F:TNH]SHIFRMCRYNAM    = [M:ADR1]CRYNAM
If dim([M:ADR1]ADRVAL)>0 and dim([F:TNH]ADRVAL)>0
 [F:TNH]ADRVAL       = [M:ADR1]ADRVAL
Endif

Return
######################################################################################
######################################################################################
$INITXC

If [M:TNH0]TNHTEX1<>""
   If left$([M:TNH0]TNHTEX1,3)="TNH"
      Call CRE_CLOB([M:TNH0]TNHTEX1,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:TNH]TNHTEX1 = [M:TNH0]TNHTEX1
Endif
If [M:TNH0]TNHTEX2<>""
   If left$([M:TNH0]TNHTEX2,3)="TNH"
      Call CRE_CLOB([M:TNH0]TNHTEX2,GOK) From TRTX3TEX
      If GOK<1 Return Endif
   Endif
   [F:TNH]TNHTEX2 = [M:TNH0]TNHTEX2
Endif

Return
######################################################################################
######################################################################################
$COMMON_ACTZO
# BRBAN * 01/04/2015 * #107394
#Actzo [M:TNH0]1-99
Actzo [M:TNH1]1-99
Actzo [M:TNH2]1-99

Return
