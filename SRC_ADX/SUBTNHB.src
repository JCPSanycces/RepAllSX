$REINIT_LIGNE
Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#-------------------------------------#
# Price recalcul                      #
#-------------------------------------#
$RECALC_TARIF
Local Integer TYPRECH
Local Decimal GROPRI
Local Char    ACT
Local Integer ORI

# --> Price list type identification : 1 normal / 4 component
If   find([M]LINTYP(NLIG), 1,2,6,10)
    TYPRECH = 1
Else
    ORI=NLIG
    While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
    If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
    TYPRECH = 4
Endif
# --> No price recalcul for free lines
If   [M]FOCFLG(NLIG) = 3 : Return : Endif
Call ALICLCAMT([M:TNH1]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "TNH1", [M:TNH1]CLCAMT1(NLIG), [M:TNH1]CLCAMT2(NLIG)) From TRTX3
# --> Price search
Call RECH_TARIF(TYPRECH,[M]ITMREF(NLIG),NLIG,[M]QTY(NLIG),"TNH",GROPRI) From TRTVENTAR
# --> Actions on free lines : S delete / C correction / I insert
If GFOCITMREF  = "" & [M]FOCFLG(NLIG) = 2 :ACT = "S":[M]FOCFLG(NLIG)=1:Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 2 :ACT = "C":Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 1 :ACT = "I":Endif
[M]GROPRI(NLIG)= GROPRI
Call CLCNETPRI([M]QTY(NLIG), [M:TNH1]CUR, NLIG) From TRTVENPRI
Call CLCPFM([M:TNH0]STOFCY, [M]PRITYP, [M]CHGTYP, [M]SHIDAT, [M]CUR, NLIG,INICPRPRI) From TRTVENPRI
Call APRES_LIGNE(NLIG, 0)
[M]UPDFLG(NLIG) = 1
ORI = NLIG
Gosub TRTGRA
Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#-------------------------------------#
# Process for frees                   #
#-------------------------------------#
$TRTGRA
Local Integer LIGGRA
Local Integer RET

If ACT = "S" | ACT = "C"
    LIGGRA = find(3, [M]FOCFLG(NLIG+1..[M]NBLIG-1))
    If LIGGRA <> 0
        LIGGRA = LIGGRA + NLIG
#       Free deletion
        If ACT = "S"
            Call SUPGRA(ORI, 1, RET) From TRTVENBOM
            If RET = 0 [M]FOCFLG(ORI)=1 : Endif
        Endif
#       Free replace : Deletion and creation
        If ACT = "C" & [M]ITMREF(LIGGRA) <> GFOCITMREF
            Call SUPGRA(LIGGRA-1, 1, RET) From TRTVENBOM
            If RET = 0
                Call CREGRA("G",0, ORI, [M:TNH1]SHIDAT, 1,LIGGRA, RET) From TRTVENBOM
                If RET = 0 [M]UPDFLG(LIGGRA-1) = 1:Endif
            Endif
#       Free creation
        Elsif ACT = "C" & [M]QTY(LIGGRA) <> GFOCQTY
            [M]QTY(LIGGRA) = GFOCQTY
            [M]UPDFLG(LIGGRA) = 1
        Endif
    Endif
Endif
If ACT = "I"
    LIGGRA = NLIG + 1
    While LIGGRA < [M:TNH1]NBLIG & !find([M:TNH1]LINTYP(LIGGRA),1,2,6,10)
        LIGGRA += 1
    Wend
    Call CREGRA("G", 0, ORI, [M:TNH1]SHIDAT, 1,LIGGRA, RET) From TRTVENBOM
Endif
Raz ACT
Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#-------------------------------------#
# Line amounts conversion             #
#-------------------------------------#
$CONV_LIGNE
Local Decimal MNTORI, MNTDES

# --> Gross price
Call CONVERT2(WANCCUR,[M:TNH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]GROPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]GROPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)

# --> Amount Discount/charge
For I = 1 To 9
   If evalue ("dim([M:TNH1]DISCRGVAL"+num$(I)+"(nlig))")>0
      If GFMTREM(I-1)="M"
         MNTORI = evalue("[M:TNH1]DISCRGVAL"+num$(I)+"(NLIG)")
         Call CONVERT(WANCCUR,[M:TNH1]CUR,GLOCALDEV,[M]CHGTYP,date$,MNTORI,MNTDES,GBIDI1) From TRTDEV
         Assign "[M:TNH1]DISCRGVAL"+num$(I)+"(NLIG)" With MNTDES
      Endif
   Endif
Next

# --> Net price
Call CONVERT2(WANCCUR,[M:TNH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]NETPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]NETPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)
# --> Cost price
Call CONVERT2(WANCCUR,[M:TNH1]CUR,GLOCALDEV,[M]CHGTYP,date$,[M]CPRPRI(NLIG),MNTDES,GBIDI1) From TRTDEV
[M]CPRPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)
# --> Calculated tax base amounts
If [M]CLCAMT1(NLIG) <> 0 | [M]CLCAMT2(NLIG) <> 0
    # These amounts depend on a formula so miscellaneous operands
    # No conversion but recalcul
    Call ALICLCAMT([M]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "TNH1", [M]CLCAMT1(NLIG), [M]CLCAMT2(NLIG)) From TRTX3
Endif

Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#-------------------------------------#
# Totals recalcul                     #
#-------------------------------------#
$RECALC_TOT
Local Integer AFF

Call CLCPFM([M:TNH0]STOFCY, [M:TNH1]PRITYP, [M:TNH0]CHGTYP, [M:TNH1]SHIDAT, [M:TNH1]CUR,
&           NLIG,INICPRPRI) From TRTVENPRI
Call CTLPFM([M:TNH1]CUR,[M:TNH1]CPRPRI(NLIG), NLIG) From TRTVENPRI

mkstat=0
Local Integer NOL : NOL=NLIG
Gosub CALC_DLV
Gosub CALC_DSP From TRTVENDIV

Gosub ADD_TOT
[M]UPDFLG(NLIG) = 1

Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#########################################################################
#---------------------------------------------------------#
# Ex tax and Incl. tax amount calcul for a delivery line  #
#---------------------------------------------------------#
$CALC_DLV
Local Decimal MNTCALC

Local Char VAT(GLONVAT)(3)
VAT (0) = [M]VAT1(NOL)
VAT (1) = [M]VAT2(NOL)
VAT (2) = [M]VAT3(NOL)

If [M:TNH1]PRITYP=1
    # Ex tax net amount line
    MNTCALC = [M]QTY(NOL) * [M]NETPRINOT(NOL)
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINDLVNOT(NOL) = MNTCALC

    # Incl. tax net amount line
    Call CLCTAXEMNTV([M]LINDLVNOT(NOL),VAT,[M:TNH1]PRITYP,GSOCIETE,[M:TNH1]DLVDAT,[M:TNH2]VACBPR,[M]CLCAMT1(NOL),[M]CLCAMT2(NOL),
&                   MNTCALC) From TRTX3                                                                               : # Bug 71296
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINDLVATI(NOL) = MNTCALC
Else
    # Incl. tax net amount line
    MNTCALC = [M]QTY(NOL) * [M]NETPRIATI(NOL)
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINDLVATI(NOL) = MNTCALC

    # Ex tax net amount line
    Call CLCTAXEMNTV([M]LINDLVATI(NOL),VAT,[M:TNH1]PRITYP,GSOCIETE,[M:TNH1]DLVDAT,[M:TNH2]VACBPR,[M]CLCAMT1(NOL),[M]CLCAMT2(NOL),
&                   MNTCALC) From TRTX3                                                                               : # Bug 71296
    Call ARRDEV (MNTCALC, [M]CUR) From TRTDIV
    [M]LINDLVNOT(NOL) = MNTCALC
Endif

Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#########################################################################
#---------------------------------------------------------#
# delivery amounts and weights incrementation             #
#---------------------------------------------------------#
$ADD_TOT
Local Decimal WLINWEI

[M]DLVNOT += [M]LINDLVNOT(NOL)
[M]DLVATI += [M]LINDLVATI(NOL)

# --> Net and Gross weights Calcul
If   [M:TNH1]XWEU(NOL) <> [M:TNH2]WEU
     Gosub CONVERSION
Else WLINWEI = [M]UNTWEI(NOL)*[M]QTY(NOL)
Endif

[M]NETWEI += WLINWEI
[M]GROWEI += WLINWEI

[M:TNH0]DSPTOTQTY += [M:TNH1]QTYSTU(NOL)
[M:TNH0]DSPTOTWEI += [M:TNH1]DSPLINWEI(NOL)
[M:TNH0]DSPTOTVOL += [M:TNH1]DSPLINVOL(NOL)

#Call MAJ_SFIT_QTY("M", "SDH2", [M:TNH1]XSOHNUM(NOL), [M:TNH1]QTYSTU(NOL), [M:TNH1]LINDLVNOT(NOL), [M:TNH1]DSPLINWEI(NOL), [M:TNH1]DSPLINVOL(NOL)) From SUBSFIT

Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#-----------------------------------------------------#
# Conversion poids en unité de l'entête de livraison  #
#-----------------------------------------------------#
$CONVERSION
Local Decimal  COEF
Local Integer  WOUV

If clalev([F:TCO]) = 0 Local File TABCOEFF [TCO] : WOUV=1 Endif
Read [TCO]TCO0=[M:TNH1]XWEU(NOL);[M:TNH2]WEU
If fstat=0
   COEF = [F:TCO]COEUOM
Else
   Read [TCO]TCO0=[M:TNH2]WEU;[M:TNH1]XWEU(NOL)
   If fstat=0 & [F:TCO]COEUOM<>0
      COEF = 1/[F:TCO]COEUOM
   Endif
Endif
If COEF = 1  WLINWEI = [M:TNH1]UNTWEI(NOL)*[M:TNH1]QTY(NOL)
Else         WLINWEI = [M:TNH1]UNTWEI(NOL)*[M:TNH1]QTY(NOL)*COEF
             Call QTEARR(WLINWEI, [M:TNH2]WEU) From TRTDIV
Endif
If WOUV=1 Close Local File [TCO] : Raz WOUV Endif
Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#---------------------------------------#
# Traitement apres ligne                #
#---------------------------------------#
Subprog APRES_LIGNE(NOL, AFF)
Value Integer NOL
Value Integer AFF

mkstat=0
# --> Contrôle du prix net
Call CTLNETPRI([M]BPCORD,[M]CHGTYP,[M]SHIDAT,[M]CUR,NOL) From TRTVENPRI
#If mkstat=2 End Endif
# --> Contrôle de la marge
Call CTLPFM([M]CUR,[M]CPRPRI(NOL), NOL) From TRTVENPRI
#If mkstat=2 End Endif
# --> Calcul du montant liv ht et ttc de la ligne
Gosub CALC_DLV
Local Integer NLIG : NLIG=NOL
Gosub CALC_DSP From TRTVENDIV

# Incrémentation des montants et poids livraison
Gosub ADD_TOT

End
# 91606 :(22/07/14) Transportation notes (Sales part dev)
######################################################################################
######################################################################################
#------------------------------------------------------------------#
# Chargement d'une adresse tiers dans un ecran adresse             #
#------------------------------------------------------------------#
# Entrée   WABRMSK : Abréviation du masque adresse                 #
#          WBPRNUM : Code tiers                                    #
#------------------------------------------------------------------#
Subprog CHARGE_ADRMSK(WABRMSK, WBPRNUM)
Value Char    WABRMSK
Value Char    WBPRNUM

Local Char    WBPAADD
Local Integer I
#If clalev([F:BPR]) = 0 Local File BPARTNER   [BPR] : Endif
#If clalev([F:BPC]) = 0 Local File BPCUSTOMER [BPC] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD] : Endif

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
If clalev([F:FCY]) = 0 Local File FACILITY  [FCY] : Endif
# End issue X3-3575

#If [F:BPR]BPRNUM<>WBPRNUM
