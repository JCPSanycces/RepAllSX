# 91606 :(22/07/14) Transportation notes (Sales part dev)
#--------------------------------------------------------------------#
# Reading of all the necessary files for a line                      #
#--------------------------------------------------------------------#
Subprog LECT_FIC(NLIG)
Value Integer NLIG

If [F:ITS]ITMREF <> [M:TNH1]ITMREF(NLIG)
     Read [F:ITS]ITS0 = [M:TNH1]ITMREF(NLIG)
     If fstat  Raz [F:ITS] : Endif
Endif
If [F:ITM]ITMREF <> [M:TNH1]ITMREF(NLIG)
     Read [F:ITM]ITM0 = [M:TNH1]ITMREF(NLIG)
     If fstat  Raz [F:ITM] : Endif
Endif

End
# 91606 :(22/07/14) Transportation notes (Sales part dev)

# 91606 :(22/07/14) Transportation notes (Sales part dev)
#------------------------------------------------------------------------------#
#     Delivery lines recalcul                                                  #
#------------------------------------------------------------------------------#
# Called in AM_ : Project code                                                 #
#  --> If price search request : GTARFLG= "1"                                  #
# Called in AM_ : Shipment date, Delivery LT, Delivery date                    #
#  --> Tax recalcul            : GTARFLG= "2"                                  #
#------------------------------------------------------------------------------#
$RECALC_LIGNE

Local Integer  NLIG, WIND
Local Char     NOME, NOMD
Local Char     WFLGTOT(1): WFLGTOT="N"
Local Integer  INICPRPRI : INICPRPRI=1
Local Char     WVACITM(GLONTVI)(3), WREP(GLONREP)
Local Char     VAT(GLONVAT)(3)
Raz WFLGTOT
If find(GTARFLG,"1","2") | [M:TNH1]CUR<>WANCCUR | [M:TNH2]VACBPR<>WANCVACBPR
    Raz [M]DLVNOT,DLVATI
    Raz [M:TNH0]DSPTOTQTY,DSPTOTVOL,DSPTOTWEI
    Raz [M]NETWEI, [M]GROWEI
Endif

#--------------------------------- #
# Detail lines modification        #
#--------------------------------- #
Raz NLIG
While NLIG < [M:TNH1]NBLIG
    If FFLGMOD <> ""
        NOME = WZONCOU
        NOMD = sum ("D", NOME)
        If FFLGMOD  = "3" Gosub COMP_ZON Endif
        If FFLGMOD <> "3" Gosub MOD_ZON  Endif
    Endif
    If WZONCOU = "BPCORD"
        Gosub REINIT_LIGNE : If mkstat=2 Break : Endif
    Endif
    If find(GTARFLG,"1","2") | [M:TNH1]CUR <> WANCCUR | [M:TNH2]VACBPR <> WANCVACBPR |
&                    [M:TNH1]PRITYP <> WANCPRITYP
        Call LECT_FIC(NLIG)
#   --> Tax rule modification : Tax codes Ré-initialization
        If [M:TNH2]VACBPR <> WANCVACBPR
            Call RECHVATCOD(1,1,[M:TNH0]BPCORD,[M:TNH1]ITMREF(NLIG),"TNH1",NLIG,VAT) From TRTX3
            [M]VAT1(NLIG) = VAT(0)
            [M]VAT2(NLIG) = VAT(1)
            [M]VAT3(NLIG) = VAT(2)
        Endif
#       --> Price search
        If GTARFLG = "1"
            Gosub RECALC_TARIF
        Else
#           --> Currency modification             : Amounts conversion + totals recalcul
            If [M:TNH1]CUR <> WANCCUR
                Gosub CONV_LIGNE
                WFLGTOT = "O"
            Endif
#           --> Tax rule modification                                  : Prices, margin, totals recalcul
#           --> Shipment date, Delivery LT, Delivery date modification : Prices, margin, totals recalcul
            If [M:TNH2]VACBPR <> WANCVACBPR | GTARFLG = "2"
                WFLGTOT="O"
            Endif
#           --> Price type modification                                : Swing - tax/+tax price
            If [M:TNH1]PRITYP <> WANCPRITYP
                If [M:TNH1]PRITYP = 1
                    [M]NETPRI(NLIG) = [M]NETPRINOT(NLIG)
                Else
                    [M]NETPRI(NLIG) = [M]NETPRIATI(NLIG)
                Endif
            Endif
        Endif
    Endif
#   --> It is necessary to recalculate totals
    If WFLGTOT="O"  Gosub RECALC_TOT Endif
    [M]UPDFLG(NLIG) = 1
    NLIG+=1
Wend
If mkstat=2 Return Endif

# 101874 : V9 : Taxe code control
#If dim(GVALTTCSDH)>0 & dim(GVALTTC)>0 : GVALTTC=GVALTTCSDH : Endif
#If !GIMPORT : Call VALTTC ("GESTNH") From TRTVENFACR : Endif
If !GIMPORT
    # Valuation is always done in this case
    GVALTTC=2
    #---- Paramètres complementaires appel valorisation
    # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
    # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
    # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
    Local    Char     PARAM_T (25) (0..10)
    PARAM_T(0)=num$(1)      : # Pas de contrôle des taxes
    PARAM_T(1)=num$(1)      : # Pas de lecture de la trace
    PARAM_T(2)=num$(0)
    Call VALTTC ("GESTNH", PARAM_T) From TRTVENFACR
    If PARAM_T(2)="1" mkstat=2 : Return Endif
Endif
# 101874

Affzo [M:TNH1]20,22,23

Return
# 91606 :(22/07/14) Transportation notes (Sales part dev)

