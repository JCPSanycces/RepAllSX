#Endif

# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
If [F:FCY]FCY<>WBPRNUM
    Read [FCY]FCY0 = WBPRNUM
    If fstat Raz [F:FCY] Endif
Endif
# End issue X3-3575

WBPAADD = evalue("[M:"+WABRMSK+"]BPAADD")

If WBPAADD<>""
  Read [BPA]BPA0=3;WBPRNUM;WBPAADD
Else
  Read [BPA]BPA0=3;WBPRNUM;[F:FCY]BPAADD
Endif
If fstat Raz [F:BPA] Endif

Assign "[M:"+WABRMSK+"]BPAADD"    With [F:BPA]BPAADD

#Assign "[M:"+WABRMSK+"]BPRNAM(0)" With [F:BPR]BPRNAM(0)
#Assign "[M:"+WABRMSK+"]BPRNAM(1)" With [F:BPR]BPRNAM(1)

