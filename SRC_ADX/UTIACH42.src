#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################
# UTIACH42 : Change setup of overheads in sub-contracted products#
#           Module =  Common data  (9)                          #
#################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Change setup of overheads in sub-contracted products") From LECFIC
 Call MAJ_UTIACH42(DOSSIER)

 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End


#####################################################################################
Subprog MAJ_UTIACH42(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIACH42: Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:ITG])=0 : Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif
If clalev([F:ITM])=0 : Local File =DOSSIER+".ITMMASTER"  [ITM] : Endif
If clalev([F:ITF])=0 : Local File =DOSSIER+".ITMFACILIT" [ITF] : Endif

Local Integer NITG, NITF
Local Integer IPTH, IMKI, IMKM, ISCM
Local Integer LREW
Local Char    LMES(250), LABR(3), LTCLCOD(GLONITG)

Call DEBTRANS From GLOCK

Trbegin [ITG]

Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
&          As [LNK]
For [ITG]ITG1 Where [ITG]SCSFLG=2
    If LTCLCOD<>[F:ITG]TCLCOD
        Default File [ITF]
        LABR="ITF"
        For [LNK] Where [F:ITM]TCLCOD=[F:ITG]TCLCOD
            LMES = "ITF :"-[F:ITF]ITMREF-[F:ITF]STOFCY
            #Call ECR_TRACE(LMES,0) From GESECRAN
            Gosub UPD_OVE
        Next
        LTCLCOD=[F:ITG]TCLCOD
    Endif
    Default File [ITG]
    LABR="ITG"
    LMES = "ITG :"-[F:ITG]TCLCOD-[F:ITG]STOFCY
    #Call ECR_TRACE(LMES,0) From GESECRAN
    Gosub UPD_OVE
Next

Commit

Close Local File [ITG]
Close Local File [ITF]

Call ECR_TRACE("UTIACH42: "+num$(NITG)+" ITMCATEG records modified",0) From GESECRAN
Call ECR_TRACE("UTIACH42: "+num$(NITF)+" ITMFACILIT records modified",0) From GESECRAN

End

$UPD_OVE
    LREW = 0
    IPTH = find(3,[F]OTRSTYP)   # Get index of receipt overheads
    IMKI = find(5,[F]OTRSTYP)   # Get index of WO entry overheads
    IMKM = find(6,[F]OTRSTYP)   # Get index of WO issue overheads
    ISCM = find(29,[F]OTRSTYP)

    If IPTH & IMKI & [F]OVECOD(IPTH-1)<>[F]OVECOD(IMKI-1)
        # If overheads are already set to receipts and WO entries and code are different => warning
        Call ECR_TRACE(LMES+": For subcontracting receipts, overhead code'"-[F]OVECOD(IPTH-1)-"' will be used instead of '"-[F]OVECOD(IMKI-1)+"'",-1) From GESECRAN
    Elsif IMKI & !IPTH
        # If overheads are already set to WO entries but not for receipts
        # => copy of this overhead code in order to be able to use it in subcontracting receipt
        # => warning because supplier receipts will have overheads
        Readlock [F] =
        If fstat
            Call FSTA(LABR) From GLOCK
        Else
            IPTH = find(0,[F]OTRSTYP)
            If IPTH>0
                [F]OTRSTYP(IPTH-1)   = 3
                [F]OVECOD(IPTH-1)    = [F]OVECOD(IMKI-1)
                [F]OVECPNFLG(IPTH-1) = [F]OVECPNFLG(IMKI-1)
                LREW = 1
                Call ECR_TRACE(LMES-": For supplier receipts, overhead code '"-[F]OVECOD(IPTH-1)-"' will be used",-1) From GESECRAN
            Else
                Call ECR_TRACE(LMES-"Impossible to create setting for receipt overheads",1) From GESECRAN
            Endif
        Endif
    Elsif !IMKI & IPTH
        # If overheads are already set to receipts but not for WO entries => warning because now, subcontracting will use overheads
        Call ECR_TRACE(LMES-": No overheads was set. Now for subcontracting receipts, overhead code '"-[F]OVECOD(IPTH-1)-"' will be used",-1) From GESECRAN
    Endif

    # If overheads are set on WO issues, we have to copy this code to stock transaction type "Subcontracting issue"
    If IMKM & !ISCM
        If !LREW
            Readlock [F] =
            If fstat
                Call FSTA(LABR) From GLOCK
            Endif
        Endif
        If !fstat
            ISCM = find(0,[F]OTRSTYP)
            If ISCM>0
                [F]OTRSTYP(ISCM-1)   = 29
                [F]OVECOD(ISCM-1)    = [F]OVECOD(IMKM-1)
                [F]OVECPNFLG(ISCM-1) = [F]OVECPNFLG(IMKM-1)
                LREW = 1
            Else
                Call ECR_TRACE(LMES-"Impossible to create setting for subcontracting issue overheads",1) From GESECRAN
            Endif
        Endif
    Endif
    If LREW
        Rewrite [F]
        If fstat
            Call FSTA(LABR) From GLOCK
        Else
            Case LABR
                When "ITF" : NITF+=1
                When "ITG" : NITG+=1
            Endcase
        Endif
    Endif
Return

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If filinfo(filpath("FIL","ITMCATEG","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIACH42(APPLI)

End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If filinfo(filpath("FIL","ITMCATEG","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ITMFACILIT","fde",APPLI),0)<=0 : End : Endif
If filinfo(filpath("FIL","ITMMASTER","fde",APPLI),0)<=0 : End : Endif

Call MAJ_UTIACH42(APPLI)
End

