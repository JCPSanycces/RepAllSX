# Supervisor
## ACLA-CLASSE ## PRJFAS
# 2018-11-06 07:13:53 982

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0PRJFAS
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PRJ From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_LIG From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_FAS From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_AMTSALPRV From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_CURFAS From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_LOTFAS From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub AINIT From WMC0PRJFAS : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0PRJFAS
Gosub _ALOADATTRIBUTE_PRJ From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_LIG From WMC1PRJFAS : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0PRJFAS
Gosub LNKPRO_AMTSALPRV From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub LNKPRO_CURFAS From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1PRJFAS : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1PRJFAS : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



