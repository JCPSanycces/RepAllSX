#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MSR",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "LIENS"       : Gosub LIENS
 When "ANNULE"      : Gosub ANNULE
 When "FERME"       : Gosub FERME
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "SEL_LISTE"   : Gosub SEL_LISTE
Endcase
Return

#####################################
$OUVRE
If clalev ([F:MSR])=0  : Local File MSRUB     [MSR]  : Endif
If clalev ([F:RUB])=0  : Local File RUBRIQUE  [RUB]  : Endif
If clalev ([F:VRA])=0  : Local File VARIA     [VRA]  : Endif
If clalev ([F:CUM])=0  : Local File CUMUL     [CUM]  : Endif
If clalev ([F:PRF])=0  : Local File PROFIL    [PRF]  : Endif
If clalev ([F:MSC])=0  : Local File MSCALR    [MSC]  : Endif
If clalev ([F:GRI])=0  : Local File GRILLE    [GRI]  : Endif
If clalev ([F:BCB])=0  : Local File BCLOB     [BCB]  : Endif
If clalev ([F:MSR1])=0 : Local File MSRUB     [MSR1] : Endif
If clalev ([F:MGR])=0  : Local File MSGRIL    [MGR]  : Endif #59527 Gestion grille MS
Local Integer VOK

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#####################################
$RAZCRE
Gosub CHARGE_PROFIL
Affzo [MSR2]
Return

#####################################
$INICRE
Read [F:MSR1]MSR3 Last
If fstat>2
 [F:MSR]ROW = 1
Else
 [F:MSR]ROW = [F:MSR1]ROW+1
Endif
Gosub INIMOD
Return

$INIMOD
Call TOKEN([F:MSR]CNDCAL)
Call TOKEN([F:MSR]BAS)
Call TOKEN([F:MSR]RAT1)
Call TOKEN([F:MSR]RAT2)
Call TOKEN([F:MSR]TBLFRM(0))
Call TOKEN([F:MSR]TBLFRM(1))
Call TOKEN([F:MSR]TBLFRM(2))
For I=0 To dim([F:MSR]ITVAMT)-1
 Call TOKEN([F:MSR]ITVAMT(I))
Next I
#CMT
Default Mask [M:MSR2]
Call SAUVE_CMT ("SUBMSR",[F:MSR]COD,"","","")
Return

#####################################
Subprog TOKEN(CHAINE)
Variable Char    CHAINE()
If CHAINE<>""
 Local Char TOKEN(250)
 TOKEN = vireblc(format$("KT:250X",CHAINE),2)
 If CHAINE<>TOKEN
  CHAINE = TOKEN
 Endif
Endif
End

#####################################
$CHARGE_PROFIL
nolign = 0
For [PRF]PRF0 Where LEG=GCURLEG
 nolign += 1
 [M:MSR2]PRFCOD(nolign-1) = [F:PRF]PRFCOD
 Call LECTEXTRA([M:MSR2]PRFLIB(nolign-1),"PROFIL","PRFDES",[F:PRF]LEG,[F:PRF]PRFCOD) From ATEXTRA
Next
[M:MSR2]NBRPRF = nolign
Return

#####################################
$LIENS
#Multi_leg
GCURLEG=[F:MSR]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Gosub CHARGE_PROFIL
For nolign=1 To [M:MSR2]NBRPRF
 Look [MSC]MSC1 = [M:MSR2]PRFCOD(nolign-1);[F:MSR]COD
 If fstat<=2
  [M:MSR2]CALC(nolign-1) = 2 :#oui
 Else
  [M:MSR2]CALC(nolign-1) = 1 :#non
 Endif
Next

#Grise/dégrise bloc 'déclenchement'
VOK=0
Look [RUB]RUB0 = [F:MSR]COD
If !fstat : VOK=1 : Endif
Call GRISE_DECLENCHE(VOK)

Call GRISE_TYPRUB([F:MSR]TYPRUB)

#59527 Gestion grille MS
If [F:MSR]TYPRUB = 7 : # Grille
  Read [MGR]MGR0 = [F:MSR]TBLCOD
  If fstat
    Read [GRI]GRI0 = [F:MSR]TBLCOD
    If !fstat
      [M:MSR3] = [F:GRI]
      [M:MSR3]TBLDES = [F:GRI]DES
      If [F:MSR]TBLCOL<>0 & [F:MSR]TBLCOL<=2
        [M:MSR3]COLDES = [F:GRI]COLDES([F:MSR]TBLCOL-1)
      Endif
      [M:MSR3]TBLLNK = "GRI"
    Endif
  Else
    [M:MSR3] = [F:MGR]
    [M:MSR3]TBLDES = [F:MGR]DES
    If [F:MSR]TBLCOL<>0 & [F:MSR]TBLCOL<=2
      [M:MSR3]COLDES = [F:MGR]COLDES([F:MSR]TBLCOL-1)
    Endif
    [M:MSR3]TBLLNK = "MGR"
  Endif
  Call GRISE_TBLCOD([F:MSR]TBLCOD)
Endif
#end 59527

For indice=0 To dim([F:MSR]CUM)-1
 If [F:MSR]CUM(indice)<>""
  [M:MSR1]CUM(indice) = [F:MSR]CUM(indice)
  Read [F:CUM]CUM0 = GCURLEG;[F:MSR]CUM(indice)
  If !fstat
   [M:MSR1]CUMPER(indice) = [F:CUM]CUMPER
  Else
   Raz [M:MSR1]CUMPER
  Endif
 Endif
Next indice

#CMT
Default Mask [M:MSR2]
Call CHARGE_CMT ("SUBMSR",[F:MSR]COD,"","","")
Return

#####################################
$CREATION
#Row invisible
[M:MSR0]ROW = [F:MSR]ROW
Gosub MODIF
Return

#####################################
$MODIF
For indice=0 To [M:MSR2]NBRPRF-1
 Read [MSC]MSC0 = [F:MSR]COD;[M:MSR2]PRFCOD(indice)
 If fstat
  If [M:MSR2]CALC(indice)=2
   [F:MSC] = [M:MSR0]
   [F:MSC] = [M:MSR2]
   [F:MSC]COD    = [M:MSR0]COD
   [F:MSC]ROW    = [M:MSR0]ROW
   [F:MSC]PRFCOD = [M:MSR2]PRFCOD(indice)
   Write [MSC]
   If fstat : GOK = 0 : Call FSTA("MSC") From GLOCK : Break : Endif
  Endif
 Else
  If [M:MSR2]CALC(indice)=1
   GCLE = [M:MSR0]COD-[M:MSR2]PRFCOD(indice)
   Delete [MSC] Where [F:MSC]COD=[M:MSR0]COD & [F:MSC]PRFCOD=[M:MSR2]PRFCOD(indice)
   If fstat=1  : GOK = -1 : GLOCK = "$MSCALR"-GCLE : Break
   Elsif fstat : GOK = 0  : Call RSTA("MSC",GCLE) From GLOCK : Break
   Endif
  Endif
 Endif
Next
Return

#####################################
$ANNULE
Local Integer R
Call ANNULE_CMT ("SUBMSR",[F:MSR]COD,"","","")
Return

#####################################
$APRES_MOD
$APRES_CRE
$AP_ANNULE
Call SETPAR From GENPLANMS
Return

#####################################
#59616
$SEL_LISTE
  Case LISTE
    When "SELRUBMS"   : Gosub S_SELRUB
  Endcase
Return

#72636
# add option to not dupplicate rubrique codes
$S_SELRUB
Local Char    TEXTE(GLONDES)(1..dim(TEX),1..3)

TIT = mess(8,31,1) : # Sélection

If clalev([F:RUB1])=0 : Local File RUBRIQUE [RUB1] : Endif
If clalev([F:MSR1])=0 : Local File MSRUB    [MSR1] : Endif

Raz NBTEX

Filter [RUB1] Where CODGRP<>"" & LEG=GCURLEG
Filter [MSR1] Where CODGRP<>""

For [MSR1]MSR0
  NBTEX += 1
  TEXTE(NBTEX,1)  = [F:MSR1]COD
  TEXTE(NBTEX,2)  = [F:MSR1]DES
  TEXTE(NBTEX,3)  = [F:MSR1]CODGRP
  TEX(NBTEX) = [F:MSR1]COD
Next

For [RUB1]RUB0
  Look [MSR1]MSR0 = [F:RUB1]COD
  If fstat
    NBTEX += 1
    TEXTE(NBTEX,1)= [F:RUB1]COD
    Call LECTEXTRA(TEXTE(NBTEX,2),"RUBRIQUE","DES",[F:RUB1]LEG,[F:RUB1]COD) From ATEXTRA
    TEXTE(NBTEX,3)= [F:RUB1]CODGRP
    TEX(NBTEX)  = [F:RUB1]COD
  Endif
Next

Filter [RUB1]
Filter [MSR1]

TIT(1) = mess(32,147,1)    : #Rubrique
TIT(2) = mess(82,123,1)    : #Intitulé
TIT(3) = mess(183,10702,1) : #Groupe
Return
#59616

########################################
####### Ecran MSR1
########################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If clalev ([F:RUB])=0 : Local File RUBRIQUE [RUB]: Endif
Read [RUB]RUB0 = GCURLEG;VALEUR
If !fstat
 OK=2
 # Ce code existe déjà comme rubrique standard
 Call AVERTIR (mess(1,10722,1), OK) From GESECRAN
 If OK<>2 : mkstat = 2 : End : Endif
 Call GRISE_DECLENCHE(1)
#76781 : Add the 'Else'
Else
 Call GRISE_DECLENCHE(0)
Endif
End

########################################
Subprog GRISE_DECLENCHE(POK)
Value Integer POK
If POK
 Effzo [M:MSR1]40 :  Grizo [M:MSR1]40
Else
 Actzo [M:MSR1]40
Endif
End

########################################
Subprog C_CNDCAL(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

########################################
Subprog C_TYPRUB(VALEUR)
Variable Integer    VALEUR()
If VALEUR=5 & len([M:MSR0]COD)>9 : # Assiette
 # La longueur du code d'une rubrique de type "assiette" ne doit pas dépasser 9 caractères
 GMESSAGE = mess(42,10708,1)
 mkstat=2 : End
Endif
Call GRISE_TYPRUB(VALEUR)
End

########################################
Subprog AS_TYPRUB(VALEUR)
Variable Integer VALEUR
GMENLOC(5)=1
GMENLOC(9)=1
GMENLOC(8)=1
GMENLOC(10)=1
End

########################################
Subprog C_BAS(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

########################################
Subprog C_RAT1(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

########################################
Subprog C_RAT2(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

########################################
Subprog C_CUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If clalev ([F:CUM])=0 : Local File CUMUL [CUM]: Endif
Call LECTURE("CUM",VALEUR,GCURLEG) From CONTOBJ
If [F:CUM]CUMTMP=2
 Call ERREUR(mess(10,10708,1)) From GESECRAN
 # Cumul intermédiaires
  mkstat=2 : End
Endif
[M:MSR1]CUMPER(nolign-1) = [F:CUM]CUMPER
End

########################################
Subprog AV_OPTCUM(VALEUR)
Variable Integer VALEUR
If VALEUR = 0 : VALEUR=3 : Endif
End

########################################
####### Ecran MSR3
########################################

########################################
Subprog C_TBLCOD(VALEUR)
Variable Char    VALEUR()
  #59527 Gestion grille MS
  If VALEUR<>""
    Look [MGR]MGR0 = VALEUR
    If fstat
      Look [GRI]GRI0 = VALEUR
      If fstat
        GMESSAGE =  mess(49,10722,1) : # Grille inexistante
        mkstat = 2 : End
      Endif
    Endif
  Endif
  #end 59527
End

########################################
Subprog GRISE_TBLCOD(VALEUR)
Variable Char    VALEUR()
  #59527 Gestion grille MS
  Raz [M:MSR3]INTFRM

  If [M:MSR3]TBLLNK = "" : End : Endif

  For indice=0 To evalue("[F:"+[M:MSR3]TBLLNK+"]NBRCMP-1")
   [M:MSR3]INTFRM(indice) = evalue("[F:"+[M:MSR3]TBLLNK+"]CMPDES("+num$(indice)+")")
   Actzo [M:MSR3]TBLFRM(indice)
  Next indice
  #  For indice=[F:GRI]NBRCMP To dim([M:MSR3]TBLFRM)-1
  For indice=evalue("[F:"+[M:MSR3]TBLLNK+"]NBRCMP") To dim([M:MSR3]TBLFRM)-1
   Grizo [M:MSR3]TBLFRM(indice)
  Next indice
  #end 59527
End

########################################
Subprog AS_TBLFRM(VALEUR)
Variable Char VALEUR()
#59527 Gestion grille MS
  If [M:MSR3]TBLLNK="" : End : Endif
  Call LECTURE([M:MSR3]TBLLNK,[M]TBLCOD,"") From CONTOBJ

  If indice+1>evalue("[F:"+[M:MSR3]TBLLNK+"]NBRCMP")
   mkstat = 1 : End
  Endif
#end 59527
End

########################################
Subprog C_TBLFRM(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

########################################
Subprog C_TBLCOL(VALEUR)
Variable Decimal VALEUR
#Variable Integer NOCOL #DLE variable pas utilisée ?
#59527 Gestion grille MS
If [M:MSR3]TBLLNK="" : End : Endif
Call LECTURE([M:MSR3]TBLLNK,[M:MSR3]TBLCOD,"") From CONTOBJ
If VALEUR>evalue("[F:"+[M:MSR3]TBLLNK+"]NBRCOL")
 # Le numéro de la colonne doit être infèrieur à xxx
 GMESSAGE = mess(13,10708,1)-num$(evalue("[F:"+[M:MSR3]TBLLNK+"]NBRCOL")+1)
 mkstat = 2 : End
Else
 If VALEUR<1
  # Le numéro de la colonne doit être supèrieur à 0
  GMESSAGE = mess(12,10708,1)-"0"
  mkstat = 2 : End
 Endif
Endif
[M:MSR3]COLDES = evalue("[F:"+[M:MSR3]TBLLNK+"]COLDES("+num$(VALEUR-1)+")")
#end 59527
End

########################################
Subprog AV_ITVLIM(VALEUR)
Variable Char VALEUR
If nolign=1 : mkstat = 1 : Endif
End

########################################
Subprog C_ITVLIM(VALEUR)
Variable Char VALEUR
If nolign<>1
 If VALEUR="0" | VALEUR=""
  # Zone obligatoire
  GMESSAGE = mess(10,123,1)
  mkstat = 2 : End
 Endif
Endif
If VALEUR<>num$(val(VALEUR))
 VALEUR = toupper(VALEUR)
 Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 If mkstat
  # Il faut saisir un nombre ou une variable
  GMESSAGE = mess(176,10703,1)
  mkstat = 2 : End
 Endif
Endif
End

########################################
Subprog C_ITVAMT(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR)
End

##############################################################
########### Sous-programmes de grisage/dégrisage
##############################################################
#valeurs de typrub :
#1-base
#2-base*tx
#3-base*tx /100
#4-intervalle
#6-cotisation
#7-grille
########################################

Subprog GRISE_TYPRUB(VALEUR)
Value Integer VALEUR

[M:MSR1]LIBTX0 = mess(2,10702,1) : # Base
Actzo [M:MSR1]BAS

[M:MSR1]LIBTX1 = ""
[M:MSR1]LIBTX2 = ""
Case VALEUR
  When 1 : # Base
   Effzo [M:MSR1]RAT1,RAT2
   Grizo [M:MSR1]RAT1,RAT2
   Effzo [M:MSR3] : Grizo [M:MSR3]
  When 2 : # Base * taux
   [M:MSR1]LIBTX1 = mess(1,10326,1)    #Part salariale
   [M:MSR1]LIBTX2 = mess(2,10326,1)    #Part patronale
   Actzo [M:MSR1]RAT1, RAT2
   Effzo [M:MSR3] : Grizo [M:MSR3]
  When 3 : # Base * taux /100
   [M:MSR1]LIBTX1 = mess(6,10708,1)    #% salarial
   [M:MSR1]LIBTX2 = mess(7,10708,1)    #% patronal
   Actzo [M:MSR1]RAT1, RAT2
   Effzo [M:MSR3] : Grizo [M:MSR3]
  When 4 : # Intervalle
   Effzo [M:MSR1]RAT1,RAT2
   Grizo [M:MSR1]RAT1,RAT2
   Effzo [M:MSR3]5 : Grizo [M:MSR3]5
   Actzo [M:MSR3]10
  When 6 : # Cotisation
   [M:MSR1]LIBTX1 = mess(6,10708,1)    #% salarial
   [M:MSR1]LIBTX2 = mess(7,10708,1)    #% patronal
   Actzo [M:MSR1]RAT1, RAT2
   Effzo [M:MSR3] : Grizo [M:MSR3]
  When 7 : # Grille
   Effzo[M:MSR1]LIBTX0
   Effzo [M:MSR1]RAT1,RAT2,BAS
   Grizo [M:MSR1]RAT1,RAT2,BAS
   Actzo [M:MSR3]5
   Effzo [M:MSR3]10 : Grizo [M:MSR3]10
Endcase
Affzo [M:MSR1]LIBTX0,LIBTX1,LIBTX2
End

#Tax band
Subprog CONTFRM(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK, LNGFOR
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0
LNGFOR = len(FORMULE)
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_" : #65041
    Read [MSR]MSR0 = CODE
    If fstat
     Read [RUB]RUB0 = GCURLEG;CODE
     If fstat
      Read [RUB]RUB1 =GCURLEG; val(CODE)
      If !fstat
       FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
       I += len([F:RUB]COD)-len(CODE)
       CODE = [F:RUB]COD
      Else
       GERR = 1 : GMESSAGE = mess(11,10702,1) : Break :  # Rubrique inexistante
      Endif
     Endif
    Endif
    #65041
    If OP<>"R_" & OP<>"B_"
     If [F:RUB]TYPRUB<>5
      GERR = 1 : GMESSAGE = mess(12,10702,1) : Break : # La rubrique n'est pas de type assiette
     Endif
    Endif
   When "V_"
    Read [VRA]VRA0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(13,10702,1) : Break : # Variable inexistante
    Elsif [F:VRA]FLGEXS=2
     GERR = 1 : GMESSAGE = mess(183,10703,1) : Break : # Variable de note de frais
    Endif
   When "C_"
    Read [CUM]CUM0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(14,10702,1) : Break : # Cumul inexistant
    Endif
   When "[F]"
    OK = 0
    For [ATZ]DICO Where CODZONE=CODE
     If find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB),"TIMEMPDAT","TIMRECAP")
      OK = 1 : Break
     Endif
    Next
    If !OK
     GERR = 1 : GMESSAGE = mess(15,10702,1) : Break : # Champ inexistant dans la base
    Endif
  Endcase
  #65041
  If find(OP,"R_","C_","B_") & mid$(FORMULE,I+1,1)<>"("
   LNGFOR +=3
  Endif
   I += 1
 Else
  I += 1
 Endif
Wend
If GERR
 GMESSAGE = CODE+"\"+GMESSAGE : mkstat = 2
Endif
If (GFONCTION="GESRUB" | GFONCTION="GESCUM") & LNGFOR>250
 # Expression trop longue
 # Les codes rubriques et cumuls seront complétés par "(1)" à la génération du plan de paie
 GERR = 1 : GMESSAGE = mess(62,123,1)+"\"+mess(206,10703,1)
 mkstat = 2
Endif
End

Subprog CONTMSR(CODE)
Variable Char CODE()
If instr(1,CODE,"-")
 # Caractère interdit
 GMESSAGE = "- :"-mess(94,123,1)
 mkstat=2 : End
Endif
If instr(1,CODE,"/")
 # Caractère interdit
 GMESSAGE = "/ :"-mess(94,123,1)
 mkstat=2 : End
Endif
If num$(val(CODE))=CODE
 If clalev([F:MSR])=0 : Local File MSRUB [MSR] : Endif
 Look [MSR]MSR0 = CODE
 If fstat
  Read [MSR]MSR1 = val(CODE)
  If !fstat
   CODE = [F:MSR]COD
  Endif
 Endif
Endif
End



########################Gestion des commentaires##########################
# Attention il faut que le clob dans l'écran s'appelle CMT
###########################################################################

#####################################
Subprog CHARGE_CMT (CODE, ID1, ID2, ID3, ID4)
Value Char CODE ()
Value Char ID1 ()
Value Char ID2 ()
Value Char ID3 ()
Value Char ID4 ()
Read [BCB]BCB0=CODE;ID1;ID2;ID3;ID4
If !fstat
 [M]CMT=[F:BCB]CLOB
Endif
End

#####################################
Subprog SAUVE_CMT (CODE, ID1, ID2, ID3, ID4)
Value Char CODE ()
Value Char ID1 ()
Value Char ID2 ()
Value Char ID3 ()
Value Char ID4 ()
Readlock [BCB]BCB0=CODE;ID1;ID2;ID3;ID4
If fstat=1
 GOK=-1 : Call RSTA("BCB",CODE-ID1-ID2-ID3-ID4) From GLOCK : End
Elsif !fstat
 [F:BCB]CLOB   = [M]CMT
 If dim([F:BCB]UPDUSR)>0 : [F:BCB]UPDUSR = GUSER : Endif
 If dim([F:BCB]UPDDAT)>0 : [F:BCB]UPDDAT = date$ : Endif
 If dim([F:BCB]UPDTIM)>0 : [F:BCB]UPDTIM = time  : Endif
 Rewrite [BCB]
 If fstat
  GOK = 0 : Call FSTA("BCB") From GLOCK : End
 Endif
Else
 Raz [F:BCB]
 [F:BCB]CODBLB = CODE
 [F:BCB]IDENT1 = ID1
 [F:BCB]IDENT2 = ID2
 [F:BCB]IDENT3 = ID3
 [F:BCB]IDENT4 = ID4
 [F:BCB]CLOB   = [M]CMT
 If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
 If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
 If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
 Write [BCB]
 If fstat
  GOK = 0 : Call FSTA("BCB") From GLOCK : End
 Endif
Endif
End

#####################################
Subprog ANNULE_CMT (CODE, ID1, ID2, ID3, ID4)
Value Char CODE ()
Value Char ID1 ()
Value Char ID2 ()
Value Char ID3 ()
Value Char ID4 ()
Delete [BCB]BCB0=CODE;ID1;ID2;ID3;ID4
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$BCLOB"-CODE-ID1-ID2-ID2-ID3
Endif
End


###########
Subprog AM_EFF1MS(VALEUR)
  Variable Integer VALEUR

  If VALEUR=2
    [M:MSR1]NOSUMMS = 2
    Affzo [M:MSR1]NOSUMMS
  Endif
End

Subprog AM_EFF2MS(VALEUR)
  Variable Integer VALEUR

  If VALEUR=2
    [M:MSR1]NOSUMMS = 2
    Affzo [M:MSR1]NOSUMMS
  Endif
End

#59527 Gestion grille MS
Subprog AM_TBLCOD(VALEUR)
  Variable Char    VALEUR()
  If VALEUR<>""
    Read [MGR]MGR0 = VALEUR
    If fstat
      Read [GRI]GRI0 = VALEUR
      If !fstat
        [M:MSR3]TBLDES = [F:GRI]DES
        [M:MSR3]TBLLNK = "GRI"
      Endif
    Else
        [M:MSR3]TBLDES = [F:MGR]DES
        [M:MSR3]TBLLNK = "MGR"
    Endif
  Else
    Raz [M:MSR3]TBLDES, TBLLNK
  Endif
  Raz [M:MSR3]TBLCOL, COLDES, TBLFRM
  Affzo [M:MSR3]TBLCOL, COLDES, TBLFRM
  Call GRISE_TBLCOD(VALEUR)
  Affzo [M:MSR3]INTFRM
End
#end 59527

#74851
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:RUB]) : Local File RUBRIQUE [RUB]: Endif
  Read [RUB]RUB0 = GCURLEG;VALEUR
  #76781 : delete the GREP='C' because we need it in duplication mode too ('D')
  If !fstat #& GREP="C"
    Call INITFROMRUBVALUES()
  Endif
End

Subprog INITFROMRUBVALUES()
  If !clalev([F:RUB]) : Local File RUBRIQUE [RUB]: Endif
  If !clalev([F:CRB]) : Local File CALRUB   [CRB]: Endif
  If !clalev([F:GRI]) : Local File GRILLE   [GRI]: Endif
  If !clalev([F:MGR]) : Local File MSGRIL   [MGR]: Endif

  [M:MSR0]=[F:RUB]
  [M:MSR1]=[F:RUB]
  [M:MSR2]=[F:RUB]
  [M:MSR3]=[F:RUB]

  For nolign=1 To [M:MSR2]NBRPRF
   Look [CRB]CRB1 = [M:MSR2]PRFCOD(nolign-1);[F:RUB]LEG;[F:RUB]COD
   If fstat<=2
    [M:MSR2]CALC(nolign-1) = 2 :#oui
   Else
    [M:MSR2]CALC(nolign-1) = 1 :#non
   Endif
  Next

  Raz [M:MSR2]CMT
  For I=0 To dim([F:RUB]CMT)-1
    If [F:RUB]CMT(I)<>""
      [M:MSR2]CMT+=[F:RUB]CMT(I)+chr$(13)
    Endif
  Next

  #Grise bloc déclenchement
  Call GRISE_DECLENCHE(1)
  Call GRISE_TYPRUB([F:RUB]TYPRUB)

  #Charge les cumuls
  For indice=0 To dim([F:RUB]CUM)-1
    If [F:RUB]CUM(indice)<>""
     [M:MSR1]CUM(indice) = [F:RUB]CUM(indice)
     Read [F:CUM]CUM0 = GCURLEG;[F:RUB]CUM(indice)
     If !fstat
      [M:MSR1]CUMPER(indice) = [F:CUM]CUMPER
     Else
      Raz [M:MSR1]CUMPER
     Endif
    Endif
  Next indice

  #Charge de préférence la grille MS si existe
  If [F:RUB]TYPRUB = 7 : # Grille
    Read [MGR]MGR0 = [F:RUB]TBLCOD
    If !fstat
      [M:MSR3] = [F:MGR]
      [M:MSR3]TBLCOD = [F:MGR]COD
      [M:MSR3]TBLDES = [F:MGR]DES
      If [F:RUB]TBLCOL<>0 & [F:RUB]TBLCOL<=2
        [M:MSR3]COLDES = [F:MGR]COLDES([F:RUB]TBLCOL-1)
      Endif
      [M:MSR3]TBLLNK = "MGR"
    Else
      Read [GRI]GRI0 = [F:RUB]TBLCOD
      If !fstat
        [M:MSR3] = [F:GRI]
        [M:MSR3]TBLDES = [F:GRI]DES
        If [F:RUB]TBLCOL<>0 & [F:RUB]TBLCOL<=2
          [M:MSR3]COLDES = [F:GRI]COLDES([F:RUB]TBLCOL-1)
        Endif
        [M:MSR3]TBLLNK = "GRI"
      Endif
    Endif
    Call GRISE_TBLCOD([F:MSR]TBLCOD)
  Endif

  Affzo [M:MSR0]
  Affzo [M:MSR1]
  Affzo [M:MSR2]
  Affzo [M:MSR3]
End
#end 74851
######################################################################################
