#<AdxTL>@(#)0.0.0.0 $Revision$ Mouvements par date
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSMJ]: Transmask [M:SMJ1] To [M:CSMJ]# Issue 25606 [M:CSMJ] = [M:SMJ1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
Raz GSOC_ACTIVE                                               # Ana

If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:SGH]) = 0 : Local File SCHGH      [SGH] : Endif  # MAE x3-106909
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])    Local File GACM       [GCM] : Endif   # Ana
Endif                                                          # Ana

# Chargement des globales référentiels, comptes et sections de la société
GFCY=GFCYDEF(7)                                                # Ana
Call GETCPY(GFCY,"",0,"") From TRTX3CPT                        # Ana
GORITITCOL=1                                                   # Ana

Global Char    WFIL1(250), WFILS(250), WFILF(250), WSTR(250), WFILSPE(250)  # hcb 78584
Local Integer WFSTAT, WREAD, WSKIP, WLIG, WPAGE
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, WOK, WNOL,WAGR

Gosub LOAD_SCREEN

NAVIG="CONSSMJ"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:SMJ1]FLG = 0
[M:SMJ1] = [M:CSMJ]
Return
############################################################
$AP_MAGNETO
[M:SMJ1]FLG = 0
Return
############################################################
$FERME
Raz GORITITCOL                                         # Ana
If clalev([F:STJ]) <> 0 : Filter [STJ] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
 Case I
  When 1 :
   GCONSULT = val(PARAM(I))
  When 2 :
   If PARAM(I) <> "" & PARAM(I) <> "***"
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:SMJ1]FLG = 0    # Permettre le préchargement
     [M:SMJ1]FCY = PARAM(I)
    Endif
   Endif
  When 3 :
   If PARAM(I) = ""
    WFILS = "1=1"
   Else
    WFILS = evalue(PARAM(I))
   Endif
 Endcase
Next I
#
If clalev([M:CSMJ]) <> 0 & [M:CSMJ]MEMO = "STD"
  [M:SMJ1] = [M:CSMJ]
Else
  [M:SMJ1]STDFLG    = 2
  [M:SMJ1]MISFLG    = 1
Endif

[M:SMJ1]STRDAT = date$
[M:SMJ1]ENDDAT = date$
# Si je viens de la consultation des pièces comptables (via tunnel)
If GTUNCPT(4)=1 # consultation de pièces
 [M:SMJ1]STRDAT = [M:PCE1]DATDEB
 [M:SMJ1]ENDDAT = [M:PCE1]DATFIN
 # Issue 100246 - 2015-02-24 by CCC
 #[M:SMJ1]SRTCOD=2 # date d'imputation # bug 26558
 [M:SMJ1]SRTCOD=3 # date de comptabilisataion
 [M:SMJ1]FCY=""
 [M:SMJ1]FLG = 0
 WNOL = nolign-1
Elsif GTUNCPT(1)=1 # consultation de comptes
 [M:SMJ1]STRDAT = [M:CPT1]DATDEB
 [M:SMJ1]ENDDAT = [M:CPT1]DATFIN
 # Issue 100246 - 2015-02-24 by CCC
 #[M:SMJ1]SRTCOD=2 # date d'imputation # bug 26558
 [M:SMJ1]SRTCOD=3 # date de comptabilisataion
 [M:SMJ1]FCY=""
 [M:SMJ1]FLG = 0
 WNOL = nolign-1
Else
 [M:SMJ1]STRDAT = date$
 [M:SMJ1]ENDDAT = date$
Endif
Return

############################################################
$LECTURE
# Affichage entêtes de colonne variables                       # Ana
Gosub AFF_TITCOL                                               # Ana

If [M:SMJ1]FLG = 2
  [M:SMJ1]FLG = 0
  NBLU        = 0
  Return
Endif
#MAE, bg 85422
[M:SMJ1]FLG = 0
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [STJ]  With Nohint
      If nolign <= MAXLIG
        Gosub LOA_LIGNE
        NBLU    = 2
        nolign += 1
        NOL    += 1
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [STJ]  With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SMJ2]
    WLIG = 0
    For [STJ] With Nohint
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [STJ] With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [STJ] With Nohint
      If WLIG >= WSKIP
        If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
Return
############################################################
$TRT_FILTER
If [M:SMJ1]FLG = 0
  [M:SMJ1]FLG = 1
  Raz [M:SMJ2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Case [M:SMJ1]SRTCOD
    When 1 :
      Onerrgo ERR_FORM1
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By CREDAT; ITMREF
      Onerrgo
    When 3 :    # Issue 100246 - 2015-02-24 by CCC : accounting date selection
      Onerrgo ERR_FORM3
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By ACCDAT; IPTDAT; ITMREF
      Onerrgo
    When Default :
      Onerrgo ERR_FORM
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT; ITMREF
      Onerrgo
  Endcase
  Raz [F:STJ]
  fstat = 0
Endif
Return
############################################################
$ERR_FORM1
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFILS)
&            Order By CREDAT; ITMREF
Resume

$ERR_FORM3
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFILS)
&            Order By ACCDAT;IPTDAT; ITMREF
Resume

$ERR_FORM
Call MESSAGE (mess(65,106,1)) From GESECRAN
Filter [STJ] Where evalue(WFIL1) & evalue(WFILS)
&            Order By IPTDAT; ITMREF
Resume
############################################################
$LOAD_FILTER
#Chargement des filtres
# Sélection numéro article
Case [M:SMJ1]SRTCOD
    When 1 : WFIL1 = "[F:STJ]CREDAT>=[M:SMJ1]STRDAT&[F:STJ]CREDAT<=[M:SMJ1]ENDDAT"
    When 3 : WFIL1 = "[F:STJ]ACCDAT>=[M:SMJ1]STRDAT&[F:STJ]ACCDAT<=[M:SMJ1]ENDDAT"
    When Default : WFIL1 = "[F:STJ]IPTDAT>=[M:SMJ1]STRDAT&[F:STJ]IPTDAT<=[M:SMJ1]ENDDAT"
Endcase
# Filtre site
If [M:SMJ1]FCY <> "" & GTUNCPT(1)<>1 & GTUNCPT(4)<>1
  WFIL1 += "&[F:STJ]STOFCY=[M:SMJ1]FCY"          # graph
Endif
# Filtre code mise à jour
If [M:SMJ1]UPDFLG = 1                            # graph
  WFIL1 += "&[F:STJ]UPDCOD=2"
Else
  WFIL1 += "&[F:STJ]UPDCOD=1"
Endif
If [M:SMJ1]REGFLG <> 2                         # hcb 040105  24390     # graph
   WFIL1 += "&[F:STJ]REGFLG <>2"           # hcb 040105  24390
Endif                                     # hcb 040105  24390

# Pour filtre les enregistrements bidon d'inventaire
WFIL1 += "&[F:STJ]TRSTYP<>0"


# Filtre type pièce
If [M:SMJ1]VCRTYPSEL > 1                                # graph
  WFIL1 += "&[F:STJ]VCRTYP=[M:SMJ1]VCRTYPSEL-1"         # graph
Endif
# Filtre numéro pièce
If [M:SMJ1]VCRNUMSEL <> ""                              # graph
  WFIL1 += "&[F:STJ]VCRNUM=[M:SMJ1]VCRNUMSEL"           # graph
Endif
# Filtre tiers
If [M:SMJ1]BPRNUM <> ""                              # graph
  WFIL1 += "&[F:STJ]BPRNUM=[M:SMJ1]BPRNUM"           # graph
Endif
# Filtre types de mvts
# CCC (20/04/05) Bug 29864 Il fallait mettre "&"
If !([M:SMJ1]MISFLG=2 & [M:SMJ1]STDFLG=2 & [M:SMJ1]CHGFLG=2) & !([M:SMJ1]MISFLG=1 & [M:SMJ1]STDFLG=1 & [M:SMJ1]CHGFLG=1)    # graph
  If [M:SMJ1]STDFLG = 2                                                   # graph
    If [M:SMJ1]MISFLG = 2      WFIL1 += "&[F:STJ]TRSTYP <> 23"            # graph
    # Issue X3-53322- 2018-06-01 by MAE : ajout type 36
    Else If [M:SMJ1]CHGFLG = 2 WFIL1 += "&!find([F:STJ]TRSTYP,7,8,9,21,25,36)"   # graph
         Else             WFIL1 += "&!find([F:STJ]TRSTYP,7,8,9,21,23,25,36)"
         Endif
    Endif
  Else
    If [M:SMJ1]MISFLG = 2                                                            # graph
       If [M:SMJ1]CHGFLG = 2   WFIL1 += "&find([F:STJ]TRSTYP,7,8,9,21,23,25,36)"     # graph
       Else               WFIL1 += "&find([F:STJ]TRSTYP,7,8,9,21,25,36)"
       Endif
    Else
       If [M:SMJ1]CHGFLG = 2   WFIL1 += "&[F:STJ]TRSTYP=23"                         # graph
       Endif
    Endif
  Endif
Endif

If GTUNCPT(4)=1 # consultation de pièces
 WFIL1 += "&[F:STJ]NUMVCR='"+[M:PCE2]NUM(WNOL)+"'"
Elsif GTUNCPT(1)=1 # consultation de comptes
 WFIL1 += "&[F:STJ]NUMVCR='"+[M:CPT2]NUM(WNOL)+"'"
Endif

# Filtre formule
WFILF = "1=1"
If [M:SMJ1]SELFOR <> ""                                        # graph
  Read [TFO]TFO0=11;[M:SMJ1]SELFOR                             # graph
  If fstat = 0
    WFILF = [F:TFO]FORFOR
  Endif
Endif
Return
############################################################
$LOA_LIGNE
#--- Issue 110327
#MAE, bg 85422
#If [F:ITM]SERMGTCOD > 1
#  Gosub AGREG
#Endif
#If WAGR=1 : Return : Endif
#[M:SMJ2] = [F:STJ]
#For I=1 To GNBDIE
#   Assign "[M:SMJ2]CCE"+num$(I)+"(nolign-1)" With [F:STJ]CCE(I-1)
#Next I
#--- End issue 110327

If [F:STJ]ITMREF <> [F:ITM]ITMREF
  Read [ITM]ITM0=[F:STJ]ITMREF
  If fstat
    Raz [F:ITM]
  Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STJ]STOFCY | [F:ITF]ITMREF <> [F:STJ]ITMREF
   Read [ITF]ITF0 = [F:STJ]ITMREF;[F:STJ]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

#--- Issue 110327
If find([F:ITM]SERMGTCOD,2,3)
  Gosub AGREG
Endif
If WAGR=1 : Return : Endif

[M:SMJ2] = [F:STJ]

If [F:ITM]SERMGTCOD=4
  [M:SMJ2]SERNUM(nolign-1) = [F:STJ]SERDEB
  [M:SMJ2]SERFIN(nolign-1) = [F:STJ]SERFIN
Endif

For I=1 To GNBDIE
   Assign "[M:SMJ2]CCE"+num$(I)+"(nolign-1)" With [F:STJ]CCE(I-1)
Next I
#--- End issue 110327


#[M:SMJ2]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SMJ2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
If dim([M:SMJ2]POT) > 0 & [F:ITF]STOMGTCOD <> 3
  [M:SMJ2]POT(nolign-1) = 0
Endif
If dim([M:SMJ2]ACT) > 0 & [F:ITF]STOMGTCOD <> 4
  [M:SMJ2]ACT(nolign-1) = 0
Endif
If [F:STJ]VCRTYP = 0
  [M:SMJ2]VCRTYPTXT(nolign-1) = ""
Else
  [M:SMJ2]VCRTYPTXT(nolign-1) =  mess([F:STJ]VCRTYP,701,1)
Endif
If [F:STJ]VCRTYPORI = 0
  [M:SMJ2]VCRTYPORIT(nolign-1) = ""
Else
  [M:SMJ2]VCRTYPORIT(nolign-1) =  mess([F:STJ]VCRTYPORI,701,1)
Endif

If [F:FCY]FCY<>[F:STJ]STOFCY
    Read [F:FCY]FCY0=[F:STJ]STOFCY
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
    Read [F:CPY]CPY0=[F:FCY]LEGCPY
Endif
[M:SMJ2]ACCCUR(nolign-1)=[F:CPY]ACCCUR


#--- Issue 110327
If [F:ITM]SERMGTCOD<4
  #--- calcul du no série de fin
  If dim([M:SMJ2]SERNUM) > 0              # hcb 31468
    If [M:SMJ2]SERNUM(nolign-1) <> ""
      If abs([M:SMJ2]QTYSTU(nolign-1)) = 1
         [M:SMJ2]SERFIN(nolign-1) = [M:SMJ2]SERNUM(nolign-1)
      Else Call PLUS_NB([M:SMJ2]SERNUM(nolign-1),abs([M:SMJ2]QTYSTU(nolign-1)),[M:SMJ2]SERFIN(nolign-1),WOK) From STKLIB
      Endif
   Else
      # Issue 120964 - 2017-01-19 by MAE
      [M:SMJ2]SERFIN(nolign-1) = ""
   Endif
  Endif                                   # hcb 31468
#--- Issue 110327
Endif

Return
############################################################
$AGREG
Raz WAGR
# Si agrégation
If [M:CSMJ]AGGFLG = 2 & NOL <> -1
  For I = 0 To MAXLIG-1
    If [M:SMJ2]STOFCY(I)    = "" : Break : Endif
    If dim([M:SMJ2]LOT) > 0
         WLOT = [M:SMJ2]LOT(I)
    Else WLOT = ""
    Endif
    If dim([M:SMJ2]SLO) > 0
         WSLO = [M:SMJ2]SLO(I)
    Else WSLO = ""
    Endif
    If dim([M:SMJ2]LOC) > 0
         WLOC = [M:SMJ2]LOC(I)
    Else WLOC = ""
    Endif
    If dim([M:SMJ2]PALNUM) > 0
         WPAL = [M:SMJ2]PALNUM(I)
    Else WPAL = ""
    Endif
    If dim([M:SMJ2]CTRNUM) > 0
         WCTR = [M:SMJ2]CTRNUM(I)
    Else WCTR = ""
    Endif
    If WLOT                 = [F:STJ]LOT       &
&      WSLO                 = [F:STJ]SLO       &
&      WLOC                 = [F:STJ]LOC       &
&      WPAL                 = [F:STJ]PALNUM    &
&      WCTR                 = [F:STJ]CTRNUM    &
&      [M:SMJ2]STA(I)       = [F:STJ]STA       &
&      [M:SMJ2]PCU(I)       = [F:STJ]PCU       &
&      [M:SMJ2]QLYCTLDEM(I) = [F:STJ]QLYCTLDEM &
&      [M:SMJ2]TRSTYP(I)    = [F:STJ]TRSTYP       #MAE, bg 85422
      [M:SMJ2]QTYPCU(I)    += [F:STJ]QTYPCU
      [M:SMJ2]QTYSTU(I)    += [F:STJ]QTYSTU
      If dim([M:SMJ2]SERNUM) > 0 & [M:SMJ2]SERNUM(I)<>""
        [M:SMJ2]SERNUM(I) = [F:STJ]SERNUM
        [M:SMJ2]SERFIN(I) = "$"
      Endif
      WAGR=1
      Break
    Endif
  Next I
  If WAGR = 1
    nolign -= 1
    NOL    -= 1
    WLIG   -= 1
    Return
  Endif
Endif
Return
#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL                             : # ana
If dim([M:SMJ2]CCE1)>0                                  # hcb 112700
#If GSOC_UPDFLG & dim([M:SMJ2]CCE1)>0                   # hcb 112700
  Local Char BASPAG(10)
  Call ISSCREENOK (nomap,"CONSSMJ2") From INTRUTILB
  BASPAG="NBLIG" : Gosub TIT_COL From W1CONSSMJ2
  # Pour forcer l'utilisation des formats évalués si tableau vide
  If [M:SMJ2]NBLIG=0
    [M:SMJ2]NBLIG=1 : Affzo [SMJ2]5 : Effzo [SMJ2]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

############################################################
$SETBOUT
CHMEN += "1"                 # hcb graph
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local    Char WPAR
[M:SMJ1]FLG = 0
#--- Bug 77058
GFCY=VALEUR
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Gosub AFF_TITCOL
#---
End
#############################################################
Subprog AM_STRDAT(VALEUR)
Variable Date     VALEUR
If VALEUR > [M]ENDDAT
  [M]ENDDAT = VALEUR
Endif
[M:SMJ1]FLG = 0
End
#############################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
[M:SMJ1]FLG = 0
End
#############################################################
Subprog AS_MISFLG(VALEUR)
Variable Integer VALEUR
End
#############################################################
Subprog AV_QTYPCU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AV_QTYSTU(VALEUR)
Variable Decimal VALEUR
If nolign > 0
  If VALEUR < 0
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog AM_MISFLG(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AM_STDFLG(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AM_SRTCOD(VALEUR)
Variable Integer VALEUR
[M:SMJ1]FLG = 0
End

##########################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,5,6,7,9,10,13,14,16,19,20,21,27,29,30,31,32,33,34,35,36,37)
        GMENLOC(I) = 1
    Endif
Next
End
######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SMJ2]LOT
######################################################################################
Subprog IB_NBLIG
    If [M:SMJ2]NUMVCR(nolign-1)=""
        Raz GBOUT5
    Endif
    If dim([M:SMJ2]LOT) > 0 Then    # SYMEU 61044
      If [M:SMJ2]LOT(nolign-1)="" Then
          Raz GBOUT6
      Endif
    Endif
    If [M:SMJ2]ITMREF(nolign-1) <> [F:ITM]ITMREF
       Read [ITM]ITM0=[M:SMJ2]ITMREF(nolign-1)
    Endif
    If (dim([M:SMJ2]LOT) > 0 and [M:SMJ2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then   # SYMEU 61044
        Raz GBOUT7
    Endif
    If !find([M:SMJ2]VCRTYP(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT8
    Else
       # Issue X3-73341 - 2018-02-19 by MAE : ajout du type "changement de contenant"
      If [M:SMJ2]TRSTYP(nolign-1) <> 36
        GBOUT8 = mess([M:SMJ2]VCRTYP(nolign-1),701,1)-"("+[M:SMJ2]VCRNUM(nolign-1)+")"
      Else
        # Issue 106909 - 2018-09-21 by MAE : gestion des opérations et affectations LPN
        Read [SGH] SGH0 = [M:SMJ2]VCRNUM(nolign-1)
        If fstat
          Raz GBOUT8
        Else
          If find([F:SGH]MODOPELPN,1,2,3)
             GBOUT8 = func AFNC.TEXTE(1003869)-"("+[M:SMJ2]VCRNUM(nolign-1)+")"
          Else
             GBOUT8 = func AFNC.TEXTE(1003554)-"("+[M:SMJ2]VCRNUM(nolign-1)+")"
          Endif
        Endif
          #pas de tunnel si le type est "changement de contenant" : on ne sait pas si le mouvement provient de l'affectation ou des opérations
          #Raz GBOUT8
         # End issue X3-106909
      Endif
    Endif
    If !find([M:SMJ2]VCRTYPORI(nolign-1),2,4,5,6,8,9,10,12,13,14,15,17,18,19,20,26,28,29,31,32,33,36)
        Raz GBOUT9
    Else
        GBOUT9 = mess([M:SMJ2]VCRTYPORI(nolign-1),701,1)-"("+[M:SMJ2]VCRNUMORI(nolign-1)+")"
    Endif
End

#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SMJ") From SUBGTC

End

######################################################################################
Subprog B8_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMJ2]VCRTYP(NOL),[M:SMJ2]VCRNUM(NOL),[M:SMJ2]TRSTYP(NOL))
End

######################################################################################
Subprog B9_NBLIG
Local Integer NOL : NOL = nolign-1
Call LNK2VCR([M:SMJ2]VCRTYPORI(NOL),[M:SMJ2]VCRNUMORI(NOL),0)
End

######################################################################################
Subprog LNK2VCR(PTYP, PNUM, PTRS)
Value Integer PTYP
Value Char    PNUM
Value Integer PTRS    # Issue X3-106909 - 2018-09-21 by MAE : gestion des opérations et affcetations LPN
# hcb 78584 deb
Local Char    WITM(GLONITM)
Local Date    WIPT
Local Date    WDAT
Local Integer WSEQ
Local Integer WIND
WITM = [F:STJ]ITMREF
WIPT = [F:STJ]IPTDAT
WSEQ = [F:STJ]MVTSEQ
WIND = [F:STJ]MVTIND
WDAT = [F:STJ]CREDAT
# hcb 78584 deb

GCONSULT = 2
Case PTYP
When 2   # commande vente
    Call OBJET("SOH",PNUM,num$(PTYP)) From GOBJET
When 4   # livraison
    Call OBJET("SDH",PNUM,num$(PTYP)) From GOBJET
When 5   # Facture vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 6   # reception
    Call OBJET("PTH",PNUM,num$(PTYP)) From GOBJET
When 8   # Retour fournisseur
    Call OBJET("PNH",PNUM,num$(PTYP)) From GOBJET
When 9   # inventaire
    #MAE, bg 76607
    Gosub SET_NOL From STKINV
    GCONSULT = 2
    #Call OBJET("SNL",PNUM,num$(PTYP)) From GOBJET
    Call OBJET("SNL",PNUM,[M:SMJ2]VCRNUMORI(NOL)) From GOBJET
    GCONSULT = 0
When 10  # ordre de fabrication
    Call OBJET("MFG",PNUM,num$(PTYP)) From GOBJET
When 12  # suivi matiere
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 13  # retour client
    Call OBJET("SRH",PNUM,num$(PTYP)) From GOBJET
When 14  # commande achat
    Call OBJET("POH",PNUM,num$(PTYP)) From GOBJET
When 15  # declaration de production
    Call OBJET("MTK",PNUM,num$(PTYP)) From GOBJET
When 17  # facture achat
    Call OBJET("PIH",PNUM,num$(PTYP)) From GOBJET
When 18  # avoir vente
    Call OBJET("SIH",PNUM,num$(PTYP)) From GOBJET
When 19  # entrée diverse
    Call OBJET("SMR",PNUM,num$(PTYP)) From GOBJET
When 20  # sortie diverse
    Call OBJET("SMO",PNUM,num$(PTYP)) From GOBJET
When 26  # Réintégration stock (inactif)
    Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
When 28  # controle qualite
    Call OBJET("STQ",PNUM,num$(PTYP)) From GOBJET
When 29  # changement de stock
     If PTRS = 36
       # Issue X3-106909 - 2018-09-21 by MAE : tunnels opérations et affectations
       If find([F:SGH]MODOPELPN,1,2,3)
        Call OBJET("LPNOPE",PNUM,num$(PTYP)) From GOBJET
       Else
        Call OBJET("LPNAFF",PNUM,num$(PTYP)) From GOBJET
       Endif
       # End issue X3-106909
      Else
        Call OBJET("SCS",PNUM,num$(PTYP)) From GOBJET
      Endif
When 31  # assemblage
    Call OBJET("BBY",PNUM,num$(PTYP)) From GOBJET
When 32  # desassemblage
    Call OBJET("DBY",PNUM,num$(PTYP)) From GOBJET
When 33  # Demande de service
    Call OBJET("SRE",PNUM,num$(PTYP)) From GOBJET
When 35  # modification des lots
    #MAE, bg 77811 pas de tunnel sur modification de lot car on ne sait pas
    #quel objet utilisé : SMX ou SLM
    #Call OBJET("SLM",PNUM,num$(PTYP)) From GOBJET
When 36  # Ordre de sous-traitance
    Call OBJET("SCO",PNUM,num$(PTYP)) From GOBJET
Endcase
GCONSULT = 0

# hcb 78584 deb

  Filter [STJ]
  Case [M:SMJ1]SRTCOD
    When 1 :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By CREDAT; ITMREF
      For [STJ]
      If [F:STJ]CREDAT=WDAT &
&        [F:STJ]ITMREF=WITM &
&        [F:STJ]MVTSEQ=WSEQ &
&        [F:STJ]MVTIND=WIND
         Break
      Endif
      Next
    When Default :
      Filter [STJ] Where evalue(WFIL1) & evalue(WFILS) & evalue(WFILF) & evalue(WFILSPE)
&                  Order By IPTDAT; ITMREF
      For [STJ]
      If [F:STJ]IPTDAT=WDAT &
&        [F:STJ]ITMREF=WITM &
&        [F:STJ]MVTSEQ=WSEQ &
&        [F:STJ]MVTIND=WIND
         Break
      Endif
      Next
  Endcase
# hcb 78584 fin




End

