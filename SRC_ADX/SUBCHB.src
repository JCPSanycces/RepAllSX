#<AdxTL>@(#)7.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CHB",GBIDC1,GBIDC2) From GOBJET
End

# Issue 74384 - 2018-04-19 by MDJ : Changes to Checkbook not saved when tunneling from bank account

$ACTION
  Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "AFFMASK"     : Gosub AFFMASK   #*X3-74384
   When "LIENS"       : Gosub LIENS
   When "LIENS2"      : Gosub LIENS2
   When "RAZCRE"      : Gosub RAZCRE
   When "RAZDUP"      : Gosub RAZDUP
   When "VERIF_CRE"   : Gosub VERIF_CRE
   When "VERIF_MOD"   : Gosub VERIF_CRE
   When "CREATION"    : Gosub CREATION
   When "DEBUT_MOD"   : Gosub DEBUT_MOD
   When "APRES_CRE"   : Gosub APRES_CRE
   When "APRES_MOD"   : Gosub APRES_MOD
   When "VERF_ANU"    : Gosub VERF_ANU
   When "ANNULE"      : Gosub ANNULE
   When "FILTRE"      : Gosub FILTRE  # 90548.n
   When 'SETBOUT'     : Gosub SETBOUT # 90548.n
  Endcase

Return

####################################################################################
$OUVRE
Local Char    NUMCHE(15)
Local Char    PREV_NUMCHE(15)
Local Integer NOL, CHQ
Local Char    LBAN(5)      #*X3-74384

If !clalev([F:CHN])  : Local File CHQNUM      [CHN]  : Endif
If !clalev([F:BAN])  : Local File BANK        [BAN]  : Endif
If !clalev([F:CHB2]) : Local File CHQBOK      [CHB2] : Endif
If !clalev([F:FCY])  : Local File FACILITY    [FCY]  : Endif

#  *X3-74384 Tunnel from GESBAN
If TUNNEL and CLE1 <>""
  If dim([M:BAN0]BAN) >= 0
    LBAN   = num$([M:BAN0]BAN)
  Endif
Endif  #*X3-74384 End


Return
#*X3-74384 ###########################################################################
$AFFMASK

If TUNNEL
  [M:CHB1]BAN= LBAN : Diszo [M:CHB1]BAN
  Gosub LIENS
Endif

Return
####################################################################################
$RAZCRE
  If TUNNEL #*X3-74384
    [M:CHB1]BAN= LBAN : Diszo [M:CHB1]BAN
  Else
    Raz [M:CHB1]CHQFIRNUM,  [M:CHB1]NBRCHQ,  [M:CHB1]USE
    Raz [M:CHB1]OCHQFIRNUM, [M:CHB1]ONBRCHQ, [M:CHB1]FCY
  Endif
  Affzo [M:CHB1]

Return
##############################################################################
$RAZDUP
  #*X3-74384  Gosub RAZCRE
Return

#########################################################################
$VERIF_CRE

  # GRNA 06/10/2011
  Gosub CHB_VERIF From CHKLIB

Return
####################################################################################
$LIENS2

  # GRNA 20/06/2011
  Gosub CHB_LIENS2 From CHKLIB

Return
####################################################################################
$FILTRE
  #*X3-74384 MWA
  If TUNNEL & dim([M:BAN0]BAN)>0
    FILTSUP = "BAN = [M:BAN0]BAN"
  Endif  #*X3-74384 End

  #*X3-74384
  If  (GREP="M")  :   Return :   Endif

  # If GSTATUT= Refresh ==>  REP = "X" not to RAZ the screen if we come from GESBAN
#  If (GNAVIG(max(GPILNAV-1,1)) = "GESBAN")  and find( REPONSE, GSTARAF,GSTAEND, GSTAFIN )
#     REP="M"
#     Return
#   Endif  #*X3-74384 End

  # 90548.sn
#  Look [CHN]CHN0(1)=CLE1
#  #*X3-74384 MWA
#  #If fstat & dim([M:BAN0]BAN)>0
#  If fstat & dim([M:BAN0]BAN)>0 & GREP <> 'C'
#    GREP = 'C' : REP = 'C'
#    Raz [M:CHB1]
#    [M:CHB1]BAN = [M:BAN0]BAN
#    Affzo [M:CHB1]1-99
#    Diszo [M:CHB1]BAN   #*X3-74384
#    REPONSE = 91
#  Endif
  # 90548.en

Return
####################################################################################
$SETBOUT

  # 90548.sn
  If (BOUT="A") and (GNAVIG(max(GPILNAV-1,1)) = "GESBAN") # cancel from GESBAN
   ####Gosub FILTRE
  Endif
  # 90548.en

#   #*X3-74384
#  If TUNNEL
#    [M:CHB1]BAN=LBAN : Affzo[M:CHB1]BAN  : Diszo[M:CHB1]BAN
#  Endif  #*X3-74384 End

   #*X3-74384 MWA
  If TUNNEL
    Look [CHN]CHN0(1)=CLE1
    If !fstat & dim([M:BAN0]BAN)>0
      [M:CHB1]BAN=LBAN : Affzo[M:CHB1]BAN  : Diszo[M:CHB1]BAN
      Call VIREBOUT(CHAINE,"C") From GOBJET
    Endif
  Endif  #*X3-74384 End MWA

Return
####################################################################################
$LIENS

  NOL = nolign-1
  [M:CHB1]USE(NOL) = 0
  [M:CHB1]OCHQFIRNUM(NOL) = [M:CHB1]CHQFIRNUM(NOL)
  [M:CHB1]ONBRCHQ(NOL) = [M:CHB1]NBRCHQ(NOL)
  [L]PREV_NUMCHE = [M:CHB1]OCHQFIRNUM(NOL)

  For CHQ = 0 To [M:CHB1]NBRCHQ(NOL)-1
   If CHQ = 0
    NUMCHE = [M:CHB1]CHQFIRNUM(NOL)
   Else
    Call INCSERIE(NUMCHE,[L]PREV_NUMCHE,1) From CHKLIB
   Endif
   [L]PREV_NUMCHE = [L]NUMCHE
   Read [CHN]CHN0=[M:CHB1]BAN;NUMCHE
   If !fstat
    If find([F:CHN]STA,2,4,5)               # Issued, Posted, Cleared
     [M:CHB1]USE(NOL) = 1 : Break
    Elsif [F:CHN]STA=3 & [F:CHN]PAYNUM<>""  # Voided on payment
     [M:CHB1]USE(NOL) = 2 : Break
    Endif
   Endif
  Next

Return
####################################################################################
$CREATION

  NOL = nolign-1
  ## If the checkbook has not been used, clear the table and then recreate the checks
  If [M:CHB1]USE(NOL)=0 & [M:CHB1]CHQFIRNUM(NOL)<>""
   If !find(GREP,'C','D')
    [L]PREV_NUMCHE = [M:CHB1]OCHQFIRNUM(NOL)
    For CHQ = 0 To [M:CHB1]ONBRCHQ(NOL)-1
     If CHQ = 0
      [L]NUMCHE = [M:CHB1]OCHQFIRNUM(NOL)
     Else
      Call INCSERIE([L]NUMCHE,[L]PREV_NUMCHE,1) From CHKLIB
     Endif
     Delete [CHN] Where BAN=[M:CHB1]BAN & CHQNUM=NUMCHE
     If fstat=1
      GOK=-1 : GLOCK="$CHQNUM"-[M:CHB1]BAN-NUMCHE : Break
     Endif
     [L]PREV_NUMCHE = [L]NUMCHE
    Next
   Endif
   If GOK<1 : Return : Endif
   Gosub CRE_CHQNUM
   If GOK<1 : Return : Endif
  Endif
  If GOK<1 : Return : Endif

Return
####################################################################################
$CRE_CHQNUM

## Création des chèques dans la table CHQNUM
[L]PREV_NUMCHE = [M:CHB1]CHQFIRNUM(NOL)

  For CHQ = 0 To [M:CHB1]NBRCHQ(NOL)-1
    If CHQ = 0
      [L]NUMCHE = [M:CHB1]CHQFIRNUM(NOL)
    Else
      Call INCSERIE([L]NUMCHE,[L]PREV_NUMCHE,1) From CHKLIB
    Endif
    [F:CHN]BAN    = [M:CHB1]BAN
    [F:CHN]CHQNUM = [L]NUMCHE
    [F:CHN]STA    = 1
    [F:CHN]PAYNUM = ""
    [F:CHN]POSPAYSEQ = ""              #100595.n
    [F:CHN]POSPAYCREDAT = [00/00/00]   #100595.n
    [F:CHN]CREUSR = GUSER
    [F:CHN]CREDAT = date$
    [F:CHN]PRNFLG = 1
    [F:CHN]PRNDAT = [00/00/00]
    [F:CHN]CLODAT = [00/00/00]
    [L]PREV_NUMCHE = [L]NUMCHE
    Write [F:CHN]
    If fstat
      GOK=0 : Call FSTA("CHN") From GLOCK : Break
    Endif
   Next

If GOK<1 : Return : Endif

Return
####################################################################################
$DEBUT_MOD
  Gosub DEBUT_MOD From CHKLIB
Return
####################################################################################
$APRES_CRE
  Gosub APRES
Return
####################################################################################
$APRES_MOD
  Gosub APRES
Return
########################
$APRES

  For NOL=0 To [M:CHB1]NBBAN-1
   [M:CHB1]OCHQFIRNUM(NOL) =  [M:CHB1]CHQFIRNUM(NOL)
   [M:CHB1]ONBRCHQ(NOL)    =  [M:CHB1]NBRCHQ(NOL)
  Next

Return
####################################################################################
$VERF_ANU
  Gosub VERF_ANU From CHKLIB
Return
####################################################################################
$ANNULE
  Gosub ANNULE From CHKLIB
Return

####################################################################################
## Etiquettes su masque CHB1
####################################################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()

If clalev([F:BAN])=0  : Local File BANK    [BAN]  : Endif
Call LEC_BAN(VALEUR) From CPTLEC
[M]CPY = [F:BAN]CPY : [M]FCY = [F:BAN]FCY
Call CHB_C_BAN(VALEUR) From CHKLIB
Call C_FCY([F:BAN]FCY) From CONSSUB

End
######################################################################################
Subprog AS_CHQFIRNUM(VALEUR)
Variable Char VALEUR()
  Gosub ACCES_CHP
End
######################################################################################
Subprog AS_NBRCHQ(VALEUR)
Variable Decimal VALEUR
  Gosub ACCES_CHP
End
######################################################################################
$ACCES_CHP
# Only allow access to 'First check' and 'Number of checks' if the checkbook was not used
# (if all checks are in a checkbook with state 'Unissued')
If [M:CHB1]USE(nolign-1)<>0
  mkstat = 2 : Return
Endif
Return
######################################################################################
Subprog C_NBBAN
  Call CHB_C_NBBAN From CHKLIB
End
######################################################################################
Subprog AM_CHQFIRNUM(VALEUR)
Variable Char    VALEUR()
  Call CHB_AM_CHQFIRNUM(VALEUR) From CHKLIB

#  If (dim([M:BAN0]BAN)>0) Then
#    Look [CHN]CHN0(1)=[M:BAN0]BAN
#    #*X3-74384 MWA
#    If fstat
#      GREP = 'C' : REP = 'C'
#      REPONSE = 91
#    Endif
#  Endif

End
######################################################################################
Subprog AM_NBRCHQ(VALEUR)
Variable Decimal VALEUR
  Call CHB_AM_NBRCHQ(VALEUR) From CHKLIB
End
######################################################################################
Subprog C_NBRCHQ(VALEUR)
Variable Decimal VALEUR
  Call CHB_C_NBRCHQ(VALEUR) From CHKLIB  # 90545
End

