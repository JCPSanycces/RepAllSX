#<AdxTL>@(#)6.0.0.0 $Revision$
################################################################
# Création des deux premiers exercices et des périodes associées
################################################################
Subprog PERIODE
If GCRE

 Call ECR_TRACE(mess(114,125,1),0) From GESECRAN : # Création des premiers exercices et périodes

 Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]
 Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
 Local File =[F:ADS]DOSSIER+".FISCALYEAR" [FIY]
 Local File =[F:ADS]DOSSIER+".PERIOD"     [PER]

 Local Integer EXER  : # Exercice
 Local Integer PERIO : # Période
 Local Integer NBPER : # Compteur nombre de périodes créées
 Local Integer N

 Trbegin [FIY] , [PER]
 
 For [CPY] Where CPYLEGFLG=2 & [F:CPY]STRPER<>[0/0/0]

  Read [GCM]GCM0=[CPY]ACM
   
  # pour tous les types de référentiels
  For N=1 To len(mess(0,2644,1))
   If [F:GCM]LED(N-1)<>""
   
    NBPER=0
    For EXER=1 To 2
     Raz [FIY]   
     [F:FIY]CPY    = [F:CPY]CPY
     [F:FIY]LEDTYP = N
     [F:FIY]FIYNUM = EXER 
     [F:FIY]FIYSTR = addmonth([F:CPY]STRPER,NBPER)
     [F:FIY]FIYEND = addmonth([F:CPY]STRPER,NBPER+12)-1
     [F:FIY]FIYSTA = 1
     [F:FIY]CREDAT = date$
     [F:FIY]CREUSR = GUSER
     If [F:GCM]CFMAUT(N-1) = 2 : [F:FIY]LEDTYPAUT = 2 : Endif
     Write [FIY] 
     If fstat : Call ERREUR("FISCALYEAR",1) From DOSDIC : Endif
     For PERIO=1 To 12
      Raz [PER]
      [F:PER]CPY    = [F:CPY]CPY
      [F:PER]LEDTYP = N
      [F:PER]FIYNUM = EXER
      [F:PER]PERNUM = PERIO
      [F:PER]PERSTA = 1
      [F:PER]PERSTOSTA = 1
      [F:PER]PERSTR = addmonth([F:CPY]STRPER,NBPER)
      [F:PER]PEREND = addmonth([F:CPY]STRPER,NBPER+1)-1
      [F:PER]LEDTYPAUT  = [F:FIY]LEDTYPAUT
      Write [PER]
      If fstat : Call ERREUR("PERIOD",1) From DOSDIC : Endif
      NBPER += 1
     Next PERIO
    Next EXER
   Endif
  Next N
 Next CPY
Commit

## Etat des journaux si on a la compta


Endif
End

