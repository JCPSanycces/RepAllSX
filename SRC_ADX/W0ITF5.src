#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITF5 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone MFGROU
mkstat = 0
zoncou = "MFGROU"
indice = 0
If varmode([M]MFGROU,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_MFGROU([M]MFGROU) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]MFGROU : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "MFGROU" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_MFGROU([M]MFGROU) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MFGROU" : GZNUM = 5007 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone MFGROUALT
mkstat = 0
zoncou = "MFGROUALT"
indice = 0
If varmode([M]MFGROUALT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_MFGROUALT([M]MFGROUALT) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]MFGROUALT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "MFGROUALT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]MFGROUALT<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "MFGROUALT" : GZNUM = 3964 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("TRO","!A",[M]MFGROUALT,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "MFGROUALT" : GZNUM = 3964 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_MFGROUALT([M]MFGROUALT) From SUBITF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "MFGROUALT" : GZNUM = 3964 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone CSTROU
mkstat = 0
zoncou = "CSTROU"
indice = 0
If varmode([M]CSTROU,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CSTROU([M]CSTROU) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CSTROU : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CSTROU" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CSTROU([M]CSTROU) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CSTROU" : GZNUM = 5010 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CSTROUALT
mkstat = 0
zoncou = "CSTROUALT"
indice = 0
If varmode([M]CSTROUALT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CSTROUALT([M]CSTROUALT) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CSTROUALT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CSTROUALT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]CSTROUALT<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CSTROUALT" : GZNUM = 3964 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("TRO","!B",[M]CSTROUALT,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CSTROUALT" : GZNUM = 3964 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CSTROUALT([M]CSTROUALT) From SUBITF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CSTROUALT" : GZNUM = 3964 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone RCCROU
mkstat = 0
zoncou = "RCCROU"
indice = 0
If varmode([M]RCCROU,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RCCROU([M]RCCROU) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]RCCROU : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "RCCROU" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_RCCROU([M]RCCROU) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RCCROU" : GZNUM = 5877 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone RCCROUALT
mkstat = 0
zoncou = "RCCROUALT"
indice = 0
If varmode([M]RCCROUALT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RCCROUALT([M]RCCROUALT) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]RCCROUALT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "RCCROUALT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]RCCROUALT<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "RCCROUALT" : GZNUM = 3964 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("TRO","!C",[M]RCCROUALT,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "RCCROUALT" : GZNUM = 3964 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_RCCROUALT([M]RCCROUALT) From SUBITF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "RCCROUALT" : GZNUM = 3964 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone MFGSHTCOD
mkstat = 0
zoncou = "MFGSHTCOD"
indice = 0
IMPENT = [M]MFGSHTCOD
If varinit([M]MFGSHTCOD,indice)=0
 IMPENT = 2
Endif
If varmode([M]MFGSHTCOD,indice)=0
 [M]MFGSHTCOD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MFGSHTCOD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MFGSHTCOD(indice)
 Endif
Endif
[M]MFGSHTCOD = IMPENT

## Zone CLEPCTAUT
mkstat = 0
zoncou = "CLEPCTAUT"
indice = 0
If varinit([M]CLEPCTAUT,indice)=0
 [M]CLEPCTAUT = 100
Endif
If varmode([M]CLEPCTAUT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLEPCTAUT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RELSCATIA
mkstat = 0
zoncou = "RELSCATIA"
indice = 0
IMPENT = [M]RELSCATIA
If varinit([M]RELSCATIA,indice)=0
 IMPENT = 2
Endif
If varmode([M]RELSCATIA,indice)=0
 [M]RELSCATIA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RELSCATIA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RELSCATIA(indice)
 Endif
Endif
[M]RELSCATIA = IMPENT

## Zone COMSEQCON
mkstat = 0
zoncou = "COMSEQCON"
indice = 0
IMPENT = [M]COMSEQCON
If varinit([M]COMSEQCON,indice)=0
 IMPENT = 1
Endif
If varmode([M]COMSEQCON,indice)=0
 [M]COMSEQCON(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "COMSEQCON" : Gosub ACTION From =IMPTRT
  IMPENT = [M]COMSEQCON(indice)
 Endif
Endif
[M]COMSEQCON = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone WGRACS
mkstat = 0
zoncou = "WGRACS"
indice = 0
If varmode([M]WGRACS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WGRACS" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("ACS","!",[M]WGRACS,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "WGRACS" : GZNUM = 729 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTACC"
  Call CONTACC([M]WGRACS) From SUBACS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WGRACS" : GZNUM = 729 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ISM
mkstat = 0
zoncou = "ISM"
indice = 0
If varmode([M]ISM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ISM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("HSH","!",[M]ISM,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ISM" : GZNUM = 54717 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone REDMODFLG
mkstat = 0
zoncou = "REDMODFLG"
indice = 0
IMPENT = [M]REDMODFLG
If varinit([M]REDMODFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]REDMODFLG,indice)=0
 [M]REDMODFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "REDMODFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]REDMODFLG(indice)
 Endif
Endif
[M]REDMODFLG = IMPENT

## Zone ITMTOLPOS
mkstat = 0
zoncou = "ITMTOLPOS"
indice = 0
WNUM = [M]ITMTOLPOS
If varmode([M]ITMTOLPOS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMTOLPOS" : Gosub ACTION From =IMPTRT
 Endif
 If [M]ITMTOLPOS<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ITMTOLPOS" : GZNUM = 42018 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]ITMTOLPOS or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_ITMTOLPOS([M]ITMTOLPOS) From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ITMTOLPOS" : GZNUM = 42018 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ITMTOLNEG
mkstat = 0
zoncou = "ITMTOLNEG"
indice = 0
WNUM = [M]ITMTOLNEG
If varmode([M]ITMTOLNEG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ITMTOLNEG" : Gosub ACTION From =IMPTRT
 Endif
 If [M]ITMTOLNEG<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ITMTOLNEG" : GZNUM = 42020 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ITMTOLNEG([M]ITMTOLNEG) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ITMTOLNEG" : GZNUM = 42020 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]ITMTOLNEG or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_ITMTOLNEG([M]ITMTOLNEG) From SUBITF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ITMTOLNEG" : GZNUM = 42020 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITF5"
Return

