#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMSNP0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
WCHAR = [M]OPPNUM
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPPNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","A",[M]OPPNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]OPPNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPPNUM([M]OPPNUM) From SUBPJMSNP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 41532 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone SNPCOD
mkstat = 0
zoncou = "SNPCOD"
indice = 0
If varmode([M]SNPCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SNPCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DESAXX
mkstat = 0
zoncou = "DESAXX"
indice = 0
If varinit([M]DESAXX,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESAXX,"PJMSNPH","DESAXX",[M:PSNP0]SNPCOD,"") From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESAXX,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESAXX" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESAXX,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESAXX" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone SHOWGRP
mkstat = 0
zoncou = "SHOWGRP"
indice = 0
If varinit([M]SHOWGRP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SHOWGRP,"388","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SHOWGRP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SHOWGRP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]SHOWGRP,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]SHOWGRP,"388","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]SHOWGRP,"388",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "SHOWGRP" : GZNUM = 54294 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone UOM
mkstat = 0
zoncou = "UOM"
indice = 0
If varmode([M]UOM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UOM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]UOM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "UOM" : GZNUM = 2685 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TUN","",[M]UOM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "UOM" : GZNUM = 2685 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone CUR
mkstat = 0
zoncou = "CUR"
indice = 0
If varmode([M]CUR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CUR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CUR,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CUR" : GZNUM = 323 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TCU","",[M]CUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CUR" : GZNUM = 323 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMSNP0"
Return

