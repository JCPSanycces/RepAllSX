#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Call OBJET("ASE",GBIDC1,GBIDC2) From GOBJET
End

#--------------------------------------------------------------------------------------------#
# Actions standards
#--------------------------------------------------------------------------------------------#
$ACTION_STD
Case ACTION
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "AB_MODIF"     : Gosub AB_MODIF

 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "AB_CREATION"  : Gosub AB_CREATION

 When "DROIT"        : Gosub DROIT
 When "LIENS"        : Gosub LIENS

 When "VERF_ANU"      : Gosub VERF_ANU
 When "AV_ANNULE"     : Gosub AV_ANNULE
 When "ANNULE"        : Gosub ANNULE
 When "AP_ANNULE"     : Gosub AP_ANNULE
 When "APRES_ANNULE"  : Gosub APRES_ANNULE

Endcase
Return
#--------------------------------------------------------------------------------------------#

#--------------------------------------------------------------------------------------------#
# Création
#--------------------------------------------------------------------------------------------#
$VERIF_CRE
OK = 1
GCRUD = "C"
Gosub ACTION
If !OK : GOK=0 : Return : Endif

If [L]ABREV="" : Return : Endif : # Modele de données sans Objet

Gosub DEFVAR
Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub AFFECT
Gosub CONT_AUTORIS
If ERRMES<>"" : OK = 0 : GOK=0 : Goto SORT_ERR : Endif

Gosub VERIF
If GOK<1  : Goto SORT_ERR : Endif

Goto SORT

$INICRE
GOK = 1
If ABREV<>""
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 Gosub INICRE From GOBJSUB
 If OPTENA & !AUTENA & dim([F]ENAFLG)>0 & [F]ENAFLG<>1
  [F]ENAFLG = 1
 Endif
Endif
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
If ABREV="" Goto SORT : Endif
Gosub VERIF_ROLE
Goto SORT

$CREATION
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
If ABREV= "": Goto SORT : Endif
Gosub DEFVAR
Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub SETCLE From ="WO"+ABREV
Gosub SET_CLE From GOBJSUB
Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
Call WRKGLOB(170,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
Call WORKPLUS(2,ABREV,"C",IDENT,"",0,1,0,GRPDEB) From AWRK
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$APRES_CRE
If GOK>=1
 Gosub ACTION
 If GOK<1 : Goto SORT_ERR : Endif
 If ABREV= "": Goto SORT : Endif
 Call ESPION(NOMFIC,1,IDENT,"") From ESPION
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
Else
 If ABREV= "": Goto SORT : Endif
 If GRPDEB<>""
  Call VIRE_GROUPE(GRPDEB) From AWRK
  GOK = 0
 Endif
Endif
Goto SORT

$AB_CREATION
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

#--------------------------------------------------------------------------------------------#
# Modification
#--------------------------------------------------------------------------------------------#
$VERIF_MOD
OK = 1
GOK  = 1
GCRUD = "U"
Gosub ACTION
If !OK : GOK=0 : Return : Endif

If [L]ABREV="" : Return : Endif : # Modele de données sans Objet

Gosub DEFVAR
Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub AFFECT
Gosub CONT_AUTORIS
If ERRMES<>"" : OK = 0 : GOK=0 : Goto SORT_ERR : Endif

Goto SORT

$INIMOD
GOK  = 1
If ABREV<>""
 Gosub DEFAUT From =PROGOBJ
 Gosub INIMOD From GOBJSUB
Endif
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
If ABREV= "": Goto SORT : Endif
Gosub VERIF_ROLE
Goto SORT

$MODIF
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
If ABREV= "": Goto SORT : Endif
Gosub DEFVAR
Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub SET_CLE From GOBJSUB
Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,2,GRPDEB) From AWRK
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$APRES_MOD
If GOK>=1
 Gosub ACTION
 If GOK<1 : Goto SORT_ERR : Endif
 If ABREV= "": Goto SORT : Endif
 Call ESPION(NOMFIC,1,IDENT,"") From ESPION
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
Else
 If ABREV= "": Goto SORT : Endif
 If GRPDEB<>""
  Call VIRE_GROUPE(GRPDEB) From AWRK
  GOK = 0
 Endif
Endif
Goto SORT

$AB_MODIF
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

#--------------------------------------------------------------------------------------------#
# Annulation
#--------------------------------------------------------------------------------------------#
$VERF_ANU
OK   = 1
GOK  = 1
GCRUD = "D"
Gosub ACTION
If !OK : GOK=0 : Return : Endif

If [L]ABREV="" : Return : Endif : # Modele de données sans Objet

Gosub DEFVAR
Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub AFFECT
Gosub CONT_AUTORIS
If ERRMES<>"" : OK = 0 : Goto SORT_ERR : Endif

Gosub SET_CLE
Call VERIF_STR(nomap,"-"+ABREV,CLECUR1,CLECUR2,CODTRT,TYPTRT,OK) From ANUCOD
If !OK : Goto SORT_ERR : Endif

Gosub VERIF_ROLE

OK = 1
Goto SORT

$AV_ANNULE
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$ANNULE
OK = 1
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
If [L]ABREV="" : Return : Endif : # Modele de données sans Objet

Gosub SET_CLE
Call ANNU_STR(nomap,"-"+ABREV,CLECUR1,CLECUR2,CODTRT,TYPTRT) From ANUCOD
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$AP_ANNULE
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$APRES_ANNULE
Gosub ACTION
If GOK<1 : Goto SORT_ERR : Endif
Goto SORT

$SORT_ERR
GMESSAGE = ERRMES
$SORT
If [L]ABREV="" : Return : Endif : # Modele de données sans Objet
GREP       = SAVGREP
GGRPFCY    = SAVGGRPFCY
GSOCIETE   = SAVSOCIETE
GCURLEG    = SAVCURLEG
GCURFCY    = SAVCURFCY
GCHAINE    = SAVGCHAINE
GOBJET     = SAVOBJET
GABREV     = SAVABR
GTRAITE    = SAVTRAITE
GFONCTION  = SAVFONC
GFONC1     = SAVFONC1
GPROGRAMME = SAVPROG
GFCYDEF(0) = SAVFCYDEF
GLOCALDEV  = SAVLOCALDEV
If GPRODUIT=1 : ## GEODE
 GDEP = SAVDEP
 GFCY =SAVFCY
Endif
Return

#--------------------------------------------------------------------------------------------#
# Lecture
#--------------------------------------------------------------------------------------------#
$DROIT
OK = 1
GCRUD= "R"
Gosub ACTION
If !OK : Return : Endif

If [L]ABREV="" : Return : Endif : # Modele de données sans Objet

Gosub DEFVAR

GOK = 1

Gosub OUVOBJ
Gosub SAV_CONTEXTE
Gosub AFFECT
Gosub CONT_AUTORIS
If ERRMES<>"" : OK = 0 : Goto SORT_ERR : Endif

Gosub VERIF
If GOK<1  : OK =0 :  Goto SORT_ERR : Endif

Gosub VERIF_ROLE
Goto SORT

$LIENS
OK = 1
Gosub ACTION
If !OK : Return : Endif
Return

$RIEN
ER = errn
Resume

#--------------------------------------------------------------------------------------------#
# Etiquettes Divers
#--------------------------------------------------------------------------------------------#
$VERIF
If func ARECAUO.APPDEM(nomap)                    : # Dossier démo
 MAXFICHE = 0
 If PROGOBJ<>"WO"+ABREV
  PROGOBJ = "WO"+ABREV
 Endif
 Gosub NOMFIC From =PROGOBJ
 Gosub SETCLE From =PROGOBJ
 Local File ATABLE [ATBB]
 Read [ATBB]CODFIC=NOMFIC
 If fstat or [F:ATBB]MODULE<>1                   : # Pas de limite sur les tables superviseur
  If A_STRSITE<>""
   MAXFICHE = 20000                              : # Limite nombre de fiches mouvements
  Elsif dim(CLESEC)>0 & CLESEC<>""
   MAXFICHE = 10000                              : # Limite nombre de fiches avec clés plus de 2 parties
  Else
   MAXFICHE = 1000                               : # Limite nombre de fiches pour les autres
  Endif
 Endif
 Close Local File [ATBB]
 Gosub DEFAUT From =PROGOBJ
 If MAXFICHE<>0 & nbrecord([F])>=MAXFICHE
  ERRMES = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE)  : # Dossier de démonstration\Nb maximum de fiches
  GERRNUM  = 1
  STA      = 2
  ZON      = "$VERIF"
  GOK = 0 : Goto SORT_ERR
 Endif
Endif

Case GPRODUIT
 When 0 : # X3
  MAXFICHE = 0
  If PROGOBJ<>"WO"+ABREV
   PROGOBJ = "WO"+ABREV                           : # Faudrait peut être planter...
  Endif
  Gosub NOMFIC From =PROGOBJ                      : # Pour les petits malins
  If find(NOMFIC,"FIXASSET")
   Case NOMFIC
    When "FIXASSET"
     #Call NOMBRE(1,MAXFICHE) From GLOCK           : # No à préciser
     #87108
     Local Char VALMAX(30)
     If fmet GACTX.AGETLICPAR("MAXFIXEDASSETS",VALMAX)=[V]CST_ATRUE
      MAXFICHE=val(VALMAX)
     Endif
   Endcase
   Gosub DEFAUT From =PROGOBJ                     : # Pour les gros malins
   If MAXFICHE<>0 & nbrecord([F])>=MAXFICHE
    ERRMES = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE) : # Dossier de démonstration\Nb maximum de fiches
    GERRNUM  = 1
    STA      = 2
    ZON      = "$VERIF"
    GOK = 0  : Goto SORT_ERR
   Endif
  Endif

 When 1 : # Géode
  MAXFICHE = -1
  If PROGOBJ<>"WO"+ABREV
   PROGOBJ = "WO"+ABREV
  Endif
  Gosub NOMFIC From =PROGOBJ
  Case NOMFIC
   When "FACILITY"
    #Call NOMBRE(2,MAXFICHE) From GLOCK
    #87108
    Local Char VALMAX(30)
    If fmet GACTX.AGETLICPAR("MAX"+NOMFIC,VALMAX)=[V]CST_ATRUE
     MAXFICHE=val(VALMAX)
    Endif
   When "DEPOSITOR"
    Read [DEP]DEP0 = [V]GFCY;[L]NEWCLE1
    If fstat
     #Call NOMBRE(3,MAXFICHE) From GLOCK
     #87108
     Local Char VALMAX(30)
     If fmet GACTX.AGETLICPAR("MAX"+NOMFIC,VALMAX)=[V]CST_ATRUE
      MAXFICHE=val(VALMAX)
     Endif
    Endif
  Endcase
  If MAXFICHE>0
   Gosub DEFAUT From =PROGOBJ
   If nbrecord([F])>=MAXFICHE
    ERRMES = mess(205,125,1)+"\"+mess(143,126,1)-":"-num$(MAXFICHE) : # Dossier de démonstration\Nb maximum de fiches
    GERRNUM  = 1
    STA      = 2
    ZON      = "$VERIF"
    GOK = 0 : Goto SORT_ERR
   Endif
  Endif
Endcase
Return

##########################
# Fichiers qui doivent être ouverts en permanence par GOBJET
$OUVOBJ
If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
If clalev([F:ALS])=0 : Local File ALSTRD   [ALS] : Endif
If clalev([F:AWI])=0 : Local File AWINDOW  [AWI] : Endif
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
Gosub DEFAUT From =PROGOBJ
Return

##########################
$SET_AUTOR
Raz CRE, MODI, SUPPR, AUTENA, ERRMES
If GUSRACS<>2 & dim([L]A_STRACC)>0 & [L]A_STRACC<>""
 Read [ACC]CODACC = GUSER;[L]A_STRACC
 If [F:ACC]MODIF<>2
  ERRMES = mess(38,134,1) : # Niveau d'accès insuffisant
  GERRNUM  = 2
  STA      = 2
  ZON      = "$SET_AUTOR"
  Return
 Endif
Endif

If GGRPFCY<>"" & dim([L]A_STRSITE)>0 & [L]A_STRSITE <>""
 Look [FGR]FGR0 = GGRPFCY;[L]A_STRSITE
 If fstat
  ERRMES = GGRPFCY-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
  GERRNUM  = 3
  STA      = 2
  ZON      = "$SET_AUTOR"
  Return
 Endif
Endif

If GUSRFCY(1)="\" or ABREV="FCY" : # Pour les fonctions sans autorisations site et l'objet FCY
 CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
 MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
 SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
 AUTENA = (instr(1,GUSRAUZ(1),"N")<>0)
Elsif dim([L]CLEVALEUR)>0 : ## GEODE
 ISITE = find(GFCY,GUSRFCY(1..GNBAUZ))
 If ISITE<>0
  CRE   = (instr(1,GUSRAUZ(ISITE),"C")<>0)
  MODI  = (instr(1,GUSRAUZ(ISITE),"M")<>0)
  SUPPR = (instr(1,GUSRAUZ(ISITE),"S")<>0)
  AUTENA = (instr(1,GUSRAUZ(ISITE),"N")<>0)
 Endif
Elsif dim([L]A_STRSITE)<=0 | (dim([L]A_STRSITE)>0 & [L]A_STRSITE="")
 CRE   = 1
 MODI  = 1
 SUPPR = 1
 AUTENA = 1
Elsif dim([L]A_STRSITE)>0 & [L]A_STRSITE<>""
 ISITE = find([L]A_STRSITE,GUSRFCY(1..GNBAUZ))
 If ISITE<>0
  CRE   = (instr(1,GUSRAUZ(ISITE),"C")<>0)
  MODI  = (instr(1,GUSRAUZ(ISITE),"M")<>0)
  SUPPR = (instr(1,GUSRAUZ(ISITE),"S")<>0)
  AUTENA = (instr(1,GUSRAUZ(ISITE),"N")<>0)
 Endif
Endif

If !CRE | !MODI | !SUPPR
 If GUSRFCY(1)="\"
  ERRMES = mess(38,134,1) : # Niveau d'accès insuffisant
  GERRNUM  = 2
  STA      = 2
  ZON      = "$SET_AUTOR"
 Elsif dim([L]CLEVALEUR)>0 : ## GEODE
  ERRMES = GFCY-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
  GERRNUM  = 3
  STA      = 2
  ZON      = "$SET_AUTOR"
 Else
  ERRMES = [L]A_STRSITE-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
  GERRNUM  = 3
  STA      = 2
  ZON      = "$SET_AUTOR"
 Endif
Endif
Return

$AUTORIS
Call AUTORIS From EXEFNC
Local Integer CRE, MODI, SUPPR, AUTENA,STA
Local Char    ZON(250),ERRMES(250)
If GNBAUZ=0
 If GNBSITE=0
  ERRMES   = mess(33,104,1) : # Vous devez d'abord créer un site dans le dossier
  GERRNUM  = 3
  STA      = 2
  ZON      = "$AUTORIS"
  Goto SORT_ERR
 Else
  ERRMES   = GFONCTION-":"-mess(1,123,1) : # Fonction non autorisée
  GERRNUM  = 3
  STA      = 2
  ZON      = "$AUTORIS"
  Goto SORT_ERR
 Endif
Elsif GUSRFCY(1)="\"
 CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
 MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
 SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
 AUTENA = (instr(1,GUSRAUZ(1),"N")<>0)
Endif
Return

########################## Sauvegarde du contexte
$SAV_CONTEXTE
SAVFONC      = GFONCTION
SAVFONC1     = GFONC1
SAVOBJET     = GOBJET
SAVABR       = GABREV
SAVPROG      = GPROGRAMME
SAVGREP      = GREP
SAVGGRPFCY   = GGRPFCY
SAVGCHAINE   = GCHAINE
SAVFCYDEF    = GFCYDEF(0)
SAVSOCIETE   = GSOCIETE
SAVCURLEG    = GCURLEG
SAVCURFCY    = GCURFCY
SAVLOCALDEV  = GLOCALDEV
If GPRODUIT=1 : ## GEODE
 SAVDEP       = GDEP
 SAVFCY       = GFCY
Endif
Return

##########################
$CONT_AUTORIS
## Controle autorisation
Call CONT_ENA(NOMFIC,OPTENA)
Call AUTORIS From EXEFNC
Gosub SET_AUTOR
If ERRMES<>"" : Goto SORT_ERR : Endif
Gosub FIL_ROLE From GOBJSUB
Return

##########################
$AFFECT
# Affect variables globales
GOBJET     = 1
GABREV     = ABREV
GTRAITE    = "GOBJET"
GFONCTION  = "GES"+ABREV
Return

##########################
$DEFVAR
Local Integer MAXFICHE,CRE, MODI, SUPPR, AUTENA,OPTENA
Local Char    PROGOBJ(GLONADC),ERRMES(250),SAVFONC(GLONAFC)
Local Char    FILROLE(250)(0..5)
Local Integer IFILROLE,ER
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..16)
Local Char    IDENT(GLONID) , NOMINT(GLONAVA) , GRPDEB(GLONVCR)

Local Integer SAVOBJET , SAVMXL
Local Char    SAVABR(GLONAOB) , SAVLOCALDEV(GLONCUR)
Local Char    SAVTRAITE(GLONADC), SAVFONC(GLONAFC), SAVFCYDEF(GLONFCY), SAVPROG(GLONADC) , OGFONCTION(GLONAFC)
Local Char    SAVBOITE(GLONFEN), SAVGFLAG(10) , OGFLAG(10) , SAVFONC1(GLONAFC)  , SAVGREP(1)

Local Char    NOMFIC(GLONATB)

PROGOBJ  = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ
Gosub ESPION From =PROGOBJ
Return

##########################
$VERIF_ROLE
# Vérification du rôle
Onerrgo RIEN
ER = 0
OK = evalue(FILROLE)
Onerrgo
If !ER & !OK
 ERRMES = mess(97,126,1) : # Vous n'avez pas les droits pour créer cette fiche
 GERRNUM  = 4
 STA      = 2
 ZON      = "$VERIF_ROLE"
 Goto SORT_ERR
Endif
Return

##########################
Subprog CONT_ENA(NOMFIC,OPTENA)
Value    Char    NOMFIC
Variable Integer OPTENA
Local File =NOMFIC [NF__]
OPTENA = (dim([F:NF__]ENAFLG)>0)
Close Local File [NF__]
End

##########################
$SET_CLE
CLECUR1 = num$(evalue("[F:A___]"+CLEPRIM))
For CL=0 To dim(CLESEC)-1
 If CLESEC(CL)<>""
  CLECUR2(CL) = num$(evalue("[F:A___]"+CLESEC(CL)))
 Endif
Next CL
Return


#--------------------------------------------------------------------------------------------#
# Etiquette appelée depuis les traitements WML
#--------------------------------------------------------------------------------------------#
Funprog ERREUR(TABLE,COD)
Value Char    TABLE
Value Integer COD
Local Char MESSAGE(250)
Case COD
 When 1 : MESSAGE = mess(26,125,1)-TABLE : #-num$(fstat) : # Erreur d'écriture
 When 2 : MESSAGE = mess(27,125,1)-TABLE : #-num$(fstat) : # Erreur de réécriture
 When 3 : MESSAGE = mess(28,125,1)-TABLE : #-num$(fstat) : # Erreur d'effacement
 When 4 : MESSAGE = mess(49,125,1)-TABLE : #-num$(fstat) : # Erreur de lecture
 When 5 : MESSAGE = mess(58,134,1)-TABLE : #-num$(fstat) : # Erreur de verrouillage
Endcase
End MESSAGE

#--------------------------------------------------------------------------------------------#
# Etiquette appelée depuis les traitements structures *.stc
#--------------------------------------------------------------------------------------------#

$ACTION
GPE = 0
GPV = 0
GPS = 0
Local Integer AI , ATRT
For AI=1 To dim([L]CODTRT)
 If [L]CODTRT(AI)<>""
  Call EXISTE_ADX("","",[L]CODTRT(AI),ATRT) From ORDSYS
  If ATRT
   Case [L]TYPTRT(AI)
    When 1 : If !GPE  : Gosub ACTION From =[L]CODTRT(AI) : Endif : # Standard
    When 2 : If !GPV  : Gosub ACTION From =[L]CODTRT(AI) : Endif : # Vertical
    When 3 : If !GPS  : Gosub ACTION From =[L]CODTRT(AI) : Endif : # Spécifique
   Endcase
  Endif
 Endif
Next AI
Return

#--------------------------------------------------------------------------------------------#
# Sous-programme appelé depuis les traitements structures *.stc
#--------------------------------------------------------------------------------------------#

Subprog AERROR(AERROR,STA,ZON)
Variable Instance AERROR(1..) Using AERROR
Value Integer   STA
Value Char      ZON

Local Integer AI

AI = maxtab(AERROR)+1

AERROR(AI) = NewInstance AERROR AllocGroup AERROR(1)
AERROR(AI).MES = GMESSAGE
AERROR(AI).NUM = GERRNUM
AERROR(AI).STA = STA
AERROR(AI).FLD = ZON

End

