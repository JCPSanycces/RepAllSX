##################################################
## Tunnel Type de commande
# FGR 13/11/2012 : X3SUIVI71937
Subprog TUNTSO(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Local Integer TOKILL

  TOKILL = 0
  If dim(VCOD) < 1 Then
    Global Char VCOD(GLONTSO)

    TOKILL = 1
  Endif
  If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
  VCOD = COD
  If GNBLEG = 1 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then
    LEG = GCURLEG
  #--If LEG="" then firstly we search a TRE record with LEG="" secondly a TRE record with TRE<>""
  Elsif LEG = "" Then
    Read [TSO]TSO0=VCOD;[L]LEG
    If fstat Then
      Read [TSO]TSO0(1)=VCOD
      If !fstat Then
        LEG = [F:TSO]LEG
      Endif
    Endif
  Endif
  Read [TSO]TSO0=[L]COD;[L]LEG
  If fstat Then
    LEG = ""
  Endif
  Call OBJET("TSO",LEG,VCOD) From GOBJET
  COD = VCOD
  If TOKILL Then
    Kill VCOD
  Endif
End

#Subprog TUNTSO(COD,LEG)
#Variable Char    COD()
#Value    Char    LEG()
#
#Global Char VCOD(GLONTSO)
#Local Char  VLEG(GLONADI)
#
#  # To update the TSO code after the tunnel order
#  VCOD = COD
#  VLEG = LEG
#  If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
#  If func AFNC.ACTIV("LEG")=0 : VLEG = GDOSLEG : Endif
#
#  #-- X3suivi 71937 - T249 : Multi-Leg--#
#  Read [TSO]TSO0 = VCOD;VLEG      : #-- Lecture sans héritage Multi-Leg
#  If fstat : VLEG = "" : Endif
#
#  Call OBJET("TSO",VLEG,VCOD) From GOBJET
#  COD = VCOD
#  Kill VCOD
#End

############################################################
# FGR 13/11/2012 : X3SUIVI71937
$SELTSOLEG2
Local Char FCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char LEG(GLONADI)
Local Char GRP(GLONAGC)
Local Char STYPSEL(GLONDES)
Local Integer WNOL
Local Integer ERR
Local Integer I
Local Char SZVIEW(GLONAVW)
Local Char CODMSK(GLONAMK)
Local Char CHAMPCOD(GLONAVA)
  If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
  #--------------------------------------------------------------------------------------------------
  If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
  If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
  If clalev([F:AMZZ])=0: Local File AMSKZON   [AMZZ] : Endif
  If clalev([F:AGF])=0 : Local File AGRPFCY   [AGF] : Endif
  #--------------------------------------------------------------------------------------------------
  #--98275 On lit le AMZZ trop tôt
  #--On charge les options définies sur le type de données du champ du masque
  #OPTIONS = ""
  #If CODMSK <> ""  and CHAMPCOD <> "" Then
  #  Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
  #  If fstat = 0 Then
  #    OPTIONS = [F:AMZZ]OPTOBJ
  #  Endif
  #Endif
  #--------------------------------------------------------------------------------------------------

  If GFONCTION = "GESTSO" Then
    # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
    OBJET = "TSO"
    Return
  Endif
  #--------------------------------------------------------------------------------------------------
  # Récupération des paramètres
  #--------------------------------------------------------------------------------------------------
  LEG     = PARAM(1)
  FCY     = PARAM(2)
  GRP     = PARAM(3)
  CPY     = PARAM(4)
  STYPSEL = PARAM(5)  # 1   =Normale ou Facturation directe ou Prêt
                      # a1  =Normale
                      # a2  =Facturation directe
                      # a3  =Pret
                      # 2   =Commande ouverte
                      # a4  =Commande ouverte      "2" et "a4" ramène la même liste
                      # bnm =n,m permet d'indiquer les valeurs qu'on accepte b12 b123 b24...
                      # Tout autre valeur : liste entière
  CODMSK   = PARAM(6)
  CHAMPCOD = PARAM(7)
  #--------------------------------------------------------------------------------------------------
  #--98275 On lit le AMZZ trop tôt
  #--On charge les options définies sur le type de données du champ du masque
  If GFONCTION <> "ADPVAL" and GFONCTION <> "GESAUS" Then                            # FGR 20/02/2015 : X3SUIVI104383
    OPTIONS = ""
    If CODMSK <> ""  and CHAMPCOD <> "" Then
      Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
      If fstat = 0 Then
        OPTIONS = [F:AMZZ]OPTOBJ
      Endif
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  # Initialisation de législation
  If func AFNC.ACTIV("LEG")=0
    [L]LEG = GDOSLEG
  Endif

  If [L]LEG = "" Then
    If [L]FCY <> "" Then
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY <> "" Then
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG = "" Then
    [L]LEG = GCURLEG
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Position et taille de la fenêtre
  #--------------------------------------------------------------------------------------------------
  Gosub OUVRE_LISTE From WOTSO
  For I = 1 To NBSEL
    If SELEXP(I) <> "" Then
      COL(I) = SELEXP(I)
    Else
      COL(I) = SELZON(I)
    Endif
    TIT(I) = SELLIB(I)
    If left$(SELFMT(I),2)="LA"
      COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
    Endif
  Next I
  NBCOL   = NBSEL
  SIZCOL  = 260
  SIZLIG  = 100
  TIT(0)  = mess(12,123,1)  # Choix
  Call TITOBJ("TSO", "", TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START   = "[F:TSO]SOHTYP"
  ORDRE   = "[F:TSO]SOHTYP;[F:TSO]LEG"
  OBJET   = ""
  #--------------------------------------------------------------------------------------------------
  ## Critères pour la sélection standard
  #--------------------------------------------------------------------------------------------------
  # --------------------------------------
  ICRITERE = 1
  CRITERE(ICRITERE) = '1=1'
  #--CPO 71937 Ca c'est le bon !
  #--Groupe de soc/sites
  If FCY="" & CPY="" & GRP<>""
    Read [F:AGF]AGF0=[L]GRP
    If !fstat
     If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
    Endif
  Endif

  If [L]FCY <> "" Then
    #--Site
    CRITERE(ICRITERE) -= '& ([F:TSO]GFY="" | ([F:TSO]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
  Elsif [L]CPY <> "" Then
    #--Société
    CRITERE(ICRITERE) -= '& ([F:TSO]GFY="" | ([F:TSO]GFY<>"" & [F:TSOC]LEGCPY="'+[L]CPY+'"))'
  Endif
  # --------------------------------------
#--CPO 71937 NOK (voir plus haut)
#  #--Groupe de soc/sites
#  If [L]FCY="" & [L]CPY="" & [L]GRP<>""
#    CRITERE(ICRITERE) -= '& ([F:TSO]GFY="" | [F:TSO]GFY="'+[L]GRP+'")'
#  Endif
  ICRITERE += 1
  #--Législation
  If LEG <> "" Then
    CRITERE(ICRITERE) -= '& ([F:TSO]LEG="'+[L]LEG+'" | [F:TSO]LEG="")'
  Endif
  # --------------------------------------
  If dim(SELCAR) > 0 & SELCAR <> 0 Then
    CRITERE(ICRITERE) -= '& left$([F:TSO]SOHTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
  Endif
  # --------------------------------------
  # Catégorie
  If left$(STYPSEL,1) = "a" Then
    # Préfixe "a" : un seul cas à tester
    ICRITERE += 1
    CRITERE(ICRITERE) -= '& SOHCAT = ' + mid$(STYPSEL,2,1)
  Elsif left$(STYPSEL,1) = "b" Then
    # Préfixe "b" : Cas successifs à tester encadrés par des |
    ICRITERE += 1
    CRITERE(ICRITERE) -= '& ('
    If len(STYPSEL) = 1 Then
      # Si on ne dit rien, c'est tout
      CRITERE(ICRITERE) -= '1=1'
    Else
      For I = 2 To len(STYPSEL)
        If I > 2 Then
          CRITERE(ICRITERE) -= '|'
        Endif
        CRITERE(ICRITERE) -= 'SOHCAT = ' + mid$(STYPSEL,I,1)
      Next NI
    Endif
    CRITERE(ICRITERE) -= ')'
  Else
    Case STYPSEL
      When "1"
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& (SOHCAT = 1 | SOHCAT = 2 | SOHCAT = 3)'
      When "2"
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& SOHCAT = 4'
      When Default
    Endcase
  Endif
  # --------------------------------------
  # FGR 20/02/2015 : X3SUIVI104383 (début) objet browser TSO2
  If GFONCTION = "ADPVAL" or GFONCTION = "GESAUS" Then
    Case OPTIONS
      When "N"
        # Normal
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& (SOHCAT = 1)'
      When "P"
        # Prêt
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& (SOHCAT = 2)'
      When "F"
        # Facture directe
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& (SOHCAT = 3)'
      When "O"
        # Ouverte
        ICRITERE += 1
        CRITERE(ICRITERE) -= '& (SOHCAT = 4)'
      When Default
    Endcase
  Endif
  # FGR 20/02/2015 : X3SUIVI104383 (fin)
  # --------------------------------------
  ICRITERE += 1

# Issue 117510
#  Call FILROLE(OBJET, FILROLE) From SUBARL

  Call FILROLE("TSO", FILROLE) From SUBARL
# End issue 117510

  If FILROLE <> "" & FILROLE <> "1=1" Then
    For I = 0 To dim(FILROLE)-1
      Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", FILROLE(I), "&") From GOBJSUB
    Next I
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
    If [L]LEG <> "" Then
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSOYGRP"
        Local File =SZVIEW [TSOY]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSO"
        Return
      Endif
    Else
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSOZGRP"
        Local File =SZVIEW [TSOZ]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSO"
        Return
      Endif
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  If 1=1 Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSOCPY"
      Local File =SZVIEW [TSOC]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TSO"
      Return
    Endif
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    If [L]LEG <> "" Then
      # Vue via GCURLEG
      #--CPO penser à sauvegarder GCURLEG !!!!!
      #Local Char SAVE_LEG(GLONADI)
      #SAVE_LEG=GCURLEG
      #GCURLEG = [L]LEG
      #Call MAJVUE("LEGTSOSEL",nomap) From DOSVUE
      #GCURLEG=SAVE_LEG
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSOSEL"
        Local File =SZVIEW [TSOS]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSO"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TSO] With [F:AXX]AXX0   = "TABSOHTYP";"DESAXX";GLANGUE;[F:TSO]SOHTYP;[F:TSO]LEG,
&                       [F:TSOY]TSOY0 ~= [L]GRP;[F:TSO]SOHTYP;[F:TSO]GFY;[F:TSO]LEG,
&                       [F:TSOS]TSO0  ~= [F:TSO]SOHTYP;[F:TSO]LEG;[L]LEG
&                    As [LTSO]
      Else
        Link [TSO] With [F:AXX]AXX0   = "TABSOHTYP";"DESAXX";GLANGUE;[F:TSO]SOHTYP;[F:TSO]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TSO]GFY,
&                       [F:TSOC]TSO0  = [F:TSO]SOHTYP;[F:TSO]LEG;[F:TSO]GFY;[L]CPY,
&                       [F:TSOS]TSO0 ~= [F:TSO]SOHTYP;[F:TSO]LEG;[L]LEG
&                    As [LTSO]
      Endif
    Else
      # Vue LEG vide
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTSOPAR"
        Local File =SZVIEW [TSOP]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TSO"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TSO] With [F:AXX]AXX0   = "TABSOHTYP";"DESAXX";GLANGUE;[F:TSO]SOHTYP;[F:TSO]LEG,
&                       [F:TSOZ]TSOZ0 ~= [L]GRP;[F:TSO]SOHTYP;[F:TSO]GFY;[F:TSO]LEG
&                    As [LTSO]
      Else
        Link [TSO] With [F:AXX]AXX0   = "TABSOHTYP";"DESAXX";GLANGUE;[F:TSO]SOHTYP;[F:TSO]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TSO]GFY,
&                       [F:TSOC]TSO0  = [F:TSO]SOHTYP;[F:TSO]LEG;[F:TSO]GFY;[L]CPY,
&                       [F:TSOP]TSO0 ~= [F:TSO]SOHTYP;[F:TSO]LEG
&                    As [LTSO]
      Endif
    Endif
  Endif
  # --------------------------------
  # Options de sélection
  If OPTIONS <> "" Then
    Gosub OPTIONS From WOTSO
    ICRITERE += 1
    For I = 1 To NBCOND
      If instr(1,OPTIONS,OPT(I)) Then
        Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", "("+CONDIT(I)+")", "&") From GOBJSUB
      Endif
    Next I
  Endif
  # --------------------------------
  Default File [LTSO]
  DEFPAG = 1
Return

#-------------------------------------
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

###########################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un régime de taxe                #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File TABSOHTYP [TSO1]
    Local File ATEXTRA   [AXX1]
  Else
    Local File =[M]DOSORG+".TABSOHTYP" [TSO1]
    Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TABSOHTYP [TSO2]
    Local File ATEXTRA   [AXX2]
    Local File ACTIV     [ACV2]
  Else
    Local File =[M]DOSDES+".TABSOHTYP" [TSO2]
    Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
    Local File =[M]DOSDES+".ATABDIV"   [ADI2]
    Local File =[M]DOSDES+".ACTIV"     [ACV2]
   Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
  Endif
  Gosub OUVDOS From ATEXTRA
  # Multi-Lég... Vérifier que la législation existe dans le dossier destination
  # Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
  # Note FGR : c'est pas top ici. Déjà y a pas de message
  #  If TABLE2 <> "" & clalev([F:ADS2]) > 0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
  #    Return
  #  Endif
  #
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
  Close Local File [TSO1], [TSO2]
  Close Local File [AXX1], [AXX2]
  If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
  If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
  If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
  If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif
Return

###########################################################################
$TRT_COPIE
Local Integer ILIG

  #--------------------------------------------------#
  # Transaction de copie d'un type de commande       #
  #--------------------------------------------------#
  Local Char    LEGDES
  Local Integer WMONOLEGDES
  # Par défaut : Leg destination=leg de l'enregistrement à copier
  LEGDES=TABLE2
  GOK = 1
  # -----------------------------------------------
  # Contrôles
#  If TABLE2 <> "" Then
#    If [M]DOSDES <> nomap Then
#      Local Char SZDOSSIER(GLONADS)
#      Local Integer LG
#
#      Read [ADI2]CODE=909;TABLE2
#      If fstat Then
#        Call MESSAGE([M:TSO1]LEG - ':' - mess(173,187,1)) From GESECRAN     #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#      LG = instr(1, [M]DOSDES, "@")
#      If LG = 0 Then
#        SZDOSSIER = [M]DOSDES
#      Else
#        SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#      Endif
#      Read [ADS2]DOSSIER=SZDOSSIER
#      If !fstat Then
#        If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#          Call MESSAGE([M:TSO1]LEG - ':' - mess(249,133,1)) From GESECRAN   #-- Législation non gérée par ce dossier --#
#          Return
#        Endif
#      Endif
#    Endif
#  Endif
  #

  If [M]DOSDES<>nomap
      # Le dossier destination est-il mono-leg ?
      If [F:ACV2]CODACT<>"LEG"
       Read [ACV2]CODACT = "LEG"
       If fstat Raz [F:ACV2] : Endif
      Endif
      If [F:ACV2]FLACT<>2
       WMONOLEGDES=0
      Else
       WMONOLEGDES=1
      Endif

      If WMONOLEGDES =0
          # Dossier destination mono-leg
          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If fstat
              # Pb lecture dossier
              Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
              Return
          Endif
          If [F:ADS2]DOSLEG(0)=""
              # Pas de législation pour le dossier
              Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
              Return
          Endif
          If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
              # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
              # Pas de copie
              Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
              Return
          Elsif TABLE2=''
              # La leg de l'enreg. à copier est toute leg
              # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
              LEGDES=[F:ADS2]DOSLEG(0)
          Endif
      Else
          # Dossier destination multi-leg
          If TABLE2<>''
            # Enregistrement à copier avec leg<>""
            Local Char SZDOSSIER(GLONADS)
            Local Integer LG
            Read [ADI2]CODE=909; TABLE2
            If fstat
             Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
             Return
            Endif

            LG = instr(1, [M]DOSDES, "@")
            If LG = 0 Then
              SZDOSSIER = [M]DOSDES
            Else
              SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
            Endif
            Read [ADS2]DOSSIER=SZDOSSIER
            If !fstat Then
                If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                  Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                  Return
                Endif
            Endif
          Endif
      Endif
  Endif

  Read [TSO2]TSO0=TABLE;LEGDES
  If !fstat Then
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
  Endif
  # -----------------------------------------------
  Trbegin [TSO2]
  Delete [TSO2] Where SOHTYP = TABLE & LEG = LEGDES
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".TABSOHTYP"
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK=0
    Call RSTA("TSO2", "") From GLOCK
    Goto AB_COPIE
  Endif
  If !fstat Then
    #-- copie des données
    For [TSO1] Where SOHTYP = TABLE & LEG = TABLE2
      [F:TSO2]=[F:TSO1]
      [F:TSO2]LEG=LEGDES
      If TABLE2=LEGDES
          Call COPTEXTRA("TABSOHTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
          Call COPTEXTRA("TABSOHTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
      Else
          Call COPTEXTRA1("TABSOHTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
          Call COPTEXTRA1("TABSOHTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
      Endif
      If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
      If dim([F:TSO2]UPDUSR) > 0 Then
        [F:TSO2]UPDUSR = GUSER
      Endif
      If dim([F:TSO2]UPDDAT) > 0 Then
        [F:TSO2]UPDDAT = date$
      Endif
      Write [TSO2]
      If fstat Then
        GOK = 0
        Call FSTA("TSO2") From GLOCK
        Break
      Endif
    Next
  Endif
  If GOK < 0 Then
    Goto ROLL_COPIE
  Elsif !GOK Then
    Goto AB_COPIE
  Endif
  Commit
Return

#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif
Return
