#<AdxTL>@(#)2.0.0.0 $Revision$
End
########################################################################
# SUBTSO                                                Novembre 2000  #
#    TYPES DE COMMANDES VENTES                                         #
########################################################################
# Issue 117510 - 20170324 by LD : Row level permission on SOHTYP

$ACTION
  Case ACTION
    When "AFFMASK"        : Gosub AFFMASK
    When "OUVRE"          : Gosub OUVRE     :#--CPO 71937
    When "LIENS"          : Gosub LIENS     :#--CPO 71937
    When "SETBOUT"        : Gosub SETBOUT   :# FGR 13/11/2012 : X3SUIVI71937
    When "RAZCRE"         : Gosub RAZCRE
    When "INICRE"         : Gosub INICRE
    When "INIMOD"         : Gosub INICRE
    When "ANNULE"         : Gosub ANNULE
    When "VERIF_CRE"      : Gosub VERIF
    When "VERIF_MOD"      : Gosub VERIF
    When "CHANGE"         : # FGR 11/12/2012 : X3SUIVI71937#--CPO 71937 Prise en compte de LEG, ajout de SUPP
                            #Call CHANGE_AXX ("TABSOHTYP", [L]SUPP(0), [L]OCODE, [L]SUPP(0), [L]NCODE) From TRTX3TEX
                            Call CHANGE_AXX ("TABSOHTYP", [L]OCODE, [L]SUPP(0), [L]NCODE, [L]SUPP(0)) From TRTX3TEX
    When "SEL_TABLE"      :  # FGR 13/11/2012 : X3SUIVI71937
      Case TABLE
        When "SELTSOLEG2" : Gosub SELTSOLEG2
      Endcase
    When "CHGCOD"         : Gosub CHGCOD  # FGR 13/11/2012 : X3SUIVI71937
    When "FERME"          : Gosub FERME
    When "AS_SOHTYP"      : Raz GCURLEG   :#--CPO 92135 Sélection sur fiche ayant une lég
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  #--CPO 71937
  #If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  #-----------------------------------#
  # Sauvegarde des variables globales #
  #-----------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #--Lors d'un tunnel depuis un document (exemple : livraison)
  Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
  #--/CPO
Return

######################################################################
$SETBOUT
  #------------------------------#
  # Désactivation bouton "Copie" #
  #------------------------------#
  If GREP <> "" | !CLECUR Then
    Call VIREBOUT(CHAINE, "2") From GOBJET
  Endif
Return

#################################################################################
$CHGCOD
  # FGR 13/11/2012 : X3SUIVI71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################
$INICRE
  #--- Creation / Modif de ATEXTRA
  #--CPO 71937 Prise en compte de LEG, ajout de [M:TSO1]LEG
  Call MAJTEXTRA ([M:TSO1]DESAXX,"TABSOHTYP","DESAXX",[M:TSO1]SOHTYP,[M:TSO1]LEG) From ATEXTRA
  Call MAJTEXTRA ([M:TSO1]SHOAXX,"TABSOHTYP","SHOAXX",[M:TSO1]SOHTYP,[M:TSO1]LEG) From ATEXTRA

  #    SOS libellés
  If dim([F:TSO]LANDESSHO)>0
    [F:TSO]LANDESSHO=GLANGUE+"~"+[M:TSO1]DESAXX+"~"+[M:TSO1]SHOAXX
  Endif

  #--CPO 71937 Contrôle global de cohérence avant enregistrement
  Gosub CONTROLE_COHERENCE

Return

######################################################################
$AFFMASK
  Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
  Gosub GRILEG
Return

######################################################################
$RAZCRE
  Gosub GRILEG
Return

######################################################################################
$LIENS
  GCURLEG = [F:TSO]LEG
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Return

######################################################################
$GRILEG
  If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
    Diszo [M:TSO1]LEG
    [M:TSO1]LEG=GDOSLEG(1)
    Affzo [M:TSO1]LEG
  Endif
Return

######################################################################
$ANNULE
  #--CPO 71937 Prise en compte de LEG, ajout de [F:TSO]LEG
  Delete [AXX] Where CODFIC="TABSOHTYP" & IDENT1=[F:TSO]SOHTYP & IDENT2=[F:TSO]LEG
Return

######################################################################
$FERME
#--CPO 71937
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#--/CPO
  #--CPO 71937 Pb tunnel sur champ vide au départ
  #If TUNNEL<>1 | dim(VCOD)<1 : Return : Endif
  If TUNNEL<>1 : Return : Endif
	If dim(VCOD)<1 : Global Char VCOD(GLONTDA) : Endif
  VCOD = CLE2
Return

######################################################################
$VERIF
  #--CPO avec LD 75115
  If [M:TSO1]SDHTYP<>""
    #--Re-lecture [F:TSD]
    If find([F:TSD]SDHTYP,"",[M:TSO1]SDHTYP)<1 | find([F:TSD]LEG,"",[M:TSO1]LEG)<1
        Local Integer WERR
        Call LEC_TSD_LEG([M:TSO1]LEG,[M:TSO1]SDHTYP,WERR) From TRTLECLEG
        #If WERR Raz [F:TSD] : Call RSTA("TSD", [M:TSO1]SDHTYP) From GLOCK : Endif
        If WERR : Raz [F:TSD] : Endif	:#--CPO 71937
    Endif
    #--Contrôle cohérence groupes
    If ([F:TSD]GFY<>"" | [M:TSO1]GFY="") & [F:TSD]GFY<>[M:TSO1]GFY
        GMESSAGE=mess(226,200,1)-[M:TSO1]GFY-mess(92,187,1)-"("
        If [M:TSO1]GFY<>""
          GMESSAGE+=[M:TSO1]GFY-"<>"-[F:TSD]GFY+")"
        Else
          GMESSAGE+=mess(220,117,1)-"<>"-[F:TSD]GFY+")"
        Endif
        GERR=1 : OK=0 : Return
    Endif
    #--Contrôle de la cohérence de la catégorie entre le type de commande et le type de livraison
    If [F:TSD]SDHCAT>0 :#--CPO 71937
      If (find([M:TSO1]SOHCAT, 1,4) & [F:TSD]SDHCAT<>1) | (find([M:TSO1]SOHCAT, 2,3) & [M:TSO1]SOHCAT<>[F:TSD]SDHCAT)
        GMESSAGE=mess(361,192,1)-"("+mess([F:TSD]SDHCAT,490,1)-"<>"-mess([M:TSO1]SOHCAT,412,1)-")"
        GERR=1 : OK=0 : Return
      Endif
    Endif
  Endif
Return

#########################################################################
#    Détail des actions : Classées par champs dans l'ordre des écrans   #
#########################################################################
######################################################################################
Subprog AP_SOHCAT(VALEUR)
Variable Integer VALEUR

  #--CPO 75115 Pas de type de livraison si cde à facturation directe
  If VALEUR=3
    Raz   [M:TSO1]SDHTYP : Affzo [M:TSO1]SDHTYP : Diszo [M:TSO1]SDHTYP
  Else
    Actzo [M:TSO1]SDHTYP
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TSO1) 20/04/2012 10:49:39 (CPO)
######################################################################################
#--CPO 71937
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

GCURLEG = VALEUR

#Issue X3-85504 - 2018-04-12 by VAVIL : Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TSO1]SOHTYP,"TSO",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End

######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()

  If [F:ANM]CODNUM <> VALEUR
     Read [ANM]ANM0 = VALEUR
     If fstat Raz [F:ANM] Endif
  Endif

  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONVCR
     GERR=1
     GMESSAGE = mess(223,199,1)
     mkstat = 1
  Endif

#Issue X3-85504 - 2018-04-12 by VAVIL : Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TSO1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    Call CTL_CODNUM_FINAL(VALEUR,[M:TSO1]LEG,[M:TSO1]SOHTYP,"TSO",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

End

######################################################################################
Subprog AS_SDHTYP(VALEUR)
Variable Char    VALEUR()

  #--CPO 75115 Pas de type de livraison si cde à facturation directe
  If [M:TSO1]SOHCAT=3 : mkstat=2 : Endif
End
######################################################################################
Subprog C_SDHTYP(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" End Endif

  # Contrôle de la cohérence de la catégorie entre le type de commande et le type de livraison
  If (find([M:TSO1]SOHCAT, 1,4) & [F:TSD]SDHCAT<>1) | (find([M:TSO1]SOHCAT, 2,3) & [M:TSO1]SOHCAT<>[F:TSD]SDHCAT)
    GMESSAGE=mess(361,192,1)-"("+mess([F:TSD]SDHCAT,490,1)-"<>"-mess([M:TSO1]SOHCAT,412,1)-")"
    mkstat=2 : End
  Endif

  #---CPO 75115 mis en commentaire (ajouté dans CONTTSD de SUBTSD)
  ## Contrôle de la cohérence du groupe entre le type de commande et le type de livraison
  #If [F:TSD]GFY<>"" & [F:TSD]GFY<>[M:TSO1]GFY
  #    GMESSAGE=mess(226,200,1)-VALEUR-mess(92,187,1)-"("
  #    If [M:TSO1]GFY<>""
  #      GMESSAGE+=[F:TSD]GFY-"<>"-[M:TSO1]GFY+")"
  #    Else
  #      GMESSAGE+=[F:TSD]GFY-"<>"-mess(220,117,1)+")"
  #    Endif
  #    mkstat=1 : End
  #Endif
  #
#--CPO 71937 Il faut laisser le type de données s'en occuper (le cas est accepté)
#  # Contrôle de la cohérence de la législation entre le type de commande et le type de livraison
#  # Le ctrl du type de données TSD n'est pas suffisamment précis pour le cas suivant :
#  # LEG="" sur le type de cde et LEG<>"" sur le type de liv : Il faut interdire ce cas
#  If [F:TSD]LEG<>"" & [F:TSD]LEG<>[M:TSO1]LEG
#      GMESSAGE=mess(226,200,1)-VALEUR-mess(74,127,1)-"("
#      If [M:TSO1]LEG<>""
#        GMESSAGE+=[F:TSD]LEG-"<>"-[M:TSO1]LEG+")"
#      Else
#        GMESSAGE+=[F:TSD]LEG-"<>"-mess(91,187,1)+")"
#      Endif
#      mkstat=1 : End
#  Endif
  #---/CPO
End

######################################################################
###############################################################################
##  Copie
###############################################################################



##################################################
## Actions of the data type TSO
##################################################
#-- Control
# FGR 13/11/2012 : X3SUIVI71937
Subprog CONTTSO(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local    Integer CAS
Local    Char    OPTIONS(30)

  If GFONCTION = "GESTSO" | COD = "" Then
    End
  Endif
  # --------------------------------------------------------------------------
  If clalev([F:TSO])  = 0 : Local File TABSOHTYP  [TSO] : Endif
  If clalev([F:AMZZ]) = 0 : Local File AMSKZON    [AMZZ] : Endif :#--for the selection options of the object
  # --------------------------------------------------------------------------
  If func AFNC.ACTIV("LEG") = 0 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then : # GCURLEG positionné par programme
    LEG = GCURLEG
  Endif
  # --------------------------------------------------------------------------
  CAS = 1  #--Legislation is empty

  #--CPO 71937
  #--Cas particulier : pas de GCURLEG mais société ou site en ligne
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
  If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  	If [L]FCY<>""
  		If [F:FCY]FCY<>[L]FCY
  			Read [F:FCY]FCY0=[L]FCY
  			If fstat : Raz [F:FCY] Endif
  		Endif
  		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  	Endif
  	If [L]CPY<>""
  		If [F:CPY]CPY<>[L]CPY
  			Read [F:CPY]CPY0=[L]CPY
  			If fstat : Raz [F:CPY] Endif
  		Endif
  		[L]LEG=[F:CPY]LEG
  	Endif
  Endif
  #--/CPO

  If LEG <> "" Then
    Read [TSO]TSO0=[L]COD;[L]LEG
    If fstat Then
      Read [TSO]TSO0=[L]COD;""
    Else
      CAS = 2  #--Legislation isn't empty
    Endif
  Else
    Read [TSO]TSO0(1)=[L]COD
    If !fstat Then
      LEG = [F:TSO]LEG
      CAS = 2
    Endif
  Endif
  If fstat Then
    Filter [TSO] Where SOHTYP=[L]COD
    Look [TSO]TSO0 First
    If !fstat Then
      # "Fiche inexistante pour la législation courante"
      # "No existing record for the curent legislation"
      GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
    Else
      # "Fiche inexistante"
      # "Record does not exist"
      GMESSAGE = [L]COD-":"-mess(23,100,1)
    Endif
    Filter [TSO]
    mkstat = 2
    End
  Endif
  # --------------------------------------------------------------------------
  #--Filtrage par groupe de société
  #--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
  #--Du fait du type de donné AGF sur le champ GRP de TABVAT, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TSO]GFY<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TSO]GFY
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TSO]GFY<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TSO]GFY : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TSO]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TSO]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

  #--Contrôle de cohérence entre le groupe de la taxe et la législation
  If [F:TSO]GFY <> "" and LEG <> "" Then
    Call CTLGFYLEG([F:TSO]GFY, LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de cohérence entre le groupe de la taxe et la législation
  If GROUPE <> "" and [F:TSO]LEG <> "" Then
    Call CTLGFYLEG(GROUPE, [F:TSO]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  # --Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
  # --uniquement si le groupe passé est renseigné
  # --uniquement si pas de contexte site ou société !
  If GROUPE <> "" Then
    If CPY = "" and FCY = "" and [F:TSO]GFY <> "" and [F:TSO]GFY <> GROUPE Then
      #--Les groupes doivent avoir au moins une société en commun
      Gosub CTLGFYGRP
      If mkstat Then
        End
      Endif
    Endif
  Endif
  #--CPO 71937
  #--Contrôle de cohérence entre le groupe passé en paramètre et la législation du type de commande à contrôler
	If GROUPE<>"" and LEG<>""
		Call CTLGFYLEG(GROUPE,LEG,"","") From TRTVENCTL
		If mkstat : End : Endif
	Endif
  # --------------------------------------------------------------------------
  #--On charge les options définies sur le type de données du champ du masque
  #--Findig Object options defined on the data type of the field in the screen
  OPTIONS = ""
  If CODMSK <> "" & CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
    If fstat = 0 Then
      OPTIONS = [F:AMZZ]OPTOBJ
    Endif
  Endif
  If CAS = 2 Then
   Call CONTROLE("TSO",OPTIONS,LEG,COD,mkstat) From CONTOBJ
  Else
   Call CONTROLE("TSO",OPTIONS,"",COD,mkstat) From CONTOBJ
  Endif

	#--CPO 71937 Contrôle global de cohérence avant enregistrement
  #--Cohérence [TSO]SDHTYP et paramètres
  If mkstat > 0 : End : Endif

	If [F:TSO]SDHTYP<>""
  	If clalev([F:TSD])=0 : Local File TABSDHTYP [TSD] : Endif

  	Call CONTTSD([TSO]SDHTYP,[L]LEG,"","",[L]FCY,GROUPE,(([F:TSO]SOHCAT=2)+1),[L]CPY) From SUBTSD
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]COD-":"-mess(226,200,1)-GMESSAGE
  		Else
  			GMESSAGE = [L]COD-"["+[L]LEG+"]"-":"-mess(226,200,1)-GMESSAGE
  		Endif
  		End
  	Endif
	Endif

End

#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [F:TSO]LEG = "" Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSOZGRP"
      Local File =SZVIEW [TSOZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSOZ]TSOZ0=[L]GROUPE;[F:TSO]SOHTYP;[F:TSO]GFY;[F:TSO]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSO]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTSOYGRP"
      Local File =SZVIEW [TSOY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TSOY]TSOY0=[L]GROUPE;[F:TSO]SOHTYP;[F:TSO]GFY;[F:TSO]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TSO]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Endif
Return

