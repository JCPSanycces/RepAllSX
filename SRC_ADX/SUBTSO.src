######################################################################################
######################################################################################
##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:TSO1]SOHTYP
	WLEG =[M:TSO1]LEG

  Call CTL_ML_CONSISTENCY("TSO", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return

$CHECK_CONSISTENCY
	Local Integer WRET

	If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSO il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTSO"
  	#--Cohérence [TSO]SOHTYP et paramètres
  	Call CONTTSO(P_CODE,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSO
  	If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
  Else #Endif
    #--Cohérence [TSO]SDHTYP et paramètres
    Call CONTTSD([TSO]SDHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",(([F:TSO]SOHCAT=2)+1),PACTUAL_CPY) From SUBTSD
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=mess(226,200,1)-GMESSAGE : Raz GMESSAGE : Return : Endif
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char    LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
	If clalev([F:TSD])=0 : Local File TABSDHTYP [TSD] : Endif

  Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTSO il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If GFONCTION<>"GESTSO" and ( [F:TSO]SOHTYP<>P_CODE | find([F:TSO]LEG,P_LEG,"")=0 )
    If P_LEG<>""
     Read [TSO]TSO0=P_CODE;P_LEG
     If fstat
      Read [TSO]TSO0=P_CODE;""
     Else
      #CAS = 2 : # P_LEGislation isn't empty
     Endif
    Else
     Read [TSO]TSO0(1)=P_CODE
     If !fstat
      P_LEG = [F:TSO]LEG
      #CAS = 2
     Endif
    Endif
    If fstat
     Filter [TSO] Where SOHTYP=P_CODE
     Look [TSO]TSO0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = P_CODE-":"-mess(23,100,1)
     Endif
     Filter [TSO]
     VSTATUS=99 : Return
    Endif
	Endif

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:TSO]LEG<>"" and P_LEG<>[F:TSO]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TSO]LEG :# "Législations différentes"
		Return
	Endif

  P_LEG=[F:TSO]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

		If [F:TSO]SDHTYP<>""
  		For [TSD] Where SDHTYP=[F:TSO]SDHTYP
  			If [F:TSD]LEG<>"" and find([F:TSD]LEG,LEGS)=0
  				LEGS(I) = [F:TSD]LEG
  				I += 1
  			Endif
  		Next
		Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du type de livraison
  	If [F:TSO]SDHTYP<>""
    	Call LEC_TSD_LEG(LEGS(I),[F:TSO]SDHTYP,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:TSD]
    Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:TSO]GFY<>"" or [F:TSD]GFY<>""

      GROUPES = NewInstance [GRPTSO] With C_GRPCOLL

      RET= fmet GROUPES.GROUPADD([F:TSO]GFY)
      RET= fmet GROUPES.GROUPADD([F:TSD]GFY)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.AllocGrp

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.AllocGrp

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:TSO])=0 : Local File TABSOHTYP [TSO] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:TSO] Where find(LEG,"",PACTUAL_LEG)>0

	For [F:TSO]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [TSO]SOHTYP et paramètres
    Call CONTTSO([TSO]SOHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTSO
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif

    #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
    #  	If VSTATUS=0
    #      #--Cohérence [TSO]SDHTYP et paramètres
    #      Call CONTTSD([TSO]SDHTYP,PACTUAL_LEG,"","",PACTUAL_FCY,"",(([F:TSO]SOHCAT=2)+1),PACTUAL_CPY) From SUBTSD
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=mess(226,200,1)-GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:TSO]SOHTYP
			P_LEG =[F:TSO]LEG
			Break
		Endif

	Next

	Filter [F:TSO]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return

######################################################################################
##  S/P                                                                              #
######################################################################################
Subprog VERF_PARAM(PPARAM, PVALEUR, POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

  # FGR 20/02/2015 : X3SUIVI104383
  If PVALEUR = "" Then
    End
  Endif

Local Char FCY(GLONFCY)
Local Char SAVE_GCURFCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char SAVE_GSOCIETE(GLONCPY)
Local Char LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

  Local File TABSOHTYP [TSO]
  #-------------------------
  [L]SAVE_GCURFCY = GCURFCY
  [L]SAVE_GSOCIETE = GSOCIETE
  If GFONCTION = "ADPVAL" Then
    # Saisie valeurs paramètres. Type de données = PGT
    FCY = [M:ADWP]FCY
    GCURFCY = FCY
    CPY = [M:ADWP]CMP
    GSOCIETE = CPY
    If dim([M:ADWP]LEG) > 0 Then
      LEG = [M:ADWP]LEG
    Else
      LEG = GDOSLEG
    Endif
    WNOL = nolign-1
    #--Initialisation de législation
    If [L]LEG = "" Then
      If [L]FCY <> "" Then
        Call LEC_FCY([L]FCY) From CPTLEC
        Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
        GSOCIETE = [F:FCY]LEGCPY
        [L]LEG = [F:CPY]LEG
      Elsif [L]CPY <> "" Then
        Call LEC_CPY([L]CPY) From CPTLEC
        [L]LEG = [F:CPY]LEG
      Endif
    Endif
    If [L]LEG = "" Then
      [L]LEG = GCURLEG
    Endif
    Call CONTTSO(PVALEUR, LEG, "MULTILEGADP", PPARAM, FCY, "", CPY)
    If mkstat Then
      POK = 0
    Endif
  Endif
  GCURFCY = [L]SAVE_GCURFCY
  GSOCIETE = [L]SAVE_GSOCIETE
End

