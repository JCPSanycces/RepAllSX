# Supervisor
## ACLA-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:00 871

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOCHD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CHDNAM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CHDSRN From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CHDSEX From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_DATCHDBRN From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CMT From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_LNKPAR From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_DPDTYPMID From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_DPDTYP From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_RELTYP From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CHDUID From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CHDCKK From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CRETIM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_UPDTIM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOCHD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOCHD
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOCHD
Gosub LNKPRO_REFNUM From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1EMPLOCHD : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EMPLOCHD : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



