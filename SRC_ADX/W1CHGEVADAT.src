#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CHGEVADAT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:06"
A_USER  = "DOC"
A_STAMP = "20181109230306"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CHGEVADAT [CHG]
Gosub HORODAT
Local Inpbox "CHGEVADAT" From GFONCTION At A_STAMP With A_WINDPREV Mask [CHG] As [SIM_]
Grizo [CHG]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CHG]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=13 : X2(0)=100 : Y1(0)=12 : Y2(0)=17
Return

$ON_REFNUM
Return

$ON_ZREFNUM
Onevent BEFORE_AREA Gosub AV_ZREFNUM From W1CHGEVADAT
Return

$AV_ZREFNUM
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Call LECTURE("EML",num$([M]REFNUM(indice)),"") From CONTOBJ
zc = [F:ID]NAM
Gosub _AFF
Return

$ON_CTRNUM
Return

$ON_EVATYP
Onevent INIT_AREA Call D_EVATYP(zc) From W1CHGEVADAT
Return

Subprog D_EVATYP(VALEUR)
Variable Char    VALEUR()
If varinit([M]EVATYP,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10464","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZEVATYP
Onevent BEFORE_AREA Gosub AV_ZEVATYP From W1CHGEVADAT
Return

$AV_ZEVATYP
Call LECTEXTRA(zc,"ATABDIV","LNGDES","10464",num$([M]EVATYP(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_EVADATSTR
Onevent CONTROL Call C_EVADATSTR(zc) From W1CHGEVADAT
Onevent BEFORE_AREA Gosub AV_EVADATSTR From W1CHGEVADAT
Return

$AV_EVADATSTR
Chgfmt [M]EVADATSTR(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_EVADATSTR(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51972 : Endif
If !mkstat
 ## Action STD
 Call C_EVADATSTR(VALEUR) From CHGEVADAT
 If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51972 : Endif
Endif
Gosub _AFF
End

$ON_EVADATEND
Onevent CONTROL Call C_EVADATEND(zc) From W1CHGEVADAT
Onevent BEFORE_AREA Gosub AV_EVADATEND From W1CHGEVADAT
Return

$AV_EVADATEND
Chgfmt [M]EVADATEND(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog C_EVADATEND(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
If !mkstat
 ## Action STD
 Call C_EVADATEND(VALEUR) From CHGEVADAT
 If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
 If !mkstat
  ## Action DATDEBFIN
  Call DATDEBFIN(VALEUR,[M]EVADATSTR) From EXEFNC
  If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
 Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


