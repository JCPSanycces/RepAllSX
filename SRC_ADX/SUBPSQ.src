#<AdxTL>@(#)116.0.0.0 $Revision$
########################################################################
# SUBPSQ : Eclatement d'une ligne de commande d'achat     MBT 22/01/98 #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p         #
# d'éclatement ligne "ECLATE_LIG" et ne sert qu'à gérer le masque      #
# écran "PSPLQTY1 [PSQ1]".                                             #
########################################################################

$ACTION
#---------------------------#
# Actions champs modèlisées #
#---------------------------#
Case ACTION
  When "AAM_PRHFCY"   : Gosub AAM_PRHFCY
  When "BAM_PRHFCY"   : Gosub BAM_PRHFCY
Endcase
Return

Subprog C_NBLIG
#------------------------------------------------#
# Contrôle sur numéro de ligne :                 #
# Status=4  validation du tableau par Return     #
# Status=5  sortie par Shift-Tab (fléche haut)   #
# Status=73 ou 82 insertion ou ajout d'une ligne #
#------------------------------------------------#
If  status=5  & [M:PSQ1]REMQTY<>0  mkstat=1 : Endif
If (status=73 | status=82) & [M:PSQ1]REMQTY=0
  GMESSAGE=mess(71,194,1) : mkstat=2
Endif
End

Subprog AVANT_NBLIG
#----------------------------------------------------------------------#
# Avant ligne : Addition qté restante si différent de insertion et fin #
#----------------------------------------------------------------------#
If [M:PSQ1]REMQTY=0 & [M:PSQ1]QTY(nolign-1)=0
  GMESSAGE=mess(71,194,1) : GERR=1
Endif
[M:PSQ1]REMQTY+=[M:PSQ1]QTY(nolign-1)
End

Subprog APRES_NBLIG
#-------------------------------------------------------------#
# Après ligne : Soustraction qté restante sauf si suppression #
#-------------------------------------------------------------#
If status=65 | status=68 | status=83 End : endif 
[M:PSQ1]REMQTY-=[M:PSQ1]QTY(nolign-1)
End

Subprog D_PRHFCY(VALEUR)
#-------------------------------------#
# Initialisation du site de réception #
#-------------------------------------#
Variable Char    VALEUR()
VALEUR=[M:PSQ1]RCPFCY
End

Subprog IB_PRHFCY
#-------------------------------------------------#
# Activation bouton "Int Stock" et "Article-site" #
#-------------------------------------------------#
Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6 : # GBOUT1 est chargé par l'action CONSSFC
If [M:PSQ1]STOMGTCOD<2 Raz GBOUT1 : Endif
GBOUT2=mess(4,198,1)
End

Subprog AS_PRHFCY(VALEUR)
#-----------------------------------#
# Avant saisie du site de réception #
#-----------------------------------#
Variable Char    VALEUR()
If dim([M:POH0]SALFCY)>0 & [M:POH0]SALFCY<>"" & ([M:POH0]DME=3 | GLINBPD<>2)
  mkstat=2
Endif
End


##########################################################################


Subprog C_PRHFCY(VALEUR)
#----------------------------------------------------------------------#
# Contrôle site de réception : Même société juridique et si article    #
# géré en stock site de stockage + existence article-site de réception #
#----------------------------------------------------------------------#
Variable Char     VALEUR()
If [M:PSQ1]STOMGTCOD>1
  Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
  If mkstat End : Endif
  If GIMPORT
    Read [ITF] ITF0=[M:PSQ1]ITMREF;VALEUR
    If fstat Raz [F:ITF] : GMESSAGE=mess(25,192,1) : mkstat=1 : End : Endif
  Endif
Else
  Call CONTROLE("FCY","", VALEUR,"",mkstat) From CONTOBJ
  If mkstat End : Endif
Endif
If [F:FCY]LEGCPY<>GSOCIETE  GMESSAGE=mess(2,194,1)  : mkstat=1 : End : Endif
End

$AAM_PRHFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL             : NOL=nolign-1
Local Char     SITE  (GLONFCY) : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PSQ1]PRHFCY(NOL) : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PSQ1]ITMREF
Return

$BAM_PRHFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1 : # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PSQ1]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return

Subprog AM_PRHFCY(VALEUR)
#-------------------------------------------------#
# Après modif : Chargement code adresse par défaut#
#-------------------------------------------------#
Variable Char     VALEUR
If [F:FCY]FCY<>VALEUR
  Read [FCY] FCY0=VALEUR : If fstat Raz [F:FCY] : Endif
Endif
#--- Vérification que le site de réception correspond à une adresse client livré
If dim([M:POH0]SALFCY)>0 & [M:POH0]SALFCY<>""
  Local Char BETRCPFCY(GLONFCY)
  Local Char BPCNUM   (GLONBPC)
  [L]BETRCPFCY=VALEUR
  [L]BPCNUM=[M:POH0]BPCORD
  Gosub CTRL_BPRADD From TRTACHCTL1
  If [L]BETRCPFCY="" : GMESSAGE=mess(267,194,1) : mkstat=1 : End : Endif
Endif
[M:PSQ1]FCYADD(nolign-1)=[F:FCY]BPAADD
End

Subprog D_FCYADD(VALEUR)
#-------------------------------------#
# Initialisation de l'adresse du site #
#-------------------------------------#
Variable Char    VALEUR()
VALEUR=[M:PSQ1]RCPADD
End

Subprog IB_FCYADD
#-----------------------------------------------------------------------#
# Init bouton code adresse pour charger [F:FCY] avant sélection adresse #
#-----------------------------------------------------------------------#
If [F:FCY]FCY<>[M:PSQ1]PRHFCY(nolign-1)
  Read [FCY] FCY0=[M:PSQ1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
Endif
Raz GBIDC3 : # Utilisé par l'action SAISELADR pour le nom
End

Subprog C_FCYADD(VALEUR)
#-----------------------------------------#
# Contrôle adresse du site de reception   #
#-----------------------------------------#
Variable Char    VALEUR()
Local    Shortint NOL : NOL=nolign-1
Read [BPA] BPA0=3;[M:PSQ1]PRHFCY(NOL);VALEUR
If fstat Raz [F:BPA] : mkstat=1 : Endif
End

Subprog D_QTY(VALEUR)
#-------------------------------#
# Initialisation de la quantité #
#-------------------------------#
Variable Decimal VALEUR
VALEUR=[M:PSQ1]REMQTY
End

Subprog AV_QTY(VALEUR)
#-------------------------------------------------------#
# Avant zone de la qté : Affichage du reste de la ligne #
#-------------------------------------------------------#
Variable Decimal VALEUR
[M:PSQ1]UOM1(nolign-1)=[M:PSQ1]UOM
Affzo [PSQ1]UOM1(nolign-1),EXTRCPDAT(nolign-1)
End

Subprog AM_QTY(VALEUR)
#-----------------------#
# Après modif de la qté #
#-----------------------#
Variable Decimal VALEUR
If VALEUR > REMQTY mkstat=1 : Endif
End

Subprog D_EXTRCPDAT(VALEUR)
#----------------------------------#
# Initialisation date de réception #
#----------------------------------#
Variable Date    VALEUR
VALEUR=[M:PSQ1]RCPDAT
End

Subprog AS_EXTRCPDAT(VALEUR)
Variable Date     VALEUR # FGR 19/01/2010 : X3SUIVI60986

#--------------------------------------------------------#
# Avant saisie : Lecture site de réception si nécessaire #
#--------------------------------------------------------#
If [F:FCY]FCY<>[M:PSQ1]PRHFCY(nolign-1)
  Read [FCY] FCY0=[M:PSQ1]PRHFCY(nolign-1) : If fstat Raz [F:FCY] : Endif
Endif
End

Subprog AM_EXTRCPDAT(VALEUR)
#-------------------------------------------------#
# Après modif : Contrôle date de réception prévue #
#-------------------------------------------------#
Variable Date     VALEUR
Local    Integer  OK : OK=1
If RETQTYSTU<>0 & VALEUR>RETRCPDAT
   Call AVERTIR(mess(95,194,1)-format$("DD2",RETRCPDAT),OK) From GESECRAN
   If OK=1 mkstat=1 : End : Endif
Endif
If RETQTYSTU=0  & VALEUR<RETRCPDAT
   Call AVERTIR(mess(38,194,1)-format$("DD2",RETRCPDAT),OK) From GESECRAN
   If OK=1 mkstat=1 : End : Endif
Endif
End

