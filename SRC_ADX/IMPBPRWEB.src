#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################
#
#    GIMP(1)   = site d'expédition pour le client
#   
###############################################################################
$ACTION
Case ACTION
        When "EXP_OUVRE" : Gosub EXP_OUVRE
        When "EXPORT"    : Gosub EXPORT
        When Default
Endcase
Return

###############################################################################
$EXP_OUVRE
If clalev([F:BPC])=0    : Local File BPCUSTOMER [BPC]   : Endif
If clalev([F:REP])=0    : Local File SALESREP   [REP]   : Endif
If clalev([F:BPD])=0    : Local File BPDLVCUST  [BPD]   : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
Return

###############################################################################
$EXPORT
#-- extraction des clients & représentants seulement #
If [F:BPR]BPCFLG = 2 | [F:BPR]REPFLG = 2 : OK = 1: Else OK = 0: Return : Endif

#-- pas de sélection des clients intersite
If [F:BPR]BETFCY = 2 : OK = 0: Return : Endif

#--- Lecture de l'adresse par défaut et du site d'expédition pour les clients
If [F:BPR]BPCFLG = 2
   Read [BPC]BPC0=[F:BPR]BPRNUM
   If fstat : Raz [F:BPC] : Endif
   #--- Adresse internet
   Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPC]BPAADD
   If fstat : Raz [F:BPA] : Endif

   Read [BPD]BPD0=[F:BPR]BPRNUM;[F:BPC]BPAADD
   If fstat : Raz [F:BPD] : Endif
   GIMP(1)= [F:BPD]STOFCY
Else Raz GIMP(1)
Endif
#--- Lecture de l'adresse par défaut pour les représentants 
If [F:BPR]REPFLG = 2
   Read [REP]REP0=[F:BPR]BPRNUM
   If fstat : Raz [F:REP] : Endif
   #--- Adresse internet
   Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:REP]BPAADD
   If fstat : Raz [F:BPA] : Endif
Endif

Return 
