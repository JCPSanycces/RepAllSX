#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#########################################################################
# Traitement modifié à partir du traitement généré WTLSTPRDWAS
# <MOD modif MOD>
#########################################################################
#########################################################################
## Genarated program to acces X3 view: LSTPRDWAS
## Program name             : TRTTITMWAS
## Subprogram name          : ACCVIEW
## Generator version        : 1.0.3
## TimeStamp                : 20090918101935
#########################################################################
# Remark: To make a personnalized access program:
#         - Set a new name to this source
#         - Change ACCTAB or ACCVIEW by ACCESS for Call, Subprog and messages lines
#         - Search and modify lines with the token XT_SPE
#         - Create a new document in the X3 subprogram function and publish the Web Service
#
# Test
Goto TSTCALL
End

#########################################################################
# Subprogram
#########################################################################
Subprog ACCVIEW(  AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,ITMDES1,ITMDES2,ITMREF,LANCAT,TSICOD0,TSICOD1,TSICOD2,VIG
&                ,PHYSTO,DET,QTY,PRIXBRUT,PRIXNET, MONTANT, REMISE)

# Begining of compulsory technical section
Value Char    AXPARCOD()(1..20)
Variable Char    AXPARVAL()(1..20)
Value Integer AXWHRLFTBRK(1..14)
Value Char    AXWHRCOD()(1..14)
Value Integer AXWHROPE(1..14)
Value Char    AXWHRCODVAL()(1..14)
Value Integer AXWHRRGTBRK(1..14)
Value Integer AXWHRANDOR(1..14)
Value Char    AXORDCOD()(1..10)
Value Integer AXORDTYP(1..10)
# End of compulsory technical section
# <XT_SPE>Set new arguments
Variable Char    ITMDES1()(1..100)
Variable Char    ITMDES2()(1..100)
Variable Char    ITMREF()(1..100)
Variable Char    LANCAT()(1..100)
Variable Char    TSICOD0()(1..100)
Variable Char    TSICOD1()(1..100)
Variable Char    TSICOD2()(1..100)
Variable Char    VIG()(1..100)

#<MOD
Variable Decimal PHYSTO(1..100)
Variable Integer DET(1..100)
Variable Decimal QTY(1..100)
Variable Decimal PRIXBRUT(1..100)
Variable Decimal PRIXNET(1..100)
Variable Decimal MONTANT(1..100)
Variable Decimal REMISE(1..100)

Local Char BPRNUM
Local Char CUR
Local Char SALFCY
Local Char STOFCY
Local Char DEFSTOFCY

For ZTMP="BPRNUM","CUR","SALFCY","STOFCY","DEFSTOFCY"
 Assign ("[L]"+ZTMP) With evalue ("AXPARVAL(find([L]ZTMP,AXPARCOD))")
Next

If [L]STOFCY=""
 [L]STOFCY = [L]DEFSTOFCY
Endif
#MOD>
# </XT_SPE>
Local Char TRT_TIT(50)
#<MOD
#TRT_TIT=" - Subprog WTLSTPRDWAS( view LSTPRDWAS)"  # <XT_SPE/>
TRT_TIT=" - Subprog TRTTITMWAS( view LSTPRDWAS)"  # <XT_SPE/>
#MOD>
Local Integer WI

# Debug - Activate line and modify $SETDEBUGJON
# Gosub SETDEBUGJON : Dbgaff


Gosub CL_INI

Gosub CL_LNK

Gosub CL_FLT

Gosub CL_RES

# Gestion timing
If GTRACE<>""
   Gosub TIMING_STOP From AYTUTIA        # Timing stop
Endif

End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
# Utilities
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #

# Initialisation clause
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$CL_INI
# Gestion trace
If GTRACE=""    # No trace active
  WI = find ("$X3TRACE", AXPARCOD)
  If WI
    Onerrgo ERR_PARNUM
    WJ = val(AXPARVAL(WI))
    Onerrgo : If GW_STAT : Return : Endif
    If WJ=1        # Trace asked
      Call OUVRE_TRACE("Test: WTLSTPRDWAS/ACCVIEW") From LECFIC
      AXPARVAL(WI)=GTRACE
      Call ECR_TRACE("### Trace from subprog ACCVIEW" ,0) From GESECRAN
      Call ECR_TRACE("X3 Trace reference:"  +GTRACE ,0) From GESECRAN
    Endif
  Endif
Else
   Call ECR_TRACE("### Trace from subprog ACCVIEW" ,0) From GESECRAN
Endif

# Messge and timing
If GTRACE<>""
   Gosub TIMING_START From AYTUTIA        # Timing start
Endif

# Optimalisation
Local Integer P_OPTIMISE   # Asked optimalisation (menu 7633) for interface
WI = find ("$OPTIMISE", AXPARCOD)
If WI
  P_OPTIMISE=val(AXPARVAL(WI))
  If P_OPTIMISE<1 : P_OPTIMISE=1 : Endif
  If GTRACE<>""
      Call ECR_TRACE("Optimalisation:"-mess(P_OPTIMISE,7933,1)-" ("+num$(P_OPTIMISE)+")" ,0) From GESECRAN
  Endif
Endif

Return

# Link clause
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$CL_LNK
If GTRACE<>""
    Call ECR_TRACE("Main view: LSTPRDWAS",0) From GESECRAN
Endif
# <XT_SPE>Set access to tables</XT_SPE>
#<MOD
If !clalev([LPW]) : Local File LSTPRDWAS [LPW] : Endif
If !clalev([AYS]) : Local File AYTFCY [AYS] : Endif

If !clalev([ITV]) : Local File ITMMVT [ITV] : Endif
If !clalev([ITV2]) : Local File ITMMVT [ITV2] : Endif

Link [LPW] With [ITV2]ITV1=[L]STOFCY;[LPW]ITMREF
&          As   [LPW_]

#MOD>
Default File [LPW_]
Return

# Filter clause
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$CL_FLT
Local Clbfile WFLTWHR(2)     # Where Filter - 2046 car.
Local Char WFLTORD(250)      # Order Filter
Local Char WWHRX3FLD(20)     # Temp X3 Field Code
Local Char WORDX3FLD(20)     # Temp X3 Field Code
Local Char WVALUE(250)       # Temp value
Raz GW_STAT
For WNBPAR=1 To 10
    If AXWHRCOD(WNBPAR) = "" : Break : Endif
    Gosub LINFLTWHR
    If GW_STAT=1 : Break : Endif
Next
If GW_STAT=1 : Return : Endif
If GTRACE<>""
    Call ECR_TRACE("Filter (Where): "+WFLTWHR ,0) From GESECRAN
Endif

For WNBPAR=1 To 12
    If AXORDCOD(WNBPAR) = "" : Break : Endif
    Gosub LINFLTORD
    If GW_STAT=1 : Break : Endif
Next
If GW_STAT=1 : Return : Endif
If GTRACE<>""
    Call ECR_TRACE("Filter (Order): "+WFLTORD ,0) From GESECRAN
Endif

Onerrgo ERR_EVAL
If WFLTWHR<>"" and WFLTORD<>""
  Filter [LPW_] Where evalue(WFLTWHR) Order With WFLTORD
Elsif WFLTWHR<>""
  Filter [LPW_] Where evalue(WFLTWHR)
Elsif WFLTORD<>""
  Filter [LPW_] Order With WFLTORD
Else
  Filter [LPW_]
Endif

Onerrgo : If GW_STAT : End : Endif

Return


$ERR_EVAL
Call ADDMESSERR("Filter: Evalue error "-TRT_TIT) From AWEB
Call ADDMESSERR("Filter where: "+WFLTWHR) From AWEB
Call ADDMESSERR("Filter order: "+WFLTORD) From AWEB
Call ADDMESSERR("errn:"-num$(errn)-" errl:"-num$(errl)) From AWEB
Call ADDMESSERR(errmes$(errn)-errm) From AWEB
GW_STAT=1
Resume


##### Calcul du filtre (Where)
$LINFLTWHR
Gosub FLTM56
Gosub FLTM7926
Return

## Menu 56 Et/ou
$FLTM56
If WNBPAR=1 : Return : Endif
Case AXWHRANDOR(WNBPAR)
When 1 : WFLTWHR+=" and "
When 2 : WFLTWHR+=" or "
Endcase
Return

## Menu 7926 Ope
$FLTM7926
Gosub VAL_VHRSET : If GW_STAT=1 : Return : Endif
Case AXWHROPE(WNBPAR)
When 2 : WFLTWHR+=    WWHRX3FLD     +' = '   + WVALUE
When 3 : WFLTWHR+=    WWHRX3FLD     +' <> '  + WVALUE
When 4 : WFLTWHR+=    WWHRX3FLD     +' > '   + WVALUE
When 5 : WFLTWHR+=    WWHRX3FLD     +' >= '  + WVALUE
When 6 : WFLTWHR+=    WWHRX3FLD     +' < '   + WVALUE
When 7 : WFLTWHR+=    WWHRX3FLD     +' <= '  + WVALUE
When 8 : WFLTWHR+='pat(toupper(' + WWHRX3FLD  + '),"'  + toupper(AXWHRCODVAL(WNBPAR)) + '*")=1'
When 9 : WFLTWHR+='pat(toupper(' + WWHRX3FLD  + '),"*' + toupper(AXWHRCODVAL(WNBPAR)) + '*")=1'
When 10: WFLTWHR+='pat(toupper(' + WWHRX3FLD  + '),"*' + toupper(AXWHRCODVAL(WNBPAR)) + '*")=0'
Endcase
Return


##  Manage Where datas
##  Input  :  AXWHRCOD  Code of Site Web field
##  Output :  WWHRX3FLD Code of X3 field
##            WVALUE   Value to compare
$VAL_VHRSET
Raz WWHRX3FLD , WVALUE
# <XT_SPE>Set selection information according the argument name</XT_SPE>
Case AXWHRCOD(WNBPAR)
 When "ITMDES1"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "ITMDES1"
 When "ITMDES2"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "ITMDES2"
 When "ITMREF"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "ITMREF"
 When "LANCAT"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "LANCAT"
 When "TSICOD0"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "TSICOD(0)"
 When "TSICOD1"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "TSICOD(1)"
 When "TSICOD2"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "TSICOD(2)"
 When "VIG"   # Alpha
    WVALUE= '"' +AXWHRCODVAL(WNBPAR)+ '"' : WWHRX3FLD = "VIG"
When Default
        Call ADDMESSERR("Compute Where: Unknown variable:"-AXWHRCOD(WNBPAR)-TRT_TIT ) From AWEB
        GW_STAT=1
Endcase
Return

## Add Filter order line
$LINFLTORD
Gosub VAL_ORDSET : If GW_STAT=1 : Return : Endif
If WFLTORD <> "" : WFLTORD +=" ; " : Endif
WFLTORD += WORDX3FLD
If AXORDTYP(WNBPAR)=2 : WFLTORD += " Desc" : Else : WFLTORD += " Asc" : Endif
Return

##  Manage order field
##  Input  :  AXORDCOD   Code of Site Web field
##  Output :  WORDX3FLD  X3 field to order
$VAL_ORDSET
Raz WVALUE
# <XT_SPE>Set order information according argument name</XT_SPE>
Case AXORDCOD(WNBPAR)
 When "ITMDES1"   # Alpha
     WORDX3FLD  = "ITMDES1"
 When "ITMDES2"   # Alpha
     WORDX3FLD  = "ITMDES2"
 When "ITMREF"   # Alpha
     WORDX3FLD  = "ITMREF"
 When "LANCAT"   # Alpha
     WORDX3FLD  = "LANCAT"
 When "TSICOD0"   # Alpha
     WORDX3FLD  = "TSICOD(0)"
 When "TSICOD1"   # Alpha
     WORDX3FLD  = "TSICOD(1)"
 When "TSICOD2"   # Alpha
     WORDX3FLD  = "TSICOD(2)"
 When "VIG"   # Alpha
     WORDX3FLD  = "VIG"
When Default
        Call ADDMESSERR("Compute Order: Unknown variable:"-AXORDCOD(WNBPAR)-TRT_TIT) From AWEB
        GW_STAT=1
Endcase
Return

# Results
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$CL_RES
Local Integer WNBREAD  : WNBREAD=0         # Request: Number of read records
Local Integer WSTART   : WSTART=1          # Request: Rank of first row to be returned (standard mode)
Local Integer WMAXREC                      # Request: Maximun number of records to be returned
Local Integer WTOTALCOUNT                  # Request: Total number of rows returned by request
Local Integer WACCTYP                      # Type of access: 0-standard  1-random

Local Integer WROWPOS                      # Current row in returned data tables

Local Integer WHASNEXT : WHASNEXT=0        # Output: Has next row (0: no more)
Local Integer WNBREC   : WNBREC=0          # Output: Number of returned records
Local Integer WRNDNB                       # Output: Number of records in random access (=0: standard access mode)


# Type of access
WACCTYP=0    # standard
WI = find ("$RANDOM", AXPARCOD)
If WI
    Onerrgo ERR_PARNUM
    WJ = val(AXPARVAL(WI))
    Onerrgo : If GW_STAT : Return : Endif
    If WJ=1  : WACCTYP=1 : Endif  # random access
Endif

# Output:  TotalCount
WTOTALCOUNT = rowcount([LPW_])
If GTRACE<>""
    Call ECR_TRACE("Total Count of request ($TOTAL_COUNT): " +num$(WTOTALCOUNT ) ,0) From GESECRAN
Endif
WI = find ("$TOTAL_COUNT", AXPARCOD)
If WI
    AXPARVAL(WI)=num$(WTOTALCOUNT)
Endif

# Request infos
Case WACCTYP
When 0    # Standard
    If GTRACE<>""
        Call ECR_TRACE("Standard access" ,0) From GESECRAN
    Endif

    # Input:  Rank of first row
    WI = find ("$REC_STARTAT", AXPARCOD)
    If WI
     Onerrgo ERR_PARNUM
     WSTART = val(AXPARVAL(WI))
     Onerrgo : If GW_STAT : Return : Endif
    Endif
    If WSTART < 1
     Call ADDMESSERR("Parameter $REC_STARTAT - Incorrect value:" -AXPARVAL(WI)-TRT_TIT ) From AWEB
     GW_STAT=1 : Return
    Endif
    If GTRACE<>""
        Call ECR_TRACE("Input - Start position($REC_STARTAT): " +num$(WSTART ) ,0) From GESECRAN
    Endif

    # Input:  Maximun number of records
    WMAXREC = 100 # default value
    WI = find ("$REC_MAX", AXPARCOD)
    If WI
     Onerrgo ERR_PARNUM
     WMAXREC = val(AXPARVAL(WI))
     Onerrgo : If GW_STAT : Return : Endif
    Endif
    If WMAXREC <1 or WMAXREC > 100
     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to 100 ):" -AXPARVAL(WI)-TRT_TIT ) From AWEB
     GW_STAT=1 : Return
    Endif
    If GTRACE<>""
        Call ECR_TRACE("Input - Maximun number of records($REC_MAX): " +num$(WMAXREC) ,0) From GESECRAN
    Endif

When 1    # Random
    If GTRACE<>""
        Call ECR_TRACE("Random access" ,0) From GESECRAN
    Endif

    # Input:  Maximun number of records
    WMAXREC = 1    # default value
    WI = find ("$REC_MAX", AXPARCOD)
    If WI
     Onerrgo ERR_PARNUM
     WMAXREC = val(AXPARVAL(WI))
     Onerrgo : If GW_STAT : Return : Endif
    Endif
    If WMAXREC <1 or WMAXREC > 100
     Call ADDMESSERR("Parameter $REC_MAX - Incorrect value(1 to 100 ):" -AXPARVAL(WI)-TRT_TIT ) From AWEB
     GW_STAT=1 : Return
    Endif
    If GTRACE<>""
        Call ECR_TRACE("Input - Maximun number of records($REC_MAX): " +num$(WMAXREC) ,0) From GESECRAN
    Endif

    #
    If WTOTALCOUNT > WMAXREC
        WRNDNB = WMAXREC
    Else
        WRNDNB = WTOTALCOUNT
    Endif
    Local Integer  RNDTABPOS(1..WRNDNB)
    WK=1
    Repeat
        WRND=int(rnd(WTOTALCOUNT))+1
        If !find(WRND, RNDTABPOS)
            RNDTABPOS(WK)=WRND
            WK+=1
        Endif
    Until WK>WRNDNB

When Default
    Call ADDMESSERR("Access type is incorrect:" -num$(WACCTYP)-TRT_TIT ) From AWEB
    GW_STAT=1 : Return
Endcase
# Results
Case WACCTYP
When 0    # Standard

  If WTOTALCOUNT >= WSTART
    #Call MESSAGE("xol1"-num$(WACCTYP)) From GESECRAN
    For [LPW_]
      WNBREAD+=1
      # Job finished
      If WNBREC >= WMAXREC  : WHASNEXT=1 : Break : Endif
      # Row selection
      If WSTART <= WNBREAD
        WNBREC+=1
        WROWPOS=WNBREC : Gosub LOADLINE
      Endif
    Next
  Endif
When 1    # Random
    For [LPW_]

      WNBREAD+=1
      # Row selection
      WROWPOS = find(WNBREAD, RNDTABPOS)
      If  WROWPOS
        WNBREC+=1
        Gosub LOADLINE
      Endif
      # Job finished
      If WNBREC >= WRNDNB : Break : Endif
    Next
Endcase

# Number of read records
If GTRACE<>""
    Call ECR_TRACE("Request - Number of read records: " +num$(WNBREAD) ,0) From GESECRAN
Endif

# Output HasNext
If WACCTYP=0 and GTRACE<>""
    Call ECR_TRACE("Request - Has next($HAS_NEXT): " +num$(WHASNEXT) ,0) From GESECRAN
Endif
WI = find ("$HAS_NEXT", AXPARCOD)
If WI : AXPARVAL(WI)= num$(WHASNEXT) : Endif

# Output: Number of returned records
If GTRACE<>""
    Call ECR_TRACE("Output - Number of returned records ($RET_COUNT): " +num$(WNBREC) ,0) From GESECRAN
Endif
WI = find ("$RET_COUNT", AXPARCOD)
If WI : AXPARVAL(WI)= num$(WNBREC) : Endif
Return

# Returned data for a row
# <XT_SPE>Spécifier les arguments renvoyées</XT_SPE>
$LOADLINE
      ITMDES1(WROWPOS) = [F]ITMDES1
      ITMDES2(WROWPOS) = [F]ITMDES2
      ITMREF(WROWPOS) = [F]ITMREF
      LANCAT(WROWPOS) = [F]LANCAT
      TSICOD0(WROWPOS) = [F]TSICOD(0)
      TSICOD1(WROWPOS) = [F]TSICOD(1)
      TSICOD2(WROWPOS) = [F]TSICOD(2)
      VIG(WROWPOS) = [F]VIG
#<MOD
Read [F:ITV]ITV0=[F:LPW_]ITMREF;[L]STOFCY

 If fstat=0
  [L]PHYSTO(WROWPOS)=([F:ITV]PHYSTO-[F:ITV]PHYALL)
 Else
  [L]PHYSTO(WROWPOS)=0
 Endif

 If fstat=0
  DET(WROWPOS)=1
  VIG(WROWPOS)=[F:LPW_]VIG
 Endif

 Call TARIF_VEN ( [F]ITMREF, QTY(WROWPOS), "UN", BPRNUM, CUR, date$, SALFCY, STOFCY, 1,
& PRIXBRUT(WROWPOS), PRIXNET(WROWPOS), MONTANT(WROWPOS), REMISE(WROWPOS) ) From FUNTARIFWAS

#MOD>
Return

$ERR_PARNUM
 Call ADDMESSERR("Parameter" -AXPARCOD(WI)- "Value not numeric:" -AXPARVAL(WI)-TRT_TIT ) From AWEB
GW_STAT=1
Resume

# Remote Debug parameters
# - - - - - - - - - - - - - - - - - - - - - - - - - - - -  - - #
$SETDEBUGJON
If dim([V]GIAADXCTX)<0 : Global Char GIAADXCTX(250) : Endif
[V]GIAADXCTX = "X3_CS:NA1:"                # entête "X3_CS:session client X3" + "NA1:session primaire"
Call SET_DEBUG_ON(1) From DEBUGGERJ        # 0=debugger socket "off"
Call SET_PORT("1789") From DEBUGGERJ       # Port*
#Call SET_HOST("172.16.9.153") From DEBUGGERJ  # @ip du pc
Call SET_HOST("Boris.ech.adx") From DEBUGGERJ
Return


# Appel pour test
#########################################################################
$TSTCALL
# Maximum memory
# maxmem=100000
# Infbox ("maxmem"-num$(maxmem))

# <XT_SPE>Set arguments of the test</XT_SPE>
Local Char    AXPARCOD(12)(1..20)
Local Char    AXPARVAL(40)(1..20)
Local Integer AXWHRLFTBRK(1..14)
Local Char    AXWHRCOD(12)(1..14)
Local Integer AXWHROPE(1..14)
Local Char    AXWHRCODVAL(40)(1..14)
Local Integer AXWHRRGTBRK(1..14)
Local Integer AXWHRANDOR(1..14)
Local Char    AXORDCOD(12)(1..10)
Local Integer AXORDTYP(1..10)
Local Char    ITMDES1(30)(1..100)
Local Char    ITMDES2(30)(1..100)
# Issue 121827 - 2017-03-09 by MAE
#Local Char    ITMREF(20)(1..100)
Local Char    ITMREF(GLONITM)(1..100)
Local Char    LANCAT(3)(1..100)
Local Char    TSICOD0(20)(1..100)
Local Char    TSICOD1(20)(1..100)
Local Char    TSICOD2(20)(1..100)
Local Char    VIG(30)(1..100)

# Set values of the test
####  -->
# AXPARCOD(1)="$RANDOM"
# AXPARCOD(1)="$REC_STARTAT" : AXPARCOD(2)="$REC_MAX"
# AXPARCOD(3)="$TOTAL_COUNT" : AXPARCOD(4)="$HAS_NEXT" : AXPARCOD(5)="$RET_COUNT"
# AXPARCOD(6)="$X3TRACE"
# AXPARCOD(1)="$OPTIMISE"
# AXPARCOD(1)       = "?"
# AXPARCOD(2)       = "?"
# AXPARCOD(3)       = "?"
# AXPARCOD(4)       = "?"
# AXPARCOD(5)       = "?"
# AXPARCOD(6)       = "?"
# AXPARVAL(1)       = "?"
# AXPARVAL(2)       = "?"
# AXPARVAL(3)       = "?"
# AXPARVAL(4)       = "?"
# AXPARVAL(5)       = "?"
# AXPARVAL(6)       = "?"
# AXWHRLFTBRK(1)    = ?
# AXWHRLFTBRK(2)    = ?
# AXWHRLFTBRK(3)    = ?
# AXWHRLFTBRK(4)    = ?
# AXWHRLFTBRK(5)    = ?
# AXWHRLFTBRK(6)    = ?
# AXWHRCOD(1)       = "?"
# AXWHRCOD(2)       = "?"
# AXWHRCOD(3)       = "?"
# AXWHRCOD(4)       = "?"
# AXWHRCOD(5)       = "?"
# AXWHRCOD(6)       = "?"
# AXWHROPE -  2:= 3:<> 4:> 5:>= 6:< 7:<= 8:xx* 9:*xx* 10:<>*xx*
# AXWHROPE(1)       = ?
# AXWHROPE(2)       = ?
# AXWHROPE(3)       = ?
# AXWHROPE(4)       = ?
# AXWHROPE(5)       = ?
# AXWHROPE(6)       = ?
# AXWHRCODVAL(1)    = "?"
# AXWHRCODVAL(2)    = "?"
# AXWHRCODVAL(3)    = "?"
# AXWHRCODVAL(4)    = "?"
# AXWHRCODVAL(5)    = "?"
# AXWHRCODVAL(6)    = "?"
# AXWHRRGTBRK(1)    = ?
# AXWHRRGTBRK(2)    = ?
# AXWHRRGTBRK(3)    = ?
# AXWHRRGTBRK(4)    = ?
# AXWHRRGTBRK(5)    = ?
# AXWHRRGTBRK(6)    = ?
# AXWHRANDOR(1)     = ?
# AXWHRANDOR(2)     = ?
# AXWHRANDOR(3)     = ?
# AXWHRANDOR(4)     = ?
# AXWHRANDOR(5)     = ?
# AXWHRANDOR(6)     = ?
# AXORDCOD(1)       = "?"
# AXORDCOD(2)       = "?"
# AXORDCOD(3)       = "?"
# AXORDCOD(4)       = "?"
# AXORDCOD(5)       = "?"
# AXORDCOD(6)       = "?"
# AXORDTYP -  1: asc 2:=desc
# AXORDTYP(1)       = ?
# AXORDTYP(2)       = ?
# AXORDTYP(3)       = ?
# AXORDTYP(4)       = ?
# AXORDTYP(5)       = ?
# AXORDTYP(6)       = ?
####  <--
# Trace
Call OUVRE_TRACE("Test: WTLSTPRDWAS/ACCVIEW") From LECFIC

# <XT_SPE>Modify arguments</XT_SPE>
Call ACCVIEW(  AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
