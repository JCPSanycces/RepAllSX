#<AdxTL>@(#)0.0.0.0 $Revision$
# Mask Management SFANA
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "LIENS"         : Gosub LIENS
 When Default
Endcase
Return

######################################################################################
$OUVRE
If clalev ([F:AOE]) = 0 : Local File AOBJEXT[AOE] : Endif
Return

######################################################################################
$LIENS
If [M]TYPEXP=1                # Client
 Raz [M]DRTWRK
 Grizo [M]DRTWRK
 Raz [M]DRTSTO
 Grizo [M]DRTSTO
Else                          # Server
 Actzo [M]DRTWRK
 Actzo [M]DRTSTO
Endif
Affzo [M]DRTWRK
Affzo [M]DRTSTO
Return

######################################################################################
# Issue 98931 - 2014-04-21 by RBU : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]DRTWRK
 Grizo [M]DRTWRK
 Raz [M]DRTSTO
 Grizo [M]DRTSTO
Else
 Actzo [M]DRTWRK
 Actzo [M]DRTSTO
Endif
Affzo [M]DRTWRK
Affzo [M]DRTSTO
End

######################################################################################
Subprog C_DRTWRK(VALEUR)
Variable Char VALEUR()
Local Char FULLPATH(250)
#  Issue 98931 - Volume management evolution - RBU
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,FULLPATH,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_DRTSTO(VALEUR)
Variable Char VALEUR()
Local Char FULLPATH(250)
#  Issue 98931 - Volume management evolution - RBU
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,FULLPATH,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_GASTPL(VALEUR)
Variable Char    VALEUR()
Call TPL_CONTROL(VALEUR,"IMPORT")
End

######################################################################################

######################################################################################

#**
#* Validate type of import/export template against template
#*
#* @param TPL - Template Name
#* @param TYP - Type - 'EXPORT' or 'IMPORT'
#*
#*
Subprog TPL_CONTROL(TPL,TYP)
  Value Char    TPL()
  Value Char    TYP()
  Call CONTROLE("AOE","",TPL,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
  Call CONTEXE([F:AOE]ACS) From SUBACS
  If mkstat : End : Endif
  Case toupper(TYP)
    When "EXPORT" If [F:AOE]EXPORT<>2
                    GMESSAGE = mess(110,141,1) : # Export not possible
                    mkstat = 1 : End
                    Endif
    When "IMPORT" If [F:AOE]IMPORT<>2
                    GMESSAGE = mess(109,141,1) : # Import not possible
                    mkstat = 1 : End
                    Endif
  Endcase
End
######################################################################################
## Section automatically added (screen SFANA) 06/05/2014 15:45:53 (RBU)
######################################################################################
Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
  If dim([V]GLEGFIL)>0
    [V]GLEGFIL = VALEUR
  Endif
End


