#<AdxTL>@(#)6.0.0.0 $Revision$
End
######################################################################################
#  SIXCAC : pour traitements de bascule Integrale --> X3                             #
######################################################################################
#                                                                                    #
# Subprog SIXCAC                                                                     #
#                                                                                    #
#     Mise à jour des codes comptables                                               #
#        Phase I  : Vérification des codes comptables du dossier de référence        #
#        Phase II : Initialisation par rapport aux données de la fiche Société       #
#                                                                                    #
# ---------------------------------------------------------------------------------- #
# PRE-REQUIS :                                                                       #
# ---------------------------------------------------------------------------------- #
#                                                                                    #
#     1 - Migrations précédentes : Comptes, Natures                                  #
#                                                                                    #
######################################################################################
##------------------------ PHASE I   --------------------------------------------   ##
######################################################################################
#
# Sous le dossier DEMO de l'Intégrale :
#    - Comptes généraux   sont sous 8 caractères
#    - Comptes collectifs sont sous 4 caractères
#
# Sous le dossier DEMO d'X3REFFRA, Paramètrage des codes comptables : 
#    - 26 Codes comptables
#    - 85 Comptes dont  2 Comptes / 66 Modificateur / 3 Collectifs
#    - Aucune nature
#    
#    Aucun compte et aucune nature ne sont compatibles avec le dossier DEMO X3
#
##  - Mise à jour COMPTE -
#
#  Si le code est de type "Compte", vérification de l'existence du compte. 
#   Si OK,  Compte conservée.
#   Si NOK, Ajout de "0" en fin de chaine jusqu'à l'existence du compte. Si OK, compte Modifié sinon RAZ du compte
#
#  Si le code est de type "Modificateur", 
#   Si la valeur contient 'x', aucune modification, Valeur conservée.
#   Si la valeur ne contient aucun 'x'... même principe que le type "Compte" SAUF aucun RAZ (au pire la valeur est conservée)
#    Lecture de la valeur en tant que compte. 
#    Si la valeur existe en tant que compte, Valeur conservée sinon ajout de "0" en fin de chaine jusqu'à l'existence en tant que compte.
#    Si cette nouvelle valeur existe en tant que compte, Valeur modifié sinon Valeur du dossier DEMO X3 est conservée.
#
#  Si le code est de type "Collectif", vérification de l'existence du compte collectif 
#   Si OK,  Compte collectif conservée.
#   Si NOK, Suppresion de "0" en fin de chaine jusqu'à l'existence du compte collectif. Si OK, compte collectif Modifié sinon RAZ du compte collectif
#
#
#
#  - Mise à jour NATURE -
#
# Même contrôle qu'en saisie, en cas de non existence ou non cohérence avec le compte => Valeur RAZ
#
#   
#####################################################################################

If !clalev([F:CAC])  : Local File GACCCODE [CAC] : Endif   # Codes comtpables

Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("GACCCODE",nbrecord([CAC])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXCAC : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

#--- Mise à jour des codes comptables par rapport au dossier de référence
Call ECR_TIME("SIXCAC : "+SI_MES(77)+" GACCODE") From DOSSUB
Call SI_GACCCODE_REF
If GOK<>1 : Goto FIN_CAC : Endif

#--- Mise à jour des codes comptables par rapport à la fiche société
Call SI_GACCCODE_SOC
If GOK<>1 : Goto FIN_CAC : Endif

$FIN_CAC
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Mise à jour des codes comptables 
#########################################################################
Subprog SI_GACCCODE_REF

##############################
Local Integer TEST
Raz TEST
#If GUSER="CP" : TEST=1 : Endif
#############################

Local Integer NBR_ACC, NBR_ACC_OK, NBR_ACC_NOK, NBR_ACC_MOD, NBR_ACC_RAZ
Raz           NBR_ACC, NBR_ACC_OK, NBR_ACC_NOK, NBR_ACC_MOD, NBR_ACC_RAZ

Local Integer MODIF, FLGWRT
Local Char WACC(GLONGAC), OPT(1)
Local Integer OK 

If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif   # Comptes
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables
If !clalev([F:CCL])  : Local File =SI_DOSSIER+".GACCCODLIG" [CCL] : Endif   # Lignes Codes comptables

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First

Local Char    COAGEN(GLONCOA), COAANA(GLONCOA)

Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

Trbegin [CAC]
GOK = 1

# Mise à jour codes comptable
Call TEMPON(SI_MES(77)) From GESECRAN

For [CAC]

 Raz FLGWRT, MODIF
 Readlock [CAC] Curr
 If TEST : Call ECR_TRACE(mess(161,197,1)-[F:CAC]ACCCOD-"("+mess([F:CAC]TYP,602,1)+")",1) From GESECRAN : Endif
 For I=0 To dim([F:CAC]ACC)-1
  Read [CCL]CCL0=[F:CAC]TYP;I+1
  # Compte
  If [F:CAC]ACC(I)<>""
   NBR_ACC+=1
   # Existence du compte
   Case [F:CCL]TYPCPT
    When 1 : # LA 604 Compte
     OPT="G" : Gosub CTL_ACC
     If MODIF
      If TEST : Call ECR_TRACE(mess([F:CCL]TXT,853,1)-":"-mess(45,102,1)-[F:CAC]ACC(I)-"=>"-WACC,0) From GESECRAN : Endif
      NBR_ACC_MOD += 1  : [F:CAC]ACC(I) = WACC : FLGWRT = 1 
     Else
      If !OK 
       If TEST : Call ECR_TRACE(mess([F:CCL]TXT,853,1)-":"-mess(45,102,1)-[F:CAC]ACC(I)-"=> RAZ",0) From GESECRAN : Endif
       NBR_ACC_RAZ += 1   : Raz [F:CAC]ACC(I) :  FLGWRT = 1 
      Endif
     Endif
    When 2 : # LA 604 Modificateur
     If !instr(1,[F:CAC]ACC(I),"x")
      OPT="" : Gosub CTL_ACC
      If MODIF
      If TEST : Call ECR_TRACE(mess([F:CCL]TXT,853,1)-":"-mess(45,102,1)-[F:CAC]ACC(I)-"=>"-WACC,0) From GESECRAN : Endif
       NBR_ACC_MOD += 1  : [F:CAC]ACC(I) = WACC : FLGWRT = 1 
      Endif
     Else
      NBR_ACC_OK += 1
     Endif  
    When 3 : # LA 604 Collectif
      OPT="C" : Gosub CTL_ACC
     If MODIF
      If TEST : Call ECR_TRACE(mess([F:CCL]TXT,853,1)-":"-mess(45,102,1)-[F:CAC]ACC(I)-"=>"-WACC,0) From GESECRAN : Endif
      NBR_ACC_MOD += 1  : [F:CAC]ACC(I) = WACC  : FLGWRT = 1 
     Else
      If !OK 
       If TEST : Call ECR_TRACE(mess([F:CCL]TXT,853,1)-":"-mess(45,102,1)-[F:CAC]ACC(I)-"=> RAZ",0) From GESECRAN : Endif
       NBR_ACC_RAZ += 1   : Raz [F:CAC]ACC(I) :  FLGWRT = 1 
      Endif
     Endif
   Endcase
  Endif
 Next
 If FLGWRT 
  Rewrite [CAC]
  If fstat
   # Code comptable... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(161,177,1)-mess([F:CAC]TYP,602,1)-[F:CAC]ACCCOD-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0 : Break
  Endif
 Endif
Next

If TEST
 Call ECR_TRACE(num$(NBR_ACC)-mess(45,102,1)-":"-num$(NBR_ACC_OK)-"/"-num$(NBR_ACC_NOK)-"/"-num$(NBR_ACC_MOD)-"/"-num$(NBR_ACC_RAZ),0) From GESECRAN
Endif

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif

Call TEMPOFF From GESECRAN
End

$CTL_ACC
Raz OK, MODIF, WACC
Call CONTROLE("GAC",OPT,[F:CAC]ACC(I),[F:CAC]COA,mkstat) From CONTOBJ
If !mkstat
 NBR_ACC_OK += 1
 OK = 1 
Else
 NBR_ACC_NOK += 1
 WACC = [F:CAC]ACC(I)
 Case OPT
   When "G",""
    For J=len([F:CAC]ACC(I)) To type([F:GAC]ACC)
     WACC +="0"
     Call CONTROLE("GAC",OPT,WACC,[F:CAC]COA,mkstat) From CONTOBJ
     If !mkstat : MODIF=1 : Break : Endif
    Next
   When "C"
    For J=len(WACC) To 1 Step -1
     If right$(WACC,len(WACC))="0"
      WACC = left$(WACC,len(WACC)-1) 
      Call CONTROLE("GAC",OPT,WACC,[F:CAC]COA,mkstat) From CONTOBJ
      If !mkstat : MODIF=1 : Break : Endif
     Else
      Break
     Endif
    Next
 Endcase
Endif
Raz mkstat, GMESSAGE
Return

######################################################################################
##------------------------ PHASE II  --------------------------------------------   ##
######################################################################################
#########################################################################
Subprog SI_GACCCODE_SOC

##############################
Local Integer TEST
Raz TEST
#If GUSER="CP" : TEST=1 : Endif
#############################

If !clalev([F:COA])  : Local File =SI_DOSSIER+".GCOA"       [COA] : Endif   # Code Plan
If !clalev([F:GAC])  : Local File =SI_DOSSIER+".GACCOUNT"   [GAC] : Endif   # Comptes
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif   # Codes comptables
If !clalev([F:CLS])  : Local File =SI_DOSSIER+".GACCCLS"    [CLS] : Endif   # Classes de comptes


If !clalev([F:ADW])  : Local File =SI_DOSSIER+".ADOVAL"     [ADW]  : Endif   # Variable globale

If !clalev([F:XSOC]) : Local File =SI_DOSSIER+".XISOC"      [XSOC] : Endif   # Société Intégrale
If !clalev([F:XSO1]) : Local File =SI_DOSSIER+".XISOCDIV1"  [XSO1] : Endif   # Société Intégrale
If !clalev([F:XSO2]) : Local File =SI_DOSSIER+".XISOCDIV2"  [XSO2] : Endif   # Société Intégrale
If !clalev([F:XSO3]) : Local File =SI_DOSSIER+".XISOCDIV3"  [XSO3] : Endif   # Société Intégrale

If !clalev([F:XRGU]) : Local File =SI_DOSSIER+".XIRGU"      [XRGU] : Endif   # Comtpe d'écart Intégrale

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 
Read [SPX] First


Local Char    WACC(GLONGAC), WACCOLD(GLONGAC)
Local Integer OK, MODIF
Local Char    COAGEN(GLONCOA), COAANA(GLONCOA)

Call LEC_COA(1,[F:SPX]CPY,[L]COAGEN) From SIXCPY
Call LEC_COA(2,[F:SPX]CPY,[L]COAANA) From SIXCPY

Read [XSOC] First
Read [XSO1] First
Read [XSO2] First
Read [XSO3] First



# Mise à jour paramètres
#########################################################################
Call TEMPON(SI_MES(163)) From GESECRAN

Trbegin [COA]

Read [COA]COA0 = [L]COAGEN
If !fstat
    # Paramètre RNDGACLOCC : Ecart d'arrondi créditeur
    [F:COA]ACCMIS(12) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO3]CPTCRDECAEUR,"GACCOUNT","")
    # Paramètre RNDGACLOCD : Ecart d'arrondi débiteur
    [F:COA]ACCMIS(11) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO3]CPTDBTECAEUR,"GACCOUNT","")
    # Paramètre ACCDEF : Compte par défaut 
    [F:COA]ACCMIS(1) = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTATE,"GACCOUNT","")
    # Paramètre CPTRES : Compte résultat
    [F:COA]ACCMIS(10) = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XSOC]CPTRSLCRD,"GACCOUNT","")
    # Paramètres CNVACCx : Compte d'écart
    Read [XRGU]IND0 = "CL"
    If !fstat 
     [F:COA]ACCMIS(4)  = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU1,"GACCOUNT","")
     [F:COA]ACCMIS(5)  = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU2,"GACCOUNT","")
    Endif
    Read [XRGU]IND0 = "FO"
    If !fstat 
     [F:COA]ACCMIS(7) = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU1,"GACCOUNT","")
     [F:COA]ACCMIS(6) = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU2,"GACCOUNT","")
    Endif
    Read [XRGU]IND0 = "EC"
    If !fstat 
     [F:COA]ACCMIS(8) = func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU2,"GACCOUNT","")
     [F:COA]ACCMIS(9) =  func SIXFONCTION.SI_COR("XIPLACBGNR", [F:XRGU]CPTRGU1,"GACCOUNT","")
    Endif


    # Paramètre ACCCSL : Compte d'attente conso.
    If [F:COA]ACCMIS(0)<>""
     WACCOLD = [F:COA]ACCMIS(0) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(0) = WACC
     Else
      Raz [F:COA]ACCMIS(0)
     Endif
    Endif

    # Paramètre ACCTMP : Compte de report
    If [F:COA]ACCMIS(2)<>""
     WACCOLD = [F:COA]ACCMIS(2) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(2) = WACC
     Else
      Raz [F:COA]ACCMIS(2)
     Endif
    Endif

    # Paramètre ANOUVO : Compte d'attente à nouveau
    If [F:COA]ACCMIS(3)<>""
     WACCOLD = [F:COA]ACCMIS(3) : Gosub CTL_PARAM
     If MODIF 
      # Contrôle supplémentaire (demande 43855)
      Read [CLS]CLS0 = 
      Call LECTURE("CLS",[F:COA]LEGCLS,[F:GAC]CLSCOD) From CONTOBJ
      If [F:CLS]TYP<>1
       Raz [F:COA]ACCMIS(3)
      Else
       [F:COA]ACCMIS(3) = WACC
      Endif
     Else
      Raz [F:COA]ACCMIS(3)
     Endif
    Endif

    # Nouveauté V6 : Gain arrondi lettrage
    If [F:COA]ACCMIS(13)<>""
     WACCOLD = [F:COA]ACCMIS(13) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(13) = WACC
     Else
      Raz [F:COA]ACCMIS(13)
     Endif
    Endif

    # Nouveauté V6 : Perte  arrondi lettrage
    If [F:COA]ACCMIS(14)<>""
     WACCOLD = [F:COA]ACCMIS(14) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(14) = WACC
     Else
      Raz [F:COA]ACCMIS(14)
     Endif
    Endif
    
    # Paramètre WAICURACC1 : Compte d'attente pour devise
    If [F:COA]ACCMIS(15)<>""
     WACCOLD = [F:COA]ACCMIS(15) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(15) = WACC
     Else
      Raz [F:COA]ACCMIS(15)
     Endif
    Endif
    
    # Paramètre WAICURACC2 : Compte d'attente pour devise
    If [F:COA]ACCMIS(16)<>""
     WACCOLD = [F:COA]ACCMIS(16) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(16) = WACC
     Else
      Raz [F:COA]ACCMIS(16)
     Endif
    Endif
    
    # Paramètre ACCEXSBAN : Compte refact. frais impayé
    If [F:COA]ACCMIS(17)<>""
     WACCOLD = [F:COA]ACCMIS(17) : Gosub CTL_PARAM
     If MODIF 
      [F:COA]ACCMIS(17) = WACC
     Else
      Raz [F:COA]ACCMIS(17)
     Endif
    Endif

   
 Rewrite [COA]
 If fstat
  # Code Plan   ... :   Erreur d'écriture 
  Call ECR_TRACE(mess(134,107,1)-[L]COAGEN-":"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif


# Initialisation des codes comptables
#########################################################################
Trbegin [CAC]

# Compte Achat : Code comptable FOURNISSEUR Achat(compte)
If [F:XSOC]CPTACH<>""        
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTACH,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=3 With ACC(8)= WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTACH"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte collectif client : Code comptable CLIENT Vente (collectif)
If [F:XSOC]CPTCLFCLT<>""
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTCLFCLT,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=2 With ACC(0)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTCLFCLT"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte collectif fournisseur : Code comptable FOURNISSEUR Achat (collectif)
If [F:XSOC]CPTCLFFOU<>""
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTCLFFOU,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=3 With ACC(0)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTCLFFOU"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte Résultalt Crédit : Code comptable SOCIETE & SITE Compte de bénéfice
If [F:XSOC]CPTRSLCRD<>""
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTRSLCRD,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=7 With ACC(3)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE CPTRSLCRD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
 Update [CAC] Where COA=[L]COAGEN & TYP=8 With ACC(4)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTRSLCRD"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte Résultalt Débit : Code comptable SOCIETE & SITE Compte de perte
If [F:XSOC]CPTRSLDBT<>""
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTRSLDBT,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=7 With ACC(4)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTRSLDBT"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
 Update [CAC] Where  COA=[L]COAGEN & TYP=8 With ACC(5)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTRSLDBT"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte Vente : Code comptable CLIENT  Vente (compte)
If [F:XSOC]CPTVEN<>""   
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSOC]CPTVEN,"GACCOUNT","")
 Update [CAC] Where COA=[L]COAGEN & TYP=2 With ACC(7)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTVEN"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte Crédit TVA : Code comptable TAXE Crédit de taxe
If [F:XSO1]CPTCRDTVA<>"" 
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO1]CPTCRDTVA,"GACCOUNT","")       
 Update [CAC] Where COA=[L]COAGEN & TYP=10 With ACC(8)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE / CPTCRDTVA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

# Compte TVA payer : Code comptable TAXE Taxe à décaisser
If [F:XSO1]CPTTVAPYE<>""        
 WACC = func SIXFONCTION.SI_COR("XIPLACBGNR",[F:XSO1]CPTTVAPYE,"GACCOUNT","")       
 Update [CAC] Where COA=[L]COAGEN & TYP=10 With ACC(7)=WACC
 If fstat
  # Erreur d'écriture
  Call ECR_TRACE("GACCCODE CPTTVAPYE"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Endif
Endif

Raz mkstat, GMESSAGE
If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
Else
 Rollback
Endif
Call TEMPOFF From GESECRAN
End

$CTL_PARAM
 Raz OK, MODIF, WACC
 Call CONTROLE("GAC","G",WACCOLD,[F:COA]COA,mkstat) From CONTOBJ
 If mkstat
  WACC = WACCOLD
  For J=len(WACCOLD) To type([F:GAC]ACC)
   WACC +="0"
   Call CONTROLE("GAC","G",WACC,[F:COA]COA,mkstat) From CONTOBJ
   If !mkstat : MODIF=1 : Break : Endif
  Next
  If !MODIF
   WACC = WACCOLD
   For J=len(WACC) To 1 Step -1
    If right$(WACC,len(WACC))="0"
     WACC = left$(WACC,len(WACC)-1) 
     Call CONTROLE("GAC","G",WACC,[F:COA]COA,mkstat) From CONTOBJ
     If !mkstat & [F:GAC]SAC=2 : MODIF=1 : Break : Endif
    Else
     Break
    Endif
   Next
  Endif
 Endif
Return





