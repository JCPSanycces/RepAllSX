##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

#
Local Char    WIN (GLONFEN)
WIN="DTEOALL"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
######################################################################################
Subprog AS_SCONUMDEB(VALEUR)
Variable Char    VALEUR()
# FQ 53586 Filtrer les listes sur le type de données SCO
Gosub SCOFILTRE
End
Subprog AS_SCONUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR="" VALEUR=[M]SCONUMDEB Endif
# FQ 53586 Filtrer les listes sur le type de données SCO
Gosub SCOFILTRE
End
$SCOFILTRE
If dim(GSCOFILTRE)<=0 Global Char GSCOFILTRE(250) Endif
# Issue 89445 GA 04/2013
If dim([M]PRHFCY)>0 & [M]PRHFCY<>""
   GSCOFILTRE='PRHFCY="'+[M]PRHFCY+'"'
   If [M]POHFCY<>""
      GSCOFILTRE-='& POHFCY="'+[M]POHFCY+'"'
   Endif
Elsif [M]POHFCY<>""
   GSCOFILTRE='POHFCY="'+[M]POHFCY+'"'
Endif
Return
######################################################################################

