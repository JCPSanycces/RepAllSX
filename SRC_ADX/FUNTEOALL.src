#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                          GA 04/2006   #
# Fonction d'allocation automatique des Ordres de sous-traitance        #
#                       (selon FUNAUTALL et FUNMAUTA )                  #
#                                                                       #
# Fenetre:  DTEOALL      Ecran: TEOALL [M:DIA]                          #
# Actions:                                                              #
# - TRTTEOALL  : Action traitement d'allocation automatique             #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When "SORTIE"        : Gosub SORTIE
 When Default
Endcase
Return

########################################################################
$INIT

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

GFCY   = GFCYDEF(6)
Gosub OUVRE
Return

########################################################################
$INIT_DIA

Local    Char    LFCY(GLONFCY) : LFCY = PARAM(1)
Local    Char    LDAT          : LDAT = PARAM(2)
Local    Char    LTYP          : LTYP = PARAM(3)
Local    Char    LVCR(GLONVCR) : LVCR = PARAM(4)
Local    Char    LITM(GLONITM) : LITM = PARAM(5)
Local    Integer LRET          : LRET = 0

# titre de la boîte
TIT = mess(36,190,1)
Raz [M:DIA]

# Issue 89445 GA 04/2013
#If LFCY <> ""  : [M:DIA]POHFCY    = LFCY  : Endif
If LFCY <> ""
   Read [F:FCY]FCY0=LFCY
   If !fstat
      If [F:FCY]WRHFLG=2 & dim([M:DIA]PRHFCY)>0 [M:DIA]PRHFCY=LFCY Endif
      If [F:FCY]PURFLG=2                        [M:DIA]POHFCY=LFCY Endif
   Endif
Endif

If LDAT <> ""
    If instr(1,LDAT,"/")
        [M:DIA]STRDAT = "["+LDAT+"]"
    Else
        [M:DIA]STRDAT = LDAT
    Endif
Else
   LDAT = date$+ GALLHOR                # llc 08.02 15423 # 15942 11.02 MM
Endif
Case LTYP
    When "1":     [M:DIA]ALLTYP = 1
    When "3":     [M:DIA]ALLTYP = 2
Endcase
If LVCR <> "" : [M:DIA]SCONUMDEB = LVCR : [M:DIA]SCONUMFIN = LVCR : Endif
If LITM <> "" : [M:DIA]CPNITMDEB = LITM : [M:DIA]CPNITMFIN = LITM : Endif

Return

########################################################################
$CONTROLE
TIT=" "
TMP=1
Return


#########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("TEOALL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif


If [M:DIA]STRDAT = [0/0/0]  : [M:DIA]STRDAT = date$ + GALLHOR : Endif      # llc 08.02 15423 # 15942 11.02 MM

# préparation des critères de filtre
Gosub SEL_MAT

# premier passage pour traiter les ruptures d'abord
If [M:DIA]SHTFLG = 2 : WFLGALL = 1 : Else : WFLGALL = 2 : Endif
Raz NBALL

# traitement des allocations (premier passage si ruptures prioritaires)
Gosub TRT_MAT

# traitement des allocations (deuxième passage si ruptures prioritaires)
If [M:DIA]SHTFLG = 2 : WFLGALL = 2 : Gosub TRT_MAT : Endif
Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune allocation effectuee ou lecture trace
    If !NBALL
         GERR = 2 : GMESSAGE = mess(71,193,1)
         PARAM(6) = "9"
    Endif
    # lecture trace
Endif
Return

#########################################################################
$SORTIE
# FQ 53586 Filtrer les listes sur le type de données SCO
If dim(GSCOFILTRE)>0 Kill GSCOFILTRE Endif
Return

########################################################################
$OUVRE
Local Integer  MODE
Local Integer  OK
Local Integer  NBALL
Local Integer  WFLGALL
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char     CUSFLT(255)
#
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Decimal  WALL
Local Decimal  WSHT
Local Integer  WRET
Local Char     WTRTLIG(1)
Local Char     WTRT(1)
Local Integer  WALLTYP
Local Char     WITMREF
Local Char     WSTOFCY
Local Char     WVCRNUM
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Date     WSTRDAT

Gosub CHARG_PARAM

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORD1]) = 0 : Local File ORDERS      [ORD1] : Endif
If clalev([F:SCO])  = 0 : Local File SCOHEAD     [SCO]  : Endif
If clalev([F:SCI])  = 0 : Local File SCOITM      [SCI]  : Endif
If clalev([F:SCM])  = 0 : Local File SCOMAT      [SCM]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK    [ORDK]

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB



Return

########################################################################
# Préparation du filtre sur la table encours (matières)                #
########################################################################
$SEL_MAT

MODE = 0
# critères liés aux articles lancés
CRITERE  = 'STOFCY ="'+[M:DIA]PRHFCY+'"'            # site de réception # Issue 89445 GA 04/2013 avant POHFCY
CRITERE -= '& VCRTYP = 36'                          # ordre de sous-traitance
CRITERE -= '& WIPSTA = 1'                           # statut ferme

CRITERE -= '& PIO >=' +num$([M:DIA]PIODEB)           # borne début priorité
CRITERE -= '& PIO <=' +num$([M:DIA]PIOFIN)           # borne fin   priorité

If [M:DIA]SCONUMDEB <> ""                               # borne début EO
   CRITERE -= '& VCRNUM >="'+[M:DIA]SCONUMDEB+'"'
Endif
If [M:DIA]SCONUMFIN <> ""                               # borne fin   EO
   CRITERE -= '& VCRNUM <="'+[M:DIA]SCONUMFIN+'"'
Endif

# affaire
If [M:DIA]PJTDEB <> ""
   CRITERE -= '& PJT >="'+[M:DIA]PJTDEB+'"'             # borne début affaire
Endif
If [M:DIA]PJTFIN <> ""
   CRITERE -= '& PJT <="'+[M:DIA]PJTFIN+'"'             # borne fin   affaire
Endif

# destinataire
If [M:DIA]BPRNUMDEB <> ""
   CRITERE -= '& BPRNUM >="'+[M:DIA]BPRNUMDEB+'"'       # borne début destin.
Endif
If [M:DIA]BPRNUMFIN <> ""
   CRITERE -= '& BPRNUM <="'+[M:DIA]BPRNUMFIN+'"'       # borne fin   destin.
Endif

# no commande d'achat
If [M:DIA]VCRNUMDEB <> ""
   CRITERE -= '& VCRNUMORI >="'+[M:DIA]VCRNUMDEB+'"'    # borne début n° commande
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE -= '& VCRNUMORI <="'+[M:DIA]VCRNUMFIN+'"'    # borne fin   n° commande
Endif
If [M:DIA]VCRNUMDEB <> "" | [M:DIA]VCRNUMFIN <> ""
   CRITERE -= '& VCRTYPORI = 14'                        # type pièce = commande achat
Endif

If [M:DIA]ITMREFDEB <> "" | [M:DIA]ITMREFFIN <> ""
    MODE = 1
    CRITERE -= '& WIPTYP = 13'                          # type EO
    If [M:DIA]ITMREFDEB <> ""
       CRITERE -= '& ITMREF >="'+[M:DIA]ITMREFDEB+'"'       # borne début article lancé
    Endif
    If [M:DIA]ITMREFFIN <> ""
       CRITERE -= '& ITMREF <="'+[M:DIA]ITMREFFIN+'"'       # borne fin   article lancé
    Endif
    CRITERE2 = 'WIPTYP = 3'                             # type MS
    If [M:DIA]CPNITMDEB <> ""
       CRITERE2 -= '& ITMREF >="'+[M:DIA]CPNITMDEB+'"'  # borne début matière
    Endif
    If [M:DIA]CPNITMFIN <> ""
       CRITERE2 -= '& ITMREF <="'+[M:DIA]CPNITMFIN+'"'  # borne fin   matière
    Endif
Else
    CRITERE -= '& WIPTYP = 3'                           # type MS
    If [M:DIA]CPNITMDEB <> ""
       CRITERE -= '& ITMREF >="'+[M:DIA]CPNITMDEB+'"'   # borne début matière
    Endif
    If [M:DIA]CPNITMFIN <> ""
       CRITERE -= '& ITMREF <="'+[M:DIA]CPNITMFIN+'"'   # borne fin   matière
    Endif
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=36;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

#---------------------------------------------------------------------#
# Traitement des matières                                             #
#---------------------------------------------------------------------#
$TRT_MAT

# critère pour le traitement des ruptures
If WFLGALL = 1
   CRITERE1 = "SHTQTY <> 0"
Else
   If [M:DIA]SHTFLG = 2
          CRITERE1 = "SHTQTY = 0"
   Else
       CRITERE1 = "1=1"
   Endif
Endif
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#

# link en tenant compte des critères sur date ou sur code priorité
Case [M:DIA]SORPAR
    When 1: Filter [ORD] Where (evalue(CRITERE) & evalue(CRITERE1) & STRDAT <= [M:DIA]STRDAT) &
&                               evalue(CUSFLT) & evalue(FORMULE1)
&                        Order By STRDAT Asc; PIO Desc
    When 2: Filter [ORD] Where (evalue(CRITERE) & evalue(CRITERE1)  & STRDAT <= [M:DIA]STRDAT) &
&                               evalue(CUSFLT) & evalue(FORMULE1)
&                        Order By PIO Desc; STRDAT Asc
Endcase

# boucle de lecture des encours matières
For  [ORD] With Nohint                # 10.02 Performances
      # FQ 70409 GA 01/2011 limiter le nb de maj de [F:SCO], on maj l'OF précédent
      If [F:ORD]VCRNUM<>WVCRNUM & WVCRNUM<>""
         Gosub TRTSCO
      Endif
      If MODE = 1
        Filter [ORD1] Where (evalue(CRITERE2) & STRDAT<=[M:DIA]STRDAT & VCRNUM=[F:ORD]VCRNUM)
&                     Order By STRDAT Asc; PIO Desc
        For [ORD1] With Nohint        # 10.02 Performances
                WITMREF = [F:ORD1]ITMREF
                WSTOFCY = [F:ORD1]STOFCY
                WVCRNUM = [F:ORD1]VCRNUM
                WVCRLIN = [F:ORD1]VCRLIN
                WVCRSEQ = [F:ORD1]VCRSEQ
                WSTRDAT = [F:ORD1]STRDAT
                Gosub SEL_MATCOMPL
                If OK = 1 : Goto NXT1 : Endif
                #
                If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                    WTRTLIG = "C"
                Else
                    WTRTLIG = "M"
                Endif
                Gosub TRTALL
        $NXT1
        Next
        Filter [ORD1]
        Goto NXT2
      Endif
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WVCRSEQ = [F:ORD]VCRSEQ
      WSTRDAT = [F:ORD]STRDAT
      Gosub SEL_MATCOMPL
      If OK = 1 : Goto NXT2 : Endif
      #
      If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
        WTRTLIG = "C"
      Else
        WTRTLIG = "M"
      Endif
      Gosub TRTALL
$NXT2
Next
#
Filter [ORD]
# FQ 70409 GA 01/2011 limiter le nb de maj de [F:SCO], traiter le dernier OF
If WVCRNUM<>""
   Gosub TRTSCO
Endif
#
#
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires sur la matière                             #
#-----------------------------------------------------------------------#
$SEL_MATCOMPL

OK=1
# lecture article
If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Raz [F:ITM] : Return : Endif
Endif

# lecture article/site
If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> WSTOFCY
    Read [ITF]ITF0=WITMREF;WSTOFCY
    If fstat : Raz [F:ITF] : Return : Endif
Endif

# lecture enregistrement entête EO
If [F:SCO]SCONUM <> WVCRNUM
    Read [SCO]SCO0=WVCRNUM
    If fstat : Raz [F:SCO] : Return : Endif
Endif

# lecture enregistrement article lancé
If [F:SCI]SCONUM <> WVCRNUM | [F:SCI]SCILIN <> WVCRLIN
    Read [SCI]SCI0=WVCRNUM;WVCRLIN
    If fstat : Raz [F:SCI] : Return : Endif
Endif

# lecture enregistrement matière
Read [SCM]SCM0=WVCRNUM;WVCRLIN;WVCRSEQ
If fstat : Raz [F:SCM] : Return : Endif

# ces 2 cas ne devraient pas se produire car on ne devrait pas avoir d'encours MSx (!!!)
If [F:SCM]CPNTYP > 1 : Return : Endif    # si composant Texte
If [F:SCM]SCOFLG = 3 : Return : Endif    # si matière fournie par le sous-traitant

If [F:SCM]MATSTA > 2 : Return : Endif    # si matière soldée ou exclue
Case [M:DIA]ALLTYP
    When 1:    If [F:SCM]ALLSTA >= 4 : Return : Endif # si alloué détail
    When 2:    If [F:SCM]ALLSTA  = 5 : Return : Endif # si alloué détail sans rupture
Endcase
#
OK=2

# PE 23570 (llc 07.04)
# GPOINT = "CUSSELCOMP" : Gosub ENTREE From EXEFNC
Return

#-----------------------------------------------------------------------#
# Traitement d'une allocation                                           #
#-----------------------------------------------------------------------#
$TRTALL
Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJALL
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Mise à jour des allocations                                           #
#-----------------------------------------------------------------------#
$MAJALL
Local Char    WTRTORD
Local Decimal WCPLQTY
Local Integer MEMSTA : MEMSTA = [F:SCM]ALLSTA # mémo statut

#
WALLTYP = [M:DIA]ALLTYP
WMESS   = mess(641,197,1)+" "+WVCRNUM+" "+mess(157,197,1)+" "+WITMREF+" "+
&         mess(158,197,1)+" "+num$(WSTRDAT)
#
Trbegin [SCO],[SCM]
    # traitement matière
    Readlock [SCM]SCM0 Curr
    If fstat = 1
        GOK = -1 : GLOCK="$SCOMAT"+WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)
        Goto ROL_TRTALL
    Elsif fstat
        GOK = 0  : Call RSTA("SCM",WVCRNUM-num$(WVCRLIN)-num$(WVCRSEQ)) From GLOCK
        Goto AB_TRTALL
    Endif
    # si passage de global vers détail, mode "E"
    If (WALLTYP=2 & [F:SCM]ALLSTA > 1 & [F:SCM]ALLSTA < 4) : WTRTLIG = "E" : Endif
    #
    Case WTRTLIG
        When "C","M": If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                          WTRT = "C"
                      Else
                          WTRT = "M"
                      Endif
                      WALL = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY
                      WSHT = [F:SCM]SHTQTY
        When "E":     WTRT = "E"
                      WALL = [F:SCM]ALLQTY
                      WSHT = [F:SCM]SHTQTY
    Endcase
    # appel à la routine de gestion des allocations
    Call ALLOCATION(WTRT, WALLTYP, WALL, WSHT, WRET) From SCOALL
    If WRET  = 9             # llc 07.01 9308
        Rewrite [SCM]
        WRET = 0
        Goto END_ALL
    Endif
    If WRET <> 0 : Goto AB_TRTALL : Endif

    # mise à jour matière
    Case WTRTLIG
        When "C","M": [F:SCM]ALLQTY    += WALL
                      [F:SCM]SHTQTY     = WSHT
                      Case WALLTYP
                        When 1: [F:SCM]ALLSTA = 3
                        When 2: [F:SCM]ALLSTA = 5
                      Endcase
        When "E":     [F:SCM]ALLQTY     = WALL
                      [F:SCM]SHTQTY     = WSHT
                      [F:SCM]ALLSTA     = 5
    Endcase

    # si rupture, maj statut allocation
    If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif

    # mise à jour matière
    Rewrite [SCM]
    If fstat : GOK=0 : Call FSTA("SCM") From GLOCK : Goto AB_TRTALL : Endif

    # mise à jour encours
    Case MODE
        When 0 : Readlock [ORD] Curr
                 [F:ORD]ALLQTY = [F:SCM]ALLQTY
                 [F:ORD]SHTQTY = [F:SCM]SHTQTY
                 Rewrite [ORD]
        When 1 : Readlock [ORD1] Curr
                 [F:ORD1]ALLQTY = [F:SCM]ALLQTY
                 [F:ORD1]SHTQTY = [F:SCM]SHTQTY
                 Rewrite [ORD1]
    Endcase
    If fstat : GOK=0 : Call FSTA("ORD") From GLOCK : Goto AB_TRTALL : Endif

    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    WMESS1 = "          "+mess(106,197,1)+":"+format$("N:15F", WALL)
    WMESS2 = "          "+mess(159,197,1)+":"+format$("N:15F", WSHT)
    Call ECR_TRACE(sum(WMESS1, " ",WMESS2),0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2

    # FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
    # mise à jour entête
    # Gosub MAJSCOHEAD

    # v6 affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB

    NBALL += 1
$END_ALL                    # llc 07.01 9308
Commit
Return

#-----------------------------------------------------------------------#
# Maj globale d'un EO après allocations                                 #
#-----------------------------------------------------------------------#
$TRTSCO                                           # FQ 70409 GA 01/2011 #
Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJSCO
Gosub DEVERROU
Return
#-----------------------------------------------------------------------#
# Mise à jour de l'entete EO                                            #
#-----------------------------------------------------------------------#
$MAJSCO                                           # FQ 70409 GA 01/2011 #
Local Integer XTOT
Local Integer I
#
If WVCRNUM="" Return Endif

Trbegin [SCO]
#
  Readlock [SCO]SCO0=WVCRNUM
  If fstat = 1
     GOK = -1 : GLOCK = "$SCOHEAD"+[F:SCO]SCONUM
     Goto ROL_TRTSCO
  Elsif fstat
     GOK = 0  : Call RSTA("SCO",   [F:SCO]SCONUM) From GLOCK
     Goto AB_TRTSCO
  Endif
#
  Gosub MAJSCOHEAD From SCOLIB
#
  Rewrite [SCO]
  If fstat
     GOK = 0 : Call FSTA("SCO") From GLOCK
     Goto AB_TRTSCO
  Endif
#
Commit
#
Return
$ROL_TRTSCO
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
Return
$AB_TRTSCO
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return


#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête EO                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "SCO"+[F:SCO]SCONUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat = 1
    Call ECR_TRACE([F:SCO]SCONUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête EO                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTALL
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJALL :Endif
Return

$AB_TRTALL
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA


Return

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################
########################################
Subprog AS_POHFCY(VALEUR)
Variable Char    VALEUR()
If GFONCTION = "CONSSHT" Diszo [M:DIA]1-99 : Endif
End
########################################
Subprog AM_POHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
    [M:DIA]STRDAT = date$+ GALLHOR  # mm 12.02
Endif                               # mm 12.02
# Issue 89445 GA 04/2013
If [F:FCY]WRHFLG=2 & dim([M:DIA]PRHFCY)>0 & [M:DIA]PRHFCY=""
   [M:DIA]PRHFCY=VALEUR : Affzo [M:DIA]PRHFCY
Endif
End
########################################
# Issue 89445 GA 04/2013
########################################
Subprog AM_PRHFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
    [M:DIA]STRDAT = date$+ GALLHOR  # mm 12.02
Endif                               # mm 12.02
End

########################################
Subprog AM_PIODEB(VALEUR)
Variable Integer VALEUR
[M:DIA]PIOFIN = VALEUR
End

########################################
Subprog C_PIOFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M:DIA]PIODEB : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_ITMREFFIN(VALEUR)
Variable Char    VALEUR()
End


########################################
Subprog AS_BPRNUMDEB(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

########################################
Subprog AS_BPRNUMFIN(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

