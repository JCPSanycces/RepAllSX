$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W2FCYPAY
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_CAECOD
Onevent CONTROL Call C_CAECOD(zc) From W2FCYPAY
Onevent BEFORE_INPUT Call AS_CAECOD(zc) From W2FCYPAY
Return

Subprog AS_CAECOD(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(55293,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CAECOD(zc) From W2FCYPAY
Onkey   2 Titled GBOUTS Call S_CAECOD(zc) From W2FCYPAY
Onkey 144 Titled GBOUTP Call P_CAECOD(zc) From W2FCYPAY
Gosub _AFF
End

Subprog C_CAECOD(VALEUR)
Variable Decimal VALEUR
## Action %CNTOBJ
Call CONTNUM("CAEC","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CAECOD" : GZNUM = 55293 : Endif
Gosub _AFF
End

Subprog S_CAECOD(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "CAEC"
PARMSK(2) = "!"
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CAECOD(VALEUR)
Variable Decimal VALEUR
Local Char VALCHAR(20)
VALCHAR = num$(VALEUR)
Call OBJET("CAEC",VALCHAR,"") From GOBJET
VALEUR = val(VALCHAR)
Gosub _AFF
End

Subprog P_CAECOD(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CAEC",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

