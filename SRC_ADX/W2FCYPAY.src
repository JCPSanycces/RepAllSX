#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FCYPAY 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_TCCCOD
Return

$ON_ZTCCCOD
Onevent BEFORE_AREA Gosub AV_ZTCCCOD From W2FCYPAY
Return

$AV_ZTCCCOD
If clalev([F:HRTCC])=0 : Local File HRTRADECLASS [HRTCC] : Endif
Call LECTURE("HRTCC",num$([M]TCCCOD(indice)),"") From CONTOBJ
zc = [F:HRTCC]TCCDES
Gosub _AFF
Return

$ON_SICSUBCLS
Return

$ON_ZSICSUBCLS
Onevent BEFORE_AREA Gosub AV_ZSICSUBCLS From W2FCYPAY
Return

$AV_ZSICSUBCLS
If clalev([F:HRSIC])=0 : Local File HRSTDINDCLS [HRSIC] : Endif
Call LECTURE("HRSIC",num$([M]SICSUBCLS(indice)),"") From CONTOBJ
zc = [F:HRSIC]SICDES
Gosub _AFF
Return

$ON_PAYREFNUM
Return

$ON_SEZCOD
Onevent INIT_AREA Call D_SEZCOD(zc) From W2FCYPAY
Return

Subprog D_SEZCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]SEZCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11674","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZSEZCOD
Onevent BEFORE_AREA Gosub AV_ZSEZCOD From W2FCYPAY
Return

$AV_ZSEZCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11674",num$([M]SEZCOD(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_UIFNUM
Return

