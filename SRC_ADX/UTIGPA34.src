#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################
# Issue 80466 GA 03/2012: Récup des CCE incorrectement migrées sur MFI, MFM et MFO
# Complément de UUMGTRTGPA03:
# Il est nécessaire d'avoir conservé les tables UU avant migration , sous leur format V5
#######################################################################


Local Char WDOSSIER(30)

  WDOSSIER = nomap
  Call SAIDOS(WDOSSIER, "") From SAIDOS
  If WDOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]WDOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Local Integer WOUV_TRACE
    If GTRACE = ""
        Call OUVRE_TRACE("UTIGPA34 : Process for CPTANALIN for CCE update - Migrate to V6") From LECFIC
        WOUV_TRACE=1
    Endif
    Call CTL_UUMGTRTGPA03_CAL(WDOSSIER)
    Call TEMPOFF     From GESECRAN
    If WOUV_TRACE=1
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE   From LECFIC
    Endif
  Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  ##### A lancer ssi nécessaire
  ##### Call MAJ_UTIGPA34(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  ##### A lancer ssi nécessaire
  ##### Call MAJ_UTIGPA34(APPLI)
End

##########################################################################
# Issue 80466 GA 03/2012 Special Récupération des CCE perdues suite bug 
##########################################################################
Subprog CTL_UUMGTRTGPA03_CAL(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=0   # Traiter toutes les lignes d'un coup, on n'utilise pas NEWMOTEUR

GOK=1
Gosub UPDCAL
If GOK<=0 
    Call ECR_TRACE("UTIGPA34 Control on CCE is not ok : Update CAL"-WDOSSIER,1) From GESECRAN
Endif

End

##########################################################################
# Issue 80466 GA 03/2012 Special Récupération des CCE perdues suite bug 
##########################################################################
$UPDCAL
GOK=1

Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(7)<>2    # N= no module - 1    7=>GPAO
  Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If  filinfo(filpath("FIL","CPTANALIN" ,"fde",WDOSSIER),0) <=0 
  Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMFICM,WNAMFICM_I,WNAMFICM_M,WNAMFICM_O
         Call MIGTABNAME (WDOSSIER,"MFGHEAD",WNAMFICM  ,ERR) From TRTMIG
If ! ERR Call MIGTABNAME (WDOSSIER,"MFGITM" ,WNAMFICM_I,ERR) From TRTMIG Endif
If ! ERR Call MIGTABNAME (WDOSSIER,"MFGMAT" ,WNAMFICM_M,ERR) From TRTMIG Endif
If ! ERR Call MIGTABNAME (WDOSSIER,"MFGOPE" ,WNAMFICM_O,ERR) From TRTMIG Endif
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If  filinfo(filpath("FIL",WNAMFICM  ,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_I,"fde",WDOSSIER),0) < 0 
& | filinfo(filpath("FIL",WNAMFICM_M,"fde",WDOSSIER),0) < 0 
& | filinfo(filpath("FIL",WNAMFICM_O,"fde",WDOSSIER),0) < 0 
  Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",2,ERR) From TRTMIG : #2=En cours

###################

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
#----- Ouverture des fichiers -----#
If clalev([F:CAL])  = 0 : Local File =WDOSSIER+".CPTANALIN"  [CAL]  : Endif    # Fichier X3 V6 à compléter

If clalev([F:MFGM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM   [MFGM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFIM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_I [MFIM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFMM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_M [MFMM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFOM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_O [MFOM] : Endif   # Fichier X3 renommé Avant Migration
Local Char WMFGFCY(GLONFCY) : WMFGFCY=""
#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBCOMMIT, ISVALID, NBLUS, NBTOT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBTOT, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J
Local Integer NB_MFI,NB_MFM,NB_MFO
Local Char WCRIT_MFI(250) : WCRIT_MFI="1=1"
Local Char WCRIT_MFM(250) : WCRIT_MFM="1=1"
Local Char WCRIT_MFO(250) : WCRIT_MFO="1=1"
# pour les WriteB des tables détails
Local Char WTAB_MFI (100) (adxwrb)
Local Char WTAB_MFM (100) (adxwrb)
Local Char WTAB_MFO (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_MFI, WCPT_MFM, WCPT_MFO, WCPT_CAL

# PE pour ajout clause where 
# ATTENTION: en dernier la clause sur MFG réutilisée juste après
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTGPA03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [CAL]
GOK = 1

# Issue 80145 Key=MFGFCY+MFGNUM
Filter [F:MFGM] Order By Key CLE=[F:MFGM]MFGFCY;[F:MFGM]MFGNUM
For [MFGM]CLE Hint Key=HINTSPE Where evalue(CRITERESPE)
  NBLUS += 1 

  If [F:MFGM]MFGFCY<>WMFGFCY
     WMFGFCY=[F:MFGM]MFGFCY
     Gosub CHARGE_PARAM From UUMGTRTGPA03
  Endif
  Raz NB_MFI,NB_MFM,NB_MFO
  
  For [F:MFIM] Where MFGNUM=[F:MFGM]MFGNUM
      NB_MFI+=1
      Gosub CTLV6_MFI_CAL
  Next
  For [F:MFMM] Where MFGNUM=[F:MFGM]MFGNUM
      NB_MFM+=1
      Gosub CTLV6_MFM_CAL
  Next
  For [F:MFOM] Where MFGNUM=[F:MFGM]MFGNUM
      NB_MFO+=1
      Gosub CTLV6_MFO_CAL
  Next
Next

$END_CAL
If GOK<1 
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UTIGPA34",7,ERR) From TRTMIG : #7=Erreur
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MFGM]
Close Local File [MFIM]
Close Local File [MFMM]
Close Local File [MFOM]
Close Local File [CAL]

Call MIGTRTEND (WDOSSIER,"UTIGPA34") From TRTMIG
Call ECR_TIME("UTIGPA34:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
Return

#######################################################################
$CTLV6_MFI_CAL
Read [CAL]="MFI";0;[F:MFIM]MFGNUM;[F:MFIM]MFGLIN;0;"";1
If fstat Gosub MAJV6_MFI_CAL Endif
Return
#######################################################################
$CTLV6_MFM_CAL
Read [CAL]="MFM";0;[F:MFMM]MFGNUM;[F:MFMM]MFGLIN;[F:MFMM]BOMSEQ;[F:MFMM]ITMREF;1
If fstat Gosub MAJV6_MFM_CAL Endif
Return
#######################################################################
$CTLV6_MFO_CAL
Read [CAL]="MFO";0;[F:MFOM]MFGNUM;[F:MFOM]OPENUM;[F:MFOM]OPESPLNUM;"EXTWST";1
If fstat Gosub MAJV6_MFO_CAL Endif
Return

#######################################################################
$MAJV6_MFM_CAL
  #Raz [F:CAL]
  [F:CAL]ABRFIC="MFM"
  [F:CAL]VCRNUM=[F:MFMM]MFGNUM
  [F:CAL]VCRLIN=[F:MFMM]MFGLIN
  [F:CAL]VCRSEQ=[F:MFMM]BOMSEQ
  [F:CAL]CPLCLE=[F:MFMM]ITMREF
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MFMM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFM]
        [F:CAL]CCE(J-1)=evalue("[F:MFMM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
      WriteB [F:CAL]
  Else
      Write [CAL]
  Endif
  If fstat
     If NEWMOTEUR & adxwrb>1
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFMM, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
     Else
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFMM"-[F:MFMM]MFGNUM-num$([F:MFMM]MFGLIN)-num$([F:MFMM]BOMSEQ)
&                    -[F:MFMM]ITMREF +", Error ="-num$(fstat),1) From GESECRAN
     Endif
     GOK=0 : Return
  Endif
Return
#######################################################################
$MAJV6_MFI_CAL
  #Raz [F:CAL]
  [F:CAL]ABRFIC="MFI"
  [F:CAL]VCRNUM=[F:MFIM]MFGNUM
  [F:CAL]VCRLIN=[F:MFIM]MFGLIN
  [F:CAL]VCRSEQ=0
  [F:CAL]CPLCLE=""
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MFIM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFIM]
        [F:CAL]CCE(J-1)=evalue("[F:MFIM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
      WriteB [F:CAL]
  Else
      Write [CAL]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFIM, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
    Else
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFIM"-[F:MFIM]MFGNUM-num$([F:MFIM]MFGLIN)
&                    +", Error ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Return
  Endif
Return
#######################################################################
$MAJV6_MFO_CAL
   #Raz [F:CAL]
   [F:CAL]ABRFIC="MFO"
   [F:CAL]VCRNUM=[F:MFOM]MFGNUM
   [F:CAL]VCRLIN=[F:MFOM]OPENUM
   [F:CAL]VCRSEQ=[F:MFOM]OPESPLNUM
   [F:CAL]CPLCLE="EXTWST"
   [F:CAL]ANALIG=1
   For J=1 To max(GNBCOA,2)
     [F:CAL]LED(J-1)=GLEDSOC(J)
     [F:CAL]COA(J-1)=GCOA(J)
   Next J
   For J=1 To max(GNBDIE,GOPTCANA)
     [F:CAL]DIE(J-1)=GDIE(J)
     If evalue("dim([F:MFOM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFO]
         [F:CAL]CCE(J-1)=evalue("[F:MFOM]CCE"+num$(J))
     Endif
   Next J
   # --- alimentation des champs et écriture enreg
   If NEWMOTEUR
      Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
      WriteB [F:CAL]
   Else
      Write [CAL]
   Endif
   If fstat
     If NEWMOTEUR & adxwrb>1
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTWST, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
     Else
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTWST"-[F:MFOM]MFGNUM-num$([F:MFOM]OPENUM)-num$([F:MFOM]OPESPLNUM)
&                    -", Error ="-num$(fstat),1) From GESECRAN
     Endif
     GOK=0 : Return
   Endif
   If [F:MFOM]EXTLAB <> ""  
       #Raz [F:CAL]
       [F:CAL]ABRFIC="MFO"
       [F:CAL]VCRNUM=[F:MFOM]MFGNUM
       [F:CAL]VCRLIN=[F:MFOM]OPENUM
       [F:CAL]VCRSEQ=[F:MFOM]OPESPLNUM
       [F:CAL]CPLCLE="EXTLAB"
       [F:CAL]ANALIG=1
       #For J=1 To max(GNBCOA,2)
       #  [F:CAL]LED(J-1)=GLEDSOC(J)
       #  [F:CAL]COA(J-1)=GCOA(J)
       #Next J
       For J=1 To max(GNBDIE,GOPTCANA)
         #[F:CAL]DIE(J-1)=GDIE(J)
         If evalue("dim([F:MFOM]LABCCE"+num$(J)+")")>0
             [F:CAL]CCE(J-1)=evalue("[F:MFOM]LABCCE"+num$(J))
         Endif
       Next J
       # --- alimentation des champs et écriture enreg
       If NEWMOTEUR
          Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
          WriteB [F:CAL]
       Else
          Write [CAL]
       Endif
       If fstat
         If NEWMOTEUR & adxwrb>1
            Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTLAB, Error ="-num$(fstat),1) From GESECRAN
            Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
         Else
            Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTLAB"-[F:MFOM]MFGNUM-num$([F:MFOM]OPENUM)-num$([F:MFOM]OPESPLNUM)
&                          -", Error ="-num$(fstat),1) From GESECRAN
         Endif
         GOK=0 : Return
       Endif
  Endif
Return
