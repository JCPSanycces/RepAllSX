#<AdxTL>@(#)0.0.0.0 $Revision$
  End

Funprog ISMNGSESSIONS
# func AFNC.PARTSEP(ver$(0),2," ") --> R070.001.00002 --< TODO
If func AFNC.PARTSEP(ver$(0),2," ")>="19r.202"
 End 1 : #  [V]CST_ATRUE
Endif
End 0 : # [V]CST_AFALSE

Funprog ISMNGSESSIONSWITHCPU
If func AFNC.PARTSEP(ver$(0),2," ")>="R070.001.00010"
 End 1 : #  [V]CST_ATRUE
Endif
End 0 : # [V]CST_AFALSE

$INIT_RQT
Local Char    WSELECT(250),WWHERE(250)
Local Integer NBADDSEL : NBADDSEL=1
Local Integer POSFROM : POSFROM=50
Local Integer POSWHERE  : POSWHERE=60
Local Integer NBADDWHERE : NBADDWHERE=POSWHERE
Local Char RQT_SESSION(250)(1..)
Local File ADOVAL [ADW_]
Local Char DOSX3(GLONADS)
Read [ADW_]ADW0="";"";"SUPDOS"
If !fstat
 DOSX3 = [F:ADW_]VALEUR
Endif
LogicClose File [ADW_]
If GTYPDBA=1
 RQT_SESSION(POSFROM+1) =" from "+[L]DOSX3+".ASYSSMDBASSO X3SM1 Join "+[L]DOSX3+".ASYSSMINTERN X3SM0 on X3SM1.SESSIONID_0 = X3SM0.SESSIONID_0 "
 RQT_SESSION(POSFROM+2) =" Join v$session VDS On VDS.SID = to_number(X3SM1.DBIDENT1_0) and VDS.AUDSID = to_number(X3SM1.DBIDENT2_0) "
Else
 RQT_SESSION(POSFROM+1) =" from "+[L]DOSX3+".ASYSSMDBASSO X3SM1 Join "+[L]DOSX3+".ASYSSMINTERN X3SM0 on X3SM1.SESSIONID_0 = X3SM0.SESSIONID_0 "
 RQT_SESSION(POSFROM+2) =" Join  sys.dm_exec_connections VDS On VDS.session_id = convert(integer, X3SM1.DBIDENT1_0) "
 RQT_SESSION(POSFROM+3) =" and VDS.connect_time = convert( datetime, X3SM1.DBIDENT2_0, 121 ) "
Endif
Return

$ADD_SELECT_RQT
If RQT_SESSION(NBADDSEL)="" and NBADDSEL=1
 RQT_SESSION(NBADDSEL) = "Select "
Endif
RQT_SESSION(NBADDSEL) -= WSELECT
NBADDSEL+=1
Raz WSELECT
Return

$ADD_WHERE_RQT
If RQT_SESSION(NBADDWHERE)="" and NBADDWHERE=POSWHERE
 RQT_SESSION(NBADDWHERE) = "where "
Endif
RQT_SESSION(NBADDWHERE) -= WWHERE
NBADDWHERE+=1
Raz WWHERE
Return

$ADD_TO_LOG
Local Integer ILOG
For ILOG=1 To maxtab(RQT_SESSION)
 If RQT_SESSION(ILOG)<>""
  Call ECR_TRACE(RQT_SESSION(ILOG),0) From GESECRAN
 Endif
Next
Return

#**
#* USER_CONNECT
#* Search the number of open sessions in a user app
#*
#* @param LOGIN
#* @param APPLI
#* @param NBSES
#*!
Subprog USER_CONNECT(LOGIN,APPLI,NBSES)
Value Char LOGIN , APPLI
Variable Integer NBSES

If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = "count(*)"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT
If LOGIN<>""
 WWHERE  = " and X3SM0.ALOGIN_0='"+[L]LOGIN+"'"           : Gosub ADD_WHERE_RQT
Endif
Raz NBSES
For (Integer NBSESSIONS) From num$((GTYPDBA*2)+1)  Sql RQT_SESSION As [SYS_]
 NBSES = [F:SYS_]NBSESSIONS
 Break
Next
End

#**
#* USER_NBCON
#* To know the number of open session type and possibly for a user
#*
#* @param LOGIN
#* @param TYPSES
#* @param NBSES
#*!
Subprog USER_NBCON(LOGIN,TYPSES,NBSES)
Value Char LOGIN
Value Integer TYPSES
Variable Integer NBSES

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0"                        : Gosub ADD_SELECT_RQT
If LOGIN<>""
 WWHERE  = "X3SM0.ALOGIN_0='"+[L]LOGIN+"'"           : Gosub ADD_WHERE_RQT
Endif
Raz [L]NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If mod([SYS_]TYPE_SESSION,8)=[L]TYPSES
  [L]NBSES += 1
 Endif
Next
End

#**
#* NBCON_APPNOWEB_USER
#* To know the number of open session type on a app for user
#*
#* @param LOGIN
#* @param APPLI
#* @param TYPSES
#* @param NBSES
#*!
Subprog NBCON_APPNOWEB_USER(LOGIN,APPLI,TYPSES,NBSES)
Value Char LOGIN
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT
If LOGIN<>""
 WWHERE  = " and  X3SM0.ALOGIN_0='"+[L]LOGIN+"'"    : Gosub ADD_WHERE_RQT
Endif
Raz [L]NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If mod([SYS_]TYPE_SESSION,8)=[L]TYPSES & [SYS_]TYPE_SESSION<>25
  [L]NBSES += 1
 Endif
Next
End

#**
#* NBCON_APP_USER
#* To know the number of open session type on a app for user
#*
#* @param LOGIN
#* @param APPLI
#* @param TYPSES
#* @param NBSES
#*!
Subprog NBCON_APP_USER(LOGIN,APPLI,TYPSES,NBSES)
Value Char LOGIN
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT
If LOGIN<>""
 WWHERE  = " and  X3SM0.ALOGIN_0='"+[L]LOGIN+"'"    : Gosub ADD_WHERE_RQT
Endif
Raz [L]NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If mod([SYS_]TYPE_SESSION,8)=[L]TYPSES
  [L]NBSES += 1
 Endif
Next
End


#**
#* USER_QUI
#*
#* For the owner of a   process (adxuid (1)) to possibly send him an email inviting the unlock symbol
#*
#* @param PROCESS
#* @param DOSSIER "3643393"
#* @param CLIENT
#* @param USER
#* @param MAIL
#*!
Subprog USER_QUI(PROCESS,DOSSIER,CLIENT,USER,MAIL)
Value Char PROCESS , DOSSIER
Variable Char CLIENT , USER , MAIL

Gosub INIT_RQT
WSELECT = "X3SM0.ALOGIN_0,X3SM0.PEER_0"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.SESSIONID_0='"+[L]PROCESS+"'"                 : Gosub ADD_WHERE_RQT

Raz [L]CLIENT
For (Char SUSR(30),Char SCLI(80)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
  [L]CLIENT = [SYS_]SCLI
  [L]USER = toupper([SYS_]SUSR)
Next
If [L]USER<>""
 If DOSSIER=nomap or DOSSIER=""
  Local File AUTILIS [AUX_]
 Else
  Local File =DOSSIER+".AUTILIS" [AUX_]
 Endif
 Read [AUX_]LOGIN = [L]USER
 If !fstat
  [L]USER = [F:AUX_]USR-[F:AUX_]NOMUSR
  [L]MAIL = [F:AUX_]ADDEML
 Endif
 LogicClose File [AUX_]
Endif
End


#**
#* USER_CONADAPI
#*
#* Used to see if there are connections ADAPEI the app before switching to mono
#*
#* @param DOSSIER
#* @param NBSES
#*!
Subprog USER_CONADAPI(DOSSIER,NBSES)
Value Char DOSSIER
Variable Integer NBSES
Local Char       MACHINE(GLONAMC) , APPLI(GLONADS)
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = " X3SM0.SESSIONTYPE_0"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"                 : Gosub ADD_WHERE_RQT

Raz [L]NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
  If !find([SYS_]TYPE_SESSION,4,7,12,15,20)
  [L]NBSES += 1
 Endif
Next
End

#**
#* USER_NBCON_APP
#*
#* To know the number of open session by type of application
#*
#* @param APPLI
#* @param TYPSES
#* @param NBSES
#*
#*!
Subprog USER_NBCON_APP(APPLI,TYPSES,NBSES)
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0"                       : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"               : Gosub ADD_WHERE_RQT

Raz NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If TYPSES=0 or mod([SYS_]TYPE_SESSION,8)=[L]TYPSES
  [L]NBSES += 1
 Endif
Next
End

#**
#* NBCON_APP_USER_ADXTYP
#*
#* To know the number of adx session started by a guy on a user app
#*
#* @param LOGIN
#* @param APPLI
#* @param TYPSES
#* @param NBSES
#*!
Subprog NBCON_APP_USER_ADXTYP(LOGIN,APPLI,TYPSES,NBSES)
Value Char LOGIN
Value Char APPLI
Value Integer TYPSES
Variable Integer NBSES
If APPLI="" : APPLI = nomap : Endif
Local Char RQT_NBCON_APP_USER_ADXTYP(250)(1..)
[L]RQT_NBCON_APP_USER_ADXTYP(1) = "select X3SM0.SESSIONTYPE_0 "
[L]RQT_NBCON_APP_USER_ADXTYP(2) = "from SUPERV.ASYSSMDBASSO X3SM1 Join SUPERV.ASYSSMINTERN X3SM0 on X3SM1.SESSIONID_0 = X3SM0.SESSIONID_0 "
[L]RQT_NBCON_APP_USER_ADXTYP(3) = "Join v$session VDS On VDS.SID = to_number(X3SM1.DBIDENT1_0) and VDS.AUDSID = to_number(X3SM1.DBIDENT2_0) "
[L]RQT_NBCON_APP_USER_ADXTYP(4) = "where  X3SM0.FOLD_0='"+[L]APPLI+"'"

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0"                       : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"               : Gosub ADD_WHERE_RQT
If LOGIN<>""
 WWHERE  = " and  X3SM0.ALOGIN_0='"+[L]LOGIN+"'"      : Gosub ADD_WHERE_RQT
Endif
Raz NBSES
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If [SYS_]TYPE_SESSION=[L]TYPSES
  [L]NBSES += 1
 Endif
Next
End


#**
#* USER_LISTE
#*
#* For a list of connected users on an app
#*
#* @param APPLI
#* @param NBUSR
#* @param LISTE
#*!
Subprog USER_LISTE(APPLI,NBUSR,LISTE)
Value Char APPLI
Variable Integer NBUSR
Variable Char LISTE
If APPLI="" : APPLI = nomap : Endif

Local Char WTABUSR(250)(1..)
Local Integer WTABNUMUSR(1..)
Local Integer WNBUSR,IFOUND,WSER

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONTYPE_0,X3SM0.ALOGIN_0,X3SM0.PEER_0"                       : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"                                           : Gosub ADD_WHERE_RQT

Raz NBUSR , LISTE
For (Integer TYPE_SESSION, Char USER(30),Char CLIENT(80)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 WSER=[F:SYS_]TYPE_SESSION
 If find([F:SYS_]TYPE_SESSION,25,33)>0 : WSER=825 : Endif
 IFOUND=find([F:SYS_]USER-num$(WSER)-[F:SYS_]CLIENT,WTABUSR(1..WNBUSR))
 If IFOUND
   WTABNUMUSR(IFOUND)+=1
   If WTABNUMUSR(IFOUND)<>2 | find(adxtyp,25,33)=0
    NBUSR += 1
   Endif
 Else
  NBUSR += 1
  WNBUSR+=1
  WTABUSR(WNBUSR)=[F:SYS_]USER-num$(WSER)-[F:SYS_]CLIENT
  WTABNUMUSR(WNBUSR)+=1
  If !instr(1,LISTE," "+[F:SYS_]USER+" ")
   LISTE += " "+[F:SYS_]USER+" "
  Endif
 Endif
Next SYS_
If LISTE<>""
 LISTE = "("+vireblc(LISTE,2)+")"
Endif
End

#**
#* LOGIN
#*
#* What is my login?
#*!
Funprog LOGIN
Local Char LOGIN_RESEAU(30)
Gosub INIT_RQT
WSELECT = "X3SM0.SYSTEMUSER_0"                                                                : Gosub ADD_SELECT_RQT
#SAM 121093
#WWHERE  = "X3SM0.SESSIONID_0="+num$(adxuid(1))+" and X3SM0.LAN_0='"+GLANGUE+"'"               : Gosub ADD_WHERE_RQT
WWHERE  = "X3SM0.SESSIONID_0="+num$(adxuid(1))               : Gosub ADD_WHERE_RQT
For (Char LOGIN(30)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 [L]LOGIN_RESEAU = [F:SYS_]LOGIN
 Break
Next
End [L]LOGIN_RESEAU


#**
#* MYPC
#*
#* What is my machine?
#*
#*!
Funprog MYPC
Local Char PC(80)
Gosub INIT_RQT
WSELECT = "X3SM0.PEER_0"                                                                      : Gosub ADD_SELECT_RQT
#SAM 121093
#WWHERE  = "X3SM0.SESSIONID_0="+num$(adxuid(1))+" and X3SM0.LAN_0='"+GLANGUE+"'"               : Gosub ADD_WHERE_RQT
WWHERE  = "X3SM0.SESSIONID_0="+num$(adxuid(1))                      : Gosub ADD_WHERE_RQT
For (Char CLIENT(30)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 [L]PC = [F:SYS_]CLIENT
 Break
Next
If PC="" : # If the user's session is not yet registered (connected)
 PC = adxmac(-2)
Endif
End [L]PC

#**
#* LOGIN_CPU
#*
#* @param USER
#* @param APPLI
#* @param UID
#* @param LOGIN
#* @param CPU
#*!
Subprog LOGIN_CPU(USER,APPLI,UID,LOGIN,CPU)
Value Char USER , APPLI , UID
Variable Char LOGIN , CPU
If [L]APPLI="" : [L]APPLI = nomap : Endif
If [L]USER=""  : [L]USER  = GUSER : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SYSTEMUSER_0"                                                                                                     : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"+" and X3SM0.ALOGIN_0='"+[L]USER+"'"+" and X3SM0.SESSIONID_0="+num$(adxuid(1))              : Gosub ADD_WHERE_RQT

Raz LOGIN,CPU
For (Char SYSTEM_USER(80)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 [L]LOGIN = [F:SYS_]SYSTEM_USER
 [L]CPU   = "deprecated"
 Break
Next

End

#**
#* CHARGE_UID
#*
#* List of ssession ID with language
#*
#* @param TBUID
#* @param NBUID
#*!
Subprog CHARGE_UID(TBUID,NBUID)
Variable Char TBUID()(1..)
Variable Integer NBUID
Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0"                     : Gosub ADD_SELECT_RQT
#SAM 121093
#WWHERE  = "X3SM0.LAN_0='"+GACTX.LAN+"'"             : Gosub ADD_WHERE_RQT
Raz TBUID , NBUID
For (Integer IDSESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If NBUID=dim(TBUID) : Break : Endif
 NBUID += 1
 TBUID(NBUID) = num$([F:SYS_]IDSESSION)
Next
End

#**
#* KILL_ALLPROC
#*
#* Lets killer all processes of a adxuid (1)
#*
#* @param UID
#*!
Subprog KILL_ALLPROC(UID)
Value Char UID

Local Char MESSA(250),ERRMES(250)
Local Char RQT_KILL_PROCESS(250)(1..), PROCESS(100), OUTPUT_LOGNAME(100)
Local Integer UIDEXIST, HTTP_STATUS, LECTRACE
Local Clbfile OUTPUT_RESHEAD(0), OUTPUT_RESBODY(0)

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0,X3SM0.PEER_0,X3SM0.REMOTE_0,X3SM0.ALOGIN_0"                                : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.SESSIONID_0="+[L]UID                                                                   : Gosub ADD_WHERE_RQT
[L]LECTRACE=[V]CST_ANO

  For (Integer IDSESSION,Char CLIENT(80),Char SERVER(80) , Char USER(20) ) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
    [L]MESSA = [F:SYS_]CLIENT-[F:SYS_]SERVER-[F:SYS_]USER
    UIDEXIST = [F:SYS_]IDSESSION
  Next

  # 2018-01-13 - JPGA X3-64517 : Adding-session-kill-button-in-PSADX-APSDX
  # We initiate the Session closure calling a SYRACUSE function
  If UIDEXIST>0
    Raz PROCESS
    [L]RQT_KILL_PROCESS(1) = "select ASM2.SYSTEMID_0,ASM2.SESSIONID_0,ASM2.SERVER_0 "
    [L]RQT_KILL_PROCESS(2) = "from "+[L]DOSX3+".ASYSSMPROCES ASM2 "
    [L]RQT_KILL_PROCESS(4) = "where  ASM2.SESSIONID_0="+[L]UID

    For (Integer IDSYSTEM,Integer SESSION,Char SERVER(80)  ) From num$((GTYPDBA*2)+1)  Sql [L]RQT_KILL_PROCESS As [SYS_]
      PROCESS -= num$([SYS_]IDSYSTEM)
    Next
    Call CLOSE_SOCKET_WITH_LOG([L]UID, null, PROCESS, [L]MESSA, [L]LECTRACE, [L]OUTPUT_LOGNAME) From ASESSIONS
  Endif
End

#**
#* USER_SYS
#*
#* @param USRSYS
#* @param USRCLI
#*!
Subprog USER_SYS(USRSYS,USRCLI)
Variable Char USRSYS
Variable Char USRCLI
Gosub INIT_RQT
WSELECT = "X3SM0.SYSTEMUSER_0,X3SM0.PEER_0"                                                                     : Gosub ADD_SELECT_RQT
WWHERE  = " X3SM0.ALOGIN_0='"+GUSER+"' and X3SM0.FOLD_0='"+nomap+"'"+" and X3SM0.SESSIONID_0="+num$(adxuid(1))  : Gosub ADD_WHERE_RQT
Raz USRSYS,USRCLI
For (Char SYSTUSR(0),Char CLIENT(80)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 USRSYS = [SYS_]SYSTUSR
 USRCLI = [SYS_]CLIENT
 Break
Next
End

#**
#* PROCESS_RUNNING
#*
#* Returns true if the process is still running
#*
#* @param PROCESS_ID
#*!
Funprog PROCESS_RUNNING(PROCESS_ID)
Value Integer PROCESS_ID

  Local Integer OK
  OK=[V]CST_AFALSE

  Gosub INIT_RQT
  WSELECT = "X3SM0.SESSIONID_0"                                : Gosub ADD_SELECT_RQT
  WWHERE  = "X3SM0.SESSIONID_0="+num$([L]PROCESS_ID)           : Gosub ADD_WHERE_RQT
  For (Integer IDSESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
    OK = [V]CST_ATRUE
    Break
  Next
End OK

#**
#* USER_MODULE
#*
#* @param SID
#* @param SCLI
#* @param SDOS
#* @param SFCT
#* @param SMOD
#*!
Subprog USER_MODULE(SID,SCLI,SDOS,SFCT,SMOD,NBSES)
Variable Char SID()(1..)
Variable Char SCLI()(1..)
Variable Char SDOS()(1..)
Variable Char SFCT()(1..)
Variable Char SMOD()(1..)
Variable Integer NBSES
Local Char CURLOG(30)
Local Integer WMODULE
Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0,X3SM0.ALOGIN_0,X3SM0.FOLD_0" : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.SESSIONID_0<>"+num$(adxuid(1))              : Gosub ADD_WHERE_RQT
Raz SID,SCLI,SDOS,SFCT,SMOD
For (Integer IDSESSION,Char USER(30),Char DOSSIER(GLONADS)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 NBSES+=1
 SID(NBSES) = num$([F:SYS_]IDSESSION)
 SCLI(NBSES) = [F:SYS_]USER
 SDOS(NBSES) = [F:SYS_]DOSSIER
 # jira X3-67545 wrong argument for module must ne a integer
 # jira X3-80294 smod is variable char so replace by a integer
 WMODULE = val(SMOD(NBSES))
 Call GET_CURFCT(adxmac(0),SDOS(NBSES),num$([F:SYS_]IDSESSION),SFCT(NBSES),WMODULE,CURLOG) From PSADX
 SMOD(NBSES) = num$(WMODULE)
Next
End


