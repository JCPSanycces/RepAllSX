#*!
Funprog IS_PROCESS_EXIST(PID)
Value Integer PID
Local Integer OK
Local File ASYSSMPROCES [ASM2]
For [F:ASM2]SESSIONID Where  SYSTEMID=[L]PID
 [L]OK = 1
Next
End [L]OK

#**
#* IS_SESSION_EXISTENT_IN_ASYSSMDBASSO *** Is a session still in Main Session table : ASYSSMDBASSO ?
#*
#* @param SESSIONID : the X3 session ID (=adxuid(1))
#* @return 1 if the session is still alive
#*!
Funprog IS_SESSION_EXISTENT_IN_ASYSSMDBASSO(SESSIONID)
Value Integer SESSIONID
Local Integer OK
Local File ASYSSMDBASSO [ASM3]
Look [F:ASM3]SESSIONID=[L]SESSIONID
If !fstat
    [L]OK = 1
Endif
LogicClose File [ASM3]
End [L]OK

######################################################################################
# FUNCTIONS AND LABELS USED IN DELETION OF DEAD SESSIONS                 --- BEGIN ---
######################################################################################
##########################
#**
#* IS_ROOT_FOLDER ****** Is folder given as INPUT a ROOT folder ?
#*
#* @param FOLDER_INPUT
#*
#* @return RETURN_CODE = 0 : NO  - it is not a ROOT folder <br>
#*         RETURN_CODE = 1 : YES - it is a ROOT folder
#*!
Funprog IS_ROOT_FOLDER (FOLDER_INPUT)
Value Char    FOLDER_INPUT()

End FOLDER_INPUT=adxmother

##########################
#**
#* RAZ_DEAD_SESSION **** MAIN Stand alone Funprog to delete every inactive sessions in X3
#*
#* @param FOLDER_INPUT : INPUT folder used to find X3 session tables so as to delete sessions
#* @param NBDEL_ASM3   : Number of records deleted in ASYSSMDBASSO session table
#* @param NBDEL_ASM0   : Number of records deleted in ASYSSMINTERN session table
#* @param NBDEL_ASM1   : Number of records deleted in ASYSSMEXTERN session table
#* @param NBDEL_ASM2   : Number of records deleted in ASYSSMPROCES session table
#* @param MESSAGE      : Message returned in case of error
#*
#* @return RETURN_CODE = 0 : successful execution <br>
#*         RETURN_CODE = 1 : FOLDER has to be a ROOT folder <br>
#*         RETURN_CODE = 9 : SQL error encountered while trying to delete sessions
#*!
Funprog RAZ_DEAD_SESSION(FOLDER_INPUT, NBDEL_ASM3, NBDEL_ASM0, NBDEL_ASM1, NBDEL_ASM2, MESSAGE)
Value Char       FOLDER_INPUT
Variable Integer NBDEL_ASM3
Variable Integer NBDEL_ASM0
Variable Integer NBDEL_ASM1
Variable Integer NBDEL_ASM2
Variable Char    MESSAGE

Local Integer    RETURN_CODE

  [L]RETURN_CODE=[V]CST_AOK

  # FOLDER has to be a ROOT folder
  If !func ASESSIONS.IS_ROOT_FOLDER ([L]FOLDER_INPUT)
    MESSAGE        = [L]FOLDER_INPUT+" : "+mess(80,127,1) : # Vous devez être connecté sur le dossier racine
    [L]RETURN_CODE = 1
  Else
    #### STEP 1 : To be done before the rest !!! Deletion of every DEAD session in DB table looking into database. Using table    : ASYSSMDBASSO
    [L]RETURN_CODE    = func RAZ_DEAD_SESSION_DETAIL ([L]FOLDER_INPUT, "ASYSSMDBASSO", NBDEL_ASM3, MESSAGE)

    #### STEP 2 : No More DEAD session exist in ASYSSMDBASSO , Deletion of every remaining DEAD session in internal table         : ASYSSMINTERN
    If [L]RETURN_CODE = [V]CST_AOK
       [L]RETURN_CODE = func RAZ_DEAD_SESSION_DETAIL ([L]FOLDER_INPUT, "ASYSSMINTERN", NBDEL_ASM0, MESSAGE)
    Endif

    #### STEP 3 : No More DEAD session exist in ASYSSMDBASSO , Deletion of every remaining DEAD session in external process table : ASYSSMEXTERN
    If [L]RETURN_CODE = [V]CST_AOK
       [L]RETURN_CODE = func RAZ_DEAD_SESSION_DETAIL ([L]FOLDER_INPUT, "ASYSSMEXTERN", NBDEL_ASM1, MESSAGE)
    Endif

    #### STEP 4 : No More DEAD session exist in ASYSSMDBASSO , Deletion of every remaining DEAD session in internal process table : ASYSSMPROCES
    If [L]RETURN_CODE = [V]CST_AOK
       [L]RETURN_CODE = func RAZ_DEAD_SESSION_DETAIL ([L]FOLDER_INPUT, "ASYSSMPROCES", NBDEL_ASM2, MESSAGE)
    Endif
  Endif
End [L]RETURN_CODE

##########################
#**
#* RAZ_DEAD_SESSION_DETAIL **** SUB Generic Funprog to delete every inactive sessions in every Session tables
#*
#* @param DOSX3            : INPUT folder used to find X3 session tables so as to delete sessions
#* @param NBDEL            : Number of records deleted in session table
#* @param TABLE_FOR_DELETE : Table Name to use for deletion
#* @param MESSAGE          : Message returned in case of error
#*
#* @return RETURN_CODE = 0 : successful execution <br>
#*         RETURN_CODE = 9 : SQL error encountered while trying to delete sessions
#*!
Funprog RAZ_DEAD_SESSION_DETAIL (DOSX3, TABLE_FOR_DELETE, NBDEL, MESSAGE)
Value Char       DOSX3
Value Char       TABLE_FOR_DELETE
Variable Integer NBDEL
Variable Char    MESSAGE

Local Integer    RETURN_CODE

  [L]RETURN_CODE=[V]CST_AOK

  # Initializations for SQL request
  Local Char WSELECT(250),WFROM(250),WWHERE(250)
  Local Char TABLE_WITH_PREFIX(50)
  Local Char RQT_SESSION(250)(1..20)
  Raz [L]WSELECT, [L]WFROM, [L]WWHERE, [L]TABLE_WITH_PREFIX

  [L]TABLE_WITH_PREFIX=DOSX3+"."+TABLE_FOR_DELETE
  Case TABLE_FOR_DELETE
    When "ASYSSMDBASSO"  : # Deletion for MAIN Session table : ASYSSMDBASSO
      # Deleting every sessions not found into Database table V$session (for Oracle) or dm_exec_connections (for Sql server)
      [L]WSELECT   = " Delete"
      [L]WFROM     = " From "+[L]TABLE_WITH_PREFIX
      If GTYPDBA=1
        [L]WWHERE  = " Where Not exists ( Select 'X' From v$session VDS"
        [L]WWHERE +=                    " Where VDS.SID    = to_number("+[L]TABLE_WITH_PREFIX+".DBIDENT1_0)"
        [L]WWHERE +=                      " And VDS.AUDSID = to_number("+[L]TABLE_WITH_PREFIX+".DBIDENT2_0) )"
      Else
        [L]WWHERE  = " Where Not exists ( Select 'X' From sys.dm_exec_connections VDS"
        [L]WWHERE +=                    " Where VDS.session_id   = convert(integer, " +[L]TABLE_WITH_PREFIX+".DBIDENT1_0)"
        [L]WWHERE +=                      " And VDS.connect_time = convert(datetime, "+[L]TABLE_WITH_PREFIX+".DBIDENT2_0, 121 ) )"
      Endif
    When Default         : # Deletion for 3 other Session tables : ASYSSMINTERN, ASYSSMEXTERN, ASYSSMPROCES
      # After having deleted every DEAD session into ASYSSMDBASSO table, deleting every remaining DEAD sesssion into 3 other session tables
      [L]WSELECT   = " Delete"
      [L]WFROM     = " From "+[L]TABLE_WITH_PREFIX
      [L]WWHERE    = " Where Not exists ( Select 'X' From "+DOSX3+".ASYSSMDBASSO X3_SM3"
      [L]WWHERE   +=                    " Where X3_SM3.SESSIONID_0 = "+[L]TABLE_WITH_PREFIX+".SESSIONID_0 )"
  Endcase

  # FILLING SQL request
  Raz RQT_SESSION
  [L]RQT_SESSION(1)  = [L]WSELECT
  [L]RQT_SESSION(5)  = [L]WFROM
  [L]RQT_SESSION(10) = [L]WWHERE

  Onerrgo SQL_ERROR
    Execsql From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION
  Onerrgo
  If [L]RETURN_CODE <> [V]CST_AOK : End [L]RETURN_CODE : Endif

  NBDEL=adxSqlRec
End [L]RETURN_CODE
$SQL_ERROR
  MESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm+"\"+"\"+mess(245,100,1)+" :"+"\"+[L]RQT_SESSION(1)+"\"+[L]RQT_SESSION(5)+"\"+[L]RQT_SESSION(10)
  RETURN_CODE=9
Resume
######################################################################################
# FUNCTIONS AND LABELS USED IN DELETION OF DEAD SESSIONS                   --- END ---
######################################################################################

# X3-67314 - JPGA - 2017-12-12 : Manage the kill of a session in psadx or apsadx
######################################################################################
# FUNCTIONS AND LABELS USED IN SESSION KILL BY SOCKET CLOSURE            --- BEGIN ---
######################################################################################
##########################
#**
#* CLOSE_SOCKET_WITH_LOG **** Funprog to call syracuse to close a socket - Writing closure information in log file
#*
#* @param CONNECTIONID : SESSIONID of the socket (adxuid(1))
#* @param APSADX       : if not null : APSADX instance of C_APSADX classe to use Class log file else old Trace file management is used
#* @param PROCESS_LIST : List of processes for a SESSION (CONNECTIONID) to put as information in log file
#* @param INFO_MESSAGE : Additionnal information to put in log file such as Client, folder ...
#* @param LECTRACE     : In Old Log file management only, if [V]CST_AYES we call LEC_TRACE at end of process else [V]CST_ANO
#*
#* @return OUTPUT_LOGNAME : (In case of error only) Name of the LOG file generated <br>
#*! -
Subprog CLOSE_SOCKET_WITH_LOG(CONNECTIONID, APSADX, PROCESS_LIST, INFO_MESSAGE, LECTRACE, OUTPUT_LOGNAME)
Value Char        CONNECTIONID
Value Instance APSADX      Using C_APSADX
Value Char        PROCESS_LIST
Value Char        INFO_MESSAGE
Value Integer     LECTRACE
Variable Char     OUTPUT_LOGNAME()

Local Char      MESSAGE(250), MESSAGE2(250), FICLOG_NAME(250)
Local Integer   TRA , STAT, HTTP_STATUS, IS_CLASS_CONTEXT
Local Clbfile   OUTPUT_RESHEAD(0), OUTPUT_RESBODY(0)
Local Instance  FICLOG       Using C_ALOG

  [L]FICLOG_NAME=""
  TRA = 1                                                                       : # Kill details in LOG
  If (APSADX = null)                                                            : # Are we in Class environment or not
    IS_CLASS_CONTEXT = [V]CST_ANO
  Else
    IS_CLASS_CONTEXT = [V]CST_AYES
  Endif

  MESSAGE = mess(248,100,1)-CONNECTIONID-"("+INFO_MESSAGE+")"                   : # Session closure
  If IS_CLASS_CONTEXT = [V]CST_AYES
    If TRA
      FICLOG=NewInstance C_ALOG AllocGroup null
      STAT=fmet FICLOG.ABEGINLOG(MESSAGE)
      [L]FICLOG_NAME=fmet FICLOG.AGETNAME()
      If PROCESS_LIST <> ''
        STAT=fmet FICLOG.APUTLINE(mess(90,134,1)-":"-PROCESS_LIST,[V]CST_AINFO) : # Process list
      Endif
    Endif
  Else
    Call WORKFLOW(1,"KIL","",GUSER) From AWRK
    If TRA
      Call OUVRE_TRACE(MESSAGE) From LECFIC
      [L]FICLOG_NAME=GTRACE
      If PROCESS_LIST <> ''
        Call ECR_TRACE(mess(90,134,1)-":"-PROCESS_LIST, 0) From GESECRAN        : # Process list
      Endif
    Endif
  Endif

  HTTP_STATUS = func ASESSIONS.CLOSE_SOCKET_BY_SESSIONID(CONNECTIONID, [L]OUTPUT_RESHEAD, [L]OUTPUT_RESBODY)
  If HTTP_STATUS =[V]CST_AHTTP_OK  : # If HTTP response is Ok  : socket has been closed correctly
    OUTPUT_LOGNAME=""                                                                 : # No error found so : No trace log file sent
    MESSAGE=mess(249,100,1)-"-"-mess(128,134,1)-":"-num$([L]HTTP_STATUS)              : # Session correctly closed by Syracuse
    MESSAGE2=mess(249,100,1)-":"-CONNECTIONID
    If IS_CLASS_CONTEXT = [V]CST_AYES
      If TRA
        STAT = fmet FICLOG.APUTLINE(MESSAGE, [V]CST_AINFO)
      Endif
      STAT = fmet APSADX.ASETERROR("",MESSAGE2, [V]CST_AINFO)
    Else
      If TRA
        Call ECR_TRACE(MESSAGE, 0) From GESECRAN
      Endif
    Endif
  Else
    OUTPUT_LOGNAME=[L]FICLOG_NAME  : # An error occured so we put the trace log file generated as output parameter
    MESSAGE=mess(250,100,1)-CONNECTIONID-"-"-mess(128,134,1)-":"-num$([L]HTTP_STATUS) : # HTTP error encountered in session closure
    If IS_CLASS_CONTEXT = [V]CST_AYES
      If TRA
        STAT = fmet FICLOG.APUTLINE(MESSAGE, [V]CST_AERROR)
        Call WRITE_FICLOG_RESHEAD(FICLOG, [L]OUTPUT_RESHEAD) From ASESSIONS
      Endif
      STAT = fmet APSADX.ASETERROR("",MESSAGE, [V]CST_AERROR)
    Else
      If TRA
        Call ECR_TRACE(MESSAGE, 0) From GESECRAN
        Call WRITE_FICLOG_RESHEAD(null, [L]OUTPUT_RESHEAD) From ASESSIONS
      Endif
    Endif
  Endif

  If TRA
    If IS_CLASS_CONTEXT = [V]CST_AYES
      STAT = fmet FICLOG.AENDLOG
      STAT = fmet APSADX.ASETERROR("",mess(135,126,1)-fmet FICLOG.AGETNAME, [V]CST_AINFO) : # Info Consulter le fichier de trace
      FreeGroup FICLOG
    Else
      Call FERME_TRACE From LECFIC
      If [L]LECTRACE=[V]CST_AYES : # [L]LECTRACE must be set to [V]CST_AYES or [V]CST_ANO
        Call LEC_TRACE From LECFIC
      Endif
    Endif
  Endif
End

##########################
#**
#* CLOSE_SOCKET_BY_SESSIONID **** Funprog to call syracuse to close a socket giving as input the SESSIONID
#*
#* @param CONNECTIONID : SESSIONID of the socket (adxuid(1)
#* @param RESHEAD      : http response HEAD
#* @param RESBODY      : http response BODY
#*
#* @return STATUSCODE  = 200  : HTTP success - CST_AHTTP_OK=200 <br>
#*         STATUSCODE != 200  : HTTP error.
#*! -
Funprog CLOSE_SOCKET_BY_SESSIONID(CONNECTIONID, RESHEAD, RESBODY)
Value    Char    CONNECTIONID
Variable Clbfile RESHEAD, RESBODY

Local Clbfile ARGUMENTS(0)
Local Integer STATUSCODE

    # [L]ARGUMENTS  = '{"connectionId": "' + CONNECTIONID + '"}'  : # Json no more used as INPUT parameter format.
    [L]ARGUMENTS  = CONNECTIONID
    [L]STATUSCODE = func SYRA_WAIT_CALL('syracuse-4gl-api/lib/session', 'closeX3Connection', [L]ARGUMENTS, [L]RESHEAD, [L]RESBODY)
End [L]STATUSCODE

##########################
#**
#* SYRA_WAIT_CALL **** SUB Funprog to wait for syracuse call
#*
#* @param MODULE       : syracuse module to call
#* @param FUNCTION     : syracuse function to invoke in module
#* @param ARGUMENTS    : syracuse arguments to give to function invoked in module
#* @param RESHEAD      : http response HEAD
#* @param RESBODY      : http response BODY
#*
#* @return STATUSCODE  = 200  : HTTP success - CST_AHTTP_OK=200 <br>
#*         STATUSCODE != 200  : HTTP error.
#*! -
Funprog SYRA_WAIT_CALL(MODULE, FUNCTION, ARGUMENTS, RESHEAD, RESBODY)
Value Char       MODULE, FUNCTION
Variable Clbfile ARGUMENTS, RESHEAD, RESBODY

Local Integer    STATUSCODE

    [L]STATUSCODE = [V]CST_AHTTP_INTERNAL   : # On HTTP server error : CST_AHTTP_INTERNAL=500
    Onerrgo ERR_SYRA_CALL
    [L]STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FUNCTION, 'wait', ARGUMENTS, '', 0, '', '0', RESHEAD, RESBODY)
    Onerrgo
End [L]STATUSCODE
$ERR_SYRA_CALL
Resume

##########################
#**
#* WRITE_FICLOG_RESHEAD **** SUB subprog to write into a LOG the RESHEAD content received by HTTP request
#*
#* @param FICLOG       : if not null : LOG file instance of C_ALOG else old Trace file management is used
#* @param RESHEAD      : http response HEAD - Format exemple : {"statusCode":"404","message":"Cannot find module 'syracuse-4gl-api/lib/session.ts'"}
#*
#*! -
Subprog WRITE_FICLOG_RESHEAD(FICLOG, RESHEAD)
Value Instance  FICLOG     Using C_ALOG
Value Clbfile   RESHEAD

Local Integer   STAT
Local Instance  NODES(1..) Using C_ASYRJSO
Local Instance  NODE       Using C_ASYRJSO
Local Instance  NODEPRO    Using C_ASYRJSO
Local Char      CNT(250)

  STAT = func ASYRJSONPARSE.PARSEJSON(GACTX, RESHEAD, [L]NODES, [L]NODE)
  While NODE <> null
    CNT = seg$(fmet NODE.AGETCNT,2,len(fmet NODE.AGETCNT)-1)
    If FICLOG = null
      Call ECR_TRACE(NODE.PRO+" : "+CNT, 1) From GESECRAN
    Else
      STAT=fmet FICLOG.APUTLINE(NODE.PRO+" : "+CNT, [V]CST_AERROR)
    Endif
    NODE = NODE.NEX
  Wend
  FreeGroup  NODES(1)
End

######################################################################################
# FUNCTIONS AND LABELS USED IN SESSION KILL BY SOCKET CLOSURE              --- END ---
