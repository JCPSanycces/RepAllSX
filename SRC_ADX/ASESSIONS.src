#**
#* PROCLI
#*
#* Get the process of a client No.
#*
#* @param APPLI
#* @param CLIENT
#* @param PORT
#* @param SESSION
#* @param PROCESS
#*!
Subprog PROCLI(APPLI,CLIENT,PORT,SESSION,PROCESS)
Value    Char APPLI , CLIENT
Value Integer PORT , SESSION
Variable Char PROCESS()(1..)

Local  Char   SPRO(250) , ORDSYS(250)
Local Integer I , LIGENT , K , NBPROC ,UIDEXIST, WAND
Local File ASYSSMPROCES [ASM2]

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0,X3SM0.PEER_0,X3SM0.REMOTE_0,X3SM0.ALOGIN_0"                                : Gosub ADD_SELECT_RQT
If [L]APPLI<>""
 WWHERE  = " X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT
 WAND =1
Endif
If [L]CLIENT<>""
 If WAND>0 :WWHERE  = " and " : Endif
 WWHERE  += " X3SM0.PEER_0='"+[L]CLIENT+"'"     : Gosub ADD_WHERE_RQT
 WAND =1
Endif
If [L]SESSION>0
 If WAND>0 :WWHERE  = " and " : Endif
 WWHERE  += " X3SM0.SESSIONTYPE_0="+num$([L]SESSION)     : Gosub ADD_WHERE_RQT
 WAND =1
Endif
If [L]SESSION>0
 If WAND>0 :WWHERE  = " and " : Endif
 WWHERE  += " X3SM0.SESSIONTYPE_0="+num$([L]SESSION)     : Gosub ADD_WHERE_RQT
 WAND =1
Endif

For (Integer IDSESSION,Char CLIENT(80),Char SERVER(80) , Char USER(20) ) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 For [F:ASM2]SESSIONID Where SESSIONID=[SYS_]IDSESSION
   K = (APPLI="" or [F:ASM2]D=APPLI)
   K *= (CLIENT="" or [F:SYS_]SCLI=CLIENT)
   K *= (PORT=0 or [F:SYS_]SPORT=num$(PORT))
   K *= (SESSION=0 or [F:SYS_]SSER=num$(SESSION))
   If K
    If NBPROC>=dim(PROCESS)
     Break
    Else
     NBPROC += 1
     PROCESS(NBPROC) = [F:SYS_]SPRO
     I = instr(1,PROCESS(NBPROC),":")
     If I
      PROCESS(NBPROC) = left$(PROCESS(NBPROC),I-1)
     Endif
    Endif
   Endif
 Next
Next
LogicClose File [ASM2]
End

#**
#* LIBRE_ASESSION
#*
#* ECLIPSE
#*
#* @param LOGIN
#* @param CURSID
#* @param APPLI
#* @param OK
#* @param NBSES
#*!
Subprog LIBRE_ASESSION(LOGIN,CURSID,APPLI,OK,NBSES)
Value    Char    LOGIN
Value    Integer CURSID
Value    Char    APPLI
Variable Integer OK , NBSES
Local Char    SID(12) , SCLI(80) , SUSR(30) , SDOS(30) , STYP(10)
Local Char    FONCTION(GLONAFC) , CURLOG(30)
Local Integer MODULE
Local Integer WAND

If APPLI="" : APPLI = toupper(nomap) : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0,X3SM0.PEER_0,X3SM0.FOLD_0,X3SM0.ALOGIN_0,X3SM0.SESSIONTYPE_0 "              : Gosub ADD_SELECT_RQT
If [L]APPLI<>""
 WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"     : Gosub ADD_WHERE_RQT
 WAND = 1
Endif
If [L]LOGIN<>""
 If WAND>0 :WWHERE  = " and " : Endif
 WWHERE += " X3SM0.ALOGIN_0='"+LOGIN+"'"    : Gosub ADD_WHERE_RQT
Endif

# Il faut que l'utilisateur soit déjà connecté sur une session libre (Client qui n'est pas dans une fonction)
For (Integer IDSESSION,Char CLIENT(80),Char FOLD(GLONADS) , Char USER(20),Integer TYPESESSION ) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 # Sessions éligibles : primaire et secondaire
 #If [F:SYS_]SID<>num$(CURSID) & find(val([F:SYS_]STYP),1,2)
 If [F:SYS_]IDSESSION<>CURSID & (mod([F:SYS_]TYPESESSION,8)=1 or mod([F:SYS_]TYPESESSION,8)=2)
  NBSES += 1
  FONCTION = ""
  Call GET_CURFCT(adxmac(0),APPLI,num$([F:SYS_]IDSESSION),FONCTION,MODULE,CURLOG) From PSADX
  # APTLREQ and APTLOB are pseudo functions for portal internal use
  If find(FONCTION, "", "APTLREQ", "APTLOBJ")
   OK = 1 : Break
  Endif
 Endif
Next
End

#**
#* GET_PID_OSLOGIN
#*
#* ECLIPSE
#*
#* @param PID
#*!
Funprog GET_PID_OSLOGIN(PID)
Value Integer PID

Local Char FILTERS(50), OSLOGIN(50), COMMAND(250)

Local File ASYSSMPROCES [ASM2]
Local File ASYSSMINTERN [ASM0]
For [F:ASM2]SESSIONID Where  SYSTEMID=[L]PID
 Read [ASM0]SESSIONID = [F:ASM2]SESSIONID
 If !fstat
  OSLOGIN = [ASM0]SYSTEMUSER
  Break
 Endif
Next
LogicClose File [ASM2],[ASM0]

End OSLOGIN


#**
#* GET_SESSIONS_EX
#*
#* ECLIPSE
#*
#* @param FOLDER_FILTER
#* @param FILTERS
#*!
Funprog GET_SESSIONS_EX(FOLDER_FILTER, FILTERS)
Value Char FOLDER_FILTER()
Value Char FILTERS()

Local Integer POS,I

If dim(GXDT_VALUE_SEP)<0 : I= func AXDTMAIN.INIT_VARIABLES() : Endif

If not GXDT_AUTH : End "" : Endif

Local Char ID(250)
Local Char PORT(250)
Local Char CLI(250)
Local Char TYP(25)
Local Char PROC(250)
Local Char PROCID(250)
Local Char USER(250)
Local Char UID(250)
Local Char ADDR(250)
Local Char FLDR(250)

Local Char    WFUNCTION(250)
Local Integer WMODULE
Local Char    WLOGIN(250)

Local Integer PORT_NUM

Local Integer POS,I
Local Clbfile SESSIONS(6)
SESSIONS = ""


Local File ASYSSMPROCES [ASM2]

Local Integer WAND

# X3SM0.SESSIONID_0,X3SM0.FOLD_0,X3SM0.LAN,X3SM0.SOLUTION_0,X3SM0.MODULE_0,X3SM0.FONCTION_0,X3SM0.SESSIONTYPE_0,
# X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.CREDATTIM_0,X3SM0.UPDDATTIM_0,X3SM0.ALOGIN_0,X3SM0.UPDUSR_0
Gosub INIT_RQT From ASESSIONS
WSELECT = "X3SM0.SESSIONID_0,X3SM0.FOLD_0,X3SM0.LAN_0,X3SM0.SOLUTION_0,X3SM0.SESSIONTYPE_0,"
Gosub ADD_SELECT_RQT From ASESSIONS
WSELECT = "X3SM0.REMOTE_0,X3SM0.PEER_0,X3SM0.SYSTEMUSER_0,X3SM0.NATURE_0,X3SM0.ALOGIN_0,X3SM0.UPDUSR_0,X3SM0.CREDATTIM_0"
Gosub ADD_SELECT_RQT From ASESSIONS
If FOLDER_FILTER<>""
 WAND = 1
 WWHERE  = "X3SM0.FOLD_0='"+FOLDER_FILTER+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
Endif
If FILTERS<>""
 If WAND>0 : WWHERE = " and " : Endif
 WWHERE += FILTERS : Gosub ADD_WHERE_RQT From ASESSIONS
Endif

If (dim(GXDT_TRACE) > 0) & GXDT_TRACE
 For I=1 To maxtab([L]RQT_SESSION)
  Call TRACE("ASESSIONS.GET_SESSIONS_EX - RQT(" + num$(I) +")=" + [L]RQT_SESSION(I)) From AXDTMAIN
 Next I
Endif

#If dim([M:PSA]UTIL)>0 & [M:PSA]UTIL<>""
#  If WAND>0 : WWHERE  = " and " : Endif
#  WWHERE  += "X3SM0.ALOGIN_0='"+tolower([M:PSA]UTIL)+"'"     : Gosub ADD_WHERE_RQT From ASESSIONS
#Endif
For (Integer SESSIONID,Char FOLD(GLONADS),Char LAN(GLONLAN),Char SOLUTION(40),Integer SESSIONTYPE,Char REMOTE(40),
&    Char PEER(250),Char SYSTEMUSER(250),Integer NATURE,Char ALOGIN(30),Char UPDUSR(GLONAUS),Datetime CREDATTIM)
&    From num$((GTYPDBA*2)+1)  Sql RQT_SESSION As [SYS_]
 For [F:ASM2]SESSIONID Where SESSIONID=[SYS_]SESSIONID
  Raz [L]WFUNCTION, [L]WMODULE, [L]WLOGIN
  [L]ID = num$([SYS_]SESSIONID)
  [L]PROCID = num$([F:ASM2]SYSTEMID)
  [L]TYP =  num$([SYS_]SESSIONTYPE)
  [L]CLI = [SYS_]PEER
  If [L]CLI="" : [L]CLI = [SYS_]REMOTE : Endif
  [L]PORT = num$([F:ASM2]PORT)
  [L]UID=  [SYS_]ALOGIN
  [L]PROC = [F:ASM2]PROCESSNAME+"("+ [F:ASM2]SERVER+")"
  [L]ADDR = [SYS_]REMOTE
  [L]FLDR = [SYS_]FOLD
  [L]USER = [SYS_]SYSTEMUSER
  If [F:ASM2]PROCESSNAME="adonix"
   Call GET_CURFCT("", [L]FLDR, num$([F:SYS_]SESSIONID), [L]WFUNCTION, [L]WMODULE, [L]WLOGIN) From PSADX
  Endif
  Gosub ADD_SESSIONS
 Next
Next
LogicClose File [ASM2]
End SESSIONS

$ADD_SESSIONS
Append SESSIONS, [L]ID
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]PROCID
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]TYP
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]CLI
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]PORT
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]UID
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]PROC
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]ADDR
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]FLDR
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]WFUNCTION
Append SESSIONS, GXDT_VALUE_SEP
Append SESSIONS, [L]USER
Append SESSIONS, GXDT_NL_SEP
#Call ECR_TRACE([L]ID+","+ ","+[L]PROCID+","+[L]TYP+","+[L]CLI+ ","+[L]PORT+","+[L]UID+","+[L]PROC+","+[L]ADDR+","+[L]FLDR+","+[L]WFUNCTION+","+[L]USER,0) From GESECRAN
Return


#**
#* #* LIST_UID_USR_BY_APPLI
#*
#* For a list of connected users on an app
#*
#* @param APPLI
#* @param NBUID
#* @param TBUID
#* @param TBLOGIN
#* @param TBPEER
#*!
Subprog LIST_UID_USR_BY_APPLI(APPLI,NBUID,TBUID,TBLOGIN,TBPEER)
Value Char APPLI
Variable Integer NBUID
Variable Integer TBUID(1..)
Variable Char TBLOGIN()(1..)
Variable Char TBPEER()(1..)

If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = "X3SM0.SESSIONID_0,X3SM0.ALOGIN_0,X3SM0.PEER_0"                     : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"                                           : Gosub ADD_WHERE_RQT

Raz TBUID , NBUID
For (Integer IDSESSION,Char USER(30),Char CLIENT(80)) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If NBUID=dim(TBUID) : Break : Endif
 NBUID += 1
 TBUID(NBUID) = [F:SYS_]IDSESSION
 TBLOGIN(NBUID) = [F:SYS_]USER
 TBPEER(NBUID) = [F:SYS_]CLIENT
Next

End

#**
#* CAL_CONNECTED_USERS
#*
#* @param DOSSIER
#* @param NBCON
#* @param RERR
#*!
Subprog CAL_CONNECTED_USERS(APPLI,NBCON,RERR)
Value Char       APPLI
Variable Integer NBCON
Variable Integer RERR

If APPLI="" : APPLI = nomap : Endif

Gosub INIT_RQT
WSELECT = " X3SM0.SESSIONTYPE_0"                        : Gosub ADD_SELECT_RQT
WWHERE  = "X3SM0.FOLD_0='"+[L]APPLI+"'"                 : Gosub ADD_WHERE_RQT
Raz [L]NBCON,RERR
For (Integer TYPE_SESSION) From num$((GTYPDBA*2)+1)  Sql [L]RQT_SESSION As [SYS_]
 If !find([SYS_]TYPE_SESSION,4,5,7)
  [L]NBCON += 1
  If ([L]NBCON > 1) Then
    [L]RERR = 1
  Endif
 Endif
Next
End


#**
#* IS_PROCESS_EXIST
