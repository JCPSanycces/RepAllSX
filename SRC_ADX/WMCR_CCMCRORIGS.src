#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs fournisseurs
# Superviseur
## CRUD-CLASSE ## CCMCRORIGS
# 2018-10-19 07:50:19 616


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File CCMCRORIGS [CCMCROS_]

If !SILENCE : Call TRACE("2 --> Local Instance C_CCMCRORIGS") From ASYRCOM : Endif
Local Instance CCMCRORIGS Using C_CCMCRORIGS

If !SILENCE : Call TRACE("3 --> New Instance C_CCMCRORIGS") From ASYRCOM : Endif
CCMCRORIGS = NewInstance C_CCMCRORIGS AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CCMCROS_]CCMCROS0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of CCMCRORIGS") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.AREAD([CCMCROS_]CRID,[CCMCROS_]ORIGSLN))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("CCMCRORIGS.CRID ="-num$(CCMCRORIGS.CRID)) From ASYRCOM
 Call TRACE("CCMCRORIGS.ORIGSLN ="-num$(CCMCRORIGS.ORIGSLN)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(CCMCRORIGS.AKEYS)
  Call TRACE("-"-num$(I)-":"-CCMCRORIGS.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CCMCROS_]
FreeGroup CCMCRORIGS
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(CCMCRORIGS,ACLE,ASTATUS,_ETAG)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _CRID(20)
Local Shortint _ORIGSLN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGSLN = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File CCMCRORIGS [CCMCROS]
Default File [F:CCMCROS]
Read [F:CCMCROS]CCMCROS0 = [L]_CRID;[L]_ORIGSLN
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CCMCROS]UPDTICK)>0
 [L]_ETAG = num$([F:CCMCROS]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(CCMCRORIGS,ACLE,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Value Char ACLE
Variable Integer ASTATUS
Local Char _CRID(20)
Local Shortint _ORIGSLN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGSLN = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.AREAD([L]_CRID,[L]_ORIGSLN))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(CCMCRORIGS,_CRID,_ORIGSLN,ASTATUS)
Variable Instance CCMCRORIGS Using C_CCMCRORIGS
Value Char _CRID
Value Shortint _ORIGSLN
Variable Integer ASTATUS

If CCMCRORIGS = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGS
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If CCMCRORIGS.APARENT=null
 [L]A_I = CCMCRORIGS.freeSnapshot
 CCMCRORIGS.snapshotEnabled = 0
 CCMCRORIGS.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & CCMCRORIGS.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If CCMCRORIGS.APARENT=null
 CCMCRORIGS.snapshotEnabled = 1
 CCMCRORIGS.setAccessorEnabled = 1
Endif
LogicClose File [CCMCROS]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS._ACTION_PARAM("AREAD_BEFORE",[L]_CRID,[L]_ORIGSLN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CCMCROS]
Read [F:CCMCROS]CCMCROS0 = [L]_CRID;[L]_ORIGSLN
If fstat
[L]A_ERROR = [L]_CRID+"~"+num$([L]_ORIGSLN)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(CCMCRORIGS,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CCMCROS]AUUID)>0 & [F:CCMCROS]AUUID=NullUuid
 [F:CCMCROS]AUUID = getUuid
Endif
SetInstance CCMCRORIGS With [F:CCMCROS]
CCMCRORIGS.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGS.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



