#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################################
# Plan des fiches techniques            GPAO 150
##############################################################################
# ACTION = SAIBENCHT
##############################################################################
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABA"           : Effzo [M:MBT] 
                           Gosub DEL_QLYWRK From MTKLIB
                           Gosub DEBUT 
    When "FIN"           : GFONC1 = SAV_GFONC1
                           GCONSULT = GCONSLCT 
                           Gosub DEL_QLYWRK From MTKLIB
                           Kill  GMCLNUM
                           Call IMPSCR From ATRTX3
    When "TERMINE"       : Gosub TERMINE
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "AB1_NBLIG"     : Gosub AB1_NBLIG
    When "AB2_NBLIG"     : Gosub AB2_NBLIG
    When "BB1_NBLIG"     : Gosub BB1_NBLIG
    When "BB2_NBLIG"     : Gosub BB2_NBLIG
    When Default
Endcase
Return

###########################################################################
$INIT
Local Char        LFCY(GLONFCY)   : LFCY   = PARAM(1)
Local Char        LORI            : LORI   = PARAM(2)
Local Char        LUSR(GLONAUS)   : LUSR   = PARAM(3)
Local Integer     LRETOK          : LRETOK = val(PARAM(4))
Local Integer     OK
Global Char       GMCLNUM(GLONTRS): GMCLNUM = ""
Raz GSTATUT

Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# sr 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du pilotage, on vérifie si un code transaction est passé
If GFONCTION = "FUNBENPLT"
    If [M:MBP]MOLTRS <> ""
        Read [BTS]BTS0=66;[M:MBP]MCLTRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
        GMCLNUM = [F:BTS]BTSNUM
        OK = 0
        Return
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif 
CRITERE = "BTSTYP=66&ENAFLG=2"                                             
# sr 10.05 demande 32570
If GPROFIL <> GSUPER                             
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
For [F:BTS] Where evalue(CRITERE)
    NBTEX+= 1
    TEX(NBTEX)   =[F:BTS]BTSNUM
    Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
Next
TIT(0) = mess(3,126,1) # Choix transactions
Return

###########################################################################
$FIN_LISTE
If GSTATUT = 7  : GMCLNUM = "" : Return : Endif
GMCLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=66;GMCLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

Return 

###########################################################################
$OUVRE
Local Char        LFCY   : LFCY   = PARAM(1)
Local Char        LORI   : LORI   = PARAM(2)
Local Char        LUSR   : LUSR   = PARAM(3)
Local Integer     LRETOK : LRETOK = val(PARAM(4))

Local  Integer RETOUR
Local  Integer WRET
Local  Integer TRA : TRA = 0
Local Char     WMASQUE
Global Integer FICTECOK
Global Integer GCONSLCT : GCONSLCT = GCONSULT
Global Char    SAV_GFONC1 : SAV_GFONC1 = GFONC1

Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Raz GCONSULT
GFONC1 = "FUNBENCHT"

Gosub OPEN_FILE
Gosub CHARG_PARAM

Gosub LECTURE_BTS

# substitution fenêtre
BOITE     = "WIMBT"+GMCLNUM
WMASQUE   = "WT66"+GMCLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY       

Gosub CHANGE_AWI From BENCHLIB

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

####################################################################################
$DEBUT
Raz    [M:MBT]
[M:MBT]FCY = GFCY
Case [F:BTS]CRIT1
     When 1 : [M:MBT]WSRT += 1
     When 2 : [M:MBT]WSRT += 2
     When 3 : [M:MBT]WSRT += 4
     When 4 : [M:MBT]WSRT += 8   
Endcase
Case [F:BTS]CRIT2
     When 1 : [M:MBT]WSRT += 16
     When 2 : [M:MBT]WSRT += 32
     When 3 : [M:MBT]WSRT += 64
     When 4 : [M:MBT]WSRT += 128 
Endcase


[M:MBT]LORI = LORI
#
If LUSR <> ""
    Filter [F:TMA] Where USR = LUSR
Else
    Filter [F:TMA] Where USR = GUSER
Endif
Read [F:TMA]TMA1 First
If !fstat : [M:MBT]WEMPNUM = [F:TMA]EMPNUM : Endif
Filter [F:TMA]
If LORI = "PILOT"
    Gosub CHARG_MASKB
Endif

# 15806 MM 05.05 : application memo STD
If LORI =""
    If filinfo(filpath("ETM",GUSER+"_"+GMCLNUM+"_"+"STD","mbt",0),0)>=0
        Call LECMEMO("STD","[M:MTB5]",GMCLNUM+"~mbt") From GMEMO
        [M:MBT] = [M:MTB5]
        Affzo [M:MBT]10
    Endif
Endif

Return

#########################################################################
$SETBOUT
ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GABAN) = 1   
If LORI = "PILOT" 
    ETABOU(GSPE1) = 0                                     # recherche
    ETABOU(GSPE2) = 0                                     # critères
Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MBT]REACT = 2 : Gosub CHARG_MASK : [M:MBT]REACT = 1 : Endif
Endcase
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return


#######################################################################
$OPEN_FILE 
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKO])<=0 : Local File MFGOPETRK  [MKO] : Endif
If clalev([F:MWS])<=0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:MTA])<=0 : Local File MTKCRDASW  [MTA] : Endif
If clalev([F:QLW])<=0 : Local File QLYWRK     [QLW] : Endif
If clalev([F:ROO])<=0 : Local File ROUOPE     [ROO] : Endif
If clalev([F:TMA])<=0 : Local File TABMAT     [TMA] : Endif
If clalev([F:TSR])<=0 : Local File TABSCA     [TSR] : Endif
If clalev([F:TMS])<=0 : Local File TABMSG     [TMS] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif 
If clalev([F:TUN])<=0 : Local File TABUNIT    [TUN] : Endif 
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:OPS])<=0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:ROH])<=0 : Local File ROUTING    [ROH] : Endif
If clalev([F:ROU])<=0 : Local File ROUOPE     [ROU] : Endif
If clalev([M:MTB5])=0 : Local Mask MTKBCRIT5 [MTB5] : Endif      # 15806 MM 05.05 : gestion memo STD  

Return

######################################################################## 
$CHARG_PARAM 
Call GETDEV(GFCY)     From DEVSUB # pour récupérer GSOCIETE
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

######################################################################## 
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 66 | [F:BTS]BTSNUM <> GMCLNUM
    Read [BTS]BTS0=66;GMCLNUM : If fstat Raz [F:BTS] : Endif
Endif
Return

###############################################################
$CHARG_MASK
Local Char    WFCY 
Local Integer WALT 
Local Date    WDAT   
Local Integer WMSG 
Local Integer I
Local Char CRITERE2(90)
Local Char CRITERE(255) 
Local Char CRITERE1(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char CUSFLT(255)
Local Char FORMULE1(255)

Local Integer WMAX : WMAX = dim([M:MBT]TIMTYP) - 2
Local Integer WEXISTE

Gosub DEL_QLYWRK From MTKLIB

CRITERE = "1=1"
CRITERE1 ="1=1"
CRITERE2 ="1=1"
Raz FORMULE1

Raz [F:MFG]
Effzo [M:MBT]15
If  [F:BTS]OFFLG = 1 
    CRITERE += "& TIMTYP = 2"
Elsif [F:BTS]GAMFLG = 1
    CRITERE += "& TIMTYP = 1"
Endif

CRITERE += "& MFGFCY = [M:MBT]FCY" 
CRITERE += '& TECCRD <> ""'
CRITERE += "& TIMTYP <> 3"
If [M:MBT]WEMPNUM <> 0
   CRITERE += "& EMPNUM =[M:MBT]WEMPNUM"
Endif    
If [M:MBT]WTRKNUMF <> "" 
   CRITERE += "& MFGTRKNUM >=[M:MBT]WTRKNUMD & MFGTRKNUM <= [M:MBT]WTRKNUMF"
Endif
If [M:MBT]WOPENUMD <> 0
   CRITERE += "& OPENUM >=[M:MBT]WOPENUMD & OPENUM <= [M:MBT]WOPENUMF"
Endif
If [M:MBT]WWSTF <> ""
  CRITERE += "& CPLWST >= [M:MBT]WWSTD & CPLWST <= [M:MBT]WWSTF"
Endif
If [M:MBT]WMFGNUMF <> ""
   CRITERE1 += "&MFGNUM>=[M:MBT]WMFGNUMD & MFGNUM<=[M:MBT]WMFGNUMF"
Endif
If [M:MBT]WROUNUMF <> ""
   CRITERE1 += "& ITMREF >=[M:MBT]WROUNUMD & ITMREF <= [M:MBT]WROUNUMF"
Endif
If [M:MBT]WROUALTF <> 0
    CRITERE1 += "& ROUALT >= [M:MBT]WROUALTD & ROUALT <= [M:MBT]WROUALTF"
Endif
If [M:MBT]WMTKDATF <> [0/0/0]
    CRITERE2+= " & [F:MTK]MFGTRKDAT >= [M:MBT]WMTKDATD & [F:MTK]MFGTRKDAT <= [M:MBT]WMTKDATF"
Endif
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT  
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif
Link [MKO] With [MTK]MTK0 = [F:MKO]MFGTRKNUM As [MKOX]
&          Where (evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1))
nolign = 0 
For [F:MKOX]
     If [F:MKO]TIMTYP = 1 & [F:MFG]MFGNUM <> [F:MKO]MFGNUM
        Read [F:MFG]MFG0 = [F:MKO]MFGNUM
        If fstat  : Raz [F:MFG] : Endif
     Endif
     If [F:MKO]TIMTYP = 1 & [M:MBT]WITMREFF <> ""
        Raz mkstat   
        For [F:MFI] Where [F:MFI]MFGNUM = [F:MKO]MFGNUM
            If [F:MFI]ITMREF < [M:MBT]WITMREFD | [F:MFI]ITMREF > [M:MBT]WITMREFF
               mkstat = 1 
               Break
            Endif
        Next
        If mkstat = 1 : Goto NEXT_MKOX : Endif
     Endif
   
     If ([F:MKO]TIMTYP = 1 & [F:MFG]MFGSTA <> 4) | [F:MKO]TIMTYP <> 1
             If nolign+1 > WMAX : Break  : Endif
             Filter [F:MTA] Where MFGTRKNUM = [F:MKO]MFGTRKNUM & OPETRKLIN = [F:MKO]OPETRKLIN   
             Look [F:MTA]MTA0 First
             If fstat : WEXISTE = 1 : Else : WEXISTE = 2 : Endif
             Filter [F:MTA]
             If (WEXISTE = [F:BTS]TECMODSAI) | [F:BTS]TECMODSAI = 3 
                 nolign += 1
                 Gosub CHARGE_MKO
             Endif
     Endif
$NEXT_MKOX
Next 
[M:MBT]NBLIG = nolign
Affzo [M:MBT]5,10 
Gosub AFF_TABLEAU
    
Return 

##################################################
$CHARG_MASKB
Local Integer I,WI
Local Integer WMAX : WMAX = dim([M:MBT]TIMTYP) - 2
Local Integer WEXISTE

Gosub DEL_QLYWRK From MTKLIB

Raz I,WI
nolign = 0
Effzo [M:MBT]15
For WI = 0 To [M:MTPK]NBLIG-1
    Read [F:MFG]MFG0 = [M:MTPK]MFGNUM(WI)
    Filter [F:MKO] Where MFGNUM = [F:MFG]MFGNUM & TECCRD <> ""
    For [F:MKO]
        If nolign+1 > WMAX : Break 2 : Endif
        Filter [F:MTA] Where MFGTRKNUM = [F:MKO]MFGTRKNUM & OPETRKLIN = [F:MKO]OPETRKLIN   
        Look [F:MTA]MTA0 First
         If fstat : WEXISTE = 1 : Else : WEXISTE = 2 : Endif
         Filter [F:MTA]
         If (WEXISTE = [F:BTS]TECMODSAI) | [F:BTS]TECMODSAI = 3 
             nolign += 1
             Gosub CHARGE_MKO
        Endif
    Next
Next
Filter [F:MKO]
[M:MBT]NBLIG = nolign
Grizo [M:MBT]5,10

Gosub AFF_TABLEAU

Return


################################################
$CHARGE_MKO
If [F:MKO]ROUOPENUM <> 0 
   If [F:MKO]TIMTYP < 2 
      Read [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
      [M:MBT] = [F:MFO]
   Elsif [F:MKO]TIMTYP = 2
      Read [F:ROO]ROO0 = [F:MKO]MFGFCY;[F:MKO]ITMREF;[F:MKO]ROUALT;[F:MKO]OPENUM;[F:MKO]RPLIND
      [M:MBT] = [F:ROO]
   Endif
Else
   [M:MBT]XOPEUOM(nolign-1)  = [F:MKO]OPEUOM
   [M:MBT]CLEFLG(nolign-1)   = 2      
Endif   
[M:MBT] = [F:MKO]

[M:MBT]MFGTRKDAT(nolign-1) = [F:MTK]MFGTRKDAT
Local Integer WORK_NOLIGN : WORK_NOLIGN = nolign-1
For WI = 1 To 15
    Assign "[M:MBT]SCANUM"+num$(WI)+"(nolign-1)"   With [F:MKO]SCANUM(WI-1)
    Assign "[M:MBT]TAREJQTY"+num$(WI)+"(nolign-1)" With [F:MKO]TABREJQTY(WI-1)
Next
If [M:MBT]TIMTYP(nolign-1) = 1   & [F:MFO]MFOTRKFLG <> 5
    [M:MBT]EXTQTY(nolign-1)  = ([F:MFO]EXTQTY-[F:MFO]CPLQTY) / [M:MBT]OPEWORCOE(nolign-1)
Endif
Read [MWS]WST0=[M:MBT]CPLWST(nolign-1);[M:MBT]FCY
If !fstat 
     [M:MBT]WSTTYP(nolign-1)     = [F:MWS]WSTTYP 
     [M:MBT]XWSTTYP(nolign-1)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
     [M:MBT]WSTSHO(nolign-1)     = [F:MWS]WSTSHO
Endif 
[M:MBT]OKQTY(nolign-1) = [M:MBT]CPLQTY(nolign-1) - [M:MBT]REJCPLQTY(nolign-1)  
If [F:MKO]TIMTYP < 2 
      Read [F:MFG]MFG0 =[M:MBT]MFGNUM(nolign-1)
      If fstat : Raz [F:MFG] : Endif
      [M:MBT]ITMREF(nolign-1) = [F:MFG]ROUNUM
      [M:MBT]ROUALT(nolign-1) = [F:MFG]ROUALT
Endif
[M:MBT]CRDOK(nolign-1) = WEXISTE
Return


##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:MBT]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=23;[M:MBT]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return

###########################################
$AFF_TABLEAU
Case [M:MBT]WSRT :
     When 33  : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKNUM(indice),
&                                                        [M:MBT]MFGTRKDAT(indice), [M:MBT]OPENUM(indice)
     When 65  : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKNUM(indice),
&                                                        [M:MBT]MFGNUM(indice), [M:MBT]OPENUM(indice)
     When 129 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKNUM(indice),
&                                                        [M:MBT]CPLWST(indice), [M:MBT]OPENUM(indice)
     When 18  : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKDAT(indice),
&                                                        [M:MBT]MFGTRKNUM(indice), [M:MBT]OPENUM(indice)
     When 66  : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKDAT(indice),
&                                                        [M:MBT]MFGNUM(indice), [M:MBT]OPENUM(indice)
     When 130 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGTRKDAT(indice),
&                                                        [M:MBT]CPLWST(indice), [M:MBT]OPENUM(indice)
     When  20 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGNUM(indice),
&                                                        [M:MBT]MFGTRKNUM(indice), [M:MBT]OPENUM(indice)
     When  36 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGNUM(indice),
&                                                        [M:MBT]MFGTRKDAT(indice), [M:MBT]OPENUM(indice)
     When 132 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]MFGNUM(indice),
&                                                        [M:MBT]CPLWST(indice), [M:MBT]OPENUM(indice)
     When  24 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]CPLWST(indice),
&                                                        [M:MBT]MFGTRKNUM(indice), [M:MBT]OPENUM(indice)
     When  40 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]CPLWST(indice),
&                                                        [M:MBT]MFGTRKDAT(indice), [M:MBT]OPENUM(indice)
     When  72 : Sorta [M:MBT]NBLIG [M:MBT]NBLIG Order By [M:MBT]CPLWST(indice),
&                                                        [M:MBT]MFGNUM(indice), [M:MBT]OPENUM(indice)
Endcase
Affzo [M:MBT]15    
Return

############################################
$AB1_NBLIG
Local Integer NOL : NOL = nolign-1
Return

############################################
$BB1_NBLIG
Local Integer WEXISTE

Read [F:MKO]MKO0 = [M:MBT]MFGTRKNUM(NOL);[M:MBT]OPETRKLIN(NOL)
Filter [F:MTA] Where MFGTRKNUM = [M:MBT]MFGTRKNUM(NOL) & OPETRKLIN = [M:MBT]OPETRKLIN(NOL)
Look [F:MTA]MTA0 First
If fstat : WEXISTE = 1 
Else  WEXISTE = 2  
    # si les réponses n'éxistaaient pas auparavant on va coloriser le numéro de suivi
    If [M:MBT]CRDOK(NOL) = 1 : [M:MBT]CRDFLG(NOL) = 2 : Endif
Endif
Filter [F:MTA]
nolign = NOL+1
Gosub CHARGE_MKO
Call AV_MFGTRKNUM([M:MBT]MFGTRKNUM(NOL))
Affzo  [M:MBT]MFGTRKNUM(NOL)
Gosub LECTURE_BTS

Return

############################################
$AB2_NBLIG
Local Integer NOL : NOL = nolign-1
Return

############################################
$BB2_NBLIG

If [M:MBT]CRDOK(NOL) = 1
    Filter [F:MTA] Where MFGTRKNUM = [M:MBT]MFGTRKNUM(NOL) & OPETRKLIN = [M:MBT]OPETRKLIN(NOL)
    Look [F:MTA]MTA0 First
    If !fstat : [M:MBT]CRDOK(NOL)  = 2
                [M:MBT]CRDFLG(NOL) = 2
    Endif
Endif
Filter [F:MTA]
Call AV_MFGTRKNUM([M:MBT]MFGTRKNUM(NOL))
Affzo [M:MBT]MFGTRKNUM(NOL)
Return

###########################################
$TERMINE
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHT) 26/04/2005 09:43:39 (SR)
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
End

Subprog C_WEMPNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [F:BTS]MATRICULE = 2 : Raz [F:TMA] : End : Endif
# GH 21/11/13 bug 94623
Call CONTROLE("TMA","",num$(VALEUR),"",mkstat) From CONTOBJ
#Read [F:TMA]TMA0 = VALEUR
#If fstat : GMESSAGE = mess(23,100,1)
#    mkstat = 1
#    End
#Endif
[M:MBT]EMPDES = [F:TMA]EMPDES
End

Subprog AM_WEMPNUM(VALEUR)
Variable Decimal VALEUR
[M:MBT]EMPDES = [F:TMA]EMPDES
Affzo [M:MBT]EMPDES
End

Subprog AM_WMTKDATD(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M:MBT]WMTKDATF = VALEUR : Affzo [M:MBT]WMTKDATF : Endif
End

Subprog C_WMTKDATF(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MBT]WMTKDATD : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End


