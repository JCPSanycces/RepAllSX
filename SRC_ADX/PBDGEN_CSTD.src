######################################################################################################
# Project       : Payment balance declaration
# File          : PBDGEN_CSTD
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 01.05.14
######################################################################################################
# Module        : Finance
# Description   : - Payment balance declaration generation (Class PBDGEN)
######################################################################################################
 # Updates :
 # Date       | Author | Version | Description
 # 2015-12-21 | ANGRE  | U10     | SAM # 111399 - Moved content from $METHODS to $EVENTS and $OPERATIONS
 # 2018-10-05 | DNE    | VNEXT   | Jira X3-110398 - Delete detail data for it is not in a collection
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
      Case [L]AEVENT
         When "AINSERT_CONTROL_BEFORE" : Gosub CONTROL_BEFORE  # Before insert and before field controls
         When "ADELETE_CONTROL_BEFORE" : Gosub ADELETE_CONTROL_BEFORE
# 2018-10-05 DNE INSERT BEGIN (X3-110398)
         When "ADELETE_BEFORE"         : Gosub ADELETE_BEFORE # Delete detail data
# 2018-10-05 DNE INSERT END
      Endcase
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
     When "EXTRACTION"             : Gosub EXTRACTION
     When "RECALCULATE"            : Gosub RECALCULATE
     When "EXPORT"                 : Gosub EXPORT
     When "POST"                   : Gosub POST
  Endcase
Return


# SAM # 111399 $METHODS content is now either in $OPERATIONS or  in $EVENTS
$METHODS
Case [L]CURPTH
   When ""
      Case [L]AMETHOD
         When "COLLECT"            : Gosub COLLECT
      Endcase
Endcase
Return

$EXTRACTION
  ASTATUS = fmet this.AREAD(CODE)
  Gosub COLLECT
Return

  # SAM # 111399 changed ACTION to ARULE
$PROPERTIES
  Case [L]CURPRO
    When "GRPORCPY"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PROP_GRPORCPY
      Endcase
    When "DATEFROM"
      Case [L]ARULE
        When "INIT"      : Gosub INIT_DATEFROM
        When "CONTROL"   : Gosub CTRL_DATEFROM
        When "PROPAGATE" : Gosub PROP_DATEFROM
      Endcase
    When "DATETO"
      Case [L]ARULE
        When "INIT"      : Gosub INIT_DATETO
        When "CONTROL"   : Gosub CTRL_DATETO
      Endcase
    When "EXPORTED"
      Case [L]ARULE
        When "INIT"      : this.EXPORTED = [V]CST_ANO
      Endcase
    When "POSTED"
      Case [L]ARULE
        When "INIT"      : this.POSTED = [V]CST_ANO
      Endcase
  Endcase
Return


############################################################################################
# Implementation of the METHODS
############################################################################################


# create new Code as a sequence number
$CONTROL_BEFORE
   If this.CODE = ""
     Local Integer STATE
     Local Integer CREATE_GOK
     If dim([V]GOK) < 0       # check if global variable GOK exists. If not, create it (unfortunately needed in NUMERO)
        Global Integer GOK
        GOK = 1
        CREATE_GOK = 1
     Endif
     Call NUMERO( "PBD1", this.GRPORCPY, this.DATETO, "", this.CODE, STATE ) From SUBANM
     If [L]STATE
        Case STATE
           When 1 : # sequence number definition doesn't exist
              ASTATUS = fmet this.ASETERROR( "", mess(81,134,1), [V]CST_AERROR )   # Nonexistent sequence number
           When 2 : # Sequence number exceeded
              ASTATUS = fmet this.ASETERROR( "", mess(82,134,1), [V]CST_AERROR )   # Sequence number exceeded
           When 99 : # Sequence number error
              ASTATUS = fmet this.ASETERROR( "", mess(83,134,1), [V]CST_AERROR )   # Sequence number error
        Endcase
     Endif
     If CREATE_GOK           # if GOK was created -> remove it again
        Kill [V]GOK
     Endif
   Endif
Return

 # Prevent deleting if record is already posted (or posted/exported).
$ADELETE_CONTROL_BEFORE
    If this.POSTED = [V]CST_AYES            # check if already posted -> if yes, no collection/extraction
        ASTATUS = fmet this.ASETERROR( "", mess(382,107,1), [V]CST_AERROR )       #  'Data has been already posted, modification not possible'
    Endif
Return


# 2018-10-05 DNE INSERT BEGIN (X3-110398)
# Delete detail data for it is not in a collection anymore and therefore must be deleted directly.
$ADELETE_BEFORE
    Local File PBDGEND [PBDGEND]

    Delete [F:PBDGEND]PBDGEND0(2) = this.CODE;this.LEG
    If fstat
        ASTATUS = fmet this.ASETERROR( "", mess(808,197,1) - "| fstat =" - num$(fstat), [V]CST_AERROR )  # "Record deletion error"
    Endif
Return
# 2018-10-05 DNE INSERT END


$PROP_GRPORCPY
  Local File COMPANY [CPY]
  Local Integer FOUND

  Read [F:CPY]CPY0 = this.GRPORCPY
  If !fstat
     If [F:CPY]CPYLEGFLG = 2            # legal company
       this.LEG = [F:CPY]LEG            # assign legislation
       this.ISGRP = [V]CST_AFALSE
     Else                               # company group
       this.ISGRP = [V]CST_ATRUE
       Local File AGRPCPY [AGC]
       this.LEG = ""                    # initialize
       For [F:AGC] Where GRP = this.GRPORCPY
         Read [F:CPY]CPY0 = [F:AGC]CPY
         If this.LEG = "" : this.LEG = [F:CPY]LEG : Endif

         If [F:CPY]LEG <> this.LEG
            ASTATUS = fmet this.ASETERROR( "GRPORCPY", func AFNC.MES3( mess(348,107,1), [F:CPY]CPY, this.GRPORCPY, this.LEG ), [V]CST_AERROR )
                                           # "The company '$1$' of the group $2$ doesn't belong to the chosen legislation $3$."
            Break
         Endif
       Next
     Endif
     If ASTATUS = [V]CST_AOK            # all correct -> read configuration PBDCONFIG
        Local File PBDCONFIG [PBDCNF]
        Read [F:PBDCNF]PBDCNF1(2) = this.LEG;this.GRPORCPY     # try to read configuration with correct GRPORCPY
        If !fstat
           FOUND = 1                                           # found
        Else                            # not found for GRPORCPY -> search with empty GRPORCPY
           Read [F:PBDCNF]PBDCNF1(2) = this.LEG;""             # try to read configuration without GRPORCPY
           FOUND = !fstat
        Endif
        If FOUND
           Local File GACM [GCM] # core model
           this.PBDCCODE = [F:PBDCNF]CODE  # set reference to configuration in class to directly find PBDCONFIG later
           this.LEDTYP = [F:PBDCNF]LEDTYP  # set ledger type from configuration

           # check currency for all companies of the group
           If this.ISGRP = [V]CST_ATRUE
              Local Char CUR(3)
              CUR = ""                     # initialize
              For [F:AGC] Where GRP = this.GRPORCPY
                 Read [F:CPY]CPY0 = [F:AGC]CPY
                 If !fstat
                    Read [F:GCM]GCM0 = [F:CPY]ACM    # read core model of company
                    If !fstat
                       If CUR = "" : CUR = [F:GCM]CUR(this.LEDTYP-1) : Endif # get currency of chosen ledger type

                       If [F:GCM]CUR(this.LEDTYP-1) <> CUR  # different currencies for ledger type in group
                           ASTATUS = fmet this.ASETERROR( "GRPORCPY", mess(319,107,1), [V]CST_AERROR ) # 'Inconsistent currencies upon group.'
                           Break
                       Endif
                    Endif
                 Endif
              Next
           Else   # legal company
              Read [F:GCM]GCM0 = [F:CPY]ACM    # read core model of company
              If !fstat
                 If [F:GCM]CUR(this.LEDTYP-1) <> [F:CPY]ACCCUR  # different currencies for ledger type and company
                     ASTATUS = fmet this.ASETERROR( "GRPORCPY", mess(361,107,1), [V]CST_AERROR ) # 'The company currency differs from the ledger company.'
                 Endif
              Endif
           Endif
           LogicClose File [GCM]
        Else
           ASTATUS = fmet this.ASETERROR( "GRPORCPY", func AFNC.MES1( mess(360,107,1), this.GRPORCPY), [V]CST_AERROR )
                                           # "The payment balance configuration for Group + cy $1$ doesn't exist"
        Endif
        LogicClose File [PBDCNF]
     Endif
  Else
     ASTATUS = fmet this.ASETERROR( "GRPORCPY", mess(16,104,1), [V]CST_AERROR )   # 'Nonexistent company'
  Endif

  If this.ISGRP = [V]CST_ATRUE : LogicClose File [AGC] : Endif
  LogicClose File [CPY]
Return


$INIT_DATEFROM
   this.DATEFROM = eomonth(addmonth(date$,-2))+1
Return


$CTRL_DATEFROM
  If (day(this.DATEFROM) <> 1)
     ASTATUS = fmet this.ASETERROR( "DATEFROM", mess(264,107,1), [V]CST_AERROR )       # 'Invalid date range'
# 2015-07-23 DNE REMOVE BEGIN (US #1223)
#  Else
#    Gosub CTRL_DATETO
# 2015-07-23 DNE REMOVE END
  Endif
Return


$PROP_DATEFROM
# 2015-07-23 DNE INSERT BEGIN (US #1223)
  If mod( month( this.DATEFROM ), 3 ) = 1 and this.LEG = "AUT"
      this.DATETO = eomonth( addmonth( this.DATEFROM, 2 ) )     # End of quarter
  Else
      this.DATETO = eomonth( this.DATEFROM )                    # End of month
  Endif
# 2015-07-23 DNE INSERT END
# 2015-07-23 DNE REMOVE BEGIN (US #1223)
#  Gosub CTRL_DATETO
# 2015-07-23 DNE REMOVE END
Return


$INIT_DATETO
#2015-07-23 DNE MODIF BEGIN (US #1223)
  If mod( month( date$), 3 ) = 2 and this.LEG = "AUT"
      this.DATETO = eomonth( addmonth( this.DATEFROM, 1 ) )     # End of quarter
  Else
      this.DATETO = eomonth( addmonth( date$, -1) )             # End of month
  Endif
#2015-07-23 DNE MODIF ORIG
#    this.DATETO = eomonth( addmonth( date$, -1) )
#2015-07-23 DNE MODIF END
Return


$CTRL_DATETO
  If this.DATETO <>[0/0/0] and this.DATEFROM <>[0/0/0]
    If this.DATETO < this.DATEFROM or year(this.DATEFROM) <> year(this.DATETO)
       ASTATUS = fmet this.ASETERROR( "DATETO", mess(264,107,1), [V]CST_AERROR )       # 'Invalid date range'
       Return
    Endif
    If gdat$(0,month(this.DATETO)+1,year(this.DATETO))<>this.DATETO or
&     gdat$(1,month(this.DATEFROM),year(this.DATEFROM))<>this.DATEFROM     Then
       ASTATUS = fmet this.ASETERROR( "DATETO", mess(264,107,1), [V]CST_AERROR )       # 'Invalid date range'
       Return
    Endif
    If !( (month(this.DATEFROM) = month(this.DATETO)) or (month(this.DATEFROM)=1 and month(this.DATETO)=3) or
&     (month(this.DATEFROM)=4 and month(this.DATETO)=6) or (month(this.DATEFROM)=7 and month(this.DATETO)=9) or
&     (month(this.DATEFROM)=10 and month(this.DATETO)=12)) Then
       ASTATUS = fmet this.ASETERROR( "DATETO", mess(264,107,1), [V]CST_AERROR )       # 'Invalid date range'
    Endif
  Endif
Return


$SORTANDGROUP
   Local Integer NUMLINES
   Local Integer LINECOUNT, I, J
   Local Decimal TOTAMOUNT
   Local File PBDGEND [PBDGEND1]

   Filter [PBDGEND] Where CODE = this.CODE and LEG = this.LEG and ISDETAIL = 2 and ISOITEM = ISOPENITEM Order With ORDERSTRING
   [L]NUMLINES =  rowcount([PBDGEND])
   If NUMLINES > 0                        # if no records found > nothing to do
     LINECOUNT = 0
     I = 0
     For [PBDGEND]
       I += 1
       If I > 1
         For J = NUMGRP-1 To 0 Step -1    # compare from last criterion to first until they differ
           If evalue("[PBDGEND1]" + FIELDS(J) + "<> [PBDGEND]" + FIELDS(J))   # change in group -> insert group line
             Gosub INSGROUP
             Break
           Else
             If J = 0 : TOTAMOUNT += [PBDGEND1]AMOUNT : Endif   # only add once
           Endif
         Next
       Endif
       [PBDGEND1] = [PBDGEND]             # remember record for comparison
     Next
     Gosub INSGROUP                       # insert last group
   Endif

   LogicClose File [PBDGEND1]
Return


$INSGROUP
  LINECOUNT += 1
  TOTAMOUNT += [PBDGEND1]AMOUNT
  Gosub ADDGROUP
  TOTAMOUNT = 0
Return


# new grouping line is inserted and filled with the correct values
$ADDGROUP
  Local Integer L
  Local Instance PBDGROUP Using C_PBDGEND
  [L]PBDGROUP = NewInstance C_PBDGEND AllocGroup null
#  SetInstance PBDGROUP With [PBDGEND1]
  For L = 0 To NUMGRP-1            # add values of all grouping fields to inserted grouped line
    Assign ("PBDGROUP."+FIELDS(L)) With evalue("[PBDGEND1]"-FIELDS(L))
  Next L
  [L]PBDGROUP.CODE     = this.CODE
  [L]PBDGROUP.LEG      = this.LEG
  [L]PBDGROUP.ISDETAIL = [V]CST_ANO
  [L]PBDGROUP.ISOITEM  = [L]ISOPENITEM
  [L]PBDGROUP.LINE     = LINECOUNT
  [L]PBDGROUP.AMOUNT   = TOTAMOUNT

  ASTATUS = fmet [L]PBDGROUP.AINSERT()
  If ASTATUS <> [V]CST_AOK Then
    ASTATUS = fmet this.ASETERROR("", mess(380,107,1), [V]CST_AWARNING) # 'Inserting into database failed'
  Endif

  FreeGroup PBDGROUP
Return


$GETORDERSTRING
Local Integer GROUPBY, K
   NUMGRP = 0                           # count and collect grouping properties
   ASTATUS = fmet [L]UICONF.AREAD(this.LEG)
   If ASTATUS = [V]CST_AOK     # "displayed fields" configuration found for legislation
     For K=1 To maxtab([L]UICONF.LINES)
       If [L]UICONF.LINES(K)<>null
          GROUPBY = [L]UICONF.LINES(K).GRPBYS = 2        # should be grouped by
          If GROUPBY
             FIELDS(NUMGRP) = [L]UICONF.LINES(K).FLD     # remember field name for sorting and grouping
             If NUMGRP = 0
               ORDERSTRING = FIELDS(NUMGRP)
             Else
               ORDERSTRING -= "; " - FIELDS(NUMGRP)
             Endif
             NUMGRP += 1
          Endif
       Endif
     Next K
   Endif
Return


$PREPAREPBDX
   Case this.LEG
     When "AUT" :
     Local Instance DATA Using C_PBDXTRAUT
     [L]DATA = NewInstance C_PBDXTRAUT AllocGroup null
   When "GER" :
     Local Instance DATA Using C_PBDXTRGER
     [L]DATA = NewInstance C_PBDXTRGER AllocGroup null
   When "POR" :
       Local Instance DATA Using C_PBDXTRPOR
       [L]DATA = NewInstance C_PBDXTRPOR AllocGroup null
   Endcase
Return


$DOGROUPING
   [L]UICONF = NewInstance C_PBDUICONF  AllocGroup null  # to read "displayed fields" configuration for legislation
   Gosub GETORDERSTRING            # build string for "Order By" clause
   If ORDERSTRING <> ""            # if no fields to be grouped by -> nothing to do
     ISOPENITEM = [V]CST_AYES
     Gosub SORTANDGROUP            # group by open items
     ISOPENITEM = [V]CST_ANO
     Gosub SORTANDGROUP            # group by payments
   Endif
   FreeGroup [L]UICONF
Return


$DATAERRORS
  Local Integer I
  For [L]I = 1 To maxtab([L]DATA.AERROR)
     Local Integer IGNORESTAT
     [L]IGNORESTAT = fmet this.ASETERROR([L]DATA.AERROR([L]I).PRO, [L]DATA.AERROR([L]I).MES, [L]DATA.AERROR([L]I).STA)
  Next [L]I
Return


$COLLECT
Local File PBDGEND [PBDGEND]
Local Instance UICONF Using C_PBDUICONF
Local Integer NUMGRP
Local Char FIELDS(12)(50)     # collects the field names to be grouped by
Local Char ORDERSTRING(250)
Local Integer ISOPENITEM

   Gosub CHECKPOSTED
   If ASTATUS <> [V]CST_AOK :  Return : Endif

   # delete existing data of this declaration (CODE + LEG)
   Trbegin [PBDGEND]
   Delete [PBDGEND]PBDGEND0(2) = this.CODE;this.LEG
   If !fstat
     Commit
     Gosub PREPAREPBDX
     ASTATUS = fmet [L]DATA.COLLECT(this)
     Gosub DATAERRORS

     If ASTATUS = [V]CST_AOK
       Gosub DOGROUPING
     Endif

     ASTATUS = fmet [L]DATA.POST_BEFORE( this )
     FreeGroup [L]DATA
     If ASTATUS <> [V]CST_AOK
         ASTATUS = fmet this.ASETERROR( "", mess(276,107,1), [V]CST_AERROR )   #  'There are lines with errors/warnings.'
         Return
     Endif
   Else
     Rollback
     ASTATUS = fmet this.ASETERROR( "", mess(808,197,1), [V]CST_AERROR )       # "Record deletion error"
   Endif

   LogicClose File [PBDGEND]

   ASTATUS = fmet this.ASETERROR( "", mess(377,107,1), [V]CST_ASUCCESS )       # 'Please refresh tables to display the updated result'
Return


$RECALCULATE
Local File PBDGEND [PBDGEND]
Local Instance UICONF Using C_PBDUICONF
Local Integer NUMGRP
Local Char FIELDS(12)(50)     # collects the field names to be grouped by
Local Char ORDERSTRING(250)
Local Integer ISOPENITEM

   ASTATUS = fmet this.AREAD(CODE)
   Gosub CHECKPOSTED
   If ASTATUS <> [V]CST_AOK :  Return : Endif

   # delete existing grouped data of this declaration (CODE + LEG + ISDETAIL=1)
   Trbegin [PBDGEND]
   Delete [PBDGEND]PBDGEND0(3) = this.CODE;this.LEG;1
   If !fstat
     Commit

     Gosub DOGROUPING
     Gosub PREPAREPBDX
     ASTATUS = fmet [L]DATA.POST_BEFORE( this )
     FreeGroup [L]DATA
     If ASTATUS <> [V]CST_AOK
          ASTATUS = fmet this.ASETERROR( "", mess(276,107,1), [V]CST_AERROR )   #  'There are lines with errors/warnings.'
          Return
     Endif
   Else
     Rollback
     ASTATUS = fmet this.ASETERROR( "", mess(808,197,1), [V]CST_AERROR )       # "Record deletion error"
   Endif

   LogicClose File [PBDGEND]

   ASTATUS = fmet this.ASETERROR( "", mess(377,107,1), [V]CST_ASUCCESS )        # 'Please refresh tables to display the updated result'
Return


$EXPORT
  # NOTE: This is an asynchronous link. So output can only be done using ADDDIAGNOSE from ASYRASYNC!
  #
  ASTATUS = fmet this.AREAD(CODE)

  If this.POSTED <> [V]CST_AYES            # No export if declaration is not posted
      Call ADDDIAGNOSE( this.ACTX, mess(381,107,1), [V]CST_AERROR ) From ASYRASYNC
      Call ASYNCTRACK( this.ACTX, "", mess(381,107,1), 100) From ASYRASYNC # 'Only posted data can be exported'
    Return
  Endif

  Gosub PREPAREPBDX
  ASTATUS = fmet [L]DATA.EXPORT(this)
  Gosub DATAERRORS
  If ASTATUS = [V]CST_AOK
    this.EXPORTED = [V]CST_AYES               # set exported flag
    ASTATUS = fmet this.AUPDATE()
  Endif

  FreeGroup [L]DATA
Return


$CHECKPOSTED
  If this.POSTED = [V]CST_AYES            # check if already posted
    ASTATUS = fmet this.ASETERROR( "", mess(382,107,1), [V]CST_AWARNING )       #  'Data has been already posted, modification not possible'
    Return
  Endif
Return


$POST
  ASTATUS = fmet this.AREAD(CODE)

  Gosub CHECKPOSTED
  If ASTATUS <> [V]CST_AOK :  Return : Endif

  # Prevent posting of empty selections (e. g. before pressing extraction button).
  Local File PBDGEND [PBDGEND] Where CODE = this.CODE
  Read [F:PBDGEND]PBDGEND0 First
  If fstat
    ASTATUS = fmet this.ASETERROR( "", mess(383,107,1), [V]CST_AWARNING )       # 'An empty result set cannot be posted'
    Return
  Endif

  Gosub PREPAREPBDX
  ASTATUS = fmet [L]DATA.POST_BEFORE( this )
  FreeGroup [L]DATA
  If ASTATUS <> [V]CST_AOK
      ASTATUS = fmet this.ASETERROR( "", mess(276,107,1), [V]CST_AERROR )   #  'There are lines with errors/warnings.'
      Return
  Endif

  this.POSTED = [V]CST_AYES               # set posted flag
  ASTATUS = fmet this.AUPDATE()
  If ASTATUS = [V]CST_AOK
    ASTATUS = fmet this.ASETERROR( "", mess(377,107,1), [V]CST_ASUCCESS )       # 'Please refresh tables to display the updated result'
  Endif

Return

