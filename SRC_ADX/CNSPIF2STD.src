############################################################
############################################################
# Traçabilité amont sur les dépenses
# Un devis peut avoir des affaires associées.
#    Recherche des affaires (distinctes) : on parcourt les affaires (pas le choix)
Subprog FIND_TREE_AMONT_LOF(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SCODLOF(GLONLOF)
Local Integer ILINLOF
Local Char PIH_F(GLONPIH)
#Local Integer PIH_L

  If !clalev([F:LOF]) Then Local File LAYOUTFAS [LOF] : Endif
  # ---------------------
  If instr(1,[F:PKW]VCRNUM,"/") Then
    SCODLOF = left$([F:PKW]VCRNUM, instr(1,[F:PKW]VCRNUM,"/")-1)
    ILINLOF = val(mid$([F:PKW]VCRNUM, instr(1,[F:PKW]VCRNUM,"/")+1, len([F:PKW]VCRNUM)))
  Else
    SCODLOF = [F:PKW]VCRNUM
    ILINLOF = 0
  Endif
  # ---------------------
  Read [F:LOF]LOF0=SCODLOF;ILINLOF
  If [F:LOF]CPMCREORI = 1 Then
    # Factures Achats
    Filter [PIH] Where [F:PIH]NUM = SCODLOF and [F:PIH]ORIMOD = 6
    If rowcount([F:PIH]) > 0 Then
      Raz PIH_F
      For [F:PIH]
        PIH_F = [F:PIH]NUM
        #PIH_L = [F:LOF]LINLOF
        Gosub WRITE_PKW1_PIH From CNSPIA2STD
        WK = 1
      Next
    Endif
    Filter [PIH]
  Elsif [F:LOF]CPMCREORI = 2 Then
    # Factures Tiers fournisseur
    Filter [PIH] Where [F:PIH]NUM = SCODLOF and [F:PIH]ORIMOD = 3
    If rowcount([F:PIH]) > 0 Then
      Raz PIH_F
      For [F:PIH]
        PIH_F = [F:PIH]NUM
        #PIH_L = [F:LOF]LINLOF
        Gosub WRITE_PKW1_PIH From CNSPIA2STD
        WK = 1
      Next
    Endif
    Filter [PIH]
  Endif
End

############################################################
# Traçabilité amont sur les biens comptables
# Un devis peut avoir des affaires associées.
#    Recherche des affaires (distinctes) : on parcourt les affaires (pas le choix)
Subprog FIND_TREE_AMONT_FAS(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char LOF_F(GLONLOF)
Local Integer LOF_L

  If !clalev([F:LOF]) Then Local File LAYOUTFAS [LOF] : Endif
  # ---------------------
  # Recherche des dépenses
  Filter [LOF] Where [F:LOF]FLGLIKAAS = G_YES and [F:LOF]AASREF = [F:PKW]VCRNUM
  If rowcount([F:LOF]) > 0 Then
    For [F:LOF]
      LOF_F = [F:LOF]CODLOF
      LOF_L = [F:LOF]LINLOF
      #If func CONSPITOOLS.VERIF_LINE([F:LOF]LINLOF, NUM_FAS) = G_OUI Then
        Gosub WRITE_PKW1_LOF
        WK = 1
      #Endif
    Next
  Endif
  Filter [LOF]
End

############################################################
# Traçabilité aval sur les dépenses
# Un devis peut avoir des commandes associées.
#    Recherche des commandes (distinctes) : on parcourt les lignes du devis.
#    Si aucune commande n'est fournie dans les lignes d'avoir, on prend la commande
#    fournie dans l'en-tête d'avoir
Subprog FIND_TREE_AVAL_LOF(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SCODLOF(GLONLOF)
Local Integer ILINLOF
Local Char FAS_F(GLONAAS)
#Local Integer FAS_L

  If !clalev([F:LOF]) Then Local File LAYOUTFAS [LOF] : Endif
  If !clalev([F:FAS]) Then Local File FXDASSETS [FAS] : Endif
  # ---------------------
  If instr(1,[F:PKW]VCRNUM,"/") Then
    SCODLOF = left$([F:PKW]VCRNUM, instr(1,[F:PKW]VCRNUM,"/")-1)
    ILINLOF = val(mid$([F:PKW]VCRNUM, instr(1,[F:PKW]VCRNUM,"/")+1, len([F:PKW]VCRNUM)))
  Else
    SCODLOF = [F:PKW]VCRNUM
    ILINLOF = 0
  Endif
  If [M:PIV1]VCRTYPSEL = NUM_LOF and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:LOF] Where CODLOF=SCODLOF and LINLOF=[M:PIV1]VCRLINSEL
  Else
    Filter [F:LOF] Where CODLOF=SCODLOF and LINLOF=ILINLOF
  Endif
  If rowcount([F:LOF]) > 0 Then
    Raz FAS_F
    For [F:LOF]
      If [F:LOF]FLGLIKAAS = G_YES and [F:LOF]AASREF <> "" Then
        FAS_F = [F:LOF]AASREF
        #FAS_L = [F:LOF]LINLOF
        If func CONSPITOOLS.VERIF_LINE([F:LOF]LINLOF, NUM_LOF) = G_OUI Then
          Read [F:FAS]FAS0=FAS_F
          If !fstat Then
            Gosub WRITE_PKW1_FAS
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:LOF]
  # ---------------------
End

############################################################
# Traçabilité aval sur les biens comptables
# Un devis peut avoir des commandes associées.
#    Recherche des commandes (distinctes) : on parcourt les lignes du devis.
#    Si aucune commande n'est fournie dans les lignes d'avoir, on prend la commande
#    fournie dans l'en-tête d'avoir
Subprog FIND_TREE_AVAL_FAS(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # FGR 16/10/2012 : X3SUIVI71278 : Il n'y a rien en dessous des immobilisations
End

############################################################
$WRITE_PKW1_LOF
  Gosub FILL_LOF From CNSPIF1STD
  Gosub WRITE_PKW1 From CONSPITOOLS
Return

############################################################
$WRITE_PKW1_FAS
  Gosub FILL_FAS From CNSPIF1STD
  Gosub WRITE_PKW1 From CONSPITOOLS
Return
