#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################
# IMPROU : Import / Export des Gammes                                #
######################################################################
# Issue X3-40395 - 2017-05-22 by BAKHA : Routing version import chnages

$ACTION
Case ACTION
    When "IMP_OUVRE" :     Gosub OUVRE
    When "IMPORT" :        Gosub IMPORT
    When "IMP_ZONE"      : Gosub IMP_ZONE
    When "IMP_TAB"       : Gosub IMP_ZONE
    When "EXP_OUVRE"       Gosub EXP_OUVRE
    When "EXPORT"          Gosub EXPORT
    # Issue X3-40395 - new actions
    When "AP_IMPORT"       :   Gosub AP_IMPORT
    When "IMP_RAZCRE"      :   Gosub IMP_RAZCRE
    When "IMP_APRES_CRE"   :   Gosub IMP_APRES_CREMOD
    When "IMP_APRES_MOD"   :   Gosub IMP_APRES_CREMOD
    # End issue X3-40395
Endcase
Return

#######################################################################
#                        IMPORT
#######################################################################

$OUVRE
Local Integer  OKCHAMP
# Issue X3-40395
Local Integer SUPROO : # 1=The component must be excluded or removed ; 2=The component must be excluded or revised

Local Integer NEWECC    # 1=import of a new version, 0 otherwise
Local Char LECCVALMAJ(GLONICVVAL)   # Version of the Route to import
Local Char LECCVALMIN(GLONICVVAL)   # Version of the Route to import
Local Date LSTRDAT                  # Start date of the version to import
Local Integer LROUALT               # Route code to use to create the version "In development"
Local Integer LECCERR               # error code
Local Integer LROHROUALT            # ROUALT in file to import
Local Integer LNBLIG                # Used to be sure that reintegration has been done correctly

Local Integer LREW      # flag to rewrite a record

#If clalev([M:ROU1])=0 : Local Mask ROU1 [ROU1] : Endif
NOMMSK(1) = "ROU1"
# End issue X3-40395

Gosub OUVRE_TEXTE
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
 When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#   textes ROUTING : Gammes Entête           ( texte *71 à *78 )
TSTCHAMP(1) ="ROH*71" : TSTCHAMP(2) ="ROH*72" : TSTCHAMP(3)="ROH*73" : TSTCHAMP(4) ="ROH*74"
TSTCHAMP(5) ="ROH*75" : TSTCHAMP(6) ="ROH*76" : TSTCHAMP(7)="ROH*77" : TSTCHAMP(8) ="ROH*78"

#   textes ROUOPE : Gammes Operations        ( texte *91 à *98 )
TSTCHAMP(21)="ROO*91" : TSTCHAMP(22)="ROO*92" : TSTCHAMP(23)="ROO*93" : TSTCHAMP(24)="ROO*94"
TSTCHAMP(25)="ROO*95" : TSTCHAMP(26)="ROO*96" : TSTCHAMP(27)="ROO*97" : TSTCHAMP(28)="ROO*98"

Gosub OUVRE_TEXTE From TRTX3IMP
Return

######################################################################
$IMPORT
# Issue X3-40395 - if any errors
If LECCERR>0 | GREP=""
    OK=0
    Return
Endif

# Local Char LMSKCOU : LMSKCOU = func STKLIB.MSKDEF    # 10.07 41142
Local Char LMSKCOU(250) : LMSKCOU = dbgstr(1) : # GH 04/10/12 bug 84931

Case IMPFIC
    When "ROH":
        # Issue X3-40395 : Control is done by actions in the screen
        If dim([M:ROU0]ROUECCMAJ)>0 & LECCVALMAJ<>""
            [M:ROU0]ROUECCMAJ = LECCVALMAJ
            [M:ROU0]ROUECCMIN = LECCVALMIN
            If NEWECC=1
                [M:ROU0]ECCSEQ=-1
            Endif
        Endif

    When "ROO":
# ---------------------------------------------------#
#     Opération de gamme                             #
# ---------------------------------------------------#
        Gosub IMP_DECLARE From TRTX3IMP
        # Issue X3-40395 - need to exclude or revise line
        Default Mask [ROU1]
#      #-----------------------------------------------#
#      # Cas de la suppression de ligne (nb poste = 0) #
#      #-----------------------------------------------#
       # Issue X3-40395 - 2017-06-12 by JUSYN : Reset SUPROO
       SUPROO = 0
       Call TST_CHAMP(IMPFIC,"WSTNBR",OKCHAMP) From SUBIMPOBJ
       If OKCHAMP & [F:ROO]WSTNBR=0
          SUPROO = 1
       Elsif LNBCPN>0 & NEWECC=2 & [F:ROO]VALENDDAT=LSTRDAT-1
          SUPROO=2   # Need to exclude OR revise the line
       Endif

# Il faut déterminer s'il s'agit d'une nouvelle ligne ou pas
        ICLEPRIM (0) = "OPENUM" : ICLESEC (0) = "RPLIND"
        NBASTAB = "NBLIG"
        Default Mask [ROU1] # 10.07 41142
#       Gosub RECHERCHE_LIGNE From TRTX3IMP
        Gosub RECHERCHE_LIGNE

        # Issue X3-40395 - error if adding an operation to 'Available to use' version routing
        If LNBCPN>0 & nolign=0 & [M:ROU0]USESTA=2 & GREP="M"
            LECCERR=9
            Gosub IMPERR
        Endif

        # Issue X3-40395 - Line revision

        If IMPFIC="ROO" & LNBCPN>0 & SUPROO<>1
            If [F:ROO]RPLIND>0 and nolign = 0
                Call LOGDBG("Line revision : [F:ROO]RPLIND="+num$([F:ROO]RPLIND)-"nolign="+num$(nolign))
                # find last line for operation
                Local Integer NOL
                For NOL=0 To [M:ROU1]NBLIG-1
                  If [M:ROU1]OPENUM(NOL) = [F:ROO]OPENUM and [M:ROU1]RPLIND(NOL) = [F:ROO]RPLIND-1
                        nolign = [M:ROU1]NOLIG(NOL)
                        Break
                  Endif
                Next

                If nolign>0
                    # Line to revise
                    If [M:ROU0]USESTA=1 & [M:ROU0]ECCDAT<>[0/0/0]
&                    & [M:ROU1]VALSTRDAT(nolign-1)<[M:ROU0]ECCDAT
&                    & [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ECCENDDAT
                        # we have to revise the line
                        Call LOGDBG("Revision of line nolign="+num$(nolign))
                        SUPROO=0    # Security
                        Call B10_NBLIG From ECCROU
                        If mkstat>0
                            LECCERR=100
                            Gosub IMPERR
                        Endif
                    Elsif [M:ROU1]RPLIND(nolign-1)=0
                        # This line can't be revised
                        Call ECR_TRACE([F:ROO]ITMREF-num$([F:ROO]OPENUM)-"This line can't be revised",-1) From GESECRAN
                    Endif
                Else
                    LECCERR=11
                    Gosub IMPERR
                Endif
            Elsif nolign>0 & [M:ROU1]CREFLG(nolign-1)=0
                # Attempt to modify a line which is being created
                LECCERR=12
                Gosub IMPERR
            Endif
        Endif

       # Line suppression  (Sequence < 0)
       If    SUPROO & nolign=0
         Call ECR_TRACE(evalue("[F:ROO]ITMREF")-evalue("num$(-[F:ROO]OPENUM)")-":"-mess(77,9005,1),1) From GESECRAN
         OK = 0
       Elsif SUPROO & nolign<>0
         If IMPFIC="ROO" & LNBCPN>0
&         & !(dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]USESTA=2 | [M:ROU0]ECCDAT=[0/0/0])
&         & [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ROUENDDAT & [M:ROU1]VALSTRDAT(nolign-1)<>[M:ROU0]ECCDAT
             Call EXCLUDE_LINE(nolign-1)
         Else
             status=65

             Call C_NBLIG From SUBROU   # check if deletion is possible
             If !mkstat
                 Call APRES_NBLIG From SUBROU
             Endif

             If mkstat
                LECCERR=100
                GMESSAGE -= [F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN-"OPENUM="-evalue("num$(-[F:ROO]OPENUM)")
                Gosub IMPERR
             Endif
         Endif
       Else
           If GREP <> "M" : Goto RETURN0 : Endif
    #           --> Nouvelle ligne à insérer : Recherche de l'insertion
            If nolign=0
                Gosub RECH_NUM_INSERT
                If nolign <> 0
                    status = 72
                Endif
            Endif
       Endif


    When "ROS":
# ---------------------------------------------------#
#     Jalonnement                                    #
# ---------------------------------------------------#
        Gosub IMP_DECLARE From TRTX3IMP
        ICLEPRIM (0) = "OPENUM" : ICLESEC (0) = ""
        NBASTAB = "BASTAB"
        Default Mask [ROU3] # 10.07 41142
        Gosub RECHERCHE_LIGNE From TRTX3IMP

        # Avoid import of ROS when the operation already exists in a previous version
        # See SUBROU3.C_BASTAB where modification of this kind of line is prohibited
        If nolign>0
&        & dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ<>0
&        & (dim([M:ROU0]NEWALT)<>1 | [M:ROU0]NEWALT=0)
            If [M:ROU0]USESTA=2
                INDTRT+=1
            Else
               Local Integer NOL
               For NOL=0 To [M:ROU1]NBLIG-1
                   If [M:ROU1]OPENUM(NOL)=[M:ROU3]OPENUM(nolign-1) & [M:ROU1]VALSTRDAT(NOL)<>[M:ROU0]ECCDAT
                        INDTRT+=1
                        Break
                   Endif
               Next
            Endif
        Endif
Endcase

Default Mask LMSKCOU # 10.07 41142

$RETURN0
Gosub IMPORT_TEXTE

Return

#---------------------------------------------------------------------
$RECH_NUM_INSERT
#   ------------------------------------------------------------------------   #
#   Recherche du numéro d'insertion                                            #
#   ------------------------------------------------------------------------   #
Local Integer I,J

J=0
For I=[M:ROU1]NBLIG-1 To 0 Step -1
    If [F:ROO]OPENUM >= [M:ROU1]OPENUM(I)
        nolign = I + 2
        J=1
        Break
    Endif
Next I
# si pas trouvé, insertion en première position
If !J : nolign = 1 : Endif
Return

# -------------------------------------------------------------- #
# Reconnaissance d'une ligne importée dans le tableau des lignes #
# -------------------------------------------------------------- #
# !!!!!!!!!!!!!!! Duplication de TRTX3IMP !!!!!!!!!!!!!!!!!!!!!! #
# le traitement standard ne permet pas de gérer les clés         #
# secondaires = 0 (RPLIND)                                       #
# voir en v130 ...........                                       #
$RECHERCHE_LIGNE
Local Char    NCLEPRIM(30), NCLESEC(30), NCLESEC2(30)
Local Char    TABCHPP (30), TABCHPS(30), TABCHPS2(30), NCLEFIC(3),   NCLEZONFIC(30)
Local Integer ICLE, K, I, TYP
Local Char    ACTLIG : ACTLIG = ""
Local Integer NIVREC : # Niveau de recherche : (0,1,2,3)
Local Integer BASTAB : # Nbre de lignes ds le tableau
For ICLE = 0 To dim(ICLEPRIM)-1
# #-------------------------------#
# # Traitement de la clé primaire #
# #-------------------------------#
  If ICLEPRIM(ICLE) <> ""
    If left$(ICLEPRIM(ICLE), 1) = "["
#     #--- On donne l'abréviation du fichier ---#
      NCLEFIC    = mid$(ICLEPRIM(ICLE), 4,3)
      NCLEZONFIC = mid$(ICLEPRIM(ICLE), 8,23)
      K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
    Else
#     #--- On ne donne pas l'abréviation du fichier ---#
      K = find (ICLEPRIM(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If K <> 0
#     #--- La clé est paramétrée : Recherche du nom de la clé ---#
      NCLEPRIM = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
      TYP=evalue ("type("+NCLEPRIM+")")
      If (TYP>10 & evalue(NCLEPRIM)<>"") or (TYP=3 & evalue(NCLEPRIM)<>[0/0/0])
&     or (TYP<11 & TYP<>3 & evalue(NCLEPRIM)<>0)
#       #--- Recherche nom du champs dans le tableau : nom différent ---#
        If TPRIM(ICLE) <> ""
          TABCHPP = TPRIM(ICLE)
#       #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
        Else
          TABCHPP = ICLEPRIM(ICLE)
        Endif
#       #--- Positionnement du niveau de recherche ---#
        NIVREC=1
#       #--------------------------------------#
#       # Traitement de la 1ère clé secondaire #
#       #--------------------------------------#
        If ICLESEC(ICLE) <> ""
#         #--- Il y a une clé secondaire 1 à vérifier ---#
          If left$(ICLEPRIM(ICLE), 1) = "["
#           #--- On donne l'abréviation du fichier ---#
            NCLEFIC    = mid$(ICLESEC(ICLE), 4,3)
            NCLEZONFIC = mid$(ICLESEC(ICLE), 8,23)
            K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
          Else
#           #--- On ne donne pas l'abréviation du fichier ---#
            K = find (ICLESEC(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
          Endif
          If K <> 0
#           #--- Recherche du nom de la clé ---#
            NCLESEC = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
            TYP=evalue ("type("+NCLESEC+")")
            If (TYP>10 & evalue(NCLESEC)<>"") or (TYP=3 & evalue(NCLESEC)<>[0/0/0])
&           or (TYP<11 & TYP<>3)
#             #--- Recherche nom du champs dans le tableau : nom différent ---#
              If TSEC(ICLE) <> ""
                TABCHPS = TSEC(ICLE)
#             #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
              Else
                TABCHPS = ICLESEC(ICLE)
              Endif
#             #--- Positionnement du niveau de recherche ---#
              NIVREC = 2
#             #--------------------------------------#
#             # Traitement de la 2ème clé secondaire #
#             #--------------------------------------#
              If ICLESEC2(ICLE) <> ""
#             #--- Il y a une clé secondaire 2 à vérifier ---#
                If left$(ICLEPRIM(ICLE), 1) = "["
#                 #--- On donne l'abréviation du fichier ---#
                  NCLEFIC    = mid$(ICLESEC2(ICLE), 4,3)
                  NCLEZONFIC = mid$(ICLESEC2(ICLE), 8,23)
                  K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
                Else
#                 #--- On ne donne pas l'abréviation du fichier ---#
                  K = find (ICLESEC2(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
                Endif
                If K <> 0
#                 #--- Recherche du nom de la clé ---#
                  NCLESEC2 = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
                  TYP=evalue ("type("+NCLESEC2+")")
                  If (TYP>10 & evalue(NCLESEC2)<>"") or (TYP=3 & evalue(NCLESEC2)<>[0/0/0])
&                 or (TYP<11 & TYP<>3 & evalue(NCLESEC2)<>0)
#                   #--- Recherche nom du champs dans le tableau : nom différent ---#
                    If TSEC2(ICLE) <> ""
                      TABCHPS2 = TSEC2(ICLE)
#                   #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
                    Else
                      TABCHPS2 = ICLESEC2(ICLE)
                    Endif
#                   #--- Positionnement du niveau de recherche ---#
                    NIVREC = 3
#                 #-- La clé secondaire 2 n'est pas renseignée : On stoppe la recherche --#
                  Else
                    NIVREC = 0
                  Endif
                Endif
              Endif
#           #--- La clé secondaire 1 n'est pas renseignée : On stoppe la recherche ---#
            Else
              NIVREC = 0
            Endif
          Endif
        Endif
        If NIVREC <> 0
          BASTAB = evalue ("[M]"+NBASTAB)
          For I=0 To BASTAB - 1
#           #--- Recherche dans le tableau ---#
            If evalue (NCLEPRIM) = evalue ("[M]"+TABCHPP+"(I)")
#             #--- On a trouve la ligne avec la cle primaire ---#
              If NIVREC > 1
                If evalue(NCLESEC) = evalue ("[M]"+TABCHPS+"(I)")
#                 #--- On a trouvé la ligne avec la cle secondaire 1 ---#
                  If NIVREC = 3
                    If evalue(NCLESEC2) = evalue ("[M]"+TABCHPS2+"(I)")
#                     #--- On a trouvé la ligne avec la cle secondaire 2 ---#
                      ACTLIG = "M" : nolign = I+1
                    Endif
                  Else
                    ACTLIG = "M" : nolign = I+1
                  Endif
                Endif
              Else
                ACTLIG = "M" : nolign = I+1
              Endif
            Endif
            If ACTLIG = "M" Break 2 : Endif
          Next
          Break
        Endif
      Endif
    Endif
  Endif
Next
Return

#---------------------------------------------------------------------
$IMPORT_TEXTE
If IMPFIC="ROH" & G_ENT
   Raz [M:ITC]T_CLE_CLOB(1)
   Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
   [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
Endif
If IMPFIC="ROO" & G_DET
   Raz [M:ITC]T_CLE_CLOB(3)
   Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
   [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
Endif

Return

#---------------------------------------------------------------------
# Issue X3-40395 - new for version import

$AP_IMPORT
Case IMPFIC
    When "ROH"
      If RUPT

        LECCVALMAJ = GIMP(1)
        LECCVALMIN = GIMP(2)
        LSTRDAT    = [F:ROH]ROUSTRDAT
        LROUALT    = val(GIMP(3))
        # If import of "in development' status => Route code in ROUALT is the one to use as "default Route code for in development status"
        If [F:ROH]USESTA=1 & [F:ROH]ROUALT>0 & [F:ROH]ROUALT<99
            LROUALT = [F:ROH]ROUALT
        Endif
        LROHROUALT = [F:ROH]ROUALT

        NEWECC = 0
        SAV_USESTA = [F:ROH]USESTA

        LECCERR = 0
        Gosub ECCCTL
        If OK & LNBCPN>0
            Readlock [ITM]ITM0=[F:ROH]ITMREF
            If fstat
                OK=0
                Call FSTA("ITM") From GLOCK
            Else
                Raz LREW
                If evalue("[F:ITM]ECCROUALT"+"(0)") <> LROUALT
                    Assign "[F:ITM]ECCROUALT"+"(0)" With LROUALT
                    LREW = 1
                Endif
                If [F:ROH]USESTA=2 & evalue("[F:ITM]ECCROUALT"+"(1)")<>[F:ROH]ROUALT
                    Assign "[F:ITM]ECCROUALT"+"(1)" With [F:ROH]ROUALT
                    LREW = 1
                Endif
                If LREW=1
                    Rewrite [ITM]
                Else
                    Unlock [ITM]
                Endif
            Endif
            # Before screens loading, we have to create the revision if needed
            If NEWECC=2
                # Creation of 'In development'
                If clalev([F:RVV2])=0 : Local File RVMVAL [RVL2] : Endif
                Filter [RVV2] Where [RVV2]ITMREF=[F:ROH]ITMREF & [RVV2]FCY=[F:ROH]FCY & [RVV2]USESTA=2
                # A version "available to use" exists
                If rowcount([RVV2])>0
                    Filter [RVV2] Where [RVV2]ITMREF=[F:ROH]ITMREF & [RVV2]FCY=[F:ROH]FCY & [RVV2]USESTA=1
                    # No version "In development" exists => revision action
                    If rowcount([RVV2])=0
                        If clalev([F:ROH2])=0 : Local File ROUTING [ROH2] : Endif
                        [F:ROH2] = [F:ROH]
                        # "D" means : don't control if start date is in the past
                        If instr(1,GIMP(4),"D")
                            Call TR_EXEC2([F:ROH]ITMREF, [F:ROH]FCY, LSTRDAT, LECCVALMAJ, LECCVALMIN, "CRERVV","D") From CRERVV
                        Else
                            Call TR_EXEC2([F:ROH]ITMREF, [F:ROH]FCY, LSTRDAT, LECCVALMAJ, LECCVALMIN, "CRERVV","") From CRERVV
                        Endif
                        [F:ROH] = [F:ROH2]
                        If GERR
                            LECCERR = 100
                            Gosub IMPERR
                        Endif
                    Endif
                Endif
                Filter [RVV2]
            Endif

            If NEWECC & [F:ROH]USESTA=2   # If new version of an available to use, change USESTA to "In development"
                If [F:ITM]ITMREF<>[F:ROH]ITMREF
                    Read [ITM]ITM0=[F:ROH]ITMREF
                Endif

                [F:ROH]USESTA  = 1
                [F:ROH]ROUALT  = LROUALT
                If [F:ROH]ROUALT=0
                    [F:ROH]ROUALT=evalue("[F:ITM]ECCROUALT"+"(0)")
                Endif
            Endif
        Endif
# Issue X3-40395 - 2017-06-14 by JUSYN : Perhaps header title ROUDESAXX text has been inserted into ATEXTRA with Routing code of "Available to use"
#                                        instead of Routing code "In development"
        If LROHROUALT <> LROUALT
            Trbegin [AXX]
            Read [AXX]AXX0 = "ROUTING";"ROUDESAXX";"imp";[F:ROH]ITMREF+"~"+num$(LROHROUALT);[F:ROH]FCY
            If !fstat
                # As Routing status is created "in development" first instead of "available to use" as it's written in the file to import
                # we have to change the key of ATEXTRA from "available to use" Routing code to "in development" Routing code
                [F:AXX]IDENT1=[F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT)
                Rewrite [AXX]
            Endif
            Commit
        Endif

      Endif

    When "ROO"
      If OK
        Gosub ECCCTL
        If OK & LNBCPN>0
              If [F:ROO]VALSTRDAT=[0/0/0]
                  [F:ROO]VALSTRDAT = LSTRDAT
              Endif
        Endif
    Endif
Endcase
Return

######################################################################

#---------------------------------------------------------------------
$IMP_RAZCRE
    Call LOGDBG("IMP_RAZCRE"-[F:ROH]FCY-[F:ROH]ITMREF-num$(LSTRDAT)-"version="+LECCVALMAJ+"/"+LECCVALMIN)
Return

######################################################################
$IMP_APRES_CREMOD
Call LOGDBG("IMP_APRES_CREMOD adxlog="+num$(adxlog)-"sav_usesta="+num$(SAV_USESTA)-"[m:ROU0]USESTA="+num$([M:ROU0]USESTA))
If SAV_USESTA=2 & [M:ROU0]USESTA=1
    # The new version has to be validated
    #Infbox "Validation version"-[M:ROU0]ITMREF-"Site="+[M:ROU0]FCY-num$(adxlog)
    #Dbgaff
    Call LOGDBG("Validation version"-[M:ROU0]ITMREF-"Site="+[M:ROU0]FCY-num$(adxlog))
    Call TR_EXEC2([M:ROU0]ITMREF, [M:ROU0]FCY) From VALRVV
    If GERR
        LECCERR=100
        Gosub IMPERR
    Endif
Endif
Return

############################################################
# ECCCTL : Controls linked to versioning
############################################################
# Parametres E : PFIL = file to control
#            S : POK : 0 if Error otherwise don't change
############################################################
$ECCCTL

Local Integer LNBCPN            # Number of part in version number
Local Integer STAT              # return code
Local Char LECC(GLONICVVAL)     # temporary variable to get version number

Call LOGDBG("----- Call ECCCTL"-IMPFIC-"default masks="+dbgstr(1)-"------------")

If clalev([F:ROH2])=0 : Local File ROUTING [ROH2] : Endif
If clalev([F:RVV2])=0 : Local File RVMVAL [RVV2] : Endif

LNBCPN = func RVMLIB.NBRCPNROU([F:ROH]ITMREF)

Case IMPFIC
    When "ROH" :

        # If product managed by version
        If LNBCPN>0
            # If import of "In development", it must already exist or no other "in development" should exist
            If LSTRDAT=[0/0/0]
                LECCERR=6
                Gosub IMPERR
                Return
            Endif
            Read [RVV2]RVV1=[F:ROH]ITMREF;[F:ROH]FCY;LECCVALMAJ;LECCVALMIN
            If !fstat
                If [F:ROH]USESTA<>[F:RVV2]USESTA
                    LECCERR=3
                    Gosub IMPERR
                    Return
                Elsif [F:ROH]USESTA=2
                    # It's possible to modify an available to use version only with not normal component
                    # Control done later
                Endif
            Elsif fstat
                # Control new version number
                Filter [RVV2] Where [RVV2]ITMREF=[F:ROH]ITMREF & [RVV2]FCY=[F:ROH]FCY
                Read [RVV2]RVV1 Last
                Filter [RVV2]
                # Check if a ROUTING in development already exists with another version number
                If [F:RVV2]USESTA=1 & [F:ROH]USESTA=1
&                & ( [F:RVV2]ECCVALMAJ<>LECCVALMAJ
&                  | [F:RVV2]ECCVALMIN<>LECCVALMIN)
                    LECCERR=7
                    Gosub IMPERR  # ROH in development already exists with another version number
                    Return
                Elsif !fstat
                    If [F:ITM]ITMREF<>[F:ROH]ITMREF
                        Read [ITM]ITM0=[F:ROH]ITMREF
                    Endif
                    If [F:RVV2]ECCVALMAJ=LECCVALMAJ
                        # same Major version => control new minor version
                        Call CALCUL([F:ITM]ECCMIN, [F:RVV2]ECCVALMIN, LECC, GMESSAGE, STAT) From SUBICV
                        If STAT
                            LECCERR=100
                            Gosub IMPERR
                            Return
                        Elsif LECCVALMIN<>LECC
                            LECCERR=4
                            Gosub IMPERR      # New minor version incorrect
                            Return
                        Endif
                    Else
                        # new major version => control all
                        Call CALCUL([F:ITM]ECCMAJ,[F:RVV2]ECCVALMAJ,LECC,GMESSAGE,STAT) From SUBICV
                        If LECCVALMAJ<>LECC
                            LECCERR=4
                            Gosub IMPERR      # New major version incorrect
                            Return
                        Elsif LNBCPN=2
                            Call CALCUL([F:ITM]ECCMIN,"",LECC,GMESSAGE,STAT) From SUBICV
                            If LECCVALMIN<>LECC
                                LECCERR=4
                                Gosub IMPERR      # New minor version incorrect
                                Return
                            Endif
                        Endif
                    Endif
                    If OK
                        Call LOGDBG("New version is correct : old="+[F:RVV2]ECCVALMAJ-[F:RVV2]ECCVALMIN-"new="+LECCVALMAJ-LECCVALMIN)
                    Endif
                    NEWECC=2
                Else
                    # No version exists => control format
                    Call LOGDBG("No version exists => creation of the first version :"-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN)
                    If !func ECCLIB.CTLCPN([F:ROH]ITMREF,1,LECCVALMAJ,LECC)
                        LECCERR=8
                        Gosub IMPERR
                        Return
                    Elsif LNBCPN=2 & !func ECCLIB.CTLCPN([F:ROH]ITMREF,2,LECCVALMIN,LECC)
                        LECCERR=8
                        Gosub IMPERR
                        Return
                    Else
                        NEWECC=1
                    Endif
                Endif
                If OK
                    If (LROUALT<=0 | LROUALT>99)
                        If evalue("[F:ITM]ECCROUALT"+"(0)")=0
                            LECCERR=5
                            Gosub IMPERR
                            Return
                        Else
                            LROUALT=evalue("[F:ITM]ECCROUALT"+"(0)")
                        Endif
                    Endif
                Endif
            Endif
            If OK
                # Control consistency of ROUALT with values in [ITM]
                Filter [ROH2] Where ITMREF=[F:ROH]ITMREF
&                                 & ( ROUALT=[F:ROH]ROUALT & USESTA<>[F:ROH]USESTA
&                                   | ROUALT<>[F:ROH]ROUALT & USESTA=[F:ROH]USESTA)
                If rowcount([ROH2])>0
                    LECCERR=2
                    Gosub IMPERR
                    Return
                Endif
                Filter [ROH2]
            Endif
        Endif

Endcase

Return

##############################################
# Write the error message in the log
$IMPERR
OK=0  # Issue 120837 - 2017-01-11 by CCC : it allows to continue other tests for nothing
Case LECCERR
    When 2 : # Wrong Routing code ($1$). Use $2$ for status $3$
              GMESSAGE = func AFNC.MES3(mess(397,193,1),
&                                      num$([F:ROH]ROUALT),
&                                      num$(evalue("[F:ITM]ECCROUALT"+"("+num$([F:ROH]USESTA-1)+")")),
&                                      mess([F:ROH]USESTA,240,1))

    When 3 : # This version already exists with another status : $1$
             GMESSAGE = func AFNC.MES1(mess(372,193,1),[F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN)

    When 4 : # Incorrect new version number
             GMESSAGE = mess(373,193,1)-[F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN

    When 5 : # Routing code for 'In development' status has not been defined
             GMESSAGE = mess(398,193,1)

    When 6 : # Start date is mandatory
             GMESSAGE = mess(502,177,1)-[F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN

    When 7 : # A version in development already exists ($1$). Impossible to import this version: $2$
             GMESSAGE = [F:ROH]FCY-[F:ROH]ITMREF-func AFNC.MES2(mess(375,193,1), [F:RVV2]ECCVALMAJ-[F:RVV2]ECCVALMIN,LECCVALMAJ-LECCVALMIN)

    When 8 : # Incorrect version format
             If LECC=""
                 GMESSAGE = mess(209,187,1)
             Else
                 GMESSAGE = [F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN-mess(209,187,1)-"("+LECC+")"+GMESSAGE
             Endif
    When 9 : # An operation can't be added to an existing available to use Route version
             GMESSAGE = mess(399,193,1) -[F:ROH]FCY-[F:ROH]ITMREF-LECCVALMAJ-LECCVALMIN-mess(236,190,1)+"="+num$([F:ROO]OPENUM)

    When 11: # X3-40395 - Line for revision not found
             GMESSAGE = [F:ROH]FCY-[M:ROU0]ITMREF-num$([F:ROO]OPENUM)-mess(400,193,1)

    When 12: # Attempt to modify a line which is being created
             GMESSAGE = [F:ROH]FCY-[M:ROU0]ITMREF-num$([F:ROO]OPENUM)-mess(384,193,1)

    When 13: # Reintegration failed
             GMESSAGE = [F:ROH]FCY-[M:ROU0]ITMREF-num$([M:ROU1]OPENUM(nolign-1))-mess(385,193,1)

    When 100 : # GMESSAGE already set
Endcase
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Raz GMESSAGE
Return

Subprog EXCLUDE_LINE(PLIN)
Value Integer PLIN
# Based on SUBBOD.B11_NBLIG

Call LOGDBG("EXCLUDE_LINE line="-num$(nolign-1)-"[M:ROU1]VALENDDAT(PLIN)="+num$([M:ROU1]VALENDDAT(PLIN))-"[M:ROU0]ECCDAT="+num$([M:ROU0]ECCDAT))
If !([M:ROU1]VALENDDAT(PLIN)=[M:ROU0]ROUENDDAT & [M:ROU1]VALSTRDAT(PLIN)<>[M:ROU0]ECCDAT) : End : Endif

[M:ROU1]UPDFLG(PLIN)=1
[M:ROU1]VALENDDAT(PLIN)=[M:ROU0]ECCDAT-1
Call LOGDBG("line excluded [M:ROU1]VALENDDAT(PLIN)="+num$([M:ROU1]VALENDDAT(PLIN)))
End

Subprog LOGDBG(PMES)
Value Char PMES
If (GSTOTRACE=4)
    Call ECR_TRACE(num$(val(timestamp$)/1000) - PMES,0) From GESECRAN
    Call FLUSH_TRACE From GESECRAN
Endif
End


# End issue X3-40395


######################################################################
$IMP_ZONE
Case IMPFIC
  When "ROH"
       If G_ENT & [M:ITC]T_CLE_CLOB(1)<>""
         [M:ROU0]TEXNUM=[M:ITC]T_CLE_CLOB(1)
       Endif

  When "ROO"
       If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & nolign>0 & IMPZON = "WST"
          [M:ROU1]ROOTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
       Endif
Endcase
Return

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE
# Issue X3-40398 - 2017-06-02 by JUSYN : Export - Used scripts and File declarations for none versioned routings
Local Char LEXPTRTGEN(GLONADC)
# adxpno(1)=SUBEXPOBJ and adxpno(2)=script generated WWExxx
LEXPTRTGEN = adxpno(2)
Local Integer OKCHAMP

If clalev ([F:RVV])  <= 0 : Local File RVMVAL [RVV]    : Endif
If clalev ([F:ROH1]) <= 0 : Local File ROUTING [ROH1]  : Endif
If clalev ([F:ROO2]) = 0  : Local File ROUOPE [ROO2]   : Endif
# Issue X3-40398 - 2017-06-02 by JUSYN : End
Gosub OUVRE_TEXTE
Return

$EXPORT
If EXPFIC="ROH" & ! func RVMLIB.NBRCPNROU([F:ROH]ITMREF) # Issue X3-40398 - 2017-06-02 by JUSYN : Export - none versioned routings
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:ROH]TEXNUM)>0 & [F:ROH]TEXNUM<>""
          G_CLE_CLOB=[F:ROH]TEXNUM : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
# Issue X3-40398 - 2017-06-12 by JUSYN : Routing export with version
Elsif EXPFIC="ROH" # versioned Routing
    If [F:ROH]ITMREF=[F:RVV]ITMREF # check if Routing items are already exported
        OK=0
        Return
    Endif
    If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif # read item for default Routing
    If [F:ITM]ITMREF<>[F:ROH]ITMREF
        Read [ITM]ITM0 = [ROH]ITMREF
        If fstat : Raz [F:ITM] : Endif
    Endif

    Filter [RVV] Where [RVV]ITMREF=[ROH]ITMREF & [RVV]FCY=[ROH]FCY
&                Order By Key RVVX=[RVV]USESTA Desc;[RVV]ITMREF;[RVV]FCY;[RVV]ECCSEQ # new key for right order in export file
    For [RVV]RVVX(1) # read ROH1 only when [RVV]USESTA changes
        Read [ROH1]ROH0=[F:RVV]ITMREF;[F:RVV]ROUALT;[F:RVV]FCY
        [F:ROH]=[F:ROH1]
        For [RVV]RVVX # Loop all versions first for "Available to use" and afterwards "In development"
            If G_ENT
               Gosub EXP_RAZ_T1 From TRTX3IMP
               If dim([F:ROH]TEXNUM)>0 & [F:ROH]TEXNUM<>""
                  G_CLE_CLOB=[F:ROH]TEXNUM : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
               Endif
            Endif
            GIMP(1)=[F:RVV]ECCVALMAJ # assign header values of the version to export file
            GIMP(2)=[F:RVV]ECCVALMIN
            GIMP(3)=evalue("num$([F:ITM]ECCROUALT"+"(0))")

            [F:ROH]ROUSTRDAT=[F:RVV]STRDAT
            [F:ROH]ROUENDDAT=[F:RVV]ENDDAT
            Gosub EXPORT0 From =LEXPTRTGEN
            NBEXP += 1
            # read detail lines to version
            For [ROO] Where
&                FCY=[F:ROH]FCY & ITMREF=[F:ROH]ITMREF & ROUALT=[F:ROH]ROUALT
&             & (VALENDDAT>=[F:RVV]STRDAT | (VALENDDAT=[F:RVV]STRDAT-1) | VALENDDAT = [0/0/0])
&             & (VALSTRDAT<=[F:RVV]ENDDAT | [F:RVV]ENDDAT=[0/0/0])

              # In order to make a difference between a line (operation line) that needs to be excluded and
              # one line that has been revised the VALENDDAT of a revised line is set to blank.
              # Excluded lines keep their VALENDDAT.
                Filter [ROO2] Where
&                     FCY=[F:ROH]FCY & ITMREF=[F:ROH]ITMREF
&                   & ROUALT=[F:ROH]ROUALT & OPENUM=[F:ROO]OPENUM
&                   & RPLIND=[F:ROO]RPLIND+1
                Look [ROO2] First
                Filter [ROO2]
                If !fstat
                    Raz [F:ROO]VALENDDAT
                Endif

                Gosub EXPORT1 From =LEXPTRTGEN
                # Export Scheduling ROS only if available in template
                Call TST_CHAMP("ROS","OPENUM",OKCHAMP) From SUBIMPOBJ
                If OKCHAMP
                    # Export Scheduling record too; Check next operation number's operation if available in version
                    Read [ROS]ROS0=[F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
                    If !fstat
                        If [F:ROS]NEXOPENUM <> 0
                            Filter [ROO2] Where
&                                 FCY=[F:ROH]FCY & ITMREF=[F:ROH]ITMREF & ROUALT=[F:ROH]ROUALT & OPENUM = [F:ROS]NEXOPENUM
&                               & (VALENDDAT>=[F:RVV]STRDAT | (VALENDDAT=[F:RVV]STRDAT-1) | VALENDDAT = [0/0/0])
&                               & (VALSTRDAT<=[F:RVV]ENDDAT | [F:RVV]ENDDAT=[0/0/0])
                            Read [ROO2] First
                            If fstat : [F:ROS]NEXOPENUM = 0 : Endif
                        Endif
                        Gosub EXPORT2 From =LEXPTRTGEN
                    Endif
                Endif
            Next
            OK=1
            EXPFIC="ROH"
        Next
    Next
    Filter [RVV]
    Filter [ROO2]
    Raz GIMP(1) : Raz GIMP(2) : Raz GIMP(3)
    OK=0
    EXPFIC="ROH"
Endif
# Issue X3-40398 - 2017-06-12 by JUSYN : End

If EXPFIC="ROO"
   Gosub EXP_RAZ_T3 From TRTX3IMP
   If G_DET
      Gosub EXP_RAZ_T3 From TRTX3IMP
      If dim([F:ROO]ROOTEX)>0 & [F:ROO]ROOTEX<>""
         G_CLE_CLOB=[F:ROO]ROOTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
      Endif
   Endif
Endif

Return

#######################################################################

