#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PDSYPS2H

######################################################################################
## Clic droit Pièce sur l'appel d'offre
######################################################################################
Subprog IB_NBPQH

  GBOUT2 = mess(35,198,1)
  If GPILNAV>1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If find("GESPQH",GNAVIG(1..GPILNAV)) Then GBOUT2="" Endif
  Endif
End

Subprog B2_NBPQH

  If clalev([F:PQH])=0 : Local File PQUOTAT [PQH] : Endif 
  Filter [F:PQH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  NOL = nolign-1
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:PSH2]PQHNUM(NOL)
  Call OBJET("PQH",[M:PSH2]PQHNUM(NOL),"") From GOBJET
  [M:PSH2]PQHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End

######################################################################################
## Clic droit Pièce sur la commande
######################################################################################
Subprog IB_NBPOH
Local Integer NOL

  GBOUT2 = mess(191,198,1)
  If GPILNAV>1 Then
    NOL = nolign-1
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    If [M:PSH2]POHTYP(NOL)=1 and find("GESPOH",GNAVIG(1..GPILNAV)) Then GBOUT2="" 
    Elsif [M:PSH2]POHTYP(NOL)=2 and find("GESPOC",GNAVIG(1..GPILNAV)) Endif
  Endif
End

Subprog B2_NBPOH
Local Integer NOL

  If clalev([F:POH])=0 : Local File PORDER [POH] : Endif 
  Filter [F:POH]
  GCONSULT = 2
  Local Char SAV_VCRNUM
  NOL = nolign-1
  # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
  # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
  SAV_VCRNUM = [M:PSH2]POHNUM(NOL)
  If [M:PSH2]POHTYP(NOL)=1 Then
    Call OBJET("POH",[M:PSH2]POHNUM(NOL),"") From GOBJET
  Elsif [M:PSH2]POHTYP(NOL)=2 Then
    Call OBJET("POC",[M:PSH2]POHNUM(NOL),"") From GOBJET
  Endif
  [M:PSH2]POHNUM(NOL) = SAV_VCRNUM 

  GCONSULT = 0
End


######################################################################################

