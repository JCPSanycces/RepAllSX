#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du fichier EDIPAR

Raz GBIDC1, GBIDC2
Call OBJET("EDP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "FIN_ACTION" : Gosub FIN_ACTION
 When "EXEACT"     : Gosub EXEACT
 When "LIENS2"     : Gosub LIENS2
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "ABANDON"    : Gosub ABANDON
 When "SEL_TABLE"  : Case COUZON
                      When "MES" : Gosub S_EDP
                     Endcase
 When "VERF_TABLE" : Case OBJET
                      When "EDP" : Gosub V_EDP
                     Endcase
 When default
Endcase
Return

$SETBOUT
If [M]MES="" | find(GREP,"C","D","M")
  Call VIREBOUT(CHAINE,"U") From GOBJET   : # Bouton Duplication
Endif
# bug 37720
CHAINE += "A" : # Bouton Supprimer
Return

$FIN_ACTION
Case BOUT
 When "U" : Gosub RAFFRAICHIR From GOBJSUB
Endcase
Return

$EXEACT
Case BOUT
  When "S" : OK=0    : # pour ne pas exécuter la suppression standard
Endcase
Return

$LIENS2
If [M]GRP>0
 Call SET_FILNAT
 Grizo FILREF, NATPAY
Else
 Actzo FILREF, NATPAY
Endif
Return

$RAZCRE
$RAZDUP
If [M]GRP>0
 Grizo FILREF, NATPAY
Else
 Actzo FILREF, NATPAY
Endif
Return

$ABANDON
Actzo FILREF, NATPAY
Return

Subprog SET_FILNAT
Local File EDIPAR [EDP]
Read [EDP]EDP0 = [M]MES;[M]BAN;0;1
If fstat
 Read [EDP]EDP0 = [M]MES;"";0;1
 If fstat : Raz [F:EDP] : Endif
Endif
[M]FILREF=[F:EDP]FILREF
[M]NATPAY=[F:EDP]NATPAY
End

# Copie 1 --> 2
$TRTCOP
If [M]DOSORG=nomap
 Local File EDIPAR [EDP1]
Else
 Local File =[M]DOSORG+".EDIPAR" [EDP1]
Endif
If [M]DOSDES=nomap
 Local File EDIPAR [EDP2]
Else
 Local File =[M]DOSDES+".EDIPAR" [EDP2]
Endif

Call TEMPON("T") From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_COP
Call TEMPOFF From GESECRAN

Close Local File [EDP1], [EDP2]
Return

$TR_COP
GOK=1
Trbegin [EDP2]
Delete [EDP2] Where MES=[M:EDP1]MES & BAN=[M:EDP1]BAN
If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".EDIPAR" : Goto ROLL_TR_COP
Elsif fstat>5
  GOK = 0 : Call RSTA("EDP2",[M:EDP1]MES-[M:EDP1]BAN) From GLOCK : Goto AB_TR_COP
Endif
For [EDP1]EDP0 Where MES=[M:EDP1]MES & BAN=[M:EDP1]BAN
  [F:EDP2] = [F:EDP1]
  Write [EDP2]
  If fstat
    GOK=0 : Call RSTA("EDP2",[F:EDP1]MES-[F:EDP1]BAN-num$([F:EDP1]GRP)) From GLOCK : Break
  Endif
Next
If   GOK<0 : Goto ROLL_TR_COP
Elsif !GOK : Goto AB_TR_COP
Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


$S_EDP
OBJET = "EDP"
Local Char ZONE(10)

# Critère de sélection
For ZONE="MES","BAN","GRP"
 If ZONE=COUZON : Break : Endif
 CRITERE += " & "+ZONE+"=[M]"+ZONE
Next
If CRITERE<>"" 
 CRITERE=right$(CRITERE,4)
 Filter [EDP] Where evalue(CRITERE)
Endif

# Positionnement par défaut dans la fenêtre de sélection
If !GINTRA
 # EXPSTART n'est pas gérée en intradon
 For ZONE="MES","BAN","GRP"
  If ZONE=COUZON : Assign "[F:EDP]"+ZONE With VALEUR
  Else           : Assign "[F:EDP]"+ZONE With evalue("[M]"+ZONE)
  Endif
 Next
 Read [EDP]EDP0(3) =
 If !fstat
  For ZONE="MES","BAN","GRP"
   If ZONE=COUZON : EXPSTART += " & "+ZONE+"=[L]VALEUR"
   Else           : EXPSTART += " & "+ZONE+"=[M]"+ZONE
   Endif
  Next
  EXPSTART=right$(EXPSTART,4)
 Endif
Endif
If EXPSTART=""
 START = COUZON
Endif

If CRITERE<>"" : Filter [EDP] : Endif
Return

$V_EDP
For ZONE="MES","BAN","GRP"
 If ZONE<>COUZON
  Assign "[M]"+ZONE With evalue("[F:EDP]"+ZONE)
 Endif
Next
mkstat=4
Return


###############################
# Etiquettes du masque EDP1
###############################

Subprog AM_GRP(VALEUR)
Variable Decimal VALEUR
If VALEUR>0 
 Grizo NATPAY, FILREF
Else
 Actzo NATPAY, FILREF
Endif
End

Subprog C_FILREF(VALEUR)
Variable Char    VALEUR()
If varmode(FILREF)=0 & VALEUR=""
 GMESSAGE = mess(92,121,1) : # Extension obligatoire
 mkstat = 2
Endif
End

Subprog D_SEGOCC(VALEUR)
Variable Decimal VALEUR
VALEUR=1 
End

Subprog C_SEGOCC(VALEUR)
Variable Decimal VALEUR
If !VALEUR
 mkstat=2
Endif
End
