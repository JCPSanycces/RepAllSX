#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe PIMPL
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
$AINSERT_CONTROL_BEFORE
  Case this.PIMTYP
    When 2,3
      # Affaire mixte
      this.PIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_PJM(this.ACTX, this.OPPNUM)
    When 4
      # Budget
      this.PIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(this.ACTX, this.OPPNUM, this.PBUCOD)
    When 5, 6, 7, 8 # Issue X3-33209 - 2017-06-12 by FGR/TEJAC : 8 was missing.
      # Taches MO/Mat/Mixte
      this.PIMNUM = func PIMPL_CSTD_PROGS.GET_PIMNUM_TASK(this.ACTX, this.OPPNUM, this.TASCOD)
    When Default
  Endcase
  # -------------------------------------
  If this.PIMTYP = 1 Then
    this.PIMSTA = [V]CST_AYES
  Endif
  # -------------------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  # -------------------------------------
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
  # -------------------------------------
  Gosub AINSERT_AUPDATE_CONTROL_BEFORE
  # -------------------------------------
Return

#######################################################################################
$AINSERT_AUPDATE_CONTROL_BEFORE
  If this.PIMDESAX1 = "" Then
    this.PIMDESAX1 = left$(this.PIMDESAXX, type(this.PIMDESAX1)-10)
  Endif
Return

#######################################################################################
$ACONTROL
  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL)
    Return
  Endif
  # -------------------------------------
  If this.PIMTYP <> 1 Then
    If this.ASTALIN = [V]CST_ANEW Then
      If this.PIMSTA <> [V]CST_ANO Then
        If this.TCHACTION <> "STATUS" Then
          [L]ASTATUS = fmet this.SETERROR("PIMSTA", mess(18,9804,1), [V]CST_AERROR)
        Endif
      Endif
    Elsif this.ASTALIN = [V]CST_AUPD Then
      If this.TCHACTION <> "STATUS" Then
        If this.PIMSTA <> this.snapshot.PIMSTA Then
          [L]ASTATUS = fmet this.SETERROR("PIMSTA", mess(18,9804,1), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Endif
  # -------------------------------------
  Case this.PIMTYP
    When 2, 3
      # Affaire mixte
      If this.ASTALIN = [V]CST_ANEW Then
        # Issue X3-86224 - 2018-05-04 by TEJAC : START
        #If this.OPPSTATE <> 1 Then
        #  [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
        #Endif
        If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.FCY, "PJMDEFSTA") = 2 Then
          If this.OPPSTATE <> 2 Then
            [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Else
          If this.OPPSTATE <> 1 Then
            [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
        # Issue X3-86224 - 2018-05-04 by TEJAC : END
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.TCHACTION <> "STATUS" Then
          If this.OPPSTATE <> this.snapshot.OPPSTATE Then
            [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
      Endif
    When 4
      # Budget
      If this.ASTALIN = [V]CST_ANEW Then
        If this.PBUSTATE <> 1 and this.PBUSTATE <> 2 Then
          [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(18,9804,1), [V]CST_AERROR)
        Endif
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.TCHACTION <> "STATUS" Then
          If this.PBUSTATE <> this.snapshot.PBUSTATE Then
            [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
      Endif
    When 5, 6, 7
      # Taches MO/Mat/Mixte
      If this.ASTALIN = [V]CST_ANEW Then
        If this.TASSTATE <> 1 Then
          [L]ASTATUS = fmet this.SETERROR("TASSTATE", mess(18,9804,1), [V]CST_AERROR)
        Endif
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.TCHACTION <> "STATUS" Then
          If this.TASSTATE <> this.snapshot.TASSTATE Then
            [L]ASTATUS = fmet this.SETERROR("TASSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
      Endif
    When Default
  Endcase
  # -------------------------------------
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL)
    Return
  Endif
Return

