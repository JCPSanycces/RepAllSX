################################################################################
## Etiquettes écran TRTAUT
################################################################################
#############################################################
## Contrôles sur la date et période de paye
#############################################################
## La date de paye doit être comprise entre
## Le premier jour du mois de paye (GMOIPAY) et
## la fin du mois + un nb jour de "décalage" (GJMAX)
## Entre le 1 et GJMAX on avertit seulement
#############################################################

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
#MIPEA - 2017-02-16- X3-11258- START
Local Integer OK
If GFONCTION1="GESABA" : End : Endif
If VALEUR<GMOIPAY or VALEUR>eomonth(GMOIPAY)+GJMAX
 GMESSAGE = mess(21,10702,1)-"("+format$("D:"+GFMMOI,GMOIPAY)+")"
# Date incompatible avec le mois de paye
 mkstat = 2 : End
Endif
If VALEUR<GMOIPAY+GJMAX
 OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,GMOIPAY+GJMAX)
&  +"-"+format$("D:"+GFMDAT4,eomonth(GMOIPAY)+GJMAX)+")",OK) From GESECRAN
# Date en dehors de la période de paye
 If OK<>2 : mkstat = 2 : End : Endif
Endif
#Local Integer OK
#If GFONCTION1="GESABA" : End : Endif
####Provisoire car pb avec globale
#GJMAX=10
#
#If VALEUR<GMOIPAY or VALEUR>eomonth(GMOIPAY)+GJMAX
# GMESSAGE = mess(21,10702,1)-"("+format$("D:"+GFMMOI,GMOIPAY)+")"
## Date incompatible avec le mois de paye
# mkstat = 2 : End
#Endif
#If VALEUR<GMOIPAY+GJMAX
# OK = 2 : Call AVERTIR(mess(22,10702,1)-"("+format$("D:"+GFMDAT4,GMOIPAY+GJMAX)
#&  +"-"+format$("D:"+GFMDAT4,eomonth(GMOIPAY)+GJMAX)+")",OK) From GESECRAN
## Date en dehors de la période de paye
# If OK<>2 : mkstat = 2 : End : Endif
#Endif
#MIPEA - 2017-02-16- X3-11258- END
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR > [M:DIA]DAT
#Date de paye en dehors de la période
 Call AVERTIR(mess(22,10702,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : Endif
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Local Integer OK

#JOJAC - 2016-08-10 - X3PEOP-894 - START
If VALEUR<[M:DIA]DATDEB
#Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
#JOJAC - 2016-08-10 - X3PEOP-894 - END

#MIPEA - 2017-02-16- X3-11258- START
###Provisoire car pb avec globale
#GJMAX=10
#MIPEA - 2017-02-16- X3-11258- END

If [M:DIA]DAT>VALEUR+GJMAX
#Date de paye en dehors de la période
 Call AVERTIR(mess(22,10702,1),OK) From GESECRAN
 If OK=1 : mkstat=2 : Endif
Endif
End

#############################################
## Comptage des bulletins de paye
#############################################
Subprog BULPAY(DATPAY,MAXBUL,NOMBRE)
Value    Date    DATPAY
Variable Integer MAXBUL
Variable Integer NOMBRE
Local File ADOSSIER [ADS]
Local Char    APPLI(10)
Local Integer BULLETIN
BULLETIN = 0
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#Call NOMBRE(1,MAXBUL) From GLOCK
#JOJAC - 2016-08-10 - X3PEOP-894 - END
#LIPET - 08-08-2016 - X3PEOP-893 - START
#MAXBUL=100000


# SBA : 98167
 Local Char VALMAX(30)
 If fmet GACTX.AGETLICPAR("MAXEMPLOYEES",VALMAX)=[V]CST_ATRUE
   MAXBUL=val(VALMAX)
 Else
   MAXBUL=0
 Endif
#LIPET - 08-08-2016 - X3PEOP-893 - END
If MAXBUL=0
 NOMBRE = 99999999 : End
Endif
For [ADS]DOSSIER
 APPLI = [F:ADS]DOSSIER
#MIPEA - 2017-02-16- X3-11258- START
 If APPLI<>GDOSX3 & filinfo(filpath("FIL","VALEMP","fde",APPLI),0)>=0
  Onerrgo ERREUR
  Local File =APPLI+".VALEMP" [VEP]
  Onerrgo
# If APPLI<>GDOSX3 & filinfo(filpath("FIL","VALEMP","fde",APPLI),0)>=0
#  Local File =APPLI+".VALEMP" [VEP]
#MIPEA - 2017-02-16- X3-11258- END
  Columns [VEP] (PYRMON,EMP,PYRDAT,ORIDAT,RVSDAT)
  For [VEP]VEP2(2) Where PYRMON=gdat$(1,month(DATPAY),year(DATPAY)) & RVSDAT=[0/0/0] & ORIDAT=[0/0/0]
   BULLETIN += 1
  Next
  Columns [VEP]
  Close Local File [VEP]
 Endif
Next
NOMBRE = max(0,MAXBUL-BULLETIN)
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TRTAUT) 09/01/2014 18:00:15 (LANEG)
######################################################################################
#81491
Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
If [M]DATPAI<VALEUR
 [M]DATPAI=VALEUR
 Affzo DATPAI
Endif
End

Subprog C_DATPAI(VALEUR)
Variable Date    VALEUR
If VALEUR<[M]DAT
 GMESSAGE= mess(229,10703,1)
 mkstat=2 :  End
Endif
If VALEUR>eomonth([M]DAT)
 Local Integer OK
 OK = 2
 Call AVERTIR(mess(232,10703,1),OK) From GESECRAN
 If OK=1 : mkstat = 2 : End : Endif
Endif
End


