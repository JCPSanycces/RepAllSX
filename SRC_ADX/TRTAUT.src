Subprog S_PAYFRQ(VALEUR)
Variable Char    VALEUR()

#  If clalev([F:HRPEO])=0  :  Local File HRPERIOD [HRPEO]  :  Endif
#  Filter [F:HRPEO] Where [F:HRPEO]PEREND(1) >= GMOIPAY and [F:HRPEO]PEREND(1) <= eomonth(GMOIPAY)
