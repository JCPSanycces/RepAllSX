#<AdxTL>@(#)4.0.0.0 $Revision$ Génération automatique des payes
#MIPEA SOURCE REMERGE
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Already done by DBA
###################################################################################################################

#** V8 : Waiting Update Accounting **#
#************************************#

Local Char PARAM(10)(1..2) , VALEUR(10)
#JOJAC - START
#Call TRAITE_CHAR(VALEUR,PARAM,"","TRTAUT","TRTAUT",4,"") From GTRAITE
Call TRAITE_CHAR(VALEUR,PARAM,"","HRTRTAUT","HRTRTAUT",4,"") From GTRAITE
#JOJAC - END
End

#########################################
## Traitement des actions : TRTAUT
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : Gosub KILLVARG
 When "DEBUT"       : Gosub DEBUT       :#86255
 When "BOUTON"      : Gosub BOUTON      :#86255
 When "SORTIE"      : Gosub SORTIE      :#86255
Endcase
Return


#######################################################
## (Actions nécessaires à la saisie des paramètres)
#######################################################
$OUVRE
Gosub OUVFIC

Local Integer NBPCE
Local Char    CRITERE(250), CRITCTR(250)
Local Char    TIT(50)
Local Char    MESSA(50)
Local Char    SYMBOLE(50)
Local Char    SYMBOLET(50)
Local Char    VALPAR(10)
Local Date    DATDEB , DATFIN
Local Integer I , J , K , OK , OPT
#MIPEA - 2017-02-16- X3-11258- START
Local Char    CRITSPEC(250) #DEHEN - 2016-12-08 - JIRA : X3-15347
#MIPEA - 2017-02-16- X3-11258- END

TIT = mess(1,10703,1)     : # Génération automatique de la paye
NBPCE=0

#86255
If dim(GCURLEG)>0 :  Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Local Mask TRTAUT [DIA]
Raz [M:DIA]
#JOJAC - START
#Mask not populated from paramaters
#[M:DIA]DATDEB = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
#[M:DIA]DATFIN = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))
#[M:DIA]DATPAI = gdat$(func DIVPAYE.INIPARUSR("DATREG","",""))
#[M:DIA]DAT    = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))

Call LECMEMO("STD","[M:DIA]","hraut") From GMEMO
#86255
Call AFF_MEMO From DIVPAYE
Return

#86255
######################################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#86255
######################################################
$AFF_MEMO
Call AFF_MEMO From DIVPAYE
Return

#86255
######################################################
$BOUTON
#JOJAC - START
#Case BOITE
#When "TRTAUT","TRTDAT","TRTSUP","TRTRECCUM","TRTRECAL","EXTRACT"
Case BOITE
When "HRTRTAUT","TRTDAT","TRTSUP","TRTRECCUM","TRTRECAL","EXTRACT"
 Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
  Endcase
Endcase
#JOJAC - END
Return

#86255
######################################################
$DEBUT
 Affzo [DIA]
 Setmok [DIA] With 0
 Call AFF_MEMO From DIVPAYE
Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
Gosub OUVRE From WPDEFTABLE
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:SRV])=0 : Local File SERVICE    [SRV] : Endif
If clalev([F:PRF])=0 : Local File PROFIL     [PRF] : Endif
If clalev([F:VRA])=0 : Local File VARIA      [VRA] : Endif
If clalev([F:VEP])=0 : Local File VALEMP     [VEP] : Endif
If clalev([F:VLA])=0 : Local File VALEUR     [VLA] : Endif
If clalev([F:VPR])=0 : Local File VALPRV     [VPR] : Endif
If clalev([F:VAN])=0 : Local File VALANA     [VAN] : Endif
If clalev([F:VAN1])=0: Local File VALANA     [VAN1]: Endif
If clalev([F:VLA1])=0: Local File VALEUR     [VLA1]: Endif
If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:ECH])=0 : Local File EXCEPTH    [ECH] : Endif
If clalev([F:ECV])=0 : Local File EXCEPTV    [ECV] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA     [HRPOA] : Endif
If clalev([F:HRPCB])=0 : Local File PRVCLOB    [HRPCB] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
If clalev([F:BCB])=0 : Local File BCLOB      [BCB] : Endif
If clalev([F:CVR])=0 : Local File CALVAR     [CVR] : Endif
If GINTMT=1
 If clalev([F:PSN])=0 : Local File PRESTATION [PSN] : Endif
 If clalev([F:PSN1])=0: Local File PRESTATION [PSN1]: Endif
Endif
If clalev([F:VEP2])=0 : Local File VALEMP     [VEP2] : Endif
#LIPET - 08-08-2016 - X3PEOP-893 - START
#JOJAC - 2017-02-20 - START
#If clalev([F:HRCTR])=0 : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:HRCTRX])=0 : Local File EMPLOCTR   [HRCTRX] : Endif
#JOJAC - 2017-02-20 - END
#LIPET - 08-08-2016 - X3PEOP-893 - END
Gosub DEFVARG
Return

$DEFVARG
#LIPET - 08-08-2016 - X3PEOP-893 - START
If dim(TRTAUTPRF)<0   : Global Char TRTAUTPRF(GLONPRF)               : Raz TRTAUTPRF   : Endif
#LIPET - 08-08-2016 - X3PEOP-893 - END
If dim(TRTAUTCOD)<0   : Global Char TRTAUTCOD(30) (1..5000) : Raz TRTAUTCOD   : Endif
If dim(TRTAUTNBCOD)<0 : Global Integer TRTAUTNBCOD          : Raz TRTAUTNBCOD : Endif
If dim(TRTAUTNBVPR)<0  : Global Integer TRTAUTNBVPR             : Raz TRTAUTNBVPR : Endif
If dim(TRTAUTVPRCOD)<0 : Global Char TRTAUTVPRCOD(30) (1..1000) : Raz TRTAUTVPRCOD: Endif
If dim(TRTAUTVPRVAL)<0 : Global Decimal TRTAUTVPRVAL (1..1000)  : Raz TRTAUTVPRVAL: Endif
If dim(TRTAUTNBPCB)<0  : Global Integer TRTAUTNBPCB             : Raz TRTAUTNBPCB : Endif
If dim(TRTAUTPCBCOD)<0 : Global Char TRTAUTPCBCOD(30) (1..1000) : Raz TRTAUTPCBCOD: Endif
If dim(TRTAUTPCBID2)<0 : Global Char TRTAUTPCBID2(50) (1..1000) : Raz TRTAUTPCBID2: Endif
#LIPET - 08-08-2016 - X3PEOP-893 - START
#FQ92876-US2675-
GORITITCOL = 1
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub SAUV_GLOBAL_CPT From TRTHRCPT
#END FQ92876-US2675-
#LIPET - 08-08-2016 - X3PEOP-893 - END
Return

$KILLVARG
If dim(TRTAUTPRF)>0   : Kill TRTAUTPRF   : Endif
If dim(TRTAUTCOD)>0   : Kill TRTAUTCOD   : Endif
If dim(TRTAUTNBCOD)>0 : Kill TRTAUTNBCOD : Endif
If dim(TRTAUTVPRCOD)>0 : Kill TRTAUTVPRCOD : Endif
If dim(TRTAUTVPRVAL)>0 : Kill TRTAUTVPRVAL : Endif
If dim(TRTAUTNBVPR)>0  : Kill TRTAUTNBVPR  : Endif
If dim(TRTAUTPCBCOD)>0 : Kill TRTAUTPCBCOD : Endif
If dim(TRTAUTNBPCB)>0  : Kill TRTAUTNBPCB  : Endif
If dim(TRTAUTPCBID2)>0 : Kill TRTAUTPCBID2 : Endif
#LIPET - 08-08-2016 - X3PEOP-893 - START
#FQ92876-US2675-
GORITITCOL = 0
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub REST_GLOBAL_CPT From TRTHRCPT
#END FQ92876-US2675-
#LIPET - 08-08-2016 - X3PEOP-893 - END
Return

#######################################################
## Contrôle des paramètres
#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
#86255
#Affectations indispensables pour avoir GCURLEG renseigné dans la 2ième fenêtre
#Sinon on le perd...
If dim([M:DIA]LEG)>0 : GCURLEG=[M:DIA]LEG : Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If GLEGFIL<>"" & GCURLEG="" : GCURLEG = GLEGFIL : Endif

Return

#######################################################
## Exécution silencieuse du traitement
#######################################################
$EXEC
Local Date    DATFINPAY , DATPAY , DATMAT , DATECH , JOUR, DATCTR, DATPAI :#81491
Local Integer RETOUR , NOK , OKC
Local Char    MATCUR(GLONEML) , MATREF(GLONEML) , MATRI(GLONEML) , SYMBOLE(50), SYMBOLET(50), CTR(GLONHRCTR)
Local Integer MAXBUL , RESTE
Local Char    CONTRAT(GLONVCR) , BULLETIN(GLONVCR)
Local Integer NBPREST , PRESTAT(1..100) , OKCONT , TOUS
Local Integer MOIS , NBMOIS , TBMOIS(1..12)

#LIPET - 08-08-2016 - X3PEOP-893 - START
Local Integer IBUL, MAXIBUL
MAXIBUL=50
Local Date TABSTRCTR (0..MAXIBUL)
Local Date TABENDCTR (0..MAXIBUL)
#LIPET - 08-08-2016 - X3PEOP-893 - END

#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

#MIPEA - 2017-02-16- X3-11258- START
# vérif du nombre de bulletins
Call BULPAY([M:DIA]DAT,MAXBUL,RESTE)
If RESTE<=0
 Call ECR_TRACE(mess(94,10703,1)-":"-num$(MAXBUL),1) From GESECRAN
 # Nb maximum de bulletins atteints
 Goto FIN_EXEC
Endif
#***********DEBRAYER EN V7 : CAUSE GESTION DES LICENCES EN COURS***************#
##Vérif du nombre de bulletins
#Call BULPAY([M:DIA]DAT,MAXBUL,RESTE)
#If RESTE<=0
# Call ECR_TRACE(mess(94,10703,1)-":"-num$(MAXBUL),1) From GESECRAN
# # Nb maximum de bulletins atteints
# Goto FIN_EXEC
#Endif
#RESTE=5000
#******************************************************************************#
#*!
#MIPEA - 2017-02-16- X3-11258- END
CRITERE = '[F:CPY]LEG="'+GCURLEG+'"'
CRITERE -= '& [F:ID]ENAFLG=2 & [F:ID]FLGPAY=2'
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif


# Filtre sur les contrats
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#CRITCTR -= '[F:HRCTR]CTRDAT<=['+num$([M:DIA]DATFIN)+'] & [F:HRCTR]STACTR=2'
#CRITCTR -= '& ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=['+num$([M:DIA]DATDEB)+'])'
CRITCTR -= '(([F:HRCTR]FLGRET<>2 & [F:HRCTR]CTRDAT<=['+num$([M:DIA]DATFIN)+'])|([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=['+num$([M:DIA]DATFIN)+']))'
CRITCTR -= '& [F:HRCTR]STACTR=2'
CRITCTR -= '& ([F:HRCTR]XITDAT=[0/0/0] or [F:HRCTR]XITDAT>=['+num$([M:DIA]DATDEB)+'])'
#JOJAC - START
CRITCTR -= '& ([F:HRCTR]PERCOD="'+[M:DIA]PERCOD+'")'
#JOJAC - END
#JOJAC - 2016-08-10 - X3PEOP-894 - END
If [M:DIA]ALLFCY<>2
 CRITCTR -= '& [F:HRCTR]ETRFCY="'+[M:DIA]FCY+'"' :# site
Endif
If [M:DIA]ALLSRV<>2
 CRITCTR -= '& [F:HRCTR]ETRSRV="'+[M:DIA]SRV+'"' :# service
Endif
If [M:DIA]ALLPRF<>2
 CRITCTR -= '& [F:HRCTR]PROPRF="'+[M:DIA]PRF+'"' :# profil
Endif

#MIPEA - 2017-02-16- X3-11258- START
#DEHEN - 2016-12-08 - JIRA : X3-15347 - START
CRITSPEC = "1=1"
GPOINT = "CREFLTSPEC" : Gosub ENTREE From EXEFNC
#DEHEN - 2016-12-08 - JIRA : X3-15347 - END
#MIPEA - 2017-02-16- X3-11258- END

If [M:DIA]POP<>""
#86255
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY,
&    [HRPOA]POA0= [M:DIA]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITCTR) & [F:HRPOA]REFNUM<>"" & evalue(CRITSPEC) #DEHEN - 2016-12-08 - JIRA : X3-15347
Else
 Link [HRCTR] With
&    [ID]ID0=[F:HRCTR]REFNUM,
&    [FCY]FCY0=[F:HRCTR]ETRFCY,
&    [CPY]CPY0=[F:FCY]LEGCPY
& As [LNK]
& Where evalue(CRITERE) & evalue(CRITCTR) & evalue(CRITSPEC) #DEHEN - 2016-12-08 - JIRA : X3-15347
Endif

#LIPET - 08-08-2016 - X3PEOP-893 - START
#For [LNK]
For [LNK]CTR0(2)
 Raz [L]TABSTRCTR, [L]TABENDCTR, [L]IBUL
 For [LNK]CTR0
  If [L]IBUL=0 | [F:HRCTR]CTRDAT>[L]TABENDCTR([L]IBUL-1)
   #Initialisation boundaries : First loop or current contrat record already included
   [L]TABSTRCTR ([L]IBUL)=[F:HRCTR]CTRDAT
   [L]TABENDCTR ([L]IBUL)=[F:HRCTR]CTRDAT
   If [L]IBUL=0 & [F:HRCTR]FLGCREBUL<>2
    #Search the real started contrat record (= checked with breakdown)
    Filter [HRCTRX] Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT<[F:HRCTR]CTRDAT & FLGCREBUL=2
    Read [HRCTRX]CTR0 Last
    Filter [HRCTRX]
    If !fstat : [L]TABSTRCTR ([L]IBUL)=[F:HRCTRX]CTRDAT : Endif
   Endif
   #Search the laster contrat record (= not checked with breakdown)
   If [F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT<[M:DIA]DATFIN
    For [HRCTRX]CTR0 Where REFNUM=[F:HRCTR]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & CTRDAT>[F:HRCTR]XITDAT
     If [F:HRCTRX]FLGCREBUL=2 : Break : Endif
     [L]TABENDCTR ([L]IBUL)=[F:HRCTRX]CTRDAT
    Next
   Endif
   [L]IBUL+=1
  Endif
 Next
 #JOJAC - 2016-08-10 - X3PEOP-894 - START
 #Next
 #JOJAC - 2016-08-10 - X3PEOP-894 - END
 For K=0 To [L]IBUL-1
#LIPET - 08-08-2016 - X3PEOP-893 - END
  Gosub SALARIE
  If RESTE<=0 : Break : Endif
  #JOJAC - 2016-08-10 - X3PEOP-894 - START
 Next
 #JOJAC - 2016-08-10 - X3PEOP-894 - END
Next
If RESTE>0 & RESTE<20
 Call ECR_TRACE(mess(95,10703,1)-":"-num$(RESTE),1) From GESECRAN
 # Attention : nb maximum de bulletins restants
Endif

If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(num$(NBPCE)-mess(8,10703,1),0) From GESECRAN : # En-tête de paye créés
Endif

$FIN_EXEC
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

# Traitement d'un salarié
$SALARIE
MATRI  = [F:HRCTR]REFNUM
DATMAT = [M:DIA]DAT
CTR    = [F:HRCTR]CTRNUM
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#DATCTR = [F:HRCTR]CTRDAT
DATCTR =  [L]TABENDCTR (K)
#JOJAC - 2016-08-10 - X3PEOP-894 - END

Gosub LECEMP From WPDEFTABLE
Call CONTROLE(MATRI,DATMAT,CTR,[M:DIA]CRI,OKC,1) From DIVPAYE
If !OKC : Return : Endif

# Repositionnement sur le contrat initial car le Lecemp a pu changer !
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR

DATPAY=[M:DIA]DAT
DATPAI=[M:DIA]DATPAI :#81491
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#If val(func AFNC.PARAM('UNQDATPAY',[F:HRCTR]ETRFCY))<>2 & [F:HRCTR]XITDAT<>[0/0/0]  :# date de paie différentes pour CDD succéssif.
If val(func AFNC.PARAM('DMA',[F:HRCTR]ETRFCY))=12 & val(func AFNC.PARAM('UNQDATPAY',[F:HRCTR]ETRFCY))<>2 & [F:HRCTR]XITDAT<>[0/0/0]
#JOJAC - 2016-08-10 - X3PEOP-894 - END
 DATPAY = max(min([M:DIA]DATFIN,[F:HRCTR]XITDAT),GMOIPAY)
 #81491
 If DATPAI<DATPAY
  DATPAI=DATPAY
 Endif
 #
Endif
If [F:ID]FLGINT<>2

 # Paie des permanents
  ##**82073
  If [M:DIA]FLGSEVBUL<>2
    # On génère une paye s'il n'y en a pas pour ce contrat sur le mois courant
    # One pays if there is no generates for the contract on the current month
    #GMOIPAY = [16/08/2016]
   #Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON=GMOIPAY
#MIPEA - 2017-02-16- X3-11258- START
#JOJAC - 2017-03-02 - START
   #Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON=GMOIPAY
  #Else
   #Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON>GMOIPAY
    Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & ENDDAT=[M:DIA]DATFIN
  Else
    Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & ENDDAT>[M:DIA]DATFIN
#JOJAC - 2017-03-02 - END
#   Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON=[M:DIA]DATDEB
#  Else
#   #Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON>GMOIPAY
#   Filter [VEP] Where EMP=MATRI & CTRNUM=CTR & CTRDAT=[F:HRCTR]CTRDAT & PYRMON>[M:DIA]DATDEB
#MIPEA - 2017-02-16- X3-11258- END
  Endif
  Read [VEP]VEP1 First
  Filter[VEP]
  If fstat>2
   OKCONT = 1
   Gosub TRTCONT
   If OKCONT
    #JOJAC - 2016-08-10 - X3PEOP-894 - START
    #DATDEB = max([M:DIA]DATDEB,[F:HRCTR]CTRDAT)
    DATDEB = max([M:DIA]DATDEB,[L]TABSTRCTR (K))
    #JOJAC - 2016-08-10 - X3PEOP-894 - END
    If [F:HRCTR]XITDAT=[0/0/0]
     DATFIN = [M:DIA]DATFIN
    Else
     DATFIN = min([M:DIA]DATFIN,[F:HRCTR]XITDAT)
    Endif
    Raz PRESTAT , NBPREST : Gosub PAYE
   Endif
  Endif

Elsif GINTMT=1

 # Paie des intermittents

 DATECH = [M:DIA]DATFIN : # Date où une prestation est considérée comme échue
#JOJAC - 2016-08-10 - X3PEOP-894 - START
 K=0 : [L]TABSTRCTR(K)=DATCTR
#JOJAC - 2016-08-10 - X3PEOP-894 - END

 Case [F:HRCTR]CALPAY

  When 1 : # Par contrat

   # On génère une paye par mois
   # si toutes les prestations de ce mois sont échues

   Raz TBMOIS,NBMOIS
#LIPET - 08-08-2016 - X3PEOP-893 - START
   #For [PSN1]PSN0 Where CTRNUM=CTR & BUL=""
   For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & CTRDAT=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
    MOICUR = month([F:PSN1]PSNENDDAT)
    If !find(MOICUR,TBMOIS(1..NBMOIS))
     NBMOIS += 1
     TBMOIS(NBMOIS) = MOICUR
    Endif
   Next
   For MOIS=1 To NBMOIS
    OKCONT = 0
    DATDEB = [31/12/2999]
    DATFIN = [0/0/0]
    Raz PRESTAT , NBPREST
    TOUS = 1
#LIPET - 08-08-2016 - X3PEOP-893 - START
    #For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & month([F:PSN1]PSNENDDAT)=TBMOIS(MOIS)
    For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & month([F:PSN1]PSNENDDAT)=TBMOIS(MOIS) & CTRDAT=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
     If [F:PSN1]PSNENDDAT<=DATECH
      DATDEB = min(DATDEB,[F:PSN1]PSNSTRDAT)
      DATFIN = max(DATFIN,[F:PSN1]PSNENDDAT)
      NBPREST += 1
      PRESTAT(NBPREST) = [F:PSN1]PSNNUM
     Else
      TOUS = 0
     Endif
    Next
    If NBPREST>0 & TOUS=1
     Gosub PAYE
    Endif
   Next MOIS

  When 2 : # Par prestation (échue)

   # On génère autant de bulletins que de nouvelles prestations échues
#LIPET - 08-08-2016 - X3PEOP-893 - START
   #For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & PSNENDDAT<=DATECH
   For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & PSNENDDAT<=DATECH & CTRDAT=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
    Raz PRESTAT
    NBPREST = 1
    PRESTAT(1) = [F:PSN1]PSNNUM
    DATDEB = [F:PSN1]PSNSTRDAT
    DATFIN = [F:PSN1]PSNENDDAT
    Gosub PAYE
   Next

  When 3 : # Par jour

   # On génère autant de bulletins que de nouvelles prestations échues
   # Mais on regroupe les prestations du même jour

   JOUR = [0/0/0]
   Raz PRESTAT , NBPREST
#LIPET - 08-08-2016 - X3PEOP-893 - START
   #For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & PSNENDDAT<=DATECH
   For [PSN1]PSN0 Where CTRNUM=CTR & BUL="" & PSNENDDAT<=DATECH & CTRDAT=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
    If [F:PSN1]PSNSTRDAT=[F:PSN1]PSNENDDAT
     If JOUR<>[F:PSN1]PSNSTRDAT
      If NBPREST
       Gosub PAYE
       Raz PRESTAT , NBPREST
      Endif
     Endif
     JOUR = [F:PSN1]PSNSTRDAT
     NBPREST += 1
     PRESTAT(NBPREST) = [F:PSN1]PSNNUM
     DATDEB = JOUR
     DATFIN = JOUR
    Else
     If NBPREST
      Gosub PAYE
      Raz PRESTAT , NBPREST
     Endif
     NBPREST = 1
     PRESTAT(1) = [F:PSN1]PSNNUM
     DATDEB = [F:PSN1]PSNSTRDAT
     DATFIN = [F:PSN1]PSNENDDAT
     Gosub PAYE
     Raz PRESTAT , NBPREST
    Endif
   Next
   If NBPREST
    Gosub PAYE
    Raz PRESTAT , NBPREST
   Endif
 Endcase
Endif

Return

# Traitement d'une prestation/paye

$PAYE
# Verrou
SYMBOLE = "VEP"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:HRCTR]CTRNUM+format$("D:"+GFMDAT,[F:HRCTR]CTRDAT)
Lock =SYMBOLE
If fstat
 Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(10,100,1),1) From GESECRAN
 Return
Endif
SYMBOLET = "TPS"+format$("D:"+GFMDAT,DATPAY)+"\"+[F:HRCTR]CTRNUM+format$("D:"+GFMDAT,[F:HRCTR]CTRDAT)
Lock =SYMBOLET
If fstat
 Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(10,100,1),1) From GESECRAN
 Unlock =SYMBOLE
 Return
Endif

# Si un site est en décalage de paye et pas les autres, l'utilisateur risque de lancer la génération
# pour tous sites ou toutes sociétés avec une date de paye au 31 (non décalée).
# Un message signale à l'utilisateur que la date de paye est incohérente avec le jour de paye

Call PARAML([F:HRCTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
##**82073
If val(VALPAR)<>0 & val(VALPAR)<>day(DATPAY)
 # Salarié en décalage de paye. Date de paye le
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(117,10702,1)-VALPAR,-1) From GESECRAN
 While day(DATPAY)<>val(VALPAR)
  DATPAY += 1
 Wend
 #81491
 If DATPAI<DATPAY
  DATPAI=DATPAY
 Endif
 #
Endif

# Création de la paye

Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(7,10703,1)-BULLETIN,0) From GESECRAN
 # Création en-tête de paye
 NBPCE += 1
 Filter [F:VEP2] Where PYRMON=[F:VEP]PYRMON & EMP=[F:VEP]EMP & BUL<>[F:VEP]BUL
 Look [F:VEP2]VEP2 Last
 Filter [F:VEP2]
 If fstat>=2
  RESTE -= 1
  If RESTE<=0
   Call ECR_TRACE(mess(94,10703,1)-":"-num$(MAXBUL),1) From GESECRAN
   # Nb maximum de bulletins atteints
  Endif
 Endif
Endif
Unlock =SYMBOLE
Unlock =SYMBOLET
Return


# Contrôle pour les permanents

###########################################################################
## Critères pour générer une nouvelle paye :
## - Répondre à la sélection
## - Etre actif
## - Avoir accès au code d'accès en exécution
## - Avoir droit à la fonction pour le site du salarié
## - Le profil doit être défini
## - Le salarié doit être présent, au moins partiellement, sur la période
## - Aucune paye ne doit être en état "saisi" sur la même fiche contrat (chrono+date)
## - Aucune paye ne doit avoir une date >= date saisie
## - La période de paye ne doit pas avoir été payée en totalité (sauf si entête multiples autorisée)
###########################################################################

$TRTCONT
##**82073
Filter [VEP] Where EMP=[F:ID]REFNUM & CTRNUM=CTR & CTRDAT=DATCTR
Read [VEP]VEP0 Last
If fstat<=2
 ##**82073
 DATFINPAY = [F:VEP]ENDDAT
 If [F:VEP]STA<2
  # Paye non calculée au
  Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(24,10702,1)-format$("D:"+GFMDAT4,DATPAY),1) From GESECRAN
  OKCONT = 0 : Return
 Elsif DATFINPAY>[M:DIA]DATFIN #& [M:DIA]FLGSEVBUL<>2
  # Période incohérente avec la paye précédente
  Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(4,10703,1),1) From GESECRAN
  OKCONT = 0 : Return
 #93233 : Add test on FLGSEVBUL
 Elsif [M:DIA]FLGSEVBUL<>2 & ([F:VEP]STRDAT>=[M:DIA]DATDEB | [F:VEP]ENDDAT>=[M:DIA]DATDEB)
&&     ([F:VEP]STRDAT<=[M:DIA]DATFIN | [F:VEP]ENDDAT<=[M:DIA]DATFIN)
  # La période chevauche la période de la paye précédente
  Call ECR_TRACE([F:ID]REFNUM-CTR-":"-mess(122,10703,1),-1) From GESECRAN
  OKCONT = 0 : Return
 Endif
Endif
Return

#######################################################
## Transaction de création des payes
#######################################################

$TR1
GOK=1
Trbegin [VEP], [VLA], [VAN], [HRPCB]
 Raz [L]BULLETIN
 ##**82073 & 81491
# Call CREPAY([F:ID]REFNUM,DATPAY,DATDEB,DATFIN,[M:DIA]DATPAI,0,CTR,PRESTAT,[F:HRCTR]CALPAY,BULLETIN
#&            ,[M:DIA]FLGOUTBUL,[M:DIA]PRFSUP,[F:HRCTR]CTRDAT)
#JOJAC - 2016-08-10 - X3PEOP-894 - START
# Call CREPAY([F:ID]REFNUM,DATPAY,DATDEB,DATFIN,DATPAI,0,CTR,PRESTAT,[F:HRCTR]CALPAY,BULLETIN
#&            ,[M:DIA]FLGOUTBUL,[M:DIA]PRFSUP,[F:HRCTR]CTRDAT)
#JOJAC - 2016-12-12 - START
# Call CREPAY([F:HRCTR]REFNUM,DATPAY,DATDEB,DATFIN,DATPAI,0,CTR,PRESTAT,[F:HRCTR]CALPAY,BULLETIN
#&            ,[M:DIA]FLGOUTBUL,[M:DIA]PRFSUP,[F:HRCTR]CTRDAT,[L]TABSTRCTR(K))
  Call CREPAY([F:HRCTR]REFNUM,DATPAY,DATDEB,DATFIN,DATPAI,0
&              ,CTR,PRESTAT,[F:HRCTR]CALPAY,BULLETIN,[M:DIA]FLGOUTBUL,[M:DIA]PRFSUP,[F:HRCTR]CTRDAT,[L]TABSTRCTR(K),[M:DIA]PERCOD,[M:DIA]PERNUM,[M:DIA]PERYEA) From TRTAUT
#JOJAC - 2016-12-12 - END
#JOJAC - 2016-08-10 - X3PEOP-894 - END
 If    GOK<0 : Goto ROL_TR1
 Elsif GOK=0 : Goto AB_TR1
 Endif

Commit
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL : Goto TR1 : Endif
Return

#MIPEA - 2016-07-18 - REQ 114309 US274 - START
#80173 : Effectif TPE
$CAL_NBREMP
If filinfo(filpath("FIL","HRNBREMP","fde",nomap),0)<=0 : Return : Endif
If func AFNC.ACTIV("KFR")
 Local Integer NBREMP (0..1) , NBRYEA(0..1)
 Local Date DATAPL (0..1)
 Raz [F:VEP]NBREMP,[F:VEP]CPYYEA,[F:VEP]CPYAPL,[F:VEP]FCYYEA,[F:VEP]FCYAPL
 Call SET_HRNBE([F:VEP]FCY,[F:VEP]PYRDAT,[L]NBREMP,[L]NBRYEA,[L]DATAPL) From SUBHRNBE # MIPEA - 2016-07-18 - REQ 114309 US274 - this call does not exist on U9 or GX3APP
 If [L]NBREMP(0)
  [F:VEP]NBREMP=[L]NBREMP(0) : [F:VEP]CPYYEA([L]NBREMP(0)-1)=[L]NBRYEA(0) : [F:VEP]CPYAPL([L]NBREMP(0)-1)=[L]DATAPL(0)  :# Dim()=5
 Endif
 # [F:VEP]NBREMP=[L]NBREMP(1) ?!?
 [F:VEP]FCYYEA=[L]NBRYEA(1) : [F:VEP]FCYAPL=[L]DATAPL(1)                                  :# Dim()=1
Endif
Return
#MIPEA - 2016-07-18 - REQ 114309 US274 - END

#######################################################
## Création d'une paye
#######################################################
#MIPEA - 2016-07-20 - REQ 114309 US274 - START
#JOJAC - 2016-12-12 - START
#Subprog CREPAY (MATCUR, DATPAY, DATDEB, DATFIN, DATPAI, COMPTE, CONTRAT, PRESTAT, MODCAL, BULLETIN, FLGOUT, PRFSUP, DATCTR, MINDATCTR)
Subprog CREPAY (MATCUR, DATPAY, DATDEB, DATFIN, DATPAI, COMPTE, CONTRAT, PRESTAT, MODCAL, BULLETIN, FLGOUT, PRFSUP, DATCTR, MINDATCTR,PERCOD,PERNUM,PERYEA)
#JOJAC - 2016-12-12 - END
#Subprog CREPAY (MATCUR, DATPAY, DATDEB, DATFIN, DATPAI, COMPTE, CONTRAT, PRESTAT, MODCAL, BULLETIN, FLGOUT, PRFSUP, DATCTR)
Value    Char    MATCUR ()
Value    Date    DATPAY
Value    Date    DATDEB
Value    Date    DATFIN
Value    Date    DATPAI
Value    Integer COMPTE
Value    Char    CONTRAT ()
Value    Integer PRESTAT(1..)
Value    Integer MODCAL
Variable Char    BULLETIN ()
Value    Integer FLGOUT
Value    Char    PRFSUP ()
Value    Date    DATCTR
Value    Date    MINDATCTR
#JOJAC - 2016-12-12 - START
Value    Char PERCOD
Value Integer PERNUM
Value Integer PERYEA
#JOJAC - 2016-12-12 - END
#MIPEA - 2016-07-20 - REQ 114309 US274 - END

Local Char    MATREF(GLONEML) , MATRI(GLONEML), CTR(GLONHRCTR)
Local Date    DERPAY , DATMAT
Local Decimal NEWVAL , STDVAL , ARRONDI
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#Local Integer I , J , K , OK , OPT , REPRISE , INITYP , OKVAR , STAT
Local Integer I , J , K , OK , OPT , REPRISE , INITYP , OKVAR , STAT, ITRT
#JOJAC - 2016-08-10 - X3PEOP-894 - END
Local Integer MAXBUL , RESTE, CONSERVATION, ECRIT
Local Char    COMPTEUR(GLONANM) , DERBUL(GLONVCR)
Local Integer NBPREST , NBVAR
Local Char    TBVAR(GLONVRA)(1..100)
Local Decimal VALEUR(1..100)
Local Char WDSP([V]GLONDSP)
#LIPET - 08-08-2016 - X3PEOP-893 - START
#Local Integer WINICCE(1..9)
Local Integer WJ,WINICCE(1..20) #FQ92876-US2675-
Local Char WSAVGSOC(GLONCPY) #FQ92876-US2675-
Local Integer DECALE
#MIPEA - 2017-02-16- X3-11258- START
# Issue 113512 - 2016-11-09 by BRBAN : X3PEOP-3623
Local Char VARHRS(GLONVRA)
Local Char VARMTH(GLONVRA)
Local Char VARZON1(GLONVRA)
Local Char VARZON2(GLONVRA)
# -#MIPEA - 2017-02-16- X3-11258- END

If clalev ([F:DIE])=0 : Local File =GTABCPT+"GDIE" [DIE] : Endif #FQ92876-US2675-
#LIPET - 08-08-2016 - X3PEOP-893 - END

If clalev([F:PCA])=0 : Local File CAISSE    [PCA] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF [TCA] : Endif

#MIPEA - 2017-02-16- X3-11258- START
# vérif du nombre de bulletins
If COMPTE
 Call BULPAY(DATPAY,MAXBUL,RESTE)
 If RESTE<=0
  Call ECR_TRACE(mess(94,10703,1)-":"-num$(MAXBUL),1) From GESECRAN
  # Nb maximum de bulletins atteints
  End
 Endif
Endif
#***********DEBRAYER EN V7 : CAUSE GESTION DES LICENCES EN COURS***************#
##Vérif du nombre de bulletins
#If COMPTE
# Call BULPAY(DATPAY,MAXBUL,RESTE)
# If RESTE<=0
#  Call ECR_TRACE(mess(94,10703,1)-":"-num$(MAXBUL),1) From GESECRAN
#  # Nb maximum de bulletins atteints
#  End
# Endif
#Endif
#RESTE=5000
#******************************************************************************#
#*
#*
#* @param MATCUR
#* @param DATPAY
#* @param DATDEB
#* @param DATFIN
#* @param DATPAI
#* @param COMPTE
#* @param CONTRAT
#* @param PRESTAT
#* @param MODCAL
#* @param BULLETIN
#* @param FLGOUT
#* @param PRFSUP
#* @param DATCTR
#* @param MINDATCTR
#* @param PERCOD
#* @param PERNUM
#* @param PERYEA
#*!
#MIPEA - 2017-02-16- X3-11258- END

MATREF = MATCUR
MATRI  = MATCUR
DATMAT = DATFIN
CTR    = CONTRAT
Gosub LECEMP From WPDEFTABLE

# Repositionnement sur le contrat initial car le Lecemp a pu changer !
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR

# Le contrat lu dans LECEMP correspond au contrat en cours à la date de paye(ce contrat peut être payé).
# Ce n'est peut-être pas le contrat affiché dans le bulletin.
# Ex : 1 contrat au 28/01/08 soldée et 1 contrat au 31/01/08. La Date de paie au 28/01/08.
If [F:ID]FLGINT=2
 Filter [HRCTR] Where CTRNUM=CONTRAT
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
Endif

#JOJAC - 2017-03-10 - START
#If [M:DIA]PERNUM=0
#  Call ECR_TRACE(mess(245,10703,1),1) From GESECRAN
#  GOK = 0 : End
#Endif
#JOJAC - 2017-03-10 - END

### Vérifs diverses
If [F:HRCTR]ETRFCY=""
 # Site du salarié non renseigné
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(14,10711,1),1) From GESECRAN
 GOK = 0 : End
Endif
If [F:HRCTR]ETRSRV=""
 # Service du salarié non renseigné
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(15,10711,1),1) From GESECRAN
 GOK = 0 : End
Endif
If [F:HRCTR]PROPRF=""
 # Profil du salarié non renseigné
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(17,10711,1),1) From GESECRAN
 GOK = 0 : End
Endif

# Paye précédente
If [F:HRCTR]FLGVAR=2
 Filter [VEP] Where EMP=MATCUR & CTRNUM=CONTRAT & CTRDAT=DATCTR
Else
 Filter [VEP] Where EMP=MATCUR & CTRNUM=CONTRAT
Endif
Read [VEP]VEP0 Last
Filter[VEP]
If fstat<=2
 DERPAY  = [F:VEP]PYRDAT
 DERBUL  = [F:VEP]BUL
 REPRISE = 0
Else
 Raz DERPAY,DERBUL
 REPRISE = 1
Endif
If !FLGOUT : FLGOUT=1 : Endif

# En tête
Raz [F:VEP]
Call LECTCA(15,STAT) From SUBTCA
If !STAT
  GMESSAGE = mess(149,10702,1) : # Compteur bulletin non défini
  GOK = 0 : Return
Else
  COMPTEUR= [F:TCA]CODNUM(4)
Endif

#Call NUMERO(COMPTEUR,[F:HRCTR]ETRFCY,[F:HRCTR]CTRDAT,CONTRAT,BULLETIN,STAT) From SUBANM
Call NUMERO(COMPTEUR,[F:HRCTR]ETRFCY,DATPAY,CONTRAT,BULLETIN,STAT) From SUBANM
If STAT
 GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
 GOK = 0 : End
Endif
[F:VEP]BUL    = BULLETIN
[F:VEP]CTRNUM = CONTRAT
#LIPET - 08-08-2016 - X3PEOP-893 - START
#[F:VEP]CTRDAT = [F:HRCTR]CTRDAT
If dim([F:VEP]CTRDAT) > 0 : [F:VEP]CTRDAT = [F:HRCTR]CTRDAT : Endif
#LIPET - 08-08-2016 - X3PEOP-893 - END

#MIPEA - 2017-02-16- X3-11258- START
If dim([F:VEP]STRCTRDAT) > 0
 If [L]MINDATCTR<>[0/0/0]
  [F:VEP]STRCTRDAT =[L]MINDATCTR
 Else
  [F:VEP]STRCTRDAT =[F:HRCTR]CTRDAT
 Endif
Endif
#MIPEA - 2017-02-16- X3-11258- END

# Multi_leg & multi_société
Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GCURLEG=[F:CPY]LEG
#JOJAC - 2017-03-07 - START
GSOCIETE = [F:CPY]CPY
#JOJAC - 2017-03-07 - END

If MODCAL>1
 [F:VEP]PSNNUM = PRESTAT
Endif
[F:VEP]CALPAY = MODCAL
[F:VEP]EMP    = MATCUR
[F:VEP]PYRDAT = DATPAY
[F:VEP]PYRMON = GMOIPAY
[F:VEP]STRDAT = DATDEB
[F:VEP]ENDDAT = DATFIN
[F:VEP]PAYDAT = DATPAI
[F:VEP]STA    = 1
[F:VEP]PST    = 1
[F:VEP]FLGLOCK = 1 : # Verrouillé US1918 65062
[F:VEP]FCY    = [F:HRCTR]ETRFCY
[F:VEP]SRV    = [F:HRCTR]ETRSRV
[F:VEP]PRF    = [F:HRCTR]PROPRF
[F:VEP]FLGVAR = [F:HRCTR]FLGVAR
[F:VEP]PRFSUP = PRFSUP
[F:VEP]CODACS = [F:ID]CODACS
[F:VEP]FLGOUT = FLGOUT
[F:VEP]LEG= GCURLEG
#JOJAC - START
[F:VEP]PERCOD = PERCOD
[F:VEP]PERYEA = PERYEA
[F:VEP]PERNUM = PERNUM
### AWAITING MULTI CURRENCY
#MIPEA - 2017-05-10- US X3-11287- START
[F:VEP]CURCOD = [F:HRCTR]CUR
#MIPEA - 2017-05-10- US X3-11287- END
#JOJAC - END
#JOJAC
# SEGAY  US 2325-88174 BULDEM
If dim([F:VEP]FLGDEMAT) > 0 : [F:VEP]FLGDEMAT = 1 : Endif
If dim([F:VEP]BULDEMAFF) > 0
    If(func SUBEML.DISP_BULDEM([F:VEP]EMP,[F:VEP]CTRNUM,[F:HRCTR]CTRDAT)<>0 and  func SUBEML.GETVAL_BULDEM([F:VEP]EMP)=2)
      [F:VEP]BULDEMAFF=2
    Else
      [F:VEP]BULDEMAFF=1
    Endif
Endif

#LIPET - 08-08-2016 - X3PEOP-893 - START
#FQ92876-US2675-
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>func DIVPAYE.GETSOC([F:VEP]FCY)
 Read [CPY]CPY0=func DIVPAYE.GETSOC([F:VEP]FCY)
Endif
Call VALDEF_FLD_ANA([F:CPY]CPY) From SUBVEP
#END FQ92876-US2675-

Gosub CAL_NBREMP
#LIPET - 08-08-2016 - X3PEOP-893 - END
If dim([F:VEP]CREDAT)>0 : [F:VEP]CREDAT = date$ : Endif
If dim([F:VEP]CREUSR)>0 : [F:VEP]CREUSR = GUSER : Endif
If dim([F:VEP]CRETIM)>0 : [F:VEP]CRETIM = time  : Endif
Gosub GETRPTBUL
# Organisme URSSAF
#MIPEA - 2016-09-30 - X3PEOP-893 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDURS
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
Call ORGANISME ([F:ID]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[F:VEP]ORG,[L]ORGLINE) From SUBORG
#Call ORGANISME ([F:ID]REFNUM,[F:HRCTR]ETRFCY,[F:HRCTR]CTRNUM,[F:VEP]ORG,GINDURS-1) From SUBORG
#MIPEA - 2016-09-30 - X3PEOP-893 - END
#LIPET - 08-08-2016 - X3PEOP-893 - START
#** V7 : Waiting Update Accounting **#
## Analytique
K = 0 : CONSERVATION = 0
Raz [F:VAN] : # LS 23/07/02

If [CPT]REFNUM<>MATCUR
 Read [CPT]CPT0 = MATCUR
Endif
If [CPT]REFNUM=MATCUR
 Raz [L]WDSP, [L]WINICCE
 [L]WDSP = [F:CPT]DSP
 Raz [L]WINICCE
 For [L]J = 1 To [V]GOPTCANA
#JOJAC - 2016-08-10 - X3PEOP-894 - START
     #[L]WINICCE([L]J) = evalue("[F:CPT]INICCE"+num$([L]J))
     #FQ92876-US2675-
     If [L]J <= GNBDIE
       [L]WJ=find(GDIE(J),[F:CPT]DIE(0..[V]GOPTCANA-1))
       If [L]WJ > 0 :
         [L]WINICCE([L]J) = evalue("[F:CPT]INICCE("+num$([L]WJ-1)+")")
       Endif
     Endif
     #END FQ92876-US2675-
#JOJAC - 2016-08-10 - X3PEOP-894 - END
 Next

 #On relit un CPR éventuel car le CPR lu dans le WPDEFTABLE et celui présent
 #maintenant peut etre différent (cf la relecture si [ID]FLGINT = 2 dont
 #la syntaxe est étrange ... à confirmer DBA)
Read [F:CPR]CPR0 = [F:HRCTR]REFNUM ; [F:HRCTR]CTRNUM ; [F:HRCTR]CTRDAT
 If fstat = 0
    Raz [L]WDSP, [L]WINICCE
    [L]WDSP = [F:CPR]DSP
    Raz [L]WINICCE
    For [L]J = 1 To [V]GOPTCANA
    #JOJAC - 2016-08-10 - X3PEOP-894 - START
         #[L]WINICCE([L]J) = evalue("[F:CPR]INICCE"+num$([L]J))
         [L]WINICCE([L]J) = evalue("[F:CPR]INICCE("+num$([L]J-1)+")") : #FQ92876-US2675-
    #JOJAC - 2016-08-10 - X3PEOP-894 - END
    Next
 Endif
 If [L]WDSP <> ""
  [F:VEP]DSP = [L]WDSP
 Else
  [F:VAN]EMP = MATCUR

#JOJAC - 2017-02-10 - START
#For J=1 To GOPTCANA
#   [L]OPT = [L]WINICCE([L]J)
  For J=1 To min(GNBDIE,GOPTCANA)
   [L]OPT = [L]WINICCE([L]J)
   Read [DIE]DIE0=GDIE(J)
   If !fstat
     [F:VAN]DIE(J-1)=GDIE(J)
#JOJAC - 2017-02-10 - END

   Case OPT
    When 1 : # Conservation
     CONSERVATION = 1
    When 2 : # Annulation
     [F:VAN]CCE(J-1) = ""
    When 3 : # Section par défaut
     If dim(SECDEF)<0
      Local Char SECDEF(GLONCDE)
      Call PARAML([F:VEP]FCY,"CCECDE",SECDEF) From ADOVAL
     Endif
     If SECDEF<>""
      If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
      If [F:CPY]CPY<>func DIVPAYE.GETSOC([F:VEP]FCY)
       Read [CPY]CPY0=func DIVPAYE.GETSOC([F:VEP]FCY)
      Endif
      #JOJAC - 2017-03-08 - START
      WSAVGSOC=GSOCIETE
      GSOCIETE=[F:CPY]CPY
      #JOJAC - 2017-03-08 - END
      #JOJAC - 2017-01-31 - START
      #Call INISEC([F:VAN]CCE(J-1),SECDEF,num$(J)) From SUBCDE
      Call INISEC([F:VAN]CCE(J-1),SECDEF,GDIE(J)) From SUBCDE
      #JOJAC - 2017-03-08 - START
      GSOCIETE=WSAVGSOC
      #JOJAC - 2017-03-08 - END
      #JOJAC - 2017-01-31 - END
     Endif
   Endcase
#JOJAC - 2017-02-10 - START
  Endif
 #JOJAC - 2017-02-10 - END
  Next J
  [F:VAN]PYRDAT = DATPAY

  If CONSERVATION
  #LIPET - 08-08-2016 - X3PEOP-893 - END

   # Si des sections sont initialisées standard et d'autres conservation, il faut créer un enregistrement
   # dans VALANA, même si la dernière paye ne contient pas d'analytique (suppression des lignes du tableau)
   # Dans ce cas ECRIT reste à 0
   ECRIT = 0
   For [VAN1]VAN0 Where EMP=MATCUR & PYRDAT=DERPAY & BUL=DERBUL
    ECRIT = 1
    [F:VAN]COE = [F:VAN1]COE
    For J=1 To GOPTCANA
     [L]OPT = [L]WINICCE([L]J)
     If OPT=1 : # Conservation
     #JOJAC - 2016-08-10 - X3PEOP-894 - START
      #[F:VAN]CCE(J-1) = [F:VAN1]CCE(J-1)
     #JOJAC - 2016-08-10 - X3PEOP-894 - END
      #FQ92876-US2675- test si l'axe est bon par rapport au modèle comptables
#LIPET - 08-08-2016 - X3PEOP-893 - START
      Read [DIE]DIE0=[F:VAN1]DIE(J-1)
      If !fstat & find([F:VAN1]DIE(J-1),GDIE(1..GNBDIE))
         [F:VAN]CCE(J-1) = [F:VAN1]CCE(J-1)
      Endif
      #END FQ92876-US2675-
#LIPET - 08-08-2016 - X3PEOP-893 - END
     Endif
    Next
    Gosub WRITE_VAN
    If GOK=0 : Break : Endif
   Next
   If ECRIT=0
    Gosub WRITE_VAN
   Endif
  Else
   Gosub WRITE_VAN
  Endif
 Endif
Endif
If GOK=0 : End : Endif

GPOINT = "MAJVEP" : Gosub ENTREE From EXEFNC
If GOK<1 : End : Endif
If GPE=1: End: Endif

Write [VEP]
If fstat
 GOK = 0 : Call FSTA("VEP") From GLOCK : End
Endif

# Mise à jour des prestations
If [F:ID]FLGINT=2 & GINTMT=1
#LIPET - 08-08-2016 - X3PEOP-893 - START
# For [PSN]PSN0 Where CTRNUM=CONTRAT & BUL=""
  For [PSN]PSN0 Where CTRNUM=CONTRAT & BUL="" & CTRDAT=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
  If find([F:PSN]PSNNUM,PRESTAT)
   Readlock [PSN] Curr
   If fstat=1
    GOK = -1 : GLOCK = "$PRESTATION"-CONTRAT : Break
   Endif
   [F:PSN]BUL = BULLETIN
   Rewrite [PSN]
   If fstat
    GOK = 0 : Call FSTA("PSN") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : End : Endif
Endif

# Valeurs
If DERPAY=[0/0/0] & [F:ID]FLGINT=1
 # On recherche le salarié modèle de la table profil pour le salarié courant
 Call LECTURE("PRF",[F:HRCTR]PROPRF,GCURLEG) From CONTOBJ
 If [F:PRF]EMPMDL<>""
  # pour récupérer la dernière date de paye du modele
  Filter [VEP] Where EMP=[F:PRF]EMPMDL
  Read [VEP]VEP0 Last
  Filter[VEP]
  If fstat<=2
   DERPAY = [F:VEP]PYRDAT
   DERBUL = [F:VEP]BUL
   MATREF = [F:PRF]EMPMDL
  Else
   #Pas de paye pour le salarié modèle
   Call ECR_TRACE([F:ID]REFNUM-":"-mess(6,10703,1)-[F:PRF]EMPMDL,0) From GESECRAN
  Endif
 Else
  #Pas de salarié modèle associé à ce profil
  Call ECR_TRACE([F:ID]REFNUM-":"-mess(5,10703,1)-[F:HRCTR]PROPRF,1) From GESECRAN
 Endif
Endif

# Init des variables pour les intermittents
If [F:ID]FLGINT=2
 NBPREST = 0
 While PRESTAT(NBPREST+1)<>0
  NBPREST += 1
 Wend
 Call INIVAR(CONTRAT,NBPREST,PRESTAT,NBVAR,TBVAR,VALEUR) From INIVAR
Endif

##Chargement des VPR
Raz TRTAUTVPRCOD
Raz TRTAUTVPRVAL
Raz TRTAUTNBVPR
##**82073
#LIPET - 08-08-2016 - X3PEOP-893 - START
#For [VPR]VPR1 Where EMP=MATCUR & CTRNUM=CONTRAT & CTRDAT=DATCTR & DAT>=DATDEB & DAT<=DATFIN
# TRTAUTNBVPR+=1
# TRTAUTVPRCOD(TRTAUTNBVPR)=[F:VPR]VARCOD
# TRTAUTVPRVAL(TRTAUTNBVPR)=[F:VPR]VARVAL
[L]DECALE=(val(func AFNC.PARAM('DMA',[F:HRCTR]ETRFCY))<>12)

For [VPR]VPR1 Where EMP=MATCUR & CTRNUM=CONTRAT & CTRDAT>=MINDATCTR & CTRDAT<=DATCTR & DAT>=addmonth(DATDEB,DECALE) & DAT<=eomonth(addmonth(DATFIN,DECALE))
 ITRT= find([F:VPR]VARCOD,TRTAUTVPRCOD(1..1000))
 If !ITRT
  TRTAUTNBVPR+=1
  TRTAUTVPRCOD(TRTAUTNBVPR)=[F:VPR]VARCOD
  TRTAUTVPRVAL(TRTAUTNBVPR)=[F:VPR]VARVAL
 Else
  TRTAUTVPRVAL(ITRT)+=[F:VPR]VARVAL
 Endif
#LIPET - 08-08-2016 - X3PEOP-893 - END
Next

##Chargement des PCB
Raz TRTAUTPCBCOD
Raz TRTAUTNBPCB
##**82073
#JOJAC - 2016-08-10 - X3PEOP-894 - START
#For [HRPCB]PCB0 Where IDENT1=MATCUR & IDENT2>=format$("D:4Y2M2D",DATDEB) & IDENT2<=format$("D:4Y2M2D",DATFIN)
#&&                  IDENT3=CONTRAT & IDENT4=DATCTR
For [HRPCB]PCB0 Where IDENT1=MATCUR & IDENT2>=format$("D:4Y2M2D",DATDEB) & IDENT2<=format$("D:4Y2M2D",DATPAY)
&&                  IDENT3=CONTRAT & IDENT4>=MINDATCTR & IDENT4<=DATCTR
#JOJAC - 2016-08-10 - X3PEOP-894 - END
 TRTAUTNBPCB+=1
 TRTAUTPCBCOD(TRTAUTNBPCB)=[F:HRPCB]CODBLB
 TRTAUTPCBID2(TRTAUTNBPCB)=[F:HRPCB]IDENT2
Next

##Chargement des CVR
If TRTAUTPRF<>[F:VEP]PRF
 TRTAUTPRF=[F:VEP]PRF
 Raz TRTAUTCOD,TRTAUTNBCOD
 For [CVR]CVR1 Where PRFCOD=[F:VEP]PRF & ENAFLG=2 & LEG=GCURLEG
  TRTAUTNBCOD+=1
  TRTAUTCOD(TRTAUTNBCOD)=[F:CVR]COD
 Next
Endif

GPOINT="MAJTABVRA": Gosub ENTREE From EXEFNC

For I=1 To TRTAUTNBCOD
 Read[F:VRA]VRA0=GCURLEG;TRTAUTCOD(I)
 If !fstat
  OKVAR = 1
  If [F:VRA]CODACT<>""
   Read [ACV]CODACT = [F:VRA]CODACT
   If fstat or [F:ACV]FLACT<>2
    OKVAR = 0
   Endif
  Endif
  If OKVAR
   If [F:ADI]CODE<>[F:VRA]PAGEMP
    Read [ADI]CODE = 10337;[F:VRA]PAGEMP
   Endif
   ARRONDI = 10^(-[F:ADI]N1)
   OK = 0 : NEWVAL = 0
   ## On charge les valeurs prévisionnelles
   For K=1 To TRTAUTNBVPR
    If [F:VRA]COD=TRTAUTVPRCOD(K)
     OK = 1
     NEWVAL += TRTAUTVPRVAL(K)
    Endif
   Next K
   ## On charge les textes prévisionnels
   For K=1 To TRTAUTNBPCB
    If [F:VRA]COD=TRTAUTPCBCOD(K)
     ##**82073
#LIPET - 08-08-2016 - X3PEOP-893 - START
     For  [PCB]PCB0 Where CODBLB=[F:VRA]COD & IDENT1=MATCUR & IDENT2=TRTAUTPCBID2(K) & IDENT3=CONTRAT & IDENT4>=MINDATCTR & IDENT4<=DATCTR
#LIPET - 08-08-2016 - X3PEOP-893 - END
     Read [HRPCB]PCB0=[F:VRA]COD;MATCUR;TRTAUTPCBID2(K);CONTRAT;DATCTR
#MIPEA - 2017-02-16- X3-11258- START
     Filter [RUB] Where (TEXVRI(0)=[F:VRA]COD or TEXVRI(1)=[F:VRA]COD) & LEG = GCURLEG
#     Filter [RUB] Where TEXVRI(0)=[F:VRA]COD or TEXVRI(1)=[F:VRA]COD
#MIPEA - 2017-02-16- X3-11258- END
     For [RUB]RUB0
#LIPET - 08-08-2016 - X3PEOP-893 - START
       # Additional comments...
       Readlock [BCB]BCB0="VARTXT";[F:VRA]COD;BULLETIN;"";[F:RUB]COD
       If !fstat
        [F:BCB]CLOB = func ACB.PLUS_([F:BCB]CLOB,space$(1),[F:PCB]CLOB)
        Rewrite [BCB]
        If fstat
         GOK = 0 : Call FSTA("BCB") From GLOCK : Break 3
        Endif
       Elsif fstat>1
       #
#LIPET - 08-08-2016 - X3PEOP-893 - END
      Raz [F:BCB]
      [F:BCB]CODBLB = "VARTXT"
      [F:BCB]IDENT1 = [F:VRA]COD
      [F:BCB]IDENT2 = BULLETIN
      [F:BCB]IDENT3 = ""
      [F:BCB]IDENT4 = [F:RUB]COD
      [F:BCB]CLOB   = [F:HRPCB]CLOB
      If dim([F:BCB]CREUSR)>0 : [F:BCB]CREUSR = GUSER : Endif
      If dim([F:BCB]CREDAT)>0 : [F:BCB]CREDAT = date$ : Endif
      If dim([F:BCB]CRETIM)>0 : [F:BCB]CRETIM = time  : Endif
       Write [BCB]
      If fstat
       GOK = 0 : Call FSTA("BCB") From GLOCK : Break 3
      Endif
     Endif
    Next
   Next
  Endif
  Next
  If !OK
##  Traitement des exceptions
    INITYP = [F:VRA]TYPINI
    STDVAL = [F:VRA]VALSTD
    For [ECV]ECV1 Where LEG=GCURLEG and VRA=[F:VRA]COD
     Read [ECH]ECH0 = GCURLEG;[F:ECV]COD
     Gosub TESTEMP
     If OK
      INITYP = [F:ECV]TYPINI
      STDVAL = [F:ECV]VALSTD
     Endif
    Next
    Case INITYP
     When 1 : # Conservation
      Read [VLA1]VLA0 = 4;"";"";"";MATREF;DERPAY;[F:VRA]COD;DERBUL
      If !fstat
       NEWVAL = [F:VLA1]VARVAL
       OK = 1
      Endif
     When 3 : # Valeur standard
      NEWVAL = STDVAL
      OK = 1
     When 5 : # Reprise
      If REPRISE
       NEWVAL = STDVAL
       OK = 1
      Endif
    Endcase
    If !OK & [F:VRA]GNRFRC=2 : # Génération forcée, on prend la valeur standard
     NEWVAL = STDVAL
     OK= 1
    Endif
   Endif
   If DERPAY=[0/0/0]
    Read [VLA]VLA0 = 4;"";"";"";MATCUR;DATPAY;[F:VRA]COD;BULLETIN
    If fstat=0 : OK=0 : Endif
   Endif
   If [F:ID]FLGINT=2
    K = find([F:VRA]COD,TBVAR(1..NBVAR))
    If K
     OK = 1
     NEWVAL = VALEUR(K)
    Endif
   Endif
   If OK
    NEWVAL = arr(NEWVAL,ARRONDI)
    Raz [F:VLA]
    [F:VLA]BUL    = BULLETIN
    [F:VLA]EMP    = MATCUR
    [F:VLA]DAT    = DATPAY
    [F:VLA]VARCOD = [F:VRA]COD
    [F:VLA]TYP    = 4
    [F:VLA]VARVAL = NEWVAL
    GPOINT = "MAJVLA" : Gosub ENTREE From EXEFNC
    If GOK<1 : Break : Endif
    If not([V]GPE)
      Write [VLA]
      If fstat
       GOK = 0 : Call FSTA("VLA") From GLOCK : Break
      Endif
     Endif
   Endif
  Endif
 Endif
Next

#MIPEA - 2017-02-16- X3-11258- START
# Issue 113512 - 2016-11-09 by BRBAN : X3PEOP-3623
Read[F:HRCTR]CTR0=MATRI;CTR;DATCTR
If !fstat
  [L]VARHRS   = func AFNC.PARAM("VARHRS",[F:HRCTR]ETRFCY)
  [L]VARMTH   = func AFNC.PARAM("VARMTH",[F:HRCTR]ETRFCY)
  [L]VARZON1  = func AFNC.PARAM("VARZON1",[F:HRCTR]ETRFCY)
  [L]VARZON2  = func AFNC.PARAM("VARZON2",[F:HRCTR]ETRFCY)
  If [L]VARHRS<>''  & [F:HRCTR]HRS<>0 : Call CREVLA(MATRI,DATPAY,[L]VARHRS,BULLETIN,[F:HRCTR]HRS)   : Endif
  If [L]VARMTH<>''  & [F:HRCTR]MTH<>0 : Call CREVLA(MATRI,DATPAY,[L]VARMTH,BULLETIN,[F:HRCTR]MTH)   : Endif
  If [L]VARZON1<>'' & [F:HRCTR]ZON1<> 0 : Call CREVLA(MATRI,DATPAY,[L]VARZON1,BULLETIN,[F:HRCTR]ZON1) : Endif
  If [L]VARZON2<>'' & [F:HRCTR]ZON2<> 0 : Call CREVLA(MATRI,DATPAY,[L]VARZON2,BULLETIN,[F:HRCTR]ZON2) : Endif
Endif
# -
#MIPEA - 2017-02-16- X3-11258- END
End

$WRITE_VAN
GPOINT = "MAJVAN" : Gosub ENTREE From EXEFNC
If GOK<1 : Return : Endif
If [V]GPE=1: Return: Endif

If sum([F:VAN]CCE(0..GOPTCANA-1))<>""
 K += 1
 [F:VAN]LIG = K
 [F:VAN]BUL = BULLETIN
 Write [VAN]
 If fstat
  GOK = 0 : Call FSTA("VAN") From GLOCK
 Endif
Endif
Return

$TESTEMP
OK = 1
If [F:ECV]DATSTR<>[0/0/0] & DATPAY<[F:ECV]DATSTR  : OK = 0 : Return : Endif
If [F:ECV]DATEND<>[0/0/0] & DATPAY>[F:ECV]DATEND  : OK = 0 : Return : Endif
If [F:ECH]FCY<>"" & [F:HRCTR]ETRFCY <>[F:ECH]FCY    : OK = 0 : Return : Endif
If [F:ECH]PRF<>"" & [F:HRCTR]PROPRF<>[F:ECH]PRF     : OK = 0 : Return : Endif
If [F:ECH]SRV<>"" & [F:HRCTR]ETRSRV<>[F:ECH]SRV     : OK = 0 : Return : Endif
If [F:ECH]EMPSTR<>"" & [F:ID]REFNUM<[F:ECH]EMPSTR : OK = 0 : Return : Endif
If [F:ECH]EMPEND<>"" & [F:ID]REFNUM>[F:ECH]EMPEND : OK = 0 : Return : Endif
If [F:ECH]CRI<>"" & !evalue([F:ECH]CRI)           : OK = 0 : Return : Endif

If dim([F:ECH]CTRCRI) > 0 & [F:ECH]CTRCRI(0) <> ""
    If !find([F:HRCTR]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+format$("D:YYYYMMDD",[F:HRCTR]CTRDAT), [F:ECH]CTRCRI) : [L]OK = 0 : Return : Endif
Endif

If [F:ECH]POP<>""
 #86255
 Read [HRPOA]POA0 = [F:ECH]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
 If fstat : OK = 0 : Return : Endif
Endif
Return

$GETRPTBUL
If [F:HRCTR]RPTBUL>""
 [F:VEP]RPTBUL = [F:HRCTR]RPTBUL
Else
 Call PARAML(GCURLEG,"NOMRPTBUL",[F:VEP]RPTBUL) From ADOVAL :#81084
Endif
Return
#LIPET - 08-08-2016 - X3PEOP-893 - START
