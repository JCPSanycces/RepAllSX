######################################################################################
# Issue 113512 - 2016-11-24 by BRBAN : X3PEOP-3600
Subprog CREVLA(REFNUM,DATPAY,VARVLA,BULLETIN,WVAL)
Value    Char    REFNUM(),VARVLA(),BULLETIN()
Value    Date    DATPAY
Value    Decimal WVAL

  Read [VLA]VLA0 = 4;GCURLEG;"";""; REFNUM;DATPAY;VARVLA;BULLETIN
  If !fstat
    [F:VLA]VARVAL = WVAL
    Rewrite [F:VLA]
  Else
    [F:VLA]BUL    = BULLETIN
    [F:VLA]EMP    = REFNUM
    [F:VLA]DAT    = DATPAY
    [F:VLA]VARCOD = VARVLA
    [F:VLA]TYP    = 4
    [F:VLA]VARVAL = WVAL
    Write [F:VLA]
  Endif
End
#MIPEA - 2017-02-16- X3-11258- END
#MIPEA - 2017-02-16- X3-11258- START
$ERREUR
  Call ECR_TRACE(mess(85,115,1)-APPLI -mess(6,123,1)-num$(errn)-errmes$(errn)-APPLI+".VALEMP",1) From GESECRAN
Resume
#MIPEA - 2017-02-16- X3-11258- END
FCREPAY

