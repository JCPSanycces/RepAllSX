& Order By evalue("PERCOD") Using
& [HRPEO]PERCOD Titled "Code",
& [HRPEO]PERMON1 Titled "Period in month",
& [HRPEO]PERSTR(1) Titled "Start of period",
& [HRPEO]PEREND(1) Titled "End of period"
& Sized (50,150)
& Titled "Period code selection"

VALEUR = [F]COD
