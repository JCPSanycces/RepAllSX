#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Delete VISULIC function
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Delete VISULIC function") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Gosub DELVISULIC
End

#----------------------------------------------#
$DELVISULIC

Call ECR_TRACE("UTISUP005 : Process Start on : "+APPLI,0) From GESECRAN

If !clalev([F:AFC2]) Local File =APPLI+".AFONCTION" [AFC2] : Endif
If !clalev([F:AOB2]) Local File =APPLI+".AOBJET"    [AOB2] : Endif
If !clalev([F:AWI2]) Local File =APPLI+".AWINDOW"   [AWI2] : Endif
If !clalev([F:ACT2]) Local File =APPLI+".ACTION"    [ACT2] : Endif
If !clalev([F:AMK2]) Local File =APPLI+".AMSK"      [AMK2] : Endif
If !clalev([F:AMZ2]) Local File =APPLI+".AMSKZON"   [AMZ2] : Endif
If !clalev([F:ATZ2]) Local File =APPLI+".ATABZON"   [ATZ2] : Endif
If !clalev([F:ATI2]) Local File =APPLI+".ATABIND"   [ATI2] : Endif
If !clalev([F:ATB2]) Local File =APPLI+".ATABLE"    [ATB2] : Endif
If !clalev([F:ADW2]) Local File =APPLI+".ADOVAL"    [ADW2] : Endif
If !clalev([F:AMA2]) Local File =APPLI+".AMSKACT"    [AMA2] : Endif
If !clalev([F:AMP2]) Local File =APPLI+".AMSKPAR"    [AMP2] : Endif


Trbegin [AFC2],[AOB2],[AWI2],[AMK2],[AMZ2],[ACT2],[ATB2],[ATI2],[ATZ2]
    Delete [AFC2] Where CODINT="VISULIC"

    Delete [AWI2] Where WIN="VISULIC"

    Delete [AMA2] Where TYPAFF=1 & CODAFF="VISULIC"
    Delete [AMP2] Where TYPAFF=1 & CODAFF="VISULIC"
    Delete [AMZ2] Where CODMSK = "VISULIC"
    Delete [AMK2] Where CODMSK="VISULIC"

    Delete [ACT2] Where ACTION="VISULIC"
Commit


Call ECR_TRACE("UTISUP005 : Process End on : "+APPLI,0) From GESECRAN

Return
