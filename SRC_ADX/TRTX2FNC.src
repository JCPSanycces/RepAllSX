#############################################################################
# TRTX2FNC           Traitement des fonctions X3 STD    Requêteur graphique #
# ------------------------------------------------------------------------- #
# EXISTS_ITF: Contrôle la présence d'un article-site pour un article donné  #
# EXISTS_ITC: Contrôle la présence d'un article-cout pour un article donné  #
# EXISTS_ITP: Contrôle la présence d'un fournisseur  pour un article donné  #
# EXISTS_CRY_CEE : Contrôle si le pays est de UE                            #
# EXISTS_CRY_BPA_CEE : Contrôle si le pays d'un adresse Tiers est de UE     #
# GET_CRY_BPA : Retourne le pays d'un adresse Tiers                         #
# EXISTS_F_ORI_AND_DES : Contrôle s'il existe un flux  si le pays d’origine et de destination sont des pays différents de l’UE
# EXISTS_F_ORI_OR_DES : Contrôle s'il existe un flux  si le pays d’origine ou de destination sont des pays différents de l’UE
# EXISTS_EECSH_EECNAF : Contrôle s'il existe un flux  si au moins un code régime ou un code nature est renseigné sur le flux
# EXISTS_FLUX : Contrôle s'il existe un flux avec en paramètre le pays d'origine, le pays de destination, le code tiers, et le code adresse                                #
# OSTCTLRSK Retourne le controle d'en-cours du client à risque              #
# OSTAUZRSK Retourne l'en-cours autorisé du client à risque                 #
#############################################################################

$TEST_GA
Infbox "Résultat de EXISTS_ITP"-num$(func EXISTS_ITP("XYZ-GA"))-num$(func EXISTS_ITP("CD100"))
End

#########################
Funprog EXISTS_ITC (LITM)
Value Char LITM
Local Shortint IOK : IOK=1
Local Char  TEXTE
  If clalev ([F:ITC])=0  Local File ITMCOST [ITC] : Endif
  # Read [ITF]ITF0(1)=LITM Bug 51887 SEGAY le 22/01/09
  Filter [ITC] Where ITMREF = LITM
  Read [ITC]ITC0 First
  If fstat
     IOK= 0
  Endif
  Filter [ITC]
End IOK

#########################
Funprog EXISTS_ITF (LITM)
Value Char LITM
Local Shortint IOK : IOK=1
  If clalev ([F:ITF])=0  Local File ITMFACILIT [ITF] : Endif
  Read [ITF]ITF0(1)=LITM
  If fstat
     IOK= 0
  Endif
End IOK

#########################
Funprog EXISTS_ITP (LITM)
Value Char LITM
Local Shortint IOK : IOK=1
  If clalev ([F:ITP])=0  Local File ITMBPS [ITP] : Endif
  Read [ITP]ITP0(1)=LITM
  If fstat
     IOK= 0
  Endif
End IOK



###############################################################
# Retourne Oui si le pays est de UE
###############################################################
Funprog EXISTS_CRY_CEE (WCRYCOD)
Value Char WCRYCOD
Local Shortint IOK : IOK=0
  If clalev([F:TCY])=0 : Local File TABCOUNTRY   [TCY] : Endif
  Read [TCY]TCY0 = WCRYCOD
  If !fstat Then
    If [TCY]EECFLG = 2 : IOK=1 : Endif
  Endif
End IOK

###############################################################
# Retourne Oui si le pays d'un adresse Tiers est de UE
###############################################################
Funprog EXISTS_CRY_BPA_CEE (WNUM,WADD)
Value Char WNUM
Value Char WADD
Local Shortint IOK : IOK=0
  If clalev([F:BPA])=0 Local File BPADDRESS   [BPA] : Endif
  Read [BPA]BPA0=1;WNUM;WADD
  If !fstat Then
    If func TRTX2FNC.EXISTS_CRY_CEE([F:BPA]CRY) : IOK=1 : Endif
  Endif
End IOK

###############################################################
# Retourne le pays d'un adresse Tiers
###############################################################
Funprog GET_CRY_BPA (WNUM,WADD)
Value Char WNUM
Value Char WADD
Local Char WCRYCOD(GLONCRY): WGRYCOD =""
  If clalev([F:BPA])=0 Local File BPADDRESS   [BPA] : Endif
  Read [BPA]BPA0=1;WNUM;WADD
  If !fstat and dim([F:BPA]CRY)>0 & [F:BPA]CRY<>"" Then
       WCRYCOD=[F:BPA]CRY
  Endif
End WCRYCOD

###############################################################
# Retourne Oui s'il existe un flux  si le pays d’origine et de destination sont des pays différents de l’UE
###############################################################
Funprog EXISTS_F_ORI_AND_DES (WCRYORI,WCRYDES)
Value Char WCRYORI
Value Char WCRYDES
Local Shortint IOK : IOK=0

  # FGR 05/08/2013 : X3SUIVI91635
  #If !func TRTX2FNC.EXISTS_CRY_CEE(WCRYORI) and !func TRTX2FNC.EXISTS_CRY_CEE(WCRYDES) Then
  If func TRTX2FNC.EXISTS_CRY_CEE(WCRYORI) and func TRTX2FNC.EXISTS_CRY_CEE(WCRYDES) Then
    IOK=1
  Endif
End IOK

###############################################################
# Retourne Oui s'il existe un flux  si le pays destination ou le pays d’origine hors UE et l'adresse transitaire pays de l’UE différent du pays UE destination ou origine
###############################################################
Funprog EXISTS_F_ORI_OR_DES (WCRYORI,WCRYDES,WNUM,WADD)
Value Char WCRYORI
Value Char WCRYDES
Value Char WNUM
Value Char WADD
Local Shortint IOK : IOK=0
  If  (!func TRTX2FNC.EXISTS_CRY_CEE(WCRYORI) and func TRTX2FNC.EXISTS_CRY_BPA_CEE (WNUM,WADD))
&       or (!func TRTX2FNC.EXISTS_CRY_CEE(WCRYDES) and func TRTX2FNC.EXISTS_CRY_BPA_CEE (WNUM,WADD)) Then
      IOK=1
  Endif
End IOK

###############################################################
# Retourne Oui s'il existe un flux  si au moins un code régime ou un code nature est renseigné sur le flux
###############################################################
Funprog EXISTS_EECSH_EECNAF (WEECSH,WEECNAT)
Value Char WEECSH
Value Char WEECNAT

Local Shortint IOK : IOK=0
Local Integer IRET   # FGR 14/01/2013 : X3SUIVI71937

  #If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif
  #Read [ADI]CODE = 15;WEECSH
  #If !fstat Then
  #  IOK= 1
  #Endif
  # FGR 14/01/2013 : X3SUIVI71937 (début)
  #Read [ADI]CODE = 6;WEECNAT
  #If !fstat Then
  #  IOK= 1
  #Endif

  If !clalev([F:TEC]) : Local File TABEECNAT [TEC] : Endif
  If !clalev([F:TSC]) : Local File TABEECSCH [TSC] : Endif
  Call LEC_TSC_LEG(GCURLEG, WEECSH, IRET) From TRTLECLEG
  If !IRET Then
    IOK= 1
  Endif
  Call LEC_TEC_LEG(GCURLEG, WEECNAT, IRET) From TRTLECLEG
  If !IRET Then
    IOK= 1
  Endif
  # FGR 14/01/2013 : X3SUIVI71937 (fin)
End IOK

###############################################################
# Retourne Oui s'il existe un flux et que les 2 pays sont différents
# avec en paramètre le pays d'origine, le pays de destination, le code tiers, et le code adresse
###############################################################
Funprog EXISTS_FLUX(WCRYORI,WCRYDES,WNUM,WADD)
Value Char WCRYORI
Value Char WCRYDES
Value Char WNUM
Value Char WADD
Local Shortint IOK : IOK=0
  If WCRYORI <> WCRYDES Then
    If (func TRTX2FNC.EXISTS_F_ORI_AND_DES (WCRYORI,WCRYDES) or func EXISTS_F_ORI_OR_DES (WCRYORI,WCRYDES,WNUM,WADD))
        IOK=1
    Endif
  Endif
End IOK

#**
#* Retourne le controle d'en-cours du client à risque
#* SEGAY
#* @since 05/03/10
#*!
Funprog OSTCTLRSK (WBPCRSK)
Value Char WBPCRSK
Local Integer WOSTCTL : WOSTCTL = 0
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0 = WBPCRSK
  If !fstat Then
    WOSTCTL = [F:BPC]OSTCTL
  Endif
End WOSTCTL
#**
#* Retourne l'en-cours autorisé du client à risque
#* SEGAY
#* @since 05/03/10
#*!
Funprog OSTAUZRSK (WBPCRSK)
Value Char WBPCRSK
Local Decimal WOSTAUZ : WOSTAUZ = 0
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  Read [F:BPC]BPC0 = WBPCRSK
  If !fstat Then
    WOSTAUZ = [F:BPC]OSTAUZ
  Endif
End WOSTAUZ
