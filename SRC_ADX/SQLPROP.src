#<AdxTL>@(#)11.0.0.0 $Revision$
Close Local Mask
Call SQLPROP(nomap)
End

########################################################################
Subprog SQLPROP(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"SQLPROP","SQLPROP","") From GSAISIE
End

######################################################################################
# Gestion des masques SQLPROP0,SQLPROP2,SQLPROP3,SQLPROP4
####################
$ACTION
#Infbox GACTION-"ACTION="+ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "RAF"          : Gosub RAF
 When "FIN"          : Gosub FIN
 When "EDI"          : Gosub EDIT
 When Default
Endcase
Return


####################
$EDIT
Local Char WLIBEL(250) : Raz WLIBEL
Local Integer WNOLIBEL : Raz WNOLIBEL
Local Integer OUVREAFC,OUVREATX
If clalev([F:AFCW])=0 : Local File AFONCTION [AFCW] : OUVREAFC=1 : Endif
If clalev([F:ATXW])=0 : Local File ATEXTE    [ATXW] : OUVREATX=1 : Endif
      WNOLIBEL= 0
      Read [F:AFCW]CODINT = "TRTPROP"
      If [S]fstat = 0
        WNOLIBEL = [F:AFCW]LIBMENU
        Read [F:ATXW]NUMERO=GLANGUE;WNOLIBEL
        If [S]fstat = 0
           WLIBEL= [F:ATXW]TEXTE
        Endif
      Endif
      If WLIBEL="" : WLIBEL="TRTPROP" : Endif
If OUVREAFC : Close File [AFCW] :  Endif
If OUVREATX : Close File [ATXW] :  Endif

Local Char TABMSK(GLONATB)(3)
Local Char TABABR(GLONABR)(3)
#on les mets dans ce sens pour avoir les info regroupées
TABMSK(0)="SQLPROP0" : TABABR(0)="PRO0"
TABMSK(1)="SQLPROP1" : TABABR(1)="PRO1"
TABMSK(2)="SQLPROP2" : TABABR(2)="PRO2"
Call PRTSCR(TABMSK,TABABR,WLIBEL,0,0) From ATRTX3
Call IMPSCR From ATRTX3
Return

####################
$OUVRE
If GTYPDBA<>2
    FIN=1
    Return
Endif
Return

####################
$DEBUT
If GTYPDBA<>2
    Call ERREUR(mess(185,115,1)) From GESECRAN : # La base de données n'est pas SQLSERVER
    FIN=1
    Return
Endif

Raz [M:PRO0]
Raz [M:PRO1]
Raz [M:PRO2]
Call VERS_SQL([M:PRO0]BDDNAM,[M:PRO0]VER,[M:PRO0]VERDES,FIN)
If FIN : Return : Endif
Gosub ACTUALISER
Return

####################
$FIN
Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"A") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A"
CHBOU += "=" : # Raffraîchir
CHBOU += "I" : # Impression

Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
Call TEMPON("L") From GESECRAN
Call CHARGE_PRO1(FIN)
Call CHARGE_PRO2(FIN)
Affzo [M:PRO1]
Affzo [M:PRO2]
Call TEMPOFF From GESECRAN
Return


###################################################################################################
###################################################################################################
Subprog CHARGE_PRO1(ERR)
Variable Integer ERR

Local Char SQLREQ (250)

Raz [M:PRO1]
Onerrgo ERR_SQL

Raz SQLREQ
SQLREQ(0) = "select "
SQLREQ(0) += "CAST(SERVERPROPERTY('MachineName') AS varchar(50)),"
SQLREQ(0) += "CAST(SERVERPROPERTY('InstanceName') AS varchar(50)),"
SQLREQ(0) += "CAST(SERVERPROPERTY('Collation') AS varchar(50)),"
SQLREQ(0) += "cast(replace(@@VERSION,char(10),char(13)+char(10)) as varchar(250))"

For (Char VSRVMAC(50),Char VSRVINS(50),Char VSRVTRI(50),
&    Char VERSION(250)) From '5' Sql SQLREQ As [BXX]
    [M:PRO1]SRVMAC=[BXX]VSRVMAC
    [M:PRO1]SRVINS=[BXX]VSRVINS
    [M:PRO1]SRVTRI=[BXX]VSRVTRI
    #Setlob [M:PRO1]VER With [BXX]VERSION
    [M:PRO1]VER = [BXX]VERSION


    Break
Next


Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



###################################################################################################
###################################################################################################
Subprog VERS_SQL(BDDNAM,VER,VERDES,ERR)
Variable Char BDDNAM
Variable Char VER
Variable Char VERDES
Variable Integer ERR

Onerrgo ERR_SQL_VERS

For (Char VBDDNAM(200),Char VERSION(200),Char VERDES(200)) From '5' Sql
&   "Select db_name(),cast(SERVERPROPERTY('ProductVersion') as varchar(200)),substring(@@VERSION,1,charindex(char(10),@@VERSION)-1)"
&   As [VER]
    BDDNAM = [VER]VBDDNAM
    VER = [VER]VERSION
    VERDES = [VER]VERDES
    Break
Next
Onerrgo
End

###################################################################################################
Subprog NOVERS_SQL(VERSION_SQL,ERR)
Variable Char VERSION_SQL
Variable Integer ERR

Onerrgo ERR_SQL_VERS

For (Char VERSION(200)) From '5' Sql
&        "select cast(serverproperty('ProductVersion') as varchar(200))"
&        As [VER]
 Call CALC_NOVERS_SQL([VER]VERSION,VERSION_SQL)
 Break
Next
Onerrgo
End

###################################################################################################
Subprog CALC_NOVERS_SQL(VERSION,VERSION_SQL)
Value Char VERSION
Variable Char VERSION_SQL
Variable Integer ERR

#SQL Server 2014      12.x
#SQL Server 2012      11.x
#SQL Server 2008      10.x
#SQL Server 2005      9.x
#SQL Server 2000      8.x

# If (left$(VERSION,1)="8")
#  VERSION_SQL = "8" :#Sql Server 2000
# Else
#  VERSION_SQL = "9" :#Sql Server 2005
# Endif
If left$(VERSION,2)="8." | left$(VERSION,2)="9."
 VERSION_SQL = left$(VERSION,1)
Else
 VERSION_SQL = left$(VERSION,2)
Endif
End


###################################################################################################
###################################################################################################
$ERR_SQL_VERS
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


######################################################################################
######################################################################################
Subprog CHARGE_PRO2(ERR)
Variable Integer ERR

Local Char SQLREQ (250) (3)

#############################################################
## Pour SQL-server
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    RESTE(250), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Decimal NOMBRE(1..10)
Local Char UNITE(5)(1..10)
Local Integer OK
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

Raz [M:PRO2]


Raz SQLREQ
SQLREQ(0) = "select "
SQLREQ(0) += "CONVERT(varchar,crdate,120),SUSER_SNAME(sid),"
SQLREQ(1) = "CAST(DATABASEPROPERTYEX(name,'Collation') AS varchar(50)),"
SQLREQ(1) += "CAST(DATABASEPROPERTYEX(name,'Recovery') AS varchar(50)),"
SQLREQ(1) += "(select count(*) from master.dbo.sysprocesses p where db_id(name)=p.dbid),"
SQLREQ(2) ="cmptlevel From master.dbo.sysdatabases where name='"+[M:PRO0]BDDNAM+"'"

For (Char VCREDAT(50),Char VPROPRIO(50),Char VBDDTRI(50),
&    Char VRPCTPL(50),Integer VNBRPRO,
&    Integer VLEVEL) From '5' Sql SQLREQ As [BXX]

    [M:PRO2]OWN=[BXX]VPROPRIO
    [M:PRO2]CREDAT=format$("DZ<:YYYYMMDD",left$([BXX]VCREDAT,10))
    [M:PRO2]CREHOU=mid$([BXX]VCREDAT,12,8)

    [M:PRO2]NBRPRO=[BXX]VNBRPRO

    [M:PRO2]BDDTRI=[BXX]VBDDTRI
    [M:PRO2]RPCTPL=[BXX]VRPCTPL

    [M:PRO2]LEV="SQL Server"
    If [BXX]VLEVEL = 70
        [M:PRO2]LEV-="7.0"
    Elsif [BXX]VLEVEL = 80
        [M:PRO2]LEV-="2000"
    Else
        [M:PRO2]LEV-="2005"
    Endif
    [M:PRO2]LEV-="("+num$([BXX]VLEVEL)+")"
    Break
Next

Raz SQLREQ
SQLREQ(0) = "select type,CONVERT(varchar,max(backup_finish_date),120) "
SQLREQ(1) = "from msdb..backupset where database_name = db_name() group by type"

For (Char VTYPE(50),Char VSAVDAT(50)) From '5' Sql SQLREQ As [BXX]
    If [BXX]VTYPE = "D"
        [M:PRO2]SAVBDDDAT=format$("DZ<:YYYYMMDD",left$([BXX]VSAVDAT,10))
        [M:PRO2]SAVBDDHOU=mid$([BXX]VSAVDAT,12,8)
    Elsif [BXX]VTYPE = "L"
        [M:PRO2]SAVLOGDAT=format$("DZ<:YYYYMMDD",left$([BXX]VSAVDAT,10))
        [M:PRO2]SAVLOGHOU=mid$([BXX]VSAVDAT,12,8)
    Elsif [BXX]VTYPE = "I"
        [M:PRO2]SAVDBDDDAT=format$("DZ<:YYYYMMDD",left$([BXX]VSAVDAT,10))
        [M:PRO2]SAVDBDDHOU=mid$([BXX]VSAVDAT,12,8)
    Endif
Next

Raz SQLREQ
Local Char WVERSSQL(30)
Call NOVERS_SQL(WVERSSQL,ERR)
If ERR<>0 : End : Endif
If WVERSSQL="8"
SQLREQ(0) = "select count(*) from dbo.sysusers o "
SQLREQ(0) += "left join (select sid, loginname, 1 as matched from master.dbo.syslogins) l on l.sid = o.sid "
SQLREQ(1) = "where ((o.issqlrole != 1 and o.isapprole != 1 and o.status != 0 and matched is not null) "
SQLREQ(1) += "or (o.sid = 0x00) and o.hasdbaccess = 1) and o.isaliased != 1"
Else
SQLREQ(0) = "select count(*) FROM sys.database_principals AS u "
SQLREQ(1) = "WHERE (u.type in ('U', 'S', 'G', 'C', 'K'))"
Endif

For (Integer VNBRUSR) From '5' Sql SQLREQ As [BXX]
    [M:PRO2]NBRUSR=[BXX]VNBRUSR
Next



nolign=0
APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)

# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    SQLDBA = "sqlcmd"
    # instance ?
    Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
    If OK<>0
        ERR=1
        End
    Endif
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
    SQLDBA = "osql"
Endif
#
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII

Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""

 FICCMD = filpath("tmp","sqlprop"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqlprop"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqlprop"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 ##
 ## On ecrit le fichier de commande pour le déclenchement
 ## car bug sur probleme de PATH
 ##WORDRE = SQLDBA-"-D"-BASE-"-U"-USER-"-P"-PASSE-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"
 ##
 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049 replace osql by sqlcmd

 # jira X3-86047 86048 86049 replace osql by sqlcmd
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    Wrseq "SET SQLCMD_EXE="+SQLDBA
    WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
    Wrseq WORDRE
    WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
    Wrseq WORDRE
 Else
    Wrseq "SET OSQL_EXE="+SQLDBA
    WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
    Wrseq WORDRE
    WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
    Wrseq WORDRE
 Endif

 Wrseq "BREAK ON"
 Openo

 If WVERSSQL="8"
  Gosub OLD_OPT
 Else
  Gosub NEW_OPT
 Endif

 Openo FICSQL,0
 #JPGA 28/01/2010 BUG-58485 : A partir de Sqlserver2005 : Positionner la base part défaut, sinon les tables sont pris depuis Master
 Wrseq "USE"-XBASE
 Wrseq "exec sp_spaceused"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  L = 0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   # with sqlcmd one line more in log with contexte .
   # need to jump this line
   If pat(LIGNE,"*Changed database context*") > 0
       # on saute ligne
   Else
       If len(LIGNE)>0
          If L=0
              J = instr(1,LIGNE," ")
              If J
                  LIGNE = vireblc(right$(LIGNE,J+1),2)
                  Gosub NOMBRE
                  [M:PRO2]TAILBASE = NOMBRE(1) : [M:PRO2]MB1 = UNITE(1)
                  [M:PRO2]ESPACE   = NOMBRE(2) : [M:PRO2]MB2 = UNITE(2)
                  Break
              Endif
              L = 1
          Endif
        Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

$NOMBRE
K = 0
Raz NOMBRE
Raz UNITE
Repeat
 J = instr(1,LIGNE," ")
 If !J : Break : Endif
 K += 1
 NOMBRE(K) = val(left$(LIGNE,J-1))
 LIGNE = vireblc(right$(LIGNE,J+1),2)
 If find(toupper(left$(LIGNE,2)),"KB","MB","GB")
  UNITE(K)=toupper(left$(LIGNE,2))
  LIGNE = vireblc(right$(LIGNE,3),2)
 Endif
Until K>=5
Return

$OLD_OPT
 ##
 ## On ecrit le fichier sql de lecture des options
 ##
 Openo FICSQL , 0
 Wrseq "BEGIN"
 Wrseq "create table #tmpopt (OptionName nvarchar(30))"
 Wrseq "insert into #tmpopt (OptionName) exec sp_dboption "+[M:PRO0]BDDNAM
 Wrseq "create table #tmp (OptionName nvarchar(30),CurrentSetting char(1))"
 Wrseq "insert into #tmp (OptionName) exec sp_dboption "
 Wrseq "update #tmp set CurrentSetting='1'"
 Wrseq "update #tmp set CurrentSetting='2' where exists (select 'x' from #tmpopt where #tmpopt.OptionName = #tmp.OptionName)"
 Wrseq "select 'VAL='+CurrentSetting+' OPT='+OptionName From #tmp"
 Wrseq "drop table #tmp"
 Wrseq "drop table #tmpopt"
 Wrseq "END"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo

 System COMMANDE = MACHINE+'@'+CMDFIC
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   #VAL=1 OPT=ANSI null default
   If left$(LIGNE,4)="VAL="
      nolign +=1
      [M:PRO2]OPTVAL(nolign-1)=val(mid$(LIGNE,5,1))
      [M:PRO2]OPT(nolign-1)=right$(LIGNE,11)
   Endif
   Rdseq LIGNE
  Wend
  [M:PRO2]NBOPT=nolign
  Openi
 Endif

 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Return

$NEW_OPT
Local Char WCOL(100)(1..)
Local Integer NB_WCOL
Raz SQLREQ
SQLREQ(0) = "select col.name from sys.all_columns col,sys.all_views vie "
SQLREQ(1) = "where col.object_id=vie.object_id and vie.name='databases' "
SQLREQ(2) = "order by col.column_id"

Raz NB_WCOL
For (Char VCOL(100)) From '5' Sql SQLREQ As [BXX]
  NB_WCOL+=1
  WCOL(NB_WCOL)=vireblc([BXX]VCOL,2)
Next
For I=1 To NB_WCOL
 Raz SQLREQ
 SQLREQ(0) = "select cast( "+WCOL(I)+" as varchar(100)) from sys.databases where name=db_name() "
 For (Char VVAL(100)) From '5' Sql SQLREQ As [BXX]
    nolign +=1
    [M:PRO2]OPTVAL(nolign-1)=vireblc([BXX]VVAL,2)
    [M:PRO2]OPT(nolign-1)=WCOL(I)
 Next
Next
[M:PRO2]NBOPT=nolign
Return

