#<AdxTL>@(#)0.0.0.0 $Revision$
# Class AQCOPR1

$EVENTS
Local Char TMP_ACTION: TMP_ACTION="EVENTS"
Gosub EVENT_ACTION
Case [L]CURPTH
   When ""
    Case [L]EVENT
    Endcase
Endcase
Return

$METHODS
Local Char TMP_ACTION: TMP_ACTION="METHODS"
Gosub METH_ACTION
If [L]METH<>AVOID.ACHAR           # Temporary until U11 - where only class methods are called due to "When Default" on Case statement
  Case [L]METH
  Endcase
Endif
Return

$OPERATIONS
Local Char TMP_ACTION: TMP_ACTION="OPERATIONS"
Gosub OPERATION_ACTION
Case [L]OPERATION
Endcase
Return


$PROPERTIES
#Gosub PROPERTY_ACTION
Case [L]CURPRO
Endcase
Return

$EVENT_ACTION
If dim([L]METH)<=0 Local Char METH : Endif
If dim([L]OPERATION)<=0 Local Char OPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]ACTION)<=0 Local Char ACTION : Endif
[L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"U10 = Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
& +ACTION+"] METH=["+[L]METH+"] Operation=["+[L]OPERATION+"]",[V]CST_AINFO)
Return

$METH_ACTION
If dim([L]METH)<=0 Local Char METH : Endif
If dim([L]OPERATION)<=0 Local Char OPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]ACTION)<=0 Local Char ACTION : Endif
If [L]METH=AVOID.ACHAR
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "U9 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
&     +ACTION+"] METH=["+[L]METH+"] Operation=["+[L]OPERATION+"]",[V]CST_AINFO)
Else
  [L]ASTATUS = fmet this.ASETERROR(ACTION, "U9 and U10 ="-this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
&     +ACTION+"] METH=["+[L]METH+"] Operation=["+[L]OPERATION+"]",[V]CST_AINFO)
Endif
#  [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [METHODS] Action "+"METH=["+[L]METH+"]",[V]CST_AINFO)
 # [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [METHODS] Action "+"CURPTH=["+CURPTH+"] ACTION=["+ACTION+"]",[V]CST_AINFO)
Return

$OPERATION_ACTION
If dim([L]METH)<=0 Local Char METH : Endif
If dim([L]OPERATION)<=0 Local Char OPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]ACTION)<=0 Local Char ACTION : Endif
[L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"U10 = Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] ACTION=["
& +ACTION+"] METH=["+[L]METH+"] Operation=["+[L]OPERATION+"]",[V]CST_AINFO)
#  [L]ASTATUS = fmet this.ASETERROR(ACTION, this.ObjectType-"Execute [OPERATION] Action "+"OPERATION=["+[L]OPERATION+"]",[V]CST_AINFO)
Return

$PROPERTY_ACTION
Local Integer MY_STATUS
If ! (ACTION ="PROPAGATE" and find(CURPRO,"UPDDATTIM","UPDUSR"))
 MY_STATUS = fmet this.ASETERROR("PROPERTY_ACTION", "Property Action Execute "+"CURPRO=["+CURPRO+"] ACTION=["+ACTION+"]",[V]CST_AINFO)
Endif
Return

