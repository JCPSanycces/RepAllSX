#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque OPECCE
# ACTIONS:
#            - SAIOPECCE     Saisie des sections analytiques des suivis opératoires
#--------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE"    :    Gosub OUVRE
    When "DEBUT"    :    Gosub DEBUT
    When "SETBOUT"  :    Gosub SETBOUT
    When "ABA"      :    Gosub DEBUT
    When "OK"       :    Gosub OK
    When "FIN"      :    Gosub FIN
Endcase
Return

####################################################################
$OUVRE
Local Integer    CHOIX, I
Local Integer    WNOLIGN
Local Char       WCCE(15)
Local Char SAV_GREP :  SAV_GREP = GREP
 
WNOLIGN = nolign
If clalev([F:MWC]) = 0 : Local File WORKCOST  [MWC] : Endif
If clalev([F:MWC2]) = 0 : Local File WORKCOST  [MWC2] : Endif #  MWC2 pour CPLLAB 
If clalev([F:CCE]) = 0 : Local File CACCE     [CCE] : Endif
If clalev([F:CDE]) = 0 : Local File CACCEDEF  [CDE] : Endif
Return

###################################################################
$SETBOUT
ETABOU(GVALI) = 1
ETABOU(GABAN) = 1
Return

################################################################### 
$DEBUT

Raz    [M:OPCE] 

# charge les sections d'origine (masque de saisie des opérations)
# distinguer selon la fonction d'où l'on vient
Case GFONC1
 When "GESMTK" , "CONSMKO" #16750 12/02 BV
   [M:OPCE] = [M:MTK1] : # une ligne suivi d'opération
    # avoir MWC en ligne pour les conditions de saisie.
   Read [MWS]WST0=[M:MTK1]CPLWST(nolign-1);[M:MTK0]MFGFCY
   Read [MWC]WCT0=[F:MWS]VLTCCE;[M:MTK0]MFGFCY
   # poste main d'oeuvre
   Raz  [F:MWC2]
   Read [MWS]WST0=[M:MTK1]CPLLAB(nolign-1);[M:MTK0]MFGFCY
   Read [MWC2]WCT0=[F:MWS]VLTCCE;[M:MTK0]MFGFCY
 When "FUNBENCHO","FUNBENPLT"
   [M:OPCE] = [M:MBO]  : # une ligne suivi des temps
   Read [MWS]WST0=[M:MBO]CPLWST(nolign-1);[M:MBO]FCY
   Read [MWC]WCT0=[F:MWS]VLTCCE;[M:MBO]FCY
   # poste main d'oeuvre
   Raz  [F:MWC2]
   Read [MWS]WST0=[M:MBO]CPLLAB(nolign-1);[M:MBO]FCY
   Read [MWC2]WCT0=[F:MWS]VLTCCE;[M:MBO]FCY
Endcase

If (GFONC1 = "GESMTK" | GFONC1 = "CONSMKO") & SAV_GREP <> "C"  # [M:MTK1]MODIFLG(nolign-1)=0 16750 12/02 BV
  Grizo [OPCE]
Else
  Affzo [OPCE]  # >> ou diszo selon mode Modif ?
Endif
If [M:OPCE]CPLLAB = "" Grizo [M:OPCE]10 : Endif
Return

############################################################
$OK
nolign = WNOLIGN   : # pour le transclasse
Case GFONC1
 When "GESMTK"
   [M:MTK1] = [M:OPCE]
 When "FUNBENCHO","FUNBENPLT"
   [M:MBO]  = [M:OPCE]
Endcase
Return

############################################################
$FIN
nolign     = WNOLIGN
Return

