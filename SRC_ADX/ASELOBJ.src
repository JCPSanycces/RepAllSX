##############################################################
Subprog C_EXP1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Integer I , K , ER
 Local Char    CHAINE(80)
 For I=1 To [M]NBTBL
  Read [ATB]CODFIC=[M]TBTBL(I)
  If ([M]ABTBL(I)="" | ([M]ABTBL(I)=[F:ATB]ABRFIC)) & evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0
   Local File =[M]TBTBL(I)
  Endif
 Next I
 Local File =[M]ATB : # Pour l'avoir par défaut
 Default [F] , [V] , [L] , [S]
 Onerrgo ERREXP
 ER = 0
 K = evalue([L]VALEUR)
 Onerrgo
 If ER
  mkstat = 2 : End
 Endif
Endif
End

$ERREXP
ER = errn
GMESSAGE = mess(37,124,1)+"\"+errmes$(ER)+"\"+errm
ER=1
# Expression incorrecte
Resume

########################################
$SEL_LISTE
Case LISTE
 When "ASELTBL"
  Local Char XTAB(GLONATB) , XABR(GLONABR), XTEXTE(30)
  NBTEX = 0
  XTAB = [M]ATB : Gosub SELTAB
  For I=1 To [M]NBTBL
   XTAB = [M]TBTBL(I)
   XABR = [M]ABTBL(I)
   Gosub SELTAB
  Next I
Endcase
Return

$SELTAB
NBTEX += 1
Read [ATB]CODFIC = XTAB
If XABR=""
 XABR = [F:ATB]ABRFIC
Endif
TEX(NBTEX) = XTAB
Call TEXTE([F:ATB]INTITFIC,XTEXTE) From OBJDIV
TEXTE(NBTEX) = XTAB-"["+XABR+"]"-XTEXTE
Return

########################################
$SEL_TABLE
Case TABLE
 When "ASELFLD"
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATX])=0  : Local File ATEXTE   [ATX]  : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
  TIT = mess(109,124,1)-PARAM(1) : # Choix d'un champ TABLE
  START = "[F:ATZ]CODZONE"
  DEFPAG = 1
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODZONE" : TIT(NBCOL) = mess(36,124,1)
  NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE"   : TIT(NBCOL) = mess(82,123,1)
  Link [ATZ]
& With [ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
&    , [ATY]CODTYP=[F:ATZ]CODTYP
&    , [ACV]CODACT=[F:ATZ]CODACT
& As [LNK]
& Where [F:ATZ]CODFIC=PARAM(1) & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0 & [F:ATY]TYPTYP<9
&     & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)
  Default File [LNK]

 When "SELINTTAB3"
  Local Char WVALZON(255)
  DEFPAG = 1
  NBCOL = 0
  ORDRE = "[F:ATX]TEXTE;[F:ATZ]CODFIC;[F:ATZ]CODZONE"
  EXPSTART =  "[F:ATX]TEXTE>='"+VALEUR+"'"
  OBJET = "ATZ"
  #120859
  #Call  TRANSCOL("ATZ",NBCOL,COL,TIT,FMTCOL) From OBJDIV
  CRITERE(1) = '(find(CODFIC,[M]ATB,TBTBL(1..[M]NBTBL))<>0) & [F:ATY]TYPTYP<9 & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
  CRITERE(1) += ' & CODFIC <> "ATEXTRA"'
  If PARAM(2)<>""
   CRITERE(1) += ' & Pat(toupper(ctrans([F:ATX]TEXTE)),"*'+toupper(ctrans(VALEUR))+'*")'
  Endif
  If [M]OBJ=""
   CRITERE(2) += ' & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0'
  Endif
  CRITERE(2) += '& ((find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & DIME=1) or find(CODTYP,"AXX","AX1","AX2","AX3")=0)'
  WVALZON = VALEUR
  VALEUR = ""

 When "SELFLDTAB5"
  Local Char WVALZON(255),ZONE(255),WVALTBL(255)
  Local Integer K
  DEFPAG = 1
  NBCOL = 0
  EXPSTART =  "[F:ATZ]CODZONE>='"+VALEUR+"'"
  OBJET = "ATZ"
  ORDRE = "[F:ATZ]CODFIC;[F:ATZ]CODZONE"
  #120859
  #Call  TRANSCOL("ATZ",NBCOL,COL,TIT,FMTCOL) From OBJDIV
  CRITERE(1) = '(find(CODFIC,[M]ATB,TBTBL(1..[M]NBTBL))<>0) & [F:ATY]TYPTYP<9 & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)'
  CRITERE(1) += ' & CODFIC <> "ATEXTRA"'
  If PARAM(2)<> ""
   CRITERE(1) += ' & Pat([F:ATZ]CODZONE,"'
   K = instr(1,VALEUR,"(")
   If K
    ZONE = left$(VALEUR,K-1)
   Else
    ZONE = VALEUR
   Endif
   CRITERE(1) += "*"+toupper(ctrans(ZONE))+'*") <> 0'
  Endif
  If [M]OBJ=""
   CRITERE(2) += ' & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")=0'
  Endif
  CRITERE(2) += '& ((find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & DIME=1) or find(CODTYP,"AXX","AX1","AX2","AX3")=0)'
  WVALZON = VALEUR
  WVALTBL = PARAM(1)
  VALEUR = ""
Endcase
Return

$FIN_TABLE
Case TABLE
 When "SELINTTAB3"
  If VALEUR <> ""
   Case zoncou
    When "DES1" : FLD1=[F:ATZ]CODZONE : TBL1=[F:ATZ]CODFIC : Affzo FLD1
    When "DES2" : FLD2=[F:ATZ]CODZONE : TBL2=[F:ATZ]CODFIC : Affzo FLD2
    When "DES3" : FLD3=[F:ATZ]CODZONE : TBL3=[F:ATZ]CODFIC : Affzo FLD3
    When "DES4" : FLD4=[F:ATZ]CODZONE : TBL4=[F:ATZ]CODFIC : Affzo FLD4
    When "DES5" : FLD5=[F:ATZ]CODZONE : TBL5=[F:ATZ]CODFIC : Affzo FLD5
   Endcase
   VALEUR = func AFNC.TEXTE([F:ATZ]NOCOURT)
  Else
   VALEUR =  WVALZON
  Endif
 When "SELFLDTAB5"
  If VALEUR <> ""
   Case zoncou
    When "FLD1" : DES1=[F:ATX]TEXTE : TBL1=[F:ATZ]CODFIC : Affzo DES1
    When "FLD2" : DES2=[F:ATX]TEXTE : TBL2=[F:ATZ]CODFIC : Affzo DES2
    When "FLD3" : DES3=[F:ATX]TEXTE : TBL3=[F:ATZ]CODFIC : Affzo DES3
    When "FLD4" : DES4=[F:ATX]TEXTE : TBL4=[F:ATZ]CODFIC : Affzo DES4
    When "FLD5" : DES5=[F:ATX]TEXTE : TBL5=[F:ATZ]CODFIC : Affzo DES5
   Endcase
   VALEUR   = [F:ATZ]CODZONE
   PARAM(1) = [F:ATZ]CODFIC
  Else
   VALEUR   =  WVALZON
   PARAM(1) =  WVALTBL
  Endif
Endcase
Return

######################################################
## Filtre STD en gestion d'objet
######################################################
Subprog FILTRE(TABLE,FILTRE)
Value    Char TABLE
Variable Char FILTRE()
Local Char DEFMSK(250) , ABR(GLONABR)

If filinfo(filpath("ETM",GUSER+"_"+TABLE+"_"+"STD","sel",0),0)>=0
 If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
 If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
 If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
 DEFMSK = dbgstr(1)
 If clalev([M:ASL])=0
  Local Mask ASELOBJ [ASL]
  Raz [M]
  Call LECMEMO("STD","[M:ASL]",TABLE+"~"+"sel") From GMEMO
 Else
  Local Mask ASELOBJ [ASL]
  Raz [M]
  Call LECMEMO("STD","[M:ASL]",TABLE+"~"+"sel") From GMEMO
 Endif
 Gosub EXPRESSION
 FILTRE = EXPRESSION
 Default Mask DEFMSK
Elsif filinfo(filpath("ETM",GSUPER+"_"+TABLE+"_"+"STD","glo",0),0)>=0
 If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
 If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
 If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
 DEFMSK = dbgstr(1)
 If clalev([M:ASL])=0
  Local Mask ASELOBJ [ASL]
  Raz [M]
  Call LECMEMOPT("STD","[M:ASL]",TABLE+"~"+"glo") From GMEMO
 Else
  Local Mask ASELOBJ [ASL]
  Raz [M]
  Call LECMEMOPT("STD","[M:ASL]",TABLE+"~"+"glo") From GMEMO
 Endif
 Gosub EXPRESSION
 FILTRE = EXPRESSION
 Default Mask DEFMSK
Else
 FILTRE = ""
Endif
End

######################################################
## Lecture d'un fichier mémo
######################################################
Subprog SEL_MEMO(TABLE,STAITO,MEMGLO,REPONSE,SEL_MEMO,FILTRE)
Value    Char    TABLE
Value    Integer STAITO
Value    Integer MEMGLO
Value    Integer REPONSE
Value    Char    SEL_MEMO()(1..)
Variable Char    FILTRE
Local    Integer NUMITM
Local    Char    ABR(GLONABR)

If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([M:ASL])=0  : Local Mask ASELOBJ   [ASL]  : Endif
Raz [M:ASL]

NUMITM = REPONSE-STAITO
If NUMITM<=MEMGLO
 Call LECMEMOPT(SEL_MEMO(NUMITM),"[M:ASL]",TABLE+"~"+"glo") From GMEMO
 Gosub COMPAT
 Gosub PARAMETRE
 Gosub EXPRESSION
 FILTRE = EXPRESSION

Elsif SEL_MEMO(NUMITM)<>""
 Call LECMEMO(SEL_MEMO(NUMITM),"[M:ASL]",TABLE+"~"+"sel") From GMEMO
 Gosub COMPAT
 Gosub PARAMETRE
 Gosub EXPRESSION
 FILTRE = EXPRESSION

Else : # Tous
 [M:ASL]OBJ = GABREV
 FILTRE = "1=1"
Endif

End

# On regarde si on a des parametres
$PARAMETRE
If find(2,[M:ASL]PAR1,[M:ASL]PAR2,[M:ASL]PAR3,[M:ASL]PAR4,[M:ASL]PAR5,[M:ASL]PAREXP)
 Call SAISIE_CHAR(GBIDC1,GBIDC1,"ASELPAR","ASELPAR","SPESELPAR") From GSAISIE
 If GBIDC1 <> ""
  Raz [M:ASL]
  [M:ASL]OBJ = GABREV
  FILTRE = "1=1"
  End
 Endif
Endif
Return

# Compatibilité avec les anciens mémo
$COMPAT
If [M:ASL]FLD1<>""
 WCHAMP = [M:ASL]FLD1
 If instr(1,WCHAMP,"(")>0 :  WCHAMP = left$(WCHAMP,instr(1,WCHAMP,"(")-1) : Endif
 Read [ATZ]CODZONE = [M:ASL]TBL1;WCHAMP
 If [M]OPE1 = 8 : [M:ASL]FMT1 = "A" : Else [M:ASL]FMT1 = [F:ATZ]CODTYP : Endif
 If [M:ASL]OPE1>1
  Call CHARGE([M:ASL]VAL1,[M:ASL]FMT1,[M:ASL]NOLIB1,0,[M:ASL]VALI1)
 Endif
 If [M:ASL]FLD1<>"" & [M:ASL]DES1=""
  Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
  If !fstat : [M:ASL]DES1 =[F:ATX]TEXTE : Endif
 Endif
Endif
If [M:ASL]FLD2<>""
 WCHAMP = [M:ASL]FLD2
 If instr(1,WCHAMP,"(")>0 :  WCHAMP = left$(WCHAMP,instr(1,WCHAMP,"(")-1) : Endif
 Read [ATZ]CODZONE = [M:ASL]TBL2;[M:ASL]FLD2
 If [M]OPE2 = 8 : [M:ASL]FMT2 = "A" : Else [M:ASL]FMT2 = [F:ATZ]CODTYP : Endif
 If [M:ASL]OPE2>1
  Call CHARGE([M:ASL]VAL2,[M:ASL]FMT2,[M:ASL]NOLIB2,0,[M:ASL]VALI2)
 Endif
 If [M:ASL]FLD2<>"" & [M:ASL]DES2=""
  Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
  If !fstat : [M:ASL]DES2 =[F:ATX]TEXTE : Endif
 Endif
Endif
If [M:ASL]FLD3<>""
 WCHAMP = [M:ASL]FLD3
 If instr(1,WCHAMP,"(")>0 :  WCHAMP = left$(WCHAMP,instr(1,WCHAMP,"(")-1) : Endif
 Read [ATZ]CODZONE = [M:ASL]TBL3;[M:ASL]FLD3
 If [M]OPE3 = 8 : [M:ASL]FMT3 = "A" : Else [M:ASL]FMT3 = [F:ATZ]CODTYP : Endif
 If [M:ASL]OPE3>1
  Call CHARGE([M:ASL]VAL3,[M:ASL]FMT3,[M:ASL]NOLIB3,0,[M:ASL]VALI3)
 Endif
 If [M:ASL]FLD3<>"" & [M:ASL]DES3=""
  Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
  If !fstat : [M:ASL]DES3 =[F:ATX]TEXTE : Endif
 Endif
Endif
If [M:ASL]FLD4<>""
 WCHAMP = [M:ASL]FLD4
 If instr(1,WCHAMP,"(")>0 :  WCHAMP = left$(WCHAMP,instr(1,WCHAMP,"(")-1) : Endif
 Read [ATZ]CODZONE = [M:ASL]TBL4;[M:ASL]FLD4
 If [M]OPE4 = 8 : [M:ASL]FMT4 = "A" : Else [M:ASL]FMT4 = [F:ATZ]CODTYP : Endif
 If [M:ASL]OPE4>1
  Call CHARGE([M:ASL]VAL4,[M:ASL]FMT4,[M:ASL]NOLIB4,0,[M:ASL]VALI4)
 Endif
 If [M:ASL]FLD4<>"" & [M:ASL]DES4=""
  Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
  If !fstat : [M:ASL]DES4 =[F:ATX]TEXTE : Endif
 Endif
Endif
If [M:ASL]FLD5<>""
 WCHAMP = [M:ASL]FLD5
 If instr(1,WCHAMP,"(")>0 :  WCHAMP = left$(WCHAMP,instr(1,WCHAMP,"(")-1) : Endif
 Read [ATZ]CODZONE = [M:ASL]TBL5;[M:ASL]FLD5
 If [M]OPE5 = 8 : [M:ASL]FMT5 = "A" : Else [M:ASL]FMT5 = [F:ATZ]CODTYP : Endif
 If [M:ASL]OPE5>1
  Call CHARGE([M:ASL]VAL5,[M:ASL]FMT5,[M:ASL]NOLIB5,0,[M:ASL]VALI5)
 Endif
 If [M:ASL]FLD5<>"" & [M:ASL]DES5=""
  Read [F:ATX]NUMERO = GLANGUE;[F:ATZ]NOCOURT
  If !fstat : [M:ASL]DES5 =[F:ATX]TEXTE : Endif
 Endif
Endif
Return

Subprog CHARGE(VALEUR,TYP,LIB,LONG,VALINT)
Variable Char    VALEUR
Value    Char    TYP
Value    Integer LIB
Value    Decimal LONG
Variable Char    VALINT

If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
If [F:ATY]CODTYP<>TYP
 Read [ATY]CODTYP = TYP
 If fstat
  Read [ATY]CODTYP = "A"
 Endif
Endif

TYP = [F:ATY]CODTYP
If left$([F:ATY]FORTYP,1)="="
 [F:ATY]FORTYP = ""
Endif

Case [F:ATY]TYPTYP
 When 1
  If val(VALINT)<=len(mess(0,LIB,1))
   VALEUR = mess(val(VALINT),LIB,1)
  Endif
 When Default
  Call CHARGE(VALEUR,TYP,LIB,LONG,VALINT)  From FMTVAR
Endcase
End


