$AS_VAL
Case I
 When 1 : If [M]FLD1="" or [M]OPE1=1 : mkstat = 1 : End : Endif
 When 2 : If [M]FLD2="" or [M]OPE2=1 : mkstat = 1 : End : Endif
 When 3 : If [M]FLD3="" or [M]OPE3=1 : mkstat = 1 : End : Endif
 When 4 : If [M]FLD4="" or [M]OPE4=1 : mkstat = 1 : End : Endif
 When 5 : If [M]FLD5="" or [M]OPE5=1 : mkstat = 1 : End : Endif
Endcase
Local Char    CHAMP(20) , TABLE(GLONATB) , FORMA(30) , CAR(1) , OPTION(10) , ZONE(GLONAVA)
Local Integer NOLIB , K , LONG , TABDIV , IND , OIND , OLIG , ER
Case I
 When 1 : CHAMP = [M]FLD1 : TABLE = [M]TBL1
 When 2 : CHAMP = [M]FLD2 : TABLE = [M]TBL2
 When 3 : CHAMP = [M]FLD3 : TABLE = [M]TBL3
 When 4 : CHAMP = [M]FLD4 : TABLE = [M]TBL4
 When 5 : CHAMP = [M]FLD5 : TABLE = [M]TBL5
Endcase
K = instr(1,CHAMP,"(")
If K
 ZONE = left$(CHAMP,K-1)
 IND  = val(right$(CHAMP,K+1))
Else
 ZONE = CHAMP
 IND  = 0
Endif
Read [ATZ]CODZONE = TABLE;ZONE
Read [ATY]CODTYP = [F:ATZ]CODTYP
If left$([F:ATY]FORTYP,2)="=G" & [F:ATY]TYPTYP=7
 Read [AGB]AGB0 = right$([F:ATY]FORTYP,2)
 If !fstat & evalue("[M]SAVGFOR")=""
  Assign "[M]SAVGFOR" With evalue(right$([F:ATY]FORTYP,2))
  Assign right$([F:ATY]FORTYP,2) With ""
 Endif
Endif
End

############################################################
Subprog AV_VAL1(VALEUR)
Variable Char VALEUR
Local Integer I
I = 1
Goto AV_VAL

Subprog AV_VAL2(VALEUR)
Variable Char VALEUR
Local Integer I
I = 2
Goto AV_VAL

Subprog AV_VAL3(VALEUR)
Variable Char VALEUR
Local Integer I
I = 3
Goto AV_VAL

Subprog AV_VAL4(VALEUR)
Variable Char VALEUR
Local Integer I
I = 4
Goto AV_VAL

Subprog AV_VAL5(VALEUR)
Variable Char VALEUR
Local Integer I
I = 5
Goto AV_VAL

$AV_VAL
Local Char    CHAMP(20) , TABLE(GLONATB) , FORMA(30) , CAR(1) , OPTION(10) , ZONE(GLONAVA)
Local Integer NOLIB , K , LONG , TABDIV , IND , OIND , OLIG , ER
Case I
 When 1 : CHAMP = [M]FLD1 : TABLE = [M]TBL1
 When 2 : CHAMP = [M]FLD2 : TABLE = [M]TBL2
 When 3 : CHAMP = [M]FLD3 : TABLE = [M]TBL3
 When 4 : CHAMP = [M]FLD4 : TABLE = [M]TBL4
 When 5 : CHAMP = [M]FLD5 : TABLE = [M]TBL5
Endcase
K = instr(1,CHAMP,"(")
If K
 ZONE = left$(CHAMP,K-1)
 IND  = val(right$(CHAMP,K+1))
Else
 ZONE = CHAMP
 IND  = 0
Endif

If ZONE=""
 FORMA = "Kf:15X"
Elsif ( ([M]OPE1=8 & I=1) or ([M]OPE2=8 & I=2)  or ([M]OPE3=8 & I=3)  or ([M]OPE4=8 & I=4)  or ([M]OPE5=8 & I=5)  )
 FORMA = ""
 NOLIB  = 0
 TABDIV = 0
 Read [ATY]CODTYP = "A"
Else
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 NOLIB  = 0
 TABDIV = 0
 Case [F:ATY]TYPTYP
  When 1
   If [F:ATY]NOLIB<>0
    NOLIB = [F:ATY]NOLIB
   Else
    NOLIB = [F:ATZ]NOLIB
   Endif
   FORMA = "Nf:2#"
  When 7
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   If LONG>20 : LONG = 20 : Endif
   OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
   If instr(1,OPTION,"C")
    CAR = "d"
   Elsif instr(1,OPTION,"A")
    CAR = "d"
   Else
    CAR = "X"
   Endif
   FORMA = "Kf:"+num$(LONG)+CAR
   If [F:ATY]OBJLIEN="ADI"
    Local File AMSKPAR [AMP]
    Read [AMP]CODPAR = 2;TABLE;ZONE;"ADI"
    PARTAB = [F:AMP]VALPAR
    If left$(PARTAB,1)="'" or left$(PARTAB,1)='"'
     PARTAB = seg$(PARTAB,2,len(PARTAB)-1)
    Endif
    OIND = indice
    OLIG = nolign
    indice = IND
    nolign = indice+1
    ER = 0
    Onerrgo ERREXP
    TABDIV = val(PARTAB)
    If ER or TABDIV=0
     ER = 0
     TABDIV = val(num$(evalue(PARTAB)))
    Endif
    Onerrgo
    If ER : TABDIV = 0 : Endif
    indice = OIND
    nolign = OLIG
    Close Local File [AMP]
   Endif
  When 8
   FORMA = "Df:"+GFMDAT
  When 2,3
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:"+num$(LONG)+"#"
  When 4
   If [F:ATY]LNGTYP<>0
    LONG = [F:ATY]LNGTYP
   Else
    LONG = [F:ATZ]LONG
   Endif
   FORMA = "Nf:15F"
 Endcase
Endif
Case I
 When 1 : [M]FMT1 = [F:ATY]CODTYP : [M]NOLIB1 = NOLIB
          If TABDIV<>0 : [M]SUPP1 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP1 = "" : Endif
 When 2 : [M]FMT2 = [F:ATY]CODTYP : [M]NOLIB2 = NOLIB
          If TABDIV<>0 : [M]SUPP2 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP2 = "" : Endif
 When 3 : [M]FMT3 = [F:ATY]CODTYP : [M]NOLIB3 = NOLIB
          If TABDIV<>0 : [M]SUPP3 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP3 = "" : Endif
 When 4 : [M]FMT4 = [F:ATY]CODTYP : [M]NOLIB4 = NOLIB
          If TABDIV<>0 : [M]SUPP4 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP4 = "" : Endif
 When 5 : [M]FMT5 = [F:ATY]CODTYP : [M]NOLIB5 = NOLIB
          If TABDIV<>0 : [M]SUPP5 = '"'+num$(TABDIV)+'"' : Else : [M]SUPP5 = "" : Endif
Endcase
#108181 wrong GFMT on advanced selection
If [F:ATY]FORTYP<>"" : GFMT=FORMA : Endif
End

