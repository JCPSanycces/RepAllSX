#<AdxTL>@(#)12.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
GCASSE = 1
Local Char PARAM(250)(1..4) , VALEUR(10)
PARAM(1) = "ACLA"

#PARAM(4) = "ATABTAB"
Call SAISIE_CHAR(VALEUR,PARAM,"ASELOBJ","ASELOBJ","XWASELOBJ") From GSAISIE
Infbox PARAM(2)
End
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ATB",GBIDC1,GBIDC2) From GOBJET
End

######################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : Gosub OK
 When "FIN"        : Gosub FIN
 When "BOUTON"     : Gosub BOUTON
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE
Endcase
Return

###############################
$OK
Gosub EXPRESSION
PARAM(2) = EXPRESSION
PARAM(3) = "1"
FIN = 1
Return

###############################
$FIN
PARAM(4) = num$(MODIF_MEMO)
Return

###############################
$BOUTON
Case BOUT
 When "M" : If GSTATUT=GSTAOK : MODIF_MEMO = 1 : Endif
 When "R" : Gosub COMPAT : Gosub PARMSK : Affzo : # Rappel
 When "E" : If GSTATUT=GSTAOK : MODIF_MEMO = 1 : Endif
Endcase
Return

##############################
$OUVRE
Local Char TABLE(30) , ABR(GLONABR), WCHAMP(GLONAVA+5)
Local Integer MODIF_MEMO

If clalev([M:ASL])>0
 Call ERREUR(mess(67,139,1)) From GESECRAN : # Une sélection avancée est déjà en cours
 PARAM(2) = ""
 PARAM(3) = "0"
 FIN = 1
 Return
Endif

Local File AOBJET [AOB] , ATABLE  [ATB] , ATABZON [ATZ], ATYPE [ATY] , ACTIV [ACV]
If clalev([F:AOT])=0  : Local File AOBJTAB [AOT]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE  [ATX]  : Endif
If clalev([F:AOS])=0  : Local File AOBJSEL [AOS]  : Endif
If clalev([F:AUS1])=0 : Local File AUTILIS [AUS1] : Endif
If clalev([F:AGB])=0  : Local File AGLOBVAR [AGB] : Endif

Local Mask ASELOBJ [ASL]

If PARAM(1)<>""
 Read [AOB]ABREV = PARAM(1)
 TABLE = [F:AOB]NOMFIC
Else
 TABLE = PARAM(4)
Endif
If (PARAM(1)<>"" & PARAM(1)<>[M]OBJ) | (PARAM(4)<>"" & PARAM(4)<>[M]ATB)
 Raz [M]
 If filinfo(filpath("ETM",GUSER+"_"+TABLE+"_"+"STD","sel",0),0)>=0
  Call LECMEMO("STD","[M:ASL]",TABLE+"~"+"sel") From GMEMO
  Gosub COMPAT
 Elsif filinfo(filpath("ETM",GSUPER+"_"+TABLE+"_"+"STD","glo",0),0)>=0
  Call LECMEMOPT("STD","[M:ASL]",TABLE+"~"+"glo") From GMEMO
  Gosub COMPAT
 Endif
Else
 Gosub COMPAT
Endif
Gosub PARMSK

Return

####################################################
$PARMSK
[M]NBTBL = 0
[M]ATB = TABLE
[M]OBJ = PARAM(1)
If PARAM(1)<>""
 Read [AOB]ABREV = PARAM(1)
 [M]DIC = [M]OBJ
 If [M]TBL1="" : [M]TBL1 = TABLE : Endif
 [M]TITDIC = mess(33,115,1) : # Objet
 Call TEXTE([F:AOB]LIBEL,[M]DICNAM) From OBJDIV
 For [AOT]ABREV Where ABREV=[M]OBJ & TABLIEN<>""
  [M]NBTBL += 1
  [M]TBTBL([M]NBTBL) = [F:AOT]TABFIC
  [M]ABTBL([M]NBTBL) = [F:AOT]TABABR
 Next AOT
 If dim([F:AOB]ABRFIC)>0 & [F:AOB]ABRFIC<>""
  [M]ABR = [F:AOB]ABRFIC
 Elsif [F:AOB]NOMFIC<>""
  Read [ATB]CODFIC=[F:AOB]NOMFIC
  [M]ABR = [F:ATB]ABRFIC
 Else
  [M]ABR = ""
 Endif
Else
 [M]DIC = [M]ATB
 [M]TITDIC = mess(56,123,1) : # Table
 Read [ATB]CODFIC = [M]ATB
 Call TEXTE([F:ATB]INTITFIC,[M]DICNAM) From OBJDIV
 [M]ABR = [F:ATB]ABRFIC
Endif
Return

###############################
$DEBUT
If [M]NBTBL=0
 [M]TBL1 = [M]ATB : [M]ABR1 = ""
 [M]TBL2 = [M]ATB : [M]ABR2 = ""
 [M]TBL3 = [M]ATB : [M]ABR3 = ""
 [M]TBL4 = [M]ATB : [M]ABR4 = ""
 [M]TBL5 = [M]ATB : [M]ABR5 = ""
 Affzo TBL1, TBL2, TBL3, TBL4, TBL5
 Grizo TBL1, TBL2, TBL3, TBL4, TBL5
Endif
Affzo
PARAM(2) = ""
PARAM(3) = "0"
Return

###############################
$EXPRESSION
If dim([M]EXPRESSION)<0
 Local Integer XFLG
 Local Char    EXPRESSION(250)
Endif

If [M]NBTBL=0 & [M]OBJ<>""
 XFLG = 0
Else
 XFLG = 1
Endif
EXPRESSION = ""
If [M]FLD1<>""
 If [M]TBL1="" or [M]TBL1=[M]ATB
  [M]TBL1 = [M]ATB : [L]ABR = [M]ABR
 Else
  If [M]ABR1=""
   Read [ATB]CODFIC=[M]TBL1
   [L]ABR = [F:ATB]ABRFIC
  Else
   [L]ABR = [M]ABR1
  Endif
 Endif
 Call ADDCRIT(EXPRESSION,[M]TBL1,[L]ABR,[M]FLD1,[M]OPE1,[M]VALI1,XFLG,[M]OBJ)
 If [M]FLD2<>""
  If [M]TBL2="" or [M]TBL2=[M]ATB
   [M]TBL2 = [M]ATB : [L]ABR = [M]ABR
  Else
   If [M]ABR2=""
    Read [ATB]CODFIC=[M]TBL2
    [L]ABR = [F:ATB]ABRFIC
   Else
    [L]ABR = [M]ABR2
   Endif
  Endif
  Call ADDETOU(EXPRESSION,[M]ANDOR2,[M]TBL2,[L]ABR,[M]FLD2,[M]OPE2,[M]VALI2,XFLG,[M]OBJ)
  If [M]FLD3<>""
   If [M]TBL3="" or [M]TBL3=[M]ATB
    [M]TBL3 = [M]ATB : [L]ABR = [M]ABR
   Else
    If [M]ABR3=""
     Read [ATB]CODFIC=[M]TBL3
     [L]ABR = [F:ATB]ABRFIC
    Else
     [L]ABR = [M]ABR3
    Endif
   Endif
   Call ADDETOU(EXPRESSION,[M]ANDOR3,[M]TBL3,[L]ABR,[M]FLD3,[M]OPE3,[M]VALI3,XFLG,[M]OBJ)
   If [M]FLD4<>""
    If [M]TBL4="" or [M]TBL4=[M]ATB
     [M]TBL4 = [M]ATB : [L]ABR = [M]ABR
    Else
     If [M]ABR4=""
      Read [ATB]CODFIC=[M]TBL4
      [L]ABR = [F:ATB]ABRFIC
     Else
      [L]ABR = [M]ABR4
     Endif
    Endif
    Call ADDETOU(EXPRESSION,[M]ANDOR4,[M]TBL4,[L]ABR,[M]FLD4,[M]OPE4,[M]VALI4,XFLG,[M]OBJ)
    If [M]FLD5<>""
     If [M]TBL5="" or [M]TBL5=[M]ATB
      [M]TBL5 = [M]ATB : [L]ABR = [M]ABR
     Else
      If [M]ABR5=""
       Read [ATB]CODFIC=[M]TBL5
       [L]ABR = [F:ATB]ABRFIC
      Else
       [L]ABR = [M]ABR5
      Endif
     Endif
     Call ADDETOU(EXPRESSION,[M]ANDOR5,[M]TBL5,[L]ABR,[M]FLD5,[M]OPE5,[M]VALI5,XFLG,[M]OBJ)
     EXPRESSION += ")"
    Endif
    EXPRESSION += ")"
   Endif
   EXPRESSION += ")"
  Endif
  EXPRESSION += ")"
 Endif
Endif
If [M]EXP1<>""
 If EXPRESSION<>""
  EXPRESSION -= "&"
 Endif
 EXPRESSION -= "("+[M]EXP1+")"
Endif
Return

###########################################################
Subprog ADDETOU(EXPR,ETOU,TABLE,ABR,CHAMP,OPE,VALEUR,XFLG,OBJ)
Variable Char EXPR()
Value Integer ETOU
Value Char TABLE,ABR,CHAMP
Value Integer OPE
Value Char VALEUR
Value Integer XFLG
Value Char  OBJ
If EXPR<>""
 Case ETOU
  When 1 : EXPR -= "&"
  When 2 : EXPR -= "|"
 Endcase
Endif
EXPR -= "("
Call ADDCRIT(EXPR,TABLE,ABR,CHAMP,OPE,VALEUR,XFLG,[M]OBJ)
End

Funprog ABRAXX(TABLE,CHAMP,OBJ)
Local Char ABR(GLONABR)
Local Integer OK
If clalev([F:AOT])=0  : Local File AOBJTAB [AOT]  : Endif
For [F:AOT] Where TABFIC ="ATEXTRA" & ABREV=OBJ
 If instr(1,[F:AOT]TABLIEN,TABLE) & instr(1,[F:AOT]TABLIEN,CHAMP)
  ABR = [F:AOT]TABABR
  OK =1
  Break
 Endif
Next
If OK =1 & ABR=""
 ABR ="AXX"
Endif
End ABR

###########################################################
Subprog ADDCRIT(EXPR,TABLE,ABR,CHAMP,OPE,VALEUR,XFLG,OBJ)
Variable Char EXPR()
Value Char TABLE,ABR,CHAMP
Value Integer OPE
Value Char VALEUR
Value Integer XFLG
Value Char  OBJ
Local Integer I , J , K , L , DIME
Local Char    ZONE(50) , ZFLG(50)
K = instr(1,CHAMP,"(")
If K
 DIME = val(right$(CHAMP,K+1))
 ZONE = left$(CHAMP,K-1)
Else
 DIME = 0
 ZONE = CHAMP
Endif
If OPE<>1
 Read [ATZ]CODZONE = TABLE;ZONE
 Read [ATY]CODTYP  = [F:ATZ]CODTYP
 If XFLG=1
  If [L]ABR=""
   Read [ATB]CODFIC = TABLE
   [L]ABR = [F:ATB]ABRFIC
  Endif
  Case [F:ATZ]CODTYP
   When "AXX","AX1","AX2","AX3"
    If func ABRAXX(TABLE,CHAMP,OBJ) <> ""
     ZFLG = "[F:"+func ABRAXX(TABLE,CHAMP,OBJ)+"]"+"TEXTE"
    Else
     ZFLG = ""
    Endif
   When Default
    ZFLG = "[F:"+[L]ABR+"]"+CHAMP
  Endcase
 Else
  Case [F:ATZ]CODTYP
   When "AXX","AX1","AX2","AX3"
   When Default
    ZFLG = CHAMP
  Endcase
 Endif
 If OPE=8
  J = instr(1,VALEUR,"*")
  K = instr(1,VALEUR,"?")
  If J or K
   L = 0
   If K or J<>len(VALEUR)
    EXPR += 'pat('+ZFLG
    If !instr(1,ZFLG,"(") : EXPR += '(0)' : Endif
    EXPR += ',"'+VALEUR+'")=1'
    L = 1
   Endif
   # If L : EXPR -= '&' : Endif :  # CCL 109985
   If     J & K : J = min(J,K)
   Elsif !J & K : J = K
   Endif
   If J>1
    If L : EXPR -= '&' : Endif :  # CCL 109985
    EXPR -= ZFLG+'>="'+left$(VALEUR,J-1)+'"'
    EXPR -= '&'
    EXPR -= ZFLG+'<"'+left$(VALEUR,J-2)+chr$(ascii(mid$(VALEUR,J-1,1))+1)+'"'
   Else
    # Issue 83187 - 2012-07-03 by VPO : correction Comme "*R"
    If !L : EXPR -= "1=1" : Endif
   Endif
  Else
   EXPR += ZFLG+'="'+VALEUR+'"'
  Endif
 Else
  If GCASSE = 1 & [F:ATY]TYPTYP=7
   EXPR -= "toupper("+ZFLG+")"
  Else
   EXPR -= ZFLG
  Endif
  Case OPE
   When 2 : EXPR += "="
   When 3 : EXPR += "<>"
   When 4 : EXPR += ">"
   When 5 : EXPR += ">="
   When 6 : EXPR += "<"
   When 7 : EXPR += "<="
  Endcase
  Case [F:ATY]TYPTYP
   When 7
    If GCASSE=1
     EXPR += '"'+toupper(VALEUR)+'"'
    Else
     EXPR += '"'+VALEUR+'"'
    Endif
   When 8
    If VALEUR="" or gdat$(VALEUR)=[0/0/0]
     EXPR += '[0/0/0]'
    Else
     EXPR += '['+format$(GFMD,gdat$(VALEUR))+']'
    Endif
   When Default
    EXPR += num$(VALEUR)
  Endcase
 Endif
Else
 EXPR += "1=1"
Endif
End

########################################
Subprog AS_TBL1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
Goto AS_TBL

Subprog AS_TBL2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
Goto AS_TBL

Subprog AS_TBL3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
Goto AS_TBL

Subprog AS_TBL4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
Goto AS_TBL

Subprog AS_TBL5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
Goto AS_TBL

$AS_TBL
If I>1 & (evalue("[M]TBL"+num$(I-1))="" or evalue("[M]FLD"+num$(I-1))="")
 VALEUR = ""
Endif
If [M]NBTBL=0
 VALEUR = [M]ATB
Elsif VALEUR = ""
 VALEUR = [M]ATB
Endif
End

########################################
Subprog AS_FLD1(VALEUR)
Variable Char    VALEUR()
Call AS_TBL1([M]TBL1)
If [M]TBL1="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD2(VALEUR)
Variable Char    VALEUR()
Call AS_TBL2([M]TBL2)
If [M]TBL2= "" or [M]FLD1="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD3(VALEUR)
Variable Char    VALEUR()
Call AS_TBL3([M]TBL3)
If [M]TBL3= "" or [M]FLD2="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD4(VALEUR)
Variable Char    VALEUR()
Call AS_TBL4([M]TBL4)
If [M]TBL4= "" or [M]FLD3="" : mkstat = 1 : End : Endif
End

Subprog AS_FLD5(VALEUR)
Variable Char    VALEUR()
Call AS_TBL5([M]TBL5)
If [M]TBL5= "" or [M]FLD4="" : mkstat = 1 : End : Endif
End

########################################

Subprog AS_DES1(VALEUR)
Variable Char    VALEUR()
Call AS_TBL1([M]TBL1)
If [M]TBL1="" : mkstat = 1 : End : Endif
End

Subprog AS_DES2(VALEUR)
Variable Char    VALEUR()
Call AS_TBL2([M]TBL2)
If [M]TBL2= "" or [M]FLD1="" : mkstat = 1 : End : Endif
End

Subprog AS_DES3(VALEUR)
Variable Char    VALEUR()
Call AS_TBL3([M]TBL3)
If [M]TBL3= "" or [M]FLD2="" : mkstat = 1 : End : Endif
End

Subprog AS_DES4(VALEUR)
Variable Char    VALEUR()
Call AS_TBL4([M]TBL4)
If [M]TBL4= "" or [M]FLD3="" : mkstat = 1 : End : Endif
End

Subprog AS_DES5(VALEUR)
Variable Char    VALEUR()
Call AS_TBL5([M]TBL5)
If [M]TBL5= "" or [M]FLD4="" : mkstat = 1 : End : Endif
End


########################################
Subprog C_TBL1(VALEUR)
Variable Char    VALEUR()
Goto C_TBL

Subprog C_TBL2(VALEUR)
Variable Char    VALEUR()
Goto C_TBL

Subprog C_TBL3(VALEUR)
Variable Char    VALEUR()
Goto C_TBL

Subprog C_TBL4(VALEUR)
Variable Char    VALEUR()
Goto C_TBL

Subprog C_TBL5(VALEUR)
Variable Char    VALEUR()
Goto C_TBL

$C_TBL
If VALEUR<>"" & !find(VALEUR,[M]ATB,[M]TBTBL(1..[M]NBTBL))
 GMESSAGE = mess(5,124,1) : mkstat = 2 : End : # Table non accessible
Endif
End

##############################################################
Subprog C_FLD1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
Goto C_FLD

Subprog C_FLD2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
Goto C_FLD

Subprog C_FLD3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
Goto C_FLD

Subprog C_FLD4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
Goto C_FLD

Subprog C_FLD5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
Goto C_FLD

##############################################################
Subprog AM_FLD1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
Goto M_FLD

Subprog AM_FLD2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
Goto M_FLD

Subprog AM_FLD3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
Goto M_FLD

Subprog AM_FLD4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
Goto M_FLD

Subprog AM_FLD5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
Goto M_FLD

##############################################################
$C_FLD
End

$M_FLD
If VALEUR = ""
 Case I
  When 1 : Effzo DES1
  When 2 : Effzo DES2
  When 3 : Effzo DES3
  When 4 : Effzo DES4
  When 5 : Effzo DES5
 Endcase
 End
Endif
VALEUR = toupper(VALEUR)
Local Integer K , DIME , DIMMAX , OKAXX
Local Char    ZONE(20),WTBL(GLONATB),WFLD(GLONAVA),WTBL1(GLONATB),WFLD1(GLONAVA)
Local Integer NBTBL2, CHOI,OKDIM
Local Char    TEX(GLONDES)(1..GDIMSIT+GDIMSOC,1..3) , TIT(GLONDES)(0..3) , WTBLABR(GLONABR)
K = instr(1,VALEUR,"(")
If K
 DIME = val(right$(VALEUR,K+1))
 ZONE   = left$(VALEUR,K-1)
 OKDIM = 1
Else
 DIME = 0
 ZONE = VALEUR
Endif
Local Integer OKCOD,OKCODFLD
Link [ATZ] With
& [ATX]NUMERO=GLANGUE;NOCOURT,
& [ACV]CODACT=[F:ATZ]CODACT,
& [ATY]CODTYP=[F:ATZ]CODTYP
& As [ATZ_]
Filter [ATZ_] Where (find(CODFIC,[M]TBTBL(1..[M]NBTBL))<>0 or CODFIC=[M]ATB) & CODFIC <> "ATEXTRA"
&                   & [F:ATY]TYPTYP<9 & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)
&                   & (find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & DIME=1 or find(CODTYP,"AXX","AX1","AX2","AX3")=0)
&                   & pat([F:ATZ]CODZONE,"*"+toupper(ctrans(ZONE))+"*")<>0
For [ATZ_]
 OKCOD += 1
 WTBL = [F:ATZ]CODFIC
 WFLD = [F:ATZ]CODZONE
 If VALEUR=[F:ATZ]CODZONE or (ZONE=[F:ATZ]CODZONE & OKDIM & [L]DIME<[F:ATZ]DIME)
  OKCODFLD +=1
  WTBL1 = [F:ATZ]CODFIC
  WFLD1 = [F:ATZ]CODZONE
 Endif
Next
Filter [ATZ_]
If !OKCOD
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
If OKCOD>1 & OKCODFLD<>1
 WFLD = ""
 Gosub SELFLD
Endif
If OKCODFLD=1
 WFLD = WFLD1
 WTBL = WTBL1
Endif
Read [ATZ]CODZONE =WTBL;WFLD
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat & [F:ATY]TYPTYP>8
 GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : End
Endif
If [M]OBJ<>"" & find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3")
 OKAXX = 0
 For [F:AOT] Where ABREV = [M]OBJ& TABFIC ="ATEXTRA"
  If instr(1,[F:AOT]TABLIEN,evalue("[M]TBL"+num$(I))) & instr(1,[F:AOT]TABLIEN,WFLD)
   OKAXX =1
   Break
  Endif
 Next AOT
 If !OKAXX
  GMESSAGE = mess(7,124,1) : # Liens impossibles
  mkstat = 2 : End
 Endif
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = WFLD
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
Case I
 When 1 : TBL1=[F:ATZ]CODFIC : Call TEXTE([F:ATZ]NOCOURT,[M]DES1) From OBJDIV : Affzo DES1
 When 2 : TBL2=[F:ATZ]CODFIC : Call TEXTE([F:ATZ]NOCOURT,[M]DES2) From OBJDIV : Affzo DES2
 When 3 : TBL3=[F:ATZ]CODFIC : Call TEXTE([F:ATZ]NOCOURT,[M]DES3) From OBJDIV : Affzo DES3
 When 4 : TBL4=[F:ATZ]CODFIC : Call TEXTE([F:ATZ]NOCOURT,[M]DES4) From OBJDIV : Affzo DES4
 When 5 : TBL5=[F:ATZ]CODFIC : Call TEXTE([F:ATZ]NOCOURT,[M]DES5) From OBJDIV : Affzo DES5
Endcase
Gosub CHOIX_TABLE
End

$C_DES
Local Integer OK
OK =1
Case I
 When 1 : If FLD1<> "" & VALEUR ="" : OK=0 : Endif
 When 2 : If FLD2<> "" & VALEUR ="" : OK=0 : Endif
 When 3 : If FLD3<> "" & VALEUR ="" : OK=0 : Endif
 When 4 : If FLD4<> "" & VALEUR ="" : OK=0 : Endif
 When 5 : If FLD5<> "" & VALEUR ="" : OK=0 : Endif
Endcase
If !OK
 Read [ATZ]CODZONE = TBL1;FLD1
 If func AFNC.TEXTE([F:ATZ]NOCOURT)<> ""
  GMESSAGE = mess(10,123,1) : # Zone obligatoire
  mkstat = 2
 Endif
Endif
End

$CHOIX_TABLE
## Si plusieurs table avec des abréviation differentes.
Raz NBTBL2,WTBLABR
For [AOT] Where ABREV= [M]OBJ & TABFIC= [F:ATZ]CODFIC
 NBTBL2 += 1
 TEX(NBTBL2,1) = [F:AOT]TABABR
 TEX(NBTBL2,2) = [F:AOT]TABFIC
 TEX(NBTBL2,3) = [F:AOT]TABLIEN
Next
If NBTBL2
 If NBTBL2=1 & ([F:ATB]CODFIC = TEX(NBTBL2,1) or TEX(NBTBL2,1)="")
  End
 Else
  CHOI = 0
  TIT(0) = mess(91,126,1)  : # Choix d'une table liée
  TIT(1) = mess(1,16,1)    : # Abréviation
  TIT(2) = mess(161,126,1) : # La table liée
  TIT(3) = mess(268,142,1) : # Expression de lien
  Call SAITEX_COL_MAX(NBTBL2,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   WTBLABR = TEX(CHOI,1)
  Endif
 Endif
Endif
Case I
 When 1 : [M]ABR1 = WTBLABR
 When 2 : [M]ABR2 = WTBLABR
 When 3 : [M]ABR3 = WTBLABR
 When 4 : [M]ABR4 = WTBLABR
 When 5 : [M]ABR5 = WTBLABR
Endcase
Return

$M_DES
If VALEUR=""
 If [M]NBTBL<>0
  Case I
   When 1 : [M]TBL1 = ""  : [M]FLD1 = "" : Affzo TBL1,FLD1
   When 2 : [M]TBL2 = ""  : [M]FLD2 = "" : Affzo TBL2,FLD2
   When 3 : [M]TBL3 = ""  : [M]FLD3 = "" : Affzo TBL3,FLD3
   When 4 : [M]TBL4 = ""  : [M]FLD4 = "" : Affzo TBL4,FLD4
   When 5 : [M]TBL5 = ""  : [M]FLD5 = "" : Affzo TBL5,FLD5
  Endcase
 Endif
 End
Endif
Local Integer OKDES,OKDESCOD,OKAXX
Local Char    WTBL(GLONATB),WFLD(GLONAVA),WTEXTE(250)
Local Integer NBTBL2, CHOI
Local Char    TEX(GLONDES)(1..GDIMSIT+GDIMSOC,1..3) , TIT(GLONDES)(0..3) , WTBLABR(GLONABR)
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Link [ATZ] With
& [ATX]NUMERO=GLANGUE;NOCOURT,
& [ACV]CODACT=[F:ATZ]CODACT,
& [ATY]CODTYP=[F:ATZ]CODTYP
& As [ATZ_]
Filter [ATZ_] Where ((find(CODFIC,[M]TBTBL(1..[M]NBTBL))<>0) or CODFIC=[M]ATB) & CODFIC <> "ATEXTRA"
&                   & [F:ATY]TYPTYP<9 & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)
&                   & (find(CODTYP,"AXX","AX1","AX2","AX3")<>0 & DIME=1 or find(CODTYP,"AXX","AX1","AX2","AX3")=0)
For [ATZ_]
 # If func AFNC.TEXTE([F:ATZ]NOCOURT) = VALEUR
  If pat(toupper(ctrans([F:ATX]TEXTE)),"*"+toupper(ctrans(VALEUR))+"*")
  OKDES +=1
  WTBL   = [F:ATZ]CODFIC
  WFLD   = [F:ATZ]CODZONE
  WTEXTE = [F:ATX]TEXTE
  If [F:ATZ]CODZONE = evalue("[M]FLD"+num$(I))
   OKDESCOD +=1
  Endif
 Endif
Next
Filter [ATZ_]
If  OKDESCOD=1 : End : Endif
If OKDES>1
 Gosub SELDES
Endif
If WFLD<>"" & WTBL<>"" & WTEXTE<>""
 Case I
   When 1 : [M]TBL1 = WTBL  : [M]FLD1 = WFLD  : Affzo TBL1,FLD1
   When 2 : [M]TBL2 = WTBL  : [M]FLD2 = WFLD  : Affzo TBL2,FLD2
   When 3 : [M]TBL3 = WTBL  : [M]FLD3 = WFLD  : Affzo TBL3,FLD3
   When 4 : [M]TBL4 = WTBL  : [M]FLD4 = WFLD  : Affzo TBL4,FLD4
   When 5 : [M]TBL5 = WTBL  : [M]FLD5 = WFLD  : Affzo TBL5,FLD5
 Endcase
 VALEUR  = WTEXTE
 Gosub CHOIX_TABLE
Else
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
End

$SELDES
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELINTTAB3"
PARMSK(1) = [M]TBL1
PARMSK(2) = "2"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELINTTAB3","ASELOBJ","") From GACTION
WFLD    = [F:ATZ]CODZONE
WTEXTE  = func AFNC.TEXTE([F:ATZ]NOCOURT)
WTBL    = [F:ATZ]CODFIC
GACTION = SAVACT
Return

$SELFLD
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELFLDTAB5"
PARMSK(1) = WTBL
PARMSK(2) = "2"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELFLDTAB5","ASELOBJ","") From GACTION
WFLD = VALEUR
WTBL = PARMSK(1)
GACTION = SAVACT
Return


