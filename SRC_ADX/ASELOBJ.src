$C_VAL
Local Char TYP(GLONATY)
Case I
 When 1 : TYP = [M]FMT1
 When 2 : TYP = [M]FMT2
 When 3 : TYP = [M]FMT3
 When 4 : TYP = [M]FMT4
 When 5 : TYP = [M]FMT5
Endcase

Call LECTURE("ATY",TYP,"") From CONTOBJ
If [F:ATY]TYPTYP>1 & [F:ATY]TYPTYP<7 & VALEUR=""
 GMESSAGE = mess(10,123,1) : mkstat = 2 : End
# Zone obligatoire
Endif
If instr(1,VALEUR,'"')
 GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 : End
#  Caractère interdit
Endif
If left$([F:ATY]FORTYP,2)="=G" & [F:ATY]TYPTYP=7 & [M]SAVGFOR<>""
 Read [AGB]AGB0 = right$([F:ATY]FORTYP,2)
 If !fstat
  Assign right$([F:ATY]FORTYP,2) With [M]SAVGFOR(I-1)
  Assign "[M]SAVGFOR" With ""
 Endif
Endif
End

