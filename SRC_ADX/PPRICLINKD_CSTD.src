#Return

#-------------------------------------------------------
#--Method used to load properties from class PPRICLINKD to [F:PPK]
$LOAD_TO_PPK_FILE
Local Integer IJ

  If dim([F:PPK]CPY)<1
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class PPRICLINKD : Method call LOAD_TO_PPK_FILE no [F:PPK] file opened", [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  SetInstance [F:PPK] With this
  #--Parcours des collections
  #--TSICOD
  For IJ=1 To maxtab(this.C_TSICOD)
    If dim([F:PPK]TSICOD(IJ-1))<1 : Break : Endif

    [F:PPK]TSICOD(IJ-1) = "" # AVOID.ACHAR

    If this.C_TSICOD(IJ)<>null
      [F:PPK]TSICOD(IJ-1) = this.C_TSICOD(IJ).TSICOD
    Endif

  Next IJ
#  #----DIE et CCE
#  For IJ=1 To maxtab(this.C_DIE)
#    If dim([F:SPK]DIE(IJ-1))<1 : Break : Endif
#
#    [F:SPK]DIE(IJ-1) = AVOID.ACHAR
#    [F:SPK]CCE(IJ-1) = AVOID.ACHAR
#
#    If this.C_DIE(IJ)<>null
#      [F:SPK]DIE(IJ-1) = this.C_DIE(IJ).DIE
#      [F:SPK]CCE(IJ-1) = this.C_DIE(IJ).CCE
#    Endif
#
#  Next IJ

Return

