#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
#
# V11 : Disable GESDKK and GESDKJ functions
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Disable  functions GESDKK and GESDKJ") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub DISABLE_FUNCTIONS
End

#----------------------------------------------------------------------------------------#

$DISABLE_FUNCTIONS

If DOSSIER=nomap
 Local File AFONCTION [AFC]
Else
 Local File =DOSSIER+".AFONCTION" [AFC]
Endif

Trbegin [AFC]

Local Char FONC(GLONAFC)
For FONC= "GESDKK", "GESDKJ"
 Read [F:AFC]CODINT = FONC
 If !fstat
  [F:AFC]CODACT="FAL"
  Rewrite [F:AFC]
  If fstat
   Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
  Endif
 Endif
Next

Commit

Close Local File [AFC]

Call PATCH(DOSSIER) From VALMENU

Return

