##########################################################################################################
#   Programmes utilitaires pour la gestion des transactions du parc client        Module CRM   6/01/2004
#
##########################################################################################################
# LOADBROWSERS  :Charge le tableau des browsers
# LOADDATA : traitement lors du chargement des données
# ONGLETS_INIT :  Traitement de gestion des onglets en initialisation
# ONGLETS_ENREG : Traitement de gestion des onglets en enregistrement
# ONGLETS_READ : Traitement de gestion des onglets lors de la lecture
# ONGLETS :  Traitement de gestion des onglets
# BLOCS_INIT :  Traitement de gestion des blocs en initialisation
# BLOCS_ENREG : Traitement de gestion des blocs en enregistrement
# BLOCS_READ : Traitement de gestion des blocs lors de la lecture
# BLOCS:  Traitement de gestion des blocs
# COLFIX_INIT :  Traitement de gestion des colonnes fixes en initialisation
# COLFIX_ENREG : Traitement de gestion des colonnes fixes lors de l'enregistrement
# COLFIX_READ : Traitement de gestion des colonnes fixes lors de la lecture
# COLFIX : Traitement de gestion des colonnes fixes
# CHAMPS_INIT : Traitement de gestion des champs en initialisation
# CHAMPS_ENREG : Traitement de gestion des champs lors de l'enregistrement
# CHAMPS_READ : Traitement de gestion des champs lors de la lecture
# CHAMPS : Traitement de gestion des champs
##########################################################################################################
##########################################################################################################
# Charge le tableau des browsers
##################################
$LOADBROWSERS
Local Integer ITERCMA3

  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  Raz [M:CMA3]NBLIG
  For ITERCMA3 = 0 To dim([M:CMA3]OBJLIS)-1
    If [M:CMA3]OBJLIS(ITERCMA3) = "" Then
      Break
    Endif
    [M:CMA3]NBLIG += 1
  Next
  For ITERCMA3 = 0 To [M:CMA3]NBLIG-1
    If [M:CMA3]OBJLIS(ITERCMA3) <> "" Then
      Read [AOB]ABREV=[M:CMA3]OBJLIS(ITERCMA3)
      If fstat Then
        [M:CMA3]OBJLISCLA(ITERCMA3) = ""
      Else
        Call TEXTE([F:AOB]LIBEL, [M:CMA3]OBJLISCLA(ITERCMA3)) From OBJDIV
      Endif
    Endif
  Next
Return

##########################################################################################################
#traitement lors du chargement des données
$LOADDATA
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZLIBELLE (50)

  Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
  If fstat <> 0 Then
    Raz [F:HTV]
  Endif
  Gosub LOADBROWSERS From SUBCMAB
  Gosub ONGLETS_READ From SUBCMAB
  Gosub BLOCS_READ From SUBCMAB
  Gosub COLFIX_READ From SUBCMAB
  Gosub CHAMPS_READ From SUBCMAB
  Gosub PE_HDKTRS From SUBHDKTRS
Return

##########################################################################################################
# Traitement de gestion des onglets en initialisation
$ONGLETS_INIT
Local Char SZTYP_ACTION

  SZTYP_ACTION = "INIT"
  Gosub ONGLETS
Return

