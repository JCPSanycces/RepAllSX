##########################################################################################################
# Traitement de gestion des colonnes fixes
$COLFIX
Local Integer ITROUVE
Local Integer INBTABLEAU
Local Char SZREFERENCE

  Raz SZREFERENCE
  INBTABLEAU = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]COLFIXNAM
    Raz [F:HTR]COLFIXVAL
    INBTABLEAU = 0
  Endif
  #MAC2 Contrats de service
  #Couvertures
  SZREFERENCE = "[MAC2]NBCON"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA1]COLFIXCON = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]COLFIXCON <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMA1]COLFIXCON
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMA1]COLFIXCON = 0
    Else
      [M:CMA1]COLFIXCON = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #MAC2  demandes de garanties
  SZREFERENCE = "[MAC2]NBWRE"
  If ACTION = "INIT" Then
    [M:CMA1]COLFIXWRE = 0
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]COLFIXWRE <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMA1]COLFIXWRE
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMA1]COLFIXWRE = 0
    Else
      [M:CMA1]COLFIXWRE = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  #MAC4  Implantations
  SZREFERENCE = "[MAC4]NBLIG"
  If ACTION = "INIT" Then
    [M:CMA1]COLFIXIMP = 0
  Endif
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]COLFIXIMP <> 0 Then
      [F:HTR]COLFIXNAM(INBTABLEAU) = SZREFERENCE
      [F:HTR]COLFIXVAL(INBTABLEAU) = [M:CMA1]COLFIXIMP
      INBTABLEAU += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]COLFIXNAM)
    If ITROUVE = 0 Then
      [M:CMA1]COLFIXIMP = 0
    Else
      [M:CMA1]COLFIXIMP = [F:HTR]COLFIXVAL(ITROUVE-1)
    Endif
  Endif
  # --------------------------
  Gosub PE_CMACOLFIX From TRTCRMPE # FGR 18/07/2012 : X3SUIVI82638
Return

