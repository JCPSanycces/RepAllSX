Return

##########################################################################################################
# Traitement de gestion des onglets lors de la lecture
$ONGLETS_READ
Local Char SZTYP_ACTION

  SZTYP_ACTION = "READ"
  Gosub ONGLETS
Return

##########################################################################################################
# Traitement de gestion des onglets
$ONGLETS
Local Integer INBONGLET
Local Integer ITROUVE
Local Char SZREFERENCE
Local Integer ITROUVE

  INBONGLET = 0
  ITROUVE = 0
  Raz SZREFERENCE
  #If SZTYP_ACTION = "INIT" Then
  If SZTYP_ACTION = "INIT" or SZTYP_ACTION = "ENREG" Then
    # FGR 13/10/2009 : X3SUIVI57386 faut le réinitialiser avant parce que sinon on modif les valeurs qui y sont ne sont pas ecrasées
    Raz [F:HTR]ONGINVISI
    INBONGLET = 0
  Endif
  SZREFERENCE="MAC2"
  If SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]MACCONFLG <> 2 and [M:CMA1]FLYWARFLG <> 2 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Endif
  SZREFERENCE = "MAC3"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA1]FCYITNFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]FCYITNFLG <> 2
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE= find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMA1]FCYITNFLG = 2
    Else
      [M:CMA1]FCYITNFLG = 1
    Endif
  Endif
  SZREFERENCE = "MAC4"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA1]MAIFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]MAIFLG <> 2 Then
      [F:HTR]ONGINVISI(INBONGLET) = SZREFERENCE
      INBONGLET += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]ONGINVISI)
    If ITROUVE = 0 Then
      [M:CMA1]MAIFLG = 2
    Else
      [M:CMA1]MAIFLG = 1
    Endif
  Endif
  # --------------------------
  Gosub PE_CMAONGLET From TRTCRMPE # FGR 18/07/2012 : X3SUIVI82638
Return

