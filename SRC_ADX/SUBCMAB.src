##########################################################################################################
# Traitement de gestion des blocs
$BLOCS
Local Integer INBBLOCINVI

  INBBLOCINVI = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTR]BLOCINVI
  Endif
  #Couvertures appliquées
  SZREFERENCE = "[MAC2]10"  # FGR 27/08/2012 : X3SUIVI83815 10, pas 5
  If SZTYP_ACTION = "INIT" Then
    [M:CMA1]MACCONFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]MACCONFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMA1]MACCONFLG = 2
    Else
      [M:CMA1]MACCONFLG = 1
    Endif
  Endif
  #Demandes de garantie
  SZREFERENCE = "[MAC2]15"  # FGR 27/08/2012 : X3SUIVI83815 15, pas 10
  If SZTYP_ACTION = "INIT" Then
    [M:CMA1]FLYWARFLG = 2
  Elsif SZTYP_ACTION = "ENREG" Then
    If [M:CMA1]FLYWARFLG <> 2 Then
      [F:HTR]BLOCINVI(INBBLOCINVI) = SZREFERENCE
      INBBLOCINVI += 1
    Endif
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTR]BLOCINVI)
    If ITROUVE = 0 Then
      [M:CMA1]FLYWARFLG = 2
    Else
      [M:CMA1]FLYWARFLG = 1
    Endif
  Endif
  # --------------------------
  Gosub PE_CMABLOCS From TRTCRMPE # FGR 18/07/2012 : X3SUIVI82638
Return

