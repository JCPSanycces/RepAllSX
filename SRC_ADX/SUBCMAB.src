##########################################################################################################
# Traitement de gestion des champs
$CHAMPS
Local Integer INBFIENAM
Local Char SZTEXTE (100)
Local Char SZCHAMPS (50)
Local Integer ITROUVE
Local Integer IVISIBLE
Local Integer IPOSITION
Local Integer IMODE
Local Integer ISAISIE
Local Integer IAFFICHE

  INBFIENAM = 0
  If SZTYP_ACTION = "ENREG" Then
    Raz [F:HTV]FIENAM
    Raz [F:HTV]FIEVAL
  Endif
  #[MAC1]
  #---------------------------------------------------#
  #[MAC1]MACBRA
  #---------------------#
  # Marque
  SZREFERENCE = "[MAC1]MACBRA"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]BRACOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]BRACOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]BRACOD = 1
    Else
      [M:CMA2]BRACOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACITSDAT
  #---------------------#
  # Date mise en service
  SZREFERENCE = "[MAC1]MACITSDAT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]ITSDATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]ITSDATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]ITSDATCOD = 1
    Else
      [M:CMA2]ITSDATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACITNDAT
  #---------------------#
  # Date d'installation
  SZREFERENCE = "[MAC1]MACITNDAT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]ITNDATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]ITNDATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]ITNDATCOD = 1
    Else
      [M:CMA2]ITNDATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACBPCPRI
  #---------------------#
  # Prix d'achat
  SZREFERENCE = "[MAC1]MACBPCPRI"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]BPCPRICOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]BPCPRICOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]BPCPRICOD = 1
    Else
      [M:CMA2]BPCPRICOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACBPCCUR
  #---------------------#
  # Devise d'achat
  SZREFERENCE = "[MAC1]MACBPCCUR"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]BPCCURCOD = 1
  Endif
  If SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]BPCPRICOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]BPCCURCOD = 1
    Else
      [M:CMA2]BPCCURCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACBPCDAT
  #---------------------#
  # Date d'achat
  SZREFERENCE = "[MAC1]MACBPCDAT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]BPCDATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]BPCDATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]BPCDATCOD = 1
    Else
      [M:CMA2]BPCDATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACSALPRI
  #---------------------#
  # Prix de vente
  SZREFERENCE = "[MAC1]MACSALPRI"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]SALPRICOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]SALPRICOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]SALPRICOD = 1
    Else
      [M:CMA2]SALPRICOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]CUR
  #---------------------#
  # Devise de vente
  SZREFERENCE = "[MAC1]CUR"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]CURCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]CURCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]CURCOD = 1
    Else
      [M:CMA2]CURCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  #[MAC1]MACPURDAT
  #---------------------#
  # Date de vente
  SZREFERENCE = "[MAC1]MACPURDAT"
  If SZTYP_ACTION = "INIT" Then
    [M:CMA2]PURDATCOD = 1
  Elsif SZTYP_ACTION = "ENREG" Then
    [F:HTV]FIENAM(INBFIENAM) = SZREFERENCE
    [F:HTV]FIEVAL(INBFIENAM) = num$([M:CMA2]PURDATCOD)
    INBFIENAM += 1
  Elsif SZTYP_ACTION = "READ" Then
    ITROUVE = find(SZREFERENCE, [F:HTV]FIENAM)
    If ITROUVE = 0 Then
      [M:CMA2]PURDATCOD = 1
    Else
      [M:CMA2]PURDATCOD = val([F:HTV]FIEVAL(ITROUVE-1))
    Endif
  Endif
  # --------------------------
  Gosub PE_CMACHAMPS From TRTCRMPE # FGR 18/07/2012 : X3SUIVI82638
Return
