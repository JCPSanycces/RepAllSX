#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "CHX_TABLE"    : Gosub CHX_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
Endcase
Return


$SEL_TABLE
Case TABLE
 When "EXPRUB"
  If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
  OBJET = "RUB"
  START = "[F:RUB]COD"
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:RUB]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
  Endif
  adxmxl = 1000
 When "EXPVRA"
  If clalev([F:VRA])=0 : Local File VARIA [VRA] : Endif
  OBJET = "VRA"
  START = "[F:VRA]COD"
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:VRA]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
  Endif
  adxmxl = 1000
 When "EXPCUM"
  If clalev ([F:CUM])=0 : Local File CUMUL [CUM] : Endif
  OBJET="CUM"
  START = "[F:CUM]CUMCOD"
  If PARAM(1)<>""
   Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'[F:CUM]LEG="'+PARAM(1)+'"',"&") From GOBJSUB
  Endif
  adxmxl = 1000
 When "EXPSAL"
  Local File ATABLE [ATB] , DICOEMP [DIC]
  OBJET = "DIC"
 When "EXPFORVAR"
  If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
  OBJET = "ADI"
  adxmxl = 1000
 When "EXPMSR"
  If clalev([F:MSR])=0 : Local File MSRUB [MSR] : Endif
  OBJET = "MSR"
  adxmxl = 1000
Endcase
Return

$CHX_TABLE
START = ""
EXPSTART = "1"
If TABLE="EXPFORVAR"
 CRITOBJ = "NUMTAB=10606"
Else
 CRITOBJ = "1=1"
Endif
CRITCAR = "1=1"
Return

$FIN_TABLE
If status<>7
 Case TABLE
  When "EXPRUB"
   If GFONCTION="GESSMH" #override for employee generator
     VALEUR = [F:RUB_]COD
   Else
     VALEUR += "R_"+[F:RUB_]COD
   Endif
  When "EXPVRA"
   If GFONCTION="GESSMH" #override for employee generator
     VALEUR = [F:VRA]COD
   Else
     VALEUR += "V_"+[F:VRA]COD
   Endif
  When "EXPCUM"
   # 31087
   # VALEUR += "C_"+[F:CUM]CUMCOD
   If GFONCTION="GESCUM"
    VALEUR += "C_"+[F:CUM_]CUMCOD
   Elsif GFONCTION="GESSMH" #override for employee generator
    VALEUR = [F:CUM_]CUMCOD
   Else
    VALEUR += "C_"+[F:CUM]CUMCOD
   Endif
  When "EXPSAL"
   If PARAM(1)="A"
    Read [ATB]CODFIC = [F:DIC]TBL
    VALEUR += "[F:"+[F:ATB]ABRFIC+"]"+[F:DIC]FLD
   Else
    VALEUR += "[F]"+[F:DIC]FLD
   Endif
  When "EXPFORVAR"
   VALEUR += "E_"+[F:ADI_]CODE
  When "EXPMSR"
   If GFONCTION="GESMSR"
    VALEUR += "R_"+[F:MSR_]COD
   Else
    VALEUR += "R_"+[F:MSR]COD
   Endif
  Endcase
Endif
Return
