$ON_SYSFLG
Onevent INIT_AREA Call D_SYSFLG(zc) From W1CTR2
Onevent BEFORE_INPUT Call AS_SYSFLG(zc) From W1CTR2
Return

Subprog D_SYSFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]SYSFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SYSFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_SYSVIS
Onevent INIT_AREA Call D_SYSVIS(zc) From W1CTR2
Return

Subprog D_SYSVIS(VALEUR)
Variable Char    VALEUR()
If varinit([M]SYSVIS,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10355","") From SUBADI
Endif
Gosub _AFF
End

$ON_SEVEMP
Onevent AFTER_CHANGE Gosub AMM_SEVEMP From W1CTR2
Onevent INIT_AREA Call D_SEVEMP(zc) From W1CTR2
Onevent BEFORE_INPUT Call AS_SEVEMP(zc) From W1CTR2
Return

Subprog D_SEVEMP(VALEUR)
Variable Integer VALEUR
If varinit([M]SEVEMP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEVEMP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_SEVEMP
Call AM_SEVEMP(zc)
If !mkstat & GOBJET
 zoncou = "SEVEMP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_SEVEMP(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_SEVEMP(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "SEVEMP" : GZNUM = 47310 : Endif
Gosub _AFF
End

$CHG_STY
Gosub CHG_STY From W2CTR2
Return

$TIT_COL
Gosub TIT_COL From W2CTR2
Return


