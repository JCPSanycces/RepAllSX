#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:42"
A_USER  = "DOC"
A_STAMP = "20181109230342"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR2 [CTR2]
Gosub HORODAT
Local Inpbox "CTR2" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR2] As [SIM_]
Grizo [CTR2]5
Grizo [CTR2]10
Grizo [CTR2]15
Grizo [CTR2]25
Grizo [CTR2]20
Grizo [CTR2]30
Grizo [CTR2]35
Grizo [CTR2]40
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=104 : Y1(0)=1 : Y2(0)=14
X1(1)=105 : X2(1)=148 : Y1(1)=1 : Y2(1)=9
X1(2)=105 : X2(2)=148 : Y1(2)=10 : Y2(2)=14
X1(3)=105 : X2(3)=148 : Y1(3)=15 : Y2(3)=17
X1(4)=1 : X2(4)=104 : Y1(4)=15 : Y2(4)=24
X1(5)=105 : X2(5)=148 : Y1(5)=18 : Y2(5)=22
X1(6)=105 : X2(6)=148 : Y1(6)=23 : Y2(6)=24
X1(7)=1 : X2(7)=104 : Y1(7)=25 : Y2(7)=26
Return

$ON_CATCSP
Onevent BEFORE_INPUT Call AS_CATCSP(zc) From W1CTR2
Onevent CONTROL Call C_CATCSP(zc) From W1CTR2
Onevent AFTER_CHANGE Gosub AMM_CATCSP From W1CTR2
Return

Subprog AS_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44777,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCSP
Call DEFHRCSP(VALEUR,GCURLEG,GSOCIETE) From SUBHRCSP
If mkstat=2
 [M]CATCSP(INDIC) = VALEUR
 Affzo CATCSP(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CATCSP(zc) From W1CTR2
Onkey   2 Titled GBOUTS Call S_CATCSP(zc) From W1CTR2
Onkey 144 Titled GBOUTP Call P_CATCSP(zc) From W1CTR2
Onkey 146 Titled GBOUTA Call SA_CATCSP(zc) From W1CTR2
Gosub _AFF
End

Subprog C_CATCSP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
If !mkstat
 ## Action CONTHRCSP
 Call CONTHRCSP(VALEUR,GCURLEG,GSOCIETE) From SUBHRCSP
 If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CATCSP
Call AM_CATCSP(zc)
If !mkstat & GOBJET
 zoncou = "CATCSP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CATCSP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CATCSP(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "CATCSP" : GZNUM = 44777 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCATCSP)")>indice
 [M]CATCSP(indice) = VALEUR
 Affzo ZCATCSP(indice)
Endif
Gosub _AFF
End

Subprog S_CATCSP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCSP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCSP"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCSP","SUBHRCSP","SPEHRCSP") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CATCSP(VALEUR)
Variable Char    VALEUR()
Call OBJET("HRCSP",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRCSP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CATCSP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRCSP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCATCSP
Onevent BEFORE_AREA Gosub AV_ZCATCSP From W1CTR2
Return

$AV_ZCATCSP
Call LECTEXTRA(zc,"HRCATCSP","DESAXX",num$([M]CATCSP(indice)),"") From ATEXTRA
Gosub _AFF
Return

