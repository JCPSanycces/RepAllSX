#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion objet MFA
Raz GPILOBJ
Call OBJET("MFA",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Etiquette ajoutée par le superviseur (Objet MFA) 20/05/2009 17:35:41 (LS)
######################################################################################
$ACTION
Case ACTION
 When "APRES_CRE" : Call GENTRT(nomap,[M]BUD1,GOK)
 When "APRES_MOD" : Call GENTRT(nomap,[M]BUD1,GOK)
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return

#To manage legislation code
$OUVRE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  GCURLEG = 'FRA' #Total Payroll is FRA only
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
######################################################################################
Subprog GENTRT(APPLI,COD,OK)
Value    Char    APPLI
Value    Char    COD
Variable Integer OK

Local Char    SAVIFS(5) , SAVIRS(5) , TETADO(50)
Local Char    PROG(10) , FICSRC(250)
Local Integer I, OK

#58420
If clalev([F:MFA_])=0  : Local File =APPLI+".MSFLDATM"    [MFA_]  : Endif

SAVIFS = adxifs
SAVIRS = adxirs
adxifs = ""
adxirs = chr$(10)

TETADO = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
#58420
#PROG = "WPMS0"+[M:MFA1]BUD1
PROG = "WPMS0"+COD
FICSRC = filpath("TRT",PROG,"src",APPLI)
Openo FICSRC , 0
Wrseq TETADO-mess(15,10722,1) : # Avant toute mesure
Wrseq "$LECTURE"
For [MFA_] Where BUD1=[L]COD
 Wrseq "[F]"+[F:MFA_]FLD+"="+[F:MFA_]FLDAFR
Next
Wrseq "Return"
Openo
Call VALID("TRT",PROG,APPLI,OK) From VALMSKSUB

adxirs = SAVIRS
adxifs = SAVIFS

End

######################################################################################
Subprog GENDOS(APPLI)
Value Char    APPLI
Local Integer OK

If clalev([F:HRMFA])=0  : Local File =APPLI+".MSFLDATM"    [HRMFA]  : Endif

For [HRMFA]MFA0(1)
 If GTRACE<>"" : Call ECR_TRACE([F:HRMFA]BUD1,0) From GESECRAN : Endif
 Call GENTRT(APPLI,[F:HRMFA]BUD1,OK)
 If OK=0 : Break : Endif
Next

End

######################################################################################

$TRTCOP
If [M]DOSORG=nomap
 Local File MSFLDATM    [MFA1]
Else
 Local File =[M]DOSORG+".MSFLDATM"    [MFA1]
Endif
If [M]DOSDES=nomap
 Local File MSFLDATM    [MFA2]
 Local File ATABDIV     [ADI2]
Else
 Local File =[M]DOSDES+".MSFLDATM"    [MFA2]
 Local File =[M]DOSDES+".ATABDIV"     [ADI2]
Endif
Read [ADI2]CODE=10652;TABLE
If fstat
 # Code budgétaire inexistant
 GMESSAGE = TABLE-mess(18,10722,1)
 GERR = 1
 Close Local File [MFA1], [MFA2], [ADI2]
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [MFA1], [MFA2], [ADI2]
Return

$TR_COP
GOK = 1
Trbegin [MFA2]

 Delete [MFA2] Where BUD1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".MSFLDATM" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("MFA2","") From GLOCK : Goto AB_TR_COP
 Endif
# 59672
# For [MFA1] Where CODREG=TABLE
 For [MFA1] Where BUD1=TABLE
  [F:MFA2] = [F:MFA1]
  If dim([F:MFA2]UPDUSR)>0 : [F:MFA2]UPDUSR = GUSER : Endif
  If dim([F:MFA2]UPDDAT)>0 : [F:MFA2]UPDDAT = date$ : Endif
  If dim([F:MFA2]UPDTIM)>0 : [F:MFA2]UPDTIM = time : Endif
  Write [MFA2]
  If fstat
   GOK = 0 : Call FSTA("MFA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

######################################################################################
## Ecran MFA1
######################################################################################

Subprog C_FLD(VALEUR)
Variable Char    VALEUR()

If clalev([F:DIC])=0 : Local File DICOEMP [DIC] : Endif

Read [DIC]DIC0 = VALEUR
If fstat
 GMESSAGE = mess(41,100,1) : # Champ inexistant
 mkstat = 2
 End
Elsif [F:DIC]ENAFLG=1
 GMESSAGE = mess(106,10702,1) : # Champ inactif
 mkstat = 2
 End
Endif
If VALEUR<>[M]FLD(nolign-1)
 Call TEXTE([F:DIC]DES,[M]DES(nolign-1)) From OBJDIV
Endif
End
