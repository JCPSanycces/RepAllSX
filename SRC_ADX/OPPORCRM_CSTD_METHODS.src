#######################################################################################
# Classe OPPOR
#######################################################################################
# METHODS                                                                             #
#######################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  SLEVEL = func AFNC.MES1(mess(939,2260,1), this.OPPNUM)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

#######################################################################################
$COMPUTE_AMT
Local Decimal ITOOL

  this.OPPAAM = arr((this.OPPAMT * this.OPPSUC) / 100, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
  this.PBYPRJAAM = arr((this.OPPAMT * this.PBYPRJ) / 100, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
  # Calcul de la double pondération
  If this.DAMAVE = [V]CST_AYES Then
    ITOOL = (this.PBYPRJ + this.OPPSUC) / 2
    this.DAM = arr((this.OPPAMT * ITOOL) / 100, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
  Else
    ITOOL = (this.OPPAMT * this.PBYPRJ) / 100
    this.DAM = arr((ITOOL * this.OPPSUC) / 100, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
  Endif
Return

#######################################################################################
# Issue X3-96497 - 2018-06-27 by FGR : BEGIN
$CURRENT_STEP
Local Integer NI
Local Integer NE
Local Integer IEXIT
Local Integer IRET

  IEXIT = [V]CST_ANO
  # -------------------------------------
  NE = 0
  For NI = maxtab(this.STPSTA) To 1 Step -1
    If this.STPSTA(NI) <> null and find(this.STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTA(NI).STEX <> AVOID.ACHAR and this.STPSTA(NI).DONX = [V]CST_AYES Then
        If NE = 0 or this.STPSTA(NI).ENDDATX > this.STPSTA(NE).ENDDATX Then
          NE = NI
        Endif
      Endif
    Endif
  Next NI
  If NE > 0 Then
    this.STRSTE = this.STPSTA(NE).ENDDATX
    this.OPPSTEADI = 421
    this.OPPSTE = this.STPSTA(NE).STEX
    IRET = fmet this.COMPUTE_OPPSTEA2()
    IEXIT = [V]CST_AYES
  Endif
  # -------------------------------------
  If IEXIT = [V]CST_ANO Then
    For NI = maxtab(this.STPSTB) To 1 Step -1
      If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.STPSTB(NI).STE <> AVOID.ACHAR and this.STPSTB(NI).DON = [V]CST_AYES Then
          If NE = 0 or this.STPSTB(NI).ENDDAT > this.STPSTB(NE).ENDDAT Then
            NE = NI
          Endif
        Endif
      Endif
    Next NI
    If NE > 0 Then
      this.STRSTE = this.STPSTB(NE).ENDDAT
      this.OPPSTEADI = 400
      this.OPPSTE = this.STPSTB(NE).STE
      IRET = fmet this.COMPUTE_OPPSTEA2()
      IEXIT = [V]CST_AYES
    Endif
  Endif
  # -------------------------------------
  If IEXIT = [V]CST_ANO Then
    Raz this.STRSTE
    Raz this.OPPSTEADI
    Raz this.OPPSTEA2
  Endif
  # -------------------------------------
Return

