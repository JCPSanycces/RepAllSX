#######################################################################################
$COMPUTE_OPPSTEA2
  If this.OPPSTEADI = 400 Then
    Local File ATABDIV [ADI]
    Read [ADI]CODE=this.OPPSTEADI;this.OPPSTE
    If !fstat Then
      Case [F:ADI]N2
        When 5
          this.OPPSTEA2 = "WIN"
        When 6
          this.OPPSTEA2 = "LOS"
        When 7
          this.OPPSTEA2 = "FOR"
        When Default
          this.OPPSTEA2 = AVOID.ACHAR
      Endcase
    Endif
  Endif
Return

#######################################################################################
$COMPUTE_OPPREACDA
Local Integer NI

  Local File ATABDIV [ADI]
  For NI = maxtab(this.STPSTB) To 1 Step -1
    If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTB(NI).STE <> AVOID.ACHAR Then
        Read [ADI]CODE=400;this.STPSTB(NI).STE
        If !fstat Then
          If [F:ADI]N2 >= 5 and [F:ADI]N2 <= 7 Then
            this.OPPREACDA = this.STPSTB(NI).ENDDAT
            Break
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

#######################################################################################
$COUNT_PRESALE_STEP
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.STPSTB)
    If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

#######################################################################################
$INIT_FIRST_STEP
  [L]ARET_VALUE = fmet this.INIT_PRESALE_STEP()
  If fmet this.COUNT_PRESALE_STEP() = 0 Then
    [L]ARET_VALUE = fmet this.INIT_POSTSALE_STEP()
  Endif
Return

#######################################################################################
$INIT_PRESALE_STEP
Local Integer ILINE
Local Integer ICOUNT

  ICOUNT = fmet this.COUNT_PRESALE_STEP()
  If ICOUNT > 0 Then
    [L]ARET_VALUE = fmet this.SETERROR(AVOID.ACHAR, mess(1170,196,1) - "(" + num$(ICOUNT) - ")", [V]CST_AERROR)
  Else
    Local File ATABDIV [ADI]
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N2 = 2
    For [ADI]
      this.OPPSTEADI = [F:ADI]NUMTAB
      ILINE = fmet this.ADDLINE("STPSTB", [V]CST_ALASTPOS)
      # -------------------
      this.STPSTB(ILINE).STE = [F:ADI]CODE
      this.STPSTB(ILINE).DON = [F:ADI]N3
      this.STPSTB(ILINE).STRDAT = date$
      this.STPSTB(ILINE).ENDDAT = date$
      # -------------------
      this.OPPSTE = this.STPSTB(ILINE).STE
      this.STRSTE = this.STPSTB(ILINE).ENDDAT
      Break
    Next
    Filter [ADI]
  Endif
Return

#######################################################################################
$COUNT_POSTSALE_STEP
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.STPSTA)
    If this.STPSTA(NI) <> null and find(this.STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

#######################################################################################
$INIT_POSTSALE_STEP
Local Integer ILINE
Local Integer ICOUNT
Local Char SDEFAULTADI(GLONADI)

  ICOUNT = fmet this.COUNT_POSTSALE_STEP()
  If ICOUNT > 0 Then
    [L]ARET_VALUE = fmet this.SETERROR(AVOID.ACHAR, mess(1171,196,1) - "(" + num$(ICOUNT) - ")", [V]CST_AERROR)
  Else
    SDEFAULTADI = func CRMUTIL140_SYRA.DEFVALADI(421)
    If SDEFAULTADI <> AVOID.ACHAR Then
      ILINE = fmet this.ADDLINE("STPSTB", [V]CST_ALASTPOS)
      this.OPPSTEADI = 421
      Local File ATABDIV [ADI]
      Read [ADI]CODE=this.OPPSTEADI;SDEFAULTADI
      # -------------------
      this.STPSTA(ILINE).STEX = [F:ADI]CODE
      this.STPSTA(ILINE).DONX = [F:ADI]N2
      this.STPSTA(ILINE).STRDATX = date$
      this.STPSTA(ILINE).ENDDATX = date$
      # -------------------
      this.OPPSTE = this.STPSTA(ILINE).STEX
      this.STRSTE = this.STPSTA(ILINE).ENDDATX
    Endif
  Endif
Return

#######################################################################################
$STPSTA_GET_INDEX
#Value Date DENDDATX
#Value Char SSTEX ()
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.STPSTA)
    If this.STPSTA(NI) <> null and find(this.STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTA(NI).ENDDATX = DENDDATX and this.STPSTA(NI).STEX = SSTEX Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

#######################################################################################
$STPSTB_GET_INDEX
#Value Date DENDDAT
#Value Char SSTE ()
#Local Integer ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.STPSTB)
    If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTB(NI).ENDDAT = DENDDAT and this.STPSTB(NI).STE = SSTE Then
        [L]ARET_VALUE = NI
        Break
      Endif
    Endif
  Next NI
Return

