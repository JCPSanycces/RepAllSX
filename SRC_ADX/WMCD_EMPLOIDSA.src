#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDSA
# 2018-11-06 07:05:54 173


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOIDSA,ASTATUS)
Variable Instance EMPLOIDSA Using C_EMPLOIDSA
Variable Integer ASTATUS

If EMPLOIDSA = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOIDSA

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOIDSA

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOIDSA,ASTATUS)
Variable Instance EMPLOIDSA Using C_EMPLOIDSA
Variable Integer ASTATUS

If EMPLOIDSA = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDSA
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOIDSA
Else
 Gosub ADELETE_EMPLOIDSA
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOIDSA,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOIDSA.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOIDSA.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOIDSA.EMPADR)
 If EMPLOIDSA.EMPADR([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.EMPADR([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOIDSA.PASDET)
 If EMPLOIDSA.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PASDET([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOIDSA.PERCNT)
 If EMPLOIDSA.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PERCNT([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

For [L]A_I=1 To maxtab(EMPLOIDSA.EMPADR)
 If EMPLOIDSA.EMPADR([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.EMPADR([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOIDSA.PASDET)
 If EMPLOIDSA.PASDET([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PASDET([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(EMPLOIDSA.PERCNT)
 If EMPLOIDSA.PERCNT([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.PERCNT([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOIDSA
Trbegin [F:ESA]
 Gosub ADELETE_EMPLOIDSA
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOIDSA
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOIDSA,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOIDSA._MAJSQL_EMPLOIDSA(EMPLOIDSA))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDSA.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOIDSA.snapshotEnabled=1
 [L]A_RETIK = EMPLOIDSA.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOIDSA.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



