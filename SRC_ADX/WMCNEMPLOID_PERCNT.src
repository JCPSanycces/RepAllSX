# Supervisor
## ACLA-CLASSE ## EMPLOID_PERCNT
# 2018-11-06 07:05:38 599

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_NAMCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_SRNCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_CRYCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_TELCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_MOBCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_EMLCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub INIT_ESSUIDCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOID_PERCNT : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOID_PERCNT
Gosub LNKPRO_CRYCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub LNKPRO_TELCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Gosub LNKPRO_MOBCNT From WMC1EMPLOID_PERCNT : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



