#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Traitement de génération d'un mailing XML
#   Module CRM                                                                          12 Novembre 2003
##########################################################################################################
##########################################################################################################
Funprog GENMAILXML(SZMXL, SFILEXML, SZTYPSEA, SZOPGNUM, IDEFADD, IHIEBPR, SZCNTTTR, SMESSAGE)
Value Char SZMXL
Value Char SFILEXML
Value Char SZTYPSEA
Value Char SZOPGNUM
Value Integer IDEFADD
Value Integer IHIEBPR
Value Char SZCNTTTR
Variable Char SMESSAGE

#Caractères XML
Local Char A(2)
Local Char B(4)
Local Char C(4)
Local Char D(2)
Local Char VQ(2)
#Buffers d'écriture
Local Char SZBUFFTOFILL(250)(5)
#Séparateurs
Local Char SZADXIFS(type(adxifs)-10)
Local Char SZADXIRS(type(adxirs)-10)
Local Integer IOK

  VQ = '"'
  A = "<"
  B = "</"
  C = "/>"
  D = ">"
  Raz SZBUFFTOFILL
  # --------------------------------
  IOK = [V]CST_ASUCCESS
  # --------------------------------
  #Contrôle de l'existence du publipostage XML demandé
  If SZMXL = "" Then
    #Aucun publipostage XML n'a été communiqué.
    SMESSAGE = mess(661,182,1)
    IOK = [V]CST_AERROR
    End IOK
  Endif
  If SFILEXML = "" Then
    SMESSAGE = mess(35,126,1)
    IOK = [V]CST_AERROR
    End IOK
  Endif
  # --------------------------------
  Local File MAILXML [MXL]
  Local File MAILXMLD [MXD]
  # --------------------------------
  Read [MXL]MXL0=SZMXL
  If fstat Then
    #Le publipostage XML communiqué n'est pas défini.
    SMESSAGE = mess(662,182,1)
    IOK = [V]CST_AERROR
    End IOK
  Endif
  # --------------------------------
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  # --------------------------------
  #Ouverture du fichier XML
  Openo SFILEXML, 0 Using [FXML]
  If fstat Then
    #On restaure les variables adxifs et adxirs
    adxifs = SZADXIFS
    adxirs = SZADXIRS
    #Erreur lors de l'ouverture du fichier XML.
    SMESSAGE = mess(660,182,1)
    IOK = [V]CST_AERROR
    End IOK
  Endif
  # --------------------------------
  #En-tête du fichier XML
  Raz SZBUFFTOFILL
  Call XMLENTET(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  # --------------------------------
  #Ecriture du ROOT
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + [F:MXL]NUM + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  # --------------------------------
  Gosub DOMAILXML
  # --------------------------------
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + [F:MXL]NUM + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  # --------------------------------
  #On ferme le fichier XML
  Openo Using [FXML]
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
  # --------------------------------
End IOK

##########################################################################################################
# Génération d'un mailing XML
###################################################################
$DOMAILXML
Local Integer IXMLOK
Local Integer ITERBOX
Local Integer IBOXCOUNT
Local Integer ICOUNTXML
Local Integer ICUT
Local Integer ITER
Local Integer IZ
Local Integer IFEEDMGC1
Local Integer IFIRLOOP
Local Integer IPRECNT
Local Integer ICANFOR
Local Integer IC
Local Integer IOUTOFMAI4
Local Integer ICCNADDEMP(6)
Local Integer IEVALTYPE
Local Char SZABR(GLONABR)
Local Char SZFIE(250)
Local Date SZBUFFDAT
Local Decimal SZBUFFFLOAT
Local Char SZREPFNCCOD(250)
Local Char SZ2REPFNCCOD(250)
Local Char SZREPFNCCLA(250)
Local Char SZ2REPFNCCLA(250)
Local Char SZBPCNUM(GLONBPR)
#Mise en mémoire du paramétrage XML
Local Integer ILONGAVA   # FGR 25/10/2010 : X3SUIVI68342
Local Integer ICONTACTCRM
Local Integer ICONTACT
Local Integer IBPARTNER
Local Integer IBPCUSTOMER
Local Integer IBPADDRESS
Local Integer ISALESREP
Local Integer ILEAD
# Gestion du tronçonnage
Local Char SZMAI4LCRY(GLONCRY)
Local Char SZMAI4LSAT(GLONSAT)
Local Char SZMAI4LZIP(GLONPOS)
Local Char SZMAI4LCTY(GLONCTY)
Local Char SZMAI4LBPR(GLONBPR)
Local Char SZMAI4LREC(GLONVCR)

  Call TEMPON("L") From GESECRAN
  #
  Local File CONTACTCRM [AIN]
  Local File CONTACT [CNT]
  Local File BPARTNER [BPR]
  Local File BPCUSTOMER [BPC]
  Local File BPADDRESS [BPA]
  Local File SALESREP [REP]
  Local File SELCMGLIS [SCL]
  #
  SZMAI4LCRY = ""
  SZMAI4LSAT = ""
  SZMAI4LZIP = ""
  SZMAI4LCTY = ""
  SZMAI4LBPR = ""
  SZMAI4LREC = ""
  #
  SZREPFNCCOD = ""
  SZ2REPFNCCOD = "AUSCRMA"
  SZREPFNCCLA = ""
  SZ2REPFNCCLA = "AUSCRMACLA"
  IFEEDMGC1 = 0
  IFIRLOOP = 0
  IPRECNT = 0
  ICANFOR = 0
  IZ = 0
  IC = 0
  ITER = 0
  IOUTOFMAI4 = 0
  Raz ICCNADDEMP
  ICUT = 2500
  ICOUNTXML = 0
  ITERBOX = 0
  IBOXCOUNT = 0
  IXMLOK = 0
  SZBPCNUM = ""
  #
  ICONTACTCRM = 0
  ICONTACT = 0
  IBPARTNER = 0
  IBPCUSTOMER = 0
  IBPADDRESS = 0
  ISALESREP = 0
  ILEAD = 0
  #
  Filter [MXD] Where [F:MXD]NUM = SZMXL and [F:MXD]LBEXML <> ""
  For [MXD]
    If [F:MXD]TAB = "CONTACTCRM" Then
      ICONTACTCRM += 1
    Elsif [F:MXD]TAB = "CONTACT" Then
      ICONTACT += 1
    Elsif [F:MXD]TAB = "BPARTNER" Then
      IBPARTNER += 1
    Elsif [F:MXD]TAB = "BPCUSTOMER" Then
      IBPCUSTOMER += 1
    Elsif [F:MXD]TAB = "BPADDRESS" Then
      IBPADDRESS += 1
    Elsif [F:MXD]TAB = "SALESREP" Then
      ISALESREP += 1
    Elsif [F:MXD]TAB = "LEAD" Then
      ILEAD += 1
    Endif
  Next
  Filter [MXD]
  # -----------------------------------
  ICONTACTCRM = max(1, ICONTACTCRM)
  ICONTACT = max(1, ICONTACT)
  IBPARTNER = max(1, IBPARTNER)
  IBPCUSTOMER = max(1, IBPCUSTOMER)
  IBPADDRESS = max(1, IBPADDRESS)
  ISALESREP = max(1, ISALESREP)
  ILEAD = max(1, ILEAD)
  ILONGAVA = GLONAVA + 5
  # -----------------------------------
  If SZTYPSEA = "CCN" Then
    Local Char SZCONTACTCRM(ILONGAVA)(ICONTACTCRM)
    Local Char SZ2CONTACTCRM(GLONDES)(ICONTACTCRM)
    Local Char SZCONTACT(ILONGAVA)(ICONTACT)
    Local Char SZ2CONTACT(GLONDES)(ICONTACT)
    Local Char SZLEAD(ILONGAVA)(ILEAD)
    Local Char SZ2LEAD(GLONDES)(ILEAD)

    Raz SZCONTACTCRM
    Raz SZCONTACT
    Raz SZ2CONTACTCRM
    Raz SZ2CONTACT
    Raz SZLEAD
    Raz SZ2LEAD
  Endif

Local Char SZBPARTNER(ILONGAVA)(IBPARTNER)
Local Char SZ2BPARTNER(GLONDES)(IBPARTNER)
Local Char SZBPCUSTOMER(ILONGAVA)(IBPCUSTOMER)
Local Char SZ2BPCUSTOMER(GLONDES)(IBPCUSTOMER)
Local Char SZBPADDRESS(ILONGAVA)(IBPADDRESS)
Local Char SZ2BPADDRESS(GLONDES)(IBPADDRESS)
Local Char SZSALESREP(ILONGAVA)(ISALESREP)
Local Char SZ2SALESREP(GLONDES)(ISALESREP)

  Raz SZBPARTNER
  Raz SZBPCUSTOMER
  Raz SZBPADDRESS
  Raz SZSALESREP
  Raz SZ2BPARTNER
  Raz SZ2BPCUSTOMER
  Raz SZ2BPADDRESS
  Raz SZ2SALESREP
  ICONTACTCRM = 0
  ICONTACT = 0
  IBPARTNER = 0
  IBPCUSTOMER = 0
  IBPADDRESS = 0
  ISALESREP = 0
  Filter [MXD] Where [F:MXD]NUM = SZMXL and [F:MXD]LBEXML <> ""
  For [MXD]
    If [F:MXD]TAB = "CONTACTCRM" Then
      SZCONTACTCRM(ICONTACTCRM) = [F:MXD]FIE
      SZ2CONTACTCRM(ICONTACTCRM) = [F:MXD]LBEXML
      ICONTACTCRM += 1
    Elsif [F:MXD]TAB = "CONTACT" Then
      SZCONTACT(ICONTACT) = [F:MXD]FIE
      SZ2CONTACT(ICONTACT) = [F:MXD]LBEXML
      ICONTACT += 1
    Elsif [F:MXD]TAB = "BPARTNER" Then
      SZBPARTNER(IBPARTNER) = [F:MXD]FIE
      SZ2BPARTNER(IBPARTNER) = [F:MXD]LBEXML
      IBPARTNER += 1
    Elsif [F:MXD]TAB = "BPCUSTOMER" Then
      SZBPCUSTOMER(IBPCUSTOMER) = [F:MXD]FIE
      SZ2BPCUSTOMER(IBPCUSTOMER) = [F:MXD]LBEXML
      IBPCUSTOMER += 1
    Elsif [F:MXD]TAB = "BPADDRESS" Then
      SZBPADDRESS(IBPADDRESS) = [F:MXD]FIE
      SZ2BPADDRESS(IBPADDRESS) = [F:MXD]LBEXML
      IBPADDRESS += 1
    Elsif [F:MXD]TAB = "SALESREP" Then
      SZSALESREP(ISALESREP) = [F:MXD]FIE
      SZ2SALESREP(ISALESREP) = [F:MXD]LBEXML
      ISALESREP += 1
    Elsif [F:MXD]TAB = "LEAD" Then
      SZSALESREP(ILEAD) = [F:MXD]FIE
      SZ2SALESREP(ILEAD) = [F:MXD]LBEXML
      ILEAD += 1
    Endif
  Next
  Filter [MXD]
  If [F:MXL]REPFNCFLG = 2 Then
    Gosub GETFNCXMLCOD
    Gosub GETFNCXMLCLA
  Endif
  For ITERBOX = 0 To 1
    IFEEDMGC1 = 0
    IFIRLOOP = 0
    ITER = 0
    If ITERBOX Then
      Call TEMPOFF From GESECRAN
      Call OUVRE_BOITE(mess(1,182,1), IBOXCOUNT) From GESECRAN
    Endif
    If SZTYPSEA = "CCN" Then
      Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM and [F:SCL]RECTYP = "CCN"
&               Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                        [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
    Elsif SZTYPSEA = "BPR" Then
      Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM and [F:SCL]RECTYP <> "CCN"
&               Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                        [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
    Endif
    For [SCL]Hint Key SCL0
      If ITER >= ICUT Then
        IFEEDMGC1 = 1
        ITER = 0
        Break
      Endif
      SZMAI4LCRY = [F:SCL]SCLCRY
      SZMAI4LSAT = [F:SCL]SCLSAT
      SZMAI4LZIP = [F:SCL]SCLZIP
      SZMAI4LCTY = [F:SCL]SCLCTY
      SZMAI4LBPR = [F:SCL]BPRNUM
      SZMAI4LREC = [F:SCL]RECNUM
      If ITERBOX Then
        #On remplit la ligne
        Gosub EXTRACTXML
      Else
        IBOXCOUNT += 1
      Endif
      ITER += 1
    Next
    Filter [SCL]
    While IFEEDMGC1
      If IFIRLOOP = 0 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]RECNUM > SZMAI4LREC
&                        and [F:SCL]BPRNUM = SZMAI4LBPR
&                        and [F:SCL]SCLCTY = SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]RECNUM > SZMAI4LREC
&                        and [F:SCL]BPRNUM = SZMAI4LBPR
&                        and [F:SCL]SCLCTY = SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 1 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]BPRNUM > SZMAI4LBPR
&                        and [F:SCL]SCLCTY = SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]BPRNUM > SZMAI4LBPR
&                        and [F:SCL]SCLCTY = SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 2 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCTY > SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCTY > SZMAI4LCTY
&                        and [F:SCL]SCLZIP = SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 3 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLZIP > SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLZIP > SZMAI4LZIP
&                        and [F:SCL]SCLSAT = SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 4 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLSAT > SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLSAT > SZMAI4LSAT
&                        and [F:SCL]SCLCRY = SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 5 Then
        If SZTYPSEA = "CCN" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP = "CCN"
&                        and [F:SCL]SCLCRY > SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Elsif SZTYPSEA = "BPR" Then
          Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM
&                        and [F:SCL]RECTYP <> "CCN"
&                        and [F:SCL]SCLCRY > SZMAI4LCRY
&                   Order By [F:SCL]SCLCRY Asc; [F:SCL]SCLSAT Asc; [F:SCL]SCLZIP Asc;
&                            [F:SCL]SCLCTY Asc; [F:SCL]BPRNUM Asc; [F:SCL]RECNUM Asc
        Endif
        IFIRLOOP += 1
        IFEEDMGC1 = 0
      Endif
      For [SCL]Hint Key SCL0
        If ITER >= ICUT Then
          IFEEDMGC1 = 1
          IFIRLOOP = 0
          ITER = 0
          Break
        Endif
        SZMAI4LCRY = [F:SCL]SCLCRY
        SZMAI4LSAT = [F:SCL]SCLSAT
        SZMAI4LZIP = [F:SCL]SCLZIP
        SZMAI4LCTY = [F:SCL]SCLCTY
        SZMAI4LBPR = [F:SCL]BPRNUM
        SZMAI4LREC = [F:SCL]RECNUM
        If ITERBOX Then
          #On remplit la ligne
          Gosub EXTRACTXML
        Else
          IBOXCOUNT += 1
        Endif
        ITER += 1
      Next
      Filter [SCL]
    Wend
  Next
  Call FERME_BOITE From GESECRAN
Return

##########################################################################################################
# Extraction d'un enregistrement en XML
###############################################################
$EXTRACTXML
  #Remplit le tableau des destinataires
  If SZTYPSEA = "CCN" Then
    If [F:SCL]RECNUM <> "" Then
      Read [AIN]AIN0=[F:SCL]RECNUM
      If !fstat Then
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + [F:MXL]ROT + " " + [F:MXL]SRT + '="' + num$(ICOUNTXML) + '"' + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        #On extrait les champs de la table CONTACTCRM
        For ICONTACTCRM = 0 To dim(SZCONTACTCRM)-1
          If SZCONTACTCRM(ICONTACTCRM) = ""  Then
            Break
          Endif
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = A + SZ2CONTACTCRM(ICONTACTCRM) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          SZABR = "AIN"
          SZFIE = SZCONTACTCRM(ICONTACTCRM)
          If SZFIE = "CNTFULNAM" Then
            Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
          Else
            Gosub FILLBUFFER
          Endif
          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = B + SZ2CONTACTCRM(ICONTACTCRM) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
        Next
        If [F:AIN]CNTTYP = 1 Then
          #On extrait les champs de la table LEAD
          For ILEAD = 0 To dim(SZLEAD)-1
            If SZLEAD(ILEAD) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2LEAD(ILEAD) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2LEAD(ILEAD) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
          If [F:SCL]BPRNUM = "" Then
            # Un tiers peut être mentionné dans le tableau.
            #On extrait les champs de la table CONTACT
            For ICONTACT = 0 To dim(SZCONTACT)-1
              If SZCONTACT(ICONTACT) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2CONTACT(ICONTACT) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2CONTACT(ICONTACT) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
            #On extrait les champs de la table BPARTNER
            For IBPARTNER = 0 To dim(SZBPARTNER)-1
              If SZBPARTNER(IBPARTNER) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
            #On extrait les champs de la table BPCUSTOMER
            For IBPCUSTOMER = 0 To dim(SZBPCUSTOMER)-1
              If SZBPCUSTOMER(IBPCUSTOMER) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2BPCUSTOMER(IBPCUSTOMER) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2BPCUSTOMER(IBPCUSTOMER) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
            #On extrait les champs de la table SALESREP
            For ISALESREP = 0 To dim(SZSALESREP)-1
              If SZSALESREP(ISALESREP) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2SALESREP(ISALESREP) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2SALESREP(ISALESREP) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
            If [F:MXL]REPFNCFLG = 2 Then
              Gosub DOEMPREPFNC
            Endif
            #On extrait les champs de la table BPADDRESS
            For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
              If SZBPADDRESS(IBPADDRESS) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
          Else
            Read [CNT]CNT0=1;[F:SCL]BPRNUM;[F:AIN]CNTNUM
            If fstat Then
              #On extrait les champs de la table CONTACT
              For ICONTACT = 0 To dim(SZCONTACT)-1
                If SZCONTACT(ICONTACT) = "" Then
                  Break
                Endif
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = A + SZ2CONTACT(ICONTACT) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = B + SZ2CONTACT(ICONTACT) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
              Next
            Else
              #On extrait les champs de la table CONTACT
              For ICONTACT = 0 To dim(SZCONTACT)-1
                If SZCONTACT(ICONTACT) = "" Then
                  Break
                Endif
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = A + SZ2CONTACT(ICONTACT) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                SZABR = "CNT"
                SZFIE = SZCONTACT(ICONTACT)
                Gosub FILLBUFFER
                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = B + SZ2CONTACT(ICONTACT) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
              Next
            Endif
            Read [BPR]BPR0=[F:SCL]BPRNUM
            If fstat Then
              #On extrait les champs de la table BPARTNER
              For IBPARTNER = 0 To dim(SZBPARTNER)-1
                If SZBPARTNER(IBPARTNER) = "" Then
                  Break
                Endif
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
              Next
            Else
              #On extrait les champs de la table BPARTNER
              For IBPARTNER = 0 To dim(SZBPARTNER)-1
                If SZBPARTNER(IBPARTNER) = "" Then
                  Break
                Endif
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                SZABR = "BPR"
                SZFIE = SZBPARTNER(IBPARTNER)
                Gosub FILLBUFFER
                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                Wrseq SZBUFFTOFILL(0) Using [FXML]
                Raz SZBUFFTOFILL
                SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
                Wrseq SZBUFFTOFILL(0) Using [FXML]
              Next
            Endif
            SZBPCNUM = [F:SCL]BPRNUM
            Gosub DOBPC
            If IDEFADD = 2 Then
              #L'adresse du contact doit être chargée.
              If IHIEBPR = 2 Then
                #Une affectation hiérarchique d'adresse est demandée.
                #Test si l'adresse contact est complétement vide.
                ICCNADDEMP(0) = 1
                If [F:AIN]ADD(0) = "" Then
                  ICCNADDEMP(1) = 1
                Else
                  ICCNADDEMP(1) = 0
                Endif
                If [F:AIN]ADD(1) = "" Then
                  ICCNADDEMP(2) = 1
                Else
                  ICCNADDEMP(2) = 0
                Endif
                If [F:AIN]ADD(2) = "" Then
                  ICCNADDEMP(3) = 1
                Else
                  ICCNADDEMP(3) = 0
                Endif
                If [F:AIN]ZIP = "" Then
                  ICCNADDEMP(4) = 1
                Else
                  ICCNADDEMP(4) = 0
                Endif
                If [F:AIN]CTY = "" Then
                  ICCNADDEMP(5) = 1
                Else
                  ICCNADDEMP(5) = 0
                Endif
                For IC = 1 To dim(ICCNADDEMP)-1
                  If ICCNADDEMP(IC) = 0 Then
                    ICCNADDEMP(0) = 0
                    Break
                  Endif
                Next
                If ICCNADDEMP(0) = 1 Then
                  #L'adresse contact est complétement vide. On charge l'adresse Tiers
                  #On charge d'abord adresse interloculeur/tier
                  If [F:CNT]BPAADD = "" Then
                    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
                  Else
                    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:CNT]BPAADD
                  Endif
                  Gosub ADRESSE
                Endif
              Endif
            Else
              #L'adresse Tiers par défaut doit être chargée.
              Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
              If fstat Then
                #On extrait les champs de la table BPADDRESS
                For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
                  If SZBPADDRESS(IBPADDRESS) = "" Then
                    Break
                  Endif
                  Raz SZBUFFTOFILL
                  SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
                  Wrseq SZBUFFTOFILL(0) Using [FXML]
                  Raz SZBUFFTOFILL
                  SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
                  Wrseq SZBUFFTOFILL(0) Using [FXML]
                Next
              Else
                #On extrait les champs de la table BPADDRESS
                For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
                  If SZBPADDRESS(IBPADDRESS) = "" Then
                    Break
                  Endif
                  Raz SZBUFFTOFILL
                  SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
                  Wrseq SZBUFFTOFILL(0) Using [FXML]
                  SZABR = "BPA"
                  SZFIE = SZBPADDRESS(IBPADDRESS)
                  Gosub FILLBUFFER
                  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                  Wrseq SZBUFFTOFILL(0) Using [FXML]
                  Raz SZBUFFTOFILL
                  SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
                  Wrseq SZBUFFTOFILL(0) Using [FXML]
                Next
              Endif
            Endif
          Endif
        Elsif [F:AIN]CNTTYP = 2 Then
          Read [LDS]LDS0=[F:SCL]RECNUM
          If fstat = 0 Then
            #On extrait les champs de la table LEAD
            For ILEAD = 0 To dim(SZLEAD)-1
              If SZLEAD(ILEAD) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2LEAD(ICONTACT) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2LEAD(ILEAD) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
          Else
            #On extrait les champs de la table LEAD
            For ILEAD = 0 To dim(SZLEAD)-1
              If SZLEAD(ILEAD) = "" Then
                Break
              Endif
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = A + SZ2LEAD(ILEAD) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              SZABR = "LDS"
              SZFIE = SZLEAD(ILEAD)
              Gosub FILLBUFFER
              Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
              Wrseq SZBUFFTOFILL(0) Using [FXML]
              Raz SZBUFFTOFILL
              SZBUFFTOFILL(0) = B + SZ2LEAD(ILEAD) + D
              Wrseq SZBUFFTOFILL(0) Using [FXML]
            Next
          Endif
          #On extrait les champs de la table CONTACT
          For ICONTACT = 0 To dim(SZCONTACT)-1
            If SZCONTACT(ICONTACT) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2CONTACT(ICONTACT) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2CONTACT(ICONTACT) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
          #On extrait les champs de la table BPARTNER
          For IBPARTNER = 0 To dim(SZBPARTNER)-1
            If SZBPARTNER(IBPARTNER) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
          #On extrait les champs de la table BPCUSTOMER
          For IBPCUSTOMER = 0 To dim(SZBPCUSTOMER)-1
            If SZBPCUSTOMER(IBPCUSTOMER) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2BPCUSTOMER(IBPCUSTOMER) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2BPCUSTOMER(IBPCUSTOMER) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
          #On extrait les champs de la table SALESREP
          For ISALESREP = 0 To dim(SZSALESREP)-1
            If SZSALESREP(ISALESREP) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2SALESREP(ISALESREP) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2SALESREP(ISALESREP) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
          If [F:MXL]REPFNCFLG = 2 Then
            Gosub DOEMPREPFNC
          Endif
          #On extrait les champs de la table BPADDRESS
          For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
            If SZBPADDRESS(IBPADDRESS) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
        Endif
        #Complément spécifiques à la structure paramétrée
        Gosub PE_OMMXML From TRTCRMPE
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = B + [F:MXL]ROT + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
      Endif
    Else
      #on a un contact banalisé
      Read [BPR]BPR0=[F:SCL]BPRNUM
      If !fstat Then
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + [F:MXL]ROT + " " + [F:MXL]SRT + '="' + num$(ICOUNTXML) + '"' + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        #Titre générique
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + [F:MXL]TTR + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = SZCNTTTR
        Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = B + [F:MXL]TTR + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        #On extrait les champs de la table BPARTNER
        For IBPARTNER = 0 To dim(SZBPARTNER)-1
          If SZBPARTNER(IBPARTNER) = "" Then
            Break
          Endif
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          SZABR = "BPR"
          SZFIE = SZBPARTNER(IBPARTNER)
          Gosub FILLBUFFER
          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
        Next
        Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        If fstat Then
          #On extrait les champs de la table BPADDRESS
          For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
            If SZBPADDRESS(IBPADDRESS) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
        Else
          #On extrait les champs de la table BPADDRESS
          For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
            If SZBPADDRESS(IBPADDRESS) = "" Then
              Break
            Endif
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            SZABR = "BPA"
            SZFIE = SZBPADDRESS(IBPADDRESS)
            Gosub FILLBUFFER
            Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
            Wrseq SZBUFFTOFILL(0) Using [FXML]
            Raz SZBUFFTOFILL
            SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
            Wrseq SZBUFFTOFILL(0) Using [FXML]
          Next
        Endif
        SZBPCNUM = [F:SCL]BPRNUM
        Gosub DOBPC
        #Complément spécifiques à la structure paramétrée
        Gosub PE_OMMXML From TRTCRMPE
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = B + [F:MXL]ROT + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
      Endif
    Endif
  Elsif SZTYPSEA = "BPR" Then
    Read [BPR]BPR0=[F:SCL]RECNUM
    If !fstat Then
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = A + [F:MXL]ROT + " " + [F:MXL]SRT + '="' + num$(ICOUNTXML) + '"' + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      #Titre générique
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = A + [F:MXL]TTR + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = SZCNTTTR
      Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = B + [F:MXL]TTR + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      #On extrait les champs de la table BPARTNER
      For IBPARTNER = 0 To dim(SZBPARTNER)-1
        If SZBPARTNER(IBPARTNER) = "" Then
          Break
        Endif
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = A + SZ2BPARTNER(IBPARTNER) + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        SZABR = "BPR"
        SZFIE = SZBPARTNER(IBPARTNER)
        Gosub FILLBUFFER
        Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
        Wrseq SZBUFFTOFILL(0) Using [FXML]
        Raz SZBUFFTOFILL
        SZBUFFTOFILL(0) = B + SZ2BPARTNER(IBPARTNER) + D
        Wrseq SZBUFFTOFILL(0) Using [FXML]
      Next
      Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
      If fstat Then
        #On extrait les champs de la table BPADDRESS
        For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
          If SZBPADDRESS(IBPADDRESS) = "" Then
            Break
          Endif
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
        Next
      Else
        #On extrait les champs de la table BPADDRESS
        For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
          If SZBPADDRESS(IBPADDRESS) = "" Then
            Break
          Endif
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          SZABR = "BPA"
          SZFIE = SZBPADDRESS(IBPADDRESS)
          Gosub FILLBUFFER
          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
          Wrseq SZBUFFTOFILL(0) Using [FXML]
          Raz SZBUFFTOFILL
          SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
          Wrseq SZBUFFTOFILL(0) Using [FXML]
        Next
      Endif
      SZBPCNUM = [F:SCL]RECNUM
      Gosub DOBPC
      #Complément spécifiques à la structure paramétrée
      Gosub PE_OMMXML From TRTCRMPE
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = B + [F:MXL]ROT + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
    Endif
  Endif
  ICOUNTXML += 1
  Call AFF_BOITE (mess(1,182,1), ICOUNTXML, IXMLOK) From GESECRAN
Return

##########################################################################################################
#chargement adresse pae défaut du tiers
$ADRESSE
  If fstat Then
  #On extrait les champs de la table BPADDRESS
  For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
    If SZBPADDRESS(IBPADDRESS) = "" Then
      Break
    Endif
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Raz SZBUFFTOFILL
    SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
    Wrseq SZBUFFTOFILL(0) Using [FXML]
    Next
  Else
    #On extrait les champs de la table BPADDRESS
    For IBPADDRESS = 0 To dim(SZBPADDRESS)-1
      If SZBPADDRESS(IBPADDRESS) = "" Then
        Break
      Endif
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = A + SZ2BPADDRESS(IBPADDRESS) + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      SZABR = "BPA"
      SZFIE = SZBPADDRESS(IBPADDRESS)
      Gosub FILLBUFFER
      Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
      Wrseq SZBUFFTOFILL(0) Using [FXML]
      Raz SZBUFFTOFILL
      SZBUFFTOFILL(0) = B + SZ2BPADDRESS(IBPADDRESS) + D
      Wrseq SZBUFFTOFILL(0) Using [FXML]
    Next
  Endif
Return

##########################################################################################################
$FILLBUFFER
  IEVALTYPE = evalue("Type([F:" + SZABR + "]" + SZFIE + ")")
  If IEVALTYPE = 1 or IEVALTYPE = 2 Then
    #Numérique
    Assign ("SZBUFFFLOAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = num$(SZBUFFFLOAT)
  Elsif IEVALTYPE = 3 Then
    #Date
    Assign ("SZBUFFDAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = format$(GFMD,SZBUFFDAT)
  Elsif IEVALTYPE >= 4 and IEVALTYPE <= 9 Then
    #Numérique
    Assign ("SZBUFFFLOAT") With evalue("[F:" + SZABR + "]" + SZFIE)
    SZBUFFTOFILL(0) = num$(SZBUFFFLOAT)
  Elsif IEVALTYPE >= 10 Then
    #Alpha
    Assign ("SZBUFFTOFILL(0)") With evalue("[F:" + SZABR + "]" + SZFIE)
  Endif
Return

##########################################################################################################
$GETFNCXMLCOD
Local Integer ITERAUS
Local Integer IDUPFOUND
Local Integer IDUPCHRONO

  #Vérifie si AUSCRMA n'est pas déjà utilisé comme étiquette XML.
  ITERAUS = 0
  IDUPFOUND = 0
  IDUPCHRONO = 0
  While 1
    IDUPFOUND = 0
    If SZTYPSEA = "CCN" Then
      If !IDUPFOUND Then
        For ITERAUS = 0 To dim(SZ2CONTACTCRM)-1
          If SZ2CONTACTCRM(ITERAUS) = "" Then
            Break
          Endif
          If SZ2CONTACTCRM(ITERAUS) = SZ2REPFNCCOD Then
            IDUPFOUND = 1
            Break
          Endif
        Next
      Endif
      If !IDUPFOUND Then
        For ITERAUS = 0 To dim(SZ2CONTACT)-1
          If SZ2CONTACT(ITERAUS) = "" Then
            Break
          Endif
          If SZ2CONTACT(ITERAUS) = SZ2REPFNCCOD Then
            IDUPFOUND = 1
            Break
          Endif
        Next
      Endif
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPARTNER)-1
        If SZ2BPARTNER(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPARTNER(ITERAUS) = SZ2REPFNCCOD Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPCUSTOMER)-1
        If SZ2BPCUSTOMER(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPCUSTOMER(ITERAUS) = SZ2REPFNCCOD Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPADDRESS)-1
        If SZ2BPADDRESS(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPADDRESS(ITERAUS) = SZ2REPFNCCOD Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2SALESREP)-1
        If SZ2SALESREP(ITERAUS) = "" Then
          Break
        Endif
        If SZ2SALESREP(ITERAUS) = SZ2REPFNCCOD Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If IDUPFOUND Then
      IDUPCHRONO += 1
      SZ2REPFNCCOD = "AUSCRMA" + num$(IDUPCHRONO)
    Else
      Break
    Endif
  Wend
Return

##########################################################################################################
$GETFNCXMLCLA
Local Integer ITERAUS
Local Integer IDUPFOUND
Local Integer IDUPCHRONO

  #Vérifie si AUSCRMACLA n'est pas déjà utilisé comme étiquette XML.
  ITERAUS = 0
  IDUPFOUND = 0
  IDUPCHRONO = 0
  While 1
    IDUPFOUND = 0
    If SZTYPSEA = "CCN" Then
      If !IDUPFOUND Then
        For ITERAUS = 0 To dim(SZ2CONTACTCRM)-1
          If SZ2CONTACTCRM(ITERAUS) = "" Then
            Break
          Endif
          If SZ2CONTACTCRM(ITERAUS) = SZ2REPFNCCLA Then
            IDUPFOUND = 1
            Break
          Endif
        Next
      Endif
      If !IDUPFOUND Then
        For ITERAUS = 0 To dim(SZ2CONTACT)-1
          If SZ2CONTACT(ITERAUS) = "" Then
            Break
          Endif
          If SZ2CONTACT(ITERAUS) = SZ2REPFNCCLA Then
            IDUPFOUND = 1
            Break
          Endif
        Next
      Endif
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPARTNER)-1
        If SZ2BPARTNER(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPARTNER(ITERAUS) = SZ2REPFNCCLA Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPCUSTOMER)-1
        If SZ2BPCUSTOMER(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPCUSTOMER(ITERAUS) = SZ2REPFNCCLA Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2BPADDRESS)-1
        If SZ2BPADDRESS(ITERAUS) = "" Then
          Break
        Endif
        If SZ2BPADDRESS(ITERAUS) = SZ2REPFNCCLA Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If !IDUPFOUND Then
      For ITERAUS = 0 To dim(SZ2SALESREP)-1
        If SZ2SALESREP(ITERAUS) = "" Then
          Break
        Endif
        If SZ2SALESREP(ITERAUS) = SZ2REPFNCCLA Then
          IDUPFOUND = 1
          Break
        Endif
      Next
    Endif
    If IDUPFOUND Then
      IDUPCHRONO += 1
      SZ2REPFNCCLA = "AUSCRMACLA" + num$(IDUPCHRONO)
    Else
      Break
    Endif
  Wend
Return

##########################################################################################################
# Extrait la fonction d'un représentant
###############################################################
$DOREPFNC
  If [F:REP]AUSNUM = "" Then
    SZREPFNCCOD = ""
    SZREPFNCCLA = ""
  Else
    Call PARAMUTIL("AUSCRMA", SZREPFNCCOD, [F:REP]AUSNUM, "") From SUBAUS
    If SZREPFNCCOD = "" Then
      SZREPFNCCLA = ""
    Else
      If SZREPFNCCOD = "1" Then
        SZREPFNCCOD = ""
        SZREPFNCCLA = ""
      Else
        SZREPFNCCLA = mess(val(SZREPFNCCOD),3022,1)
      Endif
    Endif
  Endif
  #Code fonction
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZ2REPFNCCOD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  SZBUFFTOFILL(0) = SZREPFNCCOD
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZ2REPFNCCOD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Fonction en clair
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZ2REPFNCCLA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  SZBUFFTOFILL(0) = SZREPFNCCLA
  Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZ2REPFNCCLA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
# Extrait la fonction d'un représentant
###############################################################
$DOEMPREPFNC
  #Code fonction
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZ2REPFNCCOD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZ2REPFNCCOD + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  #Fonction en clair
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = A + SZ2REPFNCCLA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
  Raz SZBUFFTOFILL
  SZBUFFTOFILL(0) = B + SZ2REPFNCCLA + D
  Wrseq SZBUFFTOFILL(0) Using [FXML]
Return

##########################################################################################################
# Extrait les informations relatives à un client
###############################################################
$DOBPC
   Read [BPC]BPC0=SZBPCNUM
   If fstat Then
     #On extrait les champs de la table BPCUSTOMER
     For IBPCUSTOMER = 0 To dim(SZBPCUSTOMER)-1
       If SZBPCUSTOMER(IBPCUSTOMER) = "" Then
         Break
       Endif
       Raz SZBUFFTOFILL
       SZBUFFTOFILL(0) = A + SZ2BPCUSTOMER(IBPCUSTOMER) + D
       Wrseq SZBUFFTOFILL(0) Using [FXML]
       Raz SZBUFFTOFILL
       SZBUFFTOFILL(0) = B + SZ2BPCUSTOMER(IBPCUSTOMER) + D
       Wrseq SZBUFFTOFILL(0) Using [FXML]
     Next
   Else
     #On extrait les champs de la table BPCUSTOMER
     For IBPCUSTOMER = 0 To dim(SZBPCUSTOMER)-1
       If SZBPCUSTOMER(IBPCUSTOMER) = "" Then
         Break
       Endif
       Raz SZBUFFTOFILL
       SZBUFFTOFILL(0) = A + SZ2BPCUSTOMER(IBPCUSTOMER) + D
       Wrseq SZBUFFTOFILL(0) Using [FXML]
       SZABR = "BPC"
       SZFIE = SZBPCUSTOMER(IBPCUSTOMER)
       Gosub FILLBUFFER
       Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
       Wrseq SZBUFFTOFILL(0) Using [FXML]
       Raz SZBUFFTOFILL
       SZBUFFTOFILL(0) = B + SZ2BPCUSTOMER(IBPCUSTOMER) + D
       Wrseq SZBUFFTOFILL(0) Using [FXML]
     Next
     If dim([F:BPC]REP) > 0 Then
       If [F:BPC]REP(0) = "" Then
         #On extrait les champs de la table SALESREP
         For ISALESREP = 0 To dim(SZSALESREP)-1
           If SZSALESREP(ISALESREP) = "" Then
             Break
           Endif
           Raz SZBUFFTOFILL
           SZBUFFTOFILL(0) = A + SZ2SALESREP(ISALESREP) + D
           Wrseq SZBUFFTOFILL(0) Using [FXML]
           Raz SZBUFFTOFILL
           SZBUFFTOFILL(0) = B + SZ2SALESREP(ISALESREP) + D
           Wrseq SZBUFFTOFILL(0) Using [FXML]
         Next
         If [F:MXL]REPFNCFLG = 2 Then
           Gosub DOEMPREPFNC
         Endif
       Else
         Read [REP]REP0=[F:BPC]REP(0)
         If fstat Then
           #On extrait les champs de la table SALESREP
           For ISALESREP = 0 To dim(SZSALESREP)-1
             If SZSALESREP(ISALESREP) = "" Then
               Break
             Endif
             Raz SZBUFFTOFILL
             SZBUFFTOFILL(0) = A + SZ2SALESREP(ISALESREP) + D
             Wrseq SZBUFFTOFILL(0) Using [FXML]
             Raz SZBUFFTOFILL
             SZBUFFTOFILL(0) = B + SZ2SALESREP(ISALESREP) + D
             Wrseq SZBUFFTOFILL(0) Using [FXML]
           Next
           If [F:MXL]REPFNCFLG = 2 Then
             Gosub DOEMPREPFNC
           Endif
         Else
           #On extrait les champs de la table SALESREP
           For ISALESREP = 0 To dim(SZSALESREP)-1
             If SZSALESREP(ISALESREP) = "" Then
               Break
             Endif
             Raz SZBUFFTOFILL
             SZBUFFTOFILL(0) = A + SZ2SALESREP(ISALESREP) + D
             Wrseq SZBUFFTOFILL(0) Using [FXML]
             SZABR = "REP"
             SZFIE = SZSALESREP(ISALESREP)
             Gosub FILLBUFFER
             Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
             Wrseq SZBUFFTOFILL(0) Using [FXML]
             Raz SZBUFFTOFILL
             SZBUFFTOFILL(0) = B + SZ2SALESREP(ISALESREP) + D
             Wrseq SZBUFFTOFILL(0) Using [FXML]
           Next
           If [F:MXL]REPFNCFLG = 2 Then
             Gosub DOREPFNC
           Endif
         Endif
       Endif
     Endif
   Endif
Return
