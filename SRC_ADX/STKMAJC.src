#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# Traitement STKMAJC - Librairie des composants de màj stock      V140 #
#                      Changement d'emplacement               MBT 2003 #
########################################################################
# Etiquette appelée par Gosub depuis le STKMAJ
#
# CHGEMP        Traitement des changements d'emplacement
#
#-----------------------------------------------------------------------
# Autres étiquettes appelées par Gosub depuis ce traitement :
#
# MAJEMP        Traitement d'une ligne détail de changement d'emplacement
# MAJEMP_SOR    Changement d'emplacement sortie
# MAJEMP_ENT    Changement d'emplacement entrée
# MAJEMP_STL    Réécriture lot après un changement d'emplacement
#
########################################################################


############################################
# Traitement des changements d'emplacement #
############################################
$CHGEMPL
GPOINT="MAJEMPSTR" : Gosub ENTREE From EXEFNC
Raz [L]WITMREF, [L]WANA, [L]WFCY
[L]WMAJTYP="C"
If [M:STW]TRFFCY=""  [M:STW]TRFFCY=[M:STW]STOFCY : Endif

Raz WAMTDEV_ITC, WAMTDEV_ITC2
#----- Boucle de traitement des lignes -----#
For I=0 To dim([M:STW]ITMREFLIG)-1
  If [M:STW]ITMREFLIG(I)=""  Break : Endif
  If ([M:STW]QTYSTU(I)<>0 | [M:STW]QTYSTUACT(I)<>0) & [M:STW]MAJTYP(I)="C"
    Gosub INI_WMAJCODSTO From STKMAJ
    Gosub MAJEMP : If GOK<1  Break : Endif
    Call AMTDEVITC(2, I, WAMTDEV_ITC2) From STKVALMAJ2      # 84744
    Call AMTDEVITC(1, I, WAMTDEV_ITC) From STKVALMAJ2      # 84744
  Endif
Next I
If GOK<1  Return : Endif
#----- Màj contrôle qualité, cumuls article-site, ... -----#
Raz [L]WRUPTPREC,   [L]WANA
Gosub MAJ_ITMMVT  From STKMAJ : If GOK<1  Return : Endif
Call MAJPMP(2,WAMTDEV_AVC) From STKVALMAJ2
If GOK<1 : Return : Endif
If WMODLOT<>1
    Call MAJFIFO(2,WAMTDEV_STP) From STKVALMAJ2
    If GOK<1 : Return : Endif
    Raz WAMTDEV_TOT
    For I=0 To GACTVLT2
        For J=0 To dim(WAMTDEV_AVC,2)-1
            WAMTDEV_TOT(I,J) += WAMTDEV_AVC(I,J)+WAMTDEV_STP(I,J)+WAMTDEV_LOT(I,J)
        Next
    Next
    Call MAJITH(2,WAMTDEV_TOT,WAMTDEV_ITC2,WMVTSEQSTR, WCTR_MVTSEQ+1) From STKVALMAJ2
    If GOK<1 : Return : Endif
Endif
Raz WAMTDEV_STP,WAMTDEV_AVC
Call MAJPMP(1,WAMTDEV_AVC) From STKVALMAJ2
If GOK<1 : Return : Endif
If WMODLOT<>1
    Call MAJFIFO(1,WAMTDEV_STP) From STKVALMAJ2
    If GOK<1 : Return : Endif
    Raz WAMTDEV_TOT
    For I=0 To GACTVLT2
        For J=0 To dim(WAMTDEV_AVC,2)-1
            WAMTDEV_TOT(I,J) += WAMTDEV_AVC(I,J)+WAMTDEV_STP(I,J)+WAMTDEV_LOT(I,J)
        Next
    Next
    Call MAJITH(1,WAMTDEV_TOT,WAMTDEV_ITC,WMVTSEQSTR, WCTR_MVTSEQ+1) From STKVALMAJ2
    If GOK<1 : Return : Endif
Endif

#-----
GPOINT="MAJEMPEND" : Gosub ENTREE From EXEFNC
Return


#------------------------------------------------#
# Traitement ligne des changements d'emplacement #
#------------------------------------------------#
$MAJEMP

[L]WCODFONC  =3  : # Code fonction (1=entrée, 2=sortie, 3=changement emplacement)
[L]WGESLIBEMP="" : # Pour gestion libération emplacement
#----- Trace début de mise à jour d'une ligne détail -----#
If [M:STW]TRAFLG>2  Gosub TRACE_DEB_LIGNE From STKMAJSUP : Endif
#----- Contrôles élémentaires et valeurs par défaut sur ligne à traiter -----#
Gosub CTL_VALDEF_LIG From STKMAJ : If GOK<1  Return : Endif
#-----
Raz [F:STL],[F:SLF], [L]WDIFALLQTY, [L]WDIFALLQTA, [L]WSPLFLG, [L]WLASRCPDAT
#----- Changement d'emplacement normal -----#
If [M:STW]MAJCOD(I)<>"A"
  #----- Lecture des tables et Raz des cumuls si 1ère fois -----#
  If [L]WITMREF=""
    [L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
    Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
  Endif
  #----- Si rupture sur article ou site, maj cumuls article-site -----#
  If [M:STW]ITMREFLIG(I)<>[L]WITMREF | [M:STW]STOFCY<>[L]WFCY
  Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif

    If [M:STW]STOFCY<>[L]WFCY
      [L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
    Endif
    Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
  Endif
  #----- Sauvegarde caractéristiques de l'entrée -----#
  [L]WPCU_RCP      =[M:STW]PCU(I)
  [L]WPCUSTUCOE_RCP=[M:STW]PCUSTUCOE(I)
  [L]WQTYPCU_RCP   =[M:STW]QTYPCU(I)
  [L]WQTYSTU_RCP   =[M:STW]QTYSTU(I)
  [L]WQTYSTUACT_RCP=[M:STW]QTYSTUACT(I)
  #-----
  [L]WSTA_RCP      =[M:STW]STA(I)
  [L]WLOT_RCP      =[M:STW]LOT(I)
  [L]WSLO_RCP      =[M:STW]SLO(I)
  [L]WBPSLOT_RCP   =[M:STW]BPSLOT(I)
  #--- Issue 110327
  #[L]WSERNUM_RCP   =[M:STW]SERNUM(I) : # C'est en principe le même pour la sortie
  If [F:ITM]SERMGTCOD=4
    [L]WSERNUM_RCP=""
  Else
    [L]WSERNUM_RCP=[M:STW]SERNUM(I)
  Endif
  #---
  [L]WPALNUM_RCP   =[M:STW]PALNUM(I)
  [L]WCTRNUM_RCP   =[M:STW]CTRNUM(I)
  [L]WSTOCOU       =[M:STW]STOCOU(I)
  [L]WSTOFLD1_RCP  =[M:STW]STOFLD1(I)
  [L]WSTOFLD2_RCP  =[M:STW]STOFLD2(I)
  #--- Issue X3-53322
  [L]WLPNNUM_RCP   =[M:STW]LPNNUM(I)

  #----- Traitement des mouvements en attente -----#
  #      Uniquement livraisons de prêt ou de sous-traitance
  #      et génération seulement du mouvement en attente de sortie
  If [L]WUPDCOD=1
    #----- Traitement mouvement en attente de sortie -----#
    [L]WMAJITV=1 : [L]WFLUX=2 : # Code màj et flux de sortie de stock
    If [M:STW]MAJCOD(I)="A" [L]SIGN=+1 Else [L]SIGN=-1 : Endif
    Gosub MAJSOR_WAI From STKMAJ : If GOK<1  Return : Endif
    #----- Si splittage, supprimer la ligne et finir la sortie -----#
    If [L]WSPLFLG=1
      Dela I,1,[M:STW]NBLIG-1 [M:STW]NBLIG : [M:STW]NBLIG-=1
      Raz [L]WSPLFLG
      Gosub MAJSOR_WAI From STKMAJ : If GOK<1  Return : Endif
    Endif
    #----- Si rupture sur site, maj cumuls article-site -----#
    If [M:STW]TRSTYP=14 & [M:STW]TRFFCY<>[L]WFCY
      Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif
      [L]WFCY=[M:STW]TRFFCY : Gosub CHARG_PARAM From STKMAJ
      Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
    Endif
  #----- Traitement des autres mouvements -----#
  Else
    # Modification d'un retour de livraison de prêt ou de sous-traitance :
    # Si le chrono stock de la sortie initiale n'existait pas lors du
    # chargement dans le STKINT, la ligne de stock a du être recréé par
    # l'annulation --> le chrono stock doit être en ligne
    If find([M:STW]TRSTYP,18,33) & [L]WSTOCOU=0
       [L]WSTOCOU       = [F:STO]STOCOU
       [M:STW]STOCOU(I) = [F:STO]STOCOU
       [M:STW]LOC(I)    = [F:STO]LOC
       [M:STW]LOCTYP(I) = [F:STO]LOCTYP
       [M:STW]LOCCAT(I) = [F:STO]LOCCAT
       [M:STW]WRH(I)    = [F:STO]WRH
    Endif

    #----- Lecture ligne stock sortie pour récupération statut et lot de sortie -----#
    [L]WFIC="STOCK"
    [L]WCLE=[L]WFCY-num$([L]WSTOCOU)
    Read [STO] STO0=[L]WFCY;[L]WSTOCOU
    If fstat
      Call RSTA("STO",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Elsif [F:STO]ITMREF<>[M:STW]ITMREFLIG(I)
      [M:STW]ERRCOD=45 : Gosub TRT_ERR From STKMAJ : Return
    Endif

    If [F:STO]PCU=[L]WPCU_RCP & [F:STO]PCUSTUCOE=[L]WPCUSTUCOE_RCP
      Raz [L]WPCU_RCP,    [L]WPCUSTUCOE_RCP
      Raz [L]WQTYPCU_RCP, [L]WQTYSTU_RCP,   [L]WQTYSTUACT_RCP
    Endif

    If [M:STW]LOCDES(I)="" | [M:STW]LOCDES(I)=[M:STW]LOC(I)
       WGESLIBEMP="L"
    Endif

    #----- Création d'une nouvelle ligne dans [M:STW] si nécessaire -----#
    If [F:STO]PCU<>[F:ITM]STU
      If mod([M:STW]QTYSTU(I),[F:STO]PCUSTUCOE)<>0 &
&        fix([M:STW]QTYSTU(I)/[F:STO]PCUSTUCOE)<>0
        Gosub SPLITTAGE From STKMAJ
        If GOK<1 Return Endif
      Endif
    Endif
    # TS le 24.08.04 : à priori inutile et faux (on casse l'UC de destination)
    #----- Alignement de l'UC saisie par rapport à la ligne de stock -----#
    #If [M:STW]PCU(I)<>[F:STO]PCU & mod([M:STW]QTYSTU(I),[F:STO]PCUSTUCOE)=0
    #  [M:STW]PCU(I)      =[F:STO]PCU
    #  [M:STW]PCUSTUCOE(I)=[F:STO]PCUSTUCOE
    #  [M:STW]QTYPCU(I)   =[M:STW]QTYSTU(I)/[M:STW]PCUSTUCOE(I)
    #Endif
    #-----

    [L]WSTA_ISS   =[F:STO]STA
    [L]WLOT_ISS   =[F:STO]LOT
    [L]WSLO_ISS   =[F:STO]SLO
    [L]WBPSLOT_ISS=[F:STO]BPSLOT
    #--- Issue 110327
    #[L]WSERNUM_ISS =[F:STO]SERNUM
    If [F:ITM]SERMGTCOD=4
      [L]WSERNUM_ISS=""
    Else
      [L]WSERNUM_ISS=[F:STO]SERNUM
    Endif
    #---
    [L]WPALNUM_ISS=[F:STO]PALNUM
    [L]WCTRNUM_ISS=[F:STO]CTRNUM
    #--- Issue X3-109881 by TS
    #[L]WSTOCOU_ISS=[F:STO]STOCOU
    [L]WSTOCOU_ISS(WNB_ISS)=[F:STO]STOCOU
    #---
    [L]WSTOFLD1_ISS=[F:STO]STOFLD1
    [L]WSTOFLD2_ISS=[F:STO]STOFLD2
    #--- Issue X3-53322
    [L]WLPNNUM_ISS =[F:STO]LPNNUM

    [L]WLASRCPDAT =[F:STO]LASRCPDAT : # Date dernière entrée de la ligne stock sortie
    #----- Positionnement code màj cumuls article-site (ITMMVT) -----#
    If [M:STW]STOFCY   <>[M:STW]TRFFCY       |
&      [L]WSTA_RCP     <>[L]WSTA_ISS         |
&      [M:STW]LOCCAT(I)<>[M:STW]LOCDESCAT(I)
      [L]WMAJITV=1
    Endif

    #----- Traitement de la sortie -----#
    Gosub MAJEMP_SOR   : If GOK<1  Return : Endif
    #----- Si splittage, supprimer la ligne et finir la sortie -----#
    If [L]WSPLFLG=1

      If [L]WPCU_RCP=""
        Gosub MAJEMP_ENT   : If GOK<1  Return : Endif
        I+=1
      Else
        Dela I,1,[M:STW]NBLIG-1 [M:STW]NBLIG : [M:STW]NBLIG-=1
        # Issue 121417 - 2017-02-13 by CCC : delete corresponding values in SVW
        # but as qty are modified to get back original quantity for entry (see just after)
        # we have to sum values of PIND and PIND+1 in [M:SVWD]
        Call COPSVWD(I,I+1,1,1,3) From STKVALECR
        Call DEL_SVW(I) From STKVALMAJ
      Endif

      Raz [L]WSPLFLG
      Gosub MAJEMP_SOR : If GOK<1  Return : Endif
    Endif
    #----- Si rupture sur site, maj cumuls article-site -----#
    If [M:STW]TRSTYP=14 & [M:STW]TRFFCY<>[L]WFCY
      Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif
      [L]WFCY=[M:STW]TRFFCY : Gosub CHARG_PARAM From STKMAJ
      Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
      [L]WMAJITV=1
    Endif
    #----- Restitution caractéristiques de l'entrée -----#

    If [L]WPCU_RCP<>""
      [M:STW]PCU(I)      =[L]WPCU_RCP
      [M:STW]PCUSTUCOE(I)=[L]WPCUSTUCOE_RCP
      [M:STW]QTYPCU(I)   =[L]WQTYPCU_RCP
      [M:STW]QTYSTU(I)   =[L]WQTYSTU_RCP
      [M:STW]QTYSTUACT(I)=[L]WQTYSTUACT_RCP
    Endif

    #----- Traitement de l'entrée -----#
    Gosub MAJEMP_ENT   : If GOK<1  Return : Endif
  Endif
#----- Annulation d'un changement d'emplacement -----#
Else
  [L]WSTOCOU_RCP=[M:STW]STOCOU(I)
  #----- Lecture des tables et Raz des cumuls si 1ère fois -----#
  If [L]WITMREF=""
    If [M:STW]TRSTYP=14
       [L]WFCY=[M:STW]TRFFCY : Gosub CHARG_PARAM From STKMAJ
    Else
       [L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
    Endif
#TS---
    Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
  Endif
  #----- Si rupture sur article ou site, maj cumuls article-site -----#
  If [M:STW]ITMREFLIG(I)<>[L]WITMREF | ([M:STW]TRSTYP=14 & [M:STW]TRFFCY<>[L]WFCY)
    Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif
    If [M:STW]TRFFCY<>[L]WFCY
      [L]WFCY=[M:STW]TRFFCY : Gosub CHARG_PARAM From STKMAJ
    Endif
    Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
  Endif
  #----- Sauvegarde caractéristiques de la sortie -----#
  [L]WPCU_ISS      =[M:STW]PCU(I)
  [L]WPCUSTUCOE_ISS=[M:STW]PCUSTUCOE(I)
  [L]WQTYPCU_ISS   =[M:STW]QTYPCU(I)
  [L]WQTYSTU_ISS   =[M:STW]QTYSTU(I)
  [L]WQTYSTUACT_ISS=[M:STW]QTYSTUACT(I)
  #-----
  [L]WOWNER_ISS    =[M:STW]OWNER(I)
  [L]WSTA_ISS      =[M:STW]STA(I)
  [L]WLOT_ISS      =[M:STW]LOT(I)
  [L]WSLO_ISS      =[M:STW]SLO(I)
  [L]WBPSLOT_ISS   =[M:STW]BPSLOT(I)
  #--- Issue 110327
  #[L]WSERNUM_ISS   =[M:STW]SERNUM(I)
  If [F:ITM]SERMGTCOD=4
    [L]WSERNUM_ISS=""
  Else
    [L]WSERNUM_ISS=[M:STW]SERNUM(I)
  Endif
  #---
  [L]WPALNUM_ISS   =[M:STW]PALNUM(I)
  [L]WCTRNUM_ISS   =[M:STW]CTRNUM(I)
  [L]WMVTSEQ_ISS   =[M:STW]MVTSEQ(I)
  [L]WMVTIND_ISS   =[M:STW]MVTIND(I)
  [L]WSTOFLD1_ISS  =[M:STW]STOFLD1(I)
  [L]WSTOFLD2_ISS  =[M:STW]STOFLD2(I)
  #--- Issue X3-53322
  [L]WLPNNUM_ISS   =[M:STW]LPNNUM(I)

  #----- Traitement des mouvements en attente -----#
  #      Uniquement livraisons de prêt ou de sous-traitance
  #      et génération seulement du mouvement en attente de sortie
  If [L]WUPDCOD=1
    #----- Si rupture sur site, maj cumuls article-site -----#
    If [M:STW]STOFCY<>[L]WFCY
      Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif
      [L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
      Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
    Endif
    #----- Traitement mouvement de sortie en attente -----#
    [L]WMAJITV=1 : [L]WFLUX=2 : # Code màj et flux de sortie de stock
    If [M:STW]MAJCOD(I)="A" [L]SIGN=+1 Else [L]SIGN=-1 : Endif
    Gosub MAJSOR_WAI From STKMAJ : If GOK<1  Return : Endif
  #----- Traitement des autres mouvements -----#
  Else
    #----- Recherche du mvt d'entrée si annulation changement d'emplacement -----#
    Read [STO] STO0=[L]WFCY;[M:STW]STOCOU(I)
    If fstat
      Call RSTA("STO",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Elsif [F:STO]ITMREF<>[M:STW]ITMREFLIG(I) | [F:STO]STOFCY<>[L]WFCY
      [M:STW]ERRCOD=45 : Gosub TRT_ERR From STKMAJ : Return
    Endif

    #--- Issue 110327
    If [F:ITM]SERMGTCOD=4
      WFIL='SERDEB=[M:STW]SERNUM(I)'
    Else
      WFIL='1=1'
    Endif
    #---

    #--- Issue X3-53322 : ajout LPNNUM
    Filter [STJ1] Where STOFCY   =[L]WFCY
&                     & VCRTYP   =[M:STW]VCRTYP
&                     & VCRNUM   =[M:STW]VCRNUM
&                     & VCRLIN   =[M:STW]VCRLIN
&                     & ITMREF   =[M:STW]ITMREFLIG(I)
&                     & IPTDAT   =[M:STW]IPTDAT
&                     & LOT      =[F:STO]LOT
&                     & SLO      =[F:STO]SLO
&                     & BPSLOT   =[F:STO]BPSLOT
&                     & PALNUM   =[F:STO]PALNUM
&                     & CTRNUM   =[F:STO]CTRNUM
&                     & STA      =[F:STO]STA
&                     & LOC      =[F:STO]LOC
&                     & PCU      =[F:STO]PCU
&                     & PCUSTUCOE=[F:STO]PCUSTUCOE
&                     & SERNUM   =[F:STO]SERNUM
&                     & QLYCTLDEM=[F:STO]QLYCTLDEM
&                     & OWNER    =[F:STO]OWNER
&                     & STOFLD1  =[F:STO]STOFLD1
&                     & STOFLD2  =[F:STO]STOFLD2
&                     & LPNNUM   =[F:STO]LPNNUM
&                     & QTYSTU   =[M:STW]QTYSTU(I)
&                     & REGFLG<>2
&                     & evalue(WFIL)                  : #--- Issue 110327
    Read [STJ1] STJ1 First
    Filter [STJ1]
    If fstat  Raz [F:STJ1] : [M:STW]ERRCOD=28 : Gosub TRT_ERR From STKMAJ : Return : Endif
    #-----
    [M:STW]LOCDES(I)   =[F:STO]LOC
    [M:STW]LOCDESTYP(I)=[F:STO]LOCTYP
    [M:STW]LOCDESCAT(I)=[F:STO]LOCCAT
    [M:STW]WRHDES(I)   =[F:STO]WRH
    [M:STW]PCU(I)      =[F:STO]PCU
    [M:STW]PCUSTUCOE(I)=[F:STO]PCUSTUCOE
    [M:STW]QTYPCU(I)   =[M:STW]QTYSTU(I)/[M:STW]PCUSTUCOE(I)
    #----
    [L]WSTA_RCP        =[F:STO]STA
    [L]WLOT_RCP        =[F:STO]LOT
    [L]WSLO_RCP        =[F:STO]SLO
    [L]WBPSLOT_RCP     =[F:STO]BPSLOT
    #--- Issue 110327
    #[L]WSERNUM_RCP    =[F:STO]SERNUM
    If [F:ITM]SERMGTCOD=4
      [L]WSERNUM_RCP=""
    Else
      [L]WSERNUM_RCP=[F:STO]SERNUM
    Endif
    #---
    [L]WPALNUM_RCP     =[F:STO]PALNUM
    [L]WCTRNUM_RCP     =[F:STO]CTRNUM
    [L]WSTOFLD1_RCP    =[F:STO]STOFLD1
    [L]WSTOFLD2_RCP    =[F:STO]STOFLD2
    #--- Issue X3-53322
    [L]WLPNNUM_RCP     =[F:STO]LPNNUM
    [L]WQLYCTLDEM_RCP  =[F:STO]QLYCTLDEM
    [L]WMVTSEQ_RCP     =[F:STJ1]MVTSEQ
    [L]WMVTIND_RCP     =[F:STJ1]MVTIND

    If [M:STW]LOCDES(I)="" | [M:STW]LOCDES(I)=[M:STW]LOC(I)
       WGESLIBEMP="L"
    Endif

    #----- Recherche ligne stock sortie avec caractéristiques identiques -----#
    nolign=I+1 : [F:STJ1]=[M:STW]
    [L]WFCY          =[M:STW]STOFCY
    [F:STJ1]PCU      =[L]WPCU_ISS
    [F:STJ1]PCUSTUCOE=[L]WPCUSTUCOE_ISS

   #--- Issue 110327
   If [F:ITM]SERMGTCOD=4 : [F:STJ1]SERNUM = "" : Endif
   #---

    #--- Issue X3-53322 : Ajout LPN
    Call CLESTO([L]WFCY,[L]WITMREF,[F:STJ1]LOT,[F:STJ1]SLO,[F:STJ1]BPSLOT,
&               [F:STJ1]PALNUM,[F:STJ1]CTRNUM,[F:STJ1]STA,[F:STJ1]LOC,[F:STJ1]PCU,
&               [F:STJ1]PCUSTUCOE,[F:STJ1]SERNUM,[F:STJ1]QLYCTLDEM,[F:STJ1]OWNER,
&               [F:STJ1]STOFLD1,[F:STJ1]STOFLD2,[F:STJ1]LPNNUM,[L]WSTOCOU) From STKLIB

    #----- Récréation ligne de stock supprimée à cause des qtés à zéro -----#
    If [L]WSTOCOU=0
      #----- Attribution du chrono stock -----#
      Call NUMERO(GSTKCPT(0),[L]WFCY,[M:STW]IPTDAT,"",[L]WPARAM,[L]WRET) From SUBANM
      If GOK<0
        [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
      Elsif GOK<1 | [L]WRET<>0
        [M:STW]ERRCOD=50 : [L]WCTEUR=GSTKCPT(0) : Gosub TRT_ERR From STKMAJ : Return
      Endif
      [L]WSTOCOU      =val([L]WPARAM)
      #-----
      Raz [F:STO]
      [F:STO]=[F:STC] : # Récupération LOCTYP, LOCCAT ...etc
      [F:STO]=[F:STJ1]
      [F:STO]STOCOU=[L]WSTOCOU
      Raz [F:STO]QTYPCU, [F:STO]QTYSTU, [F:STO]QTYSTUACT
      [F:STO]LASRCPDAT=date$
      [F:STO]LASISSDAT=[M:STW]IPTDAT
      Gosub ECRSTO From STKMAJ : If GOK<1  Return : Endif
    Endif
    If [M:STW]TRSTYP=14 [L]WFCY=[M:STW]TRFFCY Endif
    #----- Sauvegarde Chrono stock de la sortie -----#
    #--- Issue X3-109881 by TS
    #[L]WSTOCOU_ISS=[L]WSTOCOU
    [L]WSTOCOU_ISS(WNB_ISS)=[L]WSTOCOU
    #---
    #----- Positionnement code màj cumuls article-site (ITMMVT) -----#
    If [M:STW]STOFCY   <>[M:STW]TRFFCY       |
&      [L]WSTA_RCP     <>[L]WSTA_ISS         |
&      [M:STW]LOCCAT(I)<>[M:STW]LOCDESCAT(I)
       [L]WMAJITV=1
    Endif
    #----- Traitement de l'annulation d'entrée -----#
    [M:STW]STA(I)      =[L]WSTA_RCP
    #--- Issue 110327
    #[M:STW]SERNUM(I)   =[L]WSERNUM_RCP
    If [F:ITM]SERMGTCOD<>4 : [M:STW]SERNUM(I)=[L]WSERNUM_RCP : Endif
    #---
    [M:STW]PALNUM(I)   =[L]WPALNUM_RCP
    [M:STW]CTRNUM(I)   =[L]WCTRNUM_RCP
    [M:STW]STOFLD1(I)  =[L]WSTOFLD1_RCP
    [M:STW]STOFLD2(I)  =[L]WSTOFLD2_RCP
    [M:STW]QLYCTLDEM(I)=[L]WQLYCTLDEM_RCP
    #--- Issue X3-53322
    [M:STW]LPNNUM(I)   =[L]WLPNNUM_RCP

    Gosub MAJEMP_ENT    : If GOK<1  Return : Endif
    [L]WLASRCPDAT=[F:STO]LASRCPDAT
    #----- Si rupture sur site, maj cumuls article-site -----#
    If [M:STW]STOFCY<>[L]WFCY
      Gosub MAJ_ITMMVT From STKMAJ   : If GOK<1  Return : Endif
      [L]WFCY=[M:STW]STOFCY : Gosub CHARG_PARAM From STKMAJ
      Gosub LEC_FICHIERS From STKMAJ : If GOK<1  Return : Endif
      [L]WMAJITV=1
    Endif
    #----- Restitution caractéristiques de la sortie -----#
    [M:STW]PCU(I)      =[L]WPCU_ISS
    [M:STW]PCUSTUCOE(I)=[L]WPCUSTUCOE_ISS
    [M:STW]QTYPCU(I)   =[L]WQTYPCU_ISS
    [M:STW]QTYSTU(I)   =[L]WQTYSTU_ISS
    [M:STW]QTYSTUACT(I)=[L]WQTYSTUACT_ISS
    #--- Issue X3-109881 by TS
    #[M:STW]STOCOU(I)   =[L]WSTOCOU_ISS
    [M:STW]STOCOU(I)   =[L]WSTOCOU_ISS(WNB_ISS)
    #---
    #--- Issue 110327
    #[M:STW]SERNUM(I)   =[L]WSERNUM_ISS
    If [F:ITM]SERMGTCOD<>4 : [M:STW]SERNUM(I)=[L]WSERNUM_ISS : Endif
    #---
    [M:STW]OWNER(I)    =[L]WOWNER_ISS
    Raz [M:STW]QLYCTLDEM(I)
    #----- Traitement de l'annulation de sortie -----#
    Gosub MAJEMP_SOR    : If GOK<1  Return : Endif
  Endif
Endif
#----- Màj fichier lot (STOLOT) -----#
Raz [L]WFLUX
If [L]WUPDCOD=2 : # Si mouvements en attente pas de màj de lot !
  Gosub MAJEMP_STL : If GOK<1  Return : Endif : # Réécriture lot
Endif
#-----
Return


#--- TS - STOLOTFCY start
#------------------------------------------------
# Maj du lot-site lors d'un transfert inter-site
#------------------------------------------------
$MAJ_STOLOTFCY

If [M:STW]TRSTYP<>14 Return Endif

[L]WFIC="STOLOTFCY"
[L]WCLE=[M:STW]ITMREFLIG(I)-[M:STW]LOT(I)-[M:STW]SLO(I)-WFCY
#--- Issue 119372 : ajout With Lockwait=3
#--- Issue X3-74576 : suppression lockwait=3
Readlock [SLF] SLF0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I);WFCY
Case fstat
  When 1
    GLOCK="$STOLOTFCY"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
  When 4,5
    Read [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
    Raz [F:SLF]
    [F:SLF] = [F:STL]
    [F:SLF]STOFCY   =WFCY
    [F:SLF]CUR      =GSYSCUR
    Call ECRSLF From STKLIB
    If fstat
      Call FSTA("SLF") From GLOCK
      [M:STW]ERRCOD=70 : [L]WFIC="STOLOT" : Gosub TRT_ERR From STKMAJ : Return
    Endif
    If [M:STW]TRAFLG>1 & [L]WLOT<>""
      #----- Lot XXXXXXX YYYYYYY ZZZZZ créé ! -----#
      [L]WMESSAGE=mess(43,197,1)+"/"+mess(498,197,1)-[L]WITMREF-[L]WLOT-[M:STW]SLO(I)-WFCY-mess(233,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    #--- Issue 119372 : ajout With Lockwait=3
    #--- Issue X3-74576 : suppression lockwait=3
    Readlock [SLF] SLF0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I);WFCY
Endcase

#--- Maj des quantités lot
If [L]WFLUX=1
  Case left$([L]WSTA_RCP,1)
    When "A" : [F:SLF]AAACUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    When "Q" : [F:SLF]QQQCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    When "R" : [F:SLF]RRRCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
  Endcase
Elsif [L]WFLUX=2
  Case left$([L]WSTA_ISS,1)
    When "A" : [F:SLF]AAACUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    When "Q" : [F:SLF]QQQCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    When "R" : [F:SLF]RRRCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
  Endcase
Endif

#--- Maj date dernière entrée ou sortie
If [M:STW]MAJCOD(I)<>"A" & [L]SENS=1
  If [L]WFLUX=1 & [F:SLF]LASRCPDAT<[M:STW]IPTDAT
    [F:SLF]LASRCPDAT=[M:STW]IPTDAT
  Elsif [L]WFLUX=2 & [F:SLF]LASISSDAT<[M:STW]IPTDAT
    [F:SLF]LASISSDAT=[M:STW]IPTDAT
  Endif
Endif

Call MAJVALLOT(WFLUX,I,WAMTDEV_LOT) From STKVALMAJ2

Call REWSLF From STKLIB
If fstat
  Call FSTA("SLF") From GLOCK
  [M:STW]ERRCOD=70 : [L]WFIC="STOLOTFCY" : Gosub TRT_ERR From STKMAJ : Return
Endif
If [M:STW]TRAFLG>2
  [L]WCLE=[F:SLF]ITMREF-[F:SLF]LOT-[F:SLF]SLO-[F:SLF]STOFCY
  [L]WFIC="STOLOTFCY" : [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif

Return
#--- TS - STOLOTFCY end


#---------------------------------#
# Changement d'emplacement sortie #
#---------------------------------#
$MAJEMP_SOR
[L]WFLUX=2 : # Flux de sortie de stock
[M:STW]LOT(I)   =[L]WLOT_ISS
[M:STW]SLO(I)   =[L]WSLO_ISS
#[M:STW]BPSLOT(I)=[L]WBPSLOT_ISS
If [M:STW]MAJCOD(I)="A" [L]SIGN=+1 Else [L]SIGN=-1 : Endif
#----- Traitement du fichier lot (STOLOT) -----#
If [F:STL]ITMREF<>[M:STW]ITMREFLIG(I) |
&  [F:STL]LOT   <>[M:STW]LOT(I)       |
&  [F:STL]SLO   <>[M:STW]SLO(I)
  #----- Réécriture enregistrement lot précédent (STOLOT) -----#
  If [F:STL]ITMREF<>""
    Gosub MAJEMP_STL : If GOK<1  Return : Endif : # Réécriture lot
  Endif
  #----- Lecture enregistrement lot (STOLOT) -----#
  [L]WFIC="STOLOT"
  [L]WCLE=[M:STW]ITMREFLIG(I)-[M:STW]LOT(I)-[M:STW]SLO(I)
  #--- Issue 119372 : ajout With Lockwait=3
  #--- Issue X3-74576 : suppression lockwait=3
  Readlock [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
  If fstat=1
    GLOCK="$STOLOT"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
  Elsif fstat
    Call RSTA("STL",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
  Endif

  If [M:STW]TRSTYP<>14 : # TS - STOLOTFCY
    [L]WFIC="STOLOTFCY"
    [L]WCLE=[M:STW]ITMREFLIG(I)-[M:STW]LOT(I)-[M:STW]SLO(I)-WFCY
    #--- Issue 119372 : ajout With Lockwait=3
    #--- Issue X3-74576 : suppression lockwait=3
    Readlock [SLF] SLF0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I);WFCY
    If fstat=1
      GLOCK="$STOLOTFCY"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
    Elsif fstat
      Call RSTA("SLF",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
    Endif
  Endif                : # TS - STOLOTFCY

  #----- Test si modification caratéristiques du lot -----#
  # si controle qualite sauf si echantilonnage (smptyp > 1)   # hcb 50343
  If [M:STW]TRSTYP=8 & [M:STW]MAJCOD(I)="C" & [F:ITF]SMPTYP = 1
    If [M:STW]REFPER    (I) <>[F:STL]REFPER    |
&      [M:STW]SHL       (I) <>[F:STL]SHL       |
&      [M:STW]SHLDAT    (I) <>[F:STL]SHLDAT    |
&      [M:STW]SHLUOM    (I) <>[F:STL]SHLUOM    |
&      [M:STW]SHLLTI    (I) <>[F:STL]SHLLTI    |
&      [M:STW]SHLLTIUOM (I) <>[F:STL]SHLLTIUOM |
&      [M:STW]NEWLTIDAT (I) <>[F:STL]NEWLTIDAT |
&      [M:STW]DLU       (I) <>[F:STL]DLU       |
&      [M:STW]DLUDAT    (I) <>[F:STL]DLUDAT    |
&      [M:STW]BPSLOT    (I) <>[F:STL]BPSLOT    |
&      [M:STW]USRFLD1   (I) <>[F:STL]USRFLD1   |
&      [M:STW]USRFLD2   (I) <>[F:STL]USRFLD2   |
&      [M:STW]USRFLD3   (I) <>[F:STL]USRFLD3   |
&      [M:STW]USRFLD4   (I) <>[F:STL]USRFLD4
       [F:STL]REFPER    =[M:STW]REFPER   (I)
       [F:STL]SHL       =[M:STW]SHL      (I)
       [F:STL]SHLDAT    =[M:STW]SHLDAT   (I)
       [F:STL]SHLUOM    =[M:STW]SHLUOM   (I)
       [F:STL]SHLLTI    =[M:STW]SHLLTI   (I)
       [F:STL]SHLLTIUOM =[M:STW]SHLLTIUOM(I)
       [F:STL]NEWLTIDAT =[M:STW]NEWLTIDAT(I)
       [F:STL]DLU       =[M:STW]DLU      (I)
       [F:STL]DLUDAT    =[M:STW]DLUDAT   (I)
       [F:STL]BPSLOT    =[M:STW]BPSLOT   (I)
       [F:STL]USRFLD1   =[M:STW]USRFLD1  (I)
       [F:STL]USRFLD2   =[M:STW]USRFLD2  (I)
       [F:STL]USRFLD3   =[M:STW]USRFLD3  (I)
       [F:STL]USRFLD4   =[M:STW]USRFLD4  (I)
       [F:STL]ECCVALMAJ =[M:STW]ECCVALMAJ(I)
       [F:STL]ECCVALMIN =[M:STW]ECCVALMIN(I)
       [L]WMAJSTL=1
    Endif
    If [M:STW]POT(I)<>[F:STL]POT     |
&      [M:STW]ACT(I)<>[F:STL]ACT
       [F:STL]POT=[M:STW]POT(I)
       [F:STL]ACT=[M:STW]ACT(I)
       If [F:STL]ACT=0 [F:STJ]ACT=1   : Endif
       If [F:STJ]POT=0 [F:STJ]POT=100 : Endif
      [L]WMAJSTL=2
    Endif
  Endif
Endif
[M:STW]BPSLOT(I)=[L]WBPSLOT_ISS

If [M:STW]TRSTYP<>14 : # TS - STOLOTFCY
  #----- Mise à jour du fichier lot site -----#
  If [L]WSTA_ISS<>[L]WSTA_RCP | [L]WLOT_ISS<>[L]WLOT_RCP | [L]WSLO_ISS<>[L]WSLO_RCP
    #----- Mise à jour des quantités lot -----#
    Case left$([L]WSTA_ISS,1)
      When "A" : [F:SLF]AAACUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
      When "Q" : [F:SLF]QQQCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
      When "R" : [F:SLF]RRRCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    Endcase
    #-----
    If [F:SLF]AAACUMQTY<0 | [F:SLF]QQQCUMQTY<0 | [F:SLF]RRRCUMQTY<0
      [M:STW]ERRCOD=12 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    #----- Mise à jour date dernière sortie sauf en annulation -----#
    If [L]WLOT_ISS="" & [L]WLOT_ISS<>[L]WLOT_RCP
      If [M:STW]MAJCOD(I)<>"A" & [L]SENS=1 & [F:SLF]LASISSDAT<[M:STW]IPTDAT
        [F:SLF]LASISSDAT=[M:STW]IPTDAT
      Endif
    Endif
  Endif
  Call MAJVALLOT(WFLUX,I,WAMTDEV_LOT) From STKVALMAJ2
# TS - STOLOTFCY deb
Else
  # Maj du lot-site lors d'un transfert inter-site
  Gosub MAJ_STOLOTFCY
Endif
# TS - STOLOTFCY end

#----- Contrôle gestion des no série -----#
Gosub CTL_SERIE From STKMAJSER : If GOK<1  Return : Endif

#----- Si changement de site-----#
If [M:STW]STOFCY<>[M:STW]TRFFCY
  #----- Dernière date de sortie et comptage des sorties -----#
  If [L]WMAJCOD="C"    : # Création
    If [L]SENS=1  [L]WCTR_ISS=+1 : [L]WLASDAT_ISS=[M:STW]IPTDAT : Endif
  Elsif [L]WMAJCOD="A" : # Annulation
    If [L]SENS=1  [L]WCTR_ISS=-1 : Endif
  Endif
Endif

# En rupture d'emplacement, alimentation de la globale GSTKLIBEMP à 1
# pour optimiser les performances en maj de la ligne de stock.
# Appel au sous-programme STKLIBEMP si GSTKLIBEMP=1
Raz GSTKLIBEMP
If [M:STW]LOC(I)<>""
  If (I>=dim([M:STW]ITMREFLIG)-1 | [M:STW]LOC(I)<>[M:STW]LOC(I+1)) & WGESLIBEMP<>"L"
    GSTKLIBEMP=1
  Endif
Endif
#----- Màj ligne stock (STOCK) et écriture mvt de sortie (STOJOU) -----#
[M:STW]STA(I)   =[L]WSTA_ISS
[M:STW]PALNUM(I)=[L]WPALNUM_ISS
[M:STW]CTRNUM(I)=[L]WCTRNUM_ISS
[M:STW]STOFLD1(I)=[L]WSTOFLD1_ISS
[M:STW]STOFLD2(I)=[L]WSTOFLD2_ISS
#--- Issue X3-53322
[M:STW]LPNNUM(I) =[L]WLPNNUM_ISS
[L]WMVTSEQ      =[L]WMVTSEQ_ISS
[L]WMVTIND      =[L]WMVTIND_ISS
Gosub MAJSOR_STOSTJ From STKMAJS : If GOK<1  Return : Endif

#--- TS le 21.09.06
# Pour traiter la maj du transféré et du transit, si changement d'emplacement
# inter-site (livraison s-traitance, de prêt, retour s-traitance, de prêt)
If [M:STW]TRSTYP<>14 & [M:STW]TRFFCY<>"" & [M:STW]TRFFCY<>[M:STW]STOFCY
  If [L]SENS=+1
    [L]WQTYACT_TRA-=[M:STW]QTYSTUACT(I)*[L]SIGN
  Else
    [L]WQTYACT_TRF-=[M:STW]QTYSTUACT(I)*[L]SIGN
  Endif
Endif

[M:STW]STA(I)    =[L]WSTA_RCP
[M:STW]PALNUM(I) =[L]WPALNUM_RCP
[M:STW]CTRNUM(I) =[L]WCTRNUM_RCP
[M:STW]STOFLD1(I)=[L]WSTOFLD1_RCP
[M:STW]STOFLD2(I)=[L]WSTOFLD2_RCP
#--- Issue X3-53322
[M:STW]LPNNUM(I) =[L]WLPNNUM_RCP

Return


#---------------------------------#
# Changement d'emplacement entrée #
#---------------------------------#
$MAJEMP_ENT


[L]WFLUX=1 : # Flux d'entrée en stock

#--- Issue 89625
#If [M:STW]TRSTYP=14
#   [M:STW]OWNER(I)=[M:STW]TRFFCY
#Endif
  If [M:STW]TRSTYP=14 & [M:STW]OWNER(I)=[M:STW]STOFCY
    [M:STW]OWNER(I)=[M:STW]TRFFCY
  Endif
#---

[M:STW]LOT(I)   =[L]WLOT_RCP
[M:STW]SLO(I)   =[L]WSLO_RCP
[M:STW]BPSLOT(I)=[L]WBPSLOT_RCP
If [M:STW]MAJCOD(I)="A" [L]SIGN=-1 Else [L]SIGN=+1 : Endif
#----- Traitement du fichier lot (STOLOT) -----#
If [F:STL]ITMREF<>[M:STW]ITMREFLIG(I) |
&  [F:STL]LOT   <>[M:STW]LOT(I)       |
&  [F:STL]SLO   <>[M:STW]SLO(I)
  #----- Réécriture enregistrement lot précédent (STOLOT) -----#
  If [F:STL]ITMREF<>""
    Gosub MAJEMP_STL : If GOK<1  Return : Endif : # Réécriture lot
  Endif
  #----- Lecture enregistrement lot et création si nécessaire (STOLOT) -----#
  Gosub LECSTL From STKMAJ : If GOK<1  Return : Endif
Endif

If [M:STW]TRSTYP<>14 : # TS - STOLOTFCY
  #----- Mise à jour du fichier lot -----#
  If [L]WSTA_ISS<>[L]WSTA_RCP | [L]WLOT_ISS<>[L]WLOT_RCP | [L]WSLO_ISS<>[L]WSLO_RCP
    #----- Mise à jour des quantités lot -----#
    Case left$([L]WSTA_RCP,1)
      When "A" : [F:SLF]AAACUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
      When "Q" : [F:SLF]QQQCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
      When "R" : [F:SLF]RRRCUMQTY+=[M:STW]QTYSTU(I)*[L]SIGN
    Endcase
    #-----
    If [F:SLF]AAACUMQTY<0 | [F:SLF]QQQCUMQTY<0 | [F:SLF]RRRCUMQTY<0
      [M:STW]ERRCOD=12 : Gosub TRT_ERR From STKMAJ : Return
    Endif
    #----- Mise à jour date dernière entrée sauf en annulation -----#
    If [L]WLOT_ISS="" & [L]WLOT_ISS<>[L]WLOT_RCP
      If [M:STW]MAJCOD(I)<>"A" & [L]SENS=1 & [F:SLF]LASRCPDAT<[M:STW]IPTDAT
        [F:SLF]LASRCPDAT=[M:STW]IPTDAT
      Endif
    Endif
  Endif
  Call MAJVALLOT(WFLUX,I,WAMTDEV_LOT) From STKVALMAJ2
# TS - STOLOTFCY deb
Else
  # Maj du lot-site lors d'un transfert inter-site
  Gosub MAJ_STOLOTFCY
Endif
# TS - STOLOTFCY end

#----- Si changement de site -----#
If [M:STW]STOFCY<>[M:STW]TRFFCY
  #----- Dernière date d'entrée et comptage des entrées -----#
  If [L]WMAJCOD="C"    : # Création
    If [L]SENS=1  [L]WCTR_RCP=+1 : [L]WLASDAT_RCP=[M:STW]IPTDAT : Endif
  Elsif [L]WMAJCOD="A" : # Annulation
    If [L]SENS=1  [L]WCTR_RCP=-1 : Endif
  Endif
Endif

#----- Traitement de mise à jour des entrées (STOCK, STOSER, STOJOU) -----#
[L]WLOC_SVG        =[M:STW]LOC(I)
[L]WLOCTYP_SVG     =[M:STW]LOCTYP(I)
[L]WLOCCAT_SVG     =[M:STW]LOCCAT(I)
[L]WWRH_SVG        =[M:STW]WRH(I)
[M:STW]LOC(I)      =[M:STW]LOCDES(I)
[M:STW]LOCTYP(I)   =[M:STW]LOCDESTYP(I)
[M:STW]LOCCAT(I)   =[M:STW]LOCDESCAT(I)
[M:STW]WRH(I)      =[M:STW]WRHDES(I)
[M:STW]LOCDES(I)   =[L]WLOC_SVG
[M:STW]LOCDESTYP(I)=[L]WLOCTYP_SVG
[M:STW]LOCDESCAT(I)=[L]WLOCCAT_SVG
[M:STW]WRHDES(I)   =[L]WWRH_SVG
#----- Contrôle numéros de série -----#
Gosub CTL_SERIE  From STKMAJSER  : If GOK<1  Return : Endif
#----- Mise à jour de l'entrée -----#
Gosub MAJENT_TRT From STKMAJE : If GOK<1  Return : Endif
#-----
[M:STW]LOCDES(I)   =[M:STW]LOC(I)
[M:STW]LOCDESTYP(I)=[M:STW]LOCTYP(I)
[M:STW]LOCDESCAT(I)=[M:STW]LOCCAT(I)
[M:STW]WRHDES(I)   =[M:STW]WRH(I)
[M:STW]LOC(I)      =[L]WLOC_SVG
[M:STW]LOCTYP(I)   =[L]WLOCTYP_SVG
[M:STW]LOCCAT(I)   =[L]WLOCCAT_SVG
[M:STW]WRH(I)      =[L]WWRH_SVG
Return


#-------------------------------------------------------------#
# Réécriture du lot dans le cas d'un changement d'emplacement #
#-------------------------------------------------------------#
$MAJEMP_STL
If [L]WSTA_ISS<>[L]WSTA_RCP |
&  [L]WLOT_ISS<>[L]WLOT_RCP |
&  [L]WSLO_ISS<>[L]WSLO_RCP |
&  [L]WMAJSTL <>0
   Call REWSTL From STKLIB
   If fstat
      Call FSTA("STL") From GLOCK
     [M:STW]ERRCOD=70 : [L]WFIC="STOLOT" : Gosub TRT_ERR From STKMAJ : Return
   Endif

   If [M:STW]TRAFLG>2
      [L]WCLE=[F:STL]ITMREF-[F:STL]LOT-[F:STL]SLO
      [L]WFIC="STOLOT" : [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
   Endif

   If [M:STW]TRSTYP<>14 : # TS - STOLOTFCY
      Call REWSLF From STKLIB
      If fstat
         Call FSTA("SLF") From GLOCK
         [M:STW]ERRCOD=70 : [L]WFIC="STOLOTFCY" : Gosub TRT_ERR From STKMAJ : Return
      Endif
      If [M:STW]TRAFLG>2
         [L]WCLE=[F:SLF]ITMREF-[F:SLF]LOT-[F:SLF]SLO-[F:SLF]STOFCY
         [L]WFIC="STOLOTFCY" : [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
      Endif
   Endif                : # TS - STOLOTFCY

   If [L]WMAJSTL=2 & [F:STL]LOT=[L]WLOT_RCP & [F:STL]SLO=[L]WSLO_RCP
      Gosub MAJ_STOCK_LOT
   Endif
Else
  Unlock [STL] : # Déblocage du ReadLock sans réécriture !
  If [M:STW]TRAFLG>2
    [L]WCLE=[F:STL]ITMREF-[F:STL]LOT-[F:STL]SLO
    [L]WFIC="STOLOT" : [L]WMESSAGE=mess(478,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
Endif
Raz [L]WMAJSTL
Return


$MAJ_STOCK_LOT
#------------------------------------------------------------#
# Màj des lignes de stock suite à changement de titre du lot #
#------------------------------------------------------------#
[L]WFIC="STOCK"
[L]WCLE=[F:STL]ITMREF-[M:STW]TRFFCY-[F:STL]LOT-[F:STL]SLO
For [STO] STO3 Where ITMREF=[F:STL]ITMREF
&                  & STOFCY=[M:STW]TRFFCY
&                  & LOT   =[F:STL]LOT
&                  & SLO   =[F:STL]SLO
  #----- Les quantités allouée et en traitement doivent être nulles -----#
 #If [F:STO]CUMALLQTY<>0 | [F:STO]CUMWIPQTY<>0                             # hcb X3-43207
#  [M:STW]ERRCOD=44 : Gosub TRT_ERR From STKMAJ : Break                 # hcb X3-43207
#Endif                                                                  # hcb X3-43207
  #-----
  #--- Issue 116401 : ajout With lockwait=3
  #--- Issue X3-74576 : suppression lockwait=3
  Readlock [STO] Curr
  If fstat=1
    GLOCK="$STOCK"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Break
  Elsif fstat
    Call RSTA("STO",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Break
  Endif
  WQTYSTUACT_SVG = [F:STO]QTYSTUACT
  Case [F:ITF]STOMGTCOD
    When 3 : [F:STO]QTYSTUACT=arr([F:STO]QTYSTU*[F:STL]POT/100,10^-[L]WDEC_US)
    When 4 : [F:STO]QTYSTUACT=arr([F:STO]QTYSTU*[F:STL]ACT,10^-[L]WDEC_US)
  Endcase
  If [L]WMAJCODSTO="M"
     Call REWSTO("L",[L]WRET) From STKLIB
  Else
     Call REWSTO(WGESLIBEMP,[L]WRET) From STKLIB
  Endif
  Case [L]WRET
    When 1
      [L]WFIC="STOLOC"
      [L]WCLE=[M:STW]TRFFCY-[F:STO]LOC
      GLOCK="$STOLOC"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Break
    When 2
      [L]WFIC="STOLOC"
      [L]WCLE=[M:STW]TRFFCY-[F:STO]LOC
      Call FSTA("STC") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Break
    When 3
      Call FSTA("STO") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Break
  Endcase

  # Cumul des variables servant à la maj de ITMMVT
  #--- Issue 112666
  #WDIFF = [F:STO]QTYSTUACT<>WQTYSTUACT_SVG
  WDIFF = [F:STO]QTYSTUACT-WQTYSTUACT_SVG
  #---
  If WDIFF<>0
    Case left$([F:STO]STA,1)
      When "A"
        [L]WQTYACT_A += WDIFF                  : # Stock unité active (A)
        If [M:STW]OWNER(I)=[L]WFCY
           Case [F:STO]LOCCAT
             When 1 : WQTYACTINT_A += WDIFF    : # Stock interne (A)
             When 2 : WQTYACTPLF_A += WDIFF    : # Stock quai (A)
             When 3 : WQTYACTBPR_A += WDIFF    : # Stock prêté (A)
             When 4 : WQTYACTSCO_A += WDIFF    : # Stock sous-traitant (A)
           Endcase
        Endif
      When "Q"
        [L]WQTYACT_Q += WDIFF                  : # Stock unité active (Q)
        If [M:STW]OWNER(I)=[L]WFCY
           Case [F:STO]LOCCAT
             When 1 : WQTYACTINT_Q += WDIFF    : # Stock interne (Q)
             When 2 : WQTYACTPLF_Q += WDIFF    : # Stock quai (Q)
             When 3 : WQTYACTBPR_Q += WDIFF    : # Stock prêté (Q)
             When 4 : WQTYACTSCO_Q += WDIFF    : # Stock sous-traitant (Q)
           Endcase
        Endif
      When "R"
        [L]WQTYACT_R += WDIFF                  : # Stock unité active (R)
        If [M:STW]OWNER(I)=[L]WFCY
           Case [F:STO]LOCCAT
             When 1 : WQTYACTINT_R += WDIFF    : # Stock interne (R)
             When 2 : WQTYACTPLF_A += WDIFF    : # Stock quai (R)
             When 3 : WQTYACTBPR_R += WDIFF    : # Stock prêté (R)
             When 4 : WQTYACTSCO_R += WDIFF    : # Stock sous-traitant (R)
           Endcase
        Endif
    Endcase
    [L]WQTYACT += WDIFF                        : # Stock unité active (A+Q+R)
    If [M:STW]OWNER(I)=[L]WFCY
       Case [F:STO]LOCCAT
         When 1 : [L]WQTYACTINT += WDIFF          : # Stock interne (A+Q+R)
         When 2 : [L]WQTYACTPLF += WDIFF          : # Stock quai (A+Q+R)
         When 3 : [L]WQTYACTBPR += WDIFF          : # Stock prêté (A+Q+R)
         When 4 : [L]WQTYACTSCO += WDIFF          : # Stock sous-traitant (A+Q+R)
       Endcase
    Endif
  Endif

  [L]WMESSAGE=mess(551,197,1)
  If [M:STW]TRAFLG>2
    Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
Next

# Issue 112666 - 2016-07-07 by CCC
# Cumulate WDIFF is not enough because some stock lines can already be written with the correct qty
# => update ITV and SLF with STOCK records
WRET = func STKVALMAJ2.UPDQTYACT([M:STW]ITMREF, [M:STW]STOFCY, [F:STL]LOT, [F:STL]SLO)
Case [L]WRET
    When 1 :
        [L]WFIC="ITMMVT"
        [L]WCLE=[M:STW]TRFFCY-[M:STW]STOFCY
        Call FSTA("ITV") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ
    When 2 :
        [L]WFIC="STOLOTFCY"
        [L]WCLE=[M:STW]TRFFCY-[M:STW]STOFCY-[F:STL]LOT-[F:STL]SLO
        Call FSTA("SLF") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ
Endcase
Return

