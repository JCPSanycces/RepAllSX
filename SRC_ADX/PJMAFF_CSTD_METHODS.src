###################################################################################################
# Classe PJMAFF   (Employee assignments)
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-51863 - 2017-08-07 by FGR
  SLEVEL = func AFNC.MES2(mess(951,2260,1), this.OPPNUM, this.PAFCLB)
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$COPY
#Variable Instance TARGET Using C_PJMAFF
#Variable Instance TECCLA Using C_PJMACOPY
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY     # Issue X3-29531 - 2017-04-21 by FGR

  # Issue X3-29531 - 2017-04-21 by FGR : BEGIN
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

#$COPY
##Variable Instance TARGET Using C_PJMAFF
##Variable Instance TECCLA Using C_PJMACOPY
##Value Integer TECIDX
##Local Integer ARET_VALUE
#
#  # -----------------------------------------------------------------
#  Local File PJMAFF[PAF]
#  # -----------------------------------------------------------------
#  SetInstance [F:PAF] With this
#  #Set the [F] instance to the CRM project if CRMFLG is flagged       # Issue X3-15584/121450 - 2017-04-10 by EUHAV : BEGIN
#  If TECCLA.CRMFLG = [V]CST_AYES and TECCLA.DESTAFF <> AVOID.ACHAR
#    [F:PAF]OPPNUM = TECCLA.DESTAFF
#  Endif                                                               # Issue X3-15584/121450 - 2017-04-10 by EUHAV : END
#  SetInstanceNoSys TARGET With [F:PAF] # Issue X3-6717/119894 - 2016-11-22 by EUHAV
#  # -----------------------------------------------------------------
#Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  # Issue X3-29531 - 2017-04-21 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PAFCLB", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("PAFROL", AVOID.ACHAR))
Return

