#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet LPM
Raz GPILOBJ
Call OBJET("LPM",GBIDC1,GBIDC1) From GOBJET
End

$ACTION
Case ACTION
 When "FERME"        : Gosub FERME
 When "OUVRE"        : Gosub OUVRE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEACT"       : Gosub EXEACT
 When "LIENS"        : Gosub LIENS
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

$OUVRE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:MSR])=0 : Local File MSRUB [MSR]   : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:LPM]COD<>"" : 
 mkstat=4                     # mkstat=4 to load again the record after selection             
 If dim([M:LPM1]LEG)>=0 : [M:LPM1]LEG=[F:LPM]LEG: Endif
 GCURLEG=[F:LPM]LEG 
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:LPM1]LEG)>=0 
  GCURLEG=[M:LPM1]LEG 
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif 
Endif
Return

$LIENS
GCURLEG=[F:LPM]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M]DES,"MSLIVREPAY","DES",GCURLEG,[M]COD) From ATEXTRA
Return

$SETBOUT
If !CLECUR or REP<>"" or GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Else
 CHAINE += "E"
Endif
Return

$EXEACT
Case BOUT
 When "I"
  Local Char TBPAR(20)(1..10) , TBVAL(20)(1..10)
  TBPAR(1) = "livre"
  TBPAR(2) = "leg"
  TBVAL(1) = CLECUR1
  TBVAL(2) = CLECUR2
  Call ETAT("MSLIVREPAY",GFONCTION,TBPAR,TBVAL) From ETAT
Endcase
Return

########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("MSLIVREPAY","DES",CLECUR1,"","MSLIVREPAY","DES",GCURLEG,[F:LPM]COD) From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"MSLIVREPAY","DES",GCURLEG,[F:LPM]COD) From ATEXTRA
Return

########################################
$AP_CHANGE
# To change translated texts (data type AX3 & AX1) when you change the main code
Call CHGTEXTRA("MSLIVREPAY","DES",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("MSLIVREPAY","DES",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$SEL_TABLE
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Case TABLE
 When "SELLPM"
  Case [M:LPM1]TYP(nolign-1)
   When 1 : OBJET = "RUB" : Gosub CRI_SEL
   When 2 : OBJET = "MSR" : Gosub CRI_SEL
   When 3 :
    OBJET = "CUM"
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:CUM]CUMTMP<>2)',"&") From GOBJSUB
   When 4 :
    OBJET = "VRA"
  Endcase
  VALEUR = toupper(VALEUR)
Endcase
Return

$CRI_SEL
If [M:LPM1]TYPAMT(nolign-1)=2
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(([F]TYPRUB=6)|([F]TYPRUB=2 & RAT2<>""))',"&") From GOBJSUB
Elsif find([M:LPM1]TYPAMT(nolign-1),3,4,5,13,14,15,16,17,18)        :#Tax band
 Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F]TYPRUB=5)',"&") From GOBJSUB
Endif
Return


######################################################################################
## Etiquette écran LPM1
######################################################################################
Subprog C_CRI(VALEUR)
Variable Integer VALEUR
Call UNICITE(VALEUR,[M]CRI) From OBJDIV
End


########################################
Subprog AS_TYPAMT(VALEUR)
Variable Integer VALEUR
If [M]TYP(nolign-1)<>1 & [M]TYP(nolign-1)<>2
 mkstat=1 : End
Endif

#Tax band : Hide all !
For I=3 To len(mess(0,10355,1))
 GMENLOC(I)=1
Next

#If necessary display what we need
If [M]TYP(nolign-1)<>2 : # Rubrique MS
 #Tax band (D to I)
 For I=1 To func AFNC.ACTIV("TXB")
  If I<4
   GMENLOC(I+2) = 0 : # Tranche A, B, C
  Else
   GMENLOC(I+9) = 0 : # Tranche D, E, F...
  Endif
 Next
Endif

End

########################################
Subprog AS_BASE(VALEUR)
Variable Integer VALEUR
# Pas de base pour cumul, variable et Aucun
If find([M]TYP(nolign-1),3,4,5,6)
 mkstat = 1 : End
Endif
End

########################################
Subprog AS_RUBCOD(VALEUR)
Variable Char    VALEUR()
# Pas de code pour "Aucun"
If [M]TYP(nolign-1)=5
 mkstat = 1 : End
Endif
If [M]TYP(nolign-1)<>6 : # 6=Calcul
 Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6, GBOUT7
Else
 Raz GBOUT5
Endif
End

########################################
Subprog C_RUBCOD(VALEUR)
Variable Char    VALEUR()
If [M]TYP(nolign-1)=6 : # 6=Calcul
 VALEUR = vireblc(format$("KT:250X",VALEUR),2)
Else
 VALEUR = toupper(VALEUR)
Endif
Case [M]TYP(nolign-1)
 When 1
  VALEUR = left$(VALEUR,GLONRUB)
  Call CONTROLE("RUB","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 2
  VALEUR = left$(VALEUR,GLONRUB)
  Call CONTROLE("MSR","",VALEUR,"",mkstat) From CONTOBJ
 When 3
  VALEUR = left$(VALEUR,GLONCUM)
  Call CONTROLE("CUM","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 4
  VALEUR = left$(VALEUR,GLONVRA)
  Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 6
  Call CONTVAL(VALEUR)
Endcase

If mkstat : End : Endif

Case [M]TYP(nolign-1)
 When 1
  Read [F:RUB]RUB0=GCURLEG;VALEUR
  If [M]TYPAMT(nolign-1)=2 & [F:RUB]TYPRUB<>6 & [F:RUB]TYPRUB<>10 & [F:RUB]TYPRUB<>2 :#Cotisation et Régularisation et Montant=Base*taux
   GMESSAGE = mess(47,10703,1) : # Ce n'est pas une cotisation
   mkstat = 2 : End
  Endif
  #Tax band
  If find([M]TYPAMT(nolign-1),3,4,5,13,14,15,16,17,18) & [F:RUB]TYPRUB<>5
   GMESSAGE = mess(46,10703,1) : # Ce n'est pas une assiette de cotisation
   mkstat = 2 : End
  Endif
 When 2
  Read [F:MSR]MSR0=VALEUR
  If [M]TYPAMT(nolign-1)=2 & [F:MSR]TYPRUB<>6 & [F:MSR]TYPRUB<>2 :#Cotisation et Montant=Base*taux
   GMESSAGE = mess(47,10703,1) : # Ce n'est pas une cotisation
   mkstat = 2 : End
  Endif
 When 6
  Read [F:CUM]CUM0=GCURLEG;VALEUR
  If [F:CUM]CUMTMP=2
   GMESSAGE = mess(48,10703,1) : # Cumul intermédiaire
   mkstat = 2 : End
  Endif
Endcase
End

########################################
Subprog AS_DESCOL(VALEUR)
Variable Char    VALEUR()
If [M]TYP(nolign-1)=5 : # Aucun
 mkstat = 1 : End
Endif
End

########################################
Subprog APRES_NBRCOL
Local Integer I , J , K , L , NOL
NOL = nolign-1
## Effacement de lignes => Renuméroter les formules de calcul qui font référence à des lignes (F0xx)
If find(status,65,68,83)
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYP(I)=6 : # Calcul
   For J=NOL+1 To 99
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J-1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
## Insertion d'une ligne => Renuméroter les formules de calcul qui font référence à des lignes (F0xx)
Elsif [M]STA(NOL)=73
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYP(I)=6 : # Calcul
   For J=99 To NOL+1 Step -1
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J+1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
Endif
[M]STA(NOL) = 0
End

Subprog AVANT_NBRCOL
[M]STA(nolign-1) = status
End

#Tax band
Subprog CONTVAL(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK, K
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If find(OP3,"[F:")
  # Expression incorrecte
  GMESSAGE = mid$(FORMULE,I,7)-mess(37,124,1)-"[F:"
  mkstat = 2 : Break
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_"
    Read [RUB]RUB0=GCURLEG;CODE
    If fstat
     Read [RUB]RUB1=GCURLEG;val(CODE)
     If fstat
      Read [MSR]MSR0=CODE
      If fstat
       GERR = 1 : GMESSAGE = mess(11,10702,1) : Break :  # Rubrique inexistante
      Else
       FORMULE = left$(FORMULE,J-1)+[F:MSR]COD+right$(FORMULE,I+1)
       I += len([F:MSR]COD)-len(CODE)
       CODE = [F:MSR]COD
      Endif
     Else
      FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
      I += len([F:RUB]COD)-len(CODE)
      CODE = [F:RUB]COD
     Endif
    Endif
   #65041
   When "TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_"
    Read [RUB]RUB0 = GCURLEG;CODE
    If fstat
     Read [RUB]RUB1 = GCURLEG;val(CODE)
     If fstat
      GERR = 1 : GMESSAGE = mess(11,10702,1) : Break :  # Rubrique inexistante
     Else
      FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
      I += len([F:RUB]COD)-len(CODE)
      CODE = [F:RUB]COD
     Endif
    Endif
    If [F:RUB]TYPRUB<>5
     GERR = 1 : GMESSAGE = mess(12,10702,1) : Break : # La rubrique n'est pas de type assiette
    Endif
   When "V_"
    Read [VRA]VRA0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(13,10702,1) : Break : # Variable inexistante
    Elsif [F:VRA]FLGEXS=2
     GERR = 1 : GMESSAGE = mess(183,10703,1) : Break : # Variable de note de frais
    Endif
   When "C_"
    Read [CUM]CUM0 = GCURLEG;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(14,10702,1) : Break : # Cumul inexistant
    Endif
  Endcase
  I += 1
 Else
  I += 1
 Endif
Wend
If GERR
 GMESSAGE = CODE+"\"+GMESSAGE : mkstat = 2
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPM1) 25/05/2012 18:38:51 (DBA)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Effzo [M]30
End
