#<AdxTL>@(#)2.0.0.0 $Revision$


$ACTION

Case ACTION
 When "NOM_ETAT" : Gosub NOM_ETAT
 #JOJAC - 2018-08-08 - X3-103256 - START
 When "SEL_TABLE"   : Gosub SEL_TABLE
 #JOJAC - 2018-08-08 - X3-103256 - END
Endcase
Return


$NOM_ETAT
    # Print on official form and details
    If [M]OFFICALFORM = 2 and [M]DETVCR = 2
        [L]ETAT_DEB = "SWIVATFORMNLD"
    # Print with layer and details
    Elsif [M]OFFICALFORM <> 2 and [M]DETVCR = 2
        [L]ETAT_DEB = "SWIVATFORMD"
    # Print with layer without detauils details
    Elsif [M]OFFICALFORM <> 2 and [M]DETVCR <>2
        #Infbox "SWIVATFORM"
        [L]ETAT_DEB = "SWIVATFORM"
    # Print with layer without details
    Else
        [L]ETAT_DEB = "SWIVATFORMNL"
    Endif
Return

#JOJAC - 2018-08-07 - X3-103256 - START
# Selection of the request number
$SEL_TABLE
Case TABLE
 When "SELRPT"
  Local File SELVATRQTSWI [VRQTSWI]
  Default File [VRQTSWI]
  SIZCOL = 200
  NBCOL = 6
  COL(1) = "[F:VRQTSWI]NUMRPT"
  TIT(1) = mess(38,114,1) : # Requête numéro
  FMTCOL(1) = "N:8"
  COL(2) = "[F:VRQTSWI]CPY"
  TIT(2) = mess(2,116,1) : # Société
  FMTCOL(2) = "K:5c"
  COL(3) = "[F:VRQTSWI]FCY"
  TIT(3) = mess(5,116,1) : # Site
  FMTCOL(3) = "K:5c"
  COL(4) = "[F:VRQTSWI]STRDAT"
  TIT(4) = mess(369,107,1) : # Date début déclaration
  FMTCOL(4) = "DZz:DD[/]MM[/]YYYY"
  COL(5) = "[F:VRQTSWI]ENDDAT"
  TIT(5) = mess(370,107,1) : # Date fin déclaration
  FMTCOL(5)= "DZz:DD[/]MM[/]YYYY"
  COL(6) = "[F:VRQTSWI]CREUSR"
  TIT(6) = mess(37,133,1) : # Utilisateur
  FMTCOL(6) = "K:5B"
  DEFPAG=1
  SENS = 2
Endcase
Return
#JOJAC - 2018-08-07 - X3-103256 - END

