#<AdxTL>@(#)0.0.0.0 $Revision$
#
#                         T R T C C R 0
#          Annulation de la réconciliation d'un OF complet / d'une phase
#          Etape préalable à l'annulation d'une pesée
#
#########################################################################################

#########################################################################################
# Fonction Annulation réconciliation           pesée           GPAO                     #
# Paramètre général Réconciliation permet 2 valeurs : "1: Par OF"; "2: Par Phase"       #
#                                                                                       #
# LFCY  = Site de production: "" = tous sites                                           #
#########################################################################################


$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "FINSAI"       : Gosub FINSAI
 When Default
Endcase
Return


#########################################################
$OUVRE

# Ouverture des fichiers utilisés
If clalev([F:MFG])  <= 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  <= 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:WGG])  <= 0 : Local File WEIGHING    [WGG]  : Endif

#Global Integer GNBLIGMAX : GNBLIGMAX =0

Return


#########################################################
$DEBUT
#GNBLIGMAX = dim([M:CCR0]ITMREF)     # mémorisation nombre de ligne maxi
Return

#########################################################
$SETBOUT


If ![M:CCR0]NBLIG
  ETABOU(GSPE1) = 0
Elsif [M:CCR0]NBLIG
  ETABOU(GSPE1) = 1
Endif

Return

#########################################################
$AVANT_BOUTON
Local Integer OK

Case BOUT
     When "a" : If [M:CCR0]NBLIG =0 : Return : Endif
               If [M:CCR0]NBLIG <> [M:CCR0]WCPTENR
                  GMESSAGE  = mess(66,2324,1)-num$([M:CCR0]WCPTENR-[M:CCR0]NBLIG)
                  GERR = 1
                  Return
                Endif
Endcase
Return

#########################################################
$FINSAI

Return

#########################################################
$BOUTON
Case BOUT
     When "a": Gosub TRT_ANNULER
     When "b" : Gosub TRT_ABANDON
     When Default
Endcase

Return


#########################################################
$TRT_ABANDON
Raz [M:CCR0]
Affzo [M:CCR0]
Return
#########################################################
$TRT_ANNULER
Local Integer I

# Petit message de confirmation avant de tout annuler
OK=1
Call OUINON(mess( 67,2324,1),OK) From GESECRAN
If OK= 1
  Call MESSAGE (mess(68,2324,1)) From GESECRAN
  Return
Endif

# MAJ [WGG]
#  lecture historique
If [M:CCR0]NBLIG <> 0
  Call DEBTRANS From GLOCK
  Trbegin [WGG]

    For I=0 To [M:CCR0]NBLIG-1
           Readlock [WGG]WGG0 = [M:CCR0]MFGNUM;[M:CCR0]BOMOPE(I);[M:CCR0]ITMREF(I);[M:CCR0]MFGLIN(I);[M:CCR0]BOMSEQ(I);[M:CCR0]CBTDAT(I);[M:CCR0]MVTSEQ(I)
        If fstat=1     GOK=-1 : GLOCK="$WEIGHING"-[M:CCR0]MFGNUM : Gosub TRT_ROLL : Break
        Elsif fstat GOK=0  : Call RSTA("WGG",[M:CCR0]MFGNUM) From GLOCK :  Gosub TRT_ROLL : Break
        Endif

        [F:WGG]RCLCOD = 1
        [F:WGG]RCLDAT = [0/0/0]
        [F:WGG]RCLDATSUP = date$
        [F:WGG]RCLUSRSUP = GUSER
        [F:WGG]RCLTIMSUP =  mid$(time$,1,2)+mid$(time$,4,2)
        Rewrite [F:WGG]
        If fstat
           GOK = 0 : Call FSTA("WGG") From GLOCK : Break                                        # FQ 69909 Ctrl des sources avant Return
        Endif
    Next I

    Commit
    Gosub MAJ_MFM
    Raz [M:CCR0]
    Affzo  [M:CCR0]
    ACTION = "SETBOUT" : Gosub ACTION
Endif
Return


#########################################################
$MAJ_MFM

Call DEBTRANS From GLOCK
Trbegin [MFM]

# MAJ [MFM]
For [MFM]MFM0 Where MFGFCY = [M:CCR0]MFGFCY     &
&                   MFGNUM = [M:CCR0]MFGNUM     &
&                   MATSTA <> 4                 &
&                   WGGSTA = 5                  &
&                   find([F:MFM]PKC,2,4,6)      &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:CCR0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:CCR0]CTN)  ) # CATUA X3-30178
#&    ([V]GRECONCIL<>2 | BOMOPE = [M:CCR0]BOMOPE0)

      Readlock [F:MFM] Curr
      If fstat=1     GOK=-1 : GLOCK="$MFM"- [M:CCR0]MFGNUM : Gosub  TRT_ROLL : Break            # FQ 69909 Ctrl des sources avant Return
      Elsif fstat GOK=0  : Call RSTA("MFM", [M:CCR0]MFGNUM) From GLOCK : Gosub TRT_ROLL : Break # FQ 69909 Ctrl des sources avant Return
      Endif

      [F:MFM]WGGSTA = 3
      Rewrite [F:MFM]
      If fstat       GOK = 0 : Call FSTA("MFM") From GLOCK : Gosub TRT_ROLL : Break         # FQ 69909 Ctrl des sources avant Return
      Endif
Next

Commit
Gosub MAJ_ENTETE
Return

#########################################################
$MAJ_ENTETE

Call DEBTRANS From GLOCK
Trbegin [MFG]

# à partir du moment où une phase n'est plus réconciliée, l'OF n'est plus réconcilié
Call MAJ_FICHIERS ("MFG",5,8,[M:CCR0]MFGNUM,"",0,0) From SCALEXCHAN
If GOK < 1  Gosub  TRT_ROLL
Else Commit
    Call MESSAGE (mess(65,2324,1)) From GESECRAN
Endif

Return

#########################################################
$TRT_ROLL
Rollback
Return


#########################################################################
#                     ETIQUETTES                                        #
#########################################################################
$CHARGE_PARAM
Local Char VALPAR(20)
Call PARAM([M:CCR0]MFGFCY,"RECONCIL",[L]VALPAR) From ADOVAL
[V]GRECONCIL = val([L]VALPAR)

Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELRCL0) 31/05/2013 10:57:09 (MM)
######################################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()

  [M:CCR0]MFGFCY=VALEUR
  Gosub CHARGE_PARAM

  If [V]GRECONCIL=2 # Reconcile by phase
    Actzo[M:CCR0]BOMOPE0
  # CATUA X3-30178.sn
    Raz[M:CCR0]CTN
    Grizo[M:CCR0]CTN
  Elsif [V]GRECONCIL=3 # Reconcile by container
    Actzo[M:CCR0]CTN
    Raz[M:CCR0]BOMOPE0
    Grizo[M:CCR0]BOMOPE0
  # CATUA X3-30178.en
  Else
    Raz[M:CCR0]BOMOPE0
    Grizo[M:CCR0]BOMOPE0
    # CATUA X3-30178.sn
    Raz[M:CCR0]CTN
    Grizo[M:CCR0]CTN
    # CATUA X3-30178.en
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CANCELRCL0) 31/05/2013 11:03:59 (MM)
######################################################################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = [M:CCR0]MFGNUM : End : Endif

Read [MFG]MFG0 = VALEUR
If !fstat
 [M:CCR0]WGGSTA = [F:MFG]WGGSTA
 [M:CCR0]WGGFLG = [F:MFG]WGGFLG
Endif
Affzo [M:CCR0]WGGSTA,WGGFLG

Gosub ETI_MFGNUM
End


######################################################################################
#       sous prog ETIQUETTES
######################################################################################
$ETI_MFGNUM

Read [MFG]MFG0 = VALEUR
If fstat :             GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]WGGFLG = 7 :  GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
If [F:MFG]MFGSTA = 4 : GMESSAGE = mess(114,193,1) : GERR =2 : mkstat = 2 : Return : Endif

WOK = 0

# Paramétrage GRECONCIL = par OF

For [MFM]MFM0 Where MFGFCY = [M:CCR0]MFGFCY    &
&                   MFGNUM = VALEUR             &
&                   MATSTA <> 4                 &
&                   find([F:MFM]PKC,2,4,6)
    WOK = 1
    If [F:MFM]WGGSTA =  7 : WOK = 7 : Break : Endif
Next


If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
# 102152 mm 06.2015 - blocking only if  GRECONCIL = by WO
If [V]GRECONCIL= 1
  If WOK = 7  GMESSAGE = mess(45,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
Endif

[M:CCR0]MFGNUM = VALEUR
Gosub CALCUL_NBPESEE
If [M:CCR0]WCPTENR > dim([M:CCR0]ITMREF)
    GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:CCR0]MFGNUM
Endif

Return

######################################################################################
$ETI_BOMOPE

# Réconciliation par phase
If [V]GRECONCIL=2
 WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:CCR0]MFGFCY     &
&                       MFGNUM = [M:CCR0]MFGNUM     &
&                       BOMOPE = VALEUR             &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
        WOK = 1
        If [F:MFM]WGGSTA =  7 : WOK = 7 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 7  GMESSAGE = mess(46,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

Else
  Raz [M:CCR0]BOMOPE0
  Grizo [M:CCR0]BOMOPE0
Endif
[M:CCR0]BOMOPE0 = VALEUR
Gosub CALCUL_NBPESEE
If [M:CCR0]WCPTENR > dim([M:CCR0]ITMREF)
    GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:CCR0]MFGNUM
Endif

Return

# CATUA X3-30178.sn
#########################################################
$ETI_CTN

# Reconcile by container
If [V]GRECONCIL=3
 WOK = 0
    For [MFM]MFM0 Where MFGFCY = [M:CCR0]MFGFCY     &
&                       MFGNUM = [M:CCR0]MFGNUM     &
&                       CTN = VALEUR                &
&                       MATSTA <> 4                 &
&                       find([F:MFM]PKC,2,4,6)
        WOK = 1
        If [F:MFM]WGGSTA =  7 : WOK = 7 : Break : Endif
    Next

    If WOK = 0  GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2 : Return : Endif
    If WOK = 7  GMESSAGE = mess(88,2324,1) : GERR =2 : mkstat = 2 : Return : Endif

Else
  Raz [M:CCR0]CTN
  Grizo [M:CCR0]CTN
Endif
[M:CCR0]CTN = VALEUR
Gosub CALCUL_NBPESEE
If [M:CCR0]WCPTENR > dim([M:CCR0]ITMREF)
    GMESSAGE = mess(60,2324,1)-"\" - mess(61,2324,1): GERR =2 : mkstat = 2 : Raz [M:CCR0]MFGNUM
Endif

Return
# CATUA X3-30178.en

#####################################################################################
$CALCUL_NBPESEE

Raz [M:CCR0]WCPTENR
For [WGG]WGG0 Where MFGNUM = [M:CCR0]MFGNUM         &
&                   WEIWEI <> 0                     &
&                   CCLDAT = [0/0/0]                &
&                   RCLCOD =  2                     &
&                   RCLDAT <> [0/0/0]               &
&                   WEIFLG <> 4                     &
&                   WEIFLG <> 5                     &
&                   find([F:WGG]PKC,2,4,6)          &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:CCR0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:CCR0]CTN)  ) # CATUA X3-30178
#&   ([V]GRECONCIL=2 & (BOMOPE = [M:CCR0]BOMOPE0)|([V]GRECONCIL<>2 & [M:CCR0]BOMOPE0=0))  #DT - mm 05.11
  [M:CCR0]WCPTENR +=1
Next
Affzo  [M:CCR0]WCPTENR
Return

#####################################################################################
$ETI_MFGTRKNUM
Local Integer NOL   : [L]NOL=nolign-1

Filter[F:WGG]  Where  MFGNUM    = [M:CCR0]MFGNUM             &
&                            FCY=[M:CCR0]MFGFCY              &
&                            MFGTRKNUM = VALEUR              &
&                            WEIWEI    <> 0                  &
&                            CCLDAT    = [0/0/0]             &
&                            RCLDAT    <> [0/0/0]            &
&                            WEIFLG    <> 4                  &
&                            WEIFLG    <> 5                  &
&                            find([F:WGG]PKC,2,4,6)          &
&    (  [V]GRECONCIL<2 | ([V]GRECONCIL=2 & BOMOPE=[M:CCR0]BOMOPE0) | ([V]GRECONCIL=3 & CTN=[M:CCR0]CTN)  ) # CATUA X3-30178
#&   ([V]GRECONCIL<>2 | BOMOPE = [M:CCR0]BOMOPE0)

    Read[F:WGG]WGG0 First
    If !fstat
      [M:CCR0]ITMREF(NOL) = [F:WGG]ITMREF
      [M:CCR0]BOMOPE(NOL) = [F:WGG]BOMOPE
      [M:CCR0]LOT(NOL)    = [F:WGG]LOT
      [M:CCR0]WEIWEI(NOL) = [F:WGG]WEIWEI
      [M:CCR0]WEU(NOL)    = [F:WGG]WEU
      Affzo[M:CCR0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)

      If [M:CCR0]SAISIE(NOL)=1 : # Par pesée
        [M:CCR0]MFGLIN(NOL) = [F:WGG]MFGLIN
        [M:CCR0]BOMSEQ(NOL) = [F:WGG]BOMSEQ
        [M:CCR0]CBTDAT(NOL) = [F:WGG]CBTDAT
        [M:CCR0]MVTSEQ(NOL) = [F:WGG]MVTSEQ
        Affzo[M:CCR0]MFGLIN(NOL),BOMSEQ(NOL),CBTDAT(NOL),MVTSEQ(NOL)
      Endif
      Grizo [M:CCR0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    Else
       GMESSAGE = mess(16,2324,1) : GERR =2 : mkstat = 2
    Endif
Filter[F:WGG]

Return

######################################################################################
$ETI_LOT

If [M:CCR0]SAISIE(nolign-1)=1 : # Par pesée
   Return
Endif
#
GOK =1
# saisie détail
Raz[M:CCR0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)

For [WGG]WGG0 Where MFGNUM = [M:CCR0]MFGNUM               &
&                   BOMOPE = [M:CCR0]BOMOPE(nolign-1)     &
&                   WEIWEI <> 0                 &
&                   ITMREF = [M:CCR0]ITMREF(nolign-1)     &
&                   LOT    = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD =  2                 &
&                   RCLDAT <> [0/0/0]           &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5
    Read[F:WGG]WGG0 First
    If !fstat
       [M:CCR0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
       [M:CCR0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
       [M:CCR0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
       [M:CCR0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
       [M:CCR0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM
       [M:CCR0]WEU(nolign-1)        = [F:WGG]WEU
        Affzo[M:CCR0]15
       #Return             # mm 06.2013 - contrôle des sources
       GOK=0 : Break       # mm 06.2013 - suite 90111
    Endif
Next
If !GOK : Return : Endif   # mm 06.2013

GMESSAGE = mess(16,2324,1) : VALEUR = ""
Return

######################################################################################
$ETI_WEIWEI

Raz[M:CCR0]MFGLIN(nolign-1),BOMSEQ(nolign-1),CBTDAT(nolign-1),MVTSEQ(nolign-1)
GOK =1

For [WGG]WGG0 Where MFGNUM = [M:CCR0]MFGNUM               &
&                   BOMOPE = [M:CCR0]BOMOPE(nolign-1)     &
&                   ITMREF = [M:CCR0]ITMREF(nolign-1)     &
&                   LOT    = [M:CCR0]LOT(nolign-1)        &
&                   WEIWEI = VALEUR             &
&                   CCLDAT = [0/0/0]            &
&                   RCLCOD =  2                 &
&                   RCLDAT <> [0/0/0]           &
&                   WEIFLG <> 4                 &
&                   WEIFLG <> 5
    Read[F:WGG]WGG0 First
    If !fstat
      [M:CCR0]MFGLIN(nolign-1)     = [F:WGG]MFGLIN
      [M:CCR0]BOMSEQ(nolign-1)     = [F:WGG]BOMSEQ
      [M:CCR0]CBTDAT(nolign-1)     = [F:WGG]CBTDAT
      [M:CCR0]MVTSEQ(nolign-1)     = [F:WGG]MVTSEQ
      [M:CCR0]MFGTRKNUM1(nolign-1) = [F:WGG]MFGTRKNUM
      Affzo[M:CCR0]15
      #Return              # mm 06.2013 - contrôle des sources
      GOK=0 : Break        # mm 06.2013 - suite 90111
    Endif
Next
If !GOK : Return : Endif   # mm 06.2013

GMESSAGE = mess(16,2324,1) : Raz VALEUR
Return

#########################################
Subprog AV_BOMOPE0(VALEUR)
Variable Decimal VALEUR

  If [V]GRECONCIL=2 & [M:CCR0]NBLIG=0 # CATUA X3-30178
    Actzo[M:CCR0]BOMOPE0
  Else
    Grizo[M:CCR0]BOMOPE0
  Endif
End

#########################################
Subprog C_BOMOPE0(VALEUR)
Variable Decimal VALEUR

If [V]GRECONCIL=2 & VALEUR=0
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
    End
Endif
Gosub ETI_BOMOPE
End

# CATUA X3-30178.sn
# Add container fields in cancel reconciliation
#########################################
Subprog AV_CTN(VALEUR)
Variable Char    VALEUR()

  If [V]GRECONCIL=3 & [M:CCR0]NBLIG=0
    Actzo[M:CCR0]CTN
  Else
    Grizo[M:CCR0]CTN
  Endif
End

#########################################
Subprog C_CTN(VALEUR)
Variable Char    VALEUR()
  Gosub ETI_CTN
End
# CATUA X3-30178.en

#########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char    VALEUR()

If find([V]GRECONCIL,2,3) : Raz [M:CCR0]WCPTENR : Endif  # CATUA X3-68685

Raz [M:CCR0]BOMOPE0
Raz [M:CCR0]CTN # CATUA X3-30178
Raz [M:CCR0]NBLIG

#Read [MFG]MFG0 = VALEUR
#If !fstat
# [M:CCR0]WGGSTA = [F:MFG]WGGSTA
# [M:CCR0]WGGFLG = [F:MFG]WGGFLG
#Endif
#Affzo [M:CCR0]WGGSTA,BOMOPE0
Affzo [M:CCR0]BOMOPE0, WCPTENR, CTN # CATUA X3-30178
Affzo [M:CCR0]15

End

#########################################
Subprog AM_SAISIE(VALEUR)
Variable Integer VALEUR
Local Integer NOL   : [L]NOL=nolign-1
# saisie par n° de pesée
If VALEUR=1
    Raz[M:CCR0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
Else
# saisie détaillée
    Raz[M:CCR0]MFGTRKNUM(NOL)
    Actzo[M:CCR0]ITMREF(NOL),BOMOPE(NOL),LOT(NOL),WEIWEI(NOL),WEU(NOL)
    zonsui = "ITMREF(" + num$(NOL) + ")"
Endif

End

#########################################
Subprog C_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
Local Integer K
Local Integer NOL : [L]NOL=nolign-1

If [M:CCR0]SAISIE(NOL)=1 & VALEUR=""
    GMESSAGE = mess(10,123,1) : GERR =2 : mkstat = 2
Else
  If [M:CCR0]NBLIG<>0 & VALEUR<>""
    For K=0 To [M:CCR0]NBLIG-1
      If K<>[L]NOL & ([M:CCR0]MFGTRKNUM(K)=VALEUR |[M:CCR0]MFGTRKNUM1(K)= VALEUR  )
        GMESSAGE = mess(43,2324,1)-num$([L]K+1) : GERR =2 : mkstat = 2 : Break
      Endif
    Next
  Endif
Endif

End

#########################################
Subprog AM_MFGTRKNUM(VALEUR)
Variable Char    VALEUR()
Gosub ETI_MFGTRKNUM
End

#########################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Gosub ETI_LOT
If VALEUR = "" : GERR =2 : mkstat = 2 : End : Endif
[M:CCR0]LOT(nolign-1) = VALEUR
Affzo  [M:CCR0]LOT(nolign-1)
End

#########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
Affzo  [M:CCR0]WEIWEI(nolign-1)
Affzo  [M:CCR0]WEU(nolign-1)
End

#########################################
Subprog AS_BOMOPE(VALEUR)
Variable Decimal VALEUR
If [M:CCR0]BOMOPE0<>0
    VALEUR = [M:CCR0]BOMOPE0
Endif
End

#########################################
Subprog C_BOMOPE(VALEUR)
Variable Decimal VALEUR
If [V]GRECONCIL=2 & VALEUR <> [M:CCR0]BOMOPE0
    GMESSAGE = mess(6,2324,1)  : GERR =2 : mkstat = 2
Endif
End

#########################################
Subprog C_WEIWEI(VALEUR)
Variable Decimal VALEUR
Gosub ETI_WEIWEI
If !VALEUR : GERR =2 : mkstat = 2 : End : Endif
[M:CCR0]WEIWEI(nolign-1) = VALEUR
Affzo  [M:CCR0]WEIWEI(nolign-1)
End

#########################################

