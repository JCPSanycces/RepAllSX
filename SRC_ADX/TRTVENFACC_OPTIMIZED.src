#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
$LEC_VAT_OPTIMIZED
Local Integer WRET
Gosub QUEL_VATDAT From TRTVENFACC

If dim(GMIGRATION)>0 & dim(NBTVT)>0              : # Dde 81811 : Optimisation
    Gosub LEC_VAT From UUMGTRTSAL00              : # Dde 81811 : Optimisation
Else                                             : # Dde 81811 : Optimisation
  #------------------------------------------------------------------------------------------------
  Local Integer ZWINDEX
  Local Date    ZWSTRDAT

  ZWFOUND     = [V]CST_AYES
  ZWINDEX_TVT = fmet GACTX.ACACHE.TVT.AGETINDEX(WVAT,GCURLEG)
  If ZWINDEX_TVT=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).RECORD_EXIST=[V]CST_ANOTDEFINED)
    ZWFOUND=[V]CST_ANO
  Endif
  If ZWFOUND=[V]CST_AYES

    ZWFOUND = [V]CST_ANO
    ZWINDEX_TRA = [V]CST_ANOTDEFINED
    #--Possible problem when :
    #-- TRA : STRDAT=01/03/2017 RAT=21%
    #--       STRDAT=01/01/2017 RAT=20%
    #--Doc 1 : doc date 02/03/2017 => Filter with Read last will add into TRA.ACOL the entry STRDAT=01/03/2017 with 21%
    #--Doc 2 : doc date 28/02/2017 => Filter with Read last will add into TRA.ACOL the entry STRDAT=01/01/2017 with 20%
    #--If Doc 3 doc date 03/03/2017, the sigma will bring both STRDAT 01/01/2017 and 01/03/2017, as it is done for all ACOL.STRDAT <= DAT ==> NOK !!
    #--For this, we have to do 2 sigmas : first with (condition) => gives 0 (no entry, 1 1 entry true OK, >1 Multiple entries NOK)
    #--If 0 : go with former code Filter + Read last
    #--If 1 : do a second sigma with indcum*(condition) => gives the index for the right tax rate
    #--If >1 : do a for loop to find the latest date for the TRA key (in our case the 01/03/2017, and not the 01/01/2017)
    #--Hence, the following code after sigma...
    ZWINDEX_TRA = sigma (indcum=1,maxtab(GACTX.ACACHE.TRA.ACOL),
&                         (GACTX.ACACHE.TRA.ACOL(indcum)<>null and
&                          GACTX.ACACHE.TRA.ACOL(indcum).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&                          GACTX.ACACHE.TRA.ACOL(indcum).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURCPY  = GSOCIETE and
&                          GACTX.ACACHE.TRA.ACOL(indcum).STRDAT <= GBIDA1))
    ##infbox "LEC_VAT_OPTIMIZED SOC="+GSOCIETE-"First Sigma ZWINDEX_TRA="+num$(ZWINDEX_TRA)
    If ZWINDEX_TRA = 1
      #--Only one entry found, We'll take this one (A new sigma with indcum* will suffice to point to the right index)
      ZWINDEX_TRA = sigma (indcum=1,maxtab(GACTX.ACACHE.TRA.ACOL),indcum*
&                         (GACTX.ACACHE.TRA.ACOL(indcum)<>null and
&                          GACTX.ACACHE.TRA.ACOL(indcum).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&                          GACTX.ACACHE.TRA.ACOL(indcum).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&                          GACTX.ACACHE.TRA.ACOL(indcum).CURCPY  = GSOCIETE and
&                          GACTX.ACACHE.TRA.ACOL(indcum).STRDAT <= GBIDA1))
      If ZWINDEX_TRA>0
        #--Great ! We have the right index
        ZWFOUND = [V]CST_AYES
      Else
        ZWFOUND = [V]CST_ANO
      Endif
    Elsif ZWINDEX_TRA > 1
      #--In this case, more than one entry is found (meaning that we do have in the context, tax rates for different STRDAT)
      #--We'll have to select the latest one according to the DAT date
      ZWSTRDAT = [0/0/0]
      ZWINDEX  = 0
      For ZWINDEX_TRA = 1 To maxtab(GACTX.ACACHE.TRA.ACOL)
        If GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA)<>null and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).RECORD_EXIST<>[V]CST_ANOTDEFINED and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VAT     = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).CURLEG  = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).CURLEG and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).CURCPY  = GSOCIETE and
&        GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT <= GBIDA1

          If GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT >= ZWSTRDAT
            ZWSTRDAT = GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).STRDAT
            ZWINDEX  = ZWINDEX_TRA
          Endif
        Endif
      Next
      If ZWSTRDAT<>[0/0/0] or ZWINDEX<>0
        ZWINDEX_TRA = ZWINDEX
        ZWFOUND = [V]CST_AYES
      Else
        ZWFOUND = [V]CST_ANO
      Endif
    Else
      ZWFOUND = [V]CST_ANO
    Endif
    #infbox "LEC_VAT_OPTIMIZED SOC="+GSOCIETE-"After first Sigma ZWINDEX_TRA="+num$(ZWINDEX_TRA)
    If ZWFOUND<>[V]CST_AYES
      #--previous code
      Filter [TRA] Where CPY=GSOCIETE & VAT=WVAT & STRDAT<=GBIDA1 & LEG=GCURLEG
      Read [TRA]TRA0 Last
      If fstat>2
        # sinon on se rabat sur le code dossier
         Filter [TRA] Where CPY="" & VAT=WVAT & STRDAT<=GBIDA1 & LEG=""
         Read [TRA]TRA0 Last
         If fstat>2
           STAT = 2 : Filter [F:TRA]
           Return
         Else
           #--We add the entry for the existing last key, thus the next search will be done on cached entries
           ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,GCURLEG,
&                                                      GSOCIETE,[F:TRA]STRDAT)
         Endif
      Else
         #--We add the entry for the existing last key, thus the next search will be done on cached entries
         ZWINDEX_TRA = fmet GACTX.ACACHE.TRA.AGETINDEX([F:TRA]VAT,GCURLEG,
&                                                      GSOCIETE,[F:TRA]STRDAT)
      Endif

      Filter [TRA]
    Else
      [L]ZWUSINGCACHECLASS = [V]CST_AYES
    Endif
  #------------------------------------------------------------------------------------------------
  Else
    #--previous LEC_VAT
    Gosub LEC_VAT From TRTVENFACC : Return
  Endif
Endif                                            : # Dde 81811 : Optimisation

Return
#------------------------------------------------------------------------
$CHARG_VAT_OPTIMIZED

[M:SIHX]XVTAX(RV-1) = WVAT
[M:SIHX]XVTYP(RV-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATTYP
[M:SIHX]XVBAS(RV-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS
[M:SIHX]XVCHA(RV-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA
If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
  Raz [M:SIHX]XVSHO(RV-1)
  If !clalev([F:AXX])  Local File ATEXTRA [AXX] : Endif
  #-----
  GBIDC2 = GLANGUE
  If GBIDC2="" GBIDC2 = GLANDEF : Endif
  Read [AXX] AXX0="TABVAT";"SHOAXX";GLANGUE;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
  If fstat
    Read [AXX] AXX0="TABVAT";"SHOAXX";GBIDC2;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
    If fstat
      Raz [F:AXX]
    Else
      [M:SIHX]XVSHO(RV-1)=[F:AXX]TEXTE
    Endif
  Else
    [M:SIHX]XVSHO(RV-1)=[F:AXX]TEXTE
  Endif
Endif                        : # Dde 81811 : Optimisation
[M:SIHX]XVRAT(RV-1) = GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATRAT
If WTYPREG<>1 & dim(GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG)>0 & GACTX.ACACHE.TRA.ACOL(ZWINDEX_TRA).VATEXEFLG=2 : [M:SIHX]XVRAT(RV-1)=0 : Endif

Return
#------------------------------------------------------------------------
# Retourne le type de régime associé au régime de taxe tiers
Funprog RECH_TYPREG_OPTIMIZED(VALEUR)
Value Char    VALEUR
Local Integer RESULT : Raz RESULT
If VALEUR="" End RESULT Endif

Local Integer ZWINDEX_TVB, ZWFOUND
If dim(GACTX)>0
  ZWFOUND=[V]CST_AYES
  ZWINDEX_TVB = fmet GACTX.ACACHE.TVB.AGETINDEX(VALEUR,GCURLEG)
  If ZWINDEX_TVB=[V]CST_ANOTDEFINED or (GACTX.ACACHE.TVB.ACOL(ZWINDEX_TVB).RECORD_EXIST=[V]CST_ANOTDEFINED)
    ZWFOUND = [V]CST_ANO
  Endif
  If ZWFOUND = [V]CST_AYES
    RESULT=GACTX.ACACHE.TVB.ACOL(ZWINDEX_TVB).REGVAC
  Endif
Else
  If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
  If [F:TVB]VACBPR<>VALEUR | [F:TVB]LEG<>GCURLEG
    Local Integer WRET
    Call LEC_TVB_LEG(GCURLEG,VALEUR,WRET) From TRTLECLEG
    If WRET Raz [F:TVB] : Endif
  Endif
  RESULT=[F:TVB]REGVAC
Endif

End RESULT
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)


# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)
$CHARG_VAT_PROV_OPTIMIZED

Local Integer WRET :#--CPO 71937 TVT et multi-lèg
PROV_I=find("",[M:SIHV]XVTAX)
If PROV_I & PROV_BAS(PROV_J)<>0
    [M:SIHV]XVTAX(PROV_I-1) = WVAT
    [M:SIHV]XVTYP(PROV_I-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATTYP
    [M:SIHV]XVTYP(PROV_I-1) = 4                     : # A SUPPRIMER QUAND TOUT SERA OK
    [M:SIHV]XVBAS(PROV_I-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATBAS
    [M:SIHV]XVCHA(PROV_I-1) = GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VATCHA
    If dim(GMIGRATION)<=0        : # Dde 81811 : Optimisation
      Raz [M:SIHX]XVSHO(RV-1)
      If !clalev([F:AXX])  Local File ATEXTRA [AXX] : Endif
      #----
      GBIDC2 = GLANGUE
      If GBIDC2="" GBIDC2 = GLANDEF : Endif
      Read [AXX] AXX0="TABVAT";"SHOAXX";GLANGUE;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
      If fstat
        Read [AXX] AXX0="TABVAT";"SHOAXX";GBIDC2;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).VAT;GACTX.ACACHE.TVT.ACOL(ZWINDEX_TVT).LEG
        If fstat
          Raz [F:AXX]
        Else
          [M:SIHX]XVSHO(RV-1)=[F:AXX]TEXTE
        Endif
      Else
        [M:SIHX]XVSHO(RV-1)=[F:AXX]TEXTE
      Endif
    Endif                        : # Dde 81811 : Optimisation
    [M:SIHV]XVRAT(PROV_I-1) = WVATRAT                                                        : # Bug 65067
    [M:SIHV]XVSMI(PROV_I-1) = PROV_BAS(PROV_J)
    [M:SIHV]XVAMT(PROV_I-1) = PROV_AMT(PROV_J) : [M:SIHV]XVATI(PROV_I-1) = PROV_AMT(PROV_J)
    [M:SIHV]NBVAT +=1
Endif
Return
# X3-69134 : Performance enhancements for sales order import / X3-74031  : Multi-legislation updates (LD:05/24/18)

