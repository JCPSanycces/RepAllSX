#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(20)(1..10)
PARAM(1) = num$(0)
PARAM(2) = ""
PARAM(3) = "ALCOOL"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
Call GCONSULT("SLO","",PARAM) From GCONSULT
End

# Attention ne pas transférer en version 120 (Ecrans modifiés)
$ACTION

Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz[M:CSLO]: Transmask [M:SLO1] To [M:CSLO]# Issue 25606 [M:CSLO] = [M:SLO1]
                      If [F:ITM]ITMREF<>[M:SLO1]ITMREF
                        Read [ITM]ITM0=[M:SLO1]ITMREF
                        If fstat : Raz [F:ITM] : Endif
                      Endif
                      If [F:ITM]LOTMGTCOD=1
                        Diszo [M:CSLO]AGRLEN            # hcb 33807
                        If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
                           Diszo [M:CSLO]AGRSLOFLG      # hcb 33807
                        Endif                           # hcb 33807
                      Elsif [F:ITM]LOTMGTCOD=4
                        Actzo [M:CSLO]AGRLEN
                        If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
                           Actzo [M:CSLO]AGRSLOFLG      # hcb 33807
                        Endif                           # hcb 33807
                      Else
                        Actzo [M:CSLO]AGRLEN
                        If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
                           Diszo [M:CSLO]AGRSLOFLG      # hcb 33807
                           [M:CSLO]AGRSLOFLG=1
                           Endif                        # hcb 33807
                      Endif
                      Affzo [M:CSLO]AGRLEN
                      If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
                         Affzo [M:CSLO]AGRSLOFLG      # hcb 33807
                      Endif                           # hcb 33807
                      Gosub GRISAGE_CRITERES          # SYMEU

  When "FIN_CRIT"   : [M:SLO1]FLG = 0
                      [M:SLO1]    = [M:CSLO]
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return
############################################################
$AP_MAGNETO
[M:SLO1]FLG = 0
Return
############################################################
$CLECUR
If CLECUR=1
   #[M:SLO1]ITMDES1 = [F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SLO1]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Affzo [M:SLO1]ITMDES1
Endif
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:STL])=0 : Local File STOLOT     [STL]  : Endif
If clalev([F:SLF])=0 : Local File STOLOTFCY  [SLF]  : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO]  : Endif
If clalev([F:STL1])=0: Local File STOLOT     [STL1] : Endif
If clalev([F:STO])=0 : Local File STOCK      [STO1] : Endif
If clalev([F:TFO])=0 : Local File TABFOR     [TFO]  : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF]  : Endif

#
Local Char    WFIL(250)(5)
Local Char    WFORM(250)
Local Char    WFILS(250)
Local Char    WFILSPE(250)
Local Char    WFILSTL(250)
Local Char    WFILSLF(250)
Local Char    WFILSTO(250)
Local Integer WNOLIGN, WFSTAT, WREAD, WSKIP, WLIG, SVGMAXLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J
Local Char    DLOT(GLONLOT), FLOT(GLONLOT)
Local Char    DSLO(GLONSLO), FSLO(GLONSLO)
Local Char    DFCY(GLONFCY)                 # hcb 58008
Local Date    DLOTCREDAT, FLOTCREDAT
Local Date    DSHLDAT, FSHLDAT
#
Local Char    WAGRLOT(GLONLOT)
Local Decimal WAAA, WQQQ, WRRR, WALL, WACT
Local Decimal WAAAUA, WQQQUA, WRRRUA, WALLUA
#- Cumul
Local Decimal WTAAA, WTQQQ, WTRRR, WTALL, WTACT
Local Decimal WTAAAUA, WTQQQUA, WTRRRUA, WTALLUA
#
WNOLIGN = nolign
Gosub LOAD_SCREEN
#
NAVIG="CONSSLO"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FERME
If dim(WGCONSULT) > 0
  GCONSULT = WGCONSULT
  Filter [STL]
  Filter [SLF]
  nolign = WNOLIGN
Endif
Return
############################################################
$SETBOUT
If [M:SLO1]SELFLG = 0
  Call VIREBOUT(CHAINE,"c") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "c" :
    If nolign > 0 & !([M:SLO2]LOT(nolign-1) = mess(142,124,1) & nolign = [M:SLO2]NBLIG)
      PARAM(7)  = [M:SLO2]LOT(nolign-1)
      REPONSE = GSTAFIN
    Endif
Endcase
Return
#############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SLO1]STOFCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SLO1]       = [F:ITM]
          [M:SLO1]UOM    = [F:ITM]STU
        Endif
      Endif
    When 4 :
      If PARAM(I)="$" : Raz PARAM(I) : Endif
      If PARAM(I) <> "" & dim([M:SLO1]LOTSEL) > 0
        [M:SLO1]LOTSEL = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) <> ""
        Case val(PARAM(I))
          When 0 :
            [M:SLO1]SELFLG = 0
          When 1 :
            [M:SLO1]SELFLG = 1
          When 2 :
            [M:SLO1]SELFLG = 0
          When 3 :
            [M:SLO1]SELFLG = 1
         Endcase
      Endif
    When 6 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
Case val(PARAM(5))
  When 0 :
    If dim([M:SLO1]ZERLOT) > 0
      [M:SLO1]ZERLOT    = 1
    Endif
    If dim([M:SLO1]NOTZERLOT) > 0
       [M:SLO1]NOTZERLOT = 2
    Endif
  When 1 :
    If dim([M:SLO1]ZERLOT) > 0
      [M:SLO1]ZERLOT    = 1
    Endif
    If dim([M:SLO1]NOTZERLOT) > 0
      [M:SLO1]NOTZERLOT = 2
    Endif
  When 2 :
    If dim([M:SLO1]ZERLOT) > 0
      [M:SLO1]ZERLOT    = 2
    Endif
    If dim([M:SLO1]NOTZERLOT) > 0
       [M:SLO1]NOTZERLOT = 2
    Endif
  When 3 :
    If dim([M:SLO1]ZERLOT) > 0
      [M:SLO1]ZERLOT    = 2
    Endif
    If dim([M:SLO1]NOTZERLOT) > 0
      [M:SLO1]NOTZERLOT = 2
    Endif
Endcase
If clalev([M:CSLO]) <> 0 & [M:CSLO]MEMO = "STD"       # hcb 61281
  [M:SLO1] = [M:CSLO]
Endif

If !find([M:SLO1]LOCCAT001,1,2) : [M:SLO1]LOCCAT001= 2 : Endif
If !find([M:SLO1]LOCCAT002,1,2) : [M:SLO1]LOCCAT002= 2 : Endif
If !find([M:SLO1]LOCCAT003,1,2) : [M:SLO1]LOCCAT003= 2 : Endif
If !find([M:SLO1]LOCCAT004,1,2) : [M:SLO1]LOCCAT004= 2 : Endif
If !find([M:SLO1]CRITRI,1,2,3,4): [M:SLO1]CRITRI=1     : Endif
If dim([M:SLO1]ZERLOT)>0
    If !find([M:SLO1]ZERLOT,1,2)    : [M:SLO1]ZERLOT   = 2 : Endif
    If !find([M:SLO1]NOTZERLOT,1,2) : [M:SLO1]NOTZERLOT= 2 : Endif
Endif
If !find([M:SLO1]CUMFLG,1,2) : [M:SLO1]CUMFLG= 1 : Endif
If [M:CSLO]FORMULE<>""
  If parse([M:CSLO]FORMULE)  : Raz [M:CSLO]FORMULE      : Endif
Endif
If [M:SLO1]AGRLEN>0
     [M:SLO1]AGRSLOFLG=2
     If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
        Diszo [M:CSLO]AGRSLOFLG
     Endif                           # hcb 33807
Else
  If dim([M:CSLO]AGRSLOFLG)>0        # hcb 33807
     Actzo [M:CSLO]AGRSLOFLG
  Endif                              # hcb 33807
Endif
If !find([M:SLO1]AGRSLOFLG,1,2) : [M:SLO1]AGRSLOFLG=1   : Endif
# -- copie de l'écran sur l'ecran de critères (CSLO)
Gosub CRITENT From =PROGCNS
Return
############################################################
$LECTURE
Raz SVGMAXLIG
Gosub CHANGE_MSK From GCONSULT

Gosub GRISAGE_CRITERES # SYMEU

If CHGPAG<0 & [M:SLO1]CUMFLG=1 : NOL = MAXLIG   : Endif
If CHGPAG<0 & [M:SLO1]CUMFLG=2 : NOL = MAXLIG-1 : Endif
If SVGMAXLIG=0
    SVGMAXLIG=MAXLIG
Endif
If MAXLIG<>SVGMAXLIG
  MAXLIG=SVGMAXLIG
Endif
If [M:SLO1]CUMFLG=2
  MAXLIG-=1
Endif
#-- Positionnement des Filtres
Gosub TRT_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
If [M:SLO1]CUMFLG=2 & CHGPAG=1
  Gosub CAL_CUMUL
Endif
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    #--------------------#
    # Critère de lecture #
    #--------------------#
    Case [M:SLO1]CRITRI
        When 2 : # FIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSPE) & evalue(WFILSLF)
&                    Order By Key STL1 Asc
        When 3 : # FEFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSPE) & evalue(WFILSLF)
&                    Order By Key STL2 Asc
        When 4 : # LIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSPE) & evalue(WFILSLF)
&                    Order By Key STL1 Desc
        When Default :
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSPE) & evalue(WFILSLF)
&                    Order By Key STL0 Asc
    Endcase
    Raz [F:STL],[F:SLF]
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    #--------------------#
    # Critère de lecture #
    #--------------------#
    Case [M:SLO1]CRITRI
        When 2 : # FIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSLF)
&                    Order By Key STL1 Desc
        When 3 : # FEFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSLF)
&                    Order By Key STL2 Desc
        When 4 : # LIFO
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSLF)
&                    Order By Key STL1 Asc
        When Default :
          Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                    As [LNK]
&                    Where evalue(WFILSTL) & evalue(WFILS) & evalue(WFIL) & evalue(WFORM) & evalue(WFILSLF)
&                    Order By Key STL0 Desc
    Endcase
    Raz [F:STL],[F:SLF]
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SLO2] : Endif

$BOUCLE
For [LNK]
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:SLO2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
  Endif
  Gosub TRT_STOCK
  If sum(WAAA,WQQQ,WRRR) <> 0 | (sum(WAAA,WQQQ,WRRR) = 0 &  dim([M:SLO1]ZERLOT)> 0 & [M:SLO1]ZERLOT = 2)
      Gosub TRT_LIGNE
  Endif
  Filter [F:SLF]
Next
If [M:SLO1]CUMFLG=2
  If CHGPAG=-2
      WLIG=SVGMAXLIG-1
  Elsif CHGPAG=-1
  Else
      NOL += 1
      WLIG = NOL
  Endif
  Gosub AFF_CUMUL
  MAXLIG=SVGMAXLIG
Endif
Return
############################################################
$TRT_FILTER
Raz [M:SLO2]
Gosub LOAD_FILTER
Return
############################################################
$LOAD_FILTER
WFILSLF="1=1"
WFILSTL = "[F:STL]ITMREF=[M:SLO1]ITMREF"
If dim([M:SLO1]LOTSEL) > 0 & [M:SLO1]LOTSEL <> ""
  WFILSTL += "&pat([F:STL]LOT,[M:SLO1]LOTSEL)=1"
Endif
If dim([M:SLO1]ZERLOT) > 0 & dim([M:SLO1]NOTZERLOT) < 0
  If [M:SLO1]ZERLOT = 1
    WFILSLF += "&sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY)<>0"
  Endif
Else
  If dim([M:SLO1]ZERLOT) > 0 & dim([M:SLO1]NOTZERLOT) > 0
    If !([M:SLO1]ZERLOT = 2 & [M:SLO1]NOTZERLOT = 2)
      If [M:SLO1]ZERLOT = 1
        WFILSLF += "&sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY)<>0"
      Endif
      If [M:SLO1]NOTZERLOT = 1
        WFILSLF += "&sum([F:SLF]AAACUMQTY,[F:SLF]QQQCUMQTY,[F:SLF]RRRCUMQTY)=0"
      Endif
    Endif
  Endif
Endif
If [M:SLO1]STOFCY <> ""                          # hcb 58008
   WFILSLF += "&[F:SLF]STOFCY = [M:SLO1]STOFCY"
Endif


WFILSTO = ""
If [M:SLO1]LOCCAT001 = 2
  WFILSTO += ",0,1"
Endif
If [M:SLO1]LOCCAT002 = 2
  WFILSTO += ",2"
Endif
If [M:SLO1]LOCCAT003 = 2
  WFILSTO += ",3"
Endif
If [M:SLO1]LOCCAT004 = 2
  WFILSTO += ",4"
Endif
WFILSTO =  "find([F:STO]LOCCAT"+WFILSTO+")"

Raz I
Raz WFIL
WFIL="1=1"
#---------------------------------------------#
#Index 0 ITMREF+LOT+SLO
#Index 1 ITMREF+LOTCREDAT+LOT+SLO
#Index 2 ITMREF+SHLDAT+LOTCREDAT+LOT+SLO
Case CHGPAG
   When 3  : # rafraichissement
     Case [M:SLO1]CRITRI
       When 1 : # tri par lot
           WFIL = "[F:STL]LOT>DLOT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOT=DLOT & [F:STL]SLO>=DSLO","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOT=DLOT & [F:STL]SLO=DSLO  & [F:SLF]STOFCY>=DFCY","|") From GOBJSUB
       When 2 : # tri FIFO
           WFIL = "[F:STL]LOTCREDAT>DLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT>DLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO>=DSLO","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO=DSLO  & [F:SLF]STOFCY>=DFCY","|") From GOBJSUB
       When 3 : # tri FEFO
           WFIL = "[F:STL]SHLDAT>DSHLDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT>DLOTCREDAT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT>DLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO>=DSLO","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO=DSLO  & [F:SLF]STOFCY>=DFCY","|") From GOBJSUB
       When 4 : # tri LIFO
           WFIL = "[F:STL]LOTCREDAT<DLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT<DLOT","|") From GOBJSUB
           #MAE, bg 82921
           #Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO=<DSLO","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO<=DSLO","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO=DSLO  & [F:SLF]STOFCY>=DFCY","|") From GOBJSUB
     Endcase
   When  2 : # suite
     Case [M:SLO1]CRITRI
       When 1 : # tri par lot
           WFIL = "[F:STL]LOT>FLOT | [F:STL]LOT=FLOT & [F:STL]SLO>FSLO"
       When 2 : # tri FIFO
           WFIL = "[F:STL]LOTCREDAT>FLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT>FLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT=FLOT & [F:STL]SLO>FSLO","|") From GOBJSUB
       When 3 : # tri FEFO
           WFIL = "[F:STL]SHLDAT>FSHLDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=FSHLDAT & [F:STL]LOTCREDAT>FLOTCREDAT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=FSHLDAT & [F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT>FLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=FSHLDAT & [F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT=FLOT & [F:STL]SLO>DSLO","|") From GOBJSUB
       When 4 : # tri LIFO
           WFIL = "[F:STL]LOTCREDAT<FLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT<FLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=FLOTCREDAT & [F:STL]LOT=FLOT & [F:STL]SLO<FSLO","|") From GOBJSUB
     Endcase
   When -2 : # retour
     Case [M:SLO1]CRITRI
       When 1 : # tri par lot
           WFIL = "[F:STL]LOT<DLOT | [F:STL]LOT=DLOT & [F:STL]SLO<DSLO"
       When 2 : # tri FIFO
           WFIL = "[F:STL]LOTCREDAT<DLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT<DLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO<DSLO","|") From GOBJSUB
       When 3 : # tri FEFO
           WFIL = "[F:STL]SHLDAT<DSHLDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT<DLOTCREDAT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT<DLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]SHLDAT=DSHLDAT & [F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO<DSLO","|") From GOBJSUB
       When 4 : # tri LIFO
           WFIL = "[F:STL]LOTCREDAT>DLOTCREDAT"
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT>DLOT","|") From GOBJSUB
           Call ADDCRIT(WFIL,I,"","[F:STL]LOTCREDAT=DLOTCREDAT & [F:STL]LOT=DLOT & [F:STL]SLO>DSLO","|") From GOBJSUB
     Endcase
Endcase
# analyse présence formule de sélection
If [M:CSLO]FORMULE=""
  WFORM="1=1"
Else
  Read [F:TFO]TFO0=11;[M:CSLO]FORMULE
  If fstat
    WFORM="1=1"
  Else
    WFORM= [F:TFO]FORFOR
  Endif
Endif
Return

############################################################
$CAL_CUMUL
#--------------------#
# Critère de lecture #
#--------------------#
Raz WTAAA, WTAAAUA, WTQQQ, WTQQQUA, WTRRR, WTRRRUA, WTALL, WTALLUA
Case [M:SLO1]CRITRI
    When 2 :
      Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                As [LNK]
&                Where evalue(WFILSTL) & evalue(WFILSLF) & evalue(WFILS) & evalue(WFORM)
&                Order By Key STL1 Asc
    When 3 :
      Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                As [LNK]
&                Where evalue(WFILSTL) & evalue(WFILSLF) & evalue(WFILS) & evalue(WFORM)
&                Order By Key STL2 Asc
    When 4 :
      Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                As [LNK]
&                Where evalue(WFILSTL) & evalue(WFILSLF) & evalue(WFILS) & evalue(WFORM)
&                Order By Key STL1 Desc
    When Default :
      Link [STL] With [SLF]SLF0(3)=[F:STL]ITMREF;[F:STL]LOT;[F:STL]SLO
&                As [LNK]
&                Where evalue(WFILSTL) & evalue(WFILSLF) & evalue(WFILS)  & evalue(WFORM)
&                Order By Key STL0 Asc
Endcase
Raz [F:STL],[F:SLF]
For [LNK]
    Gosub TRT_STOCK
    WTAAA  += WAAA
    WTAAAUA+= WAAAUA
    WTQQQ  += WQQQ
    WTQQQUA+= WQQQUA
    WTRRR  += WRRR
    WTRRRUA+= WRRRUA
    WTALL  += WALL
    WTALLUA+= WALLUA
Next
Return

$AFF_CUMUL
#----------------------#
# Affichage des cumuls #
#----------------------#
[M:SLO2]AAACUMQTY(WLIG) = WTAAA
[M:SLO2]QQQCUMQTY(WLIG) = WTQQQ
[M:SLO2]RRRCUMQTY(WLIG) = WTRRR
[M:SLO2]TOTCUMQTY(WLIG) = WTAAA+WTQQQ+WTRRR
[M:SLO2]ALLCUMQTY(WLIG) = WTALL
If dim([M:SLO2]AAACUMQTP) > 0
  [M:SLO2]AAACUMQTP(WLIG) = WTAAAUA
  [M:SLO2]QQQCUMQTP(WLIG) = WTQQQUA
  [M:SLO2]RRRCUMQTP(WLIG) = WTRRRUA
  [M:SLO2]TOTCUMQTP(WLIG) = WTAAAUA+WQQQUA+WRRRUA
  [M:SLO2]ALLCUMQTP(WLIG) = WTALLUA
Endif
[M:SLO2]LOT(WLIG) = mess(142,124,1)
If dim([M:SLO2]AAACUMQTP) > 0
  Gosub CAL_UOM
Endif

Return
###########################################################
$CAL_UOM
Local Integer WDEC : WDEC = 0
Call QTEDEC([M:SLO2]AAACUMQTP,[M:SLO2]NBLIG,WDEC) From TRTDIV
Call QTEDEC([M:SLO2]QQQCUMQTP,[M:SLO2]NBLIG,WDEC) From TRTDIV
Call QTEDEC([M:SLO2]RRRCUMQTP,[M:SLO2]NBLIG,WDEC) From TRTDIV
Call QTEDEC([M:SLO2]ALLCUMQTP,[M:SLO2]NBLIG,WDEC) From TRTDIV
#
If WDEC > 6
  [M:SLO1]UOM = "6"
Else
  [M:SLO1]UOM = num$(WDEC)
Endif
Return
############################################################
$TRT_STOCK
WFSTAT = fstat
Raz WAAA, WQQQ, WRRR, WALL
Raz WAAAUA, WQQQUA, WRRRUA, WALLUA
If [M:SLO1]STOFCY <> ""
  Filter [STO] Where  ITMREF = [F:STL]ITMREF   &
&                     STOFCY = [M:SLO1]STOFCY  &
&                     LOT    = [F:STL]LOT      &
&                     SLO    = [F:STL]SLO      &
&                     evalue(WFILSTO)
&              Order By Key STO3
Else
  Filter [STO] Where  ITMREF = [F:STL]ITMREF &
&                     STOFCY = [F:SLF]STOFCY &
&                     LOT    = [F:STL]LOT    &
&                     SLO    = [F:STL]SLO    &
&                     evalue(WFILSTO)
&              Order By Key STO3
Endif
#
For [STO]
  Case left$([F:STO]STA,1)
    When "A" : WAAA   += [F:STO]QTYSTU
               WAAAUA += [F:STO]QTYSTUACT
    When "Q" : WQQQ   += [F:STO]QTYSTU
               WQQQUA += [F:STO]QTYSTUACT
    When "R" : WRRR   += [F:STO]QTYSTU
               WRRRUA += [F:STO]QTYSTUACT
  Endcase
  WALL   += [F:STO]CUMALLQTY
  WALLUA += [F:STO]CUMALLQTA
Next
Filter [STO]
fstat = WFSTAT
Return
############################################################
$TRT_LIGNE

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:SLF]STOFCY | [F:ITF]ITMREF <> [F:SLF]ITMREF
   Read [ITF]ITF0 = [F:SLF]ITMREF;[F:SLF]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [M:SLO1]AGRLEN = 0
  WAGRLOT = [F:STL]LOT
  J=sigma(0,nolign-1,(indcum+1)
&                   *([F:STL]LOT=[M:SLO2]LOT(indcum)
&                     & ([M:SLO1]AGRFCYFLG=2 | [F:SLF]STOFCY=[M:SLO2]STOFCY(indcum))))
  If J<>0 & [M:SLO1]AGRSLOFLG=2
     Gosub ADD_LIGNE
  Else
     Gosub LOA_LIGNE
  Endif
Else
  WAGRLOT = left$([F:STL]LOT,[M:SLO1]AGRLEN)+"*"
  J=sigma(0,nolign-1,(indcum+1)
&                   *(WAGRLOT=[M:SLO2]LOT(indcum)
&                     & ([M:SLO1]AGRFCYFLG=2 | [F:SLF]STOFCY=[M:SLO2]STOFCY(indcum))))
  If J <> 0
    Gosub ADD_LIGNE
  Else
  J=sigma(0,nolign-1,(indcum+1)
&                   *([F:STL]LOT=[M:SLO2]LOT(indcum)
&                     & ([M:SLO1]AGRFCYFLG=2 | [F:SLF]STOFCY=[M:SLO2]STOFCY(indcum))))
    If J<>0
      Gosub ADD_LIGNE
    Else
      Gosub LOA_LIGNE
    Endif
  Endif
Endif
Return
############################################################
$LOA_LIGNE


If CHGPAG > 0
  NOL    += 1
  If NOL=0
      DLOT      = [F:STL]LOT
      DSLO      = [F:STL]SLO
      DFCY      = [F:SLF]STOFCY                   # hcb 58008
      DLOTCREDAT= [F:STL]LOTCREDAT
      DSHLDAT   = [F:STL]SHLDAT
  Endif
  FLOT      = [F:STL]LOT
  FSLO      = [F:STL]SLO
  FLOTCREDAT= [F:STL]LOTCREDAT
  FSHLDAT   = [F:STL]SHLDAT
Else
  NOL    -= 1
  If NOL=MAXLIG-1
      FLOT      = [F:STL]LOT
      FSLO      = [F:STL]SLO
      FLOTCREDAT= [F:STL]LOTCREDAT
      FSHLDAT   = [F:STL]SHLDAT
  Endif
  DLOT      = [F:STL]LOT
  DSLO      = [F:STL]SLO
  DFCY      = [F:SLF]STOFCY                   # hcb 58008
  DLOTCREDAT= [F:STL]LOTCREDAT
  DSHLDAT   = [F:STL]SHLDAT
Endif
nolign = NOL+1
[M:SLO2]                    = [F:STL]
[M:SLO2]                    = [F:SLF]
[M:SLO2]LOT(nolign-1)       = WAGRLOT
[M:SLO2]STU(nolign-1)       = [F:ITM]STU
[M:SLO2]AAACUMQTY(nolign-1) = WAAA
[M:SLO2]QQQCUMQTY(nolign-1) = WQQQ
[M:SLO2]RRRCUMQTY(nolign-1) = WRRR
[M:SLO2]TOTCUMQTY(nolign-1) = WAAA+WQQQ+WRRR
[M:SLO2]ALLCUMQTY(nolign-1) = WALL
If dim([M:SLO2]AAACUMQTP) > 0
   [M:SLO2]AAACUMQTP(nolign-1) = WAAAUA
   [M:SLO2]QQQCUMQTP(nolign-1) = WQQQUA
   [M:SLO2]RRRCUMQTP(nolign-1) = WRRRUA
   [M:SLO2]TOTCUMQTP(nolign-1) = WAAAUA+WQQQUA+WRRRUA
   [M:SLO2]ALLCUMQTP(nolign-1) = WALLUA
   If [F:ITF]STOMGTCOD <> 3 & dim([M:SLO2]POT)>0
     [M:SLO2]POT(nolign-1) = 0
   Endif
   If [F:ITF]STOMGTCOD <> 4 & dim([M:SLO2]ACT)>0
     [M:SLO2]ACT(nolign-1) = 0
   Endif
Endif
Return
############################################################
$ADD_LIGNE
If dim([M:SLO1]AGRSLOFLG)>0 & dim([M:SLO2]SLO)>0 &
&      [M:SLO1]AGRSLOFLG=2 & [M:SLO2]SLO(J-1)<>"$" & [M:SLO2]SLO(J-1)<>[F:STL]SLO
   [M:SLO2]SLO(J-1)="$"
Endif
# FGR 15/01/2010 : X3SUIVI60986
#If dim([M:SLO1]AGRFCYFLG)>0 & dim([M:SLO2]STOFCY)>0 &
#&      [M:SLO1]AGRFCYFLG=2 & [M:SLO2]FCY(J-1)<>"$" & [M:SLO2]STOFCY(J-1)<>[F:SLF]STOFCY
If dim([M:SLO1]AGRFCYFLG)>0 & dim([M:SLO2]STOFCY)>0 &
&      [M:SLO1]AGRFCYFLG=2 & [M:SLO2]STOFCY(J-1)<>"$" & [M:SLO2]STOFCY(J-1)<>[F:SLF]STOFCY
   [M:SLO2]STOFCY(J-1)="$"
Endif
[M:SLO2]AAACUMQTY(J-1) += WAAA
[M:SLO2]QQQCUMQTY(J-1) += WQQQ
[M:SLO2]RRRCUMQTY(J-1) += WRRR
[M:SLO2]TOTCUMQTY(J-1) += WAAA+WQQQ+WRRR
[M:SLO2]ALLCUMQTY(J-1) += WALL
If dim([M:SLO2]AAACUMQTP) > 0
  [M:SLO2]AAACUMQTP(J-1) += WAAAUA
  [M:SLO2]QQQCUMQTP(J-1) += WQQQUA
  [M:SLO2]RRRCUMQTP(J-1) += WRRRUA
  [M:SLO2]TOTCUMQTP(J-1) += WAAAUA+WQQQUA+WRRRUA
  [M:SLO2]ALLCUMQTP(J-1) += WALLUA
  If [F:ITF]STOMGTCOD = 3
    If  dim([M:SLO2]POT)>0
        If [M:SLO2]TOTCUMQTY(J-1) = 0
          [M:SLO2]POT(J-1) = 0
        Else
          [M:SLO2]POT(J-1) = ([M:SLO2]TOTCUMQTP(J-1)*100)/[M:SLO2]TOTCUMQTY(J-1)
        Endif
    Endif
  Endif
  If [F:ITF]STOMGTCOD = 4
    If [M:SLO2]TOTCUMQTY(J-1) = 0
      [M:SLO2]ACT(J-1) = 0
    Else
      [M:SLO2]ACT(J-1) = [M:SLO2]TOTCUMQTP(J-1)/[M:SLO2]TOTCUMQTY(J-1)
    Endif
  Endif
Endif
If GFEALOTLEV = 2 & [M:SLO1]AGRLEN = 0    # hcb 65433
   Return
Endif

Raz [M:SLO2]LOTCREDAT(J-1)
If dim([M:SLO2]SHLDAT) > 0
   Raz [M:SLO2]SHLDAT   (J-1)
Endif
Raz [M:SLO2]BPSLOT   (J-1)
Raz [M:SLO2]BPSNUM   (J-1)
Raz [M:SLO2]VCRNUM   (J-1)
Raz [M:SLO2]VCRLIN   (J-1)
Raz [M:SLO2]LASRCPDAT(J-1)
Raz [M:SLO2]LASISSDAT(J-1)
Raz [M:SLO2]LASCUNDAT(J-1)
Raz [M:SLO2]USRFLD1  (J-1)
Raz [M:SLO2]USRFLD2  (J-1)
Raz [M:SLO2]USRFLD3  (J-1)
Raz [M:SLO2]USRFLD4  (J-1)
Raz [M:SLO2]DLUDAT   (J-1)      # hcb 65433
Raz [M:SLO2]NEWLTIDAT(J-1)      # hcb 65433

Return

############################################################
# Grisage du site et du code article selon la consultation
# d'où l'on vient (SYMEU)
############################################################
$GRISAGE_CRITERES
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"CONSSMV", "CONSSMJ", "CONSSAT")
        # grisage du site
        Diszo [M:SLO1]STOFCY
        # grisage du code article
        Diszo [M:SLO1]ITMREF
    Endif
Endif
Return
##########################################################################
