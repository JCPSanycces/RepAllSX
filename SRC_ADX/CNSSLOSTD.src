[M:SLO1]FLG = 0
End
########################################
Subprog AM_NOTZERLOT(VALEUR)
Variable Integer VALEUR
[M:SLO1]FLG = 0
End
############################################################
Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If dim([M:SLO1]LOTFLG) < 0 | [F:ITM]LOTMGTCOD = 1
  mkstat = 2
Endif
End
######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SLO2]LOT
######################################################################################
Subprog IB_NBLIG
If [F:ITM]SERMGTCOD = 1
 GBOUT5 = ""
Endif

If (dim([M:SLO2]LOT) > 0 and [M:SLO2]LOT(nolign-1)= "") or [F:ITM]TRKCOD<=1 Then  # SYMEU 61044
 GBOUT6 = ""
Endif
End
############################################################
Subprog AS_NBLIG
GBOUT1 = mess(3,723,1)
End
############################################################
Subprog B1_NBLIG
Local Char PARAM(20)(1..4)
PARAM(1) = "2"
PARAM(2) = [M:SLO1]STOFCY
PARAM(3) = [M:SLO1]ITMREF
PARAM(4) = [M:SLO2]LOT(nolign-1)
Call GCONSULT("SDE","",PARAM) From GCONSULT
End
############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AV_LOT(VALEUR)
Variable Char    VALEUR
If nolign <> 0
   If [M]LOT(nolign-1) = mess(142,124,1)
      pcolor = GCOUL(3)
   Else
      If [M]LOTCREDAT(nolign-1) = [0/0/0]
         pcolor = GCOUL(3)
      Else
         If dim([M]SHLDAT) > 0
            If [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
               pcolor = GCOUL(1)
            Else
               pcolor = GCOUL(0)
            Endif
         Endif
      Endif
   Endif
Endif
End
############################################################
Subprog C_AGRLEN(VALEUR)
Variable Decimal VALEUR
If VALEUR > GLONLOT
  mkstat = 2
Endif
#-- Si agreg sur lot alors agreg sur slo
If dim([M:CSLO]AGRSLOFLG)>0     # hcb 33807
   If VALEUR > 0
      [M:CSLO]AGRSLOFLG=2
      Diszo [M:CSLO]AGRSLOFLG
   Else
      Actzo [M:CSLO]AGRSLOFLG
   Endif
Endif                           # hcb 33807
End
############################################################
Subprog AM_LOCCAT001(VALEUR)
Variable Integer VALEUR
[M:SLO1]FLG = 0
End
############################################################
Subprog AM_LOCCAT002(VALEUR)
Variable Integer VALEUR
[M:SLO1]FLG = 0
End
############################################################
Subprog AM_LOCCAT003(VALEUR)
Variable Integer VALEUR
[M:SLO1]FLG = 0
End
############################################################
Subprog AM_LOCCAT004(VALEUR)
Variable Integer VALEUR
[M:SLO1]FLG = 0
End
############################################################
Subprog IB_ITMREF
If [M:SLO1]ITMREF=""
  Raz GBOUT2, GBOUT3, GBOUT4
Endif
End
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SLO") From SUBGTC

End

