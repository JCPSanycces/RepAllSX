Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
[M:SLO1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
# ISSMGTCOD n'existe plus en 140
#[M:SLO1]CRITRI = [F:ITM]ISSMGTCOD
If [M:SLO1]CRITRI=0
    [M:SLO1]CRITRI = 1
Endif
[M:SLO1]UOM    = [F:ITM]STU
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SLO1]FLG = 0
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:SLO1]FLG = 0
End
