  Endif
  Call MAJDICTRT(AOB_SPE,APPLI,AOB_TXT,AOB_MOD,AOB_ACV) From SUBADC
  Call VALID("TRT",AOB_SPE,APPLI,OK) From VALMSKSUB
 Endif
Endif
Return

#------------------#
$AJOUT
Wrseq "######################################################################################"
Wrseq "##"-mess(81,133,1)-"("+mess(33,115,1)-OBJET+")"-format$("D:"+GFMDAT4,date$)-time$-"("+GUSER+")"
Wrseq "######################################################################################"
# Etiquette ajoutée par le superviseur
Return

#------------------#
$ACTION
Wrseq "$ACTION"
Wrseq "Case ACTION"
Wrseq " When default"
Wrseq "Endcase"
Wrseq "Return"
Wrseq
Return

#------------------#
$LEC_MERE
If NBMERE = 0
 FICAPL = filpath("","APL","ini",APPLI)
 If filinfo(FICAPL,0)>=0
  Openi FICAPL
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>APPLI & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
Endif
Return
