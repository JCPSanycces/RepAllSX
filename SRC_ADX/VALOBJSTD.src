#<AdxTL>@(#)5.0.0.0 $Revision$
#--------------------------------------------------------------
# Ecriture étiquette $action dans traitements SUBxxx et SPExxx
#--------------------------------------------------------------

$VALTRT

#--------------------------------------------------------------
# Traitement SUBxxx
#--------------------------------------------------------------

OK = 1

# Même les objets de type browser peuvent avoir besoin du SUBxxx

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8

If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",AOB_STD,"src")
 Else
  FICSRC = filpath("TRT",AOB_STD,"src",APPLI)
  If filinfo(FICSRC,0)<0
   Gosub LEC_MERE
   For J=1 To NBMERE
    FICSRC = filpath("TRT",AOB_STD,"src",TBMERE(J))
    If filinfo(FICSRC,0)>=0 : Break : Endif
   Next J
  Endif
 Endif

 FLVAL = 0
 If filinfo(FICSRC,0)<0
  If APPLI=nomap
   Call EXISTE_ADX("","",AOB_STD,OKTRT) From ORDSYS
  Else
   Call EXISTE_ADX("",APPLI,AOB_STD,OKTRT) From ORDSYS
   If !OKTRT
    Gosub LEC_MERE
    For J=1 To NBMERE
     Call EXISTE_ADX("",TBMERE(J),AOB_STD,OKTRT) From ORDSYS
     If OKTRT>0 : Break : Endif
    Next J
   Endif
  Endif
  If !OKTRT
   FLVAL = 2
  Endif
 Else
  FLVAL = 1
  Openi FICSRC
  Rdseq LIGNE
  While fstat=0
   Rdseq LIGNE
   J = instr(1,LIGNE,":")
   If J=0
    J = instr(1,LIGNE,"#")
    If J=0
     J = len(LIGNE)+1
    Endif
   Endif
   If vireblc(left$(LIGNE,J-1),2)="$ACTION"
    FLVAL = 0 : Break
   Endif
  Wend
  Openi
 Endif

 If FLVAL
  If GADONIX=2 : # A Sophia, on valide dans l'appli courante
   APPVAL = APPLI
   If GTRACE<>"" & APPLI<>GDOSX3
    # Traitement $1$ modifié dans le dossier $2$
    Call ECR_TRACE(func AFNC.MES2(mess(87,127,1),AOB_STD,APPLI),1) From GESECRAN
   Endif 
  Elsif FLVAL=2 : # Ailleurs, on crée dans le dossier superviseur si le SUB est introuvable
   Call PARAM("","SUPDOS",APPVAL) From ADOVAL
   If APPVAL="" : FLVAL = 0 : Endif
  Else
   APPVAL = APPLI
  Endif
 Endif

 If FLVAL
  FICNEW = filpath("TRT",AOB_STD,"new",APPVAL)
  Openo FICNEW,0
  If FLVAL=2
   Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"-mess(164,123,1)-OBJET : # Gestion objet
  Endif
  If FLVAL=1
   Openi FICSRC
   Rdseq LIGNE
   While fstat=0
    Wrseq LIGNE
    Rdseq LIGNE
   Wend
   Openi
  Endif
  Gosub AJOUT
  Gosub ACTION
  Wrseq
  Wrseq "######################################################################################"
  Wrseq
  Openo
  FICSRC = filpath("TRT",AOB_STD,"src",APPVAL) 
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS 
  If STAT
   Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"|\"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
  Endif
  Call MAJDICTRT(AOB_STD,APPVAL,AOB_TXT,AOB_MOD,AOB_ACV) From SUBADC
  Call VALID("TRT",AOB_STD,APPVAL,OK) From VALMSKSUB
 Endif
Endif

#--------------------------------------------------------------------------------
# Traitement SPVxxx (uniquement pour rajouter $ACTION dans le traitement SPV)
#--------------------------------------------------------------------------------

OK = 1

# Pour gagner du temps chez nous !

If GADONIX=2
 OK = 0
Endif

If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",AOB_SPV,"src")
 Else
  FICSRC = filpath("TRT",AOB_SPV,"src",APPLI)
  If filinfo(FICSRC,0)<0
   Gosub LEC_MERE
   For J=1 To NBMERE
    FICSRC = filpath("TRT",AOB_SPV,"src",TBMERE(J))
    If filinfo(FICSRC,0)>=0 : Break : Endif
   Next J
  Endif
 Endif

 FLVAL = 0
 If filinfo(FICSRC,0)>0
  FLVAL = 1
  Openi FICSRC
  Rdseq LIGNE
  While fstat=0
   Rdseq LIGNE
   J = instr(1,LIGNE,":")
   If J=0
    J = instr(1,LIGNE,"#")
    If J=0
     J = len(LIGNE)+1
    Endif
   Endif
   If vireblc(left$(LIGNE,J-1),2)="$ACTION"
    FLVAL = 0 : Break
   Endif
  Wend
  Openi
 Endif

 If FLVAL
  FICNEW = filpath("TRT",AOB_SPV,"new",APPLI)
  Openo FICNEW,0
  If FLVAL=2
   Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"-mess(164,123,1)-OBJET : # Gestion objet
  Else
   Openi FICSRC
   Rdseq LIGNE
   While fstat=0
    Wrseq LIGNE
    Rdseq LIGNE
   Wend
   Openi
  Endif
  Gosub AJOUT
  Gosub ACTION
  Wrseq
  Wrseq "######################################################################################"
  Wrseq
  Openo
  FICSRC = filpath("TRT",AOB_SPV,"src",APPLI) 
  Call MOVE(FICNEW,FICSRC,STAT) From ORDSYS 
  If STAT
   Call ECR_TRACE(mess(6,123,1)+num$(STAT)-"MOVE"+"\|"+FICNEW+"\|"+FICSRC,1) From GESECRAN : # Erreur
  Endif
  Call MAJDICTRT(AOB_SPV,APPLI,AOB_TXT,AOB_MOD,AOB_ACV) From SUBADC
  Call VALID("TRT",AOB_SPV,APPLI,OK) From VALMSKSUB
 Endif
Endif
Return

#--------------------------------------------------------------------------------
# Traitement SPExxx (uniquement pour rajouter $ACTION dans le traitement SPE)
#--------------------------------------------------------------------------------

OK = 1

# Pour gagner du temps chez nous !

If GADONIX=2
 OK = 0
Endif

If OK
 If APPLI=nomap
  FICSRC = filpath("TRT",AOB_SPE,"src")
