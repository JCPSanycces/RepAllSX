#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################################################
#   Fenêtre de consultation du parc par adresse                     Module CRM             2 avril 2003 #
#########################################################################################################
#########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When Default
  Endcase
Return

#########################################################################################################
$OUVRE
Global Integer GPRESRE6NOL
Global Char GSZSRE6BPC(GLONBPC)
Global Char GSZMACAPOPUP(250)
Global Integer GISRE6HBDISP

  If PARAM(1) = "" Then
    #Aucun client n'est indiqué. Action refusée.
    GMESSAGE = mess(408,182,1)
    GERR = 2
    FIN = 1
  Endif
  GISRE6HBDISP = 0
  GPRESRE6NOL = 0
  Call TEXTE(16568, GSZMACAPOPUP) From OBJDIV      #Parc
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  NAVIG = "FUNMACA"
Return

#########################################################################################################
$DEBUT
  GSZSRE6BPC = PARAM(1)
  Call LOADSRE6
  GISRE6HBDISP = 1
Return

#########################################################################################################
$FINSAI
  If GISRE6HBDISP Then
    Raz [M:SRE6] #Nettoie l'écran avant de partir.
  Endif
  Kill GISRE6HBDISP
  Kill GSZSRE6BPC
  Kill GPRESRE6NOL
  Kill GSZMACAPOPUP
Return

#########################################################################################################
# Sous-programmes
#########################################################################################################
Subprog LOADSRE6
Local Integer ITER

  ITER = 0
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = GSZSRE6BPC Order By [F:BPA]BPAADD
  For [BPA]
    If ITER >= dim([M:SRE6]CODADR) Then
      Break
    Endif
    If ITER = 0 Then
      [M:SRE6]NBADRSEL(ITER) = "->"
    Else
      [M:SRE6]NBADRSEL(ITER) = ""
    Endif
    [M:SRE6]CODADR(ITER) = [F:BPA]BPAADD
    [M:SRE6]BPADES(ITER) = [F:BPA]BPADES
    [M:SRE6]POSCOD(ITER) = [F:BPA]POSCOD
    [M:SRE6]CTY(ITER) = [F:BPA]CTY
    [M:SRE6]SAT(ITER) = [F:BPA]SAT
    [M:SRE6]BPACRY(ITER) = [F:BPA]CRY
    If ITER = 0 Then
      [M:SRE6]CURBPAADD = [M:SRE6]CODADR(ITER)
      Call SETCURADD(1, [F:BPA]BPANUM, [F:BPA]BPAADD)
    Endif
    ITER += 1
  Next
  Filter [BPA]
  [M:SRE6]NBADR = ITER
  Affzo [M:SRE6]
End

#########################################################################################################
Subprog SETCURADD(ITYP, SZBPANUM, SZBPAADD)
Value Integer ITYP
Value Char SZBPANUM
Value Char SZBPAADD

  Local File BPADDRESS [BPA2]
  Read [BPA2]BPA0=ITYP;SZBPANUM;SZBPAADD
  If !fstat Then
    [M:SRE6]XBPADES = [F:BPA2]BPADES
    [M:SRE6]XLIG(0) = [F:BPA2]BPAADDLIG(0)
    [M:SRE6]XLIG(1) = [F:BPA2]BPAADDLIG(1)
    [M:SRE6]XLIG(2) = [F:BPA2]BPAADDLIG(2)
    [M:SRE6]XBPACRY = [F:BPA2]CRY
    [M:SRE6]XSAT = [F:BPA2]SAT
    [M:SRE6]XPOSCOD = [F:BPA2]POSCOD
    [M:SRE6]XCTY = [F:BPA2]CTY
    [M:SRE6]XTEL = [F:BPA2]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]TEL
    [M:SRE6]XFAX = [F:BPA2]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]FAX
    [M:SRE6]XWEB = [F:BPA2]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA2]WEB
  Endif
End

