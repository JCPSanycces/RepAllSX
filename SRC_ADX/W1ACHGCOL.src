#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ACHGCOL 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:00:30"
A_USER  = "DOC"
A_STAMP = "20181109230030"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBCOL"
  If [M]NBCOL=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ACHGCOL [ACOL]
Gosub HORODAT
Local Inpbox "ACHGCOL" From GFONCTION At A_STAMP With A_WINDPREV Mask [ACOL] As [SIM_]
Grizo [ACOL]5
Grizo [ACOL]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ACOL]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
X1(1)=1 : X2(1)=0 : Y1(1)=26 : Y2(1)=25
Return

$ON_TIT
Onevent INIT_AREA Call D_TIT(zc) From W1ACHGCOL
Return

Subprog D_TIT(VALEUR)
Variable Char    VALEUR()
If varinit([M]TIT,indice)=0
 VALEUR = mess(295,143,1)
Endif
Gosub _AFF
End

$ON_DOSSIER
Onevent AFTER_CHANGE Gosub AMM_DOSSIER From W1ACHGCOL
Onevent CONTROL Call C_DOSSIER(zc) From W1ACHGCOL
Onevent BEFORE_INPUT Call AS_DOSSIER(zc) From W1ACHGCOL
Onevent INIT_AREA Call D_DOSSIER(zc) From W1ACHGCOL
Return

Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
If varinit([M]DOSSIER,indice)=0
 VALEUR = nomap
Endif
Gosub _AFF
End

Subprog AS_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1117,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_DOSSIER(zc) From W1ACHGCOL
Onkey   2 Titled GBOUTS Call S_DOSSIER(zc) From W1ACHGCOL
Onkey 144 Titled GBOUTP Call P_DOSSIER(zc) From W1ACHGCOL
Onkey 146 Titled GBOUTA Call SA_DOSSIER(zc) From W1ACHGCOL
Gosub _AFF
End

Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DOSSIER" : GZNUM = 10035 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADS","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "DOSSIER" : GZNUM = 10035 : Endif
Endif
Gosub _AFF
End

$AMM_DOSSIER
Call AM_DOSSIER(zc)
If !mkstat & GOBJET
 zoncou = "DOSSIER" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action APASSWD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "APASSWD"
 PARMSK(1) = VALEUR
 PARMSK(2) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"APASSWD","APASSWD","SPEPASSWD") From GSAISIE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DOSSIER" : GZNUM = 10035 : Endif
Endif
Gosub _AFF
End

Subprog S_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ADS"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_DOSSIER(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ADS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


