#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When Default
Endcase
Return

########################################
Subprog AS_EECSCH(VALEUR)
Variable Char    VALEUR()
If   VALEUR <> ""
     Look [TEE]TEE0 = VALEUR
     If   !fstat : mkstat = 2 : Endif
Endif
End

########################################
Subprog C_EECSCH(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]EECSCH) From OBJDIV
End


########################################
Subprog AS_SCHFLO(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

########################################
Subprog AP_SCHFLO(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End

