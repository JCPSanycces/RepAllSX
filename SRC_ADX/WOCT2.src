Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'CTRNUM'
CLESEC(0) = 'REFNUM'
CLESEC(1) = 'CTRDAT'
Return

$OPTIONS
