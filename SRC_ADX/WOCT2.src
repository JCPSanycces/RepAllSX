$OUVFIC_DERLU
Return

$LEC_DERLU
Read [AFF]AFF0 = [F:HRCTR]ETRFCY;GPROFIL;GUSRFCT
If fstat : Raz [F:AFF] : Endif
Read [FCY]FCY0=[F:HRCTR]ETRFCY
If fstat : Raz [F:FCY] : Endif
Read [ID]ID0=[F:HRCTR]REFNUM
If fstat : Raz [F:ID] : Endif
Return

$CHARGE_DERLU
Return

$REMP_DERLU
Return

$CLE_DERLU
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(1)"
SELEXP(NBSEL) = "[F:HRCTR]ETRFCY-[F:FCY]FCYNAM"
Call TEXTE(1344,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(2)"
SELEXP(NBSEL) = "[F:ID]NAM-[F:ID]SRN-[F:HRCTR]REFNUM"
Call TEXTE(44921,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(3)"
SELEXP(NBSEL) = "[F:HRCTR]CTRNUM"
Call TEXTE(5481,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(4)"
SELEXP(NBSEL) = "[F:HRCTR]CTRDAT"
Call TEXTE(0,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10X"
SELMAJ(NBSEL) = 0
If clalev([F:HRCTR_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
Link [HRCTR] With
& [AFF]AFF0~=[F:HRCTR]ETRFCY;GPROFIL;GUSRFCT,
& [FCY]FCY0=[F:HRCTR]ETRFCY,
& [ID]ID0=[F:HRCTR]REFNUM
& As [HRCTR_]
[G:HRCTR_]currind = 4
Return

$DEFAUT_LISTE
Default file [HRCTR_]
Return

$OUVRE_JOIN
Return

$TIT_JOIN
Return

