#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("TCO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FILTRE"       : Gosub FILTRE
 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "MODIF"        : Gosub MODIF
 When "LIENS2"       : Gosub LIENS2
 When "MODIF"        : Gosub MODIF
 When "ANNULE"       : Gosub ANNULE
 When "CHANGE"       : Gosub CHANGE
 When "SETBOUT"      : Gosub SETBOUT
 When Default
Endcase
Return

$MODIF
Delete [AXX] Where CODFIC="TABCOEFF" & LANGUE=GLANGUE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX","*") From GLOCK : Return
Endif
For nolign=1 To [M]BASTAB
 Call MAJTEXTRA([M]COEAX1(nolign-1),"TABCOEFF","COEAX1",[M]UOM1(nolign-1),[M]UOM2(nolign-1)) From ATEXTRA
 If GOK<1 : Break : Endif
 Call MAJTEXTRA([M]COEAX2(nolign-1),"TABCOEFF","COEAX2",[M]UOM1(nolign-1),[M]UOM2(nolign-1)) From ATEXTRA
 If GOK<1 : Break : Endif
Next nolign
Return

$FILTRE
FILTSUP = "[F:TCO]REV<=1"
Return

$OUVRE
Local Integer DEC
Local File ATYPE [ATY]
Read [ATY]CODTYP = "COE"
If !fstat
 I = instr(1,num$([F:ATY]LNGTYP),".")
 If I
  DEC = val(right$(num$([F:ATY]LNGTYP),I+1))
 Endif
Endif
If DEC=0
 DEC = 6
Endif
Return

$VERIF_MOD
Filter [TCO]
Trbegin [TCO]
 Delete [TCO] Where REV=2
 If fstat=1
  GOK=-1 : Call RSTA("TCO","") From GLOCK : Rollback : OK = 0 : Return
 Endif
Commit
Return

$ANNULE
Delete [AXX] Where CODFIC="TABCOEFF" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="TABCOEFF" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA TABUNIT"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET # chgt de clé n'a pas de sens
Return

$LIENS2
Local Integer W_IND
# [M]BASTAB contient le nb d'enreg chargés à ce moment
While W_IND <= [M]BASTAB
 [M]CONCATKEY(W_IND) = format$("K:"+num$(GLONUOM)+"X",[M]UOM1(W_IND))
 [M]CONCATKEY(W_IND) += format$("K:"+num$(GLONUOM)+"X",[M]UOM2(W_IND))
 W_IND += 1
Wend
Return

############################################################
## Ecran TCO1
############################################################
Subprog APRES_BASTAB
[M]CONCATKEY(nolign-1) = format$("K:"+num$(GLONUOM)+"X",[M]UOM1(nolign-1))
[M]CONCATKEY(nolign-1) += format$("K:"+num$(GLONUOM)+"X",[M]UOM2(nolign-1))
End

Subprog C_UOM2(VALEUR)
Variable Char     VALEUR()
Local Char CONC(2*GLONUOM)
If VALEUR=[M]UOM1(nolign-1)
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
CONC = format$("K:"+num$(GLONUOM)+"X",[M]UOM1(nolign-1))
CONC += format$("K:"+num$(GLONUOM)+"X", VALEUR)
Call UNICITE(CONC, [M]CONCATKEY) From OBJDIV
End

Subprog D_COEDES(VALEUR)
Variable Char     VALEUR()
Local Char W_DES1(GLONDES), W_DES2(GLONDES)
# Concatenation des 2 libelles courts
Call LECTEXTRA(W_DES1,"TABUNIT","DESSHO",[M]UOM1(nolign-1),"") From ATEXTRA
Call LECTEXTRA(W_DES2,"TABUNIT","DESSHO",[M]UOM2(nolign-1),"") From ATEXTRA
VALEUR = W_DES1 + " - " + W_DES2
End

Subprog AS_UOM1(VALEUR)
Variable Char     VALEUR()
If VALEUR <> ""
 Look [TCO]TCO0=VALEUR;[M]UOM2(nolign-1)
 If !fstat : mkstat = 2 : Endif
Endif
End

Subprog AS_UOM2(VALEUR)
Variable Char     VALEUR()
If VALEUR <> ""
 Look [TCO]TCO0=[M]UOM1(nolign-1);VALEUR
 If !fstat : mkstat = 2 : Endif
Endif
End

##################################################
## Conversion et arrondi d'unités (GEODE)       ##
##################################################

Subprog CNVUOM(UOMORG,UOMDES,QTY,STAT)
Value    Char    UOMORG()
Value    Char    UOMDES()
Variable Decimal QTY
Variable Integer STAT

Gosub CNV
If QTY<>0 and COEF > 0
 If COEF < 1
  QTY = arr(QTY*COEF,10^(-GUNTDEC(I))*COEF)
 Else
  QTY = arr(QTY*COEF,10^(-GUNTDEC(I)))
 Endif
Endif
End

Subprog CNVUOM2(UOMORG,UOMDES,QTY,STAT)
Value    Char    UOMORG()
Value    Char    UOMDES()
Variable Decimal QTY
Variable Integer STAT

Gosub CNV
If QTY<>0
 QTY = -int(-[L]QTY*[L]COEF*10^[V]GUNTDEC(I))*10^(-[V]GUNTDEC(I))
Endif
End

$CNV
STAT = 0
If QTY=0 : Return : Endif

Local Decimal COEF
Local Shortint I

If UOMDES=UOMORG
 COEF = 1
Else
 If clalev([F:TCO])=0 : Local File TABCOEFF [TCO] : Endif
 If [F:TCO]UOM1=UOMORG & [F:TCO]UOM2=UOMDES
  COEF = [F:TCO]COEUOM
 Elsif [F:TCO]UOM1=UOMDES & [F:TCO]UOM2=UOMORG & [F:TCO]COEUOM<>0
  COEF = 1/[F:TCO]COEUOM
 Else
  Read [TCO]TCO0 = UOMORG;UOMDES
  If fstat=0
   COEF = [F:TCO]COEUOM
  Else
   Read [TCO]TCO0 = UOMDES;UOMORG
   If fstat=0 & [F:TCO]COEUOM<>0
    COEF = 1/[F:TCO]COEUOM
   Else
    COEF = 0 : STAT = 1
   Endif
  Endif
 Endif
Endif
I = find(UOMDES,GUNITE(1..GNBUNT))
Return

