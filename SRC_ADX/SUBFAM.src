#
#                  GESTION DES FAMILLES IMMOBILISATION
#
#*********************************************************************
#
# CBO   15.05.2014 FQ69690   : RE-création
# GLE   19.04.2011 FQ69690   : Création
#
#*********************************************************************
#    Modification
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# MDJ   03.11.2015 112221   : Control associations values before delete Family
# FPE   04.10.2017 X3_51842 : Missing process when Changing the key
#*********************************************************************
End

######################################################################################
# ACTIONS SUR L'OBJET
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "LIENS"      : Gosub LIENS
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "ANNULE"     : Gosub ANNULE
    When "CHANGE"     : Gosub CHANGE
    When "SETBOUT"    : Gosub SETBOUT
    When "APRES_CHOI" : Gosub APRES_CHOI  # Issue 112221
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([RDP]) : Local File RUBASSDEFP [RDP] : Endif
Return

######################################################################################
$LIENS
  Gosub BUILD_ASSOC
Return

######################################################################################
$CREATION
$MODIF
  Local Char L_LEG(20)
  If dim([M:FAM1]LEG) < 0
    L_LEG = ""
  Else
    L_LEG = [M:FAM1]LEG
  Endif

  Call MAJTEXTRA([M:FAM1]FAMDES, "FASFAM", "FAMDES", [M:FAM1]FAMREF, "") From ATEXTRA
  Call MAJTEXTRA([M:FAM1]SHODES, "FASFAM", "SHODES", [M:FAM1]FAMREF, "") From ATEXTRA
Return

######################################################################################
$ANNULE
  Local Char L_LEG(20)
  If dim([M:FAM1]LEG) < 0
    L_LEG = ""
  Else
    L_LEG = [M:FAM1]LEG
  Endif

  Delete [AXX] Where CODFIC="FASFAM" & IDENT1=[M:FAM1]FAMREF

Return
#********************************************************************
$APRES_CHOI

If dim(REPONSE)>0
  Case REPONSE
    When GSTAANU : Gosub CTL_ANU : # Issue 112221 Control of associations values
  Endcase
Endif

Return
#Issue 112221 ********************************************************************
$CTL_ANU
Local Integer OUINON

Filter[RVA] Where (DETAAS=GVML_DTAFAM & VALDETAAS=[M:FAM1]FAMREF)
Read[RVA]First
If !fstat
   # 'Suppression impossible : famille utilisée dans association
   GMESSAGE = mess(384,GML_MSGFASPR,1)-[F:RVA]ACM-" "-[F:RVA]CPY
   REPONSE =0 :
Endif
Filter[RVA]

Return
##################### #################################################################
$CHANGE
  Local Char L_LEG(20)
  If dim([M:FAM1]LEG) < 0
    L_LEG = ""
  Else
    L_LEG = [M:FAM1]LEG
  Endif

  # CBO 2015.01.14
  # Update [AXX] Where CODFIC="FASFAM" & IDENT1=[M:FAM1]FAMREF With IDENT1=[M:FAM1]FAMREF
  Update [AXX] Where CODFIC="FASFAM" & IDENT1=[L]OCODE With IDENT1 = [L]NCODE

# Issue X3-51842
  If GVML_DTAFAM = 1
    Update [RVA] Where DETAAS = GVML_DTAFAM and VALDETAAS = OCODE
&     With VALDETAAS = NOUVEAU
    Update [RVP] Where NUMASS = [F:RVA]NUMASS and VALDETAAS = [F:RVA]VALDETAAS
&     With VALDETAAS = NOUVEAU
  Endif
# End issue X3-51842

Return

######################################################################################
$SETBOUT
  If GREP="C"
    Call VIREBOUT(CHAINE, "V") From GOBJET
    Call VIREBOUT(CHAINE, "G") From GOBJET # FQ69690BC
  Endif
Return

######################################################################################
# NOMENCLATURE VERTICALE
######################################################################################
$BUILD_ASSOC
  Local Integer TYPOBJCUR
  Local Char    ACMCUR(GLONGCM)
  Local Char    CPYCUR(GLONCPY)
  Local Integer N_I, WVALUE_OK

  nolign        = 0
  [M:FAM1]CLE(0)     = "ROOT"
  [M:FAM1]LIBLONG(0) = [M:FAM1]FAMREF - func GLOFUNC.LIRE_TEXTRA("FASFAM", "FAMDES", [M:FAM1]FAMREF, "")
  [M:FAM1]ICONE(0)   = "Folder.gif"
  [M:FAM1]NUMASS(0)  = "0"
  Call SETCLE(0,"","")
  nolign        += 1

  For [RVA]RVA1 Where DETAAS = GVML_DTAFAM and VALDETAAS = [M:FAM1]FAMREF
    # Niveau type d'objet
    If TYPOBJCUR <> [F:RVA]REFOBJ
      TYPOBJCUR = [F:RVA]REFOBJ
      ACMCUR    = "&"
      [M:FAM1]CLEPERE(nolign) = "ROOT"
      [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)
      [M:FAM1]LIBLONG(nolign) = mess([F:RVA]REFOBJ,3141,1)
      [M:FAM1]ICONE(nolign)   = "Folder.gif"
      [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
      Call SETCLE(0,"","")
      nolign += 1
    Endif

    # Niveau modèle comptable
    If ACMCUR <>  [F:RVA]ACM
      ACMCUR = [F:RVA]ACM
      CPYCUR = "&"
      [M:FAM1]CLEPERE(nolign) = num$([F:RVA]REFOBJ)
      [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)+[F:RVA]ACM
      [M:FAM1]LIBLONG(nolign) = func GLOFUNC.GET_ATEXTE(27516)-[F:RVA]ACM
      [M:FAM1]ICONE(nolign)   = "Folder.gif"
      [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
      Call SETCLE(0,"","")
      nolign += 1
    Endif

    # Niveau Société
    If CPYCUR <>  [F:RVA]CPY
      CPYCUR = [F:RVA]CPY
      [M:FAM1]CLEPERE(nolign) = num$([F:RVA]REFOBJ)+[F:RVA]ACM
      [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")
      If [F:RVA]CPY = ""
        [M:FAM1]LIBLONG(nolign) = func GLOFUNC.GET_ATEXTE(5083)
      Else
        [M:FAM1]LIBLONG(nolign) = func GLOFUNC.GET_ATEXTE(1343)-[F:RVA]CPY
      Endif
      Call SETCLE([F:RVA]REFOBJ,[F:RVA]ACM,[F:RVA]CPY)
      [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
      [M:FAM1]ICONE(nolign)   = "Folder.gif"
      nolign += 1
    Endif

    # Valeurs hors plan
    For N_I = 0 To [F:RVA]NBLIG-1
      [M:FAM1]CLEPERE(nolign) = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")
      [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")+[F:RVA]RUBRAS(N_I)
      [M:FAM1]LIBLONG(nolign) = func GET_LNGDES_ATABDIV([F:RVA]RUBRAS(N_I))-":"-func SUBFAM.GET_VAL("[F:RVA]", [F:RVA]RUBRAS(N_I), "VALDETEAS("+num$(N_I)+")")
      [M:FAM1]ICONE(nolign)   = "ico.gif"
      [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
      Call SETCLE([F:RVA]REFOBJ,[F:RVA]ACM,[F:RVA]CPY)
      nolign += 1
    Next

    # Valeurs plan
    For [RVP]RVP0 Where NUMASS=[F:RVA]NUMASS and VALDETAAS=[F:RVA]VALDETAAS
      # 1° Affichage du plan traité
      [M:FAM1]CLEPERE(nolign) = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")
      [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")+num$([F:RVP]DPRPLN)
      [M:FAM1]LIBLONG(nolign) = func GLOFUNC.GET_ATEXTE(33972)-mess([F:RVP]DPRPLN,3101,1)
      [M:FAM1]ICONE(nolign)   = "Folder.gif"
      [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
      Call SETCLE([F:RVA]REFOBJ,[F:RVA]ACM,[F:RVA]CPY)
      nolign += 1

      # 2° Affichage des valeurs paramétrées du plan
      For [F:ADI]CODE Where NUMTAB=961 and A1="P"
        WVALUE_OK = 1
        Case evalue("type([F:RVP]"+[F:ADI]CODE+")")
          When 1, 2, 4, 5, 6, 7, 9
             If evalue("[F:RVP]"+[F:ADI]CODE) = 0
                WVALUE_OK = 0
             Endif
          When 3
             If evalue("[F:RVP]"+[F:ADI]CODE) = [0/0/0]
                WVALUE_OK = 0
             Endif
          When Default
             If evalue("[F:RVP]"+[F:ADI]CODE) = ""
                WVALUE_OK = 0
             Endif
        Endcase

        # Vérif si valeurs OK (idem SUBRVA) et non affichage sinon
        If WVALUE_OK
            Gosub VERIF_VAL_PLN
        Endif

        If WVALUE_OK
            [M:FAM1]CLEPERE(nolign) = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")+num$([F:RVP]DPRPLN)
            [M:FAM1]CLE(nolign)     = num$([F:RVA]REFOBJ)+[F:RVA]ACM+[F:RVA]CPY+string$([F:RVA]CPY="","&")+num$([F:RVP]DPRPLN)+[F:ADI]CODE
            [M:FAM1]LIBLONG(nolign) = func GET_LNGDES_ATABDIV([F:ADI]CODE)-":"-func SUBFAM.GET_VAL("[F:RVP]", [F:ADI]CODE, [F:ADI]CODE)
            [M:FAM1]ICONE(nolign)   = "ico.gif"
            [M:FAM1]NUMASS(nolign) = sum(num$([F:RVA]REFOBJ), "1", [F:RVA]ACM, [F:RVA]CPY)
            Call SETCLE([F:RVA]REFOBJ,[F:RVA]ACM,[F:RVA]CPY)
            nolign += 1

        Endif
      Next
    Next
  Next

  [M:FAM1]NBASSO = nolign
  nolign = 1
Return

# valeurs interdites (adapté de $LIENS de SUBRVA)
$VERIF_VAL_PLN

  Read [RDP]RDP0 = [F:RVA]REFOBJ;[F:RVA]DETAAS;[F:RVA]ACM;[F:RVA]CPY;[F:RVP]DPRPLN
  If fstat
    WVALUE_OK = 0
    Return
  Endif


  Case [F:ADI]CODE
    When "DPM"
      If [F:RDP]MGTFLGP(0) <> G_OUI
        WVALUE_OK = 0
#        [M:RVA1]DPM(nolign-1)=""
      Endif

    When "DPRDUR"
      If [F:RDP]MGTFLGP(1) <> G_OUI
        WVALUE_OK = 0
#        [M:RVA1]DPRDUR(nolign-1) = 0
      Endif

    When "DPRRAT"
      #-Taux interdit si non géré ou si mode = DF ou DM
      If [F:RDP]MGTFLGP(2) <> G_OUI or [F:RVP]DPM = G_DPMDF or [F:RVP]DPM = G_DPMDM
        WVALUE_OK = 0
#        [M:RVA1]DPRRAT(nolign-1) = 0
      Endif

    When "ALWCOD"
      If [F:RDP]MGTFLGP(3)  <> G_OUI
         WVALUE_OK = 0
#        [M:RVA1]ALWCOD(nolign-1)=0
      Endif

   When "CRBVEHCOD"
      If [F:RDP]MGTFLGP(4) <> G_OUI or [F:RVP]DPRPLN <> G301FIS
        WVALUE_OK = 0
#        [M:RVA1]CRBVEHCOD(nolign-1)= ""
      Endif

    When "DPRRAT2"
      #*Taux exceptionnel interdit si non géré ou mode <> IT, AL,AD  ou taux normal = 0
      If [F:RDP]MGTFLGP(5) <> G_OUI or
&        (find([F:RVP]DPM, G_DPMIT, G_DPMAL, G_DPMAD) = 0)  or  [F:RVP]DPRRAT = 0 or
&        ([F:RDP]MGTFLGP(2) <> G_OUI or [F:RVP]DPM= G_DPMDF or [F:RVP]DPM = G_DPMDM) # reprise du test de DPRRAT
        WVALUE_OK = 0
#        [M:RVA1]DPRRAT2(nolign-1) = 0
      Endif

    When "PRATYP"
      #* Type prorata temporis interdit si mode <> UD, "UL" et "RE"
      If [F:RDP]MGTFLGP(6) <> G_OUI or
&       ( find([F:RVP]DPM, G_DPMUD, G_DPMUL, G_DPMRE, G_DPMHL, G_DPMHD) = 0)
        WVALUE_OK = 0
#        [M:RVA1]PRATYP(nolign-1)= 0
      Endif

    When "ACLCOE"
      #*-Coefficient d'accélération interdit si mode <> UD ----------
      If [F:RDP]MGTFLGP(7) <> G_OUI or
&      ( [F:RVP]DPM <>  G_DPMUD and [F:RVP]DPM <> G_DPMDB )
        WVALUE_OK = 0
#        [M:RVA1]ACLCOE(nolign-1)=0
      Endif

    When Default
  Endcase

Return

######################################################################################
Funprog GET_LNGDES_ATABDIV(CHAMP)
Value Char    CHAMP
  If [F:ADI]NUMTAB <> 961 or [F:ADI]CODE <> CHAMP
    Read [ADI]CODE=961; CHAMP
    If fstat
      Raz [F:ADI]
    Endif
  Endif
End func GLOFUNC.LIRE_TEXTRA("ATABDIV", "LNGDES", "961", [F:ADI]CODE)


Funprog GET_VAL(CLASSE, NOMCHAMP, VALCHAMP)
Value Char    CLASSE, NOMCHAMP, VALCHAMP

  If [F:ADI]NUMTAB <> 961 or [F:ADI]CODE <> NOMCHAMP
    Read [ADI]CODE=961;NOMCHAMP
    If fstat
      End ""
    Endif
  Endif

  If CLASSE = "[F:RVP]"
    Case evalue("type("+CLASSE+NOMCHAMP+")")
      When 1, 2, 4, 5, 6, 7, 9
         If [F:ADI]N2 > 0
           End mess(evalue(CLASSE+VALCHAMP),[F:ADI]N2,1)
         Endif
         End num$(evalue(CLASSE+VALCHAMP))
      When 3
         End format$("DD2",evalue(CLASSE+VALCHAMP))
      When Default
         End evalue(CLASSE+VALCHAMP)
    Endcase
  Elsif CLASSE = "[F:RVA]"
    If [F:ADI]N2 > 0
      End mess(val(evalue(CLASSE+VALCHAMP)),[F:ADI]N2,1)
    Endif
    End evalue(CLASSE+VALCHAMP)
  Endif
End

######################################################################################
Subprog SETCLE(REFOBJ, ACM, CPY)
Value Integer REFOBJ
Value Char    ACM
Value Char    CPY

  [M:FAM1]REFOBJ(nolign)    = REFOBJ
  [M:FAM1]ACM(nolign)       = ACM
  [M:FAM1]CPY(nolign)       = CPY
  [M:FAM1]VALDETAAS(nolign) = [M:FAM1]FAMREF
End

######################################################################################
Subprog MAJHIER(CODACT,NLI,FATHVAL,RANGNIV,MESSAGE,CODRET)
Value Char CODACT
Value Integer NLI
Value Integer FATHVAL
Value Integer RANGNIV
Variable Char MESSAGE
Variable Integer CODRET

  # Si on n'a pas toute la clé d'accès on ne fait pas le tunnel
  If [M:FAM1]REFOBJ(NLI-1) = 0 : End : Endif

  Local Char CLE1(2) : CLE1 = "1"
  Call OBJET_CHAR(CLE1,"RVA",num$([M:FAM1]REFOBJ(NLI-1))+"~"+[M:FAM1]ACM(NLI-1)+"~"+[M:FAM1]CPY(NLI-1)+"~"+[M:FAM1]VALDETAAS(NLI-1)) From GOBJET
End

######################################################################################
# ACTIONS SUR CHAMPS
######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
  If dim([M:FAM1]LEG) >= 0
    # Si c'est une société qui est saisie on contrôle qu'elle est compatible avec la législation
    Call LECTURE("CPY", VALEUR, "") From CONTOBJ
    If [M:FAM1]LEG <> "" and [F:CPY]LEG <> "" and [M:FAM1]LEG <> [F:CPY]LEG
      Call ECR_TRACE(func AFNC.MES2(mess(279, GML_MSGFASPR, 1), VALEUR, [F:CPY]LEG), 1) From GESECRAN
      mkstat = 2
    Endif
  Endif
End

#** create account family (call in differents traitments)
#*  replace TRT_TABDIV from GLOFUNCIMP for family
#*
#*
#* @param PCOD
#* @param PDES
#*!
Subprog CRT_FAM(PCOD, PDES)

Value Char    PCOD
Value Char    PDES

  GOK=1

  If PCOD = ""
      End
  Endif

  Local File FASFAM [FAM]

  Look [F:FAM]FAM0 = PCOD
  If fstat
    Raz [F:FAM]
    [F:FAM]FAMREF = PCOD

    Write [FAM]
    If fstat
      # Donnée de base créée automatiquement : Table diverse n CODE LNGDES Erreur X
      Call ECR_TRACE(mess(46, GML_MSGLOF, 1) - PCOD - PDES - mess(7, 21, 1) - num$(fstat), 1) From GESECRAN
      GOK = 0
      End
    Endif

    If PDES = ""
      PDES = PCOD
    Endif

    Call MAJTEXTRA(PDES, "FASFAM", "FAMDES", PCOD, "") From ATEXTRA
    Call MAJTEXTRA(PDES, "FASFAM", "SHODES", PCOD, "") From ATEXTRA
  Endif
End

