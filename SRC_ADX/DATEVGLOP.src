#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
    Case ACTION
        When "INIT"     : Gosub INIT
        When "INIT_DIA" : Gosub INIT_DIA
        When "EXEC"     : Gosub EXEC
        When Default
    Endcase
Return

$INIT
    Local Char LCOA(GLONCOA) : [L]LCOA = PARAM(1)
    Local Char CRITERE(250)

    If clalev([F:DTA]) = 0 Then : Local File DATEVGLACC [DTA] : Endif
    If clalev([F:GAC]) = 0 Then : Local File GACCOUNT   [GAC] : Endif
Return

$INIT_DIA
    [M:DGC]COA = [L]LCOA
    Gosub BUILD_CRITERIA
    Filter [F:GAC] Where evalue([L]CRITERE)
    [M:DGC]CNT = rowcount([F:GAC])
    Filter [F:GAC]
Return

$EXEC
    Local Integer I
    Local Integer FOUND

    Gosub BUILD_CRITERIA
    Filter [F:GAC] Where evalue([L]CRITERE)

    For [F:GAC]GAC0
        [L]FOUND = 0
        For [L]I = 0 To [M:DTA]NBLIG - 1
            If [M:DTA]ACC([L]I) = [F:GAC]ACC Then
                [L]FOUND = 1
                Break
            Endif
        Next [L]I
        If [L]FOUND = 1 Then
            # update
            If [M:DGC]DELASS = [V]CST_AYES Then
                # the "Remove existing assignment" flag is set
                [M:DTA]ACCDATEV([L]I) = ""
                [M:DTA]FLGAUTO([L]I) = [V]CST_ANO
            Endif
        Else
            # insert
            [L]I = [M:DTA]NBLIG
            [M:DTA]ACC([L]I) = [F:GAC]ACC
            [M:DTA]ACCDATEV([L]I) = ""
            [M:DTA]FLGAUTO([L]I) = [V]CST_ANO
            [M:DTA]NBLIG += 1
        Endif
    Next
    Affzo [M:DTA]1-99
    # FIXME cannot tell the object that the grid content is modified

    Filter [F:GAC]
Return

$BUILD_CRITERIA
    [L]CRITERE = "[F:GAC]COA='" + [M:DGC]COA + "'"

    If [M:DGC]GACSTR <> "" Then
        [L]CRITERE -= "& [F:GAC]ACC>='" + [M:DGC]GACSTR + "'"
    Endif

    If [M:DGC]GACEND <> "" Then
        [L]CRITERE -= "& [F:GAC]ACC<='" + [M:DGC]GACEND + "'"
    Endif
Return

########################################################################################################################
## Section automatically added (screen DATEVGLOP) 08/16/2017 13:00:56 (TOGAN)
########################################################################################################################

Subprog AM_GACSTR(VALEUR)
    Variable Char VALEUR()
    [M:DGC]GACSTR = VALEUR
    Gosub UPDATE_COUNT
End

Subprog AM_GACEND(VALEUR)
    Variable Char VALEUR()
    [M:DGC]GACEND = VALEUR
    Gosub UPDATE_COUNT
End

########################################################################################################################

$UPDATE_COUNT
    Local Char CRITERE(250)

    Gosub BUILD_CRITERIA
    Filter [F:GAC] Where evalue([L]CRITERE)
    [M:DGC]CNT = rowcount([F:GAC])
    Filter [F:GAC]
    Affzo [M:DGC]CNT
Return

########################################################################################################################

