#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ATXNOTRANS","ATXNOTRANS",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "SORTIE"   : Gosub SORTIE
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "EXEC"      : Gosub EXEC
Endcase
Return

$INIT
If clalev([F:ART])=0 : Local File AREFTXT [ART] : Endif
Return

$SORTIE
Close Local File [ART]
Return

$AVANT_PAR
Gosub DEFVAR From AGLOBTRAD
TIT = mess(158,123,1)
Return

$EXEC
Local Integer SYNC : SYNC=0     # X3-9046 : for synchronization with textx server
Local Char TMPFOLDER (200)
TMPFOLDER = filpath("TRA","","")

Case GOS(1)
 When "unix"
  TMPFOLDER = TMPFOLDER + "/"
 When "dos"
  TMPFOLDER = TMPFOLDER + "\"
Endcase
Call AP_USEFLG([M:TNT0]USEFLG)

# X3-9046 : for synchronization with texts server
If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2"
    SYNC = 1
Endif

Call XXNOTRANS([M:TNT0]LANGUE,[M:TNT0]USEFLG,SYNC)
Call ECR_TRACE("Files are in the log subdirectory",0) From GESECRAN
Return

######################################

Subprog XXNOTRANS(EXTLAN,USEFLG,SYNC)
Value Char EXTLAN
Value Integer USEFLG
Value Integer SYNC

Local File ATEXTE [ATX]
Local File ATEXTE [ATX2]
Local File ATEXTE [ATX3]

Local File APLSTD [AST]
Local File APLSTD [AST2]
Local File APLSTD [AST3]
Local File AMENLOC [AML] # X3-9046 : for synchronization

Local File ATEXTRA [ATT]
Local File ATEXTRA [ATT2]
Local File ATEXTRA [ATT3]


Local Char WTEXTE(123)
Local Char WLANMES(123)
Local Char WLANORI(40)

Local Char WUSR(40)

Local Integer COMPTEUR
Local Char RAPPORT (200)

Local Char TMPFOLDER (200)
TMPFOLDER = filpath("TRA","","")
Case GOS(1)
    When "unix"
        TMPFOLDER = TMPFOLDER + "/"
    When "dos"
        TMPFOLDER = TMPFOLDER + "\"
Endcase


COMPTEUR = 0
WTEXTE   = ""
WLANORI  = ""
WLANMES  = ""
WUSR = ""
RAPPORT  = TMPFOLDER + "NOTRANSATX" + EXTLAN + ".tra"

Openo RAPPORT, 0
Wrseq '##############################################################################'
Wrseq '#                  ATEXTE : UNTRANSLATED RECORDS                             #'
Wrseq '#----------------------------------------------------------------------------#'
If GADONIX = 2 and GSOPHIA
    # on a tjs le fra traduit dans les en indus il est traduit mêm si co dev
    # donc pas besoin de filtre uniquement qur eng
    #115210/6
    Filter [ATX] Where LAN = "FRA" and (NUMERO < GMAXTXTSTD | NUMERO>GNEWTXTSTD) Order By Key NUMERO
Else
    Filter [ATX] Where LAN = "FRA" Order By Key NUMERO
Endif
    For [ATX]NUMERO
      OKREF=1
      WTEXTE= ""
      WLANORI =""
      WUSR = ""
      If USEFLG=2 : Read [ART]ART0=[F:ATX]NUMERO : If fstat : OKREF=0 : Endif : Endif
      If OKREF=1
         Read [ATX2]NUMERO = EXTLAN;[F:ATX]NUMERO
         If fstat
             COMPTEUR += 1
             If find(EXTLAN,"CHI","RUS")
                    # on recherche la trad en ENG pour faciliter la traduction des chinois et des russes
                    # et on affiche l'eng
                    Read [ATX3]NUMERO = "ENG";[F:ATX]NUMERO
                    If fstat = 0
                        WTEXTE =[F:ATX3]TEXTE
                    Else
                        WTEXTE =[F:ATX2]TEXTE
                    Endif
             Else
                    WTEXTE =[F:ATX]TEXTE
             Endif
         Else
          # cg janv 2012 maintenant sur tous les env. v7 on a le record avec lanori
          # donc si lanori = fra --> c'est à traduire
          If dim ([F:ATX2]LANORI) > 0 and [F:ATX]TEXTE = [F:ATX2]TEXTE and [F:ATX2]LANORI = "FRA"
                 COMPTEUR += 1
                 WTEXTE =[F:ATX]TEXTE
                 WLANORI = "Text origin"-[F:ATX2]LANORI
          Elsif [F:ATX]TEXTE <> "" and [F:ATX2]TEXTE = ""
                 COMPTEUR += 1
                 # cg 2012
                 If find(EXTLAN,"CHI","RUS")
                    # on recherche la trad en ENG pour faciliter la traduction des chinois et des russes
                    # et on affiche l'eng
                    Read [ATX3]NUMERO = "ENG";[F:ATX]NUMERO
                    If fstat = 0
                        WTEXTE =[F:ATX3]TEXTE
                    Else
                        WTEXTE =[F:ATX]TEXTE
                    Endif
                  Else
                    WTEXTE =[F:ATX]TEXTE
                  Endif
           Else
                If find(EXTLAN,"CHI","RUS")
                    If [F:ATX]TEXTE <> ""
                        # on recherche pour le chinois si le texte bri n'a pas ete copié dans le CHI
                        # si c'est le cas on demande a retraduire
                        # attention au texte identique au fra : ne pas les faire apparaitre
                        # exemple de texte specifique "X1"
                        # suite a demande (2007) sophie rebeyrotte : inversion
                        # c'est maintenant le ENG qui est maitre et qui met a jour le bri
                        Read [ATX3]NUMERO = "ENG";[F:ATX]NUMERO
                        If fstat = 0
                            If [F:ATX3]TEXTE=[F:ATX2]TEXTE and [F:ATX2]TEXTE <>[F:ATX]TEXTE
                                 COMPTEUR += 1
                                 #Wrseq format$("N0:8",[F:ATX]NUMERO);':';[F:ATX]TEXTE;"      ---> in english : ";[F:ATX2]TEXTE
                                 # le texte apparait en anglais dans la trace
                                 WTEXTE =[F:ATX2]TEXTE
                            Endif
                        Endif
                    Endif
                Endif
            Endif
         Endif
         If [F:ATX]UPDUSR <> ""
             WUSR = [F:ATX]UPDUSR
         Else
             WUSR = [F:ATX]CREUSR
         Endif

         # ecriture dans log
         If WTEXTE<> ""
            If WLANORI <> ""
                Wrseq format$("N:8",[F:ATX]NUMERO);':';format$("K:80X",WTEXTE);' / user :';format$("K:5X",WUSR); ' / ';WLANORI
            Else
                Wrseq format$("N:8",[F:ATX]NUMERO);':';format$("K:80X",WTEXTE);' / user :';format$("K:5X",WUSR)
            Endif
         Endif
      Endif
    Next
Filter [ATX]
Wrseq '#----------------------------------------------------------------------------#'
Wrseq ' ';COMPTEUR;' Untranslated records ... '
Wrseq '##############################################################################'
Openo

COMPTEUR = 0
WLANMES  = ""
WTEXTE   = ""
WLANORI  = ""
RAPPORT  = TMPFOLDER + "NOTRANSAST" + EXTLAN + ".tra"

Openo RAPPORT, 0
Wrseq '##############################################################################'
Wrseq '#                  APLSTD : UNTRANSLATED RECORDS                             #'
Wrseq '#----------------------------------------------------------------------------#'

# X3-9046 : Need to synchronize local menus from text server
If SYNC
    Local Char LLAN(GLONLAN)(3)
    LLAN(0)="FRA"
    LLAN(1)="ENG"
    If !find(EXTLAN,"FRA","ENG")
        LLAN(2) = EXTLAN
    Endif

    Local Integer LSTATUS
    LSTATUS = func SYNCHRONIZE(0, 2, 0, LLAN)
Endif

# en codev il peut y avoir des aml en eng non traduit en fra
# si cod fra
# il faut faire deux passes sur les env indus lanoir blanc et lanori = eng pour le fra
If EXTLAN = "FRA" and GADONIX = 2 and GSOPHIA
  Filter [AST] Where LAN = "FRA" and LANORI = "ENG" Order By Key CLE
  For [AST]CLE
     If vireblc([F:AST]LANMES,4) <> ""
         WLANMES= ""
         WLANORI =""
         Read [AST2]CLE = [F:AST]LANCHP;[F:AST]LANNUM;"ENG"
         If fstat = 0
            # enreg
             COMPTEUR += 1
             WLANORI= "ENG"
             # le texte apparait en anglais dans la trace
             WLANMES= [F:AST2]LANMES
         Endif
         # ecriture dans log
         If [F:AST]UPDUSR <> ""
             WUSR = [F:AST]UPDUSR
         Else
             WUSR = [F:AST]CREUSR
         Endif
         If WLANMES<>""
            If WLANORI <> ""
                Wrseq format$("N:5",[F:AST]LANCHP);' ';format$("N:5",[F:AST]LANNUM);':';format$("K:123X",WLANMES);" / user : ";format$("K:5X",WUSR);' / ';WLANORI
            Else
                Wrseq format$("N:5",[F:AST]LANCHP);' ';format$("N:5",[F:AST]LANNUM);':';format$("K:123X",WLANMES);" / user : ";format$("K:5X",WUSR)
            Endif
         Endif
      Endif
    Next
    Filter [AST]
Else
    Filter [AST] Where LAN = "FRA" Order By Key CLE
    For [AST]CLE
     If vireblc([F:AST]LANMES,4) <> ""
         WLANMES= ""
         WLANORI =""
         Read [AST2]CLE = [F:AST]LANCHP;[F:AST]LANNUM;EXTLAN
         If fstat
            # enreg n existe pas
             COMPTEUR += 1
             If find(EXTLAN,"CHI","RUS")
                    # on recherche la trad en ENG pour faciliter la traduction des chinois et de russes
                    # et on affiche l'eng
                    Read [AST3]CLE = [F:AST]LANCHP;[F:AST]LANNUM;"ENG"
                    If fstat = 0
                        # le texte apparait en anglais dans la trace
                         WLANMES= [F:AST3]LANMES
                    Else
                         WLANMES= [F:AST]LANMES
                    Endif
             Else
                    WLANMES= [F:AST]LANMES
             Endif
         Else
             If [F:AST2]LANMES = ""
                COMPTEUR += 1
                # cg 2012  comme le message existe mais vide il faut aussi faire de meme
                # que si existe pas .. si chi --> affchage ENG
                 If find(EXTLAN,"CHI","RUS")
                    # on recherche la trad en ENG pour faciliter la traduction des chinois et de russes
                    # et on affiche l'eng
                    Read [AST3]CLE = [F:AST]LANCHP;[F:AST]LANNUM;"ENG"
                    If fstat = 0
                        # le texte apparait en anglais dans la trace
                         WLANMES= [F:AST3]LANMES
                    Else
                         WLANMES= [F:AST]LANMES
                    Endif
                 Else
                    WLANMES= [F:AST]LANMES
                 Endif
             Elsif dim ([F:AST2]LANORI) > 0 and [F:AST]LANMES = [F:AST2]LANMES and [F:AST2]LANORI = "FRA"
                  # cg janv 2012 maintenant sur tous les env. v7 on a le record avec lanori
                  # donc si lanori = fra --> c'est à traduire
                 COMPTEUR += 1
                 WLANMES =[F:AST]LANMES
                 WLANORI = "Text origin"-[F:AST2]LANORI
             Elsif dim ([F:AST2]LANORI) > 0 and [F:AST2]LANORI = "ENG"
                  # cg janv 2012 maintenant sur tous les env. v7 on a le record avec lanori
                  # donc si lanori = eng --> c'est à traduire
                  # mais pas a traduire en eng
                  If EXTLAN <> "ENG"
                     COMPTEUR += 1
                     WLANMES = [F:AST]LANMES
                     WLANORI = "Text origin"-[F:AST2]LANORI
                 Endif
             Else
                If find(EXTLAN,"CHI","RUS")
                        # on recherche pour le chinois si le texte bri n'a pas ete copié dans le CHI
                        # si c'est le cas on demande a retraduire
                        # attention au texte identique au fra : ne pas les faire apparaitre
                        # exemple de texte specifique "X1"
                        # suite a demande (2007) sophie rebeyrotte : inversion
                        # c'est maintenant le ENG qui est maitre et qui met a jour le bri
                        Read [AST3]CLE = [F:AST]LANCHP;[F:AST]LANNUM;"ENG"
                        If fstat = 0
                            If [F:AST3]LANMES=[F:AST2]LANMES and [F:AST2]LANMES<>[F:AST]LANMES
                                 COMPTEUR += 1
                                 # le texte apparait en anglais dans la trace
                                 WLANMES= [F:AST2]LANMES
                            Endif
                        Endif
                Endif
             Endif
         Endif
         # ecriture dans log
         If [F:AST]UPDUSR <> ""
             WUSR = [F:AST]UPDUSR
         Else
             WUSR = [F:AST]CREUSR
         Endif

         If WLANMES<>""
            If WLANORI <> ""
                Wrseq format$("N:5",[F:AST]LANCHP);' ';format$("N:5",[F:AST]LANNUM);':';format$("K:123X",WLANMES);" / user : ";format$("K:5X",WUSR);' / ';WLANORI
            Else
                Wrseq format$("N:5",[F:AST]LANCHP);' ';format$("N:5",[F:AST]LANNUM);':';format$("K:123X",WLANMES);" / user : ";format$("K:5X",WUSR)
            Endif
         Endif
     Endif
    Next
    Filter [AST]
Endif
Wrseq '#----------------------------------------------------------------------------#'
Wrseq ' ';COMPTEUR;' Untranslated records ... '
Wrseq '##############################################################################'
Openo


COMPTEUR = 0
RAPPORT = TMPFOLDER + "NOTRANSTEXTRA" + EXTLAN + ".tra"
Openo RAPPORT, 0
Wrseq '##############################################################################'
Wrseq '#                  ATEXTRA : UNTRANSLATED RECORDS                            #'
Wrseq '#----------------------------------------------------------------------------#'
Filter [ATT] Where LANGUE = "FRA" Order By Key AXX0

For [ATT]
         WTEXTE   = ""
         WLANORI  = ""
         Read [ATT2]AXX0 = [F:ATT]CODFIC;[F:ATT]ZONE;EXTLAN;[F:ATT]IDENT1;[F:ATT]IDENT2
         If fstat <> 0
            If [F:ATT]TEXTE <> ""
                 COMPTEUR += 1
                 WTEXTE  =[F:ATT]TEXTE
            Endif
         Else
             If dim ([F:ATT2]LANORI) > 0 and [F:ATT]TEXTE = [F:ATT2]TEXTE and [F:ATT2]LANORI = "FRA"
                  # cg janv 2012 maintenant sur tous les env. v7 on a le record avec lanori
                  # donc si lanori = fra --> c'est à traduire
                 If [F:ATT]TEXTE <> ""
                     COMPTEUR += 1
                 Endif
                 WTEXTE  =[F:ATT]TEXTE
                 WLANORI = "Text origin"-[F:ATT2]LANORI
             Elsif [F:ATT]TEXTE <> "" and [F:ATT2]TEXTE = ""
                     COMPTEUR += 1
                     WTEXTE  =[F:ATT]TEXTE
                     If [F:ATT2]LANORI<> ""
                         WLANORI = "Text origin"-[F:ATT2]LANORI
                     Endif
             Else
                    If [F:ATT]LANORI <> "" and [F:ATT]TEXTE = [F:ATT2]TEXTE
                         If [F:ATT]TEXTE <> ""
                             COMPTEUR += 1
                         Endif
                         WTEXTE  =[F:ATT]TEXTE
                         WLANORI = "Text origin"-[F:ATT]LANORI
                    Endif
             Endif
         Endif

         If WTEXTE <>""
             If WLANORI <> ""
                 Wrseq format$("K:12X",[F:ATT]CODFIC);" ";format$("K:12X",[F:ATT]ZONE);" ";[F:ATT]IDENT1;" ";[F:ATT]IDENT2;' : ';[F:ATT]TEXTE ;' / ';WLANORI
             Else
                 Wrseq format$("K:12X",[F:ATT]CODFIC);" ";format$("K:12X",[F:ATT]ZONE);" ";[F:ATT]IDENT1;" ";[F:ATT]IDENT2;' : ';[F:ATT]TEXTE
             Endif
         Endif
Next
Filter [ATT]


# pour atabtab il y a un comportement diff sur refv7 , on n ecrit pas les enreg avec lanori et donc on ne traite que le ENG
Filter [ATT] Where LANGUE = "ENG" and CODFIC = "ATABTAB" Order By Key AXX0
For [ATT]
         WTEXTE   = ""
         WLANORI  = ""
         If EXTLAN = "ENG"
             Read [ATT2]AXX0 = [F:ATT]CODFIC;[F:ATT]ZONE;"FRA";[F:ATT]IDENT1;[F:ATT]IDENT2
         Else
             Read [ATT2]AXX0 = [F:ATT]CODFIC;[F:ATT]ZONE;EXTLAN;[F:ATT]IDENT1;[F:ATT]IDENT2
         Endif
         If fstat <> 0
            # il ne doit pas exister dans la langue a la diff des autres atextra
            If [F:ATT]TEXTE <> ""
                 COMPTEUR += 1
                 WTEXTE  =[F:ATT]TEXTE
            Endif
         Endif
         If WTEXTE <>""
              Wrseq format$("K:12X",[F:ATT]CODFIC);" ";format$("K:12X",[F:ATT]ZONE);" ";[F:ATT]IDENT1;" ";[F:ATT]IDENT2;' : ';[F:ATT]TEXTE
         Endif
Next
Filter [ATT]


Wrseq '#----------------------------------------------------------------------------#'
Wrseq ' ';COMPTEUR;' Untranslated records ... '
Wrseq '##############################################################################'
Openo

Close Local File

End



######################################################################################
## Etiquette ajoutée par le superviseur (écran ATXNOTRANS) 11/03/2008 14:18:49
######################################################################################
Subprog AP_USEFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    GERR=0
    Read [ART] First
    If fstat=0
        If [F:ART]UPDDAT<>date$
            Call MESSAGE(mess(230,100,1)-format$("D:DD[/]MM[/]YYYY",[F:ART]UPDDAT)) From GESECRAN
            GERR=2
        Endif
    Elsif fstat=4 or fstat=5
        Call MESSAGE(mess(229,100,1)) From GESECRAN
        GERR=2
    Else
        Call  FSTA("ATX") From GLOCK
        GERR=1
    Endif
Endif
End


######################################################################################
#**
#* Synchronize chapters
#*
#* @param PSILENCE : 1=doesn't display progression bar
#* @param PLOG     : where to log : 0=no log, 1=Use ECR_TRACE, 2=use Wrseq
#* @param PFORCE   : 0=optimized synchronization, 1=synchronize all
#*!
Funprog SYNCHRONIZE(PSILENCE,PLOG,PFORCE,PLAN)
Value Integer PSILENCE
Value Integer PLOG
Value Integer PFORCE
Value Char PLAN

    Local Integer I,J
    Local Integer CONTINUE, LNB, LNBTOT, INTERRUPT
    Local Char ERRMSG(250)
    Local Integer ASTATUS
    Local Integer TBNUM(1..)
    Local Integer TBCHP(1..)
    Local Char TBLAN(250)(1..)
    Local Char TBLCODES(10)(1..)
    Local Char TBLANMES(250)(1..)
    Local Char TBLANORI(250)(1..)
    Local Integer COUNT
    Local Integer LSTEP : LSTEP=50
    Local Integer START : START=0
    Local Integer LASTAML
    Local Char LASTDAT(250)
    Local Char LDATMAX(250) : LDATMAX = num$(datetime$)

    If clalev([F:AML])=0 : Local File AMENLOC [AML] : Endif

    # Save the date/time of last synchronization for XXAMLTRAD function
    Local File ADOVAL [ADW]

    Raz [F:ADW]
    Read [ADW]ADW1="XXSYNCAML";"";""

#[F:ADW]VALEUR="2017-07-25T11:55:16Z"
#Raz [F:ADW]VALEUR
#Infbox "Test avec last date="-[F:ADW]VALEUR
    If [F:ADW]VALEUR=""
        PFORCE=1
    Endif

    Case PFORCE
        When 1 :    # Synchronize all
            Filter [AML] Where find(MENLOC,0,200)=0
            COUNT = rowcount([AML])
            If !PSILENCE : Call OUVRE_BOITE("AML Synchronization", COUNT) From GESECRAN : Endif
            For [AML]
                LNB+=1
                If !PSILENCE : Call AFF_BOITE("Chapter"-num$([F:AML]MENLOC), LNB, INTERRUPT) From GESECRAN : Endif
                Gosub SYNC_AML
            Next
            If !PSILENCE : Call FERME_BOITE From GESECRAN : Endif
            Filter [AML]

        When Default:   # synchronize last modified
            If !PSILENCE : Call TEMPON("AML Synchronization") From GESECRAN : Endif
            LASTAML=0
            While 1
                # Thanks to GET_LASTMODIFIED_MESSAGES we get the list of chapter to synchronize
                # It avoids to write a special function to synchronize only some messages
                COUNT = START
                LASTDAT = [F:ADW]VALEUR
                ASTATUS = func ATXTSVC.GET_LASTMODIFIED_MESSAGES(GPRODUIT, LASTDAT ,LSTEP, COUNT, TBCHP, TBNUM, TBLAN, TBLCODES, TBLANMES, TBLANORI, ERRMSG)
                #Call LOGERR(PLOG,'### START='-num$(START)-'COUNT='-num$(COUNT)-'*****')
                If COUNT=0
                    Break
                Endif
                START += COUNT

                #Call LOGERR(PLOG,'***** count='-num$(COUNT)-'*****')
                If ASTATUS=[V]CST_AOK
                    Raz LNB
                    For J=1 To COUNT
                        LNB+=1
                        If find(TBLAN(J),PLAN) & LASTAML <> TBCHP(J)
                            LASTAML = TBCHP(J)
                            Read [AML]MENLOC=TBCHP(J)
                            #Call LOGERR(PLOG,'chapter:'+num$([F:AML]MENLOC))
                            If !fstat
                                Gosub SYNC_AML
                            Endif
                        Endif
                    Next
                Else
                    Call LOGERR(PLOG,'***** Synchronization GET_LASTMODIFIED_MESSAGES error PRODUCT='+num$(GPRODUIT)+' *****')
                    Call LOGERR(PLOG,'***** '-ERRMSG-'*****')
                    Break 2
                Endif
            Wend
            If !PSILENCE : Call TEMPOFF From GESECRAN : Endif
    Endcase
    Trbegin [ADW]
    Raz [F:ADW]
    Read [ADW]ADW1="XXSYNCAML";"";""
    [F:ADW]VALEUR = LDATMAX
    If fstat
        [F:ADW]CMP    = ""
        [F:ADW]FCY    = ""
        [F:ADW]PARAM  = "XXSYNCAML"
        Write [ADW]
    Else
        Rewrite [ADW]
    Endif
    Commit
End [V]CST_AOK

$SYNC_AML
#Call LOGERR(PLOG,'***** MENLOC='-num$([F:AML]MENLOC)-'*****')
For I=0 To dim(PLAN)-1
    If PLAN(I)<>""
        [L]CONTINUE = 0
        If func APLSTD.SYNCCHAPITRE ([F:AML]MENLOC, PLAN(I), [L]CONTINUE, ERRMSG)<>[V]CST_AOK
            Call LOGERR(PLOG,'***** Synchronization error : chapter='+num$([F:AML]MENLOC)-'language='+PLAN(I)-'*****')
            Call LOGERR(PLOG,'***** '-ERRMSG-'*****')
        Endif
    Endif
Next
Return

Subprog LOGERR(PLOG,PMES)
Value Integer PLOG
Value Char    PMES
Case PLOG
    When 1 : Call ECR_TRACE (PMES,1) From GESECRAN
    When 2 : Wrseq PMES
Endcase
End

