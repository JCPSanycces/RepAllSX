#Infbox func FUNFLASHWAS.GET_BPRNUM

End

Subprog MONITEUR(ANBPARAM, APARAMIDS , APARAMVALUES, ACLOBOUT)
  Value Integer ANBPARAM
  Value Char APARAMIDS()(0..)     # FGR 01/02/2010 : X3SUIVI60986 : pas APARAMID
  Value Char APARAMVALUES()(0..)  # FGR 01/02/2010 : X3SUIVI60986 : pas APARAMVALUE
  Variable Clbfile ACLOBOUT

  Local Integer IDX_BPRNUM

  Global Char GAYTBPRNUM(GLONBPR)

  IDX_BPRNUM=find("BPRNUM",APARAMIDS)
  If IDX_BPRNUM>=0
   [V]GAYTBPRNUM = APARAMVALUES(IDX_BPRNUM-1)
  Endif 
 
 Call MONITEUR( ANBPARAM, APARAMIDS , APARAMVALUES, ACLOBOUT) From SUBAPSMON

 Kill [V]GAYTBPRNUM
End 

##### formule pour mettre dans la requete
Funprog GET_BPRNUM()

Local Char RETOUR(50)
If dim([V]GAYTBPRNUM)>-1
 RETOUR = [V]GAYTBPRNUM
Else
  
 RETOUR=""
Endif

End RETOUR


