#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTICPT201807001
# Issue X3-93186 - Validation of view GST failed - 2018-08-13 DNE
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTICPT201807001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICPT201807001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char TMPDIC(255)

  Call ECR_TRACE("UTICPT201807001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File ADOSSIER [ADS]                    # Folder
  Local File =DOSSIER + ".AVIEW"      [AVW]    # Views
  Local File =DOSSIER + ".AVIEWB"     [AVB]
  Local File =DOSSIER + ".AVIEWC"     [AVC]
  Local File =DOSSIER + ".AVIEWD"     [AVD]
  Local File =DOSSIER + ".ACTION"     [ACT]    # Actions
  Local File =DOSSIER + ".ACTPAR"     [ATR]
  Local File =DOSSIER + ".AFONCTION"  [AFC]    # Functions
  Local File =DOSSIER + ".AMSK"       [AMK2]   # Masks (screens)
  Local File =DOSSIER + ".AWINDOW"    [AWI2]    # Windows
  # -----------------
  Read [ADS]DOSSIER=DOSSIER
  Raz COMPTEUR
  # -----------------
  Trbegin [AVW]

  #
  # Delete views (currently only GST)
  #
  For TMPDIC = "GST"
    # --------------------------
    Filter [AVW] Where [F:AVW]CODVUE = TMPDIC
    For [AVW]
      COMPTEUR += 1
      Delete [AVW]
      If fstat Then
        Call ECR_TRACE("Table AVIEW" - [F:AVW]CODVUE + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVW]
    # --------------------------
    Filter [AVB] Where [F:AVB]CODVUE = TMPDIC
    For [AVB]
      COMPTEUR += 1
      Delete [AVB]
      If fstat Then
        Call ECR_TRACE("Table AVIEWB" - [F:AVB]CODVUE + "~" + num$([F:AVB]TYPDBA) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVB]
    # --------------------------
    Filter [AVC] Where [F:AVC]CODVUE = TMPDIC
    For [AVC]
      COMPTEUR += 1
      Delete [AVC]
      If fstat Then
        Call ECR_TRACE("Table AVIEWC" - [F:AVC]CODVUE + "~" + num$([F:AVC]CODCLE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVC]
    # --------------------------
    Filter [AVD] Where [F:AVD]CODVUE = TMPDIC
    For [AVD]
      COMPTEUR += 1
      Delete [AVD]
      If fstat Then
        Call ECR_TRACE("Table AVIEWD" - [F:AVD]CODVUE + "~" + num$([F:AVD]NUMLIG) + "~" + num$([F:AVD]FLDVUE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVD]
    # --------------------------
    Call SUPVUE( TMPDIC, DOSSIER, [F:ADS]TYPDBA ) From DOSVUE
    # --------------------------
  Next

  #
  # Delete actions (currently only GSTR)
  #
  For TMPDIC = "GSTR"
    # --------------------------
    Filter [F:ATR] Where [F:ATR]ACTION = TMPDIC
    For [F:ATR]
      COMPTEUR += 1
      Delete [F:ATR]
      If fstat Then
        Call ECR_TRACE( "Table ACTPAR" - [F:ATR]ACTION + ", Error =" - num$(fstat), 1 ) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [F:ATR]
    # --------------------------
    Filter [F:ACT] Where [F:ACT]ACTION = TMPDIC
    For [F:ACT]
      COMPTEUR += 1
      Delete [F:ACT]
      If fstat Then
        Call ECR_TRACE( "Table ACTION" - [F:ACT]ACTION + ", Error =" - num$(fstat), 1 ) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [F:ACT]
    # --------------------------
  Next

  #
  # Delete functions (currently only GESGST)
  #
  For TMPDIC = "GESGST"
    # --------------------------
    Filter [F:AFC] Where [F:AFC]CODINT = TMPDIC
    For [F:AFC]
      COMPTEUR += 1
      Delete [F:AFC]
      If fstat Then
        Call ECR_TRACE("Table AFONCTION" - [F:AFC]CODINT + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [F:AFC]
    # --------------------------
    Call  UPDATE_RIGHTSETAG(DOSSIER) From ASYRFNC
    # --------------------------
  Next

  #
  # Delete mask (screens)
  #
  For TMPDIC = "GST0", "TVTLEGAUS"
    # --------------------------
    Filter [F:AMK2] Where [F:AMK2]CODMSK = TMPDIC
    For [F:AMK2]
      COMPTEUR += 1
      Call DELMSK( TMPDIC, DOSSIER ) From MSKDIV
      If GOK < 0
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [F:AMK2]
    # --------------------------
    Call DEL_TRTMSK( TMPDIC, DOSSIER ) From MSKDIV
    # --------------------------
  Next

  #
  # Delete windows
  #
  For TMPDIC = "GSTRPT", "TVTLEGAUS"
    # --------------------------
    Filter [AWI2] Where [F:AWI2]WIN = TMPDIC
    For [AWI2]
      COMPTEUR += 1
      Call DELWIN( TMPDIC, DOSSIER ) From MSKDIV
      If GOK < 0 Then
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AWI2]
    # --------------------------
  Next

  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTICPT201807001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTICPT201807001 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -----------------
  Close Local File [AVW]
  Close Local File [AVB]
  Close Local File [AVC]
  Close Local File [AVD]
  Close Local File [ACT]
  Close Local File [ATR]
  Close Local File [AFC]
  Close Local File [AMK2]
  Close Local File [AWI2]
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  Call UTI_MOUL( APPLI )
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEW") : End : Endif
  If filinfo(filpath("FIL","AVIEWD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWD") : End : Endif
  If filinfo(filpath("FIL","AVIEWC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWC") : End : Endif
  If filinfo(filpath("FIL","AVIEWB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWB") : End : Endif

  If filinfo( filpath( "FIL", "ACTION", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "ACTION" ) : End : Endif
  If filinfo( filpath( "FIL", "AFONCTION", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AFONCTION" ) : End : Endif
  If filinfo( filpath( "FIL", "AMSK", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AMSK" ) : End : Endif
  If filinfo( filpath( "FIL", "AMSKACT", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AMSKACT" ) : End : Endif
  If filinfo( filpath( "FIL", "AMSKPAR", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AMSKPAR" ) : End : Endif
  If filinfo( filpath( "FIL", "AMSKZON", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AMSKZON" ) : End : Endif

  If filinfo( filpath( "FIL", "AWINDOW", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AWINDOW" ) : End : Endif
  If filinfo( filpath( "FIL", "AWINPAR", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AWINPAR" ) : End : Endif
  If filinfo( filpath( "FIL", "AWINBRO", "fde", APPLI ), 0 )<=0 : End : Endif
  If func DOSVUE.ISVIEW( APPLI, "AWINBRO" ) : End : Endif
  # -------------------------
  Call MAJ_UTICPT201807001(APPLI)
End

