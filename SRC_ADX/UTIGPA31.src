#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTIGPA23   Modification de la LISTE des gammes                         #
##########################################################################
# Bug 76772  par GBE le 07/11/11
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIGPA31(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIGPA31(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIGPA31: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Suppression de l'écran WEIPRT     -----#
  Call TR_DELMSK("WEIPRT",DOSSIER) From MSKDIV
  #----- Suppression de la fenêtre WEIPRT  -----#
  Call TR_DELWIN("WEIPRT",DOSSIER) From MSKDIV
  #----- Suppression de l'action AWEIPRT   -----#
  Local File =DOSSIER + ".ACTION"  [ACT]
  Local File =DOSSIER + ".ACTPAR"  [ATR]
  Trbegin [ACT],[ATR]
  Delete [ACT] Where ACTION="AWEIPRT"
  Delete [ATR] Where ACTION="AWEIPRT"
  Commit
  Close Local File [ACT]
  Close Local File [ATR]
  Call ECR_TRACE("UTIGPA31 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA31(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  Call MAJ_UTIGPA31(APPLI)
End




