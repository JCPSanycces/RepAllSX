SI_TABLE = "XIFAMFOU"
Gosub SI_CRITSUP From SIXFONCTION

Trbegin [XFAM]
For [XFAM] Where FLGREP<>2
&              & evalue(SI_CRITERE)

    Call AFFBOITE([XFAM]CODFAMFOU) From SUBSIM

    If [F:XFAM]X3CLE<>""
        Call WRIADI(40, [F:XFAM]X3CLE, "", [F:XFAM]LIBFAMFOU, LRET)
    Endif
    If LRET=0 & SI_SIMU<>2
