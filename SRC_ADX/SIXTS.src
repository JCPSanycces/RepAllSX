Else
    Commit
Endif


Close Local File [XFAM]
Close Local File [XSFM]

End

#########################################################################
# Ecriture de la famille statistique
#########################################################################
Subprog WRIADI(PNUMTAB, PCOD, PFAM, PDES, PRET)
Value    Integer PNUMTAB
Value    Char    PCOD   # FGR 01/02/2010 : X3SUIVI60986 : Pas PCODE
Value    Char    PFAM
Value    Char    PDES
Variable Integer PRET

    Raz PRET, [F:ADI]
    Read [F:ADI]CODE=PNUMTAB;PCOD
    If !fstat
        If PFAM<>[F:ADI]DEPCOD    # Une autre dépendance existe pour la même sous-famille
            Call ECR_TRACE(num$(PNUMTAB)-PCOD-PFAM-PDES-SI_MES(247)-":"-[F:ADI]DEPCOD,1) From GESECRAN
        Endif
    Else
        [F:ADI]NUMTAB = PNUMTAB
        [F:ADI]CODE   = PCOD
        [F:ADI]DEPCOD = PFAM
        [F:ADI]CREDAT = date$
        [F:ADI]CRETIM = time
        [F:ADI]CREUSR = GUSER
        Write [ADI]
        If !fstat
            [F:AXX]CODFIC = "ATABDIV"
            [F:AXX]ZONE   = "LNGDES"
            [F:AXX]LANGUE = [F:SPX]LAN
            [F:AXX]IDENT1 = num$([F:ADI]NUMTAB)
            [F:AXX]IDENT2 = [F:ADI]CODE
            [F:AXX]TEXTE  = PDES
            Write [AXX]
            If fstat : Raz fstat : Endif
        Endif
    Endif
    If fstat
        Call ECR_TRACE(num$(PNUMTAB)-PCOD-PDES-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
        PRET=1
    Endif
End

######################################################################
# Compte le nombre d'enregistrement restant à traiter
# et le nombre d'enregistrement à traiter au total
######################################################################
Funprog CALNBENR(PIND)
Value Integer PIND
Local Char LMES(30), REQ(255)
Local Char LCRIT(250)
LCRIT = [M]FILTRE(PIND)

Local File =SI_DOSSIER+".XIFAMART"   [XFA]
Local File =SI_DOSSIER+".XISOUFMART" [XSFA]
Local File =SI_DOSSIER+".XIFAMCLT"   [XFC]
Local File =SI_DOSSIER+".XISOUFMCLT" [XSFC]
Local File =SI_DOSSIER+".XIFAMFOU"   [XFF]
Local File =SI_DOSSIER+".XISOUFMFOU" [XSFF]


#--- Nombre d'enregistrements restant à traiter ---#
Filter [XFA] Where FLGREP<>2
Filter [XSFA] Where FLGREP<>2
Filter [XFC] Where FLGREP<>2
Filter [XSFC] Where FLGREP<>2
Filter [XFF] Where FLGREP<>2
Filter [XSFF] Where FLGREP<>2
LMES = num$(rowcount([XFA])+rowcount([XSFA])+rowcount([XFC])+rowcount([XSFC])+rowcount([XFF])+rowcount([XSFF]))
Filter [XFA]
Filter [XSFA]
Filter [XFC]
Filter [XSFC]
Filter [XFF]
Filter [XSFF]

LMES += " / "

#--- Nombre d'enregistrements à traiter au total ---#
LMES += num$(nbrecord([XFA])+nbrecord([XSFA])+nbrecord([XFC])+nbrecord([XSFC])+nbrecord([XFF])+nbrecord([XSFF]))
End LMES

