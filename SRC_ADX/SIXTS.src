#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
#  SIXTS : pour traitements de bascule Integrale --> X3                 #
#########################################################################
#                                                                       #
# Subprog EXEC                                                          #
#     Création des familles statistiques article, client, fournisseur   #
#########################################################################

Gosub SI_CONTEXT From SIXFONCTION
Local File SIPARX3  [SPX]
Local File SIPARVAC [SPV]
Read [SPX] First

SI_SIMU=2
Call EXEC From SIXITM

End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE

If GTRACE = ""
    Call OUVRE_TRACE("SIXTS : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement ITMMASTER ------#
Call ECR_TIME("SIXTS : "+mess(6,200,1)) From DOSSUB
Call SIXTSI
Call ECR_TIME("SIXTS : "+mess(7,200,1)) From DOSSUB
Call SIXTSC
Call ECR_TIME("SIXTS : "+mess(8,200,1)) From DOSSUB
Call SIXTSS

If GOK<>1 : Goto FIN_ITM : Endif


$FIN_ITM
Onerrgo
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


$TRT_ERR
    Call ECR_TRACE( errp-"ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
    GOK=0
Resume


#########################################################################
# Création des familles statistiques articles
#########################################################################
Subprog SIXTSI

Local Integer LRET

If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif

Local File =SI_DOSSIER+".XIFAMART"   [XFAM]
Local File =SI_DOSSIER+".XISOUFMART" [XSFM]

SI_SUBPRG = "SIXTSI"

SI_TABLE = "XIFAMART"
Gosub SI_CRITSUP From SIXFONCTION

Trbegin [XFAM]
For [XFAM] Where FLGREP<>2
&              & evalue(SI_CRITERE)

    Call AFFBOITE([XFAM]CODFAMART) From SUBSIM

    If [F:XFAM]X3CLE<>""
        Call WRIADI(20, [F:XFAM]X3CLE, "", [F:XFAM]LIBFAMART, LRET)
    Endif
    If LRET=0 & SI_SIMU<>2
        [F:XFAM]FLGREP=2
        Rewrite [XFAM]
    Endif
Next
If SI_SIMU=2
    Rollback
Else
    Commit
Endif

SI_TABLE = "XISOUFMART"
Gosub SI_CRITSUP From SIXFONCTION

Trbegin [XSFM]
For [XSFM] Where FLGREP<>2
&              & evalue(SI_CRITERE)

    Call AFFBOITE([XSFM]CODFAMART-[XSFM]CODSOUFAM) From SUBSIM

    Read [XFAM]IND0=[XSFM]CODFAMART
    If [F:XSFM]X3CLE<>"" & [XFAM]X3CLE<>""
        Call WRIADI(21, [F:XSFM]X3CLE, [XFAM]X3CLE, [F:XSFM]LIBSOUFAM, LRET)
    Endif
    If LRET=0 & SI_SIMU<>2
        [F:XSFM]FLGREP=2
        Rewrite [XSFM]
    Endif
Next
If SI_SIMU=2
    Rollback
Else
    Commit
Endif


Close Local File [XFAM]
Close Local File [XSFM]

End

#########################################################################
# Création des familles statistiques clients
#########################################################################
