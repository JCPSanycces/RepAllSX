        Rewrite [XFAM]
    Endif
Next
If SI_SIMU=2
    Rollback
Else
    Commit
Endif


SI_TABLE = "XISOUFMCLT"
Gosub SI_CRITSUP From SIXFONCTION

Trbegin [XSFM]
For [XSFM] Where FLGREP<>2
&              & evalue(SI_CRITERE)

    Call AFFBOITE([XSFM]CODFAMCLT-[XSFM]CODSOUFAM) From SUBSIM

    Read [XFAM]IND0=[XSFM]CODFAMCLT
    If [F:XSFM]X3CLE<>"" & [XFAM]X3CLE<>""
        Call WRIADI(31, [F:XSFM]X3CLE, [XFAM]X3CLE, [F:XSFM]LIBSOUFAM, LRET)
    Endif
    If LRET=0 & SI_SIMU<>2
        [F:XSFM]FLGREP=2
        Rewrite [XSFM]
    Endif
Next
If SI_SIMU=2
    Rollback
Else
    Commit
Endif


Close Local File [XFAM]
Close Local File [XSFM]

End

#########################################################################
# Création des familles statistiques articles
#########################################################################
Subprog SIXTSS

Local Integer LRET

If !clalev([F:ADI])  : Local File =SI_DOSSIER+".ATABDIV"    [ADI] : Endif
If !clalev([F:AXX])  : Local File =SI_DOSSIER+".ATEXTRA"    [AXX] : Endif

