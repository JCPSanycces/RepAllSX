#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("GTC",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBGTCB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "OUVRE"      : Gosub OUVRE
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub INIT_CHAMP
 When "APRES_CRE"  : Gosub VALID
 When "APRES_MOD"  : Gosub VALID
 When "AV_ANNULE"  : Gosub AV_ANNULE
 When "ANNULE"     : Gosub ANNULE
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "VERIF_CRE"  : Gosub VERIF
 When "VERIF_MOD"  : Gosub VERIF
 When "MODIF"      : Gosub MAJ_TEXTE
 When "CREATION"   : Gosub MAJ_TEXTE
 When "CHANGE"     : Gosub CHANGE
Endcase
If PSUBB
 Gosub ACTION From SUBGTCB
Endif
Return

#----------------------------------------#
$ACTIONB
If dim(ACTION)>0 & ACTION<>""
 Local Char OACTION(20)
 OACTION = ACTION
Else
 Local Char ACTION(20)
Endif
ACTION = ACTIONB
Gosub ACTION
If dim(OACTION)>0
 ACTION = OACTION
Endif
Return

#----------------------------------------------------------------#
$OUVRE
Local Char    LIBEL(50) , CONSCOD(GLONACN)
Local Integer ER , OKSINGLE
Return

#----------------------------------------------------------------#
$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"123") From GOBJET
Endif
Return

#----------------------------------------------------------------#
$EXEBOUT
Case REP
 When "1" : Gosub VALID
 When "3" : Call VISUM("WM"+[M]CNSCOD+[M]COD) From SUBAMK
Endcase
Return

#----------------------------------------------------------------#
$MAJ_TEXTE
Call MAJTEXTRA([M]INTIT,"GTABACC","INTIT",[M]CNSCOD,[M]COD) From ATEXTRA
Return

#----------------------------------------------------------------#
$LIENS
[M]NBRFLD = 0
Gosub CHARGE_CHAMP
Raz [M]DAC
For NOL=0 To [F:GTC]NBRFLD-1
 K = find([F:GTC]FLD(NOL),[M]FLD(0..[M]NBRFLD))
 If K
  [M]DAC(K-1) = [F:GTC]DAC(NOL)
  If [M]DAC(K-1) > 0
   [M]GRA(K-1) = [F:GTC]GRA(NOL)
   [M]REP(K-1) = [F:GTC]REP(NOL)
  Else
   Raz [M]GRA(K-1),[M]REP(K-1)
  Endif
 Endif
Next NOL
Gosub TRI
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
Return

$GRISE_REPGRA
Case [M]REPGRA
 When 0,1 : # Caractère
  [M]OPTGRA = "" : [M]TYPGRA = 0 : [M]DEFGRA = 0
  Raz [M]IMAG
  Affzo OPTGRA, TYPGRA, DEFGRA, IMAG
  Grizo OPTGRA, TYPGRA, DEFGRA, IMAG
 When 2 : # Caractère ou graphique
  Actzo OPTGRA
  Actzo DEFGRA, IMAG
  If OKSINGLE
   Actzo TYPGRA
  Else
   [M]TYPGRA = 2
   Affzo TYPGRA
   Diszo TYPGRA
  Endif
 When 3 : # Caractère et graphique
  Actzo OPTGRA
  Actzo DEFGRA, IMAG
  If OKSINGLE
   Actzo TYPGRA
  Else
   [M]TYPGRA = 2
   Affzo TYPGRA
   Diszo TYPGRA
  Endif
 When 4 : # Graphique
  [M]OPTGRA = ""
  Affzo OPTGRA
  Grizo OPTGRA
  Actzo DEFGRA, IMAG
  If OKSINGLE
   Actzo TYPGRA
  Else
   [M]TYPGRA = 2
   Affzo TYPGRA
   Diszo TYPGRA
  Endif
Endcase
Gosub AFF_OPTIONS
Return

$AFF_OPTIONS
Case [M]REPGRA
 When 2
  [M]INTREPGRA = mess(164,139,1) : # Affichage par défaut
  [M]TYPREPGRA = "M"
  [M]LIBREPGRA = 2936
  [M]LNGREPGRA = 20
  [M]VALREPGRA = num$([M]AFFGRA)
  [M]OPTGRA = [M]VALREPGRA
  Call CHARGE([M]OPTGRA,[M]TYPREPGRA,[M]LIBREPGRA,[M]LNGREPGRA,[M]VALREPGRA) From FMTVAR
 When 3
  [M]INTREPGRA = mess(163,139,1) : # Position graphique
  [M]TYPREPGRA = "M"
  [M]LIBREPGRA = 2931
  [M]LNGREPGRA = 20
  [M]VALREPGRA = num$([M]POSGRA)
  [M]OPTGRA = [M]VALREPGRA
  Call CHARGE([M]OPTGRA,[M]TYPREPGRA,[M]LIBREPGRA,[M]LNGREPGRA,[M]VALREPGRA) From FMTVAR
 When Default
  [M]INTREPGRA = ""
Endcase
Chgtzn [M]OPTGRA With [M]INTREPGRA
Return

$GRISE_TYPGRA
Case [M]REPGRA
 When 0,1 : # Graphique
  [M]FSHGRA = 0
  Affzo FSHGRA
  Grizo FSHGRA
 When Default : # Caractère ou graphique/Caractère ou graphique/Graphique
  Case [M]TYPGRA
   When 1  : # Graphe Flash
    [M]FSHGRA = 0 : Affzo FSHGRA : Grizo FSHGRA
   When 2 : # Graphe multi Flash
    Actzo FSHGRA
   When 4 : # XSL
    [M]FSHGRA = 0 : Affzo FSHGRA : Grizo FSHGRA
  Endcase
Endcase
Gosub AFF_IMAGE
Return

$AFF_IMAGE
Local Char NOMIMAG(200) , IMAG1(20)
Case [M]TYPGRA
 When 1,2
  Case [M]DEFGRA
   When 1 : IMAG1="xbar"
   When 2 : IMAG1="xline"
   When 3 : IMAG1="xarea"
   When 4 : IMAG1="xpie"
   When 5 : IMAG1="xradar"
  Endcase
  If IMAG1<>""
   Case [M]FSHGRA
    When 1 : IMAG1+="m"
    When 2 : IMAG1+="cu"
    When 3 : IMAG1+="co"
   Endcase
  Endif
 When 3
  Case [M]FSHGRA
   When 4 : IMAG1="calmonth"
   When 5 : IMAG1="calweek"
   When 6 : IMAG1="calday"
  Endcase
 When 5
  IMAG1="gantt"
Endcase
Read [ASB]ASB0="SCR";toupper(IMAG1)
If !fstat
  [M]IMAG=[F:ASB]BLOB
Else
  Raz [M]IMAG
Endif
Return

#-----------------------------#
$VERIF
Local Integer M
Raz K , J , M
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)<>0                : K += 1 : Endif
 If [M]GRA(NOL)=3                 : J += 1 : Endif
 If [M]GRA(NOL)=1 | [M]GRA(NOL)=2 : M += 1 : Endif
Next NOL
If !K
 GMESSAGE = mess(94,105,1) : # Aucun champs sélectionné
 zonsui = "DAC(0)" : OK = 0
Elsif [M]NBRCOL>K
 GMESSAGE = mess(100,139,1) : # Nombre de colonnes fixes trop grand
 zonsui = "NBRCOL" : OK = 0
Elsif [M]REPGRA>1 & ( J=0 | M=0 ) & [M]ENAFLG = 2
 GMESSAGE = mess(128,139,1) : # Il faut au moins un champ de type libellé pour utiliser le graphisme
 zonsui = "NBRCOL" : OK = 0
Endif
Return

#-----------------------------#
$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9000+NOL : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)>=9000 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return

#-----------------------------#
$LIBEL
[M]INTITFLD(NOL) = ""
ACTIONB = "LIBEL" : Gosub ACTIONB
If [M]INTITFLD(NOL)<>"" : Return : Endif
If [M]CNSCOD="STA"
 Case [F:AMZ]CODZON
  When "LIBCLE"
   [M]INTITFLD(NOL) = mess(82,123,1) : # Intitulé
  When "AMT1","AMT2","AMT3","AMT4","AMT5","AMT6","AMT7","AMT8","AMT9","AMT10"
   [M]INTITFLD(NOL) = mess(32,105,1)-right$([F:AMZ]CODZON,4) : # Montant i
 Endcase
Elsif [F:AMZ]INTEVAL<>""
 Onerrgo ERRLIB
 ER = 0
 [M]INTITFLD(NOL) = evalue([F:AMZ]INTEVAL)
 If ER
  [M]INTITFLD(NOL) = [F:AMZ]INTEVAL
 Endif
 Onerrgo
Else
 Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
 [M]INTITFLD(NOL) = LIBEL
Endif
Return

$ERRLIB
ER = errn
Resume

#-----------------------------#
$CHARGE_CHAMP
CONSCOD = [M]CNSCOD
Gosub MSKREF
OKSINGLE = 1
Read [AMZ]CODE = MSKREF;"NBLIG"
If fstat=0 : J = [F:AMZ]NUMBLOC : Else J = 0 : Endif
For [AMZ]CODZON Where CODMSK=MSKREF
 OK = 1
 If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
  OK = 0
 Endif
 If [F:AMZ]CODACT<>""
  Read [ACV]CODACT = [F:AMZ]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK = 0 : Endif
 Endif
 If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
  If [F:AMZ]INTEVAL<>""
   OKSINGLE = 0
  Endif
  NOL = [M]NBRFLD
  [M]FLD(NOL) = [F:AMZ]CODZON
  Gosub LIBEL
  [M]NBRFLD += 1
 Endif
Next
Return

#-----------------------------#
$MSKREF
Local Char MSKREF(GLONAMK) , WINREF(GLONFEN)
MSKREF = ""
Call LECTURE("ACN",CONSCOD,"") From CONTOBJ
If !fstat
 WINREF = [F:ACN]WND1
 Call LECTURE("AWI",WINREF,"") From CONTOBJ
 If !fstat
  MSKREF = [F:AWI]NOMMSK(0)
 Endif
Endif
Return

#-----------------------------#
$INIT_CHAMP
Gosub CHARGE_CHAMP
Gosub TRI
If !GIMPORT
 Affzo NBRFLD,NUMLIG,FLD,INTIT,DAC
Endif
OK = 1
Return

#-----------------------------------------------------------------------------#
$AV_ANNULE
# Annulation des écrans
Local Char MASQUE1(GLONAMK) , WINDOW1(GLONFEN)
MASQUE1 = "WM"+SUPP+CODE
WINDOW1 = "WM"+SUPP+CODE
Return

#-----------------------------------------------------------------------------#
$ANNULE
Call DELMSK(MASQUE1,[L]APPLI) From MSKDIV
If GOK<1 : Return : Endif
# Annulation fenêtre
Call DELWIN(WINDOW1,[L]APPLI) From MSKDIV
# Suppresion texte traduisible
Delete [AXX] Where CODFIC="GTABACC" & ZONE="INTIT" & IDENT1=[L]SUPP & IDENT2=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[M]COD) From GLOCK
Endif
Return

#-----------------------------------------------------------------------------#
$AP_ANNULE
Local Char TRTWIN(GLONADC)
If WINDOW1<>"" : TRTWIN="WG"+WINDOW1 : Endif
Call EFFACE_ADX("",[L]APPLI,TRTWIN,OK) From ORDSYS
Call EFFACE(filpath("TRT",TRTWIN,"src",[L]APPLI),OK) From ORDSYS
Return

#-----------------------------------------------------------------------------#
$AP_CHANGE
# Annulation ancien écran
Local Char MASQUE1(GLONAMK)
MASQUE1 = "WM"+SUPP(0)+OCODE
Call TR_DELMSK(MASQUE1,[L]APPLI) From MSKDIV
Call TR_DELWIN(MASQUE1,[L]APPLI) From MSKDIV
# Validation du nouveau
Read [GTC]GTC0 = SUPP(0);NCODE
# Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
# Si on lance la validation depuis le bouton sur GESGTC, il faut forcer la validation
#Call VALIDATION(SUPP(0),NCODE,[L]APPLI,0)
Call VALIDATIONF(SUPP(0),NCODE,[L]APPLI,0)
Return

$CHANGE
Update [AXX] Where CODFIC="GTABACC" & IDENT1=SUPP(0) & ZONE="INTIT" & IDENT2=[L]OCODE With IDENT2=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA GTABACC"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#----------------------------------#
$VALID
If [F:GTC]ENAFLG=2
 If !GIMPORT
  # Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
  # Si on lance la validation depuis le bouton sur GESGTC, il faut forcer la validation
  #Call VALIDATION([F:GTC]CNSCOD,[F:GTC]COD,nomap,0)
  Call VALIDATIONF([F:GTC]CNSCOD,[F:GTC]COD,nomap,0)
 Endif
Else
 Call DELMSK("WM"+[F:GTC]CNSCOD+[F:GTC]COD,nomap) From MSKDIV
 Call DELWIN("WM"+[F:GTC]CNSCOD+[F:GTC]COD,nomap) From MSKDIV
Endif
Return

#----------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
If APPLI=GDOSX3 : End : Endif
# Validation transactions depuis génération des patchs
Call GENDOS(APPLI)
End

#----------------------------------#
Subprog VALGTC(APPLI,CNS)
Value Char APPLI,CNS
  # X3-84942 02.08.2018
  If APPLI=GDOSX3 and GADONIX <> 2 : End : Endif
  # Validation of all the screens since the generation of the patches
  Goto GEN

#----------------------------------#
Subprog GENDOS(APPLI)
Value Char APPLI
Local Char CNS(10)
CNS = ""
Goto GEN

$GEN
Local File =APPLI+".AMSK"     [AMK] , =APPLI+".AMSK"     [AMK2]
Local File =APPLI+".AMSKZON"  [AMZ] , =APPLI+".AMSKZON"  [AMZ2]
Local File =APPLI+".AMSKACT"  [AMA] , =APPLI+".AMSKACT"  [AMA2]
Local File =APPLI+".AMSKPAR"  [AMP] , =APPLI+".AMSKPAR"  [AMP2]
Local File =APPLI+".AWINDOW"  [AWI] , =APPLI+".AWINDOW"  [AWI2]
Local File =APPLI+".AWINPAR"  [AWP] , =APPLI+".AWINPAR"  [AWP2]
Local File =APPLI+".AWINBRO"  [AWB] , =APPLI+".AWINBRO"  [AWB2]
Local File =APPLI+".AWINBOUT" [AWT] , =APPLI+".AWINBOUT" [AWT2]
Local File =APPLI+".ACONSULT" [ACN]
Local File =APPLI+".GTABACC"  [GTC]
For [GTC] Where ENAFLG=2 & ([L]CNS="" or CNSCOD=[L]CNS)
 Call ECR_TRACE([F:GTC]CNSCOD-[F:GTC]COD,0) From GESECRAN
 Call VALIDATION([F:GTC]CNSCOD,[F:GTC]COD,APPLI,1)
Next
End

#------------------------------------------------#
Subprog VALIDATIONF(CNS,COD,APPLI,SILENCE)
Value Char CNS
Value Char COD
Value Char APPLI
Value Integer SILENCE

# Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
# Si on lance la validation depuis le bouton sur GESGTC, il faut forcer la validation
# on utilise WFORCE
Local Integer WFORCE : WFORCE=1
Gosub VALIDER
End

#------------------------------------------------#
Subprog VALIDATION(CNS,COD,APPLI,SILENCE)
Value Char CNS
Value Char COD
Value Char APPLI
Value Integer SILENCE

Local Integer WFORCE : WFORCE=0
Gosub VALIDER
End

$VALIDER
# Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
# Si on lance la validation depuis le bouton sur GESGTC, il faut forcer la validation
# on utilise WFORCE
Local Char    MASKDES(GLONAMK) , MSKREF(GLONAMK) , SAVLAN(GLONLAN) , CONSCOD(GLONACN)
Local Char    MASKD2(GLONAMK) , MASKR2(GLONAMK)
Local Char    WINDES(GLONFEN) , ACTIONB(20)
Local Integer OK , NOL , NCOL , LANCUR, J, FLLIG
Local Decimal RANG, RGINV : # GH 07/01/00 bug 3994
If clalev([F:AMK2])=0 : Local File AMSK     [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File AMSKZON  [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File AMSKACT  [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File AMSKPAR  [AMP2] : Endif
If clalev([F:AWI2])=0 : Local File AWINDOW  [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File AWINPAR  [AWP2] : Endif
If clalev([F:AWB2])=0 : Local File AWINBRO  [AWB2] : Endif
If clalev([F:AWT2])=0 : Local File AWINBOUT [AWT2] : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS]  : Endif
Call DEBTRANS From GLOCK
CONSCOD = CNS
If COD="" : COD=[F:GTC]COD : Endif
ACTIONB = "VALID" : Gosub ACTIONB
Gosub MSKREF
If MSKREF<>""
 MASKDES = "WM"+CNS+COD
 FLLIG = 1
 Gosub TR1
 If GOK=1 & CNS="STA"
  MSKREF = "CONSSTA3"
  MASKDES = "WMSTB"+COD
  FLLIG = 0
  Gosub TR1
  MASKD2  = MASKDES
  MASKDES = "WMSTA"+COD
 Endif
 If GOK=1
  Read [ADS]DOSSIER = APPLI
  # Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
  If WFORCE
    Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
  Else
    Call GENERDIFFSCREEN(APPLI,MASKDES) From INTRUTILB
  Endif
  If MASKD2<>""
   # Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
   If WFORCE
     Call VALID(MASKD2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
   Else
     Call GENERDIFFSCREEN(APPLI,MASKD2) From INTRUTILB
   Endif
  Endif
 Endif
Endif
If WINREF<>""
 WINDES = "WM"+CNS+COD
 Gosub TR2
 If GOK=1
   # Issue 83834 - 2012-08-07 by VPO : pb utilisation bouton VISU si validation différée
   If WFORCE
     Call VALID(WINDES,APPLI,SILENCE,OK) From VALWIN
   Else
     Call GENERDIFFWIN(APPLI,WINDES) From INTRUTILB
   Endif
 Endif
Endif
Return

$TR1
GOK=1
Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2]
 Call DELMSK(MASKDES,APPLI) From MSKDIV
 Read [AMK]CODMSK = MSKREF
 [F:AMK2] = [F:AMK]
 [F:AMK2]CODMSK = MASKDES
 NCOL = find("NBLIG",[F:AMK2]BASPAG(0..dim([F:AMK2]BASPAG)-1))
 If !NCOL
  NCOL = find(1,[F:AMK2]TYPBLOC(0..dim([F:AMK2]TYPBLOC)-1))
 Endif
 If NCOL
  For J=1 To 9
   K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
   If K
    [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1)+right$([F:AMK2]OPTION(NCOL-1),K+1)
   Endif
  Next J
  [F:AMK2]BLOCTYPT(NCOL-1) = [F:GTC]REPGRA
  [F:AMK2]BLOCTYPG(NCOL-1) = [F:GTC]TYPGRA
  [F:AMK2]BLOCPOSG(NCOL-1) = [F:GTC]POSGRA
  [F:AMK2]BLOCGDEF(NCOL-1) = [F:GTC]DEFGRA
  [F:AMK2]BLOCAFFD(NCOL-1) = [F:GTC]AFFGRA
  [F:AMK2]BLOCREPD(NCOL-1) = [F:GTC]FSHGRA
  If [F:GTC]NBRCOL>0 : # Gestion des colonnes fixes
   [F:AMK2]OPTION(NCOL-1) += num$([F:GTC]NBRCOL)
  Endif
  [F:AMK2]ACTBLOC(NCOL-1) = ""
  If FLLIG
   [F:AMK2]NBLIGT(NCOL-1)  = [F:GTC]NBRLIG
  Endif
 Endif
 [F:AMK2]MDL = 1
 Write [AMK2]
 If fstat
  GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
 Endif
 Read [AMZ]CODE = MSKREF;"NBLIG"
 If !fstat
  J = [F:AMZ]NUMBLOC
 Else
  J = 0
 Endif
 RGINV = 100
 For [AMZ]CODZON Where CODMSK=MSKREF
  NOL = find([F:AMZ]CODZON,[F:GTC]FLD(0..[F:GTC]NBRFLD-1))
  OK = 0
  If NOL & [F:GTC]DAC(NOL-1)<>0
   OK = 1
   RANG = [F:GTC]DAC(NOL-1)+10 : # Pour préserver les premiers champs invisibles (BY/DBA sur CONSBAN)
  Else
   RGINV += 1
   RANG = RGINV
  Endif
  If [F:AMZ]CODTYP="ABS"
   OK = 1 : RANG = 1
  Elsif [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
   OK = 1 : RANG = [F:AMZ]NOZONE
  Endif
  [F:AMZ2] = [F:AMZ]
  [F:AMZ2]CODMSK = MASKDES
  [F:AMZ2]NOZONE = RANG
  If [F:AMZ]CODTYP="ABS"
   [F:AMZ2]SAIAFF = 1
  Elsif !OK | [F:AMZ]SAIAFF=3
   [F:AMZ2]SAIAFF = 3
   [F:AMZ2]LIEN   = 0
  Else
   [F:AMZ2]SAIAFF   = [F:AMZ]SAIAFF
   If NOL>0
    Case [F:GTC]GRA(NOL-1)
     When 1       : [F:AMZ2]CHPARG = "G01:VALUE"
     When 2       : [F:AMZ2]CHPARG = "G02:DEF"
     When 3       : [F:AMZ2]CHPARG = "G03:LIB"
     When Default : [F:AMZ2]CHPARG = ""
    Endcase
    [F:AMZ2]CHREPR   = [F:GTC]REP(NOL-1)
   Endif
  Endif
  If [F:AMZ2]SAIAFF=3 & [F:AMZ2]OPTFOR<>"" & left$([F:AMZ2]OPTFOR,1)<>"-"
   If left$([F:AMZ2]OPTFOR,2)='="'
    [F:AMZ2]OPTFOR = '="-'+right$([F:AMZ2]OPTFOR,3)
   Else
    [F:AMZ2]OPTFOR = "-"+[F:AMZ2]OPTFOR
   Endif
  Endif
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [AMA] Where TYPAFF=1 & CODAFF=MSKREF
  [F:AMA2] = [F:AMA]
  [F:AMA2]CODAFF = MASKDES
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 For [AMP] Where TYPAFF=1 & CODAFF=MSKREF
  [F:AMP2] = [F:AMP]
  [F:AMP2]CODAFF = MASKDES
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK = 1
Trbegin [AWI2] , [AWP2] , [AWT2] , [AWB2]
 Call DELWIN(WINDES,APPLI) From MSKDIV
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Read [AWI]AWI0 = WINREF
 If !fstat
  [F:AWI2] = [F:AWI]
  [F:AWI2]WIN = WINDES
  [F:AWI2]NOMMSK(0) = MASKDES
  If MASKD2<>""
   [F:AWI2]NOMMSK(1) = MASKD2
  Endif
  [F:AWI2]CNS = CNS
  [F:AWI2]MDL = 1
  Write [AWI2]
  If fstat
   GOK = 0 : Call FSTA("AWI2") From GLOCK : Goto AB_TR2
  Endif
  For [AWP]AWP0 Where WIN=WINREF
   [F:AWP2] = [F:AWP]
   [F:AWP2]WIN = WINDES
   Write [AWP2]
   If fstat
    GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Goto AB_TR2 : Endif
  For [AWT]AWT0 Where WIN=WINREF
   [F:AWT2] = [F:AWT]
   [F:AWT2]WIN = WINDES
   Write [AWT2]
   If fstat
    GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Goto AB_TR2 : Endif
  For [AWB]AWB0 Where WIN=WINREF
   [F:AWB2] = [F:AWB]
   [F:AWB2]WIN = WINDES
   Write [AWB2]
   If fstat
    GOK = 0 : Call FSTA("AWB2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Goto AB_TR2 : Endif
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#-----------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File GTABACC [GTC1]
 Local File ATEXTRA [AXX1]
Else
 Local File =[M]DOSORG+".GTABACC"  [GTC1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GTABACC [GTC2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".GTABACC"  [GTC2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Local Char CRITERE(250) , ACTIONB(30)
CRITERE = 'CNSCOD = "'+TABLE+'"'
If TABLE2<>""
 CRITERE += ' & COD = "'+TABLE2+'"'
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GTC1], [GTC2], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [GTC2]
 Delete [GTC2] Where evalue(CRITERE)
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GTABACC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GTC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GTC1] Where evalue(CRITERE)
  [F:GTC2] = [F:GTC1]
  Call COPTEXTRA("GTABACC","INTIT",[F:GTC2]CNSCOD,[F:GTC2]COD) From ATEXTRA
  If dim([F:GTC2]UPDUSR)>0 : [F:GTC2]UPDUSR = GUSER : Endif
  If dim([F:GTC2]UPDDAT)>0 : [F:GTC2]UPDDAT = date$ : Endif
  Write [GTC2]
  If fstat
   GOK = 0 : Call FSTA("GTC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 ACTIONB = "TRCOP" : Gosub ACTIONB
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

Subprog C_CNSCOD(VALEUR)
Variable Char    VALEUR()
Local Char CONSCOD(GLONACN)
CONSCOD = VALEUR
Gosub ZONECR
If !OK
 # Le critère écran de consultation n'existe pas
 Call ERREUR([F:AWI]NOMMSK(0)-":"-mess(69,126,1)) From GESECRAN
 mkstat = 1 : End
Endif
Gosub MSKREF
If MSKREF=""
 GMESSAGE = mess(25,126,1) : # Code incorrect
 mkstat = 1 : End
Endif
End

###########################################################################
# Recherche d'une zone écran (type GTC) dans l'écran saisie critères      #
# pour savoir si le code consultation accepte le paramètrage d'un écran   #
###########################################################################
$ZONECR
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
OK = 0
Call LECTURE("ACN",CONSCOD,"") From CONTOBJ
If !fstat
 Call LECTURE("AWI",[F:ACN]WND0,"") From CONTOBJ
 If !fstat & [F:AWI]NOMMSK(0)<>""
  For [AMZ]CODE Where CODMSK=[F:AWI]NOMMSK(0)
   If [F:AMZ]CODTYP="GTC"
    OK = 1 : Break
   Endif
  Next
 Endif
Endif
Return

Subprog AM_CNSCOD(VALEUR)
Variable Char VALEUR()
Local Integer OK , NOL , OKSINGLE
Local Char    LIBEL(30)
[M]NBRFLD = 0
[M]CNSCOD = VALEUR
Gosub CHARGE_CHAMP
If !GIMPORT : Affzo 50 : Endif
End

Subprog AS_NBRLIG(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
 Local Integer NCOL
 Local Char    CONSCOD(GLONACN)
 CONSCOD = [M]CNSCOD : Gosub MSKREF
 Call LECTURE("AMK",MSKREF,"") From CONTOBJ
 NCOL   = find(1,[F:AMK]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
 VALEUR = [F:AMK]NBLIGT(NCOL-1)
 If VALEUR=0 & [F:AMK]ACTBLOC(NCOL-1)<>""
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  Call LECTURE("ACV",[F:AMK]ACTBLOC(NCOL-1),"") From CONTOBJ
  If !fstat & [F:ACV]FLACT=2
   VALEUR = [F:ACV]DIME
  Endif
 Endif
Endif
End

Subprog C_GRA(VALEUR)
Variable Integer VALEUR
CONSCOD = [M]CNSCOD : Gosub MSKREF
Read [AMZ]CODE=MSKREF;[M]FLD(nolign-1)
If !fstat &  [F:AMZ]CODTYP<>"AEX"
 Read [ATY]CODTYP=[F:AMZ]CODTYP
 If !fstat & [F:ATY]TYPTYP=7 : # On n'a droit qu'à une seule colonne libellé
  For I=0 To [M]NBRFLD-1
   If I<>nolign-1 and [M]GRA(I)=3 & VALEUR = 3
    GMESSAGE = mess(45,127,1) : # Il y a déja un champ de type libellé
    mkstat = 1 : VALEUR = 4 : Break
   Endif
  Next I
 Endif
Endif
End

Subprog AS_GRA(VALEUR)
Variable Integer VALEUR
If [M:GTC1]REPGRA<2
 VALEUR = 4 : mkstat = 1 : End
Endif
If [M:GTC1]DAC(nolign-1) = 0
 VALEUR = 0 : mkstat = 1 : End
Endif
CONSCOD = [M]CNSCOD : Gosub MSKREF
Read [AMZ]CODE=MSKREF;[M]FLD(nolign-1)
If !fstat
 If [F:AMZ]CODTYP="AEX"
  mkstat = 1
 Else
  Read [ATY]CODTYP=[F:AMZ]CODTYP
  If !fstat & [F:ATY]TYPTYP=7 : # On n'a droit qu'à une seule colonne libellé
   GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=0 : GMENLOC(4)=0
  Elsif [F:ATY]TYPTYP>=1 and [F:ATY]TYPTYP<=4
   GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=1 : GMENLOC(4)=0
  Else
   mkstat=1
  Endif
 Endif
Else
 mkstat = 1
Endif
End

Subprog AS_REP(VALEUR)
Variable Integer VALEUR
If [M]GRA(nolign-1)<>1 and [M]GRA(nolign-1)<>2
 mkstat = 1 : End
Endif
If [M]REPGRA <2
 mkstat = 1 : End
Endif
End

Subprog AM_REPGRA(VALEUR)
Variable Integer VALEUR
Local Integer OKSINGLE , I
CONSCOD = [M]CNSCOD
Gosub MSKREF
OKSINGLE = 1
For I=0 To [M]NBRFLD-1
 Read [AMZ]CODE=MSKREF;[M]FLD(I)
 If [F:AMZ]INTEVAL<>""
  OKSINGLE = 0 : Break
 Endif
Next I
If VALEUR<=1 or [M]REPGRA<=1
 Case VALEUR
  When 1
   [M]REP = 0
   [M]GRA = 0
   Effzo [M]GRA : Effzo [M]REP
  When 2,3,4
   For I=0 To [M]NBRFLD-1
    Read [AMZ]CODE=MSKREF;[M]FLD(I)
    If !fstat &  [F:AMZ]CODTYP<>"AEX" & [M]DAC(I) > 0
     Read [ATY]CODTYP=[F:AMZ]CODTYP
     If !fstat & [F:ATY]TYPTYP=7
      [M]GRA(I) = 4
     Elsif [F:ATY]TYPTYP>=1 and [F:ATY]TYPTYP<=4
      [M]GRA(I) = 4
     Else
      [M]GRA(I) = 0
     Endif
    Else
     [M]GRA(I) = 0
    Endif
   Next I
   Affzo [M]GRA
 Endcase
Endif
[M]REPGRA = VALEUR
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
End

Subprog AS_TYPGRA(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
End

Subprog AP_TYPGRA(VALEUR)
Variable Integer VALEUR
[M]TYPGRA = VALEUR
Gosub GRISE_TYPGRA
End

Subprog AS_DEFGRA(VALEUR)
Variable Integer VALEUR
If [M]TYPGRA<>1 and [M]TYPGRA<>2 : mkstat=1 : Endif
End

Subprog AP_DEFGRA(VALEUR)
Variable Integer VALEUR
[M]DEFGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog AS_FSHGRA(VALEUR)
Variable Integer VALEUR
Case [M]TYPGRA
 When 2
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=0
  GMENLOC(4)=1 : GMENLOC(5)=1 : GMENLOC(6)=1
  If [M]DEFGRA=4 or  [M]DEFGRA=5
    GMENLOC(2)=1 : GMENLOC(3)=1
  Endif
 When 3
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
  GMENLOC(4)=0 : GMENLOC(5)=0 : GMENLOC(6)=0
 When Default  : mkstat=1
Endcase
End

Subprog AP_FSHGRA(VALEUR)
Variable Integer VALEUR
[M]FSHGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog AP_OPTGRA(VALEUR)
Variable Char    VALEUR()
Case [M]REPGRA
 When 2 : [M]AFFGRA = val([M]VALREPGRA)
 When 3 : [M]POSGRA = val([M]VALREPGRA)
Endcase
End

Subprog B1_NBRFLD
Local Char CONSCOD(GLONACN)
If clalev([F:AMZ])=0 : Local File AMSKZON  [AMZ] : Endif
CONSCOD = [M]CNSCOD
Gosub MSKREF
# Issue 75246/7 - 2012-06-29 by VPO
#Read [AMZ]CODE=[L]MSKREF;[M]FLD(nolign-1)
#If !fstat & [F:AMZ]MOTCLE<>""
# Hlpbox [F:AMZ]MOTCLE
#Endif
Read [AMC]AMC0=2;[L]MSKREF;[M]FLD(nolign-1)
If !fstat & [F:AMC]MOTCLE<>""
 Hlpbox [F:AMC]MOTCLE
Endif
End

