#########################################
$ENREG_DT
#code enreg
RESULTAT="DT1"
#Intervenant
RESULTAT+="DT"+space$(1)
#Siret dÃĐclarant
Read[F:FCY2]FCY0=[F:DUC]FCYDCL
If !fstat
 If [F:FCY2]CRN=""
  #Identification du dÃĐclarant
  Call ECRIT_TRACE("DT1",mess(7,10707,1)) From TRTDCS
 Else
  If len ([F:FCY2]CRN)<35
   RESULTAT+=[F:FCY2]CRN+space$(35-len([F:FCY2]CRN))
  Else
   RESULTAT+=left$([F:FCY2]CRN,35)
  Endif
 Endif
Else
 Call ECR_TRACE("DT1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Zone reservÃĐe
RESULTAT+=space$(3)
Gosub RECUP_FCY From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_DT2
Return

#########################################
$ENREG_DT2
#code enreg
RESULTAT="DT2"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Gosub RECUP_CNT From TRTDCS
 #Zones non utilisÃĐes
 RESULTAT+=space$(70)
 #Si bordereau=TR : indiquer si dÃĐclaration des salaires en EDI Dads (0=non ; 1=oui)
 If val(NUMBORD)=915 | val(NUMBORD)=916
  Call PARAM([F:FCY2]FCY,"FLGEDI",VALPAR) From ADOVAL
  If val(VALPAR)=2 : VFLGEDI=1 :  Else : VFLGEDI=0 : Endif
  RESULTAT+=num$(VFLGEDI)+space$(35-len(num$(VFLGEDI)))
 Else
  RESULTAT+=space$(35)
 Endif
 #Zones non utilisÃĐes
 RESULTAT+=space$(62)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_DT3
Else
 Call ECR_TRACE("DT2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

