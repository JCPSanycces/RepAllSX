#########################################
$ENREG_GEN
#Effectif et Montant Ã  ZÃĐro si dÃĐclaration nÃĐant
If [M:DIA]FLGNEA=2 : Raz EFFMRK : Raz AMTTOT : Endif

#code enreg
RESULTAT="GEN"
#pÃĐriode AATM + qualifiant pÃĐriode
#Annuelle
If [M:DIA]ENDDAT-[M:DIA]STRDAT>360
 #pÃĐriode AA62
 RESULTAT+=right$(num$(year([M:DIA]STRDAT)),1+len(num$(year([M:DIA]STRDAT)))-2) +"62"+space$(31)+"900"
Else
 Call RECUP_DATE ([M:DIA]STRDAT,"AATM", WDAT) From TRTDCS
 RESULTAT+=WDAT+space$(35-len(WDAT))+"900"
Endif
#pÃĐriode2 + qualifiant pÃĐriode2
RESULTAT+=space$(38)
#Contient l'effectif au 31/12 sociÃĐtÃĐ si bordereau=TR
If val(NUMBORD)>914
 RESULTAT+=string$(15-len(num$(EFFMRK)),"0")+num$(EFFMRK)
Else
 RESULTAT+=string$(15,"0")
Endif
#statut juridique
RESULTAT+=space$(35)
#Montant 1 Total cotisation
RESULTAT+=string$(18-len(num$(abs(AMTTOT))),"0")+num$(abs(AMTTOT))
#Qualifiant du montant 1
If AMTTOT>=0 : RESULTAT+="277" : Else : RESULTAT+="977" : Endif
#Montant2(18 caractÃĻres)
RESULTAT+=string$(18,"0")
#Qualifiant du montant 2
RESULTAT+=space$(3)
#Montant 3 (18 caractÃĻres)
RESULTAT+=string$(18,"0")
#Qualifiant du montant 3
RESULTAT+=space$(3)
#nb lignes(18 caractÃĻres)
RESULTAT+=string$(18,"0")
#authentification
RESULTAT+=space$(35)
#Devise
RESULTAT+=DEVISE
#filler
RESULTAT+=space$(7)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Return

#########################################
$ENREG_EN
#Code enreg
RESULTAT="EN1"
#qualif intervenant
RESULTAT+="WP"+space$(1)
Read[F:FCY2]FCY0=[F:FCY]FCY
If fstat=0
 #identification intervenant
 INFO=[F:FCY2]CRN
 Gosub RECUP_INFO From TRTDCS
 RESULTAT+=space$(3)
 Gosub RECUP_FCY From TRTDCS
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN2
Else
 Call ECR_TRACE("EN1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN2
#Code enreg
RESULTAT="EN2"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Gosub RECUP_CNT From TRTDCS
 #No ref. 1: no compte URSSAF (sur 15 CaractÃĻres mais Ã  completer par des zÃĐros Ã  gauche si necessaire...)
 Call ORGAFFIL ([M:DIA]ORG,[F:FCY2]FCY,"","",VNUMAFF,VNUMCTR) From SUBORA
 If VNUMAFF=""
  Call ECRIT_TRACE("EN2","No de rÃĐfÃĐrence 1") From TRTDCS
  RESULTAT+=space$(35)
 Else
  If len (VNUMAFF)<35
   RESULTAT+=VNUMAFF+space$(35-len(VNUMAFF))
  Else
   RESULTAT+=left$(VNUMAFF,35)
  Endif
 Endif
 #No ref. 2  : Code APE (si bordereau=TR)
 If val(NUMBORD)=915 | val(NUMBORD)=916
  #No ref. 2: Code APE/NAF
  If len ([F:FCY2]NAF)<35
   RESULTAT+=[F:FCY2]NAF+space$(35-len([F:FCY2]NAF))
  Else
   RESULTAT+=left$([F:FCY2]NAF,35)
  Endif
 Else
  RESULTAT+=space$(35)
 Endif
 #Zones inutilisÃĐes
 RESULTAT+=space$(97)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Gosub ENREG_EN3
Else
 Call ECR_TRACE("EN2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_EN3
#Mtt Ã  ZÃĐro si dÃĐclaration nÃĐant
If [M:DIA]FLGNEA=2 : Raz AMTFCY: Raz AMTTRS : Raz AMTFCYREG : Raz AMTTAT : Endif

#Code enreg
RESULTAT="EN3"

#Date/PÃĐriode : Si BRC alors date de versement des salaires
If val(NUMBORD)=913 | val(NUMBORD)=914
 If [M:DIA]FLGNEA=2
  RESULTAT+="00000000"+space$(27)+"102"
 Else
  Call RECUP_DATE (DATVERS,"AAAAMMJJ",WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(35-len(WDAT))+"102"
 Endif
Else
 RESULTAT+=space$(38)
Endif

#Montant 1 : Total cotisations avec mtt rÃĐgul si bordereau=TR
RESULTAT+=string$(18-len(num$(abs(AMTFCY))),"0")+num$(abs(AMTFCY))
#Qualifiant montant 1
If AMTFCY>=0 : RESULTAT+="134" : Else : RESULTAT+="977" : Endif

#Montant 2 : Total versement transport (TRS)
If  AMTTRS<>0
 RESULTAT+=string$(18-len(num$(abs(AMTTRS))),"0")+num$(abs(AMTTRS))
 #Qualifiant montant 2
 If AMTTRS>0 : RESULTAT+="922" : Else : RESULTAT+="933" : Endif
Else
 RESULTAT+=string$(18,"0")+space$(3)
Endif

#Montant3
If [M:DIA]FLGREG=2 & (val(NUMBORD)=915 |val(NUMBORD)=916) & AMTFCYREG<>0
 RESULTAT+=string$(18-len(num$(abs(AMTFCYREG))),"0")+num$(abs(AMTFCYREG))
 #Qualifiant montant 3
 If AMTFCYREG>0 : RESULTAT+="923" : Else : RESULTAT+="924" : Endif
Else
 RESULTAT+=string$(18,"0")+space$(3)
Endif

#Qualifiant type date/pÃĐriode + date/pÃĐriode + Qualifiant type date/pÃĐriode
RESULTAT+=space$(8)

#Montant 4 : Total versement transport (TAT)
If  AMTTAT<>0
 RESULTAT+=string$(18-len(num$(abs(AMTTAT))),"0")+num$(abs(AMTTAT))
 #Qualifiant montant 2
 If AMTTAT>0 : RESULTAT+="942" : Else : RESULTAT+="943" : Endif
Else
 RESULTAT+=string$(18,"0")+space$(3)
Endif

#Filler
RESULTAT+=space$(122)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_EN4
Return

#########################################
$ENREG_EN4
#Effectif Ã  ZÃĐro si dÃĐclaration nÃĐant
If [M:DIA]FLGNEA=2 : Raz EFFPAYFCY : Raz EFFMRKFCY : Raz EFFMRK : Endif
#Code enreg
RESULTAT="EN4"
#effectif remunÃĐrÃĐ site
RESULTAT+=string$(15-len(num$(EFFPAYFCY)),"0")+num$(EFFPAYFCY)
If val(NUMBORD)=915 | val(NUMBORD)=916
 #effectif inscrit sociÃĐtÃĐ si TR
 RESULTAT+=string$(15-len(num$(EFFMRK)),"0")+num$(EFFMRK)
Else
 #effectif inscrit site
 RESULTAT+=string$(15-len(num$(EFFMRKFCY)),"0")+num$(EFFMRKFCY)
Endif
#Zones non utilisÃĐes
RESULTAT+=string$(210,"0")
#qualifiant enreg effectifs
RESULTAT+=space$(2)
#filler
RESULTAT+=space$(12)
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
If [M:DIA]FLGNEA<>2
 Gosub ENREG_COT
 If AMTTRS<>0
  Gosub ENREG_TRS
  If AMTTAT<>0 : Gosub ENREG_TAT : Endif
 Endif
Endif
Return

#########################################
$ENREG_COT
For[F:TDU]TDU0 Where USR=GUSER & CREDAT=date$ & CAI=[M:DIA]CAI & FCY=[F:FCY2]FCY
 #Code enreg
 RESULTAT="COT"
 #Qualif ligne cotisation
#65985
 #RESULTAT+="905"
 Read[F:ADI]CODE=10377;[F:TDU]CODDCS
 If fstat=0
  If [F:ADI]N1>99 & [F:ADI]N1<1000
   RESULTAT+=num$([F:ADI]N1)
  Else
   RESULTAT+="905" :#Urssaf par dÃĐfaut
  Endif
#
  #Type cotisation
  RESULTAT+=[F:ADI]A2
 Else
  Call ECR_TRACE("COT"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
  OK=0 : Break
 Endif
 #Qualif instruction+instruction codÃĐe
 RESULTAT+=space$(6)
 #No ligne
 RESULTAT+=string$(6,"0")
 #Date de dÃĐbut de changements de cotisations sur 35 cacarctÃĻres
 If [F:TDU]PERDEB<>[0/0/0]
  Call RECUP_DATE ([F:TDU]PERDEB, "AAAAMMJJ", WDAT) From TRTDCS
  RESULTAT+=WDAT+space$(35-len(WDAT))+"102"
 Else
  RESULTAT+=space$(38)
 Endif
 #% cotisations (seulement les taux at)
 If [F:TDU]RATWAC<>0
  RESULTAT+=string$(8-len(num$([F:TDU]RATWAC*10000)),"0")+num$([F:TDU]RATWAC*10000)
 Else
  RESULTAT+=string$(8,"0")
 Endif
 #Type montant

 #75114 : FNAL deplafonnÃĐ negatif (code 568) a dÃĐclarer en positif.
 If [F:TDU]AMT1>=0 | [F:ADI]A2="568" : RESULTAT+="920" : Else : RESULTAT+="925" : Endif

 #Montant1 (dÃĐplafonnÃĐ)
 RESULTAT+=string$(18-len(num$(arr(abs([F:TDU]AMT1),1))),"0")+num$(arr(abs([F:TDU]AMT1),1))
 #Champ rÃĐservÃĐ
 RESULTAT+=space$(3)
 #Type montant2
 #Si c'est une rÃĐduction, le signe dÃĐpend du montant de la cotisation et non de la base.
 # 59992 : Ajout code 673, 674 & 675 pour Exo ZFU
 # 60857 & 62844 : Ajout codes 462, 463 & 580 pour new reductions patronales
 If [F:ADI]A2="670" | [F:ADI]A2="671" | [F:ADI]A2="004" | [F:ADI]A2="005" | [F:ADI]A2="095"
& | [F:ADI]A2="673" | [F:ADI]A2="674" | [F:ADI]A2="675" | [F:ADI]A2="462" | [F:ADI]A2="463"
& |  [F:ADI]A2="580"
  If [F:TDU]AMT3>=0
   RESULTAT+="926"
   #Risque de rejet Ducs - RÃĐduction positive
   Call ECR_TRACE([F:TDU]CODDCS-":"-mess(28,10714,1),-1) From GESECRAN
  Else
   RESULTAT+="921"
  Endif
 Else
  If [F:TDU]AMT2>=0 : RESULTAT+="921" : Else : RESULTAT+="926" : Endif
 Endif
 #Montant2 (plafonnÃĐ)
 RESULTAT+=string$(18-len(num$(arr(abs([F:TDU]AMT2),1))),"0")+num$(arr(abs([F:TDU]AMT2),1))
 #Champ rÃĐservÃĐ
 RESULTAT+=space$(3)
 #Effectif si TR alors zone non utilisÃĐe
 If val(NUMBORD)<>915 & val(NUMBORD)<>916
  If EFFPAYFCY>=[F:TDU]NBREMP1
   RESULTAT+=string$(15-len(num$([F:TDU]NBREMP1)),"0")+num$([F:TDU]NBREMP1)
  Else
   RESULTAT+=string$(15-len(num$(EFFPAYFCY)),"0")+num$(EFFPAYFCY)
  Endif
 Else
  RESULTAT+=string$(15,"0")
 Endif
 ####################Loi TEPA
 #QuantitÃĐ 2 (4 dÃĐcimales sans sÃĐparateur)
 If [F:TDU]QTY2<>0
  RESULTAT+=string$(15-len(num$(arr([F:TDU]QTY2,1)*10000)),"0")+num$(arr([F:TDU]QTY2,1)*10000)
 Else
  RESULTAT+=string$(15,"0")
 Endif
 ####################
 #Zones non utilisÃĐes
 RESULTAT+=space$(110)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Next
If !OK : Return : Endif
Return

#########################################
$ENREG_TRS
For [F:DCT]DCT0 Where FCY=[F:FCY2]FCY & CAI=[M:DIA]CAI & ORG=[F:ORG]COD & STRDAT=[M:DIA]STRDAT & ENDDAT=[M:DIA]ENDDAT
 #Code enreg
 RESULTAT="TRS"
 #Identification du lieu : code insee sur 5 caractÃĻres
 RESULTAT+=[F:DCT]TRSCODSEE+space$(25-len([F:DCT]TRSCODSEE))
 #Taux 1
 RESULTAT+=string$(8-len(num$([F:DCT]TRSRAT(0)*10000)),"0")+num$([F:DCT]TRSRAT(0)*10000)
 #Montant 1 : Base de cotisation Taux 1
 RESULTAT+=string$(18-len(num$(arr(abs([F:DCT]TRSBAS(0)),1))),"0")+num$(arr(abs([F:DCT]TRSBAS(0)),1))
 #Qualifiant 1
 If [F:DCT]TRSBAS(0)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 If [F:DCT]TRSBAS(1)<>0
  #Taux 2
  RESULTAT+=string$(8-len(num$([F:DCT]TRSRAT(1)*10000)),"0")+num$([F:DCT]TRSRAT(1)*10000)
  #Montant 2
  RESULTAT+=string$(18-len(num$(arr(abs([F:DCT]TRSBAS(1)),1))),"0")+num$(arr(abs([F:DCT]TRSBAS(1)),1))
  #Qualifiant 2
  If [F:DCT]TRSBAS(1)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 Else
  RESULTAT+=string$(26,"0")+space$(3)
 Endif
 If [F:DCT]TRSBAS(2)<>0
  #Taux 3
  RESULTAT+=string$(8-len(num$([F:DCT]TRSRAT(2)*10000)),"0")+num$([F:DCT]TRSRAT(2)*10000)
  #Montant 3
  RESULTAT+=string$(18-len(num$(arr(abs([F:DCT]TRSBAS(2)),1))),"0")+num$(arr(abs([F:DCT]TRSBAS(2)),1))
  #Qualifiant 3
  If [F:DCT]TRSBAS(2)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 Else
  RESULTAT+=string$(26,"0")+space$(3)
 Endif
 #Filler
 RESULTAT+=space$(140)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Next
Return

#########################################
$ENREG_TAT
For [F:DCX]DCX0 Where FCY=[F:FCY2]FCY & CAI=[M:DIA]CAI & ORG=[F:ORG]COD & STRDAT=[M:DIA]STRDAT & ENDDAT=[M:DIA]ENDDAT
 #Code enreg
 RESULTAT="TAT"
 #Identification du lieu : code insee sur 5 caractÃĻres
 RESULTAT+=[F:DCX]TATCODSEE+space$(25-len([F:DCX]TATCODSEE))
 #Taux 1
 RESULTAT+=string$(8-len(num$([F:DCX]TATRAT(0)*10000)),"0")+num$([F:DCX]TATRAT(0)*10000)
 #Montant 1 : Base de cotisation Taux 1
 RESULTAT+=string$(18-len(num$(arr(abs([F:DCX]TATBAS(0)),1))),"0")+num$(arr(abs([F:DCX]TATBAS(0)),1))
 #Qualifiant 1
 If [F:DCX]TATBAS(0)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 If [F:DCX]TATBAS(1)<>0
  #Taux 2
  RESULTAT+=string$(8-len(num$([F:DCX]TATRAT(1)*10000)),"0")+num$([F:DCX]TATRAT(1)*10000)
  #Montant 2
  RESULTAT+=string$(18-len(num$(arr(abs([F:DCX]TATBAS(1)),1))),"0")+num$(arr(abs([F:DCX]TATBAS(1)),1))
  #Qualifiant 2
  If [F:DCX]TATBAS(1)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 Else
  RESULTAT+=string$(26,"0")+space$(3)
 Endif
 If [F:DCX]TATBAS(2)<>0
  #Taux 3
  RESULTAT+=string$(8-len(num$([F:DCX]TATRAT(2)*10000)),"0")+num$([F:DCX]TATRAT(2)*10000)
  #Montant 3
  RESULTAT+=string$(18-len(num$(arr(abs([F:DCX]TATBAS(2)),1))),"0")+num$(arr(abs([F:DCX]TATBAS(2)),1))
  #Qualifiant 3
  If [F:DCX]TATBAS(2)>=0 : RESULTAT+="272" : Else : RESULTAT+="972" : Endif
 Else
  RESULTAT+=string$(26,"0")+space$(3)
 Endif
 #Filler
 RESULTAT+=space$(140)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Next
Return

#########################################
$ENREG_PAI
#Code enreg
RESULTAT="PAI"
#Mode de paiement
Call ORGBAN([M:DIA]ORG,[M:DIA]CPY,[L]MODPAY,[L]BAN(0),[L]BAN(1)) From SUBORA
If [L]MODPAY
 #Mode de paiement +Qualif du compte bancaire
 If [L]MODPAY=1     :#chÃĻque
  RESULTAT+="20"+space$(1)
  RESULTAT+="BF"+space$(1)
  RESULTAT+=space$(75)
 Elsif [L]MODPAY=2  :#virement
  RESULTAT+="30"+space$(1)
  RESULTAT+="BF"+space$(1)
  Call RECUP_ORG ([M:DIA]COD,RESULTAT,OK)From TRTDCS
 Else                      :#tÃĐlÃĐrÃĻglement
  RESULTAT+="Z10"
  RESULTAT+="OR"+space$(1)
  If [M:DIA]BANFCY(NUMBANK)<>""
   Call RECUP_BANK ([M:DIA]BANFCY(NUMBANK),RESULTAT,OK)From TRTDCS
  Else
   #Banque non renseignÃĐe
   Call ECR_TRACE("PAI"-mess(20,10711,1),1) From GESECRAN
   OK=0 : Return
  Endif
 Endif
 If OK=0 : Return : Endif
 #Montant rÃĐglÃĐ
 If NUMBANK=0
  If MAXAMT<>0 & MAXAMT<AMTTOT
   RESULTAT+=string$(18-len(num$(abs(MAXAMT))),"0")+num$(abs(MAXAMT))
  Else
   RESULTAT+=string$(18-len(num$(abs(AMTTOT))),"0")+num$(abs(AMTTOT))
  Endif
 Else
  RESULTAT+=string$(18-len(num$(abs(AMTTOT)-abs(MAXAMT))),"0")+num$(abs(AMTTOT)-abs(MAXAMT))
 Endif
 #Devise
 RESULTAT+=DEVISE+space$(3-len(DEVISE))
 #Type de rÃĐfÃĐrence
 If [L]MODPAY<3     :#chÃĻque ou virement
  RESULTAT+="PQ"+space$(1)
  RESULTAT+="99" :#pour clÃĐ non calculÃĐe
  RESULTAT+="S1" :#URSSAF
  #SIRET de l'ÃĐmetteur
  Read[F:FCY2]FCY0=[F:DUC]FCYSEN
  If !fstat
   INFO=[F:FCY2]CRN
  Endif
  Gosub REF_SOCIALE From TRTDCS
 Else
  RESULTAT+="CR"+space$(1)
  RESULTAT+="URSSAF"+space$(2)
  Gosub REF_CPOP From TRTDCS
 Endif
 #Filler
 RESULTAT+=space$(71)
 Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Else
 Call ECR_TRACE("PAI"-mess(4,10707,1)-"ORGBAN [ORB]",1) From GESECRAN
 OK=0 : Return
Endif
Return
