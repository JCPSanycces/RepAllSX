#<AdxTL>@(#)3.0.0.0 $Revision$
#########################################
$ENREG_DEB
#Code enreg
RESULTAT="DEB"
#Identification de l'ÃĐmetteur
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 INFO=[F:FCY2]CRN
 Gosub RECUP_INFO From TRTDCS
 RESULTAT+="5"+space$(3)
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Identification du rÃĐcepteur
Read[F:ORG]ORG0=GCURLEG;[M:DIA]ORG
If !fstat
 INFO=[F:ORG]CRN
 Gosub RECUP_INFO From TRTDCS
 RESULTAT+="5"+space$(3)
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"ORGANISME [ORG]",1) From GESECRAN
 OK=0 : Return
Endif
Gosub COMDEB1 From TRTDCS
#Type dÃĐclaration
RESULTAT+="901"
Gosub COMDEB2 From TRTDCS
#Type de borderau
RESULTAT+=NUMBORD
Gosub COMDEB3 From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR
Gosub ENREG_DT
Gosub ENREG_MR
#Tiers dÃĐclarant
If [F:DUC]FLGEXT=2 : Gosub ENREG_AE : Endif
#Versement en Lieu Unique (VLU)
If (NUMBORD="914" | NUMBORD="916")
 Gosub ENREG_FZ
Endif
Gosub ENREG_GEN
Return

#########################################
$ENREG_FR
#code enreg
RESULTAT="FR1"
#Intervenant
RESULTAT+="FR"+space$(1)
#Siret emetteur
Read[F:FCY2]FCY0=[F:DUC]FCYSEN
If !fstat
 If [F:FCY2]CRN=""
  #Identification de l'ÃĐmetteur physique
  Call ECRIT_TRACE("FR1",mess(7,10707,1)) From TRTDCS
 Else
  If len ([F:FCY2]CRN)<35
   RESULTAT+=[F:FCY2]CRN+space$(35-len([F:FCY2]CRN))
  Else
   RESULTAT+=left$([F:FCY2]CRN,35)
  Endif
 Endif
Else
 Call ECR_TRACE("FR1"-mess(4,10707,1)-"FACILITY [FCY2]",1) From GESECRAN
 OK=0 : Return
Endif
#Zone reservÃĐe
RESULTAT+=space$(3)
Gosub RECUP_FCY From TRTDCS
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
Gosub ENREG_FR2
Return

#########################################
$ENREG_FR2
#code enreg
RESULTAT="FR2"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If fstat=0
  Gosub RECUP_CNT From TRTDCS
  #Zones non utilisÃĐes
  RESULTAT+=space$(167)
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
  Gosub ENREG_FR3
 Else
  Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
  OK=0 : Return
 Endif
Else
 Call ECR_TRACE("FR2"-mess(4,10707,1)-"CONTACT [CNT]",1) From GESECRAN
 OK=0 : Return
Endif
Return

#########################################
$ENREG_FR3
#code enreg
RESULTAT="FR3"
#collaborateur
Read[F:CNT]CNT0=3;[F:FCY2]FCY;[F:FCY2]CNTNAM
If fstat=0
 Read [AIN]AIN0=[F:FCY2]CNTNAM
 If !fstat
  Gosub RECUP_EMAIL From TRTDCS
  Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
 Else
  Call ECR_TRACE("FR3"-mess(4,10707,1)-"CONTACTCRM [AIN]",1) From GESECRAN
