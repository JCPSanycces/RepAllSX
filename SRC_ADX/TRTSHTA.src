#<AdxTL>@(#)8.0.0.0 $Revision$
Local File ITMMASTER [ITM]
Filter [ITM] Where ITMREF="206"
Read [ITM]ITM0="VITRE"
Infbox "itm="+[F:ITM]ITMREF+"fstat="+num$(fstat)
Filter [ITM]
Close Local File [ITM]
End

###############################################################################
#
# Traitement de sous programmes divers utilisés par la fenêtre de sélection
# des régularisations de manquants et par la fenêtre
# paramètres stock "Gestion des manquants"
#
# LECSTE    : Se positionne sur le fichier STOPAR[STE]
#             et alimente les priorités de l'écran STKSHTCRIT [SSC]
# MODIF_PRI : Met à jour les champs PFIELDn dans le masque courant
#             en fonction de celui qui vient d'être modifié
###############################################################################


###############################################################################
# LECSTE : Se positionne sur le fichier STOPAR[STE]
#          et alimente les priorités dans le masque STKSHTCRIT [SSC]
###############################################################################
# Paramètres E : PITM = article
#                PFCY = site
#                PAFF = Rafraichir STKSHTCRIT (0=non, 1=oui)
#
# Pré-requis : Tables suivantes ouvertes : [ITM], [STE]
###############################################################################
Subprog LECSTE(PITM, PFCY, PAFF)
Value Char    PITM
Value Char    PFCY
Value Integer PAFF
Local Integer OUVRE_ITF

Raz OUVRE_ITF
    #---------- Lecture avec catégorie et site ---------------#
    If PITM<>""
        If [F:ITM]ITMREF<>PITM
            Read [ITM]ITM0=PITM
            If fstat
                GMESSAGE = mess(134,100,1)
                End
            Endif
        Endif
        If !clalev([ITF]) : Local File ITMFACILIT [ITF] : OUVRE_ITF=1 : Endif
        Look [ITF]ITF0=PITM;PFCY
        If OUVRE_ITF
            Close Local File [ITF]
        Endif
        If fstat
            GMESSAGE = mess(139,197,1)
            End
        Endif
        Read [STE]STE0=PFCY;[F:ITM]TCLCOD
    Endif

    #---------- Lecture avec site uniquement ---------------#
    If fstat | PITM=""
        Read [STE]STE0=PFCY;""
        If fstat
            [M:SSC]SHTPAR1 = 2
            [M:SSC]SHTPAR2 = 1
            [M:SSC]SHTCAT1 = 2
            [M:SSC]SHTCAT2 = 1
            If PAFF
                Call MODIF_PRI("SHTPAR",2, [M:SSC]SHTPAR2)
                Call MODIF_PRI("SHTCAT",2, [M:SSC]SHTCAT2)
                Affzo [M:SSC]10-15
                Call ERREUR( mess(119,184,1)-"("+PFCY+")" ) From GESECRAN
            Endif
            End
        Endif
    Endif

    #---------- Affectation des champs ---------------#
    [M:SSC] = [F:STE]
    If PAFF
        Call MODIF_PRI("SHTPAR",2,[M:SSC]SHTPAR2)
        Call MODIF_PRI("SHTPAR",1,[M:SSC]SHTPAR1)
        Call MODIF_PRI("SHTCAT",2,[M:SSC]SHTCAT2)
        Call MODIF_PRI("SHTCAT",1,[M:SSC]SHTCAT1)
        Affzo [M:SSC]20-25
    Endif
End


###############################################################################
# MODIF_PRI : Met à jour les champs PFIELDn dans le masque courant
#             en fonction de celui qui vient d'être modifié
# Si PFIELD1=1 => PFIELD2=PFIELD3=1
# Si modif PFIELD1 => si PFIELD1=PFIELD2 => PFIELD2 = valeur <>PFIELD1 et <>PFIELD3 et <>1
#                  => si PFIELD1=PFIELD3 => PFIELD3 = valeur <>PFIELD1 et <>PFIELD2 et <>1
# Si PFIELD2=1 => PFIELD3=1
# Si modif PFIELD2 => si PFIELD2=PFIELD3 => PFIELD3 = valeur <>PFIELD1 et <>PFIELD2 et <>1
###############################################################################
# Paramètres E : PFIELD  = Base des nom de champs ayant une relation
#                PINDPRI = Indice du champ PFIELD modifié
#                PVAL    = Nouvelle valeur du champ PFIELDn (ce paramètre est
#                          déclaré en variable au cas où)
#
# Pré-requis : Masque par défaut contient les champs PFIELDn
#
###############################################################################
Subprog MODIF_PRI(PFIELD, PINDPRI, PVAL)
Value    Char    PFIELD
Value    Integer PINDPRI
Variable Integer PVAL

Local Integer I

# Si "Pas de traitement" est choisi, les priorités suivantes ne peuvent pas être sélectionnées
If PVAL=1
    For I=PINDPRI+1 To 3
        Assign PFIELD+num$(I) With 1
        Diszo =PFIELD+num$(I)
    Next
Else
    If PINDPRI=1
        # Sinon, si la priorité1=priorité2, priorité2 prend la valeur mini qui n'est pas choisie
        If evalue(PFIELD+"2")=PVAL
            Assign PFIELD+"2" With
&                        min( (((PVAL<>2)*(evalue(PFIELD+"3")<>2))=0)*100+2*(PVAL<>2)*(evalue(PFIELD+"3")<>2),
&                             (((PVAL<>3)*(evalue(PFIELD+"3")<>3))=0)*100+3*(PVAL<>3)*(evalue(PFIELD+"3")<>3),
&                             (((PVAL<>4)*(evalue(PFIELD+"3")<>4))=0)*100+4*(PVAL<>4)*(evalue(PFIELD+"3")<>4))
        Endif
        # De même pour priorité3
        If evalue(PFIELD+"3")=PVAL
            Assign PFIELD+"3" With
&                        min( (((PVAL<>2)*(evalue(PFIELD+"2")<>2))=0)*100+2*(PVAL<>2)*(evalue(PFIELD+"2")<>2),
&                             (((PVAL<>3)*(evalue(PFIELD+"2")<>3))=0)*100+3*(PVAL<>3)*(evalue(PFIELD+"2")<>3),
&                             (((PVAL<>4)*(evalue(PFIELD+"2")<>4))=0)*100+4*(PVAL<>4)*(evalue(PFIELD+"2")<>4))
        Endif
    Elsif evalue(PFIELD+"3")=PVAL
        Assign PFIELD+"3" With
&                        min( (((PVAL<>2)*(evalue(PFIELD+"1")<>2))=0)*100+2*(PVAL<>2)*(evalue(PFIELD+"1")<>2),
&                             (((PVAL<>3)*(evalue(PFIELD+"1")<>3))=0)*100+3*(PVAL<>3)*(evalue(PFIELD+"1")<>3),
&                             (((PVAL<>4)*(evalue(PFIELD+"1")<>4))=0)*100+4*(PVAL<>4)*(evalue(PFIELD+"1")<>4))
    Endif

        Actzo =PFIELD+num$(PINDPRI+1)
Endif
End


#########################################
# Initialisation de l'écran
#########################################
# Paramètres E : PAFFERR = 0: affichage des erreurs
#                          1: n'affiche pas les erreurs
#
# Il est possible d'appeler directement ce /s-pro
# après chargement des champs STOFCY et ITMREF
#
# Pré-requis : Table [ITM] et [STE] ouvertes
#              (appeler INIT_SHT From TRTSHTCOM)
#########################################
Subprog LOADSHTS(PAFFERR)
Value Integer PAFFERR
    Transmask [M:SSC] To [M:SHTS] # Issue 25606_Transmask [M:SHTS] = [M:SSC]
    If [M:SSC]MONOITMFLG=2
        [M:SHTS]ITMREFEND = [M:SHTS]ITMREFSTR
        Call ALIM_SHTS(PAFFERR, 1) From TRTSHTA
    Else
        Call ALIM_SHTS(PAFFERR, 0) From TRTSHTA
    Endif
End

###############################################################################
# ALIM_STHS : Alimentation de l'écran STKSHTSEL [SHTS] à partir des critères
#             renseignés dans l'en-tête
###############################################################################
# Paramètres E : PFUNC   : fonction d'origine (0= Fonction de régul)
#                                             (1= Document d'entrées)
#                PFILITM : Indique comment le tableau doit être rempli
#                            ( 0= tout      )
#                            ( 1= Premier   )
#                            ( 2= Dernier   )
#                            ( 3= Suivant   )
#                            ( 4= Précédent )
#                            ( 5= Courant   )
# Pré-requis : Table STOJOU [STJ] et STOALL [STA] ouvertes
###############################################################################
Subprog ALIM_SHTS( PAFFERR, PFILITM )
Value Integer PAFFERR
Value Integer PFILITM


Local Integer I
Local Char    WCRITTYP(50)(1..3)
Local Char    WITMCRIT(50)
Local Char    WTCLCRIT(50)
Local Char    WTSICRIT(200)
Local Char    WITMDES1(GLONDES)                 # hcb X3-53232
#--- Bug 82333
Local Char    WTRUCOD(GLONTRU)
Local Char    WLOT(GLONLOT)
Local Char    WLOC(GLONLOT)
Local Char    WWRH(GLONWRH)
Local Integer WLOCTYP
#---
#--- TS 106217
Local Char    WECCVALMAJ(GLONECS)

Local Integer LRET

If !clalev([F:ITV])   Local File ITMMVT [ITV]   Endif

    #----------- effacement des lignes précédentes ------------#
    Effzo [M:SHTS]10
    nolign = 1
    #------- construction des critères article et catégorie -------------#
    If [M:SSC]PRIDEFFLG=2
        Call LECSTE( [F:ITM]ITMREF, [M:SHTS]STOFCY, 0 ) From TRTSHTA
    Endif
    WITMCRIT1 = "1=1"
    WITMCRIT2 = "1=1"
    Case PFILITM
        When 0, 1, 2 :
            WITMCRIT1 = "ITMREF >=[M:SSC]ITMREFSTR"
            If [M:SSC]ITMREFEND<>""
                WITMCRIT2 = "ITMREF <= [M:SSC]ITMREFEND"
            Endif

        When 3 :    #------ Précédent -----#
            WITMCRIT1 = "ITMREF < [M:SHTS]ITMREFSTR"
&                     + " & ITMREF >= [M:SSC]ITMREFSTR"

        When 4 :    #----- Suivant -----#
            WITMCRIT1 = "ITMREF > [M:SHTS]ITMREFSTR"
            If [M:SSC]ITMREFEND<>""
                WITMCRIT2 = "ITMREF <= [M:SSC]ITMREFEND"
            Endif

        When 5 :    #------ Courant -------#
            WITMCRIT1 = "ITMREF >= [M:SHTS]ITMREFSTR"
            If [M:SSC]ITMREFEND<>""
                WITMCRIT2 = "ITMREF <= [M:SSC]ITMREFEND"
            Endif

        When Default:
            End
    Endcase
    If [M:SSC]TCLCODEND=""
        WTCLCRIT = "1=1"
    Else
        WTCLCRIT = "TCLCOD <= [M:SHTS]TCLCODEND"
    Endif

    WTSICRIT = "1=1"
    For I=0 To dim([M:SSC]TSICODSTR)-1
        If [M:SSC]TSICODEND(I)<>""
            WTSICRIT += " & TSICOD("+num$(I)+")>='"+[M:SSC]TSICODSTR(I)+"'"
&                      +" & TSICOD("+num$(I)+")<='"+[M:SSC]TSICODEND(I)+"'"
        Endif
    Next

    #------- Ordonnancement des catégories de document (négoce, production, interne) -----#
    For I=1 To 3
        Raz WCRITTYP(I)
        #--- Issue X3-4501 : ajout 40 tache affaire
        Case evalue("[M:SSC]SHTCAT"+num$(I))
            When 2 : #-- Négoce ---#
                WCRITTYP(I) = "find(VCRTYP,2,3,4,5,8,33,40)"
            When 3 : #-- Production ---#
                WCRITTYP(I) = "find(VCRTYP,6,10,12,36)"
            When 4 : #-- Interne ---#
                WCRITTYP(I) = "find(VCRTYP,20,31,32)"
        Endcase
    Next I

    #--------- Boucle sur les articles ---------------#
    Filter [ITM]  Where evalue(WITMCRIT1)
&                    & evalue(WITMCRIT2)
&                    & TCLCOD >= [M:SHTS]TCLCODSTR
&                    & evalue(WTCLCRIT)
&                    & evalue(WTSICRIT)

    If PFILITM=0

        For [ITM]ITM0
            Gosub LECSHTITM
        Next

        If [M:SHTS]NBLIG=0 & (!GSERVEUR | [M:SSC]ERRFLG=2) & PAFFERR<>1
            Call ERREUR( mess(20,180,1) ) From GESECRAN
            Effzo [M:SHTS]ITMREFSTR,ITMREFEND
        Endif
    Else
        If find(PFILITM,2,3)
            Read [ITM]ITM0 Last
        Else
            Read [ITM]ITM0 First
        Endif
        If fstat & [M:SHTS]ITMREFSTR<>""
            Filter [ITM]
            Read [ITM]ITM0=[M:SHTS]ITMREFSTR
        Elsif ([M:SSC]ITMREFSTR<>"" & [F:ITM]ITMREF<[M:SSC]ITMREFSTR)
&           | ([M:SSC]ITMREFEND<>"" & [F:ITM]ITMREF>[M:SSC]ITMREFEND)
&           | fstat
            If (!GSERVEUR | [M:SSC]ERRFLG=2) & PAFFERR<>1
                Call ERREUR( mess(20,180,1) ) From GESECRAN
                Effzo [M:SHTS]ITMREFSTR,ITMREFEND
            Endif
        Endif

        While !fstat
&           & [M:SHTS]NBLIG=0
&           & ([M:SSC]ITMREFSTR="" | [F:ITM]ITMREF>=[M:SSC]ITMREFSTR)
&           & ([M:SSC]ITMREFEND="" | [F:ITM]ITMREF<=[M:SSC]ITMREFEND)
            Gosub LECSHTITM
            If [M:SHTS]NBLIG=0
                If find(PFILITM,1,4,5)
                    Read [ITM] Next
                Elsif find(PFILITM,2,3)
                    Read [ITM] Prev
                Endif
                If fstat
                    If find(PFILITM,1,2,5)
                        If (!GSERVEUR | [M:SSC]ERRFLG=2) & PAFFERR<>1
                            Call ERREUR( mess(20,180,1) ) From GESECRAN
                            Effzo [M:SHTS]ITMREFSTR,ITMREFEND
                        Endif
                    Elsif find(PFILITM,3,4)
                        Filter [ITM]
                        Read [ITM]ITM0=[M:SHTS]ITMREFSTR
                    Endif
                Endif
            Else
                [M:SHTS]ITMREFSTR = [F:ITM]ITMREF
                [M:SHTS]ITMREFEND = [F:ITM]ITMREF
                Affzo [M:SHTS]ITMREFSTR,ITMREFEND
            Endif
        Wend
    Endif

    Filter [ITM]


    Affzo [M:SHTS]10
End

$LECSHTITM

If GSUITE = 9
   Return
Endif

        #--- Chargement désignation article
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES1,"[F:ITM]") From TRTX3     # hcb X3-53232


        Raz GPE
        GPOINT = "LECTAB_SHTS" : Gosub ENTREE From EXEFNC     # hcb 70857
         #---- On vérifie que le traitement automatique est autorisé si on vient d'une entrée ---#
        If !(PAFFERR=1 & [F:STE]SHTAUTFLG<>2) | GPE

            Read [ITV]ITV0=[F:ITM]ITMREF;[M:SHTS]STOFCY
            If [F:ITV]DETSHT=0 & [F:ITV]GLOSHT=0 & [F:ITV]WAISTO=0
               Return
            Endif
            # Si uniquement articles avec stock dispo
            Gosub CAL_DISPO
            If [M:SSC]STOFLG=2 & WDISPO <=0
               Return
            Endif
            For I=1 To 3
                Case evalue("[M:SSC]SHTPAR"+num$(I))
                    When 2 : #-- Mvt en attente ---#
                            If [F:ITV]WAISTO>0
                              If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SHTS]STOFCY
                                Read [ITF]ITF0=[F:ITM]ITMREF;[M:SHTS]STOFCY
                              Endif
                              #-- on interdit les régul sur des articles bloqués pour inventaire
                              If [F:ITF]CUNFLG<>2
                                Gosub LEC_MVT_ATT
                              Endif
                            Endif
                    When 3 : #-- Alloc mvt de sortie ---#
                            If [F:ITV]DETSHT>0 | [F:ITV]GLOSHT>0
                              If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SHTS]STOFCY
                                Read [ITF]ITF0=[F:ITM]ITMREF;[M:SHTS]STOFCY
                              Endif
                              #-- on interdit les régul sur des articles bloqués pour inventaire
                              If [F:ITF]CUNFLG<>2
                                Gosub LEC_MANQ
                              Endif
                            Endif
                    When 4 : #-- Alloc  ---#
                            If [F:ITV]DETSHT>0 | [F:ITV]GLOSHT>0
                              Gosub LEC_RUPT
                            Endif
                    When Default :
                Endcase
                If GSUITE = 9
                   Break
                Endif
            Next I
        Endif
    [M:SHTS]NBLIG = nolign-1

# hcb / ts  48778  demande Bertrand DUFOUR pour  David Frith  (Fold Hill Foods Case 24145)
    GPOINT = "ALIM_SHTS" : Gosub ENTREE From EXEFNC

    #---------------------------------------------------------------
    # Point d'entrée à faire pour modifier le contenu de [M:SHTS]LOT
    #---------------------------------------------------------------
    # Exemple de séquence à écrire dans le point d'entrée
    # pour que la régularisation se fasse même si le lot n'est pas renseigné
    #---
    # For I=0 To [M:SHTS]NBLIG-1
    #    If dim([M:SHTS]LOT)>0 & [M:SHTS]LOT(I)="" : [M:SHTS]LOT(I)="*" : Endif
    #    If dim([M:SHTS]SLO)>0 & [M:SHTS]SLO(I)="" : [M:SHTS]SLO(I)="*" : Endif
    # Next I
    #---
# hcb / ts  48778 fin
Return

###############################################################################
# LEC_MVT_ATT : Chargement de STKSHTSEL [SHTS] avec les mouvements en attente
###############################################################################
# Pré-requis : Table STOJOU [STJ] ouverte
#              nolign positionné sur la dernière ligne du tableau
###############################################################################
$LEC_MVT_ATT
Local Integer I_MVT
Local Integer I_SER

    If [M:SSC]FILTSUP="" [M:SSC]FILTSUP="1=1" Endif

    For I_MVT=1 To 3
        If WCRITTYP(I_MVT)<>""
            Filter [STJ] Where STOFCY = [M:SSC]STOFCY
&                            & UPDCOD = 1
&                            & ITMREF = [F:ITM]ITMREF
&                            & REGFLG <> 2
&                            & ACTQTY < 0
&                            & evalue(WCRITTYP(I_MVT))
&                            & evalue([M:SSC]FILTSUP)
&                        Order By IPTDAT
            For [STJ] Hint Key STJ0
                If nolign-1 >= GCOD_SLS
                     Call ERREUR(mess(501,199,1)) From GESECRAN
                     GSUITE = 9

                     Break
                Endif
                [M:SHTS] = [F:STJ]
                [M:SHTS]ITMDES1  (nolign-1) = WITMDES1                   # hcb X3-53232
                [M:SHTS]SEQ      (nolign-1) = [F:STJ]MVTSEQ
                [M:SHTS]TCLCOD   (nolign-1) = [F:ITM]TCLCOD
                [M:SHTS]QTYSTUACT(nolign-1) = -[F:STJ]ACTQTY
                [M:SHTS]QTYSTU   (nolign-1) = -[F:STJ]QTYSTU
                [M:SHTS]BESDAT   (nolign-1) = [F:STJ]IPTDAT
                [M:SHTS]TYPREG   (nolign-1) = 2


                #--- Bug 82333
                Gosub CAL_DISPO_LIG

                #--- Issue 48800
                [M:SHTS]QTYSTUDIS(nolign-1) = WDISPO

                # hcb 28650 deb
                If WDISPO > 0
                   [M:SHTS]AVAFLG(nolign-1) = 2
                Else
                   [M:SHTS]AVAFLG(nolign-1) = 1
                Endif
                # hcb 28650 fin

                #--- Issue 110327 inutile car stock négatif interdit si E/S global (mais on laisse le code)
                # Si no série en E/S globale
								If [F:ITM]SERMGTCOD=4
                    [M:SHTS]SERNUM(nolign-1)  = [F:STJ]SERDEB
                    [M:SHTS]SERNUMF(nolign-1) = [F:STJ]SERFIN
                Elsif dim([M:SHTS]SERNUM)>0 & [M:SHTS]SERNUM(nolign-1) <> ""
                #If dim([M:SHTS]SERNUM)>0 & [M:SHTS]SERNUM(nolign-1) <> ""
                #---
                    [M:SHTS]SERNUMF(nolign-1) = [M:SHTS]SERNUM(nolign-1)

                    #--- Bug 71421
                    #For I_SER=1 To [M:SHTS]QTYSTU(nolign-1)
                    #    Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                    #    If LRET
                    #        Raz [M:SHTS]SERNUMF(nolign-1)
                    #        Break
                    #    Endif
                    #Next I_SER
                    If [M:SHTS]QTYSTUACT(nolign-1)>1
                      For I_SER=1 To [M:SHTS]QTYSTUACT(nolign-1)-1
                        Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                        If LRET
                            Raz [M:SHTS]SERNUMF(nolign-1)
                            Break
                        Endif
                      Next I_SER
                    Endif
                    #---

                Endif
                nolign += 1
            Next
            Filter [STJ]
            If GSUITE = 9
               Break
            Endif
        Endif
    Next I_MVT
Kill I_MVT, I_SER
Return

###############################################################################
# LEC_MANQ : Chargement de STKSHTSEL [SHTS] avec les manquants
###############################################################################
# Pré-requis : Table STOALL [STA] ouverte
#              nolign positionné sur la dernière ligne du tableau
###############################################################################
$LEC_MANQ
Local Integer I_MANQ
Local Integer I_SER

    If [M:SSC]FILTSUP="" [M:SSC]FILTSUP="1=1" Endif

    For I_MANQ=1 To 3
        If WCRITTYP(I_MANQ)<>""
            #--- Bug 84767 : ajout filtre ' & SRGNUM="" '
            Filter [STA] Where STOFCY = [M:SSC]STOFCY
&                            & ITMREF = [F:ITM]ITMREF
&                            & STOCOU = 0
&                            & find(VCRTYP,3,4,5,6,8,12,20,31,32,33)
&                            & find(ALLTYP,4,5)
&                            & evalue(WCRITTYP(I_MANQ))
&                            & evalue([M:SSC]FILTSUP)
&                            & SRGNUM=""
&                        Order By BESDAT
            For [STA] Hint Key STA0
                If nolign-1 >= GCOD_SLS

                     Call ERREUR(mess(501,199,1)) From GESECRAN
                     GSUITE = 9


                     Break
                Endif
                [M:SHTS] = [F:STA]
                [M:SHTS]ITMDES1  (nolign-1) = WITMDES1                   # hcb X3-53232
                [M:SHTS]TCLCOD(nolign-1)    = [F:ITM]TCLCOD
                [M:SHTS]STU   (nolign-1)    = [F:ITM]STU
                [M:SHTS]TYPREG(nolign-1)    = 3

                #--- Bug 82333
                Gosub CAL_DISPO_LIG

                #--- Issue 48800
                [M:SHTS]QTYSTUDIS(nolign-1) = WDISPO

                # hcb 28650 deb
                If WDISPO > 0
                   [M:SHTS]AVAFLG(nolign-1) = 2
                Else
                   [M:SHTS]AVAFLG(nolign-1) = 1
                Endif
                # hcb 28650 fin

                If dim([M:SHTS]SERNUM)>0 & [M:SHTS]SERNUM(nolign-1) <> ""
                    [M:SHTS]SERNUMF(nolign-1) = [M:SHTS]SERNUM(nolign-1)

                    #--- Bug 71421
                    #For I_SER=1 To [M:SHTS]QTYSTU(nolign-1)
                    #    Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                    #    If LRET
                    #        Raz [M:SHTS]SERNUMF(nolign-1)
                    #        Break
                    #    Endif
                    #Next I_SER
                    If [M:SHTS]QTYSTUACT(nolign-1)>1
                      For I_SER=1 To [M:SHTS]QTYSTUACT(nolign-1)-1
                        Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                        If LRET
                            Raz [M:SHTS]SERNUMF(nolign-1)
                            Break
                        Endif
                      Next I_SER
                    Endif
                    #---

                Endif
                nolign += 1
            Next
            Filter [STA]
            If GSUITE = 9
               Break
            Endif
        Endif
    Next I_MANQ
Kill I_MANQ, I_SER
Return

###############################################################################
# LEC_RUPT : Chargement de STKSHTSEL [SHTS] avec les ruptures d'allocation
###############################################################################
# Pré-requis : Table STOALL [STA] ouverte
#              nolign positionné sur la dernière ligne du tableau
###############################################################################
$LEC_RUPT
Local Integer I_RUPT
Local Integer I_SER

    If [M:SSC]FILTSUP="" [M:SSC]FILTSUP="1=1" Endif

    For I_RUPT=1 To 3
        If WCRITTYP(I_RUPT)<>""
            #--- Bug 84767 : ajout filtre ' & SRGNUM="" '
            #--- Issue X3-4501 : ajout 40 tache affaire
            Filter [STA] Where STOFCY = [M:SSC]STOFCY
&                            & ITMREF = [F:ITM]ITMREF
&                            & STOCOU = 0
&                            & find(VCRTYP,2,10,36,40)
&                            & find(ALLTYP,4,5)
&                            & evalue(WCRITTYP(I_RUPT))
&                            & evalue([M:SSC]FILTSUP)
&                            & SRGNUM=""
&                        Order By BESDAT;VCRTYP;VCRNUM          # hcb 105044
            For [STA] Hint Key STA0
                If nolign-1 >= GCOD_SLS

                     Call ERREUR(mess(501,199,1)) From GESECRAN
                     GSUITE = 9


                     Break
                Endif
                [M:SHTS] = [F:STA]
                [M:SHTS]ITMDES1  (nolign-1) = WITMDES1                   # hcb X3-53232
                [M:SHTS]TCLCOD(nolign-1)    = [F:ITM]TCLCOD
                [M:SHTS]STU   (nolign-1)    = [F:ITM]STU
                [M:SHTS]TYPREG(nolign-1)    = 4

                #--- Bug 82333
                Gosub CAL_DISPO_LIG

                #--- Issue 48800
                [M:SHTS]QTYSTUDIS(nolign-1) = WDISPO

                # hcb 28650 deb
                If WDISPO > 0
                   [M:SHTS]AVAFLG(nolign-1) = 2
                Else
                   [M:SHTS]AVAFLG(nolign-1) = 1
                Endif
                # hcb 28650 fin

                If dim([M:SHTS]SERNUM)>0 & [M:SHTS]SERNUM(nolign-1) <> ""
                    [M:SHTS]SERNUMF(nolign-1) = [M:SHTS]SERNUM(nolign-1)

                    #--- Bug 71421
                    #For I_SER=1 To [M:SHTS]QTYSTU(nolign-1)
                    #    Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                    #    If LRET
                    #        Raz [M:SHTS]SERNUMF(nolign-1)
                    #        Break
                    #    Endif
                    #Next I_SER
                    If [M:SHTS]QTYSTUACT(nolign-1)>1
                      For I_SER=1 To [M:SHTS]QTYSTUACT(nolign-1)-1
                        Call PLUS_UN([M:SHTS]SERNUMF(nolign-1), [M:SHTS]SERNUMF(nolign-1), LRET) From STKLIB
                        If LRET
                            Raz [M:SHTS]SERNUMF(nolign-1)
                            Break
                        Endif
                      Next I_SER
                    Endif
                    #---

                Endif
                nolign += 1
            Next
            Filter [STA]
            If GSUITE = 9
               Break
            Endif

        Endif
    Next I_RUPT
Kill I_RUPT, I_SER
Return



###############################################################################
# CTRSELFLG: Contrôle que toutes les info nécessaires sont renseignées
###############################################################################
# Paramètres E : PNOL = indice de la ligne de SHTS sur laquelle on effectue le controle
#
#            S : LRET    = construit ainsi: bit 1(1)  =
#                                           bit 2(2)  = N° de lot    à renseigner (oui/non)
#                                           bit 3(4)  = N° de /s lot à renseigner (oui/non)
#                                           bit 4(8)  = N° de série  à renseigner (oui/non)
#                                           bit 5(16) = Statut       à renseigner (oui/non)
#                                           bit 5(16) = Emplacement  à renseigner (oui/non)
###############################################################################
Subprog CTRSELFLG(PNOL, PRET)
Value    Integer PNOL
Variable Integer PRET
Raz PRET

    If [M:SHTS]ALLTYP(PNOL)=5
        PRET=1
        End
    Endif

    If [F:ITM]ITMREF<>[M:SHTS]ITMREF(PNOL)
        Read [ITM]ITM0=[M:SHTS]ITMREF(PNOL)
# hcb 42798 deb
        Read [STE]STE0=[M:SHTS]STOFCY;[F:ITM]TCLCOD
        If fstat
           Read [STE]STE0=[M:SHTS]STOFCY;""
           If fstat
              [F:STE]STACARFLG = 2
              [F:STE]LOCCARFLG = 2
           Endif
        Endif
# hcb 42798 fin
    Endif
    If [F:ITF]ITMREF<>[M:SHTS]ITMREF(PNOL) | [F:ITF]STOFCY<>[M:SHTS]STOFCY
        Read [ITF]ITF0=[M:SHTS]ITMREF(PNOL);[M:SHTS]STOFCY
    Endif
    #--- Pour les ruptures sur commande ou OF on permet une régul auto ----#
    If [M:SHTS]TYPREG(PNOL)<>4
        #---- LOT ----#
        If [F:ITM]LOTMGTCOD>2 & (dim([M:SHTS]LOT)<=0 | [M:SHTS]LOT(PNOL)="")
            PRET +=2
        Endif
        #---- SLO ----#
        If [F:ITM]LOTMGTCOD=4 & (dim([M:SHTS]SLO)<=0 | [M:SHTS]SLO(PNOL)="")
            PRET +=4
        Endif
        #---- SERNUM ----#
        #--- Issue 110327
        #If [F:ITM]SERMGTCOD=3 & (dim([M:SHTS]SERNUM)<=0 | [M:SHTS]SERNUM(PNOL)="")
        If [F:ITM]SERMGTCOD>=3 & (dim([M:SHTS]SERNUM)<=0 | [M:SHTS]SERNUM(PNOL)="")
        #---
            PRET +=8
        Endif
        #---- STA ----#
        If [M:SHTS]STA(PNOL)="" & [F:STE]STACARFLG<>2
&         & [F:ITM]SERMGTCOD<3	 : #--- Issue 110327
            PRET +=16
        Endif
        #---- LOC ----#
        If [F:ITF]LOCMGTCOD=2 & (dim([M:SHTS]LOC)<=0 | [M:SHTS]LOC(PNOL)="" & [F:STE]LOCCARFLG<>2)
&			    & [F:ITM]SERMGTCOD<3	 : #--- Issue 110327
            PRET +=32
        Endif
    Endif
End

########################################
# Paramètre E : PON = 1: Désélectionne tout
#                     2: Sélectionne tout ce qui peut l'être
Subprog SELECT_ALL(PON)
Value Integer PON  # FGR 18/01/2010 : X3SUIVI60986

Local Integer I
Local Integer LRET
Raz [F:ITM]       # hcb 42798

    For I=0 To [M:SHTS]NBLIG-1
        If PON=2
           #--- Issue 48800
           If [M:SHTS]QTYSTUDIS(I)>0
              Call CTRSELFLG(I, LRET) From TRTSHTA
              If !LRET
                 [M:SHTS]FLG(I) = 2
                 Affzo [M:SHTS]FLG(I)
              Endif
           #--- Issue 48800
          Endif
       Else
          [M:SHTS]FLG(I) = 1
          Affzo [M:SHTS]FLG(I)
       Endif
    Next I
End

########################################
Subprog REGUL
Local Integer I
Local Integer LRET
If !GSERVEUR                          # hcb 38033
    Call OUVRE_TRACE( mess( 4, 180, 1) ) From LECFIC
    Call SHTTRACE( mess( 4, 180, 1), 0) From TRTSHTCOM
Endif                                 # hcb 38033

For I=0 To [M:SHTS]NBLIG-1
    If [M:SHTS]FLG(I) = 2
        Call REGAUTO(I, LRET) From TRTSHTAUTO
    Endif
Next I

If !GSERVEUR                          # hcb 38033
    Call SHTTRACE( mess( 4, 180, 1), 0 ) From TRTSHTCOM
    Call LEC_TRACE From LECFIC
    Call FERME_TRACE From LECFIC
    Raz GPE                                               # hcb 88236
    GPOINT = "AFFSHTS" : Gosub ENTREE From EXEFNC         # hcb 88236
    If GPE = 0                                            # hcb 88236
       Call ALIM_SHTS(0, 0) From TRTSHTA
    Endif                                                 # hcb 88236
Endif                                 # hcb 38033
End


# hcb 28650 deb
#########################################"
#--- calcul du stock dispo en statut A, Q, R
$CAL_DISPO
Local Integer WSTA
Local Decimal WDISPO
Raz WSTA
Raz WDISPO

Read [ITG]ITG1=[F:ITM]TCLCOD;[M:SSC]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;""
   If fstat
      Raz [F:ITG]
   Endif
Endif
If [F:ITG]GLOAAAFLG = 2 WSTA   = 1 Else WSTA = 0 Endif
If [F:ITG]GLOQQQFLG = 2 WSTA  += 2 Endif
If [F:ITG]GLORRRFLG = 2 WSTA  += 4 Endif
If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>[M:SSC]STOFCY
   Read [ITV]ITV0=[F:ITM]ITMREF;[M:SSC]STOFCY
   If fstat
      Raz [F:ITV]
   Endif
Endif
If WSTA <> 0
   WDISPO=0
   #--- TS 106217
   #Call STODISPO("",[M:SSC]STOFCY,[F:ITM]ITMREF,"*","*",1,WSTA,"","","",WDISPO) From STKLIB
   Call STODISPO("",[M:SSC]STOFCY,[F:ITM]ITMREF,"*","*",1,WSTA,"","","","",WDISPO) From STKLIB
   #---
Endif
Return
# hcb 28650 fin

#--- Bug 82333
#--- Calcul du stock disponible pour le mouvement/rupture à régulariser
$CAL_DISPO_LIG
WSTA = 1
#--- Issue X3-4501 : ajout 40 tache affaire
If find([M:SHTS]VCRTYP(nolign-1),2,10,36,40)
   Case [M:SHTS]VCRTYP(nolign-1)
    When 2, 40          : WTRUCOD = [F:ITG]ALLRULORD
    When 10             : WTRUCOD = [F:ITG]ALLRULMAT
    When 36             : WTRUCOD = [F:ITG]ALLRULSCC
    When Default
   Endcase
   If WTRUCOD<>""
      # Lecture règle d'allocation
      Read [TRU]TRU0=WTRUCOD
      If !fstat
         WSTA = max([F:TRU]STAFLT)
      Endif
   Endif
Else
   # Si préparation ou livraison, alimentation du type de transaction
   # Issue 86620 - 2013-05-03 by MAE : comment
   #If [M:SHTS]TRSTYP(nolign-1)=0 & find([M:SHTS]VCRTYP(nolign-1),3,4)
   If [M:SHTS]TRSTYP(nolign-1)=0 & find([M:SHTS]VCRTYP(nolign-1),3,4,5,8)           # hcb 94846
      Call GET_TRSTYP([M:SHTS]VCRTYP(nolign-1),[M:SHTS]VCRNUM(nolign-1)," ",[M:SHTS]TRSTYP(nolign-1)) From STKLIB
   Endif
   # Lecture de la règle de gestion pour le mouvement à traiter
   Call LECSRU([M:SHTS]STOFCY,[M:SHTS]TCLCOD(nolign-1),[M:SHTS]TRSTYP(nolign-1),
&           [M:SHTS]TRSCOD(nolign-1),"",LRET) From STKLIB
   If LRET=0
      WSTA = [F:SRU]AUZSTA
   Endif
Endif
If dim([M:SHTS]LOT)> 0 & [M:SHTS]LOT(nolign-1)<>""   # hcb 85839
   WLOT=[M:SHTS]LOT(nolign-1)
Else
   WLOT="*"
Endif
WLOCTYP=1
If dim([M:SHTS]LOC)> 0 & [M:SHTS]LOC(nolign-1)<>""   # hcb 85839
   WLOC=[M:SHTS]LOC(nolign-1)
   Read [F:STC]STC0=[M:SHTS]STOFCY;WLOC
   If !fstat
      Case [F:STC]LOCCAT
       When 3   : WLOCTYP = 2
       When 4   : WLOCTYP = 4
      Endcase
   Endif
Else
   WLOC="*"
Endif
If dim([M:SHTS]WRH)>0 & [M:SHTS]WRH(nolign-1)<>""
   WWRH=[M:SHTS]WRH(nolign-1)
Else
   WWRH=""
Endif
#--- TS 106217
If dim([M:SHTS]ECCVALMAJ)>0 & [M:SHTS]ECCVALMAJ(nolign-1)<>""
   WECCVALMAJ=[M:SHTS]ECCVALMAJ(nolign-1)
Else
   WECCVALMAJ=""
Endif
#Call STODISPO("",[M:SHTS]STOFCY,[F:ITM]ITMREF,WLOT,WLOC,WLOCTYP,WSTA,"","",WWRH,WDISPO) From STKLIB
Call STODISPO("",[M:SHTS]STOFCY,[F:ITM]ITMREF,WLOT,WLOC,WLOCTYP,WSTA,"","",WWRH,
&             WECCVALMAJ,WDISPO) From STKLIB
#---
Return
#---

