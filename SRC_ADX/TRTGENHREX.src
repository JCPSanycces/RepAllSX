$DISPLAYERROR
Local Integer  ERROR_FLAG
Local Char ERROR_MSG(200)

  ERROR_FLAG=errn
  ERROR_MSG=errmes$(errn)

    Infbox(num$(ERROR_FLAG))
    Infbox(num$(ERROR_MSG))
    Infbox(num$([L]TEMP_VAL))
    Infbox(num$([M:HREXE3]DFNCDN(nolign-1)))
    Infbox(num$([M:HREXE3]DFNCOD(nolign-1)))
    Infbox(num$([M:HREXE3]DFNTIT(nolign-1)))
Resume

