#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTGENHREX","GENHREXT",4,"") From GTRAITE
End

$ACTION
  Case [L]ACTION
    When "INIT"       : Gosub INIT
    When "DEBUT"      : Gosub DEBUT
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "OK"         : Gosub OK
#    When "OK"         : FIN = 1 : GOK = 1
    When "END"        : FIN = 1
  Endcase

Return

$INIT
  Gosub OUVFIC

#open screens
  Local Mask GENHREXT0    [HREXE0]   :   Raz   [HREXE0]
  Local Mask GENHREXT1    [HREXE1]   :   Raz   [HREXE1]
  Local Mask GENHREXT2    [HREXE2]   :   Raz   [HREXE2]
  Local Mask GENHREXT3    [HREXE3]   :   Raz   [HREXE3]
  Local Mask GENHREXT4    [HREXE4]   :   Raz   [HREXE4]

  Gosub DECLARATION

Return

#open files
$OUVFIC
  If clalev([F:HREXT])=0      : Local File HREXTRACT        [HREXT]    : Endif
  If clalev([F:HREXD])=0      : Local File HREXTRACTDAT     [HREXD]    : Endif
  If clalev([F:HREXF])=0      : Local File HREXTRACTFIL     [HREXF]    : Endif
  If clalev([F:HREXP])=0      : Local File HREXTRACTPAR     [HREXP]    : Endif
  If clalev([F:HREXG])=0      : Local File HREXTRACTGRP     [HREXG]    : Endif
  If clalev([F:HREXL])=0      : Local File HREXTRACTDEF     [HREXL]    : Endif
  If clalev([F:HREXV])=0      : Local File HREXTRACTVAL     [HREXV]    : Endif
  If clalev([F:HREXR])=0      : Local File HREXTRACTRES     [HREXR]    : Endif

#JASMI - 2017-09-13 - X3-49526 - START
#  If clalev([F:ATB])=0        : Local File ATABLE           [ATB]    : Endif
  If clalev([F:AVWT])=0        : Local File AVIEWTAB           [AVWT]    : Endif
#JASMI - 2017-09-13 - X3-49526 - END

  If clalev([F:HRPOA])=0      : Local File POPULA     [HRPOA]    : Endif

Return

#populate screens on startup
$DEBUT
  Raz [M:HREXE0]
  [M:HREXE0]EXRTEP = PARAM(1)
  Gosub POPULATE_WINDOW

  If [M:HREXE0]EXRTEP<>""
    Diszo [M:HREXE0]EXRTEP
  Endif

Return

#populate screens on startup
$POPULATE_WINDOW
#initialize
  Raz [M:HREXE1] : Raz [M:HREXE2]
  Raz [M:HREXE3] : Raz [M:HREXE4]

#populate header screen
  Read [F:HREXT]HREXT0 = [M:HREXE0]EXRTEP
  If !fstat
    [M:HREXE0] = [F:HREXT]
  Else
    Return
  Endif

#populate detail screen - DATA SOURCES
  nolign = 0
  For [F:HREXD]HREXD0 Where [F:HREXD]EXRTEP=[M:HREXE0]EXRTEP
    nolign += 1
    [M:HREXE1] = [F:HREXD]

    Read [F:AVWT]CODFIC = [F:HREXD]DTATBL
    If !fstat
      [M:HREXE1]DTATBLABR(nolign-1) = [F:AVWT]ABRFIC
#JASMI - 2017-02-21 - START
#    Else
#      Return
#JASMI - 2017-02-21 - END
    Endif
  Next

#populate detail screen - FILTERS
  nolign = 0
  For [F:HREXF]HREXF0 Where [F:HREXF]EXRTEP=[M:HREXE0]EXRTEP
    nolign += 1
    [M:HREXE1] = [F:HREXF]
  Next

#populate detail screen - PARAMETERS
  nolign = 0
  For [F:HREXP]HREXP0 Where [F:HREXP]EXRTEP=[M:HREXE0]EXRTEP
  #populate fixed and defined parameters
    nolign += 1
    [M:HREXE2] = [F:HREXP]
    [M:HREXE2]PARNBR = nolign
  Next

#populate detail screen - GROUP DATA
  nolign = 0
  For [F:HREXG]HREXG0 Where [F:HREXG]EXRTEP=[M:HREXE0]EXRTEP
    nolign += 1
    [M:HREXE3] = [F:HREXG]
  Next

#populate detail screen - DEFINITIONS
  nolign = 0
  For [F:HREXL]HREXL0 Where [F:HREXL]EXRTEP=[M:HREXE0]EXRTEP
    nolign += 1
    [M:HREXE3] = [F:HREXL]
  Next

#populate detail screen - VALIDATIONS
  nolign = 0
  For [F:HREXV]HREXV0 Where [F:HREXV]EXRTEP=[M:HREXE0]EXRTEP
    nolign += 1
    [M:HREXE4] = [F:HREXV]
  Next

#populate default values for parameters
  For nolign=1 To [M:HREXE2]PARNBR
    Gosub SET_GRID_DATA_TYPES
    If [M:HREXE2]PARINTTYP(nolign-1) = "8" or [M:HREXE2]PARINTTYP(nolign-1) = "12"
      If [M:HREXE2]PARDEFDEB(nolign-1)<>""
        [M:HREXE2]PARVALDEB(nolign-1)=format$("D:"+GFMDAT4,evalue([M:HREXE2]PARDEFDEB(nolign-1)))
        [M:HREXE2]VALINT1(nolign-1)=format$("D:YYYYMMDD",evalue([M:HREXE2]PARDEFDEB(nolign-1)))
      Endif
      If [M:HREXE2]PARVALTYP(nolign-1)=2
        If [M:HREXE2]PARDEFFIN(nolign-1)<>""
          [M:HREXE2]PARVALFIN(nolign-1)=format$("D:"+GFMDAT4,evalue([M:HREXE2]PARDEFFIN(nolign-1)))
          [M:HREXE2]VALINT2(nolign-1)=format$("D:YYYYMMDD",evalue([M:HREXE2]PARDEFFIN(nolign-1)))
        Endif
      Endif
    Else
      If [M:HREXE2]PARDEFDEB(nolign-1)<>""
        [M:HREXE2]PARVALDEB(nolign-1)=num$(evalue([M:HREXE2]PARDEFDEB(nolign-1)))
      Endif
      If [M:HREXE2]PARVALTYP(nolign-1)=2
        If [M:HREXE2]PARDEFFIN(nolign-1)<>""
          [M:HREXE2]PARVALFIN(nolign-1)=num$(evalue([M:HREXE2]PARDEFFIN(nolign-1)))
        Endif
      Endif
    Endif
    If [M:HREXE2]PARVALTYP(nolign-1)=1
      Grizo [M:HREXE2]PARVALFIN(nolign-1)
    Endif
  Next nolign

#diable grid if empty
  If [M:HREXE2]PARNBR=0
    Grizo [M:HREXE2]10
  Else
    Actzo [M:HREXE2]10
  Endif

#refresh screens
  Affzo [M:HREXE0]
  Affzo [M:HREXE1]
  Affzo [M:HREXE2]
  Affzo [M:HREXE3]
  Affzo [M:HREXE4]

#disable fileds in grid based on value type
  For nolign=1 To [M:HREXE2]PARNBR
    If [M:HREXE2]PARVALTYP(nolign-1)=1
      Grizo [M:HREXE2]PARVALFIN(nolign-1)
    Endif
  Next nolign

Return

#set the grid data types for the different parameters
$SET_GRID_DATA_TYPES
Local Integer   FIELD_SPEC_START, FIELD_SPEC_END

  [L]FIELD_SPEC_START=instr(1,[M:HREXE2]PARDTACLC(nolign-1),"[")
  If [L]FIELD_SPEC_START>0
    [L]FIELD_SPEC_END=instr(1,[M:HREXE2]PARDTACLC(nolign-1),"]")-[L]FIELD_SPEC_START
    If [L]FIELD_SPEC_END>0
      [M:HREXE2]PARTBL(nolign-1)=mid$([M:HREXE2]PARDTACLC(nolign-1),[L]FIELD_SPEC_START+1,[L]FIELD_SPEC_END-1)
      [L]FIELD_SPEC_START=instr(1,[M:HREXE2]PARTBL(nolign-1),":")
      If [L]FIELD_SPEC_START>0
        [L]FIELD_SPEC_END=len([M:HREXE2]PARTBL(nolign-1))-[L]FIELD_SPEC_START
        If [L]FIELD_SPEC_END>0
          [M:HREXE2]PARTBL(nolign-1)=mid$([M:HREXE2]PARTBL(nolign-1),[L]FIELD_SPEC_START+1,[L]FIELD_SPEC_END)
        Endif
      Endif
    Endif
  Endif

  [L]FIELD_SPEC_START=instr(1,[M:HREXE2]PARDTACLC(nolign-1),"]")
  If [L]FIELD_SPEC_START>0
    [L]FIELD_SPEC_END=len([M:HREXE2]PARDTACLC(nolign-1))-[L]FIELD_SPEC_START
    If [L]FIELD_SPEC_END>0
      [M:HREXE2]PARFLD(nolign-1)=mid$([M:HREXE2]PARDTACLC(nolign-1),[L]FIELD_SPEC_START+1,[L]FIELD_SPEC_END)
    Endif
  Endif



  If (([M:HREXE2]PARTBL(nolign-1)<>'') and ([M:HREXE2]PARFLD(nolign-1)<>'')) and ([M:HREXE2]PARFLD(nolign-1) <> 'XITDAT' and [M:HREXE2]PARTBL(nolign-1) ='ZHRCTR') Then
    If !clalev([F:ATB]) : Local File ATABLE  [ATB] : Endif
    If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
    If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
    If !clalev([F:AMP]) : Local File AMSKPAR [AMP] : Endif

    Read [ATB]ABRFIC=[M:HREXE2]PARTBL(nolign-1)
    If !fstat
      [M:HREXE2]PARTBL(nolign-1)=[ATB]CODFIC
    Endif

    Read [ATZ]CODZONE=[M:HREXE2]PARTBL(nolign-1);[M:HREXE2]PARFLD(nolign-1)
    If !fstat
      Read [ATY]CODTYP=[F:ATZ]CODTYP
      If !fstat
        [M:HREXE2]PARTYP(nolign-1) = [F:ATZ]CODTYP
        [M:HREXE2]PARNBRLIB(nolign-1)  = [F:ATZ]NOLIB
        [M:HREXE2]PARINTTYP(nolign-1)  = num$([F:ATY]TYPTYP)
        L_LONG = [F:ATZ]LONG
        If !L_LONG : L_LONG = [F:ATY]LNGTYP : Endif
          [M:HREXE2]PARLNG(nolign-1) = L_LONG
#          [M:PRF4]CODOBJ(nolign-1) = [F:ATY]OBJLIEN
      Else
        Raz [F:ATY]
      Endif
    Else
      Raz [F:ATZ]
    Endif
    If [F:ATZ]CODTYP="ADI"
      Read [AMP]CODPAR=2;[M:HREXE2]PARTBL(nolign-1);[M:HREXE2]PARFLD(nolign-1);[F:ATZ]CODTYP
      If !fstat
        [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,'"','')
        [F:AMP]VALPAR = ctrans([F:AMP]VALPAR,"'","")
        [M:HREXE2]PARVAL(nolign-1) = [F:AMP]VALPAR
      Endif
    Endif
  Else
    Case [M:HREXE2]PARTYP(nolign-1)
    When "M","MM"
      [M:HREXE2]PARINTTYP(nolign-1)="1"
    When "C"
      [M:HREXE2]PARINTTYP(nolign-1)="2"
    When "L"
      [M:HREXE2]PARINTTYP(nolign-1)="3"
    When "DCB"
      [M:HREXE2]PARINTTYP(nolign-1)="4"
    When "D"
      [M:HREXE2]PARINTTYP(nolign-1)="8"
    When "ADATIM"
      [M:HREXE2]PARINTTYP(nolign-1)="12"
    When Default
      [M:HREXE2]PARINTTYP(nolign-1)="7"
    Endcase
  Endif


Return

#declarations for process
$DECLARATION
Local Char      FICHIER(GDIMFIC), FICCLI(GDIMFIC)
Local Integer   LINE_NUMBER, STAT, ERROR_COUNT
Local Char      CRITERIA(250)(1..4)
Local Char      GROUP_VALUE(250)(1..2)
Local Char      TEMP_GROUP_VALUE(250)(1..)
Local Char      EXTRACT_DATA(250)(1..8)
Local Integer   CRITERIA_COUNT, DATA_LEVEL, LEVEL_RECORD_COUNT(1..2), EXTRACT_DATA_COUNT
Local Char      OPEN_FIELD_VALUE(1), CLOSE_FIELD_VALUE(1)
#JASMI - 2016-10-05 - Issue xxx - START
#Local Char      TEMP_VAL(250), TEMP_VAL2(250), CALC_CHAR(250), CALLED_FROM(20)
Local Clbfile   TEMP_VAL, FILE_VALUES(4)
Local Char      TEMP_VAL2(250), CALC_CHAR(250), CALLED_FROM(20)
#JASMI - 2016-10-05 - Issue xxx - END
Local Integer   FIELD_SPEC_START, FIELD_SPEC_END
Local Integer   TABLE_COUNT, YESNO
Local Date      RUN_DATE
Local Char      RUN_TIME(8)
Local Decimal   HEADER_RECORD_COUNT, DETAIL_RECORD_COUNT, DETAIL_RECORD_COUNT_PER_GROUPING
Local Decimal   HEADER_FIELD_COUNT, DETAIL_FIELD_COUNT, HEADER_FIELD_COUNT_PER_GROUPING, DETAIL_FIELD_COUNT_PER_GROUPING
#JASMI - 2016-05-26 - REQ 116689 - START
Local Char      BEFORE_SIGN_NEG(5), AFTER_SIGN_NEG(5),BEFORE_SIGN_POS(5), AFTER_SIGN_POS(5), PAD_NUM(1)
#JASMI - 2016-05-26 - REQ 116689 - END

Return

$CONTROLE
  If GSTATUT<>GSTAOK
   FIN = 1
  Else
   TMP = 1
   TRA = 1
  Endif

Return

$OK
  FIN = 1 : GOK = 1

  For nolign=1 To [M:HREXE2]PARNBR
    If [M:HREXE2]PARVALTYP(nolign-1)=2
      If [M:HREXE2]PARVALDEB(nolign-1)<>""
#        If [M:HREXE2]VALINT1(nolign-1) ="" Then
        If [M:HREXE2]PARVALFIN(nolign-1) ="" Then
          GERR  = 2
          GMESSAGE = [M:HREXE2]PARTIT(nolign-1)+": "+mess(10,123,1)
          FIN = 0 # Instruct the supervisor to keep the window open
          GOK = 0
          Return
        Endif
      Endif
    Endif
    If [M:HREXE2]PARMDT(nolign-1)=2
      If [M:HREXE2]PARVALDEB(nolign-1)="" Then
        GERR  = 2
        GMESSAGE = [M:HREXE2]PARTIT(nolign-1)+": "+mess(10,123,1)
        FIN = 0 # Instruct the supervisor to keep the window open
        GOK = 0
        Return
      Endif
    Endif
  Next nolign

Return

$EXEC
 Onerrgo $DISPLAYERROR
#set trace file
  TIT=[M:HREXE0]EXRTIT+" - "+mess(95,143,1)+"/"+mess(157,133,1)
  Call OUVRE_TRACE(TIT) From LECFIC

#TRACE HEADING
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN

#JASMI - 2017-09-13 - X3-49526 - START
  GOK=1
  Gosub DELETE_TRT
  Gosub CREATE_TRT
  If GOK<>0
    Gosub COMPILE_TRT
  Endif
  If GOK=0
    Return
  Endif
#JASMI - 2017-09-13 - X3-49526 - END

  Gosub OPEN_TEMPLATE_TABLES

  OK=1
  [L]ERROR_COUNT=0

#JASMI - 2016-05-26 - REQ 116689 - START
  [L]PAD_NUM=""
  If [M:HREXE0]EXRFXDLNG=2
    [L]PAD_NUM="0"
  Endif
  If [M:HREXE0]EXRSYMPOS=3
    [L]BEFORE_SIGN_NEG=""
    [L]AFTER_SIGN_NEG=[M:HREXE0]EXRDEBSYM
    [L]BEFORE_SIGN_POS=""
    [L]AFTER_SIGN_POS=[M:HREXE0]EXRCDTSYM
  Else
    [L]BEFORE_SIGN_NEG=[M:HREXE0]EXRDEBSYM
    [L]AFTER_SIGN_NEG=""
    [L]BEFORE_SIGN_POS=[M:HREXE0]EXRCDTSYM
    [L]AFTER_SIGN_POS=""
  Endif
#JASMI - 2016-05-26 - REQ 116689 - END

  Trbegin [F:HREXR]
  Gosub TR1
  If OK
    Gosub TR2
  Else
    Rollback
  Endif

#PHVEN - 2017-09-13 - Issue xxx - START
   #If([M:HREXE0]EXRTEP = "SKILL_DEV" | [M:HREXE0]EXRTEP = "EMP_STRUC")
   #  Gosub BEEWEBSERV From BEEWEB
   #Endif
#PHVEN - 2017-09-13 - Issue xxx - END

#JASMI - 2016-10-05 - Issue xxx - START
#  Call FERME_TRACE From LECFIC
  If !GSERVEUR
   Call FERME_TRACE From LECFIC
  Endif
#JASMI - 2016-10-05 - Issue xxx - END

Return

#JASMI - 2017-09-13 - X3-49526 - START
$DELETE_TRT
 Onerrgo $DISPLAYERROR
  Call DELTRT(("W"+[M:HREXE0]EXRSRCNAM+GUSER),nomap) From SUBADC

Return

#=============================================================================
$CREATE_TRT
 Onerrgo $DISPLAYERROR
Local Char    TABLE_COUNT_CHAR(1), FICSRC(250)
Local Integer TABLE_COUNTER, DATA_LEVEL, TABLE_IDX

#populate table abbreviations
#JASMI - 2017-02-07 - SA TYE 2017 - START
#  If clalev([F:ATB])=0        : Local File ATABLE           [ATB]    : Endif
  If clalev([F:AVWT])=0        : Local File AVIEWTAB           [AVWT]    : Endif
#JASMI - 2017-02-07 - SA TYE 2017 - END
  For nolign=1 To [M:HREXE1]DTANBR
    Read [F:AVWT]CODFIC = [M:HREXE1]DTATBL(nolign-1)
    If !fstat
      [L]TABLE_COUNT_CHAR="" : [L]TABLE_COUNTER=0
      If nolign>1
        For [L]TABLE_IDX=0 To (nolign-1-1)
          If [M:HREXE1]DTATBL(nolign-1)=[M:HREXE1]DTATBL([L]TABLE_IDX)
            [L]TABLE_COUNT_CHAR=num$(val([L]TABLE_COUNT_CHAR)+1)
            [L]TABLE_COUNTER+=1
          Endif
        Next
      Endif
      [M:HREXE1]DTATBLABR(nolign-1)=[F:AVWT]ABRFIC+[L]TABLE_COUNT_CHAR
      [M:HREXE1]DTAORGABR(nolign-1)=""
      If [L]TABLE_COUNT_CHAR<>""
        [M:HREXE1]DTAORGABR(nolign-1)=[F:AVWT]ABRFIC
      Endif
    Else
      GOK=0 : Call FSTA("AVWT") From GLOCK : Return
    Endif
  Next nolign

#get filename
  FICSRC = filpath("TRT",("W"+[M:HREXE0]EXRSRCNAM+GUSER),"src",nomap)

#open source file
  Openo FICSRC,0
  adxifs = ""
  adxirs = chr$(10)

#write creation details
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# Date :'-format$("DD4",date$)

#write action for open statements for data sources specified
  Wrseq ''
  Wrseq '$OPEN_TEMPLATE_TABLES'

  For nolign=1 To [M:HREXE1]DTANBR
    Wrseq '  If clalev([F:'+[M:HREXE1]DTATBLABR(nolign-1)+'])=0 : Local File '+[M:HREXE1]DTATBL(nolign-1)+' ['+[M:HREXE1]DTATBLABR(nolign-1)+'] : Endif'
  Next nolign

  Wrseq ''
  Wrseq 'Return'

#write action for header link statements for data sources specified
  Wrseq ''
  Wrseq '$LINK_HEADER'

  [L]DATA_LEVEL=1
  Gosub WRITE_LINK_ACTIONS

  Wrseq ''
  Wrseq 'Return'

#write action for detail link statements for data sources specified
  Wrseq ''
  Wrseq '$LINK_DETAIL'

  [L]DATA_LEVEL=2
  Gosub WRITE_LINK_ACTIONS

  Wrseq ''
  Wrseq 'Return'

#close file
  Openo

Return

$WRITE_LINK_ACTIONS
 Onerrgo $DISPLAYERROR
#JASMI - 2017-11-06 - X3-62958 - START
#Local Char    TEMP_VAL(250), TRAILING_CHAR(1)
Local Char    TRAILING_CHAR(1)
#JASMI - 2017-11-06 - X3-62958 - END
Local Integer TABLE_COUNTER, TABLE_COUNTER2, FIELD_SPEC_START, FIELD_SPEC_END

#get table count for level
  [L]TABLE_COUNTER2=0
  For nolign=1 To [M:HREXE1]DTANBR
    If [M:HREXE1]DTALVL(nolign-1)=[L]DATA_LEVEL
      [L]TABLE_COUNTER2+=1
    Endif
  Next nolign

  If [L]TABLE_COUNTER2<2
    Call ECR_TRACE(mess(44, 11662, 1), 0) From GESECRAN
    Return
  Endif

#write link statement
  [L]TABLE_COUNTER=0
  For nolign=1 To [M:HREXE1]DTANBR
    If [M:HREXE1]DTALVL(nolign-1)=[L]DATA_LEVEL
      [L]TABLE_COUNTER+=1
      If [L]TABLE_COUNTER=[L]TABLE_COUNTER2
        [L]TRAILING_CHAR=''
      Else
        [L]TRAILING_CHAR=','
      Endif
      If [L]TABLE_COUNTER=1
        If [L]TABLE_COUNTER2=1
          Wrseq '  Filter ['+[M:HREXE1]DTATBLABR(nolign-1)+']'
        Else
          Wrseq '  Link ['+[M:HREXE1]DTATBLABR(nolign-1)+']'
        Endif
      Else
        If [L]TABLE_COUNTER=2
          If [M:HREXE1]DTAORGABR(nolign-1)=""
            Wrseq '&   With '+[M:HREXE1]DTALNKCLC(nolign-1)+[L]TRAILING_CHAR
          Else
            [L]FIELD_SPEC_START=instr(1,[M:HREXE1]DTALNKCLC(nolign-1),[M:HREXE1]DTAORGABR(nolign-1)+"]")
            [L]FIELD_SPEC_END=len([M:HREXE1]DTALNKCLC(nolign-1))-[L]FIELD_SPEC_START+len([M:HREXE1]DTAORGABR(nolign-1))
            [L]TEMP_VAL=left$([M:HREXE1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START-1)+
&                       [M:HREXE1]DTATBLABR(nolign-1)+"]"+
&                       mid$([M:HREXE1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START+len([M:HREXE1]DTAORGABR(nolign-1))+1,[L]FIELD_SPEC_END)
            Wrseq '&   With '+[L]TEMP_VAL+[L]TRAILING_CHAR
          Endif
        Else
          If [M:HREXE1]DTAORGABR(nolign-1)=""
            Wrseq '&        '+[M:HREXE1]DTALNKCLC(nolign-1)+[L]TRAILING_CHAR
          Else
            [L]FIELD_SPEC_START=instr(1,[M:HREXE1]DTALNKCLC(nolign-1),[M:HREXE1]DTAORGABR(nolign-1)+"]")
            [L]FIELD_SPEC_END=len([M:HREXE1]DTALNKCLC(nolign-1))-[L]FIELD_SPEC_START+len([M:HREXE1]DTAORGABR(nolign-1))
            [L]TEMP_VAL=left$([M:HREXE1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START-1)+
&                       [M:HREXE1]DTATBLABR(nolign-1)+"]"+
&                       mid$([M:HREXE1]DTALNKCLC(nolign-1),[L]FIELD_SPEC_START+len([M:HREXE1]DTAORGABR(nolign-1))+1,[L]FIELD_SPEC_END)
            Wrseq '&        '+[L]TEMP_VAL+[L]TRAILING_CHAR
          Endif
        Endif
      Endif
    Endif
  Next nolign
  If [L]DATA_LEVEL=1
    Wrseq '&   As    [LNKH]'
  Else
    Wrseq '&   As    [LNKD]'
  Endif
  Wrseq '&   Where evalue([L]CRITERIA(1)+[L]CRITERIA(2)+[L]CRITERIA(3)+[L]CRITERIA(4))'
  For nolign=1 To [M:HREXE3]GRPNBR
    If [M:HREXE3]GRPDTALVL(nolign-1)=[L]DATA_LEVEL
      Wrseq '&   Order By '+[M:HREXE3]GRPORD(nolign-1)
    Endif
  Next nolign

Return

#=============================================================================
$COMPILE_TRT
 Onerrgo $DISPLAYERROR
  If dim(OK)<0 : Local Integer OK : Endif

  Call VALID("TRT",("W"+[M:HREXE0]EXRSRCNAM+GUSER),nomap,OK) From VALMSKSUB
  If OK=0
    Call ECR_TRACE(mess(166,9137,1)-("W"+[M:HREXE0]EXRSRCNAM+GUSER), 0) From GESECRAN
  Endif

Return
#JASMI - 2017-09-13 - X3-49526 - END

$OPEN_TEMPLATE_TABLES
 Onerrgo $DISPLAYERROR
#JASMI - 2017-09-13 - X3-49526 - START
#  Gosub OPEN_TEMPLATE_TABLES From ="W"+[M:HREXE0]EXRSRCNAM
  Gosub OPEN_TEMPLATE_TABLES From =("W"+[M:HREXE0]EXRSRCNAM+GUSER)
#JASMI - 2017-09-13 - X3-49526 - END

Return

$TR1
  [L]RUN_DATE=date$
  [L]RUN_TIME=num$(time$)
  For [L]DATA_LEVEL=1 To 2
    [L]GROUP_VALUE([L]DATA_LEVEL)=""
  Next [L]DATA_LEVEL
  For [L]TABLE_COUNT=0 To [M:HREXE1]DTANBR-1
    If [M:HREXE1]DTALVL([L]TABLE_COUNT)=1
      [L]DATA_LEVEL=1
      Break
    Endif
  Next [L]TABLE_COUNT
  If [L]DATA_LEVEL=1
    Gosub BUILD_WHERE_CLAUSE
    Gosub CONSTRUCT_LINK
    Gosub LOOP_RECORDS
    [L]DATA_LEVEL=1
    If !OK : Return : Endif
  Endif

Return

$TR2
 Onerrgo $DISPLAYERROR
  If [L]LEVEL_RECORD_COUNT(1) > 0 | [L]LEVEL_RECORD_COUNT(2) > 0
    If [M:HREXE0]EXRVLYOLY<>2
      If [L]ERROR_COUNT=0
        Commit
        Gosub WRITE_EXTRACT_AND_PRINT_REPORT
        Return
      Else
#JASMI - 2017-09-13 - X3-49526 - START
#        If [M:HREXE0]EXRLIVIND=1
#JASMI - 2017-09-13 - X3-49526 - END
          YESNO = 2
          Call OUINON("Would you like to create the extract file despite of the errors?", YESNO) From GESECRAN
          If YESNO = 2
            Commit
            Gosub WRITE_EXTRACT_AND_PRINT_REPORT
            Return
          Endif
#JASMI - 2017-09-13 - X3-49526 - START
#        Else
#          Call ECR_TRACE("", 0) From GESECRAN
#          Call ECR_TRACE("Extract aborted because of the error(s) above.", 0) From GESECRAN
#          OK = 0
#        Endif
#JASMI - 2017-09-13 - X3-49526 - END
      Endif
    Endif
  Endif
  Rollback

Return

$WRITE_EXTRACT_AND_PRINT_REPORT
 Onerrgo $DISPLAYERROR
  Gosub OPEN_EXTRACT_FILE
  Gosub WRITE_TO_EXTRACT_FILE
  Gosub CLOSE_EXTRACT_FILE
  If [M:HREXE0]EXRPRNRPT<>""&[M:HREXE0]EXRPRNFLG=2
    Gosub PRINT_REPORT
  Endif

Return

$BUILD_WHERE_CLAUSE
 Onerrgo $DISPLAYERROR
  [L]CRITERIA(1)="1=1"

  For [L]CRITERIA_COUNT= 2 To 4
    [L]CRITERIA([L]CRITERIA_COUNT) = ""
  Next [L]CRITERIA_COUNT

  [L]CRITERIA_COUNT = 1

#  If [L]DATA_LEVEL=2
#    For nolign=1 To [M:HREXE3]GRPNBR
#      If [M:HREXE3]GRPDTALVL(nolign-1)=1
#        [L]FIELD_SPEC_START=instr(1,[M:HREXE3]GRPDTACLC(nolign-1),"]")
#        [L]FIELD_SPEC_END=len([M:HREXE3]GRPDTACLC(nolign-1))-[L]FIELD_SPEC_START
#        [L]TEMP_VAL=left$([M:HREXE3]GRPDTACLC(nolign-1),[L]FIELD_SPEC_START-1)+
#&                   "1]"+
#&                   mid$([M:HREXE3]GRPDTACLC(nolign-1),[L]FIELD_SPEC_START+1,[L]FIELD_SPEC_END)
#        [L]CRITERIA([L]CRITERIA_COUNT)+="&"+[L]TEMP_VAL+"='"+GROUP_VALUE(1)+"'"
#      Endif
#    Next nolign
#  Endif

  For nolign=1 To [M:HREXE1]FLTNBR
    If [M:HREXE1]FLTDTALVL(nolign-1) = [L]DATA_LEVEL
      If [M:HREXE1]FLTDTACLC1(nolign-1)<>""
        [L]CRITERIA([L]CRITERIA_COUNT) += '&('
        If len([L]CRITERIA([L]CRITERIA_COUNT)) + len([M:HREXE1]FLTDTACLC1(nolign-1)) > 250
          [L]CRITERIA_COUNT += 1
        Endif
        [L]CRITERIA([L]CRITERIA_COUNT) += [M:HREXE1]FLTDTACLC1(nolign-1)
        If [M:HREXE1]FLTDTACLC2(nolign-1)<>""
          If len([L]CRITERIA([L]CRITERIA_COUNT)) + len(" or " + [M:HREXE1]FLTDTACLC2(nolign-1)) > 250
            [L]CRITERIA_COUNT += 1
          Endif
          [L]CRITERIA([L]CRITERIA_COUNT) += " or " + [M:HREXE1]FLTDTACLC2(nolign-1)
          If [M:HREXE1]FLTDTACLC3(nolign-1)<>""
            If len([L]CRITERIA([L]CRITERIA_COUNT)) + len(" or " + [M:HREXE1]FLTDTACLC3(nolign-1)) > 250
              [L]CRITERIA_COUNT += 1
            Endif
            [L]CRITERIA([L]CRITERIA_COUNT) += " or " + [M:HREXE1]FLTDTACLC3(nolign-1)
          Endif
        Endif
        [L]CRITERIA([L]CRITERIA_COUNT) += ')'
      Endif
    Endif
  Next nolign

#build defined parameters into where clause
  For nolign=1 To [M:HREXE2]PARNBR
    If [M:HREXE2]PARDTALVL(nolign-1) = [L]DATA_LEVEL
      If [M:HREXE2]PARVALDEB(nolign-1)<>""
        If [M:HREXE2]PARDTACLC(nolign-1)<>""
#          [L]TEMP_VAL=[M:HREXE2]PARVALDEB(nolign-1)
#          [L]TEMP_VAL2=[M:HREXE2]PARVALFIN(nolign-1)
          [L]TEMP_VAL=[M:HREXE2]VALINT1(nolign-1)
          [L]TEMP_VAL2=[M:HREXE2]VALINT2(nolign-1)

          Case [M:HREXE2]PARINTTYP(nolign-1)
            When "1","2","3","4","5","6" #numbers
              [L]OPEN_FIELD_VALUE = "" : [L]CLOSE_FIELD_VALUE = ""
            When "8", "12" #dates
              [L]OPEN_FIELD_VALUE = "["
              [L]CLOSE_FIELD_VALUE = "]"
#              [L]TEMP_VAL=mid$([M:HREXE2]PARVALDEB(nolign-1),4,2)+"/"+
#&                         left$([M:HREXE2]PARVALDEB(nolign-1),2)+"/"+
#&                         mid$([M:HREXE2]PARVALDEB(nolign-1),7,4)
#              If [M:HREXE2]PARVALFIN(nolign-1)<>""
#                [L]TEMP_VAL2=mid$([M:HREXE2]PARVALFIN(nolign-1),4,2)+"/"+
#&                            left$([M:HREXE2]PARVALFIN(nolign-1),2)+"/"+
#&                            mid$([M:HREXE2]PARVALFIN(nolign-1),7,4)
#              Endif
              [L]TEMP_VAL=num$(gdat$([M:HREXE2]VALINT1(nolign-1)))
              If [M:HREXE2]VALINT2(nolign-1)<>""
                [L]TEMP_VAL2=num$(gdat$([M:HREXE2]VALINT2(nolign-1)))
              Endif
            When Default #alpha
              [L]OPEN_FIELD_VALUE = "'" : [L]CLOSE_FIELD_VALUE = "'"
          Endcase
          Case [M:HREXE2]PARVALTYP(nolign-1)
          When 2
          #range value parameter
          #start value
            If len([L]CRITERIA([L]CRITERIA_COUNT))+len("&"+[M:HREXE2]PARDTACLC(nolign-1)+">="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL+[L]CLOSE_FIELD_VALUE) > 250
              [L]CRITERIA_COUNT += 1
            Endif
            [L]CRITERIA([L]CRITERIA_COUNT) += "&"+[M:HREXE2]PARDTACLC(nolign-1)+">="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL+[L]CLOSE_FIELD_VALUE
          #end value
            If len([L]CRITERIA([L]CRITERIA_COUNT))+len("&"+[M:HREXE2]PARDTACLC(nolign-1)+"<="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL2+[L]CLOSE_FIELD_VALUE) > 250
              [L]CRITERIA_COUNT += 1
            Endif
            [L]CRITERIA([L]CRITERIA_COUNT) += "&"+[M:HREXE2]PARDTACLC(nolign-1)+"<="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL2+[L]CLOSE_FIELD_VALUE
          When Default
          #single value parameter
            If len([L]CRITERIA([L]CRITERIA_COUNT))+len("&"+[M:HREXE2]PARDTACLC(nolign-1)+"="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL+[L]CLOSE_FIELD_VALUE) > 250
              [L]CRITERIA_COUNT += 1
            Endif
            [L]CRITERIA([L]CRITERIA_COUNT) += "&"+[M:HREXE2]PARDTACLC(nolign-1)+"="+[L]OPEN_FIELD_VALUE+[L]TEMP_VAL+[L]CLOSE_FIELD_VALUE
          Endcase
        Endif
      Endif
    Endif
  Next nolign

  If [L]DATA_LEVEL=1
    For nolign=1 To [M:HREXE2]PARNBR
      If [M:HREXE2]PARVALDEB(nolign-1)<>""
        If [M:HREXE2]PARDTACLC(nolign-1)<>""
          Case [M:HREXE2]PARVALTYP(nolign-1)
          When 2
            Call ECR_TRACE([M:HREXE2]PARTIT(nolign-1)+ ": "+[M:HREXE2]PARVALDEB(nolign-1)+" - "+[M:HREXE2]PARVALFIN(nolign-1), 0) From GESECRAN
          When Default
            Call ECR_TRACE([M:HREXE2]PARTIT(nolign-1)+ ": "+[M:HREXE2]PARVALDEB(nolign-1), 0) From GESECRAN
          Endcase
        Endif
      Endif
    Next nolign
    Call ECR_TRACE(string$(100, "-"), 0) From GESECRAN
  Endif
#Infbox num$([L]CRITERIA(1)) + " " + num$([L]CRITERIA(2)) + " " + num$([L]CRITERIA(3)) + " " + num$([L]CRITERIA(4))
Return

$CONSTRUCT_LINK
 Onerrgo $DISPLAYERROR
  If [L]DATA_LEVEL=1
#JASMI - 2017-09-13 - X3-49526 - START
#    Gosub LINK_HEADER From ="W"+[M:HREXE0]EXRSRCNAM
    Gosub LINK_HEADER From =("W"+[M:HREXE0]EXRSRCNAM+GUSER)
#JASMI - 2017-09-13 - X3-49526 - END
  Else
#JASMI - 2017-09-13 - X3-49526 - START
#    Gosub LINK_DETAIL From ="W"+[M:HREXE0]EXRSRCNAM
    Gosub LINK_DETAIL From =("W"+[M:HREXE0]EXRSRCNAM+GUSER)
#JASMI - 2017-09-13 - X3-49526 - END
  Endif

Return

$LOOP_RECORDS
 Onerrgo $DISPLAYERROR
  [L]LEVEL_RECORD_COUNT([L]DATA_LEVEL)=0

  [L]HEADER_RECORD_COUNT=0
  [L]DETAIL_RECORD_COUNT=0
  [L]DETAIL_RECORD_COUNT_PER_GROUPING=0
  [L]HEADER_FIELD_COUNT=0
  [L]DETAIL_FIELD_COUNT=0
  [L]HEADER_FIELD_COUNT_PER_GROUPING=0
  [L]DETAIL_FIELD_COUNT_PER_GROUPING=0

  If [L]DATA_LEVEL=1
    For [LNKH]
      Gosub PROCESS_RECORD
    #JASMI - 2016-10-05 - Issue xxx - START
      If !OK : Return : Endif
    #JASMI - 2016-10-05 - Issue xxx - END
    Next
  Else
    For [LNKD]
      Gosub PROCESS_RECORD
    #JASMI - 2016-10-05 - Issue xxx - START
      If !OK : Return : Endif
    #JASMI - 2016-10-05 - Issue xxx - END
    Next
  Endif

  Gosub FINAL_RECORD
#JASMI - 2016-10-05 - Issue xxx - START
  If !OK : Return : Endif
#JASMI - 2016-10-05 - Issue xxx - END

Return

$PROCESS_RECORD
 Onerrgo $DISPLAYERROR
  [L]LEVEL_RECORD_COUNT([L]DATA_LEVEL)+=1

  For nolign=1 To [M:HREXE3]GRPNBR
    If [M:HREXE3]GRPDTALVL(nolign-1)=[L]DATA_LEVEL
      [L]TEMP_GROUP_VALUE([L]DATA_LEVEL)=num$(evalue([M:HREXE3]GRPDTACLC(nolign-1)))
    Endif
  Next nolign

  If [L]GROUP_VALUE([L]DATA_LEVEL)=""
    [L]GROUP_VALUE([L]DATA_LEVEL)=[L]TEMP_GROUP_VALUE([L]DATA_LEVEL)
  Endif

  If [L]GROUP_VALUE([L]DATA_LEVEL)<>[L]TEMP_GROUP_VALUE([L]DATA_LEVEL)
    Gosub VALIDATE_VALUES
    If !OK : Return : Endif

    Gosub CLEAR_PREVIOUS_TEST_DATA
    If !OK : Return : Endif
    If [M:HREXE0]EXRCLEPRE=2 and [M:HREXE0]EXRLIVIND=2
      Gosub CLEAR_PREVIOUS_DATA
    Endif

    Case [L]DATA_LEVEL
      When 1
        [L]HEADER_RECORD_COUNT+=1
      When 2
        [L]DETAIL_RECORD_COUNT_PER_GROUPING+=1
        [L]DETAIL_RECORD_COUNT+=1
    Endcase

    If [M:HREXE0]EXRVLYOLY<>2
      Gosub WRITE_RESULTS
      If !OK : Return : Endif
    Endif

    If [L]DATA_LEVEL=1
      Gosub GET_DETAIL_LINES
      If !OK : Return : Endif
      Gosub GET_TOTAL_LINES
      If !OK : Return : Endif

      [L]HEADER_FIELD_COUNT_PER_GROUPING=0
      [L]DETAIL_FIELD_COUNT_PER_GROUPING=0
      [L]DETAIL_RECORD_COUNT_PER_GROUPING=0
    Endif

    [L]GROUP_VALUE([L]DATA_LEVEL)=[L]TEMP_GROUP_VALUE([L]DATA_LEVEL)

    Gosub CLEAR_GRID_VALUES
  Endif

  If [L]GROUP_VALUE([L]DATA_LEVEL)=[L]TEMP_GROUP_VALUE([L]DATA_LEVEL)
    Gosub POPULATE_VALUES
    If !OK : Return : Endif
  Endif

Return

$VALIDATE_VALUES
 Onerrgo $DISPLAYERROR
  [L]CALLED_FROM=mess(29,11662,1)
  For nolign=1 To [M:HREXE4]VLYNBR
    If [M:HREXE4]VLYDTALVL(nolign-1) = [L]DATA_LEVEL
    #get exctract field names from validation conditions and replace field values in condition i.e. '~~<Extract Field Code>'
      [L]TEMP_VAL=[M:HREXE4]VLYCDN1(nolign-1)
      Gosub EXTRACT_VALUE
      If parse(ctrans([L]TEMP_VAL,'"',''))<>0
      #JASMI - 2016-10-05 - Issue xxx - START
#        Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1), 0) From GESECRAN
#        OK = 0
#        Return
        Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+' - '+[L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        [L]ERROR_COUNT+=1
        Break
      #JASMI - 2016-10-05 - Issue xxx - END
      Endif
     #check validation condition and display error if failed or set field value
      If evalue(ctrans([L]TEMP_VAL,'"','')) = 1
        If [M:HREXE4]VLYTYP(nolign-1)=1
          Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+': '+evalue(ctrans([M:HREXE4]VLYMSG(nolign-1),'"','')), 0) From GESECRAN
          If [M:HREXE4]VLYOPT(nolign-1)<>2
            [L]ERROR_COUNT+=1
          Endif
        Else
          If find([M:HREXE4]VLYSETFLD(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))>0
            [L]TEMP_VAL=[M:HREXE4]VLYVALCLC(nolign-1)
            Gosub EXTRACT_VALUE
            If parse(ctrans([L]TEMP_VAL,'"',''))<>0
            #JASMI - 2016-10-05 - Issue xxx - START
#              Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1), 0) From GESECRAN
#              OK = 0
#              Return
              Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+' - '+[L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
              [L]ERROR_COUNT+=1
              Break
            #JASMI - 2016-10-05 - Issue xxx - END
            Else
              [M:HREXE3]DFNVAL(find([M:HREXE4]VLYSETFLD(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
            Endif
          Else
            Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': "'+[M:HREXE4]VLYSETFLD(nolign-1)+'" - '+mess(63,75,1), 0) From GESECRAN
            OK = 0
            Return
          Endif
        Endif
      Endif
    Endif
  Next nolign

Return

$EXTRACT_VALUE
 Onerrgo $DISPLAYERROR
  While instr(0, [L]TEMP_VAL, "'~~") > 0
    [L]FIELD_SPEC_START = instr(0, [L]TEMP_VAL, "'~~")
    If instr([L]FIELD_SPEC_START+1, [L]TEMP_VAL, "'") = 0
    #JASMI - 2016-10-05 - Issue xxx - START
#      Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1), 0) From GESECRAN
      Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
    #JASMI - 2016-10-05 - Issue xxx - END
      OK = 0
      Return
    Endif
    [L]FIELD_SPEC_END = instr([L]FIELD_SPEC_START+1, [L]TEMP_VAL, "'")
    [L]CALC_CHAR=mid$([L]TEMP_VAL, [L]FIELD_SPEC_START+3, [L]FIELD_SPEC_END-[L]FIELD_SPEC_START-3)
    Case [L]CALC_CHAR
    When "TOTAL_HEADER_RECORDS"
      [L]CALC_CHAR=num$(HEADER_RECORD_COUNT)
    When "TOTAL_DETAIL_RECORDS"
      [L]CALC_CHAR=num$(DETAIL_RECORD_COUNT)
    When "GROUP_DETAIL_RECORDS"
      [L]CALC_CHAR=num$(DETAIL_RECORD_COUNT_PER_GROUPING)
    When "TOTAL_HEADER_FIELDS"
      [L]CALC_CHAR=num$(HEADER_FIELD_COUNT)
    When "TOTAL_DETAIL_FIELDS"
      [L]CALC_CHAR=num$(DETAIL_FIELD_COUNT)
    When "GROUP_HEADER_FIELDS"
      [L]CALC_CHAR=num$(HEADER_FIELD_COUNT_PER_GROUPING)
    When "GROUP_DETAIL_FIELDS"
      [L]CALC_CHAR=num$(DETAIL_FIELD_COUNT_PER_GROUPING)
    When Default
      If find([L]CALC_CHAR,[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1)) = 0
        Call ECR_TRACE([L]CALLED_FROM+' '+num$(nolign)+': "'+[L]CALC_CHAR+'" - '+mess(63,75,1), 0) From GESECRAN
        OK = 0
        Return
      Endif
      [L]CALC_CHAR=[M:HREXE3]DFNVAL(find([L]CALC_CHAR,[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)
    Endcase
    [L]TEMP_VAL= left$([L]TEMP_VAL, [L]FIELD_SPEC_START-1)+
&             "'"+
&             [L]CALC_CHAR+
&             "'"+
&             right$([L]TEMP_VAL, [L]FIELD_SPEC_END+1)
  Wend

Return

$CLEAR_PREVIOUS_TEST_DATA
 Onerrgo $DISPLAYERROR
  If [L]DATA_LEVEL=1
    Delete [HREXR] Where  [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
&                         [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1) &
&                         [F:HREXR]RESLIVIND=1
    If fstat=1 | fstat>5
      GOK=0 : Call RSTA("HREXR",[M:HREXE0]EXRTEP-[L]GROUP_VALUE(1)) From GLOCK : Return
      Call ECR_TRACE(mess(34,11662,1), 0) From GESECRAN
      OK = 0
    Endif
  Endif

Return

$CLEAR_PREVIOUS_DATA
 Onerrgo $DISPLAYERROR
  If [L]DATA_LEVEL=1
  #prompts
    Filter [F:HREXR] Where  [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
&                           [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1) &
&                           [F:HREXR]RESLIVIND=2
    For [F:HREXR]HREXR0
      If [M:HREXE0]EXRBLODUP=2
        Call ECR_TRACE("", 0) From GESECRAN
        Call ECR_TRACE("Extract aborted because a duplicate live run was detected.", 0) From GESECRAN
        OK = 0
        Return
      Endif
      YESNO = 2
      Call OUINON("Live data already exists for this extract. Existing data will be overwritten. Continue?", YESNO) From GESECRAN
      If YESNO = 1
        Call ECR_TRACE("Process cancelled by user.", 0) From GESECRAN
        OK = 0
        Return
      Endif
      Break
    Next
#    Delete [HREXR] Where  [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
#&                         [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1) &
#&                         [F:HREXR]RESDETVAL=""
    Delete [HREXR] Where  [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
&                         [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1)
    If fstat=1 | fstat>5
      GOK=0 : Call RSTA("HREXR",[M:HREXE0]EXRTEP-[L]GROUP_VALUE(1)) From GLOCK : Return
      Call ECR_TRACE(mess(34,11662,1), 0) From GESECRAN
      OK = 0
    Endif
#  Else
#    Delete [HREXR] Where  [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
#&                         [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1) &
#&                         [F:HREXR]RESDETVAL=[L]GROUP_VALUE(2)
#    If fstat=1 | fstat>5
#      GOK=0 : Call RSTA("HREXR",[M:HREXE0]EXRTEP-[L]GROUP_VALUE(1)) From GLOCK : Return
#      Call ECR_TRACE(mess(34,11662,1), 0) From GESECRAN
#      OK = 0
#    Endif
  Endif

Return

$WRITE_RESULTS
 Onerrgo $DISPLAYERROR
  For nolign=1 To [M:HREXE3]DFNNBR
    If [M:HREXE3]DFNDTALVL(nolign-1) = [L]DATA_LEVEL
#JASMI - 2017-04-21 - SAM 122279 - START
#      [L]TEMP_VAL2=""
      [L]TEMP_VAL2="~skip~"
#JASMI - 2017-04-21 - SAM 122279 - END
#JASMI - 2016-05-26 - REQ 116689 - START
#      If [M:HREXE3]DFNTYP(nolign-1)="A"
#        If ([M:HREXE3]DFNMDT(nolign-1)=2) or
#&          ([M:HREXE3]DFNMDT(nolign-1)=1 and [M:HREXE3]DFNVAL(nolign-1)<>"") or
#&          ([M:HREXE3]DFNEXREMT(nolign-1)=2 and [M:HREXE3]DFNVAL(nolign-1)="")
#          [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [M:HREXE0]EXRFLDQLF + [M:HREXE3]DFNVAL(nolign-1) + [M:HREXE0]EXRFLDQLF
#        Endif
#      Else
#        If ([M:HREXE3]DFNMDT(nolign-1)=2) or
#&          ([M:HREXE3]DFNMDT(nolign-1)=1 and val([M:HREXE3]DFNVAL(nolign-1))<>0) or
#&          ([M:HREXE3]DFNEXREMT(nolign-1)=2 and val([M:HREXE3]DFNVAL(nolign-1))=0)
#          [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [M:HREXE3]DFNVAL(nolign-1)
#        Endif
#      Endif
      If [M:HREXE3]DFNTYP(nolign-1)="A"
        If ([M:HREXE3]DFNMDT(nolign-1)=2) or
&          ([M:HREXE3]DFNMDT(nolign-1)=1 and [M:HREXE3]DFNVAL(nolign-1)<>"") or
&          ([M:HREXE3]DFNEXREMT(nolign-1)=2 and [M:HREXE3]DFNVAL(nolign-1)="")
          If [M:HREXE0]EXRFXDLNG=2 #fixed lenth
            [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [M:HREXE0]EXRFLDQLF + evalue('format$("K:'+num$([M:HREXE3]DFNLNG(nolign-1))+'X","'+[M:HREXE3]DFNVAL(nolign-1)+'")') + [M:HREXE0]EXRFLDQLF
          Else
            [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [M:HREXE0]EXRFLDQLF + [M:HREXE3]DFNVAL(nolign-1) + [M:HREXE0]EXRFLDQLF
          Endif
        Endif
      Else
        If ([M:HREXE3]DFNMDT(nolign-1)=2) or
&          ([M:HREXE3]DFNMDT(nolign-1)=1 and val([M:HREXE3]DFNVAL(nolign-1))<>0) or
&          ([M:HREXE3]DFNEXREMT(nolign-1)=2 and val([M:HREXE3]DFNVAL(nolign-1))=0)
          If val([M:HREXE3]DFNVAL(nolign-1))<0
            [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [L]BEFORE_SIGN_NEG
&                        + evalue('format$("N'+[L]PAD_NUM+':'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(abs(val([M:HREXE3]DFNVAL(nolign-1))))+')')
&                        + [L]AFTER_SIGN_NEG
          Else
            If [M:HREXE0]EXRCDTSYM=""
              If [M:HREXE0]EXRSYMPOS=3
                [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1)
&                            + evalue('format$("N'+[L]PAD_NUM+':'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(abs(val([M:HREXE3]DFNVAL(nolign-1))))+')')
&                            + " "
              Else
                [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + " "
&                            + evalue('format$("N'+[L]PAD_NUM+':'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(abs(val([M:HREXE3]DFNVAL(nolign-1))))+')')
              Endif
            Else
              [L]TEMP_VAL2 = [M:HREXE3]DFNFXDTXT(nolign-1) + [L]BEFORE_SIGN_POS
&                          + evalue('format$("N'+[L]PAD_NUM+':'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(abs(val([M:HREXE3]DFNVAL(nolign-1))))+')')
&                          + [L]AFTER_SIGN_POS
            Endif
          Endif
          If [M:HREXE0]EXRFXDLNG<>2
            [L]TEMP_VAL2=vireblc([L]TEMP_VAL2,4)
          Endif
        Endif
      Endif
#JASMI - 2016-05-26 - REQ 116689 - END
      If [M:HREXE3]DFNEXUFLD(nolign-1)<>""
        [L]TEMP_VAL=[M:HREXE3]DFNEXUFLD(nolign-1)
        Gosub EXTRACT_VALUE
        If parse(ctrans([L]TEMP_VAL,'"',''))<>0
        #JASMI - 2016-10-05 - Issue xxx - START
#          Call ECR_TRACE(mess(30,11662,1)+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1), 0) From GESECRAN
          Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+' - '+mess(30,11662,1)+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        #JASMI - 2016-10-05 - Issue xxx - END
          OK = 0
          Return
        Endif
       #check validation condition and display error if failed or set field value
        If evalue(ctrans([L]TEMP_VAL,'"','')) = 1
    #JASMI - 2017-04-21 - SAM 122279 - START
    #      [L]TEMP_VAL2=""
          [L]TEMP_VAL2="~skip~"
    #JASMI - 2017-04-21 - SAM 122279 - END
        Endif
      Endif
#JASMI - 2017-04-21 - SAM 122279 - START
#      If [L]TEMP_VAL2<>""
      If [L]TEMP_VAL2<>"~skip~"
#JASMI - 2017-04-21 - SAM 122279 - END
      #calculate totals
        Gosub CALCULATE_TOTALS
        Raz [F:HREXR]
        [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP
        [F:HREXR]RESRUNDAT=[L]RUN_DATE
        [F:HREXR]RESRUNTIM=[L]RUN_TIME
        [F:HREXR]RESLIVIND = [M:HREXE0]EXRLIVIND
        [F:HREXR]RESHEAVAL=[L]GROUP_VALUE(1)
        [F:HREXR]RESDETVAL=""
        If [L]DATA_LEVEL=2
          [F:HREXR]RESDETVAL=[L]GROUP_VALUE(2)
        Endif
        [F:HREXR]RESDTALVL=[L]DATA_LEVEL
        [F:HREXR]RESNBR=nolign
        [F:HREXR]RESDFNCOD=[M:HREXE3]DFNCOD(nolign-1)
        [F:HREXR]RESVAL=[M:HREXE3]DFNVAL(nolign-1)
        [F:HREXR]RESEXRVAL=[L]TEMP_VAL2
#JASMI - 2016-05-26 - REQ 116689 - START
        [F:HREXR]RESNEWLIG=[M:HREXE3]DFNNEWLIG(nolign-1)
#JASMI - 2016-05-26 - REQ 116689 - END
        Write [F:HREXR]
        If fstat
          GOK=0 : Call FSTA("HREXR") From GLOCK : Break
          Call ECR_TRACE(mess(33,11662,1), 0) From GESECRAN
          OK = 0
        Endif
        Case [L]DATA_LEVEL
          When 1
            [L]HEADER_FIELD_COUNT+=1
            [L]HEADER_FIELD_COUNT_PER_GROUPING+=1
          When 2
            [L]DETAIL_FIELD_COUNT+=1
            [L]DETAIL_FIELD_COUNT_PER_GROUPING+=1
        Endcase
      Endif
    Endif
  Next nolign

Return

$CALCULATE_TOTALS
 Onerrgo $DISPLAYERROR
  If [M:HREXE3]DFNTOTFLD1(nolign-1)<>"" & [M:HREXE3]DFNTOTCLC1(nolign-1)<>""
      If find([M:HREXE3]DFNTOTFLD1(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))>0
        [L]TEMP_VAL=[M:HREXE3]DFNTOTCLC1(nolign-1)
        Gosub EXTRACT_VALUE
        If parse(ctrans([L]TEMP_VAL,'"',''))<>0
        #JASMI - 2016-10-05 - Issue xxx - START
#          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1), 0) From GESECRAN
          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        #JASMI - 2016-10-05 - Issue xxx - END
          OK = 0 : Return
        Else
          [M:HREXE3]DFNVALCLC(find([M:HREXE3]DFNTOTFLD1(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
          [M:HREXE3]DFNVAL(find([M:HREXE3]DFNTOTFLD1(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
        Endif
      Else
        Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': "'+[M:HREXE3]DFNTOTFLD1(nolign-1)+'" - '+mess(63,75,1), 0) From GESECRAN
        OK = 0 : Return
      Endif
  Endif

  If [M:HREXE3]DFNTOTFLD2(nolign-1)<>"" & [M:HREXE3]DFNTOTCLC2(nolign-1)<>""
      If find([M:HREXE3]DFNTOTFLD2(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))>0
        [L]TEMP_VAL=[M:HREXE3]DFNTOTCLC2(nolign-1)
        Gosub EXTRACT_VALUE
        If parse(ctrans([L]TEMP_VAL,'"',''))<>0
        #JASMI - 2016-10-05 - Issue xxx - START
#          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1), 0) From GESECRAN
          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        #JASMI - 2016-10-05 - Issue xxx - END
          OK = 0 : Return
        Else
          [M:HREXE3]DFNVALCLC(find([M:HREXE3]DFNTOTFLD2(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
          [M:HREXE3]DFNVAL(find([M:HREXE3]DFNTOTFLD2(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
        Endif
      Else
        Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': "'+[M:HREXE3]DFNTOTFLD2(nolign-1)+'" - '+mess(63,75,1), 0) From GESECRAN
        OK = 0 : Return
      Endif
  Endif

  If [M:HREXE3]DFNTOTFLD3(nolign-1)<>"" & [M:HREXE3]DFNTOTCLC3(nolign-1)<>""
      If find([M:HREXE3]DFNTOTFLD3(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))>0
        [L]TEMP_VAL=[M:HREXE3]DFNTOTCLC3(nolign-1)
        Gosub EXTRACT_VALUE
        If parse(ctrans([L]TEMP_VAL,'"',''))<>0
        #JASMI - 2016-10-05 - Issue xxx - START
#          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1), 0) From GESECRAN
          Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        #JASMI - 2016-10-05 - Issue xxx - END
          OK = 0 : Return
        Else
          [M:HREXE3]DFNVALCLC(find([M:HREXE3]DFNTOTFLD3(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
          [M:HREXE3]DFNVAL(find([M:HREXE3]DFNTOTFLD3(nolign-1),[M:HREXE3]DFNCOD(0..[M:HREXE3]DFNNBR-1))-1)=num$(evalue([L]TEMP_VAL))
        Endif
      Else
        Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': "'+[M:HREXE3]DFNTOTFLD3(nolign-1)+'" - '+mess(63,75,1), 0) From GESECRAN
        OK = 0 : Return
      Endif
  Endif

Return

$GET_DETAIL_LINES
 Onerrgo $DISPLAYERROR
  For [L]TABLE_COUNT=0 To [M:HREXE1]DTANBR-1
    If [M:HREXE1]DTALVL([L]TABLE_COUNT)=2
      [L]DATA_LEVEL=2
      Break
    Endif
  Next [L]TABLE_COUNT
  If [L]DATA_LEVEL=2
    Gosub BUILD_WHERE_CLAUSE
    Gosub CONSTRUCT_LINK
    Gosub LOOP_RECORDS
    [L]DATA_LEVEL=1
    If !OK : Return : Endif
  Endif

Return

$GET_TOTAL_LINES
 Onerrgo $DISPLAYERROR
  [L]DATA_LEVEL=3
  Gosub POPULATE_VALUES
  If !OK : Return : Endif
  Gosub VALIDATE_VALUES
  If !OK : Return : Endif
  #If [M:HREXE0]EXRVLYOLY<>2
    Gosub WRITE_RESULTS
    If !OK : Return : Endif
  #Endif
  [L]DATA_LEVEL=1

Return

$CLEAR_GRID_VALUES
 Onerrgo $DISPLAYERROR
  If [L]DATA_LEVEL=2
    For nolign=1 To [M:HREXE3]DFNNBR
      If [M:HREXE3]DFNDTALVL(nolign-1)=[L]DATA_LEVEL
        [M:HREXE3]DFNVAL(nolign-1)=""
        [M:HREXE3]DFNNUMVAL(nolign-1)=0
        [M:HREXE3]DFNRPTERR(nolign-1)=""
      Endif
    Next nolign
  Endif

Return

$POPULATE_VALUES
 Onerrgo $DISPLAYERROR
  [L]CALLED_FROM=mess(30,11662,1)
  For nolign=1 To [M:HREXE3]DFNNBR
  #JASMI - 2017-01-05 - START - to enhance performance
##    If [M:HREXE3]DFNDTALVL(nolign-1) = [L]DATA_LEVEL
    Gosub CALC_CONDITION
    If [L]TEMP_VAL="1"
  #JASMI - 2017-01-05 - END
      [L]TEMP_VAL=""
    #get exctract field names from validation conditions and replace field values in condition i.e. '~~<Extract Field Code>'
      [L]TEMP_VAL=[M:HREXE3]DFNVALCLC(nolign-1)
      Gosub EXTRACT_VALUE
      If parse([L]TEMP_VAL)<>0
      #JASMI - 2016-10-05 - Issue xxx - START
  #      Call ECR_TRACE([L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1), 0) From GESECRAN
        Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+' - '+[L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
      #JASMI - 2016-10-05 - Issue xxx - END
        OK = 0 : Return
      Endif
      [L]TEMP_VAL = num$(evalue([L]TEMP_VAL))
    #calc value
      [L]TEMP_VAL = ctrans([L]TEMP_VAL,'"','')
#JASMI - 2017-05-19 - START
    #JASMI -2016-04-05 - KENYA iTax - START
    #  [L]TEMP_VAL = ctrans([L]TEMP_VAL,"'",'')
    #JASMI -2016-04-05 - KENYA iTax - END
      [L]TEMP_VAL = ctrans([L]TEMP_VAL,"'",'')
#JASMI - 2017-05-19 - END
      If [M:HREXE3]DFNTYP(nolign-1)="A"
        [L]TEMP_VAL = evalue('format$("K:'+num$([M:HREXE3]DFNLNG(nolign-1))+'X","'+[L]TEMP_VAL+'")')
      Else
#JASMI - 2016-05-26 - REQ 116689 - START
#        If val([L]TEMP_VAL)<0
#          [L]TEMP_VAL = evalue('format$("N:'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(val([L]TEMP_VAL))+')')
#        Else
#          [L]TEMP_VAL = evalue('format$("N0:'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(val([L]TEMP_VAL))+')')
#        Endif
        [L]TEMP_VAL = evalue('format$("N:'+num$([M:HREXE3]DFNLNG(nolign-1))+'",'+num$(val([L]TEMP_VAL))+')')
#JASMI - 2016-05-26 - REQ 116689 - END
        [M:HREXE3]DFNNUMVAL(nolign-1)=val([L]TEMP_VAL)
      Endif
      [M:HREXE3]DFNVAL(nolign-1)=vireblc([L]TEMP_VAL,2)
      If [M:HREXE3]DFNMDT(nolign-1)=2 & [M:HREXE3]DFNRPTERR(nolign-1)<>"Y"
        If ([M:HREXE3]DFNTYP(nolign-1)="A" and [M:HREXE3]DFNVAL(nolign-1) = "") or
&          ([M:HREXE3]DFNTYP(nolign-1)<>"A" and val([M:HREXE3]DFNVAL(nolign-1)) = 0)
          Call ECR_TRACE([L]TEMP_GROUP_VALUE([L]DATA_LEVEL)+': '+[M:HREXE3]DFNTIT(nolign-1)+' - '+mess(10,123,1), 0) From GESECRAN
          [M:HREXE3]DFNRPTERR(nolign-1)="Y"
          [L]ERROR_COUNT+=1
        Endif
      Endif
    Endif
  Next nolign

Return

#JASMI - 2017-01-05 - START - to enhance performance
$CALC_CONDITION
 Onerrgo $DISPLAYERROR
  [L]TEMP_VAL="0"
  If [M:HREXE3]DFNDTALVL(nolign-1) = [L]DATA_LEVEL
    If [M:HREXE3]DFNCDN(nolign-1)=""
      [L]TEMP_VAL="1"
    Else
      [L]TEMP_VAL=[M:HREXE3]DFNCDN(nolign-1)
      Gosub EXTRACT_VALUE
      If parse(ctrans([L]TEMP_VAL,'"',''))<>0
        Call ECR_TRACE([L]GROUP_VALUE([L]DATA_LEVEL)+' - '+[L]CALLED_FROM+' '+[M:HREXE3]DFNCOD(nolign-1)+': '+mess(65,106,1)-'. Check for single quotes in source data', 0) From GESECRAN
        OK = 0 : Return
      Endif
      If evalue(ctrans([L]TEMP_VAL,'"','')) = 1
        [L]TEMP_VAL="1"
      Endif
    Endif
  Endif
Return
#JASMI - 2017-01-05 - END

$FINAL_RECORD
 Onerrgo $DISPLAYERROR
  If [L]LEVEL_RECORD_COUNT([L]DATA_LEVEL) > 0
    Gosub VALIDATE_VALUES
    If !OK : Return : Endif

    [L]GROUP_VALUE([L]DATA_LEVEL)=[L]TEMP_GROUP_VALUE([L]DATA_LEVEL)

    Gosub CLEAR_PREVIOUS_TEST_DATA
    If !OK : Return : Endif
    If [M:HREXE0]EXRCLEPRE=2 and [M:HREXE0]EXRLIVIND=2
      Gosub CLEAR_PREVIOUS_DATA
    Endif

    Case [L]DATA_LEVEL
      When 1
        [L]HEADER_RECORD_COUNT+=1
      When 2
        [L]DETAIL_RECORD_COUNT_PER_GROUPING+=1
        [L]DETAIL_RECORD_COUNT+=1
    Endcase

    If [M:HREXE0]EXRVLYOLY<>2
      Gosub WRITE_RESULTS
      If !OK : Return : Endif
    Endif

    If [L]DATA_LEVEL=1
      Gosub GET_DETAIL_LINES
      If !OK : Return : Endif
      Gosub GET_TOTAL_LINES
      If !OK : Return : Endif

      [L]HEADER_FIELD_COUNT_PER_GROUPING=0
      [L]DETAIL_FIELD_COUNT_PER_GROUPING=0
      [L]DETAIL_RECORD_COUNT_PER_GROUPING=0
    Endif

  Endif

  If [L]LEVEL_RECORD_COUNT([L]DATA_LEVEL) = 0
    Call ECR_TRACE("", 0) From GESECRAN
    If [L]DATA_LEVEL=1
      Call ECR_TRACE(mess(31,11662,1), 0) From GESECRAN
      If [M:HREXE0]EXRHEAMSG <> ""
        Call ECR_TRACE([M:HREXE0]EXRHEAMSG, 0) From GESECRAN
      Endif
    Else
      Call ECR_TRACE(mess(32,11662,1), 0) From GESECRAN
      If [M:HREXE0]EXRDETMSG <> ""
        Call ECR_TRACE([M:HREXE0]EXRDETMSG, 0) From GESECRAN
      Endif
    Endif
  Endif

Return

$OPEN_EXTRACT_FILE
 Onerrgo $DISPLAYERROR
  [L]FICHIER=[M:HREXE0]EXRFILNAM
  [L]FICHIER=filpath([V]GDIRBQE, [M:HREXE0]EXRFILNAM, [M:HREXE0]EXRFILEXT, 0)

  Openo [L]FICHIER,0 Using [FIC]

  SAVIFS = adxifs : SAVIRS = adxirs
  adxifs = "" : adxirs = chr$(13)+chr$(10)

Return

$WRITE_TO_EXTRACT_FILE
 Onerrgo $DISPLAYERROR
  [L]GROUP_VALUE(1)="~!~"
  [L]GROUP_VALUE(2)="~!~"

  For [L]EXTRACT_DATA_COUNT= 1 To 8
    [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT) = ""
  Next [L]EXTRACT_DATA_COUNT
  [L]EXTRACT_DATA_COUNT = 1


  Filter [F:HREXR] Where [F:HREXR]EXRTEP=[M:HREXE0]EXRTEP &
&                        [F:HREXR]RESRUNDAT=[L]RUN_DATE & [F:HREXR]RESRUNTIM=[L]RUN_TIME
  For [F:HREXR]HREXR0
    [L]TEMP_VAL=""
    If [L]GROUP_VALUE(1)="~!~"
      [L]GROUP_VALUE(1)=[F:HREXR]RESHEAVAL
    Endif
    If [L]GROUP_VALUE(2)="~!~"
      [L]GROUP_VALUE(2)=[F:HREXR]RESDETVAL
    Endif
    [L]DATA_LEVEL=[F:HREXR]RESDTALVL

    If ([L]GROUP_VALUE(1)<>[F:HREXR]RESHEAVAL) | ([L]GROUP_VALUE(2)<>[F:HREXR]RESDETVAL)
#JASMI - 2016-05-26 - REQ 116689 - START
#      Wrseq ([L]EXTRACT_DATA(1) + [L]EXTRACT_DATA(2) +
#&            [L]EXTRACT_DATA(3) + [L]EXTRACT_DATA(4) +
#&            [L]EXTRACT_DATA(5) + [L]EXTRACT_DATA(6) +
#&            [L]EXTRACT_DATA(7) + [L]EXTRACT_DATA(8))
#&                                             Using [FIC]
#
#      For [L]EXTRACT_DATA_COUNT= 1 To 8
#        [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT) = ""
#      Next [L]EXTRACT_DATA_COUNT
#      [L]EXTRACT_DATA_COUNT = 1
#
#      [L]GROUP_VALUE(1)=[F:HREXR]RESHEAVAL
#      [L]GROUP_VALUE(2)=[F:HREXR]RESDETVAL
      Gosub WRITE_FILE_AND_CLEAR
#JASMI - 2016-05-26 - REQ 116689 - END
    Endif

    If [L]EXTRACT_DATA(1)<>""
      [L]TEMP_VAL=[M:HREXE0]EXRFLDSEP
    Endif

    [L]TEMP_VAL+=[F:HREXR]RESEXRVAL
    If len([L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT)) + len([L]TEMP_VAL)
&      > 250
        [L]EXTRACT_DATA_COUNT += 1
    Endif
    [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT)+=[L]TEMP_VAL

#JASMI - 2016-05-26 - REQ 116689 - START
    If [L]EXTRACT_DATA(1)<>""
      If [F:HREXR]RESNEWLIG=2
        Gosub WRITE_FILE_AND_CLEAR
      Endif
    Endif
#JASMI - 2016-05-26 - REQ 116689 - END

  Next

  If [L]EXTRACT_DATA(1)<>""
#JASMI - 2016-05-26 - REQ 116689 - START
#    Wrseq ([L]EXTRACT_DATA(1) + [L]EXTRACT_DATA(2) +
#&          [L]EXTRACT_DATA(3) + [L]EXTRACT_DATA(4) +
#&          [L]EXTRACT_DATA(5) + [L]EXTRACT_DATA(6) +
#&          [L]EXTRACT_DATA(7) + [L]EXTRACT_DATA(8))
#&                                             Using [FIC]
    Gosub WRITE_FILE_AND_CLEAR
#JASMI - 2016-05-26 - REQ 116689 - END
  Endif

Return


#JASMI - 2016-05-26 - REQ 116689 - START
$WRITE_FILE_AND_CLEAR
 Onerrgo $DISPLAYERROR
#DESNY - START- 2018-08-06 - KENYA ITAX Add the single qoute to file for kenya excel sheet validation
FILE_VALUES = ""
If [M:HREXE0]EXRTEP = "KE_ITAX_B" | [M:HREXE0]EXRTEP = "KE_ITAX_C" Then
  For [L]EXTRACT_DATA_COUNT= 1 To 8
    If instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Rented House") > 0 Then
        FILE_VALUES += left$([L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT),instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Rented House")-1) + "Employer's Rented House"
& + right$([L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT),instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Rented House")+len("Employers Rented House"))
    Elsif instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Owned House") > 0 Then
        FILE_VALUES += left$([L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT),instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Owned House")-1) + "Employer's Owned House" +
& right$([L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT),instr(0, [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT), "Employers Owned House")+len("Employers Owned House"))
    Else
      FILE_VALUES += [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT)
    Endif
  Next [L]EXTRACT_DATA_COUNT
    Wrseq (FILE_VALUES) Using [FIC]

Else
  Wrseq ([L]EXTRACT_DATA(1) + [L]EXTRACT_DATA(2) +
&        [L]EXTRACT_DATA(3) + [L]EXTRACT_DATA(4) +
&        [L]EXTRACT_DATA(5) + [L]EXTRACT_DATA(6) +
&        [L]EXTRACT_DATA(7) + [L]EXTRACT_DATA(8))
& Using [FIC]

Endif
#DESNY - END - 2018-08-06 - KENYA ITAX Add the single qoute to file for kenya excel sheet validation

#  Wrseq ([L]EXTRACT_DATA(1) + [L]EXTRACT_DATA(2) +
#&        [L]EXTRACT_DATA(3) + [L]EXTRACT_DATA(4) +
#&        [L]EXTRACT_DATA(5) + [L]EXTRACT_DATA(6) +
#&        [L]EXTRACT_DATA(7) + [L]EXTRACT_DATA(8))
#& Using [FIC]
#  FILE_VALUES += ([L]EXTRACT_DATA(1) + [L]EXTRACT_DATA(2) +
#&        [L]EXTRACT_DATA(3) + [L]EXTRACT_DATA(4) +
#&        [L]EXTRACT_DATA(5) + [L]EXTRACT_DATA(6) +
#&        [L]EXTRACT_DATA(7) + [L]EXTRACT_DATA(8)) + chr$(13)+chr$(10)

  For [L]EXTRACT_DATA_COUNT= 1 To 8
    [L]EXTRACT_DATA([L]EXTRACT_DATA_COUNT) = ""
  Next [L]EXTRACT_DATA_COUNT
  [L]EXTRACT_DATA_COUNT = 1

  [L]GROUP_VALUE(1)=[F:HREXR]RESHEAVAL
  [L]GROUP_VALUE(2)=[F:HREXR]RESDETVAL

Return
#JASMI - 2016-05-26 - REQ 116689 - END

#########################################
$CLOSE_EXTRACT_FILE
 Onerrgo $DISPLAYERROR
  Openo Using [FIC]
  adxifs = SAVIFS : adxirs = SAVIRS

  [L]FICCLI+=[M:HREXE0]EXRFILNAM+"."+[M:HREXE0]EXRFILEXT
  Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
  If [L]STAT<>0 : [L]TRA = 0 : Endif

Return

#########################################
$PRINT_REPORT
 Onerrgo $DISPLAYERROR
Local Char TBPAR(80)(1..)
Local Char TBVAL(20)(1..)

  TBPAR(1) = "exrtep"
  TBVAL(1) = [M:HREXE0]EXRTEP

  TBPAR(2) = "datdeb"
#  TBVAL(2) = num$(month([L]RUN_DATE))+"/"+num$(day([L]RUN_DATE))+"/"+num$(year([L]RUN_DATE))
#  TBVAL(2) = num$(year([L]RUN_DATE))+"/"+num$(month([L]RUN_DATE))+"/"+num$(day([L]RUN_DATE))
  TBVAL(2) = format$("D:YYYYMMDD",[L]RUN_DATE)
  TBPAR(3) = "datfin"
#  TBVAL(3) = num$(month([L]RUN_DATE))+"/"+num$(day([L]RUN_DATE))+"/"+num$(year([L]RUN_DATE))
#  TBVAL(3) = num$(year([L]RUN_DATE))+"/"+num$(month([L]RUN_DATE))+"/"+num$(day([L]RUN_DATE))
  TBVAL(3) = format$("D:YYYYMMDD",[L]RUN_DATE)

  TBPAR(4) = "tim"
  TBVAL(4) = num$([L]RUN_TIME)

#pass template parameters
Local Integer PAR_COUNT

  [L]PAR_COUNT=4

  For nolign=1 To [M:HREXE2]PARNBR
    [L]PAR_COUNT+=1
    Case [M:HREXE2]PARVALTYP(nolign-1)
    When 2
    #range value parameter
    #start value
      TBPAR([L]PAR_COUNT) = [M:HREXE2]PARCOD(nolign-1)+"DEB"
      TBVAL([L]PAR_COUNT) = num$([M:HREXE2]VALINT1(nolign-1))
    #end value
      [L]PAR_COUNT+=1
      TBPAR([L]PAR_COUNT) = [M:HREXE2]PARCOD(nolign-1)+"FIN"
      TBVAL([L]PAR_COUNT) = num$([M:HREXE2]VALINT2(nolign-1))
    When Default
    #single value parameter
      TBPAR([L]PAR_COUNT) = [M:HREXE2]PARCOD(nolign-1)
      TBVAL([L]PAR_COUNT) = num$([M:HREXE2]VALINT1(nolign-1))
    Endcase
  Next nolign

  Call ETAT([M:HREXE0]EXRPRNRPT, "PREVISU", GLANGUE, 0, "", TBPAR, TBVAL) From AIMP3

Return

######################################################################################
## Section automatically added (screen GENHREXT0) 03/24/2015 13:37:14 (JASMI)
######################################################################################
Subprog AM_EXRTEP(VALEUR)
Variable Char    VALEUR()
  Raz [M:HREXE0]
  [M:HREXE0]EXRTEP = VALEUR
  Gosub POPULATE_WINDOW

End

######################################################################################
## Section automatically added (screen GENHREXT2) 04/16/2015 22:11:24 (JASMI)
######################################################################################
Subprog C_PARVALFIN(VALEUR)
Variable Char    VALEUR()
  If [M:HREXE2]PARVALTYP(nolign-1)=2
    If [M:HREXE2]PARVALDEB(nolign-1)<>""
      If VALEUR ="" Then
        mkstat = 1 : GMESSAGE = mess(10,123,1)
      Endif
    Endif
  Endif

End

######################################################################################

Subprog C_PARVALDEB(VALEUR)
Variable Char    VALEUR()
  If [M:HREXE2]PARMDT(nolign-1)=2
    If VALEUR ="" Then
      mkstat = 2 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

  If (nolign-1) = 1
    If VALEUR ="0" Then
      mkstat = 2 : GMESSAGE = mess(10,123,1)
    Endif
  Endif

End


