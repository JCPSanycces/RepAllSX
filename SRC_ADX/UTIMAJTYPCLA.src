#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Mise a jour champ typcla
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Mise a jour champ typcla") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2] Where DOSSIER=GDOSX3
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAFFLNK
End
Gosub MAJDIMPARASHW
Gosub MAJDIMPAR
Gosub MAJTYPCLA
End

#----------------------------------------------#
$MAJAFFLNK
Local File =DOSSIER+".ASHWPAR" [ASWP]
Trbegin [ASWP]
For [ASWP]ASWP0  Where TYPPAR=3 & TYPKEY=1
 [ASWP]TYPAFF = 1
 Rewrite [ASWP]
Next
Commit
Return

#----------------------------------------------#
$MAJDIMPARASHW
Local File =DOSSIER+".ASHWPARMET" [ASWMP]
Trbegin [ASWMP]
For [ASWMP]ASWMP0  Where DIMPARMET>1
 [ASWMP]DIMPARMET = 2
 Rewrite [ASWMP]
Next
Commit
Return

#----------------------------------------------#
$MAJDIMPAR
Local File =DOSSIER+".ACLAPARDEF" [ACLPD]
Trbegin [ACLPD]
For [ACLPD]ACLPD0  Where DIMPAR>1
 [F:ACLPD]DIMPAR = 2
 Rewrite [F:ACLPD]
Next
Commit
Return

#----------------------------------------------#
$MAJTYPCLA
Local File =DOSSIER+".ACLASSE" [ACLA]
Trbegin [ACLA]
For [ACLA]ACLA0
 If [F]TYPCLA=0
  If [ACLA]FLGSYSTEM=2
   [ACLA]TYPCLA =  4
  Elsif [ACLA]MASTER = 2
   [ACLA]TYPCLA =  2
  Elsif [ACLA]RAW = 2
   [ACLA]TYPCLA =  3
  Else
   [ACLA]TYPCLA =  1
  Endif
  Rewrite [ACLA]
 Endif
Next
Commit
Return
