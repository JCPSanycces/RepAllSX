#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJSLINK0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:10"
A_USER  = "DOC"
A_STAMP = "20181109230110"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBTAB"
  If [M]NBTAB=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask AJSLINK0 [AJK0]
Gosub HORODAT
Local Inpbox "AJSLINK0" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJK0] As [SIM_]
Grizo [AJK0]5
Grizo [AJK0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJK0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=15
Return

$ON_RAZAUDTBL
Onevent INIT_AREA Call D_RAZAUDTBL(zc) From W1AJSLINK0
Onevent BEFORE_INPUT Call AS_RAZAUDTBL(zc) From W1AJSLINK0
Onevent CONTROL Call C_RAZAUDTBL(zc) From W1AJSLINK0
Return

Subprog D_RAZAUDTBL(VALEUR)
Variable Integer VALEUR
If varinit([M]RAZAUDTBL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_RAZAUDTBL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_RAZAUDTBL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "RAZAUDTBL" : GZNUM = 44699 : Endif
Gosub _AFF
End

$ON_CODFIC
Return

$ON_ZCODFIC
Onevent BEFORE_AREA Gosub AV_ZCODFIC From W1AJSLINK0
Return

$AV_ZCODFIC
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Local File ATABLE [F_]
[F:F_]=[F:ATB]
Call LECTURE("ATB",[M]CODFIC(indice),"") From CONTOBJ
Call TEXTE([F:ATB]INTITFIC,zc) From OBJDIV
[F:ATB]=[F:F_]
Close Local File [F_]
Gosub _AFF
Return

$ON_INILNK
Onevent INIT_AREA Call D_INILNK(zc) From W1AJSLINK0
Onevent BEFORE_INPUT Call AS_INILNK(zc) From W1AJSLINK0
Return

Subprog D_INILNK(VALEUR)
Variable Integer VALEUR
If varinit([M]INILNK,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_INILNK(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


