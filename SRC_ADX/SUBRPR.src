#<AdxTL>@(#)3.0.0.0 $Revision$
#*********************************************************************
#
#          GESTION DU PLAN DES PROVISIONS POUR RENOUVELLEMENT
#
#*********************************************************************
#    Création
#    MWA - 27.05.2009
#
#*********************************************************************
#    Modification
#    MWA 00.00.0000 FQnnnn   ........................
#    MDJ - 12.06.2013  FQ 82871  Adaptations pour Convergence (pcolor)
#    CBO - 12.03.2012  FQ 80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
#
#*********************************************************************
#

  Call OBJET("RPR",GBIDC1,GBIDC2) From GOBJET
  End

######################################################################################
## Etiquette ajoutée par le superviseur (écran RPR1) 27/05/2009 14:25:37 (MWA)
######################################################################################
$ACTION

  Case ACTION
   When "OUVRE"             : Gosub OUVRE          : # Début  - Avant toute chose
   When "VERROU"            : Gosub VERROU         : #
   When "LIENS"             : Gosub LIENS          : # Début  - Lecture informations tables liées

   When "APRES_MODIF"       : Gosub APRES_MODIF

   When "SETBOUT"           : Gosub SETBOUT        : #        - Désactivation des boutons
   When "AVANT_DEVERROU"    : Gosub AVANT_DEVERROU : #        - Avant déverrouillage
   When "FERME"             : Gosub FERME
   When Default
  Endcase

Return

#=====================================================================
#
$APRES_MODIF
  OK = 0
Return


#=====================================================================
#
$OUVRE

Global Integer G_COULIG1     : # N° ligne de l'exercice courant
Global Date    G_FISSTRDPR   : # Date de début d'amortissement pour le plan fiscal
Global Date    G_FIYENDCUR   : # Date de fin de l'exercice courant
Global Date    G_PERENDCUR   : # Date de fin de la période courante de l'exercice courant
Global Date    G_FIYENDNXT   : # Date de fin de l'exercice suivant
Global Date    G_PERENDNXT   : # Date de fin de la période courante de l'exercice suivant

Local Char    LAASREF(GLONAAS)

  # Sauvegarde du contexte - variables globales
  If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif

  # Entrée par tunnel
  If ( CLE1 <> "") Then
    [L]LAASREF = CLE1      : # Sauvegarde de la référence du bien appelant
  Else
    [L]LAASREF = ""
  Endif
  # Gestion tables
  If clalev([F:FAS])=0    : Local File FXDASSETS     [FAS]    : Endif
  If clalev([F:DEP])=0    : Local File DEPREC        [DEP]    : Endif
  If clalev([F:RPR1])=0   : Local File CCNRPR        [RPR1]   : Endif
  If clalev([F:RPR2])=0   : Local File CCNRPR        [RPR2]   : Endif
  If clalev([F:RPR3])=0   : Local File CCNRPR        [RPR3]   : Endif
  If clalev([F:RPR])=0    : Local File CCNRPR        [RPR]    : Endif
  If clalev([F:FIS])=0    : Local File FISCYEAR      [FIS]    : Endif
  If clalev([F:CNX])=0    : Local File CONTEXT       [CNX]    : Endif

  #-------------------------
  # Appel au sous-programme d'initialisation de la gestion des globales d'environnement
  Call INIT_FCY () From GLOFCYCPY

  #-------------------------
Return


#=====================================================================
#
$VERROU
 OK = 0
Return


#=====================================================================
#
$LIENS

  Local Integer I_LGN

  # Lecture de la devise du contexte en cours
  Read [CNX] CNX0=[F:FAS]CPY;G300CPFI
  If (fstat) Then : Raz [F:CNX] : Endif
  [M:RPR1]CUR=[F:CNX]CUR

  # Récupération de la date de fin de l'exercice courant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TECOURA
  Read [FIS]First
  If (fstat) Then : Raz [F:FIS] : Endif
  Filter [FIS]
  G_FIYENDCUR = [F:FIS]DATENDFIY
  G_PERENDCUR = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  # Récupération de la date de fin de l'exercice suivant
  # et de la date de fin de la période courante du contexte de la société du bien concerné
  Filter [FIS] Where CPY=[F:CNX]CPY and CNX =[F:CNX]CNX and STAFIY = GVML_TESUIV
  Read [FIS]First
  Filter [FIS]
  If (fstat) Then : Raz [F:FIS] : Endif
  G_FIYENDNXT = [F:FIS]DATENDFIY
  G_PERENDNXT = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  # Lecture période courante de l'amortissment industriel
  Read [DEP]DEP0=[M:RPR1]AASREF;G_CCNPLNIND;FIYENDDAT; PERENDDAT


  # Lecture des provisions du bien
  nolign = 1
  Call ACTION_BLOCK (ACB_EFFZO, "RPR1", "NBLIG2") From GLOBIENS

  Filter [RPR1] Where AASREF=[M:RPR1]AASREF
&  Order By Key CLE=AASREF; FIYENDDAT; PERENDDAT Desc
  #> 1 >>>>>>>>>>>>>>>>>
  For [RPR1] CLE(2)
    #> 2 >>>>>>>>>>>>>>>>>
    For [RPR1] CLE

      #- 3 ----------------
      If ( [F:DEP]STRDPRDAT <= [F:RPR1]FIYENDDAT ) Then


        # -- Positionnement sur la dernière période de chaque exercice
        #=================
        [M:RPR1] = [F:RPR1]
        #=================

        # Lecture DEPREC début exercice
        Filter [RPR3] Where AASREF=[M:RPR1]AASREF and FIYENDDAT=[F:RPR1]FIYENDDAT
&                  Order By AASREF; FIYENDDAT; PERENDDAT
        Read  [RPR3] First
        If (fstat) Then : Infbox num$(fstat) : Endif
        Filter [RPR3]

        # Site financier
        [M:RPR1]FCY1(nolign-1)       = [F:RPR1]FCY
        # -- Champs calculés
        [M:RPR1]FIYENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:RPR1]FIYENDDAT)

        # ----- Exercice courant
        If ([F:RPR1]FIYENDDAT = G_FIYENDCUR ) Then : G_COULIG1=nolign-1 :  Endif

        #### ----- Dotation forcée
        #### If ([F:RPR1]ENDDPEFLG = G_OUI ) Then : Chgstl [M:RPR1]ENDDPE(nolign-1) With "TFORCAGE" :  Endif

        nolign += 1

      Endif
      #- 3 ----------------

      Break 1
    Next
    #> 2 >>>>>>>>>>>>>>>>>
  Next
  #> 1 >>>>>>>>>>>>>>>>>
  Filter [RPR1]
  [M:RPR1]NBLIG1 = nolign-1

Return

#=====================================================================
#
$SETBOUT

  # Désactivation de l'action Créer, Dupliquer, Supprimer, Changer de clé
  #Call VIREBOUT(CHAINE,"CDAHM") From GOBJET

  # Positionnement du focus sur la ligne de l'exercice courant
  If ( [M:RPR1]NBLIG1 > 0 ) Then
    zonsui="NBLIG1("+num$(G_COULIG1)+")"
  Endif

  # Activation menu Actions
  # Menu B Actions

  CHMEN += "IN"

Return


#=====================================================================
#
$AVANT_DEVERROU

  # Pas de déverrouillage du Bien appelant
  If (LAASREF <> "") Then
    OK = 0
  Endif

Return

#=====================================================================
#
$FIN

  Kill G_FISSTRDPR
  Kill G_FIYENDCUR
  Kill G_PERENDCUR
  Kill G_FIYENDNXT
  Kill G_PERENDNXT
  Kill G_COULIG1

  Gosub DELOCK_TBL_DEST From FUNLOFLDAB
Return

#=====================================================================
$FERME
  If TUNNEL : Gosub RESTAURE_GLOBAL_SV From GLOBIMM : Endif
Return

#
#*********************************************************************
#        *RPR1             E C R A N      R P R 1
#*********************************************************************
#
#############################################"
Subprog AS_NBLIG1

Local Integer NOL

  # Lecture des provisions périodiques de l'exercice choisi dans le tableau
  [L]NOL=nolign-1
  [M:RPR1]ZONCUR = [M:RPR1]FIYENDDAT([L]NOL)

  nolign = 1
  Call ACTION_BLOCK (ACB_EFFZO, "RPR1", "NBLIG2") From GLOBIENS

    Filter [RPR] Where AASREF=[M:RPR1]AASREF and FIYENDDAT = [M:RPR1]ZONCUR
&                Order By AASREF; FIYENDDAT; PERENDDAT

    For [RPR]

      [M:RPR1]FCY2(nolign-1)       = [F:RPR]FCY
      [M:RPR1]FIYSTRDAT2(nolign-1) = [F:RPR]FIYSTRDAT
      [M:RPR1]FIYENDDAT2(nolign-1) = [F:RPR]FIYENDDAT
      [M:RPR1]PERSTRDAT(nolign-1)  = [F:RPR]PERSTRDAT
      [M:RPR1]PERENDDATC(nolign-1) = format$("D:" + GFMDAT4, [F:RPR]PERENDDAT)
      [M:RPR1]PERENDDAT(nolign-1)  = [F:RPR]PERENDDAT

      [M:RPR1]STRRNWVAL2(nolign-1) = [F:RPR]STRRNWVAL
      [M:RPR1]RNWVALCOE2(nolign-1) = [F:RPR]RNWVALCOE
      [M:RPR1]RNWVALFLG2(nolign-1) = [F:RPR]RNWVALFLG
      [M:RPR1]ENDRNWVAL2(nolign-1) = [F:RPR]ENDRNWVAL

      [M:RPR1]P_1ACGRPR(nolign-1)  = [F:RPR]E_1ACGRPR + [F:RPR]P_1ACGRPR
      [M:RPR1]PERACGRPR(nolign-1)  = [F:RPR]PERACGRPR
      [M:RPR1]P_1FISRPR(nolign-1)  = [F:RPR]E_1FISRPR + [F:RPR]P_1FISRPR
      [M:RPR1]PERFISRPR(nolign-1)  = [F:RPR]PERFISRPR
      [M:RPR1]P_1RVERPR(nolign-1)  = [F:RPR]E_1RVERPR + [F:RPR]P_1RVERPR
      [M:RPR1]PERRVERPR(nolign-1)  = [F:RPR]PERRVERPR
      [M:RPR1]P_1SUPCAD(nolign-1)  = [F:RPR]E_1SUPCAD + [F:RPR]P_1SUPCAD
      [M:RPR1]PERSUPCAD(nolign-1)  = [F:RPR]PERSUPCAD
      [M:RPR1]ACGRPRDEV(nolign-1)  = [F:RPR]ACGRPRDEV
      [M:RPR1]PSTACGRPR(nolign-1)  = [F:RPR]PSTACGRPR
      [M:RPR1]FISRPRDEV(nolign-1)  = [F:RPR]FISRPRDEV
      [M:RPR1]PSTFISRPR(nolign-1)  = [F:RPR]PSTFISRPR

      nolign += 1
    Next
    Filter [RPR]
    [M:RPR1]NBLIG2 = nolign-1
    Call ACTION_BLOCK (ACB_AFFZO, "RPR1", "NBLIG2") From GLOBIENS

End


################################
Subprog AV_FIYSTRDAT(VALEUR)
Variable Date    VALEUR


  #*Fq-82871
  #* - on garde les pcolor pour l'appli. C/S
  #* - on ajoute un chgstl pour Convergence
  If ([M:RPR1]FIYENDDAT(nolign-1) = G_FIYENDCUR) Then
    Chgstl NBLIG1(nolign-1)  With "AWARNLOW"
    pcolor = GCOUL(3)  # Bleu
  Else
    Chgstl NBLIG1(nolign-1)  With ""
    pcolor = GCOUL(0)  # Normal
  Endif
End

################################
Subprog AV_PERSTRDAT(VALEUR)
Variable Date    VALEUR


  #*Fq-82871
  #* - on garde les pcolor pour l'appli. C/S
  #* - on ajoute un chgstl pour Convergence
  If ([M:RPR1]PERENDDAT(nolign-1) = G_PERENDCUR ) Then
    Chgstl NBLIG2(nolign-1)  With "AWARNLOW"
    pcolor = GCOUL(3)  # Bleu
  Else
    Chgstl NBLIG2(nolign-1)  With ""
    pcolor = GCOUL(0)  # Normal
  Endif
End



################################
Subprog AV_ENDRNWVAL(VALEUR)
Variable Decimal VALEUR
  If ( [M:RPR1]RNWVALFLG(nolign-1) = G_OUI) Then
    Chgstl [M:RPR1]ENDRNWVAL(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:RPR1]ENDRNWVAL(nolign-1) With ""
  Endif
End



################################
Subprog AV_ENDRNWVAL2(VALEUR)
Variable Decimal VALEUR
  If ( [M:RPR1]RNWVALFLG2(nolign-1) = G_OUI) Then
    Chgstl [M:RPR1]ENDRNWVAL2(nolign-1) With "TFORCAGE"
  Else
    Chgstl [M:RPR1]ENDRNWVAL2(nolign-1) With ""
  Endif
End
