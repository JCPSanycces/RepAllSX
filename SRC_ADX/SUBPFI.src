#<AdxTL>@(#)7.0.0.0 $Revision$
########################################################################
# SUBPFI : Gestion des éléments de facturation achats     MBT 21/10/97 #
#                                                 modifié MBT 20/04/98 #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:PFI]PFOOTINV                                 #
#                                                                      #
# Contrôles : Si AMTCOD=2 (Montant)         --> CLCBAS=1 (Aucune)      #
#             Si DACLIN=1 (Pas ligne tarif)                            #
#          et si DSPLIN=1 (Pas répartition) --> VATRUL=2  (Taux fixe)  #
#             Si DACLIN=2 (Ligne tarif)     --> DSPLIN=1  (Non)        #
#             Si DSPLIN=1 (Non)             --> NPRVLT=1  (Non)        #
#             Si VATRUL=1 (Produit)         --> VACITM="" (Pas niv.tax)#
########################################################################

Call OBJET("PFI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD       : # 102698 : Belgium Early discounts
 When "ANNULE"      : Gosub ANNULE
 When "AFFMASK"     : Gosub AFFMASK      : # 102698 : Belgium Early discounts
 When Default
Endcase
Return


$OUVRE
#------------------------------#
# Lecture de la devise société #
#------------------------------#
If !clalev([F:DIE])  Local File GDIE     [DIE] : Endif
If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
Local Decimal WMNTORG
Local Decimal WMNTDES
Local Integer SPSTAT
#----- Chargement de GCUR -----#
Call CHARGE_GCUR() From TRTX3
Call LECDEV (GCUR) From TRTDIV
Return


$SETBOUT
#------------------------------#
# Désactivation bouton "Copie" #
#------------------------------#
If GREP<>"" | !CLECUR Call VIREBOUT(CHAINE,"1") From GOBJET : Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return


$APRES_MODIF
#----------------------------------------------------------#
# Après modification de chaque zone traitement des "Grizo" #
#----------------------------------------------------------#
If GMODU(6)=2  : # # 102698 : Belgium Early discounts
  Case COUZON
    When "AMTCOD"
         If val(CZ)=1
           [M:PFI1]DACLIN=1 : [M:PFI1]TRFINV=1 : [M:PFI1]CLCBAS=2
           Grizo [PFI1]DACLIN, TRFINV, ACTCLCBAS, PRGCLCBAS
           Actzo [PFI1]DACORD, CLCBAS
           Affzo [PFI1]DACLIN, TRFINV, CLCBAS, ACTCLCBAS, PRGCLCBAS
         Else
           [M:PFI1]CLCBAS=1
           If [M:PFI1]DACLIN=2 Grizo [PFI1]DACORD Else Actzo [PFI1]DACORD : Endif
           If [M:PFI1]DACORD=2 Grizo [PFI1]DACLIN Else Actzo [PFI1]DACLIN : Endif
           Grizo [PFI1]CLCBAS
           If [M:PFI1]DACORD=2 Actzo [PFI1]TRFINV : Endif
           Affzo [PFI1]DACLIN, DACORD, TRFINV, CLCBAS
         Endif
    When "DACLIN"
         If val(CZ)=1 & [M:PFI1]DSPLIN=1 [M:PFI1]VATRUL=2 : [M:PFI1]NPRVLT=1
                                                  Grizo NPRVLT, VATRUL
                                                  Affzo NPRVLT, VATRUL
                                                  Actzo VACITM, ZVACITM
         Else Actzo NPRVLT, VATRUL : Endif
         If val(CZ)=2 [M:PFI1]DACORD=1 : [M:PFI1]DSPLIN=1 : Grizo DACORD, DSPLIN
                                                            Affzo DACORD, DSPLIN
         Else Actzo DACORD, DSPLIN : Endif
    When "DACORD"
         If val(CZ)=1 & [M:PFI1]AMTCOD=2 Actzo DACLIN : Endif
         If val(CZ)=2 Grizo DACLIN : Endif
    When "DSPLIN"
         If val(CZ)=1 [M:PFI1]NPRVLT=1  : Grizo NPRVLT : Affzo NPRVLT Else Actzo NPRVLT : Endif
         If val(CZ)=1 & [M:PFI1]DACLIN=1 [M:PFI1]VATRUL=2 : [M:PFI1]NPRVLT=1
                                                  Grizo NPRVLT, VATRUL
                                                  Affzo NPRVLT, VATRUL
                                                  Actzo VACITM, ZVACITM
         Else Actzo NPRVLT, VATRUL : Endif
    When "VATRUL"
         If val(CZ)=1 [M:PFI1]VACITM="" : Grizo VACITM, ZVACITM : Affzo VACITM
         Else Actzo VACITM, ZVACITM : Endif
  Endcase
Endif
# end 102698
Return


$LIENS
#---------------------------------------------------------#
# Alimentation des Mts stockés en devise dossier dans [F] #
#          pour saisie en devise société dans [M]         #
#---------------------------------------------------------#
If GMODU(6)=2 : # 102698 : Belgium Early discounts
  If [F:PFI]AMTCOD = 2
     WMNTORG = [F:PFI]DEFVAL
     Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
     If SPSTAT = 0
        [M:PFI1]DEFVAL = WMNTDES
     Endif
     [M:PFI1]DEFVALCUR = GCUR
  Else
     [M:PFI1]DEFVALCUR = ""
  Endif
  #----- Format variable pour le champ DEFVAL -----#
  Call LECDEV (GCUR) From TRTDIV
   If [M:PFI1]AMTCOD=1 [M:PFI1]XFORMAT="NZ:3.2#" Else [M:PFI1]XFORMAT="NZ:"+[F:TCU]CURFMT1 : Endif
Endif
If [M:PFI1]INCDCR=2
    # If Decrease : always subject to discount : The field musn't appear
    Chgfmt [M:PFI1]DEPFLG With "-LA:1"
Else
    # If Increase : can be both
    Chgfmt [M:PFI1]DEPFLG With "LA:1"
Endif
# end 102698
#----- Chargement tableau des axes analytiques -----#
If dim([M:PFI1]NBAXE)>0
  If [M:PFI1]DSP=""
    Actzo [PFI1]55
    If dim([M:PFI1]SOC)>0 & [M:PFI1]SOC<>""
       Call CHARG_DIE(14,[M:PFI1]SOC,"PFI1","NBAXE") From TRTX3CPT
     Else
       Call CHARG_DIE(14,"","PFI1","NBAXE") From TRTX3CPT
    Endif
  Else
    Effzo [PFI1]55 : Grizo [PFI1]55
  Endif
Endif
If GMODU(6)=2 : # 102698 : Belgium Early discounts
  #----- Chargement format et effacement zone après chaque lecture -----#
  If [M:PFI1]AMTCOD=1  Grizo DACLIN Else Actzo DACLIN : Endif
  If [M:PFI1]AMTCOD=2  Grizo CLCBAS Else Actzo CLCBAS : Endif
  If [M:PFI1]DACLIN=1 & [M:PFI1]DSPLIN=1  Grizo VATRUL Else Actzo VATRUL : Endif
  If [M:PFI1]DACLIN=2  Grizo DACORD, DSPLIN Else Actzo DACORD, DSPLIN : Endif
  If [M:PFI1]DACORD=2  Grizo DACLIN : Endif
  If [M:PFI1]DSPLIN=1 & [M:PFI1]DACLIN=1  Grizo NPRVLT Else Actzo NPRVLT : Endif
  If [M:PFI1]CLCBAS=4  Actzo ACTCLCBAS, PRGCLCBAS Else Grizo ACTCLCBAS, PRGCLCBAS : Endif
  If [M:PFI1]VATRUL=1  Grizo VACITM, ZVACITM Else Actzo VACITM, ZVACITM  : Endif
  If [M:PFI1]AMTCOD=1 | [M:PFI1]DACORD=1  Grizo [PFI1]TRFINV Else Actzo [PFI1]TRFINV : Endif
  If dim([M:PFI1]DISVATFLG)>0
    If [M:PFI1]DISVATFLG=2
      Grizo [M:PFI1]AMTCOD, INCDCR, DACORD, TRFINV, DSPLIN, CLCBAS
      # VPO 26/03/10 V6.2:60763 Settlements Discounts
      Grizo [M:PFI1]BPSORI, DEFVAL, DEPFLG
    Else
      Actzo [M:PFI1]AMTCOD, INCDCR
      # VPO 26/03/10 V6.2:60763 Settlements Discounts
      Actzo [M:PFI1]BPSORI, DEFVAL, DEPFLG
    Endif
  Endif
Endif
# end 102698
#-----
Return


$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
[M:PFI1]ENAFLG=2
If dim([M:PFI1]DISVATFLG)>0  [M:PFI1]DISVATFLG=1 : Endif
[M:PFI1]AMTCOD=1
[M:PFI1]INCDCR=1
# 102698 : Belgium Early discounts
Chgfmt [M:PFI1]DEPFLG With "LA:1"
If GMODU(6)=2  : # 102698 : Belgium Early discounts
  [M:PFI1]DACLIN=1
  [M:PFI1]DACORD=1
  [M:PFI1]TRFINV=1
  [M:PFI1]DSPLIN=1
  [M:PFI1]NPRVLT=1
  [M:PFI1]CLCBAS=2
  [M:PFI1]VATRUL=2
  [M:PFI1]DEPFLG=2
  If dim([M:PFI1]CLCDEB)>0
    If !func AFNC.ACTIV("DEB")
      [M:PFI1]CLCDEB=1
    Else
      [M:PFI1]CLCDEB=2
    Endif
  Endif
 Endif
# end 102698
#----- Chargement format et effacement zone après chaque lecture -----#
[M:PFI1]XFORMAT="NZ:3.2#"
#----- Initialisation tableau des axes -----#
If dim([M:PFI1]NBAXE)>0
  If dim([M:PFI1]SOC)>0 & [M:PFI1]SOC<>""
    Call INIT_DIE(14,[M:PFI1]SOC,"PFI1","NBAXE") From TRTX3CPT
  Else
    Call INIT_DIE(14,"","PFI1","NBAXE") From TRTX3CPT
  Endif
Endif
#----- Grisage / dégrisage des champs de l'écran -----#
Actzo [PFI1]1-99
If GMODU(6)=2 : # 102698 : Belgium Early discounts
  If [M:PFI1]AMTCOD=1   Grizo [PFI1]DACLIN : Endif
  If [M:PFI1]AMTCOD=2   Grizo [PFI1]CLCBAS : Endif
  If [M:PFI1]DACLIN=1 & [M:PFI1]DSPLIN=1  Grizo [PFI1]VATRUL : Endif
  If [M:PFI1]DACLIN=2   Grizo [PFI1]DACORD, DSPLIN : Endif
  If [M:PFI1]DACORD=2   Grizo [PFI1]DACLIN  Else  Grizo [PFI1]TRFINV : Endif
  If [M:PFI1]DSPLIN=1 & [M:PFI1]DACLIN=1  Grizo [PFI1]NPRVLT : Endif
  If [M:PFI1]CLCBAS<>4  Grizo [PFI1]ACTCLCBAS, PRGCLCBAS : Endif
  If [M:PFI1]VATRUL=1   Grizo [PFI1]VACITM, ZVACITM : Endif
Endif
# end 102698
#----- Affichage de l'écran -----#
Affzo [PFI1]1-99
Return

# 102698 : Belgium Early discounts
######################################################################
$INIMOD

Gosub INICRE

# If Decrease : always subject to discount (The field doesn't appear)
If [M:PFI1]INCDCR=2 [M:PFI1]DEPFLG=2 Endif

Return
# 102698


######################################################################
$INICRE
#--------------------------------------------------------#
# Réalimentation des Mts saisis en dev soc dans [M:PFI1] #
#       pour stockage en devise dossier dans [F]         #
#--------------------------------------------------------#
If GMODU(6)=2 : # 102698 : Belgium Early discounts
  If [F:PFI]AMTCOD = 2
     WMNTORG = [M:PFI1]DEFVAL
     Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMNTORG,WMNTDES,SPSTAT) From TRTDEV
     If SPSTAT = 0
        [F:PFI]DEFVAL = WMNTDES
     Endif
     [F:PFI]CUR = GSYSCUR
  Endif
Endif
# end 102698
#-----  Création / Modif de ATEXTRA -----#
Call MAJTEXTRA ([M:PFI1]DESAXX,"PFOOTINV","DESAXX",num$([M:PFI1]PFINUM),"") From ATEXTRA
Call MAJTEXTRA ([M:PFI1]SHOAXX,"PFOOTINV","SHOAXX",num$([M:PFI1]PFINUM),"") From ATEXTRA
#----- Clé en alpha -----#
[F:PFI]PFINUMCAR=num$([F:PFI]PFINUM)
#----- SOS libellés -----#
If dim([F:PFI]LANDESSHO)>0
   [F:PFI]LANDESSHO=GLANGUE+"~"+[M:PFI1]DESAXX+"~"+[M:PFI1]SHOAXX
Endif
#-----
If [F:PFI]CLCDEB=0  [F:PFI]CLCDEB=1 : Endif
Return


$ANNULE
Delete [AXX]Where CODFIC="PFOOTINV" & IDENT1=num$([F:PFI]PFINUM)
Return

# 102698 : Belgium Early discounts
######################################################################
$AFFMASK
# If Purchase module is not present we need to desactivate the following fields
If GMODU(6)<>2  # Purchase module inactive
    Chgfmt [M:PFI1]BPSORI     With "-LA:577"
    Chgfmt [M:PFI1]DEFVAL     With "-N:11.4"
    Chgfmt [M:PFI1]DEFVALCUR  With "-K:3"
    Chgfmt [M:PFI1]DACLIN     With "-LA:1"
    Chgfmt [M:PFI1]DACORD     With "-LA:1"
    Chgfmt [M:PFI1]TRFINV     With "-LA:567"
    Chgfmt [M:PFI1]DSPLIN     With "-LA:520"
    Chgfmt [M:PFI1]CLCDEB     With "-LA:2208"
    Chgfmt [M:PFI1]NPRVLT     With "-LA:1"
    Chgfmt [M:PFI1]CLCBAS     With "-LA:537"
    Chgfmt [M:PFI1]ACTCLCBAS  With "-K:10"
    Chgfmt [M:PFI1]PRGCLCBAS  With "-K:10"
    Chgfmt [M:PFI1]CLCORD     With "-N:2"
    Chgfmt [M:PFI1]VATRUL     With "-LA:283"
    Chgfmt [M:PFI1]VACITM     With "-K:"+num$(GLONTVI)
    If dim([M:PFI1]ZVACITM)>0
      Chgfmt [M:PFI1]ZVACITM With "-K:"+num$(type([M:PFI1]ZVACITM)-10)+"X"
    Endif
Endif
Return
# End 102698
######################################################################

Subprog AM_SOC(VALEUR)
#----------------------------------#
# Après modification de la société #
#----------------------------------#
Variable Char    VALEUR()
[M:PFI1]SOC=VALEUR
#--- Initialisation tableau des axes
If dim([M:PFI1]NBAXE)>0
   If dim([M:PFI1]SOC)>0 & [M:PFI1]SOC<>""
      Call CHARG_DIE(14,[M:PFI1]SOC,"PFI1","NBAXE") From TRTX3CPT
    Else
      Call CHARG_DIE(14,"","PFI1","NBAXE") From TRTX3CPT
   Endif
Endif
End


Subprog C_PFINUM(VALEUR)
#---------------------------#
# Contrôle sur code élément #
#---------------------------#
Variable Decimal  VALEUR
If VALEUR=0 : GERR=1 : GMESSAGE=mess(6,199,1) : mkstat=1 : Endif
End


Subprog AM_DISVATFLG(VALEUR)
#----------------------------------------#
# Après modif indicateur remise sur taxe #
#----------------------------------------#
Variable Integer VALEUR
If VALEUR=2
  If [M:PFI1]AMTCOD<>1  [M:PFI1]AMTCOD=1 : Call AM_AMTCOD([M:PFI1]AMTCOD) : Endif
  [M:PFI1]INCDCR=2
  If [M:PFI1]DACLIN<>1  [M:PFI1]DACLIN=1 : Call AM_DACLIN([M:PFI1]DACLIN) : Endif
  If [M:PFI1]DACORD<>2  [M:PFI1]DACORD=2 : Call AM_DACORD([M:PFI1]DACORD) : Endif
  [M:PFI1]TRFINV=1
  If [M:PFI1]DSPLIN<>1  [M:PFI1]DSPLIN=1 : Call AM_DSPLIN([M:PFI1]DSPLIN) : Endif
  [M:PFI1]NPRVLT=1
  If [M:PFI1]CLCBAS<>1  [M:PFI1]CLCBAS=1 : Call AM_CLCBAS([M:PFI1]CLCBAS) : Endif
  If [M:PFI1]VATRUL<>1  [M:PFI1]VATRUL=1 : Call AM_VATRUL([M:PFI1]VATRUL) : Endif
  [M:PFI1]VACITM=""
  Grizo [PFI1]AMTCOD, INCDCR, DACLIN, DACORD, TRFINV, DSPLIN, NPRVLT, CLCBAS, VATRUL, VACITM
  # VPO 26/03/10 V6.2:60763 Settlements Discounts
  [M:PFI1]BPSORI=1 : Raz [M:PFI1]DEFVAL
  Grizo [M:PFI1]BPSORI, DEFVAL
  [M:PFI1]DEPFLG=1 : Grizo [M:PFI1]DEPFLG
Else
  Actzo [M:PFI1]AMTCOD, INCDCR, DACORD, TRFINV, DSPLIN, NPRVLT, CLCBAS, VATRUL
  # VPO 26/03/10 V6.2:60763 Settlements Discounts
  Actzo [M:PFI1]BPSORI, DEFVAL, DEPFLG
Endif
Affzo [M:PFI1]AMTCOD, INCDCR, DACLIN, DACORD, TRFINV, DSPLIN, NPRVLT, CLCBAS, VATRUL, VACITM, ZVACITM
# VPO 26/03/10 V6.2:60763 Settlements Discounts
Affzo [M:PFI1]BPSORI, DEFVAL, DEPFLG
End


Subprog AM_AMTCOD(VALEUR)
#-------------------------------------------#
# Chargement format de la valeur par défaut #
#-------------------------------------------#
Variable Integer VALEUR
If GMODU(6)=2   : # 102698 : Belgium Early discounts
  Local Decimal XDEFVAL : XDEFVAL=[M:PFI1]DEFVAL : Effzo [PFI1]DEFVAL : [M:PFI1]DEFVAL=XDEFVAL
  If VALEUR=1
    [M:PFI1]XFORMAT="NZ:3.2#" : DACLIN=1 : CLCBAS=2 : Actzo [PFI1]DSPLIN
    [M:PFI1]DEFVALCUR=""
  Else
    [M:PFI1]XFORMAT="NZ:"+[F:TCU]CURFMT1    : CLCBAS=1
    [M:PFI1]DEFVALCUR=GCUR
  Endif
  If DACLIN=1 & DSPLIN=1 [M:PFI1]VATRUL=2 : Endif
  Affzo [PFI1]DEFVAL, DEFVALCUR, XFORMAT, DACLIN, DSPLIN, CLCBAS, VATRUL
Endif
# end 102698
End

# 102698 : Belgium Early discounts
######################################## Sens
Subprog AM_INCDCR(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  # If Decrease : always subject to discount : The field musn't appear
  [M:PFI1]DEPFLG=2
  Chgfmt [M:PFI1]DEPFLG With "-LA:1"
Else
  # If Increase : can be both
  Chgfmt [M:PFI1]DEPFLG With "LA:1"
  Affzo [M:PFI1]DEPFLG
Endif
End
# 102698

Subprog AS_DACLIN(VALEUR)
#-----------------------------------------------------------------#
# Avant saisie "Présence ligne tarif" : Si taux --> pas de saisie #
#-----------------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]AMTCOD=1 VALEUR=1 : mkstat=2 : Endif
End


Subprog AM_DACLIN(VALEUR)
#-------------------------------------------------------------#
# Après modif. "Présence ligne tarif" :                       #
#   Si Oui --> Pied commande à Non et répartition à Non       #
#   Si Non et si répartition à Non --> Règle taxe à taux fixe #
#-------------------------------------------------------------#
Variable Integer VALEUR
If VALEUR=2 [M:PFI1]DACORD=1 : [M:PFI1]DSPLIN=1 : Affzo DACORD, DSPLIN : Endif
If VALEUR=1 & [M:PFI1]DSPLIN=1 [M:PFI1]NPRVLT=1 : Affzo NPRVLT
              [M:PFI1]VATRUL=2 : Affzo VATRUL : Endif
End


Subprog AS_DACORD(VALEUR)
#----------------------------------------------------------------------#
# Avant saisie "Présence pied commande" : Si ligne à oui pas de saisie #
#----------------------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]DACLIN=2 VALEUR=1 : mkstat=2 : Endif
End


Subprog AM_DACORD(VALEUR)
#----------------------------------------------#
# Après modification "Présence pied commande " #
#----------------------------------------------#
Variable Integer VALEUR
If VALEUR=1
  [M:PFI1]TRFINV=1 : Grizo [PFI1]TRFINV
Elsif [M:PFI1]AMTCOD=2
  Actzo [PFI1]TRFINV
Endif
End


Subprog AS_TRFINV(VALEUR)
#--------------------------------#
# Avant saisie du code transfert #
#--------------------------------#
Variable Integer VALEUR
#GMENLOC(3)=1 : # désactivation "Prorata poids"
#GMENLOC(4)=1 : # Désactivation "Prorata volumes"
End


Subprog AS_DSPLIN(VALEUR)
#------------------------------------------------------------------#
# Avant saisie "Répartition" : Si présence sur ligne tarif --> Non #
#------------------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]DACLIN=2 VALEUR=1 : mkstat=2 : Endif
End


Subprog AM_DSPLIN(VALEUR)
#----------------------------------------------------------------------#
# Après modif. "Répartition" :                                         #
#   Si Non et si présence ligne tarif à Non --> Règle taxe à taux fixe #
#----------------------------------------------------------------------#
Variable Integer VALEUR
If VALEUR=1 & [M:PFI1]DACLIN=1 : [M:PFI1]NPRVLT=1 : Affzo NPRVLT
              [M:PFI1]VATRUL=2 : Affzo VATRUL : Endif
End


Subprog AS_NPRVLT(VALEUR)
#----------------------------------------------------------------------#
# Avant saisie "Prix net valorisation" : Si pas de répartition --> Non #
#----------------------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]DSPLIN=1 & [M:PFI1]DACLIN=1 VALEUR=1 : mkstat=2 : Endif
End


Subprog AS_CLCBAS(VALEUR)
#-----------------------------------------------------------#
# Avant saisie "Base calcul" : Si Montant --> pas de saisie #
#-----------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]AMTCOD=2 : VALEUR=1 : mkstat=2 : Endif
# GMENLOC(1)=1 : # Pas conseillé sur les radio-boutons !
End


Subprog C_CLCBAS(VALEUR)
#------------------------#
# Contrôle "Base calcul" #
#------------------------#
Variable Integer VALEUR
If [M:PFI1]AMTCOD<>2 & VALEUR=1
  GMESSAGE=mess(6,199,1) : mkstat=1 : # Valeur incorrecte !
Endif
End


Subprog AM_CLCBAS(VALEUR)
#----------------------------------#
# Après modification "Base calcul" #
#----------------------------------#
Variable Integer VALEUR
If VALEUR=4
  Actzo [PFI1]ACTCLCBAS, PRGCLCBAS
Else
  Effzo [PFI1]ACTCLCBAS, PRGCLCBAS
  Grizo [PFI1]ACTCLCBAS, PRGCLCBAS
Endif
End


Subprog AS_VATRUL(VALEUR)
#--------------------------------------------------------------------#
# Avant saisie "Règle taxe" :                                        #
#  Si présence ligne tarif à Non et pas de répartition --> Taux fixe #
#--------------------------------------------------------------------#
Variable Integer VALEUR
If [M:PFI1]DACLIN=1 & [M:PFI1]DSPLIN=1 : VALEUR=2 : mkstat=2 : Endif
End


Subprog AM_VATRUL(VALEUR)
#----------------------------------------------------------------------#
# Après modif. "Règle taxe" : Si Produit --> pas de saisie Niveau taxe #
#----------------------------------------------------------------------#
Variable Integer VALEUR
If VALEUR=1 : Raz [M:PFI1]VACITM : Affzo [PFI1]VACITM : Endif
End


Subprog AS_VACITM(VALEUR)
#-----------------------------------------------------------------#
# Pas de saisie du niveau de taxe si la règle de taxe est produit #
#-----------------------------------------------------------------#
Variable Char    VALEUR()
If [M:PFI1]VATRUL=1 : VALEUR="" : mkstat=2 : Endif
End


Subprog C_VACITM(VALEUR)
#-----------------------------------------------------------#
# Contrôle "Niveau taxe" : Obligatoire si règle à taux fixe #
#-----------------------------------------------------------#
Variable Char    VALEUR()
If [M:PFI1]VATRUL=2 & VALEUR="" mkstat=1 : Endif
End


Subprog AM_DSP(VALEUR)
#--------------------------------------#
# Après modification "Clé répartition" #
#--------------------------------------#
Variable Char    VALEUR()
If dim([M:PFI1]NBAXE)>0
  If VALEUR<>""
    Effzo [PFI1]55 : Grizo [PFI1]55
  Else
    #----- Initialisation tableau des axes -----#
    If dim([M:PFI1]SOC)>0 & [M:PFI1]SOC<>""
      Call INIT_DIE(14,[M:PFI1]SOC,"PFI1","NBAXE") From TRTX3CPT
    Else
      Call INIT_DIE(14,"","PFI1","NBAXE") From TRTX3CPT
    Endif
    #-----
    Actzo [PFI1]55 : Affzo [PFI1]55
  Endif
Endif
End


Subprog AS_NBAXE
#--------------------#
# Avant saisie NBAXE #
#--------------------#
End


Subprog C_NBAXE
#----------------#
# Contrôle NBAXE #
#----------------#
If status<>1  & status<>4  & status<>5  & status<>20 & status<>21 &
&  status<>26 & status<>92 & status<>93 End : Endif
#----- Supprimé car les GANASAIx sont au niveau de la société -----#
# For nolign=1 To [M:PFI1]NBAXE
#   If CCE(nolign-1)="" & evalue("GANASAI"+num$(nolign))=2
#     GMESSAGE=mess(46,106,1)-num$(nolign) : # Section obligatoire sur axe
#     mkstat=1 : Break
#   Endif
# Next nolign
End


$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'un élément de facturation        #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File PFOOTINV [PFI1]
  Local File ATEXTRA  [AXX1]
Else
  Local File =[M]DOSORG+".PFOOTINV" [PFI1]
  Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
  Local File PFOOTINV [PFI2]
  Local File ATEXTRA  [AXX2]
Else
  Local File =[M]DOSDES+".PFOOTINV" [PFI2]
  Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
OK=1
Look [PFI2] PFI0=val(TABLE)
If !fstat
   OK= 2 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
   If OK<>2  OK=0 : Endif
Endif
If OK
  Gosub OUVDOS  From ATEXTRA
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
Endif
Close Local File [PFI1], [AXX1], [PFI2], [AXX2]
Return

$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'un élément de facturation #
#--------------------------------------------------#
GOK=1
Trbegin [PFI2]
  Delete [PFI2] Where PFINUM=val(TABLE)
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".PFOOTINV"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("PFI2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  Read [PFI1] PFI0=val(TABLE)
  If !fstat
    [F:PFI2]=[F:PFI1]
    Call COPTEXTRA("PFOOTINV","DESAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Call COPTEXTRA("PFOOTINV","SHOAXX",TABLE,"") From ATEXTRA
    If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Write [PFI2]
    If fstat GOK=0 : Call FSTA("PFI2") From GLOCK : Goto AB_COPIE : Endif
  Endif
Commit
Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback : Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif : Return
