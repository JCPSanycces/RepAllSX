#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MWA
# LE          : 28 Septembre 2010 17:46:47
# Moulinette pour l'objet DPM    
# FQ67545
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM017: DPM object upgrade") From LECFIC
  Call EXE_UTIIMM017(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
 Subprog EXE_UTIIMM017(APPLI)
 Value Char APPLI
  If clalev([F:ZAOL]) : Close Local File [ZAOL] : Endif
  Local File =APPLI+".AOBJLST" [ZAOL]
  Call ECR_TRACE("UTIIMM017: Process Start on : "+APPLI,0) From GESECRAN
  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM017
  Call ECR_TRACE("UTIIMM017: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM017

# ---------------------
  Trbegin [ZAOL]
  
  Read [F:ZAOL]AOL0="DPM"
  If fstat
   Call ECR_TRACE("Error : DPM object doesn't exist.",-1) From GESECRAN
   GOK=0 : Goto AB_UTIIMM017
  Endif 
  Raz [F:ZAOL]
  [F:ZAOL]ABREV     = "DPM"
  [F:ZAOL]DELDEF    = 1
  [F:ZAOL]NBSEL     = 3

  [F:ZAOL]SELEXP(0) = ""
  [F:ZAOL]SELEXP(1) = "string$([F:DPM]CPY='',mess(36,7770,1))+string$([F:DPM]CPY<>'',[F:CPY]CPY-[F:CPY]CPYSHO)"
  [F:ZAOL]SELEXP(2) = "[F:DPM]DPM-string$([F:DPM]DPRMODTYP=1,[F:DPM]DES)+string$([F:DPM]DPRMODTYP=2,mess(STDDPMNUM,3228,1))"
  [F:ZAOL]SELEXP(3) = ""
  [F:ZAOL]SELEXP(4) = ""
  [F:ZAOL]SELEXP(5) = ""

  [F:ZAOL]SELFIC(0) = "DPRMOD"
  [F:ZAOL]SELFIC(1) = ""
  [F:ZAOL]SELFIC(2) = ""
  [F:ZAOL]SELFIC(3) = ""
  [F:ZAOL]SELFIC(4) = ""
  [F:ZAOL]SELFIC(5) = ""

  [F:ZAOL]SELINT(0) = 0 
  [F:ZAOL]SELINT(1) = 0
  [F:ZAOL]SELINT(2) = 0
  [F:ZAOL]SELINT(3) = 0
  [F:ZAOL]SELINT(4) = 0
  [F:ZAOL]SELINT(5) = 0

  [F:ZAOL]SELLNG(2) = 30  

  [F:ZAOL]SELTYP(0) = ""
  [F:ZAOL]SELTYP(1) = "A"
  [F:ZAOL]SELTYP(2) = "A"
  [F:ZAOL]SELTYP(3) = ""
  [F:ZAOL]SELTYP(4) = ""

  [F:ZAOL]SELZON(0) = "DPRMODTYP"
  [F:ZAOL]SELZON(1) = ""
  [F:ZAOL]SELZON(2) = ""
  [F:ZAOL]SELZON(3) = ""
  [F:ZAOL]SELZON(4) = ""
  [F:ZAOL]SELZON(5) = ""

  Rewrite [F:ZAOL]

  If fstat
   GOK=0
   Call ECR_TRACE("   Error Rewrite [F:ZAOL] fstat="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("DPM object left list modified",0) From GESECRAN
  Endif

# ---------------------
  If !GOK Then
    Goto AB_UTIIMM017
  Else
    Commit
  Endif

  # Validation de l'objet
  Call VALFEN(APPLI,"DPM") From SUBAOB   
   
Return

$AB_UTIIMM017
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM017(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM017(APPLI)
End

