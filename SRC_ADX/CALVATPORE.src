#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
####################################################################################
### DVPB0 = DCLTYP+RECTYP+DCLNUM+NUM+LIN+DCLFLD+DCLPAG
### DCLTYP, DCLNUM feeded on CALVATPOR
### DCLFLD
### DCLPAG
####################################################################################
####################################################################################
$MAIN

GPOINT = "CTLCRY" : Gosub ENTREE From EXEFNC

Call DEBTRANS From GLOCK

Trbegin [F:DVPB], [F:DVPF], [F:DVPL]
Delete [F:DVPB] Where [F:DVPB]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPB",[L]DCLNUM) From GLOCK : Rollback : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPF",[L]DCLNUM) From GLOCK : Rollback : Return : Endif
Delete [F:DVPL] Where [F:DVPL]DCLNUM=[L]DCLNUM
If fstat = 1 : GOK=0 : Call RSTA("DVPL",[L]DCLNUM) From GLOCK : Rollback : Return : Endif

HAE_CRIT = '[F:HAE]ACCDAT>=['+format$(GFMD,[L]STRDAT)+'] & [F:HAE]ACCDAT<=['+format$(GFMD,[L]ENDDAT)+'] & [F:HAE]CPY="'+[L]CPY+'"'
Gosub FILL_DVPB
If GOK=0 : Rollback : Return : Endif
Commit

If [F:DVPH]FIRDCL <> 2

  Call DEBTRANS From GLOCK
  Trbegin [F:DVPB]

  [L]ICFLG = 1

  For [F:SIH2] Where find([F:SIH2]INVTYP, 2, 4) and [F:SIH2]ACCDAT>[L]ENDDAT & [F:SIH2]CPY = [L]CPY

    If [F:SIH2]PERDEB>=[L]STRDAT & [F:SIH2]PERFIN<=[L]ENDDAT
      HAE_CRIT = '[F:HAE]NUM="'+[F:SIH2]NUM+'"'
      Gosub FILL_DVPB
    Elsif [F:SIH2]ORIMOD = 3 & [F:SIH2]INVNUM <> ""
      Look [F:DVPB]DVPB4(2) = [L]DCLNUM;[F:SIH2]INVNUM
      If !fstat
        HAE_CRIT = '[F:HAE]NUM="'+[F:SIH2]NUM+'"'
        Gosub FILL_DVPB
      Endif
    Elsif [F:SIH2]ORIMOD = 5
      Raz [L]LASSIH
      Filter [F:SID2] Where [F:SID2]NUM = [F:SIH2]NUM & [F:SID2]SIHORINUM <> "" Order By [F:SID2]SIHORINUM
      For [F:SID2]
        If [L]LASSIH <> [F:SID2]SIHORINUM
          Look [F:DVPB]DVPB4(2) = [L]DCLNUM;[F:SID2]SIHORINUM
          If !fstat
            HAE_CRIT = '[F:HAE]NUM="'+[F:SIH2]NUM+'"'
            Gosub FILL_DVPB
          Endif
        Endif
        [L]LASSIH = [F:SID2]SIHORINUM
      Next
      Filter [F:SID2]
    Endif

  Next

  If GOK=0 : Rollback : Return : Endif
  Commit

Endif

For [F:DVPH2] Where [F:DVPH2]DCLTYP = 4 & [F:DVPH2]CPY = [L]CPY & [F:DVPH2]FIRDCL <> 2 & [F:DVPH2]ENDDAT<[L]STRDAT
  For [F:DVPB] Where [F:DVPB]DCLNUM = [L]DCLNUM & [F:DVPB]DCLFLD = "007"
    Look [F:DVPB2]DVPB4 = [F:DVPH2]DCLNUM;[F:DVPB]NUM;[F:DVPB]DCLFLD
    If !fstat : Delete [F:DVPB] Curr : Endif
  Next
Next

GOK = 1
Trbegin [F:DVPF], [F:DVPL]

Gosub PROC_LIST
If GOK=0 : Rollback : Return : Endif

Gosub PROC_FIELDS

If GOK=0 : Rollback : Return : Endif
Commit

Return
####################################################################################
####################################################################################
$FILL_DVPB

Link [F:HAE] With [F:SIH]SIH0=[F:HAE]NUM As [LHAE]
& Where evalue(HAE_CRIT)

Link [F:DAEP] With [F:GACP]GAC0=[L]COA;[F:DAEP]ACC, [F:BPR]BPR0 = [F:DAEP]BPR As [LDAEP]
& Where [F:DAEP]LEDTYP= [F:DVPP]LEDTYP & [F:GACP]FLGVAT = 2

[L]RMAX = rowcount([LHAE])

Call OUVRE_BOITE(mess(1,3614,1) - [L]DCLNUM,[L]RMAX) From GESECRAN

[L]RCOUNT = 0

For [LHAE]

  Gosub GETGTE From CALVATPOR

  If [F:GTE]VAT=2

    For [F:LDAEP] Where [F:DAEP]TYP=[F:HAE]TYP & [F:DAEP]NUM=[F:HAE]NUM

      Raz [L]EECNUM
      Gosub GET_EECNUM From CALVATPOR
      [L]DCLPAG = 1
      Gosub PROCESS_DAE
      If GOK=0 : Break 2 : Endif

    Next

   Endif

  [L]RCOUNT += 1
  If mod([L]RCOUNT,1000) = 2
    Call AFF_BOITE(mess(1,20,1),[L]RCOUNT,I) From GESECRAN
  Endif

Next

If clalev([F:LDAEP]) : Close File [LDAEP] : Endif
If clalev([F:LHAE])  : Close File [LHAE]  : Endif

Call FERME_BOITE From GESECRAN

Return
######################################################################################
######################################################################################
$PROCESS_DAE

If [F:GACP]FLGVAT=2 #Bases
  If  ([F:GACP]VATIPT=1 | [F:GACP]VATIPT >= 6) #& pat([F:GACP]ACC, left$([F:DVPP]SALGOOROT,1)+"*")

    #we will not separate by fiscal space, so all to main dec (dclpag = 1)
    If [L]INVFLD07 <> 2
      If (find([F:DAEP]TAX, VAT007(1,1..dim(VAT007,2)))                                             |
&       (find([F:DAEP]TAX,  VAT007(2,1..dim(VAT007,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)  |
&       (find([F:DAEP]TAX,  VAT007(3,1..dim(VAT007,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)) |
&       (find([F:DAEP]TAX,  VAT008T(1,1..dim(VAT008T,2)))                                           |
&       (find([F:DAEP]TAX,  VAT008T(2,1..dim(VAT008T,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)|
&       (find([F:DAEP]TAX,  VAT008T(3,1..dim(VAT008T,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)) &
&       [F:DAEP]TAX<>""
        [L]SNS = -1 : [L]DCLFLD = "07" : Gosub WRITE_DVPB : Return
      Endif
    Else
      If [L]CRY <> "PT" & [L]CEEFLG = 2 & [F:DAEP]TAX<>"" &
&       ((find([F:DAEP]TAX, VAT007(1,1..dim(VAT007,2)))                                             |
&       (find([F:DAEP]TAX,  VAT007(2,1..dim(VAT007,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)  |
&       (find([F:DAEP]TAX,  VAT007(3,1..dim(VAT007,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)) |
&       (find([F:DAEP]TAX,  VAT008(1,1..dim(VAT008,2)))                                            |
&       (find([F:DAEP]TAX,  VAT008(2,1..dim(VAT008,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4) |
&       (find([F:DAEP]TAX,  VAT008(3,1..dim(VAT008,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)))
        [L]SNS = -1 : [L]DCLFLD = "07" : Gosub WRITE_DVPB : Return
      Endif
    Endif
  Endif

Endif

Return
######################################################################################
######################################################################################
$WRITE_DVPB

Raz [F:DVPB]

[F:DVPB]DCLTYP    = 4            # European
[F:DVPB]DCLNUM    = [L]DCLNUM
[F:DVPB]DCLPAG    = [L]DCLPAG
[F:DVPB]NUM       = [F:DAEP]NUM
[F:DVPB]LIN       = [F:DAEP]LIN
[F:DVPB]DCLFLD    = format$("N0:3",[L]DCLFLD)
[F:DVPB]ACC       = [F:DAEP]ACC
[F:DVPB]AMTBAS    = [F:DAEP]AMTLED*[F:DAEP]SNS*[L]SNS
[F:DVPB]DCLFLDTYP = 2
[F:DVPB]ACCDAT    = [F:DAEP]ACCDAT
[F:DVPB]VAT       = [F:DAEP]TAX
[F:DVPB]EECNUM    = [L]EECNUM
If len([L]EECNUM)>=2
  [F:DVPB]CRY = left$([L]EECNUM, 2)
Endif
If pat([F:DVPB]ACC,[F:DVPP]SALSRVROT+"*")
  [F:DVPB]OPETYP  = 5
Else
  [F:DVPB]OPETYP  = 1
Endif

If find([F:DAEP]TAX,  VAT008T(1,1..dim(VAT008T,2)))                                           |
& (find([F:DAEP]TAX,  VAT008T(2,1..dim(VAT008T,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)|
& (find([F:DAEP]TAX,  VAT008T(3,1..dim(VAT008T,2))) & [F:DVPH]AN1LOC > 0 & [F:DVPH]AN1LOC < 4)
  [F:DVPB]OPETYP  = 4
Endif

#Issue X3-43022 – 2017-09-06  by VAVIL - Possibility to define different criteria on the services declaration for the operation type
[L]SPEOPETYP  = 0
GPOINT = "CALOPETYP" : Gosub ENTREE From EXEFNC
 If [L]SPEOPETYP > 0
  [F:DVPB]OPETYP = [L]SPEOPETYP
 Endif
#End issue X3-40802

Write [F:DVPB]
If fstat : GOK = 0 : Call FSTA("DVPB") From GLOCK : Return : Endif

Return
######################################################################################
######################################################################################
$PROC_LIST

[L]LINTYP = 11

Filter [F:DVPB] Where [F:DVPB]DCLNUM = [L]DCLNUM Order By Key LKEY = EECNUM;OPETYP

[L]RCOUNT = 1
[L]AMTBAS = 0
[L]EECNUM = ""
[L]OPETYP = 0

For [F:DVPB]LKEY

  If ([L]EECNUM <> [F:DVPB]EECNUM | [L]OPETYP <> [F:DVPB]OPETYP) & [L]OPETYP <> 0

    Gosub WRITE_DVPL : If GOK = 0 : Break : Endif
    [L]AMTBAS  = [F:DVPB]AMTBAS
    [L]RCOUNT += 1

  Else

    [L]AMTBAS += [F:DVPB]AMTBAS

  Endif

  [L]EECNUM = [F:DVPB]EECNUM
  [L]OPETYP = [F:DVPB]OPETYP

Next

Filter [F:DVPB]
If GOK = 0 : Return : Endif

If [L]AMTBAS <> 0 : Gosub WRITE_DVPL : Endif

Return
##################################################################################################
##################################################################################################
$WRITE_DVPL

If [L]AMTBAS = 0 : Return : Endif
Raz [F:DVPL]

[F:DVPL]DCLNUM = [L]DCLNUM
[F:DVPL]LINTYP = [L]LINTYP
[F:DVPL]LSTLIN = [L]RCOUNT
If len([L]EECNUM) >= 2
  [F:DVPL]CRY    = left$([L]EECNUM,2)
Endif
#[F:DVPL]EECNUM = [L]EECNUM
[F:DVPL]EECNUM = right$([L]EECNUM,3)
[F:DVPL]AMTBAS = arr([L]AMTBAS,1)
[F:DVPL]OPETYP = [L]OPETYP

Write [F:DVPL]
If fstat : GOK=0 : Call FSTA("DVPL") From GLOCK : Endif

Return
######################################################################################
######################################################################################
$PROC_FIELDS

Raz FLDARR

Delete [F:DVPF] Where [F:DVPF]DCLNUM = [L]DCLNUM & [F:DVPF]DCLFLD = format$("N0:3",10)
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM = [L]DCLNUM & [F:DVPF]DCLFLD = format$("N0:3",17)
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM = [L]DCLNUM & [F:DVPF]DCLFLD = format$("N0:3",18)
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif

For [F:DVPL] Where [F:DVPL]DCLNUM = [L]DCLNUM
  Case [F:DVPL]OPETYP
    When 1 : FLDARR(1, 10) += [F:DVPL]AMTBAS
    When 4 : FLDARR(1, 17) += [F:DVPL]AMTBAS
    When 5 : FLDARR(1, 18) += [F:DVPL]AMTBAS
  Endcase
Next

Gosub BUILD_FIELD_ARRAY

For I = 10 To 18
  If find(I,FLDLST(1, 1..dim (FLDARR, 2)))
    [F:DVPF]DCLNUM = [L]DCLNUM
    [F:DVPF]DCLPAG = 1
    [F:DVPF]DCLFLD = format$("N0:3",I)
    [F:DVPF]AMT    = FLDARR(1,I)
    Write [F:DVPF]
    If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Break : Endif
  Endif
Next

If GOK
  Gosub FIELD_TOTALS
Endif

Return
#################################################################################################
#################################################################################################
$FIELD_TOTALS

Raz FLDARR

Read [F:DVPF]DVPF0 = [L]DCLNUM;1;"010"
If !fstat : FLDARR(1,19) += [F:DVPF]AMT : Endif
Read [F:DVPF]DVPF0 = [L]DCLNUM;1;"011"
If !fstat : FLDARR(1,19) += [F:DVPF]AMT : Endif
Read [F:DVPF]DVPF0 = [L]DCLNUM;1;"018"
If !fstat : FLDARR(1,19) += [F:DVPF]AMT : Endif

#total field 19
Read [F:DVPF]DVPF0 = [L]DCLNUM;1;"019"
If fstat
  [F:DVPF]DCLNUM = [L]DCLNUM
  [F:DVPF]DCLPAG = 1
  [F:DVPF]DCLFLD = format$("N0:3",19)
  [F:DVPF]AMT    = FLDARR(1,19)
  Write [F:DVPF]
Else
  [F:DVPF]AMT    = FLDARR(1,19)
  Rewrite [F:DVPF]
Endif

If fstat
  GOK       = 0
  Call FSTA("DVPF") From GLOCK
  #GMESSAGE  = func AFNC.MES2(mess(230,111,1), num$(fstat), "19") #Error while writing field total (fstat = ).
Endif

Return
#################################################################################################
#################################################################################################
$BUILD_FIELD_ARRAY

Raz FLDLST

FLDLST(1, 10) = 10
#FLDLST(1, 11) = 11 we don't calculate it so we don't consider it
FLDLST(1, 17) = 17
FLDLST(1, 18) = 18
FLDLST(1, 19) = 19

Return
######################################################################################
######################################################################################
$WRITE_DVPF

Raz [F:DVPF]
[F:DVPF]DCLNUM = [L]DCLNUM
[F:DVPF]DCLPAG = 1
[F:DVPF]DCLFLD = format$("N0:3",10)
[F:DVPF]AMT    = FLDARR(1, 10)
Write [F:DVPF]
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif

Raz [F:DVPF]
[F:DVPF]DCLNUM = [L]DCLNUM
[F:DVPF]DCLPAG = 1
[F:DVPF]DCLFLD = format$("N0:3",17)
[F:DVPF]AMT    = FLDARR(1, 17)
Write [F:DVPF]
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif

Raz [F:DVPF]
[F:DVPF]DCLNUM = [L]DCLNUM
[F:DVPF]DCLPAG = 1
[F:DVPF]DCLFLD = format$("N0:3",18)
[F:DVPF]AMT    = FLDARR(1, 18)
Write [F:DVPF]
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif

Raz [F:DVPF]
[F:DVPF]DCLNUM = [L]DCLNUM
[F:DVPF]DCLPAG = 1
[F:DVPF]DCLFLD = format$("N0:3",19)
[F:DVPF]AMT    = FLDARR(1, 19)
Write [F:DVPF]
If fstat : GOK=0 : Call FSTA("DVPF") From GLOCK : Return : Endif

Return
######################################################################################
######################################################################################
$SET_CONTEXT

[L]DCLTYP = 1
Gosub SET_CONTEXT From CALVATPORP
[L]DCLTYP = 4

Return
######################################################################################
######################################################################################
$KILL_CONTEXT

[L]DCLTYP = 1
Gosub KILL_CONTEXT From CALVATPORP
[L]DCLTYP = 4

Return
######################################################################################
######################################################################################

