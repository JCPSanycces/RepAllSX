#<AdxTL>@(#)0.0.0.0 $Revision$

#----------------------------------------------------------
# HCB pour tester !!!!!!!!!!! A ENLEVER !!!!!!!!!!!!!!!!!!!!!
If clalev([F:SDH]) = 0 Local File SDELIVERY  [SDH] Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD [SDD] Endif
If clalev([F:PRH]) = 0 Local File STOPREH    [PRH] Endif
If clalev([F:PRE]) = 0 Local File STOPRED    [PRE] Endif

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SDH]
Local Integer WRET
#Call TRF_COLISAGE("GAL06-BP000074",1,"LIV-2006-0268",1000," ",WRET)
#Call TRF_COLISAGE("GAL06-BP000074",0,"LIV-2006-0268",0000," ",WRET)
#Call  SUP_COLISAGE(4,"SST-2003-0003",2000,"",WRET)

#Rollback
Commit

End



#########################################################################
# Traitements utilisés en préparation d'expéditions            STKPREPA #
#########################################################################
# Gosub
#-----------------------------------------------------------------------#
# ALL_SOQ_PRE  : allocation des préparations (de commandes)
# ALL_REO_PRE  : allocation des préparations (de réappro emp s-traitants
#                                             et manquants s-traitants)
# ENTETE_COLIS : maj entête colis suite à enreg ou supp d'un colisage
#########################################################################
# Subprog
#-----------------------------------------------------------------------#
# MAJ_SOQ      : maj des quantités (sur liste, en prépa et préparées)
#                d'une ligne de commande
# MAJ_REO      : maj de STOREO suite à traitement dans liste de prépa
# MAJ_STA      : maj de STOALL suite à traitement dans liste de prépa
# ALI_PCK      : alimentation code emballage et capacité
# CHARGETXTPRH : alimentation texte entete ou pied BP
# CHARGETXTPRE : alimentation texte détail BP
# TRF_COLISAGE : transfert du colisage d'un bon prépa vers un bon liv
# SUP_COLISAGE : suppression du colisage d'un document
# VERF_MODSTO  : recherche si le stock d'une ligne préparée ou livrée
#                a été modifié pour déterminer si le colisage de la ligne
#                doit être supprimé
#########################################################################

#########################################################################
# Allocation du detail preparation
# - commandes de vente
#########################################################################
$ALL_SOQ_PRE

Local Decimal WOALQTYSTU, WALLSTU, WSHTSTU
#--- Dem 67277
Local Integer WRUP
#--- Issue X3-72125
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
#---

#--- Issue 117979
If [F:PRE]QTYSTU=0 : Return : Endif

If [F:SOQ]SOHNUM<>[F:PRE]ORINUM | [F:SOQ]SOPLIN<>[F:PRE]ORILIN | [F:SOQ]SOQSEQ<>[F:PRE]ORISEQ
   Read [SOQ]SOQ0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
   If fstat
      Call RSTA("SOQ",[F:PRE]ORINUM-num$([F:PRE]ORILIN)-num$([F:PRE]ORISEQ)) From GLOCK
      GOK=0 : Return
   Endif
Endif
If [F:SOQ]SOHCAT=4
   Read [SOC]SOC0=[F:PRE]ORINUM;[F:PRE]ORILIN
   If fstat
      Call RSTA("SOC",[F:PRE]ORINUM-num$([F:PRE]ORILIN)) From GLOCK
      GOK=0 : Return
   Endif
Else
   Read [SOP]SOP0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
   If fstat
      Call RSTA("SOP",[F:PRE]ORINUM-num$([F:PRE]ORILIN)-num$([F:PRE]ORISEQ)) From GLOCK
      GOK=0 : Return
   Endif
Endif

#--- Dem 67277
If [F:ITM]ITMREF<>[F:PRE]ITMREF
   Read [ITM]ITM0=[F:PRE]ITMREF
Endif
#---

#--- Traitement des allocations detaillees
Raz [M:ALP]
WOALQTYSTU = 0
WALLSTU    = 0
WSHTSTU    = 0

# Si commande avec quantite allouee detaillee
# chargement de celle-ci (si livrable) dans STOSORW

#--- Issue 102520
#If [F:SOQ]ALLTYP=2 & [F:SOQ]ALLQTY<>0
If [F:SOQ]ALLTYP=2 & ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTYSTU<>0 & ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3))
#---

   # Chargement STOSORW a partir des allocations
   If [F:SOQ]SOHCAT=2
      [M:ALP]TRSTYP = 17
   Else
      [M:ALP]TRSTYP = 4
   Endif
   [M:ALP]VCRTYP    = 2
   [M:ALP]VCRNUM    = [F:PRE]ORINUM
   [M:ALP]VCRLIN    = [F:PRE]ORILIN
   [M:ALP]VCRSEQ    = [F:PRE]ORISEQ
   [M:ALP]STOFCY    = [F:SOQ]STOFCY
   [M:ALP]ITMREF    = [F:PRE]ITMREF
   [M:ALP]QTY       = [F:PRE]QTYSTU
   [M:ALP]TYPQTY    = 2
   [M:ALP]STA       = [F:SOQ]STA
   [M:ALP]PECSCOLOC = 1
   [M:ALP]PECQLYCTL = 1
   [M:ALP]BESDAT    = [F:SOQ]SHIDAT
   [M:ALP]DLVDAT    = [F:SOQ]DEMDLVDAT
   If dim([F:PRE]WRH)>0 [M:ALP]WRH=[F:PRE]WRH Endif
   #DLUBPC
   [M:ALP]BPRNUM    = [F:PRH]BPCORD
   Raz WRET

   #--- Issue 102520
   If ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
     WRUP=1
   Else
     WRUP=0
   Endif
   Call ALLSTOSORW("",1,0,WRUP,1,1,WRET) From STKSOR
   #Call ALLSTOSORW("",1,0,0,1,1,WRET) From STKSOR
   #---

   If WRET<>0 GOK=0 : Return Endif
   # Quantité allouée origine = qte allouée + qte rupture
   WOALQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
   # Quantités allouées prépa = qte allouée et qte rupture
   WALLSTU = [M:ALP]ALLQTY
   WSHTSTU = [M:ALP]ALLQTYSHT
   #--- Bug 73267
   # On ne vient pas du plan de préparation
   If GFONC1<>"FUNPREP"
      # Si bouton préparation depuis les commandes et quantité allouée
      # non préparable, alors on ne traite pas la ligne de commande
      If WALLSTU=0 & WSHTSTU=0 & [F:SOQ]ALLQTYSTU>=[F:PRE]QTYSTU
        [F:PRE]QTYSTU=0
      Endif
   Endif
   #---
Endif

# Si prepa avec alloc detaillees
# ou prepa avec alloc globales mais recuperation d'alloc detaillees
# de la commande (on force du detaille sur la prepa)
# --> Algorithme de determination du stock restant a allouer sur la
#     prepa et stockage dans STOSORW
If (WALLTYPFLG=2 | WOALQTYSTU<>0) & [F:PRE]QTYSTU>=WOALQTYSTU
   #--- Issue X3-72125
   If [F:SOQ]SOHCAT=4
      WSAU       = [F:SOC]SAU
      WSAUSTUCOE = [F:SOC]SAUSTUCOE
   Else
      WSAU       = [F:SOP]SAU
      WSAUSTUCOE = [F:SOP]SAUSTUCOE
   Endif
   #---
   If [F:PRE]QTYSTU>WOALQTYSTU
      # Chargement STOSORW par execution de l'algorithme
      If [F:SOQ]SOHCAT=2
         [M:ALP]TRSTYP = 17
      Else
         [M:ALP]TRSTYP = 4
      Endif
      [M:ALP]VCRTYP    = 4
      [M:ALP]STOFCY    = [F:SOQ]STOFCY
      [M:ALP]ITMREF    = [F:PRE]ITMREF
      [M:ALP]QTY       = [F:PRE]QTYSTU - WOALQTYSTU
      [M:ALP]TYPQTY    = 2
      If [F:SOQ]SOHCAT=4
         [M:ALP]PCU       = [F:SOC]SAU
         [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
      Else
         [M:ALP]PCU       = [F:SOP]SAU
         [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
      Endif
      [M:ALP]BESDAT    = [F:SOQ]SHIDAT
      [M:ALP]DLVDAT    = [F:SOQ]DEMDLVDAT
      [M:ALP]ALLDAT    = [0/0/0]
      [M:ALP]STOLOC    = ""
      [M:ALP]PECINTLOC = 2
      [M:ALP]PECSCOLOC = 1
      [M:ALP]PECPLFLOC = 2
      [M:ALP]PECCUNLOK = 1
      [M:ALP]FILSTO    = ""
      [M:ALP]LOT       = [F:SOQ]LOT
      [M:ALP]LOC       = [F:SOQ]LOC
      [M:ALP]STA       = [F:SOQ]STA
      #DLUBPC
      [M:ALP]BPRNUM    = [F:SOH]BPCORD
      If dim([F:PRE]WRH)>0 [M:ALP]WRH=[F:PRE]WRH Endif
      Raz [M:ALP]ALLQTY
      # Si allocation globale, on passe la qte deja allouee en global
      If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ]ALLQTYSTU Endif
      # On genere toujours les ruptures
      Raz WRET
      #--- Dem 67277
      WRUP=0
      If ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3 | find([F:PRE]LINTYP,3,4,5,11,12,13)
         WRUP=1
      Endif
      #--- 73751
      # Si on vient du plan de préparation
      If GFONC1="FUNPREP"
         [M:ALP]TRSCOD=[F:PRH]TRSCOD
      Elsif dim([M:PRH0]TRSCOD)>0
         [M:ALP]TRSCOD=[M:PRH0]TRSCOD
      Endif
      #---
      Call GENSTOSORW("",1,0,WRUP,"C",WRET) From STKSOR
      #Call GENSTOSORW("",1,0,1,"C",WRET) From STKSOR
      #---
      If WRET<>0  GOK=0 : Return  Endif
      # Si cde alloué en global
      #    si on a alloué au moins la qté allouée initiale de la commande,
      #    alors, quantite allouee origine += qte allouee initiale
      #    sinon, quantite allouee origine += qte allouee sur la prépa
      If [F:SOQ]ALLTYP=1
         #--- Issue 104057
         If WRUP=1
            If [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT>=[F:SOQ]ALLQTYSTU+[F:SOQ]SHTQTYSTU
               WOALQTYSTU += [F:SOQ]ALLQTYSTU+[F:SOQ]SHTQTYSTU
            Else
               WOALQTYSTU += [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            Endif
         Else
         #---
            If [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT>=[F:SOQ]ALLQTYSTU
               WOALQTYSTU += [F:SOQ]ALLQTYSTU
            Else
               WOALQTYSTU += [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            Endif
         #--- Issue 104057
         Endif
      Endif
      # Incrémentation quantités allouées prépa
      WALLSTU += [M:ALP]ALLQTY
      WSHTSTU += [M:ALP]ALLQTYSHT
   Endif

   #--- Issue X3-72125 : replace [F:SOP]SAU and SAUSTUCOE by WSAU and WSAUSTUCOE
   #--- Issue 121743
   WQTYSTU = WALLSTU+WSHTSTU
   WQTY    = WQTYSTU/WSAUSTUCOE
   #--- Issue X3-66573
   Call QTEARR(WQTY, WSAU) From TRTDIV
   # Réajustement qté en unité vente entière
   Gosub REAJUSTE_QTY
   # Si la qté a été réajustée, il faut diminuer STOSORW en conséquence
   If WQTYSTU < WALLSTU+WSHTSTU
     WQTA = WALLSTU+WSHTSTU-WQTYSTU
     Call DIM_STOSORW(1,"",[M:ALP]STOFCY,WQTA,WRET) From STKSOR
     If WQTA <= WSHTSTU
       WSHTSTU -= WQTA
     Else
       WALLSTU -= WQTA-WSHTSTU
       WSHTSTU  = 0
     Endif
   Endif
   #--- End issue 121743

   #--- Issue 103798
   # Ecriture des allocations detaillees a partir de STOSORW
   #If WALLSTU+WSHTSTU>0
   # Si livraison ligne ou  cde complète et qté non totalement allouée
   If WALLSTU+WSHTSTU>0 & [F:SOH]DME>1 & [F:PRE]QTYSTU>WALLSTU+WSHTSTU
      [F:PRE]QTYSTU = 0
      GMESSAGE=[F:SOQ]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(44,192,1)
      If GTRACE=""
         Call ERREUR(GMESSAGE) From GESECRAN
      Else
         Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Endif
      Raz GMESSAGE
      Return
   Elsif WALLSTU+WSHTSTU>0
   #---

      [M:ALP]VCRTYP    = 3
      [M:ALP]VCRNUM    = [F:PRE]PRHNUM
      [M:ALP]VCRLIN    = [F:PRE]PRELIN
      [M:ALP]VCRSEQ    = 0
      [M:ALP]STOFCY    = [F:SOQ]STOFCY
      [M:ALP]ITMREF    = [F:PRE]ITMREF
      [M:ALP]TYPQTY    = 2
      [M:ALP]BESDAT    = [F:SOQ]SHIDAT
      Raz [M:ALP]ALLDAT, [M:ALP]DESQTY, [M:ALP]ALLQTY
      # Avec desallocation commande origine
      [M:ALP]VCRTYPORI  = 2
      [M:ALP]VCRNUMORI  = [F:SOQ]SOHNUM
      [M:ALP]VCRLINORI  = [F:SOQ]SOPLIN
      [M:ALP]VCRSEQORI  = [F:SOQ]SOQSEQ
      [M:ALP]ALLTYPORI  = [F:SOQ]ALLTYP

      #[M:ALP]QTY        = WOALQTYSTU
      [M:ALP]QTY        = WALLSTU+WSHTSTU

      Raz [M:ALP]MVTDES
      # Mise a jour des allocations a partir de l'ecran de travail STOSORW
      # Avec desallocation commande origine
      Call ENRSTOALL(1,1,WRET) From STKALL
      If WRET<>0 GOK=0 : Return Endif
   #--- Dem 67277
   Else
      [F:PRE]QTYSTU = 0
      GMESSAGE=[F:SOQ]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(156,191,1)+
&              "\"+mess(126,192,1)
      #--- Bug 80279
      #Call ERREUR(GMESSAGE) From GESECRAN
      If GTRACE=""
         Call ERREUR(GMESSAGE) From GESECRAN
      Else
         Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Endif
      #---
      Raz GMESSAGE
      #GOK=0           : #--- Issue 93664 puis 97221
      Return
   #---
   Endif
   [F:PRE]ALLTYP = 2
   [F:PRE]ALLQTY = [M:ALP]ALLQTY
   [F:PRE]SHTQTY = [M:ALP]ALLQTYSHT
   #--- Dem 67277
   [F:PRE]QTYSTU = [F:PRE]ALLQTY+[F:PRE]SHTQTY

   [F:PRE]OALQTYSTU = WOALQTYSTU
#--- Traitement des allocations globales
Else
   # Si commande avec allocation globale, on la diminue ou supprime
   # WOALQTYSTU contient la quantite desallouee
   If [F:SOQ]ALLTYP=1 & ([F:SOQ]ALLQTY<>0 | [F:SOQ]SHTQTY<>0)
      Call DIMALL(2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,[F:SOQ]ITMREF,
&                 3,[F:PRE]QTYSTU,[M:ALP]DESQTY,[M:ALP]DESQTYSHT,WRET) From STKALL
      If WRET<>0 GOK=0 : Return Endif
      WOALQTYSTU = [M:ALP]DESQTY + [M:ALP]DESQTYSHT
   Endif

   # Pour livraison de pret ou classique
   If [F:SOQ]SOHCAT=2
      [M:ALP]TRSTYP = 17
   Else
      [M:ALP]TRSTYP = 4
   Endif
   # Preparation
   [M:ALP]VCRTYP    = 3
   [M:ALP]VCRNUM    = [F:PRE]PRHNUM
   [M:ALP]VCRLIN    = [F:PRE]PRELIN
   [M:ALP]VCRSEQ    = 0
   [M:ALP]STOFCY    = [F:SOQ]STOFCY
   [M:ALP]ITMREF    = [F:PRE]ITMREF
   [M:ALP]QTY       = [F:PRE]QTYSTU
   [M:ALP]TYPQTY    = 2
   If [F:SOQ]SOHCAT=4
      [M:ALP]PCU       = [F:SOC]SAU
      [M:ALP]PCUSTUCOE = [F:SOC]SAUSTUCOE
   Else
      [M:ALP]PCU       = [F:SOP]SAU
      [M:ALP]PCUSTUCOE = [F:SOP]SAUSTUCOE
   Endif
   [M:ALP]BESDAT    = [F:SOQ]SHIDAT
   [M:ALP]DLVDAT    = [F:SOQ]DEMDLVDAT
   [M:ALP]ALLDAT    = [0/0/0]
   [M:ALP]STOLOC    = ""
   [M:ALP]PECRER    = 1
   [M:ALP]PECINTLOC = 2
   [M:ALP]PECSCOLOC = 1
   [M:ALP]PECPLFLOC = 2
   [M:ALP]PECCUNLOK = 1
   [M:ALP]PECQLYCTL = 1
   [M:ALP]FILSTO    = ""
   [M:ALP]LOT       = [F:SOQ]LOT
   [M:ALP]LOC       = [F:SOQ]LOC
   [M:ALP]STA       = [F:SOQ]STA
   #DLUBPC
   [M:ALP]BPRNUM    = [F:SOH]BPCORD
   If dim([F:PRE]WRH)>0 [M:ALP]WRH=[F:PRE]WRH Endif
   Raz [M:ALP]ALLQTY
   # On genere toujours les ruptures
   Raz WRET
   #--- Dem 67277
   WRUP=0
   If ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3 | find([F:PRE]LINTYP,3,4,5,11,12,13)
      WRUP=1
   Endif
   Call GENSTOALL("C",1,WRUP,0,WRET) From STKALL
   #Call GENSTOALL("C",1,1,0,WRET) From STKALL
   #---
   If WRET<>0  GOK=0 : Return  Endif

   [F:PRE]ALLTYP = 1
   [F:PRE]ALLQTY = [M:ALP]ALLQTY
   [F:PRE]SHTQTY = [M:ALP]ALLQTYSHT
    #--- Dem 67277
   [F:PRE]QTYSTU = [F:PRE]ALLQTY+[F:PRE]SHTQTY

   [F:PRE]OALQTYSTU = WOALQTYSTU
Endif

$FIN_ASP
#----------------------------
# Mise a jour de la commande
# [M:ALP]DESQTY & DESQTYSHT contiennent les qtes desallouees de la cde
#----------------------------
WALLSTU = max(0,[F:SOQ]ALLQTYSTU-[M:ALP]DESQTY)
WSHTSTU = max(0,[F:SOQ]SHTQTYSTU-[M:ALP]DESQTYSHT)
Call MAJALLORD([F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,[F:SOQ]ALLTYP,
&              1,WALLSTU,WSHTSTU,WRET) From TRTVENALL
If WRET<>0  GOK=0 : Return  Endif

Return

#########################################################################
# Allocation du detail preparation
# - reapprovisionnement emplacements sous-traitants
# - manquants sous-traitants
#########################################################################
$ALL_REO_PRE

If [F:PRW]ORITYP=3
   Read [REO]REO0=[F:PRW]STOFCY;[F:PRE]REOLOC;[F:PRE]ITMREF
   If fstat
      Call RSTA("REO",[F:PRW]STOFCY-[F:PRE]REOLOC-[F:PRE]ITMREF) From GLOCK
      GOK=0 : Return
   Endif
Endif

Raz [M:ALP]
# Pour livraison sous-traitance
[M:ALP]TRSTYP    = 20
# Preparation
[M:ALP]VCRTYP    = 3
[M:ALP]VCRNUM    = [F:PRE]PRHNUM
[M:ALP]VCRLIN    = [F:PRE]PRELIN
[M:ALP]STOFCY    = [F:PRW]STOFCY
[M:ALP]ITMREF    = [F:PRE]ITMREF
If [F:PRW]ORITYP=3
   [M:ALP]PCU       = [F:REO]PCU
   [M:ALP]PCUSTUCOE = [F:REO]PCUSTUCOE
Else
   [M:ALP]PCU       = [F:PRE]STU
   [M:ALP]PCUSTUCOE = 1
Endif
[M:ALP]QTY       = [F:PRE]QTYSTU
[M:ALP]TYPQTY    = 2
[M:ALP]BESDAT    = [F:PRW]SHIDAT
[M:ALP]DLVDAT    = [F:PRW]DLVDAT
[M:ALP]ALLDAT    = [31/12/2999]
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 2    : # Prise en cpte empl interne : Oui
[M:ALP]PECSCOLOC = 1    : # Prise en cpte empl sous-traitant : Non
[M:ALP]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALP]PECCUNLOK = 1    : # Prise en cpte stock en cours inventaire : Non
[M:ALP]PECQLYCTL = 1    : # Prise en cpte stock en demande d'analyse: Non
If dim([F:PRE]WRH)>0 [M:ALP]WRH=[F:PRE]WRH Endif
Raz [M:ALP]ALLQTY
# On genere toujours les ruptures
Raz WRET
# Algorithme d'allocation
Call GENSTOALL("C",WALLTYPFLG,1,0,WRET) From STKALL
If WRET<>0  GOK=0 : Return  Endif

[F:PRE]ALLTYP = WALLTYPFLG
[F:PRE]ALLQTY = [M:ALP]ALLQTY
[F:PRE]SHTQTY = [M:ALP]ALLQTYSHT

Return


########################################################################
# MAJ_SOQ    Mise a jour des quantites (sur liste,en prépa et préparées)
#            d'une ligne de commande
########################################################################
Subprog MAJ_SOQ (WTYP,WORINUM,WORILIN,WORISEQ,WPCU,WPCUSTUCOE,WDELTAQTY)
Value    Integer WTYP
Value    Char    WORINUM
Value    Integer WORILIN
Value    Integer WORISEQ
Value    Char    WPCU
Value    Decimal WPCUSTUCOE
Value    Decimal WDELTAQTY

Local    Integer WRET
Local    Decimal WSALSTOSTU : Raz WSALSTOSTU

#--- Issue 122584
# Si entête commande bloquée logiquement --> Abandon
Local Char SYMBOLE1(50)
SYMBOLE1="SOH"+WORINUM : Lock=SYMBOLE1
If fstat
  GMESSAGE="$SORDER"-WORINUM-mess(10,100,1)
  GOK=0 : End
Endif
#---

#--- Issue 119042 ajout du lockwait
Readlock [SOQ]SOQ0=WORINUM;WORILIN;WORISEQ With lockwait=3
If fstat=1
   GLOCK="$SORDERQ"+WORINUM-num$(WORILIN)-num$(WORISEQ)
   GOK=-1 : End
Elsif fstat
   Call RSTA("SOQ",WORINUM-num$(WORILIN)-num$(WORISEQ)) From GLOCK
   GOK=0  : End
Endif
# Maj quantité sur liste de préparation
If WTYP=1
   # Si article non géré en stock et augmentation qté liste, maj qté à livrer
   If [F:SOQ]STOMGTCOD<2 & WDELTAQTY>0
      [F:SOQ]TDLQTYSTU -= min([F:SOQ]TDLQTYSTU,WDELTAQTY)
      [F:SOQ]TDLQTY     = [F:SOQ]TDLQTYSTU*(1/WPCUSTUCOE)
   Endif
   [F:SOQ]LPRQTYSTU += WDELTAQTY
   [F:SOQ]LPRQTY     = [F:SOQ]LPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]LPRQTY,WPCU) From TRTDIV
   WSALSTOSTU=WDELTAQTY
# Maj quantité en prépa (en créa/supp BP non livrable depuis liste prépa)
Elsif WTYP=2
   [F:SOQ]LPRQTYSTU -= WDELTAQTY
   [F:SOQ]LPRQTY     = [F:SOQ]LPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]LPRQTY,WPCU) From TRTDIV
   [F:SOQ]OPRQTYSTU += WDELTAQTY
   [F:SOQ]OPRQTY     = [F:SOQ]OPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]OPRQTY,WPCU) From TRTDIV
# Maj quantité préparée (suite à bouton 'Livrable')
Elsif WTYP=3
   [F:SOQ]OPRQTYSTU  = max(0,[F:SOQ]OPRQTYSTU-WDELTAQTY)
   [F:SOQ]OPRQTY     = [F:SOQ]OPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]OPRQTY,WPCU) From TRTDIV
   [F:SOQ]PREQTYSTU += WDELTAQTY
   [F:SOQ]PREQTY     = [F:SOQ]PREQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]PREQTY,WPCU) From TRTDIV
# Maj quantité en prépa (en modification BP)
Elsif WTYP=4
   [F:SOQ]OPRQTYSTU += WDELTAQTY
   [F:SOQ]OPRQTY     = [F:SOQ]OPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]OPRQTY,WPCU) From TRTDIV
   WSALSTOSTU=WDELTAQTY
# Maj quantité préparée (en modification BP)
Elsif WTYP=5
   [F:SOQ]PREQTYSTU += WDELTAQTY
   [F:SOQ]PREQTY     = [F:SOQ]PREQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]PREQTY,WPCU) From TRTDIV
# Maj quantité préparée (en suppression BP livrable depuis liste prépa)
Elsif WTYP=6
   [F:SOQ]LPRQTYSTU -= WDELTAQTY
   [F:SOQ]LPRQTY     = [F:SOQ]LPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]LPRQTY,WPCU) From TRTDIV
   [F:SOQ]PREQTYSTU += WDELTAQTY
   [F:SOQ]PREQTY     = [F:SOQ]PREQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]PREQTY,WPCU) From TRTDIV
#--- Dem 67277
# Maj quantité en prépa (en créa non livrable depuis liste prépa)
Elsif WTYP=7
   [F:SOQ]LPRQTYSTU -= [F:PRL]QTYSTU
   [F:SOQ]LPRQTY     = [F:SOQ]LPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]LPRQTY,WPCU) From TRTDIV
   [F:SOQ]OPRQTYSTU += WDELTAQTY
   [F:SOQ]OPRQTY     = [F:SOQ]OPRQTYSTU*(1/WPCUSTUCOE)
   Call QTEARR([F:SOQ]OPRQTY,WPCU) From TRTDIV
#---
Endif

Rewrite [SOQ]
If fstat
   GOK=0 : Call FSTA("SOQ") From GLOCK : End
Endif

# hcb 103129 deb
SYMBOLE2 = "SOQ"+WORINUM+"\"+num$(WORILIN)+"\"+num$(WORISEQ)
Unlock = SYMBOLE2
# hcb 103129 fin

#--- Issue 122584
SYMBOLE1="SOH"+WORINUM
Unlock=SYMBOLE1
#---

#--------------
# Gestion des signatures : Si la cde n'est pas si signée et pas de maj des encours si cde non signée
# --> Il faut modifier l'encde
Read [SOH]SOH0=WORINUM
If fstat
   Call RSTA("SOH",WORINUM) From GLOCK
   GOK=0  : End
Endif

If [F:SOH]APPFLG=1 & GSOHAPPORD=1 & WSALSTOSTU<>0
    #----------------------------------------------------#
    # Maj de l'en-cde client dans les mouvements article #
    #----------------------------------------------------#
    Local Char WSENS
    WSENS = "+"
    If WSALSTOSTU<0
        WSALSTOSTU = WSALSTOSTU*(-1)
        WSENS   = "-"
    Endif
    Call  MAJITVVEN ([F:SOQ]ITMREF, [F:SOQ]STOFCY, WSALSTOSTU, WSENS, "S", WRET) From TRTVENMAJ
    #--- Issue 119388
    #If GOK<=0  Return : Endif
    If GOK<=0  End : Endif
    #---
Endif
#--------------

#--- Maj de l'en-cours
If [F:SOQ]STOMGTCOD <> 1
   Local Integer WMAJMTO

   WCPLQTY = [F:SOQ]DLVQTYSTU
   WTRTORD = "M"
   Gosub APPELWIP From TRTVENMAJ
   If GOK < 1 End Endif

   # GH 02/07/2014 bug 93888
   If WMAJMTO
      Gosub MAJ_MTO_SOQ From SALMTOLIB
   Endif
Endif

End

#########################################################################
# Maj de STOREO suite a traitement dans liste de preparation
#########################################################################
Subprog MAJ_REO (WMAJ,WSTOFCY,WITMREF,WREOLOC,WDELTAQTY)
Value    Integer WMAJ
Value    Char    WSTOFCY
Value    Char    WITMREF
Value    Char    WREOLOC
Value    Decimal WDELTAQTY

Readlock [REO]REO0=WSTOFCY;WREOLOC;WITMREF
If fstat=1
   GLOCK="$STOREO"+WSTOFCY-WREOLOC-WITMREF
   GOK=-1 : End
Elsif fstat
   Call RSTA("REO",WSTOFCY-WREOLOC-WITMREF) From GLOCK
   GOK=0  : End
Endif

# Création et quantité déjà en cours de préparation
If [F:REO]STAFLG=2 | (WMAJ=1 & [F:REO]QTYSTUORIA<>0)
   Call ERREUR(WSTOFCY-WREOLOC-WITMREF-":"-mess(10,100,1)) From GESECRAN
   GOK=0 : End
Endif

# Suppression
If WMAJ=3
   [F:REO]QTYSTUORIA = 0
Else
   [F:REO]QTYSTUORIA+= WDELTAQTY
   If [F:REO]QTYSTUORIA<0
      [F:REO]QTYSTUORIA=0
   Endif
Endif

Rewrite [REO]
If fstat
   GOK=0 : Call FSTA("REO") From GLOCK : End
Endif

End

#########################################################################
# Maj de STOALL suite a traitement dans liste de preparation
#########################################################################
Subprog MAJ_STA (WMAJ,WSTOFCY,WITMREF,WSEQ,WDELTAQTY)
Value    Integer WMAJ
Value    Char    WSTOFCY
Value    Char    WITMREF
Value    Integer WSEQ
Value    Decimal WDELTAQTY

Readlock [STA]STA0=WSTOFCY;WITMREF;0;WSEQ
If fstat=1
   GLOCK="$STOALL"+WSTOFCY-WITMREF-"0"-num$(WSEQ)
   GOK=-1 : End
Elsif fstat
   #--- Issue 92269
   # Si suppression d'un BP, pas d'erreur
   If WMAJ=3 : End : Endif
   #---
   #--- Bug 72079
   #Call RSTA("REO",WSTOFCY-WITMREF-"0"-num$(WSEQ)) From GLOCK
   Call RSTA("STA",WSTOFCY-WITMREF-"0"-num$(WSEQ)) From GLOCK
   #---
   GOK=0  : End
Endif

# Création et quantité déjà en cours de préparation
If WMAJ=1 & [F:STA]SRGQTYSTU<>0
   Call ERREUR(WSTOFCY-WITMREF-"0"-num$(WSEQ)-":"-mess(10,100,1)) From GESECRAN
   GOK=0  : End
Endif

# Suppression
If WMAJ=3
   [F:STA]SRGQTYSTU = 0
Else
   [F:STA]SRGQTYSTU+= WDELTAQTY
   If [F:STA]SRGQTYSTU<0
      [F:STA]SRGQTYSTU=0
   Endif
Endif

Rewrite [STA]
If fstat
   GOK=0 : Call FSTA("STA") From GLOCK : End
Endif

End

#########################################################################
# Alimentation du code emballage et de sa capacité
#########################################################################
Subprog ALI_PCK (WSTOFCY,WITMREF,WBPCORD,WPCU,WPCUSTUCOE,WPCK,WPCKCAP)
Value    Char    WSTOFCY
Value    Char    WITMREF
Value    Char    WBPCORD
Value    Char    WPCU
Value    Decimal WPCUSTUCOE
Variable Char    WPCK
Variable Decimal WPCKCAP

If clalev([F:ITM]) = 0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITG]) = 0 Local File ITMCATEG   [ITG] : Endif
If clalev([F:ITU]) = 0 Local File ITMBPC     [ITU] : Endif

Raz WPCK
Raz WPCKCAP

Read [ITU]ITU0=WITMREF;WBPCORD
If !fstat & [F:ITU]SAU=WPCU & [F:ITU]SAUSTUCOE=WPCUSTUCOE
   WPCK    = [F:ITU]PCK
   WPCKCAP = [F:ITU]PCKCAP
Endif
If WPCK=""
   If [F:ITM]ITMREF<>WITMREF
      Read [ITM]ITM0=WITMREF
      If fstat Raz [F:ITM] Endif
   Endif
   #--- Lecture article site
   Read [ITF]ITF0=WITMREF;WSTOFCY
   If !fstat & [F:ITM]SAU=WPCU & [F:ITM]SAUSTUCOE=WPCUSTUCOE
      WPCK    = [F:ITF]PCK
      WPCKCAP = [F:ITF]PCKCAP
   Else
      #--- Lecture catégorie article/site
      Read [ITG]ITG1=[F:ITM]TCLCOD;WSTOFCY
      If !fstat & [F:ITG]SAU=WPCU & [F:ITG]SAUSTUCOE=WPCUSTUCOE
         WPCK    = [F:ITG]PCK
         WPCKCAP = [F:ITG]PCKCAP
      Else
         Read [ITG]ITG1=[F:ITM]TCLCOD;""
         If !fstat & [F:ITG]SAU=WPCU & [F:ITG]SAUSTUCOE=WPCUSTUCOE
            WPCK    = [F:ITG]PCK
            WPCKCAP = [F:ITG]PCKCAP
         Endif
      Endif
   Endif
Endif

End

#-------------------------------------#
# Charge des textes entete et pied BP #
#-------------------------------------#
Subprog CHARGETXTPRH(LBPC,LADD)
Value Char LBPC
Value Char LADD

# ---   Suivi texte préparation du client livré sur entête BP : Duplication
If [F:BPD]BPCNUM<>LBPC | [F:BPD]BPAADD<>LADD
   Read [BPD]BPD0=LBPC;LADD
   If fstat Raz [F:BPD] Endif
Endif

If GSALTEXPRP=1 & [F:BPD]PRPTEX<>""
   [F:PRH]PRPTEX1=[F:BPD]PRPTEX
Elsif GSALTEXPRP=2 & [F:BPD]PRPTEX<>""
   [F:PRH]PRPTEX2=[F:BPD]PRPTEX
Endif

End

#-------------------------------------#
# Charge des textes lignes BP         #
#-------------------------------------#
Subprog CHARGETXTPRE(LBPC,LITM)
Value Char LBPC
Value Char LITM

# ---   Suivi texte préparation de l'article sur ligne BP : Duplication
If [F:ITS]ITMREF<>LITM
   Read [ITS]ITS0=LITM
   If fstat Raz [F:ITS] Endif
Endif
If [F:ITU]ITMREF<>LITM | [F:ITU]BPCNUM<>LBPC
   Read [ITU]ITU0=LITM;LBPC
   If fstat Raz [F:ITU] Endif
Endif

[F:PRE]PRPTEX=[F:ITU]ITPTEX
If [F:PRE]PRPTEX=""
   [F:PRE]PRPTEX=[F:ITS]ITPTEX
Endif

End

######################################################################################
# TRF_COLISAGE  Transfert du colisage d 1 preparation vers la livraison correspondante
#        Si LPRELIN et LSDDLIN <> 0
#           - Réécriture  SPACKD      avec : vcrtyp vcrnum vcrlin de la livraison
#           - Réécriture  SFELIVERYD  avec : pacqtystu = pacqtystu de STOPRED
#           - Réécriture  STOPRED     avec : pacqtystu = 0
#        Si LPRELIN et LSDDLIN = 0
#           - Réécriture  SPACK       avec : vcrtyp vcrnum de la livraison
#           - Maj         SDELIVERY   avec : pacflg pacnbr netwei growei vol vou
######################################################################################
# Paramètres E : LPRHNUM = N° Préparation
#                LPRELIN = N° Ligne préparation
#                LSDHNUM = N° Livraison
#                LSDDLIN = N° Ligne Livraison
#                LSUP    = Inutilisé (paramètre supplémentaire au cas où)
#                MAE, le 03/11/08, utilisation du paramétre sup pour le traitement de livraison massif des BP (avec LPRELIN=0 et LSDDLIN=0)
#                LSUP = "PRH" => maj de l'entête du BP et de l'entête du colisage
#                LSUP = "SDH" => maj de l'entête de la livraison uniquement
#            S : LRET    = Code retour : (0=OK / 1=Erreur)
#
# Prérequis    : Ces tables doivent être ouvertes
#                           si Type document = 3    STOPREH
#                                                   STOPRED
#                           si Type document = 4    SDELIVERY
#                                                   SDELIVERYD
######################################################################################
Subprog TRF_COLISAGE(LPRHNUM,LPRELIN,LSDHNUM,LSDDLIN,LSUP,LRET)
Value    Char     LPRHNUM
Value    Integer  LPRELIN
Value    Char     LSDHNUM
Value    Integer  LSDDLIN
Value    Char     LSUP
Variable Integer  LRET

Local Integer  OUVRE_SPH
Local Integer  OUVRE_SPD
Local Integer  LPACFLG   # flag colisage  2 = complet
Local Integer  LPACNBR   # nombre de colis
Local Decimal  LNETWEI   # Poids net du document
Local Decimal  LGROWEI   # Poids brut du document
Local Char     LWEU      # Unité de poids du document
Local Decimal  LVOL      # Volume du document
Local Char     LVOU      # Unité de volume du document
Local Integer  WOK
Local Decimal  WPCKPRI
Local Integer  WSTAT
Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
Raz OUVRE_SPH
Raz OUVRE_SPD
Raz GMESSAGE

If clalev([F:SPH]) = 0
   Local File SPACK  [SPH]
   OUVRE_SPH = 2
Endif
If clalev([F:SPD]) = 0
   Local File SPACKD [SPD]
   OUVRE_SPD = 2
Endif

If (LPRELIN = 0 & LSDDLIN <> 0) | (LPRELIN <> 0 & LSDDLIN = 0)
   GMESSAGE=mess(1,137,1)   # erreur interne !
   Goto TRF_COLISAGE_ERR
Endif

If LPRELIN <> 0
# ****                                 ligne renseignée    ****
# reecriture SPACKD      (ligne detail colisage)
   Update [SPD] Where VCRTYP = 3
&                   & VCRNUM = LPRHNUM
&                   & VCRLIN = LPRELIN
&               With  VCRTYP = 4,
&                     VCRNUM = LSDHNUM,
&                     VCRLIN = LSDDLIN
   If fstat=1
      GLOCK="$SPACKD"-LPRHNUM-num$(LPRELIN)
      GMESSAGE=GLOCK-mess(60,100,1)
      Goto TRF_COLISAGE_ERR
   Elsif fstat
      Call RSTA("SPD",LPRHNUM-num$(LPRELIN)) From GLOCK
      GMESSAGE=mess(12,100,1)
      Goto TRF_COLISAGE_ERR
   Endif

# reecriture STOPRED     (ligne préparation)
   Update [PRE] Where PRHNUM    = LPRHNUM
&                   & PRELIN    = LPRELIN
&               With  PACQTYSTU = 0
   If fstat=1
      GLOCK="$STOPRED"-LPRHNUM-num$(LPRELIN)
      GMESSAGE=GLOCK-mess(60,100,1)
      Goto TRF_COLISAGE_ERR
   Elsif fstat
      Call RSTA("PRE",LPRHNUM-num$(LPRELIN)) From GLOCK
      GMESSAGE=mess(12,100,1)
      Goto TRF_COLISAGE_ERR
   Endif

# reecriture SDELIVERYD  (ligne livraison)
   Update [SDD] Where SDHNUM = LSDHNUM
&                   & SDDLIN = LSDDLIN
&               With  PACQTYSTU  = [F:PRE]PACQTYSTU
   If fstat=1
      GLOCK="$SDELIVERYD"-LSDHNUM-num$(LSDDLIN)
      GMESSAGE=GLOCK-mess(60,100,1)
      Goto TRF_COLISAGE_ERR
   Elsif fstat
      Call RSTA("SDD",LSDHNUM-num$(LSDDLIN)) From GLOCK
      GMESSAGE=mess(12,100,1)
      Goto TRF_COLISAGE_ERR
   Endif

Else

# ****                             ligne non renseignée    ****
# reecriture SPACK     (entete colisage)
#MAE, le 03/11/08, en création massive des livraisons à partir des BP,
# on met à jour les entêtes de bon de prépa mais pas l'entête de livraison
If LSUP = "" or LSUP ="PRH"
   Update [SPH] Where VCRTYP = 3
&                   & VCRNUM = LPRHNUM
&                   & PACSEQ = 1
&               With  VCRTYP = 4,
&                     VCRNUM = LSDHNUM,
&                     CUR    = [F:SDH]CUR,
&                     CHGTYP = [F:SDH]CHGTYP
   If fstat=1
      GLOCK="$SPACKH"-LPRHNUM
      GMESSAGE=GLOCK-mess(60,100,1)
      Goto TRF_COLISAGE_ERR
   Elsif fstat
      Call RSTA("SPH",LPRHNUM) From GLOCK
      GMESSAGE=mess(12,100,1)
      Goto TRF_COLISAGE_ERR
   Endif

   If [F:SDH]SDHNUM<>LSDHNUM
      Read [SDH]SDH0=LSDHNUM
   Endif
   For [SPH]SPH0 Where VCRTYP=4 & VCRNUM=LSDHNUM
      WPCKPRI = [F:SPH]PCKPRI
      If [F:SPH]CUR <> GSYSCUR
         Call CONVERT(GSYSCUR,[F:SPH]CUR,GSYSCUR,[F:SPH]CHGTYP,date$,
&                     [F:SPH]PCKPRI,WPCKPRI,WSTAT) From TRTDEV
         [F:SPH]PCKPRI = WPCKPRI
         Rewrite [SPH]
      Endif
   Next

# reecriture STOPREH   (entete preparation)  !update supprimer demande Jerome Amiot!

#   Update [PRH] Where PRHNUM = LPRHNUM
#&               With  PACFLG = 1,
#&                     PACNBR = 0
#   If fstat=1
#      GLOCK="$STOPREH"-LPRHNUM
#      GMESSAGE=GLOCK-mess(60,100,1)
#      Goto TRF_COLISAGE_ERR
#   Elsif fstat
#      Call RSTA("PRH",LPRHNUM) From GLOCK
#      GMESSAGE=mess(12,100,1)
#      Goto TRF_COLISAGE_ERR
#   Endif
Endif

#MAE, le 03/11/08, en création massive des livraisons à partir des BP,
# on ne doit pas mettre à jour l'entête de livraison avant d'avoir créé la livraison
If LSUP = "" or LSUP ="SDH"
# lecture de la livraison
   Local Integer WSDH                          # hcb 103813
   WSDH = 2                                    # hcb 103813
   Readlock [SDH]SDH0=LSDHNUM
   If fstat
      Raz WSDH                                 # hcb 103813
  #    GOK = 0                                 # hcb 103813
  #    Call RSTA("SDH",LSDHNUM) From GLOCK     # hcb 103813
  #    GMESSAGE=mess(12,100,1)                 # hcb 103813
  #    Goto TRF_COLISAGE_ERR                   # hcb 103813
   Endif

# reecriture SDELIVERY (entete livraison)
#  calcul cumuls et  maj entête livraison               reecriture SDELIVERY #
   Call COLISAGE_ORIGINE([F:SDH]STOFCY,4,LSDHNUM,LPACNBR,LPACFLG,LNETWEI,
&                        LGROWEI,LWEU,LVOL,LVOU,1,LRET) From FUNPKD
   If GOK = 0 | LRET <> 0
      GMESSAGE=mess(1,137,1)
      Goto TRF_COLISAGE_ERR
   Endif

   [F:SDH]PACFLG = LPACFLG
   [F:SDH]PACNBR = LPACNBR
   [F:SDH]NETWEI = LNETWEI
   [F:SDH]GROWEI = LGROWEI
   [F:SDH]VOL    = LVOL
   If [F:SDH]VOU = ""
      [F:SDH]VOU = LVOU
   Endif

   If WSDH = 2              # hcb 103813
      Rewrite [SDH]
   Endif                    # hcb 103813
Endif

Endif

#--- Traitement des erreurs
$TRF_COLISAGE_ERR
If GMESSAGE<>""
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz GMESSAGE
   LRET = 1
Endif

If OUVRE_SPH = 2
   Close Local File [SPH]
Endif
If OUVRE_SPD = 2
   Close Local File [SPD]
Endif

End



######################################################################################
# SUP_COLISAGE  suppression du colisage d un document
#        Si LLIN = 0 suppression complete du colisage du document
#           - suppression SPACKD et SPACK   (lnum)
#           - Maj         entete document  : pacflg pacnbr netwei growei vol vou
#           - Maj         detail document  : pacqtystu = 0
#        Si LLIN <> 0 suppression du colisage de la ligne du document
#           - suppression SPACKD  (lnum + llin)
#           - reecriture ou suppression  SPACK
#           - Maj         entete document  : pacflg pacnbr netwei growei vol vou
#             (c est au programme appelant de mettre à jour pacqtystu sur detail document)
######################################################################################
# Paramètres E : LTYP    = Type document  3 = Préparation , 4 = Livraison
#                LNUM    = N° document
#                LLIN    = N° ligne du document
#                LSUP    = Paramètre divers
#                          M = modification ligne document (qte ou info stock) pacflg devient 1
#                          A = annulation   ligne document  pacflg ne change pas
#            S : LRET    = Code retour : (0=OK / 1=Erreur)
#
# Prérequis    : Ces tables doivent être ouvertes
#                           si Type document = 3    STOPREH
#                                                   STOPRED
#                           si Type document = 4    SDELIVERY
#                                                   SDELIVERYD
######################################################################################
Subprog SUP_COLISAGE(LTYP,LNUM,LLIN,LSUP,LRET)
Value    Integer  LTYP
Value    Char     LNUM
Value    Integer  LLIN
Value    Char     LSUP
Variable Integer  LRET

Local Integer  OUVRE_SPH
Local Integer  OUVRE_SPD
Local Integer  OUVRE_SPD1
Local Integer  LPACFLG   # flag colisage  2 = complet
Local Integer  LPACNBR   # nombre de colis
Local Decimal  LNETWEI   # Poids net du document
Local Decimal  LGROWEI   # Poids brut du document
Local Char     LWEU      # Unité de poids du document
Local Decimal  LVOL      # Volume du document
Local Char     LVOU      # Unité de volume du document
Local Integer  WOK
Local Char     LFCY
Local Char     WPACNUM
Local Integer  WPACSEQ
Local Integer  LOPT
Raz LPACFLG
Raz LPACNBR
Raz LNETWEI
Raz LGROWEI
Raz LWEU
Raz LVOL
Raz LVOU
Raz LRET

Raz OUVRE_SPH
Raz OUVRE_SPD
Raz OUVRE_SPD1
Raz GMESSAGE
If clalev([F:SPH]) = 0
   Local File SPACK  [SPH]
   OUVRE_SPH = 2
Endif
If clalev([F:SPD]) = 0
   Local File SPACKD [SPD]
   OUVRE_SPD = 2
Endif
If LLIN <> 0                  # suppression colisage d une ligne de document
# suppression SPD et recalcul SPH
   Filter [SPD] Where VCRTYP = LTYP & VCRNUM = LNUM & VCRLIN = LLIN
&         Order By Key SPD2
   Columns [SPD] (PACNUM,PACSEQ)
   For [SPD]
       If WPACNUM =  ""
          WPACNUM = [F:SPD]PACNUM
          WPACSEQ = [F:SPD]PACSEQ
       Endif
       If WPACNUM <> [F:SPD]PACNUM
          Gosub ENTETE_COLIS From STKPREPA
          If LRET <> 0
             Break
          Endif
          WPACNUM =  [F:SPD]PACNUM
          WPACSEQ =  [F:SPD]PACSEQ
       Endif
       Readlock [SPD] Curr
       If fstat
          LRET = 1
          Call FSTA("SPD") From GLOCK
          GMESSAGE=mess(12,100,1)
          Break
       Endif
       Delete [SPD]
   Next
   Filter  [SPD]
   Columns [SPD]
   If LRET <> 0
      Goto SUP_COLISAGE_ERR
   Else
      If WPACNUM <> ""
         Gosub ENTETE_COLIS From STKPREPA
         If LRET <> 0
            Goto SUP_COLISAGE_ERR
         Endif
      Endif
   Endif
   LOPT = 1
Else                          # suppression colisage du document

   Filter [SPH] Where  VCRTYP   =  LTYP              &
&                      VCRNUM   =  LNUM              &
&                      SPHTEX   <> ""
&               Order By Key SPH0
   For [SPH]
       If [F:SPH]SPHTEX <> ""
          If left$([F:SPH]SPHTEX,3)="SPH"
             Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
          Endif
       Endif
   Next
   Filter [SPH]

   # Suppression de tous les colis d un document
   Delete [SPH] Where VCRTYP = LTYP  & VCRNUM = LNUM
   Delete [SPD] Where VCRTYP = LTYP  & VCRNUM = LNUM
   LOPT = 0
Endif

If LTYP = 4
# lecture de la livraison
      Readlock [SDH]SDH0=LNUM
      If fstat
         GOK = 0
         Call RSTA("SDH",LNUM) From GLOCK
         GMESSAGE=mess(12,100,1)
         Goto SUP_COLISAGE_ERR
      Endif
      LFCY = [F:SDH]STOFCY
Else
# lecture de la préparation
   Readlock [PRH]PRH0=LNUM
   If fstat
      GOK = 0
      Call RSTA("PRH",LNUM) From GLOCK
      GMESSAGE=mess(12,100,1)
      Goto SUP_COLISAGE_ERR
   Endif
   LFCY = [F:PRH]STOFCY
Endif

#--- Bug 71298
If LLIN=0
#---
  Call COLISAGE_ORIGINE(LFCY,LTYP,LNUM,LPACNBR,LPACFLG,LNETWEI,LGROWEI,LWEU,LVOL,LVOU,LOPT,LRET) From FUNPKD
  If GOK = 0 | LRET <> 0
    GMESSAGE=mess(1,137,1)
    Goto SUP_COLISAGE_ERR
  Endif

  If LTYP = 4
  # réécriture entete livraison
    If LSUP = "M"
      [F:SDH]PACFLG = 1
    Endif
    [F:SDH]PACNBR = LPACNBR
    [F:SDH]NETWEI = LNETWEI
    [F:SDH]GROWEI = LGROWEI
    [F:SDH]VOL    = LVOL
    If [F:SDH]VOU = ""
      [F:SDH]VOU = LVOU
    Endif
    Rewrite [SDH]
  Else
  # réécriture entete préparation
    If LSUP = "M"
      [F:PRH]PACFLG = 1
    Endif
    [F:PRH]PACNBR = LPACNBR
    [F:PRH]NETWEI = LNETWEI
    [F:PRH]GROWEI = LGROWEI
    If LGROWEI = 0
      Raz LWEU
    Endif
    [F:PRH]WEU    = LWEU
    Rewrite [PRH]
  Endif
#--- Bug 71298
Endif
#---

#--- Traitement des erreurs
$SUP_COLISAGE_ERR
If GMESSAGE<>""
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz GMESSAGE
   LRET = 1
Endif

If OUVRE_SPH  = 2
   Close Local File [SPH]
Endif
If OUVRE_SPD  = 2
   Close Local File [SPD]
Endif
If OUVRE_SPD1 = 2
   Close Local File [SPD1]
Endif

End



########################################################################
# Mise à jour entete colis suite à enregistrement ou suppression d un colisage
#-----------------------------------------------------------------------
#            E : LFCY    = Nom du site
#                LTYP    = Type document
#                LNUM    = Numéro document
#              : LPAC    = Numéro colis
#              : LSEQ    = Sequence
#            S : LRET    = Code Erreur
########################################################################
$ENTETE_COLIS
Local    Char     WITMREF
Local    Integer  WONE
Local    Decimal  WNETWEI
Local    Integer  WSPD
Local    Integer  WSTAT

Raz WNETWEI
Raz WITMREF
Raz WSPD
WONE = 2

If clalev([F:SPD1]) = 0
   Local File SPACKD [SPD1]
   OUVRE_SPD1 = 2
Endif


Readlock  [SPH]SPH0=LTYP;LNUM;WPACNUM;WPACSEQ
If fstat=1
   GLOCK="$SPACK"-LNUM-WPACNUM-num$(WPACSEQ)
   GMESSAGE=GLOCK-mess(60,100,1)
   LRET = 1
   GOK=-1
   Return
Elsif fstat
   Call RSTA("SPH",LNUM-WPACNUM) From GLOCK
   GMESSAGE=mess(12,100,1)
   LRET = 1
   GOK=0
   Return
Endif
# calcul WNETWEI WONE
Filter [SPD1] Where VCRTYP = LTYP & VCRNUM = LNUM & PACNUM = WPACNUM & PACSEQ = WPACSEQ
&      Order By Key SPD0
       Columns [SPD1] (ITMREF, NETWEI)
For [SPD1]
     WSPD = 1
     If WITMREF  = ""
        WITMREF  =  [F:SPD1]ITMREF
     Endif
     If WITMREF  <> [F:SPD1]ITMREF
        WONE     = 1
     Endif
     WNETWEI     += [F:SPD1]NETWEI
Next
Filter  [SPD1]
Columns [SPD1]

If WSPD = 0
   If [F:SPH]SPHTEX <> ""
      If left$([F:SPH]SPHTEX,3)="SPH"
         Call SUP_CLOB([F:SPH]SPHTEX,LRET) From TRTX3TEX
      Endif
    Endif
    Delete [SPH]
Else
    [F:SPH]NETWEI    = WNETWEI
    [F:SPH]ONEITMFLG = WONE
    [F:SPH]UPDDAT    = date$
    [F:SPH]UPDUSR    = GUSER
    Rewrite [SPH]
Endif

Return


###############################################################################
# VERF_MODSTO    Recherche si le stock alloué sur une ligne préparée ou livrée
#                a été modifié (stockage dans STOSORW) afin de déterminer si
#                le colisage lié à la ligne doit être supprimé
###############################################################################
# Paramètres E : LTYP    = Type document  3=Préparation , 4=Livraison
#                LNUM    = N° document
#                LLIN    = N° ligne du document
#                LSTOSEQ = Lien entre écran ligne document et écran STOSORW
#            S : LRET    = Code retour : (0=pas de modif / 1=modif réalisée
#
# Prérequis    : Ces écrans doivent être ouverts
#                   si LTYP=3    PRH1 [PRH1] et STOSORW [SOW]
#                   si LTYP=4    SDH1 [SDH1] et STOSORW [SOW]
######################################################################################
Subprog VERF_MODSTO(LTYP,LNUM,LLIN,LSTOSEQ,LRET)
Value    Integer  LTYP
Value    Char     LNUM
Value    Integer  LLIN
Value    Integer  LSTOSEQ
Variable Integer  LRET

Local    Integer  I
Local    Decimal  WQTY

Raz LRET
If LSTOSEQ=0 End Endif

If !clalev([F:STA])  Local File STOALL [STA]  Endif
For I=0 To [M:SOW]NBLIG-1
   Raz WQTY
   # Ligne de stock [SOW] correspondante à la ligne document
   If [M:SOW]WSTOSEQ(I)=LSTOSEQ & [M:SOW]WSTOCOU(I)<>0
      # Recherche des allocations de cette ligne document pour le chrono stock
      For [STA]STA1 Where VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN & VCRSEQ=0
&                         & STOCOU=[M:SOW]WSTOCOU(I)
         WQTY += [F:STA]QTYSTUACT
# l'article site gère le colisage en série détail : controle si les séries n'ont pas été modifiés  # hcb 110327-pck
         If [F:ITF]PCKSERFLG = 2 & [M:SOW]WSERNUM(I) <> [F:STA]SERNUM                              # hcb 110327-pck
            LRET = 1                                                                               # hcb 110327-pck
            Break 2                                                                                # hcb 110327-pck
         Endif                                                                                     # hcb 110327-pck
      Next
      # Il y a une différence entre l'allocation et le stock dans [SOW]
      # --> le stock a alloué a été modifié
      If WQTY<>[M:SOW]WQTYSTUACT(I)
         LRET=1 : Break
      Endif
   Endif
Next I

End

##########################################################
#--- Issue 121743
$REAJUSTE_QTY
#---------------------------------------------
# Réajustement qté en unité vente entière
#---------------------------------------------
GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 :  Return : Endif

If [F:SOP]SAU<>[F:ITM]STU
   WQTYARR = WQTY
   Call QTEARR(WQTYARR,[F:SOP]SAU) From TRTDIV
   If WQTYARR=WQTY Return Endif

   Call CTRQTYPCU([F:SOP]SAU,[F:SOP]SAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
   If WQTYARR<>WQTYSTU
      WQTYSTU = WQTYARR
      WQTY    = WQTYSTU/[F:SOP]SAUSTUCOE
   Endif
Endif
Return
#--- End issue 121743

