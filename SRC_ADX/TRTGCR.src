#<AdxTL>@(#)10.0.0.0 $Revision$
Call OBJET("GCR",GBIDC1,GBIDC2) From GOBJET
End

###############################################################################
$ACTION
Case BCRIT
 When "ACOPIE"
  Case ACTION
   When "INIT_DIA" : Gosub INICOP From SUBGCR
   When "CONTROLE" : Gosub CONTCOP From SUBGCR
   When "EXEC"     : Gosub TRTCOP From SUBGCR
  Endcase
Endcase
Return

