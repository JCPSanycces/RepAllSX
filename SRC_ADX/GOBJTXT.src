Subprog C_TYPDOC(VALEUR)
Variable Char    VALEUR()
Local Char    NAM(GDIMFIC), FICHIER(GDIMFIC), SUF(10), MESSA(250)
Local Integer K, OK
Gosub SET_TYPX3
Gosub SETNOL
K = (find(VALEUR,CLOBX3,CLOBXT(1..NCLBXT),BLOBX3(1..NBLBX3)))
K += (dim([M]IDTSTO)>0 & [M]IDTSTO(NOL)<>"")
If K : End : Endif
If find(left$(VALEUR,1),"'",'"')
 Onerrgo RIEN
 FICHIER = evalue([M]NAM(nolign-1))
 Onerrgo
Else
 FICHIER = [M]NAM(nolign-1)
Endif
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
Local Char FULLNAME(GDIMFIC)
mkstat = func ASYRSTO.CTL_VOLFIL(2,FICHIER,FULLNAME,E_TYPE_FILEREAD,GMESSAGE)
If mkstat>0 : GMESSAGE = mess(40,126,1) : End : Endif
Local Char    NAM(GDIMFIC), SUF(10), MESSA(250)
Call SETNAM(FULLNAME,NAM,SUF)
Read [ADI]CODE = 902;toupper(VALEUR)
If !fstat & [F:ADI]A1<>"" & toupper([F:ADI]A1)<>toupper(SUF)
 If SUF=""
  MESSA = mess(40,126,1)+"\"+VALEUR-"->"-[F:ADI]A1 : # Type de fichier incorrect
 Else
  MESSA = SUF-":"-mess(40,126,1)+"\"+VALEUR-"->"-[F:ADI]A1
 Endif
 OK = 1
 Call AVERTIR(MESSA,OK) From GESECRAN
 If OK<>2 : mkstat = 1 :  End : Endif
Endif

End

