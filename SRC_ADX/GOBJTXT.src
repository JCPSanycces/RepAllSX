Subprog C_NAM(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]NAM(0..[M]NBLIG-1)) From OBJDIV
If find(left$(VALEUR,1),"'",'"')
 Onerrgo RIEN
 VALEUR = evalue(VALEUR)
 Onerrgo
Endif
If instr(1,VALEUR,"[") or instr(1,VALEUR,"/") or instr(1,VALEUR,"\")
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
 Local Char FULLNAME(GDIMFIC)
 mkstat = func ASYRSTO.CTL_VOLFIL(2,VALEUR,FULLNAME,E_TYPE_FILEREAD,GMESSAGE)
 If mkstat>0 : End : Endif
 Local Char    NAM(GDIMFIC), SUF(10), MESSA(250)
 Call SETNAM(FULLNAME,NAM,SUF)
 Read [ADI]CODE = 902;toupper(SUF)
 If !fstat & [F:ADI]A1<>"" & [M]TYPDOC(nolign-1)=""
  [M]TYPDOC(nolign-1) =  [F:ADI]A1
  Affzo [M]TYPDOC(nolign-1)
 Endif
Endif
End

