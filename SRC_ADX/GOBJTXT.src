Subprog CL_ICONE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV & [M]NAM(nolign-1)<>"" & [M]TYPDOC(nolign-1)<>""
  # X3-94636
  # checking access control once again
  # because in some cases AC_NBLIG is not executed what leads to control omitting
  Gosub ACCESS_CONTROL
  If mkstat = 1 Then End: Endif

 Local Char SAVVAL(250) : # 120748
 #SAM 120819
 Local Integer  VERROU
 Local Char     SYMBOLE(GLONASYM)
 Local Char CLESEC(GLONID1)
 Local  Char    CLE2(250)

 SAVVAL = VALEUR
 Gosub SETNOL
 Gosub SET_TYPX3
 If !find([M]TYPDOC(NOL),CLOBX3,CLOBXT(1..NCLBXT),BLOBX3(1..NBLBX3)) and (dim([M]IDTSTO)<1 or [M]IDTSTO(NOL)="")
& or  (instr(1,[M]NAM(NOL),"[") or instr(1,[M]NAM(NOL),"/") or instr(1,[M]NAM(NOL),"\"))
  ## Action ASYRVISU
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "ASYRVISU"
  PARMSK(1) = [M]NAM(nolign-1)
  VALEUR = [M]NAM(nolign-1)
  Call TRAITE_CHAR(VALEUR,PARMSK,"","ASYRVISU","",1,"") From GTRAITE
  GACTION = SAVACT
 Elsif find([M]TYPDOC(NOL),CLOBX3,CLOBXT(1..NCLBXT))>0
 #SAM 120819
  If MODI=1
    Gosub VERROU_PIECE
    If !VERROU
      Gosub MESSA_MODIF
      mkstat = 2 : End
    Endif
  Endif
  Local Integer OKCLB
  If [M:AOX]NOLIG(nolign-1)=0 : [M]NOLIG(nolign-1) = func NUMINSERT([M]NOLIG) : Endif
  OKCLB = func ADD_TEXT([M]IDENT1,[M]IDENT2,format$("N0:3#",[M]NOLIG(nolign-1)),[M]TYPDOC(nolign-1))
  If OKCLB>0
   Local Char    TXTRTF(20)
   Gosub SET_TYPX3 From GOBJTXT
   Setlob TXTRTF With [M]TEXTE
   If left$(TXTRTF,5)="{\rtf" | left$(TXTRTF,6)="{\urtf"
    If [M:AOX]TYPDOC(nolign-1)<>CLOBX3
     [M:AOX]TYPDOC(nolign-1) = CLOBX3 : Affzo [M:AOX]10
    Endif
   Elsif !find([M:AOX]TYPDOC(nolign-1),CLOBXT(1..NCLBXT))
    [M:AOX]TYPDOC(nolign-1) = CLOBXT : Affzo [M:AOX]10
   Endif
  Endif
 Elsif find([M]TYPDOC(NOL),BLOBX3(1..NBLBX3))>0
  #SAM 120819
  If MODI =1
    Gosub VERROU_PIECE
    If !VERROU
      Gosub MESSA_MODIF
      mkstat = 2 : End
    Endif
  Endif
  Local Integer OKBLB
  OKBLB = func ADD_BLOB([M]IDENT1,[M]IDENT2,format$("N0:3#",[M]NOLIG(nolign-1)),"3")
 Endif
 VALEUR = SAVVAL
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran AOBJTXT) 22/10/2014 16:29:29 (CCL)
######################################################################################
Subprog S_TYPDOC(VALEUR)
Variable Char    VALEUR()

If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif

Local Integer NBFLD, CHOI,I,OK
Local Char    TEX(GLONDES)(1..100,1..2) , TIT(GLONDES)(0..2)

Local Char CRITERIA(250)
If instr(1,[M]NAM(nolign-1),"[") or instr(1,[M]NAM(nolign-1),"/") or instr(1,[M]NAM(nolign-1),"\")
 CRITERIA = "!find([F:ADI]CODE,'RTF','TXT','PIC')"
Else
 CRITERIA = "find([F:ADI]CODE,'RTF','TXT','PIC')"
Endif
For [F:ADI] Where NUMTAB=902 and evalue(CRITERIA)
 NBFLD+= 1
 TEX(NBFLD,1) = [F:ADI]CODE
 Call LECTEXTRA(TEX(NBFLD,2) ,"ATABDIV","LNGDES",num$([F:ADI]NUMTAB),[F:ADI]CODE) From ATEXTRA
Next

CHOI = 0
TIT(0)=mess(8,31,1) # Sélection
TIT(1) = mess(6,83,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé

Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,120,160) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif

End



######################################################################################


$BOUTON_PIECE
Gosub VERROU_PIECE
If !VERROU
 Gosub MESSA_MODIF : Return
Endif
Case BOUT
 When "F"
  If !GWEBSERV
   ## Action SELFICREP
   Local Char    PARMSK(250)(1..20) , SAVACT(20) , FICHIER(GDIMFIC)
   #SAVACT = GACTION : GACTION = "SELFICREP"
   #PARMSK(1) = ""
   #Call SAISIE_CHAR(FICHIER,PARMSK,"DFICREP","SELFICREP","XWDFICREP") From GSAISIE
   SAVACT = GACTION : GACTION = "ASELFILFOL"
   PARMSK(1) = "2"
   PARMSK(2) = "2"
   PARMSK(3) = ""
   Call TRAITE_CHAR(FICHIER,PARMSK,"","ASELHIERA","ASELHIERA",3,"XWASELHIERA") From GTRAITE
   GACTION = SAVACT
   If FICHIER<>""
    Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
    Local Char FULLNAME(GDIMFIC)
    mkstat = func ASYRSTO.CTL_VOLFIL(2,FICHIER,FULLNAME,E_TYPE_FILEREAD,GMESSAGE)
    If mkstat>0 : Call ERREUR(GMESSAGE ) From GESECRAN : Return : Endif
    Local Char    NAM(GDIMFIC), SUF(10), MESSA(250)
    Call SETNAM(FULLNAME,NAM,SUF)
    [M:AOX]NAM([M:AOX]NBLIG) = FICHIER
    Read [ADI]CODE = 902;toupper(SUF)
    If !fstat & [F:ADI]A1<>""
     [M]TYPDOC([M:AOX]NBLIG)   =[ADI]CODE
    Endif
    If [M]TYPDOC([M:AOX]NBLIG) ="" : [M]TYPDOC([M:AOX]NBLIG) ="DOC" : Endif
    [M]NOLIG([M:AOX]NBLIG)     = [M:AOX]NBLIG+1
    [M:AOX]NBLIG += 1
    Affzo [M:AOX]10
   Endif
  Endif

 When "T"
  Local Integer OKLCLB
  OKCLB = func ADD_TEXT([M]IDENT1,[M]IDENT2,format$("N0:3#",[M:AOX]NBLIG+1),"RTF")
  If OKCLB
   For I=1 To dim([M:AOX]NAM)-1
    If !find("TEXT"+num$(I),[M:AOX]NAM(0..dim([M:AOX]NAM)-1))
     [M:AOX]NAM([M:AOX]NBLIG) = "TEXT"+num$(I)
     Break
    Endif
   Next
   [M]TYPDOC([M:AOX]NBLIG)   = "RTF"
   [M]NOLIG([M:AOX]NBLIG)     = [M:AOX]NBLIG+1
   [M:AOX]NBLIG += 1
   Affzo [M:AOX]10
  Endif
 When "B"
  Local Integer OKBLB
  OKBLB = func ADD_BLOB([M]IDENT1,[M]IDENT2,format$("N0:3#",[M:AOX]NBLIG+1),"3")
  If OKBLB
   For I=1 To dim([M:AOX]NAM)-1
    If !find("IMG"+num$(I),[M:AOX]NAM(0..dim([M:AOX]NAM)-1))
     [M:AOX]NAM([M:AOX]NBLIG) = "IMG"+num$(I)
     Break
    Endif
   Next
   [M]TYPDOC([M:AOX]NBLIG)   = "PIC"
   [M]NOLIG([M:AOX]NBLIG)     = [M:AOX]NBLIG+1
   [M:AOX]NBLIG += 1
   Affzo [M:AOX]10
  Endif
Endcase
Return

Funprog ADD_TEXT(IDENT1,IDENT2,IDENT3,TYPDOC)
Value Char IDENT1,IDENT2,IDENT3,TYPDOC
## Action ACLBTXT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Integer OKCLB
SAVACT = GACTION : GACTION = "AOBJTXT "
Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
ACTION = "ACL_ICONE" : PROGSUB = "GOBJTXT" : PROGSPE = "SPEOBJTXT" : PROGSPV = ""
Gosub ACTSUB From GOBJSUB
PARMSK(1) = [L]IDENT1
PARMSK(2) = [L]IDENT2
PARMSK(3) = [L]IDENT3
PARMSK(4) = [L]TYPDOC
PARMSK(5) = num$(OKCLB)
#SAM 120819
PARMSK(6) = num$(MODI)

Call TRAITE_CHAR(GBIDC1,PARMSK,"","ACLBTXT","ACLBTXT",3,"XYACLBTXT") From GTRAITE
OKCLB = val(PARMSK(5))
ACTION = "BCL_ICONE" : PROGSUB = "ACLBTXT" : PROGSPE = "SPEACLBTXT" : PROGSPV = ""
Gosub ACTSUB From GOBJSUB
GACTION = SAVACT
End OKCLB


Funprog ADD_BLOB(IDENT1,IDENT2,IDENT3,TYPBLB)
Value Char IDENT1,IDENT2,IDENT3,TYPBLB
Local Integer OKBLB
## Action ABLBTXT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
If [M:AOX]NOLIG(nolign-1)=0 : [M]NOLIG(nolign-1) = func NUMINSERT([M]NOLIG) : Endif
SAVACT = GACTION : GACTION = "ABLBTXT"
Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
ACTION = "ACL_ICONE" : PROGSUB = "GOBJTXT" : PROGSPE = "SPEOBJTXT" : PROGSPV = ""
Gosub ACTSUB From GOBJSUB
PARMSK(1) = [L]IDENT1
PARMSK(2) = [L]IDENT2
PARMSK(3) = [L]IDENT3
PARMSK(4) = [L]TYPBLB
PARMSK(5) = num$(OKBLB)
#SAM 120819
PARMSK(6) = num$(MODI)

Call TRAITE_CHAR(GBIDC1,PARMSK,"","ABLBTXT","ABLBTXT",3,"XYABLBTXT") From GTRAITE
OKBLB = val(PARMSK(5))
ACTION = "BCL_ICONE" : PROGSUB = "ABLBTXT" : PROGSPE = "SPEABLBTXT" : PROGSPV = ""
Gosub ACTSUB From GOBJSUB
GACTION = SAVACT
End OKBLB

Subprog IB_SELDOC
End

$ACCESS_CONTROL
  Local Char VOLUME(30)
  Local Integer POS
  Local Instance IVOLUME Using C_AVOLUME

  Gosub SETNOL

  If len([M]NAM(NOL)) & pat([M]NAM(NOL),"[*]/*")
    [L]POS = instr(1,[M]NAM(NOL),']/')
    VOLUME =  mid$([M]NAM(NOL),2, [L]POS-2)
  Elsif len([M]NAM(NOL)) & pat([M]NAM(NOL),"[*]")
    VOLUME =  mid$([M]NAM(NOL),2, len([M]NAM(NOL))-2)
  Endif

  If VOLUME<>""
    IVOLUME = NewInstance C_AVOLUME AllocGroup null
    STAT = fmet IVOLUME.AREAD(VOLUME)
    If STAT>=[V]CST_AERROR Then mkstat=1: Endif
    If mkstat=0 and IVOLUME.CODACC<>""
      If fmet IVOLUME.ACTX.AGETACSRIGHTC(IVOLUME,IVOLUME.CODACC,[V]CST_ATRUE)>=[V]CST_AERROR
        mkstat=1
      Endif
      FreeGroup IVOLUME
    Endif
  Endif
Return

