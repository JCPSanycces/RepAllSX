#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion des pièces jointes et 
Raz GPILOBJ,GNBMASKOUV
Local Char    VALEUR(30), PARAM(250)(1..20)
GABREV = "AUS"
PARAM(1) = GABREV
PARAM(2) = "MB"
PARAM(4) = "M"
Call SAISIE_CHAR(VALEUR,PARAM,"AOBJTXT","GOBJTXT","XWGOBJTXT") From GSAISIE
#Call SAISIE_CHAR(VALEUR,PARAM,"AOBJCOM","GOBJTXT","XWGOBJTXT") From GSAISIE
End

#-------------------------------------------------------------------------------------------------------#
$ACTION
Case GBOITE
 When "AOBJTXT" : # Gestion des Pièces jointes
  Case ACTION
   When "OUVRE"       : Gosub OUVRE_PIECE
   When "DEBUT"       : Gosub DEBUT_PIECE
   When "SETBOUT"     : Gosub SETBOUT_PIECE
   When "BOUTON"     : Gosub BOUTON_PIECE
   When "AP_CHOIX"    : Gosub AP_PIECE
   When "APRES_MODIF" : Gosub APRES_PIECE
   When "OK"          : Gosub OK_PIECE
   When "FIN"         : Gosub FIN_PIECE
  Endcase
 When "AOBJCOM" : # Gestion des Commentaires
  Case ACTION
   When "OUVRE"       : Gosub OUVRE_COMM
   When "DEBUT"       : Gosub DEBUT_COMM
   When "SETBOUT"     : Gosub SETBOUT_COMM
   When "AP_CHOIX"    : Gosub AP_COMM
   When "APRES_MODIF" : Gosub APRES_COMM
   When "OK"          : Gosub OK_COMM
   When "FIN"         : Gosub FIN_COMM
  Endcase
Endcase
Return

#-------------------------------------------------------------------------------------------------------#
# Gestion des Pièces jointes
#-------------------------------------------------------------------------------------------------------#

$OUVRE_PIECE
Local Char    OBJET(GLONAOB) , CLE1(GLONID1) , CLE2(30)(1..16) , CLEBIS(GLONID2)
Local Char    MOT(10) , REP1(30) , REP2(30) , CHAINE(250)
Local Integer OK , I , J , K , B , TEMPO
Local Char    OS(10) , IDNOL(10)
Local Char    TXTRTF(20)
Local Integer MODI

If clalev([F:AOX])=0  : Local File AOBJTXT  [AOX]  : Endif
If clalev([F:AOM])=0  : Local File AOBJTXTA [AOM]  : Endif
If clalev([F:ABB])=0  : Local File ABLOB    [ABB]  : Endif
If clalev([F:ACB])=0  : Local File ACLOB    [ACB]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif

OBJET  = PARAM(1)
CLE1   = PARAM(2)
CLEBIS = PARAM(3)


CHAINE = CLEBIS
For I=1 To dim(CLE2)
 K = instr(1,CHAINE,"~")
 If K
  CLE2(I) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE2(I) = CHAINE
  Break
 Endif
Next I

MODI = instr(1,PARAM(4),"M")

# Clé des blobs Pièces jointes
# ----------------------------
# Code blob = PJ_ + code objet
# Ident1    = Première partie de clé
# Ident2    = CLEBIS - Parties suivantes séparées par ~
# Ident3    = numéro de ligne

Gosub SETCLE From ="WO"+OBJET
Gosub SET_PCE
Gosub VERROU_PIECE
Gosub SET_TYPX3
Return

#-------------------------------#
$SET_PCE
Local Char CBLOB(10)
CBLOB = "PJ_" : # Pour préfixer le verrou et le code blob
Return

#-------------------------------#
$SET_TYPX3
Local Char    CLOBX3(GLONADI) , CLOBXT(GLONADI)(1..99) , BLOBX3(GLONADI)(1..99)
Local Integer NCLBXT , NBLBX3 , OKTAB
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : OKTAB = 1 : Endif
Raz NCLBXT , NBLBX3
# On prévilégie les codes "historiques"
For [ADI] Where NUMTAB=902
 If [F:ADI]CODE="RTF" & find([F:ADI]N1,0,3)    : # Type des fichiers .rtf gérés en clob
  CLOBX3 = [F:ADI]CODE
 Elsif [F:ADI]CODE="TXT" & find([F:ADI]N1,0,3) : # Type des fichiers .txt gérés en clob
  NCLBXT = 1 : CLOBXT(NCLBXT) = [F:ADI]CODE :
 Elsif [F:ADI]CODE="PIC" & find([F:ADI]N1,0,2) : # Type des images gérées en blob
  NBLBX3 = 1 : BLOBX3(NBLBX3) = [F:ADI]CODE
 Endif
Next ADI
# Charge les autres
For [ADI] Where NUMTAB=902
 If !find([F:ADI]CODE,CLOBX3,CLOBXT(1..NCLBXT),BLOBX3(1..NBLBX3))
  Case [F:ADI]N1
   When 1 : # Fichier (non géré dans la base)
   When 2 : # Blob base
    NBLBX3 += 1
    BLOBX3(NBLBX3) = [F:ADI]CODE
   When 3 : # Clob base
    NCLBXT += 1
    CLOBXT(NCLBXT) = [F:ADI]CODE
  Endcase
 Endif
Next ADI
If OKTAB : Close Local File [ADI] : Endif
Return

#-------------------------------#
$VERROU_PIECE
If !MODI : Return : Endif
If dim(OBJET)>0
 SYMBOLE = CBLOB+OBJET+CLE1
Else
 SYMBOLE = [M]CBLOB+[M]IDENT1
Endif
For I=1 To dim(CLESEC)
 If CLESEC(I-1)<>""
  SYMBOLE += "\"+CLE2(I)
 Endif
Next I
Lock =SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

#-------------------------------#
$DEBUT_PIECE
Gosub LECTURE
If !MODI
 nolign = 1
 Gosub CHARGE_PIECE
 IMGFLG(5) = 1 : # Croix blanche
 Diszo TEXTE, PHOTO , TYPDOC , CAT
Else
 Actzo
 IMGFLG(5) = 0
Endif
REP = ""
Return

#-------------------------------#
$SETBOUT_PIECE
If !MODI
 Call VIREBOUT(CHBOU,"O") From GOBJET
 Call VIREBOUT(CHMEN,"BTF") From GOBJET
Endif
If !VERROU & MODI
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

#-------------------------------#
$AP_PIECE
Case REPONSE
 When GSTACLK+3
  Gosub VERROU_PIECE
Endcase
Return

Funprog NUMINSERT(TAB)
Value Integer TAB()
Local Integer NUMERO
NUMERO = max(TAB(0..dim(TAB)-1))
NUMERO += 1
End NUMERO

#---------------------------------------------------------------#
$APRES_PIECE
Case zoncou
 When "NAM"
  If !VERROU
   Gosub MESSA_MODIF
   mkstat = 2 : Return
  Endif
 When "TYPDOC"
  If !VERROU
   Gosub MESSA_MODIF
   mkstat = 2 : Return
  Endif
 When "NBLIG"
  If !VERROU
   If [M]TYPDOC(nolign-1)="" or find(status,65,68,73)
    mkstat = 2
   Endif
   Return
  Endif
 When Default
  If !VERROU
   Gosub MESSA_MODIF
   mkstat = 2 : Return
  Endif
Endcase
REP = "M"
Return

#-------------------#
$MESSA_MODIF
If !MODI
 Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification impossible
Else
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
Endif
Return

#-------------------------------#
$LECTURE
Raz [M]
Call GET_OS("",OS) From ORDSYS
Call PARAM("","DIRPCE",[M]REPERT) From ADOVAL
If [M]REPERT=""
 Call PARAM("","DIRPCE1",REP1) From ADOVAL
 Call PARAM("","DIRPCE2",REP2) From ADOVAL
 [M]REPERT = REP1+REP2
Endif
If left$([M]REPERT,1)="%"
 [M]REPERT = filpath(right$([M]REPERT,2),"","",0)
Endif
If [M]REPERT=""
 If OS="unix"
  [M]REPERT = "/"
 Else
  [M]REPERT = "\"
 Endif
Elsif !find(right$([M]REPERT,len([M]REPERT)),"/","\")
 If instr(1,[M]REPERT,"\")
  [M]REPERT += "\"
 Else
  [M]REPERT += "/"
 Endif
Endif
[M]CBLOB  = CBLOB+OBJET
[M]ABREV  = OBJET
[M]IDENT1 = CLE1
[M]IDENT2 = CLEBIS
[M]MODI   = MODI
nolign = 0
If !TEMPO
 Call TEMPON(mess(90,151,1)) From GESECRAN : # Chargement en cours...
 TEMPO = 1
Endif
Call SUP_ACBABB(OK)
nolign = 0
For [AOX]AOX0 Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
 If nolign=dim([M]NOLIG)
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  MODI = 0 : Break
 Endif
 nolign += 1
 [M] = [F:AOX]
 If instr(1,[M]NAM(nolign-1) ,"[")
  [M]NAM(nolign-1)  = ctrans([M]NAM(nolign-1) ,"\","/")
 Endif
 #[M]FMT(nolign-1) = "KU:"+num$(type([F:AOX]NAM)-10)+"X"
 [M]M1(nolign-1)  = [F:AOX]MOTCLE(0)
 [M]M2(nolign-1)  = [F:AOX]MOTCLE(1)
 [M]M3(nolign-1)  = [F:AOX]MOTCLE(2)
 [M]M4(nolign-1)  = [F:AOX]MOTCLE(3)
 [M]M5(nolign-1)  = [F:AOX]MOTCLE(4)
 [M]NOLIG(nolign-1) = val([F:AOX]IDENT3)
 Read [ACB]ACB0 = CBLOB+OBJET;CLE1;CLEBIS;[F:AOX]IDENT3
 If !fstat
  Call MAJ_ACB(CLE1,CLEBIS,[F:AOX]IDENT3,[F:ACB]CLOB,[F:ACB]TYPDOC,OK)
 Else
  Read [ABB]ABB0 = CBLOB+OBJET;CLE1;CLEBIS;[F:AOX]IDENT3
  If !fstat
   Call MAJ_ABB(CLE1,CLEBIS,[F:AOX]IDENT3,[F:ABB]BLOB,[F:ABB]TYPBLB,OK)
  Endif
 Endif
Next AOX
If TEMPO
 Call TEMPOFF From GESECRAN
 TEMPO = 0
Endif
[M]NBLIG = nolign
#SAM 120819
If MODI=0
  Grizo [M]NAM
  Grizo [M]TYPDOC
  Grizo [M]CAT
  # jira 72122 add test activity code
  If func AFNC.ACTIV("ARCH")
      Grizo [M]TUNARC
  Endif
  Grizo [M]M1
  Grizo [M]M2
  Grizo [M]M3
  Grizo [M]M4
  Grizo [M]M5
Endif

Affzo [M]

Return

Subprog SUP_ACBABB(OK)
Variable Integer OK
OK = 1
Trbegin [ABB]
 Delete [ABB] Where CODBLB=num$(adxuid(1))
 If fstat : OK = 0 : Endif
 Delete [ACB] Where CODBLB=num$(adxuid(1))
 If fstat : OK = 0 : Endif
Commit
End

# Clé des blobs Pièces jointes
# ----------------------------
# Code blob = PJ_ + code objet
# Ident1    = Première partie de clé
# Ident2    = CLEBIS - Parties suivantes séparées par ~
# Ident3    = numéro de ligne

Subprog MAJ_ABB(CLE1,CLEBIS,IDENT3,PIC,TYPBLB,OK)
Value    Char    CLE1
Value    Char    CLEBIS
Value    Char    IDENT3
Value    Blbfile PIC
Value    Integer TYPBLB
Variable Integer OK
OK = 1
Trbegin [ABB]
 [F:ABB]CODBLB = num$(adxuid(1))
 [F:ABB]IDENT1 = [L]CLE1
 [F:ABB]IDENT2 = [L]CLEBIS
 [F:ABB]IDENT3 = [L]IDENT3
 Readlock [ABB]ABB0 =
 If !fstat
  [F:ABB]BLOB   = [L]PIC
  [F:ABB]TYPBLB = [L]TYPBLB
  If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
  Rewrite [ABB]
  If fstat : OK = 0 : Endif
 Elsif fstat=1
  OK = 0
 Else
  Raz [F:ABB]
  [F:ABB]CODBLB = num$(adxuid(1))
  [F:ABB]IDENT1 = CLE1
  [F:ABB]IDENT2 = CLEBIS
  [F:ABB]IDENT3 = [L]IDENT3
  [F:ABB]BLOB   = [L]PIC
  [F:ABB]TYPBLB = [L]TYPBLB
  If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
  Write [ABB]
  If fstat : OK = 0 : Endif
 Endif
Commit
End

Subprog MAJ_ACB(CLE1,CLEBIS,IDENT3,CLOB,TYPDOC,OK)
Value    Char    CLE1
Value    Char    CLEBIS
Value    Char    IDENT3
Value    Clbfile CLOB
Value    Char    TYPDOC
Variable Integer OK
OK = 1
Trbegin [ACB]
 [F:ACB]CODBLB = num$(adxuid(1))
 [F:ACB]IDENT1 = [L]CLE1
 [F:ACB]IDENT2 = [L]CLEBIS
 [F:ACB]IDENT3 = [L]IDENT3
 Readlock [ACB]ACB0 =
 If !fstat
  [F:ACB]CLOB   = [L]CLOB
  [F:ACB]TYPDOC = [L]TYPDOC
  If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
  Rewrite [ACB]
  If fstat : OK = 0 : Endif
 Elsif fstat=1
  OK = 0
 Else
  Raz [F:ACB]
  [F:ACB]CODBLB = num$(adxuid(1))
  [F:ACB]IDENT1 = CLE1
  [F:ACB]IDENT2 = CLEBIS
  [F:ACB]IDENT3 = [L]IDENT3
  [F:ACB]CLOB   = [L]CLOB
  [F:ACB]TYPDOC = [L]TYPDOC
  If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
  Write [ACB]
  If fstat : OK = 0 : Endif
 Endif
Commit
End

#-------------------------------#
$OK_PIECE
If dim([M]ARC)>0
 For nolign=1 To [M]NBLIG
  [M]ARC(nolign-1) = 1
 Next nolign
 For [AOX] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
  For nolign=1 To [M]NBLIG
   If [M]TYPDOC(nolign-1)=[F:AOX]TYPDOC & [M]NAM(nolign-1)=[F:AOX]NAM
    [M]ARC(nolign-1) = 0
   Endif
  Next nolign
 Next AOX
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 If dim([M]ARC)>0
  For nolign=1 To [M]NBLIG
   If [M]ARC(nolign-1)
    Read [AOX]AOX0=OBJET;CLE1;CLEBIS;[M]ID3(nolign-1)
    If find([M]TYPDOC(nolign-1),CLOBX3,CLOBXT(1..NCLBXT))
     Read [ACB]ACB0=CBLOB+OBJET;CLE1;CLEBIS;[M]ID3(nolign-1)
     Call EVENEMENT(1,OBJET,"[F:ACB]CLOB",[F:AOX]TYPDOC) From ARCHIVE
    Elsif find([M]TYPDOC(nolign-1),BLOBX3(1..NBLBX3))
     Read [ABB]ABB0=CBLOB+OBJET;CLE1;CLEBIS;[M]ID3(nolign-1)
     Call EVENEMENT(1,OBJET,"[F:ABB]BLOB",[F:AOX]TYPDOC) From ARCHIVE
    Else
     Call EVENEMENT(1,OBJET,[F:AOX]NAM,[F:AOX]TYPDOC) From ARCHIVE
    Endif
   Endif
  Next nolign
 Endif
 FIN = 1
Endif
Return

$TR1
GOK = 1
Trbegin [AOX] , [AOM] , [ACB] , [ABB]
 Delete [AOX] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
 If fstat=1
  GOK = -1 : GLOCK = "$AOBJTXT"-OBJET-CLE1-CLEBIS : Goto ROLL_TR1
 Endif
 Delete [AOM] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
 If fstat=1
  GOK = -1 : GLOCK = "$AOBJTXTA"-OBJET-CLE1-CLEBIS : Goto ROLL_TR1
 Endif
 Delete [ACB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
 If fstat=1
  GOK = -1 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS : Goto ROLL_TR1
 Endif
 Delete [ABB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
 If fstat=1
  GOK = -1 : GLOCK = "$ABLOB"-CBLOB+OBJET-CLE1-CLEBIS : Goto ROLL_TR1
 Endif
 For nolign=1 To [M]NBLIG
  IDNOL = format$("N0:3#",nolign)
  If dim([M]ID3)>0
   [M]ID3(nolign-1) = IDNOL
  Endif
  For K=2 To 5
   Case K
    When 2 :  If find([M]M2(nolign-1),[M]M1(nolign-1))                                                 : [M]M2(nolign-1) = "" : Endif
    When 3 :  If find([M]M3(nolign-1),[M]M1(nolign-1),[M]M2(nolign-1))                                 : [M]M3(nolign-1) = "" : Endif
    When 4 :  If find([M]M4(nolign-1),[M]M1(nolign-1),[M]M2(nolign-1),[M]M3(nolign-1))                 : [M]M4(nolign-1) = "" : Endif
    When 5 :  If find([M]M5(nolign-1),[M]M1(nolign-1),[M]M2(nolign-1),[M]M3(nolign-1),[M]M4(nolign-1)) : [M]M5(nolign-1) = "" : Endif
   Endcase
  Next K
  Raz [F:AOX]
  [F:AOX] = [M]
  [F:AOX]ABREV = OBJET
  [F:AOX]IDENT1 = CLE1
  [F:AOX]IDENT2 = CLEBIS
  [F:AOX]IDENT3 = IDNOL
  [F:AOX]MOTCLE(0) = [M]M1(nolign-1)
  [F:AOX]MOTCLE(1) = [M]M2(nolign-1)
  [F:AOX]MOTCLE(2) = [M]M3(nolign-1)
  [F:AOX]MOTCLE(3) = [M]M4(nolign-1)
  [F:AOX]MOTCLE(4) = [M]M5(nolign-1)
  Write [AOX]
  If fstat
   GOK = 0 : Call FSTA("AOX") From GLOCK : Break
  Endif
  For K=1 To 5
   Case K
    When 1 : MOT = [M]M1(nolign-1)
    When 2 : MOT = [M]M2(nolign-1)
    When 3 : MOT = [M]M3(nolign-1)
    When 4 : MOT = [M]M4(nolign-1)
    When 5 : MOT = [M]M5(nolign-1)
   Endcase
   If MOT<>""
    [F:AOM]MOTCLE = MOT
    [F:AOM]ABREV  = OBJET
    [F:AOM]IDENT1 = CLE1
    [F:AOM]IDENT2 = CLEBIS
    [F:AOM]IDENT3 = IDNOL
    Write [AOM]
    If fstat
     GOK = 0 : Call FSTA("AOM") From GLOCK : Break 2
    Endif
   Endif
  Next K
  If GOK<1 : Break : Endif
  If find([M]TYPDOC(nolign-1),CLOBX3,CLOBXT(1..NCLBXT)) & [M]NOLIG(nolign-1)<>0
   Raz [F:ACB]
   Call LEC_ACB(CLE1,CLEBIS,format$("N0:3#",[M]NOLIG(nolign-1)),[F:ACB]CLOB,OK)
   #Call LEC_ACB(CLE1,CLEBIS,IDNOL,[F:ACB]CLOB,OK)
   [F:ACB]NAMBLB = [M]NAM(nolign-1)
   [F:ACB]TYPDOC = [M]TYPDOC(nolign-1)
   [F:ACB]CODBLB = CBLOB+OBJET
   [F:ACB]IDENT1 = CLE1
   [F:ACB]IDENT2 = CLEBIS
   [F:ACB]IDENT3 = IDNOL
   If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
   If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
   If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
   If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
   Write [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS : Break
   Endif
  Elsif find([M]TYPDOC(nolign-1),BLOBX3(1..NBLBX3)) & [M]NOLIG(nolign-1)<>0
   Raz [F:ABB]
   Call LEC_ABB(CLE1,CLEBIS,format$("N0:3#",[M]NOLIG(nolign-1)),[F:ABB]BLOB,OK)
   #Call LEC_ABB(CLE1,CLEBIS,IDNOL,[F:ABB]BLOB,OK)
   [F:ABB]NAMBLB = [M]NAM(nolign-1)
   [F:ABB]CODBLB = CBLOB+OBJET
   Case [M]TYPDOC(nolign-1)
    When "PIC"   : [F:ABB]TYPBLB = 3
    When Default : [F:ABB]TYPBLB = 1
   Endcase
   [F:ABB]IDENT1 = CLE1
   [F:ABB]IDENT2 = CLEBIS
   [F:ABB]IDENT3 = IDNOL
   If dim([F:ABB]CNTTYP)>0 : [F:ABB]CNTTYP=func ASYRLOB.F_AML7806_TO_ATYP([F:ABB]TYPBLB) : Endif
   If dim([F:ABB]CREUSR)>0 : [F:ABB]CREUSR = GUSER : Endif
   If dim([F:ABB]CREDAT)>0 : [F:ABB]CREDAT = date$ : Endif
   If dim([F:ABB]CRETIM)>0 : [F:ABB]CRETIM = time  : Endif
   Write [ABB]
   If fstat
    GOK = 0 : GLOCK = "$ABLOB"-CBLOB+OBJET-CLE1-CLEBIS : Break
   Endif
  Endif
 Next nolign
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------------------------#
$FIN_PIECE
Call SUP_ACBABB(OK)
If VERROU
 Unlock =SYMBOLE
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Gestion des Commentaires
#----------------------------------------------------------------------------------------------------#

$OUVRE_COMM
Local Char    OBJET(GLONAOB), CLE1(GLONID1), CLE2(30)(1..16), CLEBIS(GLONID2)
Local Integer OK , I , J , K , MODI
Local Char    TXTRTF(20) , CHAINE(250)

If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
If clalev([F:AOM])=0 : Local File AOBJTXTA [AOM] : Endif
If clalev([F:ACB])=0 : Local File ACLOB    [ACB] : Endif

OBJET  = PARAM(1)
CLE1   = PARAM(2)
CLEBIS = PARAM(3)

CHAINE = CLEBIS
For I=1 To dim(CLE2)
 K = instr(1,CHAINE,"~")
 If K
  CLE2(I) = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  CLE2(I) = CHAINE
  Break
 Endif
Next I

MODI = instr(1,PARAM(4),"M")

# Clé des blobs Commentaires
# --------------------------
# Code blob = CO_ + code objet
# Ident1    = Première partie de clé
# Ident2    = CLEBIS - Parties suivantes séparées par ~
# Ident3    = 1

Gosub SETCLE From ="WO"+OBJET
Gosub SET_COM
Gosub SET_TYPX3
Gosub VERROU_COMM
Return

#--------------------------#
$VERROU_COMM
If !MODI : Return : Endif
SYMBOLE = CBLOB+OBJET+CLE1
For I=1 To dim(CLESEC)
 If CLESEC(I-1)<>""
  SYMBOLE += "\"+CLE2(I)
 Endif
Next I
Lock =SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

#--------------------------#
$SETBOUT_COMM
If !VERROU | !MODI
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
If !VERROU & MODI
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

#--------------------------#
$SET_COM
Local Char CBLOB(10)
CBLOB = "CO_"
Return

#--------------------------#
$DEBUT_COMM
[M]CBLOB   = CBLOB+OBJET
[M]ABREV   = OBJET
[M]IDENT1  = CLE1
[M]IDENT2  = CLEBIS
Read [ACB]ACB0 = CBLOB+OBJET;CLE1;CLEBIS;"1"
If !fstat
 [M]COMMENT = [F:ACB]CLOB
 [M]SAVCOM  = [F:ACB]CLOB
 [M]TYPDOC  = [F:ACB]TYPDOC
Else
 Raz [M]COMMENT , SAVCOM , TYPDOC
Endif
Affzo
If !MODI
 IMGFLG(5) = 1 : # Croix blanche
 Diszo
Else
 Actzo
 IMGFLG(5) = 0
Endif
REP = ""
Return

#-------------------------------#
$AP_COMM
Case REPONSE
 When GSTACLK+3
  Gosub VERROU_COMM
Endcase
Return

#-------------------------------#
$APRES_COMM
If !VERROU
 If !find(status,GSTAESC,GSTAEND)
  Gosub MESSA_MODIF
  mkstat = 2
 Endif
 Return
Endif
[M]SAVCOM = zc
Setlob TXTRTF With [M]SAVCOM
If left$(TXTRTF,5)="{\rtf" | left$(TXTRTF,6)="{\urtf"
 [M]TYPDOC = CLOBX3
Else
 [M]TYPDOC = CLOBXT
Endif
REP = "M"
Return

#--------------------------#
$OK_COMM
Gosub TR2
If GOK=1 : FIN = 1 : Endif
Return

$TR2
Trbegin [ACB]
 If len([M]COMMENT)=0
  Delete [ACB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS & IDENT3="1"
  If fstat=1
   GOK = -1 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS-"1" : Goto ROLL_TR2
  Endif
 Else
  Readlock [ACB]ACB0 = CBLOB+OBJET;CLE1;CLEBIS;"1"
  If fstat=1
   GOK = -1 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS-"1" : Goto ROLL_TR2
  Elsif fstat
   Raz [F:ACB]
   [F:ACB]CLOB   = [M]COMMENT
   [F:ACB]TYPDOC = [M]TYPDOC
   [F:ACB]NAMBLB = CBLOB+OBJET-CLE1-CLEBIS
   [F:ACB]CODBLB = CBLOB+OBJET
   [F:ACB]IDENT1 = CLE1
   [F:ACB]IDENT2 = CLEBIS
   [F:ACB]IDENT3 = "1"
   If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
   If dim([F:ACB]CREUSR)>0 : [F:ACB]CREUSR = GUSER : Endif
   If dim([F:ACB]CREDAT)>0 : [F:ACB]CREDAT = date$ : Endif
   If dim([F:ACB]CRETIM)>0 : [F:ACB]CRETIM = time  : Endif
   Write [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS-"1" : Goto AB_TR2
   Endif
  Elsif !fstat
   [F:ACB]CLOB   = [M]COMMENT
   [F:ACB]TYPDOC = [M]TYPDOC
   If dim([F:ACB]CNTTYP)>0 : [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,nomap,[F:ACB]TYPDOC) : Endif
   If dim([F:ACB]UPDUSR)>0 : [F:ACB]UPDUSR = GUSER : Endif
   If dim([F:ACB]UPDDAT)>0 : [F:ACB]UPDDAT = date$ : Endif
   If dim([F:ACB]UPDTIM)>0 : [F:ACB]UPDTIM = time  : Endif
   Rewrite [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS-"1" : Goto AB_TR2
   Endif
  Endif
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

#--------------------------#
$FIN_COMM
If VERROU
 Unlock =SYMBOLE
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Concaténation des parties secondaires des clés avec des ~ pour la gestion des blobs
# Utilisé pour les Commentaires et Pièces Jointes
#----------------------------------------------------------------------------------------------------#

Subprog SETCLE(OBJET,CLEBIS,CLE2)
Value    Char OBJET
Variable Char CLEBIS
Value    Char CLE2()(1..)
Local Integer I, K
Gosub SETCLE From ="WO"+OBJET
CLEBIS = ""
If sum(CLE2)<>""
 For I=1 To dim(CLESEC)
  If I>1 : CLEBIS += "~" : Endif
  If CLESEC(I-1)<>CLELIG & I<=dim(CLE2)
   CLEBIS += CLE2(I)
  Endif
 Next I
Endif
End

#----------------------------------------------------------------------------------------------------#
# Concaténation des parties primaire et secondaires des clés avec des ~ pour déterminer une clé
# Utilisé pour les liens (ALINK) et le retour workflow
#----------------------------------------------------------------------------------------------------#

Subprog IDENT3(OBJET,IDENT,CLE1,CLE2)
Value    Char OBJET
Variable Char IDENT()
Value    Char CLE1
Value    Char CLE2()(1..)
Local Integer I, K
Gosub SETCLE From ="WO"+OBJET
If CLELIG<>""
 K = find(CLELIG,CLESEC)
 If K : CLE2(K) = "" : Endif
Endif
IDENT = CLE1
For I=1 To dim(CLESEC)
 If CLESEC(I-1)<>"" & I<=dim(CLE2)
  IDENT += "~"+CLE2(I)
 Endif
Next I
End

#---------------------------------------------------------------------------------------------------------#
# Concaténation des parties primaire et secondaires des clés avec des _ pour déterminer le nom d'un fichier
#---------------------------------------------------------------------------------------------------------#

Subprog IDENT2(OBJET,IDENT,CLE1,CLE2)
Value    Char OBJET
Variable Char IDENT()
Value    Char CLE1
Value    Char CLE2()(1..)
Local Integer K
Local Char    INTERDIT(50), SEP(1)
SEP = left$(OBJET,1)
If SEP>="A" & SEP<="Z"
 SEP   = ""
Else
 OBJET = right$(OBJET,2)
Endif
If OBJET<>"" : # Pour gérer les objets combinés GH 06/09/01
 Gosub SETCLE From ="WO"+OBJET
 If CLELIG<>""
  K = find(CLELIG,CLESEC)
  If K : CLE2(K) = "" : Endif
 Endif
Endif
Gosub SET_IDENT
End

#-----------------------------#
Subprog IDENT(IDENT,CLE1,CLE2)
Variable Char IDENT()
Value    Char CLE1
Value    Char CLE2()(1..)
Local Integer K
Local Char    INTERDIT(50), SEP(1)
Gosub SET_IDENT
End

#-----------------------------#
$SET_IDENT
If SEP="" : SEP = "_" : Endif
IDENT = CLE1
For K=1 To dim(CLE2)
 If CLE2(K)<>""
  IDENT += SEP+CLE2(K)
 Endif
Next K
GPOINT = "INTERDIT" : Gosub ENTREE From EXEFNC : # mb 24.5.2 Demande no 14391
# Pour ne pas avoir de caractères spéciaux dans le nom d'un fichier
INTERDIT = '?"/\<>*[]|^:;,='
IDENT = ctrans(IDENT,INTERDIT,string$(len(INTERDIT),"-"))
Return

#**
#* Allow to know if an attachment or a comment exists for the object
#*
#* @param OBJET : Object (e.g ITM, BPC...)
#* @param CLE1  : First element of the key of the object to check
#* @param CLE2  : Array of other elements of the key
#* @return [V]CST_AYES if an attachment or comment exists for the object, otherwise [V]CST_ANO
#*!
Funprog ATTACH_EXIST(OBJET,CLE1,CLE2)
Value    Char OBJET
Value    Char CLE1
Value    Char CLE2()(1..)

Local Integer LRET : LRET=[V]CST_ANO
Local Char    CLEBIS(GLONID2)

Local File ACLOB   [ACB]
Local File AOBJTXT  [AOX]

# 1- Look for comments
Gosub SET_COM
Call SETCLE(OBJET,CLEBIS,CLE2)

Filter [ACB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS & IDENT3="1"
Look [ACB] First
Filter [ACB]
If !fstat
    LRET=[V]CST_AYES
Else
    # 2- Look for attachment
    Filter [AOX] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
    Look [AOX] First
    Filter [AOX]
    If !fstat
        LRET=[V]CST_AYES
    Endif
Endif

LogicClose File [ACB]
LogicClose File [AOX]

End LRET

#----------------------------------------------------------------------------------------------------#
# Duplication
#----------------------------------------------------------------------------------------------------#
#**
#* Duplicate attachments and comments of an object to another
#*
#* @param OBJET1 : Object from (e.g ITM, BPC...)
#* @param OBJET2 : Object to (e.g ITM, BPC...)
#* @param OCLE1  : First element of the key of the object to copy
#* @param OCLE2  : Array of other elements of the key
#* @param NCLE1  : First element of the key of the destination object
#* @param NCLE2  : Array of other elements of the key
#*!
Subprog DUPLI(OBJET1,OBJET2,OCLE1,OCLE2,NCLE1,NCLE2)
Value    Char OBJET1
Value    Char OBJET2
Value    Char OCLE1
Value    Char OCLE2()(1..)
Value    Char NCLE1
Value    Char NCLE2()(1..)

Local Char    OCLEBIS(GLONID2), NCLEBIS(GLONID2), FILTRE(250)
Local Integer I

If clalev([F:ACB])=0  : Local File ACLOB   [ACB]  : Endif

# Y-avait-il un commentaire associé ? si oui on le duplique.

Gosub SET_COM

Call SETCLE(OBJET1,OCLEBIS,OCLE2)
Call SETCLE(OBJET2,NCLEBIS,NCLE2)

If !adxlog
 Gosub TR_DUPC
Else
 Gosub MAJ_DUPC
Endif
If GOK<1 : End : Endif

# Duplication des pièces jointes

Gosub SET_PCE
Gosub SET_TYPX3

# Issue X3-69532 - 2018-06-26 by CCC : if the attachments must be duplicated, all types are duplicated
#FILTRE = 'find(TYPDOC,CLOBX3,CLOBXT(1..NCLBXT),BLOBX3(1..NBLBX3))<>0' : # Uniquement les blobs et clobs ???
FILTRE = "1=1"

If clalev([F:AOX])=0  : Local File AOBJTXT  [AOX]  : Endif
If clalev([F:AOM])=0  : Local File AOBJTXTA [AOM]  : Endif
If clalev([F:ABB])=0  : Local File ABLOB    [ABB]  : Endif

If !adxlog
 Gosub TR_DUPP
Else
 Gosub MAJ_DUPP
Endif
If GOK<1 : End : Endif

End

#----------------------------#

$TR_DUPC
GOK = 1
Trbegin [ACB]
 Gosub MAJ_DUPC
 If    GOK=0  : Goto AB_DUPC
 Elsif GOK=-1 : Goto ROLL_DUPC
 Endif
Commit
Return

$AB_DUPC
Rollback
Return

$ROLL_DUPC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DUPC : Endif

$MAJ_DUPC
Delete [ACB] Where CODBLB=CBLOB+OBJET2 & IDENT1=NCLE1 & IDENT2=NCLEBIS & IDENT3="1"
Read [ACB]ACB0 = CBLOB+OBJET1;OCLE1;OCLEBIS;"1"
If !fstat
 [F:ACB]CODBLB = CBLOB+OBJET2
 [F:ACB]IDENT1 = NCLE1
 [F:ACB]IDENT2 = NCLEBIS
 [F:ACB]IDENT3 = "1"
 Write [ACB]
 If fstat
  GOK = 0 : GLOCK = "$ACLOB"-CBLOB+OBJET2-NCLE1-NCLEBIS
 Endif
Endif
Return

#----------------------------#

$TR_DUPP
GOK = 1
Trbegin [AOX] , [AOM] , [ACB] , [ABB]
 Gosub MAJ_DUPP
 If    GOK=0  : Goto AB_DUPP
 Elsif GOK=-1 : Goto ROLL_DUPP
 Endif
Commit
Return

$AB_DUPP
Rollback
Return

$ROLL_DUPP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_DUPP : Endif

$MAJ_DUPP
Delete [AOX] Where ABREV=OBJET2 & IDENT1=NCLE1 & IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXT"-CBLOB+OBJET2-NCLE1-NCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOX") From GLOCK : Return
Endif
Delete [AOM] Where ABREV=OBJET2 & IDENT1=NCLE1 & IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXTA"-CBLOB+OBJET2-NCLE1-NCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOM") From GLOCK : Return
Endif
Delete [ABB] Where CODBLB=CBLOB+OBJET2 & IDENT1=NCLE1 & IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ABLOB"-CBLOB+OBJET2-NCLE1-NCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ABB") From GLOCK : Return
Endif
Delete [ACB] Where CODBLB=CBLOB+OBJET2 & IDENT1=NCLE1 & IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ACLOB"-CBLOB+OBJET2-NCLE1-NCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ACB") From GLOCK : Return
Endif
I = 0
For [AOX] Where ABREV=OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS & evalue(FILTRE)
 I += 1
 For [AOM] Where ABREV=OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS & IDENT3=[F:AOX]IDENT3
  [F:AOM]ABREV = OBJET2
  [F:AOM]IDENT1 = NCLE1
  [F:AOM]IDENT2 = NCLEBIS
  [F:AOM]IDENT3 = [F:AOX]IDENT3
  Write [AOM]
  If fstat
   GOK = 0 : GLOCK = "$AOBJTXTA"-OBJET2-NCLE1-NCLEBIS-[F:AOX]IDENT3 : Break 2
  Endif
 Next AOM
 If find([F:AOX]TYPDOC,CLOBX3,CLOBXT(1..NCLBXT)) : # Textes
  Read [ACB]ACB0 = CBLOB+OBJET1;OCLE1;OCLEBIS;[F:AOX]IDENT3
  If !fstat
   [F:ACB]CODBLB = CBLOB+OBJET2
   [F:ACB]IDENT1 = NCLE1
   [F:ACB]IDENT2 = NCLEBIS
   [F:ACB]IDENT3 = [F:AOX]IDENT3
   Write [ACB]
   If fstat
    GOK = 0 : GLOCK = "$ACLOB"-CBLOB+OBJET2-NCLE1-NCLEBIS-[F:AOX]IDENT3 : Break
   Endif
  Endif
 Elsif find([F:AOX]TYPDOC,BLOBX3(1..NBLBX3)) : # Images
  Read [ABB]ABB0 = CBLOB+OBJET1;OCLE1;OCLEBIS;[F:AOX]IDENT3
  If !fstat
   [F:ABB]CODBLB = CBLOB+OBJET2
   [F:ABB]IDENT1 = NCLE1
   [F:ABB]IDENT2 = NCLEBIS
   [F:ABB]IDENT3 = [F:AOX]IDENT3
   Write [ABB]
   If fstat
    GOK = 0 : GLOCK = "$ABLOB"-CBLOB+OBJET2-NCLE1-NCLEBIS-[F:AOX]IDENT3 : Break
   Endif
  Endif
 Endif
 [F:AOX]ABREV = OBJET2
 [F:AOX]IDENT1 = NCLE1
 [F:AOX]IDENT2 = NCLEBIS
 [F:AOX]IDENT3 = [F:AOX]IDENT3
 Write [AOX]
 If fstat
  GOK = 0 : GLOCK = "$AOBJTXT"-OBJET2-NCLE1-NCLEBIS-[F:AOX]IDENT3 : Break
 Endif
Next AOX
Return

#----------------------------------------------------------------------------------------------------#
# Annulation
#----------------------------------------------------------------------------------------------------#

Subprog ANUCOD(APPLI,OBJET,CLE1,CLE2)
Value    Char APPLI
Value    Char OBJET
Value    Char CLE1
Value    Char CLE2()(1..)
Goto ANUCOD_SUB

Subprog ANNULE(OBJET,CLE1,CLE2)
Value    Char OBJET
Value    Char CLE1
Value    Char CLE2()(1..)

$ANUCOD_SUB

Local Char    IDENT(50)
Local Char    CLEBIS(GLONID2)

If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:ACB])=0 : Local File =[L]APPLI+".ACLOB" [ACB] : Endif
Else
 If clalev([F:ACB])=0 : Local File ACLOB [ACB] : Endif
Endif

Call SETCLE(OBJET,CLEBIS,CLE2)

## Effacement du commentaire

Gosub SET_COM

If !adxlog
 Gosub TR_ANNUC
Else
 Gosub MAJ_ANNUC
Endif
If GOK<1 : End : Endif

## Effacement des pièces jointes

Gosub SET_PCE

If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:AOX])=0 : Local File =[L]APPLI+".AOBJTXT"  [AOX] : Endif
 If clalev([F:AOM])=0 : Local File =[L]APPLI+".AOBJTXTA" [AOM] : Endif
 If clalev([F:ABB])=0 : Local File =[L]APPLI+".ABLOB"    [ABB] : Endif
Else
 If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
 If clalev([F:AOM])=0 : Local File AOBJTXTA [AOM] : Endif
 If clalev([F:ABB])=0 : Local File ABLOB    [ABB] : Endif
Endif

If !adxlog
 Gosub TR_ANNUP
Else
 Gosub MAJ_ANNUP
Endif
If GOK<1 : End : Endif

End

#----------------------------#

$TR_ANNUC
GOK=1
Trbegin [ACB]
 Gosub MAJ_ANNUC
 If    GOK=0  : Goto AB_ANNUC
 Elsif GOK=-1 : Goto ROLL_ANNUC
 Endif
Commit
Return

$AB_ANNUC
Rollback
Return

$ROLL_ANNUC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUC : Endif

$MAJ_ANNUC
Delete [ACB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS
Elsif fstat
 GOK=0 : Call FSTA("ACB") From GLOCK
Endif
Return

#----------------------------#

$TR_ANNUP
GOK=1
Trbegin [AOX] , [AOM] , [ACB] , [ABB]
 Gosub MAJ_ANNUP
 If    GOK=0  : Goto AB_ANNUP
 Elsif GOK=-1 : Goto ROLL_ANNUP
 Endif
Commit
Return

$AB_ANNUP
Rollback
Return

$ROLL_ANNUP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ANNUP : Endif

$MAJ_ANNUP
Delete [AOX] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXT"-OBJET-CLE1-CLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOX") From GLOCK : Return
Endif
Delete [AOM] Where ABREV=OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXTA"-OBJET-CLE1-CLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOM") From GLOCK : Return
Endif
Delete [ABB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ABLOB"-CBLOB+OBJET-CLE1-CLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ABB") From GLOCK : Return
Endif
Delete [ACB] Where CODBLB=CBLOB+OBJET & IDENT1=CLE1 & IDENT2=CLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ACLOB"-CBLOB+OBJET-CLE1-CLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ACB") From GLOCK : Return
Endif
Return

#----------------------------------------------------------------------------------------------------#
## Changement de code
#----------------------------------------------------------------------------------------------------#

Subprog CHGCOD(APPLI,OBJET1,OBJET2,OCLE1,OCLE2,NCLE1,NCLE2)
Value    Char APPLI
Value    Char OBJET1
Value    Char OBJET2
Value    Char OCLE1
Value    Char OCLE2()(1..)
Value    Char NCLE1
Value    Char NCLE2()(1..)
Goto CHANGE_SUB

Subprog CHANGE(OBJET1,OBJET2,OCLE1,OCLE2,NCLE1,NCLE2)
Value    Char OBJET1
Value    Char OBJET2
Value    Char OCLE1
Value    Char OCLE2()(1..)
Value    Char NCLE1
Value    Char NCLE2()(1..)

$CHANGE_SUB

Local Char    OIDENT(50) , NIDENT(50)
Local Char    OCLEBIS(GLONID2), NCLEBIS(GLONID2)

If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:ACB])=0 : Local File =[L]APPLI+".ACLOB" [ACB] : Endif
Else
 If clalev([F:ACB])=0 : Local File ACLOB [ACB] : Endif
Endif

Call SETCLE(OBJET1,OCLEBIS,OCLE2)
Call SETCLE(OBJET2,NCLEBIS,NCLE2)

## Rename du commentaire

Gosub SET_COM

If !adxlog
 Gosub TR_CHANGEC
Else
 Gosub MAJ_CHANGEC
Endif
If GOK<1 : End : Endif

## Rename des liens aux pièces jointes

Gosub SET_PCE

If dim([L]APPLI)>0 & [L]APPLI<>""
 If clalev([F:AOX])=0 : Local File =[L]APPLI+".AOBJTXT"  [AOX] : Endif
 If clalev([F:AOM])=0 : Local File =[L]APPLI+".AOBJTXTA" [AOM] : Endif
 If clalev([F:ABB])=0 : Local File =[L]APPLI+".ABLOB"    [ABB] : Endif
Else
 If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif
 If clalev([F:AOM])=0 : Local File AOBJTXTA [AOM] : Endif
 If clalev([F:ABB])=0 : Local File ABLOB    [ABB] : Endif
Endif

If !adxlog
 Gosub TR_CHANGEP
Else
 Gosub MAJ_CHANGEP
Endif
If GOK<1 : End : Endif

End

#----------------------------#

$TR_CHANGEC
GOK=1
Trbegin [ACB]
 Gosub MAJ_CHANGEC
 If    GOK=0  : Goto AB_CHANGEC
 Elsif GOK=-1 : Goto ROLL_CHANGEC
 Endif
Commit
Return

$AB_CHANGEC
Rollback
Return

$ROLL_CHANGEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHANGEC : Endif

$MAJ_CHANGEC
Update [ACB] Where CODBLB=CBLOB+OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS
&             With CODBLB=CBLOB+OBJET2 , IDENT1=NCLE1 , IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ACLOB"-CBLOB+OBJET1-OCLE1-OCLEBIS
Elsif fstat
 GOK=0 : Call FSTA("ACB") From GLOCK
Endif
Return

#----------------------------#

$TR_CHANGEP
GOK=1
Trbegin [AOX] , [AOM] , [ACB] , [ABB]
 Gosub MAJ_CHANGEP
 If    GOK=0  : Goto AB_CHANGEP
 Elsif GOK=-1 : Goto ROLL_CHANGEP
 Endif
Commit
Return

$AB_CHANGEP
Rollback
Return

$ROLL_CHANGEP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CHANGEP : Endif

$MAJ_CHANGEP
Update [AOX] Where ABREV=OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS
&             With ABREV=OBJET2 , IDENT1=NCLE1 , IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXT"-CBLOB+OBJET1-OCLE1-OCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOX") From GLOCK : Return
Endif
Update [AOM] Where ABREV=OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS
&             With ABREV=OBJET2 , IDENT1=NCLE1 , IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$AOBJTXTA"-CBLOB+OBJET1-OCLE1-OCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("AOM") From GLOCK : Return
Endif
Update [ABB] Where CODBLB=CBLOB+OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS
&             With CODBLB=CBLOB+OBJET2 , IDENT1=NCLE1 , IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ABLOB"-CBLOB+OBJET1-OCLE1-OCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ABB") From GLOCK : Return
Endif
Update [ACB] Where CODBLB=CBLOB+OBJET1 & IDENT1=OCLE1 & IDENT2=OCLEBIS
&             With CODBLB=CBLOB+OBJET2 , IDENT1=NCLE1 , IDENT2=NCLEBIS
If fstat=1
 GOK=-1 : GLOCK="$ACLOB"-CBLOB+OBJET1-OCLE1-OCLEBIS : Return
Elsif fstat
 GOK=0 : Call FSTA("ACB") From GLOCK : Return
Endif
Return

#---------------------------------------------------------------------------------------#
# Retrouve le nom du fichier et son extension depuis le chemin
#---------------------------------------------------------------------------------------#

Subprog SETNAM(NOMFIC,NAM,SUF)
Value    Char NOMFIC : # Nom fichier saisi (avec ou sans chemin)
Variable Char NAM    : # Nom du fichier sans chemin ni extension
Variable Char SUF    : # Extension
Local Integer I
Local Char    CHAINE(250)
CHAINE = NOMFIC
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
SUF = ""
For I=len(CHAINE) To 1 Step -1
 If mid$(CHAINE,I,1)="."
  SUF = right$(CHAINE,I+1)
  CHAINE = left$(CHAINE,I-1)
  Break
 Endif
Next I
NAM = CHAINE
End

#---------------------------------------------------------------------------------------#
# Retrouve le nom du fichier depuis le chemin
#---------------------------------------------------------------------------------------#

Funprog SETFIC(CHEMIN)
Value Char CHEMIN
Local Integer I
Local Char    CHAINE(250)
CHAINE = CHEMIN
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
End CHAINE

#---------------------------------------------------------------------------------------#
# Retrouve le nom du répertoire depuis le chemin
#---------------------------------------------------------------------------------------#

Subprog SETREP(NOMFIC,REP)
Value    Char NOMFIC : # Nom fichier saisi (avec ou sans chemin)
Variable Char REP    : # Nom du répertoire
Local Integer I
Local Char    CHAINE(250)
CHAINE = NOMFIC
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
If I=0
 REP = "" : End
Endif
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
REP = left$(NOMFIC,len(NOMFIC)-len(CHAINE)-1)
End

