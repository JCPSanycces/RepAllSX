Subprog LEC_ACB(CLE1,CLEBIS,IDENT3,CLOB,OK)
#Value        Char    OBJET
Value        Char    CLE1
Value        Char    CLEBIS
Value        Char    IDENT3
Variable     Clbfile CLOB
Variable     Integer OK
Raz [F:ACB]
[F:ACB]CODBLB = num$(adxuid(1))
[F:ACB]IDENT1 = [L]CLE1
[F:ACB]IDENT2 = [L]CLEBIS
[F:ACB]IDENT3 = [L]IDENT3
Read [ACB] =
If !fstat
 OK = 1
 [L]CLOB = [F:ACB]CLOB
Else
 OK = 0
 Raz [L]CLOB
Endif
End

Subprog LEC_ABB(CLE1,CLEBIS,IDENT3,BLOB,OK)
#Value        Char    OBJET
Value        Char    CLE1
Value        Char    CLEBIS
Value        Char    IDENT3
Variable     Blbfile BLOB
Variable     Integer OK
Raz [F:ABB]
[F:ABB]CODBLB = num$(adxuid(1))
[F:ABB]IDENT1 = [L]CLE1
[F:ABB]IDENT2 = [L]CLEBIS
[F:ABB]IDENT3 = [L]IDENT3
Read [ABB] =
If !fstat
 OK = 1
 [L]BLOB = [F:ABB]BLOB
Else
 OK = 0
 Raz [L]BLOB
Endif
End

