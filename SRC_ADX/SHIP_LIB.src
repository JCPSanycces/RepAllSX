#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Shipment library : use with shipment class and transport class
#*!
$CTR_INSERT
Gosub CTR_TRNP
Return

$CTR_UPDATE
Gosub CTR_TRNP
Gosub CTR_DATE
Return

#**
#* 1 - if arrival date is fill, departure date mandatory and departure date<arrival date < day date
#* 2 - place : il departure place is fill, arrival place must be fill and different from the departure place
#* 3 - calcul expected arrival date if modification of impactante zone and arrival date = null
#* 4 - add shiplag on arrival date if departure date is fill
#*!
$CTR_TRNP
 Local Char WMESSAGE(250)
 Local Integer WLTI
 Local Char WTEXTE(50)
  Local Integer WRECAL  #1 si la date d'arrivée prévue a été recalculée, 0 sinon

  #1 - if arrival date is fill, departure date mandatory and departure date<arrival date < day date
  If this.ARVDAT <> AVOID.ADATE
    If this.DPEDAT = AVOID.ADATE
      [L]ASTATUS = fmet this.ASETERROR("", mess(521,194,1) + " : " + mess(10,123,1), [V]CST_AERROR)
      Return
    Endif
    If this.ARVDAT < this.DPEDAT | this.ARVDAT > date$
      [L]ASTATUS = fmet this.ASETERROR("", mess(536,194,1), [V]CST_AERROR)
      Return
    Endif
  Endif

  If this.ARVEXPDAT <> AVOID.ADATE & this.ARVEXPDAT < this.DPEDAT
    [L]ASTATUS = fmet this.ASETERROR("", mess(538,194,1), [V]CST_AERROR)
    Return
  Endif

  # 2 - place : il departure place is fill, arrival place must be fill and different from the departure place
  If this.DPETPC <> AVOID.ACHAR
    If this.ARVTPC <> AVOID.ACHAR
      If this.ARVTPC = this.DPETPC
        [L]ASTATUS = fmet this.ASETERROR("", mess(626,199,1), [V]CST_AERROR)
        Return
      Endif
    Else
      Call TEXTE(53837, WTEXTE) From OBJDIV
      [L]ASTATUS = fmet this.ASETERROR(WTEXTE, mess(10,123,1), [V]CST_AERROR)
      Return
    Endif
  Endif
WRECAL = 0
#3 - calcul expected arrival date if modification of impactante zone and arrival date = null
If ( this.ACTX.AINFOS.NAMCLA = "C_SHIPMENT")
  If (((this.ARVTPC<> this.snapshot.ARVTPC | this.DPETPC<> this.snapshot.DPETPC | this.BPTNUM<> this.snapshot.BPTNUM | this.TRNMOD<> this.snapshot.TRNMOD |this.DPEDAT <> this.snapshot.DPEDAT)
& & this.TRNNUM ="") | (this.TRNNUM="" & this.snapshot.TRNNUM <> "") | (this.ARVEXPDAT= AVOID.ADATE))  & this.DPEDAT <> AVOID.ADATE
    Call CAL_LEADTIME(1,this.DPETPC,this.ARVTPC,this.BPTNUM, this.TRNMOD, WLTI) From STCLIB
    #on réapplique le décalage total sur la nouvelle date
    this.ARVEXPDAT  = this.DPEDAT + WLTI + this.SHIPLAG
    WRECAL = 1
  Endif
Else
  If (this.ARVTPC<> this.snapshot.ARVTPC | this.DPETPC<> this.snapshot.DPETPC | this.BPTNUM<> this.snapshot.BPTNUM | this.TRNMOD<> this.snapshot.TRNMOD |this.DPEDAT <> this.snapshot.DPEDAT)
&  | (this.ARVEXPDAT= AVOID.ADATE)  & this.DPEDAT <> AVOID.ADATE
    Call CAL_LEADTIME(1,this.DPETPC,this.ARVTPC,this.BPTNUM, this.TRNMOD, WLTI) From STCLIB
    #on réapplique le décalage total sur la nouvelle date
    this.ARVEXPDAT  = this.DPEDAT + WLTI + this.SHIPLAG
    WRECAL = 1
  Endif
Endif


#If (((this.ARVTPC<> this.snapshot.ARVTPC | this.DPETPC<> this.snapshot.DPETPC | this.BPTNUM<> this.snapshot.BPTNUM | this.TRNMOD<> this.snapshot.TRNMOD |this.DPEDAT <> this.snapshot.DPEDAT) & (this.
#& TRNNUM ="" &this.ACTX.AINFOS.NAMCLA<>"C_TRANSPORT"))
#& | (this.TRNNUM="" & this.snapshot.TRNNUM <> "") | (this.ARVEXPDAT= AVOID.ADATE)) & this.DPEDAT <> AVOID.ADATE
#    Call CAL_LEADTIME(1,this.DPETPC,this.ARVTPC,this.BPTNUM, this.TRNMOD, WLTI) From STCLIB
#    #on réapplique le décalage total sur la nouvelle date
#    this.ARVEXPDAT  = this.DPEDAT + WLTI + this.SHIPLAG
#    WRECAL = 1
#Endif

# 4 - add shiplag on arrival date if departuree date is fill
If this.SHIPSLAG <> 0
  If this.DPEDAT <> AVOID.ADATE
    this.ARVEXPDAT += this.SHIPSLAG
  Endif
  this.SHIPLAG += this.SHIPSLAG
  this.SHIPSLAG = AVOID.ADEC
  WRECAL = 1
Endif

Return
# End issue 111257
#######################################################################################
# Issue 111257 US 32
#**
#* if arrival date is filled, no modification on departure date, departure and arrival place, carrier and carrier mode
#*!
$CTR_DATE
Local Char WTEXTE (100)
Local Char WTEXTE1 (200)
Local Char WTEXTETMP (100)
If this.ARVDAT <> AVOID.ADATE & this.snapshot.ARVDAT<> AVOID.ADATE
  If (this.DPEDAT<>this.snapshot.DPEDAT) | (this.DPETPC<>this.snapshot.DPETPC) | (this.ARVTPC<>this.snapshot.ARVTPC)
&   | (this.TRNMOD<>this.snapshot.TRNMOD) | (this.BPTNUM<>this.snapshot.BPTNUM)
    Call TEXTE(52762, WTEXTE) From OBJDIV
    Call TEXTE(52763, WTEXTE1) From OBJDIV
    Call TEXTE(14436, WTEXTETMP) From OBJDIV
    WTEXTE1 = WTEXTE1 + "," + WTEXTETMP
    Call TEXTE(1434, WTEXTETMP) From OBJDIV
    WTEXTE1 = WTEXTE1 + "," + WTEXTETMP
    WTEXTETMP = mess(520,194,1)
    WTEXTE1 = WTEXTE1 + "," + WTEXTETMP
    WMESSAGE = func AFNC.MES2 (mess(545,194,1),WTEXTE,WTEXTE1)
    [L]ASTATUS = fmet this.ASETERROR("", WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Endif
Return
# End Issue 111257 US 32

