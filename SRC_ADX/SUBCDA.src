#<AdxTL>@(#)3.0.0.0 $Revision$
Call OBJET("CDA",GBIDC1,GBIDC2) From GOBJET
End
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "RAZCRE"      : Gosub RAZCRE
 When "SETBOUT"     : Gosub SETBOUT
 When "LIENS"       : Gosub LIENS
 When "INIMOD"      : Gosub INIMOD
 When "INICRE"      : Gosub INIMOD
 When "VERIF_MOD"   : Gosub VERFMOD
 When "VERIF_CRE"   : Gosub VERFMOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "CHGCOD"      : Gosub CHGCOD
 When "ANNULE"      : Gosub ANNULE
 When "FERME"       : Gosub FERME
 When "AB1_ACCVCR"  : Gosub AB1_ACCVCR
 When "BB1_ACCVCR"  : Gosub BB1_ACCVCR
 When "AS_COD"      : Raz GCURLEG
Endcase
Return


$OUVRE
Local Char BPCTYP(GLONTSV), BPSTYP(GLONTPV), PROTYP(GLONTPV)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$AFFMASK
Call FMTLEG From TRTX3
Gosub GRILEG
Return

$RAZCRE
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0
 Diszo [M:CDA1]LEG
 [M:CDA1]LEG=GDOSLEG(1)
 Affzo [M:CDA1]LEG
Endif
Return

$LIENS
GCURLEG = [F:CDA]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If [M]ACCTYP = 1 : Grizo ACCVCRFLG : Else : Actzo ACCVCRFLG : Endif
Call LECTEXTRA([M]DESTRA,"GACCDENCOD","DESTRA",[M]COD,GCURLEG) From ATEXTRA
Call LECTEXTRA([M]SHOTRA,"GACCDENCOD","SHOTRA",[M]COD,GCURLEG) From ATEXTRA
Call PARAM(GCURLEG,"BPCORDTYP",[L]BPCTYP) From CPTLEC
Call PARAM(GCURLEG,"BPSORDTYP",[L]BPSTYP) From CPTLEC
If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Call PARAM(GCURLEG,"BPSPROTYP",[L]PROTYP) From CPTLEC
Endif   # Issue X3-107197
Case [M]IPTTYP
 When 1 : [M]IPTCOD=[L]BPCTYP
 When 2 : [M]IPTCOD=[L]BPSTYP
 When 4 : [M]IPTCOD=[L]PROTYP
Endcase
Return

$INIMOD
If dim([F]DES)>0
 [F]DES = [M]DESTRA
Endif
If [F]IPTTYP<>3 : [F]IPTCOD="" : Endif
If func AFNC.ACTIV("LEG")=0 : [F:CDA]LEG = GDOSLEG(1) : Endif
Return

$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"U") From GOBJET
Endif
Return

$VERFMOD
If [M]ACCTYP=1 & [M]ACCBPR="" & [M]RPCVAT=2
 GMESSAGE=mess(150,121,1)
 GERR = 1 : OK = 0  : Return
Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GACCDENCOD","DESTRA",CLECUR2,CLECUR1,"GACCDENCOD","DESTRA",GCURLEG,[M]COD)  From ATEXTRA
 Call DUPTEXTRA("GACCDENCOD","SHOTRA",CLECUR2,CLECUR1,"GACCDENCOD","SHOTRA",GCURLEG,[M]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GACCDENCOD","DESTRA",[M]COD,GCURLEG) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GACCDENCOD","SHOTRA",[M]COD,GCURLEG) From ATEXTRA
Return

$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return

$AP_CHANGE
Call CHGTEXTRA("GACCDENCOD","DESTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("GACCDENCOD","SHOTRA",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("GACCDENCOD","DESTRA",[M]COD,GCURLEG) From ATEXTRA
Call SUPTEXTRA("GACCDENCOD","SHOTRA",[M]COD,GCURLEG) From ATEXTRA
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the Tunnel button
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONCDA) : Endif
VCOD = CLE2
Return

###############################################################################
##  Copie
###############################################################################
$TRTCOP
Local Char LEGDEST(250)

If [M]DOSORG=nomap
 Local File GACCDENCOD  [CDA1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GACCDENCOD"  [CDA1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GACCDENCOD [CDA2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".GACCDENCOD"  [CDA2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA

# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE2-":"-mess(249,133,1) ) From GESECRAN
 Return
Endif

# We can't copy an empty legislation to a single-legislation folder. We have to move the empty legislation
# to the legislation of the destination folder before the copy
LEGDEST = TABLE2
If LEGDEST="" & [F:ADS2]NBLEG=1
 LEGDEST = [F:ADS2]DOSLEG(0)
Endif

Call DEBTRANS From GLOCK
Gosub TR_COP

Close Local File [CDA1], [CDA2], [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [CDA2]
 Delete [CDA2] Where COD=TABLE & LEG=LEGDEST
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GACCDENCOD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("CDA2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [CDA1] Where COD=TABLE & LEG=TABLE2
  [F:CDA2] = [F:CDA1]
  [F:CDA2]LEG = LEGDEST
  Call COPTEXTRALEG("GACCDENCOD","DESTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  Call COPTEXTRALEG("GACCDENCOD","SHOTRA",TABLE,TABLE2,LEGDEST) From CPTDIV
  If dim([F:CDA2]UPDUSR)>0 : [F:CDA2]UPDUSR = GUSER : Endif
  If dim([F:CDA2]UPDDAT)>0 : [F:CDA2]UPDDAT = date$ : Endif
  Write [CDA2]
  If fstat
   GOK = 0 : Call FSTA("CDA2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

#########################################################
Subprog IB_COD
If GFONCTION = "GESCDA" : GBOUT1="" : End : Endif
End

Subprog C_LEG(VALEUR)
Variable Char  VALEUR()
GCURLEG = VALEUR
End

Subprog C_ACS(VALEUR)
Variable Char  VALEUR()
If VALEUR<>""
 If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif
 Filter [ADW] Where [F:ADW]VALEUR=[M]COD
&                 & find([F:ADW]PARAM,"DENINSRCP","DENINSSEN","DENSPG","DENTAK")
 Read [ADW]ADW0 First
 Filter [ADW]
 If fstat<=2 : # Paramètre
  GMESSAGE=mess(81,123,1)-"TRS"-[F:ADW]PARAM
  If [F:ADW]FCY<>"" : GMESSAGE+="("+[F:ADW]FCY+")" : Endif
  VALEUR="" : mkstat=2
 Endif
Endif
End

Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)
Call CNTCOHGRPLEG(VALEUR,GCURLEG,STAT,MESSA) From CPTCNT
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End

$AB1_ACCVCR
Local Integer OPTVCR
OPTVCR = GBIDI1
GBIDI1 = 2
Return

$BB1_ACCVCR
GBIDI1 = OPTVCR
Return

Subprog AS_CIB(VALEUR)
Variable Char     VALEUR
If [M]ACCTYP=3 | [M]ACCVCRFLG<>2 : mkstat=1 : Endif : # Compte<=>Tiers
End

Subprog AS_IPTDAC(VALEUR)
Variable Integer  VALEUR
If [M]ACCTYP=2 : VALEUR=1 : mkstat=2 : Endif : # Banque<=>Compte
End

Subprog AS_IPTCOD(VALEUR)
Variable Char     VALEUR
If [M]IPTDAC<>2 : [M]IPTTYP=0 : mkstat=1 : Endif
End

Subprog C_IPTCOD(VALEUR)
Variable Char     VALEUR
If VALEUR="" : [M]IPTTYP=0 : End : Endif

If GNBLEG = 1 :
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG = [M]LEG
Endif

If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif
Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
If !fstat
 ## Le type de pièce existe mais est-il cohérent par rapport à la législation associée
 ## à la destination comptable : Call CONTROLE pour vérifier cela....
 Call CONTGTE(VALEUR,GCURLEG,[M]GFY) From SUBGTE
 If mkstat : End : Endif
 If [M]ACCBPR<>""
  GMESSAGE=mess(43,106,1)
  mkstat=2 : End
 Endif
 [M]IPTTYP=3

Else
 Call PARAM(GCURLEG,"BPCORDTYP",[M]BPCTYP) From CPTLEC
  Call PARAM(GCURLEG,"BPSORDTYP",[M]BPSTYP) From CPTLEC
 If func AFNC.ACTIV("KIT")   # Issue X3-107197
  Call PARAM(GCURLEG,"BPSPROTYP",[M]PROTYP) From CPTLEC
 Endif   # Issue X3-107197
 Case VALEUR
  When [M]BPCTYP : [M]IPTTYP=1
  When [M]BPSTYP : [M]IPTTYP=2
  When [M]PROTYP : [M]IPTTYP=4
  When Default
   GMESSAGE=mess(17,114,1)
   mkstat=2 : End
 Endcase
Endif
End

Subprog AS_IPTDEP(VALEUR)
Variable Integer VALEUR
If [M]ACCTYP<>3 : VALEUR=1 : mkstat=2 : Endif : # Compte <=> Tiers
End

