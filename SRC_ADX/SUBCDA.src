 mkstat = 1 : End
Endif
End

##################################################
## Actions of the data type CDA
##################################################

# Control
Subprog CONTCDA(COD,LEG,GFY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    GFY()

Local    Integer CAS

If GFONCTION = "GESCDA" | COD="" : End : Endif
If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
 Read [CDA]CDA0=COD;LEG
 If fstat
  Read [CDA]CDA0=COD;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Filter [CDA] Where ENAFLG=2
 Read [CDA]CDA0(1)=COD
 Filter [CDA]
 If !fstat
  LEG = [F:CDA]LEG
  If LEG<>"" :  CAS = 2 : Endif
 Else
  # To display the right message : either the recording is disable either it doesn't exist
  Read [CDA]CDA0(1)=COD
 Endif
Endif

If !fstat & [F:CDA]ENAFLG<>2
 # Destination comptable : xxx Fiche inactive
 Gosub TIT From WOCDA
 GMESSAGE = TIT-":"-[L]COD
 GMESSAGE += "\"+mess(2,126,1)
 mkstat = 2 : End
Elsif fstat
 If LEG<>""
  # LEG=FRA and the recording exists for the ITA legislation.
  # The right message isn't "Fiche inexistante" but "Fiche inexistante pour la législation courante"
  Filter [CDA] Where COD=[L]COD
  Look [CDA]CDA0 First
  Filter [CDA]
  If !fstat
   # Fiche inexistante pour la législation courante
   GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
   mkstat = 2 : End
  Endif
 Endif
 GMESSAGE = [L]COD-":"-mess(23,100,1)
 mkstat = 2 : End
Endif

If [L]GFY<>"" & [F:CDA]GFY<>"" & [L]GFY<>[F:CDA]GFY
 Call COMPAT([L]GFY,[F:CDA]GFY,"") From CFYSUB
 If mkstat=2
  Gosub TIT From WOCDA
  GMESSAGE = TIT-":"-[L]COD-[F:CDA]LEG
  GMESSAGE += "\"+mess(23,127,1)-":"-[F:CDA]GFY
  End
 Endif
Endif

If CAS=2
 Call CONTROLE("CDA","",LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("CDA","","",COD,mkstat) From CONTOBJ
Endif

End

##################################################

## Tunnel Report
Subprog TUNCDA(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONCDA)
 TOKILL = 1
Endif

If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif

# To update the CDA code after the tunnel order
VCOD = COD

If GNBLEG = 1
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Elsif LEG="" : # If LEG="" then firstly we search a CDA record with LEG="" secondly a CDA record with LEG<>""
 Read [CDA]CDA0 = VCOD;LEG
 If fstat
  Read [CDA]CDA0(1)=VCOD
  If !fstat
   LEG = [F:CDA]LEG
  Endif
 Endif
Endif

Call LEC_CDA_LEG(LEG,VCOD) From CPTLEC
If !fstat
 LEG = [F:CDA]LEG
Else
 Raz VCOD,LEG
Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("CDA",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE
If VCOD<>"" : COD = VCOD : Endif
If TOKILL : Kill VCOD : Endif
End


##################################################
## CDA selection
####################################################
Subprog SELCDA(COD,LEG,GFY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    GFY()
Local Char PARMSK(30)(1..10)
If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif
PARMSK(1) = LEG
If GNBLEG=1 : PARMSK(1) = GDOSLEG : Endif
PARMSK(2) = GFY
Call S_TAB_CHAR(COD,PARMSK,"SELCDA","SELCDA","") From GACTION
End
