Subprog AS_MATFIN(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "MATDEB") From TOOLSVAR
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VALHAB) 13/02/2013 12:03:00 (MABOS)
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ(VALEUR, "", "VALHAB")
  If AUZCFY=1 Then
    mkstat=2
  Endif

  Read [F:AGF]AGF0=VALEUR
  If !fstat & [F:AGF]FLGCPY=1 Then : # Ce n'est pas un groupe de sociétés
    Filter [F:AGC] Where GRP=VALEUR
    If rowcount([F:AGC])=0 Then : # Groupe de sites
      GMESSAGE=VALEUR-mess(216,10717,1) : # est un groupe de sites
      mkstat=2
    Endif
    Filter [F:AGC]
  Endif

End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local    Integer AUZCFY

  AUZCFY = func SUBHRSES.GET_AUZ("", VALEUR, "GENCSI")
  If AUZCFY=1 Then
    mkstat=2
  Endif

End


