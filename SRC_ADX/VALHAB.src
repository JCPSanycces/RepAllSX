#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
GACTION = "VALHAB"
PARAM(1) = ""
PARAM(2) = ""
PARAM(3) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"VALHAB2","VALHAB","VALHAB",4,"") From GTRAITE
End

######################################################################################
# Modifications :
#     SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
#     MABOS - 14/02/13 - FQ 81085-US1330- Add legislation + generic rules
#     MABOS - 11/03/13 - FQ 87514-US1406- From GESHRSES, do not come back to the last selection box
#     MABOS - 22/04/13 - FQ 86015 - US 1531 - improvement traces in mass processing
#     MABOS - 08/08/13 - FQ 81085 - US1833 - manage mémo
######################################################################################

#########################################
## Traitement des actions : SAIVAR
## Saisie des valeurs par variables
#########################################
$ACTION
  Case ACTION
    When "INIT"        : Gosub OUVRE
    When "CONTROLE"    : Gosub CONTROLE
    When "DEBUT"       : Gosub DEBUT
    When "OK"          : Gosub BOUTON_OK
    When "END"         : Gosub BOUTON_FIN
    When "SETBOUT"     : Gosub SETBOUT
    When "AVANT_BOUTON": Gosub AVANT_BOUTON : #MABOS-FQ81085-US1833 - manage mémo
    When "BOUTON"      : Gosub BOUTON
    # 60564
    When "EXEC"        : Unlock =SYMBOLE
    # MABOS-11/03/13-FQ 87514-US1406-From GESHRSES, do not come back to the last selection box
                         If GFONCTION<>"GESHRSES" Then SAI=1 : Endif
  Endcase
Return


#######################################################



$OUVRE

  Case GACTION
    When "VALHAB"  : Gosub OUVREHAB
  Endcase
Return

$OUVREHAB
  # MABON 23/12/10 - On ne peut pas valider n'importe quand
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  # SEGAY 10/01/13 - 87157 - le Look ne renvoie pas l'enregistrement de la session
  #Look [F:HRSES]SES0=PARAM(2)
  Read [F:HRSES]SES0=PARAM(2)
  If !fstat & datesyst<[F:HRSES]ENDDAT Then
    GMESSAGE=mess(193,10717,1) : # La session doit être terminée pour pouvoir valider compétences et habilitations
    GERR=1
    FIN=1
  Endif

  Gosub OUVRE From SUBINS
  Gosub OUVRE From WPDEFTABLE
  If clalev([F:HAB])=0  : Local File EMPLOHAB  [HAB] : Endif
  If clalev([F:ID2])=0  : Local File EMPLOID   [ID2] : Endif
  If clalev([F:FCY])=0  : Local File FACILITY  [FCY] : Endif
  If clalev([F:SRV])=0  : Local File SERVICE   [SRV] : Endif
  If clalev([F:PRF])=0  : Local File PROFIL    [PRF] : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA    [HRPOA] : Endif
  If clalev([F:ADI])=0  : Local File ATABDIV   [ADI] : Endif
# MABOS-14/02/2013-FQ 81085-US1330- Add legislation + generic rules
  If clalev([F:AGC])=0    : Local File AGRPCPY       [AGC]    : Endif
  If clalev([F:AGF])=0    : Local File AGRPFCY       [AGF]    : Endif
  If clalev([F:ACC])=0    : Local File ACCES         [ACC]    : Endif

  Local Mask VALHAB2 [HA2]
  Local Mask VALHAB  [DIA]
  Raz [M:DIA]
  #MABOS-FQ81085-US1833 - manage mémo
  If GFONCTION <> "GESHRSES" & GFONCTION <> "GESINS"
    Call INI_LEG From DIVPAYE
    Call LECMEMO("STD","[M:DIA]","vha") From GMEMO :
  #  If [M:DIA]LEG<>"" Then GCURLEG=[M:DIA]LEG :Endif
  Endif
  #end MABOS-FQ81085-US1833
  Local Char  CRITERE1(250), CRITERE2(250), CRITERE3(250), ZONE (250), SYMBOLE(50)
  Local Integer I, J, NBMAX, OKC, FLG
Return

#######################################################
$CONTROLE

  Case GACTION
    When "VALHAB" : Gosub CONTHAB
  Endcase
Return

$CONTHAB
  If GSTATUT=GSTAOK Then
    #MABOS-FQ81085-US1833 - manage mémo
    Local Char WECR(50)
    WECR="VALHAB"
    Gosub CONTROLE_VAL From VALCPC
    If GERR = 1 : Return :Endif
    #end MABOS-FQ81085-US1833 - manage mémo
  Endif

  If GSTATUT<>GSTAOK Then
    FIN = 1
  Else
    SYMBOLE = "VALHAB"+[M:DIA]STG
    Lock =SYMBOLE
    If fstat
      Call ECR_TRACE([M:DIA]STG-":"-mess(10,100,1),1) From GESECRAN
      FIN=1 : Return
    Endif
    TMP = 1
    TRA = 1
  Endif
Return

$SETBOUT

  Case BOITE
    When "VALHAB2"  : Gosub SETBOUTHAB
  Endcase
Return

#MABOS-FQ81085-US1833 - manage mémo
$AVANT_BOUTON
  Case BOITE
    When "VALHAB"
     Case BOUT
       When "M" : # Button "Mémo"
         Local Char WECR(50)
         [L]WECR="VALHAB"
         Gosub CONTROLE_VAL From VALCPC
     Endcase
  Endcase
Return
#end MABOS-FQ81085-US1833 - manage mémo

# FQ86190 - MABON 05/02/13 - Nouveaux boutons
#**
#* Boutons "Tout cocher" et "Tout décocher"
#*!
$BOUTON
  Case BOITE
    When "VALHAB2"
      Case BOUT
        When "C" : For I=0 To [M:HA2]NBRINS-1 : [M:HA2]FLGVAL(I)=2 : Next
        When "D" : For I=0 To [M:HA2]NBRINS-1 : [M:HA2]FLGVAL(I)=1 : Next
      Endcase
      Affzo [M:HA2]

    #81085
    When "VALHAB"
     Case BOUT
      When "R" :
       # Button "Rappel MEMO"
       Call AFF_MEMO2(1) From DIVPAYE :#MABOS-FQ81085-US1833 - manage mémo
     Endcase
    #
  Endcase
Return
# Fin MABON

$SETBOUTHAB
#MABOS-14/02/13-Ne marche pas bien car la zone courante n'est pas encore enregistrée dans les valeurs de FLGVAL
# remove activation of button ok on select grid
#enlevé car pas géré dans les autres traitements de masse
#  If !find (2,[M:HA2]FLGVAL(0..[M:HA2]NBRINS))
#    CHBOU=""
#  Else
#    CHBOU="O"
#  Endif
Return

#######################################################
$DEBUT

  Case BOITE
    When "VALHAB"
      #MABOS-FQ81085-US1833 - manage mémo
      [M:DIA]LEG=[M:DIA]LEG : # Pour ne pas passer dans SUBADI/INILEG
    # MABOS-14/02/2013-FQ 81085-US1330- Add legislation + generic rules
    # Ne pas réaffecter de valeur après retour de VALHAB2, conserver les derniers critères saisis
    # si STG remplit, ce n'est pas la première ouverture
      If [M:DIA]STG = ""
        If PARAM(1)<>"" Then [M:DIA]STG=PARAM(1) : Endif
        If PARAM(2)<>""
          [M:DIA]ALLSES=1
          [M:DIA]SES=PARAM(2)
          Call LECTURE("HRSES",PARAM(2),"") From CONTOBJ
          [M]DATDEB=[F:HRSES]STRDAT
          [M]DATFIN=[F:HRSES]ENDDAT
          # FQ86194 - MABON 04/02/13 - Si "Toutes sessions" est décochée, on ne doit pas pouvoir sélectionner les bornes de dates de fin
          Grizo [M:DIA]DATENDDEB,DATENDFIN
          # Fin MABON
        Endif
        If PARAM(3)<>"" Then
          [M:DIA]MATDEB=PARAM(3) : [M:DIA]MATFIN=PARAM(3)
        Endif
        #MABOS-FQ81085-US1833 - manage mémo
        #MABOS-14/02/2013-FQ 81085-US1330- Add legislation + generic rules
#        If dim([M:DIA]LEG) >0 :
#           If [M:DIA]LEG="" : [M:DIA]LEG    = GCURLEG : Endif
#           If [M:DIA]LEG="" :  Call AM_CPY([M:DIA]CPY) From DIVPAYE :    Endif
#           If [M:DIA]LEG="" Then [M:DIA]LEG=GLEGFIL : Endif
#           Call AM_LEG([M:DIA]LEG)
#           GCURLEG=[M:DIA]LEG
#        Endif
      Else
        # Come back on the screen after Trt
        If dim([M]LEG)> 0 : GCURLEG=[M]LEG :Endif:  #MABOS-FQ81085-US1833
      Endif
      #end-MABOS-14/02/13 -FQ 81085-US1330
      Call AFF_MEMO2(1) From DIVPAYE
      #end MABOS-FQ81085-US1833 - manage mémo
      # FQ72438 - MABON 22/03/11 - Recherche des absences du salarié pendant l'inscription
      If GFONCTION<>"GESINS" Then Grizo [M:DIA]FLGFRC : Endif
      Affzo [DIA]
      Setmok [DIA] With 0

   When "VALHAB2"
     Raz [HA2]
     [M:HA2]STAGE=[M:DIA]STG
     Gosub FILTRE
     Gosub CHARGE_INS
     If GFONCTION='GESINS' Then Grizo [M:HA2]WHABFLG Endif
     Affzo[M:HA2]
     If ![M:HA2]NBRINS
       Call ERREUR(mess(61,10720,1)) From GESECRAN : FIN=1 : # Aucune habilitation à attribuer
     Endif
  Endcase
Return

#######################
$FILTRE
Local Char    LIS_CPY(GLONCPY)(0..100)
Local Integer I

  CRITERE1="1=1" : CRITERE2="1=1"
  If [M:DIA]ALLCPY<>2
#    CRITERE1 -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE1 -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE1 += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE1 += "," : Endif
      Next
      CRITERE1 += ")>0"
    Endif
  Endif
  If [M:DIA]ALLFCY<>2
   CRITERE1 -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
  Endif
  #MABOS-14/02/2013-FQ 81085-US1330- Add legislation + generic rules
  If dim([M:DIA]LEG)>0 & [M:DIA]LEG<>"" : #LEG
    CRITERE1 -= '& [FCY]LEG = "'+[M:DIA]LEG+'"'
  Endif
  If [M:DIA]ALLSRV<>2  #service
   CRITERE1 -= '& [F:ID]SRV = "'+[M:DIA]SRV+'"'
  Endif
  If [M:DIA]ALLPRF<>2  #profil
   CRITERE2 -= '& [F:ID]PRF = "'+[M:DIA]PRF+'"'
  Endif
  If [M:DIA]MATDEB<>""
   CRITERE2 -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
  Endif
  If [M:DIA]MATFIN<>""
   CRITERE2 -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
  Endif

  CRITERE3="[F:HRSES]STG='"+[M:DIA]STG+"'"
  If [M:DIA]SES<>""
   CRITERE3-="& [F:HRSES]COD='"+[M:DIA]SES+"'"
  Endif
  #Date de début de session dans la borne saisie
  If 1=2
  If [M:DIA]DATDEB<>[0/0/0]
   CRITERE3-="& [F:HRSES]STRDAT>=["+ format$("D:"+GFMDAT,[M:DIA]DATDEB)+"]"
   CRITERE3-="& [F:HRSES]STRDAT<=["+ format$("D:"+GFMDAT,[M:DIA]DATFIN)+"]"
  Endif
  Endif
  # FQ86190 - MABON 04/02/13 - On peut sélectionner une borne de dates de fin de session
  If [M:DIA]DATENDDEB<>[0/0/0]
   CRITERE3-="& [F:HRSES]ENDDAT>=["+ format$(GFMD,[M:DIA]DATENDDEB)+"]"
  Endif
  If [M:DIA]DATENDFIN<>[0/0/0]
   CRITERE3-="& [F:HRSES]ENDDAT<=["+ format$(GFMD,[M:DIA]DATENDFIN)+"]"
  Endif
  # Fin MABON

  If [M:DIA]POP<>""
#    Link [ID] With [FCY]FCY0 = [F:ID]FCY, [POA]POA0 = [M:DIA]POP;[F:ID]REFNUM
#&     As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2) & [F:POA]REFNUM<>""
#MABOS-14/02/13- index pop
#    Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY, [HRPOA]POA0 = [M:DIA]POP;[F:ID]REFNUM
    Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY,
&                     [HRPOA]POA0 ~= [M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&     As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
  Else
#    Link [ID] With [FCY]FCY0 = [F:ID]FCY As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2)
    Link [HRCTR] With [ID]ID0=[F:HRCTR]REFNUM, [FCY]FCY0 = [F:HRCTR]ETRFCY As [LNK] Where evalue(CRITERE1) & evalue(CRITERE2)
  Endif

  Link [INS] With [HRSES]SES0 = [F:INS]SES As [LNK2]
Return

#######################
$CHARGE_INS
Local Integer I, J, NBMAX, OKC, FLG, OKENR

  I=1 : OKC=1 : FLG=0
  NBMAX=min(dim([F:INS]HABAFT), 10)
  For [F:LNK]
    Call CONTROLE([F:ID]REFNUM,datesyst,"",[M:DIA]CRI,OKC,FLG) From DIVPAYE
    If OKC
      For [LNK2] Where evalue(CRITERE3) & [F:INS]REFNUM=[F:ID]REFNUM & [F:INS]UPDHAB<>2
        # FQ86190 - MABON 04/02/13 - Critères de sélection supplémentaires :
        #     - Seuls les salariés présents tout le stage doivent être sélectionnés
        #     - Les sessions à venir doivent être exclues
        #     - Seules les inscriptions avec des habilitations doivent apparaître
        OKENR=1
#        Filter [F:INJ] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
#        If rowcount([F:INJ])=0 Then OKENR=0 : Endif
#        Filter [F:INJ]
#        If OKENR Then
#          Filter [F:INA] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
#          If rowcount([F:INA])>0 Then OKENR=0 : Endif
#          Filter [F:INA]
#        Endif
        If [F:HRSES]ENDDAT>datesyst Then OKENR=0 : Endif
        If [F:INS]HABAFT(0)="" Then OKENR=0 : Endif
        # End MABON
        If OKENR & !find([F:INS]SES+"~"+[F:INS]REFNUM, [M:HA2]KEYLIG) Then
          [M:HA2]SESSION(I-1)=[F:INS]SES
          [M:HA2]REFNUM(I-1)=[F:INS]REFNUM
          # FQ86190 - MABON 04/02/13 - Ajout date fin session
          [M:HA2]ENDDAT(I-1)=[F:HRSES]ENDDAT
          # Fin MABON
          [M:HA2]KEYLIG(I-1)=[F:INS]SES+"~"+[F:INS]REFNUM
          Call LECTURE("EML",[F:INS]REFNUM,"") From CONTOBJ
          [M:HA2]NAM(I-1)=[F:ID]NAM-[F:ID]SRN
          For J=1 To NBMAX
            ZONE="[M:HA2]HABAFT"+num$(J)+"(I-1)"
            Assign ZONE With [F:INS]HABAFT(J-1)
            ZONE="[M:HA2]HABSTR"+num$(J)+"(I-1)"
            Assign ZONE With [F:INS]HABSTR(J-1)
            ZONE="[M:HA2]HABFLG"+num$(J)+"(I-1)"
            Assign ZONE With [F:INS]HABFLG(J-1)
            # FQ86190 - MABON 04/02/13 - Ajout Date fin validité
            ZONE="[M:HA2]HABEND"+num$(J)+"(I-1)"
            Filter [HAB] Where REFNUM=[F:INS]REFNUM & HAB=[F:INS]HABAFT(J-1)
            Read [HAB]HAB0 Last
            Filter [HAB]
            If !fstat Then Assign ZONE With [F:HAB]HABEND : Endif
            # Fin MABON
          Next J
          # FQ86190 - MABON 04/02/13 - On coche tout par défaut
#          If [F:INS]NBRDAY>0 & [F:INS]HABAFT(0)<>"" :#Présent et au moins une compétence
#            [M:HA2]FLGVAL(I-1)=2
#          Else
#            [M:HA2]FLGVAL(I-1)=1
#          Endif
          [M:HA2]FLGVAL(I-1)=2
          # Fin MABON
          I+=1
        Endif
      Next
    Endif
  Next
  [M:HA2]NBRINS=I-1
  If [M:HA2]NBRINS
    NOL=0 : Gosub CHARGE_HAB
  Endif
Return

$CHARGE_HAB

  Effzo [M:HA2]15
  For I=0 To dim([F:INS]HABAFT)-1
    If evalue("[M:HA2]HABAFT"+num$(I+1)+"("+num$(NOL)+")")="" : Break : Endif
    [M:HA2]WHABAFT(I)=evalue("[M:HA2]HABAFT"+num$(I+1)+"("+num$(NOL)+")")
    [M:HA2]WHABSTR(I)=evalue("[M:HA2]HABSTR"+num$(I+1)+"("+num$(NOL)+")")
    [M:HA2]WHABFLG(I)=evalue("[M:HA2]HABFLG"+num$(I+1)+"("+num$(NOL)+")")
    # FQ86190 - MABON 04/02/13 - Ajout date fin validité
    [M:HA2]WHABEND(I)=evalue("[M:HA2]HABEND"+num$(I+1)+"("+num$(NOL)+")")
    # Fin MABON
  Next
  [M:HA2]NBRHAB=I
Return

#######################################################
$BOUTON_OK

  Case BOITE
    When "VALHAB2" :
      If !GSERVEUR
        Call OUVRE_TRACE(mess(62,10720,1)) From LECFIC : # Validation des habilitations
      Endif
      Call ECR_TRACE(mess(62,10720,1),0) From GESECRAN : # Validation des habilitations
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
      Call LIB_CRIT("[M:DIA]","VALHAB")From DIVPAYE :      #MABOS-22/04/13-FQ86015-US1531
      Call DEBTRANS From GLOCK
      Gosub TR1

      If !GSERVEUR
        Call FERME_TRACE From LECFIC
        # FQ86194 - MABON 07/02/13 - Lecture de la trace, sinon avec le retour en saisie, on ne la voit pas
        Call LEC_TRACE From LECFIC
      Endif

      #FIN = 1
  Endcase
Return

#######################################################
$BOUTON_FIN

  FIN = 1
Return

#######################################################
$TR1

  Trbegin [HAB],[INS]
  #Infos du stage en ligne
  Call LECTURE("STG",[M:HA2]STAGE,"") From CONTOBJ
  Gosub MAJ_HAB
  If   GOK<0 : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif
  Commit
Return

#######################################################
$AB_TR1

  Rollback
  GMESSAGE = mess (17,107,1) :#Rollback suite à une erreur dans la transaction
Return

#######################################################
$ROLL_TR1

  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif
Return

#######################################################
$MAJ_HAB
Local Integer FLGMOD

  GOK=1
  For I=0 To [M:HA2]NBRINS-1
    If [M:HA2]FLGVAL(I)=2
      #Infos de la session en ligne
      Call LECTURE("HRSES",[M:HA2]SESSION(I),"") From CONTOBJ
      #Infos de l'inscription en ligne + lock pour MAJ flg
      Readlock [F:INS]INS1=[M:HA2]SESSION(I);[M:HA2]REFNUM(I)
      If !fstat
        Gosub ADD_HAB
        If GOK
          [F:INS]UPDHAB=2
          Rewrite[F:INS]
          If fstat
            GOK = 0 : Call FSTA("INS") From GLOCK
          Endif
          Call ECR_TRACE(mess(59,10720,1),0) From GESECRAN : # Attribution de nouvelles habilitations effectuée
        Else
          Call ECR_TRACE(mess(60,10720,1),1) From GESECRAN : # Attribution de nouvelles habilitations impossible
        Endif
      Endif
    Endif
  Next
Return

#**
#* Calcul de la date de fin de validité de l'habilitation
#* @param HAB    : code habilitation
#* @param HABSTR : date obtention
#*!
Funprog CALC_HABEND(HAB, HABSTR)
Value Char HAB
Value Date HABSTR
Local Date DATEND
#114309 US204
#  Call LECTURE("ADI",HAB,"10397") From CONTOBJ
#  If [F:ADI]N1>0 Then
#    If HABSTR<>[0/0/0] Then
#      DATEND = addmonth(HABSTR,[F:ADI]N1)
#    Endif
#  Endif
  If !clalev([F:HRLIC]) : Local File HRLICAUT [HRLIC] : Endif
  Read [F:HRLIC]HRLIC0=[L]HAB;GCURLEG
  If !fstat & [F:HRLIC]ENAFLG=2
    If [F:HRLIC]VLY > 0
      [L]DATEND = addmonth([L]HABSTR,[F:HRLIC]VLY)
    Endif
  Else
    #we read default value if exist
    Read [F:HRLIC]HRLIC1=GCURLEG;2
    If !fstat & [F:HRLIC]VLY > 0
      [L]DATEND = addmonth([L]HABSTR,[F:HRLIC]VLY)
    Endif
  Endif
#####
End DATEND

#**
#* Calcul du numéro de ligne dans la table des habilitations
#* @param REF = matricule
#*!
Funprog CALC_NUMLIG(REF)
Value Char    REF
Local Integer NUMLIG

  Filter [F:HAB] Where REFNUM=REF Order By NUMLIG Desc
  Read [F:HAB] First
  Filter [F:HAB]
  NUMLIG = [F:HAB]NUMLIG+1
End NUMLIG

#######################################################
$ADD_HAB
Local Integer NUMLIG
Local Date    NEW_HABEND
Local Char WSHOAXX(50) : #MABOS-22/04/13-FQ86015-US1531
  Call ECR_TRACE(space$(1),0) From GESECRAN
  Read [F:ID2]ID0=[F:INS]REFNUM
  Call ECR_TRACE([F:INS]REFNUM-[F:ID2]NAM-[F:ID2]SRN-num$([F:HRSES]ENDDAT)-":",0) From GESECRAN

  # FQ72438 - MABON 22/03/11 - Recherche des absences du salarié pendant l'inscription
  GOK=0
  Filter [F:INA] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM
  If rowcount([F:INA])>0 Then : # Le collaborateur a été absent pendant la session, on ne peut donc pas valider ses habilitations
    If GFONCTION<>'GESINS' | [M:DIA]FLGFRC<>2 Then
      Filter [F:INA]
      Call ECR_TRACE(mess(232,10717,1), 0) From GESECRAN : # Le salarié a été absent : ses compétences ou habilitations ne peuvent être validées
      Return
    Endif
  Endif
  Filter [F:INA]
  # Fin MABON

  GOK=1
  NUMLIG = func CALC_NUMLIG([F:INS]REFNUM)
  For J=0 To dim([F:INS]HABAFT)-1
    If [F:INS]HABAFT(J)="" : Break : Endif
    Filter [HAB] Where REFNUM=[F:INS]REFNUM & HAB=[F:INS]HABAFT(J)
    Read [HAB]HAB0 Last
    Filter [HAB]
    If !fstat
      [F:HAB]HABSTR = [F:INS]HABSTR(J)
      NEW_HABEND = func CALC_HABEND([F:INS]HABAFT(J), [F:INS]HABSTR(J))
      If NEW_HABEND<>[0/0/0] Then
        # FQ72331 - MABON 15/03/11 - Le flag "A renouveler" prend uniquement la valeur saisie dans les critères
#        If [F:HAB]HABEND<NEW_HABEND Then
#          [F:HAB]HABFLG = 1 : # Si la nouvelle date de validité est supérieure à l'ancienne, le flag A renouveler passe à Non
#        Else
#          [F:HAB]HABFLG = [F:INS]HABFLG(J)
#        Endif
        [F:HAB]HABEND = NEW_HABEND
      Endif
#      Else
      # FQ72331 - MABON 15/03/11 - Si on est dans traitement en masse, on peut modifier le flag "A renouveler" pour chaque habilitation
      If GFONCTION="GESINS" Then
        [F:HAB]HABFLG = [F:INS]HABFLG(J)
      Else
        [F:HAB]HABFLG = [M:HA2]WHABFLG(J)
      Endif
#      Endif
      [F:HAB]UPDDAT = date$
      [F:HAB]UPDTIM = time
      [F:HAB]UPDUSR = GUSER
      Rewrite [F:HAB]
      If fstat
        GOK = 0 : Call FSTA("HAB") From GLOCK : Break
      Endif
    Else
      Raz [F:HAB]
      [F:HAB]REFNUM = [F:INS]REFNUM
      [F:HAB]NUMLIG = NUMLIG
      NUMLIG       += 1
      [F:HAB]HAB    = [F:INS]HABAFT(J)
      [F:HAB]HABSTR = [F:INS]HABSTR(J)
      # FQ72331 - MABON 15/03/11 - Si on est dans traitement en masse, on peut modifier le flag "A renouveler" pour chaque habilitation
      If GFONCTION="GESINS" Then
        [F:HAB]HABFLG = [F:INS]HABFLG(J)
      Else
        [F:HAB]HABFLG = [M:HA2]WHABFLG(J)
      Endif
      [F:HAB]HABEND = func CALC_HABEND([F:INS]HABAFT(J), [F:INS]HABSTR(J))
      [F:HAB]CREDAT = date$
      [F:HAB]CRETIM = time
      [F:HAB]CREUSR = GUSER
      Write [F:HAB]
      If fstat
        GOK = 0 : Call FSTA("HAB") From GLOCK : Break
      Endif
      #114309 US204
      #MABOS-22/04/13-FQ86015-US1531
      #Call LECTEXTRA([L]WSHOAXX,"ATABDIV","LNGDES","10397",[F:INS]HABAFT(J)) From ATEXTRA
      #Call ECR_TRACE(mess(58,10720,1)-":"-[F:INS]HABAFT(J)-":"-[L]WSHOAXX,0) From GESECRAN : # Habilitation attribuée
      #end MABOS-22/04/13-FQ86015-US1531
      Call LECTEXTRA([L]WSHOAXX,"HRLICAUT","DESAXX",[F:INS]HABAFT(J),[V]GCURLEG) From ATEXTRA
      If [L]WSHOAXX=""
        Call LECTEXTRA([L]WSHOAXX,"HRLICAUT","DESAXX",[F:INS]HABAFT(J),"") From ATEXTRA
      Endif
      Call ECR_TRACE(mess(58,10720,1)-":"-[F:INS]HABAFT(J)-":"-[L]WSHOAXX,0) From GESECRAN : # Habilitation attribuée
      ########
    Endif
  Next
Return

