Subprog AV_SES(VALEUR)
Variable Char    VALEUR()

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End

Subprog AV_DATENDDEB(VALEUR)
Variable Date    VALEUR

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End

Subprog AV_DATENDFIN(VALEUR)
Variable Date    VALEUR

If [M:DIA]ALLSES=2 Then
  Grizo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
Else
  Actzo [M:DIA]SES
  Grizo [M:DIA]DATENDDEB,DATENDFIN
Endif
End
