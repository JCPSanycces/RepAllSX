# FQ86194 - MABON 07/02/13 - Réinit session et dates
Subprog AM_STG(VALEUR)
Variable Char    VALEUR()

  [M:DIA]ALLSES=2 : Raz [M:DIA]SES,ZSES,DATDEB,DATFIN
  Affzo [M:DIA]SES,ZSES,DATDEB,DATFIN
  Diszo [M:DIA]SES
  Actzo [M:DIA]DATENDDEB,DATENDFIN
End

# FQ86194 - MABON 07/02/13 - Contrôle date session
Subprog C_SES(VALEUR)
Variable Char    VALEUR()

  Read [F:HRSES]SES0=VALEUR
  If !fstat Then
    If [F:HRSES]ENDDAT>datesyst Then
      GMESSAGE=mess(193,10717,1) : # La session doit être terminée pour pouvoir valider compétences et habilitations
      mkstat=2
    Endif
    If [F:HRSES]STG<>[M:DIA]STG Then
      GMESSAGE=mess(30,10717,1)-[M:DIA]STG : # Cette session ne dépend pas du stage
      mkstat=2
    Endif
  Endif
End

