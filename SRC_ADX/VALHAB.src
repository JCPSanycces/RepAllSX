######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif

 If clalev([F:STG])=0 : Local File STAGE [STG] : Endif

  If VALEUR <> ""
    Filter [F:STG] Where COD=VALEUR
    Read [F:STG] First
    Filter [F:STG]
    If fstat
        GMESSAGE = VALEUR-":"-mess(23,100,1)
        mkstat = 2 : End
    Endif
   Endif
End

Subprog C_ALLSES(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    Effzo SES : Diszo SES
    # FQ86190 - MABON 04/02/13 - Si "Toutes sessions" est cochée, on peut sélectionner les bornes de dates de fin
    Effzo [M:DIA]DATDEB, DATFIN
    Actzo [M:DIA]DATENDDEB,DATENDFIN
    # Fin MABON
  Else
    Actzo SES
    # FQ86190 - MABON 04/02/13 - Si "Toutes sessions" est décochée, on ne peut pas sélectionner les bornes de dates de fin
    Effzo [M:DIA]DATENDDEB,DATENDFIN : Diszo [M:DIA]DATENDDEB,DATENDFIN
    # Fin MABON
  Endif
End

Subprog AS_SES(VALEUR)
Variable Char    VALEUR()
  If [M]ALLSES = 2 : mkstat = 1 : End : Endif
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
  Gosub GRISE From DIVPAYE
  If [M]ALLSES=2 : Diszo SES : Else : Actzo SES : Endif
End

$SETNOL
Local Integer NOL
  NOL=nolign-1
Return

Subprog AS_NBRINS

  Gosub SETNOL
  If NOL>=0 & [M]NBRINS>0
    If NOL<=[M]NBRINS
      # FQ86194 - MABON 07/02/13 - La ligne sélectionnée est colorée
      Chgstl [M]NBRINS With ""
      Chgstl [M]SESSION(NOL)  With "SELLIG"
      Chgstl [M]ZSESSION(NOL) With "SELLIG"
      Chgstl [M]ENDDAT(NOL)   With "SELLIG"
      Chgstl [M]NAM(NOL)      With "SELLIG"
      Chgstl [M]REFNUM(NOL)   With "SELLIG"
      # Fin MABON
      Gosub CHARGE_HAB
      Affzo 15
    Else
      Effzo 15
    Endif
  Endif
End

Subprog AS_FLGVAL(VALEUR)
Variable Integer VALEUR

  If [M:HA2]NBRHAB=0
    GMESSAGE=mess(61,10720,1) : # Aucune habilitation à attribuer
    mkstat=1 : End
  Endif
End

Subprog AM_SES(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
    [M]DATDEB=[F:HRSES]STRDAT
    [M]DATFIN=[F:HRSES]ENDDAT
    Affzo [M]DATDEB, DATFIN
  Endif
End

