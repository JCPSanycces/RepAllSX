###########################################################################################
# Mettre à jour la date effective de conclusion des affaires
###########################################################################################
Subprog STEP15(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:OPP]) : Local File =SZAPPLI+".OPPOR" [OPP] : Endif
If !clalev([F:ADI]) : Local File =SZAPPLI+".ATABDIV" [ADI] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
Local Integer ITERSTE
ITERSTE = dim([F:OPP]STE) - 1
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [OPP] Where [F:OPP]OPPNUM > SZCLE
&                  and [F:OPP]OPPCLO = 2
&             Order By [F:OPP]OPPNUM Asc

    For [OPP]
        SZCLE = [F:OPP]OPPNUM

            If IPERF = 0
                Trbegin [OPP]
                INTR = 1
            Endif

            ITERSTE = dim([F:OPP]STE) - 1
            While 1
                If ITERSTE < 0 : Break : Endif

                If [F:OPP]STE(ITERSTE) <> ""
                    Read [ADI] CODE = 400;[F:OPP]STE(ITERSTE)
                    If !fstat
                        If [F:ADI]N2 >= 5 & [F:ADI]N2 <= 7
                            [F:OPP]OPPREACDA = [F:OPP]ENDDAT(ITERSTE)
                            Break
                        Endif
                    Endif
                Endif
            
                ITERSTE -= 1
            Wend

            If [F:OPP]OPPREACDA = [00/00/00]
                [F:OPP]OPPREACDA = [F:OPP]OPPCDA
            Endif

            Rewrite [OPP]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the opportunity real closing date n°" + [F:OPP]OPPNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 15 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [OPP]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

End

###########################################################################################
# Supprimer la règle Workflow CRMSRE1
###########################################################################################
Subprog STEP16(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:AMS]) : Local File =SZAPPLI+".AMESSAGE" [AMS] : Endif
If !clalev([F:AMD]) : Local File =SZAPPLI+".AMESSAGED" [AMD] : Endif

Local Char SZMESS(250)

Trbegin [AMS], [AMD]
Delete [AMS] Where [F:AMS]CODE = "CRMSRE1"
If fstat
    IERR = 1
    SZMESS = "Error while deleting the CRMSRE1 workflow rule header."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 16 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [AMD] Where [F:AMD]CODE = "CRMSRE1"
If fstat
    IERR = 1
    SZMESS = "Error while deleting the CRMSRE1 workflow rule details."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 16 failed.") From DOSSUB
    Rollback
    End
Endif

Commit

End

###########################################################################################
Subprog STEP17(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

# FGR 13/10/2009 : X3SUIVI58456 (début)
If !clalev([F:ADI1]) : Local File =SZAPPLI+".ATABDIV"  [ADI1] : Endif
If !clalev([F:AXX1]) : Local File =SZAPPLI+".ATEXTRA"  [AXX1] : Endif
If !clalev([F:ADI2]) : Local File =SZAPPLI+".ATABDIV"  [ADI2] : Endif
If !clalev([F:AXX2]) : Local File =SZAPPLI+".ATEXTRA"  [AXX2] : Endif 
# FGR 13/10/2009 : X3SUIVI58456 (fin)

Local Integer INTR
Local Char SZMESS(250)
INTR = 0

# FGR 13/10/2009 : X3SUIVI58456 (début)
Local Char STBSRC
Local Char STBDES

  STBSRC = "406"
  STBDES = "440"  # FGR 15/02/2010 : X3SUIVI62388 : Mauvaise table "441"
  Trbegin [ADI2], [AXX2]
  INTR = 1 # FGR 20/10/2009 : X3SUIVI58917 : du coup le commit ne se faisait pas
  For [ADI1]CODE Where NUMTAB = val(STBSRC)
    # FGR 16/02/2010 : X3SUIVI62388 (début)
    Delete [ADI2] Where [F:ADI2]NUMTAB = val(STBDES) and [F:ADI2]CODE = [F:ADI1]CODE
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (Delete-ATABDIV)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 17 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
    Delete [AXX2] Where [F:AXX2]CODFIC = "ATABDIV" and ([F:AXX2]ZONE = "LNGDES" or [F:AXX2]ZONE = "SHODES") 
&                   and [F:AXX2]IDENT1 = STBDES and [F:AXX2]IDENT2 = [F:ADI1]CODE
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (Delete-ATEXTRA)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 17 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
    # FGR 16/02/2010 : X3SUIVI62388 (fin)
    #
    Raz [F:ADI2]
    [F:ADI2] = [F:ADI1]
    [F:ADI2]NUMTAB = val(STBDES)
    If dim([F:ADI2]CREUSR)>0 : [F:ADI2]CREUSR = GUSER : Endif
    If dim([F:ADI2]CREDAT)>0 : [F:ADI2]CREDAT = date$ : Endif
    If dim([F:ADI2]CRETIM)>0 : [F:ADI2]CRETIM = time : Endif
    If dim([F:ADI2]UPDUSR)>0 : [F:ADI2]UPDUSR = "" : Endif
    If dim([F:ADI2]UPDDAT)>0 : [F:ADI2]UPDDAT = [0/0/0] : Endif
    If dim([F:ADI2]UPDTIM)>0 : [F:ADI2]UPDTIM = 0 : Endif
    # LNGDES et SHODES
    #Call COPTEXTRA("ATABDIV","LNGDES",STBSRC,[F:ADI1]CODE) From ATEXTRA
    #Call COPTEXTRA("ATABDIV","SHODES",STBSRC,[F:ADI1]CODE) From ATEXTRA
    For [AXX1]AXX0 Where CODFIC = "ATABDIV" and (ZONE = "LNGDES" or ZONE = "SHODES") and IDENT1 = STBSRC and IDENT2 = [F:ADI2]CODE
      Raz [F:AXX2]
      [F:AXX2] = [F:AXX1]
      [F:AXX2]IDENT1 = num$([F:ADI2]NUMTAB)
      If dim([F:AXX2]CREDAT)>0 : [F:AXX2]CREDAT = date$ : Endif
      If dim([F:AXX2]CREUSR)>0 : [F:AXX2]CREUSR = GUSER : Endif
      If dim([F:AXX2]CRETIM)>0 : [F:AXX2]CRETIM = time : Endif
      If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = [0/0/0] : Endif
      If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = "" : Endif
      If dim([F:AXX2]UPDTIM)>0 : [F:AXX2]UPDTIM = 0 : Endif
      Write [AXX2]
      If fstat Then
        IERR = 1
        SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (ATEXTRA)"
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("Step 17 failed.") From DOSSUB
        Rollback
        INTR = 0
        Break
      Endif
    Next
    If IERR Then
      Break
    Endif
    #
    Write [ADI2]
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (ATABDIV)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 17 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
  Next
  If INTR Then
    If !IERR Then
      Commit
    Endif
  Endif
# FGR 13/10/2009 : X3SUIVI58456 (fin)
End
