            [F:ITN]RPOFLG = 0
            [F:ITN]TYPFULOBJ = "ITNOBJ"
            [F:ITN]NUMFULOBJ = [F:ITN]NUM
            [F:ITN]OBJFLG = 0
            Rewrite [ITN]
            If fstat
                IERR = 1
                SZMESS = "Error while creating the intervention CLOB n°" + " " + [F:ITN]NUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 14 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [ITN]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

If IERR : End : Endif

######################
#Solutions
