IERRFLG = 0
Call STEP2(SZAPPLI, IERRFLG)
If IERRFLG
    Call ECR_TIME("Step 2 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
