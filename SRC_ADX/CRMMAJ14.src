###########################################################################################
# Passage des paramètres Tronc commun dans les modules Action co et Support client
###########################################################################################
Subprog STEP1(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:ADP]) : Local File =SZAPPLI+".ADOPAR" [ADP] : Endif

Local Integer ITCEXIST
Local Integer IHDKEXIST

######################
#Paramètre OPPRANGE
######################
Read [ADP] ADP0 = "TC";"OPPRANGE"
If fstat
    ITCEXIST = 0
Else
    ITCEXIST = 1
Endif

Read [ADP] ADP0 = "CRM";"OPPRANGE"
If fstat
    IHDKEXIST = 0
Else
    IHDKEXIST = 1
Endif

If ITCEXIST
    If IHDKEXIST
        Trbegin [ADP]
        Delete [ADP] Where [F:ADP]CHAPITRE = "TC" and [F:ADP]PARAM = "OPPRANGE"
        If fstat
            If fstat = 4
                Commit
            Else
                Rollback
                IERR = 1
            Endif
        Else
            Commit
        Endif
    Else
        Trbegin [ADP]
        Read [ADP] ADP0 = "TC";"OPPRANGE"
        [F:ADP]CHAPITRE = "CRM"
        Rewrite [ADP]
        If fstat
            Rollback
            IERR = 1
        Else
            Commit
        Endif
    Endif
Endif

If IERR : End : Endif

######################
#Paramètre ROBJCLL
######################
Read [ADP] ADP0 = "TC";"ROBJCLL"
If fstat
    ITCEXIST = 0
Else
    ITCEXIST = 1
Endif

Read [ADP] ADP0 = "CRM";"ROBJCLL"
If fstat
    IHDKEXIST = 0
Else
    IHDKEXIST = 1
Endif

If ITCEXIST
    If IHDKEXIST
        Trbegin [ADP]
        Delete [ADP] Where [F:ADP]CHAPITRE = "TC" and [F:ADP]PARAM = "ROBJCLL"
        If fstat
            If fstat = 4
                Commit
            Else
                Rollback
                IERR = 1
            Endif
        Else
            Commit
        Endif
    Else
        Trbegin [ADP]
        Read [ADP] ADP0 = "TC";"ROBJCLL"
        [F:ADP]CHAPITRE = "CRM"
        Rewrite [ADP]
        If fstat
            Rollback
            IERR = 1
        Else
            Commit
        Endif
    Endif
Endif

If IERR : End : Endif

######################
#Paramètre QREAC
######################
Read [ADP] ADP0 = "TC";"QREAC"
If fstat
    ITCEXIST = 0
Else
    ITCEXIST = 1
Endif

Read [ADP] ADP0 = "HDK";"QREAC"
If fstat
    IHDKEXIST = 0
Else
    IHDKEXIST = 1
Endif

If ITCEXIST
    If IHDKEXIST
        Trbegin [ADP]
        Delete [ADP] Where [F:ADP]CHAPITRE = "TC" and [F:ADP]PARAM = "QREAC"
        If fstat
            If fstat = 4
                Commit
            Else
                Rollback
                IERR = 1
            Endif
        Else
            Commit
        Endif
    Else
        Trbegin [ADP]
        Read [ADP] ADP0 = "TC";"QREAC"
        [F:ADP]CHAPITRE = "HDK"
        Rewrite [ADP]
        If fstat
            Rollback
            IERR = 1
        Else
            Commit
        Endif
    Endif
Endif

If IERR : End : Endif

######################
#Paramètre SREDEFCOV
######################
Read [ADP] ADP0 = "TC";"SREDEFCOV"
If fstat
    ITCEXIST = 0
Else
    ITCEXIST = 1
Endif

Read [ADP] ADP0 = "HDK";"SREDEFCOV"
If fstat
    IHDKEXIST = 0
Else
    IHDKEXIST = 1
Endif

If ITCEXIST
    If IHDKEXIST
        Trbegin [ADP]
        Delete [ADP] Where [F:ADP]CHAPITRE = "TC" and [F:ADP]PARAM = "SREDEFCOV"
        If fstat
            If fstat = 4
                Commit
            Else
                Rollback
                IERR = 1
            Endif
        Else
            Commit
        Endif
    Else
        Trbegin [ADP]
        Read [ADP] ADP0 = "TC";"SREDEFCOV"
        [F:ADP]CHAPITRE = "HDK"
        Rewrite [ADP]
        If fstat
            Rollback
            IERR = 1
        Else
            Commit
        Endif
    Endif
Endif

If IERR : End : Endif

End

###########################################################################################
# Alimentation des colonnes nouvelle formule des tables diverses
###########################################################################################
Subprog STEP2(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:ADI]) : Local File =SZAPPLI+".ATABDIV" [ADI] : Endif
Local Char SZMESS(250)

#Migration de la table 400
#Etapes des affaires
Trbegin [ADI]
Filter [ADI] Where [F:ADI]NUMTAB = 400

For [ADI]
    If [F:ADI]A1 = ""
        [F:ADI]N1 = 1
    Else
        [F:ADI]N1 = 2
    Endif

    Case [F:ADI]A2
        When "FIR"
            [F:ADI]N2 = 2
        When "WIN"
            [F:ADI]N2 = 5
        When "FOR"
            [F:ADI]N2 = 7
        When "LOS"
            [F:ADI]N2 = 6
        When Default
            [F:ADI]N2 = 1
    Endcase

    Rewrite [ADI]
    If fstat
        IERR = 1
        SZMESS = "Error while updating the miscellaneous table number 400."
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("Step 2 failed.") From DOSSUB
        Break
    Endif
Next

Filter [ADI]

If IERR
    Rollback
    End
Else
    Commit
Endif

#Migration de la table 407
#Catégories d'interventions
Trbegin [ADI]
Filter [ADI] Where [F:ADI]NUMTAB = 407

For [ADI]
    Case [F:ADI]A1
        When "OUT", "Out", "out"
            [F:ADI]N1 = 2
        When "IN", "In", "in"
            [F:ADI]N1 = 3
        When Default
            [F:ADI]N1 = 1
    Endcase

    Rewrite [ADI]
    If fstat
        IERR = 1
        SZMESS = "Error while updating the miscellaneous table number 407."
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("Step 2 failed.") From DOSSUB
        Break
    Endif
Next

Filter [ADI]

If IERR
    Rollback
    End
Else
    Commit
Endif

#Migration de la table 422
#Etats des demandes de service.
Trbegin [ADI]
Filter [ADI] Where [F:ADI]NUMTAB = 422

For [ADI]
    If [F:ADI]A1 = ""
        [F:ADI]N1 = 1
    Else
        [F:ADI]N1 = 2
    Endif
    [F:ADI]A1 = ""

    Rewrite [ADI]
    If fstat
        IERR = 1
        SZMESS = "Error while updating the miscellaneous table number 422."
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("Step 2 failed.") From DOSSUB
        Break
    Endif
Next

Filter [ADI]

If IERR
    Rollback
    End
Else
    Commit
Endif

End

###########################################################################################
# Mettre à jour le nouveau champ MACITNTYP des fiches parc. Le mettre à 1
###########################################################################################
Subprog STEP3(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:MAC]) : Local File =SZAPPLI+".MACHINES" [MAC] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [MAC] Where [F:MAC]MACNUM > SZCLE Order By [F:MAC]MACNUM Asc

    For [MAC]
        SZCLE = [F:MAC]MACNUM

            If IPERF = 0
                Trbegin [MAC]
                INTR = 1
            Endif

            [F:MAC]MACITNTYP = 1
            [F:MAC]MACORI = 1
            [F:MAC]MACORITXT = ""
            [F:MAC]MACORIVCR = ""
            [F:MAC]MACORIVCRL = 0
            Rewrite [MAC]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the MACITNTYP field value for the customer unit n°" + [F:MAC]MACNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 3 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [MAC]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

End

###########################################################################################
# Alimenter le champ SECCUR de la table MACITN avec le champ CUR de la même table
###########################################################################################
Subprog STEP4(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:MAI]) : Local File =SZAPPLI+".MACITN" [MAI] : Endif

Local Char SZMESS(250)
Local Char SZMACNUM
Local Integer ICLSNUM
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
STOPLOOP = 0
LOOPCRIT = ""
ICUT3 = 3000
ICLECOUNT3 = 0
SZMACNUM = ""
ICLSNUM = 0

Lock [MAI]
If fstat
    IERR = 1
    SZMESS = "Error while locking the MACITN table"
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 4 failed.") From DOSSUB
    End
Endif    
    
$STEP4LOOP
    If STOPLOOP = 1
      STOPLOOP = 2
      LOOPCRIT = "[F:MAI]MACNUM=SZMACNUM & [F:MAI]CLSNUM>ICLSNUM"

    Elsif STOPLOOP = 2
      STOPLOOP = 0
      LOOPCRIT = "[F:MAI]MACNUM>SZMACNUM"

    Else
      LOOPCRIT = "1=1"
    Endif
    ICLECOUNT3 = 0

    For [MAI]MAI1 Where evalue(LOOPCRIT)

        Trbegin [MAI]

        [F:MAI]SECCUR = [F:MAI]CUR
        [F:MAI]BPCCUR = [F:MAI]CUR

        Rewrite [MAI]
        If fstat
            IERR = 1
            SZMESS = "Error while setting the currency on customer unit previous locations"
            Call ECR_TRACE(SZMESS, 1) From GESECRAN
            Call ECR_TIME("Step 4 failed.") From DOSSUB
            Rollback
            STOPLOOP = 0
            Break
        Else
            Commit
        Endif

         ICLECOUNT3 += 1
         If ICLECOUNT3 >= ICUT3
             SZMACNUM = [F:MAI]MACNUM
             ICLSNUM = [F:MAI]CLSNUM
             STOPLOOP = 1
             Break
         Endif
    Next

    If STOPLOOP
        Goto STEP4LOOP
    Endif 

Unlock [MAI]

End

###########################################################################################
# Alimenter la nouvelle table CONTQUAL sur la base des contraites qualité existantes.
###########################################################################################
Subprog STEP5(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:CON]) : Local File =SZAPPLI+".CONTSERV" [CON] : Endif
If !clalev([F:COT]) : Local File =SZAPPLI+".CONTTEMPL" [COT] : Endif
If !clalev([F:CQL]) : Local File =SZAPPLI+".CONTQUAL" [CQL] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

#On nettoie tout et on recommence
Trbegin [CQL]
Delete [CQL] Where [F:CQL]CONNUM <> ""
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

#On traite d'abord les contrats de service
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [CON] Where [F:CON]CONNUM > SZCLE Order By [F:CON]CONNUM Asc

    For [CON]
        SZCLE = [F:CON]CONNUM

            If IPERF = 0
                Trbegin [CON]
                INTR = 1
            Endif

            #Problèmes non bloquants
            [F:CQL]CONNUM = [F:CON]CONNUM
            [F:CQL]TPL = 1
            [F:CQL]GRALEV = "A1"
            [F:CQL]ITTFCY = [F:CON]ITTFCY
            [F:CQL]ITTDUR = [F:CON]ITTDUR
            [F:CQL]ITTDURBAS = [F:CON]ITTDURBAS
            [F:CQL]ITTDATEND = [F:CON]ITTDATEND
            [F:CQL]ITTLTIMAX = [F:CON]ITTLTIMAX
            [F:CQL]BASEXXITT = [F:CON]BASEXXITT
            [F:CQL]SOLLTIMAX = [F:CON]SOLLTIMAX
            [F:CQL]BASEXXSOL = [F:CON]BASEXXSOL
            [F:CQL]AMTPLY = [F:CON]AMTPLY
            [F:CQL]BASEXXAMT = [F:CON]BASEXXAMT
            [F:CQL]OTHCNI = ""
            Write [CQL]
            If fstat
                IERR = 1
                SZMESS = "Error while creating a quality constraint for the service contract n°" + [F:CON]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 5 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Endif

            #Problèmes bloquants
            [F:CQL]CONNUM = [F:CON]CONNUM
            [F:CQL]TPL = 1
            [F:CQL]GRALEV = "B1"
            [F:CQL]ITTFCY = [F:CON]ITTFCYX
            [F:CQL]ITTDUR = [F:CON]ITTDURX
            [F:CQL]ITTDURBAS = [F:CON]ITTDURBASX
            [F:CQL]ITTDATEND = [F:CON]ITTDATENDX
            [F:CQL]ITTLTIMAX = [F:CON]ITTLTIMAXX
            [F:CQL]BASEXXITT = [F:CON]BASEXXITTX
            [F:CQL]SOLLTIMAX = [F:CON]SOLLTIMAXX
            [F:CQL]BASEXXSOL = [F:CON]BASEXXSOLX
            [F:CQL]AMTPLY = [F:CON]AMTPLYX
            [F:CQL]BASEXXAMT = [F:CON]BASEXXAMTX
            [F:CQL]OTHCNI = ""
            Write [CQL]
            If fstat
                IERR = 1
                SZMESS = "Error while creating a quality constraint for the service contract n°" + [F:CON]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 5 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Endif

            If IPERF >= 478
                Commit
                IPERF = 0
                INTR = 0
            Else
                IPERF += 1
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [CON]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

If IERR : End : Endif

#On traite ensuite les modèles de contrats de service
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [COT] Where [F:COT]CONNUM > SZCLE Order By [F:COT]CONNUM Asc

    For [COT]
        SZCLE = [F:COT]CONNUM

            If IPERF = 0
                Trbegin [COT]
                INTR = 1
            Endif

            #Problèmes non bloquants
            [F:CQL]CONNUM = [F:COT]CONNUM
            [F:CQL]TPL = 2
            [F:CQL]GRALEV = "A1"
            [F:CQL]ITTFCY = [F:COT]ITTFCY
            [F:CQL]ITTDUR = [F:COT]ITTDUR
            [F:CQL]ITTDURBAS = [F:COT]ITTDURBAS
            [F:CQL]ITTDATEND = [F:COT]ITTDATEND
            [F:CQL]ITTLTIMAX = [F:COT]ITTLTIMAX
            [F:CQL]BASEXXITT = [F:COT]BASEXXITT
            [F:CQL]SOLLTIMAX = [F:COT]SOLLTIMAX
            [F:CQL]BASEXXSOL = [F:COT]BASEXXSOL
            [F:CQL]AMTPLY = [F:COT]AMTPLY
            [F:CQL]BASEXXAMT = [F:COT]BASEXXAMT
            [F:CQL]OTHCNI = ""
            Write [CQL]
            If fstat
                IERR = 1
                SZMESS = "Error while creating a quality constraint for the service contract template n°" + [F:COT]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 5 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Endif

            #Problèmes bloquants
            [F:CQL]CONNUM = [F:COT]CONNUM
            [F:CQL]TPL = 2
            [F:CQL]GRALEV = "B1"
            [F:CQL]ITTFCY = [F:COT]ITTFCYX
            [F:CQL]ITTDUR = [F:COT]ITTDURX
            [F:CQL]ITTDURBAS = [F:COT]ITTDURBASX
            [F:CQL]ITTDATEND = [F:COT]ITTDATENDX
            [F:CQL]ITTLTIMAX = [F:COT]ITTLTIMAXX
            [F:CQL]BASEXXITT = [F:COT]BASEXXITTX
            [F:CQL]SOLLTIMAX = [F:COT]SOLLTIMAXX
            [F:CQL]BASEXXSOL = [F:COT]BASEXXSOLX
            [F:CQL]AMTPLY = [F:COT]AMTPLYX
            [F:CQL]BASEXXAMT = [F:COT]BASEXXAMTX
            [F:CQL]OTHCNI = ""
            Write [CQL]
            If fstat
                IERR = 1
                SZMESS = "Error while creating a quality constraint for the service contract template n°" + [F:COT]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 5 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Endif

            If IPERF >= 478
                Commit
                IPERF = 0
                INTR = 0
            Else
                IPERF += 1
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [COT]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

End

###########################################################################################
# Alimenter le nouveau champ CONCAT des contrats de service pour distinguer les garanties des maintenances.
###########################################################################################
Subprog STEP6(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:SOH]) : Local File =SZAPPLI+".SORDER" [SOH] : Endif
If !clalev([F:SOP]) : Local File =SZAPPLI+".SORDERP" [SOP] : Endif
If !clalev([F:CON]) : Local File =SZAPPLI+".CONTSERV" [CON] : Endif
If !clalev([F:COT]) : Local File =SZAPPLI+".CONTTEMPL" [COT] : Endif
If !clalev([F:BPC]) : Local File =SZAPPLI+".BPCUSTOMER" [BPC] : Endif
If !clalev([F:ACV]) : Local File =SZAPPLI+".ACTIV" [ACV] : Endif
# FGR 13/10/2009 : X3SUIVI58456 (début)
If !clalev([F:ADI1]) : Local File =SZAPPLI+".ATABDIV"  [ADI1] : Endif
If !clalev([F:AXX1]) : Local File =SZAPPLI+".ATEXTRA"  [AXX1] : Endif
If !clalev([F:ADI2]) : Local File =SZAPPLI+".ATABDIV"  [ADI2] : Endif
If !clalev([F:AXX2]) : Local File =SZAPPLI+".ATEXTRA"  [AXX2] : Endif 
# FGR 13/10/2009 : X3SUIVI58456 (fin)

Local Char SECTION 
Local Integer ITER
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
ITER = 0

If 0=1 Then  # FGR 16/02/2010 : X3SUIVI62388 : (déplacé dans STEP17)
# FGR 13/10/2009 : X3SUIVI58456 (début)
Local Char STBSRC
Local Char STBDES

  STBSRC = "406"
  STBDES = "440"  # FGR 15/02/2010 : X3SUIVI62388 : Mauvaise table "441"
  Trbegin [ADI2] , [AXX2]
  INTR = 1 # FGR 20/10/2009 : X3SUIVI58917 : du coup le commit ne se faisait pas
  For [ADI1]CODE Where NUMTAB = val(STBSRC)
    # FGR 16/02/2010 : X3SUIVI62388 (début)
    Delete [ADI2] Where [F:ADI2]NUMTAB = [F:ADI1]NUMTAB and [F:ADI2]CODE = [F:ADI1]CODE
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (Delete-ATABDIV)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 6 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
    Delete [AXX2] Where [F:AXX2]CODFIC = "ATABDIV" and ([F:AXX2]ZONE = "LNGDES" or [F:AXX2]ZONE = "SHODES")
&                   and [F:AXX2]IDENT1 = num$([F:ADI2]NUMTAB) and [F:AXX2]IDENT2 = [F:ADI2]CODE
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (Delete-ATEXTRA)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 6 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
    # FGR 16/02/2010 : X3SUIVI62388 (fin)
    Raz [F:ADI2]
    [F:ADI2] = [F:ADI1]
    [F:ADI2]NUMTAB = val(STBDES)
    If dim([F:ADI2]CREUSR)>0 : [F:ADI2]CREUSR = GUSER : Endif
    If dim([F:ADI2]CREDAT)>0 : [F:ADI2]CREDAT = date$ : Endif
    If dim([F:ADI2]CRETIM)>0 : [F:ADI2]CRETIM = time : Endif
    If dim([F:ADI2]UPDUSR)>0 : [F:ADI2]UPDUSR = "" : Endif
    If dim([F:ADI2]UPDDAT)>0 : [F:ADI2]UPDDAT = [0/0/0] : Endif
    If dim([F:ADI2]UPDTIM)>0 : [F:ADI2]UPDTIM = 0 : Endif
    # LNGDES et SHODES
    #Call COPTEXTRA("ATABDIV","LNGDES",STBSRC,[F:ADI1]CODE) From ATEXTRA
    #Call COPTEXTRA("ATABDIV","SHODES",STBSRC,[F:ADI1]CODE) From ATEXTRA
    For [AXX1]AXX0 Where CODFIC = "ATABDIV" and (ZONE = "LNGDES" or ZONE = "SHODES") and IDENT1 = STBSRC and IDENT2 = [F:ADI2]CODE
      Raz [F:AXX2]
      [F:AXX2] = [F:AXX1]
      [F:AXX2]IDENT1 = num$([F:ADI2]NUMTAB)
      If dim([F:AXX2]CREDAT)>0 : [F:AXX2]CREDAT = date$ : Endif
      If dim([F:AXX2]CREUSR)>0 : [F:AXX2]CREUSR = GUSER : Endif
      If dim([F:AXX2]CRETIM)>0 : [F:AXX2]CRETIM = time : Endif
      If dim([F:AXX2]UPDDAT)>0 : [F:AXX2]UPDDAT = [0/0/0] : Endif
      If dim([F:AXX2]UPDUSR)>0 : [F:AXX2]UPDUSR = "" : Endif
      If dim([F:AXX2]UPDTIM)>0 : [F:AXX2]UPDTIM = 0 : Endif
      Write [AXX2]
      If fstat Then
        IERR = 1
        SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (ATEXTRA)"
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TIME("Step 6 failed.") From DOSSUB
        Rollback
        INTR = 0
        Break
      Endif
    Next
    If IERR Then
      Break
    Endif
    #
    Write [ADI2]
    If fstat Then
      IERR = 1
      SZMESS = "Error while copying Miscellaneous Tables 406 in 440 (ATABDIV)"
      Call ECR_TRACE(SZMESS, 1) From GESECRAN
      Call ECR_TIME("Step 6 failed.") From DOSSUB
      Rollback
      INTR = 0
      Break
    Endif
  Next
  If INTR Then
    If !IERR Then
      Commit
    Endif
  Endif
# FGR 13/10/2009 : X3SUIVI58456 (fin)
Endif  # FGR 16/02/2010 : X3SUIVI62388 : (déplacé dans STEP17)

SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
ITER = 0
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [CON] Where [F:CON]CONNUM > SZCLE Order By [F:CON]CONNUM Asc

    For [CON]
        SZCLE = [F:CON]CONNUM

            If IPERF = 0
                Trbegin [CON]
                INTR = 1
            Endif

            #Assigne les nouvelles valeurs

            #Catégorie du contrat
            #[F:CON]CONTYP = "" # FGR 13/10/2009 : X3SUIVI58456 : on n'efface pas le contenu de cette rubrique qui perdure
            If [F:CON]GUA = 2
                [F:CON]CONCAT = 1
            Else
                [F:CON]CONCAT = 3
            Endif
            [F:CON]CONTYPCLA = mess([F:CON]CONCAT, 2976, 2)

            #Méthode de facturation
            [F:CON]INVMET = 1

            #Méthode de réévaluation
            [F:CON]RVAMET = 1
            [F:CON]RVASSP = 1

            #Origine
            If [F:CON]ORDNUM = ""
                [F:CON]CONORI = 1
                [F:CON]CONORIVCR = ""
                [F:CON]CONORIVCRL = 0
            Else
                [F:CON]CONORI = 2
                [F:CON]CONORIVCR = [F:CON]ORDNUM
                [F:CON]CONORIVCRL = [F:CON]ORDLINNUM
            Endif
            [F:CON]CONORITXT = ""

            #Informations de facturation
            Read [BPC] BPC0 = [F:CON]CONBPC
            If fstat
                [F:CON]CONBPCPYR = [F:CON]CONBPC
                [F:CON]CONBPCGRU = [F:CON]CONBPC
            Else
                [F:CON]CONBPCPYR = [F:BPC]BPCPYR
                [F:CON]CONBPCGRU = [F:BPC]BPCGRU

                [F:CON]CONVACBPR = [F:BPC]VACBPR
                [F:CON]CONCHGTYP = [F:BPC]CHGTYP
                [F:CON]CONPRITYP = [F:BPC]PRITYP

                #Sections analytiques
                Read [ACV] CODACT = "ANA"
                If !fstat
                    ITER = 1
                    For ITER = 1 To [F:ACV]DIME
                       GAXE = ITER
                       Call INISEC(SECTION,"CON",num$(ITER)) From SUBCDE 
                       Assign "[F:CON]CCE(ITER-1)" With SECTION 
                    Next
                Endif

                #Eléments de facturation
                ITER = 0
                For ITER = 0 To dim([F:CON]INVDTA) - 1
                    If ITER < dim([F:BPC]INVDTA)
                        [F:CON]INVDTA(ITER) = [F:BPC]INVDTA(ITER)
                        [F:CON]INVDTAAMT(ITER) = [F:BPC]INVDTAAMT(ITER)
                    Endif
                Next
            Endif

            #Affectation du tiroir 140
            Gosub SETFTIROIR From SUBCONB1

            #Rapatriement des informations de la commande associée sur le contrat
            If [F:CON]ORDNUM <> ""
                Read [SOH] SOH0 = [F:CON]ORDNUM
                If !fstat
                    [F:CON]CONBPCINV = [F:SOH]BPCINV
                    [F:CON]CONBPCPYR = [F:SOH]BPCPYR
                    [F:CON]CONBPCGRU = [F:SOH]BPCGRU
                    [F:CON]CONPJT = [F:SOH]PJT
                    [F:CON]CONCHGTYP = [F:SOH]CHGTYP
                    [F:CON]CONPRITYP = [F:SOH]PRITYP
                    [F:CON]CONVACBPR = [F:SOH]VACBPR
                    #Eléments de facturation
                    ITER = 0
                    For ITER = 0 To dim([F:CON]INVDTA) - 1
                        If ITER < dim([F:SOH]INVDTA)
                            [F:CON]INVDTA(ITER) = [F:SOH]INVDTA(ITER)
                            [F:CON]INVDTAAMT(ITER) = [F:SOH]INVDTAAMT(ITER)
                        Endif
                    Next
                Endif
                #Transfert du code article
                Filter [SOP] Where [F:SOP]SOHNUM = [F:CON]ORDNUM and [F:SOP]SOPLIN = [F:CON]ORDLINNUM
                For [SOP]
                    [F:CON]ITMREF = [F:SOP]ITMREF
                    Break
                Next
                Filter [SOP]
            Endif

            Rewrite [CON]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the category for the service contract n°" + [F:CON]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 6 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [CON]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

#Même  chose pour les modèles de contrats de service
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
ITER = 0

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [COT] Where [F:COT]CONNUM > SZCLE Order By [F:COT]CONNUM Asc

    For [COT]
        SZCLE = [F:COT]CONNUM

            If IPERF = 0
                Trbegin [COT]
                INTR = 1
            Endif

            #Assigne les nouvelles valeurs

            #Catégorie du contrat
            #[F:COT]CONTYP = "" # FGR 13/10/2009 : X3SUIVI58456 : on n'efface pas le contenu de cette rubrique qui perdure
            If [F:COT]GUA = 2
                [F:COT]CONCAT = 1
            Else
                [F:COT]CONCAT = 3
            Endif
            [F:COT]CONTYPCLA = mess([F:COT]CONCAT, 2976, 2)

            #Méthode de facturation
            [F:COT]INVMET = 1

            #Méthode de réévaluation
            [F:COT]RVAMET = 1
            [F:COT]RVASSP = 1

            Rewrite [COT]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the category for the service contract template n°" + [F:COT]CONNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 6 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [COT]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif
End

###########################################################################################
# Alimenter la table SREMAC sur la base du contenu du champ SREMAC des demandes de service.
###########################################################################################
Subprog STEP7(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:SRE]) : Local File =SZAPPLI+".SERREQUEST" [SRE] : Endif
If !clalev([F:SRM]) : Local File =SZAPPLI+".SREMAC" [SRM] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

#On nettoie tout et on recommence
Trbegin [SRM]
Delete [SRM] Where [F:SRM]SRENUM <> ""
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [SRE] Where [F:SRE]SRENUM > SZCLE Order By [F:SRE]SRENUM Asc

    For [SRE]
        SZCLE = [F:SRE]SRENUM

        If [F:SRE]SREMAC <> ""

            If IPERF = 0
                Trbegin [SRM]
                INTR = 1
            Endif

            #Alimente SREMAC
            [F:SRM]SRENUM = [F:SRE]SRENUM
            [F:SRM]ITNGRU = ""
            [F:SRM]MACNUM = [F:SRE]SREMAC
            [F:SRM]PBLNUM = [F:SRE]SREPBLGRP

            If [F:SRE]SRECOV = 2
                [F:SRM]COVFLG = 1
                [F:SRM]COVSPT = [F:SRE]SRETYPCOV
                [F:SRM]COVVCR = [F:SRE]SRECOVNUM
            Else
                [F:SRM]COVFLG = 3
                [F:SRM]COVSPT = 6
                [F:SRM]COVVCR = ""
            Endif

            [F:SRM]CREDAT = date$
            [F:SRM]CREUSR = GUSER

            Write [SRM]
            If fstat
                IERR = 1
                SZMESS = "Error while creating an SREMAC table record for service request n°" + [F:SRE]SRENUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 7 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif
        Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [SRE]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif


End

###########################################################################################
# Alimenter le champ OVRCOV des demandes de service sur la base du contenu du champ SRECOV des demandes de service.
###########################################################################################
Subprog STEP8(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:SRE]) : Local File =SZAPPLI+".SERREQUEST" [SRE] : Endif
If !clalev([F:BPC]) : Local File =SZAPPLI+".BPCUSTOMER" [BPC] : Endif
If !clalev([F:ACV]) : Local File =SZAPPLI+".ACTIV" [ACV] : Endif
If !clalev([F:FCY]) : Local File =SZAPPLI+".FACILITY" [FCY] : Endif
If !clalev([F:CPY]) : Local File =SZAPPLI+".COMPANY" [CPY] : Endif

Local Char SECTION 
Local Integer ITER
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
Local Char SZCUR
Local Char WLEGCPY (3)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
ITER = 0
SZCUR = ""

#Charge GCUR
SZCUR= GSYSCUR
If GFCYDEF (9) <> ""
   Read [FCY] FCY0 = GFCYDEF(9)
   If fstat = 0
      WLEGCPY = [F:FCY]LEGCPY
   Endif
Endif
If WLEGCPY <> ""
     Read [CPY]CPY0 = WLEGCPY
     If fstat = 0 : GCUR = [F:CPY]ACCCUR : Endif
Endif

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [SRE] Where [F:SRE]SRENUM > SZCLE Order By [F:SRE]SRENUM Asc

    For [SRE]
        SZCLE = [F:SRE]SRENUM

            If IPERF = 0
                Trbegin [SRE]
                INTR = 1
            Endif

            If [F:SRE]SRECOV = 2
                [F:SRE]OVRCOV = 1
            Else
                [F:SRE]OVRCOV = 3
            Endif

            #Informations de facturation
            Read [BPC] BPC0 = [F:SRE]SREBPC
            If fstat
                [F:SRE]SREBPCINV = [F:SRE]SREBPC
                [F:SRE]SREBPCPYR = [F:SRE]SREBPC
                [F:SRE]SREBPCGRU = [F:SRE]SREBPC
            Else
                [F:SRE]SREBPCINV = [F:BPC]BPCINV
                [F:SRE]SREBPCPYR = [F:BPC]BPCPYR
                [F:SRE]SREBPCGRU = [F:BPC]BPCGRU

                [F:SRE]SREVACBPR = [F:BPC]VACBPR
                [F:SRE]SRECHGTYP = [F:BPC]CHGTYP
                [F:SRE]SREPRITYP = [F:BPC]PRITYP
                [F:SRE]SRECUR = SZCUR
                [F:SRE]SREPTE = [F:BPC]PTE
                [F:SRE]SREDEP = [F:BPC]DEP

                #Représentants
                Read [ACV] CODACT = "REC"
                If !fstat
                    ITER = 0
                    For ITER = 0 To [F:ACV]DIME - 1
                        [F:SRE]SREREP(ITER) = [F:BPC]REP(ITER)
                    Next
                Endif

                #Sections analytiques
                Read [ACV] CODACT = "ANA"
                If !fstat
                    ITER = 1
                    For ITER = 1 To [F:ACV]DIME
                       GAXE = ITER
                       Call INISEC(SECTION,"SRE",num$(ITER)) From SUBCDE 
                       Assign "[F:SRE]CCE(ITER-1)" With SECTION 
                    Next
                Endif

                #Eléments de facturation
                ITER = 0
                For ITER = 0 To dim([F:SRE]INVDTA) - 1
                    If ITER < dim([F:BPC]INVDTA)
                        [F:SRE]INVDTA(ITER) = [F:BPC]INVDTA(ITER)
                        [F:SRE]INVDTAAMT(ITER) = [F:BPC]INVDTAAMT(ITER)
                    Endif
                Next
            Endif

            Rewrite [SRE]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the global covering for the service request n°" + [F:SRE]SRENUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 8 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [SRE]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif


End

###########################################################################################
# Alimenter la table CONTCOV sur la base du contenu des tables CONTITM et CONTPBL
###########################################################################################
Subprog STEP9(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:CON]) : Local File =SZAPPLI+".CONTSERV" [CON] : Endif
If !clalev([F:CIT]) : Local File =SZAPPLI+".CONTITM" [CIT] : Endif
If !clalev([F:CPL]) : Local File =SZAPPLI+".CONTPBL" [CPL] : Endif
If !clalev([F:CCV]) : Local File =SZAPPLI+".CONTCOV" [CCV] : Endif

#On nettoie tout et on recommence
Trbegin [CCV]
Delete [CCV] Where [F:CCV]RECNUM <> ""
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Local Char SZMESS(250)
Local Char SZCONNUM
Local Integer ITPL
Local Char SZCONMACNUM
Local Char SZPBL
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
STOPLOOP = 0
LOOPCRIT = ""
ICUT3 = 3000
ICLECOUNT3 = 0
SZCONNUM = ""
SZCONMACNUM = ""
SZPBL = ""
ITPL = 0

Lock [CCV]
If fstat
    IERR = 1
    SZMESS = "Error while locking the CONTCOV table"
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 9 failed.") From DOSSUB
    End
Endif    
    
$CITLOOP
    If STOPLOOP = 1
      STOPLOOP = 2
      LOOPCRIT = "[F:CIT]CONNUM=SZCONNUM & [F:CIT]TPL=ITPL & [F:CIT]CONMACNUM>SZCONMACNUM"

    Elsif STOPLOOP = 2
      STOPLOOP = 3
      LOOPCRIT = "[F:CIT]CONNUM=SZCONNUM & [F:CIT]TPL>ITPL"

    Elsif STOPLOOP = 3
      STOPLOOP = 0
      LOOPCRIT = "[F:CIT]CONNUM>SZCONNUM"

    Else
      LOOPCRIT = "1=1"
    Endif
    ICLECOUNT3 = 0

    For [CIT]CIT0 Where evalue(LOOPCRIT)

        Trbegin [CCV]

        Raz [F:CCV]
        [F:CCV]CONNUM = [F:CIT]CONNUM
        [F:CCV]TPL = [F:CIT]TPL
        Read [CON] CON0 = [F:CIT]CONNUM
        If fstat
            [F:CCV]BPC = ""
        Else
            [F:CCV]BPC = [F:CON]CONNUM
        Endif
        [F:CCV]RECTYP = "MAC"
        Case [F:CIT]COVTYP
            When 1
                [F:CCV]SBBRECTYP = "MAC"
            When 2
                [F:CCV]SBBRECTYP = "ITM"
        Endcase

        [F:CCV]RECNUM = [F:CIT]CONMACNUM
        [F:CCV]CMT = [F:CIT]CONMACCOD

        Write [CCV]
        If fstat
            IERR = 1
            SZMESS = "Error while creating an CONTCOV table record for service contract n°" + [F:CIT]CONNUM
            Call ECR_TRACE(SZMESS, 1) From GESECRAN
            Call ECR_TIME("Step 9 failed.") From DOSSUB
            Rollback
            STOPLOOP = 0
            Break
        Else
            Commit
        Endif

         ICLECOUNT3 += 1
         If ICLECOUNT3 >= ICUT3
             SZCONNUM = [F:CIT]CONNUM
             ITPL = [F:CIT]TPL
             SZCONMACNUM = [F:CIT]CONMACNUM
             STOPLOOP = 1
             Break
         Endif
    Next

    If STOPLOOP
        Goto CITLOOP
    Endif 

#Traitement de la table CONTPBL
STOPLOOP = 0
LOOPCRIT = ""
ICUT3 = 3000
ICLECOUNT3 = 0
SZCONNUM = ""
SZCONMACNUM = ""
SZPBL = ""
ITPL = 0

$CPLLOOP
    If STOPLOOP = 1
      STOPLOOP = 2
      LOOPCRIT = "[F:CPL]CONNUM=SZCONNUM & [F:CPL]TPL=ITPL & [F:CPL]PBLGRPCOV>SZPBL"

    Elsif STOPLOOP = 2
      STOPLOOP = 3
      LOOPCRIT = "[F:CPL]CONNUM=SZCONNUM & [F:CPL]TPL>ITPL"

    Elsif STOPLOOP = 3
      STOPLOOP = 0
      LOOPCRIT = "[F:CPL]CONNUM>SZCONNUM"

    Else
      LOOPCRIT = "1=1"
    Endif
    ICLECOUNT3 = 0

    For [CPL]CPL0 Where evalue(LOOPCRIT)

        Trbegin [CCV]

        Raz [F:CCV]
        [F:CCV]CONNUM = [F:CPL]CONNUM
        [F:CCV]TPL = [F:CPL]TPL
        Read [CON] CON0 = [F:CPL]CONNUM
        If fstat
            [F:CCV]BPC = ""
        Else
            [F:CCV]BPC = [F:CON]CONNUM
        Endif
        [F:CCV]RECTYP = "PBL"
        [F:CCV]SBBRECTYP = ""

        [F:CCV]RECNUM = [F:CPL]PBLGRPCOV
        [F:CCV]CMT = ""

        Write [CCV]
        If fstat
            IERR = 1
            SZMESS = "Error while creating an CONTCOV table record for service contract n°" + [F:CPL]CONNUM
            Call ECR_TRACE(SZMESS, 1) From GESECRAN
            Call ECR_TIME("Step 9 failed.") From DOSSUB
            Rollback
            STOPLOOP = 0
            Break
        Else
            Commit
        Endif

         ICLECOUNT3 += 1
         If ICLECOUNT3 >= ICUT3
             SZCONNUM = [F:CPL]CONNUM
             ITPL = [F:CPL]TPL
             SZPBL = [F:CPL]PBLGRPCOV
             STOPLOOP = 1
             Break
         Endif
    Next

    If STOPLOOP
        Goto CPLLOOP
    Endif 


Unlock [CCV]

End


###########################################################################################
# Alimenter les nouveaux paramètres utilisateurs V140 pour les chapitres CRM et HDK.
###########################################################################################
Subprog STEP10(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:AUS]) : Local File =SZAPPLI+".AUTILIS" [AUS] : Endif
If !clalev([F:ADU]) : Local File =SZAPPLI+".ADOVALAUS" [ADU] : Endif

Local Integer IMONTH
Local Integer IDAY
Local Char SZMONTH
Local Char SZDAY
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

#On nettoie tout et on recommence
Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMA"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMB"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMC"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMD"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRME"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMF"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMG"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSCRMH"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSHDKA"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

Trbegin [ADU]
Delete [ADU] Where [F:ADU]PARAM = "AUSHDKB"
If fstat
    If fstat = 4
        Commit
    Else
        Rollback
    Endif
Else
    Commit
Endif

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [AUS] Where [F:AUS]USR > SZCLE Order By [F:AUS]USR Asc

    For [AUS]
        SZCLE = [F:AUS]USR

        If [F:AUS]USR <> ""
            #######################
            #Champ FONCTION
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMA"
            Case [F:AUS]FNC
                When 0
                    [F:ADU]VALEUR = "1"
                When 1
                    [F:ADU]VALEUR = "2"
                When 2
                    [F:ADU]VALEUR = "3"
                When 3
                    [F:ADU]VALEUR = "4"
                When 4
                    [F:ADU]VALEUR = "5"
                When 5
                    [F:ADU]VALEUR = "1"
                When Default
                    [F:ADU]VALEUR = "1"
            Endcase

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMA value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ STATUT
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMB"
            [F:ADU]VALEUR = num$([F:AUS]STA)

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMB value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ DEBUT MISSION
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMC"

#            IMONTH = month([F:AUS]MSNSTR)
#            If IMONTH < 10
#                SZMONTH = "0" + num$(IMONTH)
#            Else
#                SZMONTH = num$(IMONTH)
#            Endif

#            IDAY = day([F:AUS]MSNSTR)
#            If IDAY < 10
#                SZDAY = "0" + num$(IDAY)
#            Else
#                SZDAY = num$(IDAY)
#            Endif
#            [F:ADU]VALEUR = num$(year([F:AUS]MSNSTR)) + SZMONTH + SZDAY

            [F:ADU]VALEUR = format$("D:YYYYMMDD",[F:AUS]MSNSTR)
            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMC value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ FIN MISSION
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMD"

#            IMONTH = month([F:AUS]MSNEND)
#            If IMONTH < 10
#                SZMONTH = "0" + num$(IMONTH)
#            Else
#                SZMONTH = num$(IMONTH)
#            Endif

#            IDAY = day([F:AUS]MSNEND)
#            If IDAY < 10
#                SZDAY = "0" + num$(IDAY)
#            Else
#                SZDAY = num$(IDAY)
#            Endif
#            [F:ADU]VALEUR = num$(year([F:AUS]MSNEND)) + SZMONTH + SZDAY

            [F:ADU]VALEUR = format$("D:YYYYMMDD",[F:AUS]MSNEND)
            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMD value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ RESPONSABLE
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRME"
            [F:ADU]VALEUR = num$([F:AUS]MNA)

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRME value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ REPRESENTANT
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMF"
            [F:ADU]VALEUR = [F:AUS]REPNUM

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMF value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ TEMPS PLEIN
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSCRMG"
            [F:ADU]VALEUR = num$([F:AUS]FULTIM)

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSCRMG value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ COLLABORATEUR HELP-DESK
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSHDKA"
            [F:ADU]VALEUR = num$([F:AUS]HDKREP)

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSHDKA value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

            #######################
            #Champ AUTORISATION DISPATCHING
            If IPERF = 0
                Trbegin [ADU]
                INTR = 1
            Endif

            Raz [F:ADU]
            [F:ADU]CODUSR = [F:AUS]USR
            [F:ADU]PARAM = "AUSHDKB"
            [F:ADU]VALEUR = num$([F:AUS]AUZDSCDEM)

            [F:ADU]CREDAT = date$
            [F:ADU]CREUSR = GUSER

            Write [ADU]
            If fstat
                IERR = 1
                SZMESS = "Error while assigning the AUSHDKB value for user " + [F:AUS]USR
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 10 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif
        Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [AUS]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

End

###########################################################################################
# Mettre à jour le nouveau champ CLLCMGFLG des fiches appels générées par une campagne. Le mettre à 1
###########################################################################################
Subprog STEP11(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:CLL]) : Local File =SZAPPLI+".PHONECALL" [CLL] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0

While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [CLL] Where [F:CLL]CLLNUM > SZCLE
&           and [F:CLL]CLLDON <> 2
&           and [F:CLL]CLLOPGTYP = "OMP"
&           and [F:CLL]CLLCMGFLG = 0
&           and [F:CLL]CLLOPGNUM <> ""
&             Order By [F:CLL]CLLNUM Asc

    For [CLL]
        SZCLE = [F:CLL]CLLNUM

            If IPERF = 0
                Trbegin [CLL]
                INTR = 1
            Endif

            [F:CLL]CLLCMGFLG = 1
            Rewrite [CLL]
            If fstat
                IERR = 1
                SZMESS = "Error while setting the CLLCMGFLG field value for the phonecall n°" + [F:CLL]CLLNUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 11 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [CLL]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

End

###########################################################################################
# Alimentation des Clobs
###########################################################################################
Subprog STEP14(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

If !clalev([F:HD1]) : Local File =SZAPPLI+".HD1CLOB" [HD1] : Endif
If !clalev([F:HD2]) : Local File =SZAPPLI+".HD2CLOB" [HD2] : Endif
If !clalev([F:HD3]) : Local File =SZAPPLI+".HD3CLOB" [HD3] : Endif
If !clalev([F:HD4]) : Local File =SZAPPLI+".HD4CLOB" [HD4] : Endif
If !clalev([F:HD5]) : Local File =SZAPPLI+".HD5CLOB" [HD5] : Endif
If !clalev([F:HD6]) : Local File =SZAPPLI+".HD6CLOB" [HD6] : Endif
If !clalev([F:SRE]) : Local File =SZAPPLI+".SERREQUEST" [SRE] : Endif
If !clalev([F:ITN]) : Local File =SZAPPLI+".INTERVEN" [ITN] : Endif
If !clalev([F:SOL]) : Local File =SZAPPLI+".SOLUTION" [SOL] : Endif
If !clalev([F:BAP]) : Local File =SZAPPLI+".BAPPOINT" [BAP] : Endif
If !clalev([F:CLL]) : Local File =SZAPPLI+".PHONECALL" [CLL] : Endif
If !clalev([F:TSK]) : Local File =SZAPPLI+".TASK" [TSK] : Endif
If !clalev([F:CMG]) : Local File =SZAPPLI+".CMARKETING" [CMG] : Endif
If !clalev([F:OMM]) : Local File =SZAPPLI+".MAILING" [OMM] : Endif
If !clalev([F:OMP]) : Local File =SZAPPLI+".PHONING" [OMP] : Endif
If !clalev([F:OMT]) : Local File =SZAPPLI+".TRADESHOW" [OMT] : Endif
If !clalev([F:OMN]) : Local File =SZAPPLI+".MEDIA" [OMN] : Endif
If !clalev([F:RSS]) : Local File =SZAPPLI+".RESOURCES" [RSS] : Endif
If !clalev([F:MST]) : Local File =SZAPPLI+".MARSCT" [MST] : Endif
If !clalev([F:QUE]) : Local File =SZAPPLI+".QUEUE" [QUE] : Endif
If !clalev([F:ICM]) : Local File =SZAPPLI+".ITMCOMP" [ICM] : Endif

Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF
Local Char SZMESS(250)


#On commence par nettoyer les tables CLOB
Trbegin [HD1], [HD2], [HD3], [HD4], [HD5], [HD6]
Delete [HD1] Where [F:HD1]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD1 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD1] Where [F:HD1]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD1 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD2] Where [F:HD2]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD2 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD2] Where [F:HD2]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD2 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD3] Where [F:HD3]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD3 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD3] Where [F:HD3]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD3 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD4] Where [F:HD4]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD4 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD4] Where [F:HD4]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD4 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD5] Where [F:HD5]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD5 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD5] Where [F:HD5]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD5 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD6] Where [F:HD6]NUM <> ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD6 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Delete [HD6] Where [F:HD6]NUM = ""
If fstat
    IERR = 1
    SZMESS = "Error while deleting HD6 Clob table."
    Call ECR_TRACE(SZMESS, 1) From GESECRAN
    Call ECR_TIME("Step 14 failed.") From DOSSUB
    Rollback
    End
Endif

Commit

######################
#Demandes de service
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [SRE] Where [F:SRE]SRENUM > SZCLE
&             Order By [F:SRE]SRENUM Asc

    For [SRE]
        SZCLE = [F:SRE]SRENUM

            If IPERF = 0
                Trbegin [SRE], [HD1]
                INTR = 1
            Endif

            If [F:SRE]SREDES <> ""
                #Création du clob
                Raz [F:HD1]
                [F:HD1]NUM = [F:SRE]SRENUM
                [F:HD1]TYP = "SRE"
                Setlob [F:HD1]CLOB With [F:SRE]SREDES
                Write [HD1]
                If fstat
                    IERR = 1
                    SZMESS = "Error while creating the service request CLOB n°" + " " + [F:SRE]SRENUM
                    Call ECR_TRACE(SZMESS, 1) From GESECRAN
                    Call ECR_TIME("Step 14 failed.") From DOSSUB
                    Rollback
                    INTR = 0
                    Break
                Endif
            Endif

            [F:SRE]TYPFULDES = "SRE"
            [F:SRE]NUMFULDES = [F:SRE]SRENUM
            [F:SRE]SREDESFLG = 0
            Rewrite [SRE]
            If fstat
                IERR = 1
                SZMESS = "Error while creating the service request CLOB n°" + " " + [F:SRE]SRENUM
                Call ECR_TRACE(SZMESS, 1) From GESECRAN
                Call ECR_TIME("Step 14 failed.") From DOSSUB
                Rollback
                INTR = 0
                Break
            Else
                If IPERF >= 478
                    Commit
                    IPERF = 0
                    INTR = 0
                Else
                    IPERF += 1
                Endif
            Endif

        ICLECOUNT += 1
        If ICLECOUNT >= ICUT : Break : Endif
    Next

    Filter [SRE]

    If IERR
        Break
    Endif
Wend

If INTR
    If !IERR
        Commit
    Endif
Endif

If IERR : End : Endif

######################
#Interventions
SZCLE = ""
ICUT = 2500
ICLECOUNT = ICUT
IPERF = 0
INTR = 0
While ICLECOUNT >= ICUT
    ICLECOUNT = 0

    Filter [ITN] Where [F:ITN]NUM > SZCLE
&             Order By [F:ITN]NUM Asc

    For [ITN]
        SZCLE = [F:ITN]NUM

            If IPERF = 0
                Trbegin [ITN], [HD2], [HD6]
                INTR = 1
            Endif

            If [F:ITN]RPO <> ""
                #Création du clob
                Raz [F:HD2]
                [F:HD2]NUM = [F:ITN]NUM
                [F:HD2]TYP = "ITN"
                Setlob [F:HD2]CLOB With [F:ITN]RPO
                Write [HD2]
                If fstat
                    IERR = 1
                    SZMESS = "Error while creating the intervention CLOB n°" + " " + [F:ITN]NUM
                    Call ECR_TRACE(SZMESS, 1) From GESECRAN
                    Call ECR_TIME("Step 14 failed.") From DOSSUB
                    Rollback
                    INTR = 0
                    Break
                Endif
            Endif

            If [F:ITN]OBJ <> ""
                #Création du clob
