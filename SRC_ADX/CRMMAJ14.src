Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("Step 3 : Fill MACINTTYP field from MACHINE table with value 1.") From DOSSUB

IERRFLG = 0
Call STEP3(SZAPPLI, IERRFLG)
If IERRFLG
