#CHECK MIGRATE_SOURCE
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("Migration 130 to 140. CRM module") From LECFIC
 Call MAJ130140(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

#########################################################################

#####################################################################################################################
#                                                                                                                   #
# Migration 130 vers 140 Module CRM                                                       Module CRM   23 mai 2002  #
#                                                                                                                   #
#####################################################################################################################

Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif

Read [ADS] DOSSIER=APPLI
If fstat
    Raz [F:ADS]
    End
Endif

#Si Module Support client non actif. On ne fait rien.
If [F:ADS]MODULE(11) <> 2 : End : Endif

#Si Module Action Co non actif. On ne fait rien.
If [F:ADS]MODULE(12) <> 2 : End : Endif

Call MAJ130140(APPLI)

End

#######################################################################
#Moulinette AVANT
#Module Support client
Subprog ACR1MAJ14
Call MAJ130140([F:ADS]DOSSIER)
End

#######################################################################
#Moulinette AVANT
#Module Action commerciale
Subprog ACR2MAJ14
End

#######################################################################
#Moulinette APRES
#Module Support client
Subprog CR1MAJ14

Local Integer IERRFLG

  # FGR 16/02/2010 : X3SUIVI62388 (début)
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Step 17 : Copying Miscellaneous Tables 406 in 440") From DOSSUB
  #
  IERRFLG = 0
  Call STEP17([F:ADS]DOSSIER, IERRFLG)
  If IERRFLG Then
    Call ECR_TIME("Step 17 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("Step 17 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  # FGR 16/02/2010 : X3SUIVI62388 (fin)

  # FGR 17/02/2008 : X3SUIVI52520
  Call MAJ_UTICRM005([F:ADS]DOSSIER) From UTICRM005
End

#######################################################################
#Moulinette APRES
#Module Action commerciale
Subprog CR2MAJ14
End

#######################################################################
Subprog MAJ130140(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRFLG
Local Integer IERRCOUNT
IERRFLG = 0
IERRCOUNT = 0

#Appels des différentes moulinettes successives
Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("Start CRM Migration 130 to 140 version") From DOSSUB
Call ECR_TRACE("--------------------------------------",0) From GESECRAN

##################################################
#Moulinette 1
#
# Passage des paramètres Tronc commun dans les modules Action co et Support client
#
##################################################
Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Call ECR_TIME("Step 1 : Transfering CRM related common core parameters into new module categories.") From DOSSUB

Call STEP1(SZAPPLI, IERRFLG)
If IERRFLG
    Call ECR_TIME("Step 1 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
Else
    Call ECR_TIME("Step 1 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
Endif

##################################################
#Moulinette 2
