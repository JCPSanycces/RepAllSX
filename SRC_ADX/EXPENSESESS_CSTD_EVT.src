#  #  When "txt"  : [L]ASTATUS = fmet this.ASETATTRIBUTE("MYDOCUMENT","$contentType","text/plain")
#  Endcase
#Next

If dim(this.HREXPENSES) > 0
  Local File HRTABEXPENS[F:HRTES]      #V12
  Local File TABVAT [F:VATESS]
  Local File ATEXTRA [AXX]
  Local Integer MAXL, NI

  Local File HRESSATT [ATT]
  Local File AOBJTXT [ATTOBJ]
  Local File ABLOB [ABLB]
  Local File ACLOB [ACLB]

  Local Integer INDX
  Local Blbfile ATTACHMENT(GLONABB)

  MAXL = maxtab(this.HREXPENSES)
  For NI = 1 To MAXL
    If this.HREXPENSES(NI) <> null and find(this.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0

      #Populate Expense code LEG tech field
      this.HREXPENSES(NI).TCH_L_LEGEXP = AVOID.ACHAR
      Read [F:HRTES]HRTES0 = this.HREXPENSES(NI).APARENT.LEG;this.HREXPENSES(NI).CODEXP  #V12
      If !fstat
        this.HREXPENSES(NI).TCH_L_LEGEXP = this.HREXPENSES(NI).APARENT.LEG
      Endif

      #Populate VAT LEG tech field
      this.HREXPENSES(NI).TCH_L_LEGVAT = AVOID.ACHAR
      Read [F:VATESS]TVT0 = this.HREXPENSES(NI).VAT;this.HREXPENSES(NI).APARENT.LEG
      If !fstat
        this.HREXPENSES(NI).TCH_L_LEGVAT = this.HREXPENSES(NI).APARENT.LEG
      Endif

      Read [F:HRTES]HRTES0 = this.HREXPENSES(NI).TCH_L_LEGEXP;this.HREXPENSES(NI).CODEXP  #V12
      If fstat = [V]CST_AOK
        #Read [AXX]AXX0 = "ATABDIV";"LNGDES";this.ACTX.LAN;"10551";[F:HRTES]UOM
        this.HREXPENSES(NI).TCH_UOMDES=func AFNC.TEXTRA("ATABDIV","LNGDES","10551",[F:HRTES]UOM)
        #this.HREXPENSES(NI).TCH_UOMDES = [F:AXX]TEXTE
        this.HREXPENSES(NI).TCH_LEG    = this.HREXPENSES(NI).APARENT.LEG
        If [F:HRTES]DEB=2
          this.HREXPENSES(NI).TCH_SNS="-"
        Else
          this.HREXPENSES(NI).TCH_SNS="+"
        Endif
      Endif

      #------------------------------Start Attachments---------------------------------#

      Filter [F:ATT] Where IDENT2 = num$(this.HREXPENSES(NI).UID)
      Read [ATT] First

      For [ATT]
        Filter [F:ATTOBJ] Where IDENT1 = [ATT]IDENT1 and IDENT2 = [ATT]IDENT2 and IDENT3 = [ATT]IDENT3
        Read [ATTOBJ] First

        If fstat > 0
          Delete [ATT]
        Endif
      Next

      Filter [F:ATTOBJ] Where IDENT2 = num$(this.HREXPENSES(NI).UID)
      Local Integer INDX : INDX = 1

      For [ATTOBJ]
        L = fmet this.HREXPENSES(NI).ADDLINE("ESSATT",INDX)

        Filter [F:ATT] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
        Read [ATT] First

        If fstat > 0
          Filter [F:ABLB] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
          Read [ABLB] First

          this.HREXPENSES(NI).ESSATT(L).ABREV = [ATTOBJ]ABREV
          this.HREXPENSES(NI).ESSATT(L).IDENT2 = [ATTOBJ]IDENT2
          this.HREXPENSES(NI).ESSATT(L).IDENT3 = [ATTOBJ]IDENT3


          If [ATTOBJ]TYPDOC = "DOC"
            Local Char VPATH(255)
            Local Integer DASHPOS : DASHPOS = instr(1,[ATTOBJ]NAM,"/")
            Local Integer EXTPOS  : EXTPOS  = instr(1,[ATTOBJ]NAM,".")
            Local Char FIC_EXT(30)

            If DASHPOS
              VPATH = right$([ATTOBJ]NAM,DASHPOS+1)
              If EXTPOS
                VPATH = left$(VPATH,instr(1,VPATH,".")-1)
              Endif
            Else
              VPATH = [ATTOBJ]NAM
            Endif

            If EXTPOS
              FIC_EXT = right$([ATTOBJ]NAM,EXTPOS+1)
            Endif

            Openi filpath("ATT",VPATH,FIC_EXT) Using [SOA]

            Getseq GLONABB, ATTACHMENT Using [SOA]

            Openi Using [SOA]

            If ATTACHMENT <> AVOID.ABLOB
              this.HREXPENSES(NI).ESSATT(L).NAM = VPATH
              this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
              Call SYNCATT([ATTOBJ]ABREV, VPATH, ATTACHMENT, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3)
            Else
              this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
              this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
            Endif
          Elsif [ATTOBJ]TYPDOC = "RTF"
            Filter [F:ACLB] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
            Read [ACLB] First

            If fstat = 0
              Local Char FILENAM(255) : FILENAM = [ATTOBJ]IDENT1 + "_" + [ATTOBJ]IDENT2 + "_" + [ATTOBJ]IDENT3
              Local Char NEWVOLUME(255) : NEWVOLUME = "ATT"
              Local Char DIRVOLA(250)
              Local Char TEXT (250)(1..)

              Setlob TEXT With [ACLB]CLOB

              DIRVOLA = func AVOLUME_CSTD._GETFULLPATH(num$(NEWVOLUME),"")

              Openo DIRVOLA + FILENAM,0 Using [FDATA]
              Wrseq TEXT Using [FDATA]
              Openo Using [FDATA]

              Openi filpath("ATT",FILENAM,"") Using [SOA]
              Getseq GLONABB, ATTACHMENT Using [SOA]
              Openi Using [SOA]

              If ATTACHMENT <> AVOID.ABLOB
                this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
                this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1

                Call SYNCATT([ATTOBJ]ABREV, [ATTOBJ]NAM, ATTACHMENT, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3)
              Else
                this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
                this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
              Endif
            Else
              this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
              this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
            Endif
          Else
            Filter [F:ABLB] Where IDENT1 = [ATTOBJ]IDENT1 and IDENT2 = [ATTOBJ]IDENT2 and IDENT3 = [ATTOBJ]IDENT3
            Read [ABLB] First

            If fstat = 0
              this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
              this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
              Call SYNCATT([ATTOBJ]ABREV, [ATTOBJ]NAM, [ABLB]BLOB, [ATTOBJ]IDENT1, [ATTOBJ]IDENT2, [ATTOBJ]IDENT3)
            Else
              this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
              this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
            Endif
          Endif

        Else
          this.HREXPENSES(NI).ESSATT(L).ABREV = [ATTOBJ]ABREV
          this.HREXPENSES(NI).ESSATT(L).NAM = [ATTOBJ]NAM
          this.HREXPENSES(NI).ESSATT(L).IDENT1 = [ATTOBJ]IDENT1
          this.HREXPENSES(NI).ESSATT(L).IDENT2 = [ATTOBJ]IDENT2
          this.HREXPENSES(NI).ESSATT(L).IDENT3 = [ATTOBJ]IDENT3
        Endif

        INDX = INDX + 1

        Filter [F:ATT]
      Next

      Filter [F:ATTOBJ]

      #------------------------------End Attachments---------------------------------#

    Endif
  Next

  LogicClose File [ATTOBJ]
  LogicClose File [ATT]

  LogicClose File [HRTES]     #V12
  LogicClose File [AXX]
Endif

Gosub CALC_TOTALS_EVT

Return
############################################################################################################
$CHECK_STATUS

Local Integer CHANGE_FOUND, MAXL, NJ
CHANGE_FOUND = [V]CST_ANO

If this.STRDAT <> this.snapshot.STRDAT
  CHANGE_FOUND = [V]CST_AYES
Endif
If this.ENDDAT <> this.snapshot.ENDDAT & CHANGE_FOUND = [V]CST_ANO
  CHANGE_FOUND = [V]CST_AYES
Endif
If this.TIT <> this.snapshot.TIT & CHANGE_FOUND = [V]CST_ANO
  CHANGE_FOUND = [V]CST_AYES
Endif

If CHANGE_FOUND <> [V]CST_AYES
  MAXL = maxtab(this.HREXPENSES)
  If MAXL > 0
    For NJ = 1 To MAXL
      If find(this.HREXPENSES(NJ).ASTALIN,[V]CST_AUPD,[V]CST_ANEW)
        CHANGE_FOUND = [V]CST_AYES
        Break
      Endif
    Next
  Endif
Endif

If CHANGE_FOUND = [V]CST_ANO
  ASTATUS = fmet this.ASETERROR("","Unable to save, no changes made",[V]CST_AERROR)
Endif

Return
############################################################################################################
$CHECK_LINES

Local Integer MAXL
Local Integer FOUND
MAXL = maxtab(this.HREXPENSES)

#Check collection again to see if there are records
If MAXL > 0
  For NI = 1 To MAXL
    If this.HREXPENSES(NI) <> null and find(this.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      FOUND = 2
      Break
    Endif
  Next
Endif

If FOUND <> 2
  ASTATUS=fmet this.ASETERROR("",mess(38,10718,1),[V]CST_AERROR)
Endif

Return
