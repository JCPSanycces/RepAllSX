############################################################################################################
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINIT"                    : Gosub AINIT
      When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      When "AINSERT_CONTROL_BEFORE"   : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"   : Gosub AUPDATE_CONTROL_BEFORE
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
      When "AINSERT_AFTER"            : Gosub AINSERT_AFTER
      When "AUPDATE_AFTER"            : Gosub AUPDATE_AFTER
    Endcase
  When "HREXPENSES"     #this is for the EXPENSES collection line
    Case [L]AEVENT
      When "ADDLINE_AFTER"            : Gosub EXPENSES_ADDLINE_AFTER
      When "ADDLINE_BEFORE"           : Gosub EXPENSES_ADDLINE_BEFORE
      When "ADELLINE_BEFORE"          : Gosub EXPENSES_ADELLINE_BEFORE
      When "ADELLINE_AFTER"           : Gosub EXPENSES_ADELLINE_AFTER
    Endcase
Endcase
Return

############################################################################################################
$METHODS
Return
############################################################################################################
$AINIT

Return
############################################################################################################
$AREAD_AFTER

If this.REFNUM <> AVOID.ACHAR
  Local File EMPLOID [ID]
  Read [ID]ID0=this.REFNUM
  If fstat = [V]CST_AOK
    this.TCH_NAMSRN = toupper([F:ID]NAM)-tolower([F:ID]SRN)
    this.TCH_SBDSRN = toupper([F:ID]NAM)-tolower([F:ID]SRN)
  Endif
  LogicClose File [ID]
Endif


