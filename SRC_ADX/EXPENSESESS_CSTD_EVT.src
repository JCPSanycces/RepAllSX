$AINSERT_AFTER
$AUPDATE_AFTER
Local Integer I
Local Char    OPERAT(30)
Gosub ATTACHMENTS
OPERAT="M"


Gosub WORKFLOW_UPDATE_STAT
Gosub EXEC_WORKFLOW

Return

$ADDITONAL_TABLE_UPDATE
Local File HREXPENSES [HREXS6]
Gosub SET_CREUPD
Return

$SET_CREUPD
If this.TCH_EMPSBD <> AVOID.ACHAR
  Local File ADOVALAUS [ADU1]
  Filter [F:ADU1] Where PARAM = "REFNUM" and VALEUR = this.REFNUM
  Read [ADU1] First
  If fstat = [V]CST_AOK
    #Update all records
    Update [HREXS6] Where CTRNUM = this.CTRNUM and EXSNUM = this.EXSNUM With UPDUSR = [F:ADU1]CODUSR
    Update [HREXS6] Where CTRNUM = this.CTRNUM and EXSNUM = this.EXSNUM With CREUSR = [F:ADU1]CODUSR
  Endif
Endif
Return

############################################################################################################
$WORKFLOW_UPDATE_STAT
#
Local Integer REQNUM,TYPEVT,STAT, I
Local Char    CODEVT(30)
Local Char    MSG(250),CLEOBJ(250)

TYPEVT=2         : # Object based event
CODEVT="HREXS"     : # The object is HREXS

# Current key
#Only one record needs to be passed to workflow
If this.HREXPENSES <> null
  For I = 1 To maxtab(this.HREXPENSES)
    If this.HREXPENSES(I) <> null and find(this.HREXPENSES(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      #Set CLEOBJ
      CLEOBJ=this.REFNUM+"~"+num$(this.EXSNUM)+"~"+num$(this.CTRNUM)+"~"+num$(this.HREXPENSES(I).LIN)
      Break
    Endif
  Next
Endif

#
Return
############################################################################################################
$EXEC_WORKFLOW
Gosub ADDITONAL_TABLE_UPDATE
STAT = func ASYRWRKCLASSIC.WORKFLOW(this.ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQNUM,MSG)
Return
############################################################################################################
$CALC_TOTALS_EVT

If this.APARENT <> null and CURPTH = "HREXPENSES"
  Gosub CALC_TOTALS_PRO From HREXPENSES_CSTD_PRO
Else
  Local Shortint I, J
  Raz this.TCH_TOTPAY, this.TCH_TOTRFU

  For J = 1 To maxtab(this.HREXPENSES)
    If this.HREXPENSES(J) <> null and find(this.HREXPENSES(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
      If this.HREXPENSES(J).TCH_SNS="+"
        I=1
      Else
        I=-1
      Endif

      this.TCH_TOTPAY+=I*this.HREXPENSES(J).PAYCUR
      this.TCH_TOTRFU+=I*this.HREXPENSES(J).RFUCUR
    Endif
  Next
Endif

Return
############################################################################################################
$CHECK_ATTACHMENT_SETUP

Local Char VFNC(10) : VFNC = "HREXS"
Local Char NEWVOLUME(255)
Gosub GET_VOLUME From PRHPORATT_SOA

Return
#############################################################################################################
Funprog HAS_ATTACHMENTS(CEXP)
Value Instance CEXP Using C_EXPENSESESS
Local Integer HAS_ATT, AI

HAS_ATT = 1

For AI = 1 To maxtab(CEXP.HREXPENSES)
  If CEXP.HREXPENSES(AI) <> null and find(CEXP.HREXPENSES(AI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    If CEXP.HREXPENSES(AI).TCH_ATTACH <> AVOID.ABLOB
      HAS_ATT = 2
      Break
    Endif
  Endif
Next

End HAS_ATT


$ATTACHMENTS
If CURPTH = ""

  Local Integer MAXL, NI, STAT
  MAXL = maxtab(this.HREXPENSES)

  If MAXL > 0
    # Attachments
    Local File ABLOB [ABB4]
    Local Blbfile _ATTACH

    For NI = 1 To MAXL
      Raz _ATTACH
      If this.HREXPENSES(NI).ESSATT <> null

          Local Integer WRITESTAT, READSTAT, COLIND, I
          Local Integer INITSTAT
          Local Char CNTTYP(GLONATYP)
          Local Char FNAM(250) : FNAM = "HREXS~"+this.HREXPENSES(NI).REFNUM+"~"+num$(this.HREXPENSES(NI).EXSNUM)

          #Set default values for variables
          WRITESTAT = [V]CST_AOK
          READSTAT  = [V]CST_AOK

          #Loop through ESSATT collection
          #Check for existing record
          For COLIND = 1 To maxtab(this.HREXPENSES(NI).ESSATT)
            If find(this.HREXPENSES(NI).ESSATT(COLIND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0

              Gosub CHECK_ATTACHMENT_SETUP

              If this.HREXPENSES(NI).ESSATT(COLIND).TCH_ATT <> AVOID.ABLOB

              #Instantiate the class
              Local Instance I_HRESSATT Using C_HRESSATT
              If (I_HRESSATT <> null) : FreeGroup I_HRESSATT : Endif
              I_HRESSATT = NewInstance C_HRESSATT AllocGroup null

              INITSTAT = fmet I_HRESSATT.AINIT()

              this.HREXPENSES(NI).ESSATT(COLIND).ABREV = "EML"
              this.HREXPENSES(NI).ESSATT(COLIND).NAM = FNAM + "_" +  format$("N0:3",COLIND)
              this.HREXPENSES(NI).ESSATT(COLIND).IDENT1 = FNAM
              this.HREXPENSES(NI).ESSATT(COLIND).IDENT2 = num$(this.HREXPENSES(NI).UID)
              this.HREXPENSES(NI).ESSATT(COLIND).IDENT3 = format$("N0:3",COLIND)

              READSTAT = fmet I_HRESSATT.AREAD(this.HREXPENSES(NI).ESSATT(COLIND).ABREV,this.HREXPENSES(NI).ESSATT(COLIND).IDENT1,this.HREXPENSES(NI).ESSATT(COLIND).IDENT2,this.HREXPENSES(NI).ESSATT(
& COLIND).
& IDENT3)
              #Load values = READSTAT will only be used to determine the method to invoke    If READSTAT = [V]CST_AOK
              #Load the fields and save the class/record
              I_HRESSATT.ABREV = this.HREXPENSES(NI).ESSATT(COLIND).ABREV
              I_HRESSATT.IDENT1 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT1
              I_HRESSATT.IDENT2 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT2
              I_HRESSATT.IDENT3 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT3
              I_HRESSATT.TCH_ATT = this.HREXPENSES(NI).ESSATT(COLIND).TCH_ATT
              I_HRESSATT.NAM = this.HREXPENSES(NI).ESSATT(COLIND).NAM

              If READSTAT = [V]CST_AOK
                #Existing record
                #Invoke the update method
                WRITESTAT = fmet I_HRESSATT.AUPDATE
              Else
                #Invoke the insert method
                WRITESTAT = fmet I_HRESSATT.AINSERT
              Endif

              Local File ABLOB [ABB1]
              Read [ABB1]ABB0 =this.HREXPENSES(NI).ESSATT(COLIND).ABREV;this.HREXPENSES(NI).ESSATT(COLIND).IDENT1;this.HREXPENSES(NI).ESSATT(COLIND).IDENT2;this.HREXPENSES(NI).ESSATT(COLIND).IDENT3
              If fstat = [V]CST_AOK
                CNTTYP = [F:ABB1]CNTTYP
              Endif
              LogicClose File [ABB1]

              Local Char VID1(250)
              Local Char VID2(250)
              Local Char VID3(250)

              VID1 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT1
              VID2 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT2
              VID3 = this.HREXPENSES(NI).ESSATT(COLIND).IDENT3

              Call SETPORATT("HREXS", "EML", VID1, this.HREXPENSES(NI).ESSATT(COLIND).TCH_ATT, VID1, VID2, VID3, CNTTYP, STAT) From PRHPORATT_SOA

              FreeGroup I_HRESSATT
            Endif
          Endif

        Next I

      Endif
    Next
    LogicClose File [ABB4]
  Endif

Endif
Return

#############################################################################################################
Subprog SYNCATT(ABREV, NAM, TCH_ATT, IDENT1, IDENT2, IDENT3)

If ABREV <> AVOID.ACHAR
  Local Integer WRITESTAT, READSTAT, ASTATUS
  Local Integer INITSTAT

  #Set default values for variables
  WRITESTAT = [V]CST_AOK
  READSTAT  = [V]CST_AOK

  #Instantiate the class
  Local Instance I_HRESSATT Using C_HRESSATT
  If (I_HRESSATT <> null) : FreeGroup I_HRESSATT : Endif
  I_HRESSATT = NewInstance C_HRESSATT AllocGroup null

  INITSTAT = fmet I_HRESSATT.AINIT()

  READSTAT = fmet I_HRESSATT.AREAD(ABREV, IDENT1, IDENT2, IDENT3)
  #Load values = READSTAT will only be used to determine the method to invoke    If READSTAT = [V]CST_AOK
  #Load the fields and save the class/record
  I_HRESSATT.ABREV = ABREV
  I_HRESSATT.IDENT1 =  IDENT1
  I_HRESSATT.IDENT2 =  IDENT2
  I_HRESSATT.IDENT3 =  IDENT3
  I_HRESSATT.TCH_ATT =  TCH_ATT
  I_HRESSATT.NAM =  NAM

  If READSTAT = [V]CST_AOK
    #Existing record
    #Invoke the update method
    WRITESTAT = fmet I_HRESSATT.AUPDATE
  Else
    #Invoke the insert method
    WRITESTAT = fmet I_HRESSATT.AINSERT
  Endif
Endif

End
#############################################################################################################

$ASSIGN_ATT_ID
Local Integer NI
 For NI = 1 To maxtab(this.EXPENSES)
  If this.EXPENSES(NI).TCH_ATTACH <> AVOID.ABLOB
    #Assigning properties
    this.EXPENSES(NI).IDENT1 = "HREXS"+"~"+num$(this.EXPENSES(NI).REFNUM)+"~"+num$(this.EXPENSES(NI).EXSNUM)
    this.EXPENSES(NI).IDENT2 = num$(this.EXPENSES(NI).UID)
    this.EXPENSES(NI).IDENT3 = "001"
   Endif
  Next
Return

