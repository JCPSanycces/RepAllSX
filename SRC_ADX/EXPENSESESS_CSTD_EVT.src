############################################################################################################
$EXPENSES_ADDLINE_AFTER

#Dbgaff
If !clalev([F:FCY]): Local File FACILITY [FCY]: Endif
If !clalev([F:CPY]): Local File COMPANY  [CPY]: Endif

Call LEC_FCY(this.APARENT.ETRFCY) From CPTLEC_SOA
#Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC_SOA

For NK=1 To maxtab(this.APARENT.HEADIM)
  If this.APARENT.HEADIM(NK).DIETYP <> AVOID.ACHAR
    K = fmet this.ADDLINE("DIMCEN",NK)

    If K <> AVOID.AINT
      this.DIMCEN(K).DIE = this.APARENT.HEADIM(NK).DIETYP
      Filter [CPY] Where CPY = [F:FCY]LEGCPY & DIE = this.APARENT.HEADIM(NK).DIETYP
      For [CPY]
        this.DIMCEN(K).CCE = [CPY]CCE(NK-1)
        Break
      Next
      Filter [CPY]
#      For I=0 To dim([F:CPY]DIE)
#        If [F:CPY]DIE(I)<>AVOID.ACHAR
#          J=find([F:CPY]DIE(I-1),CEXP.HEADIM(1..maxtab(CEXP.HEADIM)).DIETYP)
#          If J > 0 & J <= 20
#            this.DIMCEN(J).CCE = [F]CCE(I-1)
#          Endif
#        Endif
#      Next
    Endif
  Endif
Next



# add header fields to expense collection line
this.REFNUM  = this.APARENT.REFNUM
this.CTRNUM  = this.APARENT.CTRNUM
this.EXSNUM  = this.APARENT.EXSNUM       #expense note number
this.STRDAT  = this.APARENT.STRDAT
this.ENDDAT  = this.APARENT.ENDDAT
this.FCY     = this.APARENT.ETRFCY
this.TCH_LEG = this.APARENT.LEG
this.TIT     = this.APARENT.TIT

Return
