Gosub CHECK_STATUS
If ASTATUS = [V]CST_AERROR
  Return
Endif

Gosub CHECK_LINES

Local Integer LASTLIN

Local File HREXPENSES[EXS1]

Filter [EXS1] Where REFNUM = this.REFNUM & EXSNUM = this.EXSNUM & CTRNUM = this.CTRNUM Order By LIN Desc
Read [EXS1] First
If fstat = CST_AOK
  LASTLIN = [F:EXS1]LIN
Endif

Gosub REFRESH_EXPENSES_DATA

LogicClose File [EXS1]

Return
############################################################################################################
$REFRESH_EXPENSES_DATA

Local Integer MAXL, NI, _UID
Local File HRTABEXPENS [HRTES2]    #V12

MAXL = maxtab(this.HREXPENSES)
For NI = 1 To MAXL
  If this.HREXPENSES(NI) <> null and find(this.HREXPENSES(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
    this.HREXPENSES(NI).REFNUM  = this.REFNUM
    this.HREXPENSES(NI).CTRNUM  = this.CTRNUM
    this.HREXPENSES(NI).EXSNUM  = this.EXSNUM       #expense note number
    this.HREXPENSES(NI).STRDAT  = this.STRDAT
    this.HREXPENSES(NI).ENDDAT  = this.ENDDAT
    this.HREXPENSES(NI).FCY     = this.ETRFCY
    this.HREXPENSES(NI).EXSSTA  = this.EXSSTA
    this.HREXPENSES(NI).TCH_LEG = this.LEG
    If this.HREXPENSES(NI).LIN = AVOID.AINT
      LASTLIN = LASTLIN+1000
      this.HREXPENSES(NI).LIN = LASTLIN
    Endif

    If this.HREXPENSES(NI).UID = AVOID.AINT
      Raz _UID
      _UID = uniqid([HRTES2])
      this.HREXPENSES(NI).UID = _UID
    Endif

  Endif
Next

LogicClose File [HRTES2]

Return
