#<AdxTL>@(#)2.0.0.0 $Revision$
################################################################
# CBO 2014.02.25 FQ97148 éclatement des zones libres montant avec suppression du masque FGR9 et tjrs utilisation du FASFZ
# CBO 2013.07.05 FQ91070 gestion de l'éclatement d'un bien via itf des mvts aaa

# le principe est d'appeler du code déjà existant :
# principalement dans SUBFAS, SUBFAS2 et TRTFASSPL et d'adapter si il faut.
#
################################################################

$TRAITE_SPLIT

    # sert au debug : donc textes à ne pas traduire dans les appels de ECR_TRACE_INTERNE
    Local Integer WTRACE_INTERNE
    WTRACE_INTERNE = 0


    GERR = 0
    Trbegin [FASS]
    Read [F:FASS]FAS0 = [F:FXM]REF1MVT
    If fstat
        GERR = 1
#        [F:FXM]DESRJTMVT = "bien non lu (" + [F:FXM]REF1MVT + ")"
        [F:FXM]DESRJTMVT = func AFNC.MES5(mess(11, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
        [F:FXM]TRACE = GTRACE
    Endif


    If GERR = 0
        Gosub SPLIT_PREPARE         # ouvertures et traitements préparatoires
        Gosub SPLIT_AFFECT_PARAM    # paramètres de l'éclatement
    Endif

    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "before SPLIT_CONTROLE1" - [F:FXM]REF1MVT)
    If GERR = 0
        Gosub SPLIT_CONTROLE1       # Call de SAIMSK dans W0FASSPL1
    Endif
    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "after SPLIT_CONTROLE1" - [F:FXM]REF1MVT)

    If GERR = 0
        Gosub SPLIT_AFFECT_FXD      # affectation du tabulaire des biens générés par l'éclatement
    Endif
    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "after SPLIT_AFFECT_FXD" - [F:FXM]REF1MVT)

    If GERR = 0
        Gosub SPLIT_CONTROLE2       # Call de SAIMSK dans W0FASSPL1 et autres contrôles
    Endif
    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "after SPLIT_CONTROLE2" - [F:FXM]REF1MVT)

    Setmode


    If GERR = 0
        Gosub SPLIT_ENREG
        FIN = 0
        Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "after SPLIT_ENREG" - [F:FXM]REF1MVT)
    Endif

    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "before Commit/rollback" - [F:FXM]REF1MVT)


# _________________________________________________________________________________

    If GERR = 0 and fstat = 0 and [M:FXT]SIMULATION = 1
        Commit
    Else
        Rollback
    Endif
# _________________________________________________________________________________


#    If 1=2 and GERR = 0 and fstat = 0 and [M:FXT]SIMULATION = 1 # recalcul du bien
    If GERR = 0 and fstat = 0 and [M:FXT]SIMULATION = 1 # recalcul du bien
        Gosub SPLIT_RECALCUL

    Endif

    Call CPTERENDUSPLIT()
    GERR = 0
Return


$SPLIT_PREPARE

Local Char WCODWIN(30), WTRTMAM(30), WTRTALIMMSK(30), WTRTGENERE(30)
Local Shortint WNREF2
Local Integer WTAB, WERRCHP, WNUMECR
Local Integer TUNNEL

    TUNNEL = 0
    Local Mask FASPARCPY [FPC]
    Gosub OUVRE From SUBFAS

    Call REFFXM([F:FXM]OBJMVT, [F:FXM]TYPMVT, WCODWIN, WTRTMAM, WTRTALIMMSK, GABVMSKMAM, WTRTGENERE) From SUBFXM

    # lecture et alimentation des masques de gestion du bien _______________________________________

    Local Mask FAS4 [FAS4]
#    If clalev([F:FIS]) =0    : Local File FISCYEAR      [FIS]    : Endif
#    Local Mask FAS0 [FAS0], FAS1 [FAS1], FAS2 [FAS2], FAS3 [FAS3], FAS4 [FAS4]
    If WNKAS9 = G_OUI
        Local Mask KAS9 [KAS9]
    Endif
    If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
        Local Mask FAS5 [FAS5]
    Endif
    If G_ACTCCN = G_OUI
        Local Mask FAS6 [FAS6]
    Endif

    Local Mask FASFZ9 [FAS9], FAS8 [FAS8]


    GSPLBASVFRCE = 0
    [M:FAS0] = [F:FASS]
    [M:FAS1] = [F:FASS]
    [M:FAS2] = [F:FASS]
    [M:FAS3] = [F:FASS]

  # Valeur bilan PCG = Valeur d'entrée HT PCG + TVA facturée PCG - TVA récupérée PCG
  [M:FAS1]ACGBSEVAL = [M:FAS1]ACGETRNOT + [M:FAS1]IVCVATAMT - [M:FAS1]DEDVATAMT

  # Valeur bilan PCG = Valeur d'entrée HT PCG + TVA facturée PCG - TVA récupérée PCG
  [M:FAS1]IASBSEVAL = [M:FAS1]IASETRNOT + [M:FAS1]IVCVATAMTI - [M:FAS1]DEDVATAMTI

    Gosub INIT_PLAN_AMT From SUBFAS
    Gosub LOAD_PLAN_AMT From SUBFAS

    [M:FAS4] = [F:FASS]
    If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
        [M:FAS5] = [F:FASS]
    Endif
    If G_ACTCCN = G_OUI
        [M:FAS6] = [F:FASS]
    Endif

    [M:FAS9] = [F:FASS]
    [M:FAS8] = [F:FASS]
    If WNKAS9 = G_OUI
        [M:KAS9] = [F:FASS]
    Endif

    Gosub VARMODEECR From FXDINT
Return

$SPLIT_AFFECT_PARAM

    # paramètres de l'éclatement
    # alimentation des champs des masques d'éclatement_______________________________________
    # à partir de ceux de gestion du bien

    [M:OAC0]OBJREF = [F:FXM]REF1MVT
    GERR = 0
    Gosub INIT  From TRTFASSPL
    Gosub OUVRE From TRTFASSPL
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        [F:FXM]TRACE = GTRACE
        GMESSAGE = ""
        FIN = 0
        Return
    Endif
    Gosub DEBUT From TRTFASSPL


    # affectation des champs 1 _______________________________________
    # de paramétrage

    WNUMECR = 1 # n'affectera que les champs de paramétrage
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    WERRCHP = 0
    Call ALIMCHP(WERRCHP, WNUMECR) From FXDINT
    If GERR
        # alimchp incrémente mais refait en CPTERENDU pour ts les types de contrôle
        GFXDNBERR -= 1
        Return
    Endif

#    [F:FXM]TRACE = GTRACE

    GPOINT="FXD_APRES_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

Return

$SPLIT_CONTROLE1

    # Contrôle de ces champs _______________________________________

    # 1°) boutons devenant non actifs ($SETBOUT) transformés ici en contrôle

    If [M:FASE]NBFAS <= 0 and [M:FASE]SPLBAS <> GVML_TECLQTY
        # On ne peut pas éclater si on ne sait pas en combien
#        [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
        [F:FXM]DESRJTMVT = "NBFAS ou MVTTYP" - [F:FXM]REF1MVT
        [F:FXM]TRACE = GTRACE
        GERR = 1
        Return
    Endif

    If GREPART_VIA_QTY = G_OUI
        If [M:FASE]SPLBAS <>  GVML_TECLQTY
            # On ne peut pas Répartir si le tableau est vide ou si la base de répartition
            # est de type dépense
            GREPART_VIA_QTY += 1
        Endif

        If G_HASELT = G_OUI
            If [M:FASE]SPLELT <> 1 or [M:FASE]NBFAS = [M:FASE]QTYBEF or GQTE_ELT = G_NON
                # On ne peut pas répartir si le tableau est vide ou si le type d'éclatement est dépense ou mouvement
                # ou que le nombre de bien généré est égale à la quantité d'élément physique rattachée ou qu'on ne gere pas la qté
                GREPART_VIA_QTY += 1
            Endif
        Endif
        If GREPART_VIA_QTY > G_OUI
    #        [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
            [F:FXM]DESRJTMVT = "Répartition des montants par quantité impossible" - [F:FXM]REF1MVT
            [F:FXM]TRACE = GTRACE
            GERR = 1
            Return
        Endif
    Endif
    # _________________________________________________________________


    Local Integer SV_ERR_TRACE
    Default Mask [M:FASE]

    GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
    SV_ERR_TRACE = GERRTRACE


    If G_HASELT=G_OUI
        Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL1B
    Else
        Default Mask [M:FASE]
        Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL1
    Endif
    If SV_ERR_TRACE <> GERRTRACE
        GERR = 2 # le message est écrit par W0FASSPL1
        If [F:FXM]DESRJTMVT = ""
            [F:FXM]DESRJTMVT = GMESSAGE
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
            Endif
        Endif
        GIMPORT = 0
        Return
    Endif

    Call CTLVARMODE(GFXDNBERR) From FXDINT
    GIMPORT = 0

    If GFXDERRALCHP
        GERR = 1
        # alimchp incrémente mais refait en CPTERENDU pour ts les types de contrôle
        GFXDNBERR -= 1

        If [F:FXM]DESRJTMVT = ""
            [F:FXM]DESRJTMVT = GMESSAGE
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
            Endif
        Endif
        Return
    Endif

Return

$SPLIT_AFFECT_FXD

    # affectation du tabulaire des biens générés par l'éclatement
    # _________________________________________________________________

    # création du tableau des biens générés
    # attention : éclaté en 3 veut dire 2 biens créés

    # vient de $BOUTON
    If G_HASELT=G_NON
        Call CALCUL_ECLATEMENT ( ) From TRTFASSPL # Eclatement "classique" d'un bien sans élt phy
    Else
        Gosub CLEAR_TMPFASPHY  From TRTFASSPL
        Case [M:FASE]SPLELT
        When GVMLTECLELT   # ELEMENT PHYSIQUE
            If [M:FASE]NBFAS <> [M:OCP1]NBELT
                Call CALCUL_ECLATEMENT_PHY2() From TRTFASSPL # Eclatement X biens Y éléments
            Else
                Call CALCUL_ECLATEMENT_PHY() From TRTFASSPL  # éclatement 1 élément par bien
            Endif
        When GVMLTECLMVT
            Call CALCUL_ECLATEMENT_PHY() From TRTFASSPL
        When GVMLTECLDEP
            Call CALCUL_ECLATEMENT_DEP_PHY() From TRTFASSPL
        Endcase
    Endif

    WNUMECR = 2 # affectera les champs des biens créés
    GPOINT="FXD_AVANT_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    WERRCHP = 0
    Call ALIMCHP(WERRCHP, WNUMECR) From FXDINT
    If GERR
        Return
    Endif

    Gosub CTRL_INDICE
    If GERR
        Return
    Endif
    # alimchp incrémente mais refait en CPTERENDU pour ts les types de contrôle
#        GFXDNBERR -= 1
#    [F:FXM]TRACE = GTRACE

    # Point d'entrée
    GPOINT="FXD_APRES_CHP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC

    If [M:FASE]SPLBAS = GVML_TECLQTY and GREPART_VIA_QTY = G_OUI
        Call REPARTIR_MONTANT () From TRTFASSPL
    Endif
Return

$CTRL_INDICE

# Vérifier si on n'a pas paramétré un indice > au nb de biens créés
Local Integer IFASE, J, K, L

    For IFASE = 1 To GNBRUBALIM
        J = instr(1, GRUBALIM(IFASE), "(")
        If J
            K = instr(J, GRUBALIM(IFASE), ")")
            If K
                L = val(mid$(GRUBALIM(IFASE), J + 1, K - J - 1))
                If L >= [M:FASE]NBFAS
#                    [F:FXM]DESRJTMVT = "Indice $1$, pour la rubrique $2$, supérieur au nombre de biens créés ($3$)"
                    [F:FXM]DESRJTMVT = func AFNC.MES5(mess(41, GML_IMPFXD, 1), num$(L), GRUBALIM(IFASE), num$([M:FASE]NBFAS - 1), "", "")
                    [F:FXM]TRACE = GTRACE
                    GERR = 1
                    Break
                Endif
            Endif
        Endif
    Next IFASE

Return

$SPLIT_CONTROLE2

    # Call de SAIMSK dans W0FASSPL1 et autres contrôles (pour tous les champs)
    # _________________________________________________________________


    Local Integer SV_ERR_TRACE
    Default Mask [M:FASE]
#
# si il y a des dépenses : ajouter
# Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL2
# si il y a des éléments physiques : ajouter
# Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL3
#
# et traiter les champs concernés dans $IMP_MVT de TRTFASSPL

    GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
    SV_ERR_TRACE = GERRTRACE
    If G_HASELT = G_OUI
        Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL1B
        If SV_ERR_TRACE = GERRTRACE and [M:FASE]SPLELT = 3
            Default Mask [M:OCP]
            Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL2
        Endif

        If SV_ERR_TRACE = GERRTRACE
            Default Mask [M:OCP1]
            Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL3
        Endif

    Else

        Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL1

        If SV_ERR_TRACE = GERRTRACE and [M:FASE]SPLBAS = 3
            Default Mask [M:OCP]
            Call SAIMSK("", "IMP_MVT", "TRTFASSPL") From W0FASSPL2
        Endif

    Endif
    If SV_ERR_TRACE <> GERRTRACE
        GERR = 2 # le message est écrit par W0FASSPL1
        If [F:FXM]DESRJTMVT = ""
            [F:FXM]DESRJTMVT = GMESSAGE
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
            Endif
        Endif
        GIMPORT = 0
        Return
    Endif

    Call CTLVARMODE(GFXDNBERR) From FXDINT
    GIMPORT = 0

    If GFXDERRALCHP
        GERR = 1
        If [F:FXM]DESRJTMVT = ""
            [F:FXM]DESRJTMVT = GMESSAGE
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
            Endif
        Endif
        Return
    Endif

#    If [M:FASE]PRCFLG = G_OUI
#        Call CALCUL_SOLDE ( ) From TRTFASSPL
#    Endif

    # contrôle des champs _______________________________________
    # des biens générés

    Gosub AVANT_OK From TRTFASSPL
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif

Return


$SPLIT_ENREG

    # création des biens générés _______________________________________

    Gosub OK From TRTFASSPL

# si pas de dépenses liées on mets une valeur bidon ("XXX") dans la 1ère ligne
# du tableau des dépenses liées afin de forcer la passage par le $MAJ_LNK
# dans lequel on fait toutes les mises à  jour

    If dim([M:OCP]NBOBJ)>0
       If [M:OCP]NBOBJ = 0
          [M:OCP]OBJREF(0) = "XXX"
          [M:OCP]NBOBJ = 1
       Endif
    Endif

    G_ARECALCULER = 1
    Read [FAS]FAS0=[M:FAS0]AASREF
    Gosub MAJ_LNK From TRTFASSPL
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif


    # enregistrement du bien éclaté _______________________________________

    G_ARECALCULER = 1
    Gosub VERIF_MOD From SUBFAS2
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif
    Local Integer     ERROR
    If GPHY = G_OUI Then
        If clalev([F:PHYT]) = 0
            Local File PHYELT [PHYT]
        Endif
    Endif

    Gosub AVANT_MODFIC From SUBFAS2
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif

    Gosub INIMOD From SUBFAS2
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif

    Gosub MODIF From SUBFAS2
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
        Return
    Endif


#Call VISUM("FASSPL1") From SUBAMK

    [F:FASS] = [M:FAS0]
    [F:FASS] = [M:FAS1]
    [F:FASS] = [M:FAS2]
    [F:FASS] = [M:FAS3]
    [F:FASS] = [M:FAS4]
    If (dim(GKFR) >= 0 and GKFR = G_OUI) or dim(GKFR) < 0
        [F:FASS] = [M:FAS5]
    Endif
    If G_ACTCCN = G_OUI
        [F:FASS] = [M:FAS6]
    Endif

    [F:FASS] = [M:FAS9]
    [F:FASS] = [M:FAS8]
    If WNKAS9 = G_OUI
        [F:FASS] = [M:KAS9]
    Endif

    [F:FXM]TRACE = GTRACE
    Rewrite [F:FASS]

    If fstat
        [F:FXM]DESRJTMVT = func AFNC.MES5(mess(16, GML_IMPFXD, 1), [F:FXM]REF1MVT, "", "", "", "")
#            [F:FXM]DESRJTMVT = "Echec en Maj de" - [F:FXM]REF1MVT
        [F:FXM]TRACE = GTRACE
        GERR = 1
    Endif

Return

$SPLIT_RECALCUL

    # recalcul des amortissements _______________________________________

Local Integer TYPGES, WERRCHP
TYPGES = 2
Local Char PROGOBJ(30)
PROGOBJ = "WOFAS"

    Call ECR_TRACE_INTERNE(WTRACE_INTERNE, "before SPLIT_RECALCUL" - [F:FXM]REF1MVT)

#    Gosub APRES_MOD From SUBFAS2
    If !GIMPORT
        # Recalcul forcé
        If  ( G_ARECALCULER = 1 ) Then
            G_ARECALCULER   = 0
            ACALCULER = num$(G_OUI)
        Endif


        #> Chargement du masque de travail contenant le paramétrage comptable de la société
        Local Mask FASPARCPY [FPC]
        Call LOAD_FASPARCPY([F:FASS]CPY, "", G_NON, WERRCHP) From GLOFCYCPY


        GIMPORT = 1 # ne pas afficher le CR du calcul
        Gosub CALCUL_BIEN From SUBFAS
        ACALCULER = ""
    Endif
    If GERR
        [F:FXM]DESRJTMVT = GMESSAGE
    Endif
    GIMPORT = 0

Return


#** Compte-rendu adapté à l'éclatement
#*  (liste des biens créés et des éléments physiques si il y a lieu)
#*
#*!
Subprog CPTERENDUSPLIT()

Local Integer I, WBDEP
Local Char WRES(100), WECARTPHY(10)

    WECARTPHY = "  " # indentation dans le CR
    WRES =  "-->"
    If GERR
        WRES -= mess(30, GML_IMPFXD, 1)
    Else
        WRES -= mess(29, GML_IMPFXD, 1)
    Endif

    If GERR = 1 # si 2, le message est écrit par W0FASSPL1 quand GERR = 2
        Call ECR_TRACE([F:FXM]DESRJTMVT, 1) From GESECRAN
        GERR = 1
        GFXDNBERR += 1
    Elsif GERR = 2
        GFXDNBERR += 1
    Endif
    If GCRDET = 2
        Call CRDET() From FXDINT
    Endif

    Call ECR_TRACE(WRES, 0) From GESECRAN

    # Détail de l'éclatement
    If GERR = 0
        WRES  = func AFFCHP(52, "-->" - mess(39, GML_IMPFXD, 1) - ":", 0, 0)
        WRES += func AFFCHP(15, mess(50, 104, 1), 0, 2)
        WRES += func AFFCHP(10, mess(33, 105, 1), 0, 2)
        If G_HASELT=G_OUI
            WRES += WECARTPHY + func AFFCHP(30, mess(6, 3141, 1), 0, 0)
        Endif
        Call ECR_TRACE(WRES, 0) From GESECRAN

        # Code + dési : tronqués
        WRES  = "    " + func AFFCHP(40, left$([F:FASS]AASREF - "/" - [F:FASS]AASDES1, 38), 0, 0)
        WRES += func AFFCHP(8, mess(37, GML_IMPFXD, 1), 0, 0)
        WRES += func AFFCHP(15, num$([M:FASE]SPLAMTBEF), 0, 1)
        WRES += func AFFCHP(10, num$([M:FASE]QTYBEF), 0, 1)
        Call ECR_TRACE(WRES, 0) From GESECRAN

        WRES  = "    " + func AFFCHP(40, "", 0, 0)
        WRES += func AFFCHP(8, mess(38, GML_IMPFXD, 1), 0, 0)
        WRES += func AFFCHP(15, num$([M:FASE]SPLAMTAFT), 0, 1)
        WRES += func AFFCHP(10, num$([M:FASE]QTYAFT), 0, 1)
        If G_HASELT=G_OUI
            WRES += WECARTPHY + func AFFCHP(30, [M:OCP1]PHYREFDEB([M:OCP1]NBELT - 1), 0, 0)
        Endif
        Call ECR_TRACE(WRES, 0) From GESECRAN

        # FQ92254
        If [M:FASE]LOFSPLFLG = G_OUI
            If clalev([F:LOF])  = 0
                Local File LAYOUTFAS   [LOF]
            Endif

            WBDEP = 0
            For [LOF] Where AASREF = [F:FASS]AASREF
                If WBDEP = 0
                    Call ECR_TRACE("     " + func AFFCHP(30, mess(44, GML_IMPFXD, 1) - ":", 0, 0), 0) From GESECRAN
                    WBDEP = 1
                Endif
                WRES  = "      " + func AFFCHP(40, [F:LOF]CODLOF - num$([F:LOF]LINLOF) - "/" - [F:LOF]DES, 0, 0)
                Call ECR_TRACE(WRES, 0) From GESECRAN
            Next
            Filter [LOF]
        Endif


        Call ECR_TRACE("-->" - mess(40, GML_IMPFXD, 1) - ":", 0) From GESECRAN
        For I = 0 To [M:FASE]NBFAS - 2
            WRES  = "    " + func AFFCHP(48, left$([M:FASE]AASREF(I) - "/" - [M:FASE]AASDES1(I), 46), 0, 0)
            WRES += func AFFCHP(15, num$([M:FASE]SPLAMT(I)), 0, 1)
            WRES += func AFFCHP(10, num$([M:FASE]AASQTY(I)), 0, 1)
            If G_HASELT=G_OUI
                WRES += WECARTPHY + func AFFCHP(30, [M:OCP1]PHYREFDEB(I), 0, 0)
            Endif
            Call ECR_TRACE(WRES, 0) From GESECRAN

            # FQ92254
            If [M:FASE]LOFSPLFLG = G_OUI
                WBDEP = 0
                For [LOF] Where AASREF = [M:FASE]AASREF(I)
                    If WBDEP = 0
                        Call ECR_TRACE("      " + func AFFCHP(30, mess(45, GML_IMPFXD, 1) - ":", 0, 0), 0) From GESECRAN
                        WBDEP = 1
                    Endif
                    WRES  = "      " + func AFFCHP(40, [F:LOF]CODLOF - num$([F:LOF]LINLOF) - "/" - [F:LOF]DES, 0, 0)
                    Call ECR_TRACE(WRES, 0) From GESECRAN
                Next
                Filter [LOF]
            Endif
        Next I
    Endif
End


#** formattage d'1 champ à éditer
#*
#*
#* @param PLEN_COL    longueur voulue (complétée par des blancs ou  tronquée)
#* @param PCHP        champ à éditer
#* @param PPASZERO    booléen : ne rien afficher si le champ est à 0 (ou vide)
#* @param PBCOLNUM    0 : alpha cadrée à gauche
#*                    1 : num cadrée à droite
#*                    2 : alpha cadrée à droite
#*!
Funprog AFFCHP(PLEN_COL, PCHP, PPASZERO, PBCOLNUM)
Value Integer PLEN_COL
Value Char PCHP()
Value Integer PPASZERO, PBCOLNUM # 1 col num  2 col alpha à cadrer à droite

    Local Integer LG, LG2

    If (PPASZERO and PCHP = "0") or PCHP = ""
        End string$(PLEN_COL, " ")
    Endif

    # cadrage à droite d'1 alpha
    LG = len(PCHP)
    If PBCOLNUM = 2
        End string$(PLEN_COL - LG, " ") + left$(PCHP, LG)
    Endif


    If LG > 2
        If PBCOLNUM = 1
            If mid$(PCHP, LG -2, 1) = "," or  mid$(PCHP, LG -2, 1) = "."
                LG += 0
            Elsif mid$(PCHP, LG -1, 1) = "," or  mid$(PCHP, LG -1, 1) = "."
                PCHP += "0"
                LG += 1
            Else
                PCHP += ".00"
                LG += 3
            Endif
        Endif
    Elsif LG > 0 and PBCOLNUM = 1
        PCHP += ".00"
        LG += 3
    Endif


    LG2 = PLEN_COL - LG
    If LG2 > 0
        If PBCOLNUM = 1
            End string$(LG2, " ") + left$(PCHP, LG)
        Else
            End PCHP + string$(LG2, " ")
        Endif
    Endif
End left$(PCHP, PLEN_COL)


#** trace interne pour aide à la maj :
#* pour l'activer passer (en début de traitement) WTRACE_INTERNE de 0 à 1
#*
#* @param PTRACE_INTERNE  booléen conditionnant la trace
#* @param PTEXTE          texte à éditer
#*!
Subprog ECR_TRACE_INTERNE(PTRACE_INTERNE, PTEXTE)
Value Integer PTRACE_INTERNE
Value Char PTEXTE()

    If PTRACE_INTERNE
        If GERR
            Call ECR_TRACE(PTEXTE - ": with" - num$(GFXDNBERR) - "error(s)     X_X_X_X_X", 0) From GESECRAN
        Else
            Call ECR_TRACE(PTEXTE, 0) From GESECRAN
        Endif
    Endif
End
