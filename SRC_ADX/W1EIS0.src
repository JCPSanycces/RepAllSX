#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EIS0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:07"
A_USER  = "DOC"
A_STAMP = "20181109230407"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EIS0 [EIS0]
Gosub HORODAT
Local Inpbox "EIS0" From GFONCTION At A_STAMP With A_WINDPREV Mask [EIS0] As [SIM_]
Grizo [EIS0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EIS0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=7
Return

$ON_CATTYP
Onevent INIT_AREA Call D_CATTYP(zc) From W1EIS0
Return

Subprog D_CATTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CATTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PARCOD
Onevent CONTROL Call C_PARCOD(zc) From W1EIS0
Onevent BEFORE_INPUT Call AS_PARCOD(zc) From W1EIS0
Return

Subprog AS_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PARCOD(zc) From W1EIS0
Onkey 144 Titled GBOUTP Call P_PARCOD(zc) From W1EIS0
Onkey 146 Titled GBOUTA Call SA_PARCOD(zc) From W1EIS0
Gosub _AFF
End

Subprog C_PARCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 52054 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("EPR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PARCOD" : GZNUM = 52054 : Endif
Endif
Gosub _AFF
End

Subprog S_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "EPR"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EPR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PARCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EPR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CATACT
Onevent INIT_AREA Call D_CATACT(zc) From W1EIS0
Return

Subprog D_CATACT(VALEUR)
Variable Integer VALEUR
If varinit([M]CATACT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CATOPE
Onevent INIT_AREA Call D_CATOPE(zc) From W1EIS0
Return

Subprog D_CATOPE(VALEUR)
Variable Integer VALEUR
If varinit([M]CATOPE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_TESTFLG
Onevent INIT_AREA Call D_TESTFLG(zc) From W1EIS0
Onevent BEFORE_INPUT Call AS_TESTFLG(zc) From W1EIS0
Return

Subprog D_TESTFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]TESTFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TESTFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DUPLICATEFLG
Onevent INIT_AREA Call D_DUPLICATEFLG(zc) From W1EIS0
Onevent BEFORE_INPUT Call AS_DUPLICATEFLG(zc) From W1EIS0
Return

Subprog D_DUPLICATEFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]DUPLICATEFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DUPLICATEFLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


