######################################################################################
## Xtend - Utilitaires de gestion de l'arborescence des sites Xtend
#
#  Funprog GETPATH(MAC,DOSNAM,TYP,LANG,FCYCOD, PAR1)   # Obtenir un emplacement Xtend 
#
###    Arborescence principale Xtend
# Subprog DIRXTVER  (MAC, DOSNAM, RET)     # Vérification
# Subprog DIRXTUPD  (MAC, DOSNAM, RET)     # Mise à jour
# Subprog DIRXTUNIX (MAC, DOSNAM, RET)     # Droit sous unix racine xtend
# Subprog DIRXTDEL  (MAC, DOSNAM, RET)     # Suppression
#    
###    Arborescence d'un site 
# Subprog DIRFCYVER   (MAC, DOSNAM, FCYCOD, LAN, RET)          # Vérification 
# Subprog DIRFCYUPD   (MAC, DOSNAM, FCYCOD, LAN, DIRLAN, RET)  # Mise à jour
# Subprog DIRFCYUNIX  (MAC, DOSNAM, FCYCOD, RET)               # Droit sous unix site xtend
# Subprog DIRFCYDEL   (MAC, DOSNAM, FCYCOD, RET)               # Suppression
# Subprog DIRFCYTAR   (MAC, DOSNAM, FCYCOD, TARNAM, RET)       # Création tar
# Subprog DIRFCYDETAR (MAC, DOSNAM, FCYCOD, TARNAM, RET)       # Création arborescence à partir du tar 
# Subprog DIRFCYSUPTAR(MAC, DOSNAM, FCYCOD, TARNAM, RET)       # Suppression tar
# Subprog TARNAMFMT   (TARNAM,TARNAMFMT, RET)                  # Format et vérifie le nom du tar
#
# Nota: 
#    MAC    "", sodiax01:5000    Serveur
#    DOSNAM XTEND                Nom du dossier
#    FCYCOD                      Code site Xtend   
#    RET    1 Ok sinon RET=0     Code retour
######################################################################################

######################################################################################
###    Arborescence principale Xtend
######################################################################################
# $$$$
Subprog DIRXTVER(MAC, DOSNAM, RET)  # Vérification
Value Char MAC,DOSNAM
Variable Integer RET
Local Char WREPI (250), WREP (250)
Local Integer WI
RET=1
Call ECR_TRACE(mess(151,7900,1),0) From GESECRAN 
Local Char TYPOS,DIRSEP,APPLI(10)
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

Gosub DIRXTTAB
For WI=1 To NBDIRTAB
    WREPI=DIRTAB(WI) : Gosub DIRVER
Next
End

$DIRXTTAB
Local Integer NBDIRTAB
Local Char DIRTAB(250)(1..10)
NBDIRTAB=0
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)="X_TEND"
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_TAR"
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_FILES"   # Fichiers ressources externes à Xtend de maj rares
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_FILAPP"  # Fichiers ressources externes à Xtend de maj fréquentes
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"
NBDIRTAB+=1 : DIRTAB(NBDIRTAB)=DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+"X_ALL"
Return

$DIRVER
WREP=filpath(WREPI,"","",APPLI,"",MAC)   
Call ECR_TRACE("|"+mess(14,7900,1)-WREP,0) From GESECRAN     
If  filinfo(WREP,0) < 0 
    Call ECR_TRACE("|"+mess(86,133,1)-WREP,1) From GESECRAN     
    RET=0
Endif
Return
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
Subprog DIRXTUPD(MAC, DOSNAM, RET)  # UPDrication
Value Char MAC,DOSNAM
Variable Integer RET
Local Char WREPI (250), WREP (250), WREP2(250)
Local Integer WPOS
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Call ECR_TRACE(mess(150,7900,1),0) From GESECRAN 
Local Char TYPOS,DIRSEP,APPLI(10)
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

Gosub DIRXTTAB
For WI=1 To NBDIRTAB
    WREPI=DIRTAB(WI) : Gosub DIRCRE
Next
End

End

$DIRCRE
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
If  filinfo(WREP,0) < 0 
 WPOS = instr(1,WREP,"@")
 If WPOS <>0 : WREP2= right$(WREP,WPOS +1) : Else : WREP2=WREP : Endif
 Call ECR_TRACE("|"+mess(11,125,1)-WREP,0) From GESECRAN     
 ORDRE="ae_mkdir "+WREP2
 Call SYSTEME(MAC,ORDRE,OPT,STAT) From ORDSYS
 If  filinfo(WREP,0) < 0 
    Call ECR_TRACE("|"+mess(221,133,1)-WREP,1) From GESECRAN     
    RET=0 : End
 Endif
Else
 Call ECR_TRACE("|"+mess(220,133,1)-WREP,0) From GESECRAN     
Endif
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRXTUNIX(MAC, DOSNAM, RET)      # Droit sous unix racine xtend
Value Char MAC,DOSNAM
Variable Integer RET
Local Char WREPI (250), WREP(250), WREP2(250)
Local Integer WPOS
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Local Char TYPOS,DIRSEP,APPLI(10)
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

If toupper(TYPOS)<>"DOS"
  Call ECR_TRACE(mess(24,7900,1),0) From GESECRAN     
  # Racines xtend
    Gosub DIRXTTAB
    For WI=1 To NBDIRTAB
        WREPI=DIRTAB(WI) : Gosub CHMOD
    Next
Endif
End

$CHMOD
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
WPOS = instr(1,WREP,"@")
If WPOS <>0 : WREP2= right$(WREP,WPOS +1) : Else : WREP2=WREP : Endif
ORDRE="chmod -R 777 "+WREP2
Call SYSTEME(MAC,ORDRE,OPT,STAT) From ORDSYS
Return

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRXTDEL(MAC, DOSNAM, RET)  # Suppression
Value Char MAC,DOSNAM
Variable Integer RET
Local Char WREPI (250), WREP (250), WREP2(250)
Local Integer WPOS, WLANNB
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Local Char TYPOS,DIRSEP,APPLI(10)
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

# Racine xtend communes aux dossiers
WREPI = "X_TEND"
Gosub DIRDEL
# Racine xtend par dossier
WREPI = DOSNAM+DIRSEP+"X_TEND"
Gosub DIRDEL
End

$DIRDEL
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
Call ECR_TRACE("|"+mess(7,7900,1)-WREP,0) From GESECRAN     
WPOS = instr(1,WREP,"@")
If WPOS <>0 : WREP2= right$(WREP,WPOS +1) : Else : WREP2=WREP : Endif
ORDRE="ae_rmdir "+WREP2
#Infbox "ae_rmdir "+WREP2
#           On fait plusieurs fois le delete pour corriger un pb détecté en envt Windows
For WI=1 To 3
 Call SYSTEME(MAC,ORDRE,OPT,STAT) From ORDSYS
Next
#
If  !(filinfo(WREP,0) < 0 )
    Call ECR_TRACE("|"+mess(8,7900,1)-WREP,1) From GESECRAN     
    RET=0 : End
Endif
Return


######################################################################################
###    Arborescence d'un site 
######################################################################################
# $$$$
Subprog DIRFCYVER(MAC,DOSNAM,FCYCOD,LAN,DIRLAN,RET)          # Vérification d'un site
Value Char MAC,DOSNAM,FCYCOD, LAN()(1..)                 # LAN: liste des langues
Value Integer DIRLAN
Variable Integer RET
Local Char WREPI (250), WREP (250)
Local Integer WI,WPOS, WLANNB 
RET=1

Local Char TYPOS, DIRSEP,APPLI(10)
If vireblc(FCYCOD,2)="" : Call ECR_TRACE(mess(11,7900,1)-mess(148,7900,1),1) From GESECRAN : RET=0 : End : Endif 
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

Call DIRXTVER(MAC,DOSNAM,RET)

Call ECR_TRACE(mess(11,7900,1)-FCYCOD,0) From GESECRAN 

WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+FCYCOD
Gosub DIRVER
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
Gosub DIRVER
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+"X_ALL"
Gosub DIRVER

If DIRLAN=2
 WLANNB=1
 While ( WLANNB<= dim(LAN) & LAN(WLANNB)<>"" )
  WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD+DIRSEP+LAN(WLANNB)
  Gosub DIRVER
  WLANNB+=1
 Wend
Endif
End


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYUPD(MAC, DOSNAM, FCYCOD, LAN,DIRLAN, RET)  # UPDate
Value Char MAC,DOSNAM, LAN()(1..)                 # LAN: liste des langues
Value Integer DIRLAN : # gestion des dossier langue ou non
Variable Integer RET
Local Char WREPI (250), WREP (250), WREP2(250)
Local Integer WPOS, WLANNB
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Call ECR_TRACE(mess(10,7900,1)-FCYCOD,0) From GESECRAN 

Local Char TYPOS,DIRSEP,APPLI(10)
If vireblc(FCYCOD,2)="" : Call ECR_TRACE(mess(10,7900,1)-mess(148,7900,1),1) From GESECRAN : RET=0 : End : Endif 
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+FCYCOD
Gosub DIRCRE
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
Gosub DIRCRE
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+"X_ALL"
Gosub DIRCRE

If DIRLAN=2
 WLANNB=1
 While ( WLANNB<= dim(LAN) & LAN(WLANNB)<>"" )
  WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD+DIRSEP+LAN(WLANNB)
  Gosub DIRCRE
  WLANNB+=1
 Wend
Endif
End


# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYUNIX(MAC, DOSNAM, FCYCOD, RET)      # Droit sous unix site xtend
Value Char MAC,DOSNAM
Variable Integer RET
Local Char WREPI (250), WREP (250), WREP2 (250)
Local Integer WPOS, RET
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Local Char TYPOS, DIRSEP,APPLI(10)
If vireblc(FCYCOD,2)="" : Call ECR_TRACE(mess(25,7900,1)-mess(148,7900,1),1) From GESECRAN : RET=0 : End : Endif 
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

If toupper(TYPOS)<>"DOS"
  # racine Xtend  
    Call DIRXTUNIX(MAC, DOSNAM, RET)
  # Racines site Xtend
    Call ECR_TRACE(mess(25,7900,1)-FCYCOD,0) From GESECRAN     
    WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
    For indice=1 To 10  # pb niveau
        Gosub CHMOD
    Next indice
    WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+FCYCOD
    Gosub CHMOD
    WREPI = "X_TEND"+DIRSEP+DOSNAM
Endif

End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYDEL(MAC, DOSNAM, FCYCOD, RET)  # Suppression
Value Char MAC,DOSNAM                   
Variable Integer RET
Local Char WREPI (250), WREP (250), WREP2(250)
Local Integer WPOS, WLANNB
Local Char TYPOS,DIRSEP,APPLI(10)
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
If vireblc(FCYCOD,2)="" : Call ECR_TRACE(mess(12,7900,1)-mess(148,7900,1),1) From GESECRAN : RET=0 : End : Endif 
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
Gosub DIRDEL
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+FCYCOD
Gosub DIRDEL
End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYTAR   (MAC, DOSNAM, FCYCOD, TARNAM, RET)       # Création tar 
Value Char MAC,DOSNAM, FCYCOD, TARNAM                  
Variable Integer RET

Local Char WREPI(250), WREP(250), WREPFCY(250), WREPTARREL(250), WREPCMD(250)
Local Char WFILTARREL(250), WFILTARFULL(250), WFILCMD(250), WTARNAM(20)
Local Char WSTR(250), WSTR1(250)
Local Integer WPOS
Local Char TYPOS,DIRSEP,APPLI(10)
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1

Call ECR_TRACE(mess(30,7900,1)-TARNAM-"-"-mess(1,7900,1)-FCYCOD-"("-DOSNAM-")",0) From GESECRAN
If vireblc(FCYCOD,2)="" : Call ECR_TRACE(mess(30,7900,1)-mess(148,7900,1),1) From GESECRAN : RET=0 : End : Endif 
#
TARNAM=vireblc(TARNAM,2)
If TARNAM=""
    Call ECR_TRACE(mess(155,7900,1),1) From GESECRAN     
    RET=0 : Goto FCYDETAR_FIN
Endif

Call TARNAMFMT(TARNAM,WTARNAM)   # mise en forme

Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

# Répertoire site
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
If  filinfo(WREP,0) >= 0 
 WPOS = instr(1,WREP,"@")
 If WPOS <>0 : WREPFCY= right$(WREP,WPOS +1) : Else : WREPFCY=WREP : Endif
Else
 Call ECR_TRACE("|"+mess(86,133,1)-WREP,1) From GESECRAN     
  RET=0 : Goto FCYTAR_FIN
Endif

# Emplacement tar
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_TAR"
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
If  filinfo(WREP,0) >= 0
  # En relatif / site 
  WREPTARREL=".."+DIRSEP+".."+DIRSEP+"X_TAR"
  WFILTARREL=WREPTARREL+DIRSEP+WTARNAM
  WFILTARFULL=WREP+DIRSEP+WTARNAM
Else
  Call ECR_TRACE("|"+mess(86,133,1)-WREP,0) From GESECRAN     
  RET=0 : Goto FCYTAR_FIN
Endif 

# Suppression tar
Call DIRFCYSUPTAR(MAC, DOSNAM, FCYCOD, WTARNAM, RET) From AYTGESFILE

# Création fichier de commande
WREPCMD = filpath(DOSNAM+DIRSEP+"TMP","","",APPLI,"",MAC)
WFILCMD =WREPCMD+DIRSEP+"AYTTAR"+num$(adxuid(1))+"_"+num$(time)+".CMD"
Openo WFILCMD,0 Using [CMD_]
Iomode adxifs "" Using [CMD_]
Iomode adxirs chr$(10) Using [CMD_]
Iomode adxium GASCII Using [CMD_]
If toupper(TYPOS)="DOS"
    WPOS = instr(1,WFILTARFULL,":")
    If WPOS <> 0 
        WSTR = left$(WFILTARFULL,WPOS)          : Wrseq WSTR Using [CMD_]
    Else
         Call ECR_TRACE("Error- Disk letter not found in:"-WFILTARFULL,1) From GESECRAN     
         RET=0 : : Goto FCYTAR_FIN
    Endif
    WSTR='cd "'+WREPFCY+'"'                     : Wrseq WSTR Using [CMD_]
    WSTR='7za.exe a -r -y "'+WFILTARREL+'"'     : Wrseq WSTR Using [CMD_]
Else
    WSTR="cd "+WREPFCY                          : Wrseq WSTR Using [CMD_]
    WSTR="tar -f"+WFILTARREL-"-cv ."            : Wrseq WSTR Using [CMD_]
Endif
Openo Using [CMD_]

# Tar
Call ECR_TRACE(mess(157,7900,1),0) From GESECRAN   
Call ECR_TRACE("|  "-WFILTARFULL,0) From GESECRAN   
ORDRE=WFILCMD : OPT="f"
Call SYSTEME(MAC,ORDRE,OPT,STAT) From ORDSYS
#Call SYSTEME("#",ORDRE,OPT,STAT) From ORDSYS

# Verif
If  filinfo(WFILTARFULL,0) < 0 
 Call ECR_TRACE("|"+mess(130,124,1)-WSTR ,0) From GESECRAN 
 Call ECR_TRACE("|"+mess(31,7900,1)-WFILTARFULL,1) From GESECRAN     
 RET=0 : Goto FCYTAR_FIN
Endif

# Suppression fichier cde
Call EFFACE(WFILCMD , STAT) From ORDSYS

$FCYTAR_FIN
End

# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYDETAR   (MAC, DOSNAM, FCYCOD, TARNAM, RET)       # Création design site  (Rq: Tarnam sans extension)
Value Char MAC,DOSNAM, FCYCOD, TARNAM       
Variable Integer RET                        # 0:Ko 1:Ok

Local Char WREPI(250), WREP(250), WREPFCY(250), WREPTARREL(250), WREPCMD(250), WDRIVE(5)
Local Char WFILTARREL(250), WFILTARFULL(250), WFILTAR(250), WFILCMD(250), WTARNAM(20)
Local Char WSTR(250), WSTR1(250)
Local Integer WPOS
Local Char TYPOS,DIRSEP,APPLI(10)
Local Char OPT,ORDRE(250)
Local Integer STAT
RET=1
Call ECR_TRACE(mess(34,7900,1)-TARNAM-mess(1,7900,1)-FCYCOD-"("-DOSNAM-")",0) From GESECRAN
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)

#
TARNAM=vireblc(TARNAM,2)
If TARNAM=""
    Call ECR_TRACE(mess(155,7900,1),1) From GESECRAN     
    RET=0 : Goto FCYDETAR_FIN
Endif

Call TARNAMFMT(TARNAM,WTARNAM)   # mise en forme

# Répertoire html site
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
WPOS = instr(1,WREP,"@")
If WPOS <>0 : WREPFCY= right$(WREP,WPOS +1) : Else : WREPFCY=WREP : Endif
If  filinfo(WREP,0) >= 0 
    Gosub DIRDEL
    If RET=0 : Goto FCYDETAR_FIN : Endif
Endif
Gosub DIRCRE
If RET=0 : Goto FCYDETAR_FIN : Endif

# Emplacement tar
WREPI = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_TAR"
WREP=filpath(WREPI,"","",APPLI,"",MAC)              
If  filinfo(WREP,0) >= 0
  # En relatif / site 
  WREPTARREL=".."+DIRSEP+".."+DIRSEP+"X_TAR"
  WFILTARREL=WREPTARREL+DIRSEP+WTARNAM
  WFILTARFULL=WREP+DIRSEP+WTARNAM
  If  filinfo(WFILTARFULL,0) < 0
      Call ECR_TRACE("|"+mess(35,7900,1)-WFILTARFULL,1) From GESECRAN     
      RET=0 : Goto FCYDETAR_FIN
  Endif
  WPOS = instr(1,WFILTARFULL,"@")
  If WPOS <>0 : WFILTAR= right$(WFILTARFULL,WPOS +1) : Else : WFILTAR=WFILTARFULL: Endif
Else
  Call ECR_TRACE("|"+mess(86,133,1)-WREP,1) From GESECRAN     
  RET=0 : Goto FCYDETAR_FIN
Endif 

# Création fichier de commande
WREPCMD = filpath(DOSNAM+DIRSEP+"TMP","","",APPLI,"",MAC)
WFILCMD =WREPCMD+DIRSEP+"AYTDETAR"+num$(adxuid(1))+"_"+num$(time)+".CMD"
#Call ECR_TRACE("|WFILCMD:"-WFILCMD,0) From GESECRAN     

Openo WFILCMD,0 Using [CMD_]
Iomode adxifs "" Using [CMD_]
Iomode adxirs chr$(10) Using [CMD_]
Iomode adxium GASCII Using [CMD_]
If toupper(TYPOS)="DOS"
    WPOS = instr(len(MAC),WFILTARFULL,":")        # Enlever MAC car contient ':'
    If WPOS <> 0 
         # Pour avoir un comportement correct sur une machine distante
        WSTR = mid$(WFILTARFULL,WPOS-1,2)         : Wrseq WSTR Using [CMD_]
    Else
         Call ECR_TRACE("|"+"Error- Disk letter not found in:"-WFILTARFULL,1) From GESECRAN     
         RET=0 : : Goto FCYDETAR_FIN
    Endif
    # <1er version>
    WSTR='cd "'+WREPFCY+'"'                    : Wrseq WSTR Using [CMD_]
    WSTR='7za.exe x "'+WFILTARREL+'" -r -y'    : Wrseq WSTR Using [CMD_]    # pas de -o car dans la directory
    # <2ieme version>  WSTR +long
    #WSTR='7za.exe x "'+WFILTAR+'" -r -y -o"'+WREPFCY+'"'    : Wrseq WSTR Using [CMD_]
Else
    WSTR="cd "+WREPFCY                         : Wrseq WSTR Using [CMD_]
    WSTR="tar -xvf "+WFILTARREL                : Wrseq WSTR Using [CMD_]
Endif
Openo Using [CMD_]

# DeTar
Call ECR_TRACE("|"+mess(158,7900,1)-WFILTARFULL,0) From GESECRAN   
ORDRE=WFILCMD : OPT="f"
Call SYSTEME(MAC,ORDRE,OPT,STAT) From ORDSYS
#Call SYSTEME("#",ORDRE,OPT,STAT) From ORDSYS

