# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - #
# $$$$
Subprog DIRFCYSUPTAR   (MAC, DOSNAM, FCYCOD, TARNAM, RET)       #
Value Char MAC,DOSNAM, FCYCOD, TARNAM                  
Variable Integer RET

Local Char WFILTARFULL(250), WTARNAM(20)
Local Integer STAT
RET=1

Call TARNAMFMT(TARNAM,WTARNAM) From AYTGESFILE   # mise en forme
Call ECR_TRACE(mess(161,7900,1)-WTARNAM,0) From GESECRAN

WFILTARFULL=func AYTGESFILE.GETPATH(MAC, DOSNAM,"FILTAR","",FCYCOD,WTARNAM)
If  filinfo(WFILTARFULL,0) >= 0 
    Call EFFACE(WFILTARFULL, STAT) From ORDSYS
    If  filinfo(WFILTARFULL,0) >= 0 
     Call ECR_TRACE("|"+mess(32,7900,1)-WFILTARFULL,1) From GESECRAN     
     RET=0
    Else
     Call ECR_TRACE(mess(162,7900,1),0) From GESECRAN     
    Endif
Else
    Call ECR_TRACE("|"+mess(35,7900,1)-WFILTARFULL,0) From GESECRAN    
Endif
End

######################################################################################
###    Utilitaires
######################################################################################
#------------------------------------------------------------#
###    Obtenir un emplacement Xtend (modèle Intrutila)
#        MAC  Sodaix01:5000
#        DOSNAM    XTEND
#------------------------------------------------------------#
# $$$$
Funprog GETPATH(MAC,DOSNAM,TYP,LANG,FCYCOD, PAR1)
Value Char MAC,DOSNAM,TYP,LANG,FCYCOD, PAR1
Local Char XTPATH(250)
Local Char REP(200),DIRSEP,APPLI(10), TYPOS
Local Char WTARNAM(20)

Local Char TYPOS,DIRSEP,APPLI(10)
Call INFOS(MAC, TYPOS, DIRSEP, APPLI)
Case TYP
  When "DIRSEP"
      XTPATH=DIRSEP
  When "DIRXTEND"
      REP="X_TEND"
      XTPATH=filpath(REP,"","",APPLI,"",MAC)              
  When "DIRFCYGEN" 
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_GEN"+DIRSEP+FCYCOD
      XTPATH=filpath(REP,"","",APPLI,"",MAC)              
  When "DIRPAG" 
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_HTML"+DIRSEP+FCYCOD+DIRSEP+LANG
      XTPATH=filpath(REP,"","",APPLI,"",MAC)    
  When "DIRFILES" 
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_FILES"
      XTPATH=filpath(REP,"","",APPLI,"",MAC)    
  When "DIRFILAPP" 
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_FILAPP"
      XTPATH=filpath(REP,"","",APPLI,"",MAC)    
  When "DIRTAR" 
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_TAR"
      XTPATH=filpath(REP,"","",APPLI,"",MAC)    
  When "FILTAR"
      REP = DOSNAM+DIRSEP+"X_TEND"+DIRSEP+"X_TAR"
      Call TARNAMFMT(PAR1,WTARNAM)   
      XTPATH=filpath(REP,"","",APPLI,"",MAC)+DIRSEP+WTARNAM   
#      XTPATH=filpath(REP,"","",APPLI,"",MAC)+DIRSEP+FCYCOD+".tar"   
  When "FILFCY"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"FCY.xml"
  When "FILTIM"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"TIM.xml"
  When "FILFLD"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"FLD.xml"
  When "FILMES"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"MES.xml"
  When "FILOBJ"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"OBJ.xml"
  When "FILSPE"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"SPE.xml"
  When "FILPAG"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"PAG.xml"
  When "FILENT"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"ENT.xml"
  When "FILBLC"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"BLC.xml"
  When "FILDLK"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"DLK.xml"
  When "FILACT"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"ACT.xml"
  When "FILCND"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"CND.xml"
  When "FILINT"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"INT.xml"
  When "FILPRF"
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"PRF.xml"
  When "FILADV"    # Para. avancé
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"ADV.xml"
  When "FILMEN"    # Menu Xtend
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","",FCYCOD,"")+DIRSEP+"MEN.xml"
When "FILPUBSITE"    # publication site dans ays
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","","","")+DIRSEP+"PUB.xml"
When "FILWSC"    # publication pools web dans AYO
      XTPATH = func GETPATH(MAC, DOSNAM, "DIRFCYGEN","","","")+DIRSEP+"WSC.xml"
  When "FILTRT"
      XTPATH = filpath("TRT",PAR1,"src",DOSNAM,"",MAC)  
  When  Default 
      Infbox "AYTGESFILE/GETPATH- Type inconnu:"-TYP
Endcase
End XTPATH

#------------------------------------------------------------#
# $$$$
Subprog INFOS(MAC, TYPOS, DIRSEP, APPLI)
Value Char MAC
Variable Char TYPOS,DIRSEP,APPLI
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0)
Local Char MACHINE(GDIMFIC)
MACHINE=MAC
If MACHINE="" 
  MACHINE=adxmac(0)
  TYPOS=GOS(1)
Else
  Call GET_OS(MACHINE,TYPOS) From ORDSYS
Endif
Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
APPLI="X3_PUB"
End

#------------------------------------------------------------#
# $$$$
Subprog TARNAMFMT   (TARNAM,TARNAMFMT)                  # Format et vérifie le nom du tar
Value Char TARNAM              # Nom du tar avec ou sans
Variable Char TARNAMFMT        # Nom du tar avec .tar
Local Integer WI, WJ
TARNAMFMT=""
Repeat
    WJ=WI
    WI=instr(WJ+1,TARNAM,".tar")
Until WI=0
If WJ
    If(TARNAM=left$(TARNAM,WJ-1)+".tar")    # Même chaine -> Ok
        TARNAMFMT=TARNAM
   Else
        TARNAMFMT=TARNAM+".tar"
    Endif   
Else
    TARNAMFMT=TARNAM+".tar"
Endif
End

