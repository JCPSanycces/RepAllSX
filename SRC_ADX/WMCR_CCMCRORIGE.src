#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs externes
# Superviseur
## CRUD-CLASSE ## CCMCRORIGE
# 2018-10-19 07:50:21 130


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File CCMCRORIGE [CCMCROE_]

If !SILENCE : Call TRACE("2 --> Local Instance C_CCMCRORIGE") From ASYRCOM : Endif
Local Instance CCMCRORIGE Using C_CCMCRORIGE

If !SILENCE : Call TRACE("3 --> New Instance C_CCMCRORIGE") From ASYRCOM : Endif
CCMCRORIGE = NewInstance C_CCMCRORIGE AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CCMCROE_]CCMCROE0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of CCMCRORIGE") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.AREAD([CCMCROE_]CRID,[CCMCROE_]ORIGELN))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("CCMCRORIGE.CRID ="-num$(CCMCRORIGE.CRID)) From ASYRCOM
 Call TRACE("CCMCRORIGE.ORIGELN ="-num$(CCMCRORIGE.ORIGELN)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(CCMCRORIGE.AKEYS)
  Call TRACE("-"-num$(I)-":"-CCMCRORIGE.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CCMCROE_]
FreeGroup CCMCRORIGE
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(CCMCRORIGE,ACLE,ASTATUS,_ETAG)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _CRID(20)
Local Shortint _ORIGELN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGELN = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File CCMCRORIGE [CCMCROE]
Default File [F:CCMCROE]
Read [F:CCMCROE]CCMCROE0 = [L]_CRID;[L]_ORIGELN
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CCMCROE]UPDTICK)>0
 [L]_ETAG = num$([F:CCMCROE]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(CCMCRORIGE,ACLE,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Value Char ACLE
Variable Integer ASTATUS
Local Char _CRID(20)
Local Shortint _ORIGELN
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_CRID = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_ORIGELN = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.AREAD([L]_CRID,[L]_ORIGELN))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(CCMCRORIGE,_CRID,_ORIGELN,ASTATUS)
Variable Instance CCMCRORIGE Using C_CCMCRORIGE
Value Char _CRID
Value Shortint _ORIGELN
Variable Integer ASTATUS

If CCMCRORIGE = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGE
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If CCMCRORIGE.APARENT=null
 [L]A_I = CCMCRORIGE.freeSnapshot
 CCMCRORIGE.snapshotEnabled = 0
 CCMCRORIGE.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & CCMCRORIGE.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If CCMCRORIGE.APARENT=null
 CCMCRORIGE.snapshotEnabled = 1
 CCMCRORIGE.setAccessorEnabled = 1
Endif
LogicClose File [CCMCROE]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE._ACTION_PARAM("AREAD_BEFORE",[L]_CRID,[L]_ORIGELN))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CCMCROE]
Read [F:CCMCROE]CCMCROE0 = [L]_CRID;[L]_ORIGELN
If fstat
[L]A_ERROR = [L]_CRID+"~"+num$([L]_ORIGELN)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(CCMCRORIGE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CCMCROE]AUUID)>0 & [F:CCMCROE]AUUID=NullUuid
 [F:CCMCROE]AUUID = getUuid
Endif
SetInstance CCMCRORIGE With [F:CCMCROE]
CCMCRORIGE.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGE.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



