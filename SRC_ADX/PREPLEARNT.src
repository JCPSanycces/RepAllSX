#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################################
# Programme : PREPLEARNT
#
# Fonction  :
#      1- Maj de la table TMPLEARNT  pour l'état LEARNTDPR
# Création     :  06/06/2014    (FQ-70464)
# Modification :
# XXX DD.MM.YYYY FQnnnnnn   : Cccccccccccccccccccccccccccccccccccccccccccccccccccccc
#########################################################################################
$ACTION

    Case ACTION
       When "OUVRE" :   Gosub OUVRE
       When "FIN"   :   Gosub FIN
    Endcase

Return
######################################################################################
$OUVRE

If clalev([F:CPY])=0    :    Local File COMPANY         [CPY]   : Endif
If clalev([F:FCY])=0    :    Local File FACILITY        [FCY]   : Endif   # Financial sites
If clalev([F:AFF])=0    :    Local File AFCTFCY         [AFF]   : Endif   # Site profile function
If clalev([F:LEA])=0    :    Local File LEASE           [LEA]   : Endif
If clalev([F:LBB])=0    :    Local File LEABILBOOK      [LBB]   : Endif
If clalev([F:FAS])=0    :    Local File FXDASSETS       [FAS]   : Endif
If clalev([F:DEP])=0    :    Local File DEPREC          [DEP]   : Endif
If clalev([F:TLR])=0    :    Local File TMPLEARNT       [TLR]   : Endif

SYMBOLE = "PREPLEARNT"
Lock SYMBOLE With lockwait = 3
If fstat
   Return
Endif

Return
######################################################################################
$FIN

Unlock=SYMBOLE

Return
#=============================================================================
# traitement PREPLEARNT : alimentation de la table TMPLEARNT
#=============================================================================
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALEUR(30)

Gosub OUVRE
Gosub MAJ_TMPLEARNT

End
###################################################
$MAJ_TMPLEARNT
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPLEARNT pour l'état LEARNTDPR                    ---#
#------------------------------------------------------------------------------------#
    Local Integer I                 # Setting number
    Local Char    LCPYDEB (5)       # Company start
    Local Char    LCPYFIN (5)       # Company end
    Local Integer LTYPE             # Type contrat
    Local Integer LPLAN             # Plan
    Local Date    LDATDEB           # Start date
    Local Date    LDATFIN           # End date
    Local Date    LDATNULL         : LDATNULL = [01/01/1900]
    Local Integer LEDTNUM           # number session
    Local Char    SCPY (5)
    Local Integer IS_LEA            # Nombre de CLF

    Trbegin [TLR]
    Delete [TLR] Where CREUSR = GUSER
    If fstat = 1 | fstat>5
      Rollback
      #  "Problem when deletion of temporary file"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Return
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,PARAM)        : LCPYDEB  = PARAM
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,PARAM)        : LCPYFIN  = PARAM
   Call GETPARAM("type",NBPAR,PARAMETRE,PARAM)          : LTYPE    = val(PARAM)
   Call GETPARAM("plan",NBPAR,PARAMETRE,PARAM)          : LPLAN    = val(PARAM)
   Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)        : LDATDEB  = PARAM
   Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)        : LDATFIN  = PARAM
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)        : LEDTNUM  = val(PARAM)

   #--------------------------------
    Local Integer I_BSE

   Call DEBTRANS From GLOCK
   Trbegin [TLR]
   SCPY= ""
   For [CPY] Where (CPY >= LCPYDEB & CPY <= LCPYFIN )
      IS_LEA = G_NON
      SCPY =  [F:CPY]CPY
      Raz[TLR]
      Filter [LEA] Where (CPY = SCPY & BSENAT > 0 & LEATYP=GVML_CREBAIL & LEASTA = GVML_STENCOU)  Order By BSENAT Asc
      For [LEA]
         IS_LEA = G_OUI
         I_BSE = [F:LEA]BSENAT
         [F:TLR]BSENAT(I_BSE-1)     = [F:LEA]BSENAT
         [F:TLR]TOTVALORI(I_BSE-1) += [F:LEA]CUMIASBSE
         For [LBB]  Where (LEAREF=  [F:LEA]LEAREF and ENDPERDAT <= LDATFIN)
            GOK=1
            #1------------
            Gosub CHARGE_LEA
         Next # [LBB]
         For  [F:FAS] Where (LEAREF=[F:LEA]LEAREF)
            Read[DEP]DEP0=[F:FAS]AASREF;LPLAN;LDATFIN;LDATFIN
            If fstat=0
               Gosub CHARGE_DEP
            Endif
            #========================================================
         Next # [FAS]
      Next  # [LEA]
      Filter [LEA]
      If IS_LEA = G_OUI
         [F:TLR]CPY = SCPY
         [F:TLR]EDTNUM = LEDTNUM
         [F:TLR]CREUSR = GUSER
         If LEDTNUM <> 0
            Write [F:TLR]
            If fstat
               GOK=0 : Call FSTA("TLR") From GLOCK
               Break
            Endif
         Endif
      Endif
   Next #[CPY]


   If GOK : Commit : Else Gosub ROLL_TR1 : Endif


Return
#######################################################################################
$CHARGE_LEA

Local Integer NBJOURPER
Local Integer NBJOUR
Local Date    DATFIN

Local Decimal RNTEX1
Local Decimal RNTCUM1

Case [F:LEA]LEASTA
   When  2    :    DATFIN = LDATFIN
   When  3    :    DATFIN = [F:LEA]ENDLEADAT
   When  4    :    DATFIN = [F:LEA]RPUDAT
   When  5    :    DATFIN = [F:LEA]TRMLEADAT
 Endcase

If [F:LBB]STRPERDAT> DATFIN or  [F:LBB]STRPERDAT > LDATFIN
   Return
Endif

If ( [F:LBB]STRPERDAT>= LDATDEB and  [F:LBB]STRPERDAT <= LDATFIN )
  [F:TLR]TOTRNTEXE(I_BSE-1)    += [F:LBB]RNTAMT
  [F:TLR]TOTFINDPREX(I_BSE-1)  += [F:LBB]FINDPR
  [F:TLR]TOTFINEXSEXE(I_BSE-1) += [F:LBB]FINEXS
  [F:TLR]TOTCAPEXE(I_BSE-1)    += [F:LBB]FINDPR # = cumul amort.fin de l'exercice
Else
   If ([F:LBB]STRPERDAT>= LDATFIN and  [F:LBB]ENDPERDAT> LDATFIN)
     NBJOURPER = [F:LBB]NBRDAYPER
     NBJOUR = LDATFIN-[F:LBB]STRPERDAT+1
     [F:TLR]TOTRNTEXE(I_BSE-1)    += arr([F:LBB]RNTAMT*NBJOUR/NBJOURPER,2)
     [F:TLR]TOTFINDPREX(I_BSE-1)  += arr([F:LBB]FINDPR*NBJOUR/NBJOURPER,2)
     [F:TLR]TOTFINEXSEXE(I_BSE-1) += arr([F:LBB]FINEXS*NBJOUR/NBJOURPER,2)
     [F:TLR]TOTCAPEXE(I_BSE-1)    += arr([F:LBB]FINDPR *NBJOUR/NBJOURPER,2) # = cumul amort.fin de l'exercice
   Else
      If ([F:LBB]STRPERDAT<= LDATFIN and [F:LBB]ENDPERDAT<= LDATFIN and [F:LBB]ENDPERDAT>= LDATFIN)
          NBJOURPER = [F:LBB]NBRDAYPER
          NBJOUR    = [F:LBB]ENDPERDAT-LDATFIN+1
          [F:TLR]TOTRNTEXE(I_BSE-1)    += arr([F:LBB]RNTAMT*NBJOUR/NBJOURPER,2)
          [F:TLR]TOTFINDPREX(I_BSE-1)  += arr([F:LBB]FINDPR*NBJOUR/NBJOURPER,2)
          [F:TLR]TOTFINEXSEXE(I_BSE-1) += arr([F:LBB]FINEXS*NBJOUR/NBJOURPER,2)
          [F:TLR]TOTCAPEXE(I_BSE-1)    += arr([F:LBB]FINDPR *NBJOUR/NBJOURPER,2) # = cumul amort.fin de l'exercice
      Endif
   Endif
Endif

If ( [F:LBB]STRPERDAT <=  DATFIN  )
   # SI la Date de fin d'échéance est <= à la date de fin d'exercice
   # courant IAS ==> On prend le montant de redevance de la période
   If ([F:LBB]ENDPERDAT<= LDATFIN)
      [F:TLR]TOTRNTCUM(I_BSE-1)     +=[F:LBB]RNTAMT
      [F:TLR]TOTFINDPRCUM(I_BSE-1)  +=[F:LBB]FINDPR
      [F:TLR]TOTFINEXSCUM(I_BSE-1)  +=[F:LBB]FINEXS
      [F:TLR]TOTCAPCUM(I_BSE-1)      =[F:LBB]RPACAP
   Else
      # Si date début échéance est comprise dans l'EXERCICE COURANT IAS
      # mais que date de fin d'échéance n'est pas comprise dans l'exercice courant IAS
      # on calcule le montant redevance de l'échéance qui doit être attribué
      # à l'exercice courant IAS (nbjourper = nombre total de jours  de la période,
      # NBJOUR = NB DE JOURS COMPRIS ENTRE LA Date DE DÉBUT DE PÉRIODE ET LA
      # Date DE FIN EXERCICE COURANT IAS
      # ==> MONTANT À PRENDRE EN COMPTE = (REDEVANCE TOTALE * NBJOUR)/NBJOURPER
      If ([F:LBB]STRPERDAT<= LDATFIN and  [F:LBB]ENDPERDAT > LFATFIN )
         NBJOURPER = [F:LBB]NBRDAYPER
         NBJOUR = LDATFIN- [F:LBB]STRPERDAT+1
         [F:TLR]TOTRNTCUM(I_BSE-1)     +=arr([F:LBB]RNTAMT*NBJOUR/NBJOURPER,2)
         [F:TLR]TOTFINDPRCUM(I_BSE-1)  +=arr([F:LBB]FINDPR*NBJOUR/NBJOURPER,2)
         [F:TLR]TOTFINEXSCUM(I_BSE-1)  +=arr([F:LBB]FINEXS*NBJOUR/NBJOURPER,2)
         [F:TLR]TOTCAPCUM(I_BSE-1)      =arr([F:LBB]RPACAP*NBJOUR/NBJOURPER,2)
      Endif
   Endif
Endif

Return
#######################################################################################
$CHARGE_DEP

[F:TLR]TOTDPREXE(I_BSE-1)   += [F:DEP]ENDDPE
[F:TLR]TOTDPRCUM(I_BSE-1)   += ([F:DEP]DPRCUM+[F:DEP]ENDDPE)

Return
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
######################################################################################
$ROLL_TR1
Rollback : Call ROLL From GLOCK
Return
