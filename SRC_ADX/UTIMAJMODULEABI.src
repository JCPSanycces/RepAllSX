#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour module pour les tables ABI
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise a jour module pour les tables ABI") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

Gosub MAJMODULE
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER

If filinfo(filpath("FIL","ABIDIMFLD","fde",[L]DOSSIER),0)<0 or !func AFNC.ACTIVDOS(DOSSIER,"ABI") : End : Endif

Gosub MAJMODULE
End

#-------------------#
$MAJMODULE
Local File =DOSSIER+".ABIDATMRT" [ABM]
Local File =DOSSIER+".ABITABDAT" [ABF]
Local File =DOSSIER+".ABIDIM"    [ABI]
Local File =DOSSIER+".ABIHIERA"  [AHH]
Local File =DOSSIER+".ABICOND"   [AII]
Local File =DOSSIER+".ABIREGORG" [ABV]
Local File =DOSSIER+".ABIREGDES" [ABY]

Local File =DOSSIER+".ATABLE"    [ATB]
Local File =GDOSX3+".ATABLE"     [ATB2]

If dim([ABF]MODULE)<0 or dim([ABI]MODULE)<0  or dim([AHH]MODULE)<0 or dim([AHH]MODULE)<0 or dim([AII]MODULE)<0  or dim([ABV]MODULE)<0 : Return : Endif

Local Integer I,VALMOD(20)

Trbegin [ABM]

 # On affecte le module de la table de fait avec celui du datamart
 Call ECR_TRACE(mess(81,125,1)-"ABITABDAT"-time$,0) From GESECRAN
 For [ABM]
  For I=0 To [ABM]NBRABF-1
   Read [ABF]ABF0 = [F:ABM]CODABF(I)
   If !fstat & [ABF]MODULE=0
    [ABF]MODULE = [ABM]MODULE
    Rewrite [ABF]
    If fstat
     Call ERREUR("ABITABDAT"-[F:ABF]CODABF,2) From DOSDIC
    Endif
   Endif
  Next
 Next

 # si la table de fait n'est pas rataché a un datamart --> tronc commun
 Update [ABF] Where MODULE=0 With MODULE=9

 # On affecte le module de la dimension avec celui du de la table d'origine
 Call ECR_TRACE(mess(81,125,1)-"ABIDIM"-time$,0) From GESECRAN
 For [ABI] Where [ABI]MODULE=0
  Read [ATB]CODFIC = [F:ABI]TABORG
  If !fstat
   [ABI]MODULE = [ATB]MODULE
   If [ABI]MODULE = 1 : [ABI]MODULE = 9 : Endif
   Rewrite [ABI]
   If fstat
    Call ERREUR("ABIDIM"-[F:ABI]CODDIM,2) From DOSDIC
   Endif
  Else
   Read [ATB2]CODFIC = [F:ABI]TABORG
   If !fstat
    [ABI]MODULE = [ATB2]MODULE
    Rewrite [ABI]
    If fstat
     Call ERREUR("ABIDIM"-[F:ABI]CODDIM,2) From DOSDIC
    Endif
   Endif
  Endif
 Next

 # On affecte le module de la hierarchie avec celui du datamart
 Call ECR_TRACE(mess(81,125,1)-"ABIHIERA"-time$,0) From GESECRAN
 For [AHH] Where [AHH]MODULE=0
  Read [ABM]ABM0 = [F:AHH]ABM
  If !fstat
   [AHH]MODULE = [ABM]MODULE
   Rewrite [AHH]
   If fstat
    Call ERREUR("ABIHIERA"-[F:AHH]COD,2) From DOSDIC
   Endif
  Endif
 Next

 # On affecte le module de la condition predfini avec celui du datamart
 Call ECR_TRACE(mess(81,125,1)-"ABICOND"-time$,0) From GESECRAN
 For [AII] Where [AII]MODULE=0
  Read [ABM]ABM0 = [F:AII]ABM
  If !fstat
   [AII]MODULE = [ABM]MODULE
   Rewrite [AII]
   If fstat
    Call ERREUR("ABICOND"-[F:AII]COD,2) From DOSDIC
   Endif
  Endif
 Next

 # On affecte le module de la regle de synchro avec celui de la table d'origine
 Call ECR_TRACE(mess(81,125,1)-"ABIREGORG"-time$,0) From GESECRAN
 For [ABV] Where [ABV]MODULE=0
  Filter [ABY] Where CODREG = [ABV]CODREG
  Read [ABY]ABY0 First
  Filter [ABY]
  If !fstat
   Read [ABF]ABF0 = [F:ABY]TABDES
   If !fstat
    [ABV]MODULE = [ABF]MODULE
    If [ABV]MODULE = 1 : [ABV]MODULE = 9 : Endif
    Rewrite [ABV]
    If fstat
     Call ERREUR("ABIREGORG"-[F:ABV]CODREG,2) From DOSDIC
    Endif
   Endif
  Endif
 Next

Commit

For I=0 To dim(VALMOD)-1
 VALMOD(I)= 2
Next

Call MAJ_SEL(DOSSIER,"ABF") From PATCHAOB
If GPRODUIT<>-1
Call VALID_TRT(DOSSIER,0,"","","","","","","","","ABF","ABF","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"ABF") From SUBAOB
Endif

Call MAJ_SEL(DOSSIER,"ABI") From PATCHAOB
If GPRODUIT<>-1
Call VALID_TRT(DOSSIER,0,"","","","","","","","","ABI","ABI","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"ABI") From SUBAOB
Endif

Call MAJ_SEL(DOSSIER,"AHH") From PATCHAOB
If GPRODUIT<>-1
Call VALID_TRT(DOSSIER,0,"","","","","","","","","AHH","AHH","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"AHH") From SUBAOB
Endif

Call MAJ_SEL(DOSSIER,"AII") From PATCHAOB
If GPRODUIT<>-1
Call VALID_TRT(DOSSIER,0,"","","","","","","","","AII","AII","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"AII") From SUBAOB
Endif

Call MAJ_SEL(DOSSIER,"ABV") From PATCHAOB
If GPRODUIT<>-1
Call VALID_TRT(DOSSIER,0,"","","","","","","","","ABV","ABV","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"ABV") From SUBAOB
Endif

Close Local File [ABM],[ABF],[ABI],[AHH],[AII],[ABV],[ATB],[ABY],[ATB2]

Return
