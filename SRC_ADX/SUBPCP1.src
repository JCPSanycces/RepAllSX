#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque PCRITPSD
#######################################################################
# SUBPCP1 : Saisie des critères pour filtre du picking                #
#         des DA pour les appels d'offres                             #
# ------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p de     #
#        saisie des critères "SAICRITPSH" et ne sert qu'à gérer le    #
#        masque écran "PCRITSPH [PCP1]".                              #
#######################################################################


$ACTION
Return


Subprog IB_WBPSNUM
#-----------------------------#
# Avant saisie du fournisseur #
#-----------------------------#
Raz GBOUT1, GBOUT2, GBOUT3
GBOUT1=mess(73,198,1)  : # Fournisseur
GBOUT2 =mess(8,31,1)   : # Sélection
End


Subprog AM_WBPSNUM(VALEUR)
#----------------------------#
# Après modif du fournisseur #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If !instr(1,VALEUR,'*') &
&    !instr(1,VALEUR,'?') &
&    !instr(1,VALEUR,'#') &
&    !instr(1,VALEUR,'?')
    If VALEUR<>[F:BPS]BPSNUM
      Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : mkstat=1 : Endif
    Endif
    If [F:BPS]BPSNUM<>""  [M:PCP1]WBPSNAM=[F:BPS]BPSNAM : Endif
  Else
    Filter [BPS] Where pat(BPSNUM,VALEUR)
    Read [BPS] BPS0 First
    Filter [BPS]
    If fstat  Raz [F:BPS] : mkstat=2 : Endif
    If [F:BPS]BPSNUM<>""  Raz [M:PCP1]WBPSNAM : Endif
  Endif
Else
   Raz [M:PCP1]WBPSNAM
Endif
Case mkstat
  When 1 : Call ERREUR(VALEUR-mess(136,100,1)) From GESECRAN : End
  When 2 : Call ERREUR(VALEUR-mess(314,194,1)) From GESECRAN : End
Endcase
Affzo [PCP1]WBPSNAM
End


Subprog IB_WITMREF
#-----------------#
# Init bouton     #
#-----------------#
GBOUT1=mess(22,198,1) : # Articles
End


Subprog AM_WITMREF(VALEUR)
#----------------------------#
# Après modif de l'article   #
#----------------------------#
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
If VALEUR<>""
  If !instr(1,VALEUR,'*') &
&    !instr(1,VALEUR,'?') &
&    !instr(1,VALEUR,'#') &
&    !instr(1,VALEUR,'?')
    If VALEUR<>[F:ITM]ITMREF
      Read [ITM] ITM0=VALEUR : If fstat Raz [F:ITM] : mkstat=1 : Endif
    Endif
    #If [F:ITM]ITMREF<>""  [M:PCP1]WITMDES = [F:ITM]ITMDES1 : Endif
    If [F:ITM]ITMREF<>""
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PCP1]WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
  Else
    Filter [ITM] Where pat(ITMREF,VALEUR)
    Read [ITM] ITM0 First
    Filter [ITM]
    If fstat  Raz [F:ITM] : mkstat=2 : Endif
    If [F:ITM]ITMREF<>""  Raz [M:PCP1]WITMDES : Endif
  Endif
Else
  Raz [M:PCP1]WITMDES
Endif
Case mkstat
  When 1 : Call ERREUR(VALEUR-mess(212,199,1)) From GESECRAN : End
  When 2 : Call ERREUR(VALEUR-mess(314,194,1)) From GESECRAN : End
Endcase
Affzo [PCP1]WITMDES
End
