#<AdxTL>@(#)9.0.0.0 $Revision$
#Saisie paramétrage du fichier TDS
Call OBJET("TFT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT" : Gosub SETBOUT
 When "LIENS2"  : Gosub LIENS2
 When "RAZDUP"  : Gosub RAZDUP
 When "RAZCRE"  : Gosub RAZCRE
 When "ABANDON" : Gosub ABANDON
 When "SETBOUT" : Gosub SETBOUT
 When "APRES_CHOIX" : Gosub APRES_CHOIX
Endcase
Return

$SETBOUT
If CLECUR & SUPPR : CHAINE+="A" : Endif
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$LIENS2
If [M]RECTYP>1
 Call SET_FILREF
 Grizo FILREF
Else
 Actzo FILREF
Endif
Return

$RAZDUP
$RAZCRE
If COUZON="RECTYP"
 If zc>1
  Grizo FILREF
 Else
  Actzo FILREF
 Endif
Endif
Return

$ABANDON
Actzo FILREF
Return

Subprog SET_FILREF
Local File TABFILTDS [TFT]
Read [TFT]TFT0(2) = [M]COD;1
If fstat : Raz [F:TFT] : Endif
[M]FILREF=[F:TFT]FILREF
End

$APRES_CHOIX
Case REPONSE
 When GSTAANU : Gosub ANNULER : REPONSE=0
Endcase
Return

$ANNULER 
If !VERROU 
 Gosub VERROU From GOBJET
 If !VERROU 
  Call ERREUR(mess(10,100,1)) From GESECRAN : Return 
 Else 
  AFFICHE = 1 : Gosub RELIT From GOBJSUB
 Endif 
Endif 
OK = 2 : Call OUINON(mess(28,100,1),OK) From GESECRAN 
If OK<>2 : Return : Endif 
Call DEBTRANS From GLOCK 
Gosub TR3
CLECUR = 0 
Gosub RELIT From GOBJSUB
Return 
 
$TR3 
GOK=1 
Trbegin [TFT] 
 Delete [TFT] Where COD=[M]COD & RECTYP=[M]RECTYP 
Commit 
Return 

#########################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File TABFILTDS  [TFT1]
Else 
 Local File =[M]DOSORG+".TABFILTDS"  [TFT1]
Endif 
If [M]DOSDES=nomap 
 Local File TABFILTDS [TFT2]
Else 
 Local File =[M]DOSDES+".TABFILTDS"  [TFT2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [TFT1], [TFT2]
Return

$TR_COP
GOK = 1
Trbegin [TFT2]
 Delete [TFT2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABFILTDS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TFT2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TFT1] Where COD=TABLE
  [F:TFT2] = [F:TFT1]
  If dim([F:TFT2]UPDUSR)>0 : [F:TFT2]UPDUSR = GUSER : Endif
  If dim([F:TFT2]UPDDAT)>0 : [F:TFT2]UPDDAT = date$ : Endif
  Write [TFT2]
  If fstat
   GOK = 0 : Call FSTA("TFT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
Case [M]FLDTYP(nolign-1)
 When 3,4 : VALEUR = 6 : mkstat = 2
 When 6,7 : VALEUR = 2 : mkstat = 2
Endcase
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
Case [M]FLDTYP(nolign-1)
 When 5
  If !find(VALEUR,1,2,4) : mkstat = 1 : End : Endif
Endcase
End

Subprog APRES_NBLIG
Affzo TOTLNG, POS
End

Subprog AS_NBLIG
End

Subprog AV_POS(VALEUR)
Variable Decimal  VALEUR
If nolign=1
 VALEUR = 1
Else
 VALEUR = [M]POS(nolign-2) + [M]LNG(nolign-2)
Endif
End

Subprog AV_TOTLNG(VALEUR)
Variable Decimal  VALEUR
VALEUR = sum([M]LNG(0..[M]NBLIG-1))
End

Subprog AS_FILREF(VALEUR)
Variable Char     VALEUR
If [M]RECTYP<>1 : mkstat = 2 : Endif
End
