#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque STOCKSNU


$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "DEBUT"    : Gosub DEBUT
  When "OK"       : Gosub FIN
  When "ABA"      : Gosub FIN
  When "END"      : Gosub FIN
  When "FIN"      : Gosub FIN
Endcase
Return

############################################################
$OUVRE
Raz GSOC_ACTIVE

If clalev([M:SNU4]) =0 Local Mask SNU4      [SNU4]  Endif
If clalev([F:CUD])  =0 Local File CUNLISDET [CUD]   Endif
If clalev([M:SNLSW])=0 Local Mask SNLSEREW  [SNLSW] Endif  # hcb 110327
If clalev([M:SNLS]) =0 Local Mask SNLSERE   [SNLS]  Endif  # hcb 110327
If clalev([F:STS])  =0 Local File STOSER    [STS]   Endif  # hcb 110327

If GMODU(2)=2 : # Si module compta actif
  If !clalev([F:GCM])    Local File GACM       [GCM] : Endif
Endif

# Chargement des globales référenciels, comptes et sections de la société
GFCY=GFCYDEF(7)
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
GORITITCOL=1

Raz [M:SNU4]
### recuperation des elements parametres action
#recuperation session
Local Char  LSSS : LSSS  =   PARAM(1)
#recuperation liste
Local Char  LLIS : LLIS  =   PARAM(2)
Gosub FORMAT_INV_MULTI From STKINV                                                        # hcb 71659


#Gosub CHARGE_SNU4                               # hcb 110327

Return

Return

############################################################
$DEBUT
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
Gosub CHARGE_SNU4                               # hcb 110327
Affzo [M:SNU4]

Return

############################################################
$FIN
Raz GORITITCOL

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & dim([M:SNU4]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From W1SNU4
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SNU4]NBLIG=0
     [M:SNU4]NBLIG=1 : Affzo [SNU4] : Effzo [SNU4]
  Endif
Endif
Raz GSOC_UPDFLG
Return


############################################################
$CHARGE_SNU4

If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
Local Integer I
Local Integer Y
Y = 0
I = 0

Filter [CUD] Where [F:CUD]CUNSSSNUM = LSSS &
&                  [F:CUD]CUNLISNUM = LLIS
&             Order By Key CUD0

For [CUD]
    If I >  GCOD_INV-1 : Break : Endif
    [M:SNU4]LINFLG       (I) = [F:CUD]LINFLG
    [M:SNU4]ITMLISNUM    (I) = [F:CUD]ITMLISNUM
    [M:SNU4]CUNLISSTA    (I) = [F:CUD]CUNLISSTA
    [M:SNU4]ITMREF       (I) = [F:CUD]ITMREF
    If dim([M:SNU4]LPNNUM) > 0                                  # hcb X3-68147
       [M:SNU4]LPNNUM    (I) = [F:CUD]LPNNUM
    Endif
    If dim([M:SNU4]LOC) > 0
       [M:SNU4]LOC       (I) = [F:CUD]LOC
    Endif
    If dim([M:SNU4]LOT) > 0
       [M:SNU4]LOT       (I) = [F:CUD]LOT
    Endif
    If dim([M:SNU4]SLO) > 0
       [M:SNU4]SLO       (I) = [F:CUD]SLO
    Endif
    If dim([M:SNU4]ECCVALMAJ) > 0
       [M:SNU4]ECCVALMAJ (I) = [F:CUD]ECCVALMAJ
    Endif
    [M:SNU4]PCU          (I) = [F:CUD]PCU
    [M:SNU4]STA          (I) = [F:CUD]STA
    [M:SNU4]QTYPCU       (I) = [F:CUD]QTYPCU
    [M:SNU4]QTYPCUNEW    (I) = [F:CUD]QTYPCUNEW
    [M:SNU4]PCUSTUCOE    (I) = [F:CUD]PCUSTUCOE
    [M:SNU4]QTYSTU       (I) = [F:CUD]QTYSTU
    [M:SNU4]QTYSTUNEW    (I) = [F:CUD]QTYSTUNEW
    [M:SNU4]ZERSTOFLG    (I) = [F:CUD]ZERSTOFLG
    If dim([M:SNU4]SERNUM) > 0
       [M:SNU4]SERNUM    (I) = [F:CUD]SERNUM
    Endif
    If dim([M:SNU4]WRH) > 0
       [M:SNU4]WRH       (I) = [F:CUD]WRH
    Endif
    [M:SNU4]QTYSTUDEV    (I) = [F:CUD]QTYSTUNEW-[F:CUD]QTYSTU
    If [F:CUD]QTYSTU = 0
       [M:SNU4]PRCDEV    (I) = 0
    Else
       [M:SNU4]PRCDEV    (I) = ([M:SNU4]QTYSTUDEV (I)/[F:CUD]QTYSTU)*100
    Endif

# valeur unitaire
    [M:SNU4]CUNCST       (I) = [F:CUD]CUNCST
# valeur théorique = valeur unitaire * qte informatique
    [M:SNU4]CUNAMT       (I) = [F:CUD]CUNCST*[F:CUD]QTYSTU
# valeur Comptée = valeur unitaire * qte comptée
    [M:SNU4]CUNAMTNEW    (I) = [F:CUD]CUNCST*[F:CUD]QTYSTUNEW
    [M:SNU4]IPTDAT       (I) = [F:CUD]IPTDAT
    [M:SNU4]CUNLOKFLG    (I) = [F:CUD]CUNLOKFLG
    [M:SNU4]STOCOU       (I) = [F:CUD]STOCOU
    If dim([M:SNU4]PALNUM) > 0
       [M:SNU4]PALNUM    (I) = [F:CUD]PALNUM
       [M:SNU4]CTRNUM    (I) = [F:CUD]CTRNUM
    Endif
    If dim([M:SNU4]STOFLD1) > 0
       [M:SNU4]STOFLD1   (I) = [F:CUD]STOFLD1
    Endif
    If dim([M:SNU4]STOFLD2) > 0
       [M:SNU4]STOFLD2   (I) = [F:CUD]STOFLD2
    Endif

    [M:SNU4]QLYCTLDEM    (I) = [F:CUD]QLYCTLDEM
    [M:SNU4]OWNER        (I) = [F:CUD]OWNER
    If dim([M:SNU4]PCUSTUNEW) > 0                                            # hcb 31134
       If [M:SNU4]QTYSTUNEW(I) <> 0 & [M:SNU4]QTYPCUNEW(I) <>0               # hcb 31134
          [M:SNU4]PCUSTUNEW(I) = [M:SNU4]QTYSTUNEW(I) / [M:SNU4]QTYPCUNEW(I) # hcb 31134
       Endif                                                                 # hcb 31134
    Endif                                                                    # hcb 31134

#                                                                                         # hcb 71659 deb
    If [F:CUN]MULCTGFLG = 2
       [M:SNU4]QTYPCUNEW1    (I) = [F:CUD]QTYPCUNEW1
       [M:SNU4]QTYSTUNEW1    (I) = [F:CUD]QTYSTUNEW1
       [M:SNU4]ZERSTOFLG1    (I) = [F:CUD]ZERSTOFLG1
       If [M:SNU4]QTYSTUNEW1 (I) <> 0 & [M:SNU4]QTYPCUNEW1(I) <>0
          [M:SNU4]PCUSTUNEW1 (I) = [M:SNU4]QTYSTUNEW1(I) / [M:SNU4]QTYPCUNEW1(I)
       Endif
       [M:SNU4]QTYPCUNEW2    (I) = [F:CUD]QTYPCUNEW2
       [M:SNU4]QTYSTUNEW2    (I) = [F:CUD]QTYSTUNEW2
       [M:SNU4]ZERSTOFLG2    (I) = [F:CUD]ZERSTOFLG2
       If [M:SNU4]QTYSTUNEW2 (I) <> 0 & [M:SNU4]QTYPCUNEW2(I) <>0
          [M:SNU4]PCUSTUNEW2 (I) = [M:SNU4]QTYSTUNEW2(I) / [M:SNU4]QTYPCUNEW2(I)
       Endif
    Endif
#                                                                                         # hcb 71659 fin


    If [F:ITM]ITMREF <> [F:CUD]ITMREF
       Read [F:ITM]ITM0=[F:CUD]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
    If [F:ITF]STOFCY <> [F:CUD]STOFCY | [F:ITF]ITMREF <> [F:CUD]ITMREF
       Read [ITF]ITF0=[F:CUD]ITMREF;[F:CUD]STOFCY
       If fstat
          Raz [F:ITF]
       Endif
    Endif
    [M:SNU4]STU         (I) = [F:ITM]STU
    [M:SNU4]ABCCLS      (I) = [F:ITF]ABCCLS

    For Y=1 To GNBDIE
        Assign "[M:SNU4]CCE"+num$(Y)+"(I)" With [F:CUD]CCE(Y-1)
    Next
#                                                                             # hcb 110327 deb
    [M:SNU4]SERSEQ       (I) = [F:CUD]SERSEQ
    [M:SNU4]STOFCY       (I) = [F:CUD]STOFCY
    [M:SNU4]CUNSSSNUM    (I) = [F:CUD]CUNSSSNUM
    [M:SNU4]CUNLISNUM    (I) = [F:CUD]CUNLISNUM
    If  [M:SNU4]SERSEQ (I) <> 0 & [M:SNU4]CUNLISSTA (I) = 1 & [M:SNU4]STOCOU  (I) <> 0
        Local Char    LMSK
        Local Integer LLLG
        LMSK = "SNU4"
        LLLG = I
        Gosub VERIF_DESYNCHRO From STKINV1
    Endif
   #                                                                             # hcb 110327 fin
    I += 1
Next

[M:SNU4]NBLIG = I
Filter [CUD]

Return

