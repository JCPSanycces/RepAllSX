#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..20) , VALEUR(30)
Local Char OFONCTION(20)
[L]OFONCTION=[V]GFONCTION
[V]GFONCTION="FUNCFMDLVP"
Call TRAITE_CHAR([L]VALEUR,[L]PARAM,"","FUNCFMDLVP","DCFMDLVP",3,"") From GTRAITE
[V]GFONCTION=[L]OFONCTION
End

#########################################################################
#                                                                       #
#     VALIDATION DES LIVRAISONS PARTIELLEMENT VALIDEES                  #
#                                                                       #
#     - Traitement : FUNCFMDLVP                                         #
#     - Action     : TRTCFMDLVP (Traitement standard)                   #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT_TRTCFMDLVP
 When "INIT"        : Gosub INIT_TRTCFMDLVP
 When "DEBUT"       : Affzo [DIA]1-99
 When "OK"          : GOK=1
 When "END"         : GOK=0 : FIN=1
 When "CONTROLE"    : Gosub CONTROLE_TRTCFMDLVP
 When "EXEC"        : Gosub EXEC_TRTCFMDLVP
 When "TERMINE"     : Gosub TERMINE_TRTCFMDLVP
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTCFMDLVP

# X3-1152 : Non invoiceable deliveries
#GDLVTYP = 5
GDLVTYP = 4
# X3-1152 : Non invoiceable deliveries

#Local Char    STRNUM(GLONVCR), ENDNUM(GLONVCR)         : # BL début et fin

#----- Ouverture des tables et déclaration des variables pour les états -----#
Gosub INIT_ETAT From TRTX3ETA
#-----

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SCDP [DIA]

Raz [M:DIA]

[M]STOFCY=GFCYDEF(7)

Call LECMEMO ("STD","[M:DIA]","vl2") From GMEMO

# Positionner le flag si saisie des paramêtres depuis la gestion des abonnements
[M]ABT=1
If GFONCTION1="GESABA" [M]ABT=2 Endif
Return

#########################################################################
$CONTROLE_TRTCFMDLVP
If GOK < 1  FIN=1 Else TMP=1  Endif

Return

#########################################################################
$EXEC_TRTCFMDLVP

Local Char WCPY(GLONCPY), WFCY(GLONFCY)   : # 96470 : Section analytique non alimentées ds STOJOU
Raz WCPY, WFCY                            : # 96470

# --- Déclaration masque de sauvegarde utilisé par les liv ss-traitance
#     REGWAISTO du FUNRMA ouvre un ecran avec l'abréviation DIA
Local Mask SCDP [DIA1] : Default Mask [DIA]

If !GSERVEUR
# --> ouverture de la trace
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SCDP","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# Bornage de la date de prise en compte des livraisons si la requête est abonnée
# Si date expédition non renseignée, on force la date du jour
#If [M]SHIDAT = [0/0/0] & [M]ABT=2 [M]SHIDAT = date$ : Endif

# 96470 : Section analytique non alimentées ds STOJOU
# --- Chargement des globales référenciels, comptes et sections de la société
If [M:DIA]STOFCY<>""
  Raz GSOC_ACTIVE
  Call GETCPY([M:DIA]STOFCY,"",0,"") From TRTX3CPT
  Call GLOBVAR([M:DIA]STOFCY) From WWGLOBVEN
  WCPY=GSOCIETE : WFCY=[M:DIA]STOFCY
Endif
# 96470

# --> lecture des entêtes de livraison
Gosub TRAITEMENT

Return

#########################################################################
$TERMINE_TRTCFMDLVP

If NBDLV
  If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
    Call PRINT_ETAT (1,WARP_NUMREQ,[M:DIA]NDEDEN) From TRTX3ETA
  Endif
Endif

If !GSERVEUR
    If !NBDLV
      Call ECR_TRACE(mess(48,192,1),0) From GESECRAN
    Endif
# --> fermeture trace
    Call FERME_TRACE From LECFIC
# --> aucune livraison à traiter ou lecture trace
    If !NBDLV
      GERR=2 : GMESSAGE=mess(48,192,1)
    Endif
    TRA=1
Endif

# Si présence module Support Client, impression
#If GMODU(12)=2
#   Call PRINTFLYER(2,STRNUM,ENDNUM,WRET) From TRTMACRULE
#   If WRET GERR=2 : GMESSAGE=mess(WRET,182,1) Endif
#Endif

Return

#-----------------------------------------------------------------------#
# Ouverture des tables                                                  #
#-----------------------------------------------------------------------#
$OUVRE

Local  Integer  OK, STAT
Local  Char     CRITERE(250), SYMBOLE(50),SYMBOLE2(50)
Local  Decimal  COEFF, WLIN
Local  Integer  WMOD, WRET, NBDLV

Local File SDELIVERY [SD2]
If !clalev ([F:SDH]) : Local File SDELIVERY  [SDH] : Endif
If !clalev ([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
If !clalev ([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev ([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev ([F:STA]) : Local File STOALL     [STA] : Endif
If !clalev ([F:STO]) : Local File STOCK      [STO] : Endif
If !clalev ([F:STL]) : Local File STOLOT     [STL] : Endif
If !clalev ([F:STS]) : Local File STOSER     [STS] : Endif
If !clalev ([F:SOQ]) : Local File SORDERQ    [SOQ] : Endif
If !clalev ([F:REO]) : Local File STOREO     [REO] : Endif
If !clalev ([F:MVC]) : Local File BPCUSTMVT  [MVC] : Endif
If !clalev ([F:LCM]) : Local File LASTCUSMVT [LCM] : Endif
If !clalev ([F:ARP]) : Local File AREPORT    [ARP] : Endif
If !clalev ([F:BPD]) : Local File BPDLVCUST  [BPD] : Endif
If !clalev ([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If !clalev ([F:SOH]) : Local File SORDER     [SOH] : Endif

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK   [ORDK] : Raz [M:ORDK]

# Issue X3-41004 - 2017-05-29 by CPO : Analyze mass delivery validation to increase performance - Spike 2
#--opening once all tables/masks needed in VALIDATION.TRTVENLIVV
#--opened in Subprog VALIDATION from TRTVENLIVV
If !clalev ([F:ITS]) : Local File ITMSALES   [ITS] : Endif
If !clalev ([F:STJ]) : Local File STOJOU     [STJ] : Endif
If !clalev ([F:SOH]) : Local File SORDER     [SOH] : Endif
If !clalev ([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev ([F:SRU]) : Local File TABSTORUL  [SRU] : Endif
#DLUBPC
If !clalev ([F:ITU]) : Local File ITMBPC  [ITU] : Endif

If GMODU(6)=2 & clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif

If !clalev([F:SPH]) : Local File SPACK     [SPH] : Endif
If !clalev([F:SPD]) : Local File SPACKD    [SPD] : Endif
If !clalev([F:PRH]) : Local File STOPREH   [PRH] : Endif
If !clalev([F:PRL]) : Local File STOPRELIS [PRL] : Endif
If !clalev([F:CAL]) : Local File CPTANALIN [CAL] : Endif
If !clalev([F:SVF]) : Local File SVCRFOOT  [SVF] : Endif
If !clalev([F:SVV]) : Local File SVCRVAT   [SVV] : Endif
If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif

# Classe écran pour les encours
If !clalev([M:ORDK]) : Local Mask ORDK       [ORDK] : Endif
# Classe écran pour le moteur de maj
If !clalev([M:STW])  : Local Mask STOWORK    [STW]  : Endif
If clalev([M:SVW])=0
    Local Mask STOVALWORK [SVW]
Endif
Raz [M:SVW]
#--opened in $TRT1.TRTVENLIVV called from VALIDATION
If clalev ([F:TSD])=0 : Local File TABSDHTYP [TSD]  : Endif
If clalev ([F:TCA])=0 : Local File TABCOUAFF [TCA]  : Endif
If clalev([F:AOX]) =0 : Local File AOBJTXT   [AOX]  : Endif
If clalev([F:AOM]) =0 : Local File AOBJTXTA  [AOM]  : Endif
If clalev([F:ABB]) =0 : Local File ABLOB     [ABB]  : Endif
If clalev([F:ACB]) =0 : Local File ACLOB     [ACB]  : Endif
If clalev([F:BOLH])=0 : Local File BILLLADH  [BOLH] : Endif  # 101090.n
If clalev([F:BOLC])=0 : Local File BILLLADC  [BOLC] : Endif  # 101090.n
#--opened in $MAJ_ALL_SCO.TRTVENLIVV called from VALIDATION
If !clalev([F:STJ1])  : Local File STOJOU    [STJ1] : Endif
If !clalev([F:STO1])  : Local File STOCK     [STO1] : Endif
If !clalev([F:SCM])   : Local File SCOMAT    [SCM]  : Endif
If GMODU(8)=2
   If !clalev([F:MFM]) Local File MFGMAT [MFM] Endif
Endif
#--opened in $TRT_MACRULE.TRTVENLIVV called from VALIDATION
If !clalev ([M:MACW]) : Local Mask MACW [MACW]    : Endif
If !clalev ([F:CCV8]) : Local File CONTCOV [CCV8] : Endif # FGR 28/10/2015 : X3SUIVI112034
#--
# End issue X3-41004

# v6 affectations
Gosub OPEN_MTO From MTOLINKLIB

TIT = mess(34,191,1)  : # Validation Livraisons

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

Local Integer  WCDTUNL
#------------------------------------------------------------#
# Chargement flag déblocage crédit autorisé                  #
#------------------------------------------------------------#
Local Char WPARAM(10)
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif

Return

#-----------------------------------------------------------------------#
# Traitement de validation des livraisons                               #
#-----------------------------------------------------------------------#
$TRAITEMENT
Local Char     WSTOFCY(GLONFCY), PADMIN

Raz WSTOFCY

# Récupération paramètre administrateur stock
Call PARAMUTIL("STOADMIN",PADMIN,"","") From SUBAUS
GSTOADMIN = val(PADMIN)

# Constitution du filtre des entêtes livraison
CRITERE = "INVFLG=1 & CFMFLG=1"

If [M:DIA]CPY <> ""     : CRITERE -= '& CPY = "' +[M:DIA]CPY+ '"'       : Endif
If [M:DIA]STOFCY <> ""  : CRITERE -= '& STOFCY = "' +[M:DIA]STOFCY+ '"' : Endif

#---------------------------------------------------------------------#
# Point d'entree ajout filtres supplémentaires                        #
#---------------------------------------------------------------------#
Local Char FILSUP (250)
FILSUP="1=1"
GPOINT="CFMDLVFIL" : Gosub ENTREE From EXEFNC

# Lecture des livraisons et traitement
For [SD2] Hint Key SDH3 Where (evalue(CRITERE) & evalue (FILSUP))

   OK = 2
   # Livraisons non validées avec au moins une ligne validée
   Filter [SDD] Where SDHNUM=[F:SD2]SDHNUM & LINCFMFLG=2
   If rowcount([SDD])=0 : OK=1 : Endif
   Filter [SDD]
   If OK=1 Goto NEXT_SD2 Endif

   # Pour vérifier si la livraison est validable
   GPOINT="CFMDLVSEL" : Gosub ENTREE From EXEFNC
   If OK=1 Goto NEXT_SD2 Endif

   # 96470 : Section analytique non alimentées ds STOJOU
   #Call GETDEV([F:SD2]SALFCY)  From DEVSUB    : # Bug 61533
   If WFCY<>[F:SD2]SALFCY
      # --- Chargement des globales référenciels, comptes et sections de la société
      Call GETCPY([F:SD2]SALFCY,"",0,"") From TRTX3CPT
      Call GLOBVAR([F:SD2]SALFCY) From WWGLOBVEN : # Bug 61533
      WCPY=GSOCIETE : WFCY=[F:SD2]SALFCY
   Endif
   # 96470

   # Contrôle du client
   #Gosub VERIF_BPC
   #If OK=1 Goto NEXT_SD2 : Endif

   NBDLV +=1
   SYMBOLE = "SDH"+[F:SD2]SDHNUM
   Lock = SYMBOLE With lockwait=0
   If fstat=1
      # Modification en cours sur un autre poste
      Call ECR_TRACE([F:SD2]SDHNUM-mess(10,100,1),1) From GESECRAN
   Else
      If [F:SD2]SCO=2 [M:DIA1]=[M:DIA] : Close Local Mask [DIA] : Default Mask [DIA1] : Endif
      Call VALIDATION([F:SD2]SDHNUM) From TRTVENLIVV
      If [F:SD2]SCO=2 Local Mask SCD1 [DIA] : [M:DIA]=[M:DIA1] : Default Mask [DIA] : Endif
      If GOK=1
         If [F:SD2]CFMFLG=2
            If [M:DIA]NDEFLG=2 & [M:DIA]NDENAM<>"" & [M:DIA]NDEDEN<>""
               #----- Recherche du nouveau code état à partir du modèle -----#
               If [F:BPC]BPCNUM<>[F:SD2]BPCORD
                  Read [BPC] BPC0=[F:SD2]BPCORD : If fstat  Raz [F:BPC] : Endif
               Endif
               If [F:BPC]TPMCOD<>""
                  If [F:TPM]TPMCOD<>[F:BPC]TPMCOD
                     Read [TPM] TPM0=[F:BPC]TPMCOD : If fstat  Raz [F:TPM] : Endif
                  Endif
                  If [F:TPM]SALDLV<>""
                     WARP_RPTCOD(0)=[F:TPM]SALDLV
                  Else
                     WARP_RPTCOD(0)=[M:DIA]NDENAM
                  Endif
                  WARP_NBRCPY=[F:SD2]COPNBR #Gbn-Fq73266
               Else
                  WARP_RPTCOD(0)=[M:DIA]NDENAM
                  WARP_NBRCPY=[M:DIA]PRTCOP #Gbn-Fq73266
               Endif
               #----- Nombre de copies -----#
               # Si modèle d'édition, nbr copie du modèle stocké à la création de la livraison
               # Sinon, nbre de copie de la destination
               #WARP_NBRCPY=[F:SD2]COPNBR#Gbn-Fq73266
               #----- Ecriture AREPORTM et màj indicateur d'impression sur entête facture -----#
               Call ALIM_ETAT(1,WARP_NBRCPY,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ) From TRTX3ETA
               #-----
            Endif

            If GMODU(12)=2
               # Alimentation des bornes min et max des livraisons traitées
               If STRNUM=""
                  STRNUM=[F:SD2]SDHNUM
               Elsif STRNUM>[F:SD2]SDHNUM
                  STRNUM=[F:SD2]SDHNUM
               Endif
               If ENDNUM=""
                  ENDNUM=[F:SD2]SDHNUM
               Elsif ENDNUM<[F:SD2]SDHNUM
                  ENDNUM=[F:SD2]SDHNUM
               Endif
            Endif
         Endif
      Endif
      Unlock =SYMBOLE
   Endif

$NEXT_SD2
Next
Return

#########################################################################
# Actions champs                                                        #
#########################################################################

########################################
Subprog D_CPY(VALEUR)
Variable Char    VALEUR()
Call GETSOC (GFCYDEF(7)) From DEVSUB   : # init avec societe du site stock par defaut
VALEUR=GSOCIETE
[M]STOFCY=GFCYDEF(7)
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
GSOCIETE=VALEUR
Raz [M]STOFCY
End

########################################
Subprog AP_NDEFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Raz [M]NDENAM, [M]NDEDEN, [M]NDEIMP, [M]NDESRV
   Diszo [M]NDENAM, NDEDEN
Else
  If vireblc([M]NDENAM,2)=""
#     Call INIT_IMP("SDH", [M]NDENAM, [M]NDEIMP) From TRTVENIMP
     Call INIT_ARP("SDH", [M]NDENAM) From TRTVENIMP
     Actzo [M]NDENAM, NDEDEN
  Endif
Endif
Affzo [M]NDENAM, NDEDEN, NDEIMP, NDESRV
End

########################################
Subprog C_NDENAM(VALEUR)
Variable Char    VALEUR()
Local    Char    AUTSIT(10)
Local    Integer OK
# Document obligatoire si impression bon de preparation
If [M:DIA]NDEFLG = 2 & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
   End
Endif
End

Subprog AM_NDENAM(VALEUR)
Variable Char    VALEUR()

  # FGR 28/01/2015 : X3SUIVI105740
  If VALEUR <> [M]NDENAM Then
    Raz [M]NDEDEN
    Affzo [M]NDEDEN
  Endif
End

########################################
Subprog C_NDEDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M:DIA]NDENAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

Subprog AP_NDEDEN(VALEUR)
Variable Char    VALEUR()
Call INIT_SRV(VALEUR, [M]NDESRV,[M]NDEIMP) From TRTVENIMP
Affzo [M]NDESRV, NDEIMP
[M:DIA]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM(VALEUR)#Fq73266-Gbn
End

########################################
Subprog C_NDESRV(VALEUR)
Variable Char    VALEUR()
Gosub CTL_SRV From TRTVENIMP
End

########################################
Subprog C_NDEIMP(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression
If [M:DIA]NDENAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

########################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

########################################

