#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour champ KEYDUP dans la table AVIEWC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update KEYDUP field in AVIEWC file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub INIFLD
End

#-------------------#
$INIFLD

Local File =DOSSIER+".AVIEWC"   [AVC] 

If dim([F:AVC]KEYDUP)<=0
 Close Local File [AVC]
 Return 
Endif

# Mise à jour de la table AVIEWC
Call ECR_TRACE(mess(81,125,1)-"AVIEWC:"-time$,0) From GESECRAN
Trbegin [AVC]
 For [AVC]AVC0
  If [F:AVC]KEYDUP=0
   [F:AVC]KEYDUP = 2
   Rewrite [AVC]
   If fstat
    Call ERREUR("AVIEWC"-[F:AVC]CODVUE-[F:AVC]CODCLE,2) From DOSDIC
   Endif 
  Endif
 Next
Commit

Close Local File [AVC]

Return
