# Call VALIDATION("LOFCIM","LOFCIM1",nomap) From GENEVETRT6
End
# X3-41592 Dossier d'indus correspondant au dossier de ref
################################################################################
#    Sous-programme de gÃĐnÃĐration des traitement d'alimentation des ÃĐvÃĐnements
#    Ã  partir du contenu des tables PAREVT et PAREVTD.
#    GBN
#    CrÃĐation le : 09/08/2007
#    Modification le : xx/xx/xxxx
#    version SYRACUSE
#
# CBO   25.09.2017 X3-41592    : Dossier d'indus correspondant au dossier de ref
################################################################################
#**
#*
#*
#* @param PEVT
#* @param PEVTINT
#* @param APPLI_PARAM     appli ou se trouve le paramÃĐtrage (TABLES PAREVT et PAREVTD)
#* @param APPLI_TRT       appli ou se trouvent les sources et traitements gÃĐnÃĐrÃĐs
#*!
Subprog VALIDATION(PEVT, PEVTINT, APPLI_PARAM, APPLI_TRT)
Value Char    PEVT()
Value Char    PEVTINT()
Value Char    APPLI_PARAM()
Value Char    APPLI_TRT()

Local Char    NOMTRT(30)
Local Char    FICSRC(250)
Local Char    CODOBJ(30)
Local Integer OK, I_EVTINT, I_CHEVT, REFOBJ, T_NBFLDPRORAT
Local Char    EVTINT(10)(1..100)
Local Char    EVTNAM(30)
Local Char    EVTTAB(30)
Local Integer I_CODACT
Local Integer LCODACT
Local Char    LGLOACT(30)
Local Char DUP_DES(250)


  If !clalev([F:ADI])  : Local File =APPLI_PARAM+".ATABDIV" [ADI] : Endif
  If !clalev([F:GVTR]) : Local File =APPLI_PARAM+".PAREVT"  [PVT] : Endif
  If !clalev([F:GVDA]) : Local File =APPLI_PARAM+".PAREVTD" [PVD] : Endif

  If !clalev([F:ATZ])  : Local File =APPLI_PARAM+".ATABZON" [ATZ] : Endif


  #> Ouverture du fichier source Ã  gÃĐnÃĐrer : GV+pevtint.src
  #  ------------------------------------------------------

  NOMTRT = "GVS" + PEVTINT # "S"               # S comme SYRACUSE
  FICSRC = filpath("TRT", NOMTRT, "src", APPLI_TRT)
  Openo FICSRC, 0
  adxifs = ""
  adxirs = chr$(10)

  #> Lecture de la table diverse
  #  ---------------------------

  Read [F:ADI]CODE = [V]CST_TD_EVENT; PEVT
  EVTTAB = [F:ADI]A2
  REFOBJ = [F:ADI]N2


  #> Lecture de la table de paramÃĐtrage
  #  ----------------------------------

  Read [F:PVT]PVT1 = PEVT; PEVTINT

  #> En-tÃŠte
  #  -------

  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# MODIFIE PAR :'-GUSER
  Wrseq '# LE          :'-format$("DD4",date$)
  Wrseq ''

  #> Ouverture des tables
  #  --------------------

  Wrseq ''
  Wrseq ''
  Wrseq '$OUVRE_TABLE'
  Wrseq ''
  Wrseq '  If dim(APPLI_PARAM) < 0'
  Wrseq '    Local Char APPLI_PARAM(30)'
  Wrseq '    APPLI_PARAM = nomap'
  Wrseq '  Endif'
  Wrseq '  Local File =APPLI_PARAM+".' + EVTTAB + '" [EVT0]'
  Wrseq '  Local File =APPLI_PARAM+".' + EVTTAB + '" [EVT1]'
  Wrseq ''
  Wrseq 'Return'
  Wrseq ''
  Wrseq ''

  #> Alimentation des champs propres Ã  l'ÃĐvÃĐnement
  #  -----------------------------------------------------

  Wrseq'$EVTINT'
  Wrseq ''
  Filter [PVD] Where (EVTINT = PEVTINT and FLDNAM = "DES") # Zone dÃĐsignation

  Wrseq'  #'+string$(2,'-')+'> DÃĐsignation'

  OK = 1
  For [PVD]
    If [F:PVD]FLDFIL <> ""

      Read [F:ATZ]CODZONE= [F:PVT]TABEVT; [F:PVD]FLDNAM

      If [F:ATZ]CODTYP = "AXX"
        Gosub TRT_DES_AXX
        If OK = 0
          Break
        Endif

      Else
        Wrseq'  [F:EVT0]DES' + space$(18 - len("[F:EVT0]DES")) - '=' - [F:PVD]FLDFIL
      Endif
    Endif
  Next

  If OK = 0
    End
  Endif

  Wrseq ''

  #> Menus locaux

  Filter [PVD] Where (EVTINT = PEVTINT and (FLDTYP = 1 or FLDTYP = 2))
  Raz I_CHEVT
  Wrseq'  #'+string$(2,'-')+'> Menus locaux'
  For [PVD]PVD2
    If [F:PVD]FLDFIL <> ""

      If [F:PVD]FLDACT <> ""
        Wrseq '  If func AFNC.ACTIV("' + [F:PVD]FLDACT + '")'
        Wrseq '    [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
        Wrseq '  Endif'
      Else
        Wrseq'  [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
      Endif
      I_CHEVT += 1
    Endif
  Next
  Wrseq ''

  #> NumÃĐriques

  Filter [PVD] Where (EVTINT = PEVTINT and FLDTYP = 4)
  Raz I_CHEVT
  Wrseq'  #'+string$(2,'-')+'> Zones numÃĐriques'
  For [PVD]PVD2
    If [F:PVD]FLDFIL <> ""
      If [F:PVD]FLDACT <> ""
        Wrseq '  If func AFNC.ACTIV("' + [F:PVD]FLDACT + '")'
        Wrseq '    [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
        Wrseq '  Endif'
      Else
        Wrseq'  [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
      Endif
      I_CHEVT += 1
      If [F:PVD]FLDPRORAT = [V]CST_AYES
        T_NBFLDPRORAT +=1
      Endif
    Endif
  Next
  Wrseq ''

  #> AlphanumÃĐriques

  Filter [PVD] Where (EVTINT = PEVTINT and FLDTYP = 7 and FLDNAM <> "DES")
  Raz I_CHEVT
  Wrseq'  #'+string$(2,'-')+'> Zones alphanumÃĐriques'
  For [PVD]PVD2
    If [F:PVD]FLDFIL <> ""
      If [F:PVD]FLDACT <> ""
        Wrseq '  If func AFNC.ACTIV("' + [F:PVD]FLDACT + '")'
        Wrseq '    [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
        Wrseq '  Endif'
      Else
        Wrseq '  [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
      Endif
      I_CHEVT += 1
    Endif
  Next
  Wrseq ''

  #> Dates

  Filter [PVD] Where (EVTINT = PEVTINT and FLDTYP = 8)
  Raz I_CHEVT
  Wrseq'  #'+string$(2,'-')+'> Dates'
  For [PVD]PVD2
    If [F:PVD]FLDFIL <> ""
      If [F:PVD]FLDACT <> ""
        Wrseq '  If func AFNC.ACTIV("' + [F:PVD]FLDACT + '")'
        Wrseq '    [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
        Wrseq '  Endif'
      Else
        Wrseq '  [F:EVT0]' + [F:PVD]FLDNAM + space$(10-len([F:PVD]FLDNAM)) - '=' - [F:PVD]FLDFIL
      Endif
      I_CHEVT += 1
    Endif
  Next
  Filter [PVD]
  Wrseq ''
  Wrseq'Return'
  Wrseq ''
  Wrseq ''

  #> Liste des champs numÃĐriques Ã  ÃĐclater
  #  -------------------------------------

  Local Integer NBUSRFLD : NBUSRFLD = 6
  Wrseq '$ECLATE_NBFLD'
  Wrseq ''
  Wrseq '  LNBFLD =' - num$(T_NBFLDPRORAT - NBUSRFLD)
  Wrseq ''
  Wrseq 'Return'
  Wrseq ''

  Wrseq '$ECLATE_STATUS'
  Wrseq ''
  Local Integer I_ZON
  Filter [PVD] Where (EVTINT = PEVTINT and FLDTYP = 4 and FLDPRORAT = [V]CST_AYES) and left$(FLDNAM, 6) <> "USRFLD"
  For [PVD]
    Wrseq '  T_INTNOMZON(' + num$(I_ZON) + ') ' + space$(4-len(num$(I_ZON))) + '= "' + [F:PVD]FLDNAM +'"'
    I_ZON += 1
  Next
  Filter [PVD]
  Wrseq ''
  Wrseq 'Return'
  Wrseq ''
  Wrseq ''

  #> Infos diverses sur l'ÃĐvÃĐnement
  #  ------------------------------

  Wrseq '$INFO_EVTINT'
  Wrseq ''
  Wrseq '  PEVENT.EVT    = "' + PEVT + '"'
  Wrseq '  PEVENT.PLAN    = ' + num$([F:PVT]PLN)  # remplace LPLN
  Wrseq '  PEVENT.TABNAME = "' + EVTTAB + '"'
  Wrseq '  PEVENT.JOB_OBJ = ' + num$([F:PVT]OBJTYP)
  Wrseq ''
  Wrseq 'Return'
  Wrseq ''

  #> Fin de la gÃĐnÃĐration du fichier source POBJECT.NAME = EVT
  #  --------------------------------------

  Openo

  # Compilation du traitement associÃĐ au code interne
  #  ------------------------------------------------

  Call VALID("TRT", NOMTRT, APPLI_TRT, OK) From VALMSKSUB
  If OK = 0
    Local Char MESSAGE_ERR(100)
    MESSAGE_ERR="Erreur de compilation du traitement SYRACUSE" - NOMTRT - APPLI_TRT
    If GTRACE <> ""
      Call ECR_TRACE (MESSAGE_ERR, 1) From GESECRAN
    Else
      Infbox MESSAGE_ERR
    Endif
    End
  Endif

  Call MAJ_TRT_DICO(NOMTRT, APPLI_TRT, PEVTINT, OK)
  # Marquage correction.
  Local Integer B_ADCOPN : B_ADCOPN = 0
  If !clalev([F:ADC])  : Local File ADICTRT [ADC] : B_ADCOPN = 1  : Endif
  Call MAJ(NOMTRT, "", 14, "") From SUBADC
  If (B_ADCOPN) Then
    Close File [F:ADC]
  Endif

End

# dupliquer la dÃĐsignation traductible de l'objet vers la table d'evt donc de ATEXTRA
$TRT_DES_AXX

#Subprog DUPTEXTRA(TABORG,FLDORG,CLEORG1,CLEORG2,TABDES,FLDDES,CLEDES1,CLEDES2)

  OK = 1
  Wrseq '  Local File =APPLI_PARAM+".ATEXTRA" [AXX]'

  DUP_DES  = '  Call DUPTEXTRA('

  Case [F:PVT]OBJTYP
    When [V]CST_OMPHY
      DUP_DES += '"PHYELT", '
      DUP_DES += '"PHYDES1", '

      DUP_DES += 'POBJ.PHYREF, '
      DUP_DES += '"",'


#          When [V]CST_OMDEPEN
#            DUP_DES += '"LAYOUTFAS", '
#            DUP_DES += '"DES", '
#
#            DUP_DES += '"' + CLEORG1 + '", '
#            DUP_DES += '"' + CLEORG2 + '", '
#          When [V]CST_OMBIEN
#            DUP_DES += '"FXDASSETS", '
#            DUP_DES += '"AASDES1", '
#
#            DUP_DES += '"' + CLEORG1 + '", '
#            DUP_DES += '"' + CLEORG2 + '", '

    When Default
      OK = 0
      Local Char MESSAGE_ERR(100)
      MESSAGE_ERR = "GENEVETRT6 :" - mess([F:PVT]OBJTYP, 3141, 1) -": Traduction DES non programmÃĐe"
      If GTRACE <> ""
        Call ECR_TRACE (MESSAGE_ERR, 1) From GESECRAN
      Else
        Infbox MESSAGE_ERR
      Endif
      Return
  Endcase

  Wrseq DUP_DES

  DUP_DES = AVOID.ACHAR
  DUP_DES = '&  "' + [F:PVT]TABEVT + '", '
  DUP_DES += '"DES", '
  DUP_DES += 'PEVENT.REF, '
  DUP_DES += 'PEVENT.TIMSTP'
  DUP_DES += ') From ATEXTRA'
  Wrseq DUP_DES

  Wrseq '  Close File [AXX]'

Return

#=====================
$TRT_COD_ACT
  # GCODACTABX3 et GGLOACTABX3 dÃĐclarÃĐes dans SUBPVT
#  If func AFNC.ACTIV([F:PVD]FLDACT)
 I_CODACT = find([F:PVD]FLDACT, GCODACTABX3)
 If I_CODACT
  LCODACT = G_OUI
  LGLOACT = GGLOACTABX3(I_CODACT)
 Endif
Return

################################################################################
#    Sous-programme de mise Ã  jour du dictionnaire de traitement
#    GBN
#    CrÃĐation le : 09/08/2007
#    Modification le : xx/xx/xxxx
#
################################################################################
Subprog MAJ_TRT_DICO(PNOMTRT, PAPPLI, PEVTNAM, POK)
Value    Char PNOMTRT
Value    Char PAPPLI()
Value    Char PEVTNAM()
Variable Integer POK

  If !clalev([F:ADC])
    Local File =PAPPLI+".ADICTRT" [ADC]
  Endif

GOK=1

Trbegin [ADC]

Delete [ADC] Where CODTRT=PNOMTRT

Raz [F:ADC]
[F:ADC]CODTRT = PNOMTRT
[F:ADC]DES    = "GÃĐnÃĐration des ÃĐvÃĐnements"
[F:ADC]MODULE = 14
[F:ADC]CODACT = ""
[F:ADC]SRC    = G_NON
[F:ADC]CREDAT = date$
[F:ADC]CREUSR = GUSER
[F:ADC]UPDDAT = date$
[F:ADC]UPDUSR = GUSER

Write [F:ADC]
If fstat
 GOK=0
Endif

If GOK=1
 Commit
Else
 Rollback
Endif

End

