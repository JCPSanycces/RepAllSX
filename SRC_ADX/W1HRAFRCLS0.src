#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRAFRCLS0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:34"
A_USER  = "DOC"
A_STAMP = "20181109230434"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRAFRCLS0 [HRAC0]
Gosub HORODAT
Local Inpbox "HRAFRCLS0" From GFONCTION At A_STAMP With A_WINDPREV Mask [HRAC0] As [SIM_]
Grizo [HRAC0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HRAC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=4
Return

$ON_REFNUM
Return

$ON_CTRNUM
Return

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1HRAFRCLS0
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT4
Gosub _AFF
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1HRAFRCLS0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1HRAFRCLS0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


