#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(20)(1..10)
PARAM(1) = num$(0)
PARAM(2) = "GAL"
PARAM(3) = "AHCB_STLOSLTI"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
Call GCONSULT("SDE","",PARAM) From GCONSULT
End


# Attention ne pas transférer en version 120 (Ecrans modifiés)
$ACTION
Case ACTION
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSDE] : Transmask [M:SDE1] To [M:CSDE] # Issue 25606 [M:CSDE] = [M:SDE1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When "CLECUR"     : Gosub CLECUR
  When Default
Endcase
Return
############################################################
$OUVRE
If clalev([F:STL1]) = 0 : Local File STOLOT     [STL1] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR     [TFO]  : Endif
If clalev([F:STS])  = 0 : Local File STOSER     [STS]  : Endif  # Issue 110327
If clalev([F:LPN])  = 0 : Local File LPN        [LPN]  : Endif  # hcb x3-68149


#
Local Char    WFIL(250), WFILTRI(250), WFIL1(250)     # hcb X3-69570
Local Char    WCAT(20)
Local Char    WFILS(250)
Local Char    WFILFOR(250)
Local Char    WFILSPE(250)
Local Char    WLOT(GLONLOT)
Local Char    WLOC(GLONLOC)
Local Char    WPAL(GLONPAL)
Local Char    WLPN(GLONLPN)    # hcb x3-68850
Local Integer WFSTAT, WREAD, WSKIP, WLIG, SVGMAXLIG, WAGR
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I, J, K, WNOL
Local Decimal WCUMQTYSTU, WCUMQTYACT
Local Char    DLOT(GLONLOT), FLOT(GLONLOT)
Local Char    DSLO(GLONSLO), FSLO(GLONSLO)
Local Char    DSTA(GLONSTA), FSTA(GLONSTA)
Local Char    DPCU(GLONUOM), FPCU(GLONUOM)
Local Char    DLOC(GLONLOC), FLOC(GLONLOC)
Local Char    DPAL(GLONPAL), FPAL(GLONPAL)    # hcb 59291
Local Char    DITM(GLONITM), FITM(GLONITM)    # hcb 59291
Local Char    DLPN(GLONLPN), FLPN(GLONLPN)   # hcb x3-68850

Local Decimal DCOU, FCOU, DSTOCOU   # hcb 81362
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSDE"
SUITE  = 1
RETOUR = 1
Return
############################################################
# Issue 110327
$DEB_CRIT
[M:CSDE] = [M:SDE1]
If [F:ITM]SERMGTCOD <> 3
 Raz   [M:CSDE]SERNUMSTR
 Raz   [M:CSDE]SERNUMEND
 Affzo [M:CSDE]SERNUMSTR
 Affzo [M:CSDE]SERNUMEND

 Diszo [M:CSDE]SERNUMSTR
 Diszo [M:CSDE]SERNUMEND
Else
 Actzo [M:CSDE]SERNUMSTR
 Actzo [M:CSDE]SERNUMEND
Endif
Return
############################################################
$FIN_CRIT
[M:SDE1]FLG = 0
[M:SDE1]    = [M:CSDE]
Return
############################################################
$AP_MAGNETO
[M:SDE1]FLG = 0
Return
############################################################
$CLECUR
#If CLECUR=1                              # hcb 27082
#   [M:SDE1]ITMDES1 = [F:ITM]ITMDES1      # hcb 27082
#   Affzo [M:SDE1]ITMDES1                 # hcb 27082
#Endif                                    # hcb 27082
Return
############################################################
$SETBOUT
If [M:SDE1]SELFLG = 0
  Call VIREBOUT(CHAINE,"c") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case BOUT
  When "a", "b" :
    [M:SDE1]FLG = 0
  When "c" :
    If nolign > 0
      If dim([M:SDE2]LOT)> 0
        PARAM(7) = [M:SDE2]LOT(nolign-1)
      Else
        PARAM(7) = ""
      Endif
      If dim([M:SDE2]LOC)> 0
        PARAM(8) = [M:SDE2]LOC(nolign-1)
      Else
        PARAM(8) = ""
      Endif
      REPONSE = GSTAFIN
    Endif
  Endcase
Return
############################################################
$FERME
If clalev([F:STO1]) <>  0 : Filter [STO1] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDE1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDE1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) <> "" & dim([M:SDE1]LOTSEL) > 0
        [M:SDE1]LOTSEL = PARAM(I)
      Endif
    When 5 :
      [M:SDE1]SELFLG = val(PARAM(I))
    When 6 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
    When 9 :
      If PARAM(I) <> ""
        Call LECTURE("WRH",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SDE1] = [F:WRH]
        Endif
      Endif
  Endcase
Next I
If clalev([M:CSDE]) <> 0 & [M:CSDE]MEMO = "STD"
  [M:SDE1] = [M:CSDE]
  Return
Endif
If dim([M:SDE1]LOTFLG)>1
    If !find([M:SDE1]LOTFLG,3,4)
        If dim([M:SDE1]LOTFLG) < 0
          [M:SDE1]SRTCOD = 4
        Else
          [M:SDE1]SRTCOD = 3
        Endif
    Endif
Endif
If !find([M:SDE1]AGGFLG,1,2)    : [M:SDE1]AGGFLG= 2    : Endif
If !find([M:SDE1]LOCCAT001,1,2) : [M:SDE1]LOCCAT001= 2 : Endif
If !find([M:SDE1]LOCCAT002,1,2) : [M:SDE1]LOCCAT002= 2 : Endif
If !find([M:SDE1]LOCCAT003,1,2) : [M:SDE1]LOCCAT003= 2 : Endif
If !find([M:SDE1]LOCCAT004,1,2) : [M:SDE1]LOCCAT004= 2 : Endif
If !find([M:SDE1]LOCCAT005,1,2) : [M:SDE1]LOCCAT005= 1 : Endif
If !find([M:SDE1]CUMFLG,1,2)    : [M:SDE1]CUMFLG   = 1 : Endif
If find([M:SDE1]SVGMAXLIG,0)    : [M:SDE1]SVGMAXLIG=dim([M:SDE2]STOFCY) : Endif
Return
############################################################
$LECTURE
If CHGPAG = 3   #  hcb 81362
  Raz DSTOCOU
Endif

Raz [M:SDE1]SVGMAXLIG, SVGMAXLIG
If [M:SDE1]ITMREF = ""
  NBLU = 0
  Return
Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 & [M:SDE1]CUMFLG=1 : NOL = MAXLIG   : Endif
If CHGPAG<0 & [M:SDE1]CUMFLG=2 : NOL = MAXLIG-1 : Endif
If SVGMAXLIG=0
    SVGMAXLIG=MAXLIG
Endif
If MAXLIG<>SVGMAXLIG
  MAXLIG=SVGMAXLIG
Endif
If [M:SDE1]CUMFLG=2
  MAXLIG-=1
Endif
[M:SDE1]SVGMAXLIG=MAXLIG
# Si modification d'un critère : nouvelle requête
Gosub TRT_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
If [M:SDE1]CUMFLG=2 & CHGPAG=1
  Gosub CAL_CUMUL
Endif
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    #--------------------#
    # Critère de lecture #
    #--------------------#
#--- Bug 70210
#        Case [M:SDE1]SRTCOD
#            When 4 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO4 Asc
#            When 5 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                            Order By STOFCY;ITMREF;STA;LOT;SLO;LOC
#
#            When 6 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                            Order By STOFCY;ITMREF;PCU;LOT;SLO;LOC
#            When 12 :                                                        # hcb 59291
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO1 Asc
#            When Default :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO3 Asc
#        Endcase
#                                                                    # hcb X3-69570   rajout WFIL1
        Case [M:SDE1]SRTCOD
            When 4 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY;ITMREF;LOC;STOCOU Asc
            When 5 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY;ITMREF;STA;STOCOU Asc
            When 6 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY;ITMREF;PCU;STOCOU Asc
            When 12 :                                                        # hcb 59291
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY;ITMREF;PALNUM;STOCOU Asc
            When Default :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY;ITMREF;LOT;SLO;STOCOU Asc
        Endcase
#---
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    #--------------------#
    # Critère de lecture #
    #--------------------#
#--- Bug 70210
#        Case [M:SDE1]SRTCOD
#            When 4 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO4 Desc
#            When 5 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                            Order By STOFCY;ITMREF;STA Desc;LOT Desc; SLO Desc;LOC Desc
#            When 6 :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                            Order By STOFCY;ITMREF;PCU Desc;LOT Desc;SLO Desc;LOC Desc
#            When 12 :                                                        # hcb 59291
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO1 Desc
#            When Default :
#              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR)
#&                           Order By Key STO3 Desc
#        Endcase
#                                                                              # hcb X3-69570 rajout WFIL1
        Case [M:SDE1]SRTCOD
            When 4 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY; ITMREF; LOC Desc; STOCOU Desc
            When 5 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY; ITMREF; STA Desc; STOCOU Desc
            When 6 :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY; ITMREF; PCU Desc; STOCOU Desc
            When 12 :                                                        # hcb 59291
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY; ITMREF; PALNUM Desc; STOCOU Desc
            When Default :
              Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILTRI) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                           Order By STOFCY; ITMREF; LOT Desc; SLO Desc; STOCOU Desc
        Endcase
#---
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:SDE2] : Endif
Raz [F:STO1]
$BOUCLE
For [STO1]
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:SDE2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL =MAXLIG-1 : Gosub AGREG : Endif
     If NOL >=MAXLIG-1 & WAGR=0 : SUITE=2 : Break : Endif
  Else
     If NOL <0 : Gosub AGREG : Endif
     If NOL =0 : RETOUR=2 : Break : Endif
  Endif
  #--- Issue 121951
  #Gosub LOA_LIGNE
  GPE=0
  GPOINT="LOAD_STOCK" : Gosub ENTREE From EXEFNC
  If GPE<>1
    Gosub LOA_LIGNE
  Endif
  #---
Next
If NOL<0 & CHGPAG>0 Return : Endif
$LECTURE_FIN
If [M:SDE1]CUMFLG=2
  If CHGPAG=-2
      WLIG=SVGMAXLIG-1
  Elsif CHGPAG=-1
  Else
      NOL += 1
      WLIG = NOL
  Endif
  nolign=WLIG+1
  If WLIG<>0
      Gosub AFF_CUMUL
  Endif
Endif
[M:SDE2]NBLIG=SVGMAXLIG
MAXLIG=SVGMAXLIG
If CHGPAG<0
  Raz WNOL
  For I=0 To MAXLIG-1
    If [M:SDE2]STOFCY(I)<>""
      WNOL+=1
    Endif
  Next
  NOL=(SVGMAXLIG-WNOL)
  If NOL<0 NOL=0 : Endif
Endif
Return
############################################################
$TRT_FILTER
Gosub LOAD_FILTER
GPOINT="FILTRE" : Gosub ENTREE From EXEFNC
Return
############################################################
$LOAD_FILTER
WFILTRI="1=1"
WFIL1  ="1=1"                                                       # hcb X3-69570
WFIL = "[F:STO1]ITMREF=[M:SDE1]ITMREF"
If [M:SDE1]FCY <> ""
  WFIL += "&[F:STO1]STOFCY=[M:SDE1]FCY"
Endif
#
# Issue 110327 - 2016-11-16 by MAE : Gestion des séries globales
If [F:ITM]SERMGTCOD <> 4                                                                             # hcb 27082 deb
  If dim([M:SDE1]SERNUMSTR) > 0 & [M:SDE1]SERNUMSTR <> ""
    WFIL += "&([F:STO1]SERNUM>=[M:SDE1]SERNUMSTR)"
  Endif
  If dim([M:SDE1]SERNUMEND) > 0 & [M:SDE1]SERNUMEND <> ""
    WFIL += "&([F:STO1]SERNUM<=[M:SDE1]SERNUMEND)"
  Endif                                                          # hcb 27082 fin
Else
  If dim([M:SDE1]SERNUMSTR) > 0 & [M:SDE1]SERNUMSTR <> ""
    WFIL += "&([F:STS]SERNUM>=[M:SDE1]SERNUMSTR)"
  Endif
  If dim([M:SDE1]SERNUMEND) > 0 & [M:SDE1]SERNUMEND <> ""
    WFIL += "&([F:STS]SERNUM<=[M:SDE1]SERNUMEND)"
  Endif
Endif
#
If dim([M:SDE1]WRH) > 0 & [M:SDE1]WRH <> ""
  WFIL += "&([F:STO1]WRH=[M:SDE1]WRH)"
Endif
#MAE, DEB US71276
If dim([M:SDE1]ECCVALMAJ) > 0 & [M:SDE1]ECCVALMAJ <> ""
  WFIL += "&([F:STO1]ECCVALMAJ=[M:SDE1]ECCVALMAJ)"
Endif
#MAE, FIN US71276
#
If [M:SDE1]PALNUM <> ""
  WFIL += "&([F:STO1]PALNUM=[M:SDE1]PALNUM)"
Endif
#
If [M:SDE1]CTRNUM <> ""
  WFIL += "&([F:STO1]CTRNUM=[M:SDE1]CTRNUM)"
Endif
#
#                                                       # hcb X3-69570 deb
If dim([M:SDE1]LPNNUM) > 0 & [M:SDE1]LPNNUM <> ""
  WFIL1 += "&([F:STO1]LPNNUM=[M:SDE1]LPNNUM)"
Endif
#                                                       # hcb X3-69570 fin

# Filtre formule
If [M:SDE1]SELFOR <> ""
  Read [TFO]TFO0=11;[M:SDE1]SELFOR
  If fstat = 0
      WFILFOR = [F:TFO]FORFOR
  Endif
# Issue 118723  - 2016-10-06 by MAE
Else
  WFILFOR = "1=1"
# End issue 118723
Endif
If WFILFOR= ""
  WFILFOR = "1=1"
Endif
#


If dim([M:SDE1]LOTSEL) > 0 & [M:SDE1]LOTSEL <> ""
  WFIL += "&pat([F:STO1]LOT,[M:SDE1]LOTSEL)"
Endif

#---
WCAT = ""
# Emplacements internes, quai, client, s-traitants
If [M:SDE1]LOCCAT001 = 2
  WCAT += ",0,1"
Endif
If [M:SDE1]LOCCAT002 = 2
  WCAT += ",2"
Endif
If [M:SDE1]LOCCAT003 = 2
  WCAT += ",3"
Endif
If [M:SDE1]LOCCAT004 = 2
  WCAT += ",4"
Endif

# Emplacements tiers cochés
If [M:SDE1]LOCCAT005 = 2
  # Emplacements internes, quai, client ou s-traitants cochés
  If WCAT<>""
    # Emplacements (types sélectionnés) dont on est propriétaire
    # ou emplacements tiers (dont on est pas propriétaire)
    WFIL += "&((find([F:STO1]LOCCAT"+WCAT+")&[F:STO1]STOFCY=[F:STO1]OWNER)"
    WFIL += "|([F:STO1]STOFCY<>[F:STO1]OWNER))"
  # Emplacements internes, quai, client ou s-traitants non cochés
  Else
    # Uniquement les emplacements tiers (dont on est pas propriétaire)
    WFIL += "&[F:STO1]STOFCY<>[F:STO1]OWNER"
  Endif
# Emplacements tiers non cochés
# et emplacements internes, quai, client ou s-traitants cochés
Elsif WCAT<>""
  # Emplacements (types sélectionnés) dont on est propriétaire
  WFIL += "&find([F:STO1]LOCCAT"+WCAT+")&[F:STO1]STOFCY=[F:STO1]OWNER"
Endif
#---
#--- Bug 70210
#Case CHGPAG
#   When  3  : # rafraichissement
#        Case [M:SDE1]SRTCOD
#            When 4 : # par emplacement
#               WFILTRI += "&([F:STO1]LOC>DLOC | [F:STO1]LOC=DLOC & [F:STO1]LOT>DLOT"
#               WFILTRI += "| [F:STO1]LOC=DLOC & [F:STO1]LOT=DLOT & [F:STO1]SLO>DSLO)"
#            When 5 : # par statut
#               WFILTRI += "&([F:STO1]STA>DSTA | [F:STO1]LOC=DSTA & [F:STO1]LOT>DLOT"
#               WFILTRI += "| [F:STO1]LOC=DSTA & [F:STO1]LOT=DSTA & [F:STO1]SLO>DSLO)"
#            When 6 : # par unité
#               WFILTRI += "&([F:STO1]PCU>DPCU | [F:STO1]PCU=DSTA & [F:STO1]LOT>DLOT"
#               WFILTRI += "| [F:STO1]PCU=DPCU & [F:STO1]LOT=DSTA & [F:STO1]SLO>DSLO)"
#            When 12: # par identifiant 1                # hcb 59291
#               WFILTRI += "&([F:STO1]PALNUM>DPAL | [F:STO1]PALNUM=DPAL & [F:STO1]ITMREF>DITM "
#               WFILTRI += "| [F:STO1]PALNUM=DPAL & [F:STO1]ITMREF=DITM & [F:STO1]LOT>DLOT)"
#            When Default :
#               WFILTRI += "&([F:STO1]LOT>DLOT | [F:STO1]LOT=DLOT & [F:STO1]SLO>=DSLO)"
#               WFILTRI += " | ([F:STO1]LOT=DLOT & [F:STO1]SLO=DSLO & [F:STO1]LOC>=DLOC)"
#        Endcase
#   When  2  : # suite
#        Case [M:SDE1]SRTCOD
#            When 4 : # par emplacement
#               WFILTRI += "&([F:STO1]LOC>FLOC | [F:STO1]LOC=FLOC & [F:STO1]LOT>FLOT"
#               WFILTRI += "| [F:STO1]LOC=FLOC & [F:STO1]LOT=FLOT & [F:STO1]SLO>FSLO)"
#            When 5 : # par statut
#               WFILTRI += "&([F:STO1]STA>FSTA | [F:STO1]STA=FSTA & [F:STO1]LOT>FLOT"
#               WFILTRI += "| [F:STO1]STA=FSTA & [F:STO1]LOT=FLOT & [F:STO1]SLO>FSLO)"
#            When 6 : # par unité
#               WFILTRI += "&([F:STO1]PCU>FPCU | [F:STO1]PCU=FPCU & [F:STO1]LOT>FLOT"
#               WFILTRI += "| [F:STO1]PCU=FPCU & [F:STO1]LOT=FLOT & [F:STO1]SLO>FSLO)"
#            When 12: # par identifiant 1                # hcb 59291
#               WFILTRI += "&([F:STO1]PALNUM>FPAL | [F:STO1]PALNUM=FPAL & [F:STO1]ITMREF>FITM "
#               WFILTRI += "| [F:STO1]PALNUM=FPAL & [F:STO1]ITMREF=FITM & [F:STO1]LOT>FLOT)"
#            When Default :
#               WFILTRI += "&([F:STO1]LOT>FLOT | [F:STO1]LOT=FLOT & [F:STO1]SLO>FSLO)"
#               WFILTRI += " | ([F:STO1]LOT=FLOT & [F:STO1]SLO=FSLO & [F:STO1]LOC>FLOC)"
#        Endcase
#   When -2  : # retour
#        Case [M:SDE1]SRTCOD
#            When 4 : # par emplacement
#               WFILTRI += "&([F:STO1]LOC<DLOC | [F:STO1]LOC=DLOC & [F:STO1]LOT<DLOT"
#               WFILTRI += "| [F:STO1]LOC=DLOC & [F:STO1]LOT=DLOT & [F:STO1]SLO<DSLO)"
#            When 5 : # par statut
#               WFILTRI += "&([F:STO1]STA<DSTA | [F:STO1]STA=DSTA & [F:STO1]LOT<DLOT"
#               WFILTRI += "| [F:STO1]STA=DSTA & [F:STO1]STA=DSTA & [F:STO1]SLO<DSLO)"
#            When 6 : # par unité
#               WFILTRI += "&([F:STO1]PCU<DPCU | [F:STO1]PCU=DPCU & [F:STO1]LOT<DLOT"
#               WFILTRI += "| [F:STO1]PCU=DPCU & [F:STO1]LOT=DLOT & [F:STO1]SLO<DSLO)"
#            When 12: # par identifiant 1                # hcb 59291
#               WFILTRI += "&([F:STO1]PALNUM<DPAL | [F:STO1]PALNUM=DPAL & [F:STO1]ITMREF<DITM "
#               WFILTRI += "| [F:STO1]PALNUM=DPAL & [F:STO1]ITMREF=DITM & [F:STO1]LOT<DLOT)"
#            When Default :
#               WFILTRI += "&([F:STO1]LOT<DLOT | [F:STO1]LOT=DLOT & [F:STO1]SLO<DSLO)"
#               WFILTRI += " | ([F:STO1]LOT=DLOT & [F:STO1]SLO=DSLO & [F:STO1]LOC<DLOC)"
#        Endcase
#Endcase
Case CHGPAG
  When  3  : # rafraichissement
    Case [M:SDE1]SRTCOD
      When 4 : # par emplacement
        WFILTRI += "&(([F:STO1]LOC=DLOC&[F:STO1]STOCOU>DSTOCOU)|[F:STO1]LOC>DLOC)"
      When 5 : # par statut
        WFILTRI += "&(([F:STO1]STA=DSTA&[F:STO1]STOCOU>DSTOCOU)|[F:STO1]STA>DSTA)"
      When 6 : # par unité
        WFILTRI += "&(([F:STO1]PCU=DPCU&[F:STO1]STOCOU>DSTOCOU)|[F:STO1]PCU>DPCU)"
      When 12: # par identifiant 1                # hcb 59291
        WFILTRI += "&(([F:STO1]PALNUM=DPAL&[F:STO1]STOCOU>DSTOCOU)|[F:STO1]PALNUM>DPAL)"
      When Default :
        WFILTRI += "&(([F:STO1]LOT=DLOT&[F:STO1]SLO=DSLO&[F:STO1]STOCOU>DSTOCOU)"
        WFILTRI += "|([F:STO1]LOT=DLOT&[F:STO1]SLO>DSLO)|[F:STO1]LOT>DLOT)"
    Endcase
  When  2  : # suite
    Case [M:SDE1]SRTCOD
      When 4 : # par emplacement
        WFILTRI += "&(([F:STO1]LOC=FLOC&[F:STO1]STOCOU>FSTOCOU)|[F:STO1]LOC>FLOC)"
      When 5 : # par statut
        WFILTRI += "&(([F:STO1]STA=FSTA&[F:STO1]STOCOU>FSTOCOU)|[F:STO1]STA>FSTA)"
      When 6 : # par unité
        WFILTRI += "&(([F:STO1]PCU=FPCU&[F:STO1]STOCOU>FSTOCOU)|[F:STO1]PCU>FPCU)"
      When 12: # par identifiant 1                # hcb 59291
        WFILTRI += "&(([F:STO1]PALNUM=FPAL&[F:STO1]STOCOU>FSTOCOU)|[F:STO1]PALNUM>FPAL)"
      When Default :
        WFILTRI += "&(([F:STO1]LOT=FLOT&[F:STO1]SLO=FSLO&[F:STO1]STOCOU>FSTOCOU)"
        WFILTRI += "|([F:STO1]LOT=FLOT&[F:STO1]SLO>FSLO)|[F:STO1]LOT>FLOT)"
    Endcase
  When -2  : # retour
    Case [M:SDE1]SRTCOD
      When 4 : # par emplacement
        WFILTRI += "&(([F:STO1]LOC=DLOC&[F:STO1]STOCOU<DSTOCOU)|[F:STO1]LOC<DLOC)"
      When 5 : # par statut
        WFILTRI += "&(([F:STO1]STA=DSTA&[F:STO1]STOCOU<DSTOCOU)|[F:STO1]STA<DSTA)"
      When 6 : # par unité
        WFILTRI += "&(([F:STO1]PCU=DPCU&[F:STO1]STOCOU<DSTOCOU)|[F:STO1]PCU<DPCU)"
      When 12: # par identifiant 1                # hcb 59291
        WFILTRI += "&(([F:STO1]PALNUM=DPAL&[F:STO1]STOCOU<DSTOCOU)|[F:STO1]PALNUM<DPAL)"
      When Default :
        WFILTRI += "&(([F:STO1]LOT=DLOT&[F:STO1]SLO=DSLO&[F:STO1]STOCOU<DSTOCOU)"
        WFILTRI += "|([F:STO1]LOT=DLOT&[F:STO1]SLO<DSLO)|[F:STO1]LOT<DLOT)"
    Endcase
Endcase
#---
Return
############################################################
$AFF_CUMUL
[M:SDE2]STOFCY(WLIG) = "***"
If dim([M:SDE2]LOT) > 0
  [M:SDE2]LOT(WLIG)    = mess(142,124,1)
Endif
[M:SDE2]STU(WLIG)    = [F:ITM]STU
[M:SDE2]QTYSTU(WLIG) = WCUMQTYSTU
If dim([M:SDE2]QTYSTUACT) > 0
  [M:SDE2]QTYSTUACT(WLIG) = WCUMQTYACT
Endif
[M:SDE2]CUNLOKFLG(WLIG) = 0
[M:SDE2]LOCCAT   (WLIG) = 0
Return
############################################################
$CAL_CUMUL
#                                                                     # hcb X3-69570 rajout WFIL1
Case [M:SDE1]SRTCOD
    When 4 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                  Order By ITMREF; STOFCY; LOC; STOCOU Asc
    When 5 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                  Order By ITMREF; STA; STOFCY; STOCOU Asc
    When 6 :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                  Order By ITMREF; PCU; STOFCY; STOCOU Asc
    When 12:                            # hcb 59291
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                  Order By Key STO1 Asc
    When Default :
      Filter [STO1] Where evalue(WFIL) & evalue(WFILS) & evalue(WFILSPE) & evalue(WFILFOR) & evalue(WFIL1)
&                  Order By Key STO3 Asc
Endcase
Raz WCUMQTYSTU, WCUMQTYACT
For [STO1]
  WCUMQTYSTU+=[F:STO1]QTYSTU
  If dim([M:SDE2]QTYSTUACT) > 0
    WCUMQTYACT+=[F:STO1]QTYSTUACT
  Endif
Next
Return
############################################################
$AGREG
Raz WAGR
# Si agrégation
If [M:SDE1]AGGFLG = 2 & NOL <> -1
  For I = 0 To MAXLIG-1
    If [M:SDE2]STOFCY(I)    = "" : Break : Endif
    If dim([M:SDE2]LOT) > 0
         WLOT = [M:SDE2]LOT(I)
    Else WLOT = ""
    Endif
    If dim([M:SDE2]SLO) > 0
         WSLO = [M:SDE2]SLO(I)
    Else WSLO = ""
    Endif
    If dim([M:SDE2]LOC) > 0
         WLOC = [M:SDE2]LOC(I)
    Else WLOC = ""
    Endif
    If dim([M:SDE2]PALNUM) > 0
         WPAL = [M:SDE2]PALNUM(I)
    Else WPAL = ""
    Endif
#                                                  # hcb x3-68850 deb
    If dim([M:SDE2]LPNNUM) > 0
         WLPN = [M:SDE2]LPNNUM(I)
    Else WLPN = ""
    Endif
#                                                  # hcb x3-68850 fin
    If dim([M:SDE2]CTRNUM) > 0
         WCTR = [M:SDE2]CTRNUM(I)
    Else WCTR = ""
    Endif
    If WLOT                 = [F:STO1]LOT       &
&      WSLO                 = [F:STO1]SLO       &
&      WLOC                 = [F:STO1]LOC       &
&      WPAL                 = [F:STO1]PALNUM    &
&      WLPN                 = [F:STO1]LPNNUM    &
&      WCTR                 = [F:STO1]CTRNUM    &
&      [M:SDE2]STA(I)       = [F:STO1]STA       &
&      [M:SDE2]PCU(I)       = [F:STO1]PCU       &
&      [M:SDE2]PCUSTUCOE(I) = [F:STO1]PCUSTUCOE &
&      [M:SDE2]QLYCTLDEM(I) = [F:STO1]QLYCTLDEM
      [M:SDE2]STOCOU(I)     = 0
      [M:SDE2]QTYPCU(I)    += [F:STO1]QTYPCU
      [M:SDE2]QTYSTU(I)    += [F:STO1]QTYSTU
      [M:SDE2]CUMALLQTY(I) += [F:STO1]CUMALLQTY
      If dim([M:SDE2]QTYSTUACT) > 0
        [M:SDE2]QTYSTUACT(I) += ([F:STO1]QTYSTUACT)
      Endif
      If dim([M:SDE2]SERNUM) > 0 & [M:SDE2]SERNUM(I)<>""
        [M:SDE2]SERNUM(I) = "$"
      Endif
      If CHGPAG > 0
        If I=0
          DLOT      = [F:STO1]LOT
          DSLO      = [F:STO1]SLO
          DLOC      = [F:STO1]LOC
          DSTA      = [F:STO1]STA
          DPCU      = [F:STO1]PCU
          DCOU      = [F:STO1]STOCOU
          DPAL      = [F:STO1]PALNUM           # hcb 59291
          DLPN      = [F:STO1]LPNNUM           # hcb x3-68850
          DITM      = [F:STO1]ITMREF           # hcb 59291
          DSTOCOU   = [F:STO1]STOCOU           # bug 70210
        Endif
        FLOT      = [F:STO1]LOT
        FSLO      = [F:STO1]SLO
        FLOC      = [F:STO1]LOC
        FCOU      = [F:STO1]STOCOU
        FSTA      = [F:STO1]STA
        FPCU      = [F:STO1]PCU
        FPAL      = [F:STO1]PALNUM             # hcb 59291
        FLPN      = [F:STO1]LPNNUM             # hcb x3-68850
        FITM      = [F:STO1]ITMREF             # hcb 59291
        FSTOCOU   = [F:STO1]STOCOU             # bug 70210
      Else
        If I=MAXLIG-1
          FLOT      = [F:STO1]LOT
          FSLO      = [F:STO1]SLO
          FLOC      = [F:STO1]LOC
          FCOU      = [F:STO1]STOCOU
          FSTA      = [F:STO1]STA
          FPCU      = [F:STO1]PCU
          FPAL      = [F:STO1]PALNUM           # hcb 59291
          FLPN      = [F:STO1]LPNNUM           # hcb x3-6885
          FITM      = [F:STO1]ITMREF           # hcb 59291
          FSTOCOU   = [F:STO1]STOCOU           # bug 70210
        Endif
        DLOT      = [F:STO1]LOT
        DSLO      = [F:STO1]SLO
        DLOC      = [F:STO1]LOC
        DCOU      = [F:STO1]STOCOU
        DSTA      = [F:STO1]STA
        DPCU      = [F:STO1]PCU
        DPAL      = [F:STO1]PALNUM             # hcb 59291
        DLPN      = [F:STO1]LPNNUM             # hcb x3-68850
        DITM      = [F:STO1]ITMREF             # hcb 59291
        DSTOCOU   = [F:STO1]STOCOU             # bug 70210
      Endif
      WAGR=1
      Break
    Endif
  Next I
Endif
Return
############################################################
$LOA_LIGNE
Gosub AGREG
If WAGR=1 : Return : Endif
If CHGPAG > 0
    NOL    += 1
    If NOL=0
        DLOT      = [F:STO1]LOT
        DSLO      = [F:STO1]SLO
        DLOC      = [F:STO1]LOC
        DSTA      = [F:STO1]STA
        DPCU      = [F:STO1]PCU
        DCOU      = [F:STO1]STOCOU
        DPAL      = [F:STO1]PALNUM             # hcb 59291
        DLPN      = [F:STO1]LPNNUM             # hcb x3-68850
        DITM      = [F:STO1]ITMREF             # hcb 59291
        DSTOCOU   = [F:STO1]STOCOU             # bug 70210
    Endif
    FLOT      = [F:STO1]LOT
    FSLO      = [F:STO1]SLO
    FLOC      = [F:STO1]LOC
    FCOU      = [F:STO1]STOCOU
    FSTA      = [F:STO1]STA
    FPCU      = [F:STO1]PCU
    FPAL      = [F:STO1]PALNUM                 # hcb 59291
    FLPN      = [F:STO1]LPNNUM                 # hcb x3-68850
    FITM      = [F:STO1]ITMREF                 # hcb 59291
    FSTOCOU   = [F:STO1]STOCOU                 # bug 70210
Else
    NOL    -= 1
    If NOL=MAXLIG-1
          FLOT      = [F:STO1]LOT
          FSLO      = [F:STO1]SLO
          FLOC      = [F:STO1]LOC
          FCOU      = [F:STO1]STOCOU
          FSTA      = [F:STO1]STA
          FPCU      = [F:STO1]PCU
          FPAL      = [F:STO1]PALNUM           # hcb 59291
          FLPN      = [F:STO1]LPNNUM           # hcb x3-68850
          FITM      = [F:STO1]ITMREF           # hcb 59291
          FSTOCOU   = [F:STO1]STOCOU           # bug 70210
    Endif
    DLOT      = [F:STO1]LOT
    DSLO      = [F:STO1]SLO
    DLOC      = [F:STO1]LOC
    DCOU      = [F:STO1]STOCOU
    DSTA      = [F:STO1]STA
    DPCU      = [F:STO1]PCU
    DPAL      = [F:STO1]PALNUM                 # hcb 59291
    DLPN      = [F:STO1]LPNNUM                 # hcb x3-68850
    DITM      = [F:STO1]ITMREF                 # hcb 59291
    DSTOCOU   = [F:STO1]STOCOU                 # bug 70210
Endif
nolign = NOL+1
# Nouvelle ligne écran
[M:SDE2]                 = [F:STO1]
# Issue 110327
If [F:ITM]SERMGTCOD = 4
  If [F:STO1]QTYPCU = 1
    Filter [STS] Where [STS]ITMREF=[F:STO1]ITMREF & [STS]STOCOU = [F:STO1]STOCOU
    Read [STS] First
    If fstat: Raz [F:STS]: Endif
    [M:SDE2]SERNUM(nolign-1) = [F:STS]SERNUM
  Else
    [M:SDE2]SERNUM(nolign-1) = "$"
  Endif
  Filter [F:STS]
Endif
# End issue 110327

[M:SDE2]LOTDMY(nolign-1) = [F:STO1]LOT
[M:SDE2]STU(nolign-1)    = [F:ITM]STU
If dim([M:SDE2]SLO)>0 & [F:STO1]SLO<>""
  [M:SDE2]SLO(nolign-1) = [F:STO1]SLO
Endif
If dim([M:SDE2]WRH)>0 & [F:STO1]WRH<>""
  [M:SDE2]WRH(nolign-1) = [F:STO1]WRH
Endif
#MAE, DEB US71276
If dim([M:SDE2]ECCVALMAJ)>0 & [F:STO1]ECCVALMAJ<>""
  [M:SDE2]ECCVALMAJ(nolign-1) = [F:STO1]ECCVALMAJ
Endif
#MAE, FIN US71276

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STO1]STOFCY | [F:ITF]ITMREF <> [F:STO1]ITMREF
   Read [ITF]ITF0 = [F:STO1]ITMREF;[F:STO1]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

  If [F:ITM]LOTMGTCOD=4 & dim([M:SDE2]SLO)>0
      Read [STL1]STL0 = [F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
  Else
      Read [STL1]STL0(2) = [F:STO1]ITMREF;[F:STO1]LOT
  Endif
  If fstat = 0
     If dim([M:SDE2]SHLDAT) > 0
        [M:SDE2]SHLDAT(nolign-1)= [F:STL1]SHLDAT
     Endif
     If dim([M:SDE2]DLUDAT) > 0
        [M:SDE2]DLUDAT(nolign-1)= [F:STL1]DLUDAT
     Endif
     If dim([M:SDE2]NEWLTIDAT) > 0
        [M:SDE2]NEWLTIDAT(nolign-1)= [F:STL1]NEWLTIDAT
     Endif
     Case [F:ITF]STOMGTCOD
       When 3 :
        [M:SDE2]POT(nolign-1) = [F:STL1]POT
       When 4 :
        [M:SDE2]ACT(nolign-1)= [F:STL1]ACT
     Endcase
  Endif
#Endif
Return
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
[M:SDE1]FLG = 0
#
If dim([M:SDE1]WRH) > 0
    Raz   [M:SDE1]WRH
    Affzo [M:SDE1]WRH
Endif
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  If dim([M:SDE1]SERNUMSTR) > 0
   # Issue 110327
   #If [F:ITM]SERMGTCOD < 2
   If !find([F:ITM]SERMGTCOD,2,3)           # hcb X3-70317
      Raz   [M:SDE1]SERNUMSTR
      Raz   [M:SDE1]SERNUMEND
      Affzo [M:SDE1]SERNUMSTR
      Affzo [M:SDE1]SERNUMEND

      Diszo [M:SDE1]SERNUMSTR
      Diszo [M:SDE1]SERNUMEND
   Else
      Actzo [M:SDE1]SERNUMSTR
      Actzo [M:SDE1]SERNUMEND
   Endif
  Endif
  If dim([M:SDE1]LOTSEL) > 0
   If [F:ITM]LOTMGTCOD < 2
      Raz   [M:SDE1]LOTSEL
      Affzo [M:SDE1]LOTSEL

      Diszo [M:SDE1]LOTSEL
   Else
      Actzo [M:SDE1]LOTSEL
   Endif
  Endif
#                                                     # hcb  X3-68850 deb
  If dim([M:SDE1]LPNNUM) > 0
     If [F:ITF]STOFCY <> [M:SDE1]FCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
        Read [ITF]ITF0 = [F:ITM]ITMREF;[M:SDE1]FCY
        If fstat
           Raz [F:ITF]
        Endif
     Endif
     If [F:ITF]LPNMGTCOD<>2
        Raz   [M:SDE1]LPNNUM
        Affzo [M:SDE1]LPNNUM
        Diszo [M:SDE1]LPNNUM
     Else
        Actzo [M:SDE1]LPNNUM
     Endif
  Endif
#                                                     # hcb  X3-68850 fin


Endif

End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SDE1]FLG = 0
End
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
#Controle si le lot existe sur le site
If !clalev([SLF]) : Local File STOLOTFCY [SLF] : Endif
If !clalev([SLF1]) : Local File STOLOTFCY [SLF1] : Endif

If VALEUR  <> "" & [M:SDE1]ITMREF = ""
  Filter [SLF] Where  LOT  = VALEUR & STOFCY = [M:SDE1]FCY
&            Order By Key SLF0 Desc
  Read [SLF] First
  If fstat = 0 & [F:SLF]ITMREF <>""
    Filter [SLF1] Where  ITMREF <> [F:SLF]ITMREF &
&       LOT  = [F:SLF]LOT & STOFCY = [M:SDE1]FCY
    Read [SLF1] First
    If fstat = 0
      Call MESSAGE (mess(393,184,1)) From GESECRAN
      Raz VALEUR : zonsui = "[M:SDE1]ITMREF"
    Else
      [M:SDE1]ITMREF = [F:SLF]ITMREF : Affzo [M:SDE1]ITMREF
      # Issue 85421 - 2013-01-14 by MAE : lecture de ITM si saisie du lot
      Call LECTURE("ITM",[F:SLF]ITMREF,"") From CONTOBJ
    Endif
  Else
    If fstat
      GMESSAGE=mess(394,184,1)+[M:SDE1]FCY
      mkstat=2
    Endif
  Endif
  Filter [SLF]
  Filter [SLF1]
Endif

End
############################################################
Subprog AM_LOTSEL(VALEUR)
Variable Char    VALEUR()
[M:SDE1]FLG = 0
End
############################################################
Subprog AS_LOTSEL(VALEUR)
Variable Char     VALEUR
If dim([M]LOTFLG) < 0
  VALEUR = ""
  mkstat = 2
Endif
End
############################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
GMENLOC(2) = 1
If VALEUR = 0
  If dim([M]LOTFLG) < 0
    GMENLOC(3) = 1
    VALEUR = 4
  Else
    VALEUR = 3
  Endif
Endif
GMENLOC(7) = 1
GMENLOC(8) = 1
GMENLOC(9) = 1
GMENLOC(10) = 1
GMENLOC(11) = 1
# GMENLOC(12) = 1     # hcb59291
End
############################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
End
############################################################
Subprog AV_STOFCY(VALEUR)
Variable Char    VALEUR
If nolign=0 : End : Endif
If [M:SDE1]CUMFLG=1 :   pcolor = GCOUL(0) : End : Endif
If VALEUR= "***"
  pcolor = GCOUL(3)
Else
  pcolor = GCOUL(0)
Endif
End
