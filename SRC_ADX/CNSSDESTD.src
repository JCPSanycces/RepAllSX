######################################################################################
Subprog IB_NBLIG
If dim([M:SDE2]LOT) > 0
   If [M:SDE2]LOT(nolign-1)="" Then
      Raz GBOUT5
   Endif
Endif
If (dim([M:SDE2]LOT) > 0 & [M:SDE2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then
   Raz GBOUT6
Endif
#--- Issue 110327
If [F:ITM]SERMGTCOD<>4
   Raz GBOUT7
Endif
#---
End


######################################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"SDE") From SUBGTC

End

