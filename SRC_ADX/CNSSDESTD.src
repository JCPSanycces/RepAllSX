##########################################################################
Subprog AV_SERNUM(VALEUR)
Variable Char    VALEUR()
If nolign=0 : End : Endif
If [M:SDE1]CUMFLG=1
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
      #End
   Else
      pcolor = GCOUL(0)
      #End
   Endif
Endif
If [M]STOFCY(nolign-1)= "***"
   pcolor = GCOUL(3)
Else
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
   Else
      pcolor = GCOUL(0)
   Endif
Endif
# Issue 110327 - 2016-11-24 by MAE : affichage des lignes désynchronisées
If [F:ITM]SERMGTCOD = 4
  If [M:SDE2]LOCCAT(nolign-1) <> 2
      Local Integer WIND
      Raz WIND
      Call VERIF_DESYNCHRO_SERIE([F:ITM]ITMREF,[M:SDE2]STOCOU(nolign-1),[M:SDE2]QTYSTUACT(nolign-1),WIND) From STKLIB
      If WIND = 2
         Chgstl [M:SDE2]NBLIG(nolign-1)  With "STKSERDSY"
      Else
         Chgstl [M:SDE2]NBLIG(nolign-1)  With ""
      Endif
   Endif
Endif
End
