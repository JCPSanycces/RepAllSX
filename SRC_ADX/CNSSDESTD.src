Subprog AV_LOT(VALEUR)
Variable Char     VALEUR
If nolign=0 : End : Endif
If [M:SDE1]CUMFLG=1
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
      End
   Else
      pcolor = GCOUL(0)
      End
   Endif
Endif
If [M]STOFCY(nolign-1)= "***"
   pcolor = GCOUL(3)
Else
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
   Else
      pcolor = GCOUL(0)
   Endif
Endif
End
