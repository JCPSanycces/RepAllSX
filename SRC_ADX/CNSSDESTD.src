#                                                        # hcb 27082 deb
Subprog AM_SERNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]SERNUMEND = ""     : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
If [M]SERNUMEND < VALEUR : [M]SERNUMEND = VALEUR : Affzo [M]SERNUMEND : Endif
If VALEUR  <> ""
   [M:SDE1]AGGFLG= 1
Endif
End
Subprog AM_SERNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR  <> ""
   [M:SDE1]AGGFLG= 1
Endif
End

Subprog C_SERNUMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]SERNUMSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End
#                                                        # hcb 27082 FIN

######################################################################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]FCY <>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif

If nolign=0 : End : Endif
If [M:SDE1]CUMFLG=1
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
      End
   Else
      pcolor = GCOUL(0)
      End
   Endif
Endif
If [M]STOFCY(nolign-1)= "***"
   pcolor = GCOUL(3)
Else
   If dim([M:SDE2]SHLDAT) > 0 & [M]SHLDAT(nolign-1)<>[0/0/0] & [M]SHLDAT(nolign-1)<date$
      pcolor = GCOUL(1)
   Else
      pcolor = GCOUL(0)
   Endif
Endif
End

######################################################################################
Subprog C_SERNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" Then
    [M]SERNUMEND = ""
Endif
End


