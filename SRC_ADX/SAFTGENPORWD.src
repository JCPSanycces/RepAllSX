#<AdxTL>@(#)0.0.0.0 $Revision$
$WORKDOCUMENTS

Gosub DECLARE_VARS      #Variable declaration
Gosub DECLARE_TABLES    #Table declaration
Gosub ALIM_CRITER       #Criteria variable declaration
Gosub PTSTRDATWO        #Get firt date for working documents
#-
Gosub TOTAL_CONTROL_SOH #NumberOfWorkDocuments Lines e TotalQuantityIssued Calculation Order
Gosub TOTAL_CONTROL_SQH #NumberOfWorkDocuments Lines e TotalQuantityIssued Calculation Quote
Gosub TOTAL_CONTROL_PFO #NumberOfWorkDocuments Lines e TotalQuantityIssued Calculation Proforma

If [L]WDTOTDEBIT<>0 | [L]WDTOTCREDI<>0
SAFTWAY=1
Wrseq '<WorkingDocuments>' Using [SAFT]
AUXTAGNAM = 'NumberOfEntries'            : AUXTAGVAL = num$([L]WDNUMOFENT)    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalDebit'                 : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDTOTDEBIT,[L]SAFPRIRND)),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'TotalCredit'                : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDTOTCREDI,[L]SAFPRIRND)),4),",",".")    : Gosub WRITETAG From SAFTGENPORTG

  If GMODU(5) = 2 # test the presence of the Sales module
    # Export ORDERS documents
    Gosub  ORDERS    From SAFTGENWDSOH
    # Export QUOTES documents
    Gosub  QUOTES    From SAFTGENWDSQH
    # Export PROFORMA documents
    Gosub  PROFORMA  From SAFTGENWDPFO
  Endif
  Wrseq '</WorkingDocuments>' Using [SAFT]
Endif
#-
Return
#######################################################################################
#######################################################################################
$ALIM_CRITER

[L]CRITSOH = "1=1"
[L]CRITSQH = "1=1"
[L]CRITPFO = "1=1"

[L]SPECRITSOH = "1=1"
[L]SPECRITSQH = "1=1"
[L]SPECRITPFO = "1=1"

GPOINT = "SPECRIT" : Gosub ENTREE From EXEFNC

Return
######################################################################################
######################################################################################
$TOTAL_CONTROL_SOH

Gosub OPEN_LNK_SOH From SAFTGENPORWD

For [WDT1]
  [L]WDRATCUR = [F:PTSOH]CHGRAT
  If [L]WDRATCUR = 0 : [L]WDRATCUR = 1 : Endif
  [L]WDNUMOFENT += 1

  If [F:PTSOH]ORDSTA = 2 & [F:PTSOH]DLVSTA = 1 & [F:PTSOH]INVSTA =1
    Goto NEXT_WDT1
  Endif

  #Footer elements
  Gosub GET_TAX_ARRAY From SAFTGENWDSOH
  Filter [F:PTSOP] Where [F:PTSOP]SOHNUM = [F:PTSOH]SOHNUM Order By [F:PTSOP]SOPLIN
  For [F:PTSOP]
    Read[F:PTSOQ]SOQ0 = [F:PTSOP]SOHNUM;[F:PTSOP]SOPLIN;[F:PTSOP]SOPSEQ
    [L]WDLNETPRI = [F:PTSOP]NETPRINOT * [L]WDRATCUR
    [L]WDLITMQTY = [F:PTSOQ]QTY
    If  [L]WDLNETPRI = 0 & [L]WDLITMQTY =0
      [L]WDLITMQTY = 1
      [L]WDLNETPRI =  abs([F:PTSOP]NETPRINOT * [L]WDRATCUR)
    Endif

    #Footer elements
    Call FOOTER_ELEMENT([F:PTSOP]VAT(0),ARRAY_VAT,ARRAY_VATNET,DIMSVV,ARRAY_FOOTVAT,ARRAY_FOOTNET,DIMSVF,SAFPRIRND,[L]WDLITMQTY,[L]WDLNETPRI,WDDTAXAMO) From SAFTGENWDSOH

    If [L]WDLNETPRI*[L]WDLITMQTY < 0
      [L]WDTOTDEBIT +=abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSOH]SOHNUM+";0;"+num$(abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))),0) From GESECRAN : Endif
    Else
      [L]WDTOTCREDI +=abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:SIH]NUM+";"+num$(abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND)))+";0",0) From GESECRAN : Endif
    Endif
    If [L]ELTAX = ""
      [L]ELTAX = [F:PTSOP]VAT(0)
    Elsif [L]ELTAX <> "" & [L]ELTAX <> [F:PTSOP]VAT(0)
      [L]ELTAX = "ERROR"
    Endif
  Next
  Filter [F:PTSOP]

  #Order elements
  For [F:SVF] Where [F:SVF]VCRNUM=[F:PTSOH]SOHNUM
    For I=0 To dim([F:SVF]DTAVATNOT(I))-1
      If (!find([F:SVF]DTAVAT(I),[L]CTRLVAT(1..[L]COUNTVAT)) & [F:SVF]DTAVATNOT(I) <> 0) | [F:SVF]DTAVATNOT(I) > 0
        If ([F:SVF]DTAVAT(I) <> "" | ([L]ELTAX<>"" & [L]ELTAX <> "ERROR")) & [F:SVF]DTAVATNOT(I) <> 0
          If [F:SVF]DTAVATNOT(I) < 0
            [L]WDTOTDEBIT+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
            If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSOH]SOHNUM+";0;"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR)),0) From GESECRAN : Endif
          Else
            [L]WDTOTCREDI+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
            If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSOH]SOHNUM+";"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR))+";",0) From GESECRAN : Endif
          Endif
        Endif
      Endif
    Next
  Next
  #-
  $NEXT_WDT1
Next
Gosub CLOSE_LNK_SOH From SAFTGENPORWD
Return
######################################################################################
######################################################################################
$TOTAL_CONTROL_SQH

Gosub OPEN_LNK_SQH From SAFTGENPORWD
For [WDT2]
  [L]WDRATCUR = [F:PTSQH]CHGRAT
  If [L]WDRATCUR = 0 : [L]WDRATCUR = 1 : Endif
  [L]WDNUMOFENT += 1
  #[L]ELTAX       = ""

  #Footer elements
  Gosub GET_TAX_ARRAY From SAFTGENWDSQH

  Filter [F:PTSQD] Where [F:PTSQD]SQHNUM = [F:PTSQH]SQHNUM Order By [F:PTSQD]SQDLIN
  For [F:PTSQD]
    [L]WDLNETPRI = [F:PTSQD]NETPRINOT*[L]WDRATCUR
    [L]WDLITMQTY = [F:PTSQD]QTY
    If  [L]WDLNETPRI = 0 & [L]WDLITMQTY =0
      [L]WDLITMQTY = 1
      [L]WDLNETPRI =  abs([F:PTSQD]NETPRINOT * [L]WDRATCUR)
    Endif

    #Footer elements
    Call FOOTER_ELEMENT([F:PTSQD]VAT(0),ARRAY_VAT,ARRAY_VATNET,DIMSVV,ARRAY_FOOTVAT,ARRAY_FOOTNET,DIMSVF,SAFPRIRND,[L]WDLITMQTY,[L]WDLNETPRI,WDDTAXAMO) From SAFTGENWDSQH

    If [L]WDLNETPRI*[L]WDLITMQTY < 0
      [L]WDTOTDEBIT +=abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSQH]SQHNUM+";0;"+num$(abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))),0) From GESECRAN : Endif
    Else
      [L]WDTOTCREDI +=abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSQH]SQHNUM+";"+num$(abs(arr(([L]WDLNETPRI*[L]WDLITMQTY), [L]SAFPRIRND)))+";0",0) From GESECRAN : Endif
    Endif
    If [L]ELTAX = ""
      [L]ELTAX = [F:PTSQD]VAT(0)
    Elsif [L]ELTAX <> "" & [L]ELTAX <> [F:PTSQD]VAT(0)
      [L]ELTAX = "ERROR"
    Endif
  Next
  Filter [F:PTSQD]

  #Invoicing elements
  For [F:SVF] Where [F:SVF]VCRNUM=[F:PTSQH]SQHNUM
    For I=0 To dim([F:SVF]DTAVATNOT(I))-1
      If (!find([F:SVF]DTAVAT(I),[L]CTRLVAT(1..[L]COUNTVAT)) & [F:SVF]DTAVATNOT(I) <> 0) | [F:SVF]DTAVATNOT(I) > 0
        If ([F:SVF]DTAVAT(I) <> "" | ([L]ELTAX<>"" & [L]ELTAX <> "ERROR")) & [F:SVF]DTAVATNOT(I) <> 0
          If [F:SVF]DTAVATNOT(I) < 0
            [L]WDTOTDEBIT+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
            If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSQH]SQHNUM+";0;"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR)),0) From GESECRAN : Endif
          Else
            [L]WDTOTCREDI+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
            If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSQH]SQHNUM+";"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR))+";",0) From GESECRAN : Endif
          Endif
        Endif
      Endif
    Next
  Next
  #-
Next
Gosub CLOSE_LNK_SQH From SAFTGENPORWD
Return
######################################################################################
######################################################################################
$TOTAL_CONTROL_PFO

Gosub OPEN_LNK_PFO From SAFTGENPORWD

For [WDT3]
  [L]WDNUMOFENT += 1
  Call LEC_TSV_LEG(LEG, [F:PTSIH]SIVTYP, STAT) From TRTLECLEG
  [L]WDRATCUR = arr([F:PTSIH]RATMLT([L]LEDT-1)/[F:PTSIH]RATDIV([L]LEDT-1),10^-GDECRCU)

  #Footer elements
  Gosub GET_TAX_ARRAY From SAFTGENWDPFO

  Filter [F:PTSID] Where NUM = [F:PTSIH]NUM Order By [F:PTSID]SIDLIN
  For [F:PTSID]
    [L]WDLNETPRI = [F:PTSID]NETPRINOT * [L]WDRATCUR
    [L]WDLITMQTY = [F:PTSID]QTY
    If  [L]WDLNETPRI = 0 & [L]WDLITMQTY =0
      [L]WDLITMQTY = 1
      [L]WDLNETPRI =  abs([F:PTSID]AMTLIN)
    Endif

    #Footer elements
    Call FOOTER_ELEMENT([F:PTSID]VAT(0),ARRAY_VAT,ARRAY_VATNET,DIMSVV,ARRAY_FOOTVAT,ARRAY_FOOTNET,DIMSVF,SAFPRIRND,[L]WDLITMQTY,[L]WDLNETPRI,WDDTAXAMO) From SAFTGENWDPFO

    If [L]WDLNETPRI*[L]WDLITMQTY < 0
      [L]WDTOTDEBIT +=abs(arr(([L]WDLITMQTY*[L]WDLNETPRI), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSIH]NUM+";0;"+num$(abs(arr(([L]WDLITMQTY*[L]WDLNETPRI), [L]SAFPRIRND))),0) From GESECRAN : Endif
    Else
      [L]WDTOTCREDI +=abs(arr(([L]WDLITMQTY*[L]WDLNETPRI), [L]SAFPRIRND))
      If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSIH]NUM+";"+num$(abs(arr(([L]WDLITMQTY*[L]WDLNETPRI), [L]SAFPRIRND)))+";0",0) From GESECRAN : Endif
    Endif

    If [L]ELTAX = ""
      [L]ELTAX = [F:PTSID]VAT(0)
    Elsif [L]ELTAX <> "" & [L]ELTAX <> [F:PTSID]VAT(0)
      [L]ELTAX = "ERROR"
    Endif
  Next
  Filter [F:PTSID]

  #-
  #Adicao dos elementos de facturacao
  For [F:SVF] Where VCRNUM=[F:PTSIH]NUM
    For I=0 To 9
      If (!find([F:SVF]DTAVAT(I),[L]CTRLVAT(1..[L]COUNTVAT)) & [F:SVF]DTAVATNOT(I) <> 0) | [F:SVF]DTAVATNOT(I) > 0
          If ([F:SVF]DTAVAT(I) <> "" | ([L]ELTAX<>"" & [L]ELTAX <> "ERROR")) & [F:SVF]DTAVATNOT(I) <> 0
            If [F:SVF]DTAVATNOT(I)< 0
              [L]WDTOTDEBIT+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
              If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSIH]NUM+";0;"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR)),0) From GESECRAN : Endif
            Else
              [L]WDTOTCREDI+=abs([F:SVF]DTAVATNOT(I) * [L]WDRATCUR)
              If dim(GSAFTEST)>0 & GSAFTEST = 1 : Call ECR_TRACE([F:PTSIH]NUM+";"+num$(abs([F:SVF]DTAVATNOT(I)*[L]WDRATCUR))+";0",0) From GESECRAN : Endif
            Endif
          Endif
        Endif
      Next
  Next
#-
Next
Gosub CLOSE_LNK_PFO From SAFTGENPORWD
Return
#######################################################################################
#######################################################################################
$DECLARE_TABLES
#Supervisor + Common data
If !clalev([F:PTFCY])  : Local File FACILITY    [PTFCY] : Endif
If !clalev([F:VCL])    : Local File VATCLS      [VCL]   : Endif
If !clalev([F:PTTCH])  : Local File TABCHANGE   [PTTCH] : Endif
If !clalev([F:PTBPR])  : Local File BPARTNER    [PTBPR] : Endif
If !clalev([F:PTBPS])  : Local File BPSUPPLIER  [PTBPS] : Endif
If !clalev([F:PTBPC])  : Local File BPCUSTOMER  [PTBPC] : Endif
If !clalev([F:PTITM])  : Local File ITMMASTER   [PTITM] : Endif
If !clalev([F:TCU])    : Local File TABCUR      [TCU]   : Endif
If !clalev([F:TVT])    : Local File TABVAT      [TVT]   : Endif
If !clalev([F:TRA])    : Local File TABRATVAT   [TRA]   : Endif
If !clalev([F:HAE])    : Local File GACCENTRY   [HAE]   : Endif
If !clalev([F:DKK])    : Local File DKSKEY      [DKK]   : Endif

If GMODU(5) = 2 # test the presence of the Sales module
  If !clalev([F:PTSOH])  : Local File SORDER      [PTSOH] : Endif
  If !clalev([F:PTSOQ])  : Local File SORDERQ     [PTSOQ] : Endif
  If !clalev([F:PTSOP])  : Local File SORDERP     [PTSOP] : Endif
  If !clalev([F:PTSVF])  : Local File SVCRFOOT    [PTSVF] : Endif
  If !clalev([F:PTSQH])  : Local File SQUOTE      [PTSQH] : Endif
  If !clalev([F:PTSQD])  : Local File SQUOTED     [PTSQD] : Endif
  If !clalev([F:PTSIH])  : Local File SINVOICE    [PTSIH] : Endif
  If !clalev([F:PTSID])  : Local File SINVOICED   [PTSID] : Endif
  If !clalev([F:PTSIV])  : Local File SINVOICEV   [PTSIV] : Endif
  If !clalev([F:TSO])    : Local File TABSOHTYP     [TSO] : Endif
  If !clalev([F:TSQ])    : Local File TABSQHTYP     [TSQ] : Endif
Endif

Return
#######################################################################################
#######################################################################################
$DECLARE_VARS

#Header variables
Local Integer WDNUMOFENT         #NumberOfEntries
Local Decimal WDTOTDEBIT         #TotalDebit
Local Decimal WDTOTCREDI         #TotalCredit
Local Char    WDDOCNUMB(60)      #DocumentNumber
Local Char    WDATCUD(100)       #ATCUD
Local Char    WDMOVSTAT(1)       #WorkStatus
Local Char    WDMOVSTDT          #WorkStatusDate
Local Char    WDUPDUSER(30)      #SourceID - Utilizador modificador
Local Char    WDSOURCEB(1)       #SourceBilling
Local Char    WDHASHCOD(172)     #Hash
Local Char    WDHSHCONT(70)      #HashControl
Local Integer WDPERIODE          #Period
Local Char    WDMOVEDAT          #MovementDate
Local Char    WDMOVTYPE(2)       #MovementType
Local Char    WDCREUSER(30)      #SourceID - Utilizador Criador
Local Char    WDSYSENTD          #SystemEntryDate
Local Char    WDCUSTOID(30)      #CustomerID
Local Decimal WDRATCUR           #Current RATCUR

Local Decimal WDLNETPRI
Local Decimal WDLITMQTY

#Document lines variables
Local Integer WDDLINNBR          #LineNumber
Local Char    WDDPRODUC(60)      #ProductCode
Local Char    WDDPRODES(200)     #ProductDescription
Local Decimal WDDQUANTI          #Quantity
Local Char    WDDUOM(20)         #UnitOfMeasure
Local Decimal WDDNETPRI          #UnitPrice
Local Char    WDDLINDES(200)     #Description
Local Decimal WDDDEBAMT          #DebitAmount
Local Decimal WDDCREAMT          #CreditAmount
Local Char    WDDTAXTYP(3)       #TaxType
Local Char    WDDTAXCOU(5)       #TaxCountryRegion
Local Char    WDDTAXCOD(10)      #TaxCode
Local Decimal WDDTAXPER          #TaxPercentage
Local Decimal WDDTAXAMO          #TaxAmount
Local Char    WDDTAXEXA(60)      #TaxExemptionReason
Local Char    WDDTAXEXAC(3)      #TaxExemptionCode
Local Char    WDLENTDAT(10)
Local Char    WDMOVENDT          #MovementEndTime
Local Char    WDMOVSTRT          #MovementStartTime
Local Char    WDATCODID(200)     #ATDocCodeID
Local Decimal WDSETAMOUT

#Document totals
Local Decimal WDTTAXPAY          #TaxPayable
Local Decimal WDTNETTOT          #NetTotal
Local Decimal WDTGROTOT          #GrossTotal
Local Char    WDTCURCOD          #CurrencyCode
Local Decimal WDTCURAMT          #CurrencyAmount
Local Decimal WDTEXCRAT          #ExchangeRate

#Calculos,Contadores,etc..
Local Integer SAFTWAY            #Variavel para alimentar as variaveis e escrevelas pelo saft
Local Decimal STOJOUVAL          #Soma do valores da stojou para o calculo do preco nas compras
Local Decimal STOJOUQTY          #Soma das quantidades da stojou para o calculo do preco nas compras
Local Char    VEHICLEID(200)     #Variavel para passar a matricula para CDT
Local Char    TZPAR(6)           #Variavel para receber o valor do parâmetro do timezone
Local Decimal PCUSTUCOE          #Variavel que contem o Quoficiente de conversao de unidades de compra para unidades de stock
Local Integer STAT
Local Date    WDSTRDAT           #Firt data for working documents
#Footer  elements
Local Char     CTRLVAT(5)(1..)
Local Integer  COUNTVAT, FLG ,K, SDL1
Local Char     ARRAY_VAT(GLONVAT)(DIMSVV), ARRAY_FOOTVAT(GLONVAT+10)(DIMSVF)
Local Decimal  ARRAY_VATNET(DIMSVV), ARRAY_FOOTNET(DIMSVF), FOOT_RAT

#Criteria
$DEC_COMDT_CRITS

Local Char    CRITSOH(255)       #Critere SOH
Local Char    CRITSQH(255)       #Critere SQH
Local Char    CRITPFO(255)       #Critere PFO

#SPE Criteria
Local Char    SPECRITSOH(255)    #Critere SOH
Local Char    SPECRITSQH(255)    #Critere SQH
Local Char    SPECRITPFO(255)    #Critere PFO

Return
#######################################################################################
#######################################################################################
$RAZVAR_WD

#Variaveis do cabecalho do documento
#Raz WDNBLINE,WDTOTQTYM
Raz [L]WDDOCNUMB,[L]WDATCUD,[L]WDMOVSTAT,[L]WDMOVSTDT,[L]WDUPDUSER,[L]WDHASHCOD,[L]WDSOURCEB
Raz [L]WDHSHCONT,[L]WDPERIODE,[L]WDMOVEDAT,[L]WDMOVTYPE,[L]WDSYSENTD
Raz [L]WDCREUSER
Raz [L]WDDLINNBR #Issue X3-90536 – 2018-06-12  by VAVIL
#Variaveis dos totais do documento
Raz [L]WDTTAXPAY,[L]WDTNETTOT,[L]WDTGROTOT,[L]WDTCURCOD,[L]WDTCURAMT,[L]WDTEXCRAT

Return
#######################################################################################
#######################################################################################
#Variaveis das linhas do documento
$RAZVAR_WD_D

Raz [L]WDDPRODUC,[L]WDDPRODES,[L]WDDQUANTI,[L]WDDUOM,[L]WDDNETPRI,[L]WDLENTDAT
Raz [L]WDDLINDES,[L]WDDDEBAMT,[L]WDDCREAMT,[L]WDDTAXTYP,[L]WDDTAXCOU,[L]WDDTAXCOD,[L]WDDTAXPER,[L]WDDTAXAMO,[L]WDDTAXEXA,[L]WDDTAXEXAC,[L]WDSETAMOUT
Raz [L]STOJOUQTY,[L]STOJOUVAL,[L]PCUSTUCOE

Return
#######################################################################################
#######################################################################################
$WRITE_WOKDOC_H
Wrseq '<WorkDocument>' Using [SAFT]
AUXTAGNAM = 'DocumentNumber'            : AUXTAGVAL = [L]WDDOCNUMB    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'ATCUD'                     : AUXTAGVAL = [L]WDATCUD      : Gosub WRITETAG From SAFTGENPORTG
Wrseq '<DocumentStatus>' Using [SAFT]
AUXTAGNAM = 'WorkStatus'                : AUXTAGVAL = [L]WDMOVSTAT    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'WorkStatusDate'            : AUXTAGVAL = [L]WDMOVSTDT    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourceID'                  : AUXTAGVAL = [L]WDUPDUSER    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourceBilling'             : AUXTAGVAL = [L]WDSOURCEB    : Gosub WRITETAG From SAFTGENPORTG
Wrseq '</DocumentStatus>' Using [SAFT]

AUXTAGNAM = 'Hash'                      : AUXTAGVAL = [L]WDHASHCOD    : Gosub WRITETAG From SAFTGENPORTG
If WDHSHCONT <> ""
  AUXTAGNAM = 'HashControl'             : AUXTAGVAL = [L]WDHSHCONT    : Gosub WRITETAG From SAFTGENPORTG
Endif
AUXTAGNAM = 'Period'                    : AUXTAGVAL = num$([L]WDPERIODE)    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'WorkDate'                  : AUXTAGVAL = [L]WDMOVEDAT    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'WorkType'                  : AUXTAGVAL = [L]WDMOVTYPE    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SourceID'                  : AUXTAGVAL = [L]WDCREUSER    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'SystemEntryDate'           : AUXTAGVAL = [L]WDSYSENTD    : Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'CustomerID'                : AUXTAGVAL = [L]WDCUSTOID    : Gosub WRITETAG From SAFTGENPORTG
[L]RECSWRI += 1
Return
#######################################################################################
#######################################################################################
$WRITE_WOKDOC_D
  Wrseq '<Line>' Using [SAFT]
  AUXTAGNAM = 'LineNumber'                 : AUXTAGVAL = num$([L]WDDLINNBR)    : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'ProductCode'               : AUXTAGVAL = [L]WDDPRODUC    : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'ProductDescription'        : AUXTAGVAL = [L]WDDPRODES    : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'Quantity'                  : AUXTAGVAL = num$([L]WDDQUANTI)    : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'UnitOfMeasure'             : AUXTAGVAL = [L]WDDUOM       : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'UnitPrice'                 : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDDNETPRI,[L]SAFPRIRND)),4),",",".")
  Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = "TaxPointDate"              : AUXTAGVAL = [L]WDLENTDAT       : Gosub WRITETAG From SAFTGENPORTG
  If WDDLINDES<>""
    AUXTAGNAM = 'Description'               : AUXTAGVAL = [L]WDDLINDES       : Gosub WRITETAG From SAFTGENPORTG
  Endif
  If WDDDEBAMT > 0
    AUXTAGNAM = 'DebitAmount'             : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDDDEBAMT,[L]SAFPRIRND)),4),",",".")
    Gosub WRITETAG From SAFTGENPORTG
  Else
    AUXTAGNAM = 'CreditAmount'            : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDDCREAMT,[L]SAFPRIRND)),4),",",".")
    Gosub WRITETAG From SAFTGENPORTG
  Endif

  If WDDTAXTYP<>''
    Wrseq '<Tax>' Using [SAFT]
    AUXTAGNAM = "TaxType"           : AUXTAGVAL =   [L]WDDTAXTYP      : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = "TaxCountryRegion"  : AUXTAGVAL =   [L]WDDTAXCOU      : Gosub WRITETAG From SAFTGENPORTG
    AUXTAGNAM = "TaxCode"           : AUXTAGVAL =   [L]WDDTAXCOD      : Gosub WRITETAG From SAFTGENPORTG
    If [L]WDDTAXAMO = 0
      AUXTAGNAM = "TaxPercentage"   : AUXTAGVAL =  num$([L]WDDTAXPER) : Gosub WRITETAG From SAFTGENPORTG
    Else
      AUXTAGNAM = "TaxAmount"       : AUXTAGVAL =  num$([L]WDDTAXAMO) : Gosub WRITETAG From SAFTGENPORTG
    Endif
    Wrseq '</Tax>' Using [SAFT]
  Endif
  If [L]WDDTAXEXA <> "" : AUXTAGNAM =  "TaxExemptionReason" : AUXTAGVAL = [L]WDDTAXEXA  : Gosub WRITETAG From SAFTGENPORTG: Endif
  If [L]WDDTAXEXAC <> "" : AUXTAGNAM = 'TaxExemptionCode'   : AUXTAGVAL = [L]WDDTAXEXAC : Gosub WRITETAG From SAFTGENPORTG: Endif
  If [L]WDSETAMOUT <> 0
    AUXTAGNAM = "SettlementAmount"    : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDSETAMOUT,[L]SAFPRIRND)),4),",",".") : Gosub WRITETAG From SAFTGENPORTG
  Endif
  Wrseq '</Line>' Using [SAFT]
Return
#######################################################################################
#######################################################################################
$WRITE_WOKDOC_T
Wrseq '<DocumentTotals>' Using [SAFT]
AUXTAGNAM = 'TaxPayable'                : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDTTAXPAY,[L]SAFPRIRND)),4),",",".")
Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'NetTotal'                  : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr([L]WDTNETTOT,[L]SAFPRIRND)),4),",",".")
Gosub WRITETAG From SAFTGENPORTG
AUXTAGNAM = 'GrossTotal'                : AUXTAGVAL = ctrans(vireblc(format$("N20.2",ar2([L]WDTGROTOT)),4),",",".")
Gosub WRITETAG From SAFTGENPORTG

If [L]WDTCURCOD <> '' and [L]WDTCURCOD <> 'EUR'
  Wrseq '<Currency>' Using [SAFT]
  AUXTAGNAM = 'CurrencyCode'              : AUXTAGVAL = [L]WDTCURCOD          : Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'CurrencyAmount'            : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr(WDTCURAMT,[L]SAFPRIRND)),4),",",".")
  Gosub WRITETAG From SAFTGENPORTG
  AUXTAGNAM = 'ExchangeRate'              : AUXTAGVAL = ctrans(vireblc(format$([L]SAFPRIFMT,arr(WDTEXCRAT,[L]SAFPRIRND)),4),",",".")
  Gosub WRITETAG From SAFTGENPORTG
  Wrseq '</Currency>' Using [SAFT]
Endif
Wrseq '</DocumentTotals>' Using [SAFT]
Wrseq '</WorkDocument>'  Using [SAFT]
Return
#####################################################################################################################################
#####################################################################################################################################
$OPEN_LNK_SOH
  Link [F:PTSOH] With [F:PTFCY]FCY0=[F:PTSOH]STOFCY, [F:PTBPC]BPC0=[F:PTSOH]BPCORD ,[F:PTBPR]BPR0=[F:PTBPC]BPCNUM  As [WDT1]
& Where [F:PTSOH]SOHCAT<>4 & [F:PTSOH]ORDDAT>=[L]STRDATE & [F:PTSOH]ORDDAT<=[L]ENDDATE & [F:PTSOH]ORDDAT >= [L]WDSTRDAT
& & [F:PTFCY]LEGCPY=[L]SOC & evalue([L]CRITSOH) & evalue([L]SPECRITSOH)
Return

$OPEN_LNK_SQH
  Link [F:PTSQH] With [F:PTFCY]FCY0=[F:PTSQH]STOFCY, [F:PTBPC]BPC0=[F:PTSQH]BPCORD,[F:PTBPR]BPR0=[F:PTBPC]BPCNUM  As [WDT2]
& Where [F:PTSQH]QUODAT>=[L]STRDATE & [F:PTSQH]QUODAT<=[L]ENDDATE  & [F:PTSQH]QUODAT >= [L]WDSTRDAT
& & [F:PTFCY]LEGCPY=[L]SOC & evalue([L]CRITSQH)& evalue([L]SPECRITSQH)
Return

$OPEN_LNK_PFO
  Link [F:PTSIH] With [F:PTSIV]SIV0=[F:PTSIH]NUM , [F:FCY]FCY0=[F:PTSIH]FCY As [WDT3]
& Where [F:PTSIH]INVTYP=5 & [F:PTSIV]INVDAT>=[L]STRDATE & [F:PTSIV]INVDAT<=[L]ENDDATE  & [F:PTSIV]INVDAT >= [L]WDSTRDAT
& & [F:PTSIH]CPY=[L]SOC & evalue([L]CRITPFO) & evalue([L]SPECRITPFO) Order By [F:PTSIH]NUM
Return
#####################################################################################################################################
#####################################################################################################################################
$CLOSE_LNK_SOH
Close File [WDT1]
Return

$CLOSE_LNK_SQH
Close File [WDT2]
Return

$CLOSE_LNK_PFO
Close File [WDT3]
Return
#####################################################################################################################################
#####################################################################################################################################
$PTSTRDATWO
Filter [F:DKK] Where [F:DKK]KEYCODE = "SAFT-PT" Order By STRDATWD Desc; KEYVER Desc
Read [F:DKK] First
  If !fstat
    [L]WDSTRDAT =[F:DKK]STRDATWD
  Endif
Filter [F:DKK]
Return

