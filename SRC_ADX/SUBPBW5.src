##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WRCPQTYSTU
Local    Decimal WFRCQTY
Local    Integer OK

# Conversion de la quantité recept UA en US
Call PCAL_QTY ([M:PBW5]RCPQTYPUU,[M:PBW5]PUU,WRCPQTYSTU,[M:PBW5]STU,
&    [M:PBW5]ITMREF,[M:PBW5]BPSNUM,1,GBIDD2) From TRTACHQTE1

# controle avec la qté reçue
If WRCPQTYSTU <> 0 & VALEUR < WRCPQTYSTU
    # La quantité commandée est inférieure\à la quantité réceptionnée
    GMESSAGE = mess (170,194,1)
    mkstat = 2
Endif

# v6 affectations
Call GET_FRCQTY([M:PBW5]STOFCY, [M:PBW5]ITMREF, 14, [M:PBW5]VCRNUM, [M:PBW5]VCRLIN, [M:PBW5]VCRSEQ, 2, WFRCQTY) From MTOLINKLIB
If (VALEUR - WRCPQTYSTU) < WFRCQTY
    # lecture règle si nécessaire
    Local    Char    WPTOCOD(GLONPTO)
    WPTOCOD = func ITMLIB.GET_PTOCOD([M:PBW5]STOFCY, [M:PBW5]ITMREF)
    If [F:PTO]PTOCOD <> WPTOCOD
        Read [PTO]PTO0=WPTOCOD
        If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]FRCPRO <> 2
        OK=1
        Call OUINON(mess(228,190,1),OK) From GESECRAN
        If OK <> 2 : VALEUR = [M:PBW5]QTYSTU : mkstat = 2 : End : Endif
    Endif
Endif
End

