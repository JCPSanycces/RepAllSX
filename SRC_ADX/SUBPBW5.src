##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYPUU(VALEUR)
Variable Decimal VALEUR
Local Integer OK

Affzo [M:PBW5]QTYSTU

If VALEUR=0 & [M]QTYSTU=0
    Raz [M]QTYPUU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif
# sr 08.11 Demande 75557
OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
[M:PBW5]INITAR = OK
End


##########################################################################
# Saisie qté en US - 14649 12.03 MM
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local Integer OK

Affzo [M:PBW5]QTYPUU

If VALEUR=0 & [M]QTYPUU=0
    Raz [M]QTYSTU
    mkstat = 2 : GMESSAGE = mess(223,193,1)    #Il faut saisir une quantité soit en UA, soit en US
Endif
# sr 08.11 Demande 75557
OK=2 : Call OUINON(mess(63,196,1),OK) From GESECRAN
[M:PBW5]INITAR = OK
