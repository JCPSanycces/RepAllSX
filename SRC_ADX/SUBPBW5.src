#<AdxTL>@(#)4.0.0.0 $Revision$
########################################
$ACTION
Case ACTION
 When "AAM_STOFCY"   : Gosub AAM_STOFCY
 When "BAM_STOFCY"   : Gosub BAM_STOFCY
Endcase
Return

########################################
$AAM_STOFCY
#-------------------------------------------------------------#
# Avant exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     SITE(GLONFCY)   : SITE=VALEUR
Local Char     WOBJET(GLONAOB) : WOBJET="ITF"
#----- Restauration de l'ancienne valeur et blocage sur le champ -----#
If GBIDI1=1  VALEUR=[M:PBW5]STOFCY : mkstat=1 : Endif
If GBIDI1<>2 WOBJET="" : Endif : # Pas d'exécution du tunnel
GFLTITM=[M:PBW5]ITMREF
Return

########################################
$BAM_STOFCY
#-------------------------------------------------------------#
# Après exécution de l'action GOBJETC0A (tunnel article-site) #
#-------------------------------------------------------------#
nolign=NOL+1: # Restitution du nolign
Raz GFLTITM
If GBIDI1=0  Return : Endif
VALEUR=SITE
Read [ITF] ITF0=[M:PBW5]ITMREF;VALEUR
If fstat Raz [F:ITF] : Endif
If [F:ITF]ITMREF="" mkstat=1 : Endif
Return
########################################
Subprog AM_EXTRCPDAT(VALEUR)
Variable Date    VALEUR

If VALEUR < datesyst
          Call MESSAGE(mess(65,194,1)) From GESECRAN
Endif
[M:PBW5]EXTRCPDAT = VALEUR
Gosub CHARGE_WRCPDAT From BENCHLIBP

End

########################################
Subprog AS_QTYPUU(VALEUR)
Variable Decimal VALEUR
GBOUT1 = ""

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif


#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:PBW5]STOFCY | [F:ITF]ITMREF <> [F:ITM]ITMREF
   Read [ITF]ITF0 = [F:ITM]ITMREF;[M:PBW5]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

If [F:ITF]STOMGTCOD > 1 : GBOUT1=mess(102,198,1) : Endif
GBOUT2 = mess(332,198,1)

End


########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(23,198,1)
GBOUT2 = mess(24,198,1)
End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer    WRETOUR
Local Decimal    WQTY
Local Char       WPUU                        # 05.05 30036
Local Decimal    WCOEUOM, WCOEF1, WCOEF2     # 05.05 30036


#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
Read [ITP]ITP0 = [M:PBW5]ITMREF;VALEUR
If fstat = 0
    # test du code blocage
    If [F:ITP]DOUFLG = 3
           GMESSAGE = mess(9,194,1)
           Call ERREUR(GMESSAGE) From GESECRAN
           mkstat = 2
           End
    Elsif [F:ITP]DOUFLG = 2
           GMESSAGE = mess(9,194,1)
           Call AVERTIR(GMESSAGE, WRETOUR) From GESECRAN
           If WRETOUR= 1
                     VALEUR = [M:PBW5]BPSNUM
                     mkstat = 2
                     End
           Endif
    Endif
    # il faut vérifier que la qté saisie >= qte min achat
    # attention l'unité achat est peut etre differente
    WQTY = [M:PBW5]QTYPUU
    WPUU = [F:ITP]PUU

    #----- Récupération des coefficients entre UA et US -----#
    # 05.05 30036
    Call PCAL_QTY (1, [M:PBW5]PUU, GBIDD3, [M:PBW5]STU,
&                  [M:PBW5]ITMREF, [M:PBW5]BPSNUM, 1, WCOEF1) From TRTACHQTE1
    Call PCAL_QTY (1, [F:ITP]PUU, GBIDD3, [M:PBW5]STU,
&                  [M:PBW5]ITMREF, VALEUR, 1, WCOEF2) From TRTACHQTE1
    If [M:PBW5]PUU <> [F:ITP]PUU | WCOEF1 <> WCOEF2
           GMESSAGE = mess(13,194,1)
           Call MESSAGE(GMESSAGE) From GESECRAN
           #--------- qté achat saisie ------#
           # 05.05 30036
           Call PCAL_QTY ([M:PBW5]QTYSTU, [M:PBW5]STU, WQTY, [F:ITP]PUU,
&                         [M:PBW5]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
    Endif
    [M:PBW5]QTYPUU = WQTY
    [M:PBW5]PUU    = [F:ITP]PUU
    # qté stock saisie
    Call PCAL_QTY ([M:PBW5]QTYPUU, [M:PBW5]PUU, [M:PBW5]QTYSTU, [M:PBW5]STU,
&                  [M:PBW5]ITMREF, VALEUR, 1, WCOEUOM) From TRTACHQTE1
    Affzo [M:PBW5]10
Else
  # couple article - fournisseur n'existe pas
  # Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
  If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
  If [F:BPS]BPSNUM<>VALEUR
    Read [BPS] BPS0=VALEUR : If fstat Raz [F:BPS] : Endif
  Endif
  #----- Si fournisseur <> Divers -----#
  If [F:BPS]BPSTYP<>3
    # Issue 6976 - 2011-12-16 by MUARN : référencement inutile si article type générique
    If [F:ITM]ITMREF <> [M:PBW5]ITMREF
      Read [ITM] ITM0=[M:PBW5]ITMREF : If fstat Raz [F:ITM] : Endif
    Endif
    If [F:ITM]GENFLG <> 2
      # couple article - fournisseur n'existe pas
      If GITMBPS = 1
               # paramètre général : on ne continue pas
               Call ERREUR(mess(8,194,1)) From GESECRAN
               mkstat = 2
      Elsif GITMBPS = 2
               # paramètre général : facultatif donc avertir
               Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
               If WRETOUR = 1
                    VALEUR = [M:PBW5]BPSNUM
                    mkstat = 2
               Endif
      Endif
    Endif
  Endif
Endif
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer WRETOUR
Local    Date    TODAY : TODAY = date$

Raz [M:PBW5]QTYPUU
Raz [M:PBW5]QTYSTU
Raz [M:PBW5]PUU
Raz [M:PBW5]STU

# recherche fournisseur
Filter [ITP] Where ITMREF=VALEUR Order By Key ITP1
Read [ITP] First : If fstat Raz [F:ITP] : Endif
Filter [ITP]
If [M:PBW5]BPSNUM = "" : [M:PBW5]BPSNUM = [F:ITP]BPSNUM : Endif

Affzo [M:PBW5]BPSNUM
Affzo [M:PBW5]30
If WRETOUR = 1 : End :  Endif

[M:PBW5]STU    = [F:ITM]STU
[M:PBW5]PUU    = [F:ITM]PUU

Affzo [M:PBW5]PUU
Affzo [M:PBW5]STU
Affzo [M:PBW5]QTYPUU
Affzo [M:PBW5]QTYSTU


End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Read [ITF]ITF0 = VALEUR;[M:PBW5]STOFCY
If fstat
    Raz [F:ITF]
    GMESSAGE = mess(25,192,1)
    mkstat = 2
Endif

# llc 11.01 11042
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

End

########################################
Subprog C_QTYPUU(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCOEFF
Local    Decimal WQTYSTU
# controle avec la qté reçue
If [M:PBW5]RCPQTYPUU <> 0 & VALEUR < [M:PBW5]RCPQTYPUU
             GMESSAGE = mess (170,194,1)
             mkstat = 2
Endif
End


########################################
Subprog B2_QTYPUU(VALEUR)
Variable Decimal VALEUR
Local    Char    WNUM(GLONVCR) : WNUM = [M:PBW5]VCRNUM
Local    Char    WLIN         : WLIN = num$([M:PBW5]VCRLIN)

If [M:PBW5]POCNUM <> ""
    Call OBJET ("POD", WLIN, WNUM) From GOBJET
Else
    Call OBJET("POH",WNUM,"") From GOBJET
Endif

End

########################################
Subprog C_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
# llc 11.01 11042
#----- Contrôle article en fin de vie ------#
If [F:ITM]LIFENDDAT <> [0/0/0] & [F:ITM]LIFENDDAT < date$
   mkstat = 1 : GMESSAGE = mess(12,318,1) : End
Endif

# -------------------------------------------------
# FQ 55989 & 52248: validité dates du contrat ?
# -------------------------------------------------
If [M:PBW5]POCNUM<>""
   Read [POC]POC1=[M:PBW5]POCNUM;[M:PBW5]ITMREF;[M:PBW5]STOFCY
   If fstat Raz [F:POC] Endif
   If (VALEUR<[F:POC]STRDAT & [F:POC]STRDAT<>[0/0/0])
           # Cette date doit être supérieure à la date du contrat - FQ 59827 "DD2" devient "D:"+GFMDAT4
             GMESSAGE = mess(98,199,1)-[M:PBW5]POCNUM-format$("D:"+GFMDAT4,[F:POC]STRDAT)
             mkstat = 2 : End
   Endif
   If (VALEUR>[F:POC]ENDDAT & [F:POC]ENDDAT<>[0/0/0])
           # La date est supérieure à la date de validité du contrat - FQ 59827 "DD2" devient "D:"+GFMDAT4
             GMESSAGE = mess(128,192,1)-[M:PBW5]POCNUM-format$("D:"+GFMDAT4,[F:POC]ENDDAT)
             mkstat = 2 : End
   Endif
Endif

# Issue 79310 - 2012-01-16 by VPO : ctrl date
If clalev([F:FCY])=0 Local File FACILITY [FCY]  Endif
If clalev([F:POH])=0 Local File PORDER [POH]  Endif
If clalev([F:POQ])=0 Local File PORDERQ [POQ]  Endif

If [F:FCY]FCY<>[M:PBW5]STOFCY
  Read [FCY] FCY0=[M:PBW5]STOFCY : If fstat Raz [F:FCY] : Endif
Endif
If [M:PBW5]POCNUM<>""
  #on prend la date minimum sur la precédente ligne ou celle-ci
  Filter [POQ] Where POHNUM=[M:PBW5]VCRNUM & POPLIN=[M:PBW5]VCRLIN & POQSEQ<[M:PBW5]VCRSEQ
  Read [POQ]POQ0 Last
  If fstat
    GBIDA1=VALEUR
  Else
    GBIDA1=[F:POQ]EXTRCPDAT
  Endif
  Filter [POQ]
  Call CTL_JOU2(VALEUR,GBIDA1,[F:FCY]UVYDAY,[F:FCY]UVYCOD,1) From CONTX3
  If mkstat : End : Endif
Else
  If [F:POH]POHNUM<>[M:PBW5]VCRNUM
    Read [POH]POH0=[M:PBW5]VCRNUM
    If fstat Raz [F:POH] Endif
  Endif
  Call CTL_JOU2(VALEUR,[F:POH]ORDDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,0) From CONTX3
  Raz mkstat, GMESSAGE
  [M:PBW5]EXTRCPDAT=VALEUR : Affzo [M:PBW5]EXTRCPDAT
Endif

# Issue 104943 - 2015-06-30 by BEEBE : Implementing Versioning
If dim([M:PBW5]ECCVALMAJ)>0
    Call C_EXTRCPDAT(VALEUR, "PBW5") From SUBPBWECC
Endif

End

