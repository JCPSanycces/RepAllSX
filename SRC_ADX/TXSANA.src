#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque TXSANA
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

$OUVRE
Local Integer I, J, NOL, COL, MAXLIG, DETSIT, DETNAT, DETCCE, NIVDET
Local Char    FCYCUR(GLONCUR), CRIT1(200), CRIT2(200), R1(5), R2(5), R3(5), R4(5), R5(5), RTMP(5)
Local Char    R6(5), R7(5), R8(5), R9(5), R10(5), R11(5)
Local Char    AMENU(20), MENU(20), LIBEL(250), CLETRI(250), RUPT1(250), RUPT2(250), RUPT3(250)
Local Char    RUPT4(20), RUPT5(20)
Local Decimal DIV, MNT, MC, MD
Local Char    FRMAFF(80)
NOL = nolign-1
Return

$DEBUT
COL = val(right$(zoncou,7))
MAXLIG = dim([M:DIA]AMTVAL)
DIV = [M:TXM1]DIVCOL(COL-1)   :# Diviseur
If !DIV : DIV=1 : Endif
Read [TXW]TXW1 = [M:TXM0]TXSNAM;[M:TXM0]VERSION
Read [TXS]TXS1 = [M:TXM0]TXSNAM
Read [TXD]TXD0 = [M:TXM0]TXSNAM;NOL+1;COL

# Infos d'en-tête
[M]LIG = NOL+1
[M]INTIT = [M:TXM1]INTIT(NOL)
[M]COL = COL
[M]COLNAM = [M:TXM1]DIVMES(COL-1)
[M]FRM = evalue("[M:TXM3]FRM"+num$(COL)+"(NOL)")
[M]FRMX = "260"
If [F:TXD]DECCOL<>0
 [M]FORMAT = "14."+num$([F:TXD]DECCOL)+"#"
Else
 [M]FORMAT = "14#"
Endif
Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;NOL+1;COL;0
[M]AMTTOT = arr(val([F:TXM]AMTVAL)/DIV,10^-[F:TXD]DECCOL)
[M]UPDVAL = val([F:TXM]UPDVAL)/DIV

# Lignes
CRIT1 = "TXSNAM=[M:TXM0]TXSNAM & VERSION=[M:TXM0]VERSION & LIG=[L]NOL+1 & COL=[L]COL & IND>0"
CRIT1 -= "& (val(AMTDEB)<>0 | val(AMTCDT)<>0)"
DETSIT = 1 : DETNAT = 0 : DETCCE = 0  :# que le détail site
R1 = "FCY"
R2 = "ACC"
R3 = "CCE1"
R4 = "CCE2"
R5 = "CCE3"
R6 = "CCE4"
R7 = "CCE5"
R8 = "CCE6"
R9 = "CCE7"
R10 = "CCE8"
R11 = "CCE9"
[M]L1 = "009"
[M]L2 = "010"
[M]L3 = "011"
[M]L4 = "012"
[M]C1 = "009"
[M]C2 = "010"
[M]C3 = "011"
[M]C4 = "012"
[M]T1 = 2
[M]T2 = 1
[M]T3 = 1
Gosub CHARGE
MENU = "1"   :# grisage initial des menus
Return

$APRES_MODIF
Case zoncou
 When "C1"    : Gosub PREMIER
 When "C2"    : Gosub PRECEDENT
 When "C3"    : Gosub SUIVANT
 When "C4"    : Gosub DERNIER
 When "L1"    : Gosub PREMLIG
 When "L2"    : Gosub PRECLIG
 When "L3"    : Gosub SUIVLIG
 When "L4"    : Gosub DERNLIG
 When "T1"    : Gosub C_TRI1
 When "T2"    : Gosub C_TRI2
 When "T3"    : Gosub C_TRI3
Endcase
Return

$SETBOUT
Return

##########################################
$C_TRI
DETSIT = 0
DETNAT = 0
DETCCE = 0
Case [M]T1
 When 2 : DETSIT = 1
 When 3 : DETNAT = 1
 When 4 : DETCCE = 1
Endcase
Case [M]T2
 When 2 : DETSIT = 1
 When 3 : DETNAT = 1
 When 4 : DETCCE = 1
Endcase
Case [M]T3
 When 2 : DETSIT = 1
 When 3 : DETNAT = 1
 When 4 : DETCCE = 1
Endcase
#Infbox COUZON-num$(NIVDET)-R1-R2-R3
Gosub CHARGE
Return

$C_TRI3
[M]T3 = val(CZ)
Gosub C_TRI
Return

$C_TRI2
[M]T2 = val(CZ)
Case [M]T2
 When 1
  [M]T3 = 1 : Affzo T3
 When 2,3,4
  If [M]T3=1 or [M]T3=[M]T2
   [M]T3 = 1 : Affzo T3
  Endif
Endcase
Gosub C_TRI
Return

$C_TRI1
[M]T1 = val(CZ)
Case [M]T1
 When 2,3,4
  If [M]T2=1 or [M]T2=[M]T1
   [M]T2 = 1 : [M]T3 = 1 : Affzo T2,T3
  Elsif [M]T3=1 or [M]T3=[M]T1
   [M]T3 = 1 : Affzo T3
  Endif
Endcase
Gosub C_TRI
Return

$CHARGE
Effzo [M:DIA]10, NBLIG
NIVDET = DETSIT + DETNAT + DETCCE

Raz CLETRI
Gosub SET_CLETRI
# Affichage zones Détail et Tri
Case [M]T1
 When 2 : LIBEL = mess(12,105,1)
 When 3 : LIBEL = mess(45,102,1) : #mess(18,103,1)
 When 4 : LIBEL = mess(17,103,1)
Endcase
Case [M]T2
 When 2 : LIBEL -= "+"-mess(12,105,1)
 When 3 : LIBEL -= "+"-mess(45,102,1) : #mess(18,103,1)
 When 4 : LIBEL -= "+"-mess(17,103,1)
Endcase
Case [M]T3
 When 2 : LIBEL -= "+"-mess(12,105,1)
 When 3 : LIBEL -= "+"-mess(45,102,1) : #mess(18,103,1)
 When 4 : LIBEL -= "+"-mess(17,103,1)
Endcase
[M]DETSOR = LIBEL

Raz CRIT2
If DETCCE
 CRIT2 = "TYPAMT=5"
Elsif DETNAT
 CRIT2 = "TYPAMT=2"
Else
 CRIT2 = "TYPAMT=1"
Endif
Gosub CHARG_TAB
Affzo [M]
Chgstl [M]FRM0   With "TDB00"
Chgstl [M]AMTVAL With "TDBBLU"
If NIVDET>1
 For I=0 To [M]NBLIG-1
  Case [M]NIV(I)
   When 1 : Chgstl [M]FRM0(I) With "TDB10"
   When 2 : Chgstl [M]FRM0(I) With "TDB02"
  Endcase
 Next I
Endif
FRMAFF = [M]FRM
If find(left$(FRMAFF,1),"-","+")
 FRMAFF = right$(FRMAFF,2)
Endif
If left$(FRMAFF,1)="Q" or find(left$(FRMAFF,2),"NQ","EQ","PQ","GQ")
 Titcol [M]NBLIG mess(44,108,1)  For AMTVAL : # Quantités
Else
 Titcol [M]NBLIG mess(149,111,1) For AMTVAL : # Montants
Endif
Return

$CHARG_TAB
Raz nolign
Filter [TXM] Where evalue(CRIT1) & evalue(CRIT2)
&            Order By Key CLE = evalue(R1);evalue(R2);evalue(R3);evalue(R4);evalue(R5);
&                               evalue(R6);evalue(R7);evalue(R8);evalue(R9);evalue(R10);evalue(R11)
If [M]T1=4
 K1 = 9 : K2 = 10 : K3 = 11
Elsif [M]T2=4
 K1 = 1 : K2 = 10 : K3 = 11
Elsif [M]T3=4
 K1 = 1 : K2 = 2 : K3 = 11
Else
 K1 = 1 : K2 = 2 : K3 = 3
Endif
For [TXM]CLE(K1)
 If R1="CCE1"
  RUPT1 = [F:TXM]CCE1-[F:TXM]CCE2-[F:TXM]CCE3-[F:TXM]CCE4-[F:TXM]CCE5-[F:TXM]CCE6-[F:TXM]CCE7-[F:TXM]CCE8-[F:TXM]CCE9
 Else
  RUPT1 = evalue("[F:TXM]"+R1)
 Endif
 [M]FRM0(nolign) = RUPT1
 [M]NIV(nolign) = 1
 RTMP = R1 : Gosub ADDINF
 If NIVDET=1
  Raz MNT, MC, MD
 Else
  [M]INFO(nolign) = RUPT1
  RTMP = R1 : Gosub ADDINFO
 Endif
 Case R1
  When "ACC"  : [M]NAT(nolign) = [F:TXM]ACC
  When "CCE1" : [M]SEC(nolign) = [F:TXM]CCE1 : [M]AXE(nolign) = [F:TXM]DIE1
 Endcase
 For [TXM]CLE(K2)
  If R2="CCE1"
   RUPT2 = [F:TXM]CCE1-[F:TXM]CCE2-[F:TXM]CCE3-[F:TXM]CCE4-[F:TXM]CCE5-[F:TXM]CCE6-[F:TXM]CCE7-[F:TXM]CCE8-[F:TXM]CCE9
  Else
   RUPT2 = evalue("[F:TXM]"+evalue("R"+num$(K2)))
  Endif
  If NIVDET>=2
   If NIVDET=2 : Raz MNT, MC, MD : Endif
   nolign+=1 : If nolign>=MAXLIG : Break 2 : Endif
   [M]FRM0(nolign) = "....."-RUPT2
   RTMP = R2 : Gosub ADDINF
   [M]INFO(nolign) = RUPT1
   RTMP = R1 : Gosub ADDINFO
   If NIVDET>2
    [M]INFO(nolign)  = RUPT1-RUPT2
    RTMP = R2 : Gosub ADDINFO
    [M]NIV(nolign)   = 2
   Endif
   If R2="ACC" or (R1="CCE1" & R4="ACC")
    [M]NAT(nolign) = [F:TXM]ACC
   Elsif R2="CCE1"
    [M]SEC(nolign) = [F:TXM]CCE1 : [M]AXE(nolign) = [F:TXM]DIE1
   Endif
  Endif
  For [TXM]CLE(K3)
   If R3="CCE1"
    RUPT3 = [F:TXM]CCE1-[F:TXM]CCE2-[F:TXM]CCE3-[F:TXM]CCE4-[F:TXM]CCE5-[F:TXM]CCE6-[F:TXM]CCE7-[F:TXM]CCE8-[F:TXM]CCE9
   Else
    RUPT3 = evalue("[F:TXM]"+evalue("R"+num$(K3)))
   Endif
   If NIVDET=3
    nolign += 1 : If nolign>=MAXLIG : Break 3 : Endif
    [M]FRM0(nolign) = ".........."-RUPT3
    [M]INFO(nolign) = RUPT1-RUPT2
    RTMP = R2 : Gosub ADDINFO
    Raz MNT , MC , MD
    For [TXM]CLE
     MNT += val([F:TXM]AMTVAL)/DIV
     MC  += val([F:TXM]AMTCDT)/DIV
     MD  += val([F:TXM]AMTDEB)/DIV
    Next
    Gosub SETMNT
    If R3="ACC" or ((R1="CCE1" or R2="CCE1") and R5="ACC")
     [M]NAT(nolign) = [F:TXM]ACC
    Elsif R3="CCE1"
     [M]SEC(nolign) = [F:TXM]CCE1 : [M]AXE(nolign) = [F:TXM]DIE1
    Endif
   Else
    For [TXM]CLE
     MNT += val([F:TXM]AMTVAL)/DIV
     MC  += val([F:TXM]AMTCDT)/DIV
     MD  += val([F:TXM]AMTDEB)/DIV
    Next
   Endif
  Next
  If NIVDET=2
   Gosub SETMNT
  Endif
 Next
 If NIVDET=1
  Gosub SETMNT
 Endif
 nolign+=1 : If nolign>=MAXLIG : Break : Endif
Next
Filter [TXM]
[M]NBLIG = nolign
Return

$SETMNT
[M]AMTVAL(nolign) = arr(MNT,10^-[F:TXD]DECCOL)
[M]AMTCDT(nolign) = arr(MC,10^-[F:TXD]DECCOL)
[M]AMTDEB(nolign) = arr(MD,10^-[F:TXD]DECCOL)
Return

$ADDINF
Case RTMP
 When "FCY" :
  If [F:TXM]FCYINF<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]FCYINF : Endif
 When "ACC" :
  If [F:TXM]ACCINF<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]ACCINF : Endif
 When "CCE1" :
  If [F:TXM]CCEINF<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]CCEINF : Endif
Endcase
Return

$ADDINFO
Case RTMP
 When "FCY" :
  If [F:TXM]FCYINF<>"" : [M]INFO(nolign) -= "-"-[F:TXM]FCYINF : Endif
 When "ACC" :
  If [F:TXM]ACCINF<>"" : [M]INFO(nolign) -= "-"-[F:TXM]ACCINF : Endif
 When "CCE1" :
  If [F:TXM]CCEINF<>"" : [M]INFO(nolign) -= "-"-[F:TXM]CCEINF : Endif
Endcase
Return

$SET_CLETRI
If [M]T2=1
 Case [M]T1
  When 2 : R1="FCY"  : R2="ACC"  : R3="CCE1" : R4="CCE2" : R5="CCE3" : R6="CCE4" : R7="CCE5" : R8="CCE6" : R9="CCE7" : R10="CCE8" : R11="CCE9"
  When 3 : R1="ACC"  : R2="FCY"  : R3="CCE1" : R4="CCE2" : R5="CCE3" : R6="CCE4" : R7="CCE5" : R8="CCE6" : R9="CCE7" : R10="CCE8" : R11="CCE9"
  When 4 : R1="CCE1" : R2="CCE2" : R3="CCE3" : R4="CCE4" : R5="CCE5" : R6="CCE6" : R7="CCE7" : R8="CCE8" : R9="CCE9" : R10="FCY"  : R11="ACC"
 Endcase
Else
 Case [M]T1
  When 2
   R1 = "FCY"
   Case [M]T2
    When 3 : R2="ACC"  : R3="CCE1" : R4="CCE2" : R5="CCE3" : R6="CCE4" : R7="CCE5" : R8="CCE6" : R9="CCE7" : R10="CCE8" : R11="CCE9"
    When 4 : R2="CCE1" : R3="CCE2" : R4="CCE3" : R5="CCE4" : R6="CCE5" : R7="CCE6" : R8="CCE7" : R9="CCE8" : R10="CCE9" : R11="ACC"
   Endcase
  When 3
   R1 = "ACC"
   Case [M]T2
    When 2 : R2="FCY"  : R3="CCE1" : R4="CCE2" : R5="CCE3" : R6="CCE4" : R7="CCE5" : R8="CCE6" : R9="CCE7" : R10="CCE8" : R11="CCE9"
    When 4 : R2="CCE1" : R3="CCE2" : R4="CCE3" : R5="CCE4" : R6="CCE5" : R7="CCE6" : R8="CCE7" : R9="CCE8" : R10="CCE9" : R11="FCY"
   Endcase
  When 4
   R1="CCE1" : R2="CCE2" : R3="CCE3" : R4="CCE4" : R5="CCE5" : R6="CCE6" : R7="CCE7" : R8="CCE8" : R9="CCE9"
   Case [M]T2
    When 2 : R10 = "FCY" : R11 = "ACC"
    When 3 : R10 = "ACC" : R11 = "FCY"
   Endcase
 Endcase
Endif
Return

Subprog AS_NBLIG
If nolign>0
 Inftxt [M]INFO(nolign-1) At 1
Endif
End

$SUIVANT
If [L]COL<[M:TXM2]NBRCOL
 [L]COL += 1
Else
 [L]COL = 1
Endif
Gosub RECHARGE
Return

$PRECEDENT
If [L]COL>1
 [L]COL -= 1
Else
 [L]COL = [M:TXM2]NBRCOL
Endif
Gosub RECHARGE
Return

$PREMIER
If [L]COL<>1
 [L]COL = 1
 Gosub RECHARGE
Endif
Return

$DERNIER
If [L]COL<>[M:TXM2]NBRCOL
 [L]COL = [M:TXM2]NBRCOL
 Gosub RECHARGE
Endif
Return

$PREMLIG
If [L]NOL<>0
 [L]NOL = 0
 Gosub RECHARGE
Endif
Return

$DERNLIG
If [L]NOL<>[M:TXM1]NBLIG-1
 [L]NOL = [M:TXM1]NBLIG-1
 Gosub RECHARGE
Endif
Return

$SUIVLIG
If [L]NOL<[M:TXM1]NBLIG-1
 [L]NOL += 1
Else
 [L]NOL = 0
Endif
Gosub RECHARGE
Return

$PRECLIG
If [L]NOL>0
 [L]NOL -= 1
Else
 [L]NOL = [M:TXM1]NBLIG-1
Endif
Gosub RECHARGE
Return

$RECHARGE
[M]LIG = [L]NOL+1
[M]COL = [L]COL
[M]INTIT = [M:TXM1]INTIT(NOL)
DIV = [M:TXM1]DIVCOL(COL-1)  :# Diviseur
If !DIV : DIV=1 : Endif
[M]COLNAM = [M:TXM1]DIVMES(COL-1)
Read [TXD]TXD0 = [M:TXM0]TXSNAM;NOL+1;COL
If [F:TXD]DECCOL<>0
 [M]FORMAT = "14."+num$([F:TXD]DECCOL)+"#"
Else
 [M]FORMAT = "14#"
Endif
[M]FRM = evalue("[M:TXM3]FRM"+num$(COL)+"(NOL)")
Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;NOL+1;COL;0
[M]AMTTOT = val([F:TXM]AMTVAL)/DIV
[M]UPDVAL = val([F:TXM]UPDVAL)/DIV
Gosub CHARGE
Return

##########################################
$FINSAI
zonsui = "AMTVAL"+num$([M]COL)+"("+num$([M]LIG-1)+")"
mkstat = 99
Return


Subprog IB_NBLIG
If [M]NAT(nolign-1)=""
 Raz GBOUT1
Else
 GBOUT1 -= [M]NAT(nolign-1)
Endif
If [M]SEC(nolign-1)=""
 Raz GBOUT2
Else
 GBOUT2 -= [M]SEC(nolign-1)
Endif
End

Subprog AS_FRM0(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

Subprog AS_AMTVAL(VALEUR)
Variable Decimal VALEUR
mkstat = 2
End

Subprog CL_L1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog AS_T1(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1) = 1 : # Pas de aucun
If [F:TXW]DETCCE<>2
 GMENLOC(4) = 1
 If [F:TXW]DETACC<>2
  GMENLOC(3) = 1
 Endif
Endif
End

Subprog AS_T2(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
If [F:TXW]DETCCE<>2
 GMENLOC(4) = 1
 If [F:TXW]DETACC<>2
  VALEUR = 1
  mkstat = 2
 Endif
Endif
GMENLOC([M]T1) = 1
End

Subprog AS_T3(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
If [F:TXW]DETCCE<>2 or [M]T2=1
 VALEUR = 1
 mkstat = 2
Else
 GMENLOC([M]T1) = 1
 GMENLOC([M]T2) = 1
Endif
End

