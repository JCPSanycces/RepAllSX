#<AdxTL>@(#)3.0.0.0 $Revision$
## Appel général
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ACODCTL","ACODCTL","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "FIN"         : Gosub FIN
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return


$OUVRE
Local Mask ACODCTL [ACO]
If clalev([F:AMK])=0 : Local File AMSK      [AMK] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON   [AMZ] : Endif
If clalev([F:AMP])=0 : Local File AMSKPAR   [AMP] : Endif
If clalev([F:AAR])=0 : Local File ACTCODPAR [AAR] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE    [ATX] : Endif
Local Integer I
Local Char    SYMBOLE(20) , MSKCUR(GLONAMK)
Raz [M]
Return

$ENREGISTRE
Gosub VALID
REP = ""
Unlock =SYMBOLE
Actzo MASQUE
Return

$ABANDON
Actzo MASQUE
Gosub RELIT
REP = ""
Unlock =SYMBOLE
Return

$FIN
If REP<>""
 Unlock = SYMBOLE
Endif
Return

$SETBOUT
If REP=""
 Call VIREBOUT(CHBOU,"EA") From GOBJET
Endif
Return

$APRES_MODIF
Case COUZON
 When "MASQUE"
  Read [AMK]CODMSK = CZ
  If fstat
   GERR = 1 : GMESSAGE = mess(72,123,1) : Return
#  Ecran inexistant
  Endif
  [M]MASQUE = CZ
  Gosub CHARGE
  REP = ""
 When Default
  If REP=""
   SYMBOLE = "AMK"+[M]MASQUE
   Lock =SYMBOLE With lockwait=0
   If fstat
    GERR = 1 : GMESSAGE = mess(10,100,1) : Return
   Else
    REP = "M"
    Grizo MASQUE
   Endif
  Endif
Endcase
Return

$RELIT
[M]MASQUE = MSKCUR

$CHARGE
NOL=0
Call TEXTE([F:AMK]INTMSK,[M]COMMENT) From OBJDIV
For [AMZ]CODE Where CODMSK=[M]MASQUE & SAIAFF=1 & CODTYP<>"ABS"
 If !find([F:AMZ]CODZON,[M]ZONE(0..NOL-1))
  [M]ZONE(NOL)   = [F:AMZ]CODZON
  Call TEXTE([F:AMZ]INTIT,[M]INTIT(NOL)) From OBJDIV
  [M]CODCTL(NOL) = [F:AMZ]CODCTL
  NOL += 1
 Endif
Next
[M]NBLIG = NOL
Affzo
MSKCUR = [M]MASQUE
Return

$VALID
Call DEBTRANS From GLOCK
Gosub TR1
Call VALID([M]MASQUE,nomap,1,GLANGUE,0,OK) From VALMSK
Return

$TR1
GOK=1
Trbegin [AMZ]
 For [AMZ]CODZON Where CODMSK=[M]MASQUE With Lock
  If fstat=1
   GOK = -1 : GLOCK = "$AMSKZON"-[M]MASQUE : Break
  Endif
  I = find([F:AMZ]CODZON,[M]ZONE(0..[M]NBLIG-1))-1
  If I>=0
   [F:AMZ]CODCTL = [M]CODCTL(I)
   Rewrite [AMZ]
   If fstat
    GOK=0 : Call FSTA("AMZ") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return
