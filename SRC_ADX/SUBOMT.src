#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier TRADESHOW
Call OBJET ("OMT", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"       : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE"       : Gosub OUVRE
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "SETBOUT"     : Gosub SETBOUT
    When "RAZCRE"      : Gosub RAZCRE
    When "LIENS"       : Gosub LIENS
    When "FERME"       : Gosub FERME
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When "VERF_ANU"    : Gosub VERF_ANU
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCOMTCPT(GLONANM)  # Code compteur pour une opération marketing

Local Char SZBOXOMT(10)
Local Char SZBOXOT2(10)
Local Char SZSITE(GLONFCY)

  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(2)
  #  GCOMTCPT = [F:TCA]CODNUM(2)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBOMT"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:O_MT]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [O_MT] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [OMT] With [O_MT]OMT0=[F:OMT]OMTNUM,
&                 [AFF]AFF0~=[F:OMT]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OMT]FCY
&              As [OT2]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "OMT" Then
    SZBOXOMT = "GAU_CHE"
  Else
    SZBOXOMT = "GAU_CHE" + num$(find("OMT",OBJLIS(1..8))) : # Salons professionnels actifs
  Endif
  If OBJLIS(0) = "OT2" Then
    SZBOXOT2 = "GAU_CHE"
  Else
    SZBOXOT2 = "GAU_CHE" + num$(find("OT2",OBJLIS(1..8))) : # Salons professionnels clôturés
  Endif
Return

##########################################################################################################
$FERME
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      Call LOAD_OPG From SUBCMGB
    Endif
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (début)
  If dim(GCOMTCPT) > 0 Then
    Kill GCOMTCPT            # Code compteur pour une opération marketing.
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (fin)
Return

##########################################################################################################
$FILGAUCHE
  Default File [OMT]
  If currbox = SZBOXOMT Then
    # Salons professionnels actifs
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLO <> 2", "&") From GOBJSUB
  Elsif currbox = SZBOXOT2 Then
    # Salons professionnels clôturés
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLO = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OMT") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$SETBOUT
  #Retours marketing
  If REP <> "" Then
    Call VIREBOUT(CHAINE,"P") From GOBJET
  Else
    If [M:OMT0]CMGNUM = "" Then
      Call VIREBOUT(CHAINE,"P") From GOBJET
    Endif
    If [M:OMT0]OMTNUM = "" Then
      Call VIREBOUT(CHAINE,"P") From GOBJET
    Endif
  Endif
  Call VIREBOUT(CHAINE,"HC") From GOBJET
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:OMT0]FCY, 13, 2, GSOCIETE, GCURLEG, GCOMTCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMT0]FCY, GCOMTCPT, date$, "", [M:OMT0]OMTNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:OMT]OMTNUM = [M:OMT0]OMTNUM
      Affzo [M:OMT0]OMTNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:OMT]TYPFULOBJ = "OMT"
  [F:OMT]NUMFULOBJ = [M:OMT0]OMTNUM
  [M:OMT1]TYPFULOBJ = "OMT"
  [M:OMT1]NUMFULOBJ = [M:OMT0]OMTNUM
Return

##########################################################################################################
$VERIF_CRE
  Gosub CHECKDATA From SUBOMTB
Return

##########################################################################################################
$VERIF_MOD
  Gosub CHECKDATA From SUBOMTB
Return

##########################################################################################################
$CREATION
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMTB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMT",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMTB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMT",-1) From SUBPS2
  Call VALSTA("OMT",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  [M:OMT0]OMTPRECLO = [M:OMT2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT1]1-99
Return

##########################################################################################################
$APRES_MOD
  [M:OMT0]OMTPRECLO = [M:OMT2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT1]1-99
Return

##########################################################################################################
$VERF_ANU
  Gosub CONFIRM_ANU From SUBOMM
Return

##########################################################################################################
$AV_ANNULE
Local Char GSZOPGNUM
Local Integer IDELTODOCALL

  IDELTODOCALL = 0
  GSZOPGNUM = [M:OMT0]OMTNUM
  Gosub ANNULEOMT
Return

##########################################################################################################
$ANNULEOMT
  Gosub CLEANHISTO From SUBOMMB
  If GOK = 0 Then
    Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB2 From SUBOMTB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("OMT",-1) From SUBPS2
Return

##########################################################################################################
$RAZCRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  #Initialise la base d'expression de la superficie du stand
  [M:OMT2]BOOSURBAS = mess(338,196,1) #m2
  #Initialise le site par défaut
  Call SITECRMDEF ( "ACT", [M:OMT0]FCY) From CRM_UTIL
  GFCY = [M:OMT0]FCY
  Call GETDEV(GFCY) From DEVSUB
  [M:OMT2]CLO = 1
  Raz [M:OMT2]CLODAT
  #Initialise la devise par défaut
  [M:OMT0]CUR = GSYSCUR
  [M:OMT2]CUR1 = [M:OMT0]CUR
  [M:OMT2]CUR2 = [M:OMT0]CUR
  [M:OMT2]CUR3 = [M:OMT0]CUR
  Call CMGINIDATES([M:OMT0]CMGNUM,[M:OMT2]OMTSTR, [M:OMT2]OMTEND,IERRINF,ICHAPTER, IBRETOUR)  From SUBCMGB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMTB
  [M:OMT0]OMTNUM = ""
  Affzo [M:OMT0]1-99
  Affzo [M:OMT1]1-99
  Affzo [M:OMT2]1-99
Return

##########################################################################################################
$LIENS
  GFCY = [M:OMT0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBOMTB
  #Affiche le nom de la campagne
  If [M:OMT0]CMGNUM <> "" Then
    Read [CMG]CMG0=[M:OMT0]CMGNUM
    If fstat Then
      [M:OMT0]CMGTTR = [M:OMT0]CMGNUM
    Else
      [M:OMT0]CMGTTR = [F:CMG]TTR
    Endif
  Endif
  #Initialise la base d'expression de la superficie du stand
  [M:OMT2]BOOSURBAS = mess(338,196,1) #m2
  #Calcul le budget total du salon
  [M:OMT2]TOTBUD = [M:OMT2]BOOCST + [M:OMT2]OTHCST
  #Met à jour les devises
  [M:OMT2]CUR1 = [M:OMT0]CUR
  [M:OMT2]CUR2 = [M:OMT0]CUR
  [M:OMT2]CUR3 = [M:OMT0]CUR
  [M:OMT0]OMTPRECLO = [M:OMT2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT0]1-99
  Affzo [M:OMT1]1-99
  Affzo [M:OMT2]1-99
Return

##########################################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  #Met à jour les devises
  [M:OMT2]CUR1 = VALEUR
  [M:OMT2]CUR2 = VALEUR
  [M:OMT2]CUR3 = VALEUR
  Affzo [M:OMT0]1-99
  Affzo [M:OMT2]1-99
End

##########################################################################################################
Subprog AM_BOOCST(VALEUR)
Variable Decimal VALEUR

  [M:OMT2]TOTBUD = VALEUR + [M:OMT2]OTHCST
  Affzo [M:OMT2]TOTBUD
End

##########################################################################################################
Subprog AM_OTHCST(VALEUR)
Variable Decimal VALEUR

  [M:OMT2]TOTBUD = VALEUR + [M:OMT2]BOOCST
  Affzo [M:OMT2]TOTBUD
End

##########################################################################################################
Subprog IB_FULOBJ

  Raz GBOUT1
  If [M:OMT1]FULOBJ<> "" Then
    If len([M:OMT1]FULOBJ) > GLONCLE Then
        Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:OMT1]FULOBJ, VALEUR, [M:OMT1]OBJ) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:OMT1]FULOBJ = VALEUR
  Gosub DISPICON From SUBOMTB
  Affzo [M:OMT1]1-99
End

##########################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> "" Then
    Call CMGCTRLFCY (VALEUR,[M:OMT0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  # FGR 21/01/2013 : X3SUIVI71937
  If dim(GCOMTCPT) < 0 Then
    Global Char GCOMTCPT(GLONANM)   # Code compteur pour une opération marketing
  Endif
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog C_OMTSTR(VALEUR)
Variable Date    VALEUR
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEDEB (VALEUR,[M:OMT0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog C_OMTEND(VALEUR)
Variable Date    VALEUR

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> [00/00/00] Then
    Call CMGCTRLDATEFIN (VALEUR,[M:OMT0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CLO(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:OMT0]OMTPRECLO <> 2 Then
      [M:OMT2]CLODAT = date$
    Endif
  Endif
End

