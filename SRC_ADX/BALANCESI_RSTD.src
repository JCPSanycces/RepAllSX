#<AdxTL>@(#)0.0.0.0 $Revision$
# Class BALANCESI

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AQUERY_CRITERIA_AFTER
  #Ensure we don't select records where site is blank
  If PQRY.QWHERE<>""
    PQRY.QWHERE="("+PQRY.QWHERE+") and ACF_STE ne '' and TECH_BPR eq ''"
  Else
    PQRY.QWHERE="ACF_STE ne '' and TECH_BPR eq ''"
  Endif
Return

$AQUERY_TRANS_AFTER
Local Integer I

  # Convert Ledger type to character
  this.BAL.LEDTYP_A = num$([F:BAL]LEDTYP)

  # Get the year for this Fiscal year
  this.BAL.FYR = year([F:FIY]FIYEND)

  #Split out array fields into single fields
  For I = 0 To dim([F:BAL]DEB)

    # The fields only go to 13, break if more than that
    If I > 13 : Break : Endif

    Assign "this.BAL.DEB"+num$(I)     With [F:BAL]DEB(I)
    Assign "this.BAL.CDT"+num$(I)     With [F:BAL]CDT(I)
    Assign "this.BAL.DEBLED"+num$(I)  With [F:BAL]DEBLED(I)
    Assign "this.BAL.CDTLED"+num$(I)  With [F:BAL]CDTLED(I)

    # Calculate the balance in source currency for every period
    Assign "this.BAL.BALSRC"+num$(I)  With [F:BAL]DEB(I) - [F:BAL]CDT(I)

    # Calculate the balance in ledger currency for every period
    Assign "this.BAL.BALLED"+num$(I)  With [F:BAL]DEBLED(I) - [F:BAL]CDTLED(I)
  Next I

Return

