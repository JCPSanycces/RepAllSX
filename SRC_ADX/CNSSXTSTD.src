Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Case  [M:SXT1]WOWN
    When "S" : Call CONTITF(VALEUR,[M:SXT1]OWNER)  From STKLIB
    When "F" :
  Endcase
  If dim([M:SXT1]SERNUMSTR) > 0
   If [F:ITM]SERMGTCOD < 2
      Raz   [M:SXT1]SERNUMSTR
      Raz   [M:SXT1]SERNUMEND
      Affzo [M:SXT1]SERNUMSTR
      Affzo [M:SXT1]SERNUMEND

      Diszo [M:SXT1]SERNUMSTR
      Diszo [M:SXT1]SERNUMEND
   Else
      Actzo [M:SXT1]SERNUMSTR
      Actzo [M:SXT1]SERNUMEND
   Endif
  Endif
  If dim([M:SXT1]LOTSEL) > 0
   If [F:ITM]LOTMGTCOD < 2
      Raz   [M:SXT1]LOTSEL
      Affzo [M:SXT1]LOTSEL

      Diszo [M:SXT1]LOTSEL
   Else
      Actzo [M:SXT1]LOTSEL
   Endif
  Endif
Endif

End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSXT2) 04/11/2008 13:27:05 (SYMEU)
######################################################################################
## SYMEU 61044 (21/12/2009) : oublié de tester la présence du champ [M:SXT2]LOT
######################################################################################
Subprog IB_NBLIG
If dim([M:SXT2]LOT) > 0 Then      # SYMEU 61044
  If [M:SXT2]LOT(nolign-1)="" Then
     Raz GBOUT2
  Endif
Endif
If (dim([M:SXT2]LOT) > 0 and [M:SXT2]LOT(nolign-1)="") or [F:ITM]TRKCOD<=1 Then # SYMEU 61044
   Raz GBOUT3
Endif
End


######################################################################################

# FQ 57754 Module Stocks GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(7)<>2 End Endif

Call VALGTC(APPLI,"SXT") From SUBGTC

End

