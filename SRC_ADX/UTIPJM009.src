#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM009
# Issue X3-16743/120384 - 2016-12-15 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM009(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM009(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Integer IFOUND

  IERR = 0
  Call ECR_TRACE("UTIPJM009: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMPH
  #
  If filinfo(filpath("FIL", "PJMTIMEMPH", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMTIMEMPH" [PTEH]
  Local File =SZAPPLI + ".PJMTIMEMP"  [PTE]
  # -------------------------
  Trbegin [PTEH]
  NCOUNT = 0
  NCOUNTERROR = 0
  Call ECR_TRACE("UTIPJM009: Updating PJMTIMEMPH", 0) From GESECRAN
  Filter [PTEH]
  For [PTEH]PTEH0
    # -----------------------------
    Filter [PTE] Where [F:PTE]CLB = [F:PTEH]CLB
    IFOUND = 0
    For [PTE]
      IFOUND = 1
      Break
    Next
    Filter [PTE]
    If IFOUND = 0 Then
      NCOUNT += 1
      Delete [PTEH]Curr
      If fstat Then
        Call ECR_TRACE("File PJMTIMEMPH" - [F:PTEH]CLB + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
    # -----------------------------
  Next
  Filter [PTEH]
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM009: PJMTIMEMPH" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM009: PJMTIMEMPH" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM009 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM009 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMEMPH","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMPH") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM009(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMEMPH","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMEMPH") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM009(APPLI)
End

