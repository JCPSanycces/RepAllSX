Readlock [ITM]ITM0=W_ITM(W_I)
Case fstat
 When 0 :
  W_ITM    = ""                       # Issue 94787 GA 11/2013 before [F:ITM]ITMREF
  S_CPTCFG = [F:ITM]CFGVCRNUM         # JPJ E19035
  Gosub DEL_NOMENCL  From CFGLIBC
  If GOK<> 1 Return Endif
  Gosub DEL_GAMME    From CFGLIBC
  If GOK<> 1 Return Endif
# Issue 98703 GA 05/2014 Suppression article en fin de traitement uniquement
  Gosub DEL_ARTICLE From CFGLIBC
 When 1   :    # JPJ E-Gestion Lock
   GLOCK="$ITMMASTER"-W_ITM(W_I) : GOK=-1
# When Default : # Issue 89095 GA 06/2013 article déjà supprimé ? pas d'erreur ...
#   Call RSTACTX("ITM",W_ITM(W_I),W_TRASTP,"$DELETE_CONFIG") From CFGLIBD
#   GOK=0
Endcase
Return

