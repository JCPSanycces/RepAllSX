$OLD_ANNULE_NOM
# Suppression nomenclature
Filter [BOH1] Where ITMREF = W_ITM(W_I)
&             Order By Key BOH0
W_FLGEXIST=0
For [BOH1]
  If [BOH1]CFGVCRNUM <> LCFG
    W_FLGEXIST=1
    GOK = 0
    GMESSAGE = mess(238,188,1)-[BOH1]ITMREF-num$([BOH1]BOMALT)
    If [BOH1]CFGVCRNUM<>"" : GMESSAGE-=mess(240,188,1)-[BOH1]CFGVCRNUM : Endif
    Call ERREUR(GMESSAGE) From GESECRAN
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Endif
Next
Filter [BOH1]
If W_FLGEXIST : Return : Endif

Filter [BOH1] Where ITMREF = W_ITM(W_I) & CFGVCRNUM = LCFG
&             Order By Key BOH0
For [BOH1]
  Readlock [BOH1] Curr
  Case fstat
  When 1 :
    GOK = -1
    Break
  When 0 :
    # Gosub ANNULE_BOD1
    # Gosub ANNULE_BOD2
    If GOK <> 1
      Break
    Endif
    Call VERIF("BOM",LCFG,W_ITM(W_I),LFCY,"",[F:BOH1]BOMALT,LOPT,W_OKANU)
    If W_OKANU <> 0
      GOK = 0
      Break
    Else
      Call LOA_TEXTE("BOM","[F:BOH1]",W_TEX,W_TEXTYP,W_ITXT)      # JPJ TEX->TXC
      Delete [BOH1]
      If fstat
        GOK = 0
        Call FSTA("BOH1") From GLOCK
        Break
      Endif
    Endif
  When Default :
    GOK = 0
    Call FSTA("BOH1") From GLOCK
    Break
  Endcase
Next
Filter [BOH1]
Return
