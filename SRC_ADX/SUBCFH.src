If dim(LCFG)<=0 | LCFG="" Return Endif

  S_CPTCFG = LCFG
  Gosub DEL_NOMENCL  From CFGLIBC

Return

############################################################
$DELETE_ROUTING                       # Issue 89095 GA 06/2013 #
If dim(LCFG)<=0 | LCFG="" Return Endif

  S_CPTCFG = LCFG
  Gosub DEL_GAMME    From CFGLIBC

Return

############################################################
Subprog DEL_TEXTRA(LFIC,LFLD,LCR1,LCR2)
Value Char LFIC
Value Char LFLD
Value Char LCR1
Value Char LCR2
Filter [AXX] Where CODFIC = LFIC &
&                  ZONE   = LFLD &
&                  IDENT1 = LCR1 &
&                  IDENT2 = LCR2
&            Order By Key AXX0
For [AXX]
  Readlock [AXX] Curr
  Case fstat
    When 0 :
      Delete [AXX]
      If fstat
        GOK= 0
        Call FSTA("AXX") From GLOCK
        Break
      Endif
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("AXX") From GLOCK
      Break
  Endcase
Next
Filter [AXX]
End
############################################################
# Chargement des textes à supprimmer
Subprog LOA_TEXTE(LFIC,LABR,LTAB,LTEXTYP,LIND)         # JPJ TEX->TXC
Value    Char     LFIC
Value    Char     LABR
Variable Char     LTAB()
Variable Char     LTEXTYP()
Variable Integer  LIND
#
Local    Char     W_ABR(10)
Local    Char     W_EVA(40)
Local    Integer  W_I
#
Gosub PAR_TEX From WUVAR
#
W_I = find(LFIC,W_FICNAM)
If LABR = ""
  W_ABR = W_FICABR(W_I-1)
Else
  W_ABR = LABR
Endif
#
For W_I = 0 To dim(W_FICTEF)-1
  If LFIC = W_FICTEF(W_I)
    W_EVA = evalue(W_ABR+W_FICTEZ(W_I))
    If W_EVA <> ""
      If LIND < dim(LTAB)
        LTAB(LIND) = W_EVA
        LTEXTYP(LIND) = W_FICTET(W_I)      # JPJ TEX->TXC
        LIND      += 1
      Endif
    Endif
  Endif
Next W_I
End
############################################################
# Actions écran
############################################################
Subprog C_SCENUM(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_CFGVCRNUM(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog AS_DATREF(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
  VALEUR = GBIDA1
Endif
End
############################################################
Subprog AM_DATREF(VALEUR)
Variable Date    VALEUR
GBIDA1 = VALEUR
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran CFH2) 21/03/2014 11:36:24 (GA)
######################################################################################
Subprog AVANT_NBLIG
# Issue 96688 GA 03/2014 Clob
If [M:CFH2]QSTNUM(nolign-1)="" Return Endif
Read [CQU]CQU0=[M:CFH2]QSTNUM(nolign-1)
If !fstat & [F:CQU]ASWTYP=7
  Filter [CFH]  Where SCENUM    = [M:CFH0]SCENUM
&                  &  CFGVCRNUM = [M:CFH0]CFGVCRNUM
&                  &  SYMNUM    = [M:CFH2]QSTNUM(nolign-1)
&             Order By Key CFH0
  For [CFH]
       Setlob [M:CFH2]VALCLB With [F:CFH]VALALP
       Affzo [M:CFH2]VALCLB
       Break
  Next
  Filter [CFH]
Endif
End


