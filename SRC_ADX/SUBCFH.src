        Call VERIF("ROUTING",LCFG,[F:ROH1]ITMREF,[F:ROH1]FCY,"",[F:ROH1]ROUALT,LOPT,W_OKANU)
        If W_OKANU <> 0
          GOK = 0
          Break
        Else
          Call LOA_TEXTE("ROUTING","[F:ROH1]",W_TEX,W_TEXTYP,W_ITXT)      # JPJ TEX->TXC
          Delete [ROH1]
          If fstat
            GOK = 0
            Call FSTA("ROH1") From GLOCK
            Break
