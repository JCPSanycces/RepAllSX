#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "OUVRE"        : Gosub OUVRE
  When "LIENS"        : Gosub LIENS
  When "FILTRE"       : Gosub FILTRE
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "SETBOUT"      : Gosub SETBOUT
  When "ANNULE"       : Gosub ANNULE
  When "FERME"        : Gosub FERME
Endcase
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Endif
Return
############################################################
$OUVRE
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_DESTCT(GLONDCT) : # Intitule code table de contrôle
Else
  Local Char  W_DESTCT(30)      : # Intitulé code table de contrôle
Endif
Local Char    W_FLDTCT(10)  : # Champ intitulé table de contrôle
#
GBIDA1 = [31/12/2999]
[M:CFH0]DATREF = GBIDA1
Call OUVRE_TRACE("") From LECFIC
If GMODU(8) = 2
  If clalev([F:TRO])  = 0 : Local File TABROUALT  [TRO]  : Endif
  If clalev([F:ROH])  = 0 : Local File ROUTING    [ROH]  : Endif
  If clalev([F:ROO])  = 0 : Local File ROUOPE     [ROO]  : Endif
  If clalev([F:ROS])  = 0 : Local File ROUSCD     [ROS]  : Endif
Endif
If clalev([F:CBB]) = 0 : Local File CBLOB       [CBB]  : Endif    # FQ 50444 GA 11/2008
If clalev([F:AOX]) = 0 : Local File AOBJTXT     [AOX]  : Endif    # FQ 50444 GA 11/2008
If clalev([F:ATB1]) = 0 : Local File ATABLE     [ATB1] : Endif
If clalev([F:ATZ1]) = 0 : Local File ATABZON    [ATZ1] : Endif
If clalev([F:ATI1]) = 0 : Local File ATABIND    [ATI1] : Endif
Return
############################################################
$FERME
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Call IMPSCR From ATRTX3
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
############################################################
$COP_ECRAN
Local Char WMSK(10)(4)
Local Char WABR(06)(4)
#
Raz WMSK, WABR
WMSK(0) = "CFH0"
WMSK(1) = "CFH1"
WMSK(2) = "CFH2"
WMSK(3) = "CFH3"
WABR(0) = "CFH0"
WABR(1) = "CFH1"
WABR(2) = "CFH2"
WABR(3) = "CFH3"
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return
############################################################
$FILTRE
Return
############################################################
$FILGAUCHE
If [M:CFH0]DATREF = [0/0/0]
  [M:CFH0]DATREF = GBIDA1
Endif
FILGAUCHE = '[F:CHH]CFGDELDAT<=[M:CFH0]DATREF'
Return
############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"CDH") From GOBJET
Return
############################################################
$LIENS
If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008
  Local Char  W_VAL(GLONDCT+10) : # Intitule code table de contrôle
Else
  Local Char  W_VAL(40)
Endif
Read [BPR]BPR0=[M:CFH1]CFGBPRNUM
If fstat
  Raz [F:BPR]
Endif
[M:CFH1]BPRNAM = [F:BPR]BPRNAM
#
Read [ITM]ITM0=[M:CFH1]ROUNUM
If fstat
  Raz [F:ITM]
Endif
#[M:CFH1]ROUDES  = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFH1]ROUDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
#
Read [ITM]ITM0=[M:CFH1]ITMREF
If fstat
  Raz [F:ITM]
Endif
[M:CFH1]STU     = [F:ITM]STU
#[M:CFH1]ITMDES1 = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFH1]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Filter [CFH]  Where SCENUM    = [M:CFH0]SCENUM    &
&                   CFGVCRNUM = [M:CFH0]CFGVCRNUM
&             Order By Key CFH0
Raz [M:CFH2]
Raz [M:CFH3]
For [CFH]
  Read [CQU]CQU0=[F:CFH]SYMNUM
  If fstat = 0
    Case [F:CQU]QSTTYP
      When 1 :
        If [M:CFH2]NBLIG < dim([M:CFH2]QSTNUM)-1
          [M:CFH2]QSTNUM   ([M:CFH2]NBLIG) = [F:CFH]SYMNUM
          #[M:CFH2]QSTDES   ([M:CFH2]NBLIG) = [F:CQU]QSTSHO # FQ 53410 remplacé par lien
          Case [F:CQU]ASWTYP
            When 1 :
              W_VAL = vireblc([F:CFH]VALALP,1)
              If [F:CQU]TCT <> ""
                Read [TCT]TCT1=[F:CQU]TCT;[F:CFH]VALALP;0
                If fstat = 0
                  Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                  W_VAL += (" ("+W_DESTCT+")")
                Endif
              Endif
              If [F:CQU]SHACAT <> ""
                Read [CSH]CSH0=[F:CQU]SHACAT;[F:CFH]VALALP
                If fstat = 0
                  # FQ 60007 GA 11/2009
                  #W_VAL += (" ("+[F:CSH]SHANUMDES+")")
                  Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CQU]SHACAT,[F:CFH]VALALP) From ATEXTRA
                  W_VAL += (" ("+GBIDC1+")")
                Endif
              Endif
            When 2 :
              W_VAL = num$([F:CFH]VALNUM)
              If [F:CQU]TCT <> ""
                Read [TCT]TCT1=[F:CQU]TCT;"";[F:CFH]VALNUM
                If fstat = 0
                  Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                  W_VAL += (" ("+W_DESTCT+")")
                Endif
              Endif
            When 3 :
              W_VAL = format$("DfZz:"+GFMDAT,[F:CFH]VALDAT)
            When 4 :
              W_VAL = mess([F:CFH]VALNUM+1,1,1)
            When 5 :
              W_VAL = vireblc([F:CFH]VALALP,1)
              Call EFF_CRLF(W_VAL) From CFGLIBD
            When 6 :        # Issue 96688 GA 03/2014 Blob
               Raz W_VAL
            When 7 :        # Issue 96688 GA 03/2014 Clob
               Raz W_VAL
          Endcase
          [M:CFH2]QSTVAL([M:CFH2]NBLIG) = W_VAL
          [M:CFH2]QSTSEA([M:CFH2]NBLIG) = [F:CQU]SEAFLG
          [M:CFH2]NBLIG += 1
        Endif
      When 2 :
        If [M:CFH3]NBLIG < dim([M:CFH3]VARNUM)-1
          [M:CFH3]VARNUM   ([M:CFH3]NBLIG) = [F:CFH]SYMNUM
          [M:CFH3]VARSEQ   ([M:CFH3]NBLIG) = [F:CFH]SYMSEQ
          #[M:CFH3]VARDES   ([M:CFH3]NBLIG) = [F:CQU]QSTSHO # FQ 53410 remplacé par lien
          [M:CFH3]VARTYP   ([M:CFH3]NBLIG) = [F:CQU]QSTORI
          Case [F:CQU]ASWTYP
            When 1 :
              W_VAL = vireblc([F:CFH]VALALP,1)
              If [F:CQU]TCT <> ""
                Read [TCT]TCT1=[F:CQU]TCT;[F:CFH]VALALP;0
                If fstat = 0
                  Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                  W_VAL += (" ("+W_DESTCT+")")
                Endif
              Endif
              If [F:CQU]SHACAT <> ""
                Read [CSH]CSH0=[F:CQU]SHACAT;[F:CFH]VALALP
                If fstat = 0
                  # FQ 60007 GA 11/2009
                  #W_VAL += (" ("+[F:CSH]SHANUMDES+")")
                  Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CQU]SHACAT,[F:CFH]VALALP) From ATEXTRA
                  W_VAL += (" ("+GBIDC1+")")
                Endif
              Endif
            When 2 :
              W_VAL = num$([F:CFH]VALNUM)
              If [F:CQU]TCT <> ""
                Read [TCT]TCT1=[F:CQU]TCT;"";[F:CFH]VALNUM
                If fstat = 0
                  Call CFGDESTCT(W_DESTCT,W_FLDTCT) From CFGLIB
                  W_VAL += (" ("+W_DESTCT+")")
                Endif
              Endif
            When 3 :
              W_VAL = format$("DfZz:"+GFMDAT,[F:CFH]VALDAT)
            When 4 :
              W_VAL = mess([F:CFH]VALNUM+1,1,1)
            When 5 :
              W_VAL = vireblc([F:CFH]VALALP,1)
              Call EFF_CRLF(W_VAL) From CFGLIBD
          Endcase
          [M:CFH3]VARVAL([M:CFH3]NBLIG) = W_VAL
          [M:CFH3]VARSEA([M:CFH3]NBLIG) = [F:CQU]SEAFLG
          [M:CFH3]NBLIG += 1
        Endif
    Endcase
  Endif
Next
Filter [CFH]
[M:CFH0]DATREF = GBIDA1
Return
############################################################
$ANNULE
Call ANU_CONFIG([M:CFH1]FCY,[M:CFH0]CFGVCRNUM,[M:CFH1]CFGBPRNUM,[M:CFH1]BOMALT,0,OK)
Return
############################################################
Subprog ANU_CONFIG(LFCY,LCFG,LBPR,LALT,LOPT,OK)
Value    Char     LFCY
Value    Char     LCFG
Value    Char     LBPR
Value    Shortint LALT
Value    Integer  LOPT
Variable Integer  OK
#
If LCFG = ""
  End
Endif
#
Local    Integer  W_OKANU
Local    Char     W_TEX(12)(999)      : # Tableau des textes à supprimer
Local    Char     W_TEXTYP(3)(999)    : # Tableau des types de textes à supprimer ('TEX' | 'TEC')
Local    Integer  W_ITXT               : # Indice des textes à supprimer
Local    Integer  WNBITM : WNBITM=300      # Issue 96028 01/2014 taille max du tableau
Local    Char     W_ITM(GLONITM)(WNBITM) : # Tableau des articles à supprimer
Local    Integer  W_LLC         (WNBITM) : # Tableau des codes de plus bas niveau
Local    Integer  W_IIT               : # Indice  des articles à supprimer
Local    Char     W_FIL(250)
Local    Integer  W_RET
Local    Integer  W_I, W_FLGEXIST
#
If dim(S_CPTCFG)<0
   Gosub TAB_SYMBOLES   From WUVAR
Endif

# Issue 116197 - 2016-09-15 by STLIG : Re-declare WNO_DEFAULT_TEXT (CFG_CONSTANTES) for repeat deletions
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_CRESYMSYS  From CFGLIB

Gosub OPEN_FILES From CFGLIBB

#
# Suppression articles
#
Raz W_ITM, W_LLC, W_IIT, W_TEX, W_ITXT
#
      Filter [ITM1] Where CFGVCRNUM = LCFG
&             Order By Key ITM4
#
#   JPJ 28042004 - Identifier par #$
#       * Suppression du tri sur LLC
#          Nota: le tri sur LLC descendant me semblait faux (composant avant composé donc échec vérification)
#       * Structures en 2 boucles:
#            1 suppression, 1 vérification
#
For [ITM1]
  #If W_IIT < dim(W_ITM)-1 # Issue 96028 01/2014 le dim ne fonctionne pas ?
  If W_IIT < WNBITM-1
    W_ITM(W_IIT) = [F:ITM1]ITMREF
    W_LLC(W_IIT) = 0
#$    Filter [ITB1] Where ITMREF = [F:ITM1]ITMREF
#$&                 Order By Key ITB0
#$    For [ITB1]
#$      If [F:ITB1]LLC > W_LLC(W_IIT)
#$        W_LLC(W_IIT) = [F:ITB1]LLC
#$      Endif
#$    Next
#$    Filter [ITB1]
    W_IIT += 1
  Endif
Next
Filter [ITM1]

# Issue 89095 GA 07/2013 si article sur une autre code config, supprimer les données techniques
If W_IIT=0
   Gosub DELETE_BOM
   Gosub DELETE_ROUTING
   Goto  ANU_CONFIG_FIN
Endif

#$ Sorta W_IIT W_ITM,W_LLC Order By W_LLC(indice) Desc
#
For W_I = 0 To W_IIT-1
  Read [ITM]ITM0=W_ITM(W_I)
  Call PUR_STOCKS(W_ITM(W_I),W_OKANU) From CFGLIBD
  If GOK <> 1
    Break
  Else
    If W_OKANU <> 0
      GOK = 0
      GMESSAGE = [F:ITM]ITMREF-mess(68,188,1)
      Call ERREUR(GMESSAGE) From GESECRAN
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
      Break
    Else
     # Issue 89095 GA 06/2013
      Call LOA_TEXTE("ITMMASTER","",W_TEX,W_TEXTYP,W_ITXT)
      Call LOA_TEXTE("ITMFACILIT","",W_TEX,W_TEXTYP,W_ITXT)
      Call LOA_TEXTE("ITMSALES","",W_TEX,W_TEXTYP,W_ITXT)
      Call LOA_TEXTE("ITMBPS","",W_TEX,W_TEXTYP,W_ITXT)
      Call LOA_TEXTE("ITMBPC","",W_TEX,W_TEXTYP,W_ITXT)
     # Gosub ANNULE_NOM
     # If GOK <> 1
     #   Break
     # Endif
     # Gosub ANNULE_ROU
     # If GOK <> 1
     #   Break
     # Endif
     # Gosub ANNULE_ART
     # If GOK <> 1
     #   Break
     # Endif
      Gosub DELETE_CONFIG   # Issue 89095 GA 06/2013 idem exec du CFG
      Gosub ANNULE_DIV
      If GOK <> 1
        Break
      Endif
    Endif
  Endif
Next W_I  #$

If GOK<>1 : Goto ANU_CONFIG_FIN : Endif
For W_I = 0 To W_IIT-1    #$
      Call VERIF("ITMFACILIT",LCFG,W_ITM(W_I),LFCY,"",0,LOPT,W_OKANU)
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
      Call VERIF("ITMMVT",LCFG,W_ITM(W_I),LFCY,"",0,LOPT,W_OKANU)
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
      Call VERIF("ITMSALES",LCFG,W_ITM(W_I),"","",0,LOPT,W_OKANU)
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
      Call VERIF("ITMBPC",LCFG,W_ITM(W_I),"",LBPR,0,LOPT,W_OKANU)
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
      Call VERIF("ITMBPS",LCFG,W_ITM(W_I),"",LBPR,0,LOPT,W_OKANU)   # Issue 89095 GA 06/2013 ajouté
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
      Call VERIF("ITMMASTER",LCFG,W_ITM(W_I),"","",0,LOPT,W_OKANU)
      If W_OKANU <> 0
        GOK = 0
        Break
      Endif
Next W_I

#

# Issue 89095 GA 07/2013 sinon les boucles plantent
If W_ITXT=0 : Goto ANU_CONFIG_FIN : Endif

# Suppression des textes TXC
If GOK<>1 : Goto ANU_CONFIG_FIN : Endif
  For W_I = 0 To W_ITXT-1
    If W_TEXTYP(W_I)="TXC"    # Textes clob
        Call SUP_CLOB(W_TEX(W_I),W_OKANU) From TRTX3TEX
        If W_OKANU<>1
            GOK=0 : Break
        Endif
    Endif
  Next W_I

# Suppression des textes ("txt" + "rtf")
If GOK<>1 : Goto ANU_CONFIG_FIN : Endif
  For W_I = 0 To W_ITXT-1
    If W_TEXTYP(W_I)="TEX"
        W_FIL = filpath("TXT",W_TEX(W_I),"txt")
        Call EFFACE(W_FIL,W_RET) From ORDSYS
        W_FIL = filpath("TXT",W_TEX(W_I),"rtf")
        Call EFFACE(W_FIL,W_RET) From ORDSYS
    Endif
  Next W_I

#
$ANU_CONFIG_FIN
If GOK <> 1
  OK = 0
Endif
End
############################################################
Subprog VERIF(LFIC,LCFG,LITM,LFCY,LBPR,LALT,LOPT,LRET)
Value    Char     LFIC
Value    Char     LCFG
Value    Char     LITM
Value    Char     LFCY
Value    Char     LBPR
Value    Shortint LALT
Value    Integer  LOPT
Variable Integer  LRET

## GH 23/03/2016 bug 114032 wrong length for local variables
Local Char    WFIC(GLONATB)                    #Local Char    WFIC(10)
Local Char    WFIL(250)
Local Char    WWRK(type([F:ATZ1]EXPLIEN)-10)   #Local Char    WWRK(50)
Local Char    WIND1(GLONAVA)                   #Local Char    WIND1(10)
Local Char    WIND2(GLONAVA)                   #Local Char    WIND2(10)
Local Char    WIND3(GLONAVA)                   #Local Char    WIND3(10)
Local Char    WCLE(250)                        #Local Char    WCLE(120)
Local Char    WDES(type([F:ATI1]DESCRIPT)-10)  #Local Char    WDES(80)
Local Char    WFLD(GLONAVA)                    #Local Char    WFLD(10)

Local Integer WFSTAT
Local Integer I, J, K
#
WFSTAT = fstat
LRET   = 0

# Issue 89095 GA 06/2013
If LITM="" | LFIC="" End Endif

Call TEMPON (mess(4,115,1)-LFIC-LITM) From GESECRAN

Filter [ATZ1] Where LIEN = LFIC & ANNUL = 1
&             Order By Key LIEN
For [ATZ1]
  WFIC  = [F:ATZ1]CODFIC
  If !find(WFIC,"BOM","ITMBOM","ROUTING")
    Raz WIND1, WIND2, WIND3, WCLE
    If [F:ATZ1]EXPLIEN = ""
      WIND1 = [F:ATZ1]CODZONE
    Else
      I = instr(1,[F:ATZ1]EXPLIEN,";")
      If I = 0
        WIND1 = [F:ATZ1]CODZONE
      Else
        WIND1 = left$([F:ATZ1]EXPLIEN,I-1)
        WWRK  = mid$([F:ATZ1]EXPLIEN,I+1,len([F:ATZ1]EXPLIEN)-I)
        Raz I
        I = instr(1,WWRK,";")
        If I = 0
            WIND2 = WWRK
        Else
            WIND2 = left$(WWRK,I-1)
            WIND3 = mid$(WWRK,I+1,len(WWRK)-I)
        Endif
      Endif
    Endif
    Read [ATB1]CODFIC = WFIC
    If fstat = 0
      If filinfo(filpath("FIL",WFIC,"fde"),0) >= 0
        Local File =WFIC [LNK]
        Case LFIC
          When "ITMMASTER"  :
            WFIL  = "[F:LNK]"+WIND1+"=LITM"
          When "ITMFACILIT" :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LFCY"
          When "ITMMVT"     :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LFCY"
          When "ITMSALES"   :
            WFIL = "[F:LNK]"+WIND1+"=LITM"
          When "ITMBPC"     :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LBPR"
          When "ITMBPS"     :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LBPR"       # Issue 89095 GA 06/2013 ajouté
          When "ROUTING"    :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LALT & [F:LNK]"+WIND3+"=LFCY"
          When "BOM"        :
            WFIL = "[F:LNK]"+WIND1+"=LITM & [F:LNK]"+WIND2+"=LALT"
          When Default      :
            Goto SUITE_FIC
        Endcase
        Filter [LNK] Where evalue(WFIL)
        For [LNK]
          LRET = 1
          Gosub GEN_CLE
          GMESSAGE = mess(22,115,1)-WFIC+"\"+WCLE
          If LOPT = 0
            Call ERREUR(GMESSAGE) From GESECRAN
          Endif
          Call ECR_TRACE(GMESSAGE,1) From GESECRAN
          Break
        Next
        Filter [LNK]
        Close Local File [LNK]
      Endif
    Endif
  Endif
$SUITE_FIC
Next
Filter [ATZ1]
Call TEMPOFF From GESECRAN
fstat = WFSTAT
End
############################################################
$GEN_CLE
WCLE = ""
Read [ATI1]NUMLIG(2)=WFIC;1
WDES = [F:ATI1]DESCRIPT
While WDES <> ""
  J = instr(1,WDES,"+")
  K = instr(1,WDES,"-")
  If K
    If J
      J = min(J,K)
    Else
      J = K
    Endif
  Endif
  If J
    WFLD = left$(WDES,J-1)
    WDES = right$(WDES,J+1)
  Else
    WFLD = WDES
    WDES = ""
  Endif
  WCLE -= num$(evalue("[F:LNK]"+WFLD))
Wend
Return
############################################################
$OLD_ANNULE_ART
Readlock [ITM]ITM0=W_ITM(W_I)
Case fstat
  When 1 :
    GOK = -1
    Return
  When 0 :
    Call LOA_TEXTE("ITMMASTER","",W_TEX,W_TEXTYP,W_ITXT)      # JPJ TEX->TXC
    Call DEL_TEXTRA("ITMMASTER","DES1AXX",[F:ITM]ITMREF,"")
    Call DEL_TEXTRA("ITMMASTER","DES2AXX",[F:ITM]ITMREF,"")
    Call DEL_TEXTRA("ITMMASTER","DES3AXX",[F:ITM]ITMREF,"")
    Delete [ITM]
    If fstat
      GOK = 0
      Call FSTA("ITM") From GLOCK
      Return
    Endif

  When 4,5 :
  When Default :
    GOK = 0
    Call FSTA("ITM") From GLOCK
    Return
Endcase
# Article site
Filter [ITF] Where ITMREF = W_ITM(W_I)
&            Order By Key ITF0
For [ITF]
  Readlock [ITF] Curr
  Case fstat
    When 1 :
      GOK = -1
      Break
    When 0 :
      Call LOA_TEXTE("ITMFACILIT","",W_TEX,W_TEXTYP,W_ITXT)      # JPJ TEX->TXC
      Delete [ITF]
      If fstat
        GOK = 0
        Call FSTA("ITF") From GLOCK
        Break
      Else
        Gosub OLD_ANNULE_ITC
      Endif
    When Default :
      GOK = 0
      Call FSTA("ITF") From GLOCK
      Break
  Endcase
Next
Filter [ITF]
# Article cumuls
If GOK = 1
  Filter [ITV] Where ITMREF = W_ITM(W_I)
&              Order By Key ITV0
  For [ITV]
    Readlock [ITV] Curr
    Case fstat
      When 1 :
        GOK = -1
        Break
    When 0 :
      Delete [ITV]
      If fstat
        GOK = 0
        Call FSTA("ITV") From GLOCK
        Break
      Endif
    When Default :
      GOK = 0
      Call FSTA("ITV") From GLOCK
      Break
    Endcase
  Next
  Filter [ITV]
Endif
# Article nomenclature de travail
If GOK = 1
  Filter [CFB] Where ITMREF = W_ITM(W_I)
&            Order By Key ITB0
  For [CFB]
      Readlock [CFB] Curr
      Case fstat
        When 1 :
          GOK = -1
          Break
        When 0 :
          Delete [CFB]
          If fstat
