#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque UMAJDEROG
################################################################
#
# Modifs :
# CBO 2012.12.26 FQ00000 déblocage MAJ (pour ALS)
#
# CBO 2015.02.27 FQ106373 : ajout PCALAUTONOME pour forcer à passer par le calcul copié
################################################################
################################################################
#
#  Outil : utilitaire de contrôle et de maj du dérogatoire
#
################################################################
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT, PARBOUT, "", "UMAJDEROG", "UMAJDEROG", 3, "") From GTRAITE
End

$ACTION
Case ACTION
    When"AVANT_PAR"     : Gosub AVANT_PAR
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "END"          : ABANDON=G_OUI
    When "EXEC"         : Gosub EXEC
Endcase
Return


$AVANT_PAR
    If !clalev([M:DIA])
        Local Mask UMAJDEROG [DIA]
    Endif
    If !clalev([M:DI1])
        Local Mask UMAJDEROG1 [DI1]
    Endif
    If !clalev([M:DI2])
        Local Mask UMAJDEROG2 [DI2]
    Endif
Return

$OUVRE
    Global Integer ABANDON
    Local Integer OK
Return

$DEBUT
    [M:DI1]FLGSIM = G_OUI
    [M:DI1]FLGTRC = G_OUI
    [M:DI1]CALAUTONOME = G_NON

    [M:DIA]CPY = ""
    [M:DIA]CPYTOUS = G_OUI
    [M:DIA]FCY = ""
    [M:DIA]FCYTOUS = G_OUI
    [M:DIA]ACCCODTOUS = G_OUI
    [M:DIA]ACCCOD = ""
    [M:DIA]FXDTOUS = G_OUI
    [M:DIA]AASREF = ""
    [M:DI2]EXP1 = ""

    [M:DI2]TXTC1 = "Level 1 : Delta <-- Sum of Fiy and periods"
    [M:DI2]TXTC2 = "Level 2 : Delta <-- Sum of periods"

    [M:DI2]TXTNC1 = "Level 1 : sum of Fiy"
    [M:DI2]TXTNC2 = "Level 2 : sum of Fiy + sum of periods"
    [M:DI2]TXTNC3 = "Level 3 : sum of Fiy + sum of periods + period dotation"

    [M:DI2]PERCOUR = G_NON
    [M:DI2]PER1 = G_NON
    [M:DI2]TOUTESPER = G_OUI
    [M:DI2]TRTFIRSTPER = G_NON

    Diszo [M:DI1]FLGTRC
    Diszo [M:DI2]TOUTESPER

    Affzo [M:DIA]
    Affzo [M:DI1]
    Affzo [M:DI2]
Return
#________
$EXEC

    If ABANDON=G_OUI
        Return
    Endif
If GUSER <> "CBO"
    If [M:DI1]FLGSIM = G_NON
        Call OUINON(mess(188, 7774, 1), OK) From GESECRAN
    Else
        Call OUINON(mess(176, 7774, 1), OK) From GESECRAN
    Endif
    If (OK = 1) Then
        FIN      = 0
        GERR     = 1
        Return
    Endif
Endif
If [M:DI1]FLGSIM = G_NON
Endif
 # FQ106373  # CALAUTONOME
    Call UMAJDEROG([M:DI1]FLGSIM, [M:DI1]FLGTRC,
&     [M:DIA]CPYTOUS, [M:DIA]CPY, [M:DIA]FCYTOUS, [M:DIA]FCY,
&     [M:DIA]ACCCODTOUS, [M:DIA]ACCCOD, [M:DIA]FXDTOUS,
&     [M:DIA]AASREF, [M:DI2]EXP1, [M:DI2]NIV_COMPTA,
&     [M:DI2]NIV_CTRLE, [M:DI2]FORCEBIEN, [M:DI2]PER1, [M:DI2]PERCOUR,
&     [M:DI2]MJQUECOUR, [M:DI1]CALAUTONOME, [M:DI2]TRTFIRSTPER) From UMAJDEROG2

Return


Subprog AM_CPYTOUS(VALEUR)
Variable Integer VALEUR
    If VALEUR = G_OUI
        [M:DIA]CPY = ""
        Diszo [M:DIA]CPY
    Else
        Actzo [M:DIA]CPY
    Endif
    Affzo [M:DIA]CPY
End

Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
    If [M:DIA]CPYTOUS = G_OUI
        Diszo [M:DIA]CPY
    Else
        Actzo [M:DIA]CPY
    Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

    If VALEUR <> "" and [M:DIA]CPY <> "" and VALEUR <> [M:DIA]CPY
        [M:DIA]FCY = ""
        Affzo [M:DIA]FCY
    Endif
End

Subprog AM_FCYTOUS(VALEUR)
Variable Integer VALEUR
    If VALEUR = G_OUI
        [M:DIA]FCY = ""
        Diszo [M:DIA]FCY
    Else
        Actzo [M:DIA]FCY
    Endif
    Affzo [M:DIA]FCY
End

Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()
    If [M:DIA]FCYTOUS = G_OUI
        Diszo [M:DIA]FCY
    Else
        Actzo [M:DIA]FCY
    Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

    If VALEUR <> "" and instr(1, VALEUR, "*") = 0
        Local File FACILITY [FCY]
        Read [F:FCY]FCY0 = VALEUR
        If fstat = 0
            [M:DIA]CPYTOUS = G_NON
            [M:DIA]CPY     = [F:FCY]LEGCPY
            Affzo [M:DIA]CPYTOUS, CPY
        Endif
        Close File [FCY]
    Endif
End

Subprog AM_ACCCODTOUS(VALEUR)
Variable Integer VALEUR
    If VALEUR = G_OUI
        [M:DIA]ACCCOD = ""
        Diszo [M:DIA]ACCCOD
    Else
        Actzo [M:DIA]ACCCOD
    Endif
    Affzo [M:DIA]ACCCOD
End

Subprog AV_ACCCOD(VALEUR)
Variable Char    VALEUR()
    If [M:DIA]ACCCODTOUS = G_OUI
        Diszo [M:DIA]ACCCOD
    Else
        Actzo [M:DIA]ACCCOD
    Endif
End

Subprog AM_FXDTOUS(VALEUR)
Variable Integer VALEUR
    If VALEUR = G_OUI
        [M:DIA]AASREF = ""
        [M:DI2]FORCEBIEN = G_NON
        Diszo [M:DIA]AASREF
        Diszo [M:DI2]FORCEBIEN
    Else
        Actzo [M:DIA]AASREF
        Actzo [M:DI2]FORCEBIEN
    Endif
    Affzo [M:DIA]AASREF
    Affzo [M:DI2]FORCEBIEN
End

# contrôle de l'expression de sélection (sur FXDASSETS)
Subprog AV_AASREF(VALEUR)
Variable Char    VALEUR()
    If [M:DIA]FXDTOUS = G_OUI
        Diszo [M:DIA]AASREF
    Else
        Actzo [M:DIA]AASREF
    Endif
End

Subprog AM_AASREF(VALEUR)
Variable Char    VALEUR()

    If VALEUR <> "" and instr(1, VALEUR, "*") = 0
        Local File FXDASSETS [FAS]
        Read [F:FAS]FAS0 = VALEUR
        If fstat = 0
            [M:DIA]CPYTOUS = G_NON
            [M:DIA]CPY     = [F:FAS]CPY
            [M:DIA]FCYTOUS = G_NON
            [M:DIA]FCY     = [F:FAS]FCY
            Affzo [M:DIA]CPYTOUS, CPY, FCYTOUS, FCY
        Endif
        Close File [FAS]
    Endif
End

Subprog C_EXP1(VALEUR)
Variable Char    VALEUR()

Local Integer ER, K

    If VALEUR <> ""
        Local File FXDASSETS [FAS]
        Onerrgo ERREXP
        ER = 0
        K = evalue(VALEUR)
        Onerrgo
        Close File [FAS]

        If ER
            mkstat = 2
        Endif
    Endif
End

$ERREXP
    ER = errn
    GMESSAGE = mess(37,124,1) + "\" + errmes$(ER) + "\" + errm
    ER=1
Resume

Subprog B5_EXP1(VALEUR)
Variable Char    VALEUR()

    Infbox mess(193, 7774, 1)
End

Subprog AM_PER1(VALEUR)
Variable Integer VALEUR
    If VALEUR = G_OUI or [M:DI2]PERCOUR = G_OUI
        [M:DI2]TOUTESPER = G_NON
    Else
        [M:DI2]TOUTESPER = G_OUI
    Endif
    Affzo [M:DI2]TOUTESPER
End

Subprog AM_PERCOUR(VALEUR)
Variable Integer VALEUR
    # Issue X3-93379
    If VALEUR = G_OUI or [M:DI2]PER1 = G_OUI
        [M:DI2]TOUTESPER = G_NON
    Else
        [M:DI2]TOUTESPER = G_OUI
    Endif
    Affzo [M:DI2]TOUTESPER
End


######################################################################################

