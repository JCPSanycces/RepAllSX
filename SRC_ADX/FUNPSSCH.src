#<AdxTL>@(#)0.0.0.0 $Revision$ 
# FUNPSSCH
# -------------------------------------
# This function calls a dialog screen to prompt for site.
# It then calls a separate function that opens an X3 screen with an
# iframe component and calls the Planner One url and places the content
# in the iframe.
# Mask management FUNPSSCH

$ACTION
    Case ACTION
        When "DEBUT" : Gosub DEBUT
        # Display Planner One for the site entered
        When "OK"           : Gosub OK1
    Endcase
Return

$DEBUT
    Local Char SITE(GLONFCY)

    [L]SITE = GFCYDEF(8)

    Gosub OK1
Return

# User has requested a change of site display the Production Scheduler page
$OK1
    Local Clbfile RESBODY(0)
    Local Integer OK

    # Make sure we don't exit the screen
    FIN = 0

    # Get site from screen if not blank
    If [M]FCY <> ""
        [L]SITE = [M]FCY
    Endif

    # Return if site is blank, otherwise there will be an error
    If [L]SITE = ""
        Return
    Endif

    # Get URL (including token) for Planner One
    [L]OK = func MFGPSSCH.GETPSURL([L]SITE, [L]RESBODY)
    # Returns HTTP status code (200 = OK)
    If [L]OK = 200
        [M]URL = [L]RESBODY
    Else
        Call MESSAGE(mess(381,193,1)) From GESECRAN
        Return
    Endif

    Call INITURL([M]PSCIFA,"PSSCH","","") From INTRUTILA
    Affzo [M]PSCIFA

Return

