#<AdxTL>@(#)0.0.0.0 $Revision$
#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - START
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "LIENS"       : Gosub LIENS
 Endcase
Return

$OUVRE
If clalev([F:CSISA])=0 : Local File COURSEISA  [CSISA] : Endif
Return

$MODIF
$CREATION
# SBA : error in fields
#Delete [CSISA] Where COD=[F:CSI]COD and REFNUM = [M:CSI1]REFNUM and CTRNUM = [M:CSI1]CTRNUM and CTRDAT = [M:CSI1]CTRDAT
Delete [CSISA] Where COD=[M:CSI0]COD
If fstat=1
 GOK = -1
 GLOCK = "$COURSEISA"-[M:CSI0]COD
 Return
Elsif fstat>5
 GOK = 0
 Call RSTA("CSISA",[M:CSI0]COD) From GLOCK
 Return
Endif
[F:CSISA]COD = [M:CSI0]COD
[F:CSISA]REFNUM = [M:CSI1]REFNUM
#[F:CSISA]CTRNUM = [M:CSI1]CTRNUM
[F:CSISA]CTRNUM = [M:CSI1]CTR
[F:CSISA]CTRDAT = [M:CSI1]CTRDAT
[F:CSISA]    = [M:CSI2]
Write [CSISA]
If fstat
  GOK=0 : Return
Endif
Return

$ANNULE
Delete [CSISA] Where COD=[M:CSI0]COD
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("CSISA",[M:CSI0]COD) From GLOCK : Return
Endif
Return


$LIENS
# SBA : error in fields
#Read [F:CSISA]CSISA2= [M:CSI0]CTCS;[M:CSI0]COD;[M:CSI1]REFNUM;[M:CSI1]CTRNUM;[M:CSI1]CTRDAT
Read [F:CSISA]CSISA0= [M:CSI0]COD
If !fstat
  [M:CSI2] = [F:CSISA]
Endif
Return

Subprog AM_TCS(VALEUR)
Variable Char    VALEUR()
If clalev([F:TCSSA])=0 : Local File TYPCOURSESA  [TCSSA] : Endif
Read [F:TCSSA]TCSSA0= VALEUR
If !fstat
  [M:CSI2] = [F:TCSSA]

Endif
Affzo [M:CSI2]
End

#FRLAA -2015-08-17 - Requirement 110204 - US 3850 - END

