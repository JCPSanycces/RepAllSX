#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char    PARAM(10)(1..2)
Local Integer VALEUR
Call TRAITE_LIB([L]VALEUR,[L]PARAM,"","EXTRAEM","DEXTRAEM",4,"") From GTRAITE
End

$ACTION
Case [L]ACTION
 When "INIT"     : Goto INIT
 When "INIT_DIA" : Goto INIT_DIA
 When "CONTROLE" : Goto CONTROLE
 When "EXEC"     : Goto EXEC
 When "TERMINE"  : Goto TERMINE
 When "SORTIE"   : Gosub SORTIE
#-------------------------------------------------------------------------------
 When "DEBUT"    : Gosub DEBUT
Endcase
Return

################################################################################
#
# GTRAITE
#
################################################################################
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
Affzo [EAEM]
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Call DELOCK("MEA") From GLOCK
Return

$INIT
Local Integer STAT
Local Char    CRITERE(250), SYMBOLE(50)

If !clalev([F:ADI])   : Local File ATABDIV   [ADI]    : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]     : Endif
If !clalev([F:VEP])   : Local File VALEMP    [VEP]    : Endif
If !clalev([F:VEP2])  : Local File VALEMP    [VEP2]   : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR]  : Endif
If !clalev([F:CTR2])  : Local File EMPLOCTR  [CTR2]   : Endif
If !clalev([F:MEA])   : Local File MEAEMP    [MEA]    : Endif
If !clalev([F:MEA2])  : Local File MEAEMP    [MEA2]   : Endif
If !clalev([F:HRPOA])   : Local File POPULA    [HRPOA]    : Endif
If !clalev([F:FEL])   : Local File FILEDIL   [FEL]    : Endif
If !clalev([F:FGR])   : Local File FACGROUP2 [FGR]    : Endif
Gosub OUVRE_FCY

Local Mask EXTRAEM : Gosub INIT_DIA : # à virer, voir MB
Return

#-------------------------------------------------------------------------------
$INIT_DIA
Raz [M:EAEM]
Call LECMEMO("STD","[M:EAEM]","hraem") From GMEMO
Return

#-------------------------------------------------------------------------------
$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif
Raz CRITERE
[L]TMP=1
[L]TIT=mess(3,10721,1) : # Extraction en cours
If [V]GSERVEUR | 1 : [L]TRA=1 : Endif

Gosub OUVRE From WPDEFTABLE

If [M:EAEM]DATDEB>[0/0/0] : [L]CRITERE-='& PYRDAT>=['+num$([M:EAEM]DATDEB)+']' : Endif
If [M:EAEM]DATFIN>[0/0/0] : [L]CRITERE-='& PYRDAT<=['+num$([M:EAEM]DATFIN)+']' : Endif
If [M:EAEM]MATDEB>""      : [L]CRITERE-='& EMP>="'   +[M:EAEM]MATDEB+'"'       : Endif
If [M:EAEM]MATFIN>""      : [L]CRITERE-='& EMP<="'   +[M:EAEM]MATFIN+'"'       : Endif
If [M:EAEM]CTRDEB>""      : [L]CRITERE-='& CTRNUM>="'+[M:EAEM]CTRDEB+'"'       : Endif
If [M:EAEM]CTRFIN>""      : [L]CRITERE-='& CTRNUM<="'+[M:EAEM]CTRFIN+'"'       : Endif
If [M:EAEM]BULDEB>""      : [L]CRITERE-='& BUL>="'   +[M:EAEM]BULDEB+'"'       : Endif
If [M:EAEM]BULFIN>""      : [L]CRITERE-='& BUL<="'   +[M:EAEM]BULFIN+'"'       : Endif
If [M:EAEM]ALLFCY<>2      : [L]CRITERE-='& FCY="'+[M:EAEM]FCY+'"'              : Endif
If [M:EAEM]ALLSRV<>2      : [L]CRITERE-='& SRV="'+[M:EAEM]SRV+'"'              : Endif
If [M:EAEM]ALLPRF<>2      : [L]CRITERE-='& PRF="'+[M:EAEM]PRF+'"'              : Endif
If [M:EAEM]FLGUPD<2       : [L]CRITERE-='& AEMNUM=""'                          : Endif
If [M:EAEM]CPY<>""        : [L]CRITERE-='& [FGR]CPY="'+[M:EAEM]CPY+'"'         : Endif

If [L]CRITERE="" : [L]CRITERE="1=1" : Else [L]CRITERE=right$([L]CRITERE,4) : Endif

If [M:EAEM]POP<>""
 Link [VEP] With [POA]POA0   =[M:EAEM]POP;[VEP]EMP;[VEP]CTRNUM;[VEP]CTRDAT
&             , [FGR]FGR1(1) =[VEP]FCY
&             , [ID]ID0      =[VEP]EMP
&             , [HRCTR]CTR0(2) =[VEP]EMP;[VEP]CTRNUM
&            As [VEPK]
&         Where evalue([L]CRITERE) & [ID]ENAFLG=2 & [ID]FLGINT=2 & PST>1 & RVSDAT=[0/0/0]
&             & [HRCTR]CTRDAT<=PYRDAT & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=PYRDAT)
&             & [HRCTR]DNAACTASS<3  &  [F:HRPOA]REFNUM<>""

Else
 Link [VEP] With [FGR]FGR1(1) =[VEP]FCY
&             , [ID]ID0      =[VEP]EMP
&             , [HRCTR]CTR0(2) =[VEP]EMP;[VEP]CTRNUM
&            As [VEPK]
&         Where evalue([L]CRITERE) & [ID]ENAFLG=2 & [ID]FLGINT=2 & PST>1 & RVSDAT=[0/0/0]
&             & [HRCTR]CTRDAT<=PYRDAT & ([HRCTR]XITDAT=[0/0/0] | [HRCTR]XITDAT>=PYRDAT)
&             & [HRCTR]DNAACTASS<3
Endif
Gosub LNK_FCY
Return

#-------------------------------------------------------------------------------
$EXEC
If [L]TRA
 If ![V]GSERVEUR
  Call OUVRE_TRACE([L]TIT) From LECFIC
 Else
  Call ECR_TRACE([L]TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

[L]OK=-1
Filter [VEPK] Order By Key CLE=CTRNUM;AEMNUM
For [VEPK]CLE(1)
 Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:EAEM]CRI,[L]STAT,0
&             ) From DIVPAYE

 If [L]STAT
  For [VEPK]CLE(2)
   If [F:VEP]AEMNUM=""
    If [L]OK=-1 : [L]OK=1 : Endif
   Else
    [L]SYMBOLE="MEA"+[F:VEP]AEMNUM
    Gosub LOCK_MEA
    If ![L]OK & ![L]TRA : Break 2 : Endif
   Endif
   For [VEPK]CLE
    If [F:VEP]ORIBUL>""
     Read [VEP2]VEP5=[F:VEP]ORIBUL
     If !fstat & [F:VEP2]AEMNUM>""
      [L]SYMBOLE="MEA"+[F:VEP2]AEMNUM
      Gosub LOCK_MEA
      If ![L]OK & ![L]TRA : Break 2 : Endif
     Endif
    Endif
   Next
  Next
 Endif
Next
Filter [VEPK]

If [L]OK=-1
 If [L]TRA
  Call ECR_TRACE(mess(4,10721,1) ,1) From GESECRAN : # Aucun salarié à déclarer
 Else
  [V]GMESSAGE=mess(4,10721,1) : # Aucun salarié à déclarer
 Endif
 [L]OK=0
Endif
If ![L]OK : If ![L]TRA : [V]GERR=1 : [L]SAI=1 : Endif : Return : Endif

Call EXTRACTION([L]TRA)
Return

#-------------------------------------------------------------------------------
$TERMINE
If ![V]GSERVEUR & [L]TRA
 Call FERME_TRACE From LECFIC
Endif
If ![L]OK & [L]TRA : [L]SAI=1 : Endif
Return

################################################################################
#
# Routines
#
################################################################################

$OUVRE_FCY
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:FCYA]) : Local File FACILITY   [FCYA] : Endif
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA]  : Endif
If !clalev([F:BPAA]) : Local File BPADDRESS  [BPAA] : Endif
If !clalev([F:CNT])  : Local File CONTACT    [CNT]  : Endif
If !clalev([F:CNTA]) : Local File CONTACT    [CNTA] : Endif
If !clalev([F:AIN])  : Local File CONTACTCRM [AIN]  : Endif
If !clalev([F:AINA]) : Local File CONTACTCRM [AINA] : Endif
Return

#-------------------------------------------------------------------------------
$LNK_FCY
#69272
#Link [FCY] With [HRSIT]SIT0   =FCY
#&             , [BPA]BPA0(2)=3;FCY
#&             , [CNT]CNT0(2)=3;FCY
#&             , [AIN]AIN0    =[CNT]CCNCRM
#&            As [FCYK]
#&         Where [HRSIT]AEMFCY>"" & [BPA]CRY="FR" & [CNT]CNTFLG=2
#&  Order By Key CLE=FCY;[BPA]BPAADDFLG Desc

Link [FCY] With [BPA]BPA0(2)= 3;FCY
&             , [CNT]CNT0   = 3;FCY;[FCY]CNTNAM
&             , [AIN]AIN0   = [CNT]CCNCRM
&            As [FCYK]
&         Where [FCY]AEMFCY>"" & [BPA]CRY=GPAYS
&  Order By Key CLE=FCY;[BPA]BPAADDFLG Desc

#69272
#Link [FCYA] With [SITA]SIT0   =FCY
#&              , [BPAA]BPA0(2)=3;FCY
#&              , [CNTA]CNT0(2)=3;FCY
#&              , [AINA]AIN0   =[CNTA]CCNCRM
#&             As [FYKA]
#&          Where [BPAA]CRY="FR" & [CNTA]CNTFLG=2
#&   Order By Key CLE=FCY;[BPAA]BPAADDFLG Desc

Link [FCYA] With [BPAA]BPA0(2)= 3;FCY
&              , [CNTA]CNT0   = 3;FCY;[F:FCY]CNTNAM
&              , [AINA]AIN0   = [CNTA]CCNCRM
&             As [FYKA]
&          Where [BPAA]CRY=GPAYS
&   Order By Key CLE=FCY;[BPAA]BPAADDFLG Desc
Return

#-------------------------------------------------------------------------------
$LOCK_MEA
Lock =[L]SYMBOLE
If fstat : [L]OK=0 : Elsif [L]OK=-1 : [L]OK=1 : Endif
If fstat
 Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
 If [L]TRA
  Call ECR_TRACE([F:ID]REFNUM+"\"+[V]GMESSAGE,1) From GESECRAN
  [V]GMESSAGE=""
 Endif
Endif
Return

#-------------------------------------------------------------------------------
Subprog EXTRACTION(TRA)
Value Integer TRA

Local Integer STAT, NBERR, I, J, MAJ
Local Char    MATRI([V]GLONEML), NUMAEM([V]GLONMEA), TYPAEM(1), AEMCTR([V]GLONMEA)
Local Char    FEH([V]GLONADI), CTR([V]GLONHRCTR)
Local Date    DATMAT

[L]FEH="AEM"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
[L]EXTRACTION=1

Call DEBTRANS From GLOCK

$TR_EXTRACT
[V]GOK=1
Trbegin [MEA]
 Gosub EXTRACT
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : End : Else Goto TR_EXTRACT : Endif
 Elsif ![V]GOK
  Rollback
  End
 Endif
Commit

End

#-------------------------------------------------------------------------------
$EXTRACT
Filter [VEPK] Order By Key CLE=FCY;CTRNUM;ENDDAT

Raz [L]MAJ, [F:MEA]
For [VEPK]CLE(1)
 Read [FCYK]CLE(1)=[F:VEP]FCY
 If !fstat : Read [FYKA]CLE(1)=[F:FCY]AEMFCY : Endif
 If !fstat
  For [VEPK]CLE(2)
   Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:EAEM]CRI,[L]STAT,0
&               ) From DIVPAYE

   If [L]STAT
    [L]AEMCTR=[F:HRCTR]AEMNUM

    For [VEPK]CLE
     [F:HRCTR]AEMNUM=[L]AEMCTR

     Gosub TYPAEM
     If [V]GOK<1 : Break 3 : Endif
     If [L]STAT

      If [M:EAEM]CRI=""
       [L]MATRI =[F:VEP]EMP
       [L]CTR   =[F:VEP]CTRNUM
       [L]DATMAT=[F:HRCTR]CTRDAT
       Gosub LECEMP From WPDEFTABLE
      Endif

      If [L]STAT=1 : # Création
       For [L]NIVEAU=0,1,2
        Gosub RAZVAR From =[L]FEHTRT
       Next
       Raz [F:MEA], [L]NUMAEM
      Else
       Gosub LECFIC From =[L]FEHTRT
       [L]NUMAEM=[F:MEA]AEMNUM
       If ![L]MAJ
        For [L]NIVEAU=0,2
         Gosub RAZVAR From =[L]FEHTRT
        Next
       Endif
      Endif

      If [L]TRA
       Call ECR_TRACE("",0) From GESECRAN
       Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
       Call ECR_TRACE( format$([V]GFMD,[F:VEP]PYRDAT)-[F:HRCTR]REFNUM-[F:ID]NAM-[F:ID]SRN
&                    - [F:VEP]BUL, 0
&                    ) From GESECRAN
      Endif

      If [L]STAT=4 : # Soustraction des cumuls
       [L]NIVEAU=1
       Gosub OPPOSE From =[L]FEHTRT
      Endif
      Onerrgo ERREURWW
      If [L]STAT=2 : # Modif sauf cumul
       [L]NIVEAU=0
       Gosub EXTRACTION From =[L]FEHTRT
      Elsif [L]MAJ
       [L]NIVEAU=1
       Gosub EXTRACTION From =[L]FEHTRT
      Else
       For [L]NIVEAU=0,1
        Gosub EXTRACTION From =[L]FEHTRT
       Next
      Endif
      Onerrgo
      If [L]STAT=4 : # Soustraction des cumuls
       [L]NIVEAU=1
       Gosub OPPOSE From =[L]FEHTRT
      Endif

      Gosub MAJFIC From =[L]FEHTRT
      If [F:MEA]FCY   ="" : [F:MEA]FCY   =[F:HRCTR]ETRFCY    : Endif
      If [F:MEA]REFNUM="" : [F:MEA]REFNUM=[F:HRCTR]REFNUM : Endif
      If [F:MEA]CTRNUM="" : [F:MEA]CTRNUM=[F:HRCTR]CTRNUM : Endif

      If ![L]MAJ : [L]MAJ=min(2,[L]STAT) : Endif

      If [F:VEP]AEMNUM<>[F:MEA]AEMNUM
       Readlock [VEP] Curr
       If fstat=1
        [V]GOK  =-1
        [V]GLOCK="$VALEMP"-[F:VEP]BUL
        Break 3
       Elsif fstat
        [V]GOK=0
        Call FSTA("VEP") From GLOCK
        Break 3
       Endif
       Update [VEP2] Where BUL=[F:VEP]BUL With AEMNUM=[F:MEA]AEMNUM
       If fstat
        [V]GOK=0
        Call RSTA("VEP2",[F:VEP]BUL) From GLOCK
        Break 3
       Endif
      Endif

      If [F:HRCTR]AEMNUM=""
       Readlock [CTR2]CTR0=[F:HRCTR]CTRNUM
       If fstat=1
        [V]GOK  =-1
        [V]GLOCK="$EMPLOCTR"-[F:HRCTR]CTRNUM
        Break 3
       Endif

       Update [CTR2] Where CTRNUM=[F:HRCTR]CTRNUM With AEMNUM=[F:MEA]AEMNUM
       If fstat
        [V]GOK=0
        Call RSTA("CTR2",[F:HRCTR]CTRNUM) From GLOCK
        Break 3
       Endif
       [L]AEMCTR=[F:MEA]AEMNUM
      Endif

      If [L]TRA
       Call ECR_TRACE(mess(59+([L]STAT>1),123,1)-":"-[F:MEA]AEMNUM,0) From GESECRAN
       #              Création/Modification
      Endif
     Endif
    Next
   Endif
  Next
 Endif
Next
Filter [VEPK]
If [V]GOK<1 : Return : Endif

If [L]MAJ
 Gosub MAJ_AEM
 If [V]GOK<1 : Return : Endif
Endif
Return

#-------------------------------------------------------------------------------
$TYPAEM
If [F:VEP]AEMNUM>"" : # AEM déjà existante
 If [F:MEA]AEMNUM<>[F:VEP]AEMNUM
  If [L]MAJ
   Gosub MAJ_AEM
   If [V]GOK<1 : Return : Endif
  Endif

  Read [MEA]MEA0=[F:VEP]AEMNUM
  If fstat
   [V]GOK=0
   Call RSTA("MEA",[F:VEP]AEMNUM) From GLOCK
   Return
  Endif
 Endif

 If    [F:MEA]ASSCOP>2 : [L]STAT=0 : Return : # AEM émise -> non modifiable
 Elsif [L]MAJ          : [L]STAT=0 : Return : # La MàJ est déjà faite
 Endif

 Readlock [MEA] Curr
 If fstat=1
  [V]GOK  =-1
  [V]GLOCK="$MEAEMP"-[F:VEP]AEMNUM
  Return
 Endif

 [L]TYPAEM=[F:MEA]TYP
 [L]STAT  =2 : # Modif AEM sauf les cumuls
 Return
Endif

If [F:VEP]ORIBUL>"" : # Bulletin d'extourne

 Read [VEP2]VEP5=[F:VEP]ORIBUL
 If fstat
  [V]GOK=0
  Call RSTA("VEP2",[F:VEP]ORIBUL) From GLOCK
  Return
 Endif

 If [F:VEP2]AEMNUM="" : [L]STAT=0 : Return : Endif : # Bulletin extourné sans AEM -> RàF

 If [F:MEA]AEMNUM=[F:VEP2]AEMNUM
  [F:MEA2]=[F:MEA]
 Else
  Read [MEA2]MEA0=[F:VEP2]AEMNUM
  If fstat
   [V]GOK=0
   Call RSTA("MEA2",[F:VEP2]AEMNUM) From GLOCK
   Return
  Endif
 Endif

 If [F:MEA2]ASSCOP>2 : # AEM non modifiable, on doit compenser sur une autre AEM
  If [L]MAJ & [F:MEA]CTRNUM=[F:VEP]CTRNUM & [F:MEA]YEA=year([F:VEP]ENDDAT)
&  & [F:MEA]MTH=format$("D:MM",[F:VEP]ENDDAT)
   [L]TYPAEM=[F:MEA]TYP
   [L]STAT  =3+([F:MEA]TYP<>"N") : # Addition/soustraction des cumuls
   Return
  Endif

  If [L]MAJ
   Gosub MAJ_AEM
   If [V]GOK<1 : Return : Endif
  Endif

  Filter [MEA] Where CTRNUM=[F:VEP]CTRNUM & YEA=year([F:VEP]ENDDAT)
&                  & MTH=format$("D:MM",[F:VEP]ENDDAT) & ASSCOP<3
  Readlock [MEA] First
  Filter [MEA]
  If fstat=1
   [V]GOK  =0
   [V]GLOCK="$MEAEMP"-[F:MEA]AEMNUM
   Return
  Endif

  If fstat
   [L]TYPAEM="N" : # AEM rectificative négative
  Else
   [L]TYPAEM=[F:MEA]TYP
   [L]STAT  =3+([F:MEA]TYP<>"N") : # Addition/soustraction des cumuls
  Endif
  Return
 Endif

 If [L]MAJ & [F:MEA]AEMNUM<>[F:MEA2]AEMNUM
  Gosub MAJ_AEM
  If [V]GOK<1 : Return : Endif
 Endif

 If ![L]MAJ
  Readlock [MEA]MEA0=[F:MEA2]AEMNUM
  If fstat=1
   [V]GOK  =-1
   [V]GLOCK="$MEAEMP"-[F:VEP2]AEMNUM
   Return
  Endif
 Endif

 Readlock [VEP2] Curr
 If fstat=1
  [V]GOK  =-1
  [V]GLOCK="VALEMP"-[F:VEP]ORIBUL
  Return
 Endif

 Update [VEP2] Where BUL=[F:VEP]ORIBUL With AEMNUM=""
 If fstat
  [V]GOK=0
  Call FSTA("VEP2") From GLOCK
  Return
 Endif

 [L]TYPAEM=[F:MEA]TYP
 [L]STAT  =4-([F:MEA]TYP="N") : # Soustraction/addition des cumuls
 Return
Endif

If [F:HRCTR]AEMNUM=""
 If [L]MAJ
  Gosub MAJ_AEM
  If [V]GOK<1 : Return : Endif
 Endif
 [L]TYPAEM="I" : # AEM initiale
 Return
Endif

If [L]MAJ & [F:MEA]CTRNUM=[F:VEP]CTRNUM & [F:MEA]YEA=year([F:VEP]ENDDAT)
&& [F:MEA]MTH=format$("D:MM",[F:VEP]ENDDAT)
 [L]TYPAEM=[F:MEA]TYP
 [L]STAT  =3+([F:MEA]TYP="N") : # Addition/soustraction des cumuls
 Return
Endif

If [L]MAJ
 Gosub MAJ_AEM
 If [V]GOK<1 : Return : Endif
Endif

Filter [MEA] Where CTRNUM=[F:VEP]CTRNUM & YEA=year([F:VEP]ENDDAT)
&                & MTH=format$("D:MM",[F:VEP]ENDDAT)
&     Order By Key CLE=ASSCOP
Read [MEA] First
Filter [MEA]
If    fstat           : [L]TYPAEM="C" : Return : # AEM complémentaire
Elsif [F:MEA]ASSCOP>2 : [L]TYPAEM="P" : Return : # AEM rectificative positive
Endif

Readlock [MEA] Curr
If fstat=1
 [V]GOK  =-1
 [V]GLOCK="$MEAEMP"-[F:MEA]AEMNUM
 Return
Endif

[L]TYPAEM=[F:MEA]TYP
[L]STAT  =3+([F:MEA]TYP="N") : # Addition/soustraction des cumuls
Return

#-------------------------------------------------------------------------------
$MAJ_AEM
Onerrgo ERREURWW
[L]NIVEAU=2
Gosub EXTRACTION From =[L]FEHTRT
[L]NBERR=0
Gosub CONTROLE From =[L]FEHTRT
Onerrgo

Gosub MAJFIC From =[L]FEHTRT
If [F:MEA]AEMNUM="" : [L]MAJ=0 : Return : Endif

[F:MEA]EMPCOP=1+![L]NBERR
#[F:MEA]FCYCOP=[F:MEA]EMPCOP
[F:MEA]ASSCOP=[F:MEA]EMPCOP

If [L]MAJ=1 : Write [MEA] : Else Rewrite [MEA] Curr : Endif
If fstat
 [V]GOK=0
 Call FSTA("MEA") From GLOCK
 Return
Endif

[L]MAJ=0
Return

#-------------------------------------------------------------------------------
$ERREURWW
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
End
######################################################################################
## Section automatically added (screen EXTRAEM) 24/05/2012 10:10:13 (ADW)
######################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  GCURLEG = ''
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If dim([F:CPY]LEG)>0
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  GCURLEG = [F:CPY]LEG
Endif

End


######################################################################################

