#<AdxTL>@(#)6.0.0.0 $Revision$
$ACTION
Case ACTION
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Call CHANGE_AXX ("ITMCUSNOM", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase
Return

#############################################################################
$CREATION
$MODIF
Call MAJTEXTRA([M]DESAXX,"ITMCUSNOM","DESAXX",[M]ITMNOM,"") From ATEXTRA
Return

$ANNULE
Delete [AXX] Where CODFIC="ITMCUSNOM" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return  # FGR 17/12/2009 : X3SUIVI60986
Endif
Return

#############################################################################
Subprog D_ITMCUSSHO(VALEUR)
Variable Char     VALEUR
VALEUR = [M]ITMCUSDES
End
Subprog D_CREDAT(VALEUR)
Variable Date     VALEUR
VALEUR = date$
End
Subprog D_CREUSR(VALEUR)
Variable Char     VALEUR
VALEUR = GUSER
End
Subprog D_EXPNUM(VALEUR)
Variable Decimal  VALEUR
VALEUR  = [C]EXPORT
End
######################################################################################
