#<AdxTL>@(#)3.0.0.0 $Revision$ [MFI]STRDAT/ENDDAT correction
##########################################################################
# UTIGPA36: Reinit des dates debut/fin des lignes       Module GPAO      #
#           articles lancés non sous-produit à celles                    #
#           de l'OF                                                      #
##########################################################################
# GH 30/10/11                                           Bug 85452        # 
##########################################################################

Call MAJ_UTIGPA36
End

##################################
Subprog MAJ_UTIGPA36
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA36: [MFI]STRDAT/ENDDAT correction") From LECFIC
Call EXE_UTIGPA36(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA36(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA36 : Process Start on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","MFGITM","fde",DOSSIER),0)  <= 0  : End : Endif
If filinfo(filpath("FIL","MFGHEAD","fde",DOSSIER),0) <= 0  : End : Endif
If filinfo(filpath("FIL","ORDERS","fde",DOSSIER),0)  <= 0  : End : Endif

Local File =[L]DOSSIER+".MFGITM"  [MFI]
Local File =[L]DOSSIER+".MFGHEAD" [MFG]
Local File =[L]DOSSIER+".ORDERS"  [ORD]
Local Integer MAJ

Link [MFI] With [MFG]MFG0~=[F:MFI]MFGNUM As [MFX]
For [MFX] Where [MFI]ITMTYP<>2 & ([MFG]STRDAT<>[MFI]STRDAT | [MFG]ENDDAT<>[MFI]ENDDAT) : # pas les sous-produits
   GMESSAGE = mess(699,197,1)-[F:MFI]MFGNUM-num$([F:MFI]MFGLIN)+","-mess(133,187,1)-[F:MFI]ITMREF+","

   GOK=1
   Trbegin [MFI], [ORD]
      Readlock [MFI]MFI0 Curr
      If fstat
         GOK=0
         # Table ... Erreur de lecture
         Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"MFGITM"-":"-mess(49,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
      Else      
        [F:MFI]STRDAT = [F:MFG]STRDAT
        [F:MFI]ENDDAT = [F:MFG]ENDDAT
         Rewrite [MFI]
         If fstat            GOK=0
            # Table ... Erreur de réécriture
            Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"MFGITM"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
         Endif
       Endif

      If GOK
         Update [ORD] Where WIPTYP = 5 & WIPNUM = [F:MFI]WIPNUM & ITMREF = [F:MFI]ITMREF
&                     With  STRDAT = [F:MFI]STRDAT,
&                           ENDDAT = [F:MFI]ENDDAT
         If fstat 
            GOK=0
            # Table ... Erreur en réécriture
            Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"ORDERS"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
         Endif
      Endif
   If GOK<1 : Rollback
   Else     : Commit : MAJ+=1
   Endif
Next

GMESSAGE=""
If MAJ>0
   GMESSAGE=":"-num$(MAJ)-"Records updated"
Endif
Call ECR_TRACE("UTIGPA36 : Process End on : "+DOSSIER-GMESSAGE,0) From GESECRAN
GMESSAGE=""
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA36(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIGPA36(APPLI)
End
