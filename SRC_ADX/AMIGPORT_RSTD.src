#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AMIGPORT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AREAD"                        : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return






$AQUERY_OPEN_AFTER
  If PQRY.QWHERE<>"" : PQRY.QWHERE -= 'and' : Endif
  PQRY.QWHERE -= 'TYP ge "" and CLE ge ""'

Local Libelle QUERY_TYP      : QUERY_TYP=1
Local Char    QUERY_CLE(40) : QUERY_CLE=""

Gosub CHARGE_QUERY From AMIGPORT_CSTD

Local File    (
&   Char    TYP(20),
&   Char    CLE (40),
&   Char    INTIT(100))
&             From Variable
&   TYP_TBL,CLE_TBL,INTIT_TBL As [LNK_]

Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return

$AQUERY_TRANS_AFTER
this.AMIGPORT.TYP       = [LNK_]TYP
this.AMIGPORT.CLE       = [LNK_]CLE
this.INTIT              = [LNK_]INTIT
Return

$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1 : TBPRO(NBPRO) = "TYP"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AMIGPORT.TYP"
             TBFIL(NBPRO) = "[LNK_]TYP"
NBPRO += 1 : TBPRO(NBPRO) = "CLE"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AMIGPORT.CLE"
             TBFIL(NBPRO) = "[LNK_]CLE"
NBPRO += 1 : TBPRO(NBPRO) = "INTIT"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "AMIGPORT.INTIT"
             TBFIL(NBPRO) = "[LNK_]INTIT"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]TYP;[LNK_]CLE"
Return

$AREAD
Local Integer ERCODE
If this.TYP=mess(1,63,1)
  ERCODE=fmet this.ASETATTRIBUTE("ATRADE","$isHidden","false")
Else
  ERCODE=fmet this.ASETATTRIBUTE("AUSER","$isHidden","false")
Endif
Return

