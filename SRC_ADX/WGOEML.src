$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "REFNUM;CTRNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_2
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 3
SNSLIS = 1
LENLIS = 3
GAUTRELIS = 2
CLELISTE = "FCY;SRV;REFNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_3
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "REFNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_4
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "REFNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 1 : Default file [ECT_]
 When 2 : Default file [EC2]
 When 3 : Default file [ID_]
 When 4 : Default file [ID_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_] Order With CLELISTE
  Setlbox [EMP1] GAU_CHE1
  Filter [ECT_]
 When "GAU_CHE2"
  Setlbox [EMP1] GAU_CHE2
 When "GAU_CHE3"
  Gosub SETCLE_3
  Filter [ID_] Order With CLELISTE
  Setlbox [EMP1] GAU_CHE3
  Filter [ID_]
 When "GAU_CHE4"
  Gosub SETCLE_4
  Filter [ID_] Order With CLELISTE
  Setlbox [EMP1] GAU_CHE4
  Filter [ID_]
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_] Order With CLELISTE
 When "GAU_CHE3"
  Gosub SETCLE_3
  Filter [ID_] Order With CLELISTE
 When "GAU_CHE4"
  Gosub SETCLE_4
  Filter [ID_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_]
 When "GAU_CHE3"
  Gosub SETCLE_3
  Filter [ID_]
 When "GAU_CHE4"
  Gosub SETCLE_4
  Filter [ID_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "HRMAT0"       : ABMSK(0)  = "EMP0"     : AMA(0) = 1
NOMMSK(1) = "HRMAT2"       : ABMSK(1)  = "EMP2"     : AMA(1) = 1
NOMMSK(2) = "HRMAT1"       : ABMSK(2)  = "EMP1"     : AMA(2) = 1
NOMMSK(3) = "HRMAT6"       : ABMSK(3)  = "EMP6"     : AMA(3) = 1
NOMMSK(4) = "HRMAT3"       : ABMSK(4)  = "EMP3"     : AMA(4) = 1
NOMMSK(5) = "HRMAT7"       : ABMSK(5)  = "EMP7"     : AMA(5) = 1
NOMMSK(6) = "HRMAT12"      : ABMSK(6)  = "EMPC"     : AMA(6) = 1
NOMMSK(7) = "HRMAT10"      : ABMSK(7)  = "EMPA"     : AMA(7) = 1
NOMMSK(8) = "HRMAT14"      : ABMSK(8)  = "EMPE"     : AMA(8) = 1
NOMMSK(9) = "HRMAT4"       : ABMSK(9)  = "EMP4"     : AMA(9) = 1
NOMMSK(10) = "HRMAT11"      : ABMSK(10)  = "EMPB"     : AMA(10) = 1
NOMMSK(11) = "HRMAT5"       : ABMSK(11)  = "EMP5"     : AMA(11) = 1
NBMASK = 11
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:EMP0])>0 : Default Mask [EMP0] : Endif
 When 1 : If clalev([M:EMP2])>0 : Default Mask [EMP2] : Endif
 When 2 : If clalev([M:EMP1])>0 : Default Mask [EMP1] : Endif
 When 3 : If clalev([M:EMP6])>0 : Default Mask [EMP6] : Endif
 When 4 : If clalev([M:EMP3])>0 : Default Mask [EMP3] : Endif
 When 5 : If clalev([M:EMP7])>0 : Default Mask [EMP7] : Endif
 When 6 : If clalev([M:EMPC])>0 : Default Mask [EMPC] : Endif
 When 7 : If clalev([M:EMPA])>0 : Default Mask [EMPA] : Endif
 When 8 : If clalev([M:EMPE])>0 : Default Mask [EMPE] : Endif
 When 9 : If clalev([M:EMP4])>0 : Default Mask [EMP4] : Endif
 When 10 : If clalev([M:EMPB])>0 : Default Mask [EMPB] : Endif
 When 11 : If clalev([M:EMP5])>0 : Default Mask [EMP5] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:EMP0])>0 : Gosub TITRES From W1HRMAT0 : Endif
 When 1 : If clalev([M:EMP2])>0 : Gosub TITRES From W1HRMAT2 : Endif
 When 2 : If clalev([M:EMP1])>0 : Gosub TITRES From W1HRMAT1 : Endif
 When 3 : If clalev([M:EMP6])>0 : Gosub TITRES From W1HRMAT6 : Endif
 When 4 : If clalev([M:EMP3])>0 : Gosub TITRES From W1HRMAT3 : Endif
 When 5 : If clalev([M:EMP7])>0 : Gosub TITRES From W1HRMAT7 : Endif
 When 6 : If clalev([M:EMPC])>0 : Gosub TITRES From W1HRMAT12 : Endif
 When 7 : If clalev([M:EMPA])>0 : Gosub TITRES From W1HRMAT10 : Endif
 When 8 : If clalev([M:EMPE])>0 : Gosub TITRES From W1HRMAT14 : Endif
 When 9 : If clalev([M:EMP4])>0 : Gosub TITRES From W1HRMAT4 : Endif
 When 10 : If clalev([M:EMPB])>0 : Gosub TITRES From W1HRMAT11 : Endif
 When 11 : If clalev([M:EMP5])>0 : Gosub TITRES From W1HRMAT5 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:EMP0])>0 : Close Local Mask [EMP0] : Endif
If clalev([M:EMP2])>0 : Close Local Mask [EMP2] : Endif
If clalev([M:EMP1])>0 : Close Local Mask [EMP1] : Endif
If clalev([M:EMP6])>0 : Close Local Mask [EMP6] : Endif
If clalev([M:EMP3])>0 : Close Local Mask [EMP3] : Endif
If clalev([M:EMP7])>0 : Close Local Mask [EMP7] : Endif
If clalev([M:EMPC])>0 : Close Local Mask [EMPC] : Endif
If clalev([M:EMPA])>0 : Close Local Mask [EMPA] : Endif
If clalev([M:EMPE])>0 : Close Local Mask [EMPE] : Endif
If clalev([M:EMP4])>0 : Close Local Mask [EMP4] : Endif
If clalev([M:EMPB])>0 : Close Local Mask [EMPB] : Endif
If clalev([M:EMP5])>0 : Close Local Mask [EMP5] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:EMP0])>0 : Raz [M:EMP0] : Endif
 When 1 : If clalev([M:EMP2])>0 : Raz [M:EMP2] : Endif
 When 2 : If clalev([M:EMP1])>0 : Raz [M:EMP1] : Endif
 When 3 : If clalev([M:EMP6])>0 : Raz [M:EMP6] : Endif
