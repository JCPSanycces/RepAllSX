$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(37399,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "3" : LBOUT(NBTEX) = 1102 : Call TEXTE(55251,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(1043,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "2" : LMEN(NBMEN) = 2001 : Call TEXTE(26248,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "4" : LMEN(NBMEN) = 2002 : Call TEXTE(45640,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "5" : LMEN(NBMEN) = 2003 : Call TEXTE(45611,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "6" : LMEN(NBMEN) = 2004 : Call TEXTE(485,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:EMP0]REFNUM
  PARBOUT(2) = ""
  PARBOUT(3) = num$("5")
  FLGEXE = 1
  GACTION = "MATPCA"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","MATPCA","MATPCA",4,"XYMATPCA") From GTRAITE
 When "3"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:EMP0]REFNUM
  FLGEXE = 1
  GACTION = "MATDIRNUM"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","MATDIRNUM","MATDIRNUM",4,"MATDIRNUMSPE") From GTRAITE
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  PARBOUT(2) = func AFNC.PARAM("DATPAY","")
  PARBOUT(3) = [F:HRCTR]CTRNUM
  PARBOUT(4) = [00/00/0000]
  FLGEXE = 1
  GACTION = "EXCEPTSAL"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"FVEPEXC","VEPEXC","XYSUBVEPX") From GSAISIE
 When "4"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  FLGEXE = 1
  GACTION = "EXTRDUE"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","EXTRDUE","DEXTRDUE",4,"XYEXTRDUE") From GTRAITE
 When "5"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "VEP"
  PARBOUT(2) = [M:EMP0]REFNUM
  FLGEXE = 1
  GACTION = "GOBJET"
  Call OBJET_CHAR(VALBOUT,PARBOUT(1),PARBOUT(2)) From GOBJET
 When "6"
  FLGEXE = 1
  GACTION = "STD"
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


