#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OEML

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:36"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OEML",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="EMP0;EMP2;EMP1;EMP6;EMP3;EMP7;EMPC;EMPA;EMPE;EMP4;EMPB;EMP5;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = "EMP0"
BOX1 = "GAU_CHE1"
OBJLIS(1) = "ECR"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 1
DESLIS(1) = "REFNUM+CTRNUM"
OBJLIS(2) = "EC2"
CHGLIS(2) = 3
BROLIS(2) = 2
TRELIS(2) = 2
DESLIS(2) = "FCY+SRV+REFNUM"
OBJLIS(3) = "EM3"
CHGLIS(3) = 2
BROLIS(3) = 2
TRELIS(3) = 1
DESLIS(3) = "REFNUM"
OBJLIS(4) = "EM4"
CHGLIS(4) = 2
BROLIS(4) = 2
TRELIS(4) = 1
DESLIS(4) = "REFNUM"
If clalev([M:EMP0])=0 : Local Mask HRMAT0 [EMP0] : Endif
If clalev([M:EMP2])=0 : Local Mask HRMAT2 [EMP2] : Endif
If clalev([M:EMP1])=0 : Local Mask HRMAT1 [EMP1] : Endif
If clalev([M:EMP6])=0 : Local Mask HRMAT6 [EMP6] : Endif
If clalev([M:EMP3])=0 : Local Mask HRMAT3 [EMP3] : Endif
If clalev([M:EMP7])=0 : Local Mask HRMAT7 [EMP7] : Endif
If clalev([M:EMPC])=0 : Local Mask HRMAT12 [EMPC] : Endif
If clalev([M:EMPA])=0 : Local Mask HRMAT10 [EMPA] : Endif
If clalev([M:EMPE])=0 : Local Mask HRMAT14 [EMPE] : Endif
If clalev([M:EMP4])=0 : Local Mask HRMAT4 [EMP4] : Endif
If clalev([M:EMPB])=0 : Local Mask HRMAT11 [EMPB] : Endif
If clalev([M:EMP5])=0 : Local Mask HRMAT5 [EMP5] : Endif
Gosub TIT
nolign = 1
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
Link [ECT] With
& [ID]ID0=[F:ECT]REFNUM,
& [FCY]FCY0=[F:ECT]FCY,
& [ACC]CODACC=GUSER;[F:ID]CODACS
& As [ECT_]
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [ECT] With
& [ID]ID0=[F:ECT]REFNUM,
& [FCY]FCY0=[F:ECT]FCY,
& [SRV]SRV0=[F:ECT]SRV,
& [CPY]CPY0=[F:FCY]LEGCPY,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [AXX]AXX0="SERVICE";"DES";GLANGUE;[F:SRV]COD;""
& As [EC2]
& Order By Key ECT2
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:CP3])=0 : Local file COMPANY [CP3] : Endif
Link [ID] With
& [FCY]FCY0=[F:ID]FCYORI,
& [SRV]SRV0=[F:ID]SRV,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [CP3]CPY0=[F:FCY]LEGCPY
& As [ID_]
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:CP3])=0 : Local file COMPANY [CP3] : Endif
Link [ID] With
& [FCY]FCY0=[F:ID]FCYORI,
& [SRV]SRV0=[F:ID]SRV,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [CP3]CPY0=[F:FCY]LEGCPY
& As [ID_]
Return

$DEF_BOITE
Gosub HORODAT From WGOEML
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OEML" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP0]
&   Folder Mask [EMP2]
& , Folder Mask [EMP1]
& , Folder Mask [EMP6]
& , Folder Mask [EMP3]
& , Folder Mask [EMP7]
& , Folder Mask [EMPC]
& , Folder Mask [EMPA]
& , Folder Mask [EMPE]
& , Folder Mask [EMP4]
& , Folder Mask [EMPB]
& , Folder Mask [EMP5]
&  Listbox [ECT_] GAU_CHE1
&   [L]SAIRAP(1) = [F:ECT]REFNUM Using "K:15c" Titled TITSEL1(1) ,
&   [L]SAIRAP(2) = [F:ID]NAM Using "K:40X" Titled TITSEL1(2) ,
&   [L]SAIRAP(3) = [F:ID]SRN Using "K:40X" Titled TITSEL1(3) ,
&   [L]SAIRAP(4) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL1(4) ,
&   [L]SAIRAP(5) = [F:ID]FCYORI Using "K:5c" Titled TITSEL1(5) ,
&   [L]SAIRAP(6) = [F:ECT]SRV Using "K:5X" Titled TITSEL1(6) ,
&   [L]SAIRAP(7) = [F:ECT]PRF Using "K:3X" Titled TITSEL1(7)
&  Treebox [EC2] GAU_CHE2
&   [F:CPY]CPY-[F:CPY]CPYNAM-'/'-[F:ECT]FCY-[F:FCY]FCYNAM Using "K:80X" Titled TITSEL2(1) ,
&   [F:ECT]SRV-[F:AXX]TEXTE Using "K:20X" Titled TITSEL2(2) ,
&   [F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN
&   +" "+string$([F:CPY]LEG<>'',[F:CPY]LEG)+string$([F:CPY]LEG='',mess(91,187,1))
&   Titled ""
&  Listbox [ID_] GAU_CHE3
&   [L]SAIRAP(1) = [F:ID]REFNUM Using "K:15c" Titled TITSEL3(1) ,
&   [L]SAIRAP(2) = [F:ID]NAM Using "K:40X" Titled TITSEL3(2) ,
&   [L]SAIRAP(3) = [F:ID]SRN Using "K:40X" Titled TITSEL3(3) ,
&   [L]SAIRAP(4) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL3(4) ,
&   [L]SAIRAP(5) = [F:ID]FCYORI Using "K:5c" Titled TITSEL3(5)
&  Listbox [ID_] GAU_CHE4
&   [L]SAIRAP(1) = [F:ID]REFNUM Using "K:15c" Titled TITSEL4(1) ,
&   [L]SAIRAP(2) = [F:ID]NAM Using "K:40X" Titled TITSEL4(2) ,
&   [L]SAIRAP(3) = [F:ID]SRN Using "K:40X" Titled TITSEL4(3) ,
&   [L]SAIRAP(4) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL4(4) ,
&   [L]SAIRAP(5) = [F:ID]FCYORI Using "K:5c" Titled TITSEL4(5)
& As [EMP1]
Titled [EMP1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOEML
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OEML" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP0]
&   Folder Mask [EMP2]
& , Folder Mask [EMP1]
& , Folder Mask [EMP6]
& , Folder Mask [EMP3]
& , Folder Mask [EMP7]
& , Folder Mask [EMPC]
& , Folder Mask [EMPA]
& , Folder Mask [EMPE]
& , Folder Mask [EMP4]
& , Folder Mask [EMPB]
& , Folder Mask [EMP5]
& As [EMP1]
Titled [EMP1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [EMP1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [EMP1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [EMP1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS1(30)
Call TEXTE(44843,TITLIS1) From OBJDIV
Local Char TITLIS2(30)
Call TEXTE(47967,TITLIS2) From OBJDIV
Local Char TITLIS3(30)
Call TEXTE(47968,TITLIS3) From OBJDIV
Local Char TITLIS4(30)
Call TEXTE(25724,TITLIS4) From OBJDIV
Local Char TITSEL1(30)(1..7)
Call TEXTE(10793,TITSEL1(1)) From OBJDIV
Call TEXTE(55,TITSEL1(2)) From OBJDIV
Call TEXTE(1825,TITSEL1(3)) From OBJDIV
Call TEXTE(1343,TITSEL1(4)) From OBJDIV
Call TEXTE(9711,TITSEL1(5)) From OBJDIV
Call TEXTE(18735,TITSEL1(6)) From OBJDIV
Call TEXTE(8750,TITSEL1(7)) From OBJDIV
Local Char TITSEL2(30)(1..4)
Call TEXTE(8730,TITSEL2(1)) From OBJDIV
Call TEXTE(18735,TITSEL2(2)) From OBJDIV
Call TEXTE(10793,TITSEL2(3)) From OBJDIV
Call TEXTE(26213,TITSEL2(4)) From OBJDIV
Local Char TITSEL3(30)(1..5)
Call TEXTE(10793,TITSEL3(1)) From OBJDIV
Call TEXTE(55,TITSEL3(2)) From OBJDIV
Call TEXTE(1825,TITSEL3(3)) From OBJDIV
Call TEXTE(1343,TITSEL3(4)) From OBJDIV
Call TEXTE(46641,TITSEL3(5)) From OBJDIV
Local Char TITSEL4(30)(1..5)
Call TEXTE(10793,TITSEL4(1)) From OBJDIV
Call TEXTE(55,TITSEL4(2)) From OBJDIV
Call TEXTE(1825,TITSEL4(3)) From OBJDIV
Call TEXTE(1343,TITSEL4(4)) From OBJDIV
Call TEXTE(46641,TITSEL4(5)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(44843,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$REMPLIT_1
Gosub SETCLE_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [ECT_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [EMP1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [EMP1] GAU_CHE1
 Else
  Fillbox [EMP1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [ECT_]
Return

$REMPLIT_2
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [EC2] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order By Key ECT2
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(2)<>'' or NOHLIS(2)<>0
 Fillbox [EMP1] GAU_CHE2 Hint Key =HINTLIS(2)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [EMP1] GAU_CHE2
 Else
  Fillbox [EMP1] GAU_CHE2 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [EC2]
Return

$REMPLIT_3
Gosub SETCLE_3
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [ID_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(3)<>'' or NOHLIS(3)<>0
 Fillbox [EMP1] GAU_CHE3 Hint Key =HINTLIS(3)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [EMP1] GAU_CHE3
 Else
  Fillbox [EMP1] GAU_CHE3 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [ID_]
