#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : FENETRE DE GESTION DES EXTOURNES - Dotations aux amortissements
# =================================================================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - CBO - 11.02.2014 - FQ 96356 - Erreur en suppression si passage par le plan de provisions
# - GLE - 22.01.2014 - Fq 90143 - La date de comptabilisation par défaut est toujours las fin de période courante
#                               + correction la date fin de période courante n'est pas fonction du contexte
# - GBO - 10.02.2011 - Fq 71507 - Mauvaise alimentation de TYPANN si dépense issue d'X3.
# - GBO - 07.10.2010 - Fq 65071 - Génération d'un événement d'annulation même s'il n'y pas de dotation +
#                                 Alimentation des nouveaux champs TYPANN et ACCCODORI
# - GBO - 07.05.2010 - Fq 64544 - Gestion des écarts entre plans d'amortissement
########################################################################################################################

#----------------------------------------
# CHARGEMENT DE L'ONGLET DOTATIONS
#----------------------------------------
$LOAD_PSTAMT

 Affzo [M:FPC]DIEDES    #Fq65071-Force le chargement des intitulés tranduisibles long et court des axes analytiques
 Affzo [M:FPC]DIEDESSHO #

 Local Integer NODEPCNLEVT :
 Local Integer NOAMT

 Global Date    PLNPERSTRDAT(G301MAX-1)
 Global Date    PLNPERENDDAT(G301MAX-1)
 Global Date    PLNFIYSTRDAT(G301MAX-1)
 Global Date    PLNFIYENDDAT(G301MAX-1)

 # Chargement de la globale contenant la liste des plans gérés dans la société du bien
 # Chargement des information date début / fin exercice courant et suivant pour les sélections de DEPREC

 If G_ACTCCN=G_OUI
  Columns [DEP] (CPY,FCY,AASREF,CNX,DPRPLN,FIYENDDAT,PERENDDAT,
&                DPRBAS,PSTDPE,PSTEXC,PSTDER,PSTDERRVE,PSTRVETRF,PSTRVACRB,PSTCADCRB,PSTLNK,
&                DPRCUM,EXCCUM,LEGCUM,LEGRVECUM,EXEIMLCUM,EXERVECUM,EXETRFCUM)
 Else
  Columns [DEP] (CPY,FCY,AASREF,CNX,DPRPLN,FIYENDDAT,PERENDDAT,
&                DPRBAS,PSTDPE,PSTEXC,PSTDER,PSTDERRVE,PSTRVETRF,PSTRVACRB,PSTLNK,
&                DPRCUM,EXCCUM,LEGCUM,LEGRVECUM,EXEIMLCUM,EXERVECUM,EXETRFCUM)
 Endif
 For [F:CNX] Where CPY=[M:FC0]CPY
  Local Integer I_PLN
  Local Integer L_PLN, WERR
  Local Integer I_DPRPLN
  Read [F:FIYC]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TECOURA
  Read [F:FIYS]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TESUIV

  # FQ96356
  If [M:FPC]DPRPLNCNX(0) = 0
    #> Chargement du masque de travail contenant le paramétrage comptable de la société
    Local File CONTEXT [CNX]
    Call LOAD_FASPARCPY([M:FC0]CPY, "", G_NON, WERR) From GLOFCYCPY
Endif

  For I_PLN=1 To [F:CNX]NBPLC
   L_PLN=[F:CNX]PLNCAA(I_PLN-1)
   GFLGPLN(L_PLN)=G_NON
   I_DPRPLN=find([M:FPC]DPRPLNLED(find (L_PLN,[M:FPC]DPRPLNCNX)-1),[M:FPC]DPRPLN)
   GFLGPLNMNG(L_PLN)= G_OUI #fq65071
   Local Integer I_PER

   # Chargement du tableau invisible pour l'exercice courant

   For I_PER=1 To [F:FIYC]NBRPER
    #If [F:FIYC]TYPPST(I_PER-1)=GVML_TPSTDEF #Fq65071-Lecture du premier enregistrement pour récupérer les cumuls exercice
     Read [DEP]DEP0=[M:FC0]AASREF;L_PLN;[F:FIYC]DATENDFIY;[F:FIYC]DATENDPER(I_PER-1)
     If !fstat

      # Cumuls exercices antérieurs

      If dim(LFIRST)<0
        [M:FC1]DPRCUMI(L_PLN-1)    = [F:DEP]DPRCUM
        [M:FC1]EXCCUMI(L_PLN-1)    = [F:DEP]EXCCUM
        [M:FC1]LEGCUMI(L_PLN-1)    = [F:DEP]LEGCUM
        [M:FC1]LEGRVECUMI(L_PLN-1) = [F:DEP]LEGRVECUM
        [M:FC1]EXEIMLCUMI(L_PLN-1) = [F:DEP]EXEIMLCUM
        [M:FC1]EXERVECUMI(L_PLN-1) = [F:DEP]EXERVECUM
        [M:FC1]EXETRFCUMI(L_PLN-1) = [F:DEP]EXETRFCUM
        Local Integer LFIRST
      Endif

      If [F:FIYC]TYPPST(I_PER-1)=GVML_TPSTDEF & ([F:DEP]PSTDPE | [F:DEP]PSTEXC | [F:DEP]PSTDER | [F:DEP]PSTDERRVE | [F:DEP]PSTRVACRB | (G_ACTCCN=G_OUI & [F:DEP]PSTCADCRB))

       GFLGPLN(L_PLN)=G_OUI

       # Montants comptabilisés

       [M:FC1]DPRPLNI([M:FC1]NBDOTI)    = [F:DEP]DPRPLN
       [M:FC1]STAFIYI([M:FC1]NBDOTI)    = GVML_TECOURA
       [M:FC1]FIYENDDATI([M:FC1]NBDOTI) = [F:DEP]FIYENDDAT
       [M:FC1]PERENDDATI([M:FC1]NBDOTI) = [F:DEP]PERENDDAT
       [M:FC1]PSTDPEI([M:FC1]NBDOTI)    = [F:DEP]PSTDPE
       [M:FC1]PSTEXCI([M:FC1]NBDOTI)    = [F:DEP]PSTEXC
       [M:FC1]PSTDERI([M:FC1]NBDOTI)    = [F:DEP]PSTDER
       [M:FC1]PSTDERRVEI([M:FC1]NBDOTI) = [F:DEP]PSTDERRVE
       [M:FC1]PSTRVACRBI([M:FC1]NBDOTI) = [F:DEP]PSTRVACRB
       If G_ACTCCN=G_OUI
        [M:FC1]PSTCADCRBI([M:FC1]NBDOTI) = [F:DEP]PSTCADCRB
       Endif

       # Imputations analytiques

       [M:FC1]DSPI([M:FC1]NBDOTI) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
       If [M:FC1]DSPI([M:FC1]NBDOTI)=""
        Local Integer I_AXE
        Local Char    L_NOMCHAMP
        For I_AXE=1 To 9
         L_NOMCHAMP="[M:FC1]DIE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"
         Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
         L_NOMCHAMP="[M:FC1]CCE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"
         Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC1]DIE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"))
        Next I_AXE
       Endif

       [M:FC1]NBDOTI+=1
      Endif
     Endif
    #Endif
   Next I_PER

   # Chargement du tableau invisible pour l'exercice suivant

   For I_PER=1 To [F:FIYS]NBRPER
    If [F:FIYS]TYPPST(I_PER-1)=GVML_TPSTDEF
     Read [DEP]DEP0=[M:FC0]AASREF;L_PLN;[F:FIYS]DATENDFIY;[F:FIYS]DATENDPER(I_PER-1)
     If !fstat
      If [F:DEP]PSTDPE | [F:DEP]PSTEXC | [F:DEP]PSTDER | [F:DEP]PSTDERRVE | [F:DEP]PSTRVACRB | (G_ACTCCN=G_OUI & [F:DEP]PSTCADCRB)
       GFLGPLN(L_PLN)=G_OUI

       # Montants comptabilisés

       [M:FC1]DPRPLNI([M:FC1]NBDOTI)    = [F:DEP]DPRPLN
       [M:FC1]STAFIYI([M:FC1]NBDOTI)    = GVML_TESUIV
       [M:FC1]FIYENDDATI([M:FC1]NBDOTI) = [F:DEP]FIYENDDAT
       [M:FC1]PERENDDATI([M:FC1]NBDOTI) = [F:DEP]PERENDDAT
       [M:FC1]PSTDPEI([M:FC1]NBDOTI)    = [F:DEP]PSTDPE
       [M:FC1]PSTEXCI([M:FC1]NBDOTI)    = [F:DEP]PSTEXC
       [M:FC1]PSTDERI([M:FC1]NBDOTI)    = [F:DEP]PSTDER
       [M:FC1]PSTDERRVEI([M:FC1]NBDOTI) = [F:DEP]PSTDERRVE
       [M:FC1]PSTRVACRBI([M:FC1]NBDOTI) = [F:DEP]PSTRVACRB
       If G_ACTCCN=G_OUI
        [M:FC1]PSTCADCRBI([M:FC1]NBDOTI) = [F:DEP]PSTCADCRB
       Endif

       # Imputations analytiques

       [M:FC1]DSPI([M:FC1]NBDOTI) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
       If [M:FC1]DSPI([M:FC1]NBDOTI)=""
        Local Integer I_AXE
        Local Char    L_NOMCHAMP
        For I_AXE=1 To 9
         L_NOMCHAMP="[M:FC1]DIE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"
         Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
         L_NOMCHAMP="[M:FC1]CCE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"
         Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC1]DIE"+num$(I_AXE)+"I([M:FC1]NBDOTI)"))
        Next I_AXE
       Endif

       [M:FC1]NBDOTI+=1
      Endif
     Endif
    Endif
   Next I_PER

   If GFLGPLNMNG(L_PLN)=G_OUI
    #fq65071
    # Chargement de la base d'amortissement (de la période courante de l'exercice courant) dans le champ invisible
    Read [F:DEP]DEP0=[M:FC0]AASREF;L_PLN;[F:FIYC]DATENDFIY;[F:FIYC]DATENDPER([F:FIYC]INDCURPER-1)
    [M:FC1]DPRBASI(L_PLN-1)=[F:DEP]DPRBAS
    # Chargement de la devise du plan d'amortissement
    [M:FC1]CURI(L_PLN-1)=[F:CNX]CUR
    # Chargement des dates début / fin exercice / période courante
    PLNPERSTRDAT(L_PLN-1) = [F:FIYC]DATSTRPER([F:FIYC]INDCURPER-1) : # FQ90143 : indiçage manquant
    PLNPERENDDAT(L_PLN-1) = [F:FIYC]DATENDPER([F:FIYC]INDCURPER-1) : # FQ90143 : indiçage manquant
    PLNFIYSTRDAT(L_PLN-1) = [F:FIYC]DATSTRFIY                      : # FQ90143 : indiçage manquant
    PLNFIYENDDAT(L_PLN-1) = [F:FIYC]DATENDFIY                      : # FQ90143 : indiçage manquant
    # Détermination du cas de suppression du bien
    [M:FC1]TYPANNI(L_PLN-1) = func TRTFASCNLDOT.GET_TYPANN([F:FAS]AASREF,L_PLN)
   Endif

   # Préparation des événements d'annulation

   If GFLGPLN(L_PLN)=G_OUI
     Call PREP_EVT_CNL(L_PLN) From TRTFASCNLDOT
   Else
    # Aucun événement à créer : on donne la possibilité de les créer en spé
    GPOINT = "FASCNLEVTSPE" : Gosub ENTREE From EXEFNC #CHECK IGNORE_LINE
    #fq65071-Pas de dotation / on génére quand même un événement d'annulation
    If !GPE
     Call ADD_CNL_EVENT_WITHOUT_DEP(L_PLN)
   Endif
   Endif

   If dim(LFIRST)>0 : Kill LFIRST : Endif

  Next I_PLN # Boucle sur plans
 Next # Boucle sur contextes
 Columns [DEP]
#Affzo [M:FC1] #Fq65071

 # Contrôle si il y a des montants comptabilisés

 If ![M:FC1]NBDOTI
  NOAMT=1
 #[M:FC1]DPRPLN=0 : Diszo [M:FC1]DPRPLN #Fq65071
  Call LOAD_EVT_TAB(G301CPT) From TRTFASCNLDOT
  [M:FC1]DPRPLN=G301CPT
 Else
  #> Chargement du premier plan pour lequel il y a des montants comptabilisés
  Local Integer LFIRPLN : LFIRPLN=find(G_OUI,GFLGPLN)

  Call LOAD_DOT_TAB(LFIRPLN) From TRTFASCNLDOT
  Call LOAD_EVT_TAB(LFIRPLN) From TRTFASCNLDOT
  #Diszo [M:FC1]CPTDATINT #Fq65071
  [M:FC1]DPRPLN = LFIRPLN : Affzo [M:FC1]DPRPLN
 Endif

 # Actualisation des colonnes axes analytiques (nombre d'axes et titres de colonnes).
 Call AV_NBDOT From TRTFASCNLDOT
 Call AV_NBEVT From TRTFASCNLDOT

 #Fq65071-debut
 Diszo [M:FC1]CPTDATINT
 Grizo [M:FC1]EDSP
 Grizo [M:FC1]ECCE1
 Grizo [M:FC1]ECCE2
 Grizo [M:FC1]ECCE3
 Grizo [M:FC1]ECCE4
 Grizo [M:FC1]ECCE5
 Grizo [M:FC1]ECCE6
 Grizo [M:FC1]ECCE7
 Grizo [M:FC1]ECCE8
 Grizo [M:FC1]ECCE9

 If GFLGPLNMNG([M:FC1]DPRPLN)= G_OUI
  [M:FC1]DPRBAS = [M:FC1]DPRBASI([M:FC1]DPRPLN-1) #: Affzo [M:FC1]DPRBAS
  [M:FC1]CUR    = [M:FC1]CURI([M:FC1]DPRPLN-1)    #: Affzo [M:FC1]CUR : Affzo [M:FC1]ZCUR
 Endif
 [M:FC1]ACCCOD=[F:FAS]ACCCOD
 [M:FC1]ACCCODORI=func TRTFASCNLDOT.GET_ACCCODORI([F:FAS]AASREF)
 If [M:FC1]ACCCODORI="" : Chgfmt [M:FC1]ACCCODORI With "-K:20X" : Chgfmt [M:FC1]ZACCCODORI With "-K:80X" : Endif
 Affzo [M:FC1]
 #Fq65071-fin

Return

#**
#* Chargement du tableau des montants
#* comptabilisés à partir du tableau
#* invisible
#*
#* @param PDPRPLN : Plan d'amortissement à traiter
#*!
Subprog LOAD_DOT_TAB(PDPRPLN)
Value Integer PDPRPLN
 I_DEBPLAN = find(PDPRPLN,[M:FC1]DPRPLNI)
 If I_DEBPLAN
  Local Integer I_OCC
  Raz [M:FC1]NBDOT
  For I_OCC=I_DEBPLAN To [M:FC1]NBDOTI
   If [M:FC1]DPRPLNI(I_OCC-1)<>PDPRPLN : Break : Endif
    If [M:FC1]NBDOT=0
     [M:FC1]STAFIY([M:FC1]NBDOT) = [M:FC1]STAFIYI(I_OCC-1)
    Elsif [M:FC1]NBDOT>=1
     If [M:FC1]STAFIYI(I_OCC-1)<>[M:FC1]STAFIYI(I_OCC-2)
      [M:FC1]STAFIY([M:FC1]NBDOT) = [M:FC1]STAFIYI(I_OCC-1)
     Else
      [M:FC1]STAFIY([M:FC1]NBDOT) = 0
     Endif
    Endif
    [M:FC1]FIYENDDAT([M:FC1]NBDOT) = [M:FC1]FIYENDDATI(I_OCC-1)
    [M:FC1]PERENDDAT([M:FC1]NBDOT) = [M:FC1]PERENDDATI(I_OCC-1)
    [M:FC1]PSTDPE([M:FC1]NBDOT)    = [M:FC1]PSTDPEI(I_OCC-1)
    [M:FC1]PSTEXC([M:FC1]NBDOT)    = [M:FC1]PSTEXCI(I_OCC-1)
    [M:FC1]PSTDER([M:FC1]NBDOT)    = [M:FC1]PSTDERI(I_OCC-1)
    [M:FC1]PSTDERRVE([M:FC1]NBDOT) = [M:FC1]PSTDERRVEI(I_OCC-1)
    [M:FC1]PSTRVACRB([M:FC1]NBDOT) = [M:FC1]PSTRVACRBI(I_OCC-1)
    If G_ACTCCN=G_OUI
     [M:FC1]PSTCADCRB([M:FC1]NBDOT)= [M:FC1]PSTCADCRBI(I_OCC-1)
    Endif
    [M:FC1]DSP([M:FC1]NBDOT)       = [M:FC1]DSPI(I_OCC-1)
    For I=1 To 9
     CHAMP = "[M:FC1]CCE"+num$(I)+"([M:FC1]NBDOT)"
     Assign CHAMP With evalue("[M:FC1]CCE"+num$(I)+"I(I_OCC-1)")
    Next I
    [M:FC1]NBDOT+=1
  Next I_OCC
 Endif
 Affzo [M:FC1]10
End

#**
#* Chargement du tableau des événements
#* d'annulation à partir du tableau
#* invisible
#*
#* @param PDPRPLN : Plan d'amortissement à traiter
#*!
Subprog LOAD_EVT_TAB(PDPRPLN)
Value Integer PDPRPLN

 I_DEBPLAN = find(PDPRPLN,[M:FC1]IDPRPLN)
 If I_DEBPLAN
  Local Integer I_OCC, I
  Local Char    CHAMP
  Raz [M:FC1]NBEVT
  For I_OCC=I_DEBPLAN To [M:FC1]NBEVTI
   If [M:FC1]IDPRPLN(I_OCC-1)<>PDPRPLN : Break : Endif
    [M:FC1]EFIYSTA([M:FC1]NBEVT   ) = [M:FC1]IFIYSTA(I_OCC-1)
    [M:FC1]EVTDAT([M:FC1]NBEVT)     = [M:FC1]IEVTDAT(I_OCC-1)
    [M:FC1]CPTDATINT([M:FC1]NBEVT)  = [M:FC1]ICPTDATINT(I_OCC-1)
    [M:FC1]CPTDATSAV([M:FC1]NBEVT)  = [M:FC1]ICPTDATSAV(I_OCC-1)
    [M:FC1]EDPRBAS([M:FC1]NBEVT)    = [M:FC1]IDPRBAS(I_OCC-1) #Fq65071
    [M:FC1]EPSTDPE([M:FC1]NBEVT)    = [M:FC1]IPSTDPE(I_OCC-1)
    [M:FC1]EPSTEXC([M:FC1]NBEVT)    = [M:FC1]IPSTEXC(I_OCC-1)
    [M:FC1]EPSTDER([M:FC1]NBEVT)    = [M:FC1]IPSTDER(I_OCC-1)
    [M:FC1]EPSTDERRVE([M:FC1]NBEVT) = [M:FC1]IPSTDERRVE(I_OCC-1)
    [M:FC1]EPSTRVETRF([M:FC1]NBEVT) = [M:FC1]IPSTRVETRF(I_OCC-1)
    [M:FC1]EPSTRVACRB([M:FC1]NBEVT) = [M:FC1]IPSTRVACRB(I_OCC-1)
    If G_ACTCCN=G_OUI
     [M:FC1]EPSTCADCRB([M:FC1]NBEVT) = [M:FC1]IPSTCADCRB(I_OCC-1)
    Endif
    [M:FC1]EDSP([M:FC1]NBEVT)       = [M:FC1]IDSP(I_OCC-1)
    For I=1 To 9
     CHAMP = "[M:FC1]EDIE"+num$(I)+"([M:FC1]NBEVT)"
     Assign CHAMP With evalue("[M:FC1]IDIE"+num$(I)+"(I_OCC-1)")
     CHAMP = "[M:FC1]ECCE"+num$(I)+"([M:FC1]NBEVT)"
     Assign CHAMP With evalue("[M:FC1]ICCE"+num$(I)+"(I_OCC-1)")
    Next I
    [M:FC1]NBEVT+=1
  Next I_OCC
 Endif
 Affzo [M:FC1]20
 Call AV_NBEVT From TRTFASCNLDOT
End

#**
#* Préparation des événements d'annulation
#* à générer dans le tableau invisible
#*
#* @param PDPRPLN : Plan d'amortissement à traiter
#*!
Subprog PREP_EVT_CNL(PDPRPLN)
Value Integer PDPRPLN

 If ![M:FC1]NBDOTI : End : Endif #Fq65071

 I_DEBPLAN = find(PDPRPLN,[M:FC1]DPRPLNI)
 If I_DEBPLAN

  Local Char    CHAMP
  Local Integer I
  Local Integer I_OCC
  Local Integer R_FIY
  Local Integer S_FIY
  Local Integer R_CCE
  Local Char    S_CCE
  Local Char    C_CCE
  Local Decimal T_PSTDPE, T_PSTEXC, T_PSTDER, T_PSTDERRVE, T_PSTRVETRF, T_PSTRVACRB, T_PSTCADCRB
  Local Decimal T_DPRCUM, T_EXCCUM, T_LEGCUM, T_LEGRVECUM, T_EXEIMLCUM, T_EXERVECUM, T_EXETRFCUM

  For I_OCC=I_DEBPLAN To [M:FC1]NBDOTI
   If [M:FC1]DPRPLNI(I_OCC-1)<>PDPRPLN : Break : Endif

   If I_OCC=I_DEBPLAN
    S_FIY=[M:FC1]STAFIYI(I_OCC-1)
    S_CCE=[M:FC1]DSPI(I_OCC-1)
    For I=1 To 9
     S_CCE+="~"+evalue("[M:FC1]CCE"+num$(I)+"I(I_OCC-1)")
    Next I_CCE
   Else
    # Rupture Exercice ?
    If S_FIY<>[M:FC1]STAFIYI(I_OCC-1) : R_FIY=1 : S_FIY=[M:FC1]STAFIYI(I_OCC-1) : Else : R_FIY=0 : Endif
    # Rupture analytique ?
    If PDPRPLN=G301CPT
     C_CCE=[M:FC1]DSPI(I_OCC-1)
     For I=1 To 9
      C_CCE+="~"+evalue("[M:FC1]CCE"+num$(I)+"I(I_OCC-1)")
     Next I_CCE
     If S_CCE<>C_CCE : R_CCE=1 : S_CCE=C_CCE : Else : R_CCE=0 : Endif
    Endif
   Endif

   # Rupture, on ajoute l'événement

   If R_FIY | R_CCE : Gosub ADD_CNL_EVENT From TRTFASCNLDOT : Endif

   # Totalisation

   T_PSTDPE    += [M:FC1]PSTDPEI(I_OCC-1)
   T_PSTEXC    += [M:FC1]PSTEXCI(I_OCC-1)
   T_PSTDER    += [M:FC1]PSTDERI(I_OCC-1)
   T_PSTDERRVE += [M:FC1]PSTDERRVEI(I_OCC-1)
   T_PSTRVETRF += [M:FC1]PSTRVETRFI(I_OCC-1)
   T_PSTRVACRB += [M:FC1]PSTRVACRBI(I_OCC-1)
   If G_ACTCCN=G_OUI
    T_PSTCADCRB += [M:FC1]PSTCADCRBI(I_OCC-1)
   Endif

   If S_FIY=GVML_TECOURA & [M:FC1]FLGEXTANT=G_OUI & dim(LFIRST)<0
    Local Integer LFIRST
    T_DPRCUM    = [M:FC1]DPRCUMI(I_OCC-1)
    T_EXCCUM    = [M:FC1]EXCCUMI(I_OCC-1)
    T_LEGCUM    = [M:FC1]LEGCUMI(I_OCC-1)
    T_LEGRVECUM = [M:FC1]LEGRVECUMI(I_OCC-1)
    T_EXEIMLCUM = [M:FC1]EXEIMLCUMI(I_OCC-1)
    T_EXERVECUM = [M:FC1]EXERVECUMI(I_OCC-1)
    T_EXETRFCUM = [M:FC1]EXETRFCUMI(I_OCC-1)
   Endif

  Next I_OCC

  If [M:FC1]NBDOTI-I_DEBPLAN<>0 | I_OCC
   Gosub ADD_CNL_EVENT From TRTFASCNLDOT
  Endif

  If dim(LPREM) >0 : Kill LPREM  : Endif
  If dim(LFIRST)>0 : Kill LFIRST : Endif
 Endif
End

#----------------------------------------
# Ajout d'un événement d'annulation de
# dotation si rupture
#----------------------------------------
$ADD_CNL_EVENT
  [M:FC1]IFIYSTA([M:FC1]NBEVTI)    = [M:FC1]STAFIYI(I_OCC-2)
  [M:FC1]IDPRPLN([M:FC1]NBEVTI)    = PDPRPLN
  [M:FC1]IEVTDAT([M:FC1]NBEVTI)    = [M:FC1]PERENDDATI(I_OCC-2)
  # DEB FQ90143
  #[M:FC1]ICPTDATINT([M:FC1]NBEVTI) = [M:FC1]PERENDDATI(I_OCC-2)
  #[M:FC1]ICPTDATSAV([M:FC1]NBEVTI) = [M:FC1]PERENDDATI(I_OCC-2)
  [M:FC1]ICPTDATINT([M:FC1]NBEVTI) = PLNPERENDDAT(PDPRPLN-1)
  [M:FC1]ICPTDATSAV([M:FC1]NBEVTI) = PLNPERENDDAT(PDPRPLN-1)
  # FIN FQ90143
  [M:FC1]IPSTDPE([M:FC1]NBEVTI)    = T_PSTDPE
  [M:FC1]IPSTEXC([M:FC1]NBEVTI)    = T_PSTEXC
  [M:FC1]IPSTDER([M:FC1]NBEVTI)    = T_PSTDER
  [M:FC1]IPSTDERRVE([M:FC1]NBEVTI) = T_PSTDERRVE
  [M:FC1]IPSTRVETRF([M:FC1]NBEVTI) = T_PSTRVETRF
  [M:FC1]IPSTRVACRB([M:FC1]NBEVTI) = T_PSTRVACRB
  If G_ACTCCN=G_OUI
   [M:FC1]IPSTCADCRB([M:FC1]NBEVTI) = T_PSTCADCRB
  Endif
  [M:FC1]IDSP([M:FC1]NBEVTI)       = [M:FC1]DSPI(I_OCC-2)
  For I=1 To 9
   CHAMP="[M:FC1]IDIE"+num$(I)+"([M:FC1]NBEVTI)"
   Assign CHAMP With evalue("[M:FC1]DIE"+num$(I)+"I(I_OCC-2)")
   CHAMP="[M:FC1]ICCE"+num$(I)+"([M:FC1]NBEVTI)"
   Assign CHAMP With evalue("[M:FC1]CCE"+num$(I)+"I(I_OCC-2)")
   CHAMP="[M:FC1]ICCE"+num$(I)+"SAV([M:FC1]NBEVTI)"
   Assign CHAMP With evalue("[M:FC1]ICCE"+num$(I)+"([M:FC1]NBEVTI)")
  Next I

  If [M:FC1]IFIYSTA([M:FC1]NBEVTI)=GVML_TECOURA & dim(LPREM)<0
   Local Integer LPREM
   [M:FC1]IDPRBAS([M:FC1]NBEVTI)=[M:FC1]DPRBASI(PDPRPLN-1)
   If [M:FC1]FLGEXTANT=G_OUI
    [M:FC1]IDPRCUM([M:FC1]NBEVTI)    = T_DPRCUM
    [M:FC1]IEXCCUM([M:FC1]NBEVTI)    = T_EXCCUM
    [M:FC1]ILEGCUM([M:FC1]NBEVTI)    = T_LEGCUM
    [M:FC1]ILEGRVECUM([M:FC1]NBEVTI) = T_LEGRVECUM
    [M:FC1]IEXEIMLCUM([M:FC1]NBEVTI) = T_EXEIMLCUM
    [M:FC1]IEXERVECUM([M:FC1]NBEVTI) = T_EXERVECUM
    [M:FC1]IEXETRFCUM([M:FC1]NBEVTI) = T_EXETRFCUM
   Else
    Raz [M:FC1]IDPRCUM([M:FC1]NBEVTI),[M:FC1]IEXCCUM([M:FC1]NBEVTI),[M:FC1]ILEGCUM([M:FC1]NBEVTI),[M:FC1]ILEGRVECUM([M:FC1]NBEVTI),
&       [M:FC1]IEXEIMLCUM([M:FC1]NBEVTI), [M:FC1]IEXERVECUM([M:FC1]NBEVTI), [M:FC1]IEXETRFCUM([M:FC1]NBEVTI)
   Endif
  Else
   Raz [M:FC1]IDPRCUM([M:FC1]NBEVTI),[M:FC1]IEXCCUM([M:FC1]NBEVTI),[M:FC1]ILEGCUM([M:FC1]NBEVTI),[M:FC1]ILEGRVECUM([M:FC1]NBEVTI),
&      [M:FC1]IEXEIMLCUM([M:FC1]NBEVTI), [M:FC1]IEXERVECUM([M:FC1]NBEVTI), [M:FC1]IEXETRFCUM([M:FC1]NBEVTI),
&      [M:FC1]IDPRBAS([M:FC1]NBEVTI)
  Endif
  Raz T_PSTDPE, T_PSTEXC, T_PSTDER, T_PSTDERRVE, T_PSTRVETRF, T_PSTRVACRB, T_PSTCADCRB
  Raz T_DPRCUM, T_EXCCUM, T_LEGCUM, T_LEGRVECUM, T_EXEIMLCUM, T_EXERVECUM, T_EXETRFCUM
  If R_FIY : R_FIY=0 : Endif
  If R_CCE : R_CCE=0 : Endif
  [M:FC1]NBEVTI+=1
Return

#**
#* Fq65071
#* Ajout d'un événement pour les biens n'ayant aucune dotation
#* comptabilisée
#*
#* @param PPLN    Plan d'amortissement
#*!
Subprog ADD_CNL_EVENT_WITHOUT_DEP(PPLN)
Value Integer PPLN

  Local Integer L_PLN

  [M:FC1]IFIYSTA([M:FC1]NBEVTI)    = GVML_TECOURA
  [M:FC1]IDPRPLN([M:FC1]NBEVTI)    = PPLN
  [M:FC1]IEVTDAT([M:FC1]NBEVTI)    = PLNPERENDDAT(PPLN-1) : # FQ90143 : indiçage manquant
  [M:FC1]ICPTDATINT([M:FC1]NBEVTI) = PLNPERENDDAT(PPLN-1) : # FQ90143 : indiçage manquant
  [M:FC1]ICPTDATSAV([M:FC1]NBEVTI) = PLNPERENDDAT(PPLN-1) : # FQ90143 : indiçage manquant
  [M:FC1]DSPI([M:FC1]NBDOTI)=func TRTFASTRF.GET_CCE("[F:FAS]",PLNPERENDDAT(PPLN-1),0) : # FQ90143 : indiçage manquant
  If [M:FC1]DSPI([M:FC1]NBDOTI)=""
  For I=1 To 9
   # Axe analytique
   CHAMP="[M:FC1]IDIE"+num$(I)+"([M:FC1]NBEVTI)"
   L_PLN = find([M:FPC]DPRPLNLED(find(PPLN,[M:FPC]DPRPLNCNX)-1),[M:FPC]DPRPLN)
   Assign CHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I)+"("+num$(L_PLN-1)+")")
   # Section analytique
   CHAMP="[M:FC1]ICCE"+num$(I)+"([M:FC1]NBEVTI)"
   Assign CHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",PPLN,evalue("[M:FC1]IDIE"+num$(I)+"([M:FC1]NBEVTI)"))
   CHAMP="[M:FC1]ICCE"+num$(I)+"SAV([M:FC1]NBEVTI)"
   Assign CHAMP With evalue("[M:FC1]ICCE"+num$(I)+"([M:FC1]NBEVTI)")
  Next I
  Endif
  [M:FC1]IDPRBAS([M:FC1]NBEVTI)    = [M:FC1]DPRBASI(PPLN-1)
  [M:FC1]NBEVTI+=1
End

#**
#* Renvoie le type du contexte d'annulation d'un bien
#* Comptable
#*
#* @param  PAASREF  Référence bien comptable
#* @param  PPLN     Plan d'amortissement
#* @return RTYPANN  Type d'annulation
#*
#*!
Funprog GET_TYPANN(PAASREF, PPLN)
Value Char    PAASREF
Value Integer PPLN

 Local Shortint RTYPANN : RTYPANN=0

 GOK=1
 If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
 If [F:FAS]AASREF<>PAASREF
  Read [F:FAS]FAS0=PAASREF
  If fstat
   GOK=0
  Endif
 Endif

 If GOK

  #> Bien crée par saisie directe dans les immos

  If clalev([F:E24])=0 : Local File EFASCRT [E24] : Endif
  Filter [F:E24] Where REF=PAASREF & DPRPLN=PPLN
  For [F:E24]
   RTYPANN=11
   If [F:E24]CPTFLG=G_OUI : RTYPANN=12 : Break : Endif
  Next
  Filter [F:E24]
  If RTYPANN : End RTYPANN : Endif

  #> Bien cré par immobilisation d'une ou plusieurs dépenses

  If clalev([F:LOF])=0 : Local File LAYOUTFAS [LOF] : Endif
  Filter [F:LOF] Where AASREF=PAASREF
  For [F:LOF]
   RTYPANN=21
   If [F:LOF]CREORI=GVML_COIMPOR : RTYPANN=31 : Break : Endif
  Next
  Filter [F:LOF]

 Endif

End RTYPANN

#**
#* Renvoie le premier code comptable d'un bien s'il a été mis en service
#*
#* @param  PAASREF     Référence du bien
#* @return racccodori  Code comptable origine
#*!
Funprog GET_ACCCODORI(PAASREF)
Value Char PAASREF
Local Char RACCCODORI

 GOK=1
 If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif
 If [F:FAS]AASREF<>PAASREF
  Read [F:FAS]FAS0=PAASREF
  If fstat
   GOK=0
  Endif
 Endif

 If GOK
  If !clalev([E23]) : Local File EFASCHGIMP [E23] : Endif
  Filter [F:E23] Where REF=PAASREF & DPRPLN=G301CPT
  Read [F:E23] First
  If [F:E23]ACCCOD<>[F:FAS]ACCCOD &
&                   (([F:E23]GACACNO<>[F:E23]GACACND) |
&                    (GIAS & [F:E23]IASACNO<>[F:E23]IASACND))
   RACCCODORI=[F:E23]ACCCOD
  Endif
 Endif

End RACCCODORI

#**
#*
#*
#* @param PFLD      Champ analytique
#* @param PVALUE    Nouvelle valeur du champ analytique
#* @param PEVTDAT   Date d'effet de l'événement à modifier
#* @param PPLN      Plan d'amortissement
#*!
Subprog UPD_EVT_ANA_INFO(PFLD, PVALUE, PEVTDAT, PPLN)
Value Char    PFLD
Value Char    PVALUE
Value Date    PEVTDAT
Value Integer PPLN

Local Char    LFLDNAM
Local Integer I_EVT

For I_EVT=1 To [M:FC1]NBEVTI
 If [M:FC1]IDPRPLN(I_EVT-1)=PPLN & [M:FC1]IEVTDAT(I_EVT-1)=PEVTDAT
  Break
 Endif
Next I_EVT
If I_EVT
 LFLDNAM="[M:FC1]I"+PFLD+"(I_EVT-1)"
 Assign LFLDNAM With PVALUE
Endif

End

#**
#* Permet de modifier le format d'affichage des axes analytiques
#* Utilisé ici pour rendre visibles ou invisibles les colonnes
#* correspondant aux axes analytiques.
#*
#* @param PCCEFLD  :   Champs analytique à formater : DOT / EVT
#* @param PIAXE    :   Numéro d'axe 1 à 9
#* @param PFORMAT  :   Format d'affichage
#*!
Subprog CHGFMT_FLD_CCE(PCCEFLD,PIAXE,PFORMAT)
Value Char    PCCEFLD
Value Integer PIAXE
Value Char    PFORMAT

 Case PCCEFLD
  When "DOT"
   Case PIAXE
    When 1 : Chgfmt [M:FC1]CCE1 With PFORMAT
    When 2 : Chgfmt [M:FC1]CCE2 With PFORMAT
    When 3 : Chgfmt [M:FC1]CCE3 With PFORMAT
    When 4 : Chgfmt [M:FC1]CCE4 With PFORMAT
    When 5 : Chgfmt [M:FC1]CCE5 With PFORMAT
    When 6 : Chgfmt [M:FC1]CCE6 With PFORMAT
    When 7 : Chgfmt [M:FC1]CCE7 With PFORMAT
    When 8 : Chgfmt [M:FC1]CCE8 With PFORMAT
    When 9 : Chgfmt [M:FC1]CCE9 With PFORMAT
   Endcase
  When "EVT"
   Case PIAXE
    When 1 : Chgfmt [M:FC1]ECCE1 With PFORMAT
    When 2 : Chgfmt [M:FC1]ECCE2 With PFORMAT
    When 3 : Chgfmt [M:FC1]ECCE3 With PFORMAT
    When 4 : Chgfmt [M:FC1]ECCE4 With PFORMAT
    When 5 : Chgfmt [M:FC1]ECCE5 With PFORMAT
    When 6 : Chgfmt [M:FC1]ECCE6 With PFORMAT
    When 7 : Chgfmt [M:FC1]ECCE7 With PFORMAT
    When 8 : Chgfmt [M:FC1]ECCE8 With PFORMAT
    When 9 : Chgfmt [M:FC1]ECCE9 With PFORMAT
   Endcase
 Endcase

End

######################################################################################
# ACTIONS CHAMPS ECRAN FASCNL1
######################################################################################

#----------------------------------------
Subprog AS_DPRPLN(VALEUR)
Variable Integer VALEUR
 Local Integer I_PLN
 For I_PLN=1 To G301MAX-1
 #Fq65071
 #If GFLGPLN(I_PLN)<>G_OUI
  If GFLGPLNMNG(I_PLN)<>G_OUI
   GMENLOC(I_PLN)=1
  Endif
 Next I_PLN
 GMENLOC(G301AUC)=1
End

#----------------------------------------
Subprog C_DPRPLN(VALEUR)
Variable Integer VALEUR
 Raz [M:FC1]NBDOT, [M:FC1]NBEVT
 Call LOAD_DOT_TAB(VALEUR) From TRTFASCNLDOT
 Call LOAD_EVT_TAB(VALEUR) From TRTFASCNLDOT
 [M:FC1]DPRBAS=[M:FC1]DPRBASI(VALEUR-1) #Fq65071
 [M:FC1]CUR=[M:FC1]CURI(VALEUR-1)       #Fq65071
 [M:FC1]DPRPLN=VALEUR
 Local Char LCCE
 Call AV_CCE1(LCCE) From TRTFASCNLDOT
 Call AV_ECCE1(LCCE)From TRTFASCNLDOT
 Call AV_NBDOT      From TRTFASCNLDOT
 Call AV_NBEVT      From TRTFASCNLDOT
End

#----------------------------------------
Subprog AM_DPRPLN(VALEUR)
Variable Integer VALEUR
 Raz [M:FC1]NBDOT
 Call AV_NBDOT
 Call AV_NBEVT
 Affzo [M:FC1]NBEVT
End

#----------------------------------------
Subprog AP_DPRPLN(VALEUR)
Variable Integer VALEUR
End

#----------------------------------------
Subprog AM_FLGEXTANT(VALEUR)
Variable Integer VALEUR
 Case VALEUR
  When G_OUI

   Local Integer I_PLN
   For I_PLN=1 To G301MAX-1
    If GFLGPLNMNG(I_PLN)= G_OUI
     If [M:FC1]DPRBASI(I_PLN-1)<>0
      Local Integer I_EVT
      For I_EVT=1 To [M:FC1]NBEVTI
       If [M:FC1]IDPRPLN(I_EVT-1)=I_PLN & [M:FC1]IDPRBAS(I_EVT-1)=[M:FC1]DPRBASI(I_PLN-1)
        Break
       Endif
      Next I_EVT
      If I_EVT
       [M:FC1]IDPRCUM(I_EVT-1)    = [M:FC1]DPRCUMI([M:FC1]DPRPLN-1)
       [M:FC1]IEXCCUM(I_EVT-1)    = [M:FC1]EXCCUMI([M:FC1]DPRPLN-1)
       [M:FC1]ILEGCUM(I_EVT-1)    = [M:FC1]LEGCUMI([M:FC1]DPRPLN-1)
       [M:FC1]ILEGRVECUM(I_EVT-1) = [M:FC1]LEGRVECUMI([M:FC1]DPRPLN-1)
       [M:FC1]IEXEIMLCUM(I_EVT-1) = [M:FC1]EXEIMLCUMI([M:FC1]DPRPLN-1)
       [M:FC1]IEXERVECUM(I_EVT-1) = [M:FC1]EXERVECUMI([M:FC1]DPRPLN-1)
       [M:FC1]IEXETRFCUM(I_EVT-1) = [M:FC1]EXETRFCUMI([M:FC1]DPRPLN-1)
      Endif
     Endif
    Endif
   Next I_PLN
  When G_NON
   Raz [M:FC1]IDPRCUM, [M:FC1]IEXCCUM, [M:FC1]ILEGCUM, [M:FC1]ILEGRVECUM, [M:FC1]IEXEIMLCUM, [M:FC1]IEXERVECUM, [M:FC1]IEXETRFCUM
 Endcase
End

#----------------------------------------
Subprog AM_FLGUPDDAT(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  Raz [M:FC1]NBEVT
  Local Integer I
  For I=1 To [M:FC1]NBEVTI
   [M:FC1]ICPTDATINT(I-1)=[M:FC1]ICPTDATSAV(I-1)
  Next I
  Call LOAD_EVT_TAB([M:FC1]DPRPLN) From TRTFASCNLDOT
  Diszo [M:FC1]CPTDATINT
 Else
  Actzo [M:FC1]CPTDATINT
 Endif
 Affzo [M:FC1]CPTDATINT
End

#----------------------------------------
#Fq65071
Subprog AM_FLGUPDANA(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  Local Integer I
  For I=1 To [M:FC1]NBEVTI
   [M:FC1]IDSP(I-1)=[M:FC1]IDSPSAV(I-1)
   [M:FC1]ICCE1(I-1)=[M:FC1]ICCE1SAV(I-1)
   [M:FC1]ICCE2(I-1)=[M:FC1]ICCE2SAV(I-1)
   [M:FC1]ICCE3(I-1)=[M:FC1]ICCE3SAV(I-1)
   [M:FC1]ICCE4(I-1)=[M:FC1]ICCE4SAV(I-1)
   [M:FC1]ICCE5(I-1)=[M:FC1]ICCE5SAV(I-1)
   [M:FC1]ICCE6(I-1)=[M:FC1]ICCE6SAV(I-1)
   [M:FC1]ICCE7(I-1)=[M:FC1]ICCE7SAV(I-1)
   [M:FC1]ICCE8(I-1)=[M:FC1]ICCE8SAV(I-1)
   [M:FC1]ICCE9(I-1)=[M:FC1]ICCE9SAV(I-1)
  Next I
  Call LOAD_EVT_TAB([M:FC1]DPRPLN) From TRTFASCNLDOT
 Endif
 Affzo [M:FC1]EDSP
End

#----------------------------------------
Subprog AP_CPTDATINT(VALEUR)
Variable Date    VALEUR

 Local Integer LPLAN
 Local Date    LEVTDAT
 Local Integer I

 LPLAN  =[M:FC1]DPRPLN
 LEVTDAT=[M:FC1]EVTDAT(nolign-1)
 For I=1 To [M:FC1]NBEVTI
  If [M:FC1]IDPRPLN(I-1)=LPLAN &
&    [M:FC1]IEVTDAT(I-1)=LEVTDAT
   [M:FC1]ICPTDATINT(I-1)=VALEUR
   Break
  Endif
 Next I

End

#----------------------------------------
Subprog AV_NBDOT

 Local Integer I_LED
 Local Integer I_PLNLED
 Local Integer LPLNLED
 Local Integer L_DIE

 I_PLNLED = find([M:FC1]DPRPLN,[M:FPC]DPRPLNCNX)
 LPLNLED  = [M:FPC]DPRPLNLED(I_PLNLED-1)
 I_LED    = find(LPLNLED,[M:FPC]DPRPLN)

 If I_LED
  Local Integer I_DIE
  Local Char    LFORMAT
  Raz [M:FC1]NBLEDDIE
  For I_DIE=1 To 9
   If evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")=''")
    LFORMAT="-K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=""
   Else
    LFORMAT="K:"+num$(GLONCCE)+"X"
    LDIE = evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")")
    GTITDIE(I_DIE)=LDIE+"-"+[M:FPC]DIEDESSHO(find(LDIE,[M:FPC]DIE)-1)
    [M:FC1]NBLEDDIE+=1
   Endif
   Call CHGFMT_FLD_CCE("DOT",I_DIE, LFORMAT)
  Next I_DIE
 Endif

End

#Fq65071
#----------------------------------------
Subprog AS_NBEVT
 If [M:FC1]EDPRBAS(nolign-1)<>0 | [M:FC1]EFIYSTA(nolign-1)<>GVML_TECOURA
  GBOUT1=""
 Endif
 If [M:FC1]FLGUPDANA<>G_OUI
  GBOUT2=""
 Endif
End

#----------------------------------------
Subprog AV_NBEVT
 Local Integer I_LED
 Local Integer I_PLNLED
 Local Integer LPLNLED

 I_PLNLED = find([M:FC1]DPRPLN,[M:FPC]DPRPLNCNX)
 LPLNLED  = [M:FPC]DPRPLNLED(I_PLNLED-1)
 I_LED    = find(LPLNLED,[M:FPC]DPRPLN)

 If I_LED
  Local Integer I_DIE
  Local Char    LFORMAT
  Raz [M:FC1]NBLEDDIE
  For I_DIE=1 To 9
   If evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")=''")
    LFORMAT="-K:"+num$(GLONCCE)+"X"
    GTITDIE(I_DIE)=""
   Else
    LFORMAT="K:"+num$(GLONCCE)+"X"
    LDIE = evalue("[M:FPC]DPRPLNDIE"+num$(I_DIE)+"("+num$(I_LED-1)+")")
    GTITDIE(I_DIE)=LDIE+"-"+[M:FPC]DIEDESSHO(find(LDIE,[M:FPC]DIE)-1)
    [M:FC1]NBLEDDIE+=1
   Endif
   Call CHGFMT_FLD_CCE("EVT",I_DIE, LFORMAT)
  Next I_DIE
 Endif
End

#----------------------------------------
Subprog AV_CCE1(VALEUR)
Variable Char    VALEUR()
 If [M:FC1]DPRPLN<>G301CPT
  Chgfmt [M:FC1]PSTDER    With "-N:13.2"
  Chgfmt [M:FC1]PSTDERRVE With "-N:13.2"
  Chgfmt [M:FC1]PSTCADCRB With "-N:13.2"
 Endif
End

#----------------------------------------
Subprog AV_ECCE1(VALEUR)
Variable Char    VALEUR()
 If [M:FC1]DPRPLN<>G301CPT
  Chgfmt [M:FC1]EPSTDER    With "-N:13.2"
  Chgfmt [M:FC1]EPSTDERRVE With "-N:13.2"
  Chgfmt [M:FC1]EPSTCADCRB With "-N:13.2"
 Endif
End
#----------------------------------------
# Choix de l'événement porteur de la
# base d'amortissement
#----------------------------------------
Subprog B1_NBEVT

 Local Integer I_OLD, I_NEW, I

 #> Raz ancienne ligne
 For I_OLD=1 To [M:FC1]NBEVT
  If [M:FC1]EDPRBAS(I_OLD-1)<>0 & I_OLD<>nolign : Break : Endif
 Next I_OLD
 [M:FC1]EDPRBAS(I_OLD-1)=0 : Affzo [M:FC1]EDPRBAS(I_OLD-1)
 I=find([M:FC1]EVTDAT(I_OLD-1),[M:FC1]IEVTDAT)
 If I
  [M:FC1]IDPRBAS(I-1)=0
  If [M:FC1]FLGEXTANT=G_OUI
   [M:FC1]IDPRCUM(I-1)=0
   [M:FC1]IEXCCUM(I-1)=0
   [M:FC1]ILEGCUM(I-1)=0
   [M:FC1]ILEGRVECUM(I-1)=0
   [M:FC1]IEXEIMLCUM(I-1)=0
   [M:FC1]IEXERVECUM(I-1)=0
   [M:FC1]IEXETRFCUM(I-1)=0
  Endif
 Endif

 #> Alimentation nouvelle ligne
 I_NEW=nolign
 [M:FC1]EDPRBAS(I_NEW-1)=[M:FC1]DPRBAS : Affzo [M:FC1]EDPRBAS(I_NEW-1)
 I=find([M:FC1]EVTDAT(I_NEW-1),[M:FC1]IEVTDAT)
 If I
  [M:FC1]IDPRBAS(I-1)=[M:FC1]EDPRBAS(I_NEW-1)
  If [M:FC1]FLGEXTANT=G_OUI
   [M:FC1]IDPRCUM(I-1)=[M:FC1]DPRCUMI([M:FC1]DPRPLN-1)
   [M:FC1]IEXCCUM(I-1)=[M:FC1]EXCCUMI([M:FC1]DPRPLN-1)
   [M:FC1]ILEGCUM(I-1)=[M:FC1]LEGCUMI([M:FC1]DPRPLN-1)
   [M:FC1]ILEGRVECUM(I-1)=[M:FC1]LEGRVECUMI([M:FC1]DPRPLN-1)
   [M:FC1]IEXEIMLCUM(I-1)=[M:FC1]EXEIMLCUMI([M:FC1]DPRPLN-1)
   [M:FC1]IEXERVECUM(I-1)=[M:FC1]EXERVECUMI([M:FC1]DPRPLN-1)
   [M:FC1]IEXETRFCUM(I-1)=[M:FC1]EXETRFCUMI([M:FC1]DPRPLN-1)
  Endif
 Endif

End

#----------------------------------------
# Modification des imputations analytiques
#----------------------------------------
Subprog B2_NBEVT
 Local Char    PARAM(30)(1..2)
 Local Char    VALEUR
 Global Integer NOLIGNSAV : NOLIGNSAV=nolign
 GMSKORI="FC1"
 If !clalev([M:FCE]) : Local Mask FASCNLCCE [FCE] : Endif
 Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASCNLCCE","FASCNLCCE",4,"") From GTRAITE
 If dim(NOLIGNSAV)>0 : Kill NOLIGNSAV : Endif
 Call LOAD_EVT_TAB([M:FC1]DPRPLN) From TRTFASCNLDOT
End
