#<AdxTL>@(#)2.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : MDJ
# LE          : 18 Octobre   2010 09:51:59
# Moulinette pour alimenter le champ context (CNX) dans les enregistrements DEPREC(s)
# FQ68267
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM018: Initialisation du contexte dans les DEPREC(s)") From LECFIC
  Call EXE_UTIIMM018(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossiers à traiter
#*!
 Subprog EXE_UTIIMM018(APPLI)
 Value Char APPLI
  If clalev([F:CPY]) : Close Local File [CPY] : Endif
  Local File =APPLI+".COMPANY" [CPY]
  If clalev([F:CNX]) : Close Local File [CNX] : Endif
  Local File =APPLI+".CONTEXT" [CNX]
  If clalev([F:DEP]) : Close Local File [DEP] : Endif
  Local File =APPLI+".DEPREC" [DEP]
  Call ECR_TRACE("UTIIMM018: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM018

  Call ECR_TRACE("UTIIMM018: Process End on : "+APPLI,0) From GESECRAN
 End

########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM018

Trbegin [DEP]

For [F:CPY]
  For [F:CNX] Where CPY=[F:CPY]CPY
   For I_PLN=1 To [F:CNX]NBPLC
    If [F:CNX]PLNCAA(I_PLN-1) > 0

     For [F:DEP] Where ( CPY=[F:CPY]CPY & DPRPLN=[F:CNX]PLNCAA(I_PLN-1) and CNX=0 ) With Stability
       [F:DEP]CNX=[F:CNX]CNX
       Rewrite [F:DEP]
       If fstat
         GOK=0
         Call ECR_TRACE([F:CPY]CPY-" "-[F:DEP]AASREF-" "-mess([F:CNX]CNX,300,1)-num$(fstat),1) From GESECRAN
       Else
         Call ECR_TRACE([F:CPY]CPY-" "-[F:DEP]AASREF-" "-mess([F:CNX]CNX,300,1)-"MIS À JOUR",0) From GESECRAN
       Endif
    Next
    Endif
   Next I_PLN
  Next
 Next
# ---------------------
  If !GOK Then
    Goto AB_UTIIMM018
  Else
    Commit
  Endif
Return

$AB_UTIIMM018
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

#**
#* Sous-programme d'exécution de la moulinette
#* @param APPLI  Dossier à traiter
#*!
Subprog PATCH(APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","COMPANY","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","CONTEXT","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","DEPREC","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM018(APPLI)
End

#**
#* Pour exécution depuis dosmajx (validation dossier)
#* @param APPLI  Dossier à traiter
#*!
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If filinfo(filpath("FIL","COMPANY","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","CONTEXT","fde",APPLI),0) < 0 : End : Endif
  If filinfo(filpath("FIL","DEPREC","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM018(APPLI)
End
