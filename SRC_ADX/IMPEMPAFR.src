#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("EMPAFR") From GIMPOBJ
End

###################################################################################
$ACTION
  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "SAIMSK"    : Gosub SAIMSK
    When "VALID"     : Gosub VALID
  Endcase

Return

###################################################################################
$OUVRE
  Local Mask HRMAT0 [EMP0], HRMAT1  [EMP1], HRMAT2  [EMP2], HRMAT3  [EMP3], HRMAT5  [EMP5], HRMAT6  [EMP6]
  Local Mask HRMAT7 [EMP7], HRMAT10 [EMPA], HRMAT11 [EMPB], HRMAT12 [EMPC], HRMAT14 [EMPE]

  If clalev([F:ID])=0  : Local File EMPLOID    [ID]    : Endif
  If clalev([F:CHD])=0 : Local File EMPLOCHD   [CHD]   : Endif
  If clalev([F:EAF])=0 : Local File EMPLOIDAFR [EAF] : Endif
  If clalev([F:AD])=0  : Local File EMPLOAD    [AD]    : Endif
  If clalev([F:RIB])=0 : Local File EMPLORIB   [RIB]   : Endif
  If clalev([F:CPT])=0 : Local File EMPLOCPT   [CPT]   : Endif
  If clalev([F:HAB])=0 : Local File EMPLOHAB   [HAB]   : Endif

  nolign=0

Return

###################################################################################
$RAZCRE
  Raz [EMP0], [EMP1], [EMP2], [EMP3], [EMP4], [EMP5], [EMP6], [EMP7], [EMPA], [EMPB], [EMPC], [EMPE]

  nolign=0

Return

###################################################################################
$SAIMSK
Local Integer I
  Case IMPFIC
    When "ID"
      nolign=1
    #employee key
      [M:EMP0]=[F:ID]

      [M:EMP1]=[F:ID] : [M:EMP2]=[F:ID] : [M:EMP3]=[F:ID] : [M:EMP5]=[F:ID]
      [M:EMP6]=[F:ID] : [M:EMP7]=[F:ID] : [M:EMPA]=[F:ID] : [M:EMPB]=[F:ID]
      [M:EMPC]=[F:ID] : [M:EMPE]=[F:ID] : [M:EMP4]=[F:ID]

    When "CHD"
      [M:EMP1]=[F:CHD] : [M:EMP2]=[F:CHD] : [M:EMP3]=[F:CHD] : [M:EMP5]=[F:CHD]
      [M:EMP6]=[F:CHD] : [M:EMP7]=[F:CHD] : [M:EMPA]=[F:CHD] : [M:EMPB]=[F:CHD]
      [M:EMPC]=[F:CHD] : [M:EMPE]=[F:CHD] : [M:EMP4]=[F:CHD]
    When "EAF"
      [M:EMP1]=[F:EAF] : [M:EMP2]=[F:EAF] : [M:EMP3]=[F:EAF] : [M:EMP5]=[F:EAF]
      [M:EMP6]=[F:EAF] : [M:EMP7]=[F:EAF] : [M:EMPA]=[F:EAF] : [M:EMPB]=[F:EAF]
      [M:EMPC]=[F:EAF] : [M:EMPE]=[F:EAF] : [M:EMP4]=[F:EAF]
    When "AD"
      [M:EMP1]=[F:AD] : [M:EMP2]=[F:AD] : [M:EMP3]=[F:AD] : [M:EMP5]=[F:AD]
      [M:EMP6]=[F:AD] : [M:EMP7]=[F:AD] : [M:EMPA]=[F:AD] : [M:EMPB]=[F:AD]
      [M:EMPC]=[F:AD] : [M:EMPE]=[F:AD] : [M:EMP4]=[F:AD]
    When "RIB"
      [M:EMP1]=[F:RIB] : [M:EMP2]=[F:RIB] : [M:EMP3]=[F:RIB] : [M:EMP5]=[F:RIB]
      [M:EMP6]=[F:RIB] : [M:EMP7]=[F:RIB] : [M:EMPA]=[F:RIB] : [M:EMPB]=[F:RIB]
      [M:EMPC]=[F:RIB] : [M:EMPE]=[F:RIB] : [M:EMP4]=[F:RIB]
      [M:EMP7]NBRRIB=[F:RIB]NUMLIG
    When "CPT"
      [M:EMP1]=[F:CPT] : [M:EMP2]=[F:CPT] : [M:EMP3]=[F:CPT] : [M:EMP5]=[F:CPT]
      [M:EMP6]=[F:CPT] : [M:EMP7]=[F:CPT] : [M:EMPA]=[F:CPT] : [M:EMPB]=[F:CPT]
      [M:EMPC]=[F:CPT] : [M:EMPE]=[F:CPT] : [M:EMP4]=[F:CPT]
    When "HAB"
      [M:EMP1]=[F:HAB] : [M:EMP2]=[F:HAB] : [M:EMP3]=[F:HAB] : [M:EMP5]=[F:HAB]
      [M:EMP6]=[F:HAB] : [M:EMP7]=[F:HAB] : [M:EMPA]=[F:HAB] : [M:EMPB]=[F:HAB]
      [M:EMPC]=[F:HAB] : [M:EMPE]=[F:HAB] : [M:EMP4]=[F:HAB]
  Endcase

Return

###################################################################################
$VALID
  GOK=1
  If nolign=0 : Return : Endif
  If GOK=0 : GERREUR=1 : Return : Endif

  Call DEBTRANS From GLOCK

  Gosub TR1
  If GOK=0 : GERREUR=1 : Goto AB_TR1 : Endif

Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1
  Trbegin [F:ID], [F:CHD], [F:EAF], [F:AD], [F:RIB], [F:CPT], [F:HAB]


  Raz [F:ID]
  Read [F:ID]ID0=[M:EMP0]REFNUM
  [F:ID]=[M:EMP0] : [F:ID]=[M:EMP1] : [F:ID]=[M:EMP2] : [F:ID]=[M:EMP3] : [F:ID]=[M:EMP5]
  [F:ID]=[M:EMP6] : [F:ID]=[M:EMP7] : [F:ID]=[M:EMPA] : [F:ID]=[M:EMPB]
  [F:ID]=[M:EMPC] : [F:ID]=[M:EMPE] : [F:ID]=[M:EMP4]
  If fstat
    Write [F:ID]
  Else
    Rewrite [F:ID]
  Endif
  If fstat
    GOK=0 : Call FSTA("ID") From GLOCK : Return
  Endif


  Raz [F:CHD]
  Read [F:CHD]CHD0 = [M:EMP0]REFNUM
  [F:CHD]=[M:EMP0] : [F:CHD]=[M:EMP1] : [F:CHD]=[M:EMP2] : [F:CHD]=[M:EMP3] : [F:CHD]=[M:EMP5]
  [F:CHD]=[M:EMP6] : [F:CHD]=[M:EMP7] : [F:CHD]=[M:EMPA] : [F:CHD]=[M:EMPB]
  [F:CHD]=[M:EMPC] : [F:CHD]=[M:EMPE] : [F:CHD]=[M:EMP4]
  If fstat
    Write [F:CHD]
  Else
    Rewrite [F:CHD]
  Endif
  If fstat
    GOK=0 : Call FSTA("CHD") From GLOCK : Return
  Endif


  Raz [F:EAF]
  Read [F:EAF]EAF0 = [M:EMP0]REFNUM
  [F:EAF]=[M:EMP0] : [F:EAF]=[M:EMP1] : [F:EAF]=[M:EMP2] : [F:EAF]=[M:EMP3] : [F:EAF]=[M:EMP5]
  [F:EAF]=[M:EMP6] : [F:EAF]=[M:EMP7] : [F:EAF]=[M:EMPA] : [F:EAF]=[M:EMPB]
  [F:EAF]=[M:EMPC] : [F:EAF]=[M:EMPE] : [F:EAF]=[M:EMP4]
  If fstat
    Write [F:EAF]
  Else
    Rewrite [F:EAF]
  Endif
  If fstat
    GOK=0 : Call FSTA("EAF") From GLOCK : Return
  Endif


  Raz [F:AD]
  Read [F:AD]AD0 = [M:EMP0]REFNUM
  [F:AD]=[M:EMP0] : [F:AD]=[M:EMP1] : [F:AD]=[M:EMP2] : [F:AD]=[M:EMP3] : [F:AD]=[M:EMP5]
  [F:AD]=[M:EMP6] : [F:AD]=[M:EMP7] : [F:AD]=[M:EMPA] : [F:AD]=[M:EMPB]
  [F:AD]=[M:EMPC] : [F:AD]=[M:EMPE] : [F:AD]=[M:EMP4]
  If fstat
    Write [F:AD]
  Else
    Rewrite [F:AD]
  Endif
  If fstat
    GOK=0 : Call FSTA("AD") From GLOCK : Return
  Endif


  Raz [F:RIB]
  Read [F:RIB]RIB0 = [M:EMP0]REFNUM
  [F:RIB]=[M:EMP0] : [F:RIB]=[M:EMP1] : [F:RIB]=[M:EMP2] : [F:RIB]=[M:EMP3] : [F:RIB]=[M:EMP5]
  [F:RIB]=[M:EMP6] : [F:RIB]=[M:EMP7] : [F:RIB]=[M:EMPA] : [F:RIB]=[M:EMPB]
  [F:RIB]=[M:EMPC] : [F:RIB]=[M:EMPE] : [F:RIB]=[M:EMP4]
  [F:RIB]NUMLIG=[M:EMP7]NBRRIB
  If fstat
    Write [F:RIB]
  Else
    Rewrite [F:RIB]
  Endif
  If fstat
    GOK=0 : Call FSTA("RIB") From GLOCK : Return
  Endif


  Raz [F:CPT]
  Read [F:CPT]CPT0 = [M:EMP0]REFNUM
  [F:CPT]=[M:EMP0] : [F:CPT]=[M:EMP1] : [F:CPT]=[M:EMP2] : [F:CPT]=[M:EMP3] : [F:CPT]=[M:EMP5]
  [F:CPT]=[M:EMP6] : [F:CPT]=[M:EMP7] : [F:CPT]=[M:EMPA] : [F:CPT]=[M:EMPB]
  [F:CPT]=[M:EMPC] : [F:CPT]=[M:EMPE] : [F:CPT]=[M:EMP4]
  If fstat
    Write [F:CPT]
  Else
    Rewrite [F:CPT]
  Endif
  If fstat
    GOK=0 : Call FSTA("CPT") From GLOCK : Return
  Endif


  Raz [F:HAB]
  Read [F:HAB]HAB0 = [M:EMP0]REFNUM
  [F:HAB]=[M:EMP0] : [F:HAB]=[M:EMP1] : [F:HAB]=[M:EMP2] : [F:HAB]=[M:EMP3] : [F:HAB]=[M:EMP5]
  [F:HAB]=[M:EMP6] : [F:HAB]=[M:EMP7] : [F:HAB]=[M:EMPA] : [F:HAB]=[M:EMPB]
  [F:HAB]=[M:EMPC] : [F:HAB]=[M:EMPE] : [F:HAB]=[M:EMP4]
  If fstat
    Write [F:HAB]
  Else
    Rewrite [F:HAB]
  Endif
  If fstat
    GOK=0 : Call FSTA("HAB") From GLOCK : Return
  Endif


  Commit

Return


#########################
$AB_TR1
  Rollback
  Call TRACE(2,mess(17,107,1)) From SUBIMPOBJ

Return

