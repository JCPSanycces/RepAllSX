#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################
# Traitement STKSOR - Librairie des composants de sortie          V140 #
########################################################################
#
# GENSTOSORW  Traitement d'une ligne document pour allocation ou sortie
#             (Stockage dans écran de travail STOSORW)
# RAZSTOSORW  Remise à zéro de l'écran de travail STOSORW
#             Appelé dans les actions : LIENS, RAZCRE et RAZDUP
# DELSTOSORW  Suite à abandon de la saisie (Action ABANDON)
#             ou à suppression d'une ligne document qui était en cours
#             de création, suppression des allocations ou sorties
#             (Déstockage de l'écran de travail STOSORW)
# DIMSTOSORW  Diminution de la quantité stockée dans STOSORW
# SCASTOSORW  Exploitation d'une allocation d'une ligne document origine
#             pour alimentation écran de travail STOSORW
#             Ex: création d'un suivi d'OF suite à une pesée
# ALLSTOSORW  Exploitation des allocations d'une ligne document origine
#             pour alimentation écran de travail STOSORW
#             Ex: picking commande en gestion livraison
# STJSTOSORW  Exploitation des mouvements de stock d'une ligne de pièce
#             d'origine pour alimentation écran de travail STOSORW
#             Ex: picking réception en gestion retour fournisseur
# OUVSOR      Contrôle ouverture fenêtre saisie des sorties avec
#               - pas d'ouverture de la fenêtre
#                 si les éléments saisis dans la ligne de pièce sont
#                    suffisants pour déterminer le stock à sortir
#                    étiquette RECH_STOCK
#                 ou appel algo de détermination du stock à sortir
#                    sous-programme GENSTOSORW
#               - ouverture de la fenêtre
#                    exécution de l'action SAISTOSOR
# CTLPLFLOC   Contrôle qu'une ligne de stock en attente de rangement
#             est sortable (lot, sous-lot et série renseignés)
# CTLSORSER   Détermination et contrôle des no série à sortir à partir
#             d'un no début et d'une quantité saisie
# RECALLSTO   Recherche de la quantité allouée par une ligne de document
#             sur une ligne de stock
#--- TS 106217
# CTLECCVALMAJ   Contrôle de la version majeure par rapport
#                à la version saisie et à la règle de gestion
# CTLECCVAL      Contrôle de la version majeure saisie par rapport
#                à la règle de gestion
#---
#
########################################################################

########################################################################
# GENSTOSORW     Traitement d'une ligne document en cours de création
#                pour allocation ou sortie
#                Stockage dans écran de travail STOSORW après algo STOCKALG
#                Ne concerne que les nouvelles lignes
#                Attention :
#                Gestion dans [STOCK] d'une quantité en cours de traitement
#                dans les zones CUMWIPQTY et CUMWIPQTA
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LABR = Abréviation écran
#                LNOL = No ligne écran (nolign-1)
#                LNBL = Nombre lignes écran
#                -----------------------------------------------
#                Si suivi automatique (avec OF alloué)
#                ou livraison automatique de commandes
#                ou facturation automatique de commandes
#                ou génération bons de préparation
#                   LABR = ""
#                   LNOL = No ligne suivi ou autre numéro
#                   LNBL = 0
#                -----------------------------------------------
#                LRUP = Génération des ruptures (0=Non / 1=Oui)
#                LMAJ = Code MAJ ("C" = Mise à jour, "" = Simulation)
#
#            S : LRET = Code retour (0=OK / 1=Erreur)
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP    = Type mouvement(M.704)
#                                   mettre  0 si OF,EO,matière s-trait à livrer
#                                   mettre 17 si commande de prêt
#                                           4 si pour les autres commandes
#                [M:ALP]TRSCOD    = Code mouvement
#                [M:ALP]VCRTYP    = Type pièce (M.701)
#                [M:ALP]STOFCY    = Site stock
#                [M:ALP]ITMREF    = Article
#                [M:ALP]PCU       = Unité conditionnement
#                [M:ALP]PCUSTUCOE = Coefficient UC/US
#                [M:ALP]QTY       = Quantité
#                [M:ALP]TYPQTY    = Type de quantité : 1=US/2=UA (M.720)
#                                   dans ce cas, mettre toujours 2
#                [M:ALP]BESDAT    = Date besoin
#                [M:ALP]DLVDAT    = Date livraison
#                [M:ALP]ALLDAT    = Date fin réservation client
#                [M:ALP]STOLOC    = Emplacement poste de charge
#                                   à renseigner si OF ou suivi matière
#                [M:ALP]PECINTLOC = Prise en compte emp interne
#                [M:ALP]PECSCOLOC = Prise en compte emp sous-traitant
#                                   mettre 2 si s-traitance (OF/EO/Suivi matière)
#                [M:ALP]PECPLFLOC = Prise en compte emp en attente de rangement
#                [M:ALP]PECCUNLOK = Prise en compte stock en cours d'inventaire
#                                   mettre à 2 si allocation (commande ou OF)
#                [M:ALP]PECOWNER  = Propriétaire du stock
#                                   à renseigner si sortie du stock d'un tiers
#                                   (suivi OF: opération s-trait (chez s-trait))
#                                   (retour réception sous-traitance)
#                [M:ALP]FILSTO    = Filtre sur les lignes de stock
#                                   il être renseigné avec la classe [F:STO1]
#                [M:ALP]LOT       = Filtre lot ligne document
#                [M:ALP]LOC       = Filtre emplacement ligne document
#                [M:ALP]STA       = Filtre statut ligne document
#                                   sous la forme : "A1*,A20"
#                [M:ALP]AUZSST    = S-statuts autorisés sur emplacement à réappro
#                                   à renseigner si réappro zones de consommation
#                [M:ALP]LOCCAT    = Catégorie emplacement à réapprovisionner
#                                   à renseigner si réappro zones de consommation
#                [M:ALP]WRH       = Dépôt ligne document
#                [M:ALP]BPRNUM    = Client (à alimenter s'il y a un client)
#                #--- TS 106217
#                [M:ALP]ECCVALMAJ = Version majeure ligne document
#                -------------------------------------------------------
#                Si sortie à partir d'une pièce origine (Cde ou OF)
#                qui est allouée en global, alimentation de cette quantité
#                pour calcul correct du stock disponible
#                [M:ALP]ALLQTY     = Quantité déjà allouée en global
#                Attention à faire un Raz dans le cas contraire
#
########################################################################
# Sortie       : Ecran ALLPAR [ALP] (Bloc 3)
#                [M:ALP]ALLQTY     = Quantité traitée (selon [M:ALP]TYPQTY)
#                [M:ALP]ALLQTYSHT  = Quantité rupture (selon [M:ALP]TYPQTY)
#
########################################################################
Subprog GENSTOSORW(LABR,LNOL,LNBL,LRUP,LMAJ,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBL
Value    Integer LRUP
Value    Char    LMAJ
Variable Integer LRET

Local    Integer WTRSTYP
Local    Integer LFULLTAB
Local    Integer WTRBEGIN
Local    Integer I, J, K, L, M, WALISOW, WALL, WLOC, WRET
Local    Integer WE1, WE2, WE3, WT1, WT2, WT3, WNBL, WLOCFLT
Local    Char    WSHTWRH(GLONWRH)    : # Dépôt obligatoire si rupture
Local    Char    WSHTLOC(GLONLOC)    : # Emplacement obligatoire si rupture
Local    Char    WSHTLOCTYP(GLONTLO) : # Type emplacement obligatoire si rupture
Local    Char    LWRH(GLONWRH)       : # Dépôt
Local    Integer LSST                : # Sous-traitance 0/1
Local    Integer WSTA, WA, WQ, WR
Local    Decimal WSTUACTDIS, WALLQTY, WALLQTYSHT
Local    Decimal WORIQTYSTUACT  : # Bug 67404
Local    Decimal SVGQTY
Local    Char    WTRUCOD
Local    Integer LLIG           : # Lien avec ligne de document
Local    Integer LIND1          : # Indice pour récupérer sections ana document
                                  # 0 : section entête, nolign : section ligne
Local    Integer LIND2          : # Indice tableau sections analytiques
Local    Char    LANA(GLONCDE)  : # Code section analytique par défaut
Local    Decimal LSTOCOU
Local    Decimal LWIPQTY, LWIPQTA
Local    Char    WDEFLOC(GLONLOC), WDEFLOC2(GLONLOC), WDEFLOC3(GLONLOC)
Local    Char    WDEFLOCTYP(GLONTLO), WDEFLOCTYP2(GLONTLO), WDEFLOCTYP3(GLONTLO)
#--- Issue 110327
Local    Char    WNUMFIN(GLONSER), WSER(GLONSER)
Local    Decimal WQTE, WALPQTE
#---

Raz WDEFLOC, WDEFLOC2, WDEFLOC3
Raz WDEFLOCTYP, WDEFLOCTYP2, WDEFLOCTYP3
Raz WTRBEGIN, WALLQTY, WALLQTYSHT

# Lien avec ligne document non renseigné
#If LLIG=0
#   Call ERREUR(mess(375,199,1)) From GESECRAN
#   LRET=1 : Raz [M:ALP]ALLQTY : End
#Endif

Raz LRET

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITG]) =0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV]) =0  Local File ITMMVT     [ITV]   Endif
If clalev([F:TRU]) =0  Local File TABALLRUL  [TRU]   Endif
If clalev([F:SRU]) =0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STO1])=0  Local File STOCK      [STO1]  Endif
If clalev([F:STC]) =0  Local File STOLOC     [STC]   Endif
If clalev([F:SWW]) =0  Local File STOWIPW    [SWW]   Endif
#--- TS 106217
If clalev([F:ECS]) =0  Local File ECCSTA     [ECS]   Endif
#--- Issue 110327
If clalev([F:STS]) =0  Local File STOSER     [STS]   Endif
If clalev([F:STS1])=0  Local File STOSER     [STS1]  Endif
If clalev([F:SSW]) =0  Local File STOSERW    [SSW]   Endif
#---

If GWRHACT=2
   If clalev([F:ITW]) =0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH]) =0  Local File WAREHOUSE [WRH] Endif
Endif

If dim([M:SOW]WSTOCOU) <= 0
   GOK=0  : Call ERREUR (mess(339,199,1)-'SOW') From GESECRAN
   LRET=1 : Raz [M:ALP]ALLQTY : End
Endif

# Si suivi auto (avec OF alloué), livraison auto ou facturation auto de cdes
If LABR = ""
   LLIG = LNOL
Else
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
   Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
   If LRET<>0 Raz [M:ALP]ALLQTY : End Endif
Endif

#--- Dem 86487
GPOINT="MOD_SORPAR" : Gosub ENTREE From EXEFNC

# Lecture des tables article
Call LECITM([M:ALP]STOFCY,[M:ALP]ITMREF,"",0,[M:ALP]WRH,LRET) From STKLIB
If LRET<>0 : GOK=0 : Raz [M:ALP]ALLQTY : End : Endif

#--- Issue 110327
If [F:ITM]SERMGTCOD>1 & fix([M:ALP]QTY)<>[M:ALP]QTY
   Call ERREUR(mess(470,197,1)) From GESECRAN
   GOK=0 : LRET=1 : End
Endif
#---

# Récupération de la règle d'allocation
#--- Issue X3-4501 ajout de VCRTYP=40
Case [M:ALP]VCRTYP
 When 2,40           : # Commande
                       WTRUCOD = [F:ITG]ALLRULORD
 When 3,4,5,8        : # Livraison sous-traitance
                       If [M:ALP]TRSTYP=20
                          WTRUCOD = [F:ITG]ALLRULSCO
                       # Préparation, Livraison, Facture, Retour fou
                       Else
                          WTRUCOD = [F:ITG]ALLRULSHI
                       Endif
 When 6              : # Réception ( conso matières sous-traitance)
                       WTRUCOD = [F:ITG]ALLRULSCC
 When 10             : # OF (opération de sous-traitance)
                       If [M:ALP]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # OF (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMAT
                       Endif
 When 12             : # Suivi matière (opération de sous-traitance)
                       If [M:ALP]PECSCOLOC=2
                          WTRUCOD = [F:ITG]ALLRULSCC
                       # Suivi matière (interne)
                       Else
                          WTRUCOD = [F:ITG]ALLRULMFG
                       Endif
 When 20,29,31,32,33 : # Sortie diverse, Changement de stock,
                       # Assemblage, Désassemblage, Demande de service
                       WTRUCOD = [F:ITG]ALLRULTRF
 When 34             : # Réappro zones de consommation
                       If [M:ALP]LOCCAT=4
                          WTRUCOD = [F:ITG]ALLRULSCO
                       Else
                          WTRUCOD = [F:ITG]ALLRULTRF
                       Endif
 When 36             : # Ordre sous-traitance
                       WTRUCOD = [F:ITG]ALLRULSCC
 When Default
Endcase

Raz [F:TRU]
If WTRUCOD<>""
   # Lecture règle d'allocation
   Read [TRU]TRU0=WTRUCOD
   If fstat
      GOK=0  : Call RSTA("TRU",WTRUCOD) From GLOCK
      LRET=1 : Raz [M:ALP]ALLQTY : End
   Endif
Endif

Raz [M:ALP]ALLQTYSHT
If [M:ALP]ALLDAT=[0/0/0]
   [M:ALP]ALLDAT=[31/12/2999]
Endif

WTRSTYP = [M:ALP]TRSTYP

#--- Issue X3-4501 ajout de VCRTYP=40
If find([M:ALP]VCRTYP,2,10,36,40)
   # Si commande                      --> type mvt = livraison ou livraison prêt
   # Si OF                            --> type mvt = sortie OF ou s-traitance
   # Si ordre s-traitance             --> type mvt = sortie s-traitance
   Case [M:ALP]VCRTYP
    When  2 : If WTRSTYP=0 : WTRSTYP=4 : Endif
    When 10 : If [M:ALP]PECSCOLOC=2
                 WTRSTYP = 29
              Else
                 WTRSTYP = 6
              Endif
    When 36 : WTRSTYP = 29
    When 40 : WTRSTYP = 4
   Endcase
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,WTRSTYP,[M:ALP]TRSCOD,"",LRET) From STKLIB
If LRET<>0 : GOK=0 : Raz [M:ALP]ALLQTY : End : Endif

# Statuts autorisés par la règle de gestion
If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
WSTA = WA+2*WQ+4*WR

Raz WLOC
# Prise en compte emplacement attente rangement
If [M:ALP]PECPLFLOC=2 WLOC+=1  Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WLOC+=4  Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WLOC=WLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WLOC,WSTA,[M:ALP]PECOWNER,WSTUACTDIS) From STKLIB
# On rajoute l'allouée global (limité à la qté à traiter)
WSTUACTDIS += min([M:ALP]QTY,[M:ALP]ALLQTY)

#--- Bug 61354
#K = [M:SOW]NBLIG

SVGQTY = [M:ALP]QTY
# Si pas de stock disponible,récupération dépôt et emplacement exclusif
# et génération d'une rupture
If WSTUACTDIS <=0

   # --> récupération du dépôt exclusif
   If GWRHACT=2
      # Dépôt ligne document
      If [M:ALP]WRH<>""
         # Alimentation dépôt rupture
         WSHTWRH=[M:ALP]WRH
      # Filtre sur dépôt article-site si exclusif
      Else
         LSST=0
         # Sous-traitance
         If (find([M:ALP]VCRTYP,10,12) & [M:ALP]PECSCOLOC=2)
&          |(find([M:ALP]VCRTYP,3,4)   & [M:ALP]TRSTYP=20)
&          |([M:ALP]VCRTYP=34          & [M:ALP]LOCCAT=4)
            LSST=1
         Endif
         Call WRHAUTO([M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]VCRTYP,LSST,LWRH)
&            From STKWRH
         If !find(LWRH,"","*")
            # Alimentation dépôt rupture si pas de joker
            If !instr(1,LWRH,'*') & !instr(1,LWRH,'?')
&            & !instr(1,LWRH,'!') & !instr(1,LWRH,'#')
               WSHTWRH    = LWRH
               [M:ALP]WRH = LWRH
            Endif
         Endif
      Endif
   Endif

   # --> récupération de l'emplacement (ou type) exclusif
   Raz [M:ALP]LOC, [M:ALP]LOCTYP
   # Si règle d'allocations
   If WTRUCOD<>""

      # Récupération types emplacement ou emplacement par défaut
      # de l'article-site pour le type mouvement
      #--- Issue 110327
      #Gosub ALI_DEFLOC From STKALL
      Gosub ALI_DEFLOC From STKALF
      #---

      # Détermination du nombre de ligne de la règle
      I = find(0,[F:TRU]LOCFLT(0..dim([F:TRU]LOCFLT)-1))
      If I=0
         WNBL = dim([F:TRU]LOCFLT)
      Else
         WNBL = I-1
      Endif
      If min([F:TRU]LOCFLT(0..WNBL-1))>1
         # Si OF / EO ou sortie OF / EO et emplacement local renseigné
         If find([M:ALP]VCRTYP,10,36) | find([M:ALP]TRSTYP,6,29)
            If [M:ALP]STOLOC<>""
               # Si emp local exclusif sans joker on le stocke pour les ruptures
               If max([F:TRU]LOCFLT)=2
&               & !instr(1,[M:ALP]STOLOC,'*') & !instr(1,[M:ALP]STOLOC,'?')
&               & !instr(1,[M:ALP]STOLOC,'!') & !instr(1,[M:ALP]STOLOC,'#')
                  [M:ALP]LOC=[M:ALP]STOLOC
               Endif
               # Emp local dans les règles, mais non exclusif --> c'est fini
               # Issue 120913 - 2017-01-19 by MAE : Return à la place d'un end
               #If min([F:TRU]LOCFLT)=2 Return Endif
               If min([F:TRU]LOCFLT)=2 End Endif
            Endif
         Endif
         If [M:ALP]LOC=""
            # I,J et K contiennent la 1ère position des catégories emp 1,2 et 3
            # dans le tableau des règles d'allocation (0 si absent)
            I = find(3,[F:TRU]LOCFLT(0..WNBL-1))
            J = find(4,[F:TRU]LOCFLT(0..WNBL-1))
            K = find(5,[F:TRU]LOCFLT(0..WNBL-1))
            # WE1,WE2 et WE3 contiennent 1 si emp par défaut 1,2 et 3
            Raz WE1, WE2, WE3
            If WDEFLOC <>"" & !instr(1,WDEFLOC,'*')  & !instr(1,WDEFLOC,'?')
&                           & !instr(1,WDEFLOC,'!')  & !instr(1,WDEFLOC,'#')
               WE1=1
            Endif
            If WDEFLOC2<>"" & !instr(1,WDEFLOC2,'*') & !instr(1,WDEFLOC2,'?')
&                           & !instr(1,WDEFLOC2,'!') & !instr(1,WDEFLOC2,'#')
               WE2=1
            Endif
            If WDEFLOC3<>"" & !instr(1,WDEFLOC3,'*') & !instr(1,WDEFLOC3,'?')
&                           & !instr(1,WDEFLOC3,'!') & !instr(1,WDEFLOC3,'#')
               WE3=1
            Endif
            # WT1,WT2 et WT3 contiennent 1 si type emp par défaut 1,2 et 3
            Raz WT1, WT2, WT3
            If WDEFLOCTYP <>"" & !instr(1,WDEFLOCTYP,'*') &!instr(1,WDEFLOCTYP,'?')
&                              & !instr(1,WDEFLOCTYP,'!') &!instr(1,WDEFLOCTYP,'#')
               WT1=1
            Endif
            If WDEFLOCTYP2<>"" & !instr(1,WDEFLOCTYP2,'*')&!instr(1,WDEFLOCTYP2,'?')
&                              & !instr(1,WDEFLOCTYP2,'!')&!instr(1,WDEFLOCTYP2,'#')
               WT2=1
            Endif
            If WDEFLOCTYP3<>"" & !instr(1,WDEFLOCTYP3,'*')&!instr(1,WDEFLOCTYP3,'?')
&                              & !instr(1,WDEFLOCTYP3,'!')&!instr(1,WDEFLOCTYP3,'#')
               WT3=1
            Endif

            # WLOCFLT contient la valeur max des catégories d'emp (3,4 ou 5)
            WLOCFLT = max([F:TRU]LOCFLT)

            Raz WSHTLOC, WSHTLOCTYP

            # Exploitation des règles d'allocation pour déterminer
            # le type ou l'emplacement de rupture
            #--- Issue 110327
            #Gosub ALI_LOCATION From STKALL
            Gosub ALI_LOCATION From STKALF
            #---

            [M:ALP]LOC   =WSHTLOC
            [M:ALP]LOCTYP=WSHTLOCTYP
         Endif
      Endif
   Endif
   #--- Bug 61354
   K = [M:SOW]NBLIG
   Goto GEN_STOSORW_SUI
Endif

#--- Bug 61354
K = [M:SOW]NBLIG

# Si quantité disponible < quantité à allouer, on appelle l'algo avec
# comme quantité à allouer, la quantité disponible
If WSTUACTDIS<[M:ALP]QTY [M:ALP]QTY=WSTUACTDIS Endif

# Pour ne pas tenir compte des stocks avec demande d'analyse
[M:ALP]PECQLYCTL=1

# Appel à l'algorithme d'allocation
Call STOCKALG(LRUP,WTRUCOD,LFULLTAB,LRET) From STKALL
If LRET<>0 & GMESSAGE<>""
   Call ERREUR(GMESSAGE) From GESECRAN
   Raz [M:ALP]ALLQTY : End
Endif

# Si simulation, on se tire
If LMAJ="" End Endif

# Peut on rajouter les lignes à traiter dans l'écran de travail
If dim([M:SOW]WSTOCOU)<=0 | [M:SOW]NBLIG+[M:ALP]NBLIG >= dim([M:SOW]WSTOCOU)
   Call MESSAGE(mess(352,199,1)-mess(353,199,1)) From GESECRAN
   LRET=1 : Raz [M:ALP]ALLQTY : End
Endif

# Si insertion d'une ligne dans l'écran de la pièce,
# incrémentation des no lignes écran >= à ce no ligne
#If max([M:SOW]NUMLIG)<LLIG
#   For I=0 To [M:SOW]NBLIG-1
#      If [M:SOW]NUMLIG(I)>=LLIG [M:SOW]NUMLIG(I)+=1 Endif
#   Next I
#Endif

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

# Alimentation de l'écran de travail STOSORW [SOW]
For I=0 To [M:ALP]NBLIG-1
   J=[M:ALP]NLIG(I)
   Break ([M:ALP]WFLG(J)=0)
   If [M:ALP]WQTYSTUACT(J)<>0
      Readlock [STO1]STO0=[M:ALP]STOFCY;[M:ALP]WSTOCOU(J)
      If !fstat
         #--- Bug 67404
         #[F:STO1]CUMWIPQTY += [M:ALP]WQTYSTU(J)
         #[F:STO1]CUMWIPQTA += [M:ALP]WQTYSTUACT(J)
         # Création quantité en cours de traitement
         #LSTOCOU = [F:STO1]STOCOU
         #LWIPQTY = [M:ALP]WQTYSTU(J)
         #LWIPQTA = [M:ALP]WQTYSTUACT(J)
         #Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         #Rewrite [STO1]
         #If fstat
         #   Call FSTA("STO1") From GLOCK
         #Else
         #   # Si la ligne de stock pour cette ligne de document est déjà dans
         #   # STOSORW, il faut agréger (cas de l'augmentation qté ligne document)
         #   WALISOW=0
         #   If [M:SOW]NBLIG>0
         #      L=0
         #      While L<[M:SOW]NBLIG
         #         M=find(LLIG,[M:SOW]WSTOSEQ(L..[M:SOW]NBLIG-1))
         #         If M>0
         #            # On agrège
         #            If [M:SOW]WSTOCOU(L+M-1)=[M:ALP]WSTOCOU(J)
         #               [M:SOW]WQTYSTU(L+M-1)    += [M:ALP]WQTYSTU(J)
         #               [M:SOW]WQTYSTUACT(L+M-1) += [M:ALP]WQTYSTUACT(J)
         #               WALISOW = 1
         #               L = [M:SOW]NBLIG
         #            # On continue la recherche
         #            Else
         #               L += M
         #            Endif
         #         # Elle n'est pas déjà là
         #         Else
         #            L = [M:SOW]NBLIG
         #         Endif
         #      Wend
         #   Endif
         #   If WALISOW=0
         #      # On alimente STOSORW
         #      [M:SOW]WSTOSEQ(K)    = LLIG
         #      [M:SOW]WSTOCOU(K)    = [M:ALP]WSTOCOU(J)
         #      [M:SOW]WQTYSTU(K)    = [M:ALP]WQTYSTU(J)
         #      [M:SOW]WQTYSTUACT(K) = [M:ALP]WQTYSTUACT(J)
         #      Raz [M:SOW]WALLSTU(K),[M:SOW]WALLSTUACT(K)
         #      Raz [M:SOW]WLOT(K),[M:SOW]WSLO(K),[M:SOW]WLOC(K),[M:SOW]WWRH(K)
         #      Raz [M:SOW]WSTA(K),[M:SOW]WSERNUM(K),[M:SOW]WPLFSTO(K)
         #   Endif

         # Si la ligne de stock pour cette ligne de document est déjà dans
         # STOSORW, il faut agréger (cas de l'augmentation qté ligne document)
         # sauf si article avec gestion série en global: #--- Issue 110327
         WALISOW=0
         WORIQTYSTUACT=0
         #--- Issue 110327
         #If [M:SOW]NBLIG>0
         If [M:SOW]NBLIG>0 & [F:ITM]SERMGTCOD<4
         #---
            L=0
            While L<[M:SOW]NBLIG
               M=find(LLIG,[M:SOW]WSTOSEQ(L..[M:SOW]NBLIG-1))
               If M>0
                  # On agrège
                  If [M:SOW]WSTOCOU(L+M-1)=[M:ALP]WSTOCOU(J)
                     #--- Bug X3-74534
                     #WORIQTYSTUACT             = [M:SOW]WQTYSTUACT(L+M-1)
                     WORIQTYSTUACT             = [M:SOW]WQTYSTUACT(L+M-1) - [M:SOW]WALLSTUACT(L+M-1)
                     #---
                     [M:SOW]WQTYSTU(L+M-1)    += [M:ALP]WQTYSTU(J)
                     [M:SOW]WQTYSTUACT(L+M-1) += [M:ALP]WQTYSTUACT(J)
                     WALISOW = 1
                     L = [M:SOW]NBLIG
                  # On continue la recherche
                  Else
                     L += M
                  Endif
               # Elle n'est pas déjà là
               Else
                  L = [M:SOW]NBLIG
               Endif
            Wend
         Endif
         If WALISOW=0
            #--- Issue 110327
            # Détermination des no séries à sortir
            If [F:ITM]SERMGTCOD=4
               WQTE    = [M:ALP]WQTYSTU(J)
               WALPQTE = 0
               WSER    = ""
               #WFIN=0
               # Boucle pour traiter les séquences de no série
               $GEN_STOSERW
               Filter [STS] Where ITMREF=[M:ALP]ITMREF & STOCOU=[M:ALP]WSTOCOU(J) &SERNUM>WSER & SDHNUM=""
&                           Order By Key STS3
               Read [STS]First
               If !fstat
                  While func STKLIB.REC_STOSERW([M:ALP]ITMREF,[F:STS]SERNUM)<>0
                     Read [STS]Next
                     If fstat
                        [F:STS]SERNUM="" : Break
                     Endif
                  Wend
                  If [F:STS]SERNUM<>""
                     # On alimente STOSORW
                     [M:SOW]WSERNUM(K)=[F:STS]SERNUM
                     [M:SOW]WSTOSEQ(K)    = LLIG
                     [M:SOW]WSTOCOU(K)    = [M:ALP]WSTOCOU(J)
                     [M:SOW]WQTYSTU(K)    = 1
                     [M:SOW]WQTYSTUACT(K) = 1
                     Raz [M:SOW]WALLSTU(K),[M:SOW]WALLSTUACT(K)
                     Raz [M:SOW]WLOT(K),[M:SOW]WSLO(K),[M:SOW]WLOC(K),[M:SOW]WWRH(K)
                     Raz [M:SOW]WSTA(K),[M:SOW]WPLFSTO(K),[M:SOW]WECCVALMAJ(K)
                     # Transfert zones de la ligne de document vers l'écran STOSORW
                     # Dans le PE, on alimente avec I --> bidouille pour affecter K
                     SVG_I=I : I=K
                     GPOINT="DOC_SOW"
                     Gosub ENTREE From EXEFNC
                     I=SVG_I
                     # La ligne de stock en attente de rangement est-elle complète?
                     If [F:STO1]LOCCAT=2
                        Raz WRET
                        Call CTLPLFLOC([M:ALP]ITMREF,"[F:STO1]",WRET)
                        If WRET<>0 [M:SOW]WPLFSTO(K)=1 Endif
                     Endif

                     Raz WRET
                     WSER    =[F:STS]SERNUM
                     WQTE   -=1
                     WALPQTE+=1
                     # Traitement des no série d'une séquence
                     While WQTE>0
                        Call PLUS_UN(WSER,WNUMFIN,WRET) From STKLIB
                        If WRET=0
                           Read [STS1]STS0=[M:ALP]ITMREF;WNUMFIN
                           If fstat | [F:STS1]STOCOU<>[M:ALP]WSTOCOU(J)
&                           | [F:STS1]ISSDAT<>[0/0/0] | [F:STS1]SDHNUM<>""
                              WNUMFIN=""
                           Elsif func STKLIB.REC_STOSERW([M:ALP]ITMREF,WNUMFIN)<>0
                              WNUMFIN=""
                           Endif
                        Else
                           WNUMFIN=""
                        Endif
                        If WNUMFIN="" Break Endif
                        [M:SOW]WQTYSTU(K)   +=1
                        [M:SOW]WQTYSTUACT(K)+=1
                        WQTE   -=1
                        WALPQTE+=1
                        WSER    =WNUMFIN
                     Wend

                     # Blocage des no série en cours de traitement
                     Call CRE_STOSERW([M:ALP]ITMREF,[M:SOW]WSERNUM(K),[M:SOW]WQTYSTU(K),WRET) From STKLIB
                     If WRET<>0
                       # On efface le contenu de la ligne [SOW]
                       WQTE   +=[M:SOW]WQTYSTU(K)
                       WALPQTE-=[M:SOW]WQTYSTU(K)
                       Raz [M:SOW]WSERNUM(K),[M:SOW]WSTOSEQ(K),[M:SOW]WSTOCOU(K)
                       Raz [M:SOW]WQTYSTU(K),[M:SOW]WQTYSTUACT(K)
                     Else
                       [F:STO1]CUMWIPQTY += [M:SOW]WQTYSTU(K)
                       [F:STO1]CUMWIPQTA += [M:SOW]WQTYSTUACT(K)
                       LSTOCOU = [F:STO1]STOCOU
                       LWIPQTY = [M:SOW]WQTYSTU(K)
                       LWIPQTA = [M:SOW]WQTYSTUACT(K)
                       # Création quantité en cours de traitement
                       Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
                       Rewrite [STO1]
                       If fstat
                         Call FSTA("STO1") From GLOCK
                       Endif
                       WALLQTY += [M:SOW]WQTYSTUACT(K)
                       # Passage à la ligne [SOW] suivante
                       K+=1
                     Endif

                     # Il reste une quantité à traiter pour les no série
                     If WQTE>0
                       Filter [STS]
                       Goto GEN_STOSERW
                     Endif
                  Endif
               Endif
               [M:ALP]WQTYSTUACT(J) = WALPQTE
               Filter [STS]
            Else
            #--- End issue 110327

               # On alimente STOSORW
               [M:SOW]WSTOSEQ(K)    = LLIG
               [M:SOW]WSTOCOU(K)    = [M:ALP]WSTOCOU(J)
               [M:SOW]WQTYSTU(K)    = [M:ALP]WQTYSTU(J)
               [M:SOW]WQTYSTUACT(K) = [M:ALP]WQTYSTUACT(J)
               Raz [M:SOW]WALLSTU(K),[M:SOW]WALLSTUACT(K)
               Raz [M:SOW]WLOT(K),[M:SOW]WSLO(K),[M:SOW]WLOC(K),[M:SOW]WWRH(K)
               Raz [M:SOW]WSTA(K),[M:SOW]WSERNUM(K),[M:SOW]WPLFSTO(K)
               #--- TS 106217
               Raz [M:SOW]WECCVALMAJ(K)
               #--- Bug 69442
               # Transfert zones de la ligne de document vers l'écran STOSORW
               # Dans le PE, on alimente avec I --> bidouille pour affecter K
               SVG_I=I : I=K
               GPOINT="DOC_SOW"
               Gosub ENTREE From EXEFNC
               I=SVG_I
               #--- Issue 110327
               # La ligne de stock en attente de rangement est-elle complète?
               If [F:STO1]LOCCAT=2
                  Raz WRET
                  Call CTLPLFLOC([M:ALP]ITMREF,"[F:STO1]",WRET)
                  If WRET<>0 [M:SOW]WPLFSTO(K)=1 Endif
               Endif
               K += 1
            Endif
            #--- End issue 110327
         Endif

         #--- Issue 110327
         # Mise à jour des quantité en cours de traitement
         # Si article avec no série géré en E/S global, la maj a déjà été faite
         If [F:ITM]SERMGTCOD<4
         #---
            [F:STO1]CUMWIPQTY += [M:ALP]WQTYSTU(J)
            [F:STO1]CUMWIPQTA += [M:ALP]WQTYSTUACT(J)

            LSTOCOU = [F:STO1]STOCOU
            LWIPQTY = [M:ALP]WQTYSTU(J)
            LWIPQTA = [M:ALP]WQTYSTUACT(J)

            # Il existait déjà un STOSORW et donc un STOWIPW pour ce stock
            #--- Bug X3-74534
            #If WALISOW=1
            If WALISOW=1 & WORIQTYSTUACT<>0
            #---
               # Incrémentation quantité en cours de traitement
               Call ADD_STOWIPW(LSTOCOU,WORIQTYSTUACT,LWIPQTY,LWIPQTA) From STKLIB
            Else
               # Création quantité en cours de traitement
               Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
            Endif
            Rewrite [STO1]
            If fstat
               Call FSTA("STO1") From GLOCK
            Endif
            #--- End bug 67404

            WALLQTY += [M:ALP]WQTYSTUACT(J)

            #--- Issue 110327
            #If WALISOW=0
            #   # La ligne de stock en attente de rangement est-elle complète?
            #   If [F:STO1]LOCCAT=2
            #      Raz WRET
            #      Call CTLPLFLOC([M:ALP]ITMREF,"[F:STO1]",WRET)
            #      If WRET<>0 [M:SOW]WPLFSTO(K)=1 Endif
            #   Endif
            #   K += 1
            #Endif
            #Endif          : # Bug 67404
         #--- Issue 110327
         Endif
         #---
      Endif
   Endif
Next I

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

$GEN_STOSORW_SUI
# Restitution de la quantité à allouer
[M:ALP]QTY = SVGQTY
# Détermination de la quantité en rupture
WALLQTYSHT = [M:ALP]QTY - WALLQTY

# Pas de génération de ruptures
If LRUP<>1 WALLQTYSHT=0 Endif

# Création d'une ligne de rupture si nécessaire
If WALLQTYSHT>0
   [M:SOW]WSTOSEQ(K)    = LLIG
   [M:SOW]WSTOCOU(K)    = 0
   [M:SOW]WQTYSTUACT(K) = WALLQTYSHT
   # Dans ce cas, on alimente la qté US avec la qté UA
   [M:SOW]WQTYSTU(K)    = [M:SOW]WQTYSTUACT(K)
   [M:SOW]WALLSTU(K)    = 0
   [M:SOW]WALLSTUACT(K) = 0
   [M:SOW]WLOT(K)       = [M:ALP]LOT
   [M:SOW]WSLO(K)       = ""
   [M:SOW]WWRH(K)       = [M:ALP]WRH
   [M:SOW]WLOC(K)       = [M:ALP]LOC
   [M:SOW]WSTA(K)       = ""
   [M:SOW]WSERNUM(K)    = ""
   [M:SOW]WPLFSTO(K)    = 0
   #Raz WSHTACT
   #--- TS 106217
   #--- Si version exclusive et renseignée, pas de modification
   If [M:ALP]ECCVALMAJ<>"" & [F:SRU]ORDVER=2
      [M:SOW]WECCVALMAJ(K) = [M:ALP]ECCVALMAJ
   Endif
   #---

   GPOINT="ALI_SHTSOW"
   Gosub ENTREE From EXEFNC

   K += 1
Endif

[M:ALP]ALLQTY    = WALLQTY
[M:ALP]ALLQTYSHT = WALLQTYSHT

[M:SOW]NBLIG = K

# Récupération des sections analytiques : # enlevés suite bug 25687
#If LABR<>""
#   Case LABR
#    When "SDH1"               : LANA="STKLIV"
#    When "SIH4"               : LANA="STKFAC"
#    When "PNH1"               : LANA="STKPRT"
#    When "SMO1","DBY0","BBY1" : LANA="STJSOR"
#    When "MTK3","MBM"         : LANA="STKSOF"
#    When "SRE9","ITN8"        : LANA="STKHDT"
#   Endcase
#   Call STKINISEC (LLIG,LANA,"SOW") From STKECR
#Endif

# Toutes les stock n'ont pu être chargées (code activité SLS insuffisant)
# Des lignes de stock n'ont peut être pas été traitées
# ou des manquants ont pu être générés à tord
If LFULLTAB=1 & [M:ALP]ALLQTY<[M:ALP]QTY
   Call MESSAGE(mess(340,199,1)+"\"+mess(468,199,1)) From GESECRAN
Endif

End

########################################################################
$AB_TRT
Rollback
Return

########################################################################
# RAZSTOSORW     Remise à zéro de l'écran de travail STOSORW
#                Appelé dans les actions : LIENS, RAZCRE et RAZDUP
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
Subprog RAZSTOSORW

# Si tunnel depuis plan de rangement, pas de raz du masque
If GFONCTION1="FUNSSL" & GFONCTION<>"FUNSSL" End Endif

Raz [M:SOW]

End

########################################################################
# DELSTOSORW     Suite à suppression d'une ligne document qui était en
#                cours de création, suppression des allocations ou sorties
#                stockées dans écran de travail STOSORW
#                Attention :
#                Dégestion dans [STOCK] d'une quantité en cours de traitement
#                dans les zones CUMWIPQTY et CUMWIPQTA
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LLIG  = nolign-1  (indice ligne document début)
#                        Si LLIG=-1 traitement de toutes les lignes
#                LLIG1 = nolign1-1 (indice ligne document fin)
#                LABR  = abréviation masque origine
#
#                LFCY  = Site de stockage
#            S : LRET  = Code retour (0=OK / 1=Erreur)
#                Attention si erreur, ne pas supprimer la ligne document
#
########################################################################
Subprog DELSTOSORW(LLIG,LLIG1,LABR,LFCY,LRET)
Value    Integer LLIG
Value    Integer LLIG1
Value    Char    LABR
Value    Char    LFCY
Variable Integer LRET

Local Integer WTRBEGIN
Local Integer I
Local Decimal LSTOCOU
Local Decimal LWIPQTY
Raz WTRBEGIN, LRET

# Si tunnel depuis plan de rangement, pas de raz du masque
If GFONCTION1="FUNSSL" & GFONCTION<>"FUNSSL" End Endif

If [M:SOW]NBLIG=0 End Endif

#--- Issue 110327
If clalev([F:ITM]) =0  Local File ITMMASTER [ITM] Endif
If clalev([F:STO1])=0  Local File STOCK   [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW [SWW]   Endif

# On fait 2 boucles pour ne pas déphaser les qtes en cours de traitement
# de la table [STO1] et l'écran de stockage des lignes à sortir en cas de
# problème sur la table stock

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

For I=0 To [M:SOW]NBLIG-1
   If LLIG=-1 | evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG..LLIG1))")
      If [M:SOW]WSTOCOU(I)<>0
         # Il y a une quantité en cours de traitement
         If [M:SOW]WQTYSTUACT(I)>[M:SOW]WALLSTUACT(I)
            Readlock [STO1]STO0=LFCY;[M:SOW]WSTOCOU(I)
            If fstat
               GOK=0
               Call RSTA("STO1",LFCY-num$([M:SOW]WSTOCOU(I))) From GLOCK
               LRET=1 : Break
            Else
               [F:STO1]CUMWIPQTY -= max(0,[M:SOW]WQTYSTU(I)-[M:SOW]WALLSTU(I))
               [F:STO1]CUMWIPQTA -= max(0,[M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I))
               # Dans le cas où l'on serait passé en négatif
               [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY)
               [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA)

               # Suppression qté en cours de traitement
               LSTOCOU = [F:STO1]STOCOU
               LWIPQTY = [M:SOW]WQTYSTU(I)-[M:SOW]WALLSTU(I)
               Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB

               Rewrite [STO1]
               If fstat
                  GOK=0  : Call FSTA("STO1") From GLOCK
                  LRET=1 : Break
               Endif
            Endif
         #--- Issue 110327
         Else
            Read [STO1]STO0=LFCY;[M:SOW]WSTOCOU(I)
            If fstat
               GOK=0
               Call RSTA("STO1",LFCY-num$([M:SOW]WSTOCOU(I))) From GLOCK
               LRET=1 : Break
            Endif
         #---
         Endif
         #--- Issue 110327
         # Suppression no série en cours de traitement
         If [F:ITM]ITMREF<>[F:STO1]ITMREF
            Read [ITM]ITM0=[F:STO1]ITMREF
            If fstat
               GOK=0  : Call FSTA("ITM") From GLOCK
               LRET=1 : Break
            Endif
         Endif
         If [F:ITM]SERMGTCOD=4 & [M:SOW]WSERNUM(I)<>""
            Call DEL_STOSERW([F:ITM]ITMREF,[M:SOW]WSERNUM(I),[M:SOW]WQTYSTU(I),LRET) From STKLIB
            If LRET<>0 : GOK=0 : Break : Endif
         Endif
         #---
      Endif
   Endif
Next I

#--- Issue 110327
#If GOK=0 Rollback : End Endif
# On a ouvert une transaction
#If WTRBEGIN=1
#   Commit
#   Raz WTRBEGIN
#Endif
# On a ouvert une transaction
If WTRBEGIN=1
   If GOK=0
      Rollback
   Else
     Commit
     Raz WTRBEGIN
   Endif
Endif
#---

# Si traitement de toutes les lignes (abandon de la saisie document)
If LLIG=-1
   Raz [M:SOW] : End
Endif

For I=0 To [M:SOW]NBLIG-1
   If evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG..LLIG1))")
      Raz [M:SOW]WSTOSEQ(I),[M:SOW]WSTOCOU(I)
      Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I),[M:SOW]WWRH(I)
      Raz [M:SOW]WSTA(I),[M:SOW]WSERNUM(I),[M:SOW]WPLFSTO(I)
      Raz [M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)
      Raz [M:SOW]WALLSTU(I),[M:SOW]WALLSTUACT(I)
      #--- TS 106217
      Raz [M:SOW]WECCVALMAJ(I)
   Endif
Next I
For I=0 To [M:SOW]NBLIG2-1
   If evalue("find([M:SOW]WSTOSEQ2(I),[M:"+LABR+"]WSTOSEQ(LLIG..LLIG1))")
      Raz [M:SOW]WSTOSEQ2(I)
      If dim([M:SOW]CCE1)>0 Raz [M:SOW]CCE1(I) Endif
      If dim([M:SOW]CCE2)>0 Raz [M:SOW]CCE2(I) Endif
      If dim([M:SOW]CCE3)>0 Raz [M:SOW]CCE3(I) Endif
      If dim([M:SOW]CCE4)>0 Raz [M:SOW]CCE4(I) Endif
      If dim([M:SOW]CCE5)>0 Raz [M:SOW]CCE5(I) Endif
      If dim([M:SOW]CCE6)>0 Raz [M:SOW]CCE6(I) Endif
      If dim([M:SOW]CCE7)>0 Raz [M:SOW]CCE7(I) Endif
      If dim([M:SOW]CCE8)>0 Raz [M:SOW]CCE8(I) Endif
      If dim([M:SOW]CCE9)>0 Raz [M:SOW]CCE9(I) Endif
   Endif
Next I

End

########################################################################
# DIMSTOSORW     Diminution de la quantité stockée dans écran de travail
#                STOSORW (traitement des ruptures en priorité)
#                Attention :
#                Dégestion dans [STOCK] d'une quantité en cours de traitement
#                dans les zones CUMWIPQTY et CUMWIPQTA
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LLIG  = nolign-1  (indice ligne document)
#                LABR  = abréviation masque origine
#                LFCY  = Site de stockage
#                LQTA  = Quantité à diminuer (en UA)
#            S : LRET  = Code retour (0=OK / 1=Erreur)
#
########################################################################
Subprog DIM_STOSORW(LLIG,LABR,LFCY,LQTA,LRET)
Value    Integer LLIG
Value    Char    LABR
Value    Char    LFCY
Variable Decimal LQTA
Variable Integer LRET

Local Integer WTRBEGIN, I
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LQTY
Local Decimal WACTDIM, WSTUDIM
Local Integer WDIMSWW           : # Bug 62910
Local Decimal WSERDIM           : #--- Issue 110327

Raz WTRBEGIN, LRET

For I=0 To [M:SOW]NBLIG-1
   #--- Issue 121743
   #If evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG))")
   If LABR="" | evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG))")
   #---
      If [M:SOW]WSTOCOU(I)=0
         If LQTA >= [M:SOW]WQTYSTUACT(I)
            LQTA -= [M:SOW]WQTYSTUACT(I)
            Raz [M:SOW]WSTOSEQ(I),[M:SOW]WSTOCOU(I)
            Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I),[M:SOW]WWRH(I)
            Raz [M:SOW]WSTA(I),[M:SOW]WSERNUM(I),[M:SOW]WPLFSTO(I)
            Raz [M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)
            Raz [M:SOW]WALLSTU(I),[M:SOW]WALLSTUACT(I)
            #--- TS 106217
            Raz [M:SOW]WECCVALMAJ(I)
         Else
            [M:SOW]WQTYSTUACT(I) -= LQTA
            [M:SOW]WQTYSTU(I)    -= LQTA
            If [M:SOW]WALLSTUACT(I) > [M:SOW]WQTYSTUACT(I)
               [M:SOW]WALLSTUACT(I) = [M:SOW]WQTYSTUACT(I)
               [M:SOW]WALLSTU(I)    = [M:SOW]WQTYSTU(I)
            Endif
            Raz LQTA
            Break
         Endif
      Endif
   Endif
Next I
If LQTA<=0 End Endif
For I=0 To [M:SOW]NBLIG-1
   #--- Issue 121743
   #If evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG))")
   If LABR="" | evalue("find([M:SOW]WSTOSEQ(I),[M:"+LABR+"]WSTOSEQ(LLIG))")
   #---
      If [M:SOW]WSTOCOU(I)<>0
         #--- Bug 62910
         WDIMSWW = 0
         If LQTA >= [M:SOW]WQTYSTUACT(I)
            WACTDIM=[M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I)
            WSTUDIM=[M:SOW]WQTYSTU(I)   -[M:SOW]WALLSTU(I)
            #--- Issue 110327
            If [F:ITM]SERMGTCOD=4
               WSERDIM=[M:SOW]WQTYSTU(I)
            Else
               WSERDIM=0
            Endif
            #---
            Gosub MAJ_STO1
            If LRET<>0 Break Endif
            LQTA -= [M:SOW]WQTYSTUACT(I)
            Raz [M:SOW]WSTOSEQ(I),[M:SOW]WSTOCOU(I)
            Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I),[M:SOW]WWRH(I)
            Raz [M:SOW]WSTA(I),[M:SOW]WSERNUM(I),[M:SOW]WPLFSTO(I)
            Raz [M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)
            Raz [M:SOW]WALLSTU(I),[M:SOW]WALLSTUACT(I)
            #--- TS 106217
            Raz [M:SOW]WECCVALMAJ(I)
         Else
            LQTY = (LQTA*[M:SOW]WQTYSTU(I))/[M:SOW]WQTYSTUACT(I)
            #--- Issue 121743
            If LABR=""
              Call QTEARR(LQTY,[F:ITM]STU) From TRTDIV
            Else
              Call QTEARR(LQTY,evalue("[M:"+LABR+"]STU(LLIG)")) From TRTDIV
            Endif
            #Call QTEARR(LQTY,evalue("[M:"+LABR+"]STU(LLIG)")) From TRTDIV
            #---
            #--- Bug 62910
            #If [M:SOW]WALLSTUACT(I)>LQTA
            #   WACTDIM = [M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I)
            #   WSTUDIM = [M:SOW]WQTYSTU(I)   -[M:SOW]WALLSTU(I)
            #Else
            #   WACTDIM = [M:SOW]WQTYSTUACT(I)-LQTA
            #   WSTUDIM = [M:SOW]WQTYSTU(I)   -LQTY
            #Endif
            If LQTA > [M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I)
               WACTDIM = [M:SOW]WQTYSTUACT(I)-[M:SOW]WALLSTUACT(I)
               WSTUDIM = [M:SOW]WQTYSTU(I)   -[M:SOW]WALLSTU(I)
            Else
               WACTDIM = LQTA
               WSTUDIM = LQTY
               WDIMSWW = 1
            Endif
            #---
            #--- Issue 110327
            If [F:ITM]SERMGTCOD=4
               WSERDIM=LQTY
            Else
               WSERDIM=0
            Endif
            #---
            Gosub MAJ_STO1
            If LRET<>0 Break Endif
            [M:SOW]WQTYSTUACT(I) -= LQTA
            [M:SOW]WQTYSTU(I)    -= LQTY
            If [M:SOW]WALLSTUACT(I) > [M:SOW]WQTYSTUACT(I)
               [M:SOW]WALLSTUACT(I) = [M:SOW]WQTYSTUACT(I)
               [M:SOW]WALLSTU(I)    = [M:SOW]WQTYSTU(I)
            Endif
            Raz LQTA
            Break
         Endif
      Endif
   Endif
Next I

End

###########################################################################
$MAJ_STO1

# Il n'y avait pas de quantité en cours de traitement
#--- Issue 110327
#If WACTDIM<=0 Return Endif
If WACTDIM<=0 & WSERDIM=0 Return Endif
#---

If clalev([F:STO1])=0  Local File STOCK [STO1]  Endif
# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

#--- Issue 110327
If WACTDIM>0
#---
  Readlock [STO1]STO0=LFCY;[M:SOW]WSTOCOU(I)
  If fstat
    LRET=1 : GOK=0
    Call RSTA("STO1",LFCY-num$([M:SOW]WSTOCOU(I))) From GLOCK
  Else
    [F:STO1]CUMWIPQTA -= max(0,WACTDIM)
    [F:STO1]CUMWIPQTY -= max(0,WSTUDIM)
    # Dans le cas où l'on serait passé en négatif
    [F:STO1]CUMWIPQTA  = max(0,[F:STO1]CUMWIPQTA)
    [F:STO1]CUMWIPQTY  = max(0,[F:STO1]CUMWIPQTY)

    # Suppression qté en cours de traitement
    LSTOCOU = [F:STO1]STOCOU
    LWIPQTY = WSTUDIM
    #--- Bug 62910
    #Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
    If WDIMSWW=1
      Call DIM_STOWIPW(LSTOCOU,LWIPQTY,WACTDIM) From STKLIB
    Else
      Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
    Endif
    #---
    Rewrite [STO1]
    If fstat
      LRET=1 : GOK=0
      Call FSTA("STO1") From GLOCK
    Endif
  Endif
#--- Issue 110327
Endif
If WSERDIM>0 & LRET=0
  Read [STO1]STO0=LFCY;[M:SOW]WSTOCOU(I)
  If fstat
    LRET=1 : GOK=0
    Call RSTA("STO1",LFCY-num$([M:SOW]WSTOCOU(I))) From GLOCK
  Else
    Call DEL_STOSERW([F:STO1]ITMREF,[M:SOW]WSERNUM(I),WSERDIM,LRET) From STKLIB
    If LRET<>0 : GOK=0 : Endif
  Endif
Endif
#---

#--- Issue 110327
#If GOK=0 Goto AB_TRT Endif
# On a ouvert une transaction
#If WTRBEGIN=1
#   Commit
#   Raz WTRBEGIN
#Endif
# On a ouvert une transaction
If WTRBEGIN=1
   If GOK=0
      Rollback
   Else
     Commit
     Raz WTRBEGIN
   Endif
Endif
#---

Return

########################################################################
# SCASTOSORW     Lecture d'une allocations d'une ligne de document origine
#                pour stockage dans écran de travail STOSORW
#                Ex: création d'un suivi d'OF suite à une pesée
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LNBL    = Nombre lignes écran
#                -----------------------------------------------
#                Si génération suivi (avec OF alloué) à partir d'une pesée
#                   LABR = ""
#                   LNOL = No ligne suivi ou autre numéro
#                   LNBL = 0
#                -----------------------------------------------
#                LSTOCOU = Chrono stock de l'allocation
#                LSEQ    = No séquence de l'allocation
#            S : LRET    = Code retour (0=OK / 1=Erreur)
#                Attention si erreur, ne pas générer la ligne document
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP     = Type mouvement(M.704)
#                                    mettre 0 si OF,EO,matière s-trait à livrer
#                [M:ALP]TRSCOD     = Code mouvement
#                [M:ALP]VCRTYP     = Type pièce origine (M.701)
#                [M:ALP]VCRNUM     = Numéro pièce origine
#                [M:ALP]VCRLIN     = Numero ligne pièce origine
#                [M:ALP]VCRSEQ     = Numero sequence pièce origine
#                [M:ALP]STOFCY     = Site stock
#                [M:ALP]ITMREF     = Article
#                [M:ALP]QTY        = Quantité
#                [M:ALP]TYPQTY     = Type de quantité : 1=US/2=UA (M.720)
#                                    dans ce cas, mettre toujours 2
#                [M:ALP]STA        = Filtre statut ligne document
#                                    sous la forme : "A1*,A20"
#                [M:ALP]WRH        = Dépôt ligne document
#                #--- TS 106217
#                [M:ALP]ECCVALMAJ  = Version majeure ligne document
#
########################################################################
# Sortie       : Ecran ALLPAR [ALP] (Bloc 3)
#                [M:ALP]ALLQTY     = Qté active allouée sortable
#                [M:ALP]ALLQTYSHT  = Qté active en rupture
#
########################################################################
Subprog SCASTOSORW(LABR,LNOL,LNBL,LSTOCOU,LSEQ,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBL
Value    Decimal LSTOCOU
Value    Integer LSEQ
Variable Integer LRET

Local    Integer I, WRET, WPRE
Local    Char    WCRITSTO(240)
Local    Integer LLIG                : # Lien avec ligne de document
Local    Char    WDEFLOC(GLONLOC)
Local    Char    WDEFLOCTYP(GLONTLO)
Local    Char    WWRH(GLONWRH)       : # Dépôt    Bug 60536
Local    Char    LWRH(GLONWRH)       : # Dépôt

Raz LRET
Raz [M:ALP]ALLQTY, [M:ALP]ALLQTYSHT

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:SRU]) =0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STA]) =0  Local File STOALL     [STA]   Endif
If clalev([F:STO1])=0  Local File STOCK      [STO1]  Endif
#--- TS 106217
If clalev([F:ECS]) =0  Local File ECCSTA     [ECS]   Endif
#--- Issue 114287
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:STL1])=0  Local File STOLOT     [STL1]  Endif
#---

If dim([M:SOW]WSTOCOU) <= 0
   GOK=0  : Call ERREUR (mess(339,199,1)-'SOW') From GESECRAN
   LRET=1 : End
Endif

If [F:ITM]ITMREF<>[M:ALP]ITMREF
   Read [ITM]ITM0=[M:ALP]ITMREF
   If fstat
      Call RSTA("ITM",[M:ALP]ITMREF) From GLOCK
      LRET=1 : End
   Endif
Endif
#--- Issue 114287
Read [ITF]ITF0=[M:ALP]ITMREF;[M:ALP]STOFCY
If fstat
   Call RSTA("ITF",[M:ALP]ITMREF-[M:ALP]STOFCY) From GLOCK
   LRET=1 : End
Endif
#---

# Si génération d'un suivi (avec OF alloué) à partir d'une pesée
If LABR = ""
   LLIG = LNOL
Else
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
   Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
   If LRET<>0 End Endif
Endif

# Peut on ajouter les lignes dans l'écran de travail
If dim([M:SOW]WSTOCOU)<=0 | [M:SOW]NBLIG+2 >= dim([M:SOW]WSTOCOU)
   Call MESSAGE(mess(352,199,1)-mess(353,199,1)) From GESECRAN
   LRET=1 : End
Endif

# Alimentation du dépôt exclusif
If GWRHACT=2
   If [M:ALP]WRH=""
      Call WRHAUTO([M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]VCRTYP,0,LWRH) From STKWRH
      If !find(LWRH,"","*")
         # Alimentation dépôt rupture si pas de joker
         If !instr(1,LWRH,'*') & !instr(1,LWRH,'?')
&         & !instr(1,LWRH,'!') & !instr(1,LWRH,'#')
            #--- Bug 60536
            #[M:ALP]WRH = LWRH
            WWRH = LWRH
            #---
         Endif
      Endif
   #--- Bug 60536
   Else
      WWRH = [M:ALP]WRH
   #---
   Endif
Endif

#--- TS 106217
# Lecture de la règle de gestion à utiliser
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",LRET)
&           From STKLIB
If LRET<>0 End Endif
#---

# Si origine allocation = commande
# lecture de la règle de gestion pour le mouvement à traiter
If [M:ALP]VCRTYP=2
   #--- TS 106217
   #Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",LRET)
   #&            From STKLIB
   #If LRET<>0 End Endif
   #---
   # Chargement de l'emplacement (type) de consommation (si exclusif)
   Raz WDEFLOC, WDEFLOCTYP
   # Si prêt
   If [M:ALP]TRSTYP=17
      WPRE=2
   Else
      WPRE=1
   Endif
   #--- Bug 60536
   #Call RECH_PICLOC([M:ALP]VCRTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,"",
#&                   [M:ALP]WRH,1,WPRE,"N",WDEFLOC,WDEFLOCTYP) From STKALL
   Call RECH_PICLOC([M:ALP]VCRTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,"",
&                   WWRH,1,WPRE,"N",WDEFLOC,WDEFLOCTYP) From STKALL
   #---
   # Stockage dans WCRITSTO des statuts/sous-statuts autorisés
   Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL
Endif

# Alimentation de l'écran de travail STOSORW [SORW]
I = [M:SOW]NBLIG
Read [STA]STA0=[M:ALP]STOFCY;[M:ALP]ITMREF;LSTOCOU;LSEQ
If fstat
   Call RSTA("STA",[M:ALP]STOFCY-[M:ALP]ITMREF-num$(LSTOCOU)-num$(LSEQ))
&            From GLOCK
   LRET=1 : End
Endif
# Si allocation détaillée
If [F:STA]ALLTYP=2
   Read [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU
   If fstat
      Call RSTA("STO",[F:STA]STOFCY-num$([F:STA]STOCOU)) From GLOCK
      LRET=1 : End
   Endif
   #--- Issue 114287
   If [F:ITF]STOMGTCOD>2
     Read [STL1]STL0=[M:ALP]ITMREF;[F:STO1]LOT;[F:STO1]SLO
     If fstat
       Call RSTA("STL1",[M:ALP]ITMREF-[F:STO1]LOT-[F:STO1]SLO) From GLOCK
       LRET=1 : End
     Endif
   Endif
   #---
   #--- TS 1062177
   # Contrôle de la version de l'allocation par rapport à la règle de gestion
   Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",LRET)
   If LRET<>0 : Raz GMESSAGE : End : Endif
   #---

   # Si origine allocation = Cde
   If [M:ALP]VCRTYP=2
      # Si inventaire en cours ou demande d'analyse ou statut interdit
      If [F:STO1]CUNLOKFLG=2 | [F:STO1]QLYCTLDEM<>"" | !evalue(WCRITSTO)
         End
      Endif
      # Si emplacement (type) exclusif en sortie
      If [F:ITF]LOCMGTCOD=2 &
&        ((WDEFLOC<>""    & pat([F:STO1]LOC,WDEFLOC)<>1) |
&         (WDEFLOCTYP<>"" & pat([F:STO1]LOCTYP,WDEFLOCTYP)<>1))
         End
      Endif
   Endif

   # Si dépôt allocation différent dépôt exclusif, on ne la charge pas
   #--- Bug 60536
   #If GWRHACT=2 & [M:ALP]WRH<>""
   #   If !pat([F:STO1]WRH,[M:ALP]WRH)
   If GWRHACT=2 & WWRH<>""
      If !pat([F:STO1]WRH,WWRH)
   #---
         End
      Endif
   Endif

   # La ligne de stock en attente de rangement est-elle complète?
   If [F:STO1]LOCCAT=2
      Raz WRET
      Call CTLPLFLOC([F:ITM]ITMREF,"[F:STO1]",WRET)
      If WRET<>0
         # Si cde, on ne la charge pas
         If [M:ALP]VCRTYP=2
            End
         Else
            [M:SOW]WPLFSTO(I)=1
         Endif
      Endif
   Endif
Endif

[M:SOW]WSTOSEQ(I)    = LLIG
[M:SOW]WQTYSTUACT(I) = [M:ALP]QTY
[M:SOW]WQTYSTU(I)    = [M:SOW]WQTYSTUACT(I)
# Si allocation détaillée
If [F:STA]ALLTYP=2
   [M:SOW]WSTOCOU(I)    = [F:STA]STOCOU
   # Si gestion de titre
   #--- Issue 114287
   #If [F:ITF]STOMGTCOD>=2
      #[M:SOW]WQTYSTU(I) = ([M:SOW]WQTYSTUACT(I)*[F:STA]QTYSTU)/[F:STA]QTYSTUACT
      #Call QTEARR([M:SOW]WQTYSTU(I),[F:ITM]STU) From TRTDIV
      # Si gestion en titres ou UI, calcul quantité en UA
   #Endif
   If [M:ALP]TYPQTY=1
     Case [F:ITF]STOMGTCOD
       When 3 : If [M:SOW]WQTYSTU(I)=[F:STO1]QTYSTU
                  [M:SOW]WQTYSTUACT(I)=[F:STO1]QTYSTUACT
                Elsif [F:STL1]POT<>0
                  [M:SOW]WQTYSTUACT(I)=[M:SOW]WQTYSTU(I)*([F:STL1]POT/100)
                  Call QTEARR([M:SOW]WQTYSTUACT(I),[F:ITM]STU) From TRTDIV
                Endif
       When 4 : If [M:SOW]WQTYSTU(I)=[F:STO1]QTYSTU
                  [M:SOW]WQTYSTUACT(I)=[F:STO1]QTYSTUACT
                Elsif [F:STL1]ACT<>0
                  [M:SOW]WQTYSTUACT(I)=[M:SOW]WQTYSTU(I)*[F:STL1]ACT
                  Call QTEARR([M:SOW]WQTYSTUACT(I),[F:ITM]STU) From TRTDIV
                Endif
     Endcase
   Else
     Case [F:ITF]STOMGTCOD
       When 3 : If [M:SOW]WQTYSTUACT(I)=[F:STO1]QTYSTUACT
                  [M:SOW]WQTYSTU(I)=[F:STO1]QTYSTU
                Elsif [F:STL1]POT<>0
                  [M:SOW]WQTYSTU(I)=[M:SOW]WQTYSTUACT(I)/([F:STL1]POT/100)
                  Call QTEARR([M:SOW]WQTYSTU(I),[F:ITM]STU) From TRTDIV
                Endif
       When 4 : If [M:SOW]WQTYSTUACT(I)=[F:STO1]QTYSTUACT
                  [M:SOW]WQTYSTU(I)=[F:STO1]QTYSTU
                Elsif [F:STL1]ACT<>0
                  [M:SOW]WQTYSTU(I)=[M:SOW]WQTYSTUACT(I)/[F:STL1]ACT
                  Call QTEARR([M:SOW]WQTYSTU(I),[F:ITM]STU) From TRTDIV
                Endif
     Endcase
   Endif
   #--- End Issue 114287
   [M:SOW]WALLSTUACT(I) = min([M:SOW]WQTYSTUACT(I),[F:STA]QTYSTUACT)
   [M:SOW]WALLSTU(I)    = min([M:SOW]WQTYSTU(I),[F:STA]QTYSTU)
   #--- Issue 110327
   # Si série géré en sortie ou en E/S globale
   #If [F:ITM]SERMGTCOD=2
   If find([F:ITM]SERMGTCOD,2,4)
   #---
      [M:SOW]WSERNUM(I) = [F:STA]SERNUM
   Else
      Raz [M:SOW]WSERNUM(I)
   Endif
   Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WSTA(I)
# Si allocation de rupture
Else
   [M:SOW]WSTOCOU(I)    = 0
   # Dans ce cas, on alimente la qté US avec la qté UA
   [M:SOW]WLOT(I)       = [F:STA]LOT
   [M:SOW]WSLO(I)       = [F:STA]SLO
   [M:SOW]WSTA(I)       = [F:STA]STA
   [M:SOW]WWRH(I)       = [F:STA]WRH
   [M:SOW]WLOC(I)       = [F:STA]LOC
   [M:SOW]WSERNUM(I)    = [F:STA]SERNUM
   Raz [M:SOW]WALLSTUACT(I), [M:SOW]WALLSTU(I)
   #--- TS 106217
   [M:SOW]WECCVALMAJ(I) = [F:STA]ECCVALMAJ
Endif

Raz [M:SOW]WPLFSTO(I)

If [F:STA]ALLTYP=2
   [M:ALP]ALLQTY    += [M:SOW]WQTYSTUACT(I)
Else
   [M:ALP]ALLQTYSHT += [M:SOW]WQTYSTUACT(I)
Endif

[M:SOW]NBLIG += 1

End

########################################################################
# ALLSTOSORW     Lecture des allocations d'une ligne de document origine
#                pour stockage dans écran de travail STOSORW
#                Ex: picking commande en gestion livraison
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LABR    = Abréviation écran
#                LNOL    = No ligne écran (nolign-1)
#                LNBL    = Nombre lignes écran
#                -----------------------------------------------
#                Si suivi automatique (avec OF alloué)
#                ou livraison automatique de commandes
#                ou facturation automatique de commandes
#                ou génération bons de préparation
#                   LABR = ""
#                   LNOL = No ligne suivi ou autre numéro
#                   LNBL = 0
#                -----------------------------------------------
#                LRUP    = Chargement des ruptures (0=Non / 1=Oui)
#                          si pièce origine = Commande, OF ou EO
#                LCHGQTY = Chargement limité à la quantité renseignée
#                          dans [M:ALP]QTY (0=Non / 1=Oui)
#                LAFF    = Affichage des messages d'erreur (0=Non / 1=Oui)
#
#            S : LRET = Code retour (0=OK / 1=Erreur)
#                Attention si erreur, ne pas générer la ligne document
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP     = Type mouvement(M.704)
#                                    mettre  0 si OF,EO,matière s-trait à livrer
#                                    mettre 17 si commande de prêt
#                                            4 pour les autres commandes
#                [M:ALP]TRSCOD     = Code mouvement
#                [M:ALP]VCRTYP     = Type pièce origine (M.701)
#                [M:ALP]VCRNUM     = Numéro pièce origine
#                [M:ALP]VCRLIN     = Numero ligne pièce origine
#                [M:ALP]VCRSEQ     = Numero sequence pièce origine
#                [M:ALP]STOFCY     = Site stock
#                [M:ALP]ITMREF     = Article
#                [M:ALP]QTY        = Quantité
#                [M:ALP]TYPQTY     = Type de quantité : 1=US/2=UA (M.720)
#                                    dans ce cas, mettre toujours 2
#                [M:ALP]STA        = Filtre statut ligne document
#                                    sous la forme : "A1*,A20"
#                [M:ALP]PECSCOLOC  = Besoin matière pour opération de
#                                    sous-traitance
#                                    mettre 2 si s-traitance (OF/EO)
#                [M:ALP]BESDAT     = Date besoin
#                [M:ALP]DLVDAT     = Date livraison
#                [M:ALP]LOT        = Lot préférentiel
#                                    (à alimenter uniquement en import MKM)
#                [M:ALP]TWSTOSEQ   = Tableau des WSTOSEQ des lignes document
#                                    ayant la même origine (composant OF) que
#                                    celle en cours de traitement
#                                    Pour gérer correctement les allocations
#                                    à prendre en compte lors du chargement
#                                    (à alimenter si suivi matière)
#                [M:ALP]WRH        = Dépôt ligne document
#                [M:ALP]BPRNUM     = client pour le coeff de DLU client
#                #--- TS 106217
#                [M:ALP]ECCVALMAJ  = Version majeure ligne document
#
########################################################################
# Sortie       : Ecran ALLPAR [ALP] (Bloc 3)
#                [M:ALP]ALLQTY     = Qté active allouée sortable
#                [M:ALP]ALLQTYSHT  = Qté active en rupture
#
########################################################################
Subprog ALLSTOSORW(LABR,LNOL,LNBL,LRUP,LCHGQTY,LAFF,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBL
Value    Integer LRUP
Value    Integer LCHGQTY
Value    Integer LAFF
Variable Integer LRET

Local    Integer I, J, K, L, WRET, WNB, WERR, WPRE
Local    Integer WTRSTYP
Local    Char    WFILSTA(20), WCRITSTO(240)
Local    Decimal WQTY, WQTYSTUACT, WQTYSTU
Local    Decimal WNEWALLQTA       : # Qté à restant à traiter sur l'allocation
Local    Decimal WENCALLQTA       : # Qté en cours de traitement sur l'allocation
Local    Integer LLIG             : # Lien avec ligne de document
Local    Integer LIND1            : # Indice pour récupérer sections ana document
                                    # 0 : section entête, nolign : section ligne
Local    Integer LIND2            : # Indice tableau sections analytiques
Local    Char    LANA(GLONCDE)    : # Code section analytique par défaut
Local    Char    WDEFLOC(GLONLOC)
Local    Char    WDEFLOCTYP(GLONTLO)
Local    Char    WWRH(GLONWRH)        : # Dépôt                # Bug 60536
Local    Char    LWRH(GLONWRH)        : # Dépôt
Local    Integer LSST                 : # Sous-traitance 0/1
Local    Date    WDAT
Local    Date    WDATPER
Local    Integer OK
#--- Issue 110327
Local    Char    WNUMFIN(GLONSER), WSER(GLONSER)
Local    Decimal WQTE
#---
#DLU client
Local Char     NBDAY(10)
Raz NBDAY
Raz LRET
Raz [M:ALP]ALLQTY, [M:ALP]ALLQTYSHT

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITG]) =0  Local File ITMCATEG   [ITG]   Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV]) =0  Local File ITMMVT     [ITV]   Endif
If clalev([F:SRU]) =0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STA]) =0  Local File STOALL     [STA]   Endif
If clalev([F:STO1])=0  Local File STOCK      [STO1]  Endif
If clalev([F:STL1])=0  Local File STOLOT     [STL1]  Endif
#DLUBPC
If clalev([F:ITU])=0   Local File ITMBPC     [ITU]  Endif
#--- TS 106217
If clalev([F:ECS]) =0  Local File ECCSTA     [ECS]   Endif
If GWRHACT=2
   If clalev([F:ITW])=0  Local File ITMWRH    [ITW]  Endif
   If clalev([F:WRH])=0  Local File WAREHOUSE [WRH]  Endif
Endif
#--- Issue 110327
If clalev([F:STS]) =0  Local File STOSER     [STS]   Endif
If clalev([F:STS1])=0  Local File STOSER     [STS1]  Endif
If clalev([F:SSW]) =0  Local File STOSERW    [SSW]   Endif
#---

If dim([M:SOW]WSTOCOU) <= 0
   GOK=0  : Call ERREUR (mess(339,199,1)-'SOW') From GESECRAN
   LRET=1 : Goto ALLSOW_FIN
Endif

If [F:ITM]ITMREF<>[M:ALP]ITMREF
   Read [ITM]ITM0=[M:ALP]ITMREF
   If fstat
      Call RSTA("ITM",[M:ALP]ITMREF) From GLOCK
      LRET=1 : Goto ALLSOW_FIN
   Endif
Endif

#DLU Client
If [F:ITF]ITMREF<>[M:ALP]ITMREF
   Read [ITF]ITF0=[M:ALP]ITMREF;[M:ALP]STOFCY
   If fstat
      Raz [F:ITM]
   Endif
Endif
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALP]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALP]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif
#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif


# Si suivi auto (avec OF alloué), livraison auto ou facturation auto de cdes
If LABR = ""
   LLIG = LNOL
Else
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
   Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
   If LRET<>0 Goto ALLSOW_FIN Endif
Endif

# Si origine allocation = Commande, OF ou EO
# et paramètre 'chargt des ruptures' = Non
# on ne récupère que les allocations détaillées
#--- Bug 80430
#If (find([M:ALP]VCRTYP,2,3,10,36) & LRUP<>1) | [M:ALP]VCRTYP=34
#--- Bug 82815
#If (find([M:ALP]VCRTYP,2,10,36) & LRUP<>1) | [M:ALP]VCRTYP=34
#--- Issue X3-4501 ajout de VCRTYP=40
If (find([M:ALP]VCRTYP,2,10,36,40) & LRUP<>1) | [M:ALP]VCRTYP=34 |
&  ([M:ALP]VCRTYP=3 & GFONCTION="VXABP")
#---
   WFILSTA = 'ALLTYP=2'
Else
   WFILSTA = 'find(ALLTYP,2,4)<>0'
Endif

WTRSTYP = [M:ALP]TRSTYP

#--- Issue X3-4501 ajout de VCRTYP=40
If find([M:ALP]VCRTYP,2,3,10,36,40)
   # Si commande                      --> type mvt = livraison ou livraison prêt
   # Si OF                            --> type mvt = sortie OF ou s-traitance
   # Si ordre s-traitance             --> type mvt = sortie s-traitance
   Case [M:ALP]VCRTYP
    When  2,3 : If [M:ALP]TRSTYP=0 : WTRSTYP = 4 : Endif
    When 10   : If [M:ALP]PECSCOLOC=2
                   WTRSTYP = 29
                Else
                   WTRSTYP = 6
                Endif
    When 36   : WTRSTYP = 29
    When 40   : WTRSTYP = 4
   Endcase
Endif

Raz I

If [M:ALP]VCRNUM<>""
   # Si plan de réapprovisionnement, on filtre sur SRGNUM et SRGLIN
   If [M:ALP]VCRTYP=34
      Columns [STA] (STOFCY,ITMREF,VCRTYP,SRGNUM,SRGLIN,ALLTYP)
      For [STA]STA0 Where STOFCY=[M:ALP]STOFCY & ITMREF=[M:ALP]ITMREF &
&                         SRGNUM=[M:ALP]VCRNUM & SRGLIN=[M:ALP]VCRLIN &
&                         evalue(WFILSTA)
         I+=1
      Next
   Else
      Columns [STA] (VCRTYP,VCRNUM,VCRLIN,VCRSEQ,ITMREF,ALLTYP)
      For [STA]STA1 Where VCRTYP=[M:ALP]VCRTYP & VCRNUM=[M:ALP]VCRNUM &
&                         VCRLIN=[M:ALP]VCRLIN & VCRSEQ=[M:ALP]VCRSEQ &
&                         ITMREF=[M:ALP]ITMREF & evalue(WFILSTA)
         I+=1
      Next
   Endif
   Columns [STA]
Endif

# Pas d'allocation à traiter, on se débranche en traitement de fin
If I=0 Goto ALLSOW_FIN Endif

# Peut on ajouter les lignes dans l'écran de travail
If dim([M:SOW]WSTOCOU)<=0 | [M:SOW]NBLIG+I+1 >= dim([M:SOW]WSTOCOU)
   Call MESSAGE(mess(352,199,1)-mess(353,199,1)) From GESECRAN
   LRET=1 : Goto ALLSOW_FIN
Endif

# Quantité à traiter
WQTY = [M:ALP]QTY

# Récupération du dépôt exclusif
If GWRHACT=2
   # Si dépôt ligne document non renseigné
   If [M:ALP]WRH=""
      LSST=0
      # Sous-traitance
      If (find([M:ALP]VCRTYP,10,12) & [M:ALP]PECSCOLOC=2)
&       |(find([M:ALP]VCRTYP,3,4)   & [M:ALP]TRSTYP=20)
&       |([M:ALP]VCRTYP=34          & [M:ALP]LOCCAT=4)
          LSST=1
      Endif
      Call WRHAUTO([M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]VCRTYP,LSST,LWRH)
&          From STKWRH
      If !find(LWRH,"","*")
         # Alimentation dépôt rupture si pas de joker
         If !instr(1,LWRH,'*') & !instr(1,LWRH,'?')
&         & !instr(1,LWRH,'!') & !instr(1,LWRH,'#')
            #--- Bug 60536
            #[M:ALP]WRH = LWRH
            WWRH = LWRH
            #---
         Endif
      Endif
   #--- Bug 60536
   Else
      WWRH = [M:ALP]WRH
   #---
   Endif
Endif

# Si origine allocation = commande, OF ou EO
# lecture de la règle de gestion pour le mouvement à traiter
#--- Issue X3-4501 ajout de VCRTYP=40
If find([M:ALP]VCRTYP,2,3,10,36,40)
   # Lecture de la règle de gestion à utiliser
   Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,WTRSTYP,[M:ALP]TRSCOD,"",LRET)
&              From STKLIB
   If LRET<>0 Goto ALLSOW_FIN Endif

   # Chargement de l'emplacement (type) de consommation (si exclusif)
   Raz WDEFLOC, WDEFLOCTYP
   # Si prêt
   If WTRSTYP=17
      WPRE=2
   Else
      WPRE=1
   Endif
   #--- Bug 60536
#   Call RECH_PICLOC([M:ALP]VCRTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]STOLOC,
#&                   [M:ALP]WRH,[M:ALP]PECSCOLOC,WPRE,"N",WDEFLOC,WDEFLOCTYP)
#&       From STKALL
   Call RECH_PICLOC([M:ALP]VCRTYP,[M:ALP]STOFCY,[M:ALP]ITMREF,[M:ALP]STOLOC,
&                   WWRH,[M:ALP]PECSCOLOC,WPRE,"N",WDEFLOC,WDEFLOCTYP)
&       From STKALL
   #---

   # Stockage dans WCRITSTO des statuts/sous-statuts autorisés
   Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL

   GPOINT="ISSQLYCTL" : Gosub ENTREE From EXEFNC

Endif

# On affichera 3 erreurs maximum
Raz WERR
# Alimentation de l'écran de travail STOSORW [SORW]
I = [M:SOW]NBLIG

# Si plan de réapprovisionnement, on filtre sur SRGNUM et SRGLIN
If [M:ALP]VCRTYP=34
   For [STA]STA0 Where STOFCY=[M:ALP]STOFCY & ITMREF=[M:ALP]ITMREF &
&                      SRGNUM=[M:ALP]VCRNUM & SRGLIN=[M:ALP]VCRLIN &
&                      evalue(WFILSTA)
      # Allocation --> STOSORW
      Gosub CHARGE_ALL_SOW
      # Si chargement limité à la qté à traiter
      If LCHGQTY=1 Break (WQTY<=0) Endif
   Next
Else
   #---TS
   # Si pas de lot préférentiel (fonctionnement normal)
   If [M:ALP]LOT="" | instr(1,[M:ALP]STOLOC,'*') | instr(1,[M:ALP]STOLOC,'?')
&                   | instr(1,[M:ALP]STOLOC,'!') | instr(1,[M:ALP]STOLOC,'#')
   #---TS

      GPE=0
      GPOINT="NEWFILSTA" : Gosub ENTREE From EXEFNC
      If GPE=0
         Filter [STA] Where VCRTYP=[M:ALP]VCRTYP & VCRNUM=[M:ALP]VCRNUM &
&                           VCRLIN=[M:ALP]VCRLIN & VCRSEQ=[M:ALP]VCRSEQ &
&                           ITMREF=[M:ALP]ITMREF & evalue(WFILSTA)
      Endif
      For [STA]STA1
         # Allocation --> STOSORW
         Gosub CHARGE_ALL_SOW
         # Si chargement limité à la qté à traiter
         If LCHGQTY=1 Break (WQTY<=0) Endif
      Next
      Filter [STA]

   #---TS
   # Si lot préférentiel
   Else
      # Traitement de ce lot
      Link [STA] With  [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU As [ALL]
&                Where [F:STA]VCRTYP=[M:ALP]VCRTYP & [F:STA]VCRNUM=[M:ALP]VCRNUM &
&                      [F:STA]VCRLIN=[M:ALP]VCRLIN & [F:STA]VCRSEQ=[M:ALP]VCRSEQ &
&                      [F:STA]ITMREF=[M:ALP]ITMREF & [F:STO1]LOT=[M:ALP]LOT &
&                      evalue(WFILSTA)
&                Order By Key STA1
      For [ALL]
         # Allocation --> STOSORW
         Gosub CHARGE_ALL_SOW
         # Si chargement limité à la qté à traiter
         If LCHGQTY=1 Break (WQTY<=0) Endif
      Next
      If WQTY>0
         # Traitement des autres lots
         Link [STA] With  [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU As [ALL]
&                   Where [F:STA]VCRTYP=[M:ALP]VCRTYP & [F:STA]VCRNUM=[M:ALP]VCRNUM &
&                         [F:STA]VCRLIN=[M:ALP]VCRLIN & [F:STA]VCRSEQ=[M:ALP]VCRSEQ &
&                         [F:STA]ITMREF=[M:ALP]ITMREF & [F:STO1]LOT<>[M:ALP]LOT &
&                         evalue(WFILSTA)
&                Order By Key STA1
         For [ALL]
            # Allocation --> STOSORW
            Gosub CHARGE_ALL_SOW
            # Si chargement limité à la qté à traiter
            If LCHGQTY=1 Break (WQTY<=0) Endif
         Next
      Endif
   Endif
   #---TS

Endif
[M:SOW]NBLIG = I

$ALLSOW_FIN

Raz [M:ALP]TWSTOSEQ

End

########################################################################
# Chargement de l'allocation dans STOSORW
$CHARGE_ALL_SOW

# Si chargement limité à la qté à traiter et qté nulle
If LCHGQTY=1 & WQTY=0 Return Endif

# S'il existe plusieurs allocations pour un même chrono stock
# ce n'est pas une allocation détaillé avec no série renseigné (en sortie ou E/S globale)
# et les no séries ne sont pas gérés en E/S global       : #--- Issue 110327
# réagrégation de ces allocations
If I>[M:SOW]NBLIG & [F:STA]STOCOU<>0
   J=find([F:STA]STOCOU,[M:SOW]WSTOCOU([M:SOW]NBLIG..I-1))
   #--- Issue 110327
   #If J<>0 & ([F:STA]ALLTYP<>2 | [F:STA]SERNUM="")
   If J<>0 & ([F:STA]ALLTYP<>2 | [F:STA]SERNUM="") & [F:ITM]SERMGTCOD<4
   #---
      J=J+[M:SOW]NBLIG-1
      # Si chargement limité à la qté à traiter
      If LCHGQTY=1
         [L]WQTYSTUACT = min([F:STA]QTYSTUACT,WQTY)
      Else
         [L]WQTYSTUACT = [F:STA]QTYSTUACT
      Endif
      # Calcul quantité US physique
      If [F:STA]QTYSTUACT=[F:STA]QTYSTU
         # Pas de gestion de titre
         [L]WQTYSTU = [L]WQTYSTUACT
      Elsif [F:STA]QTYSTUACT=[L]WQTYSTUACT | [F:STA]QTYSTUACT=0
         # Gestion de titre et qté traitée totalement
         [L]WQTYSTU = [F:STA]QTYSTU
      Else
         # Gestion titre et qté traitée partiellement
         [L]WQTYSTU = ([L]WQTYSTUACT*[F:STA]QTYSTU)/[F:STA]QTYSTUACT
         Call QTEARR([L]WQTYSTU,[F:ITM]STU) From TRTDIV
      Endif

      [M:SOW]WQTYSTUACT(J)+=[L]WQTYSTUACT
      [M:SOW]WQTYSTU(J)   +=[L]WQTYSTU
      [M:SOW]WALLSTUACT(J)+=[L]WQTYSTUACT
      [M:SOW]WALLSTU(J)   +=[L]WQTYSTU
      [M:ALP]ALLQTY       +=[L]WQTYSTUACT
      WQTY               -= [L]WQTYSTUACT
      Return
   Endif
Endif

# Si allocation détaillée
If [F:STA]ALLTYP=2
   Read [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU
   If fstat Return Endif
   # Si origine allocation = Commande, OF ou EO
#--- Issue X3-4501 ajout de VCRTYP=40
   If find([M:ALP]VCRTYP,2,10,36,40)
      # Si inventaire en cours ou demande d'analyse
      If [F:STO1]CUNLOKFLG=2
         If WERR<3 & LAFF=1
            Gosub ALI_MESERR
            GMESSAGE+="\"+mess(126,184,1)
            Call ERREUR(GMESSAGE) From GESECRAN
            WERR+=1
         Endif
         Return
      Elsif [F:STO1]QLYCTLDEM<>"" & [M:ALP]PECQLYCTL<>2
         If WERR<3 & LAFF=1
            Gosub ALI_MESERR
            GMESSAGE+="\"+mess(460,199,1)
            Call ERREUR(GMESSAGE) From GESECRAN
            WERR+=1
         Endif
         Return
      Endif

      #--- TS 106217
      # Contrôle de la version de l'allocation par rapport à la règle de gestion
      Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",LRET)
      If LRET<>0
        Call ERREUR(GMESSAGE) From GESECRAN
        WERR+=1
        Return
      Endif
      #---

      # Si statut interdit
      If !evalue(WCRITSTO)
         If GSTOADMIN=2 & !GSERVEUR & !GIMPORT & GTRACE=""
            OK=1 : Call AVERTIR([F:STO1]STA-":"-mess(127,184,1), OK) From GESECRAN
            If OK=1 Return Endif
         Else
            If WERR<3 & LAFF=1
               Gosub ALI_MESERR
               GMESSAGE+="\"+mess(127,184,1)
               Call ERREUR(GMESSAGE) From GESECRAN
               WERR+=1
            Endif
            Return
         Endif
      Endif

      # Si dépôt allocation différent dépôt exclusif
      #--- Bug 60536
      #If GWRHACT=2 & [M:ALP]WRH<>""
      #   If !pat([F:STO1]WRH,[M:ALP]WRH)
      #      If GSTOADMIN=2 & !GSERVEUR & !GIMPORT & GTRACE=""
      If GWRHACT=2 & WWRH<>""
         If !pat([F:STO1]WRH,WWRH)
            If GSTOADMIN=2 & [M:ALP]WRH="" & !GSERVEUR & !GIMPORT & GTRACE=""
      #---
               OK=1 : Call AVERTIR([F:STO1]WRH-":"-mess(339,184,1), OK) From GESECRAN
               If OK=1 Return Endif
            Else
               If WERR<3 & LAFF=1
                  Gosub ALI_MESERR
                  GMESSAGE+="\"+mess(339,184,1)
                  Call ERREUR(GMESSAGE) From GESECRAN
                  WERR+=1
               Endif
               Return
            Endif
         Endif
      Endif

      # Si emplacement (type) exclusif en sortie
      If [F:ITF]LOCMGTCOD=2 &
&          ((WDEFLOC<>""    & pat([F:STO1]LOC,WDEFLOC)<>1) |
&           (WDEFLOCTYP<>"" & pat([F:STO1]LOCTYP,WDEFLOCTYP)<>1))
         If GSTOADMIN=2 & !GSERVEUR & !GIMPORT & GTRACE=""
            OK=1 : Call AVERTIR([F:STO1]LOC-":"-mess(241,184,1), OK) From GESECRAN
            If OK=1 Return Endif
         Else
            If WERR<3 & LAFF=1
               Gosub ALI_MESERR
               GMESSAGE+="\"+mess(241,184,1)
               Call ERREUR(GMESSAGE) From GESECRAN
               WERR+=1
            Endif
            Return
         Endif
      Endif
      # Lots périmés interdits
      If [F:SRU]SHLLOT<>3          # hcb v6dlu  nouvelle gestion
         Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
         If !fstat
            If [F:SRU]SHLLOT= 2
               WDATPER = [F:STL1]DLUDAT-val(NBDAY)  #DLUBPC
            Else
               WDATPER = [F:STL1]SHLDAT
            Endif
            If WDATPER <>[0/0/0]
               If [M:ALP]DLVDAT<>[0/0/0]
                  WDAT = [M:ALP]DLVDAT
               Else
                  WDAT = [M:ALP]BESDAT
               Endif
               If WDAT<>[0/0/0] & WDATPER<WDAT
                  If GSTOADMIN=2 & !GSERVEUR & !GIMPORT & GTRACE=""
                     OK=1 : Call AVERTIR([F:STO1]LOT-":"-mess(398,199,1), OK) From GESECRAN
                     If OK=1 Return Endif
                  Else
                     If WERR<3 & LAFF=1
                        Gosub ALI_MESERR
                        GMESSAGE+="\"+mess(398,199,1)
                        Call ERREUR(GMESSAGE) From GESECRAN
                        WERR+=1
                     Endif
                     Return
                  Endif
               Endif
            Endif
         Endif
      Endif
   Endif

   # La ligne de stock en attente de rangement est-elle complète?
   If [F:STO1]LOCCAT=2
      Raz WRET
      Call CTLPLFLOC([F:ITM]ITMREF,"[F:STO1]",WRET)
      If WRET<>0
         # Si commande, OF ou EO, on ne la charge pas
         #--- Issue X3-4501 ajout de VCRTYP=40
         If find([M:ALP]VCRTYP,2,10,36,40)
            If WERR<3 & LAFF=1
               GMESSAGE =[F:STO1]STOFCY-[F:STO1]ITMREF-[F:STO1]LOC-":"-mess(378,199,1)
               GMESSAGE+="\"+mess(377,199,1)-": "
               Case WRET
                When 1 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)
                When 2 : GMESSAGE+=mess(453,197,1)
                When 3 : GMESSAGE+=mess(43,197,1)-","-mess(456,197,1)-","-mess(453,197,1)
               Endcase
               Call ERREUR(GMESSAGE) From GESECRAN
               WERR+=1
            Endif
            Return
         Else
            [M:SOW]WPLFSTO(I)=1
         Endif
      Endif
   Endif
Endif

GOK=1
GPOINT="PECALLSOW" : Gosub ENTREE From EXEFNC
If GOK=0
   GOK=1 : Return
Endif

WNEWALLQTA = [F:STA]QTYSTUACT
WENCALLQTA = 0
# Si la pièce d'origine a déjà été sélectionnée au cours de cette transaction
# il faut déduire les allocations déjà en cours de traitement
# --> détermination de la quantité allouée réellement disponible
K=0
While [M:ALP]TWSTOSEQ(K)<>0 & K<dim([M:ALP]TWSTOSEQ)

   WENCALLQTA+=sigma(L=0,[M:SOW]NBLIG-1,[M:SOW]WALLSTUACT(L)
&                                       *( [M:SOW]WSTOCOU(L)=[F:STA]STOCOU
&                                         &[M:SOW]WSTOSEQ(L)=[M:ALP]TWSTOSEQ(K)))
   K+=1
Wend

# Calcul de la qté restant à traiter sur cette allocation
WNEWALLQTA -= WENCALLQTA
# Il n'y a plus rien à traiter sur cette allocation
If WNEWALLQTA<=0 Return Endif

[M:SOW]WSTOSEQ(I)    = LLIG
# Si chargement limité à la qté à traiter
If LCHGQTY=1
   [M:SOW]WQTYSTUACT(I) = min(WNEWALLQTA,WQTY)
Else
   [M:SOW]WQTYSTUACT(I) = WNEWALLQTA
Endif
# Si allocation détaillée
If [F:STA]ALLTYP=2

   #--- Issue 110327
   # Si origine allocation = Cde, prépa, OF ou EO, et séries en E/S global non connus
   # détermination des no séries
   #--- Issue X3-4501 ajout de VCRTYP=40
   If find([M:ALP]VCRTYP,2,3,10,36,40) & [F:ITM]SERMGTCOD=4 & [F:STA]SERNUM=""
      WQTE = [M:SOW]WQTYSTUACT(I)
      Raz [M:SOW]WQTYSTUACT(I)
      WSER = ""
      # Boucle pour traiter les séquences de no série
      $GEN_ALL_STOSERW
      Filter [STS] Where ITMREF=[M:ALP]ITMREF & STOCOU=[F:STA]STOCOU &SERNUM>WSER & SDHNUM=""
&                  Order By Key STS3
      Read [STS]First
      If !fstat
         While func STKLIB.REC_STOSERW([M:ALP]ITMREF,[F:STS]SERNUM)<>0
            Read [STS]Next
            If fstat
               [F:STS]SERNUM="" : Break
            Endif
         Wend
         If [F:STS]SERNUM<>""
            # On alimente STOSORW
            [M:SOW]WSTOCOU(I)    = [F:STA]STOCOU
            [M:SOW]WSERNUM(I)    = [F:STS]SERNUM
            [M:SOW]WSTOSEQ(I)    = LLIG
            [M:SOW]WQTYSTU(I)    = 1
            [M:SOW]WQTYSTUACT(I) = 1
            Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I),[M:SOW]WSTA(I),[M:SOW]WWRH(I)
            Raz [M:SOW]WECCVALMAJ(I)
            Raz WRET
            WSER =[F:STS]SERNUM
            WQTE-=1
            # Traitement des no série d'une séquence
            While WQTE>0
               Call PLUS_UN(WSER,WNUMFIN,WRET) From STKLIB
               If WRET=0
                  Read [STS1]STS0=[M:ALP]ITMREF;WNUMFIN
                  If fstat | [F:STS1]STOCOU<>[F:STA]STOCOU
&                  | [F:STS1]ISSDAT<>[0/0/0] | [F:STS1]SDHNUM<>""
                     WNUMFIN=""
                  Elsif func STKLIB.REC_STOSERW([M:ALP]ITMREF,WNUMFIN)<>0
                     WNUMFIN=""
                  Endif
               Else
                  WNUMFIN=""
               Endif
               If WNUMFIN="" Break Endif
               [M:SOW]WQTYSTU(I)   +=1
               [M:SOW]WQTYSTUACT(I)+=1
               WQTE-=1
               WSER =WNUMFIN
            Wend
            # Blocage des no série en cours de traitement
            Call CRE_STOSERW([M:ALP]ITMREF,[M:SOW]WSERNUM(I),[M:SOW]WQTYSTU(I),WRET) From STKLIB
            If WRET<>0
               # On efface le contenu de la ligne [SOW]
               WQTE+=[M:SOW]WQTYSTU(I)
               Raz [M:SOW]WSERNUM(I),[M:SOW]WSTOSEQ(I),[M:SOW]WSTOCOU(I)
               Raz [M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I),[M:SOW]WALLSTU(I),[M:SOW]WALLSTUACT(I)
            Else
               [M:SOW]WALLSTU(I)    = [M:SOW]WQTYSTU(I)
               [M:SOW]WALLSTUACT(I) = [M:SOW]WQTYSTUACT(I)
               Raz [M:SOW]WPLFSTO(I)
               [M:ALP]ALLQTY       += [M:SOW]WQTYSTUACT(I)
               WQTY                -= [M:SOW]WQTYSTUACT(I)
               # Issue 103089 - 2014-12-02 by SR
               GPOINT = "CHARGE_ALL_SOW" : Gosub ENTREE From EXEFNC
               # Passage à la ligne [SOW] suivante
               I+=1
            Endif
            # Il reste une quantité à traiter pour les no série
            If WQTE>0
               Filter [STS]
               Goto GEN_ALL_STOSERW
            Endif
         Endif
      Endif
      Filter [STS]
   Else
   #--- End issue 110327

      [M:SOW]WSTOCOU(I)    = [F:STA]STOCOU

      # Si pas gestion de titre
      If [F:STA]QTYSTUACT=[F:STA]QTYSTU
         [M:SOW]WQTYSTU(I) = [M:SOW]WQTYSTUACT(I)
      # sinon si qté=0 ou qté à traiter=qté allouée
      Elsif [F:STA]QTYSTUACT=0 | [M:SOW]WQTYSTUACT(I)=[F:STA]QTYSTUACT
         [M:SOW]WQTYSTU(I) = [F:STA]QTYSTU
      # sinon si gestion de titre
      Else
         [M:SOW]WQTYSTU(I) = ([M:SOW]WQTYSTUACT(I)*[F:STA]QTYSTU)/[F:STA]QTYSTUACT
         Call QTEARR([M:SOW]WQTYSTU(I),[F:ITM]STU) From TRTDIV
      Endif

      [M:SOW]WALLSTUACT(I) = [M:SOW]WQTYSTUACT(I)
      [M:SOW]WALLSTU(I)    = [M:SOW]WQTYSTU(I)
      #--- Issue 110327
      # Si série géré en sortie ou E/S globale
      #If [F:ITM]SERMGTCOD=2
      If find([F:ITM]SERMGTCOD,2,4)
      #---
         [M:SOW]WSERNUM(I)    = [F:STA]SERNUM
      Else
         Raz [M:SOW]WSERNUM(I)
      Endif
      Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I),[M:SOW]WSTA(I),[M:SOW]WWRH(I)
      #--- TS 106217
      Raz [M:SOW]WECCVALMAJ(I)
      #--- Issue 110327
      Raz [M:SOW]WPLFSTO(I)
      [M:ALP]ALLQTY += [M:SOW]WQTYSTUACT(I)
      WQTY          -= [M:SOW]WQTYSTUACT(I)
      # Issue 103089 - 2014-12-02 by SR
      GPOINT = "CHARGE_ALL_SOW" : Gosub ENTREE From EXEFNC
      I += 1
   Endif
   #--- End issue 110327

# Si allocation de rupture
Else
   [M:SOW]WSTOCOU(I)    = 0
   # Dans ce cas, on alimente la qté US avec la qté UA
   [M:SOW]WQTYSTU(I)    = [M:SOW]WQTYSTUACT(I)
   [M:SOW]WLOT(I)       = [F:STA]LOT
   [M:SOW]WSLO(I)       = [F:STA]SLO
   [M:SOW]WSTA(I)       = [F:STA]STA
   [M:SOW]WLOC(I)       = [F:STA]LOC
   [M:SOW]WWRH(I)       = [F:STA]WRH
   [M:SOW]WSERNUM(I)    = [F:STA]SERNUM
   Raz [M:SOW]WALLSTUACT(I), [M:SOW]WALLSTU(I)
   #--- TS 106217
   [M:SOW]WECCVALMAJ(I) = [F:STA]ECCVALMAJ
   #--- Issue 110327
   Raz [M:SOW]WPLFSTO(I)
   [M:ALP]ALLQTYSHT += [M:SOW]WQTYSTUACT(I)
   WQTY             -= [M:SOW]WQTYSTUACT(I)
   # Issue 103089 - 2014-12-02 by SR
   GPOINT = "CHARGE_ALL_SOW" : Gosub ENTREE From EXEFNC
   I += 1
   #--- End issue 110327
Endif

#--- Issue 110327
#Raz [M:SOW]WPLFSTO(I)
#If [F:STA]ALLTYP=2
#   [M:ALP]ALLQTY    += [M:SOW]WQTYSTUACT(I)
#Else
#   [M:ALP]ALLQTYSHT += [M:SOW]WQTYSTUACT(I)
#Endif
#WQTY -= [M:SOW]WQTYSTUACT(I)
# Issue 103089 - 2014-12-02 by SR
#GPOINT = "CHARGE_ALL_SOW" : Gosub ENTREE From EXEFNC
#I    += 1
#--- End issue 110327

Return

########################################################################
# STJSTOSORW     Lecture des mouvements de stock d'une ligne de document
#                pour stockage dans écran de travail STOSORW
#                Ex: picking réception en gestion retour fournisseur
#                    désassemblage d'un assemblage (traitement du composé)
########################################################################
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LABR = Abréviation écran
#                LNOL = No ligne écran (nolign-1)
#                LNBL = Nombre lignes écran
#
#            S : LRET = Code retour (0=OK / 1=Erreur)
#                Attention si erreur, ne pas générer la ligne document
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP     = Type mouvement(M.704)
#                [M:ALP]TRSCOD     = Code mouvement
#                [M:ALP]VCRTYP     = Type pièce origine (M.701)
#                [M:ALP]VCRNUM     = Numéro pièce origine
#                [M:ALP]VCRLIN     = Numero ligne pièce origine
#                [M:ALP]VCRSEQ     = Numero sequence pièce origine
#                [M:ALP]STOFCY     = Site stock
#                [M:ALP]ITMREF     = Article
#                [M:ALP]QTY        = Quantité
#                [M:ALP]TYPQTY     = Type de quantité : 1=US/2=UA (M.720)
#                [M:ALP]STA        = Filtre statut ligne document
#                                    sous la forme : "A1*,A20"
#
########################################################################
# Sortie       : Ecran ALLPAR [ALP] (Bloc 3)
#                [M:ALP]ALLQTY     = Qté traitée (chargée dans [SOW])
#
#                Variable global GSTJINFO = Infos sur les STJ non chargés
#                    Poids 1 = Inventaire en cours
#                    Poids 2 = Statut non autorisé
#                    Poids 4 = Demande d'analyse
#                    Poids 8 = Stock indisponible
#
########################################################################
Subprog STJSTOSORW(LABR,LNOL,LNBL,LRET)
Value    Char    LABR
Value    Integer LNOL
Value    Integer LNBL
Variable Integer LRET

Global   Integer GSTJINFO       : # Informations sur les mvts non chargés

Local    Integer I, WRET
Local    Char    WCRIT(80), WCRITSTO(240)
Local    Decimal WQTY
Local    Integer LLIG           : # Lien avec ligne de document
Local    Integer LIND1          : # Indice pour récupérer sections ana document
                                  # 0 : section entête, nolign : section ligne
Local    Integer LIND2          : # Indice tableau sections analytiques
Local    Char    LANA(GLONCDE)  : # Code section analytique par défaut
Local    Integer WTRBEGIN
Local    Char    LWRH, WFIL     : # Bug 60530
#--- Bug 76874
Local    Decimal WSTJQTY
#--- Issue 110327
Local Decimal WSTOCOU_OK
Local Decimal WSTOCOU_KO
Local Char    WSER(GLONSER)
Local Char    WSERF(GLONSER)
#---

Raz GSTJINFO
Raz LRET, WTRBEGIN
Raz [M:ALP]ALLQTY, [M:ALP]ALLQTYSHT

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:SRU]) =0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STJ]) =0  Local File STOJOU     [STJ]   Endif
If clalev([F:STO1])=0  Local File STOCK      [STO1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW    [SWW]   Endif

If dim([M:SOW]WSTOCOU) <= 0
   GOK=0  : Call ERREUR (mess(339,199,1)-'SOW') From GESECRAN
   LRET=1 : End
Endif

If [F:ITM]ITMREF<>[M:ALP]ITMREF
   Read [ITM]ITM0=[M:ALP]ITMREF
   If fstat
      Call RSTA("ITM",[M:ALP]ITMREF) From GLOCK
      LRET=1 : End
   Endif
Endif

# Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
If LRET<>0 End Endif

#--- Bug 60530
# Alimentation du filtre dépôt si mono-dépôt
If evalue("dim([M:"+LABR+"]WRH(LNOL))")>0
   LWRH=evalue("[M:"+LABR+"]WRH(LNOL)")
Endif
If LWRH<>""
   WFIL="WRH=LWRH"
Else
   WFIL="1=1"
Endif
#---

Raz I
# Issue 83150 - 2012-08-06 by CCC : Ajout de l'article dans le filtre
Columns [STJ] (STOFCY,ITMREF,VCRTYP,VCRNUM,VCRLIN,UPDCOD,REGFLG)
For [STJ]STJ1 Where STOFCY=[M:ALP]STOFCY & ITMREF=[M:ALP]ITMREF
&                 & VCRTYP=[M:ALP]VCRTYP & VCRNUM=[M:ALP]VCRNUM & VCRLIN=[M:ALP]VCRLIN
&                 & UPDCOD=2 & REGFLG<>2 & evalue(WFIL)
    I+=1
Next
Columns [STJ]

# Pas de mouvement d'origine à traiter
If I=0 End Endif

# Peut on ajouter les lignes dans l'écran de travail
If dim([M:SOW]WSTOCOU)<=0 | [M:SOW]NBLIG+I >= dim([M:SOW]WSTOCOU)
   Call MESSAGE(mess(352,199,1)-mess(353,199,1)) From GESECRAN
   LRET=1 : End
Endif

# Si insertion d'une ligne dans l'écran de la pièce,
# incrémentation des no lignes écran >= à ce no ligne
#If max([M:SOW]NUMLIG)<LLIG
#   For I=0 To [M:SOW]NBLIG-1
#      If [M:SOW]NUMLIG(I)>=LLIG [M:SOW]NUMLIG(I)+=1 Endif
#   Next I
#Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",LRET)
&           From STKLIB
If LRET<>0 End Endif

# Stockage dans WCRITSTO des statuts/sous-statuts autorisés
Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL

WQTY = [M:ALP]QTY
# Alimentation de l'écran de travail STOSORW [SORW]
I = [M:SOW]NBLIG

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

For [STJ]STJ1 Where STOFCY=[M:ALP]STOFCY & ITMREF=[M:ALP]ITMREF
&                 & VCRTYP=[M:ALP]VCRTYP & VCRNUM=[M:ALP]VCRNUM & VCRLIN=[M:ALP]VCRLIN
&                 & UPDCOD=2 & REGFLG<>2 & evalue(WFIL)
&                 & TRSTYP<>29                                  : #--- Issue 115206
   Raz WSTJQTY

   #--- Issue 110327
   # Article géré en E/S globale
   If [F:STJ]SERDEB<>""
      WSTOCOU_OK=0
      WSTOCOU_KO=0
      WSER=[F:STJ]SERDEB
      Read [STS]STS0=[F:STJ]ITMREF;WSER
      # Boucle de traitement des no séries du mouvement de stock
      While WSER<=[F:STJ]SERFIN
         # Le no série est ok
         If !fstat & [F:STS]ISSDAT=[0/0/0] & [F:STS]SDHNUM="" & func STKLIB.REC_STOSERW([F:STS]ITMREF,[F:STS]SERNUM)=0
            # Le no série est sur un autre chrono stock ok que le précédent no série
            If [F:STS]STOCOU<>WSTOCOU_OK
               # Le no série est sur un autre chrono stock non ok que le précédent no série
               # --> on lit le nouveau chrono stock
               If [F:STS]STOCOU<>WSTOCOU_KO
                  Read [STO1]STO0=[F:STJ]STOFCY;[F:STS]STOCOU
                  If !fstat
                     # Contrôle du chrono stock
                     Gosub CTRL_STOCK
                     # Le chrono stock est ok, on créé une nouvelle ligne dans [M:SOW]
                     If WRET=0
                        [M:SOW]WQTYSTU(I)    = 1
                        [M:SOW]WQTYSTUACT(I) = 1
                        [M:SOW]WSERNUM(I)    = WSER
                        WSTOCOU_OK = [F:STS]STOCOU
                        WSTOCOU_KO = 0
                     # Le chrono stock n'est pas ok
                     Else
                        WSTOCOU_OK = 0
                        WSTOCOU_KO = [F:STS]STOCOU
                     Endif
                  Else
                     WSTOCOU_OK = 0
                     WSTOCOU_KO = [F:STS]STOCOU
                  Endif
               Endif
            # Le no série est sur le même chrono stock ok que le précédent no série --> on cumule
            Else
               [M:SOW]WQTYSTU(I)    += 1
               [M:SOW]WQTYSTUACT(I) += 1
            Endif
         # Le no série n'est pas ok
         # --> on met à jour la ligne [M:SOW] du même chrono stock, s'il était ok
         #     pour les no séries précédents
         Else
            If WSTOCOU_OK<>0
              Gosub MAJ_SOW
            Endif
            WSTOCOU_OK =0
         Endif
         # Passage au no série suivant
         Call PLUS_UN(WSER,WSERF,WRET) From STKLIB
         If WRET<>0 | WSERF>[F:STJ]SERFIN : Break : Endif

         Read [STS]STS0=[F:STJ]ITMREF;WSERF
         # Le nouveau no série est sur un autre chrono stock que le no série précedent
         # --> on met à jour la ligne [M:SOW] du précedent chrono stock, s'il était ok
         If [F:STS]STOCOU<>WSTOCOU_OK & WSTOCOU_OK<>0
            Gosub MAJ_SOW
            WSTOCOU_OK = 0
         Endif
         WSER = WSERF
      Wend
      # Fin des no série du mouvement
      # --> on met à jour la ligne [M:SOW] s'il y en a une en cours
      If WSTOCOU_OK<>0
         Gosub MAJ_SOW
      Endif
   Else
   #--- End issue 110327

      If [F:STJ]SERNUM<>""
         Filter [STO1] Where ITMREF   =[F:STJ]ITMREF
&                          & SERNUM   =[F:STJ]SERNUM
&                          & STOFCY   =[F:STJ]STOFCY
      Elsif [F:ITM]LOTMGTCOD>1
         Filter [STO1] Where ITMREF   =[F:STJ]ITMREF
&                          & STOFCY   =[F:STJ]STOFCY
&                          & LOT      =[F:STJ]LOT
&                          & SLO      =[F:STJ]SLO
&                          & BPSLOT   =[F:STJ]BPSLOT
&                          & PALNUM   =[F:STJ]PALNUM
&                          & CTRNUM   =[F:STJ]CTRNUM
&                          & PCU      =[F:STJ]PCU
&                          & PCUSTUCOE=[F:STJ]PCUSTUCOE
&                          & OWNER    =[F:STJ]OWNER
&                          & STOFLD1  =[F:STJ]STOFLD1
&                          & STOFLD2  =[F:STJ]STOFLD2
      Else
         Filter [STO1] Where ITMREF   =[F:STJ]ITMREF
&                          & STOFCY   =[F:STJ]STOFCY
&                          & LOT      =[F:STJ]LOT
&                          & SLO      =[F:STJ]SLO
&                          & LOC      =[F:STJ]LOC
&                          & BPSLOT   =[F:STJ]BPSLOT
&                          & PALNUM   =[F:STJ]PALNUM
&                          & CTRNUM   =[F:STJ]CTRNUM
&                          & STA      =[F:STJ]STA
&                          & PCU      =[F:STJ]PCU
&                          & PCUSTUCOE=[F:STJ]PCUSTUCOE
&                          & OWNER    =[F:STJ]OWNER
&                          & STOFLD1  =[F:STJ]STOFLD1
&                          & STOFLD2  =[F:STJ]STOFLD2
&                          & LPNNUM   =[F:STJ]LPNNUM        : #--- Issue X3-53322
      Endif
      If [F:STJ]SERNUM<>""
         Read [STO1]STO5 First
      Else
         Read [STO1]STO3 First
      Endif

      $STJSOW_NEXT
      If !fstat
         #--- Issue 110327
         Gosub CTRL_STOCK
         If WRET<>0 : Goto STJSOW_SUI : Endif
         # Inventaire en cours
         #If [F:STO1]CUNLOKFLG=2
         #   If !find(GSTJINFO,1,3,5,7,9,11,13,15) GSTJINFO+=1 Endif
         #   Goto STJSOW_SUI
         #Endif
         # Statut non autorisé
         #If !evalue(WCRITSTO)
         #   If !find(GSTJINFO,2,3,6,7,10,11,14,15) GSTJINFO+=2 Endif
         #   Goto STJSOW_SUI
         #Endif
         # Demande d'analyse en cours
         #If [F:STO1]QLYCTLDEM<>""
         #   If !find(GSTJINFO,4,5,6,7,12,13,14,15) GSTJINFO+=4 Endif
         #   Goto STJSOW_SUI
         #Endif
         #--- End issue 110327
         If [M:ALP]TYPQTY=1
            # Pas de disponible
            If [F:STO1]QTYSTU-[F:STO1]CUMALLQTY-[F:STO1]CUMWIPQTY<=0
               If !find(GSTJINFO,8,9,10,11,12,13,14,15) GSTJINFO+=8 Endif
               Goto STJSOW_SUI
            Endif
            [M:SOW]WQTYSTU(I)    = min([F:STJ]QTYSTU,WQTY,[F:STO1]QTYSTU-[F:STO1]CUMALLQTY-[F:STO1]CUMWIPQTY)
            [M:SOW]WQTYSTUACT(I) = [M:SOW]WQTYSTU(I)
            # Calcul qté UA si gestion de titre (règle de 3)
            If [F:STJ]QTYSTU<>0 & [F:STJ]ACTQTY<>[F:STJ]QTYSTU
               [M:SOW]WQTYSTUACT(I) = ([M:SOW]WQTYSTU(I)*[F:STJ]ACTQTY)/[F:STJ]QTYSTU
               Call QTEARR([M:SOW]WQTYSTUACT(I),[F:ITM]STU) From TRTDIV
            Endif
         Else
            # Pas de disponible
            If [F:STO1]QTYSTUACT-[F:STO1]CUMALLQTA-[F:STO1]CUMWIPQTA<=0
               If !find(GSTJINFO,8,9,10,11,12,13,14,15) GSTJINFO+=8 Endif
               Goto STJSOW_SUI
            Endif
            [M:SOW]WQTYSTUACT(I) = min([F:STJ]ACTQTY,WQTY,[F:STO1]QTYSTUACT-[F:STO1]CUMALLQTA-[F:STO1]CUMWIPQTA)
            [M:SOW]WQTYSTU(I)    = [M:SOW]WQTYSTUACT(I)
            # Calcul qté US si gestion de titre (règle de 3)
            If [F:STJ]ACTQTY<>0 & [F:STJ]QTYSTU<>[F:STJ]ACTQTY
               [M:SOW]WQTYSTU(I) = ([M:SOW]WQTYSTUACT(I)*[F:STJ]QTYSTU)/[F:STJ]ACTQTY
               Call QTEARR([M:SOW]WQTYSTU(I),[F:ITM]STU) From TRTDIV
            Endif
         Endif

         # Mise à jour de la qté en cours de traitement
         Readlock [STO1] Curr
         If fstat Goto STJSOW_SUI Endif
         [F:STO1]CUMWIPQTY += [M:SOW]WQTYSTU(I)
         [F:STO1]CUMWIPQTA += [M:SOW]WQTYSTUACT(I)

         Call CRE_STOWIPW([F:STO1]STOCOU,[M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)) From STKLIB
         Rewrite [STO1]
         If fstat
            Call FSTA("STO1") From GLOCK
            Goto STJSOW_SUI
         Endif

         [M:SOW]WSTOSEQ(I) = LLIG
         [M:SOW]WSTOCOU(I) = [F:STO1]STOCOU
         Raz [M:SOW]WALLSTUACT(I), [M:SOW]WALLSTU(I)
         Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
         Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)
         #--- TS 106217
         Raz [M:SOW]WECCVALMAJ(I)

         # Bug 24467 : TS le 31.08.04
         # Inutile, pas de contrôle car il s'agit d'un retour fournisseur
         # La ligne de stock en attente de rangement est-elle complète?
         #If [F:STO1]LOCCAT=2
         #   Raz WRET
         #   Call CTLPLFLOC([F:ITM]ITMREF,"[F:STO1]",WRET)
         #   If WRET<>0 Goto STJSOW_SUI Endif
         #Endif

         If [M:ALP]TYPQTY=1
             [M:ALP]ALLQTY += [M:SOW]WQTYSTU(I)
            WQTY          -= [M:SOW]WQTYSTU(I)
         Else
            [M:ALP]ALLQTY += [M:SOW]WQTYSTUACT(I)
            WQTY          -= [M:SOW]WQTYSTUACT(I)
         Endif
         #--- Bug 76874
         WSTJQTY += [M:SOW]WQTYSTU(I)
         I += 1
         Break (WQTY=0)
      Else
         If !find(GSTJINFO,8,9,10,11,12,13,14,15) GSTJINFO+=8 Endif
      Endif

      $STJSOW_SUI
      # Si gestion lot sans gestion série, et toute la quantité du mouvement
      # n'a pas été traitée, il faut boucler sur les lignes de stock
      # car le statut ne fait pas partie du filtre --> plusieurs lignes
      #--- Bug 76874
      #If [F:STJ]SERNUM="" & [F:ITM]LOTMGTCOD>1
      If [F:STJ]SERNUM="" & [F:ITM]LOTMGTCOD>1 & [F:STJ]QTYSTU>WSTJQTY
      #---
         Read [STO1]STO3 Next
         If !fstat Goto STJSOW_NEXT Endif
      Endif
      Filter [STO1]

   #--- Issue 110327
   Endif
   #---
Next

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

[M:SOW]NBLIG = I

# Récupération des sections analytiques
#If LABR<>""
#   Case LABR
#    When "SDH1"               : LANA="STKLIV"
#    When "SIH4"               : LANA="STKFAC"
#    When "PNH1"               : LANA="STKPRT"
#    When "SMO1","DBY0","BBY1" : LANA="STJSOR"
#    When "MTK3","MBM"         : LANA="STKSOF"
#    When "SRE9","ITN8"        : LANA="STKHDT"
#   Endcase
#   Call STKINISEC (LLIG,LANA,"SOW") From STKECR
#Endif

End

#--- Issue 110327
$MAJ_SOW
# Mise à jour de la qté en cours de traitement
Readlock [STO1] Curr
If !fstat
  [F:STO1]CUMWIPQTY += [M:SOW]WQTYSTU(I)
  [F:STO1]CUMWIPQTA += [M:SOW]WQTYSTUACT(I)
  Call CRE_STOWIPW([F:STO1]STOCOU,[M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)) From STKLIB
  Rewrite [STO1]
  If !fstat
    # Mise à jour des no série en cours de traitement
    Call CRE_STOSERW([F:STO1]ITMREF,[M:SOW]WSERNUM(I),[M:SOW]WQTYSTU(I),WRET) From STKLIB
    [M:SOW]WSTOSEQ(I)    = LLIG
    [M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
    Raz [M:SOW]WALLSTUACT(I), [M:SOW]WALLSTU(I)
    Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
    Raz [M:SOW]WSTA(I), [M:SOW]WPLFSTO(I)
    Raz [M:SOW]WECCVALMAJ(I)
    [M:ALP]ALLQTY += [M:SOW]WQTYSTU(I)
    WQTY          -= [M:SOW]WQTYSTU(I)
    WSTJQTY       += [M:SOW]WQTYSTU(I)
    I += 1
  Endif
Endif
Return

$CTRL_STOCK
WRET=0
# Inventaire en cours
If [F:STO1]CUNLOKFLG=2
   If !find(GSTJINFO,1,3,5,7,9,11,13,15) GSTJINFO+=1 Endif
   WRET=1
# Statut non autorisé
Elsif !evalue(WCRITSTO)
   If !find(GSTJINFO,2,3,6,7,10,11,14,15) GSTJINFO+=2 Endif
   WRET=1
# Demande d'analyse en cours
Elsif [F:STO1]QLYCTLDEM<>""
  If !find(GSTJINFO,4,5,6,7,12,13,14,15) GSTJINFO+=4 Endif
  WRET=1
Endif
Return
#--- End issue 110327

########################################################################
# OUVSOR        Contrôle ouverture fenêtre saisie des sorties avec
#               - pas d'ouverture de la fenêtre
#                 si les éléments saisis dans la ligne de pièce sont
#                    suffisants pour déterminer le stock à sortir
#                    étiquette RECH_STOCK
#                 ou appel algo de détermination du stock à sortir
#                    sous-programme GENSTOSORW
#               - ouverture de la fenêtre
#                    exécution de l'action SAISTOSOR
#
########################################################################
# Prérequis    : L'écran de travail STOSORW [SOW] doit être ouvert
#
########################################################################
# Paramètres E : LABR  = Abréviation écran
#                LNOL  = No ligne écran (nolign-1)
#                LNBL  = Nombre lignes écran
#                LLIG  = Lien avec ligne document [M:XXX]WSTOSEQ(nolign-1)
#                LAUTO = Détermination automatique du stock à sortir (M.1)
#            S : LRET  = Code retour : 0 = pas d'ouverture
#                                          pas d'exécution action SAISTOSOR
#                                      1 = ouverture
#                                          exécution action SAISTOSOR
#                                     99 = erreur
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP    = Type mouvement(M.704)
#                [M:ALP]TRSCOD    = Code mouvement
#                [M:ALP]VCRTYP    = Type pièce (M.701)
#                [M:ALP]STOFCY    = Site stock
#                [M:ALP]ITMREF    = Article
#                [M:ALP]PCU       = Unité conditionnement
#                [M:ALP]PCUSTUCOE = Coefficient UC/US
#                [M:ALP]QTY       = Quantité
#                [M:ALP]TYPQTY    = Type de quantité : 1=US/2=UA (M.720)
#                [M:ALP]BESDAT    = Date besoin
#                [M:ALP]DLVDAT    = Date livraison
#                [M:ALP]ALLDAT    = Date fin réservation client
#                [M:ALP]STOLOC    = Emplacement poste de charge
#                                   à renseigner si OF ou suivi matière
#                [M:ALP]PECINTLOC = Prise en compte emp interne
#                [M:ALP]PECSCOLOC = Prise en compte emp sous-traitant (M.1)
#                                   mettre 2 si s-traitance (OF/EO/Suivi matière)
#                [M:ALP]PECPLFLOC = Prise en compte emp en attente de rangement
#                [M:ALP]PECCUNLOK = Prise en compte stock en cours d'inventaire (M.1)
#                                   mettre à 2 si allocation (commande ou OF)
#                [M:ALP]PECQLYCTL = Prise en compte stocks avec demande d'analyse
#                                   mettre à 1 si sortie de stock
#                                   mettre à 2 sinon (chgt emplacement, modif stock)
#                [M:ALP]PECOWNER  = Propriétaire du stock
#                                   à renseigner si sortie du stock d'un tiers
#                                   (suivi OF: opération s-trait (chez s-trait))
#                                   (retour réception sous-traitance)
#                [M:ALP]FILSTO    = Filtre sur les lignes de stock
#                                   le filtre doit être exprimé avec la classe [F:STO1]
#                [M:ALP]LOT       = Filtre lot ligne document
#                [M:ALP]LOC       = Filtre emplacement ligne document
#                [M:ALP]STA       = Filtre statut ligne document
#                                   sous la forme : "A1*,A20"
#                [M:ALP]WRH       = Dépôt ligne document
#                [M:ALP]AUZSST    = S-statuts autorisés sur emplacement à réappro
#                                   à renseigner si réappro zones de consommation
#                [M:ALP]LOCCAT    = Catégorie emplacement à réapprovisionner
#                                   à renseigner si réappro zones de consommation
#                [M:ALP]BPRNUM    = Client pour récupérer le coeff de DLU
#                #--- TS 106217
#                [M:ALP]ECCVALMAJ = Version majeure ligne document
#                ---------------------------------------------------------
#                A alimenter si pièce déjà créée (Livraison, retour achat)
#                [M:ALP]VCRNUM     = Numéro pièce
#                [M:ALP]VCRLIN     = No ligne pièce
#                [M:ALP]VCRSEQ     = No séquence pièce
#                ---------------------------------------------------------
# NEW            A alimenter si allocation pièce origine à prendre en compte
#                Utiliser uniquement pour conso matières en mode ADC (alloc OF)
#                [M:ALP]VCRTYPORI  = Type pièce origine
#                [M:ALP]VCRNUMORI  = Numéro pièce origine
#                [M:ALP]VCRLINORI  = No ligne pièce origine
#                [M:ALP]VCRSEQORI  = No séquence pièce origine
#
########################################################################
Subprog OUVSOR(LABR,LNOL,LNBL,LLIG,LAUTO,LRET)
Value    Char     LABR
Value    Integer  LNOL
Value    Integer  LNBL
Value    Integer  LLIG
Value    Integer  LAUTO
Variable Integer  LRET

Local    Integer  LRUP           : # 1 = génération de ruptures

Local    Integer  LIND1          : # Indice pour récupérer sections ana document
                                   # 0 : section entête, nolign : section ligne
Local    Integer  LIND2          : # Indice tableau sections analytiques
Local    Char     LANA(GLONCDE)  : # Code section analytique par défaut

Local    Integer  WTRBEGIN
Local    Integer  I,J,K,WRET, WRETADC, WSRETADC
Local    Integer  WTRT    : # 1=écriture STOSORW à partir des infos saisies
                            # 2=exécution GENSTOSORW
                            # 3=ouverture fenêtre saisie
Local    Char     LABRMSK
Local    Char     WSERNUM(GLONSER), WSER(GLONSER)
Local    Char     WSERNUMF(GLONSER)
Local    Char     WLOT(GLONLOT)
Local    Char     WSLO(GLONSLO)
Local    Char     WLOC(GLONLOC)
Local    Char     WSTA(GLONSTA)
Local    Char     WPALNUM(GLONPAL)
Local    Char     WCTRNUM(GLONCTR)
Local    Char     WWRH(GLONWRH)
Local    Char     WLPNNUM(GLONLPN)   : #--- Issue X3-53322
Local    Date     WDAT
Local    Date     WDATPER
Local    Char     WCRIT(240), WCRITLOT(180), WCRITSTO(240)    : # TS 106217 WCRIT(180) --> WCRIT(240)
Local    Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local    Decimal  WQTY, WQTYSTU, WQTYSTUACT, WDIMQTY
Local    Decimal  LSTOCOU
Local    Decimal  LWIPQTY, LWIPQTA, WNEWQTY, WNEWQTA
Local    Decimal  WALPQTY  : # Sauvegarde qté à traiter
Local    Decimal  WALLQTA, WALLQTY
Local    Decimal  WALPQTYD
Local    Integer  WNBSERIE, WNBSERIED
Local    Integer  WWSTA, WWLOC
#--- Issue 107033
Local    Decimal  WALLQTYSVG
#--- Issue 110327
Local    Char     WSERNUMSVG(GLONSER)
Local    Decimal  WNBSER, WSTOCOU
#---
#DLU client
Local Char     NBDAY(10)
Raz NBDAY
Raz WTRBEGIN
Raz WRET, WRETADC, WSRETADC
# Par défaut, on n'ouvre pas la fenêtre de saisie des sorties
Raz GOUVSOR

#--- Bug 89470
GPOINT="OUV_ALLPAR"
Gosub ENTREE From EXEFNC
#---

# Si ligne existante(déjà créée) et sans lien avec STOSORW
If evalue("[M:"+LABR+"]CREFLG(LNOL)")<>0 & LLIG=0
   #--- Issue 107033
   # Svg qté allouée global car elle sera cassée par Call ALLSTOSORW
   WALLQTYSVG=[M:ALP]ALLQTY
   #---
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
   Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
   If LRET<>0 LRET=99 : End Endif
   # Chargement STOSORW à partir des allocations
   Call ALLSTOSORW(LABR,LNOL,LNBL,0,0,0,LRET) From STKSOR
   #--- Issue 107033
   [M:ALP]ALLQTY=WALLQTYSVG
   #---
   If LRET<>0 LRET=99 : End Endif
Endif

# Date de référence pour la péremption des lots
WDAT = [M:ALP]DLVDAT
If WDAT=[0/0/0] WDAT=[M:ALP]BESDAT Endif

Raz WTRT
LABRMSK = "[M:"+LABR+"]"
LRET = 0

If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
If clalev([F:ITV]) =0  Local File ITMMVT     [ITV]   Endif
If clalev([F:SRU]) =0  Local File TABSTORUL  [SRU]   Endif
If clalev([F:STO1])=0  Local File STOCK      [STO1]  Endif
If clalev([F:STL1])=0  Local File STOLOT     [STL1]  Endif
If clalev([F:SWW]) =0  Local File STOWIPW    [SWW]   Endif
#--- TS 106217
If clalev([F:ECS]) =0  Local File ECCSTA     [ECS]   Endif
#DLUBPC
If clalev([F:ITU]) =0  Local File ITMBPC [ITU]   Endif
If GWRHACT=2
   If clalev([F:ITW]) =0  Local File ITMWRH    [ITW] Endif
   If clalev([F:WRH]) =0  Local File WAREHOUSE [WRH] Endif
Endif

# Lecture article et article-site
If [F:ITM]ITMREF<>[M:ALP]ITMREF
   Read [ITM]ITM0=[M:ALP]ITMREF
   If fstat
      Call RSTA("ITM",[M:ALP]ITMREF) From GLOCK
      LRET=99 : End
   Endif
Endif

Read [ITF]ITF0=[F:ITM]ITMREF;[M:ALP]STOFCY
If fstat
   Call RSTA("ITF",[F:ITM]ITMREF-[M:ALP]STOFCY) From GLOCK
   LRET=99 : End
Endif

#DLU Client
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALP]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALP]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif

#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif


# 61120 deb
#Read [ITV]ITV0=[F:ITM]ITMREF;[M:ALP]STOFCY
#If fstat
#   Call RSTA("ITV",[F:ITM]ITMREF-[M:ALP]STOFCY) From GLOCK
#   LRET=99 : End
#Endif
Local Integer WRET
   # Si pas de transaction en cours
If adxlog<>1
   Trbegin [ITV]
   WTRBEGIN=1
Endif
Call LECITV([M:ALP]STOFCY,[F:ITM]ITMREF,"",WRET) From STKLIB
   # Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif
# 61120 fin

# Article non géré en stock
If [F:ITF]STOMGTCOD=1 End Endif

# Pas de ligne
If [M:SOW]NBLIG=0 LLIG=0 Endif

# Cette ligne de document n'a pas encore de lien avec STOSORW
If LLIG=0
   WQTY=0
   # Initialisation zone lien avec ligne document [M:'LABR']WSTOSEQ(LNOL)
   Call STKWSTOSEQ(LABR,LNOL,LNBL,1,LLIG,LRET) From STKECR
   If LRET<>0 LRET=99 : End Endif
Else
   # Quantité stockée dans STOSORW (en US ou UA selon le type de quantité)
   If [M:ALP]TYPQTY=1
      WQTY=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=LLIG)))
   Else
      WQTY=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTUACT(I)*([M:SOW]WSTOSEQ(I)=LLIG)))
   Endif
Endif

#--- Demande 34639 (ADC)
# Exploitation saisie discontinue de no série pour une même ligne de document
If dim(GSERIALADC)>0 & GSERIALADC<>"" & [M:SOW]NBLIG<>0
   # Lecture de la règle de gestion pour le mouvement à traiter
   Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",WRET) From STKLIB
   If WRET<>0 : GOUVSOR=1 : End : Endif
   # Stockage dans WCRITSTO des statuts/sous-statuts autorisés
   Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL
   # Si pas de transaction en cours
   If adxlog<>1
      Trbegin [STO1]
      WTRBEGIN=1
   Endif
   I=[M:SOW]NBLIG
   WSERNUM=GSERIALADC
   While WSERNUM<=GSERIALADCF
      #--- Issue 120932
      #Readlock [STO1]STO5=[M:SMO1]ITMREF(LNOL);WSERNUM
      Readlock [STO1]STO5=[M:ALP]ITMREF;WSERNUM
      #---
      If fstat
         WRET=1 : WRETADC+=2 : Break
      Endif
      #- ADC -----------------
      Raz [L]WALLQTA, [L]WALLQTY
      If [F:STO1]CUMALLQTA<>0 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>""
         Read [STA]STA1=[M:ALP]VCRTYPORI;[M:ALP]VCRNUMORI;[M:ALP]VCRLINORI;
&                       [M:ALP]VCRSEQORI;[F:STO1]STOCOU
         If !fstat
            [L]WALLQTA += [F:STA]QTYSTUACT
            [L]WALLQTY += [F:STA]QTYSTU
         Endif
      Endif
      #-----------------------
      # Stock disponible ?
      Call STODISSOR("[F:STO1]","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
      #- ADC -----------------
      [L]WSTUACTDIS += [L]WALLQTA
      [L]WSTUDIS    += [L]WALLQTY
      #-----------------------
      If WSTUACTDIS < 1
         WRET=1 : WRETADC+=512 : Break
      Endif
      # Inventaire en cours
      If [F:STO1]CUNLOKFLG=2
         WRET=1 : WRETADC+=32 : Break
      Endif
      # Stock avec demande d'analyse
      If [M:ALP]PECQLYCTL<>2 & [F:STO1]QLYCTLDEM<>""
         WRET=1 : WRETADC+=128 : Break
      Endif

      #--- TS 106217
      # Contrôle de la version de l'allocation par rapport à la règle de gestion
      Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",WRET)
      If WRET<>0
        WRET=1 : Raz GMESSAGE : WRETADC+=1024 : Break
      Endif
      #---

      # Contrôle de la péremption
      If [F:SRU]SHLLOT<>3       # hcb v6dlu  Nouvelle gestion
         If [F:STO1]LOT<>[F:STL1]LOT & [F:STO1]SLO<>[F:STL1]SLO
            Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
            If fstat
               WRET=1 : WRETADC+=4 : Break
            #DLUBPC
            Elsif ([F:SRU]SHLLOT=2 & [F:STL1]DLUDAT<>[0/0/0] & [F:STL1]DLUDAT-val(NBDAY)<WDAT) |
&                 ([F:SRU]SHLLOT=1 & [F:STL1]SHLDAT<>[0/0/0] & [F:STL1]SHLDAT<WDAT)
               WRET=1 : WRETADC+=16 : Break
            Endif
         Endif
      Endif
      # Contrôle des statuts/sous-statuts autorisés
      If !evalue(WCRITSTO)
         WRET=1 : WRETADC+=64 : Break
      Endif
      # Contrôle de l'emplacement
      If [F:STO1]LOCCAT=3
&      |([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
&      |([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
&      |([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
         WRET=1 : WRETADC+=256 : Break
      Endif
      # Contrôle dépôt
      If GWRHACT=2 & [M:ALP]WRH<>""
         If [F:STO1]WRH<>[M:ALP]WRH
            WRET=1 : WRETADC+=256 : Break
         Endif
      Endif

      #- ADC -----------------
      [L]WALLQTA = min([L]WALLQTA,[L]WSTUACTDIS)
      [L]WALLQTY = min([L]WALLQTY,[L]WSTUDIS)
      If [L]WALLQTA<[L]WSTUACTDIS
         # Création quantité en cours de traitement
         [L]LSTOCOU = [F:STO1]STOCOU
         [L]LWIPQTY = [L]WSTUDIS   -[L]WALLQTY
         [L]LWIPQTA = [L]WSTUACTDIS-[L]WALLQTA
         Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         [F:STO1]CUMWIPQTY += [L]LWIPQTY
         [F:STO1]CUMWIPQTA += [L]LWIPQTA
      Endif
      #[F:STO1]CUMWIPQTY += WSTUDIS
      #[F:STO1]CUMWIPQTA += WSTUACTDIS
      # Création quantité en cours de traitement
      #LSTOCOU = [F:STO1]STOCOU
      #LWIPQTY = WSTUDIS
      #LWIPQTA = WSTUACTDIS
      #Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
      #-----------------------
      Rewrite [STO1]
      If fstat
         Call FSTA("STO1") From GLOCK
         WRET=1 : Break
      Endif
      # Alimentation STOSORW
      [M:SOW]WSTOSEQ(I)    = LLIG
      [M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
      [M:SOW]WQTYSTU(I)    = WSTUDIS
      [M:SOW]WQTYSTUACT(I) = WSTUACTDIS
      #- ADC -----------------
      [M:SOW]WALLSTU(I)    = [L]WALLQTY
      [M:SOW]WALLSTUACT(I) = [L]WALLQTA
      #[M:SOW]WALLSTU(I)    = 0
      #[M:SOW]WALLSTUACT(I) = 0
      #-----------------------
      Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
      Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)
      # Transfert zones de la ligne de document vers l'écran STOSORW
      GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC
      Call PLUS_UN(WSERNUM,WSER,WRET) From STKLIB
      If WRET<>0 Break Endif
      WSERNUM = WSER
      I += 1
   Wend
   If WRET<>0
      If I>0
         For J=[M:SOW]NBLIG To I-1
            Call DEL_STOWIPW([M:SOW]WSTOCOU(J),[M:SOW]WQTYSTUACT(J)) From STKLIB
            Raz [M:SOW]WSTOSEQ(J),[M:SOW]WSTOCOU(J)
            Raz [M:SOW]WQTYSTU(J),[M:SOW]WQTYSTUACT(J)
         Next J
      Endif
   Else
      [M:SOW]NBLIG=I
   Endif
   GOUVSOR = WRET
   # Si on a ouvert une transaction
   If WTRBEGIN=1
      Commit
      Raz WTRBEGIN
   Endif

   # Si terminaux portables, récupération du niveau d'erreur
   If GVTMOD=1 & WRET=1
      LRET = WRETADC
   Endif

   End
Endif
#---

# Si la quantité stockée dans STOSORW est <> 0
If WQTY<>0
   # La quantité à sortir a été modifiée
   If WQTY<>[M:ALP]QTY
      # La quantité à sortir a diminué
      If WQTY > [M:ALP]QTY
         # Et elle est nulle
         If [M:ALP]QTY=0
            # Nettoyage écran de travail pour cette ligne
            Call DELSTOSORW(LNOL,LNOL,LABR,[M:ALP]STOFCY,LRET)
            # Tout c'est bien passé, c'est terminé
            If LRET=0
               End
               # Il y a eu un pb en lecture stock, appel à la saisie des sorties
            Else
               GOUVSOR=1 : LRET=1 : End
            Endif
         Else
            # J = Nb SOW stock de la ligne / K = Nb SOW rupture de la ligne
            J = sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WSTOSEQ(I)=LLIG))
            K = sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WSTOSEQ(I)=LLIG & [M:SOW]WSTOCOU(I)=0))
            # Il y a au moins 2 ligne de stock --> ouverture du détail
            #--- Issue 110327
            If J-K>1 | [F:ITM]SERMGTCOD=4
            #If J-K>1
            #---
               GOUVSOR=1 : LRET=1 : End
            Endif
            # Quantité à diminuer
            WDIMQTY = WQTY-[M:ALP]QTY
            # Il y a au mois une ligne de rupture, on la (les) traite
            If K>0
               J = find(LLIG,[M:SOW]WSTOSEQ(0..[M:SOW]NBLIG-1))
               I = J-1
               K = J
               While WDIMQTY>0 & J<>0
                  If [M:SOW]WSTOCOU(I)=0
                     If WDIMQTY>=[M:SOW]WQTYSTUACT(I)
                        WDIMQTY-=[M:SOW]WQTYSTUACT(I)
                        Raz [M:SOW]WSTOSEQ(I),[M:SOW]WPLFSTO(I)
                        Raz [M:SOW]WLOT(I),[M:SOW]WSLO(I),[M:SOW]WLOC(I)
                        Raz [M:SOW]WWRH(I),[M:SOW]WSTA(I),[M:SOW]WSERNUM(I)
                        Raz [M:SOW]WQTYSTU(I),[M:SOW]WQTYSTUACT(I)
                        Raz [M:SOW]WALLSTU(I),[M:SOW]WALLSTUACT(I)
                        #--- TS 106217
                        Raz [M:SOW]WECCVALMAJ(I)
                     Else
                        [M:SOW]WQTYSTU(I)   -= WDIMQTY
                        [M:SOW]WQTYSTUACT(I)-= WDIMQTY
                        WDIMQTY=0
                     Endif
                  Endif
                  J = find(LLIG,[M:SOW]WSTOSEQ(K..[M:SOW]NBLIG-1))
                  I = J+K-1
                  K+= J
               Wend
            Endif
            # Il reste de la quantité à diminuer (sur la ligne de stock)
            If WDIMQTY>0
               # Recherche de la ligne de stock
               I=find(LLIG,[M:SOW]WSTOSEQ(0..[M:SOW]NBLIG-1))
               # Calcul de la nouvelle quantité de la ligne
               WNEWQTY = [M:SOW]WQTYSTU(I-1)   -WDIMQTY
               WNEWQTA = [M:SOW]WQTYSTUACT(I-1)-WDIMQTY

               # Si pas de transaction en cours
               If adxlog<>1
                  Trbegin [STO1]
                  WTRBEGIN=1
               Endif
               Readlock [STO1]STO0=[M:ALP]STOFCY;[M:SOW]WSTOCOU(I-1)
               If fstat
                  Call RSTA("STO1",[M:ALP]STOFCY-num$([M:SOW]WSTOCOU(I-1))) From GLOCK
                  WRET=1 : Goto OUVSOR_SUI
               Endif
               If find([F:ITF]STOMGTCOD,3,4)
                  Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
               Endif

               # Si quantité en US
               If [M:ALP]TYPQTY=1
                  # Si gestion en titres ou UI, calcul quantité en UA
                  Case [F:ITF]STOMGTCOD
                   When 3 : If [F:STL1]POT<>0
                               WNEWQTA = WNEWQTY*([F:STL1]POT/100)
                            Endif
                   When 4 : If [F:STL1]ACT<>0
                               WNEWQTA = WNEWQTY* [F:STL1]ACT
                            Endif
                  Endcase
               # Si quantité en UA
               Else
                  # Si gestion en titres ou UI, calcul quantité en UA
                  Case [F:ITF]STOMGTCOD
                   When 3 : If [F:STL1]POT<>0
                               WNEWQTY = WNEWQTA/([F:STL1]POT/100)
                            Endif
                   When 4 : If [F:STL1]ACT<>0
                               WNEWQTY = WNEWQTA/ [F:STL1]ACT
                            Endif
                  Endcase
               Endif

               If [M:SOW]WALLSTU(I-1)>=WNEWQTY
                  [F:STO1]CUMWIPQTY -= [M:SOW]WQTYSTU(I-1)   -[M:SOW]WALLSTU(I-1)
                  [F:STO1]CUMWIPQTA -= [M:SOW]WQTYSTUACT(I-1)-[M:SOW]WALLSTUACT(I-1)
                  LSTOCOU = [F:STO1]STOCOU
                  LWIPQTY = [M:SOW]WQTYSTU(I-1)-[M:SOW]WALLSTU(I-1)
                  Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
                  [M:SOW]WQTYSTU(I-1)    = WNEWQTY
                  [M:SOW]WQTYSTUACT(I-1) = WNEWQTA
                  [M:SOW]WALLSTU(I-1)    = WNEWQTY
                  [M:SOW]WALLSTUACT(I-1) = WNEWQTA
               Else
                  [F:STO1]CUMWIPQTY -= [M:SOW]WQTYSTU(I-1)   -WNEWQTY
                  [F:STO1]CUMWIPQTA -= [M:SOW]WQTYSTUACT(I-1)-WNEWQTA
                  LSTOCOU = [F:STO1]STOCOU
                  LWIPQTY = [M:SOW]WQTYSTU(I-1)   -WNEWQTY
                  LWIPQTA = [M:SOW]WQTYSTUACT(I-1)-WNEWQTA
                  Call DIM_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
                  [M:SOW]WQTYSTU(I-1)    = WNEWQTY
                  [M:SOW]WQTYSTUACT(I-1) = WNEWQTA
               Endif
               Rewrite [STO1]

               # Si on a ouvert une transaction
               If WTRBEGIN=1
                  Commit
                  Raz WTRBEGIN
               Endif
            Endif

            $OUVSOR_SUI
            If WRET=1
               # Il y a eu un pb en lecture stock, appel à la saisie des sorties
               GOUVSOR=1 : LRET=1 : Raz WRET : End
            Else
               # La diminution de quantité a été traitée, c'est terminé
               LRET=0 : End
            Endif
         Endif
      # La qté a augmenté et pas de détermination auto, appel à la saisie des sorties
      Elsif LAUTO<>2
         GOUVSOR=1 : LRET=1 : End
      # La quantité a augmenté et détermination auto
      Else
         WRET=1
         Goto OUVSOR_SUI2
      Endif
   # La quantité n'a pas été modifiée, rien à faire
   Else
      LRET=0 : Goto OUVSOR_FIN
   Endif
Endif

Raz WRET

# Recherche du stock correspondant aux infos saisies dans
# la ligne document pour stockage dans écran travail STOSORW
Gosub RECH_STOCK

# Si pb code activité SOW, on force l'ouverture de la fenêtre
If WRET=2
   # Ouverture fenêtre de saisie des sorties (action SAISTOSOR)
   GOUVSOR=1 : LRET=1  : Goto OUVSOR_FIN
Endif

$OUVSOR_SUI2

# Si infos saisies insuffisantes,
If WRET<>0
   # Détermination automatique
   If LAUTO=2
      WALPQTY = [M:ALP]QTY
      [M:ALP]QTY -= [L]WQTY
      # Raz [M:ALP]ALLQTY
      Raz LRUP
      # Génération de ruptures si stock négatif autorisé et
      # on n'est pas dans un flux de réapprovisionnement
      If [F:ITM]NEGSTO=2 & [M:ALP]TRSTYP<>25 LRUP=1 Endif
      # Détermination du stock à sortir et stockage dans STOSORW
      Call GENSTOSORW(LABR,LNOL,LNBL,LRUP,"C",WRET)
      # Erreur en détermination automatique
      If WRET<>0
         [M:ALP]QTY = WALPQTY
         GOUVSOR=1 : LRET=99 : Goto OUVSOR_FIN
      # La quantité n'a pas été entièrement traitée
      Elsif [M:ALP]QTY > [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
         [M:ALP]QTY = WALPQTY
         GOUVSOR=1 : LRET=1  : Goto OUVSOR_FIN
      Endif
      [M:ALP]QTY = WALPQTY
   # Détermination manuelle
   Else
      # Ouverture fenêtre de saisie des sorties (action SAISTOSOR)
      GOUVSOR=1 : LRET=1  : Goto OUVSOR_FIN
   Endif
Endif

$OUVSOR_FIN

#--- Bug 83893
If !find(LABR,"REO1","PNH1")
   #--- Issue 110327
   # Si pas d'ouverture de la fenêtre de saisie et no série en sortie sans compteur
   # ou no série en E/S globale
   #If GOUVSOR=0 & [F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU=""
   If GOUVSOR=0 & (([F:ITM]SERMGTCOD=2 & [F:ITM]SERCOU="") | [F:ITM]SERMGTCOD=4)
   #---
      # Si des no série ne sont pas renseignés, ouverture de la fenêtre
      For I=0 To [M:SOW]NBLIG-1
         If [M:SOW]WSTOSEQ(I)=LLIG & [M:SOW]WSTOCOU(I)<>0 & [M:SOW]WSERNUM(I)=""
            GOUVSOR=1 : Break
         Endif
      Next I
   Endif
#--- Bug 83893
Endif

# Si pas d'ouverture de la fenêtre de saisie
If GOUVSOR=0
   # Alimentation des zones stock de la ligne document
   # à partir de l'écran STOSORW
   Call RECSTOSOR (3,LABR,LNOL,[M:ALP]STOFCY,[M:ALP]ITMREF,
&                  [M:ALP]VCRTYP,"",0,"",WRET) From STKECR
# Si ouverture de la fenêtre de saisie
Elsif GOUVSOR=1
   # Réaffectation (Diszo) de l'état des zones stock du document
   Call ETAZONSORL(LABR,LNOL) From STKECR2
Endif


# Si terminaux portables, récupération du niveau d'erreur
If GVTMOD=1 & WRET=1
   LRET = WRETADC
Endif

#########
# A Voir
#########
#If evalue("dim([M:"+LABR+"]UPDCOD)")>=0
#   Assign "[M:"+LABR+"]UPDCOD(LNOL)" With 1
#Endif

End

################################################################################
# Détermination du traitement à réaliser suite à saisie ligne document
# En sortie WTRT = 1 : Exploitation des infos saisies dans la ligne de document
#                      pour stockage dans écran travail STOSORW
#                  2 : Détermination du stock à sortir et stockage dans STOSORW
#                  3 : Ouverture fenêtre de saisie sorties (action SAISTOSOR)
################################################################################
$DETERMINE_TRT

# Par défaut, fenêtre de saisie des sorties
WTRT=3

#--- Issue 110327
# No séries en E/S ou en E/S globale
#If [F:ITM]SERMGTCOD=3
If [F:ITM]SERMGTCOD>=3
#---
   # No série présent dans ligne document
   If evalue("dim([M:"+LABR+"]SERNUM(LNOL))")>0
      # No série renseigné
      If evalue("[M:"+LABR+"]SERNUM(LNOL)")<>""
         WTRT=1
      Else
         If LAUTO=2 WTRT=2 Endif
      Endif
   Else
      If LAUTO=2 WTRT=2 Endif
   Endif
# No séries en sortie
Elsif [F:ITM]SERMGTCOD=2
   # Détermination automatique du stock à sortir
   If LAUTO=2
#      # Compteur série ou no série présent dans ligne document et renseigné
#      If [F:ITM]SERCOU<>"" |
#&        (evalue("dim([M:"+LABR+"]SERNUM(LNOL))")>=0
#&        &evalue("[M:"+LABR+"]SERNUM(LNOL)")<>"")
#         WTRT=2
#      Endif
      WTRT=2
   # Exploitation des infos saisies dans la ligne du document
   # si insuffisante --> fenêtre de saisie des sorties
   Else
      WTRT=1
   Endif
# Pas de gestion des no séries
Else
   # Détermination automatique du stock à sortir
   If LAUTO=2
      WTRT=2
   # Exploitation des infos saisies dans la ligne du document
   # si insuffisante --> fenêtre de saisie des sorties
   Else
      WTRT=1
   Endif
Endif

Return

################################################################################
# Etiquette appelée par le traitement OUVSOR
# Recherche du stock correspondant aux infos saisies dans la ligne de document
# pour stockage dans écran travail STOSORW
################################################################################
$RECH_STOCK
# Lecture de la règle de gestion pour le mouvement à traiter
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",WRET) From STKLIB
If WRET<>0 : WRET=1 : Return : Endif

# Stockage dans WCRITSTO des statuts/sous-statuts autorisés
Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL

Raz WWSTA, WWLOC, WSTUACTDIS
# Statuts autorisés par la règle de gestion
If find([F:SRU]AUZSTA,1,3,5,7) WWSTA+=1 Endif
If find([F:SRU]AUZSTA,2,3,6,7) WWSTA+=2 Endif
If find([F:SRU]AUZSTA,4,5,6,7) WWSTA+=4 Endif
# Prise en compte emplacement en attente de rangement
If [M:ALP]PECPLFLOC=2 WWLOC+=1 Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WWLOC+=4 Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WWLOC=WWLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WWLOC,WWSTA,"",WSTUACTDIS) From STKLIB

# Issue 48252 TS 26/09/2017 - global allocated qty (limited to qty to be processed) is added
If GVTMOD<>1 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>"" & [M:ALP]ALLQTY<>0
   WSTUACTDIS += min([M:ALP]QTY,[M:ALP]ALLQTY)
Endif
#

# Si terminaux portables, rajout de la qté allouée sur la pièce origine
# au disponible (suivi matière sur OF alloué)
If GVTMOD=1 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>""
   For [STA]STA1 Where VCRTYP=[M:ALP]VCRTYPORI & VCRNUM=[M:ALP]VCRNUMORI &
&                      VCRLIN=[M:ALP]VCRLINORI & VCRSEQ=[M:ALP]VCRSEQORI &
&                      ITMREF=[F:ITM]ITMREF    & ALLTYP<3
      WSTUACTDIS += [F:STA]QTYSTUACT
   Next
Endif

If GVTMOD=1
   If WSTUACTDIS<[M:ALP]QTY
      WRET=1 : WRETADC+=512 : Return
   Else
      WALPQTYD=[M:ALP]QTY
   Endif
Else
   # Pas de stock disponible --> saisie manuelle ou détermination auto
   If WSTUACTDIS=0
      WRET=1 : WRETADC+=512 : Return
   # Stock disponible < quantité à traiter --> quantité à traiter = disponible
   Elsif WSTUACTDIS<[M:ALP]QTY
      WALPQTYD=WSTUACTDIS
   Else
      WALPQTYD=[M:ALP]QTY
   Endif
Endif

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

I=[M:SOW]NBLIG
Raz WQTY

# No séries en E/S
If [F:ITM]SERMGTCOD=3
   # Si pas de no série dans l'écran
   If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") <0 |
&     evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")<0
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   WSERNUM  = evalue("[M:"+LABR+"]SERNUM(LNOL)")
   WSERNUMF = evalue("[M:"+LABR+"]SERNUMF(LNOL)")
   # Si pas de no série saisi
   If WSERNUM=""
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   # Contrôle du nb de no série par rapport à la quantité
   WNBSERIE = val(ctrans(WSERNUMF,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            -val(ctrans(WSERNUM ,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            +1
   If WNBSERIE>[M:ALP]QTY
      WRET=1 : Goto RECH_STOCK_SUI
   Endif

   If I+WNBSERIE>dim([M:SOW]WSTOSEQ)
      Call ERREUR(mess(352,199,1)) From GESECRAN
      WRET=2 : Goto RECH_STOCK_SUI
   Endif

   WNBSERIED = min(WNBSERIE,WALPQTYD)
   If WNBSERIED<WNBSERIE
      Call PLUS_NB(WSERNUM,WNBSERIED,WSERNUMF,WRET) From STKLIB
      If WRET<>0 WRET=1 : Goto RECH_STOCK_SUI Endif
   Endif

   While WSERNUM<=WSERNUMF
      Readlock [STO1]STO5=[M:ALP]ITMREF;WSERNUM
      If fstat
         WRET=1 : Break
      Endif
      #- ADC -----------------
      Raz [L]WALLQTA, [L]WALLQTY
      If [F:STO1]CUMALLQTA<>0 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>""
         Read [STA]STA1=[M:ALP]VCRTYPORI;[M:ALP]VCRNUMORI;[M:ALP]VCRLINORI;
&                       [M:ALP]VCRSEQORI;[F:STO1]STOCOU
         If !fstat
            [L]WALLQTA += [F:STA]QTYSTUACT
            [L]WALLQTY += [F:STA]QTYSTU
         Endif
      Endif
      #-----------------------
      # Stock disponible ?
      Call STODISSOR("[F:STO1]","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
     #- ADC -----------------
      [L]WSTUACTDIS += [L]WALLQTA
      [L]WSTUDIS    += [L]WALLQTY
      #-----------------------
      If [L]WSTUACTDIS < 1
         WRET=1 : Break
      Endif

      #--- Issue 110327
      # Suppression de la séquence qui est maintenant dans CTRL_STO1
      Gosub CTRL_STO1
      If WRET=1 Break Endif
      #--- End Issue 110327

      #- ADC -----------------
      [L]WALLQTA = min([L]WALLQTA,[L]WSTUACTDIS)
      [L]WALLQTY = min([L]WALLQTY,[L]WSTUDIS)
      If [L]WALLQTA<[L]WSTUACTDIS
         # Création quantité en cours de traitement
         [L]LSTOCOU = [F:STO1]STOCOU
         [L]LWIPQTY = [L]WSTUDIS   -[L]WALLQTY
         [L]LWIPQTA = [L]WSTUACTDIS-[L]WALLQTA
         Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         [F:STO1]CUMWIPQTY += [L]LWIPQTY
         [F:STO1]CUMWIPQTA += [L]LWIPQTA
      Endif
      #[F:STO1]CUMWIPQTY += WSTUDIS
      #[F:STO1]CUMWIPQTA += WSTUACTDIS
      # Création quantité en cours de traitement
      #LSTOCOU = [F:STO1]STOCOU
      #LWIPQTY = WSTUDIS
      #LWIPQTA = WSTUACTDIS
      #Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
      #-----------------------
      Rewrite [STO1]
      If fstat
         Call FSTA("STO1") From GLOCK
         WRET=1 : Break
      Endif

      # Alimentation STOSORW
      [M:SOW]WSTOSEQ(I)    = LLIG
      [M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
      [M:SOW]WQTYSTU(I)    = WSTUDIS
      [M:SOW]WQTYSTUACT(I) = WSTUACTDIS
      #- ADC -----------------
      [M:SOW]WALLSTU(I)    = [L]WALLQTY
      [M:SOW]WALLSTUACT(I) = [L]WALLQTA
      #[M:SOW]WALLSTU(I)    = 0
      #[M:SOW]WALLSTUACT(I) = 0
      #-----------------------
      Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
      Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)
      #--- TS 106217
      Raz [M:SOW]WECCVALMAJ(I)

      # Transfert zones de la ligne de document vers l'écran STOSORW
      GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

      Call PLUS_UN(WSERNUM,WSER,WRET) From STKLIB
      If WRET<>0 Break Endif
      WSERNUM = WSER
      WQTY += 1
      I    += 1
   Wend

#--- Issue 110327
# Si article géré en E/S globale et no série début saisi
# Remarque : la saisie des séries dans la ligne document n'est pas obligatoire
# pour déterminer le stock : ils seront saisis ensuite (comme gestion en sortie)
#Elsif [F:ITM]SERMGTCOD=4 &
#&     evalue("dim([M:"+LABR+"]SERNUM(LNOL))")>0 &
#&     evalue("[M:"+LABR+"]SERNUM(LNOL)")<>""

Elsif [F:ITM]SERMGTCOD=4
   # Si pas de no série dans l'écran
   If evalue("dim([M:"+LABR+"]SERNUM(LNOL))") <0 |
&     evalue("dim([M:"+LABR+"]SERNUMF(LNOL))")<0
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   WSERNUM  = evalue("[M:"+LABR+"]SERNUM(LNOL)")
   WSERNUMF = evalue("[M:"+LABR+"]SERNUMF(LNOL)")
   # Si pas de no série saisi
   If WSERNUM=""
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   # Contrôle du nb de no série par rapport à la quantité
   WNBSERIE = val(ctrans(WSERNUMF,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            -val(ctrans(WSERNUM ,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            +1
   If WNBSERIE>[M:ALP]QTY
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   WNBSERIED = min(WNBSERIE,WALPQTYD)
   If WNBSERIED<WNBSERIE
      Call PLUS_NB(WSERNUM,WNBSERIED,WSERNUMF,WRET) From STKLIB
      If WRET<>0 WRET=1 : Goto RECH_STOCK_SUI Endif
   Endif

   While WSERNUM<=WSERNUMF
      Read [STS]STS0=[M:ALP]ITMREF;WSERNUM
      If fstat
        WRET=1 : Break
      # No série sur le même stock que le précédent
      Elsif [F:STS]STOCOU=WSTOCOU
        WNBSER+=1
        Goto SER_SUIV
      # C'est le premier no série
      Elsif WSTOCOU=0
        WSTOCOU=[F:STS]STOCOU
        WSERNUMSVG=WSERNUM
        WNBSER=1
        Goto SER_SUIV
      # Rupture chrono stock
      Else
        Gosub RUPT_STO1
        # Ligne de [SOW] non générée
        If WRET=1
          WQTY-=WNBSER
          WNBSER=0
          Break
        Endif
        # Ligne de [SOW] générée
        WSTOCOU=[F:STS]STOCOU
        WSERNUMSVG=WSERNUM
        WNBSER=1
        I+=1
        Goto SER_SUIV
      Endif

      $SER_SUIV
      WQTY += 1
      Call PLUS_UN(WSERNUM,WSER,WRET) From STKLIB
      If WRET<>0 Break Endif
      WSERNUM = WSER
   Wend

   # Traitement dernière rupture s'il y a un no série
   If WNBSER>0
     Gosub RUPT_STO1
     # Ligne de [SOW] non générée
     If WRET=1
        WQTY-=WNBSER
        WNBSER=0
     # Ligne de [SOW] générée
     Else
        I+=1
     Endif
   Endif
#--- End issue 110327

Else
   Raz WCRIT, WCRITLOT
   WCRITLOT='[F:STL1]ITMREF=[M:ALP]ITMREF'
   # L'article est géré par lot
   If [F:ITM]LOTMGTCOD<>1
      If evalue("dim([M:"+LABR+"]LOT(LNOL))")<0
         WRET=1 : Goto RECH_STOCK_SUI
      Endif
      If evalue("[M:"+LABR+"]LOT(LNOL)")=""
         WRET=1 : WRETADC+=4 : Goto RECH_STOCK_SUI
      Else
         WLOT=evalue("[M:"+LABR+"]LOT(LNOL)")
         WCRITLOT+='&[F:STL1]LOT=WLOT'
      Endif
      # L'article est géré par sous-lot
      If [F:ITM]LOTMGTCOD=4
         If evalue("dim([M:"+LABR+"]SLO(LNOL))")<0
            WRET=1 : Goto RECH_STOCK_SUI
         Endif
         If evalue("[M:"+LABR+"]SLO(LNOL)")=""
            WRET=1 : WRETADC+=8 : Goto RECH_STOCK_SUI
         Else
            WSLO=evalue("[M:"+LABR+"]SLO(LNOL)")
            WCRITLOT+='&[F:STL1]SLO=WSLO'
         Endif
      Endif
      # Contrôle de la péremption
      If [F:SRU]SHLLOT<>3   # hcb V6dlu nouvelle gestion
         If [F:SRU]SHLLOT=2
            WCRITLOT+='&([F:STL1]DLUDAT=[0/0/0]|[F:STL1]DLUDAT'+NBDAY+'>=WDAT)'
         Else
            WCRITLOT+='&([F:STL1]SHLDAT=[0/0/0]|[F:STL1]SHLDAT>=WDAT)'
         Endif
      Endif
   Endif

   WCRIT='[F:STO1]CUNLOKFLG<>2'

   #--- TS le 07.01.04 --- Demande 27154 (Version 150)
   # L'article est géré avec emplacement
   If [F:ITF]LOCMGTCOD=2
     #--- Issue X3-53322
     # mais pas avec contenant
     If [F:ITF]LPNMGTCOD<>2
     #---
       # L'article est géré par lot
       If [F:ITM]LOTMGTCOD<>1
         # Pec de l'emplacement s'il est renseigné
         If evalue("dim([M:"+LABR+"]LOC(LNOL))")>0
            If evalue("[M:"+LABR+"]LOC(LNOL)")<>""
               WLOC=evalue("[M:"+LABR+"]LOC(LNOL)")
               WCRIT+='&[F:STO1]LOC=WLOC'
            Endif
         Endif
       # L'article n'est pas géré par lot
       # L'emplacement ou PALNUM ou CTRNUM est obligatoire
       Else
         If evalue("dim([M:"+LABR+"]LOC(LNOL))")<0
            If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")<0
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Elsif evalue("[M:"+LABR+"]PALNUM(LNOL)")=""
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Endif                                   : # PALNUM est renseigné
         Elsif evalue("[M:"+LABR+"]LOC(LNOL)")=""
            If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")<0
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Elsif evalue("[M:"+LABR+"]PALNUM(LNOL)")=""
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Endif                                   : # PALNUM est renseigné
         # Prise en compte de l'emplacement
         Else
            WLOC=evalue("[M:"+LABR+"]LOC(LNOL)")
            WCRIT+='&[F:STO1]LOC=WLOC'
         Endif
       Endif
     #--- Issue X3-53322
     # L'article est géré avec contenant --> on exploite le contenant
     # si renseigné, on prend le stock correspondant
     # si non renseigné on ne filtre pas sur le no contenant
     Else
       # L'article est géré par lot
       If [F:ITM]LOTMGTCOD<>1
         # Pec du contenant s'il est renseigné
         If evalue("dim([M:"+LABR+"]LPNNUM(LNOL))")>0 & evalue("[M:"+LABR+"]LPNNUM(LNOL)")<>""
            WLPNNUM=evalue("[M:"+LABR+"]LPNNUM(LNOL)")
            WCRIT+='&[F:STO1]LPNNUM=WLPNNUM'
         # Pec de l'emplacement s'il est renseigné
         Elsif evalue("dim([M:"+LABR+"]LOC(LNOL))")>0 & evalue("[M:"+LABR+"]LOC(LNOL)")<>""
            WLOC=evalue("[M:"+LABR+"]LOC(LNOL)")
            WCRIT+='&[F:STO1]LOC=WLOC'
         Endif
       # L'article n'est pas géré par lot
       # Le contenant ou l'emplacement ou PALNUM ou CTRNUM est obligatoire
       Else
         # Pec du contenant s'il est renseigné
         If evalue("dim([M:"+LABR+"]LPNNUM(LNOL))")>0 & evalue("[M:"+LABR+"]LPNNUM(LNOL)")<>""
            WLPNNUM=evalue("[M:"+LABR+"]LPNNUM(LNOL)")
            WCRIT+='&[F:STO1]LPNNUM=WLPNNUM'
         # Pec de l'emplacement s'il est renseigné
         Elsif evalue("dim([M:"+LABR+"]LOC(LNOL))")>0 & evalue("[M:"+LABR+"]LOC(LNOL)")<>""
            WLOC=evalue("[M:"+LABR+"]LOC(LNOL)")
            WCRIT+='&[F:STO1]LOC=WLOC'
         Else
            If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")<0
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Elsif evalue("[M:"+LABR+"]PALNUM(LNOL)")=""
               If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif evalue("[M:"+LABR+"]CTRNUM(LNOL)")=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Endif                                   : # PALNUM est renseigné
         Endif
       Endif
     Endif
     #--- End issue X3-53322
   Endif

   Raz J
   #--- TS 106217
   # Si version renseignée et exclusive
   If [M:ALP]ECCVALMAJ<>"" & [F:SRU]ORDVER=2
      WCRIT += '&[F:STO1]ECCVALMAJ=[M:ALP]ECCVALMAJ'
   Endif
   #---
   # Prise en compte du dépôt s'il est renseigné
   If GWRHACT=2 & [M:ALP]WRH<>""
      WCRIT+='&[F:STO1]WRH=[M:ALP]WRH'
   Endif
   # Prise en compte du statut s'il est renseigné
   If evalue("dim([M:"+LABR+"]STA(LNOL))")>0
      If evalue("[M:"+LABR+"]STA(LNOL)")<>""
         WSTA=evalue("[M:"+LABR+"]STA(LNOL)")
         WCRIT+='&[F:STO1]STA=WSTA'
      Endif
   Endif
   # Prise en compte de PALNUM s'il est renseigné
   If evalue("dim([M:"+LABR+"]PALNUM(LNOL))")>0
      If evalue("[M:"+LABR+"]PALNUM(LNOL)")<>""
         WPALNUM=evalue("[M:"+LABR+"]PALNUM(LNOL)")
         WCRIT+='&[F:STO1]PALNUM=WPALNUM'
         J=1
      Endif
   Endif
   # Prise en compte de CTRNUM s'il est renseigné
   If evalue("dim([M:"+LABR+"]CTRNUM(LNOL))")>0
      If evalue("[M:"+LABR+"]CTRNUM(LNOL)")<>""
         WCTRNUM=evalue("[M:"+LABR+"]CTRNUM(LNOL)")
         WCRIT+='&[F:STO1]CTRNUM=WCTRNUM'
         J=1
      Endif
   Endif
   # Prise en compte du OWNER
   If [M:ALP]PECOWNER=""
      WCRIT+='&[F:STO1]OWNER=[F:STO1]STOFCY'
   Else
      WCRIT+='&find([F:STO1]OWNER,[F:STO1]STOFCY,[M:ALP]PECOWNER)'
   Endif

   # Si ni gestion série,ni lot,ni emplacement et PALNUM ou CTRNUM non renseigné
   # on a pas les éléments nécessaires pour déterminer le stock à sortir
   # Dans ce cas, on force traitement auto pour utiliser l'algorithme.
   # Si pas de filtre statut, on exploite celui saisi
   If [F:ITM]LOTMGTCOD=1 & [F:ITF]LOCMGTCOD<>2 & J<>1
      #--- Si plusieurs ligne stocks, ouverture fenêtre
      Raz I
      For [STO1]STO3 Where ITMREF=[M:ALP]ITMREF & STOFCY=[M:ALP]STOFCY &
&                          evalue(WCRIT) & evalue(WCRITSTO)
         I += 1
         If I>1 Break Endif
      Next
      If I>1 WRET=1 : Goto RECH_STOCK_SUI Endif
      #---
      If [M:ALP]STA="" & WSTA<>""
         [M:ALP]STA = WSTA
      Endif
      WRET  = 1
      LAUTO = 2
      Goto RECH_STOCK_SUI
   Endif

   #Raz WQTY

   WALPQTY = WALPQTYD

   #--- Recherche du stock filtré sur l'unité du document
   # Lecture des lots
   For [STL1]STL0 Where evalue(WCRITLOT)
      #--- Issue X3-100756 : ajout de '& PCU=[M:ALP]PCU'
      For [STO1]STO3 Where ITMREF=[M:ALP]ITMREF & STOFCY=[M:ALP]STOFCY &
&                          LOT=[F:STL1]LOT & SLO=[F:STL1]SLO &
&                          evalue(WCRIT) & evalue(WCRITSTO) & PCU=[M:ALP]PCU

         #--- Issue X3-100756
         Gosub CONTROL_STO1
         If WRET=1
            WRET=0
            Goto STO1_SUIV
         Elsif WRET=2
            Break 2
         Endif
         #---
         # Suppression de ce qui est maintenant dans $CONTROL_STO1
         #---
         #--- End issue X3-100756

         If [L]WQTY>=WALPQTYD Break 2 Endif

      $STO1_SUIV
      Next
   Next

   #--- Issue X3-100756
   #--- Seconde recherche du stock différent de l'unité du document
   # Lecture des lots
   If [L]WQTY<WALPQTYD
     For [STL1]STL0 Where evalue(WCRITLOT)
       For [STO1]STO3 Where ITMREF=[M:ALP]ITMREF & STOFCY=[M:ALP]STOFCY &
&                           LOT=[F:STL1]LOT & SLO=[F:STL1]SLO &
&                           evalue(WCRIT) & evalue(WCRITSTO) & PCU<>[M:ALP]PCU
         Gosub CONTROL_STO1
         If WRET=1
           WRET=0
           Goto STO1_SUIV2
         Elsif WRET=2
           Break 2
         Endif
         If [L]WQTY>=WALPQTYD Break 2 Endif

       $STO1_SUIV2
       Next
     Next
   Endif
   #--- End isue X3-100756

Endif

[M:SOW]NBLIG=I

# La quantité n'a pas été entièrement traitée
If [L]WQTY<[M:ALP]QTY
   WRET=1
   If GVTMOD=1
      #--- TS 106217
      #WRETADC+=512
      #---
      # Nettoyage écran de travail pour cette ligne
      Call DELSTOSORW(LNOL,LNOL,LABR,[M:ALP]STOFCY,LRET)
   Endif
Endif

# Récupération des sections analytiques
#If LABR<>""
#   Case LABR
#    When "SDH1"               : LANA="STKLIV"
#    When "SIH4"               : LANA="STKFAC"
#    When "PNH1"               : LANA="STKPRT"
#    When "SMO1","DBY0","BBY1" : LANA="STJSOR"
#    When "MTK3","MBM"         : LANA="STKSOF"
#    When "SRE9","ITN8"        : LANA="STKHDT"
#   Endcase
#   Call STKINISEC (LLIG,LANA,"SOW") From STKECR
#Endif

$RECH_STOCK_SUI

# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif

Return

#--- Issue 110327
$RUPT_STO1
Readlock [STO1]STO0=[M:ALP]STOFCY;WSTOCOU
If fstat
  WRET=1 : Return
Endif
#- ADC -----------------
Raz [L]WALLQTA, [L]WALLQTY
If [F:STO1]CUMALLQTA<>0 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>""
  Read [STA]STA1=[M:ALP]VCRTYPORI;[M:ALP]VCRNUMORI;[M:ALP]VCRLINORI;
&                [M:ALP]VCRSEQORI;[F:STO1]STOCOU
  If !fstat
    [L]WALLQTA += [F:STA]QTYSTUACT
    [L]WALLQTY += [F:STA]QTYSTU
  Endif
Endif
#-----------------------
# Stock disponible ?
Call STODISSOR("[F:STO1]","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#- ADC -----------------
[L]WSTUACTDIS += [L]WALLQTA
[L]WSTUDIS    += [L]WALLQTY
#-----------------------
If [L]WSTUACTDIS<WNBSER
  WRET=1 : Return
Endif

Gosub CTRL_STO1
If WRET=1 Return Endif

#- ADC -----------------
[L]WALLQTA = min([L]WALLQTA,[L]WNBSER)
[L]WALLQTY = min([L]WALLQTY,[L]WNBSER)
If [L]WALLQTA<[L]WNBSER
  # Création quantité en cours de traitement
  [L]LSTOCOU = [F:STO1]STOCOU
  [L]LWIPQTY = [L]WNBSER-[L]WALLQTY
  [L]LWIPQTA = [L]WNBSER-[L]WALLQTA
  Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
  [F:STO1]CUMWIPQTY += [L]LWIPQTY
  [F:STO1]CUMWIPQTA += [L]LWIPQTA
Endif
Rewrite [STO1]
If fstat
  Call FSTA("STO1") From GLOCK
  WRET=1 : Return
Endif
# Création no série en cours de traitement
If [F:ITM]SERMGTCOD=4 & WSERNUMSVG<>""
  Call CRE_STOSERW([F:STO1]ITMREF,WSERNUMSVG,WNBSER,WRET) From STKLIB
  If WRET<>0 : Return : Endif
Endif

# Alimentation STOSORW
[M:SOW]WSTOSEQ(I)    = LLIG
[M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
[M:SOW]WQTYSTU(I)    = WNBSER
[M:SOW]WQTYSTUACT(I) = WNBSER
#- ADC -----------------
[M:SOW]WALLSTU(I)    = [L]WALLQTY
[M:SOW]WALLSTUACT(I) = [L]WALLQTA
#[M:SOW]WALLSTU(I)    = 0
#[M:SOW]WALLSTUACT(I) = 0
#-----------------------
[M:SOW]WSERNUM(I) = WSERNUMSVG
Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
Raz [M:SOW]WSTA(I), [M:SOW]WPLFSTO(I)
#--- TS 106217
Raz [M:SOW]WECCVALMAJ(I)

# Transfert zones de la ligne de document vers l'écran STOSORW
GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

Return
#--- End Issue 110327

#--- Issue 110327
$CTRL_STO1
# Inventaire en cours
If [F:STO1]CUNLOKFLG=2
   WRET=1 : Return
Endif
# Stock avec demande d'analyse
If [M:ALP]PECQLYCTL<>2 & [F:STO1]QLYCTLDEM<>""
   WRET=1 : Return
Endif
#--- TS 106217
# Contrôle de la version par rapport à la règle de gestion
Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",WRET)
If WRET<>0 : Raz GMESSAGE : WRET=1 : Return : Endif
#---
# Contrôle de la péremption
If [F:SRU]SHLLOT<>3        # hcb V6dlu nouvelle valeur
  If [F:STO1]LOT<>[F:STL1]LOT & [F:STO1]SLO<>[F:STL1]SLO
    Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
    If fstat
      WRET=1 : Return
    Elsif ([F:SRU]SHLLOT=2 & [F:STL1]DLUDAT<>[0/0/0] & [F:STL1]DLUDAT-val(NBDAY)<WDAT) | ([F:SRU]SHLLOT=1 & [F:STL1]SHLDAT<>[0/0/0] & [F:STL1]SHLDAT<WDAT)
      WRET=1 : Return
    Endif
  Endif
Endif
# Contrôle des statuts/sous-statuts autorisés
If !evalue(WCRITSTO)
  WRET=1 : Return
Endif
# Contrôle de l'emplacement
If [F:STO1]LOCCAT=3
& |([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
& |([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
& |([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
  WRET=1 : Return
Endif
# Contrôle dépôt
If GWRHACT=2 & [M:ALP]WRH<>""
  If [F:STO1]WRH<>[M:ALP]WRH
    WRET=1 : Return
  Endif
Endif
Return
#--- End Issue 110327

#--- Issue 100756
$CONTROL_STO1

# Conso matière sur OF en ADC, si GCTLALL=3, on ne prend que ce qui est alloué
If GVTMOD = 1 & [M:ALP]VCRTYPORI=10 & [M:ALP]VCRNUMORI<>"" & GCTLALL>2
  Look [STA]STA1=[M:ALP]VCRTYPORI;[M:ALP]VCRNUMORI;[M:ALP]VCRLINORI;[M:ALP]VCRSEQORI;[F:STO1]STOCOU
  If fstat : WRET=1 : Return : Endif
Endif

# Stock avec demande d'analyse
If [M:ALP]PECQLYCTL<>2 & [F:STO1]QLYCTLDEM<>""
  WSRETADC = WRETADC
  #--- TS 106217
  If WSRETADC>=1024 WSRETADC-=1024 Endif
  If WSRETADC>=512 WSRETADC-=512 Endif
  If WSRETADC>=256 WSRETADC-=256 Endif
  If WSRETADC <128  WRETADC+=128 Endif
  WRET=1 : Return
Endif

# Contrôle de l'emplacement
If [F:STO1]LOCCAT=3
& |([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
& |([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
& |([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
  WSRETADC = WRETADC
  #--- TS 106217
  If WSRETADC>=1024 WSRETADC-=1024 Endif
  If WSRETADC>=512 WSRETADC-=512 Endif
  If WSRETADC <256  WRETADC+=256 Endif
  WRET=1 : Return
Endif
#- ADC -----------------
Raz [L]WALLQTA, [L]WALLQTY
If [F:STO1]CUMALLQTA<>0 & [M:ALP]VCRTYPORI<>0 & [M:ALP]VCRNUMORI<>""
  For [STA]STA1 Where VCRTYP=[M:ALP]VCRTYPORI & VCRNUM=[M:ALP]VCRNUMORI &
&                     VCRLIN=[M:ALP]VCRLINORI & VCRSEQ=[M:ALP]VCRSEQORI &
&                     STOCOU=[F:STO1]STOCOU
    [L]WALLQTA += [F:STA]QTYSTUACT
    [L]WALLQTY += [F:STA]QTYSTU
  Next
Endif
#-----------------------
# Contrôle du disponible
Call STODISSOR("[F:STO1]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#- ADC -----------------
[L]WSTUACTDIS += [L]WALLQTA
[L]WSTUDIS    += [L]WALLQTY
#-----------------------
If [L]WSTUACTDIS<=0
  #--- TS 106217
  WSRETADC = WRETADC
  If WSRETADC>=1024 WSRETADC-=1024 Endif
  #If WRETADC<512 WRETADC+=512 Endif
  If WSRETADC <512  WRETADC +=512  Endif
  #---
  WRET=1 : Return
Endif

#--- TS 106217
# Contrôle de la version par rapport à la règle de gestion
Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",WRET)
If WRET<>0
  Raz GMESSAGE
  If WRETADC<1024 WRETADC+=1024 Endif
  WRET=1 : Return
Endif
#---

Readlock [STO1]Curr
If fstat : WRET=1 : Return : Endif

If [M:ALP]TYPQTY=1
  [L]WQTYSTU    = min([L]WALPQTY,[L]WSTUDIS)
  [L]WQTY      += [L]WQTYSTU
  [L]WALPQTY   -= [L]WQTYSTU
  [L]WQTYSTUACT = [L]WQTYSTU
  # Si gestion en titres ou UI, calcul quantité en UA
  Case [F:ITF]STOMGTCOD
    When 3 : If [L]WQTYSTU=[F:STO1]QTYSTU            : #--- Issue 114287
               [L]WQTYSTUACT=[F:STO1]QTYSTUACT       : #--- Issue 114287
             Elsif [F:STL1]POT<>0
               [L]WQTYSTUACT=[L]WQTYSTU*([F:STL1]POT/100)
               Call QTEARR([L]WQTYSTUACT,[F:ITM]STU) From TRTDIV
             Endif
    When 4 : If [L]WQTYSTU=[F:STO1]QTYSTU            : #--- Issue 114287
               [L]WQTYSTUACT=[F:STO1]QTYSTUACT       : #--- Issue 114287
             Elsif [F:STL1]ACT<>0
               [L]WQTYSTUACT=[L]WQTYSTU* [F:STL1]ACT
               Call QTEARR([L]WQTYSTUACT,[F:ITM]STU) From TRTDIV
             Endif
  Endcase
Else
  [L]WQTYSTUACT = min(WALPQTY,WSTUACTDIS)
  [L]WQTY      += [L]WQTYSTUACT
  WALPQTY      -= [L]WQTYSTUACT
  [L]WQTYSTU    = [L]WQTYSTUACT
  # Si gestion en titres ou UI, calcul quantité en US
  Case [F:ITF]STOMGTCOD
    When 3 : If [L]WQTYSTUACT=[F:STO1]QTYSTUACT      : #--- Issue 114287
               [L]WQTYSTU=[F:STO1]QTYSTU             : #--- Issue 114287
             Elsif [F:STL1]POT<>0
               [L]WQTYSTU=[L]WQTYSTUACT/([F:STL1]POT/100)
               Call QTEARR([L]WQTYSTU,[F:ITM]STU) From TRTDIV
             Endif
    When 4 : If [L]WQTYSTUACT=[F:STO1]QTYSTUACT      : #--- Issue 114287
               [L]WQTYSTU=[F:STO1]QTYSTU             : #--- Issue 114287
             Elsif [F:STL1]ACT<>0
               [L]WQTYSTU=[L]WQTYSTUACT/ [F:STL1]ACT
               Call QTEARR([L]WQTYSTU,[F:ITM]STU) From TRTDIV
             Endif
  Endcase
Endif

If I>=dim([M:SOW]WSTOSEQ)
  Call ERREUR(mess(352,199,1)) From GESECRAN
  WRET=2 : Return
Endif
#- ADC -----------------
[L]WALLQTA = min([L]WALLQTA,[L]WQTYSTUACT)
[L]WALLQTY = min([L]WALLQTY,[L]WQTYSTU)
If [L]WALLQTA<[L]WQTYSTUACT
  # Création quantité en cours de traitement
  [L]LSTOCOU = [F:STO1]STOCOU
  [L]LWIPQTY = [L]WQTYSTU   -[L]WALLQTY
  [L]LWIPQTA = [L]WQTYSTUACT-[L]WALLQTA
  Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
  [F:STO1]CUMWIPQTY += [L]LWIPQTY
  [F:STO1]CUMWIPQTA += [L]LWIPQTA
Endif
#-----------------------
Rewrite [STO1]
If fstat : WRET=1 : Return : Endif

# Alimentation STOSORW
[M:SOW]WSTOSEQ(I)    = LLIG
[M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
[M:SOW]WQTYSTU(I)    = [L]WQTYSTU
[M:SOW]WQTYSTUACT(I) = [L]WQTYSTUACT
#- ADC -----------------
[M:SOW]WALLSTU(I)    = [L]WALLQTY
[M:SOW]WALLSTUACT(I) = [L]WALLQTA
#[M:SOW]WALLSTU(I)    = 0
#[M:SOW]WALLSTUACT(I) = 0
#-----------------------
Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)
#--- Issue 116754
If [F:ITM]SERMGTCOD=2 & evalue("[M:"+LABR+"]SERNUM(LNOL)")<>""
  [M:SOW]WSERNUM(I)=evalue("[M:"+LABR+"]SERNUM(LNOL)")
Endif
#---
# Transfert zones de la ligne de document vers l'écran STOSORW
GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

I += 1

Return
#--- End Issue 100756

########################################################################
# CTLPLFLOC      Contrôle qu'une ligne de stock en attente de rangement
#                est sortable
########################################################################
########################################################################
# Prérequis    : Buffer stock   en ligne : ASTO ou [F:STO] par défaut
#
########################################################################
# Paramètres E : LITM = Article
#                ASTO = Abréviation table STOCK (par défaut [F:STO]
#
#            S : LRET = Code retour = 0 : OK
#                                     1 : lot/sous-lot non renseigné
#                                     2 : no série non renseigné
#                                     3 : lot/sous-lot & no série non renseignés
#                                    99 : Article inexistant
#
########################################################################
Subprog CTLPLFLOC(LITM,ASTO,LRET)
Value    Char    LITM
Value    Char    ASTO
Variable Integer LRET

# Lecture article
If clalev([F:ITM]) =0  Local File ITMMASTER  [ITM]   Endif
If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call RSTA("ITM",[M:ALP]ITMREF) From GLOCK
      LRET=99 : End
   Endif
Endif

If ASTO="" ASTO="[F:STO]" Endif

Raz LRET
# Si emplacement en attente de rangement
If evalue(ASTO+"LOCCAT")=2
   If [F:ITM]LOTMGTCOD>2
      If evalue(ASTO+"LOT")=""
         LRET+=1
      Elsif [F:ITM]LOTMGTCOD=4
         If evalue(ASTO+"SLO")="" LRET+=1 Endif
      Endif
   Endif
   If [F:ITM]SERMGTCOD=3
      If evalue(ASTO+"SERNUM")="" LRET+=2 Endif
   #--- Issue 110327
   Elsif [F:ITM]SERMGTCOD=4
      Local File STOSER [STS9] Where ITMREF=LITM & STOCOU=evalue(ASTO+"STOCOU") & ISSDAT=[0/0/0]
      If rowcount([F:STS9]) < evalue(ASTO+"QTYSTU") LRET+=2 Endif
      Close Local File [STS9]
   #---
   Endif
Endif

End

########################################################################
# CTLSORSER   Détermination et contrôle des no série à sortir à partir
#             d'un no début et d'une quantité saisie
########################################################################
########################################################################
# Prérequis    : Buffer article en ligne : [F:ITM]
#
########################################################################
# Paramètres E : LABR  = Abréviation écran
#                LNOL  = No ligne écran (nolign-1)
#                LSER  = No série début
#                LQTY  = Quantité
#
#            S : LSERF = No série fin
#                LQTYF = Quantité OK
#
########################################################################
# Entrée       : Ecran ALLPAR [ALP] (Bloc 1)
#                [M:ALP]TRSTYP     = Type mouvement(M.704)
#                [M:ALP]TRSCOD     = Code mouvement
#                [M:ALP]STOFCY     = Site stock
#                [M:ALP]ITMREF     = Article
#                [M:ALP]BESDAT     = Date besoin
#                [M:ALP]DLVDAT     = Date livraison
#                [M:ALP]PECINTLOC  = Prise en compte emp interne
#                [M:ALP]PECSCOLOC  = Prise en compte emp sous-traitant (M.1)
#                                    mettre 2 si s-traitance (OF/EO/Suivi matière)
#                [M:ALP]PECPLFLOC  = Prise en compte emp en attente de rangement
#                [M:ALP]STA        = Filtre statut ligne document
#                                    sous la forme : "A1*,A20"
#                [M:ALP]WRH        = Dépôt ligne document
#                [M:ALP]VCRNUMORI  = No OF si sortie matière en mode VT
#                [M:ALP]VCRLINORI  = No ligne OF si sortie matière en mode VT
#                [M:ALP]BPRNUM     = Client pour le coefficient de DLU Client
#                #--- TS 106217
#                [M:ALP]ECCVALMAJ  = Version majeure ligne document
#
########################################################################
Subprog CTLSORSER(LABR,LNOL,LSER,LQTY,LSERF,LQTYF)
Value    Char     LABR
Value    Integer  LNOL
Value    Char     LSER
Value    Decimal  LQTY
Variable Char     LSERF
Variable Decimal  LQTYF

Local    Char     WCRITSTO(240)
Local    Char     WSER(GLONSER), WSERF(GLONSER)
Local    Decimal  WPCUDIS, WSTUDIS, WSTUACTDIS
Local    Integer  WRET
Local    Date     WDAT
Local    Date     WDATPER
#--- Issue 110327
Local    Integer  WNBSER
Local    Decimal  WSTOCOU, WQTYORI
#---
#DLUBPC
Local Char     NBDAY(10)
Raz NBDAY
If !clalev([F:STO1])  Local File STOCK  [STO1]  Endif
If !clalev([F:STL1])  Local File STOLOT [STL1]  Endif
#DLUBPC
If clalev([F:ITU]) =0  Local File ITMBPC [ITU]   Endif
If clalev([F:ITF]) =0  Local File ITMFACILIT [ITF]   Endif
#--- TS 106217
If clalev([F:ECS]) =0  Local File ECCSTA     [ECS]   Endif

# Lecture de la règle de gestion pour le mouvement à traiter
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",WRET) From STKLIB
If WRET<>0 : WRET=1 : End : Endif

# Stockage dans WCRITSTO des statuts/sous-statuts autorisés
Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL

#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALP]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALP]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif

Read [ITF]ITF0 = [F:ITM]ITMREF;[M:ALP]STOFCY
If fstat
   Raz [F:ITF]
Endif

#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif


# Date de référence pour la péremption des lots
WDAT = [M:ALP]DLVDAT
If WDAT=[0/0/0] WDAT=[M:ALP]BESDAT Endif

Raz LSERF, LQTYF

WSERF = LSER

#--- Issue 110327
If [F:ITM]SERMGTCOD=3
  WNBSER=1
#---
  While LQTY>0
    WSER = WSERF
    Read [STO1]STO5=[M:ALP]ITMREF;WSER
    If fstat Break Endif
    #--- Issue 110327
    # Supression de la séquence qui est maintenant dans RUPT_SORSER
    Gosub RUPT_SORSER
    If WRET<>0 Break Endif
    #---
    LSERF  = WSER
    LQTYF += 1

    LQTY  -= 1
    Break (LQTY=0)

    Call PLUS_UN(WSER,WSERF,WRET) From STKLIB
    If WRET<>0
      Break
    Endif
  Wend
#--- Issue 110327
Elsif [F:ITM]SERMGTCOD=4
  WSER = WSERF
  WQTYORI = LQTY
  While LQTY>0
    Read [STS]STS0=[M:ALP]ITMREF;WSERF
    # Le no série n'existe pas ou est déjà sorti, alloué ou en cours de traitement
    If fstat | [F:STS]SDHNUM<>"" | func STKLIB.REC_STOSERW([M:ALP]ITMREF,WSERF)<>0
      Break
    # No série sur le même stock que le précédent
    Elsif [F:STS]STOCOU=WSTOCOU
      WNBSER+= 1
      WSER   = WSERF
      Goto SORSER_SUIV
    # C'est le premier no série
    Elsif WSTOCOU=0
      WSTOCOU = [F:STS]STOCOU
      WNBSER  = 1
      Goto SORSER_SUIV
    # Rupture chrono stock
    Else
      Read [STO1]STO0=[M:ALP]STOFCY;WSTOCOU
      If fstat
        WRET=1 : WNBSER=0 : Break
      Endif
      Gosub RUPT_SORSER
      If WRET<>0
        WNBSER=0 : Break
      Endif
      WSTOCOU = [F:STS]STOCOU
      LQTYF  += WNBSER
      LSERF   = WSER
      WSER    = WSERF
      WNBSER  = 1
      Goto SORSER_SUIV
    Endif

    $SORSER_SUIV
    LQTY  -= 1
    Break (LQTY=0)
    Call PLUS_UN(WSER,WSERF,WRET) From STKLIB
    If WRET<>0 Break Endif
  Wend
  If WNBSER>0
    Read [STO1]STO0=[M:ALP]STOFCY;WSTOCOU
    If fstat
      WRET=1 : End
    Endif
    Gosub RUPT_SORSER
    If WRET=0
      LQTYF+= WNBSER
      LSERF = WSER
      # Le nombre de séries ne correspond pas à la quantité
      If LQTYF<>WQTYORI
         WRET =1
         LQTYF=0
         LSERF=""
      Endif
    Endif
  Endif
Endif
#--- End issue 110327

End

#--- Issue 110327
$RUPT_SORSER
# Stock disponible ?
Call STODISSOR("[F:STO1]","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
#--- TS - VXAMT
If [F:STO1]CUMALLQTA>0 & [M:ALP]VCRNUMORI<>""
  If !clalev([F:STA])  Local File STOALL  [STA]  Endif
  For [STA]STA0 Where STOFCY=[M:ALP]STOFCY & ITMREF=[M:ALP]ITMREF & STOCOU=[F:STO1]STOCOU
    If [F:STA]VCRTYP=10 & [F:STA]VCRNUM=[M:ALP]VCRNUMORI & [F:STA]VCRLIN=[M:ALP]VCRLINORI
      WSTUACTDIS+=[F:STA]QTYSTUACT
      #WRET=1 : Return
    Endif
  Next
Endif
#---
If WSTUACTDIS < WNBSER
  WRET=1 : Return
Endif
# Inventaire en cours
If [F:STO1]CUNLOKFLG=2
  WRET=1 : Return
Endif
#--- TS 106217
# Contrôle de la version de l'allocation par rapport à la règle de gestion
Call CTLECCVALMAJ([M:ALP]ITMREF,[M:ALP]ECCVALMAJ,[F:STO1]ECCVALMAJ,[M:ALP]BESDAT,"",WRET)
If WRET<>0
  Raz GMESSAGE : WRET=1 : Return
Endif
#---
If [F:SRU]SHLLOT<>3    # hcb V6dlu nouvelle gestion
  If [F:STO1]LOT<>[F:STL1]LOT & [F:STO1]SLO<>[F:STL1]SLO
    Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
    If fstat
      WRET=1 : Return
    Elsif ([F:SRU]SHLLOT=2 & [F:STL1]DLUDAT-val(NBDAY)<>[0/0/0] & [F:STL1]DLUDAT<WDAT) | ([F:SRU]SHLLOT=1 & [F:STL1]SHLDAT<>[0/0/0] & [F:STL1]SHLDAT<WDAT)
      WRET=1 : Return
    Endif
  Endif
Endif
# Contrôle des statuts/sous-statuts autorisés
If !evalue(WCRITSTO)
  WRET=1 : Return
Endif
# Contrôle de l'emplacement
If [F:STO1]LOCCAT=3
&|([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
&|([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
&|([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
  WRET=1 : Return
Endif
# Contrôle dépôt
If GWRHACT=2 & [M:ALP]WRH<>""
  If [F:STO1]WRH<>[M:ALP]WRH
    WRET=1 : Return
  Endif
Endif

Return
#--- End issue 110327

########################################################################
# RECALLSTO   Recherche de la quantité allouée par une ligne de document
#             sur une ligne de stock
#             Ex : Import ligne livraison avec ligne commande renseignée
#                  Recherche si le stock importé est alloué sur la cde
########################################################################
# Paramètres E : LFCY    = Site
#                LSTOCOU = Chrono stock
#                LTYP    = Type document (pour recherche allocation)
#                LNUM    = Numéro document
#                LLIN    = Ligne document
#                LSEQ    = Séquence document
#
#            S : LQTY    = Quantité allouée en unité physique
#                LQTA    = Quantité allouée en unité active
#
########################################################################
Subprog RECALLSTO(LFCY,LSTOCOU,LTYP,LNUM,LLIN,LSEQ,LQTY,LQTA)
Value    Char    LFCY
Value    Decimal LSTOCOU
Value    Integer LTYP
Value    Char    LNUM
Value    Integer LLIN
Value    Integer LSEQ
Variable Decimal LQTY
Variable Decimal LQTA

If clalev([F:STA]) =0  Local File STOALL     [STA]   Endif

Raz LQTY, LQTA
For [F:STA]STA1 Where VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN=LLIN & VCRSEQ=LSEQ
&                   & STOCOU=LSTOCOU & STOFCY=LFCY
   If [F:STA]ALLTYP=2
      LQTY += [F:STA]QTYSTU
      LQTA += [F:STA]QTYSTUACT
   Endif
Next

End

#--- TS 106217
########################################################################
# CTLECCVALMAJ   Contrôle de la version majeure par rapport
#                à la version saisie et à la règle de gestion
########################################################################
# Prérequis    : La table ECCSTA doit être ouverte
#                La règle de gestion doit être en ligne (enreg [F:SRU])
########################################################################
# Paramètre E : LITM       = Article
#               LECCVALMAJ = Version majeure du document
#               LECCVAL    = Version majeure à contrôler (lue,pickée/saisie)
#               LDAT       = Date du besoin
#               LABR       = Abréviation table règle de gestion
#                            si "" alors "SRU"
# Paramètre S : LRET       = 0 : Ok
#                            1 : Version non autorisée
#                            2 : Version inexistante
# Le message d'erreur est dans GMESSAGE
# --> à afficher en sortie du SP si nécessaire
########################################################################
Subprog CTLECCVALMAJ(LITM,LECCVALMAJ,LECCVAL,LDAT,LABR,LRET)
Value    Char    LITM
Value    Char    LECCVALMAJ
Value    Char    LECCVAL
Value    Date    LDAT
Value    Char    LABR
Variable Integer LRET
LRET=0

If LABR=""
  LABR="[F:SRU]"
Else
  LABR="[F:"+LABR+"]"
Endif
#[M:SOR]WSTOSEQ = evalue(LABR+"WSTOSEQ(LNOL)")

Local File ECCSTA  [ECS]

# Si pas de version, ne rien faire
If LECCVAL="" : End : Endif

# Si version document renseignée et exclusive et
# version à contrôler <> version document
If LECCVALMAJ<>"" & evalue(LABR+"ORDVER")=2 & LECCVAL<>LECCVALMAJ
  LRET=1
  GMESSAGE=mess(426,184,1)-":"-LECCVALMAJ
  End
Endif

Read [ECS]ECS0=LITM;LECCVAL
If fstat
  LRET=2
  GMESSAGE=LECCVAL-":"-mess(308,193,1)
  End
Endif
Case [F:ECS]ECCSTA
  When 1 : If evalue(LABR+"AUZPRO")=1
             LRET=1 : GMESSAGE =mess(422,184,1)
           Elsif evalue(LABR+"AUZPRO")=2 & [F:ECS]SPSFLG=2
             LRET=1 : GMESSAGE =mess(424,184,1)
           Endif
  When 2 : If evalue(LABR+"AUZACT")=1
             LRET=1 : GMESSAGE =mess(423,184,1)
           Elsif evalue(LABR+"AUZACT")=2 & [F:ECS]SPSFLG=2
             LRET=1 : GMESSAGE =mess(424,184,1)
           Endif
  When 3 : If evalue(LABR+"AUZSTP")=1 | (evalue(LABR+"AUZSTP")=2 & [F:ECS]EXNFLG<>2)
             LRET=1 : GMESSAGE =mess(425,184,1)
           Elsif evalue(LABR+"AUZSTP")=2 & [F:ECS]EXNFLG=2 & [F:ECS]EXNDAT<>[0/0/0] & LDAT>[F:ECS]EXNDAT
             LRET=1 : GMESSAGE =mess(425,184,1)
           Endif
  When 4 : LRET=1 : GMESSAGE =mess(433,184,1)
Endcase

#--- Issue 119013
GPOINT="CTL_ECCVALMAJ" : Gosub ENTREE From EXEFNC

End

########################################################################
# CTLECCVAL     Contrôle de la version majeure saisie par rapport
#               à la règle de gestion
#               A utiliser en saisie écran
########################################################################
# Prérequis   : La table ECCSTA doit être ouverte
########################################################################
# Paramètre E : LECCVAL  = Version majeure
#               LFCY     = Site
#               LITM     = Article
#               LTRSTYP  = Type de mouvement (ML 704)
#                          Si devis, commande ou préparation,
#                          mettre comme pour une livraison
#               LTRSCOD  = Code mouvement
#               LDAT     = Date du besoin
# Paramètre S : LRET     = 0 : OK
#                          1 : Version ne respectant pas la règle de gestion
#                              GMESSAGE positionné et à exploiter en sortie
#                          2 : Erreur lecture article
#                          3 : Erreur lecture règle de gestion
#                          4 : Erreur version inexistante
########################################################################
Subprog CTLECCVAL(LECCVAL,LFCY,LITM,LTRSTYP,LTRSCOD,LDAT,LRET)
Value    Char    LECCVAL
Value    Char    LFCY
Value    Char    LITM
Value    Integer LTRSTYP
Value    Char    LTRSCOD
Value    Date    LDAT
Variable Integer LRET

Local File ECCSTA  [ECS]

mkstat=0
# Si pas de version, ne rien faire
If LECCVAL="" : End : Endif

If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
   If fstat
      Call RSTA("ITM",LITM) From GLOCK
      LRET=2 : End
   Endif
Endif

Local File TABSTORUL [SRU]

# Lecture de la règle de gestion à utiliser
Call LECSRU(LFCY,[F:ITM]TCLCOD,LTRSTYP,LTRSCOD,"",LRET) From STKLIB
If LRET<>0
  LRET=3 : End
Endif

Read [ECS]ECS0=LITM;LECCVAL
If fstat
  GMESSAGE =LECCVAL-":"-mess(308,193,1)
  LRET=4 : End
Endif
Case [F:ECS]ECCSTA
  When 1 : If [F:SRU]AUZPRO=1
             LRET=1 : GMESSAGE =mess(422,184,1)
           Elsif [F:SRU]AUZPRO=2 & [F:ECS]SPSFLG=2
             LRET=1 : GMESSAGE =mess(424,184,1)
           Endif
  When 2 : If [F:SRU]AUZACT=1
             LRET=1 : GMESSAGE =mess(423,184,1)
           Elsif [F:SRU]AUZACT=2 & [F:ECS]SPSFLG=2
             LRET=1 : GMESSAGE =mess(424,184,1)
           Endif
  When 3 : If [F:SRU]AUZSTP=1 | ([F:SRU]AUZSTP=2 & [F:ECS]EXNFLG<>2)
             LRET=1 : GMESSAGE =mess(425,184,1)
           Elsif [F:SRU]AUZSTP=2 & [F:ECS]EXNFLG=2 & [F:ECS]EXNDAT<>[0/0/0] & LDAT>[F:ECS]EXNDAT
             LRET=1 : GMESSAGE =mess(425,184,1)
           Endif
  When 4 : LRET=1 : GMESSAGE =mess(433,184,1)
Endcase

#--- Issue 119013
GPOINT="CTL_ECCVALMAJ" : Gosub ENTREE From EXEFNC

End
#---

#########################################################################
$ALI_MESERR
GMESSAGE =mess(399,198,1)-":"-[F:STO1]STA
If [F:ITM]LOTMGTCOD>1
   GMESSAGE-=mess(43,197,1)-":"-[F:STO1]LOT
Endif
If [F:ITM]LOTMGTCOD=4
   GMESSAGE-=mess(456,197,1)-":"-[F:STO1]SLO
Endif
If [F:ITM]SERMGTCOD=3
   GMESSAGE-=mess(453,197,1)-":"-[F:STO1]SERNUM
Endif
If [F:ITF]LOCMGTCOD=2
   GMESSAGE-=mess(44,197,1)-":"-[F:STO1]LOC
Endif
Return

