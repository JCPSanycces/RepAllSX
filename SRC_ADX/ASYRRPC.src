#<AdxTL>@(#)5.0.0.0 $Revision$
#example :http://localhost:8124/sdata/x3/erp/SUPERV/$service/rpc?module=ASYRSRVBATCH&name=ABATCH_MNGT_SERVREQ
#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Char WMODULE(GLONADC),WNAME(GLONADC)
Local Integer ERROR : ERROR=[V]CST_AOK
If find(adxtyp,34,35)=0
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_EXPECTATION_FAILED,func AFNC.MES1(mess(357,139,1),num$(adxtyp)))
  End ERROR
Endif
#
If adxtyp=34
 GSERVEUR=1
 GSILENCE=1
Endif
#
Local Integer I
For I=1 To maxtab(ARCV.PARAMCOD)
 Case toupper(ARCV.PARAMCOD(I))
  When "MODULE" : WMODULE=toupper(ARCV.PARAMVAL(I))
  When "NAME"   : WNAME=toupper(ARCV.PARAMVAL(I))
 Endcase
Next I
If WMODULE="" | WNAME=""
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,"")
 End ERROR
Endif
If WMODULE<>""
 I=0
 Call EXISTE_ADX("","",WMODULE,I) From ASYRSYS
 If I<=0
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_EXPECTATION_FAILED,mess(234,100,1))
  End ERROR
 Endif
Endif

Onerrgo ERRORCALL
I=0
I=evalue("func "+WMODULE+"._EXPORTED()")
Onerrgo
If I<>1
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_EXPECTATION_FAILED,mess(243,100,1))
  End ERROR
Endif

If pat(WMODULE,"ASYR*")>0
 Call SET_CURFCT(WMODULE,1,"") From ASYRPSADX
Else
 Call SET_CURFCT(WMODULE+"/"+WNAME,1,"") From ASYRPSADX
Endif

#117092
If dim([S]adxtrp)>0 & dim([S]adxtrl)>0
  Local Char ASYRRPCTRP(type([S]adxtrp)-10)
  Local Char ASYRRPCTRL(type([S]adxtrl)-10)
  ASYRRPCTRP = [S]adxtrp
  ASYRRPCTRL = [S]adxtrl
  If func EXISTE("ATRIFIL")
   [S]adxtrp = "ATRIFIL" : # Traitement appelé par les Write/Rewrite/Update
   [S]adxtrl = "ATRIOPE" : # Etiquette appelée par les Write/Rewrite/Update
  Endif
Endif

Local Clbfile RETURNCLB
Local Clbfile PAYLOADCLB
Local Integer COUNT
Local Integer ASTATUS : ASTATUS = [V]CST_AOK
Local Char ACTION(50) : ACTION=WNAME
COUNT = strDecode(ARCV.JSON,PAYLOADCLB,GUTF8)
Gosub ACTION From =WMODULE
If dim(GOK)>0 & GOK<>1 & dim(GMESSAGE)>0 & GMESSAGE<>""
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,0,GMESSAGE)
Endif
If len(RETURNCLB)>0
 ASND.DATA='{ "$result" : {'-RETURNCLB-'} }'
Endif
#117092
If dim([S]adxtrp)>0 & dim([S]adxtrl)>0
 [S]adxtrp = ASYRRPCTRP : # Traitement appelé par les Write/Rewrite/Update
 [S]adxtrl = ASYRRPCTRL : # Etiquette appelée par les Write/Rewrite/Update
Endif
End ERROR

$ERRORCALL
I=0
Resume

#####################################################
Funprog EXISTE(TRT)
Value Char TRT
Local Integer OKTRT
Call EXISTE_ADX("","",TRT,OKTRT) From ASYRSYS
End OKTRT

