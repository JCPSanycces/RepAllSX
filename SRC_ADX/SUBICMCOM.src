#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################
# Ecrit les valeurs contenues dans les écrans ICMx dans le fichier [IMC]
Subprog WRIIMC
Local Integer I
Local Integer LTR

If !clalev([F:IMC]) : Local File ITCMATCH [IMC] : Endif

If !adxlog
    Trbegin [IMC]
    LTR = 1
Endif

[F:IMC]PRONUM  = adxuid(1)
[F:IMC]AFFUNI  = [M:ICM0]UNTFLG
[F:IMC]ITMREF  = [M:ICM0]ITMREF
[F:IMC]STOFCY1 = [M:ICM0]STOFCY1
[F:IMC]CSTTYP1 = [M:ICM0]CSTTYP1
[F:IMC]ITCDAT1 = [M:ICM0]ITCDAT1
[F:IMC]ITCSTRDAT1 = [M:ICM0]ITCSTRDAT1
[F:IMC]ITCENDDAT1 = [M:ICM0]ITCENDDAT1
[F:IMC]VCRNUM1 = [M:ICM0]VCRNUM1
[F:IMC]STOFCY2 = [M:ICM0]STOFCY2
[F:IMC]CSTTYP2 = [M:ICM0]CSTTYP2
[F:IMC]ITCDAT2 = [M:ICM0]ITCDAT2
[F:IMC]ITCSTRDAT2 = [M:ICM0]ITCSTRDAT2
[F:IMC]ITCENDDAT2 = [M:ICM0]ITCENDDAT2
[F:IMC]VCRNUM2 = [M:ICM0]VCRNUM2

[F:IMC] = [M:ICM2]
For I=0 To GACTMAT-1
    [F:IMC]MATCST(I) = [M:ICM2]MATCST1(I)
Next
[F:IMC]SCOCST    = [M:ICM2]SCOTOT1

[F:IMC] = [M:ICM3]
For I=0 To GACTMAC-1
    [F:IMC]MACCST(I) = [M:ICM3]MACCST1(I)
Next
For I=0 To GACTLAB-1
    [F:IMC]LABCST(I) = [M:ICM3]LABCST1(I)
Next

[F:IMC] = [M:ICM4]
[F:IMC]OVEMATCST = [M:ICM4]COST1(0)
[F:IMC]OVEMACCST = [M:ICM4]COST1(1)
[F:IMC]OVELABCST = [M:ICM4]COST1(2)
[F:IMC]OVESCOCST = [M:ICM4]COST1(3)

[F:IMC] = [M:ICM1]
[F:IMC]MATTOT  = [M:ICM1]COST1(0)
[F:IMC]MACTOT  = [M:ICM1]COST1(1)
[F:IMC]LABTOT  = [M:ICM1]COST1(2)
[F:IMC]SCOTOT  = [M:ICM1]COST1(3)
[F:IMC]INVDTA  = [M:ICM1]INVDTA1
[F:IMC]OVETOT  = [M:ICM1]COST1(4)
[F:IMC]CSTTOT  = [M:ICM1]CSTTOT1
[F:IMC]VLTTOT  = [F:IMC]CSTTOT+[F:IMC]OVETOT

[F:IMC]VLTTOT2 = [M:ICM1]CSTTOT2+[M:ICM1]COST2(4)

Write [IMC]
If fstat
    Call RSTA("IMC",num$([F:IMC]PRONUM)-[F:IMC]ITMREF) From GLOCK
Endif
If LTR=1
    Commit
Endif
End

#########################################################
Subprog RAZIMC

If !clalev([F:IMC]) : Local File ITCMATCH [IMC] : Endif

Trbegin [IMC]
Delete [IMC] Where PRONUM=adxuid(1)
Commit

End

Subprog RAZPRONUM
If !clalev([F:IMC]) : Local File ITCMATCH [IMC] : Endif

Local Integer WDIM
Local Integer I, J
Local Integer WADXUID(1..500)

Call UIDADX(WADXUID,WDIM) From TRTX3

Trbegin [IMC]
Delete [IMC] Where !find(PRONUM,WADXUID(1..WDIM))
Commit

End

