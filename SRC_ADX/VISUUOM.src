#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "SETBOUT"     : Gosub SETBOUT
  When "DEBUT"       : Gosub DEBUT
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "BOUTON"      : Gosub BOUTON
  When "TRT_DIV"     : Gosub TRT_DIV
Endcase
Return
############################################################
$OUVRE
If clalev([F:ITM])  = 0 Local File ITMMASTER  [ITM]  : Endif
If clalev([F:FCY])  = 0 Local File FACILITY   [FCY]  : Endif
If clalev([F:STL1]) = 0 Local File STOLOT     [STL1] : Endif
If clalev([F:STO1]) = 0 Local File STOCK      [STO1] : Endif
If clalev([F:ITF])  = 0 Local File ITMFACILIT [ITF]  : Endif

Return
############################################################
$SETBOUT
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1
ETABOU(GSPE3) = 1
ETABOU(GSPE4) = 1
#
If [M:VUOM]STA(0) = mess(291,198,1)
  ETABOU(GSPE1) = 0
Endif
If [M:VUOM]STA(0) = mess(292,198,1)
  ETABOU(GSPE2) = 0
Endif
If [M:VUOM]STA(0) = mess(293,198,1)
  ETABOU(GSPE3) = 0
Endif
If [M:VUOM]STA(0) = mess(294,198,1)
  ETABOU(GSPE4) = 0
Endif

Return
############################################################
$DEBUT
Local Char WFIL(250)
Local Char WCAT(20)
#
Local Integer I, J, K, L, M
Local Decimal WACT
Raz [M:VUOM]
#
Call LECTURE("FCY",PARAM(1),"") From CONTOBJ
If fstat 
  Raz [F:FCY]
Endif
[M:VUOM] = [F:FCY]
#
Call LECTURE("ITM",PARAM(2),"") From CONTOBJ
If fstat
  Raz [F:ITM]
Endif
[M:VUOM] = [F:ITM]
If [F:ITM]STOMGTCOD > 1
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
   If [F:ITF]STOFCY <> [F:FCY]FCY | [F:ITF]ITMREF <> [F:ITM]ITMREF 
      Read [ITF]ITF0 = [F:ITM]ITMREF;[F:FCY]FCY
      If fstat 
         Raz [F:ITF]
      Endif
   Endif
Else
   Raz [F:ITF]
Endif

If dim([M:VUOM]LOT) > 0
  [M:VUOM]LOT = PARAM(3)
Endif
[M:VUOM]STASEL = PARAM(4)
[M:VUOM]LOCCAT001 = 2
[M:VUOM]LOCCAT002 = 2
[M:VUOM]LOCCAT003 = 2
[M:VUOM]LOCCAT004 = 2
#
Affzo [M:VUOM]5-10
Gosub TRT_AFFICHAGE
Return
############################################################
$TRT_AFFICHAGE
Effzo [M:VUOM]15
#
WFIL = "[F:STO1]ITMREF=[F:ITM]ITMREF"
If [F:FCY]FCY <> ""
  WFIL += "&[F:STO1]STOFCY=[F:FCY]FCY"
Endif
If dim([M:VUOM]LOT) > 0 & [M:VUOM]LOT <> "" & [M:VUOM]LOT <> mess(142,124,1)
  WFIL += "&pat([F:STO1]LOT,[M:VUOM]LOT)"
Endif
WCAT = ""
If [M:VUOM]LOCCAT001 = 2
  WCAT += ",0,1"
Endif
If [M:VUOM]LOCCAT002 = 2
  WCAT += ",2"
Endif
If [M:VUOM]LOCCAT003= 2
  WCAT += ",3"
Endif
If [M:VUOM]LOCCAT004 = 2
  WCAT += ",4"
Endif
If WCAT <> ""
  WFIL += "&find([F:STO1]LOCCAT"+WCAT+")"
Endif

Filter [STO1] Where evalue(WFIL)
&            Order By Key STO3
#
For [STO1]
  Gosub CUM_UNITE     
Next
Filter [STO1]
# Calcul total
[M:VUOM]BASPAG += 1
[M:VUOM]STA([M:VUOM]BASPAG-1)    = mess(142,124,1)
[M:VUOM]PCU([M:VUOM]BASPAG-1)    = ""
[M:VUOM]STU([M:VUOM]BASPAG-1)    = [M:VUOM]STU(0)
[M:VUOM]QTYSTU([M:VUOM]BASPAG-1) = sum([M:VUOM]QTYSTU(0..[M:VUOM]BASPAG-2))
If dim([M:VUOM]QTYSTUACT) > 0
  [M:VUOM]QTYSTUACT([M:VUOM]BASPAG-1) = sum([M:VUOM]QTYSTUACT(0..[M:VUOM]BASPAG-2))
Endif
Affzo [M:VUOM]15
Return
############################################################
$APRES_MODIF
Case COUZON
  When "LOCCAT001" : 
    [M:VUOM]LOCCAT001 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT002" : 
    [M:VUOM]LOCCAT002 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT003" : 
    [M:VUOM]LOCCAT003 = val(CZ)
    Gosub TRT_AFFICHAGE
  When "LOCCAT004" : 
    [M:VUOM]LOCCAT004 = val(CZ)
    Gosub TRT_AFFICHAGE
Endcase
Return
############################################################
$BOUTON
Case BOUT
  When "a" : 
    J = 1 
    Gosub MOD_TABLEAU
  When "b" : 
    J = 2 
    Gosub MOD_TABLEAU
  When "c" : 
    J = 3 
    Gosub MOD_TABLEAU
  When "d" : 
    J = 4 
    Gosub MOD_TABLEAU
Endcase
Affzo [M:VUOM]
Return
############################################################
$TRT_DIV
Return
###########################################################
$CUM_UNITE
WACT = 1
Read [STL1]STL0(2) = [F:STO1]ITMREF;[F:STO1]LOT
If fstat = 0
  Case [F:ITF]STOMGTCOD
    When 3 : WACT = ([F:STL1]POT/100)
    When 4 : WACT = [F:STL1]ACT
  Endcase
Endif 
# 
M =  find([F:STO1]PCU,[M:VUOM]PCU(0..[M:VUOM]BASPAG-1))
If M <>  0
  Case left$([M:VUOM]STASEL,1)
    When "A"     :
      If left$([F:STO1]STA,1) = "A"
        [M:VUOM]QTYPCU(M-1) += [F:STO1]QTYPCU
        [M:VUOM]QTYSTU(M-1) += [F:STO1]QTYSTU
        If dim([M:VUOM]QTYSTUACT) > 0
          [M:VUOM]QTYSTUACT(M-1) += [F:STO1]QTYSTU*WACT
        Endif
      Endif
    When "Q"     :
      If left$([F:STO1]STA,1) = "Q"
        [M:VUOM]QTYPCU(M-1) += [F:STO1]QTYPCU
        [M:VUOM]QTYSTU(M-1) += [F:STO1]QTYSTU
        If dim([M:VUOM]QTYSTUACT) > 0
          [M:VUOM]QTYSTUACT(M-1) += [F:STO1]QTYSTU*WACT
        Endif
      Endif
    When "R"     :
      If left$([F:STO1]STA,1) = "R"
        [M:VUOM]QTYPCU(M-1) += [F:STO1]QTYPCU
        [M:VUOM]QTYSTU(M-1) += [F:STO1]QTYSTU
        If dim([M:VUOM]QTYSTUACT) > 0
          [M:VUOM]QTYSTUACT(M-1) += [F:STO1]QTYSTU*WACT
        Endif
      Endif
    When Default :
      [M:VUOM]QTYPCU(M-1) += [F:STO1]QTYPCU
      [M:VUOM]QTYSTU(M-1) += [F:STO1]QTYSTU
      If dim([M:VUOM]QTYSTUACT) > 0
        [M:VUOM]QTYSTUACT(M-1) += [F:STO1]QTYSTU*WACT
      Endif
  Endcase
#
  Case left$([F:STO1]STA,1)
    When "A" :
      [M:VUOM]QTYPCUAAA(M-1) += [F:STO1]QTYPCU
      [M:VUOM]QTYSTUAAA(M-1) += [F:STO1]QTYSTU
      [M:VUOM]QTYACTAAA(M-1) += [F:STO1]QTYSTU*WACT 
    When "Q" :
      [M:VUOM]QTYPCUQQQ(M-1) += [F:STO1]QTYPCU
      [M:VUOM]QTYSTUQQQ(M-1) += [F:STO1]QTYSTU
      [M:VUOM]QTYACTQQQ(M-1) += [F:STO1]QTYSTU*WACT 
    When "R" :
      [M:VUOM]QTYPCURRR(M-1) += [F:STO1]QTYPCU
      [M:VUOM]QTYSTURRR(M-1) += [F:STO1]QTYSTU
      [M:VUOM]QTYACTRRR(M-1) += [F:STO1]QTYSTU*WACT 
  Endcase
Else
  If [M:VUOM]BASPAG < dim([M:VUOM]PCU)-2
    [M:VUOM]PCU([M:VUOM]BASPAG)    = [F:STO1]PCU
    [M:VUOM]STU([M:VUOM]BASPAG)    = [F:ITM]STU
    Case left$([M:VUOM]STASEL,1)
      When "A"     : [M:VUOM]STA   ([M:VUOM]BASPAG) = mess(292,198,1) 
      When "Q"     : [M:VUOM]STA   ([M:VUOM]BASPAG) = mess(293,198,1) 
      When "R"     : [M:VUOM]STA   ([M:VUOM]BASPAG) = mess(294,198,1) 
      When Default : [M:VUOM]STA   ([M:VUOM]BASPAG) = mess(291,198,1) 
    Endcase
#    
    Case left$([M:VUOM]STASEL,1)
      When "A" :
        If left$([F:STO1]STA,1) = "A"
          [M:VUOM]QTYPCU([M:VUOM]BASPAG) = [F:STO1]QTYPCU
          [M:VUOM]QTYSTU([M:VUOM]BASPAG) = [F:STO1]QTYSTU
          If dim([M:VUOM]QTYSTUACT) > 0
            [M:VUOM]QTYSTUACT([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
          Endif
        Endif
      When "Q" :
        If left$([F:STO1]STA,1) = "Q"
          [M:VUOM]QTYPCU([M:VUOM]BASPAG) = [F:STO1]QTYPCU
          [M:VUOM]QTYSTU([M:VUOM]BASPAG) = [F:STO1]QTYSTU
          If dim([M:VUOM]QTYSTUACT) > 0
            [M:VUOM]QTYSTUACT([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
          Endif
        Endif
      When "R" :
        If left$([F:STO1]STA,1) = "R"
          [M:VUOM]QTYPCU([M:VUOM]BASPAG) = [F:STO1]QTYPCU
          [M:VUOM]QTYSTU([M:VUOM]BASPAG) = [F:STO1]QTYSTU
          If dim([M:VUOM]QTYSTUACT) > 0
            [M:VUOM]QTYSTUACT([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
          Endif
        Endif
      When Default :
        [M:VUOM]QTYPCU([M:VUOM]BASPAG) = [F:STO1]QTYPCU
        [M:VUOM]QTYSTU([M:VUOM]BASPAG) = [F:STO1]QTYSTU
        If dim([M:VUOM]QTYSTUACT) > 0
          [M:VUOM]QTYSTUACT([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
        Endif
    Endcase
    Case left$([F:STO1]STA,1)
      When "A" :
        [M:VUOM]QTYPCUAAA([M:VUOM]BASPAG) = [F:STO1]QTYPCU
        [M:VUOM]QTYSTUAAA([M:VUOM]BASPAG) = [F:STO1]QTYSTU
        [M:VUOM]QTYACTAAA([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
      When "Q" :
        [M:VUOM]QTYPCUQQQ([M:VUOM]BASPAG) = [F:STO1]QTYPCU
        [M:VUOM]QTYSTUQQQ([M:VUOM]BASPAG) = [F:STO1]QTYSTU
        [M:VUOM]QTYACTQQQ([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
      When "R" :
        [M:VUOM]QTYPCURRR([M:VUOM]BASPAG) = [F:STO1]QTYPCU
        [M:VUOM]QTYSTURRR([M:VUOM]BASPAG) = [F:STO1]QTYSTU
        [M:VUOM]QTYACTRRR([M:VUOM]BASPAG) = [F:STO1]QTYSTU*WACT
    Endcase
    [M:VUOM]BASPAG += 1
  Endif
Endif
Return
############################################################
$MOD_TABLEAU
[M:VUOM]QTYSTU([M:VUOM]BASPAG-1) = 0
If dim([M:VUOM]QTYSTUACT) > 0 
  [M:VUOM]QTYSTUACT([M:VUOM]BASPAG-1) = 0
Endif
For I = 0 To [M:VUOM]BASPAG-2
  Case J
    When 1 :
      [M:VUOM]STA   (I) = mess(291,198,1)
      [M:VUOM]QTYPCU(I) = [M:VUOM]QTYPCUAAA(I)+[M:VUOM]QTYPCUQQQ(I)+
&                         [M:VUOM]QTYPCURRR(I)
      [M:VUOM]QTYSTU(I) = [M:VUOM]QTYSTUAAA(I)+[M:VUOM]QTYSTUQQQ(I)+
&                         [M:VUOM]QTYSTURRR(I)
      If dim([M:VUOM]QTYSTUACT) > 0 
        [M:VUOM]QTYSTUACT(I) = [M:VUOM]QTYACTAAA(I)+[M:VUOM]QTYACTQQQ(I)+
&                           [M:VUOM]QTYACTRRR(I)
      Endif

    When 2 :
      [M:VUOM]STA   (I)    = mess(292,198,1)
      [M:VUOM]QTYPCU(I)    = [M:VUOM]QTYPCUAAA(I)
      [M:VUOM]QTYSTU(I)    = [M:VUOM]QTYSTUAAA(I)
      If dim([M:VUOM]QTYSTUACT) > 0 
        [M:VUOM]QTYSTUACT(I) = [M:VUOM]QTYACTAAA(I)
      Endif
    When 3 :
      [M:VUOM]STA   (I)    = mess(293,198,1)
      [M:VUOM]QTYPCU(I)    = [M:VUOM]QTYPCUQQQ(I)
      [M:VUOM]QTYSTU(I)    = [M:VUOM]QTYSTUQQQ(I)
      If dim([M:VUOM]QTYSTUACT) > 0 
        [M:VUOM]QTYSTUACT(I) = [M:VUOM]QTYACTQQQ(I)
      Endif 
    When 4 :
      [M:VUOM]STA   (I)    = mess(294,198,1)
      [M:VUOM]QTYPCU(I)    = [M:VUOM]QTYPCURRR(I)
      [M:VUOM]QTYSTU(I)    = [M:VUOM]QTYSTURRR(I)
      If dim([M:VUOM]QTYSTUACT) > 0 
        [M:VUOM]QTYSTUACT(I) = [M:VUOM]QTYACTRRR(I)
      Endif
  Endcase
  [M:VUOM]QTYSTU([M:VUOM]BASPAG-1) += [M:VUOM]QTYSTU(I)
  If dim([M:VUOM]QTYSTUACT) > 0 
    [M:VUOM]QTYSTUACT([M:VUOM]BASPAG-1) += [M:VUOM]QTYSTUACT(I)
  Endif
Next I
Return
############################################################
Subprog AV_STA(VALEUR)
Variable Char    VALEUR()
If nolign > 0 
  If VALEUR = mess(142,124,1)
    pcolor = GCOUL(3)
  Else 
    pcolor = GCOUL(0)
  Endif
Endif
End
############################################################
Subprog C_LOCCAT001(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT003 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT002(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT003 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT003(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT004 = 1
  VALEUR = 2
  mkstat = 2
Endif
End
############################################################
Subprog C_LOCCAT004(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]LOCCAT001 = 1 & [M]LOCCAT002 = 1 & [M]LOCCAT003 = 1
  VALEUR = 2
  mkstat = 2
Endif
End

