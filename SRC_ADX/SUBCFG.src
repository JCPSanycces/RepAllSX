Subprog C_SUBSCENUM(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
If VALEUR <> ""
  If VALEUR = [M:CFG0]SCENUM
    mkstat = 2
    GMESSAGE = mess(83,123,1)
  Else
    VALEUR = toupper(VALEUR)
    Read [CSC1]CSC0=VALEUR
    If fstat
      mkstat = 2
      GMESSAGE = mess(65,188,1)
    Endif
  Endif
Endif
If mkstat = 0
  [M]SUBSCENUM(NOL) = VALEUR
  Gosub MAJ_SCEFLG
  Affzo [M:CFG1]SCEFLG
Endif
End
