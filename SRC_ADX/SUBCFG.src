############################################################
Subprog AS_ROUREF(VALEUR)
Variable Char    VALEUR()
Raz GROUALT
GROUALT(0) = [M:CFG1]ROUALTREF
If [M:CFG1]ROUFLG <> 2
  mkstat = 2
  GBOUT2 = ""
Else
  If VALEUR = "" & [M:CFG4]PARITM <> ""
    VALEUR = [M:CFG4]PARITM
    Read [ITF]ITF0=[M:CFG4]PARITM;[M:CFG0]FCY
    If fstat = 0
      If [F:ITF]MFGROU <> ""
        VALEUR = [F:ITF]MFGROU
      Endif
    Endif
  Endif
Endif
End
############################################################
Subprog C_ROUREF(VALEUR)
Variable Char    VALEUR()
If [M:CFG0]FCY<>""
    LFIL = "FCY = [M:CFG0]FCY" : # GA avant "STOFCY = [M:CFG0]FCY"
Else
    LFIL = "1=1"
Endif
Filter [ROH] Where evalue(LFIL)
&                & ITMREF = VALEUR
&                & ROUALT = [M:CFG1]ROUALTREF
Read [ROH]ROH0 First
Filter [ROH]
If fstat
  mkstat = 2
  GMESSAGE = mess(45,188,1)-"("+[M:CFG0]FCY-VALEUR-num$([M:CFG1]ROUALTREF)+")"
  End
Endif
Filter [ROH] Where evalue(LFIL)
&                & ITMREF = VALEUR
&                & ROUALT = [M:CFG1]ROUALTREF
&                & [F:ROH]USESTA = 2
&                & [F:ROH]CFMFLG = 2
&                & ( [F:ROH]ROUSTRDAT = [0/0/0] | date$ >= [F:ROH]ROUSTRDAT)
&                & ( [F:ROH]ROUENDDAT = [0/0/0] | date$ <= [F:ROH]ROUENDDAT)
Read [ROH]ROH0 First
If fstat
  mkstat = 2
  GMESSAGE = mess(246,193,1)-"("+[M:CFG0]FCY-VALEUR-num$([M:CFG1]ROUALTREF)+")"
  End
Endif
Filter [ROH]

# FGR 02/10/2009 : X3SUIVI58337
#[M:CFG8]ROUDES = [F:ROH]ROUDES
Call LECTEXTRA([M:CFG8]ROUDES,"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA
Affzo [M:CFG8]ROUDES

#If [F:ROH]USESTA <> 2
#  mkstat = 2
#  GMESSAGE = mess(54,193,1)-"("+VALEUR-num$([M:CFG1]ROUALTREF)+")"
#  End
#Endif
#If [F:ROH]CFMFLG <> 2
#  mkstat = 2
#  GMESSAGE = mess(8,193,1)-"("+VALEUR-num$([M:CFG1]ROUALTREF)+")"
#  End
#Endif
#If ([F:ROH]ROUSTRDAT <> [0/0/0] & date$ < [F:ROH]ROUSTRDAT) |
#&  ([F:ROH]ROUENDDAT <> [0/0/0] & date$ > [F:ROH]ROUENDDAT)
#  mkstat = 2
#  GMESSAGE = mess(8,193,1)-"("+VALEUR-num$([M:CFG1]ROUALTREF)+")"
#  End
#Endif
End

############################################################
Subprog AS_STDOPENUM(VALEUR)
Variable Decimal VALEUR
If [M:CFG8]ORICOD(nolign-1) <> 0
  mkstat = 2
Endif
End
############################################################
Subprog C_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL
Local Char WVER(10)
Local Integer I
If [M:CFG0]FCY <> ""
  Read [ROT]ROT0=VALEUR;[M:CFG0]FCY
  If fstat
    Raz [F:ROT]
    mkstat = 2
  Endif
Else
  mkstat = 2
  Filter [ROT] Where STDOPENUM = VALEUR
&              Order By Key ROT0
  For [ROT]
    mkstat = 0
    Break
  Next
  Filter [ROT]
Endif
For I = 0 To [M:CFG8]NBLIG8-1
  If I <> NOL
    If [M:CFG8]OPENUM   (I) = [M:CFG8]OPENUM(NOL) &
&      [M:CFG8]STDOPENUM(I) = VALEUR
      mkstat = 2
      GMESSAGE = mess(24,123,1)-num$(I+1)
      Break
    Endif
  Endif
Next I
If mkstat = 0
  [M:CFG8]               = [F:ROT]
  # FGR 21/09/2009 : X3SUIVI57981
  #[M:CFG8]ROODES(NOL)    = [F:ROT]STDOPEDES
  # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
  Call LECTEXTRA([M:CFG8]ROODES(NOL),"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
  [M:CFG8]WST(NOL)       = [F:ROT]WST
  [M:CFG8]ORICOD(NOL)    = 0
  [M:CFG8]CNDFORLIN(NOL) = ""
  Affzo [M:CFG8]OPENUM   (NOL)
  Affzo [M:CFG8]ROODES   (NOL)
  Affzo [M:CFG8]WST      (NOL)
  Affzo [M:CFG8]ROOTIMCOD(NOL)
  Affzo [M:CFG8]TIMCOD   (NOL)
  Affzo [M:CFG8]PRPTIM   (NOL)
  Affzo [M:CFG8]SETTIM   (NOL)
  Affzo [M:CFG8]OPETIM   (NOL)
  Affzo [M:CFG8]CAD      (NOL)
Endif
End
