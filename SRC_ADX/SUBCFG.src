##################################################
# Issue 85729 GA 01/2013
# Détails composant déjà paramétrés ?
Subprog CTL_SAICMP(LNUMSEQ_OLD,LITMREF_OLD,LNUMSEQ_NEW,LITMREF_NEW)
Value Integer LNUMSEQ_OLD
Value Char    LITMREF_OLD
Value Integer LNUMSEQ_NEW
Value Char    LITMREF_NEW

Local Integer W_J, WREP : WREP=0  # Issue 85729 suite GA 01/2014 1ere init à 0 au lieu de 1
If dim([M:CFGW]NBLIGW)<=0 End Endif
For W_J = 0 To [M:CFGW]NBLIGW-1
  If [M:CFGW]SCENUMSEQ(W_J) = LNUMSEQ_OLD &
&    [M:CFGW]ITMREF   (W_J) = LITMREF_OLD
    # Des données de création de composants existent  ! Effacement ?
    If WREP=0 # pour ne poser la question qu'une seule fois
       #Call AVERTIR(mess(38,188,1),WREP) From GESECRAN
       Call OUINON(mess(38,188,1),WREP) From GESECRAN # Issue 85729 suite 02/2014 réponse inversée
    Endif
    If WREP = 1  # Issue 85729 suite 02/2014 réponse inversée  avant WREP <> 2
      [M:CFGW]SCENUMSEQ(W_J) = LNUMSEQ_NEW
      [M:CFGW]ITMREF   (W_J) = LITMREF_NEW
    Else
      Dela W_J,1,[M:CFGW]NBLIGW [M:CFGW]NBLIGW
    Endif
  Endif
Next
End

##################################################
# Issue 85729 GA 01/2013
# Détails opération déjà paramétrés ?
Subprog CTL_SAIOPE(LOPENUM_OLD,LSTDOPENUM_OLD,LOPENUM_NEW,LSTDOPENUM_NEW)
Value Integer LOPENUM_OLD
Value Integer LSTDOPENUM_OLD
Value Integer LOPENUM_NEW
Value Integer LSTDOPENUM_NEW

Local Integer W_J, WREP : WREP=0  # Issue 85729 suite GA 01/2014 1ere init à 0 au lieu de 1
If dim([M:CFGX]NBLIGX)<=0 End Endif
For W_J = 0 To [M:CFGX]NBLIGX-1
  If [M:CFGX]OPENUM   (W_J) = LOPENUM_OLD &
&    [M:CFGX]STDOPENUM(W_J) = LSTDOPENUM_OLD
    # Des données de création d'opérations existent ! Effacement ?
    If WREP=0 # pour ne poser la question qu'une seule fois
       #Call AVERTIR(mess(47,188,1),WREP) From GESECRAN
       Call OUINON(mess(47,188,1),WREP) From GESECRAN # Issue 85729 suite 02/2014 réponse inversée
    Endif
    If WREP = 1 # Issue 85729 suite 02/2014 réponse inversée avant WREP <> 2
      [M:CFGX]OPENUM   (W_J) = LOPENUM_NEW      # Ctrl des sources 03/2013 avant SCENUMSEQ
      [M:CFGX]STDOPENUM(W_J) = LSTDOPENUM_NEW   # Ctrl des sources 03/2013 avant ITMREF
    Else
      Dela W_J,1,[M:CFGX]NBLIGX [M:CFGX]NBLIGX
    Endif
  Endif
Next
End

