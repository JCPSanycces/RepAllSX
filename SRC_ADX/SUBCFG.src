############################################################
Subprog AS_CSTCOD(VALEUR)
Variable Integer VALEUR
Local Char W_PAR(1)
#
Local Shortint W_I
For W_I=1 To 9
    GMENLOC(W_I) = 1
Next
#
If [M:CFG1]CSTVAL=3        # mode scénario
    GMENLOC(3) = 0
    GMENLOC(7) = 0
    If [M:CFG0]CFGADV = 2
      GMENLOC(8) = 0
    Endif
Elsif [M:CFG1]CSTVAL=2    # controle de gestion
    GMENLOC(5) = 0
    GMENLOC(6) = 0
    GMENLOC(9) = 0
#Else    # pas de calcul
#    Diszo [M:CFG1]CSTCOD
#   VALEUR=1
#    mkstat=2
Endif
End
############################################################
Subprog AM_CSTCOD(VALEUR)
Variable Integer VALEUR
If VALEUR <> 8
  Local Integer I, J, K, L, M
  I = find(24,[M:CFG9]SYMTYP(0..[M:CFG9]NBLIG9-1))
  J = find(25,[M:CFG9]SYMTYP(0..[M:CFG9]NBLIG9-1))
  K = find(26,[M:CFG9]SYMTYP(0..[M:CFG9]NBLIG9-1))
  L = find(27,[M:CFG9]SYMTYP(0..[M:CFG9]NBLIG9-1))
  If sum(I,J,K,L) <> 0
    M = 1
    Call AVERTIR(mess(70,188,1),M) From GESECRAN
    If M = 2
      Local Mask CFG9 [CFGZ]
      [M:CFGZ] = [M:CFG9]
      Effzo [M:CFG9]
      For I = 0 To [M:CFGZ]NBLIG9-1
        If !find([M:CFGZ]SYMTYP(I),24,25,26,27)
          [M:CFG9]SYMTYP([M:CFG9]NBLIG9) = [M:CFGZ]SYMTYP(I)
          [M:CFG9]SYMNUM([M:CFG9]NBLIG9) = [M:CFGZ]SYMNUM(I)
          # FQ 60139 - Raz FQ 53410 remplacé par lien
          If dim([M:CFG9]SYMDES)>0 & dim([M:CFGZ]SYMDES)>0
             [M:CFG9]SYMDES([M:CFG9]NBLIG9) = [M:CFGZ]SYMDES(I)
          Endif
          [M:CFG9]SYMIND([M:CFG9]NBLIG9) = [M:CFGZ]SYMIND(I)
          [M:CFG9]UPDCOD([M:CFG9]NBLIG9) = [M:CFGZ]UPDCOD(I)
          [M:CFG9]CNDFOR([M:CFG9]NBLIG9) = [M:CFGZ]CNDFOR(I)
          [M:CFG9]FORFOR([M:CFG9]NBLIG9) = [M:CFGZ]FORFOR(I)
          [M:CFG9]ABQNUM([M:CFG9]NBLIG9) = [M:CFGZ]ABQNUM(I)
          [M:CFG9]ABQVAL([M:CFG9]NBLIG9) = [M:CFGZ]ABQVAL(I)
          [M:CFG9]ABQVALY([M:CFG9]NBLIG9)= [M:CFGZ]ABQVALY(I)
          [M:CFG9]NBLIG9 += 1
        Endif
      Next I
      Affzo [M:CFG9]
      Close Local Mask [CFGZ]
    Endif
  Endif
Endif
[M:CFG1]CSTCOD = VALEUR
Gosub MEI_SYMPAR
End
