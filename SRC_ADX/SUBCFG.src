    Call AVERTIR(mess(38,188,1),I) From GESECRAN
    If I = 2
      [M:CFG1]BOMALT    = 0
      [M:CFG1]BOMALTREF = 0
      Affzo [M:CFG1]10
      Effzo [M:CFG6]
      Raz   [M:CFGW]
    Endif
  Endif
Endif
[M:CFG1]CMPFLG = VALEUR
Gosub MEI_SYMPAR
End
