#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: NCSBPC_CSTD, Non-conformance - Customer Collection

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
        When "VALIDATE_CUSTOMER_CONTACT"
          Gosub VALIDATE_CUSTOMER_CONTACT
      Endcase
  Endcase

Return

# --------------------------------------------------
# Increment collection row's line number (ORIGCLN)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

  this.ORIGCLN = 1 + max (this.APARENT.NCSBPCCOL(1..maxtab(this.APARENT.NCSBPCCOL)).ORIGCLN)

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "CUSTCONTACT.CONTROL" : ASTATUS = fmet this.VALIDATE_CUSTOMER_CONTACT()
  Endcase

Return

# --------------------------------------------------
# The Contact must relate to the Customer ...
$VALIDATE_CUSTOMER_CONTACT

  Local File CONTACT [CNT]
  Local Char MESSAGE(100)
  Local Char CUSTOMER_NAME(50)
  Local Char CONTACT_NAME(50)
  Local Instance BPCUSTOMER Using C_BPCUSTOMER
  Local Instance CONTACTCRM Using C_CONTACTCRM
  Local Integer LOCASTATUS

  ASTATUS = CST_AOK

  If this.CUSTCONTACT <> ""

    # Read the Customer Contact ...
    Read [CNT]CNT0 = 1;this.BPCNUM;this.CUSTCONTACT
    If (fstat > 1)  # No record ...

      # Derive the Customer name ...
      BPCUSTOMER = NewInstance C_BPCUSTOMER AllocGroup null
      CUSTOMER_NAME = ""
      LOCASTATUS = fmet BPCUSTOMER.AREAD(this.BPCNUM)
      If (LOCASTATUS = CST_AOK)
        CUSTOMER_NAME = this.BPCNAM
      Endif

      # Derive the Contact name ...
      CONTACTCRM = NewInstance C_CONTACTCRM AllocGroup null
      CONTACT_NAME = ""
      LOCASTATUS = fmet CONTACTCRM.AREAD(this.CUSTCONTACT)
      If (LOCASTATUS = CST_AOK)
        CONTACT_NAME = mess(CONTACTCRM.CNTTTL,941,1) - CONTACTCRM.CNTFNA - CONTACTCRM.CNTLNA
      Endif

      MESSAGE = func ASYRFNC.MES2(mess(63,2038,1), CONTACT_NAME, CUSTOMER_NAME)
      ASTATUS = fmet this.ASETERROR("CUSTCONTACT", MESSAGE, CST_AERROR)
    Endif
  Endif

  LogicClose File [CNT]

  ARET_VALUE = ASTATUS

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

