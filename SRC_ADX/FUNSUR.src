#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque STDTDUPDR3
#################################################################################
#                                                                               #
# MODELISATION E-COMMERCE     Action traitement modification des opérations std #
#                                                                               #
# ACTION  : SAISTDTDU  : Actions lées à la saisie fenêtre                       #
#           TRTSTDTDU  : Traitement standard                                    #
#                                                                               #
#################################################################################
# Etiquettes ACTION                                                             #
#################################################################################

#--- Actions liées à la saisie fenêtre des variables
$ACTION
Case ACTION
 When "OUVRE"        : Case GACTION 
                           When "SAISTDTDU" : Gosub OUVRE
                       Endcase
 When "DEBUT"        : Case GACTION 
                           When "SAISTDTDU" : Gosub DEBUT_SAI
                       Endcase
 When "SETBOUT"      : Gosub SETBOUT 
                       
 When "FIN"          : Gosub FIN

 When Default
Endcase

#--- Actions liées au traitement standard de mise à jour

Case ACTION
 When "DEBUT"        :  Case GACTION 
                           When "TRTSTDTDU" : Gosub DEBUT_TRT
                       Endcase

 When "ENR"          : Case GACTION 
                           When "TRTSTDTDU" : Gosub ENREGISTRE
                       Endcase
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "ABA"          : Gosub ABORT

 When "TERMINE"      : Gosub TERMINE
                                            
 When Default
Endcase


Return

#########################################################################
#    Actions liées à la saisie fenêtre                                  #
#########################################################################
$OUVRE
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO] : Endif 
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM] : Endif 
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY] : Endif 
If clalev([F:ROT])  = 0 : Local File ROUOPESTD   [ROT] : Endif 
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS] : Endif 
If clalev([F:ROO])  = 0 : Local File ROUOPE      [ROO] : Endif     # 16571 11.02 MM
If clalev([F:ROH])  = 0 : Local File ROUTING     [ROH] : Endif     # 16571 11.02 MM


Local  Integer NBOPE,  OK
Local  Integer NBROU, WUOM                            # 16571 11.02 MM
Local  Char WMESS(80) , WMESS1(120) , WCLE(80)                   
Local  Char CRITERE(250) , CRITERE1 (250)
Local  Char TIT(50) : TIT = mess(149,190,1)
Global Char FORMULE1(255)
Global Integer    MAJUO  

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Return


######################################################################## 
$DEBUT_SAI

Raz [M:SUR0]
Raz [M:SUR1]
Raz [M:SUR2]
Raz [M:SUR3]

[M:SUR0]FCY = GFCY
[M:SUR1]SCOCODDEB= 1
[M:SUR1]SCOCODFIN= 3

Grizo [M:SUR2]SETTIMF     : Grizo [M:SUR2]SETTIMV
Grizo [M:SUR2]OPETIMF     : Grizo [M:SUR2]OPETIMV
Grizo [M:SUR2]PRPTIMF     : Grizo [M:SUR2]PRPTIMV
Grizo [M:SUR2]WAITIMF     : Grizo [M:SUR2]WAITIMV
Grizo [M:SUR2]PSPTIMF     : Grizo [M:SUR2]PSPTIMV
Grizo [M:SUR2]SETLABCOEF  : Grizo [M:SUR2]SETLABCOEV
Grizo [M:SUR2]OPELABCOEF  : Grizo [M:SUR2]OPELABCOEV
Grizo [M:SUR2]CADF        : Grizo [M:SUR2]CADV
Grizo [M:SUR2]WSTNBRF     : Grizo [M:SUR2]WSTNBRV
Grizo [M:SUR2]LABNBRF     : Grizo [M:SUR2]LABNBRV
Grizo [M:SUR3]OPEUOMV
Grizo [M:SUR3]EFFF        : Grizo [M:SUR3]EFFV   
Grizo [M:SUR3]SHRF        : Grizo [M:SUR3]SHRV   

Affzo [M:SUR1]1-99
Affzo [M:SUR2]1-99
Affzo [M:SUR3]1-99

Return

######################################################################## 
$SETBOUT

Raz ETABOU 
ETABOU(GVALI) = 1
ETABOU(GENRE) = 1  
ETABOU(GABAN) = 1   
ETABOU(GBFIN) = 1 
Return


######################################################################## 
$DEBUT_TRT
Default Mask [SUR4]
Local Integer WMAX : WMAX = dim([M]WST)     # llc 04.03 17909

Gosub LIRE
If [M:SUR4]NBLIG=0 
    GERR=2 : GMESSAGE=mess(147,190,1)
    FIN=1 
Endif
Return

######################################################################## 
$ENREGISTRE
OK =1
Call OUINON(mess(20,196,1), OK) From GESECRAN
If OK<> 2  : FIN = 0 :  GERR = 2 : Return : Endif

Gosub MODIF
FIN=1
GERR=2
GMESSAGE= mess(363,197,1)
Return

######################################################################## 
$ABORT
Raz[M]
Affzo[M]
Gosub LIRE
Return

####################################################################### 
$TERMINE

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

####################################################################### 
$FIN

#--- Sup. des globales perso
If dim(MAJUO)>0    : Kill  MAJUO     : Endif
If dim(FORMULE1)>0 : Kill  FORMULE1  : Endif


#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3

Return


######################################################################## 
#Sélection des opérations std
$SEL_OPE

#--> critères de saisie
CRITERE ="1=1"

If [M:SUR0]FCY<>""
    CRITERE -='&FCY="'+[M:SUR0]FCY+'"'
Endif

If [M:SUR1]OPENUMDEB<>0
   CRITERE -="&STDOPENUM>="+num$([M:SUR1]OPENUMDEB)   
Endif
If [M:SUR1]OPENUMFIN<>0
    CRITERE -="&STDOPENUM<="+num$([M:SUR1]OPENUMFIN) 
Endif

If [M:SUR1]WSTDEB<>""
    CRITERE -='&WST>="'+[M:SUR1]WSTDEB+'"'   
Endif
If [M:SUR1]WSTFIN<>""
    CRITERE -='&WST<="'+[M:SUR1]WSTFIN+'"'   
Endif

If [M:SUR1]LABWSTDEB<>""
    CRITERE -='&LABWST>="'+[M:SUR1]LABWSTDEB+'"'   
Endif
If [M:SUR1]LABWSTFIN<>""
    CRITERE -='&LABWST<="'+[M:SUR1]LABWSTFIN+'"'   
Endif

CRITERE1 = "1=1"

If [M:SUR1]SCOCODDEB<>0
    CRITERE1 -="&SCOCOD>="+num$([M:SUR1]SCOCODDEB)
Endif
If [M:SUR1]SCOCODFIN<>0
    CRITERE1 -="&SCOCOD<="+num$([M:SUR1]SCOCODFIN)
Endif

Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:SUR1]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=9;[M:SUR1]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

Return


##########################################################################    
# Traitement des actions evenementielles            #  
$APRES_MODIF  
REP="M"
Gosub SETBOUT               
Return    


######################################################################## 
$LIRE
REP = ""
Raz [M]
nolign =0

Goto M_TDUPDR
Goto FIN_TDUPDR
Return 

######################################################################## 
$M_TDUPDR

MAJUO = 0
If GTRACE=""
    Call OUVRE_TRACE(TIT) From LECFIC
Endif
[M:SUR4]FCY = [M:SUR0]FCY
Call LECTURE ("FCY" ,[M:SUR4]FCY,"") From CONTOBJ
[M:SUR4]FCYNAM = [F:FCY]FCYNAM


Gosub SEL_OPE

Filter [ROT] Where evalue (CRITERE) & evalue (CRITERE1)  & evalue(FORMULE1) Order By Key ROT0

For[ROT]
    nolign +=1
    If nolign = WMAX : Break : Endif    # llc 04.03 17909

    [M:SUR4] = [F:ROT]
  

 
    # nombre d'exemplaire
    If [M:SUR2]FWSTNBR = 2
        If [M:SUR2]WSTNBRF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]WSTNBRF
            If !fstat 
                [M:SUR4]WSTNBR(nolign-1) = int(evalue([F:TFO]FORFOR))
            Endif
        Else
            [M:SUR4]WSTNBR(nolign-1) = [M:SUR2]WSTNBRV
        Endif
        If [M:SUR4]WSTNBR(nolign-1) <= 0 : [M:SUR4]WSTNBR(nolign-1) = [F:ROT]WSTNBR : Endif
        If [M:SUR4]WST(nolign-1)<>"" :  Read [MWS]WST0=[M:SUR4]WST(nolign-1);[F:ROT]FCY : endif
        If [M:SUR4]WSTNBR(nolign-1) >  [F:MWS]WSTNBR : [M:SUR4]WSTNBR(nolign-1) = [F:ROT]WSTNBR : Endif
    Endif

    # nombre d'exemplaire MO
    If [M:SUR2]FLABNBR = 2 & [M:SUR4]LABWST(nolign-1) <> "" 
      If [M:SUR2]LABNBRF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]LABNBRF
            If !fstat 
                [M:SUR4]LABNBR(nolign-1) = int(evalue([F:TFO]FORFOR))
            Endif
        Else
            [M:SUR4]LABNBR(nolign-1) = [M:SUR2]LABNBRV
        Endif
        If [M:SUR4]LABNBR(nolign-1) <= 0 : [M:SUR4]LABNBR(nolign-1) = [F:ROT]LABNBR : Endif
        Read [MWS]WST0=[M:SUR4]LABWST(nolign-1);[F:ROT]FCY 
        If [M:SUR4]LABNBR(nolign-1) >  [F:MWS]WSTNBR : [M:SUR4]LABNBR(nolign-1) = [F:ROT]WSTNBR : Endif
    Endif  


    # réglage
    If [M:SUR2]FSETTIM = 2
        If [M:SUR2]SETTIMF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]SETTIMF
            If !fstat 
                [M:SUR4]SETTIM(nolign-1) = evalue([F:TFO]FORFOR)  
                If [M:SUR4]SETTIM(nolign-1) < 0 : [M:SUR4]SETTIM(nolign-1) = [F:ROT]SETTIM : Endif             
            Endif
        Else
            [M:SUR4]SETTIM(nolign-1) = [M:SUR2]SETTIMV
        Endif
    Endif


    # opératoire
    If [M:SUR2]FOPETIM = 2 & [M:SUR4]ROOTIMCOD(nolign-1) <> 2
        If [M:SUR2]OPETIMF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]OPETIMF
            If !fstat 
                [M:SUR4]OPETIM(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]OPETIM(nolign-1) < 0 : [M:SUR4]OPETIM(nolign-1) = [F:ROT]OPETIM : Endif
            Endif
        Else
            [M:SUR4]OPETIM(nolign-1) = [M:SUR2]OPETIMV
        Endif
    Endif


    # cadence
    If [M:SUR2]FCAD = 2 & [M:SUR4]ROOTIMCOD(nolign-1) = 2
        If [M:SUR2]CADF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]CADF
            If !fstat 
                [M:SUR4]CAD(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]CAD(nolign-1) <= 0 : [M:SUR4]CAD(nolign-1) = [F:ROT]CAD : Endif
            Endif
        Else
            [M:SUR4]CAD(nolign-1) = [M:SUR2]CADV
        Endif
    Endif
 
    # coeff. MO réglage
    If [M:SUR2]FSETLABCOE = 2 & [M:SUR4]LABWST(nolign-1) <> ""
        If [M:SUR2]SETLABCOEF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]SETLABCOEF
            If !fstat 
                [M:SUR4]SETLABCOE(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]SETLABCOE(nolign-1) <= 0 : [M:SUR4]SETLABCOE(nolign-1) = [F:ROT]SETLABCOE : Endif
            Endif
        Else
            [M:SUR4]SETLABCOE(nolign-1) = [M:SUR2]SETLABCOEV
        Endif
    Endif

    # coeff. MO opératoire
    If [M:SUR2]FOPELABCOE = 2 & [M:SUR4]LABWST(nolign-1) <> ""
        If [M:SUR2]OPELABCOEF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]OPELABCOEF
            If !fstat 
                [M:SUR4]OPELABCOE(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]OPELABCOE(nolign-1) < 0 : [M:SUR4]OPELABCOE(nolign-1) = [F:ROT]OPELABCOE : Endif
            Endif
        Else
            [M:SUR4]OPELABCOE(nolign-1) = [M:SUR2]OPELABCOEV
        Endif
    Endif


    # préparation
    If [M:SUR2]FPRPTIM = 2
        If [M:SUR2]PRPTIMF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]PRPTIMF
            If !fstat 
                [M:SUR4]PRPTIM(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]PRPTIM(nolign-1) <= 0 : [M:SUR4]PRPTIM(nolign-1) = [F:ROT]PRPTIM : Endif
            Endif
        Else
            [M:SUR4]PRPTIM(nolign-1) = [M:SUR2]PRPTIMV
        Endif
    Endif


    # attente
    If [M:SUR2]FWAITIM = 2
        If [M:SUR2]WAITIMF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]WAITIMF
            If !fstat 
                [M:SUR4]WAITIM(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]WAITIM(nolign-1) <= 0 : [M:SUR4]WAITIM(nolign-1) = [F:ROT]WAITIM : Endif
            Endif
        Else
            [M:SUR4]WAITIM(nolign-1) = [M:SUR2]WAITIMV
        Endif
    Endif


    # post-opératoire
    If [M:SUR2]FPSPTIM = 2
        If [M:SUR2]PSPTIMF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR2]PSPTIMF
            If !fstat 
                [M:SUR4]PSPTIM(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]PSPTIM(nolign-1) <= 0 : [M:SUR4]PSPTIM(nolign-1) = [F:ROT]PSPTIM : Endif
            Endif
        Else
            [M:SUR4]PSPTIM(nolign-1) = [M:SUR2]PSPTIMV
        Endif
    Endif


    # efficience
    If [M:SUR3]FEFF = 2
        If [M:SUR3]EFFF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR3]EFFF
            If !fstat 
                [M:SUR4]EFF(nolign-1) = evalue([F:TFO]FORFOR)
                If [M:SUR4]EFF(nolign-1) <= 0 : [M:SUR4]EFF(nolign-1) = [F:ROT]EFF : Endif
            Endif
        Else
            [M:SUR4]EFF(nolign-1) = [M:SUR3]EFFV
        Endif
    Endif


    # perte
    If [M:SUR3]FSHR = 2
        If [M:SUR3]SHRF <> ""
            Read [F:TFO]TFO0 = 9;[M:SUR3]SHRF
            If !fstat 
                [M:SUR4]SHR(nolign-1) = evalue([F:TFO]FORFOR)
            Endif
        Else
            [M:SUR4]SHR(nolign-1) = [M:SUR3]SHRV
        Endif
        If [M:SUR4]SHR(nolign-1) < -99 : [M:SUR4]SHR(nolign-1) = [F:ROT]SHR : Endif
    Endif


    # unité
    [M:SUR4]WUO(nolign-1) = [M:SUR4]OPEUOM(nolign-1)
    If [M:SUR3]FOPEUOM = 2
        # unité de gestion = tps/lot
        If [F:ROT]TIMCOD = 4 
            If [M:SUR3]OPEUOMV <>""
                [M:SUR4]OPEUOM(nolign-1) = [M:SUR3]OPEUOMV
                MAJUO =1 
            Endif  
        Else     
            [M:SUR4]OPEUOM(nolign-1) = [M:SUR3]OPEUOMV
            MAJUO =1   
        Endif
    Endif




Next

Filter [ROT]

[M:SUR4]NBLIG = nolign
Affzo [M:SUR4]

If nolign = WMAX : Call MESSAGE(mess(168,190,1)) From GESECRAN: Endif   # llc 04.03 17909

$FIN_TDUPDR
Return

######################################################################## 
$MODIF
Call TEMPON("V") From GESECRAN

If GTRACE=""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif

Gosub MODOPE
If !NBOPE
    WMESS=mess(371,197,1)
    Call ECR_TRACE(WMESS, 0) From GESECRAN
Endif
If [M]ROUUPD = 2 : Gosub MODROU : Endif    # 16571 11.02 MM
Call TEMPOFF From GESECRAN
Return

######################################################################## 
$MODOPE
# mise à jour des opérations std

Gosub MAJOPE
If NBOPE
    WMESS = num$(NBOPE)-mess(362,197,1)
    Call ECR_TRACE(WMESS, 0) From GESECRAN
    If MAJUO
        WMESS1 = mess(23,193,1)
        Call ECR_TRACE(WMESS1, 0) From GESECRAN
    Endif
Endif
Return

######################################################################## 
$MAJOPE
NBOPE = 0
Call DEBTRANS From GLOCK
GOK =1

Trbegin [ROT]
    For nolign =1 To [M]NBLIG
    Read [ROT]ROT0=[M]STDOPENUM(nolign-1);[M]FCY
    If fstat : Goto NXTOPE2 : Endif
    If [F:ROT]SETTIM     =  [M:SUR4]SETTIM(nolign-1)    &
&      [F:ROT]OPETIM     =  [M:SUR4]OPETIM(nolign-1)    & 
&      [F:ROT]PRPTIM     =  [M:SUR4]PRPTIM(nolign-1)    &
&      [F:ROT]WAITIM     =  [M:SUR4]WAITIM(nolign-1)    & 
&      [F:ROT]PSPTIM     =  [M:SUR4]PSPTIM(nolign-1)    & 
&      [F:ROT]SETLABCOE  =  [M:SUR4]SETLABCOE(nolign-1) &
&      [F:ROT]OPELABCOE  =  [M:SUR4]OPELABCOE(nolign-1) &
&      [F:ROT]CAD        =  [M:SUR4]CAD(nolign-1)       &
&      [F:ROT]WSTNBR     =  [M:SUR4]WSTNBR(nolign-1)    & 
&      [F:ROT]LABNBR     =  [M:SUR4]LABNBR(nolign-1)    & 
&      [F:ROT]OPEUOM     =  [M:SUR4]OPEUOM(nolign-1)    &    
&      [F:ROT]EFF        =  [M:SUR4]EFF(nolign-1)       &   
&      [F:ROT]SHR        =  [M:SUR4]SHR(nolign-1)   
       Goto NXTOPE2
Endif
$NXTOPE1
    WMESS = mess(52,197,1)-[M]FCY+"/"+num$([M]STDOPENUM(nolign-1))+"/"+[M]WST(nolign-1)
    Call ECR_TRACE(WMESS, 0) From GESECRAN
    If [M:SUR4]WUO(nolign-1)<>[M:SUR4]OPEUOM(nolign-1)   
        WMESS1="    "- mess(151, 190,1)- [M:SUR4]WUO(nolign-1)
        Call ECR_TRACE (WMESS1 , 0) From GESECRAN
    Endif
    Readlock [ROT]ROT0=[M]STDOPENUM(nolign-1);[M]FCY
    If fstat
        GOK = 0 : WCLE= num$([M]STDOPENUM(nolign-1) )-[M]FCY
        Call RSTA ("ROT", WCLE) From GLOCK
        Goto AB_MOD
    Endif
    
    [F:ROT] = [M:SUR4]
    Rewrite [ROT]
    If fstat
        GOK=0 : Call FSTA("ROT") From GLOCK
        Goto AB_MOD
    Endif
    [M]UPDFLG(nolign-1) = 2    #16571 11.02 MM
    NBOPE += 1

$NXTOPE2
    Next nolign
If GOK =1 : Commit : Endif

Return


########################################################################
#16571 11.02 MM 
$MODROU
Gosub MAJROU
WMESS = num$(NBROU)-mess(486,197,1)
Call ECR_TRACE(WMESS,0) From GESECRAN
If WOUM  
    WMESS1 = mess(23,193,1)
    Call ECR_TRACE(WMESS1, 0) From GESECRAN 
Endif

Return

######################################################################## 
# Mise à jour gamme 16571 11.02 MM 
$MAJROU
Local Integer X
Local Decimal WCOEFF
WOUM =0
NBROU = 0
GOK= 1

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(368,197,1),0) From GESECRAN


# filtre des OP du site
Filter [ROO] Where FCY= [M]FCY
    For [ROO]ROO4
        X= find ([F:ROO]STDOPENUM, [M]STDOPENUM(0..[M]NBLIG-1))
        If X= 0 : Goto NEXTROU : Endif


        # décrémentation du n°, pour être en phase avec l'indice du tableau
        X-=1

        # si OP std non modifiée
        If [M]UPDFLG(X)=1 : Goto NEXTROU : Endif

        WMESS1 = mess(370,197,1) - [F:ROO]ITMREF+"/"+num$([F:ROO]ROUALT)+
&                "/"+num$([F:ROO]OPENUM)+"/"+num$([F:ROO]STDOPENUM)
        Call ECR_TRACE(WMESS1,0)From GESECRAN

        Call DEBTRANS From GLOCK
        Trbegin [ROO]
            Readlock [ROO]Curr       
            If fstat
                GOK =0 : WCLE=[M]FCY-num$([M]STDOPENUM(X))
                Call RSTA ("RO0", WCLE) From GLOCK
                Goto AB_MOD
            Endif
            
            Gosub MODIF_OPE
  
            Rewrite [ROO]
            If fstat 
                GOK=0 : Call FSTA("ROO") From GLOCK
                Goto AB_MOD
            Endif

            NBROU += 1   
            If GOK =1 : Commit : Endif  
$NEXTROU
    Next

Filter [ROO] 
Return


######################################################################## 
# 16571 11.02 MM 
$MODIF_OPE
Local Decimal     KHM
Local Decimal     WSETTIM, WOPETIM, WCAD

Gosub CONVERSION
[F:ROO]SETTIM     = WSETTIM
[F:ROO]PRPTIM     = [M]PRPTIM(X)
[F:ROO]WAITIM     = [M]WAITIM(X)
[F:ROO]PSPTIM     = [M]PSPTIM(X)

# Type de temps opé
If [F:ROO]ROOTIMCOD = [M]ROOTIMCOD(X) 
    [F:ROO]OPETIM     = WOPETIM
    [F:ROO]CAD        = WCAD
Endif

# Efficience /Perte
If [F:ROO]WST = [M]WST(X)
    [F:ROO]EFF        = [M]EFF(X)
    [F:ROO]SHR        = [M]SHR(X)
Endif

# UO
If [F:ROO]OPEUOM <>[M]OPEUOM(X)
    WMESS1 ="    "-mess(151,190,1)-[F:ROO]OPEUOM
    Call ECR_TRACE(WMESS1, 0) From GESECRAN 
    [F:ROO]OPEUOM     = [M]OPEUOM(X)
    # recherche coefficient US/UO
    Read [ITM]ITM0=[F:ROO]ITMREF
    If !fstat
        Call RECH_COEFF([F:ITM]STU, [F:ROO]OPEUOM , WCOEFF) From MFGLIB
        If WCOEFF <> 0 : [F:ROO]OPESTUCOE  = WCOEFF
        Else  : [F:ROO]OPESTUCOE =1
            WMESS1 ="    "- mess(150,190,1) -"("+[F:ROO]OPEUOM-","-[F:ITM]STU+")"
            Call ECR_TRACE(WMESS1, 0) From GESECRAN
        Endif
        WOUM =1
    Endif
Endif

# Nb poste 
If [F:ROO]WSTNBR <>[M]WSTNBR(X)
    Read [MWS]WST0=[F:ROO]WST;[M:SUR4]FCY
    If fstat : End : Endif
    If [M]WSTNBR(X)> [F:MWS]WSTNBR 
        WMESS1 = "    "-mess(165,193,1)-"("+num$([F:MWS]WSTNBR)+")"
        Call ECR_TRACE(WMESS1, 0) From GESECRAN
    Else
        [F:ROO]WSTNBR       = [M]WSTNBR(X)
    Endif
Endif

# Nb poste MO
If [F:ROO]LABNBR <>[M]LABNBR(X)
    If [F:ROO]LABWST <>""
        Read [MWS]WST0=[F:ROO]LABWST;[M:SUR4]FCY
        If fstat : End : Endif
        If [M]LABNBR(X) > [F:MWS]WSTNBR
            WMESS1 = "    "- mess(207,193,1)-"("+num$([F:MWS]WSTNBR)+")"
            Call ECR_TRACE(WMESS1,0) From GESECRAN 
        Else
            [F:ROO]LABNBR       = [M]LABNBR(X)
        Endif
    Endif
Endif

# coef liées au poste MO
If [F:ROO]LABWST <>""
    If [M]SETLABCOE(X)<>0 : [F:ROO]SETLABCOE = [M]SETLABCOE(X): Else [F:ROO]SETLABCOE=1 : Endif
    If [M]OPELABCOE(X)<>0 : [F:ROO]OPELABCOE = [M]OPELABCOE(X): Else [F:ROO]OPELABCOE=1 : Endif
Endif


Return

######################################################################## 
# conversion de la cadence, des temps opératoire et de réglage. 16571 11.02 MM 
$CONVERSION
Read [ROH]ROH0=[F:ROO]ITMREF;[F:ROO]ROUALT;[M]FCY : # Beryl Site en fin de clé primaire
If !fstat 
    If [F:ROH]TIMUOMCOD=[M]TIMUOMCOD(X) 
       WSETTIM = [M]SETTIM(X)
       WOPETIM = [M]OPETIM(X) 
       WCAD    = [M]CAD(X) 
    Return : Endif 
    KHM =1
    If [M]TIMUOMCOD(X)=1 & [F:ROH]TIMUOMCOD=2 : KHM = 60  : Else : KHM =1/60 : Endif
    WSETTIM=KHM*[M]SETTIM(X)
    If [M]ROOTIMCOD(X)=1 : WOPETIM=KHM*[M]OPETIM(X) : Endif 
    If [M]ROOTIMCOD(X)=2 : WCAD=[M]CAD(X)/KHM : Endif 
    If [M]ROOTIMCOD(X)=3 : WOPETIM=KHM*[M]OPETIM(X) : Endif 

    WSETTIM        = arr( WSETTIM  , 0.0001)
    WOPETIM        = arr( WOPETIM  , 0.0001)         
    WCAD           = arr( WCAD     , 0.0001)    
Endif       

Return
######################################################################## 
$AB_MOD
Rollback
Call ECR_TRACE(mess(17, 107, 1), 1) From GESECRAN
Return

######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 


