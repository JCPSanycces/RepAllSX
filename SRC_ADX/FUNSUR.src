########################################
Subprog AV_ROOTIMCOD(VALEUR)
Variable Integer VALEUR
# si type tps opératoire = unitaire, seul le temps opératoire est saisi
# si type tps opératoire = cadence, seule la cadence est saisie
# ici, remise à zéro des tps non saisis
If VALEUR <> 0
   If VALEUR = 2
      [M]OPETIM(nolign-1)=0 
   Else 
      [M]CAD(nolign-1)=0    :
   Endif 
   If VALEUR<>1
      [M]TIMCOD(nolign-1)=0  
      [M]BASQTY(nolign-1)=0  
   Endif
Endif
End




########################################
Subprog C_WSTNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
If [M]WST(nolign-1) <> "" 
    Read [MWS]WST0=[M]WST(nolign-1);[M]FCY
    If VALEUR > [F:MWS]WSTNBR 
        GMESSAGE = mess(165,193,1) 
        mkstat = 2
    Endif
Endif

End

########################################
Subprog C_LABNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
If [M]LABWST(nolign-1) <> "" 
     Read [MWS]WST0=[M]LABWST(nolign-1);[M]FCY
     If VALEUR > [F:MWS]WSTNBR 
        GMESSAGE = mess(165,193,1) 
        mkstat = 2
     Endif
Endif
End

