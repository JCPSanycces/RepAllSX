       MAJUO = 1
End


########################################
Subprog AV_SCOWST(VALEUR)
Variable Char    VALEUR()
# affichage des zones liées au poste de sous-traitance
If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif 
If VALEUR <> ""
    Read [MWS]WST0=VALEUR;[M]FCY
    If !fstat
        [M]SCOWCR(nolign-1)=[F:MWS]WCR : [M]SCOWSTTYP(nolign-1)=[F:MWS]WSTTYP
    Endif 
Endif 
End


########################################
Subprog AS_OPETIM(VALEUR)
Variable Decimal VALEUR
    If [M]ROOTIMCOD(nolign-1)=2
          mkstat= 2
    Endif
End

########################################
Subprog AS_CAD(VALEUR)
Variable Decimal VALEUR
  If [M]ROOTIMCOD(nolign-1)<>2
      mkstat= 2
  Endif
End

