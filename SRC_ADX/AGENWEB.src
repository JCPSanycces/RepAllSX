#<AdxTL>@(#)12.0.0.0 $Revision$

##############################################################
## AGENWEB    Génération du traitement des WEB services
##############################################################
##############################################################

Raz GPILOBJ , GNBMASKOUV
Call OBJET("AWE",GBIDC1,GBIDC2) From GOBJET
End


$VERGEN
Local Char VERGEN
VERGEN="6.30"
Return

$ACTION
Return

$UNIQFIELD
Return
Local Integer IDX,JK
Local Char CHPN : CHPN=[M:AWE2]CHAMP(I-1)
$UNIQF1
JK=find([M:AWE2]CHAMP(I-1),PARAM(1..I-1))
If JK<>0
   IDX+=1
   [M:AWE2]CHAMP(I-1)=CHPN+"_"+num$(IDX)
   Goto UNIQF1
Endif
Return

$UNIQFIELDTAB
Return
Local Integer IDX,JK
Local Char CHPN : CHPN=PARAM(I)
$UNIQF1TAB
JK=find(CHPN,PARAM(1..I-1))
If JK<>0
   IDX+=1
   PARAM(I)=CHPN+"_"+num$(IDX)
   Goto UNIQF1TAB
Endif
Return


Subprog CHARGOBJ(TYPC,OBJET,VARIANTE,APPLI,INVISIBLE,PUBLI)
Value Char    TYPC
Value Char    OBJET
Value Char    VARIANTE
Value Char    APPLI
Value Integer INVISIBLE
Value Char    PUBLI

# Permet de charger #
#     - soit le masque AWE2        TYPC="MASK"
#     - soit la table AWEBSERDESC  TYPC="FILE"
# lorsque l'objet n'est pas enregistré dans AWEBSERDESC
# et de contrôler que l'objet est toujours en phase avec la description stockée.

Gosub DECLAREOBJ From AGENWEB

Read [A_OB]ABREV = OBJET
If fstat
 Call ECR_TRACE(OBJET-":"-mess(161,123,1),1) From GESECRAN : # Objet inexistant
 End
Endif
Read [A_WI]AWI2(2) = OBJET;VARIANTE
If fstat
 Call ECR_TRACE(OBJET-VARIANTE-":"-mess(107,133,1),1) From GESECRAN : # Pas de fenêtre
 End
Endif

If dim(ISNEW)<0
 Read [A_WE]AWE1 = PUBLI
 If fstat
  Call ECR_TRACE(PUBLI-":"-mess(216,124,1),1) From GESECRAN : # Web service non publié sur ce dossier
  End
 Endif
Endif

Local Char CBOUT(5)(1..20)
Local Char CACT(10)(1..20)
Local Integer NTEXB(1..20),NBBOUT
Call BWIN(APPLI,[F:A_WI]WIN,NBBOUT,CBOUT,CACT,NTEXB)
NBPAR = 0
NBECR = 0
NBTAB = 0
JTAB  = MAXOBJ
OK    = 1

If [F:A_WI]MSKENT<>""
 NBECR += 1
 ECRAN = [F:A_WI]MSKENT
 PMASK = left$(ALPHABET,1)
 Gosub ECRAN
 If !OK : Goto ERRDIM : Endif
Endif

# On range les écrans dans l'ordre de saisie  : CC 29/04/2010   Bug 64369
Local Integer ORDERSCR(0..[F:A_WI]NBMSK-1),RANGSCR(0..[F:A_WI]NBMSK-1),MASKSCR(0..[F:A_WI]NBMSK-1)
For I=0 To [F:A_WI]NBMSK-1
  ORDERSCR(I)=[F:A_WI]ROWMSK(I)
Next I
For I=0 To [F:A_WI]NBMSK-1
  For J=0 To [F:A_WI]NBMSK-1
    If ORDERSCR(J)<ORDERSCR(I) or (ORDERSCR(J)=ORDERSCR(I) and J<I) : RANGSCR(I)+=1 : Endif
  Next J
  MASKSCR(RANGSCR(I))=I
Next I

Local Integer II
For II=0 To [F:A_WI]NBMSK-1
 I=MASKSCR(II)
 OKMSK(I) = 1
 If [F:A_WI]ACTMSK(I)<>""
  Read [F:A_CV]CODACT = [F:A_WI]ACTMSK(I)
  If fstat or [F:A_CV]FLACT<>2
   OKMSK(I) = 0
  Endif
 Endif
 NBECR += 1
 If OKMSK(I)
  ECRAN = [F:A_WI]NOMMSK(I)
  PMASK = mid$(ALPHABET,I+2,1)
  Gosub ECRAN
  If !OK : Break : Endif
 Endif
Next II
If !OK : Goto ERRDIM : Endif



Local Integer II
For I=0 To [F:A_OB]NBSCR-1
 NBECR += 1
 ECRAN = [F:A_OB]SCRNAM(I)
 PMASK = mid$(ALPHABET,[F:A_WI]NBMSK+I+2,1)
 Gosub ECRAN
 If !OK : Break : Endif
 If [F:A_OB]SCRABR(I)<>""
  ABREV(NBECR) = [F:A_OB]SCRABR(I)
 Endif
Next I
If !OK : Goto ERRDIM : Endif

If TYPC="MASK"
    For I=1 To NBPAR
      [M:AWE2]SELECT(I-1)=2
      [M:AWE2]GROUPE(I-1)=ABREV(MASQUE(I))+"_"+num$(BLOC(I))
      [M:AWE2]CHAMP(I-1)=PARAM(I)
      Gosub UNIQFIELD
      [M:AWE2]GRPCHP(I-1)=ABREV(MASQUE(I))+"_"+num$(BLOC(I))+"~"+PARAM(I)
      [M:AWE2]NOTEX(I-1)=INTIT(I)
      Case TYP(I)
        When 1 : [M:AWE2]TYPPAR(I-1)=2 : # "Integer "
        When 2 : [M:AWE2]TYPPAR(I-1)=1 : # "Char    "
        When 3 : [M:AWE2]TYPPAR(I-1)=4 : # "Date    "
        When 4 : [M:AWE2]TYPPAR(I-1)=7 : # "Blbfile "
        When 5 : [M:AWE2]TYPPAR(I-1)=6 : # "Clbfile "
        When 6 : [M:AWE2]TYPPAR(I-1)=3 : # "Decimal "
        When Default : [M:AWE2]TYPPAR(I-1)=1 : # "Char    "
      Endcase
      If NOLIB(I)<>0 : [M:AWE2]TYPPAR(I-1)=5 : [M:AWE2]NOLIB(I-1)=NOLIB(I) : Endif # "Libelle "
      [M:AWE2]OBLIG(I-1)=OBLIG(I)
      If [M:AWE2]OBLIG(I-1)<>2 : [M:AWE2]OBLIG(I-1)=0 : Endif
      [M:AWE2]DIME(I-1)=DIME(I)
      [M:AWE2]NIVEAU(I-1)=1
      [M:AWE2]TYPFCT(I-1)=SAIAFF(I)
      [M:AWE2]OPTSAI(I-1)=OPTSAI(I)
      [M:AWE2]OPTFOR(I-1)=OPTFOR(I)
      [M:AWE2]LONG(I-1)=evalue(LNG(I))
      Call TEXTE([M:AWE2]NOTEX(I-1),[M:AWE2]INTIT(I-1)) From OBJDIV
      [M:AWE2]PBASTAB(I-1)=1
      If BASTAB(MASQUE(I),BLOC(I))<>"" : [M:AWE2]PBASTAB(I-1)=2 : Endif
    Next I
    [M:AWE2]NBLIG=NBPAR
Elsif TYPC="FILE"
 Local Integer IMAP
 Local Char CH1,CH2

 If dim(ABFIC)<0 : Local Char ABFIC : Endif
 Local Char SAVABFIC : SAVABFIC=ABFIC
 ABFIC="AWY"
 Local Integer COMLOC
 If adxlog=0 : COMLOC=1 : Trbegin [A_WY],[A_W1] : Endif

 For I=1 To NBPAR
  Gosub UNIQFIELDTAB
  Read [A_WY]AWY1=PUBLI;ABREV(MASQUE(I))+"_"+num$(BLOC(I));PARAM(I)
  If fstat=0
      [F:A_WY]LONCHP=LNG(I)
      [F:A_WY]NOLIB=NOLIB(I)
      [F:A_WY]IDX=I
      [F:A_WY]USERP=GUSER
      Gosub INIMOD From GOBJSUB
      Rewrite [A_WY]
  Else
      [F:A_WY]PUBLI=PUBLI
      [F:A_WY]SELECT=2
      [F:A_WY]GROUPE=ABREV(MASQUE(I))+"_"+num$(BLOC(I))
      [F:A_WY]CHAMP=PARAM(I)
      [F:A_WY]LONCHP=LNG(I)
      [F:A_WY]NOLIB=NOLIB(I)
      [F:A_WY]GRP=ABREV(MASQUE(I))+"_"+num$(BLOC(I))
      [F:A_WY]CHP=PARAM(I)
      [F:A_WY]USERP=GUSER
      [F:A_WY]IDX=I
      Gosub INICRE From GOBJSUB
      Write [A_WY]
  Endif
 Next I
 ABFIC=SAVABFIC

#  Suppression des éventuels champs plus utilisés
 Local Integer ITROUV
 Filter [A_WY] Where PUBLI=[L]PUBLI
 For [A_WY]
   ITROUV=find([F:A_WY]CHPPARAM,PARAM(1..NBPAR))
   If ITROUV=0
     Delete [A_W1] Where [A_W1]PUBLI=[L]PUBLI and [A_W1]GRP=[F:A_WY]GRP and [A_W1]CHP=[F:A_WY]CHP
   Endif
 Next
 Filter [AW_Y]
 If COMLOC=1 : Commit : Endif

Endif

End




$DECLAREOBJ
Local Integer MAXPAR : MAXPAR = 1000 : # Nb maximum de champs
Local Integer MAXECR : MAXECR = 24   : # Nb maximum d'écrans
Local Integer MAXBLC : MAXBLC = 15   : # Nb maxi de blocs/écran
Local Integer MAXOBJ : MAXOBJ = 36   : # Nb maxi d'écrans + tableaux
Local Integer LIMPAR2SRC : LIMPAR2SRC= 140   : # Nb de paramètres à partir duquel on crée 2 sources WJ** et WK**

Local Char    NOMTRT(GLONADC), NOMTRT1(GLONADC), NOMTRT2(GLONADC), NOMTRTX(GLONADC) , ECRAN(GLONAMK) , NOMFIC(250), NAMCH
Local Integer NBPAR , NBECR, JK, ISTRT1CR,ISTRT2CR
Local Char    PARAM(GLONADC+5)(1..MAXPAR) , NOM(GLONADC+5)(1..MAXPAR) , COM(30)(1..MAXPAR)
Local Integer DIME(1..MAXPAR) , BLOC(1..MAXPAR) , MASQUE(1..MAXPAR) , TYP(1..MAXPAR) , NOLIB(1..MAXPAR)
Local Integer SAIAFF(1..MAXPAR) , OBLIG(1..MAXPAR), INTIT(1..MAXPAR) , LISTLIB(1..200) , NBLIB
Local Char    OPTSAI(10)(1..MAXPAR),OPTFOR(50)(1..MAXPAR)

Local Integer SELCHP(1..MAXPAR)
Local Char    GRPCHOISI(40)(1..MAXPAR) , NOMCHOISI(40)(1..MAXPAR)

Local Char    LNG(GLONADC)(1..MAXPAR), CTYP(GLONATY)(1..MAXPAR)
Local Integer TYPBLC(1..MAXECR,1..MAXBLC) , DETBLC(1..MAXECR,1..MAXBLC) , INTITBLC(1..MAXECR,1..MAXBLC)
Local Char    BASTAB(GLONADC)(1..MAXECR,1..MAXBLC) ,OPTTAB(GLONADC)(1..MAXECR,1..MAXBLC) ,ABREV(GLONAOB)(1..MAXECR)
Local Integer DIMTAB(1..MAXECR,1..MAXBLC) , RANG(1..MAXECR,1..MAXBLC), INVTAB(1..MAXECR,1..MAXBLC)
Local Integer NBLOC(1..MAXECR) , DEBPAR(1..MAXECR) , FINPAR(1..MAXECR)
Local Integer I , J , K , OK , P , Q , Z1
Local Char    PROGWEB(GLONADC) , PMASK(5) , PTAB(5) , ABRLST(MAXECR)
Local Char    ALPHABET(MAXOBJ) , CHAINE(250) , DERCHP(GLONADC)
Local Integer MAXSAI , TYPVAR , SPA
Local Integer NBTAB , JTAB , BLCTYP
Local Char    ABR1(30) , ABR2(30) , VARIA1(50) , VARIA2(50), VALL1(200)
Local Char    SOUSPRO(30)(1..7)
Local Integer NBPRO
Local Char    REPCS(250) , MACCS(250) , FILCS(250) , FILAS(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Integer OKMSK(16)
Local Integer NBFLD      : # Nombre total de champs
Local Integer ACTINSLIG,ACTSUPLIG

If APPLI="" : APPLI = nomap : Endif
If clalev([F:A_WI])=0 : Local File =APPLI+".AWINDOW" [A_WI] : Endif
If clalev([F:A_MK])=0 : Local File =APPLI+".AMSK"    [A_MK] : Endif
If clalev([F:A_MZ])=0 : Local File =APPLI+".AMSKZON" [A_MZ] : Endif
If clalev([F:A_OB])=0 : Local File =APPLI+".AOBJET"  [A_OB] : Endif
If clalev([F:A_OL])=0 : Local File =APPLI+".AOBJLST" [A_OL] : Endif
If clalev([F:A_TY])=0 : Local File =APPLI+".ATYPE"   [A_TY] : Endif
If clalev([F:A_TX])=0 : Local File =APPLI+".ATEXTE"  [A_TX] : Endif
If clalev([F:A_CV])=0 : Local File =APPLI+".ACTIV"   [A_CV] : Endif
If clalev([F:A_ST])=0 : Local File =APPLI+".APLSTD"  [A_ST] : Endif
If clalev([F:A_TZ])=0 : Local File =APPLI+".ATABZON" [A_TZ] : Endif
If clalev([F:A_TI])=0 : Local File =APPLI+".ATABIND" [A_TI] : Endif
If clalev([F:A_XX])=0 : Local File =APPLI+".ATEXTRA" [A_XX] : Endif
If clalev([F:A_WY])=0 : Local File =APPLI+".AWEBSERDES" [A_WY] : Endif
If clalev([F:A_W1])=0 : Local File =APPLI+".AWEBSERDES" [A_W1] : Endif
If clalev([F:A_WE])=0 : Local File =APPLI+".AWEBSERVIC" [A_WE] : Endif
If clalev([F:A_MA])=0 : Local File =APPLI+".AMSKACT" [A_MA] : Endif
Return

$RIEN
Resume

Subprog CREOBJ(OBJET,VARIANTE,APPLI,INVISIBLE,PUBLI,VISU,HORDAT)
Value Char    OBJET
Value Char    VARIANTE
Value Char    APPLI
Value Integer INVISIBLE
Value Char    PUBLI
Value Integer VISU
Value Char    HORDAT

Gosub DECLAREOBJ



#NOMTRT  = "WJ"+OBJET+VARIANTE
#If INVISIBLE : NOMTRT+="_I" : Endif
NOMTRT  = "WJ"+PUBLI
NOMFIC  = filpath("TRT",NOMTRT,"src",APPLI)
PROGWEB = "AWEB"

ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0987654321"
MAXOBJ   = len(ALPHABET)


Read [A_OB]ABREV = OBJET
If fstat
 Call ECR_TRACE(OBJET-":"-mess(161,123,1),1) From GESECRAN : # Objet inexistant
 End
Endif
Read [A_WI]AWI2(2) = OBJET;VARIANTE
If fstat
 Call ECR_TRACE(OBJET-VARIANTE-":"-mess(107,133,1),1) From GESECRAN : # Pas de fenêtre
 End
Endif

Read [A_WE]AWE1 = PUBLI
If fstat
 Call ECR_TRACE(PUBLI-":"-mess(216,124,1),1) From GESECRAN : # Web service non publié sur ce dossier
 End
Endif

Local Char CBOUT(5)(1..20),MASKSAI
Local Char CACT(10)(1..20)
Local Integer NTEXB(1..20),NBBOUT
Call BWIN(APPLI,[F:A_WI]WIN,NBBOUT,CBOUT,CACT,NTEXB)
NBPAR = 0
NBECR = 0
NBTAB = 0
JTAB  = MAXOBJ
OK    = 1

If [F:A_WI]MSKENT<>""
 NBECR += 1
 ECRAN = [F:A_WI]MSKENT
 PMASK = left$(ALPHABET,1)
 Gosub ECRAN
 If !OK : Goto ERRDIM : Endif
Endif

# On range les écrans dans l'ordre de saisie  : CC 29/04/2010   Bug 64369
Local Integer ORDERSCR(0..[F:A_WI]NBMSK-1),RANGSCR(0..[F:A_WI]NBMSK-1),MASKSCR(0..[F:A_WI]NBMSK-1)
For I=0 To [F:A_WI]NBMSK-1
  ORDERSCR(I)=[F:A_WI]ROWMSK(I)
Next I
For I=0 To [F:A_WI]NBMSK-1
  For J=0 To [F:A_WI]NBMSK-1
    If ORDERSCR(J)<ORDERSCR(I) or (ORDERSCR(J)=ORDERSCR(I) and J<I) : RANGSCR(I)+=1 : Endif
  Next J
  MASKSCR(RANGSCR(I))=I
Next I

Local Integer II
For II=0 To [F:A_WI]NBMSK-1
 I=MASKSCR(II)
 OKMSK(I) = 1
 If [F:A_WI]ACTMSK(I)<>""
  Read [F:A_CV]CODACT = [F:A_WI]ACTMSK(I)
  If fstat or [F:A_CV]FLACT<>2
   OKMSK(I) = 0
  Endif
 Endif
 NBECR += 1
 If OKMSK(I)
  ECRAN = [F:A_WI]NOMMSK(I)
  PMASK = mid$(ALPHABET,I+2,1)
  Gosub ECRAN
  If !OK : Break : Endif
 Endif
Next II
If !OK : Goto ERRDIM : Endif



Local Integer II
For I=0 To [F:A_OB]NBSCR-1
 NBECR += 1
 ECRAN = [F:A_OB]SCRNAM(I)
 PMASK = mid$(ALPHABET,[F:A_WI]NBMSK+I+2,1)
 Gosub ECRAN
 If !OK : Break : Endif
 If [F:A_OB]SCRABR(I)<>""
  ABREV(NBECR) = [F:A_OB]SCRABR(I)
 Endif
Next I
If !OK : Goto ERRDIM : Endif


# Si nombre de variables dépasse 65000 on arrête
For I=1 To NBPAR
  NBFLD+=DIME(I)
Next I
If NBFLD > 65000 : Goto ERRNBVAR : Endif
#Infbox("Nombre de variables : " + num$(NBFLD))
Onerrgo RIEN
Local File =APPLI+"."+[F:A_OB]NOMFIC
Gosub OUVRE_LISTE From ="WO"+OBJET
Onerrgo

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
Openo NOMFIC,0
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.1  $"
Wrseq
Wrseq "#########################################################################"
Wrseq "## Publication d'un objet sous forme de web service "
Wrseq "## Objet                    :"-OBJET
Wrseq "## Transaction              :"-VARIANTE
Wrseq "## Champs Invisibles        :"-mess(INVISIBLE+1,1,1)
Wrseq "## Fenêtre                  :"-[F:A_WI]WIN
Wrseq "## Nom de Publication       :"-PUBLI
Wrseq "## Timestamp de génération  :"-HORDAT
Gosub VERGEN
Wrseq "## Version de génération    :"-VERGEN
Wrseq "#########################################################################"
Wrseq "## Subprog OBJET(OK,ZONE,STAT,GRAVE,MESS,ACTION,IDENT,NB,HORDAT,...)"
Wrseq "## Subprog LISTE(OK,ZONE,STAT,GRAVE,MESS,ACTION,IDENT,NB,HORDAT,...)"
Wrseq "#########################################################################"
Wrseq "## Subprog TEST"
Wrseq "## Subprog TEST_LISTE(NBLISTE)"
Wrseq "#########################################################################"
Wrseq "#Call TEST"
Wrseq "Call TEST_LISTE(10)"
Wrseq "End"
Wrseq

Wrseq "#########################################################################"
Wrseq "## Test de lecture"
Wrseq "#########################################################################"
Wrseq "Subprog TEST"
Wrseq "Local Char    TEXTE(20)"
Wrseq "Local Integer I , J , K"
Wrseq 'Call OUVRE_TRACE("") From LECFIC'
Wrseq "Gosub DEFVAR"
Wrseq 'WW_ACTION = "READ"      : # READ, CREATE, MODIFY, DELETE, SUPLIG, INSLIG'
Wrseq 'WW_IDENT  = ""          : # Clé de l Objet Val1~Val2 '

Wrseq
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub INITMAJ From ZZWS'+OBJET
Wrseq 'Onerrgo'
Wrseq
Wrseq "Gosub WEBSERV"
Wrseq "Gosub ANALRESOBJ"
Wrseq
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub RESMAJ From ZZWS'+OBJET
Wrseq 'Onerrgo'
Wrseq

Wrseq "#Gosub DETAILRES      : # Pour afficher le détail des variables lues ou écrites"


Wrseq 'Call FERME_TRACE From LECFIC'
Wrseq 'Call LEC_TRACE From LECFIC'
Wrseq "End"
Wrseq
Wrseq '$ERREURWS'
Wrseq 'Resume'
Wrseq

Wrseq "#########################################################################"
Wrseq "## Test liste gauche"
Wrseq "#########################################################################"
Wrseq "Subprog TEST_LISTE(NBLISTE)"
Wrseq "Value Integer NBLISTE"
Wrseq 'Call OUVRE_TRACE("") From LECFIC'
Wrseq "Gosub DEFLISTE"
Wrseq 'WW_ACTION="LIST"'
# Positionnement du filtre
Local Integer NBSEL

Read [A_OL]AOL0=OBJET
If fstat=0
  NBSEL=[F:A_OL]NBSEL
  Wrseq "# Left list Description "
  For I=1 To [F:A_OL]NBSEL
    VALL1="# "+num$(I)+" : "+[F:A_OL]SELZON(I-1)
    If VALL1="" : VALL1="# "+num$(I)+" : C"+num$(I) : Endif
    IINTIT=0
    If  [F:A_OL]SELFIC(I-1)<>"" and [F:A_OL]SELZON(I-1)<>""
      Read [A_TZ]CODZONE=[F:A_OL]SELFIC(I-1);[F:A_OL]SELZON(I-1)
      If fstat=0 : IINTIT=[F:A_TZ]NOLONG : Endif
    Endif
    If[F:A_OL]SELINT(I-1)<>0 : IINTIT=[F:A_OL]SELINT(I-1) : Endif
    Read [A_TX]NUMERO = GLANGUE;IINTIT
    If fstat=0 : VALL1 -= [F:A_TX]TEXTE : Endif
    Wrseq VALL1
  Next I
  Wrseq " # Filter for columns"
  VALL1='#WW_IDENT="'
  For I=1 To [F:A_OL]NBSEL
    VALL1+="Col"+num$(I)+"~"
  Next I
  VALL1+='"'
  Wrseq VALL1
Endif

Wrseq
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub INITLG From ZZWS'+OBJET
Wrseq 'Onerrgo'
Wrseq
Wrseq "WW_NB=NBLISTE"
Wrseq "Gosub WEBLISTE"
Wrseq "Gosub ANALRESOBJ"

Wrseq
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub RESLG From ZZWS'+OBJET
Wrseq 'Onerrgo'
Wrseq

Wrseq "For indice=1 To WW_NB"
Wrseq "  If indice=1"
Wrseq '    Call ECR_TRACE(mess(223,123,1),0) From GESECRAN'
Wrseq '    Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'
Wrseq '  Endif'
Wrseq '  Call ECR_TRACE(num$(indice)+":"'
For I=1 To [F:A_OL]NBSEL
 If I<>[F:A_OL]NBSEL
  Wrseq '&  -WW_SEL'+num$(I)+'(indice)'
 Else
  Wrseq '&  -WW_SEL'+num$(I)+'(indice),0) From GESECRAN'
 Endif
Next I
Wrseq 'Next indice'
Wrseq 'Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'
Wrseq 'Call FERME_TRACE From LECFIC'
Wrseq 'Call LEC_TRACE From LECFIC'
Wrseq "End"
Wrseq
Wrseq
Wrseq "$ANALRESOBJ"
Wrseq "Case WW_ACTION"
Wrseq ' When "READ"   : TEXTE =mess(220,123,1) :   # "Lecture"'
Wrseq ' When "CREATE" : TEXTE =mess(59,123,1)  :   # "Création"'
Wrseq ' When "MODIFY" : TEXTE =mess(60,123,1)  :   # "Modif"'
Wrseq ' When "DELETE" : TEXTE =mess(53,123,1)  :   # "Suppression"'
Wrseq ' When "LIST"   : TEXTE =mess(137,124,1) :   # "Liste"'
Wrseq ' When "SUPLIG" : TEXTE =mess(92,9009,1) :   # "Suppression ligne"'
Wrseq ' When "INSLIG" : TEXTE =mess(91,9009,1) :   # "Insertion ligne"'
Wrseq 'Endcase'

Wrseq 'Call ECR_TRACE(mess(218,123,1)+" : "+num$(WW_OK)-"("+mess(WW_OK+3,2940,1)+")",0) From GESECRAN'

Wrseq 'Case WW_OK'
Wrseq " When 0"
Wrseq '    If WW_ZONE<>""'
Wrseq '      Call ECR_TRACE(TEXTE-WW_IDENT-":"-mess(32,126,1)-WW_ZONE,0) From GESECRAN'
Wrseq '    Endif'
Wrseq " When 1"
Wrseq '   Call ECR_TRACE(TEXTE-WW_IDENT-":"-"OK",0) From GESECRAN'
Wrseq " When 9"
Wrseq '   Call ECR_TRACE(mess(221,123,1),1) From GESECRAN'    : #  XML déphasé
Wrseq "Endcase"
Wrseq 'Call ECR_TRACE(" ",0) From GESECRAN'

Wrseq 'Call ECR_TRACE(mess(219,123,1)+" : "+num$(WW_STAT),0) From GESECRAN'
Wrseq 'Call ECR_TRACE("",0) From GESECRAN'
Wrseq 'Call ECR_TRACE(mess(222,123,1),0) From GESECRAN'
Wrseq 'Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'

Wrseq "For indice=1 To WW_STAT"
Wrseq "  If WW_GRAVE(indice)=3"
Wrseq '    Call ECR_TRACE(num$(indice)-num$(WW_GRAVE(indice))+" ("+mess(WW_GRAVE(indice),2940,1)+") :"-WW_MESS(indice),1) From GESECRAN'
Wrseq '  Else'
Wrseq '    Call ECR_TRACE(num$(indice)-num$(WW_GRAVE(indice))+" ("+mess(WW_GRAVE(indice),2940,1)+") :"-WW_MESS(indice),0) From GESECRAN'
Wrseq '  Endif'
Wrseq 'Next indice'
Wrseq 'If WW_STAT=0 : Call ECR_TRACE("",0) From GESECRAN : Endif'
Wrseq 'Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'
Wrseq "Return"
Wrseq
Wrseq
Wrseq "$DEFVAR"
Wrseq "Local Integer WW_OK"
Wrseq "Local Char    WW_ZONE(30)"
Wrseq "Local Integer WW_STAT"
Wrseq "Local Integer WW_GRAVE(1..50)"
Wrseq "Local Char    WW_MESS(250)(1..50)"
Wrseq "Local Char    WW_ACTION"
Wrseq "Local Char    WW_IDENT(250)"
Wrseq "Local Integer WW_NB"
Wrseq "Local Char    WW_HORDAT(14)"
Wrseq "Local Char    WW_TAB(20)"
Wrseq "Local Char    WW_PAR(80)(1..10)"
Wrseq "Local Clbfile WW_TRACE(1)"
Wrseq 'WW_HORDAT="'+HORDAT+'"'
For I=1 To NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  Wrseq "Local ";
  Case TYP(I)
   When 1 : Wrseq "Integer ";
   When 2 : Wrseq "Char    ";
   When 3 : Wrseq "Date    ";
   When 4 : Wrseq "Blbfile ";
   When 5 : Wrseq "Clbfile ";
   When 6 : Wrseq "Decimal ";
  Endcase
  Wrseq NOM(I);
  Case TYP(I)
   When 2   : Wrseq "(";LNG(I);")";
   When 4   : Wrseq "(";num$(GLONABB);")";
   When 5   : Wrseq "(";num$(GLONACB);")";
  Endcase
  If TYPBLC(MASQUE(I),BLOC(I))=1 & PARAM(I)<>BASTAB(MASQUE(I),BLOC(I))
   Wrseq "(0..";num$(DIMTAB(MASQUE(I),BLOC(I))-1);")"
  Elsif DIME(I)>1
   Wrseq "(0..";num$(DIME(I)-1);")"
  Else
   Wrseq
  Endif
 Endif
Next I
Wrseq "Local Char    WW_MODSTAMP(20)"
Wrseq "Local Char    WW_MODUSER(20)"

Wrseq "Return"
Wrseq
Wrseq "$WEBSERV"
Wrseq "Call OBJET(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION,WW_IDENT,WW_NB"
Wrseq "&         ,WW_HORDAT,WW_TAB,WW_PAR,WW_TRACE"
Wrseq "& ";
J = 0
For I=1 To NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  J += 1
  If mod(J,10)=0
   Wrseq
   Wrseq "& ";
  Endif
  Wrseq ",";NOM(I);
 Endif
Next I
Wrseq ",WW_MODSTAMP,WW_MODUSER)"
Wrseq "& From"-NOMTRT
Wrseq "Return"
Wrseq
Wrseq "$DETAILRES"
Wrseq '   Call ECR_TRACE("WW_MODSTAMP"-":"-num$(WW_MODSTAMP),0) From GESECRAN'
Wrseq '   Call ECR_TRACE("WW_MODUSER"-":"-num$(WW_MODUSER),0) From GESECRAN'
Wrseq '# '
For I=1 To NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0 and TYP(I)<>4 and TYP(I)<>5
  Wrseq '   Call ECR_TRACE("'+NOM(I)+'"-":"-num$('+NOM(I)+'),0) From GESECRAN'
 Endif
Next I
Wrseq "Return"
Wrseq
Wrseq "$DEFLISTE"
Wrseq "Local Integer WW_OK"
Wrseq "Local Char    WW_ZONE(30)"
Wrseq "Local Integer WW_STAT"
Wrseq "Local Integer WW_GRAVE(1..50)"
Wrseq "Local Char    WW_MESS(250)(1..50)"
Wrseq "Local Char    WW_ACTION"
Wrseq "Local Char    WW_IDENT(250)"
Wrseq "Local Integer WW_NB"
Wrseq "Local Char    WW_HORDAT(14)"
Wrseq "Local Char    WW_TAB(20)"
Wrseq "Local Char    WW_PAR(80)(1..10)"
Wrseq "Local Clbfile WW_TRACE(1)"
Wrseq 'WW_HORDAT="'+HORDAT+'"'
#Wrseq "Local Integer WW_OK"
#Wrseq "Local Integer WW_STAT"
#Wrseq "Local Integer WW_GRAVE(1..10)"
#Wrseq "Local Char    WW_MESS(80)(1..10)"
#Wrseq "Local Char    WW_IDENT(250)"
#Wrseq "Local Integer WW_NB"
For I=1 To [F:A_OL]NBSEL
 Wrseq "Local Char    WW_SEL"+num$(I)+"(30)(1..NBLISTE)"
Next I
Wrseq "Return"
Wrseq
Wrseq "$WEBLISTE"
Wrseq "Call LISTE(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION,WW_IDENT,WW_NB"
Wrseq "&         ,WW_HORDAT,WW_TAB,WW_PAR,WW_TRACE"
Wrseq "& ";
For I=1 To [F:A_OL]NBSEL
 Wrseq ",WW_SEL"+num$(I);
Next I
Wrseq ")"
Wrseq "& From"-NOMTRT
Wrseq "Return"
Wrseq

Wrseq "#########################################################################"
Wrseq "## Gestion de l'objet ";OBJET
Wrseq "#########################################################################"
Wrseq "Subprog OBJET(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION,WW_IDENT,WW_NB"
Wrseq "&         ,WW_HORDAT,WW_TAB,WW_PAR,WW_TRACE"
Wrseq "& ";
J = 1
For I=1 To NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  J += 1
  If mod(J,10)=0
   Wrseq
   Wrseq "& ";
  Endif
  Wrseq ",";NOM(I);
 Endif
Next I
Wrseq ",WW_MODSTAMP,WW_MODUSER)"
Wrseq
Wrseq "Variable Integer WW_OK                            : # Statut de retour 1=OK, 0=Pas OK, 2=XML déphasé)"
Wrseq "Variable Char    WW_ZONE()                        : # Zone de sortie"
Wrseq "Variable Integer WW_STAT                          : # Nombre d'événements"
Wrseq "Variable Integer WW_GRAVE(1..)                    : # Gravité (1=info, 2=warning, 3=erreur)"
Wrseq "Variable Char    WW_MESS()(1..)                   : # Texte événements"
Wrseq "Value    Char    WW_ACTION               : # (READ, CREATE, MODIFY, DELETE, LIST, INSLIG, SUPLIG, ..)"
Wrseq "Value    Char    WW_IDENT()                       : # Identifiant (cle1~cle2~...)"
Wrseq "Variable Integer WW_NB                            : # Nb d'éléments retournés (liste)"
Wrseq "Variable Char    WW_HORDAT()                      : # Horodatage"
Wrseq "Variable Char    WW_TAB()                         : # Identification tableau pour maj lignes"
Wrseq "Variable Char    WW_PAR()(1..)                    : # Identification lignes"
Wrseq "Variable Clbfile WW_TRACE()                       : # Trace serveur"
For I=1 To NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  CHAINE = "Variable "
  Case TYP(I)
   When 1 : CHAINE += "Integer "
   When 2 : CHAINE += "Char    "
   When 3 : CHAINE += "Date    "
   When 4 : CHAINE += "Blbfile "
   When 5 : CHAINE += "Clbfile "
   When 6 : CHAINE += "Decimal "
  Endcase
  CHAINE += NOM(I)
  If find(TYP(I),2,4,5)
   CHAINE += "()"
  Endif
  If TYPBLC(MASQUE(I),BLOC(I))=1 & PARAM(I)<>BASTAB(MASQUE(I),BLOC(I))
   CHAINE += "(0..)"
  Elsif DIME(I)>1
   CHAINE += "(0.."+num$(DIME(I)-1)+")"
  Endif
  If TYP(I)=2
   CHAINE -= "Sized"-num$(evalue(LNG(I)))
  Endif
  Wrseq CHAINE;space$(max(0,50-len(CHAINE)));": # ";COM(I)
 Endif
Next I
Wrseq "Variable Char    WW_MODSTAMP()                    : # Timestamp modif objet"
Wrseq "Variable Char    WW_MODUSER()                     : # User modifieur de l'objet"
Wrseq
Wrseq "WW_OK=0"
Wrseq "Gosub ISDBGON from AWEB"
Wrseq "If WW_OK<>0 : End : Endif"
Wrseq "Local Char    WW_OBJET(GLONAOB)"
Wrseq "Local Char    WW_PROG(GLONADC)"
Wrseq "Local Char    WW_BOITE(GLONADC)"
Wrseq "Local Char    WW_VARIANTE(GLONADC)"
Wrseq "Local Char    WW_TEXTE(250)"
Wrseq "Local Char    WW_BOUT(50)"
Wrseq "Local Integer WW_I"
Wrseq
Wrseq 'WW_OBJET    = "'+OBJET+'"'
Wrseq 'WW_PROG     = "'+NOMTRT+'"'
Wrseq 'WW_BOITE    = "'+[F:A_WI]WIN+'"'
Wrseq 'WW_VARIANTE = "'+VARIANTE+'"'
Wrseq
Wrseq "Local Char HORDAT1(14)"
#Wrseq 'HORDAT1="'+num$(HORDAT)+'"'
Wrseq "Local Char HORDATG(14),VERGEN"
Wrseq 'HORDATG="'+num$(HORDAT)+'"'
Gosub VERGEN
Wrseq 'VERGEN="'+num$(VERGEN)+'"'
Wrseq 'Call RECUPHDAT("'+PUBLI+'",HORDAT1,WW_I) from AWEB'
Wrseq "Gosub ANLHOROBJ From AWEB"
Wrseq 'If WW_OK<>0 : Gosub SETTRACE : End : Endif'
Wrseq
# Boutons "fenêtre"
Wrseq '# Liste des Boutons fenetres'
CHAINE=""
For I=1 To NBBOUT
  Wrseq '#  Bouton '+CBOUT(I)+'   No action interne : '+num$(100+I)+'    Code action : '+CACT(I)
  CHAINE+=right$(CBOUT(I),len(CBOUT(I)))
Next I
Wrseq 'WW_BOUT="'+CHAINE+'"'

Wrseq 'Local Integer AOB_GES : AOB_GES='+num$([F:A_OB]TYPGES)
Wrseq 'Local Char ALIAS : ALIAS="'+PUBLI+'"'
#  Point d'entrée wrapper
Wrseq 'Local Char ACTION'
Wrseq 'ACTION="AV_WS"'
Wrseq 'GPE=0'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'


Wrseq 'If GPE<>1'
Wrseq " Gosub OBJET From "+PROGWEB
Wrseq 'Endif'
Wrseq
Wrseq 'ACTION="AP_WS"'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'

Wrseq "Gosub SETTRACE"

Wrseq "End"
Wrseq

Gosub SETTRACE
Wrseq

Local Char WABRMSK(GLONABR),WMSK(GLONAMK)


Wrseq "$OUVRE_MASK"
If [F:A_WI]MSKENT<>""
 Wrseq "Local Mask "+format$("K:12X",[F:A_WI]MSKENT)+" [A_W0]"
 WMSK =[F:A_WI]MSKENT : WABRMSK = "A_W0": Gosub SET_VARIA_BLOC
 ABRLST = left$("0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ",MAXECR)
Else
 ABRLST = "123456789ABCDEFGHIJKLMNOPQ"
Endif
For II=0 To [F:A_WI]NBMSK-1
 I=MASKSCR(II)
 If OKMSK(I)
  Wrseq "Local Mask "+format$("K:12X",[F:A_WI]NOMMSK(I))+" [A_W"+mid$("123456789ABCDEFGHIJK",II+1,1)+"]"
  WMSK =[F:A_WI]NOMMSK(I) : WABRMSK = "A_W"+mid$("123456789ABCDEFGHIJK",II+1,1) : Gosub SET_VARIA_BLOC
 Endif
Next II
For I=0 To [F:A_OB]NBSCR-1
 Wrseq "Local Mask "+format$("K:12X",[F:A_OB]SCRNAM(I))+" [A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1)+"]"
 WMSK =[F:A_OB]SCRNAM(I) : WABRMSK = "A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1) : Gosub SET_VARIA_BLOC
Next I
#   On génère une ligne Default Mask si la fenêtre n'a pas d'écran d'entête (bug sur PNH)
If [F:A_WI]MSKENT<>""
 Read [A_MK]CODMSK =[F:A_WI]MSKENT
 If fstat=0
   Wrseq "Default Mask ["+format$("K:10X",[F:A_MK]ABRMSK)+"]"
   WMSK =[F:A_MK]ABRMSK : WABRMSK = format$("K:10X",[F:A_MK]ABRMSK) : Gosub SET_VARIA_BLOC
 Endif
Endif
Wrseq "Return"
Wrseq

Local Char WABRMSK(GLONABR)
Wrseq "$SAISIE_MASK"
K = 0
If [F:A_WI]MSKENT<>""
 K = 1
 ABR1 = "[M:"+ABREV(1)+"]"
 ABR2 = "[M:A_W0]"
 WABRMSK = "A_W0"
 MASKSAI=[F:A_WI]MSKENT
 Gosub SAIZONE
Endif
For I=0 To [F:A_WI]NBMSK-1
 K += 1
 If OKMSK(I)
  ABR1 = "[M:"+ABREV(K)+"]"
  ABR2 = "[M:A_W"+mid$("123456789ABCDEFGHIJK",I+1,1)+"]"
  MASKSAI=[F:A_WI]NOMMSK(I)
  WABRMSK = "A_W"+mid$("123456789ABCDEFGHIJK",I+1,1)
  Gosub SAIZONE
 Endif
Next I
#      On remplace l'affectation du masque par un Saizo
For I=0 To [F:A_OB]NBSCR-1
  K += 1
  ABR1 = "[M:"+ABREV(K)+"]"
  ABR2 = "[M:A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1)+"]"
  MASKSAI=[F:A_OB]SCRNAM(I)
  WABRMSK = "A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1)
  Gosub SAIZONE
Next I
#For I=0 To [F:A_OB]NBSCR-1
# K += 1
# Wrseq "[M:"+ABREV(K)+"] = [M:A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1)+"]"
#Next I
Wrseq "mkstat=0"    :# Bug 68789      CC - 02/11/2010
Wrseq "Return"
Wrseq

If NBPAR>LIMPAR2SRC
  Gosub CRESRCWK
  Wrseq "$CHARGE"
  Wrseq "Gosub CHARGE from "+NOMTRT1
  Wrseq "Return"
Endif

VALL1="$CHARGE" : Gosub ECRWJWK
If [F:A_WI]MSKENT<>""
 VALL1="Raz [M:A_W0]" : Gosub ECRWJWK
Endif
For I=0 To [F:A_WI]NBMSK-1
 If OKMSK(I)
  VALL1="Raz [M:A_W"+mid$("123456789ABCDEFGHIJK",I+1,1)+"]" : Gosub ECRWJWK
 Endif
Next I
For I=0 To [F:A_OB]NBSCR-1
 VALL1="Raz [M:A_W"+mid$("123456789ABCDEFGHIJK",I+1+[F:A_WI]NBMSK,1)+"]" : Gosub ECRWJWK
Next I
I = 1
While I<=NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  Case TYPBLC(MASQUE(I),BLOC(I))
   When 1
    VARIA1 = "[M:A_W"+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))
    K = find(BASTAB(MASQUE(I),BLOC(I)),PARAM(I..NBPAR))
    VARIA2 = "[L]"+NOM(I+K-1)
    TYPVAR = TYP(I+K-1)
    SPA = 0 : Gosub ECRIVARWK
    VALL1= 'If WW_ACTION="MODIFY" and [M:A_W'+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))+'=0' : Gosub ECRWJWK
    VALL1= '  '+'[M:A_W'+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))+' = max('+'[M:A_W'+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))+
&    ','+"[M:"+ABREV(MASQUE(I))+"]"+BASTAB(MASQUE(I),BLOC(I))+')' : Gosub ECRWJWK
    VALL1= 'Endif' : Gosub ECRWJWK
    VALL1="For WW_I=0 To [M:A_W"+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))+"-1" : Gosub ECRWJWK
    For J=I To NBPAR
     If MASQUE(J)<>MASQUE(I) or BLOC(J)<>BLOC(I)
      Break
     Endif
     If PARAM(J)<>BASTAB(MASQUE(I),BLOC(I)) and SAIAFF(J)<>3
      VARIA1 = "[M:A_W"+mid$(ABRLST,MASQUE(J),1)+"]"+PARAM(J)+"(WW_I)"
      VARIA2 = "[L]"+NOM(J)+"(WW_I)"
      TYPVAR = TYP(J)
      SPA = 1 : Gosub ECRIVARWK
     Endif
    Next J
    I = J-1
    VALL1="Next WW_I" : Gosub ECRWJWK
#   When 2,4
   When Default
    If SAIAFF(I)<>3
     TYPVAR = TYP(I)
     If DIME(I)>1
      For J=1 To DIME(I)
       VARIA1 = "[M:A_W"+mid$(ABRLST,MASQUE(I),1)+"]"+PARAM(I)+"("+num$(J-1)+")"
       VARIA2 = "[L]"+NOM(I)+"("+num$(J-1)+")"
       SPA = 0 : Gosub ECRIVARWK
      Next J
     Else
      VARIA1 = "[M:A_W"+mid$(ABRLST,MASQUE(I),1)+"]"+PARAM(I)
      VARIA2 = "[L]"+NOM(I)
      SPA = 0 : Gosub ECRIVARWK
     Endif
    Endif
  Endcase
 Endif
 I += 1
Wend
VALL1="Return" : Gosub ECRWJWK
VAL1=" " : Gosub ECRWJWK

# ----------------------------------------------------------------------------------------------------
If NBPAR>LIMPAR2SRC
  Wrseq " "
  Wrseq "$CHARGEINV"
  Wrseq "Gosub CHARGEINV from "+NOMTRT1
  Wrseq "Return"
Endif

VALL1="$CHARGEINV" : Gosub ECRWJWK
I = 1
While I<=NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  Case TYPBLC(MASQUE(I),BLOC(I))
   When 1
    VARIA1 = "[M:"+ABREV(MASQUE(I))+"]"+BASTAB(MASQUE(I),BLOC(I))
    K = find(BASTAB(MASQUE(I),BLOC(I)),PARAM(I..NBPAR))
    VARIA2 = "[L]"+NOM(I+K-1)
    TYPVAR = TYP(I+K-1)
    If SAIAFF(I)=3        # JPJ E57681
        SPA = 0 : Gosub ECRIVARWK
    Endif
    VALL1="For WW_I=0 To [M:A_W"+mid$(ABRLST,MASQUE(I),1)+"]"+BASTAB(MASQUE(I),BLOC(I))+"-1" : Gosub ECRWJWK
    For J=I To NBPAR
     If MASQUE(J)<>MASQUE(I) or BLOC(J)<>BLOC(I)
      Break
     Endif
     If PARAM(J)<>BASTAB(MASQUE(I),BLOC(I)) and SAIAFF(J)=3
      VARIA1 = "[M:"+ABREV(MASQUE(J))+"]"+PARAM(J)+"(WW_I)"
      VARIA2 = "[L]"+NOM(J)+"(WW_I)"
      TYPVAR = TYP(J)
      SPA = 1 : Gosub ECRIVARWK
     Endif
    Next J
    I = J-1
    VALL1="Next WW_I" : Gosub ECRWJWK
#   When 2,4
   When Default
    If SAIAFF(I)=3
     TYPVAR = TYP(I)
     If DIME(I)>1
      For J=1 To DIME(I)
       VARIA1 = "[M:"+ABREV(MASQUE(I))+"]"+PARAM(I)+"("+num$(J-1)+")"
       VARIA2 = "[L]"+NOM(I)+"("+num$(J-1)+")"
       SPA = 0 : Gosub ECRIVARWK
      Next J
     Else
      VARIA1 = "[M:"+ABREV(MASQUE(I))+"]"+PARAM(I)
      VARIA2 = "[L]"+NOM(I)
      SPA = 0 : Gosub ECRIVARWK
     Endif
    Endif
  Endcase
 Endif
 I += 1
Wend
VALL1="Return" : Gosub ECRWJWK
VALL1=" " : Gosub ECRWJWK

# -----------------------------------------------------------------------------------------

If NBPAR>LIMPAR2SRC
  Wrseq " "
  Wrseq "$DECHARGE"
  Wrseq "Gosub DECHARGE from "+NOMTRT1
  Wrseq "Return"
Endif

VALL1="$DECHARGE" : Gosub ECRWJWK
I = 1
While I<=NBPAR
 If DETBLC(MASQUE(I),BLOC(I))=0
  Case TYPBLC(MASQUE(I),BLOC(I))
   When 1
    K = find(BASTAB(MASQUE(I),BLOC(I)),PARAM(I..NBPAR))
    #VALL1=format$("K:30X","[L]"+NOM(I+K-1))
    VALL1="[L]"+NOM(I+K-1)
    VALL1+=" = [M:"+ABREV(MASQUE(I))+"]"+BASTAB(MASQUE(I),BLOC(I)) : Gosub ECRWJWK
    VALL1="For WW_I=0 To [M:"+ABREV(MASQUE(I))+"]"+BASTAB(MASQUE(I),BLOC(I))+"-1" : Gosub ECRWJWK
    For J=I To NBPAR
     If MASQUE(J)<>MASQUE(I) or BLOC(J)<>BLOC(I)
      Break
     Endif
     If PARAM(J)<>BASTAB(MASQUE(I),BLOC(I))
      #VALL1=format$("K:30X"," [L]"+NOM(J)+"(WW_I)")
      VALL1=" [L]"+NOM(J)+"(WW_I)"
      VALL1+=" = [M:"+ABREV(MASQUE(J))+"]"+PARAM(J)+"(WW_I)" : Gosub ECRWJWK
     Endif
    Next J
    I = J-1
    VALL1="Next WW_I" : Gosub ECRWJWK
#   When 2,4
   When Default
    If DIME(I)>1
     For J=1 To DIME(I)
      #VALL1=format$("K:30X","[L]"+NOM(I)+"("+num$(J-1)+")")
      VALL1="[L]"+NOM(I)+"("+num$(J-1)+")"
      VALL1+=" = "+"[M:"+ABREV(MASQUE(I))+"]"+PARAM(I)+"("+num$(J-1)+")" : Gosub ECRWJWK
     Next J
    Else
     #VALL1=format$("K:30X","[L]"+NOM(I))
     VALL1="[L]"+NOM(I)
     VALL1+=" = "+"[M:"+ABREV(MASQUE(I))+"]"+PARAM(I) : Gosub ECRWJWK
    Endif
  Endcase
 Endif
 I += 1
Wend
VALL1="Return" : Gosub ECRWJWK
VALL1=" " : Gosub ECRWJWK


Wrseq "#########################################################################"
Wrseq "## Liste gauche"
Wrseq "#########################################################################"
Wrseq "Subprog LISTE(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION1,WW_IDENT,WW_NB"
Wrseq "&         ,WW_HORDAT,WW_TAB,WW_PAR,WW_TRACE"
Wrseq "& ";
For I=1 To [F:A_OL]NBSEL
 Wrseq ",WW_SEL"+num$(I);
Next I
Wrseq ")"
Wrseq "Variable Integer WW_OK                            : # Statut de retour 1=OK, 0=Pas OK, 2=XML déphasé)"
Wrseq "Variable Char    WW_ZONE()                        : # Zone de sortie"
Wrseq "Variable Integer WW_STAT                          : # Nombre d'événements"
Wrseq "Variable Integer WW_GRAVE(1..)                    : # Gravité (1=info, 2=warning, 3=bloquant)"
Wrseq "Variable Char    WW_MESS()(1..)                   : # Texte événements"
Wrseq "Value    Char    WW_ACTION1                       : # Action "
Wrseq "Value    Char    WW_IDENT()                       : # Identifiant (cle1~cle2~...)"
Wrseq "Variable Integer WW_NB                            : # Nb d'éléments retournés (liste)"
Wrseq "Variable Char    WW_HORDAT()                      : # Horodatage"
Wrseq "Variable Char    WW_TAB()                         : # Identification tableau pour maj lignes"
Wrseq "Variable Char    WW_PAR()(1..)                    : # Identification lignes"
Wrseq "Variable Clbfile WW_TRACE()                       : # Trace serveur"

For I=1 To [F:A_OL]NBSEL
 CHAINE = "Variable Char    WW_SEL"+num$(I)+"()(1..)"
 Wrseq CHAINE;space$(45-len(CHAINE));": # ";[F:A_OL]SELEXP(I-1)-string$([F:A_OL]SELEXP(I-1)="",[F:A_OL]SELZON(I-1))
Next I
Wrseq
Wrseq "WW_OK=0"
Wrseq "Gosub ISDBGON from AWEB"
Wrseq "If WW_OK<>0 : End : Endif"

Wrseq "Local Char    WW_OBJET(GLONAOB)"
Wrseq "Local Char    WW_PROG(GLONADC)"
Wrseq "Local Char    WW_BOITE(GLONADC)"
Wrseq "Local Char    WW_VARIANTE(GLONADC)"
Wrseq "Local Char    WW_ACTION"
Wrseq "Local Integer WW_I"

Wrseq 'WW_OBJET    = "'+OBJET+'"'
Wrseq 'WW_PROG     = "'+NOMTRT+'"'
Wrseq 'WW_BOITE    = "'+[F:A_WI]WIN+'"'
Wrseq 'WW_VARIANTE = "'+VARIANTE+'"'
Wrseq 'WW_ACTION   = "LIST"'
Wrseq
Wrseq "Local Char HORDAT1(14)"
#Wrseq 'HORDAT1="'+num$(HORDAT)+'"'
Wrseq "Local Char HORDATG(14),VERGEN"
Wrseq 'HORDATG="'+num$(HORDAT)+'"'
Gosub VERGEN
Wrseq 'VERGEN="'+num$(VERGEN)+'"'
Wrseq 'Call RECUPHDAT("'+PUBLI+'",HORDAT1,WW_I) from AWEB'
Wrseq "Gosub ANLHORSPG From AWEB"
Wrseq 'If WW_OK<>0 : Gosub SETTRACE : End : Endif'
Wrseq
Wrseq 'Local Char ALIAS : ALIAS="'+PUBLI+'"'
#  Point d'entrée wrapper
Wrseq 'Local Char ACTION'
Wrseq 'ACTION="AV_WS"'
Wrseq 'GPE=0'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'


Wrseq 'If GPE<>1'
Wrseq " Gosub OBJET From "+PROGWEB
Wrseq 'Endif'
Wrseq
Wrseq 'ACTION="AP_WS"'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'
Wrseq
Wrseq "Gosub SETTRACE"
Wrseq "End"
Wrseq
Wrseq

Gosub GENERXTEND

Openo
#Call ECR_TRACE(mess(159,133,1)-NOMTRT,0) From GESECRAN
Call VALID("TRT",NOMTRT,APPLI,OK) From VALMSKSUB
If OK=0
  Call ECR_TRACE(mess(20,123,1)-":"-PUBLI-"    "+mess(20,123,1)-NOMTRT,1) From GESECRAN
  End
Endif
If ISTRT1CR=1
 Openo Using [K_WR]
 Call VALID("TRT",NOMTRT1,APPLI,OK) From VALMSKSUB
 If OK=0
  Call ECR_TRACE(mess(20,123,1)-":"-PUBLI-"    "+mess(20,123,1)-NOMTRT1,1) From GESECRAN
  End
 Endif
Endif
If ISTRT2CR=1
 Openo Using [K_WR]
 Call VALID("TRT",NOMTRT2,APPLI,OK) From VALMSKSUB
 If OK=0
  Call ECR_TRACE(mess(20,123,1)-":"-PUBLI-"    "+mess(20,123,1)-NOMTRT2,1) From GESECRAN
  End
 Endif
Endif

NBPRO = 0
NBPRO += 1 : SOUSPRO(NBPRO) = "OBJET"
NBPRO += 1 : SOUSPRO(NBPRO) = "LISTE"

Gosub GENXMLOBJ

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

$ERRDIM
Call ECR_TRACE(OBJET-VARIANTE-":"-mess(216,133,1)-"("+num$(MAXOBJ)+")",1) From GESECRAN
# Trop d'écrans et de tableaux
End

$ERRNBVAR
Call ECR_TRACE(OBJET-VARIANTE-":"-mess(222,133,1)-num$(NBFLD)-"   /(65000)",1) From GESECRAN
# Trop de champs publiés
End



$ECRIVAR
Gosub ECRIVAR1
#Wrseq format$("K:30X",VARIA1);" = ";format$("K:30X",VARIA2);
Wrseq VARIA1;" = ";VARIA2;
Wrseq " : Endif";
Wrseq
Return

$ECRIVAR1
Case TYPVAR
 When 2
  #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>""');" : ";
  Wrseq space$(SPA);"If ";VARIA2+'<>""';" : ";
 When 3
  #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>[0/0/0]');" : ";
  Wrseq space$(SPA);"If ";VARIA2+'<>[0/0/0]';" : ";
 When 4
  #Wrseq space$(SPA);"If ";format$("K:30X","len("+VARIA2+")<>0");" : ";
  Wrseq space$(SPA);"If ";"len("+VARIA2+")<>0";" : ";
 When 5
  Wrseq space$(SPA);"Setlob WW_TEXTE With"-VARIA2
  #Wrseq space$(SPA);"If ";format$("K:30X",'WW_TEXTE<>""');" : ";
  Wrseq space$(SPA);"If ";'WW_TEXTE<>""';" : ";
 When Default
  #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>0');" : ";
  Wrseq space$(SPA);"If ";VARIA2+'<>0';" : ";
Endcase
Return

$ECRWJWK
  If ISTRT1CR=1
     Wrseq VALL1 Using [K_WR]
  Else
     Wrseq VALL1
  Endif
Return

$ECRIVARWK
If ISTRT1CR<>1
  Gosub ECRIVAR1
#  Wrseq format$("K:30X",VARIA1);" = ";format$("K:30X",VARIA2);
  Wrseq VARIA1;" = ";VARIA2;
  Wrseq " : [L]A_W"+mid$(ABRLST,MASQUE(I),1)+"_"+num$(BLOC(I))+"+=1";
  Wrseq " : Endif";
  Wrseq
Else
  Case TYPVAR
   When 2
    #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>""');" : "; Using [K_WR]
    Wrseq space$(SPA);"If ";VARIA2+'<>""';" : "; Using [K_WR]
   When 3
    #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>[0/0/0]');" : "; Using [K_WR]
    Wrseq space$(SPA);"If ";VARIA2+'<>[0/0/0]';" : "; Using [K_WR]
   When 4
    #Wrseq space$(SPA);"If ";format$("K:30X","len("+VARIA2+")<>0");" : "; Using [K_WR]
    Wrseq space$(SPA);"If ";"len("+VARIA2+")<>0";" : "; Using [K_WR]
   When 5
    Wrseq space$(SPA);"Setlob WW_TEXTE With"-VARIA2 Using [K_WR]
    #Wrseq space$(SPA);"If ";format$("K:30X",'WW_TEXTE<>""');" : "; Using [K_WR]
    Wrseq space$(SPA);"If ";'WW_TEXTE<>""';" : "; Using [K_WR]
   When Default
    #Wrseq space$(SPA);"If ";format$("K:30X",VARIA2+'<>0');" : "; Using [K_WR]
    Wrseq space$(SPA);"If ";VARIA2+'<>0';" : "; Using [K_WR]
  Endcase
  #Wrseq format$("K:30X",VARIA1);" = ";format$("K:30X",VARIA2); Using [K_WR]
  Wrseq VARIA1;" = ";VARIA2; Using [K_WR]
  Wrseq " : [L]A_W"+mid$(ABRLST,MASQUE(I),1)+"_"+num$(BLOC(I))+"+=1"; Using [K_WR]
  Wrseq " : Endif"; Using [K_WR]
  Wrseq " "  Using [K_WR]
Endif
Return



$SAIZONE
If sum(DETBLC(K,1..NBLOC(K)))=0  # CCL for managment of saizo by bloc
 #Wrseq "Saizo"-ABR1-"With"-ABR2
 For J=1 To NBLOC(K)
  Wrseq "#"-ABR1+num$(RANG(K,J))
  Wrseq "If [L]"+[L]WABRMSK+"_"+num$(J)+">0"
  Wrseq " Saizo"-ABR1+num$(RANG(K,J))-"With "-ABR2
  Wrseq " If mkstat and status=7"
  Wrseq '  WW_ZONE = "'+ABR1+'"+zonsor'
  Wrseq '  If indice>=1 : WW_ZONE+="("+num$(indice+1)+")" : Endif'
  Wrseq '  Call ERREUR(mess(32,126,1)-WW_ZONE) From GESECRAN'
  Wrseq " Endif"
  Wrseq "Endif"
 Next
Else
 DERCHP = ""
 Local Integer ISLISTDETW
 For J=1 To NBLOC(K)
  If DETBLC(K,J)=0 & !find(J,DETBLC(K,1..NBLOC(K)))
   #Wrseq "Saizo"-ABR1+num$(RANG(K,J))-"With"-ABR2
   Wrseq "If [L]"+[L]WABRMSK+"_"+num$(J)+">0 : Saizo"-ABR1+num$(RANG(K,J))-"With "-ABR2 + " : Endif"
  Elsif DETBLC(K,J)<>0 and ISLISTDETW=0
   ISLISTDETW=1
   Q = 0
   For P=DEBPAR(K) To FINPAR(K)
    If BLOC(P)=J
     Q = P
    Endif
   Next P
   If Q & SAIAFF(Q)>=3 & TYP(Q)=1 & DERCHP=""
    DERCHP = PARAM(Q)
   Endif
   Wrseq ' '
   Wrseq 'If WW_ACTION="MODIFY" and '+ABR2+BASTAB(K,DETBLC(K,J))+'=0'
   Wrseq '  '+ABR2+BASTAB(K,DETBLC(K,J))+' = max('+ABR2+BASTAB(K,DETBLC(K,J))+','+ABR1+BASTAB(K,DETBLC(K,J))+')'
   Wrseq 'Endif'
   Wrseq "For WW_I=0 To ";ABR2;BASTAB(K,DETBLC(K,J));"-1"
   Wrseq " nolign = WW_I+1"
   Wrseq " If dim(WSNOLIGN)>0 : WSNOLIGN = nolign : Endif" : # 113253 CCL add new variable to manage nolign in saizo
   Wrseq " indice = nolign-1"

   If DERCHP<>""
    #Wrseq format$("K:30X"," "+ABR1+DERCHP)+" = indice"
    #Wrseq format$("K:30X"," "+ABR2+DERCHP)+" = indice"
    Wrseq " "+ABR1+DERCHP+" = indice"
    Wrseq " "+ABR2+DERCHP+" = indice"
   Endif
   Gosub RAZ_VARIA_BLOC
   For P=DEBPAR(K) To FINPAR(K)
#    If BLOC(P)=J                                                       #   CC   13/05/2013
     Q = find(right$(PARAM(P),2),PARAM(DEBPAR(K)..FINPAR(K)))
     If Q & BLOC(DEBPAR(K)+Q-1)=DETBLC(K,J)
      Wrseq " Raz "+ABR2+PARAM(P)+","+ABR1+PARAM(P)
      Z1=find(right$(PARAM(P),2),PARAM(DEBPAR(K)..FINPAR(K)))
      If Z1=0
 #     Ecran liste/détail non conforme
        ABR1=mid$(ABR1,4,len(ABR1)-4)
        Call ECR_TRACE(ABR1-mess(227,151,1)-"  :"-mess(36,124,1)-PARAM(P),1) From GESECRAN
        End
      Endif
      Z1+=DEBPAR(K)-1
      VARIA2="[L]"+NOM(Z1)+"(WW_I)"
      TYPVAR=TYP(Z1)
      SPA=1
      Gosub ECRIVAR1
      #Wrseq format$("K:30X","  "+ABR2+PARAM(P))+" = "+ABR2+right$(PARAM(P),2)+"(WW_I)"
      Wrseq "  "+ABR2+PARAM(P)+" = "+ABR2+right$(PARAM(P),2)+"(WW_I)"
      Wrseq "  "+"[L]"+[L]WABRMSK+"_"+num$(BLOC(P))+ "+=1"
#  On met à jour de manière particulière le "code adresse" qui est supposé être le seul champ saisissable du tableau
      If SAIAFF(P)>12 or (SAIAFF(P)=12 and SAIAFF(Z1)=11)
       #Wrseq format$("K:30X","  "+ABR1+PARAM(P))+" = "+ABR2+right$(PARAM(P),2)+"(WW_I)"
       Wrseq "  "+ABR1+PARAM(P)+" = "+ABR2+right$(PARAM(P),2)+"(WW_I)"
       Gosub SET_1_VARIA_BLOC
      Endif
      Wrseq ' Elsif WW_ACTION="MODIFY"'
      #Wrseq format$("K:30X","  "+ABR2+PARAM(P))+" = "+ABR1+right$(PARAM(P),2)+"(WW_I)"
      Wrseq "  "+ABR2+PARAM(P)+" = "+ABR1+right$(PARAM(P),2)+"(WW_I)"
      If SAIAFF(P)>=11
       #Wrseq format$("K:30X","  "+ABR1+PARAM(P))+" = "+ABR1+right$(PARAM(P),2)+"(WW_I)"
       Wrseq "  "+ABR1+PARAM(P)+" = "+ABR1+right$(PARAM(P),2)+"(WW_I)"
      Endif
      Wrseq " Endif"
     Endif
   # Endif                                                           #   CC   13/05/2013
   Next P
#              insérer les CALL AS_NBLIG pour traiter les modifications de blocs liste/détail    Bug 88125   CC - 06/05/2013
   Gosub ADDSAIZONE
#
   Local Integer JJK
   For JJK=1 To NBLOC(K)
     If DETBLC(K,JJK)<>0
       Wrseq "If [L]"+[L]WABRMSK+"_"+num$(JJK)+">0 : Saizo"-ABR1+num$(RANG(K,JJK))-"With "-ABR2 + " : Endif"
       #Wrseq " Saizo"-ABR1+num$(RANG(K,JJK))-"With"-ABR2
       Wrseq " If mkstat and status=7"
       Wrseq '  WW_ZONE = "'+ABR1+'"+zonsor'
#   Wrseq '  If nolign>1 : WW_ZONE+="("+num$(nolign)+")" : Endif'
       Wrseq '  If indice>=1 : WW_ZONE+="("+num$(indice+1)+")" : Endif'
       Wrseq '  Call ERREUR(mess(32,126,1)-WW_ZONE) From GESECRAN'
       Wrseq "  Break "
       Wrseq " Endif"
     Endif
   Next JJK

   For P=DEBPAR(K) To FINPAR(K)
#    If BLOC(P)=J                                                   #  CC    13/05/2013
     Q = find(right$(PARAM(P),2),PARAM(DEBPAR(K)..FINPAR(K)))
     If Q & BLOC(DEBPAR(K)+Q-1)=DETBLC(K,J)
      #Wrseq format$("K:30X"," "+ABR1+right$(PARAM(P),2)+"(WW_I)")+" = "+ABR1+PARAM(P)
      Wrseq " "+ABR1+right$(PARAM(P),2)+"(WW_I)"+" = "+ABR1+PARAM(P)
     Endif
#    Endif
   Next P
   Wrseq " "+ABR1+BASTAB(K,DETBLC(K,J))-"+= 1" :  # CCL 120153 to increment nblig for each lines
   Wrseq "Next WW_I"
   Wrseq "If dim(WSNOLIGN)>0 : WSNOLIGN = 0 : Endif" : # 113253 CCL add new variable to manage nolign in saizo
   Wrseq "If mkstat : Return : Endif"
   Wrseq ABR1+BASTAB(K,DETBLC(K,J))-"="-ABR2+BASTAB(K,DETBLC(K,J))
  Endif
 Next J
Endif
#Wrseq "If mkstat and status=7"
#Wrseq ' WW_ZONE = "'+ABR1+'"+zonsor'
##Wrseq ' If nolign>1 : WW_ZONE+="("+num$(nolign)+")" : Endif'
#Wrseq ' If indice>=1 : WW_ZONE+="("+num$(indice+1)+")" : Endif'
#Wrseq ' Call ERREUR(mess(32,126,1)-WW_ZONE) From GESECRAN'
#Wrseq " Return"
#Wrseq "Endif"
Return

$ADDSAIZONE
Read [A_MK]CODMSK = MASKSAI
Local Char ATRTSTD,ATRTSPV,ATRTSPE
ATRTSTD=[F:A_MK]TRTSTD
ATRTSPV=[F:A_MK]TRTSPV
ATRTSPE=[F:A_MK]TRTSPE
Filter [A_MA] Where CODAFF=MASKSAI and CODZON=BASTAB(K,DETBLC(K,J)) and TYPACT=4
Local Integer NBACT5
For [A_MA]
  If ([F:A_MA]ACTION="STD" or [F:A_MA]ACTION="SPV" or [F:A_MA]ACTION="SPE") and [F:A_MA]EXEACT<>1
    Case [F:A_MA]ACTION
      When "STD"
         If [F:A_MA]DISACT<>2 and [F:A_MA]DISACT<>4
           # Wrseq 'If WW_ACTION="MODIFY"' CCL 120153 to increment nblig for each lines
           Wrseq "  Default Mask "+ABR1
           Wrseq "  Call AS_"+ BASTAB(K,DETBLC(K,J)) +" From "+ATRTSTD
           # Wrseq "Endif" CCL 120153 to increment nblig for each lines
         Endif
      When "SPV"
         If [F:A_MA]DISACT<>3 and [F:A_MA]DISACT<>4
           Wrseq "Default Mask "+ABR1
           Wrseq "Call AS_"+ BASTAB(K,DETBLC(K,J)) +" From "+ATRTSPV
         Endif
      When "SPE"
         If [F:A_MA]DISACT<>4
           Wrseq "Default Mask "+ABR1
           Wrseq "Call AS_"+ BASTAB(K,DETBLC(K,J)) +" From "+ATRTSPE
         Endif
    Endcase
  Endif
Next
Filter [A_MA]
Return


$ECRAN
If NBECR>=MAXECR
 OK = 0 : Return
Endif
Read [A_MK]CODMSK = ECRAN
ABREV(NBECR) = [F:A_MK]ABRMSK
NBLOC(NBECR) = [F:A_MK]NBBLOC
Local Integer ISDETBLC
For J=1 To [F:A_MK]NBBLOC
 If [F:A_MK]ACTBLOC(J-1)<>""
  Read [F:A_CV]CODACT = [F:A_MK]ACTBLOC(J-1)
  If fstat or [F:A_CV]FLACT<>2
   NBLOC(NBECR) -= 1
   Goto SUIBLOC
  Endif
 Endif
 TYPBLC(NBECR,J) = [F:A_MK]TYPBLOC(J-1)
 DETBLC(NBECR,J) = [F:A_MK]DETBLC(J-1)
 If DETBLC(NBECR,J)<>0 : ISDETBLC=1 : Endif
 RANG(NBECR,J)   = [F:A_MK]RANG(J-1)
 INTITBLC(NBECR,J)   = [F:A_MK]TITBLOC(J-1)
 If [F:A_MK]TYPBLOC(J-1)=1
  BASTAB(NBECR,J) = [F:A_MK]BASPAG(J-1)
  Read [A_MZ]CODE=ECRAN;BASTAB(NBECR,J)
  If fstat=0 and [F:A_MZ]SAIAFF>=3
    INVTAB(NBECR,J)=1
  Endif
  OPTTAB(NBECR,J) = [F:A_MK]OPTION(J-1)
  DIMTAB(NBECR,J) = [F:A_MK]NBLIGT(J-1)
  If [F:A_MK]ACTBLOC(J-1)<>""
   Read [A_CV]CODACT = [F:A_MK]ACTBLOC(J-1)
   If [F:A_CV]TYP=2
    DIMTAB(NBECR,J) = [F:A_CV]DIME
   Endif
  Endif
 Endif
$SUIBLOC
Next J
If INVISIBLE or ISDETBLC=1
 # On prend les zones invisibles, mais pas "techniques"
 MAXSAI = 4
Else
 MAXSAI = 3
Endif
DEBPAR(NBECR) = NBPAR+1

For K=1 To 2
 For [A_MZ]CODZON(2) Where CODMSK=ECRAN & SAIAFF<MAXSAI
  # 120626
  # 120626 - insert -1 on NUMBLOC
  If [F:A_MK]ACTBLOC([F:A_MZ]NUMBLOC-1)<>""
   Read [F:A_CV]CODACT = [F:A_MK]ACTBLOC([F:A_MZ]NUMBLOC-1)
   If fstat or [F:A_CV]FLACT<>2
    Goto SUIBLOC1
   Endif
  Endif
  BLCTYP = TYPBLC(NBECR,[F:A_MZ]NUMBLOC)
  If K=2 & BLCTYP=1 & INVTAB(NBECR,[F:A_MZ]NUMBLOC) & MAXSAI<=3 : Goto SUIBLOC1 : Endif    :# On ne prend pas les tableaux invisibles
  If (K=1 & BLCTYP>1) or (K=2 & BLCTYP=1)
   If BLCTYP=1
    If NBECR+NBTAB>=MAXOBJ
     OK = 0 : Break 2
    Endif
    PTAB   = mid$(ALPHABET,JTAB,1)
    NBTAB += 1
    JTAB  -= 1
   Endif
   For [A_MZ]CODZON
    If [F:A_MZ]CODTYP="W" : Goto SUITCH : Endif
    If NBPAR>=MAXPAR
     OK = 0 : Break 3
    Endif
    If [F:A_MZ]CODACT<>""
     Read [A_CV]CODACT = [F:A_MZ]CODACT
     If [F:A_CV]FLACT<>2    :   #  Champ non actif
       Goto SUITCH
     Endif
    Endif
    NBPAR += 1
    MASQUE(NBPAR) = NBECR
    PARAM(NBPAR)  = [F:A_MZ]CODZON
    BLOC(NBPAR)   = [F:A_MZ]NUMBLOC
    NOLIB(NBPAR)  = [F:A_MZ]NOLIB
    If NOLIB(NBPAR)<>0 and !find(NOLIB(NBPAR),LISTLIB(1..NBLIB))
      NBLIB+=1
      LISTLIB(NBLIB)=NOLIB(NBPAR)
    Endif
    OBLIG(NBPAR)  = [F:A_MZ]OBLIG
    SAIAFF(NBPAR) = [F:A_MZ]SAIAFF
    OPTSAI(NBPAR) = [F:A_MZ]OPTSAI
    OPTFOR(NBPAR) = [F:A_MZ]OPTFOR
  If ISDETBLC=1 : SAIAFF(NBPAR)+=10 : Endif               : # Pour écran Liste/détail
    INTIT(NBPAR)  = [F:A_MZ]INTIT
    If BLCTYP=1
     DIME(NBPAR)   = [F:A_MK]NBLIGT(BLOC(NBPAR)-1)
     If [F:A_MK]ACTBLOC(BLOC(NBPAR)-1)<>""
      Read [A_CV]CODACT = [F:A_MK]ACTBLOC(BLOC(NBPAR)-1)
      If [F:A_CV]TYP=2
       DIME(NBPAR) = [F:A_CV]DIME
      Endif
     Endif
    Else
     DIME(NBPAR)   = [F:A_MZ]DIME
    Endif
    If [F:A_MZ]CODACT<>""
     Read [A_CV]CODACT = [F:A_MZ]CODACT
     If [F:A_CV]TYP=2
      DIME(NBPAR) = [F:A_CV]DIME
     Endif
    Endif
    If BLCTYP=1 & PARAM(NBPAR)=[F:A_MK]BASPAG(BLOC(NBPAR)-1)
     DIME(NBPAR) = 1
    Endif
    If BLCTYP=1
     NOM(NBPAR)    = PARAM(NBPAR)+"_"+PTAB
    Else
     NOM(NBPAR)    = PARAM(NBPAR)+"_"+PMASK : # faut pas dépasser 12!!
    Endif
    If [F:A_MZ]INTIT>0
     Read [A_TX]NUMERO = GLANGUE;[F:A_MZ]INTIT
     COM(NBPAR) = [F:A_TX]TEXTE
    Endif
    CTYP(NBPAR)=[F:A_MZ]CODTYP
    If BLCTYP=1 & [F:A_MZ]CODZON=[F:A_MK]BASPAG([F:A_MZ]NUMBLOC-1)
     TYP(NBPAR) = 1
     LNG(NBPAR)="4"
    Else
     Read [A_TY]CODTYP = [F:A_MZ]CODTYP
     Case [F:A_TY]TYPTYP
      When 1,2,3   : TYP(NBPAR) = 1
      When 7       : TYP(NBPAR) = 2
      When 8       : TYP(NBPAR) = 3
      When 9       : TYP(NBPAR) = 4
      When 10      : TYP(NBPAR) = 5
      When Default : TYP(NBPAR) = 6
     Endcase
     If [F:A_TY]TYPTYP=7 or [F:A_TY]TYPTYP=9 or [F:A_TY]TYPTYP=10
      If [F:A_TY]LNGTYP<>0
       LNG(NBPAR) = "GLON"+[F:A_TY]CODTYP
      Else
       LNG(NBPAR) = num$([F:A_MZ]LONG)
      Endif
     Endif
#  Pour XTEND il faut donner LNG dans tous les cas
     If LNG(NBPAR)=""
       If [F:A_MZ]LONG<>0
         LNG(NBPAR)=num$([F:A_MZ]LONG)
       Elsif TYP(NBPAR)=1  :# Entier
         LNG(NBPAR)="4"
       Elsif TYP(NBPAR)=8  :# Date
         LNG(NBPAR)="10"
       Elsif [F:A_TY]LNGTYP<>0
         LNG(NBPAR)=num$([F:A_TY]LNGTYP) : Endif
       Endif
     Endif
     If LNG(NBPAR)="" : LNG(NBPAR)="30" : Endif     :  #  Longueur non trouvée, on prend 30

# Si pas d'option sur le champ on prend ce qui est défini sur le type de données
     If OPTSAI(NBPAR)="" : OPTSAI(NBPAR)=[F:A_TY]OPTION : Endif
     If OPTFOR(NBPAR)="" : OPTFOR(NBPAR)=[F:A_TY]FORTYP : Endif


#  On traite l'éventuelle zone lien
     If [F:A_MZ]LIEN<=1 : Goto SUITCH : Endif
     If NBPAR>=MAXPAR
      OK = 0 : Break 3
     Endif
     NBPAR += 1
     MASQUE(NBPAR) = NBECR
     PARAM(NBPAR)  = "Z"+[F:A_MZ]CODZON
     BLOC(NBPAR)   = [F:A_MZ]NUMBLOC
     NOLIB(NBPAR)  = 0
     OBLIG(NBPAR)  = 1
     SAIAFF(NBPAR) = 2
     If ISDETBLC=1 : SAIAFF(NBPAR)+=10 : Endif               : # Pour écran Liste/détail
     INTIT(NBPAR)  = 0
     DIME(NBPAR)   = DIME(NBPAR-1)
     If BLCTYP=1
      NOM(NBPAR)    = PARAM(NBPAR)+"_"+PTAB
     Else
      NOM(NBPAR)    = PARAM(NBPAR)+"_"+PMASK : # faut pas dépasser 12!!
     Endif
     COM(NBPAR) = ""
     CTYP(NBPAR)="A"
     TYP(NBPAR) = 2
     If [F:A_MZ]LIEN=3
      LNG(NBPAR)=num$(GLONSHO)
     Else
      LNG(NBPAR)=num$(GLONDES)
     Endif
#
 $SUITCH
   Next
  Endif
$SUIBLOC1
 Next
Next K
If !OK : Return : Endif
FINPAR(NBECR) = NBPAR
Return




$GENXMLOBJ
# Ouverture du fichier résultat
Local Char DIRSEP, NOMFIC(200),VALL1(200),NAMFILE
Local Char PROP(100),VALP(100),VALLM(100)
Local Integer RES
Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
Call NAMEFIC(APPLI,"WEBS","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,0)<0
  Call SYSTEME(adxmac(0),'ae_mkdir "'+NOMFIC+'"',"",RES) From ORDSYS
Endif

NAMFILE=PUBLI
Call NAMEFIC(APPLI,"WEBS","",NAMFILE,NOMFIC) From INTRUTILA
Call GLOBWEB(APPLI) From INTRUTILA
# GI_LLAN   : langues à utiliser pour la génération
# GI_NBLAN  : nombre de langues du dossier


Openo NOMFIC,0 Using [XML_]
Iomode adxifs ""  Using [XML_]
Iomode adxirs chr$(10)  Using [XML_]
Iomode adxium GUTF8  Using [XML_]
#  Ecriture du fichier XML

Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [XML_]
VALL1='<ADXDOC'
PROP="PNA" : VALP=PUBLI : Gosub ADDPROP
PROP="NAM" : VALP=[F:A_WI]WIN : Gosub ADDPROP
PROP="TIM" : VALP=HORDAT : Gosub ADDPROP
PROP="OBJ" : VALP=OBJET : Gosub ADDPROP
If VARIANTE<>"" : PROP="TRA" : VALP=VARIANTE : Gosub ADDPROP : Endif
If INVISIBLE=1 : PROP="INV" : VALP="1" : Gosub ADDPROP : Endif
PROP="FOL" : VALP=APPLI : Gosub ADDPROP
PROP="SOL" : VALP=GINSTID : Gosub ADDPROP
#PROP="WRP" : VALP="WJ"+OBJET+VARIANTE
#If INVISIBLE=1 : VALP+="_I" : Endif
PROP="WRP" : VALP="WJ"+PUBLI
Gosub ADDPROP
PROP="USER" : VALP=GUSER : Gosub ADDPROP
PROP="VER" : Gosub VERGEN : VALP=VERGEN : Gosub ADDPROP
PROP="HEAD" : VALP="1" : Gosub ADDPROP
VALL1+='>'
Wrseq VALL1 Using [XML_]
VALL1=" <ADXDATA>"
Wrseq VALL1 Using [XML_]

Local Integer MSKCOU,BLCOU,IINTIT
Local Char NAMBLCOU(50)

For I=1 To NBPAR
  Read [A_WY]AWY1=[L]PUBLI;ABREV(MASQUE(I))+"_"+num$(BLOC(I));PARAM(I)
  If fstat<>0
#   "Mapping incorrect entre l'objet et sa publication
    Call ECR_TRACE([L]PUBLI-":"-mess(284,123,1)-ABREV(MASQUE(I))+"_"+num$(BLOC(I))-PARAM(I),1) From GESECRAN : # Objet inexistant
    End
  Endif
  If DETBLC(MASQUE(I),BLOC(I))<>0: Goto SUITCHP : Endif
  If [F:A_WY]GROUPE<>NAMBLCOU
    If NAMBLCOU<>"" : #  On termine un bloc avant d'en commencer un autre
      VALL1="</GRP>" :
      Wrseq VALL1 Using [XML_]
    Endif
    NAMBLCOU=[F:A_WY]GROUPE
    MSKCOU=MASQUE(I)
    BLCOU=BLOC(I)
    Gosub ECRBLOC
  Endif
  If TYPBLC(MSKCOU,BLCOU)=1 & PARAM(I)=BASTAB(MSKCOU,BLCOU)
    Goto SUITCHP
  Endif
  VALL1='<FLD'
  PROP="NAM" : VALP=[F:A_WY]CHAMP : Gosub ADDPROP
  PROP="X3BLORIG" : VALP=[F:A_WY]GRP : Gosub ADDPROP
  PROP="X3FLORIG" : VALP=[F:A_WY]CHP : Gosub ADDPROP
#
#   Nouvelles propriétés     CC - 12/07/2010

  If [F:A_WY]SELECT<>2
    VALP="true"
    PROP="UNSEL" : Gosub ADDPROP
  Endif
  PROP="IDX" : VALP=num$([F:A_WY]IDX) : Gosub ADDPROP

#
  PROP="TYP"
  Case TYP(I)
    When 1 : VALP="Integer"
    When 2 : VALP="Char"
    When 3 : VALP="Date"
    When 4 : VALP="Blob"
    When 5 : VALP="Clob"
    When 6 : VALP="Decimal"
    When Default : VALP="Char"
  Endcase
  Gosub ADDPROP
  If NOLIB(I)<>0
    PROP="MEN" : VALP=num$(NOLIB(I)) : Gosub ADDPROP
  Endif
  If OBLIG(I)=2
  #  PROP="MAN" : VALP="1" : Gosub ADDPROP
  Endif
  PROP="MOD"
  Case SAIAFF(I)
    When 1 : VALP="Input"
    When 2 : VALP="Display"
    When 3 : VALP="Hidden"
    When 11,12,13,14 : VALP="Input"      : # Astuce pour bloc Liste / Détail
    When Default : VALP="Input"
  Endcase
  Gosub ADDPROP
  PROP="LEN"
  If left$(LNG(I),4)="GLON"
    VALP=num$(evalue(LNG(I)))
  Else
    VALP=LNG(I)
  Endif
  If VALP<>"" : Gosub ADDPROP : Endif
  If TYPBLC(MSKCOU,BLCOU)<>1 and DIME(I)>1
    PROP="DIM" : VALP=num$(DIME(I)) : Gosub ADDPROP
  Endif

  IINTIT=INTIT(I) : Gosub EVALINTIT
  VALL1+="/>"
  Wrseq VALL1 Using [XML_]
$SUITCHP
Next I

If NAMBLCOU<>"" : #  On termine un bloc avant d'en commencer un autre
  VALL1="</GRP>" :
  Wrseq VALL1 Using [XML_]
Endif

# Ecriture du noeud technique
VALL1="<GRP"
PROP="NAM" : VALP="ADXTEC" : Gosub ADDPROP
PROP="TYB" : VALP="List" : Gosub ADDPROP
PROP="DIM" : VALP="1" : Gosub ADDPROP
VALL1+=">"
Wrseq VALL1 Using [XML_]

VALL1='<FLD'
PROP="NAM" : VALP="WW_MODSTAMP" : Gosub ADDPROP
PROP="TYP" : VALP="Char" : Gosub ADDPROP
PROP="MOD" : VALP="Input" : Gosub ADDPROP
PROP="LEN" : VALP="20" : Gosub ADDPROP
PROP="IDX" : VALP=num$(NBPAR+1) : Gosub ADDPROP
VALL1+='/>'
Wrseq VALL1 Using [XML_]
VALL1='<FLD'
PROP="NAM" : VALP="WW_MODUSER" : Gosub ADDPROP
PROP="TYP" : VALP="Char" : Gosub ADDPROP
PROP="MOD" : VALP="Display" : Gosub ADDPROP
PROP="LEN" : VALP="20" : Gosub ADDPROP
PROP="IDX" : VALP=num$(NBPAR+2) : Gosub ADDPROP
VALL1+='/>'
Wrseq VALL1 Using [XML_]

VALL1="</GRP>"
Wrseq VALL1 Using [XML_]


VALL1=" </ADXDATA>"
Wrseq VALL1 Using [XML_]

VALL1=" <ADXKEY>"
Wrseq VALL1 Using [XML_]
VALL1="<GRP"
PROP="NAM" : VALP="LEFTLIST" : Gosub ADDPROP
PROP="DIM" : VALP="10000" : Gosub ADDPROP
VALL1+=">"
Wrseq VALL1 Using [XML_]
Local Integer IILEFTLONG
Read [A_OL]AOL0=OBJET
If fstat=0
  For I=1 To [F:A_OL]NBSEL
    IILEFTLONG=0
    VALL1="<FLD"
    PROP="NAM" : VALP=[F:A_OL]SELZON(I-1)
    If VALP="" : VALP="C"+num$(I) : Endif
    Gosub ADDPROP
    PROP="MOD" : VALP="Display" : Gosub ADDPROP
#    PROP="LEN" : VALP="10" : Gosub ADDPROP
    IINTIT=0
    If  [F:A_OL]SELFIC(I-1)<>"" and [F:A_OL]SELZON(I-1)<>""
      Read [A_TZ]CODZONE=[F:A_OL]SELFIC(I-1);[F:A_OL]SELZON(I-1)
      If fstat=0
        IINTIT=[F:A_TZ]NOLONG
        If [F:A_TZ]NOLIB<>0
          PROP="MEN" : VALP=num$([F:A_TZ]NOLIB) : Gosub ADDPROP
          If !find([F:A_TZ]NOLIB,LISTLIB(1..NBLIB))
            NBLIB+=1
            LISTLIB(NBLIB)=[F:A_TZ]NOLIB
          Endif
        Endif
# On cherche une longueur soit sur la colonne soit sur le type de données
        If [F:A_TZ]LONG<>0
          IILEFTLONG=[F:A_TZ]LONG
        Elsif [F:A_TZ]CODTYP<>"ATX" and [F:A_TZ]CODTYP<>"ATT"
          Read [A_TY]CODTYP=[F:A_TZ]CODTYP
          If fstat=0
            IILEFTLONG=[F:A_TY]LNGTYP
          Endif
        Endif
      Endif
    Endif
 #   On force TYP en caractère
    PROP="TYP" : VALP="Char" : Gosub ADDPROP
    PROP="LEN"
    If IILEFTLONG<>0
      VALP=num$(IILEFTLONG)
    Else
      If [F:A_OL]SELLNG(I-1)<>0
        VALP=num$([F:A_OL]SELLNG(I-1))
      Else
        VALP="30"
      Endif
    Endif
   #113938 - RBU
    If VALP<>""
      VALP=num$(int(val(VALP)))
    Endif
    #113938 - RBU
    Gosub ADDPROP
    If[F:A_OL]SELINT(I-1)<>0 : IINTIT=[F:A_OL]SELINT(I-1) : Endif
    Gosub EVALINTIT
    VALL1+="/>"
    Wrseq VALL1 Using [XML_]
  Next I
Endif
VALL1="</GRP>"
Wrseq VALL1 Using [XML_]

VALL1=" </ADXKEY>"

Wrseq VALL1 Using [XML_]
VALL1=" <ADXMEN>"
Wrseq VALL1 Using [XML_]
Sorta NBLIB LISTLIB(1..NBLIB)
For I=1 To NBLIB
    VALL1="<MNU"
    PROP="NO" : VALP=num$(LISTLIB(I)) : Gosub ADDPROP
    VALL1+=">"
    Wrseq VALL1 Using [XML_]
    For K=1 To len(mess(0,LISTLIB(I),1))
      VALL1="<VAL"
      PROP="IND" : VALP=num$(K) : Gosub ADDPROP
      For J=1 To GI_NBLAN
        Read [A_ST]CLE=LISTLIB(I);K;GI_LLAN(J)
        If fstat=0 Then
          VALLM=[F:A_ST]LANMES
          Gosub MVALC From INTRUTILA
          PROP="C_"+GI_LLAN(J) : VALP=VALLM : Gosub ADDPROP
        Endif
      Next J
      VALL1+="/>"
      Wrseq VALL1 Using [XML_]
    Next K
    VALL1="</MNU>"
    Wrseq VALL1 Using [XML_]
Next I
VALL1=" </ADXMEN>"
Wrseq VALL1 Using [XML_]

VALL1=" <ADXSER>"
Wrseq VALL1 Using [XML_]

# Boutons "standards"
Local Integer NOMEN,NOMES
ACTSUPLIG=0 : ACTINSLIG=0   : # Non traité en 143
For I=1 To 6
  VALL1="<MET"
  Case I
    When 1 : NOMEN=150  : NOMES=75  : VALP="READ"     : # Lire
    When 2 : NOMEN=123  : NOMES=3   : VALP="CREATE"   : # Créer
    When 3 : NOMEN=151  : NOMES=215 : VALP="MODIFY"   : # Modifier
    When 4 : NOMEN=123  : NOMES=4   : VALP="DELETE"   : # Supprimer
    When 5 : NOMEN=124  : NOMES=137 : VALP="LIST"     : # Liste
    When 6 : NOMEN=9009 : NOMES=92  : VALP="SUPLIG"   : # Suppression ligne
 #   When 7 : NOMEN=9009 : NOMES=91  : VALP="INSLIG"   : # Insertion ligne  (pas dispo)
  Endcase
  If I=6 and ACTSUPLIG=0 : Goto SUITMET : Endif
  If I=7 and ACTINSLIG=0 : Goto SUITMET : Endif
  PROP="ID"  : Gosub ADDPROP
  Gosub EVALINTITM
  VALL1+="/>"
  Wrseq VALL1 Using [XML_]
$SUITMET:
Next I

# Boutons "fenêtre"
For I=1 To NBBOUT
  VALL1="<MET"
  PROP="ID"  : VALP=right$(CBOUT(I),len(CBOUT(I)))    : Gosub ADDPROP
  If NTEXB(I)<>0
    IINTIT=NTEXB(I)
    Gosub EVALINTIT
  Endif
  VALL1+="/>"
  Wrseq VALL1 Using [XML_]
Next I
VALL1=" </ADXSER>"
Wrseq VALL1 Using [XML_]

# Description de la clé

VALL1="<ADXREAD"
PROP="TAB" : VALP=[F:A_OB]NOMFIC : Gosub ADDPROP
VALL1+='><GRP DIM="1" NAM="KEYS">'
Wrseq VALL1 Using [XML_]
Filter [A_TI] Where CODFIC=[F:A_OB]NOMFIC and NUMLIG=1
For [A_TI]
  Local Char DESC1(100)
  DESC1=[F:A_TI]DESCRIPT
$CRECL
  J=instr(1,DESC1,"+")
  If J>0
    VALP=left$(DESC1,J-1)
    Gosub CREFLDR
    DESC1=right$(DESC1,J+1)
    Goto CRECL
  Else
    VALP=DESC1
    Gosub CREFLDR
  Endif
  Break 1
Next
Filter [A_TI]
VALL1=" </GRP></ADXREAD>"
Wrseq VALL1 Using [XML_]


VALL1="</ADXDOC>"
Wrseq VALL1 Using [XML_]

Openo Using [XML_]

Local Integer ATYPOBJ : ATYPOBJ=1
#If dim([M]TYPOBJ)>0
  Gosub GENXSD From AGENXSD
#Endif
Return



$CREFLDR
  IINTIT=0
  Read [A_TZ]CODZONE=[F:A_OB]NOMFIC;VALP
  If fstat=0
    VALL1="<FLD"
    PROP="NAM"  : Gosub ADDPROP
    IINTIT=[F:A_TZ]NOLONG
    If [F:A_TZ]NOLIB<>0
      PROP="MEN" : VALP=num$([F:A_TZ]NOLIB) : Gosub ADDPROP
      If !find([F:A_TZ]NOLIB,LISTLIB(1..NBLIB))
        NBLIB+=1
        LISTLIB(NBLIB)=[F:A_TZ]NOLIB
      Endif
    Endif
    If [F:A_TZ]CODTYP<>""
      Read [A_TY]CODTYP=[F:A_TZ]CODTYP
      If fstat=0
        Case [F:A_TY]TYPTYP
          When 1,2,3   : VALP="Integer"
          When 7       : VALP="Char"
          When 8       : VALP="Date"
          When 9       : VALP="Blob"
          When 10      : VALP="Clob"
          When Default : VALP="Decimal"
        Endcase
        PROP="TYP" : Gosub ADDPROP
        PROP="MOD" : VALP="Input" : Gosub ADDPROP
        If [F:A_TY]TYPTYP=7 or [F:A_TY]TYPTYP=9 or [F:A_TY]TYPTYP=10
          VALP=""
          If [F:A_TZ]LONG<>0
            VALP=num$([F:A_TZ]LONG)
          Elsif [F:A_TY]LNGTYP<>0
            VALP=num$([F:A_TY]LNGTYP)
          Endif
          PROP="LEN" : Gosub ADDPROP
        Endif
      Endif
    Endif
  #{SAM 120534
   Gosub EVALINTIT
   VALL1+="/>"
   Wrseq VALL1 Using [XML_]
  Endif
  #SAM 120534}
Return


$EVALINTIT
If IINTIT<>0
  For indice=1 To GI_NBLAN
    Read [A_TX]NUMERO = GI_LLAN(indice);IINTIT
    If fstat=0
      VALLM = [F:A_TX]TEXTE
      Gosub MVALC From INTRUTILA
      PROP="C_"+GI_LLAN(indice) : VALP=VALLM : Gosub ADDPROP
    Endif
  Next indice
Endif
Return

$EVALINTITM
If IINTIT<>0
  For indice=1 To GI_NBLAN
    Read [A_ST]CLE = NOMEN;NOMES;GI_LLAN(indice)
    If fstat=0
      VALLM = [F:A_ST]LANMES
      Gosub MVALC From INTRUTILA
      PROP="C_"+GI_LLAN(indice) : VALP=VALLM : Gosub ADDPROP
    Endif
  Next indice
Endif
Return

$ADDBASPAG    : # Inutile (traité directement par le mécanisme de remontée des noeuds)
 If TYPBLC(MSKCOU,BLCOU)<>1 : Return : Endif
 VALL1="<GRP"
 PROP="NAM" : VALP=ABREV(MSKCOU)+"__"+num$(BLCOU) : Gosub ADDPROP
 PROP="TYB" : VALP="Control" :   Gosub ADDPROP
 PROP="DIM" : VALP="1" :  Gosub ADDPROP
 VALL1+=">"
 Wrseq VALL1 Using [XML_]

 VALL1="<FLD"
 PROP="NAM" : VALP=BASTAB(MSKCOU,BLCOU) : Gosub ADDPROP
 PROP="TYP" : VALP="Integer" : Gosub ADDPROP
 PROP="MOD" : VALP="Input"  : Gosub ADDPROP
 VALL1+="/>"
 Wrseq VALL1 Using [XML_]

 VALL1="</GRP>"
 Wrseq VALL1 Using [XML_]
Return

$ECRBLOC
  VALL1="<GRP"
  PROP="NAM" : VALP=NAMBLCOU : Gosub ADDPROP
  PROP="TYB"
  Case TYPBLC(MSKCOU,BLCOU)
    When 1 : VALP="Table"
    When 2 : VALP="List"
    When 3 : VALP="Pict"
    When 4 : VALP="Text"
    When 5 : VALP="Hidden"
    When Default : VALP="Other"
  Endcase
  Gosub ADDPROP
  PROP="DIM" : VALP="1"
  If TYPBLC(MSKCOU,BLCOU)=1 : VALP=num$(DIMTAB(MSKCOU,BLCOU)) : Endif
  Gosub ADDPROP
  If TYPBLC(MSKCOU,BLCOU)=1
    PROP="IDTAB" : VALP=ABREV(MSKCOU)+"~"+BASTAB(MSKCOU,BLCOU) : Gosub ADDPROP
    VALP=""
    If instr(1,OPTTAB(MSKCOU,BLCOU),"I")<>0 : VALP+="I" : ACTINSLIG+=1 : Endif
    If instr(1,OPTTAB(MSKCOU,BLCOU),"A")<>0 : VALP+="A" : ACTSUPLIG+=1 : Endif
    If instr(1,OPTTAB(MSKCOU,BLCOU),"D")<>0 : VALP+="D" : ACTSUPLIG+=1 : Endif
    PROP="OPT"   : Gosub ADDPROP
  Endif
  VALL1+=">"
  Wrseq VALL1 Using [XML_]
Return


$ADDPROP
#      Ajoute une propriété et écrit un enreg si la longueur de la ligne est > 100
  If len(VALL1)+len(PROP)+len(VALP) > 100
    VALL1+=" "
    Wrseq VALL1 Using [XML_]
    VALL1=PROP+'="'+VALP+'"'
  Else
    VALL1-=PROP+'="'+VALP+'"'
  Endif
Return


# ------------------------------------------------------------------------------------

Subprog CRESP(APPLI,PRG,SUBPRG,PUBLI,VISU,HORDAT)
#
Value Char APPLI,PRG,SUBPRG,PUBLI,HORDAT
Value Integer VISU

If clalev([F:ASU])=0 : Local File =APPLI+".ASUBPROG"  [ASU] : Endif
If clalev([F:ASP])=0 : Local File =APPLI+".ASUBPROGD" [ASP] : Endif
If clalev([F:A_XX])=0 : Local File =APPLI+".ATEXTRA"  [A_XX] : Endif
If clalev([F:A_TX])=0 : Local File =APPLI+".ATEXTE"   [A_TX] : Endif
If clalev([F:A_ST])=0 : Local File =APPLI+".APLSTD"   [A_ST] : Endif
If clalev([F:A_WY])=0 : Local File =APPLI+".AWEBSERDES" [A_WY] : Endif

Read [ASU]ASU0=PRG;SUBPRG
If (fstat<>0) : Call ECR_TRACE(mess(71,150,1)-PRG-SUBPRG,1) From GESECRAN : End : Endif

# Ouverture du fichier résultat
Local Char DIRSEP, NOMFIC(200),VALL1(200),NAMFILE,VALLM(200)
Local Char PROP(100),VALP(100),FIRSTGRP(20),GRPCOU(20)
Local Char APARAM(GLONAVB)(1..500),APUBLI(20)(1..500),ADESPAR(30)(1..500),AGRP(20)(1..500)
Local Integer ADIME(1..500),ATYPPAR(1..500),AADRVAL(1..500), STARTGR(1..500)
Local Integer RES, OK, NBCHP, I , J, NBLIB, LISTLIB(1..500)
Local Char LISTGROUP(50)(1..200)
Local Integer NBGROUP,DIMGROUP(1..200)

Call GLOBWEB(APPLI) From INTRUTILA


Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
Call NAMEFIC(APPLI,"WEBS","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,0)<0
  Call SYSTEME(adxmac(0),'ae_mkdir "'+NOMFIC+'"',"",RES) From ORDSYS
Endif

NAMFILE=PUBLI
Call NAMEFIC(APPLI,"WEBS","",NAMFILE,NOMFIC) From INTRUTILA
Openo NOMFIC,0 Using [XML_]
Iomode adxifs ""  Using [XML_]
Iomode adxirs chr$(10)  Using [XML_]
Iomode adxium GUTF8  Using [XML_]
#  Ecriture du fichier XML

Wrseq '<?xml version="1.0" encoding="utf-8" ?>' Using [XML_]
VALL1='<ADXDOC'
PROP="PNA" : VALP=PUBLI : Gosub ADDPROP
PROP="TIM" : VALP=HORDAT : Gosub ADDPROP
PROP="PRG" : VALP=PRG : Gosub ADDPROP
PROP="SPG" : VALP=SUBPRG : Gosub ADDPROP
PROP="FOL" : VALP=APPLI : Gosub ADDPROP
PROP="SOL" : VALP=GINSTID : Gosub ADDPROP
PROP="USER" : VALP=GUSER : Gosub ADDPROP
PROP="VER" : Gosub VERGEN : VALP=VERGEN : Gosub ADDPROP
PROP="HEAD" : VALP="1" : Gosub ADDPROP
PROP="WRP" : VALP="WJ"+PUBLI : Gosub ADDPROP
# PROP="C_"+GLANGUE : VALP=[F:ASU]DES : Gosub ADDPROP
PROP="C_"+GLANGUE : Call TEXTE([F:ASU]INTIT,VALLM) From OBJDIV : Gosub MVALC From INTRUTILA : VALP=VALLM: Gosub ADDPROP
VALL1+='>'
Wrseq VALL1 Using [XML_]

VALL1=" <ADXDATA>"
Wrseq VALL1 Using [XML_]


# PARAM  - Nom du paramètre
# TYPPAR - Type de paramètre : Char (1) , Integer (2) , Decimal (3) , Date (4) , Libellé (5), Clob (6)
# ADRVAL - Mode de gestion : Input (1) , Display (2)
# DESPAR - Intitulé du paramètre
# DIME   - Dimension de la variable
# PUBLI  - Nom public

I = 0
Raz LISTGROUP,NBGROUP,DIMGROUP
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
 GRPCOU=""
 Filter [A_WY] Where PUBLI=[L]PUBLI and CHP=[F:ASP]PARAM
 For [A_WY]
   GRPCOU=[F:A_WY]GROUPE
   AGRP(I+1)=[F:A_WY]GRP
   Break 1
 Next
 Filter [A_WY]

 If GRPCOU=""
   If NBGROUP=0
     GRPCOU="G1"
   Else
     If [F:ASP]DIME=ADIME(I)
       GRPCOU=APUBLI(I)
     Else
       GRPCOU="G"+num$(NBGROUP+1)
     Endif
   Endif
 Endif

 APARAM(I+1)=[F:ASP]PARAM
 APUBLI(I+1)=GRPCOU
 Call TEXTE([F:ASP]INTITPAR,ADESPAR(I+1)) From OBJDIV
 ADIME(I+1)=[F:ASP]DIME
 ATYPPAR(I+1)=[F:ASP]TYPPAR
 AADRVAL(I+1)=[F:ASP]ADRVAL
 If NBGROUP=0
  NBGROUP+=1 : STARTGR(NBGROUP)=I+1
 Else
  If !find(APUBLI(I+1),APUBLI(1..I)) : NBGROUP+=1 : STARTGR(NBGROUP)=I+1 : Endif
 Endif
 If !find(APUBLI(I+1),LISTGROUP(1..NBGROUP))
  LISTGROUP(NBGROUP) = APUBLI(I+1)
  DIMGROUP(NBGROUP)  = ADIME(I+1)
 Endif
 I+=1
Next ASP
NBCHP=I


GRPCOU=""
Local Char SPCHAMP(60)
Local Integer SPSELECT,SPLONCHP,SPNOLIB
For J=1 To NBGROUP
 GRPCOU=LISTGROUP(J)
 VALL1='<GRP'
 PROP="PNA" : VALP=GRPCOU : Gosub ADDPROP
 PROP="NAM" : VALP=GRPCOU : Gosub ADDPROP
 PROP="DIM" : VALP=num$(DIMGROUP(J)) : Gosub ADDPROP
 VALL1+=">"
 Wrseq VALL1 Using [XML_]
 For I=1 To NBCHP
   If APUBLI(I)=GRPCOU
     Read [A_WY]AWY1=[L]PUBLI;AGRP(I);APARAM(I)
     If fstat=0
       SPCHAMP=[F:A_WY]CHAMP
       SPLONCHP=[F:A_WY]LONCHP
       SPSELECT=[F:A_WY]SELECT
       SPNOLIB=[F:A_WY]NOLIB
     Else
       SPCHAMP=APARAM(I)
       SPLONCHP=0
       SPSELECT=2
       SPNOLIB=0
     Endif
     VALL1='<FLD'
     PROP="NAM" : VALP=SPCHAMP : Gosub ADDPROP
     PROP="IDX" : VALP=num$(I) : Gosub ADDPROP
     Case ATYPPAR(I)
       When 1 : VALP="Char"
       When 2 : VALP="Integer"
       When 3 : VALP="Decimal"
       When 4 : VALP="Date"
       When 5 : VALP="Libelle"
       When 6 : VALP="Clob"
       When 7 : VALP="Blob"
       When Default : VALP="Char"
     Endcase
     PROP="TYP" : Gosub ADDPROP
     Case AADRVAL(I)
       When 1 : VALP="Adr"
       When 2 : VALP="Value"
       When Default : VALP="Adr"
     Endcase
     PROP="PAR" : Gosub ADDPROP
     VALP="Input"
     PROP="MOD" : Gosub ADDPROP
     If SPSELECT<>2
       VALP="true"
       PROP="UNSEL" : Gosub ADDPROP
     Endif
     VALP=""
     Case ATYPPAR(I)
       When 1   : If SPLONCHP>0 : VALP=num$(SPLONCHP) : Else : VALP="250" : Endif
       When 6,7 : If SPLONCHP>0 : VALP=num$(SPLONCHP) : Else : VALP="4"   : Endif
     Endcase
     If VALP<>"" : PROP="LEN" : Gosub ADDPROP : Endif
     If SPNOLIB<>0
       PROP="MEN" : VALP=num$(SPNOLIB) : Gosub ADDPROP
       If !find(SPNOLIB,LISTLIB(1..NBLIB))
         NBLIB+=1 : LISTLIB(NBLIB)=SPNOLIB
       Endif
     Endif
     # PROP="C_"+GLANGUE : VALP=[F:ASU]DESPAR(I) : Gosub ADDPROP
     PROP="C_"+GLANGUE : VALP=""
     VALLM=ADESPAR(I)
     Gosub MVALC From INTRUTILA
     VALP=VALLM
     If VALP<>"" : Gosub ADDPROP : Endif
     VALL1+="/>"
     Wrseq VALL1 Using [XML_]
   Endif
 Next I
 Wrseq "</GRP>" Using [XML_]
Next J

VALL1=" </ADXDATA>"
Wrseq VALL1 Using [XML_]



VALL1=" <ADXMEN>"
Wrseq VALL1 Using [XML_]
Sorta NBLIB LISTLIB(1..NBLIB)
For I=1 To NBLIB
    VALL1="<MNU"
    PROP="NO" : VALP=num$(LISTLIB(I)) : Gosub ADDPROP
    VALL1+=">"
    Wrseq VALL1 Using [XML_]
    For K=1 To len(mess(0,LISTLIB(I),1))
      VALL1="<VAL"
      PROP="IND" : VALP=num$(K) : Gosub ADDPROP
      For J=1 To GI_NBLAN
        Read [A_ST]CLE=LISTLIB(I);K;GI_LLAN(J)
        If fstat=0 Then
          VALLM=[F:A_ST]LANMES
          Gosub MVALC From INTRUTILA
          PROP="C_"+GI_LLAN(J) : VALP=VALLM : Gosub ADDPROP
        Endif
      Next J
      VALL1+="/>"
      Wrseq VALL1 Using [XML_]
    Next K
    VALL1="</MNU>"
    Wrseq VALL1 Using [XML_]
Next I
VALL1="</ADXMEN>"
Wrseq VALL1 Using [XML_]



VALL1="</ADXDOC>"
Wrseq VALL1 Using [XML_]

Openo Using [XML_]

Local Integer ATYPOBJ : ATYPOBJ=2
#If dim([M:AWE0]TYPOBJ)>0 and [M:AWE0]PUBLI=[L]PUBLI
  Gosub GENXSD From AGENXSD
#Endif


Gosub GENWRAP

[F:ASU]PUBLINAM=[L]PUBLI
Local Integer COMLOC
If adxlog=0 : COMLOC=1 : Trbegin [ASU] : Endif
Rewrite [ASU]
If COMLOC=1 : Commit : Endif



End




######################################################################################
#    Création du programme Wrapper de sous-programmes

$GENWRAP
NOMFIC=filpath("TRT","WJ"+PUBLI,"src",APPLI)
Openo NOMFIC,0
Iomode adxifs ""
Iomode adxirs chr$(10)
Iomode adxium GUTF8

adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.1  $"
Wrseq " "
Wrseq "#########################################################################"
Wrseq "## Publication d'un web-service associé à un sous-programme"
Wrseq "## Nom de Programme         :"-PRG
Wrseq "## Nom de Sous-programme    :"-SUBPRG
Wrseq "## Nom de Publication       :"-PUBLI
Wrseq "## Timestamp de génération  :"-HORDAT
Gosub VERGEN
Wrseq "## Version de génération    :"-VERGEN
Wrseq "#########################################################################"

Wrseq " "
Wrseq " "
Wrseq "Local Integer WW_OK"
Wrseq "Local Char    WW_ZONE(30)"
Wrseq "Local Integer WW_STAT"
Wrseq "Local Integer WW_GRAVE(1..50)"
Wrseq "Local Char    WW_MESS(250)(1..50)"
Wrseq "Local Char WW_ACTION"
Wrseq "Local Char    WW_IDENT(250)"
Wrseq "Local Integer WW_NB"
Wrseq "Local Char    WW_HORDAT(14)"
Wrseq "Local Char    WW_TAB(20)"
Wrseq "Local Char    WW_PAR(80)(1..10)"
Wrseq "Local Clbfile WW_TRACE(1)"
Wrseq 'WW_HORDAT="'+HORDAT+'"'


I =0
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
  VALL1="Local "
  Case [F:ASP]TYPPAR
    When 1 : VALL1+="Char"
    When 2 : VALL1+="Integer"
    When 3 : VALL1+="Decimal"
    When 4 : VALL1+="Date"
    When 5 : VALL1+="Libelle"
    When 6 : VALL1+="Clbfile"
    When 7 : VALL1+="Blbfile"
    When Default : VALL1+="Char"
  Endcase
  VALL1-=[F:ASP]PARAM
  Case [F:ASP]TYPPAR
      When 1   : If [F:ASP]LONG>0 : VALL1+="("+num$([F:ASP]LONG)+")" : Else : VALL1+="(250)" : Endif
      When 6,7 : If [F:ASP]LONG>0 : VALL1+="("+num$([F:ASP]LONG)+")" : Else : VALL1+="(4)"   : Endif
  Endcase
  If [F:ASP]DIME>1
    VALL1+="(1.."+num$([F:ASP]DIME)+")"
  Endif
  Wrseq VALL1
 I += 1
Next ASP

Wrseq " "
Wrseq " "

Local Integer IVAR, RGVAR(1..500)
For J=1 To NBGROUP
 If STARTGR(J)>0    : # CCL 64906
  GRPCOU=APUBLI(STARTGR(J))
  #For I=STARTGR(J)-1 To [F:ASU]NBRPAR-1
  I = STARTGR(J)-1
  For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG & LIGNE>=STARTGR(J)-1
   # If [F:ASU]PUBLI(I)=GRPCOU
    If APUBLI(I+1)=GRPCOU
       IVAR+=1
       RGVAR(IVAR)=I
    Endif
    I += 1
   Next ASP
 Endif
Next J

#  Appel du sous-programme
Wrseq 'Call OUVRE_TRACE("") From LECFIC'
Wrseq ' '

Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub INITWS From '+PRG
Wrseq 'Onerrgo'
Wrseq ' '

VALL1="Call "+SUBPRG+"(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION,WW_IDENT,WW_NB,WW_HORDAT"
VALL1+=",WW_TAB,WW_PAR,WW_TRACE"
Local Integer NBGV,J,DEB,FIN
NBGV=1+([F:ASU]NBRPAR-1)/5
For J=1 To NBGV
  Wrseq VALL1
  VALL1="&            "
  DEB=(J-1)*5+1-1
  FIN=min(DEB+4,[F:ASU]NBRPAR-1)
  For I=DEB To FIN
    Read [ASP]ASP0=[F:ASU]PRG;[F:ASU]SUBPRG;RGVAR(I+1)
    VALL1+=","+[F:ASP]PARAM
  Next I
Next J
VALL1+=")"
Wrseq VALL1
Wrseq " "
Wrseq 'Call ECR_TRACE(mess(218,123,1)+" : "+num$(WW_OK)-"("+mess(WW_OK+3,2940,1)+")",0) From GESECRAN'
Wrseq 'Call ECR_TRACE(mess(219,123,1)+" : "+num$(WW_STAT),0) From GESECRAN'
Wrseq 'Call ECR_TRACE("  ",0) From GESECRAN'

Wrseq 'Call ECR_TRACE(mess(222,123,1),0) From GESECRAN'
Wrseq 'Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'
Wrseq "For indice=1 To WW_STAT"
Wrseq "  If WW_GRAVE(indice)=3"
Wrseq '    Call ECR_TRACE(num$(indice)-num$(WW_GRAVE(indice))+" ("+mess(WW_GRAVE(indice),2940,1)+") :"-WW_MESS(indice),1) From GESECRAN'
Wrseq '  Else'
Wrseq '    Call ECR_TRACE(num$(indice)-num$(WW_GRAVE(indice))+" ("+mess(WW_GRAVE(indice),2940,1)+") :"-WW_MESS(indice),0) From GESECRAN'
Wrseq '  Endif'
Wrseq 'Next indice'
Wrseq 'If WW_STAT=0 : Call ECR_TRACE("",0) From GESECRAN : Endif'
Wrseq 'Call ECR_TRACE("-------------------------------------------",0) From GESECRAN'

Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub RESULTWS From '+PRG
Wrseq 'Onerrgo'
Wrseq ' '


Wrseq 'Call FERME_TRACE From LECFIC'
Wrseq 'Call LEC_TRACE From LECFIC'

Wrseq "End"

Wrseq ' '
Wrseq ' '
Wrseq '$ERREURWS'
Wrseq 'Resume'
Wrseq ' '


#  Wrapper du sous-programme
Wrseq " "
Wrseq "# --------------------------------------------------------------- "
Wrseq " "

VALL1="Subprog "+SUBPRG+"(WW_OK,WW_ZONE,WW_STAT,WW_GRAVE,WW_MESS,WW_ACTION,WW_IDENT,WW_NB,WW_HORDAT"
VALL1+=",WW_TAB,WW_PAR,WW_TRACE"
For J=1 To NBGV
  Wrseq VALL1
  VALL1="&            "
  DEB=(J-1)*5+1-1
  FIN=min(DEB+4,[F:ASU]NBRPAR-1)
  For I=DEB To FIN
    Read [ASP]ASP0=[F:ASU]PRG;[F:ASU]SUBPRG;RGVAR(I+1)
    VALL1+=","+[F:ASP]PARAM
  Next I
Next J
VALL1+=")"
Wrseq VALL1
Wrseq " "
Wrseq "Variable Integer WW_OK"
Wrseq "Variable Char    WW_ZONE()"
Wrseq "Variable Integer WW_STAT"
Wrseq "Variable Integer WW_GRAVE(1..)"
Wrseq "Variable Char    WW_MESS()(1..)"
Wrseq "Value Char       WW_ACTION"
Wrseq "Value Char       WW_IDENT()"
Wrseq "Variable Integer WW_NB"
Wrseq "Variable Char    WW_HORDAT()"
Wrseq "Variable Char    WW_TAB()"
Wrseq "Variable Char    WW_PAR()(1..)"
Wrseq "Variable Clbfile WW_TRACE()"


For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
  Case [F:ASP]ADRVAL
    When 1 : VALL1="Variable "
    When 2 : VALL1="Value "
    When Default : VALL1="Variable "
  Endcase
  Case [F:ASP]TYPPAR
    When 1 : VALL1+="Char"
    When 2 : VALL1+="Integer"
    When 3 : VALL1+="Decimal"
    When 4 : VALL1+="Date"
    When 5 : VALL1+="Libelle"
    When 6 : VALL1+="Clbfile"
    When 7 : VALL1+="Blbfile"
    When Default : VALL1+="Char"
  Endcase
  VALL1-=[F:ASP]PARAM
  Case [F:ASP]TYPPAR
    When 1,6,7 : VALL1+="()"
  Endcase
  If [F:ASP]DIME>1
    VALL1+="(1..)"
  Endif
  Wrseq VALL1
Next ASP

Wrseq " "
Wrseq " "
Wrseq "WW_OK=0"
Wrseq "Gosub ISDBGON from AWEB"
Wrseq "If WW_OK<>0 : End : Endif"

Wrseq "Local Char HORDAT1(14)"
Wrseq "Local Integer WW_I"
#Wrseq 'HORDAT1="'+num$(HORDAT)+'"'
Wrseq "Local Char HORDATG(14),VERGEN"
Wrseq 'HORDATG="'+num$(HORDAT)+'"'
Gosub VERGEN
Wrseq 'VERGEN="'+num$(VERGEN)+'"'
Wrseq 'Call RECUPHDAT("'+PUBLI+'",HORDAT1,WW_I) from AWEB'
Wrseq "Gosub ANLHORSPG From AWEB"
Wrseq "If WW_OK<>0 : Gosub SETTRACE : End : Endif"
Wrseq "GWEBSERV=1"
Wrseq "indice=0"
Wrseq "Raz GMESSAGE,GW_STAT,GW_MESS,GW_GRAVE"
Wrseq " "
Wrseq " "

Wrseq 'Local Char ALIAS : ALIAS="'+PUBLI+'"'
#  Point d'entrée wrapper
Wrseq 'Local Char ACTION'
Wrseq 'ACTION="AV_WS"'
Wrseq 'GPE=0'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'




Wrseq 'If GPE<>1'

VALL1="Call "+SUBPRG+"("
For J=1 To NBGV
  If J>1 : VALL1="&            " : Endif
  DEB=(J-1)*5+1-1
  FIN=min(DEB+4,[F:ASU]NBRPAR-1)
  I =  DEB
  For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG & LIGNE>=DEB & LIGNE<=FIN
    VALL1+=[F:ASP]PARAM+","
    I += 1
  Next ASP
  If J=NBGV : VALL1=left$(VALL1,len(VALL1)-1)+") From "+PRG : Endif
  Wrseq VALL1
Next J
If NBGV=0 : VALL1+=") From "+PRG  : Wrseq VALL1 : Endif
Wrseq " "
Wrseq " "
Wrseq "Gosub ANLSPGRES From AWEB"
Wrseq 'Endif'
Wrseq

Wrseq 'ACTION="AP_WS"'
Wrseq 'Onerrgo ERREURWS'
Wrseq 'Gosub ACTION From SPEWS'
Wrseq 'Onerrgo'

Wrseq "GWEBSERV=0"
Wrseq "Gosub SETTRACE"
Wrseq "End"

Wrseq
Wrseq
Wrseq
 Wrseq '$XT_SPG'
 Wrseq 'Local Integer WIND : WIND ='+num$([F:ASU]NBRPAR)
 Wrseq 'Local Char    PRG      :    PRG="'+PRG+'"'
 Wrseq 'Local Char    SUBPRG   :    SUBPRG="'+SUBPRG+'"'
 Wrseq 'Local Integer RUBNBR   :    RUBNBR=WIND'
 Wrseq 'Local Char    RUBCOD        (GLONAVA+2)(0..WIND-1 )'
 Wrseq 'Local Char    RUBGRP        (GLONAPU)(0..WIND-1 )'
 Wrseq 'Local Integer RUBINTIT      (0..WIND-1 )'
 Wrseq 'Local Char    RUBTYP        (10)(0..WIND-1 )    :    # Internal type (example Char, Integer)'
 Wrseq 'Local Integer RUBADR        (0..WIND-1 )'
 Wrseq 'Local Integer RUBLON        (0..WIND-1 )'
 Wrseq 'Local Integer RUBMNL        (0..WIND-1 )'
 Wrseq 'Local Integer RUBDIM        (0..WIND-1 )'
 Wrseq ' '


J =0
For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
     VALL1 ='RUBCOD('+num$(J)+')="'+[F:ASP]PARAM+'" : '
     VALL1+='RUBGRP('+num$(J)+')="'+APUBLI(J+1)+'" : '
     VALL1+='RUBINTIT('+num$(J)+')='+num$([F:ASP]INTITPAR)+' : '
     VALL1+='RUBTYP('+num$(J)+')="'+num$([F:ASP]TYPPAR)+'" : '
 #    Case [F:AP]TYPPAR
 #     When 1 : VALL1+="Char"
 #     When 2 : VALL1+="Integer"
 #     When 3 : VALL1+="Decimal"
 #     When 4 : VALL1+="Date"
 #     When 5 : VALL1+="Libelle"
 #     When 6 : VALL1+="Clbfile"
 #     When 7 : VALL1+="Blbfile"
 #     When Default : VALL1+="Char"
 #    Endcase
 #    VALL1+='" : '
     IT1=[F:ASP]ADRVAL : If IT1>2 : IT1=2 : Endif
     VALL1+='RUBADR('+num$(J)+')='+num$(IT1)+' : '
     VALL1+='RUBLON('+num$(J)+')='+num$([F:ASP]LONG)+' : '
     VALL1+='RUBDIM('+num$(J)+')='+num$([F:ASP]DIME)+' : '
     VALL1+='RUBMNL('+num$(J)+')=0'
     Wrseq VALL1
   J += 1
Next ASP
Wrseq 'Return'


Gosub SETTRACE

Openo
Call VALID("TRT","WJ"+PUBLI,APPLI,OK) From VALMSKSUB

Return


#     Analyse si la description XML du serveur web est à jour
$ANLHORSPG
 Gosub ANLHORSPG From AWEB
Return


#     Analyse au retour d'un sous-programme. Charge les variables de status
$ANLSPGRES
 Gosub ANLSPGRES From AWEB
Return



# ----------------------------------------------------------------------------
Subprog BWIN(APPLI,WIND,NBBOUT,CBOUT,CACT,NTEXB)
Value Char WIND
Variable Integer NBBOUT
Variable Char CBOUT()(1..)
Variable Char CACT()(1..)
Variable Integer NTEXB(1..)

If APPLI="" : APPLI = nomap : Endif

If clalev([F:A_WT])=0 : Local File =APPLI+".AWINBOUT" [A_WT] : Endif
If clalev([F:A_CV])=0 : Local File =APPLI+".ACTIV"    [A_CV] : Endif
If clalev([F:A_CT])=0 : Local File =APPLI+".ACTION"   [A_CT] : Endif

Filter [A_WT] Where WIN=WIND

# On rend disponibles les boutons qui n'ouvrent pas de fenêtre

For [A_WT]
  If [F:A_WT]ACTBOUT="" : Goto BSUIT : Endif
  If [F:A_WT]CODACTBOUT<>""
    Read [F:A_CV]CODACT = [F:A_WT]CODACTBOUT
    If fstat or [F:A_CV]FLACT<>2
      Goto BSUIT
    Endif
  Endif
# on vérifie si l'action n'ouvre pas de fenêtre
  Read [F:A_CT]ACTION = [F:A_WT]ACTBOUT
  If fstat or [F:A_CT]TYP<=6
    Goto BSUIT
  Endif
  NBBOUT+=1
  CBOUT(NBBOUT)=[F:A_WT]CODBOUT
  CACT(NBBOUT)=[F:A_WT]ACTBOUT
  NTEXB(NBBOUT)=[F:A_WT]TXTBOUT
$BSUIT:
Next

Filter [A_WT]

End




$SETTRACE
Wrseq " "
Wrseq " "
Wrseq "$SETTRACE"
Wrseq "Local Char WPTRACE(200)(1..500)"
Wrseq "Local Integer IT"
Wrseq "Setlob WPTRACE(1..IT) With WW_TRACE"
Wrseq 'If instr(1,WPTRACE(1),"adonix.trace.on=on")=0 : Return : Endif'
Wrseq 'WPTRACE(1)="Engine version    : "+num$(ver$(0))+chr$(10)'
Wrseq 'WPTRACE(2)="Wrapper timestamp : "+num$(HORDATG)+chr$(10)'
Wrseq 'WPTRACE(3)="Wrapper version   : "+num$(VERGEN)+chr$(10)'
Wrseq 'WPTRACE(4)="Duration time     : "+num$(time-val(TSTART))+chr$(10)'
Wrseq 'WPTRACE(5)="WW_OK     : "+num$(WW_OK)+chr$(10)'
Wrseq 'WPTRACE(6)="WW_ZONE   : "+num$(WW_ZONE)+chr$(10)'
Wrseq 'WPTRACE(7)="WW_STAT   : "+num$(WW_STAT)+chr$(10)'
Wrseq 'IT=8'
Wrseq 'For indice=1 To WW_STAT'
Wrseq '  WPTRACE(IT)="WW_GRAVE("+num$(indice)+")  : "+num$(WW_GRAVE(indice))+chr$(10)'
Wrseq '  IT+=1 : WPTRACE(IT)="WW_MESS("+num$(indice)+")   : "+num$(WW_MESS(indice))+chr$(10)'
Wrseq '  IT+=1'
Wrseq 'Next indice'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_ACTION : "+num$(WW_ACTION)+chr$(10)'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_IDENT  : "+num$(WW_IDENT)+chr$(10)'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_NB     : "+num$(WW_NB)+chr$(10)'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_HORDAT : "+num$(WW_HORDAT)+chr$(10)'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_TAB    : "+num$(WW_TAB)+chr$(10)'
Wrseq 'IT+=1 : WPTRACE(IT)="WW_PAR    : "+num$(WW_PAR)+chr$(10)'
Wrseq 'Setlob WW_TRACE With WPTRACE(1..IT)'
Wrseq 'Return   '
Return





$GENERXTEND

Wrseq '# Interface liste gauche pour Xtend'
Wrseq '$XT_LISTE'
Wrseq 'Local Char    PRG      :    PRG="'+NOMTRT+'"'
Wrseq 'Local Char    SUBPRG   :    SUBPRG="LISTE"'
Wrseq 'Local Integer RUBNBR   :    RUBNBR='+num$(NBSEL)
Wrseq 'Local Char    RUBCOD        (GLONAVA+2)(0..'+num$(NBSEL-1)+')'
Wrseq 'Local Char    RUBGRP        (GLONAPU)(0..'+num$(NBSEL-1)+')'
Wrseq 'Local Integer RUBINTIT      (0..'+num$(NBSEL-1)+')'
Wrseq 'Local Char    RUBTYP        (GLONATY)(0..'+num$(NBSEL-1)+')'   : # Type X3 (ATY)
Wrseq 'Local Integer RUBADR        (0..'+num$(NBSEL-1)+')'            : # Menu 34 (1:adresse 2:value)
Wrseq 'Local Integer RUBLON        (0..'+num$(NBSEL-1)+')'
Wrseq 'Local Integer RUBDIM        (0..'+num$(NBSEL-1)+')'
Wrseq 'Local Integer RUBMNL        (0..'+num$(NBSEL-1)+')'
Wrseq 'Local Integer RUBRESMAX   :    RUBRESMAX=10000'
Wrseq

Local Char NOMZ(20),AT1
Local Integer IZONT
Read [A_OL]AOL0=OBJET
If fstat=0
  For I= 0 To [F:A_OL]NBSEL-1
    If  [F:A_OL]SELFIC(I)<>"" and [F:A_OL]SELZON(I)<>""
      Read [A_TZ]CODZONE=[F:A_OL]SELFIC(I);[F:A_OL]SELZON(I)
      If fstat=0 : IZONT=1 : Endif
    Endif
    NOMZ=[F:A_OL]SELZON(I)
    If NOMZ="" : NOMZ="C"+num$(I+1) : Endif
    VALL1 ='RUBCOD('+num$(I)+')="'+NOMZ+'" : '
    VALL1+='RUBGRP('+num$(I)+')="RES" : '
    IINTIT=[F:A_OL]SELINT(I)
    If IINTIT=0 and IZONT=1 : IINTIT=[F:A_TZ]NOLONG : Endif
    VALL1+='RUBINTIT('+num$(I)+')='+num$(IINTIT)+' : '
    AT1=[F:A_OL]SELTYP(I)
    If AT1=""
      If IZONT=1 : AT1=[F:A_TZ]CODTYP : Else : AT1="A" : Endif
    Endif
    VALL1+='RUBTYP('+num$(I)+')="'+AT1+'" : '
    VALL1+='RUBADR('+num$(I)+')=2 : '
    IINTIT=[F:A_OL]SELLNG
    If IINTIT=0 and IZONT=1
      IINTIT=[F:A_TZ]LONG
      If IINTIT=0
        Read [A_TY]CODTYP = [F:A_TZ]CODTYP
        If fstat=0 : IINTIT=[F:A_TY]LNGTYP : Endif
        If IINTIT=0 and [F:A_TY]TYPTYP=8 : IINTIT=10 : Endif   : # Date sur 10 caracteres
      Endif
    Endif
    If IINTIT=0 : IINTIT=30 : Endif     :  #  Longueur non trouvée, on prend 30
    VALL1+='RUBLON('+num$(I)+')='+num$(IINTIT)+' : '
    VALL1+='RUBDIM('+num$(I)+')=RUBRESMAX'
    If IZONT=1 and  [F:A_TZ]NOLIB<>0
      VALL1+=' : RUBMNL('+num$(I)+')='+num$([F:A_TZ]NOLIB)
    Endif
    Wrseq VALL1
  Next I
Endif
Wrseq 'Return'


# La table principale de cet objet gère-t-elle les propriétés UPDDAT et UPDTIM ou UPDSTP
Local Integer GTSP
Read [A_TZ]CODZONE=[F:A_OB]NOMFIC;"UPDDAT"
If fstat=0
  Read [A_TZ]CODZONE=[F:A_OB]NOMFIC;"UPDTIM"
  If fstat=0 : GTSP=2 : Endif
Endif
If GTSP=0
  Read [A_TZ]CODZONE=[F:A_OB]NOMFIC;"UPDSTP"
  If fstat=0 : GTSP=2 : Endif
Endif

#    On crée un second source pour ne pas dépasser le nombre de symboles si NBPAR > LIMPAR2SRC
If NBPAR>LIMPAR2SRC
 Gosub CRESRCXT
 Wrseq '# Interface objet pour Xtend'   Using [X_WR]
 Wrseq '$XT_OBJET' Using [X_WR]
 Local Integer IR, IT1
 For I=1 To NBPAR
  If DETBLC(MASQUE(I),BLOC(I))=0
     IR+=1
  Endif
 Next I
#  ----  On rajoute 2 à WIND pour traiter MODUSER et TIMESTAMP
# Wrseq 'Local Integer WIND : WIND ='+num$(IR-1) Using [X_WR]
 Wrseq 'Local Integer WIND : WIND ='+num$(IR-1+GTSP) Using [X_WR]
 Wrseq 'Local Char    PRG      :    PRG="'+NOMTRT+'"' Using [X_WR]
 Wrseq 'Local Char    SUBPRG   :    SUBPRG="OBJET"' Using [X_WR]
 Wrseq 'Local Integer RUBNBR   :    RUBNBR=WIND+1' Using [X_WR]
 Wrseq 'Local Char    RUBCOD        (GLONAVA+2)(0..WIND )' Using [X_WR]
 Wrseq 'Local Char    RUBGRP        (GLONAPU)(0..WIND )' Using [X_WR]
 Wrseq 'Local Integer RUBINTIT      (0..WIND )' Using [X_WR]
 Wrseq 'Local Char    RUBTYP        (GLONATY)(0..WIND )    :    # Type X3 (exemple ATY)' Using [X_WR]
 Wrseq 'Local Integer RUBADR        (0..WIND )' Using [X_WR]
 Wrseq 'Local Integer RUBLON        (0..WIND )' Using [X_WR]
 Wrseq 'Local Integer RUBMNL        (0..WIND )' Using [X_WR]
 Wrseq 'Local Integer RUBDIM        (0..WIND )' Using [X_WR]
 Wrseq ' ' Using [X_WR]

# Boucle pour initialiser des valeurs et réduire le nombre de variables affectées
Wrseq 'For IJH=0 to WIND' Using [X_WR]
Wrseq '  RUBADR(IJH)=1'   Using [X_WR]
Wrseq '  RUBDIM(IJH)=1'   Using [X_WR]
Wrseq '  RUBTYP(IJH)="M"' Using [X_WR]
Wrseq 'Next IJH' Using [X_WR]
Wrseq ' ' Using [X_WR]
#
 IR=-1
 For I=1 To NBPAR
  If DETBLC(MASQUE(I),BLOC(I))=0
     IR+=1
     VALL1 ='RUBCOD('+num$(IR)+')="'+PARAM(I)+'" : '
# NOM(I) donne le nom de la variable
     VALL1+='RUBGRP('+num$(IR)+')="'+ABREV(MASQUE(I))+"_"+num$(BLOC(I))+'" : '
     If INTIT(I)<>0
       VALL1+='RUBINTIT('+num$(IR)+')='+num$(INTIT(I))+' : '
     Endif
     If CTYP(I)<>"M"
       VALL1+='RUBTYP('+num$(IR)+')="'+CTYP(I)+'" : '
     Endif
     IT1=SAIAFF(I) : If IT1>2 : IT1=2 : Endif
     If IT1<>1
       VALL1+='RUBADR('+num$(IR)+')='+num$(IT1)+' : '
     Endif
     VALL1+='RUBLON('+num$(IR)+')='+num$(LNG(I))+' : '
     If TYPBLC(MASQUE(I),BLOC(I))=1 & PARAM(I)<>BASTAB(MASQUE(I),BLOC(I))
       VALL1+='RUBDIM('+num$(IR)+')='+num$(DIMTAB(MASQUE(I),BLOC(I)))+' : '
     Elsif DIME(I)<>1
       VALL1+='RUBDIM('+num$(IR)+')='+num$(DIME(I))+' : '
     Endif
     If NOLIB(I)<>0
       VALL1+='RUBMNL('+num$(IR)+')='+num$(NOLIB(I))
     Endif
     Wrseq VALL1 Using [X_WR]
  Endif
 Next I
 Wrseq 'Return' Using [X_WR]
 Openo Using [X_WR]

 Wrseq ' '
 Wrseq ' '
 Wrseq '# Interface objet pour Xtend'
 Wrseq '$XT_OBJET'
 Wrseq 'Gosub XT_OBJET from '+NOMTRT2

Else

 Wrseq ' '
 Wrseq ' '
 Wrseq '# Interface objet pour Xtend'
 Wrseq '$XT_OBJET'
 Local Integer IR, IT1
 For I=1 To NBPAR
  If DETBLC(MASQUE(I),BLOC(I))=0
     IR+=1
  Endif
 Next I

 #  ----  On rajoute 2 à WIND pour traiter MODUSER et TIMESTAMP
#Wrseq 'Local Integer WIND : WIND ='+num$(IR-1)
 Wrseq 'Local Integer WIND : WIND ='+num$(IR-1+GTSP)
 Wrseq 'Local Char    PRG      :    PRG="'+NOMTRT+'"'
 Wrseq 'Local Char    SUBPRG   :    SUBPRG="OBJET"'
 Wrseq 'Local Integer RUBNBR   :    RUBNBR=WIND+1'
 Wrseq 'Local Char    RUBCOD        (GLONAVA+2)(0..WIND )'
 Wrseq 'Local Char    RUBGRP        (GLONAPU)(0..WIND )'
 Wrseq 'Local Integer RUBINTIT      (0..WIND )'
 Wrseq 'Local Char    RUBTYP        (GLONATY)(0..WIND )    :    # Type X3 (exemple ATY)'
 Wrseq 'Local Integer RUBADR        (0..WIND )'
 Wrseq 'Local Integer RUBLON        (0..WIND )'
 Wrseq 'Local Integer RUBMNL        (0..WIND )'
 Wrseq 'Local Integer RUBDIM        (0..WIND )'
 Wrseq ' '

 IR=-1
 For I=1 To NBPAR
  If DETBLC(MASQUE(I),BLOC(I))=0
     IR+=1
     VALL1 ='RUBCOD('+num$(IR)+')="'+PARAM(I)+'" : '
# NOM(I) donne le nom de la variable
     VALL1+='RUBGRP('+num$(IR)+')="'+ABREV(MASQUE(I))+"_"+num$(BLOC(I))+'" : '
     VALL1+='RUBINTIT('+num$(IR)+')='+num$(INTIT(I))+' : '
     VALL1+='RUBTYP('+num$(IR)+')="'+CTYP(I)+'" : '
     IT1=SAIAFF(I) : If IT1>2 : IT1=2 : Endif
     VALL1+='RUBADR('+num$(IR)+')='+num$(IT1)+' : '
     VALL1+='RUBLON('+num$(IR)+')='+num$(LNG(I))+' : '
     If TYPBLC(MASQUE(I),BLOC(I))=1 & PARAM(I)<>BASTAB(MASQUE(I),BLOC(I))
       VALL1+='RUBDIM('+num$(IR)+')='+num$(DIMTAB(MASQUE(I),BLOC(I)))+' : '
     Else
       VALL1+='RUBDIM('+num$(IR)+')='+num$(DIME(I))+' : '
     Endif
     VALL1+='RUBMNL('+num$(IR)+')='+num$(NOLIB(I))
     Wrseq VALL1
  Endif
 Next I
Endif

If GTSP>0
  IR+=1
  VALL1 ='RUBCOD('+num$(IR)+')="AMODSTAMP" : RUBGRP('+num$(IR)+')="ADXTEC" : '
  VALL1+='RUBINTIT('+num$(IR)+')=0 : RUBTYP('+num$(IR)+')="A" : RUBADR('+num$(IR)+')=1 : '
  VALL1+='RUBLON('+num$(IR)+')='+'14 : RUBDIM('+num$(IR)+')=1 : RUBMNL('+num$(IR)+')=0'
  Wrseq VALL1
  IR+=1
  VALL1 ='RUBCOD('+num$(IR)+')="AMODUSER" : RUBGRP('+num$(IR)+')="ADXTEC" : '
  VALL1+='RUBINTIT('+num$(IR)+')=0 : RUBTYP('+num$(IR)+')="A" : RUBADR('+num$(IR)+')=1 : '
  VALL1+='RUBLON('+num$(IR)+')='+'10 : RUBDIM('+num$(IR)+')=1 : RUBMNL('+num$(IR)+')=0'
  Wrseq VALL1
Endif

# Description de la clé
I=0
Filter [A_TI] Where CODFIC=[F:A_OB]NOMFIC and NUMLIG=1
For [A_TI]
  Local Char DESC1(100)
  DESC1=[F:A_TI]DESCRIPT
  Gosub CRENBKEY
$CREELCL
  J=instr(1,DESC1,"+")
  If J>0
    VALP=left$(DESC1,J-1) : I+=1
    Gosub CREFLKEY
    DESC1=right$(DESC1,J+1)
    Goto CREELCL
  Else
    VALP=DESC1 : I+=1
    Gosub CREFLKEY
  Endif
  Break 1
Next
Filter [A_TI]

Wrseq 'Return'

Return

$CRENBKEY
Local Integer DK,NBK
For J=1 To 10
  DK=instr(DK+1,DESC1,"+")
  If DK=0 : Break 1 : Endif
  NBK+=1
Next J
Wrseq 'Local Integer RUBKEYIND     (0..'+num$(NBK)+')'
Return

$CREFLKEY
Local Integer ITKEY
For K=1 To NBPAR
 If PARAM(K)=VALP
   ITKEY=K-1 : Break 1
 Endif
Next K
Wrseq 'RUBKEYIND('+num$(I-1)+')='+num$(ITKEY)+'   : # '+VALP
Return




$CRESRCWK
If ISTRT1CR=1 : Return : Endif
NOMTRT1  = "WK"+PUBLI
NOMFIC  = filpath("TRT",NOMTRT1,"src",APPLI)
Openo NOMFIC,0 Using [K_WR]
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.1  $"  Using [K_WR]
Wrseq  Using [K_WR]
Wrseq "#########################################################################"  Using [K_WR]
Wrseq "## Publication d'un objet sous forme de web service "  Using [K_WR]
Wrseq "## Objet                    :"-OBJET  Using [K_WR]
Wrseq "## Transaction              :"-VARIANTE Using [K_WR]
Wrseq "## Champs Invisibles        :"-mess(INVISIBLE+1,1,1) Using [K_WR]
Wrseq "## Fenêtre                  :"-[F:A_WI]WIN Using [K_WR]
Wrseq "## Nom de Publication       :"-PUBLI Using [K_WR]
Wrseq "## Timestamp de génération  :"-HORDAT Using [K_WR]
Gosub VERGEN
Wrseq "## Version de génération    :"-VERGEN Using [K_WR]
Wrseq ' ' Using [K_WR]
Wrseq ' '  Using [K_WR]
 ISTRT1CR=1
Return

$CRESRCXT
If ISTRT2CR=1 : Return : Endif
NOMTRT2 = "WKX"+PUBLI
NOMFIC  = filpath("TRT",NOMTRT2,"src",APPLI)
Openo NOMFIC,0 Using [X_WR]
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision:   1.1  $"  Using [X_WR]
Wrseq  Using [X_WR]
Wrseq "#########################################################################"  Using [X_WR]
Wrseq "## Publication d'un objet sous forme de web service "  Using [X_WR]
Wrseq "## Objet                    :"-OBJET  Using [X_WR]
Wrseq "## Transaction              :"-VARIANTE Using [X_WR]
Wrseq "## Champs Invisibles        :"-mess(INVISIBLE+1,1,1) Using [X_WR]
Wrseq "## Fenêtre                  :"-[F:A_WI]WIN Using [X_WR]
Wrseq "## Nom de Publication       :"-PUBLI Using [X_WR]
Wrseq "## Timestamp de génération  :"-HORDAT Using [X_WR]
Gosub VERGEN
Wrseq "## Version de génération    :"-VERGEN Using [X_WR]
Wrseq ' ' Using [X_WR]
Wrseq ' '  Using [X_WR]
 ISTRT2CR=1
Return




# ------------------------------------------------------------------------------------------
#
#      Création d'un web service dans la table AWEBSERVIC
#      TYPGEN=1  on crée dans la table AWEBSERVIC uniquement
#            =2  on crée et on publie
#      Si l'enregistrement existe déjà on vérifie que PROG/SPROG ou OBJET/VARIANTE/INVIS
#      sont identiques, sinon on sort en erreur OK=2
#      Si l'enregistrement n'existe pas on le crée
#      Si on veut les zones invisibles mettre INVIS à 1
#      Si OK OK=0

Subprog CREWS(DOSS,PUBLI,OBJET,VARIANTE,INVIS,PROG,SPROG,TYPGEN,OK)
Value Char DOSS
Value Char PUBLI
Value Char OBJET
Value Char VARIANTE
Value Char INVIS
Value Char PROG
Value Char SPROG
Value Integer TYPGEN
Variable Integer OK

OK=0

#   Liste des Web services définis pour le dossier DOSS
#

Local Char APPLI(10),HORDAT(14)
APPLI=DOSS
If APPLI="" : APPLI=nomap : Endif

Local File =APPLI+".AWEBSERVIC" [A_WE]

# L'enregistrement existe-t-il dans AWEBSERVIC
Read [A_WE]AWE1=PUBLI
If fstat<>0 : Goto CREWS1 : Endif

# On vérifie si l'enregistrement est conforme
If [F:A_WE]OBJET<>OBJET or [F:A_WE]VARIANTE<>VARIANTE or [F:A_WE]PRG<>PROG
& or [F:A_WE]SUBPRG<>SPROG or ([F:A_WE]INVISIBLE<>val(INVIS)+1 and OBJET<>"")
   OK=2
   End
Endif
Goto CREWS2

$CREWS1:
# On crée l'enregistrement dans AWEBSERVIC
Local Integer COMLOC
If adxlog=0 : COMLOC=1 : Trbegin [F:A_WE] : Endif

[F:A_WE]TYPOBJ=1
If OBJET="" : [F:A_WE]TYPOBJ=2 : Endif
[F:A_WE]OBJET=OBJET
[F:A_WE]VARIANTE=VARIANTE
[F:A_WE]PRG=PROG
[F:A_WE]SUBPRG=SPROG
[F:A_WE]PUBLI=PUBLI
[F:A_WE]INVISIBLE=val(INVIS)+1
If dim(ABFIC)<0 : Local Char ABFIC : Endif
Local Char SAVABFIC : SAVABFIC=ABFIC
ABFIC="AWE"
Gosub INICRE From GOBJSUB
ABFIC=SAVABFIC
Write [F:A_WE]
If COMLOC=1 : Commit : Endif
If OBJET<>""
  Call CHARGOBJ("FILE",OBJET,VARIANTE,DOSS,val(INVIS),PUBLI) From AGENWEB
Endif
$CREWS2:
If TYPGEN=2
  Call ENVVAR(HORDAT) From INTRUTILA
  If OBJET=""
    Call CRESP(APPLI,PROG,SPROG,PUBLI,0,HORDAT) From AGENWEB
  Else
    Call CREOBJ(OBJET,VARIANTE,APPLI,val(INVIS),PUBLI,0,HORDAT) From AGENWEB
  Endif
Endif
Read [A_WE]AWE1=PUBLI
If fstat=0
  [F:A_WE]DATPUB=HORDAT
  [F:A_WE]USERP=GUSER
  Local Integer COMLOC
  If adxlog=0 : COMLOC=1 : Trbegin [F:A_WE] : Endif
  Rewrite [F:A_WE]
  If COMLOC=1 : Commit : Endif
Endif
End

$SET_VARIA_BLOC
Local Integer IBLOC
Read [F:A_MK]CODMSK= WMSK
If !fstat
 For IBLOC=1 To [F:A_MK]NBBLOC
  Wrseq "Local Integer"-vireblc(WABRMSK,4)+"_"+num$(IBLOC)
 Next
Endif
Return

$RAZ_VARIA_BLOC
Local Integer IBLOC
Read [F:A_MK]CODMSK= MASKSAI
If !fstat
 For IBLOC=1 To [F:A_MK]NBBLOC
  Wrseq " Raz [L]"+vireblc(WABRMSK,4)+"_"+num$(IBLOC)
 Next
Endif
Return

$SET_1_VARIA_BLOC
Local Integer IBLOC
Read [F:A_MK]CODMSK= MASKSAI
If !fstat
 For IBLOC=1 To [F:A_MK]NBBLOC
  Wrseq "  [L]"+vireblc(WABRMSK,4)+"_"+num$(IBLOC)-"+=1"
 Next
Endif
Return


