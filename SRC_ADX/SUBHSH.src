######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran HSH1) 11/10/2011 15:29:14 (MM)
######################################################################################
Subprog AV_SVRITMWEI(VALEUR)
Variable Integer VALEUR
# Pesée multi-article possible seulement en emballage interne, en pesée cumulée
# sr 12.11 demande 78888 : Elle ne peut pas être non plus "Mixte"
If find([M:HSH1]PCK,2,3) | [M:HSH1]WEIMOD = 1
  VALEUR = 1  : [M:HSH1]SVRITMWEI = 1 :  Diszo [M:HSH1]SVRITMWEI
Else
   Actzo  [M:HSH1]SVRITMWEI
Endif
End
End


######################################################################################
