#<AdxTL>@(#)5.0.0.0 $Revision$
#--- Programme de mise a jour de la table HANDLING  / Centrale de pesée
#


Call OBJET ("HSH" , GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
When "LIENS"       : Gosub LIENS
When "APRES_CRE"   : Gosub APRES_CRE
When "AVANT_MODFIC": Gosub AVANT_MODFIC
When "APRES_MOD"   : Gosub APRES_MOD
When "STATUT"      : Gosub STATUT
When "AVANTBOUT"   : Gosub AVANTBOUT
When "ABANDON"     : Gosub ABANDON
When "ANNULE"      : Gosub ANNULE
When "INICRE"      : Gosub INICRE
When "INIMOD"      : Gosub INICRE
When "SETBOUT"     : Gosub SETBOUT
When "RAZDUP"      : Gosub RAZDUP
When "RAZCRE"      : Gosub RAZCRE
When "FILTRE"      : Gosub FILTRE
When "INICRE_LIG"  : Gosub INILIG
When "INIMOD_LIG"  : Gosub INILIG
When "INIMOD"      : Gosub INIMOD
When "OUVRE"       : Gosub OUVRE
When "VERIF_CRE"   : Gosub VERIF    # mm 43344
When "VERIF_MOD"   : Gosub VERIF    # mm 43344
When "CREATION"    : Gosub CREATION
When "MODIF"       : Gosub MODIF
When "CHANGE"      : Call CHANGE_AXX ("HANDLING", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX

 When Default
Endcase
Return



#********************************************************************** APRES_CRE
$APRES_CRE

Call  SAVEHSR

Return

#********************************************************************** APRES_MOD
$APRES_MOD


Call  SUPPHSR

Call  SAVEHSR

Call  SAVEBOD

Return

#********************************************************************** SETBOUT
$SETBOUT

#--- activation desactivation des boutons
If GREP="C" | GREP="D" | [M:HSH0]HSH<> ""
   CHMEN += "F"   # v 140
Endif

Return

#********************************************************************** RAZCRE
$RAZCRE
[M:HSH1]CLECTNAUT = 0
Call RAZ_CLOB From ACLOB

#--- suppression icone texte an bas a droite de l ecran
 Call RESET_IMAGE (4) From GESECRAN   :

Return

#********************************************************************** RAZDUP
$RAZDUP

Local Integer WRET,I
Call RAZ_CLOB From ACLOB
Call DUP_CLOB("HSH",[M:HSH0]TEX,WRET) From TRTX3TEX
If WRET<1 Raz [M:HSH0]TEX : Endif
Return

#********************************************************************** INICRE
$INICRE

If [M:HSH0]TEX<>""
      Call CRE_CLOB([M:HSH0]TEX,GOK) From TRTX3TEX
      If GOK<1 Return Endif
      [F:HSH]TEX = [M:HSH0]TEX
Endif

#--- Tassement des avertissements
Gosub TASSEMENT

Return

#********************************************************************** VERIF
# 06.07 mm 43344 - Forcer la lecture d'un message avant de peser
$VERIF
If [M:HSH2]PCN(0) ="" & [M:HSH2]TXC(0)=""
    If [M:HSH1]OBL = 2
        GMESSAGE = mess(267,193,1)-mess(268,193,1)
        GERR = 2
       [M:HSH1]OBL =1 : Affzo [M:HSH1]OBL
    Endif
Endif
Return

#********************************************************************** AVANTBOUT
#    Avant l'execution des boutons et des menus
$AVANTBOUT
Return

#********************************************************************** STATUT
$STATUT
#-------------------------------------------------#
# gestion des textes                              #
#-------------------------------------------------#
Local Integer WRETOUR
Local Char    WNUMTEX(12)

If mkstat=4 & GREP=""
   #MAE, bg 50938
   #GREP="M" : REP="M"
   #Gosub SETBOUT From GOBJSUB
   Gosub ENTRE_MODIF From GOBJSUB
Endif
#---  activation icone texte en bas a droite de l ecran
If [M:HSH0]TEX <> "" & !GIMPORT & !GBROWS
   Call SET_IMAGE (4) From GESECRAN
Elsif !GIMPORT & !GBROWS
   Call RESET_IMAGE (4) From GESECRAN
Endif

Return

#********************************************************************** ABANDON
$ABANDON
Local Integer WRET

If GREP = "D"
      Call SUP_CLOB([M:HSH0]TEX,WRET) From TRTX3TEX
Endif
Call RAZ_CLOB From ACLOB
Return

#********************************************************************** ANNULE
$ANNULE
Local Integer WRET

#---  en cas d annulation de la fiche il faut aussi supprimer le texte si existant
Call SUP_CLOB([M:HSH0]TEX,WRET) From TRTX3TEX
Call RAZ_CLOB From ACLOB

Delete [HSR] Where [F:HSR]HSH = [M:HSH0]HSH
If fstat : GOK = 0 : Endif
#---Pour les libellés traduisibles
Delete [AXX] Where CODFIC="HANDLING" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#********************************************************************** LIENS
$LIENS
If [M:HSH1]PCK = 2 : Diszo [M:HSH1]CLECTNAUT
Else               : Actzo [M:HSH1]CLECTNAUT
Endif
#---  activation de l icone texte coin droit en bas
Call RAZ_CLOB From ACLOB

If [M:HSH0]TEX <> "" & !GIMPORT & !GBROWS
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT & !GBROWS
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

If dim([F:HSH]MANREDFLG) > 0
   If [M:HSH1]MANREDFLG = 0  : [M:HSH1]MANREDFLG = 1 : Endif
Endif

# 06.07 mm - Forcer la lecture d'une icône
If [M:HSH1]OBL = 0 : [M:HSH1]OBL =1 : Endif

Call  LOADHSR

Return


#********************************************************************** FILTRE
$FILTRE
Default File [HSH]

Return


#********************************************************************** INILIG
$INILIG
#Alimentation Fiche
[F:HSR]HSH = [F:HSH]HSH

Return

#********************************************************************** INIMOD
$INIMOD
#--- Tassement des avertissements
Gosub TASSEMENT

Return

#********************************************************************** INIMOD
$OUVRE
If clalev([F:CTN])  <= 0 : Local File CONTAINERS [CTN]  : Endif
If clalev([F:RSY])  <= 0 : Local File SENTENCES  [RSY]  : Endif
# mm 05.10 - % de tolérance
If clalev([F:BOH]) = 0 Local File BOM    [BOH] Endif
If clalev([F:BOD]) = 0 Local File BOMD   [BOD] Endif
If clalev([F:TBO]) = 0 Local File TABBOMALT   [TBO] Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF] Endif
Return




#********************************************************************** TASSEMENT
$TASSEMENT
#Tassement des Precautions
Local Integer I1
Local Integer I2
Local Integer I3
       For I1 = 0 To 7 Step 1
           If [F:HSH]PCN(I1) = ""
               I3 = I1 + 1
               For I2 = I3 To 7 Step 1
                   If [F:HSH]PCN(I2) <> ""
                                       [F:HSH]PCN(I1) = [F:HSH]PCN(I2)
                                       Raz  [F:HSH]PCN(I2)
                                       Break
                   Endif
               Next I2
           Endif
       Next I1

#Tassement des Toxicites
Local Integer I1
Local Integer I2
Local Integer I3
       For I1 = 0 To 3 Step 1
           If [F:HSH]TXC(I1) = ""
               I3 = I1 + 1
               For I2 = I3 To 3 Step 1
                   If [F:HSH]TXC(I2) <> ""
                                       [F:HSH]TXC(I1) = [F:HSH]TXC(I2)
                                       Raz  [F:HSH]TXC(I2)
                                       Break
                   Endif
               Next I2
           Endif
       Next I1


#Tassement des Phrases risques
Local Integer I1
Local Integer I2
Local Integer I3
       For I1 = 0 To 3 Step 1
           If [F:HSH]RSKRSY(I1) = ""
               I3 = I1 + 1
               For I2 = I3 To 3 Step 1
                   If [F:HSH]RSKRSY(I2) <> ""
                                       [F:HSH]RSKRSY(I1) = [F:HSH]RSKRSY(I2)
                                       Raz  [F:HSH]RSKRSY(I2)
                                       Break
                   Endif
               Next I2
           Endif
       Next I1

#Tassement des Phrases securites
Local Integer I1
Local Integer I2
Local Integer I3
       For I1 = 0 To 3 Step 1
           If [F:HSH]SAVRSY(I1) = ""
               I3 = I1 + 1
               For I2 = I3 To 3 Step 1
                   If [F:HSH]SAVRSY(I2) <> ""
                                       [F:HSH]SAVRSY(I1) = [F:HSH]SAVRSY(I2)
                                       Raz  [F:HSH]SAVRSY(I2)
                                       Break
                   Endif
               Next I2
           Endif
       Next I1

#Tassement des Phrases environnement
Local Integer I1
Local Integer I2
Local Integer I3
       For I1 = 0 To 3 Step 1
           If [F:HSH]ENMRSY(I1) = ""
               I3 = I1 + 1
               For I2 = I3 To 3 Step 1
                   If [F:HSH]ENMRSY(I2) <> ""
                                       [F:HSH]ENMRSY(I1) = [F:HSH]ENMRSY(I2)
                                       Raz  [F:HSH]ENMRSY(I2)
                                       Break
                   Endif
               Next I2
           Endif
       Next I1

Return


$CTRPHRASE
If VALEUR <> ""
# Lecture SENTENCES
# 101362 mm 09.2014
   Read [RSY]RSY0=VALEUR
   If fstat : GMESSAGE = mess(6,2324,1) : mkstat = 1 : Endif
   If [F:RSY]RSYTYP <> WTYP : GMESSAGE = mess(6,2324,1) : mkstat = 1 : Endif
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M]DESAXX,"HANDLING","DESAXX",[M]HSH,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HANDLING","SHOAXX",[M]HSH,"") From ATEXTRA

Return
#############################################################
$MODIF
Call MAJTEXTRA([M]DESAXX,"HANDLING","DESAXX",[M]HSH,"") From ATEXTRA
Call MAJTEXTRA([M]SHOAXX,"HANDLING","SHOAXX",[M]HSH,"") From ATEXTRA

Return
#############################################################



####################################################################
$AVANT_MODFIC
#------------------------------------------#
# Traitement avant modification            #
#------------------------------------------#
Local Integer WRET

# on a viré le texte
If [M:HSH0]TEX="" & [F:HSH]TEX <> ""
   Call SUP_CLOB([F:HSH]TEX,WRET) From TRTX3TEX
Endif
Return

#########################################################################
# Sous programme de Chargement du tableau des Affectations  HSR   HSH3
#########################################################################
Subprog LOADHSR

Raz [M:HSH3]WEIMAW
Raz [M:HSH3]WEU
Raz [M:HSH3]CTN
Raz [M:HSH3]LBEFMT
Local Integer I
I = 0

Filter [HSR] Where [F:HSR]HSH = [M:HSH0]HSH Order By [F:HSR]HSH Asc ; WEU Asc ; WEIMAW Desc ; CTN Asc

For [HSR]
    If I >= dim([M:HSH3]WEIMAW) - 1 : Break : Endif
    [M:HSH3]WEIMAW (I) = [F:HSR]WEIMAW
    [M:HSH3]WEU    (I) = [F:HSR]WEU
    [M:HSH3]CTN    (I) = [F:HSR]CTN
    [M:HSH3]LBEFMT (I) = [F:HSR]LBEFMT
    I += 1
Next
[M:HSH3]NBLIG = I
Filter [HSR]

Affzo [M:HSH3]

End


########################################################################
# Sous programme de mise a jour du tableau des Affectations  HSR   HSH3
########################################################################
Subprog SAVEHSR
Local Integer I
I = 0
For I = 0 To [M:HSH3]NBLIG - 1
    If [M:HSH3]WEU (I) <> ""

        Call DEBTRANS From GLOCK
        Trbegin [HSR]
        Readlock [HSR]HSR0 = [M:HSH0]HSH;[M:HSH3]WEU (I);[M:HSH3]WEIMAW (I);[M:HSH3]CTN (I)
        #Il s'agit d'un nouvel enregistrement
        If fstat
            [F:HSR]HSH    = [M:HSH0]HSH
            [F:HSR]WEU    = [M:HSH3]WEU    (I)
            [F:HSR]WEIMAW = [M:HSH3]WEIMAW (I)
            [F:HSR]LBEFMT = [M:HSH3]LBEFMT (I)
            [F:HSR]CTN    = [M:HSH3]CTN    (I)

             Write [HSR]
             If fstat
                 GMESSAGE = mess(100,141,1) #Erreur création
                 GERR = 1
                 Unlock [HSR]
                 Rollback
                 End
             Else
                Commit
                Unlock [HSR]
             Endif
       # Il s'agit d'une modification
       Else
            [F:HSR]HSH    = [M:HSH0]HSH
            [F:HSR]WEU    = [M:HSH3]WEU    (I)
            [F:HSR]WEIMAW = [M:HSH3]WEIMAW (I)
            [F:HSR]LBEFMT = [M:HSH3]LBEFMT (I)
            [F:HSR]CTN    = [M:HSH3]CTN    (I)

            Rewrite [HSR]
            If fstat
               GMESSAGE = mess(101,141,1) #Erreur modification
               GERR = 1
               Unlock [HSR]
               Rollback
               End
            Else
               Commit
               Unlock [HSR]
            Endif
        Endif
    Endif
Next
End

########################################################################
# Sous programme de mise a jour du % de tolérance au niveau de la nomenclature
########################################################################
Subprog SAVEBOD

# mm 05.10 - Récupération du nouveau % dans la nomenclature
For [F:BOH]BOH0 Where [F:BOH]ITMREF<>"" & [F:BOH]BOMALT<>0 & [F:BOH]BOMALTTYP=2
  For [F:BOD]BOD0 Where [F:BOD]ITMREF = [F:BOH]ITMREF & [F:BOD]BOMALT = [F:BOH]BOMALT
    If !find ([F:BOD]PKC,0,1,8,9)  & [F:BOD]LEVSET = 2  # composant pesé & niveau param. tolérance = fiche ISM
       #
       Read [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT
       If fstat : Raz [TBO] : Endif
       #
       Read [ITF]ITF0= [F:BOD]CPNITMREF;[F:TBO]FCY
       If !fstat
         If [F:ITF]ISM = [M:HSH0]HSH
           Call DEBTRANS From GLOCK
           Trbegin [BOD]
           [F:BOD]ITMTOLPOS  =  [M:HSH1]ITMTOL
           [F:BOD]ITMTOLNEG  =  [M:HSH1]ITMTOLNEG
           Rewrite [BOD]
           If fstat
              GMESSAGE = mess(101,141,1) #Erreur modification
              GERR = 1
              Rollback
              Break     # FQ 69909 Ctrl des sources avant End
           Else
              Commit
           Endif
         Endif
       Endif
    Endif
  Next
  If GERR=1 Break Endif # FQ 69909 Ctrl des sources Ligne ajoutée
Next
End

########################################################################
# Sous programme de suppresion des Affectations  HSR   HSH3
########################################################################
Subprog SUPPHSR
Call DEBTRANS From GLOCK
Lock [HSR]
  If fstat
                 GMESSAGE = mess(5,124,1) #Table non accessible
                 GERR = 1
  Endif

Trbegin [HSR]
Delete [HSR] Where [F:HSR]HSH = [M:HSH0]HSH
If fstat
    Rollback
    End
Endif
Commit
End


####################################################################### Actions Champs #
#Controle redondance pour : Precautions
Subprog C_PCN(VALEUR)

Variable Char    VALEUR()

Local Integer I
If VALEUR <> ""
   For I = 0 To 7 Step 1
     If I <> indice
       If [M:HSH2]PCN (I) = VALEUR : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif
 Next I
Endif
End


#Controle redondance pour : Toxicites

Subprog C_TXC(VALEUR)
Variable Char    VALEUR()

Local Integer I
If VALEUR <> ""
   For I = 0 To 3 Step 1
     If I <> indice
       If [M:HSH2]TXC (I) = VALEUR : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif
   Next I
Endif
End



Subprog C_RSKRSY(VALEUR)
Variable Char    VALEUR()
Local    Integer    WTYP   # FQ 69909 Ctrl des sources avant Variable

#Controle existence et coherence
WTYP = 1
Gosub CTRPHRASE

#Controle redondance pour : Phrases risques
Local Integer I
If VALEUR <> ""
   For I = 0 To 3 Step 1
     If I <> indice
       If [M:HSH2]RSKRSY (I) = VALEUR : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif
   Next I
Endif
End


Subprog C_SAVRSY(VALEUR)
Variable Char    VALEUR()
Local    Integer    WTYP   # FQ 69909 Ctrl des sources avant Variable


#Controle existence et coherence
WTYP = 2
Gosub CTRPHRASE

#Controle redondance pour :  Phrases securites

Local Integer I
If VALEUR <> ""
   For I = 0 To 3 Step 1
     If I <> indice
       If [M:HSH2]SAVRSY (I) = VALEUR : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif
   Next I
Endif
End


Subprog C_ENMRSY(VALEUR)
Variable Char    VALEUR()
Local    Integer    WTYP   # FQ 69909 Ctrl des sources avant Variable


#Controle existence et coherence
WTYP = 3
Gosub CTRPHRASE

#Controle redondance pour : Phrases environnement


Local Integer I
If VALEUR <> ""
   For I = 0 To 3 Step 1
     If I <> indice
       If [M:HSH2]ENMRSY (I) = VALEUR : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif
   Next I
Endif
End



########################################
Subprog C_NBLIG
Local Integer NUMLIGNE
NUMLIGNE = 0

#Effacement d'une seule ligne
If status = 65
    Read [HSR]HSR0 = [M:HSH0]HSH;[M:HSH3]WEU (nolign - 1);[M:HSH3]WEIMAW (nolign - 1)

    If fstat = 0
        Call DEBTRANS From GLOCK
        Trbegin [HSR]
        Delete [HSR] Curr
        If fstat
            Rollback
            Affzo [M:HSH3]
            End
        Endif
        Commit
    Endif
Endif

#Effacement d'un groupe de lignes
If status = 68 | status = 83
For NUMLIGNE = nolign - 1 To nolign1 - 1

    Read [HSR]HSR0 = [M:HSH0]HSH;[M:HSH3]WEU (NUMLIGNE);[M:HSH3]WEIMAW (NUMLIGNE)

    If fstat = 0
        Call DEBTRANS From GLOCK
        Trbegin [HSR]
        Delete  [HSR] Curr
        If fstat
            Rollback
            Affzo [M:HSH3]
            Break
        Endif
        Commit
    Endif
Next
Endif
End

########################################
Subprog C_PCK(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 & [M:HSH1]WEIMOD = 2
    GMESSAGE = mess(34,2324,1)
    mkstat = 1
    End
Endif
Local Integer I
I = 0

For I = 0 To [M:HSH3]NBLIG - 1
    If [M:HSH3]WEU (I) <> ""

       Read [CTN]CTN0 = [M:HSH3]CTN    (I)
       If fstat Raz[F:CTN] : Endif
       If VALEUR <> 3
         If VALEUR <>  [F:CTN]CTNTYP : GMESSAGE = mess(5,2324,1) : mkstat = 1 : Break : Endif
       Endif
    Endif
Next I

End

########################################
Subprog C_CTN(VALEUR)
Variable Char    VALEUR()
Read [CTN]CTN0 = VALEUR
If fstat Raz[F:CTN] : Endif
#dbgmode(1)=1


If [M:HSH1]PCK <> 3
   If [M:HSH1]PCK <>  [F:CTN]CTNTYP : GMESSAGE = mess(5,2324,1) : mkstat = 1 : Endif
Endif
End


########################################

########################################
Subprog C_WEIMOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 & [M:HSH1]PCK = 2
    GMESSAGE = mess(34,2324,1)
    mkstat = 1
    End
Endif
End

