######################################################################################################
# Project       : Swiss Localization
# File          : SUBBICSWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 09.11.15
######################################################################################################
# Module        : Customer BP invoices
# Description   : Swiss specific initializations for customer BP invoices
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
 # 04.02.16 |Bader |U10    |CALC_BVRFIELDS: don't calculate fields in import mode (GIMPORT)
######################################################################################################


######################################################################################################
Subprog SHOW_HIDE_BVRFIELDS(FCY,INVTYP,PTE,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char CUR
Local Integer SHOW

Gosub CHECK_SHOW From SUBSIHSWI
If SHOW
  Chgfmt [M:BIC1]BVRREFNUM With "K:27X"
  Chgfmt [M:BIC1]PAYBAN With "K:5c"
Else
  Raz [M:BIC1]BVRREFNUM               # clear field
  Raz [M:BIC1]PAYBAN                  # clear field
  Chgfmt [M:BIC1]BVRREFNUM With "-K:27X"
  Chgfmt [M:BIC1]PAYBAN With "-K:5c"
Endif
If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
End


######################################################################################################
Subprog CALC_PAYBAN(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

Gosub CHECK_SHOW From SUBSIHSWI
If SHOW
  [M:BIC1]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
  # if paying bank is not found, display an error message
  If [M:BIC1]PAYBAN = ""
     GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
     mkstat = 2 : End
  Endif
  Chgfmt [M:BIC1]BVRREFNUM With "K:27X"
  Chgfmt [M:BIC1]PAYBAN With "K:5c"
Else
  Raz [M:BIC1]BVRREFNUM               # clear field
  Raz [M:BIC1]PAYBAN                  # clear field
  Chgfmt [M:BIC1]BVRREFNUM With "-K:27X"
  Chgfmt [M:BIC1]PAYBAN With "-K:5c"
Endif
If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
End


######################################################################################################
Subprog CLEAR_BVRFIELDS()
If dim([M:BIC1]BVRREFNUM) > 0
   Raz [M:BIC1]BVRREFNUM              # clear field
   If !GIMPORT Affzo [M:BIC1]BVRREFNUM : Endif
Endif
If dim([M:BIC1]PAYBAN) > 0
   Raz [M:BIC1]PAYBAN                 # clear field
   If !GIMPORT Affzo [M:BIC1]PAYBAN : Endif
Endif
End



######################################################################################################
Subprog CALC_BVRFIELDS(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR

If !GIMPORT                      # calculate ISR number and paying bank only if not in import
   Call CALC_BVRFIELDS(FCY, INVTYP, PTE, BPRPAY,CUR) From SUBSIHSWI
   [M:BIC1]PAYBAN = [F:SIH]PAYBAN
   [M:BIC1]BVRREFNUM  = [F:SIH]BVRREFNUM
   Affzo [M:BIC1]PAYBAN
   Affzo [M:BIC1]BVRREFNUM
Endif
End


######################################################################################################
# Recurring invoices:
# Same as CALC_BVRFIELDS but the invoice is in [F:TSIH] not in [F:SIH].
# Therefore CALC_BVRFIELDS From SUBSIHSWI can't be used
######################################################################################################
Subprog CALC_BVRFIELDS_BATCH(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

    Gosub CHECK_SHOW From SUBSIHSWI
    If SHOW
       If [F:TSIH]AMTATI = 0 : SHOW = 0 : Endif  # no paying bank and ISR reference number if invoice amount = 0
    Endif
    GPOINT = "CALCBVRFIELDS" : Gosub ENTREE From EXEFNC                  # entry point to overwrite conditions for SHOW

    If SHOW
      If [F:TSIH]PAYBAN = ""                # paying bank not yet entered -> calculate it
         [F:TSIH]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
         # if paying bank is not found, display an error message
         If [F:TSIH]PAYBAN = ""
            GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
            GOK = 0 : GERR = 1 : End
         Endif
      Endif
      If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
      Call CONTROL_PAYBAN([F:CPY]CPY,FCY,[F:TSIH]PAYBAN) From SUBSIHSWI  # if paying bank determined -> do additional checks
      If mkstat = 2 : GOK = 0 : GERR = 1 : End : Endif

      [F:TSIH]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:TSIH]ACCDAT,[F:TSIH]NUM)
    Else
      Raz [F:TSIH]BVRREFNUM               # clear field
      Raz [F:TSIH]PAYBAN                  # clear field
    Endif
End


######################################################################################################
# Fixed Assets:
# Same as CALC_BVRFIELDS but the invoice is in [F:HEA] not in [F:SIH].
# Therefore CALC_BVRFIELDS From SUBSIHSWI can't be used
######################################################################################################
Subprog CALC_BVRFIELDS_FA(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

    Gosub CHECK_SHOW From SUBSIHSWI
    If SHOW
       If [F:HEA]AMTATI = 0 : SHOW = 0 : Endif    # no paying bank and ISR reference number if invoice amount = 0
    Endif
    GPOINT = "CALCBVRFIELDS" : Gosub ENTREE From EXEFNC                  # entry point to overwrite conditions for SHOW

    If SHOW
      If [F:HEA]PAYBAN = ""                # paying bank not yet entered -> calculate it
         [F:HEA]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
         # if paying bank is not found, display an error message
         If [F:HEA]PAYBAN = ""
            GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
            GOK = 0 : GERR = 1 : End
         Endif
      Endif
      If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
      Call CONTROL_PAYBAN([F:CPY]CPY,FCY,[F:HEA]PAYBAN) From SUBSIHSWI  # if paying bank determined -> do additional checks
      If mkstat = 2 : GOK = 0 : GERR = 1 : End : Endif

      [F:HEA]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:HEA]ACCDAT,[F:HEA]NUM)
    Else
      Raz [F:HEA]BVRREFNUM               # clear field
      Raz [F:HEA]PAYBAN                  # clear field
    Endif
End

