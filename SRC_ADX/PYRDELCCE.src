#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("CYM",GBIDC1,GBIDC2) From GOBJET
End

###########################################################################
## Effacement d'une pyramide et de ses groupes
###########################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When Default
Endcase
Return

$INIT
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:DIE])=0 : Local File GDIE       [DIE] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CYK])=0 : Local File GCCEPYMLIK [CYK] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
TMP = 1
Return

$INIT_DIA
[M]DIE    = PARAM(1)
[M]PYM    = PARAM(2)
Return

$EXEC
OK = 2
Call AVERTIR(mess(70,103,1),OK) From GESECRAN
If OK=2
 Call EFFACE([M]PYM,1)
Endif
Return

Subprog EFFACE(PYRAMIDE,TETE)
Value Char    PYRAMIDE
Value Integer TETE
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CYK])=0 : Local File GCCEPYMLIK [CYK] : Endif
If clalev([F:CYP])=0 : Local File GCCEPYMPRT [CYP] : Endif
Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [CYK],[CYP],[CRY],[CYM]
 Delete [CYK] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GCCEPYMLIK"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [CYP] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GCCEPYMPRT"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [CRY] Where PYM=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$GCCEGRUPYM"-PYRAMIDE : Goto ROLL_TR1
 Endif
 Delete [AXX] Where CODFIC="GCCEGRUPYM" & IDENT1=PYRAMIDE
 If fstat=1
  GOK = -1 : GLOCK = "$ATEXTRA"-"GCCEGRUPYM"-PYRAMIDE : Goto ROLL_TR1
 Endif
 If TETE
  Delete [CYM] Where PYM=PYRAMIDE
  If fstat=1
   GOK = -1 : GLOCK = "$GCCEPYM"-PYRAMIDE : Goto ROLL_TR1
  Endif
  Delete [AXX] Where CODFIC="GCCEPYM" & IDENT1=PYRAMIDE
  If fstat=1
   GOK = -1 : GLOCK = "$ATEXTRA"-"GCCEPYM"-PYRAMIDE : Goto ROLL_TR1
  Endif
 Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

######################################################################################
## Ecran PYRDEL
######################################################################################
Subprog C_PYM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("CYM",VALEUR,"") From CONTOBJ
If fstat 
 GMESSAGE = mess(96,102,1) : # Pyramide pas exitent
 mkstat = 2 : End
Elsif [F:CYM]DIE<>[M]DIE
 GMESSAGE = mess(93,102,1)-"("+[F:CYM]DIE+")" : # Plan de compte incompatible
 mkstat = 2 : End
Endif
End
