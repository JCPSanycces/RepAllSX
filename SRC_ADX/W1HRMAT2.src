If mkstat : GERR = 1 : GZONE = "CRYBRN" : GZNUM = 235 : Endif
If !mkstat
 ## Action INIPAYS
 Call INIPAYS(VALEUR,[M]CRYNAMBRN) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "CRYBRN" : GZNUM = 235 : Endif
 If !mkstat
  ## Action STD
  Call C_CRYBRN(VALEUR) From SUBEML2
  If mkstat : GERR = 1 : GZONE = "CRYBRN" : GZNUM = 235 : Endif
 Endif
Endif
