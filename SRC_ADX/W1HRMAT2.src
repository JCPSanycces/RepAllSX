$ON_SEX
Onevent BEFORE_INPUT Call AS_SEX(zc) From W1HRMAT2
Onevent INIT_AREA Call D_SEX(zc) From W1HRMAT2
Onevent CONTROL Call C_SEX(zc) From W1HRMAT2
Return

Subprog D_SEX(VALEUR)
Variable Integer VALEUR
If varinit([M]SEX,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SEX(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10314) From COMBOS
## Action STD
Call AS_SEX(VALEUR) From SUBEML2
If mkstat=2
 [M]SEX(INDIC) = VALEUR
 Affzo SEX(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10314,1))))
Endif
If !mkstat
 Discombo 0 From SEX(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From SEX(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_SEX(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_NTT
Onevent CONTROL Call C_NTT(zc) From W1HRMAT2
Onevent AFTER_CHANGE Gosub AMM_NTT From W1HRMAT2
Onevent BEFORE_INPUT Call AS_NTT(zc) From W1HRMAT2
Onevent INIT_AREA Call D_NTT(zc) From W1HRMAT2
Return

Subprog D_NTT(VALEUR)
Variable Char    VALEUR()
If varinit([M]NTT,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_NTT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NTT(zc) From W1HRMAT2
Onkey   2 Titled GBOUTS Call S_NTT(zc) From W1HRMAT2
Onkey 144 Titled GBOUTP Call P_NTT(zc) From W1HRMAT2
Onkey 146 Titled GBOUTA Call SA_NTT(zc) From W1HRMAT2
Gosub _AFF
End

Subprog C_NTT(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
If !mkstat
 ## Action INIPAYS
 Call INIPAYS(VALEUR,[M]NTTNAM) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
 If !mkstat
  ## Action STD
  Call C_NTT(VALEUR) From SUBEML2
  If mkstat : GERR = 1 : GZONE = "NTT" : GZNUM = 45802 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_NTT
Call AM_NTT(zc)
If !mkstat & GOBJET
 zoncou = "NTT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NTT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_NTT(VALEUR) From SUBEML2
