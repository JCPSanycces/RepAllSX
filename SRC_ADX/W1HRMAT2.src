Subprog S_CTYBRN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action VILSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "VILSEL"
 PARMSK(1) = [M]CRYBRN
 PARMSK(2) = GCTYBRNSEE
 Call S_TAB_CHAR(VALEUR,PARMSK,"","VILSEL","") From GACTION
 GCTYBRNSEE = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CTYBRN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CODINSEE
 Call CODINSEE("POS","",[M]CRYBRN,VALEUR,GCTYBRNSEE) From TRTINSEE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CTYBRNSEE
Onevent BEFORE_INPUT Call AS_CTYBRNSEE(zc) From W1HRMAT2
Return

Subprog AS_CTYBRNSEE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44918,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CTYBRNSEE(zc) From W1HRMAT2
Onkey   2 Titled GBOUTS Call S_CTYBRNSEE(zc) From W1HRMAT2
Gosub _AFF
End

Subprog S_CTYBRNSEE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELINSEE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELINSEE"
 PARMSK(1) = [M]CTYBRN
 PARMSK(2) = [M]CRYBRN
 PARMSK(3) = [M]DEPBRN
 PARMSK(4) = VALEUR
 Call S_TAB_CHAR(VALEUR,PARMSK,"","TRTINSEE","") From GACTION
 [M]CTYBRN = PARMSK(1)
 [M]DEPBRN = PARMSK(3)
 VALEUR = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFFZO
 If !GIMPORT : Affzo : Endif
Endif
Gosub _AFF
End

Subprog B1_CTYBRNSEE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CODINSEE
 Call CODINSEE("POS",[M]DEPBRN,[M]CRYBRN,[M]CTYBRN,VALEUR) From TRTINSEE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

