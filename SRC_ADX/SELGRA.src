################################################################################
Call OBJET("GRA",GBIDC1,GBIDC2) From GOBJET
End
#-------------------------------------------------------------------------------
$ACTION
    Case ACTION
     When "SEL_TABLE" : Gosub SEL_TABLE
     When Default
    Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE
  Case TABLE
    When "SELGRA"    : Gosub SELGRA
  Endcase
Return
#-------------------------------------------------------------------------------
$SELGRA
  Local Char CODFIC    : CODFIC = "GRANTS"
  Local Char LCPY, LFCY, LGRAREF

  Default File [GRA]
  LCPY = PARAM(1)
  LFCY = PARAM(2)
  GRAREF = PARAM(3)
  CRITERE = "CPY=LCPY and FCY=LFCY and GRAREF=LGRAREF" 
 # CRITERE(1) = "[GRA]CPY = [M:DIA]CPY & [GRA]FCY = [M:DIA]FCY"
  ORDRE = "GRAREF"

Return
#-------------------------------------------------------------------------------





