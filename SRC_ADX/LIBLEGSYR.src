#<AdxTL>@(#)3.0.0.0 $Revision$
#--------------------------------------------------------------------------------------
#lit la table TABVACBPR en fonction de la législation passée en paramètre
#La table TABVACBPR doit être ouverte par l'appelant
#--------------------------------------------------------------------------------------
Subprog LEC_TVB_LEG(LEG,TVB,GRET)
Value Char  LEG
Value Char  TVB
Variable Integer GRET

fstat = 0
GRET=0
Gosub SETLEG

If [F:TVB]VACBPR<>TVB | [F:TVB]LEG<>LEG
  Read [TVB]TVB0=TVB;LEG
  If fstat
   Read [TVB]TVB0=TVB;""
 Endif
Endif
GRET=fstat
End

#-----------------------------------------------------------------------------------------------#
# Issue 71937 - 2012-03-27 by SR
#lit la table TABVAT en fonction de la législation passée en paramètre
#La table TABVAT doit être ouverte par l'appelant
#-----------------------------------------------------------------------------------------------#
Subprog LEC_TVT_LEG(LEG,TVT,GRET)
Value Char  LEG
Value Char  TVT
Variable Integer GRET

fstat = 0
GRET=0
Gosub SETLEG

If [F:TVT]VAT<>TVT | [F:TVT]LEG<>LEG
  Read [TVT]TVT0=TVT;LEG
 If fstat
   Read [TVT]TVT0=TVT;""
 Endif
Endif
GRET=fstat
End

#-----------------------------------------------------------------------------------------------#
# Set the legislation
#-----------------------------------------------------------------------------------------------#
$SETLEG
Local Char    DOSLEG(GLONADI)(1..20), PAYS(30)
Local Integer NBLEG
Call SETLEG("",DOSLEG,NBLEG) From DOSCONT
If NBLEG=0
 PAYS = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,GACTX.AFOLDER,"CRYDEF")
 Case PAYS
  When "GB"  : DOSLEG(1) = "BRI" : NBLEG = 1
  When "FR"  : DOSLEG(1) = "FRA" : NBLEG = 1
  When "IT"  : DOSLEG(1) = "ITA" : NBLEG = 1
  When "PT"  : DOSLEG(1) = "POR" : NBLEG = 1
  When "ES"  : DOSLEG(1) = "SPA" : NBLEG = 1
  When "US"  : DOSLEG(1) = "USA" : NBLEG = 1
  When "DE"  : DOSLEG(1) = "GER" : NBLEG = 1
  When "CN"  : DOSLEG(1) = "CHI" : NBLEG = 1
 Endcase
Endif
If NBLEG=1 : LEG = DOSLEG(1) : Endif
Return

