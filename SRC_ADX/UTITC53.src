#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################################
# UTITC53                                                  Module Tronc commun                        #
# Initialisation de OMMRPT.LAN="FRA"                                                                   #
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
# Issue 108760 - 2015-08-07 by MAE :
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
If APPLI <> ""
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 # Issue 108760 - 2015-08-07 by MAE :
 #Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif
 If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITC53: Language and description initialisation") From LECFIC

 Call MAJ_UTITC53(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

########################################################################
Subprog MAJ_UTITC53(APPLI)
Value Char APPLI

  If filinfo(filpath("FIL", "OMMRPT", "fde", APPLI), 0) <= 0 Then
    # Si la table n'est pas là, on ne fait rien
    End
  Endif
  #
  Call ECR_TRACE("UUTITC53: Process Start on: "+APPLI,0) From GESECRAN
  Local File =APPLI+".OMMRPT" [OMR]
  Local File =APPLI+".ATEXTRA" [AXX]
  Local File ADOSSIER [ADS]
  #
  Read [ADS]DOSSIER=[L]APPLI
  #
  If type([F:OMR]LAN) >= 0 Then
    Trbegin [OMR]
    For [F:OMR] Where [F:OMR]LAN = "" or [F:OMR]MAGTPLRPT = ""
      # ---------------
      If [F:OMR]LAN = "" Then
        [F:OMR]LAN = [F:ADS]LANDEF
      Endif
      [F:OMR]MAGTPLRPT = [F:OMR]MAGTPL
      # ---------------
      Rewrite [OMR]Curr
      If fstat Then
        GOK = 0 : Call ECR_TRACE(mess(27,125,1) - [F:OMR]MAGTPL, -1) From GESECRAN : Break
      Endif
      # ---------------
      Call MAJTEXTRA(left$([F:OMR]MAGTPL,GLONAX1), "OMMRPT", "OMRSHOAX1", [F:OMR]LAN, [F:OMR]MAGTPL) From ATEXTRA
      If GOK < 1 Then
        Call ECR_TRACE("File ATEXTRA OMMRPT-OMRSHOAX1" - [F:OMR]LAN-"/"-[F:OMR]MAGTPL + ",Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        Break
      Endif
      # ---------------
      Call MAJTEXTRA(left$([F:OMR]MAGTPL,GLONAX3), "OMMRPT", "OMRDESAX3", [F:OMR]LAN, [F:OMR]MAGTPL) From ATEXTRA
      If GOK < 1 Then
        Call ECR_TRACE("File ATEXTRA OMMRPT-OMRDESAX3" - [F:OMR]LAN-"/"-[F:OMR]MAGTPL + ",Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        Break
      Endif
      # ---------------
    Next
    If GOK = 0 Then
      Goto AB_UUTITC53
    Endif
    Commit
  Endif
  Call ECR_TRACE("UUTITC53: Process End on: "+APPLI,0) From GESECRAN
End

$AB_UUTITC53
  Rollback
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If filinfo(filpath("FIL","OMMRPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"OMMRPT") : End : Endif
  # End MAE 108760
  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  Call MAJ_UTITC53(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
If APPLI=GDOSX3
     End
Endif


  # test de présence du module Tiers
  If [F:ADS]MODULE(2)<>2 : End : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If filinfo(filpath("FIL","OMMRPT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"OMMRPT") : End : Endif
  Call MAJ_UTITC53(APPLI)
End

