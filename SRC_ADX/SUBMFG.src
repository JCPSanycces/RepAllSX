End


########################################
Subprog AV_AVAOFS(VALEUR)
Variable Char    VALEUR()
Local    Decimal XLTI, WRMD
Local    Integer ILTI, WLTI, WMFGLTI, WQUALTI
Local    Char    WART(20)
# recherche article avec délai le + long
Call RECH_ART_L(WLTI, WART) From SUBMFGB
WMFGLTI = WLTI
# relecture article au cas ou ...
If [F:ITF]ITMREF<>WART
    Read [ITF]ITF0=WART;[M:MFG0]MFGFCY
    If fstat : End : Endif
Endif
XLTI    = [F:ITF]QUALTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WQUALTI = ILTI
If WQUALTI = 0
    VALEUR = num$(WMFGLTI)
Else
    VALEUR = num$(WMFGLTI)-"(+"+num$(WQUALTI)+")"
Endif
End

