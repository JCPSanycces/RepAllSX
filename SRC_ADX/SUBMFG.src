######################################################################################

$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
Call INIT_CCE(VALEUR,AXE,"MFI","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date du jour au lieu de [0/0/0]
Local Date WDATE : WDATE = date$
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return

######################################################################################
# pour la navigation vers le plan d'affectation
$MEM_VCR
If find(GREP,"C","D")
    If dim(GVCR) > 0 : # If dim(GVCR) : # Issue 121512 GH 15/02/2017 - Wrong test of dim
        Raz GVCR, GLIN, GSEQ
    Endif
    Return
Endif
If dim(GVCR) < 0
    Global Char    GVCR
    Global Integer GLIN
    Global Integer GSEQ
Endif

GVCR = [M:MFG0]MFGNUM
GLIN = [M:MFG1]MFGLIN(nolign-1)
GSEQ = 0
Return

######################################################################################
## 107513 - Versioning
######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
    Call AS_ECCVALMAJ(VALEUR) From SUBMFGECC
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Call C_ECCVALMAJ(VALEUR) From SUBMFGECC
If mkstat : End : Endif

If VALEUR<>[M:MFG1]ECCVALMAJ(nolign-1) & [M:MFG1]NBLIG>=nolign
    GMODIF=3
Endif

# Issue 110957 - 2015-09-17 by CCC
If !mkstat & dim([M:MFG1]CRID)>0 & func ECCLIB.NBRCPN([M:MFG1]ITMREF(nolign-1))=1
    [M:MFG1]CRID(nolign-1) = func TRTX3FNC.CCMID([M:MFG1]ITMREF(nolign-1),VALEUR,"")
    Affzo [M:MFG1]CRID(nolign-1)
    If dim([M:MFG1]CRFLG)>0
        [M:MFG1]CRFLG(nolign-1) = string$([M:MFG1]CRID(nolign-1)<>"","151")
        Affzo [M:MFG1]CRFLG(nolign-1)
    Endif
Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
    Call AS_ECCVALMIN(VALEUR) From SUBMFGECC
End

######################################################################################
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
Call C_ECCVALMIN(VALEUR) From SUBMFGECC
If mkstat : End : Endif

If VALEUR<>[M:MFG1]ECCVALMIN(nolign-1) & [M:MFG1]NBLIG>=nolign
    GMODIF=3
Endif

# Issue 110957 - 2015-09-17 by CCC
If !mkstat & dim([M:MFG1]CRID)>0
    [M:MFG1]CRID(nolign-1) = func TRTX3FNC.CCMID([M:MFG1]ITMREF(nolign-1),[M:MFG1]ECCVALMAJ(nolign-1),VALEUR)
    Affzo [M:MFG1]CRID(nolign-1)
    If dim([M:MFG1]CRFLG)>0
        [M:MFG1]CRFLG(nolign-1) = string$([M:MFG1]CRID(nolign-1)<>"","151")
        Affzo [M:MFG1]CRFLG(nolign-1)
    Endif
Endif
End

######################################################################################
## Section automatically added (screen MFG1) 12/16/2015 18:51:56 (CCC)
######################################################################################

Subprog C_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
# Issue X3-55362 - 2017-09-15 by JUSYN : audit for operations exists ?
Local Integer WAUDIT
# End issue X3-55362

Call CTRROUECC([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,"MFG1","ROUECCMAJ",VALEUR,[M:MFG1]ROUECCMIN,[M:MFG1]STRDAT,LRET,GMESSAGE) From RVMLIB
If find(LRET,1,4)
    mkstat=2
    End
Endif

# If the version is available we can load operations
If VALEUR <> [M:MFG1]ROUECCMAJ  : GROUTING = 1 : Endif
# Issue X3-55362 - 2017-09-20 by JUSYN : routing reload if routing selected from selection list and only minor version has changed
If func RVMLIB.NBRCPNROU([M:MFG1]ROUNUM)=1 | (func RVMLIB.NBRCPNROU([M:MFG1]ROUNUM)=2 & GROUTING=1)
# End issue X3-55362
    # Issue X3-55362 - 2017-09-18 by JUSYN : Display question to do reload or not if audit records for operations exist. Route has to be versioned.
    If GMFGREV = 2 & GROUTING = 1
        WAUDIT = 0
        WAUDIT = func RVMLIB.CHECKWOOPEAUDIT()
        If WAUDIT = 1
            Call MESSAGE(mess(412,193,1)) From GESECRAN
        Endif
    Endif
    # End issue X3-55362
    Call HIGHLIGHT("MFG1",LRET) From RVMLIB
    Local Char WVERSION(GLONICVVAL)
    WVERSION=[M:MFG1]ROUECCMAJ : [M:MFG1]ROUECCMAJ=VALEUR
    Gosub LOAROH
    [M:MFG1]ROUECCMAJ=WVERSION
Endif
End

######################################################################################
Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
# Issue X3-55362 - 2017-09-15 by JUSYN : audit for operations exists ?
Local Integer WAUDIT
# End issue X3-55362

Call CTRROUECC([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,"MFG1","ROUECCMIN",[M:MFG1]ROUECCMAJ,VALEUR,[M:MFG1]STRDAT,LRET,GMESSAGE) From RVMLIB
If find(LRET,1,4)
    mkstat=2
    End
Endif

# If the version is available we can load operations
If VALEUR <> [M:MFG1]ROUECCMIN  : GROUTING = 1 : Endif
If func RVMLIB.NBRCPNROU([M:MFG1]ROUNUM)=2
    # Issue X3-55362 - 2017-09-18 by JUSYN : Display info message if audit records for operations exist. Route has to be versioned.
    If dim([M:MFG1]ROUECCMAJ) > 0
        If GMFGREV = 2 & GROUTING = 1
            WAUDIT = 0
            WAUDIT = func RVMLIB.CHECKWOOPEAUDIT()
            If WAUDIT = 1
                Call MESSAGE(mess(412,193,1)) From GESECRAN
            Endif
        Endif
    Endif
    # End issue X3-55362
    Call HIGHLIGHT("MFG1",LRET) From RVMLIB
    Local Char WVERSION(GLONICVVAL)
    WVERSION=[M:MFG1]ROUECCMIN : [M:MFG1]ROUECCMIN=VALEUR
    Gosub LOAROH
    [M:MFG1]ROUECCMIN=WVERSION
Endif
End

######################################################################################
$LOAROH
If !find([M:MFG0]MFGMOD,1,3) : Return : Endif
If ([M:MFG3]NBLIG = 0) | (GROUTING = 1)
    Call UPDOPE(2,1,[M:MFG1]ROUALT) From MFGLIBO
    GROUTING = 0
Endif
[M:MFG1]WORTYP = [F:ROH]WORTYP
If [M:MFG0]MFGTEX = "" : [M:MFG0]MFGTEX = [F:ROH]TEXNUM : Endif    # 79913
Return

######################################################################################
  # Issue X3-48941 - display warning message if version changes and there is an audit
######################################################################################
## Section automatically added (screen MFG1) 08/11/2017 11:35:35 (BAKHA)
######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Integer WAUDIT : WAUDIT=0      # Issue X3-48941
If dim([M:MFG1]ECCVALMAJ)>0 # Issue X3-55832
  If (GMFGREV = 2 and [M:MFG1]ITMTYP(nolign-1)=1)
    # Issue X3-48941 - display warning message if there is audit
    WAUDIT = func ECCLIB.CHECKWOAUDIT()
    If (WAUDIT = 1)
      Call MESSAGE(mess(404,193,1)) From GESECRAN
    Endif
  Endif
Endif # Issue X3-55832
End

# End issue 48941
######################################################################################

