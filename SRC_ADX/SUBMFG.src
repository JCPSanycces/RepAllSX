########################################
#**----------------------------------------------------------------<br/>
#* INIROU : Initialize routing number + code + version
#**<br/>----------------------------------------------------------------
#*!
Subprog INIROU()
Local Char    WFCY(GLONFCY)
Local Integer WALT
Local Date    WDAT
Local Integer WMSG
Local Integer I
Local Integer TABTBO(3)

# Get the routing number in the product-site
If [F:ITF]ITMREF<>[M:MFG1]ITMREF(0) | [F:ITF]STOFCY<>[M:MFG0]MFGFCY
    Read [ITF]ITF0=[M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
    If fstat : End : Endif
Endif
If [M:MFG1]ROUNUM=""
    If [F:ITF]MFGROU=""
        [M:MFG1]ROUNUM=[M:MFG1]ITMREF(0)
    Else
        [M:MFG1]ROUNUM=[F:ITF]MFGROU
    Endif
Endif
#
WDAT=[M:MFG1]STRDAT
WMSG=0
WFCY=[M:MFG0]MFGFCY

# Issue 111414 - 2015-12-16 by CCC : initialize version

# If a version of route exists then it must be used
WALT = func RVMLIB.GETRVMALT([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,WDAT)
If WALT
    Read [ROH]ROH0=[M:MFG1]ROUNUM;WALT;[M:MFG0]MFGFCY
    If !fstat
        Gosub CTL_ROUALT
    Endif
Else
    If dim([M:MFG1]ROUECCMAJ)>0
        Effzo  [M:MFG1]ROUECCMAJ,ROUECCMIN
    Endif
    # Read the routing corresponding to the default routing code
    If [F:ITF]MFGROUALT <> 0
        Read [F:ROH]ROH0=[M:MFG1]ROUNUM;[F:ITF]MFGROUALT;[M:MFG0]MFGFCY
        If !fstat
            Gosub CTL_ROUALT
        Endif
    Endif
    If !WALT
        # If the default routing code is not good we look for another one
        For [ROH] Where [F:ROH]ITMREF=[M:MFG1]ROUNUM & [F:ROH]FCY = [M:MFG0]MFGFCY
            Gosub CTL_ROUALT
            If WALT : Break : Endif
        Next
    Endif
Endif

If dim([M:MFG1]ROUECCMAJ)>0 & [M:MFG1]ROUALT<>0
    # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - block change of routing
    If ([M:MFG1]SCDFLG=4 | [M:MFG1]MFGTRKFLG = 2) & func AFNC.ACTIV("POPS")
        Diszo [M:MFG1]25
    Else
        Call RVMAFF([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,[M:MFG1]ROUALT,"MFG1") From RVMLIB
    Endif
    If !GIMPORT
        Affzo [M:MFG1]25
        Call CTRROUECC([M:MFG1]ROUNUM,[M:MFG0]MFGFCY,"MFG1","ROUECCMIN",[M:MFG1]ROUECCMAJ,[M:MFG1]ROUECCMIN,[M:MFG1]STRDAT,GERR,GMESSAGE) From RVMLIB
        Call HIGHLIGHT("MFG1",GERR) From RVMLIB
        Raz GMESSAGE, GERR
    Endif
Endif

End

########################################
# Check if the routing code is suitable to BOM code
$CTL_ROUALT
Read [TRO]TRO0=[F:ROH]ROUALT
If !fstat
    Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MFG1]MFGEXTQTY,[M:MFG1]MFGSTU,WMSG) From MFGLIB
    If WALT <> 0
        # 18981 MM 08.03
        Raz TABTBO,I
        # Contrôle de cohérence de l'alternative de nomenclature
        TABTBO(0)=[F:TRO]BOMALT1
        TABTBO(1)=[F:TRO]BOMALT2
        TABTBO(2)=[F:TRO]BOMALT3
        For I = 0 To [M:MFG1]NBLIG-1
            If ([M:MFG1]ITMTYP(I) = 1 & !find([M:MFG1]BOMALT(I), TABTBO)) :  WALT = 0 : Break : Endif   # 12.04 27352
        Next
        If WALT <> 0
            [M:MFG1]WORTYP = [F:ROH]WORTYP
            [M:MFG1]ROUALT = WALT
            # FGR 18/09/2009 : X3SUIVI57927
            #[M:MFG1]ROUALTDES = [F:TRO]TROSHO
            Call LECTEXTRA([M:MFG1]ROUALTDES,"TABROUALT","TROSHOAXX",num$([F:TRO]ROUALT),"") From ATEXTRA
            If dim([M:MFG1]ROUECCMAJ)>0 & func RVMLIB.NBRCPNROU([F:ROH]ITMREF)>0
                Call INIECCROU([F:ROH]ITMREF,WFCY,WDAT,WALT,[M:MFG1]ROUECCMAJ,[M:MFG1]ROUECCMIN) From RVMLIB
            Endif
            Return
        Endif
        # fin correction 18981 MM 08.03
    Endif
Endif
Return

########################################
Subprog AV_ROUALT(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AS_ROUALT(VALEUR)
Variable Decimal VALEUR
If [F:MTS]ROUSAI = 1 : mkstat = 2 : End : Endif
If [M:MFG0]MFGMOD = 2 & [M:MFG1]ROUNUM = ""
    VALEUR = 0
    mkstat = 2
    End
Endif
# pour compenser un petit bug à l'affichage ...
If !GIMPORT
    Affzo [M:MFG1]ROUNUM
    Affzo [M:MFG1]ROUDES
Endif

End

########################################
Subprog C_ROUNUM(VALEUR)
Variable Char    VALEUR()
#
If find([M:MFG0]MFGMOD, 1, 3) & VALEUR = ""
    GMESSAGE = mess(31,190,1)
    mkstat = 2
Endif

# Issue 111414 - 2015-12-17 by CCC : control versioning of the routing chosen
If dim([M:MFG1]ROUECCMAJ)>0 & VALEUR<>[M:MFG1]ITMREF(0)
    If func RVMLIB.NBRCPNROU(VALEUR) <> func RVMLIB.NBRCPNROU([M:MFG1]ITMREF(0))
        GMESSAGE= mess(343,193,1)
        mkstat=2
    Endif
Endif
End

########################################
Subprog AM_ROUNUM(VALEUR)
Variable Char    VALEUR()
#
If !find([M:MFG0]MFGMOD,1,3)
    If VALEUR = ""
        [M:MFG1]ROUDES = ""
        [M:MFG1]ROUALT = 0
        [M:MFG1]ROUALTDES = ""
        If !GIMPORT : Affzo [M:MFG1]25 : Endif
        mkstat = 99
    Endif
    End
Endif
GROUTING = 1
# Issue 111414 - 2015-12-16 by CCC : Initialize the routing code & version
[M:MFG1]ROUNUM = VALEUR
Call INIROU
End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
Local    Char    WFCY(GLONFCY) : # 05/2008 V6 avant (3)
Local    Integer WALT
Local    Date    WDAT
Local    Integer NOL
Local    Integer TABTBO(3)
#
If [F:MTS]ROUSAI = 1 & VALEUR = 0
    GMESSAGE = mess(74,193,1)
    mkstat = 2
    End
Endif
If VALEUR <> [M:MFG1]ROUALT  : GROUTING = 1 : Endif
If GROUTING = 0 & [M:MFG3]NBLIG <> 0 : End : Endif
WDAT=[M:MFG1]STRDAT
WFCY=[M:MFG0]MFGFCY
#    Lecture ROUTING
Read [TRO]TRO0=VALEUR
If fstat : mkstat=2 : End : Endif
Read [ROH]ROH0=[M:MFG1]ROUNUM;VALEUR;[M:MFG0]MFGFCY   : # Beryl Site en fin de clé primaire
If fstat : mkstat=2 : End : Endif
#
If [M:MFG1]NBLIG = 0
    GMESSAGE = mess(43,193,1)
    mkstat = 2
    End
Endif

#MJH 106734.sn
#Look for a bad efficiency rate
Filter [ROO] Where FCY = [M:MFG0]MFGFCY & ITMREF = [M:MFG1]ITMREF(0) & ROUALT = VALEUR & OPENUM <> 0 & EFF = 0
Look [ROO]First
Filter [ROO]
If !fstat
  GMESSAGE = func AFNC.MES1(mess(891,197,1), mess(63,198,1))
  mkstat=2 : End
Endif
#MJH 106734.en

Call CONTMFGGAM(WFCY,WALT,WDAT,[M:MFG1]MFGEXTQTY, [M:MFG1]MFGSTU, 1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
# Contrôle de cohérence des alternatives de nomenclature
# llc 11.02 16545
If [M:MFG0]MFGMOD <> 3 | [M:MFG0]FLGMOD = 2
    TABTBO(0)=[F:TRO]BOMALT1
    TABTBO(1)=[F:TRO]BOMALT2
    TABTBO(2)=[F:TRO]BOMALT3
    For NOL=0 To [M:MFG1]NBLIG-1
        If [M:MFG1]ITMTYP(NOL) = 1
            If !find([M:MFG1]BOMALT(NOL), TABTBO)
                GMESSAGE=mess(53,193,1)
                mkstat=2
                End
            Endif
        Endif
    Next NOL
Endif

# mise à jour de la liste des opérations
If VALEUR <> [M:MFG1]ROUALT  : GROUTING = 1 : Endif
# Issue 111414 - 2015-12-16 by CCC : use of LOAROH subprog
#If !find([M:MFG0]MFGMOD,1,3) : End : Endif
#If ([M:MFG3]NBLIG   = 0) | (GROUTING = 1)
#    Call UPDOPE(2,1,WALT) From MFGLIBO
#    GROUTING = 0
#Endif
#[M:MFG1]WORTYP = [F:ROH]WORTYP
#If [M:MFG0]MFGTEX = "" : [M:MFG0]MFGTEX = [F:ROH]TEXNUM : Endif    # 79913
If func RVMLIB.NBRCPNROU([M:MFG1]ROUNUM)=0
   WALT = [M:MFG1]ROUALT : [M:MFG1]ROUALT = VALEUR
   Gosub LOAROH
   [M:MFG1]ROUALT = WALT
Endif
End

########################################
Subprog AV_ROUDES(VALEUR)
Variable Char    VALEUR()
If [M:MFG1]ROUNUM = "" : VALEUR = "" : End : Endif
If [F:ROH]ITMREF<>[M:MFG1]ROUNUM
    Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
    # FGR 02/10/2009 : X3SUIVI58337
    #If !fstat : VALEUR=[F:ROH]ROUDES : Endif
    If !fstat Then
      #VALEUR=[F:ROH]ROUDES
      Call LECTEXTRA(VALEUR,"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA
    Endif
Else
    # FGR 02/10/2009 : X3SUIVI58337
    #VALEUR=[F:ROH]ROUDES
    Call LECTEXTRA(VALEUR,"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA
Endif
End

########################################
Subprog AV_ROUALTDES(VALEUR)
Variable Char    VALEUR()
If [M:MFG1]ROUALT = 0 : VALEUR = "" : End : Endif
If [F:TRO]ROUALT<>[M:MFG1]ROUALT
    Read [TRO]TRO0=[M:MFG1]ROUALT
    # FGR 18/09/2009 : X3SUIVI57927
    #If !fstat : VALEUR=[F:TRO]TRODES : Endif
    If !fstat Then
      Call LECTEXTRA(VALEUR,"TABROUALT","TRODESAXX",num$([F:TRO]ROUALT),"") From ATEXTRA
    Endif
Else
    # FGR 18/09/2009 : X3SUIVI57927
    #VALEUR=[F:TRO]TRODES
    Call LECTEXTRA(VALEUR,"TABROUALT","TRODESAXX",num$([F:TRO]ROUALT),"") From ATEXTRA
Endif
End

########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
#
# FGR 02/10/2009 : X3SUIVI58337
#[M:MFG1]ROUDES = [F:ROH]ROUDES
Call LECTEXTRA([M:MFG1]ROUDES,"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA

If !GIMPORT : Affzo [M:MFG1]ROUDES : Endif
#
End

