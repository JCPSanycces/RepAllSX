$AVANT_GAMME
If clalev([ROH])=0 : Local File ROUTING [ROH] : Endif
If VALEUR <> ""
   Local File ROUTING [ROH] Where FCY=[M:MFG0]MFGFCY & ITMREF=VALEUR
Else
   Local File ROUTING [ROH] Where FCY=[M:MFG0]MFGFCY
Endif
Local Char WCLE1 (15)
Local Char WCLE2

Local Char LALTA # pour passer l'alternative en alpha à GOBJET !(param act écran)
LALTA = num$([M:MFG1]ROUALT)
#If VALEUR <> "" WCLE1 = VALEUR : Else : Raz WCLE1 : Endif
If VALEUR <> "" : WCLE1  = VALEUR+"~"+[M:MFG0]MFGFCY : Else : Raz WCLE1 : Endif
WCLE2 = LALTA

Return

