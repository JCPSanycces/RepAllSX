#<AdxTL>@(#)7.0.0.0 $Revision$
# Issue X3-48941 - 2017-07-31 by BAKHA : if component audit exists, display message before BOM reload
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking component audit, make sure version is in use
$ACTION
#--- Dem 78142
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif

# Issue 113364 - 2016-01-07 by BEEBE : avoid transaction error when MFG opened twice
If dim(GSOHFRCAUPDTICK) >= 0 Then
  Gosub RECOVERED_AUPDTICK From SUBMFGA
Endif
# Issue 113364 - 2016-01-07 by BEEBE : end

#---
 # X3-30931 - STWIL - Need AVANT_ACT to reset the record in case it has been updated by Production Scheduler
Case ACTION
 When "AVANT_ACT"    : Gosub AVANTACT     From SUBMFGA
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBMFGA
 When "VARIANTE"     : Gosub VARIANTE     From SUBMFGA
 When "SETTRANS"     : Gosub SETTRANS     From SUBMFGA
 When "FILTRE"       : Gosub FILTRE       From SUBMFGA
 When "OUVRE"        : Gosub OUVRE        From SUBMFGA
 When "STATUT"       : Gosub STATUT       From SUBMFGA
 When "AP_IMPRIME"   : Gosub AP_IMPRIME   From SUBMFGA
 When "SETBOUT"      : Gosub SETBOUT      From SUBMFGA
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBMFGA
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBMFGA
 When "DEFLIG"       : Gosub DEFLIG       From SUBMFGA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBMFGA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBMFGA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBMFGA
 When "VALLIG"       : Gosub VALLIG       From SUBMFGA
 When "RAZCRE"       : Gosub RAZCRE       From SUBMFGA
 When "RAZDUP"       : Gosub RAZDUP       From SUBMFGA
 When "LIENS"        : Gosub LIENS        From SUBMFGA
 When "STYLE"        : Gosub STYLE        From SUBMFGA # Issue 119469 GH 04/11/16 - performance enhancement
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBMFGA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBMFGA
 When "INICRE"       : Gosub INICRE       From SUBMFGA
 When "CREATION"     : Gosub CREATION     From SUBMFGA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBMFGA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBMFGA
 When "ABANDON"      : Gosub ABANDON      From SUBMFGA
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBMFGA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBMFGA
 When "INIMOD"       : Gosub INIMOD       From SUBMFGA
 When "MODIF"        : Gosub MODIF        From SUBMFGA
 When "VERF_ANU"     : Gosub VERF_ANU     From SUBMFGA
 When "AV_ANNULE"    : Gosub AV_ANNULE    From SUBMFGA
 When "ANNULE"       : Gosub ANNULE       From SUBMFGA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBMFGA
 When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBMFGA
 When "FIN_MOD"      : Gosub FIN_MOD      From SUBMFGA
 When "FERME"        : Gosub FERME        From SUBMFGA
 When "SETBOUT"      : Gosub SETBOUT      From SUBMFGA
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBMFGA
 When "VERROU"       : Gosub VERROU       From SUBMFGA    # 07.07 mm 41682
 When "DEVERROU"     : Gosub DEVERROU     From SUBMFGA    # 07.07 mm 41682
 When "AB1_ROUNUM"   : Gosub AVANT_GAMME
 When "AB5_UOMEXTQTY": Gosub AB5_VAL
 When "BB5_UOMEXTQTY": Gosub BB5_VAL
 When "AB5_EXTQTY"   : Gosub AB5_VAL
 When "BB5_EXTQTY"   : Gosub BB5_VAL
 When "AB9_NBLIG"    : Gosub MEM_VCR
 When "AB10_NBLIG"   : Gosub AB10_NBLIG   # FQ 64658 GA 07/2010 tunnel Article-site
 When "BB10_NBLIG"   : Gosub BB10_NBLIG   # FQ 64658 GA 07/2010 tunnel Article-site
 When "FIN_ACTION"   : Gosub FIN_ACTION   From SUBMFGA
 When Default
Endcase
Return

#####################################################
#---------------------------------------------------#
#      Après modification du site de production     #
# ------------------------------------------------- #
# Récupération des paramètres production            #
#---------------------------------------------------#
########################################
Subprog AS_PLNFCY(VALEUR)
Variable Char    VALEUR()
If GREP <> "C"
    If VALEUR = ""
        Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
        VALEUR = GFCY
        Gosub CHARG_PARAM From SUBMFGA
    Endif
Else
    If VALEUR = ""
       Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
       Gosub CHARG_PARAM From SUBMFGA
       VALEUR = GFCY
    Endif
Endif
End

#####################################################
Subprog AM_PLNFCY(VALEUR)
Variable Char    VALEUR()
If GMESSAGE<>""
    mkstat=2
    End
Endif
If GFCY <> VALEUR
    GFCY=VALEUR
    Gosub CHARG_PARAM From SUBMFGA
    #----- Affichage entêtes de colonne variables -----#
    Gosub AFF_TITCOL From SUBMFGA
Endif
End

#####################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char     VALEUR()
Local    Integer OK
Local    Char    WMSG(255)

If [M:MFG1]NBLIG <> 0 | [M:MFG2]NBLIG <> 0
    OK=1
    If !GIMPORT    # pas en import ...
        Call OUINON(mess(35,190,1),OK) From GESECRAN
    Endif
    If OK=2
        Call TEMPON(mess(111,195,1)) From GESECRAN
        Call CONTROL_NEW_FCY(VALEUR,WMSG) From SUBMFGB
        If WMSG <> ""
            Call TEMPOFF From GESECRAN
            Call ERREUR(WMSG) From GESECRAN
            mkstat = 2
            End
        Endif
        Call UPD_NEW_FCY(VALEUR) From SUBMFGB
        If mkstat <> 0
            Call TEMPOFF From GESECRAN
            Call ERREUR(GMESSAGE) From GESECRAN
            VALEUR = [M:MFG0]MFGFCY
            mkstat = 2
            End : # GH 21/05/2014
        Endif
        Call TEMPOFF From GESECRAN
    Else
        VALEUR = [M:MFG0]MFGFCY
    Endif
Endif
If GFCY <> VALEUR
    GFCY = VALEUR
    Gosub CHARG_PARAM From SUBMFGA
    #----- Affichage entêtes de colonne variables -----#
    Gosub AFF_TITCOL From SUBMFGA
Endif

End

########################################
Subprog C_MFGFCY(VALEUR)
Variable Char    VALEUR()

If [F:FCY]FCY <> VALEUR
    If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
    Read [FCY]FCY0=VALEUR
    If fstat : mkstat = 2 : End : Endif
Endif
If [F:FCY]LEGCPY<>GSOCIETE & GSOCIETE <> "" : GMESSAGE=mess(2,194,1) : mkstat=1 : End : Endif

If [F:FCY]MFGFLG <> 2
    GMESSAGE = mess(1,193,1)
    mkstat = 2
    End
Endif
End

#####################################################
Subprog C_MFGNUM(VALEUR)
Variable Char     VALEUR

# vérification si un enregistrement existe
Look [MFG] MFG0=VALEUR
# si on n'avait rien d'affiché on veut affiché un OF existant
If [M:MFG0]MFGNUM = "" & GREP <> "C" & GREP <> "D"
  If fstat : GMESSAGE = mess(178,199,1) : mkstat=1 : End : Endif
Endif
# en création ou duplication et compteur manuel, contrôle si no existe déja
If (GREP <> "C" & GREP <> "D") | GMANCOU <> 2  : End : Endif
VALEUR = vireblc(VALEUR,2)
Look [MFG]MFG0=VALEUR
If !fstat : GMESSAGE = mess(22,100,1) : mkstat=1 : End : Endif

End

########################################
Subprog AS_MFGMOD(VALEUR)
Variable Integer VALEUR
#
If VALEUR = 1 & !find(GREP,"C","D") : mkstat = 2 : End : Endif
#
Case GMODLCT
    When 1:    If find(GREP,"C","D") : VALEUR = 1 : Endif
               [M:MFG0]FLGMOD = 1
               mkstat = 2
               End
    When 2:    If find(GREP,"C","D")
                   VALEUR = 2
                   [M:MFG0]FLGMOD = GFLGMOD
                   Grizo [M:MFG1]25
                   Grizo [M:MFG3]5
               Endif
               mkstat = 2
               End
    When 4:    If find(GREP,"C","D") : VALEUR = 3 : Grizo [M:MFG2]5 : Endif
               [M:MFG0]FLGMOD = GFLGMOD
               mkstat = 2
               End
Endcase
#
End

########################################
Subprog C_MFGMOD(VALEUR)
Variable Integer VALEUR
If [M:MFG0]XMFGMOD = 1 & VALEUR = 2 & [M:MFG3]NBLIG <> 0 : mkstat = 2 : Endif
If [M:MFG0]XMFGMOD = 1 & VALEUR = 3 & [M:MFG2]NBLIG <> 0 : mkstat = 2 : Endif
# si OF partiel, on ne peut changer que vers le mode complet ...
If [M:MFG0]XMFGMOD = 2 & [M:MFG2]NBLIG <> 0 & !find(VALEUR, 1, 2) : mkstat = 2 : End : Endif
If [M:MFG0]XMFGMOD = 3 & [M:MFG3]NBLIG <> 0 & !find(VALEUR, 1, 3) : mkstat = 2 : End : Endif
#
If VALEUR = 1 & [F:MTS]MFGMODC <> 2 : mkstat = 2 : End : Endif
If VALEUR = 2 & [F:MTS]MFGMODM <> 2 : mkstat = 2 : End : Endif
If VALEUR = 3 & [F:MTS]MFGMODO <> 2 : mkstat = 2 : End : Endif
#
If VALEUR = 2 : [M:MFG1]WORTYP = GDEFWORTYP : Endif
Case VALEUR
    When 2: Grizo [M:MFG1]25 : Grizo [M:MFG3]5
    When 3: Grizo [M:MFG2]5
Endcase
#
End

########################################
Subprog AM_MFGMOD(VALEUR)
Variable Integer VALEUR
Local    Integer I

Case [M:MFG0]XMFGMOD
    When 2: Actzo [M:MFG1]25
            If [M:MFG1]ROUNUM = "" | [M:MFG1]ROUALT = 0
                If [M:MFG1]NBLIG <> 0 & [M:MFG1]ENDDAT <> [0/0/0] & [M:MFG1]STRDAT <> [0/0/0]
                    zonsui = "ROUNUM"
                Endif
            Else
            # mise à jour de la liste des opérations
            Call UPDOPE(2,1,[M:MFG1]ROUALT) From MFGLIBO
            Endif
    When 3: If [M:MFG1]NBLIG <> 0 & [M:MFG1]ENDDAT <> [0/0/0] & [M:MFG1]STRDAT <> [0/0/0]
                If !GIMPORT : Call TEMPON(mess(74,195,1)) From GESECRAN : Endif
# 107513 - use of RPL_MAT to take into account error status of each product
#                For I=0 To [M:MFG1]NBLIG-1
#                    GMODIF = 2                        # 63498
#                    Call UPDMAT(I,0) From MFGLIBM
#                Next
                [M:MFG0]MFGMOD=VALEUR
                Gosub RPL_MAT
                [M:MFG0]MFGMOD=[M:MFG0]XMFGMOD
                GFLGMAT = 1
                If !GIMPORT : Call TEMPOFF From GESECRAN : Endif
            Endif
Endcase
If VALEUR = 1 : [M:MFG0]FLGMOD = 1 : Endif
If VALEUR = 2 & [F:MTS]TYPMODM = 1 : [M:MFG0]FLGMOD = 2 : Endif
If VALEUR = 3 & [F:MTS]TYPMODO = 1 : [M:MFG0]FLGMOD = 2 : Endif
If !GIMPORT : Affzo [M:MFG0]FLGMOD : Endif
[M:MFG0]XMFGMOD = VALEUR

#
End

#####################################################
Subprog AS_MFGSTA(VALEUR)
Variable Integer   VALEUR
Local Decimal WQTY
Local Decimal WTOTPEC, WECART, WECART2, WTOTCOV, WTOTWOP, WTOTWOPC
Local Integer I

# FQ 71382 GA 06/2011 - régression
GMENLOC(3)=1
GMENLOC(4)=1

# FQ 71382 GA 02/2011 pas de maj si OF Clos/Soldé
# + autres tests déplacés pour éviter de changer le statut de façon intempestive
If VALEUR>2  mkstat=2 : End : Endif
#If find(GREP,"C","D") : End : Endif # FQ 74950 cf + bas
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS
#If [M:MFG1]MFGTRKFLG > 1 & [M:MFG1]MFGTRKFLG <>3
If [M:MFG1]MFGTRKFLG > 1 & [M:MFG1]MFGTRKFLG <>3 & !func AFNC.ACTIV("POPS") | func AFNC.ACTIV("POPS") & [M:MFG1]MFGTRKFLG > 3
    mkstat = 2
    End
Endif    # 35458 mm 07.06
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - Message if allocations
If [M:MFG1]ALLSTA    > 1
    GMESSAGE = mess(90,192,1)
    mkstat = 2
    End
Endif

Case [F:MTS]MFGSTA
    When 1: If find(GREP,"C","D") : VALEUR = 2 : Endif
            mkstat = 2
            End
    When 2: If find(GREP,"C","D") : VALEUR = 1 : Endif
            mkstat = 2
            End
Endcase
# FQ 74950 GA 07/2011 ne pas ressortir trop vite ...
If find(GREP,"C","D") : End : Endif

# recherche total PEC
For I = 0 To [M:MFG1]NBLIG -1
    WTOTPEC  = 0
    WTOTWOP  = 0
    WTOTWOPC = 0
    # llc 05.03 17939
    Call CUM_PEC(10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, GMEMSTA, WTOTPEC, WTOTWOP,
&                WTOTWOPC) From TRTWIP
    If WTOTWOPC <> 0 : mkstat = 2 : Break : Endif
Next
End


########################################
Subprog C_MFGSTA(VALEUR)
Variable Integer VALEUR
If find(GREP,"C","D") : End : Endif

Local Integer OK
# si passage de ferme à planifié
If VALEUR = 2 & GMEMSTA = 1
   # V6 Affectations
    Gosub CTL_MAJ_OFFP From MFGMTOLIB
    If OK <> 2 : VALEUR = [M:MFG0]MFGSTA : mkstat = 2 : End : Endif
Endif
End

########################################
Subprog AM_MFGSTA(VALEUR)
Variable Integer VALEUR
Local Integer I, K
Local Integer OK : OK =1
Local Integer WRET

# pour forcer la modification des articles lancés
Call ITMUPDFLG From SUBMFGB

# 35458 mm 07.06
# si passage de ferme à planifié alors que l'OF est édité, avertir que l'OF est édité
If  VALEUR = 2 & GMEMSTA = 1 & [M:MFG1]MFGTRKFLG = 3
    If GASW =1 : GMODSTAT = 2 : End : Endif
    Call OUINON(mess(65,190,1),OK) From GESECRAN
    GASW =1
    If OK = 1
        GMODSTAT    = 1
        [M:MFG0]MFGSTA =1
        VALEUR = 1
        Affzo [M:MFG0]MFGSTA
        End
    Else
        GMODSTAT = 2
        End
    Endif
Endif

# lancement : si mise à niveau données, relecture nomenclature et gamme
If VALEUR <> 1 | GMEMSTA <> 2 : End : Endif    # passage de planifié à ferme

# Demande 8753 MM 05/02
# Issue X3-74333 - 2018-03-19 by YARAM : Generate LOT when geslot = C, LOT = Calculated or "", LOTAFF = 1 or 2 or 3 and LOTMGT = 2 or 3
#If GRELUPD < 2 : End : Endif    # Pas de raffraichisement des OP ni des matières

# nomenclature
If !find([M:MFG0]MFGMOD,1,2) : Goto NXT_RPL : Endif    # complet ou matières seules
If GRELUPD =3 | GRELUPD =4
    # 10.04 25477
    Effzo [M:MFG2]10
    [M:MFG2]NBLIG = 0

    # 03.05 29265
    [M:MFG1]DMATNBR       = 0
    [M:MFG1]DOVRALLNBR    = 0
    [M:MFG1]DDETALLNBR    = 0
    [M:MFG1]DSHTMATNBR    = 0
    [M:MFG1]DMATCLENBR    = 0

    While (find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1)))
        # suppression sous-produits
        K = [M:MFG1]NBLIG - 1
        For I = 0 To K
            If [M:MFG1]ITMTYP(I) = 2
                Dela I,1 [M:MFG1]NBLIG
                [M:MFG1]NBLIG     -= 1
                Break
            Endif
        Next I
    Wend
    # regénération
    For I = 0 To [M:MFG1]NBLIG - 1
        If [M:MFG1]ITMTYP(I) <> 2
             GMFGLIN=[M:MFG1]XMFGLIN(I)
             GMODIF = 2
             Call UPDMAT(I, 1) From MFGLIBM
        Endif
    Next I
Endif

$NXT_RPL
# Issue 112524 - 2015-11-25 by BEEBE : setting GESLOT (Stock-Data) before MFGMOD will be checked
For I = 0 To [M:MFG1]NBLIG - 1
    Read [ITM]ITM0  = [M:MFG1]ITMREF(I)
    If !fstat
        # si pas de gestion de lot, on sort
        If [F:ITM]LOTMGTCOD > 1 & find(GLOTMGT,2,3) & [M:MFG1]LOT(I)=""      # 39141 mm 01.07
            # Lecture de la règle de gestion à utiliser
            If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif

            Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB
            # gestion lot
            # 10.05 32769
            If [F:ITM]LOTCOU = ""
                If !WRET & [F:SRU]LOTSUPINH=3
                    [M:MFG1]GESLOT(I)   = "V"
                Endif
            Else
                [M:MFG1]GESLOT(I)       = "C"
            Endif
        Endif
    Endif
Next I

# gamme
If !find([M:MFG0]MFGMOD,1,3) : End : Endif    # complet ou opérations seules
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - do not update if POPS is activ and managed by PS
If (GRELUPD =2 | GRELUPD =4) & !(([M:MFG1]SCDFLG=4 | [M:MFG1]MFGTRKFLG = 2) & func AFNC.ACTIV("POPS"))
    Call UPDOPE(1,1,0) From MFGLIBO
    Call UPDOPE(2,1,[M:MFG1]ROUALT) From MFGLIBO
Endif

## Demande 8753 MM 05/02
#
## 36774 mm 07.06
## attribution d'un numero de lot
#For I = 0 To [M:MFG1]NBLIG - 1
#    Read [ITM]ITM0  = [M:MFG1]ITMREF(I)
#    If !fstat
#        # si pas de gestion de lot, on sort
#        If [F:ITM]LOTMGTCOD > 1 & find(GLOTMGT,2,3) & [M:MFG1]LOT(I)=""      # 39141 mm 01.07
#            # Lecture de la règle de gestion à utiliser
#            If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
#
#            Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
#&           From STKLIB
#            # gestion lot
#            # 10.05 32769
#            If [F:ITM]LOTCOU = ""
#                If !WRET & [F:SRU]LOTSUPINH=3
#                    [M:MFG1]GESLOT(I)    = "V"
#                Endif
#            Else
#                [M:MFG1]GESLOT(I)       = "C"
#            Endif
#        Endif
#    Endif
#Next I
# End Issue 112524

End

########################################
Subprog IB_NBLIG
GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT7 = ""
GBOUT9 = ""
GBOUT10 = ""   # FQ 64658 RAZ boutons Article-Site

# ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - block adding by-product
If ([M:MFG1]SCDFLG=4 | [M:MFG1]MFGTRKFLG = 2) & func AFNC.ACTIV("POPS")
    Raz GBOUT8
Endif

If [M:MFG1]ITMREF(nolign-1) <> ""
    Raz GBOUT8
    GBOUT1 = mess(68,195,1)
    If [M:MFG0]MFGSTA = 1 : GBOUT2 = mess(242,198,1)  : Endif
    GBOUT3 = mess(165,198,1)
    GBOUT4 =  mess(456,198,1)
    GBOUT5 = mess(157,198,1)
    GBOUT6 = mess(275,198,1)
    If [M:MFG1]VCRNUMORI(nolign-1) <> "" : GBOUT7 =mess(31,124,1)- mess(10,159,1) : Endif
    If [M:MFG0]MFGSTA = 1 & [M:MFG1]ITMSTA(nolign-1) < 3 : GBOUT9 = mess(467,198,1) : Endif

    # FQ 64658 Article-Site - Objet ITF
    # Pour éviter Tunnel de tunnel en boucle !
    If !find("GESITF",GNAVIG(1..GPILNAV))
       GBOUT10 = mess(4,198,1)
    Endif
Endif
Call IB_NOTECHECK([M:MFG1]ITMREF(nolign-1),"ITMREF",11) From TRTNTSCTL # product notes

If !func ECCLIB.ERRCOD("MFG1",nolign-1)
    Raz GBOUT12     # Information
Endif
End

########################################

$AB10_NBLIG
#--------------------------------#
# Avant bouton vers article site #
#--------------------------------#
# FQ 64658 GA 07/2010 Accès à l'Objet ITF en tunnel
If dim(GFLTITM)<=0 Global Char GFLTITM Endif
If dim(GFLTFCY)<=0 Global Char GFLTFCY Endif
GFLTFCY=[M:MFG0]MFGFCY
GFLTITM=[M:MFG1]ITMREF(nolign-1)
GBIDI1=GCONSULT
GCONSULT=2 # pas de maj de l'article-site ?
Return

$BB10_NBLIG
#--------------------------------#
# Après bouton vers article site #
#--------------------------------#
Raz GFLTITM
Raz GFLTFCY
GCONSULT=GBIDI1 # on remet la valeur initiale
# Issue 48563 03/08/2017 by GEBIL : Error: [F:ROH] : Class Non-existent + Error: [F:BOH] : Class Non-existent
If clalev([F:ROH])=0 | clalev([F:BOH])=0 : mkstat=4 : Endif
Return

#107513
Subprog B12_NBLIG
Call ERRMSG("MFG1",nolign-1) From MFGLIB
End

########################################
Subprog AVANT_NBLIG
Local Integer NOL
NOL=nolign-1

# si sous-produit, pas de traitement
If [M:MFG1]ITMTYP(NOL) = 2 : End : Endif

#     Sauvegarde contexte
Call SAVE_CTX(NOL) From SUBMFGB
#     Lecture fichiers Article & Article/site
If   GMODIF <> 2
     Call LECT_FICLIG(NOL)    From SUBMFGB
     Call SUB_TOT(NOL)        From SUBMFGB
     Call DECNBR(NOL)         From MFGLIBP
Endif

# FQ 50547 GA 06/2009
Call GETLINE(NOL) From MFGLIBM

End

########################################
Subprog APRES_NBLIG
Local Integer NOL, I
Local Integer LRET
#
NOL = nolign-1
# si sous-produit, pas de traitement
If [M:MFG1]ITMTYP(NOL) = 2 : End : Endif

# Issue 84553 - 2012-09-19 by CCC : On attend la fin de ligne pour modifier les matières et sous-produits suite au changement d'alternative
If GMODIF=3 & find([M:MFG0]MFGMOD,1,2)
  # 120980 mm 02.2017
  If dim([M:MFG1]ECCVALMAJ)>0
      # Need to control validity date. On ECCVALxxx, validity date is a warning not a blocking error
      Call CTRECC([M:MFG1]ITMREF(nolign-1),"MFG1","STRDAT",[M:MFG1]ECCVALMAJ(nolign-1),[M:MFG1]ECCVALMIN(nolign-1),
&               [M:MFG1]STRDAT,LRET,[M:MFG1]ECCERRMSG(nolign-1)) From ECCLIB
      [M:MFG1]ECCERRCOD(nolign-1) = LRET
  Endif
  Gosub RPL_MAT
  GMODIF=0
Endif

# resynchro n° lignes s'il y a des sous-produits
If NOL > 0 & find(2, [M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1))
    For I = 0 To [M:MFG1]NBLIG -1
        If I <> NOL & [M:MFG1]ITMTYP(I) = 1 : Call UPD_SOUSPROD_SEQ(I) From MFGLIBM : Endif
    Next I
Endif

# --> Si fin sans validation : Réhabilitation des totaux et c'est tout
If (status = 6 | status = 7 | status = 27 | status = 28  | status >= 1792)
    Call ADD_TOT(NOL) From SUBMFGB
    If [M:MFG1]MFGTRKFLG = 0 : [M:MFG1]MFGTRKFLG = 1 : Endif # pour compenser bug moteur
    If !GIMPORT
        Affzo [M:MFG1]20
        Affzo [M:MFG2]5
    Endif
    End
Endif

# Suppression d'une ligne ou plusieurs lignes
If status = 65 | status = 68 | status = 83
    If !GIMPORT
        Affzo  [M:MFG1]20
        Affzo  [M:MFG2]5
    Endif
    Call ANALYSE_CTX(NOL)   From SUBMFGB
    If !find([M:MFG0]MFGMOD,1,2) : End : Endif
    If GREP = "C" & GFLGMAT = 0 : End : Endif
#    Case GREP
#        When "C","D": If GFLGMAT = 0 : End : Endif
#    Endcase
    Call UPDMAT(NOL,1)    From MFGLIBM
Endif

# Validation de la ligne
Call ADD_TOT(NOL)      From SUBMFGB
If [M:MFG1]MFGTRKFLG = 0 : [M:MFG1]MFGTRKFLG = 1 : Endif # pour compenser bug moteur
If !GIMPORT
    Affzo [M:MFG1]20
    Affzo [M:MFG2]5
Endif

# pour réafficher la ligne avec le bon numéro ...
# le pb c'est que NBLIG n'a pas encore été incrémenté en ajout...
If GMODIF = 2 : [M:MFG1]NBLIG += 1 : Endif

# recalcul dates
Call ANALYSE_CTX(NOL)  From SUBMFGB

# mise à jour des matières
Call MAJMAT(NOL) From SUBMFGB

# mise à jour conditionnements si 1ère ligne
Case GMODIF
    When 0: Call INCNBR(NOL) From MFGLIBP
    When 1: If NOL = 0
                If [M:MFG1]ITMREF(NOL+1) <> ""
                    Call UPDPRN(2,1,NOL+1) From MFGLIBP
                Endif
            Endif
    When 2: If NOL = 0 : Call UPDPRN(2,1,NOL)   From MFGLIBP : Endif
            If NOL > 0 : Call INCNBR(NOL)       From MFGLIBP : Endif
Endcase

# sauvegarde ligne
[M:MFG1]XMFGLIN(NOL)= [M:MFG1]MFGLIN(NOL)

If GMODIF = 0 & IMODIF = 2
    Call UPD_MAT_PJT(NOL,[M:MFG1]PJT(NOL)) From MFGLIBM
Endif

Call APRES_NBLIG(NOL) From SUBMFGECC

If !GIMPORT : Affzo [M:MFG1]5 : Endif

End

########################################
Subprog C_NBLIG
Local Integer NOL


# pour bug moteur
If [M:MFG1]NBLIG > 0
  If [M:MFG1]ITMREF([M:MFG1]NBLIG-1) = ""
    status=65 : nolign=[M:MFG1]NBLIG
    Dela [M:MFG1]NBLIG-1,1,[M:MFG1]NBLIG-1 [M:MFG1]NBLIG : [M:MFG1]NBLIG-=1
  Endif
Endif
#--------------------------------------------------------#
# Contrôle sur numéro de ligne                           #
#--------------------------------------------------------#
GMODIF=2
Case status
    When 65:             GMODIF = 1                      # Annulation simple
                         NOL=nolign-1
                         Gosub TEST_ANU From SUBMFGA
    When 68,83:          GMODIF = 1
                         For NOL=nolign-1 To nolign1-1   # Annulation multiple
                             Gosub TEST_ANU From SUBMFGA
                             If mkstat : Break : Endif
                         Next NOL
    When 75:             GMODIF=0                        # Modification
                         NOL=nolign-1
                         Gosub TEST_MOD From SUBMFGA
    When 73,82:          NOL=nolign-1                    # Insertion
                         Gosub TEST_INSERT From SUBMFGA
    When 1,4,5,20,21,26,31,92,93: Gosub TEST_VALID From SUBMFGA
Endcase
#
End

########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M:MFG1]CREFLG(nolign-1)<>0 : mkstat=2 : End : Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Char    WFCY(GLONFCY)

#    Lecture article et article/site
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat
      GMESSAGE = mess(134,100,1)
      mkstat = 2
      End
    Endif
Endif

#    Lecture article/site
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
    Read [ITF]ITF0=VALEUR;[M:MFG0]MFGFCY
    If fstat
      GMESSAGE = mess(45,193,1)
      mkstat = 2
      End
    Endif
Endif
#
WFCY = [M:MFG0]MFGFCY
Call CONTMFGITM(WFCY, 1) From MFGLIB
#    Test unité de stock (si saisie 1ère ligne OK sinon contrôle compatibilité ...)
If GMODIF=2 & [M:MFG1]NBLIG=0
    [M:MFG1]MFGSTU=[F:ITM]STU
    [M:MFG2]MFGSTU=[F:ITM]STU
Else
    If [F:ITM]STU<>[M:MFG1]MFGSTU
        GMESSAGE=mess(52,193,1)
        mkstat=2
        End
    Endif
Endif

# Issue 111414 - 2016-01-06 by CCC : Route versioning has to be identical between first and other products (if not only materials)
If  nolign>1 & !([M:MFG0]MFGMOD = 2 & [M:MFG0]FLGMOD = 1)
& & func RVMLIB.NBRCPNROU(VALEUR)<>func RVMLIB.NBRCPNROU([M:MFG1]ITMREF(0))
    GMESSAGE=func AFNC.MES2(mess(339,193,1), VALEUR, [M:MFG1]ITMREF(0))
    mkstat=2
    End
Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer LIG : LIG = nolign-1
Local    Integer WALT
Local    Decimal WWRK
Local    Integer WRET

#    Contrôle filtre par planificateur
Call CTLPLNFLT([M:MFG0]MFGFCY, VALEUR, GUSER) From MFGLIB
If GMESSAGE <> ""
    mkstat=2
    Call ERREUR(GMESSAGE) From GESECRAN
    End
Endif

#    Chargement ligne article

[M:MFG1]ITMTYP(LIG)     = 1
#[M:MFG1]ITMDES1(nolign-1)    = [F:ITM]ITMDES1

#########
# JAMCC 11th Jan 2018 - change made to correct error - Product description on row 1 repeats on following rows
#Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFG1]ITMDES1(LIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,VALEUR,[M:MFG1]ITMDES1(LIG), "[F:ITM]") From TRTX3
########

[M:MFG1]UOM(LIG)        = [F:ITM]STU
[M:MFG1]STU(LIG)        = [F:ITM]STU
Gosub COEFFICIENT From SUBMFGA
Case [F:MTS]QTYSAI
    When 1:    [M:MFG1]UOMEXTQTY(LIG)  =0
               [M:MFG1]EXTQTY(LIG)     =0
    When 2:    [M:MFG1]UOMEXTQTY(LIG)  =[F:ITF]MFGLOTQTY
               Call QTEARR([M:MFG1]UOMEXTQTY(LIG), [M:MFG1]UOM(nolign-1)) From TRTDIV
               [M:MFG1]EXTQTY(LIG)     =[F:ITF]MFGLOTQTY
               Call QTEARR([M:MFG1]EXTQTY(LIG), [M:MFG1]STU(nolign-1)) From TRTDIV
    When 3:    [M:MFG1]UOMEXTQTY(LIG)  =[F:ITF]REOMINQTY
               Call QTEARR([M:MFG1]UOMEXTQTY(LIG), [M:MFG1]UOM(nolign-1)) From TRTDIV
               [M:MFG1]EXTQTY(LIG)     =[F:ITF]REOMINQTY
               Call QTEARR([M:MFG1]EXTQTY(LIG), [M:MFG1]STU(nolign-1)) From TRTDIV
Endcase

# llc 05.03 18397
If [M:MFG1]ROUNUM <> "" & [M:MFG1]ROUALT <> 0 & [M:MFG1]STRDAT <> [0/0/0] & [M:MFG1]EXTQTY(LIG) <> 0
    WWRK = [M:MFG1]MFGEXTQTY + [M:MFG1]EXTQTY(LIG)
    Raz GMESSAGE
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MFG1]ROUALT
    If !fstat
        Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
        If !fstat
            Call CONTMFGGAM([M:MFG0]MFGFCY,WALT,[M:MFG1]STRDAT,WWRK,[M:MFG1]MFGSTU, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : Raz GMESSAGE : [M:MFG1]UOMEXTQTY(LIG) = 0 : [M:MFG1]EXTQTY(LIG) = 0 :  Endif
Endif
#

# sr 06.02 % Perte demande 14660
[M:MFG1]SHR(LIG) = [F:ITF]SHR

[M:MFG1]TCLCOD(LIG)     = [F:ITM]TCLCOD
[M:MFG1]ABCCLS(LIG)     = [F:ITF]ABCCLS
[M:MFG1]PLANNER(LIG)    = [F:ITF]PLANNER

# V6 Règle affectation
[M:MFG1]PTOCOD(LIG) = func ITMLIB.GET_PTOCOD(VALEUR,[M:MFG0]MFGFCY)

If dim([M:MFG1]TSICOD1(LIG))>0 [M:MFG1]TSICOD1(LIG)=[F:ITM]TSICOD(0) : Endif
If dim([M:MFG1]TSICOD2(LIG))>0 [M:MFG1]TSICOD2(LIG)=[F:ITM]TSICOD(1) : Endif
If dim([M:MFG1]TSICOD3(LIG))>0 [M:MFG1]TSICOD3(LIG)=[F:ITM]TSICOD(2) : Endif
If dim([M:MFG1]TSICOD4(LIG))>0 [M:MFG1]TSICOD4(LIG)=[F:ITM]TSICOD(3) : Endif
If dim([M:MFG1]TSICOD5(LIG))>0 [M:MFG1]TSICOD5(LIG)=[F:ITM]TSICOD(4) : Endif

Gosub RECH_NOM From SUBMFGA

If [F:MTS]UOMSAI = 1 : [M:MFG1]UOMSTUCOE(LIG) = 1 : Endif

If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] :  Endif

# si pas de gestion de lot, on sort
If [F:ITM]LOTMGTCOD = 1 : End : Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB

# gestion lot
# 10.05 32769
If [F:ITM]LOTCOU = ""
   If !WRET & [F:SRU]LOTSUPINH=3
      [M:MFG1]GESLOT(LIG)    = "V"
   Endif
Else
  [M:MFG1]GESLOT(LIG)       = "C"
Endif
If [F:MTS]LOTAFF > 1 & [F:ITM]LOTMGTCOD > 2 : [M:MFG1]LOT(LIG) = mess(62,193,1) : Endif        # 05.05 29221

Call AM_ITMREF(VALEUR) From SUBMFGECC

# Issue 110957 - 2015-09-17 by CCC
If !mkstat & dim([M:MFG1]CRID)>0 & func ECCLIB.NBRCPN(VALEUR)=0
    [M:MFG1]CRID(nolign-1) = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [M:MFG1]CRID(nolign-1)
    If dim([M:MFG1]CRFLG)>0
        [M:MFG1]CRFLG(nolign-1) = string$([M:MFG1]CRID(nolign-1)<>"","151")
        Affzo [M:MFG1]CRFLG(nolign-1)
    Endif
Endif

End

########################################
Subprog AS_UOM(VALEUR)
Variable Char    VALEUR()
If [F:MTS]UOMSAI = 1 : mkstat = 2 : End : Endif
End

########################################
Subprog C_UOM(VALEUR)
Variable Char    VALEUR()
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF

Call CTLUOM ([M:MFG1]ITMREF(nolign-1), 3, "", VALEUR, [M:MFG1]UOMSTUCOE(nolign-1), LUSCAV, LFMT, LMODIF) From STKACT
If !find(LUSCAV,"S","C")
          mkstat = 2
          End
Endif
If LUSCAV = "S" : LMODIF = 1 : Endif
If LMODIF=2 : Actzo [M:MFG1]UOMSTUCOE(nolign-1) : Else : Diszo [M:MFG1]UOMSTUCOE(nolign-1) : Endif
End

########################################
Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
[M:MFG1]UOM(nolign-1) = VALEUR
#Gosub COEFFICIENT From SUBMFGA
# sr 01.02 demande 12537
If [M:MFG1]UOMSTUCOE(nolign-1) = 0 : [M:MFG1]UOMSTUCOE(nolign-1) = 1 : Endif
If [M:MFG1]EXTQTY(nolign-1) <> 0
    [M:MFG1]UOMEXTQTY(nolign-1) = ([M:MFG1]EXTQTY(nolign-1)  / [M:MFG1]UOMSTUCOE(nolign-1))
    Call QTEARR([M:MFG1]UOMEXTQTY(nolign-1),[M:MFG1]UOM(nolign-1)) From TRTDIV
Endif
If [M:MFG1]UOMEXTQTY(nolign-1) <> 0
    [M:MFG1]EXTQTY(nolign-1) = ([M:MFG1]UOMEXTQTY(nolign-1)  * [M:MFG1]UOMSTUCOE(nolign-1))
    Call QTEARR([M:MFG1]EXTQTY(nolign-1),[M:MFG1]STU(nolign-1)) From TRTDIV
Endif
End

########################################
Subprog AS_UOMEXTQTY(VALEUR)
Variable Decimal VALEUR
GBOUT1=mess(151,198,1)
GBOUT2=mess(150,198,1)
GBOUT3=""
If [M:MFG0]MFGSTA = 1 : GBOUT3=mess(242,198,1) : Endif
GBOUT4 = ""
If GREP <> "C" : GBOUT4 = mess(282,198,1) : Endif
End

########################################
Subprog AM_UOMEXTQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WQTY
Local    Integer OK
Local    Integer WALT            # llc 05.03 18397
Local    Decimal WWRK            # llc 05.03 18397
Local    Decimal WFRCQTY
Local    Integer WAUDIT : WAUDIT=0         # Issue X3-48941 - 2017-08-23 by JUSYN : Display info message

If [M:MFG1]MFGTRKFLG > 3
    OK=1
    If !GIMPORT
        Call OUINON(mess(52,190,1),OK) From GESECRAN
    Endif
    If OK <> 2 : VALEUR = [M:MFG1]UOMEXTQTY(nolign-1) : mkstat = 2 : End : Endif
Endif
#
WQTY = VALEUR * [M:MFG1]UOMSTUCOE(nolign-1)
Call QTEARR(WQTY,[M:MFG1]STU(nolign-1)) From TRTDIV

If WQTY < [M:MFG1]CPLQTY(nolign-1)
    GMESSAGE = mess(68,193,1)
    mkstat = 2
    End
Endif

If !find(GREP,"C","D")
    Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(nolign-1), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(nolign-1), 0, 5, WFRCQTY) From MTOLINKLIB
    If (WQTY - [M:MFG1]CPLQTY(nolign-1)) < WFRCQTY
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(nolign-1)
            Read [PTO]PTO0=[M:MFG1]PTOCOD(nolign-1)
            If fstat : Raz [F:PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2
            OK=1
            Call OUINON(mess(228,190,1),OK) From GESECRAN
            If OK <> 2 : VALEUR = [M:MFG1]UOMEXTQTY(nolign-1) : mkstat = 2 : End : Endif
        Endif
    Endif
Endif

# Issue X3-48941 - 2017-08-23 by JUSYN : Display info message when required quantity has been changed for versioned product
#                                        and audit records are available for this product.
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If (GMFGREV = 2 and [M:MFG1]ITMTYP(nolign-1)=1)
    # Display warning message if there is audit
    WAUDIT = func ECCLIB.CHECKWOAUDIT()
    If (WAUDIT = 1)
      Call MESSAGE(mess(404,193,1)) From GESECRAN
    Endif
  Endif
Endif # Issue X3-55832
# Issue X3-48941 - 2017-08-23 by JUSYN - End

[M:MFG1]EXTQTY(nolign-1) = WQTY

# llc 05.03 18397
If [M:MFG1]ROUNUM <> "" & [M:MFG1]ROUALT <> 0 & [M:MFG1]STRDAT <> [0/0/0]
    WWRK = [M:MFG1]MFGEXTQTY + [M:MFG1]EXTQTY(nolign-1)
    Raz GMESSAGE
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MFG1]ROUALT
    If fstat
        GMESSAGE = mess(152,193,1)
    Else
        Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY  : # Beryl Site en fin de clé primaire
        If fstat
            GMESSAGE = mess(152,193,1)
        Else
            Call CONTMFGGAM([M:MFG0]MFGFCY,WALT,[M:MFG1]STRDAT,WWRK,[M:MFG1]MFGSTU, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : Endif
Endif
#
End

########################################
Subprog B1_UOMEXTQTY(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITF]ITF0=[M:MFG1]ITMREF(nolign-1);[M:MFG0]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
# 41211 mm 05.07 - la qté récupérée est exprimée en US.
# Il faut la convertir si l'UL a une autre valeur que celle de l'US
If [M:MFG1]UOM(nolign-1)<>[M:MFG1]STU(nolign-1)
    VALEUR = VALEUR / [M:MFG1]UOMSTUCOE(nolign-1)
    Call QTEARR(VALEUR,[M:MFG1]UOM(nolign-1)) From TRTDIV
    If  VALEUR <> 0
        [M:MFG1]EXTQTY(nolign-1) = (VALEUR  * [M:MFG1]UOMSTUCOE(nolign-1))
        Call QTEARR([M:MFG1]EXTQTY(nolign-1),[M:MFG1]STU(nolign-1)) From TRTDIV
    Endif
Endif
End

########################################
Subprog B2_UOMEXTQTY(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITF]ITF0=[M:MFG1]ITMREF(nolign-1);[M:MFG0]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
# 41211 mm 05.07 - la qté récupérée est exprimée en US.
# Il faut la convertir si l'UL a une autre valeur que celle de l'US
If [M:MFG1]UOM(nolign-1)<>[M:MFG1]STU(nolign-1)
    VALEUR = VALEUR / [M:MFG1]UOMSTUCOE(nolign-1)
    Call QTEARR(VALEUR,[M:MFG1]UOM(nolign-1)) From TRTDIV
    If  VALEUR <> 0
        [M:MFG1]EXTQTY(nolign-1) = (VALEUR  * [M:MFG1]UOMSTUCOE(nolign-1))
        Call QTEARR([M:MFG1]EXTQTY(nolign-1),[M:MFG1]STU(nolign-1)) From TRTDIV
    Endif
Endif
End

########################################
Subprog AM_UOMSTUCOE(VALEUR)
Variable Decimal VALEUR
Local    Decimal WQTY
#
WQTY = VALEUR * [M:MFG1]UOMEXTQTY(nolign-1)
Call QTEARR(WQTY,[M:MFG1]STU(nolign-1)) From TRTDIV
If WQTY < [M:MFG1]CPLQTY(nolign-1)
    GMESSAGE = mess(68,193,1)
    mkstat = 2
    End
Endif
[M:MFG1]EXTQTY(nolign-1) = WQTY
End

########################################
Subprog AS_EXTQTY(VALEUR)
Variable Decimal VALEUR
GBOUT1=mess(151,198,1)
GBOUT2=mess(150,198,1)
GBOUT3=""
If [M:MFG0]MFGSTA = 1 : GBOUT3=mess(242,198,1) : Endif
GBOUT4 = ""
If GREP <> "C" : GBOUT4 = mess(282,198,1) : Endif
End

########################################
Subprog B1_EXTQTY(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITF]ITF0=[M:MFG1]ITMREF(nolign-1);[M:MFG0]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]MFGLOTQTY
End

########################################
Subprog B2_EXTQTY(VALEUR)
Variable Decimal VALEUR
If [F:ITF]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITF]ITF0=[M:MFG1]ITMREF(nolign-1);[M:MFG0]MFGFCY
    If fstat : mkstat = 2 : End : Endif
Endif
VALEUR=[F:ITF]REOMINQTY
End

########################################
Subprog AM_EXTQTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL = nolign-1
Local    Integer OK
Local    Integer WALT            # llc 05.03 18397
Local    Decimal WWRK            # llc 05.03 18397
Local    Decimal WFRCQTY
#
If [M:MFG1]MFGTRKFLG > 3
    OK=1
    If !GIMPORT
        Call OUINON(mess(52,190,1),OK) From GESECRAN
    Endif
    If OK <> 2 : VALEUR = [M:MFG1]EXTQTY(nolign-1) : mkstat = 2 : End : Endif
Endif

If VALEUR < [M:MFG1]CPLQTY(nolign-1)
    GMESSAGE = mess(68,193,1)
    mkstat = 2
    End
Endif

If !find(GREP,"C","D")
    Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(nolign-1), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(nolign-1), 0, 5, WFRCQTY) From MTOLINKLIB
    If (VALEUR - [M:MFG1]CPLQTY(nolign-1)) < WFRCQTY
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(nolign-1)
            Read [PTO]PTO0=[M:MFG1]PTOCOD(nolign-1)
            If fstat : Raz [F:PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2
            OK=1
            Call OUINON(mess(228,190,1),OK) From GESECRAN
            If OK <> 2 : VALEUR = [M:MFG1]EXTQTY(nolign-1) : mkstat = 2 : End : Endif
        Endif
    Endif
Endif

# llc 05.03 18397
If [M:MFG1]ROUNUM <> "" & [M:MFG1]ROUALT <> 0 & [M:MFG1]STRDAT <> [0/0/0]
    WWRK = [M:MFG1]MFGEXTQTY + VALEUR
    Raz GMESSAGE
    #    Lecture ROUTING
    Read [TRO]TRO0=[M:MFG1]ROUALT
    If fstat
        GMESSAGE = mess(152,193,1)
    Else
        Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
        If fstat
            GMESSAGE = mess(152,193,1)
        Else
            Call CONTMFGGAM([M:MFG0]MFGFCY,WALT,[M:MFG1]STRDAT,WWRK,[M:MFG1]MFGSTU, 1) From MFGLIB
        Endif
    Endif
    If GMESSAGE <> "" | WALT = 0 : mkstat = 2 : End : Endif
Endif

[M:MFG1]UOMEXTQTY(nolign-1) = (VALEUR / [M:MFG1]UOMSTUCOE(nolign-1))
Call QTEARR([M:MFG1]UOMEXTQTY(nolign-1),[M:MFG1]UOM(nolign-1)) From TRTDIV

End

########################################
Subprog C_EXTQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
# on peut modifier l'alternative de nomenclature dans les cas suivants:
# - en création/dupli  ou si l'OF est en mode opérations seules
# - en modification si mode opérations seules ou ajout de ligne
#
mkstat = 2
#
If [M:MFG0]MFGMOD > 2 : mkstat = 0 : End : Endif
If         GMODIF = 2 : mkstat = 0 : End : Endif
Case GREP
    When "C", "D": mkstat = 0 : End
    When      "M": If [M:MFG1]ALLSTA = 1  & find([M:MFG1]MFGTRKFLG,1,3) # 18549 mm 12.05
                   # on autorise la modification de l'alternative de nomenclature des OF non alloués
                       mkstat = 0  : End
                   Endif
    When Default : End
Endcase
#
End

########################################
$RPL_MAT
Local Integer I, J, K
# pour forcer la modification des articles lancés
Call ITMUPDFLG From SUBMFGB

Effzo [M:MFG2]
[M:MFG2]NBLIG = 0

[M:MFG1]DMATNBR       = 0
[M:MFG1]DOVRALLNBR    = 0
[M:MFG1]DDETALLNBR    = 0
[M:MFG1]DSHTMATNBR    = 0
[M:MFG1]DMATCLENBR    = 0

J=[M:MFG1]NBLIG
While (find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1)))
    # suppression sous-produits
    K = [M:MFG1]NBLIG - 1
    For I = 0 To K
        If [M:MFG1]ITMTYP(I) = 2
            Dela I,1 [M:MFG1]NBLIG
            [M:MFG1]NBLIG     -= 1
            Break
        Endif
    Next I
Wend
If J<>[M:MFG1]NBLIG : # Issue 122638 GH 15/05/2017 - performance enhancement
   # 107513 - As styles are not updated after dela => refresh styles
   #Affzo [M:MFG1]5  : # Issue 122638 GH 15/05/2017 - performance enhancement
   Call HIGHLIGHT("MFG1",-1) From ECCLIB
Endif

If find([M:MFG0]MFGMOD,1,2)
    # regénération
    J=0
    For I = 0 To [M:MFG1]NBLIG - 1
        If [M:MFG1]ITMTYP(I) <> 2
&       & !find(func ECCLIB.ERRCOD("MFG1",I),1,4) # 107513 - If the product line has an error => we can't load corresponding components
            GMFGLIN=[M:MFG1]XMFGLIN(I)
            GMODIF = 2
            # Call UPDMAT(I, 1) From MFGLIBM : # Issue 122638 GH 15/05/2017 - performance enhancement
            Call UPDMAT(I, -1) From MFGLIBM : J=1
        Endif
    Next I
    If J : Call HIGHLIGHT("MFG2",-1) From ECCLIB : Endif
Endif
Return

########################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char    WFCY(GLONFCY) : # 05/2008 V6 avant (3)
Local Integer WALT
Local Date    WDAT
Local Char    WITM(GLONITM) : # 05/2008 V6 avant (20)
Local Integer TABTBO(3) : # Issue 112462

WITM=[M:MFG1]ITMREF(nolign-1)

If [M:MFG1]STRDAT=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MFG1]STRDAT
Endif

If VALEUR = 0 & [M:MFG0]MFGMOD = 3 & [M:MFG0]FLGMOD = 1 :  End : Endif            # llc 11.02 16545

WFCY=[M:MFG0]MFGFCY
#    Lecture BOM
Read [TBO]TBO0=2;VALEUR
If fstat : mkstat=2 : End : Endif
Read [BOH]BOH0=WITM;VALEUR;2
If fstat
    GMESSAGE = mess(95,193,1)
    mkstat=2
    End
Endif
Call CONTMFGNOM(WFCY,WALT,WDAT,1) From MFGLIB
If WALT=0 : mkstat=2 : End : Endif
#
# Issue 112462 - 2015-11-25 by BEEBE : validation after modifying BOMALT
If [M:MFG1]ROUALT <= 0
    End
Endif

# reading data for actual ROU code
Read [TRO]TRO0=[M:MFG1]ROUALT
If fstat : mkstat=2 : End : Endif

# if the assigned BOM code was changed we have to check,
# whether it´s still valid
If [M:MFG0]MFGMOD <> 3 | [M:MFG0]FLGMOD = 2
    TABTBO(0)=[F:TRO]BOMALT1
    TABTBO(1)=[F:TRO]BOMALT2
    TABTBO(2)=[F:TRO]BOMALT3
    If !find(VALEUR, TABTBO)
        GMESSAGE=mess(53,193,1)
        mkstat=2
        End
    Endif
Endif
End

########################################
Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 : End : Endif                                            # llc 11.02 16545
If [F:TBO]BOMALT<>VALEUR | [F:TBO]BOMALTTYP <> 2
    Read [TBO]TBO0=2;VALEUR
    # FGR 16/09/2009 : X3SUIVI57824
    #If !fstat : [M:MFG1]TBOSHO(nolign-1)=[F:TBO]TBOSHO : Endif
 Endif
#Bug 66723 30/08/10
Call LECTEXTRA([M:MFG1]TBOSHO(nolign-1),"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA

# 18549 mm 12.05
If find(GREP,"C","D","M")
    # If [M:MFG0]MFGMOD<>3 & GMODIF = 0 : # GH 09/12/11 bug 78292
    If [M:MFG0]MFGMOD<>3 & GMODIF = 0 & [M:MFG2]NBLIG<>0
# Issue 84553 - 2012-09-19 by CCC : On attend la fin de ligne pour modifier les matières et sous-produits suite au changement d'alternative
#        [M:MFG1]BOMALT(nolign-1) = VALEUR
#        Gosub RPL_MAT
#        GMODIF = 0
        GMODIF = 3
    Endif
Endif

End

########################################
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL : NOL = nolign-1
#
IMODIF = 2
#
End


########################################
Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()

# Issue 86069 - 2012-12-07 by CCC
If [F:ITM]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITM]ITM0=[M:MFG1]ITMREF(nolign-1)
Endif
If [F:ITM]LOTMGTCOD = 1 : mkstat = 2 : End : Endif
If VALEUR = mess(62,193,1) : VALEUR = "" : Endif
End

##########################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
# Issue 86069 - 2012-12-07 by CCC
If [F:ITM]ITMREF <> [M:MFG1]ITMREF(nolign-1)
    Read [ITM]ITM0=[M:MFG1]ITMREF(nolign-1)
Endif
# si pas de gestion de lot, on sort
If [F:ITM]LOTMGTCOD = 1 : End : Endif
Call C_LOT(VALEUR) From SUBMFGECC
If mkstat : End : Endif
If VALEUR = "" & find([M:MFG1]GESLOT(nolign-1),"C","V") : VALEUR = mess(62,193,1) : Endif
End

########################################
Subprog AS_BPCTYPDEN(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
If [M:MFG1]FMI(nolign-1) = 5 : mkstat = 2 : Endif
End

########################################
Subprog AM_BPCTYPDEN(VALEUR)
Variable Integer VALEUR
#
Case VALEUR
    When 1: [M:MFG1]BPCNUM(nolign-1)=[M:MFG0]MFGFCY
    When 2: [M:MFG1]BPCNUM(nolign-1)=""
Endcase
#
End

########################################
Subprog AS_BPCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP
#
If [M:MFG1]FMI(nolign-1) = 5 : mkstat = 2 : End : Endif
WTYP = [M:MFG1]BPCTYPDEN(nolign-1)
End


########################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP
#
WTYP = [M:MFG1]BPCTYPDEN(nolign-1)
#
If VALEUR=""
    Case WTYP
        When 1:    VALEUR=[M:MFG0]MFGFCY
        When 2:    [M:MFG1]BPCDES(nolign-1)=""
    Endcase
    End
Endif
#
Case WTYP
    When 1: Call CONTROLE("FCY","D",VALEUR,"",mkstat) From CONTOBJ
            If mkstat
                End
            Else
                Call VERFCY(VALEUR) From CONTX3
                If  mkstat
                    End
                Else
                       [M:MFG1]BPCDES(nolign-1)=[F:FCY]FCYSHO
                Endif
            Endif
            If [F:FCY]LEGCPY <> GSOCIETE
                GMESSAGE=mess(2,194,1)
                mkstat=1
                End
            Endif
    When 2: Global Char GBPRSEL(30)
            GBPRSEL = "BPCFLG=2"
            Call CONTROLE("BPR","B",VALEUR,"",mkstat) From CONTOBJ
            Kill GBPRSEL
            If mkstat
                End
            Else
                    [M:MFG1]BPCDES(nolign-1)=[F:BPR]BPRSHO
            Endif
Endcase
#
End

########################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP
Local    Char    WNUM(GLONBPR)
#
WTYP = [M:MFG1]BPCTYPDEN(nolign-1)
WNUM = VALEUR
#
Case WTYP
    When 1: If [F:FCY]FCY<>WNUM
                Read [FCY]FCY0=WNUM
                If !fstat : [M:MFG1]BPCDES(nolign-1)=[F:FCY]FCYSHO : Endif
            Else
                [M:MFG1]BPCDES(nolign-1)=[F:FCY]FCYSHO
            Endif
    When 2: If [F:BPC]BPCNUM<>WNUM
                Read [BPC]BPC0=WNUM
                If !fstat : [M:MFG1]BPCDES(nolign-1)=[F:BPC]BPCSHO : Endif
            Else
                [M:MFG1]BPCDES(nolign-1)=[F:BPC]BPCSHO
            Endif
Endcase
End


########################################
Subprog AS_VCRNUMORI(VALEUR)
Variable Char    VALEUR()  # FGR 14/01/2010 : X3SUIVI60986

Local Integer OK
If [M:MFG1]FMI(nolign-1)=5
    mkstat=2
Endif
[M]ORDFILTER = "1=1"
[M]ORDFILTER += "&ITMREF=[M:MFG1]ITMREF(nolign-1)"
If [M:MFG1]BPCTYPDEN(nolign-1) = 2 & [M:MFG1]BPCNUM(nolign-1) <> "" : [M]ORDFILTER += "&BPRNUM=[M:MFG1]BPCNUM(nolign-1)" : Endif

End

########################################
Subprog AM_VCRNUMORI(VALEUR)
Variable Char    VALEUR()
Local Integer IOK

# 09.05
If VALEUR = ""
    [M:MFG1]VCRTYPORI(nolign-1) = 0
    [M:MFG1]VCRLINORI(nolign-1) = 0
    [M:MFG1]VCRSEQORI(nolign-1) = 0
Else
    If [M:MFG1]VCRTYPORI(nolign-1) > 0 &
&      [M:MFG1]VCRLINORI(nolign-1) > 0 &
&      [M:MFG1]VCRSEQORI(nolign-1) > 0
        Filter [ORD] Where VCRTYP=[M:MFG1]VCRTYPORI(nolign-1) &
&                          VCRNUM=VALEUR &
&                          VCRLIN=[M:MFG1]VCRLINORI(nolign-1) &
&                          VCRSEQ=[M:MFG1]VCRSEQORI(nolign-1)
&       Order By Key ORD3
    Else
        Filter [ORD] Where STOFCY=[M:MFG0]MFGFCY &
&                          ITMREF=[M:MFG1]ITMREF(nolign-1) &
&                          VCRNUM=VALEUR &
&                          find(WIPTYP,1,3,4,6,8,10)
&       Order By Key ORD1
    Endif
    IOK = 0
    For [ORD]
        If !fstat : IOK = 1 : Break : Endif
    Next
    Filter [ORD]
    If IOK
        [M:MFG1]FMI(nolign-1)       = [F:ORD]FMI
        [M:MFG1]VCRTYPORI(nolign-1) = [F:ORD]VCRTYP
        [M:MFG1]VCRLINORI(nolign-1) = [F:ORD]VCRLIN
        [M:MFG1]VCRSEQORI(nolign-1) = [F:ORD]VCRSEQ
        If GREP <> "C" : [M:MFG1]FMI(nolign-1) = 1 : Endif
        If [M:MFG1]FMI(nolign-1) = 5
             Read [SOQ]SOQ0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
             If !fstat
                 If [F:SOQ]FMINUM <> ""
                    [M:MFG1]FMI(nolign-1)  = 1
                    [M:MFG1]XFMI(nolign-1) = 1
                 Else
                    [M:MFG1]XFMI(nolign-1) = 2
                    [M:MFG1]BPCTYPDEN(nolign-1) = 2
                 Endif
             Endif
        Else
            [M:MFG1]XFMI(nolign-1) = 1
        Endif
        Case [M:MFG1]BPCTYPDEN(nolign-1)
            When 1: [M:MFG1]BPCNUM(nolign-1) = [F:ORD]ORIFCY
            When 2: [M:MFG1]BPCNUM(nolign-1) = [F:ORD]BPRNUM
        Endcase
        If !GIMPORT
            Affzo [M:MFG1]BPCNUM(nolign-1)
            Affzo [M:MFG1]BPCDES(nolign-1)
            Affzo [M:MFG1]XFMI(nolign-1)
        Endif
    Endif
Endif
#
End

########################################
Subprog AM_SCDMOD(VALEUR)
Variable Integer VALEUR
If VALEUR=1 : zonsui="ENDDAT" : Endif
End

########################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If [M:MFG0]MFGSTA=4 : mkstat = 2 : Endif        # FQ 71382 pas de modif OF Clos
# Si jalonnement amont et date fin non renseignée, pas de saisie
If ([M:MFG1]SCDMOD=1 & [M:MFG1]ENDDAT=[0/0/0]) : mkstat=2 : End : Endif
If [M:MFG1]MFGTRKFLG > 4 : mkstat = 2 : Endif        # llc 09.03 19254
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

Case [M:MFG1]SCDMOD
    When 1 : If VALEUR>[M:MFG1]ENDDAT : mkstat=2 : End : Endif
    When 2 : If VALEUR=[0/0/0]        : mkstat=2 : End : Endif
Endcase

If  find([M:MFG3]SCDFLG,2,4)
& & VALEUR=[M:MFG1]STRDAT  # If date has been changed, it has to be controlled
    mkstat = 0
    End
Endif
Call CONTROL_DATE_PLN(VALEUR, [M:MFG0]MFGFCY) From MFGLIB   # révision calendriers (llc 06.00)
Call CONTROL_NOM_VAL(VALEUR, 1) From SUBMFGB

If dim([M:MFG1]ECCVALMAJ)>0 & VALEUR<>[M:MFG1]STRDAT # Issue 122638 GH 15/05/2017 - performance enhancement
   Call C_STRDAT(VALEUR) From SUBMFGECC
Endif
End

########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(20)
Local    Libelle REP
Local    Integer WRET
Local    Integer WMAX
Local    Date    TODAY : TODAY=date$
Local    Integer OK
Local    Integer WAUDIT : WAUDIT = 0  # Issue X3-48941 - audit exists ?
Local    Date    WMEMDAT : WMEMDAT = [M:MFG1]STRDAT  # Issue 122638 GH 15/05/2017 - for entry point RPLMAT

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If find(5,[M:MFG1]FMI(0..[M:MFG1]NBLIG-1)) & GREP <> "C"                # llc 05.03 17939
    OK=1
    If !GIMPORT
        Call OUINON(mess(88,190,1),OK) From GESECRAN
    Endif
    If OK <> 2 : mkstat=2 : End : Endif
Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

# 107513 - reload components according to start date
# If find([M:MFG0]MFGMOD,1,2) & [M:MFG1]MFGTRKFLG=1
# Issue 120199 GH 16/01/2017 - Materials are not updated anymore for WO in situation <> Pending
If find([M:MFG0]MFGMOD,1,2) & [M:MFG1]MFGTRKFLG=1 & [M:MFG1]NBLIG<>0 # Issue X3-62604 27/11/2017 by GEBIL - NBLIG tested for performance enhancement
    # if the WO has unexpected materials or materials with status <> Pending
    #    ask if WO materials should be updated
    #    if Yes, unexpected materials will be lost and all expected materials will be re-created with status = Pending
    # otherwise
    #    WO materials are updated with no question

    If find(GREP,"C","D") & [M:MFG2]NBLIG=0 : OK=3
    Else OK = 1+(GRELSTRDAT=2) # Issue 105127 GH 04/10/2018 - new parameter RELSTRDAT tested
    Endif

    If OK=2
      # Issue 122638 GH 15/05/2017 - entry point to skip material reloading
      GPE = 0
      GPOINT = "RPLMAT" : Gosub  ENTREE From EXEFNC
      If !GPE : OK=2 : Else OK=1 : Endif
    Endif

    If !GIMPORT
      # Issue X3-48941 - check if audit exists then display message
      If (dim([M:MFG1]ECCVALMAJ) > 0 & GMFGREV = 2) # Issue X3-55832
        WAUDIT = func ECCLIB.CHECKWOAUDIT()
      Endif # Issue X3-55832

      If OK=2 & sigma(0,[M:MFG2]NBLIG-1,[M:MFG2]BOMSEQ(indcum)=0 or [M:MFG2]MATSTA(indcum)<>1)
         If (WAUDIT =0)
           Call OUINON(mess(74,195,1)+"\"+mess(387,193,1),OK) From GESECRAN
         Else
           Call OUINON(mess(74,195,1)+"\"+mess(404,193,1),OK) From GESECRAN
         Endif
      Elsif (WAUDIT = 1)
         Call OUINON(mess(404,193,1),OK) From GESECRAN
      Endif
      # End issue X3-48941
    Endif

    If OK<>1
       Local Date LSAVDAT
       LSAVDAT = [M:MFG1]STRDAT
       [M:MFG1]STRDAT=VALEUR
       Gosub RPL_MAT
       [M:MFG1]STRDAT=LSAVDAT
    Endif
Endif

# recalcul dates matières
Call MAJDAT(VALEUR, [M:MFG0]MFGFCY)         From SUBMFGB

# recalcul dates opérations
If [M:MFG3]NBLIG <> 0
    WMAX = [M:MFG3]NBLIG-1
    Call UPD_DAT_GLOB(0, WMAX, VALEUR, [M:MFG1]ENDDAT)  From MFGLIBO
Endif

# si jalonnement amont on sort
If [M:MFG1]SCDMOD=1
# mode modification pour les lignes articles lancés
    Call ITMUPDFLG          From SUBMFGB
    End
Endif

#
WORIDAT=VALEUR
WORIFCY=[M:MFG0]MFGFCY
WLTI=0
If [M:MFG1]NBLIG <> 0
    # recherche article avec délai le + long
    Call RECH_ART_L(WLTI, WART) From SUBMFGB
    If [F:ITF]ITMREF<>WART
        Read [ITF]ITF0=WART;[M:MFG0]MFGFCY
        If fstat : End : Endif
    Endif

    # calcul date
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT,WLTI,WORIFCY,0,[M:MFG1]ENDDAT) From MFGLIB
    Call ITMUPDFLG  From SUBMFGB
Else
    [M:MFG1]ENDDAT = VALEUR
Endif

# recalcul dates opérations
If [M:MFG3]NBLIG <> 0
    WMAX = [M:MFG3]NBLIG-1
    Call UPD_DAT_GLOB(0, WMAX, VALEUR, [M:MFG1]ENDDAT)         From MFGLIBO
Endif

#
If !GIMPORT : Affzo [M:MFG1]ENDDAT  : Endif

Gosub FLGMAT #Issue X3-62604 27/11/2017 by GEBIL : Required quantity false when we modify WOF
End

########################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M:MFG0]MFGSTA=4 : mkstat = 2 : Endif        # FQ 71382 pas de modif OF Clos
# Si jalonnement aval et date début non renseignée, pas de saisie
If ([M:MFG1]SCDMOD=2 & [M:MFG1]STRDAT=[0/0/0]) : mkstat=2 : End : Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
Local    Integer I

Case [M:MFG1]SCDMOD
    When 1 : If VALEUR=[0/0/0]        : mkstat=2 : End : Endif
    When 2 : If VALEUR<[M:MFG1]STRDAT : mkstat=2 : End : Endif
Endcase

If find([M:MFG3]SCDFLG,2,4) & VALEUR=[M:MFG1]ENDDAT  # If date has not been changed, it was already controlled
    mkstat = 0 : End
Endif

# révision calendriers (llc 06.00)
Call CONTROL_DATE_PLN(VALEUR, [M:MFG0]MFGFCY) From MFGLIB
If mkstat : End : Endif
If [M:MFG1]STRDAT = [0/0/0] : End : Endif

Gosub FLGMAT #Issue X3-62604 27/11/2017 by GEBIL : Required quantity false when we modify WOF

End

########################################
$FLGMAT : #Issue X3-62604 27/11/2017 by GEBIL : Required quantity false when we modify WOF
# si mode création et date valide, génération liste matières
If !find([M:MFG0]MFGMOD,1,2) : Return : Endif
If GFLGMAT = 1                : Return : Endif
If !find(GREP,"C")       : Return : Endif
#

#If !GIMPORT : Call TEMPON(mess(74,195,1)) From GESECRAN : Endif
# CCC : 107513 - load of materials only when STRDAT change
#For I=0 To [M:MFG1]NBLIG-1
#    Call UPDMAT(I,0) From MFGLIBM
#    GFLGMAT = 1                            # 02.07 39549
#Next
GFLGMAT = 1

#If [M:MFG2]NBLIG <> 0 : GFLGMAT = 1 : Endif
#If !GIMPORT : Call TEMPOFF From GESECRAN  : Endif

# Issue 111414 - 2015-12-14 by CCC : use of an independant subprog instead AV_ action
#Call AV_ROUNUM([M:MFG1]ROUNUM)
# Initialization can be done only if...
# - no operation has already been loaded in the grid
# - a product is in the grid of products
If [M:MFG3]NBLIG = 0 & [M:MFG1]NBLIG>0
    Call INIROU
Endif

Return

########################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Char    WART(20)
Local    Date    WMEMDAT : WMEMDAT = [M:MFG1]STRDAT
Local    Integer WRET
Local    Integer WMAX
Local    Integer OK
Local    Integer WAUDIT : WAUDIT=0  # Issue X3-48941 - audit exists ?

# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

If find(5,[M:MFG1]FMI(0..[M:MFG1]NBLIG-1)) & GREP <> "C"                # llc 05.03 17939
    OK=1
    If !GIMPORT
        Call OUINON(mess(88,190,1),OK) From GESECRAN
    Endif
    If OK <> 2 : mkstat=2 : End : Endif
Endif

#
Call CHECK_PAST(VALEUR, 2) From MFGLIB

# recalcul dates opérations
If [M:MFG3]NBLIG <> 0
    WMAX = [M:MFG3]NBLIG-1
    Call UPD_DAT_GLOB(0, WMAX, [M:MFG1]STRDAT, VALEUR)         From MFGLIBO
Endif

#
If [M:MFG1]SCDMOD=2
# mode modification pour les lignes articles lancés
    Call ITMUPDFLG          From SUBMFGB
    End
Endif

# Issue 119988 GH 12/01/2017 - Objective date = last entered End date value before WO is created/duplicated
If find(GREP,"C","D") : #If [M:MFG0]OBJDAT = [0/0/0]
   [M:MFG0]OBJDAT = VALEUR
Endif

# Issue 120199 GH 16/01/2017 - Materials are not updated anymore for WO in situation <> Pending
#If [M:MFG1]MFGTRKFLG > 3 : End : Endif
If [M:MFG1]MFGTRKFLG > 1 : zonsui="STRDAT" : End : Endif

WORIDAT=VALEUR
WORIFCY=[M:MFG0]MFGFCY
WLTI=0

If [M:MFG1]NBLIG <> 0
    # recherche article avec délai le + long
    Call RECH_ART_L(WLTI, WART) From SUBMFGB
    # relecture article au cas ou ...
    If [F:ITF]ITMREF<>WART
        Read [ITF]ITF0=WART;[M:MFG0]MFGFCY
        If fstat : End : Endif
    Endif
    # calcul date
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:MFG1]STRDAT) From MFGLIB
    Call ITMUPDFLG          From SUBMFGB

# 107513 - materials are reloaded if STRDAT is modified => no need to update requirement date
#    # maj dates matières si nécessaire
#    If [M:MFG1]STRDAT <> WMEMDAT
#        Call MAJDAT([M:MFG1]STRDAT, [M:MFG0]MFGFCY) From SUBMFGB
#    Endif
Else
    [M:MFG1]STRDAT = VALEUR
Endif
#
If !GIMPORT : Affzo [M:MFG1]STRDAT : Endif
Call CHECK_PAST([M:MFG1]STRDAT, 2) From MFGLIB
#
If mkstat = 0
    # recalcul dates opérations
    If [M:MFG3]NBLIG <> 0
        WMAX = [M:MFG3]NBLIG-1
        Call UPD_DAT_GLOB(0, WMAX, [M:MFG1]STRDAT, VALEUR)         From MFGLIBO
    Endif
Endif

# If start date has been changed, reload materials
If WMEMDAT<>[M:MFG1]STRDAT
   If [M:MFG1]NBLIG<>0  #Issue X3-62604 27/11/2017 by GEBIL - performance enhancement
      # Issue 120199 GH 16/01/2017
      # if the WO has unexpected materials or materials with status <> Pending
      #    ask if WO materials should be updated
      #    if Yes, unexpected materials will be lost and all expected materials will be re-created with status = Pending
      # otherwise
      #    WO materials are updated with no question

      If !find([M:MFG0]MFGMOD,1,2) : OK=1
      Elsif find(GREP,"C","D") & [M:MFG2]NBLIG=0 : OK=3
      Else OK = 1 + (GRELSTRDAT=2) : # Issue 105127 GH 04/10/2018 - new parameter RELSTRDAT tested
      Endif

      If OK=2 : # Issue 122638 GH 15/05/2017 - entry point to skip material reloading
         GPE = 0
         GPOINT = "RPLMAT" : Gosub  ENTREE From EXEFNC
         If !GPE : OK=2 : Else OK=1 : Endif
      Endif

      If !GIMPORT
        # Issue X3-48941 - check if audit exists then display message
        If (dim([M:MFG1]ECCVALMAJ)>0 & GMFGREV = 2) # Issue X3-55832
          WAUDIT = func ECCLIB.CHECKWOAUDIT()
        Endif # Issue X3-55832

        If OK=2 & sigma(0,[M:MFG2]NBLIG-1,[M:MFG2]BOMSEQ(indcum)=0 or [M:MFG2]MATSTA(indcum)<>1)
            If (WAUDIT = 0)
              Call OUINON(mess(74,195,1)+"\"+mess(387,193,1),OK) From GESECRAN
            Else
               Call OUINON(mess(74,195,1)+"\"+mess(404,193,1),OK) From GESECRAN
            Endif
        Elsif (WAUDIT = 1)
            Call OUINON(mess(404,193,1),OK) From GESECRAN
        Endif
        # End issue X3-48941
      Endif

      # Issue 122638 GH 15/05/2017 - performance enhancement
      If OK<>1
         If dim([M:MFG1]ECCVALMAJ)>0
            Call CTRECCPRD(-1) From SUBMFGECC
            Call HIGHLIGHT("MFG1",-1) From ECCLIB
         Endif
         Gosub RPL_MAT
      Elsif dim([M:MFG1]ECCVALMAJ)>0
         Call C_STRDAT([M:MFG1]STRDAT) From SUBMFGECC
      Endif
      #Call C_STRDAT([M:MFG1]STRDAT) From SUBMFGECC
   Else
      Gosub FLGMAT #Issue X3-62604 27/11/2017 by GEBIL : Required quantity false when we modify WOF
   Endif
Endif

zonsui="STRDAT"
End

########################################
Subprog AM_LTIREDCOE(VALEUR)
Variable Decimal VALEUR
Local Integer I
Local Integer WRET
#
If [M:MFG3]NBLIG = 0 : End : Endif


# OF jalonné ?
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : End : Endif
If WRET = 2 : Call MOD_JAL From MFGLIBO : Endif

# un petit message pour patienter ...
If !GIMPORT : Call TEMPON(mess(93,195,1)) From GESECRAN : Endif

# si compression précédente = 100, cas particulier on a perdu les temps standard
# il faut relire la gamme
# llc 10.03 19813
If [M:MFG1]LTIREDCOE = 100
    For I=0 To [M:MFG3]NBLIG-1
        Call UPD_OPE_HC(I) From MFGLIBO
    Next I
    [M:MFG1]LTIREDCOE = 0
Endif

# si la valeur précédente est différente de 0, il faut recalculer les temps initiaux
If [M:MFG1]LTIREDCOE <> 0
    For I=0 To [M:MFG3]NBLIG-1
        Call UPD_OPE_UNI(12, "MFG3", I, [M:MFG1]LTIREDCOE) From MFGLIBO
    Next I
Endif
# répercussion du changement de % de compression sur les opérations
If VALEUR <> 0
    For I=0 To [M:MFG3]NBLIG-1
        Call UPD_OPE_UNI(11, "MFG3", I, VALEUR) From MFGLIBO
    Next I
Endif
#
If !GIMPORT : Affzo [M:MFG3]10 : Endif
If !GIMPORT : Call TEMPOFF From GESECRAN : Endif
#
End


