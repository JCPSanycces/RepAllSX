#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
# IMPPSH : Import/Export des demandes d'achat              MBT 09/04/99 #
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
#########################################################################

$ACTION
Case ACTION
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_TAB
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE
  When "EXPORT"        : Gosub EXPORT
  When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return


##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################

#---------------------------------------------------------------#
# Début import/export, étiquette appelée depuis le traitement : #
#   - IMPPSH            si import (G_IMPORT=1)                  #
#   - IMPPSH            si export (G_EXPORT=1)                  #
# ------------------------------------------------------------- #
# Entête *71 à *78  / Pied *81 à *88  / Ligne *91 à *98         #
#     les zones TSTCHAMP  1 à  8 déterminent l'entête           #
#     les zones TSTCHAMP 11 à 18 déterminent le pied            #
#     les zones TSTCHAMP 21 à 28 déterminent le détail          #
#---------------------------------------------------------------#
$OUVRE_TEXTE
#----- Lignes texte entête  -----#
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="PSH*71" : TSTCHAMP(2) ="PSH*72" : TSTCHAMP(3) ="PSH*73" : TSTCHAMP(4) ="PSH*74"
TSTCHAMP(5) ="PSH*75" : TSTCHAMP(6) ="PSH*76" : TSTCHAMP(7) ="PSH*77" : TSTCHAMP(8) ="PSH*78"
#----- Lignes texte pied -----#
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="PSH*81" : TSTCHAMP(12)="PSH*82" : TSTCHAMP(13)="PSH*83" : TSTCHAMP(14)="PSH*84"
TSTCHAMP(15)="PSH*85" : TSTCHAMP(16)="PSH*86" : TSTCHAMP(17)="PSH*87" : TSTCHAMP(18)="PSH*88"
#----- Lignes texte détail -----#
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
TSTCHAMP(21)="PSD*91" : TSTCHAMP(22)="PSD*92" : TSTCHAMP(23)="PSD*93" : TSTCHAMP(24)="PSD*94"
TSTCHAMP(25)="PSD*95" : TSTCHAMP(26)="PSD*96" : TSTCHAMP(27)="PSD*97" : TSTCHAMP(28)="PSD*98"
#-----
Gosub OUVRE_TEXTE From TRTX3IMP
Return


##########################################################################
#                                  IMPORT                                #
##########################################################################

#-------------------#
# Début de l'import #
#-------------------#
$OUVRE
Local Integer  OKCHAMP
Local Shortint WNOL
Local Char     WCUR(GLONCUR)
#----- Gestion des textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE
Return

#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Gosub IMPORT_TEXTE
Case IMPFIC
  When "PSH"
    #------------------------#
    # Entête demande d'achat #
    #------------------------#
  When "PSD"
    #----------------------------------------------------------#
    # Lignes demande : Déterminer si nouvelle ligne (nolign=0) #
    #----------------------------------------------------------#
    Raz WNOL
    Gosub IMP_DECLARE From TRTX3IMP
    If GREP="M"
       ICLEPRIM(0)="PSDLIN"
       ICLEPRIM(1)="ITMREF" : ICLESEC(1)="PRHFCY"  : ICLESEC2(1)="EXTRCPDAT"
       ICLEPRIM(2)="ITMREF" : ICLESEC(2)="PRHFCY"
       ICLEPRIM(3)="ITMREF" : ICLESEC(3)="EXTRCPDAT"
       ICLEPRIM(4)="ITMREF"
       NBASTAB="NBLIG"
       Gosub RECHERCHE_LIGNE From TRTX3IMP
       WNOL=nolign
       #---------------------------------------------#
       # Cas de la suppression de ligne (Qté UA = 0) #
       #---------------------------------------------#
       Call TST_CHAMP(IMPFIC,"QTYPUU",OKCHAMP) From SUBIMPOBJ
       If OKCHAMP & [F:PSD]QTYPUU=0 & nolign<>0
          status=65
          Call C_NBLIG     From SUBPSH : If mkstat Return : Endif
          Call AVANT_NBLIG From SUBPSH
          Call APRES_NBLIG From SUBPSH
       Endif
    Endif
    #----- Calcul de l'indice de la ligne -----#
    If WNOL=0 WNOL=[M:PSH1]NBLIG Else WNOL-=1 : Endif
  When "CAL"
    #--------------------------------------------------------------#
    # Traitement des comptes et sections analytiques des lignes DA #
    #            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"PSD"'         #
    #--------------------------------------------------------------#
    [F:CAL]ABRFIC="PSD"
    [F:CAL]VCRTYP=0
    Call IMPORT_ACCCCE(WNOL,"[M:PSH1]LINACC","","[M:PSH1]CCE") From TRTX3CPT
    nolign=WNOL+1 : status=75 : # Modif élément
Endcase
Return

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Gosub TRT_IMP_ZONE
If IMPZON="PRQDAT"     : # Dernier champ saisissable de l'entête
  Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
Endif
Return

#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "PSD"
    Case IMPZON
      When "LINACC1","LINACC2","LINACC3","LINACC4","LINACC5",
&          "LINACC6","LINACC7","LINACC8","LINACC9","LINACC10",
&          "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
        If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par PREQUISD
        Endif
        #-----
      When "PUU"
        Local Integer  OKCHAMP
        Call TST_CHAMP("PSD","BPSNUM",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP
          Call TST_CHAMP("PSD","EXTORDDAT",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP
            [M:PSH1]EXTORDDAT(nolign-1)=[F:PSD]EXTORDDAT
          Endif
          Local Char WBPSNUM(GLONBPS) : WBPSNUM=[F:PSD]BPSNUM
          Call AM_BPSNUM(WBPSNUM) From SUBPSH
          If !mkstat
            [M:PSH1]BPSNUM(nolign-1)=WBPSNUM
          Endif
          Raz mkstat
        Endif
      When "NETPRI" : # Dernier champ saisissable avant le montant HT ligne
        Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
        Local Integer  OKCHAMP
        Call TST_CHAMP("PSD","NETPRI",OKCHAMP) From SUBIMPOBJ
        If !OKCHAMP | [F:PSD]NETPRI=[M:PSH1]NETPRI(nolign-1)
          #--------------------------------------------------#
          # Chargement du prix brut, frais/remises et motifs #
          #--------------------------------------------------#
          Local Shortint WNOL, I
          Local Decimal  DISCRGVAL(0..8)
          Local Char     WCUR(GLONCUR)
          #-----
          WNOL=nolign-1 : WCUR=[M:PSH1]CUR(WNOL)
          #-----
          Call TST_CHAMP("PSD","GROPRI",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP
            If [M:PSH1]GROPRI(WNOL)<>[F:PSD]GROPRI
              Call PAMDISCRG ([F:PSD]GROPRI,"PSH1",0,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]GROPRI(WNOL)=[F:PSD]GROPRI
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL1",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL1)>0
            If [M:PSH1]DISCRGVAL1(WNOL)<>[F:PSD]DISCRGVAL1
              Call PAMDISCRG ([F:PSD]DISCRGVAL1,"PSH1",1,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL1(WNOL)=[F:PSD]DISCRGVAL1
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL2",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL2)>0
            If [M:PSH1]DISCRGVAL2(WNOL)<>[F:PSD]DISCRGVAL2
              Call PAMDISCRG ([F:PSD]DISCRGVAL2,"PSH1",2,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL2(WNOL)=[F:PSD]DISCRGVAL2
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL3",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL3)>0
            If [M:PSH1]DISCRGVAL3(WNOL)<>[F:PSD]DISCRGVAL3
              Call PAMDISCRG ([F:PSD]DISCRGVAL3,"PSH1",3,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL3(WNOL)=[F:PSD]DISCRGVAL3
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL4",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL4)>0
            If [M:PSH1]DISCRGVAL4(WNOL)<>[F:PSD]DISCRGVAL4
              Call PAMDISCRG ([F:PSD]DISCRGVAL4,"PSH1",4,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL4(WNOL)=[F:PSD]DISCRGVAL4
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL5",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL5)>0
            If [M:PSH1]DISCRGVAL5(WNOL)<>[F:PSD]DISCRGVAL5
              Call PAMDISCRG ([F:PSD]DISCRGVAL5,"PSH1",5,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL5(WNOL)=[F:PSD]DISCRGVAL5
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL6",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL6)>0
            If [M:PSH1]DISCRGVAL6(WNOL)<>[F:PSD]DISCRGVAL6
              Call PAMDISCRG ([F:PSD]DISCRGVAL6,"PSH1",6,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL6(WNOL)=[F:PSD]DISCRGVAL6
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL7",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL7)>0
            If [M:PSH1]DISCRGVAL7(WNOL)<>[F:PSD]DISCRGVAL7
              Call PAMDISCRG ([F:PSD]DISCRGVAL7,"PSH1",7,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL7(WNOL)=[F:PSD]DISCRGVAL7
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL8",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL8)>0
            If [M:PSH1]DISCRGVAL8(WNOL)<>[F:PSD]DISCRGVAL8
              Call PAMDISCRG ([F:PSD]DISCRGVAL8,"PSH1",8,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL8(WNOL)=[F:PSD]DISCRGVAL8
            Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGVAL9",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGVAL9)>0
            If [M:PSH1]DISCRGVAL9(WNOL)<>[F:PSD]DISCRGVAL9
              Call PAMDISCRG ([F:PSD]DISCRGVAL9,"PSH1",9,WNOL,WCUR) From TRTACHPRI1
              [M:PSH1]DISCRGVAL9(WNOL)=[F:PSD]DISCRGVAL9
            Endif
          Endif
          #----- Motifs de tarif -----#
          Call TST_CHAMP("PSD","PRIREN",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP
            Call CTLREN ([F:PSD]PRIREN,6,[M:PSH1]PRIREN(WNOL),
&                        [M:PSH1]GROPRI(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]PRIREN(WNOL)=[F:PSD]PRIREN Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN1",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN1)>0
            Call CTLREN ([F:PSD]DISCRGREN1,6,[M:PSH1]DISCRGREN1(WNOL),
&                        [M:PSH1]DISCRGVAL1(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN1(WNOL)=[F:PSD]DISCRGREN1 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN2",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN2)>0
            Call CTLREN ([F:PSD]DISCRGREN2,6,[M:PSH1]DISCRGREN2(WNOL),
&                        [M:PSH1]DISCRGVAL2(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN2(WNOL)=[F:PSD]DISCRGREN2 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN3",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN3)>0
            Call CTLREN ([F:PSD]DISCRGREN3,6,[M:PSH1]DISCRGREN3(WNOL),
&                        [M:PSH1]DISCRGVAL3(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN3(WNOL)=[F:PSD]DISCRGREN3 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN4",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN4)>0
            Call CTLREN ([F:PSD]DISCRGREN4,6,[M:PSH1]DISCRGREN4(WNOL),
&                        [M:PSH1]DISCRGVAL4(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN4(WNOL)=[F:PSD]DISCRGREN4 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN5",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN5)>0
            Call CTLREN ([F:PSD]DISCRGREN5,6,[M:PSH1]DISCRGREN5(WNOL),
&                        [M:PSH1]DISCRGVAL5(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN5(WNOL)=[F:PSD]DISCRGREN5 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN6",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN6)>0
            Call CTLREN ([F:PSD]DISCRGREN6,6,[M:PSH1]DISCRGREN6(WNOL),
&                        [M:PSH1]DISCRGVAL6(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN6(WNOL)=[F:PSD]DISCRGREN6 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN7",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN7)>0
            Call CTLREN ([F:PSD]DISCRGREN7,6,[M:PSH1]DISCRGREN7(WNOL),
&                        [M:PSH1]DISCRGVAL7(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN7(WNOL)=[F:PSD]DISCRGREN7 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN8",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN8)>0
            Call CTLREN ([F:PSD]DISCRGREN8,6,[M:PSH1]DISCRGREN8(WNOL),
&                        [M:PSH1]DISCRGVAL8(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN8(WNOL)=[F:PSD]DISCRGREN8 Else mkstat=0 : Endif
          Endif
          Call TST_CHAMP("PSD","DISCRGREN9",OKCHAMP) From SUBIMPOBJ
          If OKCHAMP & dim([M:PSH1]DISCRGREN9)>0
            Call CTLREN ([F:PSD]DISCRGREN9,6,[M:PSH1]DISCRGREN9(WNOL),
&                        [M:PSH1]DISCRGVAL9(WNOL)) From TRTPRICE
            If !mkstat [M:PSH1]DISCRGREN9(WNOL)=[F:PSD]DISCRGREN9 Else mkstat=0 : Endif
          Endif
          #----- Calcul du montant HT ligne -----#
          For I=1 To 9
            If evalue("dim([M:PSH1]DISCRGVAL"+num$(I)+"(WNOL))")>0
              DISCRGVAL(I-1)=evalue("[M:PSH1]DISCRGVAL"+num$(I)+"(WNOL)")
            Endif
          Next I
          If dim(GCALNETLIN)>0  GCALNETLIN=WNOL+1     : Endif
          If dim(GCALNETABR)>0  GCALNETABR="[M:PSH1]" : Endif
          Call CALNET(2,[F:BPS]PLISTC,[M:PSH1]GROPRI(WNOL),DISCRGVAL,
&                     [M:PSH1]QTYPUU(WNOL),[M:PSH1]NETPRI(WNOL),
&                     [M:PSH1]CUR(WNOL)) From TRTPRICE
          [M:PSH1]LINAMT(WNOL)=[M:PSH1]NETPRI(WNOL)*[M:PSH1]QTYPUU(WNOL)
          Call ARRDEV([M:PSH1]LINAMT(WNOL),[M:PSH1]CUR(WNOL)) From TRTDIV
        Endif
    Endcase
  When "CAL"
    Case IMPZON
      When "ITMDES","ITMDES1","PRHFCY","EXTRCPDAT","PUU","QTYPUU","BPSNUM","PJT",
&          "EXTORDDAT","NETPRI","LINPURTYP"
        OK=0 : # Zones non concernées par CPTANALIN
    Endcase
Endcase
Return

#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
Return

#------------------------------------#
# Traitements de IMP_ZONE et IMP_TAB #
#------------------------------------#
$TRT_IMP_ZONE
Case IMPFIC
  When "PSH"
    #------------------------#
    # Entête demande d'achat #
    #------------------------#
  When "PSD"
    #------------------------#
    # Ligne  demande d'achat #
    #------------------------#
Endcase
Return

#--------------------------------------------------------------------#
# Import d'un texte, étiquette appelée depuis les traitements IMPPSH #
#--------------------------------------------------------------------#
$IMPORT_TEXTE
Raz G_NLDET
Case IMPFIC
  When "PSH"
    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif
    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif
  When "PSD"
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif
Endcase
Return

#-------------------------------------------------------#
# Chargement de la clé du texte dans la classe [M:PSH1] #
#-------------------------------------------------------#
$IMP_ZONE_TEXTE
# Issue 81068 - 2012-03-26 by SR : Remplacement de "PTD" par "PSD"
Case IMPFIC
  When "PSH"
    # Issue X3-100500 - 2018-07-17 by SR : manage modification mode
    #If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C" : # --- Texte entête ---
    If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & (GREP="C" or GREP="M") :
      [M:PSH1]TEX1=[M:ITC]T_CLE_CLOB(1)
       Raz [M:ITC]T_CLE_CLOB(1) : # Issue X3-100500 - 2018-07-17 by SR : To do it only once
   Endif
    # Issue X3-100500 - 2018-07-17 by SR : manage modification mode
    #If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C" : # --- Texte pied ---
    If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & (GREP="C" or GREP="M")
      [M:PSH1]TEX2=[M:ITC]T_CLE_CLOB(2)
      Raz [M:ITC]T_CLE_CLOB(2) : # Issue X3-100500 - 2018-07-17 by SR : To do it only once
    Endif
  When "PSD"
    # Issue X3-100500 - 2018-07-17 by SR : manage modification mode
    #If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" : # --- texte détail ligne ---
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & (GREP="C" or GREP="M")
      [M:PSH1]LINTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
      Raz [M:ITC]T_CLE_CLOB(3) : # Issue X3-100500 - 2018-07-17 by SR : To do it only once
    Endif
Endcase
Return


##########################################################################
#                                   EXPORT                               #
##########################################################################

#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
#----- Gestion dess textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_EXPORT=1 : Gosub OUVRE_TEXTE
#-----
Return

#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Case EXPFIC
  When "PSH"
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:PSH]TEX1)>0 & [F:PSH]TEX1<>""
          G_CLE_CLOB=[F:PSH]TEX1   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:PSH]TEX2)>0 & [F:PSH]TEX2<>""
          G_CLE_CLOB=[F:PSH]TEX2   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif
  When "PSD"
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:PSD]LINTEX)>0 & [F:PSD]LINTEX<>""
          G_CLE_CLOB=[F:PSD]LINTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif
Endcase
Return

#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return

