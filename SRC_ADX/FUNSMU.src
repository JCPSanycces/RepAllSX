######################################################################
$INIT
#Global Char    GSMUNUM(GLONTRS)
#GSMUNUM = ""
Return   
######################################################################   
#----------------------------------------------# 
# Désactivation bouton "Enregistrer"           # 
#----------------------------------------------# 
$SETBOUT 
Call VIREBOUT(CHMEN,"C") From GOBJET
Local Char WLOT(GLONLOT)
Raz WLOT
If dim([M:SMU1]LOT) > 0 
   WLOT =  [M:SMU1]LOT
Endif 
If [M:SMU1]ITMREF<>"" & WLOT <> "" 
    CHMEN += "C"
Endif
Return 
###################################################################### 
#-------------------------------------#
# Après appui sur bouton "Enregistrer" #
#-------------------------------------#
$BOUTON 
Case BOUT 
    When "C" : Gosub UPDATE_SLT 
    When Default 
Endcase 
Return 

                   
                                                         
######################################################################
$OUVRE                                                                
Local Integer LRET
Local Char    XCRITERE(250)

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#---------------------------------------#   
# Ouverture des fichiers utilisés       #   
#---------------------------------------#   
If clalev([F:STL]) = 0 : Local File STOLOT     [STL]      : Endif   
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]      : Endif   
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY]      : Endif   
Return                                                                
######################################################################
$DEBUT               
Gosub REINIT_ECR
Return
######################################################################                                                                       
$FERME                                                                
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----          
#Kill GSMUNUM
Return                                                                

###############################################################################
# lecture lot
###############################################################################
$FILL_PAGE
Diszo [M:SMU1]ITMREF
[M:SMU1] = [F:STL]
Actzo [M:SMU1]USRFLD1
Actzo [M:SMU1]USRFLD2
Actzo [M:SMU1]USRFLD3
Actzo [M:SMU1]USRFLD4

Affzo [M:SMU1]USRFLD1
Affzo [M:SMU1]USRFLD2
Affzo [M:SMU1]USRFLD3
Affzo [M:SMU1]USRFLD4
Return
##########################################################################
$UPDATE_SLT
Local Char WLOT(GLONLOT)
Local Char WSLO(GLONSLO)
Raz WLOT
Raz WSLO 
If dim([M:SMU1]LOT) > 0 
   WLOT =  [M:SMU1]LOT
Endif 
If dim([M:SMU1]SLO) > 0 
   WSLO =  [M:SMU1]SLO
Endif 

Local Char    WFILTRE(100)                                                                   # hcb unicite       
If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2                                                     # hcb unicite 
    WFILTRE  = "ITMREF=[M:SMU1]ITMREF & LOT=WLOT"                                            # hcb unicite 
Else                                                                                         # hcb unicite 
    WFILTRE  = "ITMREF=[M:SMU1]ITMREF & LOT=WLOT & SLO=WSLO"                                 # hcb unicite 
Endif                                                                                        # hcb unicite 


# hcb unicite 
Update [STL] Where evalue(WFILTRE)                                                             
&      With USRFLD1 = [M:SMU1]USRFLD1, USRFLD2 = [M:SMU1]USRFLD2, USRFLD3 = [M:SMU1]USRFLD3, USRFLD4 = [M:SMU1]USRFLD4
If fstat
    GMESSAGE-=mess(50,176,1)-":"-WLOT
    If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV <> 2 : GMESSAGE-=mess(456,197,1)-":"-WSLO : Endif   # hcb unicite
    mkstat = 2
Endif
#réactivation des champs
Gosub REINIT_ECR
Return 
##########################################################################
$REINIT_ECR
Raz [M:SMU1]ITMREF , USRFLD1, USRFLD2, USRFLD3, USRFLD4
Raz [M:SMU1]WFEALOTLEV                                                   # hcb unicite

If dim([M:SMU1]LOT) > 0
   Raz [M:SMU1]LOT
Endif
If dim([M:SMU1]SLO) > 0
   Raz [M:SMU1]SLO
Endif

Affzo[M:SMU1]
Actzo[M:SMU1]ITMREF
If dim([M:SMU1]SLO) > 0
   Diszo[M:SMU1]SLO
   If GFEALOTLEV = 2                            # hcb unicite
      Local Char WINVSLO                        # hcb unicite
      WINVSLO="-K:"+num$(GLONSLO)+"X"           # hcb unicite
      Chgfmt [M:SMU1]SLO  With WINVSLO          # hcb unicite 
   Endif                                        # hcb unicite 
Endif
Diszo [M:SMU1]USRFLD1
Diszo [M:SMU1]USRFLD2
Diszo [M:SMU1]USRFLD3
Diszo [M:SMU1]USRFLD4
Return
##########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
# article doit être géré avec lot
If !find([F:ITM]LOTMGTCOD,2,3,4) : mkstat = 2 : GMESSAGE = mess(480,199,1) : Endif
End

##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET

If dim([M:SMU1]LOT) > 0 
    Raz [M:SMU1]LOT
Endif
If dim([M:SMU1]SLO) > 0 
    Raz [M:SMU1]SLO 
Endif
Effzo [M:SMU1]15-20

If dim([M:SMU1]SLO) > 0
    If [F:ITM]LOTMGTCOD <> 4 | GFEALOTLEV = 2                            # hcb unicite
        Grizo [M:SMU1]SLO
    Else
        Actzo [M:SMU1]SLO
    Endif
Endif

Raz [M:SMU1]WFEALOTLEV                                                   # hcb unicite
If [F:ITM]LOTMGTCOD=4                                                    # hcb unicite
   [M:SMU1]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1) # hcb unicite
Endif                                                                    # hcb unicite

If dim([M:SMU1]SLO) > 0 
    Affzo [M:SMU1]SLO 
Endif
End

##########################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local    Integer WIND : WIND = 0

If VALEUR = [M:SMU1]LOT : End : Endif

Look [STL]STL0(2)=[M:SMU1]ITMREF;VALEUR
If fstat  
    mkstat = 2 
    GMESSAGE = mess(123,199,1) 
    End 
Endif
End

##########################################################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
#If [F:ITM]LOTMGTCOD = 4 : End : Endif
[M:SMU1]LOT = VALEUR

If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2                                 # hcb unicite deb
    Filter [F:STL] Where ITMREF = [M:SMU1]ITMREF & LOT = [M:SMU1]LOT
&                    Order By Key STL0
    Read [STL] First  
    If fstat
       Raz [F:STL] 
    Endif
    Filter [F:STL]
Else                                                                     # hcb unicite fin
    Read [STL]STL0(2)=[M:SMU1]ITMREF;[M:SMU1]LOT
Endif                                                                    # hcb unicite 
Gosub FILL_PAGE 
End

##########################################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local    Integer WIND : WIND = 0

Look [STL]STL0=[M:SMU1]ITMREF;[M:SMU1]LOT;VALEUR
If fstat : mkstat = 2 : GMESSAGE = mess(123,199,1) : End : Endif

    # verrouillage lot
    [M:SMU1]SLO = VALEUR
    If mkstat : End : Endif

    Read [STL]STL0=[M:SMU1]ITMREF;[M:SMU1]LOT;[M:SMU1]SLO
    Gosub FILL_PAGE
End

##########################################################################
Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Gosub REINIT_ECR
End






