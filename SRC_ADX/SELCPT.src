#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
#    FILTRES & CONTROLES SUR LES COMPTES (PCG ET IAS)
#    FGR
#    Création le : 26/02/2003
#    Modification le : 27/11/2003
#    CBO  20/01/2014 FQ 95579 : Control access account.
#    GBO  29/07/2010 FQ 66329 : Ajout d'un paramètre "Critère supplémentaire" sur l'action SELCPT
#    GLE  08/04/2010 FQ 47624 : La sélection sur les comptes tient compte des groupes de sociétés et de sites
#    MDJ  02/02/2010 FQ 49241 : Possibilité de saisir un compte d'encours dans une classe de flux "Incorporelle"
#    MDJ  02/06/2006 FQ 36343 : Sélection de codes comptable Immo (pour type donnée BCA)
#    MDJ  16/05/2006 FQ 35164 : Sélection de comptes de subvention
#    GLE  08/01/2006 FQ 34656 : Prise en compte du filtre Société/Site
#    MDJ  21/10/2005 FQ 32577 : Liste codes comptables de type Immobilisation
################################################################################

################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE" : Gosub SEL_TABLE
  Endcase
Return

################################################################################
$SEL_TABLE
  If !clalev([FGR]) : Local File FACGROUP [FGR] : Endif : # FQ47624

  Case GACTION

    When "SELCPT"
      OBJET = "GAC"
      If PARAM(1) <> ""
        CRITERE = "COA='"+PARAM(1)+"'"
      Else
        CRITERE = "1=1"
      Endif
      If PARAM(2) <> ""
        If  PARAM(2) <> num$(GVML_NIENSER) or (dim([M:FLU0]CLATXS) = 0)   #Fq-49241
           CRITERE  += " & (GACACN="+PARAM(2)+")"
        Else
           CRITERE   +=  "& (GACACN= GVML_NIENCOU | GACACN="+PARAM(2)+")"    #Fq-49241
        Endif
      Endif
      If (PARAM(3)<>"") or (PARAM(4)<>"")
        # Début FQ47624
        #CRITERE += " & (FCY='' | FCY='"+PARAM(4)+"')"
        CRITERE += " & (FCY=''|FCY='"+PARAM(4)+"'"
        For [F:FGR]FGR1 Where FCY=PARAM(4)
          CRITERE += "|FCY='"+[F:FGR]CPY+"'"
        Next
        CRITERE += ")"
        # Fin FQ47624
      Endif
      #@fq66329
      If PARAM(5)<>""
       CRITERE+="&"+PARAM(5)
      Endif

    When "SELACCIMM"
      OBJET = "CAC"
      CRITERE = "TYPCPT = 5"

    When "SELCPTSUB"  : Gosub SELCPTSUB
    When Default
      Case COUZON
        When "IASACC"
          OBJET = "CCE"
          CRITERE = "IASACN="+num$([M]IASACN)
        When Default
      Endcase
  Endcase
Return
################################################################################
$SELCPTSUB

 # sélection des comptes en fonction de la classe passée en paramètre
 OBJET     = "GAC"
 CRITERE   = "CLS="+PARAM(1)


Return
################################################################################
# Contrôle que le compte saisi est de la nature demandée
#   1 - Immo en cours
#   2 - Immo en service
#   3 - Charge
#     - TVA (plus pour le moment)
#     - Fournisseurs (plus pour le moment)
################################################################################
Subprog CTRCPT(RCPT, PCOA, PTYPCPT, PCPY, PFCY)
Variable Char    RCPT      # Compte
Value Char       PCOA      # Plan de compte
Value Integer    PTYPCPT   # Nature de compte
Value Char       PCPY      # Société
Value Char       PFCY      # Site

  #Infbox "RCPT="-num$(RCPT)-"PTYPCPT="-num$(PTYPCPT)
  If PTYPCPT = GVML_NIENCOU or PTYPCPT = GVML_NIENSER or PTYPCPT = GVML_NICHARG Then
    If RCPT <> "" Then
      If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
      For [GAC] Where ACC=RCPT & COA=PCOA
         #*Fq-49241
         If dim([M:FLU0]CLATXS) > 0
            If [M:FLU0]CLATXS=GML_CFINCORP and (PTYPCPT = GVML_NIENSER or [F:GAC]GACACN=GVML_NIENCOU)
               Break
            Endif
         Endif #*Fq-49241
        If [F:GAC]GACACN <> PTYPCPT Then : # Ce compte n'est pas de la nature requise (GACACN)
          GMESSAGE = mess(60,7770,1)-"("+mess([F:GAC]GACACN,2628,1)+")"
          GERR=1
          mkstat = 2
        Endif
        # FQ95579 ajout de PCOA
        Call CTRL_AUT_OBJ("GAC", RCPT, PCOA, PFCY, date$) From GLOBIENS
        If mkstat : End : Endif #CHECK IGNORE_LINE
        Break
      Next
    Endif
  Endif
End


##################################################
Subprog CTRCPTSUB(AZC,TYPCPT,CPY,FCY)
Variable Char    AZC()
Value    Integer TYPCPT
Value    Char    CPY
Value    Char    FCY
End
