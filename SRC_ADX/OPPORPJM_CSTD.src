###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "SALFCY"                         : Gosub SALFCY                                 From OPPORPJM_CSTD_PROPERTIES
    When "OPPSTATE"                       : Gosub OPPSTATE                               From OPPORPJM_CSTD_PROPERTIES
    When "OPPMOD"                         : Gosub OPPMOD                                 From OPPORPJM_CSTD_PROPERTIES
    When "OPPDATLA"                       : Gosub OPPDATLA                               From OPPORPJM_CSTD_PROPERTIES
    When "OPPDATLV"                       : Gosub OPPDATLV                               From OPPORPJM_CSTD_PROPERTIES
    When "OPPDATS"                        : Gosub OPPDATS                                From OPPORPJM_CSTD_PROPERTIES
    When "OPPDATTH"                       : Gosub OPPDATTH                               From OPPORPJM_CSTD_PROPERTIES
    When "OPPIMPT"                        : Gosub OPPIMPT                                From OPPORPJM_CSTD_PROPERTIES
    When "ORIOPP"                         : Gosub ORIOPP                                 From OPPORPJM_CSTD_PROPERTIES
    #
    When "TAS.TASCOD"                     : Gosub TAS_TASCOD                             From OPPORPJM_CSTD_PROPERTIES
    When "TAS.TASPAE"                     : Gosub TAS_TASPAE                             From OPPORPJM_CSTD_PROPERTIES
    #
    When "TAS.PTLNK.PIMOPPTASLNK"         : Gosub TAS_PTLNK_PIMOPPTASLNK                 From OPPORPJM_CSTD_PROPERTIES
    #
    When "BUD.PBUCOD"                     : Gosub BUD_PBUCOD                             From OPPORPJM_CSTD_PROPERTIES
    When "BUD.PBUPAE"                     : Gosub BUD_PBUPAE                             From OPPORPJM_CSTD_PROPERTIES
    #
    When "CDIE.CCE"                       : Gosub CDIE_CCE                               From OPPORPJM_CSTD_PROPERTIES
    #
    When "PAF.PAFCLB"                     : Gosub PAF_PAFCLB                             From OPPORPJM_CSTD_PROPERTIES
  Endcase
Return

