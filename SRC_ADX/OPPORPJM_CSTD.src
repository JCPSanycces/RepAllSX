###################################################################################################
# Classe OPPORPJM
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                                  From OPPORPJM_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE                    From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE                    From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_AFTER"           : Gosub AUPDATE_AFTER                             From OPPORPJM_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE                    From OPPORPJM_CSTD_EVENTS
        When "ADELETE_AFTER"           : Gosub ADELETE_AFTER                             From OPPORPJM_CSTD_EVENTS
      Endcase
    When "BUD"
      Case [L]ACTION
        When "ACONTROL"                : Gosub BUD_ACONTROL                              From OPPORPJM_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub BUD_AINSERT_CONTROL_BEFORE                From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub BUD_AUPDATE_CONTROL_BEFORE                From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub BUD_ADDLINE_BEFORE                        From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub BUD_ADDLINE_AFTER                         From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub BUD_ADELLINE_BEFORE                       From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_AFTER"          : Gosub BUD_ADELLINE_AFTER                        From OPPORPJM_CSTD_EVENTS
      Endcase
    When "BUD.SPLD"
      Case [L]ACTION
        When "ADELLINE_BEFORE"         : Gosub BUD_SPLD_ADELLINE_BEFORE                  From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS"
      Case [L]ACTION
        When "ACONTROL"                : Gosub TAS_ACONTROL                              From OPPORPJM_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub TAS_AINSERT_CONTROL_BEFORE                From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub TAS_AUPDATE_CONTROL_BEFORE                From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_AFTER"   : Gosub TAS_AINSERT_CONTROL_AFTER                 From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_AFTER"   : Gosub TAS_AUPDATE_CONTROL_AFTER                 From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub TAS_ADDLINE_BEFORE                        From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub TAS_ADDLINE_AFTER                         From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub TAS_ADELLINE_BEFORE                       From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS.RITT"
      Case [L]ACTION
        When "ADDLINE_BEFORE"          : Gosub TAS_RITT_ADDLINE_BEFORE                   From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS.RTKO"
      Case [L]ACTION
        When "ADDLINE_BEFORE"          : Gosub TAS_RTKO_ADDLINE_BEFORE                   From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS.RTKO.RAFFT"
      Case [L]ACTION
        When "AINSERT_CONTROL_BEFORE"  : Gosub TAS_RTKO_RAFFT_AINSERT_CONTROL_BEFORE     From OPPORPJM_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub TAS_RTKO_RAFFT_AUPDATE_CONTROL_BEFORE     From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS.SPLD"
      Case [L]ACTION
        When "ADDLINE_BEFORE"          : Gosub TAS_SPLD_ADDLINE_BEFORE                   From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub TAS_SPLD_ADELLINE_BEFORE                  From OPPORPJM_CSTD_EVENTS
      Endcase
    When "TAS.PTLNK"
      # Issue X3-26991/X3-43920 - 2017-06-30 by FGR
      Case [L]ACTION
        When "ADDLINE_BEFORE"          : Gosub TAS_PTLNK_ADDLINE_BEFORE                  From OPPORPJM_CSTD_EVENTS
        When "ACONTROL"                : Gosub TAS_PTLNK_ACONTROL                        From OPPORPJM_CSTD_EVENTS
      Endcase
    When "BUD.SPLD"
      Case [L]ACTION
        When "ADELLINE_BEFORE"         : Gosub BUD_SPLD_ADELLINE_BEFORE                  From OPPORPJM_CSTD_EVENTS
      Endcase
    When "SPLD"
      Case [L]ACTION
        When "ACONTROL"                : Gosub SPLD_ACONTROL                             From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_BEFORE"          : Gosub SPLD_ADDLINE_BEFORE                       From OPPORPJM_CSTD_EVENTS
        When "ADDLINE_AFTER"           : Gosub SPLD_ADDLINE_AFTER                        From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_BEFORE"         : Gosub SPLD_ADELLINE_BEFORE                      From OPPORPJM_CSTD_EVENTS
        When "ADELLINE_AFTER"          : Gosub SPLD_ADELLINE_AFTER                       From OPPORPJM_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                       : Gosub SETERROR                               From OPPORPJM_CSTD_METHODS
