#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation AUD
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..7)
PARAM(1) = date$-1
PARAM(2) = date$
PARAM(3) = "MB"
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
GCONSULT = 0
Call GCONSULT("ALO","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "DEB_CRIT"   : Gosub SET_ECRAN
 When "FIN_CRIT"   : Gosub SET_ECRAN
 When "CONTPAR1"   : Gosub CONTPAR1
Endcase
Return

$AUTORIS
If filinfo(filpath("FIL","ALOGIN","fde"),0)<=0
 OK = 0 : Return
Endif
Return

$OUVRE
If clalev([F:ALO])=0 : Local File ALOGIN  [ALO] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:ACN])=0 : Local File ACONSULT [ACN] : Endif

Local Char    CRITENT(250)(1..3) , CRITSUI(250)
Local Integer SEQUENCE , MAXLIG , ICRIT
Local Char    CHAMP(20)
MAXLIG = dim([M:CAL2]ADOID)


Gosub DEFCRIT

# init periode
If [M:CAL1]STRDAT=[0/0/0] & [M:CAL1]ENDDAT=[0/0/0] 
 [M:CAL1]STRDAT = GDATEDEB
 [M:CAL1]ENDDAT = GDATEFIN
Endif
Return

$DEFCRIT
For I=1 To dim(PARAM)
 Case I
   When 1 : # STRDAT
    If instr(1,PARAM(I),"/")
     [M:CAL1]STRDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAL1]STRDAT= PARAM(I)
    Endif
   When 2 : # ENDDAT
    If instr(1,PARAM(I),"/")
     [M:CAL1]ENDDAT= "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CAL1]ENDDAT= PARAM(I)
    Endif
   When 3 : # USER
    If PARAM(I)<>""
     Call LECTURE("AUS",PARAM(I),"") From CONTOBJ
     If !fstat
      [M:CAL1]USER = PARAM(I)
     Endif
    Endif
   When 4 : # LOGIN
    [M:CAL1]LOGIN= PARAM(I)
   When 5 : # ERR
    Onerrgo
    [M:CAL1]ERR= val(PARAM(I))
    Onerrgo
   When 6 : # TOUS
    Onerrgo
    [M:CAL1]TOUS= val(PARAM(I))
    Onerrgo
   When 7 : # STAT
    If [M:CAL1]TOUS=2
     Onerrgo
     [M:CAL1]STAT= val(PARAM(I))
     Onerrgo
    Endif
 Endcase
Next
Return

$LECTURE
Gosub CRITENT
Gosub CRITSUI
NOL = 0
SUITE  = 1
RETOUR = 1
If CHGPAG>0
 Filter [ALO] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:ALO]SEQ
 NOL = 0
 For [ALO]
  If NOL>=MAXLIG
   SUITE = 2 : Break
  Else
   If CHGPAG=2 : RETOUR = 2 : Endif
   NOL += 1
   Gosub CHARGE
  Endif
 Next
 [M:CAL2]NBLIG = NOL
Else
 Filter [ALO] Where evalue(CRITENT) & evalue(CRITSUI)
&              Order By Key CLE=[F:ALO]SEQ Desc
 NOL = MAXLIG+1
 For [ALO]
  If NOL<=1
   RETOUR = 2 : Break
  Else
   If CHGPAG=-2 : SUITE = 2 : Endif
   NOL -= 1
   Gosub CHARGE
  Endif
 Next
 [M:CAL2]NBLIG = MAXLIG
Endif
NOL -= 1
Return

$CHARGE
If NBLU=1
 NBLU = 2
 If CHGPAG=2 or CHGPAG=-2 : Raz [M:CAL2] : Endif
Endif
nolign = NOL
[M:CAL2] = [F:ALO]
Return

$SET_ECRAN
If ACTION = "DEB_CRIT"
 If [M:CALO]ECRAN = ""
  Call LECTURE("ACN","ALO","") From CONTOBJ
  If !fstat & [ACN]SCRCOD <> ""
   [M:CALO]ECRAN = [ACN]SCRCOD
  Endif
 Endif
 Call C_ERR([M:CAL1]ERR)
 Call C_TOUS([M:CAL1]TOUS)
Elsif ACTION = "FIN_CRIT"
 If [M:CALO]TOUS<>2
  Actzo [M:CAL1]STAT
 Else
  Effzo [M:CAL1]STAT
  Grizo [M:CAL1]STAT
 Endif
Endif
Return

$CRITENT
Raz CRITENT , ICRIT
If [M:CAL1]STRDAT<>[0/0/0]
 Call ADDCRIT(CRITENT,ICRIT,"DATCNX","[ALO]DATCNX>=["+format$(GFMD,[M:CAL1]STRDAT)+"]","&") From GOBJSUB
Endif
If [M:CAL1]ENDDAT<>[0/0/0]
 Call ADDCRIT(CRITENT,ICRIT,"DATCNX","[ALO]DATCNX<=["+format$(GFMD,[M:CAL1]ENDDAT)+"]","&") From GOBJSUB
Endif
If [M:CAL1]ERR=2
 Call ADDCRIT(CRITENT,ICRIT,"STA","[ALO]STA<>0","&") From GOBJSUB
 If [M:CAL1]TOUS<>2
  Call ADDCRIT(CRITENT,ICRIT,"STA","[ALO]STA="+num$([M:CAL1]STAT),"&") From GOBJSUB
 Endif
Endif
If find("USER",[M:CALO]PARPLAG(0..[M:CALO]NBPLAG-1))
 Call CRIT_PLAG(CRITENT,ICRIT,"[ALO]ADOUSR","USER","[M:CALO]") From GOBJSUB
Elsif [M:CAL1]USER <> ""
 Call ADDCRIT(CRITENT,ICRIT,"USER",'[ALO]ADOUSR="'+[M:CAL1]USER+'"',"&") From GOBJSUB
Endif
If find("LOGIN",[M:CALO]PARPLAG(0..[M:CALO]NBPLAG-1))
 Call CRIT_PLAG(CRITENT,ICRIT,"[ALO]ADOLOG","LOGIN","[M:CALO]") From GOBJSUB
Elsif [M:CAL1]LOGIN <> ""
 Call ADDCRIT(CRITENT,ICRIT,"USER",'[ALO]ADOLOG="'+[M:CAL1]LOGIN+'"',"&") From GOBJSUB
Endif
If CRITENT=""
 CRITENT = "1=1"
Endif
Return

$CRITSUI
CRITSUI = ""
Case CHGPAG
 When 2
  If [M:CAL2]NBLIG>0
   SEQUENCE = [M:CAL2]SEQ([M:CAL2]NBLIG-1)
   CRITSUI = '([ALO]SEQ>'+num$(SEQUENCE)+')'
  Endif
 When -2
  If [M:CAL2]NBLIG>0
   SEQUENCE = [M:CAL2]SEQ(0)
   CRITSUI = '([ALO]SEQ<'+num$(SEQUENCE)+')'
  Endif
Endcase
If CRITSUI=""
 CRITSUI = "1=1"
Endif
Return


$CONTPAR1
Case [M:APG]WCOD
 When "USER"
 If [M:APG]BORNE(nolign-1) <> 2
  Call CONTSEL("AUS","!",VALEUR,"",mkstat) From CONTOBJ
 Endif
Endcase
Return
  
######################################################################################
## Ecran CAL1
######################################################################################
Subprog C_ERR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 If [M]ERR<>2
  [M]TOUS = 2
  Affzo TOUS
 Endif
 Actzo TOUS
Else
 Effzo TOUS,STAT
 Grizo TOUS,STAT
Endif
End

Subprog C_TOUS(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Actzo STAT
Else
 Effzo STAT
 Grizo STAT
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran WMALOMB) 09/08/2011 08:51:53 (MB)
######################################################################################
Subprog IB_NBLIG
End

Subprog B1_NBLIG
End


