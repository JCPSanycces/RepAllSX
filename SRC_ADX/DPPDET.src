#<AdxTL>@(#)1.0.0.0 $Revision$
#
#*********************************************************************
#
#           DETAIL EXERCICE/PERIODE DU PLAN D'UN BIEN
#
#*********************************************************************
#    Création
#    MWA - 17.02.2003
#
#*********************************************************************
#    Modification
#
#    CBO - 12.03.2012  FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY   
#    GBO - 11.01.2011  FQ69824  Comptabilisation multiréférentielle
#    GLE - 01.09.2010  FQ66894  Optimisation des flux
#    MWA - 01.07.2010  FQ59941  Gestion des modes russes
#    MWA - 04.05.2010  FQ64544  Comptabilisation écart sur plans liés
#    GBO - 14.04.2010  FQ63831  Problème rafraichissement Numéro de pièce comptable
#    MWA - 11.02.2010  FQ54343  Gestion des Concessions
#    MWA - 07.04.2009  FQ54202  Affichage du site financier porté par le plan
#    MWA - 06.01.2009  FQ51385  Ajout du type de dépréciation.
#
#*********************************************************************
#
# Call OBJET("DPP",GBIDC1,GBIDC2) From GOBJET
# End

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "END"         : Gosub FIN
 When "SUI"         : Gosub SUIVANT
 When "PRE"         : Gosub PRECEDENT
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "FIN"         : Gosub TERMINE
 When "AP_CHOIX"    : Gosub APRES_CHOIX
Endcase
Return

#
#*********************************************************************
#

#=====================================================================
#
$OUVRE
Local Char     LAASREF(GLONAAS)
Local Shortint LDPRPLN, LNOL, LIG
Local Date     LFIYENDDAT, LPERENDDAT

Local Integer  FLGCLC
Local Integer  FLGCNXCLC
Local Integer  FLGCNXFLX : # FQ66894
Local Integer  LCONTEXT
Local Integer  LDEPSTA

Global Integer  BAFFEXE

# Récupération des paramètres
  LAASREF    = PARAM(1)
  LDPRPLN    = val(PARAM(2))
  LFIYENDDAT = PARAM(3)
  LPERENDDAT = PARAM(4)
  If ([M:DPP1]NBLIG2 = 0) Then : LPERENDDAT = [0/0/0] : Endif
  LNOL       = val(PARAM(5))

  If ( LPERENDDAT = [0/0/0] ) Then
    BAFFEXE = 1
  Else
    BAFFEXE = 0
  Endif
 
  # Ouverture des fichiers
  If clalev([F:DEPW])=0 : Local File DEPREC      [DEPW] : Endif 
  If clalev([F:FASW])=0 : Local File FXDASSETS   [FASW] : Endif 
  If clalev([F:LCD])=0  : Local File LNKCPTABD   [LCD]  : Endif


  #If (GUSER = "MWA" ) Then : Dbgaff : Endif
  
  Read [F:FASW]FAS0= LAASREF
  FLGCLC    = [F:FASW]FLGCLC
  Call GET_CNX_FROM_PLAN ( [M:DPP1]CPY, LDPRPLN, LCONTEXT) From GLOBIENS 
  FLGCNXCLC = [F:FASW]FLGCNXCLC(LCONTEXT-1)
  [L]FLGCNXFLX = val(mid$([F:FASW]FLGCNXFLX,LCONTEXT,1)) : # FQ66894
 
  Read [F:DEPW]DEP0= LAASREF;LDPRPLN;G_FIYENDCUR;G_PERENDCUR
  If ( [F:DEPW]DEPSTA = GVML_SCNOCAL ) Then
    LDEPSTA    = G_OUI
  Else
    LDEPSTA    = G_NON
  Endif
  


Return

#=====================================================================
#
$DEBUT

  # FQ54343    
  Global Char G_CCNFMTN
  If ( G_ACTCCN = G_NON or LDPRPLN <> G_CCNPLNCAD or G_CCNRPR <> G_OUI or [F:FAS]OWNTYP <> GVML_TDCONCE) Then
    G_CCNFMTN = "-Nz3:13.2#"
  Else
    G_CCNFMTN = "Nz3:13.2#"
  Endif


  LIG = LNOL

  #------
  Gosub CHARGE_LIGNE

 #FQ63831-GBO
 #Affzo [M:DPPA]    
 #Affzo [M:DPPB]    
 #Affzo [M:DPPC]    
 #Affzo [M:DPPD]    
 #Affzo [M:DPPE]    
 #Affzo [M:DPPF]    


Return

#=====================================================================
#
$SETBOUT

Return

#=====================================================================
#
$APRES_MODIF

Return


#=====================================================================
#
$FIN
Filter [DEPW]
Return

#=====================================================================
#
$SUIVANT

  # Récupération des informations  du bien.
  LIG = LIG + 1
  If ( BAFFEXE ) Then
    If ( LIG > [M:DPP1]NBLIG1 ) Then 
      LIG = [M:DPP1]NBLIG1 
      GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
    Endif
  Else
    If ( LIG > [M:DPP1]NBLIG2 ) Then 
      LIG = [M:DPP1]NBLIG2 
      GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
    Endif
  Endif

  #------
  Gosub CHARGE_LIGNE

Return

#=====================================================================
#
$PRECEDENT

  # Récupération des informations  du bien.
  LIG = LIG - 1
  If ( LIG <= 0 ) Then
    LIG = LIG + 1
    GERR= 1: GMESSAGE = mess(27,7773,1) : Return 
  Endif
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$PREMIER

# Récupération des informations  du bien.
  LIG = 1
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$DERNIER

# Récupération des informations  du bien.
  If ( BAFFEXE ) Then
    LIG = [M:DPP1]NBLIG1
  Else
    LIG = [M:DPP1]NBLIG2
  Endif
  #------
  Gosub CHARGE_LIGNE

Return
#=====================================================================
#
$TERMINE

Return
#=====================================================================
#
$APRES_CHOIX

Return
#=====================================================================
#

########################################################
# Gestion du masque DPPC
########################################################

Subprog AV_PERSTRDAT(VALEUR)
Variable Date VALEUR


 [M:DPPC]PERSTRDATC = format$("D:" + GFMDAT4, VALEUR)
 If (BAFFEXE) Then
  Chgfmt [M:DPPC]PERSTRDATC With "-K:10X"
  Diszo  [M:DPPC]PERSTRDATC
 Else
  Chgfmt [M:DPPC]PERSTRDATC With "K:10X"
  Diszo  [M:DPPC]PERSTRDATC
 Endif

End

Subprog AV_PERENDDAT(VALEUR)
Variable Date VALEUR

 [M:DPPC]PERENDDATC = format$("D:" + GFMDAT4, VALEUR)
 If (BAFFEXE) Then
  Chgfmt [M:DPPC]PERENDDATC With "-K:10X"
  Diszo  [M:DPPC]PERENDDATC
 Else
  Chgfmt [M:DPPC]PERENDDATC With "K:10X"
  Diszo  [M:DPPC]PERENDDATC
 Endif

End

########################################################
# Gestion du masque DPPA
########################################################


Subprog AV_DPRRAT2(VALEUR)
Variable Decimal VALEUR

 # FQ59941
 Local Char PAYSIT(GLONCRY)
 PAYSIT = func TRTFAS.GET_MODE_PAYS( "", "IT" )
 Local Char LEGIT
 LEGIT  = func TRTFAS.GET_MODE_LEGISLATION( "", "IT" )
 Local Char PAYSLR(GLONCRY)
 PAYSLR = func TRTFAS.GET_MODE_PAYS( "", "LR" )
 Local Char LEGLR
 LEGLR  = func TRTFAS.GET_MODE_LEGISLATION( "", "LR" )
 Local Char PAYSDR(GLONCRY)
 PAYSDR = func TRTFAS.GET_MODE_PAYS( "", "DR" )
 Local Char LEGDR
 LEGDR  = func TRTFAS.GET_MODE_LEGISLATION( "", "DR" )
 Local Char PAYSCR(GLONCRY)
 PAYSCR = func TRTFAS.GET_MODE_PAYS( "", "CR" )
 Local Char LEGCR
 LEGCR = func TRTFAS.GET_MODE_LEGISLATION( "", "CR" )

 If (
&     ( PAYSIT = "" or ( PAYSIT <> "" and func GLOFCYCPY.GET_SOC_PAYS([F:FASW]CPY) = PAYSIT ) and
&       LEGIT  = "" or ( LEGIT  <> "" and func GLOFCYCPY.GET_SOC_LEG ([F:FASW]CPY) = LEGIT  )) 
& or  ( PAYSLR = "" or ( PAYSLR <> "" and func GLOFCYCPY.GET_SOC_PAYS([F:FASW]CPY) = PAYSLR ) and
&       LEGLR  = "" or ( LEGLR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([F:FASW]CPY) = LEGLR  ))
& or  ( PAYSDR = "" or ( PAYSDR <> "" and func GLOFCYCPY.GET_SOC_PAYS([F:FASW]CPY) = PAYSDR ) and
&       LEGDR  = "" or ( LEGDR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([F:FASW]CPY) = LEGDR  ))
& or  ( PAYSCR = "" or ( PAYSCR <> "" and func GLOFCYCPY.GET_SOC_PAYS([F:FASW]CPY) = PAYSCR ) and
&       LEGCR  = "" or ( LEGCR  <> "" and func GLOFCYCPY.GET_SOC_LEG ([F:FASW]CPY) = LEGCR  ))
&   ) Then
  Chgfmt [M:DPPA]DPRRAT2 With "N:3.6#"
  Diszo  [M:DPPA]DPRRAT2
 Else
  Chgfmt [M:DPPA]DPRRAT2 With "-N:3.6#"
  Diszo  [M:DPPA]DPRRAT2
 Endif

End


Subprog AV_EXETRFCUM(VALEUR)
Variable Decimal VALEUR

 If (BAFFEXE) Then
  Chgfmt [M:DPPA]EXETRFCUM With "N:"-GDEVFMT
  Diszo  [M:DPPA]EXETRFCUM
 Else
  Chgfmt [M:DPPA]EXETRFCUM With "-N:"-GDEVFMT
  Diszo  [M:DPPA]EXETRFCUM
 Endif

End


Subprog AV_DPRRAT(VALEUR)
Variable Decimal VALEUR
  If ( [M:DPPA]DPRRATFLG = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:DPPA]DPRRAT With "FORCAGE"
    Else
      Chgstl [M:DPPA]DPRRAT With "TFORCAGE"
    Endif

  Else
   Chgstl [M:DPPA]DPRRAT With ""
  Endif
End

Subprog AV_APLDUR(VALEUR)
Variable Decimal VALEUR
 Chgfmt [M:DPPA]APLDUR With "N:9.2"
 Diszo  [M:DPPA]APLDUR 
End

Subprog AV_RSDDUR(VALEUR)
Variable Decimal VALEUR
 Chgfmt [M:DPPA]RSDDUR With "N:9.2"
 Diszo  [M:DPPA]RSDDUR 
End


########################################################
# Gestion du masque DPPD
########################################################
Subprog B1_NBGAS
 Local Char    VALEUR
 Local Char    PAR(30)(1..3)
 PAR(1) = [M:DPPD]TYP(nolign-1)
 PAR(2) = [M:DPPD]NUM(nolign-1)
 PAR(3) = num$(func GLOBIENS.GET_LEDTYP_FROM_PLAN ([M:DPPC]CPY, [M:DPP1]DPRPLN))
 Call SAISIE_CHAR(VALEUR,PAR,"GPCCAB","TRTGPCCAB","") From GSAISIE 
End


$CHARGE_LIGNE

  Raz [M:DPPA]    
  Raz [M:DPPB]    
  Raz [M:DPPC]    
  Raz [M:DPPD]    
  Raz [M:DPPE]    
  Raz [M:DPPF]
    
  # alimentation des champs de l'écran DPPC
  [M:DPPC]CPY       = [M:DPP1]CPY
  [M:DPPC]AASREF    = [M:DPP1]AASREF 
  [M:DPPC]AASDES1   = [M:DPP1]AASDES1
  [M:DPPC]DPRPLN    = [M:DPP1]DPRPLN
  [M:DPPC]FCY       = [M:DPP1]FCY
  [M:DPPC]CUR       = [M:DPP1]CUR
  [M:DPPC]UOM       = [M:DPP1]UOM
  If ( FLGCLC = G_OUI ) Then
    [M:DPPC]FLGCLC    = "127"
  Else
    [M:DPPC]FLGCLC    = "128"
  Endif

  If ( FLGCNXCLC = GVML_RCOUI ) Then
    [M:DPPC]FLGCNXCLC = "127"
  Elsif ( FLGCNXCLC = GVML_RCCLO ) Then
    [M:DPPC]FLGCNXCLC = "129"
  Else
    [M:DPPC]FLGCNXCLC = "128"
  Endif

  If ( LDEPSTA = G_OUI ) Then
    [M:DPPC]DEPSTA    = "127"
  Else
    [M:DPPC]DEPSTA    = "128"
  Endif

  #FQ66894
  If [L]FLGCNXFLX = GVML_FLXGENE Then
    If [M:DPPC]FLGCNXCLC = "128" and [M:DPPC]DEPSTA = "128"
      [M:DPPC]FLGCNXFLX = "128"
    Else
      [M:DPPC]FLGCNXFLX = "129"
    Endif
  Elsif [L]FLGCNXFLX = GVML_FLXNOTG
    [M:DPPC]FLGCNXFLX = "127"
  Else
    [M:DPPC]FLGCNXFLX = ""
    Chgtzn [M:DPPC]FLGCNXFLX With ""
  Endif

  #-1 -------------------
  If ( BAFFEXE ) Then

  #-----------
  # EXERCICE
  #-----------

    #----------
    # Entête
    #----------
    [M:DPPC]PERSTRDAT = [0/0/0]
    [M:DPPC]PERENDDAT = [0/0/0]
    [M:DPPC]FIYSTRDAT = [M:DPP1]FIYSTRDAT  (LIG-1)
    [M:DPPC]FIYENDDAT = [M:DPP1]FIYENDDAT  (LIG-1)
    #FQ54202
    [M:DPPC]FCY       = [M:DPP1]FCY1       (LIG-1)

    #----------
    # Générale
    #----------
    [M:DPPA]STRDPRDAT = [M:DPP1]STRDPRDAT  (LIG-1)
    [M:DPPA]DPM       = [M:DPP1]DPM        (LIG-1)
    [M:DPPA]ENDDPRDAT = [M:DPP1]ENDDPRDAT  (LIG-1)
    [M:DPPA]DPRDUR    = [M:DPP1]DPRDUR     (LIG-1)
    [M:DPPA]APLDUR    = [M:DPP1]APLDUR     (LIG-1)
    [M:DPPA]RSDDUR    = [M:DPP1]RSDDUR     (LIG-1)
    [M:DPPA]DPRRAT2   = [M:DPP1]DPRRAT2E   (LIG-1)
    [M:DPPA]DPRRATFLG = [M:DPP1]DPRRATFLG  (LIG-1)
    [M:DPPA]DPRRAT    = [M:DPP1]DPRRAT     (LIG-1)
    [M:DPPA]ALWCOD    = [M:DPP1]ALWCOD     (LIG-1)
    [M:DPPA]RSDQTY    = [M:DPP1]RSDQTY     (LIG-1)
    [M:DPPA]CRBVEHCOD = [M:DPP1]CRBVEHCOD  (LIG-1)
    [M:DPPA]FIYQTY    = [M:DPP1]FIYQTY     (LIG-1)
    [M:DPPA]PERQTY    = 0
    [M:DPPA]DPRBAS    = [M:DPP1]DPRBAS     (LIG-1)
    [M:DPPA]RSDVAL    = [M:DPP1]RSDVAL     (LIG-1)
    [M:DPPA]DPRVAL    = [M:DPP1]DPRVAL     (LIG-1)
    [M:DPPA]DPRCUM    = [M:DPP1]DPRCUM     (LIG-1)
    [M:DPPA]IMLBLC    = [M:DPP1]IMLBLC     (LIG-1)
    # FQ64544
    [M:DPPA]ENDDPEFLG = [M:DPP1]ENDDPEFLG  (LIG-1)
    [M:DPPA]ENDDPE    = [M:DPP1]ENDDPE     (LIG-1)
    [M:DPPA]EXCDPR    = [M:DPP1]EXCDPR     (LIG-1)
    [M:DPPA]IML       = [M:DPP1]IML        (LIG-1)
    [M:DPPA]IMLRVE    = [M:DPP1]IMLRVE     (LIG-1)
    [M:DPPA]IMLRVEISS = [M:DPP1]IMLRVEISS  (LIG-1)
    [M:DPPA]NBV       = [M:DPP1]NBV        (LIG-1)
    [M:DPPA]DERRVEISS = [M:DPP1]DERRVEISS  (LIG-1)
    [M:DPPA]EXETRFCUM = [M:DPP1]EXETRFCUM  (LIG-1)
    [M:DPPA]IMLRVETRF = [M:DPP1]IMLRVETRF  (LIG-1)
    [M:DPPA]MTCDPEDEV = [M:DPP1]MTCDPEDEV  (LIG-1)
    [M:DPPA]EXERVADEV = [M:DPP1]EXERVADEV  (LIG-1)
    [M:DPPA]RVAAMT    = [M:DPP1]RVAAMT     (LIG-1)
    [M:DPPA]RVACRB    = [M:DPP1]RVACRB     (LIG-1)
    [M:DPPA]NSPVAL    = [M:DPP1]NSPVAL     (LIG-1)
    # FQ54343
    If ( G_ACTCCN = G_OUI and [M:DPPC]DPRPLN = G_CCNPLNCAD ) Then
      [M:DPPA]PERCADCRB = [M:DPP1]EXECADCRB (LIG-1)
      [M:DPPA]TRFCADCUM = [M:DPP1]TRFCADCUM (LIG-1)
    Endif
    #--------------------
    # Révision plan
    #--------------------
    
    #-- Niveau période

    #--------------------
    # Comptabilisation
    #--------------------
    
    #-- Niveau période

    #----------------
    # Fiscal
    #----------------
    [M:DPPF]CRBVEHCOD = [M:DPP1]CRBVEHCOD  (LIG-1)
    [M:DPPF]CRBCUM    = [M:DPP1]CRBCUM     (LIG-1)
    [M:DPPF]CRBAMT    = [M:DPP1]CRBAMT     (LIG-1)
    [M:DPPF]ALWCUM    = [M:DPP1]ALWCUM     (LIG-1)
    [M:DPPF]ALWAMT    = [M:DPP1]ALWAMT     (LIG-1)
    [M:DPPF]DFDBLC    = [M:DPP1]DFDBLC     (LIG-1)
    [M:DPPF]DFDLIM    = [M:DPP1]DFDLIM     (LIG-1)
    [M:DPPF]DFD       = [M:DPP1]DFD        (LIG-1)
    [M:DPPF]DFDRVE    = [M:DPP1]DFDRVE     (LIG-1)
     #----------------
    # Suivi
    #----------------

    [M:DPPE]PERREFCLCI  = [M:DPP1]PERREFCLCI  (LIG-1)
    [M:DPPE]PERREFCLCT  = [M:DPP1]PERREFCLCT  (LIG-1)
    [M:DPPE]PERREFCLC   = [M:DPP1]PERREFCLC   (LIG-1)
    [M:DPPE]DPMI        = [M:DPP1]DPMI        (LIG-1)
    [M:DPPE]DPMT        = [M:DPP1]DPMT        (LIG-1)
    [M:DPPE]DPM         = [M:DPP1]DPM         (LIG-1)
    [M:DPPE]RSDVALI     = [M:DPP1]RSDVAL      (LIG-1)
    [M:DPPE]RSDVALT     = [M:DPP1]RSDVAL      (LIG-1)
    [M:DPPE]RSDVAL      = [M:DPP1]RSDVAL      (LIG-1)
    [M:DPPE]DPRVALI     = [M:DPP1]BSEVAL      (LIG-1) - [M:DPP1]RSDVAL      (LIG-1)
    [M:DPPE]DPRVALT     = [M:DPP1]DPRBAS      (LIG-1) - [M:DPP1]RSDVAL      (LIG-1)
    [M:DPPE]DPRVAL      = [M:DPP1]DPRVAL      (LIG-1)
    [M:DPPE]BSEVALI     = [M:DPP1]BSEVAL      (LIG-1)
    [M:DPPE]BSEVALT     = [M:DPP1]DPRBAS      (LIG-1)
    [M:DPPE]DPRBAS      = [M:DPP1]DPRBAS      (LIG-1)
    [M:DPPE]DPRCUMI     = [M:DPP1]EXECLOCUMI  (LIG-1)
    [M:DPPE]DPRCUMT     = [M:DPP1]EXECLOCUMT  (LIG-1)
    [M:DPPE]DPRCUM      = [M:DPP1]DPRCUM      (LIG-1)
    [M:DPPE]ENDDPEI     = [M:DPP1]ENDDPEI     (LIG-1)
    [M:DPPE]ENDDPET     = [M:DPP1]ENDDPET     (LIG-1)
    [M:DPPE]ENDDPE      = [M:DPP1]ENDDPE      (LIG-1)
    [M:DPPE]EXCDPRI     = [M:DPP1]EXCDPRI     (LIG-1)
    [M:DPPE]EXCDPRT     = [M:DPP1]EXCDPRT     (LIG-1)
    [M:DPPE]EXCDPR      = [M:DPP1]EXCDPR      (LIG-1)
    [M:DPPE]NBVI        = [M:DPP1]NBVI        (LIG-1)
    [M:DPPE]NBVT        = [M:DPP1]NBVT        (LIG-1)
    [M:DPPE]NBV         = [M:DPP1]NBV         (LIG-1)
 
    
  Else
  #-1 -------------------

  #-----------
  # PERIODE
  #-----------


    Local Integer   LIGEXE
    LIGEXE = find([M:DPP1]FIYSTRDAT2 (LIG-1), [M:DPP1]FIYSTRDAT)

    #----------
    # Entête
    #----------
    [M:DPPC]FIYSTRDAT = [M:DPP1]FIYSTRDAT2 (LIG-1)
    [M:DPPC]FIYENDDAT = [M:DPP1]FIYENDDAT2 (LIG-1)
    [M:DPPC]PERSTRDAT = [M:DPP1]PERSTRDAT  (LIG-1)
    [M:DPPC]PERENDDAT = [M:DPP1]PERENDDAT  (LIG-1)
    #FQ54202
    [M:DPPC]FCY       = [M:DPP1]FCY2       (LIG-1)

    #----------
    # Générale
    #----------
    [M:DPPA]STRDPRDAT = [M:DPP1]STRDPRDAT2 (LIG-1)
    [M:DPPA]DPM       = [M:DPP1]DPM2       (LIG-1)
    [M:DPPA]ENDDPRDAT = [M:DPP1]ENDDPRDAT2 (LIG-1)
    [M:DPPA]DPRDUR    = [M:DPP1]DPRDUR2    (LIG-1)
    [M:DPPA]APLDUR    = [M:DPP1]APLDUR2    (LIG-1)
    [M:DPPA]RSDDUR    = [M:DPP1]RSDDUR2    (LIG-1)
    [M:DPPA]DPRRAT2   = [M:DPP1]DPRRAT2P   (LIG-1)
    [M:DPPA]DPRRATFLG = [M:DPP1]DPRRATFLG2 (LIG-1)
    [M:DPPA]DPRRAT    = [M:DPP1]DPRRAT2    (LIG-1)
    [M:DPPA]ALWCOD    = [M:DPP1]ALWCOD2    (LIG-1)
    [M:DPPA]RSDQTY    = [M:DPP1]RSDQTY2    (LIG-1)
    [M:DPPA]CRBVEHCOD = [M:DPP1]CRBVEHCOD  (LIGEXE-1)
    [M:DPPA]FIYQTY    = [M:DPP1]FIYQTY2    (LIG-1)
    [M:DPPA]PERQTY    = [M:DPP1]PERQTY     (LIG-1)
    [M:DPPA]DPRBAS    = [M:DPP1]DPRBAS2    (LIG-1)
    [M:DPPA]RSDVAL    = [M:DPP1]RSDVAL2    (LIG-1)
    [M:DPPA]DPRVAL    = [M:DPP1]DPRVAL2    (LIG-1)
    [M:DPPA]DPRCUM    = [M:DPP1]PERCLOCUM  (LIG-1)
    [M:DPPA]IMLBLC    = [M:DPP1]IMLBLC2    (LIG-1)
    # FQ64544
    [M:DPPA]ENDDPEFLG = [M:DPP1]PERDPEFLG  (LIG-1)
    [M:DPPA]ENDDPE    = [M:DPP1]PERENDDPE  (LIG-1)
    [M:DPPA]EXCDPR    = [M:DPP1]PEREXCDPR  (LIG-1)
    [M:DPPA]IML       = [M:DPP1]IML2       (LIG-1)
    [M:DPPA]IMLRVE    = [M:DPP1]IMLRVE2    (LIG-1)
    [M:DPPA]IMLRVEISS = [M:DPP1]IMLRVEISS2 (LIG-1)
    [M:DPPA]NBV       = [M:DPP1]NBV2       (LIG-1)
    [M:DPPA]DERRVEISS = [M:DPP1]DERRVEISS2 (LIG-1)
    [M:DPPA]EXETRFCUM = [M:DPP1]EXETRFCUM  (LIGEXE-1)
    [M:DPPA]IMLRVETRF = [M:DPP1]IMLRVETRF2 (LIG-1)
    [M:DPPA]MTCDPEDEV = [M:DPP1]MTCDPEDEV2 (LIG-1)
    [M:DPPA]EXERVADEV = [M:DPP1]EXERVADEV2 (LIG-1)
    [M:DPPA]RVAAMT    = [M:DPP1]RVAAMT2    (LIG-1)
    [M:DPPA]RVACRB    = [M:DPP1]RVACRB2    (LIG-1)
    [M:DPPA]NSPVAL    = [M:DPP1]NSPVAL2    (LIG-1)
    # FQ54343
    If ( G_ACTCCN = G_OUI and [M:DPPC]DPRPLN = G_CCNPLNCAD ) Then
      [M:DPPA]PERCADCRB = [M:DPP1]PERCADCRB2 (LIG-1)
      [M:DPPA]TRFCADCUM = [M:DPP1]TRFCADCUM2 (LIG-1)
    Endif
    #--------------------
    # Révision plan
    #--------------------
    [M:DPPB]MTCDPEDAT = [M:DPP1]MTCDPEDAT  (LIG-1)
    [M:DPPB]MTCTIATYP = [M:DPP1]MTCTIATYP  (LIG-1)
    [M:DPPB]MTCTIADAT = [M:DPP1]MTCTIADAT  (LIG-1)
    [M:DPPB]MTCDEVADJ = [M:DPP1]MTCDEVADJ2 (LIG-1)
    [M:DPPB]RVADAT    = [M:DPP1]RVADAT2    (LIG-1)
    [M:DPPB]RVATIADAT = [M:DPP1]RVATIADAT  (LIG-1)
    [M:DPPB]RVATYP    = [M:DPP1]RVATYP     (LIG-1)
    [M:DPPB]RVACOE    = [M:DPP1]RVACOE2    (LIG-1)
    [M:DPPB]RVACOEREF = [M:DPP1]RVACOEREF  (LIG-1) 
    # FQ51385  
    [M:DPPB]IMLTYP    = [M:DPP1]IMLTYP2    (LIG-1)
    [M:DPPB]INTIMLTYP = [M:DPP1]INTIMLTYP2 (LIG-1)
    [M:DPPB]EXTIMLTYP = [M:DPP1]EXTIMLTYP2 (LIG-1) 
    #--------------------
    # Comptabilisation
    #--------------------
    [M:DPPD]DPEDEV    = [M:DPP1]DPEDEV    (LIG-1)
    [M:DPPD]EXCDEV    = [M:DPP1]EXCDEV    (LIG-1)
    [M:DPPD]DERDEV    = [M:DPP1]DERDEV    (LIG-1)
    [M:DPPD]DERRVEDEV = [M:DPP1]DERRVEDEV (LIG-1)
    [M:DPPD]RVETRFDEV = [M:DPP1]RVETRFDEV (LIG-1)
    [M:DPPD]RVACRBDEV = [M:DPP1]RVACRBDEV (LIG-1)
    # FQ64544
    [M:DPPD]LNKDEV    = [M:DPP1]LNKDEV    (LIG-1)
    [M:DPPD]PSTDPE    = [M:DPP1]PSTDPE    (LIG-1)
    [M:DPPD]PSTEXC    = [M:DPP1]PSTEXC    (LIG-1)
    [M:DPPD]PSTDER    = [M:DPP1]PSTDER    (LIG-1)
    [M:DPPD]PSTDERRVE = [M:DPP1]PSTDERRVE (LIG-1)
    [M:DPPD]PSTRVETRF = [M:DPP1]PSTRVETRF (LIG-1)
    [M:DPPD]PSTRVACRB = [M:DPP1]PSTRVACRB (LIG-1)
    [M:DPPD]NBGAS=0
   # Fq69824
   #For [F:LCD] Where REF=[M:DPP1]AASREF & DPRPLN=[M:DPP1]DPRPLN & FIYENDDAT=[M:DPPC]FIYENDDAT & PERENDDAT=[M:DPPC]PERENDDAT
    For [F:LCD] Where REF=[M:DPP1]AASREF & DPRPLN=[M:DPP1]DPRPLN & FIYENDDAT=[M:DPPC]FIYENDDAT & 
&                    (PERENDDAT>[M:DPPC]PERSTRDAT & PERENDDAT<=[M:DPPC]PERENDDAT)
     [M:DPPD]TYP([M:DPPD]NBGAS)=[F:LCD]TYP
     [M:DPPD]NUM([M:DPPD]NBGAS)=[F:LCD]NUM
     [M:DPPD]NBGAS+=1
    Next

    # FQ54343
    If ( G_ACTCCN = G_OUI and [M:DPPC]DPRPLN = G_CCNPLNCAD) Then
      [M:DPPD]CADCRBDEV = [M:DPP1]CADCRBDEV (LIG-1)
      [M:DPPD]PSTCADCRB = [M:DPP1]PSTCADCRB (LIG-1)
    Endif
    # FQ64544
    [M:DPPD]PSTLNK    = [M:DPP1]PSTLNK    (LIG-1)
   
    #----------------
    # Fiscal
    #----------------
    If ( [M:DPPC]PERENDDAT = [M:DPPC]FIYENDDAT ) Then
      [M:DPPF]CRBVEHCOD = [M:DPP1]CRBVEHCOD  (LIGEXE-1)
      [M:DPPF]CRBCUM    = [M:DPP1]CRBCUM     (LIGEXE-1)
      [M:DPPF]CRBAMT    = [M:DPP1]CRBAMT     (LIGEXE-1)
      [M:DPPF]ALWCUM    = [M:DPP1]ALWCUM     (LIGEXE-1)
      [M:DPPF]DFDBLC    = [M:DPP1]DFDBLC     (LIGEXE-1)
      [M:DPPF]DFDLIM    = [M:DPP1]DFDLIM     (LIGEXE-1)
      [M:DPPF]DFD       = [M:DPP1]DFD        (LIGEXE-1)
      [M:DPPF]DFDRVE    = [M:DPP1]DFDRVE     (LIGEXE-1)
    Endif
    #----------------
    # Suivi
    #----------------
    [M:DPPE]PERREFCLCI  = [M:DPP1]PERREFCL2I  (LIG-1) 
    [M:DPPE]PERREFCLCT  = [M:DPP1]PERREFCL2T  (LIG-1) 
    [M:DPPE]PERREFCLC   = [M:DPP1]PERREFCLC2  (LIG-1) 
    [M:DPPE]DPMI        = [M:DPP1]DPMI2       (LIG-1)
    [M:DPPE]DPMT        = [M:DPP1]DPMT2       (LIG-1)
    [M:DPPE]DPM         = [M:DPP1]DPM2        (LIG-1)
    [M:DPPE]RSDVALI     = [M:DPP1]RSDVAL2     (LIG-1)
    [M:DPPE]RSDVALT     = [M:DPP1]RSDVAL2     (LIG-1)
    [M:DPPE]RSDVAL      = [M:DPP1]RSDVAL2     (LIG-1)
    [M:DPPE]DPRVALI     = [M:DPP1]BSEVAL2     (LIG-1)  -  [M:DPP1]RSDVAL2     (LIG-1)
    [M:DPPE]DPRVALT     = [M:DPP1]DPRVAL2     (LIG-1)
    [M:DPPE]DPRVAL      = [M:DPP1]DPRVAL2     (LIG-1)
    [M:DPPE]BSEVALI     = [M:DPP1]BSEVAL2     (LIG-1)
    [M:DPPE]BSEVALT     = [M:DPP1]DPRBAS2     (LIG-1)
    [M:DPPE]DPRBAS      = [M:DPP1]DPRBAS2     (LIG-1)
    [M:DPPE]DPRCUMI     = [M:DPP1]PERCLOCUMI  (LIG-1)
    [M:DPPE]DPRCUMT     = [M:DPP1]PERCLOCUMT  (LIG-1)
    [M:DPPE]DPRCUM      = [M:DPP1]PERCLOCUM   (LIG-1)
    [M:DPPE]ENDDPEI     = [M:DPP1]DPEI        (LIG-1)
    [M:DPPE]ENDDPET     = [M:DPP1]DPET        (LIG-1)
    [M:DPPE]ENDDPE      = [M:DPP1]PERENDDPE   (LIG-1)
    [M:DPPE]EXCDPRI     = [M:DPP1]PEREXCDPRI  (LIG-1)
    [M:DPPE]EXCDPRT     = [M:DPP1]PEREXCDPRT  (LIG-1)
    [M:DPPE]EXCDPR      = [M:DPP1]PEREXCDPR   (LIG-1)
    [M:DPPE]NBVI        = [M:DPP1]NBVI2       (LIG-1)
    [M:DPPE]NBVT        = [M:DPP1]NBVT2       (LIG-1)
    [M:DPPE]NBV         = [M:DPP1]NBV2        (LIG-1)

   
  Endif
  #-1 -------------------

  #Fq63831-GBO
  Affzo [M:DPPA]    
  Affzo [M:DPPB]    
  Affzo [M:DPPC]    
  Affzo [M:DPPD]    
  Affzo [M:DPPE]    
  Affzo [M:DPPF]    

Return






##########################################
Subprog AV_ENDDPE(VALEUR)
Variable Decimal VALEUR

  # FQ64544
  If ( [M:DPPA]ENDDPEFLG = G_OUI) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:DPPA]ENDDPE With "FORCAGE"
      Chgstl [M:DPPE]ENDDPE With "FORCAGE"
    Else
      Chgstl [M:DPPA]ENDDPE With "TFORCAGE"
      Chgstl [M:DPPE]ENDDPE With "TFORCAGE"
    Endif
  Else
   Chgstl [M:DPPA]ENDDPE With ""
   Chgstl [M:DPPE]ENDDPE With ""
  Endif

End



