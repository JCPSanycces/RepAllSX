#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
# Select SAFE X3 components from the solution.xml file
#########################################################################
#########################################################################
#-----------------------------------------------------------------------#
# ACTIONS :
#
# SELJAV     : SELJAV     : Select the Java Server
#########################################################################
$ACTION
Case ACTION
 When "SEL_LISTE"     : Gosub SEL_LISTE
 When Default
Endcase
Return

#########################################################################
#    Selection from list
#########################################################################
$SEL_LISTE
Case LISTE
  When "SELJAV"   : Gosub S_JAV
Endcase
Return

#########################################################################
$S_JAV

Local Char TEX(50)(1..10),TEXTE(80)(1..10,1..3)
Local Char FAMILY,PROP1(100),PROP2(100),PROP3(100),VPROP(100)

Local Char NOMFIC(200),VALL1(200)
Local Integer I1,I2,I3

FAMILY = "SERVERJAVA"
PROP1  = "all.host.alias"
PROP2  = "component.serverjava.servername"
PROP3  = "all.host.port"

TIT(0) = mess(43,151,1)
TIT(1) = mess(21,151,1)
TIT(2) = mess(3,9716,1)
TIT(3) = mess(238,139,1)

OK=1

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : OK=2 : End : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat : End : Endif
Iomode adxifs "" Using [CST_]
Iomode adxirs chr$(10) Using [CST_]
Iomode adxium GUTF8 Using [CST_]
fstat=0
While !fstat
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"module")
    I3 = instr(1,toupper(VALL1),toupper(FAMILY))<>0
    Raz VPROP
  Endif
  If I3
    I1=instr(1,toupper(VALL1),toupper(PROP1))
    If I1
      If instr(I1+len(PROP1),toupper(VALL1),toupper(PROP1))
        I1=instr(I1+1,toupper(VALL1),">")
        I2=instr(I1+1,toupper(VALL1),"<")
        VPROP=mid$(VALL1,I1+1,I2-I1-1)
        NBTEX +=1
        TEX(NBTEX)     = VPROP
        TEXTE(NBTEX,1) = VPROP
      Endif
    Endif
    I1=instr(1,toupper(VALL1),toupper(PROP2))
    If I1
      If instr(I1+len(PROP2),toupper(VALL1),toupper(PROP2))
        I1=instr(I1+1,toupper(VALL1),">")
        I2=instr(I1+1,toupper(VALL1),"<")
        VPROP=mid$(VALL1,I1+1,I2-I1-1)
        TEXTE(NBTEX,2) = VPROP
      Endif
    Endif
    I1=instr(1,toupper(VALL1),toupper(PROP3))
    If I1
      If instr(I1+len(PROP3),toupper(VALL1),toupper(PROP3))
        I1=instr(I1+1,toupper(VALL1),">")
        I2=instr(I1+1,toupper(VALL1),"<")
        VPROP=mid$(VALL1,I1+1,I2-I1-1)
        TEXTE(NBTEX,3) = VPROP
      Endif
    Endif
  Endif
Wend
Openi Using [CST_]

Return
