#<AdxTL>@(#)12.0.0.0 $Revision$
Close Local File
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = "": #"ACTION"
Call TRAITE_CHAR(VALEUR,PARAM,"AIMP1","AIMP1","",3,"") From GTRAITE
End

$ACTION
Case GACTION
 When "AIMP2" : # Différé
  Gosub ACT_DIF
 When "AIMP21" : # Segmentation
  Gosub ACT_SEG
Endcase
Return

###########################################################
## Impressions différées
###########################################################
$ACT_DIF
Case ACTION
 When "DEBUT"  : Gosub DEBUT
 When "OK"     : Gosub OK
 When "FINSAI" : Affzo [RPT]IMPDIF
 When Default
Endcase
Return

$OK
[M:RPT] = [M]
If [M]DIFFERE=2
 [M:RPT]IMPDIF = 2 : # Impression différée
Else
 [M:RPT]IMPDIF = 1
Endif
Affzo [RPT]IMPDIF
Return

$DEBUT
[M] = [M:RPT]
[M]HOR = [F:ARP]HOR
If [F:ARP]HOR<>""
 Read [ABH]ABH0 = [F:ARP]HOR
 [M]HORDES = [F:ABH]DES
Else
 [M]HORDES = ""
Endif
Affzo
Return

###########################################################
## Segmentation
###########################################################
$ACT_SEG
Case ACTION
 When "DEBUT"      : Gosub DEBUT_SEG
 When "OK"         : Gosub OK_SEG
Endcase
Return

$DEBUT_SEG
[M:SEG]CODTYP = [M:RPT]PARTYP(nolign-1)
[M:SEG]LONG   = [M:RPT]LONG(nolign-1)
[M:SEG]NOLIB  = [M:RPT]NOLIB(nolign-1)
[M:SEG]NBLIG  = [M:RPT]NBSEG
For I=0 To [M:RPT]NBSEG-1
 [M:SEG]VALEUR(I) = [M:RPT]VALSEG(I)
 [M:SEG]VALINT(I) = [M:RPT]VALSEG(I)
Next I
Affzo [SEG]
Return

$OK_SEG
For I=1 To [M:SEG]NBLIG-1
 # Issue X3-48208 - 2017-11-02 by CCC : Compare VALINT as this value is used in fine to set VALSEG
 #If [M:SEG]VALEUR(I)<=[M:SEG]VALEUR(I-1)
 If [M:SEG]VALINT(I)<=[M:SEG]VALINT(I-1)
  GERR = 1 : GMESSAGE = mess(9,135,1) : FIN = 0 : Break
 Endif
Next I
[M:RPT]NBSEG = [M:SEG]NBLIG
For I=0 To [M:RPT]NBSEG-1
 [M:RPT]VALSEG(I) = [M:SEG]VALINT(I)
Next I
Return

########################################
## Ecran AIMP2
########################################
Subprog AS_DIFDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
If [M]DIFFERE<>2 : mkstat = 1 : End : Endif
If VALEUR=[0/0/0]
 VALEUR = date$
 Call CTLDAT([F:ARP]HOR,"","",VALEUR,OK) From ARQTSUB
 If !OK
  Call INIDAT([F:ARP]HOR,"","",VALEUR) From ARQTSUB
  [M]DIFTIM = "0000"
  Call INIHOR([F:ARP]HOR,"","",VALEUR,[M]DIFTIM,OK) From ARQTSUB
 Endif
Endif
End

Subprog C_DIFDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
Call CTLDAT([F:ARP]HOR,"","",VALEUR,OK) From ARQTSUB
If !OK : mkstat = 2 : End : Endif
End

Subprog AS_DIFTIM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M]DIFFERE<>2 : mkstat = 1 : End : Endif
If VALEUR=""
 VALEUR = left$(time$,2)+mid$(time$,4,2)
 Call CTLHOR([F:ARP]HOR,"","",[M]DIFDAT,VALEUR,OK) From ARQTSUB
 If !OK
  Call INIHOR([F:ARP]HOR,"","",[M]DIFDAT,VALEUR,OK) From ARQTSUB
 Endif
Endif
End

Subprog C_DIFTIM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Call CTLHOR([F:ARP]HOR,"","",[M]DIFDAT,VALEUR,OK) From ARQTSUB
If !OK : mkstat = 2 : End : Endif
End

