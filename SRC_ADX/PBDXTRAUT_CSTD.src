#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


########################################################################################################################
# Properties ###########################################################################################################

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

########################################################################################################################
# Methods ##############################################################################################################

# SAM # 111399 changed ACTION to AMETHOD
$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When "COLLECT"     : Gosub COLLECT_DATA
# 2015-05-19 DNE INSERT BEGIN
        When "POST_BEFORE" : Gosub POST_BEFORE
# 2015-05-19 DNE INSERT END
        When "EXPORT"      : Gosub EXPORT_FILE
      Endcase
  Endcase
Return

########################################################################################################################
# Params ###############################################################################################################
# Instance : PARAM_PBDGEN
$COLLECT_DATA
  If PARAM_PBDGEN = null Then
    # Nonexistent instance
    ASTATUS = fmet this.ASETERROR("", mess(6,112,1), [V]CST_AERROR)
    Return
  Endif

  Local Instance CONFIG Using C_PBDCONFIG
  [L]CONFIG = NewInstance C_PBDCONFIG AllocGroup null
  ASTATUS = fmet [L]CONFIG.AREAD(PARAM_PBDGEN.PBDCCODE, PARAM_PBDGEN.LEG)

  # root account
  Local File GACCENTRYD [DAER]
  Local File AGRPCPY    [AGCR]
  Local File COMPANY    [CPYR]

  # data
  Local File GACCENTRYD [DAE]
  Local File AGRPCPY    [AGC]
  Local File COMPANY    [CPY]
  Local File BPARTNER   [BPR]

  Local Clbfile ACCROOT
  [L]ACCROOT = func PBDXTRLIB.TRIGGERING_ACCOUNTS("[F:DAER]ACC", [L]CONFIG.ROOTACC)
  Local Clbfile ACCINCL
  [L]ACCINCL = func PBDXTRLIB.DATA_TO_INCLUDE([L]CONFIG, "[F:DAE]ACC", "[F:DAE]OFFACC", "[F:DAE]TYP", "[F:DAE]SNS")
  Local Clbfile ACCEXCL
  [L]ACCEXCL = func PBDXTRLIB.DATA_TO_EXCLUDE([L]CONFIG, "[F:DAE]ACC", "[F:DAE]OFFACC", "[F:DAE]TYP")
#  Gosub DUMP_RULES

  If PARAM_PBDGEN.ISGRP = [V]CST_ATRUE Then
    # group of companies
    Link [F:DAER] With
&     [F:DAE]DAE0(2) = [F:DAER]TYP;[F:DAER]NUM,
&     [F:AGC]AGC1 = [F:DAER]CPY,
&     [F:CPY]CPY0 = [F:AGC]CPY,
&     [F:BPR]BPR0 = [F:DAE]OFFACC
&   As [LNK]
&   Where [F:DAER]CPY = PARAM_PBDGEN.GRPORCPY
&     and [F:DAER]LEDTYP = [L]CONFIG.LEDTYP
&     and [F:DAER]ACCDAT >= PARAM_PBDGEN.DATEFROM
&     and [F:DAER]ACCDAT <= PARAM_PBDGEN.DATETO
&     and [F:CPY]CRY <> [F:BPR]CRY
&     and evalue([L]ACCROOT)
&     and evalue([L]ACCINCL)
&     and evalue([L]ACCEXCL)
&   Order By [F:DAER]ACCNUM;[F:DAE]ACCNUM
  Else
    # company
    Link [F:DAER] With
&     [F:DAE]DAE0(2) = [F:DAER]TYP;[F:DAER]NUM,
&     [F:CPY]CPY0 = [F:DAER]CPY,
&     [F:BPR]BPR0 = [F:DAE]OFFACC
&   As [LNK]
&   Where [F:DAER]CPY = PARAM_PBDGEN.GRPORCPY
&     and [F:DAER]LEDTYP = [L]CONFIG.LEDTYP
&     and [F:DAER]ACCDAT >= PARAM_PBDGEN.DATEFROM
&     and [F:DAER]ACCDAT <= PARAM_PBDGEN.DATETO
&     and [F:CPY]CRY <> [F:BPR]CRY
&     and evalue([L]ACCROOT)
&     and evalue([L]ACCINCL)
&     and evalue([L]ACCEXCL)
&   Order By [F:DAER]ACCNUM;[F:DAE]ACCNUM
  Endif

  Local Char TMPECOCOD(250)
  Local Char TMPVAL(255)
  Local File PBDBPGRPD [PBDBPD]
  Local Instance ECOCOD Using C_PBDECOCOD
  [L]ECOCOD = NewInstance C_PBDECOCOD AllocGroup null
  Local Instance GENLINE Using C_PBDGEND
  [L]GENLINE = NewInstance C_PBDGEND AllocGroup null
  Local Integer J : [L]J = 1
  Local Char LISTOFCLANUMS(10)(0..) # contains all postings with activated balance flag
  For [LNK]
    Gosub PROCESS_JOURNAL
    If ASTATUS <> [V]CST_AOK
      Local Integer K
      For [L]K = 1 To maxtab([L]GENLINE.AERROR)
        Local Integer IGNORE
        [L]IGNORE = fmet this.ASETERROR([L]GENLINE.AERROR([L]K).PRO, [L]GENLINE.AERROR([L]K).MES, [L]GENLINE.AERROR([L]K).STA)
      Next [L]K
      Break
    Endif
    [L]J += 1
  Next
  FreeGroup [L]GENLINE
  FreeGroup [L]ECOCOD

  FreeGroup [L]CONFIG

  # balance flag activated
  Gosub BALANCE_POSTINGS
Return

########################################################################################################################
# Params ###############################################################################################################
# Instance : PARAM_PBDGEN
$EXPORT_FILE
  If PARAM_PBDGEN = null Then
    # Nonexistent instance
    ASTATUS = fmet this.ASETERROR("", mess(6,112,1), [V]CST_AERROR)
    Return
  Endif
  If PARAM_PBDGEN.LEG <> "AUT" Then
    # Legislation differs from 'AUT'
    ASTATUS = fmet this.ASETERROR("", mess(387,107,1) - "'AUT'.", [V]CST_AERROR)
    Return
  Endif

  Local Char DECL_ID(2) : [L]DECL_ID = "ZB"
  Local Char EUVATID(11)
  [L]EUVATID = func GET_EUVATID(PARAM_PBDGEN.ISGRP, PARAM_PBDGEN.GRPORCPY)
  Local Char ZBYEAR(4)
  Local Char ZBQUART(1)
  Call GET_DATES(PARAM_PBDGEN.DATETO, [L]ZBYEAR, [L]ZBQUART)
  Local Char DECLTYPE(1)
  Local Char CONTACT_NAME(20)
  Local Char CONTACT_MAIL(30)
  Local Char CONTACT_PHONE(GLONTEL)
  Call GET_CONTACT(this.ACTX.USER, PARAM_PBDGEN.ISGRP, PARAM_PBDGEN.GRPORCPY, [L]CONTACT_NAME, [L]CONTACT_MAIL, [L]CONTACT_PHONE)

  If [L]CONTACT_PHONE = "" Then
    ASTATUS = fmet this.ASETERROR("", mess(390,107,1), [V]CST_AERROR)
    Return
  Endif

  Local Integer EXPORT_ERROR : [L]EXPORT_ERROR = 0
  Local Char VOLUME(20) : [L]VOLUME = "TMP"
  Local Char NAME(100)
  If PARAM_PBDGEN.ISGRP = [V]CST_AYES Then
    [L]NAME = "PBDZABIL-GRP"
  Else
    [L]NAME = "PBDZABIL-CPY"
  Endif
  [L]NAME += PARAM_PBDGEN.GRPORCPY
  [L]NAME += "_" + format$("D:DDMMYYYY", PARAM_PBDGEN.DATEFROM) + "-" + format$("D:DDMMYYYY", PARAM_PBDGEN.DATETO)
  [L]NAME += ".csv"
  Local Char PATHSRV(255)
#  [L]PATHSRV = filpath([L]VOLUME, [L]NAME, [L]EXT)
  [L]PATHSRV = func ASYRSTO.GETFULLPATH([L]VOLUME, [L]NAME)

  Onerrgo EXPORT_FILE_ERROR
  Openo [L]PATHSRV, 0 Using [PBDEXP]
  Onerrgo
  If [L]EXPORT_ERROR <> 0 Then
    Return
  Endif

  Local Instance CONFIG Using C_PBDCONFIG
  [L]CONFIG = NewInstance C_PBDCONFIG AllocGroup null
  ASTATUS = fmet [L]CONFIG.AREAD(PARAM_PBDGEN.PBDCCODE, PARAM_PBDGEN.LEG)

  Local Char LISTOFADL(10)(0..)
  Local Char LISTOFCRY(10)(0..)

  # CSV columns
  Local Char CRYCODE(2)
  Local Char ADLCODE(4)
  Local Char ZBEXPORT(255) : [L]ZBEXPORT = ""
  Local Char ZBIMPORT(255) : [L]ZBIMPORT = ""
  Local Decimal EXPORT
  Local Decimal IMPORT
  Local Integer I
  Local Integer NOTPROCESSED : [L]NOTPROCESSED = 1

  Local File PBDGEND [PBDGEND]
& Where [F:PBDGEND]CODE     = PARAM_PBDGEN.CODE
&   and [F:PBDGEND]LEG      = PARAM_PBDGEN.LEG
&   and [F:PBDGEND]ISDETAIL = [V]CST_ANO
&   and [F:PBDGEND]ISOITEM  = [V]CST_AYES

  Local Integer K
  Local Integer TOTAL : [L]TOTAL = rowcount([F:PBDGEND])

  For [F:PBDGEND]
    # CSV columns
    [L]CRYCODE = ""
    [L]ADLCODE = ""
    [L]ZBEXPORT = ""
    [L]ZBIMPORT = ""
    [L]EXPORT = 0
    [L]IMPORT = 0
    [L]NOTPROCESSED = 1

    # determine if ADL-CRY-pair is already processed - necessary, because
    # incoming and outgoing values are located in the same line in the export file but are different lines in database
    For [L]I = 0 To dim([L]LISTOFADL) Step 1
      If [L]LISTOFADL([L]I) = "" : Break : Endif
      If [F:PBDGEND]ECOCOD = [L]LISTOFADL([L]I) and [F:PBDGEND]BPRCRY = [L]LISTOFCRY([L]I)
        [L]NOTPROCESSED = 0
        Break
      Endif
    Next

    If [L]NOTPROCESSED and [F:PBDGEND]ECOCOD <> "" and [F:PBDGEND]BPRCRY <> "" Then
      Call ASYNCTRACK(PARAM_PBDGEN.ACTX, PARAM_PBDGEN.CODE, [F:PBDGEND]ECOCOD, int(100 * ([L]K / [L]TOTAL))) From ASYRASYNC

      [L]ADLCODE = [F:PBDGEND]ECOCOD
      [L]CRYCODE = func PBDXTRLIB.GET_ISO_3166_1_ALPHA2([F:PBDGEND]BPRCRY)
#      [L]CRYCODE = [F:PBDGEND]BPRCRY

      If [F:PBDGEND]ORIENT = 1 Then
        # incoming
        [L]IMPORT = [F:PBDGEND]AMOUNT
        [L]EXPORT = func GET_MATCHING_AMOUNT([F:PBDGEND]CODE, [F:PBDGEND]LEG, 2)
      Else
        # outgoing
        [L]EXPORT = [F:PBDGEND]AMOUNT
        [L]IMPORT = func GET_MATCHING_AMOUNT([F:PBDGEND]CODE, [F:PBDGEND]LEG, 1)
      Endif

#      If [L]EXPORT <> 0 or [L]IMPORT <> 0 Then # only lines with a valid (<> 0) amount
      If arr(abs([L]EXPORT), 1) >= abs([L]CONFIG.AMTLIMIT) or arr(abs([L]IMPORT), 1) >= abs([L]CONFIG.AMTLIMIT) Then # only lines with a valid (<> 0) amount
        If [L]EXPORT <> 0 Then
          [L]ZBEXPORT = num$(arr(abs([L]EXPORT), 1))
        Endif
        If [L]IMPORT <> 0 Then
          [L]ZBIMPORT = num$(arr(abs([L]IMPORT), 1))
        Endif
        Wrseq [L]DECL_ID + ";"
&         + [L]EUVATID + ";"
&         + [L]ZBYEAR + ";"
&         + [L]ZBQUART + ";"
&         + [L]DECLTYPE + ";"
&         + [L]CONTACT_NAME + ";"
&         + [L]CONTACT_PHONE + ";"
&         + [L]CONTACT_MAIL + ";"
&         + [L]CRYCODE + ";"
&         + [L]ADLCODE + ";"
&         + [L]ZBEXPORT + ";"
&         + [L]ZBIMPORT Using [PBDEXP]
#        ASTATUS = fmet this.ASETERROR("", [L]DECL_ID + ";"
#&         + [L]EUVATID + ";"
#&         + [L]ZBYEAR + ";"
#&         + [L]ZBQUART + ";"
#&         + [L]DECLTYPE + ";"
#&         + [L]CONTACT_NAME + ";"
#&         + [L]CONTACT_PHONE + ";"
#&         + [L]CONTACT_MAIL + ";"
#&         + [L]CRYCODE + ";"
#&         + [L]ADLCODE + ";"
#&         + [L]ZBEXPORT + ";"
#&         + [L]ZBIMPORT, [V]CST_ASUCCESS)
      Endif

      [L]I = 0
      While [L]LISTOFCRY([L]I) <> ""
        [L]I += 1
      Wend
      [L]LISTOFADL([L]I) = [F:PBDGEND]ECOCOD
      [L]LISTOFCRY([L]I) = [F:PBDGEND]BPRCRY
    Endif

    [L]K += 1
    If func ASYRASYNC.ABORTREQUESTED(PARAM_PBDGEN.ACTX) Then
      # Export incomplete
      Call ADDDIAGNOSE(PARAM_PBDGEN.ACTX, mess(243,123,1)-mess(258,193,1), [V]CST_AERROR) From ASYRASYNC
      Break
    Endif
  Next

  FreeGroup [L]CONFIG
  Openo Using [PBDEXP]

  Raz [L]LISTOFADL
  Raz [L]LISTOFCRY

  If not func ASYRASYNC.ABORTREQUESTED(PARAM_PBDGEN.ACTX) Then
    Call ASYNCTRACK(PARAM_PBDGEN.ACTX, "", "", 100) From ASYRASYNC
    Call ADDLINKDOWNLOAD(PARAM_PBDGEN.ACTX, "ATYPE10-1", "[" + [L]VOLUME + "]/" + [L]NAME) From ASYRASYNC
  Endif
Return

$EXPORT_FILE_ERROR
  [L]EXPORT_ERROR = 1
Resume


# 2015-05-19 DNE INSERT BEGIN
########################################################################################################################
# Params ###############################################################################################################
# Instance : PARAM_PBDGEN
$POST_BEFORE
    ARET_VALUE = [V]CST_AOK
Return
# 2015-05-19 DNE INSERT END

########################################################################################################################
# Private ##############################################################################################################

$PROCESS_JOURNAL
  Local Instance CONFIGLINE Using C_PBDCONFIGD
  If func MATCH_INCLUDE_RULE([L]CONFIG, [F:DAE]ACC, [F:DAE]TYP, [L]CONFIGLINE) = [V]CST_ATRUE Then
    # a matching configuration line is found
    # check whether a BP is specified
    If [L]CONFIGLINE.BPGROUP <> "" Then
      For [F:PBDBPD]PBDBPD0 Where [F:PBDBPD]COD = [L]CONFIGLINE.BPGROUP and [F:PBDBPD]LEG = PARAM_PBDGEN.LEG
        [L]TMPVAL = [F:PBDBPD]BPR
        If right$([L]TMPVAL, len([L]TMPVAL)) <> "*" Then
          If [L]TMPVAL = [F:DAER]BPR
            [L]TMPECOCOD = [F:PBDBPD]ECOCOD
            Break
          Endif
        Elsif [L]TMPVAL = "*" or left$([L]TMPVAL, len([L]TMPVAL) - 1) = left$([F:DAER]BPR, len([L]TMPVAL) - 1)
          [L]TMPECOCOD = [F:PBDBPD]ECOCOD
          Break
        Endif
      Next
      ASTATUS = fmet ECOCOD.AREAD([L]TMPECOCOD, PARAM_PBDGEN.LEG)
    Else
      ASTATUS = fmet ECOCOD.AREAD([L]CONFIGLINE.PBDECO, PARAM_PBDGEN.LEG)
    Endif

    [L]GENLINE.CODE     = PARAM_PBDGEN.CODE
    [L]GENLINE.LEG      = PARAM_PBDGEN.LEG
    [L]GENLINE.ISDETAIL = [V]CST_AYES
    [L]GENLINE.ISOITEM  = [V]CST_AYES
    [L]GENLINE.LINE     = [L]J
    [L]GENLINE.ECOCOD = [L]ECOCOD.COD
    [L]GENLINE.ECOTYP = [L]ECOCOD.TYP
    [L]GENLINE.ECODES = [L]ECOCOD.DES
    [L]GENLINE.ACCNUM = [F:DAE]ACCNUM
    [L]GENLINE.ACCDAT = [F:DAE]ACCDAT
    [L]GENLINE.DOCTYP = [F:DAE]TYP
    [L]GENLINE.DOCNUM = [F:DAE]NUM
    [L]GENLINE.BPR    = [F:BPR]BPRNUM
    [L]GENLINE.BPRCRY = [F:BPR]CRY
#    [L]GENLINE.BPRCRY = func PBDXTRLIB.GET_ISO_3166_1_ALPHA2([F:BPR]CRY)

    Case [L]CONFIG.AMOUNT
      When 1 # Original transaction currency
        [L]GENLINE.AMOUNT = [F:DAE]SNS * [F:DAE]AMTCUR
        [L]GENLINE.CUR = [F:DAE]CUR
      When 2 # Ledger currency
        [L]GENLINE.AMOUNT = [F:DAE]SNS * [F:DAE]AMTLED
        [L]GENLINE.CUR    = [F:DAE]CURLED
#      Default
        #TODO: implement proper error handling
    Endcase
    If [L]CONFIG.AMTTYPE = 2 Then
      # Include tax
      [L]GENLINE.AMOUNT = func PBDXTRLIB.APPLY_TAX([L]GENLINE.LEG, [L]GENLINE.AMOUNT, [F:DAE]CPY, [F:DAE]TAX, [F:DAE]ACCDAT)
    Endif
    [L]GENLINE.AMOUNT = arr([L]GENLINE.AMOUNT, 1)
    [L]GENLINE.FLG    = 1 # create
    [L]GENLINE.BALFLG = [L]CONFIGLINE.BALAMT
    [L]GENLINE.ORIENTCFG = [L]CONFIGLINE.ORIENT
    If [L]GENLINE.BALFLG = [V]CST_ANO Then
      [L]GENLINE.ORIENT = func DETERMINE_ORIENTATION([L]CONFIGLINE, [L]GENLINE.AMOUNT)
    Else
      If [L]GENLINE.ECOCOD = "" Then
        # Postings with enabled balance and without ecocode are incomplete.
        ASTATUS = fmet this.ASETERROR("", mess(386,107,1), [V]CST_AWARNING)
      Else
        Gosub ADD_TO_LIST
      Endif
    Endif
#    Infbox("ACCNUM=" + num$([F:DAE]ACCNUM) + ": ASTATUS=" + num$(ASTATUS) + " (LINE=" + num$([L]J) + ")")

    ASTATUS = fmet [L]GENLINE.AINSERT()
  Endif
Return

########################################################################################################################
# LISTOFCLANUMS contains all postings with activated balance flag
$ADD_TO_LIST
  Local Integer I : [L]I = 0

  While [L]LISTOFCLANUMS([L]I) <> ""
    If [L]LISTOFCLANUMS([L]I) = [L]GENLINE.ECOCOD Then
      Return
    Endif
    [L]I += 1
  Wend
  [L]LISTOFCLANUMS([L]I) = [L]GENLINE.ECOCOD
Return

########################################################################################################################
# Apply orientation to postings with activated balance flag ############################################################
$BALANCE_POSTINGS
  Local File PBDGEND [PBDGEND]
  Local Decimal BALANCE
  Local Integer ORIENTATION
  For [L]J = 0 To dim([L]LISTOFCLANUMS) Step 1
    If [L]LISTOFCLANUMS([L]J) = "" Then
      Break
    Endif
    Filter [F:PBDGEND]
&   Where [F:PBDGEND]CODE = PARAM_PBDGEN.CODE
&     and [F:PBDGEND]LEG  = PARAM_PBDGEN.LEG
&     and [F:PBDGEND]ISDETAIL = [V]CST_AYES
&     and [F:PBDGEND]ISOITEM  = [V]CST_AYES
&     and [F:PBDGEND]ECOCOD   = [L]LISTOFCLANUMS([L]J)
&     and [F:PBDGEND]BALFLG   = [V]CST_AYES
    [L]BALANCE = 0
    For [F:PBDGEND]
      [L]BALANCE += [F:PBDGEND]AMOUNT
    Next
    [L]ORIENTATION = 0
    Case [F:PBDGEND]ORIENTCFG
      When 1
        # Credit=incoming; Debit=outgoing
        If [L]BALANCE < 0 Then # Credit
          [L]ORIENTATION = 1
        Else
          [L]ORIENTATION = 2
        Endif
      When 2
        # Credit=outgoing; Debit=incoming
        If [L]BALANCE < 0 Then # Credit
          [L]ORIENTATION = 2
        Else
          [L]ORIENTATION = 1
        Endif
    Endcase
    Local Integer OK : [L]OK = 1
    Trbegin [F:PBDGEND]
    For [F:PBDGEND]
      [F:PBDGEND]ORIENT = [L]ORIENTATION
      Rewrite [F:PBDGEND]
      If fstat <> 0 Then
        [L]OK = 0
        Break
      Endif
    Next
    If [L]OK = 1 Then
      Commit
    Else
      Rollback
      # The modification of PBDGEND has failed
      ASTATUS = fmet this.ASETERROR("", func AFNC.MES1(mess(2,2260,1), "PBDGEND"), [V]CST_AERROR)
    Endif
  Next [L]J
Return

########################################################################################################################
# Check for matching rules #############################################################################################

# return [V]CST_ATRUE if config line matches
Funprog MATCH_INCLUDE_RULE(VCONFIG, VACC, VTYP, RCONFIGLINE)
  Variable Instance VCONFIG Using C_PBDCONFIG
  Value Char VACC()
  Value Char VTYP()
  Variable Instance RCONFIGLINE Using C_PBDCONFIGD

  RCONFIGLINE = null
  If VCONFIG = null Then
    End [V]CST_AFALSE
  Endif

  Local Integer I
  Local Instance CONFIGLINE Using C_PBDCONFIGD
  For [L]I = 1 To maxtab(VCONFIG.LINESINCL)
    [L]CONFIGLINE = VCONFIG.LINESINCL([L]I)
    Local Integer ACCLEN
    [L]ACCLEN = len([L]CONFIGLINE.CROOTACC)
    # an asterisk is allowed to be used with the CROOTACC field
    If right$([L]CONFIGLINE.CROOTACC, [L]ACCLEN) = "*" Then
      If instr(1, VACC, left$([L]CONFIGLINE.CROOTACC, [L]ACCLEN - 1)) = 1 and [L]CONFIGLINE.DOCTYPE = VTYP Then
        RCONFIGLINE = [L]CONFIGLINE
        End [V]CST_ATRUE
      Endif
      If instr(1, VACC, left$([L]CONFIGLINE.CROOTACC, [L]ACCLEN - 1)) = 1 and [L]CONFIGLINE.DOCTYPE = "" Then
        RCONFIGLINE = [L]CONFIGLINE
        End [V]CST_ATRUE
      Endif
    Else
      If [L]CONFIGLINE.CROOTACC = VACC and [L]CONFIGLINE.DOCTYPE = VTYP Then
        RCONFIGLINE = [L]CONFIGLINE
        End [V]CST_ATRUE
      Endif
      If [L]CONFIGLINE.CROOTACC = VACC and [L]CONFIGLINE.DOCTYPE = "" Then
        RCONFIGLINE = [L]CONFIGLINE
        End [V]CST_ATRUE
      Endif
    Endif
  Next [L]I
End [V]CST_AFALSE

########################################################################################################################
# Determine the orientaion #############################################################################################
Funprog DETERMINE_ORIENTATION(VCONFIGLINE, VAMOUNT)
  Variable Instance VCONFIGLINE Using C_PBDCONFIGD
  Value Double VAMOUNT
  Local Integer LRESULT

  Case VCONFIGLINE.ORIENT
    When 1
      # Credit=incoming; Debit=outgoing
      If VAMOUNT < 0 Then # Credit
        [L]LRESULT = 1
      Else
        [L]LRESULT = 2
      Endif
    When 2
      # Credit=outgoing; Debit=incoming
      If VAMOUNT < 0 Then # Credit
        [L]LRESULT = 2
      Else
        [L]LRESULT = 1
      Endif
#    Default
    #TODO: implement proper error handling
  Endcase
End [L]LRESULT

########################################################################################################################
# Determine EU VAT ID ##################################################################################################
Funprog GET_EUVATID(VISGRP, VGRPORCPY)
  Value Integer VISGRP
  Value Char VGRPORCPY()

  Local File COMPANY [CPY]
  If VISGRP Then
    Local File AGRPCPY [AGC] Where [F:AGC]GRP = VGRPORCPY
    For [F:AGC]
      Local Char VATLECMP(10)
      #angre X3-103750
      If func AFNC.ACTIV("KDEAT")
          [L]VATLECMP = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY, [F:AGC]CPY, "VATLECMP")
#      ASTATUS = fmet this.ASETERROR("[F:AGC]CPY=" + [F:AGC]CPY, "VATLECMP=" + [L]VATLECMP, [V]CST_ASUCCESS)
          If [L]VATLECMP <> "" Then
          Break
        Endif
      Endif
    Next
    If [L]VATLECMP = "" Then
      ASTATUS = fmet this.ASETERROR("", mess(389,107,1), [V]CST_AERROR)
      End "n/a"
    Endif
    Read [F:CPY]CPY0 = [L]VATLECMP
  Else
    Read [F:CPY]CPY0 = VGRPORCPY
  Endif
  If fstat = 0 Then
    End [F:CPY]EECNUM
  Endif
  # $1$ company does not exist.
  If VISGRP Then
    ASTATUS = fmet this.ASETERROR("", func AFNC.MES1(mess(57,7711,1), [L]VATLECMP), [V]CST_AERROR)
  Else
    ASTATUS = fmet this.ASETERROR("", func AFNC.MES1(mess(57,7711,1), VGRPORCPY), [V]CST_AERROR)
  Endif
End "n/a"

########################################################################################################################
########################################################################################################################
Subprog GET_DATES(VDATEND, RYEAR, RQUART)
  Value Date VDATEND
  Variable Char RYEAR
  Variable Char RQUART
  Local Integer MON

  RYEAR = num$(year(VDATEND))

  [L]MON = month(VDATEND)
  If [L]MON < 4 Then
    RQUART = num$(1)
  Elsif [L]MON < 7 Then
    RQUART = num$(2)
  Elsif [L]MON < 10 Then
    RQUART = num$(3)
  Else
    RQUART = num$(4)
  Endif
End

########################################################################################################################
# Get contact data #####################################################################################################
Subprog GET_CONTACT(VUSER, VISGRP, VGRPORCPY, RNAME, RMAIL, RPHONE)
  Value Char VUSER()
  Value Integer VISGRP
  Value Char VGRPORCPY()
  Variable Char RNAME()
  Variable Char RMAIL()
  Variable Char RPHONE()

  Local File AUTILIS [AUS]
  Read [F:AUS]CODUSR = VUSER
  If fstat = 0 Then
    RNAME = [F:AUS]NOMUSR
    RMAIL = [F:AUS]ADDEML
    RPHONE = [F:AUS]TELEP
    If RPHONE = "" Then
      RPHONE = func GET_PHONE_NUMBER(VUSER, VISGRP, VGRPORCPY)
    Endif
  Endif
End

Funprog GET_PHONE_NUMBER(VUSER, VISGRP, VGRPORCPY)
  Value Char VUSER()
  Value Integer VISGRP
  Value Char VGRPORCPY()
  Local Char RESULT(GLONTEL)

  # the phone number for the default address for USER
  [L]RESULT = func GET_USER_DEF_ADDR_PHONE_NUMBER(VUSER)
  If [L]RESULT <> "" Then
    End [L]RESULT
  Endif
  # company or group of companies?
  If VISGRP Then
    [L]RESULT = func GET_COMPANY_GROUP_FIRST_DEF_ADDR_PHONE_NUMBER(VGRPORCPY)
  Else
    [L]RESULT = func GET_COMPANY_DEF_ADDR_PHONE_NUMBER(VGRPORCPY)
  Endif
End [L]RESULT

Funprog GET_USER_DEF_ADDR_PHONE_NUMBER(VUSER)
  Value Char VUSER()
  Local Char RESULT(GLONTEL)

  Local File BPADDRESS [BPA] Where [F:BPA]BPATYP = 4 and [F:BPA]BPANUM = VUSER Order By [F:BPA]BPAADDFLG Desc
  Read [F:BPA] First
  If fstat = 0 Then
    [L]RESULT = [F:BPA]TEL(0)
  Endif
End [L]RESULT

Funprog GET_COMPANY_DEF_ADDR_PHONE_NUMBER(VCPY)
  Value Char VCPY()
  Local Char RESULT(GLONTEL)

  Local File BPADDRESS [BPA] Where [F:BPA]BPATYP = 2 and [F:BPA]BPANUM = VCPY Order By [F:BPA]BPAADDFLG Desc
  Read [F:BPA] First
  If fstat = 0 Then
    [L]RESULT = [F:BPA]TEL(0)
  Endif
End [L]RESULT

Funprog GET_COMPANY_GROUP_FIRST_DEF_ADDR_PHONE_NUMBER(VGRP)
  Value Char VGRP()
  Local Char RESULT(GLONTEL)

  Local File AGRPCPY [AGC] Where [F:AGC]GRP = VGRP
  For [F:AGC]
    [L]RESULT = func GET_COMPANY_DEF_ADDR_PHONE_NUMBER([F:AGC]CPY)
    If [L]RESULT <> "" Then
      Break
    Endif
  Next
End [L]RESULT

########################################################################################################################
# Get matching amount ##################################################################################################
Funprog GET_MATCHING_AMOUNT(VCODE, VLEG, VORIENTATION)
  Value Char VCODE()
  Value Char VLEG()
  Value Integer VORIENTATION

  Local File PBDGEND [PBDMATCH]

  Filter [F:PBDMATCH]
& Where [F:PBDMATCH]CODE = VCODE
&   and [F:PBDMATCH]LEG = VLEG
&   and [F:PBDMATCH]ISDETAIL = [V]CST_ANO
&   and [F:PBDMATCH]ISOITEM = [V]CST_AYES
&   and [F:PBDMATCH]ORIENT = VORIENTATION
  Read [F:PBDMATCH] First
  If fstat = 0 Then
    End [F:PBDMATCH]AMOUNT
  Endif
End 0

########################################################################################################################

$DUMP_RULES
  Local Char PATHSRV(255)
  [L]PATHSRV = func ASYRSTO.GETFULLPATH("TMP", "togan.log")
  Openo [L]PATHSRV, 0 Using [TOGAN]
  Wrseq "ACCROOT=" + [L]ACCROOT Using [TOGAN]
  Wrseq "ACCINCL=" + [L]ACCINCL Using [TOGAN]
  Wrseq "ACCEXCL=" + [L]ACCEXCL Using [TOGAN]
  Openo Using [TOGAN]
Return

