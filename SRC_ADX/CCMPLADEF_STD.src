#<AdxTL>@(#)0.0.0.0 $Revision$

Subprog VERF_PARAM(PARAM, VALEUR, OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

  Local Char CCMPLANNER(30)

  If (clalev([AUS]) = 0) : Local File AUTILIS [AUS] : Endif

  Read [AUS]CODUSR = VALEUR

  If (fstat = 0)
    Call PARAMUTIL("CCMPLANNER", CCMPLANNER, [F:AUS]USR, "") From SUBAUS
    If (CCMPLANNER <> "2")
      OK = 0
      MESSAGE = func ASYRFNC.MES1(mess(74,2038,1),VALEUR)
      GMESSAGE = MESSAGE
      GERR = 1
    Endif
  Elsif (VALEUR <> "")
    OK = 0
    MESSAGE = func ASYRFNC.MES1(mess(14,2038,1),VALEUR)
    GMESSAGE = MESSAGE
    GERR = 1
  Endif

  Close Local File [AUS]

End

