#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation: CCMPLANHF1 ...
# Based on standard Plan Representation: CCMPLANH, but filtered on ~
# Plan selected if logged-in user is an actioner and Change Request @ status 'Implement'.

$METHODS

  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
  Endcase

Return

$AQUERY_TRANS_AFTER

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet CHANGE_REQUEST.AREAD(this.CCMPH.CRID)

  ASTATUS = CST_AERROR
  If (CHANGE_REQUEST.CRSTATUS = 5)  # Implement
    If (clalev([CCMPD]) = 0) : Local File CCMPLAND [CCMPD] : Endif
    For [CCMPD] Where CRID = this.CCMPH.CRID and ACTIONER = this.ACTX.USER
      ASTATUS = CST_AOK
    Next
  Endif

  FreeGroup CHANGE_REQUEST

Return

$PROPERTIES
Case [L]CURPRO
Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

