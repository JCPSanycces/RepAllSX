#<AdxTL>@(#)8.0.0.0 $Revision$
##################################################################################
#   Import d'un objet de type normal
##################################################################################

#CHECK UNUSED_BEGIN

$CHARGEMSK
Gosub SETCLE
[F:AAA_] = [F]
If GPRODUIT=1 : ## GEODE GX # Vérification de l’environnement
 Case [M:IMP2]TYPENV
  When 1
   Read [FCY]FCY0 = GFCY
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(1,310,1)-GFCY) From SUBIMPOBJ : # Site
   Endif
  When 2
   Read [DEP]DEP0 = GFCY;GDEP
   If fstat
    OK=0 : Call TRACE(2,GCLE-mess(2,310,1)-GFCY-GDEP) From SUBIMPOBJ : # Déposant
   Endif
 Endcase
 If !OK : Return : Endif
Endif
Assign "[G:"+ABFIC+"]currind" With 1
Read =
If fstat
 If GPRODUIT=1 : ## GEODE GX
  # si import en 2 phases, pas de création en phase 2
  If ![M:IMP2]IMPORTN & [M:IMP2]IMPORT2=2 : [F]=[F:AAA_] : Return : Endif
  # verrouillage en création de fiche
  CHAINE = "C"
  Gosub VERROU
  If !OK : Return : Endif
 Endif
 CLECUR = 0
 [F] = [F:AAA_]
 CHAINE = "C"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 GREP = "C" : REP = "C"
 ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
 OK=(instr(1,CHAINE,"C")<>0)
 If OK & (dim([M:AOE1]OPTCRE)<0 | [M:AOE1]OPTCRE=2) : # (1)
  Gosub SET_AUTOR
  If !CRE
   OK = 0 : Call TRACE2(2,GCLE-ERRMES,-1) From SUBIMPOBJ
   GREP = "" : REP = ""
  #Else
  # GREP = "C" : REP = "C"
  # ACTION = "RAZCRE"      : Gosub ACTIONG From SUBIMPOBJ
  # ACTION = "IMP_RAZCRE"  : Gosub ACTION From SUBIMPOBJ
  Endif
 Elsif OK
  Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = "" : REP = ""
 Else
  Call TRACE2(2,GCLE-mess(7,123,1),-1) From SUBIMPOBJ : # Création impossible
  GREP = "" : REP = ""
 Endif
Else
 If GPRODUIT=1 : ## GEODE GX
  # si import en 2 phases, pas de modification en phase 1
  If ![M:IMP2]IMPORTN & [M:IMP2]IMPORT2=1 : [F]=[F:AAA_] : Return : Endif
  # verrouillage en modification de fiche
  CHAINE = "M"
 Endif
 Gosub VERROU
 If !OK : Return : Endif
 nolign = 1
 For IMA=0 To NBMASK
  If AMA(IMA)
   Gosub CHARGEMSK From =WINPROG
  Endif
 Next IMA
 ACTION = "LIENS"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_LIENS" : Gosub ACTION  From SUBIMPOBJ
 CLECUR = 1
 CHAINE = "M"
 ACTION = "SETBOUT"     : Gosub ACTIONG From SUBIMPOBJ
 ACTION = "IMP_SETBOUT" : Gosub ACTION  From SUBIMPOBJ
 If instr(1,CHAINE,"M")
  OK = 1
  ACTION = "AVANT_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ACTION = "IMP_AVANT_MOD" : Gosub ACTION  From SUBIMPOBJ
 Else
  OK = 0
 Endif
 If OK & [M:AOE1]OPTUPD=2
  GREP = "M" : REP = "M"
  Gosub SET_AUTOR
  If !MODI
   OK = 0 : Call TRACE2(2,GCLE-ERRMES,-1) From SUBIMPOBJ
   GREP = "" : REP = ""
  Elsif dim([L]ZSITE)>0 & [L]ZSITE<>""
   If evalue("[M]"+[L]ZSITE)<>evalue("[F:AAA_]"+[L]ZSITE)
    If !SUPPR
     OK = 0 : Call TRACE2(2,GCLE-mess(9,123,1),-1) From SUBIMPOBJ : # Modification impossible
     GREP = "" : REP = ""
    Endif
    If evalue("[F:AAA_]"+[L]ZSITE)<>""
     If GUSRFCY(1)<>"\"
      ISITE = find(evalue("[F:AAA_]"+[L]ZSITE),GUSRFCY(1..GNBAUZ))
     Else
      ISITE = 1
     Endif
     If ISITE=0 | !(instr(1,GUSRAUZ(ISITE),"C"))
      OK = 0 : Call TRACE2(2,GCLE-evalue("[F:AAA_]"+[L]ZSITE)-mess(2,104,1),-1) From SUBIMPOBJ
      # Vous n'avez pas les droits pour ce site
      GREP = "" : REP = ""
     Endif
    Endif
   Endif
  Endif
 Elsif OK
  Call TRACE2(1,GCLE-mess(105,141,1),-1) From SUBIMPOBJ : # Opération non effectuée
  GREP = "" : REP = ""
 Else
  OK = 0 : Call TRACE2(2,GCLE-mess(9,123,1),-1) From SUBIMPOBJ : # Modification impossible
  GREP = "" : REP = ""
 Endif
Endif
[F] = [F:AAA_]
Return

$VERROU
OK = 1
ACTION = "VERROU"     : Gosub ACTIONG From SUBIMPOBJ
If !OK : Return : Endif
ACTION = "IMP_VERROU" : Gosub ACTION From SUBIMPOBJ
If !OK : Return : Endif
SYMBOLE = func GOBJACT.SYMBOLE_VERROU(ABFIC,GCLE)
Lock =SYMBOLE With lockwait=0
If fstat
 If GPRODUIT=1 & CHAINE="C" : ## GEODE GX
  Call TRACE2(2,GCLE-mess(215,100,1),-1) From SUBIMPOBJ : # Création en cours sur un autre poste
 Else
  Call TRACE2(2,GCLE-mess(61,141,1),-1) From SUBIMPOBJ : # Fiche en cours de modification
 Endif
 OK = 0
Endif
Return

$DEVERROU
ACTION = "DEVERROU"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_DEVERROU" : Gosub ACTION From SUBIMPOBJ
Unlock =SYMBOLE
Return

$SETCLE
CLECUR1 = num$(evalue("[F]"+CLEPRIM))
GCLE = num$(evalue("[F]"+CLEPRIM))
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  CLECUR2(I) = num$(evalue("[F]"+CLESEC(I)))
  GCLE += "\"+num$(evalue("[F]"+CLESEC(I)))
 Endif
Next I
Return

$VALID
If GPRODUIT=1 & [M:IMP2]TYPENV & find(GREP,"C","M") : ## GEODE GX
 GFCY = evalue("[F:AAA_]"+[L]CLEFCY)
 If [M:IMP2]TYPENV=2 : GDEP = evalue("[F:AAA_]"+[L]CLEDEP) : Endif
Endif
If GREP="C"
 ACTION = "VERIF_CRE"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ACTION = "IMP_VERIF_CRE" : Gosub ACTION  From SUBIMPOBJ
 If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
 If !OK : GREP = "" : Return : Endif
 Gosub TR1
 If GOK<1
  Call TRACE2(2,mess(100,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur création
 Else
  Gosub SETCLE : CLECUR = 1
  ACTION = "APRES_CRE"     : Gosub ACTIONG From SUBIMPOBJ
  ACTION = "IMP_APRES_CRE" : Gosub ACTION From SUBIMPOBJ
  Call TRACE2(0,GCLE,-1) From SUBIMPOBJ
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  If (dim([M:AOE1]ENAWRK)<0 | [M:AOE1]ENAWRK=2)
   Call WORKFLOW(2,ABREV,"C",IDENT) From AWRK
  Endif
 Endif
Elsif GREP="M"
 ACTION = "VERIF_MOD"     : Gosub ACTIONG From SUBIMPOBJ
 If !OK : GREP = "" : Return : Endif
 ACTION = "IMP_VERIF_MOD" : Gosub ACTION From SUBIMPOBJ
 If dim(ANOWRITE)>0 and ANOWRITE>0 : Return : Endif # CRUD done by class
 If !OK : GREP = "" : Return : Endif
 Gosub TR2
 If GOK<1
  Call TRACE2(2,mess(101,141,1)-GCLE,-1) From SUBIMPOBJ : # Erreur modification
 Else
  ACTION = "APRES_MOD"     : Gosub ACTIONG From SUBIMPOBJ
  ACTION = "IMP_APRES_MOD" : Gosub ACTION From SUBIMPOBJ
  Call TRACE2(1,GCLE,-1) From SUBIMPOBJ
  Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
  If (dim([M:AOE1]ENAWRK)<0 | [M:AOE1]ENAWRK=2)
   Call WORKFLOW(2,ABREV,"M",IDENT) From AWRK
  Endif
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INICRE From GOBJSUB
 Gosub INIEXP From SUBIMPOBJ
 ACTION = "INICRE"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ACTION = "IMP_INICRE" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif
 ACTION = "CREATION"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 ACTION = "IMP_CREATION" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
ACTION = "AB_CREATION"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_AB_CREATION" : Gosub ACTION  From SUBIMPOBJ
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR2
GOK=1
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 If GPRODUIT=1 & [M:IMP2]TYPENV : ## GEODE GX
  Assign "[F]"+CLEFCY With GFCY
  If [M:IMP2]TYPENV=2 : Assign "[F]"+CLEDEP With GDEP : Endif
 Endif
 Readlock =
 If fstat=1
  GOK=-1 : Call FSTA(ABFIC) From GLOCK : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "AVANT_MODFIC"    : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ACTION = "IMP_AVANT_MODFIC" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 nolign = 1
 Gosub CHARGEFIC From SUBIMPOBJ
 Gosub INIMOD From GOBJSUB
 Gosub INIEXP From SUBIMPOBJ
 ACTION = "INIMOD"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ACTION = "IMP_INIMOD" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 ACTION = "MODIF"     : Gosub ACTIONG From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 ACTION = "IMP_MODIF" : Gosub ACTION From SUBIMPOBJ
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
ACTION = "AB_MODIF"     : Gosub ACTIONG From SUBIMPOBJ
ACTION = "IMP_AB_MODIF" : Gosub ACTION From SUBIMPOBJ
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

##############################################################
$SET_AUTOR
Raz CRE, MODI, SUPPR, ERRMES
If GUSRACS<>2 & dim([L]ZACC)>0 & [L]ZACC<>"" & evalue("dim([F]"+[L]ZACC+")")>0
 If evalue("[F]"+[L]ZACC)<>""
  Read [ACC_]CODACC = GUSER;evalue("[F]"+[L]ZACC)
  If [F:ACC_]MODIF<>2
   ERRMES = mess(38,134,1) : # Niveau d'accès insuffisant
   Return
  Endif
 Endif
Endif
If GUSRFCY(1)="\" : # Pour les fonctions sans autorisations site
 CRE   = (instr(1,GUSRAUZ(1),"C")<>0)
 MODI  = (instr(1,GUSRAUZ(1),"M")<>0)
 SUPPR = (instr(1,GUSRAUZ(1),"S")<>0)
Elsif dim([L]ZSITE)<=0 | (dim([L]ZSITE)>0 & [L]ZSITE="")
 CRE   = 1
 MODI  = 1
 SUPPR = 1
Elsif dim([L]ZSITE)>0 & [L]ZSITE<>"" & evalue("dim([F]"+[L]ZSITE+")")>0
 If evalue("[F]"+[L]ZSITE)=""
  CRE   = 1
  MODI  = 1
  SUPPR = 1
 Else
  ISITE = find(evalue("[F]"+[L]ZSITE),GUSRFCY(1..GNBAUZ))
  If ISITE<>0
   CRE   = (instr(1,GUSRAUZ(ISITE),"C")<>0)
   MODI  = (instr(1,GUSRAUZ(ISITE),"M")<>0)
   SUPPR = (instr(1,GUSRAUZ(ISITE),"S")<>0)
  Endif
 Endif
Endif
If !CRE | !MODI | !SUPPR
 If GUSRFCY(1)="\"
  ERRMES = mess(38,134,1) : # Niveau d'accès insuffisant
 Else
  ERRMES = evalue("[F]"+[L]ZSITE)-":"-mess(2,104,1)  : # Vous n'avez pas les droits pour ce site
 Endif
Endif
Return

#CHECK UNUSED_END
