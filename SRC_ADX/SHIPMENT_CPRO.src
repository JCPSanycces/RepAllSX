#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################
$SHIPSTAT_INIT
  this.SHIPSTAT = 1
Return

# MAE, landed cost 110325
#####################################################
$SHIPDAT_INIT
  this.SHIPDAT = date$
Return

# Issue 111257
#####################################################
#**
#* 1 - lecture du transport et affectation de la classe des shipment avec ses valeurs
#* 2 - recherche du pays d'origine et de destination à partir des lieux de départ et d'arrivée
#*!
$TRNNUM_PROPAGATE
  Local File BPADDRESS[BPA]
  Local File SHIPDOC[SHIPD]
  Local Char LVCRNUM(GLONVCR)
  Local Integer LVCRTYP

  Local Instance WTRANSPORT Using C_TRANSPORT
  WTRANSPORT = NewInstance C_TRANSPORT AllocGroup null

  If fmet WTRANSPORT.AREAD(this.TRNNUM) = [V]CST_AOK
    this.DPETPC = WTRANSPORT.DPETPC
    this.ARVTPC = WTRANSPORT.ARVTPC
    this.DPEDAT = WTRANSPORT.DPEDAT
    this.ARVDAT = WTRANSPORT.ARVDAT
    this.TRNMOD = WTRANSPORT.TRNMOD
    this.BPTNUM = WTRANSPORT.BPTNUM
    this.ARVEXPDAT = WTRANSPORT.ARVEXPDAT
    this.SHIPLAG = WTRANSPORT.SHIPLAG
    # Issue 118124 - 2016-08-23 by MAE : Affectation du code tiers à partir du transport
    this.BPRNUM = WTRANSPORT.BPRNUM
  Endif

  FreeGroup WTRANSPORT    # Issue X3-86303

  #ramener la désignation du transport
  #Call LECTEXTRA(this.TRNDES,"TRANSPORT","DESAXX",this.TRNNUM,"") From ATEXTRA
  If this.DPETPC <> AVOID.ACHAR
      Filter [F:BPA] Where BPATYP=8 & BPANUM = this.DPETPC
      Read [F:BPA] First
      this.DPECRY = [F:BPA]CRY
      Filter [F:BPA]
  Endif
  If this.ARVTPC <> AVOID.ACHAR
    Filter [F:BPA] Where BPATYP=8 & BPANUM = this.ARVTPC
    Read [F:BPA] First
    this.ARVCRY = [F:BPA]CRY
    Filter [F:BPA]
  Endif


Return

#####################################################
#**
#*Affectation du pays d'origine
#*!
$DPETPC_PROPAGATE
  Local File BPADDRESS[BPA]
  Filter [F:BPA] Where BPATYP=8 & BPANUM = this.DPETPC
  Read [F:BPA] First
  this.DPECRY = [F:BPA]CRY
  Filter [F:BPA]
Return

#####################################################
#**
#*Affectation du pays destination
#*!
$ARVTPC_PROPAGATE
  Local File BPADDRESS[BPA]
  Filter [F:BPA] Where BPATYP=8 & BPANUM = this.ARVTPC
  Read [F:BPA] First
  this.ARVCRY = [F:BPA]CRY
  Filter [F:BPA]
Return
# End issue 111257
#####################################################
#**
#*Recalcul de la date d'arrivée prévue en fonction du décalage
#*!
## ----------------------- TCTRNUM --------------------------------------
$TCTRNUM_PROPAGATE
Local Instance WTABCONTAINER Using C_TABCONTAINER
WTABCONTAINER = NewInstance C_TABCONTAINER AllocGroup null

If this.TCTRNUM <> AVOID.ACHAR
  If fmet WTABCONTAINER.AREAD(this.TCTRNUM) = [V]CST_AOK
    this.DSPWEU = WTABCONTAINER.WEU
    this.DSPVOU = WTABCONTAINER.VOU
    this.CTRMAXWEI = WTABCONTAINER.MAXWEI
    this.CTRMAXVOL = WTABCONTAINER.TCTRVOL
    this.TARWEI = WTABCONTAINER.TARWEI
   Endif
   If this.SHIPNBCTR <> 0
    this.MAXWEI = this.SHIPNBCTR * (this.TARWEI + this.CTRMAXWEI)
    this.MAXVOL = this.SHIPNBCTR * this.CTRMAXVOL
  Else
    this.MAXWEI = 0
    this.MAXVOL = 0
  Endif
Else
    this.SHIPNBCTR = 0
    this.CTRMAXWEI = 0
    this.CTRMAXVOL = 0
    this.TARWEI = 0
Endif

FreeGroup WTABCONTAINER

Return
## ----------------------- SHIPNBCTR --------------------------------------
$SHIPNBCTR_PROPAGATE
If this.SHIPNBCTR <> 0
  this.MAXWEI = this.SHIPNBCTR * (this.TARWEI + this.CTRMAXWEI)
  this.MAXVOL = this.SHIPNBCTR * this.CTRMAXVOL
Else
  this.MAXWEI = 0
  this.MAXVOL = 0
Endif

Return
# End issue 111256 US3

