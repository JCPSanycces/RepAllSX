W_Q = (W_I/W_LAM)
For W_R = 0 To W_Q
  W_FSQ    = "WUVAR0"+num$(W_R)
  W_FICSRC = filpath("TRT",W_FSQ,"src",LAPL)
  Openo W_FICSRC,0
  adxifs = ""
  adxirs = chr$(10)
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
  Wrseq "############################################################"
  Wrseq "# ";W_FSQ;" CFG routines generated : ";num$(date$);" ";num$(time$);" By ";GUSER
  Wrseq "# ";GVERSION;" ";W_REL
  Wrseq "############################################################"
  Wrseq "#"
  Wrseq "$MEI_VARLAB"
  Wrseq "# Initialization Label array "
  For W_J = (W_R*W_LAM) To (W_R*W_LAM)+(W_LAM-1)
    If W_J = W_I
      Break
    Else
      W_STR = '"'+W_PRS+W_LAQ(W_J)+'"              '
      Wrseq 'W_VARLAB(';format$("N0:5#",W_J); ') = ';W_STR; ': ';
      Wrseq 'W_VARATT(';format$("N0:5#",W_J); ') = "';num$(W_LAP(W_J));num$(W_LAT(W_J));'"'
    Endif
  Next W_J
  Wrseq "#"
  Wrseq "Return"
  Openo
  Call VALID("TRT",W_FSQ,LAPL,W_U) From VALMSKSUB
Next W_R
