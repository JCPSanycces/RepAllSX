#        When 4 :
#          Wrseq " Global Integer ";W_FMT;"("+num$(W_QDI(W_J))+")"
#        When 5 :
#          Wrseq " Global Char    ";W_FMT;"(250)"
#        When 6 :                                           # FQ 50451 GA 11/2008
#          Wrseq " Global Blbfile ";W_FMT
#        When 7 :                                           # FQ 50451 GA 11/2008
#          Wrseq " Global Clbfile ";W_FMT
#      Endcase
#    Endif
    If W_QTC(W_J) <> "" | W_QCT(W_J) = 4
      W_FMT = W_PRL+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
      If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008 type de données DCT
         Wrseq  "                         Global Char    ";W_FMT;"(GLONDCT)"
      Else
         Wrseq  "                         Global Char    ";W_FMT;"(30)"
      Endif
    Endif
  Next W_J
  Wrseq "#"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_FMT = W_PRW+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
      W_STR = '"'+W_PRW+W_QSN(W_J)+'"          '
      Wrseq "    When ";W_STR;":";
      Gosub DEF_SYMBOLE
#      If W_QDI(W_J) < 2
#        Case W_QST(W_J)
#          When 1 :
#            W_LNG = GLONDES
#            # FQ 72480 GA 03/2011 pb site > 3c S_FCY etait en Char (3)
#            If evalue("dim(GLON"+W_QSN(W_J)+")")>0
#              W_LNG = evalue("GLON"+W_QSN(W_J))
#            Elsif find(W_QSN(W_J),"FCY","CUR")
#              W_LNG = 3
#            Endif
#            If find(W_QSN(W_J),"ITMSEL","SELITM","CMPSEL","CURITM","CURROU")
#              W_LNG = GLONITM : # V6 avant 20
#            Endif
#            Wrseq " Global Char    ";W_FMT;"("+num$(W_LNG)+")"
#          When 2 :
#            Wrseq " Global Decimal ";W_FMT
#          When 3 :
#            Wrseq " Global Date    ";W_FMT
#          When 4 :
#            Wrseq " Global Integer ";W_FMT
#          When 5 :
#            Wrseq " Global Char    ";W_FMT;"(250)"
#          When 6 :                                           # FQ 50451 GA 11/2008
#            Wrseq " Global Blbfile ";W_FMT
#          When 7 :                                           # FQ 50451 GA 11/2008
#            Wrseq " Global Clbfile ";W_FMT
#        Endcase
#      Else
#        Case W_QST(W_J)
#          When 1 :
#            W_LNG = GLONDES
#           # FQ 72480 GA 03/2011 pb site > 3c S_FCY etait en Char (3)
#            If evalue("dim(GLON"+W_QSN(W_J)+")")>0
#              W_LNG = evalue("GLON"+W_QSN(W_J))
#            Elsif find(W_QSN(W_J),"FCY","CUR")
#              W_LNG = 3
#            Endif
#            If find(W_QSN(W_J),"ITMSEL","SELITM","CMPSEL","CURITM","CURROU")
#              W_LNG = GLONITM : # V6 avant 20
#            Endif
#            Wrseq " Global Char    ";W_FMT;"("+num$(W_LNG)+")("+num$(W_QDI(W_J))+")"
#          When 2 :
#            Wrseq " Global Decimal ";W_FMT;"("+num$(W_QDI(W_J))+")"
#          When 3 :
#            Wrseq " Global Date    ";W_FMT;"("+num$(W_QDI(W_J))+")"
#          When 4 :
#            Wrseq " Global Integer ";W_FMT;"("+num$(W_QDI(W_J))+")"
#          When 5 :
#            Wrseq " Global Char    ";W_FMT;"(250)"
#          When 6 :                                           # FQ 50451 GA 11/2008
#            Wrseq " Global Blbfile ";W_FMT
#          When 7 :                                           # FQ 50451 GA 11/2008
#            Wrseq " Global Clbfile ";W_FMT
#        Endcase
#      Endif
    Endif
    If W_QTC(W_J) <> "" | W_QCT(W_J) = 4
      W_FMT = W_PRY+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
      Wrseq  "                         Global Char    ";W_FMT;"(30)"
    Endif
  Next  W_J
  Wrseq "  Endcase"
  Wrseq "  Gosub CRE_SYMTXT"
  Wrseq "Endif"
  Wrseq "Return"
#
  Wrseq "############################################################"
  Wrseq "$SUP_SYMBOLE"
# FQ 56326  Wrseq 'If evalue("dim("+W_VAR+")>0")' # FQ 73793 GA 05/2011 ajout [V]
  Wrseq 'If W_VAR<>"" & evalue("dim([V]"+W_VAR+")>0")'
  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    W_STR = '"'+W_PRS+W_QSN(W_J)+'"           '
    # FQ 73793 GA 05/2011
    #Wrseq "    When ";W_STR;": Kill ";W_PRS;W_QSN(W_J)
    Wrseq "    When ";W_STR;": Kill [V]";W_PRS;W_QSN(W_J)
    If W_QTC(W_J) <> "" | W_QCT(W_J) = 4
      # FQ 73793 GA 05/2011
      #Wrseq "                         Kill ";W_PRL;W_QSN(W_J)
      Wrseq "                         Kill [V]";W_PRL;W_QSN(W_J)
    Endif
  Next W_J
#
  Wrseq "#"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_STR = '"'+W_PRW+W_QSN(W_J)+'"           '
      # FQ 73793 GA 05/2011
      #Wrseq "    When ";W_STR;": Kill ";W_PRW;W_QSN(W_J)
      Wrseq "    When ";W_STR;": Kill [V]";W_PRW;W_QSN(W_J)
      If W_QTC(W_J) <> "" | W_QCT(W_J) = 4
        # FQ 73793 GA 05/2011
        #Wrseq "                         Kill ";W_PRY;W_QSN(W_J)
        Wrseq "                         Kill [V]";W_PRY;W_QSN(W_J)
      Endif
    Endif
  Next W_J
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
  Wrseq "############################################################"
# Ecriture des routines d'activation zones ecran
  Wrseq "$ACT_SYMBOLE"
  Wrseq 'If evalue("dim([M]"+W_PRQ+mid$(W_VAR,3,GLONCQU)+")>0")'
  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_FMT = "[M]"+W_PRQ+W_QSN(W_J)
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "    When ";W_STR;":  Actzo ";W_FMT
    Endif
  Next
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$GRI_SYMBOLE"
  Wrseq 'If evalue("dim([M]"+W_PRQ+mid$(W_VAR,3,GLONCQU)+")>0")'

  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_FMT = "[M]"+W_PRQ+W_QSN(W_J)
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "    When ";W_STR;":  Grizo ";W_FMT
    Endif
  Next
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
  Wrseq "############################################################"
# Ecriture des routines d'effacement zones ecran
  Wrseq "$EFF_SYMBOLE"
  Wrseq 'If evalue("dim([M]"+W_PRQ+mid$(W_VAR,3,GLONCQU)+")>0")'

  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_FMT = "[M]"+W_PRQ+W_QSN(W_J)
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "    When ";W_STR;":  Effzo ";W_FMT
    Endif
  Next
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
# Ecriture des routines d'affichage zones ecran
  Wrseq "############################################################"
  Wrseq "$AFF_SYMBOLE"
  Wrseq 'If evalue("dim([M]"+W_PRQ+mid$(W_VAR,3,GLONCQU)+")>0")'
  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QSP(W_J) = 1
      W_FMT = "[M]"+W_PRQ+W_QSN(W_J)
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "    When ";W_STR;":  Affzo ";W_FMT
    Endif
  Next
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
  Wrseq "############################################################"
# Ecriture des routines d'affectation valeur par defaut
  Wrseq "# Set default value for a symbol"
  Wrseq "$SET_DEFAUT"
  Wrseq 'If S_CPTCOP <> ""'
  Wrseq '  Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)'
  Wrseq '  If fstat = 0 & [F:CQU]QSTTYP = 1'
  Wrseq '    Read [CFH]CFH0=S_SCENUM;S_CPTCOP;mid$(W_VAR,3,GLONCQU);0'
  Wrseq '    If fstat = 0'
  Wrseq '      If [F:CQU]SHACAT <> ""'
  Wrseq '        [F:CFH]VALALP=tolower([F:CFH]VALALP)     # JPJ E21817'     # JPJ E21817 (F&M: zone alpha - minuscule pour ctl écran)->
  Wrseq '        Gosub SET_COP'
  Wrseq '        Read [CSH]CSH0=[F:CQU]SHACAT;toupper(evalue(W_VAR))'     # JPJ E21817 <-
  Wrseq '        If fstat = 0'
  Wrseq '          For W_Z = 0 to [F:CSH]SYMNBR-1'
  Wrseq '            W_VARS = W_VAR'
  Wrseq '            W_VAR  = W_PRS+[F:CSH]SYMNUM(W_Z)'
  Wrseq '            If evalue("dim([V]"+W_VAR+")<0")'                       # FQ 73793 GA 05/2011 ajout [V]
  Wrseq '              Gosub CRE_SYMBOLE From ='+CH_DOSSIER+'"WUVAR"'        # JPJ E21167
  Wrseq '            Endif'
#                    ->  JPJ E21724 Il faut le bon symbole en ligne pour set_cop et set_def
  Wrseq '            Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)'     # JPJ E21724
  Wrseq '            If fstat = 0'     # JPJ E21724
  Wrseq '              Read [CFH]CFH0=S_SCENUM;S_CPTCOP;mid$(W_VAR,3,GLONCQU);0'
  Wrseq '              If fstat = 0'
  Wrseq '                Gosub SET_COP'
  Wrseq '              Else'
  Wrseq '                Gosub SET_DEF'
  Wrseq '              Endif'
  Wrseq '            Endif'     # JPJ E21724
  Wrseq '            W_VAR  = W_VARS'
  Wrseq '          Next W_Z'
  Wrseq '          Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)'       # JPJ E21724 recharger la question
  Wrseq '          Gosub MEI_VARCAL From CFGLIBB'
  Wrseq '        Endif'
  Wrseq '      Else'                 # JPJ E21817  Cas standard
  Wrseq '        Gosub SET_COP'      # JPJ E21817
  Wrseq '      Endif'
  Wrseq '    Else'         # JPJ E21724 pas d'enreg. hito
  Wrseq '       Gosub SET_DEF'  # JPJ E21724
  Wrseq '    Endif'
  Wrseq '  Else'
  Wrseq '    Gosub SET_DEF'
  Wrseq '  Endif'
  Wrseq 'Else'
  Wrseq '  If S_MEMO = 2'
  Wrseq '    Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)'
  Wrseq '    If fstat = 0 & [F:CQU]QSTTYP = 1'
  Wrseq '      Read [CME]CME0=0;S_SCENUM;GUSER;S_BPRNUM;S_BPRREF;mid$(W_VAR,3,GLONCQU);0'
  Wrseq '      If fstat = 0'
  Wrseq '        Gosub SET_MEMO'
  Wrseq '      Else'
  Wrseq '        Gosub SET_DEF'
  Wrseq '      Endif'
  Wrseq '    Else'
  Wrseq '      Gosub SET_DEF'
  Wrseq '    Endif'
  Wrseq '  Else'
  Wrseq '    Gosub SET_DEF'
  Wrseq '  Endif'
  Wrseq 'Endif'
  Wrseq 'Return'
  Wrseq "############################################################"
  Wrseq "$SET_DEF"
  Wrseq 'If dim(S_CFGCFG) > 0 & S_CFGCFG <> 0 & S_AUTCFG= 0'
  Wrseq '  Read [CQU]CQU0=mid$(W_VAR,3,GLONCQU)'
  Wrseq '  If fstat = 0 & [F:CQU]QSTTYP = 1'
  Wrseq '    Read [CME]CME1=1;adxuid(1);S_SCENUM;mid$(W_VAR,3,GLONCQU)'
  Wrseq '    If fstat = 0 & S_AUTCFG = 0'
  Wrseq '      Gosub SET_MEMO'
  Wrseq '      Goto SET_DEF_FIN'
  Wrseq '    Endif'
  Wrseq '  Endif'
  Wrseq 'Endif'
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QOR(W_J) = 1 |  W_QOR(W_J) = 2
      W_FMT = W_PRS+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      If W_QSP(W_J) <> 3
        If W_QSD(W_J)=""            # Issue 79301 & 50451 GA 02/2012
           # Nothing to do
        Elsif W_QEV(W_J) = 0
          # FQ 73793 GA 05/2011
          #Wrseq "  When ";W_STR;": ";W_FMT;" = ";W_QSD(W_J)
          Wrseq "  When ";W_STR;": [V]";W_FMT;" = ";W_QSD(W_J)
        Else
          Wrseq "  When ";W_STR;": Onerrgo SET_DEF_ERR"
          # FQ 73793 GA 05/2011
          #Wrseq "                       ";W_FMT;" = ";W_QSD(W_J)
          Wrseq "                       [V]";W_FMT;" = ";W_QSD(W_J)
          Wrseq "                       Onerrgo"
        Endif
      Else
        Wrseq "  When ";W_STR;": "
        # FQ 73793 GA 05/2011
        #Wrseq "    Call SET_VALCPT('";W_QSC(W_J);"'";",S_FCY,S_IPTDAT,'',";W_PRS;W_QSN(W_J);",S_RETURN) From CFGLIB"
        Wrseq "    Call SET_VALCPT('";W_QSC(W_J);"'";",S_FCY,S_IPTDAT,'',[V]";W_PRS;W_QSN(W_J);",S_RETURN) From CFGLIB"
      Endif
    Endif
  Next W_J
  Wrseq "Endcase"
  Wrseq "$SET_DEF_FIN"
  Wrseq "Return"
  Wrseq "$SET_DEF_ERR"
  Wrseq "Resume"
  Wrseq "############################################################"
  # Ecriture des routines d'affectation valeur par defaut evalue
  Wrseq "# Set default value evaluated for a symbol"
  Wrseq "$SET_DEFEVA"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QEV(W_J) <> 0
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;": Onerrgo SET_DEFEVA_ERR"
      Wrseq "                       VALEUR = ";W_QSD(W_J)
      Wrseq "                       Onerrgo"
    Endif
  Next W_J
  Wrseq "Endcase"
  Wrseq "$SET_DEFEVA_FIN"
  Wrseq "Return"
  Wrseq "$SET_DEFEVA_ERR"
  Wrseq "Resume"
  Wrseq "############################################################"
  Wrseq "$SET_COP"
  Wrseq 'Raz W_ALP, W_NUM, W_DAT'
  Wrseq 'Case [F:CQU]ASWTYP'
  Wrseq '  When 1 : W_ALP = [F:CFH]VALALP'
  Wrseq '  When 2 : W_NUM = [F:CFH]VALNUM'
  Wrseq '  When 3 : W_DAT = [F:CFH]VALDAT'
  Wrseq '  When 4 : W_NUM = [F:CFH]VALNUM'
  Wrseq '  When 5 : W_ALP = [F:CFH]VALALP'
  # Issue 117679 - 2016-08-23 by STLIG : Copy VALBLB and VALCLB field values,
  #                                      BLOB and CLOB are not [CFH] fields.
  Wrseq '  When 6 : If dim([F:CFH]VALBLB)>0 & dim(W_BLB)>0 W_BLB = [F:CFH]VALBLB Endif'
  Wrseq '  When 7 : If dim([F:CFH]VALCLB)>0 & dim(W_CLB)>0 W_CLB = [F:CFH]VALCLB Endif'
  Wrseq 'Endcase'
  Wrseq 'Gosub SET_SYMBOLE From ='+CH_DOSSIER+'"WUVAR"'
  Wrseq 'Return'
  #
  Wrseq "############################################################"
  Wrseq "$SET_MEMO"
  Wrseq 'Raz W_ALP, W_NUM, W_DAT'
  Wrseq 'Case [F:CQU]ASWTYP'
  Wrseq '  When 1 : W_ALP = [F:CME]VALALP'
  Wrseq '  When 2 : W_NUM = [F:CME]VALNUM'
  Wrseq '  When 3 : W_DAT = [F:CME]VALDAT'
  Wrseq '  When 4 : W_NUM = [F:CME]VALNUM'
  Wrseq '  When 5 : '
        # FQ 49950 & 52104 tjs relire le Clob
  Wrseq '           If dim([F:CME]CLOB)>0 & dim(W_CLB)>0'
  Wrseq '              W_CLB = [F:CME]CLOB'
  Wrseq '              Call CLB_TO_CHAR(W_ALP,W_PRS+[F:CME]QSTNUM) From CFGLIBD'
  Wrseq '           Else'
  Wrseq '              W_ALP = [F:CME]VALALP'
  Wrseq '           Endif'
  Wrseq '  When 6 : If dim([F:CME]BLOB)>0 W_BLB = [F:CME]BLOB Endif' # FQ 50451 GA 11/2008
  Wrseq '  When 7 : If dim([F:CME]CLOB)>0 W_CLB = [F:CME]CLOB Endif' # FQ 50451 GA 11/2008
  Wrseq 'Endcase'
  Wrseq 'Gosub SET_SYMBOLE From ='+CH_DOSSIER+'"WUVAR"'
  Wrseq 'Return'

  Wrseq "############################################################"
  Wrseq "$SET_SYMLIB"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QTC(W_J) <> "" & W_QST(W_J) = 1
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq '  When ';W_STR;' : Call LOA_INTSYM(1,W_VAR,';'"';W_QTC(W_J);'")'
    Endif
    If W_QTC(W_J) <> "" & W_QST(W_J) = 2
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq '  When ';W_STR;' : Call LOA_INTSYM(2,W_VAR,';'"';W_QTC(W_J);'")'
    Endif
    If W_QCT(W_J) = 4
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq '  When ';W_STR;' : Call LOA_INTSYM(3,W_VAR,';'"';W_QSN(W_J);'")'
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$AFF_SYMLIB"
  Wrseq 'If evalue("dim([M]"+W_PRZ+mid$(W_VAR,3,GLONCQU)+")>0")'
  Wrseq "  Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QTC(W_J) <> "" | W_QCT(W_J) = 4
      W_FMT = "[M]"+W_PRZ+W_QSN(W_J)
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq '    When ';W_STR;' : Affzo ';W_FMT
    Endif
  Next
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "Subprog LOA_INTSYM(LPAR,LVAR,LCOD)"
  Wrseq "Value   Integer LPAR"
  Wrseq "Value   Char    LVAR"
  Wrseq "Value   Char    LCOD"
  Wrseq "#"
  Wrseq "Local   Char    WALP(250)"
  Wrseq "Local   Decimal WDEC"
  Wrseq "#"
  Wrseq 'If evalue("dim([M]"+W_PRQ+mid$(LVAR,3,GLONCQU)+")>0")'
  Wrseq "  Case LPAR"
  Wrseq "    When 1 :"
  Wrseq "      WALP = evalue(LVAR)"
  Wrseq '      Read [TCT]TCT1=LCOD;WALP;0'
  Wrseq "      If fstat = 0"
# FQ 60007 GA 11/2009 remplacement de [F:TCT]DESCOD
#  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with [F:TCT]DESCOD'
  Wrseq '        Call CFGDESTCT(GBIDC1,GBIDC2) From CFGLIB'
  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with GBIDC1'
  Wrseq "      Endif"
  Wrseq "    When 2 :"
  Wrseq "      WNUM = evalue(LVAR)"
  Wrseq '      Read [TCT]TCT1=LCOD;"";WNUM'
  Wrseq "      If fstat = 0"
# FQ 60007 GA 11/2009 remplacement de [F:TCT]DESCOD
#  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with [F:TCT]DESCOD'
  Wrseq '        Call CFGDESTCT(GBIDC1,GBIDC2) From CFGLIB'
  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with GBIDC1'
  Wrseq "      Endif"
  Wrseq "    When 3 :"
  Wrseq "      WALP = toupper(evalue(LVAR))"
  Wrseq '      Read [CSH]CSH0=LCOD;WALP'
  Wrseq "      If fstat = 0"
# FQ 60007 GA 11/2009 remplacement de SHANUMDES + FQ 60132
#  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with [F:CSH]SHANUMDES'
  Wrseq '         Call LECTEXTRA(GBIDC1,"CFGSHA","SHANUMAXX",[F:CSH]SHACAT,[F:CSH]SHANUM) From ATEXTRA'
  Wrseq '        Assign "[M]"+W_PRZ+mid$(LVAR,3,GLONCQU) with GBIDC1'
  Wrseq "      Endif"
  Wrseq "  Endcase"
  Wrseq "Endif"
  Wrseq "End"
  Wrseq "############################################################"
  Wrseq "$OPE_FILTER"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QOB(W_J) = "ADI" & W_QTB(W_J)<>"ATABDIV" # Issue 98847 GA 04/2014
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":  "
      Wrseq "    If clalev([F:";W_QATB(W_J);"]) = 0 : Local File ATABDIV [";W_QATB(W_J);"] : Endif"
   Elsif W_QOB(W_J) <> ""
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":  "
# CCC (29/11/05)     Wrseq "    If clalev([F:";W_QOB(W_J);"]) = 0 : Local File ";W_QTB(W_J);" [";W_QOB(W_J);"] : Endif"
      Wrseq "    If clalev([F:";W_QATB(W_J);"]) = 0 : Local File ";W_QTB(W_J);" [";W_QATB(W_J);"] : Endif"
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$SET_FILTER"
  Wrseq "Gosub OPE_FILTER"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    # Issue 98847 GA 04/2014 filter with ATABDIV: table code can be stored is in CODFIC
    If W_QOB(W_J) = "ADI" & W_QTB(W_J)<>"ATABDIV"
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":  "
      Wrseq '     S_FILTER = "NUMTAB='+W_QTB(W_J)+'"'
      If W_QFO(W_J) = ""
        Wrseq '    If S_FILTER <> "1=1"'
        Wrseq "      Filter [";W_QATB(W_J);"] Where evalue(S_FILTER)"
        Wrseq "    Endif"
      Else
        Wrseq '    If clalev([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif'
        Wrseq '    Read [TFO]TFO0=7;"';W_QFO(W_J);'"'
        Wrseq '    If !fstat & [F:TFO]FORFOR<>""'
        Wrseq '      S_FILTER += "&('+[F:TFO]FORFOR+')"'
        Wrseq "      Filter [";W_QATB(W_J);"] Where evalue(S_FILTER)"
        Wrseq "    Endif"
      Endif
    Elsif W_QOB(W_J) <> ""
        W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
        Wrseq "  When ";W_STR;":  "
        If W_QFO(W_J) = ""
          Wrseq '    If S_FILTER <> ""'
  # CCC (29/11/05)       Wrseq "      Filter [";W_QOB(W_J);"] Where evalue(S_FILTER)"
          Wrseq "      Filter [";W_QATB(W_J);"] Where evalue(S_FILTER)"
          Wrseq "    Endif"
        Else
          Wrseq '    If clalev([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif'
          Wrseq '    Read [TFO]TFO0=7;"';W_QFO(W_J);'"'
          Wrseq "    If fstat = 0"
          Wrseq "      S_FILTER = [F:TFO]FORFOR"
  # CCC (29/11/05)        Wrseq "      Filter [";W_QOB(W_J);"] Where evalue(S_FILTER)"
          Wrseq "      Filter [";W_QATB(W_J);"] Where evalue(S_FILTER)"
          Wrseq "    Endif"
        Endif
     Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$RESET_FILTER"
  Wrseq "Gosub OPE_FILTER"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QOB(W_J) = "ADI" & W_QTB(W_J)<>"ATABDIV" # Issue 98847 GA 04/2014
    Elsif W_QOB(W_J) <> ""
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":"
      If W_QOF(W_J) <> ""
# CCC (29/11/05)        Wrseq "    LVAL = num$([F:";W_QOB(W_J);"]";W_QOF(W_J);")"
        Wrseq "    LVAL = num$([F:";W_QATB(W_J);"]";W_QOF(W_J);")"
      Endif
      If W_QIN(W_J) <> ""
        Wrseq '    If evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
        # FQ 45345 GA 01/2008 If W_QINTYP(W_J)="AXX"      # table texte tra
        If find(W_QINTYP(W_J),"AXX","AX1","AX2","AX3")
            Wrseq '      Call LECTEXTRA(';W_PRZ;W_QSN(W_J);',"';W_QTB(W_J);'","';W_QIN(W_J);'",LVAL,"") From ATEXTRA'
        Else                        # std
# CCC (29/11/05)           Wrseq '      Assign W_PRZ+"';W_QSN(W_J);'" With [F:';W_QOB(W_J);']';W_QIN(W_J)
            Wrseq '      Assign W_PRZ+"';W_QSN(W_J);'" With [F:';W_QATB(W_J);']';W_QIN(W_J)
        Endif
        Wrseq '    Endif'
      Endif
# CCC (29/11/05)     Wrseq "    If clalev([F:";W_QOB(W_J);"]) <> 0 : Filter [";W_QOB(W_J);"] : Endif"
      Wrseq "    If clalev([F:";W_QATB(W_J);"]) <> 0 : Filter [";W_QATB(W_J);"] : Endif"
      If W_QFO(W_J) <> ""
        Wrseq '    S_FILTER = ""'
      Endif
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$SEL_TABLE"
  Wrseq "Gosub OPE_FILTER"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QOB(W_J) <> ""
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":  "
      Call CFG_KEYFIC(LAPL,W_QTB(W_J),W_KEYNBR,W_KEYFLD,W_KEYATY,W_KEYTYP) From CFGLIBD
      Case W_KEYNBR
        When 1 :
          If W_KEYTYP(0) > 10
            Wrseq '    Call SELECT(LOBJ,"",LVAL,"") From SELOBJ'
          Else
            Wrseq '    Local Decimal LVALNUM : LVALNUM = val(LVAL)'
            Wrseq '    Call SELNUM(LOBJ,"",LVALNUM,"") From SELOBJ'
            Wrseq '    LVAL = num$(LVALNUM)'
          Endif
        When 2 :
          If W_KEYATY(0) = "FCY"     # Issue 81521 before [M]FCY
            Wrseq '    Call SELECT(LOBJ,"",LVAL,S_FCY) From SELOBJ'
          Else
            If W_KEYATY(1) = "FCY"
              If W_KEYTYP(0) > 10    # Issue 81521 before [M]FCY
                Wrseq '    Call SELECT(LOBJ,"",S_FCY,LVAL) From SELOBJ'
              Endif
            Else
              If W_KEYTYP(0) > 10
                Wrseq '    Call SELECT(LOBJ,"",LVAL,"") From SELOBJ'
              Else
                Wrseq '    Local Decimal LVALNUM : LVALNUM = val(LVAL)'
                Wrseq '    Call SELNUM(LOBJ,"",LVALNUM,"") From SELOBJ'
                Wrseq '    LVAL = num$(LVALNUM)'
              Endif
            Endif
          Endif
      Endcase
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$CTR_TABLE"
  Wrseq "Gosub OPE_FILTER"
  Wrseq "fstat = 0"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    # Issue 98847 GA 04/2014 control with ATABDIV
    If W_QOB(W_J) = "ADI"
        W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
        Wrseq "  When ";W_STR;":  "
        Wrseq '    Gosub SET_FILTER'    # --> Pour Charger S_FILTER
        Wrseq '    If S_FILTER=""'
        Wrseq '        S_FILTER="1=1"'
        Wrseq '    Endif'
        Wrseq '    Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = VALEUR & evalue(S_FILTER)'
        Wrseq '    fstat = 5'
        Wrseq '    For [';W_QATB(W_J);']'
        Wrseq '      fstat = 0'
        Wrseq '    Next'
        Wrseq '    Filter [';W_QATB(W_J);']'
        Wrseq '    S_FILTER = ""'

     Elsif W_QOB(W_J) <> ""
        W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
        Wrseq "  When ";W_STR;":  "
        Call CFG_KEYFIC(LAPL,W_QTB(W_J),W_KEYNBR,W_KEYFLD,W_KEYATY,W_KEYTYP) From CFGLIBD
        Case W_KEYNBR
          When 1 :
            Wrseq '    [G:';W_QATB(W_J);']currind = 1'
            If W_KEYTYP(0) > 10
              Wrseq '    Read[';W_QATB(W_J);']=VALEUR'
            Else
              Wrseq '    Read[';W_QATB(W_J);']=val(num$(VALEUR))'
            Endif
            If W_QIN(W_J) <> ""
              Wrseq '    If fstat = 0 & evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
              # FQ 45345 GA 01/2008 If W_QINTYP(W_J)="AXX"      # table texte tra
              If find(W_QINTYP(W_J),"AXX","AX1","AX2","AX3")
                  # FQ 60170 GA 11/2009 sauf sur ITMMASTER
                  If W_QTB(W_J)<>"ITMMASTER"
                  Wrseq '      Call LECTEXTRA(';W_PRZ;W_QSN(W_J);',"';W_QTB(W_J);'","';W_QIN(W_J);'",num$([F:';W_QATB(W_J);']';W_QOF(W_J);'),"") From ATEXTRA'
                  Else
                  Wrseq '      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:';W_QATB(W_J);']';W_QOF(W_J);',';W_PRZ;W_QSN(W_J);', "[F:';W_QATB(W_J);']") From TRTX3'
                  Wrseq '      If fstat & evalue(W_PRZ+"';W_QSN(W_J);'")<>"" fstat=0 Endif'
                  Endif
              Else                        # std
                  Wrseq '      Assign W_PRZ+"';W_QSN(W_J);'" With [F:';W_QATB(W_J);']';W_QIN(W_J)
              Endif
              Wrseq '    Endif'
            Endif
          When 2 :
            If W_KEYATY(0) = "FCY"
              Wrseq '    [G:';W_QATB(W_J);']currind = 1'
              Wrseq '    [G:';W_QATB(W_J);']currlen = 0'
              If W_KEYTYP(1) > 10
                # Issue 81521 before [M]FCY + case fstat
                Wrseq '    Read[';W_QATB(W_J);']=S_FCY;VALEUR'
                Wrseq '    If fstat'
                Wrseq '      Read[';W_QATB(W_J);']="";VALEUR'
                Wrseq '    Endif'
              Else
                # Issue 81521 before [M]FCY + case fstat
                Wrseq '    Read[';W_QATB(W_J);']=S_FCY;val(num$(VALEUR))'
                Wrseq '    If fstat'
                Wrseq '      Read[';W_QATB(W_J);']="";val(num$(VALEUR))'
                Wrseq '    Endif'
              Endif
              If W_QIN(W_J) <> ""
                Wrseq '    If fstat =0 & evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
                # FQ 45345 GA 01/2008 If W_QINTYP(W_J)="AXX"      # table texte tra
                  If find(W_QINTYP(W_J),"AXX","AX1","AX2","AX3")
                      # Issue 81521 before [M]FCY + need to save fstat
                      Wrseq '      Local integer WSTAT : WSTAT=fstat'
                      Wrseq '      Call LECTEXTRA(';W_PRZ;W_QSN(W_J);',"';W_QTB(W_J);'","';W_QIN(W_J);'",S_FCY,num$([F:';W_QATB(W_J);']';W_QOF(W_J);')) From ATEXTRA'
                      Wrseq '      fstat=WSTAT '
                  Else                        # std
                      Wrseq '      Assign W_PRZ+"';W_QSN(W_J);'" With [F:';W_QATB(W_J);']';W_QIN(W_J)
                  Endif
                Wrseq '    Endif'
            # Issue 100387 GA 06/2014 second part of key is an ITM
              Elsif W_KEYATY(1) = "ITM"
                  Wrseq '    If fstat = 0 & evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
                  Wrseq '      Read[F:ITM]ITM0=VALEUR'
                  Wrseq '      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,';W_PRZ;W_QSN(W_J);', "[F:ITM]") From TRTX3'
                  Wrseq '      If fstat & evalue(W_PRZ+"';W_QSN(W_J);'")<>"" fstat=0 Endif'
                  Wrseq '    Endif'
              Endif
            Else
              If W_KEYATY(1) = "FCY"
                Wrseq '    [G:';W_QATB(W_J);']currind = 1'
                Wrseq '    [G:';W_QATB(W_J);']currlen = 0'
                If W_KEYTYP(0) > 10     # Issue 81521 before [M]FCY
                  Wrseq '    Read[';W_QATB(W_J);']=VALEUR;S_FCY'
                Else
                  Wrseq '    Read[';W_QATB(W_J);']=val(num$(VALEUR));S_FCY'
                Endif
                If W_QIN(W_J) <> ""
                  Wrseq '    If fstat = 0 & evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
                    # FQ 45345 GA 01/2008 If W_QINTYP(W_J)="AXX"      # table texte tra
                      If find(W_QINTYP(W_J),"AXX","AX1","AX2","AX3")
                          # Issue 81521 before [M]FCY + need to save fstat
                          Wrseq '      Local integer WSTAT : WSTAT=fstat'
                          Wrseq '      Call LECTEXTRA(';W_PRZ;W_QSN(W_J);',"';W_QTB(W_J);'","';W_QIN(W_J);'",num$([F:';W_QATB(W_J);']';W_QOF(W_J);'),S_FCY) From ATEXTRA'
                          Wrseq '      fstat=WSTAT'
                      Else                        # std
                          Wrseq '      Assign W_PRZ+"';W_QSN(W_J);'" With [F:';W_QATB(W_J);']';W_QIN(W_J)
                      Endif
                  Wrseq '    Endif'
            # Issue 100387 GA 06/2014 first part of key is an ITM
                Elsif W_KEYATY(0) = "ITM"
                  Wrseq '    If fstat = 0 & evalue("dim("+W_PRZ+"';W_QSN(W_J);')>0")'
                  Wrseq '      Read[F:ITM]ITM0=VALEUR'
                  Wrseq '      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,';W_PRZ;W_QSN(W_J);', "[F:ITM]") From TRTX3'
                  Wrseq '      If fstat & evalue(W_PRZ+"';W_QSN(W_J);'")<>"" fstat=0 Endif'
                  Wrseq '    Endif'
                Endif
              Else
                If W_QFO(W_J)<>""
                    Wrseq '    Gosub SET_FILTER'    # --> Pour Charger S_FILTER
                    Wrseq '    Filter [';W_QATB(W_J);']'    # --> On enlève tout de suite le filtre qui a pu être positionné
                    Wrseq '    If S_FILTER=""'
                    Wrseq '        S_FILTER="1=1"'
                    Wrseq '    Endif'
                Else
                    Wrseq '    S_FILTER="1=1"'
                Endif
                Wrseq '    Case type([F:';W_QATB(W_J);']';W_QOF(W_J);')'
                Wrseq '      When 1, 2, 4, 5, 6, 7, 9 :'
                Wrseq '         W_NUM = val(num$(VALEUR))'
                Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_NUM & evalue(S_FILTER)'
                Wrseq '      When 3 :'
                Wrseq '         W_DAT = VALEUR'
                Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_DAT & evalue(S_FILTER)'
                Wrseq '      When Default :'
                Wrseq '         W_ALP = VALEUR'
                Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_ALP & evalue(S_FILTER)'
                Wrseq '    Endcase'
                Wrseq '    fstat = 5'
                Wrseq '    For [';W_QATB(W_J);']'
                Wrseq '      fstat = 0'
                Wrseq '    Next'
                Wrseq '    Filter [';W_QATB(W_J);']'
                Wrseq '    S_FILTER = ""'
              Endif
            Endif
          When Default :
            If W_QFO(W_J)<>""
                Wrseq '    Gosub SET_FILTER'    # --> Pour Charger S_FILTER
                Wrseq '    Filter [';W_QATB(W_J);']'    # --> On enlève tout de suite le filtre qui a pu être positionné
                Wrseq '    If S_FILTER=""'
                Wrseq '        S_FILTER="1=1"'
                Wrseq '    Endif'
            Else
                Wrseq '    S_FILTER="1=1"'
            Endif
            Wrseq '    Case type([F:';W_QATB(W_J);']';W_QOF(W_J);')'
            Wrseq '      When 1, 2, 4, 5, 6, 7, 9 :'
            Wrseq '         W_NUM = val(num$(VALEUR))'
            Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_NUM & evalue(S_FILTER)'
            Wrseq '      When 3 :'
            Wrseq '         W_DAT = VALEUR'
            Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_DAT & evalue(S_FILTER)'
            Wrseq '      When Default :'
            Wrseq '         W_ALP = VALEUR'
            Wrseq '         Filter [';W_QATB(W_J);'] Where ';W_QOF(W_J);' = W_ALP & evalue(S_FILTER)'
            Wrseq '    Endcase'
            Wrseq '    fstat = 5'
            Wrseq '    For [';W_QATB(W_J);']'
            Wrseq '      fstat = 0'
            Wrseq '    Next'
            Wrseq '    Filter [';W_QATB(W_J);']'
            Wrseq '    S_FILTER = ""'
        Endcase
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
  Wrseq "$CTR_FILTER"
  Wrseq "Gosub OPE_FILTER"
  Wrseq "mkstat = 0"
  Wrseq "Case W_VAR"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    If W_QOB(W_J) <> ""
      W_STR = '"'+W_PRS+W_QSN(W_J)+'"          '
      Wrseq "  When ";W_STR;":"
      Wrseq "    Default file [F:";W_QATB(W_J);"]"
      Wrseq "    If !evalue(S_FILTER) : mkstat = 2 : Endif"
    Endif
  Next
  Wrseq "Endcase"
  Wrseq "Return"
  Wrseq "############################################################"
# Ecriture des routines d'affectation des textes symboles
  If [F:ADS1]NBRLAN = 1
    Wrseq "$CRE_SYMTXT"
    Wrseq 'If evalue("dim("+W_PRX+mid$(W_VAR,3,GLONCQU)+")>0")'
    Wrseq "  Return"
    Wrseq "Endif"
    Wrseq "Case mid$(W_VAR,3,GLONCQU)"
    For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
      If W_J = W_I
        Break
      Endif
      W_FMT = W_PRX+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
      W_STR = '"'+W_QSN(W_J)+'"          '
      # FQ 73793(bis) GA 05/2011 ajout [V]
      # V6 Wrseq "  When ";W_STR;":  Global Char ";W_FMT;'(20) : ';W_FMT;' = "';W_QSM(W_J,0);'"'
      Wrseq "  When ";W_STR;":  Global Char ";W_FMT;'(';GLONDES;') : [V]';W_FMT;' = "';W_QSM(W_J,0);'"'
    Next W_J
    Wrseq "Endcase"
  Else
    Wrseq "$CRE_SYMTXT"
    Wrseq 'If evalue("dim("+W_PRX+mid$(W_VAR,3,GLONCQU)+")>0")'
    Wrseq "  Return"
    Wrseq "Endif"
    Wrseq "Case GLANGUE"
    For W_S = 0 To [F:ADS1]NBRLAN-1
      Wrseq '  When "';[F:ADS1]LAN(W_S);'" :'
      Wrseq "    Case mid$(W_VAR,3,GLONCQU)"
      For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
        If W_J = W_I
          Break
        Endif
        W_FMT = W_PRX+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
        W_STR = '"'+W_QSN(W_J)+'"          '
        # FQ 73793(bis) GA 05/2011 ajout [V]
        # V6 Wrseq "      When ";W_STR;":  Global Char ";W_FMT;'(20) : ';W_FMT;' = "';W_QSM(W_J,W_S);'"'
        Wrseq "      When ";W_STR;":  Global Char ";W_FMT;'(';GLONDES;') : [V]';W_FMT;' = "';W_QSM(W_J,W_S);'"'
      Next W_J
      Wrseq "    Endcase"
    Next W_S
    Wrseq "Endcase"
  Endif
  Wrseq "Return"

  Wrseq "############################################################"
# Ecriture des routines suppresion globales textes
  Wrseq "$KIL_SYMTXT"
  Wrseq 'If evalue("dim("+W_PRX+mid$(W_VAR,3,GLONCQU)+")<0")'
  Wrseq "  Return"
  Wrseq "Endif"
  Wrseq "Case mid$(W_VAR,3,GLONCQU)"
  For W_J = (W_R*W_STE) To (W_R*W_STE)+(W_STE-1)
    If W_J = W_I
      Break
    Endif
    W_FMT = W_PRX+format$("Kv1:"+num$(GLONAVA)+"X",W_QSN(W_J))
    W_STR = '"'+W_QSN(W_J)+'"          '
    Wrseq "  When ";W_STR;":  Kill ";W_FMT
  Next W_J
  Wrseq "Endcase"
  Wrseq "Return"
  Openo
  Call VALID("TRT",W_FSQ,LAPL,W_U) From VALMSKSUB
Next W_R
#
Openo
Call VALID("TRT",W_FSQ,LAPL,W_U) From VALMSKSUB
#
$GEN_WUVAR_UNL
Unlock ="WUVAR"
#
# Issue 105050 by GA 08/2015 : execute new WUVAR scripts
If LAPL=nomap & W_U
   Gosub TAB_SYMBOLES From WUVAR
Endif
$GEN_WUVAR_FIN
End

############################################################
$DEF_SYMBOLE
Case W_QST(W_J)
  When 1 :
    W_LNG = GLONDES
    If find(W_QSN(W_J),"FCY","CUR") : # Issue 54216 GH 19/09/2017 - generated a too short length for MAT
      If evalue("dim(GLON"+W_QSN(W_J)+")")>0
         W_LNG = evalue("GLON"+W_QSN(W_J))
      # Elsif find(W_QSN(W_J),"FCY","CUR") : # Issue 54216 GH 19/09/2017 - FCY is a string with 5 caracters maximum
      Elsif W_QSN(W_J)="FCY"
        W_LNG = 5
      Elsif W_QSN(W_J)="CUR"
        W_LNG = 3
      Endif
    Elsif find(W_QSN(W_J),"ITMSEL","SELITM","CMPSEL","CURITM","CURROU")
      W_LNG = GLONITM : # V6 avant 20
    Endif
    Wrseq " Global Char    ";W_FMT;"("+num$(W_LNG)+")";string$(W_QDI(W_J)>1,"("+num$(W_QDI(W_J))+")");""
  When 2 :
    Wrseq " Global Decimal ";W_FMT;string$(W_QDI(W_J)>1,"("+num$(W_QDI(W_J))+")");""
  When 3 :
    Wrseq " Global Date    ";W_FMT;string$(W_QDI(W_J)>1,"("+num$(W_QDI(W_J))+")");""
  When 4 :
    Wrseq " Global Integer ";W_FMT;string$(W_QDI(W_J)>1,"("+num$(W_QDI(W_J))+")");""
  When 5 :
    Wrseq " Global Char    ";W_FMT;"(250)"
  When 6 :                                           # FQ 50451 GA 11/2008
    Wrseq " Global Blbfile ";W_FMT
  When 7 :                                           # FQ 50451 GA 11/2008
    Wrseq " Global Clbfile ";W_FMT
Endcase
Return

############################################################
# Generation routine de contrôle des liens de ITMMASTER (utiliastion ulterieure)
$GENCHKITM
Wrseq "############################################################"
Wrseq "# Routine to check ITMMASTER fields"
Wrseq "Subprog CHKITM(LRET,LVAL)"
Wrseq "Variable Char    LRET()"
Wrseq "Variable Char    LVAL()"
Wrseq "Local    Char    W_FLD(30)"
Wrseq "Local    Integer W_RET, W_IND"
Wrseq "#"
Wrseq "Raz W_IND,LRET,LVAL"
Filter [ATZ] Where CODFIC =  "ITMMASTER" &
&                  LIEN   <> ""
&            Order By Key  CODZONE
For [ATZ]
  If !find([F:ATZ]CODZONE,"ITMREF")
    Read [ATB]CODFIC=[F:ATZ]LIEN
    Read [ATI]NUMLIG(2)=[F:ATZ]LIEN;1
    W_STR = [F:ATZ]CODZONE+'            '
    W_DIM = evalue("dim([F:ITM]"+[F:ATZ]CODZONE+")")
    For W_M = 0 To W_DIM-1
      If [F:ATZ]OBLIG = 2
        Wrseq 'Local File ';[F:ATZ]LIEN;' [LOO]'
        If W_DIM > 1
          Wrseq 'indice = ';num$(W_M)
        Endif
        Wrseq 'Call CTRFLD("ITMMASTER","';[F:ATZ]CODZONE;'",W_RET)'
        Wrseq 'If W_RET <> 0 : W_FLD = "';[F:ATZ]CODZONE;'" : Gosub LOA_FLDERR : Endif'
        Wrseq 'Close Local file [LOO]'
        Wrseq '#'
      Else
        If W_DIM = 1
          # Issue 93006 GA 11/2013 Case evalue("type([F:ITM]"+[F:ATZ]CODZONE+")")
          Local Shortint WTYPE : WTYPE = evalue("type([F:ITM]"+[F:ATZ]CODZONE+")")
          Case WTYPE
            When 1, 2, 4, 5, 6, 7, 9 :
              Wrseq 'If [F:ITM]';W_STR;' <> 0'
            When 3 :
              Wrseq 'If [F:ITM]';W_STR;' <> [0/0/0]'
            When Default :
              If WTYPE>=10 & WTYPE<522 # Issue 93006 GA 11/2013
                 Wrseq 'If [F:ITM]';W_STR;' <> ""'
              Endif
          Endcase
          Wrseq '  Local File ';[F:ATZ]LIEN;' [LOO]'
          Wrseq '  Call CTRFLD("ITMMASTER","';[F:ATZ]CODZONE;'",W_RET)'
          Wrseq '  If W_RET <> 0 : W_FLD = "';[F:ATZ]CODZONE;'" : Gosub LOA_FLDERR : Endif'
          Wrseq '  Close Local file [LOO]'
          Wrseq 'Endif'
        Else
        # Issue 93006 GA 11/2013 Case evalue("type([F:ITM]"+[F:ATZ]CODZONE+")")
        Local Shortint WTYPE : WTYPE = evalue("type([F:ITM]"+[F:ATZ]CODZONE+")")
        Case WTYPE
            When 1, 2, 4, 5, 6, 7, 9 :
              Wrseq 'If [F:ITM]';W_STR;'(';num$(W_M);') <> 0'
            When 3 :
              Wrseq 'If [F:ITM]';W_STR;'(';num$(W_M);') <> [0/0/0]'
            When Default :
              If WTYPE>=10 & WTYPE<522 # Issue 93006 GA 11/2013
                 Wrseq 'If [F:ITM]';W_STR;'(';num$(W_M);') <> ""'
              Endif
          Endcase
          If WTYPE<522 # Issue 93006 GA 11/2013
            Wrseq '  Local File ';[F:ATZ]LIEN;' [LOO]'
            Wrseq '  indice = ';num$(W_M)
            Wrseq '  Call CTRFLD("ITMMASTER","';[F:ATZ]CODZONE;'",W_RET)'
            Wrseq '  If W_RET <> 0 : W_FLD = "';[F:ATZ]CODZONE;'(';num$(W_M);')" : Gosub LOA_FLDERR : Endif'
            Wrseq '  Close Local file [LOO]'
            Wrseq 'Endif'
          Endif
        Endif
        Wrseq '#'
      Endif
    Next W_M
  Endif
Next
Filter [ATZ]
Wrseq "End"
Wrseq "############################################################"
Wrseq "$LOA_FLDERR"
Wrseq "If W_IND < dim(LRET)-1"
Wrseq '  LRET(W_IND) = W_FLD'
Wrseq "  If W_IND < dim(LVAL)-1"
Wrseq '    LVAL(W_IND) = evalue("num$([F:ITM]"+W_FLD+")")'
Wrseq "  Endif"
Wrseq "  W_IND += 1"
Wrseq "Endif"
Wrseq "Return"
Wrseq "#"
Return
############################################################
Subprog GEN_DEF(LFIC)
Value Integer   LFIC
Local Char   W_SCE(05)
Local Char   W_FLD(80)
Local Char   W_TXT(07)
Local Char   W_FIC(GLONATB) # JAMCC Issue X3-89202 05/2018
Local Char   W_ABR(10)
#
Call CONV_FIC(LFIC,W_FIC,W_ABR) From CFGLIB
#
Wrseq "Onerrgo INI_ERR"
Wrseq "# All scenarios user defined default values"
Filter [CDF] Where RECCOD  = 0    &
&                  CODFIC  = LFIC &
&                  SCENUM  = ""
&            Order By Key CDF1
For [CDF]
  W_FLD = [F:CDF]CODFLD+"          "
  Wrseq W_ABR;W_FLD;"= ";[F:CDF]DEFVAL
Next
Wrseq "# By scenario user defined default values"
Wrseq "Case S_SCENUM"
Filter [CDF] Where CODFIC  = LFIC &
&                  SCENUM <> ""
&            Order By Key CDF1
W_SCE = ""
For [CDF]
  W_FLD = [F:CDF]CODFLD+"          "
  W_TXT = '"'+[F:CDF]SCENUM+'"     '
  If [F:CDF]SCENUM <> W_SCE
    Wrseq '  When ';W_TXT;' : ';W_ABR;W_FLD;"= ";[F:CDF]DEFVAL
  Else
    Wrseq '                 ';W_ABR;W_FLD;"= ";[F:CDF]DEFVAL
  Endif
  W_SCE = [F:CDF]SCENUM
Next
Wrseq "  When default :"
Wrseq "Endcase"
Filter [CDF]
Wrseq "Onerrgo"
End
############################################################
# Routine d'ajout des abreviations [F:xxx] dans l'expression de lien
Subprog MAJ_LNK(LFIC,LABR,LLNK)
Value    Char    LFIC
Value    Char    LABR
Variable Char    LLNK
#
Local    Char    WLNK(120)
Local    Char    WZON(120)
Local    Char    WFLD(GLONAVA)   # Issue 82989 suite GA 11/2012 avant (10)
Local    Integer W_I, W_J
W_I = 1
$MAJ_LNK1
W_J = instr(W_I,LLNK,";")
If W_J = 0
  WZON = seg$(LLNK,W_I,len(LLNK))
Else
  WZON = seg$(LLNK,W_I,W_J-1)
Endif
W_K = instr(1,WZON,"(")
If W_K > 0
  WFLD = seg$(WZON,1,W_K-1)
Else
  WFLD = WZON
Endif
Read [ATZ]CODZONE=LFIC;WFLD
If fstat = 0
  WLNK += LABR+WZON
Else
  WLNK += WZON
Endif
If W_J <> 0
  WLNK += ";"
  W_I = W_J+1
  Goto MAJ_LNK1
Endif
LLNK = WLNK
End
############################################################
# Creation ecran et fenetre sous scenarios par copie
############################################################
Subprog COP_WIN(LAPP,LREF,LMSK,LABR,LWEB)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
Value    Char    LABR
Value    Char    LWEB
#
# Effacement ancien masque
Call DEL_WIN(LAPP,LMSK,"","")  # From CFGLIBA
If GOK <> 1
  Goto COP_WIN_FIN
Endif
Local    Integer W_I, W_J, W_K, W_L, W_M, W_N, W_O
#
If clalev([F:AMK1])= 0 :  Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 :  Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWI1])= 0 :  Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 :  Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 :  Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 :  Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
############################################################
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call FSTA("ADS1") From GLOCK
  GOK = 0
  Goto COP_WIN_FIN
Endif
# Duplication entete ecran
Read [AMK1]CODMSK=LREF
If fstat
  GOK = 0
  Call FSTA("AMK1") From GLOCK
  Goto COP_WIN_FIN
Else
  [F:AMK2]        = [F:AMK1]
  [F:AMK2]CODMSK  = LMSK
  [F:AMK2]ABRMSK  = LABR
  # [F:AMK2]ABRWEB  = LWEB        JPJ 12/09/03
  [F:AMK2]MDL     = 1
  Write [AMK2]
  If fstat
    GOK = 0
    Call FSTA("AMK2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Endif
# Duplication des champs
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
For [AMZ1]
  [F:AMZ2]       = [F:AMZ1]
  [F:AMZ2]CODMSK = LMSK
  Write [AMZ2]
  If fstat
    GOK = 0
    Call FSTA("AMZ2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMZ1]
# Duplication actions ecran
Filter [AMA1] Where TYPAFF = 1    &
&                   CODAFF = LREF
&             Order By Key TYPAFF
For [AMA1]
  [F:AMA2]       = [F:AMA1]
  [F:AMA2]CODAFF = LMSK
  Write [AMA2]
  If fstat
    GOK = 0
    Call FSTA("AMA2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMA1]
# Duplication parametres action

Filter [AMP1] Where TYPAFF = 1    &
&                   CODAFF = LREF
&             Order By Key CODPAR
For [AMP1]
  [F:AMP2]       = [F:AMP1]
  [F:AMP2]CODAFF = LMSK
  Write [AMP2]
  If fstat
    GOK = 0
    Call FSTA("AMP2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AMP1]
# Duplication fenetre
Read [AWI1]AWI0=LREF
If fstat
  GOK = 0
  Call FSTA("AWI1") From GLOCK
  Goto COP_WIN_FIN
Else
  [F:AWI2]          = [F:AWI1]
  [F:AWI2]WIN       = LMSK
  [F:AWI2]NOMMSK(0) = LMSK
  Write [AWI2]
  If fstat
    GOK = 0
    Call FSTA("AWI2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Endif
# Duplication parametres fenetre
Filter [AWP1] Where WIN    = LREF
&             Order By Key AWP0
For [AWP1]
  [F:AWP2]       = [F:AWP1]
  [F:AWP2]WIN    = LMSK
  Write [AWP2]
  If fstat
    GOK = 0
    Call FSTA("AWP2") From GLOCK
    Goto COP_WIN_FIN
  Endif
Next
Filter [AWP1]
Filter [AWT1] Where WIN = LREF
For [AWT1]
  [F:AWT2]    = [F:AWT1]
  [F:AWT2]WIN = LMSK
  Write [AWT2]
  If fstat
    Call FSTA("AWT2") From GLOCK
    Break
  Endif
Next
Filter [AWT1]
Filter [AWB1] Where WIN = LREF
For [AWB1]
  [F:AWB2]    = [F:AWB1]
  [F:AWB2]WIN = LMSK
  Write [AWB2]
  If fstat
    Call FSTA("AWB2") From GLOCK
    Break
  Endif
Next
Filter [AWB1]
#
# FQ 62390 GA 02/2010 vérifier le maxmem sinon erreur dans VALMSKLEC(287) Plus de mémoire disponible
maxmem = max(int(maxmem/1024),40000)

# Issue ???? - GA 02/2012
# Validation ecran et fenetre
Call VALIDDIRECT(LMSK,LAPP,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
# CCC (19/09/05) Bug 32161
If W_O<>1 | GOK<>1
    GOK = 0
    Goto COP_WIN_FIN
Endif
# Issue ???? - GA 02/2012
Call VALIDDIRECT(LMSK,LAPP,0,W_O) From VALWIN
# CCC (19/09/05) Bug 32161
If W_O<>1 | GOK<>1
    GOK = 0
    Goto COP_WIN_FIN
Endif
adxmbm      = adxmbm
$COP_WIN_FIN
End

############################################################
# Creation ecran de selection
# LAPP    : application
# LREF    : ecran de reference
# LMSK    : ecran genere
# LNBL    : nombre de lignes fenetre
# LQTY    : Choix colonne quantite
# LPRI    : Choix colonne prix
# LFLD    : champs a visualiser codes "nom fichier,nom zone"
# LLIN    : Ligne de produit pour conversion intitules (facult)
# LFIL    : Filtres supplementaires
############################################################
Subprog GEN_SEL(LAPP,LREF,LMSK,LNBL,LQTY,LPRI,LFLD,LLIN,LFIL)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
Value    Integer LNBL
Value    Integer LQTY
Value    Integer LPRI
Variable Char    LFLD()
Value    Char    LLIN
Value    Char    LFIL
#
# Effacement ancien masque
Call DEL_WIN(LAPP,LMSK,"","")  # From CFGLIBA
If GOK <> 1
  Goto GEN_SEL_FIN
Endif
#
Local    Integer W_STAT
Local    Char    W_SUF(4)
Local    Integer W_LAN
Local    Char    W_GLANGUE(3)
Local    Char    W_FICANU(GDIMFIC)
Local    Char    W_TRTANU(GDIMFIC)
Local    Char    W_FIC(GLONATB)(dim(LFLD)+1) # JAMCC Issue X3-89202 05/2018
Local    Char    W_ZON(GLONAVA)(dim(LFLD)+1) # Issue 82989 suite GA 11/2012 avant (10)
Local    Char    W_EVA(40)
#
Local    Integer W_I, W_J, W_K, W_L, W_M, W_O
#
If clalev([F:AMK1])= 0 :  Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 :  Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
If clalev([F:ATB1])= 0 :  Local File ATABLE             [ATB1]  : Endif
If clalev([F:ATZ1])= 0 :  Local File ATABZON            [ATZ1]  : Endif
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
If clalev([F:TLP]) = 0 :  Local File TABLINCFG          [TLP]   : Endif
############################################################
# Lecture ligne de produit
If LLIN <> ""
  Read [TLP]TLP0=LLIN
  If fstat
    Raz [F:TLP]
  Endif
Else
  Raz [F:TLP]
Endif
# Lecture des champs
Raz W_FIC, W_ZON, W_J
If !find(LFLD,"ITMMASTER,ITMREF")
  W_FIC(W_J) = "ITMMASTER"
  W_ZON(W_J) = "ITMREF"
  W_J += 1
Endif
For W_I = 0 To dim(LFLD)-1
  If LFLD(W_I) <> ""
    W_K = instr(1,LFLD(W_I),",")
    W_FIC(W_J) = seg$(LFLD(W_I),1,W_K-1)
    W_ZON(W_J) = seg$(LFLD(W_I),W_K+1,len(LFLD(W_I)))
    W_J += 1
  Endif
Next I
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call FSTA("ADS1") From GLOCK
  GOK = 0
  Goto GEN_SEL_FIN
Endif
############################################################
# Mise a jour AMSK
Read [AMK1]CODMSK=LREF
If fstat
  Call RSTA("AMK1",LREF) From GLOCK
  GOK =0
  Goto GEN_SEL_FIN
Endif
#
[F:AMK2]          = [F:AMK1]
[F:AMK2]CODMSK    = LMSK
[F:AMK2]NBLIGT(3) = LNBL
[F:AMK2]MDL       = 1
If (LFIL(0) = "" & LFIL(1) = "" & LFIL(2) ="" &LFIL(3) ="")
  [F:AMK2]LNGLIB(2) = 15
Endif
Write [AMK2]
If fstat
  Call FSTA("AMK2") From GLOCK
  GOK =0
  Goto GEN_SEL_FIN
Endif
############################################################
# Mise a jour AMSKZON
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
For [AMZ1]
  [F:AMZ2]       = [F:AMZ1]
  [F:AMZ2]CODMSK = LMSK
  If [F:AMZ1]CODZON = "FLD"
    For W_I = 0 To dim(W_FIC)-1
      If W_FIC(W_I) <> ""
        Read [ATB1]CODFIC=W_FIC(W_I)
        If fstat = 0
          Read [ATZ1]CODZONE=W_FIC(W_I);W_ZON(W_I)
          If fstat = 0
            [F:AMZ2]CODTYP     = [F:ATZ1]CODTYP
            [F:AMZ2]CODZON     = [F:ATZ1]CODZONE
            Gosub TRT_INTIT
            [F:AMZ2]LONG       = [F:ATZ1]LONG
            [F:AMZ2]NOLIB      = [F:ATZ1]NOLIB
            [F:AMZ2]NOZONE     = W_I + 20
            [F:AMZ2]DIME       = LNBL
            # JPJ E22595 - Reprendre l'option d'affichage définit sur la table
            [F:AMZ2]OPTSAI      = [F:AMZ1]OPTSAI
            If [F:ATZ1]OPTION<>"" : [F:AMZ2]OPTSAI=[F:ATZ1]OPTION : Endif      # /JPJ E22595
            Write [AMZ2]
            If fstat
              Call FSTA("AMZ2") From GLOCK
              GOK =0
              Break 2
            Endif
            Read [AMP1]CODPAR=1;[F:AMZ1]CODMSK;"DMY"+[F:AMZ2]CODTYP
            If fstat = 0
              [F:AMP2]       = [F:AMP1]
              [F:AMP2]CODAFF = [F:AMZ2]CODMSK
              [F:AMP2]CODZON = [F:AMZ2]CODZON
              Write [AMP2]
              If fstat
                Call FSTA("AMP2") From GLOCK
                GOK =0
                Break 2
              Endif
            Endif
          Endif
        Endif
      Endif
    Next W_I
  Else
    Gosub VAL_ZON
    If W_L = 1
      If [F:AMZ2]NUMBLOC = 4
        [F:AMZ2]DIME = LNBL
      Endif
      Write [AMZ2]
      If fstat
        Call FSTA("AMZ2") From GLOCK
        GOK =0
        Break
      Endif
      Filter [AMA1] Where TYPAFF = 1              &
&                         CODAFF = LREF           &
&                         CODZON = [F:AMZ2]CODZON
&                   Order By Key TYPAFF
      For [AMA1]
        [F:AMA2]       = [F:AMA1]
        [F:AMA2]CODAFF = LMSK
        Write [AMA2]
        If fstat
          Call FSTA("AMA2") From GLOCK
          GOK =0
          Break
        Endif
      Next
      Filter [AMA1]
      Filter [AMP1] Where TYPAFF = 1              &
&                         CODAFF = LREF           &
&                         CODZON = [F:AMZ2]CODZON
&                   Order By Key CODPAR
      For [AMP1]
        [F:AMP2]       = [F:AMP1]
        [F:AMP2]CODAFF = LMSK
        Write [AMP2]
        If fstat
          Call FSTA("AMP2") From GLOCK
          GOK =0
          Break
        Endif
      Next
      Filter [AMP1]
    Endif
  Endif
Next
Filter [AMZ1]
#
# FQ 62390 GA 02/2010 vérifier le maxmem sinon erreur dans VALMSKLEC(287) Plus de mémoire disponible
maxmem = max(int(maxmem/1024),40000)

# Validation du masque
Call VALID(LMSK,LAPP,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
# CCC (19/09/05) Bug 32161
If W_O<>1 | GOK<>1
    GOK = 0
    Goto GEN_SEL_FIN
Endif
Call GEN_FEN(LAPP,LREF,LMSK)
adxmbm      = adxmbm
#
$GEN_SEL_FIN
End
############################################################
$VAL_ZON
W_L = 0
If (left$([F:AMZ1]CODZON,3) = "DMY")          |
&  ([F:AMZ1]CODZON = "QTYSAU"  & LQTY <> 3)   |
&  ([F:AMZ1]CODZON = "CST"     & LPRI = 1 )   |
&  ([F:AMZ1]CODZON = "FIL000"  & LFIL(0) = "")
  W_L = 0
Else
  W_L = 1
  If ([F:AMZ1]CODZON = "SELSUP" & LFIL(0) = "" & LFIL(1) = "" & LFIL(2) ="" &LFIL(3) ="")
    [F:AMZ2]NOZONE  = 1
  Endif
  If ([F:AMZ1]CODZON = "CSTTOT"  & LPRI    = 1 ) |
&    ([F:AMZ1]CODZON = "QTYSTU"  & LQTY   <> 2 ) |
&    ([F:AMZ1]CODZON = "CUR"     & LPRI    = 1 )
    [F:AMZ2]SAIAFF = 3
    [F:AMZ2]OPTSAI = ""
    [F:AMZ2]OPTFOR = ""
    [F:AMZ2]OBLIG  = 1
    [F:AMZ2]LIEN   = 1
    [F:AMZ2]TUNNEL = 1
  Endif
# Effacement filtres inactifs selon ecran de reference
  If LREF = "CFGSEL"
    If ([F:AMZ1]CODZON = "SELINT1" & LFIL(0) = "") |
&      ([F:AMZ1]CODZON = "ANDOR1"  & LFIL(1) = "") |
&      ([F:AMZ1]CODZON = "SELINT2" & LFIL(1) = "") |
&      ([F:AMZ1]CODZON = "ANDOR2"  & LFIL(2) = "") |
&      ([F:AMZ1]CODZON = "SELINT3" & LFIL(2) = "") |
&      ([F:AMZ1]CODZON = "ANDOR3"  & LFIL(3) = "") |
&      ([F:AMZ1]CODZON = "SELINT4" & LFIL(3) = "") |
&      ([F:AMZ1]CODZON = "ANDOR4"  & LFIL(0) = "" & LFIL(1) = "" & LFIL(2) ="" &LFIL(3) ="")
      [F:AMZ2]SAIAFF = 3
      [F:AMZ2]OPTSAI = ""
      [F:AMZ2]OPTFOR = ""
      [F:AMZ2]OBLIG  = 1
      [F:AMZ2]LIEN   = 1
      [F:AMZ2]TUNNEL = 1
    Endif
  Else
    If left$([F:AMZ1]CODZON,6) = "SELINT"
      W_M = val(right$([F:AMZ1]CODZON,7)) -1
      If evalue("LFIL("+num$(W_M)+")=''")
        [F:AMZ2]SAIAFF = 3
        [F:AMZ2]OPTSAI = ""
        [F:AMZ2]OPTFOR = ""
        [F:AMZ2]OBLIG  = 1
        [F:AMZ2]LIEN   = 1
        [F:AMZ2]TUNNEL = 1
      Endif
    Endif
  Endif
Endif
Return
############################################################
# Intitule : court pour unite / normal pour autres champs
#            conversion des intitules si rubriques configurateur
$TRT_INTIT
If [F:AMZ2]CODTYP = "UOM"
  [F:AMZ2]INTIT = [F:ATZ1]NOABREG
Else
  [F:AMZ2]INTIT = [F:ATZ1]NOCOURT
Endif
[F:AMZ2]INTEVAL = ""
Case left$([F:AMZ2]CODZON,9)
  When "CFGFLDNUM" :
    W_EVA = "[F:TLP]CFGNUM"+num$(mid$([F:AMZ2]CODZON,10,1))
    If evalue(W_EVA) > 1
      [F:AMZ2]INTIT = 0
      [F:AMZ2]INTEVAL = "mess("+num$(evalue(W_EVA))+",760,1)"
    Endif
  When "CFGFLDALP" :
    W_EVA = "[F:TLP]CFGALP"+num$(mid$([F:AMZ2]CODZON,10,1))
    If evalue(W_EVA) > 1
      [F:AMZ2]INTIT = 0
      [F:AMZ2]INTEVAL = "mess("+num$(evalue(W_EVA))+",760,1)"
    Endif
Endcase
Return
############################################################
# Creation ecran de saisie ligne de produit
# LAPP     : application
# LREF     : ecran de reference
# LMSK     : ecran genere
# LNUF     : Intitule numeriques
# LNUS     : Codes saisie numerique
# LNUT     : Table de controle numerique
# LALF     : Intitule alpha
# LALS     : Codes saisie alpha
# LALT     : Table de controle alpha
############################################################
Subprog GEN_LIN(LAPP,LREF,LMSK,LNUF,LNUS,LNUT,LALF,LALS,LALT)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
Value    Integer LNUF()
Value    Integer LNUS()
Value    Char    LNUT()
Value    Integer LALF()
Value    Integer LALS()
Value    Char    LALT()
#
# Effacement ancien masque
Call DEL_WIN(LAPP,LMSK,"","")  # From CFGLIBA
If GOK <> 1
  Goto GEN_LIN_FIN
Endif
#
Local    Integer W_STAT
Local    Char    W_SUF(4)
Local    Integer W_LAN
Local    Char    W_GLANGUE(3)
Local    Char    W_FICANU(GDIMFIC)
Local    Char    W_TRTANU(GDIMFIC)
Local    Integer W_BLO, W_BLO1, W_BLO2
#
Local    Integer W_I, W_J, W_K, W_O, W_P
#
If clalev([F:AMK1])= 0 :  Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 :  Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:ATB1])= 0 :  Local File ATABLE             [ATB1]  : Endif
If clalev([F:ATZ1])= 0 :  Local File ATABZON            [ATZ1]  : Endif
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
############################################################
# Calcul taille bloc maxi
W_BLO1 = 0
W_BLO2 = 0
For W_I = 0 To dim(LALF)-1
  If LALF(W_I) > 1
    W_BLO1 += 1
  Endif
Next W_I
#
For W_I = 0 To dim(LNUF)-1
  If LNUF(W_I) > 1
    W_BLO2 += 1
  Endif
Next W_I
If W_BLO1 > W_BLO2
  W_BLO = W_BLO1
Else
  W_BLO = W_BLO2
Endif
#
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call FSTA("ADS1") From GLOCK
  GOK = 0
  Goto GEN_LIN_FIN
Endif
############################################################
# Mise a jour AMSK
Read [AMK1]CODMSK=LREF
If fstat
  Call RSTA("AMK1",LREF) From GLOCK
  GOK =0
  Goto GEN_LIN_FIN
Endif
#
[F:AMK2]          = [F:AMK1]
[F:AMK2]CODMSK    = LMSK
[F:AMK2]MDL       = 1
If W_BLO1 = 0
  [F:AMK2]POSBLOC(1) = 3.1
  [F:AMK2]POSBLOC(2) = 2.1
  [F:AMK2]TYPBLOC(1) = 5
Endif
If W_BLO2 = 0
  [F:AMK2]TYPBLOC(2) = 5
Endif
#
If LREF = "CFGLIN"
  [F:AMK2]NBRLIG = max((W_BLO1+W_BLO2+4),9)
Else
  [F:AMK2]NBRLIG = W_BLO1+W_BLO2+4
Endif
Write [AMK2]
If fstat
  Call FSTA("AMK2") From GLOCK
  GOK =0
  Goto GEN_LIN_FIN
Endif
############################################################
# Mise a jour AMSKZON
W_K = 1
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
For [AMZ1]
  Case [F:AMZ1]CODZON
    When "FLDNUM" :
      W_J = 1
      For W_I = 0 To dim(LNUF)-1
        [F:AMZ2]       = [F:AMZ1]
        [F:AMZ2]CODMSK = LMSK
        If LNUF(W_I) > 1
          [F:AMZ2]CODZON     = "CFGFLDNUM"+num$(W_I+1)
          [F:AMZ2]INTIT      = 0
          [F:AMZ2]NOZONE     = W_J
          [F:AMZ2]INTEVAL    = "mess("+num$(LNUF(W_I))+",760,1)"
          Case LNUS(W_I)
            When 1 :
              [F:AMZ2]SAIAFF = 1
              [F:AMZ2]OBLIG  = 2
            When 2 :
              [F:AMZ2]SAIAFF = 1
              [F:AMZ2]OBLIG  = 1
            When 3 :
              [F:AMZ2]SAIAFF = 2
              [F:AMZ2]OBLIG  = 1
            When 4 :
              [F:AMZ2]SAIAFF = 3
              [F:AMZ2]OBLIG  = 1
          Endcase
          [F:AMZ2]NUMLIG     = W_K
          W_K += 1
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK =0
            Break 2
          Endif
#
          [F:AMZ2]CODZON     = "CFGTXTNUM"+num$(W_I+1)
          [F:AMZ2]INTIT      = 0
          [F:AMZ2]NOZONE     = W_J+0.2
          [F:AMZ2]INTEVAL    = ""
          [F:AMZ2]SAIAFF     = 2
          [F:AMZ2]OBLIG      = 1
          [F:AMZ2]CODTYP     = "A"  : # FQ 49950 ici on garde A20 plutôt que le type DCT
          [F:AMZ2]LONG       = 20
          [F:AMZ2]OPTSAI     = "W"
          [F:AMZ2]NUMLIG     = W_K
          W_J += 1
          W_K += 1
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK =0
            Break 2
          Endif
#
          Filter [AMA1] Where TYPAFF = 1     &
&                             CODAFF = LREF  &
&                             CODZON = "FLDNUM"
&                       Order By Key TYPAFF
          For [AMA1]
            [F:AMA2]       = [F:AMA1]
            [F:AMA2]CODAFF = LMSK
            [F:AMA2]CODZON = "CFGFLDNUM"+num$(W_I+1)
            Case [F:AMA1]TYPACT
              When 5 :
                If ([F:AMA1]ACTION="CFGCTRTCTN" & LNUT(W_I) <> "")
                  Write [AMA2]
                  If fstat
                    Call FSTA("AMA2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When 8 :
                If ([F:AMA1]ACTION="SELTCT" & LNUT(W_I) <> "")
                  Write [AMA2]
                  If fstat
                    Call FSTA("AMA2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
               Endif
             Endcase
           Next
           Filter [AMA1]
#
           Filter [AMP1] Where TYPAFF = 1         &
&                              CODAFF = LREF      &
&                              CODZON = "FLDNUM"
&                        Order By Key CODPAR
           For [AMP1]
             [F:AMP2]       = [F:AMP1]
             [F:AMP2]CODAFF = LMSK
             [F:AMP2]CODZON = "CFGFLDNUM"+num$(W_I+1)
             Case [F:AMP1]CODPAR
               When "TCT"    :
                 If LNUT(W_I) <> ""
                   [F:AMP2]VALPAR = '"'+LNUT(W_I)+'"'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
               When "FLDNAM" :
                 If LNUT(W_I) <> ""
                   [F:AMP2]VALPAR = '"CFGFLDNUM'+num$(W_I+1)+'"'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
               When "QSTNUM"    : # V6 oubli des versions précédentes ? paramètre ajouté à l'action SELTCT
                 If LNUT(W_I) <> ""
                   [F:AMP2]VALPAR = '""'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
             Endcase
           Next
           Filter [AMP1]
         Endif
      Next W_I
    When "FLDALP" :
      W_J = 1
      For W_I = 0 To dim(LALF)-1
        [F:AMZ2]       = [F:AMZ1]
        [F:AMZ2]CODMSK = LMSK
        If LALF(W_I) > 1
          [F:AMZ2]CODZON     = "CFGFLDALP"+num$(W_I+1)
          [F:AMZ2]INTIT      = 0
          [F:AMZ2]NOZONE     = W_J
          [F:AMZ2]INTEVAL    = "mess("+num$(LALF(W_I))+",760,1)"
          Case LALS(W_I)
            When 1 :
              [F:AMZ2]SAIAFF = 1
              [F:AMZ2]OBLIG  = 2
            When 2 :
              [F:AMZ2]SAIAFF = 1
              [F:AMZ2]OBLIG  = 1
            When 3 :
              [F:AMZ2]SAIAFF = 2
              [F:AMZ2]OBLIG  = 1
            When 4 :
              [F:AMZ2]SAIAFF = 3
              [F:AMZ2]OBLIG  = 1
          Endcase
          [F:AMZ2]NUMLIG     = W_K
          W_K += 1
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK =0
            Break 2
          Endif
#
          [F:AMZ2]CODZON     = "CFGTXTALP"+num$(W_I+1)
          [F:AMZ2]INTIT      = 0
          [F:AMZ2]NOZONE     = W_J+0.2
          [F:AMZ2]INTEVAL    = ""
          [F:AMZ2]SAIAFF     = 2
          [F:AMZ2]OBLIG      = 1
          If dim(GLONDCT)>0 & GLONDCT>30  : # FQ 49950 GA 11/2008 type de données DCT
            [F:AMZ2]CODTYP     = "A"
            [F:AMZ2]LONG       = GLONDCT
            [F:AMZ2]OPTLNG     = 20         # FQ 53017 GA 02/2009
          Else
            [F:AMZ2]CODTYP     = "A"
            [F:AMZ2]LONG       = 20
          Endif
          [F:AMZ2]OPTSAI     = "W"
          [F:AMZ2]NUMLIG     = W_K
          W_J += 1
          W_K += 1
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK =0
            Break 2
          Endif
#
          Filter [AMA1] Where TYPAFF = 1        &
&                             CODAFF = LREF     &
&                             CODZON = "FLDALP"
&                       Order By Key TYPAFF
          For [AMA1]
            [F:AMA2]       = [F:AMA1]
            [F:AMA2]CODAFF = LMSK
            [F:AMA2]CODZON = "CFGFLDALP"+num$(W_I+1)
            Case [F:AMA1]TYPACT
              When 5 :
                If ([F:AMA1]ACTION="CFGCTRTCTA" & LALT(W_I) <> "")
                  Write [AMA2]
                  If fstat
                    Call FSTA("AMA2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When 8 :
                If ([F:AMA1]ACTION="SELTCT" & LALT(W_I) <> "")
                  Write [AMA2]
                  If fstat
                    Call FSTA("AMA2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
               Endif
             Endcase
           Next
           Filter [AMA1]
#
           Filter [AMP1] Where TYPAFF = 1          &
&                              CODAFF = LREF       &
&                              CODZON = "FLDALP"
&                        Order By Key CODPAR
           For [AMP1]
             [F:AMP2]       = [F:AMP1]
             [F:AMP2]CODAFF = LMSK
             [F:AMP2]CODZON = "CFGFLDALP"+num$(W_I+1)
             Case [F:AMP1]CODPAR
               When "TCT"    :
                 If LALT(W_I) <> ""
                   [F:AMP2]VALPAR = '"'+LALT(W_I)+'"'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
               When "FLDNAM" :
                 If LALT(W_I) <> ""
                   [F:AMP2]VALPAR = '"CFGFLDALP'+num$(W_I+1)+'"'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
               When "QSTNUM"    : # V6 oubli des versions précédentes ? paramètre ajouté à l'action SELTCT
                 If LALT(W_I) <> ""
                   [F:AMP2]VALPAR = '""'
                   Write [AMP2]
                   If fstat
                     Call FSTA("AMP2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
              Endcase
           Next
           Filter [AMP1]
         Endif
      Next W_I
    When Default :
      [F:AMZ2]       = [F:AMZ1]
      [F:AMZ2]CODMSK = LMSK
      [F:AMZ2]NUMLIG = W_K
      Write [AMZ2]
      If fstat
        Call FSTA("AMZ2") From GLOCK
        GOK =0
        Break
      Endif
      Filter [AMA1] Where TYPAFF = 1              &
&                         CODAFF = LREF           &
&                         CODZON = [F:AMZ2]CODZON
&                   Order By Key TYPAFF
      For [AMA1]
        [F:AMA2]       = [F:AMA1]
        [F:AMA2]CODAFF = LMSK
        Write [AMA2]
        If fstat
          Call FSTA("AMA2") From GLOCK
          GOK =0
          Break
        Endif
      Next
      Filter [AMA1]
      Filter [AMP1] Where TYPAFF = 1              &
&                         CODAFF = LREF           &
&                         CODZON = [F:AMZ2]CODZON
&                   Order By Key CODPAR
      For [AMP1]
        [F:AMP2]       = [F:AMP1]
        [F:AMP2]CODAFF = LMSK
        Write [AMP2]
        If fstat
          Call FSTA("AMP2") From GLOCK
          GOK =0
          Break
        Endif
      Next
      Filter [AMP1]
  Endcase
Next
Filter [AMZ1]
#
# FQ 77122 GA 10/2011 code déplacé + cas particulier validation différée
Call GEN_MSK(LAPP,LREF,LMSK) From CFGLIBA

Call GEN_FEN(LAPP,"ICFGLIN",LMSK)
adxmbm      = adxmbm
$GEN_LIN_FIN
End
############################################################
Subprog GEN_MSK(LAPP,LREF,LMSK)                 # FQ 77122 #
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
Local    Integer W_O
#
# FQ 46086 GA 02/2008 selon mb 13.2.7
# maxmem = max(int(maxmem/1024),30000)
# FQ 62390 GA 02/2010 vérifier le maxmem sinon erreur dans VALMSKLEC(287) Plus de mémoire disponible
maxmem = max(int(maxmem/1024),40000)

If clalev([M:CFGU])=0    # on est en interactif => validation directe
    # Validation ecran et fenetre
    # Issue 79793 - GA 02/2012
    #Call CTRL_MASK(LAPP,LMSK,"") From TRTX3   # FQ 77679 GA 11/2011
    Call VALIDDIRECT (LMSK,LAPP,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
    # CCC (19/09/05) Bug 32161
    If W_O<>1 | GOK<>1
        GOK = 0
      End     # FQ 77122 GA 10/2011 code déplacé depuis CFGLIBE avant Goto OK_POS_FIN
    Endif

    # JPJ - Ajout pour charger le nouveau mask en mémoire
    Case left$(LMSK,3)
      When "WUA"    :  If (clalev([M:CINI])=0) : Local Mask =LAPP+"."+LMSK [CINI] : Endif : Close Local Mask [CINI]
      When "WUS"    :  If (clalev([M:CSEL])=0) : Local Mask =LAPP+"."+LMSK [CSEL] : Endif : Close Local Mask [CSEL]
      When "WUF"    :  If (clalev([M:CSHA])=0) : Local Mask =LAPP+"."+LMSK [CSHA] : Endif : Close Local Mask [CSHA]
      When "WUX"    :  If (clalev([M:CSCE])=0) : Local Mask =LAPP+"."+LMSK [CSCE] : Endif : Close Local Mask [CSCE]
      When "ZUX"    :  If (clalev([M:CSCE])=0) : Local Mask =LAPP+"."+LMSK [CSCE] : Endif : Close Local Mask [CSCE]
      When "WUI"    :  If (clalev([M:CINI])=0) : Local Mask =LAPP+"."+LMSK [CINI] : Endif : Close Local Mask [CINI]
      When Default
    Endcase
Else
    # on est en validation de dossier => validation éventuellement différée
    Call VALID (LMSK,LAPP,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
    # CCC (19/09/05) Bug 32161
    If W_O<>1 | GOK<>1
        GOK = 0
      End     # FQ 77122 GA 10/2011 code déplacé depuis CFGLIBE avant Goto OK_POS_FIN
    Endif
Endif
End

############################################################
Subprog GEN_FEN(LAPP,LREF,LMSK)
Value    Char    LAPP
Value    Char    LREF
Value    Char    LMSK
#
Local    Integer W_I
#
If clalev([F:AWI1])= 0 :  Local File =LAPP+".AWINDOW"   [AWI1]  : Endif
If clalev([F:AWI2])= 0 :  Local File =LAPP+".AWINDOW"   [AWI2]  : Endif
If clalev([F:AWP1])= 0 :  Local File =LAPP+".AWINPAR"   [AWP1]  : Endif
If clalev([F:AWP2])= 0 :  Local File =LAPP+".AWINPAR"   [AWP2]  : Endif
If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
#
Read [AWI1]AWI0=LREF
If fstat = 0
  [F:AWI2]          = [F:AWI1]
  [F:AWI2]WIN       = LMSK
  [F:AWI2]NOMMSK(0) = LMSK
  [F:AWI2]MDL       = 1        # ecran normal
  Write [AWI2]
  Filter [AWP1] Where WIN = LREF
  For [AWP1]
    [F:AWP2]    = [F:AWP1]
    [F:AWP2]WIN = LMSK
    Write [AWP2]
    If fstat
      Call FSTA("AWP2") From GLOCK
      Break
    Endif
  Next
  Filter [AWP1]
  Filter [AWT1] Where WIN = LREF
  For [AWT1]
    [F:AWT2]    = [F:AWT1]
    [F:AWT2]WIN = LMSK
    Write [AWT2]
    If fstat
      Call FSTA("AWT2") From GLOCK
      Break
    Endif
  Next
  Filter [AWT1]
  Filter [AWB1] Where WIN = LREF
  For [AWB1]
    [F:AWB2]    = [F:AWB1]
    [F:AWB2]WIN = LMSK
    Write [AWB2]
    If fstat
      Call FSTA("AWB2") From GLOCK
      Break
    Endif
  Next
  Filter [AWB1]
  If clalev([M:CFGU])=0     # FQ 77122 on est en interactif => validation directe
     Call VALIDDIRECT(LMSK,LAPP,0,W_I) From VALWIN
  Else
     Call VALID(LMSK,LAPP,0,W_I) From VALWIN
  Endif
Endif
End
############################################################
# Generation des variables systemes accessibles utilisateur
# Si modif ne pas oublier de modifier (CFG_CRESYMSYS dans CFGLIB)
Subprog GEN_VARSYS
Local Integer WBOC, WSEL, I
If clalev([F:ACV]) = 0 : Local File ACTIV [ACV] : Endif
If dim(S_DOSSIER)>0 & S_DOSSIER<>nomap
   If clalev([F:CQU]) = 0 : Local File =S_DOSSIER+".CFGQST"  [CQU]  : Endif # FQ 50431
   If clalev([M:CFV1])= 0 : Local Mask =S_DOSSIER+".CFGVAL1" [CFV1] : Endif # FQ 72829 GA 04/2011
Else
   If clalev([F:CQU]) = 0 : Local File              CFGQST   [CQU]  : Endif # FQ 50431
   If clalev([M:CFV1])= 0 : Local Mask              CFGVAL1  [CFV1] : Endif
Endif
Read [ACV]CODACT="BOC"
If fstat = 0
  WBOC = [F:ACV]DIME
Else
  WBOC = 300
Endif
WSEL = dim([M:CFV1]ITMREF)
#
Call GEN_FLDSYS("FCY"   ,mess(1,772,1),1,1,2,1,"")
Call GEN_FLDSYS("IPTDAT",mess(2,772,1),3,0,1,1,"")
Call GEN_FLDSYS("CUR"   ,mess(3,772,1),1,1,2,1,"")
Call GEN_FLDSYS("TRAFLG",mess(4,772,1),2,0,1,1,"")
Call GEN_FLDSYS("BPRNUM",mess(5,772,1),1,1,2,1,"")
Call GEN_FLDSYS("BPRREF",mess(6,772,1),1,1,2,1,"")
Call GEN_FLDSYS("PURDAT",mess(7,772,1),3,0,1,1,"")
Call GEN_FLDSYS("ITMQTY",mess(8,772,1),2,0,2,1,"")
Call GEN_FLDSYS("NOHIS" ,mess(9,772,1),2,0,1,1,"")
Call GEN_FLDSYS("ITMSEL",mess(10,772,1),1,1,1,WSEL,"")
Call GEN_FLDSYS("SELITM",mess(12,772,1),1,1,2,1,"")
Call GEN_FLDSYS("CMPSEL",mess(11,772,1),1,1,1,WBOC,"")
Call GEN_FLDSYS("CURITM",mess(12,772,1),1,1,2,1,"")
Call GEN_FLDSYS("CURROU",mess(13,772,1),1,1,2,1,"")
Call GEN_FLDSYS("CSTTOT",mess(14,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CSTMAT",mess(15,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CSTMAC",mess(16,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CSTLAB",mess(17,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CSTSCO",mess(18,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CSTOVE",mess(19,772,1),2,0,2,1,"0")
Call GEN_FLDSYS("CST"   ,mess(20,772,1),2,0,1,1,"")
Call GEN_FLDSYS("ITMREF",mess(21,772,1),1,1,1,1,"")
Call GEN_FLDSYS("ITMDES",mess(22,772,1),1,3,1,1,"")
Call GEN_FLDSYS("CFGLIN",mess(23,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGNUM1",mess(24,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGNUM2",mess(25,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGNUM3",mess(26,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGNUM4",mess(27,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGNUM5",mess(28,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGNUM6",mess(29,772,1),2,0,1,1,"")
Call GEN_FLDSYS("CFGALP1",mess(30,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGALP2",mess(31,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGALP3",mess(32,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGALP4",mess(33,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGALP5",mess(34,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CFGALP6",mess(35,772,1),1,1,1,1,"")
Call GEN_FLDSYS("LNKOK"  ,mess(36,772,1),2,0,1,1,"")
Call GEN_FLDSYS("RNDVAR" ,mess(37,772,1),2,0,1,1,"6")
Call GEN_FLDSYS("UPDLEV" ,mess(38,772,1),1,1,1,1,"")
Call GEN_FLDSYS("SCESEL" ,mess(39,772,1),1,1,1,1,"")
Call GEN_FLDSYS("FILTER" ,mess(40,772,1),5,3,1,1,"")
Call GEN_FLDSYS("RPAR"   ,mess(41,772,1),1,1,1,1,"")
Call GEN_FLDSYS("GENDES1",mess(42,772,1),1,3,1,1,"")
Call GEN_FLDSYS("GENDES2",mess(43,772,1),1,3,1,1,"")
Call GEN_FLDSYS("GENDES3",mess(44,772,1),1,3,1,1,"")
Call GEN_FLDSYS("PURMEM" ,mess(45,772,1),2,0,1,1,"")
Call GEN_FLDSYS("DYNAMT" ,mess(46,772,1),2,0,1,1,"0")
Call GEN_FLDSYS("DYNABQ" ,mess(47,772,1),1,1,1,1,"")
Call GEN_FLDSYS("CSTBOM" ,mess(48,772,1),4,0,1,1,"0")    # FQ 49639 GA 10/2008 booléen - avant "" GA 12/2008
# Issue 105776 GA 02/2015 - start
Local Shortint WKO : WKO=0
For [CQU] Where find(QSTNUM,"BOMALTRE","ROUALTRE")
   WKO=1 : Break
Next
If WKO=1
   Call MAJ_UTICFG001(S_DOSSIER) From UUCFG001
Endif
# Issue 105776 GA 02/2015 - end
Call GEN_FLDSYS("BOMALT"   ,mess(49,772,1),2,0,1,1,"0")  # Issue 82989 GA 07/2012 4 new dedicated symbols
Call GEN_FLDSYS("BOMALTREF",mess(50,772,1),2,0,1,1,"0")  # Issue 82989 GA 07/2012 4 new dedicated symbols
Call GEN_FLDSYS("ROUALT"   ,mess(51,772,1),2,0,1,1,"0")  # Issue 82989 GA 07/2012 4 new dedicated symbols
Call GEN_FLDSYS("ROUALTREF",mess(52,772,1),2,0,1,1,"0")  # Issue 82989 GA 07/2012 4 new dedicated symbols
For I=1 To 9                                             # Issue 93425 GA 11/2013
   # Issue 104907 text messages are inverted customer v/s supplier
   #Call GEN_FLDSYS("ITUITM"+num$(I),mess(53,772,1)-num$(I),1,3,1,1,"")
   #Call GEN_FLDSYS("ITPITM"+num$(I),mess(54,772,1)-num$(I),1,3,1,1,"")
   #Call GEN_FLDSYS("ITUDES"+num$(I),mess(55,772,1)-num$(I),1,3,1,1,"")
   #Call GEN_FLDSYS("ITPDES"+num$(I),mess(56,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITPITM"+num$(I),mess(53,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITUITM"+num$(I),mess(54,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITPDES"+num$(I),mess(55,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITUDES"+num$(I),mess(56,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITPBPR"+num$(I),mess(5,772,1)-num$(I),1,3,1,1,"")
   Call GEN_FLDSYS("ITUBPR"+num$(I),mess(5,772,1)-num$(I),1,3,1,1,"")
Next
# Issue 107850 - 2015-06-23 by GA : Filter for response table
Call GEN_FLDSYS("FILTCT" ,mess(57,772,1),1,1,1,1,"")
# Issue 95035 GA 12/2013
# ATTENTION: vérifier que le nb de variables insérées [au 1er lancement] ne dépasse pas 200 (cf GEN_WUVAR)
End
############################################################
# Generation une variable systemes accessibles utilisateur
Subprog GEN_FLDSYS(LSYM,LDES,LASW,LCHA,LHIS,LDIM,LDEF)
Value    Char    LSYM
Value    Char    LDES
Value    Integer LASW
Value    Integer LCHA
Value    Integer LHIS
Value    Integer LDIM
Value    Char    LDEF
#
Read [CQU]CQU0=LSYM
Case fstat
  When 0 :
    # FQ 53410 QSTDES,QSTSHO remplacés par les liens
    If dim([F:CQU]QSTDES)>0 [F:CQU]QSTDES    = LDES Endif
    If [F:CQU]QSTNUM <> "DYNAMT"
      If dim([F:CQU]QSTSHO)>0 [F:CQU]QSTSHO  = LDES Endif
    Endif
    [F:CQU]ASWTYP    = LASW
    [F:CQU]ASWCHA    = LCHA
    [F:CQU]QSTDIM    = LDIM
    If LDEF <> "" | LSYM = "UPDLEV"
      [F:CQU]QSTORI    = 2
    Else
      [F:CQU]QSTORI    = 3
    Endif
    # Issue 82989 GA 07/2012 Désignation du symbole à partir de la V6
    Call MAJTEXTRA (LDES,"CFGQST","QSTAXX",[F:CQU]QSTNUM,"") From ATEXTRA
    [F:CQU]UPDDAT    = date$
    [F:CQU]UPDUSR    = GUSER
    Rewrite [CQU]
    If fstat
      GOK = 0
      Call FSTA("CQU") From GLOCK
    Endif
  When 4,5 :
    Raz [F:CQU]
    [F:CQU]QSTNUM    = LSYM
    # FQ 53410 QSTDES,QSTSHO remplacés par les liens
    If dim([F:CQU]QSTDES)>0 [F:CQU]QSTDES    = LDES Endif
    If dim([F:CQU]QSTSHO)>0 [F:CQU]QSTSHO    = LDES Endif
    [F:CQU]QSTLEN    = 99 - len(LSYM)
    [F:CQU]QSTTYP    = 2
    [F:CQU]QSTDIM    = LDIM
    [F:CQU]ASWTYP    = LASW
    [F:CQU]ASWCHA    = LCHA
    [F:CQU]CTLTYP    = 1
    [F:CQU]CTLBLO    = 1
    [F:CQU]HISFLG    = LHIS
    [F:CQU]SEAFLG    = 1
    [F:CQU]QUOFLG    = 1
    [F:CQU]ORDFLG    = 1
    If LDEF <> "" | LSYM = "UPDLEV"
      [F:CQU]QSTORI    = 2
      Case LASW
        When 1 : [F:CQU]ALPDEFVAL = LDEF
        When 2 : [F:CQU]NUMDEFVAL = val(LDEF)
        When 3 :
        When 4 : [F:CQU]NUMDEFVAL = val(LDEF)
        When 5 : [F:CQU]ALPDEFVAL = LDEF
      Endcase
    Else
      [F:CQU]QSTORI    = 3
    Endif
    [F:CQU]CREDAT    = date$
    [F:CQU]CREUSR    = GUSER
    Write [CQU]
    If fstat
      GOK = 0
      Call FSTA("CQU") From GLOCK
    Endif
  When Default :
    GOK = 0
    Call FSTA("CQU") From GLOCK
Endcase
End

############################################################
# Effacement fenetre generee
# LAPP = Dossier
# LMSK = Nom ecran
# LSTO = Classe pour stockage ancien numeros de ligne ou rien
# LBLO = Numero des blocs "1" et "2" de saisie (Si LSTO<>"")
############################################################
Subprog DEL_WIN(LAPP,LMSK,LSTO,LBLO)
Value    Char    LAPP
Value    Char    LMSK
Value    Char    LSTO
Value    Char    LBLO
#
Local    Integer W_STAT
Local    Char    W_SUF(4)
Local    Integer W_LAN
Local    Char    W_GLANGUE(3)
Local    Char    W_FICANU(GDIMFIC)
Local    Char    W_TRTANU(GDIMFIC)
Local    Char    W_INT(20)
Local    Integer W_I
Local    Integer WADS1 : WADS1=0
#
# FQ 53854 GA 17/03/2009 pour ne pas ouvrir les tables
#Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_PREFIXES From CFGLIB
#
If LAPP=nomap | LAPP=""
  Local File AMSK               [AMK2]
  Local File AMSKZON            [AMZ2]
  Local File AMSKACT            [AMA2]
  Local File AMSKPAR            [AMP2]
  Local File AWINBOUT           [AWT2]
  Local File AWINBRO            [AWB2]
# FQ 55611 GA 09/2009 sinon pb dans DELWIN From MSKDIV
  If clalev([F:AWI]) Close Local File [AWI] Endif
  If clalev([F:AWP]) Close Local File [AWP] Endif
  If clalev([F:AWB]) Close Local File [AWB] Endif
  If clalev([F:AWT]) Close Local File [AWT] Endif
  Local File AWINDOW            [AWI]
  Local File AWINPAR            [AWP]
  Local File AWINBRO            [AWB]
  Local File AWINBOUT           [AWT]
Else
  Local File =LAPP+".AMSK"      [AMK2]
  Local File =LAPP+".AMSKZON"   [AMZ2]
  Local File =LAPP+".AMSKACT"   [AMA2]
  Local File =LAPP+".AMSKPAR"   [AMP2]
  Local File =LAPP+".AWINBOUT"  [AWT2]
  Local File =LAPP+".AWINBRO"   [AWB2]
# FQ 55611 GA 09/2009 sinon pb dans DELWIN From MSKDIV
  If clalev([F:AWI]) Close Local File [AWI] Endif
  If clalev([F:AWP]) Close Local File [AWP] Endif
  If clalev([F:AWB]) Close Local File [AWB] Endif
  If clalev([F:AWT]) Close Local File [AWT] Endif
  Local File =LAPP+".AWINDOW"   [AWI]
  Local File =LAPP+".AWINPAR"   [AWP]
  Local File =LAPP+".AWINBRO"   [AWB]
  Local File =LAPP+".AWINBOUT"  [AWT]
Endif
Local File ADOSSIER             [ADS1]
############################################################
Local Char WDOSSIER(GLONADS)
Local Integer WPOS : WPOS=instr(1,LAPP,"@")
If WPOS
 # si dossier distant, on n'a pas la ligne dans [ADS1]
   WDOSSIER=right$(LAPP,WPOS+1)
   Raz [F:ADS1]    # FQ 55611
Else
   WDOSSIER=LAPP
   # Lecture parametres dossier
   Read [ADS1]DOSSIER=WDOSSIER
   If fstat
     Call FSTA("ADS1") From GLOCK
     GOK = 0
     Goto DEL_WIN_FIN
   Endif
Endif

# memorisation des anciens numeros de bloc et ligne
If LSTO <> ""
  If dim([F:AMK2]INTBLOC) > 0
    Read [AMK2]CODMSK=LMSK
    If fstat = 0
      For W_I = 0 To dim([F:AMK2]INTBLOC)-1
        If [F:AMK2]INTBLOC(W_I) <> ""
          W_INT = evalue([F:AMK2]INTBLOC(W_I))
          Assign LSTO+"INTBLOC(W_I)" With W_INT
        Endif
      Next W_I
    Endif
  Endif
  W_I = 0
  Filter [AMZ2] Where CODMSK = LMSK  &
&                     left$([F:AMZ2]CODZON,2) = W_PRQ
&               Order By Key CODZON
  For [AMZ2]
    Assign LSTO+"QSTNUM(W_I)" With mid$([F:AMZ2]CODZON,3,GLONCQU)
    Case [F:AMZ2]NUMBLOC
      When val(mid$(LBLO,1,1)) :
        Assign LSTO+"BLONBR(W_I)" With 1
      When val(mid$(LBLO,2,1)) :
        Assign LSTO+"BLONBR(W_I)" With 2
      When val(mid$(LBLO,3,1)) :
        Assign LSTO+"BLONBR(W_I)" With 3
    Endcase
    Assign LSTO+"LINNBR(W_I)" With [F:AMZ2]NOZONE
    W_I += 1
    Assign LSTO+"NBLIG"       With W_I
  Next
  Filter [AMZ2]
Endif
If [F:ADS1]DOSSIER=LAPP  # on ne peut pas supprimer sur un dossier distant
   Call DELWIN(LMSK,LAPP) From MSKDIV
   Call DELMSK(LMSK,LAPP) From MSKDIV
Endif
adxmbm = adxmbm
#
$DEL_WIN_FIN
Close Local File [ADS1]
Close Local File [AMK2],[AMZ2], [AMA2] , [AMP2] , [AWT2] , [AWB2]
# FQ 55611 GA 09/2009 sinon pb dans DELWIN From MSKDIV
Close Local File [AWI],[AWB],[AWP],[AWT]
End

############################################################
# Creation ecran et fenetre sous scenarios par copie
############################################################
Subprog COP_CFGWIN(LDOSORG,LDOSDES,LNOMORG,LNOMDES,LABRDES)
Value    Char    LDOSORG
Value    Char    LDOSDES # FQ 49403 pour copier d'un dossier à un autre
Value    Char    LNOMORG
Value    Char    LNOMDES
Value    Char    LABRDES
# Value    Char    LWEB # FQ 49403 non utilisé

Local    Integer W_O, WADS1 : WADS1=0
#
# FQ 55611 ne rien faire si même dossier, même écran ... (ne pas supprimer)
If LDOSORG=LDOSDES & LNOMORG=LNOMDES End Endif

If clalev([F:ADS1])= 0 :  Local File ADOSSIER [ADS1] : WADS1=1  : Endif

# Effacement écran et fenêtre à regénérer
Call DEL_WIN(LDOSDES,LNOMDES,"","")  # From CFGLIBA
If GOK <> 1
  Goto COP_CFGWIN_FIN
Endif

############################################################
Local Char WDOSSIER(GLONADS)
Local Integer WPOS : WPOS=instr(1,LDOSDES,"@")
If WPOS
 # si dossier distant, on n'a pas la ligne dans [ADS1]
   WDOSSIER=right$(LDOSDES,WPOS+1)
   Raz [F:ADS1]    # FQ 55611
Else
   WDOSSIER=LDOSDES
   # Lecture parametres dossier
   Read [ADS1]DOSSIER=WDOSSIER
   If fstat
     Call FSTA("ADS1") From GLOCK
     GOK = 0
     Goto COP_CFGWIN_FIN
   Endif
Endif

# ----------------------------
# Copie et Validation ecran
# ----------------------------
Call COPY_AMK(LDOSORG,LDOSDES,LNOMORG,LNOMDES,LABRDES,W_O) From CFGLIBA
If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif
If [F:ADS1]DOSSIER=LDOSDES   # on ne peut pas valider si dossier distant
  # FQ 55611 & 57130 GA 09/2009 pb dans VALMSKLEC
  # Call VALID(LNOMDES,LDOSDES,[F:ADS1]NBRLAN,[F:ADS1]LAN,1,W_O) From VALMSK
  # If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif
Endif

# ----------------------------
# Copie et Validation fenetre
# ----------------------------
Call COPY_AWI(LDOSORG,LDOSDES,LNOMORG,LNOMDES,W_O) From CFGLIBA
If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif
If [F:ADS1]DOSSIER=LDOSDES   # on ne peut pas valider si dossier distant
  # FQ 55611 & 57130 GA 09/2009 pb dans VALMSKLEC
  # Call VALID(LNOMDES,LDOSDES,1,W_O) From VALWIN
  # If W_O<>1 | GOK<>1 : GOK = 0 : Goto COP_CFGWIN_FIN : Endif
Endif
adxmbm      = adxmbm
$COP_CFGWIN_FIN
If WADS1=1 Close Local File [ADS1] Endif
End


######################################################
# Subprog COPY_AMK           (selon TRTCOP de SUBAMK)
# copie d'un masque écran dans les cas suivants:
# - pour duplication / renommé
# - d'un dossier à un autre
# Paramètres:
# - LDOSORG Dossier origine
# - LDOSDES Dossier destination
# - LAMKORG Ecran   origine
# - LAMKDES Ecran   destination
# - LABRDES Abréviation écran   destination
# - LOK     Code retour 1=Ok
# Cas d'utilisation:
# - copie des paramétrages CFG d'un dossier à un autre
######################################################
Subprog COPY_AMK(LDOSORG,LDOSDES,LAMKORG,LAMKDES,LABRDES,LOK)
Value    Char    LDOSORG
Value    Char    LDOSDES
Value    Char    LAMKORG
Value    Char    LAMKDES
Value    Char    LABRDES
Variable Integer LOK

LOK=1
If LDOSORG=nomap | LDOSORG=""
 Local File AMSK    [AMK1]
 Local File AMSKZON [AMZ1]
 Local File AMSKACT [AMA1]
 Local File AMSKPAR [AMP1]
 Local File ATEXTE  [ATX1]
#CHECK IGNORE_BEGIN
 If GVERSION>="1.7.0"   # Issue 83581
   Local File AMOTCLE [AMC1]
 Endif
#CHECK IGNORE_END
Else
 Local File =LDOSORG+".AMSK"    [AMK1]
 Local File =LDOSORG+".AMSKZON" [AMZ1]
 Local File =LDOSORG+".AMSKACT" [AMA1]
 Local File =LDOSORG+".AMSKPAR" [AMP1]
 Local File =LDOSORG+".ATEXTE"  [ATX1]
#CHECK IGNORE_BEGIN
 If GVERSION>="1.7.0"   # Issue 83581
   Local File =LDOSORG+".AMOTCLE" [AMC1]
 Endif
#CHECK IGNORE_END
Endif
If LDOSDES=nomap  | LDOSDES=""
 Local File AMSK    [AMK2]
 Local File AMSKZON [AMZ2]
 Local File AMSKACT [AMA2]
 Local File AMSKPAR [AMP2]
 Local File ATEXTE  [ATX2]
#CHECK IGNORE_BEGIN
 If GVERSION>="1.7.0"   # Issue 83581
   Local File AMOTCLE [AMC2]
 Endif
#CHECK IGNORE_END
Else
 Local File =LDOSDES+".AMSK"    [AMK2]
 Local File =LDOSDES+".AMSKZON" [AMZ2]
 Local File =LDOSDES+".AMSKACT" [AMA2]
 Local File =LDOSDES+".AMSKPAR" [AMP2]
 Local File =LDOSDES+".ATEXTE"  [ATX2]
#CHECK IGNORE_BEGIN
 If GVERSION>="1.7.0"   # Issue 83581
   Local File =LDOSDES+".AMOTCLE" [AMC2]
 Endif
#CHECK IGNORE_END
Endif
OK = 1
If GTRACE=""
 Read [AMK2]CODMSK = LAMKDES
 If !fstat
  OK=1 : Call AVERTIR(LDOSDES-LAMKDES-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP_AMK
Endif
Close Local File [AMK1], [AMZ1], [AMA1], [AMP1], [ATX1]
&              , [AMK2], [AMZ2], [AMA2], [AMP2], [ATX2]
End

$TR_COP_AMK
GOK = 1

Local Integer WUPDTRBEGIN : Raz WUPDTRBEGIN

# Si pas de transaction en cours
 If adxlog<>1
   GOK=1
   Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] , [ATX2]
   WUPDTRBEGIN=1
 Endif

 Delete [AMK2] Where CODMSK=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSK" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMK2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 If dim(WNBZ)>0
  WNBZ = 0
  For [AMZ2] Where CODMSK=LAMKDES
   WNBZ += 1
   WZON(WNBZ) = [F:AMZ2]CODZON
#CHECK IGNORE_BEGIN
   If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
      Read  [F:AMC2]AMC0=2;[F:AMZ2]CODMSK;[F:AMZ2]CODZON
      If !fstat WMOT(WNBZ) = [F:AMC2]MOTCLE Endif
   Else
      WMOT(WNBZ) = [F:AMZ2]MOTCLE
   Endif
#CHECK IGNORE_END
  Next AMZ2
 Endif
 Delete [AMZ2] Where CODMSK=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKZON" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMZ2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 Delete [AMA2] Where TYPAFF=1 & CODAFF=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKACT" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMA2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 Delete [AMP2] Where TYPAFF=1 & CODAFF=LAMKDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AMSKPAR" : Goto ROLL_TR_COP_AMK
 Elsif fstat>5
  GOK = 0 : Call RSTA("AMP2","") From GLOCK : Goto AB_TR_COP_AMK
 Endif
 For [AMK1]CODMSK Where CODMSK=LAMKORG
  [F:AMK2] = [F:AMK1]
  If LAMKORG<>LAMKDES & LAMKDES<>""
     [F:AMK2]CODMSK = LAMKDES
  Endif
  If [F:AMK1]ABRMSK<>LABRDES & LABRDES<>""
     [F:AMK2]ABRMSK = LABRDES
  Endif
  Call COPTEXTE([F:AMK1]INTMSK,[F:AMK2]INTMSK) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AMK1]NBBLOC-1
   Call COPTEXTE([F:AMK1]TITBLOC(I),[F:AMK2]TITBLOC(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AMK2]UPDUSR)>0 : [F:AMK2]UPDUSR = GUSER : Endif
  If dim([F:AMK2]UPDDAT)>0 : [F:AMK2]UPDDAT = date$ : Endif
  If dim([F:AMK2]UPDTIM)>0 : [F:AMK2]UPDTIM = time  : Endif
  Write [AMK2]
  If fstat
   GOK=0 : Call FSTA("AMK2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AMK
 Elsif !GOK : Goto AB_TR_COP_AMK
 Endif
 For [AMZ1]CODE Where CODMSK=LAMKORG
  [F:AMZ2] = [F:AMZ1]
  If LAMKORG<>LAMKDES [F:AMZ2]CODMSK=LAMKDES Endif
  Call COPTEXTE([F:AMZ1]INTIT,[F:AMZ2]INTIT) From OBJDIV
  If dim([F:AMZ1]INFBUL)>0 & dim([F:AMZ2]INFBUL)>0
   Call COPTEXTE([F:AMZ1]INFBUL,[F:AMZ2]INFBUL) From OBJDIV
   If GOK<1 : Break : Endif
  Endif
  If dim(WNBZ)>0
   I = find([F:AMZ1]CODZON,WZON(1..WNBZ))
   If I
#CHECK IGNORE_BEGIN
     If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
        [F:AMC2]TYPZON   = 2
        [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
        [F:AMC2]IDENT2   = [F:AMZ2]CODZON
        [F:AMC2]MOTCLE   =  WMOT(I)
     Else
        [F:AMZ2]MOTCLE = WMOT(I)
     Endif
#CHECK IGNORE_END
   Endif
  Endif
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
  If GVERSION>="1.7.0" & [F:AMC2]MOTCLE<>""  # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
      Write [AMC2]
      If fstat ### Pas d'erreur si mot clé d'aide existant
      Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AMK
 Elsif !GOK : Goto AB_TR_COP_AMK
 Endif
 For [AMA1]TYPAFF Where TYPAFF=1 & CODAFF=LAMKORG
  [F:AMA2] = [F:AMA1]
  If LAMKORG<>LAMKDES [F:AMA2]CODAFF=LAMKDES Endif
  If dim([F:AMA2]INTITACT)>0
   Call COPTEXTE([F:AMA1]INTITACT,[F:AMA2]INTITACT) From OBJDIV
  Endif
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP_AMK : Endif
 For [AMP1]CODPAR Where TYPAFF=1 & CODAFF=LAMKORG
  [F:AMP2] = [F:AMP1]
  If LAMKORG<>LAMKDES [F:AMP2]CODAFF=LAMKDES Endif
  Write [AMP2]
  If fstat
   GOK=0 : Call FSTA("AMP2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP_AMK : Endif
 # un petit message de trace
 Local Char W_MSG (250)
 W_MSG = mess(129,123,1)-LAMKORG
 Call ECR_TRACE(W_MSG,0) From GESECRAN

# Si on a ouvert une transaction
 If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
 Endif
Return

$AB_TR_COP_AMK
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

$ROLL_TR_COP_AMK
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP_AMK : Endif
Return

######################################################
# Subprog COPY_AWI           (selon TRTCOP de SUBAWI)
# copie d'une fenêtre dans les cas suivants:
# - pour duplication / renommé
# - d'un dossier à un autre
# Paramètres:
# - LDOSORG Dossier origine
# - LDOSDES Dossier destination
# - LWINORG Ecran   origine
# - LWINDES Ecran   destination
# - LOK     Code retour 1=Ok
# Cas d'utilisation:
# - copie des paramétrages CFG d'un dossier à un autre
######################################################
Subprog COPY_AWI(LDOSORG,LDOSDES,LWINORG,LWINDES,LOK)
Value    Char    LDOSORG
Value    Char    LDOSDES
Value    Char    LWINORG
Value    Char    LWINDES
Variable Integer LOK
LOK=1
If LDOSORG=nomap | LDOSORG=""
 Local File AWINDOW  [AWI1]
 Local File AWINPAR  [AWP1]
 Local File AWINBRO  [AWB1]
 Local File AWINBOUT [AWT1]
 Local File ATEXTE   [ATX1]
Else
 Local File =LDOSORG+".AWINDOW"  [AWI1]
 Local File =LDOSORG+".AWINPAR"  [AWP1]
 Local File =LDOSORG+".AWINBRO"  [AWB1]
 Local File =LDOSORG+".AWINBOUT" [AWT1]
 Local File =LDOSORG+".ATEXTE"   [ATX1]
Endif
If LDOSDES=nomap | LDOSDES=""
 Local File AWINDOW  [AWI2]
 Local File AWINPAR  [AWP2]
 Local File AWINBRO  [AWB2]
 Local File AWINBOUT [AWT2]
 Local File ATEXTE   [ATX2]
Else
 Local File =LDOSDES+".AWINDOW"  [AWI2]
 Local File =LDOSDES+".AWINPAR"  [AWP2]
 Local File =LDOSDES+".AWINBRO"  [AWB2]
 Local File =LDOSDES+".AWINBOUT" [AWT2]
 Local File =LDOSDES+".ATEXTE"   [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP_AWI
Close Local File [AWI1], [AWP1], [AWB1], [AWT1], [ATX1]
&              , [AWI2], [AWP2], [AWB2], [AWT2], [ATX2]
End

$TR_COP_AWI
GOK = 1
Local Integer WUPDTRBEGIN : Raz WUPDTRBEGIN

# Si pas de transaction en cours
 If adxlog<>1
   GOK=1
   Trbegin [AWI2] , [AWP2] , [AWB2] , [AWT2] , [ATX2]
   WUPDTRBEGIN=1
 Endif

 Delete [AWI2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINDOW" : Goto ROLL_TR_COP_AWI
 Endif
 Delete [AWP2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINPAR" : Goto ROLL_TR_COP_AWI
 Endif
 Delete [AWB2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINBRO" : Goto ROLL_TR_COP_AWI
 Endif
 Delete [AWT2] Where WIN=LWINDES
 If fstat=1
  GOK=-1 : GLOCK = "$"+LDOSDES+".AWINBOUT" : Goto ROLL_TR_COP_AWI
 Endif
 For [AWI1]AWI0 Where WIN=LWINORG
  [F:AWI2] = [F:AWI1]
  If LWINORG<>LWINDES [F:AWI2]WIN=LWINDES Endif
  # configurateur : le nom de fenêtre est aussi le nom du masque
  If [F:AWI1]NOMMSK(0) = LWINORG [F:AWI2]NOMMSK(0) = LWINDES Endif
  Call COPTEXTE([F:AWI1]DES,[F:AWI2]DES) From OBJDIV
  If GOK<1 : Break : Endif
  For I=0 To [F:AWI1]NBMSK-1
   Call COPTEXTE([F:AWI1]INTMSK(I),[F:AWI2]INTMSK(I)) From OBJDIV
   If GOK<1 : Break 2 : Endif
  Next I
  If dim([F:AWI2]UPDUSR)>0 : [F:AWI2]UPDUSR = GUSER : Endif
  If dim([F:AWI2]UPDDAT)>0 : [F:AWI2]UPDDAT = date$ : Endif
  If dim([F:AWI2]UPDTIM)>0 : [F:AWI2]UPDTIM = time  : Endif
  Write [AWI2]
  If fstat
   GOK=0 : Call FSTA("AWI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AWI
 Elsif !GOK : Goto AB_TR_COP_AWI
 Endif
 For [AWP1]AWP0 Where WIN=LWINORG
  [F:AWP2] = [F:AWP1]
  If LWINORG<>LWINDES [F:AWP2]WIN=LWINDES Endif
  Write [AWP2]
  If fstat
   GOK = 0 : Call FSTA("AWP2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AWI
 Elsif !GOK : Goto AB_TR_COP_AWI
 Endif
 Read [AWB1]AWB0 = LWINORG
 If !fstat
  [F:AWB2] = [F:AWB1]
  If LWINORG<>LWINDES [F:AWB2]WIN=LWINDES Endif
  For I=0 To [F:AWB1]NBLIS-1
   Call COPTEXTE([F:AWB1]INTLIS(I),[F:AWB2]INTLIS(I)) From OBJDIV
   If GOK<1 : Break : Endif
  Next I
  Write [AWB2]
  If fstat
   GOK = 0 : Call FSTA("AWB2") From GLOCK
  Endif
 Endif
 For [AWT1]AWT0 Where WIN=LWINORG
  [F:AWT2] = [F:AWT1]
  If LWINORG<>LWINDES [F:AWT2]WIN=LWINDES Endif
  Call COPTEXTE([F:AWT1]TXTBOUT,[F:AWT2]TXTBOUT) From OBJDIV
  If GOK<1 : Break : Endif
  Write [AWT2]
  If fstat
   GOK = 0 : Call FSTA("AWT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP_AWI
 Elsif !GOK : Goto AB_TR_COP_AWI
 Endif
 # un petit message de trace
 Local Char W_MSG (250)
 W_MSG = mess(91,123,1)-mess(14,126,1)-LWINORG
 Call ECR_TRACE(W_MSG,0) From GESECRAN
# Si on a ouvert une transaction
 If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
 Endif
Return

$AB_TR_COP_AWI
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

$ROLL_TR_COP_AWI
# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP_AWI : Endif
Return

