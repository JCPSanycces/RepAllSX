Wrseq "Subprog ASS_SYMBOLE(LMSK,LVAR)"
Wrseq "Value   Char LMSK"
Wrseq "Value   Char LVAR"
Wrseq "#"
Wrseq "Local   Char WTXT(250)"
Wrseq "#"
Wrseq 'If evalue("dim("+LMSK+W_PRQ+mid$(LVAR,3,GLONCQU)+")>0") & evalue("dim("+LVAR+")>0")'
# FQ 52104 GA 02/2009 a faire avant les affectations du For
Wrseq '  If evalue("type("+LVAR+")")=4'
Wrseq "    Assign LMSK+W_PRQ+mid$(LVAR,3,GLONCQU) With evalue(LVAR)+1"
Wrseq '  Else'
Wrseq "    Assign LMSK+W_PRQ+mid$(LVAR,3,GLONCQU) With evalue(LVAR)"
Wrseq "  Endif"
For W_J = 0 To W_I-1
  If W_QSP(W_J) = 1 & W_QST(W_J) = 5
    Wrseq '  If LVAR = "';W_PRS;W_QSN(W_J);'"'
    Wrseq '    WTXT = evalue(LVAR)'
    # FQ 52104 GA 02/2009 Affichage du texte rtf
    Wrseq '    #Call EFF_CRLF(WTXT) From CFGLIBD'
    Wrseq '    Call CLB_TO_CHAR(WTXT,LVAR) From CFGLIBD'
    Wrseq "    Assign LMSK+W_PRQ+mid$(LVAR,3,GLONCQU) With WTXT"
    Wrseq '  Endif'
  Endif
Next W_J

Wrseq "Endif"
Wrseq "End"
#
Wrseq "############################################################"
Wrseq "# Routine to generate filter on response table (symbol level)"
Wrseq "$SET_FILTCT"
# JPJ E19190 ->
Wrseq "# JPJ E19190 ->"
Wrseq "Local Char WQFO(03)"
Wrseq "Case LQST"
For W_J = 0 To W_I -1
  If W_QCT(W_J) = 2 & W_QTC(W_J) <> "" & W_QFO(W_J) <> ""
    W_STR = '"'+W_QFO(W_J)+'"'
    Wrseq '  When "';W_QSN(W_J);'" : WQFO=';W_STR
  Endif
Next W_J
Wrseq "  When default :"
Wrseq "    Goto SET_FILTCT_FIN"
Wrseq "Endcase"
Wrseq 'If clalev([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif'
Wrseq 'Read [TFO]TFO0=7;WQFO'
Wrseq "If fstat = 0"
Wrseq '   If LFIL <> ""'
Wrseq '      LFIL += "&"'
Wrseq "   Endif"
Wrseq "   LFIL += [F:TFO]FORFOR"
Wrseq "Endif"
Wrseq "$SET_FILTCT_FIN"
Wrseq "# JPJ E19190 <-"
# JPJ E19190 <-
Wrseq "Return"
Wrseq "############################################################"
Wrseq "# Routine to generate filter on form / models"
Wrseq "$SET_FILSHA"
Wrseq "Case LSHA"
For W_J = 0 To W_I-1
  If W_QCT(W_J) = 4 & W_QFO(W_J) <> ""
    W_STR = '"'+W_QSN(W_J)+'"'
    Wrseq "  When ";W_STR;" : "
    Wrseq '    If clalev([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif'
    Wrseq '    Read [TFO]TFO0=7;"';W_QFO(W_J);'"'
    Wrseq "    If fstat = 0"
    Wrseq '      If LFIL <> ""'
    Wrseq '        LFIL += "&"'
    Wrseq "      Endif"
    Wrseq "      LFIL += [F:TFO]FORFOR"
    Wrseq "    Endif"
  Endif
Next W_J
Wrseq "Endcase"
Wrseq "Return"
