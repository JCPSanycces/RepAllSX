Wrseq "$KIL_SYMTXT"
Wrseq "Gosub EXT_FIC"
Wrseq 'Gosub KIL_SYMTXT From ='+CH_DOSSIER+'"WUVAR1"+W_EXTFIC'
Wrseq "Return"
#
Wrseq "############################################################"
Wrseq "$SET_SYMBOLE"
Wrseq 'Case evalue("type("+W_VAR+")")'
Wrseq "  When 1, 2, 4, 5, 6, 7, 9 :"
Wrseq "    Assign W_VAR with W_NUM"
Wrseq "  When 3 :"
Wrseq "    Assign W_VAR with W_DAT"
# FQ 50451 GA 11/2008 ajout Blob & Clob
Wrseq "  When 522 :"
Wrseq "    Assign W_VAR With W_BLB"
Wrseq "  When 523 :"
Wrseq "    Assign W_VAR With W_CLB"
Wrseq "  When Default :"
Wrseq "    Assign W_VAR with W_ALP"
Wrseq "Endcase"
Wrseq "Return"
#
Wrseq "############################################################"
Wrseq "$SAVE_SYMBOLE"
Wrseq 'Assign W_PRW+mid$(W_VAR,3,GLONCQU) With evalue(W_VAR)'
Wrseq 'If evalue("dim("+W_PRL+mid$(W_VAR,3,GLONCQU)+")>0")'
Wrseq '  Assign W_PRY+mid$(W_VAR,3,GLONCQU) With evalue(W_PRL+mid$(W_VAR,3,GLONCQU))'
Wrseq 'Endif'
Wrseq "Return"
#
Wrseq "############################################################"
Wrseq "$REST_SYMBOLE"
Wrseq 'Assign W_VAR With evalue(W_PRW+mid$(W_VAR,3,GLONCQU))'
Wrseq 'If evalue("dim("+W_PRY+mid$(W_VAR,3,GLONCQU)+")>0")'
Wrseq '  Assign W_PRL+mid$(W_VAR,3,GLONCQU) With evalue(W_PRY+mid$(W_VAR,3,GLONCQU))'
Wrseq 'Endif'
Wrseq "Return"
Wrseq "############################################################"
Wrseq "# Routine to check link validity with other tables before creating data"
Wrseq "Subprog CTRFLD(LFIC,LZON,LRET)"
Wrseq "Value    Char    LFIC"
Wrseq "Value    Char    LZON"
Wrseq "Variable Integer LRET"
Wrseq "#"
Wrseq "Raz LRET, fstat"
Wrseq "Case LFIC"
For W_J = 0 To dim(W_FIN)-1
  Read [ATB]CODFIC = W_FIN(W_J)
  Wrseq '  When  "';W_FIN(W_J);'" : '
  Wrseq "    Case LZON"
  Filter [ATZ] Where CODFIC = W_FIN(W_J) & LIEN <> ""
&              Order By Key  CODZONE
  For [ATZ]
    If [F:ATZ]LIEN <> "ITMMASTER"
      Read [ATB]CODFIC=[F:ATZ]LIEN
      Read [ATI]NUMLIG(2)=[F:ATZ]LIEN;1
      W_STR = '"'+[F:ATZ]CODZONE+'"          '
      If [F:ATZ]EXPLIEN <> ""
        W_LNK = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
        # Issue 83483 GA 07/2012 enlever la fin du lien
        If pat(W_LNK,"*;[V]GSUPCLE") & len(W_LNK)>11
              W_LNK=left$(W_LNK,len(W_LNK)-11)
        Endif
      Else
        W_LNK = W_FIA(W_J)+[F:ATZ]CODZONE
      Endif
      Call MAJ_LNK(W_FIN(W_J),W_FIA(W_J),W_LNK)
      # Issue 67114 GA 08/2013
      If ([F:ATZ]DIME>1 | [F:ATZ]CODACT<>"") & pat(W_LNK,"*(indice)*")
         W_STRIND="(indice)"
      Else
         W_STRIND=""
      Endif
      # FQ 75693 GA 08/2011 tenir compte des liens facultatifs
      If [F:ATZ]OBLIG=2
        Wrseq '      When ';W_STR;' : Look [LOO]';[F:ATI]CODIND;'=';W_LNK
      Else
      # FQ 76842 GA 09/2011 attention au type de données du champ
      #  Wrseq '      When ';W_STR;' : If '+W_FIA(W_J)+[F:ATZ]CODZONE+'<>""'
        Local Shortint WTYPE : WTYPE = evalue("type("+W_FIA(W_J)+[F:ATZ]CODZONE+")")
        Case WTYPE
          When 1, 2, 4, 5, 6, 7, 9 :
            Wrseq '      When ';W_STR;' : If '+W_FIA(W_J)+[F:ATZ]CODZONE+W_STRIND+'<>0'
          When 3 :
            Wrseq '      When ';W_STR;' : If '+W_FIA(W_J)+[F:ATZ]CODZONE+W_STRIND+'<>[0/0/0]'
          When Default :
            If WTYPE<522 # Issue 93006 GA 11/2013
               Wrseq '      When ';W_STR;' : If '+W_FIA(W_J)+[F:ATZ]CODZONE+W_STRIND+'<>""'
            Endif
        Endcase
        If WTYPE<522 # Issue 93006 GA 11/2013
          Wrseq '                            Look [LOO]';[F:ATI]CODIND;'=';W_LNK
          Wrseq '                            Endif'
        Endif
      Endif
    Endif
  Next
  Filter [ATZ]
  Wrseq '      When default : '
  Wrseq '    Endcase'
Next W_J
Wrseq "  When default :"
Wrseq "Endcase"
Wrseq "LRET = fstat"
Wrseq "End"
Wrseq "#"
#
Wrseq "############################################################"
Wrseq "# Routine to check link validity with other tables when creating data"
Wrseq "Subprog CTRFLD1(LFIC,LZON,LRET)"
Wrseq "Value    Char    LFIC"
Wrseq "Value    Char    LZON"
Wrseq "Variable Integer LRET"
Wrseq "#"
Wrseq "Raz LRET, fstat"
Wrseq "Case LFIC"
For W_J = 0 To dim(W_FIN)-1
  Read [ATB]CODFIC = W_FIN(W_J)
  Wrseq '  When  "';W_FIN(W_J);'" : '
  Wrseq "    Case LZON"
  Filter [ATZ] Where CODFIC = W_FIN(W_J) & LIEN <> ""
&              Order By Key  CODZONE
  For [ATZ]
    If [F:ATZ]LIEN = "ITMMASTER"
     If !(W_FIN(W_J) = "ITMMASTER" & [F:ATZ]CODZONE = "ITMREF")     # JPJ E25591    pas de ctl sur clé table article
      Read [ATB]CODFIC=[F:ATZ]LIEN
      Read [ATI]NUMLIG(2)=[F:ATZ]LIEN;1
      W_STR = '"'+[F:ATZ]CODZONE+'"          '
      If [F:ATZ]EXPLIEN <> ""
        W_LNK = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
      Else
        W_LNK = W_FIA(W_J)+[F:ATZ]CODZONE
      Endif
      Call MAJ_LNK(W_FIN(W_J),W_FIA(W_J),W_LNK)
      Wrseq '      When ';W_STR;' : Look [LOO]';[F:ATI]CODIND;'=';W_LNK
     Endif     # JPJ E25591 <
    Endif
  Next
  Filter [ATZ]
  Wrseq '      When default : '
  Wrseq '    Endcase'
Next W_J
Wrseq "  When default :"
Wrseq "Endcase"
Wrseq "LRET = fstat"
Wrseq "End"
Wrseq "#"
#
Wrseq "############################################################"
Wrseq "# Routine to check ITMFACILITY fields"
Wrseq "Subprog CHKITF"
Wrseq "Local integer W_RET"
Wrseq '#'
Filter [ATZ] Where CODFIC =  "ITMFACILIT" &
&                  LIEN   <> ""
&            Order By Key  CODZONE
For [ATZ]
  If !find([F:ATZ]CODZONE,"ITMREF","CFGVCRNUM")
    Read [ATB]CODFIC=[F:ATZ]LIEN
    Read [ATI]NUMLIG(2)=[F:ATZ]LIEN;1
    W_STR = [F:ATZ]CODZONE+'            '
    If evalue("dim([F:ITF]"+[F:ATZ]CODZONE+")>0")
      If [F:ATZ]OBLIG = 2
        Wrseq 'Local File ';[F:ATZ]LIEN;' [LOO]'
        Wrseq 'Call CTRFLD("ITMFACILIT","';[F:ATZ]CODZONE;'",W_RET)'
        Wrseq 'If W_RET <> 0 : Raz [F:ITF]';W_STR;' : Endif'
        Wrseq 'Close Local file [LOO]'
        Wrseq '#'
      Else
        # Issue 93006 GA 11/2013 Case evalue("type([F:ITF]"+[F:ATZ]CODZONE+")")
        Local Shortint WTYPE : WTYPE = evalue("type([F:ITF]"+[F:ATZ]CODZONE+")")
        Case WTYPE
          When 1, 2, 4, 5, 6, 7, 9 :
            Wrseq 'If [F:ITF]';W_STR;' <> 0'
          When 3 :
            Wrseq 'If [F:ITF]';W_STR;' <> [0/0/0]'
          When Default :
            If WTYPE>=10 & WTYPE<522 # Issue 93006 GA 11/2013
               Wrseq 'If [F:ITF]';W_STR;' <> ""'
            Endif
        Endcase
        Wrseq '  Local File ';[F:ATZ]LIEN;' [LOO]'
        Wrseq '  Call CTRFLD("ITMFACILIT","';[F:ATZ]CODZONE;'",W_RET)'
        Wrseq '  If W_RET <> 0 : Raz [F:ITF]';W_STR;' : Endif'
        Wrseq '  Close Local file [LOO]'
        Wrseq 'Endif'
        Wrseq '#'
      Endif
    Endif
  Endif
Next
Filter [ATZ]
Wrseq "End"
Wrseq "#"

# Issue 93006 GA 11/2013
Gosub GENCHKITM

Wrseq "############################################################"
