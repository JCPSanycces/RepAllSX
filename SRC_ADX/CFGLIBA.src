#<AdxTL>@(#)5.0.0.0 $Revision$
# Version Beryl
############################################################
# Sous programmes de generation du configurateur
# GEN_WUVAR      : Generation du code de traitement des variables
# DEL_WIN        : Effacement ecran + fenêtre configurateur
# COP_WIN        : Copie ecran + fenêtre sous-scénario configurateur
# GEN_SEL        : Generation ecran de selection
# GEN_LIN        : Generation ecran saisie ligne de produit
# GEN_MSK        : Validation ecran
# GEN_FEN        : Generation/Validation fenetre
#
# COP_CFGWIN     : Copie ecran + fenêtre configurateur (vers un autre dossier)
# COP_AMK        : Copie ecran   (vers un autre dossier ou duplication)
# COP_AWI        : Copie fenêtre (vers un autre dossier ou duplication)
############################################################
# Issue 82300 CQU 8c => 10c mid$(W_VAR,3,8) devient mid$(W_VAR,3,GLONCQU)
############################################################
# Contrôle symboles reserves
Subprog CTR_SYMRES(LSYM)
Value Char     LSYM
#
Local Char T_SYM(GLONAVA)(50)  # Issue 82989 suite GA 11/2012 avant (10)
T_SYM(00) = "CFGCFG"
T_SYM(01) = "AUTCFG"
T_SYM(02) = "UPDMOD"
T_SYM(03) = "PHASE"
T_SYM(04) = "SEQ"
T_SYM(05) = "LIN"
T_SYM(06) = "SELINP"
T_SYM(07) = "SELSCS"
T_SYM(08) = "SELCOR"
T_SYM(09) = "SALTXT"
T_SYM(10) = "ENDINP"
T_SYM(11) = "RETURN"
T_SYM(12) = "HRDCOP"
T_SYM(13) = "LEVEL"
T_SYM(14) = "ABORT"
T_SYM(15) = "SEQTEX"
T_SYM(16) = "MEMO"
T_SYM(17) = "SCDOPE"
T_SYM(18) = "SELTBL"
T_SYM(19) = "WINAUT"
T_SYM(20) = "QSTFLG"
T_SYM(21) = "DOSSIER"
T_SYM(22) = "APLLNG"
T_SYM(23) = "AUTERR"
T_SYM(24) = "SCENUM"
T_SYM(25) = "SUBSCE"
T_SYM(26) = "SCEDES"
T_SYM(27) = "CPTCFG"
T_SYM(28) = "CPTCOP"
T_SYM(29) = "MODITM"
T_SYM(30) = "NOLNK"
T_SYM(31) = "FCYITF"
T_SYM(32) = "RCMP"
# Issue 82300 GA 06/2012 6 new dedicated symbols
T_SYM(33) = "ITUITM"
T_SYM(34) = "ITUDES"
T_SYM(35) = "ITUBPR"
T_SYM(36) = "ITPITM"
T_SYM(37) = "ITPDES"
T_SYM(38) = "ITPBPR"
# Issue 82989 GA 07/2012 4 new dedicated symbols
T_SYM(39) = "BOMALT"
T_SYM(40) = "BOMALTREF"
T_SYM(41) = "ROUALT"
T_SYM(42) = "ROUALTREF"
#
If find(LSYM,T_SYM(0..dim(T_SYM)-1))
  mkstat = 2
Endif
End
############################################################
# Generation des traitements du configurateur WUVAR WUVARnn
# Le masque courant doit contenir un champs dimensionne FILTAB contenant
#    les tables a traiter
# Le masque courant doit contenir un champs dimensionne VARSUP qui contiendra
#    les variables locales
#
#
############################################################
Subprog GEN_WUVAR(LAPL,LSCE,LTAB)
Value   Char LAPL
Value   Char LSCE
Value   Char LTAB()
#
Local Char    W_FSQ (10)
#
Local File =LAPL+".CFGQST" [CQU0]
#
Local Integer W_NBLAN            : W_NBLAN=20 # Issue 105687 GA 01/2015 more than 10 languages
# Issue 95035 GA 12/2013 avant +100: cela permet à GEN_VARSYS de passer si aucune variable système n'existe dans le dossier
Local Integer W_NBV              : W_NBV = nbrecord([F:CQU0])+200
Local Integer W_LAM              : W_LAM = 1000 : # Nombre de symboles par traitement WUVAR0n
Local Integer W_STE              : W_STE =  100 : # Nombre de symboles par traitement WUVAR1n
# Noms des fichiers generes
Local Char    W_FICSRC(GDIMFIC)
# Lock fonction de generation des traitements configurateur
Lock = "WUVAR"
If fstat
  Goto GEN_WUVAR_FIN
Endif
#
Local Char    W_FIC(GLONATB) # JAMCC Issue X3-89202 05/2018
Local Char    W_ABR(10)
Local Char    W_EVA(40)
Local Char    W_FMT(20)
Local Char    W_STR(14)
Local Char    W_STRIND(20) # Issue 67114 GA 08/2013 "(indice)"
Local Char    W_MSG(100)
Local Char    W_IDX(80)
Local Char    W_INT(20)
Local Char    W_FLD(GLONAVA)
Local Char    W_REL(40)
Local Char    W_SUF(03)
Local Char    W_TYP(05)     # JPJ TEX->TXC
#
Local Integer W_KEYNBR
Local Char    W_KEYFLD(10)(08)
Local Char    W_KEYATY(03)(08)
Local Integer W_KEYTYP    (08)
#
Local Char    W_QSN(12)(W_NBV)
Local Integer W_QST    (W_NBV)
Local Char    W_QSD(70)(W_NBV)
Local Integer W_QSP    (W_NBV)
#Local Char    W_QSM(GLONDES)(W_NBV,10)      :# V6 avant W_QSM(20)(W_NBV,10) champ [F:CQU]QSTSHO
Local Char    W_QSM(GLONDES)(W_NBV,W_NBLAN)  :# Issue 105687 GA 01/2015
Local Char    W_QSC(10)(W_NBV)
Local Integer W_QDI    (W_NBV)
Local Integer W_QOR    (W_NBV)
Local Char    W_QTC(10)(W_NBV)
Local Integer W_QCT    (W_NBV)
Local Char    W_QTB(10)(W_NBV)
Local Char    W_QATB(10)(W_NBV)    # CCC (29/11/05) Bug 33447 Utilisation de l'abréviation de la table au lieu du nom de l'objet censé gérer la table
Local Char    W_QOB(03)(W_NBV)
Local Char    W_QOF(10)(W_NBV)
Local Char    W_QFO(03)(W_NBV)
Local Char    W_QIN(10)(W_NBV)
Local Char    W_QINTYP(3)(W_NBV)    # Type intitulé
Local Integer W_QEV    (W_NBV)
#
Local Integer W_LAS    (W_NBV)
Local Char    W_LAQ(12)(W_NBV)
Local Integer W_LAT    (W_NBV)
Local Integer W_LAP    (W_NBV)
#
Local Integer W_LNG
Local Integer W_DIM
Local Char    W_FIN(10)(12)
Local Char    W_FIA(10)(dim(W_FIN))
Local Char    W_LNK(120)
Local Char    W_GLANGUE(GLONLAN),WQSTDES(GLONDES) # FQ 53410

Local Integer W_I, W_J, W_K, W_L, W_M, W_N, W_O, W_P, W_Q, W_R, W_S, W_T, W_U
#
W_FIN(00) = "ITMMASTER"
W_FIN(01) = "ITMFACILIT"
W_FIN(02) = "ITMMVT"
W_FIN(03) = "ITMSALES"
W_FIN(04) = "BOM"
W_FIN(05) = "BOMD"
W_FIN(06) = "ROUTING"
W_FIN(07) = "ROUOPE"
W_FIN(08) = "ITMBPC"
W_FIN(09) = "ROUSCD"
W_FIN(10) = "ITMCOST"
W_FIN(11) = "ITMBPS"
#
Gosub CFG_CONSTANTES From CFGLIB
#
If clalev([F:ADS1])= 0 : Local File   ADOSSIER           [ADS1] : Endif
If clalev([F:ANM]) = 0 : Local File  =LAPL+".ACODNUM"    [ANM]  : Endif
If clalev([F:ATB]) = 0 : Local File  =LAPL+".ATABLE"     [ATB]  : Endif
If clalev([F:ATZ]) = 0 : Local File  =LAPL+".ATABZON"    [ATZ]  : Endif
If clalev([F:ATI]) = 0 : Local File  =LAPL+".ATABIND"    [ATI]  : Endif
If clalev([F:ATY]) = 0 : Local File  =LAPL+".ATYPE"      [ATY]  : Endif
If clalev([F:APT]) = 0 : Local File  =LAPL+".APATCH"     [APT]  : Endif
If clalev([F:ITM]) = 0 : Local File  =LAPL+".ITMMASTER"  [ITM]  : Endif
If clalev([F:ITF]) = 0 : Local File  =LAPL+".ITMFACILIT" [ITF]  : Endif
If clalev([F:CDF]) = 0 : Local File  =LAPL+".CFGDEF"     [CDF]  : Endif
If clalev([F:ACV]) = 0 : Local File  =LAPL+".ACTIV"      [ACV]  : Endif
If clalev([M:CFV1])= 0 : Local Mask  =LAPL+".CFGVAL1"    [CFV1] : Endif
#
Read [ADS1]DOSSIER=LAPL
If fstat
  Call FSTA("ADS1") From GLOCK
  Goto GEN_WUVAR_UNL
Endif
#
Filter [APT] Where TYP = "P"
&            Order By Key APT2
Read [APT] Last
If fstat = 0
  W_REL = " Last Patch :"-[F:APT]RELEASE-num$([F:APT]PATNUM)
Endif
Filter [APT]
# Generation variables systeme
Call GEN_VARSYS From CFGLIBA
#
W_K = 0
For W_I = 0 To dim(W_FIN)-1
  Read [ATB]CODFIC=W_FIN(W_I)
  If fstat = 0
    W_FIA(W_I) = "[F:"+[F:ATB]ABRFIC+"]"
    Filter [ATZ] Where CODFIC = [F:ATB]CODFIC & ( CODTYP = "TEX" | CODTYP = "TXC")
&                Order By Key  CODTYP                                                     # JPJ TEX->TXC
    For [ATZ]
      W_K += 1
    Next
    Filter [ATZ]
  Endif
Next W_I
# JPJ : Protection sur indice pour avoir un code valide
# En 140, il n'y a normallement plus de champs de type 'TEX' néanmoins le montage est gardé.
# Cela ne pose pas de pb car W_FICTEF(0) (nom du fichier ex: BOMD) n'est pas initialisé.
If W_K=0 : W_K=1 : Endif

# Traitement des questions et variables
W_I = 0
W_L = 0
W_P = 0
Filter [CQU0] Order By Key CQU0
For [CQU0]
  If LSCE = "" | [F:CQU0]QSTORI > 1 | (LSCE <> "" & [F:CQU0]QSTORI = 1 & find([F:CQU0]QSTNUM,LTAB))
    If W_I < dim([M]VARSUP)-1
      # FQ 53410 lecture texte traduit pour [F:CQU0]QSTNUM
      #[M]VARSUP(W_I) = W_PRS+[F:CQU0]QSTNUM+" ,"+[F:CQU0]QSTDES-"("+mess([F:CQU0]ASWTYP,252,1)+")"
      Call LECTEXTRA(WQSTDES,"CFGQST","QSTAXX",[F:CQU0]QSTNUM,"") From ATEXTRA
      [M]VARSUP(W_I) = W_PRS+[F:CQU0]QSTNUM+" ,"+WQSTDES-"("+mess([F:CQU0]ASWTYP,252,1)+")"
    Endif
    If W_I < dim(W_QSN)
      If [F:CQU0]QSTTYP = 1
        W_L += 1
      Endif
      W_QSN(W_I) = [F:CQU0]QSTNUM
      W_QST(W_I) = [F:CQU0]ASWTYP
      W_QOR(W_I) = [F:CQU0]QSTORI
      W_QCT(W_I) = [F:CQU0]CTLTYP
      W_QTC(W_I) = [F:CQU0]TCT
      If [F:CQU0]CODNUM = ""
        W_QSP(W_I) = [F:CQU0]QSTTYP
      Else
        W_QSP(W_I) = 3
      Endif
      # FQ 60137
      #W_GLANGUE=GLANGUE # FQ 53410
      For W_S = 0 To [F:ADS1]NBRLAN-1
        # FQ 60137 garder QSTSHO - FQ 53410 lecture texte traduit dans chaque langue du dossier selon [F:CQU0]QSTNUM
        #W_T = find([F:ADS1]LAN(W_S),[F:CQU0]QSTSHO(0..[F:CQU0]QSTSHONBR-1))
        W_T = find([F:ADS1]LAN(W_S),[F:CQU0]QSTLAN(0..[F:CQU0]QSTSHONBR-1))
        #If W_T = 0  # Issue 105687 GA 01/2015
        If W_T = 0 | W_T> W_NBLAN | W_T>dim([F:CQU0]QSTSHO)
          W_QSM(W_I,W_S) = [F:CQU0]QSTSHO(0)
        Else
          W_QSM(W_I,W_S) = [F:CQU0]QSTSHO(W_T-1)
        Endif
        #GLANGUE=[F:ADS1]LAN(W_S)
        #Call LECTEXTRA(W_QSM(W_I,W_S),"CFGQST","QSTAXX",[F:CQU0]QSTNUM,"") From ATEXTRA
      Next W_S
      # GLANGUE=W_GLANGUE # FQ 53410
      W_QEV(W_I) = 0
      If [F:CQU0]EVADEFVAL <> ""
        W_QEV(W_I) = 1
        W_QSD(W_I) = [F:CQU0]EVADEFVAL
      Else
        Case [F:CQU0]ASWTYP
          When 1 : W_QSD(W_I) = '"'+[F:CQU0]ALPDEFVAL+'"'
          When 2 : W_QSD(W_I) = num$([F:CQU0]NUMDEFVAL)
          When 3 : W_QSD(W_I) = "date$"
          When 4 : W_QSD(W_I) = num$([F:CQU0]NUMDEFVAL)
          When 5 : W_QSD(W_I) = '"'+[F:CQU0]ALPDEFVAL+'"'
          When 6 : W_QSD(W_I) = '"'+[F:CQU0]ALPDEFVAL+'"'   # FQ 50451 GA 11/2008 type Blob
          When 7 : W_QSD(W_I) = '"'+[F:CQU0]ALPDEFVAL+'"'   # FQ 50451 GA 11/2008 type Clob
        Endcase
      Endif
      W_QSC(W_I) = [F:CQU0]CODNUM
      W_QDI(W_I) = [F:CQU0]QSTDIM
      W_QFO(W_I) = [F:CQU0]FILFIC
      If [F:CQU0]CTLTYP = 3
        W_QTB(W_I) = [F:CQU0]CODFIC
        W_QOB(W_I) = [F:CQU0]OBJET
        W_QOF(W_I) = [F:CQU0]CODFLD

      # CCC (29/11/05) Bug 33447 Récupérer l'abréviation de la table
        Read [ATB]CODFIC=[F:CQU0]CODFIC
        W_QATB(W_I)= [F:ATB]ABRFIC
        If fstat = 0 & [F:ATB]INTIT <> ""
          W_QIN(W_I) = [F:ATB]INTIT
          Read [ATZ]CODZONE=[F:ATB]CODFIC;[F:ATB]INTIT
          W_QINTYP(W_I) = [ATZ]CODTYP    # Pour lecture
        Endif
        W_P       += 1
      Elsif [F:CQU0]CTLTYP = 6   # FQ GA 08/2011 Ctrl Table diverse
        W_QTB(W_I) = [F:CQU0]CODFIC # Issue 98847 GA 04/2014 "ATABDIV"   # CODFIC
        W_QOB(W_I) = "ADI"          # Objet
        W_QOF(W_I) = "CODE"         # Issue 98847 GA 04/2014 "NUMTAB"    #
        Read [ATB]CODFIC="ATABDIV"
        W_QATB(W_I)= "ADI"          # ABRFIC
        If fstat = 0 & [F:ATB]INTIT <> ""
          W_QIN(W_I) = [F:ATB]INTIT
          Read [ATZ]CODZONE=[F:ATB]CODFIC;[F:ATB]INTIT
          W_QINTYP(W_I) = [ATZ]CODTYP    # Pour lecture
        Endif
        W_P       += 1
      Endif
      W_LAQ(W_I) = W_QSN(W_I)
      W_LAS(W_I) = 99-len([F:CQU0]QSTNUM)
      W_LAT(W_I) = W_QST(W_I)
      W_LAP(W_I) = W_QSP(W_I)
    Endif
    #
    W_I += 1
  Endif
Next
Filter [CQU0]
Close Local File [CQU0]
Sorta W_I W_LAS, W_LAQ, W_LAT, W_LAP Order By W_LAS(indice), W_LAQ(indice)
#
# Effacement anciens traitements generes - V5 les .adx sont dans une archive
#
  W_SUF = "src"
  W_R      = 0
  W_FICSRC = filpath("TRT","WUVAR0"+num$(W_R),W_SUF,LAPL)
  While filinfo(W_FICSRC,0)>=0
    Call EFFACE(W_FICSRC,W_J) From ORDSYS
    W_R += 1
    W_FICSRC = filpath("TRT","WUVAR0"+num$(W_R),W_SUF,LAPL)
  Wend
#
  W_R      = 0
  W_FICSRC = filpath("TRT","WUVAR1"+num$(W_R),W_SUF,LAPL)
  While filinfo(W_FICSRC,0)>=0
    Call EFFACE(W_FICSRC,W_J) From ORDSYS
    W_R += 1
    W_FICSRC = filpath("TRT","WUVAR1"+num$(W_R),W_SUF,LAPL)
  Wend
#
# Issue 88129 GA 02/2013 remplacer aussi WUVAR.src
  W_R      = 0
  W_FICSRC = filpath("TRT","WUVAR",W_SUF,LAPL)
  While filinfo(W_FICSRC,0)>=0
    Call EFFACE(W_FICSRC,W_J) From ORDSYS
    W_R += 1
    W_FICSRC = filpath("TRT","WUVAR",W_SUF,LAPL)
  Wend

  W_SUF = "adx"
  W_R      = 0
  W_FICSRC = "WUVAR0"+num$(W_R)
  Call EXISTE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  While W_J
    Raz W_J
    Call EFFACE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
    W_R += 1
    W_FICSRC = "WUVAR0"+num$(W_R)
    Call EXISTE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  Wend
#
  W_R      = 0
  W_FICSRC = "WUVAR1"+num$(W_R)
  Call EXISTE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  While W_J
    Raz W_J
    Call EFFACE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
    W_R += 1
    W_FICSRC = "WUVAR0"+num$(W_R)
    Call EXISTE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  Wend
#
# Issue 88129 GA 02/2013 remplacer aussi WUVAR.adx
  W_R      = 0
  W_FICSRC = "WUVAR"
  Call EXISTE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  If W_J
    Call EFFACE_ADX("",LAPL,W_FICSRC,W_J) From ORDSYS
  Endif
#
# Generation variables
#
W_FSQ    = "WUVAR"
W_FICSRC = filpath("TRT",W_FSQ,"src",LAPL)
# FQ 49740 pb avec Gosub ... From = S_DOSSIER+".WUVAR" devient From ='+CH_DOSSIER+'"WUVAR"
# FQ 50292 oubli report FQ 50192 il reste un pb CH_DOSSIER = '"S_DOSSIER."+'
Local Char CH_DOSSIER(20)
#If LAPL<>nomap              # Issue 88129 02/2013 toujours préfixer
   CH_DOSSIER = 'S_DOSSIER+"."+'
#Else
#   CH_DOSSIER = ""
#Endif

Openo W_FICSRC,0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%I%"
Wrseq "############################################################"
Wrseq "# ";W_FSQ;" CFG routines generated : ";num$(date$);" ";num$(time$);" By ";GUSER
Wrseq "# ";GVERSION;" ";W_REL
Wrseq "############################################################"
Wrseq "Subprog CFG_VER(LVER)"
Wrseq "Variable Char LVER"
Wrseq 'LVER = "';GVERSION;' ';GUSER;' ';num$(date$);' ';num$(time$);'"'
Wrseq "End"
Wrseq "############################################################"
Wrseq "Subprog CFG_DOS(LDOS)"
Wrseq "Variable Char LDOS"
Wrseq 'LDOS = "';LAPL;'"'
Wrseq "End"
Wrseq "############################################################"
#
# Generation Variables globales si absentes
# (Ne pas oublier de mettre a jour liste symboles reserves si ajout)
Wrseq "$TAB_SYMBOLES"
Wrseq "#"
Wrseq "# Global variables of the configurator"
Wrseq "#"
Wrseq "If dim(S_CFGCFG)  > 0"
Wrseq "  Return"
Wrseq "Endif"
Wrseq "#"
Wrseq "Gosub CFG_PREFIXES From CFGLIB"
Wrseq "#"
# Issue 106724 GA 03/2015 variable length for S_SCENUM(05), S_SUBSCE(05)
# Issue 86230 GA 02/2013 ajout S_MODBPSNUM,S_MODITMREFBPS,S_MODBPCNUM,S_MODITMREFBPC
# Issue 89191 GA 04/2013 ajout S_MODITMDESBPS,S_MODITMDESBPC
Wrseq "Global Integer S_CFGCFG, S_AUTCFG, S_UPDMOD, S_PHASE , S_SEQ   , S_LIN   , S_SELINP, S_SELSCS,"
Wrseq "&              S_SELCOR, S_SALTXT, S_ENDINP, S_RETURN, S_HRDCOP, S_LEVEL , S_ABORT,  S_SEQTEX,"
Wrseq "&              S_MEMO  , S_SCDOPE, S_SELTBL, S_WINAUT, S_QSTFLG, S_ALPLNG"
Wrseq "Global Char    S_DOSSIER(10), S_AUTERR(50), S_SCENUM(GLONCFG), S_SUBSCE(GLONCFG), S_SCEDES(GLONDES),"
Wrseq "&              S_CPTCFG(GLONVCR), S_CPTCOP (GLONITM), S_MODITM(GLONITM), "
Wrseq "&              S_MODBPSNUM(GLONBPR)(20),S_MODITMREFBPS(GLONVCR)(20),"
Wrseq "&              S_MODBPCNUM(GLONBPR)(20),S_MODITMREFBPC(GLONVCR)(20),"
Wrseq "&              S_MODITMDESBPS(GLONDES)(20),S_MODITMDESBPC(GLONDES)(20)"
Wrseq "#"
Wrseq "# Array of field text, type and nature"
# Issue 82989 GA 07/2012 before W_VARLAB(10)
Wrseq "Global Char    W_VARLAB(GLONAVA)(";num$(W_I);"),"
Wrseq "&              W_VARATT(02)(";num$(W_I);"),"
# Issue 82989 suite GA 11/2012 before W_VARRNG(10)
Wrseq "&              W_VARRNG(GLONAVA)(";num$(W_L+1);"),"
Wrseq "&              W_INTSEL(40)(12)"
If W_P > 0
# Issue 82989 suite GA 11/2012 before W_VAROBJ(08)
  Wrseq "Global Char    W_VAROBJ(GLONAVA)(";num$(W_P);")"
Endif
Wrseq "Global Integer W_INDRNG, W_STRRNG, W_PILRNG"               # FQ 50596 GA 11/2008 + W_PILRNG
Wrseq "# Array of table informations"
Wrseq "Global Integer W_FICNUM    (";num$(dim(W_FIN));"),"
Wrseq "&              W_FICTEM    (";num$(W_K);")"                # Texte riche: module (pour type Tex)
Wrseq "Global Char    W_EXTFIC(03),"
Wrseq "&              W_FICNAM(10)(";num$(dim(W_FIN));"),"
Wrseq "&              W_FICABR(08)(";num$(dim(W_FIN));"),"
# Issue 84700 GA 11/2012 Translated texts before (10)(03)
#Wrseq "&              W_FICAXF(10)(03),"
#Wrseq "&              W_FICAXZ(10)(03),"
#Wrseq "&              W_FICAXN(10)(03),"
Wrseq "&              W_FICAXF("+num$(GLONAVA)+")(20),"
Wrseq "&              W_FICAXZ("+num$(GLONAVA)+")(20),"
Wrseq "&              W_FICAXN("+num$(GLONAVA)+")(20),"
Wrseq "&              W_FICAX1("+num$(GLONAVA)+")(20),"
Wrseq "&              W_FICAX2("+num$(GLONAVA)+")(20),"
Wrseq "&              W_FICAX3("+num$(GLONAVA)+")(20),"  # Issue 84700 GA 11/2012
Wrseq "&              W_FICTEF(10)(";num$(W_K);"),"    # Texte riche: Fichier
Wrseq "&              W_FICTEZ(10)(";num$(W_K);"),"    # Texte riche: Zone
Wrseq "&              W_FICTET(3)(";num$(W_K);"),"     # JPJ TEX->TXC  Texte riche: Type
Wrseq "&              W_KEYTEX(60)"
Wrseq "#"
#
Wrseq "# Initialization"
Wrseq "S_DOSSIER = ";'"';LAPL;'"'
Wrseq "S_ALPLNG  = ";num$(GLONDES)
W_Q   = (W_I/W_LAM)
For W_R = 0 To W_Q
  Wrseq 'Gosub MEI_VARLAB From ='+CH_DOSSIER+'"WUVAR0';num$(W_R);'"'
Next W_R
# N'activer qu'n version 130
#Wrseq "Gosub MEI_SYMTXT"
#
# Generation des tables systemes
#
Wrseq "#"
For W_J = 0 To dim(W_FIN)-1
  Wrseq 'W_FICABR('; format$("N0:3#",W_J); ') = "';W_FIA(W_J);'" : ';
  If W_J < 11
    Wrseq 'W_FICNUM('; format$("N0:3#",W_J); ') =  ';num$(W_J+13);" : ";
  Else
    Wrseq 'W_FICNUM('; format$("N0:3#",W_J); ') =  ';num$(W_J+17);" : ";
  Endif
  Wrseq 'W_FICNAM('; format$("N0:3#",W_J); ') = "';W_FIN(W_J);'"'
Next W_J
Wrseq "# Initialization of translated description fields parameters"
Wrseq "Local Shortint ITXT : ITXT=0"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES1" : W_FICAXN(ITXT) = "DES1AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES2" : W_FICAXN(ITXT) = "DES2AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES3" : W_FICAXN(ITXT) = "DES3AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
# Issue 84700 GA 11/2012 more Translated texts before (10)(03)
# Issue 89095 GA 06/2013 uniquement champs en correspondance xxxDES/SHO vers xxxyyyAXX
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMCATEG"  : W_FICAXZ(ITXT) = "TCLDES" : W_FICAXN(ITXT) = "TCLAXX"'
Wrseq 'W_FICAX1(ITXT) = "TCLCOD"    : W_FICAX2(ITXT) = "" : : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMCATEG"  : W_FICAXZ(ITXT) = "TCLSHO" : W_FICAXN(ITXT) = "TCLSHOAXX"'
Wrseq 'W_FICAX1(ITXT) = "TCLCOD"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = ""'
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMSALES"  : W_FICAXZ(ITXT) = "ITMDES1" : W_FICAXN(ITXT) = "DES1AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = ""'
# Issue 89095 GA 06/2013 sauf cas particuliers BOH et ROH
#Wrseq "ITXT+=1"
#Wrseq 'W_FICAXF(ITXT) = "BOM"       : W_FICAXZ(ITXT) = "BOMDES" : W_FICAXN(ITXT) = "BOMDESAXX"'
#Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "BOMALT" : W_FICAX3(ITXT) = "BOMALTTYP" '
#Wrseq "ITXT+=1"
#Wrseq 'W_FICAXF(ITXT) = "ROUTING"   : W_FICAXZ(ITXT) = "ROUDES" : W_FICAXN(ITXT) = "ROUDESAXX"'
#Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "ROUALT" : W_FICAX3(ITXT) = "FCY" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ROUOPESTD" : W_FICAXZ(ITXT) = "STDOPEDES" : W_FICAXN(ITXT) = "STDOPEDESAXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : : W_FICAX3(ITXT) = "" '
Wrseq "#"
W_K = 0
For W_J = 0 To dim(W_FIN)-1
  Filter [ATZ] Where CODFIC = W_FIN(W_J) & (CODTYP = "TEX" | CODTYP="TXC")
&              Order By Key  CODTYP                                            # JPJ TEX->TXC
  For [ATZ]
    Read [ATB]CODFIC=[F:ATZ]CODFIC
    If fstat = 0
      W_STR = format$("K:12X",'"'+W_FIN(W_J)+'"')
      W_FMT = format$("K:12X",'"'+[F:ATZ]CODZONE+'"')
      W_TYP = format$("K:5X",'"'+[F:ATZ]CODTYP+'"')     # JPJ TEX->TXC
      Wrseq 'W_FICTEF(';format$("N0:3#",W_K); ') = ';W_STR;' : W_FICTEZ(';format$("N0:3#",W_K);') = ';W_FMT;
      Wrseq ' : W_FICTET(';format$("N0:3#",W_K); ') = ';W_TYP ;           # JPJ TEX->TXC
      Wrseq ' : W_FICTEM(';format$("N0:3#",W_K); ') = ';num$([F:ATB]MODULE)
      W_K += 1
    Endif
  Next
  Filter [ATZ]
Next W_J
Wrseq "#"
#
W_P = 0
For W_J = 0 To W_I-1
  If W_QCT(W_J) = 3
    Wrseq 'W_VAROBJ(';format$("N0:3#",W_P); ') = "';W_QSN(W_J);'"'
    W_P += 1
  Endif
Next W_J
Wrseq "#"
Wrseq "Return"
Wrseq "############################################################"
Wrseq "# Set symbol text"
Wrseq "$MEI_SYMTXT"
Wrseq "Local Integer W_Z"
Wrseq "For W_Z = 0 to dim(W_VARLAB)-1"
Wrseq "  W_VAR = W_PRX+mid$(W_VARLAB(W_Z),3,GLONCQU)"
Wrseq "  Gosub CRE_SYMTXT"
Wrseq "Next W_Z"
Wrseq "Return"
# Ecriture de la routine de suppression de toutes les variables globales
Wrseq "############################################################"
Wrseq "# Delete global variables of the configurateur"
Wrseq "$SUP_GLOBALES"
Wrseq "Local Integer W_Z"
Wrseq "#"
Wrseq "If dim(S_DOSSIER) < 0"
Wrseq "  Return"
Wrseq "Endif"
Wrseq "Gosub CFG_PREFIXES from CFGLIB"
Wrseq "# Delete global variable of symbols"
Wrseq "For W_Z = 0 To dim(W_VARLAB)-1"
Wrseq "  W_VAR = W_VARLAB(W_Z)"
Wrseq '  Gosub SUP_SYMBOLE From ='+CH_DOSSIER+'"WUVAR"'
Wrseq "  W_VAR = W_PRW+mid$(W_VAR,3,GLONCQU)"
Wrseq '  Gosub SUP_SYMBOLE From ='+CH_DOSSIER+'"WUVAR"'
Wrseq "  W_VAR = W_PRX+mid$(W_VAR,3,GLONCQU)"
Wrseq '  Gosub KIL_SYMTXT  From ='+CH_DOSSIER+'"WUVAR"'
Wrseq "Next W_Z"
Wrseq "#"
Wrseq "# Delete special prefixs of the configurator"
Wrseq "Kill W_PRS, W_PRL, W_PRR, W_PRX, W_PRQ, W_PRW, W_PRY, W_PRZ"
Wrseq "#"
Wrseq "# Delete global variables and arrays"
Wrseq "If dim(S_CFGCFG) > 0"
Wrseq "  Kill S_CFGCFG,  S_AUTCFG, S_AUTERR, S_ALPLNG, S_SCENUM, S_SUBSCE, S_SCEDES, S_UPDMOD, S_PHASE"
Wrseq "  Kill S_SEQ   ,  S_LIN   , S_CPTCFG, S_CPTCOP, S_SELINP, S_SELSCS, S_SELCOR, S_SALTXT, S_ENDINP"
Wrseq "  Kill S_RETURN,  S_HRDCOP, S_LEVEL , S_ABORT , S_SEQTEX, S_MEMO  , S_SCDOPE, S_SELTBL, S_WINAUT"
Wrseq "  Kill S_MODITM,  S_QSTFLG"
Wrseq "  Kill W_VARLAB,  W_VARATT, W_VARRNG, W_FICNAM, W_FICABR, W_FICNUM, W_FICAXF, W_FICAXZ"
Wrseq "  Kill W_FICAXN,  W_FICAX1, W_FICAX2, W_FICTEF, W_FICTEZ, W_FICTEM, W_KEYTEX, W_FICTET"      # JPJ TEX->TXC
Wrseq "  Kill W_STRRNG,  W_INTSEL, W_EXTFIC, W_INDRNG, W_PILRNG"                  # FQ 50596 GA 11/2008 + W_PILRNG
Wrseq "Endif"
# Issue 86230 GA 02/2013 ajout S_MODBPSNUM, S_MODITMREFBPS, S_MODBPCNUM, S_MODITMREFBPC
# Issue 89191 GA 04/2013 ajout S_MODITMDESBPS,S_MODITMDESBPC
Wrseq "If dim(S_MODBPSNUM) > 0"
Wrseq "  Kill S_MODBPSNUM, S_MODITMREFBPS, S_MODBPCNUM, S_MODITMREFBPC"
Wrseq "  Kill S_MODITMDESBPS,S_MODITMDESBPC"
Wrseq "Endif"
Wrseq "If dim(W_VAROBJ) > 0"
Wrseq "  Kill W_VAROBJ"
Wrseq "Endif"
Wrseq 'If (dim(GFONC1) < 0 | GFONC1 <> "FUNCFGUTI") & dim(S_DOSSIER) > 0'
Wrseq "  Kill S_DOSSIER"
Wrseq "Endif"
Wrseq "If dim(Z_VARLAB) > 0"
Wrseq "  Kill Z_VARLAB, Z_VARATT, Z_VARNBR"
Wrseq "Endif"
Wrseq "Return"
Wrseq "############################################################"
Wrseq "$PAR_TEX"
Wrseq "# Array of table informations"
Wrseq "Local  Char    W_FICNAM(10)(";num$(dim(W_FIN));")"
Wrseq "Local  Char    W_FICABR(08)(";num$(dim(W_FIN));")"
Wrseq "Local  Integer W_FICNUM    (";num$(dim(W_FIN));")"
# Issue 84700 GA 11/2012 Translated texts before (10)(03)
Wrseq "Local  Char    W_FICAXF("+num$(GLONAVA)+")(20)"
Wrseq "Local  Char    W_FICAXZ("+num$(GLONAVA)+")(20)"
Wrseq "Local  Char    W_FICAXN("+num$(GLONAVA)+")(20)"
Wrseq "Local  Char    W_FICAX1("+num$(GLONAVA)+")(20)"
Wrseq "Local  Char    W_FICAX2("+num$(GLONAVA)+")(20)"
Wrseq "Local  Char    W_FICAX3("+num$(GLONAVA)+")(20)" # Issue 84700 GA 11/2012 added
Wrseq "#"

# JPJ : Protection sur indice pour avoir un code valide
# En 140, il n'y a normallement plus de champs de type 'TEX' néanmoins le montage est gardé.
# Cela ne pose pas de pb car W_FICTEF(0) (nom du fichier ex: BOMD) n'est pas initialisé.
If W_K=0 : W_K=1 : Endif

Wrseq "Local  Char    W_FICTEF(10)(";num$(W_K);")"
Wrseq "Local  Char    W_FICTEZ(10)(";num$(W_K);")"
Wrseq "Local  Char    W_FICTET(3)(";num$(W_K);")"     # JPJ TEX->TXC  Type de texte riche
Wrseq "Local  integer W_FICTEM    (";num$(W_K);")"
Wrseq "#"
Wrseq "#"
For W_J = 0 To dim(W_FIN)-1
  Wrseq 'W_FICABR('; format$("N0:3#",W_J); ') = "';W_FIA(W_J);'" : ';
  If W_J < 11
    Wrseq 'W_FICNUM('; format$("N0:3#",W_J); ') =  ';num$(W_J+13);" : ";
  Else
    Wrseq 'W_FICNUM('; format$("N0:3#",W_J); ') =  ';num$(W_J+17);" : ";
  Endif
  Wrseq 'W_FICNAM('; format$("N0:3#",W_J); ') = "';W_FIN(W_J);'"'
Next W_J
Wrseq "Local Shortint ITXT : ITXT=0"
Wrseq "# Initialization of translated description fields parameters"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES1" : W_FICAXN(ITXT) = "DES1AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES2" : W_FICAXN(ITXT) = "DES2AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMMASTER" : W_FICAXZ(ITXT) = "ITMDES3" : W_FICAXN(ITXT) = "DES3AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = "" '
# Issue 84700 GA 11/2012 more Translated texts before (10)(03)
# Issue 89095 GA 06/2013 uniquement champs en correspondance xxxDES/SHO vers xxxyyyAXX
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMCATEG"  : W_FICAXZ(ITXT) = "TCLDES" : W_FICAXN(ITXT) = "TCLAXX"'
Wrseq 'W_FICAX1(ITXT) = "TCLCOD"    : W_FICAX2(ITXT) = "" : : W_FICAX3(ITXT) = "" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMCATEG"  : W_FICAXZ(ITXT) = "TCLSHO" : W_FICAXN(ITXT) = "TCLSHOAXX"'
Wrseq 'W_FICAX1(ITXT) = "TCLCOD"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = ""'
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ITMSALES"  : W_FICAXZ(ITXT) = "ITMDES1" : W_FICAXN(ITXT) = "DES1AXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : W_FICAX3(ITXT) = ""'
# Issue 89095 GA 06/2013 sauf cas particuliers BOH et ROH
#Wrseq "ITXT+=1"
#Wrseq 'W_FICAXF(ITXT) = "BOM"       : W_FICAXZ(ITXT) = "BOMDES" : W_FICAXN(ITXT) = "BOMDESAXX"'
#Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "BOMALT" : W_FICAX3(ITXT) = "BOMALTTYP" '
#Wrseq "ITXT+=1"
#Wrseq 'W_FICAXF(ITXT) = "ROUTING"   : W_FICAXZ(ITXT) = "ROUDES" : W_FICAXN(ITXT) = "ROUDESAXX"'
#Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "ROUALT" : : W_FICAX3(ITXT) = "FCY" '
Wrseq "ITXT+=1"
Wrseq 'W_FICAXF(ITXT) = "ROUOPESTD" : W_FICAXZ(ITXT) = "STDOPEDES" : W_FICAXN(ITXT) = "STDOPEDESAXX"'
Wrseq 'W_FICAX1(ITXT) = "ITMREF"    : W_FICAX2(ITXT) = "" : : W_FICAX3(ITXT) = "" '
Wrseq "#"
W_K = 0
For W_J = 0 To dim(W_FIN)-1
  Filter [ATZ] Where CODFIC = W_FIN(W_J) & (CODTYP = "TEX" | CODTYP = "TXC")
&              Order By Key  CODTYP
  For [ATZ]
    Read [ATB]CODFIC=[F:ATZ]CODFIC
    If fstat = 0
      W_STR = format$("K:12X",'"'+W_FIN(W_J)+'"')
      W_FMT = format$("K:12X",'"'+[F:ATZ]CODZONE+'"')
      W_TYP = format$("K:5X",'"'+[F:ATZ]CODTYP+'"')
      Wrseq 'W_FICTEF(';format$("N0:3#",W_K); ') = ';W_STR;' : W_FICTEZ(';format$("N0:3#",W_K);') = ';W_FMT;
      Wrseq ' : W_FICTET(';format$("N0:3#",W_K); ') = ';W_TYP;     # JPJ TEX->TXC
      Wrseq ' : W_FICTEM(';format$("N0:3#",W_K); ') = ';num$([F:ATB]MODULE)
      W_K += 1
    Endif
  Next
  Filter [ATZ]
Next W_J
Wrseq "#"
#
Wrseq "Return"
Wrseq "#"
Wrseq "############################################################"
Wrseq "$EXT_FIC"
Wrseq 'W_EXTFIC = "0"'
For W_J = 0 To W_I-1
  If mod(W_J,W_STE) = 0
    W_FMT = format$("K:14X",'"'+W_QSN(W_J)+'"')
    Wrseq 'If mid$(W_VAR,3,GLONCQU) >= ';W_FMT;' : W_EXTFIC = num$(';num$(W_J/W_STE);') : Endif'
  Endif
Next W_J
Wrseq "Return"
Wrseq "#"
Wrseq "############################################################"
Wrseq "$CRE_SYMBOLE"
Wrseq "Gosub EXT_FIC"
Wrseq 'Gosub CRE_SYMBOLE From ='+CH_DOSSIER+'"WUVAR1"+W_EXTFIC'
Wrseq "Return"
#
