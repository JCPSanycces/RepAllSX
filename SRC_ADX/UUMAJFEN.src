#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
## Validation des fonctions
##############################################################################
Call OUVRE_TRACE(mess(81,125,1)-"AWINDOW") From LECFIC : # Mise à jour de la table
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local Integer I , MAJ , DET
Local File =DOSSIER+".AWINDOW" [AWI]
DET = 0
Trbegin [AWI]
 For [AWI]
  MAJ = 0
  For I=[F:AWI]NBMSK+1 To dim([F:AWI]NOMMSK)
   If [F:AWI]INTMSK(I-1)<>0
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"INTMSK="+num$(INTMSK),-1) From GESECRAN
    Endif
    [F:AWI]INTMSK(I-1) = 0
    MAJ = 1
   Endif
   If [F:AWI]NOMMSK(I-1)<>""
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"NOMMSK="+num$(NOMMSK),-1) From GESECRAN
    Endif
    [F:AWI]NOMMSK(I-1) = ""
    MAJ = 1
   Endif
   If [F:AWI]ACTMSK(I-1)<>""
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"ACTMSK="+num$(ACTMSK),-1) From GESECRAN
    Endif
    [F:AWI]ACTMSK(I-1) = ""
    MAJ = 1
   Endif
   If [F:AWI]FLGMSK(I-1)<>0
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"FLGMSK="+num$(FLGMSK),-1) From GESECRAN
    Endif
    [F:AWI]FLGMSK(I-1) = 0
    MAJ = 1
   Endif
   If [F:AWI]ROWMSK(I-1)<>0
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"ROWMSK="+num$(ROWMSK),-1) From GESECRAN
    Endif
    [F:AWI]ROWMSK(I-1) = 0
    MAJ = 1
   Endif
   If [F:AWI]INTFOLD(I-1)<>""
    If DET
     Call ECR_TRACE([F:AWI]WIN-num$(I)-"INTFOLD="+num$(INTFOLD),-1) From GESECRAN
    Endif
    [F:AWI]INTFOLD(I-1) = ""
    MAJ = 1
   Endif
  Next I
  If MAJ
   If !DET
    Call ECR_TRACE([F:AWI]WIN-"updated",0) From GESECRAN
   Endif
   Rewrite [AWI]
   If fstat
    Call ERREUR("AWINDOW"-[F:AWI]WIN,2) From DOSDIC
   Endif
  Endif
 Next AWI
Commit
Return
