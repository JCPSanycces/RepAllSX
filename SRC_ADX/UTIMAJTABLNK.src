#<AdxTL>@(#)5.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation de la table AWRKTAB
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Init AWRKTAB file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#-------------------#
$MAJTAB
If filinfo(filpath("FIL","AWRKTAB","fde",[L]DOSSIER),0)<0 : End : Endif

Local Integer I , NBCRE

If DOSSIER=nomap
 Local File AWRKLNK [AWM] , AWRKTAB [AWK]
Else
 Local File =DOSSIER+".AWRKLNK" [AWM] , =DOSSIER+".AWRKTAB" [AWK]
Endif

If dim([AWM]NBRLNK)>0
  Trbegin [AWK]
   For [AWM]
    Delete [AWK] Where MODELE=[F:AWM]MODELE
    For I=1 To [AWM]NBRLNK
     Raz [F:AWK]
     [F:AWK]MODELE = [F:AWM]MODELE
     [F:AWK]NUMLIG = I
     [F:AWK]TABLNK = [F:AWM]TABLNK(I-1)
     [F:AWK]ABRLNK = [F:AWM]ABRLNK(I-1)
     [F:AWK]TABORI = [F:AWM]TABORI(I-1)
     If dim([AWM]ABRORI)>0 : [F:AWK]ABRORI = [F:AWM]ABRORI(I-1) : Endif
     [F:AWK]TYPLNK = [F:AWM]TYPLNK(I-1)
     [F:AWK]CLELNK = [F:AWM]CLELNK(I-1)
     [F:AWK]EXPLNK = [F:AWM]EXPLNK(I-1)
     If dim([AWM]EXPSEL)>0 : [F:AWK]EXPSEL = [F:AWM]EXPSEL(I-1) : Endif
     If dim([AWM]STRLNK)>0 : [F:AWK]STRLNK = [F:AWM]STRLNK(I-1) : Endif
     Write [AWK]
     If fstat
      Call ERREUR("AWRKTAB"-[F:AWK]MODELE,1) From DOSDIC
     Else
      NBCRE += 1
     Endif
    Next I
   Next AWM
  Commit

  Call ECR_TRACE(num$(NBCRE)-mess(103,141,1),0) From GESECRAN : # Enregistrements créés

Endif

Close Local File

Return
