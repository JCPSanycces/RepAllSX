#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"CPTRUB","CPTRUB","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRER
 When "SETBOUT"     : Gosub SETBOUT
 When "FIN"         : Gosub FIN
Endcase
Return

$DEBUT
Local Integer I, J, OK, PLEIN, DERRUB
Local Char    PCOD(10), SYMBOLE(30)
Local File RUBRIQUE[RUB]
Raz [M:CRUB]
Raz GREP
REPORT2="LISCPTRUB"

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$APRES_MODIF
Case COUZON
 When "RUBDEB"
  If [M]RUBFIN<>""
   [M]RUBDEB = CZ
   Gosub CHARGE
  Endif
 When "RUBFIN"
  If [M]RUBDEB<>""
   [M]RUBFIN = CZ
   Affzo [M]RUBFIN
   Gosub CHARGE
  Endif
 When "NBLIG"
  If GREP=""
   If instr(1,GUSRAUZ(1),"M")
    GREP = "M"
    Gosub GRISE
   Else
    mkstat = 2
   Endif
  Endif
Endcase
Return

$ABANDON
Gosub DEVERROU
Gosub DEGRISE
Raz [M:CRUB]
Affzo [M:CRUB]
Raz GREP
SUIZON="[M:CRUB]RUBDEB"
Return

$ENREGISTRER
Sorta NBLIG NBLIG Order By ROW([S]indice), ACC([S]indice)
Call DEBTRANS From GLOCK
Gosub TR1
Gosub ABANDON
Return

$TR1
Trbegin [RUB]

## Raz des comptes d'OD dans RUBRIQUE
For [RUB] Where ROW>=[M]ROWDEB & ROW<=[M]ROWFIN
 Raz [F:RUB]NBRACC, [F:RUB]SAC, [F:RUB]ACC, [F:RUB]TYPAMT, [F:RUB]SNS, [F:RUB]DETEMP
 Rewrite [RUB]
 If fstat
  GOK = 0 : Call FSTA("RUB") From GLOCK : Break
 Endif
Next
If GOK=0 : Goto AB_TR1 : Endif

## Maj des comptes d'OD dans RUBRIQUE
J    = 0
PCOD = ""
For I=0 To [M]NBLIG-1 : # Parcours des comptes du tableau triés sur rang
 If [M]COD(I)<>PCOD
  If PCOD<>""         : # Changement de rubrique il faut enregistrer
   [F:RUB]NBRACC = J
   Rewrite [F:RUB]
   If fstat
    GOK = 0 : Call FSTA("RUB") From GLOCK : Break
   Endif
  Endif
  Read [RUB]RUB0=GCURLEG;[M]COD(I)
  If fstat
   GOK = 0 : Call RSTA("RUB",[M]COD(I)) From GLOCK : Break
  Endif
  PCOD = [M]COD(I)
  J = 0
 Endif
 If J>dim([F:RUB]ACC)-1
  GOK = 0
  # OD de paye maximum par rubrique
  Call ERREUR(num$(dim([F:RUB]ACC))-mess(79,10703,1)-"("-[F:RUB]COD-")") From GESECRAN
  Break
 Endif
 [F:RUB]SAC(J)    = [M]SAC(I)
 [F:RUB]ACC(J)    = [M]ACC(I)
 [F:RUB]TYPAMT(J) = [M]TYPAMT(I)
 [F:RUB]SNS(J)    = [M]SNS(I)
 [F:RUB]DETEMP(J) = [M]DETEMP(I)
 J +=1
Next I
If GOK=0
 Goto AB_TR1
Elsif PCOD<>""        : # Enregistrement de la dernière rubrique
 [F:RUB]NBRACC = J
 Rewrite [RUB]
 If fstat
  GOK = 0 : Call FSTA("RUB") From GLOCK : Goto AB_TR1
 Endif
Endif
Commit
Return

$SETBOUT
CHMEN = ""
CHBOU = ""
If GREP="M"
 CHBOU = "EA"
 STADEF = GSTAENR
Endif
#
# LST : inutile en 150
#
#Gosub SET_BOUT_STD From GSAISIE
#Gosub SET_BOUT_SPE From GSAISIE
Return

$DEVERROU
For I=0 To [M]NBL-1
 SYMBOLE = "RUB"+[M]SYM(I)+GCURLEG
 Unlock =SYMBOLE
Next I
Return

$CHARGE
Call TEMPON("R") From GESECRAN
Filter [RUB] Where ROW>=[M]ROWDEB & ROW<=[M]ROWFIN & TMPCAL<>2 & TYPRUB<>5 &
&                  (DEC=0 | DEC>=GARODEV) & NBRACC>0 & LEG=GCURLEG Order By Key RUB1
I = 0
PLEIN = 0
For [RUB]
 GCURLEG=[RUB]LEG
 OK = 1
 If instr(1,GUSRAUZ(1),"M")
  SYMBOLE = "RUB"+[F:RUB]COD+GCURLEG
  Lock =SYMBOLE
  If fstat
   OK = 0
   Call ECR_TRACE(mess(60,100,1)-num$([F:RUB]ROW)-[F:RUB]COD,0) From GESECRAN : # Enregistrement verrouillé
  Else
   [M]SYM([M]NBL) = [F:RUB]COD
   [M]NBL +=1
  Endif
 Endif
 If OK
  For J=0 To [F:RUB]NBRACC-1
   [M]ROW(I)    = [F:RUB]ROW
   [M]COD(I)    = [F:RUB]COD
   [M]SAC(I)    = [F:RUB]SAC(J)
   [M]ACC(I)    = [F:RUB]ACC(J)
   [M]TYPAMT(I) = [F:RUB]TYPAMT(J)
   [M]SNS(I)    = [F:RUB]SNS(J)
   [M]DETEMP(I) = [F:RUB]DETEMP(J)
   I +=1
   If I>dim([M]ROW)-1 : PLEIN=1 : Break 2 : Endif
  Next J
 Endif
 DERRUB = [F:RUB]ROW
Next
[M]NBLIG = I
Filter [RUB]
Call TEMPOFF From GESECRAN
If PLEIN
 Unlock =SYMBOLE
 [M]NBL -=1
 Raz [M]SYM([M]NBL)
 For J=0 To [M]NBLIG-1
  If [M]ROW(J)=[F:RUB]ROW
   Raz [M]ROW(J),[M]COD(J),[M]SAC(J),[M]ACC(J),[M]TYPAMT(J),[M]SNS(J),[M]DETEMP(J)
   I -=1
  Endif
 Next J
 # Tableau plein Dernière rubrique traitée
 Call MESSAGE(mess(26,100,1)-"\"-mess(91,10703,1)-num$(DERRUB)) From GESECRAN
 [M]ROWFIN = DERRUB
Endif
[M]NBLIG = I
Affzo [M:CRUB]
Return

$GRISE
Grizo [M]RUBDEB,RUBFIN
Return

$DEGRISE
Actzo [M]RUBDEB,RUBFIN
Return

$FIN
Gosub DEVERROU
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Goto FIN : Else : Goto TR1 : Endif
Return

$AB_TR1
Rollback
Goto FIN
Return

########################################
# Ecran CPTRUB
########################################

Subprog AM_RUBDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[RUB]RUB0=GCURLEG;VALEUR
 [M:CRUB]ROWDEB=[F:RUB]ROW
Endif
End

Subprog AP_RUBDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read[RUB]RUB1 First
 VALEUR = [F:RUB]COD
Endif
End

Subprog AM_RUBFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[RUB]RUB0=GCURLEG;VALEUR
 [M:CRUB]ROWFIN=[F:RUB]ROW
 If [M:CRUB]ROWFIN < [M:CRUB]ROWDEB
  GMESSAGE = mess(28,10702,1) : # Borne incorrecte
  mkstat   = 2
 Endif
Endif
End

Subprog AP_RUBFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Read[RUB]RUB1 Last
 VALEUR = [F:RUB]COD
Endif
End

Subprog AV_ROWFIN(VALEUR)
Variable Decimal VALEUR
Read[RUB]RUB1=GCURLEG;VALEUR
If !fstat & [M]RUBFIN<>[F:RUB]COD
 [M]RUBFIN = [F:RUB]COD
 Affzo [M]RUBFIN
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Char SYMBOLE(30)
If GBIDI1=1 & VALEUR<>"" : # Poser le verrou
 If !find(VALEUR,[M]SYM(0..[M]NBL-1))
  SYMBOLE = "RUB"+VALEUR+GCURLEG
  Lock =SYMBOLE
  If !fstat
   [M]SYM([M]NBL) = VALEUR
   [M]NBL +=1
  Else
   GMESSAGE = mess(60,100,1)       : # enregistrement verrouillé
   mkstat = 2
  Endif
 Endif
Else GBIDI1=0
Endif
End

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Filter [RUB] Where ROW>=[M]ROWDEB & ROW<=[M]ROWFIN & TMPCAL<>2 & TYPRUB<>5 &
&                  (DEC=0 | DEC>=GARODEV) & LEG=GCURLEG
Read[RUB]RUB0=GCURLEG;VALEUR
If fstat
 # Paramétrage d'une OD de paye impossible pour cette rubrique
 GMESSAGE = mess(77,10703,1)
 mkstat=2
Else
 [M]ROW(nolign-1) = [F:RUB]ROW
Endif
Filter [RUB]
End

Subprog AS_NBLIG
# Aucune rubrique à traiter
If [M]NBLIG=0
 GMESSAGE = mess(78,10703,1)
 mkstat = 1
Endif
End

Subprog AVANT_NBLIG
Local Char SYMBOLE(30)
Raz GBIDI1
If status=73 | status=82    : # Ajout ou insertion
 GBIDI1 = 1
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CPTRUB) 19/05/2005 10:11:06 (LS)
######################################################################################
Subprog AS_ACC(VALEUR)
Variable Char    VALEUR()
Call AS_ACC(VALEUR) From SUBRUB
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
Call C_ACC(VALEUR) From SUBRUB
End

