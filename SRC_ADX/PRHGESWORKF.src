#-------------------------------------------------------------------
# action de validation des workflows...
#-------------------------------------------------------------------
Subprog ACTIONVALDEMMULTI(AXPARCOD,AXPARVAL,CHRONO,USRDES,NEWACT,COMMAN)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     CHRONO()()
    Value    Char     USRDES()()
    Value    Char     NEWACT()()
     Value    Char    COMMAN()()
 If clalev([F:AWR])=0 : Local File AWRKREG [AWR] : Endif
If clalev([F:AWM])=0 : Local File AWRKLNK [AWM] : Endif
Local Integer WI:WI=0
While CHRONO(WI)<>""
  If NEWACT(WI)<>""
    Call SIGWRK(CHRONO(WI),USRDES(WI),NEWACT(WI),COMMAN(WI)) From PORSUP
  Endif
  WI+=1
Wend
End
