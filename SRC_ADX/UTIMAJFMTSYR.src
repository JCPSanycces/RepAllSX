#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour format Syracuse dans type de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ATYPE table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub FMTSYR
End

#-------------------#
$FMTSYR

Local File =DOSSIER+".ATYPE"   [ATY]

If dim([F:ATY]FMTSYR)<=0 
 Close Local File
 Return
Endif

# Mise à jour de la table ATYPE
Call ECR_TRACE(mess(81,125,1)-"ATYPE:"-time$,0) From GESECRAN
Trbegin [ATY]
 For [ATY] Where FMTSYR=0
  Case [ATY]TYPTYP
   When 1   : If [F:ATY]NOLIB=1 : [F:ATY]FMTSYR = 1 : Else : [F:ATY]FMTSYR = 10 : Endif
   When 7   : [F:ATY]FMTSYR = 7
   When 2,3 : [F:ATY]FMTSYR = 2
   When 4   : [F:ATY]FMTSYR = 3
   When 5,6 : [F:ATY]FMTSYR = 4
   When 8   : [F:ATY]FMTSYR = 5
   When 9   : [F:ATY]FMTSYR = 8
   When 10  : [F:ATY]FMTSYR = 9
  Endcase
  Rewrite [ATY]
  If fstat
   Call ERREUR("ATYPE"-[F:ATY]CODTYP,2) From DOSDIC
  Endif 
 Next ATY
Commit

Close Local File

Return
