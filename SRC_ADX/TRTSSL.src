Subprog AM_STASTR(VALEUR)
Variable Char    VALEUR()
If [M]STAEND = ""     : [M]STAEND = VALEUR : Affzo [M]STAEND : Endif
If [M]STAEND < VALEUR : [M]STAEND = VALEUR : Affzo [M]STAEND : Endif
End

