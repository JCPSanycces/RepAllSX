Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
#si sloori renseigné lors de l entrée à quai alors modification interdite
If [M:SSL1]SLOORI(NOL) <> ""
   If [M:SSL1]SLOORI(NOL) <> VALEUR
       GMESSAGE= mess(60,184,1)
       mkstat=2
   Endif
Endif

End

