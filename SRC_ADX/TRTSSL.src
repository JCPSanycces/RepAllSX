Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If [M:SSLC]VCRNUMEND (NOL) = ""     : [M:SSLC]VCRNUMEND (NOL) = VALEUR : Affzo [M:SSLC]VCRNUMEND (NOL) : Endif
If [M:SSLC]VCRNUMEND (NOL) < VALEUR : [M:SSLC]VCRNUMEND (NOL) = VALEUR : Affzo [M:SSLC]VCRNUMEND (NOL) : Endif

End


########################################
Subprog C_VCRNUMEND(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If VALEUR < [M:SSLC]VCRNUMSTR (NOL) : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End


########################################
Subprog AM_LSTWIOFLG(VALEUR)
Variable Integer VALEUR
If [M:SSL1]SRGPPSSTR <> ""
   If VALEUR = 1
      [M:SSL1]LSTWIOFLG = 1
      Call ACT_SELSSL From TRTSSLA
   Endif
Endif

End

########################################
Subprog AS_VCRTYP(VALEUR)
Variable Integer VALEUR
If [M:SSL1]STOCOU (nolign-1) <> 0                                # hcb x3-82988
   mkstat = 2                                                    # hcb x3-82988
Endif                                                            # hcb x3-82988
Local Integer I
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,701,1))
    If !find(I,6,9,13,18,19,28)
        GMENLOC(I) = 1
    Endif
Next
End
########################################
Subprog AS_VCRTYPC1(VALEUR)
Variable Integer VALEUR
Local Integer I
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,7,10,14,19,20,29)
        GMENLOC(I) = 1
    Endif
Next
End

########################################
Subprog AVANT_NBLIG
Local Integer LLIG
Gosub SET_NOL From TRTSSLA
LLIG = NOL
Gosub LEC_TABSTO From TRTSSLA
End

########################################
# liste à ranger du filtr
Subprog B1_SRGPPS(VALEUR)
Variable Char    VALEUR()
VALEUR             = [M:SSL1]SRGPPSSTR
[M:SSL1]SRGPPS(NOL)= [M:SSL1]SRGPPSSTR
[M:SSL1]MODFLG(NOL)=2
End

########################################
# derniere liste à ranger
Subprog B2_SRGPPS(VALEUR)
Variable Char    VALEUR()
VALEUR             = [M:SSL1]SRGPPSEND
[M:SSL1]SRGPPS(NOL)= [M:SSL1]SRGPPSEND
[M:SSL1]MODFLG(NOL)=2
End

########################################
# nouvelle liste à ranger du filtre
Subprog B3_SRGPPS(VALEUR)
Variable Char    VALEUR()
Local Integer WRET
Gosub SET_NOL From TRTSSLA
Call DEBTRANS From GLOCK
Trbegin [SRG]
Call NUMERO(GSTKCPT(15),[M:SSL1]STOFCY,date$,[M:SSL1]ITMREF(NOL),VALEUR,WRET) From SUBANM
If WRET = 1  mkstat = 2 :
   GMESSAGE= mess(842,196,1)
Endif
If WRET = 2  mkstat = 2 :
   GMESSAGE= mess(30,196,1)
Endif
If WRET = 0
   [M:SSL1]SRGPPSEND   = VALEUR
   [M:SSL1]SRGPPS(NOL) = VALEUR
   [M:SSL1]MODFLG(NOL) = 2
   Commit
Else
   Rollback
Endif
End

########################################
Subprog IB_SRGPPS
Gosub SET_NOL From TRTSSLA

# liste à ranger du filtre
GBOUT1 = mess(450,198,1)
# dernière liste à ranger
GBOUT2= mess(451,198,1)
# nouvelle liste à ranger
GBOUT3= mess(452,198,1)
# Bouton   4 liste à blanc
GBOUT4 = mess(453,198,1)

If  [M:SSL1]SRGPPSSTR = ""
    GBOUT1 = ""
Endif
If  [M:SSL1]SRGPPSEND = ""
    GBOUT2 = ""
Endif
If  [M:SSL1]SRGPPS(NOL) =  ""
    Raz GBOUT4
Endif

# sur une liste deja enregistrer seule lste à blanc est permit
If  [M:SSL1]CREFLG(NOL) <> 0
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
Endif

End

########################################
Subprog AS_VCRTYPC(VALEUR)
Variable Integer VALEUR
Local Integer I
#CCC (13/09/10) tout est désactivé par défaut
For I=1 To len(mess(0,725,1))
    If !find(I,1,7,10,14,19,20,29)
        GMENLOC(I) = 1
    Endif
Next

End

########################################
Subprog C_VCRTYP(VALEUR)
Variable Integer VALEUR
Gosub SET_NOL From TRTSSLA
Call CTRCLESRG("SSL1",1,VALEUR,"",0,"","","") From TRTSSLA
End

########################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
If [M:SSL1]COCHAGE(NOL) <> 2
   Call CTRCLESRG("SSL1",2,[M:SSL1]VCRTYP(NOL),VALEUR,0,"","","") From TRTSSLA
Endif
End

########################################
Subprog C_VCRLIN(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTSSLA
If [M:SSL1]COCHAGE(NOL) <> 2
   Call CTRCLESRG("SSL1",3,[M:SSL1]VCRTYP(NOL),[M:SSL1]VCRNUM(NOL),VALEUR,"","","") From TRTSSLA
   If mkstat <> 2
      [M:SSL1]ITMREF(NOL) = [F:SRG]ITMREF
      Affzo  [M:SSL1]ITMREF(NOL)
   Endif
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If [M:SSL1]COCHAGE(NOL) <> 2
   Call CTRCLESRG("SSL1",4,[M:SSL1]VCRTYP(NOL),[M:SSL1]VCRNUM(NOL),[M:SSL1]VCRLIN(NOL),VALEUR,"","") From TRTSSLA
Endif
End

########################################
Subprog C_LOCORI(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
If [M:SSL1]COCHAGE(NOL) <> 2
   Call CTRCLESRG("SSL1",5,[M:SSL1]VCRTYP(NOL),[M:SSL1]VCRNUM(NOL),[M:SSL1]VCRLIN(NOL),[M:SSL1]ITMREF(NOL),VALEUR,"") From TRTSSLA
Endif
End

########################################
Subprog AM_LOCORI(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
Gosub ACT_PIKSSL From TRTSSLA
End


###########################################
#bouton 2   Detail                        #
#bouton 3   info lot (blanc ou compteur)  #
#bouton 4   Complément lot                #
#bouton 5   Document origine              #
#bouton 6   Stock par site                #
###########################################
Subprog IB_NBLIG
Gosub SET_NOL From TRTSSLA
Local Integer LRET
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""

Call INIT_GOUVLOT("SRT") From STKENT
If dim([M:SSL1]LOT) > 0

   If ([M:SSL1]LOT(NOL)<>"$" & [M:SSL1]LOT(NOL)<>""
&      | [M:SSL1]GESLOT(NOL)="C"
&      | [M:SSL1]GESLOT(NOL)="V")
       If [M:SSL1]GESLOT(NOL)<>""
          GBOUT3 = mess(441,198,1)    # info lot (blanc ou compteur)
       Endif
       If GOUVLOT>0
       # Complément lot : Visible uniquement si ligne de doc
       # n'est pas encore enregistrée et n'a qu'une seule ligne de détail
          Local Integer LRET
          LRET = func STKENT.CAL_NBENTW( [M:SSL1]WSTOSEQ(NOL) )
          If LRET=1
             GBOUT4 = mess(442,198,1)  # Complément lot
          Endif
       Endif
   Endif
Endif
GBOUT2 = mess(65,198,1)     # Détail
GBOUT5 = mess(53,117,1)     # Document origine
If [M:SSL1]VCRNUM(NOL) = ""
   GBOUT5 = ""
Endif
If [M:SSL1]ITMREF(NOL) = ""
   GBOUT2 = ""
   GBOUT6 = ""
Endif
End

Subprog B2_NBLIG
#ligne détail
Gosub SET_NOL From TRTSSLA
Local Integer LLIG
Local Integer LRET
If  [M:SSL1]COCHAGE(NOL) <> 2 | [M:SSL1]WSTOSEQ(NOL) =  0
    [M:SSL1]COCHAGE(NOL) = 2
    [M:SSL1]MODFLG (NOL) = 2
    GREP = "M"
    Call MAJ_SRG_STAFLG(NOL,[M:SSL1]COCHAGE(NOL))  From TRTSSLA
    If GOK < 1
        Raz GOUVENT
        [M:SSL1]COCHAGE         (NOL)    = 1
        [M:SSL1]MODFLG          (NOL)    = 1
        Raz [M:SSL1]SRGPPS      (NOL)
        Raz [M:SSL1]WSTOFLG     (NOL)
        Raz [M:SSL1]PCU         (NOL)
        Raz [M:SSL1]QTYPCU      (NOL)
        Raz [M:SSL1]QTYSTU      (NOL)
        Raz [M:SSL1]PCUSTUCOE   (NOL)
        If dim([M:SSL1]LOT) > 0
            Raz [M:SSL1]LOT         (NOL)
        Endif
        If dim([M:SSL1]BPSLOT) > 0
           Raz [M:SSL1]BPSLOT      (NOL)
        Endif
        If dim([M:SSL1]SLO) > 0
           Raz [M:SSL1]SLO         (NOL)
           Raz [M:SSL1]NBSLO       (NOL)
        Endif
#                                                                                         # hcb 111781 deb
        If dim([M:SSL1]ECCVALMAJ)>0
           Raz [M:SSL1]ECCVALMAJ(NOL)
           Raz [M:SSL1]ECCVALMIN(NOL)
           Raz [M:SSL1]ECCSAIFLG(NOL)
        Endif
#                                                                                         # hcb 111781 fin
        If dim([M:SSL1]SERNUM) > 0
           Raz [M:SSL1]SERNUM      (NOL)
        Endif
        If dim([M:SSL1]SERNUMF) > 0
           Raz [M:SSL1]SERNUMF     (NOL)
        Endif
        If dim([M:SSL1]PALNUM) > 0
           Raz [M:SSL1]PALNUM      (NOL)
        Endif
        If dim([M:SSL1]CTRNUM) > 0
           Raz [M:SSL1]CTRNUM      (NOL)
        Endif

        Raz [M:SSL1]STA            (NOL)
#                                                                               # hcb x3-82988 deb
        If dim([M:SSL1]TCTRNUM) > 0
            Raz [M:SSL1]TCTRNUM    (NOL)
            Raz [M:SSL1]LPNNUM     (NOL)
            Affzo [M:SSL1]TCTRNUM  (NOL)
            Affzo [M:SSL1]LPNNUM   (NOL)
        Endif
#                                                                               # hcb x3-82988 fin
        If dim([M:SSL1]LOCTYP) > 0
            Raz [M:SSL1]LOCTYP     (NOL)
        Endif
        If dim([M:SSL1]LOC) > 0
           Raz [M:SSL1]LOC         (NOL)
        Endif
        If dim([M:SSL1]WRH) > 0
           Raz [M:SSL1]WRH         (NOL)
        Endif
        Affzo [M:SSL1]COCHAGE     (NOL)
        Affzo [M:SSL1]SRGPPS      (NOL)
        Affzo [M:SSL1]WSTOFLG     (NOL)
        Affzo [M:SSL1]PCU         (NOL)
        Affzo [M:SSL1]QTYPCU      (NOL)
        Affzo [M:SSL1]QTYSTU      (NOL)
        Affzo [M:SSL1]PCUSTUCOE   (NOL)
        If dim([M:SSL1]LOT) > 0
           Affzo [M:SSL1]LOT         (NOL)
        Endif
        If dim([M:SSL1]BPSLOT) > 0
            Affzo [M:SSL1]BPSLOT      (NOL)
        Endif
        If dim([M:SSL1]SLO) > 0
           Affzo [M:SSL1]SLO         (NOL)
           Affzo [M:SSL1]NBSLO       (NOL)
        Endif

        If dim([M:SSL1]SERNUM) > 0
           Affzo [M:SSL1]SERNUM      (NOL)
        Endif
        If dim([M:SSL1]SERNUMF) > 0
           Affzo [M:SSL1]SERNUMF     (NOL)
        Endif
        If dim([M:SSL1]PALNUM) > 0
           Affzo [M:SSL1]PALNUM      (NOL)
        Endif
        If dim([M:SSL1]CTRNUM) > 0
           Affzo [M:SSL1]CTRNUM      (NOL)
        Endif

        Affzo [M:SSL1]STA            (NOL)
        If dim([M:SSL1]LOCTYP) > 0
           Affzo [M:SSL1]LOCTYP      (NOL)
        Endif
        If dim([M:SSL1]LOC) > 0
           Affzo [M:SSL1]LOC         (NOL)
        Endif
        If dim([M:SSL1]WRH) > 0
           Affzo [M:SSL1]WRH         (NOL)
        Endif
        End
    Endif

    LLIG = NOL
    LRET = 0
    Default Mask [SSL1]

    Call INIZONENT([M:SSL1]ITMREF(NOL),"SSL1",[M:SSL1]STOFCY,"",0,"",(NOL),
&                  [M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),[M:SSL1]VCRNUM(NOL),
&                  1,0) From STKECR

#RUBRIQUE destination par défaut
    [M:SSL1]PCU         (nolign-1)   = [M:SSL1]PCUORI      (nolign-1)
    [M:SSL1]QTYPCU      (nolign-1)   = [M:SSL1]QTYPCUORI   (nolign-1)
    [M:SSL1]QTYSTU      (nolign-1)   = [M:SSL1]QTYSTUORI   (nolign-1)
    [M:SSL1]PCUSTUCOE   (nolign-1)   = [M:SSL1]PCUSTUCOEO  (nolign-1)
    If dim([M:SSL1]LOT) > 0
       [M:SSL1]LOT         (nolign-1)   = [M:SSL1]LOTORI      (nolign-1)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       [M:SSL1]BPSLOT      (nolign-1)   = [M:SSL1]BPSLOTORI   (nolign-1)
    Endif
    If dim([M:SSL1]SLO) > 0
       [M:SSL1]SLO         (nolign-1)   = [M:SSL1]SLOORI      (nolign-1)
       If [M:SSL1]SLO      (nolign-1) <> ""
          [M:SSL1]NBSLO    (nolign-1)   = 1
       Endif
    Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJ(nolign-1) = [M:SSL1]ECCVALMAJORI(nolign-1)
      [M:SSL1]ECCVALMIN(nolign-1) = [M:SSL1]ECCVALMINORI(nolign-1)
      [M:SSL1]ECCSAIFLG(nolign-1) = [M:SSL1]ECCSAIFLGORI(nolign-1)
   Endif
#                                                                                         # hcb 111781 fin
    If dim([M:SSL1]SERNUM) > 0
       [M:SSL1]SERNUM      (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       [M:SSL1]SERNUMF     (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       [M:SSL1]PALNUM      (nolign-1)   =  [M:SSL1]PALNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       [M:SSL1]CTRNUM      (nolign-1)   =  [M:SSL1]CTRNUMORI   (nolign-1)
    Endif

    Gosub DES_RUB_DESTINATION From TRTSSLA
    Call INIT_SSL1(NOL)       From TRTSSLA

    Call STKFILLENTW([M:SSL1]STOFCY,"SSL1",[M:SSL1]TRSTYP(nolign-1),[M:SSL1]TRSCOD(NOL),"",[M:SSL1]VCRTYP(nolign-1),[M:SSL1]IPTDAT(NOL),NOL,[M:SSL1]NBLIG,"SRT") From STKENT
    GOUVENT = 0
    Affzo  [M:SSL1]COCHAGE(NOL)
    Affzo  [M:SSL1]ITMREF(NOL)
    Affzo [M:SSL1]PCU         (NOL)
    Affzo [M:SSL1]QTYPCU      (NOL)
    Affzo [M:SSL1]QTYSTU      (NOL)
    Affzo [M:SSL1]PCUSTUCOE   (NOL)
    If dim([M:SSL1]LOT) > 0
       Affzo [M:SSL1]LOT         (NOL)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       Affzo [M:SSL1]BPSLOT      (NOL)
    Endif
    If dim([M:SSL1]SLO) > 0
       Affzo [M:SSL1]SLO         (NOL)
       Affzo [M:SSL1]NBSLO       (NOL)
    Endif

    If dim([M:SSL1]SERNUM) > 0
       Affzo [M:SSL1]SERNUM      (NOL)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       Affzo [M:SSL1]SERNUMF     (NOL)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       Affzo [M:SSL1]PALNUM      (NOL)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       Affzo [M:SSL1]CTRNUM      (NOL)
    Endif

    Affzo [M:SSL1]STA            (NOL)
    If dim([M:SSL1]LOCTYP) > 0
       Affzo [M:SSL1]LOCTYP      (NOL)
    Endif
    If dim([M:SSL1]LOC) > 0
       Affzo [M:SSL1]LOC         (NOL)
    Endif
    If dim([M:SSL1]WRH) > 0
       Affzo [M:SSL1]WRH         (NOL)
    Endif
 Endif
# des que l on rentre en saisie detail bouton enregistre actif
GREP = "M"

GOUVENT = 16384
End


########################################
Subprog B3_NBLIG
Call INFOLOT("SSL1", nolign-1) From STKENT
End

########################################
Subprog B4_NBLIG
GOUVLOT = GOUVLOT-mod(GOUVLOT,2)    # Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT = 1                         # permet de passer le test de l'ouverture de la fenetre complément lot
End

########################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Integer LLIG
Local Integer LRET

Call CTLUOM ([M:SSL1]ITMREF(NOL),3,"", VALEUR,[M:SSL1]PCUSTUCOE(NOL), LUSCAV, LFMT, LMODIF) From STKACT
If LUSCAV <> "S"
   If LUSCAV <> "C"
      mkstat = 2
      End
   Endif
Endif

If LMODIF=2
   Actzo [M:SSL1]PCUSTUCOE(NOL)
Endif

#--- Alimentation de la quantité en US : ENTstu
[M:SSL1]QTYSTU(NOL) = [M:SSL1]QTYPCU(NOL) * [M:SSL1]PCUSTUCOE(NOL)
Call QTEARR([M:SSL1]QTYSTU(NOL),[M:SSL1]STU(NOL)) From TRTDIV
Affzo [M:SSL1]PCUSTUCOE(NOL)
Affzo [M:SSL1]QTYSTU(NOL)

End

########################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
If VALEUR<=0
   mkstat=2
Endif
End

########################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTSSLA
[M:SSL1]QTYSTU(NOL) = VALEUR * [M:SSL1]PCUSTUCOE(NOL)
Call QTEARR([M:SSL1]QTYSTU(NOL),[M:SSL1]STU(NOL)) From TRTDIV
Affzo [M:SSL1]QTYSTU(NOL)
End

########################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTSSLA
#--- Alimentation de la quantité en US : ENTstu
[M:SSL1]QTYSTU(NOL) = [M:SSL1]QTYPCU(NOL) * VALEUR
Call QTEARR([M:SSL1]QTYSTU(NOL),[M:SSL1]STU(NOL)) From TRTDIV
Affzo [M:SSL1]QTYSTU(NOL)
End


########################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
If VALEUR<>""
    Call STKCTRSLO(VALEUR, [M:SSL1]NBSLO(NOL), [M:SSL1]LOT(NOL),
&                  [M:SSL1]ITMREF(NOL),[M:SSL1]BPSLOT(NOL),[M:SSL1]GESLOT(NOL), [M:SSL1]VCRNUMORI(NOL), [M:SSL1]VCRTYPORI(NOL), [M:SSL1]VCRLINORI(NOL), 0,
&                  [M:SSL1]STOFCY, [M:SSL1]SLOF(NOL)) From STKACT
    Affzo [M:SSL1]SLOF(NOL)
Endif

End

########################################
# Appelé avant l'action SAISTOENT
# Permet de vérifier s'il faut la lancer ou non
$AAPRES_NBLIG
Gosub SET_NOL From TRTSSLA
Local Shortint WRET
If GOK < 1
        Raz GOUVENT
        [M:SSL1]COCHAGE         (NOL)    = 1
        Raz [M:SSL1]SRGPPS      (NOL)
        Raz [M:SSL1]WSTOFLG     (NOL)
        Raz [M:SSL1]PCU         (NOL)
        Raz [M:SSL1]QTYPCU      (NOL)
        Raz [M:SSL1]QTYSTU      (NOL)
        Raz [M:SSL1]PCUSTUCOE   (NOL)
        If dim([M:SSL1]LOT) > 0
           Raz [M:SSL1]LOT         (NOL)
        Endif
        If dim([M:SSL1]BPSLOT) > 0
           Raz [M:SSL1]BPSLOT      (NOL)
        Endif
        If dim([M:SSL1]SLO) > 0
           Raz [M:SSL1]SLO         (NOL)
           Raz [M:SSL1]NBSLO       (NOL)
        Endif
#                                                                                         # hcb 111781 deb
        If dim([M:SSL1]ECCVALMAJ)>0
           Raz [M:SSL1]ECCVALMAJ(NOL)
           Raz [M:SSL1]ECCVALMIN(NOL)
           Raz [M:SSL1]ECCSAIFLG(NOL)
        Endif
#                                                                                         # hcb 111781 fin
        If dim([M:SSL1]SERNUM) > 0
           Raz [M:SSL1]SERNUM      (NOL)
        Endif
        If dim([M:SSL1]SERNUMF) > 0
           Raz [M:SSL1]SERNUMF     (NOL)
        Endif
        If dim([M:SSL1]PALNUM) > 0
           Raz [M:SSL1]PALNUM      (NOL)
        Endif
        If dim([M:SSL1]CTRNUM) > 0
           Raz [M:SSL1]CTRNUM      (NOL)
        Endif

        Raz [M:SSL1]STA           (NOL)
#                                                                               # hcb x3-82988 deb
        If dim([M:SSL1]TCTRNUM) > 0
           Raz [M:SSL1]TCTRNUM    (NOL)
           Raz [M:SSL1]LPNNUM     (NOL)
           Affzo [M:SSL1]TCTRNUM  (NOL)
           Affzo [M:SSL1]LPNNUM   (NOL)
        Endif
#                                                                               # hcb x3-82988 fin
        If dim([M:SSL1]LOCTYP) > 0
           Raz [M:SSL1]LOCTYP     (NOL)
        Endif
        If dim([M:SSL1]LOC) > 0
           Raz [M:SSL1]LOC        (NOL)
        Endif
        If dim([M:SSL1]WRH) > 0
           Raz [M:SSL1]WRH        (NOL)
        Endif
        Affzo [M:SSL1]COCHAGE     (NOL)
        Affzo [M:SSL1]SRGPPS      (NOL)
        Affzo [M:SSL1]WSTOFLG     (NOL)
        Affzo [M:SSL1]PCU         (NOL)
        Affzo [M:SSL1]QTYPCU      (NOL)
        Affzo [M:SSL1]QTYSTU      (NOL)
        Affzo [M:SSL1]PCUSTUCOE   (NOL)
        If dim([M:SSL1]LOT) > 0
           Affzo [M:SSL1]LOT         (NOL)
        Endif
        If dim([M:SSL1]BPSLOT) > 0
           Affzo [M:SSL1]BPSLOT      (NOL)
        Endif
        If dim([M:SSL1]SLO) > 0
           Affzo [M:SSL1]SLO         (NOL)
           Affzo [M:SSL1]NBSLO       (NOL)
        Endif
        If dim([M:SSL1]SERNUM) > 0
           Affzo [M:SSL1]SERNUM      (NOL)
        Endif
        If dim([M:SSL1]SERNUMF) > 0
           Affzo [M:SSL1]SERNUMF     (NOL)
        Endif
        If dim([M:SSL1]PALNUM) > 0
           Affzo [M:SSL1]PALNUM      (NOL)
        Endif
        If dim([M:SSL1]CTRNUM) > 0
           Affzo [M:SSL1]CTRNUM      (NOL)
        Endif
        Affzo [M:SSL1]STA            (NOL)
        If dim([M:SSL1]LOCTYP) > 0
           Affzo [M:SSL1]LOCTYP      (NOL)
        Endif
        If dim([M:SSL1]LOC) > 0
           Affzo [M:SSL1]LOC         (NOL)
        Endif
        If dim([M:SSL1]WRH) > 0
           Affzo [M:SSL1]WRH         (NOL)
        Endif
        [M:SSL1]MODFLG               (NOL)    = 1
        Return
    Endif

If [M:SSL1]COCHAGE(NOL) = 2
   Gosub DES_RUB_DESTINATION From TRTSSLA
Endif
If [M:SSL1]COCHAGE(NOL) = 2 & [M:SSL1]WSTOFLG (NOL) = 0
   Call OUVENT([M:SSL1]STOFCY,"SSL1",[M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),"",[M:SSL1]VCRTYP(nolign-1),[M:SSL1]IPTDAT(nolign-1),nolign-1,[M:SSL1]NBLIG,"SRT","",WRET) From STKENT
   [M:SSL1]MODFLG            (NOL)    = 2
   Affzo [M:SSL1]ITMREF(NOL)
Else
   GOUVENT = 0
   GOUVLOT = 0
Endif
Return

########################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR
Gosub SET_NOL From TRTSSLA

Call STKCTRNBSLO(VALEUR, [M:SSL1]PCU(NOL), [M:SSL1]QTYPCU(NOL)) From STKACT
End

########################################
Subprog APRES_NBLIG
Gosub SET_NOL From TRTSSLA
# mise à jour du flag STAFLG
If [M:SSL1]STOCOU(NOL) <> 0
   Call MAJ_SRG_STAFLG(NOL,[M:SSL1]COCHAGE(NOL))  From TRTSSLA
Endif

End

########################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

Local Shortint LRET
Local Char     LSLO
#si lotori renseigné lors de l entrée à quai alors modification interdite
If [M:SSL1]LOTORI(NOL) <> ""
   If [M:SSL1]LOTORI(NOL) <> VALEUR
       GMESSAGE= mess(60,184,1)
       mkstat=2
   Endif
Endif

End

########################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If [M:SSL1]WSTOFLG(NOL)=0 & [M:SSL1]COCHAGE(NOL)=2
  pcolor=GCOUL(1) : # Rouge
Else
  pcolor=GCOUL(0) : # Noir
Endif
End

########################################
Subprog C_LOCTYP(VALEUR)
Variable Char    VALEUR()
If len(VALEUR) <> 0
    Read [TLO]TLO0=[M:SSL1]STOFCY;VALEUR
    If fstat
        mkstat = 2
    Else
      If [M:SSL1]SRGWAIFLG <> 2           # hcb 50197
# type quai non autorisé
          If [F:TLO]LOCCAT = 2
             GMESSAGE = mess(854,196,1)
             mkstat = 2
             End
          Endif
      Endif
#                                                                               # hcb x3-82988 deb
      If [F:ITF]LPNMGTCOD = 2 &  dim([M:SSL1]LPNNUM) > 0 & [M:SSL1]LPNNUM(nolign-1) <> ""
         If find([F:TLO]LOCCAT,3,4)
            GMESSAGE = mess(241,184,1)  # Emplacement non autorise
            mkstat = 2
            End
         Endif
      Endif
#                                                                               # hcb x3-82988 fin
    Endif
Endif
#--- Bug 72649
If [M:SSL1]LOCTYP(nolign-1)<>VALEUR
   Call RAZLOC([M:SSL1]LOC(nolign-1),[M:SSL1]WLOCSEQ(nolign-1)) From STKACT
Endif
#---
End

########################################
Subprog B5_NBLIG
Gosub SET_NOL From TRTSSLA
Local Char NUM
GCONSULT = 2
Case [M:SSL1]VCRTYP(NOL)
When 6        # reception
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("PTH",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 09      # inventaire
      Call OBJET("SNL",[M:SSL1]VCRNUM(NOL),[M:SSL1]VCRNUMORI(NOL)) From GOBJET
When 13      # retour client
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("SRH",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 15     # declaration de production
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("MTK",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 18     # avoir vente
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("SIH",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 19       # entrée diverse
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("SMR",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 28       # controle qualite
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("STQ",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
When 35       # modification des lots
      NUM = num$([M:SSL1]VCRTYP(NOL))
      Call OBJET("SLM",[M:SSL1]VCRNUM(NOL),NUM) From GOBJET
Endcase
[M:ENTW]WZONPCU = "PCU"            # hcb 70295
[M:ENTW]WZONQUC = "QTYPCU"         # hcb 70295
[M:ENTW]WZONCCS = "PCUSTUCOE"      # hcb 70295
[M:ENTW]WZONQUS = "QTYSTU"         # hcb 70295
[M:ENTW]WZONSTOUPD = ""            # hcb 70295
GCONSULT = 0
End


########################################
Subprog B6_NBLIG
Gosub SET_NOL From TRTSSLA

Local Integer LLIG
Local Integer LRET

If [M:SSL1]COCHAGE(NOL) <> 2

   [M:SSL1]COCHAGE(NOL) = 2
    LLIG = NOL
    LRET = 0
    Default Mask [SSL1]

    Call INIZONENT([M:SSL1]ITMREF(NOL),"SSL1",[M:SSL1]STOFCY,"",0,"",(NOL),
&                  [M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),[M:SSL1]VCRNUM(NOL),
&                  1,0) From STKECR

#RUBRIQUE destination par défaut
    [M:SSL1]PCU         (nolign-1)   = [M:SSL1]PCUORI      (nolign-1)
    [M:SSL1]QTYPCU      (nolign-1)   = [M:SSL1]QTYPCUORI   (nolign-1)
    [M:SSL1]QTYSTU      (nolign-1)   = [M:SSL1]QTYSTUORI   (nolign-1)
    [M:SSL1]PCUSTUCOE   (nolign-1)   = [M:SSL1]PCUSTUCOEO  (nolign-1)
    If dim([M:SSL1]LOT) > 0
       [M:SSL1]LOT         (nolign-1)   = [M:SSL1]LOTORI      (nolign-1)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       [M:SSL1]BPSLOT      (nolign-1)   = [M:SSL1]BPSLOTORI   (nolign-1)
    Endif
    If dim([M:SSL1]SLO) > 0
       [M:SSL1]SLO         (nolign-1)   = [M:SSL1]SLOORI      (nolign-1)
       If [M:SSL1]SLO      (nolign-1) <> ""
          [M:SSL1]NBSLO    (nolign-1)   = 1
       Endif
    Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJ(nolign-1) = [M:SSL1]ECCVALMAJORI(nolign-1)
      [M:SSL1]ECCVALMIN(nolign-1) = [M:SSL1]ECCVALMINORI(nolign-1)
      [M:SSL1]ECCSAIFLG(nolign-1) = [M:SSL1]ECCSAIFLGORI(nolign-1)
   Endif
#                                                                                         # hcb 111781 fin
    If dim([M:SSL1]SERNUM) > 0
       [M:SSL1]SERNUM      (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       [M:SSL1]SERNUMF     (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       [M:SSL1]PALNUM      (nolign-1)   =  [M:SSL1]PALNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       [M:SSL1]CTRNUM      (nolign-1)   =  [M:SSL1]CTRNUMORI   (nolign-1)
    Endif

    Call INIT_SSL1(NOL)       From TRTSSLA
    Call STKFILLENTW([M:SSL1]STOFCY,"SSL1",[M:SSL1]TRSTYP(nolign-1),[M:SSL1]TRSCOD(NOL),"",[M:SSL1]VCRTYP(nolign-1),[M:SSL1]IPTDAT(NOL),NOL,[M:SSL1]NBLIG,"SRT") From STKENT
    GOUVENT = 0
    GOUVLOT = 0

Else

   [M:SSL1]COCHAGE(NOL) = 1
    If [M:SSL1]SRGPPS_AV(NOL) = ""
       Raz [M:SSL1]SRGPPS(NOL)
    Endif
    Raz [M:SSL1]WSTOFLG     (NOL)
    Raz [M:SSL1]PCU         (NOL)
    Raz [M:SSL1]QTYPCU      (NOL)
    Raz [M:SSL1]QTYSTU      (NOL)
    Raz [M:SSL1]PCUSTUCOE   (NOL)
    If dim([M:SSL1]LOT) > 0
       Raz [M:SSL1]LOT         (NOL)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       Raz [M:SSL1]BPSLOT      (NOL)
    Endif
    If dim([M:SSL1]SLO) > 0
       Raz [M:SSL1]SLO         (NOL)
       Raz [M:SSL1]NBSLO       (NOL)
    Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      Raz [M:SSL1]ECCVALMAJ(NOL)
      Raz [M:SSL1]ECCVALMIN(NOL)
      Raz [M:SSL1]ECCSAIFLG(NOL)
   Endif
#                                                                                         # hcb 111781 fin
    If dim([M:SSL1]SERNUM) > 0
       Raz [M:SSL1]SERNUM      (NOL)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       Raz [M:SSL1]SERNUMF     (NOL)
    Endif
    Raz [M:SSL1]STA         (NOL)
    If dim([M:SSL1]PALNUM) > 0
       Raz [M:SSL1]PALNUM      (NOL)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       Raz [M:SSL1]CTRNUM      (NOL)
    Endif
#                                                                               # hcb x3-82988 deb
    If dim([M:SSL1]TCTRNUM) > 0
       Raz [M:SSL1]TCTRNUM    (NOL)
       Raz [M:SSL1]LPNNUM     (NOL)
       Affzo [M:SSL1]TCTRNUM  (NOL)
       Affzo [M:SSL1]LPNNUM   (NOL)
    Endif
#                                                                               # hcb x3-82988 fin
    If dim([M:SSL1]LOCTYP) > 0
       Raz [M:SSL1]LOCTYP      (NOL)
    Endif
    If dim([M:SSL1]LOC) > 0
       Raz [M:SSL1]LOC         (NOL)
    Endif
    If dim([M:SSL1]WRH) > 0
       Raz [M:SSL1]WRH         (NOL)
    Endif
    Gosub DES_RUB_DESTINATION From TRTSSLA
Endif

Affzo [M:SSL1]25

End

Subprog AS_LOCTYP(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If [F:ITF]LOCMGTCOD > 1
# si  type quai mise à blanc des zones type et emplacement
   If [M:SSL1]LOCTYP (NOL) <> ""
       Read [TLO]TLO0=[M:SSL1]STOFCY;[M:SSL1]LOCTYP (NOL)
       If fstat
          Raz [F:TLO]
       Else
# type quai non autorisé
          If [F:TLO]LOCCAT = 2
# si code trs on met à blanc pour l aide sur type emplacement
             Raz [M:SSL1]LOCTYP (NOL)
             Raz [M:SSL1]LOC    (NOL)
             If [M:SSL1]TRSCOD  (NOL) <> ""
                [M:SSL1]TRSCOD  (NOL) = ""
             Endif

          Endif
       Endif
   Endif
Endif

End

Subprog AM_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA

If [M:SSL1]CREFLG(NOL) <> 0 & (VALEUR <> [M:SSL1]SRGPPS_AV(NOL) & [M:SSL1]SRGPPS(NOL) <> "")
   GMESSAGE= mess(77,184,1)       # Vous ne pouvez pas modifier directement le numéro
   mkstat=2
   End
Endif

[M:SSL1]MODFLG(NOL)=2

#si compteur manuel on peut saisir une liste inexistante
If GSTKCPTMAN(15) = 2
   End
Endif
If  [M:SSL1]SRGPPSSTR = VALEUR
    End
Endif
If  [M:SSL1]SRGPPSEND = VALEUR
    End
Endif
Local Integer WEXI
WEXI = 0
WEXI = find ( VALEUR,[M:SSL1]SRGPPS(0..[M:SSL1]NBLIG))
If WEXI <> 0
   End
Endif
#Compteur manuel , le numero de liste doit exister dans le tableau
GMESSAGE= mess(55,184,1)
mkstat=2

End

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
#                                                                               # hcb x3-82988 deb
 If [F:ITF]LPNMGTCOD = 2 & dim([M:SSL1]LPNNUM) > 0 & [M:SSL1]LPNNUM(nolign-1) <> ""
   If find([F:STC]LOCCAT,3,4)
      GMESSAGE = mess(241,184,1)  # Emplacement non autorise
      mkstat = 2
      End
   Endif
Endif
#                                                                               # hcb x3-82988 fin
Affzo [M:SSL1]LOCTYP(NOL)

End


