Subprog AM_WRHSTR(VALEUR)
Variable Char    VALEUR()
If [M:SSL1]WRHEND = ""       : [M:SSL1]WRHEND = VALEUR : Affzo [M:SSL1]WRHEND : Endif
If [M:SSL1]WRHEND < VALEUR   : [M:SSL1]WRHEND = VALEUR : Affzo [M:SSL1]WRHEND : Endif

End

Subprog C_WRHEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:SSL1]WRHSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

Subprog C_WRHORI(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
If [M:SSL1]COCHAGE(NOL) <> 2
   Call CTRCLESRG("SSL1",6,[M:SSL1]VCRTYP(NOL),[M:SSL1]VCRNUM(NOL),[M:SSL1]VCRLIN(NOL),[M:SSL1]ITMREF(NOL),"",VALEUR) From TRTSSLA
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif
End

#--- Bug 60553
Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:SSL1]WRH(nolign-1)<>""
   Raz [M:SSL1]LOC(nolign-1)
Endif
End

Subprog C_WRHE(VALEUR)
Variable Char    VALEUR()
# si mono depot et gestion depot alors un dépot doit etre saisie
If [M:SSL1]WRHOBY = 2 & [M:SSL1]WRHGES = 2 & VALEUR = ""
   GMESSAGE= mess(348,184,1)
   mkstat=2
Endif
End


