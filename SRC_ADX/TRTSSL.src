Subprog C_LPNNUM(VALEUR)
Variable Char    VALEUR()

# dans le cas d'un plan de rangement il ne faut pas que l emplacement soit de type quai

If [F:LPN]LOCTYP <> ""
   Read [TLO]TLO0=[M:SSL1]STOFCY;[F:LPN]LOCTYP
   If fstat
      Raz [F:LPN]
   Else
# type quai non autorisé
      If [F:TLO]LOCCAT = 2
         GMESSAGE = mess(854,196,1)
      mkstat = 2
      End
      Endif
   Endif
Endif
End


