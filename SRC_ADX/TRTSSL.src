End


########################################
Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR
Local Integer LLIG
Local Integer LRET
Local Integer WOK
GOK = 1
WOK = 0
Gosub SET_NOL From TRTSSLA

[M:SSL1]COCHAGE  (nolign-1) = VALEUR

If VALEUR = 1
# pour ne pas recuperer les infos dans le STOENTW
    Raz [M:SSL1]WSTOSEQ     (NOL)
    Raz [M:SSL1]WSTOFLG     (NOL)
    If [M:SSL1]SRGPPS_AV(NOL) = ""
       [M:SSL1]SRGPPS(NOL)    = ""
       Raz [M:SSL1]SRGPPS      (NOL)
       Raz [M:SSL1]PCU         (NOL)
       Raz [M:SSL1]QTYPCU      (NOL)
       Raz [M:SSL1]QTYSTU      (NOL)
       Raz [M:SSL1]PCUSTUCOE   (NOL)
       Affzo [M:SSL1]SRGPPS(NOL)
       Raz   [M:SSL1]WSTOFLG(NOL)
       [M:SSL1]MODFLG(NOL)    = 1
    Endif
    If dim([M:SSL1]LOT) > 0
       Raz [M:SSL1]LOT         (NOL)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       Raz [M:SSL1]BPSLOT      (NOL)
    Endif
    If dim([M:SSL1]SLO) > 0
       Raz [M:SSL1]SLO         (NOL)
       Raz [M:SSL1]NBSLO       (NOL)
    Endif
#                                                                                         # hcb 111781 deb
    If dim([M:SSL1]ECCVALMAJ)>0
       Raz [M:SSL1]ECCVALMAJ(NOL)
       Raz [M:SSL1]ECCVALMIN(NOL)
       Raz [M:SSL1]ECCSAIFLG(NOL)
    Endif
#                                                                                         # hcb 111781 fin

    If dim([M:SSL1]SERNUM) > 0
       Raz [M:SSL1]SERNUM      (NOL)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       Raz [M:SSL1]SERNUMF     (NOL)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       Raz [M:SSL1]PALNUM      (NOL)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       Raz [M:SSL1]CTRNUM      (NOL)
    Endif

    Raz [M:SSL1]STA            (NOL)
#                                                                               # hcb x3-82988 deb
    If dim([M:SSL1]TCTRNUM) > 0
       Raz [M:SSL1]TCTRNUM     (NOL)
       Raz [M:SSL1]LPNNUM      (NOL)
       Affzo [M:SSL1]TCTRNUM   (NOL)
       Affzo [M:SSL1]LPNNUM    (NOL)
    Endif
#                                                                               # hcb x3-82988 fin
    If dim([M:SSL1]LOCTYP) > 0
       Raz [M:SSL1]LOCTYP      (NOL)
    Endif
    If dim([M:SSL1]LOC) > 0
       Raz [M:SSL1]LOC         (NOL)
    Endif
    If dim([M:SSL1]WRH) > 0
       Raz [M:SSL1]WRH         (NOL)
    Endif
    Affzo [M:SSL1]SRGPPS       (NOL)
    Affzo [M:SSL1]WSTOFLG      (NOL)
    Affzo [M:SSL1]PCU          (NOL)
    Affzo [M:SSL1]QTYPCU       (NOL)
    Affzo [M:SSL1]QTYSTU       (NOL)
    Affzo [M:SSL1]PCUSTUCOE    (NOL)
    If dim([M:SSL1]LOT) > 0
       Affzo [M:SSL1]LOT       (NOL)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       Affzo [M:SSL1]BPSLOT      (NOL)
    Endif
    If dim([M:SSL1]SLO) > 0
       Affzo [M:SSL1]SLO         (NOL)
       Affzo [M:SSL1]NBSLO       (NOL)
    Endif
    If dim([M:SSL1]SERNUM) > 0
       Affzo [M:SSL1]SERNUM      (NOL)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       Affzo [M:SSL1]SERNUMF     (NOL)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       Affzo [M:SSL1]PALNUM      (NOL)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       Affzo [M:SSL1]CTRNUM      (NOL)
    Endif
    Affzo [M:SSL1]STA            (NOL)
    If dim([M:SSL1]LOCTYP) > 0
       Affzo [M:SSL1]LOCTYP      (NOL)
    Endif
    If dim([M:SSL1]LOC) > 0
       Affzo [M:SSL1]LOC         (NOL)
    Endif
    If dim([M:SSL1]WRH) > 0
       Affzo [M:SSL1]WRH         (NOL)
    Endif
Else
    LLIG = NOL
    LRET = 0
    Default Mask [SSL1]
    Call INIZONENT([M:SSL1]ITMREF(NOL),"SSL1",[M:SSL1]STOFCY,"",0,"",(NOL),[M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),[M:SSL1]VCRNUM(NOL),1,0) From STKECR
#RUBRIQUE destination par défaut
    [M:SSL1]PCU         (nolign-1)   = [M:SSL1]PCUORI      (nolign-1)
    [M:SSL1]QTYPCU      (nolign-1)   = [M:SSL1]QTYPCUORI   (nolign-1)
    [M:SSL1]QTYSTU      (nolign-1)   = [M:SSL1]QTYSTUORI   (nolign-1)
    [M:SSL1]PCUSTUCOE   (nolign-1)   = [M:SSL1]PCUSTUCOEO  (nolign-1)
    If dim([M:SSL1]LOT) > 0
       [M:SSL1]LOT         (nolign-1)   = [M:SSL1]LOTORI      (nolign-1)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       [M:SSL1]BPSLOT      (nolign-1)   = [M:SSL1]BPSLOTORI   (nolign-1)
    Endif
    If dim([M:SSL1]SLO) > 0
       [M:SSL1]SLO         (nolign-1)   = [M:SSL1]SLOORI      (nolign-1)
       If [M:SSL1]SLO      (nolign-1) <> ""
          [M:SSL1]NBSLO    (nolign-1)   = 1
       Endif
    Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJ(nolign-1) = [M:SSL1]ECCVALMAJORI(nolign-1)
      [M:SSL1]ECCVALMIN(nolign-1) = [M:SSL1]ECCVALMINORI(nolign-1)
      [M:SSL1]ECCSAIFLG(nolign-1) = [M:SSL1]ECCSAIFLGORI(nolign-1)
   Endif
#                                                                                         # hcb 111781 fin

    If dim([M:SSL1]SERNUM) > 0
       [M:SSL1]SERNUM      (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       [M:SSL1]SERNUMF     (nolign-1)   =  [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]PALNUM) > 0                                               # hcb 27200
       [M:SSL1]PALNUM      (nolign-1)   =  [M:SSL1]PALNUMORI   (nolign-1)    # hcb 27200
    Endif                                                                    # hcb 27200
    If dim([M:SSL1]CTRNUM) > 0                                               # hcb 27200
       [M:SSL1]CTRNUM      (nolign-1)   =  [M:SSL1]CTRNUMORI   (nolign-1)    # hcb 27200
    Endif                                                                    # hcb 27200
    Gosub ACT_RUB_DESTINATION From TRTSSLA
    Call INIT_SSL1(NOL)       From TRTSSLA

    [M:SSL1]COCHAGE         (NOL)  = 2
    [M:SSL1]MODFLG          (NOL) = 2
    GREP = "M"
Endif
End

