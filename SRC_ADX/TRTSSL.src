Subprog B4_SRGPPS(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL From TRTSSLA
VALEUR = ""
[M:SSL1]SRGPPS(NOL) = ""
Affzo  [M:SSL1]SRGPPS(NOL)
[M:SSL1]MODFLG(NOL)=2

End

