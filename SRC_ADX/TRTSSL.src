#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du masque SSL1
$ACTION

#---------------------------------#
Case ACTION
 When "FIN_TABLE"     : Gosub FINTABLE     From TRTSSLA
 When "CONTROLE"      : Gosub CONTROLE     From TRTSSLA
 When "SEL_TABLE"     : Gosub SELTABLE     From TRTSSLA
 When "SEL_LISTE"     : Gosub SELLISTE     From TRTSSLA
 When "FIN_LISTE"     : Gosub FINLISTE     From TRTSSLA
 When "VERF_TABLE"    : Gosub VERFTABLE    From TRTSSLA
 When "INIT"          : Gosub INIT         From TRTSSLA
 When "TITRE"         : Gosub TIT_TRT      From TRTSSLA
 When "OUVRE_BOITE"   : Gosub OUVREBOITE   From TRTSSLA
 When "OUVRE"         : Gosub OUVRE        From TRTSSLA
 When "DEBUT"         : Gosub DEBUT        From TRTSSLA
 When "ABA"           : Gosub ABANDON      From TRTSSLA
 When "END"           : Gosub ACTEND       From TRTSSLA
 When "FIN"           : Gosub FIN          From TRTSSLA
 When "FINSAI"        : Gosub FINSAI       From TRTSSLA
 When "OK"            : Gosub OK           From TRTSSLA
 When "BOUTON"        : Gosub BOUTON       From TRTSSLA
 When "SETBOUT"       : Gosub SETBOUT      From TRTSSLA
 When "AP_CHOIX"      : Gosub APCHOIX      From TRTSSLA
 When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG From TRTSSL
 When "APRES_MODIF"   : Gosub APRES_MODIF  From TRTSSLA
 When "AVANT_LIS"     : Gosub AVANT_LIS    From TRTSSLA

 When Default
Endcase
Return

$SEL_TABLE
Return

########################################
# Actions Champs
########################################

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If GFCY <> VALEUR
    GFCY = VALEUR
Endif
GHCBFCY = VALEUR
# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT From TRTSSLA

End
########################################
Subprog AM_SRGPPSSTR(VALEUR)
Variable Char    VALEUR()

If VALEUR = ""
   Raz   [M:SSL1]LSTWIOFLG
   Grizo [M:SSL1]LSTWIOFLG
   Actzo [M:SSL1]10, 15
   If dim([M:SSL1]WRHSTR) > 0
      If [M:SSL1]WRHGES <> 2
         Diszo [M:SSL1]WRHSTR
         Diszo [M:SSL1]WRHEND
      Endif
   Endif
Else
   If [M:SSL1]NBLIG <> 0
      Gosub DEBUT_SAISSL From TRTSSLA
      [M:SSL1]SRGPPSSTR = VALEUR
      Affzo  [M:SSL1]SRGPPSSTR
   Else
      [M:SSL1]SRGPPSSTR = VALEUR
   Endif
   Actzo [M:SSL1]LSTWIOFLG
Endif
End

########################################
Subprog C_SRGPPSSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CTRPPSSRG("SSL1",VALEUR) From TRTSSLA
Endif
End

########################################
Subprog C_LSTWIOFLG(VALEUR)
Variable Integer VALEUR
If [M:SSL1]SRGPPSSTR <> ""
   If VALEUR = 1
      Raz [M:SSL1]FLGDAT
      Raz [M:SSL1]STRDAT
      Raz [M:SSL1]ENDDAT
      Raz [M:SSL1]VCRTYPC1
      Raz [M:SSL1]VCRTYPC
      Raz [M:SSL1]VCRNUMSTR1
      Raz [M:SSL1]VCRNUMSTR
      Raz [M:SSL1]VCRNUMEND1
      Raz [M:SSL1]VCRNUMEND
      If  dim([M:SSL1]WRHE)> 0
          Raz [M:SSL1]WRHE
      Endif
      Raz [M:SSL1]ITMREFSTR
      Raz [M:SSL1]ITMREFEND
      Raz [M:SSL1]LOCSTR
      Raz [M:SSL1]LOCEND
      Raz [M:SSL1]STASTR
      Raz [M:SSL1]STAEND
      [M:SSL1]VCRTYPC(1) = 0
      [M:SSL1]VCRTYPC(2) = 0
      [M:SSL1]VCRTYPC(3) = 0
      [M:SSL1]VCRTYPC(4) = 0
      [M:SSL1]VCRTYPC(5) = 0
      Grizo [M:SSL1]10, 15
   Else
      Actzo [M:SSL1]10, 15
      If dim([M:SSL1]WRHSTR) > 0
         If [M:SSL1]WRHGES <> 2
            Diszo [M:SSL1]WRHSTR
            Diszo [M:SSL1]WRHEND
         Endif
      Endif
   Endif
Endif

End

########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If [M:SSL1]ENDDAT = [0/0/0]  : [M:SSL1]ENDDAT = VALEUR : Affzo [M:SSL1]ENDDAT : Endif
If [M:SSL1]ENDDAT < VALEUR   : [M:SSL1]ENDDAT = VALEUR : Affzo [M:SSL1]ENDDAT : Endif
End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:SSL1]STRDAT : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_VCRTYPC1(VALEUR)
Variable Integer VALEUR
Gosub CHARGETYP_BLOC20 From TRTSSLA
End

########################################
Subprog AM_VCRNUMSTR1(VALEUR)
Variable Char    VALEUR()
If [M:SSL1]VCRNUMEND1 = ""     : [M:SSL1]VCRNUMEND1 = VALEUR : Affzo [M:SSL1]VCRNUMEND1 : Endif
If [M:SSL1]VCRNUMEND1< VALEUR  : [M:SSL1]VCRNUMEND1 = VALEUR : Affzo [M:SSL1]VCRNUMEND1 : Endif
Gosub CHARGESTR_BLOC20 From TRTSSLA
End


########################################
Subprog AM_VCRNUMEND1(VALEUR)
Variable Char    VALEUR()
Gosub CHARGEEND_BLOC20 From TRTSSLA
End

########################################
Subprog C_VCRNUMEND1(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M:SSL1]VCRNUMSTR1 : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif

End


########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End


########################################
Subprog AM_LOCSTR(VALEUR)
