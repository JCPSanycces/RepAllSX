#<AdxTL>@(#)133.0.0.0 $Revision$
######################################################################
# FUNSPCSEL : Traitement de saisie des tarifs de vente               #
#             Selection du tarif pour appel à saisie des tarifs      # 
######################################################################
Onerrgo ERREUR From CONTROLE  
  
# sauvegarde environnement
Call SAVBOUT From GESECRAN
SAVGOBJET=GOBJET
SAVPROG=GPROGRAMME
GOBJET=1
GPROGRAMME="FUNSPCSEL"

If clalev ([F:SPC])=0 : Local File SPRICCONF [SPC] : Endif
# Si on a passé un code tarif en paramètre
If GBIDC2 <> ""
   Read [SPC]SPC0=GBIDC2
   If !fstat 
      GFLTPLI=GBIDC2
      Call OBJET ("SPL",GBIDC3,GFLTPLI) From GOBJET 
      Goto FIN
   Endif
Endif

Local Integer ETABOU (1..GNBBOU)
If clalev([M:SPCS])=0 : Local Mask SPCSEL [SPCS] : Raz [M:SPCS] : Endif
Local Dlgbox Mask [SPCS]
& Button mess(64,123,1),mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(103,195,1)
& As [SPCS]
$DEBUT
Local Integer REPONSE
nolign = 0
For [SPC]
 nolign += 1
 [M] = [F:SPC]
 Next
[M]NBTAR = nolign
pcolor = GCOUL(0)
Boxact [SPCS]
Affzo
ETABOU(GVALI)=1
ETABOU(GABAN)=1
Call SETBOUT(ETABOU) From GESECRAN
$SELECTION  
Boxinp [SPCS] Using REPONSE
Raz GFLTPLI
Case REPONSE 
  When GSTAOK
       Raz GFLTPLI
       GFLTPLI=[M]PLI(nolign-1) 
       Call OBJET ("SPL",GBIDC3,GFLTPLI) From GOBJET 
       Goto SELECTION  
  When GSTAESC, GSTAFIN 
       Goto FIN 
  When Default Goto SELECTION  
Endcase 

$FIN
# restitution environnement
GOBJET=SAVGOBJET
GPROGRAMME=SAVPROG
Call RESTBOUT From GESECRAN
Call IMPSCR From ATRTX3
End
