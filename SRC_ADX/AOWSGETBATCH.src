#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Get the batch requete
#*
#* @param I_TACHE  : Batch tache = IMPORT or EXPORT
#* @param I_REQNUM : No batch requete
#* @param I_GETTRA : Get the log of the batch = YES or NO
#* @param O_STAREQ : status of this requete
#*                          1 - Standby
#*                          2 - In progress
#*                          3 - Finished
#*                          4 - Held
#*                          5 - Kill
#*                          6 - Canceled
#*                          7 - Error
#*                          8 - Overdue
#*                          9 - Warning
#* @param O_MESREQ  : Message of the requete status
#* @param O_FILE    : For the batch request EXPORT, the export file
#* @param O_FILETRA : Log of the requete if I_GETTRA= YES
#* @param O_STATUS  : Status of Web service : 0=OK else >0 ERROR
#* @param O_MESSA   : Error if status>0
#*!
Subprog GET(I_TACHE, I_REQNUM,I_GETTRA,O_STAREQ,O_MESREQ,O_FILE,O_FILETRA,O_STATUS,O_MESSA)
Value     Char      I_TACHE()
Value     Integer   I_REQNUM
Value     Char      I_GETTRA()
Variable  Integer   O_STAREQ
Variable  Char      O_MESREQ()
Variable  Clbfile   O_FILE()
Variable  Clbfile   O_FILETRA()
Variable  Integer   O_STATUS
Variable  Char      O_MESSA()

Local Char YEND(3) : YEND="END"
Local Char S_TMP(255)
Local Integer EXIST,I,J,K
Local Clbfile LEC(6)
Local Char FICTRARQT(GDIMFIC)
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif

Raz O_STAREQ,O_FILE,O_FILETRA, O_STATUS,O_MESREQ,O_MESSA

If find(I_TACHE,"IMPORT","EXPORT")=0
 O_STATUS = 1 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_TACHE","IMPORT","EXPORT") : End : #"The name of the batch is only IMPORT or EXPORT" : End
Endif

If find(I_GETTRA,"YES","NO")=0
 O_STATUS = 2 : O_MESSA=func AFNC.MES3(mess(183,141,1),"I_GETTRA","YES","NO") : End : #"The value of I_GETTRA is YES or NO" : End
Endif
Read [ABR]NUMREQ = I_REQNUM
If fstat
 O_STATUS = 3 : O_MESSA=mess(188,141,1) : End : #"Number of the batch requete is not found" : End
Endif

If [F:ABR]TACHE<>I_TACHE
 O_STATUS = 4 : O_MESSA=mess(189,141,1) : End : #"Number requete doesn't correspondent with the batch tache" : End
Endif

O_STAREQ = [F:ABR]FLAG
O_MESREQ = mess(O_STAREQ,21,1)
If I_GETTRA="YES"
 FICTRARQT = func SERVSYS.GET_FILE_RQT(format$("N0:8#",I_REQNUM),"tra") : #109897  # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
 If FICTRARQT=""
    O_STATUS=5
    O_MESSA=mess(188,141,1)
    End
 Endif
 I= instr(1,[L]FICTRARQT,"@")
 If I>0
  FICTRARQT = right$([L]FICTRARQT,I+1)
 Endif
Call EXISTE(FICTRARQT,[L]EXIST) From ORDSYS
 If [L]EXIST=1
  Openi FICTRARQT Using [TRA]
  Iomode adxifs "" Using [TRA]
  Iomode adxirs chr$(10) Using [TRA]
  Iomode adxium GUTF8 Using [TRA]
  Raz O_FILETRA
  fstat=0
  While fstat=0
   Rdseq LEC Using [TRA]
   If fstat=0
    Append O_FILETRA,LEC
   Endif
  Wend
  Openi Using [TRA]
  Append O_FILETRA,"END"
  Endif

 If O_FILETRA<>"" & right$(O_FILETRA,len(O_FILETRA)-2)<>[L]YEND
  O_STATUS = 20 : O_MESSA=func AFNC.MES2(mess(187,141,1),"I_FILE",YEND) : End : #"the value of O_FILE should finished by the word"-YEND : End
 Endif
Endif

If I_TACHE="EXPORT"
  Gosub BATCH_EXPORT
  Gosub TRT_FILE_TO_CLOB From AOWSEXPORT
Endif
End

$BATCH_EXPORT

Local Char    ABRECR(GLONABR)(0..15)
ABRECR(0)=""
ABRECR(1)="DIA"
Local Mask EXPOBJ [DIA]
Read [ABR]NUMREQ = I_REQNUM

Default File [F:ABL]
Filter [ABL] Where NUMREQ = I_REQNUM
Call GETPAR(ABRECR) From REQUETES
Local Char     FIL1FULL(GDIMFIC) : # Fullname of the csv file : ex c:/../tmp/ol.csv
Local Integer NBLIG1,NBLIG2, ZFSTAT

Local Char I_RECORDSEP(1) : [L]I_RECORDSEP = "|"


Local Clbfile LEC(6)

[L]FIL1FULL = [M:DIA]NOMEXP

J=1
I=0
Repeat
 K=I
 I= instr(J,[L]FIL1FULL,".")
 J=I+1
Until I=0
If K>0
 S_TMP= left$([L]FIL1FULL,K-1)
Endif
If S_TMP<>""
 J=1
 I=0
 Repeat
  K=I
  I= instr(J,[L]S_TMP,"_")
  J=I+1
 Until I=0
 If K>0
  [L]I_RECORDSEP = chr$(val(right$([L]FIL1FULL,K+1)))
 Endif
Endif
If clalev([F:AOE])=0 : Local File AOBJEXT [AOE] : Endif
 Read [AOE]AOE0 = [M:DIA]MODELE
 If fstat : Return : Endif
 Local Char     SEPENR(5)
 SEPENR = func AOWSIMPORT.GET_SEPENR([F:AOE]SEPREC)

Return

