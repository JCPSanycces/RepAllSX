#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
#
# Library of Legislation procedures for Organisation screens
#
# Window  : OORG
# Screens : ORG0, ORG1, ORG3
#
############################################################


########################################
#23/04/12 - DKA - Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()

  #Call HIDE_ACTIVITYFIELDS From WORGHIDE
  #Call SHOW_LEGACTCALLS From WORGSHOW
  Case GCURLEG
   When "FRA"
     If clalev([F:AMKW])=0 : Local File AMSK [AMKW] : Endif
     Local Integer WNUMLIBEL
     Read [F:AMKW]CODMSK = "ORG3"
     # Show Tab title
     Chgtfd [M:ORG3] With func AFNC.TEXTE(45490)    #DUCS
     # Show Block titles
     WNUMLIBEL=[F:AMKW]TITBLOC(0)
     Chgtbk [M:ORG3]5  With func AFNC.TEXTE(WNUMLIBEL)   #Identification
     WNUMLIBEL=[F:AMKW]TITBLOC(1)
     Chgtbk [M:ORG3]15 With func AFNC.TEXTE(WNUMLIBEL)  #Type
     WNUMLIBEL=[F:AMKW]TITBLOC(2)
     Chgtbk [M:ORG3]20 With func AFNC.TEXTE(WNUMLIBEL)  #Urssaf
     WNUMLIBEL=[F:AMKW]TITBLOC(3)
     Chgtbk [M:ORG3]25 With func AFNC.TEXTE(WNUMLIBEL)  #Pôle emploi
     WNUMLIBEL=[F:AMKW]TITBLOC(4)
     Chgtbk [M:ORG3]30 With func AFNC.TEXTE(WNUMLIBEL)  #IRC/IP
     WNUMLIBEL=[F:AMKW]TITBLOC(5)
     Chgtbk [M:ORG3]35 With func AFNC.TEXTE(WNUMLIBEL)   #Grouping
     #DBA Agilo Task 1129
     Read [F:AMKW]CODMSK = "ORG1"
     WNUMLIBEL=[F:AMKW]TITBLOC(1)
     Chgtbk [M:ORG1]10 With func AFNC.TEXTE(WNUMLIBEL)
     Chgfmt [M:ORG1]DEP      With "K:3X"
     Chgfmt [M:ORG1]MEW      With "K:3X"
     ##ORG3 - Show all of tab
     Chgfmt [M:ORG3]KEYORG       With "LA:10371"    #Type
     Chgfmt [M:ORG3]LIBKEYORG    With "K:35X"       #Other
     Chgfmt [M:ORG3]TYPIRC       With "LA:10386"    #Type
     Chgfmt [M:ORG3]FLGORGCMP      With "LA:1"      #Complementary organization
     Chgfmt [M:ORG3]CODSSC       With "K:4X"        #Code
     Chgfmt [M:ORG3]TYPFRM0      With "K:20X"       #Slip(1)
     Chgfmt [M:ORG3]DUECOD       With "K:20X"       #DUE Code
     Chgfmt [M:ORG3]TYPASS       With "LA:10325"    #
     Chgfmt [M:ORG3]NUMASS       With "K:2X"        #Number
     Chgfmt [M:ORG3]TYPFRM1      With "K:20X"       #Slip(2)
     Chgfmt [M:ORG3]NUMDCS       With "K:20X"       #Organisation
     Chgfmt [M:ORG3]TYPFRM2      With "K:20X"       #Slip(3)
     #Chgfmt [M:ORG3]NBRLG        With "N:4X"        #Slip(3)
     #Chgfmt [M:ORG3]GRPORG       With "K:10X"       #Organisn
  #MASHI - 2017-05-09 - JIRA X3-21955 - START
     If dim([M:ORG1]BID)>0       : Chgfmt [M:ORG1]BID       With "K:40X"     Endif
     If dim([M:ORG1]CUR)>0       : Chgfmt [M:ORG1]CUR       With "K:3X"      Endif
     If dim([M:ORG1]TYPFND)>0    : Chgfmt [M:ORG1]TYPFND    With "-LA:1817": Raz[M:ORG1]TYPFND    Endif
     If dim([M:ORG1]QUASCH)>0    : Chgfmt [M:ORG1]QUASCH    With "-LA:1":    Raz[M:ORG1]QUASCH    Endif
     If dim([M:ORG1]QUAERN)>0    : Chgfmt [M:ORG1]QUAERN    With "-LA:1":    Raz[M:ORG1]QUAERN    Endif
     If dim([M:ORG1]SALSAC)>0    : Chgfmt [M:ORG1]SALSAC    With "-LA:1":    Raz[M:ORG1]SALSAC    Endif
     If dim([M:ORG1]BNKACCTYP)>0 : Chgfmt [M:ORG1]BNKACCTYP With "-LA:1819": Raz[M:ORG1]BNKACCTYP Endif
     If dim([M:ORG1]BNKACCNUM)>0 : Chgfmt [M:ORG1]BNKACCNUM With "-Nz:9":    Raz[M:ORG1]BNKACCNUM Endif
     If dim([M:ORG1]BNKSRTCOD)>0 : Chgfmt [M:ORG1]BNKSRTCOD With "-K:8X":    Raz[M:ORG1]BNKSRTCOD Endif
     If dim([M:ORG1]BSOROL)>0    : Chgfmt [M:ORG1]BSOROL    With "-K:30X":   Raz[M:ORG1]BSOROL    Endif
     If dim([M:ORG1]PAYMTH)>0    : Chgfmt [M:ORG1]PAYMTH    With "-LA:1818": Raz[M:ORG1]PAYMTH    Endif

  #MASHI - 2017-05-09 - JIRA X3-21955 - END
When "BRI"
  #MASHI - 2017-05-09 - JIRA X3-21955 - START
     If dim([M:ORG1]BID)>0       : Chgfmt [M:ORG1]BID       With "-K:40X" : Raz[M:ORG1]BID  Endif
     If dim([M:ORG1]CUR)>0       : Chgfmt [M:ORG1]CUR       With "-K:3X"  : Raz[M:ORG1]CUR  Endif
     If dim([M:ORG1]TYPFND)>0    : Chgfmt [M:ORG1]TYPFND    With "LA:1817": Endif
     If dim([M:ORG1]QUASCH)>0    : Chgfmt [M:ORG1]QUASCH    With "LA:1":    Endif
     If dim([M:ORG1]QUAERN)>0    : Chgfmt [M:ORG1]QUAERN    With "LA:1":    Endif
     If dim([M:ORG1]SALSAC)>0    : Chgfmt [M:ORG1]SALSAC    With "LA:1":    Endif
     If dim([M:ORG1]BNKACCTYP)>0 : Chgfmt [M:ORG1]BNKACCTYP With "LA:1819": Endif
     If dim([M:ORG1]BNKACCNUM)>0 : Chgfmt [M:ORG1]BNKACCNUM With "Nz:9":    Endif
     If dim([M:ORG1]BNKSRTCOD)>0 : Chgfmt [M:ORG1]BNKSRTCOD With "K:8X":    Endif
     If dim([M:ORG1]BSOROL)>0    : Chgfmt [M:ORG1]BSOROL    With "K:30X":   Endif
     If dim([M:ORG1]PAYMTH)>0    : Chgfmt [M:ORG1]PAYMTH    With "LA:1818": Endif
     If [M:ORG1]BNKACCTYP<3 # Bank Account
       Grizo [M:ORG1]BSOROL
    Else
       Actzo [M:ORG1]BSOROL
    Endif
   #MIPEA - 2016-09-27 - X3PEOP-752 - START
    If func AFNC.ACTIV("KFR")
     # Hide Tab title
     Chgtfd [M:ORG3]   With ""
     # Hide Block titles
     Chgtbk [M:ORG3]5  With ""
     Chgtbk [M:ORG3]15 With ""
     Chgtbk [M:ORG3]20 With ""
     Chgtbk [M:ORG3]25 With ""
     Chgtbk [M:ORG3]30 With ""
     Chgtbk [M:ORG3]35 With ""
     ##ORG3 - Hide all of tab
     Chgfmt [M:ORG3]KEYORG       With "-LA:10371"   : Raz [M:ORG3]KEYORG    : #Type
     Chgfmt [M:ORG3]LIBKEYORG    With "-K:35X"      : Raz [M:ORG3]LIBKEYORG : #Other
     Chgfmt [M:ORG3]TYPIRC       With "-LA:10386"   : Raz [M:ORG3]TYPIRC    : #Type
     Chgfmt [M:ORG3]FLGORGCMP    With "-LA:1"       : Raz [M:ORG3]FLGORGCMP : #Complementary organization
     Chgfmt [M:ORG3]CODSSC       With "-K:4X"       : Raz [M:ORG3]CODSSC    : #Code
     Chgfmt [M:ORG3]TYPFRM0      With "-K:20X"      : Raz [M:ORG3]TYPFRM0   : #Slip(1)
     Chgfmt [M:ORG3]DUECOD       With "-K:20X"      : Raz [M:ORG3]DUECOD    : #DUE Code
     Chgfmt [M:ORG3]TYPASS       With "-LA:10325"   : Raz [M:ORG3]TYPASS    : #
     Chgfmt [M:ORG3]NUMASS       With "-K:2X"       : Raz [M:ORG3]NUMASS    : #Number
     Chgfmt [M:ORG3]TYPFRM1      With "-K:20X"      : Raz [M:ORG3]TYPFRM1   : #Slip(2)
     Chgfmt [M:ORG3]NUMDCS       With "-K:20X"      : Raz [M:ORG3]NUMDCS    : #Organisation
     Chgfmt [M:ORG3]TYPFRM2      With "-K:20X"      : Raz [M:ORG3]TYPFRM2   : #Slip(3)
     Chgfmt [M:ORG3]NBRLIG       With "N:4X"        : Chgfmt [M:ORG3]NBRLIG   With "-N:4X"       : Raz [M:ORG3]NBRLIG   : #Slip(3) #DEHEN - 2016-09-26 - Corrected Syntax
     Chgfmt [M:ORG3]GRPORG       With "-K:10X"      : Raz [M:ORG3]GRPORG    : #Organisn
    Endif
    #MIPEA - 2016-09-27 - X3PEOP-752 - END
     #DBA Agilo Task 1129
     Chgtbk [M:ORG1]10 With ""
     Chgfmt [M:ORG1]DEP      With "-K:3X"           : Raz [M:ORG1]DEP
     Chgfmt [M:ORG1]MEW      With "-K:3X"           : Raz [M:ORG1]MEW
    #MASHI - 2017-05-09 - JIRA X3-21955 - END

   When Default
    #MIPEA - 2016-09-27 - X3PEOP-752 - START
    If func AFNC.ACTIV("KFR")
     # Hide Tab title
     Chgtfd [M:ORG3]   With ""
     # Hide Block titles
     Chgtbk [M:ORG3]5  With ""
     Chgtbk [M:ORG3]15 With ""
     Chgtbk [M:ORG3]20 With ""
     Chgtbk [M:ORG3]25 With ""
     Chgtbk [M:ORG3]30 With ""
     Chgtbk [M:ORG3]35 With ""
     ##ORG3 - Hide all of tab
     Chgfmt [M:ORG3]KEYORG       With "-LA:10371"   : Raz [M:ORG3]KEYORG    : #Type
     Chgfmt [M:ORG3]LIBKEYORG    With "-K:35X"      : Raz [M:ORG3]LIBKEYORG : #Other
     Chgfmt [M:ORG3]TYPIRC       With "-LA:10386"   : Raz [M:ORG3]TYPIRC    : #Type
     Chgfmt [M:ORG3]FLGORGCMP    With "-LA:1"       : Raz [M:ORG3]FLGORGCMP : #Complementary organization
     Chgfmt [M:ORG3]CODSSC       With "-K:4X"       : Raz [M:ORG3]CODSSC    : #Code
     Chgfmt [M:ORG3]TYPFRM0      With "-K:20X"      : Raz [M:ORG3]TYPFRM0   : #Slip(1)
     Chgfmt [M:ORG3]DUECOD       With "-K:20X"      : Raz [M:ORG3]DUECOD    : #DUE Code
     Chgfmt [M:ORG3]TYPASS       With "-LA:10325"   : Raz [M:ORG3]TYPASS    : #
     Chgfmt [M:ORG3]NUMASS       With "-K:2X"       : Raz [M:ORG3]NUMASS    : #Number
     Chgfmt [M:ORG3]TYPFRM1      With "-K:20X"      : Raz [M:ORG3]TYPFRM1   : #Slip(2)
     Chgfmt [M:ORG3]NUMDCS       With "-K:20X"      : Raz [M:ORG3]NUMDCS    : #Organisation
     Chgfmt [M:ORG3]TYPFRM2      With "-K:20X"      : Raz [M:ORG3]TYPFRM2   : #Slip(3)
     Chgfmt [M:ORG3]NBRLIG       With "N:4X"        : Chgfmt [M:ORG3]NBRLIG   With "-N:4X"       : Raz [M:ORG3]NBRLIG   : #Slip(3) #DEHEN - 2016-09-26 - Corrected Syntax
     Chgfmt [M:ORG3]GRPORG       With "-K:10X"      : Raz [M:ORG3]GRPORG    : #Organisn
    Endif
    #MIPEA - 2016-09-27 - X3PEOP-752 - END
     #DBA Agilo Task 1129
     Chgtbk [M:ORG1]10 With ""
     Chgfmt [M:ORG1]DEP      With "-K:3X"           : Raz [M:ORG1]DEP
     Chgfmt [M:ORG1]MEW      With "-K:3X"           : Raz [M:ORG1]MEW
  #MASHI - 2017-05-09 - JIRA X3-21955 - START
     If dim([M:ORG1]BID)>0       : Chgfmt [M:ORG1]BID       With "K:40X"   Endif
     If dim([M:ORG1]CUR)>0       : Chgfmt [M:ORG1]CUR       With "K:3X"    Endif
     If dim([M:ORG1]TYPFND)>0    : Chgfmt [M:ORG1]TYPFND    With "-LA:1817": Raz[M:ORG1]TYPFND    Endif
     If dim([M:ORG1]QUASCH)>0    : Chgfmt [M:ORG1]QUASCH    With "-LA:1":    Raz[M:ORG1]QUASCH    Endif
     If dim([M:ORG1]QUAERN)>0    : Chgfmt [M:ORG1]QUAERN    With "-LA:1":    Raz[M:ORG1]QUAERN    Endif
     If dim([M:ORG1]SALSAC)>0    : Chgfmt [M:ORG1]SALSAC    With "-LA:1":    Raz[M:ORG1]SALSAC    Endif
     If dim([M:ORG1]BNKACCTYP)>0 : Chgfmt [M:ORG1]BNKACCTYP With "-LA:1819": Raz[M:ORG1]BNKACCTYP Endif
     If dim([M:ORG1]BNKACCNUM)>0 : Chgfmt [M:ORG1]BNKACCNUM With "-Nz:9":    Raz[M:ORG1]BNKACCNUM Endif
     If dim([M:ORG1]BNKSRTCOD)>0 : Chgfmt [M:ORG1]BNKSRTCOD With "-K:8X":    Raz[M:ORG1]BNKSRTCOD Endif
     If dim([M:ORG1]BSOROL)>0    : Chgfmt [M:ORG1]BSOROL    With "-K:30X":   Raz[M:ORG1]BSOROL    Endif
     If dim([M:ORG1]PAYMTH)>0    : Chgfmt [M:ORG1]PAYMTH    With "-LA:1818": Raz[M:ORG1]PAYMTH    Endif

  #MASHI - 2017-05-09 - JIRA X3-21955 - END

  Endcase
End




