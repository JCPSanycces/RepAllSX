#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# FUNPPCVAL :     Validation automatique des  des tarifs Achats         #
#                         entre deux bornes                             #
# --------------------------------------------------------------------- #
#  Validation des tarifs d'achats dans un patch :  EXE  SUBPPC          #
#  ( la traitement contient le s/p   Subprog SUBPPC                     #
#########################################################################
Local File ACTION
#-- ajout parametre = nom de l'application à traiter  : cg le 21 février 99
#-- pour résoudre le probleme de la validation dossier de X3 vers appli client

Call PPCVAL (nomap)
End


#########################################################################################
Subprog PPCVAL(APPLI)
Value Char APPLI

Raz GLIBDES
GNBREM = 0

Local Integer OK , I
Local Integer I_MOD   : I_MOD=0 : # pas de suppression des lignes tarifs
Local Integer DESTARIFS 
Local Char    DEBUT(GLONPLI) , FIN(GLONPLI)
Local Mask    PPCVAL [PPCV] : Raz [M:PPCV]
Local Mask    PPC0 [PPC0], PPC1 [PPC1], PPC2 [PPC2], PPC3 [PPC3]

$SELECTION
OK=2 : Call DIALWIN(OK,mess(36,198,1),"IPPCVAL") From GESECRAN
If OK<>2 : End :Endif
If [M:PPCV]FINTAR < [M:PPCV]DEBTAR
  Call MESSAGE (mess(202,100,1)) From GESECRAN
  Goto SELECTION
Endif

Call OUVRE_TRACE(mess(55,195,1)) From LECFIC

If clalev ([F:PPC])<=0 : Local File PPRICCONF  [PPC] : Endif
If clalev ([F:PRS])<=0 : Local File PRICSTRUCT [PRS] : Endif

DEBUT = [M:PPCV]DEBTAR
FIN   = [M:PPCV]FINTAR
If FIN = "" : FIN = chr$(255) : Endif
Filter [PPC] Where PLI>=DEBUT & PLI<=FIN

Gosub GENER_ECRAN

$FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


#########################################################################
# Appelé par le SUBPPC (depuis sous-prog PATCH ou GENDOS)
# suppose que le fichier trace soit ouvert avant appel 
#########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

GNBREM   = 0
Raz  GLIBDES 

Local  Integer OK , I
Local  Integer I_MOD   : I_MOD=0 : # pas de suppression des lignes tarifs
Local  Integer DESTARIFS 

Onerrgo ON_SCASSE
If clalev([M:PPC0])<=0 : Local Mask =APPLI+".PPC0" [PPC0] : Endif 
If clalev([M:PPC1])<=0 : Local Mask =APPLI+".PPC1" [PPC1] : Endif 
If clalev([M:PPC2])<=0 : Local Mask =APPLI+".PPC2" [PPC2] : Endif 
If clalev([M:PPC3])<=0 : Local Mask =APPLI+".PPC3" [PPC3] : Endif 
Onerrgo

Local File =APPLI+".AWINDOW"   [AWI] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINPAR"   [AWP] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBRO"   [AWB] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AWINBOUT"  [AWT] : # Déjà ouvert en local, le réouvrir !

If clalev ([F:PPC])<=0 : Local File =APPLI+".PPRICCONF"  [PPC] : Endif
If clalev ([F:PRS])<=0 : Local File =APPLI+".PRICSTRUCT" [PRS] : Endif
#If clalev ([F:AMK])<=0 : Local File =APPLI+".AMSK"       [AMK] : Endif
#If clalev ([F:AMZ])<=0 : Local File =APPLI+".AMSKZON"    [AMZ] : Endif
#If clalev ([F:AMA])<=0 : Local File =APPLI+".AMSKACT"    [AMA] : Endif
#If clalev ([F:AMP])<=0 : Local File =APPLI+".AMSKPAR"    [AMP] : Endif
#If clalev ([F:ATY])<=0 : Local File =APPLI+".ATYPE"      [ATY] : Endif
#If clalev ([F:ACT])<=0 : Local File =APPLI+".ACTION"     [ACT] : Endif
#If clalev ([F:ATR])<=0 : Local File =APPLI+".ACTPAR"     [ATR] : Endif
#If clalev ([F:AAR])<=0 : Local File =APPLI+".ACTCODPAR"  [AAR] : Endif
#If clalev ([F:ATB])<=0 : Local File =APPLI+".ATABLE"     [ATB] : Endif
#If clalev ([F:ATZ])<=0 : Local File =APPLI+".ATABZON"    [ATZ] : Endif
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]

Local File =APPLI+".ACTIV"     [ACV] : # Déjà ouvert en local, le réouvrir !
Local File =APPLI+".AOBJET"    [AOB] : # Déjà ouvert en local, le réouvrir !

#If clalev ([F:ATX])<=0 : Local File =APPLI+".ATEXTE"     [ATX] : Endif
#If clalev ([F:ADV])<=0 : Local File =APPLI+".ATABTAB"    [ADV] : Endif
Local File =APPLI+".ATEXTE"     [ATX]
Local File =APPLI+".ATABTAB"    [ADV]

Filter [PPC]
Gosub GENER_ECRAN

$ON_SCASSE
End

#---------------------------------------------#
# re generation des ecrans et des traitements #
#---------------------------------------------#
$GENER_ECRAN
For [PPC]
  Read [PRS] PRS0=2;[F:PPC]PLISTC
  If fstat  Break : Endif
  For I=0 To dim([F:PRS]INCDCR)-1
    If [F:PRS]INCDCR(I)=0 : Break : Endif
    Call LECTEXTRA (GLIBDES(I),"PRICSTRUCT","DESAXX("+num$(I)+")",
&                   "2",[F:PRS]PLISTC) From ATEXTRA
  Next I
  GNBREM=I
#  GMYTARIF = [F:PPC]PLI
  GOK = 1
  Trbegin [PPC]
  [M:PPC0]=[F:PPC]
  [M:PPC1]=[F:PPC]
  [M:PPC2]=[F:PPC]
  [M:PPC3]=[F:PPC]
  Default File [PPC]
  Gosub DEL_ECR From SUBPPC
  Gosub GEN_ECR From SUBPPC
    If GOK <> 1
       Call ECR_TRACE(mess(14,100,1)-mess(50,198,1)-[F:PPC]PLI,1) From GESECRAN
       Rollback
  Else
       Call ECR_TRACE (mess(87,197,1)-mess(50,198,1)-[F:PPC]PLI,0) From GESECRAN
       Commit
  Endif
Next

Return
