######################################################################################
## Etiquette ajoutée par le superviseur (écran SQLSTA1) 24/02/2006 13:44:10 (VPO)
######################################################################################
Subprog B1_NBINDEX
For I=nolign To [M:STA1]NBINDEX
  [M:STA1]PROFLG(I-1)=2
Next I
Affzo [M:STA1]5
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B2_NBINDEX
For I=nolign To [M:STA1]NBINDEX
  [M:STA1]PROFLG(I-1)=1
Next I
Affzo [M:STA1]5
#gerer les boutons de fenetre + bouton contextuel
mkstat=4
End

Subprog B3_NBINDEX
Local Integer ERR
Local Integer NOOBJ : NOOBJ=nolign
Call ACTUALISER_LIGNE(NOOBJ,ERR)
Affzo [M:STA1]5
End

Subprog B4_NBINDEX
Local Integer ERR
Local Integer NOOBJ : NOOBJ=nolign
Call GENERER_LIGNE(ERR)
Call ACTUALISER_LIGNE(NOOBJ,ERR)
Affzo [M:STA1]5
End

