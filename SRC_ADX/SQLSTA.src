#<AdxTL>@(#)8.0.0.0 $Revision$
Close Local Mask
Call SQLSTA(nomap)
End

########################################################################
Subprog SQLSTA(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"SQLSTA","SQLSTA","") From GSAISIE
End

######################################################################################
# Gestion du masque SQLSTA0
####################
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "RAF"          : Gosub RAF
 When "FIN"          : Gosub FIN
 When Default
Endcase
Return

####################
$OUVRE
If GTYPDBA<>2
    FIN=1
    Return
Endif
Return

####################
$DEBUT
If GTYPDBA<>2
    Call ERREUR(mess(185,115,1)) From GESECRAN : # La base de données n'est pas SQLSERVER
    FIN=1
    Return
Endif

Raz [M:STA0]
Call VERS_SQL([M:STA0]BDDNAM,[M:STA0]VER,[M:STA0]VERDES,FIN) From SQLPROP
If FIN : Return : Endif
Diszo [M:STA0]
Gosub ACTUALISER
Return

####################
$FIN
Return

####################
$BOUTON
Case BOUT
   When "A" : Gosub ACTUALISER
   When "G" : Gosub GENERER
Endcase
Return

#########
$SETBOUT
Call VIREBOUT(CHMEN,"AG") From GOBJET

#on affiche toujours Actualiser
CHMEN+="A"
CHBOU += "=" : # Raffraîchir

NOIND=find(2,[M:STA1]PROFLG(0..[M:STA1]NBINDEX-1))
If NOIND<>0
   CHMEN+="G"
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

####################
$RAF
$ACTUALISER
Call TEMPON("L") From GESECRAN
Call CHARGE_STA1(FIN)
Call CHARGE_STA2(FIN)
Affzo [M:STA1]
Affzo [M:STA2]
Call TEMPOFF From GESECRAN
Return

####################
$GENERER
Local Integer ERR,I,COUNT
Local Integer INTERRUPT : INTERRUPT=1

COUNT=0
For nolign=1 To [M:STA1]NBINDEX
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
  Endif
Next nolign

Call OUVRE_BOITE(mess(219,100,1),COUNT) From GESECRAN
COUNT=0
#generation pour les index
For nolign=1 To [M:STA1]NBINDEX
  I=nolign-1
  If [M:STA1]PROFLG(nolign-1)=2
     COUNT+=1
     Call AFF_BOITE([M:STA1]INDEX(I),COUNT,INTERRUPT ) From GESECRAN
     Call GENERER_LIGNE(ERR)
  Endif
Next nolign

Call FERME_BOITE From GESECRAN

Gosub ACTUALISER
Return


###################################################################################################
###################################################################################################
Subprog CHARGE_STA1(ERR)
Variable Integer ERR
Onerrgo ERR_SQL

Local Integer NOOBJ

Raz [M:STA1]
nolign = 0

Local Char REQSQL (250) (2)
#VPO 04/03/08 BUG46131 ajout cast sur o.name
REQSQL(0) = "SELECT cast(o.name as varchar),i.name,convert(varchar,STATS_DATE(i.id,i.indid),120),cast(i.rowcnt as varchar) "


Local Char WVERSSQL(30)
Call NOVERS_SQL(WVERSSQL,ERR) From SQLPROP
If ERR<>0 : End : Endif
If WVERSSQL="8"
REQSQL(1) ="From sysindexes i,sysobjects o,sysusers u"
& -"where o.id=i.id and o.uid=u.uid and i.name<>o.name"
& -"and i.name not like '%ROWID'"
& -"and i.name<>'t'+o.name"
& -"and i.status in (0,2)"
& -"and u.name='"+nomap+"'"
& -"order by o.name,i.name"
Else
REQSQL(1) ="From sysindexes i,sysobjects o"
& -"where o.id=i.id and i.name<>o.name"
& -"and i.name not like '%ROWID'"
& -"and i.name<>'t'+o.name"
& -"and i.status in (0,2)"
& -"and SCHEMA_NAME(o.uid)='"+nomap+"'"
& -"order by o.name,i.name"
Endif

For (Char VTAB(50),Char VIND(50),Char VDAT(50),Char VROW(50)) From '5' Sql REQSQL As [BXX]
    nolign +=1
    [M:STA1]TAB(nolign-1)=[BXX]VTAB
    [M:STA1]INDEX(nolign-1)=[BXX]VIND
    NOOBJ = nolign
    ###Call ACTUALISER_LIGNE(NOOBJ,ERR)
    Gosub AFFECT_LIG
Next
[M:STA1]NBINDEX = nolign
Onerrgo
End

###################################################################################################
$AFFECT_LIG
    If [BXX]VDAT=""
       [M:STA1]STTFLG(NOOBJ-1)=1
    Else
       [M:STA1]STTFLG(NOOBJ-1)=2
    Endif
    [M:STA1]STTDAT(NOOBJ-1)=format$("DZ<:YYYYMMDD",left$([BXX]VDAT,10))
    #[M:STA1]STTHOU(NOOBJ-1)=mid$([BXX]VDAT,12,2)+mid$([BXX]VDAT,15,2)
    [M:STA1]STTHOU(NOOBJ-1)=mid$([BXX]VDAT,12,8)
    [M:STA1]NBRLIN(NOOBJ-1)=val([BXX]VROW)
Return

###################################################################################################
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


###################################################################################################
###################################################################################################
#**
#* Load screen SQLSTA2
#*
#* @param ERR : return 0 if no error, else return 1
#*!
Subprog CHARGE_STA2(ERR)
Variable Integer ERR

Raz [M:STA2]
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    RESTE(250), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char    INDNAME(50) : INDNAME=""
Local Char    XINSTANCE(200)
Local Char    XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host
Local Integer OK

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)
# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
    SQLDBA = "sqlcmd"
    Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
    If OK<>0
        ERR=1
        End
    Endif
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
    SQLDBA = "osql"
Endif

Onerrgo ERR_SQL

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII

#
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""
 FICCMD = filpath("tmp","sqlstat"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqlstat"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqlstat"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 ## On ecrit le fichier sql pour les tables
 ##
 Openo FICSQL , 0
 For I=0 To [M:STA1]NBINDEX-1
   Wrseq "PRINT 'INDEX="+[M:STA1]INDEX(I)+"'"
   Wrseq "exec sp_autostats @tblname='"+NOMDOS+"."+[M:STA1]TAB(I)+"',@indname='"+[M:STA1]INDEX(I)+"'"
 Next
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 ##
 ##
 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049
 #Wrseq "SET OSQL_EXE="+SQLDBA
 #WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
 #WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
     Wrseq "SET SQLCMD_EXE="+SQLDBA
     WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
     Wrseq WORDRE
     WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
     Wrseq WORDRE
 Else
     Wrseq "SET OSQL_EXE="+SQLDBA
     WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
     Wrseq WORDRE
     WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
     Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 #
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If len(LIGNE)>0
      RESTE=""
      If left$(LIGNE,6)="INDEX=" Then
         INDNAME = "["+right$(LIGNE,7)+"]"
         J=find(right$(LIGNE,7),[M:STA1]INDEX(0..[M:STA1]NBINDEX-1))
         NEWVAL=0
      Elsif left$(LIGNE,len(INDNAME))=INDNAME
         RESTE=right$(LIGNE,len(INDNAME)+1)
         RESTE = vireblc(RESTE,2)
         NEWVAL=1
      Elsif NEWVAL=1 Then
         RESTE=LIGNE
      Endif
      If NEWVAL=1 Then
         If left$(RESTE,2)="ON" Then
            [M:STA1]STTAUT(J-1)=2
            NEWVAL=0
         Elsif left$(RESTE,3)="OFF" Then
            [M:STA1]STTAUT(J-1)=1
            NEWVAL=0
         Endif
      Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'

 Openo FICSQL,0
#94590
# Wrseq "exec sp_dboption @dbname='"+XBASE+"',@optname='auto create statistics'"
# Wrseq "exec sp_dboption @dbname='"+XBASE+"',@optname='auto update statistics'"
 Wrseq "SELECT 'IsAutoCreateStatistics=',Case When DATABASEPROPERTYEX('"+XBASE+"', 'IsAutoCreateStatistics')=1 Then 'TRUE' Else 'FALSE' End ;"
 Wrseq "SELECT 'IsAutoUpdateStatistics=',Case When DATABASEPROPERTYEX('"+XBASE+"', 'IsAutoUpdateStatistics')=1 Then 'TRUE' Else 'FALSE' End ;"

 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 #Call SYSTEME(MACHINE,WORDRE,"",ER) From ORDSYS
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  Openi FICTRA
  Rdseq LIGNE
  nolign = 0
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
#94590
#   If len(LIGNE)>0
#    nolign +=1
#    [M:STA2]PAR(nolign-1)=left$(LIGNE,30)
#    [M:STA2]PARVAL(nolign-1)=vireblc(right$(LIGNE,31),2)
#   Endif
   I=instr(0,LIGNE,"=")
   If len(LIGNE)>0 & I>0
    nolign +=1
    [M:STA2]PAR(nolign-1)=left$(LIGNE,I-1)
    [M:STA2]PARVAL(nolign-1)=vireblc(right$(LIGNE,I+1),2)
   Endif
   Rdseq LIGNE
  Wend
  [M:STA2]NBPAR = nolign
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Onerrgo
End


###################################################################################################
###################################################################################################
Subprog ACTUALISER_LIGNE(NOOBJ,ERR)
Variable Integer NOOBJ
Variable Integer ERR

Local Char REQSQL (250)


Local Char WVERSSQL(30)
Call NOVERS_SQL(WVERSSQL,ERR) From SQLPROP
If ERR<>0 : End : Endif
If WVERSSQL="8"
REQSQL = "select convert(varchar,STATS_DATE(i.id,i.indid),120),cast(i.rowcnt as varchar)"
& -"from sysindexes i,sysobjects o,sysusers u"
& -"where o.id=i.id and o.uid=u.uid"
& -"and i.name='"+[M:STA1]INDEX(NOOBJ-1)+"'"
& -"and i.status in (0,2)"
& -"and u.name='"+nomap+"'"
Else
REQSQL = "select convert(varchar,STATS_DATE(i.id,i.indid),120),cast(i.rowcnt as varchar)"
& -"from sysindexes i,sysobjects o"
& -"where o.id=i.id"
& -"and i.name='"+[M:STA1]INDEX(NOOBJ-1)+"'"
& -"and i.status in (0,2)"
& -"and SCHEMA_NAME(o.uid)='"+nomap+"'"
Endif

Onerrgo ERR_LIG

For (Char VDAT(50),Char VROW(50)) From '5' Sql REQSQL As [BXX]
    Gosub AFFECT_LIG
   Break
Next

Onerrgo
End



###################################################################################################
###################################################################################################
Subprog GENERER_LIGNE(ERR)
Variable Integer ERR

Local Char SQLREQ (250)

Onerrgo ERR_LIG

SQLREQ = "update statistics ["+nomap+"].["+[M:STA1]TAB(nolign-1)+"] "+[M:STA1]INDEX(nolign-1)

Execsql From "5" Sql SQLREQ

Onerrgo
End

###################################################################################################
###################################################################################################
$ERR_LIG
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End


