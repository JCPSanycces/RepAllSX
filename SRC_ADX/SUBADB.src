#<AdxTL>@(#)9.0.0.0 $Revision$
########################################################################
# SUBADB : Saisie en fenêtre d'une adresse tiers          MBT 20/11/97 #
# -------------------------------------------------------------------- #
# Ce traitement est appelé depuis le S/P SAISADR du TRTX3              #
# Issue 100619 - 2014-07-24 by SR : [M:ADB] remplacés par [M]          #
# Car le Webservice ouvre une autre abréviation que ADB                #
########################################################################

Subprog S_BPAADD(VALEUR)
#---------------------------#
# Sélection du code adresse #
#---------------------------#
Variable Char    VALEUR()
Local    Integer TYP : TYP=1
Call SELADR(TYP,ADBBPR,BPRNAM,VALEUR) From TRTX3
If VALEUR="" VALEUR=BPAADD : mkstat=1 : Endif
End

Subprog C_BPAADD(VALEUR)
#-----------------------#
# Contrôle code adresse #
#-----------------------#
Variable Char    VALEUR()
Read [BPA] BPA0=1;ADBBPR;VALEUR
If fstat Raz [F:BPA] : mkstat=1 : Endif
End

Subprog AM_BPAADD(VALEUR)
#------------------------------------#
# Après modification du code adresse #
#------------------------------------#
Variable Char    VALEUR()
[M]BPAADD      =[F:BPA]BPAADD
[M]BPAADDLIG(0)=[F:BPA]BPAADDLIG(0)
[M]BPAADDLIG(1)=[F:BPA]BPAADDLIG(1)
[M]BPAADDLIG(2)=[F:BPA]BPAADDLIG(2)
[M]CRY         =[F:BPA]CRY
[M]CRYNAM      =[F:BPA]CRYNAM
[M]SAT         =[F:BPA]SAT
[M]POSCOD      =[F:BPA]POSCOD
[M]CTY         =[F:BPA]CTY
[M]ADBFLG      =1
Affzo [M]
End

Subprog AM_CRY(VALEUR)
#-------------------------------------#
# Après modification du code pays     #
# Chargement et affichage nom du pays #
#-------------------------------------#
Variable Char    VALEUR()
Call LECTEXTRA([M]CRYNAM,"TABCOUNTRY","CRYDES",[F:TCY]CRY,"") From ATEXTRA
Affzo CRYNAM
End

Subprog AS_BPAADD(VALEUR)
Variable Char     VALEUR
If ADBTRT <>0 : mkstat = 2 : Endif
End
