#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet AWU
Raz GPILOBJ
Call OBJET("AWU",GBIDC1,GBIDC2) From GOBJET
End

#-----------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "SETBOUT" : Gosub SETBOUT
 When "LIENS"   : Gosub LIENS
 When "LIENS2"  : Gosub LIENS2
Endcase
Return

$SETBOUT
If !instr(1,GUSRAUZ(1),"U") & [M]USER<>GUSER
 Call VIREBOUT(CHAINE,"AMC") From GOBJET
Endif
Return

$LIENS
Read [AUS]CODUSR=[M]USRDEL(nolign-1)
[M]USREML(nolign-1) = [F:AUS]ADDEML
Return

$LIENS2
Read [AUS]CODUSR=[M]USER
[M]USEREML = [F:AUS]ADDEML
Return

#------------------------------------------------------#
Subprog C_USER(VALEUR)
Variable Char    VALEUR()
Read [AUS]CODUSR=VALEUR
[M]USEREML = [F:AUS]ADDEML
If !instr(1,GUSRAUZ(1),"U") & VALEUR<>GUSER
 Look [AWU]=VALEUR
 If fstat
  Call ERREUR(mess(7,123,1)) From GESECRAN : # Création impossible
  mkstat = 1 : End
 Endif
Endif
End

Subprog C_USRDEL(VALEUR)
Variable Char    VALEUR()
Read [AUS]CODUSR=VALEUR
[M]USREML(nolign-1) = [F:AUS]ADDEML
End

Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
Local Integer I , J , K
J = nolign-1
For I=1 To [M]NBRLIG
 K = (I-1<>J)
 K *= ([M]USRDEL(J)=[M]USRDEL(I-1))
 K *= ([M]NATURE(J)=[M]NATURE(I-1))
 K *= ([M]TYPDEL(J)=[M]TYPDEL(I-1))
 K *= ([M]VLYSTR(J)=[M]VLYSTR(I-1))
 K *= ([M]VLYEND(J)=[M]VLYEND(I-1))
 If K
  GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en ligne
  mkstat = 1 : Break
 Endif
Next I
End
