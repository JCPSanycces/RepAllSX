################################################################################################
# Update shift code for all employees associated with a detail team
################################################################################################
Subprog UPDATE_SHIFT(ITEAMNUM,ISHIFT)
Value Integer ITEAMNUM
Value Char ISHIFT
  Local File SFTTEM [SFTTM]
  Local File TABMAT [TMA]

  Filter [SFTTM] Where TEAMNUM = ITEAMNUM
  For [SFTTM]
    Read [TMA]TMA0=[F:SFTTM]EMPNUM
    If fstat
      #Error reading record
      [L]ASTATUS = fmet this.ASETERROR ("SHIFT", mess(21,2422,1), [V]CST_AERROR)
      Return
    Endif

    [TMA]SHIFT = ISHIFT

    Rewrite [TMA]
    If fstat
      #Error updating record
      [L]ASTATUS = fmet this.ASETERROR ("SHIFT", mess(21,2422,1), [V]CST_AERROR)
      Return
    Endif
  Next
  Filter [SFTTM]

  LogicClose File [TMA]
  LogicClose File [SFTTM]
End

