#<AdxTL>@(#)0.0.0.0 $Revision$ $Revision$
#------------------------------------------------------------------------#
# Changement de valeur                                            V140   #
#                        /s Pro divers                                   #
#------------------------------------------------------------------------#

Subprog CHARG_CGV(LFCY, LITM)
Value Char LFCY
Value Char LITM

Local Integer LERR, LRET
Local Char    WTCM(GLONTCM)   #112699/116166.n

# Issue 80993 - 2012-05-10 by CCC
If dim(GRNDVAL)<=0 : Global Decimal GRNDVAL : Endif

    Effzo [M:CGV]10-99
    Raz [M:CGV]NBDEL,CSTCOUDEL

    If [F:ITM]ITMREF<>LITM
        Raz [F:ITM]
        Read [ITM]ITM0=LITM
    Endif

    # 112688/116166.sn
    # Get the Product/Site record
    If [F:ITF]ITMREF<>LITM & [F:ITF]STOFCY<>LFCY
        Raz [F:ITF]
        Read [F:ITF]ITF0=LITM;LFCY
    Endif
    [M:CGV]VLTCOD = [F:ITF]VLTCOD

    # Get the costing method record
    Call GETTCM(LITM,LFCY,WTCM,LRET) From STKVAL

    #Default REPFLG to Quantity
    [M:CGV]REPFLG=3
    # 112688/116166.en

    Gosub FORMAT_INV From STKLIB
    If left$(GWSINVSLO,1)<>"-"
        GWSINVSLO=left$(GWSINVSLO,1)+"P"+right$(GWSINVSLO,2)
    Endif

    [M:CGV]ACCCUR = GLOCALDEV
    Affzo [M:CGV]ACCCUR
    [M:CGV]STU = [F:ITM]STU

    Raz GCGVMODIF
    Actzo [M:CGV]10-15
    If [F:ITM]LOTMGTCOD>1
        Gosub CHARG_SLF
        Actzo [M:CGV]20
        Diszo [M:CGV]30
        [M:CGV]AMTTOTLOT = sum([M:CGV]LOTCST)
        [M:CGV]AMTLOTORI = [M:CGV]AMTTOTLOT
        [M:CGV]LOTCUR    = GSYSCUR
    Else
        Grizo [M:CGV]20
        Grizo [M:CGV]30
    Endif
#    If !LERR
        Gosub CHARG_STP
#        If !LERR
            Gosub CHARG_ITV
            [M:CGV]QTYTOTCST = sum([M:CGV]QTYSTUACT)
            [M:CGV]CSTQTYORI = sum([M:CGV]QTYSTUACT)
            [M:CGV]AMTTOTCST = sum([M:CGV]CST)
            If [M:CGV]QTYTOTCST>0
                [M:CGV]PRICST    = [M:CGV]AMTTOTCST / [M:CGV]QTYTOTCST
            Else
                [M:CGV]PRICST    = 0
            Endif
            [M:CGV]AMTCSTORI = [M:CGV]AMTTOTCST
            If LERR<>3 & [F:ITM]LOTMGTCOD>1 & sum([M:CGV]LOTQTYACT)<>[M:CGV]AVCBASQTY
                LERR=2    # Désynchro des stock => lancer la resynchro
            Else
                #On est synchro => on récupére la qté physique totale
                If [F:ITM]LOTMGTCOD>1
                    [M:CGV]AVCBASQTP = sum([M:CGV]LOTQTYSTU)
                Else
                    [M:CGV]AVCBASQTP = [M:CGV]AVCBASQTY
                Endif
                [M:CGV]DIFQTYCST = [M:CGV]QTYTOTCST-[M:CGV]AVCBASQTY
            Endif
#        Endif
#    Endif
    Case LERR
        When 1: # Tableau plein => modifier la valeur du code activité CGV
                Call ERREUR(mess(149,184,1)) From GESECRAN
        When 2: # Désynchro des stock => lancer la resynchro
                Call ERREUR(mess(46,184,1)) From GESECRAN
        When 3: # Désynchronisation STOLOTFCY/STOCK
                Call ERREUR(mess(260,184,1)) From GESECRAN
        When 4: # Erreur accès fichier (call RSTA déjà fait)
        When Default:
                If [M:CGV]AVCBASQTY=0
                    Call ERREUR(mess(135,190,1)) From GESECRAN    #Stock nul
                    LERR=5
                Endif
    Endcase
#    If LERR : mkstat = 2 : Endif
    # CCC (03/11/06) BUG 38220
    If [F:ITM]LOTMGTCOD>1
        [M:CGV]MODLOTFLG = 2
    Else
        [M:CGV]MODLOTFLG = 1
    Endif
    Case LERR
        When 0       : Actzo [M:CGV] 6-99
        When 3       : [M:CGV]REPFLG = 1
                       [M:CGV]MODLOTFLG = 1
                       Actzo [M:CGV] 6-99
                       Grizo [M:CGV]REPFLG
                       Grizo [M:CGV]20    # Lots
                       Grizo [M:CGV]30    # Lots
        When Default : Grizo [M:CGV] 6-99
    Endcase

End

##########################################################################
$CHARG_STP

Call INIRNDVAL("STOCOST","CST") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

    Filter [F:STP] Where STOFCY =  LFCY &
&                      ITMREF =  LITM  &
&                      QTYSTUACT > 0
&                Order By Key STP0
    nolign = 0
    For [F:STP]
        If nolign < dim([M:CGV]QTYSTUACT)-1
            nolign += 1
            [M:CGV] = [F:STP]
            [M:CGV]QTYSTUACT(nolign-1) = [F:STP]QTYSTUACT
            [M:CGV]CST(nolign-1)       = arr([M:CGV]CST(nolign-1), GRNDVAL)
            [M:CGV]AVCCST(nolign-1)    = arr([F:STP]CST/[F:STP]QTYSTUACT, GRNDVAL)
            [M:CGV]QTYSTUORI(nolign-1) = [M:CGV]QTYSTUACT(nolign-1)
            [M:CGV]CSTORI(nolign-1)    = [M:CGV]CST(nolign-1)
            [M:CGV]VCRTYPP(nolign-1)   = [F:STP]VCRTYP
            [M:CGV]VCRNUMP(nolign-1)   = [F:STP]VCRNUM
            [M:CGV]VCRLINP(nolign-1)   = [F:STP]VCRLIN
            [M:CGV]FIFOFLG(nolign-1)   = 1
        Else
            LERR = 1    # Tableau plein
            Break
        Endif
    Next
    [M:CGV]NBFIFO = nolign
    Filter [F:STP]
Return

##########################################################################
$CHARG_SLF

Call INIRNDVAL("STOLOTFCY","AVCBASAMT") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

Local Decimal LCUMQTY
    nolign = 0
    Filter [F:SLF] Where ITMREF=LITM & STOFCY=LFCY
    For [F:SLF]
        LCUMQTY=[F:SLF]AVCBASQTY
        If LCUMQTY>0
            # Issue 97591 - 2014-03-24 by CCC : filter with owner
            #For [STO] Where Key STO3(4)=LITM;LFCY;[F:SLF]LOT;[F:SLF]SLO
            #    LCUMQTY -= [F:STO]QTYSTUACT
            #Next
            LCUMQTY -= func GETSTOQTYLOT(LITM,LFCY,[F:SLF]LOT,[F:SLF]SLO,"")
            If LCUMQTY=0
                If nolign < dim([M:CGV]LOTQTYSTU)-1
                    Read [STL]STL0=LITM;[F:SLF]LOT;[F:SLF]SLO
                    nolign += 1
                    [M:CGV] = [F:SLF]
                    [M:CGV]WLOT(nolign-1)      = [F:SLF]LOT
                    [M:CGV]LOTQTYACT(nolign-1) = [F:SLF]AVCBASQTY
                    [M:CGV]LOTQTYSTU(nolign-1) = [M:CGV]LOTQTYACT(nolign-1)/(([F:STL]POT/100)+([F:STL]POT=0))
                    [M:CGV]LOTCST(nolign-1)    = arr([F:SLF]AVCBASAMT, GRNDVAL)
                    [M:CGV]LOTAVC(nolign-1)    = arr([F:SLF]AVC, GRNDVAL)
                    [M:CGV]LOTCSTORI(nolign-1) = [M:CGV]LOTCST(nolign-1)
                    [M:CGV]LOTAVCORI(nolign-1) = [M:CGV]LOTAVC(nolign-1)
                    [M:CGV]LOTFLG(nolign-1)    = 1
                Else
                    LERR=1    # Tableau plein !!!
                    Break
                Endif
            Else
                LERR = 3     # Désynchronisation STOLOTFCY/STOCK
            Endif
        Endif
    Next
    [M:CGV]NBLOT = nolign
    Filter [F:SLF]
Return

##########################################################################
$CHARG_ITV
Call INIRNDVAL("ITMMVT","AVCBASAMT") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

    Raz [F:ITV]
    Read [ITV]ITV0=LITM;LFCY
    If fstat
        Call RSTA("ITV",LITM+";"+LFCY) From GLOCK
        LERR = 4
        Return
    Endif
    [M:CGV] = [F:ITV]
    [M:CGV]AVCBASFLG = 1

    [M:CGV]AVCBASAMT = arr([M:CGV]AVCBASAMT, GRNDVAL)
    [M:CGV]BASAMTORI = [M:CGV]AVCBASAMT

Return

###############################################################################
# MODIF : Rend insaisissable les autres blocs et modifie GCGVMODIF
###############################################################################
# Paramètres E : LBLOC = Ce qui a été modifié
#                         1:AVCAMTBAS - 2:Pile FIFO - 3:Valeurs lots
###############################################################################
Subprog MODIF(LBLOC)
Value Integer LBLOC

    Case LBLOC
        When 2 :
            If [M:CGV]CSTQTYORI<>[M:CGV]QTYTOTCST | sum([M:CGV]FIFOFLG)<>[M:CGV]NBFIFO
                If !GCGVMODIF
                    Diszo [M:CGV]10
                    If [F:ITM]LOTMGTCOD>1 | [M:CGV]MODLOTFLG=1
                        Diszo [M:CGV]20
                    Endif
                Endif
                GCGVMODIF = 2
            Else
                Actzo [M:CGV]10
                If [F:ITM]LOTMGTCOD>1 & [M:CGV]MODLOTFLG=2
                    Actzo [M:CGV]20
                Endif
                GCGVMODIF = 0
            Endif
        When 3 :
            If sum([M:CGV]LOTFLG)<>[M:CGV]NBLOT
                If !GCGVMODIF
                    Diszo [M:CGV]10-15
                Endif
                GCGVMODIF = 3
            Else
                Actzo [M:CGV]10-15
                GCGVMODIF = 0
            Endif
    Endcase
End


###############################################################################
# CTR_ENR_CGV : Contrôle que l'enregistrement du changement de valeur
#               est possible. GMESSAGE et GERR sont positionnées en cas d'erreur
###############################################################################
$CTR_ENR_CGV
If [M:CGV]DIFQTYCST<>0
    GMESSAGE = mess(148,184,1)
    GERR = 1
Endif
Return

###############################################################################
# ENR_CGV : Effectue l'enregistrement du changement de valeur.
#           Record the value change
###############################################################################
$ENR_CGV
Local Integer LRET
Local Char    LVCRNUM(GLONVCR)
Local Decimal LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1+1+4) : Raz LDELTA

Global Integer GSTJFLG
Global Decimal GCHGVAL

If !clalev([F:ITG])   : Local File ITMCATEG   [ITG]   : Endif
If !clalev([F:FCY])   : Local File FACILITY   [FCY]   : Endif
If !clalev([F:STJ])   : Local File STOJOU     [STJ]   : Endif
If !clalev([F:STJ1])  : Local File STOJOU     [STJ1]  : Endif    # Utilisée par ECRSTJ
If !clalev([F:SJV])   : Local File STOJOUVAL  [SJV]   : Endif
If !clalev([F:CGV])   : Local File CHGVAL     [CGV]   : Endif
If !clalev([F:CGVD])  : Local File CGVDET     [CGVD]  : Endif

Raz [F:FCY]
Read [FCY]FCY0 = [M:CGV]STOFCY    # Pour récupérer le site financier

If GSTOTRACE>1
    Call OUVRE_TRACE(mess(30,701,1)) From LECFIC
Endif

Trbegin [ITV], [CGV], [CGVD]
Call DEBTRANS From GLOCK

Call NUMERO(GSTKCPT(21),[M:CGV]STOFCY,[M:CGV]IPTDAT,"",LVCRNUM,LRET) From SUBANM

# Issue 79428 - 2012-01-20 by CCC
Read [ITM]ITM0=[M:CGV]ITMREF

GSTJFLG = [V]CST_ANO  # Default to no record created

Case GCGVMODIF
    When 1 :
        GCHGVAL = [M:CGV]AVCBASAMT-[M:CGV]BASAMTORI
        Call ECRTRACE (mess(120,184,1),0) From STKVAL
        Call MAJITV([M:CGV]AVCBASAMT, [M:CGV]BASAMTORI, LDELTA)
        If GOK=1
            Call ECRONESTJ(LVCRNUM, [M:CGV]AVCBASAMT-[M:CGV]BASAMTORI, LDELTA)  # 116166/112688.n
            If [M:CGV]REPFLG>1
                Call MAJSTP([M:CGV]AVCBASAMT, [M:CGV]BASAMTORI, [M:CGV]REPFLG)
                If GOK=1
                    Call MAJSLF(LVCRNUM, [M:CGV]AVCBASAMT, [M:CGV]BASAMTORI, [M:CGV]REPFLG)
                Endif
            # 112688/116166.o
            #Else
            #    Call ECRONESTJ(LVCRNUM, [M:CGV]AVCBASAMT-[M:CGV]BASAMTORI, LDELTA)
            Endif
        Endif
    When 2 :
        GCHGVAL = [M:CGV]AMTTOTCST-[M:CGV]AMTCSTORI
        Call ECRTRACE (mess(121,184,1),0) From STKVAL
        # Issue 79428 - 2012-01-20 by CCC
        Call MAJSTPTAB(LVCRNUM,LDELTA)
        If GOK=1
            Call ECRONESTJ(LVCRNUM, [M:CGV]AMTTOTCST-[M:CGV]AMTCSTORI, LDELTA)   # 116166/112688.n
            If [M:CGV]REPFLG>1
                Call MAJITV([M:CGV]AMTTOTCST , [M:CGV]AMTCSTORI, LDELTA)
                If GOK=1
                    Call MAJSLF(LVCRNUM, [M:CGV]AMTTOTCST, [M:CGV]AMTCSTORI,[M:CGV]REPFLG)
                Endif
            # 112688/116166.o
            #Else
            #    Call ECRONESTJ(LVCRNUM, [M:CGV]AMTTOTCST-[M:CGV]AMTCSTORI, LDELTA)
            Endif
        Endif
    When 3 :
        GCHGVAL = [M:CGV]AMTTOTLOT-[M:CGV]BASAMTORI
        Call ECRTRACE (mess(122,184,1),0) From STKVAL
        If [M:CGV]REPFLG>1
            Call MAJITV([M:CGV]AMTTOTLOT , [M:CGV]AMTLOTORI, LDELTA)
            If GOK=1
                Call MAJSTP([M:CGV]AMTTOTLOT, [M:CGV]AMTLOTORI,[M:CGV]REPFLG)
            Endif
            # 116166/112688.n - Create STOJOU records for Lot entry but non-lot valuation is distribution is selected
            If find([F:TCM]ISSVLTCOD,4,5,8)
              Call ECRONESTJ(LVCRNUM, [M:CGV]AMTTOTLOT-[M:CGV]BASAMTORI, LDELTA)
            Endif
        Endif
        If GOK=1
            Call MAJSLFTAB(LVCRNUM)
        Endif
Endcase

If GOK = 1
  Call MAJ_CHGVAL(LVCRNUM)
  Call MAJ_CGVDET(LVCRNUM)
Endif

If GOK=1
    Commit
Else
    Rollback
Endif
If GSTOTRACE>1
    Call FERME_TRACE() From LECFIC
    Call LEC_TRACE() From LECFIC
Endif
Return

###############################################################################
Subprog MAJITV(PNEWAMT, POLDAMT, PDELTA)
Value Decimal PNEWAMT
Value Decimal POLDAMT
Variable Decimal PDELTA()

Local Decimal LAVC(dim(PDELTA))
Local Integer I

    Call INIRNDVAL("ITMMVT","AVCBASAMT") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

    Call ECRTRACE ("------------ ITMMVT [ITV] ------------",0) From STKVAL
    If !clalev([F:ITV]) : Local File ITMMVT : Endif
    Readlock [ITV]ITV0=[M:CGV]ITMREF;[M:CGV]STOFCY
    Call ECRTRACE (mess(123,184,1)-"AVCBASAMT="+num$([F:ITV]AVCBASAMT),0) From STKVAL
    If POLDAMT=0
        [F:ITV]AVCBASAMT += PNEWAMT
        #[F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,10^-GDECPRI)  # 112077.o
        [F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,GRNDVAL)       # 112077.n
    Else
        [F:ITV]AVCBASAMT = arr([F:ITV]AVCBASAMT * PNEWAMT / POLDAMT, GRNDVAL)
        #[F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,10^-GDECPRI)  # 112077.o
        [F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,GRNDVAL)       # 112077.n
    Endif
    If GACTDECCST
        # Issue 79428 - 2012-01-20 by CCC
#        If POLDAMT<>0
#            Call LOADVAR(PDELTA,"[F:ITV]", 0, "A", (PNEWAMT-POLDAMT) / POLDAMT, 0, 10^-GDECPRI) From FUNSADJB
#        Endif
#        Call LOADFIC("[F:ITV]",PDELTA, "A", "CST", 1, 1) From FUNSADJB
        #Call REPART2("ITV","A",[F:ITV]AVCBASAMT,PDELTA)         # 112077.o
        Call REPART3("ITV","A",[F:ITV]AVCBASAMT,GRNDVAL,PDELTA)  # 112077.n
        If [F:ITV]AVCBASQTY<>0
            #Call LOADVAR(LAVC,"[F:ITV]", 0, "A", 1 / [F:ITV]AVCBASQTY, 0, 10^-GDECPRI) From STKVALECR  # 112077.o
            Call LOADVAR(LAVC,"[F:ITV]", 0, "A", 1 / [F:ITV]AVCBASQTY, 0, GRNDVAL) From STKVALECR       # 112077.n
            Call LOADFIC("[F:ITV]",LAVC, "A", "AVC", 1, 0) From STKVALECR
        Endif
    Endif
    Call ECRTRACE (mess(124,184,1)-"AVCBASAMT="+num$([F:ITV]AVCBASAMT),0) From STKVAL
    Call REWITV From STKLIB
    If fstat
        GOK=0
        Call RSTA("ITV",[M:CGV]ITMREF-[M:CGV]STOFCY) From GLOCK
    Endif

    # Update screen values if not the entered type
    If GCGVMODIF <> 1
      [M:CGV]AVCBASAMT  = [F:ITV]AVCBASAMT
      [M:CGV]AVC        = [F:ITV]AVC
      If [M:CGV]BASAMTORI<>0
        [M:CGV]PERDEP   = arr(([F:ITV]AVCBASAMT-[M:CGV]BASAMTORI)*100/[M:CGV]BASAMTORI,0.000001)
      Endif
    Endif

End


###############################################################################
# MAJSTP: Ajoute un montant à toute la pile FIFO
###############################################################################
# Paramètres E : PDIFAMT = Montant à répercuter
#                PMOD    = Mode de répartition (2:prop cst; 3:prop qté)
###############################################################################
Subprog MAJSTP(PNEWAMT, POLDAMT, PMOD)
Value Decimal PNEWAMT
Value Decimal POLDAMT
Value Integer PMOD

If PMOD<2
    End
Endif

Local Decimal LQTYTOT : Raz LQTYTOT
Local Decimal LCSTTOT : Raz LCSTTOT
Local Decimal LDIFTOT : Raz LDIFTOT
Local Decimal LDIF    : Raz LDIF
Local Integer I

    Call ECRTRACE ("------------ STOCOST [STP] ------------",0) From STKVAL
    If POLDAMT=0
        End
    Endif

    Call INIRNDVAL("STOCOST","CST") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

    If !clalev([F:STP]) : Local File STOCOST : Endif

    Filter [F:STP] Where STOFCY =  [M:CGV]STOFCY &
&                      ITMREF =  [M:CGV]ITMREF  &
&                      QTYSTUACT > 0
&                Order By Key STP0
    For [F:STP]
        LQTYTOT += [F:STP]QTYSTUACT
        LCSTTOT += [F:STP]CST
    Next
    For [F:STP]
        Readlock [F:STP] Curr
        If PMOD=3 | LCSTTOT=0
            LDIF = arr(LCSTTOT*(PNEWAMT-POLDAMT)*[F:STP]QTYSTUACT/(POLDAMT*LQTYTOT), GRNDVAL)
        Else
            LDIF = arr((PNEWAMT-POLDAMT)*[F:STP]CST/POLDAMT, GRNDVAL)
        Endif
        If LDIF <> 0
            Call ECRTRACE ("        [F:STP]CSTCOU="+num$([F:STP]CSTCOU),0) From STKVAL
            Call ECRTRACE ("        [F:STP]CST="+num$([F:STP]CST),0) From STKVAL
            Call ECRTRACE ("        [F:STP]CST+="+num$(LDIF),0) From STKVAL
            LDIFTOT    += LDIF
            [F:STP]CST += LDIF
            If GACTDECCST
                # Issue 79428 - 2012-01-20 by CCC
                Call REPART("STP","",[F:STP]CST)
            Endif
            Call REWSTP From STKLIB
            If fstat : GOK=0 : Break : Endif
        Endif
        # Update screen values if not the entered type - needed for CGVDET records
        For I=0 To NBFIFO-1
          If [M:CGV]CSTCOU(I)=[F:STP]CSTCOU and [M:CGV]CSTDAT(I)=[F:STP]CSTDAT and [M:CGV]CSTTIM(I)=[F:STP]CSTTIM
            [M:CGV]CST(I)     = [F:STP]CST
            [M:CGV]AVCCST(I)  = arr([F:STP]CST/[F:STP]QTYSTUACT, GRNDVAL)
            Break
          Endif
        Next
    Next
    LDIF = LCSTTOT*(PNEWAMT-POLDAMT)/POLDAMT-LDIFTOT
    If GOK=1 & LDIF<>0
        Readlock [F:STP] Last    # Dernier ou premier ou peu importe ...
#       Call ECRTRACE ("    Erreur d'arrondis ("+num$(LDIF)+") répercutée sur [f:stp]cstcou"+num$([F:STP]CSTCOU),0) From STKVAL
        [F:STP]CST += LDIF
        Call REWSTP From STKLIB
        If fstat : GOK=0 : Endif
    Endif
    Filter [F:STP]
End

###############################################################################
#
# Valeur à répartir = Valeur totale des lots * PNEWAMT/POLDAMT
#
# Nouvelle valeur lot = Ancienne valeur lot
#                       + valeur à répartir * repartition
#
# si PMOD = 2 : repartition = Ancienne valeur lot / Valeur totale des lots
# si PMOD = 3 : repartition = Quantité lot / Quantité totale des lots
#
###############################################################################
Subprog MAJSLF(PVCRNUM, PNEWAMT, POLDAMT, PMOD)
Value Char    PVCRNUM
Value Decimal PNEWAMT
Value Decimal POLDAMT
Value Integer PMOD

If PMOD<2
    End
Endif

Local Decimal LQTYTOT : Raz LQTYTOT
Local Decimal LCSTTOT : Raz LCSTTOT
Local Decimal LDIFTOT : Raz LDIFTOT
Local Decimal LDIF    : Raz LDIF
Local Decimal LCUMQTY : Raz LCUMQTY
Local Integer LRET    : Raz LRET
Local Integer LVCRLIN
Local Integer I
Local Decimal LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1+1+4)  : Raz LDELTA
Local Decimal LAVC  (1+GACTMAT+GACTMAC+GACTLAB+1+1+4)  : Raz LAVC
Local Decimal LTABDEV(1+GACTMAT+GACTMAC+GACTLAB+1+1+4) : Raz LTABDEV

    Call ECRTRACE ("------------ STOLOTFCY [SLF] ---------",0) From STKVAL

    If POLDAMT=0
        End
    Endif

    If !clalev([F:SLF]) : Local File STOLOTFCY : Endif

    Call INIRNDVAL("STOLOTFCY","AVCBASAMT") From STKVALECR  # Issue 80993 - 2012-05-10 by CCC

    Filter [F:SLF] Where ITMREF=[M:CGV]ITMREF & STOFCY=[M:CGV]STOFCY
#    Call ECRTRACE ("    Calcul totaux lots",0) From STKVAL
    For [F:SLF]
        LCUMQTY=[F:SLF]AVCBASQTY
        If LCUMQTY>0
            # Issue 97591 - 2014-03-24 by CCC : filter with owner
            #For [STO] Where Key STO3(4)=[M:CGV]ITMREF;[M:CGV]STOFCY;[F:SLF]LOT;[F:SLF]SLO
            #    LCUMQTY -= [F:STO]QTYSTU
            #Next
            LCUMQTY -= func GETSTOQTYLOT([M:CGV]ITMREF,[M:CGV]STOFCY,[F:SLF]LOT,[F:SLF]SLO,"")
            If LCUMQTY=0
                LQTYTOT += [F:SLF]AVCBASQTY
                LCSTTOT += [F:SLF]AVCBASAMT
            Endif
        Endif
    Next
#    Call ECRTRACE ("        Qté tot lots="+num$(LQTYTOT)+" | Montant tot lots="+num$(LCSTTOT),0) From STKVAL
    For [F:SLF]
        LCUMQTY=[F:SLF]AVCBASQTY
        If LCUMQTY>0
            # Issue 97591 - 2014-03-24 by CCC : filter with owner
            #For [STO] Where Key STO3(4)=[M:CGV]ITMREF;[M:CGV]STOFCY;[F:SLF]LOT;[F:SLF]SLO
            #    LCUMQTY -= [F:STO]QTYSTU
            #Next
            LCUMQTY -= func GETSTOQTYLOT([M:CGV]ITMREF,[M:CGV]STOFCY,[F:SLF]LOT,[F:SLF]SLO,"")
            If LCUMQTY=0
                Readlock [F:SLF] Curr
                If PMOD=3 | LCSTTOT=0
                    LDIF = arr(LCSTTOT*(PNEWAMT-POLDAMT)*[F:SLF]AVCBASQTY/(POLDAMT*LQTYTOT), GRNDVAL)
                Else
                    LDIF = arr((PNEWAMT-POLDAMT)*[F:SLF]AVCBASAMT/POLDAMT, GRNDVAL)
                Endif
                If LDIF <> 0
                    #---- Mise à jour du lot --------#
                    Call ECRTRACE("    "+mess(3,181,1)-[F:SLF]SLO-"/"-[F:SLF]LOT-mess(33,105,1)+"="+num$([F:SLF]AVCBASQTY)-mess(32,105,1)+"="+num$([F:SLF]AVCBASAMT),0) From STKVAL
                    Call ECRTRACE("        "+mess(32,105,1)+" += "+num$(LDIF),0) From STKVAL
                    LDIFTOT       += LDIF
                    [F:SLF]AVCBASAMT += LDIF
                    # CCC (24/07/04) Bug 25236 : Le prix moyen n'était pas recalculé
                    If [F:SLF]AVCBASQTY>0
                        [F:SLF]AVC = [F:SLF]AVCBASAMT/([F:SLF]AVCBASQTY)
                    Endif
                    If GACTDECCST
                        # Issue 79428 - 2012-01-20 by CCC
                        Call REPART2("SLF","A",[F:SLF]AVCBASAMT,LDELTA)
                        If [F:SLF]AVCBASQTY<>0
                            Call LOADVAR(LAVC,"[F:SLF]", 0, "A", 1 / [F:SLF]AVCBASQTY, 0, 10^-GDECPRI) From STKVALECR
                            Call LOADFIC("[F:SLF]",LAVC, "A", "AVC", 1, 0) From STKVALECR
                        Endif
                    Endif
                    Call REWSLF From STKLIB
                    If fstat : GOK=0 : Break : Endif

                    # 116166/112688 - only record to STOJOU here if Lot average
                    If [F:TCM]ISSVLTCOD(0)=6 & ([M:CGV]REPFLG>1 | GCGVMODIF=3)
                      #------ Ecriture du mouvement dans STOJOU -----------#
                      Raz [F:STJ]
                      [F:STJ]ITMREF = [M:CGV]ITMREF
                      [F:STJ]STOFCY = [M:CGV]STOFCY
                      [F:STJ]OWNER  = [M:CGV]STOFCY
                      [F:STJ]FINRSPFCY = [F:FCY]FINRSPFCY
                      [F:STJ]UPDCOD = 2
                      [F:STJ]IPTDAT = [M:CGV]IPTDAT
                      [F:STJ]TRSTYP = 23
                      [F:STJ]VCRTYP = 30
                      [F:STJ]VCRNUM = PVCRNUM
                      [F:STJ]VCRLIN = LVCRLIN
                      [F:STJ]LOT    = [F:SLF]LOT
                      [F:STJ]SLO    = [F:SLF]SLO
                      [F:STJ]AMTVAL = LDIF
                      [F:STJ]VARVAL = LDIF
                      [F:STJ]AMTORD = LDIF
                      [F:STJ]VARORD = LDIF
                      [F:STJ]ENTCOD = [M:CGV]ENTCOD
                      [F:STJ]REGFLG = 1
                      For I=1 To GNBDIE
                          [F:STJ]CCE(I-1) = [M:CGV]CCE(I-1)
                          [F:STJ]DIE(I-1) = GDIE(I)
                      Next
                      # 112688/116166.o
                      #If GCGVMODIF=1
                      #  [F:STJ]PRINAT=5
                      #  If [M:CGV]AVCBASQTY<>0
                      #      [F:STJ]PRIORD = arr([M:CGV]AVCBASAMT/[M:CGV]AVCBASQTY,10^-GDECPRI)
                      #  Endif
                      #Endif
                      # 112688/116166.sn
                      [F:STJ]PRINAT=1
                      [F:STJ]PRIORD = [F:SLF]AVC
                      # 112688/116166.en
                      Call ECRSTJ(0,LRET) From STKLIB
                      LVCRLIN += 1000
                      Call ECRTRACE ("       [STJ]ITMREF="+[F:STJ]ITMREF-"STOFCY="+[F:STJ]STOFCY-"IPTDAT="+num$([F:STJ]IPTDAT)-"MVTSEQ="+num$([F:STJ]MVTSEQ),0) From STKVAL
                      Call ECRTRACE ("       [STJ]TRSTYP="+num$([F:STJ]TRSTYP)-"VCRTYP="+num$([F:STJ]VCRTYP)-"VCRNUM="+[F:STJ]VCRNUM,0) From STKVAL
                      Call ECRTRACE ("       [STJ]LOT="+[F:STJ]LOT-"SLO="+[F:STJ]SLO,0) From STKVAL
                      Call ECRTRACE ("       [STJ]AMTVAL=VARVAL=AMTORD=VARORD="+num$(LDIF),0) From STKVAL
                      GOK = !LRET
                      If !GOK : Break : Endif
                      GSTJFLG = [V]CST_AYES
                      #----- Enrgistrement du détail de la valeur du mouvement -----#
                      If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
                          Raz [F:SJV]
                          [F:SJV] = [F:STJ]
                          # Issue 79428 - 2012-01-20 by CCC
                          #If [F:SLF]AVCBASAMT-LDIF<>0
                          #    Call LOADFIC("[F:SLF]",LTABAVC, "A", "AVC", LDIF/([F:SLF]AVCBASAMT-LDIF), 0) From FUNSADJB
                          #Endif
                          #Call DELTA2SJV(LTABAVC, LTABDEV, 0, 1) From STKVALECR
                          Call DELTA2SJV(LDELTA, LTABDEV, 0, 1) From STKVALECR
                          Write [SJV]
                      Endif
                    Endif
                    # Update screen values if not the entered type - needed for CGVDET records
                    For I=0 To NBLOT-1
                      If [M:CGV]WLOT(I)=[F:SLF]LOT and [M:CGV]SLO(I)=[F:SLF]SLO
                        [M:CGV]LOTCST(I)  = [F:SLF]AVCBASAMT
                        [M:CGV]LOTAVC(I)  = [F:SLF]AVC
                        Break
                      Endif
                    Next
               Endif
            Endif
        Endif
    Next
    LDIF = LCSTTOT*(PNEWAMT-POLDAMT)/POLDAMT-LDIFTOT
    If GOK=1 & LDIF<>0
#        Call ECRTRACE("    Erreur d'arrondis à rajouter: "+num$(LDIF), 0) From STKVAL
        Readlock [F:SLF] Last
#        Call ECRTRACE("        Sur le lot:"+[F:SLF]LOT-" SLO="+[F:SLF]SLO, 0) From STKVAL
        [F:SLF]AVCBASAMT += LDIF
        Call REWSLF From STKLIB
        If fstat
            GOK=0
        Elsif [F:TCM]ISSVLTCOD(0)=6 & ([M:CGV]REPFLG>1 | GCGVMODIF=3) # 112077.n - Only update STJ when needed (miss from 116166/112688)
            Readlock [STJ]STJ0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
#            Call ECRTRACE("        Sur le mouvement: mvtseq="+num$([F:STJ]MVTSEQ), 0) From STKVAL
            [F:STJ]AMTVAL += LDIF
            [F:STJ]VARVAL += LDIF
            [F:STJ]AMTORD += LDIF
            [F:STJ]VARORD += LDIF
            Rewrite [F:STJ]
            If fstat : GOK=0 : Endif
        Endif
    Endif
    Filter [F:SLF]

    If [F:TCM]ISSVLTCOD(0)=6 & ([M:CGV]REPFLG>1 | GCGVMODIF=3)
      GCHGVAL = LDIFTOT
    Endif

End


###############################################################################
Subprog MAJSTPTAB(PVCRNUM,PDELTA)
Value Char    PVCRNUM
Variable Decimal PDELTA()

Local Integer I, LRET, J
Local Char    LCCSTCOU
Local Decimal LDIFQTY
Local Decimal LDIFCST
Local Char    LTIME(8)
Local Decimal LDELTA(dim(PDELTA))

Call ECRTRACE ("------------ STOCOST [STP] ------------",0) From STKVAL

If !clalev([F:STP]) : Local File STOCOST : Endif

Raz PDELTA
For I=0 To [M:CGV]NBFIFO-1
    If [M:CGV]FIFOFLG(I)=2    # Ligne modifiée
        Raz [F:STP]
        LDIFCST = [M:CGV]CST(I)-[M:CGV]CSTORI(I)
        LDIFQTY = [M:CGV]QTYSTUACT(I) - [M:CGV]QTYSTUORI(I)
        If [M:CGV]CSTCOU(I)=0    # Nouvelle ligne
            If LDIFQTY>0
                Call ECRTRACE ("    "+mess(7,112,1)+" STP",0) From STKVAL
                Call ECRTRACE ("        [F:STP]CST    = "+num$(LDIFCST),0) From STKVAL
                Call ECRTRACE ("        [F:STP]QTYSTUACT = "+num$(LDIFQTY),0) From STKVAL
                #----- Attribution du chrono couts -----#
                Call NUMERO(GSTKCPT(2),[M:CGV]STOFCY,[M:CGV]IPTDAT,"",LCCSTCOU,LRET) From SUBANM
                [F:STP]CSTDAT  =date$
                LTIME = time$
                [F:STP]CSTTIM  =left$(LTIME,2)+mid$(LTIME,4,2)+right$(LTIME,len(LTIME)-1)
                [F:STP]CSTCOU  =val(LCCSTCOU)
                [F:STP]ITMREF  =[M:CGV]ITMREF
                [F:STP]STOFCY  =[M:CGV]STOFCY
                [F:STP]CST    += LDIFCST
                [F:STP]QTYSTUACT += LDIFQTY
                [F:STP]VCRTYP  = 30
                [F:STP]VCRNUM  = PVCRNUM
                If GACTDECCST
                    # Issue 79428 - 2012-01-20 by CCC
                    Call REPART2("STP","",[F:STP]CST,LDELTA)
                    # Issue 92292 - 2013-09-05 by CCC : J à la place de I
                    For J=1 To dim(PDELTA)-1
                        PDELTA(J)+=LDELTA(J)
                    Next
                Endif
                Call ECRSTP From STKLIB
                If fstat
                    Call FSTA("STP") From GLOCK
                    GOK=0
                    Break
                Endif
                # Set the key value back to the screen for proper tracking
                [M:CGV]CSTCOU(I) = [F:STP]CSTCOU
                [M:CGV]CSTDAT(I) = [F:STP]CSTDAT
                [M:CGV]CSTTIM(I) = [F:STP]CSTTIM
            Endif
        Else    # Ancienne ligne
            Readlock [F:STP]STP0=[M:CGV]ITMREF;[M:CGV]STOFCY;[M:CGV]CSTDAT(I);[M:CGV]CSTTIM(I);[M:CGV]CSTCOU(I)
            If !fstat
                If LDIFQTY=-[F:STP]QTYSTUACT
                    Call ECRTRACE ("    "+mess(2,24,1)+" STP : CSTCOU="+num$([F:STP]CSTCOU),0) From STKVAL
                    [F:STP]QTYSTUACT=0     # CCC (2009-10-30) PE 53988
                    Call REWSTP From STKLIB
                Else
                    Call ECRTRACE ("    "+mess(3,85,1)+" STP : CSTCOU="+num$([F:STP]CSTCOU),0) From STKVAL
                    Call ECRTRACE ("        [F:STP]CST    += "+num$(LDIFCST),0) From STKVAL
                    Call ECRTRACE ("        [F:STP]QTYSTUACT += "+num$(LDIFQTY),0) From STKVAL
                    [F:STP]CST    += LDIFCST
                    [F:STP]QTYSTUACT += LDIFQTY
                    If GACTDECCST
                        # Issue 79428 - 2012-01-20 by CCC
                        Call REPART2("STP","",[F:STP]CST,LDELTA)
                        # Issue 92292 - 2013-09-05 by CCC : J à la place de I
                        For J=1 To dim(PDELTA)-1
                            PDELTA(J)+=LDELTA(J)
                        Next
                    Endif
                    Call REWSTP From STKLIB
                Endif
            Endif
            If fstat
                Call FSTA("STP") From GLOCK
                GOK=0
                Break
            Endif
        Endif
    Endif
Next
For I=0 To [M:CGV]NBDEL-1
    For [STP] Where ITMREF=[M:CGV]ITMREF & CSTCOU=[M:CGV]CSTCOUDEL(I)
        [F:STP]QTYSTUACT=0     # CCC (2009-10-30) PE 53988
        Call REWSTP From STKLIB
    Next
Next
End

###############################################################################
Subprog MAJSLFTAB(PVCRNUM)
Value Char PVCRNUM

Local Integer I, J
Local Decimal LDIFCST, LDIFTOT
Local Integer LRET
Local Integer LVCRLIN
Local Decimal LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1+1+4) : Raz LDELTA
Local Decimal LAVC(1+GACTMAT+GACTMAC+GACTLAB+1+1+4) : Raz LAVC
Local Decimal LTABDEV(1+GACTMAT+GACTMAC+GACTLAB+1+1+4) : Raz LTABDEV

Call ECRTRACE ("------------ STOLOTFCY [SLF] ------------",0) From STKVAL

If !clalev([F:SLF]) : Local File STOLOTFCY : Endif

LVCRLIN = 1000
For I=0 To [M:CGV]NBLOT-1
    If [M:CGV]LOTCST(I)<>[M:CGV]LOTCSTORI(I)    # Ancienne ligne
        LDIFCST = [M:CGV]LOTCST(I)-[M:CGV]LOTCSTORI(I)
        #----------- Enregistrement du lot -----------------#
        Readlock [F:SLF]SLF0=[M:CGV]ITMREF;[M:CGV]WLOT(I);[M:CGV]SLO(I);[M:CGV]STOFCY
        Call ECRTRACE ("    "+mess(3,85,1)+" SLF : LOT="+[F:SLF]LOT-"SLO="+[F:SLF]SLO,0) From STKVAL
        Call ECRTRACE ("        [F:SLF]AVCBASAMT    += "+num$([M:CGV]LOTCST(I)),0) From STKVAL
        [F:SLF]AVCBASAMT = [M:CGV]LOTCST(I)
        [F:SLF]AVC       = [M:CGV]LOTAVC(I)
        If GACTDECCST
            Raz LDELTA
            # Issue 79428 - 2012-01-20 by CCC
            Call REPART2("SLF","A",[F:SLF]AVCBASAMT,LDELTA)
            If [F:SLF]AVCBASQTY<>0
                Call LOADVAR(LAVC,"[F:SLF]", 0, "A", 1 / [F:SLF]AVCBASQTY, 0, 10^-GDECPRI) From STKVALECR
                Call LOADFIC("[F:SLF]",LAVC, "A", "AVC", 1, 0) From STKVALECR
            Endif
        Endif
        Call REWSLF From STKLIB
        If fstat : GOK=0 : Break : Endif

        # 112688/116166.n - Create STOJOU entry for Lot AUC only
        If [F:TCM]ISSVLTCOD(0)=6 & GCGVMODIF=3
          #------------ Enregistrement du mouvement -----------#
          Raz [F:STJ]
          [F:STJ]ITMREF = [M:CGV]ITMREF
          [F:STJ]STOFCY = [M:CGV]STOFCY
          [F:STJ]OWNER  = [M:CGV]STOFCY
          [F:STJ]FINRSPFCY = [F:FCY]FINRSPFCY
          [F:STJ]UPDCOD = 2
          [F:STJ]IPTDAT = [M:CGV]IPTDAT
          [F:STJ]TRSTYP = 23
          [F:STJ]VCRTYP = 30
          [F:STJ]VCRNUM = PVCRNUM
          [F:STJ]VCRLIN = LVCRLIN
          [F:STJ]LOT    = [F:SLF]LOT
          [F:STJ]SLO    = [F:SLF]SLO
          [F:STJ]AMTVAL = LDIFCST
          [F:STJ]VARVAL = LDIFCST
          [F:STJ]AMTORD = LDIFCST
          [F:STJ]VARORD = LDIFCST
          [F:STJ]ENTCOD = [M:CGV]ENTCOD
          [F:STJ]REGFLG = 1
          #112688/116166.n
          [F:STJ]PRINAT = 1
          [F:STJ]PRIORD = [M:CGV]LOTAVC(I)
          #112688/116166.n
          For J=1 To GNBDIE
              [F:STJ]CCE(J-1) = [M:CGV]CCE(J-1)
              [F:STJ]DIE(J-1) = GDIE(J)
          Next
          LDIFTOT += LDIFCST
          Call ECRSTJ(0,LRET) From STKLIB
          LVCRLIN += 1000
          If LRET
              GOK = 0
              Break
          Endif

          Call ECRTRACE ("        "+mess(7,112,1)+" STJ",0) From STKVAL
          Call ECRTRACE ("            ITMREF="+[F:STJ]ITMREF-"STOFCY="+[F:STJ]STOFCY-"IPTDAT="+num$([F:STJ]IPTDAT)-"MVTSEQ="+num$([F:STJ]MVTSEQ),0) From STKVAL
          Call ECRTRACE ("            TRSTYP="+num$([F:STJ]TRSTYP)-"VCRTYP="+num$([F:STJ]VCRTYP)-"VCRNUM="+[F:STJ]VCRNUM,0) From STKVAL
          Call ECRTRACE ("            LOT="+[F:STJ]LOT-"Slo="+[F:STJ]SLO,0) From STKVAL
          Call ECRTRACE ("            AMTVAL=VARVAL=AMTORD=VARORD="+num$(LDIFCST),0) From STKVAL

          GSTJFLG = [V]CST_AYES

          If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
              Raz [F:SJV]
              [F:SJV] = [F:STJ]
              # Issue 79428 - 2012-01-20 by CCC
#             If [M:CGV]LOTCSTORI(I)<>0
#                Call LOADFIC("[F:SLF]",LTABAVC, "A", "AVC", LDIFCST/[M:CGV]LOTCSTORI(I), 0) From FUNSADJB
#             Endif
#             Call DELTA2SJV(LTABAVC, LTABDEV, 0, 1) From STKVALECR
              Call DELTA2SJV(LDELTA, LTABDEV, 0, 1) From STKVALECR
              Write [SJV]
          Endif
        Endif
    Endif
Next

If [F:TCM]ISSVLTCOD(0)=6 & GCGVMODIF=3 : GCHGVAL = LDIFTOT : Endif

End


###############################################################
# Dans le cas ou on ne répartit pas selon les lots,
# on écrit un seul mouvement pour l'article (<=> pas par lot)
###############################################################
# Paramètre E : PDIF = différence de valeur (Nouvelle-Ancienne)
# Returns 0 if no STOJOU record created, 1 if record created
###############################################################
Subprog ECRONESTJ(PVCRNUM,PDIF,PDELTA)
Value Char    PVCRNUM
Value Decimal PDIF
Value Decimal PDELTA()

Local Integer LRET, I
Local Integer LVCRLIN
Local Decimal LTABNUL(dim(PDELTA)) : Raz LTABNUL

  # 116166/112688 - only record to STOJOU here if AUC or FIFO/LIFO and main tables being updated
  If ([F:TCM]ISSVLTCOD(0)=4 & ([M:CGV]REPFLG>1 | GCGVMODIF=1)) | (find([F:TCM]ISSVLTCOD(0),5,8) & ([M:CGV]REPFLG>1 | GCGVMODIF=2))

    # 116166/112688 - If just changing FIFO or Lots, but no overall change, do not create a STOJOU record
    #If [M:CGV]AMTTOTCST=[M:CGV]AVCBASAMT & ([M:CGV]AMTTOTCST=[M:CGV]AMTTOTLOT | [M:CGV]NBLOT=0) : End 0 : Endif

    LVCRLIN = 1000
    #------ Ecriture du mouvement dans STOJOU -----------#
    Raz [F:STJ]
    [F:STJ]ITMREF = [M:CGV]ITMREF
    [F:STJ]STOFCY = [M:CGV]STOFCY
    [F:STJ]OWNER  = [M:CGV]STOFCY
    [F:STJ]FINRSPFCY = [F:FCY]FINRSPFCY
    [F:STJ]UPDCOD = 2
    [F:STJ]IPTDAT = [M:CGV]IPTDAT
    [F:STJ]TRSTYP = 23
    [F:STJ]VCRTYP = 30
    [F:STJ]VCRNUM = PVCRNUM
    [F:STJ]VCRLIN = LVCRLIN
    [F:STJ]AMTVAL = PDIF
    [F:STJ]VARVAL = PDIF
    [F:STJ]AMTORD = PDIF
    [F:STJ]VARORD = PDIF
    # Pour la modif du PMP on l'enregistre dans le PRIORD afin de l'utiliser en régul des sorties
    # 116166/112688.o
    #If GCGVMODIF=1
    #    [F:STJ]PRINAT=5
    #    If [M:CGV]AVCBASQTY<>0
    #        [F:STJ]PRIORD = arr([M:CGV]AVCBASAMT/[M:CGV]AVCBASQTY,10^-GDECPRI)
    #    Endif
    #Endif
    # 116166/112688.sn
    [F:STJ]PRINAT=1
    If [M:CGV]AVCBASQTY<>0
      Case GCGVMODIF
        When 1 : [F:STJ]PRIORD = arr([M:CGV]AVCBASAMT/[M:CGV]AVCBASQTY,10^-GDECPRI)
        When 2 : [F:STJ]PRIORD = arr([M:CGV]AMTTOTCST/[M:CGV]AVCBASQTY,10^-GDECPRI)
        When 3 : [F:STJ]PRIORD = arr([M:CGV]AMTTOTLOT/[M:CGV]AVCBASQTY,10^-GDECPRI)
      Endcase
    Endif
    # 116166/112688.en
    #If no difference, don't put in an ETNCOD in STOJOU. Entered ENTCOD will be recorded in CHGVAL table
    If PDIF <> 0 : [F:STJ]ENTCOD = [M:CGV]ENTCOD : Endif
    [F:STJ]REGFLG = 1
    For I=1 To GNBDIE
        [F:STJ]CCE(I-1) = [M:CGV]CCE(I-1)
        [F:STJ]DIE(I-1) = GDIE(I)
    Next
    Call ECRSTJ(0,LRET) From STKLIB
    Call ECRTRACE ("        "+mess(7,112,1)+" STJ",0) From STKVAL
    Call ECRTRACE ("            ITMREF="+[F:STJ]ITMREF-"STOFCY="+[F:STJ]STOFCY-"IPTDAT="+num$([F:STJ]IPTDAT)-"MVTSEQ="+num$([F:STJ]MVTSEQ),0) From STKVAL
    Call ECRTRACE ("            TRSTYP="+num$([F:STJ]TRSTYP)-"VCRTYP="+num$([F:STJ]VCRTYP)-"VCRNUM="+[F:STJ]VCRNUM,0) From STKVAL
    Call ECRTRACE ("            AMTVAL=VARVAL=AMTORD=VARORD="+num$(PDIF),0) From STKVAL
    Call ECRTRACE ("            PRIORD="+num$([F:STJ]PRIORD),0) From STKVAL
    GOK = !LRET
    If GOK : GSTJFLG = [V]CST_AYES : Endif
    If GACTDECCST & [F:STJ]CREMVTDAT>=GDATDECCST
        Raz [F:SJV]
        [F:SJV] = [F:STJ]
        Call DELTA2SJV(PDELTA, LTABNUL, 0, 1) From STKVALECR
        Write [SJV]
    Endif
  Endif #116166/112688.n
End

###############################################################################
Subprog MAJ_CHGVAL(CGVNUM)
Value Char CGVNUM

  Raz [F:CGV]

  [F:CGV]CGVNUM       = [L]CGVNUM
  [F:CGV]STOFCY       = [M:CGV]STOFCY
  [F:CGV]ITMREF       = [M:CGV]ITMREF
  [F:CGV]IPTDAT       = [M:CGV]IPTDAT
  [F:CGV]CGVMOD       = GCGVMODIF
  [F:CGV]CGVAMT       = GCHGVAL
  [F:CGV]REPFLG       = [M:CGV]REPFLG
  [F:CGV]STJFLG       = GSTJFLG
  [F:CGV]ENTCOD       = [M:CGV]ENTCOD
  [F:CGV]ISSVLTCOD(0) = [F:TCM]ISSVLTCOD(0)
  [F:CGV]ISSVLTCOD(1) = [F:TCM]ISSVLTCOD(1)

  Write [CGV]
  If fstat : GOK=0 : Endif
End

###############################################################################
Subprog MAJ_CGVDET(CGVNUM)
Value Char CGVNUM

  Local Integer I

  # Overall value - AVC block
  If GCGVMODIF = 1 or [M:CGV]REPFLG > 1
    Raz [F:CGVD]
    [F:CGVD]CGVNUM      = [L]CGVNUM
    [F:CGVD]CGVTYP      = 1
    [F:CGVD]AMT         = [M:CGV]AVCBASAMT
    [F:CGVD]AMTORI      = [M:CGV]BASAMTORI
    [F:CGVD]ACTQTY      = [M:CGV]AVCBASQTY
    [F:CGVD]ACTQTYORI   = [M:CGV]AVCBASQTY
    [F:CGVD]PERDEP      = [M:CGV]PERDEP
    [F:CGVD]AVC         = [M:CGV]AVC
    Write [CGVD]
    If fstat : GOK=0 : End : Endif
  Endif

  # FIFO Tier modification
  If GCGVMODIF = 2 or [M:CGV]REPFLG > 1
    For I = 0 To NBFIFO-1
      Raz [F:CGVD]
      [F:CGVD]CGVNUM    = [L]CGVNUM
      [F:CGVD]CGVTYP    = 2
      [F:CGVD]CSTCOU    = [M:CGV]CSTCOU(I)
      [F:CGVD]CSTDAT    = [M:CGV]CSTDAT(I)
      [F:CGVD]CSTTIM    = [M:CGV]CSTTIM(I)
      [F:CGVD]AMT       = [M:CGV]CST(I)
      [F:CGVD]AMTORI    = [M:CGV]CSTORI(I)
      [F:CGVD]ACTQTY    = [M:CGV]QTYSTUACT(I)
      [F:CGVD]ACTQTYORI = [M:CGV]QTYSTUORI(I)
      [F:CGVD]AVC       = [M:CGV]AVCCST(I)
      Write [CGVD]
      If fstat : GOK=0 : End : Endif
    Next
  Endif

  # Lot value modification
  If GCGVMODIF = 3 or [M:CGV]REPFLG > 1
    For I = 0 To NBLOT-1
      If 1=1
        Raz [F:CGVD]
        [F:CGVD]CGVNUM    = [L]CGVNUM
        [F:CGVD]CGVTYP    = 3
        [F:CGVD]LOT       = [M:CGV]WLOT(I)
        [F:CGVD]SLO       = [M:CGV]SLO(I)
        [F:CGVD]AMT       = [M:CGV]LOTCST(I)
        [F:CGVD]AMTORI    = [M:CGV]LOTCSTORI(I)
        [F:CGVD]ACTQTY    = [M:CGV]LOTQTYACT(I)
        [F:CGVD]ACTQTYORI = [M:CGV]LOTQTYACT(I)
        [F:CGVD]AVC       = [M:CGV]LOTAVC(I)
        Write [CGVD]
        If fstat : GOK=0 : End : Endif
      Endif
    Next
  Endif

End
#**
#* REPART : Répartit un montant total sur les détails
#* ##################################################
#* @param PABRFIC : Abréviation fichier
#* @param PREFIX  : Préfixe des zones de détail
#* @param PNEWTOT : Nouvelle valeur du total
#*!
Subprog REPART(PABRFIC,PREFIX,PNEWTOT)
Value Char PABRFIC
Value Char PREFIX
Value Decimal PNEWTOT
Local Decimal LDELTA(1+GACTMAT+GACTMAC+GACTLAB+1+1+4)

Call REPART2(PABRFIC,PREFIX,PNEWTOT,LDELTA)

End

#**
#* REPART2 : Répartit un montant total sur les détails
#* ##################################################
#* @param PABRFIC : Abréviation fichier
#* @param PREFIX  : Préfixe des zones de détail
#* @param PNEWTOT : Nouvelle valeur du total
#* @param PDELTA (sortie) : Détail des variations appliquées dans le fichier
#*!
Subprog REPART2(PABRFIC,PREFIX,PNEWTOT,PDELTA)
Value Char PABRFIC
Value Char PREFIX
Value Decimal PNEWTOT
Variable Decimal PDELTA()

# Issue 112077 - 2017-01-31 by ERMIL : Added new REPART3 to allow passing in specific rounding precision
Call REPART3(PABRFIC,PREFIX,PNEWTOT,10^-GDECPRI,PDELTA)

End

#**
#* REPART3 : Répartit un montant total sur les détails
#* ##################################################
#* @param PABRFIC : Abréviation fichier
#* @param PREFIX  : Préfixe des zones de détail
#* @param PNEWTOT : Nouvelle valeur du total
#* @param PRNDVAL : Rounding precision
#* @param PDELTA (sortie) : Détail des variations appliquées dans le fichier
#*!
Subprog REPART3(PABRFIC,PREFIX,PNEWTOT,PRNDVAL,PDELTA)
Value Char PABRFIC
Value Char PREFIX
Value Decimal PNEWTOT
Value Decimal PRNDVAL
Variable Decimal PDELTA()

Local Decimal LAMTDET(1+GACTMAT+GACTMAC+GACTLAB+1+1+4)

        Call LOADVAR(LAMTDET,"[F:"+PABRFIC+"]", 0, PREFIX, 1, 0, PRNDVAL) From STKVALECR
        If sum(LAMTDET)=0
            Call LOADFIC("[F:"+PABRFIC+"]",LAMTDET, PREFIX, "CST", 0, 0) From STKVALECR
            Assign "[F:"+PABRFIC+"]"+PREFIX+"MATCST(max(0,[F:ITM]BRDCOD-1))" With PNEWTOT

            # 112077.n - Load PDELTA with the values from the table
            Call LOADVAR(PDELTA,"[F:"+PABRFIC+"]", 0, PREFIX, 1, 0, PRNDVAL) From STKVALECR

        Else
            #Call LOADFIC("[F:"+PABRFIC+"]",LAMTDET, PREFIX, "CST", PNEWTOT/sum(LAMTDET), 0) From STKVALECR   # 112077.o
            # 112077.n - use LOADVAR to load PDELTA so PRNDVAL is taken into account with the COE
            Call LOADVAR(PDELTA,"[F:"+PABRFIC+"]", 0, PREFIX, PNEWTOT/sum(LAMTDET), 0, PRNDVAL) From STKVALECR
            Call LOADFIC("[F:"+PABRFIC+"]",PDELTA, PREFIX, "CST", 1, 0) From STKVALECR
        Endif
        #Call LOADVAR(PDELTA,"[F:"+PABRFIC+"]", 0, PREFIX, 1, 0, PRNDVAL) From STKVALECR  # 112077.o - being loaded above
        For I=1 To dim(PDELTA)-1
            PDELTA(I)-=LAMTDET(I)
        Next
End

#**----------------------------------------------------------------<br/>
#* GETSTOQTYLOT : return quantity in STOCK for a lot
#**<br/>----------------------------------------------------------------<br/>
#* @param PITM = Item
#* @param PFCY = site
#* @param PLOT = lot number
#* @param PSLO = sub-lot number
#**<br/>----------------------------------------------------------------
#*!
Funprog GETSTOQTYLOT(PITM,PFCY,PLOT,PSLO,PSUP)
Value Char PITM
Value Char PFCY
Value Char PLOT
Value Char PSLO
Value Char PSUP

If clalev([F:STO])=0 : Local File STOCK [STO] : Endif

Local Decimal LQTY

For [STO] reckey Where ITMREF = PITM
&                & STOFCY = PFCY
&                & OWNER  = PFCY
&                & LOT    = PLOT
&                & SLO    = PSLO
    LQTY += [F:STO]QTYSTUACT
Next

End LQTY

