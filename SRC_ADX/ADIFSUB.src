#<AdxTL>@(#)3.0.0.0 $Revision$
Call DIFSUB
End

#--------------------------------------------------------------#
Subprog DIFSUB
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ADIFSUB","ADIF",3,"") From GTRAITE
End

#--------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#--------------------------------------------------------------#
$INIT
Local Char DOSORG(250) , DOSDES(250) 
TIT = mess(196,115,1) : # Différence sous-programmes
Return

#--------------------------------------------------------------#
$INIT_DIA
[M]OBJET = TIT
Return

#--------------------------------------------------------------#
$CONTROLE
DOSORG = [M]DOSORG
DOSDES = [M]DOSDES
Return

#--------------------------------------------------------------#
$EXEC
If !GSERVEUR
 Call OUVRE_BOITE(TIT,0) From GESECRAN
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Gosub TRTDIFSUB
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call FERME_BOITE From GESECRAN
Endif
TRA = 1
Return

#--------------------------------------------------------------#
$TRTDIFSUB
Local Integer  MAXSUB , MAXTRT , MAXPAR
MAXSUB = 200
MAXTRT = 30000
MAXPAR = 150
Local Integer  STAT , NBORG , NBDES , NBSUB , NBBOI , SEK
Local Char     ORDSYS(255)(1..2) , TRTSUB(30)(1..MAXSUB)
Local Integer  SUBFCT(1..MAXSUB) , SEKSUB(1..MAXSUB)
Local Char     TRTORG(GLONADC)(1..MAXTRT) , APPORG(GLONADS) , MACORG(GLONAMC)
Local Char     TRTDES(GLONADC)(1..MAXTRT) , APPDES(GLONADS) , MACDES(GLONAMC)
Local Integer  RELORG(10) , RELDES(10)
Local Char     LIGNE(250) , MOTCLE(250) , CRITERE(250)
Local Integer  C , S , INTERRUPT
Local Char     TBPAR(30)(1..MAXPAR) , TBPAR2(30)(1..MAXPAR)
Local Integer  TBTYP(1..MAXPAR) , TBADR(1..MAXPAR) , TBTYP2(1..MAXPAR) , TBADR2(1..MAXPAR)
Local Integer  FCT , NBPAR , FCT2 , NBPAR2

MOTCLE   = sigma(0,25,chr$(65+indcum))
MOTCLE  += sigma(0,25,chr$(97+indcum))
MOTCLE  += sigma(0,9,chr$(48+indcum))
MOTCLE  += "-_"
CRITERE  = 'left$(TRTORG(C),1)<>"W"'
CRITERE += ' & find(TRTORG(C),TRTDES)'
#CRITERE += ' & [F:ADC]MODULE=1 & TRTORG(C)="GESECRAN"'

Call MACHINE(DOSORG,MACORG,APPORG) From ORDSYS
ORDSYS(1) = "lsadx -a "+APPORG+" TRT src"
Call SYSTEME2(MACORG,ORDSYS(1),"",NBORG,TRTORG) From ORDSYS
NBORG = min(NBORG,dim(TRTORG))
Local File =DOSORG+".ADOVAL" [AD2]
Read [AD2]ADW0="";"";"RELEASE"
RELORG = val([F:AD2]VALEUR)
Close Local File [AD2]

Call MACHINE(DOSDES,MACDES,APPDES) From ORDSYS
ORDSYS(1) = "lsadx -a "+APPDES+" TRT src"
Call SYSTEME2(MACDES,ORDSYS(1),"",NBDES,TRTDES) From ORDSYS
NBDES = min(NBDES,dim(TRTDES))
Local File =DOSDES+".ADOVAL" [AD2]
Read [AD2]ADW0="";"";"RELEASE"
RELDES = val([F:AD2]VALEUR)
Close Local File [AD2]

If filinfo(filpath("FIL","ADICTRT","srf",DOSORG),0)>0
 If DOSORG=nomap
  Local File ADICTRT [ADC]
 Else
  Local File =DOSORG+".ADICTRT" [ADC]
 Endif
Endif

Raz NBBOI
For C=1 To NBORG
 If clalev([F:ADC])>0
  Read [ADC]ADC0=TRTORG(C)
  If fstat : Raz [F:ADC] : Endif
 Endif
 If evalue(CRITERE)
  NBBOI += 1
 Endif
Next C
Call SET_BOITE(TIT,NBBOI) From GESECRAN

Raz NBBOI
For C=1 To NBORG
 If clalev([F:ADC])>0
  Read [ADC]ADC0=TRTORG(C)
  If fstat : Raz [F:ADC] : Endif
 Endif
 If evalue(CRITERE)
  NBBOI += 1
  Call AFF_BOITE(TRTORG(C),NBBOI,INTERRUPT) From GESECRAN
  Gosub CHERCHE_SUB
  For S=1 To NBSUB
   Case SUBFCT(S)
    When 1       : MESSA = "Subprog"
    When 2       : MESSA = "Funprog"
    When Default : MESSA = ""
   Endcase
   MESSA -= TRTSUB(S)-"From"-TRTORG(C)-":"
   Call CHERCHE_PAR(filpath("TRT",TRTORG(C),"src",DOSORG),TRTSUB(S),SEKSUB(S),RELORG,FCT,NBPAR,TBPAR,TBTYP,TBADR)
   If NBPAR=-1
    Call ECR_TRACE("Subprog"-TRTSUB(S)-"From"-TRTORG(C)-":"-mess(14,135,1),1) From GESECRAN
   Elsif !FCT
    # Sous-programme inexistant 
    #Call ECR_TRACE(MESSA-mess(71,150,1),0) From GESECRAN
   Else
    Call CHERCHE_PAR(filpath("TRT",TRTORG(C),"src",DOSDES),TRTSUB(S),0,RELDES,FCT2,NBPAR2,TBPAR2,TBTYP2,TBADR2)
    If NBPAR2=-1
     Call ECR_TRACE("Subprog"-TRTSUB(S)-"From"-TRTORG(C)-":"-mess(14,135,1),1) From GESECRAN
    Elsif !FCT2
     # Sous-programme inexistant 
     #Call ECR_TRACE(MESSA-mess(71,150,1)-DOSDES,0) From GESECRAN
    Elsif NBPAR<>NBPAR2
     # Nombre d'arguments différents
     Call ECR_TRACE(MESSA-mess(193,115,1)-"("+num$(NBPAR2)+"/"+num$(NBPAR)+")",1) From GESECRAN
    Else
     For I=1 To NBPAR
      If TBTYP(I)<>TBTYP2(I)
       # Type interne différent
       Call ECR_TRACE(MESSA-TBPAR(I)-mess(194,115,1)-"("+mess(TBTYP2(I),33,1)+"/"+mess(TBTYP(I),33,1)+")",1) From GESECRAN
      Elsif TBADR(I)<>TBADR2(I)
       # Adressage différent
       Call ECR_TRACE(MESSA-TBPAR(I)-mess(195,115,1)-"(Variable/Value)",1) From GESECRAN
      Endif
     Next I
    Endif
   Endif     
  Next S
 Endif
Next C
Return

#--------------------------------------------------------------#
$CHERCHE_SUB
NBSUB = 0
If filinfo(filpath("TRT",TRTORG(C),"src",DOSORG),0)<=0 : Return : Endif
Openi filpath("TRT",TRTORG(C),"src",DOSORG) Using [SSS]
Iomode adxifs "" Using [SSS]
Iomode adxirs chr$(10) Using [SSS]
If RELORG<14
 Iomode adxium GASCII Using [SSS]
Else
 Iomode adxium GUTF8 Using [SSS]
Endif  
SEK = adxseek("SSS")
Rdseq LIGNE Using [SSS]
While fstat=0
 LIGNE = vireblc(LIGNE,2)
 Case left$(LIGNE,7)
  When "Subprog" : FCT = 1
  When "Funprog" : FCT = 2
  When Default   : FCT = 0
 Endcase
 If FCT<>0
  LIGNE = vireblc(right$(LIGNE,8),2)
  K = len(LIGNE)
  For I=1 To K
   If !instr(1,MOTCLE,mid$(LIGNE,I,1))
    K = I-1 : Break
   Endif
  Next I
  If K>0
   If NBSUB<dim(TRTSUB)
    NBSUB += 1
    TRTSUB(NBSUB) = left$(LIGNE,K)
    SUBFCT(NBSUB) = FCT
    SEKSUB(NBSUB) = SEK
   Else
    Call ECR_TRACE(func AFNC.MES(mess(214,115,1),TRTORG(C)),0) From GESECRAN : # Trop de sous-programmes dans #
    Break
   Endif
  Endif
 Endif
 SEK = adxseek("SSS")
 Rdseq LIGNE Using [SSS]
Wend
Openi Using [SSS]
Return

#----------------------------------------------------------------------------#
Subprog CHERCHE_PAR(TRAIT,SUB,SEK,RELEASE,FCT,NBPAR,TBPAR,TBTYP,TBADR)
Value    Char    TRAIT , SUB
Value    Integer SEK , RELEASE
Variable Integer FCT
Variable Integer NBPAR
Variable Char    TBPAR()(1..)
Variable Integer TBTYP(1..) , TBADR(1..)
Local Integer I , J , K , TP , TYP, DIMC, K1, K2, K3, KJ , L , NOKPAR
Local Char    LIGNE(250) , LIGNE2(250), AVARC, AVART, CNSUB(50)
Local Char    LIGNEIN(250)(1..10)
Local Integer NBIN, INBIN
Raz NBPAR , FCT , NOKPAR
If filinfo(TRAIT,0)>0
 Openi TRAIT Using [TTT]
 Iomode adxifs "" Using [TTT]
 Iomode adxirs chr$(10) Using [TTT]
 If RELEASE<14
  Iomode adxium GASCII Using [TTT]
 Else
  Iomode adxium GUTF8 Using [TTT]
 Endif
 Seek First+SEK Using [TTT]
 Rdseq LIGNE Using [TTT]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  Case left$(LIGNE,7)
   When "Subprog" : FCT = 1
   When "Funprog" : FCT = 2
   When Default   : FCT = 0
  Endcase
  If FCT<>0
   LIGNE = vireblc(right$(LIGNE,8),2)
   NBIN=1
   LIGNEIN(NBIN)=LIGNE
   KJ=instr(1,LIGNE,"(")
   If KJ=0
    CNSUB=vireblc(left$(LIGNE,len(SUB)+1),2)
   Elsif KJ>len(SUB)
    CNSUB=vireblc(mid$(LIGNE,len(SUB)+1,KJ-len(SUB)),2)
   Else
    CNSUB=""
   Endif
   If LIGNE=SUB | (left$(LIGNE,len(SUB))=SUB & CNSUB="(")
    While 1
     Rdseq LIGNE2 Using [TTT]
     If left$(LIGNE2,1)="&"
      If len(LIGNEIN(NBIN))+len(vireblc(right$(LIGNE2,2),2))<250
        LIGNEIN(NBIN)+=vireblc(right$(LIGNE2,2),2)
      Else
        If right$(LIGNEIN(NBIN),len(LIGNEIN(NBIN)))<>","
          LIGNEIN(NBIN)+=","
        Endif
        NBIN+=1
        If left$(vireblc(right$(LIGNE2,2),2),1)=","
          LIGNEIN(NBIN)=vireblc(right$(LIGNE2,2),2)
        Else
          LIGNEIN(NBIN)=","+vireblc(right$(LIGNE2,2),2)
        Endif
      Endif
     Else
      Break
     Endif
    Wend
    INBIN=1
    LIGNE=LIGNEIN(INBIN)
    K = instr(1,LIGNE,"(")
    If K
     While 1
      J = instr(K+1,LIGNE,",")
      If J
       If NBPAR>=dim(TBPAR)
        NOKPAR = 1
       Else
        NBPAR += 1
        TBPAR(NBPAR) = vireblc(seg$(LIGNE,K+1,J-1),2)
       Endif
       K = J
      Else
       J = instr(K+1,LIGNE,")")
       If J
        If NBPAR>=dim(TBPAR)
         NOKPAR = 1
        Else
         NBPAR += 1
         TBPAR(NBPAR) = vireblc(seg$(LIGNE,K+1,J-1),2)
        Endif
        K = J
        Break
       Else
        If INBIN<NBIN
          INBIN+=1
          LIGNE=LIGNEIN(INBIN)
          K= 1
        Else
          Break
        Endif
       Endif
      Endif
     Wend
    Endif
    LIGNE = LIGNE2
    While 1
     LIGNE = vireblc(LIGNE,2)
     If LIGNE="" | left$(LIGNE,1)="#"
      TYP = 0
     Elsif left$(LIGNE,5)="Value"
      TYP = 2
      LIGNE = vireblc(right$(LIGNE,6),2)
     Elsif left$(LIGNE,8)="Variable"
      TYP = 1
      LIGNE = vireblc(right$(LIGNE,9),2)
     Else
      Break
     Endif
     If TYP
      TP = 0
      L = 0
      If    left$(LIGNE,4)="Char"     : TP = 1 : L = 4
      Elsif left$(LIGNE,7)="Integer"  : TP = 2 : L = 7
      Elsif left$(LIGNE,8)="Shortint" : TP = 8 : L = 8
      Elsif left$(LIGNE,7)="Decimal"  : TP = 3 : L = 7
      Elsif left$(LIGNE,4)="Date"     : TP = 4 : L = 4
      Elsif left$(LIGNE,7)="Libelle"  : TP = 5 : L = 7
      Elsif left$(LIGNE,7)="Clbfile"  : TP = 6 : L = 7
      Elsif left$(LIGNE,7)="Blbfile"  : TP = 7 : L = 7
      Endif
      LIGNE = vireblc(right$(LIGNE,L+1),2)
      While LIGNE<>""
       K = instr(1,LIGNE,",")
       If K
        AVART = left$(LIGNE,K-1)
        LIGNE = right$(LIGNE,K+1)
       Else
        AVART = LIGNE
        LIGNE = ""
       Endif
       AVARC = vireblc(AVART,2)
       K = instr(1,AVARC,"(")
       If K
        AVARC = vireblc(left$(AVARC,K-1),2)
       Endif
       K = instr(1,AVARC,":")
       If K
        AVARC = vireblc(left$(AVARC,K-1),2)
       Endif
       K = find(AVARC,TBPAR(1..NBPAR))
       If K
        TBTYP(K) = TP
        TBADR(K) = TYP
       Endif
      Wend
     Endif
     Rdseq LIGNE Using [TTT]
     If fstat : Break : Endif
    Wend
    Break
   Else
    FCT = 0
   Endif
  Endif
  Rdseq LIGNE Using [TTT]
 Wend
 Openi Using [TTT]
Endif
If NOKPAR
 NBPAR = -1
Endif
End
