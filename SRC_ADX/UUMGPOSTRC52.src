#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGPOSTRC52                                         Module Commun Data  #
#                                                                          #
#              Post-migration of Purchase/BP Invoices                      #
#                                                                          #
# Management of news fields : FIY/PER                                      #
#                                                                          #
############################################################################


Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSTRC52") From LECFIC
  Endif

  #Call RAZ_UUMGPOSTRC52(DOSSIER)
  Call MAJ_UUMGPOSTRC52(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSTRC52(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSTRC52",ERR) From TRTMIG

End

###################################################################################
Subprog MAJ_UUMGPOSTRC52(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(8)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGPOSTRC52 Open items Process : Update PINVOICE - Fields : FIY/PER") From DOSSUB
Call ECR_TRACE("UUMGPOSTRC52 : Process Start on : "+DOSSIER,0) From GESECRAN

If clalev([F:PIH]) : Close File [PIH] : Endif
#--------------- Index addition  ----------#
Call MIGINDCRE (DOSSIER,"PINVOICE","CPY+ACCDAT+NUM","","",0,ERR) From TRTMIG
If ERR :
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",7,ERR) From TRTMIG : Goto FIN
Endif

#--------------- Opening of files  -----#
If clalev([F:PIH])  = 0 : Local File =DOSSIER+".PINVOICE"  [PIH]  : Endif      # Sales/BP Invoices
If clalev([F:GCM])  = 0 : Local File =DOSSIER+".GACM"      [GCM]  : Endif      # Account core model
If clalev([F:CPY])  = 0 : Local File =DOSSIER+".COMPANY"   [CPY]  : Endif      # Company
If clalev([F:PER])  = 0 : Local File =DOSSIER+".PERIOD"    [PER]  : Endif      # Fiscal periods

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3
Local Date DCLE1

# Common variable declaration
Local Char COMPANY(GLONCPY)
Local Libelle LEDGENMAIN
Local Decimal EXERCICE, PERIODE
Local Date    DAT

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_COM02
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:PIH]PER=0 & [F:PIH]CPY='"+ACLE1+"' & [F:PIH]ACCDAT=["+format$(GFMD,DCLE1)+"] & [F:PIH]NUM>'"+ACLE2+"'"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:PIH]PER=0 & [F:PIH]CPY='"+ACLE1+"' & [F:PIH]ACCDAT>["+format$(GFMD,DCLE1)+"]"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:PIH]PER=0 & [F:PIH]CPY>'"+ACLE1+"'"
Else
 CRITERE = "[F:PIH]PER=0 & 1=1"
Endif

Trbegin [PIH]
GOK = 1

For [PIH]MIG(1) Where evalue(CRITERE)

 # By company - Reading of Main General Ledger
 [L]COMPANY = [F:PIH]CPY
 If [F:CPY]CPY<>[L]COMPANY
  Read [CPY]CPY0 =  [L]COMPANY
  # Non-existent Company
  If fstat : GOK = 0 : Call ERREUR("PINVOICE"-[L]COMPANY-mess(16,104,1),4) From DOSDIC : Break : Endif
 Endif
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGENMAIN = [F:GCM]GENLEDTYP

 For [PIH]MIG(2)

  # By due date - Reading of Fiscalyear and Fiscal Period
  [L]DAT = [F:PIH]ACCDAT
  Gosub GETPERSOC
   If [L]EXERCICE=0 or [L]PERIODE=0
   # Incorrect Period
   Call ERREUR("PINVOICE"-[L]COMPANY-num$([L]LEDGENMAIN)-format$(GFMD,[L]DAT)-mess(10,116,1),4) From DOSDIC : Goto NEXT1
  Endif

  For [PIH]MIG

   NBLUS+=1

   #--- New field assignation
   [F:PIH]FIY=[L]EXERCICE
   [F:PIH]PER=[L]PERIODE

   Rewrite [F:PIH]
   If fstat
    Call ECR_TRACE("File PINVOICE(NUM)"-[F:PIH]NUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break 3
   Endif

   NBCOMMIT += 1
   NB+=1
   If NB>GMAXUPDTRS
    ACLE1 = [F:PIH]CPY
    DCLE1 = [F:PIH]ACCDAT
    ACLE2 = [F:PIH]NUM
    STOP=1
    Break 3
   Endif
  Next
 $NEXT1
 Next
Next

If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC52",7,ERR) From TRTMIG
Else
  Commit
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSTRC52",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_COM02
  Endif
Endif

Close Local File [PIH]
#--------------- Deleting an index ----------#
Call MIGINDDEL (DOSSIER,"PINVOICE",ERR) From TRTMIG

Gosub UNSET_FIRST From TRTFIRST

$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSTRC52") From TRTMIG
Call ECR_TIME("UUMGPOSTRC52 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


#############################################################################################################
$GETPERSOC
If [L]DAT>=[F:PER]PERSTR & [L]DAT<=[F:PER]PEREND &  [L]COMPANY=[F:PER]CPY & [L]LEDGENMAIN=[F:PER]LEDTYP
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
 Return
Endif
For [PER]PER0 Where [F:PER]CPY=[L]COMPANY & [F:PER]PERSTR<=[L]DAT & [F:PER]PEREND>=[L]DAT & [F:PER]LEDTYP=[L]LEDGENMAIN
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
Next
Return

