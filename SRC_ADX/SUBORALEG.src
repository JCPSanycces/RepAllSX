############################################################
#
# Library of Legislation procedures for Organisation screens
#
# Window  : OORA
# Screens : ORA0
#
############################################################


########################################
#Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
  #MIPEA - 2016-10-10 - X3PEOP-907 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  Case GCURLEG
   When "FRA"
     Chgfmt [M:ORA0]TYPIRC       With "LA:10386"  #Type
   When Default
     Chgfmt [M:ORA0]TYPIRC       With "-LA:10386"  : Raz [M:ORA0]TYPIRC : #Type
  Endcase
Endif
#MIPEA - 2016-10-10 - X3PEOP-907 - END
End

