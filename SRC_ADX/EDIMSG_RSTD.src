#********************************************************************
# Subprog GET_IMPORTMODELE_DETAILS
#********************************************************************
#
#*
#* @param WOBJECT
#*!
Subprog GET_IMPORTMODELE_DETAILS(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local File AOBJEXT [AOE]
  Read [AOE]AOE0 = WOBJECT.MSGTPL
  If !fstat
    WOBJECT.APARENT.TYPFIL = [AOE]TYPFIL
    WOBJECT.APARENT.CODDBA = [AOE]CODDBA
    WOBJECT.APARENT.FLDLIM = [AOE]FLDLIM
    WOBJECT.APARENT.SEPREC = [AOE]SEPREC
    WOBJECT.APARENT.SEPFLD = [AOE]SEPFLD
    WOBJECT.APARENT.SEPDEC = [AOE]SEPDEC
    WOBJECT.APARENT.OPTDAT = [AOE]OPTDAT
    Case [AOE]OPTDAT
      When 1 : WOBJECT.APARENT.LIBDAT = right$(mess(15,141,1),4)  : # 1 : JJMMAA
      When 2 : WOBJECT.APARENT.LIBDAT = right$(mess(16,141,1),4)  : # 2 : JJMMAAAA
      When 3 : WOBJECT.APARENT.LIBDAT = right$(mess(17,141,1),4)  : # 3 : AAMMJJ
      When 4 : WOBJECT.APARENT.LIBDAT = right$(mess(18,141,1),4)  : # 4 : AAAAMMJJ
      When 5 : WOBJECT.APARENT.LIBDAT = right$(mess(175,141,1),4) : # 5 : AAAA-MM-JJ
      When Default : WOBJECT.APARENT.LIBDAT = ""
    Endcase
    WOBJECT.APARENT.OPTMNL = [AOE]OPTMNL
    WOBJECT.APARENT.OPTCHA = [AOE]OPTCHA
  Else
    WOBJECT.APARENT.TYPFIL = 1
    WOBJECT.APARENT.CODDBA = 1
    WOBJECT.APARENT.FLDLIM = ""
    WOBJECT.APARENT.SEPREC = ""
    WOBJECT.APARENT.SEPFLD = ""
    WOBJECT.APARENT.SEPDEC = ""
    WOBJECT.APARENT.OPTDAT = 0
    WOBJECT.APARENT.LIBDAT = ""
    WOBJECT.APARENT.OPTMNL = 0
    WOBJECT.APARENT.OPTCHA = 1
  Endif
  LogicClose File [AOE]
End

