###############################################################################
# Representation Class EDIMSG                                                 #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When "" :
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
        When "AREAD_AFTER"           : Gosub AREAD_AFTER
        When Default
      Endcase
    When "EMS" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EMS_AREAD_AFTER
      Endcase
    When "EMS.EMSD" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EMS_EMSD_AREAD_AFTER
      Endcase
    When "EMS.EMSA" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EMS_EMSA_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "EMS.MSGTYP"
      Case [L]ARULE
        When "PROPAGATE"  : Gosub EMS_MSGTYP_PROPAGATE
      Endcase
    When "EMS.MSGDIR"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMS_MSGDIR_PROPAGATE
      Endcase
    When "EMS.MSGOPE"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMS_MSGOPE_PROPAGATE
      Endcase
    When "EMS.MSGTPL"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMS_MSGTPL_PROPAGATE
      Endcase
    When "EMS.DRTPDF"
      Case [L]ARULE
        When "PROPAGATE": Gosub EMS_DRTPDF_PROPAGATE
      Endcase
    When "EMS.CATCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMS_CATCOD_PROPAGATE
      Endcase
  Endcase
Return


####################################################################

$EMS_MSGDIR_PROPAGATE
  Call EMS_DISPLAY(this)
Return

####################################################################

$EMS_MSGOPE_PROPAGATE
  Call EMS_DISPLAY(this)
Return

####################################################################

$EMS_MSGTYP_PROPAGATE
  Call EMS_DISPLAY(this)
  Local Integer I
  For I = 1 To maxtab(this.EMSD)
    Call EMS_EMSD_DISPLAY(this.EMSD)
  Next I
Return

####################################################################

$EMS_CATCOD_PROPAGATE
  Call EMS_DISPLAY(this)

  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.APARENT.CATOPE = 2 #Create
  Else
    this.APARENT.CATOPE = WCATOPE
  Endif
Return

####################################################################

$EMS_MSGTPL_PROPAGATE
  Call EMS_DISPLAY(this)
  Local Integer I
  For I = 1 To maxtab(this.EMSD)
    Call EMS_EMSD_DISPLAY(this.EMSD)
  Next I
#  For I = 1 To maxtab(this.EMST)
#    Call EMS_EMST_DISPLAY(this.EMST)
#  Next I

#  Call GET_IMPORTMODELE_DETAILS(this)

Return

####################################################################

$EMS_DRTPDF_PROPAGATE
  Call EMS_DISPLAY(this)
Return

####################################################################

#####################################################################
# STANDARD METHODS
#####################################################################


#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.EMS.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EMS.CATCOD,"CATDES")
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.EMS.ACTX.ACACHE.ECA.AGETVALNUM(this.EMS.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif


  Local Integer WPOS, WNB

  #display EDI flows using the current Message Mapping structure
  WPOS = 0
  WNB = 0
  Local File EDIFLO [EFL]
  Local File EDIFLOD [EFLD]
  #issue 100699 /10
#  Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD;[EFLD]FLOREL As [LIEN] Where [EFLD]MSGTYP = 1 and [EFLD]MSGFOR = 1 and [EFLD]MSGCOD = this.EMS.MSGCOD and [EFLD]MSGREL = this.EMS.MSGREL
  Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD;[EFLD]FLOREL As [LIEN] Where [EFLD]MSGTYP = 1 and ([EFLD]MSGFOR = 1 or [EFLD]MSGFOR = 2) and [EFLD]MSGCOD = this.EMS.MSGCOD and [EFLD]MSGREL = this.EMS.
& MSGREL
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('FLO', [V]CST_ALASTPOS)
      this.FLO(WPOS).FLOFLOCOD = [EFLD]FLOCOD
      this.FLO(WPOS).FLOFLOREL = [EFLD]FLOREL
      this.FLO(WPOS).FLOFLODES = [EFL]FLODES
      this.FLO(WPOS).FLOVALID  = [EFL]VALID
      this.FLO(WPOS).FLOFLGACT = [EFL]FLGACT
    Endif
  Next
  LogicClose File [EFLD]
  LogicClose File [EFL]


  #display EDI Sequential files using the current Message Mapping structure
  WPOS = 0
  WNB = 0
  Local File EDISEQFIL [ESF]
  Filter [ESF] Where [ESF]MSGCOD = this.EMS.MSGCOD and [ESF]MSGREL = this.EMS.MSGREL
  For [ESF]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('SEQ', [V]CST_ALASTPOS)
      this.SEQ(WPOS).SEQMSGCOD    = [ESF]MSGCOD
      this.SEQ(WPOS).SEQMSGREL    = [ESF]MSGREL
      this.SEQ(WPOS).SEQMSGFILNOR = [ESF]MSGFILNOR
      this.SEQ(WPOS).SEQFILDES    = [ESF]FILDES
      this.SEQ(WPOS).SEQVALID     = [ESF]VALID
    Endif
  Next
  LogicClose File [ESF]

  #display EDI XML files using the current Message Mapping structure US 110699/10
  WPOS = 0
  WNB = 0
  Local File EDIXMLFIL [EXF]
  Filter [EXF] Where [EXF]MSGCOD = this.EMS.MSGCOD and [EXF]MSGREL = this.EMS.MSGREL
  For [EXF]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('CML', [V]CST_ALASTPOS)
      this.CML(WPOS).CMLMSGCOD    = [EXF]MSGCOD
      this.CML(WPOS).CMLMSGREL    = [EXF]MSGREL
      this.CML(WPOS).CMLMSGFILNOR = [EXF]MSGFILNOR
      this.CML(WPOS).CMLFILDES    = [EXF]FILDES
      this.CML(WPOS).CMLVALID     = [EXF]VALID
    Endif
  Next
  LogicClose File [EXF]
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$EMS_AREAD_AFTER
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")

  Call EMS_DISPLAY(this)
  Call GET_IMPORTMODELE_DETAILS(this)
Return

$EMS_EMSD_AREAD_AFTER
  Call EMS_EMSD_DISPLAY(this)
Return


#********************************************************************
# Method EMS_EMSA_AREAD_AFTER
#********************************************************************
#*
#*!
$EMS_EMSA_AREAD_AFTER
  this.CODNAM = func EDILIBA.GET_CODNAM(this.CODE)

  Local Char WTXT(120)
  Local Char WLAN(3)

  If this.CODE <> "" and this.ALIAS <> ""
    If this.APARENT.REPCOD <> ""
      Local File ASHWEXPPRO [ASWR]
      Read [ASWR]ASWR0 = this.APARENT.REPCOD;this.ALIAS
      If !fstat
        this.CODPRO = [ASWR]CODPRO
        # WLAN = this.ACTX.LAN
#        WLAN="ENG"
        WLAN=this.ACTX.LAN
        ##Always propose the english text
        Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
        this.DESCRIPTION = WTXT
      Else
        this.CODPRO = ""
        this.DESCRIPTION = ""
      Endif
      LogicClose File [ASWR]
    Else
      this.CODPRO = ""
      this.DESCRIPTION = ""
    Endif
  Else
    this.CODPRO = ""
    this.DESCRIPTION = ""
  Endif

Return

#********************************************************************
# Subprog EMS_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT
#*!
Subprog EMS_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(20)

  WPROP = "$isHidden"

  If WOBJECT.MSGDIR = 1  ### ISSUE
    WOK = fmet WOBJECT.ASETATTRIBUTE('MSGTPL', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('TYPFIL', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('CODDBA', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('FLDLIM', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPREC', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPFLD', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPDEC', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTDAT', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTMNL', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTCHA', WPROP, 'true')
    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('LIBDAT', WPROP, 'true')
  Else  ### RECEIPT
    WOK = fmet WOBJECT.ASETATTRIBUTE('MSGTPL', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('TYPFIL', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('CODDBA', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('FLDLIM', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPREC', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPFLD', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('SEPDEC', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTDAT', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTMNL', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('OPTCHA', WPROP, 'false')
#    WOK = fmet WOBJECT.APARENT.ASETATTRIBUTE('LIBDAT', WPROP, 'false')
  Endif

  WPROP = "$isDisabled"

  If WOBJECT.MSGDIR = 1  ### ISSUE
    WOK = fmet WOBJECT.ASETATTRIBUTE('MSGOPE', WPROP, 'true')
  Else  ### 2 RECEIPT
    WOK = fmet WOBJECT.ASETATTRIBUTE('MSGOPE', WPROP, 'false')
  Endif
End


