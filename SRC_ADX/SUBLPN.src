######################################################################################
## Etiquette ajoutée par le superviseur (écran LPN) 14/09/2017 09:47:52 (MAE)
######################################################################################
Subprog AM_LOC(VALEUR)
Variable Char    VALEUR()
SetInstance WLPN With [M:LPN]
WLPN.LOC = VALEUR
SetInstance [M:LPN] With WLPN
Affzo [M:LPN]
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPN0) 25/09/2017 06:43:59 (MAE)
######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
SetInstance WLPN With [M:LPN]
WLPN.TCTRNUM = VALEUR
SetInstance [M:LPN] With WLPN
SetInstance [M:LPN0] With WLPN
If [M:LPN]LPNREFCOU<> AVOID.ACHAR and [M:LPN]LPNNUM <> AVOID.ACHAR
  Call MESSAGE (mess(556,184,1)) From GESECRAN
Endif
Affzo [M:LPN]
Affzo [M:LPN0]
End


