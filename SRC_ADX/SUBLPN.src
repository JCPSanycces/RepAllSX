######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPN) 16/04/2018 08:16:43 (MAE)
######################################################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If !find(VALEUR,"",[M:LPN]LOC)
  Read [STC]STC0=[M:LPN]STOFCY;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Elsif [F:STC]LOCCAT >2
    GMESSAGE = mess(16,196,1)
    mkstat=2 : End
  Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPN1) 08/06/2018 12:21:00 (MAE)
######################################################################################
Subprog IB_NBLIG
If [F:ITM]ITMREF <> [M:LPN1]ITMREF(nolign-1)
  Read [ITM]ITM0 = [M:LPN1]ITMREF(nolign-1)
Endif
If [F:ITM]SERMGTCOD <> 4
  Raz GBOUT3
Endif

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran LPN) 22/08/2018 07:11:08 (MAE)
######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# Réinitialisation du dépôt
If dim([M:LPN]WRH)>0
   Call WRHINIT([M:LPN]WRH,VALEUR,0) From STKWRH
Endif
#---

End


