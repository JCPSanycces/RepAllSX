######################################################################################
## Etiquette ajoutée par le superviseur (Objet LPN) 13/09/2017 07:13:45 (MAE)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE           From SUBLPNA
 When "RAZCRE"       : Gosub RAZCRE          From SUBLPNA
 When "RAZDUP"       : Gosub RAZDUP          From SUBLPNA
 When "LIENS"        : Gosub LIENS           From SUBLPNA
 When "AV_ANNULE"    : Gosub AV_ANNULE       From SUBLPNA
 When "ANNULE"       : Gosub ANNULE          From SUBLPNA
 When "CREATION"     : Gosub CREATION        From SUBLPNA
 When "MODIF"        : Gosub MODIF           From SUBLPNA
 When "FERME"        : Gosub FERME           From SUBLPNA
 When "SETBOUT"      : Gosub SETBOUT         From SUBLPNA
 When "EXEBOUT"      : Gosub EXEBOUT         From SUBLPNA
 When "BOUTON"       : Gosub BOUTON          From SUBLPNA
 When Default
Endcase
Return


