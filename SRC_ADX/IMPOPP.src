#######################################################################################################################
# IMPOPP : Import / Export des affaires                                                   FGR 02/07/2014 X3SUIVI93274 #
#######################################################################################################################
End
# ---------------------------------------------------------------------------------------------------------------------
$ACTION
  Case ACTION
    When "IMPORT"               : Gosub IMPORT
  Endcase
Return

# ---------------------------------------------------------------------------------------------------------------------
$IMPORT
Local Integer NI
Local Integer NE

  Case IMPFIC
    When "OPP"
      # -----------------------------
      NE = -1
      For NI = 0 To dim([M:OPP2]CPP)
        NE += 1
        If [F:OPP]CPP(NI) = "" Then
          Break
        Endif
      Next
      [M:OPP2]NBCPP = NE
      # -----------------------------
      NE = -1
      For NI = 0 To dim([M:OPP3]STE)
        NE += 1
        If [F:OPP]STE(NI) = "" Then
          Break
        Endif
      Next
      [M:OPP3]NBSTE = NE
      # -----------------------------
      NE = -1
      For NI = 0 To dim([M:OPP4]STEX)
        NE += 1
        If [F:OPP]STEX(NI) = "" Then
          Break
        Endif
      Next
      [M:OPP4]NBSTEX = NE
      # -----------------------------
      NE = -1
      For NI = 0 To dim([M:OPP5]SBBPJT)
        NE += 1
        If [F:OPP]SBBPJT(NI) = "" Then
          Break
        Endif
      Next
      [M:OPP5]NBPJT = NE
      # -----------------------------
  Endcase
Return
