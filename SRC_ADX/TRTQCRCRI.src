#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
Call SAISIE_NUM(VALEUR,PARAM,"IQCRCRI","TRTQCRCRI") From GSAISIE
End
#CHECK UNUSED_END

###################################################################################
# TRTSCSCRI    Saisie des filtres pour la liste de picking des changements stock  #
###################################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Integer I,J

Raz [M:QCR] : Transmask [M:QCR1] To [M:QCR]  # Issue 25606_Transmask [M:QCR] = [M:QCR1]
If [M:QCR1]STOFCY=""
    Call ERREUR(mess(215,193,1)) From GESECRAN
    FIN=1
    Return
Endif


Affzo [M:QCR]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR

[M:QCR1] = [M:QCR]

Affzo [M:QCR1]ITMREFSEL
If dim([M:QCR1]WRHSEL) > 0     # hcb 63541
   Affzo [M:QCR1]WRHSEL
Endif

FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return


Subprog AM_ITMREFSEL(VALEUR)
Variable Char    VALEUR()
    Read [ITF]ITF0 = VALEUR;[M:QCR1]STOFCY
    If fstat
        mkstat = 2
    Endif
    If !mkstat
        If dim([M:QCR]SERNUMSTR)>0
            If find([F:ITM]SERMGTCOD,2,3)                     # hcb 110327
                Actzo [M:QCR]SERNUMSTR,SERNUMEND
            Else
                Effzo [M:QCR]SERNUMSTR,SERNUMEND
                Diszo [M:QCR]SERNUMSTR,SERNUMEND
            Endif
        Endif
        If [F:ITM]LOTMGTCOD<=1
            If dim([M:QCR]LOTSTR)>0
                Effzo [M:QCR]LOTSTR,LOTEND
                Diszo [M:QCR]LOTSTR,LOTEND
            Endif
            If dim([M:QCR]SLOSTR)>0
                Effzo [M:QCR]SLOSTR,SLOEND
                Diszo [M:QCR]SLOSTR,SLOEND
            Endif
        Elsif [F:ITM]LOTMGTCOD=4
            If dim([M:QCR]LOTSTR)>0
                Actzo [M:QCR]LOTSTR,LOTEND
            Endif
            If dim([M:QCR]SLOSTR)>0
                Actzo [M:QCR]SLOSTR,SLOEND
            Endif
        Else
            If dim([M:QCR]LOTSTR)>0
                Actzo [M:QCR]LOTSTR,LOTEND
            Endif
            If dim([M:QCR]SLOSTR)>0
                Effzo [M:QCR]SLOSTR,SLOEND
                Diszo [M:QCR]SLOSTR,SLOEND
            Endif
        Endif

        If dim([M:QCR]LOCSTR)>0
            If [F:ITF]LOCMGTCOD=2
                Actzo [M:QCR]LOCSTR,LOCEND
            Else
                Effzo [M:QCR]LOCSTR,LOCEND
                Diszo [M:QCR]LOCSTR,LOCEND
            Endif
        Endif
#                                                           # hcb X3-88857 deb
       If dim([M:QCR]LPNNUMDEB)>0
            If [F:ITF]LPNMGTCOD = 2
                Actzo [M:QCR]LPNNUMDEB,LPNNUMEND
            Else
                Effzo [M:QCR]LPNNUMDEB,LPNNUMEND
                Diszo [M:QCR]LPNNUMDEB,LPNNUMEND
            Endif
        Endif
#                                                           # hcb X3-88857 fin
        Affzo [M:QCR]20
    Endif
End

Subprog AM_UOM(VALEUR)
Variable Char    VALEUR()
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOEF

    If find(VALEUR,[M:QCR]UOM)
        mkstat=2
        End
    Endif

    Call CTLUOM ([M:QCR]ITMREFSEL,3,"", VALEUR,LCOEF, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif
End

Subprog AM_LOTSTR(VALEUR)
Variable Char    VALEUR()
If [M:QCR]LOTEND=[M:QCR]LOTSTR | [M:QCR]LOTEND<VALEUR
   [M:QCR]LOTEND = VALEUR
   Affzo [M:QCR]LOTEND
Endif
End

Subprog C_LOTEND(VALEUR)
Variable Char    VALEUR()
If [M:QCR]LOTSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:QCR]LOTSTR
Endif
If dim([M:QCR]SLOSTR)>0
   If VALEUR <> [M:QCR]LOTSTR
      Effzo [M:QCR]SLOSTR,SLOEND
   Endif
Endif
End

Subprog AM_SLOSTR(VALEUR)
Variable Char    VALEUR()
If [M:QCR]SLOEND=[M:QCR]SLOSTR | [M:QCR]SLOEND<VALEUR
   [M:QCR]SLOEND = VALEUR
   Affzo [M:QCR]SLOEND
Endif
End

