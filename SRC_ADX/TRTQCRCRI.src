Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()

Local Integer I,J
Local Char    WWSTA(30)
Local Char    WSTA(3)(20)

If VALEUR="" Raz [M:QCR]FORSTA : End Endif

VALEUR=toupper(VALEUR)
WWSTA=VALEUR
J=instr(J,WWSTA,",")
While J<>0
   WSTA(I)=left$ (WWSTA,J-1)
   WWSTA  =right$(WWSTA,J+1)
   J=instr(J,WWSTA,",")
   I+=1
Wend
J=I
WSTA(I)=WWSTA
For I=0 To J
   If !find(left$(WSTA(I),1),"A","Q","R")
      mkstat=2 : GMESSAGE=mess(21,199,1)
      Break
   Elsif len(WSTA(I))>GLONSTA
      mkstat=2 : GMESSAGE=mess(456,199,1)-num$(GLONSTA)
      Break
   Endif
Next I

# Construction de la formule :
Call DECODE_STAT(VALEUR,[M:QCR]FORSTA) From TRTCATEG

End

Subprog AM_WRHSEL(VALEUR)
Variable Char    VALEUR()
[M:QCR]WRHSEL = VALEUR

End

#                                                           # hcb X3-88857 deb
Subprog AM_LPNNUMDEB(VALEUR)
Variable Char    VALEUR()
If [M:QCR]LPNNUMEND=[M:QCR]LPNNUMDEB | [M:QCR]LPNNUMEND<VALEUR
   [M:QCR]LPNNUMEND = VALEUR
Endif
Affzo [M:QCR]LPNNUMEND
End

Subprog C_LPNNUMEND(VALEUR)
Variable Char    VALEUR()
If [M:QCR]LPNNUMDEB>VALEUR
   GMESSAGE = mess(44,199,1)   # la borne fin est inferieure à celle du début
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:QCR]LPNNUMDEB
Endif
End
#                                                           # hcb X3-88857 fin

