#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_BEGIN
Local Mask SMO0    [SMO0]
Local Mask SMO1    [SMO1]
Local Mask STOSORW [SOW]
Local Mask ALLPAR  [ALP]

Local Char PARBOUT(250)(1..6), SAVACT(20), VALEUR
PARBOUT(1) = "SMO1"
PARBOUT(2) = "0"
PARBOUT(3) = "0"
PARBOUT(4) = "A-TS140"
PARBOUT(5) = "MAR"
PARBOUT(6) = "20"
SAVACT = GACTION : GACTION = "SAISTCBAR"
Call SAISIE_CHAR(VALEUR,PARBOUT,"ISTOSOR","TRTSTOSOR","XYTRTSTOSOR") From GSAISIE
GACTION = SAVACT

End
#CHECK UNUSED_END

########################################################################
# Traitement TRTSTCBAR - Saisie des barèmes des structures de cout     #
#                                                                      #
########################################################################
# Action SAISTCBAR
#    Paramètres     - LNOL    No ligne écran (nolign-1)
#                   - LNBL    Nombre lignes écran
########################################################################
# Prérequis    : Ecran de stockage STC2W [STC2W] doit être ouvert
#
########################################################################

$ACTION
#--- Actions liées au traitement standard
#Infbox(ACTION)
#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "INIT"          : Gosub INIT
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub FIN_END
 When "ABANDON"       : Gosub ABANDON
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI
 When "INICRE_LIG"    : Gosub INICRE_LIG
 When "INIMOD_LIG"    : Gosub INIMOD_LIG
Endcase

Return

#########################################################################
$INIT
Return

#########################################################################
$OUVRE
Global Integer GSUPLIG        : # Pour identifier que l'on supprime une ligne
Global Integer GNOLIG         : # nolign-1 (pour accés aux axes ana origines)

Local Integer LNOL            : # No ligne courante (nolign-1) masque origine
Local Integer LNBL            : # Nombre lignes écran
Local Char    LSTCNUM         : # STCNUM de la structure de cout avant duplication
# TS
Local Integer LAUTO       : # 0 ouverture manuelle
                            # 1 ouverture auto, ligne déjà existante, on ressort
                            # 2 ouverture auto, nouvelle ligne

Local Integer LRET
Local Integer I, J, K, NOL, WF
Local Integer WNBLIG, WRAFF
Local Integer LSEQ
Local Integer WGENR           : # 1 si on a enregistré , 0 sinon
Raz WGENR

# Récupération des paramètres
LNOL    = val(PARAM(1))
LNBL    = val(PARAM(2))
LSTCNUM = PARAM(3)
LAUTO   = val(PARAM(4))
If LAUTO=1 | [M:STC1]DIRCLCMOD(LNOL)<>5
  FIN=1 : Return
Endif

If clalev([M:STCW])=0    Local Mask STC2W     [STCW]   Endif

If clalev([F:STCB])=0    Local File COSTSTCB  [STCB]   Endif
If clalev([F:TUN])=0     Local File TABUNIT   [TUN]    Endif
If clalev([F:TABCUR])=0  Local File TABCUR    [TCU]    Endif

GNOLIG = LNOL

Return


##########################################################################################################
# Alimentation du masque de sortie de stock
#######################################################################
$CHARGE_PARAM
  [M:STC2]WSTCSEQ   = [M:STC1]WSTCSEQ(LNOL)
  [M:STC2]CUR       = [M:STC1]CUR(LNOL)
  [M:STC2]UOM       = [M:STC1]UOM(LNOL)
  [M:STC2]STCNUM    = [M:STC1]STCNUM
  [M:STC2]STCLIN    = [M:STC1]STCLIN(LNOL)
  Read [TUN]TUN0    = [M:STC2]UOM
  Read [TCU]TCU0    = [M:STC2]CUR
Return

#########################################################################
$DEBUT
#-----------------------------------------------------------------------
# Traitement à alimenter pour les différentes fonctions
# Chargement des blocs 1 et 2 de [M:SOR]
#-----------------------------------------------------------------------
Default Mask "[STC2]"
Raz [M:STC2]
Affzo [M:STC2]

[M:STC2]NBLIG = 0
Gosub CHARGE_PARAM

# Si ligne existante(déjà créée) ou en cours de saisie(fin de ligne éxécutée)
# on regarde si [M:STCW] est déjà chargé,
# dans le cas contraire on l'alimente à partir de la table COSTSTCB
# Le [STCW] est-il déjà chargé pour cette ligne ?
WCHARGSTCW=1
If [M:STC2]WSTCSEQ<>0 & [M:STCW]NBLIG>0
   For I=0 To [M:STCW]NBLIG-1
      If [M:STCW]WSTCSEQ(I)=[M:STC1]WSTCSEQ(LNOL)
         Raz WCHARGSTCW
         Break
      Endif
   Next I
Endif


# Il n'est pas déjà chargé --> on l'alimente à partir de la table COSTSTCB
If WCHARGSTCW=1
   Call WSTCSEQ (LNOL, [M:STC1]NBLIG, LRET)
   Gosub CHARGE_STCW  #chargement de l'écran STCW a partir de la table COSTSTCB
   # Si problème en chargement
   If FIN = 1 : Return : Endif
Endif

# Alimentation du masque STC2
Gosub ALI_MSK_STC

If FIN=1 Return Endif

If LAUTO=2 & [M:STC2]NBLIG>0
  FIN=1 : Return
Endif

If [M:STC2]NBLIG>0
   Affzo [M:STC2]1-99
   Actzo [M:STC2]MINLIM
   Actzo [M:STC2]MAXLIM
   Actzo [M:STC2]UNTPRI
Endif

Gosub ETA_MSK_STCW

Return

#########################################################################
$SETBOUT
GREP="C"
If !find("=",CHBOU) CHBOU+="=" Endif
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif
Return

#########################################################################
$CHARGE_STCW
If LSTCNUM <> ""
  #Si on est en duplication, on récupére les lignes de bareme de la strcucture dupliquée
  Filter [STCB] Where [F:STCB]STCNUM=LSTCNUM and [F:STCB]STCLIN=[M:STC2]STCLIN
Else
  Filter [STCB] Where [F:STCB]STCNUM=[M:STC2]STCNUM and [F:STCB]STCLIN=[M:STC2]STCLIN
Endif
J = [M:STCW]NBLIG
 # Peut on ajouter les lignes dans l'écran de travail
  I = rowcount([F:STCB])
  If J+I > dim([M:STCW]WSTCSEQ)
     WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCW")
     Call MESSAGE(WMESSAGE) From GESECRAN
     FIN = 1
     Filter[F:STCB]
     Return
  Endif
  For [STCB]STCB0
      [M:STCW]WSTCSEQ(J) = [M:STC1]WSTCSEQ(LNOL)
      [M:STCW]WMINLIM(J) = [F:STCB]MINLIM
      [M:STCW]WMAXLIM(J) = [F:STCB]MAXLIM
      [M:STCW]WUNTPRI(J) = [F:STCB]UNTPRI
      [M:STCW]WSTCLIN(J)  = [M:STC2]STCLIN
      [M:STCW]WSTCLIM(J)  =[F:STCB]STCLIM
      [M:STCW]NBLIG  += 1
      J=J+1
   Next
   Filter [F:STCB]
Return

#########################################################################
$ALI_MSK_STC

Local Decimal WORIALLSTU, WORIALLPCU, WENCALLSTU
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Integer WRET, WMAX, I1, I2

# Nb de lignes maximum du tableau [STC]
WMAX = dim([M:STC2]MINLIM)

NOL=0
If [M:STCW]NBLIG<=0 Goto ALI_MSK_STC_FIN Endif
For I=0 To [M:STCW]NBLIG-1
   # Nb max de lignes atteint
   If NOL>=WMAX
     WMESSAGE = func AFNC.MES1(mess(608,199,1),"STC2")
     Call MESSAGE(WMESSAGE) From GESECRAN
     FIN = 1
     Break
   Endif
   #If [M:STCW]WSTCSEQ(I)=[M:STC1]WSTCSEQ(LNOL) #& [M:STCW]WSTCLIN(I)=[M:STC1]STCLIN(LNOL)
   #MUARN CF TS 13/05/2013
   If [M:STCW]WSTCSEQ(I)=[M:STC1]WSTCSEQ(LNOL)
      [M:STC2]WSTCSEQ        = [M:STCW]WSTCSEQ(I)
      [M:STC2]MINLIM(NOL)    = [M:STCW]WMINLIM(I)
      [M:STC2]MAXLIM(NOL)    = [M:STCW]WMAXLIM(I)
      Call QTEARR([M:STC2]MINLIM(NOL),[M:STC2]UOM) From TRTDIV
      Call QTEARR([M:STC2]MAXLIM(NOL),[M:STC2]UOM) From TRTDIV
      [M:STC2]UNTPRI(NOL)    = [M:STCW]WUNTPRI(I)
      [M:STC2]STCLIM(NOL)    = [M:STCW]WSTCLIM(I)
     Goto ALI_MSK_STC_SUI
   Endif
   Goto NEXT_STCW

$ALI_MSK_STC_SUI

      NOL += 1

$NEXT_STCW
Next I



$ALI_MSK_STC_FIN

# Tableau chargé
If NOL<=WMAX
   [M:STC2]NBLIG = NOL
Else
   [M:STC2]NBLIG = WMAX
Endif

Return

#########################################################################
$ETA_MSK_STCW

#gére l'apparence des champs
Actzo[M:STC2]MAXLIM(LNOL)
Actzo[M:STC2]MINLIM(LNOL)
Actzo[M:STC2]UNTPRI(LNOL)

# Si pas de ligne, on se casse
#If [M:STC2]NBLIG=0 Return Endif
Return

#########################################################################
$APRES_MODIF
REP = "M"
Return

#########################################################################
$INIMOD_LIG
Return

#########################################################################
$INICRE_LIG
If nolign-1>0
  [M:STC2]MINLIM(nolign-1) = [M:STC2]MAXLIM(nolign-2)
Endif
Return
#########################################################################
$AVANT_ENR

If [M:STC2]NBLIG=0
  GMESSAGE=mess(61,199,1)  : GERR=1 : FOK=0
Endif

Return

#########################################################################
$ENR

# Peut on ajouter les lignes dans l'écran de travail
If [M:STCW]NBLIG+[M:STC2]NBLIG >= dim([M:STCW]WSTCSEQ)
   WMESSAGE = func AFNC.MES1(mess(608,199,1),"STCW")
   Call MESSAGE(WMESSAGE) From GESECRAN
   Return
Endif
# Suppression des lignes [STCW] initiales pour la ligne de document
For I=0 To [M:STCW]NBLIG-1
   If [M:STCW]WSTCSEQ(I)=[M:STC2]WSTCSEQ
      Raz [M:STCW]WSTCSEQ(I),[M:STCW]WMAXLIM(I)
      Raz [M:STCW]WMINLIM(I),[M:STCW]WUNTPRI(I)
      Raz [M:STCW]WSTCLIN(I),[M:STCW]WSTCLIM(I)
   Endif
Next I

# Alimentation de l'écran de stockage COSTSTCB
WNBLIG = [M:STCW]NBLIG
J      = [M:STCW]NBLIG
If [M:STC2]NBLIG>0
   For I=0 To [M:STC2]NBLIG-1
      [M:STCW]WSTCLIN(J)    = [M:STC2]STCLIN
      [M:STCW]WSTCSEQ(J)    = [M:STC2]WSTCSEQ
      [M:STCW]WMAXLIM(J)    = [M:STC2]MAXLIM(I)
      [M:STCW]WMINLIM(J)    = [M:STC2]MINLIM(I)
      [M:STCW]WUNTPRI(J)    = [M:STC2]UNTPRI(I)
      [M:STCW]WSTCLIM(J)    = 1000*(I+1)

      [M:STCW]NBLIG += 1
      J += 1

      $ENR_SUI
   Next I
   If LRET<>0 Goto AB_TRT Endif
Endif

# On a enregistré
WGENR = 1
FIN   = 1
#alimentation du WSTCSEQ de l'écran STC1
[M:STC1]WSTCSEQ(LNOL) = [M:STC2]WSTCSEQ
# Barèmes OK
Raz [M:STC1]WLIMOK(LNOL)
Return

#########################################################################
$AB_TRT
Rollback
Return

#########################################################################
$ABA

REP=""
WPICK=1
Effzo [M]15
GCHARGRUPT = ""
Gosub ALI_MSK_STC
Affzo [M]1-99
WPICK=2
Return

#########################################################################
$BOUTON

Return

#########################################################################
$FIN_END
# contrôle au moins 1 ligne
If [M:STC2]NBLIG=0
  GMESSAGE=mess(61,199,1)  : GERR=1 : FIN=0
Endif

If GERR=1
  FIN=0
Endif
Return


#########################################################################
$ABANDON

If LAUTO>1
  GMESSAGE=mess(619,199,1)  : GERR=1 : FOK=0
Endif
Return

#########################################################################
$FIN

# Si on a pas enregistré
If WGENR<>1
   Goto FIN_SUI
Endif
Raz [M:STC2]

$FIN_SUI

Return

#########################################################################
$FINSAI
Default Mask "[STC1]"

[M:STC1]UPDFLG(LNOL)=1

# SI ON A ENREGISTRÉ & ACCÉS PAR BOUTON --> BOUTON 'Enregistrer' DANS LE DOCUMENT
# Ne pas positionner mkstat dans les autres cas, car les actions suivantes ne
# seraient pas exécutées (ex: TRTCRENOM dans les livraisons)
If WGENR=1 & GREP="" mkstat=4 Endif

$FINSAI_SUI
Return

#########################################################################
# Action sur champs
#########################################################################

########################################
Subprog C_NBLIG
Local Integer NOL

# --> Suppression de lignes
If find(status,65,68,83)
   GSUPLIG = status
   [M:STCW]WSTCSEQ(nolign-1) = 0  #on casse le lien avec la ligne de document
Else
   Raz GSUPLIG
Endif

End

########################################
Subprog WSTCSEQ (LNOL, LNBLIG, LRET)
Value    Integer LNOL
Value    Integer LNBLIG
Variable Integer LRET

Local Integer LSEQ
Raz LRET
If LNOL < 0
    Call ERREUR(mess(46,105,1)-"WSTCSEQ") From GESECRAN
    LRET=1
    End
Endif

LSEQ=0
If LNBLIG > 0
   LSEQ = evalue ("max([M:STC1]WSTCSEQ(0..LNBLIG-1))")
Endif
If evalue("[M:STCW]NBLIG") > 0
   LSEQ = evalue ("max(LSEQ,[M:STCW]WSTCSEQ(0..[M:STCW]NBLIG-1))")
Endif

If evalue("[M:STC1]WSTCSEQ(LNOL)")=0
   Assign "[M:STC1]WSTCSEQ(LNOL)" With LSEQ+1
Endif
LLIG = evalue("[M:STC1]WSTCSEQ(LNOL)")

[M:STC2]WSTCSEQ = [M:STC1]WSTCSEQ(LNOL)

End

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STC2) 23/10/2012 11:56:15 (MAE)
######################################################################################
# Borne mini de la ligne ne peut pas être > borne maxi de la ligne précédente
Subprog C_MINLIM(VALEUR)
Variable Decimal VALEUR
If nolign-1>0
  If VALEUR <= [M:STC2]MAXLIM(nolign-2)
    mkstat = 2
    GMESSAGE = mess(143,192,1)
  Endif
Endif
End

######################################################################################~
# Plus utilisé (on bloque avant)
# Si borne mini ligne en cours < borne maxi de la ligne précédente : borne maxi de la ligne précédente recalculée
Subprog AM_MINLIM(VALEUR)
Variable Decimal VALEUR
If nolign-1>0 & VALEUR < [M:STC2]MAXLIM(nolign-2)
  [M:STC2]MAXLIM(nolign-2) = VALEUR - (10^(-[F:TUN]UOMDEC))
  Affzo [M:STC2]MAXLIM(nolign-2)
Endif
End

######################################################################################
# borne maxi ne peut pas être < borne mini
Subprog C_MAXLIM(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M:STC2]MINLIM(nolign-1)
    GMESSAGE = mess(252,123,1)
    mkstat = 2
    End
Elsif nolign < [M:STC2]NBLIG & VALEUR > [M:STC2]MAXLIM(nolign)
    mkstat = 2
    GMESSAGE = mess(144,192,1)
Endif
End

######################################################################################
# Initialisation de borne mini de la ligne suivante
# si borne mini ligne suivante devient < borne maxi ligne suivante, recalcul borne maxi ligne suivante
Subprog AM_MAXLIM(VALEUR)
Variable Decimal VALEUR
If nolign < dim([M:STC2]MINLIM) & [M:STC2]MINLIM(nolign)<>0
  [M:STC2]MINLIM(nolign)=(10^(-[F:TUN]UOMDEC))+VALEUR
  If [M:STC2]MAXLIM(nolign) < [M:STC2]MINLIM(nolign)
     [M:STC2]MAXLIM(nolign)=[M:STC2]MINLIM(nolign)
  Endif
  Affzo [M:STC2]MINLIM(nolign), MAXLIM(nolign)
Endif
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran STC2) 26/10/2012 11:15:54 (MAE)
######################################################################################
Subprog AVANT_NBLIG
# Issue 102144 - 2014-09-05 by SR : Initialiser que si <> 0 dans tous les cas
#If nolign>1 & [M:STC2]MINLIM(nolign-1) = 0
If [M:STC2]MINLIM(nolign-1) = 0
  If nolign>1
      [M:STC2]MINLIM(nolign-1)=(10^(-[F:TUN]UOMDEC))+[M:STC2]MAXLIM(nolign-2)
  Else
      [M:STC2]MINLIM(0)=10^(-[F:TUN]UOMDEC)
  Endif
Endif
Affzo [STC2]MINLIM(nolign-1)
End
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran STC2) 13/11/2012 10:47:08 (SR)
######################################################################################
Subprog APRES_NBLIG
Local Integer NOL : NOL = nolign-1
#----- Si suppression ligne,recalcul borne debut ligne suivante -----#
If status=65 | status=68 | status=83
    If NOL<[M:STC2]NBLIG-1
       If NOL <> 0
          [M:STC2]MINLIM(NOL+1) = (10^(-[F:TUN]UOMDEC))+[M:STC2]MAXLIM(NOL-1)
       Else
          [M:STC2]MINLIM(NOL+1) = (10^(-[F:TUN]UOMDEC))
       Endif
       Affzo [M:STC2]MINLIM(NOL+1)
    Endif
Endif

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran STC2W) 19/11/2012 14:38:43 (SR)
######################################################################################
Subprog IB_NBLIG
End

Subprog AV_NBLIG
End

Subprog B3_NBLIG
End


######################################################################################
