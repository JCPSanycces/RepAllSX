#<AdxTL>@(#)11.0.0.0 $Revision$
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"PAYPROPAL"
 GFONCTION="PAYPROPAL" : Call AUTORIS From EXEFNC
Endif
GACTION = "PAYPROPAL"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYPROPAL","DGENPAY",4,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

##################################################################
## Création du règlement : Etiquettes appelées depuis PAYPROPAL ##
##################################################################
$CRE_PAH
Gosub INIT
Gosub AFFECT_PTH
If GOK<1 : Return : Endif
Gosub AFFECT_PAO
If GOK<1 : Return : Endif
Gosub AFFECT_PTD
If GOK<1 : Return : Endif
Gosub TRACE
Return


$INIT
If clalev([F:PAH])=0  : Local File PAYPTH     [PAH]  : Endif
If clalev([F:PAO])=0  : Local File PAYPTHDOC  [PAO]  : Endif
If clalev([F:PYP])=0  : Local File PAYPTD     [PYP]  : Endif
If clalev([F:PRI])=0  : Local File PAYPTHRIT  [PRI]  : Endif
If clalev([F:RIU])=0  : Local File RITDUD     [RIU]  : Endif
If clalev([F:RIU2])=0 : Local File RITDUD     [RIU2] : Endif
If clalev([F:RCU])=0  : Local File RITCUM     [RCU]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
If clalev([F:TAM])=0  : Local File TABPAM     [TAM]  : Endif

If !clalev([M:PAH3])  : Local Mask PAYORD3 [PAH3]  : Endif

Local Char    MODREG(GLONDEP)
Local Char    TYPREG(GLONTPY)
Local Char    FACCUR(GLONCUR)
Local Integer NBFAC, NBDOC, DOC
Local Decimal TYPCOURS
Local Decimal TOTFAC

Local Integer MAXDOC : MAXDOC = 99
Local Char    TNUMVCR(GLONVCR)(0..MAXDOC)
Local Char    TCURVCR(GLONCUR)(0..MAXDOC)
Local Integer TDUDNUM(0..MAXDOC)
Local Integer TDUDLIG(0..MAXDOC)
Local Decimal TAMTVCR(0..MAXDOC)

TOTFAC = 0


Local Char    CODRTZ(GLONRTZ)
Local Char    NUMRTZ(GLONVCR)
Local Integer I, RIT, RTZ
Local Decimal MOIS, ANNEE

Call ELEMNO(";",4,[L]MODREG) From PAYPROPAL2

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",[M:DIA]CPY,"") From CONTOBJ

## Type de règlement ???
Case [M:DIA]SNS
 When 1 : # Ordres de paiement
  #Filter [TPY] Where SNS = 1 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0 & [F:TPY]SNS=1
  Filter [TPY] Where LEG=[F:CPY]LEG & SNS = 1 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0 & [F:TPY]SNS=1
  Read [TPY]TPY0 First
  Filter [TPY]
  If !fstat
   TYPREG = [F:TPY]PAYTYP
  Endif
 When 2 : # Récibo
  Call LEC_TAM(GCURLEG, MODREG) From CPTLEC
  If !fstat & [F:TAM]TYP = 4 : # Chèques de tiers (endossement) => Il faut avoir une transation qui autorise l'endossement
   #Filter [TPY] Where FLGEND = 2 & SNS = 2 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
   Filter [TPY] Where LEG=[F:CPY]LEG & FLGEND = 2 & SNS = 2 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
   Read [TPY]TPY0 First
   Filter [TPY]
   If !fstat
    TYPREG = [F:TPY]PAYTYP
   Endif
  Else
   #Filter [TPY] Where SNS = 2 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
   Filter [TPY] Where LEG=[F:CPY]LEG & SNS = 2 & find(MODREG,[F:TPY]PAM(0..dim([F:TPY]PAM)-1))<>0
   Read [TPY]TPY0 First
   Filter [TPY]
   If !fstat
    TYPREG = [F:TPY]PAYTYP
   Endif
  Endif
Endcase
If TYPREG<>""
 Call LEC_TPY_LEG([F:CPY]LEG,TYPREG) From CPTLEC
 TYPCOURS = [F:TPY]RATTYP
Else
 TYPCOURS = 1
Endif
Return


$AFFECT_PTH
Raz [F:PAH]
[F:PAH]TYP = [M:DIA]SNS : # 1:Dépense/Ordre de paiement    2:Recette/Récibo

## Tiers (BPR)
Call ELEMNO(";",2,[F:PAH]BPR) From PAYPROPAL2

# Collectif (BPRSAC)
If [M:DIA]SACPAY<>""                     :# collectif imposé
 [F:PAH]BPRSAC = [M:DIA]SACPAY
Elsif [M:DIA]SAC<>""                     :# 1 seul collectif
 [F:PAH]BPRSAC = [M:DIA]SAC
Elsif !([M:DIA]PAYSAC=2 | [M:DIA]PAYDUD=2) :# 1 collectif/règlt ou 1 échéance/règlt
 Call ELEMNO(";",8,[F:PAH]BPRSAC) From PAYPROPAL2
Endif

## Société (CPY)
Call ELEMNO(";",1,[F:PAH]CPY) From PAYPROPAL2
Call LECTURE("CPY",[F:PAH]CPY,"") From CONTOBJ

## Site (FCY)
If [M:DIA]FCYPAY<>""                     :# site imposé
 [F:PAH]FCY = [M:DIA]FCYPAY
Elsif [M:DIA]ALLFCY=1                    :# 1 seul site
 [F:PAH]FCY = [M:DIA]FCY
Endif

## Date ordre de paiement/récibo (DAT)
[F:PAH]DAT = [M:DIA]ACCDAT

## Numéro ordre de paiement/recibos (NUM)
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 If [F:PAH]TYP = 1
  COMPTREG = [F:TCA]CODNUM(9)  : # Ordres de paiements
 Else
  COMPTREG = [F:TCA]CODNUM(10) : # Recibo
 Endif
Endif
If COMPTREG=""
 If [F:PAH]TYP = 1
  COMPTREG = "ORD"
 Else
  COMPTREG = "RCB"
 Endif
Endif
If [F:PAH]TYP = 1 or
& ((func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGNUM",[F:PAH]CPY)<>"2") or func AFNC.ACTIV("KAG") = 0) # Issue X3-107197
 ## Pas de structure de numérotation particulière pour les ordres de paiements
 Call NUMERO(COMPTREG,[F:PAH]FCY,[F:PAH]DAT,"",[F:PAH]NUM,STAT) From SUBANM
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE = mess(60,199,1)-"("+COMPTREG+") : "+MESSA
  Return
 Endif
Else
 Filter [ADI] Where NUMTAB = 362
 For [ADI]CODE
  VU = instr(1,[F:ADI]A1,num$(6)) : #  6:Recibo
  If VU
   TYPDOC = [F:ADI]CODE : Break
  Endif
 Next
 Filter [ADI]
 If !VU
  TYPDOC = "RC"
 Endif
 Call NUMEROARG(COMPTREG,[F:PAH]FCY,TYPDOC,3,[F:PAH]DAT,[F:PAH]VAC,[F:PAH]NUM,[F:PAH]CAI,[F:PAH]DATVLYCAI,STAT) From SUBANMARG
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANMARG
  GMESSAGE=mess(104,117,1)-"("+COMPTREG+") : "+MESSA
  Return
 Endif
Endif

## Etat (STA)
[F:PAH]STA = 1

## Régime TVA du tiers (VAC)
If [F:PAH]TYP = 1
 # Ordres de paiements => Fournisseurs
 Call LECTURE("BPS",[F:PAH]BPR,"") From CONTOBJ
 Call INIT_REGIME([F:PAH]BPR,[F:PAH]FCY,"F",[F:PAH]VAC) From CPTSUB
Elsif [F:PAH]TYP=2
 # Récibos => Clients
 Call LECTURE("BPC",[F:PAH]BPR,"") From CONTOBJ
 Call INIT_REGIME([F:PAH]BPR,[F:PAH]FCY,"C",[F:PAH]VAC) From CPTSUB
Endif

## Récepteur / no reception (BPRPTH/NUMPTH) : champs du récibos non initialisés

## Champs adresse
Call LECTURE("BPR",[F:PAH]BPR,"") From CONTOBJ
#Recherche de l'adresse de facturation associée au rib de type "fournisseur"
Filter [BID] Where [F:BID]BPATYP=1 & [F:BID]BPANUM=[F:PAH]BPR
Read [BID]BID0 First
Filter [BID]
If !fstat
 Read [BPA]BPA0 = 1;[F:PAH]BPR;[F:BID]BPAADD
 If !fstat : [F:PAH]BPAINV = [F:BID]BPAADD :  Gosub LECADR : Endif
Else
 #Recherche de l'adresse par défaut
 Read [BPA]BPA0 = 1;[F:PAH]BPR;[F:BPR]BPAADD
 If !fstat : [F:PAH]BPAINV = [F:BPR]BPAADD : Gosub LECADR : Endif
Endif

## Champs RIB, domiciliation
Call LECTURE("BPR",[F:PAH]BPR,"") From CONTOBJ
Local Char CRITBID (250)
Local Integer TROUVE
TROUVE=0
#Recherche du rib par défaut en fonction du tiers et de son code adresse
CRITBID = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[F:BPR]BPRNUM+"'"
CRITBID -=" & [F:BID]BPAADD ='"+[F:DUD]BPAPAY+"'"
CRITBID -=" & [F:BID]BIDNUMFLG = 2 "
Filter [BID] Where evalue (CRITBID)
Read [BID]BID0 First
Filter [BID]
If !fstat : TROUVE=1 : Endif
If !TROUVE
 # Rib par défaut
 Read [BID]BID0(3) = 1;[F:BPR]BPRNUM;[F:BPR]BIDNUM
 If fstat
  # sinon le premier par défaut du premier code adresse
  For [BID]BID0 Where BPATYP=1 & BPANUM=[F:BPR]BPRNUM
   If [F:BID]BIDNUMFLG = 2 : TROUVE=0 : Break : Endif
  Next
  If !TROUVE
   # Sinon le premier
   Read [BID]BID0(2) = 1;[F:BPR]BPRNUM
  Endif
 Endif
Endif

If fstat<=2
 [F:PAH]BID    = [F:BID]BIDNUM
 [F:PAH]BIDCRY = [F:BID]CRY
 [F:PAH]PAB1   = [F:BID]PAB1
 [F:PAH]PAB2   = [F:BID]PAB2
Endif

## Champs CREDAT, CREUSR
If dim([F:PAH]CREDAT)>0 : [F:PAH]CREDAT=date$ : Endif
If dim([F:PAH]CREUSR)>0 : [F:PAH]CREUSR=GUSER : Endif
Write [F:PAH]
If fstat
 GOK=0 : Call FSTA("PAH") From GLOCK : Return
Endif
Return


$LECADR
Read [BPA]BPA0 = 1;[F:PAH]BPR;[F:PAH]BPAINV
If !fstat
 Call LECTURE("BPR",[F:PAH]BPR,"") From CONTOBJ
 For I=0 To min(dim([F:PAH]BPANAM),dim([F:BPR]BPRNAM))-1
  [F:PAH]BPANAM(I) = [F:BPR]BPRNAM(I)
 Next I
Endif
For I=0 To min(dim([F:PAH]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
 [F:PAH]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
Next I
[F:PAH]POSCOD = [F:BPA]POSCOD
[F:PAH]CTY    = [F:BPA]CTY
[F:PAH]CRY    = [F:BPA]CRY
[F:PAH]SAT    = [F:BPA]SAT
If [F:BPA]CRYNAM<>"" : [F:PAH]CRYNAM = [F:BPA]CRYNAM
Else [F:PAH]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[F:PAH]CRYNAM) From TRTDIV
Endif
Return


$AFFECT_PAO
## Table des documents appliqués d'un ordre de paiement/recibo
NUMLIN = 1
For [TPD2]TPD0 Where CPY=[M:DIA]CPY & PAYTYP=[F:TP2]PAYTYP & GRPCRI=[F:TP2]GRPCRI
&                  & FLG=[F:TP2]FLG & FLGCRE=2
 Readlock [DUD]DUD1 = [F:TPD2]ACCNUM;[F:TPD2]DUDLIG
 If fstat=1
  GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:TPD2]ACCNUM)-num$([F:TPD2]DUDLIG)
  Break
 Elsif fstat
  GOK=0 : Call RSTA("DUD",num$([F:TPD2]ACCNUM)-num$([F:TPD2]DUDLIG)) From GLOCK
  Break
 Endif
 FACCUR = [F:DUD]CUR
 Call LECTURE("TCU",[F:DUD]CUR,"") From CONTOBJ
 ARD=[F:TCU]CURRND
 Raz [F:PAO]
 [F:PAO]TYP = [F:PAH]TYP
 [F:PAO]NUM = [F:PAH]NUM
 [F:PAO]LIG = [L]NUMLIN
 Case [F:DUD]TYP
  When "*SO"   : [F:PAO]IPTTYP = 1 : # Commandes clients
  When "*PO"   : [F:PAO]IPTTYP = 2 : # Commandes fournisseurs
  When Default : [F:PAO]IPTTYP = 3 : # Pièces comptables
 Endcase
 Case [F:PAO]IPTTYP
  When 1 : [F:PAO]VCRTYP = [L]BPCTYP
  When 2 : [F:PAO]VCRTYP = [L]BPSTYP
  When 3 : [F:PAO]VCRTYP = [F:DUD]TYP
 Endcase
 [F:PAO]VCRNUM   = [F:DUD]NUM
 [F:PAO]DUDNUM   = [F:DUD]ACCNUM
 [F:PAO]DUDLIG   = [F:DUD]DUDLIG
 ## [F:PAO]SNSDUD vaut -1 pour les avoirs, +1 pour les factures
 If [F:PAH]TYP = 1 : # Ordres de paiement
  [F:PAO]SNSDUD = [F:DUD]SNS*-1
 Else : # Récibos
  [F:PAO]SNSDUD = [F:DUD]SNS
 Endif
 [F:PAO]FCYLIN = [F:DUD]FCY
 [F:PAO]CURVCR = [F:DUD]CUR
 If [M:DI2]CTLFLG <> 2
  [F:PAO]AMTVCR = [F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Else  : # On peut modifier le montant à règler dans le masque de contrôle...
  [F:PAO]AMTVCR = [F:TPD2]AMTCUR
 Endif
 Call CONVERT([F:PAO]CURVCR,GCURSHR,[L]DEVLED,TYPCOURS,[F:PAH]DAT,[F:PAO]AMTVCR,[F:PAO]AMTRPT,STAT) From TRTDEV
 If STAT
  # Pas de cours de devise [F:PAH]CURVCR -> GCURSHR
  Call ECR_TRACE(mess(16,114,1)-[F:PAO]CURVCR-"->"-GCURSHR-"("+format$("D:"+GFMDAT,[F:PAH]DAT)-")",1) From GESECRAN
  GOK=0 : Break
 Endif
 Call CONVERT([F:PAO]CURVCR,[F:CPY]ACCCUR,[F:CPY]ACCCUR,TYPCOURS,[F:PAH]DAT,[F:PAO]AMTVCR,[F:PAO]AMTLOC,STAT) From TRTDEV
 If STAT
  # Pas de cours de devise [F:PAO]CURVCR -> [F:CPY]ACCCUR
  Call ECR_TRACE(mess(16,114,1)-[F:PAO]CURVCR-"->"-[F:CPY]ACCCUR-"("+format$("D:"+GFMDAT,[F:PAH]DAT)-")",1) From GESECRAN
  GOK=0 : Break
 Endif

 If [F:PAO]SNSDUD>1
  Local Decimal MTAGIO, MTAGIOLOC, MTAGIORPT
  If [F:DUD]DEP<>""
   Call ESC_AGIO([F:DUD]DEP,[F:PAO]AMTVCR,[F:PAH]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIO,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
   Call ESC_AGIO([F:DUD]DEP,[F:PAO]AMTLOC,[F:PAH]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIOLOC,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
   Call ESC_AGIO([F:DUD]DEP,[F:PAO]AMTRPT,[F:PAH]DAT,[F:DUD]DUDDAT,DELAI,[L]TAUX_ESC,[L]MTAGIORPT,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From TRTDIV
   If ([L]TAUX_ESC<0 & GDIV(2)="") or ([L]TAUX_ESC>0 & GDIV(5)="") : [L]TAUX_ESC=0 : Endif
  Endif
  If [L]TAUX_ESC <> 0
   If [L]TAUX_ESC>0 and DELAI<0 : [L]MTAGIO *= -1 : [L]MTAGIOLOC *= -1 : Endif
   [L]MTAGIO    = arr([L]MTAGIO,ARD)
   [L]MTAGIOLOC = arr([L]MTAGIOLOC,ARD)
   [L]MTAGIORPT = arr([L]MTAGIORPT,ARD)
  Endif

  [F:PAO]DEP = [F:DUD]DEP
  [F:PAO]AMTDEP = MTAGIO
  [F:PAO]AMTLOCDEP = MTAGIOLOC
  [F:PAO]AMTRPTDEP = MTAGIORPT
 Endif
 TOTFAC += [F:PAO]AMTVCR - [F:PAO]AMTDEP

 ## Remplissagge tableaux exploités pour le calcul des retenues
 TNUMVCR(NBDOC) = [F:PAO]VCRNUM
 TCURVCR(NBDOC) = [F:PAO]CURVCR
 TDUDNUM(NBDOC) = [F:PAO]DUDNUM
 TDUDLIG(NBDOC) = [F:PAO]DUDLIG
 TAMTVCR(NBDOC) = [F:PAO]AMTVCR

 NBDOC += 1
 Write [F:PAO]
 If fstat
  GOK=0 : Call FSTA("PAO") From GLOCK : Break
 Endif
 [L]NUMLIN += 1

 ## Maj montants temporaires de l'échéance
 [F:DUD]TMPCUR += [F:PAO]AMTVCR-[F:PAO]AMTDEP
 [F:DUD]TMPLOC += [F:PAO]AMTLOC-[F:PAO]AMTLOCDEP
 Call SLDECH("DUD")From MODECHE
 Rewrite [DUD]
 If fstat
  GOK=0 : Call FSTA("DUD") From GLOCK : Break
 Endif
Next
If GOK=0 : Return : Endif
If [F:PAH]TYP<>1 : Return : Endif : # Pour les récibos, on s'arrête là...

################################################################
## Calcul retenues...uniquement pour les ordres de paiements...
################################################################
Call CHARGE_RETENUES(2,[F:PAH]CPY,[F:PAH]TYP,[F:PAH]NUM,[F:PAH]DAT,TNUMVCR,TDUDNUM,TDUDLIG,NBDOC) From SUBPAHRTZ
## On efface les montants réels de retenues précédemment chargés...
For I = 0 To [M:PAH3]NBRIT-1
 [M:PAH3]RITAMT(I) = 0
 [M:PAH3]RITAMTRPT(I) = 0
Next
Gosub RAZ_TABRET
For DOC=0 To NBDOC-1
 NBFAC = NBDOC
 Call CAL_RETENUES(2,[F:PAH]TYP,[F:PAH]NUM,[F:PAH]DAT,[F:PAH]CPY,[F:PAH]BPR,DOC+1,TNUMVCR(DOC),TDUDNUM(DOC),TDUDLIG(DOC),[F:PAO]CURVCR,
&                  TAMTVCR(DOC),NBFAC,TABCODRTZ,TABAMT,TABAMTRPT,TABBAS,TABBASRPT,TABBASCUM,TABRITCUM,TABREPRTZ) From SUBPAHRTZ
Next
If GOK<1 : Return : Endif

#####################################################################################################
## Stockage retenues dans la table PAYPTHDOC... (Table des documents appliqués)
#####################################################################################################

For DOC=0 To NBDOC-1
 Read [PAO]PAO0 = [F:PAH]TYP ; [F:PAH]NUM ; DOC+1
 If !fstat
  Filter [RIU] Where TYPREC = 1 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = [F:PAO]DUDLIG
  Readlock [RIU]RIU0 First
  Filter [RIU]
  If fstat=1
   GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
  Endif
  Filter [RIU2] Where TYPREC = 0 & NUM = [F:PAO]VCRNUM & DUDNUM = [F:PAO]DUDNUM & DUDLIG = 1
  Readlock [RIU2]RIU0 First
  Filter [RIU2]
  If fstat=1
   GOK=-1 : GLOCK="$RITDUD"-num$(TYPREC)-[F:PAO]VCRNUM-num$([F:PAO]DUDNUM)-num$([F:PAO]DUDLIG) : Break
  Endif
  For RTZ=0 To [M:PAH3]NBRIT-1
   If TABCODRTZ(DOC,RTZ)<>""
    [F:PAO]RITCOD(RTZ)     += TABCODRTZ(DOC,RTZ)
    [F:PAO]RITAMT(RTZ)     += TABAMT(DOC,RTZ)
    [F:PAO]RITAMTRPT(RTZ)  += TABAMTRPT(DOC,RTZ)
    [F:RIU]RITAMT(RTZ)     += TABAMT(DOC,RTZ)
    [F:RIU]RITAMTRPT(RTZ)  += TABAMTRPT(DOC,RTZ)
    [F:RIU2]RITAMT(RTZ)    += TABAMT(DOC,RTZ)
    [F:RIU2]RITAMTRPT(RTZ) += TABAMTRPT(DOC,RTZ)
   Endif
  Next
  Rewrite [RIU]
  If fstat
   GOK = 0 : Call FSTA("RIU") From GLOCK : Break
  Endif
  Rewrite [RIU2]
  If fstat
   GOK = 0 : Call FSTA("RIU2") From GLOCK : Break
  Endif
 Endif
 Rewrite [PAO]
 If fstat
  GOK = 0 : Call FSTA("PAO") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif


#####################################################################################################
## Ecriture dans la table PAYPTHRIT... (Table des montants retenues par ordre de paiements/récibos)
#####################################################################################################
For RIT = 0 To [M:PAH3]NBRIT-1
 If [M:PAH3]RITCOD(RIT)<>""
  [F:PRI]TYP    = [F:PAH]TYP
  [F:PRI]NUM    = [F:PAH]NUM
  [F:PRI]DES    = [M:PAH3]DES(RIT)
  [F:PRI]CUR    = TCURVCR(0)
  [F:PRI]RITCOD = [M:PAH3]RITCOD(RIT)
  CODRTZ = [F:PRI]RITCOD
  Gosub SEQ_NUM
  [F:PRI]RITNUM = NUMRTZ
  [F:PRI]AMTRTZ = sum(TABAMT(0..NBDOC-1,RIT))
  [F:PRI]BASRTZ = sum(TABBAS(0..NBDOC-1,RIT))
  [F:PRI]AMTRTZRPT = sum(TABAMTRPT(0..NBDOC-1,RIT))
  [F:PRI]BASRTZRPT = sum(TABBASRPT(0..NBDOC-1,RIT))
  [F:PRI]BASMONCUM = TABBASCUM(RIT)
  [F:PRI]AMTMONCUM = TABRITCUM(RIT)
  Write [PRI]
  If fstat
   GOK = 0 : Call FSTA("PRI") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif


#####################################################################################################
## Ecriture dans la table RITCUM... (Tale des retenues mensuels cumulés (GANANCIAS))
#####################################################################################################
$WRITE_RITCUM
ANNEE = year([F:PAH]DAT)
MOIS  = month([F:PAH]DAT)
For NUMRET = 0 To [M:PAH3]NBRIT-1
 Read [RTZ]RTZ0 = [M:PAH3]RITCOD(NUMRET)
 If !fstat & [F:RTZ]MET = 2
  Read [RCU]RCU0 = [F:PAH]CPY ; [F:PAH]BPR ; [L]ANNEE ; [L]MOIS ; [M:PAH3]RITCOD(NUMRET)
  If !fstat
   [F:RCU]AMTMON += [M:PAH3]RITAMTRPT(NUMRET)
   [F:RCU]BASMON += [M:PAH3]RITBASRPT(NUMRET)
   Rewrite [RCU]
   If fstat
    GOK=0 : Call FSTA("RCU") From GLOCK : Break
   Endif
  Elsif fstat
   [F:RCU]CPY    = [F:PAH]CPY
   [F:RCU]BPR    = [F:PAH]BPR
   [F:RCU]YEA    = [L]ANNEE
   [F:RCU]MON    = [L]MOIS
   [F:RCU]RITCOD = [M:PAH3]RITCOD(NUMRET)
   [F:RCU]AMTMON = [M:PAH3]RITAMTRPT(NUMRET)
   [F:RCU]BASMON = [M:PAH3]RITBASRPT(NUMRET)
   Write [RCU]
   If fstat
    GOK=0 : Call FSTA("RCU") From GLOCK : Break
   Endif
  Endif
 Endif
Next
If GOK<1 : Return : Endif

TOTFAC -= sum(TABAMT(0..NBDOC-1,0..NBRIT))
Return

# On affecte un numéro de retenue à chaque retenue
$SEQ_NUM
Read [F:RTZ]RTZ0 = CODRTZ
Call NUMERO([F:RTZ]COU,[F:PAH]CPY,[F:PAH]DAT,CODRTZ,NUMRTZ,STAT) From SUBANM
If GOK<0 : Return
Elsif GOK<1 | STAT
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE=mess(104,117,1)-"("+[F:RTZ]COU+") : "+MESSA
 Endif
 GOK=0 : Return
Endif
Return



$AFFECT_PTD
Raz [F:PYP]
[F:PYP] = [F:PAH]
[F:PYP]LIG = 1
## Mode de règlement (PAM)
Call ELEMNO(";",4,[L]MODREG) From PAYPROPAL2
[F:PYP]PAM = [L]MODREG
## Devise règlement (CUR)
If [M:DIA]CURPAY<>""
 [F:PYP]CUR=[M:DIA]CURPAY
Else
 Call ELEMNO(";",3,[F:PYP]CUR) From PAYPROPAL2
Endif
## Banque (BAN)
Gosub RECH_BAN From PAYPROPAL2
If [L]BAN<>""
 Call LECTURE("BAN",[L]BAN,"") From CONTOBJ
 [F:PYP]BAN  = [L]BAN
Endif
## N°chèque (CHQNUM) : initialisé dans le cas d'un ordre de paiement ssi le code activité KAQ est actif
## et si le mode de règlement est de type 2 (cheques al dia) ou de type 3 (cheques diferidos)
If [F:PAH]TYP=1 & func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGCHQ",[F:PAH]CPY)="2" # Issue X3-107197
 If [F:PAH]TYP = 1 : # Ordre de paiements
  If clalev([F:CHN])=0 : Local File CHQNUM [CHN] : Endif
  Call LEC_TAM(GCURLEG, [F:PYP]PAM) From CPTLEC
  If !fstat & find([F:TAM]TYP,2,3)
   Filter [CHN] Where BAN = [F:PYP]BAN & STA=1
   Readlock [CHN]CHN0 First
   Filter [CHN]
   If fstat=1
    GOK=-1 : GLOCK="$CHQNUM"-[F:PYP]BAN-[F:CHN]CHQNUM : Return
   Elsif fstat
    GOK=0 : Call RSTA("CHN",[F:PYP]BAN-[F:CHN]CHQNUM) From GLOCK : Return
   Elsif !fstat
    [F:CHN]STA = 2
    [F:CHN]PAYORDNUM = [F:PAH]NUM
    Rewrite [CHN]
    If fstat
     GOK=0 : Call FSTA("CHN") From GLOCK : Return
    Endif
    [F:PYP]CHQNUM = [F:CHN]CHQNUM
   Endif
  Endif
 Endif
Endif
## N°carte... (CRDTYP, CRDNUM) : non initialisé
## Date émission (SENDAT). Elle est saissable dans le cas des modes de règlements :
##    - Cheques al dia (type 2)
##    - Cheques diferidos (type 3)
##    - Cheques de terceros (type 4)
##    - Tarjetas (type 5)
##    - Débit en compte (type 6)
## .. et initialisée par la date de l'ordre de paiement ou la date du récibo
Call LEC_TAM(GCURLEG, [F:PYP]PAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,2,3,4,5,6)
 [F:PYP]SENDAT = [0/0/0]
Else
 [F:PYP]SENDAT = [F:PAH]DAT
Endif
## Date échéance (DUDDAT). Elle est saisissable dans le cas des modes de règlements :
##    - Cheques diferidos (type 3)
##    - Cheques de terceros (type 4)
##    - Tarjetas (type 5)
## ... et initialisée par :
##       Ordres de paiements : Date échéance = date de la la facture (échéance) plus lointaine
##       Récibos : Date échéance = date du récibo
Call LEC_TAM(GCURLEG, [F:PYP]PAM) From CPTLEC
If !fstat & !find([F:TAM]TYP,3,4,5)
 [F:PYP]SENDAT = [0/0/0]
Elsif [F:PAH]TYP = 1
 If clalev([F:DUD4])=0 : Local File GACCDUDATE [DUD4] : Endif
 Local Integer I
 Local Date DATMAX
 DATMAX =  [0/0/0]
 For I = 0 To [L]NBDOC-1
  Read [DUD]DUD1 = TDUDNUM(I) ; TDUDLIG(I)
  If !fstat & DATMAX<[F:DUD4]DUDDAT
   DATMAX = [F:DUD4]DUDDAT
  Endif
 Next
 If DATMAX<>[0/0/0]
  [F:PYP]SENDAT = DATMAX
 Else
  [F:PYP]SENDAT = [F:PAH]DAT
 Endif
Elsif [F:PAH]TYP = 2
 [F:PYP]SENDAT = [F:PAH]DAT
Endif
## Montant échéance (AMTLIN2) (Dev. échéance)
[F:PYP]AMTLIN2 = TOTFAC
## Montant règlement (AMTLIN) (Dev. règlement)
If [F:PYP]CUR = FACCUR
 [F:PYP]AMTLIN = [F:PYP]AMTLIN2
Else
 Call CONVERT(FACCUR,[F:PYP]CUR,[F:CPY]ACCCUR,TYPCOURS,[F:PAH]DAT,[F:PYP]AMTLIN2,
&             [F:PYP]AMTLIN,[L]STAT) From TRTDEV
 If [L]STAT
  # Pas de cours de devise [F:DUD]CUR -> [F:PYP]CUR
  Call ECR_TRACE(mess(16,114,1)-FACCUR-"->"-[F:PYP]CUR-"("+format$("D:"+GFMDAT,[F:PAH]DAT)-")",1) From GESECRAN
  GOK=0 : Return
 Endif
Endif
## Champs liés à l'endossement (KAD) : SENORI, SENCRN, SENBPR, PAYNUMEND : non renseignés. Les ordres de paiements/récibos
## générés seront sur des modes de règlements différents de l'endossement
Write [F:PYP]
If fstat
 GOK=0 : Call FSTA("PYP") From GLOCK : Return
Endif
Return



$RAZ_TABRET
Local Char    TABCODRTZ(GLONRTZ)(0..99,0..dim([M:PAH3]RITNUM)-1) : # Tableau des codes retenues/document
Local Decimal TABAMT(0..99,0..dim([M:PAH3]RITNUM)-1): # Tableau montants retenues par doc et code retenue
Local Decimal TABAMTRPT(0..99,0..dim([M:PAH3]RITNUM)-1): # Idem TABAMT mais en devise reporting
Local Decimal TABBAS(0..99,0..dim([M:PAH3]RITNUM)-1): # Tableau bases retenues par document et code retenue
Local Decimal TABBASRPT(0..99,0..dim([M:PAH3]RITNUM)-1): # Idem TABBAS mais en devise reporting

Local Decimal TABBASCUM(0..dim([M:PAH3]RITNUM)-1): # Base cumulée (pour retenues Ganancias)
Local Decimal TABRITCUM(0..dim([M:PAH3]RITNUM)-1): # montant retenue cumulée (pour retenues Ganancias)

Local Decimal TABREPRTZ(0..99)
Local Integer NBFAC
Raz TABCODRTZ, TABAMT, TABAMTRPT, TABBAS, TABBASRPT, TABREPRTZ, TABBASCUM, TABRITCUM

For I = 0 To [M:PAH3]NBRIT-1
 [M:PAH3]RITAMT(I)    = 0
 [M:PAH3]RITAMTRPT(I) = 0
 [M:PAH3]RITBAS(I)    = 0
 [M:PAH3]RITBASRPT(I) = 0
Next
Return


$TRACE
SEP=", "
Call ECR_TRACE(" ",0) From GESECRAN
Gosub TRACE_PAH
For [PAO]PAO0 Where TYP=[F:PAH]TYP & NUM=[F:PAH]NUM
 Gosub TRACE_PAO
Next
GMESSAGE=""
Return


$TRACE_PAH
# Ordre de paiement/Recibo NUM : FCY, DAT, BAN, PAM, BPRSAC, BPR, BPRNAM, AMTCUR CUR
GMESSAGE = ""
GMESSAGE=[F:PAH]FCY+SEP+format$("D:"+GFMDAT,[F:PAH]DAT)+SEP+[L]BAN+SEP+[L]MODREG
Call LECTURE("BPR",[F:PAH]BPR,"") From CONTOBJ
GMESSAGE+=SEP+[F:PAH]BPRSAC-[F:PAH]BPR+SEP+[F:BPR]BPRNAM
GMESSAGE+=SEP+num$([F:PYP]AMTLIN)-[F:PYP]CUR
If [M:DIA]SIM<>2
 Call ECR_TRACE(mess([F:PAH]TYP,8501,1)-[F:PAH]NUM-":"-GMESSAGE,0) From GESECRAN
Else
 Call ECR_TRACE(mess([F:PAH]TYP,8501,1)-":"-GMESSAGE,0) From GESECRAN
Endif
Return

$TRACE_PAO
# VCRTYP, VCRNUM, FCY, SAC, BPR, BPRNAM, AMTLIN, CUR
GMESSAGE = ""
GMESSAGE+=[F:PAO]VCRTYP+SEP+[F:PAO]VCRNUM+SEP+[F:PAO]FCYLIN
Call LECTURE("GAS",[F:PAO]VCRNUM,[F:PAO]VCRTYP) From CONTOBJ
GMESSAGE+=SEP+num$([F:PAO]AMTVCR-[F:PAO]AMTDEP)-[F:PAO]CURVCR
Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Return

