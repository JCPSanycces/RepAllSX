##################################################
Subprog ACT_SIMCHGITG
Global Integer GSIMCHGITG
Call TRT_CHGITG From FUNCHGITG
Kill GSIMCHGITG

End
##################################################


Subprog C_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
If [M]TCLCOD <> ""
   If VALEUR = [M]TCLCOD
      mkstat = 2
   Endif
Endif

End

Subprog AM_TCLCODOLD(VALEUR)
Variable Char    VALEUR()
Read [ITG]ITG1=VALEUR;""
If fstat
   Raz [ITG]
Endif

[M]SCSFLGOLD = [F:ITG]SCSFLG
[M]PHAFLGOLD = [F:ITG]PHAFLG
[M]GENFLGOLD = [F:ITG]GENFLG
[M]TOOFLGOLD = [F:ITG]TOOFLG
[M]INTFLGOLD = [F:ITG]INTFLG
[M]PURFLGOLD = [F:ITG]PURFLG
[M]SALFLGOLD = [F:ITG]SALFLG
[M]MFGFLGOLD = [F:ITG]MFGFLG
[M]DLVFLGOLD = [F:ITG]DLVFLG
[M]SCPFLGOLD = [F:ITG]SCPFLG

If [M]TCLCOD <> ""
   If [M]SCSFLG <> [M]SCSFLGOLD
      Chgstl [M]SCSFLG    With "AWARNLOW"
      Chgstl [M]SCSFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SCSFLG    With ""
      Chgstl [M]SCSFLGOLD With ""
   Endif
   If [M]PHAFLG <> [M]PHAFLGOLD
      Chgstl [M]PHAFLG    With "AWARNLOW"
      Chgstl [M]PHAFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]PHAFLG    With ""
      Chgstl [M]PHAFLGOLD With ""
   Endif
   If [M]GENFLG <> [M]GENFLGOLD
      Chgstl [M]GENFLG    With "AWARNLOW"
      Chgstl [M]GENFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]GENFLG    With ""
      Chgstl [M]GENFLGOLD With ""
   Endif
   If [M]TOOFLG <> [M]TOOFLGOLD
      Chgstl [M]TOOFLG    With "AWARNLOW"
      Chgstl [M]TOOFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]TOOFLG    With ""
      Chgstl [M]TOOFLGOLD With ""
   Endif
   If [M]INTFLG <> [M]INTFLGOLD
      Chgstl [M]INTFLG    With "AWARNLOW"
      Chgstl [M]INTFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]INTFLG    With ""
      Chgstl [M]INTFLGOLD With ""
   Endif
   If [M]PURFLG <> [M]PURFLGOLD
      Chgstl [M]PURFLG    With "AWARNLOW"
      Chgstl [M]PURFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]PURFLG    With ""
      Chgstl [M]PURFLGOLD With ""
   Endif
   If [M]SALFLG <> [M]SALFLGOLD
      Chgstl [M]SALFLG    With "AWARNLOW"
      Chgstl [M]SALFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SALFLG    With ""
      Chgstl [M]SALFLGOLD With ""
   Endif
   If [M]MFGFLG <> [M]MFGFLGOLD
      Chgstl [M]MFGFLG    With "AWARNLOW"
      Chgstl [M]MFGFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]MFGFLG    With ""
      Chgstl [M]MFGFLGOLD With ""
   Endif
   If [M]DLVFLG <> [M]DLVFLGOLD
      Chgstl [M]DLVFLG    With "AWARNLOW"
      Chgstl [M]DLVFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]DLVFLG    With ""
      Chgstl [M]DLVFLGOLD With ""
   Endif
   If [M]SCPFLG <> [M]SCPFLGOLD
      Chgstl [M]SCPFLG    With "AWARNLOW"
      Chgstl [M]SCPFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SCPFLG    With ""
      Chgstl [M]SCPFLGOLD With ""
   Endif
   Affzo [M:DIA0]                            # hcb x3-99277
Endif

Local Integer I
Raz [M]ITMREFSTR
Raz [M]ITMREFEND
Raz [M]SELFOR
If dim([M]TSICODSTR) > 0
  For I = 0 To dim([M]TSICODSTR)-1
      Raz [M]TSICODSTR
      Raz [M]TSICODEND
  Next I
Endif


Affzo [M:DIA]                           # hcb x3-99277
#Affzo [M]35                            # hcb x3-99277

End

Subprog AM_TCLCOD(VALEUR)
Variable Char    VALEUR()
Read [ITG]ITG1=VALEUR;""
If fstat
   Raz [ITG]
Endif

[M]SCSFLG    = [F:ITG]SCSFLG
[M]PHAFLG    = [F:ITG]PHAFLG
[M]GENFLG    = [F:ITG]GENFLG
[M]TOOFLG    = [F:ITG]TOOFLG
[M]INTFLG    = [F:ITG]INTFLG
[M]PURFLG    = [F:ITG]PURFLG
[M]SALFLG    = [F:ITG]SALFLG
[M]MFGFLG    = [F:ITG]MFGFLG
[M]DLVFLG    = [F:ITG]DLVFLG
[M]SCPFLG    = [F:ITG]SCPFLG

   If [M]SCSFLG <> [M]SCSFLGOLD
      Chgstl [M]SCSFLG    With "AWARNLOW"
      Chgstl [M]SCSFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SCSFLG    With ""
      Chgstl [M]SCSFLGOLD With ""
   Endif
   If [M]PHAFLG <> [M]PHAFLGOLD
      Chgstl [M]PHAFLG    With "AWARNLOW"
      Chgstl [M]PHAFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]PHAFLG    With ""
      Chgstl [M]PHAFLGOLD With ""
   Endif
   If [M]GENFLG <> [M]GENFLGOLD
      Chgstl [M]GENFLG    With "AWARNLOW"
      Chgstl [M]GENFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]GENFLG    With ""
      Chgstl [M]GENFLGOLD With ""
   Endif
   If [M]TOOFLG <> [M]TOOFLGOLD
      Chgstl [M]TOOFLG    With "AWARNLOW"
      Chgstl [M]TOOFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]TOOFLG    With ""
      Chgstl [M]TOOFLGOLD With ""
   Endif
   If [M]INTFLG <> [M]INTFLGOLD
      Chgstl [M]INTFLG    With "AWARNLOW"
      Chgstl [M]INTFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]INTFLG    With ""
      Chgstl [M]INTFLGOLD With ""
   Endif
   If [M]PURFLG <> [M]PURFLGOLD
      Chgstl [M]PURFLG    With "AWARNLOW"
      Chgstl [M]PURFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]PURFLG    With ""
      Chgstl [M]PURFLGOLD With ""
   Endif
   If [M]SALFLG <> [M]SALFLGOLD
      Chgstl [M]SALFLG    With "AWARNLOW"
      Chgstl [M]SALFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SALFLG    With ""
      Chgstl [M]SALFLGOLD With ""
   Endif
   If [M]MFGFLG <> [M]MFGFLGOLD
      Chgstl [M]MFGFLG    With "AWARNLOW"
      Chgstl [M]MFGFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]MFGFLG    With ""
      Chgstl [M]MFGFLGOLD With ""
   Endif
   If [M]DLVFLG <> [M]DLVFLGOLD
      Chgstl [M]DLVFLG    With "AWARNLOW"
      Chgstl [M]DLVFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]DLVFLG    With ""
      Chgstl [M]DLVFLGOLD With ""
   Endif
   If [M]SCPFLG <> [M]SCPFLGOLD
      Chgstl [M]SCPFLG    With "AWARNLOW"
      Chgstl [M]SCPFLGOLD With "AWARNLOW"
   Else
      Chgstl [M]SCPFLG    With ""
      Chgstl [M]SCPFLGOLD With ""
   Endif

Affzo [M:DIA0]25  # hcb x3-99277

End

Subprog C_TCLCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR = [M]TCLCODOLD
   mkstat = 2
Endif
Read [ITG]ITG1=VALEUR;""
If fstat
   Raz [ITG]
Endif
If [M]SCSFLGOLD = [F:ITG]SCSFLG &
&  [M]PHAFLGOLD = [F:ITG]PHAFLG &
&  [M]GENFLGOLD = [F:ITG]GENFLG &
&  [M]TOOFLGOLD = [F:ITG]TOOFLG &
&  [M]INTFLGOLD = [F:ITG]INTFLG &
&  [M]PURFLGOLD = [F:ITG]PURFLG &
&  [M]SALFLGOLD = [F:ITG]SALFLG &
&  [M]MFGFLGOLD = [F:ITG]MFGFLG &
&  [M]DLVFLGOLD = [F:ITG]DLVFLG &
&  [M]SCPFLGOLD = [F:ITG]SCPFLG
   #MAE,bg 83265
   OK=2
   Call AVERTIR(mess(920,196,1),OK ) From GESECRAN
   If OK =1 :    mkstat = 2 : Endif
Endif

End

Subprog IB_ITMREFSTR
If [M]ITMREFSTR = ""
   GBOUT1 = ""
Endif
End

Subprog IB_ITMREFEND
If [M]ITMREFEND = ""
   GBOUT1 = ""
Endif

End

Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CONTROLE("ITM","",VALEUR,"",mkstat) From CONTOBJ   # hcb 95483
   If [F:ITM]TCLCOD <> [M]TCLCODOLD
      GMESSAGE= mess(65,193,1)
      mkstat = 2
   Endif
Endif

End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif

End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Call CONTROLE("ITM","",VALEUR,"",mkstat) From CONTOBJ   # hcb 95483
   If [F:ITM]TCLCOD <> [M]TCLCODOLD
      GMESSAGE= mess(65,193,1)
      mkstat = 2
   Endif
Endif



If VALEUR < [M]ITMREFSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

Subprog AM_TSICODSTR(VALEUR)
Variable Char    VALEUR()
If [M]TSICODEND(indice) = ""    : [M]TSICODEND(indice) = VALEUR : Affzo [M]TSICODEND(indice) : Endif
If [M]TSICODEND(indice)< VALEUR : [M]TSICODEND(indice) = VALEUR : Affzo [M]TSICODEND(indice) : Endif
End

Subprog C_TSICODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TSICODSTR(indice) : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif

End

