End

$ON_INI
Onevent INIT_AREA Call D_INI(zc) From W1TRTGENCTR
Return

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
If varinit([M]INI,indice)=0
 ## Action INICRIDIA
 Gosub GRISE From DIVPAYE
Endif
Gosub _AFF
End

$CHG_STY
