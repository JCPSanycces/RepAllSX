 Affzo PRF(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_PRF(zc) From W1TRTGENCTR
Onkey   2 Titled GBOUTS Call S_PRF(zc) From W1TRTGENCTR
Onkey 144 Titled GBOUTP Call P_PRF(zc) From W1TRTGENCTR
Onkey 146 Titled GBOUTA Call SA_PRF(zc) From W1TRTGENCTR
Gosub _AFF
End

Subprog C_PRF(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
If !mkstat
 ## Action CONTPRF
 Call CONTPRF(VALEUR) From SUBPRF
 If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
 Endif
Endif
Gosub _AFF
End

