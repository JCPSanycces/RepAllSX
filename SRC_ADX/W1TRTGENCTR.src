$AMM_DOCFINA
Call AM_DOCFINA(zc)
If !mkstat & GOBJET
 zoncou = "DOCFINA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DOCFINA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_DOCFINA(VALEUR) From TRTGENCTR
If mkstat : GERR = 1 : GZONE = "DOCFINA" : GZNUM = 51437 : Endif
Gosub _AFF
End

Subprog S_DOCFINA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "20"
 PARMSK(4) = [M]VALFININT
 PARMSK(5) = [M]VALFINPAR
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALFININT = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]NOLIB)
 PARMSK(3) = "20"
 PARMSK(4) = [M]VALFININT
 PARMSK(5) = [M]VALFINPAR
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]VALFININT = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_DOCFINA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = "M"
 PARMSK(2) = [M]VALFINPAR
 PARMSK(3) = num$([M]NOLIB)
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FLGUPD
Onevent INIT_AREA Call D_FLGUPD(zc) From W1TRTGENCTR
Onevent BEFORE_INPUT Call AS_FLGUPD(zc) From W1TRTGENCTR
Return

Subprog D_FLGUPD(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGUPD,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

Subprog AS_FLGUPD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

