#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201802002
# Issue X3-66468 - 2018-01-11 by SINGC
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201802002(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201802002(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Char SDESAXX(GLONAX3)
Local Char SSHOAXX(GLONAX1)

  Call ECR_TRACE("UTIPJM201802002: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:PJTC]) = 0 : Local File =DOSSIER + ".PJMTIMCAT" [PJTC] : Endif
  If clalev([F:ADI])  = 0 : Local File =DOSSIER + ".ATABDIV"   [ADI]  : Endif
  If clalev([F:ADV])  = 0 : Local File =DOSSIER + ".ATABTAB"   [ADV]  : Endif
  If clalev([F:AXX])  = 0 : Local File =DOSSIER + ".ATEXTRA"   [AXX]  : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [PJTC]
  Filter [ADI] Where [F:ADI]NUMTAB = 640
  For [ADI]
    Look [PJTC]PJTC0=[F:ADI]CODE
    If fstat <> 0 Then
      [F:PJTC]CATCOD = [F:ADI]CODE
      Call DUPTEXTRA("ATABDIV", "LNGDES", "640", [F:ADI]CODE, "PJMTIMCAT", "DESAXX", [F:PJTC]CATCOD, "") From ATEXTRA
      Call DUPTEXTRA("ATABDIV", "SHODES", "640", [F:ADI]CODE, "PJMTIMCAT", "SHOAXX", [F:PJTC]CATCOD, "") From ATEXTRA
      Write [PJTC]
      COMPTEUR += 1
      If fstat Then
        Call ECR_TRACE("File PJMTIMCAT" - [F:PJTC]CATCOD + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
    # -----------------
    Call SUPTEXTRA("ATABDIV", "LNGDES", "640", [F:ADI]CODE) From ATEXTRA
    Call SUPTEXTRA("ATABDIV", "SHODES", "640", [F:ADI]CODE) From ATEXTRA
  Next
  Filter [ADI]
  # -----------------
  Call SUPTEXTRA("ATABTAB", "LNGDES", "640", "") From ATEXTRA
  Call SUPTEXTRA("ATABTAB", "SHODES", "640", "") From ATEXTRA
  Delete [ADI] Where [F:ADI]NUMTAB = 640
  COMPTEUR += 1
  If fstat Then
    Call ECR_TRACE("File ATABDIV" - [F:ADI]NUMTAB + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  # -----------------
  Delete [ADV] Where [F:ADV]NUMTAB = 640
  COMPTEUR += 1
  If fstat Then
    Call ECR_TRACE("File ATABTAB" - [F:ADV]NUMTAB + ", Error =" - num$(fstat), 1) From GESECRAN
    GOK = 1
    IERR = 1
    NCOUNTERROR += 1
  Endif
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201802002 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201802002 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [PJTC]
  Close Local File [ADI]
  Close Local File [ADV]
  Close Local File [AXX]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMCAT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMCAT") : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABDIV") : End : Endif
  If filinfo(filpath("FIL","ATABTAB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABTAB") : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201802002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTIMCAT","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTIMCAT") : End : Endif
  If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABDIV") : End : Endif
  If filinfo(filpath("FIL","ATABTAB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATABTAB") : End : Endif
  If filinfo(filpath("FIL","ATEXTRA","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ATEXTRA") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201802002(APPLI)
End

