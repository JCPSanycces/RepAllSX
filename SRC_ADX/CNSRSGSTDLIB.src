#** #############################################################################################################
#*
#* Procedure:  OPEN_REPORT
#*
#* Purpose:    Starts a given X3 report.
#*
#*
#* Parameters:
#*
#* @param PRTCOD      Value Char     Name of the report or print code
#*
#*! #############################################################################################################

Subprog OPEN_REPORT( PRTCOD )
Value Char PRTCOD()
    Local Char TBPAR(30)(1..50), TBVAL(30)(1..50)
    Local Char RPT(20)

    Call SAIETAT( PRTCOD, RPT ) From GCONSULT
    If RPT <> ""
        Call ETATN( RPT, GFONCTION, TBPAR, TBVAL ) From ETAT
    Endif
End



