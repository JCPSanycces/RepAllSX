Subprog OPEN_RS_EXPORT_DIALOG
    # ...
    Call OPEN_DIALOG( right$( GFONCTION, 5 ) + "Q" )
End



#** #############################################################################################################
#*
#* Procedure:  OPEN_DIALOG
#*
#* Purpose:    Opens the RS property/export dialog
#*
#*
#* Parameters:
#*
#* @param SCREEN      Const Char ()     Screen code (CODMSK)
#*
#*! #############################################################################################################

Subprog OPEN_DIALOG( SCREEN )
Value Char SCREEN()                                 # Screen code.
    Local Char RESULT(255)      : RESULT = ""       # Result parameter (variable VALEUR) of the child screen
    Local Char PARAM(10)(1..10)                     # Parameter array for the SAISIE_xxx procedure
    Local Char PROG(GLONADC)                        # Standard processing  for the child screen
    Local Char PROGSPE(GLONADC)                     # SPEcific processing for the child screen

    # Get the standard and specific processing names for the local BID screen.
    Call GETSCREENTRT( SCREEN, PROG, PROGSPE ) From BIDLOC

    # Open the property screen.
    Call SAISIE_CHAR( RESULT, PARAM, SCREEN, PROG, PROGSPE ) From GSAISIE
End



#** #############################################################################################################
#*
#* Function:   REPLACE
#*
#* Purpose:    Replace a given text in a string by another one.
#*
#*
#* Parameters:
#*
#* @param CONTENT            Value Char  Contains the text to convert.
#* @param SRC                Value Char  Contains the text to replace.
#* @param DEST               Value Char  Contains the text that should replace the text
#*                           in SRC.
#*
#*! #############################################################################################################

Funprog REPLACE( CONTENT, SRC, DEST )
Value Char CONTENT()
Value Char SRC()
Value Char DEST()

    Local Integer K

     K = instr( 1, CONTENT, SRC )
     While K
        CONTENT = left$( CONTENT, K - 1 ) + DEST + right$( CONTENT, K + len( SRC ) )
        K = instr( K + len( DEST ), CONTENT, SRC )
     Wend
End CONTENT



# ###############################################################################################################
# ##########
# ########## Utility functions/procedures
# ##########
# ########## - XML file creation
# ##########
# ###############################################################################################################

#** #############################################################################################################
#*
#* Sub chunk:  XML_INIT
#*
#* Purpose:    Initialize the XML tag stack for further use of XML_... chunks and
#*             functions. Creates a file selector XOUT (... Using [XOUT])
#*
#*
#* Parameters: None
#*
#*! #############################################################################################################

$XML_INIT
    # Initialize an XML tag stack.
    Local Char    XMLTAGSTACK(255)(50)
    Local Integer XMLTAGSTACKPOINTER : XMLTAGSTACKPOINT = 0
    Local Char    XMLTAG(50)         : XMLTAG = ""
    Local Char    XMLATTR(50)        : XMLATTR = ""
    Local Char    XMLCONTENT(255)    : XMLCONTENT = ""
    Local Char    XMLFILENAME(255)   : XMLFILENAME = ""
    Local Char    XMLDTDNAME(255)    : XMLDTDNAME = ""
    Local Integer XMLFILEERR         : XMLFILEERR = 0
Return



#** #############################################################################################################
#*
#* Sub chunk:  XML_OPEN
#*
#* Purpose:    Opens an XML file.
#*
#* Note:       Creates a file selector XOUT (... Using [XOUT]). So you can send data
#*             directly to the XML file using XOUT.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLFILENAME        local char(255)   XML file name.
#* @param XMLDTDNAME         local char(255)   Optional DTD file name.
#*
#*! #############################################################################################################

$XML_OPEN
    # Open index XML file for writing.
    Onerrgo XML_ERROR
    Openo XMLFILENAME, 0                                                 Using [XOUT]
    Onerrgo
    If XMLFILEERR
        Return
    Endif
    Iomode adxirs chr$(13) + chr$(10)                                    Using [XOUT]
    Iomode adxifs ";"                                                    Using [XOUT]

    # Write XML header
    Wrseq "<?xml version='1.0' encoding='UTF-8'?>"                       Using [XOUT]
    If XMLDTDNAME <> ""
        Wrseq "<!DOCTYPE DataSet SYSTEM '" + XMLDTDNAME + "'>"           Using [XOUT]
    Endif
Return
$XML_ERROR
    XMLFILEERR = 1
Resume



#** #############################################################################################################
#*
#* Sub chunk:  XML_CLOSE
#*
#* Purpose:    ...
#*
#*
#* Parameters: None
#*
#*! #############################################################################################################

$XML_CLOSE
    # Flush: Close open XML tags.
    While XMLTAGSTACKPOINTER > 0
        Gosub XML_POP_TAG
    Wend

    # Close XML file.
    Openo Using [XOUT]
Return



#** #############################################################################################################
#*
#* Sub chunk:  XML_PUSH_TAG
#*
#* Purpose:    XML_PUSH_TAG is part of the XML tag stack. It takes the name of an XML tag
#*             pushes it on the stack and writes the opening of an XML tag into the output
#*             file.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLTAG             local char(255)   Name of the XML tag
#* @param XMLATTR            local char(255)   Optional attribute string.
#*
#*! #############################################################################################################

$XML_PUSH_TAG
    XMLTAGSTACK(XMLTAGSTACKPOINTER) = XMLTAG
    XMLTAGSTACKPOINTER += 1
    If XMLATTR = ""
        Wrseq "<" + XMLTAG + ">" Using [XOUT]
    Else
        Wrseq "<" + XMLTAG - XMLATTR + ">" Using [XOUT]
        Raz XMLATTR
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  XML_POP_TAG
#*
#* Purpose:    XML_POP_TAG is part of the XML tag stack. It pops the name of an XML tag
#*             and writes the ending of an XML tag to the output file.
#*
#*! #############################################################################################################

$XML_POP_TAG
    XMLTAGSTACKPOINTER -= 1
    XMLTAG= XMLTAGSTACK(XMLTAGSTACKPOINTER)
    Wrseq "</" + XMLTAG + ">" Using [XOUT]
Return



#** #############################################################################################################
#*
#* Sub chunk:  XML_CREATE_TAG
#*
#* Purpose:    Create an XML tag with text content.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param XMLTAG             local char(255)   Name of the XML tag
#* @param XMLATTR            local char(255)   Optional attribute string.
#* @param XMLCONTENT         local char(255)   Text content of the XML tag
#*
#*! #############################################################################################################

$XML_CREATE_TAG
    If XMLATTR = ""
        Wrseq "<" + XMLTAG + ">" + func XML_ENCODE_ENTITIES( XMLCONTENT ) + "</" + XMLTAG + ">" Using [XOUT]
    Else
        Wrseq "<" + XMLTAG - XMLATTR + ">" + func XML_ENCODE_ENTITIES( XMLCONTENT ) + "</" + XMLTAG + ">" Using [XOUT]
        Raz XMLATTR
    Endif
Return



#** #############################################################################################################
#*
#* Function:   XML_ENCODE_ENTITIES
#*
#* Purpose:    Replace forbidden characters by XML entities.
#*
#*
#* Parameters:
#*
#* @param XMLCONTENT         Value Char  Contains the text to convert.
#*
#*! #############################################################################################################

Funprog XML_ENCODE_ENTITIES( XMLCONTENT )
Value Char XMLCONTENT()

    Local Integer I, K
    Local Char CA(1)(1..4)
    Local Char CX(6)(1..4)

    # Replacement table
    CA(1) = "<" : CX(1) = "&lt;"
    CA(2) = ">" : CX(2) = "&gt;"
    CA(3) = '"' : CX(3) = "&quot;"
    CA(4) = '&' : CX(4) = "&amp;"

    # Replacement
    For I = 1 To dim(CA)
     K = instr( 1, XMLCONTENT, CA(I) )
     While K
        XMLCONTENT = left$( XMLCONTENT, K-1) + CX(I) + right$( XMLCONTENT, K + len( CA(I) ) )
        K = instr( K + len( CX(I) ), XMLCONTENT, CA(I) )
     Wend
    Next I
End XMLCONTENT

