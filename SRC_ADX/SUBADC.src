#<AdxTL>@(#)12.0.0.0 $Revision$
Local Datetime DT
DT = datetime$
Infbox func DT_TS(DT)-num$(timestamp$)
End

Raz GPILOBJ , GNBMASKOUV
Call OBJET("ADC",GBIDC1,GBIDC3) From GOBJET
End

#---------------------------------------------------------------------------#
# Traitements générés dans les transactions
# Liste des préfixes des traitements commençant par W réservés par produit
# Exhaustive pour le superviseur - Non garantie pour les autres produits
#---------------------------------------------------------------------------#

#---------------------------------------------------------------------------#
#           <<<<<<<<<        Attention:       >>>>>>>>>>
# Tous les préfixes sont listé maintenant dans traitement APREFIXTRT
# - Pour tous les nouveaux préfixes :
#      Ils doivent être définit dans un Funprog GET_PREFIX_xxx dans APREFIXTRT
# - Pour les anciennes préfixes     :
#      Ils doivent prendre la même logique au fur et à mesure
#---------------------------------------------------------------------------#


$ACTION
Case ACTION
 When "SETBOUT"     : Gosub SETBOUT
 When "STATUT"      : Gosub STATUT
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "VERF_ANU"    : Gosub VERF_ANU
 When "ANNULE"      : Gosub ANNULE
 When "AVANT_CHOI"  : Gosub AVANT_CHOI
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FERME"       : Gosub FERME
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "CLE_GAUCHE"  : Gosub CLE_GAUCHE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "TRT_DIV"     : Gosub TRT_DIV
 When "AP_ANNULE"  : Gosub AP_ANNULE

Endcase
Return

#------------------------#
$OUVRE
Local Char    FICHIER(250) , TEXFIC(150) , IDUSR(50)
Local Char    EXT(3)
Local Char    APPSUP(GLONADS) , APPCUR(GLONADS)
Local Integer STAT , ER
Onerrgo ERFIC
If clalev([F:ADX])=0 : Local File ADICADX [ADX] : Endif
Onerrgo
If ER
 GMESSAGE = "ADICADX : "+mess(76,139,1) : # Vue inexistante
 OK = 0 : Return
Endif
Gosub CHARGE_USR
Return

#------------------------#
$OUVRE_BOITE
Global Char   BOXADX(10)
BOXADX = "GAU_CHE"+num$(find("ADX",OBJLIS(1..dim(OBJLIS)-1)))
Return

#------------------------#
$FERME
If dim(BOXADX)>0 : Kill BOXADX : Endif
Return

#------------------------#
$APRES_CHOI
Case REPONSE
 When GSTAANU
  CHAINE = filpath("TRT",[M]CODTRT,"src",nomap)
  If filinfo(CHAINE,0)<0
   Call EXISTE_ADX("",nomap,[M]CODTRT,K) From ORDSYS
   If !K
    CHAINE = ""
   Else
    CHAINE = filpath("TRT",[M]CODTRT,"adx",nomap)
   Endif
  Endif
  If CHAINE<>""
   # Etes-vous sûr de vouloir supprimer le fichier # ?
   Call AVERTIR("|"+func AFNC.MES(mess(216,115,1),CHAINE),K) From GESECRAN
   If K<>2 : REPONSE = 0 : Return : Endif
  Endif
 When GSTADOC1 : REPONSE = 0 : Call PARAGRAPHES(func CODDOC,[M]CODTRT,GBIDC1) From GOBJACT
 When GSTADOC2 : REPONSE = 0
 When GSTADOC3 : REPONSE = 0
 When GSTALFT,GSTALF2,GSTALF3,GSTALF4
  Case currbox
   When BOXADX
    [F:ADC] = [F:ADX]
    If [F:ADX]DOSSIER<>nomap
     Onerrgo ERFIC
     Local File =[F:ADX]DOSSIER+".ADICTRT" [ADCX]
     Read [ADCX]ADC0=[F:ADX]CODTRT
     If !fstat
      Raz [M:ADC1]
      [M:ADC1] = [F:ADCX]
      Call INFOS([F:ADX]CODTRT+"."+[F:ADX]DOSSIER,NBUSER,USER,NOM,ID,[M:ADC1]INFO)
      Affzo
      Gosub VIRE_SRCINT
      Gosub GRISE_SRCINT
      Gosub VIRE_INTERN
      Call LECTURE_DOC(func CODDOC,[M]CODTRT,[M]TEXTE,K) From SUBADO
      REPONSE = 0
      Grizo [ADC1]
     Endif
     Close Local File [ADCX]
     Onerrgo
    Endif
  Endcase
Endcase
Return

#-----------------------------------#
$AVANT_CHOI
If !CLECUR
 Gosub VIRE_SRCINT
 Gosub GRISE_SRCINT
 Gosub VIRE_INTERN
Endif
Return

#----------------------------------------------------------------------#
$VERF_ANU
OK = 1
Call VERF_ANU("ADC","ADICTRT",[L]CODE,GBIDC3) From ADELETE
If GBIDC3<>""
 # Suppression impossible
 Call ERREUR([L]CODE-":"-mess(1,115,1)+"\"+GBIDC3) From GESECRAN
 OK = 0 : Return
Endif
If filinfo(filpath("TRT",[L]CODE,"LCKsrc",nomap),0)>0
 # Suppression impossible\Traitement $1$ existant dans le dossier $2$\Traitement verrouillé
 Call ERREUR(mess(1,115,1)+"\"+func AFNC.MES2(mess(217,139,1),[L]CODE,nomap)+"\"+mess(13,139,1)) From GESECRAN
 OK = 0 : Return
Endif
Return

#------------------------#
$CLE_GAUCHE
Case currbox
 When BOXADX : CLELISTE = "[F:ADX]CODTRT;[F:ADX]DOSSIER"
Endcase
Return

#------------------------#
$SETBOUT
If CLECUR=0 or REP="M" or !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
If APPCUR<>"" & APPCUR<>nomap
 Call VIREBOUT(CHAINE,"MA2") From GOBJET
Endif
If GSOPHIA
 CHMEN += "45" : # Epuration/Vérification archive
Endif
Return

#------------------------#
$STATUT
Case BOUT
 When "4" : Call EPURE
 When "5" : Call LISTRT
Endcase
Return

#-----------------------------#
$CHARGE_USR
Local Char    LIGNE(50)(1..50)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer NBUSER , ER , SAVIUM
Local Char    USER(10)(1..1000) , NOM(30)(1..1000)
Local Decimal ID(1..1000)
If GOS(1)="unix"
 ER = 0
 Onerrgo RIEN
 Openi "/etc/passwd"
 Onerrgo
 If !ER
  SAVIFS = adxifs
  SAVIRS = adxirs
  SAVIUM = adxium
  adxifs = ":"
  adxirs = chr$(10)
  adxium = GASCII
  Rdseq LIGNE
  While fstat=0
   NBUSER += 1
   USER(NBUSER) = LIGNE(1)
   ID(NBUSER)   = val(LIGNE(3))
   NOM(NBUSER)  = LIGNE(5)
   Rdseq LIGNE
  Wend
  Openi
  adxifs = SAVIFS
  adxirs = SAVIRS
  adxium = SAVIUM
 Endif
Endif
Return

$RIEN
ER = 1
Resume

#------------------------#
$RAZCRE
Actzo [ADC1]

$RAZDUP
Effzo [M:ADC1]INFO
APPCUR = nomap
Gosub VIRE_SRCINT
Gosub GRISE_SRCINT
Gosub VIRE_INTERN
Return

#------------------------#
$LIENS
Call INFOS([M:ADC1]CODTRT,NBUSER,USER,NOM,ID,[M:ADC1]INFO)
Actzo [ADC1]
Gosub VIRE_SRCINT
Gosub GRISE_SRCINT
Gosub VIRE_INTERN
Call LECTURE_DOC(func CODDOC,[M]CODTRT,[M]TEXTE,K) From SUBADO
APPCUR = nomap
Return

#------------------------#
$GRISE_SRCINT
If GSOPHIA
 If [M]SRC=2
  [M]SRCINT = 1
  Affzo SRCINT
  Diszo SRCINT
 Else
  Actzo SRCINT
 Endif
Endif
Return

#------------------------#
$VIRE_SRCINT
If GSOPHIA
 Chgtzn [M]SRCINT With ctrans("Livraison du source nécessite autorisation","","")
 Chgfmt [M]SRCINT With "LA1:10X"
Else
 Chgtzn [M]SRCINT With ""
 Chgfmt [M]SRCINT With "-LA1:10X"
Endif
Return

#------------------------#
$VIRE_INTERN
If GSOPHIA
 Chgtzn [M]INTERN With ctrans("Internationalisé","","")
 Chgfmt [M]INTERN With "LA1:10X"
Else
 Chgtzn [M]INTERN With ""
 Chgfmt [M]INTERN With "-LA1:10X"
Endif
Return

#------------------------#

$CREATION
# JPGA 27-27-2010 BUG-66277 : ECRIRE_DOC 2 parametres ajoutes : Module et Code activité
$MODIF
Call ECRIRE_DOC(func CODDOC,[M]CODTRT,[M]TEXTE,[M]DES,[M]MODULE,[M]CODACT) From SUBADO
Return

#------------------------#
$APRES_CRE
Call INFOS([M:ADC1]CODTRT,NBUSER,USER,NOM,ID,[M:ADC1]INFO)
Affzo [ADC1]INFO

# CCL : For SCM : creation of meta hors transaction
If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
[L]DOC_CLE1=func CODDOC :  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=[M]CODTRT
Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "C") From AGENLIBA
Return

#------------------------#
$ANNULE
If filinfo(filpath("TRT",[L]CODE,"src",nomap),0)>0
 Call EFFACE(filpath("TRT",[L]CODE,"src",nomap),K) From ORDSYS
Endif
If filinfo(filpath("TRT",[L]CODE,"xrc",nomap),0)>0
 Call EFFACE(filpath("TRT",[L]CODE,"xrc",nomap),K) From ORDSYS
Endif
Call EFFACE_ADX("",nomap,[L]CODE,K) From ORDSYS
If filinfo(filpath("TRT",[L]CODE,"adx",nomap),0)>0
 Call EFFACE(filpath("TRT",[L]CODE,"adx",nomap),K) From ORDSYS
Endif
Call EFFACE_DOC(func CODDOC,[L]CODE) From SUBADO
Return

$AP_ANNULE
# CCL : For SCM : creation of meta hors transaction
If dim([L]DOC_CLE1)<0 | dim([L]DOC_CLE2)<0 : Local Char DOC_CLE1, DOC_CLE2(50)(0..1) : Endif
[L]DOC_CLE1=func CODDOC  :  [L]DOC_CLE2(0)=GLANGUE  :  [L]DOC_CLE2(1)=[L]CODE
Call TRACE_COR("ADO", [L]DOC_CLE1, [L]DOC_CLE2, "A") From AGENLIBA
Return

#-------------------------------------------------------------------------#
Subprog INFOS(FICHIER,NBUSER,USER,NOM,ID,INFO)
Value    Char FICHIER
Value Integer NBUSER
Value Char    USER()(1..)
Value Char    NOM()(1..)
Value Decimal ID(1..)
Variable Char INFO()(0..)

Local Decimal TAILLE , PROPRIO
Local Date    DATMOD
Local Char    HREMOD(10)
Local Integer L , I , OK
Local Char    TRAIT(GLONADC) , APPLI(GLONADS)

I = instr(1,FICHIER,".")
If I
 TRAIT = left$(FICHIER,I-1)
 APPLI = right$(FICHIER,I+1)
Else
 TRAIT = FICHIER
Endif

Raz [L]INFO
L = 0
Call INFOFIC("TRT",FICHIER,"src",PROPRIO,TAILLE,DATMOD,HREMOD,OK)
If OK<0
 [L]INFO(L) = mess(55,100,1)-"src"-mess(87,100,1) : # Fichier...inexistant
Else
 [L]INFO(L) = mess(55,100,1)-"src"-mess(172,126,1)-nomap(OK) : # Fichier...présent dans le dossier
 L += 1
 [L]INFO(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER
  [L]INFO(L) += ","-mess(134,133,1)-IDUSR : # Propriétaire
 Endif
 [L]INFO(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifié le
Endif
L += 2
Call INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK)
If OK<0
 [L]INFO(L) = mess(158,139,1) : # Traitement inexistant dans l'archive
Else
 [L]INFO(L) = mess(159,139,1)-nomap(OK) : # Traitement existant dans l'archive du dossier
Endif
If TAILLE>=0
 L += 1
 [L]INFO(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER
  [L]INFO(L) += ","-mess(134,133,1)-IDUSR : # Propriétaire
 Endif
 [L]INFO(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifié le
 If !NBUSER & clalev([F:ADC])>0 : # mb 19.12.2013 La lecture du /etc/passwd n'est plus autorisée
  Read [ADC]ADC0=FICHIER
  [L]INFO(L) -= mess(240,123,1)-[F:ADC]UPDUSR : # par
 Endif
Endif
L += 2
Call VERSACH(nomap,[L]INFO(L))
[L]INFO(L) = mess(199,115,1)-"->"-[L]INFO(L)
End

#-------------------#
Funprog CODDOC
End "TRT"

#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ADICTRT   [ADC1]
 Local File ATEXTRA   [AXX1]
 Local File ADOCUMENT [ADO1]
 Local File ADOCCLB   [ADH1]
Else
 Local File =[M]DOSORG+".ADICTRT"   [ADC1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
 Local File =[M]DOSORG+".ADOCUMENT" [ADO1]
 Local File =[M]DOSORG+".ADOCCLB"   [ADH1]
Endif
If [M]DOSDES=nomap
 Local File ADICTRT   [ADC2]
 Local File ATEXTRA   [AXX2]
 Local File ADOCUMENT [ADO2]
 Local File ADOCCLB   [ADH2]
Else
 Local File =[M]DOSDES+".ADICTRT"   [ADC2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
 Local File =[M]DOSDES+".ADOCUMENT" [ADO2]
 Local File =[M]DOSDES+".ADOCCLB"   [ADH2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ADC1], [ADC2], [AXX1], [AXX2]
Close Local File [ADO1], [ADH1], [ADO2], [ADH2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [ADC2]
 Delete [ADC2] Where CODTRT=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ADICTRT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ADC2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ADC1]ADC0 Where CODTRT=TABLE
  [F:ADC2] = [F:ADC1]
  Call FLDUPD("ADC2") From OBJDIV
  Write [ADC2]
  If fstat
   GOK=0 : Call FSTA("ADC2") From GLOCK : Break
  Endif
  Call COPIE_DOC(func CODDOC,TABLE,[M]DOSORG,[M]DOSDES) From SUBADO
  If GOK<>1 : Break : Endif
 Next ADC1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

$ERFIC
ER = errn
Resume

#--------------------------------------------------------------#
# Mise à jour dictionnaire
#--------------------------------------------------------------#

Subprog MAJ(TRT,COM,MODULE,ACTIV)
Value Char TRT , COM
Value Integer MODULE
Value Char ACTIV
Local Integer OK , ER
If TRT="" or left$(TRT,1)="W" : End : Endif
If !adxlog
 Gosub TR_MAJ
Else
 Gosub MAJADC
Endif
End

#--------------#
$TR_MAJ
GOK=1
Trbegin [ADC]
 Gosub MAJADC
 If GOK=-1 : Goto ROLL_TR_MAJ
 Elsif GOK=0 : Goto AB_TR_MAJ
 Endif
Commit
#{SAM 122394 : The entity has to exist in the database before calling for an extracion!
If left$(TRT,4)<>"ADXT" and len(UPD_FLAG)
 Call TRACE_COR("ADC",TRT,"",UPD_FLAG) From GOBJET
Endif
#SAM 122394}
Return

$AB_TR_MAJ
Rollback
Return

$ROLL_TR_MAJ
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_MAJ : Endif

#--------------#
$MAJADC
 Local Char UPD_FLAG(1):UPD_FLAG=''
Readlock [ADC]ADC0=TRT
If fstat=1
 GOK=-1 : Call FSTA("ADC") From GLOCK
Elsif fstat
 Raz [F:ADC]
 [F:ADC]CODTRT = TRT
 If COM<>""
  [F:ADC]DES = COM
 Endif
 If ACTIV<>"" : [F:ADC]CODACT = ACTIV  : Endif
 Call FLDCRE("ADC") From OBJDIV
 If MODULE<>0
  [F:ADC]MODULE = MODULE
 Elsif find(left$(TRT,3),"SUB","SPE","SPV")
  Local File AOBJET [AOB]
  Read [AOB]ABREV=right$(TRT,4)
  If !fstat
   [F:ADC]MODULE = [F:AOB]MODULE
   Call TEXTE([F:AOB]LIBEL,[F:ADC]DES) From OBJDIV
  Endif
  Close Local File [AOB]
 Elsif left$(TRT,3)="CNS" & right$(TRT,len(TRT)-2)="STD"
  Local File ACONSULT [ACN]
  Read [ACN]ACN0=seg$(TRT,4,len(TRT)-3)
  If !fstat
   [F:ADC]MODULE = [F:ACN]MODULE
   Call TEXTE([F:ACN]LIBEL,[F:ADC]DES) From OBJDIV
  Endif
  Close Local File [ACN]
 Elsif left$(TRT,3)="STR"
  Local File ASTR [ASE]
  Read [ASE]ASE0=right$(TRT,4)
  If !fstat
   [F:ADC]MODULE = [F:ASE]MODULE
   Call TEXTE([F:ASE]INTSTR,[F:ADC]DES) From OBJDIV
  Endif
  Close Local File [ASE]
 Endif
 If [F:ADC]MODULE=0
  Onerrgo ERFIC
  Local Char AGRPDEV(250),AGRPDEVMOD(250)
  AGRPDEV = func AFNC.PARAMUTIL("AGRPDEV","","")
  AGRPDEVMOD = func AFNC.PARNUMADI("",98,AGRPDEV,1)
  [F:ADC]MODULE = val(AGRPDEVMOD)
  Onerrgo
  If [F:ADC]MODULE=0
   If GPRODUIT=-1
    [F:ADC]MODULE = 1
   Else
    [F:ADC]MODULE = 2
   Endif
  Endif
 Endif
 OK = (left$(TRT,3)="CNS" & right$(TRT,len(TRT)-2)="STD")
 OK += (find(left$(TRT,3),"IMP","FUN","SUB"))
 If OK
  [F:ADC]SRC = 2
  [F:ADC]SRCINT = 1
 Else
  [F:ADC]SRC = 1
  If [F:ADC]MODULE=1 or GPRODUIT=-1
   [F:ADC]SRCINT = 2
  Else
   [F:ADC]SRCINT = 1
  Endif
 Endif
 Write [ADC]
 UPD_FLAG='C'
Else
 If [F:ADC]DES="" & COM<>""
  [F:ADC]DES = COM
 Endif
 If MODULE<>0 : [F:ADC]MODULE = MODULE : Endif
 #103140
 #If ACTIV<>"" : [F:ADC]CODACT = ACTIV  : Endif
 Call FLDUPD("ADC") From OBJDIV
 Rewrite [ADC]
 UPD_FLAG='M'
Endif
If fstat
 GOK=0 : Call FSTA("ADC") From GLOCK : Return
Endif
Return

#-------------------------------------#
Subprog DEL(TRT)
Value Char TRT
If TRT="" or left$(TRT,1)="W" : End : Endif
If !adxlog
 Gosub TR_DEL
Else
 Gosub DELADC
Endif
End

#--------------#
$TR_DEL
GOK=1
Trbegin [ADC]
 Gosub DELADC
 If GOK=0 : Goto AB_TR_DEL : Endif
Commit
Return

$AB_TR_DEL
Rollback
Return

#--------------#
$DELADC
Read [ADC]ADC0=TRT
If !fstat
 Call TRACE_COR("ADC",TRT,"","A") From GOBJET
 Delete [ADC] =
 If fstat
  GOK=0 : Call FSTA("ADC") From GLOCK
 Else
  Call EFFACE_DOC(func CODDOC,TRT) From SUBADO
 Endif
Endif
Return


#------------------------------------------------------------------------------------#
# Mise à jour du dico appelée depuis la validation écran/objet/consult/structures
#------------------------------------------------------------------------------------#

Subprog MAJDICTRT(TRT,DOS,COM,MODU,ACT)
Value Char    TRT , DOS , COM
Value Integer MODU
Value Char    ACT
Local Integer ER,OK

OK =  ([L]TRT<>"")
OK *=  ([L]TRT<"W")
OK *= (left$([L]TRT,3)<>"SPE" & left$([L]TRT,3)<>"SPV")
OK *= (!find(right$([L]TRT,len([L]TRT)-2),"STD","SPE","SPV") or !find(left$([L]TRT,4),"CNSX","CNSY","CNSZ"))
OK *= (left$([L]TRT,3)<>"CNS" or right$([L]TRT,len([L]TRT)-2)<>"SPE")
OK *= (left$([L]TRT,3)<>"CNS" or right$([L]TRT,len([L]TRT)-2)<>"SPV")
OK *= (!find(left$([L]TRT,4),"SUBX","SUBY","SUBZ","IMPX","IMPY","IMPZ","FUNX","FUNY","FUNZ"))
If !OK : End : Endif

#If TRT="" or left$(TRT,1)="W" : End : Endif
Onerrgo ERFIC
If DOS="" or DOS=nomap
 Local File ADICTRT [ADC] , ATEXTE [ATX]
Else
 Local File =DOS+".ADICTRT" [ADC] , =DOS+".ATEXTE" [ATX]
Endif
If GSOPHIA & filinfo(filpath("FIL","XXCORT","fde",DOS),0)>0
 If clalev([F:XCT])=0  : Local File =DOS+".XXCORT"    [XCT] : Endif
 If clalev([F:XCH])=0  : Local File =DOS+".XXCORH"    [XCH] : Endif
 If filinfo(filpath("FIL","AOBJGRPDEV","fde",DOS),0)>0
  If clalev([F:AGD])=0 : Local File =DOS+".AOBJGRPDEV"    [AGD] : Endif
 Endif
Endif
Onerrgo
If ER : End : Endif
Call MAJ(TRT,COM,MODU,ACT)
Close Local File [ADC] , [ATX]
End

#-------------------------------------------------------------------------------------#
# Mise à jour du dico appelée depuis les éditeurs des clients (C/S, Eclipse, Web)
#-------------------------------------------------------------------------------------#

Funprog DICTRT(TRT,EXT,APP,MAC,COM,OPE,MES)
Value Char TRT , EXT , APP , MAC , COM
Value Integer OPE : # 1 Maj, 2 suppr
Variable Char MES
Local Integer STA , ER , K
Local Char    DOSSIER(GLONADD) , SYMBOLE(80)
If TRT=""
 End 0
Elsif toupper(EXT)="STC" : # Non géré dans le dico trt mais pas de message d'erreur
 STA = 1 : MES = ""
 End STA
Elsif toupper(EXT)<>"SRC"
 STA = 5 : MES = EXT-":"-mess(26,143,1) : # Extension non gérée
 End STA
Endif
Onerrgo ERFIC
DOSSIER = APP
If MAC<>""
 K = instr(1,MAC,":")
 If K
  SER = left$(MAC,K-1)
  TCP = right$(MAC,K+1)
 Else
  SER = MAC
  TCP = ""
 Endif
 If adxmac(0)="" & tolower(SER)=adxmac(-1) & (TCP="" or TCP=num$(adxtcp))
  MAC = ""
 Endif
 If MAC<>""
  DOSSIER = MAC+"@"+DOSSIER
 Endif
Endif
If DOSSIER<>"" & DOSSIER<>nomap
 Local File =DOSSIER+".ADICTRT"   [ADC]
 Local File =DOSSIER+".ADOCUMENT" [ADO]
 Local File =DOSSIER+".ADOCCLB"   [ADH]
 Local File =DOSSIER+".ATEXTE"    [ATX]
Else
 Local File ADICTRT [ADC] , ADOCUMENT [ADO] , ADOCCLB [ADH] , ATEXTE [ATX]
Endif
Onerrgo
If ER
 STA = 4 : MES = mess(196,133,1)-string$(DOSSIER<>"",DOSSIER+".")+"ADICTRT" : # Erreur à l'ouverture de la table
 End STA
Endif
If [L]OPE=2
 Call DEL(TRT)
Else
 Call MAJ(TRT,COM,0,"")
Endif
Case GOK
 When 1  : STA = 1 : MES = ""
 When -1 : STA = 2 : MES = mess(60,100,1) : # Enregistrement verrouillé
 When 0  : STA = 3 : MES = mess(14,100,1) : # Transaction interrompue
Endcase
Close Local File [ADC] , [ADO] , [ADH] , [ATX]
End STA

#--------------------------------------------------------------#
# Epuration du dictionnaire
#--------------------------------------------------------------#

Subprog EPURE
Local File ADICTRT [ADC]
Local File ADOCUMENT [ADO] , ADOCCLB [ADH]
Local Integer OK
Call OUVRE_TRACE("") From LECFIC
Trbegin [ADC]
 For [ADC]ADC0
  If filinfo(filpath("TRT",[F:ADC]CODTRT,"adx"),0)<0
   Call ECR_TRACE([F:ADC]CODTRT,0) From GESECRAN
   Call EFFACE_DOC(func CODDOC,[F:ADC]CODTRT) From SUBADO
   Delete [ADC] Curr
  Endif
 Next ADC
Commit
Close Local File
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog LISTRT
Local Char ORDSYS(250) , CHAINE(250)
Local Integer OKTRT
# 2018-06-12 JPGA X3-95488 : -v option is no more necessary since V12 because it activates DEBUG mode creating x3_diary* trace files
ORDSYS = adxmac(0)+'@archive -d '+nomap-' -t -l "*"'
Local File (TRT(30)) From System ORDSYS As [TRT_]
# Vérification archive traitement
Call OUVRE_TRACE(mess(239,139,1)) From LECFIC
For [TRT_]
 If filinfo(filpath("TRT",[F:TRT_]TRT,"adx"),0)<0
  # Traitement (adx) inexistant
  Call ECR_TRACE([F:TRT_]TRT-":"-mess(246,139,1),1) From GESECRAN
 Endif
 If filinfo(filpath("TRT",[F:TRT_]TRT,"src"),0)<0
  Read [ADC]ADC0 = [F:TRT_]TRT
  If !fstat & [F:ADC]SRC=2
   # Traitement (src) inexistant
   Call ECR_TRACE([F:TRT_]TRT-":"-mess(245,139,1),1) From GESECRAN
  Elsif fstat & GSOPHIA & left$(TRT,1)<>"W"
   # Traitement inexistant dans le dictionnaire
   Call ECR_TRACE([F:TRT_]TRT-":"-mess(244,139,1),1) From GESECRAN
  Endif
 Endif
Next TRT_
Close Local File [TRT_]
ORDSYS = adxmac(0)+'@lsadx -a '+nomap-' TRT adx'
Local File (TRT(30)) From System ORDSYS As [TRT_]
For [TRT_]
 Call EXISTE_ADX("","",TRT,OKTRT) From ORDSYS
 If !OKTRT
  # Traitement inexistant dans l'archive
  Call ECR_TRACE(TRT-":"-mess(158,139,1),1) From GESECRAN
 Endif
Next TRT_
Close Local File [TRT_]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#--------------------------------------------------------------#
# Effacement d'un traitement
#--------------------------------------------------------------#

Subprog DELTRT(TRAIT,DOSSIER)
Value Char TRAIT
Value Char DOSSIER
Local Integer STAT , OKTRT , ER
Local Char    FICHIER(GDIMFIC) , APPLI(GLONADS) , MACHINE(GLONAMC)
ER = 0
Onerrgo ERFIC
If DOSSIER<>"" & DOSSIER<>nomap
 Local File =DOSSIER+".ADICTRT"   [ADC]
 Local File =DOSSIER+".ADOCUMENT" [ADO]
 Local File =DOSSIER+".ADOCCLB"   [ADH]
Else
 Local File ADICTRT [ADC] , ADOCUMENT [ADO] , ADOCCLB [ADH]
Endif
Look [ADC]ADC0 = TRAIT
If !fstat & !ER
 If !adxlog
  Call DEBTRANS From GLOCK
  Gosub TRDEL_TRT
 Else
  Gosub DEL_TRT
 Endif
 If GOK<1 : End : Endif
Endif
Onerrgo
FICHIER = filpath("TRT",TRAIT,"src",DOSSIER)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
FICHIER = filpath("TRT",TRAIT,"xrc",DOSSIER)
If filinfo(FICHIER,0)>=0
 Call EFFACE(FICHIER,STAT) From ORDSYS
Endif
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Call EXISTE_ADX(MACHINE,APPLI,TRAIT,OKTRT) From ORDSYS
If OKTRT>0
 Call EFFACE_ADX(MACHINE,APPLI,TRAIT,STAT) From ORDSYS
Endif
End

$TRDEL_TRT
Trbegin [ADC]
 Gosub DEL_TRT
 If GOK<1 : Goto AB_TRDEL_TRT : Endif
Commit
Return

$AB_TRDEL_TRT
Rollback
Return

$DEL_TRT
Readlock [ADC]ADC0 = TRAIT
If fstat=1
 GOK=-1 : GLOCK="$ADICTRT"-TRAIT : Return
Endif
Call EFFACE_DOC(func CODDOC,TRAIT) From SUBADO
Delete [ADC]ADC0 = TRAIT
If fstat=1
 GOK = -1 : GLOCK = "$ADICTRT"-TRAIT
Endif
Return

#-------------------------------------------------------------------------#
Subprog INFOFIC(REP,FICHIER,EXT,PROPRIO,TAILLE,DATMOD,HREMOD,OK)
Value    Char    REP
Value    Char    FICHIER
Value    Char    EXT
Variable Decimal TAILLE
Variable Decimal PROPRIO
Variable Date    DATMOD
Variable Char    HREMOD
Variable Integer OK
Local Integer A , T , J , H , M , S
Local Char    CHEMIN(250)
Local Char    TRAIT(GLONADC) , APPLI(GLONADS)
I = instr(1,FICHIER,".")
If I
 TRAIT = left$(FICHIER,I-1)
 APPLI = right$(FICHIER,I+1)
Else
 TRAIT = FICHIER
Endif
OK = -1
For A=0 To 7
 If nomap(A)<>"" & (APPLI="" or nomap(A)=APPLI)
  CHEMIN = filpath(REP,TRAIT,EXT,nomap(A))
  If filinfo(CHEMIN,0)>=0
   OK = A : Break
  Endif
 Endif
Next A
If OK<0 : End : Endif
T = filinfo(CHEMIN,9)
J = int(T/(3600*24))
H = int(mod(T,3600*24)/3600)
M = int(mod(T,3600)/60)
S = mod(T,60)
DATMOD  = [01/01/1970]+J
HREMOD  = format$("N0:2#",H)+":"+format$("N0:2#",M)+":"+format$("N0:2#",S)
PROPRIO = filinfo(CHEMIN,5)
TAILLE  = filinfo(CHEMIN,7)
End

$USER
K = find(PROPRIO,ID(1..NBUSER))
If K
 IDUSR = NOM(K)-"("+USER(K)+")"
Else
 IDUSR = num$(PROPRIO)
Endif
Return

#-----------------------------------------------------------------------#
# Extraction d'un time d'un champ au format datetime
#-----------------------------------------------------------------------#

Funprog TIM_DATETIME(DT)
Value Datetime DT
Local Char TIM
Local Integer I
Local Char    CHAINE(20) , H(2) , M(2) , S(2)
CHAINE = num$(DT)
I = instr(1,CHAINE,":")
If I
 H = seg$(CHAINE,I-2,I-1)
 I = instr(I+1,CHAINE,":")
 If I
  M = seg$(CHAINE,I-2,I-1)
  S = seg$(CHAINE,I+1,I+2)
 Endif
Endif
TIM = H+":"+M+":"+S
End TIM

#---------------------------------------------------------#
# Extraction d'une date d'un champ au format datetime
#---------------------------------------------------------#

Funprog DAT_DATETIME(DT)
Value Datetime DT
Local Date DAT
Local Integer Y , M , D
Local Char    CHAINE(20)
CHAINE = num$(DT)
Y = val(left$(CHAINE,4))
M = val(mid$(CHAINE,6,2))
D = val(mid$(CHAINE,9,2))
DAT = gdat$(D,M,Y)
End DAT

#-------------------------------------------------------------------#
# Renvoi l'heure d'un datetime en nombre de secondes depuis Minuit
#-------------------------------------------------------------------#

Funprog TIMESEC_FROM_DT(DT)
Value Datetime DT
Local Integer TIM
If num$(DT)=num$(gdatetime$(""))
 TIM = 0
Else
 TIM = 3600*val(seg$(num$(DT),12,13)) + 60*val(seg$(num$(DT),15,16)) + val(seg$(num$(DT),18,19))
Endif
End TIM

#------------------------------------------------#
# Conversion date$ et time -> timestamp
#------------------------------------------------#

Funprog CNVSTP(DAT,TIM)
Value Date    DAT
Value Integer TIM
Local Integer J
Local Decimal T
If DAT<[01/01/1970]
 End ""
Endif
J = DAT-[01/01/1970]
T = J*24*3600*1000
If TIM>0 & TIM<24*3600
 T += TIM*1000
Endif
End num$(T)

#------------------------------------------------#
# Conversion datetime -> timestamp
#------------------------------------------------#

Funprog DT_TS(DT)
Value Datetime DT
Local Date DAT
Local Integer TIM
Local Integer Y , M , D , J
Local Decimal T
Local Char    CHAINE(20)
CHAINE = num$(DT)
Y = val(left$(CHAINE,4))
M = val(mid$(CHAINE,6,2))
D = val(mid$(CHAINE,9,2))
DAT = gdat$(D,M,Y)
If num$(DT)=num$(gdatetime$(""))
 TIM = 0
Else
 TIM = 3600*val(seg$(num$(DT),12,13)) + 60*val(seg$(num$(DT),15,16)) + val(seg$(num$(DT),18,19))
Endif
If DAT<[01/01/1970]
 End ""
Endif
J = DAT-[01/01/1970]
T = J*24*3600*1000
If TIM>0 & TIM<24*3600
 T += TIM*1000
Endif
End num$(T)

#-----------------------------------------------------------------------#
Funprog CNVDAT(STAMP)
Value Char STAMP
Local Decimal T
Local Integer J
T = val(STAMP)
J = int(T/(3600*1000*24))
End [01/01/1970]+J

#-----------------------------------------------------------------------#
Funprog CNVTIM(TIM)
Value Integer TIM
Local Integer J , H , M , S
Local Char    DAT(30) , HEU(30)
J = int(TIM/(3600*24))
H = int(mod(TIM,3600*24)/3600)
M = int(mod(TIM,3600)/60)
S = mod(TIM,60)
DAT = format$(GFMDAT4,[01/01/1970]+J)
HEU  = format$("N0:2#",H)+":"+format$("N0:2#",M)+":"+format$("N0:2#",S)
End DAT-HEU-"GMT"

#-----------------------------------------------------------------------#
Funprog CNVSYR(STAMP)
Value Char STAMP
Local Integer SYR : # Format Syracuse
Goto T_CNVMIL

#-----------------------------------------------------------------------#
Funprog CNVMIL4(STAMP)
Value Char STAMP
Local Integer LAN : # Format pays optimisé (non affichage minutes si 0)
Goto T_CNVMIL

#-----------------------------------------------------------------------#
Funprog CNVMIL(STAMP)
Value Char STAMP

$T_CNVMIL
Local Decimal T , L
Local Char    DAT(10) , HEU(8) , MIL(3)
Local Integer J , H , M , S
T = val(STAMP)
J = int(T/(3600*1000*24))
H = int(mod(T,3600*1000*24)/(3600*1000))
M = int(mod(T,3600*1000)/(60*1000))
S = int(mod(T,60*1000)/1000)
L = mod(T,1000)
If dim([L]LAN)>0
 DAT = format$(GFMDAT4,[01/01/1970]+J)
Else
 DAT = format$("D:YYYY[-]MM[-]DD",[01/01/1970]+J)
Endif
HEU = format$("N0:2#",H)+":"+format$("N0:2#",M)+":"+format$("N0:2#",S)
MIL = format$("N0:3#",L)
If dim([L]LAN)>0 : # Optimisé
 If !H & !M & !S
  End DAT
 Elsif !L
  End DAT-HEU
 Endif
Elsif dim([L]SYR)>0 : # Syracuse
 End DAT+"T"+HEU+"Z"
Endif
End DAT-HEU-MIL

#-----------------------------------------------------------------------#
Subprog INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK)
Value    Char    FICHIER
Variable Decimal TAILLE
Variable Decimal PROPRIO
Variable Date    DATMOD
Variable Char    HREMOD
Variable Integer OK
Local Integer A , T , J , H , M , S , OKTRT
Local Char    INFO(30)
Local Char    TRAIT(GLONADC) , APPLI(GLONADS)
I = instr(1,FICHIER,".")
If I
 TRAIT = left$(FICHIER,I-1)
 APPLI = right$(FICHIER,I+1)
Else
 TRAIT = FICHIER
Endif
OK = -1
For A=0 To 7
 If nomap(A)<>"" & (APPLI="" or nomap(A)=APPLI)
  Call EXISTE_ADX("",nomap(A),TRAIT,OKTRT) From ORDSYS
  If OKTRT>0
   OK = A : Break
  Endif
 Endif
Next A
Call INFOFIC("TRT",FICHIER,"adx",PROPRIO,TAILLE,DATMOD,HREMOD,OKTRT)
If OKTRT<0
 TAILLE = OKTRT
Endif
End

#-------------------------------------------------------------------------#
Subprog VERSACH(DOSSIER,VERSION)
Value Char DOSSIER
Variable Char VERSION
Local Char FICHIER(GDIMFIC) , MACHINE(GLONAMC) , APPLI(GLONADS)
Local Integer STAT
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
FICHIER = filpath("","vers","atx",APPLI,"",MACHINE)
If filinfo(FICHIER,0)<=0
 VERSION = "5"
Else
 Call SYSTEME2(MACHINE,'archive -n -d'-APPLI,"",STAT,VERSION) From ORDSYS
Endif
End

#-------------------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When ""
  OBJET = "ADC"
 When "SELADCORG"
  Local Char     MACHINE(GDIMFIC) , DOSSIER(GDIMFIC) , APPLI(GLONADS)
  OBJET = "ADC"
  DOSSIER = PARAM(1)
  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
  If DOSSIER = nomap or MACHINE = ""
   Return
  Elsif filinfo(filpath("FIL","ADOVAL","fde",APPLI,"",MACHINE),0)<=0
   OBJET = ""
  Else
   Local File =DOSSIER+".ADOVAL" [ADW_]
   Read [ADW_]ADW0="";"";"SUPDOS"
   If fstat or [F:ADW_]VALEUR=""
    OBJET = ""
   Else
    APPLI = [F:ADW_]VALEUR
    If filinfo(filpath("FIL","ADICTRT","fde",APPLI,"",MACHINE),0)>0
     If !clalev([ADC]) : Local File =MACHINE+"@"+APPLI+".ADICTRT" [ADC] : Endif
    Else
     OBJET = ""
    Endif
   Endif
   Close Local File [ADW_]
  Endif
Endcase
Return

#-------------------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "EDITION"  : Gosub EDIT
 When "EDITION2" : Gosub EDIT2
Endcase
Return

#-------------------------------------------------------------------------#
$EDIT
Local Integer TYPTRT
If VALEUR="" : Return : Endif
TYPTRT = val(PARAM(1)) : # =2->Structure, <>2->Traitement
Case TYPTRT
 When 2       : Call EDITION(VALEUR+".stc")
 When Default : Call EDITION(VALEUR)
Endcase
Return

#-------------------------------------------------------------------------#
$EDIT2
Local Integer TYPTRT
If PARAM(1)="" : Return : Endif
TYPTRT = val(PARAM(2)) : # =2->Structure, <>2->Traitement
Case TYPTRT
 When 2       : Call EDITION(PARAM(1)+".stc")
 When Default : Call EDITION(PARAM(1))
Endcase
Return

#-------------------------------------------------------------------------#
Subprog EDITION(TRAIT)
Value Char TRAIT
Local Integer A , OK ,ECLIPSE, FUSION, EDIWEB, LOK , STC
Local Char    PARAM(30)(1..2) , CODTRT(GLONADC)
CODTRT = TRAIT
STC = instr(1,CODTRT,".stc")
If STC
 CODTRT = left$(CODTRT,STC-1)
 PARAM(2) = "2"
Endif
ECLIPSE = (func AFNC.PARAMUTIL("AECLIPSE",GUSER,"")="2")
FUSION = (dim(GFUSION)>0 & GFUSION)
EDIWEB = (GBROWS & !FUSION) | (FUSION & !ECLIPSE)

If CODTRT=""
 # No source file
 If EDIWEB
  Call TRAITE_CHAR(CODTRT,PARAM,"EDITRTWEB","EDITRTWEB","",6,"") From GTRAITE
 Elsif ECLIPSE
  End
 Else
  Edi : # Pmt
 Endif

Else
 # Source file provided
 OK = -1
 For A=0 To 7
  If nomap(A)<>""
   If STC & filinfo(filpath("STC",CODTRT,"stc",A),0)>=0
    OK = A : Break
   Elsif !STC & filinfo(filpath("TRT",CODTRT,"src",A),0)>=0
    OK = A : Break
   Endif
  Endif
 Next A
 # Testing convergence integration with Eclipse
 If FUSION : # CCL 114989 Script editor from screen dictionary
  If OK>=0
   PARAM(1) = nomap(OK)
  Endif
  Call TRAITE_CHAR(CODTRT,PARAM,"EDITRTWEB","EDITRTWEB","",6,"") From GTRAITE
 Elsif EDIWEB
  If OK>=0
   PARAM(1) = nomap(OK)
  Endif
  Call TRAITE_CHAR(CODTRT,PARAM,"EDITRTWEB","EDITRTWEB","",6,"") From GTRAITE
 Elsif ECLIPSE
  LOK = 0
  If OK>=0
   If STC & filinfo(filpath("STC",CODTRT,"LCKstc",OK),0)>0
   Elsif !STC & filinfo(filpath("TRT",CODTRT,"LCKsrc",OK),0)>0
    LOK = 1
   Endif
  Endif
  Call EDIT(TRAIT,LOK) From AECLIPSE
 Elsif OK=0
  Edi =TRAIT
 Elsif OK>0
  Edi =nomap(OK)+"."+TRAIT
 Else
  Edi
 Endif
Endif
End

