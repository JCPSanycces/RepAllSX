#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# DELETE ADO ASEAR
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("DELETE ADO ASEAR") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ADOCUMENT [ADO]
 Local File ADOCBLB [ADB]
 Local File ADOCCLB [ADH]
Else
 Local File =DOSSIER+".ADOCUMENT" [ADO]
 Local File =DOSSIER+".ADOCBLB" [ADB]
 Local File =DOSSIER+".ADOCCLB" [ADH]
Endif

Gosub DEL_ADO

Close Local File [ADO] , [ADH] , [ADB]
End

#----------------------------------------------#
$DEL_ADO
Local Char WTYPE(20)
Local Char WCODE(30)

Trbegin [ADO] , [ADH] , [ADB]

WTYPE="ACV" : WCODE="ASEAR" : Gosub DEL
WTYPE="AGB" : WCODE="GPUBLIASEAR" : Gosub DEL
WTYPE="ADP" : WCODE="ASEARLAN" : Gosub DEL
WTYPE="ADP" : WCODE="ASEARLAN2" : Gosub DEL
WTYPE="ADP" : WCODE="ASEARNBMAJ" : Gosub DEL
Gosub DEL_CODACT_ASEAR
Commit
Return

#----------------------------------------------#
$DEL
 Delete [ADO] Where [F]TYP=WTYPE & [F]COD=WCODE
 If fstat=1
   Call ERREUR("$ADOCUMENT"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Delete [ADB] Where  [F]TYP=WTYPE & [F]COD=WCODE
 If fstat=1
  Call ERREUR( "$ADOCBLB"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Delete [ADH] Where [F]TYP=WTYPE & [F]COD=WCODE
 If fstat=1
   Call ERREUR("$ADOCCLB"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Return

#----------------------------------------------#
$DEL_CODACT_ASEAR
 Delete [ADO] Where CODACT="ASEAR"
 If fstat=1
   Call ERREUR("$ADOCUMENT"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Delete [ADB] Where CODACT="ASEAR"
 If fstat=1
  Call ERREUR( "$ADOCBLB"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Delete [ADH] Where CODACT="ASEAR"
 If fstat=1
   Call ERREUR("$ADOCCLB"-WTYPE-WCODE,3) From DOSDIC
 Endif
 Return
