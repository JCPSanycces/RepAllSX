#<AdxTL>@(#)0.0.0.0 $Revision$
End

$ACTION
Case ACTION
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return


$CONTROLE
Local Integer OK
MESSA = mess(28,119,1)-mess([M]INVTYP,645,1)-[M]NUM  :# Validation facture...
OK=2 : Call OUINON(MESSA,OK) From GESECRAN
If OK=2
    TMP = 1  :# Pour afficher des tempon/tempoff
Else
    FIN=1
Endif
Return


$EXEC
If [M]INVTYP<>5
    # Il y a un problème de nombre de fichier ouverts
    # On ferme ce qui a l'air de ne pas servir
    Close Local File [GDA] , [TVT] , [ACC] , [ADI] , [AUS] , [TCY]
    # Création d'un trace de pièce de transfert
    Call OUVRE_TRACE(mess(28,119,1)-mess(55,198,1)-":" -[M:BIS0]NUM) From LECFIC    # Validation Facture
    Call VALID([M:BIS0]NUM) From SUBBIS
    # Lecture de la trace
    Call FERME_TRACE From LECFIC
    If GOK = 1 : TRA=1 : Endif
    Gosub OUVRE From WOBIS
Else
    Call DEBTRANS From GLOCK
    Call VALIDPRO([M]NUM) From SUBBIS
Endif
Return

