#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AQUERY_CRITERIA_AFTER"  : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

$AQUERY_CRITERIA_AFTER

If func AFNC.ACTIV("GLM")>0
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2) and (LVEENHANCE eq 2)"
  Else
    PQRY.QWHERE = "(CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2) and (LVEENHANCE eq 2)"
  Endif
Else
  If (PQRY.QWHERE <> "")
    PQRY.QWHERE = "(" + PQRY.QWHERE + ") and (CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
  Else
    PQRY.QWHERE = "(CATTIM eq 3) and (ENAFLG eq 2) and (AUZPRH eq 2)"
  Endif
Endif
#MIPEA - 2018-02-28- US X3-80413- END
Return

