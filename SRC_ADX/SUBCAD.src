#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque CABQ2
$ACTION
Case ACTION
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "FILTRE"       : Gosub FILTRE
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "OUVRE"        : Gosub OUVRE
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "LIENS2"       : Gosub LIENS2
  When "RAZCRE"       : Gosub RAZCRE
  When "VERF_ANU"     : Gosub VERF_ANU
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "FERME"        : Gosub FERME
  When "INICRE"       : Gosub INICRE
  When "INIMOD"       : Gosub INICRE
  When "ANNULE"       : Gosub ANNULE
  When Default
Endcase
Return
###########################################################
$INICRE
Call MAJTEXTRA([M:CAD1]ABQAXX,"CFGABQ","ABQAXX",[M:CAD1]ABQNUM,"") From ATEXTRA
Call MAJTEXTRA([M:CAD1]ABSAXX,"CFGABQ","ABSAXX",[M:CAD1]ABQNUM,"") From ATEXTRA
Call MAJTEXTRA([M:CAD1]ORDAXX,"CFGABQ","ORDAXX",[M:CAD1]ABQNUM,"") From ATEXTRA
Call MAJTEXTRA([M:CAD1]RESAXX,"CFGABQ","RESAXX",[M:CAD1]ABQNUM,"") From ATEXTRA
Return
###########################################################
$ANNULE
Delete [AXX] Where CODFIC="CFGABQ" & IDENT1=[M:CAD1]ABQNUM
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Endif
Return
###########################################################
$FILTRE
FILTRE   = "[F:CAB]ABQCOD= 3"
Return
###########################################################
$FILGAUCHE
FILTSUP   = "[F:CAB]ABQCOD= 3 & [F:CAB]ABQLIN = 1"
Return
###########################################################
$OUVRE
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Global Char GSABSTXT1(28)
Global Char GSABSTXT2(28)
Global Char GSORDTXT1(28)
Global Char GSORDTXT2(28)
Global Char GSRESTXT (15)
Global Char GSSTRTXT (10)
Global Char GSENDTXT (10)
#
Call INTFLD("CABQ2","DMYTXT1",GSABSTXT1)
Call INTFLD("CABQ2","DMYTXT2",GSABSTXT2)
Call INTFLD("CABQ2","DMYTXT3",GSORDTXT1)
Call INTFLD("CABQ2","DMYTXT4",GSORDTXT2)
Call INTFLD("CABQ2","DMYTXT5",GSRESTXT)
Call INTFLD("CABQ2","DMYTXTSTR",GSSTRTXT)
Call INTFLD("CABQ2","DMYTXTEND",GSENDTXT)
Return
###########################################################
$RAZCRE
Actzo [M:CAD1]
Return
###########################################################
$SETBOUT
# cas du tunnel pour consultation
If GFONCTION <> "GESCAD"
  Call VIREBOUT(CHAINE,"A2") From GOBJET
Else
  Call VIREBOUT(CHAINE,"H") From GOBJET
Endif
If GCONSULT = 1
  Call VIREBOUT(CHAINE,"CMADH") From GOBJET
Endif
# cas du tunnel pour consultation sans recherche
If GCONSULT = 2
  Call VIREBOUT(CHAINE,"RCMAD><LI09SH") From GOBJET
Endif
Return
############################################################
$EXEBOUT
#Local Char WDMY
Case REP
   When "a"
     adxmbm = adxmbm
     Gosub SUP_GLOBALES   From WUVAR
     Gosub CFG_CONSTANTES From CFGLIB
     Gosub CFG_SYMBOLES   From CFGLIB
   When "2" :
     If !GINTRA
       Call COPIE([M:CAD1]ABQNUM)
     Endif
Endcase
Return
############################################################
$LIENS2
For I = 0 To [M]NBLIG-1
  Case [M]ABQTYP
    When 1 :
      [M]STRVAL(I) = [M]ALPSTRVAL(I)
      [M]ENDVAL(I) = [M]ALPENDVAL(I)
    When 2 :
      [M]STRVAL(I) = num$([M]NUMSTRVAL(I))
      [M]ENDVAL(I) = num$([M]NUMENDVAL(I))
    When 3 :
      [M]STRVAL(I) = format$("DfZz:"+GFMDAT,[M]DATSTRVAL(I))
      [M]ENDVAL(I) = format$("DfZz:"+GFMDAT,[M]DATENDVAL(I))
  Endcase
  Case [M]ABQTYPY
    When 1 :
      [M]STRVALY(I) = [M]ALPSTRVALY(I)
      [M]ENDVALY(I) = [M]ALPENDVALY(I)
    When 2 :
      [M]STRVALY(I) = num$([M]NUMSTRVALY(I))
      [M]ENDVALY(I) = num$([M]NUMENDVALY(I))
    When 3 :
      [M]STRVALY(I) = format$("DfZz:"+GFMDAT,[M]DATSTRVALY(I))
      [M]ENDVALY(I) = format$("DfZz:"+GFMDAT,[M]DATENDVALY(I))
  Endcase
  Case [M]RESTYP
    When 1 :
      [M]RESVAL(I) = [M]ALPRESVAL(I)
    When 2 :
      [M]RESVAL(I) = num$([M]NUMRESVAL(I))
    When 3 :
      [M]RESVAL(I) = format$("DfZz:"+GFMDAT,[M]DATRESVAL(I))
  Endcase
Next I
Call GET_ATEXTRA("CFGABQ","ABSAXX",GLANGUE,GSABSTXT1) From TRTX3TEX
GSABSTXT2 = GSABSTXT1
If GSABSTXT1 <> ""
  If [M:CAD1]ABSCOD = 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    GSABSTXT1 -= "]"+GSSTRTXT+"["
    GSABSTXT2 -= "["+GSENDTXT+"]"
  Else
    GSABSTXT2 = ""
  Endif
Else
  Call INTFLD("CABQ2","DMYTXT1",GSABSTXT1)
  If [M:CAD1]ABSCOD = 2
    Call INTFLD("CABQ2","DMYTXT2",GSABSTXT2)
  Else
    GSABSTXT2 = ""
  Endif
Endif
Call GET_ATEXTRA("CFGABQ","ordAXX",GLANGUE,GSORDTXT1) From TRTX3TEX
GSORDTXT2 = GSORDTXT1
If GSORDTXT1 <> ""
  If [M:CAD1]ORDCOD = 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    GSORDTXT1 -= "]"+GSSTRTXT+"["
    GSORDTXT2 -= "["+GSENDTXT+"]"
  Else
    GSORDTXT2 = ""
  Endif
Else
  Call INTFLD("CABQ2","DMYTXT3",GSORDTXT1)
  If [M:CAD1]ORDCOD = 2
    Call INTFLD("CABQ2","DMYTXT4",GSORDTXT2)
  Else
    GSORDTXT2 = ""
  Endif
Endif
Call GET_ATEXTRA("CFGABQ","RESAXX",GLANGUE,GSRESTXT) From TRTX3TEX
If GSRESTXT = ""
  Call INTFLD("CABQ2","DMYTXT5",GSRESTXT)
Endif
Grizo [M:CAD1]10-20
Actzo [M:CAD1]ABSAXX
Actzo [M:CAD1]ORDAXX
Actzo [M:CAD1]RESAXX
Actzo [M:CAD1]ABSCOD
Actzo [M:CAD1]ORDCOD
Return
###########################################################
Subprog INTFLD(LMSK,LZON,LTXT)
Value    Char LMSK
Value    Char LZON
Variable Char LTXT
If clalev([F:AMZ]) = 0 : Local File AMSKZON [AMZ] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE  [ATX] : Endif
Read [AMZ]CODE=LMSK;LZON
If fstat = 0
  Call TEXTE([F:AMZ]INTIT,LTXT) From OBJDIV
Endif
End
###########################################################
$FERME
Kill GSABSTXT1
Kill GSABSTXT2
Kill GSORDTXT1
Kill GSORDTXT2
Kill GSRESTXT
Kill GSSTRTXT
Kill GSENDTXT
#
Call  IMPSCR       From ATRTX3
If GFONCTION = "GESCAB"
  Gosub SUP_GLOBALES From WUVAR
Endif
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
###########################################################
$COP_ECRAN
Call PRTSCR("CABQ2","CAD1","",0,0) From ATRTX3
Return
############################################################
$VERF_ANU
If clalev([F:CLN]) = 0 : Local File CFGLNK [CLN] : Endif
Filter [CLN] Where SYMTYP = 10             &
&                  SYMNUM = [M:CAD1]ABQNUM
&            Order By Key CLN1
For [CLN]
  Call ERREUR(mess(174,188,1)-mess([F:CLN]SYMTYPWUS,752,1)-[F:CLN]SYMNUMWUS) From GESECRAN
  OK = 0
  Break
Next
Filter [CLN]
Return
############################################################
############################################################
Subprog COPIE(LPAR)
Value Char    LPAR
#
Local Char    W_TRA(100)
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(113,188,1)-LPAR) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(78,188,1)+" : "+LPAR
  W_OK = 2
  zonsui = "DOSDES"
  Call DIALWIN(W_OK,mess(113,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File CFGABQ    [CAB1]
  Local File ATEXTRA   [AXX1]
Endif
# tables en ecriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".CFGABQ"    [CAB2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
Endif
# Contrôle copie possible (les elements existants doivent etre de meme nature)
Read [CAB1]CAB0=LPAR;1
If fstat
  Goto COPIE_FIN
Endif
Read [CAB2]CAB0=LPAR;1
If fstat = 0
  If [F:CAB1]ABQTYP  <> [F:CAB2]ABQTYP  |
&    [F:CAB1]ABQTYPY <> [F:CAB2]ABQTYPY |
&    [F:CAB1]RESTYP  <> [F:CAB2]RESTYP
    W_TRA = [F:CAB1]ABQNUM-mess(93,188,1)
    W_ERR = 1
    Call ECR_TRACE(W_TRA,1) From GESECRAN
  Else
    W_OK = 2
    Call OUINON(mess(148,196,1),W_OK) From GESECRAN
    If W_OK <> 2
      Call OUVRE_TRACE(mess(112,188,1)-LPAR) From LECFIC
      Goto COPIE_FIN
    Endif
  Endif
Endif
If W_ERR <> 0
  Goto COPIE_FIN
Endif
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Call DEBTRANS    From GLOCK
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
If clalev([F:AXX1]) : Close Local File [AXX1] : Endif
If clalev([F:AXX2]) : Close Local File [AXX2] : Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
$TRT_COPIE
Trbegin [CAB2]
Delete [CAB2] Where ABQNUM = LPAR
# Copie abaques
Filter [CAB1] Where ABQNUM = LPAR
For [CAB1]
  [F:CAB2] = [F:CAB1]
  [F:CAB2]CREUSR = GUSER
  [F:CAB2]CREDAT = date$
  [F:CAB2]UPDUSR = ""
  [F:CAB2]UPDDAT = [0/0/0]
  Write [CAB2]
  If fstat
    GOK = 0
    Call FSTA("CAB2") From GLOCK
    Break
  Endif
  If [F:CAB2]ABQLIN = 1
    W_TRA = mess(91,123,1)-mess(78,188,1)-[F:CAB2]ABQNUM
    Call ECR_TRACE(W_TRA,0) From GESECRAN
  Endif

# Issue 98625 GA 04/2014 avant [F:CFG1] Ko
  Call COPTEXTRA("CFGABQ","ABQAXX",[F:CAB1]ABQNUM,"") From ATEXTRA
  Call COPTEXTRA("CFGABQ","ABSAXX",[F:CAB1]ABQNUM,"") From ATEXTRA
  Call COPTEXTRA("CFGABQ","ORDAXX",[F:CAB1]ABQNUM,"") From ATEXTRA
  Call COPTEXTRA("CFGABQ","RESAXX",[F:CAB1]ABQNUM,"") From ATEXTRA
  If !GOK : Break : Endif
Next
Filter [CAB1]
If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return
############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return
############################################################
Subprog AS_ABQTYP(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(4) = 1
  GMENLOC(5) = 1
Endif
End
############################################################
Subprog AM_ABQTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M]ABQCHA = 0
  Affzo [M]ABQCHA
Endif
End
############################################################
Subprog AS_ABQCHA(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0 | [M]ABQTYP <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_ABQTYPY(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(4) = 1
  GMENLOC(5) = 1
Endif
End
############################################################
Subprog AM_ABQTYPY(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M]ABQCHAY = 0
  Affzo [M]ABQCHAY
Endif
End
############################################################
Subprog AS_ABQCHAY(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0 | [M]ABQTYPY <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_RESTYP(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Else
  GMENLOC(4) = 1
  GMENLOC(5) = 1
Endif
End
############################################################
Subprog AM_RESTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M]RESCHA = 0
  Affzo [M]RESCHA
Endif
End
############################################################
Subprog AS_RESCHA(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0 | [M]RESTYP <> 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_ABSCOD(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_ORDCOD(VALEUR)
Variable Integer VALEUR
If [M]NBLIG <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_STRVAL(VALEUR)
Variable Char VALEUR()
If nolign > 1 & VALEUR = ""
  Case [M]ABQTYP
    When 1 :
      VALEUR = [M]STRVAL(nolign-2)
      [M]ALPSTRVAL(nolign-1) = [M]ALPENDVAL(nolign-2)
    When 2 :
      VALEUR = [M]STRVAL(nolign-2)
      [M]NUMSTRVAL(nolign-1) = [M]NUMENDVAL(nolign-2)
    When 3 :
      VALEUR = [M]STRVAL(nolign-2)
      [M]DATSTRVAL(nolign-1) = [M]DATENDVAL(nolign-2)
  Endcase
Endif
End
############################################################
Subprog C_STRVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYP,[M]ABQCHA,[M]ALPSTRVAL(nolign-1),
&    [M]NUMSTRVAL(nolign-1),[M]DATSTRVAL(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  If nolign > 1
    Case [M]ABQTYP
      When 1 :
        If [M]ALPSTRVAL(nolign-1) < [M]ALPSTRVAL(nolign-2)
          mkstat = 2
        Else
          If [M]ALPSTRVAL(nolign-1) <> [M]ALPSTRVAL(nolign-2)   &
&            [M]ALPSTRVAL(nolign-1) <= [M]ALPENDVAL(nolign-2)
            mkstat = 2
          Endif
        Endif
      When 2 :
        If [M]NUMSTRVAL(nolign-1) < [M]NUMSTRVAL(nolign-2)
          mkstat = 2
        Else
          If [M]NUMSTRVAL(nolign-1) <> [M]NUMSTRVAL(nolign-2)   &
&            [M]NUMSTRVAL(nolign-1) <= [M]NUMENDVAL(nolign-2)
            mkstat = 2
          Endif
        Endif
      When 3 :
        If [M]DATSTRVAL(nolign-1) < [M]DATSTRVAL(nolign-2)
          mkstat = 2
        Else
          If [M]DATSTRVAL(nolign-1) <> [M]DATSTRVAL(nolign-2)   &
&            [M]DATSTRVAL(nolign-1) <= [M]DATENDVAL(nolign-2)
            mkstat = 2
          Endif
        Endif
    Endcase
  Endif
Endif
End
############################################################
Subprog AS_ENDVAL(VALEUR)
Variable Char VALEUR()
If [M]ABSCOD = 1
  mkstat = 2
  VALEUR = ""
Else
  If nolign > 1
    If [M]STRVAL(nolign-1) = [M]STRVAL(nolign-2)
      VALEUR = [M]ENDVAL(nolign-2)
      Case [M]ABQTYP
        When 1 : [M]ALPENDVAL(nolign-1) = VALEUR
        When 2 : [M]NUMENDVAL(nolign-1) = val(VALEUR)
        When 3 : [M]DATENDVAL(nolign-1) = format$("DfZz:"+GFMDAT,VALEUR)
      Endcase
      mkstat = 2
    Endif
  Endif
Endif
End
############################################################
Subprog C_ENDVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYP,[M]ABQCHA,[M]ALPENDVAL(nolign-1),
&    [M]NUMENDVAL(nolign-1),[M]DATENDVAL(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  Case [M]ABQTYP
    When 1 :
      If [M]ALPENDVAL(nolign-1) < [M]ALPSTRVAL(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 2 :
      If [M]NUMENDVAL(nolign-1) < [M]NUMSTRVAL(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 3 :
      If [M]DATENDVAL(nolign-1) < [M]DATSTRVAL(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
  Endcase
Endif
End
############################################################
Subprog AS_STRVALY(VALEUR)
Variable Char    VALEUR()
If [M]ABQTYPY = 2 & nolign > 1 & VALEUR = ""
  If [M]NUMSTRVAL(nolign-1) = [M]NUMSTRVAL(nolign-2) &
&    [M]NUMENDVAL(nolign-1) = [M]NUMENDVAL(nolign-2)
    VALEUR = num$([M]NUMENDVALY(nolign-2)+1)
  Endif
Endif
End
############################################################
Subprog C_STRVALY(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYPY,[M]ABQCHAY,[M]ALPSTRVALY(nolign-1),
&    [M]NUMSTRVALY(nolign-1),[M]DATSTRVALY(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  If nolign > 1
    If [M]STRVAL(nolign-1) = [M]STRVAL(nolign-2) & [M]ENDVAL(nolign-1) = [M]ENDVAL(nolign-2)
      Case [M]ABQTYPY
        When 1 :
          If [M]ALPSTRVALY(nolign-1) <= [M]ALPENDVALY(nolign-2)
            mkstat = 2
          Endif
        When 2 :
          If [M]NUMSTRVALY(nolign-1) <= [M]NUMENDVALY(nolign-2)
            mkstat = 2
          Endif
        When 3 :
          If [M]DATSTRVALY(nolign-1) <= [M]DATENDVALY(nolign-2)
            mkstat = 2
          Endif
      Endcase
    Endif
  Endif
Endif
End
############################################################
Subprog AS_ENDVALY(VALEUR)
Variable Char    VALEUR()
If [M]ORDCOD = 1
  mkstat = 2
  VALEUR = ""
Endif
End
############################################################
Subprog C_ENDVALY(VALEUR)
Variable Char    VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]ABQTYPY,[M]ABQCHAY,[M]ALPENDVALY(nolign-1),
&    [M]NUMENDVALY(nolign-1),[M]DATENDVALY(nolign-1),mkstat)  From CFGLIBD
If mkstat = 0
  Case [M]ABQTYPY
    When 1 :
      If [M]ALPENDVALY(nolign-1) < [M]ALPSTRVALY(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 2 :
      If [M]NUMENDVALY(nolign-1) < [M]NUMSTRVALY(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 3 :
      If [M]DATENDVALY(nolign-1) < [M]DATSTRVALY(nolign-1)
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
  Endcase
Endif
End
############################################################
Subprog C_RESVAL(VALEUR)
Variable Char VALEUR()
VALEUR = vireblc(VALEUR,1)
Call SAI_VARIABLE(VALEUR,[M]RESTYP,[M]RESCHA,[M]ALPRESVAL(nolign-1),
&    [M]NUMRESVAL(nolign-1),[M]DATRESVAL(nolign-1),mkstat)  From CFGLIBD
End
############################################################
Subprog C_ABQNUM(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,"/")
  mkstat = 2
Endif
End
############################################################
Subprog AM_ABSAXX(VALEUR)
Variable Char    VALEUR()
Local Char BASPAG(10)
If VALEUR <> ""
  If [M:CAD1]ABSCOD <> 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    GSABSTXT1 = VALEUR -"]"+GSSTRTXT+"["
    GSABSTXT2 = VALEUR -"["+GSENDTXT+"]"
  Else
    GSABSTXT1 = VALEUR
    GSABSTXT2 = ""
  Endif
Else
  Call INTFLD("CABQ2","DMYTXT1",GSABSTXT1)
  If [M:CAD1]ABSCOD <> 2
    Call INTFLD("CABQ2","DMYTXT2",GSABSTXT2)
  Else
    GSABSTXT2 = ""
  Endif
Endif
BASPAG = "NBLIG"
Gosub TIT_COL From W1CABQ1
End
############################################################
Subprog AM_ORDAXX(VALEUR)
Variable Char    VALEUR()
Local Char BASPAG(10)
If VALEUR <> ""
  If [M:CAD1]ORDCOD = 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    GSORDTXT1 = VALEUR -"]"+GSSTRTXT+"["
    GSORDTXT2 = VALEUR -"["+GSENDTXT+"]"
  Else
    GSORDTXT1 = VALEUR
    GSORDTXT2 = ""
  Endif
Else
  Call INTFLD("CABQ2","DMYTXT3",GSORDTXT1)
  If [M:CAD1]ORDCOD <> 2
    Call INTFLD("CABQ2","DMYTXT4",GSORDTXT2)
  Else
    GSORDTXT2 = ""
  Endif
Endif
BASPAG = "NBLIG"
Gosub TIT_COL From W1CABQ1
End
############################################################
Subprog AM_RESAXX(VALEUR)
Variable Char    VALEUR()
Local Char BASPAG(10)
If VALEUR <> ""
  GSRESTXT = VALEUR
Else
  Call INTFLD("CABQ2","DMYTXT5",GSRESTXT)
Endif
BASPAG = "NBLIG"
Gosub TIT_COL From W1CABQ1
End
############################################################
Subprog AM_ABSCOD(VALEUR)
Variable Integer VALEUR
Local Char BASPAG(10)
If [M:CAD1]ABSAXX <> ""
  If VALEUR = 2
    # FQ 78675 GA 01/2012 intitulé des colonnes
    GSABSTXT1 = [M:CAD1]ABSAXX-"]"+GSSTRTXT+"["
    GSABSTXT2 = [M:CAD1]ABSAXX-"["+GSENDTXT+"]"
  Else
    GSABSTXT1 = [M:CAD1]ABSAXX
    GSABSTXT2 = ""
  Endif
Else
  Call INTFLD("CABQ2","DMYTXT1",GSABSTXT1)
  If VALEUR = 2
    Call INTFLD("CABQ2","DMYTXT2",GSABSTXT2)
  Else
    GSABSTXT2 = ""
  Endif
Endif
BASPAG = "NBLIG"
Gosub TIT_COL From W1CABQ1
End
