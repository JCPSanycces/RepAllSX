#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour no de rang dans fonctions ACHANGE
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update ACHANGE fonction") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub GESACG
End

#-------------------#
$GESACG
#CHECK IGNORE_BEGIN
Local Char AFC(GLONAFC)

Local File =DOSSIER+".AFONCTION"   [AFC] 

# Mise à jour de la table AFONCTION
Call ECR_TRACE(mess(81,125,1)-"AFONCTION:"-time$,0) From GESECRAN
Trbegin [AFC]
 For [L]AFC="ACHANGE","GESACG","ACOPADO"
  Read [AFC]CODINT=[L]AFC
  If !fstat
   Case [F:AFC]CODINT
    When "GESACG"  : [F:AFC]RANG = 93
    When "ACOPADO" : [F:AFC]RANG = 92
    When "ACHANGE" : [F:AFC]RANG = 94
   Endcase
   Rewrite [AFC]
   If fstat
    Call ERREUR("AFONCTION"-[F:AFC]CODINT,2) From DOSDIC
   Endif 
  Endif
 Next AFC
Commit

Close Local File [AFC]
#CHECK IGNORE_END

Return
