#<AdxTL>@(#)6.0.0.0 $Revision$
################################################################################
# ACH1MAJ30 : Mises à jour à effectuer lors du passage à la v6   Module achats #
# ---------------------------------------------------------------------------- #
# AV_POH : Alimentation des nouveaux champs dans les commandes d'achat         #
# AV_UOH : Alimentation des nouveaux champs dans les historiques de commande   #
################################################################################

###############################################################
# Alimentation des nouveaux champs dans les commandes d'achat #
# ----------------------------------------------------------- #
# Table PORDER - Entête commande :                            #
#   CPY        Code société                                   #
#   FPUFLG     Indicateur relance livraisons                  #
#   OCNFLG     Indicateur relance ARC                         #
#   BPOADD     Code adresse expéditeur                        #
#   BPONAM     Nom ou raison sociale fournisseur expéditeur   #
#   BPOADDLIG  Lignes adresse expéditeur                      #
#   BPOPOSCOD  Code postal expéditeur                         #
#   BPOCTY     Ville expéditeur                               #
#   BPOSAT     Etat expéditeur                                #
#   BPOCRY     Pays expéditeur                                #
#   BPOCRYNAM  Nom du pays expéditeur                         #
#   BPAPAY     Code adresse fournisseur payé                  #
#   BPAINV     Code adresse fournisseur facturant             #
#   EECICT     Incoterm                                       #
#   EECLOC     Lieu transport CEE                             #
#   EECNUM     Identification CEE                             #
#   DSPWEU     Unité de poids pour répartition                #
#   DSPVOU     Unité de volume pour répartition               #
#   TOTLINATI  Total TTC ligne                                #
#   TOTLINAMT  Total HT  ligne                                #
#   TOTLINQTY  Total quantités commandées en UA               #
#   TOTLINWEU  Total poids                                    #
#   TOTLINVOU  Total volume                                   #
#   TOTTAXAMT  Total des taxes                                #
#   INVDTALIN1 Eléments facturation ligne tarif               #
#   INVDTAVAT1 Codes taxe éléments facturation ligne tarif    #
#   INVDTALIN2 Eléments facturation répartis sur ligne        #
#   INVDTAVAT2 Codes taxe éléments facturation répartis       #
#   TOTORDL    Total HT devise société                        #
#   TTVORDL    Total TTC devise société                       #
# Table PORDERQ - Lignes quantités commande                   #
#   CPY        Code société                                   #
#   BPAINV     Code adresse fournisseur facturant             #
#   LINPURTYP  Type d'achat                                   #
#   LINTYP     Type de ligne                                  #
#   CMMTAX     Indicateur type d'engagement (HT/HTND/TTC)     #
#   CMMFLG     Indicateur engagement                          #
#   QTYWEU     Poids                                          #
#   QTYVOU     Volume                                         #
#   LINATI     Montant TTC ligne (produit sans éléments fact) #
#   CLCAMT1-3  Bases spéciales 1-3 calcul taxe                #
#   ITMREFORI  Article lancé          (remplace MFGITM)       #
#   VCRTYPORI  Type pièce origine                             #
#   VCRNUMORI  No pièce origine       (remplace MFGNUM)       #
#   VCRLINORI  Ligne pièce prigine    (remplace OPENUM)       #
#   VCRSEQORI  Séquence pièce origine (remplace OPESPLNUM)    #
# Table PORDERP - Lignes prix commande                        #
#   CPY        Code société                                   #
# Table PORDERC - Lignes article commande ouverte             #
#   CPY        Code société                                   #
#   COA(10)    Codes plan de compte                           #
#   LINACC(10) Comptes                                        #
#   LINPURTYP  Type d'achat                                   #
#   EECICT     Incoterm                                       #
#   EECLOC     Lieu transport CEE                             #
#   EECNUM     Identification CEE                             #
# Table CPTANALIN - Lignes comptables analytiques             #
#   Création d'enregistrements dans cette nouvelle table      #
#   en remplacement des champs comptes et sections            #
# Table PVCRFOOT  - Eléments de facturation                   #
#   Création d'enregistrements dans cette nouvelle table      #
#   en remplacement des champs éléments de facturation        #
# Table PVCRVAT   - Tableau des taxes                         #
#   Création d'enregistrements dans cette nouvelle table      #
# Table GACCDUDATE - Echéances                                #
#   BPAPAY     Code adresse fournisseur payé                  #
###############################################################
$AV_POH
Local File =[F:ADS]DOSSIER+".PORDER"     [POH]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [POQ]
Local File =[F:ADS]DOSSIER+".PORDERP"    [POP]
Local File =[F:ADS]DOSSIER+".PORDERC"    [POC]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [CAL]
Local File =[F:ADS]DOSSIER+".BPARTNER"   [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER" [BPS]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".ITMMASTER"  [ITM]
Local File =[F:ADS]DOSSIER+".TABVAT"     [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"  [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]
Local File =[F:ADS]DOSSIER+".GACCOUNT"   [GAC]
Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
Local File =[F:ADS]DOSSIER+".GAUTACEF"   [GAG]
Local File =[F:ADS]DOSSIER+".TABVAC"     [TVC]
Local File =[F:ADS]DOSSIER+".PORDER"     [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"    [TB1]
Local File =[F:ADS]DOSSIER+".CPTANALIN"  [TB2]
Local File =[F:ADS]DOSSIER+".TABUNIT"    [TUN]
Local File =[F:ADS]DOSSIER+".TABCOEFF"   [TCO]
Local File =[F:ADS]DOSSIER+".TABCHANGE"  [TCH]
Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"     [ADP]
Local File =[F:ADS]DOSSIER+".PFOOTINV"   [PFI]
Local File =[F:ADS]DOSSIER+".PVCRVAT"    [PVV]
Local File =[F:ADS]DOSSIER+".PVCRFOOT"   [PVF]
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]
Local File =[F:ADS]DOSSIER+".GACCDUDATE" [DUD]
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT" [PRS]
#-----
Local Libelle  WPVVFLG, WPVFFLG
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPOH), CRITERE(90)
Local Char     WEECICT(GLONADI)
Local Char     TPLAN  (GLONCOA)(1..10)
Local Char     TCOMPTE(GLONGAC)(1..10)
Local Char     ID1(20)(1..1), ID2(20)(1..3), WMSG(80)
Local Integer  STAT, I, J, K, WPOPLIN, WPURTYP, SIGN
Local Libelle  WEECLOC
Local Decimal  WRND, WTOTLINAMT, MTLIG
Local Decimal  WQTYPUU, WQTYWEU, WQTYVOU
#----- Variables locales pour calcul TVA -----#
Local Integer  TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)
#----- Tableau des taxes en mémoire (20 maxi) -----#
Local Integer  NBTAX
Local Char     TAX(GLONVAT)(20)
Local Decimal  BASTAX(20)
Local Decimal  AMTTAX(20)
Local Decimal  DEDTAX(20)
Local Libelle  PURTYP(20)
Local Libelle  VATTYP(20)
#----- Tableau des éléments de facturation en mémoire (15 maxi) -----#
Local Integer  NBFAC
Local Integer  INVDTA(15)
Local Decimal  INVDTAAMT(15)
Local Decimal  INVLINAMT(15)
Local Decimal  INVCPLAMT(15)
Local Libelle  INVLINFLG(15)
Local Libelle  DEBCDT(15)
Local Char     INVDTAVAT(GLONVAT)(15)
Local Decimal  DTAAMTTAX(15)
Local Decimal  DTADEDTAX(15)
Local Decimal  CUMLIG(15)
#-----
Raz CLE1, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Order Process 1 : Update PORDER-Q-P-C") From DOSSUB
$BOUCLE_POH
If  STOP=1
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1"
Endif
Raz COMPTEUR
Trbegin [POH],[POQ],[POP],[POC]
  For [POH] POH0 Where evalue(CRITERE)
    Raz [F:POH]TOTLINAMT, [F:POH]TOTLINQTY, [F:POH]TOTLINWEU, [F:POH]TOTLINVOU
    Raz [L]NBTAX,  [L]TAX,       [L]BASTAX,    [L]AMTTAX,    [L]DEDTAX,    [L]PURTYP
    Raz [L]VATTYP
    Raz [L]NBFAC,  [L]INVDTA,    [L]INVDTAAMT, [L]INVLINAMT, [L]INVCPLAMT, [L]INVLINFLG
    Raz [L]DEBCDT, [L]INVDTAVAT, [L]DTAAMTTAX, [L]DTADEDTAX, [L]CUMLIG
    #----- Alimentation société, indicateurs relance sur l'entête de commande -----#
    Call PARAM([F:POH]POHFCY,"SALDSPWEU",[F:POH]DSPWEU) From ADOVAL
    Call PARAM([F:POH]POHFCY,"SALDSPVOU",[F:POH]DSPVOU) From ADOVAL
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:POH]POHFCY) From TRTX3CPT
    [F:POH]CPY=GSOCIETE
    If [F:BPS]BPSNUM<>[F:POH]BPSNUM
      Read [BPS] BPS0=[F:POH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    [F:POH]FUPFLG=[F:BPS]FUPFLG
    [F:POH]OCNFLG=[F:BPS]OCNFLG
    #----- Taxes déjà traitées car présentes dans PVCRVAT ? -----#
    If [F:POH]POHTYP=2
      Look [PVV] PVV1=5;[F:POH]POHNUM;1
    Else
      Look [PVV] PVV1=3;[F:POH]POHNUM;1
    Endif
    If fstat  WPVVFLG=1  Else  WPVVFLG=0 : Endif
    #----- Eléments déjà traités car présents dans PVCRFOOT ? -----#
    If [F:POH]POHTYP=2
      Look [PVF] PVF1=5;[F:POH]POHNUM;1
    Else
      Look [PVF] PVF1=3;[F:POH]POHNUM;1
    Endif
    If fstat  WPVFFLG=1  Else  WPVFFLG=0 : Endif
    #-----
    [L]WEECICT   =[F:BPS]EECICT
    [L]WEECLOC   =[F:BPS]EECLOC
    #----- Alimentation des informations douanières si commande classique -----#
    If [F:POH]POHTYP<>2
      #----- Alimentation incoterm et lieu de transport CEE -----#
      If [F:POH]EECICT=""
        [F:POH]EECICT=[F:BPS]EECICT : # Incoterm
      Endif
      If GACTDEB=2 & [F:POH]EECLOC=0
        [F:POH]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
      Endif
      #----- Alimentation identification CEE du tiers facturant -----#
      If GACTDEB=2 & [F:POH]EECNUM=""
        If [F:BPR]BPRNUM<>[F:POH]BPSINV
          Read [BPR] BPR0=[F:POH]BPSINV : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:POH]EECNUM=[F:BPR]EECNUM : # Identification CEE
      Endif
    Endif
    #-----
    If [F:POH]BPOADD=""
      #----- Si fournisseur divers, adr.commande = adr.expédition -----#
      If [F:BPS]BPSTYP=3
        [F:POH]BPOADD      =[F:POH]BPAADD
        [F:POH]BPONAM(0)   =[F:POH]BPRNAM(0)
        [F:POH]BPONAM(1)   =[F:POH]BPRNAM(1)
        [F:POH]BPOADDLIG(0)=[F:POH]BPAADDLIG(0)
        [F:POH]BPOADDLIG(1)=[F:POH]BPAADDLIG(1)
        [F:POH]BPOADDLIG(2)=[F:POH]BPAADDLIG(2)
        [F:POH]BPOPOSCOD   =[F:POH]POSCOD
        [F:POH]BPOCTY      =[F:POH]CTY
        [F:POH]BPOSAT      =[F:POH]SAT
        [F:POH]BPOCRY      =[F:POH]CRY
        [F:POH]BPOCRYNAM   =[F:POH]CRYNAM
      #----- alimentation code adresse expédition -----#
      Else
        [F:POH]BPOADD=[F:BPS]BPAADD
        If GACTSAD=2 : # Stockage systématique de l'adresse !
          #----- Lecture BPARTNER si nécessaire -----#
          If [F:BPR]BPRNUM<>[F:POH]BPSNUM
            Read [BPR] BPR0=[F:POH]BPSNUM
            If fstat Raz [F:BPR] : Endif
          Endif
          #----- Lecture de l'adresse si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
            Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:POH]BPONAM(0)    = [F:BPR]BPRNAM(0)
          [F:POH]BPONAM(1)    = [F:BPR]BPRNAM(1)
          [F:POH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:POH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:POH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:POH]BPOCRY       = [F:BPA]CRY
          [F:POH]BPOCRYNAM    = [F:BPA]CRYNAM
          [F:POH]BPOSAT       = [F:BPA]SAT
          [F:POH]BPOPOSCOD    = [F:BPA]POSCOD
          [F:POH]BPOCTY       = [F:BPA]CTY
        Endif
      Endif
    Endif
    #----- Alimentation code adresse fournisseur payé -----#
    If [F:BPS]BPRPAY=[F:POH]BPRPAY
      [F:POH]BPAPAY=[F:BPS]BPAPAY
    Else
      If [F:BPS]BPSNUM<>[F:POH]BPRPAY
        Read [BPS] BPS0=[F:POH]BPRPAY : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:POH]BPAPAY=[F:BPS]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:BPS]BPSINV=[F:POH]BPSINV
      [F:POH]BPAINV=[F:BPS]BPAINV
    Else
      If [F:BPS]BPSNUM<>[F:POH]BPSINV
        Read [BPS] BPS0=[F:POH]BPSINV : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:POH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation champs pour le multi-référenciels comptabilité -----#
    If dim([F:POH]DIE)>0 & [F:POH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:POH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #----- Alimentation éléments et taxes ligne tarif -----#
    If [F:BPS]BPSNUM<>[F:POH]BPSNUM
      Read [BPS] BPS0=[F:POH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    #-----
    Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
    #----- Chargement arrondi devise commande -----#
    If [F:TCU]CUR<>[F:POH]CUR
      Read [TCU] TCU0=[F:POH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
    #-----
    For I=0 To dim([F:POH]INVDTAVAT1)-1
      If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
        [F:POH]INVDTALIN1(I)=GINVDTALIN(I)
        If [F:POH]INVDTAVAT1(I)=""
          Read [PFI] PFI0=GINVDTALIN(I) : If fstat  Raz [F:PFI] : Endif
          If [F:PFI]VATRUL=2
            Read [TVC] TVC0=[F:BPS]VACBPR;[F:PFI]VACITM : If fstat  Raz [F:TVC] : Endif
            [F:POH]INVDTAVAT1(I)=[F:TVC]VAT
          Endif
        Endif
      Endif
    Next I
    #----- Calcul total des quantités UA, poids, volume -----#
    For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & find(LINTYP,0,1,2,4)<>0
      If [F:ITM]ITMREF<>[F:POQ]ITMREF
        Read [ITM] ITM0=[F:POQ]ITMREF : If fstat  Raz [F:ITM] : Endif
      Endif
      #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
      If [F:POH]DSPWEU=""  [F:POH]DSPWEU=[F:ITM]WEU : Endif
      If [F:POH]DSPVOU=""  [F:POH]DSPVOU=[F:ITM]VOU : Endif
      #-----
      [F:POQ]QTYWEU=[F:ITM]ITMWEI*[F:POQ]QTYSTU
      [F:POQ]QTYVOU=[F:ITM]ITMVOU*[F:POQ]QTYSTU
      Call CONVERT_QTY([F:ITM]WEU,[F:POH]DSPWEU,[F:POQ]QTYWEU) From TRTX3
      Call CONVERT_QTY([F:ITM]VOU,[F:POH]DSPVOU,[F:POQ]QTYVOU) From TRTX3
      #----- Cumuls qtés ligne -----#
      If [F:POQ]WIPSTA<2 & [F:POQ]LINSTA<>3 & [F:POH]POHTYP<>2
        [F:POH]TOTLINQTY+=[F:POQ]QTYPUU
        [F:POH]TOTLINWEU+=[F:POQ]QTYWEU
        [F:POH]TOTLINVOU+=[F:POQ]QTYVOU
      Endif
    Next
    #----- Calcul total des montants Ht ligne -----#
    For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & LINTYP<>2 & WIPSTA<2 & LINSTA<>3
      [F:POH]TOTLINAMT+=[F:POQ]LINAMT
    Next
    #----- Reprise des éléments existant sur l'entête de commande -----#
    If dim([F:POH]INVDTA)>0
      Raz K
      For I=0 To dim([F:POH]INVDTA)-1
        If [F:POH]INVDTA(I)<>0
          J=[L]NBFAC
          Read [PFI] PFI0=[F:POH]INVDTA(I) : If fstat  Raz [F:PFI] : Endif
          [L]INVDTA   (J)=[F:POH]INVDTA(I)
          [L]INVDTAAMT(J)=[F:POH]INVDTAAMT(I)
          [L]INVCPLAMT(J)=[F:POH]INVCPLAMT(I)
          If [F:PFI]DACLIN=2
            [L]INVLINFLG(J)=6
          Else
            [L]INVLINFLG(J)=[F:PFI]DSPLIN
          Endif
          [L]DEBCDT   (J)=max(1,[F:PFI]INCDCR)
          SIGN=1-2*([L]DEBCDT(J)-1)
          If [F:POH]AMTCOD(I)=2  : #----- Montant
            [L]INVLINAMT(J)=[F:POH]INVDTAAMT(I)*SIGN
          Elsif [F:PFI]CLCBAS<>3 : #----- Pourcentage sur HT
            [L]INVLINAMT(J)=arr([F:POH]TOTLINAMT*[F:POH]INVDTAAMT(I)/100,WRND)*SIGN
          Else                   : #----- Pourcentage sur TTC
            [L]INVLINAMT(J)=arr([F:POH]TTVORD*[F:POH]INVDTAAMT(I)/100,WRND)*SIGN
          Endif
          If [F:PFI]VATRUL=2
            Read [TVC] TVC0=[F:POH]VACBPR;[F:PFI]VACITM : If fstat  Raz [F:TVC] : Endif
            [L]INVDTAVAT(J)=[F:TVC]VAT
          Endif
          [L]NBFAC+=1
          If [F:PFI]DSPLIN>1
            [F:POH]INVDTALIN2(K)=[L]INVDTA   (J)
            [F:POH]INVDTAVAT2(K)=[L]INVDTAVAT(J)
            K+=1
          Endif
        Endif
      Next I
    Endif
    #-----
    Raz WTOTLINAMT, [F:POH]TOTLINATI
    For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM
      WPOPLIN=[F:POQ]POPLIN
      #----- Alimentation sté, adresse facturant et expéditeur sur lignes commande -----#
      [F:POQ]CPY      =[F:POH]CPY
      [F:POQ]BPAINV   =[F:POH]BPAINV
      #----- Alimentation du type d'achat -----#
      If [F:POQ]LINPURTYP=0  [F:POQ]LINPURTYP=1 : Endif
      #----- Alimentation du type de ligne -----#
      If [F:POQ]LINTYP=0  [F:POQ]LINTYP=1 : Endif
      #----- Alimentation des quantités poids et volume (sauf ligne service) -----#
      If find([F:POQ]LINTYP,1,2,4)
        If [F:ITM]ITMREF<>[F:POQ]ITMREF
          Read [ITM] ITM0=[F:POQ]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        #-----
        [F:POQ]QTYWEU=[F:ITM]ITMWEI*[F:POQ]QTYSTU
        [F:POQ]QTYVOU=[F:ITM]ITMVOU*[F:POQ]QTYSTU
        Call CONVERT_QTY([F:ITM]WEU,[F:POH]DSPWEU,[F:POQ]QTYWEU) From TRTX3
        Call CONVERT_QTY([F:ITM]VOU,[F:POH]DSPVOU,[F:POQ]QTYVOU) From TRTX3
      Endif
      #----- Si ce n'est pas un service, qté, poids et volume pour répartition -----#
      If [F:POQ]LINTYP<>3
        WQTYPUU=[F:POQ]QTYPUU
        WQTYWEU=[F:POQ]QTYWEU
        WQTYVOU=[F:POQ]QTYVOU
      Endif
      #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
      If ([F:POQ]CLCAMT1<>0 | [F:POQ]CLCAMT2<>0)
&       & [F:POQ]CLCAMT3=0
&       & [F:POQ]CLCAMT4=0
&       & [F:POQ]CLCAMT5=0
&       & [F:POQ]CLCAMT6=0
&       & [F:POQ]CLCAMT7=0
        #----- Lecture ligne commande prix -----#
        If [F:POH]POHTYP=1
          Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
        Else
          Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First
          Filter [POP]
        Endif
        If fstat  Raz [F:POP] : Endif
        #-----
        Raz WCLCAMT, WCLCFLG
        WCLCAMT1=[F:POQ]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:POQ]CLCAMT2 : WCLCFLG2=0
        For I=2 To 3
          Case I
            When 2 : WTAX=[F:POP]VAT(I-1) : Gosub TRT_BASE
            When 3 : WTAX=[F:POP]VAT(I-1) : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:POQ]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:POQ]CLCAMT2 : Endif
          For I=2 To 3
            If WCLCFLG(I)=1
              Assign "[F:POQ]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
        Endif
      Endif
      #----- Calcul bases et taxes de la ligne de commande -----#
      If [F:POQ]LINTYP<>2 & [F:POQ]WIPSTA<2 & [F:POQ]LINSTA<>3
        WTOTLINAMT+=[F:POQ]LINAMT
        If [F:POH]POHTYP=1
          Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
        Else
          Filter [POP] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First
          Filter [POP]
        Endif
        If fstat
          Raz [F:POP]
        Elsif WPVVFLG & WPVFFLG
          #----- Pour toutes les commandes -----#
          Gosub MAJ_CALTAX_LIG    : # Calcul bases et taxes ligne
          #----- Si commande classique -----#
          If [F:POH]POHTYP=1
            Gosub MAJ_BASTAX_LIG  : # Màj bases et taxes pied à partir des lignes
            Gosub MAJ_ELEMENTS    : # Répartition éléments pied sur ligne et maj bases et taxes
          Endif
          #-----
        Endif
        #----- Total TTC lignes -----#
        [F:POH]TOTLINATI+=[F:POQ]LINATI
      Endif
      #----- Mise à jour type d'engagement (HT/HTND/TTC) -----#
      If [F:POQ]CMMTAX=0  [F:POQ]CMMTAX=1 : Endif
      #----- Mise à jour indicateur d'engagement (0=inactif, 1=actif) -----#
      If [F:POQ]CMMNUM<>"" & [F:POQ]LINCLEFLG<>2
        [F:POQ]CMMFLG=1
      Else
        [F:POQ]CMMFLG=0
      Endif
      #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
      If dim([F:POQ]MFGITM)>0    & [F:POQ]ITMREFORI="" [F:POQ]ITMREFORI=[F:POQ]MFGITM    : Endif
      If dim([F:POQ]MFGNUM)>0    & [F:POQ]VCRNUMORI="" [F:POQ]VCRNUMORI=[F:POQ]MFGNUM    : Endif
      If dim([F:POQ]OPENUM)>0    & [F:POQ]VCRLINORI=0  [F:POQ]VCRLINORI=[F:POQ]OPENUM    : Endif
      If dim([F:POQ]OPESPLNUM)>0 & [F:POQ]VCRSEQORI=0  [F:POQ]VCRSEQORI=[F:POQ]OPESPLNUM : Endif
      If [F:POQ]VCRNUMORI<>""    & [F:POQ]VCRTYPORI=0  [F:POQ]VCRTYPORI=10               : Endif
      #-----
      COMPTEUR+=1
      Rewrite [POQ]
      If fstat
        Call ECR_TRACE("File PORDERQ"-[F:POH]POHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----- Création lignes comptables analytiques pour commandes classiques -----#
      If [F:POH]POHTYP=1 & dim([F:POQ]LINACC)>0 & dim([F:POQ]LINCNA)>0
        Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
        If fstat
          Raz [F:POP]
        Else 
          Look [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
          If fstat
            Raz [F:CAL]
            [F:CAL]ABRFIC="POP"
            [F:CAL]VCRNUM=[F:POP]POHNUM
            [F:CAL]VCRLIN=[F:POP]POPLIN
            [F:CAL]VCRSEQ=[F:POP]POPSEQ
            [F:CAL]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:CAL]LED(I-1)=GLEDSOC(I)
              [F:CAL]COA(I-1)=GCOA(I)
            Next I
            [F:CAL]ACC(0)=[F:POQ]LINACC
            [F:CAL]ACC(1)=[F:POQ]LINCNA
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:CAL]DIE(I-1)=GDIE(I)
              If evalue("dim([F:POP]CCE"+num$(I)+")")>0
                [F:CAL]CCE(I-1)=evalue("[F:POP]CCE"+num$(I))
              Endif
            Next I
            COMPTEUR+=1
            Write [CAL]
            If fstat
              Call ECR_TRACE("File CPTANALIN POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)
&                            +", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    #----- Pour commande classique uniquement -----#
    If [F:POH]POHTYP=1 & WPVVFLG & WPVFFLG
      [F:POH]TOTORD=[F:POH]TOTLINAMT
      #----- Calcul taxes des éléments de facturation en pied -----#
      For I=0 To [L]NBFAC-1
        [F:POH]TOTORD+=[L]INVLINAMT(I)
        If [L]INVDTAVAT(I)<>""
          #-----
          Raz TAXE : TAXE(1)=[L]INVDTAVAT(I)
          Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                      [L]INVLINAMT(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [L]DTAAMTTAX(I)=MONTANT(1)
          [L]DTADEDTAX(I)=MONTDED(1)
          #----- Recherche si taxe déja existante -----# 
          J=find([L]INVDTAVAT(I),[L]TAX(0..[L]NBTAX-1))
          If J<>0 & [L]PURTYP(J-1)<>1
            K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
            If K<>0
              J+=K
              If [L]PURTYP(J-1)<>1
                K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
                If K<>0 J+=K Else J=0 : Endif
              Endif
            Else
              J=0
            Endif
          Endif
          #----- Nouvelle taxe -----# 
          If J=0
            #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
            If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT0 : Endif
            #-----
            J=[L]NBTAX
            [L]NBTAX+=1  
            [L]TAX   (J)=[L]INVDTAVAT(I)
            [L]PURTYP(J)=1
            If [F:TVT]VAT<>[L]INVDTAVAT(I)
              Read [TVT] TVT0=[L]INVDTAVAT(I) : If fstat  Raz [F:TVT] : Endif
            Endif
            [L]VATTYP(J)=[F:TVT]VATTYP
          Else
            J-=1
          Endif
          #----- Mise à jour de la base et des montants de taxe -----#
          [L]BASTAX(J)+=[L]INVLINAMT(I)
          [L]AMTTAX(J)+=[L]DTAAMTTAX(I)
          [L]DEDTAX(J)+=[L]DTADEDTAX(I)
        Endif
$MAJ_SUIT0
      Next I
      #----- Calcul total taxes -----#
      If [F:POH]VACTYP<>4
        [F:POH]TOTTAXAMT=sum([L]AMTTAX)
      Else
        [F:POH]TOTTAXAMT=0
      Endif
      [F:POH]TTVORD=[F:POH]TOTORD+[F:POH]TOTTAXAMT
      #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
      Raz [F:PVV]
      [F:PVV]VCRTYP=3
      [F:PVV]VCRNUM=[F:POH]POHNUM
      [F:PVV]POHNUM=[F:POH]POHNUM
      [F:PVV]CREDAT=date$
      [F:PVV]CREUSR=GUSER
      For I=0 To [L]NBTAX-1
        [F:PVV]TAX   =[L]TAX(I)
        [F:PVV]BASTAX=[L]BASTAX(I)
        [F:PVV]AMTTAX=[L]AMTTAX(I)
        [F:PVV]DEDTAX=[L]DEDTAX(I)
        [F:PVV]PURTYP=[L]PURTYP(I)
        [F:PVV]VATTYP=[L]VATTYP(I)
        #----- Chargement des taux de taxe -----#
        Filter [TRA] Where CPY=[F:POH]CPY & VAT=[F:PVV]TAX & STRDAT<=[F:POH]ORDDAT
        Read [TRA] TRA0 Last
        If fstat>2
          Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=[F:POH]ORDDAT
          Read [TRA]TRA0 Last
          If fstat>2  Raz [F:TRA] : Endif
        Endif
        [F:PVV]VATRAT=[F:TRA]VATRAT
        [F:PVV]DEDRAT=[F:TRA]DEDRAT
        #-----
        [F:PVV]IND=I+1
        COMPTEUR+=1
        Write [PVV]
        If fstat
          Call ECR_TRACE("File PVCRVAT 3"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Next I
    #----- Juste calcul total taxes lignes pour commandes ouvertes -----#
    Elsif [F:POH]POHTYP=2
      [F:POH]TOTORD=[F:POH]TOTLINAMT
      [F:POH]TTVORD=[F:POH]TOTLINATI
      If [F:POH]VACTYP<>4
        [F:POH]TOTTAXAMT=[F:POH]TTVORD-[F:POH]TOTORD
      Else
        [F:POH]TOTTAXAMT=0
      Endif
      Raz [F:POH]TOTLINAMT, [F:POH]TOTLINATI
    Endif
    #----- Ecriture du tableau des éléments dans la table PVCRFOOT -----#
    If WPVVFLG & WPVFFLG
      Raz [F:PVF]
      If [F:POH]POHTYP=2
        [F:PVF]VCRTYP=5
      Else
        [F:PVF]VCRTYP=3
      Endif
      [F:PVF]VCRNUM=[F:POH]POHNUM
      [F:PVF]POHNUM=[F:POH]POHNUM
      [F:PVF]CREDAT=date$
      [F:PVF]CREUSR=GUSER
      For I=0 To [L]NBFAC-1
        If [F:PFI]PFINUM<>[L]INVDTA(I)
          Read [PFI] PFI0=[L]INVDTA(I)
        Endif
        [F:PVF]INVDTA   =[L]INVDTA(I)
        [F:PVF]INVDTAAMT=[L]INVDTAAMT(I)
        If [F:POH]POHTYP=2
          [F:PVF]INVORDAMT=0
          [F:PVF]INVLINAMT=0
        Elsif [L]INVLINFLG(I)<>6
          [F:PVF]INVORDAMT=[L]INVLINAMT(I)
          [F:PVF]INVLINAMT=0
        Else
          [F:PVF]INVORDAMT=0
          [F:PVF]INVLINAMT=[L]INVLINAMT(I)
        Endif
        [F:PVF]INVCPLAMT=[L]INVCPLAMT(I)
        [F:PVF]INVDTAFLG=1
        [F:PVF]INVLINFLG=[L]INVLINFLG(I)
        [F:PVF]INVORDFLG=[F:PFI]DACORD
        [F:PVF]DEBCDT   =[L]DEBCDT(I)
        [F:PVF]INVDTAVAT=[L]INVDTAVAT(I)
        [F:PVF]DTAAMTTAX=[L]DTAAMTTAX(I)
        [F:PVF]DTADEDTAX=[L]DTADEDTAX(I)
        [F:PVF]AMTCOD   =[F:PFI]AMTCOD
        If [F:PVF]AMTCOD=1
          [F:PVF]AMTCODLIB="%"
          [F:PVF]FORMAT   =func TRTX3FNC.GETFMTREM(1)
        Elsif [F:PVF]INVLINFLG<>6
          [F:PVF]AMTCODLIB=[F:POH]CUR
          [F:PVF]FORMAT   ="NZ:"+[F:TCU]CURFMT1+"[ ]"
        Else
          [F:PVF]AMTCODLIB=""
          [F:PVF]FORMAT   ="NzZ:"+[F:TCU]CURFMT1+"[ ]"
        Endif
        [F:PVF]CLCORD   =[F:PFI]CLCORD
        [F:PVF]CLCBAS   =[F:PFI]CLCBAS
        [F:PVF]IND=I+1
        COMPTEUR+=1
        Write [PVF]
        If fstat
          Call ECR_TRACE("File PVCRFOOT 3"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
        Endif
      Next I
    Endif
    #----- Chargement HT et TTC commande en devise société -----#
    Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&                [F:POH]TOTORD,[F:POH]TOTORDL,[F:POH]CHGCOE,STAT) From TRTDEV
    If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     1-File PORDER"-[F:POH]POHNUM+", Error ="-num$(STAT),1) From GESECRAN
    Endif
    Call COURMNT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,1,
&                [F:POH]TTVORD,[F:POH]TTVORDL,[F:POH]CHGCOE,STAT) From TRTDEV
    If STAT <> 0 Then
      # FGR 12/01/2010 : X3SUIVI61184
      Call ECR_TRACE("     2-File PORDER"-[F:POH]POHNUM+", Error ="-num$(STAT),1) From GESECRAN
    Endif
    #-----
    COMPTEUR+=1
    Rewrite [POH]
    If fstat
      Call ECR_TRACE("File PORDER"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #----- Mise à jour code adresse tiers âyeur sur échéances -----#
    COMPTEUR+=1
    Update [DUD] Where TYP="*PO" & NUM=[F:POH]POHNUM & BPAPAY=""
&                With  BPAPAY=[F:POH]BPAPAY
    If fstat
      Call ECR_TRACE("File GACCDUDATE"-"*PO"-[F:POH]POHNUM+",Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    COMPTEUR+=1
    Update [POP] Where POHNUM=[F:POH]POHNUM With CPY=[F:POH]CPY
    If fstat
      Call ECR_TRACE("File PORDERP"-[F:POH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #----- Particularités pour commandes ouvertes -----#
    If [F:POH]POHTYP=2
      [F:TB0]=[F:POH]
      For [POC] Where POHNUM=[F:POH]POHNUM
        WPOPLIN=[F:POC]POPLIN
        #----- Chargement de la société -----#
        [F:POC]CPY=[F:POH]CPY
        #----- Chargement comptes et type d'achat -----#
        If [F:POC]COA(0)="" & [F:POC]LINACC(0)="" & [F:POC]COA(1)="" & [F:POC]LINACC(1)=""
          [F:TB1]=[F:POH]
          [F:TB1]=[F:POC]
          [F:TB1]LINPURTYP=max([F:POC]LINPURTYP,1)
          #-----
          If dim([F:POQ]LINACC)>0
            Filter [POQ] Where POHNUM=[F:POH]POHNUM & POPLIN=WPOPLIN & (LINACC<>"" | LINCNA<>"")
          Else
            Filter [POQ] Where POHNUM=[F:POH]POHNUM & POPLIN=WPOPLIN
          Endif
          Read [POQ] POQ0 First
          If fstat
            Raz [F:POQ]
          Else
            [F:TB1]=[F:POQ]
          Endif
          Filter [POQ]
          #-----
          If dim([F:POQ]LINACC)>0 & ([F:POQ]LINACC<>"" | [F:POQ]LINCNA<>"")
            Raz TPLAN, TCOMPTE
            TPLAN(1)  =GCOA(1)
            TCOMPTE(1)=[F:POQ]LINACC
            TPLAN(2)  =GCOA(2)
            TCOMPTE(2)=[F:POQ]LINCNA
            TPLAN(3)  =GCOA(3)
            WPURTYP   =max([F:POQ]LINPURTYP,1)
          Else
            #----- Chargement table liée PORDERP pour la pièce auto PORD -----#
            Read [POP] POP0(2)=[F:POH]POHNUM;WPOPLIN
            If fstat
              Raz [F:POP]
            Endif
            [G:POP]currind=1 : [G:POP]currlen=0 : # Réinitialisation clé par défaut
            If [F:POP]POHNUM=""
              [F:POP]=[F:POH]
              [F:POP]=[F:POC]
              If [F:ITM]ITMREF<>[F:POC]ITMREF
                Read [ITM] ITM0=[F:POC]ITMREF : If fstat  Raz [F:ITM] : Endif
              Endif
              For I=0 To dim([F:POP]TSICOD)-1 
                [F:POP]TSICOD(I)=[F:ITM]TSICOD(I) 
              Next I
              Gosub ALIVATCOD
            Endif 
            #----- Chargement table liée CPTANALIN pour la pièce auto PORD -----#
            Raz [F:TB2]
            [F:TB2]ABRFIC="POP"
            [F:TB2]VCRNUM=[F:POH]POHNUM
            [F:TB2]VCRLIN=WPOPLIN
            [F:TB2]VCRSEQ=[F:POP]POPSEQ
            [F:TB2]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:TB2]LED(I-1)=GLEDSOC(I)
              [F:TB2]COA(I-1)=GCOA(I)
              [F:TB2]ACC(I-1)=""
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:TB2]DIE(I-1)=GDIE(I)
              If evalue("dim([F:POP]CCE"+num$(I)+")")>0
                [F:TB2]CCE(I-1)=evalue("[F:POP]CCE"+num$(I))
              Endif
            Next I
            #----- Recherche comptes et type d'achat -----#
            Raz ID1,ID2
            #Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
            #If STAT
            #  Raz TPLAN, TCOMPTE
            #  WPURTYP=1
            #Else
            #  If [F:GAC]COA<>TPLAN(1) | [F:GAC]ACC<>TCOMPTE(1)
            #    Read [GAC] GAC0=TPLAN(1);TCOMPTE(1) : If fstat  Raz [F:GAC] : Endif
            #  Endif
            #  If [F:GAC]VATIPT=5
            #    WPURTYP=3
            #  Elsif [F:GAC]VATIPT=4
            #    WPURTYP=2
            #  Else
            #    WPURTYP=1
            #  Endif
            #Endif
            Raz TPLAN, TCOMPTE : WPURTYP=1
          Endif
          #-----
          Raz [F:POC]COA, [F:POC]LINACC
          For I=1 To 10
            If TPLAN(I)<>""
              J=find(TPLAN(I),GCOA(1..GNBCOA))
              If J
                [F:POC]COA(J-1)   =GCOA(J)
                [F:POC]LINACC(J-1)=TCOMPTE(I)
              Endif
            Endif
          Next I
          [F:POC]LINPURTYP=WPURTYP
        Endif
        #----- Chargement des informations douanières -----#
        If [F:POC]EECICT2=""  [F:POC]EECICT2=[L]WEECICT : Endif : # Incoterm
        If GACTDEB=2
          If [F:POC]EECLOC2=0 [F:POC]EECLOC2=[L]WEECLOC : Endif : # Lieu de transport CEE
          If [F:POC]EECNUM2=""
            If [F:BPR]BPRNUM<>[F:POH]BPSINV
              Read [BPR] BPR0=[F:POH]BPSINV : If fstat  Raz [F:BPR] : Endif
            Endif
            [F:POC]EECNUM2=[F:BPR]EECNUM : # Identification CEE
          Endif
        Endif
        #-----
        COMPTEUR+=1
        Rewrite [POC]
        If fstat
          Call ECR_TRACE("File PORDERC"-[F:POH]POHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
        Endif
        #----- Création lignes comptables analytiques pour commandes ouvertes -----#
        For [POP] POP0 Where POHNUM=[F:POC]POHNUM & POPLIN=[F:POC]POPLIN
          Look [CAL] CAL0="POP";0;[F:POP]POHNUM;[F:POP]POPLIN;[F:POP]POPSEQ;"";1
          If fstat
            Raz [F:CAL]
            [F:CAL]ABRFIC="POP"
            [F:CAL]VCRNUM=[F:POP]POHNUM
            [F:CAL]VCRLIN=[F:POP]POPLIN
            [F:CAL]VCRSEQ=[F:POP]POPSEQ
            [F:CAL]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:CAL]LED(I-1)=GLEDSOC(I)
              [F:CAL]COA(I-1)=GCOA(I)
              [F:CAL]ACC(I-1)=[F:POC]LINACC(I-1)
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:CAL]DIE(I-1)=GDIE(I)
              If evalue("dim([F:POP]CCE"+num$(I)+")")>0
                [F:CAL]CCE(I-1)=evalue("[F:POP]CCE"+num$(I))
              Endif
            Next I
            COMPTEUR+=1
            Write [CAL]
            If fstat
              Call ECR_TRACE("File CPTANALIN POP 0"-[F:POP]POHNUM-num$([F:POP]POPLIN)
&                            +", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Next
      Next
    Endif
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:POH]POHNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_POH : Endif
Close Local File [POH], [POQ], [POP], [POC], [CAL], [BPR], [BPS], [BPA], [ITM], [TVT],
&                [TRA], [TCU], [GAC], [GAU], [GAD], [GAG], [TVC], [TB0], [TB1], [TB2],
&                [TUN], [TCO], [TCH], [ADW], [ADP], [PFI], [PVV], [PVF], [ATY], [DUD],
&                [GCM], [PRS]
Call ECR_TIME("DOSMAJ30 Purchase Order Process 1 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#########################################################################
# MAJ_CALTAX_LIG : S/P de calcul des bases et des taxes    MBT 19/12/07 #
#                     de la ligne de commande                           #
#########################################################################
$MAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1)=[F:POP]VAT(0) : WCLCAMT(1)=[F:POQ]CLCAMT1
    When 2 : TAXE(2)=[F:POP]VAT(1) : WCLCAMT(2)=[F:POQ]CLCAMT2
    When 3 : TAXE(3)=[F:POP]VAT(2) : WCLCAMT(3)=[F:POQ]CLCAMT3
  Endcase
Next I
#-----
Call CALTAXE2(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,3,TAXE,1,[F:POQ]LINAMT,
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:POQ]BASTAXLIN1=[F:POQ]LINAMT
      [F:POQ]AMTTAXLIN1=MONTANT(1)
      [F:POQ]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:POP]VAT(1)=""
        Raz [F:POQ]AMTTAXLIN2, [F:POQ]DEDTAXLIN2
      Else
        [F:POQ]AMTTAXLIN2=MONTANT(2)
        [F:POQ]DEDTAXLIN2=MONTDED(2)
        Read [TVT] TVT0=[F:POP]VAT(1) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:POQ]BASTAXLIN1+=[F:POQ]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:POP]VAT(2)=""
        Raz [F:POQ]AMTTAXLIN3, [F:POQ]DEDTAXLIN3
      Else
        [F:POQ]AMTTAXLIN3=MONTANT(3)
        [F:POQ]DEDTAXLIN3=MONTDED(3)
        Read [TVT] TVT0=[F:POP]VAT(2) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:POQ]BASTAXLIN1+=[F:POQ]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:POH]VACTYP<>4
  [F:POQ]LINATI=[F:POQ]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN1
      When 2 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN2
      When 3 : [F:POQ]LINATI+=[F:POQ]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:POQ]LINATI=[F:POQ]LINAMT
Endif
[F:POQ]LINATIAMT=[F:POQ]LINATI
#----- Si commande ouverte, c'est fini ! -----#
If [F:POH]POHTYP=2  Return : Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
  If evalue("dim([F:POP]DISCRGVAL"+num$(I)+")")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(evalue("[F:POP]DISCRGVAL"+num$(I))*[F:POQ]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=evalue("[F:POP]DISCRGVAL"+num$(I))
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:POQ]LINAMT*evalue("[F:POP]DISCRGVAL"+num$(I))/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:POH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:POP]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:POQ]BASTAXLIN1+=BASE
          [F:POQ]AMTTAXLIN1+=MONTANT(1)
          [F:POQ]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----# 
      J=find(GINVDTALIN(I-1),[L]INVDTA(0..[L]NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If [L]NBFAC>=dim([L]INVDTA)  Goto MAJ_SUIT1 : Endif
        #-----
        J=[L]NBFAC
        [L]NBFAC+=1
        [L]INVDTA   (J)=GINVDTALIN       (I-1)
        [L]INVLINFLG(J)=6
        [L]DEBCDT   (J)=GINCDCR          (I-1)
        [L]INVDTAVAT(J)=[F:POH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      [L]INVLINAMT(J)+=BASE
    Endif
  Endif
$MAJ_SUIT1
Next I
#-----
Return


#########################################################################
# MAJ_BASTAX_LIG : S/P de mise à jour des bases et         MBT 19/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de la ligne de commande                   #
#########################################################################
$MAJ_BASTAX_LIG 
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3
  Case I
    When 1 : WTAX   =[F:POP]VAT(0)     : WBASE  =[F:POQ]BASTAXLIN1
             WAMTTAX=[F:POQ]AMTTAXLIN1 : WDEDTAX=[F:POQ]DEDTAXLIN1
    When 2 : WTAX   =[F:POP]VAT(1)     : WBASE  =[F:POQ]LINAMT
             WAMTTAX=[F:POQ]AMTTAXLIN2 : WDEDTAX=[F:POQ]DEDTAXLIN2
    When 3 : WTAX   =[F:POP]VAT(2)     : WBASE  =[F:POQ]LINAMT
             WAMTTAX=[F:POQ]AMTTAXLIN3 : WDEDTAX=[F:POQ]DEDTAXLIN3
  Endcase
  If WTAX<>""
    If [F:TVT]VAT<>WTAX
      Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
    Endif
    If I>1
      Case [F:TVT]VATBAS
        When 2 : WBASE=[F:POQ]CLCAMT1 : # Base spéciale 1
        When 3 : WBASE=[F:POQ]CLCAMT2 : # Base spéciale 2
      Endcase
    Endif
    #----- Recherche si taxe déja existante -----# 
    J=find(WTAX,[L]TAX(0..[L]NBTAX-1))
    If J<>0 & [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
      K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
      If K<>0
        J+=K
        If [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
          K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----# 
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
      If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT2 : Endif
      #-----
      J=[L]NBTAX
      [L]NBTAX+=1  
      [L]TAX   (J)=WTAX 
      [L]PURTYP(J)=[F:POQ]LINPURTYP
      [L]VATTYP(J)=[F:TVT]VATTYP
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    [L]BASTAX(J)+=WBASE
    [L]AMTTAX(J)+=WAMTTAX
    [L]DEDTAX(J)+=WDEDTAX
  Endif
$MAJ_SUIT2
Next I
Return


###############################################################################
# MAJ_ELEMENTS : S/P de répartition des éléments de facturation  MBT 20/12/07 #
#                  sur les lignes de commande avec màj des bases              #
#                  et calcul des taxes si taxe produit                        #
###############################################################################
$MAJ_ELEMENTS
For I=0 To [L]NBFAC-1
  If [L]INVLINFLG(I)>1 & [L]INVLINFLG<6 & find([L]INVDTA(I),[F:POH]INVDTALIN2(0..8))>0
    J=find([L]INVDTA(I),[F:POH]INVDTALIN2(0..8))
    If WTOTLINAMT<[F:POH]TOTLINAMT
      Raz MTLIG
      Case [L]INVLINFLG
        When 2 : #----- Prorata par quantités -----#
          If [F:POH]TOTLINQTY<>0
            MTLIG=[L]INVLINAMT(I)*WQTYPUU/[F:POH]TOTLINQTY
          Endif
        When 3 : #----- Prorata par montants -----#
          If [F:POH]TOTLINAMT<>0
            MTLIG=[L]INVLINAMT(I)*[F:POQ]LINAMT/[F:POH]TOTLINAMT
          Endif
        When 4 : #----- Prorata par poids -----#
          If [F:POH]TOTLINWEU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYWEU/[F:POH]TOTLINWEU
          Endif
        When 5 : #----- Prorata par volume -----#
          If [F:POH]TOTLINVOU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYVOU/[F:POH]TOTLINVOU
          Endif
      Endcase
      MTLIG=arr(MTLIG,WRND)
    Else
      MTLIG=[L]INVLINAMT(I)-[L]CUMLIG(I)
    Endif
    #----- Chargement du montant réparti sur la ligne de commande -----#
    Assign "[F:POQ]DISCRGAMT"+num$(J) With MTLIG
    [L]CUMLIG(I)+=MTLIG
    #----- Traitement de la taxe du montant réparti si taxe produit -----#
    If [L]INVDTAVAT(I)="" & [F:POP]VAT(0)<>""
      #----- Recherche si taxe déja existante -----# 
      J=find([F:POP]VAT(0),[L]TAX(0..[L]NBTAX-1))
      If J<>0 & [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
        K=find([F:POP]VAT(0),[L]TAX(J..[L]NBTAX-1))
        If K<>0
          J+=K
          If [L]PURTYP(J-1)<>[F:POQ]LINPURTYP
            K=find([F:POP]VAT(0),[L]TAX(J..[L]NBTAX-1))
            If K<>0 J+=K Else J=0 : Endif
          Endif
        Else
          J=0
        Endif
      Endif
      #----- Nouvelle taxe -----# 
      If J=0
        #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
        If [L]NBTAX>=dim([L]TAX)  Goto MAJ_SUIT3 : Endif
        #-----
        J=[L]NBTAX
        [L]NBTAX+=1  
        [L]TAX   (J)=[F:POP]VAT(0)
        [L]PURTYP(J)=[F:POQ]LINPURTYP
        If [F:TVT]VAT<>[F:POP]VAT(0)
          Read [TVT] TVT0=[L]INVDTAVAT(I) : If fstat  Raz [F:TVT] : Endif
        Endif
        [L]VATTYP(J)=[F:TVT]VATTYP
      Else
        J-=1
      Endif
      #-----
      Raz TAXE : TAXE(1)=[F:POP]VAT(0)
      Call CALTAXE(GSOCIETE,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,TAXE,1,
&                  MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
      #----- Mise à jour de la base et des montants de taxe -----#
      [F:POQ]BASTAXLIN1+=MTLIG
      [F:POQ]AMTTAXLIN1+=MONTANT
      [F:POQ]DEDTAXLIN1+=MONTDED
      If [F:POH]VACTYP<>4  [F:POQ]LINATIAMT+=MONTANT : Endif
      [L]BASTAX(J)+=MTLIG
      [L]AMTTAX(J)+=MONTANT
      [L]DEDTAX(J)+=MONTDED
      #-----
    Endif
  Endif
$MAJ_SUIT3
Next I
Return


###################################################################
# Alimentation des nouveaux champs dans les historiques commandes #
# --------------------------------------------------------------- #
# Table UPORDER - Historique entête commande :                    #
#   CPY       Code société                                        #
#   FPUFLG    Indicateur relance livraisons                       #
#   OCNFLG    Indicateur relance ARC                              #
#   BPOADD    Code adresse expéditeur                             #
#   BPONAM    Nom ou raison sociale fournisseur expéditeur        #
#   BPOADDLIG Lignes adresse expéditeur                           #
#   BPOPOSCOD Code postal expéditeur                              #
#   BPOCTY    Ville expéditeur                                    #
#   BPOSAT    Etat expéditeur                                     #
#   BPOCRY    Pays expéditeur                                     #
#   BPOCRYNAM Nom du pays expéditeur                              #
#   BPAPAY    Code adresse fournisseur payé                       #
#   BPAINV    Code adresse fournisseur facturant                  #
#   EECICT    Incoterm                                            #
#   EECLOC    Lieu transport CEE                                  #
#   EECNUM    Identification CEE                                  #
#   DSPWEU    Unité de poids pour répartition                     #
#   DSPVOU     Unité de volume pour répartition                   #
#     Non traité !! TOTLINATI  Total TTC ligne                    #
#     Non traité !! TOTLINAMT  Total HT  ligne                    #
#     Non traité !! TOTLINQTY  Total quantités commandées en UA   #
#     Non traité !! TOTLINWEU  Total poids                        #
#     Non traité !! TOTLINVOU  Total volume                       #
#     Non traité !! TOTTAXAMT  Total des taxes                    #
#   INVDTALIN1 Eléments facturation ligne tarif                   #
#   INVDTAVAT1 Codes taxe éléments facturation ligne tarif        #
#   INVDTALIN2 Eléments facturation répartis sur ligne            #
#   INVDTAVAT2 Codes taxe éléments facturation répartis           #
#   TOTORDL   Total HT devise société                             #
#   TTVORDL   Total TTC devise société                            #
# Table UPORDERQ - Historique lignes quantités commande           #
#   CPY       Code société                                        #
#   BPAINV    Code adresse fournisseur facturant                  #
#   LINPURTYP Type d'achat                                        #
#   LINTYP    Type de ligne                                       #
#   CMMTAX    Indicateur type d'engagement (HT/HTND/TTC)          #
#   CMMFLG    Indicateur engagement                               #
#   QTYWEU    Poids                                               #
#   QTYVOU    Volume                                              #
#   LINATI    Montant TTC ligne (produit sans éléments fact)      #
#   CLCAMT1-3  Bases spéciales 1-3 calcul taxe                    #
#   ITMREFORI Article lancé          (remplace MFGITM)            #
#   VCRTYPORI Type pièce origine                                  #
#   VCRNUMORI No pièce origine       (remplace MFGNUM)            #
#   VCRLINORI Ligne pièce prigine    (remplace OPENUM)            #
#   VCRSEQORI Séquence pièce origine (remplace OPESPLNUM)         #
# Table UPORDERP - Historique lignes prix commande                #
#   CPY       Code société                                        #
# Table UPORDERC - Historique lignes article commande ouverte     #
#   CPY       Code société                                        #
#   COA(10)   Codes plan de compte                                #
#   LINACC(10)Comptes                                             #
#   LINPURTYP Type d'achat                                        #
#   EECICT    Incoterm                                            #
#   EECLOC    Lieu transport CEE                                  #
#   EECNUM    Identification CEE                                  #
# Table CPTANALIN - Lignes comptables analytiques                 #
#   Création d'enregistrements dans cette nouvelle table          #
#   en remplacement des champs comptes et sections                #
#                                                                 #
# Les deux tables suixantes ne sont pas traitées !!               #
#        Table PVCRFOOT  - Eléments de facturation                #
#          Création d'enregistrements dans cette nouvelle table   #
#          en remplacement des champs éléments de facturation     #
#        Table PVCRVAT   - Tableau des taxes                      #
#          Création d'enregistrements dans cette nouvelle table   #
###################################################################
$AV_UOH
Local File =[F:ADS]DOSSIER+".UPORDER"     [UOH]
Local File =[F:ADS]DOSSIER+".UPORDERQ"    [UOQ]
Local File =[F:ADS]DOSSIER+".UPORDERP"    [UOP]
Local File =[F:ADS]DOSSIER+".UPORDERC"    [UOC]
Local File =[F:ADS]DOSSIER+".CPTANALIN"   [CAL]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR]
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
Local File =[F:ADS]DOSSIER+".BPADDRESS"   [BPA]
Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM]
Local File =[F:ADS]DOSSIER+".TABVAT"      [TVT]
Local File =[F:ADS]DOSSIER+".TABRATVAT"   [TRA]
Local File =[F:ADS]DOSSIER+".TABCUR"      [TCU]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
Local File =[F:ADS]DOSSIER+".GAUTACE"     [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"    [GAD]
Local File =[F:ADS]DOSSIER+".GAUTACEF"    [GAG]
Local File =[F:ADS]DOSSIER+".TABVAC"      [TVC]
Local File =[F:ADS]DOSSIER+".PORDER"      [TB0]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [TB1]
Local File =[F:ADS]DOSSIER+".CPTANALIN"   [TB2]
Local File =[F:ADS]DOSSIER+".PORDER"      [POH]
Local File =[F:ADS]DOSSIER+".PORDERP"     [POP]
Local File =[F:ADS]DOSSIER+".PORDERQ"     [POQ]
Local File =[F:ADS]DOSSIER+".TABUNIT"     [TUN]
Local File =[F:ADS]DOSSIER+".TABCOEFF"    [TCO]
Local File =[F:ADS]DOSSIER+".TABCHANGE"   [TCH]
Local File =[F:ADS]DOSSIER+".ADOVAL"      [ADW]
Local File =[F:ADS]DOSSIER+".ADOPAR"      [ADP]
Local File =[F:ADS]DOSSIER+".PFOOTINV"    [PFI]
Local File =[F:ADS]DOSSIER+".PVCRVAT"     [PVV]
Local File =[F:ADS]DOSSIER+".PVCRFOOT"    [PVF]
Local File =[F:ADS]DOSSIER+".ATYPE"       [ATY]
Local File =[F:ADS]DOSSIER+".GACM"        [GCM]
Local File =[F:ADS]DOSSIER+".PRICSTRUCT"  [PRS]
#-----
Local Libelle  WPVVFLG, WPVFFLG
Local Integer  COMPTEUR, STOP, WNBR
Local Char     CLE1(GLONPOH), CRITERE(90)
Local Integer  CLE2
Local Char     WEECICT(GLONADI)
Local Char     TPLAN  (GLONCOA)(1..10)
Local Char     TCOMPTE(GLONGAC)(1..10)
Local Char     ID1(20)(1..1), ID2(20)(1..3), WMSG(80)
Local Integer  STAT, I, J, K, WPOPLIN, WPURTYP, SIGN
Local Libelle  WEECLOC
Local Decimal  WRND, WTOTLINAMT, MTLIG
Local Decimal  WQTYPUU, WQTYWEU, WQTYVOU
#----- Variables locales pour calcul TVA -----#
Local Integer  TYPREG
Local Decimal  BASE, MONTANT(1..3), MONTDED(1..3)
Local Char     TAXE(GLONVAT)(1..3)
Local Decimal  WCLCAMT1, WCLCAMT2, WCLCAMT(1..7)
Local Libelle  WCLCFLG1, WCLCFLG2, WCLCFLG(1..7)
Local Decimal  WBASE, WAMTTAX, WDEDTAX
Local Char     WTAX(GLONVAT)
#----- Tableau des taxes en mémoire (20 maxi) -----#
Local Integer  NBTAX
Local Char     TAX(GLONVAT)(20)
Local Decimal  BASTAX(20)
Local Decimal  AMTTAX(20)
Local Decimal  DEDTAX(20)
Local Libelle  PURTYP(20)
Local Libelle  VATTYP(20)
#----- Tableau des éléments de facturation en mémoire (15 maxi) -----#
Local Integer  NBFAC
Local Integer  INVDTA(15)
Local Decimal  INVDTAAMT(15)
Local Decimal  INVLINAMT(15)
Local Decimal  INVCPLAMT(15)
Local Libelle  INVLINFLG(15)
Local Libelle  DEBCDT(15)
Local Char     INVDTAVAT(GLONVAT)(15)
Local Decimal  DTAAMTTAX(15)
Local Decimal  DTADEDTAX(15)
Local Decimal  CUMLIG(15)
#-----
Raz CLE1, CLE2, STOP, WNBR
Call ECR_TIME("DOSMAJ30 Purchase Order Process 2 : Update UPORDER-Q-P-C") From DOSSUB
$BOUCLE_UOH
If  STOP=1
  CRITERE = 'POHNUM="'+CLE1+'" & REVNUM>'+num$(CLE2)
  STOP = 2
Elsif STOP=2
  CRITERE = 'POHNUM>"'+CLE1+'"'
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
Trbegin [UOH],[UOQ],[UOP],[UOC]
  For [UOH] POH0 Where evalue(CRITERE)
    Raz [F:UOH]TOTLINAMT, [F:UOH]TOTLINQTY, [F:UOH]TOTLINWEU, [F:UOH]TOTLINVOU
    Raz [L]NBTAX,  [L]TAX,       [L]BASTAX,    [L]AMTTAX,    [L]DEDTAX,    [L]PURTYP
    Raz [L]VATTYP
    Raz [L]NBFAC,  [L]INVDTA,    [L]INVDTAAMT, [L]INVLINAMT, [L]INVCPLAMT, [L]INVLINFLG
    Raz [L]DEBCDT, [L]INVDTAVAT, [L]DTAAMTTAX, [L]DTADEDTAX, [L]CUMLIG
    #----- Alimentation société, indicateurs relance sur l'entête de commande -----#
    Call PARAM([F:UOH]POHFCY,"SALDSPWEU",[F:UOH]DSPWEU) From ADOVAL
    Call PARAM([F:UOH]POHFCY,"SALDSPVOU",[F:UOH]DSPVOU) From ADOVAL
    Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:UOH]POHFCY) From TRTX3CPT
    [F:UOH]CPY=GSOCIETE
    If [F:BPS]BPSNUM<>[F:UOH]BPSNUM
      Read [BPS] BPS0=[F:UOH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    [F:UOH]FUPFLG=[F:BPS]FUPFLG
    [F:UOH]OCNFLG=[F:BPS]OCNFLG
    #----- Taxes déjà traitées car présentes dans PVCRVAT ? -----#
    If [F:UOH]POHTYP=2
      Look [PVV] PVV1=5;[F:UOH]POHNUM;1
    Else
      Look [PVV] PVV1=3;[F:UOH]POHNUM;1
    Endif
    If fstat  WPVVFLG=1  Else  WPVVFLG=0 : Endif
    #----- Eléments déjà traités car présents dans PVCRFOOT ? -----#
    If [F:UOH]POHTYP=2
      Look [PVF] PVF1=5;[F:UOH]POHNUM;1
    Else
      Look [PVF] PVF1=3;[F:UOH]POHNUM;1
    Endif
    If fstat  WPVFFLG=1  Else  WPVFFLG=0 : Endif
    #-----
    [L]WEECICT   =[F:BPS]EECICT
    [L]WEECLOC   =[F:BPS]EECLOC
    #----- Alimentation des informations douanières si commande classique -----#
    If [F:UOH]POHTYP<>2
      #----- Alimentation incoterm et lieu de transport CEE -----#
      If [F:UOH]EECICT=""
        [F:UOH]EECICT=[F:BPS]EECICT : # Incoterm
      Endif
      If GACTDEB=2 & [F:UOH]EECLOC=0
        [F:UOH]EECLOC=[F:BPS]EECLOC : # Lieu de transport CEE
      Endif
      #----- Alimentation identification CEE du tiers facturant -----#
      If GACTDEB=2 & [F:UOH]EECNUM=""
        If [F:BPR]BPRNUM<>[F:UOH]BPSINV
          Read [BPR] BPR0=[F:UOH]BPSINV : If fstat  Raz [F:BPR] : Endif
        Endif
        [F:UOH]EECNUM=[F:BPR]EECNUM
      Endif
    Endif
    #-----
    If [F:UOH]BPOADD=""
      #----- Si fournisseur divers, adr.commande = adr.expédition -----#
      If [F:BPS]BPSTYP=3
        [F:UOH]BPOADD      =[F:UOH]BPAADD
        [F:UOH]BPONAM(0)   =[F:UOH]BPRNAM(0)
        [F:UOH]BPONAM(1)   =[F:UOH]BPRNAM(1)
        [F:UOH]BPOADDLIG(0)=[F:UOH]BPAADDLIG(0)
        [F:UOH]BPOADDLIG(1)=[F:UOH]BPAADDLIG(1)
        [F:UOH]BPOADDLIG(2)=[F:UOH]BPAADDLIG(2)
        [F:UOH]BPOPOSCOD   =[F:UOH]POSCOD
        [F:UOH]BPOCTY      =[F:UOH]CTY
        [F:UOH]BPOSAT      =[F:UOH]SAT
        [F:UOH]BPOCRY      =[F:UOH]CRY
        [F:UOH]BPOCRYNAM   =[F:UOH]CRYNAM
      #----- alimentation code adresse expédition -----#
      Else
        [F:UOH]BPOADD=[F:BPS]BPAADD
        If GACTSAD=2 : # Stockage systématique de l'adresse !
          #----- Lecture BPARTNER si nécessaire -----#
          If [F:BPR]BPRNUM<>[F:UOH]BPSNUM
            Read [BPR] BPR0=[F:UOH]BPSNUM
            If fstat Raz [F:BPR] : Endif
          Endif
          #----- Lecture de l'adresse si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:UOH]BPSNUM | [F:BPA]BPAADD<>[F:UOH]BPOADD
            Read [BPA] BPA0=1;[F:UOH]BPSNUM;[F:UOH]BPOADD
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:UOH]BPONAM(0)    = [F:BPR]BPRNAM(0)
          [F:UOH]BPONAM(1)    = [F:BPR]BPRNAM(1)
          [F:UOH]BPOADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:UOH]BPOADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:UOH]BPOADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:UOH]BPOCRY       = [F:BPA]CRY
          [F:UOH]BPOCRYNAM    = [F:BPA]CRYNAM
          [F:UOH]BPOSAT       = [F:BPA]SAT
          [F:UOH]BPOPOSCOD    = [F:BPA]POSCOD
          [F:UOH]BPOCTY       = [F:BPA]CTY
        Endif
      Endif
    Endif
    #----- Alimentation code adresse fournisseur payé -----#
    If [F:BPS]BPRPAY=[F:UOH]BPRPAY
      [F:UOH]BPAPAY=[F:BPS]BPAPAY
    Else
      If [F:BPS]BPSNUM<>[F:UOH]BPRPAY
        Read [BPS] BPS0=[F:UOH]BPRPAY : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:UOH]BPAPAY=[F:BPS]BPAADD
    Endif
    #----- Alimentation code adresse fournisseur facturant -----#
    If [F:BPS]BPSINV=[F:UOH]BPSINV
      [F:UOH]BPAINV=[F:BPS]BPAINV
    Else
      If [F:BPS]BPSNUM<>[F:UOH]BPSINV
        Read [BPS] BPS0=[F:UOH]BPSINV : If fstat  Raz [F:BPS] : Endif
      Endif
      [F:UOH]BPAINV=[F:BPS]BPAADD
    Endif
    #----- Alimentation champs pour le multi-régérenciels comptabilité -----#
    If dim([F:UOH]DIE)>0 & [F:UOH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
        [F:UOH]DIE(I-1)=GDIE(I)
      Next I
    Endif
    #----- Alimentation éléments et taxes ligne tarif -----#
    If [F:BPS]BPSNUM<>[F:UOH]BPSNUM
      Read [BPS] BPS0=[F:UOH]BPSNUM : If fstat  Raz [F:BPS] : Endif
    Endif
    #-----
    Call TYPREM(2,[F:BPS]PLISTC) From TRTPRICE
    #----- Chargement arrondi devise commande -----#
    If [F:TCU]CUR<>[F:UOH]CUR
      Read [TCU] TCU0=[F:UOH]CUR
      If !fstat  WRND=[F:TCU]CURRND  Else  WRND=0.01 : Endif
    Else
      WRND=[F:TCU]CURRND
    Endif
    #-----
    For I=0 To dim([F:UOH]INVDTAVAT1)-1
      If GINVDTALIN(I)<>0 & GNPRNOTFLG(I)=1
        [F:UOH]INVDTALIN1(I)=GINVDTALIN(I)
        If [F:UOH]INVDTAVAT1(I)=""
          Read [PFI] PFI0=GINVDTALIN(I) : If fstat  Raz [F:PFI] : Endif
          If [F:PFI]VATRUL=2
            Read [TVC] TVC0=[F:BPS]VACBPR;[F:PFI]VACITM : If fstat  Raz [F:TVC] : Endif
            [F:UOH]INVDTAVAT1(I)=[F:TVC]VAT
          Endif
        Endif
      Endif
    Next I
    #----- Calcul total des quantités UA, poids, volume -----#
    For [UOQ] POQ0 Where POHNUM   =[F:UOH]POHNUM
&                      & LINREVNUM=[F:UOH]REVNUM
&                      & find(LINTYP,0,1,2,4)<>0
      If [F:ITM]ITMREF<>[F:UOQ]ITMREF
        Read [ITM] ITM0=[F:UOQ]ITMREF : If fstat  Raz [F:ITM] : Endif
      Endif
      #----- Par sécurité, chargement des unités de l'article si nécessaire -----#
      If [F:UOH]DSPWEU=""  [F:UOH]DSPWEU=[F:ITM]WEU : Endif
      If [F:UOH]DSPVOU=""  [F:UOH]DSPVOU=[F:ITM]VOU : Endif
      #-----
      [F:UOQ]QTYWEU=[F:ITM]ITMWEI*[F:UOQ]QTYSTU
      [F:UOQ]QTYVOU=[F:ITM]ITMVOU*[F:UOQ]QTYSTU
      Call CONVERT_QTY([F:ITM]WEU,[F:UOH]DSPWEU,[F:UOQ]QTYWEU) From TRTX3
      Call CONVERT_QTY([F:ITM]VOU,[F:UOH]DSPVOU,[F:UOQ]QTYVOU) From TRTX3
      #----- Cumuls qtés ligne -----#
      If [F:UOQ]WIPSTA<2 & [F:UOQ]LINSTA<>3 & [F:UOH]POHTYP<>2
        [F:UOH]TOTLINQTY+=[F:UOQ]QTYPUU
        [F:UOH]TOTLINWEU+=[F:UOQ]QTYWEU
        [F:UOH]TOTLINVOU+=[F:UOQ]QTYVOU
      Endif
    Next
    #----- Calcul total des montants Ht ligne -----#
    For [UOQ] POQ0 Where POHNUM   =[F:UOH]POHNUM
&                      & LINREVNUM=[F:UOH]REVNUM
&                      & LINTYP<>2
&                      & WIPSTA<2
&                      & LINSTA<>3
      [F:UOH]TOTLINAMT+=[F:UOQ]LINAMT
    Next
    #----- Reprise des éléments existant sur l'entête de commande -----#
    If dim([F:UOH]INVDTA)>0
      Raz K
      For I=0 To dim([F:UOH]INVDTA)-1
        If [F:UOH]INVDTA(I)<>0
          J=[L]NBFAC
          Read [PFI] PFI0=[F:UOH]INVDTA(I) : If fstat  Raz [F:PFI] : Endif
          [L]INVDTA   (J)=[F:UOH]INVDTA(I)
          [L]INVDTAAMT(J)=[F:UOH]INVDTAAMT(I)
          [L]INVCPLAMT(J)=[F:UOH]INVCPLAMT(I)
          If [F:PFI]DACLIN=2
            [L]INVLINFLG(J)=6
          Else
            [L]INVLINFLG(J)=[F:PFI]DSPLIN
          Endif
          [L]DEBCDT   (J)=max(1,[F:PFI]INCDCR)
          SIGN=1-2*([L]DEBCDT(J)-1)
          If [F:UOH]AMTCOD(I)=2  : #----- Montant
            [L]INVLINAMT(J)=[F:UOH]INVDTAAMT(I)*SIGN
          Elsif [F:PFI]CLCBAS<>3 : #----- Pourcentage sur HT
            [L]INVLINAMT(J)=arr([F:UOH]TOTLINAMT*[F:UOH]INVDTAAMT(I)/100,WRND)*SIGN
          Else                   : #----- Pourcentage sur TTC
            [L]INVLINAMT(J)=arr([F:UOH]TTVORD*[F:UOH]INVDTAAMT(I)/100,WRND)*SIGN
          Endif
          If [F:PFI]VATRUL=2
            Read [TVC] TVC0=[F:UOH]VACBPR;[F:PFI]VACITM : If fstat  Raz [F:TVC] : Endif
            [L]INVDTAVAT(J)=[F:TVC]VAT
          Endif
          [L]NBFAC+=1
          If [F:PFI]DSPLIN>1
            [F:UOH]INVDTALIN2(K)=[L]INVDTA   (J)
            [F:UOH]INVDTAVAT2(K)=[L]INVDTAVAT(J)
            K+=1
          Endif
        Endif
      Next I
    Endif
    #-----
    Raz WTOTLINAMT, [F:UOH]TOTLINATI
    For [UOQ] POQ0 Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
      WPOPLIN=[F:UOQ]POPLIN
      #----- Alimentation sté, adresse facturant et expéditeur sur lignes commande -----#
      [F:UOQ]CPY      =[F:UOH]CPY
      [F:UOQ]BPAINV   =[F:UOH]BPAINV
      #----- Alimentation du type d'achat -----#
      If [F:UOQ]LINPURTYP=0  [F:UOQ]LINPURTYP=1 : Endif
      #----- Alimentation du type de ligne -----#
      If [F:UOQ]LINTYP=0  [F:UOQ]LINTYP=1 : Endif
      #----- Alimentation des quantités poids et volume (sauf ligne service) -----#
      If find([F:UOQ]LINTYP,1,2,4)
        If [F:ITM]ITMREF<>[F:UOQ]ITMREF
          Read [ITM] ITM0=[F:UOQ]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        #-----
        [F:UOQ]QTYWEU=[F:ITM]ITMWEI*[F:UOQ]QTYSTU
        [F:UOQ]QTYVOU=[F:ITM]ITMVOU*[F:UOQ]QTYSTU
        Call CONVERT_QTY([F:ITM]WEU,[F:UOH]DSPWEU,[F:UOQ]QTYWEU) From TRTX3
        Call CONVERT_QTY([F:ITM]VOU,[F:UOH]DSPVOU,[F:UOQ]QTYVOU) From TRTX3
      Endif
      #----- Si ce n'est pas un service, qté, poids et volume pour répartition -----#
      If [F:UOQ]LINTYP<>3
        WQTYPUU=[F:UOQ]QTYPUU
        WQTYWEU=[F:UOQ]QTYWEU
        WQTYVOU=[F:UOQ]QTYVOU
      Endif
      #----- Alimentation des bases spéciales 1-3 calcul taxe -----#
      If ([F:UOQ]CLCAMT1<>0 | [F:UOQ]CLCAMT2<>0)
&       & [F:UOQ]CLCAMT3=0
&       & [F:UOQ]CLCAMT4=0
&       & [F:UOQ]CLCAMT5=0
&       & [F:UOQ]CLCAMT6=0
&       & [F:UOQ]CLCAMT7=0
        #----- Lecture ligne commande prix -----#
        If [F:UOH]POHTYP=1
          Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]POPLIN;1
        Else
          # Issue 77323 - 2011-10-21 by VPO : index POP1 doesn't exist
          #Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
          #Read [UOP] POP1 First
          #Filter [UOP]
          Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
&         Order By Key CLE =POPDAT;POPSEQ
          Read [UOP] CLE First
          Filter [UOP]
        Endif
        If fstat  Raz [F:UOP] : Endif
        #-----
        Raz WCLCAMT, WCLCFLG
        WCLCAMT1=[F:POQ]CLCAMT1 : WCLCFLG1=0
        WCLCAMT2=[F:POQ]CLCAMT2 : WCLCFLG2=0
        For I=2 To 3
          Case I
            When 2 : WTAX=[F:UOP]VAT(I-1) : Gosub TRT_BASE
            When 3 : WTAX=[F:UOP]VAT(I-1) : Gosub TRT_BASE
          Endcase
        Next I
        If WCLCFLG1 | WCLCFLG2
          If WCLCFLG1  Raz [F:UOQ]CLCAMT1 : Endif
          If WCLCFLG2  Raz [F:UOQ]CLCAMT2 : Endif
          For I=2 To 3
            If WCLCFLG(I)=1
              Assign "[F:UOQ]CLCAMT"+num$(I) With WCLCAMT(I)
            Endif
          Next I
        Endif
      Endif
      #----- Calcul bases et taxes de la ligne de commande -----#
      If [F:UOQ]LINTYP<>2 & [F:UOQ]WIPSTA<2 & [F:UOQ]LINSTA<>3
        WTOTLINAMT+=[F:UOQ]LINAMT
        If [F:UOH]POHTYP=1
          Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]POPLIN;1
        Else
          # Issue 77323 - 2011-10-21 by VPO : index POP1 doesn't exist
          #Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
          #Read [UOP] POP1 First
          #Filter [UOP]
          Filter [UOP] Where POHNUM=[F:UOQ]POHNUM & POPLIN=[F:UOQ]POPLIN & POPDAT>=[F:UOQ]DEMRCPDAT
&         Order By Key CLE =POPDAT;POPSEQ
          Read [UOP] CLE First
          Filter [UOP]
        Endif
        If fstat
          Raz [F:UOP]
        Elsif WPVVFLG & WPVFFLG
          #----- Pour toutes les commandes -----#
          Gosub HMAJ_CALTAX_LIG   : # Calcul bases et taxes ligne
          #----- Si commande classique -----#
          #If [F:UOH]POHTYP=1
          #  Gosub HMAJ_BASTAX_LIG : # Màj bases et taxes pied à partir des lignes
          #  Gosub HMAJ_ELEMENTS   : # Répartition éléments pied sur ligne et maj bases et taxes
          #Endif
          #-----
        Endif
        [F:UOH]TOTLINATI+=[F:UOQ]LINATI
      Endif
      #----- Mise à jour type d'engagement (HT/HTND/TTC) -----#
      If [F:UOQ]CMMTAX=0  [F:UOQ]CMMTAX=1 : Endif
      #----- Mise à jour indicateur d'engagement (0=inactif, 1=actif) -----#
      If [F:UOQ]CMMNUM<>"" & [F:UOQ]LINCLEFLG<>2
        [F:UOQ]CMMFLG=1
      Else
        [F:UOQ]CMMFLG=0
      Endif
      #----- Alimentation des nouveaux champs sous-traitance à partir des anciens -----#
      If dim([F:UOQ]MFGITM)>0    & [F:UOQ]ITMREFORI="" [F:UOQ]ITMREFORI=[F:UOQ]MFGITM    : Endif
      If dim([F:UOQ]MFGNUM)>0    & [F:UOQ]VCRNUMORI="" [F:UOQ]VCRNUMORI=[F:UOQ]MFGNUM    : Endif
      If dim([F:UOQ]OPENUM)>0    & [F:UOQ]VCRLINORI=0  [F:UOQ]VCRLINORI=[F:UOQ]OPENUM    : Endif
      If dim([F:UOQ]OPESPLNUM)>0 & [F:UOQ]VCRSEQORI=0  [F:UOQ]VCRSEQORI=[F:UOQ]OPESPLNUM : Endif
      If [F:UOQ]VCRNUMORI<>""    & [F:UOQ]VCRTYPORI=0  [F:UOQ]VCRTYPORI=10               : Endif
      COMPTEUR+=1
      Rewrite [UOQ]
      If fstat
        Call ECR_TRACE("File UPORDERQ"-[F:UOH]POHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif
      #----- Création lignes comptables analytiques pour commande classique -----#
      If [F:UOH]POHTYP=1 & dim([UOQ]LINACC)>0 & dim([F:UOQ]LINCNA)>0
        Read [UOP] POP0=[F:UOQ]POHNUM;[F:UOQ]LINREVNUM;[F:UOQ]POPLIN;1
        If fstat
          Raz [F:UOP]
        Else 
          Look [CAL] CAL0="UOP";0;[F:UOP]POHNUM;[F:UOP]POPLIN;[F:UOP]POPSEQ;num$([F:UOP]LINREVNUM);1
          If fstat
            Raz [F:CAL]
            [F:CAL]ABRFIC="UOP"
            [F:CAL]VCRNUM=[F:UOP]POHNUM
            [F:CAL]VCRLIN=[F:UOP]POPLIN
            [F:CAL]VCRSEQ=[F:UOP]POPSEQ
            [F:CAL]CPLCLE=num$([F:UOP]LINREVNUM)
            [F:CAL]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:CAL]LED(I-1)=GLEDSOC(I)
              [F:CAL]COA(I-1)=GCOA(I)
            Next I
            [F:CAL]ACC(0)=[F:UOQ]LINACC
            [F:CAL]ACC(1)=[F:UOQ]LINCNA
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:CAL]DIE(I-1)=GDIE(I)
              If evalue("dim([F:UOP]CCE"+num$(I)+")")>0
                [F:CAL]CCE(I-1)=evalue("[F:UOP]CCE"+num$(I))
              Endif
            Next I
            COMPTEUR+=1
            Write [CAL]
            If fstat
              Call ECR_TRACE("File CPTANALIN UOP 0"-[F:UOP]POHNUM-num$([F:UOP]LINREVNUM)
&                            +", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
#    #----- Pour commande classique uniquement -----#
#    If [F:UOH]POHTYP=1 & WPVVFLG & WPVFFLG
#      [F:UOH]TOTORD=[F:UOH]TOTLINAMT
#      #----- Calcul taxes des éléments de facturation en pied -----#
#      For I=0 To [L]NBFAC-1
#        [F:UOH]TOTORD+=[L]INVLINAMT(I)
#        If [L]INVDTAVAT(I)<>""
#          #-----
#          Raz TAXE : TAXE(1)=INVDTAVAT(I)
#          Call CALTAXE(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,1,TAXE,1,
#&                      INVLINAMT(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#          [L]DTAAMTTAX(I)=MONTANT(1)
#          [L]DTADEDTAX(I)=MONTDED(1)
#          #----- Recherche si taxe déja existante -----# 
#          J=find([L]INVDTAVAT(I),[L]TAX(0..[L]NBTAX-1))
#          If J<>0 & [L]PURTYP(J-1)<>1
#            K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
#            If K<>0
#              J+=K
#              If [L]PURTYP(J-1)<>1
#                K=find([L]INVDTAVAT(I),[L]TAX(J..[L]NBTAX-1))
#                If K<>0 J+=K Else J=0 : Endif
#              Endif
#            Else
#              J=0
#            Endif
#          Endif
#          #----- Nouvelle taxe -----# 
#          If J=0
#            #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
#            If [L]NBTAX>=dim([L]TAX)  Goto HMAJ_SUIT0 : Endif
#            #-----
#            J=[L]NBTAX
#            [L]NBTAX+=1  
#            [L]TAX   (J)=INVDTAVAT(I)
#            [L]PURTYP(J)=1
#            If [F:TVT]VAT<>[L]INVDTAVAT(I)
#              Read [TVT] TVT0=[L]INVDTAVAT(I) : If fstat  Raz [F:TVT] : Endif
#            Endif
#            [L]VATTYP(J)=[F:TVT]VATTYP
#          Else
#            J-=1
#          Endif
#          #----- Mise à jour de la base et des montants de taxe -----#
#          [L]BASTAX(J)+=INVLINAMT(I)
#          [L]AMTTAX(J)+=DTAAMTTAX(I)
#          [L]DEDTAX(J)+=DTADEDTAX(I)
#        Endif
#$HMAJ_SUIT0
#      Next I
#      #----- Calcul total taxes -----#
#      If [F:UOH]VACTYP<>4
#        [F:UOH]TOTTAXAMT=sum([L]AMTTAX)
#      Else
#        [F:UOH]TOTTAXAMT=0
#      Endif
#      [F:UOH]TTVORD=[F:UOH]TOTORD+[F:UOH]TOTTAXAMT
#      #----- Ecriture du tableau des taxes dans la table PVCRVAT -----#
#      Raz [F:PVV]
#      [F:PVV]VCRTYP=3
#      [F:PVV]VCRNUM=[F:UOH]POHNUM
#      [F:PVV]POHNUM=[F:UOH]POHNUM
#      [F:PVV]VCRCPL=[F:UOH]REVNUM
#      [F:PVV]CREDAT=date$
#      [F:PVV]CREUSR=GUSER
#      For I=0 To [L]NBTAX-1
#        [F:PVV]TAX   =[L]TAX(I)
#        [F:PVV]BASTAX=[L]BASTAX(I)
#        [F:PVV]AMTTAX=[L]AMTTAX(I)
#        [F:PVV]DEDTAX=[L]DEDTAX(I)
#        [F:PVV]PURTYP=[L]PURTYP(I)
#        [F:PVV]VATTYP=[L]VATTYP(I)
#        #----- Chargement des taux de taxe -----#
#        Filter [TRA] Where CPY=[F:UOH]CPY & VAT=[F:PVV]TAX & STRDAT<=[F:UOH]ORDDAT
#        Read [TRA] TRA0 Last
#        If fstat>2
#          Filter [TRA] Where CPY="" & VAT=[F:PVV]TAX & STRDAT<=[F:UOH]ORDDAT
#          Read [TRA]TRA0 Last
#          If fstat>2  Raz [F:TRA] : Endif
#        Endif
#        [F:PVV]VATRAT=[F:TRA]VATRAT
#        [F:PVV]DEDRAT=[F:TRA]DEDRAT
#        #-----
#        [F:PVV]IND=I+1
#        COMPTEUR+=1
#        Write [PVV]
#        If fstat
#          Call ECR_TRACE("File PVCRVAT 3"-[F:UOH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#      Next I
#    #----- Juste calcul total taxes lignes pour commandes ouvertes -----#
#    Elsif [F:UOH]POHTYP=2
#      [F:UOH]TOTORD=[F:UOH]TOTLINAMT
#      [F:UOH]TTVORD=[F:UOH]TOTLINATI
#      If [F:UOH]VACTYP<>4
#        [F:UOH]TOTTAXAMT=[F:UOH]TTVORD-[F:UOH]TOTORD
#      Else
#        [F:UOH]TOTTAXAMT=0
#      Endif
#      Raz [F:UOH]TOTLINAMT, [F:UOH]TOTLINATI
#    Endif
#    #----- Ecriture du tableau des éléments dans la table PVCRFOOT -----#
#    If WPVVFLG & WPVFFLG
#      Raz [F:PVF]
#      If [F:UOH]POHTYP=2
#        [F:PVF]VCRTYP=5
#      Else
#        [F:PVF]VCRTYP=3
#      Endif
#      [F:PVF]VCRNUM=[F:UOH]POHNUM
#      [F:PVF]POHNUM=[F:UOH]POHNUM
#      [F:PVF]VCRCPL=[F:UOH]REVNUM
#      [F:PVF]CREDAT=date$
#      [F:PVF]CREUSR=GUSER
#      For I=0 To [L]NBFAC-1
#        If [F:PFI]PFINUM<>[L]INVDTA(I)
#          Read [PFI] PFI0=[L]INVDTA(I)
#        Endif
#        [F:PVF]INVDTA   =[L]INVDTA(I)
#        [F:PVF]INVDTAAMT=[L]INVDTAAMT(I)
#        If [F:UOH]POHTYP=2
#          [F:PVF]INVORDAMT=0
#          [F:PVF]INVLINAMT=0
#        Elsif [L]INVLINFLG(I)<>6
#          [F:PVF]INVORDAMT=[L]INVLINAMT(I)
#          [F:PVF]INVLINAMT=0
#        Else
#          [F:PVF]INVORDAMT=0
#          [F:PVF]INVLINAMT=[L]INVLINAMT(I)
#        Endif
#        [F:PVF]INVCPLAMT=[L]INVCPLAMT(I)
#        [F:PVF]INVDTAFLG=1
#        [F:PVF]INVLINFLG=[L]INVLINFLG(I)
#        [F:PVF]INVORDFLG=[F:PFI]DACORD
#        [F:PVF]DEBCDT   =[L]DEBCDT(I)
#        [F:PVF]INVDTAVAT=[L]INVDTAVAT(I)
#        [F:PVF]DTAAMTTAX=[L]DTAAMTTAX(I)
#        [F:PVF]DTADEDTAX=[L]DTADEDTAX(I)
#        [F:PVF]AMTCOD   =[F:PFI]AMTCOD
#        If [F:PVF]AMTCOD=1
#          [F:PVF]AMTCODLIB="%"
#          [F:PVF]FORMAT   =func TRTX3FNC.GETFMTREM(1)
#        Else
#          [F:PVF]AMTCODLIB=[F:UOH]CUR
#          [F:PVF]FORMAT   ="NZ:"+[F:TCU]CURFMT1+"[ ]"
#        Endif
#        [F:PVF]CLCORD   =[F:PFI]CLCORD
#        [F:PVF]CLCBAS   =[F:PFI]CLCBAS
#        [F:PVF]IND=I+1
#        COMPTEUR+=1
#        Write [PVF]
#        If fstat
#          Call ECR_TRACE("File PVCRFOOT 3"-[F:UOH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#      Next I
#    Endif
    #----- Chargement HT et TTC commande en devise société -----#
    # FGR 12/01/2010 : X3SUIVI61184
    If [F:UOH]CUR<>"" & GLOCALDEV<>""
      Call COURMNT([F:UOH]CUR,GLOCALDEV,GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,1,
&                  [F:UOH]TOTORD,[F:UOH]TOTORDL,[F:UOH]CHGCOE,STAT) From TRTDEV
      Call COURMNT([F:UOH]CUR,GLOCALDEV,GLOCALDEV,[F:UOH]CHGTYP,[F:UOH]ORDDAT,1,
&                  [F:UOH]TTVORD,[F:UOH]TTVORDL,[F:UOH]CHGCOE,STAT) From TRTDEV
    Endif
    #-----
    COMPTEUR+=1
    Rewrite [UOH]
    If fstat
      Call ECR_TRACE("File UPORDER"-[F:UOH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #-----
    COMPTEUR+=1
    Update [UOP] Where POHNUM=[F:UOH]POHNUM With CPY=[F:UOH]CPY
    If fstat
      Call ECR_TRACE("File UPORDERP"-[F:UOH]POHNUM+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    #----- Particularités pour commandes ouvertes -----#
    If [F:UOH]POHTYP=2
      [F:TB0]=[F:UOH]
      For [UOC] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM
        WPOPLIN=[F:UOC]POPLIN
        #----- Chargement de la société -----#
        [F:UOC]CPY=[F:UOH]CPY
        #----- Chargement comptes et type d'achat -----#
        If [F:UOC]COA(0)="" & [F:UOC]LINACC(0)="" & [F:UOC]COA(1)="" & [F:UOC]LINACC(2)=""
          [F:TB1]=[F:UOH]
          [F:TB1]=[F:UOC]
          [F:TB1]LINPURTYP=max([F:UOC]LINPURTYP,1)
          # Issue 74490 - 2011-06-20 by VPO : erreur sur filter REVNUM=[F:UOH]REVNUM au lieu de LINREVNUM=[F:UOH]REVNUM
          If dim([F:UOQ]LINACC)>0
            #Filter [UOQ] Where POHNUM=[F:UOH]POHNUM & REVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN & (LINACC<>"" | LINCNA<>"")
            Filter [UOQ] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN & (LINACC<>"" | LINCNA<>"")
          Else
            #Filter [UOQ] Where POHNUM=[F:UOH]POHNUM & REVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN
            Filter [UOQ] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN
          Endif
          Read [UOQ] POQ0 First
          If fstat
            Raz [F:UOQ]
          Else
            [F:TB1]=[F:UOQ]
          Endif
          Filter [UOQ]
          #----- Recherche comptes et type d'achat -----#
          If dim([F:UOQ]LINACC)>0 & ([F:UOQ]LINACC<>"" | [F:UOQ]LINCNA<>"")
            Raz TPLAN, TCOMPTE
            TPLAN(1)  =GCOA(1)
            TCOMPTE(1)=[F:POQ]LINACC
            TPLAN(2)  =GCOA(2)
            TCOMPTE(2)=[F:POQ]LINCNA
            TPLAN(3)  =GCOA(3)
            WPURTYP   =max([F:POQ]LINPURTYP,1)
          Else
            [F:POH]=[F:UOH]
            #----- Chargement table liée UPORDERP pour la pièce auto PORD -----#
            Filter [UOP] Where POHNUM=[F:UOH]POHNUM & LINREVNUM=[F:UOH]REVNUM & POPLIN=WPOPLIN
            Read [UOP] POP0 First  : If fstat  Raz [F:UOP] : Endif
            Filter [UOP]
            [F:POP]=[F:UOP]
            [F:POQ]=[F:UOQ]
            If [F:UOP]POHNUM=""
              [F:POP]=[F:UOH]
              [F:POP]=[F:UOC]
              [F:POP]=[F:UOQ]
              If [F:ITM]ITMREF<>[F:UOC]ITMREF
                Read [ITM] ITM0=[F:UOC]ITMREF : If fstat  Raz [F:ITM] : Endif
              Endif
              For I=0 To dim([F:POP]TSICOD)-1 
                [F:POP]TSICOD(I)=[F:ITM]TSICOD(I) 
              Next I 
              Gosub ALIVATCOD
            Endif
            #----- Chargement table liée CPTANALIN pour la pièce auto PORD -----#
            Raz [F:TB2]
            [F:TB2]ABRFIC="UOP"
            [F:TB2]VCRNUM=[F:UOH]POHNUM
            [F:TB2]VCRLIN=WPOPLIN
            [F:TB2]VCRSEQ=[F:UOP]POPSEQ
            [F:TB2]CPLCLE=num$([F:UOP]LINREVNUM)
            [F:TB2]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:TB2]LED(I-1)=GLEDSOC(I)
              [F:TB2]COA(I-1)=GCOA(I)
              [F:TB2]ACC(I-1)=""
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:TB2]DIE(I-1)=GDIE(I)
              If evalue("dim([F:UOP]CCE"+num$(I)+")")>0
                [F:TB2]CCE(I-1)=evalue("[F:UOP]CCE"+num$(I))
              Endif
            Next I
            #-----
            Raz ID1,ID2
            #Call COMPTE("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
            #If STAT
            #  Raz TPLAN, TCOMPTE
            #  WPURTYP=1
            #Else
            #  If [F:GAC]COA<>TPLAN(1) | [F:GAC]ACC<>TCOMPTE(1)
            #    Read [GAC] GAC0=TPLAN(1);TCOMPTE(1) : If fstat  Raz [F:GAC] : Endif
            #  Endif
            #  If [F:GAC]VATIPT=5
            #    WPURTYP=3
            #  Elsif [F:GAC]VATIPT=4
            #    WPURTYP=2
            #  Else
            #    WPURTYP=1
            #  Endif
            #Endif
            Raz TPLAN, TCOMPTE : WPURTYP=1
          Endif
          #-----
          Raz [F:UOC]COA, [F:UOC]LINACC
          For I=1 To 10
            If TPLAN(I)<>""
              J=find(TPLAN(I),GCOA(1..GNBCOA))
              If J
                [F:UOC]COA(J-1)   =GCOA(J)
                [F:UOC]LINACC(J-1)=TCOMPTE(I)
              Endif
            Endif
          Next I
          [F:UOC]LINPURTYP=WPURTYP
        Endif
        #----- Chargement des informations douanières -----#
        If [F:UOC]EECICT2=""  [F:UOC]EECICT2=[L]WEECICT : Endif : # Incoterm
        If GACTDEB=2
          If [F:UOC]EECLOC2=0 [F:UOC]EECLOC2=[L]WEECLOC : Endif : # Lieu de transport CEE
          If [F:UOC]EECNUM2=""
            If [F:BPR]BPRNUM<>[F:UOH]BPSINV
              Read [BPR] BPR0=[F:UOH]BPSINV : If fstat  Raz [F:BPR] : Endif
            Endif
            [F:UOC]EECNUM2=[F:BPR]EECNUM : # Identification CEE
          Endif
        Endif
        #-----
        COMPTEUR+=1
        Rewrite [UOC]
        If fstat
          Call ECR_TRACE("File UPORDERC"-[F:UOH]POHNUM-num$(WPOPLIN)+", Error ="-num$(fstat),1) From GESECRAN
        Endif
        #----- Création lignes comptables analytiques pour commandes ouvertes -----#
        For [UOP] POP0 Where POHNUM=[F:UOC]POHNUM & LINREVNUM=[F:UOC]LINREVNUM & POPLIN=[F:UOC]POPLIN
          Look [CAL] CAL0="UOP";0;[F:UOP]POHNUM;[F:UOP]POPLIN;[F:UOP]POPSEQ;num$([F:UOP]LINREVNUM);1
          If fstat
            Raz [F:CAL]
            [F:CAL]ABRFIC="UOP"
            [F:CAL]VCRNUM=[F:UOP]POHNUM
            [F:CAL]VCRLIN=[F:UOP]POPLIN
            [F:CAL]VCRSEQ=[F:UOP]POPSEQ
            [F:CAL]CPLCLE=num$([F:UOP]LINREVNUM)
            [F:CAL]ANALIG=1
            For I=1 To max(GNBCOA,2)
              [F:CAL]LED(I-1)=GLEDSOC(I)
              [F:CAL]COA(I-1)=GCOA(I)
              [F:CAL]ACC(I-1)=[F:UOC]LINACC(I-1)
            Next I
            For I=1 To max(GNBDIE,GOPTCANA)
              [F:CAL]DIE(I-1)=GDIE(I)
              If evalue("dim([F:UOP]CCE"+num$(I)+")")>0
                [F:CAL]CCE(I-1)=evalue("[F:UOP]CCE"+num$(I))
              Endif
            Next I
            COMPTEUR+=1
            Write [CAL]
            If fstat
              Call ECR_TRACE("File CPTANALIN UOP 0"-[F:UOP]POHNUM-num$([F:UOP]LINREVNUM)
&                            +", Error ="-num$(fstat),1) From GESECRAN
            Endif
          Endif
        Next
      Next
    Endif
    #-----
    WNBR+=1
    If COMPTEUR>GMAXUPDTRS  CLE1=[F:UOH]POHNUM : CLE2 =[F:UOH]REVNUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto BOUCLE_UOH : Endif
Close Local File [UOH], [UOQ], [UOP], [UOC], [CAL], [BPR], [BPS], [BPA], [ITM], [TVT],
&                [TRA], [TCU], [GAC], [GAU], [GAD], [GAG], [TVC], [TB0], [TB1], [TB2],
&                [POH], [POP], [POQ], [TUN], [TCO], [TCH], [ADW], [ADP], [PFI], [PVV],
&                [PVF], [ATY], [GCM], [PRS]
Call ECR_TIME("DOSMAJ30 Purchase Order Process 2 : Ended ("+num$(WNBR)+")") From DOSSUB
Return


#########################################################################
# HMAJ_CALTAX_LIG : S/P de calcul des bases et des taxes   MBT 24/12/07 #
#                     de l'historique ligne de commande                 #
#########################################################################
$HMAJ_CALTAX_LIG
#-----
For I=1 To 3
  Case I
    When 1 : TAXE(1) = [F:UOP]VAT(0) : WCLCAMT(1)=[F:UOQ]CLCAMT1
    When 2 : TAXE(2) = [F:UOP]VAT(1) : WCLCAMT(2)=[F:UOQ]CLCAMT2
    When 3 : TAXE(3) = [F:UOP]VAT(2) : WCLCAMT(3)=[F:UOQ]CLCAMT3
  Endcase
Next I
#-----
Call CALTAXE2(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,3,TAXE,1,[F:UOQ]LINAMT,
&             WCLCAMT,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#-----
For I=1 To 3
  Case I
    When 1
      [F:UOQ]BASTAXLIN1=[F:UOQ]LINAMT
      [F:UOQ]AMTTAXLIN1=MONTANT(1)
      [F:UOQ]DEDTAXLIN1=MONTDED(1)
    When 2
      If [F:UOP]VAT(1)=""
        Raz [F:UOQ]AMTTAXLIN2, [F:UOQ]DEDTAXLIN2
      Else
        [F:UOQ]AMTTAXLIN2=MONTANT(2)
        [F:UOQ]DEDTAXLIN2=MONTDED(2)
        Read [TVT] TVT0=[F:UOP]VAT(1) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:UOQ]BASTAXLIN1+=[F:UOQ]AMTTAXLIN2 : Endif
      Endif
    When 3
      If [F:UOP]VAT(2)=""
        Raz [F:UOQ]AMTTAXLIN3, [F:UOQ]DEDTAXLIN3
      Else
        [F:UOQ]AMTTAXLIN3=MONTANT(3)
        [F:UOQ]DEDTAXLIN3=MONTDED(3)
        Read [TVT] TVT0=[F:UOP]VAT(2) : If fstat  Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 [F:UOQ]BASTAXLIN1+=[F:UOQ]AMTTAXLIN3 : Endif
      Endif
  Endcase
Next I
#-----
If [F:UOH]VACTYP<>4
  [F:UOQ]LINATI=[F:UOQ]LINAMT
  For I=1 To 3
    Case I
      When 1 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN1
      When 2 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN2
      When 3 : [F:UOQ]LINATI+=[F:UOQ]AMTTAXLIN3
    Endcase
  Next I
Else
  [F:UOQ]LINATI=[F:UOQ]LINAMT
Endif
[F:UOQ]LINATIAMT=[F:UOQ]LINATI
#----- Si commande ouverte, c'est fini ! -----#
If [F:UOH]POHTYP=2  Return : Endif
#----- Calcul de la taxe des montants remises/frais de la ligne tarif -----#
For I=1 To 9
  If evalue("dim([F:UOP]DISCRGVAL"+num$(I)+")")>0
    If GNPRNOTFLG(I-1)=1 & GINVDTALIN(I-1)<>0
      #----- C'est un montant -----#
      If GDISCRGTYP(I-1)=1
        If GCLCRUL(I-1)=1 : # Par unité
          BASE=arr(evalue("[F:UOP]DISCRGVAL"+num$(I))*[F:UOQ]QTYUOM,WRND)
        Else              : # Par ligne
          BASE=evalue("[F:UOP]DISCRGVAL"+num$(I))
        Endif
      #----- C'est un pourcentage -----#
      Else
        BASE=arr([F:UOQ]LINAMT*evalue("[F:UOP]DISCRGVAL"+num$(I))/100,WRND)
      Endif
      #----- Inversion du montant si minoration -----#
      If GINCDCR(I-1)=2  BASE=-BASE : Endif
      #----- Màj base et mt taxe ligne si taux produit -----#
      If [F:UOH]INVDTAVAT1(I-1)=""
        Raz TAXE : TAXE(1)=[F:UOP]VAT(0)
        If BASE<>0
          Call CALTAXE(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,1,TAXE,1,
&                      BASE,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
          [F:UOQ]BASTAXLIN1+=BASE
          [F:UOQ]AMTTAXLIN1+=MONTANT(1)
          [F:UOQ]DEDTAXLIN1+=MONTDED(1)
        Endif
      Endif
      #----- Recherche si élément déja existant -----# 
      J=find(GINVDTALIN(I-1),[L]INVDTA(0..[L]NBFAC-1))
      If J=0
        #----- Le nombre maximum d'élément est dépassé ! (Impossible en théorie) ------#
        If [L]NBFAC>=dim([L]INVDTA)  Goto HMAJ_SUIT1 : Endif
        #-----
        J=[L]NBFAC
        [L]NBFAC+=1
        [L]INVDTA   (J)=GINVDTALIN       (I-1)
        [L]INVLINFLG(J)=6
        [L]DEBCDT   (J)=GINCDCR          (I-1)
        [L]INVDTAVAT(J)=[F:UOH]INVDTAVAT1(I-1)
      Else
        J-=1
      Endif
      [L]INVLINAMT(J)+=BASE
    Endif
  Endif
$HMAJ_SUIT1
Next I
#-----
Return


#########################################################################
# HMAJ_BASTAX_LIG : S/P de mise à jour des bases et        MBT 24/12/07 #
#                     montants de taxe à partir des                     #
#                     valeurs de l'historique ligne de commande         #
#########################################################################
$HMAJ_BASTAX_LIG 
#----- Mise à jour des bases et des montants de taxe -----#
For I=1 To 3
  Case I
    When 1 : WTAX   =[F:UOP]VAT(0)     : WBASE  =[F:UOQ]BASTAXLIN1
             WAMTTAX=[F:UOQ]AMTTAXLIN1 : WDEDTAX=[F:UOQ]DEDTAXLIN1
    When 2 : WTAX   =[F:UOP]VAT(1)     : WBASE  =[F:UOQ]LINAMT
             WAMTTAX=[F:UOQ]AMTTAXLIN2 : WDEDTAX=[F:UOQ]DEDTAXLIN2
    When 3 : WTAX   =[F:UOP]VAT(2)     : WBASE  =[F:UOQ]LINAMT
             WAMTTAX=[F:UOQ]AMTTAXLIN3 : WDEDTAX=[F:UOQ]DEDTAXLIN3
  Endcase
  If WTAX<>""
    If [F:TVT]VAT<>WTAX
      Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
    Endif
    If I>1
      Case [F:TVT]VATBAS
        When 2 : WBASE=[F:UOQ]CLCAMT1 : # Base spéciale 1
        When 3 : WBASE=[F:UOQ]CLCAMT2 : # Base spéciale 2
      Endcase
    Endif
    #----- Recherche si taxe déja existante -----# 
    J=find(WTAX,[L]TAX(0..[L]NBTAX-1))
    If J<>0 & [L]PURTYP(J-1)<>[F:UOQ]LINPURTYP
      K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
      If K<>0
        J+=K
        If [L]PURTYP(J-1)<>[F:UOQ]LINPURTYP
          K=find(WTAX,[L]TAX(J..[L]NBTAX-1))
          If K<>0 J+=K Else J=0 : Endif
        Endif
      Else
        J=0
      Endif
    Endif
    #----- Nouvelle taxe -----# 
    If J=0
      #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
      If [L]NBTAX>=dim([L]TAX)  Goto HMAJ_SUIT2 : Endif
      #-----
      J=[L]NBTAX
      [L]NBTAX+=1  
      [L]TAX   (J)=WTAX 
      [L]PURTYP(J)=[F:UOQ]LINPURTYP
      [L]VATTYP(J)=[F:TVT]VATTYP
    Else
      J-=1
    Endif
    #----- Mise à jour de la base et des montants de taxe -----#
    [L]BASTAX(J)+=WBASE
    [L]AMTTAX(J)+=WAMTTAX
    [L]DEDTAX(J)+=WDEDTAX
  Endif
$HMAJ_SUIT2
Next I
Return


###############################################################################
# HMAJ_ELEMENTS : S/P de répartition des éléments de facturation MBT 24/12/07 #
#                   sur l'historique lignes de commande avec màj des bases    #
#                   et calcul des taxes si taxe produit                       #
###############################################################################
$HMAJ_ELEMENTS
For I=0 To [L]NBFAC-1
  If [L]INVLINFLG(I)>1 & [L]INVLINFLG<6 & find([L]INVDTA(I),[F:UOH]INVDTALIN2(0..8))>0
    J=find([L]INVDTA(I),[F:UOH]INVDTALIN2(0..8))
    If WTOTLINAMT<[F:UOH]TOTLINAMT
      Raz MTLIG
      Case [L]INVLINFLG
        When 2 : #----- Prorata par quantités -----#
          If [F:UOH]TOTLINQTY<>0
            MTLIG=[L]INVLINAMT(I)*WQTYPUU/[F:UOH]TOTLINQTY
          Endif
        When 3 : #----- Prorata par montants -----#
          If [F:UOH]TOTLINAMT<>0
            MTLIG=[L]INVLINAMT(I)*[F:UOQ]LINAMT/[F:UOH]TOTLINAMT
          Endif
        When 4 : #----- Prorata par poids -----#
          If [F:UOH]TOTLINWEU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYWEU/[F:UOH]TOTLINWEU
          Endif
        When 5 : #----- Prorata par volume -----#
          If [F:UOH]TOTLINVOU<>0
            MTLIG=[L]INVLINAMT(I)*WQTYVOU/[F:UOH]TOTLINVOU
          Endif
      Endcase
      MTLIG=arr(MTLIG,WRND)
    Else
      MTLIG=[L]INVLINAMT(I)-[L]CUMLIG(I)
    Endif
    #----- Chargement du montant réparti sur la ligne de commande -----#
    Assign "[F:UOQ]DISCRGAMT"+num$(J) With MTLIG
    [L]CUMLIG(I)+=MTLIG
    #----- Traitement de la taxe du montant réparti si taxe produit -----#
    If [L]INVDTAVAT(I)="" & [F:UOP]VAT(0)<>""
      #----- Recherche si taxe déja existante -----# 
      J=find([F:UOP]VAT(0),[L]TAX(0..[L]NBTAX-1))
      If J<>0 & [L]PURTYP(J-1)<>[F:UOQ]LINPURTYP
        K=find([F:UOP]VAT(0),[L]TAX(J..[L]NBTAX-1))
        If K<>0
          J+=K
          If [L]PURTYP(J-1)<>[F:UOQ]LINPURTYP
            K=find([F:UOP]VAT(0),[L]TAX(J..[L]NBTAX-1))
            If K<>0 J+=K Else J=0 : Endif
          Endif
        Else
          J=0
        Endif
      Endif
      #----- Nouvelle taxe -----# 
      If J=0
        #----- Le nombre maximum de taxe est dépassé ! (Impossible en théorie) ------#
        If [L]NBTAX>=dim([L]TAX)  Goto HMAJ_SUIT3 : Endif
        #-----
        J=[L]NBTAX
        [L]NBTAX+=1  
        [L]TAX   (J)=[F:UOP]VAT(0)
        [L]PURTYP(J)=[F:UOQ]LINPURTYP
        If [F:TVT]VAT<>[F:UOP]VAT(0)
          Read [TVT] TVT0=[F:UOP]VAT(0) : If fstat  Raz [F:TVT] : Endif
        Endif
        [L]VATTYP(J)=[F:TVT]VATTYP
      Else
        J-=1
      Endif
      #-----
      Raz TAXE : TAXE(1)=[F:UOP]VAT(0)
      Call CALTAXE(GSOCIETE,[F:UOH]ORDDAT,[F:UOH]VACBPR,[F:UOH]CUR,1,TAXE,1,
&                  MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
      #----- Mise à jour de la base et des montants de taxe -----#
      [F:UOQ]BASTAXLIN1+=MTLIG
      [F:UOQ]AMTTAXLIN1+=MONTANT
      [F:UOQ]DEDTAXLIN1+=MONTDED
      If [F:UOH]VACTYP<>4  [F:UOQ]LINATIAMT+=MONTANT : Endif
      [L]BASTAX(J)+=MTLIG
      [L]AMTTAX(J)+=MONTANT
      [L]DEDTAX(J)+=MONTDED
      #-----
    Endif
  Endif
$HMAJ_SUIT3
Next I
Return


#############################################
# Alimentation des codes taxes dans [F:POP] #
#############################################
$ALIVATCOD
Read [TVC] TVC0=[F:BPS]VACBPR;[F:ITM]VACITM(0)
If !fstat  [F:POP]VAT(0)=[F:TVC]VAT : Endif
Read [TVC] TVC0=[F:BPS]VACBPR;[F:ITM]VACITM(1)
If !fstat  [F:POP]VAT(1)=[F:TVC]VAT : Endif
Read [TVC] TVC0=[F:BPS]VACBPR;[F:ITM]VACITM(2)
If !fstat  [F:POP]VAT(2)=[F:TVC]VAT : Endif
Return


##################################
# Traitement des bases spéciales #
##################################
$TRT_BASE
If [F:TVT]VAT<>WTAX
  Read [TVT] TVT0=WTAX : If fstat  Raz [F:TVT] : Endif
Endif
If [F:TVT]VATBAS=2 & WCLCAMT1<>0
  WCLCFLG1=1 : WCLCAMT(I)=WCLCAMT1 : WCLCFLG(I)=1
Endif
If [F:TVT]VATBAS=3 & WCLCAMT2<>0
  WCLCFLG2=1 : WCLCAMT(I)=WCLCAMT2 : WCLCFLG(I)=1
Endif
Return
