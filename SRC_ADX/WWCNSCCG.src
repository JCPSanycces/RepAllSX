#<AdxTL>@(#)%I%
# Supervisor
# Inquiry CCG

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:00"
A_USER  = "ADMIN"
A_STAMP = "20181109081100"
Return

$DEFAUT
Default File [CNG]
Return

$OUVFIC
Local File CNGCPY [CNG]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1000798,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSCCGSTD"
PROGSPE    = "CNSCCGSPE"
CBOITE     = "DCNSCCG"
BOITE      = "FCNSCCG"
NOMMSK(0)  = "CONSCCG1"
ABMSK(0)   = "CCG1"
NOMMSK(1)  = "CONSCCG2"
ABMSK(1)   = "CCG2"
CMEMO      = "ctp"
CNOMMSK    = "CRITCCG"
CABMSK     = "CCCG"
NOMFIC     = "CNGCPY"
ABFIC      = "CNG"
OBJDERLU   = "CNG"
MAGNETO    = 2
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..2), CLEMSK(10)(0..2)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "CNG0"
NBCMP = 3
CLECMP(0) = "CPY"
CLEMSK(0) = "CPY"
CLECMP(1) = "YEA"
CLEMSK(1) = "YEA"
CLECMP(2) = "TIM"
CLEMSK(2) = "TIM"
Return

$OUVRE
If clalev([F:CNG])=0 : Local File CNGCPY       [CNG] : Endif
If clalev([F:ID])=0 : Local File EMPLOID      [ID] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR     [HRCTR] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY       [CNG] : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET     [HRPEOD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:TIM])=0 : Local File TIMCOD       [TIM] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CCCG]
 When  0 : Local Mask =NOMMSK(0) [CCG1]
 When  1 : Local Mask =NOMMSK(1) [CCG2]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CCCG]
 When  0 : Grizo [CCG1]
 When  1 : Grizo [CCG2]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CCCG]CPY)>0 : Grizo [CCCG]CPY : Endif
           If dim([M:CCCG]TIM)>0 : Grizo [CCCG]TIM : Endif
 When  0 : If dim([M:CCG1]CPY)>0 : Grizo [CCG1]CPY : Endif
           If dim([M:CCG1]YEA)>0 : Grizo [CCG1]YEA : Endif
           If dim([M:CCG1]TIM)>0 : Grizo [CCG1]TIM : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CCCG]TIM)>0
 Grizo [CCCG]TIM
Endif
If dim([M:CCCG]DATPYR)>0
 Grizo [CCCG]DATPYR
Endif
If dim([M:CCCG]CPY)>0
 Grizo [CCCG]CPY
Endif
If dim([M:CCCG]FCY)>0
 Grizo [CCCG]FCY
Endif
If dim([M:CCCG]SRV)>0
 Grizo [CCCG]SRV
Endif
If dim([M:CCCG]POP)>0
 Grizo [CCCG]POP
Endif
If dim([M:CCCG]REFSTR)>0
 Grizo [CCCG]REFSTR
Endif
If dim([M:CCCG]REFEND)>0
 Grizo [CCCG]REFEND
Endif
If dim([M:CCCG]LEG)>0
 Grizo [CCCG]LEG
Endif
If dim([M:CCCG]PERCOD)>0
 Grizo [CCCG]PERCOD
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CCCG])>0 : Close Local Mask [CCCG] : Endif
 When  0 : If clalev([M:CCG1])>0 : Close Local Mask [CCG1] : Endif
 When  1 : If clalev([M:CCG2])>0 : Close Local Mask [CCG2] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CCCG]
 When  0 : Default Mask [CCG1]
 When  1 : Default Mask [CCG2]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CCCG]
 When  0 : Raz [M:CCG1]
 When  1 : Raz [M:CCG2]
Endcase
Return

$CRITENT
If dim([M:CCCG]TIM)>0 & dim([M:CCG1]TIM)>0
 [M:CCCG]TIM = [M:CCG1]TIM
Endif
If dim([M:CCCG]DATPYR)>0 & dim([M:CCG1]DATPYR)>0
 [M:CCCG]DATPYR = [M:CCG1]DATPYR
Endif
If dim([M:CCCG]CPY)>0 & dim([M:CCG1]CPY)>0
 [M:CCCG]CPY = [M:CCG1]CPY
Endif
If dim([M:CCCG]FCY)>0 & dim([M:CCG1]FCY)>0
 [M:CCCG]FCY = [M:CCG1]FCY
Endif
If dim([M:CCCG]SRV)>0 & dim([M:CCG1]SRV)>0
 [M:CCCG]SRV = [M:CCG1]SRV
Endif
If dim([M:CCCG]POP)>0 & dim([M:CCG1]POP)>0
 [M:CCCG]POP = [M:CCG1]POP
Endif
If dim([M:CCCG]REFSTR)>0 & dim([M:CCG1]REFSTR)>0
 [M:CCCG]REFSTR = [M:CCG1]REFSTR
Endif
If dim([M:CCCG]REFEND)>0 & dim([M:CCG1]REFEND)>0
 [M:CCCG]REFEND = [M:CCG1]REFEND
Endif
If dim([M:CCCG]LEG)>0 & dim([M:CCG1]LEG)>0
 [M:CCCG]LEG = [M:CCG1]LEG
Endif
If dim([M:CCCG]PERCOD)>0 & dim([M:CCG1]PERCOD)>0
 [M:CCCG]PERCOD = [M:CCG1]PERCOD
Endif
Return

$ENTCRIT
If dim([M:CCCG]TIM)>0 & dim([M:CCG1]TIM)>0
[M:CCG1]TIM = [M:CCCG]TIM
Endif
If dim([M:CCCG]DATPYR)>0 & dim([M:CCG1]DATPYR)>0
[M:CCG1]DATPYR = [M:CCCG]DATPYR
Endif
If dim([M:CCCG]CPY)>0 & dim([M:CCG1]CPY)>0
[M:CCG1]CPY = [M:CCCG]CPY
Endif
If dim([M:CCCG]FCY)>0 & dim([M:CCG1]FCY)>0
[M:CCG1]FCY = [M:CCCG]FCY
Endif
If dim([M:CCCG]SRV)>0 & dim([M:CCG1]SRV)>0
[M:CCG1]SRV = [M:CCCG]SRV
Endif
If dim([M:CCCG]POP)>0 & dim([M:CCG1]POP)>0
[M:CCG1]POP = [M:CCCG]POP
Endif
If dim([M:CCCG]REFSTR)>0 & dim([M:CCG1]REFSTR)>0
[M:CCG1]REFSTR = [M:CCCG]REFSTR
Endif
If dim([M:CCCG]REFEND)>0 & dim([M:CCG1]REFEND)>0
[M:CCG1]REFEND = [M:CCCG]REFEND
Endif
If dim([M:CCCG]LEG)>0 & dim([M:CCG1]LEG)>0
[M:CCG1]LEG = [M:CCCG]LEG
Endif
If dim([M:CCCG]PERCOD)>0 & dim([M:CCG1]PERCOD)>0
[M:CCG1]PERCOD = [M:CCCG]PERCOD
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSCCG2"
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


