####################################################################
# Traitments
####################################################################
$_ADDTRT
this.AINF.TRT(1) = "PROJET_CSTD"
this.AINF.TYP(1) = 1
this.AINF.PTH(1) = ""
this.AINF.NBTRT = 1
Return

####################################################################
#Declaration of variables
####################################################################

$DECLARE_VAR
Local Char    ACTION(50) , CURPRO(250) , VALPRO(250) , CURQRY(50) , CURPTH(250)
Local Char    AMETHOD(50) ,AOPERATION(50),AEVENT(50),ARULE(50)
Local Integer ALLSTAT,AISMET,ASTATUS
Return


####################################################################
# Global methods & standards
####################################################################
$AINIT
Gosub DECLARE_VAR
[L]AEVENT = "AINIT" : [L]ACTION = "AINIT" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# AERRORS
####################################################################

$_AERROR
Gosub DECLARE_VAR From WMC0PROJET
Local Integer ALLSTAT
Call ALLERRORS(this,_CTX,_SUPP) From ASYRSUB
For AINDCLA=1 To 10
 If this.COLBPRFIN(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLBPRFIN(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 24
 If this.COLPER(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLPER(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.LOT(AINDCLA)<>null
  [L]ASTATUS = fmet this.LOT(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.FAS(AINDCLA)<>null
  [L]ASTATUS = fmet this.FAS(AINDCLA)._AERROR(_CTX,_SUPP)
 Endif
Next AINDCLA
Return

####################################################################
# Delete all errors
####################################################################

$_ADELERRORS
Gosub DECLARE_VAR From WMC0PROJET
Local Integer ALLSTAT
[L]ASTATUS = fmet this.ADELETEERROR([L]_APARAM)
For AINDCLA=1 To 10
 If this.COLBPRFIN(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLBPRFIN(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 24
 If this.COLPER(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLPER(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.LOT(AINDCLA)<>null
  [L]ASTATUS = fmet this.LOT(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.FAS(AINDCLA)<>null
  [L]ASTATUS = fmet this.FAS(AINDCLA)._ADELERRORS(_APARAM)
 Endif
Next AINDCLA
Return

####################################################################
# _ASEARCHINFOS
####################################################################

$_ASEARCHINFOS
Gosub DECLARE_VAR From WMC0PROJET
ASTATUS= func ASYRSUB.ASEARCHINFOS(this,[L]AINS_ORI,[L]ERR_TYPE,[L]PROPERTY,[L]ASTAT,[L]SELSTAT,[L]PATH)
If [L]ERR_TYPE=[V]CST_ACURRENT : Return : Endif
For AINDCLA=1 To 10
 If this.COLBPRFIN(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLBPRFIN(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'COLBPRFIN('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 24
 If this.COLPER(AINDCLA)<>null
  [L]ASTATUS = fmet this.COLPER(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'COLPER('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.LOT(AINDCLA)<>null
  [L]ASTATUS = fmet this.LOT(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'LOT('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.FAS(AINDCLA)<>null
  [L]ASTATUS = fmet this.FAS(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'FAS('+num$(AINDCLA)+')')
 Endif
Next AINDCLA
Return

####################################################################
# AGETERRORSFROM
####################################################################

$_AGETERRORSFROM
Gosub DECLARE_VAR From WMC0PROJET
If AINS_FROM<>null
 [L]ASTATUS = fmet AINS_FROM.ASEARCHINFOS( [V]CST_ALL, "", [V]CST_AFATAL, 0)
Endif
Call AGETERRORSFROM(AINS_FROM,this,ENVIRONNEMENT) From ASYRSUB
Return

####################################################################
# RICH MEDIA
####################################################################
$AREAD_CLB
Case [L]_PRONAME
 When "DESLNG"
  If fmet this.AGETATTRIBUTE("DESLNG","$isLoaded")<>"true"
   Gosub READ_CLB_DESLNG
  Else
   [L]_CLB = this.DESLNG
  Endif
  If [L]_CNT=''
   [L]ASTATUS = fmet this.ASETATTRIBUTE("DESLNG","$contentType","text/rtf")
   [L]_CNT = "text/rtf"
  Endif
Endcase
Return

$READ_CLB_DESLNG
If this.ACTX.AFOLDER="" | this.ACTX.AFOLDER=nomap
Local File PROJET [WPRJ]
Else
Local File =this.ACTX.AFOLDER+".PROJET" [WPRJ]
Endif
Raz [L]_CLB
Raz [L]_CNT
Gosub DECODE_KEYVAL From ASYRLOB
[F:WPRJ]PRJ = [L]_KEYVALTAB(1)
Read [WPRJ] =
If !fstat
 [L]_CLB = [F:WPRJ]DESLNG
Endif
LogicClose File [WPRJ]
Return

$READ_EXI_DESLNG
If this.ACTX.AFOLDER="" | this.ACTX.AFOLDER=nomap
Local File PROJET [WPRJ]
Else
Local File =this.ACTX.AFOLDER+".PROJET" [WPRJ]
Endif
Local Tinyint _EXI : [L]_EXI=1
[F:WPRJ]PRJ = this.PRJ
Look [WPRJ] =
If fstat
 [L]_EXI=0
Endif
LogicClose File [WPRJ]
Return

####################################################################
$ACONTROL
####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "COLBPRFIN"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"COLBPRFIN",this)
 When "COLPER"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"COLPER",this)
 When "FAS"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"FAS",this)
 When "LOT"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"LOT",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "COLBPRFIN"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"COLBPRFIN","C_PROJET_COLBPRFIN",this)
 When "COLPER"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"COLPER","C_PROJET_COLPER",this)
 When "FAS"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"FAS","C_PRJFAS",this)
 When "LOT"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"LOT","C_PRJLOT",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "COLBPRFIN"
  [L]_ALINE = 10
 When "COLPER"
  [L]_ALINE = 24
 When "FAS"
  [L]_ALINE = 10
 When "LOT"
  [L]_ALINE = 10
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "COLBPRFIN"
  [L]_ALINE = 1
 When "COLPER"
  [L]_ALINE = 1
 When "FAS"
  [L]_ALINE = 1
 When "LOT"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# _ALOAD_KEYS
####################################################################
$_ALOAD_KEYS
this.AKEYS(1) = "PRJ"
Return

####################################################################
# _ADELINSTANCE
####################################################################
$_ADELINSTANCE
[L]ASTATUS = func ASYRSUBTAB._ADELINSTANCE(this)
Return

####################################################################
# ADDINSTANCE_BOUND
####################################################################
$ADDINSTANCE_BOUND
Return



