#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Saisie d'un texte sur consommation SAV                         Module CRM           17 Décembre 2003
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "OK"           : Gosub ONOK
    When "SUP"          : Gosub ONSUP
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GISYNHBDISP

  GISYNHBDISP = 0
  #PARAM(1) : Contexte d'appel de la fenêtre
  #PARAM(2) : GREP
  #PARAM(3) : HDTNUM
  #PARAM(4) : HDTNUMSEQ
  #PARAM(5) : nolign - 1 de la ligne appelante
  If PARAM(1) = "" Then
    #Aucun contexte n'a été communiqué. Accès refusé.
    GMESSAGE = mess(828,182,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  If PARAM(3) = "" Then
    If PARAM(4) = "" Then
      #Aucun identifiant n'a été communiqué. Accès à la saisie des textes refusé.
      GMESSAGE = mess(905,182,1)
      GERR = 1
      FIN = 1
      Return
    Endif
  Endif
Return

##########################################################################################################
$SETBOUT
  ETABOU(GSUPP) = 1
  If [M:SYN8]DIRTY Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
  If [M:SYN8]INVFLG Then
    ETABOU(GSUPP) = 0
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$DEBUT
  Raz [M:SYN8]
  [M:SYN8]CXT = PARAM(1)
  [M:SYN8]SYN8GREP = PARAM(2)
  [M:SYN8]HDTNUM = PARAM(3)
  [M:SYN8]HDTNUMSEQ = PARAM(4)
  [M:SYN8]NOL = val(PARAM(5))
  Gosub SETINVFLG
  Gosub LOADSYN8
  If [M:SYN8]INVFLG Then
    Diszo [M:SYN8]CLOB
  Endif
  Affzo [M:SYN8]1-99
  GISYNHBDISP = 1
Return

##########################################################################################################
$FINSAI
  If GISYNHBDISP Then
    Raz [M:SYN8]
  Endif
  Kill GISYNHBDISP
Return

##########################################################################################################
$APRES_MODIF
  If [M:SYN8]INVFLG = 0 Then
    [M:SYN8]DIRTY = 1
  Endif
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Traitement du bouton OK
#########################################################
$ONOK
Local Integer IFROMOK
Local Char SZHDTSALTEX(GLONTXC)
Local Char SZHDTNUM(GLONVCR)
Local Char SZHDTTEX(250)
Local Char SZTXCCODE(GLONTXC)
Local Integer IERR

  IERR = 0
  SZTXCCODE = ""
  SZHDTSALTEX = ""
  SZHDTNUM = ""
  IFROMOK = 1
  #Suppression
  Gosub ONSUP2
  #Test de création d'un clob
  Setlob SZHDTTEX With [M:SYN8]CLOB
  If len(SZHDTTEX) < 200 Then
    If [M:SYN8]SYN8GREP = "" Then
      Call REMOVECHAR(chr$(13), SZHDTTEX) From CRMUTIL140
      Call REMOVECHAR(chr$(10), SZHDTTEX) From CRMUTIL140
      Case [M:SYN8]CXT
        When "SRE9"
          SZHDTSALTEX = [M:SRE9]HDTSALTEX([M:SYN8]NOL)
          SZHDTNUM = [M:SRE9]HDTNUM([M:SYN8]NOL)
        When "ITN8"
          SZHDTSALTEX = [M:ITN8]HDTSALTEX([M:SYN8]NOL)
          SZHDTNUM = [M:ITN8]HDTNUM([M:SYN8]NOL)
      Endcase
      Call DEBTRANS From GLOCK
      Trbegin [HDT]
      Readlock [HDT]HDT0=SZHDTNUM
      If fstat Then
        #L'enregistrement du texte relatif à la consommation a échoué.
        GMESSAGE = mess(909,182,1)
        GERR = 1
        Rollback
        Return
      Else
        [F:HDT]HDTTEX = SZHDTTEX
        [F:HDT]HDTSALTEX = SZTXCCODE
        Rewrite [HDT]
        If fstat Then
          #L'enregistrement du texte relatif à la consommation a échoué.
          GMESSAGE = mess(909,182,1)
          GERR = 1
          Rollback
          Return
        Else
          Commit
        Endif
      Endif
      Case [M:SYN8]CXT
        When "SRE9"
          Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
          Affzo [M:SRE9]1-99
        When "ITN8"
          Call LOADHDT([M:ITN0]NUM) From SUBITNB2
          Affzo [M:ITN8]1-99
        When Default
      Endcase
    Else
      Case [M:SYN8]CXT
        When "SRE9"
          Setlob [M:SRE9]HDTTEX([M:SYN8]NOL) With [M:SYN8]CLOB
          Call REMOVECHAR(chr$(13), [M:SRE9]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
          Call REMOVECHAR(chr$(10), [M:SRE9]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
          Affzo [M:SRE9]HDTTEX([M:SYN8]NOL)
        When "ITN8"
          Setlob [M:ITN8]HDTTEX([M:SYN8]NOL) With [M:SYN8]CLOB
          Call REMOVECHAR(chr$(13), [M:ITN8]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
          Call REMOVECHAR(chr$(10), [M:ITN8]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
          Affzo [M:ITN8]HDTTEX([M:SYN8]NOL)
        When Default
      Endcase
    Endif
    [M:SYN8]DIRTY = 0
    Return
  Endif
  #Création d'un clob
  If [M:SYN8]SYN8GREP = "" Then
    Setlob SZHDTTEX With [M:SYN8]CLOB
    Call REMOVECHAR(chr$(13), SZHDTTEX) From CRMUTIL140
    Call REMOVECHAR(chr$(10), SZHDTTEX) From CRMUTIL140
    Case [M:SYN8]CXT
      When "SRE9"
        SZHDTSALTEX = [M:SRE9]HDTSALTEX([M:SYN8]NOL)
        SZHDTNUM = [M:SRE9]HDTNUM([M:SYN8]NOL)
      When "ITN8"
        SZHDTSALTEX = [M:ITN8]HDTSALTEX([M:SYN8]NOL)
        SZHDTNUM = [M:ITN8]HDTNUM([M:SYN8]NOL)
    Endcase
    Call DEBTRANS From GLOCK
    Trbegin [TXC], [HDT]
    If SZHDTSALTEX = "" Then
      SZTXCCODE = ""
      Call CPTTXCKEY(SZTXCCODE, IERR) From SUBSREB3
      If IERR Then
        #L'enregistrement du texte relatif à la consommation a échoué.
        GMESSAGE = mess(909,182,1)
        GERR = 1
        Rollback
        Return
      Endif
    Else
      SZTXCCODE = SZHDTSALTEX
      Delete [TXC] Where [F:TXC]CODE = SZHDTSALTEX
      If fstat Then
        #L'enregistrement du texte relatif à la consommation a échoué.
        GMESSAGE = mess(909,182,1)
        GERR = 1
        Rollback
        Return
      Endif
    Endif
    #Ecriture du texte dans TEXCLOB
    Raz [F:TXC]
    [F:TXC]CODE = SZTXCCODE
    [F:TXC]TEXTE = [M:SYN8]CLOB
    [F:TXC]CREUSR = GUSER
    [F:TXC]CREDAT = date$
    Write [TXC]
    If fstat Then
      #L'enregistrement du texte relatif à la consommation a échoué.
      GMESSAGE = mess(909,182,1)
      GERR = 1
      Rollback
      Return
    Endif
    Readlock [HDT]HDT0=SZHDTNUM
    If fstat Then
      #L'enregistrement du texte relatif à la consommation a échoué.
      GMESSAGE = mess(909,182,1)
      GERR = 1
      Rollback
      Return
    Else
      [F:HDT]HDTTEX = SZHDTTEX
      [F:HDT]HDTSALTEX = SZTXCCODE
      Rewrite [HDT]
      If fstat Then
        #L'enregistrement du texte relatif à la consommation a échoué.
        GMESSAGE = mess(909,182,1)
        GERR = 1
        Rollback
        Return
      Else
        Commit
      Endif
    Endif
    Case [M:SYN8]CXT
      When "SRE9"
        Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
        Affzo [M:SRE9]1-99
      When "ITN8"
        Call LOADHDT([M:ITN0]NUM) From SUBITNB2
        Affzo [M:ITN8]1-99
      When Default
    Endcase
  Else
    Call DEBTRANS From GLOCK
    Trbegin [HD7]
    Case [M:SYN8]CXT
      When "SRE9"
        If [M:SRE9]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:SRE9]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Delete [HD7] Where [F:HD7]NUM = [M:SRE9]HDTNUMSEQ([M:SYN8]NOL) and [F:HD7]TYP = "HDTSEQ" and [F:HD7]PRONUM = adxuid(1)
            If fstat Then
              #L'enregistrement du texte relatif à la consommation a échoué.
              GMESSAGE = mess(909,182,1)
              GERR = 1
              Rollback
              Return
            Endif
            Raz [F:HD7]
            [F:HD7]NUM = [M:SRE9]HDTNUMSEQ([M:SYN8]NOL)
            [F:HD7]TYP = "HDTSEQ"
            [F:HD7]PRONUM = adxuid(1)
            [F:HD7]CLOB = [M:SYN8]CLOB
            Write [HD7]
            If fstat Then
              #L'enregistrement du texte relatif à la consommation a échoué.
              GMESSAGE = mess(909,182,1)
              GERR = 1
              Rollback
              Return
            Else
              Commit
            Endif
          Endif
        Else
          Delete [HD7] Where [F:HD7]NUM = [M:SRE9]HDTNUM([M:SYN8]NOL) and [F:HD7]TYP = "HDT" and [F:HD7]PRONUM = adxuid(1)
          If fstat Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Endif
          Raz [F:HD7]
          [F:HD7]NUM = [M:SRE9]HDTNUM([M:SYN8]NOL)
          [F:HD7]TYP = "HDT"
          [F:HD7]PRONUM = adxuid(1)
          [F:HD7]CLOB = [M:SYN8]CLOB
          Write [HD7]
          If fstat Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Commit
          Endif
        Endif
      When "ITN8"
        If [M:ITN8]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:ITN8]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Delete [HD7] Where [F:HD7]NUM = [M:ITN8]HDTNUMSEQ([M:SYN8]NOL) and [F:HD7]TYP = "HDTSEQ" and [F:HD7]PRONUM = adxuid(1)
            If fstat Then
              #L'enregistrement du texte relatif à la consommation a échoué.
              GMESSAGE = mess(909,182,1)
              GERR = 1
              Rollback
              Return
            Endif
            Raz [F:HD7]
            [F:HD7]NUM = [M:ITN8]HDTNUMSEQ([M:SYN8]NOL)
            [F:HD7]TYP = "HDTSEQ"
            [F:HD7]PRONUM = adxuid(1)
            [F:HD7]CLOB = [M:SYN8]CLOB
            Write [HD7]
            If fstat Then
              #L'enregistrement du texte relatif à la consommation a échoué.
              GMESSAGE = mess(909,182,1)
              GERR = 1
              Rollback
              Return
            Else
              Commit
            Endif
          Endif
        Else
          Delete [HD7] Where [F:HD7]NUM = [M:ITN8]HDTNUM([M:SYN8]NOL) and [F:HD7]TYP = "HDT" and [F:HD7]PRONUM = adxuid(1)
          If fstat Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Endif
          Raz [F:HD7]
          [F:HD7]NUM = [M:ITN8]HDTNUM([M:SYN8]NOL)
          [F:HD7]TYP = "HDT"
          [F:HD7]PRONUM = adxuid(1)
          [F:HD7]CLOB = [M:SYN8]CLOB
          Write [HD7]
          If fstat Then
            #L'enregistrement du texte relatif à la consommation a échoué.
            GMESSAGE = mess(909,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Commit
          Endif
        Endif
      When Default
    Endcase
    Case [M:SYN8]CXT
      When "SRE9"
        Setlob [M:SRE9]HDTTEX([M:SYN8]NOL) With [M:SYN8]CLOB
        Call REMOVECHAR(chr$(13), [M:SRE9]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
        Call REMOVECHAR(chr$(10), [M:SRE9]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
        Affzo [M:SRE9]HDTTEX([M:SYN8]NOL)
      When "ITN8"
        Setlob [M:ITN8]HDTTEX([M:SYN8]NOL) With [M:SYN8]CLOB
        Call REMOVECHAR(chr$(13), [M:ITN8]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
        Call REMOVECHAR(chr$(10), [M:ITN8]HDTTEX([M:SYN8]NOL)) From CRMUTIL140
        Affzo [M:ITN8]HDTTEX([M:SYN8]NOL)
      When Default
    Endcase
  Endif
  [M:SYN8]DIRTY = 0
Return

##########################################################################################################
# Bouton Supprimer
#########################################################
$ONSUP
Local Integer IFROMOK
Local Integer IMESSREP

  IFROMOK = 0
  IMESSREP = 0
  #Confirmez-vous la suppression du texte relatif à la consommation ?
  Call OUINON(mess(924,182,1), IMESSREP) From GESECRAN
  If IMESSREP <> 2 Then
    Return
  Endif
  Gosub ONSUP2
Return

##########################################################################################################
$ONSUP2
  If [M:SYN8]SYN8GREP = "" Then
    Call DEBTRANS From GLOCK
    Trbegin [TXC], [HDT]
    Case [M:SYN8]CXT
      When "SRE9"
        If [M:SRE9]HDTNUM([M:SYN8]NOL) = "" Then
          #La suppression du texte relatif à la consommation a échoué.
          GMESSAGE = mess(923,182,1)
          GERR = 1
          Rollback
          Return
        Else
          If [M:SRE9]HDTSALTEX([M:SYN8]NOL) <> "" Then
            Delete [TXC] Where [F:TXC]CODE = [M:SRE9]HDTSALTEX([M:SYN8]NOL)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Read [HDT]HDT0=[M:SRE9]HDTNUM([M:SYN8]NOL)
          If fstat Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Else
            [F:HDT]HDTTEX = ""
            [F:HDT]HDTSALTEX = ""
            Rewrite [HDT]
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Commit
        Endif
        If IFROMOK = 0 Then
          Call LOADHDT([M:SRE0]SRENUM) From SUBSREB1
          Affzo [M:SRE9]1-99
        Endif
      When "ITN8"
        If [M:ITN8]HDTNUM([M:SYN8]NOL) = "" Then
          #La suppression du texte relatif à la consommation a échoué.
          GMESSAGE = mess(923,182,1)
          GERR = 1
          Rollback
          Return
        Else
          If [M:ITN8]HDTSALTEX([M:SYN8]NOL) <> "" Then
            Delete [TXC] Where [F:TXC]CODE = [M:ITN8]HDTSALTEX([M:SYN8]NOL)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Read [HDT]HDT0=[M:ITN8]HDTNUM([M:SYN8]NOL)
          If fstat Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Else
            [F:HDT]HDTTEX = ""
            [F:HDT]HDTSALTEX = ""
            Rewrite [HDT]
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Commit
        Endif
        If IFROMOK = 0 Then
          Call LOADHDT([M:ITN0]NUM) From SUBITNB2
          Affzo [M:ITN8]1-99
        Endif
      When Default
    Endcase
  Else
    Call DEBTRANS From GLOCK
    Trbegin [HD7], [TXC]
    Case [M:SYN8]CXT
      When "SRE9"
        If [M:SRE9]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:SRE9]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Delete [HD7] Where [F:HD7]NUM = [M:SRE9]HDTNUMSEQ([M:SYN8]NOL) and [F:HD7]TYP = "HDTSEQ" and [F:HD7]PRONUM = adxuid(1)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
            If [M:SRE9]HDTSALTEX([M:SYN8]NOL) <> "" Then
              Delete [TXC] Where [F:TXC]CODE = [M:SRE9]HDTSALTEX([M:SYN8]NOL)
              If fstat Then
                #La suppression du texte relatif à la consommation a échoué.
                GMESSAGE = mess(923,182,1)
                GERR = 1
                Rollback
                Return
              Endif
            Endif
            Commit
          Endif
        Else
          Delete [HD7] Where [F:HD7]NUM = [M:SRE9]HDTNUM([M:SYN8]NOL) and [F:HD7]TYP = "HDT" and [F:HD7]PRONUM = adxuid(1)
          If fstat Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Endif
          If [M:SRE9]HDTSALTEX([M:SYN8]NOL) <> "" Then
            Delete [TXC] Where [F:TXC]CODE = [M:SRE9]HDTSALTEX([M:SYN8]NOL)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Commit
        Endif
        If IFROMOK = 0 Then
          [M:SRE9]HDTTEX([M:SYN8]NOL) = ""
          [M:SRE9]HDTSALTEX([M:SYN8]NOL) = ""
          Affzo [M:SRE9]HDTTEX([M:SYN8]NOL)
        Endif
      When "ITN8"
        If [M:ITN8]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:ITN8]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Else
            Delete [HD7] Where [F:HD7]NUM = [M:ITN8]HDTNUMSEQ([M:SYN8]NOL) and [F:HD7]TYP = "HDTSEQ" and [F:HD7]PRONUM = adxuid(1)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
            If [M:ITN8]HDTSALTEX([M:SYN8]NOL) <> "" Then
              Delete [TXC] Where [F:TXC]CODE = [M:ITN8]HDTSALTEX([M:SYN8]NOL)
              If fstat Then
                #La suppression du texte relatif à la consommation a échoué.
                GMESSAGE = mess(923,182,1)
                GERR = 1
                Rollback
                Return
              Endif
            Endif
            Commit
          Endif
        Else
          Delete [HD7] Where [F:HD7]NUM = [M:ITN8]HDTNUM([M:SYN8]NOL) and [F:HD7]TYP = "HDT" and [F:HD7]PRONUM = adxuid(1)
          If fstat Then
            #La suppression du texte relatif à la consommation a échoué.
            GMESSAGE = mess(923,182,1)
            GERR = 1
            Rollback
            Return
          Endif
          If [M:ITN8]HDTSALTEX([M:SYN8]NOL) <> "" Then
            Delete [TXC] Where [F:TXC]CODE = [M:ITN8]HDTSALTEX([M:SYN8]NOL)
            If fstat Then
              #La suppression du texte relatif à la consommation a échoué.
              GMESSAGE = mess(923,182,1)
              GERR = 1
              Rollback
              Return
            Endif
          Endif
          Commit
        Endif
        If IFROMOK = 0 Then
          [M:ITN8]HDTTEX([M:SYN8]NOL) = ""
          [M:ITN8]HDTSALTEX([M:SYN8]NOL) = ""
          Affzo [M:ITN8]HDTTEX([M:SYN8]NOL)
        Endif
      When Default
    Endcase
  Endif
  If IFROMOK = 0 Then
    [M:SYN8]DIRTY = 0
    Raz [M:SYN8]CLOB
    Affzo [M:SYN8]1-99
  Endif
Return

##########################################################################################################
$LOADSYN8
  If [M:SYN8]SYN8GREP = "" Then
    Case [M:SYN8]CXT
      When "SRE9"
        If [M:SRE9]HDTSALTEX([M:SYN8]NOL) = "" Then
          Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
        Else
          Read [TXC]TXC0=[M:SRE9]HDTSALTEX([M:SYN8]NOL)
          If fstat Then
            Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
          Else
            [M:SYN8]CLOB = [F:TXC]TEXTE
          Endif
        Endif
      When "ITN8"
        If [M:ITN8]HDTSALTEX([M:SYN8]NOL) = "" Then
          Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
        Else
          Read [TXC]TXC0=[M:ITN8]HDTSALTEX([M:SYN8]NOL)
          If fstat Then
            Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
          Else
            [M:SYN8]CLOB = [F:TXC]TEXTE
          Endif
        Endif
      When Default
    Endcase
  Else
    Case [M:SYN8]CXT
      When "SRE9"
        If [M:SRE9]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:SRE9]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
          Else
            Read [HD7]HD70=[M:SRE9]HDTNUMSEQ([M:SYN8]NOL);"HDTSEQ";adxuid(1)
            If fstat Then
              If [M:SRE9]HDTSALTEX([M:SYN8]NOL) = "" Then
                Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
              Else
                Read [TXC]TXC0=[M:SRE9]HDTSALTEX([M:SYN8]NOL)
                If fstat Then
                  Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
                Else
                  [M:SYN8]CLOB = [F:TXC]TEXTE
                Endif
              Endif
            Else
              [M:SYN8]CLOB = [F:HD7]CLOB
            Endif
          Endif
        Else
          Read [HD7]HD70=[M:SRE9]HDTNUM([M:SYN8]NOL);"HDT";adxuid(1)
          If fstat Then
            If [M:SRE9]HDTSALTEX([M:SYN8]NOL) = "" Then
              Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
            Else
              Read [TXC]TXC0=[M:SRE9]HDTSALTEX([M:SYN8]NOL)
              If fstat Then
                Setlob [M:SYN8]CLOB With [M:SRE9]HDTTEX([M:SYN8]NOL)
              Else
                [M:SYN8]CLOB = [F:TXC]TEXTE
              Endif
            Endif
          Else
            [M:SYN8]CLOB = [F:HD7]CLOB
          Endif
        Endif
      When "ITN8"
        If [M:ITN8]HDTNUM([M:SYN8]NOL) = "" Then
          If [M:ITN8]HDTNUMSEQ([M:SYN8]NOL) = "" Then
            Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
          Else
            Read [HD7]HD70=[M:ITN8]HDTNUMSEQ([M:SYN8]NOL);"HDTSEQ";adxuid(1)
            If fstat Then
              If [M:ITN8]HDTSALTEX([M:SYN8]NOL) = "" Then
                Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
              Else
                Read [TXC]TXC0=[M:ITN8]HDTSALTEX([M:SYN8]NOL)
                If fstat Then
                  Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
                Else
                  [M:SYN8]CLOB = [F:TXC]TEXTE
                Endif
              Endif
            Else
              [M:SYN8]CLOB = [F:HD7]CLOB
            Endif
          Endif
        Else
          Read [HD7]HD70=[M:ITN8]HDTNUM([M:SYN8]NOL);"HDT";adxuid(1)
          If fstat Then
            If [M:ITN8]HDTSALTEX([M:SYN8]NOL) = "" Then
              Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
            Else
              Read [TXC]TXC0=[M:ITN8]HDTSALTEX([M:SYN8]NOL)
              If fstat Then
                Setlob [M:SYN8]CLOB With [M:ITN8]HDTTEX([M:SYN8]NOL)
              Else
                [M:SYN8]CLOB = [F:TXC]TEXTE
              Endif
            Endif
          Else
            [M:SYN8]CLOB = [F:HD7]CLOB
          Endif
        Endif
      When Default
    Endcase
  Endif
Return

##########################################################################################################
$SETINVFLG
  [M:SYN8]INVFLG = 0
  Case [M:SYN8]CXT
    When "SRE9"
      If [M:SRE2]SREASS = 5 Then
        [M:SYN8]INVFLG = 1
      Else
        [M:SYN8]INVFLG = 0
      Endif
    When "ITN8"
      Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
      If !fstat Then
        If [F:SRE]SREASS = 5 Then
          [M:SYN8]INVFLG = 1
        Else
          [M:SYN8]INVFLG = 0
        Endif
      Endif
    When Default
  Endcase
Return
