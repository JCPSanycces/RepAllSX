#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(30)(1..4) , VALEUR(10)
PARAM(1) = nomap
PARAM(2) = ""
PARAM(3) = "ACOMPOBJ"
PARAM(4) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","ARQTPAR","",3,"") From GTRAITE
End

############################################################
# Saisie des paramètres d'une tâche batch
############################################################

$ACTION
Case ACTION
 When "INIT"      : Gosub INIT
 When "INIT_DIA"  : Gosub INIT_DIA
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
 When "TERMINE"   : FIN = 1
 When "SORTIE"    : Gosub SORTIE
 When Default     : # Actions de GSAISIE
  GPE = 0
  Local Integer K
  If dim([V]GSPEBATCH)>0 & GSPEBATCH<>""
   Call EXISTE_ADX("","",GSPEBATCH,K) From ORDSYS
   If K>0 : Gosub ACTION From =GSPEBATCH : Endif
  Endif
  If !GPE & dim([V]GPROBATCH)>0 & GPROBATCH<>""
   Gosub ACTION From =GPROBATCH
  Endif
Endcase
Return

$INIT
# On définit la boîte de critère à saisir
Local Char    DOSSIER(GLONADS) , TACHE(GLONABT) , GROUPE(GLONABG)
Local Char    BPROG(GLONADC) , SPROG(GLONADC) , USER(GLONAUS)
Local Integer I , J , K , REQUETE
Local Char    ABRECR(GLONABR)(0..15) , FICHIER(GDIMFIC)

DOSSIER = PARAM(1)
If DOSSIER="" : DOSSIER = nomap : Endif
USER    = GUSER
GROUPE  = PARAM(2)
TACHE   = PARAM(3)
REQUETE = val(PARAM(4))
Raz BCRIT , BPROG , SPROG
If clalev([F:ABT])>0 : Close Local File [ABT] : Endif
If clalev([F:AFC])>0 : Close Local File [AFC] : Endif
If clalev([F:ACT])>0 : Close Local File [ACT] : Endif
If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
Local File =DOSSIER+".AFONCTION" [AFC]
Local File =DOSSIER+".ACTION"    [ACT]
If clalev([F:ABT])=0  : Local File ABATTAC  [ABT]  : Endif
If clalev([F:ABR])=0  : Local File ABATRQT  [ABR]  : Endif
If clalev([F:ABR2])=0 : Local File ABATRQT  [ABR2] : Endif
If clalev([F:ABL])=0  : Local File ABATRQTL [ABL]  : Endif
If clalev([F:ABP])=0  : Local File ABATPAR  [ABP]  : Endif
If clalev([F:ABG])=0  : Local File ABATGRP  [ABG]  : Endif
Local Char    SAVPAR(250)(1..dim(PARAM))
For I=1 To dim(PARAM)
 SAVPAR(I) = PARAM(I)
Next I
Read [ABG]ABG0 = GROUPE
If !fstat & TACHE=""
 BCRIT= ""
 FIN = 1
 Return
Endif
Read [ABT]CODTAC = TACHE
If !fstat
 If [F:ABT]FONCTION<>"" : # Nouvelle mode
  Read [AFC]CODINT = [F:ABT]FONCTION
  If !fstat
   If dim([V]GCHGENV)>0
    If dim([F:AFC]DEPENV)>0 & [F:AFC]DEPENV=2 : # Chgt environnement
     GCHGENV=2
    Elsif dim([F:AFC]FCYENV)>0 & [F:AFC]FCYENV=2
     GCHGENV=1
    Else
     GCHGENV=0
    Endif
   Endif
   For I=0 To [F:AFC]NBVAR-1
    If [F:AFC]VALEUR(I)<>"#"
     Assign [F:AFC]VARIA(I) With evalue([F:AFC]VALEUR(I))
    Else
     Assign [F:AFC]VARIA(I) With [F:ABT]PARAM
    Endif
   Next I
   Raz PARAM
   For I=1 To dim([F:AFC]VALPAR)
    If [F:AFC]VALPAR(I-1)<>""
     PARAM(I) = num$(evalue([F:AFC]VALPAR(I-1)))
    Endif
   Next I
   If [F:AFC]ACTION<>""
    Read [ACT]ACTION = [F:AFC]ACTION
    If !fstat
     BCRIT = [F:ACT]PARAM4
     BPROG = [F:ACT]CODTRT
     SPROG = [F:ACT]SPETRT
     Case [F:ACT]PARAM3
      When 3,4 : TYPPRG = [F:ACT]PARAM3
     Endcase
    Endif
   Endif
  Endif
 Endif
Endif
GBATCH = 1
If BCRIT<>"" & (BPROG<>"" | SPROG<>"")
 Call SETMASK(BCRIT,ABRECR)
 ACTION = "OUVRE_BATCH" : Gosub ACTIONB
Else
 ABRECR = ""
 Read [ABR]NUMREQ = REQUETE
 If fstat=0 & !find([F:ABR]FLAG,1,4) : # En attente/bloquée
  FIN = 1
 Endif
Endif
GPROBATCH = BPROG
GSPEBATCH = SPROG
GSTATUT = GSTAOK : # Au cas où pas de paramètres à saisir
Return

$ERR
If errn<>39 : # Etiquette inexistante
 GMESSAGE = errp+"("+num$(errl)+")"-num$(errn)-":"-errmes$(errn)-errm
 Call ERREUR(GMESSAGE) From GESECRAN
 GMESSAGE = ""
Endif
Resume

$ACTIONB
GPE = 0
If dim(SPROG)>0 & SPROG<>""
 Call EXISTE_ADX("","",SPROG,K) From ORDSYS
 If K>0 : Gosub ACTION From =SPROG : Endif
Endif
If !GPE & dim(BPROG)>0 & BPROG<>""
 Gosub ACTION From =BPROG
Endif
Return

Subprog SETMASK(BCRIT,ABRECR)
Value    Char BCRIT
Variable Char ABRECR()
Local Char    TRTCRIT(GLONADC) , TITCRIT(200) , MSKCRIT(GLONAMK)(0..15)
Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRECR,TITCRIT) From GTRAITE
End

$AVANT_PAR
If sum(ABRECR)<>""
 K = 0
 For I=0 To dim(ABRECR)-1
  If ABRECR(I)<>"" & evalue("clalev([M:"+ABRECR(I)+"])")>0
   K = 1 : Break
  Endif
 Next I
 If K
  Gosub LEC_PARAM
  If REQUETE<>0
   GCONSDIA = -1
   If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
   Default File [F:ABL]
   Filter [ABL] Where NUMREQ = [L]REQUETE
   Call GETPAR(ABRECR) From REQUETES
   Filter [F:ABL]
   Default File [F:ABR]
   Read [ABR]NUMREQ = [L]REQUETE
   If fstat=0 & !find([F:ABR]FLAG,1,4) : # En attente/bloquée
    GCONSDIA = 1
   Endif
  Endif
 Endif
Endif
Return

$INIT_DIA
ACTION = "INIT_DIA" : Gosub ACTIONB
Gosub LEC_PARAM
If REQUETE<>0
 GCONSDIA = -1
 If sum(ABRECR)<>""
  If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
  Default File [F:ABL]
  Filter [ABL] Where NUMREQ = [L]REQUETE
  Call GETPAR(ABRECR) From REQUETES
  Filter [F:ABL]
  Default File [F:ABR]
 Endif
 Read [ABR]NUMREQ = REQUETE
 If fstat=0 & !find([F:ABR]FLAG,1,4) : # En attente/bloquée
  GCONSDIA = 1
 Endif
Endif
Return

$SORTIE
GCONSDIA = 0
GBATCH = 0
If dim([V]GCHGENV)>0 : GCHGENV=0 : Endif
If [V]GPRODUIT=1 & dim([L]BATFCY)=1 : [V]GFCY=[L]BATFCY : [V]GDEP=[L]BATDEP : Endif
Return

$LEC_PARAM
# Chargement de la boite
Local Char DOSS(GLONADS), UTIL(GLONAUS)
DOSS = DOSSIER
UTIL = USER
If REQUETE<>0
 Read [ABR]NUMREQ = REQUETE
 If fstat=0
  DOSS = [F:ABR]DOSSIER
  UTIL = [F:ABR]USER
  If [V]GPRODUIT=1 & dim([L]BATFCY)=-1
   Local Char BATFCY([V]GLONFCY), BATDEP([V]GLONDEP)
   #CHECK UNUSED_BEGIN
   [L]BATFCY=[V]GFCY
   [L]BATDEP=[V]GDEP
   [V]GFCY  =[F:ABR]FCY
   [V]GDEP  =[F:ABR]DEP
   #CHECK UNUSED_END
  Endif
 Endif
Endif
Return

$CONTROLE
ACTION = "CONT_BATCH" : Gosub ACTIONB
For I=1 To dim(PARAM)
 PARAM(I) = SAVPAR(I)
Next I
Return

$EXEC
If GSTATUT=GSTAOK
 If REQUETE=0 & [M:ABQ1]JOBMOD=2
  #109897
  Call SETJOB(TACHE,[M:ABQ1]DOSSIER,[M:ABQ1]USER,[M:ABQ1]GRP,TACHE,[M:ABQ1]DAT,[M:ABQ1]HEURE,ABRECR,FICHIER,[M:ABQ1]LAN) From SERVJOB
  If FICHIER=""
   GERR = 1 : GMESSAGE = mess(9,135,1) : # Paramètres incorrects
  Else
   GERR = 2 : GMESSAGE = mess(12,125,1)-"|"+FICHIER : # Création du fichier
  Endif
 Else
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK=1 & REQUETE=0
   GERR = 2 : GMESSAGE = mess(29,134,1)+" ("+num$([F:ABR]NUMREQ)+")" : # Requête transmise au serveur
  Elsif REQUETE<>0
   mkstat = 4 : # Pour réafficher les requêtes
  Endif
 Endif
Endif
Return

$TR1
GOK = 1
Trbegin [ABP] , [ABR]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GLOCK="$ABATPAR" : Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("ABP","") From GLOCK : Goto AB_TR1
 Endif
 If REQUETE<>0
  Readlock [ABR]NUMREQ = REQUETE
  If fstat=1
   GOK=-1 : GLOCK = "$ABATRQT"-num$(REQUETE) : Goto ROLL_TR1
  Elsif fstat
   GOK = 0 : Call RSTA("ABR",num$(REQUETE)) From GLOCK : Goto AB_TR1
  Endif
  If !find([F:ABR]FLAG,1,4) : # En attente/Bloquée
   GERR = 1 : GMESSAGE = mess(22,134,1) : # La requête n'est plus en attente d'exécution
   GOK = 0 : Goto AB_TR1
  Elsif [F:ABR]GRP<>""
   GERR = 1
   For [ABR2]FLAG Where GRP=[F:ABR]GRP & NUMGRP=[F:ABR]NUMGRP
    If [F:ABR2]FLAG=1 : GERR = 0 : Endif : # La première requête du groupe doit être en attente
    Break
   Next ABR2
   If GERR
    GMESSAGE = mess(105,134,1) : # Le groupe n'est plus en attente d'exécution
    GOK = 0 : Goto AB_TR1
   Endif
  Endif
  [F:ABR2] = [F:ABR]
  Delete [ABR] Where NUMREQ=REQUETE
  Delete [ABL] Where NUMREQ=REQUETE
  [F:ABR] = [F:ABR2]
 Else
  Read [ABT]CODTAC = TACHE
  If fstat
   GOK=0 : Call RSTA("ABT",TACHE) From GLOCK : Goto AB_TR1
  Endif
  Raz [F:ABR]
  [F:ABR] = [M:ABQ1]
  [F:ABR] = [F:ABT]
  [F:ABR]TACHE = [F:ABT]CODTAC
  [F:ABR]ETAT  = [F:ABT]TRAIT
  [F:ABR]FLAG  = 1
  [F:ABR]NUMREQ = [F:ABP]NUMREQ
 Endif
 If [V]GPRODUIT=1
  #CHECK UNUSED_BEGIN
  [F:ABR]FCY = [V]GFCY
  [F:ABR]DEP = [V]GDEP
  #CHECK UNUSED_END
 Endif
 Gosub ECRIT_PARAM From REQUETES
 If GOK=0 : Goto AB_TR1 : Endif
 If REQUETE=0
  [F:ABP]NUMREQ += 1
  Rewrite [ABP]
  If fstat
   GOK=0 : Call FSTA("ABP") From GLOCK : Goto AB_TR1
  Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

