#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
## Etiquette ajoutée par le superviseur (Objet MMS) 01/09/2009 16:27:34 (VPO)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "CREATION"  : Gosub TR_CRE
 When "MODIF"     : Gosub TR_MOD
 When "LIENS"     : Gosub LIENS
 When "SEL_LISTE" : Gosub SEL_LISTE
 When Default
Endcase
Return

######################################################################################
$OUVRE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
Return

$RAZCRE
If [M:MMS1]NBVAL=0
nolign = 0
##nolign += 1 : [M:MMS1]CODFIC(nolign-1)="PREQUISD" : [M:MMS1]CODZONE(nolign-1)="PRHFCY" : [M:MMS1]VALDEF(nolign-1)="[M]PSHFCY" : Call AP_CODZONE([M:MMS1]CODZONE(nolign-1))
[M:MMS1]NBVAL  = nolign
Affzo [M:MMS1]
Endif
Return
######################################################################################
$LIENS
# Chargement ecran MMSDEFVAL (tableau)
If dim([M:MMS1]NBVAL) > 0
  Raz [M:MMS1]CODFIC,[M:MMS1]CODZONE,[M:MMS1]VALDEF,[M:MMS1]NBVAL
  nolign = 0
  For [MMV] Where ID=[M:MMS1]ID
     nolign += 1
     [M:MMS1]=[F:MMV]
     Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);[M:MMS1]CODZONE(nolign-1)
     If !fstat
     Call TEXTE([F:ATZ]NOCOURT,[M:MMS1]COM(nolign-1)) From OBJDIV
     Endif
  Next
  [M:MMS1]NBVAL  = nolign
Endif
Return

######################################################################################
$TR_CRE
Goto SUBCREMOD

$TR_MOD
# Mise à jour table MMSDEFVAL
If dim([M:MMS1]NBVAL) > 0
     For [MMV]MMV0 Where ID = [M:MMS1]ID
       Delete [MMV]
    #  Vérifier si un enregistrement est locké : si oui : Fin
       If fstat = 1
          GOK = -1
          Call RSTA("MMV",[M:MMS1]ID) From GLOCK : Break
       Endif
     Next
Endif
If GOK < 0 Goto FINCREMOD Endif

$SUBCREMOD
 For  nolign = 1 To [M:MMS1]NBVAL
   Raz [F:MMV]
   [F:MMV] = [M:MMS1]
   [F:MMV]ID    = [M:MMS1]ID
   If [F:MMV]CREUSR  = ""
      [F:MMV]CREUSR    = GUSER
      [F:MMV]CREDAT    = date$
      Raz [F:MMV]UPDUSR
      Raz [F:MMV]UPDDAT
   Endif
   Write [MMV]
   If fstat
    GOK = 0 : Call FSTA("MMV") From GLOCK : Break
   Endif

 Next nolign

$FINCREMOD
# Retour de la CREATION et de la MODIF
Return


######################################################################################
Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
If [M:MMS1]ABRFIL=""
    Local Integer NB
    Raz [M:MMS1]ABRFIL , [M:MMS1]TABFIL , NB
    For [ATB] Where find(CODFIC,"PREQUIS","PREQUISD","SMVTH","SMVTD")<>0
       [M:MMS1]TABFIL(NB) = [F:ATB]CODFIC
       [M:MMS1]ABRFIL(NB) = [F:ATB]ABRFIC
       NB += 1
    Next
Endif
End

Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
If find(VALEUR,[M:MMS1]TABFIL)=0
    GMESSAGE = mess(83,123,1)
    mkstat = 2
    End
Endif
End

Subprog C_CODZONE(VALEUR)
Variable Char    VALEUR()
If [M:MMS1]CODFIC(nolign-1)<>"" & VALEUR=""
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
Endif
Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);VALEUR
If fstat
    GMESSAGE = mess(23,100,1)
    mkstat = 2
    End
Endif
For I=0 To NBVAL
    If [M:MMS1]CODFIC(nolign-1)+"/"+VALEUR=[M:MMS1]CODFIC(I)+"/"+[M:MMS1]CODZONE(I) & I<>nolign-1
        GMESSAGE = mess(29,100,1)-num$(I+1)
        mkstat = 2
        End
    Endif
Next I
End

Subprog AP_CODZONE(VALEUR)
Variable Char    VALEUR()
 Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);VALEUR
 If !fstat
    Call TEXTE([F:ATZ]NOCOURT,[M:MMS1]COM(nolign-1)) From OBJDIV
 Endif
End

Subprog IB_VALDEF
Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);[M:MMS1]CODZONE(nolign-1)
Case [F:ATZ]CODTYP
When "ADI":
When "M":
When Default:
    If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat | [F:ATY]OBJLIEN=""
        #pas de liste/selection
        Raz GBOUTS
    Endif
Endcase
End

Subprog AV_VALDEF(VALEUR)
Variable Char    VALEUR()
Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);[M:MMS1]CODZONE(nolign-1)
If [F:ATZ]CODTYP="D"
Chgfmt [M:MMS1]VALDEF(nolign-1) With "D:DD[/]MM[/]YYYY"
Else
Chgfmt [M:MMS1]VALDEF(nolign-1) With "K:80X"
Endif
End

Subprog C_VALDEF(VALEUR)
Variable Char    VALEUR()
If [M:MMS1]CODFIC(nolign-1)<>"" & [M:MMS1]CODZONE(nolign-1)<>"" & VALEUR=""
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
Endif
End

######################################################################################
$SEL_LISTE
If COUZON="VALDEF"
   NBTEX = 0
   TIT(0)=[M:MMS1]COM(nolign-1)
   TIT(1)=""
   TIT(2)=""
   Local Char TEXTE(80)(1..200,1..2)
   If clalev([F:AST])=0 : Local File APLSTD [AST] : Endif
   For [AST] Where LANCHP=[F:ATZ]NOLIB & LAN=GLANGUE & LANNUM>0
     NBTEX += 1
     TEX(NBTEX)   = num$([F:AST]LANNUM)
     TEXTE(NBTEX,1) = num$([F:AST]LANNUM)
     TEXTE(NBTEX,2) = [F:AST]LANMES
   Next
Endif
Return

######################################################################################
Subprog S_VALDEF(VALEUR)
Variable Char    VALEUR()
Read [ATZ]CODZONE=[M:MMS1]CODFIC(nolign-1);[M:MMS1]CODZONE(nolign-1)

Local Char    PARMSK(250)(1..20)
Case [F:ATZ]CODTYP
When "ADI":
    PARMSK(1) = left$([F:ATZ]EXPLIEN,instr(1,[F:ATZ]EXPLIEN,";")-1)
    PARMSK(2) = ""
    Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION

When "M":
    SAVACT = GACTION : GACTION = "GSELLIS"
    PARMSK(1) = "VALDEF"
    PARMSK(2) = "SUBMMS"
    Call S_LIS_CHAR(VALEUR,PARMSK,"GSELECT","ASELGEN","") From GACTION
    GACTION = SAVACT

When Default:
    If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat | [F:ATY]OBJLIEN=""
        #pas de liste/selection
        PARMSK(1) = [F:ATZ]CODTYP
    Else
        PARMSK(1) = [F:ATY]OBJLIEN
        PARMSK(2) = "!"
        Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
    Endif
Endcase
End


######################################################################################

