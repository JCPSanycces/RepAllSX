######################################################################################
Subprog IB_ABRFIL
End

# Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFILWRK
 Grizo [M]VOLFILWRK
 Raz [M]VOLFILSTO
 Grizo [M]VOLFILSTO
Else
 Actzo [M]VOLFILWRK
 Actzo [M]VOLFILSTO
Endif
Affzo [M]VOLFILWRK
Affzo [M]VOLFILSTO
End

Subprog C_VOLFILWRK(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End

Subprog C_VOLFILSTO(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTSTO,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 98928 - 2014-07-04 by RBA : Volumes managment evolution
