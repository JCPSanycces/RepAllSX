#<AdxTL>@(#)12.0.0.0 $Revision$
Local File XBUGS [XBG] Where CREDAT > [01/06/2000] & ORIDESTUSR = ""    #CHECK IGNORE_LINE

$TRT

GOK = 1
Call DEBTRANS From GLOCK
Trbegin [XBG]

Readlock [XBG]XBG0 First

If fstat = 1
    GOK = -1
    GLOCK = "XBUGS"
    Goto ROLL_TRT
Elsif fstat
    GOK = 0
    Call RSTA("XBG", "") From GLOCK
    Goto AB_TRT
    End
Endif

While !fstat

    If NBSTAT = 1
        [XBG]ORIDESTUSR = [XBG]DESTUSR
        Rewrite [XBG]
    Elsif NBSTAT > 1
        [XBG]ORIDESTUSR = [XBG]HUSR(1)
        Rewrite [XBG]
    Endif
    
    Readlock [XBG]XBG0 Next

Wend

Commit

End

#######################
$ROLL_TRT

Rollback
Call ROLL From GLOCK
If GROLL
    Commit
    End
Else
    Goto TRT 
Endif
End

#######################
$AB_TRT

Rollback
Commit
End
