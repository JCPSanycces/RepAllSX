Subprog AV_POS(VALEUR)
Variable Decimal  VALEUR
If nolign=1
 VALEUR = 1
Else
 If [M]DESLIN(nolign-1)<>""
  VALEUR = [M]POS(nolign-2) + [M]LNG(nolign-2)
 Endif
Endif
End

Subprog APRES_NBLIG
If !GIMPORT : Affzo TOTLNG, POS : Endif
End

