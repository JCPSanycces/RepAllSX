#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ENTSAL4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:10"
A_USER  = "DOC"
A_STAMP = "20181109230410"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ENTSAL4 [ENT4]
Gosub HORODAT
Local Inpbox "ENTSAL4" From GFONCTION At A_STAMP With A_WINDPREV Mask [ENT4] As [SIM_]
Grizo [ENT4]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ENT4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=88 : Y1(0)=1 : Y2(0)=23
Return

$ON_WAFFMUT
Onevent INIT_AREA Call D_WAFFMUT(zc) From W1ENTSAL4
Return

Subprog D_WAFFMUT(VALEUR)
Variable Char    VALEUR()
If varinit([M]WAFFMUT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10329","") From SUBADI
Endif
Gosub _AFF
End

