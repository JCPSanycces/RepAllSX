End
#######################################################################################
# PROPERTIES                                                                          #
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG properties related calls
# ----------------------- CPY --------------------------------------
$CPY
  Case [L]ARULE
    When "PROPAGATE" : Gosub PROPAGATE_CPY
    When Default     : Return
  Endcase
Return

$PROPAGATE_CPY

  If this.CPY<>""
    Local File COMPANY [CPY]
    Read [F:CPY]CPY0=this.CPY
    If fstat Raz [F:CPY] : Endif
    this.LEG = [F:CPY]LEG
    this.CPYCUR = [F:CPY]ACCCUR
  Endif

Return

# ----------------------- QUOINVTAX --------------------------------------
$QUOINVTAX
  Case [L]ARULE
    When "GET"       : this.QUOINVTAX = this.QUOINVATI - this.QUOINVNOT
    When Default     : Return
  Endcase

Return

