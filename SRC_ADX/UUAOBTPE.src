##################################################################################
 Call OUVRE_TRACE("Test moulinette UUAOBTPE") From LECFIC
 Call PATCH(nomap)
 Call LEC_TRACE From LECFIC
End
#######################################################################
# Pour exÃĐcution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(PAPPLI)
Value Char    PAPPLI

If filinfo(filpath("FIL","AOBJLST","fde",PAPPLI),0)<=0
      End
Else
   Call EXE_UUAOBTPE(PAPPLI)
Endif

End
##################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

 Local Char FICHIER(250)
 FICHIER=filpath("FIL","AOBJLST","fde",APPLI)
 If filinfo(FICHIER,0) < 0
  End
 Endif
  Call EXE_UUAOBTPE(APPLI)
End

End

#------ Suppression des infos de l'onglet DonnÃĐes du dictionnaire des ÃĐtats ------#
Subprog EXE_UUAOBTPE(LDOSSIER)
Value Char LDOSSIER

#----- Variables locales -----#
Local Char     WMSG(80)
Local Integer OK

GOK =1

#-----
Call ECR_TRACE("UUAOBTPE: Update main left list of the TPE object "+LDOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ZAOL]) =0  Local File =LDOSSIER+".AOBJLST"     [ZAOL] : Endif
#-------------------------------#
#   mise a jour table AOBJLST   #
#-------------------------------#
Trbegin [ZAOL]
Read [F:ZAOL]AOL0="TPE"
If fstat
 Call ECR_TRACE("Error : The TPE object doesn't exist.",-1) From GESECRAN
 GOK=0 : Goto FIN
Endif
Raz [F:ZAOL]
[F:ZAOL]ABREV     = "TPE"
[F:ZAOL]DELDEF    = 1
[F:ZAOL]NBSEL     = 5

[F:ZAOL]SELEXP(0) = "string$([F:TPE]CPY='',mess(36,7770,1))+string$([F:TPE]CPY<>'',[F:CPY]CPY)"
[F:ZAOL]SELEXP(1) = "string$([F:TPE]DPRPLN=0,mess(16,3101,1))+string$([F:TPE]DPRPLN>0,mess([F:TPE]DPRPLN,3101,1))"
[F:ZAOL]SELEXP(2) = "string$([F:TPE]ACEGRP='',mess(103,7778,1))+string$([F:TPE]ACEGRP<>'',[F:TPE]ACEGRP)"
[F:ZAOL]SELEXP(3) = ""
[F:ZAOL]SELEXP(4) = ""

[F:ZAOL]SELFIC(0) = ""
[F:ZAOL]SELFIC(1) = ""
[F:ZAOL]SELFIC(2) = ""
[F:ZAOL]SELFIC(3) = "TYPACE"
[F:ZAOL]SELFIC(4) = "ATEXTRA"

[F:ZAOL]SELINT(0) = 1343
[F:ZAOL]SELINT(1) = 33972
[F:ZAOL]SELINT(2) = 616
[F:ZAOL]SELINT(3) = 34014
[F:ZAOL]SELINT(4) = 8

[F:ZAOL]SELTYP(0) = "A"
[F:ZAOL]SELTYP(1) = "A"
[F:ZAOL]SELTYP(2) = "A"
[F:ZAOL]SELTYP(3) = ""
[F:ZAOL]SELTYP(4) = ""

[F:ZAOL]SELZON(0) = ""
[F:ZAOL]SELZON(1) = ""
[F:ZAOL]SELZON(2) = ""
[F:ZAOL]SELZON(3) = "ACETYP"
[F:ZAOL]SELZON(4) = "TEXTE"

Rewrite [F:ZAOL]

$FIN
 If GOK=1
  Commit
 Else
  Rollback
 Endif

 If GOK
  Call VALID("OTPE",LDOSSIER,1,GOK) From VALWIN
 Endif
 If GOK
  Call VALID("TPE",LDOSSIER,1,GOK) From VALOBJ
 Endif

 If !GSERVEUR : GSERVEUR=1 : Local Integer LGSERVEUR : Endif
 Call VALFCT(LDOSSIER) From AVALAFC
 If dim(LGSERVEUR)>0
  GSERVEUR = 0
 Endif

$FIN2
#----- Fin du traitement -----#
WMSG ="UUAOBTPE: end of process"
Call ECR_TRACE(WMSG,0) From GESECRAN

End
