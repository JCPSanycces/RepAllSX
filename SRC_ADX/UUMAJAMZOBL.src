#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################################
## Mise à jour de la colonne obligatoire sur les champs Alpha avec une action CONTOBJW
########################################################################################
Call OUVRE_TRACE(mess(81,125,1)-"AMSKZON -> Action/CONTOBJW") From LECFIC : # Mise à jour de la table
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Gosub MAJ
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJ
End

$MAJ
Local File =DOSSIER+".AMSKZON" [AMZ] , =DOSSIER+".AMSKACT" [AMA] , =DOSSIER+".ATYPE" [ATY]
Call ECR_TRACE(mess(81,125,1)-"AMSKZON",0) From GESECRAN : # Mise à jour de la table
Trbegin [AMZ]
 For [AMA] Where ACTION="CONTOBJW"
  Read [AMZ]CODE=[F:AMA]CODAFF;[F:AMA]CODZON
  If !fstat
   Read [ATY]CODTYP=[F:AMZ]CODTYP
   If !fstat & [F:ATY]TYPTYP=7 & [F:AMZ]OBLIG<>2
    [F:AMZ]OBLIG = 2
    Rewrite [AMZ]
    If fstat
     Call ERREUR("AMSKZON",2) From DOSDIC
    Endif
   Endif
  Endif
 Next AMA
Commit
Close Local File
End
