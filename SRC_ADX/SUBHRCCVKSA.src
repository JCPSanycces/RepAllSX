#JOJAC 2016-02-29 - REQ 114309 US7 - START
#FRLAA - 2015-04-14 - Requirement 104631 US 3487 - START
$ACTION
Case ACTION
  When "MODIF"         : Gosub MODIF
  When "CREATION"      : Gosub CREATION
  When Default
Endcase
Return

$MODIF
$CREATION
If clalev([F:PSA]) = 0 : Local File POSTEKSA    [PSA]         : Endif
If clalev([F:POT]) = 0 : Local File POSTE       [POT]         : Endif

#JOJAC 2016-02-29 - REQ 114309 US7 - START
#If func AFNC.ACTIV("KZA")>0
#JOJAC 2016-02-29 - REQ 114309 US7 - END

#JOJAC 2016-02-29 - REQ 114309 US7 - START
If GCURLEG="ZAF"
#JOJAC 2016-02-29 - REQ 114309 US7 - END
  Filter [POT] Where CCV = [M:HRCCV0]COD
  Read [POT] First
  Filter [POT]
  If !fstat
    Update [PSA] Where COD = [F:POT]COD With OCPLEV = [M:HRCCV0]OCPLEV
    If fstat
      GOK = 0 : Call FSTA("PSA") From GLOCK : Return
    Endif
  Endif
Endif
Return
#FRLAA - 2015-04-14 - Requirement 104631 US 3487 - END
#JOJAC 2016-02-29 - REQ 114309 US7 - END

