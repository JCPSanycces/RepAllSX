#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# PJMACTOPE
###############################################################################
$ACTION
  Case ACTION
    When "OUVRE"             : Gosub OUVRE
    When "DEBUT"             : Gosub DEBUT
    When "SETBOUT"           : Gosub SETBOUT
    When "BOUTON"            : Gosub BOUTON
    When "APRES_MODIF"       : Gosub APRES_MODIF
    When "ENR"               : Gosub ENR
    When "ABA"               : Gosub ABANDON
    When Default
  Endcase
Return

###############################################################################
$OUVRE
  # -----------------------------
  NAVIG = GACTION
  GOK = 1
  # -----------------------------
Return

###############################################################################
$DEBUT
  If dim(GZINSPJM) <= 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  If  PARAM(1) = AVOID.ACHAR or PARAM(2) = AVOID.ACHAR or val(PARAM(3)) = 0 or val(PARAM(4)) = 0 Then
    GMESSAGE = mess(186,123,1)
    GERR = 1
    FIN = 1
    Return
  Endif
  # -----------------------------
  [M:PJOPE0]OPPNUM    = PARAM(1)
  [M:PJOPE0]TASCOD    = PARAM(2)
  [M:PJOPE0]LINTAS    = fmet GZINSPJM.PJM(1).TAS_GET_INDEX([M:PJOPE0]TASCOD)
  [M:PJOPE0]OPENUM    = val(PARAM(3))
  [M:PJOPE0]OPESPLNUM = val(PARAM(4))
  [M:PJOPE0]COLLIN    = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO_GET_INDEX([M:PJOPE0]OPENUM, [M:PJOPE0]OPESPLNUM)
  #
  Call LOAD_SCREEN([M:PJOPE0]COLLIN)
Return

###############################################################################
$SETBOUT
  If REP <> "" Then
    Call VIREBOUT(CHMEN,"1") From GOBJET
  Endif
Return

###############################################################################
$BOUTON
  Case BOUT
    When "1"
      # Status change
      Gosub RELIT_GZINSPJM From SUBPJMA
      Call LOAD_SCREEN([M:PJOPE0]COLLIN)
    When Default
  Endcase
Return

###############################################################################
$APRES_MODIF
  REP = "M"
Return

###############################################################################
$ENR
Local Integer MY_STATUS

  Call COPY_SCREEN_TO_CLASS()
  If GERR = 1 Then
    Return
  Endif
  # --------------------------------
  [L]MY_STATUS = fmet GZINSPJM.AUPDATE()
  If [L]MY_STATUS <> [V]CST_AOK Then
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
    If GMESSAGE = AVOID.ACHAR Then
      GMESSAGE = mess(159,2260,1)
    Endif
    If [L]MY_STATUS <> [V]CST_AWARNING Then
      Return
    Endif
  Endif
  # --------------------------------
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call LOAD_SCREEN([M:PJOPE0]COLLIN)
  REP = ""
Return

###############################################################################
$ABANDON
  Gosub RELIT_GZINSPJM From SUBPJMA
  Call LOAD_SCREEN([M:PJOPE0]COLLIN)
  REP = ""
Return

###############################################################################
Subprog LOAD_SCREEN(ICOLLIN)
Value Integer ICOLLIN

Local Integer ISHOWLINE

  ISHOWLINE = [M:PJOPE0]LINTAS
  Raz [M:PJOPE0]
  Raz [M:PJOPE0A]                                                                        # Issue X3-103661 - 2018-08-06 by FGR
  Raz [M:PJOPE0B]                                                                        # Issue X3-103661 - 2018-08-06 by FGR
  [M:PJOPE0]LINTAS = ISHOWLINE
  SetInstance [M:PJOPE0] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO(ICOLLIN)
  SetInstance [M:PJOPE0A] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO(ICOLLIN)       # Issue X3-103661 - 2018-08-06 by FGR
  SetInstance [M:PJOPE0B] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO(ICOLLIN)       # Issue X3-103661 - 2018-08-06 by FGR
  #
  [M:PJOPE0]COLLIN = ICOLLIN          # Line index in the collection
  # -----------------------------
  Call LOAD_AFFECTATION()
  Call DISABLE_FIELDS()
  # -----------------------------
  Affzo [M:PJOPE0]1-99
  Affzo [M:PJOPE0A]1-99                                                                  # Issue X3-103661 - 2018-08-06 by FGR
  Affzo [M:PJOPE0B]1-99                                                                  # Issue X3-103661 - 2018-08-06 by FGR
  Affzo [M:PJOPE1]1-99
End

###############################################################################
Subprog LOAD_AFFECTATION()

Local Integer NI

  nolign = 0
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT)
    If GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI) <> null and
&      find(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0
&   Then
      nolign += 1
      Call SHOW_RAFFT_LINE(NI)
    Endif
  Next NI
  [M:PJOPE1]NBAFF = nolign
End

###############################################################################
Subprog SHOW_RTKO(VNLINE)
Value Integer VNLINE

  SetInstance [M:PJOPE0] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN)
  SetInstance [M:PJOPE0A] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN)        # Issue X3-103661 - 2018-08-06 by FGR
  SetInstance [M:PJOPE0B] With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN)        # Issue X3-103661 - 2018-08-06 by FGR
  [M:PJOPE0]COLLIN = VNLINE   # Line index in the collection
  # ------------------------------------
  Affzo [M:PJOPE0]RMNQTY
  Affzo [M:PJOPE0A]1-99                                                                            # Issue X3-103661 - 2018-08-06 by FGR
  Affzo [M:PJOPE0B]1-99                                                                            # Issue X3-103661 - 2018-08-06 by FGR
End

###############################################################################
Subprog SHOW_RAFFT_LINE(VNLINE)
Value Integer VNLINE

Local Char KEYCONCAT(250)
Local Integer IPOANUM

  SetInstance [M:PJOPE1]5 With GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(VNLINE)
  [M:PJOPE1]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  # ------------------------------------
  KEYCONCAT = GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(VNLINE).KEYCONCAT
  IPOANUM = GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(VNLINE).POANUM
  [M:PJOPE1]BTNDES(nolign-1) = func OPPORPJM_CSTD_PROGS.PJMCLOB_GET_ICON(GZINSPJM.ACTX, func PJMOPEAFF_CSTD_PROGS.POALGDES_EXIST(GZINSPJM.ACTX, KEYCONCAT, IPOANUM) = [V]CST_AYES
&                              or func PJMOPEAFF_CSTD_PROGS.POALGCOM_EXIST(GZINSPJM.ACTX, KEYCONCAT, IPOANUM) = [V]CST_AYES)
  # ------------------------------------
End

###############################################################################
Subprog COPY_SCREEN_TO_CLASS()

Local Integer MY_STATUS
Local Integer ILINE
Local Integer NI

  # Hybrid part (begin)
  SetInstance GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN) With [M:PJOPE0]
  # [NBAFF]
  For NI = 1 To maxtab(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT)
    If GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI) <> null
&      and find(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI).AUUID), [M:PJOPE1]AUUID(0..[M:PJOPE1]NBAFF-1))
      If ILINE = 0 Then
        ILINE = find(GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI).POANUM, [M:PJOPE1]POANUM(0..[M:PJOPE1]NBAFF-1))
      Endif
      If ILINE = 0 Then
        [L]MY_STATUS = fmet GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).ADELLINE("RAFFT",GZINSPJM.PJM(1).TAS([M:PJOPE0]LINTAS).RTKO([M:PJOPE0]COLLIN).RAFFT(NI).AORDER)
        If [L]MY_STATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # Hybrid part (end)
End

###############################################################################
Subprog DISABLE_FIELDS()

Local Integer NI

  Local File PJMAUS [PAUS]
  # ----------------------------------
  # 1) The user has to be authorised for updating remaining load
  Read [PAUS]PAUS=GUSER
  If [F:PAUS]PAUSPA <> [V]CST_AYES Then
    Affzo [M:PJOPE1]5
    For NI = 0 To [M:PJOPE1]NBAFF-1
      If [M:PJOPE1]POACLB(NI) <> GUSER Then
        Grizo [M:PJOPE1]POACLB(NI)
        Grizo [M:PJOPE1]POADES(NI)
        Grizo [M:PJOPE1]BTNDES(NI)
        Grizo [M:PJOPE1]POASTR(NI)
        Grizo [M:PJOPE1]POASTRHM(NI)
        Grizo [M:PJOPE1]POAEND(NI)
        Grizo [M:PJOPE1]POAENDHM(NI)
        Grizo [M:PJOPE1]POASTDQTY(NI)
        Grizo [M:PJOPE1]POARMNQTY(NI)
      Endif
    Next NI
  Endif
End

