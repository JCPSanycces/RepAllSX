#<AdxTL>@(#)10.0.0.0 $Revision$

# Stansard script of screens : CPTEXT, CPTLOT, CPTSIM, CPVAL, VATDCL

$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
   When "CPTSELVCR"
    If clalev([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
    OBJET = "GAS"
    SUPP = [M]TYP
  Endcase
Endcase
Return

Subprog DEBUT(VALEUR)
Variable Char VALEUR
 GCURLEG = ""
 If dim([M]LEG)>0 & [M]LEG<>VALEUR
  Local Char LEGUSER(GLONADI)
  Call PARAMUTIL("LEGFIL",LEGUSER,VALEUR,"") From SUBAUS
  If LEGUSER=""
   zonsui="LEG"
   mkstat = 2
  Else
   [M]LEG=LEGUSER
   Affzo LEG
   GCURLEG = [M]LEG
  Endif
 Endif
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 Diszo ALLCPY
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0
  Effzo LEG : Diszo LEG
 Endif
 mkstat = 1 : End
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2   : Affzo ALLFCY : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0
  Effzo LEG : Diszo LEG
 Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
If clalev ([F:CPY])=0 : Local File COMPANY [CPY] :Endif
Call LEC_CPY(VALEUR) From CPTLEC
If dim([M]LEG)>0 : [M]LEG = [F:CPY]LEG : Endif
GCURLEG=[F:CPY]LEG
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If dim([M]LEG)>0 : [M]LEG = [F:CPY]LEG : Endif
# Initialize the gobal in order to allow the control (group , leg ..) of the different object available as on the GTE / JOU etc..
GCURLEG=[F:CPY]LEG
GSOCIETE=VALEUR
If GCURFCY=""
 I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
 GCURFCY = GSITE(I)
Endif
## Dates are displayed when the CPY field is populated : CPTEXT / CPTVAL / VATDCL/ TRFSAC
## Avoid to display dates by default only when we clic on the OK button (then the AS_ASTRDAT is triggered).It's too late
If dim([M]STRDAT)>0 & dim([M]ENDDAT)>0 & dim([M]ALLCPY)>0 & [M]STRDAT=[0/0/0]
 [M]CPY = VALEUR
 Call AS_STRDAT([M]STRDAT)
 Affzo [M]STRDAT,ENDDAT
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]LEG
 [M]TYP=""
 [M]JOU=""
Endif
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AP_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
If [M]ALLCPY=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
If VALEUR=2 : Effzo FCY : Grizo FCY : Else : Actzo FCY : Endif
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo FCY : Grizo FCY
 GCURFCY=""
 If dim([M]CPY)>0 & [M]CPY<>""
  I = find([M]CPY,GSOCSITE(1..GNBSITE))
  GCURFCY = GSITE(I)
 Endif
Else
 Actzo FCY
Endif
End

Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\" : End : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
 OK = 1
 Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
 If [F:CPY]CPYLEGFLG=2
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = 0 : Break
   Endif
  Next I
 Else
  For [FGR]FGR0 Where CPY=[L]SOC
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = 0 : Break
   Endif
  Next
 Endif
Endif
If !OK
 VALEUR = 1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
If [M]ALLFCY=2 : mkstat = 1 : End : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
GCURFCY=VALEUR
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
 If dim([M]VCRDEB)>0 : Effzo VCRDEB, VCRFIN : Grizo VCRDEB,VCRFIN : Endif
Else
 Actzo TYP
 If dim([M]VCRDEB)>0 : Actzo VCRDEB,VCRFIN : Endif
Endif
End

Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
# Field ACTION1 : CPTSIM (value<>""), CPTVAL,VATDCL
If dim([M]ACTION1)>0
 If [M]ACTION1<>""
  If [F:GTE]VCRSIM<>2
   GMESSAGE = mess(32,107,1)
   mkstat = 2 : End
  Endif
 Else
  If [F:GTE]VCRSIM=2 & [F:GTE]VCRREA<>2
   GMESSAGE = mess(33,107,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_ALLTYPJOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : [M]TYPJOU=0 : Affzo TYPJOU : Grizo TYPJOU : Else : Actzo TYPJOU : Endif
End

Subprog AS_TYPJOU(VALEUR)
Variable Integer  VALEUR
If [M]ALLTYPJOU = 2 : mkstat = 1 : End : Endif
End

Subprog C_TYPJOU(VALEUR)
Variable Integer  VALEUR
If [M]ALLTYP<>2 & [F:GTE]AUZJOU(VALEUR-1)<>2
 GMESSAGE = mess(51,106,1)-[M]TYP
 mkstat = 2 : End
Endif
End

Subprog C_ALLJOU(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo JOU : Grizo JOU : Else : Actzo JOU : Endif
End

Subprog AS_JOU(VALEUR)
Variable Char     VALEUR
If [M]ALLJOU = 2 : mkstat = 1 : End : Endif
If VALEUR="" & [M]TYP<>""
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOU(VALEUR)
Variable Char     VALEUR
If dim([M]ALLTYPJOU)>0 & [M]ALLTYPJOU<>2 & [F:JOU]TYP<>[M]TYPJOU
 GMESSAGE = mess(5,107,1)-mess([M]TYPJOU,613,1)
 mkstat = 2 : End
Elsif [M]ALLTYP<>2 & [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
 GMESSAGE = mess(8,106,1)
 mkstat = 2 : End
Endif
If dim([M]ALLCPY)>0 & [M]ALLCPY<>2
 Call VERIF([F:JOU]FCY,[M]FCY,VALEUR) From CFYSUB
 If mkstat : End  : Endif
Endif
Call CONTEXE([F:JOU]ACS) From CPTSUB
End

Subprog AS_ALLUSR(VALEUR)
Variable Integer VALEUR
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo USR : Grizo USR : Else : Actzo USR : Endif
End

Subprog AS_USR(VALEUR)
Variable Char  VALEUR
If [M]ALLUSR = 2 : mkstat = 1 : End : Endif
If VALEUR="" : VALEUR = GUSER : Endif
End

## Dates are populated in init : CPTEXT / CPTVAL / VATDCL
## When we open the window the date fields aren't populated. If we clic on the OK button,
## then the AS_ASTRDAT is triggered and the dates are populated but the user doesn't see it.
## To trigger AS_STRDAT when CPY is populated, in D_STRDAT we populate date only if GDATEDEB<>[0/0/0]
## If GDATEDEB=[0/0/0], the date is populated first by cpy and then by GFYDEF(0) when CPY
## is populated.
Subprog D_STRDAT(VALEUR)
Variable Date VALEUR
If VALEUR=[0/0/0] & GDATEDEB<>[0/0/0]
  VALEUR    = GDATEDEB
  [M]ENDDAT = GDATEFIN
 Endif
End

Subprog AS_STRDAT(VALEUR)
Variable Date     VALEUR
Local Integer ISITE
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If VALEUR=[0/0/0]
 If GDATEDEB<>[0/0/0]
  VALEUR    = GDATEDEB
  [M]ENDDAT = GDATEFIN
 Else
  If dim([M]ALLCPY)>0 & [M]ALLCPY<>2 & [F:CPY]CPYLEGFLG=2
   Call LEC_CPY([M]CPY) From CPTLEC
   Call GETSOC([F:CPY]MAIFCY) From DEVSUB
   Call DEFPER([M]CPY,GTYPGEN,VALEUR,[M]ENDDAT) From CPTSUB
  Else
   ISITE = find(GFCYDEF(0),GSITE(1..GNBSITE))
   If ISITE
    Call DEFPER(GSOCSITE(ISITE),GTYPGEN,VALEUR,[M]ENDDAT) From CPTSUB
   Endif
  Endif
 Endif
Endif
End

Subprog C_ALLVAT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Effzo VAT : Grizo VAT : Else : Actzo VAT : Endif
End

Subprog AS_VAT(VALEUR)
Variable Char    VALEUR()
If [M]ALLVAT=2 : mkstat = 1 : End : Endif
End

Subprog AS_SIMSTA(VALEUR)
Variable Integer  VALEUR
If [M]ACTION1<>"V" : mkstat=2 : End : Endif
If [M]CPY<>""
 If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
  VALEUR = 2
  mkstat = 2 : End
 Endif
Endif
End

Subprog D_SIM(VALEUR)
Variable Integer VALEUR
Case [M]ACTION1
 When "+" : VALEUR=2 : End
 When "-" : VALEUR=1 : End
Endcase
End

Subprog AS_SIM(VALEUR)
Variable Integer  VALEUR
Case [M]ACTION1
 When "+" : VALEUR=2 : mkstat=2 : End
 When "-" : VALEUR=1 : mkstat=2 : End
Endcase
End

Subprog C_CATLOT(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 : Grizo STALOT : Else : Actzo STALOT : Endif
End

Subprog AS_STALOT(VALEUR)
Variable Integer  VALEUR
If [M]CATLOT>1 : mkstat = 1 : End : Endif
If [M]CPY<>""
 If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
  VALEUR = 2
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_RAZLOT(VALEUR)
Variable Integer  VALEUR
If [M]CATLOT>1 : mkstat = 1 : End : Endif
End

Subprog AS_ENDLOT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]STRLOT : VALEUR=[M]STRLOT : Endif
End

Subprog C_ENDLOT(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]STRLOT
 GMESSAGE = mess(44,199,1)
 mkstat = 1
Endif
End

Subprog AS_VCRDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
End

Subprog AS_VCRFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLTYP=2 : mkstat = 1 : End : Endif
If VALEUR="" | VALEUR<[M]VCRDEB : VALEUR=[M]VCRDEB : Endif
End

Subprog C_VCRFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]VCRDEB
 GMESSAGE = mess(44,199,1)
 mkstat = 2
Endif
End

Subprog AS_AUTACC(VALEUR)
Variable Integer VALEUR
If [M]ACTION1="V" : mkstat=2 : End : Endif
End

########################################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE
End

$GRISE
If dim([M]ALLCPY)>0
 If [M]ALLCPY=2
  Effzo CPY,FCY : Grizo CPY,FCY
  [M]ALLFCY=2 : Affzo ALLFCY : Grizo ALLFCY
  If dim([M]LEG)>0 : Affzo LEG : Endif
 Else
  Actzo CPY,ALLFCY
  If dim([M]LEG)>0
   If [M]LEG = ""
    Effzo LEG : Diszo LEG
   Else
    # When go back from Memo the value of LEG should be keep.
    Diszo LEG
   Endif
  Endif
 Endif
Endif
If dim([M]ALLFCY)>0
 If [M]ALLFCY=2 : Grizo FCY : Else : Actzo FCY : Endif
Endif
If dim([M]ALLTYPJOU)>0
 If [M]ALLTYPJOU=2 : [M]TYPJOU=0 : Affzo TYPJOU : Grizo TYPJOU : Else : Actzo TYPJOU : Endif
Endif
If dim([M]ALLJOU)>0
 If [M]ALLJOU=2 : Grizo JOU : Else : Actzo JOU : Endif
Endif
If dim([M]ALLTYP)>0
 If [M]ALLTYP=2
  If dim([M]TYP)>0
   Grizo TYP
   If dim([M]VCRDEB)>0 : Grizo VCRDEB,VCRFIN : Endif
  Endif
 Else
  If dim([M]TYP)>0
   Actzo TYP
   If dim([M]VCRDEB)>0 : Grizo VCRDEB,VCRFIN : Endif
  Endif
 Endif
Endif
If dim([M]ALLUSR)>0
 If [M]ALLUSR=2 : [M]USR="" : Affzo USR : Grizo USR : Else : Actzo USR : Endif
Endif
If dim([M]ALLVAT)>0
 If [M]ALLVAT=2 : Grizo VAT : Else : Actzo VAT : Endif
Endif
If dim([M]SIMSTA)>0
 If [M]ACTION1="V"
  Actzo SIMSTA,TYPDES,JOUDES
 Else
  Grizo SIMSTA,TYPDES,JOUDES
 Endif
Endif
If dim([M]AUTACC)>0
 If [M]ACTION1="V" : Grizo AUTACC : Else : Actzo AUTACC : Endif
Endif
If dim([M]CATLOT)>0
 If [M]CATLOT<>1 : Grizo STALOT : Else : Actzo STALOT : Endif
Endif
If dim([M]GENCAT)>0
 If [M]GENCAT<>1 : Grizo GENSIM : Else : Actzo GENSIM : Endif
Endif
Return

########################################################
## Sous-programmes pour les batchs
########################################################

#CHECK IGNORE_BEGIN

Subprog GETPAR
Local Char P1(15)(1..80) , P2(15)(1..80)
Call LEC_PARAM(P1,P2) From REQUETES
Call GETPAR("[M:DIA]",P1,P2) From REQUETES
End

Subprog PARAM(DOSSIER,USER,P1,P2,OK,TIT,WIN)
Value    Char    DOSSIER
Value    Char    USER
Variable Char    P1()(1..)
Variable Char    P2()(1..)
Variable Integer OK
Value    Char    TIT
Value    Char    WIN

If DOSSIER<>nomap
 Call ERREUR(mess(39,134,1)-DOSSIER) From GESECRAN
 OK = 0 : End
Endif
Call GETPAR("[M:DIA]",P1,P2) From REQUETES

OK=2 : Call DIALWIN(OK,TIT,WIN) From GESECRAN

If OK=2
 Call SETPAR("[M:DIA]",P1,P2) From REQUETES
Else
 OK = 0
Endif
End
#CHECK IGNORE_END

Subprog C_TYPDES(VALEUR)
Variable Char    VALEUR()
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If VALEUR<>""
 Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat : End : Endif
 If [F:GTE]VCRREA<>2
  GMESSAGE = mess(33,107,1) : mkstat = 2 : End
 Endif
Else
 If dim([M]TYP)>0 & [M]TYP<>""
  Call LEC_GTE_LEG(GCURLEG,[M]TYP) From CPTLEC
  If [F:GTE]VCRREA<>2 & dim([M]ACTION1)>0 & [M]ACTION1="V"
   GMESSAGE = mess(10,123,1) : mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_JOUDES(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYPDES <> ""
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 Call LEC_GTE_LEG(GCURLEG,[M]TYPDES) From CPTLEC
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_JOUDES(VALEUR)
Variable Char    VALEUR()
Call CTL_JOUDES(VALEUR,GCURLEG)
End

# CTL_JOUDES called from  : CPTVALSIM (cf C_JOUDES) + CPTSVC + SUBEXG + CPTCLP
Subprog CTL_JOUDES(VALEUR,LEG)
Variable Char    VALEUR()
Value    Char    LEG()
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
If VALEUR = ""
 # FQ121566
 If dim([M]ACTION1)>0 & [M]ACTION1="V" & GFONCTION <> "CPTVALSIM"
  GMESSAGE = mess(10,123,1) : mkstat = 2 : End
 Endif
Else
 Call LEC_JOU_LEG(LEG,VALEUR) From CPTLEC
 Call CONTEXE([F:JOU]ACS) From CPTSUB : If mkstat : End : Endif

 If dim([M]VCRTYP)>0 # for trt CPTCLP
  Call LEC_GTE_LEG(GCURLEG,[M]VCRTYP) From CPTLEC
 Elsif dim([M]TYPPCE)>0 # for trt CPTSVC / SUBEXG
  Call LEC_GTE_LEG(GCURLEG,[M]TYPPCE) From CPTLEC
 Else
  Call LEC_GTE_LEG(GCURLEG,[M]TYPDES) From CPTLEC
 Endif
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE = mess(51,106,1) : mkstat=2 : End
 Elsif [M]CPY <>"" & [F:JOU]FCY <>""
  Call VERSOC([F:JOU]FCY,[M]CPY,[M]FCY,VALEUR) From CFYSUB
  If mkstat : End : Endif
 Endif
Endif
End

# C_GRPSOC called from CNVECAR
Subprog C_GRPSOC(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]   : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM]   : Endif
If clalev([F:LED])=0  : Local File GLED        [LED]   : Endif
Local Integer OKSOC
Local Char    SOCIETE(GLONCPY)
If VALEUR<>"" & VALEUR<>[M]GRPSOC
 If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
 Call CONTALLCPY(VALEUR) From CPTSUB
 If mkstat : End : Endif
 [M]NBSOC = 0
 For [AGC] Where GRP=VALEUR
  SOCIETE = [F:AGC]CPY
  GSOCIETE = SOCIETE
  Gosub OKSOC
  If OKSOC
   Gosub CONTSOC
  Endif
  If OKSOC
   [M]SOC([M]NBSOC) = SOCIETE
   [M]NBSOC += 1
  Endif
 Next
 Affzo 10
 # Si pas de Grp de Soc alors on initialise par défaut la 1ere société avec la société par défaut du dossier
Elsif VALEUR="" & dim([M]NBSOC)>0 & [M]NBSOC=0 & dim([M]SITE)>0 & [M]SITE=""
 Raz [M]SOC
 [M]NBSOC = 1
 [M]SOC(0)=GDEFSOC
 If dim([M]LEDTYP)>0 & [M]LEDTYP<>0
  Call LEC_CPY([M]SOC(0)) From CPTLEC
  Call LEC_GCM([F:CPY]ACM) From CPTLEC
  Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
  [M]COA = [F:LED]COA
 Endif
 Affzo 10
Endif
End

$OKSOC
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED     [LED] : Endif
Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
If [M]NBSOC=0 & [F:LED]COA<>""
 [M]COA = [F:LED]COA
 OKSOC = 1
Else
 OKSOC = ([F:LED]COA=[M]COA)
Endif
Return

$CONTSOC
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If GUSRFCY(1)<>"\"
 Local Integer I
 Call LEC_CPY(SOCIETE) From CPTLEC
 For I=1 To GNBSITE
  If SOCIETE=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
   OKSOC = 0 : Break
  Endif
 Next I
Endif
Return

# C_GRPSOC called from CNVECAR + CPTDUM
Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char REFER(GLONLED)
Local Char SOCCUR(GLONCPY)
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif
SOCCUR = ""
If dim([M]GRPSOC)>0
 If [M]GRPSOC<>"" & ([M]NBSOC = 0 | VALEUR<>[M]LEDTYP)
  Raz [M]NBSOC, SOC
  [M]LEDTYP = VALEUR
  Gosub INISOC
  Call LEC_CPY([M]SOC(0)) From CPTLEC
 Elsif [M]GRPSOC="" & dim([M]SITE)>0
  Call LEC_FCY([M]SITE) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 Endif
Elsif dim([M]FCY)>0
 Call LEC_FCY([M]FCY) From CPTLEC
 Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Endif
SOCCUR = [F:CPY]CPY
If SOCCUR<>""
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 REFER = [F:GCM]LED(VALEUR-1)
 If REFER=""
  GMESSAGE = mess(201,111,1)
  mkstat = 2 : End
 Endif
Endif
End

$INISOC
If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
[M]NBSOC = 0
For [AGC] Where GRP=[M]GRPSOC
 SOCIETE = [F:AGC]CPY
 Gosub OKSOC
 If OKSOC
  Gosub CONTSOC
 Endif
 If OKSOC
  [M]SOC([M]NBSOC) = SOCIETE
  [M]NBSOC += 1
 Endif
Next
Affzo 10
Return

## Called from CPTDSPANA/CPTDUM/CNVECAR/SUBLTR
Subprog C_NBSOC
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED     [LED] : Endif
If [M]NBSOC>1
 Effzo SITE
 Grizo SITE
 GCURFCY=""
 GSOCIETE=""
Else
 Actzo SITE
Endif
If status>=65 & status<=90
 Case status
 When 65,68,83 : # Annulation/Sup ligne
  Gosub SETNOL
  If NOL=0 : GMESSAGE= mess(1,115,1): mkstat=2 :Endif
 Endcase
Endif
If [M]COA=""
 If dim([M]CPY)>0 & GFONCTION = "CPTDSPANA"
  Call LEC_CPY([M]CPY(0)) From CPTLEC
 Else
  Call LEC_CPY([M]SOC(0)) From CPTLEC
 Endif
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
 [M]COA = [F:LED]COA
Endif
If adxgtb=2  :# Sortie du tableau
 If GNBLEG=1 : GCURLEG = GDOSLEG : End : Endif
 Local Integer INDLEG, NBRLEG
 Local Char TABLEG(GLONADI)(1..100)
 GCURLEG=""
 If dim([M]CPY)>0 & GFONCTION="CPTDSPANA"
  Call LEGCPY([M]CPY,NBRLEG,TABLEG) From CPTDIV
 Else
  Call LEGCPY([M]SOC,NBRLEG,TABLEG) From CPTDIV
 Endif
 If NBRLEG=1
  GCURLEG = TABLEG
 Endif
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return
##

# AS_SOC called by CNVECAR
Subprog AS_SOC(VALEUR)
Variable Char    VALEUR()
If nolign=1 & VALEUR=""
 If dim([M]LEDTYP)>0 & [M]LEDTYP<>0
  If clalev([F:CPY])=0  : Local File COMPANY     [CPY]   : Endif
  If clalev([F:GCM])=0  : Local File GACM        [GCM]   : Endif
  If clalev([F:LED])=0  : Local File GLED        [LED]   : Endif
  Local Char SOCCUR(GLONCPY), REFER(GLONLED)
  SOCCUR = GDEFSOC
  If SOCCUR<>""
   Call LEC_CPY(SOCCUR) From CPTLEC
   Call LEC_GCM([F:CPY]ACM) From CPTLEC
   REFER = [F:GCM]LED([M]LEDTYP-1)
   If REFER<>""
    VALEUR = GDEFSOC
    Call LEC_LED(REFER) From CPTLEC
    [M]COA = [F:LED]COA
   Endif
  Endif
 Else
  VALEUR = GDEFSOC
 Endif
Endif
End

# C_SOC called by CNVECAR
Subprog C_SOC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]SOC) From OBJDIV
If mkstat : End : Endif
Local Integer OKSOC
Local Char    SOCIETE(GLONCPY)
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]   : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM]   : Endif
SOCIETE = VALEUR
GSOCIETE = VALEUR
If nolign=1 & [M]NBSOC = 1 : [M]NBSOC = 0 : Endif
Gosub OKSOC
If nolign=1 & [M]NBSOC = 0 : [M]NBSOC = 1 : Endif
If !OKSOC
 GMESSAGE = mess(93,102,1)
 mkstat = 2 : End
Endif
Gosub CONTSOC
If !OKSOC
 GMESSAGE = mess(32,104,1)
 mkstat = 2 : End
Endif
If nolign=1
 [M]SOC(0) = VALEUR
 Call LEC_CPY([M]SOC(0)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 REFER = [F:GCM]LED([M]LEDTYP-1)
 If REFER=""
  GMESSAGE = mess(201,111,1)
  mkstat = 2 : End
 Endif
Endif
If GCURFCY=""
 I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
 GCURFCY = GSITE(I)
Endif
End

# C_SITE called by CNVECAR
Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If VALEUR=""
 If [M]NBSOC=0
  GMESSAGE = mess(9,109,1)
  mkstat = 2
 Endif
 End
Endif
Call LEC_FCY(VALEUR) From CPTLEC
SOCIETE = [F:FCY]LEGCPY
GSOCIETE = SOCIETE
If [M]NBSOC>0 & SOCIETE<>[M]SOC(0)
 GMESSAGE = mess(30,106,1)-SOCIETE
 mkstat = 2 : End
Endif
GCURFCY=VALEUR
Gosub OKSOC
End
######################################################################################

