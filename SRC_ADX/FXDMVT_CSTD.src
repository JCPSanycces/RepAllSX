#<AdxTL>@(#)1.0.0.0 $Revision$
# Classe FXDMVT

$ACTION

    Case ACTION
    When "AREAD_AFTER"
    When "GET"
      If CURPRO = "FXD.DESI"
          this.DESI = func FDESI(this.APARENT.OBJMVT,
&                          this.APARENT.TYPMVT, this.CODZONE, this.DIME, this.DPRPLN)
      Endif
    When Default
    Endcase
Return



#** Lecture de désignation du champ écran (zone utilisateur ou non)
#*
#*
#* @param POBJMVT   dépense, immos...
#* @param PTYPMVT   sortie, transfert...
#* @param PCODZONE  champ à afficher
#* @param PDIME     champ dimensionné
#* @param PDPRPLN   plan (si DEPREC)
#*!
Funprog FDESI(POBJMVT, PTYPMVT, PCODZONE, PDIME, PDPRPLN)

Value Integer POBJMVT, PTYPMVT
Value Char PCODZONE
Value Char PDIME
Value Integer PDPRPLN

Local Char WCODWIN, WCODMSK
Local Integer I, WBTROUVE
Local Char WDESI(50)

    WCODWIN = func FREFFXM(POBJMVT, PTYPMVT)
    If WCODWIN = ""
        End ""
    Endif

    Local File AWINDOW [AWI]
    Read [AWI]AWI0 = WCODWIN
    If fstat
        Close File [AWI]
        End ""
    Endif

    Local File AMSK    [AMK]
    Local File AMSKZON [AMZ]
    Local File ATEXTE  [ATX]
    Local File ATEXTRA [AXX]

    WBTROUVE = 0
    I = -1
    WDESI = ""

    While I < [F:AWI]NBMSK

        WCODMSK = ""
        If I = -1
            WCODMSK = [F:AWI]MSKENT
        Else
            WCODMSK = [F:AWI]NOMMSK(I)
        Endif

        If WCODMSK <> ""
            Read [AMZ]CODE = WCODMSK; PCODZONE

            If fstat = 0
                Read [AMK]CODMSK = WCODMSK
                RABVMSK = [F:AMK]ABRMSK
                WBTROUVE = 1

                If left$(PCODZONE,  6) = "USRFLD"
# CBO-LSE : besoin de l'info langue de CX
                    Read [AXX]AXX0(4) = "FREFLD"; PCODZONE; "FRA"; num$(POBJMVT)
                    If fstat=0
                        WDESI = [F:AXX]TEXTE
                        WBTROUVE = 2
                    Else
                        WDESI = "fstat" - val(fstat)
                        WBTROUVE = 3
# CBO-LSE : besoin de l'info GLANDEF
#                        Read [AXX]AXX0(4) = "FREFLD"; PCODZONE; GLANDEF; num$(POBJMVT)
#                        If fstat=0
#                            WDESI = [F:AXX]TEXTE
#                        Endif
                    Endif

                Else
                    Read [ATX]NUMERO = "FRA" ; [F:AMZ]INTIT
                    If fstat = 0
                        WDESI = [F:ATX]TEXTE
                        WBTROUVE = 2
                    Endif
                Endif
                Break
            Endif
        Endif
        I += 1
    Wend

    If WBTROUVE = 0
        End WDESI
    Endif
    If WDESI = ""
        WDESI = PCODZONE
    Endif
    Close File [AWI], [AMK], [AMZ], [ATX], [AXX]
    If (WBTROUVE = 1 or WBTROUVE = 2) and PDPRPLN > 0
        WDESI -= "(" + mess(PDPRPLN, 3101, 1) + ")"
    Endif
End WDESI

#** référentiel utilisé pour les mouvements
#*
#*
#* @param POBJMVT : dépenses, immos...
#* @param PTYPMVT : sortie, transfert...
#*!
Funprog FREFFXM(POBJMVT, PTYPMVT)
Value Integer POBJMVT, PTYPMVT

    If POBJMVT = 1 # GFXM_DEPENSE
        If PTYPMVT = 5 # GFXM_MODIF
            End "OLOF"
        Endif

    Elsif POBJMVT = 2 # GFXM_IMMOS
        If PTYPMVT = 1 # GFXM_SORTIE
            End "FASISSM"
        Elsif PTYPMVT = 2 # GFXM_TRANSFERT
            End "FASTRFM"
        Elsif PTYPMVT = 3 # GFXM_IMPUT
            End "FASTRFCU"
        Elsif PTYPMVT = 5 # GFXM_MODIF
            End "OFAS"
        Endif

    Elsif POBJMVT = 6 # GFXM_PHY

        If PTYPMVT = 1 # GFXM_SORTIE
            End "PHYISSM"
        Elsif PTYPMVT = 2 # GFXM_TRANSFERT
            End "PHYTRFM"
        Elsif PTYPMVT = 5 # GFXM_MODIF
            End "OPHY"
        Endif
    Endif
End ""
