#<AdxTL>@(#)12.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#  AEXPXML             Export de données au format XML
#    

Call AEXPXML("OITM","XML")
End

Subprog AEXPXML(WINDOW,TYPEXP)
Value Char WINDOW,TYPEXPORT

#  TYPEXP : EXCEL ou XML


Local Integer I,J,K,L,VALID,NBSCR,NTEX,DIMF,NBLIG,INDI,STAT,NBFB
Local Char VALL1(200),VALLM(250),VALLP(250),PROP(20),APPLI
Local Char CODACT(20),LSCR(12)(1..20),LANCOU,DIRSEP,SCREEN,SUFF
Local Char NAMEF(200),NAMEF1(100)
Local Char SAVINT(100),SAVVAL(250)

LANCOU=GLANGUE
APPLI=nomap
If TYPEXP="EXCEL"
  Local Clbfile ANAM(4),ALIB(4),AVAL(4)
  Local Char ANAMC(15)(1..500),ALIBC(100)(1..500),AVALC(250)(1..500)
Endif

If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif
If clalev([F:AMK])=0 : Local File =APPLI+".AMSK"     [AMK] : Endif
If clalev([F:AMZ])=0 : Local File =APPLI+".AMSKZON"  [AMZ] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"   [ATX] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif
If clalev([F:ACC])=0 : Local File =APPLI+".ACCES"    [ACC] : Endif

Read [AWI]AWI0=WINDOW
If fstat<>0 : End : Endif
If [F:AWI]MSKENT<>""
  NBSCR+=1
  LSCR(NBSCR)=[F:AWI]MSKENT
Endif

For I=1 To [F:AWI]NBMSK
  CODACT=[F:AWI]ACTMSK(I-1)
  Gosub CONTACT
  If VALID=0
    NBSCR+=1
    LSCR(NBSCR)=[F:AWI]NOMMSK(I-1)
  Endif
Next I

Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
NAMEF = filpath(APPLI+DIRSEP+"TMP","","","X3_PUB") 
NAMEF1="F"+num$(adxuid(1))+"_"+GBOITE+"_"+num$(time)
If TYPEXP="XML"
  NAMEF1+=".xml"
Else
  NAMEF1+=".csv"
Endif
NAMEF+=DIRSEP+NAMEF1

If TYPEXP="XML"
  Openo NAMEF,0 Using [XML_]
  Iomode adxifs "" Using [XML_]
  Iomode adxirs chr$(10) Using [XML_]
  Iomode adxium GUTF8 Using [XML_]
Else
  Openo NAMEF,0 Using [CSV_]
  Iomode adxifs "" Using [CSV_]
  Iomode adxirs chr$(10) Using [CSV_]
  Iomode adxium GASCII Using [CSV_]
Endif

If TYPEXP="XML"
  VALL1='<FEN'
  PROP="NAM" : VALLP=WINDOW : Gosub ADDPROP
  PROP="EXTDAT" : VALLP=num$(date$) : Gosub ADDPROP
  PROP="EXTTIM" : VALLP=num$(time$) : Gosub ADDPROP
  PROP="EXTDOS" : VALLP=APPLI : Gosub ADDPROP
  NTEX=[F:AWI]DES : Gosub EVINTIT
  PROP="LIB" : VALLP=VALLM : Gosub ADDPROP
  VALL1+=">"
  Wrseq VALL1 Using [XML_]
Else
  NTEX=[F:AWI]DES : Gosub EVINTIT
  VALL1='"'+WINDOW+'";"'+SAVINT+'";"'+APPLI+'";"'+num$(date$)+'";"'+num$(time$)+'";'
  Wrseq VALL1 Using [CSV_]
Endif

For I=1 To NBSCR
  SCREEN=LSCR(I)
  Gosub EVSCREEN
Next I

If TYPEXP="XML"
  VALL1='</FEN>'
  Wrseq VALL1 Using [XML_]
  Openo Using [XML_]
Else
  Openo Using [CSV_]
Endif

Gosub VISURES

End




$EVSCREEN
  Read [AMK]CODMSK=SCREEN
  If TYPEXP="XML"
    VALL1='<SCRN' 
    PROP="NAM" : VALLP=SCREEN : Gosub ADDPROP
    NTEX=[F:AMK]INTMSK : Gosub EVINTIT
    PROP="LIB" : VALLP=VALLM : Gosub ADDPROP
    VALL1+='>'
    Wrseq VALL1 Using [XML_]
  Else
    VALL1='"";""'
    VALL1='"---";"---";"---"'
    Wrseq VALL1 Using [CSV_]
    NTEX=[F:AMK]INTMSK : Gosub EVINTIT
    VALL1='"'+SCREEN+'";"'+SAVINT+'";'
    Wrseq VALL1 Using [CSV_]
  Endif
  For J=1 To [F:AMK]NBBLOC
    If [F:AMK]TYPBLOC(J-1)<>5
      Gosub EVBLOC
    Endif
  Next J
  If TYPEXP="XML"
    VALL1='</SCRN>'
    Wrseq VALL1 Using [XML_]
  Endif
Return



$EVBLOC
  VALL1='<FRM'
  If [F:AMK]INTBLOC(J-1)<>""
     Onerrgo EVINTERR
     PROP="LIB" : indice=1 
     VALLM=[F:AMK]INTBLOC(J-1)
     If left$(VALLM,1)="#" : VALLM=right$(VALLM,2) : Endif
     VALLM=evalue(VALLM)
     Gosub MVALC From INTRUTILA
     VALLP=VALLM : Gosub ADDPROP
     Onerrgo   
  Else
    NTEX=[F:AMK]TITBLOC(J-1) : Gosub EVINTIT
    PROP="LIB" : VALLP=VALLM : Gosub ADDPROP
  Endif
  If TYPEXP="XML"
    PROP="TYP" : VALLP=num$([F:AMK]TYPBLOC(J-1)) : Gosub ADDPROP
    PROP="LIBTYP" : VALLM=mess([F:AMK]TYPBLOC(J-1),38,1) :  Gosub MVALC From INTRUTILA
    VALLP=VALLM : Gosub ADDPROP
  Endif
  NBLIG=1
  If [F:AMK]TYPBLOC(J-1)=1
    Onerrgo EVVALERR
    NBLIG=max(1,evalue("[M:"+[F:AMK]ABRMSK+"]"+[F:AMK]BASPAG(J-1)))
    Onerrgo
    PROP="NBLIG" : VALLP=num$(NBLIG) : Gosub ADDPROP
  Endif
  If TYPEXP="XML"
    VALL1+='>'
    Wrseq VALL1 Using [XML_]
  Else
    VALL1='"";""'
    Wrseq VALL1 Using [CSV_]
    VALL1='"'+SAVINT+'";'
    Wrseq VALL1 Using [CSV_]
  Endif
  Filter [AMZ] Where CODMSK=SCREEN and NUMBLOC=J Order By NOZONE
  For L=1 To NBLIG
    If [F:AMK]TYPBLOC(J-1)=1
      If TYPEXP="XML"
        VALL1='<LIG'
        PROP="NUM" : VALLP=num$(L) : Gosub ADDPROP
        VALL1+='>'
        Wrseq VALL1 Using [XML_]
      Else
         Raz ANAM,ALIB,AVAL,ANAMC,ALIBC,AVALC,NBFB
      Endif
    Endif
    For [AMZ]
      NBFB+=1
      Gosub EVFIELD
    Next
    If [F:AMK]TYPBLOC(J-1)=1
      If TYPEXP="XML"
        VALL1='</LIG>'
        Wrseq VALL1 Using [XML_]
      Else
        If L=1
          Setlob ANAM With ANAMC(1..NBFB)
          Wrseq ANAM Using [CSV_]
          Setlob ALIB With ALIBC(1..NBFB)
          Wrseq ALIB Using [CSV_]
        Endif
        Setlob AVAL With AVALC(1..NBFB)
        Wrseq AVAL Using [CSV_]
      Endif
    Endif
  Next L
  If TYPEXP="XML"
    VALL1='</FRM>'
    Wrseq VALL1 Using [XML_]
  Endif
Return


$EVFIELD
  If [F:AMZ]SAIAFF<=0 or [F:AMZ]SAIAFF>3 : Return : Endif
  CODACT=[F:AMZ]CODACT
  Gosub CONTACT
  If VALID=1 : Return : Endif 
  If [F:AMZ]CODZON=[F:AMK]BASPAG(J-1) : Return : Endif
  If [F:AMZ]CODACC<>""
    Read [ACC]CODACC = GUSER;[F:AMZ]CODACC
    If fstat=0 & [F:ACC]EXEC<>2 : Return : Endif
  Endif
  SUFF=""
  DIMF=1
  If [F:AMZ]DIME>1 and [F:AMK]TYPBLOC(J-1)<>1 : DIMF=[F:AMZ]DIME : Endif  
  For K=1 To DIMF
    If DIMF>1 : SUFF="_"+num$(K) : Endif
    If TYPEXP="XML"
      VALL1='<FLD'
      PROP="NAM" : VALLP=[F:AMZ]CODZON+SUFF  
      Gosub ADDPROP
    Endif
    If [F:AMZ]INTEVAL<>""
      Onerrgo EVINTERR
      PROP="LIB" : indice=L 
      VALLM=[F:AMZ]INTEVAL
      If left$(VALLM,1)="#" : VALLM=right$(VALLM,2) : Endif
      PROP="LIB" : VALLM=num$(evalue(VALLM)) :  Gosub MVALC From INTRUTILA
      VALLP=VALLM : Gosub ADDPROP   
      Onerrgo
    Else
      NTEX=[F:AMZ]INTIT : Gosub EVINTIT
      PROP="LIB" : VALLP=VALLM : Gosub ADDPROP
    Endif
    If TYPEXP="XML"
      If [F:AMZ]NOLIB<>0
        PROP="MEN" : VALLP=num$([F:AMZ]NOLIB) : Gosub ADDPROP
      Endif
      PROP="ATT" : VALLP=""
      Case [F:AMZ]SAIAFF
        When 1 : VALLP="INPUT"
        When 2 : VALLP="DISPLAY"
        When 3 : VALLP="HIDDEN"
      Endcase 
      Gosub ADDPROP
    Endif

    PROP="VAL" : VALLM=""
    Onerrgo EVVALERR
    INDI=K-1
    If [F:AMK]TYPBLOC(J-1)=1 : INDI=L-1 : Endif
    VALLM=num$(evalue("[M:"+[F:AMK]ABRMSK+"]"+[F:AMZ]CODZON+"("+num$(INDI)+")"))
    SAVVAL=VALLM
    If TYPEXP="XML"
      Gosub MVALC From INTRUTILA
      VALLP=VALLM
      Onerrgo
      Gosub ADDPROP
    Endif

    If [F:AMZ]NOLIB<>0 and SAVVAL<>""
      PROP="LIBVAL"  
      Onerrgo EVVALERR
      VALLM=mess(val(VALLM),[F:AMZ]NOLIB,1)
      SAVVAL=VALLM
      If TYPEXP="XML"
        Gosub MVALC From INTRUTILA
        VALLP=VALLM
        Onerrgo
        Gosub ADDPROP
      Endif
    Endif

    If TYPEXP="XML"
      VALL1+='/>'
      Wrseq VALL1 Using [XML_]
    Else
      If [F:AMK]TYPBLOC(J-1)=1
         ANAMC(NBFB)='"'+[F:AMZ]CODZON+'";'
         ALIBC(NBFB)='"'+SAVINT+'";'
         AVALC(NBFB)='"'+SAVVAL+'";'
      Else
      VALL1='"'+[F:AMZ]CODZON+'";"'+SAVINT+'";"'+SAVVAL+'";'
      Wrseq VALL1 Using [CSV_]
      Endif
    Endif

    If [F:AMZ]LIEN>1
      If TYPEXP="XML"
        VALL1='<FLD'
        PROP="NAM" : VALLP="Z"+[F:AMZ]CODZON+SUFF : 
        Gosub ADDPROP
      Endif

      PROP="VAL" : VALLM=""
      Onerrgo EVVALERR
      VALLM=num$(evalue("[M:"+[F:AMK]ABRMSK+"]Z"+[F:AMZ]CODZON+"("+num$(INDI)+")"))
      SAVVAL=VALLM
      If TYPEXP="XML"
        Gosub MVALC From INTRUTILA
        VALLP=VALLM
        Onerrgo
        Gosub ADDPROP
      Else
        If [F:AMK]TYPBLOC(J-1)=1
           NBFB+=1
           ANAMC(NBFB)='"'+"Z"+[F:AMZ]CODZON+'";'
           ALIBC(NBFB)='"'+" "+'";'
           AVALC(NBFB)='"'+SAVVAL+'";'
        Else
        VALL1='"Z'+[F:AMZ]CODZON+'";"'+" "+'";"'+SAVVAL+'";'
        Wrseq VALL1 Using [CSV_]
        Endif
      Endif

      If TYPEXP="XML"
        VALL1+='/>'
        Wrseq VALL1 Using [XML_]
      Endif
    Endif
  Next K  
Return


$ADDPROP
#      Ajoute une propriété et écrit un enreg si la longueur de la ligne est > 100
  If TYPEXP="EXCEL" : Raz VALL1 : Return : Endif
  If len(VALL1)+len(PROP)+len(VALLP) > 100
    Wrseq VALL1 Using [XML_]
    VALL1=PROP+'="'+VALLP+'"'
  Else
    VALL1-=PROP+'="'+VALLP+'"'
  Endif
Return


$EVINTERR
Resume

$EVVALERR
Resume

$CONTACT
 VALID=0
 If CODACT<>""
   Read [ACV]CODACT = CODACT
   If fstat<>0 or [F:ACV]FLACT<>2 : VALID=1 : Endif
 Endif
Return


$EVINTIT
 Raz VALLM,SAVINT
 If NTEX=0 : Return : Endif
 Read [ATX]NUMERO = LANCOU;NTEX
 If fstat=0
   VALLM=[F:ATX]TEXTE
   SAVINT=VALLM
   If TYPEXP="XML"
     Gosub MVALC From INTRUTILA
   Endif
 Endif
Return


$VISURES
  Local Char URL(200),RETOUR(200)
  URL=GVIRTDIR+DIRSEP+APPLI+DIRSEP+"TMP"+DIRSEP+NAMEF1

  Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                           "UILocalDir="+ chr$(1) +"HTTP",
&                           "UILocalFile="+ chr$(1) +URL

Return




