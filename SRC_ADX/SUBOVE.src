#<AdxTL>@(#)61.0.0.0 $Revision$
# Objet Frais généraux
########################################
$ACTION
Case ACTION
 When "LIENS"    Gosub LIENS 
 When "VERIF_CRE" Gosub VERIF_CRE 
 When "VERIF_MOD" Gosub VERIF_CRE  
 When "INICRE"   Gosub INICRE
 When "INIMOD"   Gosub INICRE
 When "ANNULE"   Gosub ANNULE
 When Default
Endcase
Return
 
$INICRE
    Call MAJTEXTRA([M:OVE1]OVEAXX,"OVERHEAD","OVEAXX",[M:OVE1]OVECOD,"") From ATEXTRA
    Call MAJTEXTRA([M:OVE1]OVESHOAXX,"OVERHEAD","OVESHOAXX",[M:OVE1]OVECOD,"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="OVERHEAD" & ZONE="OVEAXX" & CLE1= [M:OVE1]OVECOD
    Delete [AXX] Where CODFIC="OVERHEAD" & ZONE="OVESHOAXX" & CLE1= [M:OVE1]OVECOD
Return

$LIENS 
# dimensionnement libre du tableau de nature
#                                            03/06/03
If find("",[F]OVENAT(0..dim([F]OVENAT)-1)) > 0 
  [M]NBLIG = find("",[F]OVENAT(0..dim([F]OVENAT)-1)) - 1 
Else 
  [M]NBLIG = dim([F]OVENAT)
Endif 
Return
 
$VERIF_CRE 
If [M]NBLIG = 0 
    GMESSAGE = mess(205,199,1)
    OK = 0 
    SUIZON = "NBLIG" 
Else
  For nolign = 1 To [M]NBLIG  : # test rajouté 14/06/99 (TB)
   If ([M:OVE1]FXDOVEA(nolign-1)+[M:OVE1]FXDOVEB(nolign-1)+[M:OVE1]FXDOVEC(nolign-1)
&    +[M:OVE1]FXDOVED(nolign-1)) = 0
&    & [M:OVE1]FORCODA(nolign-1)="" & [M:OVE1]FORCODB(nolign-1)="" 
&    & [M:OVE1]FORCODC(nolign-1)="" & [M:OVE1]FORCODD(nolign-1)=""
       GMESSAGE = mess(106,193,1)
       # "Une des colonnes au moins doit être renseignée"
       OK = 0
       SUIZON = "NBLIG" 
       Break
   Endif
  Next
Endif 
Return 
 
# Sous-programme pour actions sur Zones 
####################################### 
Subprog AM_FXDOVEA(VALEUR)
Variable Decimal  VALEUR
If VALEUR <> 0 : Effzo FORCODA(nolign-1) : Endif
Gosub CUR_VID 
End
Subprog AM_FXDOVEB(VALEUR)
Variable Decimal  VALEUR
If VALEUR <> 0 : Effzo FORCODB(nolign-1) : Endif
Gosub CUR_VID 
End
Subprog AM_FXDOVEC(VALEUR)
Variable Decimal  VALEUR
If VALEUR <> 0 : Effzo FORCODC(nolign-1) : Endif
Gosub CUR_VID 
End
Subprog AM_FXDOVED(VALEUR)
Variable Decimal  VALEUR
If VALEUR <> 0 : Effzo FORCODD(nolign-1) : Endif
Gosub CUR_VID 
End
 
$CUR_VID 
# "Devise non renseignée le forfait sera exprimé dans la devise du site de calcul" 
If VALEUR <> 0 & [M:OVE1]CUR = "" 
   GMESSAGE = mess(206,199,1) : GERR = 2
Endif 
Return 
 
Subprog C_OVENAT(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M:OVE1]OVENAT) From OBJDIV
End
########################################
