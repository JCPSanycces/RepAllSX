#<AdxTL>@(#)9.0.0.0 $Revision$
GSCHEMA = ""
Call OBJET("LOT",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "FILTRE"      : Gosub FILTRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "SETBOUT"     : Gosub SETBOUT
 When "VERF_ANU"    : Gosub VERF_ANU
 When "VERF_CHG"    : Gosub VERF_CHG
 When "ABANDON"     : Gosub ABANDON
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "EFFMASK"     : Gosub EFFMASK
 When "DEFTRANS"    : Gosub DEFTRANS
 When "VARIANTE"    : Gosub VARIANTE
 When "SETTRANS"    : Gosub SETTRANS
 When "STATUT"      : Gosub STATUT
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "FIN"         : Gosub FIN
 When "FERME"       : Raz GGRPFCY
 When Default
Endcase
Return

$OUVRE

GSCHEMA = GFLAG
Call LECTURE("GDE",GSCHEMA,"") From CONTOBJ
Gosub SETMASK From GOBJET
Local Integer MAXLIG , MAXVTL
MAXLIG = dim([M:HAE1]SAC1)
MAXVTL = dim([M:VTL]AMT)
If MAXVTL<=0 or MAXLIG<=0
 GMESSAGE=""
 Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
 GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1) : # Paramétrage à revoir
 GSCHEMA="\"+GSCHEMA
 GERR = 1 : OK = 0
 Return
Endif
If clalev([F:CCE2]) = 0 : Local File =GTABCPT+"CACCE"   [CCE2] : Endif

If clalev([M:VTL])  = 0 : Local Mask VENTILE  [VTL] : Endif
If clalev([M:VT2])  = 0 : Local Mask VENTILE2 [VT2] : Endif

Local Char    TBCUR(GLONCUR)(1..4), MESSA(255)
Local Integer NBCUR
Local Integer CONSCUR
Local Decimal MONTANT
Local Integer NLIG, NLOT
Local Integer OKTCA
Local Decimal DEBLOC(MAXLIG) , CDTLOC(MAXLIG)
Local Decimal TMPLOC(MAXVTL)
Local Decimal AROLOC
Local Decimal COURS
Local Char    SAVSCH(10) , LOTCPT(GLONANM)
Local Integer MONOCPY # <JFL>
OK = 1

## CP 10/10/00 Habilitations Boutons
Local Integer ACCFCY, SAVCONS
Local Char    AUZFCY(15)


Local Mask GACCENTFMT  [HAEF]        # Ouverture du masque pour diverses informations
Local Mask SAICURLED   [SCL]         # Ouverture du masque pour la gestion des devises

Local Decimal EXERCICE, PERIODE      # Gestion des exercices/périodes

# Struture de données (Type de référentiel, référentiel et compte)
Global Integer GNBSTR
Global Integer GSTRTYP(1..MAXLIG)
Global Char    GSTRIDT(5)(1..MAXLIG)
Global Char    GSTRLED(GLONLED)(1..MAXLIG)
Global Char    GSTRCOA(GLONCOA)(1..MAXLIG)
Global Char    GSTRACC(GLONGAC)(1..MAXLIG)

# Utilisé par les Tiers
Global Integer GNBPLAN
Global Char    GPLAN(GLONCOA)(1..10)
Global Char    GCODLED(GLONLED)(1..10)

Global Integer GNBPLAN
Global Char    GPLAN(GLONCOA)(1..10)
Global Char    GCODLED(GLONLED)(1..10)


Local Char    WLED(GLONLED),WCUR(GLONCPY)
Local Integer I,J,K,IND,INDLED,INDANA,AXE,STAT,AXI
Return

$FIN
Return

$EFFMASK
[M:HAE1]DACINI = SAVSCH
Return

$FILTRE
If GSCHEMA<>"" & GSCHEMA<>GSCHDEFL
 FILTSUP  = '[F:LOT]DACDIA="'+GSCHEMA+'"'
Endif
Return

$DEFTRANS
If GFLAG="" :  GFLAG = GSCHDEFL : Endif
If GIMPORT & GFLAG="" : GFLAG = "STDL" :  Endif    ## En import, on ne pourra pas le saisir
Return

$VARIANTE
If !clalev([F:GDE]) : Local File =GTABCPT+"GDIAENTRY" [GDE] : Endif
Call LECTURE("GDE",VARCOD,"") From CONTOBJ
If fstat or [F:GDE]FLGLOT<>2 or [F:GDE]ENAFLG<>2
 OK = 0
Endif
Return

$SETTRANS
# GFLAG contient le code de la transaction choisie
If clalev ([F:GDE])=0 : Local File GDIAENTRY [GDE] : Endif
Call LECTURE("GDE",GFLAG,"") From CONTOBJ
GGRPFCY = [F:GDE]GFY
Return

$LIENS
Gosub SETMSK
Raz nolign, [M:VTL], [M:VT2], K

#--- Lectures diverses...
Call LECTURE("FCY",[F:LOT]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:LOT]CPY,"") From CONTOBJ
Call LEC_JOU_LEG([F:CPY]LEG,[F:LOT]JOU) From CPTLEC
Call LECTURE("GDE",[F:LOT]DACDIAGAS,"") From CONTOBJ
GGRPFCY = [F:GDE]GFY
Call LECTURE("GDE",[F:LOT]DACDIA,"") From CONTOBJ
If GGRPFCY="" : GGRPFCY = [F:GDE]GFY : Endif

Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETCUR(1,[F:CPY]CPY,[M]CURAFF) From CPTDIV
Call GETSOC([F:LOT]FCY) From DEVSUB

#--- Initialisation et contrôle des masques
Call INIMSKFMT([F:LOT]FCY,[F:LOT]DACDIA,"LOT",date$,STAT)  From SUBGASA
If STAT
 GMESSAGE=""
 Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
 Gosub MESSAGE From CPTAUTO
 GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA : # Paramétrage à revoir
 GERR = 1 : OK = 0
Endif


For [LOH]LOH0 Where LOT=[F:LOT]LOT

 For [LOD]LOD0 Where LOT=[F:LOH]LOT & ORNVCR=[F:LOH]ORNVCR
  nolign += 1
  [M] = [F:LOH]
  [M] = [F:LOD]
  If [F:LOD]LIN=1
   [M]NEW(nolign-1) = 2
  Else
   [M]NEW(nolign-1) = 1
  Endif

  For I=1 To [M:HAEF]NBRLED
   Assign "[M]ACC"+num$(I)+"("+num$(nolign-1)+")"  With [F:LOD]ACC(I-1)
   Assign "[M]SAC"+num$(I)+"("+num$(nolign-1)+")"  With [F:LOD]SAC(I-1)
  Next

  If [F:LOH]CUR<>[M]CURAFF
   Call LEC_GTE_LEG(GCURLEG,[F:LOH]TYP) From CPTLEC
   If [F:LOH]RATDIV(GTYPGEN-1)>0 : COURS =  [F:LOH]RATMLT(GTYPGEN-1)/[F:LOH]RATDIV(GTYPGEN-1) : Endif
   Call CONVERT3([F:LOH]CUR,[M]CURAFF,[M]CURAFF,[F:GTE]TYPRAT,[F:LOH]RATDAT,
&                [F:LOD]AMTCUR,MONTANT,COURS,STAT) From CPTSUB
   If STAT : # Pas de cours de devises [M]CUR -> [M]CURAFF (RATDAT)
    #GMESSAGE=mess(16,114,1)-[F:LOH]CUR-"->"-[M]CURAFF-"("+format$("D:"+GFMDAT,[F:LOH]RATDAT)+")"
   Endif
  Else
   MONTANT = [F:LOD]AMTCUR
  Endif
  If STAT : MONTANT=0 : Endif
  If [F:LOD]SNS=1
   [M]DEB(nolign-1) = [F:LOD]AMTCUR
   [M]TOTDEB += MONTANT
  Else
   [M]CDT(nolign-1) = [F:LOD]AMTCUR
   [M]TOTCDT += MONTANT
  Endif

  # Forcé l'initialisation à vide... autrement les étiquette D_ s'effectuent
  If varinit([M]CCE1,nolign-1)=0
   For AXE=1 To 20
    Assign "[M]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With ""
   Next AXE
  Endif

  If [F:LOD]DSP=""
   OK = 0
   For [LOA]LOA0 Where LOT=[F:LOD]LOT & ORNVCR=[F:LOD]ORNVCR & LIN=[F:LOD]LIN
    K += 1
    If !OK : OK = K : Endif
    [M:VT2]TBAMT(K) = [F:LOA]AMTCUR
    [M:VT2]TBQTY(K) = [F:LOA]QTY
    For I=1 To dim([F:LOA]CCE)-1
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With [F:LOA]CCE(I-1)
    Next I
   Next
   If OK
    If OK=K
     For I=1 To dim([F:LOA]CCE)-1
      Assign "[M]CCE"+num$(I)+"("+num$(nolign-1)+")"
&     With   evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
      Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
     Next I
     K -= 1
    Else
     [M]PTV(nolign-1) = OK
     [M]PTF(nolign-1) = K
     [M]DSP(nolign-1) = "$"
    Endif
   Endif
  Endif

 # Chargement des référentiels, de leur devise et des cours diviseur/multiplicateur
 For I=1 To len(mess(0,2644,1))
  Assign "[M]RATDIV"+num$(I)+"("+num$(nolign-1)+")" With [F:LOH]RATDIV(I-1)
  Assign "[M]RATMLT"+num$(I)+"("+num$(nolign-1)+")" With [F:LOH]RATMLT(I-1)
 Next

 Next
Next
[M:VT2]PTVENT = K+1
[M]NBLIG = nolign

Return

$SETMSK
Default Mask [HAE1]
Return

$SETBOUT
If CLECUR1<>"" & [M]UPDFLG=2
 Call VIREBOUT(CHAINE,"M") From GOBJET
Endif
If !GCONSULT
 Call VIREBOUT(CHAINE,"H") From GOBJET
Endif
If !GIMPORT
 Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
 If [L]ACCFCY & instr(1,[L]AUZFCY,"T") : CHMEN += "1" : Endif
Endif
# <JFL>
# suppression des boutons : supprimer, enregistrer, créer + interdiction de duplication
If MONOCPY : Call VIREBOUT(CHAINE,"AMCD") From GOBJET : Endif
# </JFL>
Raz GMESSAGE
Return

$AVANTBOUT
Case BOUT
 When "1"
  SAVCONS = GCONSULT
  GCONSULT = 2
Endcase
Return

$STATUT
Case BOUT
 When "1"
  GCONSULT = SAVCONS
Endcase
Return

$VERF_CHG
$VERF_ANU
If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
Read [HAE]HAE2(1) = "LO"+CODE
If fstat=0
 GMESSAGE = mess(73,107,1) : # Simulations générées pour ce lot
 GERR = 1 : OK = 0
Endif
Return

$ANNULE
Delete [LOH] Where LOT = CLECUR1
If fstat=1 : GOK=-1 : GLOCK="$GENTLOTH"-CLECUR1 : Return
Elsif fstat : GOK=0 : Call RSTA("LOH",CLECUR1) From GLOCK : Return
Endif

Delete [LOD] Where LOT = CLECUR1
If fstat=1 : GOK=-1 : GLOCK="$GENTLOTD"-CLECUR1 : Return
Elsif fstat : GOK=0 : Call RSTA("LOD",CLECUR1) From GLOCK : Return
Endif

Delete [LOA] Where LOT = CLECUR1
If fstat=1 : GOK=-1 : GLOCK="$GENTLOTA"-CLECUR1 : Return
Elsif fstat : GOK=0 : Call RSTA("LOA",CLECUR1) From GLOCK : Return
Endif
Return

$INICRE
LOTCPT = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(2,OKTCA) From SUBTCA
If OKTCA : LOTCPT = [F:TCA]CODNUM(2) : Endif
If LOTCPT="" : LOTCPT = "GLO" : Endif
Call NUMERO(LOTCPT,[M]FCY,datesyst,"",[F:LOT]LOT,STAT) From SUBANM
If GOK<1 | STAT
 GOK =0
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE=mess(60,199,1)-"("+LOTCPT+") : "+MESSA
 Endif
 Return
Endif
[M]LOT = [F:LOT]LOT
If dim([M:HAE1]LOT)>0 : Affzo [HAE1]LOT : Endif
Return

$INIMOD
[F:LOT]DACDIA = [F:GDE]DIA
Return

$RAZCRE
Raz [M:VTL], [M:VT2]
Gosub GRISE_CLE
Return

$RAZDUP
[M]UPDFLG = 1
Gosub GRISE_CLE
Return

$GRISE_CLE
Gosub GRISE_CLE From =WINPROG
Return

$CREATION
Gosub SETMSK
NLOT = 0

For nolign=1 To [M]NBLIG
 If [M]NEW(nolign-1)=2
  Raz [F:LOH]
  [F:LOH] = [F:LOT]
  [F:LOH] = [M]
  NLOT += 1
  [F:LOH]ORNVCR = NLOT
  NLIG = 0

  # Gestion des devise (Champs dimentionnée à 10 : CURMGT, RATMLT, RAMDIV)
  For I=0 To dim([F:LOH]CURMGT)-1
   [F:LOH]CURMGT(I) = [M:HAEF]CURC(I)
   [F:LOH]RATDIV(I) = evalue("[M]RATDIV"+num$(I+1)+"("+num$(nolign-1)+")")
   [F:LOH]RATMLT(I) = evalue("[M]RATMLT"+num$(I+1)+"("+num$(nolign-1)+")")
  Next

  Write [LOH]
  If fstat
   GOK = 0 : Call FSTA("LOH") From GLOCK : Break
  Endif
 Endif
 Raz [F:LOD]
 [F:LOD] = [F:LOH]
 [F:LOD] = [M]

 For I=0 To [M:HAEF]NBRLED-1
  [F:LOD]LEDTYP(I) = [M:HAEF]LEDTYP(I)
  [F:LOD]COA(I)    = [M:HAEF]COA(I)
  [F:LOD]ACC(I)    = evalue("[M]ACC"+num$(I+1)+"("+num$(nolign-1)+")")
  [F:LOD]SAC(I)    = evalue("[M]SAC"+num$(I+1)+"("+num$(nolign-1)+")")
 Next

 NLIG += 1
 [F:LOD]LIN = NLIG
 If [M]DEB(nolign-1)<>0
  [F:LOD]SNS = 1
  [F:LOD]AMTCUR = [M]DEB(nolign-1)
 Else
  [F:LOD]SNS = -1
  [F:LOD]AMTCUR = [M]CDT(nolign-1)
 Endif
 If [M]DSP(nolign-1)="$" : [F:LOD]DSP = "" : Endif
 Write [LOD]
 If fstat
  GOK = 0 : Call FSTA("LOD") From GLOCK : Break
 Endif

  ##--- Réparation manuelle
  If [M]DSP(nolign-1)="$"
   K = 0
   For I=[M]PTV(nolign-1) To [M]PTF(nolign-1)
    K += 1
    Raz [F:LOA]
    [F:LOA] = [F:LOH]
    [F:LOA] = [F:LOD]
    [F:LOA]AMTCUR = [M:VT2]TBAMT(I)
    [F:LOA]QTY    = [M:VT2]TBQTY(I)
    [F:LOA]ANALIN = K
    For J=1 To dim([F:LOA]CCE)-1
     [F:LOA]DIE(J-1) = evalue("[M:VT2]TBDIE("+num$(J-1)+")")
     [F:LOA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(J)+"("+num$(I)+")")
    Next J

    Write [LOA]
    If fstat
     GOK = 0 : Call FSTA("LOA") From GLOCK : Break 2
    Endif
   Next I

  ##--- Réparation standard

  Elsif [M]DSP(nolign-1)<>""
   [M:VTL]TOTREP  = [F:LOD]AMTCUR
   [M:VTL]QTOTREP = [F:LOD]QTY

   #--- Chargement de la répartition
   Call LECTURE("TCU",[F:LOH]CUR,"") From CONTOBJ
   Call LECTURE("GAC",[F:LOD]ACC,[F:LOD]COA) From CONTOBJ
   Call LECLED([F:LOT]CPY,[F:LOD]LEDTYP(INDLED),WLED,WCUR) From CPTDIV
   Call INDLED(WLED,"",IND,AXI) From CPTDIV
   Call CHARGE_VTE_STR([F:LOD]DSP,[M]UOM(nolign-1),WLED,[F:LOD]ACC,"") From VENTILE

   Raz [F:LOA]
   [F:LOA] = [F:LOH]
   [F:LOA] = [F:LOD]
   K = 0
   For I=0 To [M:VTL]BAS-1
    K += 1
    [F:LOA]AMTCUR = [M:VTL]AMT(I)
    [F:LOA]QTY    = [M:VTL]QTY(I)
    [F:LOA]ANALIN = K
    For J=1 To dim([F:LOA]CCE)
     [F:LOA]DIE(J-1) = evalue("[M:VTL]DIE("+num$(J-1)+")")
     If find([F:LOA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      [F:LOA]CCE(J-1) = evalue("[M:VTL]CCE"+num$(J)+"("+num$(I)+")")
     Endif
    Next J
    Write [LOA]
    If fstat
     GOK = 0 : Call FSTA("LOA") From GLOCK : Break 2
    Endif
   Next I

 ##--- Répartition saisie sur la ligne d'écriture générale
  Else

   Raz [F:LOA]
   [F:LOA] = [F:LOH]
   [F:LOA] = [F:LOD]
   [F:LOA]ANALIN = 1

   For J=1 To dim([F:LOA]CCE)-1
    [F:LOA]DIE(J-1) = evalue("[M:HAEF]DIE("+num$(J-1)+")")
    [F:LOA]CCE(J-1) = evalue("[M]CCE"+num$(J)+"("+num$(nolign-1)+")")
   Next J

   If sum([F:LOA]CCE(0..dim([F:LOA]CCE)-1))<>"" #| GLEDDIEIPT(IND)=2
    Write [LOA]
    If fstat
     GOK = 0 : Call FSTA("LOA") From GLOCK : Break
    Endif
   Endif
  Endif

Next nolign
If GOK<1 : Return : Endif
Return

$MODIF
Gosub ANNULE
If GOK<1 : Return : Endif
Gosub CREATION
Return

$APRES_MOD
Gosub RELIT From GOBJSUB
Return

$VERIF
If [M]NBLIG=0
 GMESSAGE = mess(17,106,1) : # Il n'y a aucune ligne saisie
 OK = 0 : Return
Endif
Gosub CONTLIG From SUBLO1
If mkstat : OK = 0 : Return : Endif
Return

$ABANDON
Gosub DEGRISE_CLE
Return

$APRES_CRE
Gosub DEGRISE_CLE
Return

$DEGRISE_CLE
Gosub DEGRISE_CLE From =WINPROG
Return
