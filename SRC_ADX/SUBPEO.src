#<AdxTL>@(#)0.0.0.0 $Revision$
#Call OBJET ("PEO", GBIDC1, GBIDC2) From GOBJET
#End

$ACTION
#---------------------------------#
# Actions de l'objet PEO (GOBJET) #
#---------------------------------#
Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS     From SUBPEOA
 When "VARIANTE"     : Gosub VARIANTE     From SUBPEOA
 When "SETTRANS"     : Gosub SETTRANS     From SUBPEOA
 When "AV_IMPRIME"   : Gosub AV_IMPRIME   From SUBPEOA
 When "AP_IMPRIME"   : Gosub AP_IMPRIME   From SUBPEOA
 When "OUVRE"        : Gosub OUVRE        From SUBPEOA
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE  From SUBPEOA
 When "FILTRE"       : Gosub FILTRE       From SUBPEOA
 When "SETBOUT"      : Gosub SETBOUT      From SUBPEOA
 When "AVANTBOUT"    : Gosub AVANTBOUT    From SUBPEOA
 When "EXEBOUT"      : Gosub EXEBOUT      From SUBPEOA
 When "HINT"         : Gosub HINTCLE      From SUBPEOA
 When "FILGAUCHE"    : Gosub FILGAUCHE    From SUBPEOA
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE From SUBPEOA
#When "TIROIR"       : Gosub TIROIR       From SUBPEOA
 When "DEB_PICK"     : Gosub DEB_PICK     From SUBPEOA
 When "PICKE"        : Gosub PICKE        From SUBPEOA
 When "DEPICK"       : Gosub DEPICK       From SUBPEOA
 When "FIN_PICK"     : Gosub FIN_PICK     From SUBPEOA
 When "STATUT"       : Gosub STATUT       From SUBPEOA
 When "DEFLIG"       : Gosub DEFLIG       From SUBPEOA
 When "LIENS_LIG"    : Gosub LIENS_LIG    From SUBPEOA
 When "INICRE_LIG"   : Gosub INICRE_LIG   From SUBPEOA
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From SUBPEOA
 When "VALLIG"       : Gosub VALLIG       From SUBPEOA
 When "RAZCRE"       : Gosub RAZCRE       From SUBPEOA
 When "RAZDUP"       : Gosub RAZDUP       From SUBPEOA
 When "LIENS"        : Gosub LIENS        From SUBPEOA
 When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBPEOA
 When "INICRE"       : Gosub INICRE       From SUBPEOA
 When "CREATION"     : Gosub CREATION     From SUBPEOA
 When "APRES_CRE"    : Gosub APRES_CRE    From SUBPEOA
 When "AB_CREATION"  : Gosub AB_CREATION  From SUBPEOA
 When "AVANT_MOD"    : Gosub AVANT_MOD    From SUBPEOA
 When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBPEOA
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC From SUBPEOA
 When "INIMOD"       : Gosub INIMOD       From SUBPEOA
 When "MODIF"        : Gosub MODIF        From SUBPEOA
 When "APRES_MOD"    : Gosub APRES_MOD    From SUBPEOA
 When "AB_MODIF"     : Gosub AB_MODIF     From SUBPEOA
 When "ABANDON"      : Gosub ABANDON      From SUBPEOA
 When "VERF_ANU"     : Gosub VERF_ANU     From SUBPEOA
 When "ANNULE"       : Gosub ANNULE       From SUBPEOA
 When "FERME"        : Gosub FERME        From SUBPEOA
 When "AB2_ITMREF"   : Gosub AB2_ITMREF
 When "AB3_ITMREF"   : Gosub AB3_ITMREF
 When "AB4_ITMREF"   : Gosub AB4_ITMREF
 When Default
Endcase
Return




######################################################################################
# SCO0 => Entête: Site/Fournisseur/NomencArticleSousTraitance
######################################################################################


Subprog D_POHFCY(VALEUR)
Variable Char     VALEUR
  VALEUR = GFCY
End

Subprog AS_POHFCY(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Initialisation du site de commande           #
# ------------------------------------------------- #
If VALEUR=""
   VALEUR = GFCY
Endif
End

######################################################################################
#59323
Subprog PERIO(SIT,MATRI)
Variable Char SIT
Value   Char MATRI
GPOINT = "PERIOD" : Gosub ENTREE From EXEFNC
End

Subprog AM_POHFCY(VALEUR)
#---------------------------------------------------#
#      Après modification du site de commande       #
# ------------------------------------------------- #
# Rechargement GSOCIETE : Société juridique         #
#              GLOCALDEV: Devise sté juridique      #
#              GFINRSP  : Site financier            #
#              GFCY     : Site commande             #
#              GRCPFCY  : Site réception par défaut #
# Récupération des paramètres achats et budget      #
# Rechargement code acheteur                        #
#---------------------------------------------------#
Variable Char     VALEUR
# (re)Chargement GSOCIETE courante pour le multi-soc
If GFCY<>VALEUR
   GFCY=VALEUR : Gosub CHARG_PARAM From SUBPEOA
Else
   Call ACTUALIS_FMTDIE(VALEUR,"PTR",9,GSCOPTRNUM)From TRTX3CPT
Endif
If GMESSAGE<>""
  GERR=1 : mkstat=1 : Goto RAZ_POHFCY
Endif
# Société courante
[M:SCO0]CPY = GSOCIETE
#----- Contrôle et chargement des zones inter-sites -----#
If [M:SCO0]BPRNUM<>""
  Call CTRL_INTERSITE (VALEUR,[M:SCO0]BPRNUM) From SUBPEOA
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL From SUBPEOA
[M:SCO0]CPY=GSOCIETE
[M:SCO1]INVFCY=GFINRSP      : # maj par CHARG_PARAM (appel de GETDEV)

$RAZ_POHFCY
If mkstat
  Local Char WMESS(80) : WMESS=GMESSAGE
  GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBPEOA
  GMESSAGE=WMESS
  GERR=1 : mkstat=1 : End
Endif

End

######################################################################################
Subprog IB_BPSNUM
#---------------------------------------#
# Initialisation bouton sur fournisseur #
#---------------------------------------#
Raz GBOUT2, [M:SCO0]WTRAIT
End


Subprog AM_BPRNUM(VALEUR)
#---------------------------------------------------#
#      Après modification du fournisseur            #
#---------------------------------------------------#
Variable Char    VALEUR
Local    Integer WOK
Local    Char    WSTOFCY (GLONFCY)
Local    Char    WRCPFCY (GLONFCY)
Local    Char    WBPRNUM (GLONBPR)

#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
WBPRNUM = VALEUR
Gosub READ_BPR From BPRLIB

WOK = func BPRLIB.IS_BPS_ACTIVE(VALEUR)
If WOK = 1 : mkstat=1 : Endif

WOK = func BPRLIB.CTL_BPS_DOUFLG(VALEUR)
If WOK = 1 : Endif : # mkstat déjà positionné si nécessaire

#-------------------------------------------
# Quel emplacement de sous-traitance ?
# Site de réception du client livré
#      => Site de production [M:SCO1]MFGFCY
# Site d'expédition du client livré (sur lequel se trouve l'emplacement sous-traitance)
#      => Site de stockage des matières
#      => Site de réception du produit sous-traité [M:SCO1]PRHFCY
#-------------------------------------------
Call FIND_SCOLOC ( VALEUR, [M:SCO1]BPAADD, [M:SCO1]LOC,WRCPFCY,WSTOFCY) From BPRLIB
If [M:SCO1]MFGFCY="" : [M:SCO1]MFGFCY=WRCPFCY : Endif
If [M:SCO1]PRHFCY="" : [M:SCO1]PRHFCY=WSTOFCY : Endif
#

If [F:BPR]BPRNUM=VALEUR
   GCUR           = [F:BPR]CUR
   [M:SCO1]CUR    = [F:BPR]CUR
   [M:SCO1]LAN    = [F:BPR]LAN
Else
   GCUR           = GLOCALDEV
   [M:SCO1]CUR    = GLOCALDEV
   [M:SCO1]LAN    = GLANGUE
Endif
#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:SCO0]TSSCOD)>0
  For I=0 To dim([M:SCO0]TSSCOD)-1
    [M:SCO0]TSSCOD(I)=[F:BPS]TSSCOD(I)
  Next I
Endif
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif

#----- Contrôle et chargement des zones inter-sites -----#
  Call CTRL_INTERSITE ([M:SCO0]POHFCY,VALEUR) From SUBPEOA
  If mkstat
    Local Char WMESS(80) : WMESS=GMESSAGE
    GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBPEOA
    GMESSAGE=WMESS
    GERR=1 : mkstat=1 : End
  Endif

  If [M:SCO0]ITMREF<>""
     Call RECH_SCO1_ITMREF ([M:SCO0]ITMREF,VALEUR)
  Endif

End

######################################################################################
Subprog C_BPRNUM(VALEUR)
#---------------------------------------------------#
#      Infos complémentaires du fournisseur         #
#---------------------------------------------------#
Variable Char    VALEUR
Local    Integer WOK
Local    Char    WSTOFCY (GLONFCY)
Local    Char    WRCPFCY (GLONFCY)
Local    Char    WBPRNUM (GLONBPR)

#----- Lecture BPARTNER si nécessaire pour chargement CUR, LAN -----#
WBPRNUM = VALEUR
Gosub READ_BPR From BPRLIB

WOK = func BPRLIB.IS_BPS_ACTIVE(VALEUR)
If WOK = 1 : mkstat=1 : Endif

WOK = func BPRLIB.CTL_BPS_DOUFLG(VALEUR)
If WOK = 1 : Endif : # mkstat déjà positionné si nécessaire

#-------------------------------------------
# Quel emplacement de sous-traitance ?
# Site de réception du client livré
#      => Site de production [M:SCO1]MFGFCY
# Site d'expédition du client livré (sur lequel se trouve l'emplacement sous-traitance)
#      => Site de stockage des matières
#      => Site de réception du produit sous-traité [M:SCO1]PRHFCY
#-------------------------------------------
Raz [M:SCO1]MFGFCY,BPAADD,LOC
Call FIND_SCOLOC ( VALEUR, [M:SCO1]BPAADD, [M:SCO1]LOC,WRCPFCY,WSTOFCY) From BPRLIB
#cf CTRL_INTERSITE
#If [M:SCO1]MFGFCY="" : [M:SCO1]MFGFCY=WRCPFCY : Affzo [M:SCO1]MFGFCY : Endif
If [M:SCO1]PRHFCY="" : [M:SCO1]PRHFCY=WSTOFCY : Affzo [M:SCO1]PRHFCY : Endif
#

If [F:BPR]BPRNUM=VALEUR
   GCUR           = [F:BPR]CUR
   [M:SCO1]CUR    = [F:BPR]CUR
   [M:SCO1]LAN    = [F:BPR]LAN
Else
   GCUR           = GLOCALDEV
   [M:SCO1]CUR    = GLOCALDEV
   [M:SCO1]LAN    = GLANGUE
Endif
[M:SCO3]CUR = [M:SCO1]CUR : Affzo [M:SCO3]CUR  # FQ 54650

#--------------------------------------------------#
# Type de donnée MC1 = devise commande (GCUR)      #
#                MC2 = devise société  (GLOCALDEV) #
#                MC3 = devise dossier  (GSYSCUR)   #
#--------------------------------------------------#
GDEV1(1)=GCUR : GDEV1(2)=GLOCALDEV : GDEV1(3)=GSYSCUR
For I=1 To 3
  GDEVFM1(I)=GDEVFMT1(max(find(GDEV1(I),GDEVISE(1..GNBDEV)),1))
Next I
#----- Chargement zones provenant du BPSUPPLIER -----#
If dim([M:SCO0]TSSCOD)>0
  For I=0 To dim([M:SCO0]TSSCOD)-1
    [M:SCO0]TSSCOD(I)=[F:BPS]TSSCOD(I)
  Next I
Endif
#----- Chargement libellés et formats colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
  GPLISTC=[F:BPS]PLISTC
  Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
  Call TARIFCHGT(6)                From TRTPRICE
Endif

#----- Contrôle et chargement des zones inter-sites -----#
Call CTRL_INTERSITE ([M:SCO0]POHFCY,VALEUR) From SUBSCOA
If mkstat
  Local Char WMESS(80) : WMESS=GMESSAGE
  GFCY=[M:SCO0]POHFCY : Gosub CHARG_PARAM From SUBSCOA
  GMESSAGE=WMESS
  GERR=1 : mkstat=1 : End
Endif

# Récup Adresse Client livré et Emplacement de sous-traitance
If [M:SCO1]BPAADD=""
   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
   If [M:SCO1]BPAADD<>""
      Call AM_BPAADD([M:SCO1]BPAADD) From SUBSCO1
   Endif
   Affzo [M:SCO1]BPAADD
Endif

If [M:SCO1]BPAADD=""
   Call FIND_FCYADD([M:SCO1]MFGFCY,[M:SCO1]BPAADD) From BPRLIB
Endif
If [M:SCO1]PRHADD=""
   Call FIND_FCYADD([M:SCO1]PRHFCY,[M:SCO1]PRHADD) From BPRLIB
Endif
End

######################################################################################
Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------#
#      Avant saisie du fournisseur                  #
#---------------------------------------------------#
Variable Char    VALEUR()
Local Char       WBPS
Local Char       WITMREF : WITMREF = [M:SCO0]ITMREF
Local Integer    WBOMALT : WBOMALT = [M:SCO0]BOMALT
Raz WBPS
If VALEUR = ""
   Call FIND_BPRNUM (WITMREF,WBOMALT,WBPS) From SCOLIB
   VALEUR         = WBPS
   [M:SCO0]BPRNUM = WBPS
   Affzo [M:SCO0]BPRNUM
Endif
End

######################################################################################

Subprog AS_SCONUM(VALEUR)
#----------------------------------#
# Avant saisie du numéro de retour #
#----------------------------------#
Variable Char    VALEUR()
If (GREP="C" | GREP="D") & GMANCOU<>2  mkstat=2 : Endif
End

Subprog C_SCONUM(VALEUR)
Variable Char     VALEUR
#----- Vérif si un enregistrement existe
Look [PEO]SCO0=VALEUR
#----- Si on n'avait rien d'affiché on veut afficher un ordre existant ----#
If [M:SCO0]SCONUM="" & GREP<>"C" & GREP<>"D"
  If fstat GMESSAGE=mess(178,199,1) : mkstat=1 : End : Endif
Endif
# en création ou duplication et compteur manuel, contrôle si no existe déja
If (GREP <> "C" & GREP <> "D") | GMANCOU <> 2  : End : Endif
VALEUR = vireblc(VALEUR,2)
Look [PEO]SCO0=VALEUR
If !fstat GMESSAGE=mess(22,100,1) : mkstat=1 : End : Endif
End

Subprog AM_SCONUM(VALEUR)
Variable Char    VALEUR()
End

######################################################################################

Subprog AS_ITMREF(VALEUR)
Variable Char VALEUR
# Cas d'une modification: pas de maj
####If [M:SCO0]ITMREF<> "" & GREP="" : mkstat = 2 : End : Endif
####  sauf que les boutons ne fonctionnent plus !!!!
End

######################################################################################

Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
# Ctrl Article sous-traité pris en charge par le tunnel

 #Call CONTROLE("ITF","",[M:SCO0]POHFCY,VALEUR,mkstat) From CONTOBJ
Local Integer WOK
WOK = func ITMLIB.IS_ITF_OK(VALEUR,[M:SCO0]POHFCY)
If WOK<2 : mkstat=2 : End : Endif

End

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If !find(GREP,"C","D") & [M:SCO0]ITMREF<>""
# Modification article sous-traité, veuillez supprimer puis recréer votre ordre de sous-traitance.
  GMESSAGE=mess(362,194,1)
  VALEUR = [M:SCO0]ITMREF : Affzo [M:SCO0]ITMREF
  mkstat = 2 : End
Endif

Call RECH_SCO1_ITMREF (VALEUR,[M:SCO0]BPRNUM)

#------------------------------------------------------------------------------#
# Appel S/P picking des besoins article sous-traité sauf si import             #
#------------------------------------------------------------------------------#
[M:SCO0]TRTPIC=1
If !GIMPORT
  If [F:ITM]SCPFLG=2                               : # Sous-traité (produit fini ou composé)
     [M:SCO0]TRTPIC=1
     If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY<>2       : # Inter-sites/intra-société
        [M:SCO0]TRTPIC=2
     Endif
  Else
     [M:SCO0]TRTPIC=0
  Endif
Endif
mkstat=0
End
#----- Retour à la saisie de la référence article -----#
$RETOURITMREF
mkstat=1 : [M:SCO0]ITMREF=""
End

######################################################################################

Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
Local    Integer WBOMALT : WBOMALT = VALEUR
# Cas d'une modification: pas de maj
If [M:SCO0]BOMALT <> 0 & GREP="" : mkstat = 2 : End : Endif
If [M:SCO0]ITMREF <> "" and WBOMALT = 0
  #----- Formats et entêtes de colonne variables (comptes, sections) -----#
   Gosub CHARG_PARAM From SUBPEOA
   Gosub AFF_TITCOL  From SUBPEOA
 # on cherche à proposer une alt de nomenc lorsque c'est possible
   Call FIND_BOMALT([M:SCO0]ITMREF,[M:SCO0]BPRNUM,WBOMALT ) From SCOLIB
   VALEUR = WBOMALT
Endif
End

Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Char    WFCY(GLONFCY)
Local Integer WBOMALT
Local Date    WDAT
Local Char    WITM(GLONITM)

WITM=[M:SCO0]ITMREF
WBOMALT=VALEUR

If [M:SCO1]ORDDAT=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:SCO1]ORDDAT
Endif

If [M:SCO0]POHFCY = ""
    WFCY=GFCY
Else
    WFCY=[M:SCO0]POHFCY
Endif
# Ctrl Nomenc de sous-traitance
Call CONTSCONOM(WFCY,WBOMALT,WDAT,1)
#
End

Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
Local Integer WBOMALT  : WBOMALT = VALEUR
Local    Integer WOK : WOK=2
If WBOMALT <> 0 & [M:SCO0]ITMREF<>""
   Call   CHARGE_BOMALT ([M:SCO0]ITMREF,WBOMALT, WOK) From SUBPEOA
   If WOK<>2 : mkstat=1 : Endif
Endif
End



######################################################################################

Subprog RECH_SCO1_ITMREF(LITMREF,LBPRNUM)
Variable Char    LITMREF()
Variable Char    LBPRNUM()

Local Integer    WBOMALT : WBOMALT = [M:SCO0]BOMALT
Local Decimal    WCOEFF
Local Integer    WOK  : WOK  = 2

#---------------------------------------------------#
#  Lecture ITM et ITF
#---------------------------------------------------#
Local Char WITMREF(GLONITM) : WITMREF=LITMREF
Local Char WFCY   (GLONFCY) : WFCY=[M:SCO0]POHFCY
If [M:SCO1]PRHFCY <> "" and [M:SCO1]PRHFCY <> [M:SCO0]POHFCY
   WFCY = [M:SCO1]PRHFCY
Endif
GOK=1
Gosub READ_ITM From ITMLIB
Gosub READ_ITF From ITMLIB
If GOK<>1  Goto RETOURITMREF : Endif

#----- Contrôle si article actif ? -----#
WOK = func ITMLIB.IS_ACTIVE ( LITMREF )
If WOK=1  Goto RETOURITMREF : Endif

#----- Article référencé chez le fournisseur ? -----#
# Issue X3-55891 - 2018-09-12 by MUARN : exploitation table article/fournisseur/site
#WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM )
If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY=1
  WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM, [M:SCO1]PRHFCY,2)
Else
  WOK = func ITMLIB.IS_ITP_OK ( LITMREF, LBPRNUM, [M:SCO1]PRHFCY,1)
Endif
If WOK=1  Goto RETOURITMREF : Endif
[M:SCO1]PURMINQTY = [F:ITP]PURMINQTY : # GA pour SUBPEO1 ctrl Qté

If LITMREF <> "" and LITMREF <> [M:SCO0]ITMREF & [M:SCO0]BOMALT<>0
# Changement d'article, on efface l'alternative précédente
  WBOMALT = 0
  [M:SCO0]BOMALT = 0
  Affzo [M:SCO0]BOMALT
#
  Raz [M:SCO1] : Raz [M:SCO2] : Raz [M:SCO3]
  Gosub RAZCRE From SUBPEO1
  Gosub RAZCRE From SUBPEO2
  Gosub RAZCRE From SUBPEO3
  Affzo [M:SCO1]
  Affzo [M:SCO2]
  Affzo [M:SCO3]
Endif
#

[M:SCO1]STU=[F:ITM]STU
If [F:PTR]UOMSAIFLG1 = 1
 # Saisie des qtés en UA non autorisée
   [M:SCO1]PUU       = [M:SCO1]STU
Else
   If [F:ITP]PUU<>"" : [M:SCO1]PUU=[F:ITP]PUU : Else [M:SCO1]PUU=[F:ITM]PUU : Endif
Endif

#----------------------------------
# Préparation des données Quantité
#----------------------------------
If [M:SCO1]PUU=[M:SCO1]STU
   [M:SCO1]PUUSTUCOE = 1
   [M:SCO1]EXTQTY = [M:SCO1]QTYPUU
Elsif [F:ITM]PUU<>[M:SCO1]PUU
   Call PCAL_QTY([M:SCO1]QTYPUU,[M:SCO1]PUU,[M:SCO1]EXTQTY,[M:SCO1]STU,
&                 LITMREF,[M:SCO0]BPRNUM,1,[M:SCO1]PUUSTUCOE)  From TRTACHQTE1
Else
   Call PCAL_QTY([M:SCO1]QTYPUU,[M:SCO1]PUU,[M:SCO1]EXTQTY,[M:SCO1]STU,
&                 LITMREF,[M:SCO0]BPRNUM,1,GBIDD1)  From TRTACHQTE1
Endif

If LITMREF <> "" & WBOMALT <> 0 & [M:SCO2]NBLIG=0
# préChargement de: [M:SCO1],[M:SCO2],[M:SCO3] selon la nomenclature
  Call   CHARGE_BOMALT (LITMREF,WBOMALT,WOK) From SUBPEOA
  If WOK=1  Goto RETOURITMREF : Endif
#
# on repositione ITM sur le composé
  If [F:ITM]ITMREF<>LITMREF
    WITMREF=LITMREF
    Gosub READ_ITM From ITMLIB
    Gosub READ_ITF From ITMLIB
    If GOK<>1  Goto RETOURITMREF : Endif
  Endif
Endif

If [M:SCO1]BPAADD=""
   # FQ 54554 Adresse du client livré (avant FIND_BPAADD)
   Call FIND_BPDADD ([M:SCO0]BPRNUM,[M:SCO1]BPAADD) From  BPRLIB
   If [M:SCO1]BPAADD<>""
      Call AM_BPAADD([M:SCO1]BPAADD) From SUBPEO1
   Endif
   Affzo [M:SCO1]BPAADD
Endif
Affzo [SCO1]


End

######################################################################################

########################################
# Boutons/Menus contextuels
########################################
Subprog IB_ITMREF
Local Integer I, NBITM
# boutons
If [M:SCO0]ITMREF <> ""
#
  GBOUT2  = mess(00004,00198,1) :  # Article-Site
  GBOUT8  = mess(00348,00194,1) :  # Situation article lancé
  #GBOUT9  = mess(??,??,1)      :  # Coût article sous-traité
  GBOUT10 = mess(00038,00198,1) :  # Texte
#
# s'il y a une réf de commande
  If [M:SCO1]POHNUM<>""
    GBOUT3 = mess(00010,00159,1) :  # Commande
  Else
    Raz GBOUT3
  Endif
#
  If [M:SCO1]WIPNUM<> ""
    GBOUT4 = mess(00238,00198,1) :  # Encours
  Else
    Raz GBOUT4
  Endif
#
Endif

End

$AB2_ITMREF
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # Article-Site
  WOBJET="ITF"
  WCLE1 =[M:SCO0]ITMREF
  WCLE2 =[M:SCO0]POHFCY
Return

$AB3_ITMREF
