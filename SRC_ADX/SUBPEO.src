#########################################################################
# Contrôle de validité d'une alternative
Subprog CONTSCONOM(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG

   If [M:SCO0]ITMREF <> [F:BOH]ITMREF | LALT <> [F:BOH]BOMALT | [F:BOH]BOMALTTYP <> 3
      Read [BOH]BOH0=[M:SCO0]ITMREF;LALT;3
      If fstat : mkstat=1 : End : Endif
   Endif

   If [F:TBO]BOMALT<>LALT | [F:TBO]BOMALTTYP <> 3
      Read [TBO]TBO0=3;LALT
      If fstat : mkstat=1 : End : Endif
   Endif

   Call CONTSCONOM(LFCY, LALT, LDAT, LMSG) From SCOLIB
End

######################################################################################

