#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque GENCEV
# Création
#     MABON - 30/08/12 - EXI 81491 PHASE 707
#              - Génération des entretiens d'évaluation
# Modifications :
#     SEGAY - 16/01/13 - EXI 87090 US1222 + 87537
#     MABOS - 22/02/13 - FQ81085 - US1332 - Add Legislation + Generic rules
#     MABOS - 05/03/13 - Bug 88428 - repositionnement sur fiche de GESCEV
#     FQ81491 - 18/10/13 - Gestion date d'effet
#     SEGAY - 13/02/14 - FQ 96649 - US2420 - Mission
######################################################################################

$ACTION

  Case ACTION
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "FIN"        : Gosub FIN
    When "SORTIE"     : Gosub SORTIE : #MABOS - 05/03/13-88428-repositionnement sur fiche de GESCEV
  Endcase
Return

#**#####################################################################################
#*
#*!


$INIT_DIA
Local Char LEGAXX(30)

  # Ouverture des tables utilisées
  If clalev([F:FCY])=0    : Local File FACILITY    [FCY]    : Endif
  If clalev([F:CPY])=0    : Local File COMPANY     [CPY]    : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA      [HRPOA]  : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR    [HRCTR]  : Endif
  If clalev([F:ID])=0     : Local File EMPLOID     [ID]     : Endif
  If clalev([F:AD])=0     : Local File EMPLOAD     [AD]     : Endif
  If clalev([F:CPT])=0    : Local File EMPLOCPT    [CPT]    : Endif
  If clalev([F:RIB])=0    : Local File EMPLORIB    [RIB]    : Endif
  If clalev([F:MED])=0    : Local File EMPLOMED    [MED]    : Endif
  If clalev([F:CEV])=0    : Local File COMPEVAL    [CEV]    : Endif
  If clalev([F:EVE])=0    : Local File EVAEMP      [EVE]    : Endif
  If clalev([F:EVE2])=0   : Local File EVAEMP      [EVE2]   : Endif
  If clalev([F:EVC])=0    : Local File EVAEMPCPC   [EVC]    : Endif
  If clalev([F:EVD])=0    : Local File EVAEMPDET   [EVD]    : Endif
  If clalev([F:EVD2])=0   : Local File EVAEMPDET   [EVD2]   : Endif
  If clalev([F:EPO])=0    : Local File EMPLOPOT    [EPO]    : Endif
  # FQ87153 - MABON 17/01/13 - Ajout bouton "Initialisation compéences"
  If clalev([F:POT])=0    : Local File POSTE       [POT]    : Endif
  If clalev([F:JOT])=0    : Local File JOBTYP      [JOT]    : Endif
  If clalev([F:CPC])=0    : Local File COMPETENCE  [CPC]    : Endif
  If clalev([F:HRSCA])=0  : Local File SCALE       [HRSCA]  : Endif
  If clalev([F:CPE])=0    : Local File CPCEMP      [CPE]    : Endif
  # Fin MABON
  #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If clalev([F:ADI])=0    : Local File ATABDIV      [ADI]   : Endif
  If clalev([F:EVM])=0    : Local File EVAEMPMIS    [EVM]   : Endif : # 13/02/14 - EXI 96649 US2420 Mission
  If clalev([F:MIS])=0    : Local File MISSION      [MIS]   : Endif : # 13/02/14 - FQ 96649 - US2420 - Mission
#LIPET - 2017-10-23 - X3-29324 - START
  If clalev([F:HRCTR1])=0  : Local File EMPLOCTR      [HRCTR1] : Endif
  If clalev([F:EVI])=0   : Local File EVAEMPACT     [EVI]  : Endif
  If clalev([F:EVI2])=0  : Local File EVAEMPACT     [EVI2]  : Endif
  If clalev([F:EVE3])=0  : Local File EVAEMP        [EVE3]  : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:MPI])=0   : Local File MISPOTIND     [MPI]   : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:MJI])=0   : Local File MISJOTIND     [MJI]   : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:EVC3])=0  : Local File EVAEMPCPC     [EVC3]  : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:EVD3])=0  : Local File EVAEMPDET     [EVD3]  : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:EVM3])=0  : Local File EVAEMPMIS     [EVM3]  : Endif #FRLAA - 2016-07-27 - REQUIREMENT 117178 US 3
  If clalev([F:EVIN])=0  : Local File EVAEMPIND     [EVIN]  : Endif #FRLAA - X3-11714-12859 2017-01-09
#LIPET - 2017-10-23 - X3-29324 - END

$INI_FLDS_CRIT
  If GFONCTION="GESCEV" Then
    If [M]CODCEV="" Then
      Read [F:CEV]CEV0=[M:CEV0]COD
    Endif
    Actzo [M]
    [M:DIA]CODCEV = [F:CEV]COD

    [M:DIA]ALLCPY=2 : [M:DIA]CPY=""
    [M:DIA]ALLFCY=2 : [M:DIA]FCY=""
    If [F:CEV]CPYCEV<>"" Then
      [M:DIA]ALLCPY=1 : [M:DIA]CPY=[F:CEV]CPYCEV
      If [F:CEV]FCYCEV<>"" Then [M:DIA]ALLFCY=1 : [M:DIA]FCY=[F:CEV]FCYCEV : Endif
    Else
      [M:DIA]ALLCPY=2
      Actzo [M:DIA]ALLCPY
    Endif
    [M:DIA]ALLSRV=2 : [M:DIA]SRV="" : If [F:CEV]SRVCEV<>"" Then [M:DIA]ALLSRV=1 : [M:DIA]SRV=[F:CEV]SRVCEV : Endif
    [M:DIA]WLEG=[F:CEV]LEG
    GCURLEG=[F:CEV]LEG
    #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules

     If GCURLEG="" & [M:DIA]CPY<>"" Then
      Read [F:CPY]CPY0=[M:DIA]CPY
      If !fstat Then
        Call LEG_CPY([M:DIA]CPY,GCURLEG)

      Endif
      If GCURLEG="" & [M:DIA]FCY<>"" Then
        Read [F:FCY]FCY0=[M:DIA]FCY
        If !fstat Then
           Read [F:CPY]CPY0=[F:FCY]LEGCPY
           If !fstat Then
              GCURLEG = [F:FCY]LEG
           Endif
        Endif
      Endif
    Endif
    If dim([M:DIA]LEG)>0 Then [M:DIA]LEG=GCURLEG : Endif

    [M:DIA]POP    = [F:CEV]POPCEV
    [M:DIA]PRF    = [F:CEV]PRFCEV
    LEGAXX=[F:CEV]LEG
    Call LECTEXTRA([M:DIA]PRFDES,"PROFIL","PRFDES",LEGAXX,[M:DIA]PRF) From ATEXTRA
    [M:DIA]POT    = [F:CEV]POTCEV
    [M:DIA]JOBPOT = [F:CEV]JOTCEV

    [M:DIA]EVATYP = [F:CEV]EVATYP
    [M:DIA]STRDAT = [F:CEV]STRDAT
    [M:DIA]ENDDAT = [F:CEV]ENDDAT

    Raz [M]MATSTR,[M]MATEND, [M]CRI
  Endif
Return

#####################################
$CONTROLE
Gosub CONTROLE_LEG_OK  ## MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If !WOK
     SAI=1 : Return
  Endif

  If GSTATUT<>GSTAOK or OK=0 Then
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif


Return

#**
#* Calcul des critères de sélection
#*!
$CALC_CRIT
  Gosub CALC_CRIT1
  Gosub CALC_CRIT2

  # On doit sélectionner les salariés dont la date d'entrée est <= à la date de début de période et <= à la date de fin de période
  # et dont la date de sortie, si elle est renseignée, est >= à la date de l'évaluation (donc date$)
  CRITERE3  = "1=1"
#  CRITERE3 -= "& (([F:HRCTR]CTRDAT<=["+format$(GFMD,[M:DIA]STRDAT)+"] | [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,date$)+"])"
#  CRITERE3 -= " | ([F:HRCTR]RETDATEFF<>[0/0/0] & [F:HRCTR]RETDATEFF<=["+format$(GFMD,[M:DIA]STRDAT)+"]))"
  CRITERE3 -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,date$)+"])"

  # FQ81491 - 18/10/13 - On doit aussi prendre la date de rétroactivité en compte
#  CRITERE4 = "([F:HRCTR]CTRDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"])"
  CRITERE4  = "([F:HRCTR]CTRDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"] | ([F:HRCTR]FLGRET=2 & [F:HRCTR]RETDATEFF<=["+format$(GFMD,[M:DIA]ENDDAT)+"]))"
  # Fin FQ81491
  CRITERE4 += "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=["+format$(GFMD,[M:DIA]ENDDAT)+"])"
Return

$CALC_CRIT1
Local Integer ONE_CRIT, I
Local Char    LIS_CPY(GLONCPY)(0..100)
  CRITERE1="1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE1 -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE1 += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE1 += "," : Endif
      Next
      CRITERE1 += ")>0"
    Else
      If [M:DIA]CPY <> ""
        CRITERE1="1=2"
      Endif
    Endif
  Endif

  If [M:DIA]ALLFCY<>2       Then CRITERE1  -= "& [F:FCY]FCY='"+[M:DIA]FCY+"'"       : Endif
  If [M:DIA]ALLSRV<>2       Then CRITERE1  -= "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"    : Endif

#  MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If dim([M:DIA]LEG)> 0 & [M:DIA]LEG<>""  Then CRITERE1  -=  "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)" : Endif

  If [M:DIA]POP<>""         Then CRITERE1  -= "& [F:HRPOA]COD='"+[M:DIA]POP+"'"       : Endif
  If [M:DIA]PRF<>""         Then CRITERE1  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"    : Endif
  If [M:DIA]POT<>""         Then CRITERE1  -= "& [F:HRCTR]POT='"+[M:DIA]POT+"'"       : Endif
  If [M:DIA]JOBPOT<>""      Then CRITERE1  -= "& [F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"'" : Endif
Return

$CALC_CRIT2
  CRITERE2="1=1"
  CRITERE2  -= "& [F:ID]FLGNEWSAL <> 2"
  If [M:DIA]MATSTR<>""      Then CRITERE2  -= "& [F:ID]REFNUM>='"+[M:DIA]MATSTR+"'" : Endif
  If [M:DIA]MATEND<>""      Then CRITERE2  -= "& [F:ID]REFNUM<='"+[M:DIA]MATEND+"'" : Endif
Return

#**#####################################################################################
#* Exécution de l'action
#*!
$EXEC
#SBA pb grp societes
Local Clbfile CRITERE1(2)
Local Char    CRITERE2(250), CRITERE3(250), CRITERE4(250)
Local Char    WFCY([V]GLONFCY), WCPY([V]GLONCPY)
Local Integer I, OKENR
Local Integer LOK, NBENREG_EVA, NBEVACRE
Local Char    LISTEVACRE(100)(0..)
#LIPET - 2017-10-23 - X3-29324 - START
Local Char    SAV_FCY([V]GLONFCY)
Local Integer ISTYPPREV
#LIPET - 2017-10-23 - X3-29324 - END

  If [M:DIA]SIMUL=1 Then
    Call OUINON(mess(191,10717,1), LOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
    If LOK = 1 Then SAI=1 : Return : Endif
  Endif

  TIT=mess(87,10720,1) : # Génération des entretiens
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If [M:DIA]SIMUL=2 Then
    Call ECR_TRACE(toupper(mess(27,107,1)),0) From GESECRAN : # SIMULATION
    Call ECR_TRACE("------------------------------------",0) From GESECRAN
  Endif
  Gosub CALC_CRIT
  #LIPET - 2017-10-25 - START
  #ADDMAN - ajout du manager lors de la création
  Gosub CALC_FLUX From SUBEVA
  #LIPET - 2017-10-25 - END
  If [M:DIA]POP<>"" Then
#MABOS-07/11/12-Modify HRPOA index
#    Link [F:ID] With [F:HRCTR]CTR0(0)=[F:ID]REFNUM, [F:FCY]FCY0=[F:HRCTR]ETRFCY, [F:HRPOA]POA0~=[M:DIA]POP;[F:ID]REFNUM As [ID_]
    Link [F:ID] With [F:HRCTR]CTR0(0)=[F:ID]REFNUM, [F:FCY]FCY0=[F:HRCTR]ETRFCY, [F:HRPOA]POA0~=[M:DIA]POP;[F:ID]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT As [ID_]

  Else
    Link [F:ID] With [F:HRCTR]CTR0(0)=[F:ID]REFNUM, [F:FCY]FCY0=[F:HRCTR]ETRFCY As [ID_]
  Endif

  Filter [F:ID_] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) & evalue(CRITERE4) Order By [F:ID]REFNUM;[F:HRCTR]CTRNUM
#  Trbegin [F:EVE], [F:EVC], [F:EVD]
#LIPET - 2017-10-23 - X3-29324 - START
#  Trbegin [F:EVE], [F:EVD], [F:EVM] # 13/02/14 - EXI 96649 US2420 Mission
  Trbegin [F:EVE], [F:EVC], [F:EVD], [F:EVM], [F:EVE3], [F:EVM3], [F:EVC3]
  NBEVACRE=0
#LIPET - 2017-10-23 - X3-29324 - END
  For [F:ID_]
    OKENR=1
    If [M:DIA]CRI<>"" Then
      # Lecture des enregistrements des tables EMPLOxxx pour évaluation de [M:DIA]CRI
      Read [F:AD]AD0=[F:ID]REFNUM
      Read [F:CPT]CPT0=[F:ID]REFNUM
      Filter [F:RIB] Where REFNUM=[F:ID]REFNUM : Read [F:RIB] Last : Filter [F:RIB]
      Filter [F:MED] Where REFNUM=[F:ID]REFNUM : Read [F:MED] Last : Filter [F:MED]
      Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:DIA]CRI,OKENR,0) From DIVPAYE
    Endif
#    If [M:DIA]LEG<>"" Then
#      LEGCTR=func TOOLSHRLEG.GETLEGFCY([F:HRCTR]ETRFCY)
#      If LEGCTR<>[M:DIA]LEG Then OKENR=0 : Endif
#    Endif
    If OKENR Then
      If find([F:ID]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+[M:DIA]STRDAT+"~"+[M:DIA]ENDDAT+"~"+[M:DIA]EVATYP,LISTEVACRE)>0 Then
        OKENR=0
      Endif
    Endif
    If OKENR Then
      LISTEVACRE(NBEVACRE)=[F:ID]REFNUM+"~"+[F:HRCTR]CTRNUM+"~"+[M:DIA]STRDAT+"~"+[M:DIA]ENDDAT+"~"+[M:DIA]EVATYP
      NBEVACRE+=1
      GOK=1
      Gosub MAJ_EVA : If GOK=0 Then Break : Endif
#LIPET - 2017-10-23 - X3-29324 - START
      If func AFNC.ACTIV("EVAEN")>0 : Gosub WRITE_MULREV : Endif
      If GOK=0 Then Break : Endif
#LIPET - 2017-10-23 - X3-29324 - END
    Endif
  Next

  If GOK Then
    If [M:DIA]SIMUL=1 Then
      Commit
    Else
      Rollback
    Endif
  Else
    Rollback
  Endif

  # Gestion de la trace
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If NBENREG_EVA>0 Then
    Call ECR_TRACE(mess(89,10720,1)-":"-num$(NBENREG_EVA),0) From GESECRAN : # Nombre d'entretiens d'évaluation créés
  Else
    Call ECR_TRACE(mess(90,10720,1),0) From GESECRAN : # Aucun entretien d'évaluation à traiter
  Endif
  Call FERME_TRACE From LECFIC
  # Fermeture de la fenêtre "Opération en cours"
  Call TEMPOFF From GESECRAN
  # Lecture de la trace, sinon avec SAI=1 plus bas, on ne la voit pas
  Call LEC_TRACE From LECFIC
  GMESSAGE=""
  # On retourne en saisie en fin de traitement (par exemple, pour lancer le traitement
  # en réel après l'avoir lancé en simulation)
  # MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  # - Only if Simulation
  If [M:DIA]SIMUL=2 Then
    SAI=1
  Endif
Return

#**
#* Création des évaluations
#*!
$MAJ_EVA
Local Integer AUZCFY, DUPLIC, I, OKENR
Local Char    EVAEAN(30), MESSEVA(250)
#LIPET - 2017-10-23 - X3-29324 - START
Local Date    WDATSTR, WDATEND
Local Integer WEVAVAL
Local Integer NOL : # MABOS 01/09/2017

  Raz WEVAVAL
  WDATSTR=[M:DIA]STRDAT
  WDATEND=[M:DIA]ENDDAT
#LIPET - 2017-10-23 - X3-29324 - END
  GOK=1 : DUPLIC=1

  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
  AUZCFY = func SUBHRSES.GET_AUZ([F:FCY]LEGCPY, [F:HRCTR]ETRFCY, "GESEVA")

  If AUZCFY=2 Then
#LIPET - 2017-10-23 - X3-29324 - START
#    # On cherche si l'évaluation existe déjà, et on en crée une nouvelle si elle n'existe pas encore
#    Read [F:EVE2]EVE0=[F:ID]REFNUM;[F:HRCTR]CTRNUM;[M:DIA]STRDAT;[M:DIA]ENDDAT;[M:DIA]EVATYP
#    If !fstat Then
#      If [F:EVE2]EVATYP<>[M:DIA]EVATYP Then
#        OKENR=1   : # même période, mais type différent ==> on crée
#      Else
#        OKENR=0   : # même période et même type ==> on ne crée pas
#      Endif
#    Else
#      OKENR=1
#      # Si une évaluation existe avec le même type d'entretien mais à une période différente, on duplique une partie de l'enregistrement
#      Filter [F:EVE2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR<[M:DIA]STRDAT Order By EVADATSTR Desc
#      For [F:EVE2]
#        If [F:EVE2]EVATYP=[M:DIA]EVATYP Then
#          DUPLIC=2 : Break
#        Endif
#      Next
#      Filter [F:EVE2]
#    Endif
    OKENR=0
    If [M:DIA]PREEVA = 2 # si au moins un paramètre prochaine evaluation ok pour les critères de campagne
      If [F:HRCTR]ETRFCY <> SAV_FCY
         SAV_FCY=[F:HRCTR]ETRFCY
         ISTYPPREV =func DIVEVA.IS_SOC_TYPEOF([F:HRCTR]ETRFCY,"EVAPRO",[M:DIA]EVATYP)  + func DIVEVA.IS_SOC_TYPEOF([F:HRCTR]ETRFCY,"EVABIL",[M:DIA]EVATYP)
      Endif
      If ISTYPPREV
          Filter [F:EVE2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVATYP=[M:DIA]EVATYP & NEXEVA<=[M:DIA]ENDDAT & NEXEVA>=[M:DIA]STRDAT  Order By EVADATSTR Desc
          Read [F:EVE2] Last
          If !fstat
            WDATSTR=[F:EVE2]EVADAT
            WDATEND=[F:EVE2]NEXEVA-1
            WEVAVAL=[F:EVE2]EVAVAL
            Read [F:EV1]EVE0=[F:ID]REFNUM;[F:HRCTR]CTRNUM;WDATSTR;WDATEND;[M:DIA]EVATYP
            If fstat : OKENR=1 : DUPLIC=2 : Endif
          Endif
          Filter [F:EVE2]
      Endif
    Else
      # On cherche si l'évaluation existe déjà, et on en crée une nouvelle si elle n'existe pas encore
      Read [F:EVE2]EVE0=[F:ID]REFNUM;[F:HRCTR]CTRNUM;WDATSTR;WDATEND;[M:DIA]EVATYP #US4124 112391
      If !fstat Then
        If [F:EVE2]EVATYP<>[M:DIA]EVATYP Then
          OKENR=1   : # même période, mais type différent ==> on crée
        Else
          OKENR=0   : # même période et même type ==> on ne crée pas
        Endif
      Else
        OKENR=1

        # Si une évaluation existe avec le même type d'entretien mais à une période différente, on duplique une partie de l'enregistrement
        Filter [F:EVE2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR<WDATSTR Order By EVADATSTR Desc #US4124 112391
        For [F:EVE2]
          If [F:EVE2]EVATYP=[M:DIA]EVATYP Then
            DUPLIC=2 : Break
          Endif
        Next
        Filter [F:EVE2]
      Endif
    Endif
#LIPET - 2017-10-23 - X3-29324 - END
    If OKENR Then
      Raz [F:EVE]
      [F:EVE]REFNUM    = [F:ID]REFNUM
      [F:EVE]CTRNUM    = [F:HRCTR]CTRNUM
      [F:EVE]CTRDAT    = [F:HRCTR]CTRDAT
      # On n'initialise pas la date d'évaluation
#       [F:EVE]EVADAT    = date$
      [F:EVE]EVATYP    = [M:DIA]EVATYP
#LIPET - 2017-10-23 - X3-29324 - START
      # Vérification de l'entretien professionnel
      [F:EVE]FLGPRO=func DIVPAYE.GET_VALTYPEVA("PRO",[F:HRCTR]ETRFCY,[M:DIA]EVATYP)
      # Vérification de l'entretien bilan
      [F:EVE]FLGBIL=func DIVPAYE.GET_VALTYPEVA("BIL",[F:HRCTR]ETRFCY,[M:DIA]EVATYP)
      # Vérification de l'entretien annuel
      [F:EVE]FLGYEA=func DIVPAYE.GET_VALTYPEVA("YEA",[F:HRCTR]ETRFCY,[M:DIA]EVATYP)
#LIPET - 2017-10-23 - X3-29324 - END
      # Vérification de l'entretien annuel
      Call PARAM([F:FCY]LEGCPY,"EVAYEA",EVAEAN) From ADOVAL
      If EVAEAN <> "" & [M:DIA]EVATYP=EVAEAN
        [F:EVE]FLGYEA=2
      Endif
#LIPET - 2017-10-23 - X3-29324 - START
#      [F:EVE]EVADATSTR = [M:DIA]STRDAT
#      [F:EVE]EVADATEND = [M:DIA]ENDDAT
      [F:EVE]EVADATSTR = WDATSTR
      [F:EVE]EVADATEND = WDATEND
#LIPET - 2017-10-23 - X3-29324 - END
      [F:EVE]CEV       = [M:DIA]CODCEV
      Call PARAM([F:HRCTR]ETRFCY,"EVASCA",[F:EVE]EVASCA) From ADOVAL
      [F:EVE]EVAVAL    = 1
      [F:EVE]FLGMOB=2 # SEGAY - 16/01/13 - EXI 87090 US1222 + 87537
#LIPET - 2017-10-23 - X3-29324 - START
      #Bloc Suivi
      [F:EVE]FLGACTFOR    = 1
      [F:EVE]FLGCERTIF    = 1
      [F:EVE]FLGEVO       = 1
      [F:EVE]EVAMAIREC    = 2
       If func AFNC.ACTIV("EVAEN")>0
        [F:EVE]EVAEMPSTA = 4
        If [M:CEV0]REVWEI = 0
          [F:EVE]REVWEI = 100
        Else
          [F:EVE]REVWEI       = [M:CEV0]REVWEI
        Endif
      Endif
#LIPET - 2017-10-23 - X3-29324 - END
      If DUPLIC=2 Then  : # Duplication partielle
        # Onglet Généralités
        [F:EVE]EVAMAT       = [F:EVE2]EVAMAT
        [F:EVE]EVALIB       = [F:EVE2]EVALIB
        [F:EVE]EVAMAT2      = [F:EVE2]EVAMAT2
        [F:EVE]EVALIB2      = [F:EVE2]EVALIB2
#LIPET - 2017-10-23 - X3-29324 - START
        [F:EVE]PRJPFL       = [F:EVE2]PRJPFL
#LIPET - 2017-10-23 - X3-29324 - END
        # Onglet Perspectives : on ne récupère ni les stages, ni la mobilité
#        [F:EVE]EVAPOT       = [F:EVE2]EVAPOT
#        [F:EVE]EVAJOB       = [F:EVE2]EVAJOB
#        [F:EVE]EVAJOBGRP    = [F:EVE2]EVAJOBGRP
#        [F:EVE]EVAJOBGRPDAT = [F:EVE2]EVAJOBGRPDAT
#        [F:EVE]FLGMOB       = [F:EVE2]FLGMOB
#        [F:EVE]AREDAT       = [F:EVE2]AREDAT
#        [F:EVE]ARE          = [F:EVE2]ARE
#        [F:EVE]EVAFCY       = [F:EVE2]EVAFCY
        # Onglet Commentaires : on récupère dans Entretien précédent, l'entretien évaluateur et collaborateur
        # de l'entretien précédent
#        [F:EVE]EVACMTNEW    = [F:EVE2]EVACMTNEW
#        [F:EVE]CMTMATNEW    = [F:EVE2]CMTMATNEW
      Endif
#LIPET - 2017-10-23 - X3-29324 - START
      #ADDMAN - ajout du manager lors de la création
      #On actualise si evalib=""
      If[F:EVE]EVALIB =""
        [F:EVE]EVAMAT =func SUBEVA.GET_CHEFNCTR([F:HRCTR]CTRNUM,WNIVMGR)
        fstat=0
      Endif
      If[F:EVE]EVALIB2 =""
        [F:EVE]EVAMAT2 =""
      Endif
#LIPET - 2017-10-23 - X3-29324 - END
      Call PARAM([F:HRCTR]ETRFCY,"EVAMIS",[F:EVE]EVAMIS) From ADOVAL : # 13/02/14 - EXI 96649 US2420 Mission
      fstat=0 : # 112991
      If [M:DIA]SIMUL=1 Then
        Write [F:EVE]
      Endif
      If fstat Then
        GOK=0 : Call FSTA("EVE") From GLOCK
      Else
        If DUPLIC=2 Then  : # Duplication partielle
          # Onglet Performances : on récupère les "Nouveaux objectifs" de l'entretien précédent, donc TYPBOJ=2
#LIPET - 2017-10-23 - X3-29324 - START
          Filter [F:EVD2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR=[F:EVE2]EVADATSTR
&                         & EVADATEND=[F:EVE2]EVADATEND & TYPOBJ=2 & EVAMAT = [F:EVE2]EVAMAT
          NOL=0
#          Filter [F:EVD2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR=[F:EVE2]EVADATSTR
#&                             & EVADATEND=[F:EVE2]EVADATEND & TYPOBJ=2
#LIPET - 2017-10-23 - X3-29324 - END
          For [F:EVD2]
            Raz [F:EVD]
            [F:EVD]          = [F:EVD2]
#LIPET - 2017-10-23 - X3-29324 - START
#            [F:EVD]EVADATSTR = [M:DIA]STRDAT
#            [F:EVD]EVADATEND = [M:DIA]ENDDAT
            [F:EVD]          = [F:EVE]
            [F:EVD]NUMLIG    = NOL
            [F:EVD]EVADATSTR = WDATSTR
            [F:EVD]EVADATEND = WDATEND
#LIPET - 2017-10-23 - X3-29324 - END
            [F:EVD]TYPOBJ    = 1
#LIPET - 2017-10-23 - X3-29324 - START
            [F:EVD]ORIDET    = 2
#LIPET - 2017-10-23 - X3-29324 - END
            If [M:DIA]SIMUL=1 Then
              Write [F:EVD]
            Endif
            If fstat Then
              GOK=0 : Call FSTA("EVD") From GLOCK : Break
            Endif
          Next
          Filter [F:EVD2]
          If GOK Then
#LIPET - 2017-10-23 - X3-29324 - START
            # Onglet Compétences : on ne récupère rien
#            Filter [F:EVC2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR=[F:EVE2]EVADATSTR
#&                                 & EVADATEND=[F:EVE2]EVADATEND & EVATYPCPC=1
#            For [F:EVC2]
#              Raz [F:EVC]
#              [F:EVC] = [F:EVC2]
#              If [M:DIA]SIMUL=1 Then
#                Write [F:EVC]
#              Endif
#              If fstat Then
#                GOK=0 : Call FSTA("EVC") From GLOCK : Break
#              Endif
#            Next
#            Filter [F:EVC2]
            # Onglet Perspectives  : on récupère les "Action" de l'entretien précédent
            Filter [F:EVI2] Where REFNUM=[F:ID]REFNUM & CTRNUM=[F:HRCTR]CTRNUM & EVADATSTR=[F:EVE2]EVADATSTR
&                             & EVADATEND=[F:EVE2]EVADATEND & EVATYP=[F:EVE2]EVATYP & EVAMAT = [F:EVE2]EVAMAT
            For [F:EVI2]
              Raz [F:EVI]
              [F:EVI]          = [F:EVI2]
              [F:EVI]EVAMAT    = [F:EVE2]EVAMAT
              [F:EVI]EVADATSTR = WDATSTR
              [F:EVI]EVADATEND = WDATEND
              If [M:DIA]SIMUL=1 Then
                Write [F:EVI]
              Endif
              If fstat Then
                GOK=0 : Call FSTA("EVI") From GLOCK : Break
              Endif
            Next
            Filter [F:EVI2]
#LIPET - 2017-10-23 - X3-29324 - END
          Endif
        Endif
        # 13/02/14 - EXI 96649 US2420 Mission
        Gosub MAJ_POT_JOBPOT
        Gosub MAJ_EVAEMPMIS

        # FQ87153 - MABON 17/01/13 - Ajout bouton "Initialisation compéences"
        If [M:DIA]INICPC=2 Then
          Gosub MAJ_CPC
        Endif
        # Fin MABON
      Endif
    Else
     If [M:DIA]PREEVA <> 2
      # Matricule xxx / Contrat yyy : Entretien d'évaluation déjà existant
      MESSEVA = mess(1,10319,1)-[F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN-"/"-mess(72,10720,1)-[F:HRCTR]CTRNUM-":"-mess(92,10720,1)
      Call ECR_TRACE(MESSEVA,-1) From GESECRAN
      Endif
    Endif

    If GOK & OKENR Then
      NBENREG_EVA += 1
      # Matricule xxx / Contrat yyy :
      MESSEVA = mess(1,10319,1)-[F:ID]REFNUM-[F:ID]NAM-[F:ID]SRN-"/"-mess(72,10720,1)-[F:HRCTR]CTRNUM-":"
      If DUPLIC<>2 Then
        MESSEVA -= mess(88,10720,1) : # Création entretien évaluation
      Else
#LIPET - 2017-10-23 - X3-29324 - START
       # MESSEVA -= mess(91,10720,1)-format$("DD2",[F:EVE2]EVADATSTR)-mess(95,100,1)-format$("DD2",[F:EVE2]EVADATEND) : # Duplication de l'entretien d'évaluation du ... au ...
        If [M:DIA]PREEVA = 2 & WEVAVAL = 10
          MESSEVA -= mess(88,10720,1)-mess(94,100,1)-format$("DD2",WDATSTR)-mess(95,100,1)-format$("DD2",WDATEND) : # Création entretien évaluation Du ... au ...
        Else
          MESSEVA -= mess(91,10720,1)-format$("DD2",WDATSTR)-mess(95,100,1)-format$("DD2",WDATEND) : # Duplication de l'entretien d'évaluation du ... au ...
        Endif
#LIPET - 2017-10-23 - X3-29324 - END
      Endif
      Call ECR_TRACE(MESSEVA,0) From GESECRAN
    Endif
  Endif
Return

# 13/02/14 - EXI 96649 US2420 Mission
$MAJ_POT_JOBPOT
If clalev([M:EVA0])=0 : Local Mask EVA0 [EVA0] : Endif
Raz [M:EVA0]
#LIPET - 2017-10-23 - X3-29324 - START
#[M:EVA0]EVADATEND=[M:DIA]ENDDAT
[M:EVA0]EVADATEND=WDATEND
#LIPET - 2017-10-23 - X3-29324 - END
Gosub INI_POT_JOBPOT From SUBEVA
Return

# 13/02/14 - EXI 96649 US2420 Mission
$MAJ_EVAEMPMIS
Local Integer WIS_GENCEV
If clalev([M:EVA7])=0 : Local Mask EVA7 [EVA7] : Endif
Raz [M:EVA7]
[L]WIS_GENCEV=1
Gosub INIT_MIS From SUBEVA
If [M:DIA]SIMUL=1 Then
  Gosub SAUVE_EVAEMPMIS From SUBEVA
Endif
Return

# FQ87153 - MABON 17/01/13 - Ajout bouton "Initialisation compéences"
$MAJ_CPC
#LIPET - 2017-10-23 - X3-29324 - START
#Local Char POT(30), JOBPOT(30)
Local  Char    POT(GLONPOT), JOBPOT(GLONJOT)
Global Integer IS_GENCEV
#LIPET - 2017-10-23 - X3-29324 - END
Local  Char    POTCTR(GLONPOT),JOTCTR(GLONJOT)

#  If clalev([M:EVA0])=0 : Local Mask EVA0 [EVA0] : Endif
  If clalev([M:EVA2])=0 : Local Mask EVA2 [EVA2] : Endif
#  Raz [M:EVA0]
  Raz [M:EVA2]

# 13/02/14 - EXI 96649 US2420 Mission in $MAJ_POT_JOBPOT
#  Filter [F:EPO] Where [EPO]REFNUM=[F:ID]REFNUM & [EPO]CTRNUM=[F:HRCTR]CTRNUM & [EPO]DATPOT<=[M:DIA]ENDDAT Order By DATPOT
#  Read [F:EPO] Last
#  Filter [F:EPO]
#  If !fstat & ([F:EPO]POT<>"" | [F:EPO]JOBPOT<>"") Then
#    [M:EVA0]POT    = [F:EPO]POT
#    [M:EVA0]JOBPOT = [F:EPO]JOBPOT
#  Else
#    [M:EVA0]POT    = [F:HRCTR]POT
#    [M:EVA0]JOBPOT = [F:HRCTR]JOBPOT
#  Endif

  [M:EVA0]REFNUM=[F:ID]REFNUM
#LIPET - 2017-10-23 - X3-29324 - START
  [V]IS_GENCEV=1
#LIPET - 2017-10-23 - X3-29324 - END
  Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
  If !fstat Then
    [M:EVA0]EVALEG = [F:FCY]LEG
  Endif
  mkstat=0 : Call B1_NBRCPC From SUBEVA
  mkstat=0 : Call B1_NBRVAL From SUBEVA
#LIPET - 2017-10-23 - X3-29324 - START
#  Gosub SAUVE_EVACPC From SUBEVA
  Kill [V]IS_GENCEV
  If [M:DIA]SIMUL=1 Then
    Gosub SAUVE_EVACPC From SUBEVA
  Endif
#LIPET - 2017-10-23 - X3-29324 - END
Return
# Fin MABON

$FIN
Return

#LIPET - 2017-10-23 - X3-29324 - START
$WRITE_MULREV
#Create a record for each additional reviewer
Local Integer I
Local Char TMP_MAT(30)
Local Char MNGRLIST(30)(1..)

Delete [EVE3] Where [EVE3]REFNUM = [F:EVE]REFNUM & [EVE3]CTRNUM = [F:EVE]CTRNUM & [EVE3]EVADATSTR = [F:EVE]EVADATSTR & [EVE3]EVADATEND = [F:EVE]EVADATEND & [EVE3]EVATYP = [F:EVE]EVATYP & [EVE3]
& EVAMAIREC = 1
If fstat = 1
  GOK = -1
  GLOCK = "EVE3" - [F:EVE]REFNUM- [F:EVE]CTRNUM - [F:EVE]EVATYP
Elsif fstat>5
  GOK = 0
  Call RSTA("EVE3" - [F:EVE]REFNUM- [F:EVE]CTRNUM - [F:EVE]EVATYP) From GLOCK
  Return
Endif

MNGRLIST(1)         = [F:EVE]EVAMAT
#Loop through the multiple reviewers
For I = 1 To [M:CEV0]NBRMULREV
  TMP_MAT = ""

  #Get the reviewer - multiple reviewer TMP_MAT
  Call GETCHEFNCTR_NCTRL([F:EVE]CTRNUM,[M:CEV0]MULTYPMGR(I-1),TMP_MAT)From PORMAT
  #Check if blank manager returns, log all cases
  If find(TMP_MAT,MNGRLIST(1..)) <> 0 or TMP_MAT = ""
    GOK = 0
    Call ECR_TRACE(toupper(num$([F:EVE]REFNUM) - num$([F:EVE]CTRNUM) - mess([M:CEV0]MULTYPMGR(I-1),50,1))- mess(00126,00143,1),0) From GESECRAN
  Endif
    Raz [F:EVE3]
    [F:EVE3]              = [F:EVE]
    [F:EVE3]REVWEI        = [M:CEV0]MULREVWEI(I-1)
    [F:EVE3]EVAMAIREC     = 1
    [F:EVE3]EVAEMPSTA     = 4
    [F:EVE3]EVAMAT        = TMP_MAT
    MNGRLIST(I+1)         = TMP_MAT
    Write [EVE3]
    If fstat
      GOK = 0
    Endif

#FRLAA 2017-01-31 X3-11377 Task X3-23631 - START
#EVAEMPCPC
If [M:DIA]INICPC=2 Then


    If GOK>0
      Delete [EVC3] Where [EVC3]REFNUM=[F:EVE]REFNUM & [EVC3]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC3]EVADATSTR=[F:EVE]EVADATSTR & [EVC3]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC3]EVATYP=[F:EVE]EVATYP & [EVC3]EVAMAT=TMP_MAT
&                  & [EVC3]EVATYPCPC=1

      If fstat = 1
        GOK = -1
        GLOCK = "$CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVC]EVACPCDAT
    Elsif fstat>5
      GOK = 0
      Call RSTA("CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVC]EVACPCDAT) From GLOCK
        Return
      Endif

      For [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC]EVATYP=[F:EVE]EVATYP & [EVC]EVAMAT=[F:EVE]EVAMAT
&                  & [EVC]EVATYPCPC=1
        Raz [F:EVC3]
        [F:EVC3]              = [F:EVC]
        [F:EVC3]EVAMAT        = TMP_MAT
        Write [EVC3]
        If fstat
          GOK = 0
        Endif
      Next
    Endif

    If GOK>0
      Delete [EVC3] Where [EVC3]REFNUM=[F:EVE]REFNUM & [EVC3]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC3]EVADATSTR=[F:EVE]EVADATSTR & [EVC3]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC3]EVATYP=[F:EVE]EVATYP & [EVC3]EVAMAT=TMP_MAT
&                  & [EVC3]EVATYPCPC=2

      If fstat = 1
        GOK = -1
        GLOCK = "$CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVC]EVACPCDAT
    Elsif fstat>5
      GOK = 0
      Call RSTA("CPCEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVC]EVACPCDAT) From GLOCK
        Return
      Endif

      For [EVC] Where [EVC]REFNUM=[F:EVE]REFNUM & [EVC]CTRNUM=[F:EVE]CTRNUM
&                  & [EVC]EVADATSTR=[F:EVE]EVADATSTR & [EVC]EVADATEND=[F:EVE]EVADATEND
&                  & [EVC]EVATYP=[F:EVE]EVATYP & [EVC]EVAMAT=[F:EVE]EVAMAT
&                  & [EVC]EVATYPCPC=2
        Raz [F:EVC3]
        [F:EVC3]              = [F:EVC]
        [F:EVC3]EVAMAT        = TMP_MAT
        Write [EVC3]
        If fstat
          GOK = 0
        Endif
      Next
    Endif
Endif
#FRLAA 2017-01-31 X3-11377 Task X3-23631 - END

#EVAEMPMIS
    If GOK>0
      Delete [EVM3] Where [F:EVM3]REFNUM=[F:EVE]REFNUM & [F:EVM3]CTRNUM=[F:EVE]CTRNUM
& &   [F:EVM3]EVADATSTR=[F:EVE]EVADATSTR & [F:EVM3]EVADATEND=[F:EVE]EVADATEND
& &   [F:EVM3]EVATYP=[F:EVE]EVATYP & [F:EVM3]EVAMAT = [F:EVE]EVAMAT
      If fstat = 1
        GOK = -1
        GLOCK = "$MISEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVE]EVATYP
      Elsif fstat>5
        GOK = 0
        Call RSTA("MISEMP"-[F:EVE]REFNUM-[F:EVE]CTRNUM-[F:EVE]EVADAT-[F:EVE]EVATYP) From GLOCK
        Return
      Endif

      For [EVM] Where [F:EVM]REFNUM=[F:EVE]REFNUM & [F:EVM]CTRNUM=[F:EVE]CTRNUM
& &   [F:EVM]EVADATSTR=[F:EVE]EVADATSTR & [F:EVM]EVADATEND=[F:EVE]EVADATEND
& &   [F:EVM]EVATYP=[F:EVE]EVATYP & [F:EVM]EVAMAT = [F:EVE]EVAMAT
        [F:EVM3]              = [F:EVM]
        [F:EVM3]EVAMAT        = TMP_MAT
        Write [EVM3]
        If fstat
          GOK = 0
        Endif
      Next
    Endif
  NBENREG_EVA += 1
Next
If GOK = 0 : NBENREG_EVA = 0 : Endif
Return
#LIPET - 2017-10-23 - X3-29324 - END

$SORTIE
#MABOS-05/03/13-88428-repositionnement sur fiche de GESCEV
If GFONCTION="GESCEV" Then
  Read [F:CEV]CEV0=[M:CEV0]COD
  GCURLEG=[F:CEV]LEG
Endif
Return
#LIPET - 2017-10-23 - X3-29324 - START
#**
#*
#*
#* @param VALEUR : type of interview
#*!
Subprog AFF_INTTYPENT(VALEUR,CPY,FCY)
Value Char VALEUR()
Value Char CPY
Value Char FCY
Local Integer CHK
Local Char LIBTYPINT(30)(1..2)
  CHK=0
  Call AFF_CHK_INTTYPENT(VALEUR,CPY,FCY,CHK,LIBTYPINT) From SUBCEV
  If LIBTYPINT(1) = mess(156,10720,1) : #"Prochain entretien déb."
    [M:DIA]PREEVA =2
  Else
    [M:DIA]PREEVA =1
  Endif
  Chgtzn[M:DIA]STRDAT With LIBTYPINT(1)
  #TODO pas en V6
  Chgtzn[M:DIA]ENDDAT With LIBTYPINT(2)
End
#LIPET - 2017-10-23 - X3-29324 - END
######################################################################################
## Gestion des champs de l'écran
######################################################################################
#LIPET - 2017-10-23 - X3-29324 - START
Subprog AV_INICPC(VALEUR)
Variable Integer VALEUR
  Call AFF_INTTYPENT([M:DIA]EVATYP,[M:DIA]CPY,[M:DIA]FCY)
End
#LIPET - 2017-10-23 - X3-29324 - END
Subprog AV_ALLCPY(VALEUR)
Variable Integer VALEUR
  Call AV_ALLCPY(VALEUR) From TOOLSVAR
End

#Subprog AS_ALLCPY(VALEUR)
#Variable Integer VALEUR
#  Call AS_ALLCPY(VALEUR) From TOOLSVAR
#End


#Subprog AS_CPY(VALEUR)
#Variable Char    VALEUR()
#  Call AS_CPY(VALEUR) From TOOLSVAR
#End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char CRITERE1(250), LISTLEG(5)(1..10)
Local Integer NBLEG, NBCPY
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If !(func LEG_MODIF) Then
      Call C_CPYCEV(VALEUR) From SUBCEV
  Endif
#LIPET - 2017-10-23 - X3-29324 - START
 Call AFF_INTTYPENT([M:DIA]EVATYP,VALEUR,[M:DIA]FCY)
#LIPET - 2017-10-23 - X3-29324 - END
End

Subprog AV_ALLFCY(VALEUR)
Variable Integer VALEUR
  Call AV_ALLFCY(VALEUR) From TOOLSVAR
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  Call AS_ALLFCY(VALEUR) From TOOLSVAR
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
  Call C_ALLFCY(VALEUR) From TOOLSVAR
#LIPET - 2017-10-23 - X3-29324 - START
  Call AFF_INTTYPENT([M:DIA]EVATYP,[M:DIA]CPY,[M:DIA]FCY)
#LIPET - 2017-10-23 - X3-29324 - END
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()

  If GCURLEG<>"" Then
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      Call LECTURE("FCY", VALEUR, "") From CONTOBJ
      If !fstat Then
        If [F:FCY]LEG<>GCURLEG Then
           VALEUR=""
        Endif
      Endif
   Endif

End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
  If (func LEG_MODIF) Then
    If GCURLEG<>"" Then
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      Call LECTURE("FCY", VALEUR, "") From CONTOBJ
      If !fstat Then
        If [F:FCY]LEG<>GCURLEG Then
          GMESSAGE=mess(3,45,1)-":"-VALEUR+chr$(10)+chr$(13)+mess(62,127,1)-[F:FCY]LEG : # Réservé à la législation
          mkstat=2 : End
        Endif
      Endif
    Endif
  Endif
  Call C_FCY(VALEUR, "GENCEV") From TOOLSVAR
#LIPET - 2017-10-23 - X3-29324 - START
  Call AFF_INTTYPENT([M:DIA]EVATYP,[M:DIA]CPY,VALEUR)
#LIPET - 2017-10-23 - X3-29324 - END

End

Subprog AV_ALLSRV(VALEUR)
Variable Integer VALEUR

  Call AV_ALLSRV(VALEUR) From TOOLSVAR
End

Subprog D_ALLSRV(VALEUR)
Variable Integer VALEUR

  Call D_ALLSRV(VALEUR) From TOOLSVAR
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR

  Call C_ALLSRV(VALEUR) From TOOLSVAR
End

Subprog AS_SRV(VALEUR)
Variable Char    VALEUR()

  Call AS_SRV(VALEUR) From TOOLSVAR
End

Subprog AS_MATEND(VALEUR)
Variable Char    VALEUR()

  Call INIT_ZONE(VALEUR, "MATSTR") From TOOLSVAR
End

Subprog C_MATEND(VALEUR)
Variable Char    VALEUR()

  Call C_MATEND(VALEUR) From TOOLSVAR
  # No ACTION CONTROLE in this screen, so control on last field seizable:
  If !mkstat & (varmode([M]CRI)>0 | func CRI_SAISI ) Then
    Diszo [M]CRI
    Gosub CONTROLE_LEG_OK From GENCEV
    If !WOK :  mkstat = 2 : End :  Endif
  Endif

End

Subprog AM_POT(VALEUR)
Variable Char    VALEUR()

  If clalev([F:POT])=0 : Local File POSTE [POT] : Endif
  Call LECTURE("POT",VALEUR,"") From CONTOBJ
  If [F:POT]JOBPOT<>""
    [M:DIA]JOBPOT = [F:POT]JOBPOT
    Affzo [M:DIA]JOBPOT,ZJOBPOT
  Endif
End

Subprog AM_CODCEV(VALEUR)
Variable Char    VALEUR()

  If VALEUR="" Then End : Endif
  If clalev([F:CEV])=0 : Local File COMPEVAL [CEV] : Endif
  Call LECTURE("CEV", VALEUR, "") From CONTOBJ
  If !fstat Then
    Gosub INIT_DIA
#    [M:DIA]EVATYP = [F:CEV]EVATYP
#    [M:DIA]STRDAT = [F:CEV]STRDAT
#    [M:DIA]ENDDAT = [F:CEV]ENDDAT

    Affzo [M:DIA]
    Setmok [M] With 0
  Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
Local    Char    LEGCPY(5)

 If  func LEG_MODIF Then
  [M]ALLFCY=2 : [M]FCY="" : [M]ZFCY="" : Affzo [M]FCY, ZFCY
  Call AM_CPY_FCY(VALEUR)
 Endif

End


Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
 If   func LEG_MODIF  Then
  If VALEUR<>"" Then
    Read [F:FCY]FCY0=VALEUR
    If !fstat Then
      Read [F:CPY]CPY0=[F:FCY]LEGCPY
      Call AM_CPY_FCY([F:FCY]LEGCPY)
    Endif
  Else
    Call AM_CPY_FCY([M]CPY)
  Endif
 Endif

End

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
 If   func LEG_MODIF Then
# Equivalent à action BMALLCPY
  If dim([M:DIA]LEG)>0 & VALEUR=2 Then
    If [M:DIA]LEG<>""
       [M:DIA]LEG="" :#MABOSMABOS
       Actzo [M:DIA]LEG : Affzo [M:DIA]LEG, ZLEG
       GCURLEG = [M:DIA]LEG
       Call INIT_BYLEG([M:DIA]LEG)
    Endif
    Actzo [M:DIA]LEG : Affzo [M:DIA]LEG, ZLEG
  Endif
 Endif

End

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
 If  func LEG_MODIF  Then
   If VALEUR=2 Then
      If [M:DIA]ALLCPY=2 Then
        Actzo [M:DIA]LEG : Affzo [M:DIA]LEG, ZLEG
      Else
        Call AM_CPY_FCY([M]CPY)
      Endif
   Endif
 Endif
End

Subprog AM_PRF(VALEUR)
Variable Char    VALEUR()
Local    Char    LEGAXX(30)

  LEGAXX=GCURLEG
  Call LECTEXTRA([M]PRFDES,"PROFIL","PRFDES",LEGAXX,VALEUR) From ATEXTRA
End

Subprog C_PRF(VALEUR)
Variable Char    VALEUR()
Local    Char    LEG(5)
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If VALEUR ="" : End : Endif
  If dim([M:DIA]LEG)  >0
    [L]LEG=[M:DIA]LEG
  Else
    [L]LEG=GCURLEG
  Endif
  If clalev([F:PRF])=0 : Local File PROFIL [PRF] : Endif
  If [L]LEG<>"" Then
    Read [F:PRF]PRF0=[L]LEG;VALEUR
  Endif
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  Call CONTROLE("PRF","!",VALEUR,[L]LEG,mkstat) From CONTOBJ
  If mkstat : GERR = 1  : Endif
End


Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
Local Char LEGCPY(5)
#MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If [F:CEV]CPYCEV<>""  Then
    Diszo [M:DIA]ALLCPY, CPY :#, LEG
  Endif
  If func LEG_MODIF Then
    Call LEG_CPY(VALEUR,[L]LEGCPY)
  Endif
  If !(func LEG_MODIF) | [L]LEGCPY<> "" Then Diszo [M:DIA]LEG : Endif
  If [M:DIA]ALLCPY=2    Then Diszo [M:DIA]CPY : Endif


End

Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  If [F:CEV]FCYCEV<>""  Then Diszo [M:DIA]ALLFCY, FCY  : Endif
  If [M:DIA]ALLFCY=2    Then Diszo [M:DIA]FCY          : Endif
End

Subprog AV_POP(VALEUR)
Variable Char    VALEUR()

  If [F:CEV]POPCEV<>"" Then  Diszo [M:DIA]POP :  Endif
End

Subprog AV_PRF(VALEUR)
Variable Char    VALEUR()
  #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If [F:CEV]PRFCEV<>"" Then
      Diszo [M:DIA]PRF
  Else
    If GCURLEG="" Then
      Diszo [M:DIA]PRF
    Else
      Actzo  [M:DIA]PRF
    Endif
  Endif
End


Subprog AS_PRF(VALEUR)
Variable Char    VALEUR()
  Call AV_PRF(VALEUR)
End

Subprog AV_POT(VALEUR)
Variable Char    VALEUR()

  If [F:CEV]POTCEV<>"" Then Diszo [M:DIA]POT : Endif
End

Subprog AV_JOBPOT(VALEUR)
Variable Char    VALEUR()

  If [F:CEV]JOTCEV<>"" Then Diszo [M:DIA]JOBPOT : Endif
End



Subprog AV_SRV(VALEUR)
Variable Char    VALEUR()

  If [F:CEV]SRVCEV<>"" Then Diszo [M:DIA]ALLSRV, SRV : Endif
End

Subprog AV_CRI(VALEUR)
Variable Char    VALEUR()

  Actzo [M:DIA]CRI
  #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
#  If [M:DIA]CPY<>"" | [M:DIA]FCY<>"" | [M:DIA]SRV<>"" | [M:DIA]LEG<>"" | [M:DIA]POP<>"" | [M:DIA]PRF<>""
#&  | [M:DIA]POT<>"" | [M:DIA]JOBPOT<>"" Then
  If func CRI_SAISI  Then
    [L]VALEUR=""
    Diszo [M:DIA]CRI
    Gosub CONTROLE_LEG_OK From GENCEV
  Endif
End


Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()

  #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
  If !(func LEG_MODIF)  Then Diszo [M:DIA]LEG : Endif
End

# SBA   28/08/2013 US 1835 81085
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
If GCURLEG<>VALEUR
   Call INIT_BYLEG(VALEUR)
Endif
GCURLEG=VALEUR
End


######################################################################################

######################################################################################

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Local    Integer I, J, K
Local    Char    LIS_CPY(GLONCPY)(0..100), LIS_LEG(5)(0..100)

  If VALEUR="" Then End : Endif

  I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
  If I>0 Then : # C'est un groupe de sociétés
    J=0
    For K=0 To I-1
      Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
      If !find([F:CPY]LEG, LIS_LEG)Then
        LIS_LEG(J)=[F:CPY]LEG
        J+=1
      Endif
    Next
    J-=1
    If !find(VALEUR,LIS_LEG(0..J)) Then
      GMESSAGE=mess(93,10720,1)-[M:DIA]CPY : # Cette législation ne fait pas partie des législations du groupe de sociétés
      mkstat=2
    Endif
  Endif
End


# #MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
Subprog INIT_BYLEG(VALEUR)
Value Char VALEUR
# call by DIVPAYE# Raz all fields after Leg, if leg is modified
GCURLEG=VALEUR
If [F:CEV]SRVCEV ="" Then [M]ALLSRV=2 : Raz [M]SRV, [M]ZSRV  : Affzo [M]ALLSRV,SRV,ZSRV : Endif
If [F:CEV]POPCEV ="" Then Raz [M]POP, [M]ZPOP  : Affzo [M]POP,ZPOP  : Endif
If [F:CEV]PRFCEV ="" Then Raz [M:DIA]PRF, [M:DIA]PRFDES : Affzo [M:DIA]PRF, PRFDES  : Endif
If [F:CEV]POTCEV ="" Then Raz [M]POT, [M]ZPOT  : Affzo [M]POT,ZPOT  : Endif
If [F:CEV]JOTCEV ="" Then Raz [M]JOBPOT,[M]ZJOBPOT : Affzo [M]JOBPOT,ZJOBPOT : Endif

Raz [M]MATSTR,[M]MATEND, [M]CRI
Affzo [M]MATSTR,MATEND, CRI
End


Subprog AV_LEG(VALEUR)
Variable Char    VALEUR()
  If !(func LEG_MODIF) Then Diszo [M:DIA]LEG : Endif
  If [M]FCY<> "" Then Diszo [M:DIA]LEG : Endif
End

Subprog S_CPY(VALEUR)
Variable Char    VALEUR()
Local Char WSAVLEG(5)
Local Char PARMSK(250)(1..16)

#If !(func LEG_MODIF) Then
   WSAVLEG=GLEGFIL
  GLEGFIL=GCURLEG
#Endif
PARMSK(1) = "CPY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION

#If !(func LEG_MODIF) Then
   GLEGFIL=WSAVLEG
#Endif
End

Funprog LEG_MODIF
Local Integer RESULT
RESULT =1
#If [M]WLEG <> "" | [M]WLEGTYP <> "" Then
If [M]WLEG <> "" | dim([M:DIA]LEG)<1 Then
  RESULT= 0
Endif
End RESULT


Subprog LEG_CPY(WCPY, WLEG)
Variable Char WCPY, WLEG

Local    Integer I, K, DIFF_LEG
Local    Char    LEG(5), LIS_CPY(GLONCPY)(0..100)
#MABOS-19/02/13
If [L]WLEG="" &  func LEG_MODIF Then
  If [L]WCPY<>"" Then
    I=0 : Call CALC_GRPCPY([L]WCPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then : # C'est un groupe de sociétés
      [L]LEG="" : DIFF_LEG=1
      For K=0 To I-1
        Call LECTURE("CPY", LIS_CPY(K), "") From CONTOBJ
        If [L]LEG="" Then LEG=[F:CPY]LEG : Endif
        If [L]LEG<>[F:CPY]LEG Then
          DIFF_LEG=2 : Break
        Endif
      Next
      If DIFF_LEG=1 Then : # Toutes les sociétés du groupe ont la même leg
        [L]WLEG=[L]LEG
      Else               : # Les sociétés du groupe ont des legs différentes
        [L]WLEG=""
      Endif
    Else
      Read [F:CPY]CPY0=[L]WCPY # MABOS-28/03/13
      If !fstat Then
        [L]WLEG=[L]LEG
      Endif
    Endif
   Endif
  Endif

End


Subprog AM_CPY_FCY(VALEUR)
Variable Char    VALEUR()
Local    Char    LEGCPY(5)

 If  func LEG_MODIF Then
  Call LEG_CPY(VALEUR,[L]LEGCPY)

  If [M:DIA]LEG<>[L]LEGCPY Then
    [M:DIA]LEG=[L]LEGCPY
    GCURLEG = [M:DIA]LEG
    Call INIT_BYLEG([M:DIA]LEG)
  Endif

  If [L]LEGCPY="" Then
      Actzo [M:DIA]LEG
    Else
      Diszo [M:DIA]LEG
    Endif
    Affzo [M:DIA]LEG, ZLEG
  Endif



End
#end MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
######################################################################################

$CONTROLE_LEG_OK
# MABOS - 22/02/13 - FQ81085  -US1332 - Add Legislation + Generic rules
Local Integer WOK
Local Char WECR(50)
Local Char WLIBCOUR(50)
Local Char WMESSAGE(250)
Local Char WFIELD(50) (1..6)
Local Integer WONCAMP(1..6)
Local Char WLEG(GLONADI) (1..6)
# SBA : error if [F:CEV]LEG<>""
WOK=1
Local Integer K, WTEST

              Local Char  LISTLEG(5)(1..10)
              Local Integer NBLEG, NBCPY

#  If dim([M:DIA]LEG)>0 & [M:DIA]LEG ="" Then
   If dim([M:DIA]LEG)>0 & [F:CEV]LEG ="" Then
    WOK=0
    K=0

    WECR="GENCEV"

    K+=1
    WLEG(K)=[M:DIA]LEG       :# Législation
    WOK = 1
    If [M:DIA]LEG <>"" & varmode([M:DIA]LEG) >0 Then
        If [M:DIA]FCY<>"" Then
          WFIELD(K)="FCY"
          If [F:CEV]FCYCEV ="" Then WONCAMP(K)=0 Else WONCAMP(K)=1 :Endif
        Elsif [M:DIA]CPY<>"" Then
          WFIELD(K)="CPY"
          If [F:CEV]CPYCEV ="" Then WONCAMP(K)=0 Else WONCAMP(K)=1 :Endif
        Endif
    Else
          WFIELD(K)="LEG" :  WONCAMP(K)=0
    Endif

    K+=1
    Call GET_LEGSRV([M]SRV,WOK,WLEG(K),0)    From TOOLSHRLEG        :# Service
    WFIELD(K)="SRV"
    If [F:CEV]SRVCEV ="" Then
      WONCAMP(K)=0
    Else
      WONCAMP(K)=1
    Endif

    K+=1
    Call GET_LEGPOP([M]POP,WOK, WLEG(K), 0)  From TOOLSHRLEG        :# Population
    WFIELD(K)="POP"
    If [F:CEV]POPCEV ="" Then
      WONCAMP(K)=0
    Else
      WONCAMP(K)=1
    Endif


    K+=1
    Call GET_LEGPOT([M]POT,WOK, WLEG(K), 0)  From TOOLSHRLEG         :# Poste
    WFIELD(K)="POT"
    If [F:CEV]POTCEV ="" Then
      WONCAMP(K)=0
    Else
      WONCAMP(K)=1
    Endif


    K+=1
    Call GET_LEGJOBPOT([M]JOBPOT,WOK, WLEG(K), 0)  From TOOLSHRLEG   :# Emploi type
    WFIELD(K)="JOBPOT"
    If [F:CEV]JOTCEV  ="" Then
      WONCAMP(K)=0
    Else
      WONCAMP(K)=1
    Endif

    For I =1 To K
       WFIELD(I)=func TOOLSHRLEG.LIB_FIELD(WECR,WFIELD(I))
       If WONCAMP(I)=1 Then
#          If GUSER="MABOS"
            WFIELD(I)-= mess(118,10720,1)
#          Endif
       Endif

    Next

    K+=1
    WFIELD(K)=""
    WLEG(K)=""

    If  K > 1 & WOK Then
      If [M:DIA]LEG ="" & [M:DIA]CPY <> "" :# Multi societé + multileg (if not: [M:DIA]LEG is filled)

         [L]NBLEG = 0: [L]NBCPY = 0 : Raz [L]LISTLEG
         Call LIST_LEGCPY([M:DIA]CPY,[L]LISTLEG,[L]NBLEG,[L]NBCPY) From TOOLSHRLEG
         WFIELD(K)=mess(00001,02696,1)          :# Groupe de sociétés
         If [F:CEV]CPYCEV <>"" Then
#            If GUSER="MABOS"
              WFIELD(K)-=mess(118,10720,1)
#            Endif
         Endif

         For I=1 To [L]NBLEG
           WLEG(K)-=[L]LISTLEG(I)
         Next

         If [L]NBLEG> 0 Then
           For I =1 To K-1
              If WLEG(I) <> "" & !find(WLEG(I),[L]LISTLEG)
                 WOK =0
                 If !WOK Then  Break :  Endif
              Endif
           Next
           If !WOK Then
              WMESSAGE = mess(104,10720,1)+":"+chr$(10)+WFIELD(K)+":"-WLEG(K)+chr$(10)+WFIELD(I)+":"-WLEG(I)
              # 'Incompatibilité de législation'
           Endif
         Endif
      Endif
    Endif

    If  K > 1 & WOK Then
      WLIBCOUR = WFIELD(1)
      WLEGCOUR = WLEG(1)
      #
      For I =2 To K-1
        Call LEGOK(WLIBCOUR,WLEGCOUR,WFIELD(I), WLEG(I) , WOK,WMESSAGE,0) From TOOLSHRLEG
        If !WOK Then  Break :  Endif
      Next
    Endif

    If !WOK
       GMESSAGE = WMESSAGE: : GERR=1 : # SAI=1 : Return
    Endif


 Endif
 Return

Funprog CRI_SAISI
Local Integer WSAISI
[L]WSAISI=0
If ( [M:DIA]CPY<>"" | [M:DIA]FCY<>"" | [M:DIA]SRV<>"" | (dim([M:DIA]LEG)>0 & [M:DIA]LEG<>"")
& | [M:DIA]POP<>"" | [M:DIA]PRF<>""  | [M:DIA]POT<>"" | [M:DIA]JOBPOT<>"") Then
  [L]WSAISI = 1
Endif

End [L]WSAISI

