#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# IMPPOH : Import/Export des commandes standards d'achat   MBT 07/04/99 #
# --------------------------------------------------------------------- #
# Traitements des actions spécifiques à l'import/export                 #
#########################################################################

$ACTION
Case ACTION
  When "IMP_AVANT_OUVRE"
    If !clalev([F:CFL])  Local File CPTFOOTLNK [CFL] : Endif
  When "IMP_OUVRE"     : Gosub OUVRE
  When "IMPORT"        : Gosub IMPORT
  When "IMP_ZONE"      : Gosub IMP_ZONE
  When "IMP_TAB"       : Gosub IMP_TAB
  When "IMP_FERME"     : Gosub FERME
  #-----
  When "EXP_OUVRE"     : Gosub EXP_OUVRE
  When "EXPORT"        : Gosub EXPORT
  When "EXP_ZONE"      : Gosub EXP_ZONE
Endcase
Return


##########################################################################
#                              IMPORT / EXPORT                           #
##########################################################################

#---------------------------------------------------------------#
# Début import/export, étiquette appelée depuis le traitement : #
#   - IMPPOH            si import (G_IMPORT=1)                  #
#   - IMPPOH            si export (G_EXPORT=1)                  #
# ------------------------------------------------------------- #
# Entête *71 à *78  / Pied *81 à *88  / Ligne *91 à *98         #
#     les zones TSTCHAMP  1 à  8 déterminent l'entête           #
#     les zones TSTCHAMP 11 à 18 déterminent le pied            #
#     les zones TSTCHAMP 21 à 28 déterminent le détail          #
#---------------------------------------------------------------#
$OUVRE_TEXTE
#----- Lignes texte entête  -----#
Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
TSTCHAMP(1) ="POH*71" : TSTCHAMP(2) ="POH*72" : TSTCHAMP(3) ="POH*73" : TSTCHAMP(4) ="POH*74"
TSTCHAMP(5) ="POH*75" : TSTCHAMP(6) ="POH*76" : TSTCHAMP(7) ="POH*77" : TSTCHAMP(8) ="POH*78"
#----- Lignes texte pied -----#
Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
TSTCHAMP(11)="POH*81" : TSTCHAMP(12)="POH*82" : TSTCHAMP(13)="POH*83" : TSTCHAMP(14)="POH*84"
TSTCHAMP(15)="POH*85" : TSTCHAMP(16)="POH*86" : TSTCHAMP(17)="POH*87" : TSTCHAMP(18)="POH*88"

#----- Lignes texte détail -----#
Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
# -------------------------------------
# FGR 27/11/2012 : X3SUIVI86171 (début)
  Local Integer NIOK

  Call TST_CHAMP("POP", "*91", NIOK) From SUBIMPOBJ
  If NIOK Then
    TSTCHAMP(21)="POP*91" : TSTCHAMP(22)="POP*92" : TSTCHAMP(23)="POP*93" : TSTCHAMP(24)="POP*94"
    TSTCHAMP(25)="POP*95" : TSTCHAMP(26)="POP*96" : TSTCHAMP(27)="POP*97" : TSTCHAMP(28)="POP*98"
  Else
    TSTCHAMP(21)="POQ*91" : TSTCHAMP(22)="POQ*92" : TSTCHAMP(23)="POQ*93" : TSTCHAMP(24)="POQ*94"
    TSTCHAMP(25)="POQ*95" : TSTCHAMP(26)="POQ*96" : TSTCHAMP(27)="POQ*97" : TSTCHAMP(28)="POQ*98"
  Endif
# FGR 27/11/2012 : X3SUIVI86171 (fin)
# -------------------------------------

#-----
Gosub OUVRE_TEXTE From TRTX3IMP
Return


##########################################################################
#                                  IMPORT                                #
##########################################################################

#--------------------------#
# Début de l'import/export #
#--------------------------#
$OUVRE
Local Integer  OKCHAMP
Local Shortint WNOL, J, K, L, SAVNOLIGN
Local  Integer  PVF_INVDTA   (max(func AFNC.ACTIV("PFI"),20))
Local  Char     PVF_INVDTAVAT(GLONVAT)(max(func AFNC.ACTIV("PFI"),20))
Local  Integer  OK_INVDTA, OK_INVDTAAMT, OK_INVDTAVAT
If dim(RELIT)<0  Local Integer RELIT : Endif
#----- Gestion des adresses fournisseur commande et expéditeur -----#
Global Integer GOK_BPAADD, GOK_BPRNAM(2), GOK_BPAADDLIG(3)
Global Integer GOK_POSCOD, GOK_CTY, GOK_SAT, GOK_CRY, GOK_CRYNAM, GOK_ADRESS1
#-----
Global Integer GOK_BPOADD, GOK_BPONAM(2), GOK_BPOADDLIG(3)
Global Integer GOK_BPOPOSCOD, GOK_BPOCTY, GOK_BPOSAT, GOK_BPOCRY, GOK_BPOCRYNAM, GOK_ADRESS2
#-----
Call TST_CHAMP("POH","BPAADD"      ,GOK_BPAADD      ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPRNAM(0)"   ,GOK_BPRNAM(0)   ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPRNAM(1)"   ,GOK_BPRNAM(1)   ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPAADDLIG(0)",GOK_BPAADDLIG(0)) From SUBIMPOBJ
Call TST_CHAMP("POH","BPAADDLIG(1)",GOK_BPAADDLIG(1)) From SUBIMPOBJ
Call TST_CHAMP("POH","BPAADDLIG(2)",GOK_BPAADDLIG(2)) From SUBIMPOBJ
Call TST_CHAMP("POH","POSCOD"      ,GOK_POSCOD      ) From SUBIMPOBJ
Call TST_CHAMP("POH","CTY"         ,GOK_CTY         ) From SUBIMPOBJ
Call TST_CHAMP("POH","SAT"         ,GOK_SAT         ) From SUBIMPOBJ
Call TST_CHAMP("POH","CRY"         ,GOK_CRY         ) From SUBIMPOBJ
Call TST_CHAMP("POH","CRYNAM"      ,GOK_CRYNAM      ) From SUBIMPOBJ
GOK_ADRESS1  = GOK_BPAADD + GOK_BPRNAM(0) + GOK_BPRNAM(1)
GOK_ADRESS1 += GOK_BPAADDLIG(0) + GOK_BPAADDLIG(1) + GOK_BPAADDLIG(2)
GOK_ADRESS1 += GOK_POSCOD + GOK_CTY + GOK_SAT + GOK_CRY + GOK_CRYNAM
#-----
Call TST_CHAMP("POH","BPOADD"      ,GOK_BPOADD      ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPONAM(0)"   ,GOK_BPONAM(0)   ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPONAM(1)"   ,GOK_BPONAM(1)   ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOADDLIG(0)",GOK_BPOADDLIG(0)) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOADDLIG(1)",GOK_BPOADDLIG(1)) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOADDLIG(2)",GOK_BPOADDLIG(2)) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOPOSCOD"   ,GOK_BPOPOSCOD   ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOCTY"      ,GOK_BPOCTY      ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOSAT"      ,GOK_BPOSAT      ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOCRY"      ,GOK_BPOCRY      ) From SUBIMPOBJ
Call TST_CHAMP("POH","BPOCRYNAM"   ,GOK_BPOCRYNAM   ) From SUBIMPOBJ
GOK_ADRESS2  = GOK_BPOADD + GOK_BPONAM(0) + GOK_BPONAM(1)
GOK_ADRESS2 += GOK_BPOADDLIG(0) + GOK_BPOADDLIG(1) + GOK_BPOADDLIG(2)
GOK_ADRESS2 += GOK_BPOPOSCOD + GOK_BPOCTY + GOK_BPOSAT + GOK_BPOCRY + GOK_BPOCRYNAM
#----- Gestion des informations douanières -----#
Global Integer GOK_EECNUM, GOK_EECICT, GOK_ICTCTY, GOK_FFWNUM
Global Integer GOK_FFWADD, GOK_EECLOC, GOK_DOUANE
#-----
Call TST_CHAMP("POH","EECNUM"   ,GOK_EECNUM)   From SUBIMPOBJ
Call TST_CHAMP("POH","EECICT"   ,GOK_EECICT)   From SUBIMPOBJ
Call TST_CHAMP("POH","ICTCTY"   ,GOK_ICTCTY)   From SUBIMPOBJ
Call TST_CHAMP("POH","FFWNUM"   ,GOK_FFWNUM)   From SUBIMPOBJ
Call TST_CHAMP("POH","FFWADD"   ,GOK_FFWADD)   From SUBIMPOBJ
Call TST_CHAMP("POH","EECLOC"   ,GOK_EECLOC)   From SUBIMPOBJ
#-----
Call TST_CHAMP("PVF","INVDTA"   ,OK_INVDTA)    From SUBIMPOBJ
Call TST_CHAMP("PVF","INVDTAAMT",OK_INVDTAAMT) From SUBIMPOBJ
Call TST_CHAMP("PVF","INVDTAVAT",OK_INVDTAVAT) From SUBIMPOBJ
#-----
GOK_DOUANE = GOK_EECNUM + GOK_EECICT + GOK_ICTCTY + GOK_FFWNUM + GOK_FFWADD + GOK_EECLOC
#----- Gestion des textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_IMPORT=1 : Gosub OUVRE_TEXTE
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
#-----
Return

#-----------------------------------------------------#
# Après lecture d'un enregistrement (entête ou ligne) #
#                                                     #
# IMPFIC : Abréviation du fichier en cours            #
#-----------------------------------------------------#
$IMPORT
Gosub IMPORT_TEXTE
Case IMPFIC
  When "POH"
    Raz PVF_INVDTA, PVF_INVDTAVAT
  When "POQ", "POP"
    #------------------------------------------------------------#
    # Lignes commande : Déterminer si nouvelle ligne (nolign<>0) #
    #------------------------------------------------------------#
    Raz WNOL
    Gosub IMP_DECLARE From TRTX3IMP
    If GREP="M"
       ICLEPRIM(0)="POPLIN"
       ICLEPRIM(1)="ITMREF" : ICLESEC(1)="PRHFCY"  : ICLESEC2(1)="EXTRCPDAT"
       ICLEPRIM(2)="ITMREF" : ICLESEC(2)="PRHFCY"
       ICLEPRIM(3)="ITMREF" : ICLESEC(3)="EXTRCPDAT"
       ICLEPRIM(4)="ITMREF"
       NBASTAB="NBLIG"
       Gosub RECHERCHE_LIGNE From TRTX3IMP
       WNOL=nolign
       #-----------------------------------------------#
       # Cas de la suppression de ligne (Qté cdée = 0) #
       #-----------------------------------------------#
       Call TST_CHAMP(IMPFIC,"QTYUOM",OKCHAMP) From SUBIMPOBJ
       If OKCHAMP & [F:POQ]QTYUOM=0 & nolign<>0
          status=65
          Call C_NBLIG     From SUBPOH : If mkstat Return : Endif
          Call AVANT_NBLIG From SUBPOH
          Call APRES_NBLIG From SUBPOH
       Endif
    Endif
    #----- Calcul de l'indice de la ligne -----#
    If WNOL=0 WNOL=[M:POH2]NBLIG Else WNOL-=1 : Endif
  When "CAL"
    #--------------------------------------------------------------------#
    # Traitement des comptes et sections analytiques des lignes commande #
    #            left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"POP"'               #
    #--------------------------------------------------------------------#
    [F:CAL]ABRFIC="POP"
    [F:CAL]VCRTYP=0
    Call IMPORT_ACCCCE(WNOL,"[M:POH2]LINACC","","[M:POH2]CCE") From TRTX3CPT
    nolign=WNOL+1 : status=75 : # Modif élément
  When "PVF"
    #----------------------------------------#
    # Traitement des éléments de facturation #
    #----------------------------------------#
    If [F:PVF]INVDTA<>0
      If [M:POH3]NBFAC>0
        K=find([F:PVF]INVDTA,[M:POH3]INVDTA(0..[M:POH3]NBFAC-1))
        If K & OK_INVDTAVAT
          If (GREP<>"C" | find([F:PVF]INVDTA,PVF_INVDTA(0..[M:POH3]NBFAC-1)))
            If [M:POH3]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
              L=find([F:PVF]INVDTA,[M:POH3]INVDTA(K..[M:POH3]NBFAC-1))
              If L
                K+=L
                If [M:POH3]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                  L=find([F:PVF]INVDTA,[M:POH3]INVDTA(K..[M:POH3]NBFAC-1))
                  If L
                    K+=L
                    If [M:POH3]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                      L=find([F:PVF]INVDTA,[M:POH3]INVDTA(K..[M:POH3]NBFAC-1))
                      If L
                        K+=L
                        If [M:POH3]INVDTAVAT(K-1)<>[F:PVF]INVDTAVAT
                          K=0
                        Endif
                      Else
                        K=0
                      Endif
                    Endif
                  Else
                    K=0
                  Endif
                Endif
              Else
                K=0
              Endif
            Endif
          Endif
        Endif
      Else
        K=0
      Endif
      If K=0
        PVF_INVDTA     ([M:POH3]NBFAC)=[F:PVF]INVDTA
        PVF_INVDTAVAT  ([M:POH3]NBFAC)=[F:PVF]INVDTAVAT
       #[M:POH3]INVDTA ([M:POH3]NBFAC)=[F:PVF]INVDTA
       #Read [PFI] PFI0=[F:PVF]INVDTA : If fstat  Raz [F:PFI] : Endif
       #Call GET_ATEXTRA("PFOOTINV","SHOAXX",GLANGUE,[M:POH3]INVDTALIB([M:POH3]NBFAC)) From TRTX3TEX
       #[M:POH3]NBFAC+=1
        [F:PVF]IND=[M:POH3]NBFAC+1
        nolign=0 : status=73 : # Nouvel élément
      Else
        PVF_INVDTA    (K-1)=[F:PVF]INVDTA
        PVF_INVDTAVAT (K-1)=[F:PVF]INVDTAVAT
        [F:PVF]IND=K
        nolign=K : status=75 : # Modif élément
      Endif
    Endif
    #-----
  When "CFL"
    #----------------------------------------------------------------------------#
    # Traitement des comptes et sections analytiques des éléments de facturation #
    #                 left$([M:AOE1]FLGLNK(SEPNUM-1),5)='"PVF"'                  #
    #----------------------------------------------------------------------------#
    WNOL=[F:PVF]IND-1
    [F:CFL]ABRFIC="PVF"
    [F:CFL]VCRTYP=8
    [F:CAL]=[F:CFL]
    Call IMPORT_ACCCCE(WNOL,"[M:POH3]ACC","[M:POH3]DSP","[M:POH3]PFICCE")    From TRTX3CPT
    nolign=WNOL+1 : status=75 : # Modif élément
Endcase
Return

#-----------------------------------------#
# Equivalent à la saisie d'un champ fiche #
#                                         #
# IMPFIC : Abréviation du fichier         #
# IMPMSK : Nom de l'écran en cours        #
# IMPZON : Nom du champ en cours          #
# IMPMOD : Déclenche l'Après_modif        #
# OK     : Conditionne IMP_ZONE standard  #
#-----------------------------------------#
$IMP_ZONE
Gosub TRT_IMP_ZONE
Case IMPFIC
  When "POH"
    Case IMPZON
      When "CCE"       : If [F:POH]CCE(indice)=""  OK=0 : Endif
      When "NBFAC"     : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "INVFCY"               : # Dernier champ saisissable de l'entête
        If GOK_ADRESS1
          Gosub IMP_ZONE_ADRESS1  : # Traitement adresse fournisseur commande
        Endif
        If GOK_ADRESS2
          Gosub IMP_ZONE_ADRESS2  : # Traitement adresse fournisseur expéditeur
        Endif
        If GOK_DOUANE
          Gosub IMP_ZONE_DOUANE   : # Traitement informations douanières
        Endif
        Gosub IMP_ZONE_TEXTE      : # Traitement des textes entête et pied
    Endcase
Endcase
Return

#-------------------------------------------#
# Equivalent à la saisie d'un champ tableau #
#                                           #
# IMPFIC : Abréviation du fichier           #
# IMPMSK : Nom de l'écran en cours          #
# IMPZON : Nom du champ en cours            #
# IMPMOD : Déclenche l'Après_modif          #
# OK     : Conditionne IMP_ZONE standard    #
#-------------------------------------------#
$IMP_TAB
Gosub TRT_IMP_ZONE
# Issue 84130 - 2013-02-21 by SR : Gérer zones impactantes
Case IMPFIC
  When "POQ", "POP"
    Case IMPZON
      When "LINACC1","LINACC2","LINACC3","LINACC4","LINACC5",
&          "LINACC6","LINACC7","LINACC8","LINACC9","LINACC10",
&          "CCE1", "CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "CCE10",
&          "CCE11","CCE12","CCE13","CCE14","CCE15","CCE16","CCE17","CCE18","CCE19","CCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CAL" -----#
        If find("CPTANALIN",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par PORDERQ-P
        Endif
        #-----
      When "VAT1"
        If [F:POP]VAT(0)<>""
          [M:POH2]VAT1(nolign-1)=[F:POP]VAT(0) : IMPMOD=1
        Endif
      When "VAT2"
        If [F:POP]VAT(1)<>""
          [M:POH2]VAT2(nolign-1)=[F:POP]VAT(1) : IMPMOD=1
        Endif
      When "VAT3"            : # Dernier champ saisissable avant indicateur solde LINCLEFLG
        If [F:POP]VAT(2)<>""
          [M:POH2]VAT3(nolign-1)=[F:POP]VAT(2) : IMPMOD=1
        Endif
        #-----
        Gosub IMP_ZONE_TEXTE : # Traitement des textes entête et pied
        #----- Chargement de l'indicateur de solde -----#
        Local Integer  OKCHAMP
        Call TST_CHAMP("POQ","LINCLEFLG",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP  [M:POH2]LINCLEFLG(nolign-1)=[F:POQ]LINCLEFLG : Endif
        #----- Chargement des motifs tarif -----#
        Local Shortint WNOL : WNOL=nolign-1
        Call TST_CHAMP("POP","PRIREN",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP
          Call CTLREN ([F:POP]PRIREN,6,[M:POH2]PRIREN(WNOL),
&                      [M:POH2]GROPRI(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]PRIREN(WNOL)=[F:POP]PRIREN  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN1",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN1)>0
          Call CTLREN ([F:POP]DISCRGREN1,6,[M:POH2]DISCRGREN1(WNOL),
&                      [M:POH2]DISCRGVAL1(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN1(WNOL)=[F:POP]DISCRGREN1  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN2",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN2)>0
          Call CTLREN ([F:POP]DISCRGREN2,6,[M:POH2]DISCRGREN2(WNOL),
&                      [M:POH2]DISCRGVAL2(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN2(WNOL)=[F:POP]DISCRGREN2  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN3",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN3)>0
          Call CTLREN ([F:POP]DISCRGREN3,6,[M:POH2]DISCRGREN3(WNOL),
&                      [M:POH2]DISCRGVAL3(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN3(WNOL)=[F:POP]DISCRGREN3  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN4",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN4)>0
          Call CTLREN ([F:POP]DISCRGREN4,6,[M:POH2]DISCRGREN4(WNOL),
&                      [M:POH2]DISCRGVAL4(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN4(WNOL)=[F:POP]DISCRGREN4  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN5",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN5)>0
          Call CTLREN ([F:POP]DISCRGREN5,6,[M:POH2]DISCRGREN5(WNOL),
&                      [M:POH2]DISCRGVAL5(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN5(WNOL)=[F:POP]DISCRGREN5  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN6",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN6)>0
          Call CTLREN ([F:POP]DISCRGREN6,6,[M:POH2]DISCRGREN6(WNOL),
&                      [M:POH2]DISCRGVAL6(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN6(WNOL)=[F:POP]DISCRGREN6  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN7",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN7)>0
          Call CTLREN ([F:POP]DISCRGREN7,6,[M:POH2]DISCRGREN7(WNOL),
&                      [M:POH2]DISCRGVAL7(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN7(WNOL)=[F:POP]DISCRGREN7  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN8",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN8)>0
          Call CTLREN ([F:POP]DISCRGREN8,6,[M:POH2]DISCRGREN8(WNOL),
&                      [M:POH2]DISCRGVAL8(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN8(WNOL)=[F:POP]DISCRGREN8  Else  mkstat=0 : Endif
        Endif
        Call TST_CHAMP("POP","DISCRGREN9",OKCHAMP) From SUBIMPOBJ
        If OKCHAMP & dim([M:POH2]DISCRGREN9)>0
          Call CTLREN ([F:POP]DISCRGREN9,6,[M:POH2]DISCRGREN9(WNOL),
&                      [M:POH2]DISCRGVAL9(WNOL)) From TRTPRICE
          If !mkstat  [M:POH2]DISCRGREN9(WNOL)=[F:POP]DISCRGREN9  Else  mkstat=0 : Endif
        Endif
      When "GROPRI","QTYSTU","QTYVOU","QTYWEU","UOM","WEU","VOU","QTYUOM"
         [M:POH2]WSTCUPD(nolign-1) = 2
    Endcase
  When "CAL"
    Case IMPZON
      When "ITMDES","ITMDES1","PRHFCY","FCYADD","USEPLC","LINSTOFCY","SCOADD","UOM",
&          "QTYUOM","UOMPUUCOE","QTYSTU","PJT","EXTRCPDAT","GROPRI","LINPURTYP",
&          "QUAFLG","EECINCRAT","ORICRY","VAT1","VAT2","VAT3","TAXISS","TAXRCP",
&          "TAXOTH1","TAXOTH2"
        OK=0 : # Zones non concernées par CPTANALIN
    Endcase
  When "PVF"
    Case IMPZON
      When "NBFAC"     : mkstat=1 : # Ne pas exécuter la boucle d'import des éléments
      When "INVDTA"    : #If [M:POH3]INVDTA (nolign-1)<>0  OK=0 : Endif
      When "ACC1","ACC2","ACC3","ACC4","ACC5","ACC6","ACC7","ACC8","ACC9","ACC10","DSP",
&          "PFICCE1", "PFICCE2", "PFICCE3", "PFICCE4", "PFICCE5", "PFICCE6", "PFICCE7",
&          "PFICCE8", "PFICCE9", "PFICCE10","PFICCE11","PFICCE12","PFICCE13","PFICCE14",
&          "PFICCE15","PFICCE16","PFICCE17","PFICCE18","PFICCE19","PFICCE20"
        #----- Pas de contrôle si les comptes et sections sont importés avec "CFL" -----#
        If find("CPTFOOTLNK",[M:AOE1]FLGFIL(0..[M:AOE1]NBRFLG))
          OK=0 : mkstat=1 : # Zones non concernées par PVCRFOOT
        Endif
        #-----
    Endcase
  When "CFL"
    Case IMPZON
      When "INVDTAAMT","INVDTAVAT" : OK=0 : # Zones non concernées par CPTANALIN
    Endcase
Endcase
Return

#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
If dim(GOK_ADRESS1)>0
  Kill GOK_BPAADD, GOK_BPRNAM, GOK_BPAADDLIG
  Kill GOK_POSCOD, GOK_CTY, GOK_SAT, GOK_CRY, GOK_CRYNAM, GOK_ADRESS1
Endif
If dim(GOK_ADRESS2)>0
  Kill GOK_BPOADD, GOK_BPONAM, GOK_BPOADDLIG
  Kill GOK_BPOPOSCOD, GOK_BPOCTY, GOK_BPOSAT, GOK_BPOCRY, GOK_BPOCRYNAM, GOK_ADRESS2
Endif
If dim(GOK_DOUANE)>0
  Kill GOK_EECNUM, GOK_EECICT, GOK_ICTCTY, GOK_FFWNUM
  Kill GOK_FFWADD, GOK_EECLOC, GOK_DOUANE
Endif
Return

#------------------------------------#
# Traitements de IMP_ZONE et IMP_TAB #
#------------------------------------#
$TRT_IMP_ZONE
Case IMPFIC
  When "POQ", "POP" :
    #-----------------------------------------------------------#
    # Lignes commande : Déterminer la bonne abréviation fichier #
    #-----------------------------------------------------------#
    Local Shortint I
    I=find(IMPZON,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    If I=0
      I=find(IMPZON+"(0)",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If I & find(left$([M:AOE2]ZONE(I-1),3),"POQ","POP")
      IMPFIC=left$([M:AOE2]ZONE(I-1),3)
    Endif
Endcase
Return

#--------------------------------------------------------------------#
# Import d'un texte, étiquette appelée depuis les traitements IMPPOH #
#--------------------------------------------------------------------#
$IMPORT_TEXTE
Raz G_NLDET
Case IMPFIC
  When "POH" :
    If G_ENT     : # --- Texte entete ---
       Raz [M:ITC]T_CLE_CLOB(1)
       Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(1)=G_CLE_CLOB
    Endif
    If G_PIE     : # --- Texte pied ---
       Raz [M:ITC]T_CLE_CLOB(2)
       Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(2)=G_CLE_CLOB
    Endif
  When "POQ"
    If G_DET     : # --- Texte detail ---
       Raz [M:ITC]T_CLE_CLOB(3)
       Gosub IMP_T3 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
       [M:ITC]T_CLE_CLOB(3)=G_CLE_CLOB
    Endif
Endcase
Return

#---------------------------------------------------------------------#
# Chargement de la clé du texte dans les classes [M:POH1] et [M:POH2] #
#---------------------------------------------------------------------#
$IMP_ZONE_TEXTE
Case IMPFIC
  When "POH"
    # FGR 27/11/2012 : X3SUIVI86171
    #If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & GREP="C" : # --- Texte entête ---
    If G_ENT & [M:ITC]T_CLE_CLOB(1)<>"" & (GREP="C" or GREP="M") : # --- Texte entête ---
      [M:POH1]TEX1=[M:ITC]T_CLE_CLOB(1)
      Raz [M:ITC]T_CLE_CLOB(1)                   # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois
   Endif
    # FGR 27/11/2012 : X3SUIVI86171
    #If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & GREP="C" : # --- Texte pied ---
    If G_PIE & [M:ITC]T_CLE_CLOB(2)<>"" & (GREP="C" or GREP="M") : # --- Texte pied ---
      [M:POH1]TEX2=[M:ITC]T_CLE_CLOB(2)
      Raz [M:ITC]T_CLE_CLOB(2)                   # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois
    Endif
  When "POQ","POP"
    # FGR 27/11/2012 : X3SUIVI86171
    #If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & GREP="C" : # --- texte détail ligne ---
    If G_DET & [M:ITC]T_CLE_CLOB(3)<>"" & (GREP="C" or GREP="M") : # --- texte détail ligne ---
      [M:POH2]LINTEX(nolign-1)=[M:ITC]T_CLE_CLOB(3)
      Raz [M:ITC]T_CLE_CLOB(3)                   # FGR 27/11/2012 : X3SUIVI86171 : pour ne le faire qu'une fois
    Endif
Endcase
Return

#---------------------------------------------------------#
# Chargement des champs de l'adresse fournisseur commande #
#---------------------------------------------------------#
$IMP_ZONE_ADRESS1
#----- Ne pas écraser une éventuelle adresse spécifique en modification de commande -----#
If [M:AD61]ADBFLG<>2
  #----- Lecture BPARTNER si nécessaire -----#
  If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
    Read [BPR] BPR0=[M:POH0]BPSNUM
    If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
  Endif
  #----- Lecture BPSUPPLIER si nécessaire -----#
  If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
    Read [BPS] BPS0=[M:POH0]BPSNUM
    If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
  Endif
  #----- Lecture de l'adresse si nécessaire -----#
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POH0]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
    Read [BPA] BPA0=1;[M:POH0]BPSNUM;[F:BPR]BPAADD
    If fstat  Raz [F:BPA] : Endif
  Endif
  #----- Chargement de l'adresse standard -----#
  [M:AD61]BPAADD       = [F:BPS]BPAADD
  [M:AD61]BPRNAM(0)    = [F:BPR]BPRNAM(0)
  [M:AD61]BPRNAM(1)    = [F:BPR]BPRNAM(1)
  [M:AD61]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AD61]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AD61]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AD61]CRY          = [F:BPA]CRY
  [M:AD61]CRYNAM       = [F:BPA]CRYNAM
  [M:AD61]SAT          = [F:BPA]SAT
  [M:AD61]POSCOD       = [F:BPA]POSCOD
  [M:AD61]CTY          = [F:BPA]CTY
  [M:AD61]ADBBPR       = [M:POH0]BPSNUM
Endif
#----- Chargement des champs adresse en fonction de leur présence dans le modèle -----#
If GOK_BPAADD
  [M:AD61]BPAADD=[F:POH]BPAADD
  #----- Lecture de l'adresse si nécessaire -----#
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POH0]BPSNUM | [F:BPA]BPAADD<>[M:AD61]BPAADD
    Read [BPA] BPA0=1;[M:POH0]BPSNUM;[M:AD61]BPAADD
    If fstat  Raz [F:BPA] : Endif
  Endif
  #-----
  [M:AD61]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AD61]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AD61]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AD61]CRY          = [F:BPA]CRY
  [M:AD61]CRYNAM       = [F:BPA]CRYNAM
  [M:AD61]SAT          = [F:BPA]SAT
  [M:AD61]POSCOD       = [F:BPA]POSCOD
  [M:AD61]CTY          = [F:BPA]CTY
  [M:AD61]ADBFLG=2
Endif
#-----
If GOK_BPRNAM(0)     [M:AD61]BPRNAM(0)   =[F:POH]BPRNAM(0)    : [M:AD61]ADBFLG=2 : Endif
If GOK_BPRNAM(1)     [M:AD61]BPRNAM(1)   =[F:POH]BPRNAM(1)    : [M:AD61]ADBFLG=2 : Endif
If GOK_BPAADDLIG(0)  [M:AD61]BPAADDLIG(0)=[F:POH]BPAADDLIG(0) : [M:AD61]ADBFLG=2 : Endif
If GOK_BPAADDLIG(1)  [M:AD61]BPAADDLIG(1)=[F:POH]BPAADDLIG(1) : [M:AD61]ADBFLG=2 : Endif
If GOK_BPAADDLIG(2)  [M:AD61]BPAADDLIG(2)=[F:POH]BPAADDLIG(2) : [M:AD61]ADBFLG=2 : Endif
If GOK_POSCOD        [M:AD61]POSCOD      =[F:POH]POSCOD       : [M:AD61]ADBFLG=2 : Endif
If GOK_CTY           [M:AD61]CTY         =[F:POH]CTY          : [M:AD61]ADBFLG=2 : Endif
If GOK_SAT           [M:AD61]SAT         =[F:POH]SAT          : [M:AD61]ADBFLG=2 : Endif
If GOK_CRY           [M:AD61]CRY         =[F:POH]CRY          : [M:AD61]ADBFLG=2 : Endif
If GOK_CRYNAM        [M:AD61]CRYNAM      =[F:POH]CRYNAM       : [M:AD61]ADBFLG=2 : Endif
#-----
Return

#-----------------------------------------------------------#
# Chargement des champs de l'adresse fournisseur expéditeur #
#-----------------------------------------------------------#
$IMP_ZONE_ADRESS2
#----- Ne pas écraser une éventuelle adresse spécifique en modification de commande -----#
If [M:AD62]ADBFLG<>2
  #----- Lecture BPARTNER si nécessaire -----#
  If [F:BPR]BPRNUM<>[M:POH0]BPSNUM
    Read [BPR] BPR0=[M:POH0]BPSNUM
    If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
  Endif
  #----- Lecture BPSUPPLIER si nécessaire -----#
  If [F:BPS]BPSNUM<>[M:POH0]BPSNUM
    Read [BPS] BPS0=[M:POH0]BPSNUM
    If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
  Endif
  #----- Lecture de l'adresse si nécessaire -----#
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POH0]BPSNUM | [F:BPA]BPAADD<>[F:BPS]BPAADD
    Read [BPA] BPA0=1;[M:POH0]BPSNUM;[F:BPR]BPAADD
    If fstat  Raz [F:BPA] : Endif
  Endif
  #----- Chargement de l'adresse standard -----#
  [M:AD62]BPAADD       = [F:BPS]BPAADD
  [M:AD62]BPRNAM(0)    = [F:BPR]BPRNAM(0)
  [M:AD62]BPRNAM(1)    = [F:BPR]BPRNAM(1)
  [M:AD62]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AD62]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AD62]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AD62]CRY          = [F:BPA]CRY
  [M:AD62]CRYNAM       = [F:BPA]CRYNAM
  [M:AD62]SAT          = [F:BPA]SAT
  [M:AD62]POSCOD       = [F:BPA]POSCOD
  [M:AD62]CTY          = [F:BPA]CTY
  [M:AD62]ADBBPR       = [M:POH0]BPSNUM
Endif
#----- Chargement des champs adresse en fonction de leur présence dans le modèle -----#
If GOK_BPAADD
  [M:AD62]BPAADD=[F:POH]BPOADD
  #----- Lecture de l'adresse si nécessaire -----#
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POH0]BPSNUM | [F:BPA]BPAADD<>[M:AD62]BPAADD
    Read [BPA] BPA0=1;[M:POH0]BPSNUM;[M:AD62]BPAADD
    If fstat  Raz [F:BPA] : Endif
  Endif
  #-----
  [M:AD62]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:AD62]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:AD62]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:AD62]CRY          = [F:BPA]CRY
  [M:AD62]CRYNAM       = [F:BPA]CRYNAM
  [M:AD62]SAT          = [F:BPA]SAT
  [M:AD62]POSCOD       = [F:BPA]POSCOD
  [M:AD62]CTY          = [F:BPA]CTY
  [M:AD62]ADBFLG=2
Endif
#-----
If GOK_BPONAM(0)     [M:AD62]BPRNAM(0)   =[F:POH]BPONAM(0)    : [M:AD62]ADBFLG=2 : Endif
If GOK_BPONAM(1)     [M:AD62]BPRNAM(1)   =[F:POH]BPONAM(1)    : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOADDLIG(0)  [M:AD62]BPAADDLIG(0)=[F:POH]BPOADDLIG(0) : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOADDLIG(1)  [M:AD62]BPAADDLIG(1)=[F:POH]BPOADDLIG(1) : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOADDLIG(2)  [M:AD61]BPAADDLIG(2)=[F:POH]BPOADDLIG(2) : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOPOSCOD     [M:AD62]POSCOD      =[F:POH]BPOPOSCOD    : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOCTY        [M:AD62]CTY         =[F:POH]BPOCTY       : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOSAT        [M:AD62]SAT         =[F:POH]BPOSAT       : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOCRY        [M:AD62]CRY         =[F:POH]BPOCRY       : [M:AD62]ADBFLG=2 : Endif
If GOK_BPOCRYNAM     [M:AD62]CRYNAM      =[F:POH]BPOCRYNAM    : [M:AD62]ADBFLG=2 : Endif
#-----
Return

#----------------------------------------#
# Chargement des informations douanières #
#----------------------------------------#
$IMP_ZONE_DOUANE
If GOK_EECNUM  [M:PCEV]EECNUM=[F:POH]EECNUM : Endif
If GOK_EECICT  [M:PCEV]EECICT=[F:POH]EECICT : Endif
If GOK_ICTCTY  [M:PCEV]ICTCTY=[F:POH]ICTCTY : Endif
If GOK_FFWNUM  [M:PCEV]FFWNUM=[F:POH]FFWNUM : Endif
If GOK_FFWADD  [M:PCEV]FFWADD=[F:POH]FFWADD : Endif
If GOK_EECLOC  [M:PCEV]EECLOC=[F:POH]EECLOC : Endif
Return


##########################################################################
#                                   EXPORT                               #
##########################################################################

#-----------------------------------------------------------------#
# Début export, étiquette appelée directement depuis le SUBEXPOBJ #
#-----------------------------------------------------------------#
$EXP_OUVRE
#----- Gestion dess textes -----#
Gosub DECLARE_TEXTE From TRTX3IMP
G_EXPORT=1 : Gosub OUVRE_TEXTE
#----- Changement pseudo table CPTFOOTLNK par CPTANALIN bis -----#
If clalev([F:CFL])  Close Local File [CFL] : Endif
Local File CPTANALIN [CFL]
#-----
Return

#---------------------------------------------------#
# Après lecture d'un enregistrement (entête, ligne) #
# ------------------------------------------------- #
# EXPFIC : Abréviation du fichier en cours          #
#---------------------------------------------------#
$EXPORT
Case EXPFIC
  When "POH"
    If G_ENT
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:POH]TEX1)>0 & [F:POH]TEX1<>""
          G_CLE_CLOB=[F:POH]TEX1   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_PIE
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:POH]TEX2)>0 & [F:POH]TEX2<>""
          G_CLE_CLOB=[F:POH]TEX2   : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif
  When "POQ","POP"
    If G_DET
       Gosub EXP_RAZ_T3 From TRTX3IMP
       If dim([F:POQ]LINTEX)>0 & [F:POQ]LINTEX<>""
          G_CLE_CLOB=[F:POQ]LINTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T3 From TRTX3IMP
       Endif
    Endif
Endcase
Return

#------------------------------------------#
# Export d'un champ                        #
# ---------------------------------------- #
# EXPFIC : Abréviation du fichier en cours #
#------------------------------------------#
$EXP_ZONE
Return
