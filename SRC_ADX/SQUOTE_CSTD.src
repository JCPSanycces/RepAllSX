#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER              From SQUOTE_METHODS
        When Default
      Endcase
    When "SQD"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SQD         From SQUOTE_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
        When Default
      Endcase
    When "SVV"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVV         From SQUOTE_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVV          From SQUOTE_METHODS
        When Default
      Endcase
    When "SVF"
      Case [L]AEVENT
        When "AREAD_BEFORE"    : Gosub AREAD_BEFORE_SVF         From SQUOTE_METHODS # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF          From SQUOTE_METHODS
        When Default
      Endcase
    When "SVF.C_DTAVAT"
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER_SVF_C_DTAVAT From SQUOTE_METHODS
        When Default
      Endcase
    When Default
  Endcase

Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
        When "LOAD_ADDBPC"         : Gosub LOAD_ADDBPC              From SQUOTE_METHODS
        When "UNLOAD_ADDBPC"       : Gosub UNLOAD_ADDBPC            From SQUOTE_METHODS
        When "LOAD_ADDBPD"         : Gosub LOAD_ADDBPD              From SQUOTE_METHODS
        When "UNLOAD_ADDBPD"       : Gosub UNLOAD_ADDBPD            From SQUOTE_METHODS
  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all calls related to _LEG properties
  Case CURPRO
    When "CPY"              :  Gosub CPY    		From SQUOTE_PROPERTIES
    When "QUOINVTAX"        :  Gosub QUOINVTAX  From SQUOTE_PROPERTIES
    When Default
  Endcase

Return

#######################################################################################

