#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################
############################################################
$FILL_SQH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SQH]SQHNUM
  VCRTYP_T    = NUM_SQH
  If dim(SQH_L) >= 0 Then
    VCRLIN_T  = SQH_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    VCRNUMCALC_T = [F:SQH]PJT
  Else
    # Aval
    VCRNUMCALC_T = [F:SQH]SOHNUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SQH]QUODAT
  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(430, [F:SQH]QUOSTA)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:SQH]APPFLG)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)
  If [M:PIV1]VCRTYPSEL = NUM_SQH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(430, [F:SQH]QUOSTA)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(280, [F:SQH]APPFLG)
  Endif
  SALFCY_T    = [F:SQH]SALFCY
  STOFCY_T    = [F:SQH]STOFCY
  BPRNUM_T    = [F:SQH]BPCORD
  JOU_T       = ""
  If dim([F:SQH]REP(0)) >= 0 Then
    REP1_T    = [F:SQH]REP(0)
    If dim([F:SQH]REP(1)) >= 0 Then
      REP2_T  = [F:SQH]REP(1)
    Endif
  Endif

#  CURS        = [F:SQH]CUR
#  WCHGTYP     = [F:SQH]CHGTYP
#  ORDNOT_T    = [F:SQH]QUONOT
#  ORDATI_T    = [F:SQH]QUOATI
#  SCURVCR_T   = [F:SQH]CUR
#  WMNTORG(0)  = [F:SQH]QUOINVNOTL
#  WMNTORG(1)  = [F:SQH]QUOINVATI
#  Gosub CALC_MNT From CONSPITOOLS
  CURS        = [F:SQH]CUR
  WCHGTYP     = [F:SQH]CHGTYP
  ORDNOT_T    = [F:SQH]QUOINVNOT  #[F:SQH]QUONOT
  ORDATI_T    = [F:SQH]QUOINVATI  #[F:SQH]QUOATI
  SCURVCR_T   = [F:SQH]CUR
  WMNTORG(0)  = [F:SQH]QUOINVNOTL
  WMNTORG(1)  = [F:SQH]QUOINVATIL #[F:SQH]QUOINVATI
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:SQH]QUOINVNOTL
  ORDATIL_T   = [F:SQH]QUOINVATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS

Return

############################################################
$FILL_SDH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SDH]SDHNUM
  VCRTYP_T    = NUM_SDH
  If dim(SDH_L) >= 0 Then
    VCRLIN_T = SDH_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    VCRNUMCALC_T = [F:SDH]SOHNUM
  Else
    # Aval
    VCRNUMCALC_T = [F:SDH]SIHNUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SDH]DLVDAT

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  # FGR 06/11/2014 : X3SUIVI103671 (début)
  #STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]RTNSTA)
  #STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]INVFLG)
  If [F:SDH]SDHCAT = 2 Then
    STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]RTNSTA)
  Else
    STBVCRSTAT(1)  = ""
  Endif
  If [F:SDH]INVFLG = [V]CST_AYES Then
    STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(418, 3)
  Else
    STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(418, 1)
  Endif
  # FGR 06/11/2014 : X3SUIVI103671 (fin)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)

  If [M:PIV1]VCRTYPSEL = NUM_SDH Then
    # FGR 06/11/2014 : X3SUIVI103671 (début)
    #[M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]RTNSTA)
    #[M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]INVFLG)
    If [F:SDH]SDHCAT = 2 Then
      [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(451, [F:SDH]RTNSTA)
    Else
      [M:PIV1]VCRSTA = ""
    Endif
    If [F:SDH]INVFLG = [V]CST_AYES Then
      [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(418, 3)
    Else
      [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(418, 1)
    Endif
    # FGR 06/11/2014 : X3SUIVI103671 (fin)
  Endif
  SALFCY_T    = [F:SDH]SALFCY
  STOFCY_T    = [F:SDH]STOFCY
  BPRNUM_T    = [F:SDH]BPCORD
  JOU_T       = ""
  If dim([F:SDH]REP(0)) >= 0 Then
    REP1_T    = [F:SDH]REP(0)
    If dim([F:SDH]REP(1)) >= 0 Then
      REP2_T  = [F:SDH]REP(1)
    Endif
  Endif

#  CURS        = [F:SDH]CUR
#  WCHGTYP     = [F:SDH]CHGTYP
#  ORDNOT_T    = [F:SDH]DLVNOT
#  ORDATI_T    = [F:SDH]DLVATI
#  SCURVCR_T   = [F:SDH]CUR
#  WMNTORG(0)  = [F:SDH]DLVINVNOT
#  WMNTORG(1)  = [F:SDH]DLVINVATI
#  Gosub CALC_MNT From CONSPITOOLS
  CURS        = [F:SDH]CUR
  WCHGTYP     = [F:SDH]CHGTYP
  ORDNOT_T    = [F:SDH]DLVINVNOT  #[F:SDH]DLVNOT
  ORDATI_T    = [F:SDH]DLVINVATI  #[F:SDH]DLVATI
  SCURVCR_T   = [F:SDH]CUR
  WMNTORG(0)  = [F:SDH]DLVINVNOTL #[F:SDH]DLVINVNOT
  WMNTORG(1)  = [F:SDH]DLVINVATIL #[F:SDH]DLVINVATI
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:SDH]DLVINVNOTL
  ORDATIL_T   = [F:SDH]DLVINVATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
Return

############################################################
$FILL_SRH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SRH]SRHNUM
  VCRTYP_T    = NUM_SRH
  If dim(SRH_L) >= 0 Then
    VCRLIN_T = SRH_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    If dim(ENRLOC) >= 0 Then
      VCRNUMCALC_T = [F:SRH]SRHNUM
    Else
      VCRNUMCALC_T = [F:SRD]SDHNUM
    Endif
  Else
    # Aval
    If dim(ENRLOC) >= 0 Then
      VCRNUMCALC_T = [F:SRH]SRHNUM
    Else
      VCRNUMCALC_T = [F:SRD]SIHNUM
    Endif
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SRH]RTNDAT
  SALFCY_T    = [F:SRH]SALFCY
  STOFCY_T    = [F:SRH]STOFCYDLV
  BPRNUM_T    = [F:SRH]BPCORD
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  ORDNOT_T    = 0
  ORDATI_T    = 0
  SCURVCR_T   = ""
  ORDNOTL_T   = 0
  ORDATIL_T   = 0
  ORDNOTD_T   = 0
  ORDATID_T   = 0
Return

############################################################
$FILL_SIH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SIH]NUM
  VCRTYP_T    = NUM_SIH
  If dim(SIH_L) >= 0 Then
    VCRLIN_T = SIH_L
  Endif
  Read [F:SIV]SIV1=4;[F:SIH]NUM
  If !fstat Then
    VCRNUMCALC_T = [F:SIV]NUM
  Else
    Raz [F:SIV]
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SIH]ACCDAT

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(429, [F:SIH]STA)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(645, [F:SIH]INVTYP)      # FGR 31/08/2015 : X3SUIVI110665
  If [M:PIV1]VCRTYPSEL = NUM_SIH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(429, [F:SIH]STA)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(645, [F:SIH]INVTYP)                  # FGR 31/08/2015 : X3SUIVI110665
  Endif

  Read [F:SIV]SIV0=[F:SIH]NUM
  If !fstat Then
    SALFCY_T  = [F:SIV]SALFCY
    STOFCY_T  = [F:SIV]STOFCY
  Else
    SALFCY_T  = [F:SIH]FCY
    STOFCY_T  = ""
  Endif
  BPRNUM_T    = [F:SIH]BPR
  JOU_T       = ""
  If dim([F:SIV]REP(0)) >= 0 Then
    REP1_T    = [F:SIV]REP(0)
    If dim([F:SIV]REP(1)) >= 0 Then
      REP2_T  = [F:SIV]REP(1)
    Endif
  Endif

#  CURS        = [F:SIH]CUR
#  WCHGTYP     = [F:SIH]CURTYP
#  ORDNOT_T    = [F:SIH]AMTNOT
#  ORDATI_T    = [F:SIH]AMTATI
#  SCURVCR_T   = [F:SIH]CUR
#  WMNTORG(0)  = [F:SIH]AMTNOTL
#  WMNTORG(1)  = [F:SIH]AMTATIL
#  Gosub CALC_MNT From CONSPITOOLS
  CURS        = [F:SIH]CUR
  WCHGTYP     = [F:SIH]CURTYP
  ORDNOT_T    = [F:SIH]AMTNOT
  ORDATI_T    = [F:SIH]AMTATI
  SCURVCR_T   = [F:SIH]CUR
  WMNTORG(0)  = [F:SIH]AMTNOTL
  WMNTORG(1)  = [F:SIH]AMTATIL
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:SIH]AMTNOTL
  ORDATIL_T   = [F:SIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
Return

############################################################
$FILL_SIV
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:SIH]NUM
  VCRTYP_T     = NUM_SIV
  If dim(SIV_L) >= 0 Then
    VCRLIN_T = SIV_L
  Endif
  VCRNUMCALC_T = [F:SIH]NUM
  IPTDAT_T     = [F:SIH]ACCDAT

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(429, [F:SIH]STA)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)
  If [M:PIV1]VCRTYPSEL = NUM_SIV Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(429, [F:SIH]STA)
  Endif

  Read [F:SIV]SIV0=[F:SIH]NUM
  If !fstat Then
    SALFCY_T     = [F:SIV]SALFCY
    STOFCY_T     = [F:SIV]STOFCY
    If dim([F:SIV]REP(0)) >= 0 Then
      REP1_T      = [F:SIV]REP(0)
      If dim([F:SIV]REP(1)) >= 0 Then
        REP2_T      = [F:SIV]REP(1)
      Endif
    Endif
    VCRNUMCALC_T = [F:SIV]SIHORINUM
  Else
    SALFCY_T     = [F:SIH]FCY
    STOFCY_T     = ""
    REP1_T       = ""
    REP2_T       = ""
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  BPRNUM_T     = [F:SIH]BPR
  JOU_T        = ""

#  CURS         = [F:SIH]CUR
#  WCHGTYP      = [F:SIH]CURTYP
#  ORDNOT_T     = [F:SIH]AMTNOT
#  ORDATI_T     = [F:SIH]AMTATI
#  SCURVCR_T    = [F:SIH]CUR
#  WMNTORG(0)   = [F:SIH]AMTNOTL
#  WMNTORG(1)   = [F:SIH]AMTATIL
#  Gosub CALC_MNT From CONSPITOOLS
  CURS         = [F:SIH]CUR
  WCHGTYP      = [F:SIH]CURTYP
  ORDNOT_T     = [F:SIH]AMTNOT
  ORDATI_T     = [F:SIH]AMTATI
  SCURVCR_T    = [F:SIH]CUR
  WMNTORG(0)   = [F:SIH]AMTNOTL
  WMNTORG(1)   = [F:SIH]AMTATIL
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T    = [F:SIH]AMTNOTL
  ORDATIL_T    = [F:SIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
Return

############################################################
$FILL_SOH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SOH]SOHNUM
  VCRTYP_T    = NUM_SOH
  If dim(SOH_L) >= 0 Then VCRLIN_T = SOH_L Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    VCRNUMCALC_T = [F:SOH]PJT
  Else
    # Aval
    VCRNUMCALC_T = [F:SOH]LASINVNUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SOH]ORDDAT

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(415, [F:SOH]ORDSTA)
  STBVCRSTAT(2)  = func CONSPITOOLS.GET_MESSAGE(417, [F:SOH]DLVSTA)
  STBVCRSTAT(3)  = func CONSPITOOLS.GET_MESSAGE(418, [F:SOH]INVSTA)
  STBVCRSTAT(4) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:SOH]APPFLG)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)

  If [M:PIV1]VCRTYPSEL = NUM_SOH Then
    [M:PIV1]VCRSTA =  func CONSPITOOLS.GET_MESSAGE(415, [F:SOH]ORDSTA)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(417, [F:SOH]DLVSTA)
    [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(418, [F:SOH]INVSTA)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(280, [F:SOH]APPFLG)
  Endif
  SALFCY_T    = [F:SOH]SALFCY
  STOFCY_T    = [F:SOH]STOFCY
  BPRNUM_T    = [F:SOH]BPCORD
  JOU_T       = ""
  If dim([F:SOH]REP(0)) >= 0 Then
    REP1_T      = [F:SOH]REP(0)
    If dim([F:SOH]REP(1)) >= 0 Then
      REP2_T      = [F:SOH]REP(1)
    Endif
  Endif

#  CURS        = [F:SOH]CUR
#  WCHGTYP     = [F:SOH]CHGTYP
#  ORDNOT_T    = [F:SOH]ORDNOT
#  ORDATI_T    = [F:SOH]ORDATI
#  SCURVCR_T   = [F:SOH]CUR
#  WMNTORG(0)  = [F:SOH]ORDINVNOT
#  WMNTORG(1)  = [F:SOH]ORDINVATI
#  Gosub CALC_MNT From CONSPITOOLS
  CURS        = [F:SOH]CUR
  WCHGTYP     = [F:SOH]CHGTYP
  ORDNOT_T    = [F:SOH]ORDINVNOT
  ORDATI_T    = [F:SOH]ORDINVATI
  SCURVCR_T   = [F:SOH]CUR
  WMNTORG(0)  = [F:SOH]ORDINVNOTL
  WMNTORG(1)  = [F:SOH]ORDINVATIL
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T    = [F:SOH]ORDINVNOTL
  ORDATIL_T    = [F:SOH]ORDINVATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
Return

############################################################
$FILL_SOC
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:SOC]SOHNUM
  VCRTYP_T     = NUM_SOC
  If dim(SOC_L) >= 0 Then
    VCRLIN_T = SOC_L
  Endif
  VCRNUMCALC_T = [F:SOC]SOHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:SOC]EARDATCUS

  If clalev([F:SOHF])=0 : Local File SORDER [SOHF] : Endif
  Read [F:SOHF]SOH0=VCRNUM_T
  If !fstat Then
    # FGR 20/01/2012 : X3SUIVI71278 (début)
    Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
    If [F:SOHF]VLYDATCON < date$ Then
      STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
    Else
      STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_NON)
    Endif
    STBVCRSTAT(2)   += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:SOH]APPFLG)
    # FGR 20/01/2012 : X3SUIVI71278 (fin)
    If [M:PIV1]VCRTYPSEL = NUM_SOC Then
      If [F:SOHF]VLYDATCON < date$ Then
        [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
      Else
        [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, G_NON)
      Endif
      [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(280, [F:SOH]APPFLG)
    Endif
  Endif

  SALFCY_T     = [F:SOC]SALFCY
  STOFCY_T     = [F:SOC]STOFCY
  BPRNUM_T     = [F:SOC]BPCORD
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T   = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_HAE
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:HAE]NUM
  VCRTYP_T     = NUM_HAE
  If dim(HAE_L) >= 0 Then
    VCRLIN_T = HAE_L
  Endif
  VCRNUMCALC_T = [F:HAE]NUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:HAE]ACCDAT
  SALFCY_T     = [F:HAE]FCY
  STOFCY_T     = ""
  JOU_T        = [F:HAE]JOU
  BPRNUM_T     = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T   = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_PRH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:PRH]PRHNUM
  VCRTYP_T    = NUM_PRH
  If dim(PRH_L) >= 0 Then
    VCRLIN_T = PRH_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    VCRNUMCALC_T = [F:PRH]PRLNUM
  Else
    # Aval
    VCRNUMCALC_T = [F:PRH]SDHNUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:PRH]SHIDAT          # Issue X3-38584 - 2018-03-06 by FGR : no [F:PRH]DLVDAT

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(2754, [F:PRH]DLVFLG)
  # FGR 20/01/2012 : X3SUIVI71278 (fin)
  If [M:PIV1]VCRTYPSEL = NUM_PRH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2754, [F:PRH]DLVFLG)
  Endif

  SALFCY_T    = ""
  STOFCY_T    = [F:PRH]STOFCY
  JOU_T       = ""
  BPRNUM_T    = [F:PRH]BPCORD
  REP1_T      = ""
  REP2_T      = ""
  ORDNOT_T    = 0
  ORDATI_T    = 0
  SCURVCR_T   = ""
  ORDNOTL_T   = 0
  ORDATIL_T   = 0
  ORDNOTD_T   = 0
  ORDATID_T   = 0
Return

