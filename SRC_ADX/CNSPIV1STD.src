############################################################
$FILL_DUD
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:DUD]NUMDUD
  If [F:DUD]TYP = "*SO" Then
    VCRTYP_T    = NUM_DUDA
  Else
    VCRTYP_T    = NUM_DUD
  Endif
  If dim(NUM_L) >= 0 Then
    VCRLIN_T = NUM_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    #If dim(SIV_F) >= 0 Then
    If [F:PKW]VCRTYPORI = NUM_SIH Then
      # Facture
      VCRNUMCALC_T = [F:DUD]NUM
    Else
      VCRNUMCALC_T = [F:DUD]NUM
    Endif
  Else
    # Aval
    VCRNUMCALC_T = [F:DUD]NUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:DUD]DUDDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:DUD]FLGFUP)
  If [F:DUD]PAYCUR + [F:DUD]TMPCUR = 0 Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1062)
  Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR < [F:DUD]AMTCUR Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1063)
  Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR >= [F:DUD]AMTCUR Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1064)
  Endif
  If [M:PIV1]VCRTYPSEL = NUM_DUD Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:DUD]FLGFUP)
    If [F:DUD]PAYCUR + [F:DUD]TMPCUR = 0 Then
      [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(196, 1062)
    Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR < [F:DUD]AMTCUR Then
      [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(196, 1063)
    Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR >= [F:DUD]AMTCUR Then
      [M:PIV1]VCRSTA_S= func CONSPITOOLS.GET_MESSAGE(196, 1064)
    Endif
  Endif

  SALFCY_T    = [F:DUD]FCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:DUD]BPR
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

 #CURS        = GLOCALDEV
  CURS        = [F:DUD]CUR
  If VCRTYP_T = NUM_DUDA Then
    # Commande
    Read [F:SOH]SOH0=[F:DUD]NUM
    WCHGTYP   = [F:SOH]CHGTYP
  Else
    # Facture
    Read [F:SIH]SIH0=[F:DUD]NUM
    WCHGTYP   = [F:SIH]CURTYP
  Endif
#  ORDNOT_T    = 0
#  ORDATI_T    = [F:DUD]AMTCUR
#  SCURVCR_T   = [F:DUD]CUR
#  WMNTORG(0)  = 0
#  WMNTORG(1)  = [F:DUD]AMTLOC
#  Gosub CALC_MNT From CONSPITOOLS
#  ORDNOTL_T   = 0
#  ORDATIL_T   = [F:DUD]AMTLOC
  ORDNOT_T    = 0
  ORDATI_T    = [F:DUD]AMTCUR
  SCURVCR_T   = [F:DUD]CUR
  WMNTORG(0)  = 0
  WMNTORG(1)  = [F:DUD]AMTLOC
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T    = 0
  ORDATIL_T    = [F:DUD]AMTLOC
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
Return

############################################################
$FILL_PYH
  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:TPY]) Then Local File TABPAYTYP [TPY]  : Endif   # Transactions de règlements
  If !clalev([F:BAN]) Then Local File BANK [BAN] : Endif         # Compte en banque
  If !clalev([F:PYD1]) Then Local File PAYMENTD [PYD1] : Endif
  #
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:PYH]NUM
  VCRTYP_T    = NUM_PYH
  If dim(NUM_L) >= 0 Then
    VCRLIN_T = NUM_L
  Endif

  VCRNUMCALC_T = num$([F:PYD]DUDNUM) + "/" + num$([F:PYD]DUDLIG)

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:PYH]ACCDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(689, [F:PYH]STA)
  If [M:PIV1]VCRTYPSEL = NUM_PYH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(689, [F:PYH]STA)
  Endif

  SALFCY_T    = [F:PYH]FCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:PYH]BPR
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  Read [F:TPY]TPY0=[F:PYH]PAYTYP
  Read [F:BAN]BAN0=[F:PYH]BAN

  ORDNOT_T    = 0
  ORDATI_T    = [F:PYH]AMTCUR
  SCURVCR_T   = [F:PYH]CUR

  ORDNOTL_T   = 0
  ORDATIL_T   = 0
  If [F:BAN]CUR = GLOCALDEV Then
    # Si devise banque est devise société
    CURS = [F:BAN]CUR
    If [F:PYH]AMTBAN <> 0 Then
      ORDATIL_T    = [F:PYH]AMTBAN
    Elsif [F:PYH]BANPAYTPY <> 0 Then
      ORDATIL_T    = [F:PYH]BANPAYTPY
    Endif
  Endif

  ORDNOTD_T   = 0
  ORDATID_T   = 0
  If [F:BAN]CUR = GSYSCUR Then
    # Si devise banque est devise dossier
    CURS = [F:BAN]CUR
    If [F:PYH]AMTBAN <> 0 Then
      ORDATID_T    = [F:PYH]AMTBAN
    Elsif [F:PYH]BANPAYTPY <> 0 Then
      ORDATID_T    = [F:PYH]BANPAYTPY
    Endif
  Endif
  WCHGTYP     = [F:TPY]RATTYP

  If ORDATID_T = 0 and ORDATIL_T = 0 Then
    # Dans ce cas on cherche les montants autrement
    If [F:TPY]RATINV = G_NON Then
      CURS = [F:PYH]CUR
      WMNTORG(0)  = 0
      WMNTORG(1)  = [F:PYH]AMTCUR
      Gosub CALC_MNT From CONSPITOOLS
    Else
      CURS = [F:PYH]CUR
      WMNTORG(0)  = 0
      WMNTORG(1)  = [F:PYH]AMTCUR
      Gosub CALC_MNT From CONSPITOOLS
      ORDNOTL_T   = 0
      ORDATIL_T   = 0
      Filter [PYD1] Where [F:PYD]NUM = [F:PYH]NUM
      For [PYD1]
        ORDATIL_T = [F:PYD1]PAYLOCLIN
      Next
      Filter [PYD1]
    Endif
  Else
    # Convertir ORDATID_T en devise ORDATIL_T ou ORDATIL_T en devise ORDATID_T selon celui qui est différent de zéro.
    WMNTORG(0)  = 0
    If ORDATIL_T <> 0 Then
      WMNTORG(1)  = ORDATIL_T
    Else
      WMNTORG(1)  = ORDATID_T
    Endif
    Gosub CALC_MNT From CONSPITOOLS
  Endif
Return

############################################################
$FILL_REL
  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:BPC]) Then Local File BPCUSTOMER   [BPC]  : Endif : # Clients
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SOI]SOINUM
  VCRTYP_T    = NUM_REL
  If dim(NUM_L) >= 0 Then
    VCRLIN_T = NUM_L
  Endif

  VCRNUMCALC_T = [F:SOI]SOINUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SOI]SOIDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:SOI]FLGPST)
  If [M:PIV1]VCRTYPSEL = NUM_REL Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:SOI]FLGPST)
  Endif

  SALFCY_T    = [F:SOI]FCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:SOI]BPR
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  Read [F:BPC]BPC0=[F:SOI]BPR
  CURS        = [F:SOI]CUR
  WCHGTYP     = [F:BPC]CHGTYP
  ORDNOT_T    = 0
  ORDATI_T    = [F:SOI]AMTCUR
  SCURVCR_T   = [F:SOI]CUR
  WMNTORG(0)  = 0
  WMNTORG(1)  = [F:SOI]AMTCUR
  Gosub CALC_MNT From CONSPITOOLS
Return

