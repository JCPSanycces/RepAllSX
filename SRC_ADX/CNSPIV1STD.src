############################################################
$FILL_CON
  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:BPC]) Then Local File BPCUSTOMER   [BPC]  : Endif : # Clients
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:CON]CONNUM
  VCRTYP_T    = NUM_CON
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:CON]CONNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:CON]SIUDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(2976, [F:CON]CONCAT)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:CON]EVRPBL)
  STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:CON]EVRMAC)
  STBVCRSTAT(4) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:CON]CRSCOVSAM)
  If [M:PIV1]VCRTYPSEL = NUM_CON Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2976, [F:CON]CONCAT)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(1, [F:CON]EVRPBL)
    [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(1, [F:CON]EVRMAC)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(1, [F:CON]CRSCOVSAM)
  Endif

  SALFCY_T    = [F:CON]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:CON]CONBPC
  JOU_T       = ""
  If dim([F:CON]SALREP(0)) >= 0 Then
    REP1_T    = [F:CON]SALREP(0)
    If dim([F:CON]SALREP(1)) >= 0 Then
      REP2_T  = [F:CON]SALREP(1)
    Endif
  Endif

  Read [BPC]BPC0=BPRNUM_T
  CURS        = [F:CON]CUR
  WCHGTYP     = [F:BPC]CHGTYP
  ORDNOT_T    = [F:CON]CONAMT
  ORDATI_T    = 0
  SCURVCR_T   = [F:CON]CUR
  WMNTORG(0)  = [F:CON]CONAMT
  WMNTORG(1)  = 0
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
$FILL_MAC
  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:BPC]) Then Local File BPCUSTOMER   [BPC]  : Endif : # Clients
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:MAC]MACNUM
  VCRTYP_T    = NUM_MAC
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:MAC]MACNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:MAC]MACPURDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(2972, [F:MAC]MACITNTYP)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:MAC]MACITNLND)
  If [F:MAC]MACSERNUM <> "" Then
    STBVCRSTAT(3) -= ":" - [F:MAC]MACSERNUM
  Else
    Raz STBVCRSTAT(3)
  Endif
  If [M:PIV1]VCRTYPSEL = NUM_MAC Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2972, [F:MAC]MACITNTYP)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(1, [F:MAC]MACITNLND)
    [M:PIV1]VCRSTA_C = [F:MAC]MACSERNUM
  Endif

  SALFCY_T    = [F:MAC]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:MAC]MACCUTBPC
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  Read [BPC]BPC0=BPRNUM_T
  CURS        = [F:MAC]CUR
  WCHGTYP     = [F:BPC]CHGTYP
  ORDNOT_T    = [F:MAC]MACSALPRI
  ORDATI_T    = 0
  SCURVCR_T   = [F:MAC]CUR
  WMNTORG(0)  = [F:MAC]MACSALPRI
  WMNTORG(1)  = 0
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
$FILL_SRE
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SRE]SRENUM
  VCRTYP_T    = NUM_SRE
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:SRE]SRENUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SRE]CREDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1)  = func CONSPITOOLS.GET_MESSAGE(975, [F:SRE]SREASS)
  STBVCRSTAT(2)  = func CONSPITOOLS.GET_MESSAGE(3003, [F:SRE]OVRCOV)
  STBVCRSTAT(3) += STBVCRSTAT(0) + [F:SRE]SREGRALEV #+ STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(428, [F:SRE]SREGRALEV, "LNGDES")
  If [M:PIV1]VCRTYPSEL = NUM_SRE Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(975, [F:SRE]SREASS)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(3003, [F:SRE]OVRCOV)
    [M:PIV1]VCRSTA_C = [F:SRE]SREGRALEV + STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(428, [F:SRE]SREGRALEV, "LNGDES")
  Endif

  SALFCY_T    = [F:SRE]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:SRE]SREBPC
  JOU_T       = ""
  If dim([F:SRE]SREREP(0)) >= 0 Then
    REP1_T    = [F:SRE]SREREP(0)
    If dim([F:SRE]SREREP(1)) >= 0 Then
      REP2_T  = [F:SRE]SREREP(1)
    Endif
  Endif

  CURS        = [F:SRE]SRECUR
  WCHGTYP     = [F:SRE]SRECHGTYP
  ORDNOT_T    = func GET_INV_HDKTASK([F:SRE]SRENUM, "")
  ORDATI_T    = 0
  SCURVCR_T   = [F:SRE]SRECUR
  WMNTORG(0)  = ORDNOT_T
  WMNTORG(1)  = 0
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
$FILL_ITN
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:ITN]NUM
  VCRTYP_T    = NUM_ITN
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:ITN]NUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:ITN]DAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:ITN]DON)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:ITN]SCO)
  STBVCRSTAT(3) += STBVCRSTAT(0) + [F:ITN]TYP #+ STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(407, [F:ITN]TYP, "LNGDES")
  If [M:PIV1]VCRTYPSEL = NUM_ITN Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:ITN]DON)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(1, [F:ITN]SCO)
    [M:PIV1]VCRSTA_C = [F:ITN]TYP + STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(407, [F:ITN]TYP, "LNGDES")
  Endif

  SALFCY_T    = [F:ITN]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:ITN]BPC
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  Read [F:SRE]SRE0=[F:ITN]SRVDEMNUM
  CURS        = [F:SRE]SRECUR
  WCHGTYP     = [F:SRE]SRECHGTYP
  ORDNOT_T    = func GET_INV_HDKTASK([F:SRE]SRENUM, [F:ITN]NUM)
  ORDATI_T    = 0
  SCURVCR_T   = [F:SRE]SRECUR
  WMNTORG(0)  = ORDNOT_T
  WMNTORG(1)  = 0
  Gosub CALC_MNT From CONSPITOOLS
Return

############################################################
Funprog GET_INV_HDKTASK(SSRENUM, SITNNUM)
Value Char SSRENUM
Value Char SITNNUM

Local Decimal IARENDRE

  If !clalev([F:HDT]) Then Local File HDKTASK [HDT]  : Endif
  IARENDRE = 0
  Filter [F:HDT] Where [F:HDT]SRENUM = SSRENUM and (SITNNUM = "" or (SITNNUM <> "" and [F:HDT]ITNNUM = SITNNUM)) and [F:HDT]HDTINV = G_OUI
  For [F:HDT]
    IARENDRE += [F:HDT]HDTAMTINV
  Next
  Filter [F:HDT]
End IARENDRE

############################################################
$FILL_SOL
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:SOL]NUM
  VCRTYP_T    = NUM_SOL
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:SOL]NUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:SOL]CREDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + [F:SOL]CAT #+ STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(409, [F:SOL]CAT, "LNGDES")
  STBVCRSTAT(2) += STBVCRSTAT(0) + [F:SOL]PBLGRP
  If [M:PIV1]VCRTYPSEL = NUM_SOL Then
    [M:PIV1]VCRSTA = [F:SOL]CAT + STBVCRSTAT(0) + func CRM_UTIL.FGET_LIB(409, [F:SOL]CAT, "LNGDES")
    [M:PIV1]VCRSTA_S = [F:SOL]PBLGRP
  Endif

  SALFCY_T    = ""
  STOFCY_T    = ""
  BPRNUM_T    = ""
  JOU_T       = ""
  REP1_T      = ""
  REP2_T      = ""

  CURS        = ""
  WCHGTYP     = 0
  ORDNOT_T    = 0
  ORDATI_T    = 0
  SCURVCR_T   = ""
  WMNTORG(0)  = 0
  WMNTORG(1)  = 0
Return

