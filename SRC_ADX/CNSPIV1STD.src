  If [M:PIV1]VCRTYPSEL = NUM_TSK Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:TSK]TSKDON)
  Endif

  SALFCY_T    = [F:TSK]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:TSK]TSKCMP
  JOU_T       = ""
  REP1_T      = [F:TSK]TSKREP
  REP2_T      = ""

  CURS        = ""
  WCHGTYP     = 0
  ORDNOT_T    = 0
  ORDATI_T    = 0
  SCURVCR_T   = ""
  WMNTORG(0)  = 0
  WMNTORG(1)  = 0
Return

############################################################
$FILL_CLL
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:CLL]CLLNUM
  VCRTYP_T    = NUM_CLL
  VCRLIN_T    = 0

  VCRNUMCALC_T = [F:CLL]CLLNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T  = [F:PKW]VCRNUM
    VCRLINORI_T  = [F:PKW]VCRLIN
    VCRTYPORI_T  = [F:PKW]VCRTYP
  Endif
  IPTDAT_T    = [F:CLL]CLLDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:CLL]CLLDON)
  STBVCRSTAT(2)  = func CONSPITOOLS.GET_MESSAGE(956, [F:CLL]CLLTYP)
  If [M:PIV1]VCRTYPSEL = NUM_CLL Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:CLL]CLLDON)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(956, [F:CLL]CLLTYP)
  Endif

  SALFCY_T    = [F:CLL]SALFCY
  STOFCY_T    = ""
  BPRNUM_T    = [F:CLL]CLLCMP
  JOU_T       = ""
  REP1_T      = [F:CLL]CLLREP
  REP2_T      = ""

  CURS        = ""
  WCHGTYP     = 0
  ORDNOT_T    = 0
  ORDATI_T    = 0
  SCURVCR_T   = ""
  WMNTORG(0)  = 0
  WMNTORG(1)  = 0
Return

############################################################
$FILL_BAP
  # FGR 13/01/2012 : X3SUIVI71278
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T    = [F:BAP]APTNUM
  VCRTYP_T    = NUM_BAP
  VCRLIN_T    = 0

