#<AdxTL>@(#)226.0.0.0 $Revision$
##########################################################################
Subprog VALDIC
##########################################################################
Local Integer OK , FORCE
Local Char VALEUR(10), PARAM(30)(1..2)
If filinfo(filpath("FIL",[M:ATB0]CODFIC,"fde"),0)<=0 & filinfo(filpath("FIL",[M:ATB0]CODFIC,"srf"),0)<=0
 OK=2 : Call OUINON(mess(16,176,1)-[M:ATB0]CODFIC,OK) From GESECRAN : # Génération du fichier CODFIC ?
Else
 Call SAISIE_CHAR(VALEUR,PARAM,"AFORCE","VALDIC","") From GSAISIE
 OK = val(PARAM(2))
Endif
Case OK
 When 2       : FORCE = 0
 When 3       : FORCE = 1
 When Default : End
Endcase
Call TEMPON("V") From GESECRAN
Call MAJFIC([M:ATB0]CODFIC,nomap,FORCE) 
Call MAJTRIG([M:ATB0]CODFIC,nomap)
Call TEMPOFF From GESECRAN
End

########################################################
$ACTION
Case ACTION
 When "OK"     : PARAM(2) = "2" : FIN = 1
 When "BOUTON" : PARAM(2) = "3" : FIN = 1
 When "END"    : PARAM(2) = "1" : FIN = 1
Endcase
Return

########################################################
Subprog MAJFIC(TABLE,APPLI,FORCE)
Value Char    TABLE
Value Char    APPLI
Value Integer FORCE

Global Decimal GCOEFTAB : GCOEFTAB = 0.5

Local Char    HISAPL(GLONADS)
Local Char    MESSAGE(80)(1..5) , FICTRA(250)
Local Char    LIGNE(250) , LIGNE1(250) , ORDSYS(250)(1..2)
Local Integer I , STAT , NEWLIG
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM

If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"  [ATI] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"   [ATX] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif
If clalev([F:ANX])=0 : Local File =APPLI+".AINDEX"   [ANX] : Endif
If clalev([F:ADW])=0 : Local File =APPLI+".ADOVAL"   [ADW] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADA])=0 : Local File ADOSACT  [ADA] : Endif

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Read [ADS]DOSSIER = APPLI

## Mise à jour des liens/Rajout des champs système v7

Gosub SET_FLDSYS From SUBATB
Gosub SET_TABSYS From SUBATB

Call DEBTRANS From GLOCK
Gosub TR_LIEN

## Validation de la table

Call MAJTAB(TABLE,FORCE) From DOSTAB

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Close Local File
End

#####################
$TR_LIEN
GOK=1
Trbegin [ATZ]

 # Mise à jour des liens

 NEWLIG = 0
 For [ATZ]NUMLIG Where CODFIC=TABLE
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If !fstat & [F:ATY]FICLIEN<>"" & [F:ATZ]LIEN<>[F:ATY]FICLIEN & [F:ATZ]LIEN<>""
   [F:ATZ]LIEN = [F:ATY]FICLIEN
   If [F:ATZ]ANNUL=0 : [F:ATZ]ANNUL = 1 : Endif
   If [F:ATZ]OBLIG=0 : [F:ATZ]OBLIG = 2 : Endif
   Rewrite [ATZ]
   If fstat
    GOK=0 : Call FSTA("ATZ") From GLOCK : Break
   Endif
  Endif
  NEWLIG = [F:ATZ]NUMLIG    
 Next
 If GOK<1 : Goto AB_TR_LIEN : Endif

 # Rajout des champs système
 # Rajout systématique non activé pour le moment - c'est fait uniquement à la création d'une nouvelle table

 If !find(TABLE,TABSYS(1..NBSYS)) & 1=0
  For I=1 To dim(FLDSYS)
   If FLDSYS(I)<>""
    Read [ATZ]CODZONE=TABLE;FLDSYS(I)
    If fstat
     NEWLIG += 1
     Raz [F:ATZ]
     [F:ATZ]CODFIC  = TABLE
     [F:ATZ]CODZONE = FLDSYS(I)
     [F:ATZ]CODTYP  = TYPFLD(I)
     [F:ATZ]NUMLIG  = NEWLIG
     [F:ATZ]DIME    = 1
     [F:ATZ]NOABREG = INTFLD(I)
     [F:ATZ]NOCOURT = INTFLD(I)
     [F:ATZ]NOLONG  = INTFLD(I)
     [F:ATZ]ANNUL   = ANUFLD(I)
     [F:ATZ]LIEN    = LNKFLD(I)
     If TYPFLD(I)="AUS"
      [F:ATZ]VERIF  = 1
     Endif
     [F:ATZ]OBLIG   = 1
     [F:ATZ]ZERO    = 1
     Write [ATZ]
     If fstat
      GOK=0 : Call FSTA("ATZ") From GLOCK : Break
     Endif
    Endif
   Endif
  Next I
  If GOK<1 : Goto AB_TR_LIEN : Endif
 Endif

Commit
Return

$AB_TR_LIEN
Rollback
Return

########################################################
Subprog MAJTRIG(TABLE,APPLI)
Value Char    TABLE
Value Char    APPLI

If clalev([F:ATB])=0 : Local File =APPLI+".ATABLE"   [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =APPLI+".ATABZON"  [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =APPLI+".ATABIND"  [ATI] : Endif
If clalev([F:ATX])=0 : Local File =APPLI+".ATEXTE"   [ATX] : Endif
If clalev([F:ATY])=0 : Local File =APPLI+".ATYPE"    [ATY] : Endif
If clalev([F:ACV])=0 : Local File =APPLI+".ACTIV"    [ACV] : Endif
If clalev([F:ANX])=0 : Local File =APPLI+".AINDEX"   [ANX] : Endif
If clalev([F:ADW])=0 : Local File =APPLI+".ADOVAL"   [ADW] : Endif
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If clalev([F:ADA])=0 : Local File ADOSACT  [ADA] : Endif

Read [ADS]DOSSIER = APPLI

Call MAJTRIG(TABLE) From DOSTAB
Close Local File
End

####################################################################
Subprog RAZFIC(TABLE,FLG130)
Value Char    TABLE
Value Integer FLG130
Local Integer OK , STAT
Local Char    ORDSYS(250)(1..2)
Local Char    FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5)
OK=1 : Call OUINON(mess(52,123,1)-TABLE,OK) From GESECRAN : # Remise à zéro de la table
If OK<>2 : End : Endif
GOK = 1
Gosub RAZTAB
If GOK
 Call MAJTRIG(TABLE,nomap) 
Endif
End

$RAZTAB
FICTRA  = filpath("tmp",TABLE,"tra",0)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Endif
ORDSYS(1) = "valfil -s -z"
If FLG130=2 : # Version 130
 ORDSYS(1) -= "-a"
Endif
ORDSYS(1) -= nomap-TABLE
ORDSYS(2) = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Openi
If MESSAGE(1)<>""
 GOK = 0 : # Erreur en validation de la table
 Call ECR_TRACE(mess(51,123,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
Endif
Return

