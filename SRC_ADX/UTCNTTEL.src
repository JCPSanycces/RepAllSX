#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Liste des champs "tûˋlûˋphone" qui ne respectent pas le format du pays
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Control 'Phone' fied") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Control folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Control folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub CNTTEL
End

#-------------------#
$CNTTEL
Local Integer NBFLD , I , ENT , TBDIM(1..30) , ER
Local Char    TBFLD(GLONAVA)(1..30) , FLDTCY(GLONAVA) , PAYS(GLONCRY)
Local Char    CHAINE(250) , CLE(250) , MESSA(250) , ZONE(60)

Local File =DOSSIER+".ATABZON" [ATZ] , =DOSSIER+".TABCOUNTRY" [TCY]
&         ,=DOSSIER+".ATABIND" [ATI] , =DOSSIER+".ACTIV"      [ACV]

For [ATZ]CODZONE(1)
 Raz NBFLD , FLDTCY , TBDIM , TBFLD
 For [ATZ]CODZONE
  If [F:ATZ]CODTYP="TEL"
   NBFLD += 1
   TBFLD(NBFLD) = [F:ATZ]CODZONE
   If [F:ATZ]DIME>0
    TBDIM(NBFLD) = [F:ATZ]DIME
   Elsif [F:ATZ]CODACT<>""
    Read [ACV]CODACT = [F:ATZ]CODACT
    If !fstat
     TBDIM(NBFLD) = [F:ACV]DIME
    Endif
   Endif
   TBDIM(NBFLD) = max(1,TBDIM(NBFLD))
  Elsif [F:ATZ]CODTYP="CRY"
   FLDTCY = [F:ATZ]CODZONE
  Endif
 Next ATZ
 If NBFLD>0
  Gosub SETCLE
  Gosub CNTTAB
 Endif
Next ATZ(1)

Close Local File
Return

#----------------------------#
$SETCLE
CLE = ""
Read [ATI]NUMLIG(2) = [F:ATZ]CODFIC;1
If !fstat
 CHAINE = [F:ATI]DESCRIPT
 While CHAINE<>""
  I = instr(1,CHAINE,"+")
  J = instr(1,CHAINE,"-")
  If I & J
   I = min(I,J)
  Elsif J & !I
   I = J
  Endif
  If CLE<>""
   CLE += '-'
  Endif
  If I
   CLE += 'num$([F:XXX]'+left$(CHAINE,I-1)+')'
   CHAINE = right$(CHAINE,I+1)
  Else
   CLE += 'num$([F:XXX]'+CHAINE+')'
   CHAINE = ""
  Endif
 Wend
Endif
Return

#--------------------------#
$CNTTAB
If filinfo(filpath("FIL",[F:ATZ]CODFIC,"fde",DOSSIER),0)>0
 Local File =DOSSIER+"."+[F:ATZ]CODFIC [XXX]
 ENT = 0
 For [XXX]
  If FLDTCY=""
   PAYS = GPAYS
  Else
   PAYS = evalue("[F:XXX]"+FLDTCY)
  Endif
  If PAYS<>""
   Gosub LECPAY
  Endif
  For I=1 To NBFLD
   For J=1 To TBDIM(I)
    ZONE = "[F:XXX]"+TBFLD(I)
    If J>1
     ZONE += "("+num$(J-1)+")"
    Endif
    Onerrgo ER
    CHAINE = evalue(ZONE)
    Onerrgo
    If ER
     Call ECR_TRACE("Erreur"-[F:ATZ]CODFIC-ZONE,1) From GESECRAN
    Elsif CHAINE<>""
     MESSA = ""
     Call CNTTEL(CHAINE,MESSA) From CONTNUM
     If MESSA<>""
      If !ENT
       Call ECR_TRACE("#### File"-[F:ATZ]CODFIC,0) From GESECRAN
       If FLDTCY=""
        Call ECR_TRACE("Country field not found -> default country used"-GPAYS,-1) From GESECRAN
       Endif
       ENT = 1
      Endif
      Call ECR_TRACE("key="+evalue(CLE)-", Field="+ZONE-", Phone="+CHAINE-"->"-MESSA,-1) From GESECRAN
     Endif
    Endif
   Next J
  Next I
 Next XXX
 Close Local File [XXX]
Endif
Return

#------------#
$ER
ER = errn
Resume

#--------------------------#
$LECPAY
If [F:TCY]CRY<>PAYS
 Read [TCY]TCY0 = PAYS
 If fstat : Raz [F:TCY] : Return : Endif
Endif
Return
