######################################################################################

Subprog FIND_POF (LMAT)
Value Integer LMAT
Local Integer NOL : NOL=LMAT
Local Integer W_FOUND : W_FOUND=0
#-------------------------------------------#
# On vérifie si une commande est rattachée  #
# en cherchant un encours POF ou TRF        #
#-------------------------------------------#
# si matière fournie par le ss-traitant uniquement
If [M:SCO2]SCOFLG(NOL)<>3 : End : Endif
If [M:SCO2]POHNUM(NOL)=""
  Raz [F:ORD]
  If [M:SCO0]BETFCY=2 & [M:SCO0]BETCPY<>2
#   Commande inter-site: encours de type 7 TRF
    Filter [ORD] Where WIPTYP=7 & WIPSTA=1      & ITMREF=[M:SCO2]CPNITMREF(NOL)
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=[M:SCO2]SCMLIN(NOL)
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD] Else W_FOUND = 1 Endif
  Else
#   Recherche d'un encours article POF
    Filter [ORD] Where WIPTYP=2 & WIPSTA=1      & ITMREF=[M:SCO2]CPNITMREF(NOL)
&                    & VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                    & VCRLINORI=[M:SCO1]SCILIN # & VCRSEQORI=[M:SCO2]SCMLIN(NOL)
    Read   [ORD] ORD0 First
    If fstat : Raz [F:ORD]  Else W_FOUND = 1 Endif
  Endif
  Filter [ORD]
  If W_FOUND = 1
    # Référence ligne commande sur [F:SCM]
    [M:SCO2]POHNUM(NOL) = [F:ORD]VCRNUM
    [M:SCO2]POPLIN(NOL) = [F:ORD]VCRLIN
    [M:SCO2]POQSEQ(NOL) = [F:ORD]VCRSEQ
    Gosub SCM_MATSTA_PUR From SCOLIB
    Affzo [M:SCO2]MATSTA (NOL)
    #
    # Référence de l'encours POF
    [M:SCO2]WIPTYP(NOL) = [F:ORD]WIPTYP
    [M:SCO2]WIPSTA(NOL) = [F:ORD]WIPSTA
    [M:SCO2]WIPNUM(NOL) = [F:ORD]WIPNUM
#
  Else
#   Recherche d'une ligne de commande
    Filter [POQW] Where  VCRTYPORI=36             & VCRNUMORI=[M:SCO0]SCONUM
&                      & VCRLINORI=[M:SCO1]SCILIN & VCRSEQORI=[M:SCO2]SCMLIN(NOL)
&                      & ITMREF   =[M:SCO2]CPNITMREF(NOL)
    Read   [POQW]POQ4 First
    If fstat : Raz [F:POQW] : Goto FIN_FIND_POF : Endif
#
    # Référence ligne commande sur [F:SCM]
    [M:SCO2]POHNUM(NOL) = [F:POQW]POHNUM
    [M:SCO2]POPLIN(NOL) = [F:POQW]POPLIN
    [M:SCO2]POQSEQ(NOL) = [F:POQW]POQSEQ
    Gosub SCM_MATSTA_PUR From SCOLIB
    Affzo [M:SCO2]MATSTA (NOL)
  Endif
Else
# TEMPORAIRE: si ligne POQW supprimée => Raz de la référence
  Read [POQW] POQ0=[M:SCO2]POHNUM(NOL);[M:SCO2]POPLIN(NOL);[M:SCO2]POQSEQ(NOL)
  If fstat
     Raz [F:POQW]
     Raz [M:SCO2]POHNUM(NOL),[M:SCO2]POPLIN(NOL),[M:SCO2]POQSEQ(NOL)
     [M:SCO2]MATSTA(NOL) = 1
  Elsif find([M:SCO2]MATSTA(NOL),0,1,4)
    Gosub SCM_MATSTA_PUR From SCOLIB
  Endif
  Affzo [M:SCO2]MATSTA (NOL)
Endif
$FIN_FIND_POF
Filter [POQW]
If [M:SCO2]POHNUM(NOL)=""
   Actzo [M:SCO2]CPNITMREF(NOL), MATSTA(NOL), RETQTY(NOL)
Else
 # Issue 93852 GA 01/2014 ajout GROPRI
 # une fois le service commandé, il faut utiliser l'écran de maj des commandes pour màj la qté
 # => les zones sont bloquées dans la saisie de SCO
   Diszo [M:SCO2]CPNITMREF(NOL), MATSTA(NOL), RETQTY(NOL), GROPRI(NOL)
Endif
End

######################################################################################
Subprog CTRL_SCOFLG (LSCOFLG,NOL)
Value Integer LSCOFLG
Value Integer NOL
Local Decimal WDIS
Local Integer WRET

mkstat=0

If LSCOFLG=2
# -----------------------------------------------
# Matière mise à disposition du sous-traitant
# -----------------------------------------------

  [M:SCO2]PICPRN(NOL) = 2
  If [M:SCO2]CPNTYP(NOL)>1
  # "Ce type de composant ne peut être mis à disposition du sous-traitant"
     GMESSAGE=mess(524,199,1) : mkstat=1 : GERR = 1 : End
  Endif
#
  # Issue 83062 GA 07/2012 ne pas recalculer les dates des matières
  If GACTION<>"LIENS" | [M:SCO2]DLVDAT(NOL)=[0/0/0]
    # Date de livraison des matières
    Local Integer WOFS : WOFS=[M:SCO2]BOMOFS(NOL)
    Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(NOL),WOFS,[M:SCO2]DLVDAT(NOL)) From SCOLIB
  Endif

  # V6 Règle d'affectation
  [M:SCO2]PTOCOD(NOL) = func ITMLIB.GET_PTOCOD([M:SCO2]CPNITMREF(NOL),[M:SCO2]STOFCY(NOL))

Elsif LSCOFLG=3
  # Est-ce que cet article est acheté ? sinon pb génération de la commande d'achat
    WOK = func ITMLIB.IS_BOUGHT ( [M:SCO2]CPNITMREF(NOL) )
    If WOK=1 : mkstat=1: End : Endif

  # Est-ce que cet article est vendu ? sinon pb génération de la commande de vente intersite
    If [M:SCO0]BETCPY = 2 | [M:SCO0]BETFCY = 2
       WOK = func ITMLIB.IS_SOLD ( [M:SCO2]CPNITMREF(NOL) )
       If WOK=1 : mkstat=1: End : Endif
    Endif
Endif
# -----------------------------------------------
# Matière interne ou fournie par le sous-traitant
# -----------------------------------------------
If LSCOFLG<>2 | [M:SCO2]CPNTYP(NOL)=5
   [M:SCO2]PICPRN(NOL) = 1 : : Affzo [M:SCO2]PICPRN(NOL)
   #----- article non géré en stock         -----#
   [M:SCO2]STOMGTCOD  (NOL)=1  : Affzo [M:SCO2]STOMGTCOD(NOL)
   Raz [M:SCO2]AVAQTY (NOL)    : Affzo [M:SCO2]AVAQTY(NOL)
   Raz [M:SCO2]LOC    (NOL)    : Affzo [M:SCO2]LOC(NOL)
   Raz [M:SCO2]MFGFCY (NOL)    : Affzo [M:SCO2]MFGFCY(NOL)
   Raz [M:SCO2]LOT    (NOL)    : Affzo [M:SCO2]LOT(NOL)
   Raz [M:SCO2]DLVDAT (NOL)    : Affzo [M:SCO2]DLVDAT(NOL)
# Issue 83440 GA 11/2012
   Raz [M:SCO2]STOFCY (NOL)    : Raz [M:SCO2]LOC(NOL)
   Affzo [M:SCO2]STOFCY(NOL)   : Affzo [M:SCO2]LOC(NOL)
# Issue 83440 GA 11/2012
#Elsif [M:SCO2]STOFCY(NOL)="" & [M:SCO0]POHFCY<>""
   #[M:SCO2]STOFCY(NOL) = [M:SCO0]POHFCY
Endif

If [M:SCO2]STOMGTCOD(NOL)=2    # recherche stock disponible site
  Call LECITV2([M:SCO2]STOFCY(NOL),[M:SCO2]CPNITMREF(NOL),WRET) From MFGLIB

  #--- Issue 115110 : Added LECCVAL parameter in 10th position
  Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
  If dim([M:SCO2]ECCVALMAJ)>0 & [M:SCO2]ECCVALMAJ(NOL)<>""
    If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
    Call LECSRU([M:SCO2]STOFCY(NOL),[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
    If WRET=0 & [F:SRU]ORDVER=2
      WECCVALMAJ=[M:SCO2]ECCVALMAJ(NOL)
    Endif
  Endif
  Call STODISALL([M:SCO2]STOFCY(NOL),[M:SCO2]CPNITMREF(NOL),36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
  #Call STODISALL([M:SCO2]STOFCY(NOL),[M:SCO2]CPNITMREF(NOL),36,1,2,1,2,"","",WDIS,WRET) From STKALL
  #--- End issue 115110

  [M:SCO2]AVAQTY(NOL)    = WDIS + [M:SCO2]ALLQTY(NOL)
  Affzo [M:SCO2]AVAQTY(NOL)
Endif

End

######################################################################################

Subprog D_SCSLIN(VALEUR)
Variable Decimal VALEUR
  Call CALC_SCSLIN(VALEUR)
End

######################################################################################
# FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
Local Integer  NOL : NOL=nolign-1
If [M:SCO1]ITMSTA>2 : mkstat=2 : End : Endif
If [M:SCO2]SCOFLG(NOL)<>3
  Raz [M:SCO2]GROPRI(NOL),[M:SCO2]NETPRI(NOL),[M:SCO2]PRIREN(NOL),[M:SCO2]REFPRI(NOL),LINAMT(NOL)
  If dim([M:SCO1]CHGTYP)>0
    Local Integer LMAT : LMAT=NOL
    Gosub CALC_LINAMT_SCO2 From SCOLIB
    # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
    #Affzo [M:SCO2]
  Endif
  Affzo [M:SCO2]GROPRI(NOL),PRIREN(NOL),REFPRI(NOL),LINAMT(NOL),LINAMTL(NOL)
  mkstat=2
Endif
End

######################################################################################
# FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR

Local Integer  J, NOL : NOL=nolign-1

If VALEUR=[M:SCO2]GROPRI(NOL) | [M:SCO2]SCOFLG(NOL)<>3 End : Endif

If VALEUR=0
  # Relecture du tarif achat
  Call UPD_MAT_PRI(NOL) From SCOLIB
  VALEUR=[M:SCO2]GROPRI(NOL)
Else
  #----- Lecture BPSUPPLIER nécessaire pour chargement PLISTC tarifs -----#
  If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
     WBPRNUM = [M:SCO0]BPRNUM
     Gosub READ_BPS From BPRLIB
  Endif

  Local Decimal  MT1, MT2, DISCRGVAL(0..8)
  For J=1 To 9
      If evalue("dim([M:SCO2]DISCRGVAL"+num$(J)+"(NOL))")>0
          If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&             MT1=evalue("[M:SCO2]DISCRGVAL"+num$(J)+"(NOL)*MT2")
              Call ARRDEV(MT1,[M:SCO1]CUR) From TRTDIV
              Assign "[M:SCO2]DISCRGVAL"+num$(J)+"(NOL)" With MT1
          Endif
          DISCRGVAL(J-1)=evalue("[M:SCO2]DISCRGVAL"+num$(J)+"(NOL)")
      Endif
  Next J
  If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
  If dim(GCALNETABR)>0  GCALNETABR="[M:SCO2]" : Endif
  Call CALNET(2,[F:BPS]PLISTC,VALEUR,DISCRGVAL,[M:SCO2]RETQTY(NOL),
&               [M:SCO2]NETPRI(NOL),[M:SCO1]CUR) From TRTPRICE
#
  If dim(GDACMANPUR)<0 | GDACMANPUR=0      # Issue 93852 GA 01/2014
    [M:SCO2]PRIREN(NOL)=GUPDPRIPUR         # 8=Motif ne venant pas du tarif
  Else
    [M:SCO2]PRIREN(NOL)=GDACMANPUR         # Motif de saisie manuelle du prix de la DA
  Endif
  # FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
  If dim([M:SCO1]CHGTYP)>0
    [M:SCO2]GROPRI(NOL)=VALEUR     # FQ 76145 GA 09/2011 sinon GROPRI est raz en fin de ctrl
    Local Integer LMAT : LMAT=NOL
    Gosub CALC_LINAMT_SCO2 From SCOLIB
  Endif
Endif
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
#Affzo [M:SCO2]
Affzo [M:SCO2]GROPRI(NOL), PRIREN(NOL),REFPRI(NOL),LINAMT(NOL),LINAMTL(NOL)
End

Subprog AP_GROPRI(VALEUR)               # Issue 93852 GA 01/2014
Variable Decimal VALEUR
#---------------------------------------------------------------------------------#
# Après saisie du prix brut : si matière fournie par le sous-traitant             #
#---------------------------------------------------------------------------------#
If [M:SCO2]SCOFLG(nolign-1)<>3 VALEUR=0 Endif
End

######################################################################################
# pour la navigation vers le plan d'affectation
$MEM_VCR
If find(GREP,"C","D")
    If dim(GVCR) > 0 : # Issue 121512 GH 15/02/2017 - Wrong test of dim
        Raz GVCR, GLIN, GSEQ
    Endif
    Return
Endif
If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
Endif

GVCR = [M:SCO0]SCONUM
GLIN = [M:SCO1]SCILIN    # FQ 78073 avant (nolign-1)
GSEQ = [M:SCO2]SCMLIN(nolign-1)
Return
