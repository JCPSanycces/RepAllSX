Subprog B13_NBLIG
Call ERRMSG("SCO2",nolign-1) From MFGLIB
End


Subprog AVANT_NBLIG
# nouvelle ligne ?
If [M:SCO2]CPNITMREF(nolign-1)=""
  Gosub RAZCRE
Endif
# Issue 110904/114860 - 2016-04-12 by JUSYN : Display or hide for BOM version fields
If [M:SCO2]CPNITMREF(nolign-1) <> ""
    Call ECCAFF([M:SCO2]CPNITMREF(nolign-1) , "SCO2" , nolign-1) From SCOECCLIB
Endif
End

Subprog APRES_NBLIG
[M:SCO2]UPDFLG(nolign-1) = 1
End

######################################################################################

Subprog D_SCMLIN(VALEUR)
Variable Decimal VALEUR
Call CALC_SCMLIN(VALEUR,nolign)
End

Subprog C_CPNITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer    I
Local Integer    WOK  : WOK  = 2
Local Char       WFCY   (GLONFCY) : WFCY   =[M:SCO2]STOFCY(nolign-1)
Local Char       WITMREF(GLONITM) : WITMREF=VALEUR
#
# Issue 87038 GA 01/2013 performances ?
If [F:ITM]ITMREF<>WITMREF
  # Ctrl de la réf d'article saisie
  Gosub READ_ITM From ITMLIB
#
  # Issue 85534 GA 11/2012 ctrl ssi article-site trouvé
  # If WFCY = ""
  #    WFCY = [M:SCO1]PRHFCY
  # Endif
  # Gosub READ_ITF From ITMLIB
  # Call CONTMATITM(VALEUR, WFCY, [M:SCO2]SCOFLG(nolign-1), 1) From SCOLIB
  #
Endif
#
End

Subprog AM_CPNITMREF(VALEUR)
Variable Char    VALEUR()
#
If VALEUR<>[M:SCO2]CPNITMREF(nolign-1) & [M:SCO2]CPNITMREF(nolign-1)<>""
#  si changt d'article, raz des zones de prix pour relire le tarif
   Raz [M:SCO2]GROPRI(nolign-1),PRIREN(nolign-1),NETPRI(nolign-1),REFPRI(nolign-1),LINAMT(nolign-1)
Endif

# Issue 87038 GA 01/2013 performances: déplacé depuis C_CPNITMREF ?
  For I=0 To [M:SCO2]NBLIG-1
      If [M:SCO2]BOMSEQ(I)=0 & [M:SCO2]CPNITMREF(I) = VALEUR
        GMESSAGE = mess(67,193,1)
        mkstat = 2
        Break
      Endif
  Next I

If VALEUR <> [F:BOD]CPNITMREF
 # on charge la 1ere matière qui correspond
   Filter [BOD] Where ITMREF=[M:SCO0]ITMREF and BOMALT=[M:SCO0]BOMALT and CPNITMREF=VALEUR
&                 and BOMALTTYP = 3
&                 and (BOMSTRDAT=[0/0/0] or BOMSTRDAT <= [M:SCO1]ORDDAT)
&                 and (BOMENDDAT=[0/0/0] or BOMENDDAT >= [M:SCO1]ORDDAT)
   Read   [BOD] BOD0 First : If ! fstat : [M:SCO2] = [F:BOD]: Else Raz [F:BOD] : Endif
   Filter [BOD]
Endif
# FQ 74682 GA 07/2011 + BPRNUM
Call RECH_SCO2_CPNITMREF(VALEUR,[M:SCO0]ITMREF,[M:SCO0]BPRNUM)
If mkstat Goto RETOURITMREF : Endif
#-----
If [M:SCO2]NBLIG < nolign
   [M:SCO2]NBLIG = nolign
Endif
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
#Affzo [SCO2]
#Infbox "Debug AM_CPNITMREF: sortie Ok ... VALEUR="-VALEUR-" Lig="-num$(nolign)
End
#----- Retour à la saisie de la référence article -----#
$RETOURITMREF
mkstat=1 : VALEUR =""
End


Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
# Site des matières = Site de réception article commandé (par défaut)
### VALEUR = [M:SCO0]POHFCY
End

Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End Endif

# Ctrl de la réf d'article saisie
Local Char WITMREF(GLONITM) : WITMREF=[M:SCO2]CPNITMREF(nolign-1)
Local Char WFCY   (GLONFCY) : WFCY=VALEUR
Gosub READ_ITF From ITMLIB
# Issue 85539 - 2012-11-05 by CCC : Contrôle bloquant site
If GOK=-1 : GOK=1 : OK=1 : GMESSAGE=mess(139,197,1)-WITMREF-WFCY : mkstat=2 : End : Endif

If [F:ITF]STOMGTCOD>0
   [M:SCO2]STOMGTCOD(nolign-1)=[F:ITF]STOMGTCOD : Affzo [M:SCO2]STOMGTCOD(nolign-1)
Endif
End

########################################
Subprog C_RETQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0 & [M:SCO2]MATSTA(nolign-1)<>4 & [M:SCO2]CPNTYP(nolign-1)<>5 : mkstat = 2 : End : Endif
If VALEUR > 0 & VALEUR < [M:SCO2]USEQTY(nolign-1)
   Call MESSAGE(mess(63,193,1)) From GESECRAN
   mkstat=2
   End
Endif
End

########################################
Subprog AM_RETQTY(VALEUR)
Variable Decimal VALEUR
Local    Decimal WCPL
Local    Decimal WEXT
Local    Integer WRET
Local    Integer NOL : NOL = nolign-1
Local    Integer VS

WEXT = VALEUR
WCPL = [M:SCO2]USEQTY(NOL)
Call CONT_SOLDE_MAT([M:SCO2]STOFCY(NOL), [M:SCO2]CPNITMREF(NOL), WCPL, WEXT, WRET) From SCOLIB
If WRET = 1
    VS=1
    Call AVERTIR(mess(53,190,1),VS) From GESECRAN
    If VS = 1
        VALEUR = [M:SCO2]RETQTY(NOL)
        mkstat = 2
        End
    Endif
    [M:SCO2]MATSTA(NOL)   = 3
    Affzo [M:SCO2]MATSTA(NOL)
Endif

# Issue 86384 GA 12/2012
If [M:SCO2]SCOFLG(NOL)=0 [M:SCO2]SCOFLG(NOL)=2 Endif
If [M:SCO2]SCOFLG(NOL)=2
   If [M:SCO2]STOFCY(NOL)="" : [M:SCO2]STOFCY(NOL) = [M:SCO1]PRHFCY : Endif
   If [M:SCO2]LOC   (NOL)="" : [M:SCO2]LOC   (NOL) = [M:SCO1]LOC    : Endif
   If [M:SCO2]MFGFCY(NOL)="" : [M:SCO2]MFGFCY(NOL) = [M:SCO1]MFGFCY : Endif
Endif


[M:SCO2]RETQTY(NOL)=VALEUR : Affzo [M:SCO2]RETQTY(NOL)
#----- Maj du prix ? -----# FQ 76145 GA 09/2011 code revu
#Call UPD_MAT_PRI(NOL) From SCOLIB
If [M:SCO2]SCOFLG(NOL)=3 & dim([M:SCO1]CHGTYP)>0
    Local Integer LMAT : LMAT=nolign-1
    Gosub CALC_LINAMT_SCO2 From SCOLIB
Endif

MMODIF = 1

End

########################################
Subprog AM_BOMOFS(VALEUR)
Variable Decimal  VALEUR
Local    Integer NOL : NOL = nolign-1

# Calcul Date mise à dispo du composant
If VALEUR>0 & [M:SCO2]SCOFLG(NOL)=2
  # Date de livraison des matières: obligatoire pour génération de l'encours MSx
    Local Integer WOFS : WOFS=VALEUR
    Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(NOL),WOFS,[M:SCO2]DLVDAT(NOL)) From SCOLIB
Endif
End

########################################
Subprog AS_DLVDAT(VALEUR)
Variable Date    VALEUR
Local    Integer NOL : NOL = nolign-1

# Date du besoin
If [M:SCO2]DLVDAT(NOL)=[0/0/0] & [M:SCO2]SCOFLG(NOL)=2
  # Date de livraison des matières
    # Issue 66836 - 2010-08-30 by CCC : Remplacement de VALEUR par [M:SCO2]BOMOFS(NOL)
    Local Integer WOFS : WOFS=[M:SCO2]BOMOFS(NOL)
    Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(NOL),WOFS,[M:SCO2]DLVDAT(NOL)) From SCOLIB
Endif
End

Subprog C_DLVDAT(VALEUR)
Variable Date    VALEUR
#
# If VALEUR = [0/0/0] : mkstat = 2 : End : Endif
If VALEUR > [M:SCO1]RETDAT
    Call ERREUR(mess(64,193,1)) From GESECRAN
    mkstat=2
    End
Endif

End

########################################
Subprog AS_SCOFLG(VALEUR)
Variable Integer VALEUR
# Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
# Issue 82823 GA 06/2012
# Type =1 "Interne" inutilisable sur nomenclature de sous-traitance
  GMENLOC(1)=1
End

Subprog C_SCOFLG(VALEUR)
Variable Integer VALEUR
Local Char       WFCY   (GLONFCY) : WFCY   =[M:SCO2]STOFCY(nolign-1)
Local Char       WITMREF(GLONITM) : WITMREF=[M:SCO2]CPNITMREF(nolign-1)
#
# Ctrl de la réf d'article saisie
Gosub READ_ITM From ITMLIB
# Issue 85534 GA 11/2012 ctrl ssi article-site trouvé
# Gosub READ_ITF From ITMLIB
# Call CONTMATITM([M:SCO2]CPNITMREF(nolign-1), WFCY, VALEUR, 1) From SCOLIB
#

# Issue X3-45519 - 2017-12-20 by MUARN : pas de changement si alloué
If [M:SCO2]SCOFLG(nolign-1) = 2 & VALEUR = 3 & [M:SCO2]ALLSTA(nolign-1) <> 1
  GMESSAGE = mess(586,194,1)
  mkstat = 2
Endif

End

Subprog AM_SCOFLG(VALEUR)
Variable Integer VALEUR
Local    Integer NOL : NOL = nolign-1
Local Integer    WOK  : WOK  = 2

# FQ 76145 GA 09/2011 test revu
# si on passe de 2:"mise à dispo du sous-traitant" à 3:"fournie par le sous-traitant"
#If find(VALEUR,1,3) & [M:SCO2]SCOFLG(nolign-1)=2 & [M:SCO2]POHNUM(nolign-1)<>""
If find(VALEUR,1,2) & [M:SCO2]SCOFLG(nolign-1)=3 & [M:SCO2]POHNUM(nolign-1)<>""
# maj non autorisée si matière déjà dans la commande
  Read [POQW]POQ0=[M:SCO2]POHNUM(NOL);[M:SCO2]POPLIN(NOL);[M:SCO2]POQSEQ(NOL)
  If fstat Raz [F:POQW] : Endif
  If [F:POQW]POHNUM=[M:SCO2]POHNUM(NOL)
    # Vous devez d'abord annuler la commande:
     GMESSAGE=mess(345,194,1)-[M:SCO2]POHNUM(NOL)-"/"-num$([M:SCO2]POPLIN(NOL))
  Endif
Endif

# Issue 118062 - 2016-08-31 by MUARN : message si commande existe
If [M:SCO1]POHNUM <> ""
  Call MESSAGE(mess(569,194,1)) From GESECRAN
Endif

Call CTRL_SCOFLG( VALEUR, NOL)

End

######################################################################################

Subprog RECH_SCO2_CPNITMREF(LCPNITMREF, LITMREF,LBPRNUM)
Value    Char    LCPNITMREF
Value    Char    LITMREF
Value    Char    LBPRNUM   # FQ 74682 GA 07/2011
Local    Decimal LQTY
Local    Integer NOL : NOL = nolign-1
Local Integer    WOK : WOK  = 2

# ------------------------
# Chargement de [F:ITM]
# ------------------------
If LCPNITMREF<>[F:ITM]ITMREF
   Local Char WITMREF(GLONITM): WITMREF=LCPNITMREF
   Gosub READ_ITM From ITMLIB
   #If fstat : Gosub RETOURITMREF : Endif
Endif

#----- Contrôle si article actif ?               -----#
WOK = func ITMLIB.IS_ACTIVE ( LCPNITMREF )
If WOK=1  Goto RETOURITMREF : Endif

# ------------------------
# Chargement de [F:ITF]
# ------------------------
If [M:SCO2]STOFCY(NOL)=[F:FCY]FCY & [F:FCY]WRHFLG=2
   Local Char WITMREF(GLONITM): WITMREF=LCPNITMREF
   Local Char WFCY(GLONFCY)   : WFCY=[M:SCO2]STOFCY(NOL)
   Gosub READ_ITF From ITMLIB
   #If fstat : Gosub RETOURITMREF : Endif
   #If GOK<1 & GMESSAGE<>"" Call ECR_TRACE(GMESSAGE,1) From GESECRAN Endif # Issue 85534
   If GOK<>1 : GOK=1 : Raz GMESSAGE Endif
Endif

#----- Composants de type Texte: matière exclue par défaut ? -----#
If [M:SCO2]CPNTYP(NOL)>=5 : [M:SCO2]SCOFLG(NOL)=1 : [M:SCO2]MATSTA(NOL)=4 : End : Endif

# Issue 78122 GA 08/2012 toujours tenir compte du SCA indiqué sur la nomenclature de sous-traitance
# FQ 51330 si % perte et PEC activé sur l'article-site
#If [M:SCO2]SCA(NOL) <> 0  & [F:ITF]RELSCATIA<>0
If [M:SCO2]SCA(NOL) <> 0
   [M:SCO2]RELSCATIA(NOL) = 2 # before [F:ITF]RELSCATIA
Else
   [M:SCO2]RELSCATIA(NOL) = 1
Endif
# Issue 83440 GA 11/2012 code déplacé
### Issue 81641 maj site/emplacement des composants
##If [M:SCO2]SCOFLG(NOL)=2
##  #Call UPD_MAT_FCY([M:SCO1]PRHFCY,NOL) From SCOLIB
##  If [M:SCO1]PRHFCY<>[M:SCO2]STOFCY(NOL)             # Issue 85534 selon [M:SCO1]PRHFCY
##     [M:SCO2]STOFCY(NOL)=[M:SCO1]PRHFCY
##  Endif
##  If [M:SCO1]LOC<>"" & [M:SCO1]LOC<>[M:SCO2]LOC(NOL) # Issue 85534 selon [M:SCO1]LOC
##     [M:SCO2]LOC(NOL)=[M:SCO1]LOC
##  Endif
##Endif

If [M:SCO2]DLVDAT(NOL)=[0/0/0]
  # Date de livraison des matières
  Local Integer WOFS : WOFS=[M:SCO2]BOMOFS(NOL)
  Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(NOL),WOFS,[M:SCO2]DLVDAT(NOL)) From SCOLIB
Endif

#---------------------------------------
# Quantités
#---------------------------------------
If dim([M:SCO2]BOMUOM(NOL))>0    # UML actif # FQ 76146 GA 09/2011
   If [M:SCO2]BOMUOM(NOL)="" : [M:SCO2]BOMUOM(NOL) = [F:ITM]STU : Endif
Endif
[M:SCO2]STU(NOL)      = [F:ITM]STU
LQTY = [M:SCO1]EXTQTY
# calcul quantité matière nécessaire pour produire LQTY
Call CALCUL_QTY([M:SCO1]BASQTY,[M:SCO2]STU(NOL),[M:SCO2]LIKQTYCOD(NOL),
&               [M:SCO2]LIKQTY(NOL),[M:SCO2]QTYRND(NOL),[M:SCO2]SCA(NOL),
&               [M:SCO2]RELSCATIA(NOL), [M:SCO2]RETQTY(NOL),LQTY) From SCOLIBM

[M:SCO2]MATSTA(NOL) = 1

# Issue 87038 GA 01/2013 Performances
#Affzo [M:SCO2]MATSTA(NOL)
#Affzo [M:SCO2]RETQTY(NOL)

#----- Maj du prix ? -----#
Call UPD_MAT_PRI(NOL) From SCOLIB

# Issue 83440 GA 11/2012 code déplacé
###----- Contrôles liés à SCOFLG                   -----#
##Call CTRL_SCOFLG([M:SCO2]SCOFLG(NOL),NOL)
##If mkstat=1 : End : Endif

End


######################################################################################

Subprog UPDATE_SCMTEX(LCOD)
Value Char LCOD
Local Integer WRET
Case LCOD
  When "C","M","U" :
    #---------------------------------------------#
    # nouvelle gestion des textes                 #
    #---------------------------------------------#
     If [F:SCM]SCMTEX <> ""
        If left$([F:SCM]SCMTEX,3)="SCM"
           Call CRE_CLOB([F:SCM]SCMTEX,GOK) From TRTX3TEX
        Elsif left$([F:SCM]SCMTEX,3) <> "SCM"
           Call DUP_CLOB("SCM",[F:SCM]SCMTEX,GOK) From TRTX3TEX
        Endif
     Endif
   When "A"
     If [F:SCM]SCMTEX <> "" & left$([F:SCM]SCMTEX,3) = "SCM"
        Call SUP_CLOB([F:SCM]SCMTEX,WRET) From TRTX3TEX
     Endif
Endcase
End

