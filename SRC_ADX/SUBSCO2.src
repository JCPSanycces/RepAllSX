#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
## Traitement de l'onglet <Matières> des Commandes Ss-traitance SUBSCO2 ##
##########################################################################
## selon SUBMFG2                                                        ##
##########################################################################
$ACTION
Case ACTION
 When "AB6_NBLIG"     : Return
 When "AB4_NBLIG"     : Gosub AB4_NBLIG
 When "AB12_NBLIG"    : Gosub MEM_VCR
 When "SUPLIG"        : Gosub SUPLIG
 #When Default        : Infbox "SUBSCO2: action "-ACTION
Endcase
Return

###########################################################################
##
$OUVRE
Global Integer MMODIF
Return

########################################################################
$FERME
Return

########################################################################
$APRES_MODIF
MMODIF=1
Call ITMUPDFLG
Return

###########################################################################
## Action technique de définition du filtre de lecture
$DEFLIG
FICLIG = "SCOMAT" : ABLIG = "SCM"
Return

###########################################################################
$RAZCRE
#----------------------------#
# Initialisation de la ligne #
#----------------------------#
# clé: cf INICRE_LIG à la validation
  [M:SCO2]SCOFLG (nolign-1) = 2   : # Matière fournie au sous-traitant par défaut
#
  [M:SCO2]STOFCY (nolign-1) = [M:SCO1]PRHFCY # used by Datatype ITF on CPNITMREF
  [M:SCO2]LOC    (nolign-1) = [M:SCO1]LOC    #
#
#----- Chargement comptes et sections analytiques -----#
# Call CHARG_SCM_CPTANALIN(nolign-1) From SCOCPTLIB # Issue 91501 GA 08/2013
#-----
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
  Affzo [M:SCO2]STOFCY(nolign-1) : Affzo [M:SCO2]LOC(nolign-1) : Affzo [M:SCO2]SCOFLG(nolign-1)
Return

###########################################################################
$RAZDUP
# appelé par RAZDUP de SUBSCOA
Local Integer NOL
For NOL=0 To [M:SCO2]NBLIG-1
    [M:SCO2]POHNUM(NOL)=""
    [M:SCO2]POPLIN(NOL)=0
    [M:SCO2]POQSEQ(NOL)=0
    [M:SCO2]WIPNUM(NOL)=""
    [M:SCO2]WIPTYP(NOL)=0
    [M:SCO2]WIPSTA(NOL)=0
    [M:SCO2]ALLSTA(NOL)=1 : # Aucune allocation
    [M:SCO2]ALLQTY(NOL)=0
    [M:SCO2]SHTQTY(NOL)=0
    [M:SCO2]USEQTY(NOL)=0
    [M:SCO2]DLVQTY(NOL)=0
    [M:SCO2]INVQTY(NOL)=0
    Raz [M:SCO2]DLVDAT(NOL)
    # Issue X3-38230 - 2017-08-24 by MUARN : gestion des zones modifiables
    Actzo [M:SCO2]CPNITMREF(NOL), MATSTA(NOL), RETQTY(NOL), GROPRI(NOL)
    If  [M:SCO3]NETPRI=0  # Suite Issue 92532 GA 06/2014 user want to keep price ?
        Raz [M:SCO2]NETPRI(NOL),GROPRI(NOL),REFPRI(NOL),PRIREN(NOL),LINAMT(NOL)   # FQ 74536
        Raz [M:SCO2]NETPRIL(NOL),LINAMTL(NOL)             # FQ 74682
    Endif
    Raz [M:SCO2]UPDDAT(NOL),[M:SCO2]UPDUSR(NOL)       # FQ 51325
    Raz [M:SCO2]CREDAT(NOL),[M:SCO2]CREUSR(NOL)       # Maj par WRITE_SCM
    Gosub SCM_MATSTA_DEF From SCOLIB
Next
# Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
Affzo [M:SCO2]1-99 #Affzo [M:SCO2]
Return


###########################################################################
$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
Local Integer NOL : NOL=nolign-1

# Insertion d'une nouvelle ligne: on renseigne toute la clé
  [F:SCM]SCONUM = [M:SCO0]SCONUM
  Call CALC_SCMLIN([M:SCO2]SCMLIN(NOL),nolign)
  Call CALC_SCSLIN([M:SCO2]SCSLIN(NOL))
  [F:SCM]SCMLIN = [M:SCO2]SCMLIN(NOL)
  [F:SCM]SCSLIN = [M:SCO2]SCSLIN(NOL)
  [F:SCM]ITMREF = [M:SCO0]ITMREF
  [F:SCM]BOMALT = [M:SCO0]BOMALT
  [F:SCM]BOMSEQ = [M:SCO2]BOMSEQ(NOL)
  # Issue X3-42750 - 2017-07-07 by MUARN : déjà réalisé
  #Gosub SCM_MATSTA_DEF From SCOLIB
#
# Contrôles communs création/modification
  Gosub COMPLETE_SCM
  # Issue 113031 - 2016-02-12 by MUARN : gestion de l'erreur
  If GOK<1 : Return : Endif
#
  If [F:SCM]CPY = ""
     [F:SCM]CPY = GSOCIETE
  Endif
#
Return

###########################################################################
$INIMOD_LIG
#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
Local Integer NOL : NOL=nolign-1
# Pb de synchro à cause de la clé sur 3 rubriques ?
  If  [M:SCO2]ITMREF(NOL) <> [M:SCO0]ITMREF
      [F:SCM]ITMREF= [M:SCO0]ITMREF
  Endif
  If  [M:SCO2]BOMALT(NOL) <> [M:SCO0]BOMALT
      [F:SCM]BOMALT = [M:SCO0]BOMALT
  Endif
# Clé d'unicité => pas de recalcul ...
####  Call CALC_SCMLIN([M:SCO2]SCMLIN(NOL),nolign)
####  [F:SCM]SCMLIN = [M:SCO2]SCMLIN(NOL)
#
# Contrôles communs création/modification
  Gosub COMPLETE_SCM
#
Return


###########################################################################
# appel en VERIF_CRE et VERIF_MOD sur l'objet SCO
$VERIF
Local Integer I, LRET
Local Char       WFCY   (GLONFCY)
Local Char       WITMREF(GLONITM)
Local Shortint J # Issue 118457 - 2016-09-21 by MUARN : contrôle axes obligatoires

For I=0 To [M:SCO2]NBLIG-1
    #
    Raz GMESSAGE : Raz [F:ITF]
    # Issue 113031 - 2016-02-15 by MUARN : gestion site
    If [M:SCO2]SCOFLG(I) < 3 & [M:SCO2]MATSTA(I)<>4 & [M:SCO2]CPNTYP(I)<>5
      If [M:SCO2]STOFCY(I)="" : [M:SCO2]STOFCY(I) = [M:SCO1]PRHFCY : Endif
      # Issue X3-92985 - 2018-05-30 by MUARN : non, l'emplacement a pu etre supprimé volontairement
      #If [M:SCO2]LOC(I)   ="" : [M:SCO2]LOC(I)    = [M:SCO1]LOC    : Endif
      If [M:SCO2]MFGFCY(I)="" : [M:SCO2]MFGFCY(I) = [M:SCO1]MFGFCY : Endif
    Endif
    # End issue 113031
    # Issue 83440 GA 11/2012 ctrl déplacés
    # Ctrl de la réf d'article saisie
    # Issue 113031 - 2016-02-15 by MUARN : alimentation site
    #WFCY   =[M:SCO2]STOFCY(I)
    If [M:SCO2]STOFCY(I)<>""
      WFCY=[M:SCO2]STOFCY(I)
    Else
      WFCY=[M:SCO3]PRHFCY # FQ 65646 avant [F:SCO]PRHFCY
    Endif
    # End issue 113031
    WITMREF=[M:SCO2]CPNITMREF(I)
    Gosub READ_ITM From ITMLIB
    # Issue 86384 GA 12/2012 sauf matière exclue
    If [M:SCO2]SCOFLG(I)<>3 & [M:SCO2]MATSTA(I)<>4
       Gosub READ_ITF From ITMLIB
       If GOK<>1
         zonsui="[M:SCO1]PRHFCY"
         GERR=1 : mkstat=1 : Break
       Endif
       # Issue 86556 (ctrl déplacé) & Issue 85583 GA 11/2012
       Call CONTSEL("LOC","",[M:SCO2]LOC(I),[M:SCO2]STOFCY(I),mkstat) From CONTOBJ
       If mkstat=1  : Break : Endif

       # Issue 88814 GA 05/2013 Pouvoir rendre LOC obligatoire
       If dim(GEOMLOC)>0 & GEOMLOC=1 & [M:SCO2]LOC(I)=""
         # Livraison pour sous-traitance : L'emplacement doit être renseigné !
         GMESSAGE=mess(1,762,1) - "(LOC)\"+mess(237,192,1)
         mkstat=1  : Break
       Endif
    Endif
    # Issue 113031 - 2016-02-15 by MUARN : contrôle site
    If [M:SCO2]SCOFLG(I) = 3 & [M:SCO2]NETPRI(I)=0
      Call READ_ITM_ITF ([M:SCO2]CPNITMREF(I),WFCY) From ITMLIB
      If GOK<1 : mkstat=1 : Break : Endif
    Endif
    # End issue 113031
    If [F:ITF]STOMGTCOD>0 & [F:ITF]STOMGTCOD<>[M:SCO2]STOMGTCOD(I)
       [M:SCO2]STOMGTCOD(I)=[F:ITF]STOMGTCOD
    Elsif [M:SCO2]STOMGTCOD(I)=0
       [M:SCO2]STOMGTCOD(I)=[F:ITM]STOMGTCOD
    Endif
    # Issue 114967 - 2016-03-15 by MUARN : toujours CONTMATITM
    # Issue 107513/US10 by GA
    #If func AFNC.ACTIV("ECC")
    #  Call CONTMATITMECC([M:SCO2]CPNITMREF(I), [M:SCO2]STOFCY(I), [M:SCO2]SCOFLG(I), "SCO2",  LRET, [M:SCO2]ECCERRMSG(nolign-1)) From SCOLIB
    #  [M:SCO2]ECCERRCOD(nolign-1)=LRET
    #Else
    #  Call CONTMATITM([M:SCO2]CPNITMREF(I), [M:SCO2]STOFCY(I), [M:SCO2]SCOFLG(I), 1) From SCOLIB
    #Endif
    # Issue 118841 - 2016-10-04 by MUARN : ECC code ectivité
    # Issue X3-42750 - 2017-07-07 by MUARN : ne pas faire sur les matière exclues
    If [M:SCO2]MATSTA(I)<>4
      If func AFNC.ACTIV("ECC")
        Call CONTMATITM([M:SCO2]CPNITMREF(I), [M:SCO2]STOFCY(I), [M:SCO2]SCOFLG(I), "SCO2",  LRET, [M:SCO2]ECCERRMSG(nolign-1)) From SCOLIB
      Else
        Call CONTMATITM([M:SCO2]CPNITMREF(I), [M:SCO2]STOFCY(I), [M:SCO2]SCOFLG(I), "SCO2",  LRET, GMESSAGE) From SCOLIB
      Endif
    Endif
    # Issue 114967 - 2016-03-15 by MUARN : gestion erreur
    If LRET = 4 : GERR = 1 : Break : Endif

    Call CTRL_SCOFLG([M:SCO2]SCOFLG(I), I )
    If mkstat=1 : Break : Endif

    # Issue X3_39028 - 2017-06-06 by MUARN : non déjà fait, sinon on perd les raz manuels
    #----- Chargement sections analytiques -----#
    # Issue 91501 GA 08/2013
    #Local Char WVAL(GLONCCE)
    #If dim(ICCE)<1  Local Integer ICCE : Endif
    #For ICCE=1 To GNBDIE
    #    If evalue("[M:SCO2]CCE"+num$(ICCE)+"(I)")=""   # Issue 91857 & 91501 GA 08/2013
    #       Raz WVAL
    #       Call INIT_CCE(WVAL,ICCE,"SCM","",0) From TRTX3CPT
    #       Assign "[M:SCO2]CCE"+num$(ICCE)+"(I)" With WVAL
    #    Endif
    #Next

    # Issue 118457 - 2016-09-21 by MUARN : contrôle axes obligatoires
    nolign = I+1
    # Issue X3-54486 - 2018-03-07 by MUARN : faire un Raz de GMESSAGE sinon une exploitation erronée
    Raz GMESSAGE
    For J = 1 To GNBDIE
      # Issue X3-66820 - 2017-12-20 by MUARN : uniquement si saisisable
      If evalue("varmode([M:SCO2]CCE" + num$(J) + ")") = 0
        Local Char WVAL(GLONCCE)
        WVAL = evalue("[M:SCO2]CCE"+num$(J)+"("+num$(I) +")")
        Call SAIS_CCE(WVAL,J,"","") From TRTX3CPT
        If !mkstat
          Call CTRL_CCE(WVAL,J,"",GFINRSP,[M:SCO1]RETDAT) From TRTX3CPT
          If GMESSAGE <> ""
            GERR = 1
            GMESSAGE -= mess(18,197,1) - num$(I+1)
            OK = 0
            Break 2
          Endif
        Endif
        Raz mkstat
      Endif
    Next

    #I+=1  # Issue 83440 GA 11/2012 on ne controlait qu'une ligne sur 2 ?????
Next
If mkstat=1 & zonsui="" : zonsui="[M:SCO0]BOMALT" : GERR=1 : Endif
Return


###########################################################################
$COMPLETE_SCM
#Local Integer NOL : NOL=nolign-1
# cas des matières ajoutées, le CPNTYP n'est pas renseigné
  If [F:SCM]CPNTYP < 1
     [F:SCM]CPNTYP=1
     #[M:SCO2]CPNTYP(NOL) = [F:SCM]CPNTYP
  Endif

# Matières mises à dispo du sous-traitant
  If [F:SCM]SCOFLG < 3 & [F:SCM]MATSTA<>4 & [F:SCM]CPNTYP<>5
     If [F:SCM]STOFCY="" : [F:SCM]STOFCY = [M:SCO1]PRHFCY : Endif # Issue 85534 avant [M:SCO0]POHFCY
     # Issue X3-92985 - 2018-05-30 by MUARN : non, l'emplacement a pu etre supprimé volontairement
     #If [F:SCM]LOC   ="" : [F:SCM]LOC    = [M:SCO1]LOC    : Endif
     If [F:SCM]MFGFCY="" : [F:SCM]MFGFCY = [M:SCO1]MFGFCY : Endif

  Else
  # pas d'encours MSx si Matière fournie par le sous-traitant
    If [F:SCM]WIPNUM<>""
       Call UPDATE_MSX("A", 0) From SCOLIB
    Endif
 # FQ 76145 GA 09/2011 le Raz sans repréciser [F:SCM] vidait les zones écran en tableau (GROPRI,PRIREN,...)
  # pas de livraison si Matière fournie par le sous-traitant
    Raz [F:SCM]MFGFCY,[F:SCM]LOC,[F:SCM]DLVDAT,[F:SCM]BOMOFS
  # pas de site de stockage, pas d'adresse sous-traitant
    Raz [F:SCM]STOFCY
  Endif

# Date de livraison des matières: obligatoire pour génération de l'encours MSx
  If [F:SCM]SCOFLG=2
     Local Integer WOFS : WOFS=[F:SCM]BOMOFS
     Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[F:SCM]STOFCY,WOFS,[F:SCM]DLVDAT) From SCOLIB
  Endif

# Priorité
  If [F:SCM]PIO = 0
     [F:SCM]PIO = [M:SCO1]PIO
  Endif

 # FQ 76145 GA 09/2011 le Raz sans repréciser [F:SCM] vidait les zones écran en tableau (GROPRI,PRIREN,...)
  #----- Maj du prix ? -----# FQ 73561 GA 05/2011 avant fait dans LIENS
  If [F:SCM]SCOFLG<>3
     Raz [F:SCM]NETPRI,[F:SCM]GROPRI,[F:SCM]PRIREN,[F:SCM]LINAMT
     If dim([F:SCM]LINAMTL)>0 : Raz [F:SCM]NETPRIL,[F:SCM]LINAMTL : Endif : # Issue 121512 GH 15/02/2017 - Wrong test of dim
  Elsif [F:SCM]NETPRI=0
     Call UPD_MAT_PRI(-1) From SCOLIB
     # Issue 113031 - 2016-02-12 by MUARN : gestion de l'erreur
     If GOK<1 : Return : Endif
     Gosub CALC_LINAMT_SCM  From SCOLIB
  Else
     Gosub CALC_LINAMT_SCM  From SCOLIB
  Endif

#----- Chargement comptes et sections analytiques -----#
  #Call CHARG_SCM_CPTANALIN(nolign-1) From SCOCPTLIB # Issue 91501 GA 08/2013 Ko écrase les valeurs saisies
Return

###########################################################################
## Lecture des lignes
#########################################################################
$LIENS
Local Integer IMAT : IMAT=0
Local Integer L

# ----
# déjà fait dans SUBSCOA/LIENS:
# ne pas refaire ici sinon on perd les FMTDIE et FMTCOA
# Raz [M:SCO2]
# ----
For [SCM]SCM0 Where SCONUM=[M:SCO0]SCONUM
  # le transclasse a besoin de connaitre nolign
    nolign = IMAT + 1
    [M:SCO2] = [F:SCM]
    If [M:SCO2]SCOFLG(IMAT) = 0 : [M:SCO2]SCOFLG(IMAT) = 2 : Endif

    # Issue 106083 - 2016-04-07 by MUARN : ne pas faire
    # Ctrl présence d'une ligne POF
    #Call FIND_POF(IMAT) From SUBSCO2
    # Issue X3-38230 - 2017-08-24 by MUARN : gestion des zones modifiables ou non si EO commandé
    If [M:SCO2]POHNUM(IMAT)=""
      Actzo [M:SCO2]CPNITMREF(IMAT), MATSTA(IMAT), RETQTY(IMAT), GROPRI(IMAT)
    Else
      Diszo [M:SCO2]CPNITMREF(IMAT), MATSTA(IMAT), RETQTY(IMAT), GROPRI(IMAT)
    Endif

    If dim([M:SCO2]BOMUOM(IMAT))>0
      If [M:SCO2]BOMUOM(IMAT)=""
         [M:SCO2]BOMUOM(IMAT)=[F:SCM]STU
         [M:SCO2]BOMSTUCOE(IMAT)=1
         [M:SCO2]BOMQTY(IMAT)=[F:SCM]LIKQTY
      Endif
    Endif

  # Issue 87038 GA 01/2013 Performances: ne pas refaire si on vient de valider la saisie
  # Affichage stock dispo
    If [M:SCO2]STOMGTCOD(IMAT)=2 & [M:SCO2]AVAQTY(IMAT)=0
       Call CTRL_SCOFLG( [M:SCO2]SCOFLG(IMAT), IMAT)
    Endif

  #----- Chargement comptes et sections analytiques -----#
    Call CHARG_SCM_CPTANALIN(IMAT) From SCOCPTLIB

    IMAT+=1
Next
[M:SCO2]NBLIG =IMAT
# Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
Affzo [M:SCO2]1-99

# qté productible selon SHTQTY
If dim(GAVASCO) <= 0 : Global Decimal GAVASCO : Endif
GAVASCO = 9999999999
Call MAJ_AVASCOQTY("SCO2") From SCOLIBM

Call CTRECCCPN(-1) From SCOECCLIB      # Control each line of component and highlight them if necessary

Return

###########################################################################
## Modification des lignes
#########################################################################
$MODIF
Local Integer I
Local Integer J : J=0
Local Char    WIPMEM(GLONVCR)(max(func AFNC.ACTIVDOS(GDOSSIER,"PSM"),100))  # Issue 82466 avant WIPMEM(15)(100)
Local Integer WRETOUR,K
Local Integer L         : # pour sections analytiques
Local Integer WEXISTE
Local Char    WMESS(250) : WMESS="" # Issue 90321 GA 07/2013
#
Gosub DEFLIG
For I=0 To [M:SCO2]NBLIG-1
#
   Readlock [SCM]SCM0=[M:SCO0]SCONUM;[M:SCO1]SCILIN;[M:SCO2]SCMLIN(I)
   If fstat=1 : GOK=-1 : GLOCK="$SCOMAT"-num$(I) : Break : Endif
   WEXISTE = fstat
#
   If [M:SCO2]MATSTA(I) < 3 & [M:SCO2]ALLSTA(I) > 3 & [M:SCO2]RETQTY(I)<>[F:SCM]RETQTY
       # Issue 90321 GA 07/2013
       # "Cette action peut remettre en cause des allocations matières existantes.\Procéder à une vérification manuelle."
       #Call MESSAGE(mess(229,190,1)+"("+[F:SCM]ITMREF+")") From GESECRAN
       If WMESS=""
          WMESS=mess(229,190,1)+"("+[F:SCM]CPNITMREF
       Elsif len(WMESS)>230
          If !pat(WMESS, ", ...") WMESS+=", ..." Endif
       Else
          WMESS+=","+[F:SCM]CPNITMREF
       Endif
   Endif
#
   nolign = I + 1
   [F:SCM] = [M:SCO1] : [F:SCM] = [M:SCO2]

   If dim([M:SCO2]BOMUOM(I))<0    # UML inactif
        [F:SCM]BOMUOM =[M:SCO2]STU(I)
        [F:SCM]BOMSTUCOE=1
        [F:SCM]BOMQTY=[M:SCO2]LIKQTY(I)
   Endif

#
   If    WEXISTE=0
      # Maj d'une ligne
        Gosub INIMOD_LIG
#
      #  Texte
        Call UPDATE_SCMTEX("U")
#
      # Mise à jour de l'encours matières
        Call UPDATE_MSX("U", [M:SCO0]MODALL) From SCOLIB
#
      #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCM_CPTANALIN ("M",nolign-1) From SCOCPTLIB
        If GOK<1 : Break : Endif
#
        Gosub REWRITE_SCM From SCOLIB
        If GOK<1 : Break : Endif
#
      # On enregistre les n° d'encours à mettre à jour
        WIPMEM(J) = [F:SCM]WIPNUM
        J+=1
#
   Elsif WEXISTE = 5
      # Insertion d'une nouvelle ligne
        Gosub INICRE_LIG
#
      #  Texte
        Call UPDATE_SCMTEX("C")
#
      # Mise à jour de l'encours matières
        Call UPDATE_MSX("C", [M:SCO0]MODALL) From SCOLIB
#
      #----- Ecriture des comptes et sections de la ligne de document -----#
        Call UPDATE_SCM_CPTANALIN ("C",nolign) From SCOCPTLIB
        If GOK<1 : Break : Endif
#
        Gosub WRITE_SCM From SCOLIB
        If GOK<1 : Break : Endif
#
      # On enregistre les n° d'encours à mettre à jour
        WIPMEM(J) = [F:SCM]WIPNUM
        J+=1
#
   Endif
Next I

# Purge des matières supprimées
 For [SCM]SCM0 Where SCONUM=[M:SCO0]SCONUM With Lock
    I = find([F:SCM]SCMLIN,[M:SCO2]SCMLIN(0..[M:SCO2]NBLIG-1))
    If  I = 0
      # Texte
        Call UPDATE_SCMTEX("A")
      #
        Gosub DELETE_SCM From SCOLIB
        #If GOK<1 : Break : Endif
     Else
        Gosub REWRITE_SCM From SCOLIB
        #If GOK<1 : Break : Endif
     Endif
 Next

# type des ordres ... avant VCRTYP=10(OF) et WIPTYP=6
 For [ORD]ORD3 Where WIPTYP = 3 & VCRTYP = 36 & ORIFCY = [M:SCO0]POHFCY
&                  & VCRNUM = [M:SCO0]SCONUM  & VCRLIN = [M:SCO1]SCILIN
    If !find([F:ORD]WIPNUM,[M:SCO2]WIPNUM(0..[M:SCO2]NBLIG-1)) &
&      !find([F:ORD]WIPNUM,WIPMEM(0..dim(WIPMEM)-1))
       # suppression encours
       [M:ORDK]MAJCOD     = "A"
       [M:ORDK]WIPTYP     = 3
       [M:ORDK]WIPNUM     = [F:ORD]WIPNUM
       [M:ORDK]ITMREF     = [F:ORD]ITMREF
       Call WIP From TRTWIP
    Endif
Next

# Issue 90321 GA 07/2013
If WMESS<>""
  WMESS+=")"
 # "Cette action peut remettre en cause des allocations matières existantes.\Procéder à une vérification manuelle."
  Call MESSAGE(WMESS) From GESECRAN
Endif
Return

$CREATION
Local Integer I
Local Integer WRETOUR,K
Local Integer L         : # pour sections analytiques
#

Raz [F:SCM]
For I=0 To [M:SCO2]NBLIG-1
# le transclasse a besoin de connaitre nolign
    nolign = I + 1
    [F:SCM] = [M:SCO0] : [F:SCM] = [M:SCO1] : [F:SCM] = [M:SCO2]
#
    If dim([M:SCO2]BOMUOM(I))<0    # UML inactif
        [F:SCM]BOMUOM =[M:SCO2]STU(I)
        [F:SCM]BOMSTUCOE=1
        [F:SCM]BOMQTY=[M:SCO2]LIKQTY(I)
    Endif
#
#
  # on s'assure que la Cle soit entièrement renseignée
    Gosub INICRE_LIG
    # Issue 113031 - 2016-02-12 by MUARN : gestion de l'erreur
    If GOK<1 : Break : Endif
#
  # Texte
    Call UPDATE_SCMTEX("C")
#
  # Mise à jour de l'encours matières
    Call UPDATE_MSX("C", [M:SCO0]MODALL) From SCOLIB
    If GOK<1 : Break : Endif   # Issue 88058 GA 02/2013
#
  #----- Ecriture des comptes et sections de la ligne de document -----#
    Call UPDATE_SCM_CPTANALIN ("M",nolign-1) From SCOCPTLIB
    If GOK<1 : Break : Endif
#
    Gosub WRITE_SCM From SCOLIB
    If GOK<1 : Break : Endif
#
Next I
If GOK<1 : Return : Endif   # Issue 88058 GA 02/2013
Return

###########################################################################
## Annulation de toutes les lignes
#########################################################################
$ANNULE
Local Integer WRET
For [SCM]SCM0 Where SCONUM=[M:SCO0]SCONUM With Lock
# Texte
  Call UPDATE_SCMTEX("A")
#
# Mise à jour de l'encours matières
  Call UPDATE_MSX("A", [M:SCO0]MODALL) From SCOLIB
#
#----- Ecriture des comptes et sections de la ligne de document -----#
# ne pas planter en cas d'erreur
  Call UPDATE_SCM_CPTANALIN ("A",nolign-1) From SCOCPTLIB
#
  Gosub DELETE_SCM From SCOLIB
  If GOK < 1 : Break : Endif
Next
Return

$SUPLIG
#-----------------------------------------------------------#
# Avant Delete ou Rewrite de la ligne                       #
#-----------------------------------------------------------#
# not used ????
Return

#------------------------------------------------------------------------#
# Pour forcer le flag update des lignes articles lancés  extrait SUBMFGB #
#------------------------------------------------------------------------#
Subprog ITMUPDFLG
Local Integer I
#
If find(GREP,"C","D") : End : Endif
#
#For  I=0 To [M:SCO1]NBLIG-1
#    [M:SCO1]UPDFLG(I)=1
#Next I
[M:SCO1]UPDFLG = 1
#
End

###########################################################################
# (re)Calcul n° ligne matière
Subprog CALC_SCMLIN(LSCMLIN, NOL)
Variable Decimal  LSCMLIN
Variable Shortint NOL
# initialisation selon le paramètre BOMSTE
# If !GIMPORT  : # pb car GIMPORT=1 (bug ailleurs)
 If LSCMLIN=0
    If NOL > 1
        LSCMLIN = [M:SCO2]SCMLIN(NOL-2) + GBOMSTE
    Else
        LSCMLIN = GBOMSTE
    Endif
 Endif
End

###########################################################################
# (re)Calcul n° ligne service
Subprog CALC_SCSLIN(VALEUR)
Variable Decimal  VALEUR
# un seul service dans un premier temps ...
 If !GIMPORT
    VALEUR = [M:SCO3]SCSLIN
 Endif
End

###########################################################################
Subprog C_NBLIG
Local Integer NOL
#
End

########################################
Subprog IB_NBLIG
Local Integer I, NBITM
Local Integer NOL : NOL=nolign-1
GBOUT2 = ""                : # Détail matière                (action SCMFICH)
GBOUT3 = ""                : # Exclure/réactiver une matière STD => B3_NBLIG
GBOUT4 = ""                : # Données gestion stock         (action VISUITF)
GBOUT5 = ""                : # Allocation automatique        STD => B5_NBLIG
GBOUT6 = ""                : # Allocation manuelle           (action SAISTOALL)
GBOUT7 = ""                : # Voir allocation               (action CONSALL)
GBOUT8  = ""               : # Stock projeté                 (action CONSSPR)
GBOUT9  = ""               : # Situation matière             (action SCMTRKSTA)
GBOUT10 = ""               : # Coût matière                  (action SCMTRKPRI)
GBOUT11 = ""               : # Texte
GBOUT12 = ""               : # affectation                   (action FMLKB)

# pas de matières
If dim([M:SCO2]CPNITMREF) < NOL : mkstat = 2 : End : Endif

# boutons
If [M:SCO2]CPNITMREF(NOL) <> ""

    # fenêtre détail Matière
    GBOUT2 = mess(84,195,1)

    If dim(GDEFEORTYP)>0 & !find(GDEFEORTYP,2,4)
       Raz GBOUT3                : # Pas de maj des matières
    # si matière exclue: réactivation
    Elsif [M:SCO2]MATSTA(NOL) = 4
        GBOUT3 = mess(185,198,1) : # Réactiver
    Else
        Case [M:SCO2]ALLSTA(NOL)
            When 1 : If [M:SCO2]MATSTA(NOL) < 2 # Issue 97153 GA 02/2014 before = 1
                        GBOUT3 = mess(182,198,1)    :  # Exclure
                     Endif
                     GBOUT7 = ""
            When Default:    GBOUT7 = mess(426,198,1) :  # voir allocation
        Endcase
    Endif

    # Allocation automatique
    GBOUT5 = mess(914,196,1)

    # Allocation manuelle
    GBOUT6 = mess(915,196,1)

    # fenêtre Situation Matière
    GBOUT9  = mess(349,194,1)

    # fenêtre Coût Matière
    GBOUT10 = mess(56,197,1)

    # texte
    GBOUT11 =  mess(38,198,1)

    # si consultation, pas d'exclusion, pas d'allocation
    If GCONSLCT = 1
        GBOUT3 = ""
        GBOUT5 = ""
        GBOUT6 = ""
    Endif

    # si création/modif pas d'allocation
    If GREP <> ""
        GBOUT5 = ""
        GBOUT6 = ""
    Endif

    # statut non ferme, pas d'allocation
    If [M:SCO1]SCOSTA <> 1
        GBOUT5 = ""
        GBOUT6 = ""
        GBOUT7 = ""
    Endif

    # si matière soldée, pas d'exclusion
    If [M:SCO2]MATSTA(NOL) = 3
        GBOUT3 = ""
    Endif

    # pas d'allocation:
    # - si matière non fournie au sous-traitant
    # - si matière soldée ou exclue
    # - si composant Texte ou Valorisation
    If  [M:SCO2]SCOFLG(NOL)<>2 | find([M:SCO2]MATSTA(NOL),3,4) | [M:SCO2]CPNTYP(NOL)>=5
        GBOUT5 = ""
        GBOUT6 = ""
        GBOUT7 = ""
    Endif

    # pas de visu stock projeté:
    # - si non géré en stock
    # - si matière fournie par le sous-traitant
    If [M:SCO2]STOMGTCOD(NOL)<>2 | [M:SCO2]SCOFLG(NOL)<>2
        GBOUT4 = ""
        GBOUT8 = ""
    Else
       # Données de gestion stock
        GBOUT4 = mess(456,198,1)
       # stock projeté
        GBOUT8 = mess(157,198,1)
    Endif

    # si SCO à l'étude, pas d'allocation ni d'exclusion
    If [M:SCO1]SCOTRKFLG = 2
        GBOUT3 = ""
    Endif

    # si allocation détail, on ne propose pas allocation globale
    If [M:SCO2]ALLSTA(NOL) > 3 : GBOUT5 = "" : Endif

    # si allocation globale sans rupture, pas d'allocation globale
    If [M:SCO2]ALLSTA(NOL) = 3 : GBOUT5 = "" : Endif
    # Ctrl autorisation bouton allocation manuelle
    If !find (GREP, "C", "D") & GBOUT6 <> ""
        GBIDC2="A": GFCY=[M:SCO2]STOFCY(NOL) : Gosub AUTORIS_OPT From CONTX3
        If !GBIDI2 : Raz GBOUT6  : Endif
    Endif
    If [M:SCO1]SCOSTA = 1 & find([M:SCO2]SCOFLG(NOL),1,2) & [M:SCO2]MATSTA(NOL) < 3 : GBOUT12 = mess(467,198,1) : Endif
Else
    # si consultation, pas d'ajout de matière non prévue
    If GCONSLCT = 1 | (dim(GDEFEORTYP)>0 & !find(GDEFEORTYP,2,4))
        GBOUT2 = ""
    Elsif [M:SCO1]SCOTRKFLG>4 | [M:SCO1]SCOSTA=4  # Issue 100710 GA 06/2014 no new component if EO closed
        GBOUT2 = ""
    Else
        GBOUT2 = mess(180,198,1)    # ajout matière non prévue # FQ 70171 GA 01/2011
    Endif

    # RAZ boutons allocation
    GBOUT5 = ""
    GBOUT6 = ""
    GBOUT7 = ""
Endif

If !func ECCLIB.ERRCOD("SCO2",nolign-1)
    Raz GBOUT13     # Information
Endif

# Issue 110904/114860 - 2016-04-12 by JUSYN : If the released product is BOM versioned then it's not allowed to add unexpected materials.
# GBOUT2 is empty except for the case if it is allowed to add unexpected materials
If dim([M:SCO0]ECCVALMAJ)>0
    If func ECCLIB.NBRCPN([M:SCO0]ITMREF) > 0
        Raz GBOUT2
    Endif
Endif
End

########################################
Subprog B1_NBLIG
#
End

########################################
# Activation/exclusion d'une matière
########################################
Subprog B3_NBLIG
Local    Integer I
Local    Integer NOL : NOL = nolign-1

# l'exclusion d'une matière est gérée par la mise à 0 de la quantité besoin
# pour l'instant on laisse la ligne affichée ...
# la réactivation implique le recalcul du besoin à partir des données initiales
If [M:SCO2]MATSTA(NOL) = 4

  # calcul quantité matière nécessaire pour produire [M:SCO1]EXTQTY
    Call CALCUL_QTY([M:SCO1]BASQTY,[M:SCO2]STU(NOL),[M:SCO2]LIKQTYCOD(NOL),
&                   [M:SCO2]LIKQTY(NOL),[M:SCO2]QTYRND(NOL),[M:SCO2]SCA(NOL),
&                   [M:SCO2]RELSCATIA(NOL), [M:SCO2]RETQTY(NOL),[M:SCO1]EXTQTY) From SCOLIBM
#
    Filter [BOD] Where ITMREF=[M:SCO0]ITMREF
&                  and BOMALT=[M:SCO0]BOMALT            and BOMALTTYP=3
&                  and CPNITMREF=[M:SCO2]CPNITMREF(NOL) and CPNTYP<6
&                  and (BOMENDDAT = [0/0/0] | BOMENDDAT >= [M:SCO1]ORDDAT )
&                  and (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= [M:SCO1]ORDDAT )
    Read   [BOD] First
    If fstat : Raz [F:BOD] : Endif
    Filter [BOD]
#
    [M:SCO2]SCOFLG(NOL) = [F:BOD]SCOFLG
    [M:SCO2]BOMOFS(NOL) = [F:BOD]BOMOFS
   # Date de livraison des matières: obligatoire pour génération de l'encours MSx
    If [M:SCO2]SCOFLG(NOL)=2
       Local Integer WOFS : WOFS=[F:BOD]BOMOFS
       Call UPD_MAT_DAT([M:SCO3]OPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(NOL),WOFS,[M:SCO2]DLVDAT(NOL)) From SCOLIB
    Endif

    # Issue 86384 GA 12/2012
    If [M:SCO2]SCOFLG(NOL) < 3 & [M:SCO2]CPNTYP(NOL)=1
       [M:SCO2]STOFCY(NOL)=[M:SCO1]PRHFCY
       Call READ_ITM_ITF ([M:SCO2]CPNITMREF(NOL),[M:SCO2]STOFCY(NOL)) From ITMLIB
       If GOK<1 : End : Endif # Issue 83440 GA 11/2012

       If [M:SCO2]SCA(NOL) <> 0  & [F:ITF]RELSCATIA<>0
          [M:SCO2]RELSCATIA(NOL) = [F:ITF]RELSCATIA
       Endif

       [M:SCO2]LOC(NOL)    = [M:SCO1]LOC     # emplacement sous-traitance
       [M:SCO2]MFGFCY(NOL) = [M:SCO1]MFGFCY
       [M:SCO2]STOMGTCOD(NOL) = func ITMLIB.GET_STOMGTCOD([M:SCO2]CPNITMREF(NOL),[M:SCO2]STOFCY(NOL))
       # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
       #If [M:SCO2]STOMGTCOD(NOL)<2 [M:SCO2]SCOFLG(NOL)=1 Endif
    Endif
#
    [M:SCO2]MATSTA(NOL) = 1
    # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
    #Affzo [M:SCO2]
    Affzo [M:SCO2]RETQTY(NOL),MATSTA(NOL),BOMOFS(NOL),SCOFLG(NOL),DLVDAT(NOL)
Else
# cas matière non prévue
    If [M:SCO2]BOMSEQ(NOL) = 0
        # suppression de la ligne
        Dela NOL,1 [M:SCO2]NBLIG
        # mise à jour NBLIG et réaffichage
        [M:SCO2]NBLIG     -= 1
        # Issue 100710 GA 06/2014 Affzo nécessaire ici sinon on ne voit pas le Dela
        # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
        # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
        Affzo [M:SCO2]1-99
    Else
        Raz [M:SCO2]DLVDAT(NOL)
        [M:SCO2]RETQTY(NOL) = 0
        [M:SCO2]MATSTA(NOL) = 4
        # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
        #[M:SCO2]SCOFLG(NOL) = 1    : # matière interne
        [M:SCO2]BOMOFS(NOL) = 0    : # pas de délai
      # pas de site de stockage, pas d'adresse sous-traitant
        Raz [M:SCO2]MFGFCY(NOL) : Raz [M:SCO2]STOFCY(NOL) : Raz [M:SCO2]LOC(NOL)
        [M:SCO2]STOMGTCOD(NOL) = 1
        # Issue 91501 GA 08/2013 bannir les Affzo généraux car cela initialise et valide le masque
        #Affzo [M:SCO2]
        Affzo [M:SCO2]RETQTY(NOL),MATSTA(NOL),BOMOFS(NOL),SCOFLG(NOL),DLVDAT(NOL)
    Endif
Endif
# pour réinitialiser texte bouton
mkstat=4
End

$AB4_NBLIG
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
  # Article-Site
  WOBJET="ITF"
  WCLE1 =[M:SCO2]STOFCY(nolign-1)
  WCLE2 =[M:SCO2]CPNITMREF(nolign-1)
Return


