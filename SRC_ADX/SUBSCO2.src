$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SCM","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
If VALEUR="" Gosub D_CCEX Endif # Issue 91501 GA 07/2013
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SCO1]RETDAT) From TRTX3CPT
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:SCO2]CPNITMREF(nolign-1)
Endif
Return

######################################################################################
# Issue 107513/US2/US10 by GA 06/2015
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Char LMSG(250)

# Issue 110904 - 2016-04-13 by JUSYN : Correct input data
# Initialise fields
[M:SCO2]ECCERRCOD(nolign-1) = 0
[M:SCO2]ECCERRMSG(nolign-1) = ""

Call CTRECC([M:SCO2]CPNITMREF(nolign-1),"SCO2","ECCVALMAJ",VALEUR,[M:SCO2]ECCVALMIN(nolign-1),
&           [M:SCO2]DLVDAT,LRET,LMSG) From ECCLIB
# Issue 111417 - 2015-09-30 by CCC : don't change errcod if managed with minor version, wait for control on ECCVALMIN
If func ECCLIB.NBRCPN([M:SCO2]CPNITMREF(nolign-1))=1
    [M:SCO2]ECCERRCOD(nolign-1) = LRET
    [M:SCO2]ECCERRMSG(nolign-1) = LMSG
Endif

# Issue 110904 - 2016-04-13 by JUSYN : Display message
If find([M:SCO2]ECCERRCOD(nolign-1),1,4)
    GMESSAGE=LMSG
    mkstat=2
Endif

End

######################################################################################
# Issue 107513/US2/US10 by GA 06/2015
Subprog C_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

# Issue 110904 - 2016-04-13 by JUSYN : Correct input data
Call CTRECC([M:SCO2]CPNITMREF(nolign-1),"SCO2","ECCVALMIN",[M:SCO2]ECCVALMAJ(nolign-1),VALEUR,
&           [M:SCO2]DLVDAT,LRET,[M:SCO2]ECCERRMSG(nolign-1)) From ECCLIB

[M:SCO2]ECCERRCOD(nolign-1) = LRET

# Issue 110904 - 2016-04-13 by JUSYN : Display message
If find(LRET,1,4)
    GMESSAGE=[M:SCO2]ECCERRMSG(nolign-1)
    mkstat=2
    GERR = 1
Endif


End


