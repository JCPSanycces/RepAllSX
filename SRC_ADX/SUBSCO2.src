Subprog AS_BOMUOM(VALEUR)
Variable Char    VALEUR()
Local Integer    TYP
If clalev ([F:TUN])=0  Local File TABUNIT  [TUN] Endif

If VALEUR = "" : VALEUR = [M:SCO2]STU(nolign-1) : Endif
TYP=0
Read [TUN]TUN0=[M]STU
If !fstat
    TYP = [F:TUN]UOMTYP
Endif

If !find(TYP,3,4)
    VALEUR =[M:SCO2]STU(nolign-1)
    [M:SCO2]BOMSTUCOE(nolign-1)=1
    [M:SCO2]BOMQTY   (nolign-1)=[M:SCO2]LIKQTY(nolign-1)
    mkstat=2
Endif

End

