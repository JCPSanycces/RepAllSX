#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Raz code accés dans état AMSK
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update CODACC on report AMSK") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJREP
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJREP
End

#-------------------#
$MAJREP

Local File =DOSSIER+".AREPORT" [ARP]

# Mise à jour de la table AREPORT
Trbegin [ARP]
 Read [ARP]ARP0="AMSK"
 If !fstat & [F:ARP]ACS="MBT"
  Call ECR_TRACE(mess(81,125,1)-"AREPORT :"-time$,0) From GESECRAN
  [F:ARP]ACS = ""
  Rewrite [ARP] 
 Endif
Commit

Close Local File [ARP]

Return
