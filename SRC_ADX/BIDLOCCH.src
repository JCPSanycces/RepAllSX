# < DEBUG> #################################################################################### #
End
# </DEBUG> #################################################################################### #




#** #####################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #####################################################################################

$ACTION
    Case ACTION
        When "OUVRE"    : Gosub OUVRE                 # Basic initialization.
        When "AV_CHOIX" : Gosub AV_CHOIX              # Initialize the fields by reading the parent screen.
        When "OK"       : VALEUR = "OK" : Gosub OK    # Write back the entered information.
        When Default    : Gosub ACTION From BIDLOCDE
    Endcase
Return



#** #####################################################################################
#*
#* Sub chunk:  OUVRE
#*
#* Purpose:    Handler before opening a window.
#*             Opens some needed tables and initializes some variables for further use.
#*
#*! #####################################################################################

$OUVRE
    Gosub OUVRE From BIDLOCDE
    [L]LENBANCOD = 5                                  # Reset size of bank sort code.
    [L]LENBANACC = 12                                 # Reset size of bank account number.
Return



#** #####################################################################################
#*
#* Sub chunk:  AV_CHOIX
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the local BID screen.
#*
#*! #####################################################################################

$AV_CHOIX
    Gosub AV_CHOIX From BIDLOCDE

    # We only copy BVRNUM field if it exists for KSW activity code could be deactivated.
    If dim([M]BVRNUM) > 0
        # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
        # there are differend field names and sometimes indexed fields (table view):
        If ( PARENTSCREEN = "BAN1" ) and ( dim([M:BAN2]BVRNUM) > 0 )
            # GESBAN function:
            [M]BVRNUM = [M:BAN2]BVRNUM
        Elsif evalue( "dim([M:" + PARENTSCRABR + "]BVRNUM)" ) > 0
            # BIDxxx screens (GESBPR, GESBPC, ... function):
            [M]BVRNUM = evalue( "[M:" + PARENTSCRABR + "]BVRNUM(" + TABINDEX + ")" )
        Endif
        Affzo 1-99
    Endif
Return



#** #####################################################################################
#*
#* Sub chunk:  OK
#*
#* Purpose:    Handler for the OK button. Insert the data in the parent screen.
#*
#*! #####################################################################################

$OK
    # We only copy BVRNUM field if it exists for KSW activity code could be deactivated.
    If dim([M]BVRNUM) > 0
        # Case distinction between BAN1 screen (GESBAN function) and the BIDxxx screens for
        # there are differend field names and sometimes indexed fields (table view):
        If ( PARENTSCREEN = "BAN1" ) and ( dim([M:BAN2]BVRNUM) > 0 )
            # GESBAN function:
            [M:BAN2]BVRNUM = [M]BVRNUM
        Elsif evalue( "dim([M:" + PARENTSCRABR + "]BVRNUM)" ) > 0
            # BIDxxx screens (GESBPR, GESBPC, ... function):
            Assign "[M:" + PARENTSCRABR + "]BVRNUM(" + TABINDEX + ")" With [M]BVRNUM
        Endif
    Endif

    Gosub OK From BIDLOCDE
Return



# ############################################################################################# #
# ##########                                                                                    #
# ########## Screen/Window handling                                                             #
# ##########                                                                                    #
# ##########                                                                                    #
# ##########                                                                                    #
# ############################################################################################# #


# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank account number                                      #
# ########## Does:  - Checks that the bank account number is numeric                            #
# ##########        - Fills the bank account number with leading zeroes.                        #
# ##########        - Recalculates the IBAN.                                                    #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANACC(VALEUR)
Variable Char VALEUR()

    Local Integer LENGTH : LENGTH = len( VALEUR )
    Local Integer I

    # Prepend leading zeroes.
    For I = LENGTH + 1 To [M]LENBANACC
        VALEUR = "0" + VALEUR
    Next

    VALEUR = toupper( VALEUR )
End

Subprog AM_BANACC( VALEUR )
Variable Char VALEUR()

    Call AM_BANACC( VALEUR ) From BIDLOCDE
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the bank sort code                                           #
# ########## Does:  - Checks that the bank sort code is numeric                                 #
# ##########        - Fills the bank sort code with leading zeroes.                             #
# ##########        - Checks if the bank sort code is valid (if bank control is activated)      #
# ##########        - Fills in bank and IBAN.                                                   #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_BANCOD( VALEUR )
Variable Char VALEUR()

    Call C_BANCOD( VALEUR ) From BIDLOCDE
End

Subprog AM_BANCOD( VALEUR )
Variable Char VALEUR()

    Call AM_BANCOD( VALEUR ) From BIDLOCDE
End



# ############################################################################################# #
# ##########                                                                                    #
# ########## Event: After changing the IBAN                                                     #
# ########## Does:  Checks the validity of the IBAN and restores bank sort code and bank        #
# ##########        account number.                                                             #
# ##########                                                                                    #
# ############################################################################################# #

Subprog C_IBACOD( VALEUR )
Variable Char VALEUR()

    Call C_IBACOD( VALEUR ) From BIDLOCDE
End

Subprog AM_IBACOD( VALEUR )
Variable Char VALEUR()

    Call AM_IBACOD( VALEUR ) From BIDLOCDE
End
