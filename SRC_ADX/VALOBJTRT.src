#<AdxTL>@(#)0.0.0.0 $Revision$
#---------------------------------------------------------------------------------------------------#
# VALOBJTRT Ecriture du traitement WOxxx (GESxxx en 130)
#---------------------------------------------------------------------------------------------------#

$VALTRT
Gosub TRT_DEB
Gosub ETIQUETTES
Gosub TRT_FIN
Return

$TRT_DEB
NOMPROG = "WO"+OBJET
FICSRC = filpath("TRT",NOMPROG,"src",APPLI)
Openo FICSRC , 0
adxifs = ""
adxirs = chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq "#"-mess(164,123,1)-OBJET : # Gestion objet
Wrseq
Return

$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,APPLI,OK) From VALMSKSUB
Return

#---------------------------------------------------------------------------------------------------#
$ETIQUETTES
#---------------------------------------------------------------------------------------------------#

Wrseq "$HORODAT"
Wrseq "Local Date    A_DATE"
Wrseq "Local Char    A_HEURE(10) , A_USER(10)"
Wrseq "Local Char    A_STAMP(15)"
Wrseq "A_DATE  = [";format$(GFMD,JOUR)+"]"
Wrseq 'A_HEURE = "';HEURE;'"'
Wrseq 'A_USER  = "';GUSER;'"'
Wrseq 'A_STAMP = "';format$('D:YYYYMMDD',JOUR);ctrans(HEURE,':','');'"'
Wrseq "Return"
Wrseq

Wrseq "$DEFAUT"
If ATB_ABR<>""
 Wrseq "Default File ["+ATB_ABR+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$OUVFIC"
If ATB_FIC<>""
 If ATB_ABR<>"" & ATB_ABR<>ATB_FIC
  Wrseq "Local File"-ATB_FIC -"["+ATB_ABR+"]"
 Else
  Wrseq "Local File"-ATB_FIC
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$NOMFIC"
NLG = num$(MAXLIA)
Wrseq "Local Integer NBLNK , TITLNK(1.."+NLG+")"
Wrseq "Local Char    OBJLNK(GLONAOB)(1.."+NLG+") , CODLNK(GLONADI)(1.."+NLG+")"
Wrseq "Local Char    DESLNK(20)(1.."+NLG+") , ABRLNK(GLONABR)(1.."+NLG+")"
Wrseq "Local Integer NUMLNK(1.."+NLG+") , LIGLNK(1.."+NLG+")"

Wrseq "Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)"
Wrseq "Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ"
Wrseq "Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)"
Wrseq "Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)"
Wrseq "Local Integer DELDEF, FCYREQ"
Wrseq "Local Char    SELIND(250) , ADDURL(250)"

If AOB_MLOCK=2
 Wrseq "Local Integer MLOCK"
Endif
If AOB_RQT<>"xxx"
 Wrseq "Local Char    RQTGRP(GLONALH)"
Endif

Wrseq 'NOMFIC = "'+ATB_FIC+'"'
Wrseq 'ABFIC  = "'+ATB_ABR+'"'
Wrseq 'ABTAB  = "'+ATB_STD+'"'
Wrseq 'NOMINT = "'+ATB_INT+'"'
Wrseq 'TYPGES = '+num$(AOB_GES)
Wrseq 'SELORD = '+num$(AOB_ORD)
Wrseq 'ZSITE  = "'+AOB_FLDFCY+'"'
Wrseq 'ZACC   = "'+AOB_FLDACC+'"'
Wrseq 'FLDGRF = "'+AOB_FLDGRF+'"'
Wrseq 'FLDGRC = "'+AOB_FLDGRC+'"'
Wrseq 'FLDLEG = "'+AOB_FLDLEG+'"'
K = 0
If AOB_FLDFCY<>""
 Read [ATZ]CODZONE = ATB_FIC;AOB_FLDFCY
 If !fstat & [F:ATZ]OBLIG=2 : K = 1 : Endif
Endif
Wrseq "FCYREQ = "+num$(K)
Wrseq "PPAG   = "+num$(find(AWI_TYP,2,3)<>0)
SELIND = ""
If AOB_CLE<>""
 Read [ATI]CODIND = ATB_FIC;AOB_CLE
 If !fstat 
  CHAINE = [F:ATI]DESCRIPT
  While CHAINE<>""
   I = instr(1,CHAINE,"+")
   J = instr(1,CHAINE,"-")
   If I & J
    I = min(I,J)
   Elsif J & !I
    I = J
   Endif
   If I
    If SELIND<>"" : SELIND += ";" : Endif
    SELIND += "[F:"+ATB_ABR+"]"+left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    If SELIND<>"" : SELIND += ";" : Endif
    SELIND += "[F:"+ATB_ABR+"]"+CHAINE
    CHAINE = ""
   Endif
  Wend
 Endif
Endif
Wrseq 'SELIND = "'+SELIND+'"'
Wrseq "DELDEF = "+num$(AOB_DELDEF=2)
If AOB_MLOCK=2
 Wrseq "If !GIMPORT : MLOCK = 1 : Endif"
Endif
If dim(AOB_URL)>0
 If instr(1,AOB_URL,'"')
  Wrseq "ADDURL = '";format$("KTv2:250X",AOB_URL)+"'"
 Else
  Wrseq 'ADDURL = "';format$("KTv2:250X",AOB_URL)+'"'
 Endif
Endif
If AOB_RQT<>"" & AOB_RQT<>"xxx"
 Wrseq 'RQTGRP = "'+AOB_RQT+'"'
Endif
If find(AOB_GES,2,3)
 Wrseq "Local Char    BASPAG(GLONAVA)"
 Wrseq "Local Integer MAXLIG" 
 Wrseq 'BASPAG = "'+AOB_BASPAG+'"'
 Wrseq 'MAXLIG = '+num$(AOB_MAXLIG)
Endif

If AOB_RPT1<>"" 
 Wrseq 'REPORT1 = "'+AOB_RPT1+'"' 
Endif
If AOB_RPT2<>"" 
 Wrseq 'REPORT2 = "'+AOB_RPT2+'"' 
Endif 
If AOB_CLE<>"" 
 Wrseq 'NOMKEY = "'+AOB_CLE+'"' 
Endif 
Wrseq "FLGSTAT = "+num$(AOB_STA=2)
If dim(AOB_LIBSHO)>0 & AOB_LIBSHO<>0
 Wrseq "TITOBJ = "+num$(AOB_LIBSHO)
Else
 Wrseq "TITOBJ = "+num$(AOB_LIBEL)
Endif

Wrseq "NBLNK = 0"
Wrseq "Raz NUMLNK , LIGLNK"
Raz K, L
For I=1 To AOK_NBR
 K += 1
 If AOK_LNK(I)<>""
  Wrseq 'NBLNK += 1'
  Wrseq 'OBJLNK(NBLNK) = "'+AOK_OBJ(I)+'"'
  Wrseq 'CODLNK(NBLNK) = "'+AOK_LNK(I)+'"'
  Wrseq 'DESLNK(NBLNK) = "[F:'+AOK_ABR(I)+']'+AOK_INT(I)+'"'
  Wrseq 'TITLNK(NBLNK) = '+num$(AOK_TIT(I))
  Wrseq 'ABRLNK(NBLNK) = "'+AOK_ABR(I)+'"'
  If AOK_BAS(I)<>""
   L += 1
   Wrseq "NUMLNK("+num$(K)+") = "+num$(L)
   Wrseq "Local Char CLELNK"+num$(L)+"(40)(1..300)"
  Endif
 Endif
Next I
Wrseq "Return"
Wrseq

Wrseq "$OUVRE"
For I=1 To AOB_NBFIC
 Wrseq 'If clalev([F:'+AOB_ABRLNK(I)+'])=0';
 K = find(AOB_FICLNK(I),TABCPT(1..CPTNB))
 If K
  Wrseq
  Wrseq ' If dim(GTABCPT)>0 & GTABCPT<>"" & find("'+OBJCPT(K)+'",GABRCPT(1..GNBTABCPT))'
  Wrseq '  Local File =GTABCPT+"'+AOB_FICLNK(I)+'" ['+AOB_ABRLNK(I)+']'
  Wrseq ' Else '
  Wrseq '  Local File '+AOB_FICLNK(I)+' ['+AOB_ABRLNK(I)+']'
  Wrseq ' Endif'
 Else
  Wrseq ' : Local File '+format$("K:"+num$(GLONATB)+"X",AOB_FICLNK(I))+' ['+AOB_ABRLNK(I)+'] : ';
 Endif
 Wrseq 'Endif'
Next I
If AOB_FLDACC<>""
 Wrseq "If clalev([F:ACC])=0 : Local File "+format$('K:10X','ACCES')+" [ACC] : Endif"
Endif
If AOB_FLDFCY<>""
 Wrseq "If clalev([F:AFF])=0 : Local File "+format$('K:10X','AFCTFCY')+" [AFF] : Endif"
Endif
For I=1 To AOB_NBVUE
 Wrseq 'If clalev([F:'+AOB_ABRVUE(I)+'])=0';
 Wrseq ' : Local File '+format$("K:"+num$(GLONAVW)+"X",AOB_CODVUE(I))+' ['+AOB_ABRVUE(I)+'] : ';
 Wrseq 'Endif'
Next I
For I=1 To AOK_NBR
 Wrseq 'If clalev([F:'+AOK_ABR(I)+'])=0';
 K = find(AOK_FIC(I),TABCPT(1..CPTNB))
 If K
  Wrseq
  Wrseq ' If dim(GTABCPT)>0 & GTABCPT<>"" & find("'+OBJCPT(K)+'",GABRCPT(1..GNBTABCPT))'
  Wrseq '  Local File =GTABCPT+"'+AOK_FIC(I)+'" ['+AOK_ABR(I)+']'
  Wrseq ' Else'
  Wrseq '  Local File '+AOK_FIC(I)+' ['+AOK_ABR(I)+']'
  Wrseq ' Endif'
 Else
  Wrseq ' : Local File '+format$("K:"+num$(GLONATB)+"X",AOK_FIC(I))+' ['+AOK_ABR(I)+'] : ';
 Endif
 Wrseq 'Endif'
Next I
Wrseq 'Return'
Wrseq

Wrseq "$ESPION"
Wrseq "NUMESPION = 1"
Wrseq "Return"
Wrseq

Wrseq "$TIT"
Wrseq "Local Char TIT(60)" 
If AOB_LIBEL=0 
 Wrseq "TIT = titre" 
Else
 Wrseq "Call TEXTE("+num$(AOB_LIBEL)+",TIT) From OBJDIV" 
Endif
Wrseq "Return"
Wrseq

Wrseq "$SETCLE"
Wrseq "Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0.."+num$(max(NBCLE-2,0))+") , CLELIG(GLONAVA)"
If CLEPRIM<>""
 Wrseq "CLEPRIM = '"+CLEPRIM+"'"
Endif
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  Wrseq "CLESEC("+num$(I)+") = '"+CLESEC(I)+"'"
 Endif
Next I
If find(AOB_GES,3)
 Wrseq "CLELIG = '"+CLE(NBCLE)+"'"
Endif
If CLEGEO<>"" : ## GEODE
 NLG = num$(max(0,NBCLE-2-(CLEFCY<>"")-(CLEDEP<>"")))
 Wrseq "Local Char CLEVALEUR(GLONAVA), CLESUPP(GLONAVA)(0.."+NLG+"), CLEFCY(GLONAVA), CLEDEP(GLONAVA)"  
 Wrseq "CLEVALEUR = '"+CLEGEO+"'"
 For I=0 To dim(CLESUPP)-1
  If CLESUPP(I)="" : Break : Endif
  Wrseq "CLESUPP("+num$(I)+") = '"+CLESUPP(I)+"'"
 Next I
 If CLEFCY<>"" : Wrseq "CLEFCY = '"+CLEFCY+"'" : Endif
 If CLEDEP<>"" : Wrseq "CLEDEP = '"+CLEDEP+"'" : Endif
Endif
If AOB_DSYPAR=2
 Wrseq "Local Integer DSYPAR"
 Wrseq "DSYPAR=2"
Endif
Wrseq "Return"
Wrseq

Wrseq "$OPTIONS"
Wrseq "Local Integer  NBCOND"
Wrseq "Local Char     CONDIT(50)(1.."+num$(MAXOPT)+")"
Wrseq "Local Char     OPT(1)(1.."+num$(MAXOPT)+") , OPTSEL("+num$(MAXOPT)+")"
Wrseq "Local Char     LIBOPT(30)(1.."+num$(MAXOPT)+"), MESSAG(80)(1.."+num$(MAXOPT)+")"
Wrseq "NBCOND = 0"
For I=1 To AOB_NBOPT
 Wrseq "NBCOND += 1"
 Wrseq "OPT(NBCOND)    = '"+AOB_OPTCOD(I)+"'"
 Wrseq 'CONDIT(NBCOND) = "'+vireblc(format$("KT:80X",AOB_OPTCND(I)),2)+'"'
 Wrseq 'Call TEXTE('+num$(AOB_OPTLIB(I))+',LIBOPT(NBCOND)) From OBJDIV'
 Wrseq 'Call TEXTE('+num$(AOB_OPTERR(I))+',MESSAG(NBCOND)) From OBJDIV'
Next I
Wrseq "OPTSEL = '"+AOB_OPT+"'"
Wrseq "Return"
Wrseq

Wrseq "$LIBPAR"
Wrseq "Local Char LIBPAR(30)"
Wrseq "Call TEXTE("+num$(AOB_LIBPAR)+",LIBPAR) From OBJDIV"
Wrseq "Return"
Wrseq

Wrseq "$OUVFIC_DERLU"
If AOB_NBSEL<>0 & !find(AOB_GES,2,4) & ATB_ABR<>""
 K = 0
 Wrseq "Local Decimal  A_BUFI(0..GNBDERNIER)"      : # Un index est nécessaire pour la 140
 Wrseq "Local Char     A_BUFC(200)(0..GNBDERNIER)" : # Et la clé aussi
 For I=1 To AOB_NBSEL
  If AOB_SELFIC(I)<>"" : # Pas d'expression dans derniers lus
   If AOB_SELFIC(I)=ATB_FIC & AOB_SELZON(I)=FLDTXT
    Wrseq "Local Char     A_BUF"+num$(K+1)+"("+num$(GLONID1)+")(0..GNBDERNIER)" : K += 1 : OK = 1
   Else
    OK = 0  
   Endif
  Else
   OK = 0
  Endif
  If !OK
   Wrseq "Local ";  
   Case AOB_SELTYPTYP(I)
    When 1       : Wrseq "Libelle  ";
    When 2       : Wrseq "Shortint ";
    When 3       : Wrseq "Integer  ";
    When 7       : Wrseq "Char     ";
    When 8       : Wrseq "Date     ";
    When Default : Wrseq "Decimal  ";
   Endcase
   Wrseq "A_BUF"+num$(K+1); : K += 1
   If AOB_SELTYPTYP(I)=7
    If AOB_SELLNG(I)<>0
     Wrseq "("+num$(AOB_SELLNG(I))+")";
    Else
     Wrseq "(50)";
    Endif
   Endif
   Wrseq "(0..GNBDERNIER)"
  Endif
 Next I
 Wrseq "If clalev([F:"+ATB_ABR+"9])>0 : Close Local File ["+ATB_ABR+"9] : Endif"
 Wrseq "Local File ("
 K = 0
 Wrseq "& Decimal  A_TABI,"
 Wrseq "& Char     A_TABC(200)";
 For I=1 To AOB_NBSEL
  Wrseq ","
  If AOB_SELFIC(I)<>""
   If AOB_SELFIC(I)=ATB_FIC & AOB_SELZON(I)=FLDTXT
    Wrseq "& Char     A_TAB"+num$(K+1)+"("+num$(GLONID1)+")"; : K += 1 : OK = 1
   Else
    OK = 0
   Endif
  Else
   OK = 0
  Endif
  If !OK
   Case AOB_SELTYPTYP(I)
    When 1       : Wrseq "& Libelle  ";
    When 2       : Wrseq "& Shortint ";
    When 3       : Wrseq "& Integer  ";
    When 7       : Wrseq "& Char     ";
    When 8       : Wrseq "& Date     ";
    When Default : Wrseq "& Decimal  ";
   Endcase
   Wrseq "A_TAB"+num$(K+1); : K += 1
   If AOB_SELTYPTYP(I)=7
    If AOB_SELLNG(I)<>0
     Wrseq "("+num$(AOB_SELLNG(I))+")";
    Else
     Wrseq "(50)";
    Endif
   Endif
  Endif
 Next I
 Wrseq 
 Wrseq "& ) From Variable ";
 K = 0
 Wrseq "A_BUFI,A_BUFC";
 For I=1 To AOB_NBSEL
  Wrseq "," ;
  Wrseq "A_BUF"+num$(K+1); : K += 1
 Next I
 Wrseq
 Wrseq "& As ["+ATB_ABR+"9]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$LEC_DERLU"
If AOB_NBSEL<>0 & AOB_GES<>2 & ATB_ABR<>""
 If FLDTXT<>""
  Wrseq "Read [ATX]NUMERO = GLANGUE ; [F:"+ATB_ABR+"]"+FLDTXT
  Wrseq "If fstat : Raz [F:ATX] : Endif"
 Endif
 If AOB_FLDACC<>""
  Wrseq "Read [ACC]CODACC = GUSER ; [F:"+ATB_ABR+"]"+AOB_FLDACC
  Wrseq "If fstat : Raz [F:ACC] : Endif"
 Endif
 If AOB_FLDFCY<>""
  Wrseq "Read [AFF]AFF0 = [F:"+ATB_ABR+"]"+AOB_FLDFCY+";GPROFIL;GUSRFCT"
  Wrseq "If fstat : Raz [F:AFF] : Endif"
 Endif
 If LNKSEL<>""
  For I=1 To AOB_NBFIC
   If J<MAXLNK & AOB_EXPLNK(I)<>"" & AOB_OBLLNK(I)
    CHAINE = vireblc(format$("KT:200X",AOB_EXPLNK(I)),2)
    Wrseq "Read ["+AOB_ABRLNK(I)+"]"+AOB_CLELNK(I)+"="+CHAINE
    Wrseq "If fstat : Raz [F:"+AOB_ABRLNK(I)+"] : Endif"
    J += 1
   Endif    
  Next I
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$CHARGE_DERLU"
If AOB_NBSEL<>0 & !find(AOB_GES,2,4) & ATB_ABR<>""
 Wrseq "If clalev([F:"+ATB_ABR+"9])>0"
 Wrseq " Read ["+ATB_ABR+"9] = [F:"+ATB_ABR+"9]A_TABI"
 Wrseq " [L]CLE = [F:"+ATB_ABR+"9]A_TABC"
 Wrseq "Endif"
Endif
Wrseq "Return"
Wrseq

Wrseq "$REMP_DERLU"
If AOB_NBSEL<>0 & !find(AOB_GES,2,4) & AWI_BOX<>"" & ATB_ABR<>""
 Wrseq "If clalev([F:"+ATB_ABR+"9])>0"
 Wrseq " Filter ["+ATB_ABR+"9]"
 Wrseq "& Where A_TABI<>0"
 K = 0
 Wrseq "& Order by A_TABI"
 Wrseq " Fillbox ["+AWI_BOX+"] GAU_CHE9"
 Wrseq "Endif"
Endif
Wrseq "Return"  
Wrseq  

Wrseq "$CLE_DERLU"
If AOB_NBSEL<>0 & !find(AOB_GES,2,4) & AWI_BOX<>"" & ATB_ABR<>""
 Wrseq "If clalev([F:"+ATB_ABR+"9])>0"
 Wrseq " Local Integer A_IND"
 Wrseq " Local Char    A_CLEDERLU(200)"
 Wrseq ' A_CLEDERLU = ""'
 If CLEPRIM<>""
  Case TYPPRIM
   When 1,2,3,4,5,6 : Wrseq ' A_CLEDERLU = num$([F:'+ATB_ABR+']'+CLEPRIM+')+"~"'
   When Default     : Wrseq ' A_CLEDERLU = [F:'+ATB_ABR+']'+CLEPRIM+'+"~"'
  Endcase
 Endif
 For I=0 To dim(CLESEC)-1
  If CLESEC(I)="" or (AOB_GES=3 & CLESEC(I)=CLE(NBCLE)) : Break : Endif
  Case TYPSEC(I)
   When 1,2,3,4,5,6 : Wrseq ' A_CLEDERLU += num$([F:'+ATB_ABR+']'+CLESEC(I)+')+"~"'
   When Default     : Wrseq ' A_CLEDERLU += [F:'+ATB_ABR+']'+CLESEC(I)+'+"~"'
  Endcase
 Next I
 If CLEPRIM<>"" or CLESEC(0)<>""
  Wrseq " A_IND = find(A_CLEDERLU,A_BUFC)"
  Wrseq " If A_IND"
  Wrseq "  [F:"+ATB_ABR+"9]A_TABI = A_BUFI(A_IND-1)"
  Wrseq " Else"
  Wrseq "  Raz [F:"+ATB_ABR+"9]"
  Wrseq " Endif"
 Endif
 Wrseq "Endif"
Endif
Wrseq "Return"  
Wrseq  

Wrseq "$OUVRE_LISTE"
Wrseq "Local Integer NBSEL , NBTRI , SELCAR"
NLG = num$(MAXSEL)
Wrseq "Local Char    SELZON(30)(0.."+NLG+")"
Wrseq "Local Char    SELEXP(200)(0.."+NLG+")"
Wrseq "Local Char    SELLIB(30)(0.."+NLG+")"
Wrseq "Local Char    SELFMT(30)(0.."+NLG+")"
Wrseq "Local Schar   SELFOR(30)(0.."+NLG+")"
Wrseq "Local Integer SELTYP(0.."+NLG+")"
Wrseq "Local Integer SELMAJ(0.."+NLG+")"
If AOB_GES=4 & dim(AOB_SELPCK)>0
 Wrseq "Local Integer SELPCK(0.."+NLG+")"
Endif
Wrseq "Local Char    TRIZON(20)(0.."+NLG+")"
Wrseq "Local Char    TRILIB(30)(0.."+NLG+")"
Wrseq 'SELCAR = '+num$(AOB_CAR)
Wrseq 'NBSEL = 0 : NBTRI = 0'
For I=1 To AOB_NBSEL
 Wrseq 'NBSEL += 1'
 If AOB_SELFIC(I)<>""
  If AOB_SELTYP(I)="ATX"
   Wrseq 'SELZON(NBSEL) = "[F:ATX]TEXTE"'
  Else
   Wrseq 'SELZON(NBSEL) = "[F:'+AOB_SELABR(I)+']'+AOB_SELZON(I);
   If AOB_SELDIM(I)>1
    Wrseq '(0)';
   Endif
   Wrseq '"'
  Endif
  Wrseq 'Call TEXTE('+num$(AOB_SELINT(I))+',SELLIB(NBSEL)) From OBJDIV'
 Else
  Wrseq 'SELZON(NBSEL) = "[L]SAIRAP('+num$(I)+')"'
  Wrseq 'SELEXP(NBSEL) = "'+vireblc(format$("KT:200X",AOB_SELEXP(I)),2)+'"'
  Wrseq 'Call TEXTE('+num$(AOB_SELINT(I))+',SELLIB(NBSEL)) From OBJDIV'
 Endif
 If AOB_SELTYP(I)="ATX"
  Wrseq 'SELTYP(NBSEL) = 7'
 Else
  Wrseq 'SELTYP(NBSEL) = '+num$(AOB_SELTYPTYP(I))
 Endif
 Wrseq 'SELFMT(NBSEL) = "'+AOB_SELFMT(I)+'"'
 Wrseq 'SELFOR(NBSEL) = ';
 If AOB_SELFOR(I)<>"" : Wrseq AOB_SELFOR(I) : Else : Wrseq '""' : Endif
 If AOB_SELFIC(I)<>"" & (instr(1,AOB_SELOPT(I),"A") or instr(1,AOB_SELOPT(I),"C"))
  Wrseq 'SELMAJ(NBSEL) = 1'
 Else
  Wrseq 'SELMAJ(NBSEL) = 0'
 Endif
 If AOB_GES=4 & dim(AOB_SELPCK)>0
  Wrseq 'SELPCK(NBSEL) = '+num$(AOB_SELPCK(I))
 Endif
 If AOB_SELFIC(I)<>""
  Wrseq 'NBTRI += 1'
  If AOB_SELTYP(I)="ATX"
   Wrseq 'TRIZON(NBTRI) = "[F:ATX]TEXTE"'
  Else
   Wrseq 'TRIZON(NBTRI) = "[F:'+AOB_SELABR(I)+']'+AOB_SELZON(I)+'"'
  Endif
  Wrseq 'TRILIB(NBTRI) = SELLIB(NBSEL)'
 Endif
Next I
If AOB_FLDFCY<>"" or AOB_FLDACC<>"" or FLDTXT<>"" or sum(AOB_OBLLNK) or AOB_FLDGRF<>"" or AOB_FLDGRC<>""
 Wrseq "If clalev([F:"+ATB_ABR+"_])=0"
 Wrseq " Gosub OUVFIC_LISTE"
 Wrseq "Endif"
Endif
Wrseq "Return"
Wrseq

Wrseq "$OUVFIC_LISTE"
Raz OKTXT, OKACC, OKFCY, OKGRC, OKGRF
If ATB_FIC<>"" & (AOB_FLDFCY<>"" or AOB_FLDACC<>"" or FLDTXT<>"" or sum(AOB_OBLLNK) or AOB_FLDGRF<>"" or AOB_FLDGRC<>"")
 SPA = 0 : Gosub WRLINK From VALOBJSUB
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEFAUT_LISTE"
If ATB_ABR<>""
 If (AOB_FLDFCY<>"" or AOB_FLDACC<>"" or FLDTXT<>"" or sum(AOB_OBLLNK)) and AOB_NBSEL>0 or AOB_FLDGRF<>"" or AOB_FLDGRC<>""
  Wrseq "Default file ["+ATB_ABR+"_]"   
 Else
  Wrseq "Default file ["+ATB_ABR+"]"
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "$OUVRE_JOIN"
If NBCLE>0 & !find(AOB_GES,4)
 If AOB_GES=3 & NBCLE>2
  J = NBCLE
 Elsif AOB_GES=3 & NBCLE=2
  J = NBCLE-1
 Else
  J = -1
 Endif 
 Raz K, CHAINE
 For I=1 To NBCLE
  If I<>J
   CHAINE += "A_TABJ"+num$(K+1)
   If (I=NBCLE-1 & J=NBCLE) | I=NBCLE : 
   Else                               : CHAINE += ";"
   Endif
  Endif
  K += 1
 Next I
 Wrseq 'Local Char    ORDRE_JOI(250)'
 Wrseq 'ORDRE_JOI = "'+CHAINE+'"'
 Raz K
 For I=0 To NBCLE-1
  If NBCLE=1      # seule et unique clé
   L = LONPRIM
   T = TYPPRIM
  Elsif I=0 :     # Clé primaire
   L = LONSEC(0)
   T = TYPSEC(0)
  Elsif I=1 
   L = LONPRIM
   T = TYPPRIM
  Elsif CLESEC(I-1)=""
   Break
  Else :  # Clé secondaire
   L = LONSEC(I-1)
   T = TYPSEC(I-1)
  Endif
  Wrseq "Local ";  
  Case T
   When 1       : Wrseq "Libelle  ";
   When 2       : Wrseq "Shortint ";
   When 3       : Wrseq "Integer  ";
   When 7       : Wrseq "Char     ";
   When 8       : Wrseq "Date     ";
   When Default : Wrseq "Decimal  ";
  Endcase
  Wrseq "A_BUFJ"+num$(K+1); : K += 1
  If T=7
   If L<>0
    Wrseq "("+num$(L)+")";
   Else
    Wrseq "("+num$(GLONID1)+")";
   Endif
  Endif    
  Wrseq "(1..GNBSEL)"
  If NBCLE=1 : Break : Endif
 Next I
 Wrseq "Local Char     A_BUFJ"+num$(K+1)+"(15)(1..GNBSEL)" : K += 1 : # type de document
 Wrseq "Local Char     A_BUFJ"+num$(K+1)+"(80)(1..GNBSEL)" : K += 1 : # nom du document
 Raz K
 Wrseq "Local File("
 For I=0 To NBCLE-1
  If NBCLE=1
   L = LONPRIM
   T = TYPPRIM
   Wrseq "& ";  
  Elsif I=0 : # Clé primaire
   L = LONSEC(0)
   T = TYPSEC(0)
   Wrseq "& ";  
  Elsif I=1
   L = LONPRIM
   T = TYPPRIM
   Wrseq ","
   Wrseq "& ";  
  Elsif CLESEC(I-1)=""
   Break
  Else : # Clé secondaire
   L = LONSEC(I-1)
   T = TYPSEC(I-1)
   Wrseq ","
   Wrseq "& ";  
  Endif
  Case T
   When 1       : Wrseq "Libelle  ";
   When 2       : Wrseq "Shortint ";
   When 3       : Wrseq "Integer  ";
   When 7       : Wrseq "Char     ";
   When 8       : Wrseq "Date     ";
   When Default : Wrseq "Decimal  ";
  Endcase
  Wrseq "A_TABJ"+num$(K+1); : K += 1
  If T=7
   If L<>0
    Wrseq "("+num$(L)+")";
   Else
    Wrseq "("+num$(GLONID1)+")";
   Endif
  Endif
  If NBCLE=1 : Break : Endif
 Next I
 Wrseq ",";
 Wrseq
 Wrseq "& Char     A_TABJ"+num$(K+1)+"(15)," : K += 1 
 Wrseq "& Char     A_TABJ"+num$(K+1)+"(80)"  : K += 1 
 Wrseq "& ) From Variable ";
 Raz J, K
 For I=1 To 2+NBCLE
  If J=1 : Wrseq ", "; : Else : J = 1 : Endif
  Wrseq "A_BUFJ"+num$(K+1); : K += 1
 Next
 Wrseq
 Wrseq "& As [PCEJ]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$TIT_JOIN"
If NBCLE>0 & !find(AOB_GES,4)
 Raz I
 Wrseq 'Local Char TITJOI'+'(30)(1..'+num$(2+NBCLE)+')'
 If NBCLE=1
  Wrseq 'Call TEXTE('+num$(TITPRIM)+',TITJOI'+'('+num$(I+1)+')) From OBJDIV'
  I +=1
  Wrseq 'TITJOI'+'('+num$(I+1)+') = mess(59,100,1) : # Type'
  I += 1
  Wrseq 'TITJOI'+'('+num$(I+1)+') = mess(38,100,1) : # Nom'
 Else
  Wrseq 'Call TEXTE('+num$(TITSEC(0))+',TITJOI'+'('+num$(I+1)+')) From OBJDIV'
  I += 1
  Wrseq 'Call TEXTE('+num$(TITPRIM)+',TITJOI'+'('+num$(I+1)+')) From OBJDIV'
  K = I+1
  For I=1 To NBCLE-2
   Wrseq 'Call TEXTE('+num$(TITSEC(I))+',TITJOI'+'('+num$(K+1)+')) From OBJDIV'
   K += 1
  Next I
  Wrseq 'TITJOI'+'('+num$(NBCLE+1)+') = mess(59,100,1) : # Type'
  Wrseq 'TITJOI'+'('+num$(NBCLE+2)+') = mess(38,100,1) : # Nom'
 Endif
Endif
Wrseq "Return"
Wrseq

Wrseq "Subprog FORMCLE(FMT,LG,TIT)"
Wrseq "Variable Char    FMT()"
Wrseq "Variable Integer LG"
Wrseq "Variable Char    TIT()"
If CLEGEO<>"" : # X3 Géode
 Call FORMA(30,TYPGEO,LONGEO,LIBGEO,OPTGEO,FORGEO,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
 T = TYPGEO
Else
 Call FORMA(30,TYPPRIM,LONPRIM,LIBPRIM,OPTPRIM,FORPRIM,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
 T = TYPPRIM
Endif
If left$(TYPFMT,1)="="
 Wrseq 'FMT = '+right$(TYPFMT,2)+OPTFMT+'f:'+CHFMT
 Elsif T=8
 Wrseq 'FMT = "Df:"+GFMDAT'
Else
 Wrseq 'FMT = "'+TYPFMT+OPTFMT+'f:'+CHFMT+'"'
Endif
Wrseq 'LG = '+num$(LNGFMT)
Wrseq 'TIT = ""' : # On n'en a plus besoin
Wrseq "End"
Wrseq

If (CLEGEO="" & CLESEC(0)<>"") | (CLEGEO<>"" & CLESUPP(0)<>"")
 Wrseq "Subprog FORMCLE2(FMT)"
 Wrseq "Variable Char    FMT()"
 If CLEGEO<>""
  Call FORMA(30,TYPSUPP(0),LONSUPP(0),LIBSUPP(0),OPTSUPP(0),FORSUPP(0),TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
  T = TYPSUPP(0)
 Else
  Call FORMA(30,TYPSEC(0),LONSEC(0),LIBSEC(0),OPTSEC(0),FORSEC(0),TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
  T = TYPSEC(0)
 Endif
 If left$(TYPFMT,1)="="
  Wrseq 'FMT = '+right$(TYPFMT,2)+OPTFMT+'f:'+CHFMT
 Elsif T=8
  Wrseq 'FMT = "Df:"+GFMDAT'
 Else
  Wrseq 'FMT = "'+TYPFMT+OPTFMT+'f:'+CHFMT+'"'
 Endif
 Wrseq "End"
 Wrseq
Endif

Wrseq "$LIENS"
K = 0
If FLDTXT<>""     : K += 1 : Endif
If AOB_FLDACC<>"" : K += 1 : Endif
If AOB_FLDFCY<>"" : K += 1 : Endif
For I=1 To AOB_NBFIC
 If AOB_EXPLNK(I)<>"" & AOB_OBLLNK(I) & K<MAXLNK
  K += 1
  Wrseq "Read ["+AOB_ABRLNK(I)+"]"+AOB_CLELNK(I)+" = "+vireblc(format$("KT:200X",AOB_EXPLNK(I)),2)
  Wrseq "If fstat : Raz [F:"+AOB_ABRLNK(I)+"] : Endif"
 Endif    
Next I
Wrseq "Return"
Wrseq

Wrseq "$LIAISONS"
K = 0
For I=1 To AOK_NBR
 If AOK_LNK(I)<>""
  K += 1
  If AOK_BAS(I)=""
   Wrseq "Read ["+AOK_ABR(I)+"]"+AOK_CLE(I)+" = "+vireblc(format$("KT:120X",AOK_EXP(I)),2)
   Wrseq "If fstat : Raz [F:"+AOK_ABR(I)+"] : Endif"
  Else
   Wrseq "LIGLNK("+num$(K)+") = ";vireblc(format$("KT:120X",AOK_BAS(I)),2)
  Endif
 Endif
Next I
Wrseq "Return"
Wrseq

K = 0
For I=1 To AOK_NBR
 If AOK_BAS(I)<>"" & AOK_LNK(I)<>""
  K += 1
  Wrseq "$LIAISONS_"+num$(K)
  Wrseq "Read ["+AOK_ABR(I)+"]"+AOK_CLE(I)+" = "+vireblc(format$("KT:120X",AOK_EXP(I)),2)
  Wrseq "If fstat : Raz [F:"+AOK_ABR(I)+"] : Endif"
  Wrseq "Return"
  Wrseq
 Endif
Next I

Wrseq "Subprog TITTRN(COD,TIT)"
Wrseq "Value Char COD"
Wrseq "Variable Char TIT"
Wrseq "Local Integer OUV"
Wrseq "Local Char    CRITERE(250)"
Wrseq 'TIT = ""'
If AOB_TRNATB<>""
 Wrseq "Default [V] , [L] , [S] , [F] , [M]"
 Wrseq "If clalev([F:"+AOB_TRNABR+"])=0 : Local File "+AOB_TRNATB+" ["+AOB_TRNABR+"] : OUV = 1 : Endif"
 Wrseq "Default File ["+AOB_TRNABR+"]"
 Wrseq 'CRITERE = '+"'"+'[F:'+AOB_TRNABR+']'+AOB_TRNFLD+'=[L]COD'+"'"
 If AOB_TRNCND<>""
  Wrseq 'CRITERE += '+"'"+'& '+format$("KV2:250X",AOB_TRNCND)+"'"
 Endif
 If dim(AOB_TRNLEG)>0 & AOB_TRNLEG<>""
  Wrseq 'If dim([F:'+AOB_TRNABR+']'+AOB_TRNLEG+')>0 & dim(GLEGFIL)>0 & GLEGFIL<>"" & GNBLEG>1'
  Wrseq ' CRITERE += '+"'"+'& ([F:'+AOB_TRNABR+']'+AOB_TRNLEG+'="" | [F:'+AOB_TRNABR+']'+AOB_TRNLEG+'=GLEGFIL)'+"'"
  Wrseq ' Local Integer OK'
  Wrseq 'Endif'
 Endif
 Wrseq 'For ['+AOB_TRNABR+'] Where evalue(CRITERE)'
 If dim(AOB_TRNLEG)>0 & AOB_TRNLEG<>""
  Wrseq ' If dim([L]OK)>0 : OK = 1 : Endif'
 Endif
 Case AOB_TRNTYP
  When "AXX","AX1","AX2","AX3"
   Wrseq ' Call LECTEXTRA(TIT';
   If AOB_TRNCLE(1)<>"" : Wrseq ','+AOB_TRNCLE(1); Else : Wrseq ',""'; : Endif
   If AOB_TRNCLE(2)<>"" : Wrseq ','+AOB_TRNCLE(2); Else : Wrseq ',""'; : Endif
   If AOB_TRNCLE(3)<>"" : Wrseq ','+AOB_TRNCLE(3); Else : Wrseq ',""'; : Endif
   If AOB_TRNCLE(4)<>"" : Wrseq ','+AOB_TRNCLE(4); Else : Wrseq ',""'; : Endif
   Wrseq ') From ATEXTRA'
  When "ATX"
   Wrseq " Call TEXTE([F:"+AOB_TRNABR+"]"+AOB_TRNTIT+",TIT) From OBJDIV"
  When Default
   Wrseq " TIT = [F:"+AOB_TRNABR+"]"+AOB_TRNTIT
 Endcase
 Wrseq " Break"
 Wrseq "Next "+AOB_TRNABR
 Wrseq "If OUV : Close Local File ["+AOB_TRNABR+"] : Endif"
 Wrseq "Default [V] , [L] , [S] , [M] , [F]"
 If dim(AOB_TRNLEG)>0 & AOB_TRNLEG<>""
  Wrseq 'If dim([L]OK)>0 & OK<>1 : TIT = "!" : Endif'
 Endif
Endif
Wrseq "End"
Wrseq

Wrseq "$OUVTAB"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "Local File "+ATB_FIC+" ["+ATB_STD+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$OUVVUE"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "Local File WVCPY"+OBJET+" ["+ATB_STD+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$DEFAUT_TAB"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "Default File ["+ATB_STD+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$TRANS_TAB"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "[F:"+ATB_STD+"] = [F:"+ATB_ABR+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$TRANS_FIC"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "[F:"+ATB_ABR+"] = [F:"+ATB_STD+"]"
Endif
Wrseq "Return"
Wrseq

Wrseq "$FERME_TAB"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "If clalev([F:"+ATB_ABR+"])>0 : Close Local File ["+ATB_ABR+"] : Endif"
Endif
Wrseq "Return"
Wrseq

Wrseq "$FERME_FIC"
If ATB_STD<>"" & ATB_STD<>ATB_ABR
 Wrseq "If clalev([F:"+ATB_STD+"])>0 : Close Local File ["+ATB_STD+"] : Endif"
Endif
Wrseq "Return"
Wrseq

Return
