#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM016 Update PJMTSKOPE.OPESTARTDT and PJMTSKOPE.OPEENDDT
#
# Issue X3-28419/122095 - 2017-03-21 by FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM016(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM016(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE

  #-----------------------------------#
  If filinfo(filpath("FIL","PJMTSKOPE","fde",DOSSIER),0)<=0 : End : Endif
  If filinfo(filpath("FIL","PJMTIMEMP","fde",DOSSIER),0)<=0 : End : Endif
  #-----------------------------------#
  Call ECR_TRACE("UTIPJM016: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:PTKO]) = 0 : Local File =DOSSIER + ".PJMTSKOPE"  [PTKO] : Endif
  If clalev([F:PTE]) = 0 : Local File =DOSSIER + ".PJMTIMEMP"  [PTE] : Endif
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [PTKO]
  Filter [PTE] Where [F:PTE]PIMTASCOD <> "" and [F:PTE]OPENUM > 0
  For [PTE]
    Read [PTKO]PTKO0=[F:PTE]OPPNUM;[F:PTE]TASCOD;[F:PTE]OPENUM;[F:PTE]OPESPLNUM
    If !fstat Then
      # -----------------
      IUPDATE = 0
      If [F:PTKO]OPESTARTDT = [0/0/0] or [F:PTKO]OPESTARTDT < [F:PTE]PTEDAT Then
       [F:PTKO]OPESTARTDT = [F:PTE]PTEDAT
       IUPDATE = 1
      Endif
      If [F:PTKO]OPEENDDT = [0/0/0] or [F:PTKO]OPEENDDT < [F:PTE]PTEDAT Then
        [F:PTKO]OPEENDDT = [F:PTE]PTEDAT
        IUPDATE = 1
      Endif
      # -----------------
      If IUPDATE = 1 Then
        COMPTEUR += 1
        Rewrite [PTKO]
        If fstat Then
          Call ECR_TRACE("File PJMTSKOPE" - [F:PTKO]OPPNUM - [F:PTKO]TASCOD - num$([F:PTKO]OPENUM) - num$([F:PTKO]OPESPLNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          NCOUNTERROR += 1
        Endif
      Endif
      # -----------------
    Endif
  Next
  Filter [PTE]
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM016 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM016 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [PTKO]
  Close Local File [PTE]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKOPE") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTIMEMP") : End : Endif
  Call MAJ_UTIPJM016(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTSKOPE") : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"PJMTIMEMP") : End : Endif
  Call MAJ_UTIPJM016(APPLI)
End

