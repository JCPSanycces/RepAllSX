#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion objet ARC
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ARC",GBIDC1,GBIDC2) From GOBJET 
End 

#--------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ANNULE"      : Gosub ANNULE
 When "CHANGE"      : Gosub CHANGE
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "STORE"       : Gosub STORE
 When "CONTROL"     : Gosub CONTROL
 When "PARAM"       : Gosub PARAM
 When "GETURL"      : Gosub GETURL
Endcase
Return

#--------------------------------#
$STORE
$CONTROL
$PARAM
$GETURL
Return

#--------------------------------#
$OUVRE
Local Char FOROLD(250)(1..dim([M:ARC2]FORPAR)) , CODOLD(10)(1..dim([M:ARC2]FORPAR))
Return

#--------------------------------#
$APRES_MODIF
Case zoncou
 When "TYPDOC" : [M]TYPDOC = zc : Gosub CHARGE : Affzo [ARC2]
 When "IDTVOL" : [M]IDTVOL = zc : Gosub CHARGE : Affzo [ARC2]
Endcase
Return

#--------------------------------#
$CHARGE
# Permet de charger un nouveau paramétrage en gardant les anciennes valeurs saisies sur les paramètres
Raz FOROLD , CODOLD
For I=1 To [M:ARC2]NBLIG
 CODOLD(I) = [M:ARC2]CODPAR(I-1)
 FOROLD(I) = [M:ARC2]FORPAR(I-1)
Next I
Gosub CHARGE_PARAM
For I=1 To [M:ARC2]NBLIG
 K = find([M:ARC2]CODPAR(I-1),CODOLD)
 If K
  [M:ARC2]FORPAR(I-1) = FOROLD(K)
 Endif
Next I
Return

#--------------------------------#
$LIENS
Gosub CHARGE_PARAM
For [ARW] Where CODARC=[M:ARC0]CODARC
 I = find([F:ARW]CODPAR,[M:ARC2]CODPAR)
 If I
  [M:ARC2]FORPAR(I-1) = [F:ARW]FORPAR
 Endif
Next ARW
Gosub GRISE_EVT
Gosub GRISE_CLE
Gosub GRISE_JOI
Return

#--------------------------------#
$CHARGE_PARAM
nolign = 0
For [ARE]ARE0 Where TYPDOC=[M:ARC1]TYPDOC & IDTVOL=[M:ARC1]IDTVOL
 nolign += 1
 [M:ARC2] = [F:ARE]
 [M:ARC2]FORPAR(nolign-1) = ""
Next ARE
[M:ARC2]NBLIG = nolign
Return

#--------------------------------#
$GRISE_EVT
Case [M:ARC1]TYPEVT
 When 1 : # Objet
  Effzo [ARC1]RPTEVT , EXPEVT , FCTEVT , OBJLNK , OBJCLE
  Grizo [ARC1]RPTEVT , EXPEVT , FCTEVT , OBJLNK , OBJCLE
  Actzo [ARC1]OBJEVT
 When 2 : # Etat
  Effzo [ARC1]EXPEVT , FCTEVT
  Grizo [ARC1]EXPEVT , FCTEVT
  Actzo [ARC1]OBJEVT , RPTEVT , OBJLNK , OBJCLE
 When 3 : # Export
  Effzo [ARC1]FCTEVT , OBJEVT , RPTEVT
  Grizo [ARC1]FCTEVT , OBJEVT , RPTEVT
  Actzo [ARC1]EXPEVT , OBJLNK , OBJCLE
 When 4,5,6 : # Trace/Excel/Manuel
  Effzo [ARC1]EXPEVT , OBJEVT , RPTEVT
  Grizo [ARC1]EXPEVT , OBJEVT , RPTEVT
  Actzo [ARC1]FCTEVT , OBJLNK , OBJCLE
Endcase 
Return

#--------------------------------#
$GRISE_CLE
If [M:ARC1]OBJLNK=""
 [M:ARC1]OBJCLE = ""
 Affzo [ARC1]OBJCLE
 Grizo [ARC1]OBJCLE
Else
 Actzo [ARC1]OBJCLE
Endif
Return

#--------------------------------#
$GRISE_JOI
If [M:ARC1]TYPEVT=1
 Actzo [ARC1]IDTCNT , IDTSTO , VERSION
 Effzo [ARC1]MOTCLE , CAT , NAM
 Grizo [ARC1]MOTCLE , CAT , NAM
Else
 If [M:ARC1]OBJLNK=""
  Effzo [ARC1]MOTCLE , IDTCNT , IDTSTO , VERSION , CAT , NAM
  Grizo [ARC1]MOTCLE , IDTCNT , IDTSTO , VERSION , CAT , NAM
 Else
  Actzo [ARC1]MOTCLE , IDTCNT , IDTSTO , VERSION , CAT , NAM
 Endif
Endif
Return

#--------------------------------#
$CREATION
Raz [F:ARW]
[F:ARW]CODARC = [M:ARC0]CODARC
For I=1 To [M:ARC2]NBLIG
 [F:ARW]CODPAR = [M:ARC2]CODPAR(I-1)
 [F:ARW]FORPAR = [M:ARC2]FORPAR(I-1)
 Write [ARW]
 If fstat
  GOK=0 : Call RSTA("ARW",[M:ARC0]CODARC-[M:ARC2]FORPAR(I-1)) From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
Call MAJTEXTRA([M:ARC0]INTIT,"ARCHPAR","INTIT",[M:ARC0]CODARC,"") From ATEXTRA
Return

#--------------------------------#
$MODIF
Delete [ARW] Where CODARC=[M:ARC0]CODARC
Gosub CREATION
Return

#-------------#
$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET : # Validation
Endif
Return

#-------------#
$EXEBOUT
Case REP
 When "V" : Call VALIDATION(nomap,[M:ARC0]CODARC,0)
Endcase
Return

#--------------------------------#
$ANNULE
Delete [AXX] Where CODFIC="ARCHPAR" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#--------------------------------#
$CHANGE
Update [AXX] Where CODFIC="ARCHPAR" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ARCHPAR"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#--------------------------------#
$APRES_CRE
$APRES_MOD
Call VALIDATION(nomap,[M:ARC0]CODARC,0)
Return

#--------------------------------#
$SET_PRGSTD
Local Char    PRGSTD(GLONADC) , PRGSPE(GLONADC)
Local Integer OKTRT
PRGSTD = "SUBARC"
PRGSPE = "SPEARC"
Call EXISTE_ADX("","",PRGSPE,OKTRT) From ORDSYS
If !OKTRT
 PRGSPE = ""
Endif
Return

#---------------------#
$SET_PREF
Local Char PREF(5)
PREF = "WMARC"
Return

#------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELPAR" : Gosub SELPAR
Endcase
Return

#--------------------------------#
$SELPAR
Local Char    TIT(50)(0..4) , TEXTE(250)(1..200,1..4) , TEX(250)(1..200)
Local File ARCHPARE [ARE]
NBTEX = 0
FORCE = 1
For [ARE]ARE0 Where TYPDOC=PARAM(1) & IDTVOL=PARAM(2)
 NBTEX += 1
 TEX(NBTEX)     = 'G_'+toupper(ctrans([F:ARE]CODPAR))
 TEXTE(NBTEX,1) = [F:ARE]CODPAR
 Call LECTEXTRA(TEXTE(NBTEX,2),"ARCHPARE","INTPAR",[F:ARE]TYPDOC,[F:ARE]IDTVOL+"~"+[F:ARE]CODPAR) From ATEXTRA
 TEXTE(NBTEX,3) = mess([F:ARE]TYPPAR,33,1)
 TEXTE(NBTEX,4) = 'G_'+toupper(ctrans([F:ARE]CODPAR))
Next ARE
TIT    = mess(49,143,1)-PARAM(1)-PARAM(2) : # Liste des paramètres
TIT(1) = mess(37,100,1)  : # Code
TIT(2) = mess(30,109,1)  : # Intitulé
TIT(3) = mess(165,124,1) : # Type interne
TIT(4) = mess(135,105,1) : # Formule
Return

#------------------------------------------------------------------#
# Pour les patches des transactions
#------------------------------------------------------------------#

Subprog PATCH(APPLI)
Value Char APPLI
Call GENDOS(APPLI)
End

#------------------------------------------------------------------#
# Pg de mise à jour globale
#------------------------------------------------------------------#

Subprog GENDOS(APPLI)
Value Char APPLI
Local File =APPLI+".ARCHPAR"  [ARC]
Local File =APPLI+".ARCHPAR"  [ARC2]
Local File =APPLI+".ARCHPARE" [ARE]
Local File =APPLI+".ARCHPARW" [ARW]
Local File =APPLI+".AOBJET"   [AOB]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".ATABIND"  [ATI]
Local File =APPLI+".ATEXTRA"  [AXX]
For [ARC2]ARC0 Where ENAFLG=2
 Call ECR_TRACE([F:ARC2]CODARC,0) From GESECRAN
 Call VALIDATION(APPLI,[F:ARC2]CODARC,1)
Next ARC2
End

#-----------------------------------------------------------------------------#
Subprog VALIDATION(DOSSIER,CODE,SILENCE)
Value Char DOSSIER , CODE
Value Integer SILENCE
Local Char     FICSRC(GDIMFIC) , IDENT(20)
Local Char     MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Char     CHAINE(250) , MAGIC(80) , NOMPROG(GLONADC) , CLE(30)(1..16)
Local Integer  I , J , K , L , OK
Local Integer  NBPAR , NBCLE

If DOSSIER="" or DOSSIER=nomap
 If clalev([F:ARC])=0 : Local File ARCHPAR  [ARC] : Endif
 If clalev([F:ARE])=0 : Local File ARCHPARE [ARE] : Endif
 If clalev([F:ARE])=0 : Local File ARCHPARW [ARW] : Endif
 If clalev([F:AOB])=0 : Local File AOBJET   [AOB] : Endif
 If clalev([F:ATB])=0 : Local File ATABLE   [ATB] : Endif
 If clalev([F:ATI])=0 : Local File ATABIND  [ATI] : Endif
 If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
Else
 If clalev([F:ARC])=0 : Local File =DOSSIER+".ARCHPAR"  [ARC] : Endif
 If clalev([F:ARE])=0 : Local File =DOSSIER+".ARCHPARE" [ARE] : Endif
 If clalev([F:ARE])=0 : Local File =DOSSIER+".ARCHPARW" [ARW] : Endif
 If clalev([F:AOB])=0 : Local File =DOSSIER+".AOBJET"   [AOB] : Endif
 If clalev([F:ATB])=0 : Local File =DOSSIER+".ATABLE"   [ATB] : Endif
 If clalev([F:ATI])=0 : Local File =DOSSIER+".ATABIND"  [ATI] : Endif
 If clalev([F:AXX])=0 : Local File =DOSSIER+".ATEXTRA"  [AXX] : Endif
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

MAGIC   = mess(77,133,1) : # Superviseur Adonix
IDENT   = "## WM-PATCH ##"
Gosub SET_PREF

NOMPROG = PREF+CODE

If !SILENCE
 Call TEMPON(mess(159,133,1)-NOMPROG) From GESECRAN : # Validation du traitement
Endif

OK = 1
Read [ARC]ARC0=[L]CODE
If fstat
 Call ECR_TRACE([L]CODE-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
 End 
Endif

If OK
 Gosub TRT_DEB
 If OK
  Gosub ETIQ
  Gosub TRT_FIN
 Endif
Endif

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

End

#-------------------------------------------------------#
$TRT_DEB
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
FICSRC = filpath("TRT",NOMPROG,"src",APPLI,"",MACHINE)
Openo FICSRC , 0
Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Wrseq "#"-MAGIC
Wrseq IDENT-mess(40,143,1)-[F:ARC]CODARC-'('+format$("D:",date$)-time$+')' : # Code archivage
Wrseq
Return

#-------------------------------------------------------#
$TRT_FIN
Wrseq
Openo
Call VALID("TRT",NOMPROG,DOSSIER,OK) From VALMSKSUB
Return

#------------------------------------------------------------------------------#
$ETIQ
Wrseq "#-----------------------#"
Wrseq '$DECPAR'
For [ARE] Where TYPDOC=[F:ARC]TYPDOC & IDTVOL=[F:ARC]IDTVOL
 If [F:ARE]CODPAR<>""
  Case [F:ARE]TYPPAR
   When 1       : Wrseq 'Global Char G_'+toupper(ctrans([F:ARE]CODPAR))+'(250)';
   When 4       : Wrseq 'Global Date G_'+toupper(ctrans([F:ARE]CODPAR));
   When Default : Wrseq 'Global Decimal G_'+toupper(ctrans([F:ARE]CODPAR));
  Endcase
  Wrseq ' : #'-func AFNC.TEXTRA("ARCHPARE","INTPAR",[F:ARE]TYPDOC,[F:ARE]IDTVOL+"~"+[F:ARE]CODPAR)
 Endif
Next ARE
Wrseq "Local Char    CODPAR(50)(1..50) , VALPAR(250)(1..50) , VALDAT(30) , FORMULE(250)"
Wrseq "Local Integer ADRPAR(1..50)"
Wrseq "Local Integer NBPAR"
Wrseq 'Return'
Wrseq

Wrseq "#-----------------------#"
Wrseq '$KILPAR'
For [ARE] Where TYPDOC=[F:ARC]TYPDOC & IDTVOL=[F:ARC]IDTVOL
 If [F:ARE]CODPAR<>""
  Wrseq 'Kill G_'+toupper(ctrans([F:ARE]CODPAR))
 Endif
Next ARE
Wrseq 'Return'
Wrseq

Wrseq "#-----------------------#"
Wrseq "$INIPAR"
Wrseq "Raz VALPAR , NBPAR"
NBPAR = 0
For [ARE] Where TYPDOC=[F:ARC]TYPDOC & IDTVOL=[F:ARC]IDTVOL
 If [F:ARE]CODPAR<>""
  NBPAR += 1
  Wrseq 'CODPAR('+num$(NBPAR)+') = "'+[F:ARE]CODPAR+'"'
  Wrseq 'ADRPAR('+num$(NBPAR)+') = '+num$([F:ARE]ADRPAR)-': #'-mess([F:ARE]ADRPAR,34,1)
  Read [ARW]ARW0=[F:ARC]CODARC;[F:ARE]CODPAR
  If fstat : Raz [F:ARW] : Endif
  Wrseq '#'-func AFNC.TEXTRA("ARCHPARE","INTPAR",[F:ARE]TYPDOC,[F:ARE]IDTVOL+"~"+[F:ARE]CODPAR)
  Wrseq 'ERN = 0'
  If instr(1,[F:ARW]FORPAR,'"')
   Wrseq "FORMULE = '"+format$("KTv2:255X",[F:ARW]FORPAR)+"'"
  Else
   Wrseq 'FORMULE = "'+format$("KTv2:255X",[F:ARW]FORPAR)+'"'
  Endif
  If [F:ARE]ADRPAR=1 : # Variable
   Wrseq 'Onerrgo RIEN'
  Else
   Wrseq 'Onerrgo  ER'
  Endif
  CHAINE = [F:ARW]FORPAR
  Case [F:ARE]TYPPAR
   When 1
    If CHAINE="" : CHAINE = '""' : Endif
    Wrseq 'G_'+toupper(ctrans([F:ARE]CODPAR))+' = '+format$("KTv2:250X",CHAINE)
    Wrseq 'VALPAR('+num$(NBPAR)+') = num$(G_'+toupper(ctrans([F:ARE]CODPAR))+')'
   When 4
    If CHAINE="" : CHAINE = '[00/00/0000]' : Endif
    Wrseq 'G_'+toupper(ctrans([F:ARE]CODPAR))+' = '+format$("KTv2:250X",CHAINE)
    Wrseq 'VALPAR('+num$(NBPAR)+') = format$("D:"+GFMDAT4,G_'+toupper(ctrans([F:ARE]CODPAR))+')'
   When Default
    If CHAINE="" : CHAINE = '0' : Endif
    Wrseq 'G_'+toupper(ctrans([F:ARE]CODPAR))+' = '+format$("KTv2:250X",CHAINE)
    Wrseq 'VALPAR('+num$(NBPAR)+') = num$(G_'+toupper(ctrans([F:ARE]CODPAR))+')'
  Endcase
  Wrseq 'Onerrgo'
  Wrseq 'If ERN : OK = 0 : Return : Endif'
 Endif
Next ARE
Wrseq 'NBPAR = '+num$(NBPAR)
Wrseq 'Return'
Wrseq

Wrseq "#-----------------------#"
Wrseq "$MAJPAR"
NBPAR = 0
For [ARE] Where TYPDOC=[F:ARC]TYPDOC & IDTVOL=[F:ARC]IDTVOL
 If [F:ARE]CODPAR<>""
  Read [ARW]ARW0=[F:ARC]CODARC;[F:ARE]CODPAR
  If fstat : Raz [F:ARW] : Endif
  NBPAR += 1
  If [F:ARE]ADRPAR=1 : # Variable
   Wrseq '#'-func AFNC.TEXTRA("ARCHPARE","INTPAR",[F:ARE]TYPDOC,[F:ARE]IDTVOL+"~"+[F:ARE]CODPAR)
   Wrseq 'ERN = 0'
   CHAINE = format$("KTv2:255X",[F:ARW]FORPAR)
   K = ctrans(CHAINE,"/\;,$*+","")<>CHAINE
   K += left$(CHAINE,1)>="a" & left$(CHAINE,1)<="z"
   K += left$(CHAINE,1)>="0" & left$(CHAINE,1)<="9"
   If K
    CHAINE = ""
   Endif
   If instr(1,CHAINE,'"')
    Wrseq "FORMULE = '"+CHAINE+"'"
   Else
    Wrseq 'FORMULE = "'+CHAINE+'"'
   Endif
   Wrseq 'Onerrgo  ER'
   Case [F:ARE]TYPPAR
    When 1
     Wrseq 'If VALPAR('+num$(NBPAR)+')<>"" : G_'+toupper(ctrans([F:ARE]CODPAR))+' = VALPAR('+num$(NBPAR)+') : Endif'
     If CHAINE<>"" 
      Wrseq CHAINE+' = G_'+toupper(ctrans([F:ARE]CODPAR))
     Endif
    When 4
     Wrseq 'Call CHARGE(VALPAR('+num$(NBPAR)+'),"D",0,0,VALDAT) From FMTVAR'
     Wrseq 'G_'+toupper(ctrans([F:ARE]CODPAR))+' = VALDAT'
     If CHAINE<>""
      Wrseq CHAINE+' = G_'+toupper(ctrans([F:ARE]CODPAR))
     Endif
    When Default
     Wrseq 'If VALPAR('+num$(NBPAR)+')<>"" : G_'+toupper(ctrans([F:ARE]CODPAR))+' = val(VALPAR('+num$(NBPAR)+')) : Endif'
     If CHAINE<>""
      Wrseq CHAINE+' = G_'+toupper(ctrans([F:ARE]CODPAR))
     Endif
   Endcase
   Wrseq 'Onerrgo'
   Wrseq 'If ERN : OK = 0 : Return : Endif'
  Endif
 Endif
Next ARE
Wrseq 'Return'
Wrseq

Wrseq "#-----------------------#"
Wrseq "$SETCLE"
Wrseq 'Local Char CLEOBJ(250)'
If [F:ARC]OBJLNK<>""
 If [F:ARC]OBJCLE<>""
  CHAINE = [F:ARC]OBJCLE
  Raz NBCLE
  While CHAINE<>""
   I = instr(1,CHAINE,";")
   NBCLE += 1
   If I
    CLE(NBCLE) = left$(CHAINE,I-1)
    CHAINE = right$(CHAINE,I+1)
   Else
    CLE(NBCLE) = CHAINE
    CHAINE = ""
   Endif
   If NBCLE>1
    Wrseq 'CLEOBJ += "~"+';
   Else
    Wrseq 'CLEOBJ = ';
   Endif
   Wrseq CLE(NBCLE)
  Wend
 Else
  Read [AOB]ABREV=[F:ARC]OBJLNK
  Read [ATB]CODFIC = [F:AOB]NOMFIC
  If !fstat
   Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
   If !fstat
    CHAINE = [F:ATI]DESCRIPT
    Raz NBCLE
    While CHAINE<>""
     I = instr(1,CHAINE,"+")
     J = instr(1,CHAINE,"-")
     If I & J
      I = min(I,J)
     Elsif J & !I
      I = J
     Endif
     NBCLE += 1
     If I
      CLE(NBCLE) = left$(CHAINE,I-1)
      CHAINE = right$(CHAINE,I+1)
     Else
      CLE(NBCLE) = CHAINE
      CHAINE = ""
     Endif
     If NBCLE>1
      Wrseq 'CLEOBJ += "~"+';
     Else
      Wrseq 'CLEOBJ = ';
     Endif
     Wrseq 'num$([F:'+[F:ATB]ABRFIC+']'+CLE(NBCLE)+')'
    Wend
   Endif
  Endif
 Endif
Endif
Wrseq 'Return'
Wrseq

Wrseq '#------------------#'
Wrseq '$ER'
Wrseq 'ERN = errn'
Wrseq 'ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"'
Wrseq 'If FORMULE<>""'
Wrseq ' ERM += mess(65,106,1)-FORMULE : # Erreur en évaluation de la formule'
Wrseq 'Endif'
Wrseq 'Gosub AFF_ERR'
Wrseq 'Resume'
Wrseq 

Wrseq '#------------------#'
Wrseq '$AFF_ERR'
Wrseq 'Call ECR_TRACE(ERM,1) From GESECRAN'
Wrseq 'Return'
Wrseq

Wrseq '#------------------#'
Wrseq '$RIEN'
Wrseq 'Resume'
Wrseq
Return

#----------------------------------------------------------------------------#
$CHARGE_HLP
Local Integer I , J , NBFOR
Local Char    A_AHLP(50) , OBJET(GLONAOB)
Local Char    FEN(GLONFEN)
Raz [M]HLPFOR, NBFOR
FEN = ""
Case [M]TYPEVT
 When 1 : # Objet
  OBJET = [M]OBJEVT
  Gosub SET_FENOBJ
 When 2 : # Report
  FEN = "AIMP1"
 When 3 : # Import/export
  FEN = "OAOE"
 When 4,5,6 : # Trace/Excel/Manuel
  If [M]FCTEVT<>""
   Read [AFC]CODINT = [M]FCTEVT
   If !fstat & [F:AFC]ACTION<>""
    Read [ACT]ACTION=[F:AFC]ACTION
    If !fstat & [F:ACT]PARAM4<>""
     FEN = [F:ACT]PARAM4
    Endif
   Endif
  Endif
Endcase
If FEN<>""
 Read [AWI]AWI0 = FEN
 If fstat : FEN = "" : Endif
Endif
Case [M]TYPEVT
 When 1 : # Objet
  Read [AOB]ABREV = [M]OBJEVT
  If !fstat
   A_HLP = [F:AOB]NOMFIC : Gosub INC_HLP
   Gosub CHARGE_AWI
  Endif
 When 2 : # Report
  If [M]OBJEVT<>""
   Read [AOB]ABREV = [M]OBJEVT
   If !fstat
    A_HLP = [F:AOB]NOMFIC : Gosub INC_HLP
    OBJET = [M]OBJEVT
    Gosub SET_FENOBJ
    Gosub CHARGE_AWI
   Endif
  Endif
  A_HLP = "AREPORT" : Gosub INC_HLP
  Gosub CHARGE_AWI
 When 3 : # Import/export
  Read [AOE]AOE0 = [M]EXPEVT
  If !fstat
   A_HLP = "AOBJEXT" : Gosub INC_HLP
   Gosub CHARGE_AWI
  Endif
 When 4,5,6 : # Trace/Excel/Manuel
  A_HLP = "AFONCTION" : Gosub INC_HLP
  Gosub CHARGE_AWI
Endcase
Return

$INC_HLP
If NBFOR<dim([M]HLPFOR) & !find(A_HLP,[M]HLPFOR(0..NBFOR+1))
 NBFOR += 1
 [M]HLPFOR(NBFOR-1) = A_HLP
Endif
Return

#--------------------------------------------#
$SET_FENOBJ
Filter [AWI] Where OBJ=OBJET
Read [AWI]AWI0 = "O"+OBJET
If !fstat
 FEN = [F:AWI]WIN
Else
 For [AWI]
  FEN = [F:AWI]WIN : Break
 Next AWI
Endif
Filter [AWI]
Return

#--------------------------------------------#
$CHARGE_AWI
If FEN<>""
 If [F:AWI]MSKENT<>""
  Read [AMK]CODMSK = [F:AWI]MSKENT
  If !fstat
   A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]MSKENT : Gosub INC_HLP
  Else
   A_HLP = "[M]"+[F:AWI]MSKENT : Gosub INC_HLP
  Endif   
 Endif
 For I=0 To [F:AWI]NBMSK-1
  If [F:AWI]NOMMSK(I)<>""
   J = 1
   If [F:AWI]ACTMSK(I)<>""
    Read [ACV]CODACT = [F:AWI]ACTMSK(I)
    If fstat | [F:ACV]FLACT<>2
     J = 0
    Endif
   Endif
   If J
    Read [AMK]CODMSK = [F:AWI]NOMMSK(I)
    If !fstat
     A_HLP = "[M:"+[F:AMK]ABRMSK+"]"+[F:AWI]NOMMSK(I)
    Else
     A_HLP = "[M]"+[F:AWI]NOMMSK(I)
    Endif
    Gosub INC_HLP
   Endif
  Endif
 Next I
Endif
Return

#---------------------------------------------------------------------------------------#
Subprog AS_FLDCPY(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
End

Subprog AS_FLDFCY(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
End

Subprog C_TYPEVT(VALEUR)
Variable Integer VALEUR
[M]TYPEVT = VALEUR
Gosub GRISE_EVT
Gosub GRISE_CLE
Gosub GRISE_JOI
End

Subprog C_OBJLNK(VALEUR)
Variable Char    VALEUR()
[M]OBJLNK = VALEUR
Gosub GRISE_CLE
Gosub GRISE_JOI
End

Subprog AS_OBJCLE(VALEUR)
Variable Char    VALEUR()
Gosub CHARGE_HLP
Read [AOB]ABREV = [M]OBJLNK
If !fstat
 A_HLP = [F:AOB]NOMFIC : Gosub INC_HLP
Endif
Raz [M:ARC1]ABRFIL, TABFIL
If [M]OBJLNK<>""
 Read [AOB]ABREV=[M]OBJLNK
 If !fstat & [F:AOB]NOMFIC<>""
  Read [ATB]CODFIC = [F:AOB]NOMFIC
  If !fstat
   [M:ARC1]ABRFIL(0) = [F:ATB]ABRFIC
   [M:ARC1]TABFIL(0) = [F:ATB]CODFIC
  Endif
 Endif
Endif
End

Subprog C_OBJCLE(VALEUR)
Variable Char    VALEUR()
Local    Integer I, J, NBPART , NBPOINT
If VALEUR<>"" & [M]OBJLNK<>""
 Read [AOB]ABREV=[M]OBJLNK
 If !fstat
  Gosub SETCLE From ="WO"+[M]OBJLNK
  NBPART = 1
  If dim([L]CLEVALEUR)>0 : ## GEODE
   For I=0 To dim(CLESUPP)-1
    If CLESUPP(I)<>""
     NBPART += 1
    Endif
   Next I
  Else
   For I=0 To dim(CLESEC)-1
    If CLESEC(I)<>""
     NBPART += 1
    Endif
   Next I
  Endif
  If CLELIG<>""
   NBPART -= 1
  Endif
  NBPOINT = 0
  For I= 1 To len(VALEUR)
   If mid$(VALEUR,I,1)=";"
    NBPOINT += 1
   Endif
  Next I
  If NBPOINT<>NBPART-1
   GMESSAGE = mess(46,9022,1) : # Clé incorrecte
   mkstat = 2
  Endif
 Endif
Endif
End

Subprog C_TYPDOC(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TYPEVT<>1
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 1 : End
Endif
End

Subprog C_FLDFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY<>"" & [M]FLDCPY=""
 GMESSAGE = mess(41,143,1) : # Il faut renseigner soit le champ site soit le champ société
Endif
End

