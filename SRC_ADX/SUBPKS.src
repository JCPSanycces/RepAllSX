#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PKS1

$ACTION
Case ACTION
 When Default
Endcase
Return

#-------------------------------------------------#
# Actions sur les champs de l'écran PKS1        # 
#-------------------------------------------------#

Subprog AP_SSTOFCY(VALEUR)
Variable Char    VALEUR()
If [M:PKS1]SVAL=2
    Actzo [M:PKS1]SINV
Else
    Diszo [M:PKS1]SINV
Endif
End

Subprog AM_SNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" 
   [M:PKS1]SNUMFIN = VALEUR 
   Affzo [M:PKS1]SNUMFIN 
   Endif
End

Subprog AM_SBPCORDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   [M:PKS1]SBPCORDFIN = VALEUR 
   Affzo [M:PKS1]SBPCORDFIN 
   Actzo [M:PKS1]SBPAADDDEB
Else
   Diszo [M:PKS1]SBPAADDDEB
Endif
End

Subprog AM_SBPAADDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" 
   [M:PKS1]SBPAADDFIN = VALEUR 
   Affzo [M:PKS1]SBPAADDFIN
   Endif
End

Subprog AP_SBPCORDFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
   Actzo [M:PKS1]SBPAADDFIN
Else
   Raz [M:PKS1]SBPAADDFIN 
   Diszo [M:PKS1]SBPAADDFIN
Endif
End

Subprog C_SBPAADDFIN(VALEUR)
Variable Char    VALEUR()
If [M:PKS1]SBPCORDDEB = [M:PKS1]SBPCORDFIN 
   If VALEUR  < [M:PKS1]SBPAADDDEB 
      GMESSAGE = mess(44,199,1) 
      mkstat = 2 
   Endif 
Endif 
End

Subprog AM_SNONVAL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:PKS1]SVAL = 1 
   [M:PKS1]SVAL = 2
   Affzo [M:PKS1]SVAL
   Actzo [M:PKS1]SINV
Endif
End

Subprog AM_SVAL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:PKS1]SNONVAL = 1 
   [M:PKS1]SNONVAL = 2
   Affzo [M:PKS1]SNONVAL
Endif
If VALEUR=2
    Actzo [M:PKS1]SINV
Else
    Diszo [M:PKS1]SINV
Endif
End

Subprog AS_SVCRTYP(VALEUR)
Variable Integer VALEUR

Local Integer I
For I=1 To len(mess(0,701,1))
    If !find(I,3,4)
        GMENLOC(I) = 1
    Endif
Next

End

Subprog AP_SVCRTYP(VALEUR)
Variable Integer VALEUR
[M:PKS1]SVCRTYP = VALEUR

If VALEUR = 4 
   [M:PKS1]SCOL      = 1            # prise en compte document colisé
   [M:PKS1]SNONVAL   = 2            # non validé
   [M:PKS1]SVAL      = 1            # validé        
   [M:PKS1]SINV      = 1            # prise en compte livraisos facturées
   [M:PKS1]OBJET   = "SDH"          # livraison
   Actzo  [M:PKS1]20 
   Affzo  [M:PKS1]20 
Else
   [M:PKS1]SCOL      = 1            # prise en compte document colisé
   [M:PKS1]SNONVAL   = 1            # non validé
   [M:PKS1]SVAL      = 1            # validé        
   [M:PKS1]SINV      = 1            # prise en compte livraisos facturées
   [M:PKS1]OBJET   = "PRH"          # preparation
   Grizo  [M:PKS1]SNONVAL           # non validé
   Grizo  [M:PKS1]SVAL              # validé        
   Grizo  [M:PKS1]SINV              # prise en compte livraisos facturées
   Affzo  [M:PKS1]20 
Endif

End

Subprog AM_SRTNUM(VALEUR)
Variable Char    VALEUR()
Read [SRT] SRT0=11;VALEUR

If fstat | [F:SRT]ENAFLG=1 
   End
Endif

[M:PKS1]SRTNUM  = [F:SRT]SRTNUM
[M:PKS1]SRTTYP  = [F:SRT]SRTTYP
GFLAG           = [F:SRT]SRTNUM

Call LECTEXTRA([M:PKS1]DESAXX,"STKTRS","DESAXX",num$([M:PKS1]SRTTYP),[M:PKS1]SRTNUM) From ATEXTRA
Affzo [M:PKS1]DESAXX

If [F:SRT]PKGTYP = 1
    GPKD_BOITE      = "WOPKD"+[F:SRT]SRTNUM
    GPKDNUM         = [F:SRT]SRTNUM
Else
    GPKD_BOITE      = "WOPKP"+[F:SRT]SRTNUM
    GPKPNUM         = [F:SRT]SRTNUM
Endif
GSRTNUM         = GFLAG

End


######################################################################################

