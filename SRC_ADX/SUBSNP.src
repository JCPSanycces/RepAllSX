                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]SERSCR)
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]IDECOD1) > 0
       If [M:SNP2]IDECOD1>1      TZONE(IZON)="PALNUM"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]IDESCR1) > 0
       If [M:SNP2]IDESCR1>1      TZONE(IZON)="PALNUM"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]IDESCR1)
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]IDECOD2) > 0
       If [M:SNP2]IDECOD2>1      TZONE(IZON)="CTRNUM"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]IDESCR2) > 0
       If [M:SNP2]IDESCR2>1      TZONE(IZON)="CTRNUM"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]IDESCR2)
                                 IZON+=1
       Endif
    Endif

    If dim([M:SNP2]WRHCOD) > 0
       If [M:SNP2]WRHCOD>1       TZONE(IZON)="WRH"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]WRHSCR) > 0
       If [M:SNP2]WRHSCR>1       TZONE(IZON)="WRH"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]WRHSCR)
                                 IZON+=1
       Endif
    Endif
#                                                                                         # hcb X3-68147 deb
  If dim([M:SNP2]LPNCOD) > 0
       If [M:SNP2]LPNCOD>1       TZONE(IZON)="LPNNUM"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]LPNSCR) > 0
       If [M:SNP2]LPNSCR>1       TZONE(IZON)="LPNNUM"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]LPNSCR)
                                 IZON+=1
       Endif
    Endif
#                                                                                         # hcb X3-68147 fin


    If [M:SNP2]QTYPCUCOD=1    TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]QTYPCUSCR>1    TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]QTYPCUSCR)
                              IZON+=1
    Endif
    If [M:SNP2]QTYSTUCOD=1    TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]QTYSTUSCR>1    TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]QTYSTUSCR)
                              IZON+=1
    Endif
    If [M:SNP2]ABCCOD=1       TZONE(IZON)="ABC"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]ABCSCR>1       TZONE(IZON)="ABC"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]ABCSCR)
                              IZON+=1
    Endif
   OPT1=2
   Gosub PE_STKTRS
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif

#--- Génération écrans et fenêtre inventaire détail
WNOMOBJ="SNL"
#WACSCOD=[M:SRG0]ACSCOD
#WLIBEL =[M:SRG0]DESAXX
#WENAFLG=[M:SRG0]ENAFLG
WNUM   =2

#---------------- Noms fenêtres et traitement inventaire document ---#
Local Char     WINREF1(GLONFEN) : WINREF1="ISNL1"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WQSNL"+[M:SNP0]SRTNUM+"S"
#-------------------------- 1er écran ---------------------------#
MFROM="SNL1"
MTO="W"+WMODU+[M:SNP0]SRTNUM+"S"
#MTO="WT"+num$([M:SNP0]SRTTYP)+[M:SNP0]SRTNUM+"S"

Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"

    If [M:SNP2]CUNDEVDSY1=1  TZONE(IZON)="QTYSTUDEV"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="PRCDEV"
                             TMOD(IZON) =3
                             IZON+=1

    Endif
    If [M:SNP2]CUNDEVSCR1=1  TZONE(IZON)="QTYSTUDEV"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNDEVSCR1)
                             IZON+=1
                             TZONE(IZON)="PRCDEV"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNDEVSCR1)
                             IZON+=1

    Endif


    If [M:SNP2]CUNAMTDSY1=1  TZONE(IZON)="CUNCST"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CUNAMT"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CUNAMTNEW"
                             TMOD(IZON) =3
                             IZON+=1
    Endif

    If [M:SNP2]CUNAMTSCR1>1   TZONE(IZON)="CUNCST"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR1)
                             IZON+=1
                             TZONE(IZON)="CUNAMT"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR1)
                             IZON+=1
                             TZONE(IZON)="CUNAMTNEW"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR1)
                             IZON+=1
    Endif

    If [M:SNP2]QTYPCUCOD1=1   TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]QTYPCUSCR1>1   TZONE(IZON)="QTYPCU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]QTYPCUSCR1)
                              IZON+=1
    Endif
    If [M:SNP2]QTYSTUCOD1=1   TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]QTYALLCOD1=1   TZONE(IZON)="CUMALLQTY"
                              TMOD(IZON) =3
                              IZON+=1
    Endif
    If [M:SNP2]QTYSTUSCR1>1   TZONE(IZON)="QTYSTU"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]QTYSTUSCR1)
                              IZON+=1
    Endif
    If [M:SNP2]QTYALLSCR1>1   TZONE(IZON)="CUMALLQTY"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]QTYALLSCR1)
                              IZON+=1
    Endif
    If [M:SNP2]DEPRATCOD1>1   TZONE(IZON)="DEPRAT"
                              TMOD(IZON) =[M:SNP2]DEPRATCOD1
                              IZON+=1
    Endif
    If [M:SNP2]DEPRATSCR1>1   TZONE(IZON)="DEPRAT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]DEPRATSCR1)
                              IZON+=1
    Endif
    If [M:SNP2]DEPAMTCOD1>1   TZONE(IZON)="DEPAMT"
                              TMOD(IZON) =[M:SNP2]DEPAMTCOD1
                              IZON+=1
    Endif
    If [M:SNP2]DEPAMTSCR1>1   TZONE(IZON)="DEPAMT"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]DEPAMTSCR1)
                              IZON+=1
    Endif
    If [M:SNP2]OWNERCOD>1   TZONE(IZON)="OWNER"
                              TMOD(IZON) =[M:SNP2]OWNERCOD
                              IZON+=1
    Endif
    If [M:SNP2]OWNERSCR>1   TZONE(IZON)="OWNER"
                              TMOD(IZON) =9
                              TINT(IZON) =num$([M:SNP2]OWNERSCR)
                              IZON+=1
    Endif

Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif


Return

#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV

Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNPURTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:SNP0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour réception si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
#  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
  I=find("SNP2",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:SNP0]ACSCOD
  [F:AWI]LIBEL     = [M:SNP0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:SNP0]SRTNUM


  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN

Return

#-----------------------------------------------------------------#
# Modification des écrans de base si sections d'entête invisibles #
#-----------------------------------------------------------------#
$MODIF_ECRAN
Return


#---------------------------------------#
# Restauration de l'écran de base  #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return

$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(10)(5)
Local Char WABR(06)(5)
#
Raz WMSK, WABR
Call TEXTFIC("PURTRS","PTRNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("PURTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:SNP0]SRTNUM-[M:SNP0]DESAXX-WINT(1)+" : "+[M:SNP0]ACSCOD
WMSK(0) = "SNP0"
WMSK(1) = "SNP1"
WMSK(2) = "SNP2"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return


