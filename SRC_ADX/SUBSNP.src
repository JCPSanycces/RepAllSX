Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"

# inventaire document


    If [M:SNP1]MVTDESCOD>1   TZONE(IZON)="MVTDES"                  : # Dessignation mvt
                             TMOD(IZON) =[M:SNP1]MVTDESCOD
                             IZON+=1
    Endif
    If [M:SNP1]IPTDATCOD>1   TZONE(IZON)="IPTDAT"                  : # Date imputation
                             TMOD(IZON) =[M:SNP1]IPTDATCOD
                             IZON+=1
                             TZONE(IZON)="CREDAT"                  : # Date création
                             TMOD(IZON) =[M:SNP1]IPTDATCOD
                             IZON+=1
    Endif
#                                                                                         # hcb 71659 deb
    If [M:SNP1]CTGUSRFLG>1   TZONE(IZON)="CTGUSR"                  : # Inventoriste
                             TMOD(IZON) =[M:SNP1]CTGUSRFLG
                             IZON+=1
                             TZONE(IZON)="CTGUSR1"                 : # Inventoriste 1
                             TMOD(IZON) =[M:SNP1]CTGUSRFLG
                             IZON+=1
                             TZONE(IZON)="CTGUSR2"                 : # Inventoriste 2
                             TMOD(IZON) =[M:SNP1]CTGUSRFLG
                             IZON+=1
    Endif
#                                                                                         # hcb 71659 fin

    If [M:SNP2]CUNDEVDSY=1   TZONE(IZON)="QTYSTUDEV"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="PRCDEV"
                             TMOD(IZON) =3
                             IZON+=1
    Endif
    If [M:SNP2]CUNDEVSCR>1   TZONE(IZON)="QTYSTUDEV"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNDEVSCR)
                             IZON+=1
                             TZONE(IZON)="PRCDEV"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNDEVSCR)
                             IZON+=1

    Endif


    If [M:SNP2]CUNAMTDSY=1   TZONE(IZON)="CUNCST"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CUNAMT"
                             TMOD(IZON) =3
                             IZON+=1
                             TZONE(IZON)="CUNAMTNEW"
                             TMOD(IZON) =3
                             IZON+=1
    Endif
    If [M:SNP2]CUNAMTSCR>1   TZONE(IZON)="CUNCST"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR)
                             IZON+=1
                             TZONE(IZON)="CUNAMT"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR)
                             IZON+=1
                             TZONE(IZON)="CUNAMTNEW"
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:SNP2]CUNAMTSCR)
                             IZON+=1
    Endif

    If dim([M:SNP2]LOCCOD) > 0
       If [M:SNP2]LOCCOD>1       TZONE(IZON)="LOC"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]LOCSCR) > 0
       If [M:SNP2]LOCSCR>1       TZONE(IZON)="LOC"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]LOCSCR)
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]LOTCOD) > 0
       If [M:SNP2]LOTCOD>1       TZONE(IZON)="LOT"
                                 TMOD(IZON) =3
                                IZON+=1
       Endif
    Endif
    If dim([M:SNP2]LOTSCR) > 0
       If [M:SNP2]LOTSCR>1       TZONE(IZON)="LOT"
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:SNP2]LOTSCR)
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]SLOCOD) > 0
       If [M:SNP2]SLOCOD>1       TZONE(IZON)="SLO"
                                 TMOD(IZON) =3
                                 IZON+=1
       Endif
    Endif
    If dim([M:SNP2]SLOSCR) > 0
