#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion objet SNP
#######################################################################
# SUBSNP : Transactions inventaire                                    #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Génération de 1 écrans de saisie à partir                           #
#                 de l ecran SNL0  pour inventaire "document"         #
#                 de l ecran SNL1  pour inventaire "détail"           #
#                                                                     #
# Nom des écrans générés : WTxyyyz                                    #
#                            x = 6 pour inventaire                    #
#                                                                     #
#                          yyy = nom de la transaction (STRNUM)       #
#                                                                     #
#                            z = numéro d'ordre de l'écran            #
#                                1 pour inventaire "document"         #
#                                S pour inventaire "détail"           #
#######################################################################
Call OBJET("SNP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=6
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:SNP0]SRTTYP = 6
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "AV_IMPRIME"  : Gosub COP_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"       : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return


$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char APPLI    : APPLI=nomap
Local Char WMODU(3) : WMODU="T"
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WNUM
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#---------------------------------------------------#
# traiter les transactions de type inventaires      #
#---------------------------------------------------#
$FILTRE
FILTSUP="SRTTYP=6"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case REP
  When "1" : Call DEBTRANS From GLOCK
             Trbegin ADOVAL
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
  When Default
Endcase
Return

$LIENS

#-- Positionnement des valeurs si non renseignées
#** Onglet entete
If [M:SNP0]ENAFLG     =0  [M:SNP0]ENAFLG   =2   : Endif
If [M:SNP1]MVTDESCOD  =0  [M:SNP1]MVTDESCOD=3   : Endif
If [M:SNP1]IPTDATCOD  =0  [M:SNP1]IPTDATCOD=3   : Endif
If [M:SNP1]CTGUSRFLG  =0  [M:SNP1]CTGUSRFLG=3   : Endif                                   # hcb 71659

[M:SNP2]SERCOD1    = 2

#** Onglet rubriques "inventaire document"
If [M:SNP2]CUNDEVDSY  =0  [M:SNP2]CUNDEVDSY  =2   : Endif :
If [M:SNP2]CUNDEVSCR  =0  [M:SNP2]CUNDEVSCR  =1   : Endif :
If [M:SNP2]CUNAMTDSY  =0  [M:SNP2]CUNAMTDSY  =2   : Endif :
If [M:SNP2]CUNAMTSCR  =0  [M:SNP2]CUNAMTSCR  =1   : Endif :
If [M:SNP2]CTRALLRGP  =0  [M:SNP2]CTRALLRGP  =2   : Endif :
If dim([M:SNP2]LOCCOD) > 0
   If [M:SNP2]LOCCOD     =0  [M:SNP2]LOCCOD     =1   : Endif :
Endif
If dim([M:SNP2]LOCSCR) > 0
   If [M:SNP2]LOCSCR     =0  [M:SNP2]LOCSCR     =1   : Endif :
Endif
If dim([M:SNP2]SLOCOD) > 0
   If [M:SNP2]SLOCOD     =0  [M:SNP2]SLOCOD     =1   : Endif :
Endif
If dim([M:SNP2]SLOSCR) > 0
   If [M:SNP2]SLOSCR     =0  [M:SNP2]SLOSCR     =1   : Endif :
Endif

If dim([M:SNP2]IDECOD1) > 0
   If [M:SNP2]IDECOD1     =0  [M:SNP2]IDECOD1     =1   : Endif :
Endif
If dim([M:SNP2]IDESCR1) > 0
   If [M:SNP2]IDESCR1     =0  [M:SNP2]IDESCR1     =1   : Endif :
Endif
If dim([M:SNP2]IDECOD2) > 0
   If [M:SNP2]IDECOD2     =0  [M:SNP2]IDECOD2     =1   : Endif :
Endif
If dim([M:SNP2]IDESCR2) > 0
   If [M:SNP2]IDESCR2     =0  [M:SNP2]IDESCR2     =1   : Endif :
Endif
If dim([M:SNP2]SERCOD) > 0
   If [M:SNP2]SERCOD     =0  [M:SNP2]SERCOD       =2   : Endif :
Endif
If dim([M:SNP2]SERSCR) > 0
   If [M:SNP2]SERSCR     =0  [M:SNP2]SERSCR       =1   : Endif :
Endif
If dim([M:SNP2]WRHCOD) > 0
   If [M:SNP2]WRHCOD     =0  [M:SNP2]WRHCOD       =2   : Endif :
Endif
If dim([M:SNP2]WRHSCR) > 0
   If [M:SNP2]WRHSCR     =0  [M:SNP2]WRHSCR       =1   : Endif :
Endif
If dim([M:SNP2]LPNCOD) > 0                                                           # hcb X3-68147
   If [M:SNP2]LPNCOD     =0  [M:SNP2]LPNCOD       =1   : Endif :
Endif
If [M:SNP2]ITMDES1COD =0  [M:SNP2]ITMDES1COD =2   : Endif :
If [M:SNP2]STACOD     =0  [M:SNP2]STACOD     =1   : Endif :
If [M:SNP2]STASCR     =0  [M:SNP2]STASCR     =1   : Endif :
If [M:SNP2]QTYPCUCOD  =0  [M:SNP2]QTYPCUCOD  =1   : Endif :
If [M:SNP2]QTYSTUCOD  =0  [M:SNP2]QTYSTUCOD  =1   : Endif :
If [M:SNP2]QTYSTUSCR  =0  [M:SNP2]QTYSTUSCR  =1   : Endif :
If [M:SNP2]ABCCOD     =0  [M:SNP2]ABCCOD     =1   : Endif :
If [M:SNP2]ABCSCR     =0  [M:SNP2]ABCSCR     =1   : Endif :

#** Onglet rubriques "inventaire détail"
If [M:SNP2]QTYPCUCOD1 =0  [M:SNP2]QTYPCUCOD1 =1   : Endif :
If [M:SNP2]QTYSTUCOD1 =0  [M:SNP2]QTYSTUCOD1 =1   : Endif :
If [M:SNP2]QTYSTUSCR1 =0  [M:SNP2]QTYSTUSCR1 =1   : Endif :
If [M:SNP2]QTYALLCOD1 =0  [M:SNP2]QTYALLCOD1 =1   : Endif :
If [M:SNP2]QTYALLSCR1 =0  [M:SNP2]QTYALLSCR1 =1   : Endif :
If [M:SNP2]DEPRATCOD1 =0  [M:SNP2]DEPRATCOD1 =1   : Endif :
If [M:SNP2]DEPRATSCR1 =0  [M:SNP2]DEPRATSCR1 =1   : Endif :
If [M:SNP2]DEPAMTCOD1 =0  [M:SNP2]DEPAMTCOD1 =1   : Endif :
If [M:SNP2]DEPAMTSCR1 =0  [M:SNP2]DEPAMTSCR1 =1   : Endif :
If [M:SNP2]CUNDEVDSY1  =0  [M:SNP2]CUNDEVDSY1  =2   : Endif :
If [M:SNP2]CUNDEVSCR1  =0  [M:SNP2]CUNDEVSCR1  =1   : Endif :
If [M:SNP2]CUNAMTDSY1  =0  [M:SNP2]CUNAMTDSY1  =2   : Endif :
If [M:SNP2]CUNAMTSCR1  =0  [M:SNP2]CUNAMTSCR1  =1   : Endif :
If [M:SNP2]OWNERCOD    =0  [M:SNP2]OWNERCOD    =3   : Endif :
If [M:SNP2]OWNERSCR    =0  [M:SNP2]OWNERSCR    =1   : Endif :

#** Onglet rubriques "lot"
If [M:SNP2]SRUB1FLG   =0  [M:SNP2]SRUB1FLG   =1   : Endif :
If [M:SNP2]SRUB2FLG   =0  [M:SNP2]SRUB2FLG   =1   : Endif :
If [M:SNP2]SRUB3FLG   =0  [M:SNP2]SRUB3FLG   =1   : Endif :
If [M:SNP2]SRUB4FLG   =0  [M:SNP2]SRUB4FLG   =1   : Endif :


#-- Grisage des zones si besoin
#** Onglet rubriques "inventaire détail"
If dim([M:SNP2]LOCCOD) > 0
   If [M:SNP2]LOCCOD     =2  Grizo [SNP2]LOCSCR     Else Actzo [SNP2]LOCSCR     : Endif
Endif
If dim([M:SNP2]LOTCOD) > 0
   If [M:SNP2]LOTCOD     =2  Grizo [SNP2]LOTSCR     Else Actzo [SNP2]LOTSCR     : Endif
Endif
If dim([M:SNP2]SLOCOD) > 0
   If [M:SNP2]SLOCOD     =2  Grizo [SNP2]SLOSCR     Else Actzo [SNP2]SLOSCR     : Endif
Endif
If [M:SNP2]STACOD     =2  Grizo [SNP2]STASCR     Else Actzo [SNP2]STASCR     : Endif
If dim([M:SNP2]SERCOD) > 0
   If [M:SNP2]SERCOD     =2  Grizo [SNP2]SERSCR     Else Actzo [SNP2]SERSCR     : Endif
Endif
If dim([M:SNP2]IDECOD1) > 0
   If [M:SNP2]IDECOD1     =2  Grizo [SNP2]IDESCR1     Else Actzo [SNP2]IDESCR1     : Endif
Endif
If dim([M:SNP2]IDECOD2) > 0
   If [M:SNP2]IDECOD2     =2  Grizo [SNP2]IDESCR2     Else Actzo [SNP2]IDESCR2     : Endif
Endif
If dim([M:SNP2]WRHCOD) > 0
   If [M:SNP2]WRHCOD     =2  Grizo [SNP2]WRHSCR     Else Actzo [SNP2]WRHSCR     : Endif
Endif
If dim([M:SNP2]LPNCOD) > 0                                                                     # hcb x3-68147
   If [M:SNP2]LPNCOD     =2  Grizo [SNP2]LPNSCR     Else Actzo [SNP2]LPNSCR     : Endif
Endif
If [M:SNP2]CUNDEVDSY  =1  Grizo [SNP2]CUNDEVSCR  Else Actzo [SNP2]CUNDEVSCR  : Endif
If [M:SNP2]CUNAMTDSY  =1  Grizo [SNP2]CUNAMTSCR  Else Actzo [SNP2]CUNAMTSCR  : Endif
If [M:SNP2]QTYPCUCOD  =1  Grizo [SNP2]QTYPCUSCR  Else Actzo [SNP2]QTYPCUSCR  : Endif
If [M:SNP2]QTYSTUCOD  =1  Grizo [SNP2]QTYSTUSCR  Else Actzo [SNP2]QTYSTUSCR  : Endif
If [M:SNP2]ABCCOD     =1  Grizo [SNP2]ABCSCR     Else Actzo [SNP2]ABCSCR     : Endif

#** Onglet rubriques "inventaire détail"
If [M:SNP2]QTYPCUCOD1  =1  Grizo [SNP2]QTYPCUSCR1  Else Actzo [SNP2]QTYPCUSCR1  : Endif
If [M:SNP2]QTYSTUCOD1  =1  Grizo [SNP2]QTYSTUSCR1  Else Actzo [SNP2]QTYSTUSCR1  : Endif
If [M:SNP2]QTYALLCOD1  =1  Grizo [SNP2]QTYALLSCR1  Else Actzo [SNP2]QTYALLSCR1  : Endif
If [M:SNP2]DEPRATCOD1  =3  Grizo [SNP2]DEPRATSCR1  Else Actzo [SNP2]DEPRATSCR1  : Endif
If [M:SNP2]DEPAMTCOD1  =3  Grizo [SNP2]DEPAMTSCR1  Else Actzo [SNP2]DEPAMTSCR1  : Endif
If [M:SNP2]OWNERCOD    =3  Grizo [SNP2]OWNERSCR    Else Actzo [SNP2]OWNERSCR    : Endif
If [M:SNP2]CUNDEVDSY1  =1  Grizo [SNP2]CUNDEVSCR1  Else Actzo [SNP2]CUNDEVSCR1  : Endif
If [M:SNP2]CUNAMTDSY1  =1  Grizo [SNP2]CUNAMTSCR1  Else Actzo [SNP2]CUNAMTSCR1  : Endif


WMODU +=format$("N0:2",[M:SNP0]SRTTYP)

Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
#** Onglet entete
[M:SNP0]SRTTYP    =6
[M:SNP0]ENAFLG    =2
[M:SNP1]MVTDESCOD =2
[M:SNP1]IPTDATCOD =3
[M:SNP1]CTGUSRFLG =3                                                                      # hcb 71659


#** Onglet rubriques "inventaire document"
[M:SNP2]CUNDEVDSY  =2
[M:SNP2]CUNAMTDSY  =2
[M:SNP2]CTRALLRGP  =2
If dim([M:SNP2]LOCCOD) > 0
   [M:SNP2]LOCCOD     =1
Endif
If dim([M:SNP2]LOCSCR) > 0
   [M:SNP2]LOCSCR     =1
Endif
If dim([M:SNP2]SLOCOD) > 0
   [M:SNP2]SLOCOD     =1
Endif
If dim([M:SNP2]SLOSCR) > 0
   [M:SNP2]SLOSCR     =1
Endif
If dim([M:SNP2]IDECOD1) > 0
   [M:SNP2]IDECOD1     =1
Endif
If dim([M:SNP2]IDESCR1) > 0
   [M:SNP2]IDESCR1     =1
Endif
If dim([M:SNP2]IDECOD2) > 0
   [M:SNP2]IDECOD2     =1
Endif
If dim([M:SNP2]IDESCR2) > 0
   [M:SNP2]IDESCR2     =1
Endif
If dim([M:SNP2]WRHCOD) > 0
   [M:SNP2]WRHCOD     =1
Endif
If dim([M:SNP2]LPNCOD) > 0                  # hcb x3-68147
   [M:SNP2]LPNCOD     =1
Endif
[M:SNP2]ITMDES1COD =2
[M:SNP2]STACOD     =1
[M:SNP2]STASCR     =1
[M:SNP2]QTYPCUCOD  =2
[M:SNP2]QTYSTUCOD  =2
[M:SNP2]QTYSTUSCR  =1
[M:SNP2]ABCCOD     =2
[M:SNP2]ABCSCR     =1

#** Onglet rubriques "inventaire détail"
[M:SNP2]SERCOD1    = 2
#[M:SNP2]SERSCR1   = 1
[M:SNP2]CUNDEVDSY1  =2
[M:SNP2]CUNAMTDSY1  =2

[M:SNP2]QTYPCUCOD1 =2
[M:SNP2]QTYSTUCOD1 =2
[M:SNP2]QTYALLCOD1 =2
[M:SNP2]LODCOD1    =2
[M:SNP2]QTYSTUSCR1 =1
[M:SNP2]QTYALLSCR1 =1
[M:SNP2]DEPRATCOD1 =1
[M:SNP2]DEPRATSCR1 =1
[M:SNP2]DEPAMTCOD1 =1
[M:SNP2]DEPAMTSCR1 =1
[M:SNP2]OWNERCOD   =3
[M:SNP2]OWNERSCR   =1

#** Onglet rubriques "lot"
[M:SNP2]SRUB1FLG   =1
[M:SNP2]SRUB2FLG   =1
[M:SNP2]SRUB3FLG   =1
[M:SNP2]SRUB4FLG   =1



Actzo [SNP0]
Actzo [SNP1]
Actzo [SNP2]

#-- Grisage des zones si besoin
#** Onglet rubriques "inventaire détail"
If dim([M:SNP2]LOCCOD) > 0
   If [M:SNP2]LOCCOD     =2  Grizo [SNP2]LOCSCR     Else Actzo [SNP2]LOCSCR     : Endif
Endif
If dim([M:SNP2]LOTCOD) > 0
   If [M:SNP2]LOTCOD     =2  Grizo [SNP2]LOTSCR     Else Actzo [SNP2]LOTSCR     : Endif
Endif
If dim([M:SNP2]SLOCOD) > 0
   If [M:SNP2]SLOCOD     =2  Grizo [SNP2]SLOSCR     Else Actzo [SNP2]SLOSCR     : Endif
Endif
If dim([M:SNP2]IDECOD1) > 0
   If [M:SNP2]IDECOD1    =2  Grizo [SNP2]IDESCR1    Else Actzo [SNP2]IDESCR1    : Endif
Endif
If dim([M:SNP2]IDECOD2) > 0
   If [M:SNP2]IDECOD2    =2  Grizo [SNP2]IDESCR2    Else Actzo [SNP2]IDESCR2    : Endif
Endif
If [M:SNP2]STACOD     =2  Grizo [SNP2]STASCR     Else Actzo [SNP2]STASCR     : Endif
If dim([M:SNP2]SERCOD) > 0
   If [M:SNP2]SERCOD     =2  Grizo [SNP2]SERSCR     Else Actzo [SNP2]SERSCR     : Endif
Endif
If dim([M:SNP2]WRHCOD) > 0
   If [M:SNP2]WRHCOD     =2  Grizo [SNP2]WRHSCR     Else Actzo [SNP2]WRHSCR     : Endif
Endif
If dim([M:SNP2]LPNCOD) > 0                                                                 # hcb X3-68147
   If [M:SNP2]LPNCOD     =2  Grizo [SNP2]LPNSCR     Else Actzo [SNP2]LPNSCR     : Endif
Endif
If [M:SNP2]QTYPCUCOD  =1  Grizo [SNP2]QTYPCUSCR  Else Actzo [SNP2]QTYPCUSCR  : Endif
If [M:SNP2]QTYSTUCOD  =1  Grizo [SNP2]QTYSTUSCR  Else Actzo [SNP2]QTYSTUSCR  : Endif
If [M:SNP2]ABCCOD     =1  Grizo [SNP2]ABCSCR     Else Actzo [SNP2]ABCSCR     : Endif
If [M:SNP2]CUNDEVDSY  =1  Grizo [SNP2]CUNDEVSCR  Else Actzo [SNP2]CUNDEVSCR  : Endif
If [M:SNP2]CUNAMTDSY  =1  Grizo [SNP2]CUNAMTSCR  Else Actzo [SNP2]CUNAMTSCR  : Endif

#** Onglet rubriques "inventaire détail"
If [M:SNP2]QTYPCUCOD1 =1  Grizo [SNP2]QTYPCUSCR1 Else Actzo [SNP2]QTYPCUSCR1 : Endif
If [M:SNP2]QTYSTUCOD1 =1  Grizo [SNP2]QTYSTUSCR1 Else Actzo [SNP2]QTYSTUSCR1 : Endif
If [M:SNP2]QTYALLCOD1 =1  Grizo [SNP2]QTYALLSCR1 Else Actzo [SNP2]QTYALLSCR1 : Endif
If [M:SNP2]DEPRATCOD1 =3  Grizo [SNP2]DEPRATSCR1 Else Actzo [SNP2]DEPRATSCR1 : Endif
If [M:SNP2]DEPAMTCOD1 =3  Grizo [SNP2]DEPAMTSCR1 Else Actzo [SNP2]DEPAMTSCR1 : Endif
If [M:SNP2]OWNERCOD   =3  Grizo [SNP2]OWNERSCR   Else Actzo [SNP2]OWNERSCR   : Endif
If [M:SNP2]CUNDEVDSY1 =1  Grizo [SNP2]CUNDEVSCR1 Else Actzo [SNP2]CUNDEVSCR1 : Endif
If [M:SNP2]CUNAMTDSY1 =1  Grizo [SNP2]CUNAMTSCR1 Else Actzo [SNP2]CUNAMTSCR1 : Endif


WMODU +=format$("N0:2",[M:SNP0]SRTTYP)

Gosub PE_STKTRS
Affzo [SNP0]1-99
Affzo [SNP1]1-99
Affzo [SNP2]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When "LOCCOD"
       If val(CZ)=2
         [M:SNP2]LOCSCR=1
         If !GIMPORT Affzo [SNP2]LOCSCR : Grizo [SNP2]LOCSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]LOCSCR
       Endif
When "LOTCOD"
       If val(CZ)=2
         [M:SNP2]LOTSCR=1
         If !GIMPORT Affzo [SNP2]LOTSCR : Grizo [SNP2]LOTSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]LOTSCR
       Endif
When "SLOCOD"
       If val(CZ)=2
         [M:SNP2]SLOSCR=1
         If !GIMPORT Affzo [SNP2]SLOSCR : Grizo [SNP2]SLOSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]SLOSCR
       Endif
When "STACOD"
       If val(CZ)=2
         [M:SNP2]STASCR=1
         If !GIMPORT Affzo [SNP2]STASCR : Grizo [SNP2]STASCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]STASCR
       Endif
When "SERCOD"
       If val(CZ)=2
         [M:SNP2]SERSCR=1
         If !GIMPORT Affzo [SNP2]SERSCR : Grizo [SNP2]SERSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]SERSCR
       Endif
When "IDECOD1"
       If val(CZ)=2
         [M:SNP2]IDESCR1=1
         If !GIMPORT Affzo [SNP2]IDESCR1 : Grizo [SNP2]IDESCR1   : Endif
       Elsif !GIMPORT
         Actzo [SNP2]IDESCR1
       Endif
When "IDECOD2"
       If val(CZ)=2
         [M:SNP2]IDESCR2=1
         If !GIMPORT Affzo [SNP2]IDESCR2 : Grizo [SNP2]IDESCR2   : Endif
       Elsif !GIMPORT
         Actzo [SNP2]IDESCR2
       Endif
When "WRHCOD"
       If val(CZ)=2
         [M:SNP2]WRHSCR=1
         If !GIMPORT Affzo [SNP2]WRHSCR : Grizo [SNP2]WRHSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]WRHSCR
       Endif
 When "LPNCOD"                                                                         # hcb X3-68147
       If val(CZ)=2
         [M:SNP2]LPNSCR=1
         If !GIMPORT Affzo [SNP2]LPNSCR : Grizo [SNP2]LPNSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]LPNSCR
       Endif
When "CUNDEVDSY"
       If val(CZ)=1
         [M:SNP2]CUNDEVSCR=1
         If !GIMPORT Affzo [SNP2]CUNDEVSCR : Grizo [SNP2]CUNDEVSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]CUNDEVSCR
       Endif
When "CUNAMTDSY"
       If val(CZ)=1
         [M:SNP2]CUNAMTSCR=1
         If !GIMPORT Affzo [SNP2]CUNAMTSCR : Grizo [SNP2]CUNAMTSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]CUNAMTSCR
       Endif
When "QTYPCUCOD"
       If val(CZ)=1
         [M:SNP2]QTYPCUSCR=1
         If !GIMPORT Affzo [SNP2]QTYPCUSCR : Grizo [SNP2]QTYPCUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]QTYPCUSCR
       Endif
When "QTYSTUCOD"
       If val(CZ)=1
         [M:SNP2]QTYSTUSCR=1
         If !GIMPORT Affzo [SNP2]QTYSTUSCR : Grizo [SNP2]QTYSTUSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]QTYSTUSCR
       Endif
When "ABCCOD"
       If val(CZ)=1
         [M:SNP2]ABCSCR=1
         If !GIMPORT Affzo [SNP2]ABCSCR : Grizo [SNP2]ABCSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]ABCSCR
       Endif


When "CUNDEVDSY1"
       If val(CZ)=1
         [M:SNP2]CUNDEVSCR1=1
         If !GIMPORT Affzo [SNP2]CUNDEVSCR1 : Grizo [SNP2]CUNDEVSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]CUNDEVSCR1
       Endif
When "CUNAMTDSY1"
       If val(CZ)=1
         [M:SNP2]CUNAMTSCR1=1
         If !GIMPORT Affzo [SNP2]CUNAMTSCR1 : Grizo [SNP2]CUNAMTSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]CUNAMTSCR1
       Endif

When "QTYPCUCOD1"
       If val(CZ)=1
         [M:SNP2]QTYPCUSCR1=1
         If !GIMPORT Affzo [SNP2]QTYPCUSCR1 : Grizo [SNP2]QTYPCUSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]QTYPCUSCR1
       Endif
When "QTYSTUCOD1"
       If val(CZ)=1
         [M:SNP2]QTYSTUSCR1=1
         If !GIMPORT Affzo [SNP2]QTYSTUSCR1 : Grizo [SNP2]QTYSTUSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]QTYSTUSCR1
       Endif
When "QTYALLCOD1"
       If val(CZ)=1
         [M:SNP2]QTYALLSCR1=1
         If !GIMPORT Affzo [SNP2]QTYALLSCR1 : Grizo [SNP2]QTYALLSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]QTYALLSCR1
       Endif

When "DEPRATCOD1"
       If val(CZ)=3
         [M:SNP2]DEPRATSCR1=1
         If !GIMPORT Affzo [SNP2]DEPRATSCR1 : Grizo [SNP2]DEPRATSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]DEPRATSCR1
       Endif
When "DEPAMTCOD1"
       If val(CZ)=3
         [M:SNP2]DEPAMTSCR1=1
         If !GIMPORT Affzo [SNP2]DEPAMTSCR1 : Grizo [SNP2]DEPAMTSCR1     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]DEPAMTSCR1
       Endif
When "OWNERCOD"
       If val(CZ)=3
         [M:SNP2]OWNERSCR=1
         If !GIMPORT Affzo [SNP2]OWNERSCR : Grizo [SNP2]OWNERSCR     : Endif
       Elsif !GIMPORT
         Actzo [SNP2]OWNERSCR
       Endif

When Default
      Gosub PE_STKTRS
Endcase
Return

