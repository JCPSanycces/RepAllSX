#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:03"
A_USER  = "DOC"
A_STAMP = "20181109230603"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRLIG"
  If [M]NBRLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask POT4 [POT4]
Gosub HORODAT
Local Inpbox "POT4" From GFONCTION At A_STAMP With A_WINDPREV Mask [POT4] As [SIM_]
Grizo [POT4]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POT4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=80 : Y1(0)=1 : Y2(0)=24
Return

$ON_NBRLIG
Onevent BEFORE_INPUT Call AS_NBRLIG From W1POT4
Return

Subprog IB_NBRLIG
Local Decimal BASPAG
## Action STD
Call IB_NBRLIG From SUBPOT
Gosub _AFF
End

Subprog AS_NBRLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45131,GBOUT1) From OBJDIV
Call TEXTE(15622,GBOUT2) From OBJDIV
Call TEXTE(47675,GBOUT3) From OBJDIV
Call IB_NBRLIG
Onkey 129 Titled GBOUT1 Call B1_NBRLIG From W1POT4
Onkey 130 Titled GBOUT2 Call B2_NBRLIG From W1POT4
Onkey 131 Titled GBOUT3 Call B3_NBRLIG From W1POT4
Gosub _AFF
End

Subprog B1_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]CODSCA(nolign-1),"HRSCA","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CPC(nolign-1),"CPC","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBRLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBRLIG From SUBPOT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CPC
Onevent CONTROL Call C_CPC(zc) From W1POT4
Onevent AFTER_CHANGE Gosub AMM_CPC From W1POT4
Onevent BEFORE_INPUT Call AS_CPC(zc) From W1POT4
Return

Subprog AS_CPC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(22067,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CPC(zc) From W1POT4
Onkey   2 Titled GBOUTS Call S_CPC(zc) From W1POT4
Onkey 144 Titled GBOUTP Call P_CPC(zc) From W1POT4
Onkey 146 Titled GBOUTA Call SA_CPC(zc) From W1POT4
Gosub _AFF
End

Subprog C_CPC(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
If !mkstat
 ## Action STD
 Call C_CPC(VALEUR) From SUBPOT
 If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CPC
Call AM_CPC(zc)
If !mkstat & GOBJET
 zoncou = "CPC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CPC(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CPC(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZCPC)")>indice
 [M]CPC(indice) = VALEUR
 Affzo ZCPC(indice)
Endif
Gosub _AFF
End

Subprog S_CPC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCPCLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCPCLEG"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCPCLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CPC(VALEUR)
Variable Char    VALEUR()
Call OBJET("CPC",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CPC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CPC"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CPC(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CPC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCPC
Onevent BEFORE_AREA Gosub AV_ZCPC From W1POT4
Return

$AV_ZCPC
Call LECTEXTRA(zc,"COMPETENCE","DES",num$([M]CPC(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_NIV
Onevent CONTROL Call C_NIV(zc) From W1POT4
Onevent BEFORE_INPUT Call AS_NIV(zc) From W1POT4
Onevent AFTER_CHANGE Gosub AMM_NIV From W1POT4
Return

Subprog AS_NIV(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_NIV(VALEUR) From SUBPOT
If mkstat=2
 [M]NIV(INDIC) = VALEUR
 Affzo NIV(INDIC) : mkstat = 2
Endif
Onkey   2 Titled GBOUTS Call S_NIV(zc) From W1POT4
Gosub _AFF
End

Subprog C_NIV(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
If !mkstat
 ## Action CTLNIV
 Call CTLNIV(VALEUR,[M]CPC(nolign-1)) From SUBCPC
 If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
Endif
Gosub _AFF
End

$AMM_NIV
Call AM_NIV(zc)
If !mkstat & GOBJET
 zoncou = "NIV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NIV(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_NIV(VALEUR) From SUBPOT
If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
Gosub _AFF
End

Subprog S_NIV(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELNIV
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELNIV"
 PARMSK(1) = [M]CPC(nolign-1)
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELNIV","SUBCPC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_ORI
Onevent INIT_AREA Call D_ORI(zc) From W1POT4
Return

Subprog D_ORI(VALEUR)
Variable Integer VALEUR
If varinit([M]ORI,indice)=0
 VALEUR = 6
Endif
Gosub _AFF
End

$ON_WEI
Onevent BEFORE_INPUT Call AS_WEI(zc) From W1POT4
Onevent INIT_AREA Call D_WEI(zc) From W1POT4
Onevent CONTROL Call C_WEI(zc) From W1POT4
Return

Subprog D_WEI(VALEUR)
Variable Decimal VALEUR
If varinit([M]WEI,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_WEI(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_WEI(VALEUR) From SUBPOT
If mkstat=2
 [M]WEI(INDIC) = VALEUR
 Affzo WEI(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_WEI(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "WEI" : GZNUM = 25982 : Endif
Gosub _AFF
End

$ON_CODORI
Onevent INIT_AREA Call D_CODORI(zc) From W1POT4
Return

Subprog D_CODORI(VALEUR)
Variable Char    VALEUR()
If varinit([M]CODORI,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10461","") From SUBADI
Endif
Gosub _AFF
End

$ON_FLGKEY
Onevent INIT_AREA Call D_FLGKEY(zc) From W1POT4
Return

Subprog D_FLGKEY(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGKEY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CODSCA
Return

$ON_CRSFLG
Onevent INIT_AREA Call D_CRSFLG(zc) From W1POT4
Return

Subprog D_CRSFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]CRSFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


