#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ESSPASDET 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:11"
A_USER  = "DOC"
A_STAMP = "20181109230411"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPAS"
  If [M]NBRPAS=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ESSPASDET [ESPDT]
Gosub HORODAT
Local Inpbox "ESSPASDET" From GFONCTION At A_STAMP With A_WINDPREV Mask [ESPDT] As [SIM_]
Grizo [ESPDT]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ESPDT]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_NBRPAS
Onevent CONTROL Call C_NBRPAS From W1ESSPASDET
Return

Subprog C_NBRPAS
Local Decimal BASPAG
## Action STD
Call C_NBRPAS From ESSPASDET
If mkstat : GERR = 1 : GZONE = "NBRPAS" : GZNUM = 0 : Endif
Gosub _AFF
End

$ON_PASNUM
Onevent AFTER_CHANGE Gosub AMM_PASNUM From W1ESSPASDET
Onevent CONTROL Call C_PASNUM(zc) From W1ESSPASDET
Return

Subprog C_PASNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "PASNUM" : GZNUM = 1120 : Endif
Gosub _AFF
End

$AMM_PASNUM
Call AM_PASNUM(zc)
If !mkstat & GOBJET
 zoncou = "PASNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PASNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PASNUM(VALEUR) From ESSPASDET
If mkstat : GERR = 1 : GZONE = "PASNUM" : GZNUM = 1120 : Endif
Gosub _AFF
End

$ON_PASDTE
Onevent AFTER_CHANGE Gosub AMM_PASDTE From W1ESSPASDET
Onevent BEFORE_AREA Gosub AV_PASDTE From W1ESSPASDET
Return

$AV_PASDTE
Chgfmt [M]PASDTE(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$AMM_PASDTE
Call AM_PASDTE(zc)
If !mkstat & GOBJET
 zoncou = "PASDTE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PASDTE(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_PASDTE(VALEUR) From ESSPASDET
If mkstat : GERR = 1 : GZONE = "PASDTE" : GZNUM = 212 : Endif
Gosub _AFF
End

$ON_PLCISS
Onevent AFTER_CHANGE Gosub AMM_PLCISS From W1ESSPASDET
Return

$AMM_PLCISS
Call AM_PLCISS(zc)
If !mkstat & GOBJET
 zoncou = "PLCISS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PLCISS(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PLCISS(VALEUR) From ESSPASDET
If mkstat : GERR = 1 : GZONE = "PLCISS" : GZNUM = 46425 : Endif
Gosub _AFF
End

$ON_PASCRY
Onevent AFTER_CHANGE Gosub AMM_PASCRY From W1ESSPASDET
Onevent CONTROL Call C_PASCRY(zc) From W1ESSPASDET
Onevent BEFORE_INPUT Call AS_PASCRY(zc) From W1ESSPASDET
Onevent INIT_AREA Call D_PASCRY(zc) From W1ESSPASDET
Return

Subprog D_PASCRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]PASCRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_PASCRY(zc) From W1ESSPASDET
Onkey 144 Titled GBOUTP Call P_PASCRY(zc) From W1ESSPASDET
Onkey 146 Titled GBOUTA Call SA_PASCRY(zc) From W1ESSPASDET
Gosub _AFF
End

Subprog C_PASCRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "PASCRY" : GZNUM = 263 : Endif
Gosub _AFF
End

$AMM_PASCRY
Call AM_PASCRY(zc)
If !mkstat & GOBJET
 zoncou = "PASCRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PASCRY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PASCRY(VALEUR) From ESSPASDET
If mkstat : GERR = 1 : GZONE = "PASCRY" : GZNUM = 263 : Endif
Gosub _AFF
End

Subprog S_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog SA_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PASCRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ISSAUZ
Onevent AFTER_CHANGE Gosub AMM_ISSAUZ From W1ESSPASDET
Return

$AMM_ISSAUZ
Call AM_ISSAUZ(zc)
If !mkstat & GOBJET
 zoncou = "ISSAUZ" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ISSAUZ(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ISSAUZ(VALEUR) From ESSPASDET
If mkstat : GERR = 1 : GZONE = "ISSAUZ" : GZNUM = 55127 : Endif
Gosub _AFF
End

$ON_EXPDAT
Return

$ON_ETRPITTYP
Return

$ON_ETRPITDAT
Return

$ON_ETRPITEXPDAT
Return

$ON_PASAMD
Onevent INIT_AREA Call D_PASAMD(zc) From W1ESSPASDET
Return

Subprog D_PASAMD(VALEUR)
Variable Integer VALEUR
If varinit([M]PASAMD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PASDATNEW
Return

$ON_PASDATAMD
Return

$ON_TCH_NUMLIG
Return

$CHG_STY
Return


