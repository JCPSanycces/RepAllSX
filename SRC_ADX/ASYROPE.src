#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK

ERROR = func OPE(ACTX,PSYR,ARCV,JSON,ASND,PSYR.CODREP,PSYR.CODFAC,PSYR.OPERATION,PSYR.SELREP)

End ERROR

#-------------------------------------------------------------------------#
Funprog OPE(ACTX,PSYR,ARCV,JSON,ASND,REPRES,TYPREP,OPER,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance JSON       Using C_ASYRJSO
Variable Instance ASND Using C_ASYRSND
Value    Char     REPRES , TYPREP , OPER , KEYS


Local Integer ERROR : ERROR=[V]CST_AOK
Local Char    WOPERATION(30) , CHAINE(250)
Local Char    PRGREP(30) , REPNAM(10)
Local Integer I , J , K , ASTATUS
Local Char    OPE_CODPAR(30)(1..30) , OPE_VALPAR(250)(1..30)
Local Char    OPE_KEYS(250)

REPNAM = "OPE"

If GTRASYR : Call TRACE("key="+KEYS-"oper="+OPER-"repres="+REPRES) From ASYRCOM : Endif

FreeInstance [UPD]
Local Instance  UPD(1..) Using C_ADELTA
Local Instance  ASWK     Using C_ASYRWRK
ASWK = evalue("Newinstance ["+REPNAM+"] With C_ASYRWRK")

ASWK.REPRES = REPRES
ASWK.FACET  = TYPREP
ASWK.KEYURL = KEYS
ASWK.OPERAT = 2

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#

Local Instance REP Using C_AREPENT : # Representation containing metadatas

PRGREP = func SUBASW.PREFIX_TRT+REPRES : # WMREP

Call DESCRIPTION_REPRESENTATION(REP,REPNAM) From =PRGREP
# Create instance class or representation

I = find(OPER,REP.LNK(1..maxtab(REP.LNK)).COD)
If I=0 or REP.LNK(I)=null or REP.LNK(I).MET=null
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_OK,func ASYRFNC.MES1(mess(56,149,1),OPER))
Goto ERR_DETAIL
Endif

WOPERATION = REP.LNK(I).MET.COD

# Set parameters

Call DECODE_PARAM(REP,ARCV,OPER,OPE_KEYS,OPE_CODPAR,OPE_VALPAR)
If OPE_KEYS="" : OPE_KEYS = KEYS : Endif

Local Instance WREP Using ="C_"+REP.LNK(I).CLA
WREP = evalue("Newinstance ["+REPNAM+"] With C_"+REP.LNK(I).CLA)

# Call method
Local Clbfile WCLBRETURN : WCLBRETURN=""
#109788
Call EXE_OPERATION(WREP,WOPERATION,WCLBRETURN,OPE_KEYS,OPE_CODPAR,OPE_VALPAR) From =func APREFIXTRT.GET_PREFIX_REP+"0"+REP.REP

# Result method

ASND.DATA = ""
ASWK.NUMWRK = 1
ASTATUS = fmet WREP.AGETMAXERROR("")
Call FIND_ERROR_CLASS(WREP,REP,UPD) From ASYRDELERR
# Opération $1$ terminée
If maxtab(UPD)<=0
 CHAINE = func AFNC.MES1(mess(221,143,1),WOPERATION)
 Call MAJ_ERROR(UPD,3,0,NullUuid,WREP.AUUID,0,"",OPER,CHAINE,datetime$,[V]CST_ASUCCESS,0) From ASYRDELSYS
 #109788
 If WCLBRETURN<>""
 Call MAJ_RETURN(UPD,3,0,NullUuid,WREP.AUUID,0,"",OPER,WCLBRETURN) From ASYRDELSYS
 Endif
Endif
Call DETAIL_JSON(REP,WREP,ASWK,PSYR,UPD,ASND.DATA) From ASYRDATDEL

ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+REPRES+"('"+KEYS+"')"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRES+"."+TYPREP

$ERR_DETAIL
FreeGroup ASWK : #free of AWSK, WREP, REP
End ERROR


#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

Subprog DECODE_PARAM(REP,ARCV,OPER,OPE_KEYS,OPE_CODPAR,OPE_VALPAR)
Variable Instance REP  Using C_AREPENT
Variable Instance ARCV Using C_ASYRRCV
Value    Char OPER
Variable Char OPE_KEYS , OPE_CODPAR()(1..) , OPE_VALPAR()(1..)
Local Integer I , J , K , P
K = find(OPER,REP.LNK(1..maxtab(REP.LNK)).COD)
For I=1 To maxtab(REP.LNK(K).CLE)
 If REP.LNK(K).CLE(I)<>null
  J = find(toupper(REP.LNK(K).CLE(I).PAR),ARCV.PARAMCOD)
  If J
   If OPE_KEYS<>""
    OPE_KEYS += "~"
   Endif
   OPE_KEYS += ARCV.PARAMVAL(J)
  Endif
 Endif
Next I
P = 0
For I=1 To maxtab(REP.LNK(K).PAR)
 If REP.LNK(K).PAR(I)<>null
  J = find(toupper(REP.LNK(K).PAR(I).PAR),ARCV.PARAMCOD)
  If J
   P += 1
   OPE_CODPAR(P) = REP.LNK(K).PAR(I).PAR
   OPE_VALPAR(P) = ARCV.PARAMVAL(J)
  Endif
 Endif
Next I
End

