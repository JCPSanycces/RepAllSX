#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION

GBIDC1 = "FUNSADJB"
#GBIDC1 = "FUNSADJSPE" : If ACTION="INIT" : Infbox "Trt installé chez Dyadem" : Endif

Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH_ADJSTO
  When "INIT"           : Gosub INIT_ADJSTO
  When "EXEC"           : Gosub EXEC_ADJSTO
  When "INIT_DIA"       : Gosub INIT_SADJ_ADJSTO
  When "OK"             : Gosub OK_ADJSTO
  When "END"            : Gosub END_ADJSTO
Endcase
Return

#############################################################
$OUVRE_BATCH_ADJSTO
Gosub OPEN_FILE From =GBIDC1
Return
#############################################################
$INIT_ADJSTO
Gosub OPEN_FILE  From =GBIDC1
Return
#############################################################
$EXEC_ADJSTO
    Call STKADJ From =GBIDC1
Return
#############################################################
$INIT_SADJ_ADJSTO
Raz [M:SADJ]
Return
#############################################################
$OK_ADJSTO
FIN  = 1
Return
#############################################################
$END_ADJSTO
Raz [M:SADJ]
FIN = 1
Return

