############################################################
Subprog AM_CPYSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]CPYSTR = [M:SADJ]CPYEND | VALEUR > [M:SADJ]CPYEND
    [M:SADJ]CPYEND = VALEUR
    Affzo [M:SADJ]CPYEND
Endif
End

############################################################
Subprog AM_STOFCYSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]STOFCYSTR = [M:SADJ]STOFCYEND | VALEUR > [M:SADJ]STOFCYEND
    [M:SADJ]STOFCYEND = VALEUR
    Affzo [M:SADJ]STOFCYEND
Endif
End

############################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]TCLCODSTR = [M:SADJ]TCLCODEND | VALEUR > [M:SADJ]TCLCODEND
    [M:SADJ]TCLCODEND = VALEUR
    Affzo [M:SADJ]TCLCODEND
Endif
End

############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]ITMREFSTR = [M:SADJ]ITMREFEND | VALEUR > [M:SADJ]ITMREFEND
    [M:SADJ]ITMREFEND = VALEUR
    Affzo [M:SADJ]ITMREFEND
Endif
End

############################################################
Subprog AM_VLTSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]VLTSTR = [M:SADJ]VLTEND | VALEUR > [M:SADJ]VLTEND
    [M:SADJ]VLTEND = VALEUR
    Affzo [M:SADJ]VLTEND
Endif
End

############################################################
Subprog AM_BUYSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]BUYSTR = [M:SADJ]BUYEND | VALEUR > [M:SADJ]BUYEND
    [M:SADJ]BUYEND = VALEUR
    Affzo [M:SADJ]BUYEND
Endif
End

############################################################
Subprog AM_TSICODSTR(VALEUR)
Variable Char    VALEUR()
If [M:SADJ]TSICODSTR(indice) = [M:SADJ]TSICODEND(indice) | VALEUR > [M:SADJ]TSICODEND(indice)
    [M:SADJ]TSICODEND(indice) = VALEUR
    Affzo [M:SADJ]TSICODEND(indice)
Endif
End

############################################################

################################################################
# REGUL : Régularise immédiatement un article-site
#         à partir du tout premier mouvement
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
################################################################
Subprog REGUL(PITM,PFCY)
Value Char PITM
Value Char PFCY
Gosub OPEN_FILE From FUNSADJB
# Récupération du tout 1er document de l'article site
Filter [STJ] Where ITMREF=PITM & STOFCY=PFCY
&                & VCRLIN>0
&            Order By IPTDAT;CREMVTDAT;CREMVTTIM;MVTSEQ Desc
Read [STJ] First
Filter [STJ]
If !fstat
    # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter
    Call REGULVCR([F:STJ]ITMREF,[F:STJ]STOFCY,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,[F:STJ]TRSTYP,[F:STJ]CREMVTSEQ)
Endif

End

################################################################
# REGUL : Régularise immédiatement un article-site
#         à partir du tout premier mouvement
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
################################################################
Subprog REGUL2(PITM,PFCY,PSIM)
Value Char PITM
Value Char PFCY
Value Integer PSIM
Gosub OPEN_FILE From FUNSADJB
# Récupération du tout 1er document de l'article site
Filter [STJ] Where ITMREF=PITM & STOFCY=PFCY
&                & VCRLIN>0
&            Order By IPTDAT;CREMVTDAT;CREMVTTIM;MVTSEQ Desc
Read [STJ] First
Filter [STJ]
If !fstat
    # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter
    Call REGULVCR2([F:STJ]ITMREF,[F:STJ]STOFCY,[F:STJ]VCRTYP,[F:STJ]VCRNUM,[F:STJ]VCRLIN,[F:STJ]TRSTYP,[F:STJ]CREMVTSEQ,PSIM)
Endif

End

################################################################
# REGULVCR : Régularise immédiatement un article-site
#            à partir d'un document donné
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
#                PTYP = type de document
#                PNUM = N° de document
#                PLIN = N° ligne de document
#                PTRS = transaction type
#                PSEQ = CREMVTSEQ
################################################################
Subprog REGULVCR(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ)
Value Char PITM
Value Char PFCY
Value Integer PTYP
Value Char PNUM
Value Integer PLIN
Value Integer PTRS  # 118579.n - add TRSTYP to SMA table
Value Integer PSEQ  # 118579.n - add CCREMVTSEQ to SMA table

Call REGULVCR2(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ,0)

End

################################################################
# REGULVCR : Régularise immédiatement un article-site
#            à partir d'un document donné. La simulation est possible
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
#                PTYP = type de document
#                PNUM = N° de document
#                PLIN = N° ligne de document
#                PTRS = transaction type
#                PSEQ = CREMVTSEQ
#                PSIM = 0: pas de simu ; 1:simu
################################################################
Subprog REGULVCR2(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ,PSIM)
Value Char PITM
Value Char PFCY
Value Integer PTYP
Value Char PNUM
Value Integer PLIN
Value Integer PTRS  # 118579.n - add TRSTYP to SMA table
Value Integer PSEQ  # 118579.n - add CCREMVTSEQ to SMA table
Value Integer PSIM

Local Integer LRET
Local Integer LSMANUM

Local Mask STOADJ [SADJ]
Gosub OPEN_FILE From FUNSADJB

Trbegin [SMA]
Delete [SMA] Where ITMREF=PITM & STOFCY=PFCY
LRET = func CRESMA0(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ)  # 118579.m - Added TRSTYP & CREMVTSEQ as a parameter
If LRET
    Rollback
    Infbox "CRESMA0 KO : fstat="-num$(LRET)
    End
Else
    LSMANUM = [F:SMA]NUM
    Commit
Endif

Raz [M:SADJ]
[M:SADJ]ITMREFSTR=PITM
[M:SADJ]ITMREFEND=PITM
[M:SADJ]STOFCYSTR=PFCY
[M:SADJ]STOFCYEND=PFCY
[M:SADJ]SIMFLG=(PSIM<>0)*2

Call STKADJ From FUNSADJB

If PSIM
    Trbegin [SMA]
    Delete [SMA] Where NUM=LSMANUM
    Commit
Endif
End

################################################################
# CTRSMA : Contrôle que la régul de sortie peut se faire
#          à partir d'un document donné
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
#                PTYP = type de document
#                PNUM = N° de document
#                PLIN = N° ligne de document
#                PTRS = transaction type
#                PSEQ = CREMVTSEQ
################################################################
# Renvoie le code erreur de TSTEXEREG
# ou fstat*(-1) si le SMA temporaire n'a pas pu être créé
################################################################
Funprog CTRSMA(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ)
Value Char PITM
Value Char PFCY
Value Integer PTYP
Value Char PNUM
Value Integer PLIN
Value Integer PTRS  # 118579.n - add TRSTYP to SMA table
Value Integer PSEQ  # 118579.n - add CCREMVTSEQ to SMA table

Local Integer LRET

Gosub OPEN_FILE From FUNSADJB

Trbegin [SMA]
Delete [SMA] Where NUM=0
LRET = func CRESMA0(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ)

If !LRET
  # L'enreg SMA est positionné--> on peu tlancer le test
  LRET = func FUNSADJB.TSTEXEREG(PITM,PFCY,0)
Else
  LRET = -LRET
Endif

Rollback

End LRET

################################################################
# CRESMA0 : Crée un déclencheur dans SMA avec NUM=0
################################################################
# Parameters E : PITM = Article
#                PFCY = Site
#                PTYP = type de document
#                PTRS = transaction type
#                PNUM = N° de document
#                PLIN = N° ligne de document
################################################################
Funprog CRESMA0(PITM,PFCY,PTYP,PNUM,PLIN,PTRS,PSEQ)
Value Char PITM
Value Char PFCY
Value Integer PTYP
Value Char PNUM
Value Integer PLIN
Value Integer PTRS    # 118579.n - Add TRSTYP to SMA table
Value Integer PSEQ    # 118579.n - Add CREMVTSEQ to SMA table

Local Integer LRET
Local Char LVCRNUM(GLONVCR), LITM(GLONITM), LFCY(GLONFCY)
Local Integer LVCRLIN, LVCRTYP
Local Char REQ(250)

If clalev([F:SMA])=0 : Local File STKMVTADJ [SMA] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

Raz [F:SMA]
REQ = "SELECT max(NUM_0) From STKMVTADJ"
[F:SMA]NUM=1
For (Integer NUM) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    [F:SMA]NUM = [F:SQLX]NUM+1
    Break
Next
[F:SMA]STOFCY = PFCY
[F:SMA]VCRTYP = PTYP
[F:SMA]VCRNUM = PNUM
[F:SMA]VCRLIN = PLIN
[F:SMA]TRSTYP = PTRS      # X3-67371/118579.n - Add TRSTYP to SMA table
[F:SMA]CREMVTSEQ = PSEQ   # 118579.n - Add CREMVTSEQ to SMA table
[F:SMA]VCRTYPREG = PTYP
[F:SMA]VCRNUMREG = PNUM
[F:SMA]VCRLINREG = PLIN
[F:SMA]CREDAT = date$
[F:SMA]CRETIM = mid$(time$,1,2)+mid$(time$,4,2)+mid$(time$,7,2)
Read [ITM]ITM0=PITM
[F:SMA]ITMREF= PITM
[F:SMA]TCLCOD= [F:ITM]TCLCOD
ISITE = find([F:SMA]STOFCY,GSITE(1..GNBSITE))
[F:SMA]CPY   = GSOCSITE(ISITE)
[F:SMA]QTY = 1

If adxlog=1
    Write [SMA]
Else
    Trbegin [SMA]
    Write [SMA]
    Commit
Endif

End fstat

##################################################################################
# MAJSMA : Alimente les champs ITMREF, CPY et TCLCOD de tous les enregistrements
#          de la table STKMVTADJ [SMA]
##################################################################################
Subprog MAJSMA

Local Char    LVCRNUM(GLONVCR),LVCRNUMREG(GLONVCR)
Local Integer LVCRTYP, LVCRTYPREG, LVCRLIN, LVCRLINREG
Local Char    LSTOFCY(GLONFCY)
Local Integer ISITE, LNB, LSTOP

If !clalev([F:SMA]) : Local File STKMVTADJ [SMA] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
If !clalev([F:STJ]) : Local File STOJOU    [STJ] : Endif
Call OUVRE_TRACE("Set ITMREF, CPY and TCLCOD in [F:SMA]") From LECFIC


$FOR_SMA
Call DEBTRANS From GLOCK
Trbegin [SMA]

If LSTOP=1
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP=LVCRTYP & STOFCY=LSTOFCY & VCRNUMREG=LVCRNUMREG & VCRLINREG=LVCRLINREG & VCRTYPREG>LVCRTYPREG
    LSTOP += 1
Elsif LSTOP=2
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP=LVCRTYP & STOFCY=LSTOFCY & VCRNUMREG=LVCRNUMREG & VCRLINREG>LVCRLINREG
    LSTOP += 1
Elsif LSTOP=3
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP=LVCRTYP & STOFCY=LSTOFCY & VCRNUMREG>LVCRNUMREG
    LSTOP += 1
Elsif LSTOP=4
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP=LVCRTYP & STOFCY>LSTOFCY
    LSTOP += 1
Elsif LSTOP=5
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN=LVCRLIN & VCRTYP>LVCRTYP
    LSTOP += 1
Elsif LSTOP=6
    Filter [SMA] Where VCRNUM=LVCRNUM & VCRLIN>LVCRLIN
    LSTOP += 1
Elsif LSTOP=7
    Filter [SMA] Where VCRNUM>LVCRNUM
    LSTOP = 0
Endif

For [SMA]
    LVCRNUM = [F:SMA]VCRNUM
    LVCRLIN = [F:SMA]VCRLIN
    LVCRTYP = [F:SMA]VCRTYP
    LSTOFCY = [F:SMA]STOFCY
    LVCRNUMREG = [F:SMA]VCRNUMREG
    LVCRLINREG = [F:SMA]VCRLINREG
    LVCRTYPREG = [F:SMA]VCRTYPREG

    Gosub MAJ_CPYTCL

    If LNB>50000
        LSTOP =1
        Break
    Endif
Next
Filter [SMA]
If GOK
    Commit
    If LSTOP
        Goto FOR_SMA
    Endif
Else
    Rollback
Endif

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

# Pour mise à jour de la société et de la catégorie
$MAJ_CPYTCL
    Read [STJ]STJ1=[F:SMA]STOFCY;[F:SMA]VCRTYP;[F:SMA]VCRNUM;[F:SMA]VCRLIN
    If !fstat
        Raz [F:ITM]
        Read [ITM]ITM0=[F:STJ]ITMREF
        If !fstat
            ISITE = find([F:SMA]STOFCY,GSITE(1..GNBSITE))
            If ISITE
                Readlock [SMA] Curr
                [F:SMA]ITMREF= [F:STJ]ITMREF
                [F:SMA]CPY   = GSOCSITE(ISITE)
                [F:SMA]TCLCOD= [F:ITM]TCLCOD
                Rewrite [SMA]
                LNB +=1
            Else
                Call ECR_TRACE("site:"+[F:SMA]STOFCY+" société non trouvée",1) From GESECRAN
            Endif
        Else
            Call ECR_TRACE("[ITM] '"+[F:STJ]ITMREF+"' : FSTAT="+num$(fstat),1) From GESECRAN
        Endif
    Else
        Call ECR_TRACE("[SMA]"+[F:SMA]STOFCY+";"+[F:SMA]VCRTYP+";"+[F:SMA]VCRNUM+";"+[F:SMA]VCRLIN+":FSTAT="+num$(fstat),1) From GESECRAN
    Endif
Return

