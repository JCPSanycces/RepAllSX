#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FOC0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CODFOR
mkstat = 0
zoncou = "CODFOR"
indice = 0
If varmode([M]CODFOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CODFOR" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CODFOR,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CODFOR" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "FOC"
  Local Char    VALEUR(250)
  VALEUR = [M]CODFOR
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]CODFOR = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODFOR" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]LEG,"909","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]LEG,"909",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]LEG or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_LEG([M]LEG) From SUBFOC
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESFOR
mkstat = 0
zoncou = "DESFOR"
indice = 0
If varinit([M]DESFOR,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESFOR,"FORCTR","DESFOR",[M:FOC0]LEG,[M:FOC0]CODFOR) From ATEXTRA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]DESFOR,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "DESFOR" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]DESFOR,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "DESFOR" : GZNUM = 8 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TYPFOR
mkstat = 0
zoncou = "TYPFOR"
indice = 0
IMPENT = [M]TYPFOR
WNUM = IMPENT
If varinit([M]TYPFOR,indice)=0
 IMPENT = 1
Endif
If varmode([M]TYPFOR,indice)=0
 [M]TYPFOR(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TYPFOR" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TYPFOR(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TYPFOR(IMPENT) From SUBFOC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TYPFOR" : GZNUM = 680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]TYPFOR = IMPENT

## Zone CAIVAL
mkstat = 0
zoncou = "CAIVAL"
indice = 0
If varmode([M]CAIVAL,indice)=0
 SAVACT = GACTION : GACTION = "AFMTSAI"
 Call ASAISIE([M]CAIVAL,"M") From FMTVAR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CAIVAL : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CAIVAL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "AFMTCONT"
  Call CONTROLE([M]CAIVAL,"M",[M]CAILIB,15,[M]CAIFOR) From FMTVAR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CAIVAL" : GZNUM = 55102 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACONTACL"
   Call CONTACL([M]CAIFOR,"M","","") From SUBACL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CAIVAL" : GZNUM = 55102 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ADIFOR
mkstat = 0
zoncou = "ADIFOR"
indice = 0
If varmode([M]ADIFOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ADIFOR" : Gosub ACTION From =IMPTRT
 Endif
 If [M]ADIFOR=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "ADIFOR" : GZNUM = 5548 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If [M]ADIFOR<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ADIFOR" : GZNUM = 5548 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTNUM("ADV","",[M]ADIFOR,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "ADIFOR" : GZNUM = 5548 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CTRFOR
mkstat = 0
zoncou = "CTRFOR"
indice = 0
If varmode([M]CTRFOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRFOR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FMTFOR
mkstat = 0
zoncou = "FMTFOR"
indice = 0
If varmode([M]FMTFOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FMTFOR" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "FOC0"
Return

