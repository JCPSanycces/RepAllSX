#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("PLAN","") From ETAT
End

####################################################
## Impression du plan de paye
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local File RUBRIQUE [RUB]
Local Integer RW , I
Gosub TR1
End

$TR1
GOK = 1
Trbegin [RUB]
 For [RUB]RUB0 Where LEG=GCURLEG
  Gosub DECODE
 Next
Commit
Return

$DECODE
Readlock [RUB] Curr
If fstat : Return : Endif
RW = 0
Call TOKEN([F:RUB]CNDCAL,RW)
Call TOKEN([F:RUB]BAS,RW)
Call TOKEN([F:RUB]RAT1,RW)
Call TOKEN([F:RUB]RAT2,RW)
Call TOKEN([F:RUB]TBLFRM(0),RW)
Call TOKEN([F:RUB]TBLFRM(1),RW)
Call TOKEN([F:RUB]TBLFRM(2),RW)
For I=0 To dim([F:RUB]ITVAMT)-1
 Call TOKEN([F:RUB]ITVAMT(I),RW)
Next I
Call TOKEN([F:RUB]AMTMAX(0),RW)
Call TOKEN([F:RUB]AMTMAX(1),RW)
Call TOKEN([F:RUB]AMTMAX(2),RW)
Call TOKEN([F:RUB]DESPRN,RW)
If RW
 Rewrite [RUB]
 If fstat
  GOK = 0 : Call FSTA("RUB") From GLOCK
 Endif
Endif
Return

Subprog TOKEN(CHAINE,RW)
Variable Char    CHAINE()
Variable Integer RW
If CHAINE<>""
 Local Char TOKEN(250)
 TOKEN = vireblc(format$("KT:250X",CHAINE),2)
 If CHAINE<>TOKEN
  CHAINE = TOKEN
  RW = 1
 Endif
Endif
End

