#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC01   Migration de la table ITMMASTER       Module TC         #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif

If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC01") From LECFIC
  Endif
  #Call RAZ_UUMGTRTTRC01(DOSSIER)
  Call MAJ_UUMGTRTTRC01(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

Subprog MAJ_UUMGTRTTRC01(DOSSIER)
Value Char DOSSIER

#--- Issue 108760 by TS
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
#---

If [F:ADS]MODULE(8)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

Local Integer ERR
Local Char WNAMITMM
Call MIGTABNAME (DOSSIER,"ITMMASTER",WNAMITMM,ERR) From TRTMIG

If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMITMM,"fde",[F:ADS]DOSSIER),0) < 0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################


Local Integer ERR, NBCOMMIT,NBLUS

# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
#Local Char WTAB_ITM (100) (adxwrb)
#Local Shortint WCPT_ITM

Call ECR_TIME("UUMGTRTTRC01 tables ITM Process : Update ITM") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"ITMMASTER",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:ITM])  = 0 : Local File =DOSSIER+".ITMMASTER"    [ITM]  : Endif   # Fichier X3 "Vide"

If clalev([F:ITMM]) = 0 : Local File =DOSSIER+"."+WNAMITMM   [ITMM] : Endif   # Fichier X3 renommé Avant Migration

If clalev([F:ITG]) = 0 : Local File =DOSSIER+".ITMCATEG"   [ITG] : Endif   # Catégorie article
If clalev([F:ITS]) = 0 : Local File =DOSSIER+".ITMSALES"   [ITS] : Endif   # Catégorie article

#-----  Déclaration des variables -----#
# Issue 112303 - 2015-11-09 by MAE : Déplacement des variables
Local Char WTAB_ITM (100) (adxwrb)
Local Shortint WCPT_ITM
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz STOP, CRITERE, NBCOMMIT,NBLUS

# Déclaration des variables communes de travail
Local Integer I, J

#Lecture de la table CADIEDEF
Local File =[F:ADS]DOSSIER+".CADIEDEF"     [CDI]
Local Integer NBCDI : NBCDI=nbrecord([CDI])
Local Char WDIE(GLONDIE)(0..20)
Local Integer WNBRDIE
Local Integer WI
Raz WI
Read [CDI]CDI0 = 1
  If !fstat
    WNBRDIE = [F:CDI]NBRDIE
    For WI=0 To [F:CDI]NBRDIE-1
      WDIE(WI)=[F:CDI]DIE(WI)
    Next
  Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC01" : FILTRELIN=0 : Raz CRITERESPE : Raz HINTSPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_ITM00
Raz NB
If STOP=1
 STOP = 0
 CRITERE = "[F:ITMM]ITMREF>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif

Trbegin [ITM]
GOK = 1

For [ITMM] Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS+=1
  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTTRC01" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_ITM
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_ITM
  Endif
  [F:ITM] = [F:ITMM]

  #Appel proc de migration sur entete
  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_ITM
    If GOK<1 : Break : Endif
  Endif

  # Passage en V7
  If val(VERSION)<GMIGX3VER70
    Gosub MAJV7_ITM
    If GOK<1 : Break : Endif
  Endif

  ############################
  #-- Boucle sur les lignes
  ############################
  If GOK<1 : Break : Endif

  # --- alimentation des champs et écriture enreg
  #--- Issue 108760 by TS
  #If NEWMOTEUR
  #    Gosub ITM_STK  # pour stocker ref
  #    WriteB [F:ITM]
  #Else
  #    Write [F:ITM]
  #Endif
  #If fstat
  #  If NEWMOTEUR & adxwrb>1
  #    Call ECR_TRACE("File ITMMASTER, Error ="-num$(fstat),1) From GESECRAN
  #    Gosub ITM_ERRTRA : # pour afficher les ref
  #  Else
  #    Call ECR_TRACE("File ITMMASTER(CPY/SALFCY/NUM)"-[F:ITM]ITMREF+", Error ="-num$(fstat),1) From GESECRAN
  #  Endif
  #  GOK=0 : Break
  #Endif
  Gosub ITM_STK  # pour stocker ref
  WriteB [F:ITM]
  If fstat
    Call ECR_TRACE("File ITMMASTER, Error ="-num$(fstat),1) From GESECRAN
    Gosub ITM_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  #---

  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:ITMM]ITMREF
    STOP=1
    Break
  Endif
$SUITE_BOUCLE
Next

$FIN_BOUCLE
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC01",7,ERR) From TRTMIG : #7=Erreur
Else
  #--- Issue 108760 by TS
  #If NEWMOTEUR & adxwrb>1
    Flush [F:ITM]
    If fstat
        Call ECR_TRACE("File ITMMASTER, Error ="-num$(fstat),1) From GESECRAN
        Gosub ITM_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  #--- Issue 108760 by TS
  #Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
    TABMIGKEY(2)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_BOUCLE
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC01",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_ITM00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [ITM] #, [XXD]
Close Local File [ITMM] #, [XXDM]
Close Local File [ITG], [ITS]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"ITMMASTER",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTTRC01") From TRTMIG
Call ECR_TIME("UUMGTRTTRC01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End
################################################
$RAZV6_ITM
If dim([F:ITM]CRESTP)>0 Raz [F:ITM]CRESTP : Endif
Raz [F:ITM]DIE
If dim([F:ITM]IDTSGL)>0 Raz [F:ITM]IDTSGL : Endif
If dim([F:ITM]UPDSTP)>0 Raz [F:ITM]UPDSTP : Endif
Raz [F:ITM]DLU
Raz [F:ITM]DLVFLG
Raz [F:ITM]EECGES
Raz [F:ITM]GENFLG
Raz [F:ITM]INTFLG
Raz [F:ITM]ITMVOU
Raz [F:ITM]MFGFLG
Raz [F:ITM]NEWLTISTA
Raz [F:ITM]PHAFLG
Raz [F:ITM]PURFLG
Raz [F:ITM]SALFLG
Raz [F:ITM]SCSFLG
Raz [F:ITM]SHLLTIUOM
Raz [F:ITM]SHLUOM
Raz [F:ITM]STAFED
Raz [F:ITM]TOOFLG
Raz [F:ITM]VACITM
Raz [F:ITM]VOU

Return
################################################
$RAZV7_ITM
Raz [F:ITM]CPRCOE
Raz [F:ITM]ITMSFTTYP
Return
################################################
$MAJV6_ITM

[F:ITM]EECGES = 2
[F:ITM]DLU       = 1
[F:ITM]SHLUOM    = 1
[F:ITM]SHLLTIUOM = 1
#---- CLSTYP ----#
If [F:ITM]TCLCOD<>""
  If [F:ITM]TCLCOD <> [F:ITG]TCLCOD
    Read [ITG]ITG1=[F:ITM]TCLCOD;""
    If fstat
      Call ECR_TRACE("File ITMMASTER, Error ="-num$(fstat),1) From GESECRAN
      Gosub ITM_ERRTRA : # pour afficher les ref
      GOK=0 : Goto FIN_BOUCLE : #on part sur rollback
    Endif
  Endif
  [F:ITM]MFGFLG = [F:ITG]MFGFLG
  [F:ITM]SCPFLG = [F:ITG]SCPFLG
  [F:ITM]SCSFLG = [F:ITG]SCSFLG
  [F:ITM]PHAFLG = [F:ITG]PHAFLG
  [F:ITM]GENFLG = [F:ITG]GENFLG
  [F:ITM]TOOFLG = [F:ITG]TOOFLG
  [F:ITM]DLVFLG = [F:ITG]DLVFLG
  [F:ITM]PURFLG = [F:ITG]PURFLG
  [F:ITM]SALFLG = [F:ITG]SALFLG
  [F:ITM]INTFLG = [F:ITG]INTFLG
  #If [F:ITM]CLSTYP <> [F:ITG]CLSTYP
  #  Call ECR_TRACE([F:ITM]ITMREF-" "-[F:ITM]TCLCOD-" "-mess(252,184,1)
#&                      -mess([F:ITM]CLSTYP,222,1)-mess(254,184,1)-mess([F:ITG]CLSTYP,222,1),-1) From GESECRAN
#  Endif
  # si livrable et unite de vente = "" alors unite de vente = unite de stock
  If [F:ITM]SAU        = ""
       [F:ITM]SAU        = [F:ITM]STU
  Endif
  If [F:ITM]SAUSTUCOE  = 0
     [F:ITM]SAUSTUCOE  = 1
  Endif
Endif
        #Rewrite [ITM]
#MAE, bg 69273, si DLVFLG = 2, on vérifie qu'il existe un ITMSALES, sinon, on le créé
If [F:ITM]DLVFLG = 2
  Read [ITS]ITS0 = [F:ITM]ITMREF
  If fstat > 1
    #MISE à jour table ITMSALES
    [F:ITS]       = [F:ITG]
    [F:ITS]       = [F:ITM]
    Write [ITS]
    #MAE, pas besoin de message
    #Call ECR_TRACE([F:ITS]ITMREF-" "-mess(59,123,1)-" "-mess(16,752,1), -1) From GESECRAN
    If fstat
       Call FSTA("ITS") From GLOCK
    Endif
  Endif
Endif
#Mise à jour des sections analytiques
Raz WI
For WI=0 To WNBRDIE-1
  If WI<dim([F:ITM]DIE)
     If [F:ITM]DIE(WI)=""  [F:ITM]DIE(WI)=WDIE(WI) : Endif
  Else
    Break
  Endif
Next

Return
################################################
$MAJV7_ITM
[F:ITM]CPRCOE       = 1
[F:ITM]ITMSFTTYP    = 1
Return
################################################
$ITM_STK
Call STK (WTAB_ITM,WCPT_ITM,[F:ITM]ITMREF) From TRTMIG
Return
##############################################################################################
$ITM_ERRTRA
Call ERRTRA (WTAB_ITM,WCPT_ITM,"File ITMMASTER(REFITM)=") From TRTMIG
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
Call MAJ_UUMGTRTTRC01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC01(APPLI)
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTTRC01(DOSSIER)
Value Char DOSSIER

Local Integer ERR
##1 - verifications
####################
If [F:ADS]MODULE(8)<>2 : End : Endif          : # N= no module

Local Char WNAMITMM
Call MIGTABNAME (DOSSIER,"ITMMASTER",WNAMITMM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMITMM,"fde",[F:ADS]DOSSIER),0) < 0 :  End : Endif

Call MIGTABRAZ (DOSSIER,"ITMMASTER",ERR) From TRTMIG

##3 - On vide AMIGKEY pour le flux
####################

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC01",ERR) From TRTMIG

End

