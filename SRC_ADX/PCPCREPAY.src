#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("PCP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
Endcase
Return

$INIT
If !clalev([F:PYH])    : Local File PAYMENTH    [PYH]  : Endif
If !clalev([F:PYD])    : Local File PAYMENTD    [PYD]  : Endif
If !clalev([F:PYA])    : Local File PAYMENTA    [PYA]  : Endif
If !clalev([F:CPY])    : Local File COMPANY     [CPY]  : Endif
If !clalev([F:BAN])    : Local File BANK        [BAN]  : Endif
If !clalev([F:BPR])    : Local File BPARTNER    [BPR]  : Endif
If !clalev([F:BPC])    : Local File BPCUSTOMER  [BPC]  : Endif
If !clalev([F:RLT2])   : Local File RELMT940    [RLT2] : Endif
If !clalev([F:TPY])    : Local File TABPAYTYP   [TPY]  : Endif
If !clalev([F:RLD2])   : Local File RELMT940D   [RLD2] : Endif
If !clalev([F:RLD3])   : Local File RELMT940D   [RLD3] : Endif
If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:DAE])    : Local File GACCENTRYD  [DAE]  : Endif
If !clalev([F:HAE3])   : Local File GACCENTRY   [HAE3] : Endif
If !clalev([F:SIH])    : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:CDA])    : Local File GACCDENCOD  [CDA]  : Endif
If !clalev([F:COA])    : Local File GCOA        [COA]  : Endif
If !clalev([F:GAC])    : Local File GACCOUNT    [GAC]  : Endif
If !clalev([F:CAC])    : Local File GACCCODE    [CAC]  : Endif
If !clalev([F:BID])    : Local File BID         [BID]  : Endif
If !clalev([F:TCA])    : Local File TABCOUAFF   [TCA]  : Endif


Local Char    DEVLED(GLONCUR)                        : # Devise du référentiel général principal
Local Char    PLAN(GLONCOA), PLANA(GLONCOA)          : # Plans comptes référentiels principaux (général et ana)
Local Char    COMPTE(GLONGAC), CPTANA(GLONGAC)       : # Comptes référentiels principaux (général et ana)
Local Char    CODCPT(GLONCAC)

Local Integer NOLI, XSIGN, I, K, STAT, II
Local Integer INDAXE, INDAXI, AXE
Local Integer S_SENS
Local Decimal WBQE, MT, SMT, QTE, SQTE, ARQ, SOLDE

Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels
Return


$CONTROLE
Return

$EXEC
Gosub CREREG
Return

$CREREG
If !GSERVEUR
 Call OUVRE_TRACE(mess(10,8890,1))From LECFIC
Endif
Call SETPLAN([M:PCP]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
Call SETCUR(1,[M:PCP]CPY,DEVLED) From CPTDIV
GOK = 1 : STAT = 0
For NOLI=0 To [M:PCP]NBLIG-1
 ## Création des règlements : on s'occupe des ordres de paiements dont le règlement X3
 ## n'a pas encore été règlé ([M:PCP]FLGCRE<>2) et qui ont un niveau inférieur où égal
 ## à celui demandé (si la génération est demandé avec le niveau 'B', on traitera
 ## les ordres de paiements qui ont le niveau 'A' et 'B')
 If [M:PCP]FLGCRE(NOLI)<>2 & ([M:DIA]LEVEL="" | [M:PCP]LET(NOLI)<=[M:DIA]LEVEL)
  Gosub TR_GENER
  If GOK<1 | STAT : Break : Endif
 Endif
Next
Affzo [M:PCP]

# Lecture de la trace
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return


$TR_GENER
GOK = 1
Trbegin [PYH], [PYD], [PYA], [DUD], [RLD2]
 Readlock [RLD2]RLD0 = [M:PCP]FILNUM ; [M:PCP]TRFNUM ; [M:PCP]SEQNUM(NOLI) ; [M:PCP]LIN(NOLI)
 If fstat=1
  GOK=-1 : GLOCK="$RELMT940D"-[M:PCP]FILNUM-[M:PCP]TRFNUM-[M:PCP]SEQNUM(NOLI)-num$([M:PCP]LIN(NOLI)) : Goto ROLL_TR_GENER
 Elsif fstat
  GOK=0 : Call RSTA("RLD2",[M:PCP]FILNUM-[M:PCP]TRFNUM-[M:PCP]SEQNUM(NOLI)-num$([M:PCP]LIN(NOLI))) From GLOCK : Goto AB_TR_GENER
 Endif
 If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
  Readlock [DUD]DUD1 = [M:PCP]DUDNUM(NOLI) ; [M:PCP]DUDLIG(NOLI)
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE"-[M:PCP]DUDNUM(NOLI)-num$([M:PCP]DUDLIG(NOLI)) : Goto ROLL_TR_GENER
  Elsif fstat
   GOK=0 : Call RSTA("DUD",num$([M:PCP]DUDNUM(NOLI))-num$([M:PCP]DUDLIG(NOLI))) From GLOCK : Goto AB_TR_GENER
  Endif
  ## On contrôle que le solde de l'échéance (=montant restant à règler) est supérieur ou égal au montant de l'ordre
  ## de paiement (l'échéance a pu être règlé entre temps via la saisie de règlement X3 ou via le lettrage
  ## avec un avoir ou via le lettrage manuel avec une pièce de règlement, etc...)
  If !fstat & [F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR < [M:PCP]AMTCUR(NOLI)
   ## Solde de l'échéance supérieur au montant de l'ordre de paiement
   SOLDE = [F:DUD]AMTCUR-[F:DUD]TMPCUR-[F:DUD]PAYCUR
   Call ECR_TRACE(mess(1,292,1)-[M:PCP]NUM(NOLI)-format$(GFMDAT,[M:PCP]DUDDAT(NOLI))-"("+mess(3,40,1)-num$(NOLI+1)+")"-":"-
&                 +mess(224,117,1)-"("+num$(SOLDE)+")"-"<"-tolower(mess(225,117,1))-"("+num$([M:PCP]AMTCUR(NOLI))+")"
&                 +"\"+mess(226,117,1),1) From GESECRAN
   Goto AB_TR_GENER : # Rollback mais on laisse GOK à 1 pour traiter les autres ordres de paiements
  Endif
 Endif
 ## Destinations comptables par défaut
 Case [M:PCP]SIGN
  When -1
   Call PARAM([M:PCP]CPY,"DENSPG",GDIV(0)) From ADOVAL     : # Dépense
   Call PARAM([M:PCP]CPY,"DENINSSEN",GDIV(1)) From ADOVAL  : # Acompte émis (pour le moment inexploité. JLT: on ne gère pas les acomptes....)
   Call PARAM([M:PCP]CPY,"DENPAY",GDIV(2)) From ADOVAL     : # AR Discounts (pour le moment inexploité. JLT: on ne gère pas les escomptes....)
  When 1
   Call PARAM([M:PCP]CPY,"DENTAK",GDIV(0)) From ADOVAL     : # Recette
   Call PARAM([M:PCP]CPY,"DENINSRCP",GDIV(1)) From ADOVAL  : # Acompte reçu (pour le moment inexploité. JLT: on ne gère pas les acomptes....)
   Call PARAM([M:PCP]CPY,"DENDEP",GDIV(2)) From ADOVAL     : # AR Discounts (pour le moment inexploité. JLT: on ne gère pas les escomptes....)
 Endcase
 Call PARAM([M:PCP]CPY,"DENCRG",GDIV(5)) From ADOVAL : # Agios (pour le moment inexploité. JLT: on ne gère pas les agios....)

 STAT = 0
 nolign = NOLI+1
 Gosub CHARGE_PYH
 If STAT | !GOK : Goto AB_TR_GENER : Endif
 Gosub CHARGE_PYD
 If STAT | !GOK : Goto AB_TR_GENER : Endif

 Write [PYH]
 If fstat
  GOK=0 : Call FSTA("PYD") From GLOCK : Goto AB_TR_GENER
 Endif

 [M:PCP]FLGCRE(NOLI) = 2
 [M:PCP]NUMREG(NOLI) = [F:PYH]NUM

 [F:RLD2]FLGCRE = 2
 [F:RLD2]NUMREG = [F:PYH]NUM
 Rewrite [F:RLD2]
 If fstat
  GOK=0 : Call FSTA("RLD2") From GLOCK : Goto AB_TR_GENER
 Endif

 ## Création règlement [F:PYH]NUM
 If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
  Call ECR_TRACE(mess(3,61,1)-num$(NOLI+1)-","-mess(1,292,1)-[M:PCP]NUM(NOLI)-"("+format$(GFMDAT,[M:PCP]DUDDAT(NOLI))+")"-":"-
&                mess(92,117,1)-[F:PYH]NUM,0) From GESECRAN
 Else
  Call ECR_TRACE(mess(3,61,1)-num$(NOLI+1)-","-mess(78,117,1)-[M:PCP]BPRPAY(NOLI)-":"-
&                mess(92,117,1)-[F:PYH]NUM,0) From GESECRAN
 Endif
Commit
Return


$CHARGE_PYH
Raz [F:PYH]
[F:PYH] = [M:PCP]
[F:PYH]CPY    = [M:PCP]CPY
[F:PYH]BAN    = [M:PCP]BAN
[F:PYH]CUR    = [M:PCP]CUR
[F:PYH]BPRTYP = 1 # Client
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
If [F:PYH]PAYTYP = ""
 Call RECH_PAYTYP([M:PCP]SIGN(nolign-1),[M:PCP]PAM(nolign-1),[M:PCP]PAYTYP(nolign-1)) From PCPPROPO
 [F:PYH]PAYTYP = [M:PCP]PAYTYP(nolign-1)
Endif
If [F:PYH]PAYTYP = ""
 If [M:PCP]SIGN(nolign-1)=1
  # Aucune transaction de règlement type recette trouvée pour ce mode de règlement
  GOK = 0 : Call ECR_TRACE([M:PCP]PAM(nolign-1)-":"-mess(9,8890,1),1) From GESECRAN : Return
 Elsif [M:PCP]SIGN(nolign-1)=-1
  # Aucune transaction de règlement type dépense trouvée pour ce mode de règlement
  GOK = 0 : Call ECR_TRACE([M:PCP]PAM(nolign-1)-":"-mess(8,8890,1),1) From GESECRAN : Return
 Endif
Endif
Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
[F:PYH]SNS       = [F:TPY]SNS
[F:PYH]FRMFLG    = 3
If [M:PCP]FCY = ""
 [F:PYH]FCY = [M:PCP]FCYLIN(NOLI)
 If [F:PYH]FCY = "" ## car site à la ligne non renseigné... alors on génère le règlt sur le site principal
  Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
  If !fstat & [F:CPY]MAIFCY<>""
   [F:PYH]FCY = [F:CPY]MAIFCY
  Else
   ## Pas de site principal rattaché à la société
   GOK = 0 : Call ECR_TRACE(mess(68,107,1),1) From GESECRAN : Return
  Endif
 Endif
Endif
[F:PYH]STA       = 1
[F:PYH]STAFLG(0) = 1
[F:PYH]PST       = 1
[F:PYH]DES       = [M:PCP]DES(NOLI)
[F:PYH]ACCDAT    = [M:PCP]VALDAT(NOLI)
[F:PYH]BPR       = [M:PCP]BPRPAY(NOLI)

Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
If fstat : Return : Endif
If [F:BPR]BPCFLG=2
 Call LECTURE("BPC",[F:PYH]BPR,"") From CONTOBJ
 Call INIT_COMPTE([F:PYH]BPR,GSOCIETE,"C",CODCPT) From CPTSUB
 If [L]CODCPT<>"" & [F:BPC]BPCSTA=2
  Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
  Call LECTURE("GAC",[F:CAC]ACC(0),GPLAN(1)) From CONTOBJ
  If [F:GAC]AUZBPR(0)=2 : [F:PYH]BPRSAC=[F:GAC]ACCSHO : Endif
 Endif
Endif

Read [GAC]GAC1 = GPLAN(1);[F:PYH]BPRSAC
If !fstat
 [F:PYH]ACC = [F:GAC]ACC
Endif
[F:PYH]PAM       = [M:PCP]PAM(NOLI)
[F:PYH]AMTCUR    = [M:PCP]AMTCUR(NOLI)
[F:PYH]BILDAT    = [M:PCP]VALDAT(NOLI)
[F:PYH]DUDDAT    = [M:PCP]VALDAT(NOLI)
[F:PYH]ORIDAT    = [F:PYH]BILDAT  : # date d'origine
[F:PYH]VALDAT    = [M:PCP]VALDAT(NOLI)
If [F:PYH]BAN<>""
 Call LECTURE("BAN",[F:PYH]BAN,"") From CONTOBJ
 If [F:PYH]CUR = [F:BAN]CUR
  [F:PYH]AMTBAN = [F:PYH]AMTCUR
 Else
  Call CONVERT([F:PYH]CUR,[F:BAN]CUR,DEVLED,[F:TPY]RATTYP,[F:PYH]ACCDAT,[F:PYH]AMTCUR,[F:PYH]AMTBAN,STAT) From TRTDEV
  If [L]STAT
   # Pas de cours de devise [F:PYH]CUR -> [F:BAN]CUR
   Call ECR_TRACE(mess(16,114,1)-[F:PYH]CUR-"->"-[F:BAN]CUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
   GOK=0 : Return
  Endif
 Endif
Endif
Local Integer K
If [F:PYH]AMTBAN<>0
 Call SIGN2(1,[F:PYH]SNS,0,0,0,K) From PAYDIV
 If [F:PYH]SNS=1 : K*=-1 : Endif
 [F:PYH]BANPAYTPY=K*[F:PYH]AMTBAN
Else
 [F:PYH]BANPAYTPY=0
Endif
[F:PYH]CHQNUM    = ""
[F:PYH]CHQBAN    = "" : ## ????
[F:PYH]CRDTYP    = ""
[F:PYH]CRDNUM    = ""

If dim([F:PYH]CREDAT)>0 : [F:PYH]CREDAT=date$ : Endif
If dim([F:PYH]CREUSR)>0 : [F:PYH]CREUSR=GUSER : Endif
# Type de chèque
If find([F:TPY]DACCHQTYP,1,2)
 [F:PYH]CHQTYP = 1
Endif
# Type de remise
If find([F:TPY]DACFRMTYP,1,2)
 [F:PYH]FRMTYP = 1
Endif
[F:PYH]EXPNUM    = [C]EXPORT

If [M:PCP]BIDNUM(NOLI)<>""
 [F:PYH]BID = [M:PCP]BIDNUM(NOLI)
 Read [BID]BID0 = 1;[F:BPR]BPRNUM;[M:PCP]BIDNUM(NOLI)
 If !fstat
  [F:PYH]BIDCRY = [F:BID]CRY
  If [F:TPY]DACPAB1<>3 : [F:PYH]PAB1 = [F:BID]PAB1 : Endif
  If [F:TPY]DACPAB2<>3 : [F:PYH]PAB2 = [F:BID]PAB2 : Endif
 Endif
Else
 If [F:TPY]DACBID<>3
  Call LECTURE("BPR",[F:PYH]BPR,"") From CONTOBJ
  Local Char BIDCRIT (250)
  Local Integer TROUVE
  TROUVE=0
  #Recherche du rib en fonction du tiers et de son code adresse
  If [F:TPY]SNS>0 & [F:TPY]SNS<3
   CRITBID = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[F:BPR]BPRNUM+"'"
   CRITBID -=" & [F:BID]BPAADD ='"+[F:DUD]BPAPAY+"'"
   Filter [BID] Where evalue (CRITBID)
   Read [BID]BID0 First
   Filter [BID]
   If !fstat : TROUVE=1 : Endif
  Endif
  If !TROUVE
   # Rib par défaut
   Read [BID]BID0 = 1;[F:BPR]BPRNUM;[F:BPR]BIDNUM
   If fstat
    # Sinon le premier
    Read [BID]BID0(2) = 1;[F:BPR]BPRNUM
   Endif
  Endif
  If fstat<=2
   [F:PYH]BID    = [F:BID]BIDNUM
   [F:PYH]BIDCRY = [F:BID]CRY
   If [F:TPY]DACPAB1<>3 : [F:PYH]PAB1 = [F:BID]PAB1 : Endif
   If [F:TPY]DACPAB2<>3 : [F:PYH]PAB2 = [F:BID]PAB2 : Endif
  Endif
 Endif
Endif

# Recherche d'un numéro
Local Integer OKTCA
COMPTREG = ""
#KC Bug 56431 : chgmt de lecture en LECTCA from SUBTCA
#Call LECTURE("TCA","3","") From CONTOBJ
#If !fstat
Call GETSOC([F:PYH]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 If [F:PYH]SNS=1 : COMPTREG = [F:TCA]CODNUM(0)
 Else            : COMPTREG = [F:TCA]CODNUM(1)
 Endif
Endif
If COMPTREG="" : COMPTREG = "PY1" : Endif
Call NUMERO(COMPTREG,[F:PYH]FCY,[F:PYH]ACCDAT,[F:TPY]PAYTYP,[F:PYH]NUM,[L]STAT) From SUBANM
If [L]STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 Call ECR_TRACE(mess(60,199,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN
 Return
Endif
If STAT | GOK<1 : Return : Endif
Return


$CHARGE_PYD
Raz [F:PYD]
[F:PYD]NUM = [F:PYH]NUM
[F:PYD]LIN = 1
# Destination comptable
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 Case [F:DUD]TYP
  When "*SO","*PO" : [F:PYD]DENCOD   = GDIV(1) : # Normalement pas exploitée car acomptes gérés
  When Default     : [F:PYD]DENCOD   = GDIV(0)
 Endcase
Else
 [F:PYD]DENCOD   = GDIV(0)
Endif
GPOINT = "INIPYD" : Gosub ENTREE From EXEFNC
If GOK<>1 : Return : Endif

For I=1 To GNBPLAN
 Call LECLED([F:PYH]CPY,GTYPLED(I),[F:PYD]LED,DEVLED) From CPTDIV
 [F:PYD]COA = GPLAN(I)
Next

[F:PYD]ACCTYP   = 1         :# Banque <=> Tiers

## VCRTYP vide si acompte
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 Case [F:DUD]TYP
  When "*SO"   : [F:PYD]IPTTYP = 1
  When "*PO"   : [F:PYD]IPTTYP = 2
  When Default : [F:PYD]IPTTYP = 3
                 [F:PYD]VCRTYP = [F:DUD]TYP
 Endcase
Else
 [F:PYD]IPTTYP = 3
 [F:PYD]VCRTYP = ""
Endif

Call LEC_CPY([F:PYH]CPY) From CPTLEC
Call LEC_CDA_LEG([F:CPY]LEG,[F:PYD]DENCOD) From CPTLEC
[F:PYD]ACCSNS    = [F:CDA]ACCSNS
[F:PYD]FCYLIN    = [M:PCP]FCYLIN(NOLI)
If [F:PYD]FCYLIN="" & ([M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI))
 [F:PYD]FCYLIN = [F:DUD]FCY
Endif
If [F:PYD]FCYLIN=""
 [F:PYD]FCYLIN = [M:PCP]FCY
Endif
[F:PYD]CURLIN    = [M:PCP]CUR
[F:PYD]VCRNUM    = [M:PCP]NUM(NOLI)
[F:PYD]BPRINV    = [M:PCP]BPRINV(NOLI)
[F:PYD]AMTLIN    = [M:PCP]AMTCUR(NOLI)
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 [F:PYD]DUDNUM    = [M:PCP]DUDNUM(NOLI)
 [F:PYD]DUDLIG    = [M:PCP]DUDLIG(NOLI)
 [F:PYD]BPRSACINV = [F:DUD]SAC
Endif

[L]XSIGN = 0
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 S_SENS = [F:DUD]SNS
Else
 S_SENS = [M:PCP]SIGN(NOLI)
Endif
Call SNSPAYECH([F:PYD]ACCSNS,[F:PYH]SNS,S_SENS,[L]XSIGN) From SUBPAY2
[F:PYD]AMTLIN *= [L]XSIGN
[F:PYD]PAYCURLIN = [L]XSIGN*[F:PYD]AMTLIN
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 Call SIGN2([F:PYD]ACCSNS,[F:PYH]SNS,[F:DUD]ACCNUM,[F:DUD]DUDLIG,
&           [F:PYD]IPTTYP,[L]XSIGN) From PAYDIV
Else
 Call SIGN2([F:PYD]ACCSNS,[F:PYH]SNS,0,0,
&           [F:PYD]IPTTYP,[L]XSIGN) From PAYDIV
Endif
[F:PYD]AMTLIN2 = [F:PYD]AMTLIN * [L]XSIGN
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 If [F:PYH]CUR<>[F:DUD]CUR
  Call CONVERT([F:DUD]CUR,[F:PYH]CUR,DEVLED,[F:TPY]RATTYP,[F:PYH]ACCDAT,[F:PYD]AMTLIN2,
&              [F:PYD]AMTLIN2,[L]STAT) From TRTDEV
  If [L]STAT
   # Pas de cours de devise [F:DUD]CUR -> [F:PYH]CUR
   Call ECR_TRACE(mess(16,114,1)-[F:DUD]CUR-"->"-[F:PYH]CUR-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
   GOK=0 : Return
  Endif
 Endif
Endif

Gosub SET_PYD
If GOK<1 : Return : Endif

# En devise société
STATOK=0
If DEVLED=[F:PYD]CURLIN
 [F:PYD]PAYLOCLIN=[F:PYD]PAYCURLIN
 STATOK=1
Elsif DEVLED=[F:PYH]CUR
 [F:PYD]PAYLOCLIN=sgn([F:PYD]PAYCURLIN)*abs([F:PYD]AMTLIN2-[F:PYD]RITAMT2)
 STATOK=1
Else
 If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
  # Application du cours facture
  Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
  Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
  If [F:PYD]AMTLIN2<>0 & [F:TPY]RATINV=2 & [F:PYH]CUR=[F:DUD]CUR & [F:PYH]BAN<>""
   If [F:BAN]CUR=DEVLED or [F:BAN]CUR=[F:PYH]CUR
    Read [HAE3]HAE0 = [F:PYD]VCRTYP ; [F:PYD]VCRNUM
    If !fstat
     Call SETFLGDEV([F:HAE3]CUR,[F:PYH]CPY,[F:HAE3]RATDAT) From CPTDIV
     COURS  = [F:HAE3]RATMLT(GTYPGEN-1)/[F:HAE3]RATDIV(GTYPGEN-1)
     If COURS<>0
      STATOK = 1
      Call CONVERT3([F:PYD]CURLIN,DEVLED,DEVLED,[F:HAE3]TYPRAT,[F:HAE3]RATDAT,[F:PYD]PAYCURLIN,[F:PYD]PAYLOCLIN,
&                   COURS,STAT) From CPTSUB
      If STAT
       # Pas de cours de devises CURLIN -> DEVLED (à la date de la facture)
       GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-DEVLED-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
       GOK=0 : Return
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
If !STATOK
 Call CONVERT([F:PYD]CURLIN,DEVLED,DEVLED,[F:TPY]RATTYP,[F:PYH]ACCDAT,[F:PYD]PAYCURLIN,[F:PYD]PAYLOCLIN,STAT) From TRTDEV
 If STAT
  # Pas de cours de devises CURLIN -> DEVLED (ACCDAT)
  GMESSAGE=mess(16,114,1)-[F:PYD]CURLIN-"->"-DEVLED-"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")"
  GOK=0 : Return
 Endif
Endif

Write [PYD]
If fstat
 GOK=0 : Call FSTA("PYD") From GLOCK : Return
Endif

Gosub SET_PYA
If GOK<0 : Return : Endif

###################  GACCDUDATE
If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
 [F:DUD]TMPCUR += [F:PYD]PAYCURLIN
 [F:DUD]TMPLOC += [F:PYD]PAYLOCLIN
 Call SLDECH("DUD")From MODECHE
 Rewrite [F:DUD]
 If fstat
  GOK=0 : Call FSTA("DUD") From GLOCK : Return
 Endif
Endif

If GOK<>1 : Return : Endif
Return


########
$SET_PYD
########
If [F:CDA]ACCBPR<>"" : PLAN = GPLAN(1) : COMPTE = [F:CDA]ACCBPR
Else                 : PLAN = GPLAN(1) : COMPTE = [F:PYH]ACC
Endif
[PYD]BPRLIN = [F:PYH]BPR

If !instr(1,COMPTE,"x")
 Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
 If fstat
  # Destination comptable DENCOD : COMPTE Compte inexistant
  Call ECR_TRACE(mess(40,121,1)-[F:PYD]DENCOD-":"-COMPTE-"("+PLAN+")"+mess(22,116,1),1) From GESECRAN
  GOK = 0 : Return
 Elsif [F:GAC]SAC=2 & (([F:PYH]BPR="" & [F:PYD]ACCTYP=1) | (COMPTE<>"" & [F:PYD]BPRLIN=""))
  # Destination comptable DENCOD : COMPTE Type de compte incorrect
  Call ECR_TRACE(mess(40,121,1)-[F:PYD]DENCOD-":"-COMPTE-mess(59,106,1),1) From GESECRAN
  GOK = 0 : Return
 Else
  Call CONTACC(GTYPLED(I),PLAN,COMPTE,[F:PYH]FCY,"",[F:PYH]ACCDAT) From CPTCNT
 Endif
Endif

Gosub RECH_ACCANA
If CPTANA<>""
 If [F:PYD]ACCTYP=1 & ([M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI))
  If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
  Read [DAE]DAE2 = [F:DUD]ACCNUM
  If fstat=0 & [F:DAE]DSP<>"" : [F:PYD]DSP=[F:DAE]DSP : Endif
 Endif
 If !instr(1,CPTANA,"x")
  Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
  If [F:GAC]FLGUOM=2 & [F:GAC]VALUOM<>0
   MT = 0
   Call CONVERT([F:PYD]CURLIN,GCURSHR,DEVLED,GTYPCURSHR,[F:PYH]ACCDAT,[F:PYD]AMTLIN,MT,STAT) From TRTDEV
   If !STAT
    [F:PYD]QTYLIN = MT/[F:GAC]VALUOM
    Call AROQTE([F:PYD]QTYLIN,[F:GAC]UOM) From CPTINI
   Endif
  Endif
 Endif
Endif

COMPTE = evalue("[F:PYD]ACC("+num$(0)+")")
If [F:CDA]RPCVAT<2
 Raz [F:PYD]VATLIN
Else
 If [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
  [F:PYD]VATLIN = [F:DUD]VAT
 Endif
 If evalue("[F:PYD]ACC("+num$(0)+")")<>"" & !instr(1,COMPTE,"x")
  Call LECTURE("GAC",COMPTE,GPLAN(1)) From CONTOBJ
  If [F:GAC]FLGVAT<2 : Raz [F:PYD]VATLIN
  Elsif [F:PYD]VATLIN="" : [F:PYD]VATLIN=[F:GAC]VAT(0)
  Endif
 Endif
Endif
Return

$RECH_ACCANA
Local Char PLANA(GLONCOA), CPTANA(GLONGAC)
Local Char TPLAN(GLONCOA)(1..GNBPLAN), TCOMPTEX(GLONGAC)(1..GNBPLAN)
Local Integer II
For II=1 To GNBPLAN
 TPLAN(II)   = GPLAN(II)
 TCOMPTEX(II) = evalue("[F:PYD]ACC("+num$(II)+")")
Next
Call RECH_ACC(2,[F:PYH]CPY,GTYPLED,GNBPLAN,TPLAN,TCOMPTEX,PLANA,CPTANA) From CPTDIV
Return


########
$SET_PYA
########
If CPTANA="" : Return : Endif
If [F:GAC]FLGUOM=2
 If clalev([F:TUN])=0 : Local File TABUNIT [TUN] : Endif
 Call LECTURE("TUN",[F:GAC]UOM,"") From CONTOBJ
 ARQ = 10^(-[F:TUN]UOMDEC)
Endif

Case [F:PYD]DSP
 When ""
  K = 0
  If [F:PYD]ACCTYP=1 & [M:PCP]DUDNUM(NOLI)<>0 & [M:PCP]DUDLIG(NOLI)
   SMT = 0 : SQTE = 0
   If clalev([F:DAA])=0 : Local File GACCENTRYA [DAA]: Endif
   Read [DAE]DAE2 = [F:PYD]DUDNUM
   For [DAA]DAA0 Where TYP=[F:DUD]TYP & NUM=[F:DUD]NUM & LIN=[F:DAE]LIN & IDTLIN=[F:DAE]IDTLIN
    K += 1
    Raz [F:PYA]
    [F:PYA] = [F:PYH]
    [F:PYA] = [F:PYD]
    [F:PYA]LINANA = K
    MT=0 : QTE=0
    If [F:DAE]AMTCUR=[F:PYD]AMTLIN
     MT=[F:DAA]AMTCUR
    Elsif [F:DAE]AMTCUR<>0
     MT = arr(([F:DAA]AMTCUR+SMT)*[F:PYD]AMTLIN/[F:DAE]AMTCUR,ARD)
&        -arr(SMT*[F:PYD]AMTLIN/[F:DAE]AMTCUR,[F:TCU]CURRND)
     SMT += [F:DAA]AMTCUR
    Endif
    If [F:GAC]FLGUOM=2
     If [F:DAE]UOM=[F:GAC]UOM & [F:DAE]QTY=[F:PYD]QTYLIN
      QTE=[F:DAA]QTY
     Elsif [F:PYD]AMTLIN<>0
      QTE = arr((MT+SQTE)*[F:PYD]QTYLIN/[F:PYD]AMTLIN,ARQ)
&          -arr(SQTE*[F:PYD]QTYLIN/[F:PYD]AMTLIN,ARQ)
      SQTE += [F:DAA]QTY
     Endif
    Endif
    [F:PYA]AMTANA = MT
    [F:PYA]QTYANA = QTE
    For AXE=1 To GNBAXE
     Call INDLED([F:DAA]LED,GAXE(AXE),INDLED,INDAXI) From CPTDIV
     If INDAXI
      VU = find(GAXE(AXE),[F:DAA]DIE(0..dim([F:PYA]DIE)-1))
      If VU
       Assign "[F:PYA]DIE("+num$(AXE-1)+")" With [F:DAA]DIE(VU-1)
       Assign "[F:PYA]CCE("+num$(AXE-1)+")" With [F:DAA]CCE(VU-1)
      Endif
     Endif
    Next

    Write [PYA]
    If fstat
     GOK=0 : Call FSTA("PYA") From GLOCK : Break
    Endif
   Next
   If GOK<1 : Return : Endif
  Endif
  If K=0
   Raz [F:PYA]
   [F:PYA]=[F:PYH]
   [F:PYA]=[F:PYD]
   [F:PYA]LINANA = 1
   [F:PYA]AMTANA = [F:PYD]AMTLIN
   [F:PYA]QTYANA = [F:PYD]QTYLIN
   OK = 0

   For AXE=1 To GNBAXE
    [F:PYA]DIE(AXE-1) = GAXE(AXE)
    Call INDLED([F:PYD]LED,GAXE(AXE),INDLED,INDAXI) From CPTDIV
    If INDAXI
     # Init selon le code PAYMENTD
     Call CLIFOU([F:PYH]BPR,[F:PYH]COA,[F:PYH]ACC,[F:PYH]SNS,[L]BPRTYP) From PAYDIV
     Call INISEC([F:PYA]CCE(AXE-1),"PAYMENTD",GAXE(AXE),[L]BPRTYP) From PAYDIV

     # Init selon entête de facture/commande
     If [F:PYA]CCE(AXE-1)=""
      If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
      Call LECTURE("BIC",[F:PYD]VCRNUM,"") From CONTOBJ
      If fstat=0 & [F:SIH]GTE=[F:DUD]TYP
       INDAXE = find(GAXE(AXE),[F:SIH]DIE(0..dim([F:SIH]DIE)-1))
       If INDAXE
        [F:PYA]DIE(AXE-1) = GAXE(AXE)
        [F:PYA]CCE(AXE-1) = [F:SIH]CCE(INDAXE-1)
       Endif
      Endif
     Endif

     ## Si section de l'axe AXE-1 toujours pas initialisé, on essaye d'initialiser la section
     ## selon le compte du référentiel qui gère l'axe
     If [F:PYA]CCE(AXE-1)=""
      For NLED=1 To GNBPLAN
       Call INDLED([F:PYD]LED,GAXE(AXE),IND,AXI) From CPTDIV
       If IND & AXI
        If !instr(1,evalue("[F:PYD]ACC"+num$(NLED)),"x")
         Call LECTURE("GAC",evalue("[F:PYD]ACC("+num$(NLED)+")"),GPLAN(NLED)) From CONTOBJ
         SUIVI = find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
         If SUIVI
          [F:PYA]CCE(AXE-1) = [F:GAC]CCEDEF(SUIVI-1)
          If [F:PYA]CCE(AXE-1)<>"" : Break : Endif
         Endif
        Endif
       Endif
      Next
     Endif
    Endif
   Next AXE
   Write [PYA]
   If fstat
    GOK=0 : Call FSTA("PYA") From GLOCK
   Endif
  Endif
 When Default
  K = 0 : SUMPOI = 0
  If clalev([F:DSP])=0 : Local File CADSP [DSP] : Endif
  For [DSP]DSP0 Where DSP=[F:PYD]DSP
   SUMPOI += [F:DSP]COE
  Next
  SUMP = 0
  For [DSP]DSP0 Where DSP=[F:PYD]DSP
   K += 1
   Raz [F:PYA]
   [F:PYA]=[F:PYH]
   [F:PYA]=[F:PYD]
   [F:PYA]LINANA = K
   For AXE=1 To GNBAXE
    Call INDLED([F:PYD]LED,GAXE(AXE),INDLED,INDAXI) From CPTDIV
    If INDAXI
     VU = find(GAXE(AXE),[F:DSP]DIE(0..dim([F:DSP]DIE)-1))
     If VU
      [F:PYA]DIE(AXE-1) = GAXE(AXE)
      [F:PYA]CCE(AXE-1) = evalue("[F:DSP]CCE"+num$(VU))
     Endif
    Endif
   Next
   If SUMPOI<>0
    [F:PYA]AMTANA = arr([F:PYD]AMTLIN*(SUMP+[F:DSP]COE)/SUMPOI,ARD)
&                  -arr([F:PYD]AMTLIN*SUMP/SUMPOI,ARD)
    If [F:GAC]FLGUOM=2
     [F:PYA]QTYANA = arr([F:PYD]QTYLIN*(SUMP+[F:DSP]COE)/SUMPOI,AROQTE)
&                   -arr([F:PYD]QTYLIN*SUMP/SUMPOI,ARQ)
    Endif
    SUMP += [F:DSP]COE
   Endif
   Write [PYA]
   If fstat
    GOK=0 : Call FSTA("PYA") From GLOCK : Break
   Endif
  Next
Endcase
Return


$AB_TR_GENER
Rollback
Return

$ROLL_TR_GENER
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_GENER : Endif
