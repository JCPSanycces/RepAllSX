   If !clalev([F:PID])  Local File PINVOICED  [PID]  Endif
   If !clalev([F:PTH])  Local File PRECEIPT   [PTH]  Endif
   If !clalev([F:PTD])  Local File PRECEIPTD  [PTD]  Endif
   If !clalev([F:PTDW]) Local File PRECEIPTD [PTDW]  Endif :#--CPO DM 105661 Ajout de la sous-traitance
   If !clalev([F:PNH])  Local File PRETURN    [PNH]  Endif
   If !clalev([F:PND])  Local File PRETURND   [PND]  Endif
   If !clalev([F:PNDW]) Local File PRETURND  [PNDW]  Endif :#--CPO DM 105661 Ajout de la sous-traitance
   If !clalev([F:POH])  Local File PORDER     [POH]  Endif
