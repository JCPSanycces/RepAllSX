Raz [M:DIA]
[M:DIA]FLO=3

Return
#######################################################################
#--CPO 97978 Lors de la correction de cette fiche : nombre d'instructions trop important
$CONTROLE

#--- Si Regeneration --> pas de controle
If [M]REG = 2 Return Endif
#--- Si Nelle generation : controle de de la date
Filter [DER] Where (CPY=[M]CPY & DEBDAT>=[M]DEBDAT)
Read [DER]DER0 First
If fstat : Filter[DER] : Return
Else
  GERR=1
  GMESSAGE=mess(171,192,1) :# Une déclaration d'échange de biens correspondant à ces paramètres a déjà été réalisée
Endif
Filter [DER]
TMP=1
TIT=""

Return
#######################################################################
$EXEC_DECLA
#--CPO 97978 Lors de la correction de cette fiche : nombre d'instructions trop important
#--déplacement des déclarations dans FUNDEBA
Local Char    CRITERE(250)
Local Char    CRITERE2(250) # X3-88277 Intercompany transfer and Intrastat file (LCC 29/06/18)
Local Integer NBENR
Local Integer NBENRREG,NBENRNAT :#--CPO 74679
Local Integer JL0,JL1
Local Char    WCRY(GLONCRY), WCUR(GLONCUR)
Local Char    LCRY        (GLONCRY)              : # pour lecture table pays
Local Date    LDATE                              : # pour controle date
#--- Tableaux stockage données CEE des pays
NBENR=nbrecord([TCY])
Local Char    T_CRY       (GLONCRY)(NBENR)       : # Code pays
Local Char    T_EECCOD    (5)      (NBENR)       : # Code pays (codif CEE)
Local Date    T_EECDAT             (NBENR)       : # Date entrée CEE
#--- W_CRYFROM et W_CRYTO donnent le sens du flux physique
Local Char    W_CRYFROM   (GLONCRY)              : # Code pays depart (sens du flux physique)
Local Char    W_CRYTO     (GLONCRY)              : # Code pays arrivee  (sens du flux physique)
Local Date    W_DATE                             : # Date du mouvement (pour test entree CEE)
Local Char    W_FFWNUM    (GLONBPT)              : # Transitaire
Local Char    W_FFWADD    (3)                    : # Code adresse transitaire
Local Char    W_CRYFFW    (GLONCRY)              : # Code pays transitaire
Local Char    W_EECCRYFROM(GLONCRY)              : # Code pays CEE depart
Local Char    W_EECCRYTO  (GLONCRY)              : # Code pays CEE arrivee
Local Char    W_EECCRYFFW (GLONCRY)              : # Code pays CEE transitaire
Local Char    WCRYSOCEEC  (GLONCRY)              : # Code pays CEE de la société
Local Integer WOK                                : # Pièce non traitée DEB ? 0=non / 1=oui
Local Integer WOKLIG                             : # Lignes à traiter ( pour PTH et PNH )
Local Integer I, WFLO, SVGFLO, STAT
Local Decimal WFISAMT
Local Char    WUPDFIL     (10)                   : # Table active
Local Integer WUPDTYP                            : # type de maj
NBENR=nbrecord([PFI])
Local Integer PFI_NUM     (NBENR)
Local Integer PFI_CLCDEB  (NBENR)
NBENR=nbrecord([SFI])
Local Integer SFI_NUM     (NBENR)
Local Integer SFI_CLCDEB  (NBENR)
#------------
Local Integer SFI_DSPLIN  (NBENR)                : # En Ventes, les éléments de facturation répartis sur les lignes sont à retirer des éléments de pied, car ils serons pris à part
#--- Variables utilisée lors de la valorisation des pièces
Local Decimal WSTAAMT
Local Decimal WINVDTAAMT                         : # Somme des éléments de facturation dont CLCDEB = 2 (valeur fiscale et valeur statistique)
Local Decimal WINVDTAAMTVS                       : # Somme des éléments de facturation dont CLCDEB = 3 (uniquement sur valeur statistique)
Local Decimal WDISCRGAMT                         : # Somme des répartitions par ligne des éléments de facturation, en tenant compte de CLCDEB = 2 (valeur fiscale et valeur statistique)
Local Decimal WDISCRGAMTVS                       : # Somme des répartitions par ligne des éléments de facturation, en tenant compte de CLCDEB = 3 (valeur statistique uniquement)
Local Decimal WFACDTAAMT                         : # Montant des éléments de facturation non répartis, entrant dans la valeur fiscale et statistique
Local Decimal WFACDTAAMTVS                       : # Montant des éléments de facturation non répartis, entrant dans la valeur statistique uniquement
Local Decimal WFACDISCRG                         : # Somme des répartitions par ligne des éléments de facturation, en tenant compte de CLCDEB = 2 (valeur fiscale et valeur statistique)
Local Decimal WFACDISCRGVS                       : # Somme des répartitions par ligne des éléments de facturation, en tenant compte de CLCDEB = 3 (valeur statistique uniquement)
Local Decimal WFISAMTDTA                         : # Valeur fiscale suivant éléments de la facture (cas réception/livraison facturée)
Local Decimal WSTAAMTDTA                         : # Valeur statistique suivant éléments de la facture (cas réception/livraison facturée)
Local Decimal WTOTAMTNOT                         : # Calcul de la somme des montants HT des lignes
Local Decimal WTOTDTA
Local Decimal WTOTDTAVS
Local Decimal WTOTDISCRG
Local Decimal WTOTDISCRGVS
Local Decimal WMONTANT
Local Decimal WMONTANTVS
Local Decimal WKMONTANT
Local Decimal WRCPINVQTY                         : # Utilisé lors de la valo des reception de cdes facturées
Local Decimal WORDINVQTY                         : # Utilisé lors de la valo des reception de cdes facturées
Local Decimal WINVQTY                            : # Utilisé lors de la valo des reception de cdes facturées
Local Decimal WSAVFISAMTDTA
Local Decimal WSAVSTAAMTDTA
Local Integer WMAJ                               : # Permet la mise à jour de la facture/avoir si la valeur fiscale valorisée <> de celle de la pièce
Local Integer WLINSUP                            : # Une facture/avoir valorisée sera marquée comme traitée (EECNUMDEB) si elle n'a pas de lignes supp.
Local Integer WPASVALO                           : # Flag arrêt de la valorisation d'une pièce
Local Integer WTRNOK                             : # Gère le Commit/Rollback de la transaction
Local Char    W_NUM       (30)                   : # Var de travail lors de la valorisation des réceptions et/ou livraisons
Local Char    W_NUMPIECE  (30)                   : # Utilisée lors de la MAJ du champs EECNUMDEB dans les pièces
Local Integer W_NUMLINPIEC                       : # Utilisée lors de la MAJ du champs LINEECFLG dans les détails retour
Local Char    WNUMEROPIECE(30)
Local Char    WPIECE      (10)
Local Char    WDETAILPIECE(10)
Local Integer WNOLIGN
Local Integer WOKDETAIL
#--- Pour alimenter les pièces à l'origine des valorisations
Local Integer WNOLINVALO                         : # Ligne valorisée selon factures/avoirs
#--CPO 75397 Indice incorrect
#Local Char    WVCRNUMVALO (30)(15,100)           : # Numéro de pièce prise en compte lors de la valorisation
#Local Integer WVCRLINVALO (15,100)               : # Numéro de ligne de la pièce prise en compte
Local Integer NBLIGNESDET
#-- On initialise le nbr de lignes en fonction des codes activité de dimensionnement
NBLIGNESDET=max(100,func AFNC.ACTIV("SDH"),func AFNC.ACTIV("SIH"),func AFNC.ACTIV("SRH"),func AFNC.ACTIV("SOH"),
&                   func AFNC.ACTIV("PTH"),func AFNC.ACTIV("PIH"),func AFNC.ACTIV("PNH"))
Local Char    WVCRNUMVALO (30)(15,NBLIGNESDET)   : # Numéro de pièce prise en compte lors de la valorisation
Local Integer WVCRLINVALO     (15,NBLIGNESDET)   : # Numéro de ligne de la pièce prise en compte
#--CPO
#--- Compteurs lignes extraites Introduction/Expédition
Local Integer WNOLININT                          : # Compteur lignes introduction
Local Integer WOLDLININT                         : # Pour pouvoir retrouver le bon n° de ligne si rollback
Local Integer WNOLINEXP                          : # Compteur lignes expédition
Local Integer WOLDLINEXP                         : # Pour pouvoir retrouver le bon n° de ligne si rollback
Local Integer WTROUVE
Local Char    WKCRITERE(250)
Local Decimal W_MTTHTLIN                         : # Pour ne calculer qu'une fois le mtt Ht de la ligne
Local Char    WEECNAT(20)
Local Char    WEECSCH(20)
Local Integer WVALSTO
Local Integer WMVT
Local Integer WINDICE
#--CPO 74679 Amélioration de la trace
Local Char    WMESS_TRACE(250)
Local Integer WMESS_CODE
#--CPO
Local Libelle W_VCRTYP # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
#--CPO DM 105661 Ajout de la sous-traitance
Local Integer W_CHANGED_MVT
Local Integer W_ISEMPTY_EEC_SCH_NAT
Local Decimal WINVDTAAMT2
Local Decimal WINVDTAAMTVS2
Local Decimal WTMP_FISAMT,WTMP_FISAMTVS
Local Decimal W_MTTHTLINVS
Local Decimal WTMP_CONVERT
Local Integer WSAVE_WMVT
Local Integer W_LIG_COMPOSE
Local Decimal W_LIG_COMPOSE_QTY
Local Decimal W_LIG_COMPOSE_QTY_LIV
Local Decimal W_LIG_COMPOSE_QTY_RCP
Local Integer W_FOUND_NOTNULL
Local Integer W_ALREADY_READ
#--/
Return
###########################################################################################################
#--CPO 105661 Lors de la correction de cette fiche : nombre d'instructions trop important
#--déplacement des déclarations dans FUNDEBA
$EXEC_ALL

#------------
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC
Endif

#--- Chargement des paramètres tronc commun
Call GLOBVAR([M]CPY) From WWGLOBTC

#--CPO 74679 Bloc muté ici pour avoir les titres avant les nvx messages
If !GSERVEUR
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call PRTSCR("DDEB","DIA","",0,1)  From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif

#--- Chargement du pays et de la devise de la société traitée
Read [CPY]CPY0=[M]CPY
If !fstat
  WCRY=[F:CPY]CRY
  WCUR=[F:CPY]ACCCUR     :# Attention : si modification de cette dernière, il faut revoir les valos des lignes à 0 (exp. PRIORD dans devise de la société)
  GCURLEG=[F:CPY]LEG
  LCRY=WCRY : Gosub LEC_TCY From FUNDEB
  WCRYSOCEEC=[F:TCY]EECCOD
  #--CPO 74679 Amélioration de la trace
  #--   "Pays xxxx, code pays DEB non renseigné dans la fiche pays.
  #--    Des flux risquent de ne pas être extraits."
  If [F:TCY]EECCOD="" : WMESS_CODE=1 : WMESS_TRACE=WCRY : Gosub MESS_TRACE From FUNDEB : Endif
  #--CPO
Endif
#--- Tableaux contenant les Régimes et les Natures CEE
#--- utilisés pour acceder rapidement à la "Valeur de stock" pour chaque Régime et/ou Nature
#--- cela évite les lectures à répétition
#--- Régimes CEE
#--CPO 71937 Déclinaison multi-législation + remplacemant par TABEECSCH et TABEECNAT
#Filter [ADIW] Where NUMTAB=15 :# Uniquement la table diverse des Régimes (N° 15)
#NBENRREG=rowcount([ADIW])
#Local Char    REG_CODE(20)(NBENRREG)
#Local Integer REG_VALSTO(NBENRREG)
#Raz JL0
#For [ADIW]
#  REG_CODE(JL0)=[F:ADIW]CODE : REG_VALSTO(JL0)=[F:ADIW]N2
#  JL0 +=1
#Next
#Filter [ADIW]
Filter [F:TSC] Where (LEG="" or LEG=GCURLEG)
NBENRREG=rowcount([F:TSC])
Local Char    REG_CODE		(GLONTSC)(NBENRREG)
Local Char    REG_CODE_LEG(GLONADI)(NBENRREG)
Local Integer REG_VALSTO(NBENRREG)
Raz JL0
#--CPO 71937 Comme l'extraction se fait pour une société : on filtre les enreg avec leg="" ou leg=GCURLEG
For [TSC]
  REG_CODE	  (JL0)=[F:TSC]EECSCH
  REG_CODE_LEG(JL0)=[F:TSC]LEG
  REG_VALSTO  (JL0)=[F:TSC]VALSTO
  JL0 +=1
Next
Filter [F:TSC]
#--- Natures CEE
#Filter [ADIW] Where NUMTAB=6  :# Uniquement la table diverse des Natures (N° 6)
#NBENRNAT=rowcount([ADIW])
#Local Char    NAT_CODE(20)(NBENRNAT)
#Local Integer NAT_VALSTO(NBENRNAT)
#Raz JL0
#For [ADIW]
#  NAT_CODE(JL0)=[F:ADIW]CODE : NAT_VALSTO(JL0)=[F:ADIW]N2
#  JL0 +=1
#Next
#Filter [ADIW]
Filter [F:TEC] Where (LEG="" or LEG=GCURLEG)
NBENRNAT=rowcount([F:TEC])
Local Char    NAT_CODE		(GLONTEC)(NBENRNAT)
Local Char    NAT_CODE_LEG(GLONADI)(NBENRNAT)
Local Integer NAT_VALSTO(NBENRNAT)
Raz JL0
#--CPO 71937 Comme l'extraction se fait pour une société : on filtre les enreg avec leg="" ou leg=GCURLEG
For [TEC] Where (LEG="" or LEG=GCURLEG)
  NAT_CODE	  (JL0)=[F:TEC]EECNAT
  NAT_CODE_LEG(JL0)=[F:TEC]LEG
  NAT_VALSTO  (JL0)=[F:TEC]VALSTO
  JL0 +=1
Next
Filter [F:TEC]
#--/CPO
#--- Chargement tableaux pays
Raz JL0
For [TCY] Where EECFLG=2
  T_CRY(JL0)=[F:TCY]CRY : T_EECCOD(JL0)=[F:TCY]EECCOD : T_EECDAT(JL0)=[F:TCY]EECDAT
  #--CPO 74679 Amélioration de la trace
  #--   "Pays xxxx, code pays DEB non renseigné dans la fiche pays.
  #--    Des flux risquent de ne pas être extraits."
  If [F:TCY]EECCOD="" : WMESS_CODE=1 : WMESS_TRACE=[F:TCY]CRY : Gosub MESS_TRACE From FUNDEB : Endif
  #--CPO
  JL0 +=1
Next

#--CPO 74679 Amélioration de la trace
#-- "La table d'affectation des régimes et nature par flux n'est pas alimentée
#--  pour le pays d'extraction ou pour tous les pays en général."
Filter [DRN] Where find([F:DRN]CRY,WCRY,"")
If rowcount([F:DRN])=0 : WMESS_CODE=5 : Gosub MESS_TRACE From FUNDEB : Endif
Filter [DRN]
#-- "Les codes régimes et/ou nature utilisés dans la table d'affectation de ces derniers
#--  par flux sont différents de ceux définis dans les tables diverses."
Filter [DRN] Where !find([F:DRN]EECSCH,REG_CODE(0..NBENRREG-1)) & !find([F:DRN]EECSCHR,REG_CODE(0..NBENRREG-1))
&                      & [F:DRN]EECSCH<>[F:DRN]EECSCHR & !([F:DRN]EECSCH="" & [F:DRN]EECSCHR="")
If rowcount([F:DRN])>0 : WMESS_CODE=6 : Gosub MESS_TRACE From FUNDEB : Endif
Filter [DRN]
Filter [DRN] Where !find([F:DRN]EECNAT,NAT_CODE(0..NBENRNAT-1)) & !find([F:DRN]EECNATR,NAT_CODE(0..NBENRNAT-1))
&                      & [F:DRN]EECNAT<>[F:DRN]EECNATR & !([F:DRN]EECNAT="" & [F:DRN]EECNATR="")
If rowcount([F:DRN])>0 : WMESS_CODE=7 : Gosub MESS_TRACE From FUNDEB : Endif
Filter [DRN]
#--CPO

#--- Suppression des enregistrements DEB suivant critères
Call DEBTRANS From GLOCK

Trbegin [DEB]
If [M]REG=2         # Si Regénération
                    #- Sup dans table DEB tous les enregistrements ayant le code traitement à regénérer
  Delete [DEB] Where EECNUMDEB=[M]EECNUMDEB
Elsif [M]RAZDEB=2   # Si Purge
                    #- Sup dans la table DEB tous les enregistrements de la société
  Delete [DEB] Where CPY=[M]CPY
Endif
Commit
#--- Init tableaux de prise en compte des éléments de facturation
Raz I
For [PFI]  Where CLCDEB >  1
  PFI_NUM(I)=[F:PFI]PFINUM : PFI_CLCDEB(I)=[F:PFI]CLCDEB
  I +=1
Next
Raz I
For [SFI]  Where CLCDEB >  1
  SFI_NUM(I)=[F:SFI]SFINUM : SFI_CLCDEB(I)=[F:SFI]CLCDEB : SFI_DSPLIN(I)=[F:SFI]DSPLIN
  I +=1
Next
#--- Recherche d'un numéro de génération, le cas échéant
If [M]REG <> 2
  Gosub REC_EECNUMDEB From FUNDEB
  If GOK < 1 Return Endif
Endif

Raz WNOLININT
Raz WNOLINEXP
#--- Maj a partir des tables Achats
If GMODU(6)=2
  Gosub EEC_PTH From FUNDEB            : # Réceptions fournisseurs
  Gosub EEC_PNH From FUNDEB            : # Retours    fournisseurs
  # Pas de ttt des fact/avoirs, avec une exception : facture sur commande de ctm directe (sous certaines conditions)
  Gosub EEC_PIH  From FUNDEBA          : # Factures   fournisseurs (factures, avoirs)
Endif
#--- Maj a partir des tables Ventes
If GMODU(5)=2
  Gosub EEC_SDH From FUNDEB            : # Livraisons clients
                                       : # (classique, prêt, sous-traitance, inter-sites, inter-sociétés)
  Gosub EEC_SRH From FUNDEB            : # Retours    clients  (client, prêt)
  Gosub EEC_SIH From FUNDEB            : # Factures   clients  (factures, avoirs)
Endif

Return
#--/
###################################################################################################
$EEC_DEBGEN
#--CPO DM 105661 Ajout de la sous-traitance
#--Nombre instructions trop important

#----------------------------------------------------
# Pour assurer la cohérence des données,
# La transaction est gérée dans l'étiquette appelante
#----------------------------------------------------
Local Integer WNBLIGNONTRT
Local Decimal WTMPFISAMT,WTMPSTAAMT #--CPO 107173 Arrondi autres pays

WOK = 1
Raz WNBLIGNONTRT
Raz WTRNOK

WNOLIGN = nolign
For nolign = 1 To [M:DEBG]NBDEB
  #--- Si valeur fiscale après arrondi est nulle, on ne prend pas en compte la ligne
  #--- sauf si le paramètre général "EECEXTFREE" est à "Oui"
  WTMPFISAMT = [M:DEBG]FISAMT(nolign-1) #--CPO 107173 Arrondi autres pays
  If [M:DEBG]FISAMT(nolign-1)    : # valeur fiscale
    If mod([M:DEBG]FISAMT(nolign-1),int([M:DEBG]FISAMT(nolign-1))) = 0.5
      [M:DEBG]FISAMT(nolign-1) = arr([M:DEBG]FISAMT(nolign-1),1)-1
    Else
      [M:DEBG]FISAMT(nolign-1) = arr([M:DEBG]FISAMT(nolign-1),1)
    Endif
  Endif
  WTMPSTAAMT = [M:DEBG]STAAMT(nolign-1) #--CPO 107173 Arrondi autres pays
  If [M:DEBG]STAAMT(nolign-1)    : # valeur statistique
    If mod([M:DEBG]STAAMT(nolign-1),int([M:DEBG]STAAMT(nolign-1))) = 0.5
      [M:DEBG]STAAMT(nolign-1) = arr([M:DEBG]STAAMT(nolign-1),1)-1
    Else
      [M:DEBG]STAAMT(nolign-1) = arr([M:DEBG]STAAMT(nolign-1),1)
    Endif
  Endif
  #--- On ne peut pas avoir une valeur statistique négative
  #If [M:DEBG]STAAMT(nolign-1)<0 : [M:DEBG]STAAMT(nolign-1)=0 : Endif
  # If ([M:DEBG]FISAMT(nolign-1) <= 0) and (GEECEXTFREE=1) : WNBLIGNONTRT += 1 : Goto NEXT_EEC_DEBGEN : Endif
  #---On ne tient pas compte de EECEXTFREE dans le cas d'un gratuit
  #If ([M:DEBG]FISAMT(nolign-1)<0)or (([M:DEBG]FISAMT(nolign-1)=0) and (GEECEXTFREE=1))
  #CPO - vu avec CH : c'est le paramètre EECEXTFREE qui décide si on extrait une ligne à 0
  #If ([M:DEBG]FISAMT(nolign-1)<0)or (([M:DEBG]FISAMT(nolign-1)=0) and (GEECEXTFREE=1) and ([M:DEBG]FOCITM(nolign-1)<>2))
  #CPO - vu avec CH : il faut avoir les deux valeurs fiscale et statistique à comparer avec le paramétre
  If ([M:DEBG]STAAMT(nolign-1)<0) or ([M:DEBG]FISAMT(nolign-1)<0) or
&  (([M:DEBG]FISAMT(nolign-1)=0) and ([M:DEBG]STAAMT(nolign-1)=0) and (GEECEXTFREE=1))
    WNBLIGNONTRT += 1
    If [M]PRNULVAL=2
      Call ECR_TRACE(mess(735,197,1)-[M:DEBG]VCRNUM-mess(743,197,1)-mess(744,197,1)-num$([M:DEBG]VCRLIN(nolign-1))-mess(745,197,1),0) From GESECRAN
    Endif
    Goto NEXT_EEC_DEBGEN
  Endif
  #--- Un flux n'est pas extrait si le Régime et la Nature sont vides
  If [M:DEBG]EECSCH(nolign-1) = '' and  [M:DEBG]EECNAT(nolign-1) = ''
    WNBLIGNONTRT += 1
    If [M]PRNULREGNA=2
      Call ECR_TRACE(mess(735,197,1)-[M:DEBG]VCRNUM-mess(746,197,1)-mess(744,197,1)-num$([M:DEBG]VCRLIN(nolign-1))-mess(745,197,1),0) From GESECRAN
    Endif
    Goto NEXT_EEC_DEBGEN
  Endif
  # Call DEBTRANS From GLOCK
  Raz [F:DEB]
  #--- Renseignement des pièces utilisées pour la valorisation, le cas échéant
  Raz [M:DEBG]VCRNUMVALO
  Raz [M:DEBG]VCRLINVALO
  # If [M:DEBG]LINVALOFLG(nolign-1)=2
    For I=1 To dim(WVCRNUMVALO)
      If nolign-1>=NBLIGNESDET :#CPO 75397 100
        Call ECR_TRACE(num$(dim(WVCRNUMVALO))-[M:DEBG]VCRNUM-num$([M:DEBG]VCRLIN(nolign-1))-num$(I)-num$(nolign),0) From GESECRAN
        Break
      Endif
      If WVCRNUMVALO(I-1,nolign-1) = "" : Break : Endif
      [M:DEBG]VCRNUMVALO(I-1)= WVCRNUMVALO(I-1,nolign-1)
      [M:DEBG]VCRLINVALO(I-1)= WVCRLINVALO(I-1,nolign-1)
    Next
  # Else
      # Raz [M:DEBG]VCRNUMVALO
      # Raz [M:DEBG]VCRLINVALO
  # Endif

  #--CPO 107173 Arrondi autres pays
  [M:DEBG]FISAMT(nolign-1) = WTMPFISAMT
  [M:DEBG]STAAMT(nolign-1) = WTMPSTAAMT
  #--/
  [F:DEB] = [M:DEBG]
  #FQ 52782
  If dim([F:DEB]EXPNUM)>0
    [F:DEB]EXPNUM=[C]EXPORT
  Endif
  #--- Pour assurer la continuité (avant V6 - utilisation de la var WUPDTYP)
  #--- traitement V6 : utilisation de WUPDFIL
  If WUPDFIL="SIH"
    If [M:DEBG]FLO(nolign-1)=2
      WUPDTYP=22          :# Expédition   Ventes
    Elsif [M:DEBG]FLO(nolign-1)=1
      WUPDTYP=12          :# Introduction Ventes
    Endif
  Endif

  Local Integer SPSTAT
  Call DEB (WUPDTYP,SPSTAT) From =GVARCTLPRG
  If SPSTAT>0 : WNBLIGNONTRT += 1 : Goto NEXT_EEC_DEBGEN : Endif

  #--- Spanish Intrastat declaration SAM# 82698
  Gosub PORT From FUNDEBSPA

  #--- Portuguese Intrastat declaration SAM# 88323
  Gosub SET_REGION From FUNDEBPOR

  Local Integer SAUVGPE     : SAUVGPE=GPE : GPE=0
  GPOINT="DEBMAJ" : Gosub ENTREE From EXEFNC
  If GPE : GPE=SAUVGPE : WNBLIGNONTRT += 1 : Goto NEXT_EEC_DEBGEN : Endif :#  Return : Endif

  #--- Fait ici car dépend du retour des appels des points d'entrée
  # Incrémentation numéro ligne DEB
  If [F:DEB]FLO=1      :# Introduction
    WNOLININT += 1
    [F:DEB]DEBLIN = WNOLININT
  Elsif [F:DEB]FLO = 2 :# Expédition
    WNOLINEXP += 1
    [F:DEB]DEBLIN = WNOLINEXP
  Endif

  Write [DEB]
  If fstat
    Call RSTA("DEB",num$([F:DEB]VCRTYP)-[F:DEB]VCRNUM-num$([F:DEB]VCRLIN)) From GLOCK
    WTRNOK = 1 : Break
  Endif

$NEXT_EEC_DEBGEN
Next

nolign = WNOLIGN
If WTRNOK
  WOK = 0
  Return
Endif
#--- Si aucune ligne n'a donné lieu à un enregistrement DEB
If WNBLIGNONTRT = [M:DEBG]NBDEB
  WOK = 0
  Return
Endif
#--- Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
Raz WVCRNUMVALO
Raz WVCRLINVALO

Return
$ACH_TOTDTA
#--Nombre instructions trop important
#--CPO DM 105661 Ajout de la sous-traitance

#--- Somme des éléments de facturation non répartis sur les lignes
# Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
# Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
# a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
# puis répartition sur les lignes, au prorata des montants de chaque ligne
Raz WTOTDTA
Raz WTOTDTAVS
Raz JL0
If WNUMEROPIECE <> ""
  # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
  #For [PVF] PVF1 Where find(VCRTYP,6,7,8)<>0 & VCRNUM = WNUMEROPIECE
  For [PVF] PVF1 Where find(VCRTYP,6,7,8)<>0 & VCRNUM = WNUMEROPIECE and VCRTYP=W_VCRTYP
  # End issue 110289
    If find([F:PVF]INVLINFLG,1,6)
      JL0=find([F:PVF]INVDTA,PFI_NUM)
      If JL0
        #--- Dans : Valeur fiscale et valeur statistique
        If PFI_CLCDEB(JL0-1)=2
          WTOTDTA   += [F:PVF]INVDTAAMT
          WTOTDTAVS += [F:PVF]INVDTAAMT
        Endif
        #--- Uniquement dans la valeur statistique
        If PFI_CLCDEB(JL0-1)=3
          WTOTDTAVS += [F:PVF]INVDTAAMT
        Endif
      Endif
    Endif
  Next
Endif

Return
#----------------------------------------------------------------------
$ACH_TOTDISCRG
#--Nombre instructions trop important
#--CPO DM 105661 Ajout de la sous-traitance

#--- Somme des éléments de facturation répartis sur la ligne
# Attention :
# Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
# De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
Raz WTOTDISCRG
Raz WTOTDISCRGVS
Raz JL0
If WPIECE <> "" and WDETAILPIECE <> ""
  For I=0 To evalue("dim("+"[F:"+WPIECE+"]"+"INVDTALIN2"+")")-1
    If evalue("[F:"+WPIECE+"]"+"INVDTALIN2"+"("+num$(I)+")") > 0
      JL0=find(evalue("[F:"+WPIECE+"]"+"INVDTALIN2"+"("+num$(I)+")"),PFI_NUM)
       #--- L'élément de facturation doit être pris en compte :
       If JL0 & evalue("dim("+"[F:"+WDETAILPIECE+"]"+"DISCRGAMT"+num$(I+1)+")") > 0
        #--- Dans : Valeur fiscale et valeur statistique
        If PFI_CLCDEB(JL0-1)=2
          WTOTDISCRG   += evalue("[F:"+WDETAILPIECE+"]"+"DISCRGAMT"+num$(I+1))
          WTOTDISCRGVS += evalue("[F:"+WDETAILPIECE+"]"+"DISCRGAMT"+num$(I+1))
        Endif
        #--- Uniquement dans la valeur statistique
        If PFI_CLCDEB(JL0-1)=3
          WTOTDISCRGVS += evalue("[F:"+WDETAILPIECE+"]"+"DISCRGAMT"+num$(I+1))
        Endif
      Endif
    Endif
  Next I
Endif

Return
########################################################################
$VEN_TOTDTA
#--Nombre instructions trop important
#--CPO DM 105661 Ajout de la sous-traitance

#--- Somme des éléments de facturation non répartis sur les lignes
Raz WTOTDTA, WTOTDTAVS, JL0
If WNUMEROPIECE <> ""
  # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
  #For [SVF]SVF0 Where VCRNUM = WNUMEROPIECE
  For [SVF]SVF0 Where VCRNUM = WNUMEROPIECE and VCRTYP = W_VCRTYP
  # End issue 110289
    #--- Nous devons tester si l'élément trouvé doit être réparti sur les lignes (champ DSPLIN de SVCRFOOT)
    JL0=find([F:SVF]DTA,SFI_NUM)
    If JL0
      #--- On prend en compte que les éléments non répartis
      If SFI_DSPLIN(JL0-1) < 2
        #--- Dans : Valeur fiscale et valeur statistique
        If SFI_CLCDEB(JL0-1)=2
          WTOTDTA   += [F:SVF]DTANOT
          WTOTDTAVS += [F:SVF]DTANOT
        Endif
        #--- Uniquement dans la valeur statistique
        If SFI_CLCDEB(JL0-1)=3
          WTOTDTAVS += [F:SVF]DTANOT
        Endif
      Endif
    Endif
  Next
Endif

Return
#----------------------------------------------------------------------
$VEN_TOTDISCRG
#--Nombre instructions trop important
#--CPO DM 105661 Ajout de la sous-traitance

#--- Somme des éléments de facturation répartis sur la ligne
Raz WTOTDISCRG
Raz WTOTDISCRGVS
Raz JL0
If WPIECE <> ""
  For I=0 To evalue("dim("+"[F:"+WPIECE+"]"+"DDTANUM"+")")-1 :#valeurs WPIECE : SID, SDD
    If evalue("[F:"+WPIECE+"]"+"DDTANUM"+"("+num$(I)+")") > 0
      JL0=find(evalue("[F:"+WPIECE+"]"+"DDTANUM"+"("+num$(I)+")"),SFI_NUM)
      #--- L'élément de facturation doit être pris en compte :
      If JL0 and SFI_DSPLIN(JL0-1)>1 and evalue("dim("+"[F:"+WPIECE+"]"+"DDTANOT"+"("+num$(I)+")"+")") > 0
        #--- Dans : Valeur fiscale et valeur statistique
        If SFI_CLCDEB(JL0-1)=2
          WTOTDISCRG   += evalue("[F:"+WPIECE+"]"+"DDTANOT"+"("+num$(I)+")")
          WTOTDISCRGVS += evalue("[F:"+WPIECE+"]"+"DDTANOT"+"("+num$(I)+")")
        Endif
        #--- Uniquement dans la valeur statistique
        If SFI_CLCDEB(JL0-1)=3
          WTOTDISCRGVS += evalue("[F:"+WPIECE+"]"+"DDTANOT"+"("+num$(I)+")")
        Endif
      Endif
    Endif
  Next I
Endif

Return
#######################################################################
# Ventes : Factures clients
#          ( factures, avoirs )
#----------------------------------------------------------------------
$EEC_SIH

WUPDFIL="SIH" : WFLO = 2 :# Expédition
WUPDTYP=22 :# Expédition Ventes - utilisé dans les points d'entrée (conformité versions antérieures)

Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(625,197,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE  = '[F:SIH]ACCDAT<=[M]DEBDAT'                : # Date comptable < ou = a selection
CRITERE += '&[F:SIH]ORIMOD=5'                      : # Factures du module ventes
CRITERE += '&[F:SIH]CPY=[M]CPY'
CRITERE += '&[F:SIH]INVTYP<3'                    : # Uniquement les Factures et les Avoirs
CRITERE += '&[F:SIH]STA=3'                       : # Uniquement les pièces validées

If [M]REG=2
  CRITERE += '&([F:SIH]EECNUMDEB=[M]EECNUMDEB|[F:SIH]EECNUMDEB=0)'
Else
  #--CPO 105671
  #CRITERE += '& [F:SIH]EECNUMDEB=0'
  CRITERE += '&([F:SIH]EECNUMDEB=0|([F:SIH]INVTYP=2&[F:SIH]EECNUMDEB=[M]EECNUMDEB))'
Endif

Gosub ALIFILSUP From FUNDEB

# For [SIH]SIH7 Where (evalue(CRITERE) & evalue(FILSUP))
#--- Afin de lire les pièces dans l'ordre
Filter [SIH] Where (evalue(CRITERE) & evalue(FILSUP)) Order By ACCDAT Asc;NUM Asc
For [SIH]
  # Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
  Raz WVCRNUMVALO
  Raz WVCRLINVALO
  If [F:SIV]NUM <> [F:SIH]NUM
    Read [SIV]SIV0=[F:SIH]NUM
    If fstat : Raz [F:SIV] : Goto NEXT_SIH : Endif
  Endif

  #--CPO 105671
  #--Cas d'un avoir sur retour
  #--Lors de la valorisation du retour avec les elts de l'avoir, et si l'avoir
  #--porte uniquement sur le retour et les mtts de l'avoir <> du retour
  #--le EECNUMDEB de l'avoir est positionné au [M]EECNUMDEB de l'extraction courante
  #--du coup, l'avoir en régul ne sortait pas lors de la première extraction, il fallait regénérer
  #--Correction faite : ajout d'un cas particulier dans CRITERE dans EEC_SIH portant sur les avoirs
  #--Ici, il faut êtr sûrs de passer uniquement dans ce cas précis, sinon, on passe au doc suivant
  If [M]REG<>2 and [F:SIH]EECNUMDEB<>0 and ([F:SIH]INVTYP<>2 or ([F:SIH]INVTYP=2 and [F:SIV]SIHORI<>6))
    Goto NEXT_SIH
  Endif
  #--/105671
  #--- Uniquement les origines : Directe, Commande, Livraison, Facture, Devis, Retour
  # X3-88277 Intercompany transfer and Intrastat file (LCC 29/06/18)
  #If [F:SIV]SIHORI > 6 : Goto NEXT_SIH : Endif
  CRITERE2="[F:SIV]SIHORI > 6"
  GPOINT="FILSIH" : Gosub ENTREE From EXEFNC
  If evalue(CRITERE2): Goto NEXT_SIH : Endif
  # End X3-88277 Intercompany transfer and Intrastat file (LCC 29/06/18)
  #--- Si Régime et Nature sont vides, la ligne n'est pas extraite
  If [F:SIV]EECSCH="" and [F:SIV]EECNAT="" and [F:SIV]EECSCHR="" and [F:SIV]EECNATR=""
    If [M]PRNULREGNA=2
      Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-mess(746,197,1),0) From GESECRAN
    Endif
    Goto NEXT_SIH
  Endif

  Gosub CTL_EEC From FUNDEB
  If WOK=0 : Goto NEXT_SIH : Endif

  # Afin de retrouver les bons numéros en cas de rollback
  WOLDLININT = WNOLININT
  WOLDLINEXP = WNOLINEXP
  Call DEBTRANS From GLOCK
  Raz WTRNOK
  Trbegin [DEB]

  #--- Somme des éléments de facturation non répartis sur les lignes
  WNUMEROPIECE = [F:SIH]NUM
  W_VCRTYP=4 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
  Gosub VEN_TOTDTA From FUNDEB
  WINVDTAAMT   = WTOTDTA
  WINVDTAAMTVS = WTOTDTAVS
  Raz WNUMEROPIECE
  Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
  #--- Prise en compte des éléments de l'entête de pièce, puis de chaque ligne de détail
  Gosub EEC_UN_SIH From FUNDEB
  If WOK=0 : Gosub AB_DEB From FUNDEB : Goto NEXT_SIH : Endif
  #--- Ecriture des éléments du masque DEBGEN dans le fichier DEB
  Gosub EEC_DEBGEN From FUNDEB
  If WOK=0 : Gosub AB_DEB From FUNDEB : Goto NEXT_SIH : Endif
  #--- On met à jour le champ EECNUMDEB si l'écriture dans le fichier DEB a réussi
  # Uniquement si au moins une ligne a été renseignée dans le masque de génération
  If [M:DEBG]NBDEB > 0
    W_NUMPIECE = [F:SIH]NUM
    If W_NUMPIECE <> ""
      #--- Maj no traitement dans la pièce
      Update [SIH] Where NUM = W_NUMPIECE With EECNUMDEB = [M]EECNUMDEB
      If fstat
        Call FSTA("SIH") From GLOCK
        Gosub AB_DEB From FUNDEB
        Goto NEXT_SIH
      Endif
    Endif
    Raz W_NUMPIECE
  Else
    Gosub AB_DEB From FUNDEB
    Goto NEXT_SIH
  Endif

  Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(741,197,1),0) From GESECRAN

  Commit
$NEXT_SIH
Next
Filter [SIH]

Return
#----------------------------------------------------------------------
$EEC_UN_SIH
WOK=1
WOKLIG=1

nolign=0
If [F:SIV]NUM <> [F:SIH]NUM
  Read [SIV]SIV0=[F:SIH]NUM
  If fstat : WOK = 0 : Raz [F:SIV] : Return : Endif
Endif
Case [F:SIH]INVTYP
  When 1       :  WMVT=15 : Gosub EEC_UN_SIH_FAC From FUNDEB : # Traitement des Factures / Factures Complémentaires
  When 2       :  WMVT=16 : Gosub EEC_UN_SIH_AVR From FUNDEB : # Traitement des Avoirs / Avoirs pour retour
  When Default :  WOK = 0 : Return                           : # Les autres types de factures ne seront pas pris en compte
Endcase
If WOK = 0 : Return : Endif

Return
#----------------------------------------------------------------------
$EEC_UN_SIH_FAC
#--- Traitement des Factures
If [F:SIH]INVTYP <> 1 : WOK = 0 : Return : Endif
#Filter [SID] Where NUM=[F:SIH]NUM Order By SIDLIN Asc
#For [SID]
For [SID]SID0 Where NUM=[F:SIH]NUM
  WOKLIG = 1 :#--CPO 97006
  #--CPO 106690 Cas de deux lignes de type "divers", n'ayant pas d'article et qui se suivent
  If [F:SID]ITMREF="" :  Goto NEXT_UN_SIH_FAC : Endif
  #--/
  If [F:ITM]ITMREF <> [F:SID]ITMREF
    Read [F:ITM]ITM0=[F:SID]ITMREF
    If fstat : Raz [F:ITM] : Goto NEXT_UN_SIH_FAC : Endif
  Endif
  #--- Si l'article n'est pas "Soumis à la DEB", on saute la ligne de détail
  If [F:ITM]EECGES <> 2
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=3 : WMESS_TRACE=mess(735,197,1)-[F:SID]NUM-num$([F:SID]SIDLIN)-[F:ITM]ITMREF : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_UN_SIH_FAC
  Endif

  #--CPO DM 105661 Ajout de la sous-traitance
  #---on extrait uniquement les lignes de type "Nomenclature composé"
  #---et celles "Standard"
  If find([SID]LINTYP,11,12,13)>0
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=4 : WMESS_TRACE=mess(735,197,1)-[F:SID]NUM-num$([F:SID]SIDLIN) : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_UN_SIH_FAC
  Endif
  #--/

  #FQ 56398 (suite de 51074) - Point d'entrée pour gérer des contrôles à la ligne
  Local Integer SAUVGPE     : SAUVGPE=GPE : GPE=0
  #La variable GPE permet d'accepter ou de refuser la ligne
  # 0 -> la ligne est acceptée
  # 1 -> la ligne est refusée, on passe à la suivante
  GPOINT="DEBCTLLIG" : Gosub ENTREE From EXEFNC
  If GPE : GPE=SAUVGPE : Goto NEXT_UN_SIH_FAC : Endif
  #FQ 56398

  nolign +=1
  #--- Chargement du masque avec les éléments de la ligne
  Case [F:SIV]SIHORI
    When 1       :  Gosub DEBG_SIH_FAC_DIR From FUNDEB : # Origine directe
    When 2       :  Gosub DEBG_SIH_FAC_CDE From FUNDEB : # Origine commande
    When 3       :  Gosub DEBG_SIH_FAC_LIV From FUNDEB : # Origine livraison - Uniquement les lignes supplémentaires
    When Default :  WOK = 0 : Break
  Endcase
  If WOK    = 0 : Break : Endif
  If WOKLIG = 0
    # Pour bien renseigner l'entête du masque DEBG
    nolign -= 1
    Goto NEXT_UN_SIH_FAC
  Endif
  #--- Maj flag LINEECFLG dans les détails de la pièce Facture
  If [F:SIH]NUM <> ""
    W_NUMPIECE = [F:SIH]NUM
    W_NUMLINPIEC = [F:SID]SIDLIN
    Update [SID] Where NUM = W_NUMPIECE and SIDLIN = W_NUMLINPIEC With LINEECFLG = 2
    If fstat : Call FSTA("SID") From GLOCK : WOK = 0 : Break : Endif
    Raz W_NUMPIECE
    Raz W_NUMLINPIEC
  Endif

$NEXT_UN_SIH_FAC
Next
#Filter [SID]

If WOK = 0 : Return : Endif
If nolign = 0 : WOK = 0 : Return : Endif

Return
#----------------------------------------------------------------------
$EEC_UN_SIH_AVR
#--- Traitement des Avoirs
If [F:SIH]INVTYP <> 2 : WOK = 0 : Return : Endif

For [SID]SID0 Where NUM=[F:SIH]NUM
  WOKLIG = 1 :#--CPO 97006
#Filter [SID] Where NUM=[F:SIH]NUM Order By SIDLIN Asc
#For [SID]
  #--CPO 106690 Cas de deux lignes de type "divers", n'ayant pas d'article et qui se suivent
  If [F:SID]ITMREF="" :  Goto NEXT_UN_SIH_AVR : Endif
  #--/
  If [F:ITM]ITMREF <> [F:SID]ITMREF
    Read [F:ITM]ITM0=[F:SID]ITMREF
    If fstat : Raz [F:ITM] : Goto NEXT_UN_SIH_AVR : Endif
  Endif
  #--- Si l'article n'est pas "Soumis à la DEB", on saute la ligne de détail
  If [F:ITM]EECGES <> 2
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=3 : WMESS_TRACE=mess(735,197,1)-[F:SID]NUM-num$([F:SID]SIDLIN)-[F:ITM]ITMREF : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_UN_SIH_AVR
  Endif

  #--CPO DM 105661 Ajout de la sous-traitance
  #---on extrait uniquement les lignes de type "Nomenclature composé"
  #---et celles "Standard"
  If find([SID]LINTYP,11,12,13)>0
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=4 : WMESS_TRACE=mess(735,197,1)-[F:SID]NUM-num$([F:SID]SIDLIN) : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_UN_SIH_AVR
  Endif
  #--/

  #FQ 56398 (suite de 51074) - Point d'entrée pour gérer des contrôles à la ligne
  Local Integer SAUVGPE     : SAUVGPE=GPE : GPE=0
  #La variable GPE permet d'accepter ou de refuser la ligne
  # 0 -> la ligne est acceptée
  # 1 -> la ligne est refusée, on passe à la suivante
  GPOINT="DEBCTLLIG" : Gosub ENTREE From EXEFNC
  If GPE : GPE=SAUVGPE : Goto NEXT_UN_SIH_AVR : Endif
  #FQ 56398

  nolign +=1
  #--- Chargement du masque avec les éléments de la ligne
  Case [F:SIV]SIHORI
    When 1       :  Gosub DEBG_SIH_AVR_DIR From FUNDEB : # Origine directe
    When 4       :  Gosub DEBG_SIH_AVR_FAC From FUNDEB : # Origine facture
    When 6       :  Gosub DEBG_SIH_AVR_RET From FUNDEB : # Origine retour
    When Default :  WOK = 0 : Break                    : # Autre
  Endcase
  If WOK    = 0 : Break : Endif
  If WOKLIG = 0
    # Pour bien renseigner l'entête du masque DEBG
    nolign -= 1
    Goto NEXT_UN_SIH_AVR
  Endif
  #--- Maj flag LINEECFLG dans les détails de la pièce Avoir
  If [F:SIH]NUM <> ""
    W_NUMPIECE = [F:SIH]NUM
    W_NUMLINPIEC = [F:SID]SIDLIN
    Update [SID] Where NUM = W_NUMPIECE and SIDLIN = W_NUMLINPIEC With LINEECFLG = 2
    If fstat : Call FSTA("SID") From GLOCK : WOK = 0 : Break : Endif
    Raz W_NUMPIECE
    Raz W_NUMLINPIEC
  Endif

$NEXT_UN_SIH_AVR
Next
#Filter [SID]

If WOK = 0 : Return : Endif
If nolign = 0 : WOK = 0 : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_FAC_DIR
#--- Chargement du masque avec les éléments de la ligne de Facture avec Origine Directe

Gosub DEBG_SIH_FAC From FUNDEB
If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_FAC_CDE
#--- Chargement du masque avec les éléments de la ligne de Facture avec Origine Commande

#--- Les factures ayant cette origine ont toujours le flag STOMVTFLG à "Oui"
If [F:SIV]STOMVTFLG = 1 : WOK = 0 : Return : Endif

Gosub DEBG_SIH_FAC From FUNDEB
If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_FAC_LIV
#---Chargement du masque avec les éléments de la ligne de Facture avec Origine Livraison

If [F:SID]SDHNUM = "" and [F:SID]SDDLIN = 0
  #---Ligne directe
  Gosub DEBG_SIH_FAC From FUNDEB
Else
  #--- Ligne issue de livraison
  #--- Si Facture de prêt, il y a DEB sur la ligne de facture
  #--- si la Livraison de prêt n'a pas fait l'objet d'une DEB auparavant
  # (le cas si le règime CEE de la livr. n'a pas été renseigné)
  Read [F:SDH]SDH0=[F:SID]SDHNUM
  If fstat : WOKLIG=0 : Raz [F:SDH] : Return : Endif
  If [F:SDH]LND=2 and [F:SDH]EECNUMDEB = 0
    WMVT=17
    Gosub DEBG_SIH_FAC From FUNDEB : # Factures de prêt
  Else
    #-----------------------------------
    #--Evite de prendre en compte les livraisons extraites qui contiennent
    #--dans la liste des pièces valorisées, la facture en cours
    #(si mtt facture identique à la livraison donc la facture n'a pas été marquée avec le n° d'extraction de la livraison)
    If [F:SDH]EECNUMDEB<>0 and [F:SDH]EECNUMDEB<>[M]EECNUMDEB
      Look [F:DEB]DEB1=[M:DIA]CPY;4;[F:SID]SDHNUM;[F:SID]SDDLIN;2
      If !fstat
        Read [F:DEB]DEB1 Curr
        If fstat : Raz [F:DEB] : Endif
        WINDICE=find([F:SID]NUM,[F:DEB]VCRNUMVALO)
        If (WINDICE<=0) or (WINDICE>0 and !find([F:SID]SIDLIN,[F:DEB]VCRLINVALO(WINDICE-1)))
          #Message : "Pièce xxxx créée, alors que le flux d'origine a été déclaré"
          Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-mess(744,197,1)-num$([F:SID]SIDLIN)-mess(748,197,1)
&                 -mess(129,197,1)-[F:SDH]SDHNUM,0) From GESECRAN
        Endif
      Endif
    Endif
    #-----------------------------------
    WOKLIG=0 : Return
  Endif
Endif
If WOKLIG=0 : Return : Endif
If WOK=0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_FAC
#--- Chargement du masque avec les éléments de la ligne de Facture
If nolign=1
  Raz [M:DEBG]
  [M:DEBG]CPY       = [M:DIA]CPY
  [M:DEBG]CUR       = [F:CPY]ACCCUR
  [M:DEBG]EECNUMDEB = [M:DIA]EECNUMDEB
  [M:DEBG]DEBDAT    = [M:DIA]DEBDAT
  Case [F:SIH]INVTYP
    When 1       :  [M:DEBG]VCRTYP    = 5          : # Facture vente
    When 2       :  [M:DEBG]VCRTYP    = 18         : # Avoir   vente
  Endcase
  [M:DEBG]VCRNUM    = [F:SIH]NUM
  [M:DEBG]DAT       = [F:SIH]ACCDAT
  [M:DEBG]CURDOC    = [F:SIH]CUR
  [M:DEBG]BPRNUM  = [F:SIV]BPCINV
  If [F:SIV]BPIEECNUM <> ""
    [M:DEBG]EECNUM = [F:SIV]BPIEECNUM
  Else
    Read [BPR]BPR0=[F:SIV]BPCINV
    If fstat : Raz [F:BPR] : Endif
    If [F:BPR]EECNUM <> ""
     [M:DEBG]EECNUM  = [F:BPR]EECNUM
    Endif
  Endif
  #FQ 52621
  #--- Cas du n° de TVA issu du pays expéditeur
  If [M:DEBG]EECNUM <> ""
    If left$([M:DEBG]EECNUM,2)=W_EECCRYFROM
      Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM,0) From GESECRAN
      # "Radical du numéro de TVA identique à celui du site expéditeur"
      Call ECR_TRACE(mess(740,197,1),0) From GESECRAN
    Endif
  Endif
  If [F:SIV]STOFCY<>""
    If [F:FCY]FCY<>[F:SIV]STOFCY
      Read [FCY]FCY0=[F:SIV]STOFCY
      If fstat : Raz [F:FCY] : Endif
    Endif
    Read [BPA]BPA0=3;[F:SIV]STOFCY;[F:FCY]BPAADD
    If fstat : Raz [F:BPA] : Endif
    If [F:BPA]POSCOD<>""
      [M:DEBG]REG (0) = left$([F:BPA]POSCOD,2)
    Endif
  Else
    #--- Cas des fact/avoirs sans mvt de stock, où le STOFCY n'est pas renseigné
    If [F:FCY]FCY<>[F:SIV]SALFCY
      Read [FCY]FCY0=[F:SIV]SALFCY
      If fstat : Raz [F:FCY] : Endif
    Endif
    Read [BPA]BPA0=3;[F:SIV]SALFCY;[F:FCY]BPAADD
    If fstat : Raz [F:BPA] : Endif
    If [F:BPA]POSCOD<>""
      [M:DEBG]REG (0) = left$([F:BPA]POSCOD,2)
    Endif
  Endif
Endif
#--- Site de stockage
If [F:SIV]STOFCY <> ""
  [M:DEBG]STOFCY  (nolign-1) = [F:SIV]STOFCY
Else
  [M:DEBG]STOFCY  (nolign-1) = [F:SIV]SALFCY
Endif
[M:DEBG]CRYFCY  (nolign-1) = W_EECCRYFROM
#--- Etat fédéral
If dim([M:DEBG]STAFED)>0
  Read [ITF]ITF0=[F:SID]ITMREF;[F:SIV]STOFCY
  If fstat : Raz [F:ITF] : Endif
  If dim([F:ITF]STAFED)<>0 and [F:ITF]STAFED<>""
    [M:DEBG]STAFED(nolign-1)=[F:ITF]STAFED
  Else
    If dim([F:ITM]STAFED)>0 and [F:ITM]STAFED<>""
      [M:DEBG]STAFED(nolign-1)=[F:ITM]STAFED
    Endif
  Endif
Endif

[M:DEBG]VCRLIN  (nolign-1) = [F:SID]SIDLIN
[M:DEBG]FLO     (nolign-1) = WFLO
[M:DEBG]ITMREF  (nolign-1) = [F:SID]ITMREF
[M:DEBG]ITMDES1 (nolign-1) = [F:SID]ITMDES1
[M:DEBG]CUSREF  (nolign-1) = [F:ITM]CUSREF
#--- Flux physique ou flux financier
If find([F:SID]EECFLOPHY,1,0)  :# "Non"
  #--- Flux financier
  [M:DEBG]EECNAT  (nolign-1) = [F:SIV]EECNATR
  [M:DEBG]EECSCH  (nolign-1) = [F:SIV]EECSCHR
Elsif [F:SID]EECFLOPHY = 2     :# "Oui"
  #--- Flux physique
  [M:DEBG]EECNAT  (nolign-1) = [F:SIV]EECNAT
  [M:DEBG]EECSCH  (nolign-1) = [F:SIV]EECSCH
Endif
#--CPO 97978 Commande à facturation directe avec mdl "Contremarque directe"
#--- Cas de la facture de cde de contremarque directe => Régime positionné à la valeur du flux de la table des regimes et nat. par mvt.
  Raz WTROUVE
  Raz WVALSTO
  If [F:SID]SOHNUM <> "" and [F:SID]SOPLIN <> 0 and [F:SID]SOQSEQ
    Read [SOQ]SOQ0=[F:SID]SOHNUM;[F:SID]SOPLIN;[F:SID]SOQSEQ
    If fstat : Raz [F:SOQ] : Endif
    If [F:SOQ]FMI=2 and [F:SOQ]FMINUM <> ""  : # Contremarque directe
      Read [POH]POH0=[F:SOQ]FMINUM
      If fstat : Raz [F:POH] : Endif

      #--- TS Issue 101474 --CPO OK
      If [F:POH]CRY=""
        If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:POH]BPSNUM or [F:BPA]BPAADD<>[F:POH]BPAADD
          Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPAADD
          If fstat : Raz [F:BPA] : Endif
        Endif
        [F:POH]CRY = [F:BPA]CRY
        #  Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPAADD
        #  If !fstat : [F:POH]CRY=[F:BPA]CRY : Endif
      Endif
      If [F:POH]BPOCRY=""
        If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:POH]BPSNUM or [F:BPA]BPAADD<>[F:POH]BPOADD
          Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
          If fstat : Raz [F:BPA] : Endif
        Endif
        [F:POH]BPOCRY = [F:BPA]CRY
        #  Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
        #  If !fstat : [F:POH]BPOCRY=[F:BPA]CRY : Endif
      Endif
      #---

      #--- Le pays du fournisseur doit être UE à la date de la commande
      JL0=find([F:POH]CRY,T_CRY)
      If JL0 and [F:POH]ORDDAT >= T_EECDAT(JL0-1)
        Raz JL0
        #--- Echange triangulaire si les pays des trois différents sites sont différents et sont UE
        JL0=find([F:POH]BPOCRY,T_CRY)
        If JL0 and T_EECCOD(JL0-1)<>"" and [F:POH]ORDDAT >= T_EECDAT(JL0-1)
          #--- Le pays du fournisseur doit être différent de ceux de la Livraison de ctm
          If T_EECCOD(JL0-1) <> W_EECCRYFROM and T_EECCOD(JL0-1) <> W_EECCRYTO
            Read [FCY]FCY0=[F:SIV]STOFCY : # pays depart
            If fstat : Raz [F:FCY] : Endif
            # MVT= 7 : "Livraison de contremarque directe"
            Call FLUX_REGNAT(7,[F:SIV]STOFCY,[F:FCY]CRY,[M:DEBG]EECSCH(nolign-1),[M:DEBG]EECNAT(nolign-1),WVALSTO,WTROUVE) From FUNDEBA
            If WTROUVE=1
              Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-num$([F:SID]SIDLIN),0) From GESECRAN
              # "Echange triangulaire : le Régime CEE et/ou la Nature ont été modifiés"
              Call ECR_TRACE(mess(737,197,1),0) From GESECRAN
            Endif
          Elsif T_EECCOD(JL0-1) = W_EECCRYTO
            Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-num$([F:SID]SIDLIN),0) From GESECRAN
            # "Echange triangulaire : 'Le fournisseur expéditeur et le client livré ou le site de vente sont dans le même pays'
            Call ECR_TRACE(mess(824,197,1)+" : "+mess(825,197,1),0) From GESECRAN
            WOKLIG=0 : Return
          Endif
        Else
          Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-num$([F:SID]SIDLIN),0) From GESECRAN
          # "Echange triangulaire : 'La date de commande de contremarque est antérieure à l'entrée dans l'UE du pays de'+'l'adresse d'expédition du fournisseur'
          # ou le pays de l'adresse d'expédition du fournisseur n'est pas un pays UE
          Call ECR_TRACE(mess(824,197,1)+" : "+mess(826,197,1)+" "+mess(827,197,1)+", "+mess(829,197,1)+" "+mess(827,197,1)+" "+mess(830,197,1),0) From GESECRAN
          WOKLIG=0 : Return
        Endif
      Else
        Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-num$([F:SID]SIDLIN),0) From GESECRAN
        # "Echange triangulaire : 'La date de commande de contremarque est antérieure à l'entrée dans l'UE du pays de'+'l'adresse commande du fournisseur'
        # ou le pays de l'adresse commande du fournisseur n'est pas un pays UE
        Call ECR_TRACE(mess(824,197,1)+" : "+mess(826,197,1)+" "+mess(828,197,1)+", "+mess(829,197,1)+" "+mess(828,197,1)+" "+mess(830,197,1),0) From GESECRAN
        WOKLIG=0 : Return
      Endif
    Endif
  Endif
#--/
If W_EECCRYFFW<>""  [M:DEBG]DESCRY (nolign-1) = W_EECCRYFFW
  Else              [M:DEBG]DESCRY (nolign-1) = W_EECCRYTO
Endif
[M:DEBG]ORICRY  (nolign-1) = ""                      : # car flux d'expédition(l'introduction avoir est traitée plus bas)
[M:DEBG]REG     (nolign-1) = [M:DEBG]REG(0)          : # site expé à l'entête
If [F:ITM]ITMWEI<>0
  If toupper(left$([F:ITM]WEU,2))="KG"
    [M:DEBG]NETMAS (nolign-1) = [F:ITM]ITMWEI*[F:SID]QTYSTU
  Else
    I=find("KG",GUNITE(1..GDIMUNT))
    If I=0 I=find("Kg",GUNITE(1..GDIMUNT)) Endif
    If I=0 I=find("kg",GUNITE(1..GDIMUNT)) Endif
    If I<>0
      Read [TCO]TCO0=[F:ITM]WEU;GUNITE(I)
      If !fstat [M:DEBG]NETMAS (nolign-1) = [F:ITM]ITMWEI*[F:SID]QTYSTU*[F:TCO]COEUOM Endif
    Endif
  Endif
Endif
If [F:ITM]EEU<>"" & [F:ITM]EEUSTUCOE<>0
  [M:DEBG]EECUNT (nolign-1) =[F:SID]QTYSTU/[F:ITM]EEUSTUCOE
Endif
[M:DEBG]EECTRN  (nolign-1) = [F:SIV]EECTRN
[M:DEBG]EECICT  (nolign-1) = [F:SIV]EECICT
[M:DEBG]EECLOC  (nolign-1) = [F:SIV]EECLOC

Raz W_MTTHTLIN
If [F:SID]AMTNOTLIN <> 0
  W_MTTHTLIN = [F:SID]AMTNOTLIN
Else
  #--- Si prix net = 0 on prend le prix de revient CPRPRI
  #--- ce dernier est libellé dans la devise du document
  #--- Hors ligne liée à un composant kit/sous-traité ou nomenclature
  If find([F:SID]LINTYP,3,4,5,7,8,9,11,12,13)=0
    #--- On tient compte du paramétrage valeur stock des paramétres des flux par mouvement
    Raz WTROUVE,WVALSTO
    Call FLUX_REGNAT(WMVT,[M:DEBG]STOFCY(nolign-1),[F:FCY]CRY,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA
    If WTROUVE and WVALSTO=2
      W_MTTHTLIN = [F:SID]CPRPRI*[F:SID]QTY
    Else
      #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
      Raz JL0,JL1
      #--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
      #JL0=find([M:DEBG]EECSCH(nolign-1),REG_CODE) :# Pour tenir compte de la modif de Reg/Nat des gratuits
      #JL1=find([M:DEBG]EECNAT(nolign-1),NAT_CODE) :# Pour tenir compte de la modif de Reg/Nat des gratuits
      #If (JL0 and REG_VALSTO(JL0-1)=2) or (JL1 and NAT_VALSTO(JL1-1)=2)
      Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
      If JL0>0 : Raz [F:TSC] : Endif
      Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
      If JL1>0 : Raz [F:TEC] : Endif
      If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
      #--/
        W_MTTHTLIN = [F:SID]CPRPRI*[F:SID]QTY
      Endif
    Endif
  Endif
Endif
[M:DEBG]FISAMT  (nolign-1) = W_MTTHTLIN
#--- Prise en compte du coefficient de majoration CEE, le cas échéant
[M:DEBG]STAAMT  (nolign-1) = W_MTTHTLIN
If [F:BPD]BPCNUM = [F:SIV]BPCORD and [F:BPD]BPAADD = [F:SIV]BPAADD
 If [F:BPD]EECINCRAT <> 0
  [M:DEBG]STAAMT  (nolign-1) = W_MTTHTLIN*[F:BPD]EECINCRAT
 Endif
Else
  Read [BPD]BPD0=[F:SIV]BPCORD;[F:SIV]BPAADD
  If fstat : Raz [F:BPD] : Endif
  If [F:BPD]EECINCRAT <> 0
    [M:DEBG]STAAMT  (nolign-1) = W_MTTHTLIN*[F:BPD]EECINCRAT
  Endif
Endif
#--- Prise en compte des éléments de facturation répartis sur la ligne
WPIECE = "SID"
Gosub VEN_TOTDISCRG From FUNDEB
WDISCRGAMT   = WTOTDISCRG
WDISCRGAMTVS = WTOTDISCRGVS
Raz WPIECE
Raz WTOTAMTNOT
#--- Somme montants HT détails
For [SIDW]SID0 Where NUM=[F:SID]NUM
  WTOTAMTNOT += [F:SIDW]AMTNOTLIN
Next

# Si le total des lignes ne permet pas de proratiser,
# il faut prendre en compte les éléments déjà éclatés sur les lignes
If WTOTAMTNOT <> 0
  #--- Il faut proratiser par rapport au [F:SID]AMTNOTLIN, même si = 0
  #--- car sinon, si on prend W_MTTHLIN qui tient compte du CPRPRI,
  #--- nous risquons d'avoir un total des lignes > au WTOTAMTNOT et un faux prorata !
  [M:DEBG]FISAMT(nolign-1) += ((WINVDTAAMT  *[F:SID]AMTNOTLIN)/WTOTAMTNOT) + WDISCRGAMT
  [M:DEBG]STAAMT(nolign-1) += ((WINVDTAAMTVS*[F:SID]AMTNOTLIN)/WTOTAMTNOT) + WDISCRGAMTVS
Else
  [M:DEBG]FISAMT(nolign-1) += WDISCRGAMT
  [M:DEBG]STAAMT(nolign-1) += WDISCRGAMTVS
Endif
#--- Conversion de la valeur fiscale, le cas échéant
If [F:SIH]CUR <> WCUR
  WFISAMT=[M:DEBG]FISAMT(nolign-1)
  Raz STAT
  Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
  If STAT
    Raz STAT
    Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
    If STAT
      WOK=0
      Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
      Return
    Endif
  Endif
Endif
#--- Conversion de la valeur statistique, le cas échéant
If [F:SIH]CUR <> WCUR
  WSTAAMT=[M:DEBG]STAAMT(nolign-1)
  Raz STAT
  Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WSTAAMT,[M:DEBG]STAAMT(nolign-1),STAT) From TRTDEV
  If STAT
    Raz STAT
    Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WSTAAMT,[M:DEBG]STAAMT(nolign-1),STAT) From TRTDEV
    If STAT
      WOK=0
      Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
      Return
    Endif
  Endif
Endif
[M:DEBG]NIV   (nolign-1) = GNIVEXP
[M:DEBG]NBDEB = nolign

Return
#----------------------------------------------------------------------
$DEBG_SIH_AVR_DIR
#--- Avoirs origine directe
# Chargement du masque avec les éléments de la ligne d'Avoir avec Origine Directe

Case [F:SID]EECFLOPHY
  When 1 :  #--- Génération d'un flux de régularisation EXPEDITION
            Gosub DEBG_SIH_AVRREG From FUNDEB
  When 2 :  #--- Génération d'un flux physique INTRODUCTION
            WFLO = 1 :# Introduction
            Gosub DEBG_SIH_AVRPHY From FUNDEB
            #--- Il faut remettre le type de flux à expédition
            WFLO=2 :# Expédition
            #--- Génération d'un flux de régularisation EXPEDITION
            #--- uniquement si le paramètre "FLWCORCRE" est à "Oui"
            If GFLWCORCRE=2
              nolign += 1
              WFLO = 2 :# Expédition
              Gosub DEBG_SIH_AVRREG From FUNDEB
            Endif
  When Default :  WOKLIG = 0
Endcase
If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_AVR_FAC
#--- Avoirs origine facture
# Attention : les factures peuvent avoir des origines différentes
# Directe, Livraison, Commande, Contrat, Demande de services, Transfert
# Pour chaque origine de la facture il faut faire attention aux lignes supplémentaires
# Toutes ne rentrent pas dans la DEB

Case [F:SID]EECFLOPHY
  When 1 :  #--- Génération d'un flux de régularisation EXPEDITION
            WFLO = 2 :# Expédition
            Gosub DEBG_SIH_AVRREG From FUNDEB
  When 2 :  #--- Génération d'un flux physique INTRODUCTION
            WFLO = 1 :# Introduction
            Gosub DEBG_SIH_AVRPHY From FUNDEB
            #--- Il faut remettre le type de flux à expédition
            WFLO=2 :# Expédition
            #--- génération d'un flux de régularisation EXPEDITION
            #--- uniquement si le paramètre "FLWCORCRE" est à "Oui"
            If GFLWCORCRE=2
              nolign += 1
              WFLO = 2 :# On repositionne en Expédition
              Gosub DEBG_SIH_AVRREG From FUNDEB
            Endif
  When Default :  WOKLIG = 0
Endcase

If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_AVR_RET
#--- Avoirs origine retour
# Chargement du masque avec les éléments de la ligne d'Avoir avec Origine Directe

#--- Les avoirs ayant cette origine ont toujours le flag STOMVTFLG à "Oui"
If [F:SIV]STOMVTFLG = 1 : WOK = 0 : Return : Endif
#--- Les lignes d'avoir sur Retours sont traitées dans les Retours sur ventes
If [F:SID]SRHNUM = "" and [F:SID]SRDLIN = 0
  #--- Ligne directe
  Case [F:SID]EECFLOPHY
    When 1 :  #--- Génération d'un flux de régularisation EXPEDITION
              WFLO = 2 :# Expédition
              Gosub DEBG_SIH_AVRREG From FUNDEB
    When 2 :  #--- Génération d'un flux physique INTRODUCTION
              WFLO = 1 :# Introduction
              Gosub DEBG_SIH_AVRPHY From FUNDEB
              #--- Il faut remettre le type de flux à expédition
              WFLO=2 :# Expédition
              #--- Génération d'un flux de régularisation EXPEDITION
              #--- uniquement si le paramètre "FLWCORCRE" est à "Oui"
              If GFLWCORCRE=2
                nolign += 1
                WFLO = 2 :# Expédition
                Gosub DEBG_SIH_AVRREG From FUNDEB
              Endif
    When Default :  WOKLIG = 0
  Endcase
Else
  #--- Ligne issue d'un retour
  Read [SRH]SRH0=[F:SID]SRHNUM
  If fstat : Raz [F:SRH] : WOKLIG=0 : Return : Endif
  #-----------------------------------
  #--Evite de prendre en compte les retours extraits qui contiennent
  #--dans la liste des pièces valorisées, l'avoir en cours
  #(si mtt avoir identique au retour donc l'avoir n'a pas été marqué avec le n° d'extraction du retour)
  If [F:SRH]EECNUMDEB<>0 and [F:SRH]EECNUMDEB<>[M]EECNUMDEB
    Look [F:DEB]DEB1=[M:DIA]CPY;13;[F:SID]SRHNUM;[F:SID]SRDLIN;1
    If !fstat
      Read [F:DEB]DEB1 Curr
      If fstat : Raz [F:DEB] : Endif
      WINDICE=find([F:SID]NUM,[F:DEB]VCRNUMVALO)
      If (WINDICE<=0) or (WINDICE>0 and !find([F:SID]SIDLIN,[F:DEB]VCRLINVALO(WINDICE-1)))
        #Message : "Pièce xxxx créée, alors que le flux d'origine a été déclaré"
        Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-mess(744,197,1)-num$([F:SID]SIDLIN)-mess(748,197,1)
&                 -mess(624,197,1)-[F:SRH]SRHNUM,0) From GESECRAN
      Endif
    Endif
  Endif
  #-----------------------------------
  #FQ 52676
  #--- Génération d'un flux de régularisation EXPEDITION
  #--- uniquement si le paramètre "FLWCORCRE" est à "Oui"
  If GFLWCORCRE=2
    WFLO = 2 :# Expédition
    Gosub DEBG_SIH_AVRREG From FUNDEB
    If WOKLIG = 0 : Return : Endif
    If WOK = 0    : Return : Endif
    #Lors de la valorisation de la ligne de retour, si le montant de l'avoir sur retour est 0
    #on prend le prix de l'ordre de la ligne de retour.
    #Donc, quand on extrait le flux de régul Expédition, sur la ligne d'avoir, si son montant est à 0
    #il faut également valoriser cette ligne avec le prix de l'ordre du retour à l'origine de l'avoir
    If [F:SID]AMTNOTLIN=0 and find([F:SID]LINTYP,3,4,5,7,8,9,11,12,13)=0
      #--CPO DM 105661 Ajout de la sous-traitance
      If [F:SID]LINTYP=10
        Gosub VALO_AVR_RET_SST From FUNDEBB
      Else
        Gosub VALO_AVR_RET From FUNDEBA
      Endif
      If WOKLIG = 0 : Return : Endif
      If WOK = 0    : Return : Endif
    Endif
  Else
  #fin FQ 52676
    WOKLIG = 0 : Return
  Endif
Endif
If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif

Return
#----------------------------------------------------------------------
$DEBG_SIH_AVRREG
#--- Flux financier associé à la ligne d'Avoir
#--- Flux : EXPEDITION
Gosub DEBG_SIH_FAC From FUNDEB
If WOKLIG = 0 : Return : Endif
If WOK = 0    : Return : Endif
# Etant un flux financier, il faut prendre la valeur du flux de régularisation
[M:DEBG]EECSCH(nolign-1)=[F:SIV]EECSCHR
[M:DEBG]EECNAT(nolign-1)=[F:SIV]EECNATR

Return
#----------------------------------------------------------------------
$DEBG_SIH_AVRPHY
#--- Flux physique associé à la ligne d'Avoir
#--- Flux : INTRODUCTION
Gosub DEBG_SIH_FAC From FUNDEB
[M:DEBG]NIV   (nolign-1) = GNIVINT
#--- Le pays d'origine
LCRY=W_CRYFROM
Gosub LEC_TCY From FUNDEB
If [F:TCY]EECFLG=2 & [F:TCY]EECCOD<>""
  [M:DEBG]ORICRY(nolign-1)=[F:TCY]EECCOD
Else
  [M:DEBG]ORICRY(nolign-1)=[F:TCY]ISO
Endif

Return

