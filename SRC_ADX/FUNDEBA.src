If clalev([F:FGR1R])=0 : Local File FACGROUP  [FGR1R] : Endif
If clalev([F:FGR2]) =0 : Local File FACGROUP  [FGR2]  : Endif
If clalev([F:FGR2R])=0 : Local File FACGROUP  [FGR2R] : Endif
#--/
#--- Tables ventes
If GMODU(5)=2
   If !clalev([F:SIH])  Local File SINVOICE   [SIH]  Endif
   If !clalev([F:SIV])  Local File SINVOICEV  [SIV]  Endif
   If !clalev([F:SID])  Local File SINVOICED  [SID]  Endif
   If !clalev([F:SVF])  Local File SVCRFOOT   [SVF]  Endif
   If !clalev([F:SVV])  Local File SVCRVAT    [SVV]  Endif
   If !clalev([F:SDH])  Local File SDELIVERY  [SDH]  Endif
   If !clalev([F:SDD])  Local File SDELIVERYD [SDD]  Endif
   If !clalev([F:SDDW]) Local File SDELIVERYD [SDDW] Endif :#--CPO DM 105661 Ajout de la sous-traitance
   If !clalev([F:SRH])  Local File SRETURN    [SRH]  Endif
   If !clalev([F:SRHW]) Local File SRETURN   [SRHW]  Endif
   If !clalev([F:SRD])  Local File SRETURND   [SRD]  Endif
   If !clalev([F:SRDW]) Local File SRETURND  [SRDW]  Endif
   If !clalev([F:SIDC]) Local File SINVOICED [SIDC]  Endif
   If !clalev([F:SIHC]) Local File SINVOICE  [SIHC]  Endif
