#<AdxTL>@(#)1.0.0.0 $Revision$
#@ Check diff -CPO-16/12/13
##########################################################################
# Permet de retrouver les valeurs du Régime CEE et de la Nature CEE      #
# pour un mouvement donné, un site, depuis le paramétrage des régimes et #
# natures par mouvement                                                  #
# Entrée : - Type de mouvement : AMVT                                    #
#          - Site              : ASITE                                   #
#          - Pays du site      : ACRYSITE                                #
# Sortie : - Régime CEE        : VEECSCH                                 #
#          - Nature CEE        : VEECNAT                                 #
#          - Flag trouvé O/N   : VTROUVE   (1 si OK)                     #
##########################################################################
#--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
#Subprog FLUX_REGNAT(AMVT,ASITE,ACRYSITE,VEECSCH,VEECNAT,VVALSTO,VTROUVE)
#
#Value    Integer AMVT                       :# Le type de mouvement
#Value    Char    ASITE                      :# Le site concerné
#Value    Char    ACRYSITE                   :# Le pays du site concerné
#Variable Char    VEECSCH                    :# Regime CEE
#Variable Char    VEECNAT                    :# Nature CEE
#Variable Integer VVALSTO                    :# Valeur stock
#Variable Integer VTROUVE                    :# Eléments trouvés
#
#Raz VTROUVE,VVALSTO
#Raz VEECNAT,VEECSCH
#
#If !clalev([F:DRN])  : Local File DEBREGNAT [DRN] : Endif
#If !clalev([F:FGR])  : Local File FACGROUP  [FGR] : Endif
#If !clalev([F:AGF])  : Local File AGRPFCY   [AGF] : Endif
#
#
#Link [DRN] With [FGR]FGR0~=[DRN]GRP;ASITE,[AGF]AGF0~=[DRN]GRP As [DRN1]
#&              Where [DRN]MVT=AMVT and ([DRN]CRY=ACRYSITE or [DRN]CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
#&              Order By Key CLE1=[AGF]FLGCPY Desc;[DRN]GRP Desc;[DRN]CRY Desc;[DRN]LEG Desc
#Read [DRN1] First
#If !fstat
#    #--- Initialisation des régimes et natures
#    VEECNAT = [F:DRN1]EECNAT
#    VEECSCH = [F:DRN1]EECSCH
#    VVALSTO = [F:DRN1]VALSTO
#    VTROUVE=1
#Else
#    #--- Le site n'appartient à aucun groupe utilisé dans le paramétrage des mouvements
#    Filter [DRN] Where MVT=AMVT and GRP="" and (CRY=ACRYSITE or CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
#&              Order By CRY Desc;LEG Desc
#    #--- On prend les valeurs associées au mouvement n'ayant aucun groupe de défini
#    Read [DRN] First
#    If !fstat
#        #--- Initialisation des régimes et natures
#        VEECNAT = [F:DRN1]EECNAT
#        VEECSCH = [F:DRN1]EECSCH
#        VVALSTO = [F:DRN1]VALSTO
#        VTROUVE = 1
#    Endif
#    Filter [DRN]
#Endif
#End
Subprog FLUX_REGNAT(I_EEC,WSITEDEB,WCRYDEB,IM_SCH,IM_NAT,VVALSTO,VTROUVE)

Value    Integer I_EEC                   :# Le type de mouvement
Value    Char    WSITEDEB                :# Le site concerné
Value    Char    WCRYDEB                 :# Le pays du site concerné
Variable Char    IM_SCH                  :# Regime CEE
Variable Char    IM_NAT                  :# Nature CEE
Variable Integer VVALSTO                 :# Valeur stock
Variable Integer VTROUVE                 :# Eléments trouvés

#--Afin de passer par le même sous-pro de recherche EEC_INIT => appelé par le Subprog INICRE_EEC (en création des documents)
Local Integer IM_FLUX                    : # Flux ( 0=pas d'enr. CEE / 1=Intro / 2=Expé )
Local Integer IV_FLUX                    : # Flux ( 0=pas d'enr. CEE / 1=Intro / 2=Expé )
Local Char    IV_NAT                     : # Nature si regul valorisation
Local Char    IV_SCH                     : # Regime si regul valorisation

If clalev([F:DRN])  =0 : Local File DEBREGNAT [DRN] 	: Endif
If clalev([F:FGRR]) =0 : Local File FACGROUP  [FGRR] 	: Endif
If clalev([F:AGFF]) =0 : Local File AGRPFCY   [AGFF] 	: Endif
If clalev([F:TSC])  =0 : Local File TABEECSCH [TSC]   : Endif
If clalev([F:TSCR]) =0 : Local File TABEECSCH [TSCR]  : Endif
If clalev([F:TEC])  =0 : Local File TABEECNAT [TEC]   : Endif
If clalev([F:TECR]) =0 : Local File TABEECNAT [TECR]  : Endif
If clalev([F:FGR1]) =0 : Local File FACGROUP  [FGR1]  : Endif
If clalev([F:FGR1R])=0 : Local File FACGROUP  [FGR1R] : Endif
If clalev([F:FGR2]) =0 : Local File FACGROUP  [FGR2]  : Endif
If clalev([F:FGR2R])=0 : Local File FACGROUP  [FGR2R] : Endif

Raz VTROUVE,VVALSTO
Raz IM_SCH,IM_NAT

Gosub EEC_INIT

If dim(WTROUV)>0 : VTROUVE = WTROUV : Endif
#--/CPO

End
#####################################################################
#####################################################################
#-------------------------------------------------------------------#
#    Traitement d'initialisation des données DEB dans les documents #
#    (le bouton CEE n'est accessible qu'après création du document) #
#    Concerne : livraison / retour                                  #
#               réception / retour                                  #
#               facture / avoir                                     #
#-------------------------------------------------------------------#
# Entrée    ABIDC3    : Abréviation de la pièce à initialiser       #
# Sortie    IM_FLUX   : Flux physique                               #
#           IM_NAT    : Nature si mvt marchandise                   #
#           IM_SCH    : Regime si mvt marchandise                   #
#           IV_FLUX   : Flux régularisation                         #
#           IV_NAT    : Nature si regul valorisation                #
#           IV_SCH    : Regime si regul valorisation                #
#-------------------------------------------------------------------#
Subprog INICRE_EEC (ABIDC3,IM_FLUX,IM_NAT,IM_SCH,IV_FLUX,IV_NAT,IV_SCH)

Value    Char    ABIDC3                     : # Doit contenir l'abréviation de la pièce
Variable Integer IM_FLUX                    : # Flux ( 0=pas d'enr. CEE / 1=Intro / 2=Expé )
Variable Char    IM_NAT                     : # Nature si mvt marchandise
Variable Char    IM_SCH                     : # Regime si trf marchandise
Variable Integer IV_FLUX                    : # Flux ( 0=pas d'enr. CEE / 1=Intro / 2=Expé )
Variable Char    IV_NAT                     : # Nature si regul valorisation
Variable Char    IV_SCH                     : # Regime si regul valorisation

Local Integer I_EEC                         : # indice de la ligne d'initialisation
Local Char    WSITEDEB(GLONFCY)             : # pour renseigner le site de réception/retour/vente
Local Char    WCRYDEB(GLONCRY)              : # pour renseinger le pays du site
Local Char    WLEG(GLONADI)                 : # pour renseigner la législation

If !clalev([F:DRN])  : Local File DEBREGNAT [DRN] : Endif
If !clalev([F:FGRR]) : Local File FACGROUP [FGRR] : Endif :# Pour préserver le buffer
If !clalev([F:AGFF]) : Local File AGRPFCY  [AGFF] : Endif :# Pour préserver le buffer
If !clalev([F:FCYY]) : Local File FACILITY [FCYY] : Endif :# Pour préserver le buffer
#--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
If clalev([F:TSC])  =0 : Local File TABEECSCH [TSC]   : Endif
If clalev([F:TSCR]) =0 : Local File TABEECSCH [TSCR]  : Endif
If clalev([F:TEC])  =0 : Local File TABEECNAT [TEC]   : Endif
If clalev([F:TECR]) =0 : Local File TABEECNAT [TECR]  : Endif
If clalev([F:FGR1]) =0 : Local File FACGROUP  [FGR1]  : Endif
If clalev([F:FGR1R])=0 : Local File FACGROUP  [FGR1R] : Endif
If clalev([F:FGR2]) =0 : Local File FACGROUP  [FGR2]  : Endif
If clalev([F:FGR2R])=0 : Local File FACGROUP  [FGR2R] : Endif
#--/CPO

I_EEC=99
Raz IM_FLUX, IM_NAT,IM_SCH
Raz IV_FLUX, IV_NAT,IV_SCH

Case ABIDC3
     When "SDH"         : Gosub EEC_INI_SDH : # Livraison
     When "SRH"         : Gosub EEC_INI_SRH : # Retour client / Retour client
     When "SIV"         : Gosub EEC_INI_SIV : # Facture/Avoir client
     When "PTH"         : Gosub EEC_INI_PTH : # Réception
     When "PNH"         : Gosub EEC_INI_PNH : # Retour fournisseur
     When "PIH"         : Gosub EEC_INI_PIH : # Facture/Avoir fournisseur
Endcase
#--- ce point est appellé depuis un sous-pro,
#--- lui-même appellé depuis la création des différentes pièces.
#--- attention à la modification des buffers
#La doc du PE existe mais sur FUNDEB
GPOINT="DEBINI" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE

End
#------------------------------------------------------------------------
$EEC_INI_SDH
# Livraison classique              (1)
# Livraison inter-sociétés         (2)
# Livraison de prêt                (3)
# Livraison de sous-traitance      (4)
# Livraison inter-sites            (5)
# Livraison export avec transit.   (6)
# Livraison contremarque directe   (7)
# Livraison de gratuits            (18)

#--- Si le buffer n'est pas positionné, on sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:SDH]) : Return : Endif

I_EEC=1                                          : # Livraison classique
If [F:SDH]BETFCY=2   : I_EEC=5 : Endif           : # Livraison inter-sites
If [F:SDH]BETCPY=2   : I_EEC=2 : Endif           : # Livraison inter-sociétés
If [F:SDH]LND=2      : I_EEC=3 : Endif           : # Livraison de prêt
If [F:SDH]SCO=2      : I_EEC=4 : Endif           : # livraison pour sous-traitance
If [F:SDH]FFWNUM<>"" : I_EEC=6 : Endif           : # Livraison export avec transit.
#--- Livraison contremarque directe
#--- une même livraison peut avoir des lignes de ctm et des lignes normales
#--- Régime 21 ou 31 ?
#--- Solution implémentée : R21 et changement du régime lors du ttt d'une ligne de livraison de type ctm

#--- Livraison de gratuits
#--- une même livraison peut avoir des lignes de gratuits et des lignes normales
#--- Quel régime appliquer ?
#--- Solution implémentée : régime livr. normale et changement du régime lors du ttt d'une ligne de livraison de gratuits

WSITEDEB = [F:SDH]STOFCY
If [F:SDH]STOFCY <> ""
  Read [FCYY]FCY0=[F:SDH]STOFCY
  If fstat : Raz [F:FCYY] : Endif
  WCRYDEB=[F:FCYY]CRY
Endif
Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INI_SRH
# Retour client                    (12)
# Retour de prêt                   (13)
# Retour matière de sous-traitance (19) DM 52929

#--- Si le buffer n'est pas positionné, on sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:SRH]) : Return : Endif

I_EEC=12                                         : # Retour client
If [F:SRH]LNDRTN=2 : I_EEC=13 : Endif            : # Retour de prêt
#DM 52929
If [F:SRH]SCORTN=2 : I_EEC=19 : Endif            : # Retour matière de sous-traitance

WSITEDEB = [F:SRH]STOFCY
If [F:SRH]STOFCY <> ""
  Read [FCYY]FCY0=[F:SRH]STOFCY
  If fstat : Raz [F:FCYY] : Endif
  WCRYDEB=[F:FCYY]CRY
Endif
Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INI_SIV
# Factures vente                   (15)
# Avoirs vente                     (16)
# Factures de prêt                 (17)

# Local Integer EECMVTFLG
# Local Integer WNBLIN
#--- Si le buffer n'est pas positionné, on sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:SIV]) : Return : Endif
#--- Cas des factures de prêt
If !clalev([F:SDHH]) : Local File SDELIVERY [SDHH] : Endif

If find([F:SIV]INVTYP,1,5)                        : # Facture / Proforma (pour conformité V130)
  I_EEC=15
  If [F:SIV]SIHORI=3 & [F:SIV]SIHORINUM <> "" and [F:SDHH]SDHNUM <> [F:SIV]SIHORINUM
    Read [F:SDHH]SDH0=[F:SIV]SIHORINUM
    If !fstat
      If [F:SDHH]LND=2 and [F:SDHH]EECNUMDEB = 0
        I_EEC=17                                : # Factures de prêt
      Endif
    Endif
  Endif
Endif
If [F:SIV]INVTYP=2 : I_EEC=16 : Endif             : # Avoir

WSITEDEB = [F:SIV]STOFCY
#--- Cas des pièces sans mvt de stock où le STOFCY n'est pas renseigné
If WSITEDEB = "" : WSITEDEB= [F:SIV]SALFCY : Endif

Read [FCYY]FCY0=WSITEDEB
If fstat : Raz [F:FCYY] : Endif
WCRYDEB=[F:FCYY]CRY

Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INI_PTH
# Réception classique              (8)
# Réception de sous-traitance      (9)
# Réception inter-sites            (10)
# Réception inter-sociétés         (11)

#--- Si le buffer n'est pas positionné, on sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:PTH]) : Return : Endif

I_EEC = 8                                           : # Réception classique
#--- Réception de sous-traitance                    : # Réception de sous-traitance
#--- une même réception peut avoir des lignes de sous-traitance et des lignes normales
#--- ayant des Régimes et/ou Natures différents
#--- Solution implémentée : Régime de réception classique et changement
#---                        au régime récept. ss-trait. lors du ttt d'extraction de la DEB
If [F:PTH]BETFCY = 2 : I_EEC=10 : Endif             : # Réception inter-sites
If [F:PTH]BETCPY = 2 : I_EEC=11 : Endif             : # Réception inter-sociétés

WSITEDEB = [F:PTH]PRHFCY
If [F:PTH]PRHFCY <> ""
  Read [FCYY]FCY0=[F:PTH]PRHFCY
  If fstat : Raz [F:FCYY] : Endif
  WCRYDEB=[F:FCYY]CRY
Endif

Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INI_PNH
# Retour fournisseur               (14)

#--- Si le buffer n'est pas positionné, on ne sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:PNH]) : Return : Endif

I_EEC = 14

WSITEDEB = [F:PNH]PNHFCY
If [F:PNH]PNHFCY <> ""
  Read [FCYY]FCY0=[F:PNH]PNHFCY
  If fstat : Raz [F:FCYY] : Endif
  WCRYDEB=[F:FCYY]CRY
Endif
Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INI_PIH
#--- Les Factures/Avoirs fournisseurs ne sont pas traités
If I_EEC=99 : Return : Endif
#--- Si le buffer n'est pas positionné, on ne sort du ttt
#--- l'initialisation des informations douanières est faite depuis "inicre"
If !clalev([F:PIH]) : Return : Endif

WSITEDEB = [F:PIH]FCY
If [F:PIH]FCY <> ""
  Read [FCYY]FCY0=[F:PIH]FCY
  If fstat : Raz [F:FCYY] : Endif
  WCRYDEB=[F:FCYY]CRY
Endif
Gosub EEC_INIT

Return
#------------------------------------------------------------------------
$EEC_INIT

Local Integer WTROUV
Raz WTROUV

#--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
#If I_EEC <> 0 and I_EEC <> 99
#  Link [DRN] With [FGRR]FGR0~=[DRN]GRP;WSITEDEB,[AGFF]AGF0~=[DRN]GRP As [DRN1]
#&       Where [DRN]MVT=I_EEC and ([DRN]CRY=WCRYDEB or [DRN]CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
#&       Order By Key CLE1=[AGFF]FLGCPY Desc;[DRN]GRP Desc;[DRN]CRY Desc;[DRN]LEG Desc
#  Read [DRN1] First
#  If !fstat
#    #--- Initialisation des régimes et natures
#    IM_FLUX=[F:DRN1]FLUX      : IM_NAT=[F:DRN1]EECNAT  : IM_SCH=[F:DRN1]EECSCH
#    IV_FLUX=[F:DRN1]FLUXREGUL : IV_NAT=[F:DRN1]EECNATR : IV_SCH=[F:DRN1]EECSCHR
#    WTROUV=1
#  Endif
#  If WTROUV = 0
#    #--- Le site n'appartient à aucun groupe utilisé dans le paramétrage des mouvements
#    #--- Nous cherchons d'abord une entrée dans la table sans groupe de sociétés, mais
#    #--- liée au pays du site, puis une entrée sans pays et sans législation
#    Filter [DRN] Where MVT=I_EEC and GRP="" and (CRY=WCRYDEB or CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
#&                Order By CRY Desc;LEG Desc
#    #--- On prend les valeurs associées au mouvement n'ayant aucun groupe de défini
#    Read [DRN] First
#    If !fstat
#      #--- Initialisation des régimes et natures
#      IM_FLUX=[F:DRN]FLUX      : IM_NAT=[F:DRN]EECNAT  : IM_SCH=[F:DRN]EECSCH
#      IV_FLUX=[F:DRN]FLUXREGUL : IV_NAT=[F:DRN]EECNATR : IV_SCH=[F:DRN]EECSCHR
#      WTROUV=1
#    Endif
#    Filter [DRN]
#  Endif
#Endif

If I_EEC <> 0 and I_EEC <> 99
	#--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
#  Link [DRN] With [FGRR]FGR0~=[DRN]GRP;WSITEDEB,[AGFF]AGF0~=[DRN]GRP As [DRN1]
#&       Where [DRN]MVT=I_EEC and ([DRN]CRY=WCRYDEB or [DRN]CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
#&       Order By Key CLE1=[AGFF]FLGCPY Desc;[DRN]GRP Desc;[DRN]CRY Desc;[DRN]LEG Desc

  #Read [DRN1] First
  #If !fstat
  Link [DRN] With
&			 [FGRR]FGR0		 ~=	[DRN]GRP;WSITEDEB,
&			 [AGFF]AGF0		 ~=	[DRN]GRP
&		As [DRN1]
&   Where
&			 [DRN]MVT =I_EEC and ([DRN]CRY=WCRYDEB or [DRN]CRY="") and
&			([DRN]LEG =GCURLEG or [DRN]LEG="")
&   Order By Key CLE1=[AGFF]FLGLEG Desc;[DRN]GRP Desc;[DRN]CRY Desc;[DRN]LEG Desc
	#--Parcours des entrées retenues afin de contrôler aussi la cohérence des champs sous-niveau, déclinés eux aussi par législation
	For [DRN1]CLE1
		Raz mkstat

    Call CONTTSC([DRN1]EECSCH ,GCURLEG,"","",WSITEDEB,"","") From SUBTSC
		If mkstat : Goto NEXT_DRN1 : Endif

    Call CONTTSC([DRN1]EECSCHR,GCURLEG,"","",WSITEDEB,"","") From SUBTSC
		If mkstat : Goto NEXT_DRN1 : Endif

    Call CONTTEC([DRN1]EECNAT ,GCURLEG,"","",WSITEDEB,"","") From SUBTEC
		If mkstat : Goto NEXT_DRN1 : Endif

    Call CONTTEC([DRN1]EECNATR,GCURLEG,"","",WSITEDEB,"","") From SUBTEC
    If mkstat=0
      #--- Initialisation des régimes et natures
      IM_FLUX=[F:DRN1]FLUX      : IM_NAT=[F:DRN1]EECNAT  : IM_SCH=[F:DRN1]EECSCH
      IV_FLUX=[F:DRN1]FLUXREGUL : IV_NAT=[F:DRN1]EECNATR : IV_SCH=[F:DRN1]EECSCHR
      #--Pour l'appel depuis la génération FUNDEB
      If dim(VVALSTO)>0 : VVALSTO = [F:DRN1]VALSTO : Endif
      WTROUV=1
    	Break
    Endif
    $NEXT_DRN1
  Next
  If WTROUV = 0
    #--- Le site n'appartient à aucun groupe utilisé dans le paramétrage des mouvements
    #--- Nous cherchons d'abord une entrée dans la table sans groupe de sociétés, mais
    #--- liée au pays du site, puis une entrée sans pays et sans législation
    #--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
   Filter [DRN] Where MVT=I_EEC and GRP="" and (CRY=WCRYDEB or CRY="") and ([DRN]LEG=GCURLEG or [DRN]LEG="")
&               Order By Key CLE1=CRY Desc;LEG Desc
   #--- On prend les valeurs associées au mouvement n'ayant aucun groupe de défini
   For [DRN]CLE1
		Raz mkstat

    Call CONTTSC([DRN]EECSCH ,GCURLEG,"","",WSITEDEB,"","") From SUBTSC
		If mkstat : Goto NEXT_DRN : Endif

    Call CONTTSC([DRN]EECSCHR,GCURLEG,"","",WSITEDEB,"","") From SUBTSC
		If mkstat : Goto NEXT_DRN : Endif

    Call CONTTEC([DRN]EECNAT ,GCURLEG,"","",WSITEDEB,"","") From SUBTEC
		If mkstat : Goto NEXT_DRN : Endif

    Call CONTTEC([DRN]EECNATR,GCURLEG,"","",WSITEDEB,"","") From SUBTEC
    If mkstat=0
      #--- Initialisation des régimes et natures
      IM_FLUX=[F:DRN]FLUX      : IM_NAT=[F:DRN]EECNAT  : IM_SCH=[F:DRN]EECSCH
      IV_FLUX=[F:DRN]FLUXREGUL : IV_NAT=[F:DRN]EECNATR : IV_SCH=[F:DRN]EECSCHR
     	#--Pour l'appel depuis la génération FUNDEB
     	If dim(VVALSTO)>0 : VVALSTO = [F:DRN]VALSTO : Endif
      WTROUV=1
     	Break
    Endif
    $NEXT_DRN
   Next
   Filter [DRN]
   Raz GMESSAGE : Raz mkstat :#--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
  Endif
Endif

Return
#######################################################################
# Prise en compte des factures complémentaires sur réception
#----------------------------------------------------------------------
$DEBG_DTA_PTHCPL
#---uniquement si la réception n'est pas encore facturée
#---(la facture complémentaire ne flague pas la ligne de réception)
#---on peut avoir une réception soldée ayant des factures complémentaires
Raz WFISAMT : Raz WSTAAMT
Raz WFACDTAAMT, WFACDTAAMTVS, WFISAMTDTA, WSTAAMTDTA, W_NUM, WPASVALO, WMAJ, WTRNOK, WTROUVE
Raz WRCPINVQTY, WORDINVQTY
Raz WSAVFISAMTDTA, WSAVSTAAMTDTA
Raz WNOLINVALO
If [F:PTD]INVQTYSTU = 0
  #---recherche des lignes de factures ayant comme origine ma réception
  For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN) & INVTYP = 1
    If ([M]REG=1 & [F:PID]LINEECFLG <> 2) | [M]REG=2
      If [F:PIH]NUM <> [F:PID]NUM
        Read [PIH]PIH0 = [F:PID]NUM
        If fstat : Raz [F:PIH] : WPASVALO= 1 : Break : Endif
        # Uniquement les factures validées
        # si une des factures n'est pas validée, il ne faut pas valoriser, car les montants peuvent changer
        If [F:PIH]STA <> 3 : WPASVALO= 1 : Break : Endif
      Else
        If [F:PIH]STA <> 3 : WPASVALO= 1 : Break : Endif
      Endif
      #--- Vérification si la facture n'a pas fait l'objet d'une DEB
      If ([F:PIH]EECNUMDEB <> 0 & [F:PIH]EECNUMDEB <> [M]EECNUMDEB) : Break : Endif
      #--- Enregistrement PIV doit exister
      If [F:PIV]NUM <> [F:PIH]NUM
        Read [PIV]PIV0=[F:PIH]NUM
        If fstat : Raz [F:PIV] : WPASVALO= 1 : Break : Endif
      Endif
      WFISAMT = [F:PID]AMTNOTLIN
      #--- Prise en compte de EECINCRAT
      # içi, car après il peut y avoir des éléments de facturation pris en compte uniquement dans la valeur statistique
      # Pas de EECINCRAT dans le PID
      # Nous devons le chercher dans la pièce de réception
      If [F:PTD]EECINCRAT <> 0
        WSTAAMT  = [F:PID]AMTNOTLIN*[F:PTD]EECINCRAT
      Else
        WSTAAMT  = [F:PID]AMTNOTLIN
      Endif
      #--- En-tête, calculons la somme des éléments de facturation de l'en-tête
      #--- Eléments de facturation
      # Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
      # Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
      # a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
      # puis répartition sur les lignes, au prorata des montants de chaque ligne
      WNUMEROPIECE = [F:PID]NUM
      W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
      Gosub ACH_TOTDTA From FUNDEB
      WFACDTAAMT   = WTOTDTA
      WFACDTAAMTVS = WTOTDTAVS
      Raz WNUMEROPIECE
      Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
      W_NUM = [F:PID]NUM
      #--- Nous traitons la ligne de détail facture liée au détail de réception
      #--- Calcul de la somme des éléments de facturation répartis sur les lignes
      # Attention :
      # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
      # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
      WPIECE       = "PIV"
      WDETAILPIECE = "PID"
      Gosub ACH_TOTDISCRG From FUNDEB
      WFACDISCRG   = WTOTDISCRG
      WFACDISCRGVS = WTOTDISCRGVS
      Raz WPIECE : Raz WDETAILPIECE
      # Si le total des lignes ne permet pas de proratiser,
      # il faut prendre en compte les éléments déjà éclatés sur les lignes
      If [F:PIV]TOTLINAMT <> 0
        WFISAMT += ((WFACDTAAMT*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRG
        WSTAAMT += ((WFACDTAAMTVS*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRGVS
      Else
        # Si le total des lignes est 0
        # il faut prendre en compte les éléments déjà éclatés sur les lignes
        WFISAMT += WFACDISCRG
        WSTAAMT += WFACDISCRGVS
      Endif
      #--- Conversion de la valeur fiscale, le cas échéant
      If [F:PIH]CUR <> WCUR
         WMONTANT = WFISAMT
         Raz STAT
         Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
         If STAT
           Raz STAT
           Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
           If STAT
             Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
             WPASVALO= 1 : Break
           Endif
         Endif
      Endif
      #--- Conversion de la valeur statistique, le cas échéant
      If [F:PIH]CUR <> WCUR
         WMONTANT = WSTAAMT
         Raz STAT
         Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
         If STAT
           Raz STAT
           Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
           If STAT
             Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
             WPASVALO= 1 : Break
           Endif
         Endif
      Endif
      #FQ 52759 - la valeur fiscale est modifiée uniquement si la ligne porte sur le même article de la réception
      If [F:PID]ITMREF = [F:PTD]ITMREF
        WFISAMTDTA += WFISAMT
      Endif
      Raz WFISAMT : Raz WMONTANT
      WSTAAMTDTA += WSTAAMT : Raz WSTAAMT : Raz WMONTANTVS
    Else
      WPASVALO= 1 : Break
    Endif
  Next
  If WPASVALO : Return : Endif
  #---Si ok on rajoute les valeurs calculées aux valeurs fiscales et stat de la réception
  If WFISAMTDTA <> 0
    [M:DEBG]FISAMT(nolign-1) += WFISAMTDTA
    [M:DEBG]LINVALOFLG(nolign-1)=2
  Endif
  #--- Valeur statistique valorisée avec les éléments de la facture cpl
  If WSTAAMTDTA <> 0
    [M:DEBG]STAAMT(nolign-1) += WSTAAMTDTA
    [M:DEBG]LINVALOFLG(nolign-1)=2
  Endif
  #--- Maj des pièces valorisées
  For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN) & INVTYP = 1 :# Factures complémentaires origine réception
      #--- Renseignement des pièces prises en compte lors de la valorisation
      #--- Facture de la réception
      #--CPO 75397 Indice incorrect
      If nolign > NBLIGNESDET
        Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
        Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
        WTRNOK = 1
        Break
      Endif
      WINDICE=find([F:PID]NUM,WVCRNUMVALO(0..14,nolign-1))
      If WINDICE<=0 or (WINDICE>0 and !find([F:PID]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
        WNOLINVALO += 1
        If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
          Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
          Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
          WTRNOK = 1
          Break
        Endif
        WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PID]NUM
        WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PID]PIDLIN
      Endif
      #---Maj des n°EECNUMDEB des entêtes des factures complémentaires
      #---Maj des LINEECFLG des lignes des factures complémentaires
      W_NUMPIECE   = [F:PID]NUM
      W_NUMLINPIEC = [F:PID]PIDLIN
      Update [PID] Where NUM=W_NUMPIECE and PIDLIN=W_NUMLINPIEC With LINEECFLG = 2
      If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break : Endif

      Update [PIH] Where NUM=[F:PID]NUM With EECNUMDEB = [M]EECNUMDEB
      If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif
   Next
   If WTRNOK : Return : Endif
Endif

Return
#######################################################################
#DM 52811 - cas particulier de la réception de ctm directe
#######################################################################
# Achats : Factures / Avoirs fournisseurs
#----------------------------------------------------------------------
$EEC_PIH
# Introduction - Factures
# Expédition   - Avoirs pour retour avec ligne supplémentaire
# Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
WUPDFIL="PIH" : WFLO=1
WUPDTYP=11 :# Introduction Achats - utilisé dans les points d'entrée (conformité versions antérieures)
#DM 52811
#Extraction uniquement des lignes de factures qui concernent des mvt. de contremarque directe
#et qui représentent le cas particulier d'une ctm directe, dont le client se situe dans le même
#état CEE que le site de vente et le fss expéditeur se situe dans un autre état CEE.
#Flux d'Introduction sur la ligne de facture (seule moyen de constater la réception,
#car pour une ctm directe il n'y a pas de réception)
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(628,197,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE  = '[F:PIH]ACCDAT<=[M]DEBDAT'            : # Date comptable < ou = a selection
CRITERE += ' & [F:PIH]ORIMOD=6'                  : # Factures du module achats
CRITERE += ' & [F:PIH]CPY=[M]CPY'
#CRITERE += ' & [F:PIH]INVTYP<3'                  : # Uniquement les Factures et les Avoirs
CRITERE += ' & [F:PIH]INVTYP=1'                  : # Uniquement les Factures
CRITERE += ' & [F:PIH]STA=3'                     : # Uniquement les pièces validées

If [M]REG=2
   CRITERE += '& ([F:PIH]EECNUMDEB=[M]EECNUMDEB | [F:PIH]EECNUMDEB=0)'
Else
   CRITERE += '& [F:PIH]EECNUMDEB=0'
Endif

Gosub ALIFILSUP From FUNDEB

For [PIH]PIH0 Where (evalue(CRITERE) & evalue(FILSUP))
  # Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
  Raz WVCRNUMVALO
  Raz WVCRLINVALO
  #enregistrement PIV doit exister
  Read [PIV]PIV0=[F:PIH]NUM
  If fstat : Goto NEXT_PIH : Endif

  #--- Si Régime et Nature sont vides, la ligne n'est pas extraite
  # If [F:PIH]EECSCH="" and [F:PIH]EECNAT=""
  #   If [M]PRNULREGNA=2
  #     Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-mess(746,197,1),0) From GESECRAN
  #   Endif
  #   Goto NEXT_PIH
  # Endif

  #--- Type de mouvement
  #WMVT=8 :# Réception classique

  # Afin de retrouver les bons numéros en cas de rollback
  WOLDLININT = WNOLININT
  WOLDLINEXP = WNOLINEXP
  Call DEBTRANS From GLOCK
  Trbegin [DEB]

  #--- Prise en compte des éléments de l'entête de pièce, puis de chaque ligne de détail
  Gosub EEC_UN_PIH
  If WOK=0 : Gosub AB_DEB From FUNDEB : Goto NEXT_PIH : Endif

  #--- Ecriture des éléments du masque DEBGEN dans le fichier DEB
  Gosub EEC_DEBGEN From FUNDEB
  If WOK=0 : Gosub AB_DEB From FUNDEB : Goto NEXT_PIH : Endif

  #--- MAJ champ EECNUMDEB si l'écriture dans le fichier DEB a réussi
  #--- Uniquement si au moins une ligne a été renseignée dans le masque de génération
  If [M:DEBG]NBDEB > 0
    W_NUMPIECE = [F:PIH]NUM
      #--- Maj no traitement dans la pièce de réception
      Update [PIH] Where NUM = W_NUMPIECE With EECNUMDEB = [M]EECNUMDEB
      If fstat
        Call FSTA("PIH") From GLOCK
        Gosub AB_DEB From FUNDEB
        Goto NEXT_PIH
      Endif
      Raz W_NUMPIECE
  Else
    #--- si aucune ligne extraite
    Gosub AB_DEB From FUNDEB
    Goto  NEXT_PIH
  Endif

  Call ECR_TRACE(mess(628,197,1)-[F:PIH]NUM-mess(741,197,1),0) From GESECRAN

  Commit
$NEXT_PIH
Next

Return : # Les différentes pièces seront traitées lors des traitements des réceptions et des retours
#----------------------------------------------------------------------
$EEC_UN_PIH
Case [F:PIV]INVTYP
  When 1       :  Gosub EEC_UN_PIH_FACTURE                                 :# Traitement des Factures / Factures Complémentaires
  When 2       :  Gosub EEC_UN_PIH_AVOIR                                   :# Traitement des Avoirs / Avoirs pour retour
  When Default                                                             :# Les autres types de factures ne serons pas pris en compte
Endcase

Return
#----------------------------------------------------------------------
$EEC_UN_PIH_FACTURE
#--- Traitement des Factures et des Factures complémentaires
# Les factures qui concernent des Réceptions serons traitées lors de la prise en compte de ces dernières
# Les autres factures ne serons pas prises en compte (pas de régularisations pour les flux d'Introduction)
#DM 52811 - sauf certains cas particulier de factures sur cde de ctm

WOK    = 1    :# mettre à 0 pour ne pas prendre en compte la pièce
WOKLIG = 1    :# mettre à 0 pour ne pas prendre en compte une ligne de détail
Raz W_NUM     :# pour calculer une seule fois les elts de facturation non répartis

#--- TS Issue 101474 --CPO OK
If [F:PIH]CRY=""
  If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:PIH]BPR or [F:BPA]BPAADD<>[F:PIH]BPAINV
    Read [BPA]BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
    If fstat : Raz [F:BPA] : Endif
  Endif
  [F:PIH]CRY = [F:BPA]CRY
  #  Read [BPA]BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
  #  If !fstat : [F:PIH]CRY=[F:BPA]CRY : Endif
Endif
#---

#--- Chargement du masque DEBGEN
nolign=0
For [PID]Where NUM=[F:PIH]NUM
  WOKLIG = 1 :#--CPO 97006
  #--CPO 106690 Cas de deux lignes de type "divers", n'ayant pas d'article et qui se suivent
  If [F:PID]ITMREF="" :  Goto NEXT_EEC_UN_PIH : Endif
  #--/
  #--CPO DM 105661 Ajout de la sous-traitance
  #--Déplacé au début du For..plus propre
  # Uniquement les lignes avec origine commande
  If [F:PID]TYPORI<>1 : Goto NEXT_EEC_UN_PIH : Endif
  #--/
  #--- Si l'article n'est pas "Soumis à la DEB", on saute la ligne de détail
  If [F:ITM]ITMREF <> [F:PID]ITMREF
    Read [F:ITM]ITM0=[F:PID]ITMREF
    If fstat : Raz [F:ITM] : Goto NEXT_EEC_UN_PIH : Endif
  Endif
  #--CPO DM 105661 Ajout de la sous-traitance
  #--Déplacé après le contrôle des pays..plus propre car pas la peine d'avoir un message si doc non objet DEB
  #--- Si l'article n'est pas "Soumis à la DEB", on saute la ligne de détail
  #If [F:ITM]EECGES <> 2
  #  #--CPO 74679 Amélioration de la trace
  #  WMESS_CODE=3 : WMESS_TRACE=mess(735,197,1)-[F:PID]NUM-num$([F:PID]PIDLIN)-[F:ITM]ITMREF : Gosub MESS_TRACE From FUNDEB
  #  #--CPO
  #  Goto NEXT_EEC_UN_PIH
  #Endif
  ##---FQ 52926
  ##---on extrait uniquement les lignes de type "Nomenclature composé"
  ##---et celles "Standard"
  #If [F:PID]LINTYP  > 2
  #  #--CPO 74679 Amélioration de la trace
  #  WMESS_CODE=4 : WMESS_TRACE=mess(735,197,1)-[F:PID]NUM-num$([F:PID]PIDLIN) : Gosub MESS_TRACE From FUNDEB
  #  #--CPO
  #  Goto NEXT_EEC_UN_PIH
  #Endif
  #--/
  #--CPO DM 105661 Ajout de la sous-traitance
  #--Déplacé au début du For..plus propre
  # Uniquement les lignes avec origine commande
  #If [F:PID]TYPORI<>1 : Goto NEXT_EEC_UN_PIH : Endif
  #--/
  Read [POQ]POQ0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
  If fstat : Raz [F:POQ] : Goto NEXT_EEC_UN_PIH : Endif
  # Uniquement les lignes de commande avec origine ctm directe
  If [F:POQ]ORI<>2 : Goto NEXT_EEC_UN_PIH : Endif

  #FQ 56398 (suite de 51074) - Point d'entrée pour gérer des contrôles à la ligne
  Local Integer SAUVGPE     : SAUVGPE=GPE : GPE=0
  #La variable GPE permet d'accepter ou de refuser la ligne
  # 0 -> la ligne est acceptée
  # 1 -> la ligne est refusée, on passe à la suivante
  #La doc de PE existe mais sur FUNDEB
  GPOINT="DEBCTLLIG" : Gosub ENTREE From EXEFNC   #CHECK IGNORE_LINE
  If GPE : GPE=SAUVGPE : Goto NEXT_EEC_UN_PIH : Endif
  #FQ 56398

  Read [POP]POP0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
  If fstat : Raz [F:POP] : Goto NEXT_EEC_UN_PIH : Endif
  Read [POH]POH0=[F:PID]POHNUM
  If fstat : Raz [F:POH] : Goto NEXT_EEC_UN_PIH : Endif

  #--- TS Issue 101474 --CPO OK
  If [F:POH]BPOCRY=""
    If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:POH]BPSNUM or [F:BPA]BPAADD<>[F:POH]BPOADD
      Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
      If fstat : Raz [F:BPA] : Endif
    Endif
    [F:POH]BPOCRY=[F:BPA]CRY
    #  Read [BPA]BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
    #  If !fstat : [F:POH]BPOCRY=[F:BPA]CRY : Endif
  Endif
  #---

  # Contrôle CEE des pays de provenance et de destination
  # A partir de la cde de ctm, car lieux d'expédition/réception éffectives
  Raz WOKLIG                                        : # controle pays depart a la ligne
  If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:POQ]PRHFCY
    W_CRYTO=[F:FCY]CRY                              : # pays arrive
  Else
    Read [FCY]FCY0=[F:POQ]PRHFCY                    : # site de réception
    If fstat : Raz [F:FCY] : Endif
    W_CRYTO=[F:FCY]CRY                              : # pays arrive
  Endif
  W_DATE=[F:PIH]ACCDAT                              : # date mouvement=date facture car c'est elle qui constate la "réception"
  W_FFWNUM=[F:PIH]FFWNUM : W_FFWADD=[F:PIH]FFWADD   : # donnees transitaire
  #--- on tient compte uniquement de l'adresse du fss expéditeur de l'entête de la cde
  W_CRYFROM=[F:POH]BPOCRY                           : # pays du fss facturant
  Gosub CTL_EEC_CRY
  #On test le WOK de l'étiquette CTL_EEC_CRY
  If WOK=0 : WOK=1 : Goto NEXT_EEC_UN_PIH : Endif

  #--CPO DM 105661 Ajout de la sous-traitance
  #--Déplacé après le contrôle des pays..plus propre car pas la peine d'avoir un message si doc non objet DEB
  #--- Si l'article n'est pas "Soumis à la DEB", on saute la ligne de détail
  If [F:ITM]EECGES <> 2
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=3 : WMESS_TRACE=mess(735,197,1)-[F:PID]NUM-num$([F:PID]PIDLIN)-[F:ITM]ITMREF : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_EEC_UN_PIH
  Endif
  #---FQ 52926
  #---on extrait uniquement les lignes de type "Nomenclature composé"
  #---et celles "Standard"
  If find([F:PID]LINTYP,3,4)>0
    #--CPO 74679 Amélioration de la trace
    WMESS_CODE=4 : WMESS_TRACE=mess(735,197,1)-[F:PID]NUM-num$([F:PID]PIDLIN) : Gosub MESS_TRACE From FUNDEB
    #--CPO
    Goto NEXT_EEC_UN_PIH
  Endif
  #--/

  Read [SOQ]SOQ0=[F:POQ]SOHNUM;[F:POQ]SOPLIN;[F:POQ]SOQSEQ
  If fstat : Raz [F:SOQ] : Goto NEXT_EEC_UN_PIH : Endif

  If [F:SOQ]FMI=2 and [F:SOQ]FMINUM=[F:POQ]POHNUM
    #Nous sommes sur une ligne de facture achat avec origine commande achat
    #générée par ctm directe depuis la cde de vente
    #On déclare un flux d'introduction
    #si le site du client livré (cde vente) est dans le même pays que celui du site d'expédition
    #et le pays du fss expéditeur est dans un pays tiers CEE (c'est le cas suite au contrôle CTL_EEC)
    Read [F:SOH]=[F:SOQ]SOHNUM
    If fstat : Raz [F:SOH] : Goto NEXT_EEC_UN_PIH : Endif
    # Il faut s'assurer que le pays du site de réception est identique au pays du site d'expédition
    # si les deux sites sont différents
    If [F:POQ]PRHFCY<>[F:SOH]STOFCY
      Read [FCY]FCY0=[F:POQ]PRHFCY
      If fstat : Raz [F:FCY] : Endif
      GBIDC1=[F:FCY]CRY
      Read [FCY]FCY0=[F:SOH]STOFCY
      If fstat : Raz [F:FCY] : Endif
      GBIDC2=[F:FCY]CRY
      If GBIDC1<>GBIDC2 : Goto NEXT_EEC_UN_PIH : Endif
    Endif
    # Condition du cas particulier permettant l'extraction
    # Le site d'expédition de la cde de vente de ctm est identique au pays de l'adresse du client livré de la même cde
    If [F:FCY]FCY<>[F:SOH]STOFCY
      Read [FCY]FCY0=[F:SOH]STOFCY
      If fstat : Raz [F:FCY] : Endif
    Endif
    If [F:SOH]BPDCRY=[F:FCY]CRY
      #le pays du client livré est le même que celui du site d'expédition
      WOKLIG=1

      nolign +=1
      #--- Chargement du masque avec les éléments de la ligne
      Gosub DEBG_PIH
      If WOK = 0    : Break : Endif                              :# la pièce n'est pas prise en compte
      If WOKLIG = 0 : nolign -= 1 : Goto NEXT_EEC_UN_PIH : Endif :# le détail n'est pas pris en compte, on passe au prochain

      #--- Maj flag LINEECFLG dans les détails de la pièce
      If [F:PID]NUM <> ""
        W_NUMPIECE = [F:PID]NUM
        W_NUMLINPIEC = [F:PID]PIDLIN
        Update [PID] Where NUM = W_NUMPIECE and PIDLIN = W_NUMLINPIEC With LINEECFLG = 2
        If fstat : Call FSTA("PID") From GLOCK : WOK = 0 : Break : Endif
        Raz W_NUMPIECE
        Raz W_NUMLINPIEC
      Endif
    Endif
  Endif

$NEXT_EEC_UN_PIH
Next

If WOK = 0 : Return : Endif
If nolign = 0 : WOK = 0 : Return : Endif

Return
#----------------------------------------------------------------------
$EEC_UN_PIH_AVOIR
#--- Traitement des Avoirs / Avoirs pour retour
Case [F:PIH]PIHTYP
  When 3    : Gosub EEC_UN_PIH_AVOIR_FINANCIER
  When 4    : Gosub EEC_UN_PIH_AVOIR_RETOUR
  When Default
Endcase

Return
#----------------------------------------------------------------------
$EEC_UN_PIH_AVOIR_FINANCIER
#--- Traitement des Avoirs
# Seuls les flux physiques sont à déclarer en achat, donc les avoirs financiers ne serons pas pris en compte
# Pour sauter la pièce
WOK = 0 :# Si traitement écrit par la suite, le positionner à 1

Return
#----------------------------------------------------------------------
$EEC_UN_PIH_AVOIR_RETOUR
#--- Traitement des Avoirs sur Retours
If [F:PIV]PIHTYP <> 4 : Return : Endif
# Le flux physique sera traité lors du traitement des retours,
# les Avoirs sur retours serons traités à ce moment là, afin de valoriser les retours, le cas échéant

# Dans ce traitement doivent être traités les lignes supplémentaires des Avoirs sur retour,
# Mais aujourd'hui il n'est pas possible d'avoir une ligne supplémentaire de retour sur un tel avoir, ligne non liée à un retour
# Pour sauter la pièce
WOK = 0 :# Si traitement écrit par la suite, le positionner à 1

Return
# Traitement à remettre le jour où il sera possible d'avoir une ligne supplémentaire retour dans un tel avoir,
# Mais non liée à une pièce de retour.
#-----------------------------------------------------------------------
$DEBG_PIH
If nolign=1
  Raz [M:DEBG]
  [M:DEBG]CPY       = [M:DIA]CPY
  [M:DEBG]CUR       = [F:CPY]ACCCUR
  [M:DEBG]EECNUMDEB = [M:DIA]EECNUMDEB
  [M:DEBG]DEBDAT    = [M:DIA]DEBDAT
  [M:DEBG]VCRTYP    = 17
  [M:DEBG]VCRNUM    = [F:PIH]NUM
  [M:DEBG]DAT       = [F:PIH]ACCDAT
  [M:DEBG]CURDOC    = [F:PIH]CUR
  [M:DEBG]BPRNUM    = [F:PIH]BPR
  If [F:PTH]EECNUM<>""
    [M:DEBG]EECNUM = [F:PIH]EECNUM
  Else
    #--- N° d'identif CEE du fournisseur facturant
    If [F:BPR]BPRNUM <> [F:PIH]BPR
      Read [BPR]BPR0 = [F:PIH]BPR
      If fstat : Raz [F:BPR] : Endif
      [M:DEBG]EECNUM  = [F:BPR]EECNUM
    Else
      [M:DEBG]EECNUM  = [F:BPR]EECNUM
    Endif
  Endif
  #FQ 52621
  #--- Cas du n° de TVA issu du pays de réception
  If [M:DEBG]EECNUM <> ""
    If left$([M:DEBG]EECNUM,2)=W_EECCRYTO
      Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM,0) From GESECRAN
      # "Radical du numéro de TVA identique à celui du site de réception"
      Call ECR_TRACE(mess(751,197,1),0) From GESECRAN
    Endif
  Endif
Endif
#--- N° de département
If [F:PID]TYPORI=1 :# Origine commande
  If [F:POQ]PRHFCY<>""
    If [F:FCY]FCY<>[F:POQ]PRHFCY
      Read [FCY]FCY0=[F:POQ]PRHFCY
      If fstat : Raz [F:FCY] : Endif
    Endif
    If [F:FCY]BPAADD <> ""
      Read [BPA]BPA0=3;[F:POQ]PRHFCY;[F:FCY]BPAADD
      If fstat : Raz [F:BPA] : Endif
    Endif
    #--- Site de stockage
    [M:DEBG]STOFCY  (nolign-1) = [F:POQ]PRHFCY  :# dépend de l'origine de la ligne
    [M:DEBG]CRYFCY  (nolign-1) = [F:FCY]CRY     :# le pays du site
  Endif
Else
  If [F:FCY]FCY<>[F:PID]FCY
    Read [FCY]FCY0=[F:PID]FCY
    If fstat : Raz [F:FCY] : Endif
  Endif
  If [F:FCY]BPAADD <> ""
    Read [BPA]BPA0=3;[F:PID]FCY;[F:FCY]BPAADD
    If fstat : Raz [F:BPA] : Endif
  Endif
  #--- Site de stockage
  [M:DEBG]STOFCY  (nolign-1) = [F:PID]FCY  :# dépend de l'origine de la ligne
  [M:DEBG]CRYFCY  (nolign-1) = [F:FCY]CRY     :# le pays du site
Endif
If [F:BPA]POSCOD<>""
  [M:DEBG]REG (nolign-1) = left$([F:BPA]POSCOD,2)
Endif

#--- Etat fédéral
If dim([M:DEBG]STAFED)>0
  Read [ITF]ITF0=[F:PID]ITMREF;[F:PIH]FCY
  If fstat : Raz [F:ITF] : Endif
  If dim([F:ITF]STAFED)<>0 and [F:ITF]STAFED<>""
    [M:DEBG]STAFED(nolign-1)=[F:ITF]STAFED
  Else
    If dim([F:ITM]STAFED)>0 and [F:ITM]STAFED<>""
      [M:DEBG]STAFED(nolign-1)=[F:ITM]STAFED
    Endif
  Endif
Endif

#---
[M:DEBG]VCRLIN  (nolign-1) = [F:PID]PIDLIN
[M:DEBG]FLO     (nolign-1) = 1
[M:DEBG]ITMREF  (nolign-1) = [F:PID]ITMREF
[M:DEBG]ITMDES1 (nolign-1) = [F:PID]ITMDES1
[M:DEBG]CUSREF  (nolign-1) = [F:ITM]CUSREF
Raz WTROUVE
Raz WVALSTO
If [F:PIH]EECNAT<>""
  [M:DEBG]EECNAT  (nolign-1) = [F:PIH]EECNAT
Else
  #Si pas de Nature renseignée, on cherche la Nature du type de mvt 8 - "Réception classique"
  Call FLUX_REGNAT(8,[M:DEBG]STOFCY(nolign-1),[M:DEBG]CRYFCY(nolign-1),[M:DEBG]EECSCH(nolign-1),[M:DEBG]EECNAT(nolign-1),WVALSTO,WTROUVE)
  If WTROUVE
    Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-num$([F:PID]PIDLIN),0) From GESECRAN
    # "Le Régime CEE et/ou la Nature ont été modifiés"
    Call ECR_TRACE(mess(752,197,1),0) From GESECRAN
  Endif
Endif
If [F:PIH]EECSCH<>""
  [M:DEBG]EECSCH  (nolign-1) = [F:PIH]EECSCH
Elsif WTROUVE=0
  Call FLUX_REGNAT(8,[M:DEBG]STOFCY(nolign-1),[M:DEBG]CRYFCY(nolign-1),[M:DEBG]EECSCH(nolign-1),GBIDC1,WVALSTO,WTROUVE)
  If WTROUVE
    Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-num$([F:PID]PIDLIN),0) From GESECRAN
    # "Le Régime CEE et/ou la Nature ont été modifiés"
    Call ECR_TRACE(mess(752,197,1),0) From GESECRAN
  Endif
Endif
#--- Si Régime et Nature sont vides, la ligne n'est pas extraite
If [M:DEBG]EECSCH(nolign-1)="" and [M:DEBG]EECNAT(nolign-1)=""
  If [M]PRNULREGNA=2
    Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-num$([F:PID]PIDLIN)-mess(746,197,1),0) From GESECRAN
  Endif
  WOKLIG=0 : Return
Endif
If W_EECCRYFFW<>""
  [M:DEBG]DESCRY(nolign-1) = W_EECCRYFFW
Else
  [M:DEBG]DESCRY(nolign-1) = W_EECCRYFROM
Endif
#--- Pays d'origine
If [F:PID]TYPORI=1        :# Origine commande
  If [F:POP]ORICRY<>""
    LCRY=[F:POP]ORICRY
  Else
    LCRY=[F:POH]BPOCRY
  Endif
Else
  LCRY=[F:PIH]CRY         :# le pays du fss facturant
Endif
Gosub LEC_TCY From FUNDEB
If [F:TCY]EECFLG=2 & [F:TCY]EECCOD<>""
  [M:DEBG]ORICRY(nolign-1)=[F:TCY]EECCOD
Else
  [M:DEBG]ORICRY(nolign-1)=[F:TCY]ISO
Endif
#--- Masse nette et unités CEE
If [F:ITM]ITMWEI<>0
  If toupper(left$([F:ITM]WEU,2))="KG"
    [M:DEBG]NETMAS (nolign-1) = [F:ITM]ITMWEI*[F:PID]QTYSTU
  Else
    I=find("KG",GUNITE(1..GDIMUNT))
    If I=0 I=find("Kg",GUNITE(1..GDIMUNT)) Endif
    If I=0 I=find("kg",GUNITE(1..GDIMUNT)) Endif
    If I<>0
      Read [TCO]TCO0=[F:ITM]WEU;GUNITE(I)
      If !fstat [M:DEBG]NETMAS (nolign-1) = [F:ITM]ITMWEI*[F:PID]QTYSTU*[F:TCO]COEUOM Endif
    Endif
  Endif
Endif
If [F:ITM]EEU<>"" & [F:ITM]EEUSTUCOE<>0
  [M:DEBG]EECUNT (nolign-1) =[F:PID]QTYSTU/[F:ITM]EEUSTUCOE
Endif
[M:DEBG]EECTRN  (nolign-1) = [F:PIH]EECTRN
[M:DEBG]EECICT  (nolign-1) = [F:PIH]EECICT
[M:DEBG]EECLOC  (nolign-1) = [F:PIH]EECLOC
#--- Calcul de la valeur fiscale
#--- Calcul de la valeur statistique
#--- Prise en compte des éléments de facturation

#--- En-tête, calculons la somme des éléments de facturation de l'en-tête
#--- Eléments de facturation
# Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
# Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
# a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
# puis répartition sur les lignes, au prorata des montants de chaque ligne
WNUMEROPIECE = [F:PID]NUM
W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
Gosub ACH_TOTDTA From FUNDEB
WINVDTAAMT   = WTOTDTA
WINVDTAAMTVS = WTOTDTAVS
Raz WNUMEROPIECE
Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
W_NUM = [F:PID]NUM

#--- Calcul de la somme des éléments de facturation répartis sur les lignes
# Attention :
# Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
# De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
WPIECE       = "PIV"
WDETAILPIECE = "PID"
Raz WFACDISCRG : Raz WFACDISCRGVS
Gosub ACH_TOTDISCRG From FUNDEB
WFACDISCRG   = WTOTDISCRG
WFACDISCRGVS = WTOTDISCRGVS
Raz WPIECE : Raz WDETAILPIECE

# Répartition sur chaque ligne au prorata des montants
Raz WFISAMT : Raz WSTAAMT
WFISAMT = [F:PID]AMTNOTLIN
#--- Prise en compte de EECINCRAT
# içi, car après il peut y avoir des éléments de facturation pris en compte uniquement dans la valeur statistique
# Pas de EECINCRAT dans le PID
# Nous devons le chercher sur la commande
If [F:PID]TYPORI=1 :# Origine commande
  If [F:POP]EECINCRAT<>0
    WSTAAMT  = [F:PID]AMTNOTLIN*[F:POP]EECINCRAT
  Else
    WSTAAMT  = [F:PID]AMTNOTLIN
  Endif
Else
  #Coef du fss expéditeur
  Read [F:BPS]BPS0=[F:PIH]BPR
  If fstat : Raz [F:BPS] : Endif
  If [F:BPS]EECINCRAT<>0
    WSTAAMT  = [F:PID]AMTNOTLIN*[F:BPS]EECINCRAT
  Else
    WSTAAMT  = [F:PID]AMTNOTLIN
  Endif
Endif

# Si le total des lignes ne permet pas de proratiser,
# il faut prendre en compte les éléments déjà éclatés sur les lignes
If [F:PIV]TOTLINAMT <> 0
  WFISAMT += ((WINVDTAAMT*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRG
  WSTAAMT += ((WINVDTAAMTVS*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRGVS
Else
  # il faut prendre en compte les éléments déjà éclatés sur les lignes
  WFISAMT += WFACDISCRG
  WSTAAMT += WFACDISCRGVS
Endif
#--- Conversion de la valeur fiscale, le cas échéant
If [F:PIH]CUR <> WCUR
   WMONTANT = WFISAMT
   Raz STAT
   Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
   If STAT
     Raz STAT
     Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
     If STAT
       Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
       WOK = 0 : Return
     Endif
   Endif
Endif
#--- Conversion de la valeur statistique, le cas échéant
If [F:PIH]CUR <> WCUR
   WMONTANT = WSTAAMT
   Raz STAT
   Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
   If STAT
     Raz STAT
     Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
     If STAT
       Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
       WOK=0 : Return
     Endif
   Endif
Endif
[M:DEBG]FISAMT(nolign-1)=WFISAMT
[M:DEBG]STAAMT(nolign-1)=WSTAAMT

[M:DEBG]NIV   (nolign-1)=GNIVINT
[M:DEBG]NBDEB = nolign

Return
###########################################################################################
$VALO_AVR_RET
If [F:SID]SRHNUM = "" : Return : Endif
#Lors de la valorisation de la ligne de retour, si le montant de l'avoir sur retour est 0
#on prend le prix de l'ordre de la ligne de retour.
#Donc, quand on extrait le flux de régul Expédition, sur la ligne d'avoir, si son montant est à 0
#il faut également valoriser cette ligne avec le prix de l'ordre du retour à l'origine de l'avoir
Raz WFISAMT : Raz WSTAAMT
If [F:SID]AMTNOTLIN=0 and find([F:SID]LINTYP,3,4,5,7,8,9,11,12,13)=0
  Read [F:SRD]SRD0=[F:SID]SRHNUM;[F:SID]SRDLIN
  If !fstat and [F:SRD]PRIORD <> 0
    #--- On tient compte du paramétrage valeur stock des paramétres des flux par mouvement
    Raz WTROUVE,WVALSTO
    Call FLUX_REGNAT(WMVT,[M:DEBG]STOFCY(nolign-1),[F:FCY]CRY,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA
    If WTROUVE and WVALSTO=2
      WFISAMT = [F:SRD]PRIORD*[F:SID]QTYSTU
    Else
      #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
      Raz JL0,JL1
      #--CPO 71937 Déclinaison multi-lég TABEECSCH et TABEECNAT
      #JL0=find([M:DEBG]EECSCH(nolign-1),REG_CODE) :# Pour tenir compte de la modif de Reg/Nat des gratuits
      #JL1=find([M:DEBG]EECNAT(nolign-1),NAT_CODE) :# Pour tenir compte de la modif de Reg/Nat des gratuits
      #If (JL0 and REG_VALSTO(JL0-1)=2) or (JL1 and NAT_VALSTO(JL1-1)=2)
      Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
      If JL0>0 : Raz [F:TSC] : Endif
      Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
      If JL1>0 : Raz [F:TEC] : Endif
      If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
      #--/
        WFISAMT = [F:SRD]PRIORD*[F:SID]QTYSTU
      Endif
    Endif
  Endif
  #Il faut convertir le montant obtenu de la devise de la société en celle de facturation,
  #car à ces montants il faut rajouter les éléments de facturation de la ligne d'avoir
  If WFISAMT > 0
    If WCUR <> [F:SIH]CUR
      WKMONTANT = WFISAMT
      Raz STAT
      Call CONVERT(WCUR,[F:SIH]CUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT ,WKMONTANT,WFISAMT,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT(WCUR,[F:SIH]CUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WKMONTANT,WFISAMT,STAT) From TRTDEV
        If STAT
          WOK=0
          Call ECR_TRACE(mess(735,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
          Return
        Endif
      Endif
    Endif
    #--- Prise en compte du coefficient de majoration CEE, le cas échéant
    If [F:BPD]BPCNUM = [F:SIV]BPCORD and [F:BPD]BPAADD = [F:SIV]BPAADD
      If [F:BPD]EECINCRAT <> 0
        WSTAAMT = WFISAMT*[F:BPD]EECINCRAT
      Endif
    Endif
  Endif
  WFISAMT += WDISCRGAMT
  WSTAAMT += WDISCRGAMTVS
  #--- Conversion de la valeur fiscale, le cas échéant
  If [F:SIH]CUR <> WCUR
    WKFISAMT=WFISAMT
    Raz STAT
    Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WKFISAMT,WFISAMT,STAT) From TRTDEV
    If STAT
      Raz STAT
      Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WKFISAMT,WFISAMT,STAT) From TRTDEV
      If STAT
        WOK=0
        Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
        Return
      Endif
    Endif
  Endif
  #--- Conversion de la valeur statistique, le cas échéant
  If [F:SIH]CUR <> WCUR
    WKSTAAMT=WSTAAMT
    Raz STAT
    Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WKSTAAMT,WSTAAMT,STAT) From TRTDEV
    If STAT
      Raz STAT
      Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WKSTAAMT,WSTAAMT,STAT) From TRTDEV
      If STAT
        WOK=0
        Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
        Return
      Endif
    Endif
  Endif
  [M:DEBG]FISAMT(nolign-1)=WFISAMT
  [M:DEBG]STAAMT(nolign-1)=WSTAAMT
Endif

Return
#------------------CPO Lors de la correction 75397 Ttt FUNDEB trop long !----------------------
#--- Reception fournisseur --------------------------------------------
$CTL_EEC_PTH
Raz WOKLIG                                           : # controle pays depart a la ligne

If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:PTH]PRHFCY
  W_CRYTO=[F:FCY]CRY                               : # pays arrive
Else
  Read [FCY]FCY0=[F:PTH]PRHFCY                     : # site de réception
  If fstat : Raz [F:FCY] : Endif
  W_CRYTO=[F:FCY]CRY                               : # pays arrive
Endif

W_DATE=[F:PTH]RCPDAT                                 : # date mouvement
W_FFWNUM=[F:PTH]FFWNUM : W_FFWADD=[F:PTH]FFWADD      : # donnees transitaire
#--- on tient compte uniquement de l'adresse du fss expéditeur de l'entête
W_CRYFROM=[F:PTH]BPOCRY                              : # pays depart

#--- TS Issue 101474 --CPO OK
If W_CRYFROM=""
  If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:PTH]BPSNUM or [F:BPA]BPAADD<>[F:PTH]BPOADD
    Read [BPA]BPA0=1;[F:PTH]BPSNUM;[F:PTH]BPOADD
    If fstat : Raz [F:BPA] : Endif
  Endif
  W_CRYFROM=[F:BPA]CRY
Endif
#---

Gosub CTL_EEC_CRY
If WOK=0 : Return : Endif
#For [PTD] Where PTHNUM=[F:PTH]PTHNUM
#    W_CRYFROM=[F:PTD]BPOCRY                          : # pays depart
#    Gosub CTL_EEC_CRY
#    If WOKLIG : Break : Endif                        : # au moins une ligne à traiter
#Next
#If WOKLIG=0 : WOK=0 : Return
# Si'l trouve quand même une ligne qui respecte les contraintes de pays,
# alors qu'avant la var WOK a été positionnée à 0 (lignes d'avant ne respectaient pas)
# le WOK reste à 0 malgré le fait que WOKLIG soit à 1.
# Donc si WOKLIG = 1 il faut remettre WOK à 1 car cela veut dire qu'on a trouvé une ligne
#Else WOK=1 : Return : Endif

Return
#--- Retour fournisseur -----------------------------------------------
$CTL_EEC_PNH
Raz WOKLIG                                           : # controle pays arrivee a la ligne

If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:PNH]PNHFCY
  W_CRYFROM=[F:FCY]CRY                             : # pays depart
Else
  Read [FCY]FCY0=[F:PNH]PNHFCY                     : # site de retour
  If fstat : Raz [F:FCY] : Endif
  W_CRYFROM=[F:FCY]CRY                             : # pays depart
Endif

W_DATE=[F:PNH]RTNDAT                                 : # date mouvement
W_FFWNUM=[F:PNH]FFWNUM : W_FFWADD=[F:PNH]FFWADD      : # donnees transitaire
#--- on tient compte uniquement de l'adresse du fss expéditeur de l'entête
W_CRYTO=[F:PNH]CRY                                   : # pays arrivee
Gosub CTL_EEC_CRY
If WOK=0 : Return : Endif
#For [PND] Where PNHNUM=[F:PNH]PNHNUM
#    W_CRYTO=[F:PND]BPOCRY                            : # pays arrivee
#    Gosub CTL_EEC_CRY
#    If WOKLIG : Break : Endif                        : # au moins une ligne à traiter
#Next
#If WOKLIG=0 : WOK=0 : Return
# Si'l trouve quand même une ligne qui respecte les contraintes de pays,
# alors qu'avant la var WOK a été positionnée à 0 (lignes d'avant ne respectaient pas)
# le WOK reste à 0 malgré le fait que WOKLIG soit à 1.
# Donc si WOKLIG = 1 il faut remettre WOK à 1 car cela veut dire qu'on a trouvé une ligne
#Else WOK=1 : Return : Endif

Return
#--- Facture / Avoir fournisseur --------------------------------------
$CTL_EEC_PIH
# Aucune pièce facture ou avoir achat n'est traitée directement
# Les factures liées à des réceptions ou à des factures de réceptions serons traitées lors du traitement des pièces de réception
# Les avoirs pour retours serons traités lors du traitement des retours
# Les pièces liées à des flux financiers ne sont pas à traiter en Achats.
#######################################################################
#V6.10
Raz WOKLIG                                        : # controle pays depart a la ligne

If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:PIH]FCY
  W_CRYTO=[F:FCY]CRY                              : # pays arrive
Else
  Read [FCY]FCY0=[F:PIH]FCY                       : # site de réception
  If fstat : Raz [F:FCY] : Endif
  W_CRYTO=[F:FCY]CRY                              : # pays arrive
Endif

W_DATE=[F:PIH]ACCDAT                              : # date mouvement
W_FFWNUM=[F:PIH]FFWNUM : W_FFWADD=[F:PIH]FFWADD   : # donnees transitaire
#--- on tient compte uniquement de l'adresse du fss de l'entête
W_CRYFROM=[F:PIH]CRY                              : # pays du fss facturant

#--- TS Issue 101474 --CPO OK
If W_CRYFROM=""
  If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:PIH]BPR or [F:BPA]BPAADD<>[F:PIH]BPAINV
    Read [BPA]BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
    If fstat : Raz [F:BPA] : Endif
  Endif
  W_CRYFROM=[F:BPA]CRY
  #  Read [BPA]BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
  #  If !fstat : W_CRYFROM=[F:BPA]CRY : Endif
Endif
#---

Gosub CTL_EEC_CRY
If WOK=0 : Return : Endif
#######################################################################

Return
#--- Livraison client -------------------------------------------------
$CTL_EEC_SDH

If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:SDH]STOFCY
  W_CRYFROM=[F:FCY]CRY                             : # pays depart
Else
  Read [FCY]FCY0=[F:SDH]STOFCY
  If fstat : Raz [F:FCY] : Endif
  W_CRYFROM=[F:FCY]CRY                             : # pays depart
Endif

If [F:SDH]BPDCRY<>""                               : # pays arrivee
  W_CRYTO=[F:SDH]BPDCRY
Else
  If [F:BPA]BPANUM<>"" and [F:BPA]BPATYP=1 and [F:BPA]BPANUM=[F:SDH]BPCORD and [F:BPA]BPAADD=[F:SDH]BPAADD
    W_CRYTO=[F:BPA]CRY
  Else
    Read [BPA]BPA0=1;[F:SDH]BPCORD;[F:SDH]BPAADD
    If fstat : Raz [F:BPA] : Endif
    W_CRYTO=[F:BPA]CRY
  Endif
Endif

W_DATE=[F:SDH]DLVDAT                               : # date mouvement
W_FFWNUM=[F:SDH]FFWNUM : W_FFWADD=[F:SDH]FFWADD    : # donnees transitaire
Gosub CTL_EEC_CRY :
If WOK=0 : Return : Endif

Return
#--- Retour client ----------------------------------------------------
$CTL_EEC_SRH
If [F:SRH]BPDCRY<>""                               : # pays depart
  W_CRYFROM=[F:SRH]BPDCRY
Else
  If [F:BPA]BPANUM<>"" and [F:BPA]BPATYP=1 and [F:BPA]BPANUM=[F:SRH]BPCORD and [F:BPA]BPAADD=[F:SRH]BPAADD
    W_CRYFROM=[F:BPA]CRY
  Else
    Read [BPA]BPA0=1;[F:SRH]BPCORD;[F:SRH]BPAADD
    If fstat : Raz [F:BPA] : Endif
    W_CRYFROM=[F:BPA]CRY
  Endif
Endif

If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:SRH]STOFCY
  W_CRYTO=[F:FCY]CRY
Else
  Read [FCY]FCY0=[F:SRH]STOFCY                     : # pays arrivee
  If fstat : Raz [F:FCY] : Endif
  W_CRYTO=[F:FCY]CRY
Endif

W_DATE=[F:SRH]RTNDAT                               : # date mouvement
W_FFWNUM=[F:SRH]FFWNUM : W_FFWADD=[F:SRH]FFWADD    : # donnees transitaire
Gosub CTL_EEC_CRY
If WOK=0 : Return : Endif

Return
#--- Facture / Avoir client -------------------------------------------
$CTL_EEC_SIH

If [F:SIV]STOFCY <> ""
  If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:SIV]STOFCY
    W_CRYFROM=[F:FCY]CRY
  Else
    Read [FCY]FCY0=[F:SIV]STOFCY                   : # pays depart
    If fstat : Raz [F:FCY] : Endif
    W_CRYFROM=[F:FCY]CRY
  Endif
Else
  #--- Cas des fact/avoirs sans mvt de stock, où le STOFCY n'est pas renseigné
  If [F:FCY]FCY<>"" and [F:FCY]FCY=[F:SIV]SALFCY
    W_CRYFROM=[F:FCY]CRY
  Else
    Read [FCY]FCY0=[F:SIV]SALFCY
    If fstat : Raz [F:FCY] : Endif
    W_CRYFROM=[F:FCY]CRY
  Endif
Endif

If [F:SIV]BPDCRY<>""                               : # pays arrivee
  W_CRYTO=[F:SIV]BPDCRY
Else
  If [F:BPA]BPANUM<>"" and [F:BPA]BPATYP=1 and [F:BPA]BPANUM=[F:SIV]BPCORD and [F:BPA]BPAADD=[F:SIV]BPAADD
    W_CRYTO=[F:BPA]CRY
  Else
    Read [BPA]BPA0=1;[F:SIV]BPCORD;[F:SIV]BPAADD
    If fstat : Raz [F:BPA] : Endif
    W_CRYTO=[F:BPA]CRY
  Endif
Endif

W_DATE=[F:SIV]INVDAT                               : # date mouvement
W_FFWNUM=[F:SIV]FFWNUM : W_FFWADD=[F:SIV]FFWADD    : # donnees transitaire

Gosub CTL_EEC_CRY
If WOK=0 : Return : Endif

Return
#----------------------------------------------------------------------
# Document non retenu si :
#- Absence pays depart / absence pays arrivee
#- Pays depart = pays arrivee
#- Pays depart/arrivee dans CCE mais date document < date entree CEE
#- Pays depart ou arrivee (suivant sens) hors CEE et pas de transitaire
#        -    pas de transitaire
#        - ou pays transitaire hors CEE
#        - ou pays transtaire CEE = pays depart/arrivee
#----------------------------------------------------------------------
$CTL_EEC_CRY
Raz W_EECCRYFROM, W_EECCRYTO, W_EECCRYFFW

If W_CRYFROM=""                         WOK=0 : Return   Endif
If W_CRYTO=""                           WOK=0 : Return   Endif
If W_CRYFROM=W_CRYTO                    WOK=0 : Return   Endif
#--- Pays de ... a
JL0=find(W_CRYFROM,T_CRY)
If JL0
  If T_EECCOD(JL0-1)<>""
    W_EECCRYFROM=T_EECCOD(JL0-1)
    If W_DATE<T_EECDAT(JL0-1)           WOK=0 : Return   Endif
  Endif
Endif
JL0=find(W_CRYTO,T_CRY)
If JL0
  If T_EECCOD(JL0-1)<>""
    W_EECCRYTO=T_EECCOD(JL0-1)
    If W_DATE<T_EECDAT(JL0-1)           WOK=0 : Return   Endif
  Endif
Endif
If W_EECCRYFROM<>"" & W_EECCRYTO<>"" & W_EECCRYFROM<>W_EECCRYTO : Goto CTL_CRY_OK : Endif
#--- Recherche flux avec transitaire d un pays CEE --------------------
If W_FFWNUM="" | W_FFWADD=""            WOK=0 : Return   Endif
Read [BPA]BPA0=1;W_FFWNUM; W_FFWADD
If fstat                                WOK=0 : Return   Endif
W_CRYFFW=[F:BPA]CRY
JL0=find(W_CRYFFW,T_CRY)
If JL0
  If T_EECCOD(JL0-1)<>""
    W_EECCRYFFW=T_EECCOD(JL0-1)
    If W_DATE<T_EECDAT(JL0-1)           WOK=0 : Return   Endif
  Endif
Else                                    WOK=0 : Return
Endif
#--- livraison client / retour fournisseur / facture client
If find(WUPDFIL,"SDH","PNH") | ( WUPDFIL="SIH" & [F:SIV]INVTYP=1 )
  If W_EECCRYFROM=""                    WOK=0 : Return   Endif
  If W_EECCRYFROM=W_EECCRYFFW           WOK=0 : Return   Endif
Endif
#--- reception fournisseur / retour client / avoir client
If find(WUPDFIL,"PTH","SRH") | ( WUPDFIL="SIH" & [F:SIV]INVTYP=2 )
  If W_EECCRYTO=""                      WOK=0 : Return   Endif
  If W_EECCRYTO=W_EECCRYFFW             WOK=0 : Return   Endif
Endif
$CTL_CRY_OK
WOKLIG +=1

Return
#####################################################################################
#--CPO 71937 Lors du nouveau dév multi-lég : nombre d'instructions trop important
$INIT
#--- Masque pour generation
If !clalev([M:DEBG]) Local Mask DEBGEN    [DEBG]  Endif
#--- Tables communes
