        GERR= 1: GMESSAGE = mess(565,GML_MSGFAS,1)
        mkstat = 2 : End
     Endif
  Endif  #Fq-71337

  Call DETERM_VEHTAXTYP([M:FASV]VEHTYP, VALEUR, RTAXPWR)
  If RTAXPWR <> ""
     [M:FASV]VEHTAXTYP= RTAXPWR
     Affzo [M:FASV]VEHTAXTYP
     Diszo [M:FASV]VEHTAXTYP
  Endif
#Fq-71337 Endif

End

#------------------------------------------------------------------
Subprog AP_VEHPWR(VALEUR)
Variable Decimal VALEUR
Local Char RTAXPWR

  If [M]TAXPLI <>  GVML_TIEXONT
     If VALEUR <= 0 & [M]VEHTAXRUL = GVML_RIPFISC
        # Puissance fiscale obligatoire si Règle d'imposition = "Puissance fiscale CV"
        GERR= 1: GMESSAGE = mess(565,GML_MSGFAS,1)
        mkstat = 2 : End
     Endif
  Endif  #Fq-71337

  Call DETERM_VEHTAXTYP([M:FASV]VEHTYP, VALEUR, RTAXPWR)
  If RTAXPWR <> ""
     [M:FASV]VEHTAXTYP= RTAXPWR
     Affzo [M:FASV]VEHTAXTYP
     Diszo [M:FASV]VEHTAXTYP
  Endif

  #Fq-71337 Endif

End
##########################################################################
Subprog DETERM_VEHTAXTYP(PGENRE, PPUISSANCE, PVEHTAXTYP)

Value    Char     PGENRE
Value    Integer  PPUISSANCE
Variable Char     PVEHTAXTYP

Local Char LDES
Local Integer ERROR
#If clalev([F:ADI])<>0  : Close File [ADI] : Endif : # FQ82740
If clalev([F:ADI])=0   : Local File ATABDIV  [ADI] : Endif : # Tables diverse
##Fq-60551
Read[ADI]CODE=965;PGENRE
If fstat=0
     #===================
     #Fq-71337 If (PGENRE = "VP") or ([F:ADI]N1= 2)
         Case PPUISSANCE
            When 0              :    PVEHTAXTYP = ""
            When 1,2,3,4        :    PVEHTAXTYP = "P1"
            When 5,6,7          :    PVEHTAXTYP = "P2"
            When 8,9,10,11      :    PVEHTAXTYP = "P3"
            When 12,13,14,15    :    PVEHTAXTYP = "P4"
         Endcase
      #Fq-71337 Endif
      If PPUISSANCE > 15 : PVEHTAXTYP = "P5" : Endif   #*Fq-58084
 Endif   #Fq-60551

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran FASVEH) 16/03/2007 11:27:47 (MDR)
######################################################################################
Subprog AM_VEHTAXTYP(VALEUR)
Variable Char    VALEUR()

End
######################################################################################
## Taxe / puissance fiscale 20/02/2007 (MDR)
######################################################################################
Subprog C_VEHTAXTYP(VALEUR)
Variable Char    VALEUR()

If VALEUR <= "0" & [M]VEHTAXRUL = GVML_RIPFISC
   # Tarif imposition obligatoire si Règle d'imposition = "Puissance fiscale CV"
   GERR= 1: GMESSAGE = mess(562,GML_MSGFAS,1)
   mkstat = 2 : End
Endif

End

######################################################################################
## Taux CO2 20/02/2007 (MDR)
######################################################################################
Subprog AM_VEHCO2(VALEUR)
Variable Decimal VALEUR
Local Char RTAXCO2
#*Fq-58084
If VALEUR <=0
   Raz   [M:FASV]VEHCO2RAT
   Diszo [M:FASV]VEHCO2RAT
   Affzo [M:FASV]VEHCO2RAT
Endif    #*Fq-58084

  If [M]TAXPLI <>  GVML_TIEXONT
     If VALEUR <= 0 & [M]VEHTAXRUL = GVML_RITXCO2
        # Taux émission CO2 obligatoire si  Règle d'imposition = "Taux émission CO2"
        GERR= 1: GMESSAGE = mess(563,GML_MSGFAS,1)
        mkstat = 2 : End
     Endif
  Endif #Fq-71337

  Call DETERM_VEHCO2RAT([M:FASV]VEHTYP, VALEUR, RTAXCO2)
  If RTAXCO2<> ""
     [M:FASV]VEHCO2RAT= RTAXCO2
     Affzo [M:FASV]VEHCO2RAT
     Diszo [M:FASV]VEHCO2RAT
  Endif
  #Fq-71337Endif

End
