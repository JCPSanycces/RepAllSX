######################################################################################
## Tarif imposition
######################################################################################
Subprog AP_TAXPLI(VALEUR)
Variable Integer VALEUR

#*Fq-68482 Si éxonération totale ==> pas de règle d'imposition
#*Fq-6848 If VALEUR=GVML_TIEXONT
  #*Fq-6848 Raz[M]VEHTAXRUL :   Affzo[M]VEHTAXRUL
  #*Fq-6848 Raz [M]VEHTAXTYP  : Diszo[M]VEHTAXTYP  :   Affzo[M]VEHTAXTYP   #FQ-58084
  #*Fq-6848 Raz [M]VEHCO2RAT  : Diszo[M]VEHCO2RAT  :   Affzo[M]VEHCO2RAT   #FQ-58084
#*Fq-6848 Else
   Actzo  [M]VEHTAXRUL
#*Fq-6848 Endif

End
#------------------------------------------------------------------
Subprog AM_TAXPLI(VALEUR)
Variable Integer VALEUR

# Si éxonération totale ==> pas de règle d'imposition
#*Fq-6848 If VALEUR=GVML_TIEXONT
  #*Fq-6848 Raz [M]VEHTAXRUL :   Affzo[M]VEHTAXRUL
  #*Fq-6848 Raz [M]VEHTAXTYP  : Diszo[M]VEHTAXTYP  :   Affzo[M]VEHTAXTYP   #FQ-58084
  #*Fq-6848 Raz [M]VEHCO2RAT  : Diszo[M]VEHCO2RAT  :   Affzo[M]VEHCO2RAT   #FQ-58084
#*Fq-6848 Else
   #*Fq-6848 Actzo  [M]VEHTAXRUL
#*Fq-6848 Endif

End

######################################################################################
## Règle d'imposition  19/02/2007(MDR)
######################################################################################
Subprog AS_VEHTAXRUL(VALEUR)
Variable Integer VALEUR

If  [M]TAXPLI = GVML_TIEXONT
   #*Fq-6848GMENLOC(GVML_RIPFISC) = 1
   #*Fq-6848GMENLOC(GVML_RITXCO2) = 1
Endif

End
#------------------------------------------------------------------
Subprog AM_VEHTAXRUL(VALEUR)
Variable Integer VALEUR

If VALEUR = GVML_RIPFISC & [M]VEHTAXTYP <= "0"
   Actzo [M]VEHTAXTYP
Endif

If VALEUR = GVML_RITXCO2 & [M:FASV]VEHCO2 <= 0
   Actzo [M]VEHCO2
Endif

If VALEUR = GVML_RITXCO2 & [M:FASV]VEHCO2RAT <= "0"
   Actzo [M]VEHCO2RAT
Endif

End
######################################################################################
## Genre du véhicule
######################################################################################
Subprog AM_VEHTYP(VALEUR)
Variable Char    VALEUR()

Global Integer GMAJCOE : GMAJCOE = G_NON
Global Decimal GVALCOE : GVALCOE = 0
# FQ 46680 : Nouvelles règles TVA
#*Fq-55504If ( (VALEUR = "TCP" or VALEUR = "VP") and func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY)= "FR" and
#*Fq-55504&        [M:FAS1]ADMCOE <> 0. ) Then
#*Fq-55504    # Pour un véhicule, le coefficient d'admission doit être égal à 0.
#*Fq-55504    GERR= 1: GMESSAGE = mess(644,GML_MSGFAS,1)
#*Fq-55504    mkstat = 2 : End
#*Fq-55504  Endif

#Fq-60551 : coefficient d'admission récupéré depuis la table des genres véhicules
#Fq-76430 : Modification des coeff de TVA et modification de la base d'amortissement
#           uniquement société française et si bien en création ou bien de l'exercice.
If  (func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA")
   Local Date    RDATE(1..5)
   Local Integer LRET
   Local Integer OK
   Call GET_CNX_DAT([M:FAS0]CPY, 1, RDATE, LRET) From GLOBIENS
   If GREP="C" or [M:FAS5]VATREGDAT >=  RDATE(1)
If clalev([F:ADI])=0  : Local File ATABDIV  [ADI] : Endif : # Tables diverse
Read[ADI]CODE=965;VALEUR
If fstat=0
            # Test coeff. différent pour éviter maj d'une base amort qui aurait été forcée (cas de FRAIKIN)
            If [F:ADI]N2 <> [M:FAS1]ADMCOE
               # Attention, le coeff. d'admission et donc le montant TVA récupérée et la Valeur Bilan vont être modifiés. Confirmez-vous ?
               Call OUINON(mess(842,GML_MSGFAS,1), OK) From GESECRAN
               If ( OK = 1) : mkstat = 2 : End : Endif
               GMAJCOE = G_OUI  : GVALCOE  =   [F:ADI]N2
Endif
         Endif     #Fq-60551
   Endif
Endif #Fq-76430

End
######################################################################################
## Puissance (CV) 16/03/2007 (MDR)
######################################################################################
Subprog AM_VEHPWR(VALEUR)
Variable Decimal VALEUR
Local Char RTAXPWR

#*Fq-58084
If VALEUR <=0
   Raz [M:FASV]VEHTAXTYP
   Diszo [M:FASV]VEHTAXTYP
   Affzo [M:FASV]VEHTAXTYP
Endif   #*Fq-58084

If [M]TAXPLI <>  GVML_TIEXONT
   If VALEUR <= 0 & [M]VEHTAXRUL = GVML_RIPFISC
      # Puissance fiscale obligatoire si Règle d'imposition = "Puissance fiscale CV"
      GERR= 1: GMESSAGE = mess(565,GML_MSGFAS,1)
      mkstat = 2 : End
   Endif
Endif  #Fq-71337

 Call DETERM_VEHTAXTYP([M:FASV]VEHTYP, VALEUR, RTAXPWR)
 If RTAXPWR <> ""
    [M:FASV]VEHTAXTYP= RTAXPWR
    Affzo [M:FASV]VEHTAXTYP
    Diszo [M:FASV]VEHTAXTYP
 Endif
 #Fq-71337 Endif

End
######################################################################################
## Puissance (CV) 22/02/2007 (MDR)
######################################################################################
