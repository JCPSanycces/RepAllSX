######################################################################################
## Tarif émission CO2  20/02/2007 (MDR)
######################################################################################
Subprog DETERM_VEHCO2RAT(PGENRE, PCO2, PVEHCO2RAT)
Value    Char     PGENRE
Value    Integer  PCO2
Variable Char     PVEHCO2RAT

Local Integer ERROR
   #If clalev([F:ADI])<>0  : Close File [ADI] : Endif : # FQ82740
   If clalev([F:ADI])=0  : Local File ATABDIV  [ADI] : Endif : # Tables diverse
   #Fq-#Fq-60551
   Read[ADI]CODE=965;PGENRE
   If fstat=0
     #===================
    #Fq-71337 If (PGENRE = "VP") or ([F:ADI]N1= 2)
        If          PCO2 > 0    & PCO2 <= 100         :    PVEHCO2RAT= "C1"
           Elsif    PCO2 > 100  & PCO2 <= 120         :    PVEHCO2RAT= "C2"
           Elsif    PCO2 > 120  & PCO2 <= 140         :    PVEHCO2RAT= "C3"
           Elsif    PCO2 > 140  & PCO2 <= 160         :    PVEHCO2RAT= "C4"
           Elsif    PCO2 > 160  & PCO2 <= 200         :    PVEHCO2RAT= "C5"
           Elsif    PCO2 > 200  & PCO2 <= 250         :    PVEHCO2RAT= "C6"
           Elsif    PCO2 > 250                        :    PVEHCO2RAT= "C7"
        Endif
     #Fq-71337 Endif
  Endif   #Fq-60551

End
#------------------------------------------------------------------
Subprog C_VEHCO2RAT(VALEUR)
Variable Char VALEUR

If VALEUR <= "0" & [M]VEHTAXRUL = GVML_RITXCO2
   GERR= 1: GMESSAGE = mess(564,GML_MSGFAS,1)
   mkstat = 2 : End
Endif
End

######################################################################################
## Début de location
#####################################################################################
Subprog AM_RNTSTRDAT(VALEUR)
Variable Date    VALEUR

Local Integer NB_JOUR, NB_MOIS, NB_WEEK
Local Decimal NB_YEAR

  If ( ( VALEUR =  [0/0/0]  and [M:FASV]RNTENDDAT <> [0/0/0] ) or
&      ( VALEUR <> [0/0/0]  and [M:FASV]RNTENDDAT <> [0/0/0] and [M:FASV]RNTENDDAT < VALEUR  ) ) Then
      GERR= 1: GMESSAGE = mess(141,GML_MSGFASPR,1)
      mkstat = 2 : End
  Endif

  If (VALEUR <> [0/0/0] and [M:FASV]RNTENDDAT <> [0/0/0] ) Then
    Call CALCUL_NB_D_M_W_Y ( VALEUR, [M:FASV]RNTENDDAT,
&                            NB_JOUR, NB_MOIS, NB_WEEK, NB_YEAR    ) From GLOBIENS
    [M:FASV]RNTMONDUR = NB_MOIS
    [M:FASV]RNTDAYDUR = NB_JOUR
    Actzo [M:FASV]RNTMONDUR, RNTDAYDUR
  Else
    [M:FASV]RNTMONDUR = 0
    [M:FASV]RNTDAYDUR = 0
    Diszo [M:FASV]RNTMONDUR, RNTDAYDUR
  Endif
  Affzo [M:FASV]RNTMONDUR, RNTDAYDUR

End
######################################################################################
## Fin de location
#####################################################################################
Subprog AM_RNTENDDAT(VALEUR)
Variable Date    VALEUR

Local Integer NB_JOUR, NB_MOIS, NB_WEEK
Local Decimal NB_YEAR

  If ( VALEUR <>  [0/0/0] and
&      ( [M:FASV]RNTSTRDAT = [0/0/0]  or
&        ( [M:FASV]RNTSTRDAT <> [0/0/0]  and [M:FASV]RNTSTRDAT >  VALEUR )
&      )
&    ) Then
      GERR= 1: GMESSAGE = mess(141,GML_MSGFASPR,1)
      mkstat = 2 : End
  Endif

  If (VALEUR <> [0/0/0] and RNTSTRDAT <> [0/0/0] ) Then
    Call CALCUL_NB_D_M_W_Y ( [M:FASV]RNTSTRDAT, VALEUR,
&                            NB_JOUR, NB_MOIS, NB_WEEK, NB_YEAR    ) From GLOBIENS
    [M:FASV]RNTMONDUR = NB_MOIS
    [M:FASV]RNTDAYDUR = NB_JOUR
    Actzo [M:FASV]RNTMONDUR, RNTDAYDUR
  Else
    [M:FASV]RNTMONDUR = 0
    [M:FASV]RNTDAYDUR = 0
    Diszo [M:FASV]RNTMONDUR, RNTDAYDUR
  Endif
  Affzo [M:FASV]RNTMONDUR, RNTDAYDUR

End
######################################################################################
##Fq-60551 Etiquette ajoutée par le superviseur (écran FASVEH) 08/12/2009 11:19:13 (MDJ)
######################################################################################
Subprog AS_RNTSTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK

   If [M:FAS1]OWNTYP = GVML_TDLOCAT
      If VALEUR = [0/0/0]
         Call AVERTIR(mess(797,GML_MSGFAS,1), OK) From GESECRAN  #FQ-71562
      Endif
   Endif
End


