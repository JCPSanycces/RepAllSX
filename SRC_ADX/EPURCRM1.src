        If dim([F:OMN1]CREHISUSR)>0 : [F:OMN1]CREHISUSR = [V]GUSER : Endif
        Write [F:OMN1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$MEDIA" - [F:OMN]OMNNUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMN]OMN1 Where [F:OMN]CMGNUM = [F:F1]NUM
      Call ECR_TRACE(mess(810,182,1) - ":" - [F:OMN]OMNNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
    Next
  Endif
  If ![L]SIMUL Then
    Delete [OMN] Where [F:OMN]CMGNUM = [F:F1]NUM
    If fstat Then
      Call ECR_TRACE("$MEDIA" - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
Return

#################################################################################
$FERME_CMG
  Gosub FERME_CLL From EPURCRM
  If clalev([F:OMM])  : Close Local File [OMM]  : Endif
  If clalev([F:OMM1]) : Close Local File [OMM1] : Endif
  If clalev([F:OMP])  : Close Local File [OMP]  : Endif
  If clalev([F:OMP1]) : Close Local File [OMP1] : Endif
