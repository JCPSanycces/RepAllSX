#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
#    Epuration des campagnes marketing                                          #
# ------------------------------------------------------------------------------#
#    CMG : Actions liées à l'épuration des campagnes marketing                  #
#################################################################################
#################################################################################
$OUVRE_CMG
  Gosub OUVRE_CLL From EPURCRM
  If HISTO Then
    If OKEPU = 0 Then
      If clalev([F:OMM]) = 0 : Local File =[L]APPLI +".MAILING"      [OMM] : Endif
      If clalev([F:OMP]) = 0 : Local File =[L]APPLI +".PHONING"      [OMP] : Endif
      If clalev([F:OMT]) = 0 : Local File =[L]APPLI +".TRADESHOW"    [OMT] : Endif
      If clalev([F:OMN]) = 0 : Local File =[L]APPLI +".MEDIA"        [OMN] : Endif
      If clalev([F:CLL]) = 0 : Local File =[L]APPLI +".PHONECALL"    [CLL] : Endif
      If clalev([F:HIM]) = 0 : Local File =[L]APPLI +".HISTOOMM"     [HIM] : Endif
      If clalev([F:MRE]) = 0 : Local File =[L]APPLI +".OMMRESULT"    [MRE] : Endif
      If clalev([F:SEC]) = 0 : Local File =[L]APPLI +".SELCMG"       [SEC] : Endif
      If clalev([F:SCL]) = 0 : Local File =[L]APPLI +".SELCMGLIS"    [SCL] : Endif
      If clalev([F:MOG]) = 0 : Local File =[L]APPLI +".MKGOPG"       [MOG] : Endif
      If clalev([F:HD5]) = 0 : Local File =[L]APPLI + ".HD5CLOB"     [HD5] : Endif
      TABLE = "MAILING"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:OMM1])= 0 : Local File =[L]HISAPL + ".MAILING"    [OMM1] : Endif
      TABLE = "PHONING"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:OMP1])= 0 : Local File =[L]HISAPL + ".PHONING"    [OMP1] : Endif
      TABLE = "TRADESHOW"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:OMT1])= 0 : Local File =[L]HISAPL + ".TRADESHOW"  [OMT1] : Endif
      TABLE = "MEDIA"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:OMN1])= 0 : Local File =[L]HISAPL + ".MEDIA"      [OMN1] : Endif
      TABLE = "PHONECALL"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:CLL1])= 0 : Local File =[L]HISAPL + ".PHONECALL"  [CLL1] : Endif
      TABLE = "HISTOOMM"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:HIM1])= 0 : Local File =[L]HISAPL + ".HISTOOMM"   [HIM1] : Endif
      TABLE = "OMMRESULT"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:MRE1])= 0 : Local File =[L]HISAPL + ".OMMRESULT"  [MRE1] : Endif
      TABLE = "SELCMG"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:SEC1])= 0 : Local File =[L]HISAPL + ".SELCMG"     [SEC1] : Endif
      TABLE = "SELCMGLIS"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:SCL1])= 0 : Local File =[L]HISAPL + ".SELCMGLIS"  [SCL1] : Endif
      TABLE = "MKGOPG"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:MOG1])= 0 : Local File =[L]HISAPL + ".MKGOPG"     [MOG1] : Endif
      TABLE = "HD5CLOB"
      Gosub CRETAB_HISTO From EPURCRM
      If clalev([F:HD51])= 0 : Local File =[L]HISAPL + ".HD5CLOB"    [HD51] : Endif
    Else
      If clalev([F:OMM]) = 0 : Local File =[L]HISAPL +".MAILING"     [OMM]  : Endif
      If clalev([F:OMP]) = 0 : Local File =[L]HISAPL +".PHONING"     [OMP]  : Endif
      If clalev([F:OMT]) = 0 : Local File =[L]HISAPL +".TRADESHOW"   [OMT]  : Endif
      If clalev([F:OMN]) = 0 : Local File =[L]HISAPL +".MEDIA"       [OMN]  : Endif
      If clalev([F:CLL]) = 0 : Local File =[L]HISAPL +".PHONECALL"   [CLL]  : Endif
      If clalev([F:HIM]) = 0 : Local File =[L]HISAPL +".HISTOOMM"    [HIM]  : Endif
      If clalev([F:MRE]) = 0 : Local File =[L]HISAPL +".OMMRESULT"   [MRE]  : Endif
      If clalev([F:SEC]) = 0 : Local File =[L]HISAPL +".SELCMG"      [SEC]  : Endif
      If clalev([F:SCL]) = 0 : Local File =[L]HISAPL +".SELCMGLIS"   [SCL]  : Endif
      If clalev([F:MOG]) = 0 : Local File =[L]HISAPL +".MKGOPG"      [MOG]  : Endif
      If clalev([F:HD5]) = 0 : Local File =[L]HISAPL +".HD5CLOB"     [HD5]  : Endif
    Endif
  Else
    If clalev([F:OMM]) = 0 : Local File =[L]APPLI +".MAILING"        [OMM] : Endif
    If clalev([F:OMP]) = 0 : Local File =[L]APPLI +".PHONING"        [OMP] : Endif
    If clalev([F:OMT]) = 0 : Local File =[L]APPLI +".TRADESHOW"      [OMT] : Endif
    If clalev([F:OMN]) = 0 : Local File =[L]APPLI +".MEDIA"          [OMN] : Endif
    If clalev([F:CLL]) = 0 : Local File =[L]APPLI +".PHONECALL"      [CLL] : Endif
    If clalev([F:HIM]) = 0 : Local File =[L]APPLI +".HISTOOMM"       [HIM] : Endif
    If clalev([F:MRE]) = 0 : Local File =[L]APPLI +".OMMRESULT"      [MRE] : Endif
    If clalev([F:SEC]) = 0 : Local File =[L]APPLI +".SELCMG"         [SEC] : Endif
    If clalev([F:SCL]) = 0 : Local File =[L]APPLI +".SELCMGLIS"      [SCL] : Endif
    If clalev([F:MOG]) = 0 : Local File =[L]APPLI +".MKGOPG"         [MOG] : Endif
    If clalev([F:HD5]) = 0 : Local File =[L]APPLI +".HD5CLOB"        [HD5] : Endif
  Endif
Return

##########################################################################################################
$FILTRE_CMG
Return

##########################################################################################################
$CONTROL_CMG
Return

##########################################################################################################
$HIS_EPU_CMG
Local Char SF1CLLNUM(type([F:CLL]CLLNUM)-10)
Local Char SF1MKTNUM(type([F:CLL]CLLCMGNUM)-10)
Local Char SF1TYPFULOBJ(GLONCLT)

  #CHECK FILE_DECLARE LEAD [F1]
  # -------------------------------------
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(1,13,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
  Endif
  # -------------------------------------
  Gosub CONTROL_CMG
  If OKHIS = 0 and OKEPU = 0 Then
    Return
  Endif
  # -------------------------------------
  # Appels sur campagne marketing
  If [L]OKHIS and [L]OKEPU = 0 Then
    Filter [CLL] Where [F:CLL]TYPFULOBJ = "CMG" and [F:CLL]NUMFULOBJ = [F:F1]NUM
    For [CLL]
      SF1CLLNUM = [F:CLL]CLLNUM
      SF1MKTNUM = [F:CLL]CLLCMGNUM
      SF1TYPFULOBJ = [F:CLL]TYPFULOBJ
      # ----------------------------
      Gosub HIS_EPU_CLL_GENERIQUE From EPURCRM
      If IERRINF = 1 Then
        Break
      Endif
      # ----------------------------
      If ![L]SIMUL Then
        Raz [F:CLL1]
        [F:CLL1] = [F:CLL]
        If dim([F:CLL1]CREHISDAT)>0 : [F:CLL1]CREHISDAT = date$    : Endif
        If dim([F:CLL1]CREHISUSR)>0 : [F:CLL1]CREHISUSR = [V]GUSER : Endif
        Write [F:CLL1]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$PHONECALL" - SF1CLLNUM - [F:F1]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    Filter [CLL]
    If IERRINF = 1 Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - SF1CLLNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [CLL] Where [F:CLL]TYPFULOBJ = "CMG" and [F:CLL]NUMFULOBJ = [F:F1]NUM
    If fstat Then
      Call ECR_TRACE("$PHONECALL" - [F:F1]NUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  # Clob Campagne marketing
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(901,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    Filter [HD5] Where [F:HD5]NUM = [F:F1]NUM and [F:HD5]TYP = "CMG"
    For [HD5]
      If ![L]SIMUL Then
        Raz [F:HD51]
        [F:HD51] = [F:HD5]
        If dim([F:HD51]CREHISDAT)>0 : [F:HD51]CREHISDAT = date$    : Endif
        If dim([F:HD51]CREHISUSR)>0 : [F:HD51]CREHISUSR = [V]GUSER : Endif
        Write [F:HD51]
        If fstat Then
          IERRINF = 1
          Call ECR_TRACE("$HD5CLOB" - [F:F1]NUM - [F:HD51]NUM - mess(13,100,1), 1) From GESECRAN
          Break
        Endif
      Endif
    Next
    Filter [HD5]
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(902,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    Delete [HD5] Where [F:HD5]NUM = [F:F1]NUM and [F:HD5]TYP = "CMG"
    If fstat Then
      Call ECR_TRACE("$HD5CLOB" - [F:F1]NUM - mess(10,100,1), 1) From GESECRAN
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Historiques mailings
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(811,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [HIM] Where [F:HIM]OMMNUM = [F:OMM]OMMNUM
      For [HIM]
        If ![L]SIMUL Then
          Raz [F:HIM1]
          [F:HIM1] = [F:HIM]
          If dim([F:HIM1]CREHISDAT)>0 : [F:HIM1]CREHISDAT = date$    : Endif
          If dim([F:HIM1]CREHISUSR)>0 : [F:HIM1]CREHISUSR = [V]GUSER : Endif
          Write [F:HIM1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$HISTOOMM" - [F:HIM]HIMNUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [HIM]
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [HIM] Where [F:HIM]OMMNUM = [F:OMM]OMMNUM
      For [HIM]
        Call ECR_TRACE(mess(812,182,1) - ":" - [F:HIM]HIMNUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
      Filter [HIM]
    Next
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Delete [HIM] Where [F:HIM]OMMNUM = [F:OMM]OMMNUM
      If fstat Then
        Call ECR_TRACE("$HISTOOMM" - mess(10,100,1), 1) From GESECRAN
        IERRINF = 1
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  # Données de fusion
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(813,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [MRE] Where [F:MRE]OPGNUM = [F:OMM]OMMNUM
      For [MRE]
        If ![L]SIMUL Then
          Raz [F:MRE1]
          [F:MRE1] = [F:MRE]
          If dim([F:MRE1]CREHISDAT)>0 : [F:MRE1]CREHISDAT = date$    : Endif
          If dim([F:MRE1]CREHISUSR)>0 : [F:MRE1]CREHISUSR = [V]GUSER : Endif
          Write [F:MRE1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$OMMRESULT" - [F:MRE]MRENUM - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [MRE]
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [MRE] Where [F:MRE]OPGNUM = [F:OMM]OMMNUM
      For [MRE]
        Call ECR_TRACE(mess(814,182,1) - ":" - [F:MRE]MRENUM - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
      Filter [MRE]
    Next
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Delete [MRE] Where [F:MRE]OPGNUM = [F:OMM]OMMNUM
      If fstat Then
        Call ECR_TRACE("$OMMRESULT" - mess(10,100,1), 1) From GESECRAN
        IERRINF = 1
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  # Echantillon
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(799,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP = "CCN"
      For [SCL]
        If ![L]SIMUL Then
          Raz [F:SCL1]
          [F:SCL1] = [F:SCL]
          If dim([F:SCL1]CREHISDAT)>0 : [F:SCL1]CREHISDAT = date$    : Endif
          If dim([F:SCL1]CREHISUSR)>0 : [F:SCL1]CREHISUSR = [V]GUSER : Endif
          Write [F:SCL1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$SELCMGLIS" - num$([F:SCL]CLSNUM) - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SCL]
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP = "CCN"
      For [SCL]
        Call ECR_TRACE(mess(800,182,1) - ":" - num$([F:SCL]CLSNUM) - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
      Filter [SCL]
    Next
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Delete [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP = "CCN"
      If fstat Then
        Call ECR_TRACE("$SELCMGLIS" - mess(10,100,1), 1) From GESECRAN
        IERRINF = 1
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  #
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(799,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP <> "CCN"
      For [SCL]
        If ![L]SIMUL Then
          Raz [F:SCL1]
          [F:SCL1] = [F:SCL]
          If dim([F:SCL1]CREHISDAT)>0 : [F:SCL1]CREHISDAT = date$    : Endif
          If dim([F:SCL1]CREHISUSR)>0 : [F:SCL1]CREHISUSR = [V]GUSER : Endif
          Write [F:SCL1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$SELCMGLIS" - num$([F:SCL]CLSNUM) - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      Filter [SCL]
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Filter [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP <> "CCN"
      For [SCL]
        Call ECR_TRACE(mess(800,182,1) - ":" - num$([F:SCL]CLSNUM) - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
      Filter [SCL]
    Next
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Delete [SCL] Where [F:SCL]OPGNUM = [F:OMM]OMMNUM and [F:SCL]RECTYP <> "CCN"
      If fstat Then
        Call ECR_TRACE("$SELCMGLIS" - mess(10,100,1), 1) From GESECRAN
        IERRINF = 1
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Sélections marketing
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(815,182,1) - ":" - [F:F1]NUM - mess(748,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      For [SEC] Where [F:SEC]OPGNUM = [F:OMM]OMMNUM
        If ![L]SIMUL Then
          Raz [F:SEC1]
          [F:SEC1] = [F:SEC]
          If dim([F:SEC1]CREHISDAT)>0 : [F:SEC1]CREHISDAT = date$    : Endif
          If dim([F:SEC1]CREHISUSR)>0 : [F:SEC1]CREHISUSR = [V]GUSER : Endif
          Write [F:SEC1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$SELCMG" - [F:SEC]SELTBL - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Endif
      Next
      If IERRINF Then
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      For [SEC] Where [F:SEC]OPGNUM = [F:OMM]OMMNUM
        Call ECR_TRACE(mess(816,182,1) - ":" - [F:SEC]SELTBL - mess(748,182,1) - ":" - [L]APPLI, 0) From GESECRAN
      Next
    Next
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
      Delete [SEC] Where [F:SEC]OPGNUM = [F:OMM]OMMNUM
      If fstat Then
        Call ECR_TRACE("$SELCMG" - mess(10,100,1), 1) From GESECRAN
        IERRINF = 1
        Break
      Endif
    Next
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # -------------------------------------
  #Relations ciblages/opérations marketing
  If [L]OKHIS and [L]OKEPU = 0 Then
    If [L]TRACEDET Then
      Call ECR_TRACE(mess(817,182,1) - ":" - [L]HISAPL, 0) From GESECRAN
    Endif
    If ![L]SIMUL Then
      For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
        For [MOG]MOG2 Where [F:MOG]OPGNUM = [F:OMM]OMMNUM
          Raz [F:MOG1]
          [F:MOG1] = [F:MOG]
          If dim([F:MOG1]CREHISDAT)>0 : [F:MOG1]CREHISDAT = date$    : Endif
          If dim([F:MOG1]CREHISUSR)>0 : [F:MOG1]CREHISUSR = [V]GUSER : Endif
          Write [F:MOG1]
          If fstat Then
            IERRINF = 1
            Call ECR_TRACE("$MKGOPG" - mess(13,100,1), 1) From GESECRAN
            Break
          Endif
        Next
        If IERRINF Then
          Break
        Endif
      Next
    Endif
    If IERRINF Then
      OKHIS = 0
      OKEPU = 0
      Return
    Endif
  Endif
  # Suppression dans le dossier mère
  If [L]TRACEDET Then
    Call ECR_TRACE(mess(818,182,1) - ":" - [L]APPLI, 0) From GESECRAN
  Endif
  If ![L]SIMUL Then
    For [OMM]OMM1 Where [F:OMM]CMGNUM = [F:F1]NUM
