  If clalev([F:HIM])  : Close Local File [HIM]  : Endif
  If clalev([F:HIM1]) : Close Local File [HIM1] : Endif
  If clalev([F:MRE])  : Close Local File [MRE]  : Endif
  If clalev([F:MRE1]) : Close Local File [MRE1] : Endif
  If clalev([F:SEC])  : Close Local File [SEC]  : Endif
