#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR12 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:13:24"
A_USER  = "DOC"
A_STAMP = "20181109231324"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "HRLSTNR"
  If [M]HRLSTNR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR12 [CTR12]
Gosub HORODAT
Local Inpbox "CTR12" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR12] As [SIM_]
Grizo [CTR12]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR12]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=25
Return

$ON_CODLST
Onevent CONTROL Call C_CODLST(zc) From W1CTR12
Onevent BEFORE_INPUT Call AS_CODLST(zc) From W1CTR12
Onevent AFTER_CHANGE Gosub AMM_CODLST From W1CTR12
Return

Subprog AS_CODLST(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CODLST(zc) From W1CTR12
Onkey 144 Titled GBOUTP Call P_CODLST(zc) From W1CTR12
Onkey 146 Titled GBOUTA Call SA_CODLST(zc) From W1CTR12
Gosub _AFF
End

Subprog C_CODLST(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTHRLST
 Call CONTHRLST(VALEUR) From SUBHRLST
 If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action STD
   Call C_CODLST(VALEUR) From SUBCTR2
   If mkstat : GERR = 1 : GZONE = "CODLST" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CODLST
Call AM_CODLST(zc)
If !mkstat & GOBJET
 zoncou = "CODLST" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODLST(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODLST)")>indice
 [M]CODLST(indice) = VALEUR
 Affzo ZCODLST(indice)
Endif
Gosub _AFF
End

Subprog S_CODLST(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRLST
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRLST"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRLST","SUBHRLST","SPEHRLST") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CODLST(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRLST"
PARMSK(2) = num$(GCURLEG)
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODLST(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = num$(GCURLEG)
Call VISU("HRLST",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODLST
Onevent BEFORE_AREA Gosub AV_ZCODLST From W1CTR12
Return

$AV_ZCODLST
Call LECTEXTRA(zc,"HRLVESUBHEA","DES",num$(GCURLEG),num$([M]CODLST(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_STRDATLVE
Onevent CONTROL Call C_STRDATLVE(zc) From W1CTR12
Onevent BEFORE_INPUT Call AS_STRDATLVE(zc) From W1CTR12
Onevent BEFORE_AREA Gosub AV_STRDATLVE From W1CTR12
Return

$AV_STRDATLVE
Chgfmt [M]STRDATLVE(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog AS_STRDATLVE(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_STRDATLVE(zc) From W1CTR12
Gosub _AFF
End

Subprog C_STRDATLVE(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "STRDATLVE" : GZNUM = 1805 : Endif
If !mkstat
 ## Action STD
 Call C_STRDATLVE(VALEUR) From SUBCTR2
 If mkstat : GERR = 1 : GZONE = "STRDATLVE" : GZNUM = 1805 : Endif
Endif
Gosub _AFF
End

Subprog S_STRDATLVE(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action STD
 Call S_STRDATLVE(VALEUR) From SUBCTR2
Endif
Gosub _AFF
End

$ON_ENDDATLVE
Onevent CONTROL Call C_ENDDATLVE(zc) From W1CTR12
Onevent BEFORE_INPUT Call AS_ENDDATLVE(zc) From W1CTR12
Onevent BEFORE_AREA Gosub AV_ENDDATLVE From W1CTR12
Return

$AV_ENDDATLVE
Chgfmt [M]ENDDATLVE(indice) With "D:"+GFMDAT
Gosub _AFF
Return

Subprog AS_ENDDATLVE(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ENDDATLVE(zc) From W1CTR12
Gosub _AFF
End

Subprog C_ENDDATLVE(VALEUR)
Variable Date    VALEUR
## Action %OBLIG
If VALEUR=[0/0/0]
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
If !mkstat
 ## Action DATDEBFIN
 Call DATDEBFIN(VALEUR,[M]STRDATLVE(nolign-1)) From EXEFNC
 If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
 If !mkstat
  ## Action STD
  Call C_ENDDATLVE(VALEUR) From SUBCTR2
  If mkstat : GERR = 1 : GZONE = "ENDDATLVE" : GZNUM = 1806 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_ENDDATLVE(VALEUR)
Variable Date    VALEUR
If !GWEBSERV
 ## Action STD
 Call S_ENDDATLVE(VALEUR) From SUBCTR2
Endif
Gosub _AFF
End

$CHG_STY
Return


