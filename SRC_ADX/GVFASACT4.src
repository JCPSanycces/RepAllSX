 [F:EVT0]AASBUS     = [M:FAS1]AASBUS
 [F:EVT0]DSP        = [M:FAS2]DSP
 If dim([M:FAS2]DIE(0)) > 0
  [F:EVT0]DIE1       = [M:FAS2]DIE(0)
 Endif
 If dim([M:FAS2]CCE(0)) > 0
  [F:EVT0]CCE1       = [M:FAS2]CCE(0)
 Endif
