 [F:EVT0]GALREFBASO = GGALREFBASO
 [F:EVT0]ACTGAL     = GACTGAL
 [F:EVT0]GALREFBASD = GGALREFBASD
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = [M:FAS1]ACCCOD
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
 [F:EVT0]USRFLDA1   = [M]USRFLDA1
 [F:EVT0]USRFLDA2   = [M]USRFLDA2
