#<AdxTL>@(#)3.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Copy data from table ASHW to ASHWCOL, ASHWOPT
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Copy data from table ASHW to ASHWCOL and ASHWOPT") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ASHW [ASW]
 Local File ASHWCOL [ASWC]
 Local File ASHWOPT [ASWO]
 Local File ASHWEXPPRO [ASWR]
 Local File ASHWFLD [ASWF]
 Local File ATYPE [ATY]
Else
 Local File =DOSSIER+".ASHW" [ASW]
 Local File =DOSSIER+".ASHWCOL" [ASWC]
 Local File =DOSSIER+".ASHWOPT" [ASWO]
 Local File =DOSSIER+".ASHWEXPPRO" [ASWR]
 Local File =DOSSIER+".ASHWFLD" [ASWF]
 Local File =DOSSIER+".ATYPE" [ATY]
Endif

Gosub MAJTAB1

#If dim([F:ASW]CODGRP)>0
#  Gosub MAJTAB2
#Endif
#
#
#If dim([F:ASWO]OPTFLGCLA)>0
#Gosub MAJTAB3
#Endif
#
#If dim([F:ASWR]STAINIPRO)>0
#Gosub MAJTAB4
#Endif
#
#If dim([F:ASWR]STAINIPRO)>0 & dim([F:ASWR]STAQRYPRO)>0
#Gosub MAJTAB5
#Endif
#
#If dim([F:ASW]DEFLNKFAC)>0
#Gosub MAJTAB6
#Endif

Gosub MAJTAB7

Close Local File [ASW],[ASWO],[ASWC],[ASWR],[ASWF],[ATY]
End

#----------------------------------------------------------------------------------------#
$MAJTAB1
Trbegin [ASW]
 For [ASW]
    If [F:ASW]TYPMSKREP<>1 & [F:ASW]DEFREP=2
      [F:ASW]DEFREP=1
    Endif
    Rewrite [ASW]
    If fstat
     Call ERREUR("ASHW"-[F:ASW]CODREP,2) From DOSDIC
    Endif
 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB2
Local Integer I

Trbegin [ASW]
 For [ASW]

  #Options
  For I=1 To 20
   If [F:ASW]OPTCOD(I-1)<>""
    Read [ASWO]ASWO0=[F:ASW]CODREP;[F:ASW]OPTCOD(I-1)
    If fstat
      Raz [F:ASWO]
      [F:ASWO]=[F:ASW]

      [F:ASWO]OPTCOD=[F:ASW]OPTCOD(I-1)
      Write [ASWO]
      If fstat
       Call ERREUR("ASHWOPT"-[F:ASW]CODREP-[F:ASWO]OPTCOD,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

  #Collections
  For I=1 To 20
   If [F:ASW]CODGRP(I-1)<>""
    Read [ASWC]ASWC0=[F:ASW]CODREP;[F:ASW]CODGRP(I-1)
    If !fstat
      If [F:ASWC]ALIASCOL="" & dim([F:ASW]ALIASGRP)>0
        If [F:ASW]ALIASGRP(I-1)<>""
          [F:ASWC]ALIASCOL=[F:ASW]ALIASGRP(I-1)
          Rewrite [ASWC]
          If fstat
           Call ERREUR("ASHWCOL"-[F:ASW]CODREP-[F:ASWC]CODCOL,2) From DOSDIC
          Endif
        Endif
      Endif
      If [F:ASWC]ALIASCOL="" & instr(1,[F:ASWC]CODCOL,".")=0
        [F:ASWC]ALIASCOL=[F:ASWC]CODCOL
        Rewrite [ASWC]
        If fstat
         Call ERREUR("ASHWCOL"-[F:ASW]CODREP-[F:ASWC]CODCOL,2) From DOSDIC
        Endif
      Endif
    Elsif fstat
      Raz [F:ASWC]
      [F:ASWC]=[F:ASW]

      [F:ASWC]CODCOL=[F:ASW]CODGRP(I-1)

      If [F:ASWC]ALIASCOL="" & dim([F:ASW]ALIASGRP)>0
        If [F:ASW]ALIASGRP(I-1)<>""
          [F:ASWC]ALIASCOL=[F:ASW]ALIASGRP(I-1)
        Endif
      Endif
      If [F:ASWC]ALIASCOL="" & instr(1,[F:ASWC]CODCOL,".")=0
        [F:ASWC]ALIASCOL=[F:ASWC]CODCOL
      Endif

      [F:ASWC]ACTCOL=[F:ASW]ACTGRP(I-1)
      [F:ASWC]MINCOL=[F:ASW]MINGRP(I-1)
      [F:ASWC]MAXCOL=[F:ASW]MAXGRP(I-1)
      [F:ASWC]PROCOL=[F:ASW]PROGRP(I-1)
      [F:ASWC]INTCOL=[F:ASW]INTGRP(I-1)
      [F:ASWC]FLGINSCOL=[F:ASW]FLGINSGRP(I-1)
      [F:ASWC]FLGSUPCOL=[F:ASW]FLGSUPGRP(I-1)
      [F:ASWC]FLGTRICOL=[F:ASW]FLGTRIGRP(I-1)
      [F:ASWC]FLGAPDCOL=[F:ASW]FLGAPDGRP(I-1)

      Write [ASWC]
      If fstat
       Call ERREUR("ASHWCOL"-[F:ASW]CODREP-[F:ASWC]CODCOL,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB3
Local Integer WCOUNT
Trbegin [ASWO]
 For [ASWO]ASWO0(1) Where OPTFLGCLA=0
  WCOUNT=0
  For [ASWO]ASWO0
    WCOUNT+=1
    If [F:ASWO]OPTCND=""
      [F:ASWO]OPTFLGCLA=2
    Else
      [F:ASWO]OPTFLGCLA=1
    Endif
    [F:ASWO]OPTOBY=1
    [F:ASWO]OPTDEF=1
    Rewrite [ASWO]
    If fstat
     Call ERREUR("ASHWOPT"-[F:ASWO]CODREP-[F:ASWO]OPTCOD,2) From DOSDIC
    Endif
  Next
  If WCOUNT=1
    If [F:ASWO]OPTCND=""
      [F:ASWO]OPTFLGCLA=2
    Else
      [F:ASWO]OPTFLGCLA=1
    Endif
    [F:ASWO]OPTDEF=1
    [F:ASWO]OPTOBY=2
    Rewrite [ASWO]
    If fstat
     Call ERREUR("ASHWOPT"-[F:ASWO]CODREP-[F:ASWO]OPTCOD,2) From DOSDIC
    Endif
  Endif
 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB4
Trbegin [ASWR]
 For [ASWR]ASWR0 Where STAINIPRO=0
  [F:ASWR]STAINIPRO=1
  Rewrite [ASWR]
  If fstat
   Call ERREUR("ASHWEXPPRO"-[F:ASWR]CODREP-[F:ASWR]ALIAS,2) From DOSDIC
  Endif
 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB5
Local Integer BTROUVE : BTROUVE=0

#If dim([F:ASWR]STAQRYPRO)>0
#Filter [ASWR] Where STAQRYPRO<>0
#Read [ASWR]First
#If !fstat
#  BTROUVE=1
#Endif
#Filter [ASWR]
#If BTROUVE=1 : Return : Endif
#Endif

Trbegin [ASWR]
 For [ASWR]ASWR0

  If [F:ASWR]STAINIPRO=2
   If [F:ASWR]STAQRYPRO=0 : [F:ASWR]STAQRYPRO=2 : Endif
   If [F:ASWR]STADETPRO=0 : [F:ASWR]STADETPRO=2 : Endif
   If [F:ASWR]STAEDIPRO=0 : [F:ASWR]STAEDIPRO=2 : Endif
   If [F:ASWR]STALOKPRO=0 : [F:ASWR]STALOKPRO=2 : Endif
   If [F:ASWR]STASUMPRO=0 : [F:ASWR]STASUMPRO=2 : Endif
  Endif
  If [F:ASWR]STAQRYPRO=0 : [F:ASWR]STAQRYPRO=1 : Endif
  If [F:ASWR]STADETPRO=0 : [F:ASWR]STADETPRO=1 : Endif
  If [F:ASWR]STAEDIPRO=0 : [F:ASWR]STAEDIPRO=1 : Endif
  If [F:ASWR]STALOKPRO=0 : [F:ASWR]STALOKPRO=1 : Endif
  If [F:ASWR]STASUMPRO=0 : [F:ASWR]STASUMPRO=1 : Endif

  Rewrite [ASWR]
  If fstat
   Call ERREUR("ASHWEXPPRO"-[F:ASWR]CODREP-[F:ASWR]ALIAS,2) From DOSDIC
  Endif
 Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB6
Local Integer I
Trbegin [ASW]
For [ASW]
  For I=1 To 5
   If [F:ASW]DEFLNKFAC(I-1)=0
    If [F:ASW]LNKMENFAC(I-1)<>""
     [F:ASW]DEFLNKFAC(I-1)=1
    Else
     [F:ASW]DEFLNKFAC(I-1)=2
    Endif
   Endif
  Next
  Rewrite [ASW]
  If fstat
   Call ERREUR("ASHW"-[F:ASW]CODREP,2) From DOSDIC
  Endif
Next
Commit

Return

#----------------------------------------------------------------------------------------#
$MAJTAB7
Trbegin [ASWF]
 For [ASWF]ASWF0
  Read [ATY]CODTYP=[F:ASWF]CODTYP
  If !fstat & find([F:ATY]TYPTYP,8,11,12)
   [F:ASWF]LONG=0
  Elsif !fstat & find([F:ATY]TYPTYP,9,10)
   [F:ASWF]LONG=1
  Endif
  Rewrite [ASWF]
  If fstat
   Call ERREUR("ASHWFLD"-[F:ASWF]CODREP-[F:ASWF]CODFLD,2) From DOSDIC
  Endif
 Next
Commit

Return
