#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGUKI 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:32"
A_USER  = "DOC"
A_STAMP = "20181109230332"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBBAN"
  If [M]NBBAN=0
  Endif
 When "NBCAR"
  If [M]NBCAR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGUKI [CPYUKI]
Gosub HORODAT
Local Inpbox "CPYLEGUKI" From GFONCTION At A_STAMP With A_WINDPREV Mask [CPYUKI] As [SIM_]
Grizo [CPYUKI]5
Grizo [CPYUKI]10
Grizo [CPYUKI]15
Grizo [CPYUKI]25
Grizo [CPYUKI]30
Grizo [CPYUKI]35
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CPYUKI]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=14 : X2(0)=99 : Y1(0)=7 : Y2(0)=11
X1(1)=14 : X2(1)=99 : Y1(1)=12 : Y2(1)=15
X1(2)=14 : X2(2)=99 : Y1(2)=16 : Y2(2)=19
X1(3)=14 : X2(3)=13 : Y1(3)=20 : Y2(3)=19
X1(4)=14 : X2(4)=99 : Y1(4)=20 : Y2(4)=19
X1(5)=14 : X2(5)=99 : Y1(5)=20 : Y2(5)=22
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1CPYLEGUKI
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_TAXDTT
Onevent AFTER_CHANGE Gosub AMM_TAXDTT From W1CPYLEGUKI
Onevent CONTROL Call C_TAXDTT(zc) From W1CPYLEGUKI
Return

Subprog C_TAXDTT(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TAXDTT" : GZNUM = 1001654 : Endif
Gosub _AFF
End

$AMM_TAXDTT
Call AM_TAXDTT(zc)
If !mkstat & GOBJET
 zoncou = "TAXDTT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TAXDTT(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TAXDTT(VALEUR) From TRTCPYLEGUKI
If mkstat : GERR = 1 : GZONE = "TAXDTT" : GZNUM = 1001654 : Endif
Gosub _AFF
End

