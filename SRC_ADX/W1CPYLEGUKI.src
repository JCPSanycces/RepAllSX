$ON_CLMEMPALL
Onevent CONTROL Call C_CLMEMPALL(zc) From W1CPYLEGUKI
Onevent INIT_AREA Call D_CLMEMPALL(zc) From W1CPYLEGUKI
Onevent BEFORE_INPUT Call AS_CLMEMPALL(zc) From W1CPYLEGUKI
Return

Subprog D_CLMEMPALL(VALEUR)
Variable Integer VALEUR
If varinit([M]CLMEMPALL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CLMEMPALL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_CLMEMPALL(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_CLMEMPALL(VALEUR) From TRTCPYLEGUKI
If mkstat : GERR = 1 : GZONE = "CLMEMPALL" : GZNUM = 1001684 : Endif
Gosub _AFF
End

