###################################################################################################
$OPPDATLA
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPDATLA_CONTROL
  Endcase
Return

$OPPDATLA_CONTROL
  #If this.TCHACTION <> "LAUNCH" Then                                                                           # Issue X3-86224 - 2018-05-04 by TEJAC
  If this.TCHACTION <> "LAUNCH" and
&   (this.TCHACTION = AVOID.ACHAR and fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "PJMDEFSTA") <> 2)
& Then  # Issue X3-86224 - 2018-05-04 by TEJAC
    If this.OPPDATLA <> this.snapshot.OPPDATLA Then
      [L]ASTATUS = fmet this.SETERROR("OPPDATLA", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$OPPDATLV
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPDATLV_CONTROL
  Endcase
Return

$OPPDATLV_CONTROL
  If this.TCHACTION <> "DELIVERY" Then
    If this.OPPDATLV <> this.snapshot.OPPDATLV Then
      [L]ASTATUS = fmet this.SETERROR("OPPDATLV", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$OPPDATS
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPDATS_CONTROL
  Endcase
Return

$OPPDATS_CONTROL
  If this.TCHACTION <> "CLOSING" and this.TCHACTION <> "REACTIVATE" Then
    If this.OPPDATS <> this.snapshot.OPPDATS Then
      [L]ASTATUS = fmet this.SETERROR("OPPDATS", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$OPPDATTH
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPDATTH_CONTROL
  Endcase
Return

$OPPDATTH_CONTROL
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "REACTIVATE" Then
    If this.OPPDATTH <> this.snapshot.OPPDATTH Then
      [L]ASTATUS = fmet this.SETERROR("OPPDATTH", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$OPPIMPT
  Case [L]ARULE
    When "INIT"      : Gosub OPPIMPT_INIT
  Endcase
Return

$OPPIMPT_INIT
  this.OPPIMPT = [V]CST_ANO
Return

###################################################################################################
$ORIOPP
  # Issue X3-43754 - 2016-06-28 by EUHAV
  Case [L]ARULE
    When "CONTROL"  : Gosub ORIOPP_CONTROL
  Endcase
Return

$ORIOPP_CONTROL
Local Char SMESSAGE(250)
Local Integer IPIMTYP

  # Issue X3-43754 - 2016-06-28 by EUHAV
  If this.TCHACTION <> "COPY" Then
    If this.ORIOPP <> this.snapshot.ORIOPP Then
      [L]ASTATUS = fmet this.SETERROR("ORIOPP", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
  If this.ORIOPP <> AVOID.ACHAR Then
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.ORIOPP, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
    If SMESSAGE <> AVOID.ACHAR Then
      [L]ASTATUS = fmet this.SETERROR("ORIOPP", SMESSAGE, [V]CST_AERROR)
    Else
      If IPIMTYP <> 2 and IPIMTYP <> 3 Then
        [L]ASTATUS = fmet this.SETERROR("ORIOPP", func AFNC.MES1(mess(450,2260,1), this.ORIOPP), [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

###################################################################################################
# Linked to TAS collection
###################################################################################################
$TAS_TASCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub TAS_TASCOD_CONTROL
  Endcase
Return

$TAS_TASCOD_CONTROL
Local Integer ILINE
Local Integer NI   # Issue X3-52534 - 2017-08-17 by FGR

  ILINE = fmet this.APARENT.TAS_GET_INDEX(this.TASCOD)
  If ILINE > 0 Then          # Issue X3-36812 - 2017-06-26 by FGR : was missing
    If this.APARENT.TAS(ILINE) <> this Then
      # There is another exiting line with the same code : error
      [L]ASTATUS = fmet this.SETERROR("TASCOD", func AFNC.MES1(mess(155,2260,1), this.TASCOD), [V]CST_AERROR)
    Endif
  Endif
  # Issue X3-52534 - 2017-08-17 by FGR : BEGIN
  If this.ASTALIN = [V]CST_ANEW Then
    For NI = 1 To maxtab(this.APARENT.TAS)
      If this.APARENT.TAS(NI) <> null and find(this.APARENT.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.APARENT.TAS(NI).TASPAE <> AVOID.ACHAR Then
          If fmet this.APARENT.TAS_GET_INDEX(this.APARENT.TAS(NI).TASPAE) = 0 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASCOD", func AFNC.MES2(mess(968,2260,1), this.APARENT.TAS(NI).TASCOD, this.APARENT.TAS(NI).TASPAE), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Next NI
  Endif
  # Issue X3-52534 - 2017-08-17 by FGR : END
Return

###################################################################################################
# Issue X3-17821/120740 - 2017-01-05 by FGR : BEGIN
$TAS_TASPAE
  Case [L]ARULE
    When "CONTROL"   : Gosub TAS_TASPAE_CONTROL
  Endcase
Return

$TAS_TASPAE_CONTROL
Local Integer ILINE
Local Integer IRET
Local Integer NI             # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Integer NE             # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Char PROJECT(GLONOPP)  # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Char BUDGET(GLONPBU)   # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Char TASK(GLONTAC)     # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Char RPROJECT(GLONOPP) # Issue X3-26991/X3-43920 - 2017-07-04 by FGR
Local Char RTASK(GLONTAC)    # Issue X3-26991/X3-43920 - 2017-07-04 by FGR

  If this.TASPAE <> AVOID.ACHAR Then
    ISTATUS = fmet this.APARENT.TAS_CHECK_TASPAE_VALID(this.TASPAE)
    [L]ASTATUS = max([L]ASTATUS, ISTATUS)
    # ---------------------------------------
    ILINE = fmet this.APARENT.TAS_GET_INDEX(this.TASPAE)
    If ILINE < 1 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(219,2260,1), this.TASPAE), [V]CST_AERROR))
    Endif
    If ILINE > 0 Then   # Issue X3-44354 - 2017-06-09 by FGR : not necessary to test ILINE=0 here, already tested in $TAS_ACONTROL event
      If this.APARENT.TAS(ILINE).TASTYP <> 1 Then
        [L]ASTATUS = fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(425,2260,1), mess(this.APARENT.TAS(ILINE).TASTYP,2258,1)), [V]CST_AERROR)
      Endif
      If fmet this.APARENT.TAS(ILINE).RITT_EXISTING() = [V]CST_AYES Then
        IRET = fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(481,2260,1), this.TASPAE), [V]CST_AERROR)
        [L]ASTATUS = max([L]ASTATUS, IRET)
      Endif
      If fmet this.APARENT.TAS(ILINE).RTKO_EXISTING() = [V]CST_AYES Then
        IRET = fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(482,2260,1), this.TASPAE), [V]CST_AERROR)
        [L]ASTATUS = max([L]ASTATUS, IRET)
      Endif
      If fmet this.APARENT.TAS(ILINE).SPLD_EXISTING() = [V]CST_AYES Then
        IRET = fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(483,2260,1), this.TASPAE), [V]CST_AERROR)
        [L]ASTATUS = max([L]ASTATUS, IRET)
      Endif
      # Issue X3-26991/X3-43920 - 2017-06-30 by FGR : BEGIN
      If fmet this.APARENT.TAS(ILINE).PTLNK_EXISTING() = [V]CST_AYES Then
        IRET = fmet this.SETERROR("TASPAE", func AFNC.MES1(mess(581,2260,1), this.TASPAE), [V]CST_AERROR)
        [L]ASTATUS = max([L]ASTATUS, IRET)
      Endif
      # Issue X3-26991/X3-43920 - 2017-06-30 by FGR : END
    Endif               # Issue X3-44354 - 2017-06-09 by FGR : not necessary to test ILINE=0 here, already tested in $TAS_ACONTROL event
    # Issue X3-26991/X3-43920 - 2017-07-04 by FGR : BEGIN check if the TASPAE is linked in this project or in another one
    For NI = 1 To maxtab(this.APARENT.TAS)
      If this.APARENT.TAS(NI) <> null and find(this.APARENT.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        For NE = 1 To maxtab(this.APARENT.TAS(NI).PTLNK)
          If this.APARENT.TAS(NI).PTLNK(NE) <> null and find(this.APARENT.TAS(NI).PTLNK(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.APARENT.TAS(NI).PTLNK(NE).PIMOPPTASLNK, PROJECT, BUDGET, TASK)
            If TASK = this.TASPAE Then
              IRET = fmet this.SETERROR("TASPAE", func AFNC.MES2(mess(594,2260,1), this.TASPAE, this.APARENT.TAS(NI).TASCOD), [V]CST_AERROR)
              Break
            Endif
          Endif
        Next NE
      Endif
    Next NI
    If func PJMTSKLNK_CSTD_PROGS.IS_LINKED_SOMEWHERE_ELSE(this.ACTX, this.OPPNUM, this.TASPAE, RPROJECT, RTASK) = [V]CST_AYES Then
      IRET = fmet this.SETERROR("TASPAE", func AFNC.MES3(mess(595,2260,1), this.TASPAE, RTASK, RPROJECT), [V]CST_AERROR)
    Endif
    # Issue X3-26991/X3-43920 - 2017-07-04 by FGR : END
  Endif
Return
# Issue X3-17821/120740 - 2017-01-05 by FGR : END

###################################################################################################
$TAS_PTLNK_PIMOPPTASLNK
  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  Case [L]ARULE
    When "CONTROL"   : Gosub TAS_PTLNK_PIMOPPTASLNK_CONTROL
  Endcase
Return

$TAS_PTLNK_PIMOPPTASLNK_CONTROL
Local Char PROJECT(GLONOPP)
Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
Local Char PROJECTLNK(GLONOPP)
Local Char BUDGETLNK(GLONPBU)
Local Char TASKLNK(GLONTAC)
Local Integer IRET
Local Integer ILINELNK
Local Char SMESSAGE(250)

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  Raz PROJECT
  Raz TASK
  Local File PJMTSKLNK [PTLNK]
  # -------------------------
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.PIMOPPTASLNK, PROJECT, BUDGET, TASK)
  If IRET >= [V]CST_AERROR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", mess(83,123,1) - this.PIMOPPTASLNK, [V]CST_AERROR))
  Else
    If TASK = AVOID.ACHAR Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", mess(83,123,1) - this.PIMOPPTASLNK, [V]CST_AERROR))
    Endif
  Endif
  If PROJECT = this.OPPNUM Then
    # Link is in the current project : controls have to be do in classes
    ILINELNK = fmet this.APARENT.APARENT.TAS_GET_INDEX(TASK)
    If ILINELNK = 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES1(mess(6,2260,1), TASK), [V]CST_AERROR))
      Return
    Endif
  Else
    If func PIMPL_CSTD_PROGS.IS_PIMNUM_EXIST(this.ACTX, this.PIMOPPTASLNK) = [V]CST_ANO Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", mess(83,123,1) - this.PIMOPPTASLNK, [V]CST_AERROR))
      Return
    Endif
  Endif
  # -------------------------
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.PIMOPPTASLNK <> this.snapshot.PIMOPPTASLNK) Then
    # To do only for a new line or a line where PIMOPPTASLNK has been updated
    If PROJECT = this.OPPNUM Then
      # Link is in the current project : controls have to be do in classes
      If this.APARENT.APARENT.TAS(ILINELNK).TASSTATE = 4 Then
        # The task selected is closed : error
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES1(mess(13,2260,1), TASK), [V]CST_AERROR))
      Endif
      #
      If fmet this.APARENT.APARENT.TAS_IS_PARENT(TASK) = [V]CST_AYES Then
        # The task selected is parent : error
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES1(mess(592,2260,1), TASK), [V]CST_AERROR))
      Endif
    Else
      # Link is in another project : controls have to be do in tables
      IRET = func PIMPL_CSTD_PROGS.GET_TASSTATE_VALUE(this.ACTX, this.PIMOPPTASLNK, AVOID.ACHAR, SMESSAGE)
      If SMESSAGE <> AVOID.ACHAR Then
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", SMESSAGE, [V]CST_AERROR))
      Elsif IRET = 4 Then
        # The task selected is closed : error
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES2(mess(592,2260,1), TASK, PROJECT), [V]CST_AERROR))
      Endif
      #
      If func PJMTSK_CSTD_PROGS.IS_PARENT(this.ACTX, PROJECT, TASK) = [V]CST_AYES Then
        # The task selected is parent : error
        [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES2(mess(593,2260,1), TASK, PROJECT), [V]CST_AERROR))
      Endif
    Endif
  Endif
  # -------------------------
  If PROJECT = this.OPPNUM Then
    For NI = 1 To maxtab(this.APARENT.APARENT.TAS(ILINELNK).PTLNK)
      If this.APARENT.APARENT.TAS(ILINELNK).PTLNK(NI) <> null and find(this.APARENT.APARENT.TAS(ILINELNK).PTLNK(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.APARENT.APARENT.TAS(ILINELNK).PTLNK(NI).PIMOPPTASLNK = this.APARENT.KEYCONCAT Then
          IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(this.ACTX, this.APARENT.APARENT.TAS(ILINELNK).PTLNK(NI).PIMOPPTASLNK, PROJECTLNK, BUDGETLNK, TASKLNK)
          [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES3(mess(586,2260,1), this.TASCOD, TASK, TASK), [V]CST_AERROR))
          Break
        Endif
      Endif
    Next NI
  Else
    Filter [PTLNK] Where [F:PTLNK]OPPNUM = PROJECT and [F:PTLNK]PIMOPPTASLNK = this.APARENT.KEYCONCAT
    For [PTLNK]
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PIMOPPTASLNK", func AFNC.MES4(mess(587,2260,1), this.TASCOD, TASK, PROJECT, TASK), [V]CST_AERROR))
      Break
    Next
    Filter [PTLNK]
  Endif
  # -------------------------
Return

###################################################################################################
# Linked to BUD collection
###################################################################################################
$BUD_PBUCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub BUD_PBUCOD_CONTROL
  Endcase
Return

$BUD_PBUCOD_CONTROL
Local Integer ILINE
Local Integer NI   # Issue X3-52534 - 2017-08-17 by FGR

  ILINE = fmet this.APARENT.BUD_GET_INDEX(this.PBUCOD)
  If ILINE > 0 Then
    If this.APARENT.BUD(ILINE) <> this Then
      # There is another exiting line with the same code : error
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES1(mess(154,2260,1), this.PBUCOD), [V]CST_AERROR))
    Endif
  Endif
  # Issue X3-52534 - 2017-08-17 by FGR : BEGIN
  If this.ASTALIN = [V]CST_ANEW Then
    For NI = 1 To maxtab(this.APARENT.BUD)
      If this.APARENT.BUD(NI) <> null and find(this.APARENT.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.APARENT.BUD(NI).PBUPAE <> AVOID.ACHAR Then
          If fmet this.APARENT.BUD_GET_INDEX(this.APARENT.BUD(NI).PBUPAE) = 0 Then
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", func AFNC.MES2(mess(967,2260,1), this.APARENT.BUD(NI).PBUCOD, this.APARENT.BUD(NI).PBUPAE), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Next NI
  Endif
  # Issue X3-52534 - 2017-08-17 by FGR : END
Return

###################################################################################################
$BUD_PBUPAE
  # Issue X3-33035 - 2017-06-09 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub BUD_PBUPAE_CONTROL
  Endcase
Return

$BUD_PBUPAE_CONTROL
Local Integer ISTATUS

  # Issue X3-33035 - 2017-06-09 by FGR
  If this.PBUPAE <> AVOID.ACHAR Then
    ISTATUS = fmet this.APARENT.BUD_CHECK_PBUPAE_VALID(this.PBUPAE)
    [L]ASTATUS = max([L]ASTATUS, ISTATUS)
  Endif
Return

###################################################################################################
# Linked to CDIE collection
###################################################################################################
$CDIE_CCE
  Case [L]ARULE
    When "CONTROL"   : Gosub CDIE_CCE_CONTROL
  Endcase
Return

$CDIE_CCE_CONTROL
Local Char SMESSAGE(250)

  # Note : in this case .APARENT. is mandatory existing because this is a dimensionned property in the table
  #        => this.APARENT can't be = null in this case
  [L]ASTATUS = func FINCCE_SYRA.CTL_CCE (this.ACTX, this.CCE, this.DIE, fmet this.APARENT.CDIE_SITE(), [0/0/0], SMESSAGE)
  If [L]ASTATUS <> [V]CST_AOK Then
    #[L]ASTATUS = fmet this.SETERROR("CCE", SMESSAGE, [L]ASTATUS)        # Issue X3-66474 - 2018-02-02 by SINGC
    [L]ASTATUS = fmet this.APARENT.SETERROR("CCE", SMESSAGE, [L]ASTATUS) # Issue X3-66474 - 2018-02-02 by SINGC
  Endif
Return

###################################################################################################
# Linked to PAF collection
###################################################################################################
$PAF_PAFCLB
  # Issue X3-39889 - 2017-07-26 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub PAF_PAFCLB_CONTROL
  Endcase
Return

$PAF_PAFCLB_CONTROL
Local Integer NI

  # Issue X3-39889 - 2017-07-26 by FGR
  For NI = 1 To maxtab(this.APARENT.PAF)
    If this.APARENT.PAF(NI) <> null and find(this.APARENT.PAF(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.APARENT.PAF(NI) <> this Then
        If this.APARENT.PAF(NI).PAFCLB = this.PAFCLB Then
          [L]ASTATUS = fmet this.SETERROR("PAFCLB", func AFNC.MES1(mess(173,2260,1), this.PAFCLB), [V]CST_AERROR)
          Break
        Endif
      Endif
    Endif
  Next NI
Return

