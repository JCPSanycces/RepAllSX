#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe OPPORPJM
###################################################################################################
# Properties
###################################################################################################
$SALFCY
  Case [L]ARULE
    When "PROPAGATE" : Gosub SALFCY_PROPAGATE
  Endcase
Return

$SALFCY_PROPAGATE
Local Integer I_DIE
Local Integer I_FCY
Local Char    L_CPY(GLONCPY)
Local Integer RNBRDIE
Local Char    RDIE(GLONDIE)(1..max(1,GOPTCANA))
Local Char    RDIEFMT(15)(1..max(1,GOPTCANA))
Local Char    RDIECOLHEA(15)(1..max(1,GOPTCANA))
Local Integer RDIEOBYFLG(1..max(1,GOPTCANA))
Local Char    RERRMES(250)
Local Integer ILINE
Local Integer NI

  # ---------------------------------------
  this.OPEDEFFCY = this.SALFCY
  # ---------------------------------------
  # A partir du site récupération du modèle, référentiels,...
  I_FCY = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.SALFCY)
  If I_FCY <> [V]CST_ANOTDEFINED Then
    L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY,"LEGCPY")
  Endif
  #---
  If func FINACM_SYRA.GET_ANASTC(this.ACTX, L_CPY, 2, RNBRDIE, RDIE, RDIEFMT, RDIECOLHEA, RDIEOBYFLG, RERRMES) = [V]CST_AOK Then
    # En premier on vide éventuellement les lignes existantes
    For NI = maxtab(this.CDIE) To 1 Step -1
      If this.CDIE(NI) <> null and find(this.CDIE(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        ILINE = fmet this.ADELLINE("CDIE", this.CDIE(NI).AORDER)
      Endif
    Next NI
    # Récupération des axes de la société
    For I_DIE = 1 To RNBRDIE
      ILINE = fmet this.ADDLINE("CDIE", [V]CST_ALASTPOS)
      # ---------------------------------------
      If ILINE <> [V]CST_ANOTDEFINED Then
        this.CDIE(ILINE).DIE = RDIE(I_DIE)
      Endif
      # ---------------------------------------
    Next I_DIE
  Endif
  # End issue 109158-11
  # ---------------------------------------
  L_CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.SALFCY,"LEGCPY")
  this.CUROPP = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(L_CPY,"RGCCUR")
  # ---------------------------------------
  this.TASBUDAUT = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "TASBUDAUT")
  # ---------------------------------------
  # Issue X3-86224 - 2018-05-14 by TEJAC : START
  If this.ASTALIN = [V]CST_ANEW Then
    # FGR : only on a new projet. If site is updated, project status will not change its value.
    # We are never comming back from "Launched" to "New"
    If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "PJMDEFSTA") = 2 Then
      this.OPPSTATE = 2
    Else
      this.OPPSTATE = 1
    Endif
  Endif
  # Issue X3-86224 - 2018-05-14 by TEJAC : END
Return

###################################################################################################
$OPPMOD
  Case [L]ARULE
    When "INIT"      : Gosub OPPMOD_INIT
  Endcase
Return

$OPPMOD_INIT
  this.OPPMOD = [V]CST_ANO
Return

###################################################################################################
$OPPSTATE
  #When "INIT"      : Gosub OPPSTATE_INIT        # Issue X3-86224 - 2018-05-04 by TEJAC
  Case [L]ARULE
    When "CONTROL"   : Gosub OPPSTATE_CONTROL
    When "PROPAGATE" : Gosub OPPSTATE_PROPAGATE
  Endcase
Return

# Issue X3-86224 - 2018-05-04 by TEJAC : START
$OPPSTATE_CONTROL
Local Integer IPJMDEFSTA

  # ----------------------
  If this.OPPSTATE <> 1 and this.OPPSTATE <> 2 and this.OPPSTATE <> 3 and this.OPPSTATE <> 4  and this.OPPSTATE <> 9 Then
    [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1), [V]CST_AERROR)
  Endif
  # ----------------------
  Case this.TCHACTION
    When "LAUNCH"
      If this.OPPSTATE <> 2 Then
        [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1) - "(" + mess(this.OPPSTATE,2249,1) + ")", [V]CST_AERROR)
      Endif
    When "DELIVERY"
      If this.OPPSTATE <> 3 Then
        [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1) - "(" + mess(this.OPPSTATE,2249,1) + ")", [V]CST_AERROR)
      Endif
    When "CLOSING"
      If this.OPPSTATE <> 4 Then
        [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1) - "(" + mess(this.OPPSTATE,2249,1) + ")", [V]CST_AERROR)
      Endif
    When "SUSPENSION"
      If this.OPPSTATE <> 9 Then
        [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1) - "(" + mess(this.OPPSTATE,2249,1) + ")", [V]CST_AERROR)
      Endif
    When "REACTIVATE"
      # TODO : FLORENT ICI : voir le controle à ce niveau
    When Default
      If this.ASTALIN = [V]CST_ANEW Then
        If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "PJMDEFSTA") = 2 Then
          If this.OPPSTATE <> 2 Then
          #If this.OPPSTATE <> 2 and this.OPPSTATE <> 1 Then
            [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Else
          If this.OPPSTATE <> 1 Then
            [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.OPPSTATE <> this.snapshot.OPPSTATE Then
          [L]ASTATUS = fmet this.SETERROR("OPPSTATE", mess(187,2260,1), [V]CST_AERROR)
        Endif
      Endif
  Endcase
  # ----------------------
Return

$OPPSTATE_PROPAGATE
  Case this.TCHACTION
    When "REACTIVATE"
      If this.snapshot.OPPSTATE = 4 Then
        Raz this.OPPDATS
      Elsif this.snapshot.OPPSTATE = 9 Then
        Raz this.OPPDATTH
      Endif
    When AVOID.ACHAR
      # Issue X3-107401 - 2018-09-06 by FGR : BEGIN : moved and completed in OPPOR_CSTD_PROPERTIES
      # Issue X3-86224 - 2018-05-04 by TEJAC
      #If fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, this.SALFCY, "PJMDEFSTA") = 2 Then
      #  this.OPPDATLA = date$
      #Endif
      # Issue X3-107401 - 2018-09-06 by FGR : END
  Endcase
Return

