#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char    VALEUR(250), PARAM(250)(1..20)
OGNBSEL = GNBSEL
GNBSEL = 10
PARAM(1) = "AVW"
PARAM(2) = "CODVUE"
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJET","SELOBJ","") From GACTION
GNBSEL = OGNBSEL
End

########################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
   When "SELOBJ","SELOBJSTD"
    OBJET   = PARAM(1)
    OPTIONS = PARAM(2)
    If instr(1,PARAM(3),"~")
     Call SUPPN(PARAM(3),SUPP) From CONTOBJ
    Else
     SUPP = PARAM(3)
     For I=3 To min(dim(PARAM),dim(SUPP)+3)-1
      SUPP(I-3) = PARAM(I)
     Next I
    Endif
   When "SELOBJCRIT"
    OBJET   = PARAM(1) 
    OPTIONS = PARAM(2)
    If instr(1,PARAM(3),"~")
     Call SUPPN(PARAM(3),SUPP) From CONTOBJ
    Else
     SUPP = PARAM(3)
    Endif
    Raz CRITERE , ICRITERE
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(4),"&") From GOBJSUB
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(5),"&") From GOBJSUB
   When "SELOBJET"
    SAV_VALEUR = VALEUR
    OBJET   = PARAM(1)
    Local Char    PROGOBJ(GDIMFIC) , PROGSUB(GDIMFIC) , PROGSPE(GDIMFIC) , PROGSPV(GDIMFIC)(1..50)
    Local Integer PSTD , PSUB , PSPE , PSPV
    Call SETPROG(OBJET,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
    If !PSTD : OK = 0 : Return : Endif
    If find(OBJET,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
     If clalev([F:ATX]) : Close Local File [ATX] : Endif
     Local File =GTABCPT+"ATEXTE" [ATX]
    Endif
    Gosub OPTIONS From =PROGOBJ
    Gosub NOMFIC  From =PROGOBJ
    Gosub SETCLE  From =PROGOBJ
    OPTIONS = OPTSEL
    If PARAM(3)<>""
     OPTIONS = PARAM(3)
    Endif
    If dim([L]CLEVALEUR)>0 : ## GEODE
     If PARAM(2)=CLEVALEUR
      If CLESUPP<>"" 
       If evalue("dim([M]"+CLESUPP+")")>1
        SUPP = num$(evalue("[M]"+CLESUPP+"("+num$(nolign-1)+")"))
       Elsif evalue("dim([M]"+CLESUPP+")")>0
        SUPP = num$(evalue("[M]"+CLESUPP))
       Endif
       If SUPP="0" : SUPP = "" : Endif
      Endif
     Endif
    Elsif PARAM(2)=CLEPRIM
     If CLESEC<>"" & (TYPGES<>3 or dim(CLESEC)>1)
      If evalue("dim([M]"+CLESEC+")")>1
       SUPP = num$(evalue("[M]"+CLESEC+"("+num$(nolign-1)+")"))
      Else
       SUPP = num$(evalue("[M]"+CLESEC))
      Endif
      If SUPP="0" : SUPP = "" : Endif
     Endif
    Elsif CLESEC<>"" & PARAM(2)=CLESEC
     Case type(VALEUR)
      When 1,2,4,5,6,7,8 : VALEUR = val(num$(evalue("[M]"+CLEPRIM)))
      When Default       : VALEUR = num$(evalue("[M]"+CLEPRIM))
     Endcase
     If (TYPGES<>3 and dim(CLESEC)>1)
      SUPP = num$(evalue("[M]"+CLESEC))
     Endif
    Else
     If CLESEC<>"" & (TYPGES<>3 or dim(CLESEC)>1)
      If evalue("dim([M]"+CLESEC+")")>1
       SUPP = num$(evalue("[M]"+CLESEC+"("+num$(nolign-1)+")"))
      Else
       SUPP = num$(evalue("[M]"+CLESEC))
      Endif
      If SUPP="0" : SUPP = "" : Endif
     Endif
     Case type(VALEUR)
      When 1,2,4,5,6,7,8 : VALEUR = val(num$(evalue("[M]"+CLEPRIM)))
      When Default       : VALEUR = num$(evalue("[M]"+CLEPRIM))
     Endcase
    Endif
    START  = PARAM(2)
  Endcase
 When "VERF_TABLE"
  Case TABLE
   When "SELOBJET"
    If PARAM(2)=CLEPRIM
     VALEUR = evalue("[F:"+ABFIC+"]"+CLEPRIM)
    Elsif evalue("dim([M]"+CLEPRIM+")")>0
     Assign "[M]"+CLEPRIM With evalue("[F:"+ABFIC+"]"+CLEPRIM)
    Endif
    For CL=0 To dim(CLESEC)-1
     If CLESEC(CL)<>""
      If evalue("dim([M]"+CLESEC(CL)+")")>0
       Assign "[M]"+CLESEC(CL) With evalue("[F:"+ABFIC+"]"+CLESEC(CL))
       If PARAM(2)=CLESEC(CL)
        VALEUR = evalue("[F:"+ABFIC+"]"+CLESEC(CL))
       Endif
      Endif
     Endif
    Next CL
    mkstat = 4 : # Pour forcer la relecture 
  Endcase
 When "CHX_TABLE"
#
#BY
  #If GPRODUIT=0
  # Local Integer OKTRT
  # Call EXISTE_ADX("",nomap,"WWCPY",OKTRT) From ORDSYS
  # If OKTRT
  #  Gosub SETNUM From WWCPY
  #  If TT
  #   Gosub SELOBJ From GSOCIETE
  #  Endif
  # Endif
  #Endif
#/BY
#
 When "FIN_TABLE"
  Case TABLE
   When "SELOBJET"
    Case GSTATUT
     When 7
      VALEUR = SAV_VALEUR
     When Default      
      If CLESEC<>"" & PARAM(2)=CLESEC : # mb 30.7.1
       Case type(VALEUR)
        When 1,2,4,5,6,7,8 : VALEUR = val(num$(evalue("[M]"+CLESEC)))
        When Default       : VALEUR = num$(evalue("[M]"+CLESEC))
       Endcase
      Endif
    Endcase
  Endcase
Endcase
Return

########################################################################
Subprog SELECT(ABREV,OPTIONS,VALEUR,SUPP)
Value    Char ABREV     : # Abréviation fichier
Value    Char OPTIONS   : # Options particulières
Variable Char VALEUR()  : # Zone courante
Value    Char SUPP()    : # Zone de clé secondaire
Local Char    PARAM(250)(1..20)
PARAM(1) = ABREV
PARAM(2) = OPTIONS
PARAM(3) = SUPP
Call S_TAB_CHAR(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
End

########################################################################
Subprog SELNUM(ABREV,OPTIONS,VALEUR,SUPP)
Value    Char    ABREV     : # Abréviation fichier
Value    Char    OPTIONS   : # Options particulières
Variable Decimal VALEUR()  : # Zone courante
Value    Char    SUPP()    : # Zone de clé secondaire
Local Char    PARAM(250)(1..20)
PARAM(1) = ABREV
PARAM(2) = OPTIONS
PARAM(3) = SUPP
Call S_TAB_NUM(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
End

########################################################################
Subprog SELLIB(ABREV,OPTIONS,VALEUR,SUPP)
Value    Char    ABREV     : # Abréviation fichier
Value    Char    OPTIONS   : # Options particulières
Variable Integer VALEUR()  : # Zone courante
Value    Char    SUPP()    : # Zone de clé secondaire
Local Char    PARAM(250)(1..20)
PARAM(1) = ABREV
PARAM(2) = OPTIONS
PARAM(3) = SUPP
Call S_TAB_LIB(VALEUR,PARAM,"SELOBJ","SELOBJ","") From GACTION
End
