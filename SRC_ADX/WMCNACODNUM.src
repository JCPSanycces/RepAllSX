#<AdxTL>@(#)0.0.0.0 $Revision$Class Doc sequence numbers
# Supervisor
## ACLA-CLASSE ## ACODNUM
# 2018-11-06 07:00:50 914

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0ACODNUM
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_CODNUM From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_DES From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_LNG From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_NIVDEF From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_NIVRAZ From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_TYP From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_NBPOS From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_CTLCHR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_ZERO From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_SEQ From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_SEQTBL From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_SEQABR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_SEQNBR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_LEG From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_UPDDAT From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_CREDAT From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub AINIT From WMC0ACODNUM : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0ACODNUM
Gosub _ALOADATTRIBUTE_CODNUM From WMC1ACODNUM : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0ACODNUM
Gosub LNKPRO_CODNUM From WMC1ACODNUM : Gosub TESTALLSTAT
For AINDCLA=1 To 10
 If this.NBCOMPONENT(AINDCLA)<>null& find(this.NBCOMPONENT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.NBCOMPONENT(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_SEQTBL From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub LNKPRO_LEG From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1ACODNUM : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1ACODNUM : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



