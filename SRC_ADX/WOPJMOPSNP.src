Call TEXTE(1003567,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..0) , CLELIG(GLONAVA)
CLEPRIM = 'SNPCOD'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(40)(0..GNBDERNIER)
Local Char     A_BUF2(20)(0..GNBDERNIER)
Local Char     A_BUF3(30)(0..GNBDERNIER)
Local Date     A_BUF4(0..GNBDERNIER)
Local Char     A_BUF5(30)(0..GNBDERNIER)
If clalev([F:PJSNPH9])>0 : Close Local File [PJSNPH9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(40),
& Char     A_TAB2(20),
& Char     A_TAB3(30),
& Date     A_TAB4,
& Char     A_TAB5(30)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5
& As [PJSNPH9]
Return

$LEC_DERLU
Read [AX3]AXX0="PJMOPSNPH";"DESAXX";GLANGUE;[F:PJSNPH]SNPCOD;""
If fstat : Raz [F:AX3] : Endif
Read [AX4]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PJSNPH]OPPNUM;""
If fstat : Raz [F:AX4] : Endif
Return

$CHARGE_DERLU
If clalev([F:PJSNPH9])>0
 Read [PJSNPH9] = [F:PJSNPH9]A_TABI
 [L]CLE = [F:PJSNPH9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:PJSNPH9])>0
 Filter [PJSNPH9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [PJSNP1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:PJSNPH9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:PJSNPH]SNPCOD+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:PJSNPH9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:PJSNPH9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PJSNPH]OPPNUM"
Call TEXTE(18260,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PJSNPH]OPPNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:PJSNPH]SNPCOD"
Call TEXTE(1003359,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PJSNPH]SNPCOD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(3)"
SELEXP(NBSEL) = "[F:AX3]TEXTE"
Call TEXTE(1003364,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
NBSEL += 1
SELZON(NBSEL) = "[F:PJSNPH]SNPCREDAT"
Call TEXTE(14105,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 8
SELFMT(NBSEL) = "DZz:"+GFMDAT4+""
SELFOR(NBSEL) = "DZz:"+GFMDAT4
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:PJSNPH]SNPCREDAT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[L]SAIRAP(5)"
SELEXP(NBSEL) = "[F:AX4]TEXTE"
Call TEXTE(56083,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = "K:30X"
SELMAJ(NBSEL) = 0
If clalev([F:PJSNPH_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:AX3])=0 : Local file ATEXTRA [AX3] : Endif
If clalev([F:AX4])=0 : Local file ATEXTRA [AX4] : Endif
Link [PJSNPH] With
& [AX3]AXX0="PJMOPSNPH";"DESAXX";GLANGUE;[F:PJSNPH]SNPCOD;"",
& [AX4]AXX0="PIMPL";"PIMDESAXX";GLANGUE;[F:PJSNPH]OPPNUM;""
& As [PJSNPH_]
Return

$DEFAUT_LISTE
Default file [PJSNPH_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1"
