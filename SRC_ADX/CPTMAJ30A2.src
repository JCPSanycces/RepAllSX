 If dim([F:GBS]FLGHISCAR)>0
  [F:GBS]FLGHISCAR = num$([F:GBS]FLGHIS)
  Rewrite [GBS]
  If fstat
   GOK = 0 : Call ERREUR("GBAGSCR"-[F:GBS]COD,1) From DOSDIC
  Endif
 Endif
