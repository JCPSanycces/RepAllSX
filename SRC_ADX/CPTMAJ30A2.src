Call ECR_TIME(mess(81,125,1)-": TABPAYTYP") From DOSSUB : # maj table
For [TPY]TPY0
 If dim([F:TPY]DES)>0
  Call MAJTEXTRA([F:TPY]DES,"TABPAYTYP","DESTRA",[F:TPY]PAYTYP,"") From CPTMAJ30
 Endif
 If dim([F:TPY]DESSHO)>0
  Call MAJTEXTRA([F:TPY]DESSHO,"TABPAYTYP","SHOTRA",[F:TPY]PAYTYP,"") From CPTMAJ30
