Trbegin [GBS]
For [GBS]GBS0
 If dim([F:GBS]DES)>0
  Call MAJTEXTRA([F:GBS]DES,"GBAGSCR","DESTRA",num$([F:GBS]FLGHIS),[F:GBS]COD) From CPTMAJ30
