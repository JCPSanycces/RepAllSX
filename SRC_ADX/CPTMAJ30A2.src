##-------------------------------------------------------------------------------------------------------#
# appel à partir de DOSMAJ30... pour récupérer les champs dont le type de données est passé à AXx
##-------------------------------------------------------------------------------------------------------#
$TXS_ATEXTRA
If filinfo(filpath("FIL","TXSA","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TXSA"     [TXS]
 Call ECR_TIME(mess(81,125,1)-": TXSA") From DOSSUB : # maj table

 Global Char MIGDOSMAJ(10)  : MIGDOSMAJ  = [F:ADS]DOSSIER
 Global Char MIGGLANMAJ(10) : MIGGLANMAJ = [F:ADS]LANDEF
 Global Char MIGDOSCOP(10)  : MIGDOSCOP  = [F:ADS]DOSCOP

 For [TXS]TXS1
  If dim([F:TXS]GRPDES)>0
   Call MAJTEXTRA([F:TXS]GRPDES,"TXSA","GRPDES",[F:TXS]LSTGRP,"") From CPTMAJ30
  Endif
  If dim([F:TXS]TXSDES)>0
   Call MAJTEXTRA([F:TXS]TXSDES,"TXSA","TXSDES",[F:TXS]TXSNAM,"") From CPTMAJ30
  Endif
  For I=0 To 19
   If dim([F:TXS]NAMCOL(I))>0
    Call MAJTEXTRA([F:TXS]NAMCOL(I),"TXSA","NAMCOL",[F:TXS]TXSNAM,num$(I+1)) From CPTMAJ30
   Endif
  Next I
 Next
 Close Local File [TXS]
 Kill MIGDOSMAJ
 Kill MIGGLANMAJ
 Kill MIGDOSCOP
Endif
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour TXSA/TXSD/TXSM/TXSP/TXSV/TXSW
##-------------------------------------------------------------------------------------------------------#
$TXSA
##-------------------------------------------------------------------------------------------------------#
If filinfo(filpath("FIL","TXSA","fde",[F:ADS]DOSSIER),0)>0
 Local File =[F:ADS]DOSSIER+".TXSA"     [TXS]
 Call ECR_TIME(mess(81,125,1)-": TXSA") From DOSSUB : # maj table
 Gosub SET_FIRST From TRTFIRST
 Raz STOP
 $LOOP_TXS
 Raz NB
 If STOP
  Raz STOP
  CRITERE = "[F:TXS]TXSNAM>'"+ACLE1+"'"
 Else
  CRITERE = "1=1"
 Endif

 Trbegin [TXS]
 GOK = 1
 For [TXS]TXS1 Where evalue(CRITERE)

  # Nx champs
  [F:TXS]GENLEDTYP = 1
  [F:TXS]ANALEDTYP = 2
  For I=0 To dim([F:TXS]SAICOL)-1
   [F:TXS]SAICOL(I) = 1
  Next

  [F:TXS]CCEINF =  [F:TXS]CNAINF

  If [F:TXS]CCEINF="CCEDEF"
   [F:TXS]CCEINF="DEFCCE"
  Elsif [F:TXS]CCEINF<>"" & !find([F:TXS]CCEINF,"DES","DESSHO","FCY","ACS","AUZ","VLYSTR","VLYEND","IPT","UOM","CREDAT","CREUSR")
   [F:TXS]CCEINF = "CCE"
  Endif

  # Textes traduisibles... sont effectués à l'appel de DOSMAJ30 (même nom...)

  NB+=1
  Rewrite [TXS]
  If fstat
   GOK = 0 : Call ERREUR("TXSA"-[F:TXS]TXSNAM,1) From DOSDIC
  Endif

  If NB>GMAXUPDTRS
   ACLE1 = [F:TXS]TXSNAM
   STOP=1
   Break
  Endif

 Next

 Commit
 If STOP
  Goto LOOP_TXS
 Endif
 Gosub UNSET_FIRST From TRTFIRST
 Close Local File [TXS]
Endif
Return

##-------------------------------------------------------------------------------------------------------#
$TXSD
##-------------------------------------------------------------------------------------------------------#
If filinfo(filpath("FIL","TXSD","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TXSD"      [TXD]
Local File =[F:ADS]DOSSIER+".TXSM"      [TXM]
Local File =[F:ADS]DOSSIER+".BUDPARAXI" [BPX]

Local File =[F:ADS]DOSSIER+".GACM"     [GCM]
Local File =[F:ADS]DOSSIER+".GLED"     [LED]

Local Char    COAGEN(30), COAANA(30), COAIAS(30)
Local Char    LEDGEN(30), LEDANA(30), LEDIAS(30)

Filter [F:GCM] Where LEG=LEGREF
Read [F:GCM] First
If !fstat
 Read [F:LED]LED0 = [F:GCM]LED(0)
 COAGEN = [F:LED]COA
 LEDGEN = [F:GCM]LED(0)
 If  [F:GCM]LED(1)<>""
  Read [F:LED]LED0 = [F:GCM]LED(1)
  COAANA = [F:LED]COA
  LEDANA = [F:GCM]LED(1)
 Else
  Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
  COAANA = [F:LED]COA
  LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
 Endif
 If [F:GCM]LED(2)<>""
  Read [F:LED]LED0 = [F:GCM]LED(2)
  COAIAS = [F:LED]COA
  LEDIAS = [F:GCM]LED(2)
 Endif
Else
 Filter [F:GCM]
 Read [F:GCM] First
 If !fstat
  Read [F:LED]LED0 = [F:GCM]LED(0)
  COAGEN = [F:LED]COA
  LEDGEN = [F:GCM]LED(0)
  If  [F:GCM]LED(1)<>""
   Read [F:LED]LED0 = [F:GCM]LED(1)
   COAANA = [F:LED]COA
   LEDANA = [F:GCM]LED(1)
  Else
   Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   COAANA = [F:LED]COA
   LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
  Endif
  If [F:GCM]LED(2)<>""
   Read [F:LED]LED0 = [F:GCM]LED(2)
   COAIAS = [F:LED]COA
   LEDIAS = [F:GCM]LED(2)
  Endif
 Else
  COAGEN = PLGEN
  LEDGEN = [F:RGCM]LED(0)
  COAANA = PLANA
  LEDANA = [F:RGCM]LED(1)
  COAIAS = PLIAS
  LEDIAS = [F:RGCM]LED(2)
 Endif
Endif

# Axes analytiques en lignes
Read [LED]LED0 = LEDANA


Call ECR_TIME(mess(81,125,1)-": TXSD/TXSM") From DOSSUB : # maj table

# Récupération des formules...
Local Char      NEWFRM(250),LIGNE(250)
Local Char      AZONE(250), ZONE(250), CAR
Local Integer   I, J, K, NARG, SENS
Local Char      ARG(30)(1..9),CR(30)(1..9)

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_TXD
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:TXD]TXSNAM='"+ACLE1+"' & [F:TXD]LIG="+num$(ICLE1)+" & [F:TXD]COL>"+num$(ICLE2)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:TXD]TXSNAM='"+ACLE1+"' & [F:TXD]LIG>"+num$(ICLE1)
Elsif STOP = 3
 Raz STOP
 CRITERE = "[F:TXD]TXSNAM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [TXD]
GOK = 1
For [TXD]TXD0 Where evalue(CRITERE)

 If [TXD]COL=0
  # Textes traduisibles...
  Call MAJTEXTRA([F:TXD]FRM,"TXSD","DES",[F:TXD]TXSNAM,num$([F:TXD]LIG)) From CPTMAJ30
 Else
  Raz NEWFRM
  LIGNE = [F:TXD]FRM
  While LIGNE<>""
   K = instr(1,LIGNE," ")
   If K
    ZONE = left$(LIGNE,K-1) : LIGNE = vireblc(right$(LIGNE,K+1),2)
   Else
    ZONE = LIGNE : LIGNE = ""
   Endif
   AZONE = ZONE
   If left$(ZONE,3)="IAS"
    Gosub FORMULE_IAS
   Else
    Gosub TRT_ZONE
   Endif
   NEWFRM+=" "
  Wend
  [F:TXD]FRM = NEWFRM
 Endif

 Filter [F:TXM] Where [F:TXM]TXSNAM=[F:TXD]TXSNAM & [F:TXM]COL=[F:TXD]COL & [F:TXM]LIG=[F:TXD]LIG
 For [F:TXM]
  If left$(ZONE,3)="IAS" : [F:TXM]COA = COAIAS  Else [F:TXM]COA = COAGEN : Endif
  # A ce stade, les CR renseignés sont OK
  For I=1 To max(1,[F:LED]DIENBR)
   Assign "[F:TXM]DIE"+num$(I) With evalue("[F:LED]DIE("+num$(I-1)+")")
  Next
  Rewrite [TXM]
  If fstat
   GOK = 0 : Call ERREUR("TXSM"-[F:TXM]TXSNAM-[F:TXM]VERSION-num$([F:TXM]LIG)-num$([F:TXM]COL)-num$([F:TXM]IND),1) From DOSDIC
  Endif
 Next
 Filter [TXM]

 NB+=1
 Rewrite [TXD]
 If fstat
  GOK = 0 : Call ERREUR("TXSD"-[F:TXD]TXSNAM-num$([F:TXD]LIG)-num$([F:TXD]COL),1) From DOSDIC
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:TXD]TXSNAM
  ICLE1 = [F:TXD]LIG
  ICLE2 = [F:TXD]COL
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_TXD
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [TXD],[TXM],[GCM],[LED],[BPX]
Return

$TRT_ZONE
Raz CR
CAR = left$(ZONE,1)
Case CAR

 When "-"
  ZONE = right$(ZONE,2)
  NEWFRM += CAR
  Goto TRT_ZONE

 When "+"
  ZONE = right$(ZONE,2)
  NEWFRM += CAR
  Gosub TRT_ZONE

 When "G"
  If left$(ZONE,3)="GM(" | left$(ZONE,3)="GQ("
   K = instr(1,ZONE,",")
   NEWFRM += left$(ZONE,K-1)+',"'+num$(1)+'"'+right$(ZONE,K)
  Endif

 When "N","E","P"

  # On ne concerve par le premier argument...
  # Le 2ème, on le concerve
  # Le 3/4/5 sont à replacés selon le code croisement
  NEWFRM += left$(ZONE,3)
  ZONE = right$(ZONE,3)
  ZONE = seg$(ZONE,2,len(ZONE)-1)
  Raz NARG
  While ZONE<>""
   NARG += 1
   J = instr(1,ZONE,",")
   If J
    ARG(NARG) = left$(ZONE,J-1)
    ZONE      = right$(ZONE,J+1)
   Else
    ARG(NARG) = ZONE
    ZONE      = ""
   Endif
   If left$(ARG(NARG),1)='"' or left$(ARG(NARG),1)="'"
    If left$(ARG(NARG),1)=right$(ARG(NARG),len(ARG(NARG)))
     ARG(NARG) = seg$(ARG(NARG),2,len(ARG(NARG))-1)
    Endif
   Endif

   If NARG = 1
    # Code croisement
    Read [BPX]BPX0 = ARG(NARG)
   Elsif NARG = 2
     NEWFRM += ARG(NARG)
   Else
    If [F:BPX]AXI1>0 & NARG=3 : CR([F:BPX]AXI1) = ARG(NARG) : Endif
    If [F:BPX]AXI2>0 & NARG=4 : CR([F:BPX]AXI2) = ARG(NARG) : Endif
    If [F:BPX]AXI3>0 & NARG=5 : CR([F:BPX]AXI3) = ARG(NARG) : Endif
   Endif
  Wend

  For I=1 To min(8,[F:LED]DIENBR)
   NEWFRM += ',"'
   If CR(I)<>""
    NEWFRM += CR(I)
   Else
    NEWFRM += "*"
   Endif
   NEWFRM += '"'
  Next
  NEWFRM += ')'

 When Default
  NEWFRM += ZONE

Endcase
Return

$FORMULE_IAS
CMD = seg$(ZONE,5,len(ZONE)-1)
NBARG = 0
SENS  = 0
NEWFRM += "[3]NM("
While CMD<>""
 K = instr(1,CMD,",")
 If K
  ARG = left$(CMD,K-1) : CMD = vireblc(right$(CMD,K+1),2)
 Else
  ARG = CMD : CMD = ""
 Endif
 ARG = vireblc(ctrans(ARG,'"'+"'","  "),2)
 NBARG += 1
 Case num$(NBARG)
  When "1" :                      # Formule
   If left$(ARG,1)="-" :
    SENS= -1 :
    ARG = right$(ARG,2)
   Endif
   NEWFRM += ARG+","
  When "2" :                      # Type de secteur
   CAR=ARG
  When "3" :                      # Secteur
   If ARG="" : ARG='" "' : Endif
   If CAR = "1" : NEWFRM += ARG+",*" : Endif
   If CAR = "2" : NEWFRM += "*,"+ARG : Endif
 Endcase
Wend
NEWFRM += ")"
If SENS=-1
 NEWFRM = "-"+NEWFRM
Endif
Return

##-------------------------------------------------------------------------------------------------------#
$TXSP
##-------------------------------------------------------------------------------------------------------#
If filinfo(filpath("FIL","TXSP","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TXSP"     [TXP]
Call ECR_TIME(mess(81,125,1)-": TXSP") From DOSSUB : # maj table
Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_TXP
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:TXP]TXSNAM='"+ACLE1+"' & [F:TXP]VERSION='"+ACLE2+"' & [F:TXP]COL>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:TXP]TXSNAM='"+ACLE1+"' & [F:TXP]VERSION>'"+ACLE2+"'"
Elsif STOP = 3
 Raz STOP
 CRITERE = "[F:TXP]TXSNAM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [TXP]
GOK = 1
For [TXP]TXP0 Where evalue(CRITERE)

 If [TXP]NEWENT=2 & [TXP]CLOENT=2
  [F:TXP]TYPMNT = 1
 Elsif[TXP]NEWENT=2
  [F:TXP]TYPMNT = 2
 Elsif [TXP]CLOENT=2
  [F:TXP]TYPMNT = 3
 Else
  [F:TXP]TYPMNT = 4
 Endif

 NB+=1
 Rewrite [TXP]
 If fstat
  GOK = 0 : Call ERREUR("TXSP"-[F:TXP]TXSNAM-[F:TXP]VERSION,1) From DOSDIC
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:TXP]TXSNAM
  ACLE2 = [F:TXP]VERSION
  ICLE1 = [F:TXP]COL
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_TXP
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [TXP]
Return

##-------------------------------------------------------------------------------------------------------#
$TXSV
##-------------------------------------------------------------------------------------------------------#
If filinfo(filpath("FIL","TXSV","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TXSV"     [TXV]
Call ECR_TIME(mess(81,125,1)-": TXSV") From DOSSUB : # maj table

For [TXV]TXX0 Where VERSION=""
 # Textes traduisibles...
 Call MAJTEXTRA([F:TXV]VARDES,"TXSV","VARTRA",[F:TXV]TXSNAM,[F:TXV]VARNAM) From CPTMAJ30
Next
Close Local File [TXV]
Return




##-------------------------------------------------------------------------------------------------------#
## Pyramides comptes
##-------------------------------------------------------------------------------------------------------#
$PYRAM_CUMUL

Local File =[F:ADS]DOSSIER+".GACCOUNT"   [GAC]
Filter [GAC] Where TYP=2
If nbrecord([F:GAC])=0
 Close Local File [GAC]
 Return
Endif

Call ECR_TIME(mess(81,125,1)-": GACCPYM/GACCGRUPYM") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".GACCPYM"    [GYM]
Local File =[F:ADS]DOSSIER+".GACCGRUPYM" [GRY]
Local File =[F:ADS]DOSSIER+".GACCGRUPYM" [GR2]

Local File =[F:ADS]DOSSIER+".GACM"       [GCM]
Local File =[F:ADS]DOSSIER+".GLED"       [LED]

Local Char    COAGEN(30)

Filter [F:GCM] Where LEG=LEGREF
Read [F:GCM] First
If !fstat
 Read [F:LED]LED0 = [F:GCM]LED(0)
 COAGEN = [F:LED]COA
Else
 Filter [F:GCM]
 Read [F:GCM] First
 If !fstat
  Read [F:LED]LED0 = [F:GCM]LED(0)
  COAGEN = [F:LED]COA
 Else
  COAGEN = PLGEN
 Endif
Endif

# Création de la pyramide
Local Char    PYRAMIDE(30)  :  PYRAMIDE ="FIRST"
Gosub PYRAM
# Création des groupes de comptes
Gosub GROUP
# Suppression des fils/père
#Gosub DELPYM
# Utilitaire de parcours du rang (70096)
Gosub PRNROW

Close Local File [GAC],[GYM],[GRY],[GR2],[GCM],[LED]
Return


$PYRAM
Trbegin [GYM]
Raz [GYM]
[F:GYM]PYM    = PYRAMIDE
[F:GYM]COA    = COAGEN
[F:GYM]CREUSR = GUSER
[F:GYM]CREDAT = date$
[F:GYM]CRETIM = time
[F:GYM]UPDUSR = GUSER
[F:GYM]UPDDAT = date$
[F:GYM]UPDTIM = time
Write [GYM]
If fstat
 GOK = 0 : Call ERREUR("GACCPYM"-[F:GYM]PYM,1) From DOSDIC
Endif
Commit
Return

$GROUP
Local Char    RACCUR(30) , RACINE(30)
Local Integer RANG , LIGNE
Local Integer JOK : JOK=1

Local Integer NBNIV : NBNIV = type([F:GAC]ACC)-10
Local Integer LONG(1..NBNIV)
Local Integer NIVEAU(1..NBNIV)

For NIV=1 To NBNIV
 LONG(NIV)   = NIV-1
 NIVEAU(NIV) = (NIV-1)*10
Next

Filter [GAC] Where TYP=2
Trbegin [GRY]

 For NIV=NBNIV To 1 Step -1
  #
  # Création des groupes liés aux de comptes de cumuls V5
  #
  RACCUR = ""
  RANG   = 0
  If NIV=NBNIV
   Filter [GAC] Where TYP=2 & len([F:GAC]ACC)>=LONG(NIV)
  Else
   Filter [GAC] Where TYP=2 & len([F:GAC]ACC)>=LONG(NIV) & len([F:GAC]ACC)<LONG(NIV+1)
  Endif

  For [GAC]GAC0

   RACINE = left$([F:GAC]ACC,LONG(NIV))
   If RACINE<>RACCUR or !JOK
    If RACINE<>RACCUR
     RACCUR = RACINE
     LIGNE  = 0
     RANG  += 10
    Endif
    Raz [F:GRY]
    [F:GRY]PYM    = PYRAMIDE
    [F:GRY]GRU    = RACCUR
    [F:GRY]LEV    = NIVEAU(NIV)
    Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GACCGRUPYM","DESTRA",PYRAMIDE,RACCUR) From CPTMAJ30
    Call MAJTEXTRA(RACCUR,"GACCGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From CPTMAJ30
    If dim([F:GRY]DES)>0
     [F:GRY]DES    = mess(100,102,1)-RACCUR : # Groupe
    Endif
    [F:GRY]PRNROW = RANG
    [F:GRY]COA    = COAGEN
    If JOK
     [F:GRY]LIN    = 1
     [F:GRY]ACC    = RACCUR+"*"
    Else
     LIGNE += 1
     [F:GRY]LIN    = LIGNE
     [F:GRY]ACC    = [F:GAC]ACC
    Endif
    #[F:GRY]CLSCOD = [F:GAC]CLSCOD
    [F:GRY]CLSCOD =  num$([F:GAC]CLS)

    If dim([F:GRY]CREDAT)>0 : [F:GRY]CREDAT = date$ : Endif
    If dim([F:GRY]CREUSR)>0 : [F:GRY]CREUSR = GUSER : Endif
    If dim([F:GRY]CRETIM)>0 : [F:GRY]CRETIM = time  : Endif
    Write [GRY]
    If fstat
      GOK = 0 : Call ERREUR("GACCGRUPYM"-[F:GRY]PYM-[F:GRY]GRU-num$([F:GRY]LIN),1) From DOSDIC
    Endif
   Endif
  Next
  Filter [GAC]
  #
  # Groupes de cumuls du niveau inférieur
  #
  If NIV<NBNIV
   RACCUR = ""
   Filter [GRY] Where PYM=PYRAMIDE & LEV=NIVEAU(NIV+1) & LIN=1 Order By Key CLE=GRU
   For [GRY]CLE
    RACINE = left$([F:GRY]GRU,LONG(NIV))
    If RACINE=""
     RACINE = "TOTAL"
    Endif
    If RACINE<>RACCUR
     RACCUR = RACINE
     RANG  += 10
     Raz [F:GR2]
     [F:GR2] = [F:GRY]
     [F:GR2]GRU    = RACCUR
     [F:GR2]LIN    = 1
     [F:GR2]LEV    = NIVEAU(NIV)
     Call MAJTEXTRA(mess(100,102,1)-RACCUR,"GACCGRUPYM","DESTRA",PYRAMIDE,RACCUR) From CPTMAJ30
     Call MAJTEXTRA(RACCUR,"GACCGRUPYM","SHOTRA",PYRAMIDE,RACCUR) From CPTMAJ30
     If dim([F:GR2]DES)>0
      [F:GR2]DES    = mess(100,102,1)-RACCUR : # Groupe
     Endif
     [F:GR2]PRNROW = RANG
     [F:GR2]SBBGRU = [F:GRY]GRU
     [F:GR2]COA    = COAGEN
     [F:GR2]ACC    = ""
    Else
     [F:GR2]LIN   += 1
     [F:GR2]SBBGRU = [F:GRY]GRU
    Endif
    If dim([F:GR2]CREDAT)>0 : [F:GR2]CREDAT = date$ : Endif
    If dim([F:GR2]CREUSR)>0 : [F:GR2]CREUSR = GUSER : Endif
    If dim([F:GR2]CRETIM)>0 : [F:GR2]CRETIM = time  : Endif
    Write [GR2]
    # Pas de condition sur le Write...
    # 70096 => Si le fils devient père, il faut corriger l'enregistrement.
    If fstat=3
     Update [GR2] Where PYM=[L]PYRAMIDE & GRU=RACCUR & LIN=1 With ACC="", SBBGRU=[F:GRY]GRU, LEV=NIVEAU(NIV)
    Endif
   Next
  Endif
 Next NIV
Commit

# Lancement de la resynchronisation des pyramides après migration => Post Requis
#Call PYRAMPRT(PYRAMIDE,"FIRST",nomap) From LIENPYRACC
#Call PYRAMLIK(PYRAMIDE,"FIRST",nomap) From LIENPYRACC
Return

# Suppression des fils devenu père...
$DELPYM
GOK = 1
Trbegin [GRY]
Filter [GRY] Where PYM="FIRST" and SBBGRU=""
For [GRY]
 I = instr(1,[F:GRY]ACC,"*")
 If I
  RACCUR= left$([F:GRY]ACC,I-1)  # Fils
  Filter [GR2] Where PYM="FIRST" and SBBGRU<>"" and GRU=RACCUR
  If rowcount([F:GR2])>1
   Delete [GRY] Curr
  Endif
 Endif
Next
Filter [GRY]
Commit
Return

# Utilitaire de parcours du rang
$PRNROW
Trbegin [GRY]
For I=0 To NBNIV
 Filter [GRY] Where PYM="FIRST" and len([F:GRY]GRU)=I
 RANG=10
 For [GRY]GRY0(2)
  For [GRY]GRY0
   [F:GRY]PRNROW = RANG
   Rewrite [F:GRY]
  Next
  RANG+=10
 Next
Next
Commit
Return

##-------------------------------------------------------------------------------------------------------#
## Suppression des pièces IAS..
##-------------------------------------------------------------------------------------------------------#
$SUP_GAU
Local File =[F:ADS]DOSSIER+".GAUTACE"    [GAU]
Local File =[F:ADS]DOSSIER+".GAUTACED"   [GAD]
Local File =[F:ADS]DOSSIER+".GAUTACEF"   [GAG]
Local File =[F:ADS]DOSSIER+".GVARPARVAL" [GVV]

Local Char CODE(30)
CODE = "IASBC"
Delete [GAU] Where COD=CODE : If fstat : Call ERREUR("GAU"-CODE,3) From DOSDIC : Endif
Delete [GAD] Where COD=CODE : If fstat : Call ERREUR("GAD"-CODE,3) From DOSDIC : Endif
Delete [GAG] Where COD=CODE : If fstat : Call ERREUR("GAG"-CODE,3) From DOSDIC : Endif
Delete [GVV] Where COD=CODE : If fstat : Call ERREUR("GVV"-CODE,3) From DOSDIC : Endif

CODE = "IASBS"
Delete [GAU] Where COD=CODE : If fstat : Call ERREUR("GAU"-CODE,3) From DOSDIC : Endif
Delete [GAD] Where COD=CODE : If fstat : Call ERREUR("GAD"-CODE,3) From DOSDIC : Endif
Delete [GAG] Where COD=CODE : If fstat : Call ERREUR("GAG"-CODE,3) From DOSDIC : Endif
Delete [GVV] Where COD=CODE : If fstat : Call ERREUR("GVV"-CODE,3) From DOSDIC : Endif


Close Local File [GAU],[GAD],[GAG],[GVV]
Return

$TEX_GAU
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".GAUTACE"   [GAU]
Call ECR_TIME(mess(81,125,1)-": ATEXTRA : GAU") From DOSSUB : # maj table
For [GAU]GAU0
 If dim([F:GAU]DES)>0
  Call MAJTEXTRA([F:GAU]DES,"GAUTACE","DESTRA",[F:GAU]COD,"") From CPTMAJ30
 Endif
 If dim([F:GAU]DESSHO)>0
  Call MAJTEXTRA([F:GAU]DESSHO,"GAUTACE","SHOTRA",[F:GAU]COD,"") From CPTMAJ30
 Endif
Next
Close Local File [GAU]
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".GAUTACED"  [GAD]
Call ECR_TIME(mess(81,125,1)-": ATEXTRA : GAD") From DOSSUB : # maj table

Raz STOP
$LOOP_GAD
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:GAD]COD='"+ACLE1+"' & [F:GAD]LINNUM>"+num$(ICLE)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:GAD]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GAD]
For [GAD]GAD0 Where evalue(CRITERE)

 If dim([F:GAD]DES)>0
  Call MAJTEXTRA([F:GAD]DES,"GAUTACED","DESTRA",[F:GAD]COD,num$([F:GAD]LINNUM)) From CPTMAJ30
 Endif
 If dim([F:GAD]DESSHO)>0
  Call MAJTEXTRA([F:GAD]DESSHO,"GAUTACED","SHOTRA",[F:GAD]COD,num$([F:GAD]LINNUM)) From CPTMAJ30
 Endif

 If dim([F:GAD]LINNUMCAR)>0 & [F:GAD]LINNUMCAR=""
  [F:GAD]LINNUMCAR = num$([F:GAD]LINNUM)
  Rewrite [GAD]
  If fstat
   GOK = 0 : Call ERREUR("GAUTACED"-[F:GAD]COD,1) From DOSDIC
  Else
   If NB>GMAXUPDTRS
    ACLE1 = [F:GAD]COD
    ICLE1 = [F:GAD]LINNUM
    STOP=1
    Break
   Endif
  Endif
 Endif
Next
Commit
If STOP
 Goto LOOP_GAD
Endif
Close Local File [GAD]
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".GRPAUTACE"   [GRA]
Call ECR_TIME(mess(81,125,1)-": ATEXTRA : GRA") From DOSSUB : # maj table
For [GRA]GRA0
 If dim([F:GRA]DES)>0
  Call MAJTEXTRA([F:GRA]DES,"GRPAUTACE","DESTRA",[F:GRA]COD,"") From CPTMAJ30
 Endif
 If dim([F:GRA]DESSHO)>0
  Call MAJTEXTRA([F:GRA]DESSHO,"GRPAUTACE","SHOTRA",[F:GRA]COD,"") From CPTMAJ30
 Endif
Next
Close Local File [GRA]
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".GVARCODPAR"  [GVA]
Local File =[F:ADS]DOSSIER+".ATEXTE"      [ATX]

Call ECR_TIME(mess(81,125,1)-": ATEXTRA : GVA") From DOSSUB : # maj table

Raz STOP
$LOOP_GVA
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:GVA]CODPAR>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

For [GVA]GVA0 Where evalue(CRITERE)

 If dim([F:GVA]INTITPAR)>0
  Read [ATX]NUMERO = MIGGLANMAJ;[F:GVA]INTITPAR
  If !fstat
   Call MAJTEXTRA([F:ATX]TEXTE,"GVARCODPAR","DESTRA",[F:GVA]CODPAR,"") From CPTMAJ30
  Endif
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GVA]CODVAR
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_GVA
Endif
Close Local File [GVA], [ATX]
##-------------------------------------------------------------------------------------------------------#

Local File =[F:ADS]DOSSIER+".GVARGAU"  [GVG]
Local File =[F:ADS]DOSSIER+".ATEXTE"   [ATX]

Call ECR_TIME(mess(81,125,1)-": ATEXTRA : GVG") From DOSSUB : # maj table

Raz STOP
$LOOP_GVG
Raz NB
If STOP
 STOP = 0
 CRITERE = "[F:GVG]CODVAR>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

For [GVG]GVG0 Where evalue(CRITERE)

 If dim([F:GVG]INTITA)>0
  Read [ATX]NUMERO = MIGGLANMAJ;[F:GVG]INTITA
  If !fstat
   Call MAJTEXTRA([F:ATX]TEXTE,"GVARGAU","DESTRA",[F:GVG]CODVAR,"") From CPTMAJ30
  Endif
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GVG]CODVAR
  STOP=1
  Break
 Endif

Next

If STOP
 Goto LOOP_GVG
Endif

Close Local File [GVG], [ATX]
Return



##-------------------------------------------------------------------------------------------------------#
## Axes sous la Fiche société avec "Saisie obligatoire... Paramètres SAIANA"
##-------------------------------------------------------------------------------------------------------#
$GDIE_CPY

Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]   # Sociétés
Local File =[F:ADS]DOSSIER+".ADOVAL"     [ADW2]


Local Char SAICCE(10)
Local Integer AXE

Trbegin [CPY]

 For [CPY]CPY0 Where CPYLEGFLG=2
  For AXE = 1 To [L]MIGGOPTCANA
   [F:CPY]DIE(AXE-1) = "AX"+num$(AXE)
   [F:CPY]DACDIE(AXE-1) = 2
   Raz SAICCE
   Read [ADW2]ADW0 = "";"";"SAIANA"+num$(AXE)
   If !fstat
    [L]SAICCE = [F:ADW2]VALEUR
   Endif
   If [L]SAICCE<>"2"
    [F:CPY]OBYDIE(AXE-1) = 1
   Else
    [F:CPY]OBYDIE(AXE-1) = 2
   Endif
  Next

  If [L]AXEIAS1<>"" & [L]AXEIAS2<>""
   [F:CPY]DIE(AXE) = [L]AXEIAS1
   [F:CPY]DACDIE(AXE) = 2
   [F:CPY]OBYDIE(AXE) = 1

   [F:CPY]DIE(AXE+1) = [L]AXEIAS2
   [F:CPY]DACDIE(AXE+1) = 2
   [F:CPY]OBYDIE(AXE+1) = 1
  Endif

  Rewrite [CPY]
  If fstat
   Call ERREUR("COMPANY"-[F:CPY]CPY,1) From DOSDIC
  Endif
 Next

Commit

Close Local File [CPY],[ADW2]
Return


##-------------------------------------------------------------------------------------------------------#
## Axes sous la Fiche site : Bug 52857
##-------------------------------------------------------------------------------------------------------#
$GDIE_FCY

Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]   # Sites

Local Integer AXE

Trbegin [FCY]

 For [FCY]FCY0
  For AXE = 1 To [L]MIGGOPTCANA
   [F:FCY]DIE(AXE-1) = "AX"+num$(AXE)
  Next

  If dim([L]AXEIAS1)>0 & dim([L]AXEIAS2)>0
   If [L]AXEIAS1<>"" & [L]AXEIAS2<>""
    [F:FCY]DIE(AXE)   = [L]AXEIAS1
    [F:FCY]DIE(AXE+1) = [L]AXEIAS2
   Endif
  Endif

  Rewrite [FCY]
  If fstat
   Call ERREUR("FACILITY"-[F:FCY]FCY,1) From DOSDIC
  Endif
 Next

Commit

Close Local File [FCY]
Return

##-------------------------------------------------------------------------------------------------------#
## Axes sous la Fiche Utilisateurs
##-------------------------------------------------------------------------------------------------------#
$GDIE_AUS

Local File =[F:ADS]DOSSIER+".AUTILIS"    [AUS]   # Utilisateurs

Local Integer AXE

Trbegin [AUS]

 For [AUS]CODUSR
  For AXE = 1 To [L]MIGGOPTCANA
   [F:AUS]DIE(AXE-1) = "AX"+num$(AXE)
  Next

  If dim([L]AXEIAS1)>0 & dim([L]AXEIAS2)>0
   If [L]AXEIAS1<>"" & [L]AXEIAS2<>""
    [F:AUS]DIE(AXE)   = [L]AXEIAS1
    [F:AUS]DIE(AXE+1) = [L]AXEIAS2
   Endif
  Endif

  Rewrite [AUS]
  If fstat
   Call ERREUR("AUTILIS"-[F:AUS]USR,1) From DOSDIC
  Endif
 Next

Commit

Close Local File [AUS]
Return


##-------------------------------------------------------------------------------------------------------#
# Migration du paramètrage...
##-------------------------------------------------------------------------------------------------------#
Subprog AOBJPARAM(DOSSIER,DOSREF)
Value Char DOSSIER , DOSREF

#-- Migration des modèles import/export
#--   Filtre sur les modèles du module COMPTABILITE et TIERS.
#--   Copie si le modèle V5 n'est pas liée à un code activité spécifique.

Call ECR_TIME(mess(81,125,1)-": AOBJEXT") From DOSSUB : # maj table
Local File =DOSREF+".AOBJEXT"   [AOE6]
Local File =DOSSIER+".AOBJEXT"  [AOE5]

Filter [AOE6] Where MODULE=2 or MODULE=3
For [AOE6]
 Read [AOE5]AOE0 = [F:AOE6]EXT
 If fstat or [F:AOE5]CODACT="" or [F:AOE5]CODACT<"X"
  Call COPOBJ(DOSREF,DOSSIER,"AOE",[F:AOE6]EXT,"","","")    From ACOPIE
 Endif
Next
Close Local File [AOE5],[AOE6]

#-- Déclencheurs statitiques.
Call COPOBJ(DOSREF,DOSSIER,"PS1","GAS","","","")    From ACOPIE

#-- Workflow : Modèles de données
Call COPOBJ(DOSREF,DOSSIER,"AWM","BUOAPP","","","") From ACOPIE
Call COPOBJ(DOSREF,DOSSIER,"AWM","BUOREV","","","") From ACOPIE

#-- Workflow : Règles d'affectation
Call COPOBJ(DOSREF,DOSSIER,"AWR","BUOAPP","","","") From ACOPIE
Call COPOBJ(DOSREF,DOSSIER,"AWR","BUOREV","","","") From ACOPIE

#-- Compteur documents Budgets opérationnels
Call COPOBJ(DOSREF,DOSSIER,"ANM","BOA","","","") From ACOPIE
Call COPOBJ(DOSREF,DOSSIER,"ANM","BRV","","","") From ACOPIE
Call COPOBJ(DOSREF,DOSSIER,"ANM","PRJ","","","") From ACOPIE
Call COPOBJ(DOSREF,DOSSIER,"ANM","ENV","","","") From ACOPIE
End

##-------------------------------------------------------------------------------------------------------#
# Initialisation de la législation
##-------------------------------------------------------------------------------------------------------#
Subprog INILEG_TRC(DOSSIER,LEGREF)
Value Char DOSSIER , LEGREF

Local Char TABLE(GLONATB)
TABLE="GACM"        : Gosub INIT_LEG   # Modèle comptable
TABLE="GLED"        : Gosub INIT_LEG   # Référentiels
TABLE="GACCCLS"     : Gosub INIT_LEG   # Classes de comptes
TABLE="GCOA"        : Gosub INIT_LEG   # Code plan
#TABLE="GCACCOA"     : Gosub INIT_LEG   # Transactions de saisie code compta
TABLE="GTYPACCENT"  : Gosub INIT_LEG   # Types de pièces
TABLE="RITENZIONE"  : Gosub INIT_LEG   # Retenues

End


##-------------------------------------------------------------------------------------------------------#
# Initialisation de la législation
##-------------------------------------------------------------------------------------------------------#
Subprog INILEG_CPT(DOSSIER,LEGREF)
Value Char DOSSIER , LEGREF

Local Char TABLE(GLONATB)
TABLE="GDIAENTRY"   : Gosub INIT_LEG   # Transactions de saisie de pièces
TABLE="GJOURNAL"    : Gosub INIT_LEG   # Journaux
TABLE="TABBUDTYP"   : Gosub INIT_LEG   # Transactions budégtaires
TABLE="GACCDENCOD"  : Gosub INIT_LEG   # Destinations comptables
TABLE="TABPAYTYP"   : Gosub INIT_LEG   # Transactions de règlements
TABLE="TXSA"        : Gosub INIT_LEG   # Paramétrage Tableau de bord
TABLE="TABFILBAN"   : Gosub INIT_LEG   # Paramétrage fichiers bancaires
TABLE="TABFILTDS"   : Gosub INIT_LEG   # Paramétrage fichiers TDS
TABLE="FILTDS"      : Gosub INIT_LEG   # Structure fichier DADS-U
End

$INIT_LEG
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0

 Local File =DOSSIER+"."+TABLE [ALEG]
 Trbegin [ALEG]
  GOK = 1
  Update [ALEG] With LEG=LEGREF
  If fstat
   GOK = 0 : Call ERREUR(TABLE,2) From DOSDIC
  Else
   Call ECR_TIME(mess(81,125,1)-":"-TABLE-"(LEG)") From DOSSUB : # maj table
  Endif

 If GOK
  Commit
 Else
  Rollback
 Endif
 Close Local File [ALEG]

Endif
Return


##-------------------------------------------------------------------------------------------------------#
# Législation sous TABFILBAN
##-------------------------------------------------------------------------------------------------------#
# 1ère partie sous INILEG_CPT
# 2ème partie, RAZ de LEG selon condition
Subprog INILEG_TFB(DOSSIER,DOSCOP)
Value Char DOSSIER
Value Char DOSCOP

If filinfo(filpath("FIL","TABFILBAN","fde",DOSSIER),0)<=0 : End : Endif
If filinfo(filpath("FIL","TABFILBAN","fde",DOSCOP),0)<=0 : End : Endif

Local File =DOSSIER+".TABFILBAN"   [TFB]
Local File =DOSCOP+".TABFILBAN"  [TFBR]

#Fiche 91332
Local Integer WVERSION
Local File =[L]DOSCOP+".ADOVAL" [TADW]
Read [TADW]ADW0 = "";"";"RELEASE"
If fstat=0
 WVERSION  = val( [F:TADW]VALEUR )
Endif

Call ECR_TIME(mess(81,125,1)-": TABFILBAN (release"-num$(WVERSION)+")") From DOSSUB : # maj table

If WVERSION<40

 Trbegin [TFB]
  For [TFB]
   Read [TFBR]TFB0 = [F:TFB]COD;[F:TFB]BAN;[F:TFB]RECTYP;[F:TFB]ORDNUM;[F:TFB]NUM
   If !fstat & [F:TFBR]LEG=""
    [F:TFB]LEG = ""
    Rewrite [TFB]
    If fstat
     Call ERREUR("TABFILBAN"-[F:TFB]COD-[F:TFB]BAN-num$([F:TFB]RECTYP)-num$([F:TFB]ORDNUM)-num$([F:TFB]NUM),1) From DOSDIC
    Endif
   Endif
  Next
 Commit

Else

 Trbegin [TFB]
  For [TFB] Where LEG<>""
   Read [TFBR]TFB0 = [F:TFB]COD;[F:TFB]BAN;[F:TFB]RECTYP;[F:TFB]ORDNUM;"";[F:TFB]NUM
   If !fstat
    Update [TFB] Where COD=[F:TFBR]COD & BAN=[F:TFBR]BAN & RECTYP=[F:TFBR]RECTYP & ORDNUM=[F:TFBR]ORDNUM & NUM=[F:TFBR]NUM
&                With LEG=""
    If fstat
     Call ERREUR("TABFILBAN"-[F:TFB]COD-[F:TFB]BAN-num$([F:TFB]RECTYP)-num$([F:TFB]ORDNUM)-num$([F:TFB]NUM),1) From DOSDIC
    Endif
   Endif
  Next
 Commit


Endif

Close Local File [TFB], [TFBR], [TADW]
End
