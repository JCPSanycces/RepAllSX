#<AdxTL>@(#)7.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Gosub INIVAR From CPTMAJ30
#Call ACPTMAJ30 From CPTMAJ30
#Call ATRSMAJ30 From CPTMAJ30
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################################################
# ... MAJ30 : Mises à jour à effectuer lors du passage à la version 6
##########################################################################################################

##-------------------------------------------------------------------------------------------------------#
## Textes traduisibles...  Libellé à transférer
##-------------------------------------------------------------------------------------------------------#
$NEWATX
Gosub CSFPARH              #   Paramétrages extractions
Gosub GACCFIX              #   Abonnement
Gosub TABBUDTYP            #   Transactions budgets
Gosub CADISTMP             #   Répartitons temporelles
Gosub GDUDSCR              #   Ecrans gestion échéances
Gosub GBAGSCR              #   Ecrans gestion situation tiers
Gosub FUPGRP               #   Groupes de relances
Gosub GRPCUR               #   Groupes de devises
Gosub TABPAYTYP            #   Transactions de règlement
Return

$CSFPARH
If filinfo(filpath("FIL","CSFPARH","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".CSFPARH"  [CWH]
Call ECR_TIME(mess(81,125,1)-": CSFPARH") From DOSSUB : # maj table
Trbegin [CWH]
For [CWH]CWH0
 If dim([F:CWH]DES)>0
  Call MAJTEXTRA([F:CWH]DES,"CSFPARH","DESTRA",[F:CWH]CODANY,"") From CPTMAJ30
 Endif
 If dim([F:CWH]DESSHO)>0
  Call MAJTEXTRA([F:CWH]DESSHO,"CSFPARH","SHOTRA",[F:CWH]CODANY,"") From CPTMAJ30
 Endif
 If dim([F:CWH]COA)>0 : [F:CWH]COA = PLGEN : Endif
 Rewrite [CWH]
 If fstat
  Call ERREUR("CSFPARH"-[F:CWH]CODANY,1) From DOSDIC
 Endif
Next
Commit
Close Local File [CWH]
Return

$GACCFIX
If filinfo(filpath("FIL","GACCFIX","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".GACCFIX"  [GAF]
Call ECR_TIME(mess(81,125,1)-": GACCFIX") From DOSSUB : # maj table
For [GAF]GAF0
 If dim([F:GAF]DES)>0
  Call MAJTEXTRA([F:GAF]DES,"GACCFIX","DESTRA",[F:GAF]COD,"") From CPTMAJ30
 Endif
 If dim([F:GAF]DESSHO)>0
  Call MAJTEXTRA([F:GAF]DESSHO,"GACCFIX","SHOTRA",[F:GAF]COD,"") From CPTMAJ30
 Endif
 #->KC Vinci
 # Si Flag Actif existe le mettre à Oui par défaut
 If dim([F:GAF]ENAFLG)>0
  [F:GAF]ENAFLG=2
 Endif
 #<-KC Vinci
 Rewrite [GAF]
Next
Close Local File [GAF]
Return

$TABBUDTYP
If filinfo(filpath("FIL","TABBUDTYP","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".TABBUDTYP"  [TBU]
Call ECR_TIME(mess(81,125,1)-": TABBUDTYP") From DOSSUB : # maj table
For [TBU]TBU0
 If dim([F:TBU]DES)>0
  Call MAJTEXTRA([F:TBU]DES,"TABBUDTYP","DESTRA",[F:TBU]BUDTYP,"0") From CPTMAJ30
 Endif
 If dim([F:TBU]DESSHO)>0
  Call MAJTEXTRA([F:TBU]DESSHO,"TABBUDTYP","SHOTRA",[F:TBU]BUDTYP,"0") From CPTMAJ30
 Endif
Next
Close Local File [TBU]
Return

$CADISTMP
If filinfo(filpath("FIL","CADISTMP","fde",[F:ADS]DOSSIER),0)<=0 : Return : Endif
Local File =[F:ADS]DOSSIER+".CADISTMP"  [DTP]
Call ECR_TIME(mess(81,125,1)-": CADISTMP") From DOSSUB : # maj table
For [DTP]DTP0
