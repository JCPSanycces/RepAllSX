#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGSPA 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:32"
A_USER  = "DOC"
A_STAMP = "20181109230332"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGSPA [CLSPA]
Gosub HORODAT
Local Inpbox "CPYLEGSPA" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLSPA] As [SIM_]
Grizo [CLSPA]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLSPA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=37 : X2(0)=76 : Y1(0)=12 : Y2(0)=17
Return

$ON_SPABPCTSD
Onevent BEFORE_AREA Gosub AV_SPABPCTSD From W1CPYLEGSPA
Return

$AV_SPABPCTSD
If [M]FMTCUR<>""
 Chgfmt [M]SPABPCTSD(indice) With [M]FMTCUR
Else
 Chgfmt [M]SPABPCTSD(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_CUR1
Return

$ON_SPABPSTSD
Onevent BEFORE_AREA Gosub AV_SPABPSTSD From W1CPYLEGSPA
Return

$AV_SPABPSTSD
If [M]FMTCUR<>""
 Chgfmt [M]SPABPSTSD(indice) With [M]FMTCUR
Else
 Chgfmt [M]SPABPSTSD(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_CUR2
Return

$ON_SPAYEATSD
Onevent BEFORE_AREA Gosub AV_SPAYEATSD From W1CPYLEGSPA
Return

$AV_SPAYEATSD
If [M]FMTCUR<>""
 Chgfmt [M]SPAYEATSD(indice) With [M]FMTCUR
Else
 Chgfmt [M]SPAYEATSD(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_CUR3
Return

$ON_FMTCUR
Onevent INIT_AREA Call D_FMTCUR(zc) From W1CPYLEGSPA
Return

Subprog D_FMTCUR(VALEUR)
Variable Char    VALEUR()
If varinit([M]FMTCUR,indice)=0
 VALEUR = "N+:13.2"
Endif
Gosub _AFF
End

$CHG_STY
Return


