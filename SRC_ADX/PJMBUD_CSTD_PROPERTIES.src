#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUD
###################################################################################################
$PBUCOD
  # Issue X3-52534 - 2017-08-17 by FGR
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUCOD_CONTROL
  Endcase
Return

$PBUCOD_CONTROL
  # Issue X3-52534 - 2017-08-17 by FGR
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PBUCOD <> this.snapshot.PBUCOD Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("PBUCOD", mess(18,9804,1), [V]CST_AERROR))
    Endif
  Endif
Return

###################################################################################################
$PBUFCY
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUFCY_CONTROL     # Issue X3-6100/119458 - 2016-10-27 by FGR :
    When "PROPAGATE" : Gosub PBUFCY_PROPAGATE
  Endcase
Return

$PBUFCY_CONTROL
Local Char SFCYFINBUD(GLONFCY)

  # Issue X3-6100/119458 - 2016-10-27 by FGR : BEGIN the budget site have to be a financial site
  SFCYFINBUD = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.PBUFCY, "FINRSPFCY")
  If SFCYFINBUD <> this.PBUFCY Then
    [L]ASTATUS = fmet this.SETERROR("PBUFCY", func AFNC.MES1(mess(440,2260,1), this.PBUCOD), [V]CST_AERROR)
  Endif
  # Issue X3-6100/119458 - 2016-10-27 by FGR : END
Return

$PBUFCY_PROPAGATE
Local Integer NI

  this.PIMPL.FCY = this.PBUFCY
  # --------------------------------------------------
  For NI = 1 To maxtab(this.BUDLIG)
    If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      this.BUDLIG(NI).PLBFCY = this.PBUFCY
    Endif
  Next NI
Return

###################################################################################################
$PBUSTATE
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUSTATE_CONTROL
    When "PROPAGATE" : Gosub PBUSTATE_PROPAGATE
  Endcase
Return

$PBUSTATE_CONTROL
  # ----------------------
  If this.PBUSTATE <> 1 and this.PBUSTATE <> 2 and this.PBUSTATE <> 3 and this.PBUSTATE <> 4 and this.PBUSTATE <> 9 Then
    [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1), [V]CST_AERROR)
  Endif
  # ----------------------
  Case this.TCHACTION
    When "OPEN"
      # This is not an action
      If this.PBUSTATE <> 2 Then
        [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1) - "(" + mess(this.PBUSTATE,2251,1) + ")", [V]CST_AERROR)
      Endif
    When "DELIVERY"
      If this.PBUSTATE <> 3 Then
        [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1) - "(" + mess(this.PBUSTATE,2251,1) + ")", [V]CST_AERROR)
      Endif
    When "CLOSING"
      If this.PBUSTATE <> 4 Then
        [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1) - "(" + mess(this.PBUSTATE,2251,1) + ")", [V]CST_AERROR)
      Endif
    When "SUSPENSION"
      If this.PBUSTATE <> 9 Then
        [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1) - "(" + mess(this.PBUSTATE,2251,1) + ")", [V]CST_AERROR)
      Endif
    When "REACTIVATE"
      # TODO : FLORENT ICI : voir le controle à ce niveau
    When Default
      If this.ASTALIN = [V]CST_ANEW Then
        If this.TCHOPPSTATE = 1 Then
          # On a not launch project, the budget have to have "New" as status
          If this.PBUSTATE <> 1 Then
            [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Else
          # In others cases, the budget have to have "Open" as status
          If this.PBUSTATE <> 2 Then
            [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(18,9804,1), [V]CST_AERROR)
          Endif
        Endif
      Elsif this.ASTALIN = [V]CST_AUPD Then
        If this.PBUSTATE <> this.snapshot.PBUSTATE Then
          [L]ASTATUS = fmet this.SETERROR("PBUSTATE", mess(186,2260,1) - "(" + mess(this.PBUSTATE,2251,1) + ")", [V]CST_AERROR)
        Endif
      Endif
  Endcase
  # ----------------------
Return

$PBUSTATE_PROPAGATE
Local Integer NI

  # ----------------------
  Case this.TCHACTION
    When "CLOSING"
      For NI = 1 To maxtab(this.BUDLIG)
        If this.BUDLIG(NI) <> null and find(this.BUDLIG(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.BUDLIG(NI).PLBFLGREM = [V]CST_ANO Then
            If this.BUDLIG(NI).PLBCOMTEX <> AVOID.ACHAR Then
              this.BUDLIG(NI).PLBCOMTEX += chr$(10) + chr$(13) + string$("-",40) + chr$(10) + chr$(13)
            Endif
            # TODO FGR voir pour mettre les format$ qui vont bien pour les date, quantité et montant
            this.BUDLIG(NI).PLBCOMTEX += func AFNC.MES3(mess(274,2260,1), num$(this.PBUDATS), num$(this.BUDLIG(NI).PLBQTYREM), num$(this.BUDLIG(NI).PLBAMTREM))
          Endif
          this.BUDLIG(NI).PLBQTYREM = 0
          this.BUDLIG(NI).PLBAMTREM = 0
        Endif
      Next NI
    When "REACTIVATE"
      If this.snapshot.PBUSTATE = 4 Then
        Raz this.PBUDATS
      Elsif this.snapshot.PBUSTATE = 9 Then
        Raz this.PBUDATH
      Endif
    When Default
  Endcase
  # ----------------------
  If this.ASTALIN = [V]CST_ANEW Then
    this.PIMPL.PBUSTATE = this.PBUSTATE
  Else
    this.PIMPL.TCHACTION = "STATUS"
    this.PIMPL.PBUSTATE = this.PBUSTATE
  Endif
  # ----------------------
Return

###################################################################################################
$PBUELE
  Case [L]ARULE
    When "INIT"      : Gosub PBUELE_INIT
  Endcase
Return

$PBUELE_INIT
  this.PBUELE = [V]CST_AYES            # By default a budget is elementary
Return

###################################################################################################
$PBUIMP
  Case [L]ARULE
    When "INIT"      : Gosub PBUIMP_INIT
  Endcase
Return

$PBUIMP_INIT
  this.PBUIMP = [V]CST_AYES            # By default a budget is chargeable
Return

###################################################################################################
$PBUDATS
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUDATS_CONTROL
  Endcase
Return

$PBUDATS_CONTROL
  If this.TCHACTION <> "CLOSING" and this.TCHACTION <> "REACTIVATE" Then
    If this.PBUDATS <> this.snapshot.PBUDATS Then
      [L]ASTATUS = fmet this.SETERROR("PBUDATS", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$PBUDATH
  Case [L]ARULE
    When "CONTROL"   : Gosub PBUDATH_CONTROL
  Endcase
Return

$PBUDATH_CONTROL
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "REACTIVATE" Then
    If this.PBUDATH <> this.snapshot.PBUDATH Then
      [L]ASTATUS = fmet this.SETERROR("PBUDATH", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
Return

###################################################################################################
$KEYCONCAT
  # Issue X3-29531 - 2017-04-21 by FGR
  Case [L]ARULE
    When "GET"     : Gosub KEYCONCAT_GET
  Endcase
Return

$KEYCONCAT_GET
  # Issue X3-29531 - 2017-04-21 by FGR
  this.KEYCONCAT = func PIMPL_CSTD_PROGS.GET_PIMNUM_BUDGET(this.ACTX, this.OPPNUM, this.PBUCOD)
Return

###################################################################################################
$ORIPBU
  # Issue X3-43754 - 2017-07-03 by EUHAV
  Case [L]ARULE
    When "CONTROL" : Gosub ORIPBU_CONTROL
  Endcase
Return

$ORIPBU_CONTROL
Local Char SMESSAGE(250)
Local Integer IPIMTYP

  # Issue X3-43754 - 2017-07-03 by EUHAV
  If this.TCHACTION <> "COPY" Then
    If this.ORIPBU <> this.snapshot.ORIPBU Then
      [L]ASTATUS = fmet this.SETERROR("ORIPBU", mess(18,9804,1), [V]CST_AERROR)
    Endif
  Endif
  If this.ORIPBU <> AVOID.ACHAR Then
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(this.ACTX, this.ORIPBU, AVOID.ACHAR, AVOID.ACHAR, SMESSAGE)
    If SMESSAGE <> AVOID.ACHAR Then
      [L]ASTATUS = fmet this.SETERROR("ORIPBU", SMESSAGE, [V]CST_AERROR)
    Else
      If IPIMTYP <> 4 Then
        [L]ASTATUS = fmet this.SETERROR("ORIPBU", func AFNC.MES1(mess(450,2260,1), this.ORIPBU), [V]CST_AERROR)
      Endif
    Endif
  Endif
Return

