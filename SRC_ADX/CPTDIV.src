#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################################################################
#-------------------------------------Comptabilité : Actions diverses---------------------------------------------------------------#
#
# LEDTYP_CHOICE(CPY,OPTION)
#    => Définit la liste des types référentiels en fonction de l'option passée en paramètre
#
# LECLEDMAIN(CAS,SOCIETE,TYPLED)
#    => Renvoie le type référentiel principal (géné si CAS=1, ana si CAS=2) de la société
#       passé en paramètres
#
# LECLED(SOCIETE,TYPLED,CODLED,DEVLED)
#    => Renvoie le code et devise référentiel associés au type de référentiel et société passés en paramètres
#
# LECPLAN(SOCIETE,TYPLED,PLAN)
#    => Recherche le code plan associé au type de référentiel et à la société passés en paramètres
#
# LECMAINPLAN(CAS,SOCIETE,PLAN)
#    => Renvoie le code plan associé au référentiel principal général (si CAS=1)
#       ou principal analytique (si CAS=2) de la société passé en paramètre
#
# INDLED(LED,DIE,INDL,INDD)
#    => Renvoie la position du référentiel dans GLED et éventuellement la position de l'axe si celui ci est passé en paramètre
#
# SETCUR(CAS,SOCIETE,DEVISE)
#    => Devise du référentiel principal général ou analytique d'une société
#
# SETCURFLD(DEVISE)
#    => Renvoie la devise 'commune' à utiliser
#
# SETPLAN(SOCIETE,NBPLAN,PLAN,REFTYP,NBAXE,AXE,OBLIG)
#    => Renvoie les plans comptables et les axes flagués 'saisis en amont' d'une société
#
# SETPLAN2(MODELE,NBPLAN,PLAN,REFTYP,NBAXE,AXE,OBLIG)
#    => Renvoie les plans comptables et TOUS les axes d'un modèle comptable
#
# SETPLAN3(SOCIETE,NBPLAN,PLAN,REFTYP)
#    => Renvoie les plans comptables de tous les référentiels non automatiques d'une société
#
# SETPLANAXE(SOCIETE,NBREF,REFTYP,NBPLAN,PLAN,NBAXE,AXE,OBLIG)
#    => Renvoie les plans comptables et les axes pour une société et une liste de type de référentiels
#
# SETPLANAXE2(SOCIETE,NBREF,REFTYP,NBPLAN,PLAN,NBAXE,AXE,OBLIG)
#    => Renvoie les plans comptables et TOUS les axes pour une société et une liste de type de référentiels
#       même ceux saisis en amont.
#
# SETMAINREF(SOCIETE,TYPLEDGEN,TYPLEDANA)
#    => Renvoie le type de référentiel principal général et analytique d'une société (ou d'un site)
#
# SETREF(SOCIETE,NBLED,CODLED)
#    => Renvoie les codes référentiels d'une société (ou d'un site)
#
# SETGCM(SOCIETE,MODELE)
#    => Renvoie le modèle comptable d'une société (ou d'un site)
#
# GETNUMAXE(SOCIETE,LEDTYP,AXE,NUMAXE)
#    => donne le numéro de l'axe choisi dans le référentiel pour une société et un type de référentiel
#
# GETLSTAXE(SOCIETE,LEDTYP,NBRDIE,LSTDIE)
#    => Nombre d'axe et Liste des codes axes d'un référentiel à partir d'une société et du type de référentiel
#
# RECH_ACC(TYPACC,SOCIETE,TTYPLED,NBTYPLED,TPLAN,TCOMPTE,PLAN,COMPTE)
#    => Recherche du compte général ou analytique (selon TYPACC) dans un tableau de comptes
#
# RECH_ACCMIS(SOC,LEDTYP,ACCDIVTYP,COMPTE)
#    => Renvoie le compte d'un type de compte divers (menu 2649) pour un type de référentiel et une société passés en paramètre
#
# SETFLGDEV(DEV,SOC,DAT)
#    => Position des devises par rapport à l'euro (in ou out)
#
# SETLEDTYPLIST(SOCIETE,PLAN,NBRLEDTYP,LEDTYPLIST)
#    => Renvoie pour une société et un plan de compte, la liste des types référentiels utilisés
#
# GETTYPLEDVLDAUT(SOCIETE,LEDTYP,TYPLEDVLDAUT,NBRVLDAUT)
#    => Renvoie pour une société et type de référentiel, la liste et le nombre de types référentiels en validation auto pour ce type
#
# LSTLEDTYP(SOCIETE,OPTION,TLEDTYP,NBLED)
#    => Permet de renvoyer la liste des types référentiels utilisés pour une société donnée
#
# LSTGCM(NBMOD,TMODELE)
#    => Liste des modèles comptables utilisés (=définis pour au moins une société)
#
# SETDIECCELED(TBDIE,TBCCE,REFERENTIEL,TBDIELED,TBCCELED)
#    => A partir d'une liste d'Axes/Sections, on retourne les Axes/Sections gérés sur le référentiel passé en paramètre
#
# SETCCEAXE(SOCIETE,LEDTYP,TBDIE,TBCCE,TBDIE2,TBCCE2)
#    => Renvoie un tableau de code axes et sections d'un référentiel passé en paramètres à partir d'un tableau d'axes
#       et sections rattachés à X référentiels (Ex d'utilisation : la création automatique d'engagement à partir d'une commande,
#       la commande étant multi-référentiels alors que l'engagement est généré uniquement sur le référentiel général principal)
#
# SAI_AMONT(SOCIETE,NBREF,REFTYP,AXE,SAI_AMONT)
#    => Permet de savoir si l'axe "AXE" passé en paramètre est flagué "saisie en amont"
#       sur au moins un des référentiels gérés. Si c'est le cas, l'axe sera saisissable dans les
#       document amonts (factures, règlement)). Dans le cas contraire, l'axe sera initialisé et affiché
#       mais non saisissable
#
# LEDTYPAUT(SOCIETE,LEDTYP,FLGAUT)
#    => Définit si le type de référentiel passé en paramètre est flagué 'automatique'
#
# ORILEDTYP(SOCIETE,LEDTYPAUT,LEDTYPORI)
#    => Si le type de référentiel passé en paramètre est flagué 'automatique' => Renvoie le type de référentiel origine (non automatique)
#
# SUIVI_ANA(SOCIETE,TTYPLED,NBTYPLED,TPLAN,TCOMPTE,TDIE,NBDIE,SUIVI)
#    => Renvoie 1 si au moins un compte (parmi le tableau des comptes passés en paramètres) a un suivi
#       sur au moins un des axes passés en paramètres.
#
# GETTYPSOCSITGRP(SOCSITGRP,REPONSE)
#    => Retourne s'il s'agit d'une Société, d'un site ou  d'un grp
#       0:inexistant, 1:société juridique, 2:site, 3:grp de site, 4:grp de sociétés
#
# NBFCY(SOC,NBSIT)
#    => Renvoie le nombre de sites financiers d'une société
#
# NBSAC(PLAN,NBSAC)
#    => Renvoie le nombre de collectifs définis dans un plan de comptes
#
# FLGDEM(SOCIETE,FLGDEM)
#    => Permet de savoir si la société pointe sur un modèle comptable avec 'Double Entry Method' (FLGDEM=2 dans ce cas)
#
# LEDTYPDEM(SOCIETE,LSTTYPLED)
#    => Renvoie la liste des types référentiels flagués 'Double Entry Method'
#
# GCMDEM(TABGCM,NBGCM)
#    => Renvoie la liste des modèles comptables flagués 'Double Entry Method'
#
# CPYDEM(CPYDEM,LEDTYP)
#    => Renvoie la première société trouvée et le type référentiel flagués 'Double Entry Method'
#
# COADEM(TABCOA,NBCOA)
#    => Renvoie la liste des codes plans associés à un modèle comptable flagué 'Double Entry Method'
#
# LEGCPY(TCPY,NBLEG,LSTLEG)
#    => Renvoie le nombre et la liste des législations d'un ensemble de sociétés
#####################################################################################################################

#####################################################################################################################################

Subprog LECLEDMAIN(CAS,SOCIETE,TYPLED)
Value    Integer  CAS       : # Si 1:général si 2:analytique si 3:IAS
Value    Char     SOCIETE() : # Société
Variable Integer  TYPLED    : # Type référentiel
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
Local Char MODELE(GLONGCM)
Call SETGCM(SOCIETE,MODELE)
Call LEC_GCM(MODELE) From CPTLEC
Case CAS
 When 1 : TYPLED = [F:GCM]GENLEDTYP
 When 2 : TYPLED = [F:GCM]ANALEDTYP
 When 3 : TYPLED = [F:GCM]IASLEDTYP
Endcase
End

Subprog LECLED(SOCIETE,TYPLED,CODLED,DEVLED)
## Recherche du code référentiel et devise référentiel associé au type de référentiel
## et à la société passés en paramètres
Value    Char     SOCIETE() : # Société
Value    Integer  TYPLED    : # Type référentiel
Variable Char     CODLED()  : # Code référentiel
Variable Char     DEVLED()  : # Devise référentiel
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
Local Integer ISOC, IGCM
ISOC = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC : End : Endif
IGCM = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
Endif
If !IGCM : End : Endif
Call LEC_GCM(GGCMSOC(ISOC)) From CPTLEC
If !fstat
 If TYPLED<>0
  Case TYPLED
   When 1  : CODLED = [F:GCM]LED(0) : DEVLED = [F:GCM]CUR(0)
   When 2  : CODLED = [F:GCM]LED(1) : DEVLED = [F:GCM]CUR(1)
   When 3  : CODLED = [F:GCM]LED(2) : DEVLED = [F:GCM]CUR(2)
   When 4  : CODLED = [F:GCM]LED(3) : DEVLED = [F:GCM]CUR(3)
   When 5  : CODLED = [F:GCM]LED(4) : DEVLED = [F:GCM]CUR(4)
   When 6  : CODLED = [F:GCM]LED(5) : DEVLED = [F:GCM]CUR(5)
   When 7  : CODLED = [F:GCM]LED(6) : DEVLED = [F:GCM]CUR(6)
   When 8  : CODLED = [F:GCM]LED(7) : DEVLED = [F:GCM]CUR(7)
   When 9  : CODLED = [F:GCM]LED(8) : DEVLED = [F:GCM]CUR(8)
   When 10 : CODLED = [F:GCM]LED(9) : DEVLED = [F:GCM]CUR(9)
  Endcase
 Endif
Endif
End

Funprog LECCURLED(SOCIETE,TYPLED)
## Recherche du code référentiel et devise référentiel associé au type de référentiel
## et à la société passés en paramètres
Value    Char     SOCIETE() : # Société
Value    Integer  TYPLED    : # Type référentiel
Local Char     CODLED(GLONLED)  : # Code référentiel
Local Char     DEVLED(GLONCUR)  : # Devise référentiel
Call LECLED(SOCIETE, TYPLED,CODLED,DEVLED)
End DEVLED

Subprog LECPLAN(SOCIETE,TYPLED,PLAN)
## Recherche le code plan associé au type de référentiel et à la société passés en paramètres
Value    Char     SOCIETE() : # Société
Value    Integer  TYPLED    : # Type référentiel
Variable Char     PLAN()    : # Code référentiel
Local Char    CODLED(GLONLED)
Local Char    DEVLED(GLONCUR)
Local Integer ILED
Call LECLED(SOCIETE,TYPLED,CODLED,DEVLED)
ILED = find(CODLED,GLED(1..GLEDNBR))
If !ILED
 Call GLOBVAR From SETGLBLED
 ILED = find(CODLED,GLED(1..GLEDNBR))
Endif
If ILED
 PLAN = GLEDCOA(ILED)
Endif
End

Subprog LECMAINPLAN(CAS,SOCIETE,PLAN)
## Renvoie le code plan associé au référentiel principal général (si CAS=1)
## ou principal analytique (si CAS=2) de la société passé en paramètre
Value    Integer  CAS       : # Si 1:général si 2:analytique
Value    Char     SOCIETE() : # Société
Variable Char     PLAN()    : # Code référentiel
Local Libelle TYPGEN, TYPANA
Call SETMAINREF(SOCIETE,TYPGEN,TYPANA) From CPTDIV
Case CAS
 When 1
  Call LECPLAN(SOCIETE,TYPGEN,PLAN) From CPTDIV
 When 2
  Call LECPLAN(SOCIETE,TYPANA,PLAN) From CPTDIV
Endcase
End

Subprog INDLED(LED,DIE,INDL,INDD)
## Recherche indice du Référentiel sous GLED avec le Référentiel passé en paramètre
## et recherche l'indice de l'Axe (1 à 9) sous le référentiel avec l'Axe passé en paramètre
Value    Char     LED()   : # Référentiel
Value    Char     DIE ()  : # Axe
Variable Integer  INDL()  : # Indice du référentiel GLED(x)
Variable Integer  INDD()  : # Indice de l'axe sous le référenciel (GDIEx)
Local    Char     LEDDIE(GLONDIE)
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif
Raz INDD
INDL = find(LED,GLED(1..GLEDNBR))
If !INDL
 Call GLOBVAR From SETGLBLED
 INDL = find(LED,GLED(1..GLEDNBR))
Endif
If !INDL  : End : Endif
If DIE="" : End : Endif
If GLEDDIENBR(INDL)=0 : End : Endif
For INDD=1 To GLEDDIENBR(INDL)
 If DIE=evalue("GDIE"+num$(INDD)+"("+num$(INDL)+")") : Break : Endif
Next
If INDD>GLEDDIENBR(INDL) : Raz INDD : End: Endif
End

########################################################################
## Devise du référentiel principal général ou analytique d'une société
########################################################################
Subprog SETCUR(CAS,SOCIETE,DEVISE)
Value    Integer CAS          # 1:réf. principal général   2: réf. principal analytique
Value    Char    SOCIETE()
Variable Char    DEVISE()
Local Char CODLED(GLONLED)
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Case CAS
 When 1
  Call LECLED(SOCIETE,GTYPGEN,CODLED,DEVISE) From CPTDIV
 When 2
  Call LECLED(SOCIETE,GTYPANA,CODLED,DEVISE) From CPTDIV
Endcase
End

#########################################################################################################
# Renvoie la devise à utiliser en fonction des sociétés du dossier : si toutes les
# sociétés sont associées à la même devise pour le type référentiel principal, on renvoie cette devise.
# sinon, on renvoie la devise contenue dans GCURSHR
# Ce sous-programme peut être utilisé lorsque l'on a besoin de restituer des montants dans une trace
# par exemple et permet d'afficher ces montants en devise locale plutôt qu'en devise 'zone commune'
# Par contre, les montants stockés au niveau du dossier (plafond, etc...) doivent tjs être exprimés
# en devise GCURSHR
#########################################################################################################
Subprog SETCURFLD(DEVISE)
Variable Char    DEVISE()
If !clalev([F:GCM]) : Local File GACM     [GCM] : Endif
Local Integer NBMOD, MODELE
Local Char    TMODELE(GLONGCM)(1..max(1,nbrecord([F:GCM])))
Call LSTGCM(NBMOD,TMODELE)
For MODELE=1 To NBMOD
 Call LEC_GCM(TMODELE(MODELE)) From CPTLEC
 If MODELE = 1
  DEVISE = [F:GCM]CUR([F:GCM]GENLEDTYP-1)
 Elsif DEVISE<>[F:GCM]CUR
  DEVISE = GCURSHR : Break
 Endif
Next
End

#########################################################
## Plans de comptes et axes à saisir pour une société
#########################################################
Subprog SETPLAN(SOCIETE,NBPLAN,PLAN,REFTYP,NBAXE,AXE,OBLIG)
Value    Char    SOCIETE        : # Société ou site
Variable Integer NBPLAN         : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)    : # Plans (COA) (en 1:général principal, si <>1, en 2:analytique principal)
Variable Integer REFTYP(1..)    : # Types référentiels (en 1:général principal, si <>1, en 2:analytique principal)
Variable Integer NBAXE          : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)     : # Axes (DIE)
Variable Integer OBLIG(1..)     : # Obligatoire (O/N)
Local Char    MODELE(GLONGCM)
Local Integer SAI_AMONT : SAI_AMONT = 1
Local Integer INI_AXE : INI_AXE = 1
Call SETGCM(SOCIETE,MODELE) From CPTDIV
Gosub SET_PLAN
End

$SET_PLAN
Local Integer IGCM , ILED , IREF , IDIE , NBREF
Local Char    REFER(GLONLED)(1..max(1,len(mess(0,2644,1))))
Local Char    CODAXE(GLONDIE) , REF(GLONLED)
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
Raz NBPLAN
If INI_AXE : Raz NBAXE : Endif
If dim([L]SOCIETE)>0 & SOCIETE<>""
 Call LEC_CPY(SOCIETE) From CPTLEC
Else
 Call LEC_CPY(GSOCIETE) From CPTLEC
Endif
Call LEC_GCM(MODELE) From CPTLEC
IGCM   = find(MODELE,GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM   = find(MODELE,GGCM(1..GGCMNBR))
Endif
If IGCM
 NBREF    = 1
 REFTYP(NBREF) = GLEDTYPGEN(IGCM)
 REFER(NBREF)  = GLEDGEN(IGCM)
 If GLEDTYPGEN(IGCM)<>GLEDTYPANA(IGCM)
  NBREF+=1
  REFTYP(NBREF) = GLEDTYPANA(IGCM)
  REFER(NBREF) = GLEDANA(IGCM)
 Endif
 For IREF=1 To NBREF
  NBPLAN += 1
  ILED = find(REFER(IREF),GLED(1..GLEDNBR))
  If !ILED
   Call GLOBVAR From SETGLBLED
   ILED = find(REFER(IREF),GLED(1..GLEDNBR))
  Endif
  If ILED
   PLAN(IREF) = GLEDCOA(ILED)
   Gosub AXES
  Endif
 Next IREF
 For IREF=1 To len(mess(0,2644,1))
  If !find(IREF,GLEDTYPGEN(IGCM),GLEDTYPANA(IGCM))
   REF = evalue("GLED"+num$(IREF)+"("+num$(IGCM)+")")
   If REF<>"" & !find(REF,REFER(1..NBREF))
    If [F:GCM]CFMAUT(IREF-1)<>2
     NBREF += 1
     REFER(NBREF) = REF
     ILED = find(REF,GLED(1..GLEDNBR))
     If !ILED
      Call GLOBVAR From SETGLBLED
      ILED = find(REF,GLED(1..GLEDNBR))
     Endif
     If ILED
      NBPLAN      += 1
      PLAN(NBPLAN) = GLEDCOA(ILED)
      Gosub AXES
     Endif
     REFTYP(NBPLAN) = IREF
    Endif
   Endif
  Endif
 Next IREF
Endif
Return

$AXES
If !INI_AXE : Return : Endif
If NBAXE>=GOPTCANA : Return : Endif
Local Integer VU
Local Integer SAIAXE
For IDIE=1 To GLEDDIENBR(ILED)
 CODAXE = evalue("GDIE"+num$(IDIE)+"("+num$(ILED)+")")
 VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
 If VU<>0
  SAIAXE = [F:CPY]DACDIE(VU-1)
 Else
  SAIAXE = 2 : # Sait-on jamais...
 Endif
 If CODAXE<>"" & !find(CODAXE,AXE(1..NBAXE)) & NBAXE<dim(AXE) & (!SAI_AMONT | SAIAXE=2)
  NBAXE       += 1
  AXE(NBAXE)   = CODAXE
  VU = find(CODAXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
  If VU<>0
   OBLIG(NBAXE) = [F:CPY]OBYDIE(VU-1)
  Else
   OBLIG(NBAXE) = 1 : # Sait-on jamais...
  Endif
  If NBAXE>=GOPTCANA : Break : Endif
 Endif
Next IDIE
Return

###########################################################################################
## Plans de comptes et axes à saisir pour un modéle comptable  (Idem SETPLAN sauf qu'ici on
## renvoie tous les axes même ceux qui sont déflagués 'Saisie en amont' SETPLAN2 sert
## notamment pour l'affichage des axes des fiches sociétés et site (sections par défaut)
###########################################################################################
Subprog SETPLAN2(MODELE,NBPLAN,PLAN,REFTYP,NBAXE,AXE,OBLIG)
Value    Char    MODELE         : # Modèle comptable
Variable Integer NBPLAN         : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)    : # Plans (COA) (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer REFTYP(1..)    : # Types référentiels (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer NBAXE          : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)     : # Axes (DIE)
Variable Integer OBLIG(1..)     : # Obligatoire (O/N)
Local Integer SAI_AMONT : SAI_AMONT = 0
Local Integer INI_AXE   : INI_AXE = 1
Gosub SET_PLAN
End

#########################################################
## Plans de comptes non automatiques pour une société
#########################################################
Subprog SETPLAN3(SOCIETE,NBPLAN,PLAN,REFTYP)
Value    Char    SOCIETE        : # Société ou site
Variable Integer NBPLAN         : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)    : # Plans (COA) (en 1:général principal, si <>1 en 2:analytique principal)
Variable Integer REFTYP(1..)    : # Types référentiels (en 1:général principal, si <>1 en 2:analytique principal)
Local Char    MODELE(GLONGCM)
Local Integer SAI_AMONT : SAI_AMONT = 0
Local Integer INI_AXE   : INI_AXE = 0
Call SETGCM(SOCIETE,MODELE) From CPTDIV
Gosub SET_PLAN
End


##########################################################################################################
## Plans de comptes et axes à saisir pour une société et une liste de référentiels passée en paramètres
## sasie en amont.
##########################################################################################################
Subprog SETPLANAXE(SOCIETE,NBREF,REFTYP,NBPLAN,PLAN,NBAXE,AXE,OBLIG)
Value    Char    SOCIETE       : # Société
Value    Integer NBREF         : # Nb de référentiels
Value    Integer REFTYP(1..)   : # Type référentiels
Variable Integer NBPLAN        : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)   : # Plans (COA) (en 1:général principal, en 2:analytique principal)
Variable Integer NBAXE         : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)    : # Axes (DIE)
Variable Integer OBLIG(1..)    : # Obligatoire (O/N)

Local Integer SAI_AMONT : SAI_AMONT = 1
Local Integer INI_AXE   : INI_AXE = 1

Local Integer ILED, IREF, IDIE
Local Char    REFER(GLONLED)(1..len(mess(0,2644,1)))
Local Char    DEVREF(GLONCUR)(1..len(mess(0,2644,1)))

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif

Call LEC_CPY(SOCIETE) From CPTLEC

Raz NBPLAN, PLAN, NBAXE, AXE, OBLIG
NBPLAN = 0
For IREF=1 To NBREF
 Call LECLED(SOCIETE,REFTYP(IREF),REFER(IREF),DEVREF(IREF)) From CPTDIV
 ILED = find(REFER(IREF),GLED(1..GLEDNBR))
 If !ILED
  Call GLOBVAR From SETGLBLED
  ILED = find(REFER(IREF),GLED(1..GLEDNBR))
 Endif
 If ILED
  NBPLAN += 1
  PLAN(IREF) = GLEDCOA(ILED)
  Gosub AXES
 Endif
Next IREF
End

##########################################################################################################
## Plans de comptes et axes à saisir pour une société et une liste de référentiels passée en paramètres
## Ce sous programme renvoie tous axes même ceux non saisis en amont
##########################################################################################################
Subprog SETPLANAXE2(SOCIETE,NBREF,REFTYP,NBPLAN,PLAN,NBAXE,AXE,OBLIG)
Value    Char    SOCIETE       : # Société
Value    Integer NBREF         : # Nb de référentiels
Value    Integer REFTYP(1..)   : # Type référentiels
Variable Integer NBPLAN        : # Nb de plans comptables (max 10)
Variable Char    PLAN()(1..)   : # Plans (COA) (en 1:général principal, en 2:analytique principal)
Variable Integer NBAXE         : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)    : # Axes (DIE)
Variable Integer OBLIG(1..)    : # Obligatoire (O/N)

Local Integer SAI_AMONT : SAI_AMONT = 0
Local Integer INI_AXE   : INI_AXE = 1

Local Integer ILED, IREF, IDIE
Local Char    REFER(GLONLED)(1..len(mess(0,2644,1)))
Local Char    DEVREF(GLONCUR)(1..len(mess(0,2644,1)))
Local Char    CODAXE(GLONDIE)

If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif

Call LEC_CPY(SOCIETE) From CPTLEC

Raz NBPLAN, PLAN, NBAXE, AXE, OBLIG
NBPLAN = 0
For IREF=1 To NBREF
 Call LECLED(SOCIETE,REFTYP(IREF),REFER(IREF),DEVREF(IREF)) From CPTDIV
 ILED = find(REFER(IREF),GLED(1..GLEDNBR))
 If !ILED
  Call GLOBVAR From SETGLBLED
  ILED = find(REFER(IREF),GLED(1..GLEDNBR))
 Endif
 If ILED
  NBPLAN += 1
  PLAN(IREF) = GLEDCOA(ILED)
  Gosub AXES
 Endif
Next IREF
End

##########################################################################################################
## Nombre et liste les Axes communs pour une société passée en paramètres
##########################################################################################################
Subprog SETAXECOM(SOCIETE,NBAXE,AXE)
Value    Char    SOCIETE       : # Société
Variable Integer NBAXE         : # Nb d'axes à saisir (max 20)
Variable Char    AXE()(1..)    : # Axes (DIE)

If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif

Local Char    MODELE(GLONGCM), REF(GLONLED), CODAXE(GLONDIE), LSTAXE(GLONDIE)(1..max(GOPTCANA,20))
Local Integer IREF,ILED,IDIE,IAXE,ILST

Call SETGCM(SOCIETE,MODELE) From CPTDIV

Raz NBAXE, AXE

Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM(MODELE) From CPTLEC
IGCM   = find(MODELE,GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM   = find(MODELE,GGCM(1..GGCMNBR))
Endif
If IGCM
 For IREF=1 To len(mess(0,2644,1))
  REF = evalue("GLED"+num$(IREF)+"("+num$(IGCM)+")")
  If REF<>"" & [F:GCM]CFMAUT(IREF-1)<>2
   ILED = find(REF,GLED(1..GLEDNBR))
   If !ILED
    Call GLOBVAR From SETGLBLED
    ILED = find(REF,GLED(1..GLEDNBR))
   Endif
   If ILED
    For IDIE=1 To GLEDDIENBR(ILED)
     CODAXE = evalue("GDIE"+num$(IDIE)+"("+num$(ILED)+")")
     If CODAXE<>"" & ILST<dim(LSTAXE)
      If !find(CODAXE,LSTAXE(1..ILST))
       ILST+= 1
       LSTAXE(ILST) = CODAXE
       If ILST>=GOPTCANA : Break : Endif
      Elsif !find(CODAXE,AXE(1..NBAXE))
       NBAXE+= 1
       AXE(NBAXE)= CODAXE
      Endif
     Endif
    Next IDIE
   Endif
  Endif
 Next IREF
Endif
End

########################################################################
## Référentiel principal général et analytique pour une société/site
########################################################################
Subprog SETMAINREF(SOCIETE,TYPLEDGEN,TYPLEDANA)
Value    Char    SOCIETE     : # Société ou site
Variable Libelle TYPLEDGEN   : # Type référentiel principal général
Variable Libelle TYPLEDANA   : # Type référentiel principal analytique
Local Char    MODELE(GLONGCM)
Local Integer IGCM
Call SETGCM(SOCIETE,MODELE) From CPTDIV
IGCM   = find(MODELE,GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM   = find(MODELE,GGCM(1..GGCMNBR))
Endif
If IGCM
 TYPLEDGEN = GLEDTYPGEN(IGCM)
 TYPLEDANA = GLEDTYPANA(IGCM)
Endif
End

########################################################################
## Codes référentiels pour une société/site
########################################################################
Subprog SETREF(SOCIETE,NBLED,CODLED)
Value    Char    SOCIETE       : # Société ou site
Variable Integer NBLED         : # Nombre de référentiels
Variable Char    CODLED()(1..) : # Référentiels (en 1:général principal, en 2:analytique principal)
Local Char    MODELE(GLONGCM)
Local Integer IGCM, IREF
Call SETGCM(SOCIETE,MODELE)
IGCM   = find(MODELE,GGCM(1..GGCMNBR))
If !IGCM
 Call GLOBVAR From SETGLBGCM
 IGCM   = find(MODELE,GGCM(1..GGCMNBR))
Endif
If IGCM
 CODLED(1) = GLEDGEN(IGCM)
 CODLED(2) = GLEDANA(IGCM)
 NBLED = 2
 For IREF=1 To len(mess(0,2644,1))
  REF = evalue("GLED"+num$(IREF)+"("+num$(IGCM)+")")
  If REF<>"" & !find(REF,CODLED(1..NBLED))
   NBLED+=1
   CODLED(NBLED) = REF
  Endif
 Next
Endif
End

########################################################################
## Modèle comptable pour une société ou un site
########################################################################
Subprog SETGCM(SOCIETE,MODELE)
Value    Char    SOCIETE   : # Société ou site
Variable Char    MODELE    : # Modèle comptable
Local Integer ISOC, ISITE
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(SOCIETE,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Endif
MODELE = GGCMSOC(ISOC)
End

########################################################################
##  Numéro d'axe dans un référentiel
########################################################################
## Modif BY 03/12/2008 pour gérer une société non juridique
########################################################################
Subprog GETNUMAXE(SOCIETE,LEDTYP,AXE,NUMAXE)
Value Char       SOCIETE
Value Integer    LEDTYP
Value Char       AXE
Variable Integer NUMAXE
NUMAXE=0
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif

Call LEC_CPY(SOCIETE) From CPTLEC
If !fstat
 If [F:CPY]CPYLEGFLG<>2
  If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  Read [FGR]FGR0(1) = SOCIETE
  Call LEC_FCY([F:FGR]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
 Endif
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 If !fstat
  If LEDTYP=0 : End : Endif
  Call LEC_LED([F:GCM]LED(LEDTYP-1)) From CPTLEC
  If !fstat
   For I=0 To [F:LED]DIENBR-1
    If [F:LED]DIE(I)=AXE : NUMAXE=I+1 : Break : Endif
   Next
  Endif
 Endif
Endif
End

########################################################################################################
## Recherche du compte général ou analytique (selon TYPACC) dans un tableau de comptes à partir
## d'une liste de type de référentiels passée en paramètres
## Ce sous-programme peut utilisé en gestion de document (factures...) ou génération de pièce
## lorsqu'on a besoin de lire le compte général (pour aller cher le code taxe par ex...) ou analytique
########################################################################################################
Subprog RECH_ACC(TYPACC,SOCIETE,TTYPLED,NBTYPLED,TPLAN,TCOMPTE,PLAN,COMPTE)
Value    Integer TYPACC         : # 1:Compte géné   2:Compte ana
Value    Char    SOCIETE        : # Société
Value    Integer TTYPLED(1..)   : # Type de référentiel
Value    Integer NBTYPLED       : # Nb de type référentiel
Value    Char    TPLAN()(1..)   : # Tableau des plans de comptes
Value    Char    TCOMPTE()(1..) : # Tableau des comptes
Variable Char    PLAN()         : # Plan de compte géné ou ana selon TYPACC
Variable Char    COMPTE()       : # Compte général ou analytique selon TYPACC

Local Char    LED(GLONLED)
Local Char    DEV(GLONCUR)
Local Integer TLED
Local Integer INDLED
Local Libelle TYPLEDGEN, TYPLEDANA

If clalev([F:LED])=0 : Local File GLED [LED] : Endif

Call SETMAINREF(SOCIETE,TYPLEDGEN,TYPLEDANA) From CPTDIV

Raz COMPTE, PLAN, INDLED
Case TYPACC
 When 1
  INDLED = find(TYPLEDGEN,TTYPLED(1..NBTYPLED))
 When 2
  INDLED = find(TYPLEDANA,TTYPLED(1..NBTYPLED))
Endcase
If INDLED
 PLAN   = TPLAN(INDLED)
 COMPTE = TCOMPTE(INDLED)
Endif
## Si pas de compte sur le référentiel principal (général ou analytique selon TYPACC), on regarde s'il y a
## un compte sur un autre type de référentiel (général ou analytique selon TYPACC)...
If COMPTE=""
 For INDLED=1 To NBTYPLED
  Case TYPACC
   When 1
    If TTYPLED(INDLED)<>TYPLEDGEN
     [L]TLED = TTYPLED(INDLED)
     Call LECLED(SOCIETE,[L]TLED,LED,DEV) From CPTDIV
     Call LEC_LED([L]LED) From CPTLEC
     If [F:LED]GEN=2
      PLAN   = TPLAN(INDLED)
      COMPTE = TCOMPTE(INDLED)
      # Ajout du break sinon on renvoie systématiquement le dernier référentiel qui peut avoir un compte vide
      If COMPTE<>"" : Break : Endif
     Endif
    Endif
   When 2
    If TTYPLED(INDLED)<>TYPLEDANA
     [L]TLED = TTYPLED(INDLED)
     Call LECLED(SOCIETE,[L]TLED,LED,DEV) From CPTDIV
     Call LEC_LED([L]LED) From CPTLEC
     If [F:LED]ANA=2
      COMPTE = TCOMPTE(INDLED)
      PLAN  = TPLAN(INDLED)
      # Ajout du break sinon on renvoie systématiquement le dernier référentiel qui peut avoir un compte vide
      If COMPTE<>"" : Break : Endif
     Endif
    Endif
  Endcase
 Next
Endif
If COMPTE<>""
 Call LEC_GAC(COMPTE,PLAN) From CPTLEC
Endif
End


##################################################################################
# Renvoie le compte d'un type de compte divers pour un type de référentiel et
# une société passés en paramètre
##################################################################################
Subprog RECH_ACCMIS(SOC,LEDTYP,ACCDIVTYP,COMPTE)
Value    Char    SOC()      : # Société
Value    Libelle LEDTYP     : # Type référentiel
Value    Integer ACCDIVTYP  : # Type compte divers (ligne du menu local 2649)
Variable Char    COMPTE()   : # Compte
If clalev([F:COA])=0  : Local File GCOA [COA] : Endif
Local Char PLAN(GLONCOA)
Call LECPLAN(SOC,LEDTYP,PLAN) From CPTDIV
Call LEC_COA(PLAN) From CPTLEC
COMPTE = [F:COA]ACCMIS(ACCDIVTYP-1)
End

################################################################################
##  Position des devises (transaction et référentiels) par rapport à l'Euro
################################################################################
Subprog SETFLGDEV(DEV,SOC,DAT)
Value Char    DEV()         : # Devise (transaction)
Value Char    SOC()         : # Société
Value Date    DAT           : # Date

Local Char    DEVLED(GLONCUR)
Local Integer I, IREF

Global Libelle GLEDFLG(1..len(mess(0,2644,1))) : # Positionnement de la devise de référentiel (In ou Out)

If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM    [GCM] : Endif

# Devise passée en paramètre (devise transaction)
GCURFLG = 1
I = find(DEV,GDEVISE(1..GNBDEV))
If !I : GCURFLG=0 : End : Endif
If GDEVDAT(I)<=DAT : GCURFLG=2 : Endif  : # Si devise 'Out', GDEVDAT=31/12/9999

# Devise des référentiels
Call LEC_CPY(SOC) From CPTLEC            # Lecture de la société juridique
Call LEC_GCM([F:CPY]ACM) From CPTLEC     # Lecture du modèle comptable

For IREF=1 To len(mess(0,2644,1))
 GLEDFLG(IREF) = 1
 I = find([F:GCM]CUR(IREF-1),GDEVISE(1..GNBDEV))
 If !I
  GLEDFLG(IREF)=0
 Else
  If GDEVDAT(I)<=DAT : GLEDFLG(IREF)=2 : Endif
 Endif
Next
End

##################################################################################
##  Liste des types de référentiel pour une société et un plan de compte
##  NB: si le plan de compte est renseigné à vide, on renvoie la liste de
##  tous les types de référentiel
##################################################################################
Subprog SETLEDTYPLIST(SOCIETE,PLAN,NBRLEDTYP,LEDTYPLIST)
Value Char SOCIETE
Value Char PLAN
Variable Integer NBRLEDTYP
Variable Integer LEDTYPLIST(0..len(mess(0,2644,1))-1)

Local Char LEDCUR(GLONLED)
NBRLEDTYP=0
If SOCIETE<>""
 If PLAN=""
  For I=1 To len(mess(0,2644,1))
   LEDTYPLIST(NBRLEDTYP)=I
   NBRLEDTYP +=1
  Next I
 Else
  ISOC = find(SOCIETE,GSOC(1..GNBSOC))
  If !ISOC : End : Endif
  IGCM = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
  If !IGCM
   Call GLOBVAR From SETGLBGCM
   IGCM = find(GGCMSOC(ISOC),GGCM(1..GGCMNBR))
  Endif
  If !IGCM : End : Endif
  For J=1 To len(mess(0,2644,1))
   LEDCUR = evalue("GLED"+num$(J)+"("+num$(IGCM)+")")
   If LEDCUR<>""
    ILED = find(LEDCUR,GLED(1..GLEDNBR))
    If !ILED
     Call GLOBVAR From SETGLBLED
     ILED = find(LEDCUR,GLED(1..GLEDNBR))
    Endif
    If GLEDCOA(ILED)=PLAN : LEDTYPLIST(NBRLEDTYP)=J : NBRLEDTYP +=1 : Endif
   Endif
  Next J
 Endif
Endif
End

#################################################################################
##  Liste et nombre de types de référentiel en validation auto pour une société
##  et un type de référentiel donnés
#################################################################################
Subprog GETTYPLEDVLDAUT(SOCIETE,LEDTYP,TYPLEDVLDAUT,NBRVLDAUT)
Value    Char     SOCIETE
Value    Integer  LEDTYP
Variable Integer  TYPLEDVLDAUT(1..)
Variable Integer  NBRVLDAUT
Local Integer I, J, K
J=1
Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
For I=0 To dim([F:GCM]LED)-1
 If [F:GCM]CFMAUT(I)=2 & [F:GCM]ORILEDTYP(I)=LEDTYP
  TYPLEDVLDAUT(J)=I+1
  J+=1
 Endif
Next I
NBRVLDAUT=J-1
For K=J+1 To len(mess(0,2644,1))
 TYPLEDVLDAUT(K)=0
Next
End

#################################################################################
##  Liste des modèles comptables utilisés (=définis pour au moins une société)
#################################################################################
Subprog LSTGCM(NBMOD,TMODELE)
Variable Integer NBMOD
Variable Char    TMODELE()(1..)
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
NBMOD = 0
Raz TMODELE
For [CPY]CPY0 Where [F:CPY]CPYLEGFLG=2
 If !find([F:CPY]ACM,TMODELE(1..NBMOD))
  NBMOD += 1
  TMODELE(NBMOD) = [F:CPY]ACM
 Endif
Next
End

##########################################################################################################
## Nombre d'axe et Liste des codes axes d'un référentiel à partir d'une société et du type de référentiel
##########################################################################################################
Subprog GETLSTAXE(SOCIETE,LEDTYP,NBRDIE,LSTDIE)
Value    Char    SOCIETE()      : # Société
Value    Integer LEDTYP         : # Type référentiel
Variable Integer NBRDIE         : # Nombre axe
Variable Char    LSTDIE()(1..)  : # Tableau des sections correspondantes aux codes axes contenus dans TBDIE2

If !clalev([F:LED]) : Local File GLED [LED] : Endif

Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Integer AXE

Call LECLED(SOCIETE,LEDTYP,CODLED,DEVLED) From CPTDIV
Call LEC_LED(CODLED) From CPTLEC
NBRDIE = [F:LED]DIENBR
For AXE=1 To dim([F:LED]DIE)
 LSTDIE(AXE) = [F:LED]DIE(AXE-1)
Next
End

##########################################################################################
## Filtrage de code axes et sections ana pour un type référentiel passé en paramètres
##########################################################################################
Subprog SETCCEAXE(SOCIETE,LEDTYP,TBDIE,TBCCE,TBDIE2,TBCCE2)
Value    Char    SOCIETE()     : # Société
Value    Integer LEDTYP        : # Type référentiel pour lequel on veut renvoyer les bons axes/sections
Value    Char    TBDIE()(1..)  : # Tableau des codes axes des X types référentiels
Value    Char    TBCCE()(1..)  : # Tableau des sections correspondantes aux codes axes contenus dans TBDIE
Variable Char    TBDIE2()(1..) : # Tableau des codes axes gérés par le référentiel passé en paramètres
Variable Char    TBCCE2()(1..) : # Tableau des sections correspondantes aux codes axes contenus dans TBDIE2

If !clalev([F:LED]) : Local File GLED [LED] : Endif

Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Integer AXE, VU, NBDIE

Call LECLED(SOCIETE,LEDTYP,CODLED,DEVLED) From CPTDIV
Call LEC_LED(CODLED) From CPTLEC
NBDIE = 0
For AXE=1 To dim([F:LED]DIE)
 If [F:LED]DIE(AXE-1)<>""
  VU = find([F:LED]DIE(AXE-1),TBDIE(1..GOPTCANA))
  If VU
   NBDIE += 1
   TBDIE2(NBDIE) = TBDIE(VU)
   TBCCE2(NBDIE) = TBCCE(VU)
  Endif
 Endif
Next
End

#################################################################################
## Définit si le type de référentiel passé en paramètre est 'automatique' pour
## la société passée également en paramètre
#################################################################################
Subprog LEDTYPAUT(SOCIETE,LEDTYP,FLGAUT)
Value    Char    SOCIETE()     : # Société
Value    Integer LEDTYP        : # Type référentiel
Variable Integer FLGAUT        : # 1:Non 2:Oui

If !clalev([F:GCM]) : Local File GACM     [GCM] : Endif

Local Char MODELE(GLONGCM)

Call SETGCM(SOCIETE,MODELE)
Call LEC_GCM(MODELE) From CPTLEC
If [F:GCM]CFMAUT(LEDTYP-1)=2
 [L]FLGAUT = 2
Else
 [L]FLGAUT = 1
Endif
End

#################################################################################
## Retourne le type de référentiel d'origine (non automatique)
## si le type de référentiel passé en paramètre est 'automatique'
## pour la société passée également en paramètre.
## Sinon (type de référentiel paramètre non automatique )on retourne 0.
#################################################################################
Subprog ORILEDTYP(SOCIETE,LEDTYPAUT,LEDTYPORI)
Value    Char    SOCIETE()     : # Société
Value    Integer LEDTYPAUT     : # Type référentiel
Variable Integer LEDTYPORI     : # Type référentiel

If !clalev([F:GCM]) : Local File GACM     [GCM] : Endif

Local Char MODELE(GLONGCM)

Call SETGCM(SOCIETE,MODELE)
Call LEC_GCM(MODELE) From CPTLEC
If [F:GCM]CFMAUT(LEDTYPAUT-1)=2
 [L]LEDTYPORI   = [F:GCM]ORILEDTYP(LEDTYPAUT-1)
Else
 [L]LEDTYPORI  = 0
Endif
End


########################################################################################################
## Contrôle qu'au moins un compte (parmi le tableau des comptes passé en paramètres) a un suivi
## analytique sur au moins un des axes passés en paramètres
## Ce sous-programme est utile en avant-saisie de la zone "répartition analytique" de manière
## à la rendre inaccessible lorsqu'aucun compte n'a un suivi sur les axes saisissables
########################################################################################################
Subprog SUIVI_ANA(SOCIETE,TTYPLED,NBTYPLED,TPLAN,TCOMPTE,TDIE,NBDIE,SUIVI)
Value    Char    SOCIETE        : # Société
Value    Integer TTYPLED(1..)   : # Type de référentiel
Value    Integer NBTYPLED       : # Nb de type référentiel
Value    Char    TPLAN()(1..)   : # Tableau des plans de comptes
Value    Char    TCOMPTE()(1..) : # Tableau des comptes
Value    Char    TDIE()(1..)    : # Tableau des axes analytiques
Value    Integer NBDIE          : # Nombre d'axes analytiques
Variable Integer SUIVI          : # 0:Pas de suivi  1:Suivi sur au moins un axe

Local Char    LED(GLONLED)
Local Char    DEV(GLONCUR)
Local Integer TLED
Local Integer INDLED

If clalev([F:LED])=0 : Local File GLED     [LED] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif

SUIVI = 0
For INDLED=1 To NBTYPLED
 [L]TLED = TTYPLED(INDLED)
 Call LECLED(SOCIETE,[L]TLED,LED,DEV) From CPTDIV
 Call LEC_LED([L]LED) From CPTLEC
 If [F:LED]ANA=2 & TCOMPTE(INDLED)<>""
  Call LEC_GAC(TCOMPTE(INDLED),TPLAN(INDLED)) From CPTLEC
  For AXE=1 To NBDIE
   If find(TDIE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : SUIVI = 1 : Break 2 : Endif
  Next
 Endif
Next
End

########################################################################################################
## Permet de renvoyer la liste des types référentiels utilisés pour une société donnée
## OPTION = 0 : Tous les référentiels
## OPTION = 1 : Tous les référentiels non automatiques
## OPTION = 2 : Tous les référentiels automatiques
## OPTION = 3 : Tous les référentiels non automatiques dont le référentiel est coché "Analytique
## Ajout 17/11/11
## OPTION = 4 : Tous les type de référentiels dont le référentiel est coché "Budget
########################################################################################################
Subprog LSTLEDTYP(SOCIETE,OPTION,TLEDTYP,NBLED)
Value    Char    SOCIETE()
Value    Integer OPTION
Variable Integer TLEDTYP(1..len(mess(0,2644,1)))
Variable Integer NBLED
Local Integer NLED
Raz NBLED, TLEDTYP
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM    [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED    [LED] : Endif
Call LEC_CPY(SOCIETE) From CPTLEC
If !fstat
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 If !fstat
  For NLED = 1 To len(mess(0,2644,1))
   Call LEC_LED([F:GCM]LED(NLED-1)) From CPTLEC
   If !fstat
    If [F:GCM]LED(NLED-1) <> ""
     Case OPTION
      When 0 : NBLED+=1 : TLEDTYP(NBLED)=NLED
      When 1 : If [F:GCM]CFMAUT(NLED-1) <> 2 :  NBLED+=1 : TLEDTYP(NBLED)=NLED : Endif
      When 2 : If [F:GCM]CFMAUT(NLED-1) = 2  :  NBLED+=1 : TLEDTYP(NBLED)=NLED : Endif
      When 3 : If [F:GCM]CFMAUT(NLED-1) <> 2 & [F:LED]ANA=2  :  NBLED+=1 : TLEDTYP(NBLED)=NLED : Endif
      When 4 : If [F:LED]BUD=2  :  NBLED+=1 : TLEDTYP(NBLED)=NLED : Endif
     Endcase
    Endif
   Endif
  Next NLED
 Endif
Endif
End


Subprog LEDTYP_CHOICE(CPY,OPTION)
## Permet de définir la liste des types de référentiel en fonction de l'option passée en paramètre
#    - flagué 'Général'               (si OPTION=1)
#    - flagué 'Gestion échéances'     (si OPTION=2)   # Suppression du flag, la "Gestion des échéances est induite par le "Réf. Principal Général"
#    - flagué 'Analytique'            (si OPTION=3)
#    - flagué 'Budgets'               (si OPTION=4)
#    - flagué 'Engagements'           (si OPTION=5)
#    - flagué 'Consolidation'         (si OPTION=11)
#    - Tous "types"                   (si OPTION=0)
#    - Tous "types" non flagué automatique                       (si OPTION=6)
#    - Tous "types" non flagué automatique  & flagué 'Général'   (si OPTION=7)
#    - Tous "types" non flagué automatique  & flagué 'Analytique'(si OPTION=8)
#    - Flagué 'Double Entry Method'                              (si OPTION=9)
#    - Flagué 'Lettrable'  (si OPTION=10)
Value Char    CPY()
Value Integer OPTION
Local Integer NBLED, IND, TYPREF
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM     [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED     [LED] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Raz GMENLOC
If CPY<>""
 Call LEC_CPY(CPY) From CPTLEC
 If !fstat
  If [F:CPY]CPYLEGFLG=2
   Gosub TYPLED_CHOICE
  Else
   For [FGR] Where CPY=[L]CPY
    Call LEC_FCY([F:FGR]FCY) From CPTLEC
    Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
    Gosub TYPLED_CHOICE
   Next
  Endif
 Endif
Else
 # Pas de société passé en paramètre avec une OPTION=6 => Liste les types de référentiels non automatique (Paramètre GLEDTYPAUT)
 If OPTION=6
  For NBLED=1 To len(GLEDTYPAUT)
   TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
   # Gestion de la valeur 10
   If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
    IND=10
   Else
    IND = TYPREF
   Endif
   If OPTION=6
    GMENLOC(IND)=1
   Endif
  Next
 Endif
Endif
End

$TYPLED_CHOICE
Call LEC_GCM([F:CPY]ACM) From CPTLEC
If !fstat
 For NBLED = 1 To len(mess(0,2644,1))
  Call LEC_LED([F:GCM]LED(NBLED-1)) From CPTLEC
  If !fstat
   Case OPTION
    When 0  : If [F:GCM]LED(NBLED-1) = ""   : GMENLOC(NBLED)=1 : Endif
    When 1  : If [F:LED]GEN    <>2          : GMENLOC(NBLED)=1 : Endif
    When 3  : If [F:LED]ANA    <>2          : GMENLOC(NBLED)=1 : Endif
    When 4  : If [F:LED]BUD    <>2          : GMENLOC(NBLED)=1 : Endif
    When 5  : If [F:LED]CMM <>2 | [F:GCM]CFMAUT(NBLED-1) = 2 : GMENLOC(NBLED)=1 : Endif
    When 6  : If [F:GCM]CFMAUT(NBLED-1) = 2                  : GMENLOC(NBLED)=1 : Endif
    When 7  : If [F:GCM]CFMAUT(NBLED-1) = 2 | [F:LED]GEN <>2 : GMENLOC(NBLED)=1 : Endif
    When 8  : If [F:GCM]CFMAUT(NBLED-1) = 2 | [F:LED]ANA = 1 : GMENLOC(NBLED)=1 : Endif
    When 9  : If [F:GCM]DOELED(NBLED-1) <>2 : GMENLOC(NBLED)=1 : Endif
    When 10 : If [F:GCM]CFMAUT(NBLED-1) = 2 | [F:LED]MTCFLG<>2 : GMENLOC(NBLED)=1 : Endif
    When 11 : If [F:LED]CSL    <>2          : GMENLOC(NBLED)=1 : Endif
   Endcase
  Else
   GMENLOC(NBLED)=1
  Endif
 Next NBLED
Endif
Return

Subprog SAI_AMONT(SOCIETE,NBREF,REFTYP,AXE,SAI_AMONT)
Value    Char    SOCIETE()     : # Société
Value    Integer NBREF         : # Nb de référentiels
Value    Integer REFTYP(1..)   : # Type référentiels
Value    Char    AXE()         : # Code axe
Variable Integer SAI_AMONT     : # 1:Axe non saisi en amont  2:Axe saisi en amont
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Local Integer VU
Call LEC_CPY(SOCIETE) From CPTLEC
SAI_AMONT = 0
VU = find(AXE,[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
If VU<>0
 SAI_AMONT = [F:CPY]DACDIE(VU-1)
Else
 SAI_AMONT = 2
Endif
End

Subprog GETTYPSOCSITGRP(SOCSITGRP,REPONSE)
Value    Char    SOCSITGRP() : # Société,site ou grp
Variable Integer REPONSE     : # 1:société juridique  2:site 3:grp de site 4:grp de sociétés
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY   [AGF] : Endif
Read [AGF]AGF0 = SOCSITGRP
 If fstat
  Look [FCY]FCY0=SOCSITGRP
  If fstat
   REPONSE=0
   #Groupe, société ou site inexistant
   GMESSAGE=mess(149,108,1)
   mkstat=2 : End
  Elsif !fstat
   # Site
   REPONSE=2
  Endif
 Elsif !fstat
  If [F:AGF]FLGCPY=2
   If [F:AGF]FLGLEG=2
    # Sociéte juridique
    REPONSE=1
   Else
    # Groupe de sociétés
    REPONSE=4
   Endif
  Else
   # Groupe de sites
   REPONSE=3
  Endif
 Endif
End REPONSE

Subprog SETDIECCELED(TBDIE,TBCCE,REFERENTIEL,TBDIELED,TBCCELED)
Value Char TBDIE()(1..)
Value Char TBCCE()(1..)
Value Char REFERENTIEL
Variable Char TBDIELED()(1..)
Variable Char TBCCELED()(1..)
Raz TBDIELED,TBCCELED
# A partir d'une liste d'Axes/Sections, on retourne les Axes/Sections
# gérés sur le référentiel passé en paramètre
Local Integer K : K=0
If !clalev([F:LED]) : Local File GLED : Endif
Call LEC_LED(REFERENTIEL) From CPTLEC
If !fstat
 For J=1 To dim(TBDIE)
  If TBDIE(J)="" : Break  : Endif
  If find(TBDIE(J),[F:LED]DIE(0..[F:LED]DIENBR-1))
   K+=1
   TBDIELED(K)=TBDIE(J)
   TBCCELED(K)=TBCCE(J)
  Endif
 Next
Endif
End

## Dem 62598
#####################################################################################################################
## Renvoie le nombre de sites financiers d'une société
#####################################################################################################################
Subprog NBFCY(SOC,NBSIT)
Value    Char    SOC()
Variable Integer NBSIT
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
NBSIT = 0
For [FCY]FCY0 Where LEGCPY=SOC & FINFLG=2
 NBSIT += 1
Next
End


#####################################################################################################################
## Renvoie le nombre de collectifs définis dans un plan de comptes
#####################################################################################################################
Subprog NBSAC(PLAN,NBSAC)
Value    Char    PLAN()
Variable Integer NBSAC
If !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif
NBSAC = 0
For [GAC]GAC0 Where COA=PLAN & SAC=2
 NBSAC += 1
Next
End
## <Fin dem 62598>


#####################################################################################################################
## Permet de savoir si la société pointe sur un modèle comptable avec 'Double Entry Method' (FLGDEM=2 dans ce cas)
#####################################################################################################################
Subprog FLGDEM(SOCIETE,FLGDEM)
Value    Char    SOCIETE()
Variable Integer FLGDEM
FLGDEM = 1
If !func AFNC.ACTIV("KRU") : End : Endif
If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
Local Char MODELE(GLONGCM)
Call SETGCM(SOCIETE,MODELE)
Call LEC_GCM(MODELE) From CPTLEC
If !fstat
 If find(2,[F:GCM]DOELED(0..dim([F:GCM]DOELED)-1))
  FLGDEM = 2
 Endif
Endif
End

#####################################################################################################################
## Renvoie la liste des types référentiels flagués 'Double Entry Method'
#####################################################################################################################
Subprog LEDTYPDEM(SOCIETE,LSTTYPLED)
Value    Char    SOCIETE()
Variable Char    LSTTYPLED()
If !func AFNC.ACTIV("KRU") : LSTTYPLED = "" : End : Endif

If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
Local Char MODELE(GLONGCM)
Local Integer LEDTYP
Call SETGCM(SOCIETE,MODELE)
Call LEC_GCM(MODELE) From CPTLEC
If !fstat
 For LEDTYP = 1 To len(mess(0,2644,1))
  If dim([F:GCM]DOELED)>0 & [F:GCM]DOELED(LEDTYP-1) = 2
   LSTTYPLED += num$(LEDTYP)
  Endif
 Next
Endif
End

#####################################################################################################################
## Renvoie la liste des modèles comptables flagués 'Double Entry Method'
#####################################################################################################################
Subprog GCMDEM(TABGCM,NBGCM)
Variable Char    TABGCM()(1..)
Variable Integer NBGCM(1..)
If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
Filter [GCM] Where find(2,[F:GCM]DOELED(0..len(mess(0,2644,1))))
Raz TABGCM, NBGCM
For [GCM]
 NBGCM += 1
 TABGCM(NBGCM) = [F:GCM]GCM
Next
Filter [GCM]
End

#####################################################################################################################
## Renvoie la première société trouvée flaguée 'Double Entry Method'
#####################################################################################################################
Subprog CPYDEM(CPY,LEDTYP)
Variable Char    CPY()
Variable Integer LEDTYP
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM    [GCM] : Endif
Local Char LSTTYPLED(10)
For [CPY]CPY0
 Call LEDTYPDEM([F:CPY]CPY,LSTTYPLED)
 If LSTTYPLED<>"" : [L]CPY = [F:CPY]CPY : LEDTYP = val(left$(LSTTYPLED,1)) : Break : Endif
Next
End

Funprog MODRUS(SOC)
Value Char SOC
If SOC="" : End 0 : Endif
Local Char LSTTYPLED(10)
Call LEDTYPDEM(SOC,LSTTYPLED)
If LSTTYPLED<>""
 End 1
Else
 End 0
Endif
End

#####################################################################################################################
## Renvoie la liste des codes comptables liés à un modèle comptable flagué 'Double Entry Method'
#####################################################################################################################
Subprog COADEM(TABCOA,NBCOA)
Variable Char    TABCOA()(1..)
Variable Integer NBCOA(1..)

If !clalev([F:GCM]) : Local File GACM [GCM] : Endif
If !clalev([F:LED]) : Local File GLED [LED] : Endif

Local Integer INDGCM,INDLED,INDCOA

Filter [GCM] Where find(2,[F:GCM]DOELED(0..len(mess(0,2644,1))))
For [GCM]
 For INDGCM=1 To dim([F:GCM]LED)
  If [F:GCM]DOELED(INDGCM-1)=2
   INDLED = find([F:GCM]LED(INDGCM-1),GLED(1..GLEDNBR))
   If !INDLED
    Call GLOBVAR From SETGLBLED
    INDLED = find([F:GCM]LED(INDGCM-1),GLED(1..GLEDNBR))
   Endif
   INDCOA = find(GLEDCOA(INDLED),TABCOA(1..NBCOA))
   If !INDCOA
    NBCOA+=1
    TABCOA(NBCOA) = GLEDCOA(INDLED)
   Endif
  Endif
 Next
Next
Filter [GCM]
End

#####################################################################################################################
#  Renvoie le nombre et la liste des législations d'un ensemble de sociétés
#####################################################################################################################
Subprog LEGCPY(TCPY,NBLEG,LSTLEG)
Value    Char    TCPY()(1..)
Variable Integer NBLEG(1..)
Variable Char    LSTLEG()(1..)

Local Integer INDCPY
Local Char    VLEG(GLONADI)
NBLEG=0

For INDCPY=1 To dim(TCPY)
 If TCPY(INDCPY)="" | NBLEG>dim(LSTLEG)-1 : Break : Endif
 VLEG = GLEGSOC(find(TCPY(INDCPY),GSOC(1..GNBSOC)))
 If VLEG<>"" & !find(VLEG,LSTLEG(1..NBLEG))
  NBLEG+=1
  LSTLEG(NBLEG)=VLEG
 Endif
Next
End

#####################################################################################################################
# Copie des textes du dossier origine sans supprimer les autres textes du dossier destination.
# Copie de données déclinées multi législation : CLE2BIS contient la législation du dossier destination car
# quand on copie une LEG="" sur un dossier mono lég, la LEG de destination est la LEG de ce dossier.
# Copy the multi legislation data : CLE2BIS contains the legislation of the destination folder because
# when we copy an empty legislation to a single legislation folder, LEG = legislation of this single legislation folder
#####################################################################################################################

Subprog COPTEXTRALEG(TABLE,CHAMP,CLE1,CLE2,CLE2BIS)
Value    Char    TABLE, CHAMP, CLE1, CLE2, CLE2BIS
For [AXX1] Where CODFIC=TABLE & ZONE=CHAMP & IDENT1=CLE1 & IDENT2=CLE2
 Read [F:AXX2]AXX0 = TABLE;CHAMP;[F:AXX1]LANGUE;CLE1;CLE2BIS
 If !fstat
  [F:AXX2]TEXTE = [F:AXX1]TEXTE
  [F:AXX2]IDENT2 = CLE2BIS
  Call FLDUPD("AXX2") From OBJDIV
  Rewrite [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT2 = CLE2BIS
  Call FLDUPD("AXX2") From OBJDIV
  Write [AXX2]
  If fstat
   GOK=0 : Call FSTA("AXX2") From GLOCK : Break
  Endif
 Endif
Next
End

