###############################################################################
# Representation Class EDICPYPAR                                              #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
         When "AQUERY_TRANS_AFTER"   : Gosub AQUERY_TRANS_AFTER
      Endcase
    When "ECP"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub ECP_AREAD_AFTER
      Endcase
    When "ECP.ECPD"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub ECP_ECPD_AREAD_AFTER
        When Default
      Endcase
    When "ECP.ECPDF"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EBC_EBCDF_AREAD_AFTER
        When Default
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Init SAM 112148 XML signature
  Case CURPRO
    When "ECP.IDTYPE" #SAM 110811
      Case [L]ARULE
        When "PROPAGATE" : Gosub ECP_IDTYPE_PROPAGATE
    Endcase
  Endcase
Return

####################################################################

#Init SAM 110811 - Identication ID type
$ECP_IDTYPE_PROPAGATE
  Call ECP_ECP_DISPLAY(this)
Return
#End SAM 110811

####################################################################

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.ECP.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.ECP.CPY,"CPYNAM")
  this.ECP.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.ECP.PARCOD,"PARDES")
Return

#********************************************************************
# Method ECP_AREAD_AFTER
#********************************************************************
#*
#*!
$ECP_AREAD_AFTER
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"CPYNAM")

  Local Integer WPARTYP #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  WPARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)

  #Init SAM 110811
  Local Integer WOK
  Local Char WPROP(15), WPROP1(15), WPROP2(15)

  WPROP = "$isDisabled"
  WPROP1= "$isMandatory"
  WPROP2= "$isHidden" #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)

  WOK = fmet this.ASETATTRIBUTE('FISCODE', WPROP, 'true')
  WOK = fmet this.ASETATTRIBUTE('DUNS',    WPROP,'false')
  WOK = fmet this.ASETATTRIBUTE('VATNUM' , WPROP, 'true')

#  If WPARTYP = 1 #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#    WOK = fmet this.ASETATTRIBUTE('FLOCOD', WPROP2, 'false')
#    WOK = fmet this.ASETATTRIBUTE('FLOREL', WPROP2, 'false')
#  Else
#    WOK = fmet this.ASETATTRIBUTE('FLOCOD', WPROP2, 'true')
#    WOK = fmet this.ASETATTRIBUTE('FLOREL', WPROP2, 'true')
#  Endif

  Call ECP_ECP_DISPLAY(this)
  #End SAM 110811
Return

#SAM 110811 US 6
#********************************************************************
# Subprog ECP_ECP_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog ECP_ECP_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15), WPROP1(15)
#
  WPROP = "$isDisabled"

  Case WOBJECT.IDTYPE
    When 6       :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'false')
    When Default :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'true')
  Endcase

End
#/ SAM 110811 US6

#********************************************************************
# Method ECP_ECPD_AREAD_AFTER
#********************************************************************
#*
#*!
#Init SAM 112148 XML signature (only displayed when signature is "Yes")
$ECP_ECPD_AREAD_AFTER
  Call ECP_ECPD_DISPLAY(this)
Return


#********************************************************************
# Subprog ECP_ECPD_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog ECP_ECPD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK, WSIGN
  Local Char WPROP(15)

  WPROP = "$isHidden"
  If dim(WOBJECT.ECPD)>1
    WSIGN=WOBJECT.SIGNATURE
  Else
    WSIGN=WOBJECT.APARENT.SIGNATURE
  Endif
  Case WSIGN
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('USER', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CERTIFICATE', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('ADDRESS', WPROP, 'true')
    When 2 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('USER', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CERTIFICATE', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('ADDRESS', WPROP, 'false')
  Endcase

End
#End SAM 112148


$EBC_EBCDF_AREAD_AFTER
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
  this.FLGACT = fmet this.ACTX.ACACHE.EFL.AGETVALNUM(this.FLOCOD,this.FLOREL,"FLGACT")
  Local Integer WCATOPE
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return

