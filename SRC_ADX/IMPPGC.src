#<AdxTL>@(#)12.0.0.0 $Revision$
ACTION
Case ACTION
 When "EXPORT"   : Gosub EXPORT
 When "IMPORT"   : Gosub IMPORT
Endcase
Return

$EXPORT
If [F:CPG]TYP<>2 : # Export groupes sections uniquement
 OK = 0
Endif
Return

$IMPORT
Case IMPFIC
 When "CPC"
  I = find([F:CPC]CCE,[M]CCE(0..[M]NBRCCE-1))
  If I
   status = 75
   nolign = I
  Endif
Endcase
Return
