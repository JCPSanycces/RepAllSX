#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
# Sous-programmes pour la gestion des utilisateurs                                            22 juin 2000
#
# CHKCRMINFOS     : Vérifie la cohérence des paramètres CRM et HDK.
# SETDEFFNC       : Affecte la fonction par défaut d'un utilisateur.
# MANAGE_REP      : Assure la gestion de l'interface Utilisateur/Représentant.
# BESURELINK      : Assurance d'un lien unique Utilisateur/Représentant
# CREREP          : Création d'un représentant
# CREREPFROMUSER  : Création d'un représentant
# UPDALLFROMUSER  : Mise à jour d'un représentant
# UPDAUSFROMBPR   : Mise à jour d'un utilisateur
# SECUREREPADD    : Assurance sur le chargement des adresses associées à un tiers
# GET_GROUPE :Donne le libellé d'un groupe de paramètre formater Libellé groupe (CODE) :
##########################################################################################################
##########################################################################################################
# Vérifie la cohérence des paramètres CRM et HDK.
##########################################################################################################
Subprog CHKCRMINFOS(ICRMOK)
Variable Integer ICRMOK

Local Integer ISALESUSR
Local Integer IBPAFOUND
Local Integer IAUSCRMA
Local Integer IAUSCRMB
Local Char SZAUSCRMC
Local Char SZAUSCRMD
Local Integer IAUSCRME
Local Char SZAUSCRMF
Local Integer IAUSCRMG
Local Char SZAUSCRMH
#LSE 20/11/2006
Local Char SZGROUPE(100)
Local Char PARMSK(250)(1..20) , SAVACT(20)  # FGR 27/07/2010 : X3SUIVI66067
Local Integer NI                            # FGR 27/07/2010 : X3SUIVI66067
Local Integer SVGIMPORT                     # FGR 27/07/2010 : X3SUIVI66067

  Raz SZGROUPE
  #On obtient la valeur des différents paramètres
  For ITER = 0 To [M:AUS7]NBVAR - 1
    If [M:AUS7]CHAPITRE(ITER) = "CRM" Then
      #Obtient la fonction de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMA" Then
        IAUSCRMA = val([M:AUS7]VALINT(ITER))
      Endif
      #Obtient le statut de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMB" Then
        IAUSCRMB = val([M:AUS7]VALINT(ITER))
      Endif
      #Obtient la date de début de mission de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMC" Then
        SZAUSCRMC = [M:AUS7]VALEUR(ITER)
      Endif
      #Obtient la date de fin de mission de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMD" Then
        SZAUSCRMD = [M:AUS7]VALEUR(ITER)
      Endif
      #Obtient le responsable de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRME" Then
        IAUSCRME = val([M:AUS7]VALINT(ITER))
      Endif
      #Obtient le code représentant de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMF" Then
        SZAUSCRMF = [M:AUS7]VALEUR(ITER)
      Endif
      #Obtient le flag temps plein de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMG" Then
        IAUSCRMG = val([M:AUS7]VALINT(ITER))
      Endif
      #Obtient le schéma hebdomadaire de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMH" Then
        SZAUSCRMH = [M:AUS7]VALEUR(ITER)
      Endif
    Endif
  Next
  #Maintenant on vérifie
  ISALESUSR = 0
  If IAUSCRMA = 2 or IAUSCRMA = 3 or IAUSCRMA = 4 or IAUSCRMA = 6 Then
    ISALESUSR = 1
  Endif
  If ISALESUSR Then
    If SZAUSCRMF = "" Then
      If [M:AUS2]NBADR = 0 Then
        #Un utilisateur associé à un représentant doit comporter au minimum une adresse.
        GMESSAGE = mess(379,182,1)
        GERR = 1
        ICRMOK = 0
        End
      Endif
      # FGR 27/07/2010 : X3SUIVI66067 (début)
      Gosub CTRL_VILLE
      If GERR = 1 Then
        ICRMOK = 0
        End
      Endif
      # FGR 27/07/2010 : X3SUIVI66067 (fin)
    Else
      Read [REP]REP0=SZAUSCRMF
      If fstat Then
        #LSE 20/11/2006
        Call GET_GROUPE("COL", SZGROUPE)
        #Le code représentant indiqué pour le paramètre AUSCRMF ne correspond pas à un représentant existant.
        GMESSAGE = SZGROUPE - mess(66,177,1)
        GERR = 1
        ICRMOK = 0
        End
      Else
        IBPAFOUND = 0
        Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = SZAUSCRMF
        For [BPA]
          IBPAFOUND = 1
          Break
        Next
        Filter [BPA]
        If IBPAFOUND = 0 Then
          If [M:AUS2]NBADR = 0 Then
            #Un utilisateur associé à un représentant doit comporter au minimum une adresse.
            GMESSAGE = mess(379,182,1)
            GERR = 1
            ICRMOK = 0
            End
          Endif
        Else
          # FGR 27/07/2010 : X3SUIVI66067 (début)
          Gosub CTRL_VILLE
          If GERR = 1 Then
            ICRMOK = 0
            End
          Endif
          # FGR 27/07/2010 : X3SUIVI66067 (fin)
        Endif
      Endif
    Endif
    If IAUSCRMB > 0 Then
      If IAUSCRMB < 4 Then
        If SZAUSCRMC = "" Then
          #LSE 20/11/2006
          Call GET_GROUPE("COL", SZGROUPE)
          #Le paramètre AUSCRMC (Date de début de mission)
          # doit être renseigné pour un utilisateur associé à un représentant.
          GMESSAGE = SZGROUPE - mess(380,182,1)
          GERR = 1
          ICRMOK = 0
          End
        Elsif IAUSCRMB > 1 Then
          #Temporaire ou occasionnel
          If SZAUSCRMD = "" Then
            #LSE 20/11/2006
            Call GET_GROUPE("COL", SZGROUPE)
            #Le paramètre AUSCRMD (Date de fin de mission)
            # doit être renseigné pour un utilisateur temporaire ou occasionnel associé à un représentant.
            GMESSAGE = SZGROUPE - mess(381,182,1)
            GERR = 1
            ICRMOK = 0
            End
          Endif
        Endif
      Endif
    Endif
    If IAUSCRMG <> 2 Then
      If SZAUSCRMH = "" Then
        #LSE 20/11/2006
        Call GET_GROUPE("COL", SZGROUPE)
        #Un schéma hebdomadaire doit être indiqué pour un utilisateur ne travaillant pas à temps plein.
        GMESSAGE = SZGROUPE - mess(382,182,1)
        GERR = 1
        ICRMOK = 0
        End
      Endif
    Endif
  Else
    If SZAUSCRMF <> "" Then
      #LSE 20/11/2006
      Call GET_GROUPE("COL", SZGROUPE)
      #Cet utilisateur comporte un code représentant alors qu'il n'exerce pas une fonction commerciale.
      GMESSAGE = SZGROUPE - mess(383,182,1)
      GERR = 1
      ICRMOK = 0
      End
    Endif
  Endif
End

##########################################################################################################
$CTRL_VILLE
  # FGR 27/07/2010 : X3SUIVI66067 (début)
  For NI = 1 To [M:AUS2]NBADR
    SAVACT = GACTION : GACTION = "VILCNTOBL"
    SVGIMPORT = GIMPORT
    GIMPORT = 1
    PARMSK(1) = [M:AUS2]BPACRY(NI-1)
    PARMSK(2) = [M:AUS2]POSCOD(NI-1)
    PARMSK(3) = "1"
    Call S_AFF_CHAR([M:AUS2]CTY(NI-1), PARMSK, "VILCNTOBL", "SUBPOS", "") From GACTION
    [M:AUS2]POSCOD(NI-1) = PARMSK(2)
    GACTION = SAVACT
    GIMPORT = SVGIMPORT
    If mkstat Then
      GERR = 1
      GZONE = "CODADR("+num$(NI-1)+")"
      zonsui = "CODADR("+num$(NI-1)+")"
      nolign = NI
      GZNUM = 0
      Break
    Endif
  Next NI
  If GERR = 1 Then
    ICRMOK = 0
    End
  Endif
  # FGR 27/07/2010 : X3SUIVI66067 (fin)
Return

############################################################################
# Affecte la fonction par défaut d'un utilisateur.
############################################################################
$SETDEFFNC
Local Integer IDEFVALFOUND
Local Integer ITERAUS

  IDEFVALFOUND = 0
  If !clalev([F:ADW]) : Local File ADOVAL [ADW] : Endif
  #Valeur dossier, société ou site
  Filter [ADW] Where [F:ADW]PARAM = "AUSCRMA"
  For [ADW]ADW1
    IDEFVALFOUND = 1
    Break
  Next
  Filter [ADW]
  If IDEFVALFOUND Then
    Return
  Else
    #On met la valeur : Autre
    For ITERAUS = 0 To [M:AUS7]NBVAR - 1
      If [M:AUS7]CHAPITRE(ITERAUS) = "CRM" Then
        #Obtient la fonction de l'utilisateur
        If [M:AUS7]PARAM(ITERAUS) = "AUSCRMA" Then
          [M:AUS7]PARAM(ITERAUS) = 1
          Affzo [M:AUS7]PARAM(ITERAUS)
          Break
        Endif
      Endif
    Next
  Endif
Return

##########################################################################################################
# Assure la gestion de l'interface Utilisateur/Représentant.
##########################################################################################################
Subprog MANAGE_REP(ICRMOK)
Variable Integer ICRMOK

Local Integer ITER
Local Integer IAUSFNC
Local Char SZAUS7REP
Local Integer ITERAUS7REP
Local Integer IAUSWITHREP
Local Char SZFIRSTREP
Local Char SZGROUPE (100)

  GCRMAUS7FLG = 0
  GCRMAUS7REP = ""
  GCRMAUS8REP = ""
  IAUSFNC = 1
  SZAUS7REP = ""
  ITERAUS7REP = 0
  IAUSWITHREP = 0
  SZFIRSTREP = ""
  Raz SZGROUPE
  #Obtient la fonction de l'utilisateur
  For ITER = 0 To [M:AUS7]NBVAR-1
    If [M:AUS7]CHAPITRE(ITER) = "CRM" Then
      If [M:AUS7]PARAM(ITER) = "AUSCRMA" Then
        IAUSFNC = val([M:AUS7]VALINT(ITER))
        Break
      Endif
    Endif
  Next
  #Obtient le code représentant
  For ITER = 0 To [M:AUS7]NBVAR - 1
    If [M:AUS7]CHAPITRE(ITER) = "CRM" Then
      If [M:AUS7]PARAM(ITER) = "AUSCRMF" Then
        SZAUS7REP = [M:AUS7]VALEUR(ITER)
        ITERAUS7REP = ITER
        Break
      Endif
    Endif
  Next
  If SZAUS7REP <> "" Then
    Read [REP]REP0=SZAUS7REP
    If fstat Then
      SZAUS7REP = ""
    Endif
  Endif
  #Définit le code représentant associé à la fiche Utilisateur
  #LSE 04/07/2005
  If IAUSFNC = 2 or IAUSFNC = 3 or IAUSFNC = 4 or IAUSFNC = 6 Then
    If SZAUS7REP = "" Then
      #Il faut créer un représentant
      Call CREREP([M:AUS0]USR, ICRMOK)
    Else
      #On vérifie qu'il y a un représentant associé à la fiche utilisateur
      Filter [REP] Where [F:REP]AUSNUM = [M:AUS0]USR
      IAUSWITHREP = 0
      For [REP] REP1
        If IAUSWITHREP = 0 Then
          SZFIRSTREP = [F:REP]REPNUM
        Endif
        IAUSWITHREP += 1
      Next
      Filter [REP]
      If IAUSWITHREP = 0 Then
        #Il faut associer l'utilisateur à un représentant existant
        Filter [REP] Where [F:REP]REPNUM = SZAUS7REP
        For [REP]REP0
          If [F:REP]AUSNUM = "" Then
            Trbegin [REP]
            [F:REP]AUSNUM = [M:AUS0]USR
            Rewrite [REP]
            If fstat Then
              Rollback
            Else
              Commit
              GCRMAUS8REP = SZAUS7REP
              If [M:AUS2]NBADR = 0 Then
                GCRMAUS7FLG = 1
              Endif
            Endif
          Else
           #LSE 20/11/2006
           Call GET_GROUPE("COL", SZGROUPE)
           #Le code représentant indiqué dans le paramètre AUSCRMF est incorrect.
           #Celui-ci est déjà associé à un autre utilisateur.
           GMESSAGE = SZGROUPE - mess(392,182,1)
           GERR = 2
           ICRMOK = 0
          Endif
        Next
        Filter [REP]
      Elsif IAUSWITHREP = 1 Then
        If SZFIRSTREP = SZAUS7REP Then
          #On vérifie si les informations partagées sont cohérentes.
          GCRMAUS8REP = SZFIRSTREP
          If [M:AUS2]NBADR = 0 Then
            GCRMAUS7FLG = 1
          Endif
        Else
          #Le représentant associé à l'utilisateur a été modifié.
          #On vérifie, si la nouvelle association est possible.
          Filter [REP] Where [F:REP]REPNUM = SZAUS7REP
          For [REP]REP0
            If [F:REP]AUSNUM = "" Then
              Trbegin [REP]
              [F:REP]AUSNUM = [M:AUS0]USR
              Rewrite [REP]
              If fstat Then
                Rollback
              Else
                Commit
              Endif
            Else
              #LSE 20/11/2006
              Call GET_GROUPE("COL", SZGROUPE)
              #Le code représentant indiqué dans le paramètre AUSCRMF est incorrect.
              #Celui-ci est déjà associé à un autre utilisateur.
              GMESSAGE = SZGROUPE - mess(392,182,1)
              GERR = 2
              ICRMOK = 0
            Endif
          Next
          Filter [REP]
          If ICRMOK Then
            #On désolidarise l'ancien représentant de la fiche utilisateur
            Filter [REP] Where [F:REP]AUSNUM = [M:AUS0]USR and [F:REP]REPNUM <> SZAUS7REP
            For [REP]
              Trbegin [REP]
              [F:REP]AUSNUM = ""
              Rewrite [REP]
              If fstat Then
                Rollback
              Else
                Commit
              Endif
            Next
            Filter [REP]
            GCRMAUS8REP = SZAUS7REP
          Endif
        Endif
      Elsif IAUSWITHREP > 1 Then
        #Il faut supprimer des associations
        Call BESURELINK([M:AUS0]USR, SZFIRSTREP)
        #On vérifie si les informations partagées sont cohérentes.
        GCRMAUS8REP = SZFIRSTREP
      Endif
    Endif
  Else
    #On vérifie s'il ne reste pas des représentants qui trainent avec le code de cet utilisateur
    Filter [REP] Where [F:REP]AUSNUM = [M:AUS0]USR
    For [REP] REP1
      Trbegin [REP]
      [F:REP]AUSNUM = ""
      Rewrite [REP]
      If fstat Then
        Rollback
      Else
        Commit
      Endif
    Next
    Filter [REP]
  Endif
End

##############################################################################
# Assurance d'un lien unique Utilisateur/Représentant
##############################################################################
Subprog BESURELINK(SZAUSCOD, SZREPCOD)
Value Char SZAUSCOD
Value Char SZREPCOD

  Filter [REP] Where [F:REP]AUSNUM = SZAUSCOD and [F:REP]REPNUM <> SZREPCOD
  For [REP]
    Trbegin [REP]
    [F:REP]AUSNUM = ""
    Rewrite [REP]
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Next
  Filter [REP]
End

##############################################################################
# Création d'un représentant
##############################################################################
Subprog CREREP(SZAUSCOD, ICRMOK)
Value Char SZAUSCOD
Variable Integer ICRMOK

Local Char BPRKEY
Local Integer BPRKEYNUM
Local Char SZMESS(250)
Local Integer IASK

  IASK = 0
  SZMESS = ""
  BPRKEY = ""
  BPRKEYNUM = 1
  #Constitution d'une clé Tiers unique et non existante
  BPRKEY = SZAUSCOD
  Read [BPR]BPR0=BPRKEY
  If fstat Then
    #Confirmez-vous la création du représentant XXXX? Celui-ci sera associé à la fiche de l'utilisateur.
    SZMESS = mess(366,182,1) - BPRKEY - "?" - mess(367,182,1)
    Call OUINON(SZMESS, IASK) From GESECRAN
    If IASK = 2 Then
      GCRMAUS7REP = BPRKEY
    Else
      ICRMOK = 0
      End
    Endif
  Else
    #Il existe un représentant disposant du même code que cet utilisateur.
    # S'agit-il de la même personne ?
    SZMESS = mess(368,182,1)
    Call OUINON(SZMESS, IASK) From GESECRAN
    If IASK = 2 Then
      Call BESURELINK(SZAUSCOD, BPRKEY)
      GCRMAUS7REP = BPRKEY
    Else
      While 1
        BPRKEY = [F:BPR]BPRNUM + num$(BPRKEYNUM)
        Read [BPR]BPR0=BPRKEY
        If fstat Then
          Break
        Endif
        BPRKEYNUM += 1
      Wend
      #Confirmez-vous la création du représentant XXXX? Celui-ci sera associé à la fiche de l'utilisateur.
      SZMESS = mess(366,182,1) - BPRKEY - "?" - mess(367,182,1)
      Call OUINON(SZMESS, IASK) From GESECRAN
      If IASK = 2 Then
        GCRMAUS7REP = BPRKEY
      Else
        ICRMOK= 0
        End
      Endif
    Endif
  Endif
End

##############################################################################
# Création d'un représentant
##############################################################################
Subprog CREREPFROMUSER
  If GCRMAUS7REP = "" Then
    End
  Endif

Local Char SZBPRDEFADD
Local Integer ITOCRE
Local Integer ITER
Local Char SZBPAADD
Local Char SZMESS(250)
Local Char SZREPACCCOD

  ITOCRE = 0
  SZBPAADD = ""
  SZMESS = ""
  SZBPRDEFADD = ""
  #Obtention du code comptable par défaut du représentant
  Raz SZREPACCCOD
  Call INITACCCOD(SZREPACCCOD,4) From TRTX3
  #Obtention du code adresse par défaut.
  For ITER = 0 To [M:AUS2]NBADR-1
    If [M:AUS2]BPAADDFLG(ITER) = 2 Then
      SZBPAADD = [M:AUS2]CODADR(ITER)
      Break
    Endif
  Next
  #Début de la transaction de création globale
  Call DEBTRANS From GLOCK
  Trbegin [BPR], [BPA2], [REP]
  ################################
  #Tiers
  Read [BPR]BPR0=GCRMAUS7REP 
  If fstat Then
    Raz [F:BPR]
    ITOCRE = 1
  Else
    ITOCRE = 0
    SZBPRDEFADD = [F:BPR]BPAADD
  Endif
  #Création du tiers
  [F:BPR]BPRNUM = GCRMAUS7REP
  [F:BPR]BPRSHO = GCRMAUS7REP
  [F:BPR]BPRNAM = [M:AUS0]NOMUSR
  #Infos dépendantes du pays
  [F:BPR]CRY = GPAYS
  If [F:TCY]CRY <> GPAYS Then
    Read [TCY]TCY0=GPAYS
    If fstat Then
      Raz [F:TCY]
    Endif
  Endif
  [F:BPR]LAN = [F:TCY]LAN
  [F:BPR]CUR = [F:TCY]CUR
  [F:BPR]ACCCOD = SZREPACCCOD
  [F:BPR]REPFLG = 2
  #MAE, le 27/02/09, bg 52971
  [F:BPR]ENAFLG = 2
  [F:BPR]BPAADD = SZBPAADD
  If ITOCRE Then
    Write [BPR]
  Else
    Rewrite [BPR]
  Endif
  If fstat Then
    #Erreur lors la génération du Tiers pour le représentant : XXXX
    SZMESS = mess(369,182,1) - GCRMAUS7REP
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    GCRMAUS7REP = ""
    End
  Endif
  ##############################
  #Création du représentant
  Read [REP]REP0=GCRMAUS7REP 
  If fstat Then
    Raz [F:REP]
    ITOCRE = 1
  Else
    ITOCRE = 0
  Endif
  [F:REP]CUR    = [F:BPR]CUR
  [F:REP]BPAADD = [F:BPR]BPAADD
  [F:REP]REPNUM = GCRMAUS7REP
  [F:REP]REPNAM = [M:AUS0]NOMUSR
  [F:REP]ACCCOD = SZREPACCCOD
  Read [AFT]AFT0=[M:AUS1]PRFFCT
  If !fstat Then
    [F:REP]FCY = [F:AFT]FCYDEF(4)
  Endif
  [F:REP]AUSNUM = [M:AUS0]USR
  If ITOCRE Then
    Write [REP]
  Else
    Rewrite [REP]
  Endif
  If fstat Then
    #Erreur lors la génération du représentant associé à l'utilisateur.
    SZMESS = mess(370,182,1)
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    GCRMAUS7REP = ""
    End
  Endif
  ####################################
  #Création des adresses
  If GCRMAUS7FLG Then
    Delete [BPA] Where [F:BPA]BPATYP = 4 and [F:BPA]BPANUM = [M:AUS0]USR
    If fstat Then
      #Erreur lors la génération des adresses pour le représentant :
      SZMESS = mess(371,182,1) - GCRMAUS7REP
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS7REP = ""
      End
    Endif
    Filter [BPA2] Where [F:BPA2]BPATYP = 1 and [F:BPA2]BPANUM = GCRMAUS7REP 
    For [BPA2]
      Raz [F:BPA]
      [F:BPA] = [F:BPA2]
      [F:BPA]BPATYP = 4
      [F:BPA]BPANUM = [M:AUS0]USR
      Write [BPA]
      If fstat Then
        GERR = 1
        Break
      Endif
    Next
    Filter [BPA2]
  Else
    Delete [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = GCRMAUS7REP 
    If fstat Then
      #Erreur lors la génération des adresses pour le représentant :
      SZMESS = mess(371,182,1) - GCRMAUS7REP
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS7REP = ""
      End
    Endif
    Filter [BPA2] Where [F:BPA2]BPATYP = 4 and [F:BPA2]BPANUM = [M:AUS0]USR
    For [BPA2]
      Raz [F:BPA]
      [F:BPA] = [F:BPA2]
      [F:BPA]BPATYP = 1
      [F:BPA]BPANUM = GCRMAUS7REP
      Write [BPA]
      If fstat Then
        GERR = 1
        Break
      Endif
    Next
    Filter [BPA2]
  Endif
  If GERR Then
    #Erreur lors la génération des adresses pour le représentant :
    SZMESS = mess(371,182,1) - GCRMAUS7REP
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    GCRMAUS7REP = ""
    End
  Endif
  ##############################
  #Création du paramètre utilisateur contenant le code du représentant
  Read [ADU2]ADU0=[M:AUS0]USR;"AUSCRMF"
  If fstat Then
    Raz [F:ADU2]
    [F:ADU2]CODUSR = [M:AUS0]USR
    [F:ADU2]PARAM = "AUSCRMF"
    [F:ADU2]VALEUR = GCRMAUS7REP
    [F:ADU2]CREDAT = date$
    [F:ADU2]CREUSR = GUSER
    Write [ADU2]
    If fstat Then
      #Erreur lors la génération du paramètre utilisateur : Code représentant.
      SZMESS = mess(378,182,1)
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS7REP = ""
      End
    Endif
  Else
    [F:ADU2]VALEUR = GCRMAUS7REP
    [F:ADU2]UPDDAT = date$
    [F:ADU2]UPDUSR = GUSER
    Rewrite [ADU2]
    If fstat Then
      #Erreur lors la génération du paramètre utilisateur : Code représentant.
      SZMESS = mess(378,182,1)
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS7REP = ""
      End
    Endif
  Endif
  Commit
  GCRMAUS7REP = ""
  If GCRMAUS7FLG Then
    Default Mask [AUS2]
    Call CHARG_BPA(4, [M:AUS0]USR, SZBPRDEFADD) From TRTBPA
    Affzo [M:AUS2]
  Endif
  Affzo [M:AUS7]
End

##############################################################################
# Mise à jour d'un représentant
##############################################################################
Subprog UPDALLFROMUSER
  If GCRMAUS8REP = "" Then
    End
  Endif

Local Char SZBPRDEFADD
Local Integer ITER
Local Char SZBPAADD
Local Char SZMESS(250)

  SZMESS = ""
  SZBPAADD = ""
  SZBPRDEFADD = ""
  #Obtention du code adresse par défaut.
  For ITER = 0 To [M:AUS2]NBADR-1
    If [M:AUS2]BPAADDFLG(ITER) = 2 Then
      SZBPAADD = [M:AUS2]CODADR(ITER)
      Break
    Endif
  Next
  #Début de la transaction de création globale
  Call DEBTRANS From GLOCK
  Trbegin [BPR], [BPA2], [REP]
  ################################
  #Mise à jour du tiers
  Read [BPR]BPR0=GCRMAUS8REP 
  If !fstat Then
    If GCRMAUS7FLG Then
      SZBPRDEFADD = [F:BPR]BPAADD
    Else
      [F:BPR]BPAADD = SZBPAADD
    Endif
    [F:BPR]BPRNAM = [M:AUS0]NOMUSR
    Rewrite [BPR]
    If fstat Then
      #Erreur lors la mise à jour des informations sur la fiche tiers associée.
      SZMESS = mess(372,182,1)
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS8REP = ""
      End
    Endif
  Endif
  ##############################
  #Mise à jour du représentant
  Read [REP]REP0=GCRMAUS8REP 
  If !fstat Then
    [F:REP]REPNAM = [M:AUS0]NOMUSR
    Rewrite [REP]
    If fstat Then
      #Erreur lors la mise à jour des informations sur la fiche représentant associée.
      SZMESS = mess(373,182,1)
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS8REP = ""
      End
    Endif
  Endif
  ####################################
  #Création des adresses
  If GCRMAUS7FLG Then
    Delete [BPA] Where [F:BPA]BPATYP = 4 and [F:BPA]BPANUM = [M:AUS0]USR
    If fstat Then
      #Erreur lors la mise à jour des adresses pour le représentant : XXXX
      SZMESS = mess(374,182,1) - GCRMAUS8REP
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS8REP = ""
      End
    Endif
    Filter [BPA2] Where [F:BPA2]BPATYP = 1 and [F:BPA2]BPANUM = GCRMAUS8REP
    For [BPA2]
      Raz [F:BPA]
      [F:BPA] = [F:BPA2]
      [F:BPA]BPATYP = 4
      [F:BPA]BPANUM = [M:AUS0]USR
      Write [BPA]
      If fstat Then
        GERR = 1
        Break
      Endif
    Next
    Filter [BPA2]
  Else
    Delete [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = GCRMAUS8REP 
    If fstat Then
      #Erreur lors la mise à jour des adresses pour le représentant : XXXX
      SZMESS = mess(374,182,1) - GCRMAUS8REP
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      GCRMAUS8REP = ""
      End
    Endif
    Filter [BPA2] Where [F:BPA2]BPATYP = 4 and [F:BPA2]BPANUM = [M:AUS0]USR
    For [BPA2]
      Raz [F:BPA]
      [F:BPA] = [F:BPA2]
      [F:BPA]BPATYP = 1
      [F:BPA]BPANUM = GCRMAUS8REP
      Write [BPA]
      If fstat Then
        GERR = 1
        Break
      Endif
    Next
    Filter [BPA2]
  Endif
  If GERR Then
    #Erreur lors la mise à jour des adresses pour le représentant :
    SZMESS = mess(374,182,1) - GCRMAUS8REP
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    GCRMAUS8REP = ""
    End
  Endif
  Commit
  If GCRMAUS7FLG Then
    Default Mask [AUS2]
    Call CHARG_BPA(4, [M:AUS0]USR, SZBPRDEFADD) From TRTBPA
    Affzo [M:AUS2]
  Endif
  GCRMAUS8REP = ""
End

##############################################################################
# Mise à jour d'un utilisateur
##############################################################################
Subprog UPDAUSFROMBPR(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZMESS(250)
Local Integer IDEALWADD
Local Char SZBPAADD

  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  Read [REP]REP0=SZBPRNUM
  If fstat Then
    End
  Endif
  If [F:REP]AUSNUM = "" Then
    End
  Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  Local File BPADDRESS [BPA3]
  SZMESS = ""
  SZBPAADD = ""
  IDEALWADD = 0
  Read [BPR]BPR0=SZBPRNUM
  If !fstat Then
    If [F:BPR]BPAADD <> "" Then
      IDEALWADD = 1
      SZBPAADD = [F:BPR]BPAADD
    Endif
  Endif
  #Début de la transaction de création globale
  Call DEBTRANS From GLOCK
  Trbegin [AUS], [BPA]
  ##############################
  #Mise à jour de l'utilisateur
  Read [AUS]CODUSR=[F:REP]AUSNUM
  If !fstat Then
    [F:AUS]NOMUSR = [F:REP]REPNAM
    If IDEALWADD Then
      [F:AUS]BPAADD = SZBPAADD
    Endif
    Rewrite [AUS]
    If fstat Then
      #Erreur lors la mise à jour des informations sur la fiche utilisateur associée.
      SZMESS = mess(376,182,1)
      GMESSAGE = SZMESS
      GERR = 1
      Rollback
      Close Local File [BPA3]
      End
    Endif
  Endif
  ####################################
  #Création des adresses
  Delete [BPA] Where [F:BPA]BPATYP = 4 and [F:BPA]BPANUM = [F:REP]AUSNUM
  If fstat Then
    #Erreur lors la mise à jour des adresses pour l'utilisateur : XXXX
    SZMESS = mess(377,182,1) - [F:REP]AUSNUM
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    Close Local File [BPA3]
    End
  Endif
  Filter [BPA3] Where [F:BPA3]BPATYP = 1 and [F:BPA3]BPANUM = [F:REP]REPNUM
  For [BPA3]
    Raz [F:BPA]
    [F:BPA] = [F:BPA3]
    [F:BPA]BPATYP = 4
    [F:BPA]BPANUM = [F:REP]AUSNUM
    Write [BPA]
    If fstat Then
      GERR = 1
      Break
    Endif
  Next
  Filter [BPA3]
  If GERR Then
    #Erreur lors la mise à jour des adresses pour l'utilisateur : XXXX
    SZMESS = mess(377,182,1) - [F:REP]AUSNUM
    GMESSAGE = SZMESS
    GERR = 1
    Rollback
    Close Local File [BPA3]
    End
  Endif
  Commit
  Close Local File [BPA3]
End

#############################################################
# Assurance sur le chargement des adresses associées à un tiers
#############################################################
Subprog SECUREREPADD
Local Char DEFADD
Local Integer NOL
Local Integer ISAVNOLIGN
Local Integer ITER
Local Integer IBPAFOUND
Local Char SZAUSCRMF

  DEFADD = ""
  SZAUSCRMF = ""
  IBPAFOUND = 0
  NOL = 0
  ISAVNOLIGN = nolign
  #On obtient la valeur des différents paramètres
  For ITER = 0 To [M:AUS7]NBVAR-1
    If [M:AUS7]CHAPITRE(ITER) = "CRM" Then
      #Obtient le code représentant de l'utilisateur
      If [M:AUS7]PARAM(ITER) = "AUSCRMF" Then
        SZAUSCRMF = [M:AUS7]VALEUR(ITER)
        Break
      Endif
    Endif
  Next
  If SZAUSCRMF = "" Then
    End
  Endif
  Read [REP]REP0=SZAUSCRMF
  If fstat Then
    End
  Endif
  Read [BPR]BPR0=SZAUSCRMF
  If fstat Then
    End
  Endif
  DEFADD = [F:BPR]BPAADD
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = SZAUSCRMF
  For [BPA]
    IBPAFOUND = 0
    For ITER = 0 To [M:AUS2]NBADR-1
      If [M:AUS2]CODADR(ITER) <> "" Then
        If [F:BPA]BPAADD <> "" Then
          If [M:AUS2]CODADR(ITER) = [F:BPA]BPAADD Then
            IBPAFOUND = 1
            Break
          Endif
        Endif
      Endif
    Next
    If IBPAFOUND = 0 Then
      Gosub LOADMISSINGADD
    Endif
  Next
  Filter [BPA]
  nolign = ISAVNOLIGN
  Affzo [M:AUS2]
End

##################################
# Chargement de l'adresse représentant manquante
################################## 
$LOADMISSINGADD
  [M]IDENT  = "4" + [M:AUS0]USR
  [M]NUMBPA = 4
  nolign = [M]NBADR + 1
  [M] = [F:BPA] 
  [M]CODADR(nolign-1)  = [F:BPA]BPAADD
  [M]BPACRY(nolign-1)  = [F:BPA]CRY
  [M]ADDLIG1(nolign-1) = [F:BPA]BPAADDLIG(0)
  [M]ADDLIG2(nolign-1) = [F:BPA]BPAADDLIG(1)
  [M]ADDLIG3(nolign-1) = [F:BPA]BPAADDLIG(2)
  If [F:BPA]BPAADD = DEFADD Then
    [M]BPAADDFLG (nolign-1) = 2
  Else
    [M]BPAADDFLG (nolign-1) = 1
  Endif
  [M]NBADR += 1
  If [M]NBADR > 0 and !find(2,[M]BPAADDFLG(0..[M]NBADR-1)) Then
    [M]BPAADDFLG(0) = 2
  Endif
  If [M]NBADR = 0 Then
    Effzo [M:AUS2]30
    Grizo [M:AUS2]30
  Else
    Actzo [M:AUS2]30
    NOL = 0
    Gosub REMP_ADR
  Endif
End

##################################
$REMP_ADR
  [M]XCODADR = [M]CODADR(NOL)
  [M]XBPADES = [M]BPADES(NOL)
  If dim([M]XTYPADD) > 0 Then
    [M]XTYPADD = [M]TYPADD(NOL)
  Endif
  [M]XBPACRY = [M]BPACRY(NOL)
  [M]XCRYNAM = [M]CRYNAM(NOL)
  If dim([M]XNAM) > 0 Then
    [M]XNAM(0) = [M]NAM1(NOL)
    [M]XNAM(1) = [M]NAM2(NOL)
  Endif
  [M]XADDLIG1 = [M]ADDLIG1(NOL)
  [M]XADDLIG2 = [M]ADDLIG2(NOL)
  [M]XADDLIG3 = [M]ADDLIG3(NOL)
  If dim([M]XSAT) > 0 Then
    [M]XSAT = [M]SAT(NOL) 
  Endif
  [M]XPOSCOD = [M]POSCOD(NOL)
  [M]XCTY = [M]CTY(NOL)
  If dim([M]XCODSEE) > 0 Then
    [M]XCODSEE = [M]CODSEE(NOL)
  Endif
  [M]XTEL = [M]TEL(NOL)
  [M]XFAX = [M]FAX(NOL)
  [M]XWEB = [M]WEB(NOL)
  If dim([M]XEXTNUM) > 0 Then
    [M]XEXTNUM = [M]EXTNUM(NOL)
  Endif
  [M]XBPAADDFLG  = [M]BPAADDFLG(NOL)
  If dim([M]XVLYSTR) > 0 Then
    [M]XVLYSTR = [M]VLYSTR(NOL)
    [M]XVLYEND = [M]VLYEND(NOL)
  Endif
  Call LECTURE("TCY",[M]XBPACRY,"") From CONTOBJ
  Gosub TITRES From W1BPA
  If dim([M:AUS2]XSAT) > 0 Then
    If [F:TCY]ETAT <> 2 Then
      Grizo [M:AUS2]XSAT
    Else
      Actzo [M:AUS2]XSAT
    Endif
  Endif
  If dim([M:AUS2]XCODSEE) > 0 Then
    If [F:TCY]POSCODCTL <> 2 Then
      Effzo [M:AUS2]XCODSEE
      Grizo [M:AUS2]XCODSEE
    Else
      Actzo [M:AUS2]XCODSEE
    Endif
  Endif
  If [M:AUS2]XBPACRY <> "" Then
    Diszo [M:AUS2]XCRYNAM
  Else
    Actzo [M:AUS2]XCRYNAM
  Endif
Return

##########################################################################################################
#LSE 20/11/2006
#Donne le libellé d'un groupe de paramètre formater Libellé groupe (CODE) :
Subprog GET_GROUPE (SZCODGRP, SZLIBGRP)
Value Char SZCODGRP
Variable Char SZLIBGRP()

Local Char SZVALEUR(100)

  Raz SZVALEUR
  Call GET_LIB(903, SZCODGRP, SZVALEUR) From CRM_UTIL
  If SZVALEUR <> "" Then
    SZVALEUR = mess(499,177,1) - SZVALEUR - "(" + SZCODGRP+") : "
  Else
    SZVALEUR = mess(499,177,1) - SZCODGRP - ": "
  Endif                
  SZLIBGRP = SZVALEUR
End                    
