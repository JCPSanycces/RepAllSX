#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POP1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:00"
A_USER  = "DOC"
A_STAMP = "20181109230600"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPOP"
  If [M]NBRPOP=0
  Endif
 When "NBRMAT"
  If [M]NBRMAT=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask POP1 [POP1]
Gosub HORODAT
Local Inpbox "POP1" From GFONCTION At A_STAMP With A_WINDPREV Mask [POP1] As [SIM_]
Grizo [POP1]10
Grizo [POP1]20
Grizo [POP1]30
Grizo [POP1]40
Grizo [POP1]45
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=76 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=76 : Y1(1)=4 : Y2(1)=9
X1(2)=1 : X2(2)=76 : Y1(2)=12 : Y2(2)=24
X1(3)=1 : X2(3)=76 : Y1(3)=10 : Y2(3)=11
X1(4)=1 : X2(4)=76 : Y1(4)=25 : Y2(4)=28
Return

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_COD(zc) From W1POP1
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1POP1
Onkey 144 Titled GBOUTP Call P_COD(zc) From W1POP1
Onkey 146 Titled GBOUTA Call SA_COD(zc) From W1POP1
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,"") From SUBPOP
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJW
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARMSK(1) = "POP"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOP"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOP","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_COD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POP"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_COD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_DES
Onevent INIT_AREA Call D_DES(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_DES(zc) From W1POP1
Return

Subprog IB_DES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DES(VALEUR)
Variable Char    VALEUR()
If varinit([M]DES,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"","","","") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DES(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DES(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DES(zc) From W1POP1
Gosub _AFF
End

Subprog B1_DES(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DES" : PROGSUB = "SUBPOP" : PROGSPE = "SPEPOP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DES" : PROGSUB = "SUBPOP" : PROGSPE = "SPEPOP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1POP1
Onevent CONTROL Call C_LEG(zc) From W1POP1
Onevent AFTER_CHANGE Gosub AMM_LEG From W1POP1
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1POP1
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 VALEUR = GLEGFIL
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1POP1
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1POP1
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1POP1
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1POP1
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"909","") From SUBADI
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"909",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action STD
  Call C_LEG(VALEUR) From SUBPOP
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBPOP
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1POP1
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_AUZPRH
Onevent INIT_AREA Call D_AUZPRH(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_AUZPRH(zc) From W1POP1
Return

Subprog D_AUZPRH(VALEUR)
Variable Integer VALEUR
If varinit([M]AUZPRH,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_AUZPRH(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_POP
Onevent CONTROL Call C_POP(zc) From W1POP1
Onevent AFTER_CHANGE Gosub AMM_POP From W1POP1
Onevent BEFORE_INPUT Call AS_POP(zc) From W1POP1
Return

Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_POP(zc) From W1POP1
Onkey 144 Titled GBOUTP Call P_POP(zc) From W1POP1
Onkey 146 Titled GBOUTA Call SA_POP(zc) From W1POP1
Gosub _AFF
End

Subprog C_POP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat
 ## Action CONTPOP
 Call CONTPOP(VALEUR,GCURLEG) From SUBPOP
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("POP","$",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  If !mkstat
   ## Action STD
   Call C_POP(VALEUR) From SUBPOP
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_POP
Call AM_POP(zc)
If !mkstat & GOBJET
 zoncou = "POP" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_POP(VALEUR) From SUBPOP
If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPOP)")>indice
 [M]POP(indice) = VALEUR
 Affzo ZPOP(indice)
Endif
Gosub _AFF
End

Subprog S_POP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOP
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOP"
 PARMSK(1) = GCURLEG
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOP","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_POP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "POP"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_POP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("POP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPOP
Onevent BEFORE_AREA Gosub AV_ZPOP From W1POP1
Return

$AV_ZPOP
If clalev([F:HRPOP])=0 : Local File POPUL [HRPOP] : Endif
Local File POPUL [F_] 
[F:F_]=[F:HRPOP]
Call LECTURE("POP",num$([M]POP(indice)),"") From CONTOBJ
zc = [F:HRPOP]DES
[F:HRPOP]=[F:F_]
Close Local File [F_]
Gosub _AFF
Return

$ON_POPLEG
Onevent INIT_AREA Call D_POPLEG(zc) From W1POP1
Return

Subprog D_POPLEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]POPLEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_NBRMAT
Onevent AFTER_LINE Call APRES_NBRMAT From W1POP1
Onevent BEFORE_INPUT Call AS_NBRMAT From W1POP1
Return

Subprog AS_NBRMAT
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44923,GBOUT1) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBRMAT From W1POP1
Gosub _AFF
End

Subprog B1_NBRMAT
Local Decimal BASPAG
If !GWEBSERV
 ## Action SELEMPLO2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO2"
 PARMSK(1) = [M]CRISEL
 PARMSK(2) = "1"
 Call SAISIE_NUM(BASPAG,PARMSK,"SELEMP","SELEMP","XWSELEMP") From GSAISIE
 [M]CRISEL = PARMSK(1)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action SELEMPLO3
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO3"
 PARMSK(1) = "1"
 Call S_AFF_NUM(BASPAG,PARMSK,"","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog APRES_NBRMAT
Local Decimal BASPAG
## Action STD
Call APRES_NBRMAT From SUBPOP
If mkstat : End : Endif
Gosub _AFF
End

$ON_REFNUM
Onevent CONTROL Call C_REFNUM(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_REFNUM(zc) From W1POP1
Onevent AFTER_CHANGE Gosub AMM_REFNUM From W1POP1
Return

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44843,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_REFNUM(VALEUR) From SUBPOP
If mkstat=2
 [M]REFNUM(INDIC) = VALEUR
 Affzo REFNUM(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_REFNUM(zc) From W1POP1
Onkey   2 Titled GBOUTS Call S_REFNUM(zc) From W1POP1
Onkey 144 Titled GBOUTP Call P_REFNUM(zc) From W1POP1
Onkey 146 Titled GBOUTA Call SA_REFNUM(zc) From W1POP1
Gosub _AFF
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
If !GWEBSERV
 If !mkstat
  ## Action CONTEMP
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTEMP"
  PARMSK(1) = ""
  PARMSK(2) = ""
  PARMSK(3) = ""
  PARMSK(4) = ""
  PARMSK(5) = ""
  PARMSK(6) = GCURLEG
  Call S_LIS_CHAR(VALEUR,PARMSK,"","DIVPAYE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
If !mkstat
 ## Action DROITEMP
 Call DROIT(VALEUR,"","","") From DIVPAYE
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("EML","",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_REFNUM
Call AM_REFNUM(zc)
If !mkstat & GOBJET
 zoncou = "REFNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_REFNUM(VALEUR) From SUBPOP
If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
Gosub _AFF
End

Subprog S_REFNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMLCTR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMLCTR"
 PARMSK(1) = GCURLEG
 PARMSK(2) = ""
 PARMSK(3) = [0/0/0]
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELEMLCTR","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_REFNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("EML",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "EML"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("EML",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CTRNUM
Onevent CONTROL Call C_CTRNUM(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_CTRNUM(zc) From W1POP1
Onevent AFTER_CHANGE Gosub AMM_CTRNUM From W1POP1
Return

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
If !GWEBSERV
 ## Action SELEMPCTR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPCTR"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AAS_CTRNUM" : PROGSUB = "SUBPOP" : PROGSPE = "SPEPOP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 PARMSK(6) = GCURLEG
 PARMSK(7) = [M:POP1]REFNUM(nolign-1)
 PARMSK(8) = ACTION
 PARMSK(9) = ""
 PARMSK(10) = ""
 PARMSK(11) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELEMPCTR","SELMAT","") From GACTION
 [M:POP1]REFNUM(nolign-1) = PARMSK(7)
 ACTION = "BAS_CTRNUM" : PROGSUB = "SUBPOP" : PROGSPE = "SPEPOP" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
 If mkstat=2
  [M]CTRNUM(INDIC) = VALEUR
  Affzo CTRNUM(INDIC) : mkstat = 2
 Endif
Endif
Onkey   2 Titled GBOUTS Call S_CTRNUM(zc) From W1POP1
Onkey 144 Titled GBOUTP Call P_CTRNUM(zc) From W1POP1
Onkey 146 Titled GBOUTA Call SA_CTRNUM(zc) From W1POP1
Gosub _AFF
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
If !mkstat
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 If !GWEBSERV
  If !mkstat
   ## Action CONTCTR
   Call CONTCTR(VALEUR,[M:POP1]REFNUM(nolign-1)) From DIVPAYE
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("CTR","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 If !mkstat
  ## Action STD
  Call C_CTRNUM(VALEUR) From SUBPOP
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CTRNUM
Call AM_CTRNUM(zc)
If !mkstat & GOBJET
 zoncou = "CTRNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CTRNUM(VALEUR) From SUBPOP
If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
Gosub _AFF
End

Subprog S_CTRNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELCTRLEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTRLEG"
 PARMSK(1) = [M:POP1]REFNUM(nolign-1)
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = GCURLEG
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 PARMSK(8) = ""
 PARMSK(9) = ""
 PARMSK(10) = ""
 PARMSK(11) = ""
 PARMSK(12) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTRLEG","TOOLSHRLEG","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "CTR"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CTRNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("CTR",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CTRDAT
Onevent BEFORE_AREA Gosub AV_CTRDAT From W1POP1
Return

$AV_CTRDAT
Chgfmt [M]CTRDAT(indice) With "DPZ:"+GFMDAT4
Gosub _AFF
Return

$ON_MAJTYP
Onevent INIT_AREA Call D_MAJTYP(zc) From W1POP1
Return

Subprog D_MAJTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]MAJTYP,indice)=0
 VALEUR = 2
Endif
Gosub _AFF
End

$ON_CTRLEG
Onevent INIT_AREA Call D_CTRLEG(zc) From W1POP1
Return

Subprog D_CTRLEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]CTRLEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_CRI
Onevent CONTROL Call C_CRI(zc) From W1POP1
Onevent BEFORE_INPUT Call AS_CRI(zc) From W1POP1
Return

Subprog AS_CRI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(44923,GBOUT1) From OBJDIV
Call TEXTE(1484,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRI(zc) From W1POP1
Onkey 130 Titled GBOUT2 Call B2_CRI(zc) From W1POP1
Onkey 131 Titled GBOUT3 Call B3_CRI(zc) From W1POP1
Gosub _AFF
End

Subprog C_CRI(VALEUR)
Variable Char    VALEUR()
## Action AFRCONTB
Call C_FORMULE(VALEUR) From AFORMULEB
If mkstat : GERR = 1 : GZONE = "CRI" : GZNUM = 13781 : Endif
Gosub _AFF
End

Subprog B1_CRI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMPLO2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO2"
 PARMSK(1) = VALEUR
 PARMSK(2) = num$(2)
 Call SAISIE_CHAR(VALEUR,PARMSK,"SELEMP","SELEMP","XWSELEMP") From GSAISIE
 VALEUR = PARMSK(1)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action SELEMPLO3
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO3"
 PARMSK(1) = num$(2)
 Call S_AFF_CHAR(VALEUR,PARMSK,"","SUBPOP","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_CRI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"EMPLOID","EMPLOCTR","EMPLOPRO","EMPLOENT","EMPLOAD") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_CRI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = "EMPLOID"
 PARMSK(2) = "EMPLOCTR"
 PARMSK(3) = "EMPLOPRO"
 PARMSK(4) = "EMPLOENT"
 PARMSK(5) = "EMPLOAD"
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


