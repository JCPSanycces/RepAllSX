# test url = http://localhost:8124/syracuse-main/html/main.html?url=%2Ftrans%2Fx3%2Ferp%2FSUPERV%2F%24sessions%3Ff%3DAECLIEXE%252F2%252FAECLIEXE%252FM%252FASHWVAL
#
#Local Clbfile RESHEAD
#Local Clbfile RESBODY
#Local Integer OK
#OF = func ASYRMETA.EXTRACT_METADATA("representations", "AQCPROC07", RESHEAD, RESBODY)

$TEST
Call VALIDATION(1,"ZZACTIV",nomap,0,1,0,GBIDI2,GBIDI1) From ASHWVAL
#Call VALIDATION_ALL(nomap,"COMPANY") From SUBASW
#Call VALIDATION(1,"COMPANY","SUPERV",0,1,0,GBIDI2,GBIDI1) From ASHWVAL
End

# YTABCOUNTRY     ATABLE AREPORT  TABCOUNTRY
#------------------------------------------------------------#
# Génération de la structure Representation
#------------------------------------------------------------#

Subprog VALIDATION(TEST,CODREP,DOSSIER,SILENCE,TYPGEN,VALP,TYPAGE,OK)
Value    Integer TEST
Value    Char     CODREP
Value    Char     DOSSIER
Value    Integer  SILENCE
Value    Integer  TYPGEN
Value    Integer  VALP
Variable Integer  TYPAGE
Variable Integer  OK

Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Integer I

OK=1
If TEST
 # Validation de la représentation
 Call OUVRE_TRACE(mess(14,140,1)-CODREP) From LECFIC
Endif

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

If !SILENCE
 Call TEMPON(mess(14,140,1)-CODREP) From GESECRAN
Endif
If GTRACE<>""
 Call ECR_TRACE(mess(14,140,1)-CODREP,0) From GESECRAN
Endif

Local Integer WLOCKSTC
#----- Contrôle lock logique -----#
Call JELOCKEDOS([L]DOSSIER,"AVALSUPSTC",WLOCKSTC) From OBJDIV
If WLOCKSTC=0
 WLOCKSTC=1
 Lock ="AVALSUPSTC" From =[L]DOSSIER With lockwait=-1
Else
 WLOCKSTC=0
Endif

Local Instance ASHW  Using C_ASW
Local Instance AERR(1..)  Using C_AERROR

# Control classe representation
Call VERIF_VALID_REP(DOSSIER,CODREP,OK,AERR) From ASHWCONTROL
#91436 warning sur classe/rep inactive
#If  func ACLACONTROL.HAS_AERR(AERR)>0
If OK<>1 | func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

# Chargement classe representation
ASHW  = NewInstance C_ASW AllocGroup null
#If func ASYRFNC.IS_UPDATE_MONGO>0
# Clbfile RESHEAD, RESBODY
# OK = func ASYR META.EXTRACT_METADATA(func ASYRMETA.GETCOLLECTION("ASW"),func ASYRMETA.GETMAJMONGO("ASW"), CODREP, RESHEAD, RESBODY)
# #SCM??? Goto  FIN
#Endif

Call INI_ACLAVARDEF(CODREP,DOSSIER,ASHW,AERR) From ASHWVALLEC

If TYPGEN=0
 Call LOAD_REP(TEST,DOSSIER,CODREP,0,"",ASHW,AERR) From ASHWVALLEC
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Else
 Call LOAD_REP_COL(TEST,DOSSIER,CODREP,ASHW,AERR) From ASHWVALLEC
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Endif
Call DELETE_ALLSTC(DOSSIER,CODREP) From ASHWVALSUB

# Génération du traitement WMCLAxxxx
For I=1 To maxtab(ASHW.ASHWCOL)
 If ASHW.ASHWCOL(I)<>null
  Call VALSTR_REP(DOSSIER,ASHW.ASHWCOL(I).CODREP,0,TYPAGE,ASHW.ASHWCOL(I),AERR) From ASHWVALTRT
  If func ACLACONTROL.HAS_AERR(AERR)>0 : Break : Endif
 Endif
Next
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

Call VALSTR_REP(DOSSIER,ASHW.CODREP,VALP,TYPAGE,ASHW,AERR) From ASHWVALTRT
If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif

# Génération du trt WMQRYXXXX
Call VALTRT_QRY(DOSSIER,CODREP,ASHW,AERR) From ASHWQRY
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

# Génération du trt WMRxxxx
If find(ASHW.ACLA.TYPCLA,2,5)>0 : # PERSISTANTE OR INTERFACE
 Call CRUD_CLASSE(DOSSIER,CODREP,ASHW.ACLA,ASHW,AERR) From ASHWVALCRUD
 If func ACLACONTROL.HAS_AERR(AERR)>0
  Goto PERDU
 Endif
Endif

# Génération du trt WMREPxxxx
Call VALTRT_REP(DOSSIER,CODREP,ASHW,AERR) From ASHWVALREP
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

#Génération du trt WMJSOxxxx
Call VALTRT_JSO(DOSSIER,CODREP,ASHW,AERR) From ASHWJSO
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

#Génération du trt WMRPTxxxx
Call VALTRT_RPT(DOSSIER,CODREP,ASHW,AERR) From ASHWVALRPT
If func ACLACONTROL.HAS_AERR(AERR)>0
 Goto PERDU
Endif

Goto FIN

#----------------------------------------------#
$FIN
#pour afficher les erreurs et warning
Call TRACE_AERR(AERR) From ACLACONTROL
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If TEST
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
If ASHW<>null : FreeGroup ASHW : Endif
If maxtab(AERR)>0 & AERR<>null
 FreeGroup AERR
Endif
If WLOCKSTC
 Unlock ="AVALSUPSTC" From =[L]DOSSIER
Endif
End

#--------------#
$PERDU
OK=0
Goto FIN

#--------------#
$ERREUR
Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
Resume


#**
#* _DEFERRED_VALIDATION :
#* Validate an entity if necessary
#*
#* @param ACTX
#* @param _ENTITY
#*!
Funprog _DEFERRED_VALIDATION(ACTX,_CLASS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char _CLASS

Local Integer ERROR : ERROR=[V]CST_AOK
Local Char ENTITY(50),ERRMESSAGE(255)

If filinfo(filpath("STC",[L]_CLASS,"stc",nomap,"",""),0)<0
& | filinfo(filpath("STC",[L]_CLASS,"adx",nomap,"",""),0)<0
 #To force the differed validation
 Onerrgo ERR_DEFERRED_VALIDATION
 Local Instance INS Using =[L]_CLASS
 INS=NewInstance [SUBASW] With =[L]_CLASS
 FreeInstance [SUBASW]
 Onerrgo
 If ERROR = [V]CST_AERROR
  If ERRMESSAGE<>""
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,ERRMESSAGE)
  Endif
  ENTITY = right$(_CLASS,3)
  If left$(_CLASS,2) = "R_"
    # The validation failed:
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(7,149,1),ENTITY))
  Elsif left$(_CLASS,2) = "C_"
    # The validation failed:
    ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(9,149,1),ENTITY))
  Endif
 Endif
Endif
End ERROR

$ERR_DEFERRED_VALIDATION
ERRMESSAGE=errm-errmes$(errn)
ERROR = [V]CST_AERROR
Resume

#**
#* _CHECK_ASW
#* Checks that CODREP and/or CODCLA exists
#*!
Funprog _CHECK_ASW(ACTX,CODREP,CODCLA,CODFAC,CODFNC,MODULE,CHECKRIGHT)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char CODREP
Variable Char CODCLA
Value Char CODFAC
Variable Char CODFNC
Variable Integer MODULE
Value Integer CHECKRIGHT : # 1- check access right AFCRIGHT , 0- no control on AFCRIGHT

Local Integer WENAFAC
Local Integer ERROR : ERROR=[V]CST_AOK
If len([L]CODCLA)
 ERROR = func ACLAVAL._CHECK_ACLA(ACTX,[L]CODCLA,[L]CODFAC)
 If ERROR : Goto FIN_CHECK_ASW : Endif
Endif

If len([L]CODREP)
 If ACTX.AFOLDER=nomap
  Local File ASHW    [ASW]
  Local File AFONCTION    [AFC]
 Else
  Local File =ACTX.AFOLDER+".ASHW"   [ASW]
  Local File =ACTX.AFOLDER+".AFONCTION"   [AFC]
 Endif
 Read [ASW]ASW0 = [L]CODREP
 If fstat
  #This representation doesn't exist
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(8,149,1),[L]CODREP))
  Goto FIN_CHECK_ASW
 Endif
 If !func ASYRFNC.ACTIVDOS(ACTX.AFOLDER,[F:ASW]CODACT)
  #Représentation inactive
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(22,140,1)-[L]CODREP-"("+[F:ASW]CODACT+")")
  Goto FIN_CHECK_ASW
 Endif
 #108869
 #If [F:ASW]AFCRIGHT<>"" & [L]CODFAC<>"$lookup"
 If CHECKRIGHT & [F:ASW]AFCRIGHT<>"" & [L]CODFAC<>"$lookup"
  ERROR = fmet ACTX.AGETAFCRIGHT(ACTX,[F:ASW]AFCRIGHT,[V]CST_ATRUE)
  If ERROR : Goto FIN_CHECK_ASW : Endif
 Endif
 If [F:ASW]FONCTION<>""
  Read [AFC]CODINT=[F:ASW]FONCTION
  If fstat
   [L]CODFNC="R_"+[L]CODREP
   [L]MODULE=[F:ASW]MODULE
  Else
   [L]CODFNC=[F:ASW]FONCTION
   [L]MODULE=[F:AFC]MODULE
  Endif
 Else
   [L]CODFNC="R_"+[L]CODREP
   [L]MODULE=[F:ASW]MODULE
 Endif
 If [L]CODFAC<>""
  WENAFAC=1
  Case [L]CODFAC
  When "$query"   : WENAFAC=[F:ASW]ENAFAC(2) :# Query
                    [L]CODFNC="R_"+[L]CODREP
                    [L]MODULE=[F:ASW]MODULE
  When "$bulk"    : WENAFAC=[F:ASW]ENAFAC(2) :# Query
                    [L]CODFNC="R_"+[L]CODREP
                    [L]MODULE=[F:ASW]MODULE
  When "$details" : WENAFAC=[F:ASW]ENAFAC(0) :# Detail
                    [L]CODFNC="R_"+[L]CODREP
                    [L]MODULE=[F:ASW]MODULE
  When "$edit"    : WENAFAC=[F:ASW]ENAFAC(1) :# Edit
  When "$lookup"  : WENAFAC=[F:ASW]ENAFAC(3) :# lookup
  When "$summary" : WENAFAC=[F:ASW]ENAFAC(4) :# Summary
                    [L]CODFNC="R_"+[L]CODREP
                    [L]MODULE=[F:ASW]MODULE
  Endcase
  If WENAFAC<>2
   #La facette $1$ de la représentation $2$ n'est pas accessible
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(14,149,1),[L]CODFAC,[L]CODREP))
   Goto FIN_CHECK_ASW
  Endif
 Endif
 If [L]CODCLA<>"" & [F:ASW]CODCLA<>[L]CODCLA
  #La classe $1$ ne correspond pas à la représentation $2$
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,ERROR,[V]CST_AHTTP_NOT_ACCEPTABLE,func ASYRFNC.MES2(mess(22,149,1),[L]CODCLA,[L]CODREP))
  Goto FIN_CHECK_ASW
 Elsif [L]CODCLA=""
  ERROR = func ACLAVAL._CHECK_ACLA(ACTX,[F:ASW]CODCLA,[L]CODFAC)
  If ERROR : Goto FIN_CHECK_ASW : Endif
  [L]CODCLA=[F:ASW]CODCLA
 Endif
 ERROR =  func ASHWVAL._DEFERRED_VALIDATION(ACTX,"R_"+[L]CODREP)
 If ERROR : Goto FIN_CHECK_ASW : Endif
Endif

$FIN_CHECK_ASW
LogicClose File
End ERROR

