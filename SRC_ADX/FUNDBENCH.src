#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
#---------------------------------------------------------------------------#
# Action FMFGD Plan de travail
#---------------------------------------------------------------------------#
$ACTION
If pat(ACTION,"BB*_NBLIG")
   Gosub RECHARG_PARAM
   Gosub LECTURE_BTS    : # Issue 96456 GH 14/06/2018 - More general than before (button 4)
Endif
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "AVANT_BOUTON"  : Gosub AVANT_BOUTON
    When "BOUTON"        : Gosub BOUTON
    When "MEN"           : Gosub BOUTON
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "EDI"           : Gosub EDITION
    When "TERMINE"       : Gosub TERMINE
    When "AB12_NBLIG"    : Gosub AB12_NBLIG
    When "BB12_NBLIG"    : Gosub BB12_NBLIG
    When "AB5_NBLIG"     : Gosub MEM_VCR From BENCHLIB
    When "AB14_NBLIG"    : Gosub MEM_VCR From BENCHLIB
    When "AB15_NBLIG"    : Gosub MEM_VCR From BENCHLIB
Endcase
Return

#########################################################################
$INIT
Global Char    GMDLNUM(GLONTRS)
GMDLNUM = ""
Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# sr 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:ACC])=0 : Local File ACCES    [ACC] : Endif
If clalev ([F:BTS])=0 : Local File BENCHTRS [BTS] : Endif

# Issue 77003 - 2011-11-21 by CCC : bloc déplacé en 1ère position
# si on vient du planning global, on vérifie si un code transaction est passé
If (left$(GFONCTION,9) = "FUNGBENCH" | left$(GFONCTION,8) = "FUNMPICK")
    # si on vient accidentellement (on a pas fait de sélection dans zoom encours associé mais l'action
    # suite s'exécute quand même ...
    If GSTATUT = 7 : OK = 0 : GSTATUT = 0 : Return : Endif
Endif

# FQ 45926 & 45702 GA 02/2008
# Transaction par défaut sur menu FUNDBENCH ou FUNDBENCHA
If dim(PARAM(5))>0 & PARAM(5)> ""
    GMDLNUM = PARAM(5)
    Gosub LECTURE_BTS
    OK = 0
    Return
Else
    Raz [F:BTS]
Endif

# si on vient du planning global, on vérifie si un code transaction est passé
If (left$(GFONCTION,9) = "FUNGBENCH" | left$(GFONCTION,8) = "FUNMPICK")
# Issue 77003 - 2011-11-21 by CCC
#    # si on vient accidentellement (on a pas fait de sélection dans zoom encours associé mais l'action
#    # suite s'exécute quand même ...
#    If GSTATUT = 7 : OK = 0 : GSTATUT = 0 : Return : Endif
   # 03.08 45981
    If dim([M:MGB]TRS) > 0 & [M:MGB]TRS <> ""
            Read [BTS]BTS0=52;[M:MGB]TRS
            If fstat | [F:BTS]ENAFLG=1  : Return : Endif
            GMDLNUM = [F:BTS]BTSNUM
            OK = 0
            Return
    Endif
Endif

CRITERE = "BTSTYP=52&ENAFLG=2"

#---------
# PE pour initialisation
GPOINT = "FILTER_TRS"
Gosub  ENTREE From EXEFNC
#---------

# sr 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif

If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=52;GFLAG
    Filter [BTS]
    If !fstat
        GMDLNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif

If GMDLNUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return


###########################################################################
$FIN_LISTE
GMDLNUM = TEX(CHOIX)
Return


###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=52;GMDLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

Return

###########################################################################
# Initialisation/ouverture tables/substitution fenêtre
#########################################################################
$OUVRE
Global Integer GBFIRST  :             GBFIRST = 0
Global Integer GBMAX
Global Integer GBNOPROD, GBNOACH
Global Integer GDLRET :               GDLRET = 0
Global Integer GWNBT :                GWNBT = 13
Global Integer GKILL
If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
    Kill GKILL
Endif
Local Char    WFCY(GLONFCY)
Local Char    WPLN(GLONAUS)  : # Planificateur
Local Date    WDAT
Local Char    WITM(GLONITM)
Local Char    WTRS(GLONTRS)
Local Char    WORI
Local Integer WSRT  # 22206 MM 01.05
Local Integer WRET : WRET = 0
Local Char    WDATC
Local Char    CODE(3)
Local Integer RETOUR
Local Integer L,I,IRET
Local Integer REPONSE
Local Date    WDATBES
Local Integer WSRT
Local Char    WPJT(GLONPJT)
Local Char    WVCR(GLONVCR)
Local Char    WBPR(GLONBPR)
Local Date    WSTRDAT
Local Date    WENDDAT
Local Integer WFLT
Local Integer STA
Local Char    WVCRNUM(GLONVCR)
Local Integer WSTA
Local Integer WTYPE, WAPP, WPRO, WINT, WSCO
Local Integer WSOSCOD
Local Char    IMPMSK(GLONAMK)
Local Integer WCTLCOD
Local Char    WMASQUE(GLONAMK)
Local Integer ISINTERCPY
Local Integer WTRI
Local Char    WITMREF(GLONITM)
Local Integer WOK
Local Char    WECCMAJ(GLONICVVAL), WECCMIN(GLONICVVAL) # Issue 104943 - 2015-07-20 by BEEBE : implementing versioning

# ouverture des tables
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:ATZ])  = 0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:BTS]) <= 0 : Local File BENCHTRS   [BTS] : Endif
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TRP]) <= 0 : Local File TABREOPOL  [TRP] : Endif
If clalev ([F:PCB]) <= 0 : Local File PARMRP     [PCB] : Endif
If clalev([F:CAL])  <=0  : Local File CPTANALIN  [CAL] : Endif
If clalev([F:DTR])  <=0  : Local File DIETRS     [DTR] : Endif

If clalev ([F:BPD]) <= 0 : Local File BPDLVCUST  [BPD] : Endif
If clalev ([F:BPR]) <= 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPC]) <= 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TWD]) <= 0 : Local File TABWEEDIA  [TWD] : Endif
If clalev ([F:TUV]) <= 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:EVL]) <= 0 : Local File ECCVAL     [EVL] : Endif # Issue 111122 - 2015-10-19 by GH

If dim(GRCPFCY)<0 : Global Char GRCPFCY(GLONFCY) : Endif

If GMODU(8) = 2
    If clalev ([F:MTS]) <= 0 : Local File MFGTRS    [MTS] : Endif
    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD   [MFG] : Endif
    If clalev ([F:MFI]) <= 0 : Local File MFGITM    [MFI] : Endif
    If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
    ## GH 19/05/2014 bug 100108 société et législation non encore déterminées ici
    #Call LECTCA(8,WOK) From SUBTCA
    #If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
    #GOPS    = [F:TCA]CODNUM(4)   # compteur suggestion opérations
Endif

If GMODU(6) = 2
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
    If clalev ([F:POH]) <= 0 : Local File PORDER     [POH] : Endif
    If clalev ([F:POP]) <= 0 : Local File PORDERP    [POP] : Endif
    If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([F:PSD]) <= 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:SCO]) <= 0 : Local File SCOHEAD    [SCO] : Endif
    If clalev ([F:SCI]) <= 0 : Local File SCOITM     [SCI] : Endif
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
Endif

If GMODU(5) = 2
    If clalev ([F:SOH]) <= 0 : Local File SORDER     [SOH] : Endif
    If clalev ([F:SOP]) <= 0 : Local File SORDERP    [SOP] : Endif
    If clalev ([F:SOQ]) <= 0 : Local File SORDERQ    [SOQ] : Endif
    If clalev ([F:SOC]) <= 0 : Local File SORDERC    [SOC] : Endif
    If clalev ([F:SDH]) <= 0 : Local File SDELIVERY  [SDH] : Endif
    If clalev ([F:SDD]) <= 0 : Local File SDELIVERYD [SDD] : Endif
Endif

# masque pour paramètres mises à jour
Local Mask ORCK [ORCK]
Local Mask MFGK [MFGK]
Local Mask SCOK [SCOK]  : # GA 02/2006
If clalev ([M:ORDK]) <= 0 : Local Mask ORDK [ORDK] : Endif # Issue 108577 - by GA 07/2015

# 15806 MM 05.05  : pour memo
If clalev ([M:MFB4]) <= 0 :  Local Mask MFGBCRIT4   [MFB4] : Endif

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

# mise en relief affectations
Gosub OPEN_HL_TABLIN From HLIGHTLIB

# chargement des paramètres action
WFCY    = PARAM(1)
WPLN    = PARAM(2)
WDATC   = PARAM(3)
WITM    = PARAM(4)
WTRS    = PARAM(5)
WORI    = PARAM(6)         # 22206 MM 01.05
WSRT    = val(PARAM(7))    # 22206 MM 01.05

# Issue 104943 - 2015-07-20 by BEEBE : implementing versioning
If dim(PARAM(9))>0  : WECCMAJ=PARAM(9)  : Endif
If dim(PARAM(10))>0 : WECCMIN=PARAM(10) : Endif

# si zoom encours associé depuis planning global
If dim(GZOOM) > 0
    If GZOOM
        WFCY = GZOOMFCY
        WITM = GZOOMITM
    Endif
Endif

Gosub LECTURE_BTS

# initialisations
WAPP = 0
WPRO = 0
WINT = 0
WSCO = 0
If [F:BTS]APPSUG = 2 : WAPP += 1 : Endif
If [F:BTS]APPPLN = 2 : WAPP += 2 : Endif
If [F:BTS]APPLAN = 2 : WAPP += 4 : Endif
If [F:BTS]PLNSUG = 2 : WPRO += 1 : Endif
If [F:BTS]PLNPLN = 2 : WPRO += 2 : Endif
If [F:BTS]PLNLAN = 2 : WPRO += 4 : Endif
If [F:BTS]INTSUG = 2 : WINT += 1 : Endif
If [F:BTS]INTPLN = 2 : WINT += 2 : Endif
If [F:BTS]INTLAN = 2 : WINT += 4 : Endif
If [F:BTS]SCOSUG = 2 : WSCO += 1 : Endif
If [F:BTS]SCOPLN = 2 : WSCO += 2 : Endif
If [F:BTS]SCOLAN = 2 : WSCO += 4 : Endif

# substitution fenêtre
BOITE     = "WFMFGD"+GMDLNUM
WMASQUE   = "WT52"+GMDLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY

Gosub CHANGE_AWI From BENCHLIB

Return

#########################################################################
$TIT
Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
Call TITAWI(BOITE,GMESSAGE) From OBJDIV
TIT = GMESSAGE-[F:BTS]BTSNUM-":"-TIT
GMESSAGE=""
Return

#########################################################################
# alimentation initiale écran
$DEBUT
Raz [M:MGD]

# FQ 74895 GA 07/2011 déplacé avant recopie des autres critères et déclenché de façon systématique, même si appel en tunnel
# 15806 MM 05.05 : application memo STD
# If WORI=""
    Raz [M:MFB4]
    If filinfo(filpath("ETM",GUSER+"_"+GMDLNUM+"_"+"STD","mfd",0),0)>=0
        Call LECMEMO("STD","[M:MFB4]",GMDLNUM+"~mfd") From GMEMO
        # On applique le code mémo STD si c'est la transaction à laquelle il se rapporte
        [M:MGD]        = [M:MFB4]
    Endif
# Endif

If WFCY <> "" : [M:MGD]FCY     = WFCY : Else : [M:MGD]FCY     = GFCYDEF(7) : Endif
GFCY = [M:MGD]FCY : Gosub CHARG_PARAM
If GMODU(8)=2 & GOPS="" : Raz [M:MGD]FCY : Endif : ## GH 19/05/2014 bug 100108
If WPLN <> "" : [M:MGD]PLANNER = WPLN : Else : [M:MGD]PLANNER = GUSER      : Endif
If WDATC <> ""
    If instr(1,WDATC,"/")
        WDAT = "["+WDATC+"]"
    Else
        WDAT = WDATC
    Endif
Endif
If WDAT <> [0/0/0] : [M:MGD]MSTDAT = WDAT : Else : [M:MGD]MSTDAT = date$+(GPLNHOR*7) : Endif

If WITM <> ""
    [M:MGD]ITMREF     = WITM
    Call C_ITMREF([M:MGD]ITMREF)
    Call AM_ITMREF([M:MGD]ITMREF)
Elsif dim([M:MGD]IECCVALMAJ)>0
    Diszo [M:MGD]IECCVALMIN
    Diszo [M:MGD]IECCVALMAJ
Endif

If WSRT<>0 : # GH 05/12/12 bug 86277
    [M:MGD]SRTCOD     = WSRT
Endif
If [M:MGD]SRTCOD  = 0 : [M:MGD]SRTCOD = 5 : Endif

# mémorisation contexte habilitation suivant transaction
Gosub ANALYSE_CTX

# mémorisation nombre de ligne maxi
GBMAX = dim([M:MGD]WIPTYPSTA)

# Issue 104943 - 2015-07-20 by BEEBE : Implementing Versioning
If dim([M:MGD]IECCVALMAJ)>0
    If varmode([M:MGD]IECCVALMAJ)=0 : [M:MGD]IECCVALMAJ=WECCMAJ : Endif
    If varmode([M:MGD]IECCVALMIN)=0 : [M:MGD]IECCVALMIN=WECCMIN : Endif
Endif

If WFCY <> "" & WITM <> ""
    IRET = GDLRET
    [M:MGD]REACT = 2
    Gosub REACTUALISATION
    [M:MGD]REACT = 1
    GDLRET = IRET
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGD]ICRID)>0
   Diszo [MGD]ICRID
   If func ECCLIB.NBRCPN([M:MGD]ITMREF)>0 : # already done via AM_ITMREF for a product with no version
      [M:MGD]ICRID = func TRTX3FNC.CCMID([M:MGD]ITMREF,[M:MGD]IECCVALMAJ,[M:MGD]IECCVALMIN)
      If dim([M:MGD]ICRFLG)>0
         [M:MGD]ICRFLG = string$([M:MGD]ICRID<>"","151")
      Endif
   Endif
Endif
If dim([M:MGD]CRID)>0
   Diszo [MGD]CRID
Endif

Diszo [M:MGD]15
Affzo [M:MGD]5-15
Return

#########################################################################
# état des boutons
$SETBOUT
If [M:MGD]ITMREF = ""
 Call VIREBOUT(CHMEN, "AGSDP") From GOBJET
 ## GH 14/09/11 pour que les affectations de ETABOU(GSPEx) qui suivent ne soient plus ignorées
 Gosub SET_BOUT_SPE From GSAISIE
 CHMEN=OCHMEN
Endif

ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
If (WAPP >= 1 | WINT >= 1)  & GMODU(6) = 2            # achat
    ETABOU(GSPE3) = 1
Else
    ETABOU(GSPE3) = 0
Endif
If WPRO >= 1 & GMODU(8) = 2                           # fabrication - 14102 mm 06.06
    ETABOU(GSPE4) = 1
Else
    ETABOU(GSPE4) = 0
Endif
If WSCO >= 1 & GMODU(6) = 2                           # sous-traitance
    ETABOU(GSPE5) = 1
Else
    ETABOU(GSPE5) = 0
Endif
If [M:MGD]ITMREF <> ""                                # graphique
    ETABOU(GSPE6) = 1
Else
    ETABOU(GSPE6) = 0
Endif
If WORI = "G"                                         # planning global
    ETABOU(GSPE7) = 0
Else
    ETABOU(GSPE7) = 1
Endif
If WORI = "P"                                         # regroupement
    ETABOU(GSPE8) = 0
Else
    ETABOU(GSPE8) = 1
Endif
ETABOU(GBFIN) = 1                                     # fin
ETABOU(GEDIT) = 1                                     # hardcopy
Return

########################################################################
$AVANT_BOUTON
Case BOUT
    When "8" : # Issue 110957 - 2015-10-07 by GH
      If dim([M:MGD]IECCVALMAJ)>0
          WECCMAJ = [M:MGD]IECCVALMAJ
          WECCMIN = [M:MGD]IECCVALMIN
      Else
          Raz WECCMAJ, WECCMIN
      Endif
Endcase
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub RECHERCHER
    When "2"       :     Gosub CRITERES
    When "3"       :     Gosub ACHAT
    When "4"       :     Gosub FABRICATION
    When "5"       :     Gosub SOUSTRAIT
    When "7"       :     Gosub PLANNING
    When "8"       :     Gosub REGROUPEMENT
    When "T"       :     Gosub LECTURE_BTS                # rechargement BTS après visualisation
Endcase
FIN=0
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub RECHERCHER
Endif
Return

#########################################################################
$RECHERCHER
# FQ 60065 GA 11/2009
If [M:MGD]ITMREF = "" | [M:MGD]FCY = ""
# Aucun article-site ne correspond aux critères de sélection saisis
   GMESSAGE=mess(114,184,1)
   GERR = 2 : Return
Endif
Gosub LECTURE_BTS
IRET = GDLRET
[M:MGD]REACT = 2
Gosub REACTUALISATION
[M:MGD]REACT = 1
GDLRET = IRET
Return

#########################################################################
$CRITERES
Gosub REACTUALISATION
Return

#########################################################################
$ACHAT
$FABRICATION
$SOUSTRAIT
$PLANNING
$REGROUPEMENT

Gosub RECHARG_PARAM
Gosub LECTURE_BTS
Gosub REACTUALISATION
Return

#########################################################################
$REACTUALISATION
If [M:MGD]REACT = 2
    Gosub CHARGE_MGD
    If nolign = GBMAX : GMESSAGE = mess(168,190,1) : GERR = 2 : Endif
    [M:MGD]REACT = 1
    GDLRET = 2
Endif
Return

############################################################################
$EDITION
Call PRTSCR(WMASQUE,"MGD","",0,0) From ATRTX3
# Issue 77648 - 2011-11-08 by VPO : edition partait à la sortie de la fonction
Call IMPSCR From ATRTX3
Return

#########################################################################
$TERMINE
Raz GMESSAGE
PARAM(7) = num$(GDLRET)
If GDLRET = 2 & left$(GFONCTION,9) = "FUNGBENCH"
   # 03.08 45981
    If dim([M:MGB]TRS) > 0
        [M:MGB]REACT = 2
        Gosub FABRICATION From FUNGBENCH
    Endif
Endif

If dim(GKILL) < 0
    If dim(GVCR) > 0 : Kill GVCR : Endif
    If dim(GLIN) > 0 : Kill GLIN : Endif
    If dim(GSEQ) > 0 : Kill GSEQ : Endif
Else
    Kill GKILL
Endif
GBNOACH = 1
GBNOPROD = 1
If dim(GZOOM) > 0
    If GZOOM
        GZOOM = 0
        Raz GZOOMFCY
        Raz GZOOMITM
    Endif
Endif
Call IMPSCR From ATRTX3
Return

########################################################################
# Analyse et mémorisation contexte
########################################################################
$ANALYSE_CTX
[M:MGD]PLNHAB = WPRO
[M:MGD]APPHAB = WAPP
[M:MGD]INTHAB = WINT
[M:MGD]SCOHAB = WSCO

# pour les sélections article/site
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 1
    [M:MGD]ITMCAT = "23"
Endif
If [F:BTS]PLANNER = 1 & [F:BTS]BUYER = 2
    [M:MGD]ITMCAT = "14"
Endif
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 2
    [M:MGD]ITMCAT = "1234"
Endif

#   filtre sur planificateur
If [F:BTS]APPLAN = 1 | GBUYFLT = 1
    Case GPLNFLT
        When 2: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER|PLANNER=""'
        When 3: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER'
    Endcase
Else
    # GH 24/08/11 bug 75840
    # Case GPLNFLT
    #    When 2: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER|PLANNER=""|BUY=[M:MGD]PLANNER'
    #    When 3: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER|BUY=[M:MGD]PLANNER'
    # Endcase
    Case GPLNFLT
        When 1: [M:MGD]ITMFILTER = 'BUY=[M:MGD]PLANNER|BUY=""'
        When 2: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER|PLANNER=""|BUY=[M:MGD]PLANNER|BUY=""'
        When 3: [M:MGD]ITMFILTER = 'PLANNER=[M:MGD]PLANNER|BUY=[M:MGD]PLANNER|BUY=""'
    Endcase
Endif

If [M:MGD]MEMO = "" : # GH 05/12/12 bug 86277
    [M:MGD]FORMULE = [F:BTS]DEFFOR

    # 21180 MM 01.05 : filtre "origine des suggestions" provenant de la transaction, appliqué par défaut
    [M:MGD]MRPFLG = [F:BTS]MRPFLG
Endif

Return

###########################################################################
# Chargement du masque
$CHARGE_MGD
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)
Local Char    XCRITERE3(255)
Local Char    XCRITERE4(255)
Local Char    FORMULE1(255)
Local Char    CUSFLT(255)
Local Decimal WQSOS             # Quantité ordres prévisions
Local Char    ECCFLTMAJ # Issue 104943 - implementing versioning
Local Char    ECCFLTMIN # Issue 104943 - implementing versioning

Dela 0,[M:MGD]NBLIG+1 [M:MGD]NBLIG

Gosub LOAD_FILTER From BENCHLIB

If XCRITERE1  = "" : XCRITERE1  = "1=2" : Endif
If XCRITERE2  = "" : XCRITERE2  = "1=2" : Endif
If XCRITERE3  = "" : XCRITERE3  = "1=2" : Endif
If XCRITERE4  = "" : XCRITERE4  = "1=2" : Endif

# analyse présence formule de sélection
If [M:MGD]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:MGD]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

# Issue 104943 - 2015-06-30 by BEEBE : implementing versioning
ECCFLTMAJ="1=1"
ECCFLTMIN="1=1"
If dim([M:MGD]IECCVALMAJ)>0
    If [M:MGD]IECCVALMAJ<>""
        ECCFLTMAJ="ECCVALMAJ = [M:MGD]IECCVALMAJ"
        If [M:MGD]IECCVALMIN<>""
            ECCFLTMIN="ECCVALMIN = [M:MGD]IECCVALMIN"
        Endif
    Endif
Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections (09.04 24686)
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

Filter [ORD] Where STOFCY = [M:MGD]FCY     &
&                      ITMREF = [M:MGD]ITMREF  &
&                      ENDDAT <= [M:MGD]MSTDAT &
&                      (evalue(XCRITERE1)|evalue(XCRITERE2)|evalue(XCRITERE3)|evalue(XCRITERE4))&evalue(FORMULE1)&evalue(CUSFLT) &
&                      evalue(ECCFLTMAJ) & evalue(ECCFLTMIN)
&                      Order By Key ORD1

# unification chargement du tableau entre plan de travail et affectations ...
Default Mask [MGD]
Gosub LOAD_MGD_MLB From BENCHLIB

Filter [ORD]

# Affichage du plan de travail selon les règles du MRP - 38764 mm 12.06
If [F:BTS]HORDEM = 2 & WQSOS <>0
    WQSOS = 0
    Gosub DISPLAY_MRP From BENCHLIB
Endif

Gosub TRI_TAB
Gosub LOAD_EXTQTY From BENCHLIB
Gosub HIGHLIGHT

Return

####################################################################
$HIGHLIGHT
Affzo [M:MGD]20

# mise en relief affectations
[M:HLIK]ABB          = "MGD"
[M:HLIK]VARABS       = "NBLIG"
[M:HLIK]NBREX        = 0

# réinitialisation style
Chgstl [M:MGD]NBLIG  With ""

# application style
For I =0 To [M:MGD]NBLIG - 1
    [M:HLIK]LINNUM = I
    [M:HLIK]STYLE = ""

    If dim(GVCR) > 0 & [M:MGD]VCRNUM(I) = GVCR   # FQ 67481 GVCR inexistant
        [M:HLIK]STYLE = "MTOLINKD"
        Goto NXT_HIGH
    Endif
    If [M:MGD]SHTQTY(I) > 0 & ([M:MGD]SHTQTY(I) > [M:MGD]MTOQTY(I))
        [M:HLIK]STYLE = "MTOLINKC"
        Goto NXT_HIGH
    Endif
    If ([M:MGD]MTOQTY(I) > 0 | [M:MGD]ALLQTY(I) > 0)
        If [M:MGD]RMNEXTQTY(I) <= [M:MGD]MTOQTY(I) + [M:MGD]ALLQTY(I)
            [M:HLIK]STYLE = "MTOLINKA"
        Else
            [M:HLIK]STYLE = "MTOLINKB"
        Endif
        Goto NXT_HIGH
    Endif
$NXT_HIGH
    GPOINT = "STYLE" : Gosub ENTREE From EXEFNC : # GH 19/01/12 dm 78713
    If [M:HLIK]STYLE<>""
       Gosub STYLE_HL_TABLIN From HLIGHTLIB
    Endif
Next I
Return

###########################################################################
# 22206 MM 01.05 : tri selon date besoin
$TRI_TAB
If [M:MGD]NBLIG <> 0
   #----------------------------------------------------------------------------------------------
    GPOINT = "CUSSRT"
    WTRI = 0
    Gosub  ENTREE From EXEFNC
    If !WTRI
        # FQ 67298 GA 09/2010 ajout VCRNUM dans les tris
        Case [M:MGD]SRTCOD
            When 5 : Sorta [M:MGD]NBLIG [M:MGD]NBLIG Order By [M:MGD]ENDDAT(indice), [M:MGD]WIPTYP(indice),[M:MGD]VCRNUM(indice)    # date fin
            When 6 : Sorta [M:MGD]NBLIG [M:MGD]NBLIG Order By [M:MGD]REQDAT(indice), [M:MGD]WIPTYP(indice),[M:MGD]VCRNUM(indice)    # date besoin
        Endcase
    Endif
Endif
Return

############################################################
$AFF_DES
Local Integer    WSEM      : WSEM = 1  : # Premier jour ouvré semaine
Local Integer    WCOR
Local Decimal    WDEL
Local Integer    WCOD
Local Date       WDAT
Local Decimal    WDMYI
Local Date       WDMYD
Local Char       WPAR(1)

Call PARAM([M:MGD]FCY,"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
   WSEM = 1
Else
   WSEM = val(WPAR)
Endif

[M:MGD]STU     = [F:ITM]STU
[M:MGD]PURFLG  = [F:ITM]PURFLG
[M:MGD]MFGFLG  = [F:ITM]MFGFLG
[M:MGD]SCPFLG  = [F:ITM]SCPFLG
[M:MGD]SCSFLG  = [F:ITM]SCSFLG
[M:MGD]PHAFLG  = [F:ITM]PHAFLG
[M:MGD]GENFLG  = [F:ITM]GENFLG
[M:MGD]TOOFLG  = [F:ITM]TOOFLG
[M:MGD]DLVFLG  = [F:ITM]DLVFLG
[M:MGD]SALFLG  = [F:ITM]SALFLG
[M:MGD]INTFLG  = [F:ITM]INTFLG
[M:MGD]SHR     = [F:ITF]SHR

# calcul date fin horizon demande arrondi fin semaine
If [F:ITF]FOH = 0
   [M:MGD]FOHDAT = [0/0/0]
Else
   If WSEM = 1
      WCOR = 7
   Else
      WCOR = WSEM-1
   Endif
   WCOD = [F:ITF]FOHUOT
   WDEL = [F:ITF]FOH
   WDAT = date$
   Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:MGD]FOHDAT) From CBNLIB
Endif
# calcul date fin horizon ferme
If [F:ITF]PLH = 0
  [M:MGD]PLHDAT = [0/0/0]
Else
  WCOR = 0
  WCOD = [F:ITF]PLHUOT
  WDEL = [F:ITF]PLH
  WDAT = date$
  Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:MGD]PLHDAT) From CBNLIB
Endif
[M:MGD]PLH     = [F:ITF]PLH
[M:MGD]PLHUOT  = [F:ITF]PLHUOT
[M:MGD]XPLHUOT = mess([M:MGD]PLHUOT, 291, 1)
[M:MGD]FOH     = [F:ITF]FOH
[M:MGD]FOHUOT  = [F:ITF]FOHUOT
[M:MGD]XFOHUOT = mess([M:MGD]FOHUOT, 291, 1)
[M:MGD]SAFSTO  = [F:ITF]SAFSTO
[M:MGD]REOMINQTY = [F:ITF]REOMINQTY

Affzo [M:MGD]10-15
Return

####################################################################
$CHARG_PARAM
If dim(GMDLNUM)>0    # FQ 61343 GA 01/2010 pb si appel depuis le plan global (?)
   Call GETCPY(GFCY,"BTS",52,GMDLNUM) From TRTX3CPT
Elsif dim(GMGLNUM)>0
   Call GETCPY(GFCY,"BTS",51,GMGLNUM) From TRTX3CPT
Endif

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
#----- Variables globales Achat
Call GLOBVAR(GFCY)    From WWGLOBACH

## GH 19/05/2014 bug 100108
If GMODU(8) = 2
    If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
    Local Integer WOK
    Call LECTCA(8,WOK) From SUBTCA
    If WOK=0 : GOPS = "" : Else GOPS = [F:TCA]CODNUM(4) : Endif  # compteur suggestion opérations
Endif
Return

## GH 13/09/11 bug 76100
$RECHARG_PARAM
If GFCY<>[M:MGD]FCY
 GFCY=[M:MGD]FCY : Gosub CHARG_PARAM
Endif
Return

########################################################################
$LECTURE_BTS
# Issue 96456 GH 14/06/2018 - Optimisation
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 52 | [F:BTS]BTSNUM <> GMDLNUM
    Read [BTS]BTS0=52;GMDLNUM
    If fstat : Raz [F:BTS] : Endif
Endif
# 09.05 31994
If GMODU(8) = 2
    # FQ 45926 & 45702 GA 02/2008 SEL_TABLE appelée avant OUVRE
    If clalev ([F:MTS]) <= 0 : Local File MFGTRS    [MTS] : Endif
    If [F:BTS]MFGTRS<>""
       If [F:MTS]MTSTYP<>1 | [F:MTS]MTSNUM<>[F:BTS]MFGTRS
          Read [MTS]MTS0=1;[F:BTS]MFGTRS
          If fstat : Raz [F:MTS] : Endif
       Endif
    Else
       If [F:MTS]MTSTYP<>1 | [F:MTS]MTSNUM<>GMFGMTSNUM
          Read [MTS]MTS0=1;GMFGMTSNUM
          If fstat : Raz [F:MTS] : Endif
        Endif
    Endif
Endif
# Achats de sous-traitance: transaction de maj auto d'EO
If GMODU(6) = 2
    # FQ 45926 & 45702 GA 02/2008 SEL_TABLE appelée avant OUVRE
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
    If dim([F:BTS]SCOTRS)>0 & [F:BTS]SCOTRS<>""
       If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>[F:BTS]SCOTRS
          Read [PTR]PTR0=9;[F:BTS]SCOTRS
          If fstat : Raz [F:PTR] : Endif
       Endif
    Else
       If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>GSCOPTRNUM
          Read [PTR]PTR0=9;GSCOPTRNUM
          If fstat : Raz [F:PTR] : Endif
       Endif
    Endif
Endif
Return

###########################################################################
# ETIQUETTES                                                              #
###########################################################################

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : mkstat = 2 : End : Endif
Endif
If [F:ITF]ITMREF <> VALEUR
    Read [ITF]ITF0=VALEUR;[M:MGD]FCY
    If fstat : Raz [F:ITF] : End : Endif
Endif

Gosub AFF_DES

# Issue 104943 - 2015-06-30 by BEEBE : implementing versioning
If dim([M:MGD]IECCVALMAJ)>0
    Effzo [MGD] IECCVALMAJ, IECCVALMIN
    If VALEUR<>""
        Local Integer I
        I=func ECCLIB.NBRCPN(VALEUR)
        If I>0
           Actzo [M:MGD]IECCVALMAJ
        Else
           Diszo [M:MGD]IECCVALMAJ
        Endif
        If I>1
           Actzo [M:MGD]IECCVALMIN
        Else
           Diszo [M:MGD]IECCVALMIN
        Endif
    Else
        Diszo [M:MGD]IECCVALMIN
        Diszo [M:MGD]IECCVALMAJ
    Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGD]ICRID)=1 & func ECCLIB.NBRCPN(VALEUR)<1
    [M:MGD]ICRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [MGD]ICRID
    If dim([M:MGD]ICRFLG)>0
       [M:MGD]ICRFLG = string$([M:MGD]ICRID<>"","151") : Affzo [MGD]ICRFLG
    Endif
Endif
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY : WFCY = [M:MGD]FCY
Local    Char    WART : WART = VALEUR
Local    Char    WUSR : WUSR = [M:MGD]PLANNER

If VALEUR = ""
    GBNOACH  = 1
    GBNOPROD = 1
    End
Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If [F:BTS]APPLAN = 1
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
Else
    Call CTLPLNACH(WFCY, WART, WUSR) From MFGLIB
Endif
If GMESSAGE <> ""
   mkstat = 2
   End
Endif

Call CONTMFGITM(WFCY, 0) From MFGLIB
If mkstat <> 0
    GBNOPROD = 1
    mkstat = 0
Else
    GBNOPROD = 0
Endif
If [M:MGD]PURFLG <> 2 : GBNOACH = 1 : Else : GBNOACH = 0 : Endif

End

########################################
Subprog AV_NBLIG
GUNT1(1) = [M:MGD]STU
End

########################################
Subprog IB_NBLIG
Local Integer L     : L = nolign-1
Local Integer WAPP, WPRO, WINT, WSCO, WRET
Local Char    AUZ(15)

mkstat = 0

GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT7 = ""
GBOUT8 = ""
GBOUT9 = ""
GBOUT10 = ""
GBOUT11 = ""
GBOUT12 = ""
GBOUT13 = ""
GBOUT14 = ""
GBOUT15 = ""
GBOUT16 = ""
GBOUT17 = ""      # Issue 108577 - by GA 07/2015

# Issue 107498/108 - 2016-05-19 by BEEBE : initialize
[M:MGD]PARPJT=""
Raz [M:MGD]PARWIPTYP

If [M:MGD]NBLIG = 0 : End : Endif

WAPP = 0
WPRO = 0
WSCO = 0
WINT = 0
If [F:BTS]APPSUG = 2 : WAPP += 1 : Endif
If [F:BTS]APPPLN = 2 : WAPP += 2 : Endif
If [F:BTS]APPLAN = 2 : WAPP += 4 : Endif
If [F:BTS]PLNSUG = 2 : WPRO += 1 : Endif
If [F:BTS]PLNPLN = 2 : WPRO += 2 : Endif
If [F:BTS]PLNLAN = 2 : WPRO += 4 : Endif
If [F:BTS]INTSUG = 2 : WINT += 1 : Endif
If [F:BTS]INTPLN = 2 : WINT += 2 : Endif
If [F:BTS]INTLAN = 2 : WINT += 4 : Endif
If [F:BTS]SCOSUG = 2 : WSCO += 1 : Endif
If [F:BTS]SCOPLN = 2 : WSCO += 2 : Endif
If [F:BTS]SCOLAN = 2 : WSCO += 4 : Endif

# réajustement suivant habilitation achat + interX
If GBUYFLT = 2 & [M:MGD]PLANNER <> [M:MGD]BUY(L) & [M:MGD]BUY(L) <> ""
    If find(WAPP,4,5,6,7) : WAPP -= 4 : Endif
    If find(WINT,4,5,6,7) : WINT -= 4 : Endif
Endif

# GH 24/08/11 bug 75840
# réajustement suivant habilitation fabrication + sous-traitance
If (GPLNFLT = 2 & !find([M:MGD]PLANNER2(L),[M:MGD]PLANNER,"")) |
&  (GPLNFLT = 3 & [M:MGD]PLANNER2(L)<>[M:MGD]PLANNER)
    If find(WPRO,4,5,6,7) : WPRO -= 4 : Endif
    If find(WSCO,4,5,6,7) : WSCO -= 4 : Endif
Endif

# réajustement si module absent
If GMODU(6) < 2 : WAPP = 0 : WSCO = 0 : WINT = 0 : Endif
If GMODU(8) < 2 : WPRO = 0 : Endif

# si DA obligatoire, l'action commander n'est dispo que sur les DA
If [F:ITM]ITMREF <> [M:MGD]ITMREF
    Read [ITM]ITM0=[M:MGD]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PRQFLG = 2 & WAPP>=4 & ([M:MGD]WIPTYP(L) <> 2 |  [M:MGD]WIPSTA(L) = 3)
    WAPP -= 4
Endif

If [M:MGD]WIPTYPSTA(L) <> "" # Issue 107498/101 - 2016-04-26 by ALSHE : add Project demand
    Case [M:MGD]WIPTYP(L)
      When 1,3,6,8,14 : # Customer order + Subcontracted material + Material requirements + Transfer request + Project demand
              If find([M:MGD]WIPTYP(L),3,6,8,14) # Issue 107498/101 - 2016-04-26 by ALSHE : add Project demand
                    GBOUT5 = mess(384,198,1)
                    If [M:MGD]WIPSTA(L) = 1
                        Call HAB_ACT([M:MGD]FCY, "M", WRET) From BENCHLIB
                        If WRET : GBOUT12 = mess(33,191,1) : Endif    # allocation manuelle
                    Endif
              Endif
              If [M:MGD]WIPSTA(L) = 1 & ([M:MGD]RMNEXTQTY(L) > ([M:MGD]ALLQTY(L) + [M:MGD]MTOQTY(L)))
                  If [M:MGD]PURFLG = 2
                      Case WAPP
                          When 2,3: GBOUT1 = mess(337,198,1)  # demander
                          When 4,5: GBOUT1 = mess(363,198,1)  # commander
                          When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                      Endcase
                      If GBOUT1 = ""
                          Case WINT
                              When 2,3: GBOUT1 = mess(337,198,1)  # demander
                              When 4,5: GBOUT1 = mess(363,198,1)  # commander
                              When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                          Endcase
                      Endif
                  Endif
                  If [M:MGD]MFGFLG = 2
                      Case WPRO
                          When 2,3:   GBOUT2 = mess(495,198,1)  # planifier (fabrication)
                      #   When 2,3:   GBOUT2 = mess(279,198,1)  # planifier                ## GH 07/09/11 bug 76098
                          When 4,5:   GBOUT2 = mess(280,198,1)  # lancer
                          When 6,7:   GBOUT2 = mess(333,198,1)  # planifier/lancer
                      Endcase
                      #If GBOUT2 = ""
                      #    Case WINT
                      #        When 2,3: GBOUT1 = mess(337,198,1)  # demander
                      #        When 4,5: GBOUT1 = mess(363,198,1)  # commander
                      #        When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                      #    Endcase
                      #Endif
                      # GH 14/12/11 bug 78268
                      # Call HAB_ACT([M:MGD]FCY, "P", WRET) From BENCHLIB
                      # If WRET : GBOUT9 = mess(437,198,1) : Endif    # multi-niveaux
                  Endif
                  If [M:MGD]SCPFLG = 2
                      Case WSCO
                          When 2,3: GBOUT3 = mess(496,198,1)    # planifier (sous-traitance)
                      #   When 2,3: GBOUT3 = mess(279,198,1)    # planifier                ## GH 07/09/11 bug 76098
                          When 4,5: GBOUT3 = mess(239,198,1)    # sous-traiter
                          When 6,7: GBOUT3 = mess(474,198,1)    # planifier/sous-traiter
                      Endcase
                  Endif
                  If find(2,[M:MGD]SCPFLG,[M:MGD]MFGFLG) : #  If [M:MGD]MFGFLG=2 : # GH 06/06/2013 bug 90311
                     Call DROITSITEF("FUNDBENCH",[M:MGD]FCY,AUZ,WRET) From CPTSUB
                     If WRET & instr(1,AUZ,"P") : GBOUT9 = mess(437,198,1) : Endif    # multi-niveaux
                  Endif
## GH 25/04/2014 bug 84573
#                  If find([M:MGD]WIPTYP(L),1,8) : # [M:MGD]WIPTYP(L) = 1 & [M:MGD]FMI(L) = 5 : # GH 10/10/12 bug 84957
#                      Read [SOQ]SOQ0=[M:MGD]VCRNUM(L);[M:MGD]VCRLIN(L);[M:MGD]VCRSEQ(L)
#                      If !fstat & [F:SOQ]FMINUM <> ""
#                         Raz GBOUT2, GBOUT3, GBOUT4, GBOUT9 : # GBOUT2="" : GBOUT9="" : # GH 10/10/12 bug 84957
#                      Endif
#                  Endif
                  If find([M:MGD]WIPTYP(L),1,8)
                      Read [SOQ]SOQ0=[M:MGD]VCRNUM(L);[M:MGD]VCRLIN(L);[M:MGD]VCRSEQ(L)
                      If fstat | [F:SOQ]FMINUM <> ""
                         # ctm déjà effectuée
                         Raz GBOUT1, GBOUT2, GBOUT3, GBOUT9
                      Else
                         If !find([F:SOQ]FMI,3,5,6)
                            Local Char    WPTOCOD(GLONPTO)
                            WPTOCOD = func ITMLIB.GET_PTOCOD([M:MGD]ITMREF,[M:MGD]FCY)
                            If [F:PTO]PTOCOD <> WPTOCOD
                                Read [PTO]PTO0=WPTOCOD
                                If fstat : Raz [F:PTO] : Endif
                            Endif
                         Endif
                         If (find([F:SOQ]FMI,3,5,6) | [F:PTO]PTODIR=2)
&                           & func MTOLINKLIB.LINK_EXISTS([M:MGD]FCY,[M:MGD]VCRTYP(L),[M:MGD]VCRNUM(L)
&                                                                   ,[M:MGD]VCRLIN(L),[M:MGD]VCRSEQ(L),[M:MGD]WIPTYP(L))
                            # ctm à effectuer ou affectation 1<=>1 & demande déjà affectée
                            Raz GBOUT1, GBOUT2, GBOUT3, GBOUT9
                         Else
                             Case [F:SOQ]FMI
                               When 3               # ctm = achat
                                 Raz GBOUT2, GBOUT3
                               When 5               # ctm = production
                                 Raz GBOUT1, GBOUT3
                               When 6               # ctm = SST
                                 Raz GBOUT1, GBOUT2
                             Endcase
                         Endif
                      Endif
                  Endif
##
              Endif
              Case [M:MGD]WIPTYP(L)
                When 6,14 : GBOUT8  = mess(273,198,1) # Issue 107498/101 - 2016-04-26 by ALSHE : add Project demand
                When 8    : GBOUT14 = mess(384,198,1)
              Endcase
      When 2: # commande achat
              Case [M:MGD]WIPSTA(L)
                  When 1:    Case WAPP
                                    When 4,5,6,7: GBOUT1 = mess(335,198,1)  # modifier
                             Endcase
                             If GBOUT1 = ""
                                 If WINT >= 4 : GBOUT1 = mess(335,198,1) : Endif
                             Endif
                             GBOUT17 = mess(3,2088,1) : # Issue 108577 by GA 07/2015
                  When 2:    Case WAPP
                                    When 2,3 :    GBOUT1 = mess(335,198,1)  # modifier
                                    When 4,5 :    GBOUT1 = mess(363,198,1)  # commander
                                    When 6,7 :    GBOUT1 = mess(362,198,1)  # modifier/commander
                             Endcase
                             If GBOUT1 = ""
                                 If WINT >= 2 : GBOUT1 = mess(362,198,1) : Endif
                             Endif
                  When 3:    Case WAPP
                                    When 1:   GBOUT1 = mess(335,198,1)  # modifier
                                    When 2:   GBOUT1 = mess(337,198,1)  # demander
                                    When 3:   GBOUT1 = mess(346,198,1)  # modifier/demander
                                    When 4:   GBOUT1 = mess(363,198,1)  # commander
                                    When 5:   GBOUT1 = mess(362,198,1)  # modifier/commander
                                    When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT1 = ""
                                  If WINT >= 1 : GBOUT1 = mess(364,198,1) : Endif
                              Endif
                              If [M:MGD]MFGFLG = 2
                                  Case WPRO
                                        When 2,3:   GBOUT2 = mess(495,198,1)  # planifier (fabrication)
                                  #     When 2,3:   GBOUT2 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                        When 4,5:   GBOUT2 = mess(280,198,1)  # lancer
                                        When 6,7:   GBOUT2 = mess(333,198,1)  # planifier/lancer
                                  Endcase
                              Endif
                              If [M:MGD]SCPFLG = 2
                                  Case WSCO
                                        When 2,3:   GBOUT3 = mess(496,198,1)  # planifier (sous-traitance)
                                  #     When 2,3:   GBOUT3 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                        When 4,5:   GBOUT3 = mess(239,198,1)  # sous-traiter
                                        When 6,7:   GBOUT3 = mess(474,198,1)  # planifier/sous-traiter
                                  Endcase
                              Endif
                              If find(WAPP,1,3,5,7) : GBOUT16=mess(2,24,1)-[M:MGD]WIPTYPSTA(L) : Endif
                              GBOUT7 = mess(499,198,1)    # 106430 - Product usage
              Endcase
      When 4: # sous-traitance
              # si SCF et commande autorisée
              If [M:MGD]WIPSTA(L) = 1
                  If find(WAPP,4,5,6,7)
                      GBOUT1  = mess(363,198,1)  # commander
                  Endif
                  If GBOUT1 = ""
                      If WINT >= 4 : GBOUT1 = mess(362,198,1) : Endif
                  Endif
              Endif
              GBOUT5 = mess(384,198,1)
      When 5: # ordre de fabrication
              Case [M:MGD]WIPSTA(L)
                  When 1: If WPRO >= 4
                              GBOUT2 = mess(335,198,1)    # modifier
                          Endif
                  When 2: Case WPRO
                              When 2,3: GBOUT2 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT2 = mess(280,198,1)  # lancer
                              When 6,7: GBOUT2 = mess(334,198,1)  # modifier/lancer
                          Endcase
                  When 3: If !find([M:MGD]ORI(L),5,6) # FQ 61344 GA01/2010
                             # Encours WOS hors CBN/PDP
                              Case WPRO
                                  When 1:   GBOUT2 = mess(335,198,1)  # modifier
                                  When 2:   GBOUT2 = mess(279,198,1)  # planifier
                                  When 3:   GBOUT2 = mess(345,198,1)  # modifier/planifier
                                  When 4:   GBOUT2 = mess(280,198,1)  # lancer
                                  When 5:   GBOUT2 = mess(334,198,1)  # modifier/lancer
                                  When 6,7: GBOUT2 = mess(333,198,1)  # planifier/lancer
                              Endcase
                          Else
                              # FQ 61344 GA01/2010
                              # Encours WOS provenant du CBN/PDP: pas de maj autorisée
                              Case WPRO
                                  When 2,3: GBOUT2 = mess(279,198,1)  # planifier
                                  When 4,5: GBOUT2 = mess(280,198,1)  # lancer
                                  When 6,7: GBOUT2 = mess(333,198,1)  # planifier/lancer
                              Endcase
                          Endif
                          If [M:MGD]PURFLG = 2
                              Case WAPP
                                    When 2,3: GBOUT1 = mess(337,198,1)  # demander
                                    When 4,5: GBOUT1 = mess(363,198,1)  # commander
                                    When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT1 = ""
                                    Case WINT
                                        When 2,3,4,5,6,7: GBOUT1 = mess(362,198,1)  # demander/commander
                                    Endcase
                              Endif
                          Endif
                          If [M:MGD]SCPFLG = 2
                              Case WSCO
                                    When 2,3:   GBOUT3 = mess(496,198,1)  # planifier (sous-traitance)
                              #     When 2,3:   GBOUT3 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                    When 4,5:   GBOUT3 = mess(239,198,1)  # sous-traiter
                                    When 6,7:   GBOUT3 = mess(474,198,1)  # planifier/sous-traiter
                              Endcase
                          Endif
                          If find(WPRO,1,3,5,7) : GBOUT16=mess(2,24,1)-[M:MGD]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT5 = mess(384,198,1)
              GBOUT6 = mess(282,198,1)
              GBOUT7 = mess(423,198,1)
              GBOUT8 = mess(273,198,1)
              If [M:MGD]WIPSTA(L) = 1
                  Call HAB_ACT([M:MGD]FCY, "A", WRET) From BENCHLIB
                  If WRET : GBOUT10 = mess(56,198,1) : Endif       # allocation OF
              Endif
              If find([M:MGD]WIPSTA(L),1,2)
                  Call HAB_ACT([M:MGD]FCY, "J", WRET) From BENCHLIB
                  If WRET : GBOUT13 = mess(158,198,1) : Endif          # jalonnement
              Endif
      When 7: # ordre inter-site
              Case [M:MGD]WIPSTA(L)
                  When 1:  If WINT >= 4
                               GBOUT1 = mess(335,198,1)  # modifier
                           Endif
                           If GBOUT1 = ""
                               If WAPP >= 4 : GBOUT1 = mess(335,198,1) : Endif
                           Endif
                  When 2:  Case WINT
                              When 2,3: GBOUT1 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT1 = mess(363,198,1)  # commander
                              When 6,7: GBOUT1 = mess(362,198,1)  # modifier/commander
                           Endcase
                           If GBOUT1 = ""
                               If WAPP >= 2 : GBOUT1 = mess(362,198,1) : Endif
                           Endif
                  When 3:  Case WINT
                              When 1:   GBOUT1 = mess(335,198,1)  # modifier
                              When 2:   GBOUT1 = mess(279,198,1)  # demander
                              When 3:   GBOUT1 = mess(345,198,1)  # modifier/demander
                              When 4:   GBOUT1 = mess(363,198,1)  # commander
                              When 5:   GBOUT1 = mess(362,198,1)  # modifier/commander
                              When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                           Endcase
                           If GBOUT1 = ""
                               If WAPP >= 1 : GBOUT1 = mess(364,198,1) : Endif
                           Endif
                           If find(WINT,1,3,5,7) : GBOUT16=mess(2,24,1)-[M:MGD]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT14 = mess(384,198,1)                      # 11295 MM 03.06
      When 9: # sous-produits
              GBOUT5 = mess(384,198,1)
              GBOUT8 = mess(273,198,1)
      When 13: # ordre de sous-traitance
              Case [M:MGD]WIPSTA(L)
                  When 1: If WSCO >= 4
                              GBOUT3 = mess(335,198,1)    # modifier
                          Endif
                  When 2: Case WSCO
                              When 2,3: GBOUT3 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT3 = mess(239,198,1)  # sous-traiter
                              When 6,7: GBOUT3 = mess(475,198,1)  # modifier/sous-traiter
                          Endcase
                  When 3: Case WSCO
                              When 1:   GBOUT3 = mess(335,198,1)  # modifier
                              When 2:   GBOUT3 = mess(279,198,1)  # planifier
                              When 3:   GBOUT3 = mess(345,198,1)  # modifier/planifier
                              When 4:   GBOUT3 = mess(239,198,1)  # sous-traiter
                              When 5:   GBOUT3 = mess(475,198,1)  # modifier/sous-traiter
                              When 6,7: GBOUT3 = mess(474,198,1)  # planifier/sous-traiter
                          Endcase
                          If [M:MGD]MFGFLG = 2
                              Case WPRO
                                    When 2,3:   GBOUT2 = mess(495,198,1)  # planifier (fabrication)
                              #     When 2,3:   GBOUT2 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                    When 4,5:   GBOUT2 = mess(280,198,1)  # lancer
                                    When 6,7:   GBOUT2 = mess(333,198,1)  # planifier/lancer
                              Endcase
                          Endif
                          If [M:MGD]PURFLG = 2
                              Case WAPP
                                    When 2,3: GBOUT1 = mess(337,198,1)  # demander
                                    When 4,5: GBOUT1 = mess(363,198,1)  # commander
                                    When 6,7: GBOUT1 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT1 = ""
                                    Case WINT
                                        When 2,3,4,5,6,7: GBOUT1 = mess(362,198,1)  # demander/commander
                                    Endcase
                              Endif
                          Endif
                          If find(WSCO,1,3,5,7) : GBOUT16=mess(2,24,1)-[M:MGD]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT5 = mess(384,198,1)
              GBOUT6 = mess(282,198,1)
              GBOUT7 = mess(423,198,1)
              If [M:MGD]WIPSTA(L) = 1
                  Call HAB_ACT([M:MGD]FCY, "A", WRET) From BENCHLIB
                  If WRET : GBOUT11 = mess(56,198,1) : Endif       # allocation sous-traitance
              Endif
    Endcase

    If find([M:MGD]WIPSTA(L),1,2)
        Case [M:MGD]WIPTYP(L)
            When 1:       Case [M:MGD]CODOBJ(L)
                            When "SOH"   : GBOUT4 = mess(191,198,1)-[M:MGD]CODCLE(L)  # commande
                            When Default : GBOUT4 = mess(191,198,1)-[M:MGD]CODCLE2(L) # commande
                          Endcase
            When 2,7:     Case [M:MGD]CODOBJ(L)
                            When "PSH" : GBOUT4 = mess(332,198,1)-[M:MGD]CODCLE(L)    # Demande/commande
                            When "POH" : GBOUT4 = mess(332,198,1)-[M:MGD]CODCLE(L)    # Demande/commande
                            When "POD" : GBOUT4 = mess(332,198,1)-[M:MGD]CODCLE2(L)   # Demande/commande
                          Endcase
            When 5,6,9:   GBOUT4 = mess(336,198,1)-[M:MGD]CODCLE(L)                   # ordre de fabrication
            When 4:       Case [M:MGD]ABBFIL(L)
                            When "MFO" : GBOUT4 = mess(336,198,1)-[M:MGD]CODCLE(L)    # ordre de fabrication
                            When "SCS" : GBOUT4 = mess(473,198,1)-[M:MGD]CODCLE(L)    # ordre de sous-traitance
                          Endcase
            When 3,13:    GBOUT4 = mess(473,198,1)-[M:MGD]CODCLE(L)                   # ordre de sous-traitance
            # Issue 107498/101 - 2016-04-26 by ALSHE : add Project demand
            When 14:      GBOUT4 = mess(274,197,1)-[M:MGD]CODCLE(L)                   # Project demand
        Endcase
    Endif

    If [M:MGD]WIPSTA(L) = 1 : GBOUT15 = mess(467,198,1) : Endif : # affectations
Endif

# Issue 107498/108 - 2016-05-19 by BEEBE : load actual PJT in PARPJT for further usage
[M:MGD]PARPJT=[M:MGD]PJT(L)
[M:MGD]PARWIPTYP=[M:MGD]WIPTYP(L)

End

########################################
Subprog AP_NBLIG
Gosub RECHARG_PARAM
End

###########################################################################
# FQ 48587 Fonction de suppression pour les suggestions
Subprog B16_NBLIG
If [M:MGD]WIPSTA(nolign-1) <> 3
   mkstat=2 : GMESSAGE=mess(1,115,1)
Else
   Local Integer WOK : WOK=2
   Call OUINON(mess(123,105,1),WOK) From GESECRAN
   If WOK = 2
       Case [M:MGD]WIPTYP(nolign-1)
           When 2:
               Trbegin [ORD]
               Readlock [ORD]ORD0=[M:MGD]WIPTYP(nolign-1);[M:MGD]WIPNUM(nolign-1);[M:MGD]ITMREF
               If !fstat : Delete [ORD] : Commit : Endif
           When 5:
              Raz [M:MFGK]
              [M:MFGK]CODMAJ = "A"
              [M:MFGK]CODTRS = 2
              [M:MFGK]MFGNUM = [M:MGD]VCRNUM(nolign-1)
              [M:MFGK]MFGFCY = [M:MGD]FCY
              [M:MFGK]MFGSTA = [M:MGD]WIPSTA(nolign-1)
              [M:MFGK]MFGLIN = [M:MGD]VCRLIN(nolign-1)
              [M:MFGK]ITMREF = [M:MGD]ITMREF
              Call MAJ_OF From MFGAUTLIB
           When 7:
               Trbegin [ORD]
               Readlock [ORD]ORD0=[M:MGD]WIPTYP(nolign-1);[M:MGD]WIPNUM(nolign-1);[M:MGD]ITMREF
               If !fstat : Delete [ORD] : Endif
               For [ORD]ORD0 Where (WIPTYP=8) & (ORIFCY=[M:MGD]FCY) & (VCRNUM=[M:MGD]VCRNUM(nolign-1) | VCRNUMORI=[M:MGD]VCRNUM(nolign-1))
                   Readlock [ORD]  Curr
                   If !fstat : Delete [ORD] : Endif
               Next
               Commit
           When 13:
              Raz [M:SCOK]
              [M:SCOK]CODMAJ = "A"
              [M:SCOK]SCONUM = [M:MGD]VCRNUM(nolign-1)
              [M:SCOK]STOFCY = [M:MGD]FCY
              [M:SCOK]SCOSTA = [M:MGD]WIPSTA(nolign-1)
              [M:SCOK]SCILIN = [M:MGD]VCRLIN(nolign-1)
              [M:SCOK]ITMREF = [M:MGD]ITMREF
              Call MAJ_SCO From SCOAUTLIB
        Endcase
        Gosub RECHERCHER # Recharger le tableau ...
   Endif
Endif
End

######################################################################################
## Call correct action for button 7 based on button caption
######################################################################################
Subprog B7_NBLIG
Local Decimal BASPAG
Case GBOUT7
  When mess(423,198,1)
    ## Action FDISPPLN
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "FDISPPLN"
    PARMSK(1) = [M:MGD]FCY
    PARMSK(2) = num$([M:MGD]WIPTYP(nolign-1))
    PARMSK(3) = num$([M:MGD]WIPSTA(nolign-1))
    PARMSK(4) = [M:MGD]VCRNUM(nolign-1)
    PARMSK(5) = [M:MGD]STU
    PARMSK(6) = num$([M:MGD]RMNEXTQTY(nolign-1))
    PARMSK(7) = num$([M:MGD]RMNEXTQTY(nolign-1))
    Call SAISIE_NUM(BASPAG,PARMSK,"IDISPPLN","BENCHLIB","XYZBENCHLIB") From GSAISIE
    GACTION = SAVACT
  When mess(499,198,1)  # 106430 - Purchase planning
    ## Action ITMHIS
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "ITMHIS"
    PARMSK(1) = [M:MGD]ITMREF
    PARMSK(2) = [M:MGD]FCY
    Call TRAITE_NUM(BASPAG,PARMSK,"ITMHIS","TRTITH","",1,"SPEITH") From GTRAITE
    GACTION = SAVACT
Endcase
End


######################################################################################
########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
GFCY = VALEUR
Gosub CHARG_PARAM

## GH 19/05/2014 bug 100108
If GMODU(8)=2 & GOPS="" : # compteur suggestion opérations
   GMESSAGE = mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1) : mkstat=2 : End
Endif

# Issue 83704 missing 37255 mm 08.06
If [F:ITF]STOFCY <> VALEUR & [M:MGD]ITMREF<>""
    Read [ITF]ITF0=[M:MGD]ITMREF;VALEUR
    If fstat : Raz [F:ITF] : End : Endif
    Gosub AFF_DES
Endif

End

########################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : mkstat = 2 : Endif
End

# --------------------------------------------------------------------- #
#     ETIQUETTES UTILISEES PAR ACTION SAISTOALL (ALLOCATIONS MANUELLES) #
#                                                                       #
#                Appelées depuis TRTSTOALLA                             #
# --------------------------------------------------------------------- #

#---------------------------------------------------------------------- #
# Action avant bouton  : Vérifications au préalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenêtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB12_NBLIG
Local Integer WOK, NOL : NOL=nolign-1
If [M:MGD]VCRTYP(NOL) = 36
  Gosub VERIF_EO
Elsif [M:MGD]VCRTYP(NOL) = 10
  Gosub VERIF_OF
# Issue 107498/101 - 2016-06-01 by ALSHE : Control for MTx demands
Elsif [M:MGD]VCRTYP(NOL) = 40
  Gosub VERIF_MT
Endif
Return

#--------------------------------------------------#
# Contrôle de l'OF                                 #
#--------------------------------------------------#
$VERIF_OF
Local Char    SYMBOLE(50)

If clalev([F:MFG])=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFM])=0 : Local File MFGMAT     [MFM] : Endif

# -- Verrouillage de l'OF
SYMBOLE = "MFG"+[M:MGD]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:MGD]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#--------------------------------------------------#
# Contrôle de l'EO                                 #
#--------------------------------------------------#
$VERIF_EO
Local Char    SYMBOLE(50)

If clalev([F:SCO])=0 : Local File SCOHEAD    [SCO] : Endif
If clalev([F:SCM])=0 : Local File SCOMAT     [SCM] : Endif

# -- Verrouillage de l'EO
SYMBOLE = "SCO"+[M:MGD]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:MGD]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

# Issue 107498/101 - 2016-06-01 by ALSHE : Control for MTx demands
#--------------------------------------------------#
# Control of Project Task                          #
#--------------------------------------------------#
$VERIF_MT
Local Char    SYMBOLE(50)
Local Char    PROJECT(40)
Local Char    BUDGET(15)
Local Char    TASK(15)

Local Integer RETSTA

# Issue 107498/108 - 2016-08-16 by JUSYN : check for PJM activity code
If !func AFNC.ACTIV("PJM")
    Return
Endif

# -- Verrouillage de l'MT
RETSTA = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:MGD]PJT(nolign-1), PROJECT, BUDGET, TASK)

SYMBOLE = "PJM"+PROJECT
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE = PROJECT-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC

If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif
Default Mask [ALL]
If [M:MGD]VCRTYP(LNOL)=36
  Gosub CHARGE_EO
Elsif [M:MGD]VCRTYP(LNOL)=10
  Gosub CHARGE_OF
Endif
Return

#--------------------------------------------------#
# Chargement de l'OF                               #
#--------------------------------------------------#
$CHARGE_OF
# lecture de l'OF
If [F:MFG]MFGNUM<>[M:MGD]VCRNUM(LNOL)
    Read [MFG]MFG0=[M:MGD]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:MFM]MFGNUM <> [M:MGD]VCRNUM(LNOL) |
&  [F:MFM]MFGLIN <> [M:MGD]VCRLIN(LNOL) |
&  [F:MFM]BOMSEQ <> [M:MGD]VCRSEQ(LNOL) |
&  [F:MFM]ITMREF <> [M:MGD]ITMREF
    Read [MFM]MFM0=[M:MGD]VCRNUM(LNOL);[M:MGD]VCRLIN(LNOL);[M:MGD]VCRSEQ(LNOL);[M:MGD]ITMREF
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 10
[M:ALL]VCRNUM    = [F:MFM]MFGNUM
[M:ALL]VCRLIN    = [F:MFM]MFGLIN
[M:ALL]VCRSEQ    = [F:MFM]BOMSEQ
[M:ALL]PCU       = [F:MFM]STU
[M:ALL]STU       = [F:MFM]STU
# 11.05 demande 33011
[M:ALL]STOLOC    = [F:MFM]LOC
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:MFM]RETQTY - [F:MFM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:MFM]ALLQTY
[M:ALL]SHTQTY    = [F:MFM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:MFM]RETDAT
[M:ALL]DLVDAT    = [F:MFM]RETDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT      = [F:MFM]LOT
[M:ALL]XLOC      = [F:MFM]LOC
[M:ALL]XSTA      = [F:MFM]STA

If [F:MFM]SCOFLG = 2    : # Prise en compte emplacements sous-traitants
    [M:ALL]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [F:MFM]BOMOPE <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM & OPENUM=[F:MFM]BOMOPE
&                    Order By Key MFO0
        For [MFO]
            [M:ALL]BPCORD = [F:MFO]BPRNUM
            [M:ALL]BPAADD = [F:MFO]BPAADD
            If [M:ALL]BPCORD <> "" : Break : Endif
        Next
        Filter [MFO]
    Endif
Else
    [M:ALL]PECSCOLOC = 1
Endif
#Call WRHAUTO([F:MFM]MFGFCY,[F:MFM]ITMREF,10,0,[M:ALL]PECSCOLOC-1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

# sr 05.05
If find([F:MFM]ALLSTA,2,3)
     [M:ALL]GLOALLQTY = [F:MFM]ALLQTY
Else
     Raz [M:ALL]GLOALLQTY
Endif

Diszo [M:ALL]QTYTOALL
Return



#--------------------------------------------------#
# Chargement de l'EO                               #
#--------------------------------------------------#
$CHARGE_EO
# lecture de l'EO
If [F:SCO]SCONUM<>[M:MGD]VCRNUM(LNOL)
    Read [SCO]SCO0=[M:MGD]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:SCM]SCONUM <> [M:MGD]VCRNUM(LNOL) |
&  [F:SCM]SCILIN <> [M:MGD]VCRLIN(LNOL) |
&  [F:SCM]SCMLIN <> [M:MGD]VCRSEQ(LNOL) |
&  [F:SCM]CPNITMREF <> [M:MGD]ITMREF
    Read [SCM]SCM0=[M:MGD]VCRNUM(LNOL);[M:MGD]VCRLIN(LNOL);[M:MGD]VCRSEQ(LNOL)
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 36
[M:ALL]VCRNUM    = [F:SCM]SCONUM
[M:ALL]VCRLIN    = [F:SCM]SCILIN
[M:ALL]VCRSEQ    = [F:SCM]SCMLIN
[M:ALL]PCU       = [F:SCM]STU
[M:ALL]STU       = [F:SCM]STU
# 11.05 demande 33011
[M:ALL]STOLOC    = [F:SCM]LOC
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:SCM]RETQTY - [F:SCM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:SCM]ALLQTY
[M:ALL]SHTQTY    = [F:SCM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:SCM]DLVDAT
[M:ALL]DLVDAT    = [F:SCM]DLVDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT      = [F:SCM]LOT
[M:ALL]XLOC      = [F:SCM]LOC
[M:ALL]XSTA      = [F:SCM]STA
[M:ALL]PECSCOLOC = 2
#Call WRHAUTO([F:SCM]STOFCY,[F:SCM]CPNITMREF,36,0,1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif
# sr 05.05
If find([F:SCM]ALLSTA,2,3)
     [M:ALL]GLOALLQTY = [F:SCM]ALLQTY
Else
     Raz [M:ALL]GLOALLQTY
Endif

Diszo [M:ALL]QTYTOALL
Return


#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
# allocation matières
If [M:MGD]VCRTYP(LNOL) = 36    #Issue X3-98762 14/08/2018 by GEBIL: Manual allocation from planning: tables desynch =>LNOL not, NOL !
  Gosub AVANT_EO
Elsif [M:MGD]VCRTYP(LNOL) = 10   #Issue X3-98762 14/08/2018 by GEBIL
  Gosub AVANT_OF
Endif
Return

#--------------------------------------------------#
# Contrôle avant enregistrement                    #
#--------------------------------------------------#
$AVANT_OF
Return

$AVANT_EO
Return

#---------------------------------------------------------------------- #
# Mise à jour complémentaires après enregistrement                      #
# Si problème mettre GOK=0 pour annuler l'enregistrement                #
#---------------------------------------------------------------------- #
# WALLQTY contient la quantité allouée                                  #
# WSHTQTY contient la quantité en rupture                               #
#---------------------------------------------------------------------- #
$APRES_STOALL
# allocation matières
If [M:MGD]VCRTYP(LNOL) = 36  #Issue X3-98762 14/08/2018 by GEBIL
  Gosub APRES_EO
Elsif [M:MGD]VCRTYP(LNOL) = 10  #Issue X3-98762 14/08/2018 by GEBIL
  Gosub APRES_OF
Endif
Return

#--------------------------------------------------#
# Mise à jour de l'OF                              #
#--------------------------------------------------#
$APRES_OF
# allocation matières OF
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, [M:ALL]ALLTYP, WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Return : Endif

[M:MGD]REACT = 2
GDLRET = 2
Gosub FABRICATION From FUNDBENCH

Return

#--------------------------------------------------#
# Mise à jour de l'EO                              #
#--------------------------------------------------#
$APRES_EO
# allocation matières EO
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, [M:ALL]ALLTYP, WRET) From SCOALL
If WRET <> 0 : GOK = 0 : Return : Endif

[M:MGD]REACT = 2
GDLRET = 2
Gosub SOUSTRAIT From FUNDBENCH

Return

#---------------------------------------------------------------------- #
# Action apres bouton                                                   #
#---------------------------------------------------------------------- #
$BB12_NBLIG
# Suppression du verrou sur la commande
Unlock=SYMBOLE

Return

###########################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran MFGBCRIT4) 31/01/2005 15:17:19 (MM)
######################################################################################
# 22206 MM 01.05
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,373,1))
    GMENLOC(I)=1
Next I
GMENLOC(5)=0
GMENLOC(6)=0
End

######################################################################################
## Section automatically added (screen MFGBENCHD) 30.06.2015 15:15:01 (BEEBE)
######################################################################################

Subprog C_IECCVALMAJ(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   # Issue 111122 - 2015-10-19 by GH
   #Call CTRECC([M:MGD]ITMREF,"MGD","ECCVALMAJ",VALEUR,[M:MGD]IECCVALMIN,[0/0/0],GERR,GMESSAGE) From ECCLIB
   ## Only Warning Message
   #If find(GERR,1,4)
   #   GERR=2
   #Endif
   Filter [EVL] Where ECCTYP=4
   Look [EVL]EVL1(2) = [M:MGD]ITMREF;VALEUR
   Filter [EVL]
   If fstat>2
      GMESSAGE = mess(308,193,1) # Non-existing version
      mkstat=2 : End
   Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGD]ICRID)=1 & (VALEUR="" | func ECCLIB.NBRCPN([M:MGD]ITMREF)=1)
    [M:MGD]ICRID = func TRTX3FNC.CCMID([M:MGD]ITMREF,VALEUR,"")
    Affzo [MGD]ICRID
    If dim([M:MGD]ICRFLG)>0
       [M:MGD]ICRFLG = string$([M:MGD]ICRID<>"","151") : Affzo [MGD]ICRFLG
    Endif
Endif
End

######################################################################################
Subprog AS_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If [M:MGD]IECCVALMAJ=""
    mkstat=1
Endif
End

######################################################################################
Subprog C_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   # Issue 111122 - 2015-10-19 by GH
   #Call CTRECC([M:MGD]ITMREF,"MGD","ECCVALMIN",[M:MGD]IECCVALMAJ,VALEUR,[0/0/0],GERR,GMESSAGE) From ECCLIB
   ## Only Warning Message
   #If find(GERR,1,4)
   #   GERR=2
   #Endif
   Look [EVL]EVL1(3) = [M:MGD]ITMREF;[M:MGD]IECCVALMAJ;VALEUR;4
   If fstat>2
      GMESSAGE = mess(308,193,1) : # Non-existing version
      mkstat=2 : End
   Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGD]ICRID)=1 & func ECCLIB.NBRCPN([M:MGD]ITMREF)=2
    [M:MGD]ICRID = func TRTX3FNC.CCMID([M:MGD]ITMREF,[M:MGD]IECCVALMAJ,VALEUR)
    Affzo [MGD]ICRID
    If dim([M:MGD]ICRFLG)>0
       [M:MGD]ICRFLG = string$([M:MGD]ICRID<>"","151") : Affzo [MGD]ICRFLG
    Endif
Endif
End

