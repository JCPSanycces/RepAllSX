########################################
Subprog AS_O3(VALEUR)
Variable Integer VALEUR
# Phase III : Transfert compta
# X3 JML 07/05/98 GOPTCPT ???
If [M]PAGE=len(mess(0,667,1))
 mkstat=1 : End : # C'est un tableau de bord
Endif
End

########################################
Subprog AS_O4(VALEUR)
Variable Integer VALEUR
# Phase  IV : Transfert immo
# X3 JML 07/05/98 GOPTIMM ???
If [M]PAGE=len(mess(0,667,1))
 mkstat=1 : End : # C'est un tableau de bord
Endif
End

########################################
Subprog AS_O5(VALEUR)
Variable Integer VALEUR
# Phase   V : Calcul cumuls
If [M]O2=2 | [M]O3=2 | [M]O4=2
 VALEUR = 2
 mkstat=2 : End
Endif
End

########################################
Subprog AS_O7(VALEUR)
Variable Integer VALEUR
# Phase VII : Recalcul modif
If [M]O1=2
 VALEUR = 2
 mkstat=2 : End
Endif
End
########################################
Subprog C_O8(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 | VALEUR>dim([F:GAC]BSEDEB)-1
 VALEUR = 2
 mkstat=2 : End
Endif
End

