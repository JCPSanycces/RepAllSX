#-------------------------------------------------------------------------------------
$ACTION
 Case ACTION
  When "OUVRE" : Gosub OUVRE
  When "DEBUT" : Gosub DEBUT
  When "FIR"   : Gosub FIR
  When "LAS"   : Gosub LAS
  When "PRE"   : Gosub PRE
  When "SUI"   : Gosub SUI
  When Default
 Endcase
Return

#-------------------------------------------------------------------------------------
$OUVRE
 Local Integer LINDICE
 LINDICE = val(PARAM(1)) 
Return

#-------------------------------------------------------------------------------------
$DEBUT
 [M:VA0]=[M:VAT9]
  nolign = LINDICE
 [M:VA1]=[M:VAT9]
Return

#-------------------------------------------------------------------------------------
$FIR
 If dim([M:VAT9]NBHIS)<0 : Return : Endif
 LINDICE=1 
 nolign = LINDICE
 [M:VA1]=[M:VAT9]
Return

#-------------------------------------------------------------------------------------
$LAS
 If dim([M:VAT9]NBHIS)<0 : Return : Endif
 LINDICE=[M:VAT9]NBHIS
 nolign = LINDICE
 [M:VA1]=[M:VAT9]
Return

#-------------------------------------------------------------------------------------
$PRE
 If dim([M:VAT9]NBHIS)<0 : Return : Endif
 If ( LINDICE > 1 ) Then
  LINDICE-=1 
  nolign = LINDICE
  [M:VA1]=[M:VAT9]
 Endif
Return

#-------------------------------------------------------------------------------------
$SUI
 If dim([M:VAT9]NBHIS)<0 : Return : Endif
 If ( LINDICE < [M:VAT9]NBHIS ) Then
  LINDICE+=1 
  nolign = LINDICE
  [M:VA1]=[M:VAT9]
 Endif
Return






