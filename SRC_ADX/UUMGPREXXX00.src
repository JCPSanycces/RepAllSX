#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGPREXXX00   Pre-migration devis                         Module XXX    #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête devis : SQUOTED                                                   #
# ----------------------                                                   #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
#                                                                          #
# Migration en V7 :                                                        #
# ---------------                                                          #
# Détail devis : SQUOTED                                                   #
# ----------------------                                                   #
# Alim. PJT à partir du champ PJT de l'entête devis                        #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS : #pas de dossier histo
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPREXXX00") From LECFIC
  Endif

  Call MAJ_UUMGPREXXX00(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGPREXXX00(DOSSIER)
Value Char DOSSIER

If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

##1 - verifications
####################

If [F:ADS]MODULE(N)<>2 : : # N= no module
  End
Endif

Call ECR_TIME("UUMGPREXXX00 Sales Quote Process : Update SQUOTE") From DOSSUB
Call ECR_TRACE("UUMGPREXXX00 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPREXXX00 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3

Local Integer ERR

# Mise à jour des champs directement par une requête SQL
# contrôle de cohérence quelque soit la version
Gosub TRT_SQL0
If GOK<1 : Goto FIN : Endif

# Passage en V6
If val(VERSION)<GMIGX3VER60
  # Mise à jour des champs par boucle de lecture de la table et maj

  # ----------------------------------------
  # 1- ajouter les colonnes dans la table SQH
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_V6
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"SQUOTE",ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Endif

# Passage en V7
If val(VERSION)<GMIGX3VER70
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table SQD
  # ----------------------------------------
  Gosub ADDCOLV7
  If ERR : Goto FIN : Endif
  # Mise à jour des champs directement par une requête SQL
  Gosub TRT_SQLV7
  If GOK<1 : Goto FIN : Endif
Endif


$FIN
Call ECR_TIME("UUMGPREXXX00 Sales Quote Process END.") From DOSSUB
End

##########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V6
# ----------------------------------------
# 1- ajouter les colonnes dans la table SQH
# 2- ajouter un index unique
# ----------------------------------------
$ADDCOLV6

  # 1- ajouter les colonnes dans la table SQH
  # Ajout du champ BPAORD : Adresse client commande
  Call MIGADDCOL (DOSSIER,"SQUOTE","BPAORD","A",5,1,ERR) From TRTMIG
  If ERR : Return : Endif

  If GACTDEB=2
    # Ajout du champ BPIEECNUM  : Identification CEE
    Call MIGADDCOL (DOSSIER,"SQUOTE","BPIEECNUM","A",20,1,ERR) From TRTMIG
    If ERR : Return : Endif

    Call MIGADDCOL (DOSSIER,"SQUOTE","EECLOC","C",2,1,ERR) From TRTMIG
    If ERR : Return : Endif

  Endif

  # Ajout du champ EECICT : Incoterm
  Call MIGADDCOL (DOSSIER,"SQUOTE","EECICT","A",20,1,ERR) From TRTMIG
  If ERR : Return : Endif

  #2- ajouter un index unique
  #--------------- INDEX ADDITION  ----------#
  Call MIGINDCRE (DOSSIER,"SQUOTE","BPCORD+SQHNUM","","",0,ERR) From TRTMIG
  If ERR : Return : Endif

Return

########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V7
# 1- ajouter les colonnes dans la table SQD
# ----------------------------------------
$ADDCOLV7

# 1- ajouter les colonnes dans la table SQD
# ----------------------------------------
# Ajout du champ PJT : Code affaire
Call MIGADDCOL (DOSSIER,"SQUOTED","PJT","A",40,1,ERR) From TRTMIG
If ERR : Return : Endif

Call MIGVALTAB(DOSSIER,"SQUOTED") From TRTMIG
If ERR : Return : Endif

Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête devis : SQUOTE                                                    #
# ---------------------                                                    #
# Gestion des adresses                                                     #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_V6

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------
#----- Ouverture des fichiers -----#
If clalev([F:SQH]) : Close File [SQH] : Endif
If clalev([F:SQH])  = 0 : Local File =DOSSIER+".SQUOTE"      [SQH]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1, ACLE2
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Filter [SQH] Order By Key CLE=[F:SQH]BPCORD;[F:SQH]SQHNUM

$LOOP_SAL01
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:SQH]BPCORD=ACLE1 & [F:SQH]SQHNUM>ACLE2"
Elsif STOP=2
 STOP = 0
 CRITERE  = "[F:SQH]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

#CRITERE = 'find([F:SQH]SQHNUM, "DEV0108F3100001", "DEV0108F3100004")'


Trbegin [SQH]
GOK = 1

For [SQH]CLE Where evalue(CRITERE)

  If [F:SQH]BPAORD<>'' & [F:SQH]EECICT<>'' & (dim([F:SQH]EECLOC)<0 | [F:SQH]EECLOC<>0) & (dim([F:SQH]BPIEECNUM)<0 | [F:SQH]BPIEECNUM<>'')
      Goto SUITE_LOOP_SAL01
  Endif

  # --- alimentation des champs
  Gosub RECUP_BPR
  # --- alimentation des champs
  Gosub RECUP_BPD

  Rewrite [F:SQH]
  If fstat
    Call ECR_TRACE("File SQUOTE(SQHNUM)"-[F:SQH]SQHNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:SQH]BPCORD
    ACLE2 = [F:SQH]SQHNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_SAL01
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_SAL01
  Endif
Endif

$FIN_SAL01
Filter [SQH]
Gosub UNSET_FIRST From TRTFIRST
Close Local File [SQH], [BPR], [BPC], [BPD]

Call ECR_TIME("UUMGPREXXX00 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB

Return

########################################################################
$RECUP_BPR

    If [F:SQH]BPAORD="" | (GACTDEB=2 & [F:SQH]BPIEECNUM="")
      # --- Alimentation Adresse client commande
      # --- Alimentation n° d'identification CEE
      If [F:BPC]BPCNUM<>[F:SQH]BPCORD
          Read [F:BPC]BPC0 = [F:SQH]BPCORD : If fstat Raz [F:BPC] Endif
      Endif
    Endif

    If [F:SQH]BPAORD=""
      If dim([F:BPC]BPAADD)>0 & [F:BPC]BPAADD<>""
          [F:SQH]BPAORD=[F:BPC]BPAADD
      Else
          If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
              Read [BPR]BPR0=[F:BPC]BPCNUM : If fstat Raz [F:BPR] Endif
          Endif
          [F:SQH]BPAORD=[F:BPR]BPAADD
      Endif
    Endif

    If GACTDEB=2 & [F:SQH]BPIEECNUM=""
      If [F:BPR]BPRNUM<>[F:BPC]BPCINV
          Read [F:BPR]BPR0 = [F:BPC]BPCINV : If fstat Raz [BPR] Endif
      Endif
      [F:SQH]BPIEECNUM=[F:BPR]EECNUM
    Endif

Return

#########################################################################
$RECUP_BPD

     If ([F:SQH]EECICT="" | (GACTDEB=2 & [F:SQH]EECLOC=0))
         # Alimentation incoterm et lieu de transport CEE
         If [F:BPD]BPCNUM<>[F:SQH]BPCORD | [F:BPD]BPAADD<>[F:SQH]BPAADD
             Read [F:BPD]BPD0 = [F:SQH]BPCORD;[F:SQH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:SQH]EECICT="" [F:SQH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:SQH]EECLOC=0 [F:SQH]EECLOC=[F:BPD]EECLOC Endif
     Endif

Return


########################################################################
$TRT_SQL0

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SQH]) : Close File [SQH] : Endif
If clalev([F:SQD]) : Close File [SQD] : Endif
If clalev([F:SQH])  = 0 : Local File =DOSSIER+".SQUOTE"      [SQH]  : Endif
If clalev([F:SQD])  = 0 : Local File =DOSSIER+".SQUOTED"     [SQD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SQD]
GOK = 1

# Suppression des incohérences entre tables avant migration
# A faire pour toutes les versions
Gosub TRT_SQL_00

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SQH],[SQD]
Return
############################################################################
# Migration :                                                              #
# ---------------                                                          #
# Détail devis : SQUOTED                                                   #
# ---------------------                                                    #
# Alim. SALFCY à partir de l'entête si différence                          #
############################################################################
$TRT_SQL_00
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SQUOTED SET SALFCY_0="
REQSQL(1)="(SELECT SQH.SALFCY_0 FROM"-DOSSIER+".SQUOTE SQH WHERE SQH.SQHNUM_0=SQUOTED.SQHNUM_0)"
REQSQL(2)=" WHERE SQUOTED.SALFCY_0<>(SELECT SQH.SALFCY_0 FROM"-DOSSIER+".SQUOTE SQH WHERE SQH.SQHNUM_0=SQUOTED.SQHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

########################################################################
$TRT_SQLV7

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:SQH]) : Close File [SQH] : Endif
If clalev([F:SQD]) : Close File [SQD] : Endif
If clalev([F:SQH])  = 0 : Local File =DOSSIER+".SQUOTE"      [SQH]  : Endif
If clalev([F:SQD])  = 0 : Local File =DOSSIER+".SQUOTED"     [SQD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SQD]
GOK = 1

# Champs à alimenter à partir de la V7
Gosub TRT_SQL_V7

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [SQH],[SQD]
Return

############################################################################
# Migration en V7 :                                                        #
# ---------------                                                          #
# Détail devis : SQUOTED                                                   #
# ----------------------                                                   #
# Alim. PJT à partir du champ PJT de l'entête devis                        #
############################################################################
$TRT_SQL_V7
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+".SQUOTED SET PJT_0="
REQSQL(1)="(SELECT SQH.PJT_0 FROM"-DOSSIER+".SQUOTE SQH WHERE SQH.SQHNUM_0=SQUOTED.SQHNUM_0)"
REQSQL(2)=" WHERE SQUOTED.PJT_0=' '"

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume


