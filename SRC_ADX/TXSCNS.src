#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du masque TXSCNS
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

$OUVRE
Local Integer I, J, K, NOL, COL, MAXLIG, DETSIT, DETCPT, DETBPR, NIVDET
Local Char    FCYCUR(GLONCUR), CRIT1(200), CRIT2(200), CRIT3(200), R1(6), R2(6), R3(6), RTMP(6)
Local Char    CRITACC(50), CRITBPR(50)
Local Char    VIRMEN(20), LIBEL(50), CLETRI(50), RUPT1(20), RUPT2(20), RUPT3(20)
Local Decimal DIV, MNT, MC, MD
Local Char    FRMAFF(80)
NOL = nolign-1
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Return

##########################################
$APRES_MODIF
Case zoncou
 When "C1"    : Gosub PREMIER
 When "C2"    : Gosub PRECEDENT
 When "C3"    : Gosub SUIVANT
 When "C4"    : Gosub DERNIER
 When "L1"    : Gosub PREMLIG
 When "L2"    : Gosub PRECLIG
 When "L3"    : Gosub SUIVLIG
 When "L4"    : Gosub DERNLIG
 When "T1"    : Gosub C_TRI1
 When "T2"    : Gosub C_TRI2
 When "T3"    : Gosub C_TRI3
Endcase
Return

##########################################
$DEBUT
COL = val(right$(zoncou,7))
MAXLIG = dim([M:DIA]AMTVAL)
DIV = [M:TXM1]DIVCOL(COL-1)   :# Diviseur
If !DIV : DIV=1 : Endif
Read [TXS]TXS1 = [M:TXM0]TXSNAM
Read [TXD]TXD0 = [M:TXM0]TXSNAM;NOL+1;COL

# Infos d'en-tête
[M]LIG = NOL+1
[M]INTIT = [M:TXM1]INTIT(NOL)
[M]COL = COL
[M]COLNAM = [M:TXM1]DIVMES(COL-1)
[M]FRM = evalue("[M:TXM3]FRM"+num$(COL)+"(NOL)")
[M]FRMX = "260"
If [F:TXD]DECCOL<>0
 [M]FORMAT = "14."+num$([F:TXD]DECCOL)+"#"
Else
 [M]FORMAT = "14#"
Endif
Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;NOL+1;COL;0
[M]AMTTOT = arr(val([F:TXM]AMTVAL)/DIV,10^-[F:TXD]DECCOL)
[M]UPDVAL = val([F:TXM]UPDVAL)/DIV

# Lignes de détail
CRIT1 = "TXSNAM=[M:TXM0]TXSNAM & VERSION=[M:TXM0]VERSION & LIG=[L]NOL+1 & COL=[L]COL & IND>0"
CRIT1 -= "& (val(AMTDEB)<>0 | val(AMTCDT)<>0)"
DETSIT = 1 : DETCPT = 0 : DETBPR = 0   :# que le détail site
R1 = "FCY"
R2 = "ACC"
R3 = "BPR"
[M]L1 = "009"
[M]L2 = "010"
[M]L3 = "011"
[M]L4 = "012"
[M]C1 = "009"
[M]C2 = "010"
[M]C3 = "011"
[M]C4 = "012"
[M]T1 = 2
[M]T2 = 1
[M]T3 = 1
Gosub CHARGE
Return

##########################################
$SETBOUT
Return

##########################################
$C_TRI
DETCPT = 0
DETBPR = 0
DETSIT = 0
Case [M]T1
 When 2 : DETSIT = 1
 When 3 : DETCPT = 1
 When 4 : DETBPR = 1
Endcase
Case [M]T2
 When 2 : DETSIT = 1
 When 3 : DETCPT = 1
 When 4 : DETBPR = 1
Endcase
If [M]T2<>1
 Case [M]T3
  When 2 : DETSIT = 1
  When 3 : DETCPT = 1
  When 4 : DETBPR = 1
 Endcase
Endif
#Infbox COUZON-num$(NIVDET)-R1-R2-R3
Gosub CHARGE
Return

$C_TRI3
[M]T3 = val(CZ)
Gosub C_TRI
Return

$C_TRI2
[M]T2 = val(CZ)
Case [M]T2
 When 1
  [M]T3 = 1 : Affzo T3
 When 2,3,4
  If [M]T3=1 or [M]T3=[M]T2
   [M]T3 = 1 : Affzo T3
  Endif
Endcase
Gosub C_TRI
Return

$C_TRI1
[M]T1 = val(CZ)
Case [M]T1
 When 2,3,4
  If [M]T2=1 or [M]T2=[M]T1
   [M]T2 = 1 : [M]T3 = 1 : Affzo T2,T3
  Elsif [M]T3=1 or [M]T3=[M]T1
   [M]T3 = 1 : Affzo T3
  Endif
 When 5
  [M]T2 = 1 : [M]T3 = 1 : Affzo T2,T3
Endcase
Gosub C_TRI
Return

##########################################
$CHARGE
NIVDET = DETSIT + DETCPT + DETBPR
Raz CLETRI
Gosub SET_CLETRI

# Alimentation zone Tri
Raz LIBEL
For I=1 To NIVDET
 If LIBEL<>"" : LIBEL -= "+ " : Endif
 Case evalue("R"+num$(I))
  When "FCY"    : LIBEL += mess(12,105,1)
  When "ACC"    : LIBEL += mess(30,105,1)
  When "BPR"    : LIBEL += mess(31,105,1)
 Endcase
Next I
[M]DETSOR = LIBEL

Gosub SET_CRIT
Gosub CHARG_TAB
Affzo [M]
Chgstl [M]FRM0   With "TDB00"
Chgstl [M]AMTVAL With "TDBBLU"
If NIVDET>1
 For I=0 To [M]NBLIG-1
  Case [M]NIV(I)
   When 1 : Chgstl [M]FRM0(I) With "TDB10"
   When 2 : Chgstl [M]FRM0(I) With "TDB02"
  Endcase
 Next I
Endif

FRMAFF = [M]FRM
If find(left$(FRMAFF,1),"-","+")
 FRMAFF = right$(FRMAFF,2)
Endif
If left$(FRMAFF,1)="Q" or find(left$(FRMAFF,2),"NQ","EQ","PQ","GQ")
 Titcol [M]NBLIG mess(44,108,1)  For AMTVAL : # Quantités
Else
 Titcol [M]NBLIG mess(149,111,1) For AMTVAL : # Montants
Endif

If GBROWS : zonsui="NBLIG" : Endif
Return

$SET_CRIT
Raz CRITACC, CRITBPR
If DETBPR
 CRITACC = "TYPAMT=3"
Elsif DETCPT
 CRITACC = "TYPAMT=2"
Else
 CRITACC = "TYPAMT=1"
Endif
Return

##########################################
$CHARG_TAB
Effzo [M:DIA]10, NBLIG
Raz nolign
CRITERE = CRIT1 -"&"- CRITACC
Filter [TXM] Where evalue(CRITERE)
&            Order By Key CLE = evalue(R1);evalue(R2);evalue(R3)
For [TXM]CLE(1)
  RUPT1 = evalue("[F:TXM]"+R1)
  [M]FRM0(nolign) = RUPT1
  RTMP = R1 : Gosub ADDINF
  If NIVDET=1
   Raz MNT, MC, MD
  Else
   [M]INFO(nolign) = RUPT1
   RTMP = R1 : Gosub ADDINFO
   [M]NIV(nolign) = 1
  Endif
  If R1="ACC"
   [M]COMPTE(nolign) = [F:TXM]ACC
  Endif
  For [TXM]CLE(2)
    RUPT2 = evalue("[F:TXM]"+R2)
    If NIVDET>=2
      If NIVDET=2 : Raz MNT, MC, MD : Endif
      nolign+=1 : If nolign>=MAXLIG : Break 2 : Endif
      [M]FRM0(nolign) = "....."-RUPT2
      RTMP = R2 : Gosub ADDINF
      [M]INFO(nolign) = RUPT1
      RTMP = R1 : Gosub ADDINFO
      If NIVDET>2
       [M]INFO(nolign) = RUPT1-RUPT2
       RTMP = R2 : Gosub ADDINFO
       [M]NIV(nolign)   = 2
      Endif
    Endif
    If R2="ACC" | (R2="BPR" & R1="ACC")
     [M]COMPTE(nolign) = [F:TXM]ACC
    Endif
    For [TXM]CLE(3)
      RUPT3 = evalue("[F:TXM]"+R3)
      If NIVDET=3
       nolign+=1 : If nolign>=MAXLIG : Break 3 : Endif
       [M]FRM0(nolign) = ".........."-RUPT3
       RTMP = R3 : Gosub ADDINF
       [M]INFO(nolign) = RUPT1-RUPT2
       RTMP = R2 : Gosub ADDINFO
       Raz MNT,MC,MD
       For [TXM]CLE
        MNT += val([F:TXM]AMTVAL)
        MC  += val([F:TXM]AMTCDT)
        MD  += val([F:TXM]AMTDEB)
       Next
       Gosub SETMNT
      Else
       For [TXM]CLE
        MNT += val([F:TXM]AMTVAL)
        MC  += val([F:TXM]AMTCDT)
        MD  += val([F:TXM]AMTDEB)
       Next
      Endif
      If R3="ACC" | (R3="BPR" & R2="ACC")
       [M]COMPTE(nolign) = [F:TXM]ACC
      Endif
    Next
    If NIVDET=2
     Gosub SETMNT
    Endif
  Next
  If NIVDET=1
   Gosub SETMNT
  Endif
  nolign+=1 : If nolign>=MAXLIG : Break : Endif
Next
Filter [TXM]
[M]NBLIG = nolign
Return

$SETMNT
[M]AMTVAL(nolign) = arr(MNT/DIV,10^-[F:TXD]DECCOL)
[M]AMTCDT(nolign) = arr(MC/DIV,10^-[F:TXD]DECCOL)
[M]AMTDEB(nolign) = arr(MD/DIV,10^-[F:TXD]DECCOL)
Return

$ADDINF
Case RTMP
 When "FCY" :
  If [F:TXM]FCYINF<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]FCYINF : Endif
 When "ACC" :
  If [F:TXM]ACCINF<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]ACCINF : Endif
 When "BPR" :
  If [F:TXM]BPRINF<>"" & [F:TXM]BPR<>"" : [M]FRM0(nolign) -= "-"-[F:TXM]BPRINF : Endif
Endcase
Return

$ADDINFO
Case RTMP
 When "FCY" :
  If [F:TXM]FCYINF<>"" : [M]INFO(nolign) -= "-"-[F:TXM]FCYINF : Endif
 When "ACC" :
  If [F:TXM]ACCINF<>"" : [M]INFO(nolign) -= "-"-[F:TXM]ACCINF : Endif
 When "BPR" :
  If [F:TXM]BPRINF<>"" & [F:TXM]BPR<>"" : [M]INFO(nolign) -= "-"-[F:TXM]BPRINF : Endif
Endcase
Return


##########################################
$SET_CLETRI
Case [M]T1
 When 1 : R1 = "FCY"
 When 2 : R1 = "FCY"
 When 3 : R1 = "ACC"
 When 4 : R1 = "BPR"
Endcase
Case [M]T2
 When 1
  If R1<>"FCY"
   R2 = "FCY"
  Else
   R2 = "ACC"
  Endif
 When 2 : R2 = "FCY"
 When 3 : R2 = "ACC"
 When 4 : R2 = "BPR"
Endcase
Case [M]T3
 When 1
  If R1<>"FCY" & R2<>"FCY"
   R3 = "FCY"
  Elsif R1<>"ACC" & R2<>"ACC"
   R3 = "ACC"
  Else
   R3 = "BPR"
  Endif
 When 2 : R3 = "FCY"
 When 3 : R3 = "ACC"
 When 4 : R3 = "BPR"
Endcase
Return

# Sous-programme de switch permettant de placer RD en R3.
# Liste traitée en boucle : le 1er va à la dernière place, le second va en 1ere place...
Subprog SWITCH(R1,R2,R3,RD)
Variable Char R1(), R2(), R3()
Value Char RD()
Local Char RT(6)
Case RD
 When R1 :
   RT = R1
   R1 = R2
   R2 = R3
   R3 = RT
 When R2 :
   RT = R2
   R2 = R3
   R3 = RT
Endcase
End

##########################################
$PREMIER
If [L]COL<>1
 [L]COL = 1
 Gosub RECHARGE
Endif
Return

$DERNIER
If [L]COL<>[M:TXM2]NBRCOL
 [L]COL = [M:TXM2]NBRCOL
 Gosub RECHARGE
Endif
Return

$SUIVANT
If [L]COL<[M:TXM2]NBRCOL
 [L]COL += 1
Else
 [L]COL = 1
Endif
Gosub RECHARGE
Return

$PRECEDENT
If [L]COL>1
 [L]COL -= 1
Else
 [L]COL = [M:TXM2]NBRCOL
Endif
Gosub RECHARGE
Return

$PREMLIG
If [L]NOL<>0
 [L]NOL = 0
 Gosub RECHARGE
Endif
Return

$SUIVLIG
If [L]NOL<[M:TXM1]NBLIG-1
 [L]NOL += 1
Else
 [L]NOL = 0
Endif
Gosub RECHARGE
Return

$PRECLIG
If [L]NOL>0
 [L]NOL -= 1
Else
 [L]NOL = [M:TXM1]NBLIG-1
Endif
Gosub RECHARGE
Return

$DERNLIG
If [L]NOL<>[M:TXM1]NBLIG-1
 [L]NOL = [M:TXM1]NBLIG-1
 Gosub RECHARGE
Endif
Return

##########################################
$RECHARGE
[M]LIG = [L]NOL+1
[M]COL = [L]COL
[M]INTIT = [M:TXM1]INTIT(NOL)
DIV = [M:TXM1]DIVCOL(COL-1)  :# Diviseur
If !DIV : DIV=1 : Endif
[M]COLNAM = [M:TXM1]DIVMES(COL-1)
Read [TXD]TXD0 = [M:TXM0]TXSNAM;NOL+1;COL
If [F:TXD]DECCOL<>0
 [M]FORMAT = "14."+num$([F:TXD]DECCOL)+"#"
Else
 [M]FORMAT = "14#"
Endif
[M]FRM = evalue("[M:TXM3]FRM"+num$(COL)+"(NOL)")
Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;NOL+1;COL;0
[M]AMTTOT = val([F:TXM]AMTVAL)/DIV
[M]UPDVAL = val([F:TXM]UPDVAL)/DIV
Gosub CHARGE
Return

##########################################
$FINSAI
zonsui = "AMTVAL"+num$([M]COL)+"("+num$([M]LIG-1)+")"
mkstat = 99
Return

##########################################
# Etiquettes du masque TXSCNS
##########################################

Subprog AS_NBLIG
If nolign>0
 Inftxt [M]INFO(nolign-1) At 1
Endif
End

Subprog IB_NBLIG
If [M]COMPTE(nolign-1)=""
 Raz GBOUT1,GBOUT2
Elsif left$([M]FRM,3)="IAS"
 GBOUT2 -= [M]COMPTE(nolign-1)
 Raz GBOUT1
Else
 GBOUT1 -= [M]COMPTE(nolign-1)
 Raz GBOUT2
Endif
End

$SET_CRIT2
If DETCPT
 CRIT2 = "ACC<>''"
Else
 CRIT2 = "ACC=''"
Endif
If DETBPR
 CRIT2 -= "& BPR<>''"
 If !DETCPT
  CRIT2 = "ACC<>'' & BPR<>''"
 Elsif !DETSIT
  CRIT2 = "ACC<>''"
 Endif
Else
 CRIT2 -= "& BPR=''"
Endif
Return

Subprog AS_FRM0(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

Subprog AS_AMTVAL(VALEUR)
Variable Decimal VALEUR
mkstat = 2
End

##########################################################################
Subprog CL_L1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_L4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C1(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C2(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C3(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog CL_C4(VALEUR)
Variable Char    VALEUR()
mkstat = 4
End

Subprog AS_T1(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC(1) = 1 : # Pas de aucun
GMENLOC(5) = 1
If [F:TXW]DETACC<>2
 GMENLOC(3) = 1
Endif
If [F:TXW]DETBPR<>2
 GMENLOC(4) = 1
Endif
End

Subprog AS_T2(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
GMENLOC([M]T1) = 1
GMENLOC(5) = 1
If [F:TXW]DETACC<>2
 GMENLOC(3) = 1
Endif
If [F:TXW]DETBPR<>2
 GMENLOC(4) = 1
Endif
If sum(GMENLOC(2..5))=4
 VALEUR = 1
 mkstat = 2
Endif
End

Subprog AS_T3(VALEUR)
Variable Integer VALEUR
Raz GMENLOC
If [M]T2=1
 VALEUR = 1
 mkstat = 2 : End
Endif
GMENLOC([M]T1) = 1
GMENLOC([M]T2) = 1
GMENLOC(5) = 1
If [F:TXW]DETACC<>2
 GMENLOC(3) = 1
Endif
If [F:TXW]DETBPR<>2
 GMENLOC(4) = 1
Endif
If sum(GMENLOC(2..5))=4
 VALEUR = 1
 mkstat = 2
Endif
End
