#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Mask Management SFTEL
######################################################################################
$ACTION
  Case ACTION
    When "DEBUT"        : Gosub DEBUT
    When "OUVRE"        : Gosub OUVRE
    When "BOUTON"       : Gosub EXEBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "FERME"        : Gosub FERME
    When Default
  Endcase
Return
######################################################################################
## After entry window has been displayed (Initialization)
######################################################################################
$DEBUT

  # Clear the Labor screen
  Effzo [M:SFTEL]

  # Assign the Employee ID and Site values passing on from the SFT portal screen
  [M:SFTEL]EMPNUM = val(PARAM(1))
  [M:SFTEL]FCY    = PARAM(2)

  Local Char PARAMRET(4)
  Call PARAM([M:SFTEL]FCY,"SFTEMPCLK",PARAMRET) From ADOVAL
  SFTEMPCLK = val([L]PARAMRET)

  # Default work center and work center group from the employee table
  If !clalev([F:TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=[M:SFTEL]EMPNUM

  # Check to see if this is the employee's default site
  # If not, can't use defaults and don't grab default work center and group
  If [F:TMA]DEFFCY <> "" & [F:TMA]DEFFCY = [M:SFTEL]FCY
    [L]DEFAULTSITE = [V]CST_AYES

    [M:SFTEL]WSTF = [F:TMA]DEFWST
    [M:SFTEL]WCRF = [F:TMA]DEFWCR
  Else
    If [F:TMA]DEFWCR <> AVOID.ACHAR | [F:TMA]DEFWST <> AVOID.ACHAR
      # Verify if we can use the default site and group
      If func SFTLIB.VALIDATE_WORK_CENTER([M:SFTEL]FCY, [F:TMA]DEFWCR, [F:TMA]DEFWST) = [V]CST_AYES
        [M:SFTEL]WSTF = [F:TMA]DEFWST
        [M:SFTEL]WCRF = [F:TMA]DEFWCR
      Endif
    Endif
  Endif

  LogicClose File [TMA]

  #Default start date to today date
  [M:SFTEL]LSD = date$

  Affzo [M:SFTEL] # Refresh the Labor screen

  # Populate the grid bases on site passing in from the SFT main screen
  Call POPULATE_WORK_ORDERS ([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                            [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

Return
######################################################################################
$SETBOUT
  Raz CHMEN

  CHMEN += "BCI"
  If find([V]CST_AYES, [M:SFTEL]FLGL) : CHMEN += "S" : Endif
  If DEFAULTSITE=[V]CST_AYES & !find([V]CST_AYES, [M:SFTEL]FLGL) : CHMEN += "D" : Endif

Return
######################################################################################
## before the window opening. Declare resources like global variables, addtional
## tables...etc.
## Set ANOWRITE to 1 and declare instance.
######################################################################################
$OUVRE

  Local Integer DEFAULTSITE, SFTEMPCLK

  If !clalev([SFTX])    : Local File SFTTXN     [SFTX]    : Endif
  If !clalev([SFTXNS])  : Local File SFTTXN     [SFTXNS]  : Endif
  If !clalev([SFTH])    : Local File SFTTXNH    [SFTH]    : Endif
  If !clalev([MFO])     : Local File MFGOPE     [MFO]     : Endif
  If !clalev([MFOP])    : Local File MFGOPE     [MFOP]    : Endif
  If !clalev([MFG])     : Local File MFGHEAD    [MFG]     : Endif
  If !clalev([MWS])     : Local File WORKSTATIO [MWS]     : Endif
  If !clalev([SCH])     : Local File SCHEDULING [SCH]     : Endif

Return
######################################################################################
##  Button or menu item execution
######################################################################################
$EXEBOUT

  Case BOUT
    When "D"  : Gosub DEFAULT_RETURN
    When "S"  : Gosub SAVETRANSACTION
    When "C"  : Gosub RELOAD_GRID
  Endcase

Return

######################################################################################
## When window, screens and tables are closed.
## Free the instance.
######################################################################################
$FERME

  LogicClose File [SFTX], [SFTXNS], [SFTH], [MFG], [MFO], [MWS], [MFOP], [SCH]

Return
######################################################################################
$RELOAD_GRID

  # Re-populate the grid
  Call POPULATE_WORK_ORDERS ([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                            [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

Return
######################################################################################
$SAVETRANSACTION

  Local Integer EMPLOYEELIST(1..)

  #  Action not allowed if employee is not clocked in
  If func SFTLIB.EMPTYP(EMPNUM) <> 2    # skip detailed team
    If  SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTEL]EMPNUM) = [V]CST_ANO
      Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:SFTEL]EMPNUM))) From GESECRAN #CT-1797
      Return
    Endif
  Endif

  # Make sure at least one line was selected on the grid. If not, display a message.
  If !find([V]CST_AYES, [M:SFTEL]FLGL)
    GERR=1 : GMESSAGE = mess(187,7900,1)   # No line selected
    Return
  Endif

  # Start processing the elapsed labor
  Call SAVE()

  Gosub FERME   # Close files

  # Close the Labor page
  FIN=1
Return
######################################################################################
$DEFAULT_RETURN
  If !clalev([TMAD]) : Local File TABMAT [TMAD] : Endif

  Read [TMAD]TMA0=[M:SFTEL]EMPNUM

  # The default work center or work center group were updated - re-load the screen
  If ([M:SFTEL]WCRF<>[F:TMAD]DEFWCR) | ([M:SFTEL]WSTF<>[F:TMAD]DEFWST)
    [M:SFTEL]WCRF = [F:TMAD]DEFWCR
    [M:SFTEL]WSTF = [F:TMAD]DEFWST

    Affzo [M:SFTEL]

    # Populate the grid bases on site passing in from the SFT main screen
    Call POPULATE_WORK_ORDERS ([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                              [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

  Endif

  LogicClose File [TMAD]

Return
######################################################################################
Subprog AVANT_NBLIG

  If [M:SFTEL]CPLLAB(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTEL]CPLLAB(nolign-1)
  Else
    Actzo [M:SFTEL]CPLLAB(nolign-1)
  Endif

# 115429-Enable/disable Machines field bases on primary WC type
  If [M:SFTEL]WSTTYP(nolign-1) = 2    # 2-Labor
    Raz [M:SFTEL]NUMMAC(nolign-1)
    Grizo [M:SFTEL]NUMMAC(nolign-1)
  Else
    Actzo [M:SFTEL]NUMMAC(nolign-1)
  Endif

  If [M:SFTEL]WONOTE(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTEL]WONOTE(nolign-1)
  Endif

  If [M:SFTEL]OPNOTE(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTEL]OPNOTE(nolign-1)
  Endif

  Affzo [M:SFTEL]CPLLAB(nolign-1), NUMMAC(nolign-1)

End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  # Passing site value to filter the grid data
  Call POPULATE_WORK_ORDERS (VALEUR,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                           [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

End
######################################################################################
Subprog AM_MFGNUMF(VALEUR)
Variable Char    VALEUR()

  # Passing work order value to filter the grid data
  Call VALIDATE_REPOPULATE_GRID ([M:SFTEL]FCY,VALEUR,[M:SFTEL]OPENUMF,
&                            [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

End
######################################################################################
Subprog AM_OPENUMF(VALEUR)
Variable Decimal VALEUR
Local Integer   YESNO : YESNO = [V]CST_AYES

Call VALIDATE_REPOPULATE_GRID([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,VALEUR,
&                              [M:SFTEL]WCRF,[M:SFTEL]WSTF,[M:SFTEL]LSD)

End
######################################################################################
Subprog AM_WCRF(VALEUR)
Variable Char    VALEUR()

  # Passing WC group value to filter the grid data
  Call VALIDATE_REPOPULATE_GRID([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                            VALEUR,[M:SFTEL]WSTF,[M:SFTEL]LSD)

End
######################################################################################
Subprog AM_WSTF(VALEUR)
Variable Char    VALEUR()

  # Passing work center value to filter the grid data
  Call VALIDATE_REPOPULATE_GRID([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                            [M:SFTEL]WCRF,VALEUR,[M:SFTEL]LSD)

End
######################################################################################
Subprog AM_LSD(VALEUR)
Variable Date    VALEUR

  # Passing start date value
  Call VALIDATE_REPOPULATE_GRID([M:SFTEL]FCY,[M:SFTEL]MFGNUMF,[M:SFTEL]OPENUMF,
&                            [M:SFTEL]WCRF,[M:SFTEL]WSTF,VALEUR)
End
######################################################################################
Subprog C_FLGL(VALEUR)
Variable Integer VALEUR

  If VALEUR=[V]CST_AYES & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = [V]CST_ANO
  Endif

  # TODAN-119090: Do not allow Machine only
  If VALEUR = [V]CST_AYES & [M:SFTEL]NUMMAC(nolign-1) = [V]CST_ANO &
&    [M:SFTEL]WSTTYP(nolign-1) = 1 & [M:SFTEL]CPLLAB(nolign-1) = AVOID.ACHAR

    Call ERREUR(mess(30,2422,1)) From GESECRAN
    VALEUR = [V]CST_ANO
    mkstat = 1
    End
  Endif

  [M:SFTEL]FLGL(nolign-1) = VALEUR

End
######################################################################################
Subprog AM_FLGL(VALEUR)
Variable Integer VALEUR

  # If they unchecked the line - verify future operations
  If [V]GCTLOPEPRE > 1 & VALEUR = [V]CST_ANO
    # Set the value to the screen
    [M:SFTEL]FLGL(nolign-1) = [V]CST_ANO
    For I = 0 To [M:SFTEL]NBLIG-1
      If [M:SFTEL]FLGL(I)=[V]CST_AYES
        If [M:SFTEL]MFGNUM(I)=[M:SFTEL]MFGNUM(nolign-1) & [M:SFTEL]OPENUM(I)>[M:SFTEL]OPENUM(nolign-1)
          Call FORMAT_PRIOR_OPER(I, [V]CST_ANO)
        Endif
      Endif
    Next I
  Endif

End
######################################################################################
Subprog C_NUMJOBS(VALEUR)
Variable Decimal VALEUR
  If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End
######################################################################################
Subprog AM_NUMJOBS(VALEUR)
Variable Decimal VALEUR

  Call SELECTLINE(VALEUR)

End
######################################################################################
# TODAN-119090.so
Subprog C_NUMMAC(VALEUR)
Variable Integer VALEUR

  # Uncheck the Machine option when the CTLOPEPRE-Expected operation tracking co parameter is on
  # and the prior operation is not running.
  If VALEUR = [V]CST_AYES & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = [V]CST_ANO
  Endif

End
######################################################################################
Subprog AM_NUMMAC(VALEUR)
Variable Integer VALEUR

  # Do not allow when the operation is Machine only
  If VALEUR = [V]CST_ANO & [M:SFTEL]WSTTYP(nolign-1) = 1 & [M:SFTEL]CPLLAB(nolign-1) = AVOID.ACHAR
    Call ERREUR(mess(30,2422,1)) From GESECRAN
    VALEUR = [V]CST_AYES
    mkstat = 1
    End
  Endif

  If VALEUR <> [M:SFTEL]NUMMAC(nolign-1) : Call SELECTLINE(VALEUR) : Endif

End
# TODAN-119090.eo
######################################################################################
Subprog C_CPLWST(VALEUR)
Variable Char    VALEUR()

  Read [MWS]WST0 = VALEUR; [M:SFTEL]FCY
  If fstat
    Call ERREUR(mess(196,193,1)) From GESECRAN    # Not found
    mkstat = 1
    End
  Else
      If [F:MWS]WSTTYP <> [M:SFTEL]WSTTYP(nolign-1)   # Not allow a different type of work order
         #CT-1797.sn
         #GMESSAGE = VALEUR - mess(47,2422,1) : mkstat=2 : End
         Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN #CT-1797
         mkstat=2
         #CT-1797.en
         End
      Endif
  Endif

  If VALEUR<>"" & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = ""
  Endif
End
######################################################################################
Subprog AM_CPLWST(VALEUR)
Variable Char    VALEUR()

  # Get work center group value from work center table filtering by work center and site.
  [M:SFTEL]WCGRP(nolign-1) = func SFTLIB.GET_CENTER_GROUP(VALEUR, [M:SFTEL]FCY)
  Affzo [M:SFTEL]WCGRP(nolign-1)

  If VALEUR <> [M:SFTEL]CPLWST(nolign-1) : Call SELECTLINE(1) : Endif

End
######################################################################################
Subprog C_CPLLAB(VALEUR)
Variable Char    VALEUR()

  # Cannot remove if labor center existed
  If VALEUR = AVOID.ACHAR & [M:SFTEL]CPLLAB(nolign-1) <> AVOID.ACHAR
    GMESSAGE = VALEUR - mess(48,2422,1) : mkstat=2 : End
  Endif

  # Allow change when labor center exists
  If VALEUR <> AVOID.ACHAR & [M:SFTEL]CPLLAB(nolign-1) <> AVOID.ACHAR
    # Labor (secondary) center cannot be the same as the primary work center
    If VALEUR = [M:SFTEL]CPLWST(nolign-1) : GMESSAGE=mess(26,193,1) : mkstat=2 : End : Endif
    # Check if labor center exist in the same site
    Read [MWS]WST0 = VALEUR; [M:SFTEL]FCY
    If fstat
      GMESSAGE= VALEUR - mess(44,2422,1)
      mkstat=2
      End
    Else
      # Cannot have labor center that is not a labor type
      If [F:MWS]WSTTYP <> 2
         GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2 : End
      Endif
    Endif
  Endif

  If VALEUR<>"" & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = ""
  Endif
End
######################################################################################
Subprog AM_CPLLAB(VALEUR)
Variable Char    VALEUR()

  # Get work center group value from work center table filtering by work center and site.
  [M:SFTEL]LCGRP(nolign-1) = func SFTLIB.GET_CENTER_GROUP(VALEUR, [M:SFTEL]FCY)
  Affzo [M:SFTEL]LCGRP(nolign-1)

  If VALEUR <> [M:SFTEL]CPLLAB(nolign-1) : Call SELECTLINE(1) : Endif

End

######################################################################################
Subprog C_SETDURTIM(VALEUR)
Variable Decimal    VALEUR()
  If VALEUR > 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End

######################################################################################
Subprog AM_SETDURTIM(VALEUR)
Variable Decimal    VALEUR()

  # Check Time unit, convert to minutes if needed.
  If [M:SFTEL]TIMUOMCOD(nolign-1) = 1
    [M:SFTEL]SETUDURATION(nolign-1) = VALEUR * 60
  Else
    [M:SFTEL]SETUDURATION(nolign-1) = VALEUR
  Endif

  Call SELECTLINE([M:SFTEL]SETUDURATION(nolign-1))

End
######################################################################################
Subprog C_RUNDURTIM(VALEUR)
Variable Decimal    VALEUR()
  If VALEUR > 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End

######################################################################################
Subprog AM_RUNDURTIM(VALEUR)
Variable Decimal    VALEUR()

  # Check Time unit, convert to minutes if needed.
  If [M:SFTEL]TIMUOMCOD(nolign-1) = 1
    [M:SFTEL]RUNDURATION(nolign-1) = VALEUR * 60
  Else
    [M:SFTEL]RUNDURATION(nolign-1) = VALEUR
  Endif

  Call SELECTLINE([M:SFTEL]RUNDURATION(nolign-1))

End
######################################################################################
Subprog C_COMPLQTY(VALEUR)
Variable Decimal VALEUR
  If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End
######################################################################################
Subprog AM_COMPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer OK

  If VALEUR > [M:SFTEL]REMQTY(nolign-1)
    Call AVERTIR(mess(54,190,1),OK) From GESECRAN
    If OK = 1     # Cancel
      mkstat = 1
      End
    Else
      [M:SFTEL]CLEFLG(nolign-1) = [V]CST_AYES
    Endif
  Else
    If VALEUR = [M:SFTEL]REMQTY(nolign-1)
      [M:SFTEL]CLEFLG(nolign-1) = [V]CST_AYES
    Else
      [M:SFTEL]CLEFLG(nolign-1) = [V]CST_ANO
    Endif
  Endif

  Affzo [M:SFTEL]CLEFLG(nolign-1)
  Call SELECTLINE(VALEUR)
  Call REJECTQTY(VALEUR)
  Call REJECTCODE([M:SFTEL]REJQTY(nolign-1))
End
######################################################################################
Subprog C_REJQTY(VALEUR)
Variable Decimal VALEUR
  If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End
######################################################################################
Subprog AM_REJQTY(VALEUR)
Variable Decimal VALEUR

  # Display message when rejected qty is > completed qty and
  # clear out the selection option
  If VALEUR > [M:SFTEL]COMPLQTY(nolign-1)
      Call ERREUR(mess (25,2422,1)) From GESECRAN # Rejected qty. cannot be more than Completed qty.
      VALEUR = 0
      OK = 1
      mkstat = 1
  Else
    Call SELECTLINE(VALEUR)
    Call REJECTCODE(VALEUR)
  Endif
End
######################################################################################
Subprog C_REJCOD(VALEUR)
Variable Decimal VALEUR

  If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0 : End
  Endif

  Local Char WSCANUM(12) : WSCANUM = num$(VALEUR)
  If VALEUR <> 0
    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
  Endif
End
######################################################################################
Subprog C_CLEFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR=[V]CST_AYES & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = [V]CST_ANO
  Endif
End
######################################################################################
Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
  Local Integer I

  Call SELECTLINE(VALEUR)

  # If they unchecked the line - verify future operations
  If [V]GCTLOPEPRE > 1 & VALEUR = [V]CST_ANO
    # Set the value to the screen
    [M:SFTEL]CLEFLG(nolign-1) = [V]CST_ANO
    For I = 0 To [M:SFTEL]NBLIG-1
      If [M:SFTEL]FLGL(I)=[V]CST_AYES
        If [M:SFTEL]MFGNUM(I)=[M:SFTEL]MFGNUM(nolign-1) & [M:SFTEL]OPENUM(I)>[M:SFTEL]OPENUM(nolign-1)
          Call FORMAT_PRIOR_OPER(I, [V]CST_ANO)
        Endif
      Endif
    Next I
  Endif
End

######################################################################################
Subprog AS_WONOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFG table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFG]MFG0=[M:SFTEL]MFGNUM(nolign-1)

End

######################################################################################
Subprog AS_OPNOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFO table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFO]MFO0=[M:SFTEL]MFGNUM(nolign-1);[M:SFTEL]OPENUM(nolign-1)

End

######################################################################################
Subprog SELECTLINE(I)
Value Decimal I
  If I<>0 & [M:SFTEL]FLGL(nolign-1)<>[V]CST_AYES
    [M:SFTEL]FLGL(nolign-1)=[V]CST_AYES
    Affzo [M:SFTEL]FLGL(nolign-1)
  Endif
End
######################################################################################
Subprog REJECTQTY(I)
Value Decimal I
  If I > 0
    Actzo [M:SFTEL]REJQTY(nolign-1)
  Else
    Raz [M:SFTEL]REJQTY(nolign-1)
    Grizo [M:SFTEL]REJQTY(nolign-1)
  Endif
  Affzo [M:SFTEL]REJQTY(nolign-1)
End
######################################################################################
Subprog VALIDATE_REPOPULATE_GRID(FCY, WO, OPENUM, WCG, WC, STRDAT)    # TODAN-118504
#Subprog VALIDATE_REPOPULATE_GRID(FCY, WO, OPENUM, WC, WCG, STRDAT)

Value Char FCY
Value Char WO
Value Integer OPENUM
Value Char WC
Value Char WCG
Value Date STRDAT

Local Integer   YESNO : YESNO = [V]CST_AYES

  If find([V]CST_AYES, [M:SFTEL]FLGL)
    Call OUINON(mess(68,2422,1), YESNO) From GESECRAN
    If YESNO <> 2    # No
      mkstat = 2
      End
    Endif
  Endif

  # Passing operation value to filter the grid data
  Call POPULATE_WORK_ORDERS (FCY, WO, OPENUM, WCG, WC, STRDAT)    # TODAN-118504
#  Call POPULATE_WORK_ORDERS (FCY, WO, OPENUM, WC, WCG, STRDAT)

End
######################################################################################
Subprog REJECTCODE(I)
Value Decimal I
  If I > 0
    Actzo [M:SFTEL]REJCOD(nolign-1)
  Else
    Raz [M:SFTEL]REJCOD(nolign-1)
    Grizo [M:SFTEL]REJCOD(nolign-1)
  Endif
  Affzo [M:SFTEL]REJCOD(nolign-1)
End

######################################################################################
Subprog POPULATE_WORK_ORDERS (STE, WO, OPE, WCG, WC, STARTDATE)
Value Char    STE
Value Char    WO
Value Char    WCG
Value Char    WC
Value Integer OPE
Value Date    STARTDATE

  Local Char    WCENTERGRP(5), WCENTER(8), LCENTER(8), CRIT(250)
  Local Integer OPERPREC, I

  Local Integer WMAX
  WMAX = dim([M:SFTEL]MFGNUM)  # Max lines to be displayed

  # Initialize grid
  Raz [M:SFTEL]NBLIG
  Effzo 15

  # Build the criteria for the search
  CRIT = "[MFO]OPESTA<5 & [MFG]MFGSTA=1 & [MFG]SUSFLG=1"
  If STE <> AVOID.ACHAR
    CRIT += " & [MFO]MFGFCY='"+STE+"'"
  Endif
  If WO <> AVOID.ACHAR
    CRIT += " & [MFO]MFGNUM='"+WO+"'"
  Endif
  If OPE<>AVOID.AINT
    CRIT += " & [MFO]OPENUM="+num$(OPE)
  Endif
  If STARTDATE<>AVOID.ADATE
    CRIT += " & [MFO]OPESTR<=[" + format$(GFMD,STARTDATE) + "]"
  Endif
  If GMTKALLMGT = [V]CST_AYES   # Allocation required
    CRIT += " & find([MFG]ALLSTA,3,5)"
  Endif
  If GDOSFAB = [V]CST_AYES      # Printing required
    CRIT += " & [MFG]MFGTRKFLG >=3"
  Endif

  Link [MFO] With [MFG]MFG0~=[MFO]MFGNUM As [SFTMFO]
& Where evalue(CRIT)
& Order By Key KEY1=[MFO]MFGNUM;[MFO]OPENUM

  For [SFTMFO]KEY1
    If I >= WMAX
        Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
        Break
    Endif
    #-----------------------------------------------------------------------------
    # For each WO from the WO-Operation...
    # First, look for the modified WC and LC, if existed, from current transactions
    # or from the historical transaction tables.
    # We need these value to populate a correct WC group and LC group
    #-----------------------------------------------------------------------------

    # Initialize variables
    WCENTER     = AVOID.ACHAR
    LCENTER     = AVOID.ACHAR
    WCENTERGRP  = AVOID.ACHAR

    #-----------------------------------------------------------------------------
    # Subcontracting operation is concurrently not supported in our SFT project
    #-----------------------------------------------------------------------------

    Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:SFTEL]FCY
    If [F:MWS]WSTTYP = 3 : Goto NEXT_WO : Endif

    #-----------------------------------------------------------------------------
    # If someone has this record open using actuals, don't display it here
    #-----------------------------------------------------------------------------
    Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                         [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                         [F:SFTX]UTCENDDATTIM = AVOID.ADATTIM Order By VCRNUM
    Look [F:SFTX] First # TODAN-118504
#    Read [F:SFTX] First
    Filter [F:SFTX]
    If !fstat : Goto NEXT_WO : Endif

    #-------------------------------------------------------------
    # If the CTLOPEPRE parameter is not 1 (No tracking)
    # we need to store the previous operation for later validation
    #-------------------------------------------------------------
    If GCTLOPEPRE > 1
      [L]OPERPREC = 0
      # Find the prior operation number
      Filter [SCH] Where MFGNUM = [SFTMFO]MFGNUM & NEXOPENUM = [SFTMFO]OPENUM
      Read [SCH]SCH0 First
      Filter [SCH]
      If !fstat : [L]OPERPREC = [F:SCH]OPENUM : Endif
    Endif

    #-----------------------------------------------------------------------------
    # Get modified work center and labor center from SFT current/history tables
    #-----------------------------------------------------------------------------
    # Default from WO operations table
    WCENTER = [F:MFO]EXTWST
    LCENTER = [F:MFO]EXTLAB

    Call GET_SFT_WC_LC([SFTMFO]MFGNUM, [SFTMFO]OPENUM, [F:MWS]WSTTYP, [SFTMFO]EXTWST,
&                      [SFTMFO]EXTLAB, WCENTER, LCENTER) From SFTLIB
    If WC<>AVOID.ACHAR &  WC<>[L]WCENTER
      Goto NEXT_WO
    Endif

    # Get work center group value from work center table filtering by work center and site.
    WCENTERGRP = func SFTLIB.GET_CENTER_GROUP(WCENTER, STE)
    If WCG<>AVOID.ACHAR &  WCG<>[L]WCENTERGRP
      Goto NEXT_WO
    Endif

    # Filter by work center group when user enter a value
    [M:SFTEL]FLGL(I)      = 0
    [M:SFTEL]MFGNUM(I)    = [SFTMFO]MFGNUM     # Work order
    [M:SFTEL]OPENUM(I)    = [SFTMFO]OPENUM     # Operation
    [M:SFTEL]OPERPREC(I)  = [L]OPERPREC
    [M:SFTEL]NUMJOBS(I)   = 1
#    [M:SFTEL]NUMMAC(I)    = [SFTMFO]EXTWSTNBR  # Expected machines     # TODAN-119090.o
    [M:SFTEL]CPLWST(I)    = WCENTER           # Work center
    [M:SFTEL]CPLLAB(I)    = LCENTER           # Labor center
    [M:SFTEL]OPEUOM(I)    = [SFTMFO]OPEUOM     # UOM
    [M:SFTEL]OPESTR(I)    = [SFTMFO]OPESTR     # Start date
    [M:SFTEL]OPEEND(I)    = [SFTMFO]OPEEND     # End date
    [M:SFTEL]OPEDESC(I)   = [SFTMFO]ROODES     # Operation description
    [M:SFTEL]WCGRP(I)     = WCENTERGRP        # Work center group
    [M:SFTEL]TIMUOMCOD(I) = [SFTMFO]TIMUOMCOD
    [M:SFTEL]LCGRP(I)     = func SFTLIB.GET_CENTER_GROUP(LCENTER, STE)        # Labor work center group
    [M:SFTEL]REMQTY(I)    = func GET_REMAINING_QTY(
&                                [SFTMFO]MFGNUM, [SFTMFO]OPENUM, [SFTMFO]OPEUOM, [F:MFG]STU,
&                                [SFTMFO]EXTQTY, [SFTMFO]CPLQTY)
    # Get the work center type
    Read [F:MWS]WST0=[L]WCENTER;[M:SFTEL]FCY
    [M:SFTEL]WSTTYP(I)    = [F:MWS]WSTTYP

    # TODAN-119090.sn
    If [M:SFTEL]WSTTYP(I) = 1   # Machine type
      [M:SFTEL]NUMMAC(I) = [V]CST_AYES
    Else
      [M:SFTEL]NUMMAC(I) = [V]CST_ANO
    Endif
    # TODAN-119090.en

    #If no notes - clear out the button
    If [F:MFG]MFGTEX="" : [M:SFTEL]WONOTE(I)=AVOID.ACHAR : Endif
    If [F:MFO]MFOTEX="" : [M:SFTEL]OPNOTE(I)=AVOID.ACHAR : Endif

    I += 1

NEXT_WO:

  Next

  # Disable the Rejected qty and Rejected code fields
  Grizo [M:SFTEL]REJQTY
  Grizo [M:SFTEL]REJCOD

  [M:SFTEL]NBLIG = I
  Affzo 15    # Refresh the grid

End

####################################################################################
# Save the selected operations
####################################################################################
Subprog SAVE()

  Local Char    START_WONUM(20)(1..), START_WCENTER(8)(1..)
  Local Char    START_LCENTER(8)(1..), START_UOM(3)(1..)
  Local Integer I, START_COUNT, START_OPENUM(1..), START_NUMMAC(1..)
  Local Integer START_NUMJOBS(1..), START_REJECTEDCODE(1..), START_CLOSE(1..)
  Local Decimal START_SETUPDURATION(1..), START_RUNDURATION(1..)
  Local Decimal START_COMPLETEQTY(1..), START_REJECTEDQTY(1..)
  Local Char    ERRMSG(125)
  Local Integer ERRNUM, OK, MY_STATUS

  # Initialization
  START_COUNT = 0

  # Loop through the activity grid and start the elapsed labor operation
  For I = 0 To [M:SFTEL]NBLIG-1
    If [M:SFTEL]FLGL(I) = 2   # Selected

      # Add the record to a collection
      START_COUNT += 1
      START_WONUM(START_COUNT)          = [M:SFTEL]MFGNUM(I)          # Work order
      START_OPENUM(START_COUNT)         = [M:SFTEL]OPENUM(I)          # Operation number
      START_NUMMAC(START_COUNT)         = [M:SFTEL]NUMMAC(I)          # Machine included
      START_NUMJOBS(START_COUNT)        = [M:SFTEL]NUMJOBS(I)         # Number of jobs
      START_WCENTER(START_COUNT)        = [M:SFTEL]CPLWST(I)          # Work center
      START_LCENTER(START_COUNT)        = [M:SFTEL]CPLLAB(I)          # Labor center
      START_SETUPDURATION(START_COUNT)  = [M:SFTEL]SETUDURATION(I)    # Setup duration
      START_RUNDURATION(START_COUNT)    = [M:SFTEL]RUNDURATION(I)     # Run duration
      START_COMPLETEQTY(START_COUNT)    = [M:SFTEL]COMPLQTY(I)        # Completed quantity
      START_UOM(START_COUNT)            = [M:SFTEL]OPEUOM(I)          # UOM
      START_REJECTEDQTY(START_COUNT)    = [M:SFTEL]REJQTY(I)          # Rejected quantity
      START_REJECTEDCODE(START_COUNT)   = [M:SFTEL]REJCOD(I)          # Rejection code
      START_CLOSE(START_COUNT)          = [M:SFTEL]CLEFLG(I)          # Complete
    Endif
  Next

  # Start the operations
  If START_COUNT > 0
    #--- Shop floor tracking transaction class
    Local Instance SFTRANSACTION Using C_SFTTXN
    SFTRANSACTION = NewInstance C_SFTTXN AllocGroup null
    MY_STATUS = fmet SFTRANSACTION.TIME_TRACKING([M:SFTEL]EMPNUM, [M:SFTEL]FCY, START_WONUM, START_OPENUM,
&                                               START_NUMMAC, START_NUMJOBS, START_WCENTER, START_LCENTER,
&                                               START_SETUPDURATION, START_RUNDURATION, START_COMPLETEQTY,
&                                               START_UOM, START_REJECTEDQTY, START_REJECTEDCODE, START_CLOSE,
&                                               START_COUNT)

    # Check if the operation start successfully
    If MY_STATUS >= [V]CST_AERROR
      Call ERREUR(SFTRANSACTION.AERROR.MES) From GESECRAN
    Endif

    FreeGroup SFTRANSACTION
    Kill SFTRANSACTION

  Endif

End

######################################################################################
Funprog VERIFY_PRIOR_OPERATION
Local Integer ALLOW_IT, NOL, I, OPERPREC
Local Char    MFGNUM(50)

  # No check needed
  If [V]GCTLOPEPRE = 1 : End [V]CST_AYES : Endif

  ALLOW_IT  = [V]CST_ANO
  NOL       = nolign-1
  OPERPREC  = [M:SFTEL]OPERPREC(NOL)
  MFGNUM    = [M:SFTEL]MFGNUM(NOL)

  # Already checked this line once and is OK
  If [M:SFTEL]PRIOROK(NOL) = [V]CST_AYES : End [V]CST_AYES : Goto FINALIZE : Endif

  # No prior operation
  If [L]OPERPREC=0 : End [V]CST_AYES : Endif

  # Check the grid for this operation and see if marked complete
  For I = 0 To [M:SFTEL]NBLIG-1
    If [L]OPERPREC = [M:SFTEL]OPENUM(I) & [L]MFGNUM = [M:SFTEL]MFGNUM(I)
      If [M:SFTEL]FLGL(I) = [V]CST_AYES & [M:SFTEL]CLEFLG(I) = [V]CST_AYES
        ALLOW_IT = [V]CST_AYES : Goto FINALIZE
      Endif
      Break
    Endif
  Next I

  # Check if prior marked complete in MFG Operations table
  Filter [MFOP] Where MFGNUM=[L]MFGNUM & OPENUM=[L]OPERPREC & [F:MFOP]OPESTA>=5
  Read [MFOP]MFO0 First
  Filter [MFOP]
  If !fstat : ALLOW_IT = [V]CST_AYES : Goto FINALIZE : Endif

  # Check for prior marked complete in SFT tables
  Filter [F:SFTX] Where [F:SFTX]VCRNUM=[L]MFGNUM & [F:SFTX]OPENUM=[L]OPERPREC & [F:SFTX]CLEFLG=[V]CST_AYES
  Read [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If !fstat : ALLOW_IT = [V]CST_AYES : Goto FINALIZE : Endif

  # Prior is not closed anywhere. If Warn, ask before blocking
  If [V]GCTLOPEPRE=2
    Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC)-"("+mess(61,100,1)-num$(I+1)+")",ALLOW_IT) From GESECRAN
  Else
    Call ERREUR(mess(22,190,1)-num$(OPERPREC)-"("+mess(61,100,1)-num$(I+1)+")") From GESECRAN
  Endif

FINALIZE:
  Call FORMAT_PRIOR_OPER(NOL, ALLOW_IT)

End ALLOW_IT

######################################################################################
Subprog FORMAT_PRIOR_OPER(NOL, ALLOW_IT)
Value Integer NOL
Value Integer ALLOW_IT

  If ALLOW_IT = [V]CST_AYES
    #115429 - Enable machine bases on WC type
    If [M:SFTEL]WSTTYP(NOL) <> 2
      Actzo [M:SFTEL]NUMMAC(NOL)
    Endif

    Actzo [M:SFTEL]NUMJOBS(NOL)
    Actzo [M:SFTEL]CPLWST(NOL)
    Actzo [M:SFTEL]SETDURTIM(NOL)
    Actzo [M:SFTEL]RUNDURTIM(NOL)
    Actzo [M:SFTEL]COMPLQTY(NOL)
    Actzo [M:SFTEL]CLEFLG(NOL)

    If [M:SFTEL]CPLLAB(NOL) <> AVOID.ACHAR
      Actzo [M:SFTEL]CPLLAB(NOL)
    Endif

    If [M:SFTEL]COMPLQTY(NOL)>0
      Actzo [M:SFTEL]REJQTY(NOL)
    Endif

    # We either passed validation or the user selected OK.
    # Set the flag so we don't check again
    [M:SFTEL]PRIOROK(NOL) = [V]CST_AYES
  Else
    Raz [M:SFTEL]CLEFLG(NOL), [M:SFTEL]FLGL(NOL)
    [M:SFTEL]PRIOROK(NOL) = [V]CST_ANO

    Grizo [M:SFTEL]NUMMAC(NOL)
    Grizo [M:SFTEL]NUMJOBS(NOL)
    Grizo [M:SFTEL]CPLWST(NOL)
    Grizo [M:SFTEL]CPLLAB(NOL)
    Grizo [M:SFTEL]SETDURTIM(NOL)
    Grizo [M:SFTEL]RUNDURTIM(NOL)
    Grizo [M:SFTEL]COMPLQTY(NOL)
    Grizo [M:SFTEL]REJQTY(NOL)
    Grizo [M:SFTEL]CLEFLG(NOL)

    Affzo 15
  Endif
End
####################################################################################
# Save the selected operations
####################################################################################
Funprog GET_REMAINING_QTY(IMFGNUM, IOPENUM, IOPEUOM, IMFGUOM, IEXTQTY, ICPLQTY)
Value Char    IMFGNUM
Value Integer IOPENUM
Value Char    IOPEUOM
Value Char    IMFGUOM
Value Decimal IEXTQTY
Value Decimal ICPLQTY

  Local Decimal REMQTY, OPEWORCOE, WCOEFF

  # Get the Coefficient from the UOM
  Call RECH_COEFF(IMFGUOM, IOPEUOM, WCOEFF) From MFGLIB
  If WCOEFF<>0 : OPEWORCOE = WCOEFF : Else OPEWORCOE = 1 : Endif

  # Initial remaining qty from the MFGOPE table
  REMQTY = (IEXTQTY - ICPLQTY)/OPEWORCOE

  #-----------------------------------------------------------------------------
  # Current SFT transactions table
  #-----------------------------------------------------------------------------
  For [F:SFTXNS] Where VCRNUM = IMFGNUM & OPENUM = IOPENUM
    # Reduce the remaining qty from the complete qty
    REMQTY -= [F:SFTXNS]CPLQTY
  Next

End REMQTY

