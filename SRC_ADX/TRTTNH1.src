#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION
Return
######################################################################################
######################################################################################
Subprog VAL_TNH(VCRNUM)
Variable Char    VCRNUM()

Local Integer WRET
Call VALIDATE ([L]VCRNUM,[L]WRET)  From TRTTNH1

End
######################################################################################
######################################################################################
Subprog VALIDATE(TNHNUM,RETVAL)
Value    Char     TNHNUM
Variable Integer  RETVAL

[L]RETVAL = 0

Local File TRANNOTEH  [TNH]
Local File TRANNOTED  [TND]
Local File BPARTNER   [BPR]
Local Char    SYMBOLTNH(30)
Local Integer LRET, PRIVTRACE
Local Char    WABREV(3)
Local Char    CBLOB(3)
Local Char    WCPT(GLONANM)

#----- Open trace -----#
If GTRACE = ""
  Call OUVRE_TRACE(mess(131,7711,1)) From LECFIC
  [L]PRIVTRACE = 1
Else
  Call ECR_TRACE(mess(131,7711,1),0) From GESECRAN
Endif

#----- Logic symbol -----#
SYMBOLTNH="TNH"+[L]TNHNUM
Lock=SYMBOLTNH
If fstat
  Call ECR_TRACE("$TNH"-[L]TNHNUM-mess(10,100,1),1) From GESECRAN
  SYMBOLTNH="" : Goto FINVAL
Endif

Call DEBTRANS From GLOCK

$TR_VALID

Trbegin [F:TNH]
Readlock [F:TNH]TNH0=[L]TNHNUM
If fstat=1
  GOK=-1 : GLOCK="$TNH"                      : Goto ROL_VAL
Elsif fstat
  GOK=0  : Call RSTA("TNH",[L]TNHNUM) From GLOCK : Goto AB_VAL
Endif

Local Integer PORDIGSIGN : [L]PORDIGSIGN = func PORLEGLIB.DIGSIGN([F:TNH]FCY, "")

If [L]PORDIGSIGN = 1
  Local Char AUTARV(30) : [L]AUTARV = ''

  Call PARAM([F:TNH]FCY, "ARVDATAUT", [L]AUTARV) From ADOVAL
  Case GFONCTION
    When "FUNCFMTNH"
      If [M:DIA]ENA = 2
        [F:TNH]DPEDAT   = [F:TNH]TRNDAT + [M:DIA]STRDAYS
        [F:TNH]ETD        = ctrans([M:DIA]STRHOU,":","")
        If [L]AUTARV='2'
          [F:TNH]ARVDAT   = [F:TNH]TRNDAT + [M:DIA]ENDDAYS
          [F:TNH]ETA        = ctrans([M:DIA]ENDHOU,":","")
        Endif
      Endif
    When "GESTNH"
      If [F:TNH]DPEDAT= [0/0/0]
        [F:TNH]DPEDAT = [M:TNH0]TRNDAT
      Endif
      If [L]AUTARV='2'
        If [F:TNH]ARVDAT = [0/0/0]
          [F:TNH]ARVDAT = [M:TNH0]TRNDAT
        Endif
      Endif
  Endcase

  Local Char LNUM(GLONVCR)

  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  Call LEC_FCY ([F:TNH]FCY) From CPTLEC

  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC

  # Document type
  If [F:TNH]TNHTYP<>""
    If !clalev ([F:TTN]) : Local File TABTNHTYP [TTN] : Endif
    Call LEC_TTN_LEG([F:CPY]LEG,[F:TNH]TNHTYP,LRET) From TRTLECLEG
    If LRET<>0 Raz [F:TTN] : Endif
    WCPT = [F:TTN]CODNUMEND

    If func PORLEGLIB.ANM_OK(WCPT, GMESSAGE) <> 1
      GERR=1 : GOK=0 : Goto AB_VAL
    Endif

  Endif

  Call NUMERO(WCPT,[F:TNH]FCY,[F:TNH]TRNDAT,"",LNUM,LRET) From SUBANM

  If GOK<0 Goto ROL_VAL Endif

  If LRET <> 0 | GOK<1
    Local Char MESSA(80)
    Local Integer SAUV_STAT
    If dim(STAT)<0 : Local Integer STAT : Endif
    SAUV_STAT=STAT : STAT=LRET
    #GMESSAGE=mess(60,199,1)-"("+[F:TCA]CODNUM(13)+") : "
    GMESSAGE=mess(60,199,1)-"("+WCPT+") : "
    Gosub MESSAGE From SUBANM
    STAT=SAUV_STAT
    GMESSAGE-=MESSA : GERR=1 : GOK=0 : Goto AB_VAL
  Endif

  # BRBAN 08-07-2014 SAM#93745 US2
  If [L]PORDIGSIGN=1
    If find([F:TTN]RECTYP,2,3,4)
      If [F:TNH]MANDOC=''
        If GTRACE = ''
          If find([F:TTN]RECTYP,2,3)
            GMESSAGE=mess(128,7711,1) #Should fill the manual/backup document number.
          Else #4
            GMESSAGE=mess(196,7711,1) #Should fill the manual document field with the external document number.
          Endif
          GERR= 1
          GOK = 0
        Else
          If find([F:TTN]RECTYP,2,3)
            Call ECR_TRACE(mess(128,7711,1),1) From GESECRAN #Should fill the manual/backup document number.
          Else #4
            Call ECR_TRACE(mess(196,7711,1),1) From GESECRAN #Should fill the manual document field with the external document number.
          Endif
          GOK = 0
        Endif
      Endif
    Endif
  Endif
  If GOK=0 : Goto AB_VAL : Endif

  #If [L]PORDIGSIGN = 1
    Gosub CTRL_CHRONOLOGIC
    If GOK=0 : Goto AB_VAL : Endif
  #Endif

  # Table updates with the new sequence counter
  If !clalev([F:ABB]) : Local File ABLOB     [ABB] : Endif
  If !clalev([F:ACB]) : Local File ACLOB     [ACB] : Endif
  If !clalev([F:AOX]) : Local File AOBJTXT   [AOX] : Endif
  If !clalev([F:AOM]) : Local File AOBJTXTA  [AOM] : Endif

  [L]WABREV="TNH"

  Update [AOX] Where ABREV=[L]WABREV & IDENT1=[L]TNHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOX") From GLOCK
    Goto AB_VAL
  Endif
  Update [AOM] Where ABREV=[L]WABREV & IDENT1=[L]TNHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("AOM") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "PJ_" : # Pour les pieces jointes
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]TNHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif
  Update [ABB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]TNHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ABB") From GLOCK
    Goto AB_VAL
  Endif
  [L]CBLOB = "CO_" : # Pour les commentaires
  Update [ACB] Where CODBLB=[L]CBLOB+[L]WABREV & IDENT1=[L]TNHNUM With IDENT1=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("ACB") From GLOCK
    Goto AB_VAL
  Endif

  Update [TND] Where TNHNUM=[L]TNHNUM With TNHNUM=[L]LNUM
  If find(fstat,1,3)
    GOK=0  : Call FSTA("TND") From GLOCK
    Goto AB_VAL
  Endif

  [F:TNH]TMPTNHNUM = [L]TNHNUM
  [F:TNH]TNHNUM = LNUM
  Rewrite [TNH]
  If fstat
    GOK=0 : Call FSTA("TNH") From GLOCK
    Goto AB_VAL
  Endif
  Readlock [TNH]TNH0 = LNUM
  If fstat=1
    GOK=-1 : GLOCK="$TNH"+TNHNUM : Goto ROL_VAL
  Elsif fstat
    GOK=0  : Call RSTA("TNH",TNHNUM) From GLOCK : Goto AB_VAL
  Endif

  If clalev([M:TNH0]) : If dim([M:TNH0]TNHNUM)>0 : [M:TNH0]TNHNUM = LNUM : Endif : Endif

  #If [L]PORDIGSIGN = 1
    Gosub DIGSIGN
    If [L]LRET > 1
      If GMESSAGE <> "" : Call ECR_TRACE(GMESSAGE,1) From GESECRAN : Endif
      Raz GMESSAGE : Goto AB_VAL
    Endif

  #Endif
  If [L]LRET=0
    Gosub SEND_TO_AT
  Endif

  [F:TNH]CFMFLG = 2
  Rewrite [F:TNH]
  If fstat : GOK=0 : Call FSTA("TNH") From GLOCK : Goto AB_VAL : Endif

Else

  [F:TNH]CFMFLG = 2
  Rewrite [F:TNH]
  If fstat : GOK=0 : Call FSTA("TNH") From GLOCK : Goto AB_VAL : Endif

Endif

Commit
[L]RETVAL = 1

Goto FINVAL
#----- Rollback with retry -----#
$ROL_VAL
Rollback
Call ROLL From GLOCK
If GROLL
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
  Goto FINVAL
Else
  Goto TR_VALID
Endif
#----- Definitive rollback -----#
$AB_VAL
Rollback
If GMESSAGE <> ""
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Endif
Call ECR_TRACE(mess(18,114,1),1) From GESECRAN
Call ECR_TRACE([F:TNH]TNHNUM-mess(123,197,1),0) From GESECRAN

$FINVAL
If SYMBOLTNH<>""  Unlock=SYMBOLTNH : Raz SYMBOLTNH : Endif

Call ECR_TRACE(mess(131,7711,1)-mess(124,100,1),0) From GESECRAN
If [L]PRIVTRACE = 1
  Call FERME_TRACE  From LECFIC
  Call LEC_TRACE  From LECFIC
Endif

End
######################################################################################
######################################################################################
$DIGSIGN
#signature variables
Local Char    CURTIM          : [L]CURTIM = time$
Local Date    CURDAT          : [L]CURDAT = date$
Local Char    MESSTOSIGN(250)

[L]MESSTOSIGN = format$("D:YYYY[-]MM[-]DD",[F:TNH]TRNDAT) + ";" + format$("D:YYYY[-]MM[-]DD",[L]CURDAT) + "T" + [L]CURTIM + ";" + [F:TNH]TNHTYP-[F:TNH]TNHNUM + ";" +
& "0.00" + ";"
Call SIGNDOC_NEW ([F:TNH]TNHNUM, 10, [F:TNH]TNHTYP,[L]MESSTOSIGN,[L]WCPT,[F:TNH]TRNDAT,
&             [L]CURDAT,[L]CURTIM,[F:TTN]RECTYP,[F:TTN]SAFTTRNTYP,LRET)                           From DKSLIB

Return
######################################################################################
######################################################################################
$CTRL_CHRONOLOGIC

Local Integer SEQ
Local Char    DOCNUM(GLONVCR) : DOCNUM=[L]LNUM
If clalev([F:TNHB])=0 Local File TRANNOTEH [TNHB] Endif

Repeat
 Call NUMERO_PREC(WCPT,[F:TNH]FCY,[F:TNH]TRNDAT,"",[L]DOCNUM,SEQ,LRET) From SUBANM
 If LRET<>0
    GMESSAGE = WCPT-DOCNUM-mess(60,199,1) : GOK=0 : Break
 Endif
 If SEQ>=1
    Read [F:TNHB]TNH0=DOCNUM
    If !fstat
       If [F:TNHB]TRNDAT>[F:TNH]TRNDAT
          GOK=0
          GMESSAGE = mess(145,7711,1)
       Endif
       SEQ=0
    Endif
 Endif
Until SEQ<=1
Close Local File [F:TNHB]
Return
######################################################################################
######################################################################################
$TNHTYP
#85785
If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TTN]) : Local File TABTNHTYP [TTN] : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
If fstat > 1 : Raz [F:FCY] : Endif

Link [TTN] With [FGR]FGR0=[F:TTN]GFY;GFCY As [KTTN]

Filter [KTTN] Where ([F:TTN]GFY="" | [FGR]FCY=GFCY) & ([F:TTN]LEG=[F:FCY]LEG | [F:TTN]LEG="" ) Order By [F:TTN]LEG Desc;[F:FGR]FCY Desc
Read [KTTN] First
If fstat=0
  WTNHTYP = [F:TTN]TNHTYP
Endif

Filter [KTTN]
If clalev([KTTN]) : Close File [KTTN] : Endif

Return
######################################################################################
######################################################################################
$SEND_TO_AT
If [F:TNH]ATDTCOD <> ""
   If !clalev ([F:DKD]) : Local File DKSDATA [DKD] : Endif
   Read [F:DKD]DKD0 = "SAFT-PT";[F:TNH]TNHTYP;[F:TNH]TNHNUM
   If !fstat
      If [F:DKD]ATDTCOD <> ""
         Call ECR_TRACE(mess(46,8933,1),1) From GESECRAN
      Else
         [F:DKD]ATDTCOD    = [F:TNH]ATDTCOD
         [F:DKD]ATDTCOMSTA = "0"
         [F:DKD]ATDTINPTYP = 1
         [F:DKD]RECTYP     = [F:TTN]RECTYP
         Rewrite [F:DKD]
         If fstat
            Call ECR_TRACE(mess(47,8933,1),1) From GESECRAN
         Endif
      Endif
   Else
      Call ECR_TRACE(mess(2,8933,1),1) From GESECRAN
   Endif
Else
   Local Char    AUTSND(1)
   Local Integer RETSTAT

   Read [F:BPR]BPR0=[F:TNH]BPRNUM
   If !fstat
    Call PARAM([F:TNH]FCY, "AUTCOMAT", [L]AUTSND) From ADOVAL
    # BRBAN 24-03-2015 #106027
    If [L]AUTSND = '2' & func PORLEGLIB.DOCCTR(10,'',[F:TNH]TNHTYP,[F:TNH]FCY) = 1 & [F:BPR]CRY='PT' & func PORLEGLIB1.CTRL_COMDAT([F:TNH]FCY,[F:TNH]DPEDAT,[F:TNH]ETD)=1
    Call SENDDTTOAT([F:TNH]TNHNUM,10, [L]RETSTAT) From PORLEGLIB1
   Endif
  Endif
Endif

Return
######################################################################################
######################################################################################

