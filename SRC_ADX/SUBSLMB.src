#<AdxTL>@(#)2.0.0.0 $Revision$
################################################
# Alimente le masque STOWORK
# Ce sous programme est à appeler sur l'action:
#    CREATION
################################################
$ALISTW

Local Integer I, LRET
Local Char    WSLO(GLONSLO)
# chargement des lignes à sortir
Raz [STW]
Raz [M:STW]NBLIG
Raz [STWX]
Raz [M:STWX]NBLIG
For I = 0 To [M:SLM1]NBLIG - 1
    #--- Bug 62346
    #Call ADDSTOWORKLIN("C", "S", [M:SLM1]STOFCY, [M:SLM1]WSTOCOU(I), [M:SLM1]QTYPCU(I), [M:SLM1]QTYSTU(I), LRET) From STKINT
       Call ADDSTWLIN("C","S",[M:SLM1]STOFCY,[M:SLM1]WSTOCOU(I),
&                  [M:SLM1]QTYPCU(I),[M:SLM1]QTYSTU(I),[M:SLM1]SERNUM(I),[M:SLM1]SERNUMF(I), LRET) From STKINT  # hcb 110327
    #---
    If LRET <> 0 : Raz GOK : Return : Endif
#                                                              # hcb 110327 deb
    If [F:ITM]SERMGTCOD = 4
      # Suppression no série en cours de traitement
       Call DEL_STOSERW([F:STO]ITMREF,[M:SLM1]SERNUM(I),[M:SLM1]QTYSTU(I),LRET) From STKLIB
       If LRET <> 0 : Raz GOK : Return : Endif
     Endif
#                                                              # hcb 110327 end
Next I

# Initialisation de l'en-tête (apres l'ajout de ligne car le transclasse de STL vers STW surcharge la pièce)
[M:STW]STOFCY     = [M:SLM1]STOFCY      # Site
[M:STW]TRSTYP     = 2                   # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:SLM1]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [M:SLM1]VCRNUM      # Numéro pièce
[M:STW]VCRLIN     = 0                   # Numero ligne pièce
[M:STW]ITMREF     = [M:SLM1]ITMREF      # Article
[M:STW]MVTDES     = [M:SLM1]MVTDES      # Désignation mouvement
[M:STW]PJT        = [M:SLM1]PJT         # Affaire
[M:STW]TRSFAM     = [M:SLM1]TRSFAM      # Famille mouvement
[M:STW]IPTDAT     = [M:SLM1]IPTDAT      # Date imputation
[M:STW]TRAFLG     = 0

Raz [M:SVW], [M:SDPA]
Gosub ALIVALWORK From STKVALMAJ    # => alimentation de SVW & SDPA
If sum([M:STW]QTYSTU) <> 0
    # Issue X3-25079 - 2017-02-24 by ERMIL : Transmask performance changes
    #[M:SDP] = [M:SDPA] : Raz [M:SDPA]
    # Make sure line number variables populated prior to Transmask
    Raz [M:SDP]
    Transmask [M:SDPA] To [M:SDP]
    Raz [M:SDPA]
    Gosub CAL_TOT From SUBSDP    # PRI = somme des composantes
    [M:SDP]AMTTOT = [M:SDP]PRI
    [M:SDP]PRI /= sum([M:STW]QTYSTU)
    Call PROSDP("SDP",1/sum([M:STW]QTYSTU)) From SUBSDPCOM

    Call COPSDP2VALW(0,"VALW","SDP") From SUBSDPCOM
    [M:VALW]NBLIG = 1   # CCC (2009-09-04) Bug 55614 : nblig n'était pas renseigné ce qui ne permettait pas de valoriser le nouveau lot
    [M:VALW]WSTOSEQ(0) = 1
Endif

# sauvegarde STOWORK (on va repartir du même modèle pour les entrées)
# sauvegarde STOWORK (on va repartir du même modèle pour les entrées)
If [F:SRT]RENUMCOD = 2 & [F:SRT]MIXCOD = 1         # hcb 84097
   [M:STW]BPRNUM   = [F:STL]BPSNUM
Endif

Transmask [M:STW] To [M:STWX]  # Issue 25606_Transmask [M:STWX] = [M:STW]
# mise à jour des sorties
Call MAJ_STOCK From STKMAJ
If GOK = 0 : Return : Endif

# CCC (22/06/05) Bug 30922
[M:STWX]PRIORDH = [M:STW]ISSAMTVAL/sum([M:STWX]QTYSTU)

# chargement des lignes à entrer, on repart du modèle sauvegardé

Raz [STW]
Raz [M:STW]NBLIG
Transmask [M:STWX] To [M:STW]  # Issue 25606_Transmask [M:STW] = [M:STWX]

# seul le type de mouvement change dans l'entête
[M:STW]TRSTYP     = 1                   # Type mouvement (M.704)

# on applique le nouveau lot/slot, on ajoute l'étiquetage et on change le sens
For I = 0 To [M:STWX]NBLIG - 1
    [M:STW]MAJTYP(I)       = "E"
    [M:STW]LOT(I)          = [M:SLM1]LOTDES
    If dim([M:SLM1]SLODES) > 0  : [M:STW]SLO(I)= [M:SLM1]SLODES : Endif
    [M:STW]LBEFMT(I)       = [M:SLM1]LBEFMT(I)
    [M:STW]LBENBR(I)       = [M:SLM1]LBENBR(I)
#                                                                             hcb unicite deb
    If GFEALOTLEV = 2 & [F:ITM]LOTMGTCOD=4
       Filter [F:STL] Where ITMREF = [M:SLM1]ITMREF & LOT = [M:SLM1]LOTDES
&                    Order By Key STL0
       Read [STL] First
       If !fstat
          nolign = I+1
          [M:STW] = [F:STL]
          If dim([M:SLM1]SLODES) > 0
             [M:STW]SLO(I)= [M:SLM1]SLODES
          Endif
         [M:STW]VCRTYP    = [M:STWX]VCRTYP
         [M:STW]VCRNUM    = [M:STWX]VCRNUM
         [M:STW]VCRLIN    = [M:STWX]VCRLIN
       Endif
       Filter [F:STL]
    #---Bug 71538
    # Si mélange, chargement des données du lot destination
    Elsif GMODCOD=2
       If dim([M:SLM1]SLODES)>0 WSLO=[M:SLM1]SLODES Endif
       Read [STL]STL0=[M:SLM1]ITMREF;[M:SLM1]LOTDES;WSLO
       If !fstat
          [M:STW] = [F:STL]
          # Si date péremption ou utilisation du lot origine inférieure
          # à celle du lot destination, on écrase celle du lot destination
          If [M:STWX]SHLDAT<[M:STW]SHLDAT : [M:STW]SHLDAT=[M:STWX]SHLDAT : Endif
          If [M:STWX]DLUDAT<[M:STW]DLUDAT : [M:STW]DLUDAT=[M:STWX]DLUDAT : Endif
          [M:STW]VCRTYP    = [M:STWX]VCRTYP
          [M:STW]VCRNUM    = [M:STWX]VCRNUM
          [M:STW]VCRLIN    = [M:STWX]VCRLIN
       Endif
    Endif
    #---
GPOINT = "STW_SLM1" : Gosub  ENTREE From EXEFNC  # hcb 82022

#                                                                             HCB UNICITE FIN
Next I

Raz [M:SVW], [M:SDPA]
Local Integer LLIG
LLIG = 1
Gosub ALIVALWORK From STKVALMAJ    # => alimentation de SVW

# mise à jour des entrées
Call MAJ_STOCK From STKMAJ

Return

###############################################################################
# Mise à jour des quantités après saisie du détail
# LABR doit contenir l'abréviation du masque concerné
###############################################################################
$MAJ_LIG_DOC

# a compléter
mkstat = 4
GRAFFRAICHISLM = 1

Return

###############################################################################
# DEPICK : Depick d'une ligne de stock
###############################################################################
# Paramètres E : PSTOFCY = Site
#                PSTOCOU = Chrono stock
#                PABR    = Abréviation de l'écran document
#                PRET    = Code retour (0=OK, 1=Erreur)
#
###############################################################################
Subprog DEPICK(PSTOFCY, PSTOCOU, PABR, PRET)
Value Char    PSTOFCY
Value Decimal PSTOCOU
Value Char    PABR
Variable Integer PRET

Local Integer  LRET
Local Shortint WRET
Local Integer  LSEQ
Local Integer  I1, LLIGDOC
Local Decimal  LWIPQTY, LWIPQTA
Local Integer  LNB
Local Char     LPCU(GLONUOM)
Local Decimal  LCOEF, LQTYSTYU
Local Decimal  LSTOCOU
Local Char     LSERF(GLONSER)

Local Char     LABR(10) : LABR = PABR

#--- Bug 62346
#--- Maj des cumuls quantité en cours de traitement
Local Integer WTRBEGIN
#PRET = 1
#Readlock [STO1]STO0=PSTOFCY;PSTOCOU
#If fstat : End :  Endif
#--- Fin Bug 62346

LLIGDOC = evalue("find(PSTOCOU, [M:"+PABR+"]WSTOCOU(0..[M:"+PABR+"]NBLIG))")
If !LLIGDOC : End : Else LLIGDOC-=1 : Endif

#--- Bug 62346
If adxlog<>1
  PRET=0
  Trbegin [STO1]
  WTRBEGIN=1
Endif
Readlock [STO1]STO0=PSTOFCY;PSTOCOU
If !fstat
  [F:STO1]CUMWIPQTY = max(0,[F:STO1]CUMWIPQTY-[M:SLM1]QTYSTU(LLIGDOC))
  [F:STO1]CUMWIPQTA = max(0,[F:STO1]CUMWIPQTA-([M:SLM1]QTYSTU(LLIGDOC)*[M:SLM1]POT/100))
  Call DEL_STOWIPW([F:STO1]STOCOU,[M:SLM1]QTYSTU(LLIGDOC)) From STKLIB
  Rewrite [STO1]
  If fstat
    PRET=1 : Call FSTA("STO1") From GLOCK
  Endif
Else
  PRET=1
Endif
If [F:ITM]SERMGTCOD <> 4                                                    # hcb 110327
   Readlock [STO1]STO0=PSTOFCY;PSTOCOU
   If !fstat
      [F:STO1]CUMWIPQTY = max(0,[F:STO1]CUMWIPQTY-[M:SLM1]QTYSTU(LLIGDOC))
      [F:STO1]CUMWIPQTA = max(0,[F:STO1]CUMWIPQTA-([M:SLM1]QTYSTU(LLIGDOC)*[M:SLM1]POT/100))
      Call DEL_STOWIPW([F:STO1]STOCOU,[M:SLM1]QTYSTU(LLIGDOC)) From STKLIB
      Rewrite [STO1]
      If fstat
         PRET=1 : Call FSTA("STO1") From GLOCK
      Endif
      If PRET = 0                                                                       # hcb 110327
         Dela LLIGDOC,1 [M:SLM1]NBLIG                                                   # hcb 110327
         [M:SLM1]NBLIG -= 1                                                             # hcb 110327
      Endif                                                                             # hcb 110327
   Else
      PRET=1
   Endif
#                                                                               # hcb 110327 deb
Else
   Local Integer I
   Local Integer J
   Local Integer OK
   Raz I,J
   OK = 0
   If [M:SLM1]NBLIG <> 0
      While OK <> 1
         I = find(PSTOCOU,[M:SLM1]WSTOCOU(J..[M:SLM1]NBLIG-1))
         If I<>0
            LLIGDOC = J+I-1
            J       = LLIGDOC
            Readlock [STO1]STO0=PSTOFCY;PSTOCOU
            If !fstat
               [F:STO1]CUMWIPQTY = max(0,[F:STO1]CUMWIPQTY-[M:SLM1]QTYSTU(LLIGDOC))
               [F:STO1]CUMWIPQTA = max(0,[F:STO1]CUMWIPQTA-[M:SLM1]QTYSTU(LLIGDOC))
               Call DEL_STOWIPW([F:STO1]STOCOU,[M:SLM1]QTYSTU(LLIGDOC)) From STKLIB
               Rewrite [STO1]
               If fstat
                  PRET=1 : Call FSTA("STO1") From GLOCK
                  OK = 1
               Endif
               If PRET = 0
                  Call DEL_STOSERW([F:ITM]ITMREF,[M:SLM1]SERNUM(LLIGDOC),[M:SLM1]QTYSTU(LLIGDOC),PRET) From STKLIB
               Endif
               If PRET = 0
                  Dela LLIGDOC,1,[M:SLM1]NBLIG-1 [M:SLM1]NBLIG
                  [M:SLM1]NBLIG -= 1
                  If J>[M:SLM1]NBLIG-1 OK=1 Endif
               Else
                  OK = 1
               Endif
            Endif
         Else
           OK=1
        Endif
     Wend
   Endif
Endif
#                                                                               # hcb 110327 end
If WTRBEGIN=1
  If PRET=0 : Commit : Else : Rollback : Endif
  Raz WTRBEGIN
Endif
#--- Fin bug 62346

#Dela LLIGDOC,1 [M:SLM1]NBLIG                                                   # hcb 110327
#[M:SLM1]NBLIG -= 1                                                             # hcb 110327

If [M:SLM1]NBLIG = 0 : Actzo [M:SLM1]10 : Endif
Affzo [M:SLM1]

#--- Bug 62346
#Raz PRET

End

###############################################################################
# remplissage tableau avec toutes les lignes du lot d'origine
###############################################################################
$FULL_LOT
Local Char LUSCAV
Local Char LFMT
Local Integer LMODIF
Local Decimal LCOE
Local Integer LRET

Local Char XCRITERE(250)
XCRITERE  = "[F:STO]ITMREF=[M:SLM1]ITMREF&"
XCRITERE += "[F:STO]STOFCY=[M:SLM1]STOFCY&"
XCRITERE += "[F:STO]CUNLOKFLG<>2&"
XCRITERE += "[F:STO]LOT=[M:SLM1]LOT"
If [M:SLM1]SLOMOD = 2 & dim([M:SLM1]SLO) > 0  :
    XCRITERE += '&[F:STO]SLO=[M:SLM1]SLO'
Endif
Filter [STO] Where evalue(XCRITERE) Order By Key STO3

Effzo [M:SLM1]20
[M:SLM1]NBLIG = 0

For [STO]
    # Contrôle de l'insertion
    If [M:SLM1]NBLIG + 1 >= dim([M:SLM1]STA) - 1
        Break
    Endif
    Gosub FILL_LINE
Next

Filter [STO]
Return

###############################################################################
# remplissage ligne tableau à partir d'une ligne stock
###############################################################################
$FILL_LINE
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 4 | [F:SRT]SRTNUM <> GSLMNUM                   # hcb 50197
   Read [SRT]SRT0=4;GSLMNUM : If fstat Raz [F:SRT] : Endif
Endif

# Ouverture de la ligne
nolign = [M:SLM1]NBLIG
Insa nolign,1,[M:SLM1]NBLIG [M:SLM1]NBLIG
[M:SLM1]NBLIG += 1
nolign = [M:SLM1]NBLIG
NOL = nolign-1
status = 0
If dim([M]QTYPCU)>0 : Actzo [M]QTYPCU(NOL) : Endif

If dim([M:SLM1]PALNUM)>0 [M:SLM1]PALNUM(NOL)=[F:STO]PALNUM Endif
If dim([M:SLM1]CTRNUM)>0 [M:SLM1]CTRNUM(NOL)=[F:STO]CTRNUM Endif
If dim([M:SLM1]LOC)>0    [M:SLM1]LOC(NOL)   =[F:STO]LOC    Endif
If dim([M:SLM1]LOCTYP)>0 [M:SLM1]LOCTYP(NOL)=[F:STO]LOCTYP Endif
If dim([M:SLM1]SERNUM)>0 [M:SLM1]SERNUM(NOL)=[F:STO]SERNUM Endif
[M:SLM1]STA(NOL)       = [F:STO]STA
[M:SLM1]PCU(NOL)       = [F:STO]PCU
[M:SLM1]PCUSTUCOE(NOL) = [F:STO]PCUSTUCOE
[M:SLM1]QTYPCU(NOL)    = [F:STO]QTYPCU


[M:SLM1]WSTOCOU(NOL) = [F:STO]STOCOU

Call LECITM2( [M:SLM1]STOFCY, [M:SLM1]ITMREF, "", LRET ) From STKLIB

[M:SLM1]STU(NOL) = [F:ITM]STU
[M:SLM1]QTYSTU(NOL) = [F:STO]QTYSTU

If [M:SLM1]PCU(NOL) = [F:ITM]STU
    Diszo [M:SLM1]PCU(NOL), QTYPCU(NOL), PCUSTUCOE(NOL)
    Call CTLUOM ([M:SLM1]ITMREF, 3, "", [M:SLM1]STU(NOL), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
Else

    Call CTLUOM ([M:SLM1]ITMREF, 3, "", [M:SLM1]PCU(NOL), LCOE, LUSCAV, LFMT, LMODIF) From STKACT
Endif
If [F:SRT]PRNCOD1 = 2
   #--- Bug 59444
   #[M:SLM1]LBENBR(NOL) = int([M:SLM1]QTYPCU(NOL))
   If int([M:SLM1]QTYPCU(NOL))=[M:SLM1]QTYPCU(NOL)
      [M:SLM1]LBENBR(NOL) = [M:SLM1]QTYPCU(NOL)
   Else
      [M:SLM1]LBENBR(NOL) = int([M:SLM1]QTYPCU(NOL))+1
   Endif
   #---
   [M:SLM1]LBEFMT(NOL) = LFMT
Endif
If dim([M:SLM1]SERNUM)>0 Diszo [M:SLM1]SERNUM(NOL) Endif

GPOINT = "SLM1_STO" : Gosub  ENTREE From EXEFNC  # hcb 82022

#                                                                 # hcb 110327 deb
If [F:ITM]SERMGTCOD = 4 & [F:STO]CUMWIPQTY = 0 & [F:STO]CUMWIPQTA = 0
   Local Char    PABR
   Local Integer PNOL
   PABR = "SLM1"
   PNOL  = [M:SLM1]NBLIG-1
   [M:SLM1]NBLIG -= 1
   Gosub CTR_SERIES_GLOBALE From SUBSCSB
   Return
Endif
#                                                                 # hcb 110327 end
#--- Bug 62346
# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [STO]
   WTRBEGIN=1
Endif
Readlock [STO]Curr
If !fstat
   LQTYSTU    = [F:STO]QTYSTU-[F:STO]CUMWIPQTY
   LQTYSTUACT = [F:STO]QTYSTUACT-[F:STO]CUMWIPQTA
   [F:STO]CUMWIPQTY += LQTYSTU
   [F:STO]CUMWIPQTA += LQTYSTUACT
   Rewrite [STO]
   # Création quantité en cours de traitement
   Call CRE_STOWIPW([F:STO]STOCOU,LQTYSTU,LQTYSTUACT) From STKLIB
Else
   Unlock [STO]
Endif
# Si on a ouvert une transaction
If WTRBEGIN=1
   Commit
   Raz WTRBEGIN
Endif
#--- Fin Bug 62346

Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur lot/sous-lot                           #
#-----------------------------------------------------------------------#
$VERROU
Local Char MYSYMBOL(50)
If dim([M:SLM1]SLO) > 0
    MYSYMBOL = "STL"+[M:SLM1]ITMREF+[M:SLM1]LOT + [M:SLM1]SLO
Else
    MYSYMBOL = "STL"+[M:SLM1]ITMREF+[M:SLM1]LOT
Endif
Lock = MYSYMBOL With lockwait = 0
If fstat
    GMESSAGE-=mess(43,197,1)-":"-[M:SLM1]LOT
    If [F:ITM]LOTMGTCOD = 4 & dim([M:SLM1]SLO) > 0 : GMESSAGE-=mess(456,197,1)-":"-[M:SLM1]SLO : Endif
    GMESSAGE+="\"+mess(10,100,1)
    mkstat = 2
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur lot/sous-lot                                #
#-----------------------------------------------------------------------#
$DEVERROU
Local Char MYSYMBOL(50)
If dim([M:SLM1]SLO) > 0
    MYSYMBOL = "STL"+[M:SLM1]ITMREF+[M:SLM1]LOT + [M:SLM1]SLO
Else
    MYSYMBOL = "STL"+[M:SLM1]ITMREF+[M:SLM1]LOT
Endif
Unlock=MYSYMBOL
Return

#-----------------------------------------------------------------------#
# Contrôle statuts présents dans lot                                    #
# la classe STL doit être chargée
#-----------------------------------------------------------------------#
Subprog CHECK_LOT_STA(LASTA, LQSTA, LRSTA, LIND)
Value    Integer LASTA
Value    Integer LQSTA
Value    Integer LRSTA
Variable Integer LIND

Local Integer XSTA

XSTA = 0 : LIND = 0
If LASTA = 2 : XSTA += 1 : Endif
If LQSTA = 2 : XSTA += 2 : Endif
If LRSTA = 2 : XSTA += 4 : Endif

Case XSTA
    When 1: If [F:SLF]QQQCUMQTY <> 0 | [F:SLF]RRRCUMQTY <> 0 : LIND = 4 : Endif
    When 2: If [F:SLF]AAACUMQTY <> 0 | [F:SLF]RRRCUMQTY <> 0 : LIND = 4 : Endif
    When 3: If [F:SLF]RRRCUMQTY <> 0                         : LIND = 4 : Endif
    When 4: If [F:SLF]AAACUMQTY <> 0 | [F:SLF]QQQCUMQTY <> 0 : LIND = 4 : Endif
    When 5: If [F:SLF]QQQCUMQTY <> 0                         : LIND = 4 : Endif
    When 6: If [F:SLF]AAACUMQTY <> 0                         : LIND = 4 : Endif
    When 7: # ben rien
Endcase
End

