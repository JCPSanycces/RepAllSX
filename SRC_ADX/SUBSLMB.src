############################################################################
# CHECK_LOT : Vérifie que l'opération de mélange peut être effectuée
############################################################################
# La valeur renvoyée est : 0= OK
#                          5= le lot est présent sur un autre site
#                          6= les dates de péremption ou utilisation sont différentes
#                          7= les caractéristiques des lots sont différentes
############################################################################
Funprog CHECK_LOT(PITM, PLOTDES, PSLODES)
Value Char PITM
Value Char PLOTDES
Value Char PSLODES

Local Integer LRET
Local Char    WSLO(GLONSLO)

If [F:SLF]AAACUMQTY+[F:SLF]QQQCUMQTY+[F:SLF]RRRCUMQTY <> func STKLIB.QTYLOT(PITM, PLOTDES, PSLODES,"")
   GERR=3 : LRET=5
Endif

If !clalev([F:STL1]) : Local File STOLOT [STL1] : Endif
If [F:ITM]ITMREF<>[M:SLM1]ITMREF
    Read [ITM]ITM0=[M:SLM1]ITMREF
Endif

#--- Si mélange
If GMODCOD=2
   #--- Lecture lot origine
   If dim([M:SLM1]SLO)>0 WSLO=[M:SLM1]SLO Endif
   Read [F:STL1]STL0=PITM;[M:SLM1]LOT;WSLO
   If !fstat
      If [F:STL1]SHLDAT<>[F:STL]SHLDAT | [F:STL1]DLUDAT<>[F:STL]DLUDAT
         LRET=6
      Elsif [F:STL1]USRFLD1<>[F:STL]USRFLD1 | [F:STL1]USRFLD2<>[F:STL]USRFLD2 |
&           [F:STL1]USRFLD3<>[F:STL]USRFLD3 | [F:STL1]USRFLD4<>[F:STL]USRFLD4 |
&           [F:STL1]BPSNUM <>[F:STL]BPSNUM  | [F:STL1]LTIDAT <>[F:STL]LTIDAT  |
&           [F:STL1]NEWLTIDAT<>[F:STL]NEWLTIDAT
         LRET=7
      Endif
   Endif
Endif

End LRET
