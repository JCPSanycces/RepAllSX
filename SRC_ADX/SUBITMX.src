#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque ITMX
########################################
Subprog C_NBITMCPP
Local Integer NUMLIGNE

  If status = 65 Then
    #Effacement d'une seule ligne
    Read [ILK]ILK2=SZITM;[M:ITMX]NUM(nolign-1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [ILK]
      Delete [ILK]Curr
      If fstat Then
        Rollback
        Affzo [M:ITMX]
        End
      Endif
      Commit
    Endif
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      Read [ILK]ILK2=SZITM;[M:ITMX]NUM(nolign-1)
      If fstat = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [ILK]
        Delete [ILK]Curr
        If fstat Then
          Rollback
          Affzo [M:ITMX]
          Break
        Endif
        Commit
      Endif
    Next
  Endif
End

########################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

  #Effacement de l'article concurrent précédent
  If VALEUR <> "" Then
    Read [ILK]ILK2=SZITM;[M:ITMX]NUM(nolign-1)
    If fstat = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [ILK]
      Delete [ILK]Curr
      If fstat Then
        Rollback
        End
      Endif
      Commit
    Endif
  Endif
  [M:ITMX]NUM(nolign-1) = VALEUR
  Read [ICM]ICM0=[M:ITMX]NUM(nolign-1)
  [M:ITMX]BRA(nolign-1) = [F:ICM]BRA
  [M:ITMX]SALPRI(nolign-1) = [F:ICM]SALPRI
  [M:ITMX]REF(nolign-1) = [F:ICM]REF
  Affzo [M:ITMX]BRA(nolign-1)
  Affzo [M:ITMX]SALPRI(nolign-1)
  Affzo [M:ITMX]REF(nolign-1)
  ISDIRTY = 1
End

########################################
Subprog IB_NBITMCPP
  If [M:ITMX]NUM(nolign-1) = "" Then
    Raz GBOUT1
  Else
    GBOUT1 = mess(148,195,1) #Détail
  Endif
End

########################################
Subprog C_NUM(VALEUR)
Variable Char    VALEUR()

Local Integer I

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  #Vérifie si cet article n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim([M:ITMX]NUM)-1
    If I <> nolign-1 Then
      If [M:ITMX]NUM(I) = VALEUR and [M:ITMX]NUM(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(434,196,1) #Cet article a déjà été saisi.
        GERR = 2
      Endif
    Endif
  Next
End
