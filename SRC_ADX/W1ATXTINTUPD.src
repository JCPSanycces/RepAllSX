#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ATXTINTUPD 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:53"
A_USER  = "DOC"
A_STAMP = "20181109230153"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask ATXTINTUPD [ATIU]
Gosub HORODAT
Local Inpbox "ATXTINTUPD" From GFONCTION At A_STAMP With A_WINDPREV Mask [ATIU] As [SIM_]
Grizo [ATIU]5
Grizo [ATIU]10
Grizo [ATIU]15
Grizo [ATIU]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [ATIU]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=112 : Y1(1)=4 : Y2(1)=6
X1(2)=1 : X2(2)=112 : Y1(2)=7 : Y2(2)=9
X1(3)=1 : X2(3)=112 : Y1(3)=10 : Y2(3)=28
Return

$ON_NUMERO
Onevent AFTER_CHANGE Gosub AMM_NUMERO From W1ATXTINTUPD
Onevent BEFORE_INPUT Call AS_NUMERO(zc) From W1ATXTINTUPD
Onevent CONTROL Call C_NUMERO(zc) From W1ATXTINTUPD
Return

Subprog AS_NUMERO(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(23797,GBOUT1) From OBJDIV
Call TEXTE(1000834,GBOUT2) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NUMERO(zc) From W1ATXTINTUPD
Onkey 130 Titled GBOUT2 Call B2_NUMERO(zc) From W1ATXTINTUPD
Gosub _AFF
End

Subprog C_NUMERO(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NUMERO" : GZNUM = 170 : Endif
Gosub _AFF
End

$AMM_NUMERO
Call AM_NUMERO(zc)
If !mkstat & GOBJET
 zoncou = "NUMERO" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NUMERO(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_NUMERO(VALEUR) From ATXTINTUPD
If mkstat : GERR = 1 : GZONE = "NUMERO" : GZNUM = 170 : Endif
Gosub _AFF
End

Subprog B1_NUMERO(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action STD
 Call B1_NUMERO(VALEUR) From ATXTINTUPD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NUMERO(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action STD
 Call B2_NUMERO(VALEUR) From ATXTINTUPD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_LAN
Onevent CONTROL Call C_LAN(zc) From W1ATXTINTUPD
Onevent AFTER_CHANGE Gosub AMM_LAN From W1ATXTINTUPD
Onevent BEFORE_INPUT Call AS_LAN(zc) From W1ATXTINTUPD
Return

Subprog AS_LAN(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3587,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LAN(zc) From W1ATXTINTUPD
Onkey   2 Titled GBOUTS Call S_LAN(zc) From W1ATXTINTUPD
Onkey 144 Titled GBOUTP Call P_LAN(zc) From W1ATXTINTUPD
Onkey 146 Titled GBOUTA Call SA_LAN(zc) From W1ATXTINTUPD
Gosub _AFF
End

Subprog C_LAN(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TLA","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
 If !mkstat
  ## Action STD
  Call C_LAN(VALEUR) From ATXTINTUPD
  If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LAN
Call AM_LAN(zc)
If !mkstat & GOBJET
 zoncou = "LAN" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LAN(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LAN(VALEUR) From ATXTINTUPD
If mkstat : GERR = 1 : GZONE = "LAN" : GZNUM = 1505 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLAN)")>indice
 [M]LAN(indice) = VALEUR
 Affzo ZLAN(indice)
Endif
Gosub _AFF
End

Subprog S_LAN(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call S_LAN(VALEUR) From ATXTINTUPD
Endif
Gosub _AFF
End

Subprog B1_LAN(VALEUR)
Variable Char    VALEUR()
Call OBJET("TLA",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_LAN(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TLA"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LAN(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TLA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLAN
Onevent BEFORE_AREA Gosub AV_ZLAN From W1ATXTINTUPD
Return

$AV_ZLAN
Call LECTEXTRA(zc,"TABLAN","INTDES",num$([M]LAN(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TXTPDTCODA
Onevent CONTROL Call C_TXTPDTCODA(zc) From W1ATXTINTUPD
Onevent AFTER_CHANGE Gosub AMM_TXTPDTCODA From W1ATXTINTUPD
Return

Subprog C_TXTPDTCODA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_TXTPDTCODA(VALEUR) From ATXTINTUPD
If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
Gosub _AFF
End

$AMM_TXTPDTCODA
Call AM_TXTPDTCODA(zc)
If !mkstat & GOBJET
 zoncou = "TXTPDTCODA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TXTPDTCODA(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TXTPDTCODA(VALEUR) From ATXTINTUPD
If mkstat : GERR = 1 : GZONE = "TXTPDTCODA" : GZNUM = 12792 : Endif
Gosub _AFF
End

$ON_TXTSRVLANORI
Return

$ON_ZTXTSRVLANORI
Onevent BEFORE_AREA Gosub AV_ZTXTSRVLANORI From W1ATXTINTUPD
Return

$AV_ZTXTSRVLANORI
Call LECTEXTRA(zc,"TABLAN","INTDES",num$([M]TXTSRVLANORI(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_ATXLANORI
Return

$ON_ZATXLANORI
Onevent BEFORE_AREA Gosub AV_ZATXLANORI From W1ATXTINTUPD
Return

$AV_ZATXLANORI
Call LECTEXTRA(zc,"TABLAN","INTDES",num$([M]ATXLANORI(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_UPDLANORI
Onevent CONTROL Call C_UPDLANORI(zc) From W1ATXTINTUPD
Onevent BEFORE_INPUT Call AS_UPDLANORI(zc) From W1ATXTINTUPD
Return

Subprog AS_UPDLANORI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(3587,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_UPDLANORI(zc) From W1ATXTINTUPD
Onkey   2 Titled GBOUTS Call S_UPDLANORI(zc) From W1ATXTINTUPD
Onkey 144 Titled GBOUTP Call P_UPDLANORI(zc) From W1ATXTINTUPD
Onkey 146 Titled GBOUTA Call SA_UPDLANORI(zc) From W1ATXTINTUPD
Gosub _AFF
End

Subprog C_UPDLANORI(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TLA","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "UPDLANORI" : GZNUM = 9760 : Endif
Gosub _AFF
End

Subprog S_UPDLANORI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TLA"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_UPDLANORI(VALEUR)
Variable Char    VALEUR()
Call OBJET("TLA",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_UPDLANORI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TLA"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_UPDLANORI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TLA",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


