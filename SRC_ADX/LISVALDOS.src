#<AdxTL>@(#)6.0.0.0 $Revision$
Call IMPRIME("LISVALDOS","") From ETAT
End

####################################################
## Etat des temps par section
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

If clalev([F:VFD])=0  : Local File VALFDR   [VFD]  : Endif
If clalev([F:VCP])=0  : Local File VALCPY   [VCP]  : Endif
If clalev([F:VFC])=0  : Local File VALFCY   [VFC]  : Endif

Local Date DATDEB, DATFIN, DATREF1, DATREF2
Local Char PARAM(30)

Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM)   : DATDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM)   : DATFIN = PARAM

Case [M]RPTCOD
 When "LISVALDOS" :  Gosub VALDOS
 When "LISVALCPY" :  Gosub VALSOC
 When "LISVALFCY" :  Gosub VALSIT
Endcase

If DATREF1=[0/0/0] : DATREF1=date$ : Endif
If DATREF2=[0/0/0] : DATREF2=date$ : Endif

PARAM=DATREF1
Call SETPARAM("refdeb",NBPAR,PARAMETRE,PARAM) From ETAT
PARAM=DATREF2
Call SETPARAM("reffin",NBPAR,PARAMETRE,PARAM) From ETAT

End

#Recherche date exacte de début de validité
###########################################
$VALDOS
Raz DATREF1, DATREF2 : I=0
Filter [F:VFD] Where DAT<=DATFIN Order By DAT Desc 
For [F:VFD] 
 If I=0 : DATREF2=[F:VFD]DAT : I+=1 : Endif
 DATREF1=[F:VFD]DAT 
 If [F:VFD]DAT<DATDEB : Break : Endif
Next
Return

#Recherche date exacte de début de validité
###########################################
$VALSOC
Local Char SOCIETE (GLONCPY)
Call GETPARAM("cpy",NBPAR,PARAMETRE,SOCIETE)
Raz DATREF1, DATREF2 : I=0
Filter [F:VCP] Where CPY=SOCIETE & DAT<=DATFIN Order By CPY;DAT Desc 
For [F:VCP] 
 If I=0 : DATREF2=[F:VCP]DAT : I+=1 : Endif
 DATREF1=[F:VCP]DAT 
 If [F:VCP]DAT<DATDEB : Break : Endif
Next
Return

#Recherche date exacte de début de validité
###########################################
$VALSIT
Local Char SITE (GLONFCY)
Call GETPARAM("fcy",NBPAR,PARAMETRE,SITE)
Raz DATREF1, DATREF2 : I=0
Filter [F:VFC] Where FCY=SITE & DAT<=DATFIN Order By FCY;DAT Desc 
For [F:VFC] 
 If I=0 : DATREF2=[F:VFC]DAT : I+=1 : Endif
 DATREF1=[F:VFC]DAT 
 If [F:VFC]DAT<DATDEB : Break : Endif
Next
Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End


