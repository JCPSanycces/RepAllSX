#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################
## Etat KE-NSSF-RET-NEW
####################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    SOCIETE(GLONCPY), ETAT(GLONARP), TYPRET(2)
Local Char    PARAM(20)
Local Char    CRITERE1(250) , CRITERE2(250)
Local Integer K , NUMREQ , OK
Local Char YEA(4), TAXMON(2)

If clalev([F:HSP])=0    : Local File HISTOPAYE    [HSP]        : Endif
If clalev([F:VEP])=0    : Local File VALEMP       [VEP]        : Endif
If clalev([F:FGR])=0    : Local File FACGROUP     [FGR]        : Endif
If clalev([F:TMP])=0    : Local File TMPHISTO     [TMP]        : Endif
If clalev([F:ACC])=0    : Local File ACCES        [ACC]        : Endif
If clalev([F:ID])=0     : Local File EMPLOID      [ID]         : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR     [HRCTR]      : Endif
If clalev([F:FCY])=0    : Local File FACILITY     [FCY]        : Endif
If clalev([F:CPY])=0    : Local File COMPANY      [CPY]        : Endif
If clalev([F:CPYAFR])=0 : Local File HRCOMPANYAFR [CPYAFR]     : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET     [HRPEOD]     : Endif
If clalev([F:ARM])=0    : Local File AREPORTM     [ARM]        : Endif
If clalev([F:ESA])=0    : Local File EMPLOIDSA    [ESA]        : Endif
If clalev([F:EAF])=0    : Local File EMPLOIDAFR   [EAF]        : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("cpy",NBPAR,PARAMETRE,SOCIETE)
Call GETPARAM("mon",NBPAR,PARAMETRE,TAXMON)
Call GETPARAM("year",NBPAR,PARAMETRE,YEA)
Call GETPARAM("typret",NBPAR,PARAMETRE,TYPRET)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1="1=1"
CRITERE1 = "[F:HSP]TYP=6"

If val(TAXMON)<>0
 CRITERE1 -= '& [F:HRPEOD]TAXMON='+TAXMON+''
Endif

If val(YEA)<>0
 CRITERE1 -= '& [F:HRPEOD]PERYEA='+YEA+''
Endif

CRITERE2 = '[F:FGR]CPY="'+SOCIETE+'"'

Link [HSP] With [VEP]VEP5=[F:HSP]BUL
& , [FGR]FGR0=SOCIETE;[F:VEP]FCY
& , [HRPEOD]HRPEOD0 = [F:VEP]PERCOD;[F:VEP]PERYEA;[F:VEP]PERNUM
& , [HRCTR]CTR0 = [F:VEP]EMP;[F:VEP]CTRNUM;[F:VEP]CTRDAT
& As [LHSP]
& Where evalue(CRITERE1) & evalue(CRITERE2) & ([F:HSP]RUB="ARNSS2_MTD" or [F:HSP]RUB="ARRNSS_MTD" or [F:HSP]RUB="NSSF_V_EEM" or [F:HSP]RUB="NSSF_V_ERM" or [F:HSP]RUB="TIER1_EE_M" or [F:HSP]RUB=
& "TIER1_ER_M" or [F:HSP]RUB="TIER2_EE_M" or [F:HSP]RUB="TIER2_ER_M" or [F:HSP]RUB="TIER3_EE_M" or [F:HSP]RUB="TIER3_ER_M" or [F:HSP]RUB="PENS_NEW_A" or [F:HSP]RUB="PENSAL_REG" or [F:HSP]RUB=
& "PENSEE_MTD" or [F:HSP]RUB="PENSER_MTD" or [F:HSP]RUB="ARNSER_MTD" or [F:HSP]RUB="ARNS2ER_MT")
& Order By Key CLE=[F:HSP]EMP;[F:HSP]CTRNUM;[F:HSP]DAT

SVFONCTION = GFONCTION
Call GETPARAM("X3FCT",NBPAR,PARAMETRE,GFONCTION)
Call AUTORIS From EXEFNC

Call DEBTRANS From GLOCK
Gosub TR1
Call TEMPOFF From GESECRAN
GFONCTION = SVFONCTION
Call AUTORIS From EXEFNC

End

$TR1

Local Integer COUNTER
COUNTER=0


GOK = 1
Trbegin [ARM]
 Delete [ARM] Where USR=GUSER & RPTCOD=[L]ETAT
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR1
 Endif

 K = 0
 For [LHSP]CLE(2)
  Read [ID]ID0=[F:HSP]EMP
  If !fstat
   Filter [HRCTR] Where REFNUM=[F:HSP]EMP & CTRNUM=[F:HSP]CTRNUM
   Read [HRCTR]CTR0 Last
   Filter [HRCTR]
   If !fstat
    Call CONTROLE([F:HSP]EMP,[F:HSP]DAT,[F:HSP]CTRNUM,"",OK,1) From DIVPAYE
   Else OK=0
   Endif
  Else OK =0
  Endif
  If OK
   For [LHSP]CLE
    Raz [F:ARM]
    K+=1
    Gosub CALC_CONTRIBUTIONS
    Gosub CALC_PENSAL_NEW
    Read [ESA]ESA0=[HSP]EMP
    Read [EAF]EAF0=[HSP]EMP
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]CLEA1  = [L]SOCIETE
    [F:ARM]CLEN1  = [L]CONTTYP1
    [F:ARM]CLEMD1 = [L]AMT_PENSAL
    [F:ARM]CLEMD2 = [L]AMT_MEMBER
    [F:ARM]CLEMD3 = [L]EMP_CONT
    [F:ARM]CLEMD4 = [L]TOTAL_AMT
    [F:ARM]NUMLIG = K
    [F:ARM]CLEN2  = [L]INCOMETYP1
    [F:ARM]CLEA2  = [HRCTR]REFNUM
    [F:ARM]CLEA3  = [F:ID]NAM
    [F:ARM]CLEA4  = [F:ID]SRN
    [F:ARM]CLEA5  = [F:ESA]SECNAM
    [F:ARM]CLEA6  = [F:EAF]EMPUID
    [F:ARM]CLEA7  = [F:HRCTR]EMPTAXNUM
    [F:ARM]CLEA8  = [F:ID]NUMSSC
    [F:ARM]CLEA9  = [HRCTR]CTRNUM
    [F:ARM]CLED1  = [HRCTR]CTRDAT
    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
   Next
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$CHECK_CONT_TYPE

Local Integer TOT101, TOT102, TOT103
Local Decimal TIEREE, TIERER, ARNMTD
Local Decimal TIEREE2, TIERER2, ARNMTD2
Local Decimal TIEREE3, TIERER3
Local Decimal AMTNSSVEEM, AMTNSSVERM, TOTNSSVERM
Local Decimal ARNSER_MTD, ARNS2ER_MT
Local Integer CONTTYP1

#Initialize
TOT101=0
TOT102=0
TOT103=0
TIEREE=0
TIERER=0
ARNMTD=0
TIEREE2=0
TIERER2=0
ARNMTD2=0
TIEREE3=0
TIERER3=0
AMTNSSVEEM=0
AMTNSSVERM=0
TOTNSSVERM=0

CONTTYP1 =0

If TYPRET = "1" Then

  If [F:HSP]RUB = "TIER1_EE_M" Then
      TIEREE = [F:HSP]AMT
  Endif

  If [F:HSP]RUB = "TIER1_ER_M" Then
      TIERER = [F:HSP]AMT
  Endif

  If [F:HSP]RUB = "ARRNSS_MTD" Then
      ARNMTD = [F:HSP]AMT
  Endif

    If [F:HSP]RUB = "ARNSER_MTD" Then
      ARNSER_MTD = [F:HSP]AMT
  Endif


  TOT101 = TIEREE + TIERER + ARNMTD + ARNSER_MTD

  If TOT101 > 0 Then
    CONTTYP1 =101
  Endif

  If [F:HSP]RUB = "TIER2_EE_M" Then
      TIEREE2 = [F:HSP]AMT
  Endif

  If [F:HSP]RUB  = "TIER2_ER_M" Then
      TIERER2 = [F:HSP]AMT
  Endif

  If [F:HSP]RUB  = "ARNSS2_MTD" Then
      ARNMTD2 = [F:HSP]AMT
  Endif

    If [F:HSP]RUB  = "ARNS2ER_MT" Then
      ARNS2ER_MT = [F:HSP]AMT
  Endif

  TOT102 = TIEREE2 + TIERER2 + ARNMTD2 + ARNS2ER_MT

  If TOT102 > 0 Then
    CONTTYP1 =102
  Endif

  If [F:HSP]RUB = "TIER3_EE_M" Then
      TIEREE3 = [F:HSP]AMT
  Endif

  If [F:HSP]RUB = "TIER3_ER_M" Then
      TIERER3 = [F:HSP]AMT
  Endif

  TOT103 = TIEREE3 + TIERER3

  If TOT103 > 0 Then
    CONTTYP1 =103
  Endif


  If [F:HSP]RUB = "NSSF_V_EEM" Then
      AMTNSSVEEM = [F:HSP]AMT
  Endif

  If [F:HSP]RUB = "NSSF_V_ERM" Then
      AMTNSSVERM = [F:HSP]AMT
  Endif

  TOTNSSVERM = AMTNSSVEEM + AMTNSSVERM

  If TOTNSSVERM > 0 Then
      CONTTYP1 =105
  Endif
Elsif TYPRET="3" Then
  CONTTYP1=200
Endif

Return

$CHECK_INC_TYPE

Local Decimal TOT1, TOT2
Local Decimal TIEREE, TIERER
Local Decimal TIEREE2, TIERER2
Local Decimal TIEREE3, TIERER3
Local Decimal AMTNSSVEEM, AMTNSSVERM
Local Integer INCOMETYP1

#Initialize
TOT1=0
TOT2=0
TIEREE=0
TIERER=0
TIEREE2=0
TIERER2=0
TIEREE3=0
TIERER3=0
AMTNSSVEEM=0
AMTNSSVERM=0

INCOMETYP1 =0

If TYPRET="1" Then
  If [L]CONTTYP1=101 or [L]CONTTYP1=102 or [L]CONTTYP1=103 or [L]CONTTYP1=105 Then
    If [F:HSP]RUB = "TIER1_EE_M" Then
        TIEREE = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "TIER1_ER_M" Then
        TIERER = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "TIER2_EE_M" Then
        TIEREE2 = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "TIER2_ER_M" Then
        TIERER2 = [F:HSP]AMT
    Endif

    If [F:HSP]RUB  = "TIER3_EE_M" Then
        TIEREE3 = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "TIER3_ER_M" Then
        TIERER3 = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "NSSF_V_EEM" Then
        AMTNSSVEEM = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "NSSF_V_ERM" Then
        AMTNSSVERM = [F:HSP]AMT
    Endif

    TOT1 = TIEREE + TIERER + TIEREE2 + TIERER2 + TIEREE3 + TIERER3 + AMTNSSVEEM + AMTNSSVERM

    If TOT1 > 0 Then
       INCOMETYP1 = 1
    Endif
  Endif
  If [L]CONTTYP1=102 or [L]CONTTYP1=101 Then
    If [F:HSP]RUB = "ARRNSS_MTD" Then
        AMTNSSVEEM = [F:HSP]AMT
    Endif

    If [F:HSP]RUB = "ARNSS2_MTD" Then
        AMTNSSVERM = [F:HSP]AMT
    Endif

    TOT2 = AMTNSSVEEM + AMTNSSVERM

    If TOT2 > 0 Then
        INCOMETYP1 = 2
    Endif
  Endif
Elsif TYPRET="3" Then
  INCOMETYP1=1
Endif
Return

$CALC_PENSAL_NEW

Local Decimal AMT_PENSAL, TOT_INCOME

TOT_INCOME=0
AMT_PENSAL=0
If clalev([F:HSP2])=0: Local File HISTOPAYE [F:HSP2] : Endif
If clalev([F:VEP2])=0: Local File VALEMP [F:VEP2] : Endif


If TYPRET = "1" Then
  #Filter [F:HSP2] Where EMP=[HRCTR]REFNUM and RUB="PENS_NEW_A" and month(DAT)=val([L]TAXMON)
  Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="PENS_NEW_A" and month(DAT)=val([L]TAXMON)
  Read [LHSP2] Last
  If !fstat
    AMT_PENSAL = [LHSP2]AMT
  Endif
Elsif TYPRET ="3" Then
  #Filter [F:HSP2] Where EMP=[HRCTR]REFNUM and RUB="PENSAL_REG" and month(DAT)=val([L]TAXMON)
    Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="PENSAL_REG" and month(DAT)=val([L]TAXMON)
  Read [LHSP2] Last
  #Read [F:HSP2] Last
  If !fstat
    AMT_PENSAL = [LHSP2]AMT
  Endif
Endif

Return

$CALC_CONTRIBUTIONS

Local Decimal AMT_MEMBER, TOTAL_AMT, EMP_CONT
Local Integer COUNT1
Gosub CHECK_CONT_TYPE
Gosub CHECK_INC_TYPE

If clalev([F:HSP2])=0: Local File HISTOPAYE [F:HSP2] : Endif
If clalev([F:VEP2])=0: Local File VALEMP    [F:VEP2] : Endif

AMT_MEMBER=0
TOTAL_AMT=0
EMP_CONT=0

If TYPRET="1" Then
  If [L]CONTTYP1=101  Then
    If [L]INCOMETYP1=1  Then
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER1_EE_M" and month(DAT)=val([L]TAXMON)
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER1_EE_M" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
    Elsif [L]INCOMETYP1=2
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="ARRNSS_MTD" and month(DAT)=val([L]TAXMON)
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="ARRNSS_MTD" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=102 Then
    If [L]INCOMETYP1=1 Then
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER2_EE_M" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER2_EE_M" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
    Elsif [L]INCOMETYP1=2 Then
                Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="ARNSS2_MTD" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="ARNSS2_MTD" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=103 Then
    If [L]INCOMETYP1=1 Then
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER3_EE_M" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER3_EE_M" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [F:HSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=105 Then
    If [L]INCOMETYP1=1  Then
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="NSSF_V_EEM" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="NSSF_V_EEM" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
    Endif
  Endif
  #Filter [F:HSP]

  If [L]CONTTYP1=101  Then
    If [L]INCOMETYP1=1 Then
     Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER1_ER_M" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER1_ER_M" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Elsif [L]INCOMETYP1=2 Then
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="ARNSER_MTD" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="ARNSER_MTD" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=102 Then
    If [L]INCOMETYP1=1 Then
     Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER2_ER_M" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER2_ER_M" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Elsif [L]INCOMETYP1=2 Then
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="ARNS2ER_MT" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="ARNS2ER_MT" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=103 Then
    If [L]INCOMETYP1=1 Then
     Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="TIER3_ER_M" and month(DAT)=val([L]TAXMON)
     Read [LHSP2] Last
     # Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="TIER3_ER_M" and month(DAT)=val([L]TAXMON)
     # Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Endif
  Elsif [L]CONTTYP1=105 Then
    If [L]INCOMETYP1=1 Then
     Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="NSSF_V_ERM" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="NSSF_V_ERM" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
    Endif
  Endif
  #Filter [F:HSP]
Elsif TYPRET="3" Then
  If [L]CONTTYP1=200 and [L]INCOMETYP1=1  Then
      LHSP2
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="PENSER_MTD" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="PENSER_MTD" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      If !fstat Then
        EMP_CONT = [LHSP2]AMT
      Endif
      #Filter [F:HSP] Where EMP=[HRCTR]REFNUM and RUB="PENSEE_MTD" and month(DAT)=val([L]TAXMON)
      #Read [F:HSP] First
      Link [HSP2] With [VEP2]VEP5=[F:HSP2]BUL
& As [LHSP2]
& Where [F:HSP2]EMP=[HRCTR]REFNUM and  [VEP2]CTRNUM=[HRCTR]CTRNUM and [VEP2]CTRDAT=[HRCTR]CTRDAT and [F:HSP2]RUB="PENSEE_MTD" and month(DAT)=val([L]TAXMON)
      Read [LHSP2] Last
      If !fstat Then
        AMT_MEMBER = [LHSP2]AMT
      Endif
  Endif
  #Filter [F:HSP]
Endif
TOTAL_AMT=EMP_CONT+AMT_MEMBER

Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

