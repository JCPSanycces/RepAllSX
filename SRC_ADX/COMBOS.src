#<AdxTL>@(#)6.0.0.0 $Revision$


############################################################################################
## Initialisation des menus locaux en fonction des pays
############################################################################################
Subprog INICOMBO(MENLOC)
Value Integer MENLOC

Raz GMENLOC : # Tout est autorisé par défaut
GCOMBO = MENLOC

# GPORTVA = Gestion TVA Portugaise (KPD)

Case MENLOC

 When 609 : # Type de TVA
  If !GPORTVA
   GMENLOC(5) = 1
   GMENLOC(6) = 1
   GMENLOC(7) = 1
  Endif

 When 646 : # Type d'achats
  # If !GPORTVA
  If !GPORTVA & GPRODUIT=0 & !func AFNC.ACTIV("KSP") : # Gestion TVA Espagnole (KSP)
   GMENLOC(3) = 1
  Endif
Endcase
End

############################################################################################
## Sous-programme qui positionne les variables ad hoc pour les traitements automatiques
############################################################################################
$COMBOS
If sum(GMENLOC)<>0
 Local Integer WM , WN , WI
 WM = len(mess(0,GCOMBO,1))
 If WM>=1
  Local Integer WCOMBO(1..WM)
  For WI=1 To len(mess(0,GCOMBO,1))
   If GMENLOC(WI)<>0
    WN += 1
    WCOMBO(WN) = WI
   Endif
  Next WI
 Endif
Endif
Return
