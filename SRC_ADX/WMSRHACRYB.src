$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 3381: RES='Table des Pays'
   When 263: RES='Pays'
   When 1505: RES='Langue'
   When 31229: RES='Continent'
   When 323: RES='Devise'
  Endcase
 When "ENG":
  Case _ID
   When 3381: RES='Country table'
   When 263: RES='Country'
   When 1505: RES='Language'
   When 31229: RES='Continent'
   When 323: RES='Currency'
  Endcase
 When "ITA":
  Case _ID
   When 3381: RES='Tabella Paesi'
   When 263: RES='Paese'
   When 1505: RES='Lingua'
   When 31229: RES='Continente'
   When 323: RES='Valuta'
  Endcase
 When "POR":
  Case _ID
   When 3381: RES='Tabela dos Países'
   When 263: RES='País'
   When 1505: RES='Língua'
   When 31229: RES='Continente'
   When 323: RES='Divisa'
  Endcase
 When "SPA":
  Case _ID
   When 3381: RES='Tabla de Países'
   When 263: RES='País'
   When 1505: RES='Idioma'
   When 31229: RES='Continente'
   When 323: RES='Divisa'
  Endcase
 When "BRI":
  Case _ID
   When 3381: RES='Countries'
   When 263: RES='Country'
   When 1505: RES='Language'
   When 31229: RES='Continent'
   When 323: RES='Currency'
  Endcase
 When "GER":
  Case _ID
   When 3381: RES='Ländertabelle'
   When 263: RES='Land'
   When 1505: RES='Sprache'
   When 31229: RES='Kontinent'
