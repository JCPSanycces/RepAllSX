   When 31229: RES='Kontynent'
   When 323: RES='Waluta'
  Endcase
 When "CHI":
  Case _ID
   When 3381: RES='国家'
   When 263: RES='国家'
   When 1505: RES='语言'
   When 31229: RES='洲'
   When 323: RES='货币'
  Endcase
 When "ARB":
