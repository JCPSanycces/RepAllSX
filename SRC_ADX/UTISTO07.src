#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTISTO07   Moulinette pour initialiser le paramètre AUZMOD             #
#            des zones écran de type EMP + validation des écrans         #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTISTO07(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO07(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer STAT
Local Char APPLI : APPLI = DOSSIER

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif

Call ECR_TRACE("UTISTO07: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:AMZ9])  =0  Local File =DOSSIER+".AMSKZON"   [AMZ9] : Endif
If clalev([F:AMP9])  =0  Local File =DOSSIER+".AMSKPAR"   [AMP9] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Gosub OUVFIC From VALMSKLEC

Filter [AMZ9] Where CODTYP="EMP"
For [AMZ9]CODE(1)
    Call ECR_TRACE("Screen processed :"+[F:AMZ9]CODMSK,0) From GESECRAN
    Trbegin [AMP9]
    For [AMZ9]CODE
        Read [AMP9]CODPAR=1;[F:AMZ9]CODMSK;[F:AMZ9]CODZON;"AUZMOD"
        If fstat=0
            If !find([F:AMP9]VALPAR,'""','"*"')
                [F:AMP9]VALPAR='""'
                Rewrite [AMP9]
                COMPTEUR += 1
            Endif
        Else
            [F:AMP9]TYPAFF=1
            [F:AMP9]CODAFF=[F:AMZ9]CODMSK
            [F:AMP9]CODZON=[F:AMZ9]CODZON
            [F:AMP9]CODPAR="AUZMOD"
            [F:AMP9]VALPAR='""'
            Write [AMP9]
            COMPTEUR += 1
        Endif
    Next
    Commit
    #---- Validation de l'écran ----#
    If DOSSIER=nomap
        Lock ="AMK"+[F:AMZ9]CODMSK With lockwait=0
    Else
        Lock ="AMK"+[F:AMZ9]CODMSK From =DOSSIER With lockwait=0
    Endif
    If fstat=0
        Call VALID([F:AMZ9]CODMSK,DOSSIER,[F:ADS]NBRLAN,[F:ADS]LAN,1,STAT) From VALMSK
        If DOSSIER=nomap
            Unlock ="AMK"+[F:AMZ9]CODMSK With lockwait=0
        Else
            Unlock ="AMK"+[F:AMZ9]CODMSK From =DOSSIER With lockwait=0
        Endif
    Else
        Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
    Endif
    
Next

Call ECR_TRACE("UTISTO07 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO07(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call MAJ_UTISTO07(APPLI)
End




