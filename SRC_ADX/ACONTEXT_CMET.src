# bug 98387 to create all child classes
$AINIT_ACTX
If SELF.AFOLD=null
 [L]ARET_VALUE = fmet SELF.AINIT
Endif
Return

#------------------------------------------------------------------------------#
$ACTX_INIT_LAN
Gosub AINIT_ACTX : # bug 98387 to create all child classes

SELF.isReadonly = 0

Gosub INIT_AFOLDER

If [L]ARET_VALUE = 0
 Gosub L_SET_LAN : # 98854
 SELF.isReadonly = 0 : # 98854

 Gosub L_SET_LOGIN

# 98854
# #it the LOGIN is OK the language can be set :
# If [L]ARET_VALUE = 0
#  Gosub L_SET_LAN
# Endif

 Close Local File [ADW_ACTX]
Endif
SELF.isReadonly = 1
Return

#------------------------------------------------------------------------------#
$INIT_AFOLDER
SELF.AFOLDER = [L]AFOLDER
Gosub INIT_ASOLUTION
Return

#------------------------------------------------------------------------------#
$INIT_ASOLUTION

Local Integer I , J
Local Char    DOSREF(GLONADS) , PATH_NAMSOL(250)
Local Clbfile CLOB(2)

For I=7 To 0 Step -1
 If adxmother(I)<>""
  DOSREF = adxmother(I)
  Break
 Endif
Next I

PATH_NAMSOL = filpath("","","",DOSREF)
PATH_NAMSOL = left$(PATH_NAMSOL,len(PATH_NAMSOL)-len(DOSREF))
PATH_NAMSOL += "solution.xml"

SELF.ASOLUTION = ""

If filinfo(PATH_NAMSOL,7)>0

 Openi PATH_NAMSOL,0 Using [SOLUTION]
 Iomode adxifs ""    Using [SOLUTION]
 Iomode adxirs ""    Using [SOLUTION]
 Iomode adxium GUTF8 Using [SOLUTION]
 Rdseq CLOB          Using [SOLUTION]
 Openi               Using [SOLUTION]

 I = instr(1,CLOB,"<solution")
 If I
  I = instr(I,CLOB,"name")
  If I
   I = instr(I,CLOB,'"')
   If I
    J = instr(I+1,CLOB,'"')
    If J
     SELF.ASOLUTION = seg$(CLOB,I+1,J-1)
    Endif
   Endif
  Endif
 Endif

Endif

Return

#------------------------------------------------------------------------------#
$ACTX_INIT_LANISO
Gosub AINIT_ACTX : # bug 98387 to create all child classes
#Call TRACE("DBG ACTX_INIT_LANISO") From ASYRCOM
#Call TRACE("DBG ->INIT_AFOLDER") From ASYRCOM
SELF.isReadonly = 0

Gosub INIT_AFOLDER

If [L]ARET_VALUE = 0
 Gosub ACTX_SET_LANISO : #98854
 SELF.isReadonly = 0 : #98854

 #Call TRACE("DBG ->L_SET_LOGIN") From ASYRCOM
 Gosub L_SET_LOGIN

# 98854
# #it the LOGIN is OK the language can be set :
# If [L]ARET_VALUE = 0
#  #Call TRACE("DBG ->ACTX_SET_LANISO") From ASYRCOM
#  Gosub ACTX_SET_LANISO
# Endif

 Close Local File [ADW_ACTX]
Endif
SELF.isReadonly = 1
Return



#------------------------------------------------------------------------------#
$ACTX_SET_LANISO
Gosub AINIT_ACTX : # bug 98387 to create all child classes
Local Char LAN(10)
#Compute the language mapped to the LANISO :
#Call TRACE("DBG ->ACTX_SET_LANISO [L]LANISO:"+[L]LANISO) From ASYRCOM
[L]LAN = func ADS_TOOL.SEARCH_LANX3(SELF.AFOLDER,[L]LANISO)
#Call TRACE("DBG ->ACTX_SET_LANISO [L]LAN:"+[L]LAN) From ASYRCOM
# set the language :
Gosub L_SET_LAN
#set the LANISO property :
SELF.isReadonly = 0

SELF.LANISO = [L]LANISO
SELF.isReadonly = 1
Kill [L]LAN
Return

#------------------------------------------------------------------------------#
$ACLEAN
Raz [L]ARET_VALUE
Gosub L_ACLEAN
Return

#------------ $ACTX_xxx internal use only ------------#
$L_ACLEAN
SELF.isReadonly = 0
Local Integer L_ERR
L_ERR = fmet SELF.AINIT
If L_ERR > 2
 # Error 3 : AINIT error
 [L]ARET_VALUE = 3
Endif
If [L]ARET_VALUE = 0
 L_ERR = fmet SELF.APARAM._ACLEAN
 If L_ERR > 0
  # Error 4 : APARAM.CLEAN error
  [L]ARET_VALUE = 4
  Return
 Endif
 #L_ERR = fmet SELF.ACACHE.ACLEAN
 If L_ERR > 0
  [L]ARET_VALUE = 4
 Endif
Endif
SELF.isReadonly = 1
Return

#------------ $ACTX_xxx internal use only ------------#
$L_SET_LAN
If !len(SELF.LAN) & !len([L]LAN)
 # The context's language isn't set and the isolan received isn't correct :
 [L]LAN = func ADS_TOOL.GET_LANDEF(SELF.AFOLDER)
Endif

If len([L]LAN)
Local Char  L_LAN(10)
Local Char  L_LAN_OLD(10)

#Call TRACE("DBG ->L_SET_LAN:"+[L]LAN) From ASYRCOM

 # keep memory of the current LAN value
 [L]L_LAN_OLD = SELF.LAN
 [L]L_LAN = [L]LAN

 #Is SELF language supported by the folder ?
 #107661
 If func ADS_TOOL.CHECK_LAN(SELF.AFOLDER, [L]L_LAN) <= 0
   [L]L_LAN = func ADS_TOOL.SEARCH_LANRPL(SELF.AFOLDER, [L]L_LAN)
 Endif

 If func ADS_TOOL.CHECK_LAN(SELF.AFOLDER, [L]L_LAN) <= 0
  # NO :
  # warning -1: LAN not activated for given dossier, apply the default LAN
  [L]ARET_VALUE = -1
  # Get the folder's default language
  [L]L_LAN = func ADS_TOOL.GET_LANDEF(SELF.AFOLDER)
  #Call TRACE("DBG ->GET_LANDEF:"+[L]L_LAN) From ASYRCOM
 Endif

 If (len([L]L_LAN_OLD) > 0) & ([L]L_LAN <> [L]L_LAN_OLD)
  #If the computed language is different from the current language then clean the context :
  Gosub ACLEAN
 Endif

 # Set the language :
 SELF.isReadonly = 0
 SELF.LAN = [L]L_LAN
 SELF.isReadonly = 1

 #set the language for the engine
 messname(0) = SELF.LAN
 adxmbm = adxmbm
 adxrob(0)   = "ECR"
 adxrob(1)   = "M"+SELF.LAN

 #Set the local settings dependings on the language
 Gosub L_SET_LOCAL_SETTINGS

 #Destroy local variables :
 Kill [L]L_LAN
 Kill [L]L_LAN_OLD
Endif
Return

#------------ $ACTX_xxx internal use only ------------#
$L_SET_LOGIN
Local Char SUPDOS(20),READOS(10),REASUP(10)
Local Integer TSTDOS,ERROR
Local File =[L]AFOLDER+".ADOVAL"  [ADW_ACTX]

Read [ADW_ACTX]ADW0 = "";"";"TEST"
If fstat or val([ADW_ACTX]VALEUR )<>2
 TSTDOS = 0
Else
 TSTDOS = 1
Endif

If !TSTDOS
 Read [ADW_ACTX]ADW0 = "";"";"SUPDOS"
 If !fstat
  [L]SUPDOS = [ADW_ACTX]VALEUR
 Endif

 Local File =[L]SUPDOS+".ADOVAL"  [SUP_ACTX]

 Read [ADW_ACTX]ADW0 = "";"";"RELEASE"
 If !fstat : READOS = [ADW_ACTX]VALEUR : Endif
 Read [SUP_ACTX]ADW0 = "";"";"RELEASE"
 If !fstat : REASUP = [SUP_ACTX]VALEUR : Endif

 If READOS <> REASUP
  [L]ARET_VALUE = 10 : # Release of this folder not up to date compare to the mother X3 folder
  Return
 Endif

Endif

#111173 check ENAFLG and USRCONNECT
[L]ARET_VALUE=func AUS_TOOL._CHECK_LOGIN([L]AFOLDER, [L]LOGIN,SELF.LOGIN,SELF.USER,SELF.APRFCOD,SELF.ALLACS)
If [L]ARET_VALUE<>0
 Return
Endif
Local Integer MONO

# checks that the folder is available
#107271
If func DOSSUB.ISHISTFOLD([L]AFOLDER)
  Local File =[L]AFOLDER+".ADOVALHIS" [AHW_ACTX]
  Read [AHW_ACTX]AHW0 = "";"";"MONO"
  MONO = val([F:AHW_ACTX]VALEUR)
  If fstat
   # Error 1: AFOLDER not accessible
   [L]ARET_VALUE = 1
  Endif
  Close Local File [AHW_ACTX]
Else
 Read [ADW_ACTX]ADW0 = "";"";"MONO"
 [L]MONO = val([F:ADW_ACTX]VALEUR)
  If fstat
   # Error 1: AFOLDER not accessible
   [L]ARET_VALUE = 1
  Endif
Endif
If [L]ARET_VALUE = 0 & [L]MONO
 # nbruser=1 C'est moi qui suis en train de rentrer !!
 # Mais il peut y avoir qqn qui travaille sur le dossier
 # par le menu "Autres fonctions" (Superviseur)
 #107807 use CHECK_MONO instead of nbruser
 #If SELF.APRFCOD=CST_APROFIL_ADMIN & nbruser=1 & MONO=1
 If MONO=1 & SELF.APRFCOD=CST_APROFIL_ADMIN & func ACONTEXT_CMET.CHECK_MONO([L]AFOLDER,SELF.LOGIN)=1
  #Call MESSAGE(mess(151,124,1)) From GESECRAN : # Vous êtes en mode mono-utilisateur
  [L]ARET_VALUE=0 : #OK
  # MONO>1 Une opération a été lancée sur le dossier
  # (A partir du dossier OU du menu "Autres fonctions")
  # 1-) Soit, elle est en cours...
  # 2-) Soit, elle s'est mal terminée !!
  #     (un déverrouillage dossier s'impose alors)
 Else
  # Connection impossible
  Case MONO
   When 2       : [L]ARET_VALUE=5 : # mess(146,124,1) : # Modification du dossier en cours
   When 3       : [L]ARET_VALUE=6 : # mess(147,124,1) : # Sauvegarde du dossier en cours
   When 4       : [L]ARET_VALUE=7 : # mess(148,124,1) : # Resynchronisation en cours
   When 5       : [L]ARET_VALUE=8 : # mess(149,124,1) : # Remise à zéro en cours
   When Default : [L]ARET_VALUE=9 : # mess(153,100,1) : # Le dossier est en mode mono
  Endcase
 Endif
Endif

If [L]ARET_VALUE<>0 : Return : Endif

#107271
#Verif si dossier histo doit être revalidé
Local Char MESSAGE(250)
Local Char WCHAMAJDOSREF(50),WCHDOSREF(50)
WCHDOSREF=func DOSSUB.PARENTHISTFOLD([L]AFOLDER)
If WCHDOSREF<>""
 Call GETPARHIS([L]AFOLDER,"AMAJDOSREF",WCHAMAJDOSREF) From SUBADS
 If val(WCHAMAJDOSREF)<>0
  #Attention: le dossier de référence $1$ a été modifié
  #La validation de dossier doit être lancée sur le dossier $1$
  #MESSAGE=func AFNC.MES1(mess(289,125,1),WCHDOSREF)+chr$(10)+func AFNC.MES1(mess(290,125,1),[L]AFOLDER)
  MESSAGE=func AFNC.MES1(mess(290,125,1),[L]AFOLDER)
  ERROR = func ASYRSUB._ASETSTATUS(SELF,"",0,[V]CST_AWARNING,[V]CST_AHTTP_OK,MESSAGE) Endif
Endif

Return

Funprog CHECK_MONO(APPLI,LOGIN)
Value Char APPLI,LOGIN
Local Integer NBSESSTOT
If find(adxtyp,25,33)=0
 If nbruser<>1 : End 0 : Endif
 End 1
Endif
Call USER_CONADAPI(APPLI,NBSESSTOT) From PSADX
If NBSESSTOT>2 : End 0 : Endif
If NBSESSTOT<2 : End 1 : Endif
Local Integer NBSESSUSR25
Local Integer NBSESSUSR33
Call NBCON_APP_USER_ADXTYP(LOGIN,APPLI,25,NBSESSUSR25) From PSADX
If NBSESSUSR25<>1 : End 0 : Endif
Call NBCON_APP_USER_ADXTYP(LOGIN,APPLI,33,NBSESSUSR33) From PSADX
If NBSESSUSR33<>1 : End 0 : Endif
End 1

#------------ $ACTX_xxx internal use only ------------#
$L_SET_LOCAL_SETTINGS
Local Integer ERRNUM
ERRNUM = 0
Onerrgo L_SET_LOCAL_SETTINGS_ERROR
ERRNUM = fmet SELF.AINTL.AINIT
Onerrgo
If  !ERRNUM>0
 Local Char    SEPTHO(1) , SEPDEC(1)
 Local Integer NUMBER
 SEPTHO = SELF.AINTL.THOUSANDSEP
 If SEPTHO<>""
  adxsca = left$(adxsca,2)+SEPTHO+right$(adxsca,4)
 Endif
 SEPDEC = SELF.AINTL.DECIMALSEP
 If SEPDEC<>""
  adxsca = left$(adxsca,3)+SEPDEC+right$(adxsca,5)
 Endif
 NUMBER = SELF.AINTL.TWODIGITYEAR
 If NUMBER<>0
  adxdcs = NUMBER
 Endif
Endif
Return

$L_SET_LOCAL_SETTINGS_ERROR
ERRNUM = errn
Resume

$ACLEANRIGHT
SELF.isReadonly = 0
 If !func AUS_TOOL._FILL_ACTX_USER(SELF.AFOLDER,SELF.USER,SELF.APRFCOD,SELF.ALLACS)
  SELF.isReadonly = 1
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(SELF,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(2,63,1)-SELF.USER-mess(30,149,1))
  [L]ARET_VALUE=[L]ASTATUS
  Return
Endif
If SELF._APROFIL<>null
 For I=1 To maxtab(SELF._APROFIL.AFCT)
  If SELF._APROFIL.AFCT(I)<>null
   FreeInstance SELF._APROFIL.AFCT(I)
  Endif
 Next
 For I=1 To maxtab(SELF._APROFIL.AACS)
  If SELF._APROFIL.AACS(I)<>null
   FreeInstance SELF._APROFIL.AACS(I)
  Endif
 Next
 For I=1 To maxtab(SELF._APROFIL.AROLE)
  If SELF._APROFIL.AROLE(I)<>null
   FreeInstance SELF._APROFIL.AROLE(I)
  Endif
 Next
 FreeInstance SELF._APROFIL
 SELF._APROFIL=null
Endif
SELF.isReadonly = 1
Return
#----------------------------------------------------------------
$_INIT_APROFIL
Local Integer I
If SELF._APROFIL=null
 If SELF.AFOLDER=nomap
  Local File AFCTFCT   [AFT_ACTX]
 Else
  Local File =SELF.AFOLDER+".AFCTFCT" [AFT_ACTX]
 Endif
 Read [AFT_ACTX]AFT0 = SELF.APRFCOD
 If fstat
  If dim(AFLGERR) >= 0 & AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(206,139,1)-SELF.APRFCOD)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
  LogicClose File [AFT_ACTX]
  Return
 Endif

 SELF.isReadonly = 0
 SELF._APROFIL = NewInstance C_ACTXFCTPRF AllocGroup SELF
 #[L]ASTATUS = fmet SELF._APROFIL.AINIT
 #PRFCOD CODE PROFIL
 SELF._APROFIL.PRFCOD=SELF.APRFCOD
 #INTPRF  INTITULÉ
 #Call LECTEXTRA(SELF._APROFIL,"",SELF._APROFIL.INTPRF,"AFCTFCT","INTPRF", SELF._APROFIL.PRFCOD, "") From ASYRFNC
 #ALLACS  TOUTES ACCES AUTORISÉES
 SELF._APROFIL.ALLACS=[F:AFT_ACTX]ALLACS

 #AUTETA  AUTOR. GROUPES ÉTATS (coll AETATS)
 For I=0 To dim(SELF._APROFIL.AUTETA)-1
  SELF._APROFIL.AUTETA(I+1)=[F:AFT_ACTX]AUTETA(I)
 Next
 #FCYDEF  SITE PAR DÉFAUT (coll AFCYDEF)
 For I=0 To dim(SELF._APROFIL.FCYDEF)-1
  SELF._APROFIL.FCYDEF(I+1)=[F:AFT_ACTX]FCYDEF(I)
 Next

 #DIFIMP  IMPRESSIONS DIFFÉRÉS
 #FILTRE  FILTRE ÉTATS
 If SELF._APROFIL.PRFCOD=[V]CST_APROFIL_ADMIN
  SELF._APROFIL.DIFIMP = 2
  SELF._APROFIL.FILTRE="*"
 Else
  SELF._APROFIL.DIFIMP = [F:AFT_ACTX]DIFIMP
  If dim([F:AFT_ACTX]FILTRE)>0
   SELF._APROFIL.FILTRE = [F:AFT_ACTX]FILTRE
  Else
   SELF._APROFIL.FILTRE = "*"
  Endif
 Endif
 #ALLFCT  TOUTES FONCTIONS AUTORISÉES
 SELF._APROFIL.ALLFCT=[F:AFT_ACTX]ALLFCT
 #FLGPOR  PORTAIL FIGÉ
 SELF._APROFIL.FLGPOR=[F:AFT_ACTX]FLGPOR
 #AFCT  FONCTIONS
 SELF.isReadonly = 1
 LogicClose File [AFT_ACTX]
Endif
Return

#---------------------------------------------------------------
$AGETPRFFCYDEF
Raz AFCYDEF
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If [L]IMODULE<1 | [L]IMODULE>dim(SELF._APROFIL.FCYDEF) | [L]IMODULE>len(mess(0,14,1))
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(132,124,1)-num$([L]IMODULE))
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
AFCYDEF=SELF._APROFIL.FCYDEF([L]IMODULE)
Return

#---------------------------------------------------------------
$AGET_IACS
Local Integer IACS
IACS=find([L]ACODACC,SELF._APROFIL.AACS(1..maxtab(SELF._APROFIL.AACS)).ACODACC)
If IACS=0
 If SELF.AFOLDER=nomap
  Local File ACCCOD [ACS_ACTX]
  Local File ACCES [ACC_ACTX]
  Else
  Local File =SELF.AFOLDER+".ACCCOD"   [ACS_ACTX]
  Local File =SELF.AFOLDER+".ACCES"   [ACC_ACTX]
 Endif
 Read [ACS_ACTX]ACS0 = [L]ACODACC
 If fstat
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(56,133,1)-[L]ACODACC)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
  LogicClose File [ACS_ACTX],[ACC_ACTX]
  Return
 Endif
 SELF.isReadonly = 0
 IACS=maxtab(SELF._APROFIL.AACS)+1
 SELF._APROFIL.AACS(IACS) = NewInstance C_ACTXACS AllocGroup SELF._APROFIL
 SELF._APROFIL.AACS(IACS).ACODACC=[L]ACODACC
 Read [ACC_ACTX]CODACC = SELF.USER;[L]ACODACC
 If fstat
  SELF._APROFIL.AACS(IACS).ACONSUL=0
  SELF._APROFIL.AACS(IACS).AMODIF=0
  SELF._APROFIL.AACS(IACS).AEXEC=0
 Else
  SELF._APROFIL.AACS(IACS).ACONSUL=[F:ACC_ACTX]CONSUL
  SELF._APROFIL.AACS(IACS).AMODIF=[F:ACC_ACTX]MODIF
  SELF._APROFIL.AACS(IACS).AEXEC=[F:ACC_ACTX]EXEC
 Endif
 SELF.isReadonly = 1
 LogicClose File [ACS_ACTX],[ACC_ACTX]
Endif
Return

$AGET_IFCT
Local Integer IFCT,IDX
IFCT=find([L]AFONCTION,SELF._APROFIL.AFCT(1..maxtab(SELF._APROFIL.AFCT)).ACODFCT)
If IFCT=0
 If SELF.AFOLDER=nomap
  Local File AFONCTION [AFC_ACTX]
  Local File AFCTPRF   [AFP_ACTX]
  Local File AFCTFCY   [AFF_ACTX]
 Else
  Local File =SELF.AFOLDER+".AFONCTION" [AFC_ACTX]
  Local File =SELF.AFOLDER+".AFCTPRF"   [AFP_ACTX]
  Local File =SELF.AFOLDER+".AFCTFCY"   [AFF_ACTX]
 Endif
 Read [AFC_ACTX]CODINT=[L]AFONCTION
 If fstat
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(2,130,1)-[L]AFONCTION)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
  LogicClose File [AFC_ACTX],[AFP_ACTX],[AFF_ACTX]
  Return
 Endif
 SELF.isReadonly = 0
 IFCT=maxtab(SELF._APROFIL.AFCT)+1
 SELF._APROFIL.AFCT(IFCT) = NewInstance C_ACTXFCT AllocGroup SELF._APROFIL
 SELF._APROFIL.AFCT(IFCT).ACODFCT=[L]AFONCTION
 #SELF._APROFIL.AFCT(IFCT).INTFCT=func ASYRFNC.TEXTE([F:AFC_ACTX]NOM)
 SELF._APROFIL.AFCT(IFCT).FCYAUZ=[F:AFC_ACTX]FCYAUZ
 SELF._APROFIL.AFCT(IFCT).TYP=[F:AFC_ACTX]TYP
 If SELF._APROFIL.ALLFCT=2   : # Toutes fonctions autorisées pour le profil
  IDX=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
  SELF._APROFIL.AFCT(IFCT).AFCY(IDX) = "\"
  If SELF._APROFIL.AFCT(IFCT).FCYAUZ<>2 or [L]AFONCTION="GESFCY" : # Fonctions sans sites
   If SELF._APROFIL.AFCT(IFCT).TYP=2 or (SELF._APROFIL.AFCT(IFCT).TYP=0 & left$([L]AFONCTION,3)="GES") : # Objet
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX) = 2
   Else
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"C")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"M")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"S")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"N")<>0)+1
   Endif
  Else   : # Fonctions avec sites
   If [F:AFC_ACTX]TYP=2 : # Objet
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX) = 2
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX) = 2
   Else
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"C")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"M")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"S")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"N")<>0)+1
   Endif
  Endif
 Else   : # Toutes fonctions non autorisées pour le profil
  If SELF._APROFIL.AFCT(IFCT).FCYAUZ<>2 : # Fonctions sans sites
   IDX=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
   SELF._APROFIL.AFCT(IFCT).AFCY(IDX) = "\"
   Read [AFP_ACTX]AFP0 = SELF.APRFCOD ; [L]AFONCTION ; ""
   If !fstat & [F:AFP_ACTX]ACS=2
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,[F:AFP_ACTX]OPT,"C")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,[F:AFP_ACTX]OPT,"M")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,[F:AFP_ACTX]OPT,"S")<>0)+1
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,[F:AFP_ACTX]OPT,"N")<>0)+1
   Else
    SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=0
    SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=0
    SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=0
    SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=0
   Endif
  Else  : # Fonctions avec sites
   Filter [AFF_ACTX] Where PRFCOD=SELF.APRFCOD & FNC=[L]AFONCTION & FCY<>""
   Read [AFF_ACTX]AFF1 First
   Filter [AFF_ACTX]
   If fstat
    IDX=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
    SELF._APROFIL.AFCT(IFCT).AFCY(IDX) = "\"
    #117035 cas ADMCA sur GESFCY
    If [L]AFONCTION="GESFCY"
     Read [AFP_ACTX]AFP0 = SELF.APRFCOD ; [L]AFONCTION ; ""
     If !fstat & [F:AFP_ACTX]ACS=2
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,[F:AFP_ACTX]OPT,"C")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,[F:AFP_ACTX]OPT,"M")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,[F:AFP_ACTX]OPT,"S")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,[F:AFP_ACTX]OPT,"N")<>0)+1
     Else
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=0
     Endif
    Else
     SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=0
     SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=0
     SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=0
     SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=0
    Endif
   Else
    IDX=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
    SELF._APROFIL.AFCT(IFCT).AFCY(IDX) = "!" : #Site vide
    Read [AFP_ACTX]AFP0 = SELF.APRFCOD ; [L]AFONCTION ; ""
    If !fstat
     If [F:AFP_ACTX]ACS=2
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,[F:AFP_ACTX]OPT,"C")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,[F:AFP_ACTX]OPT,"M")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,[F:AFP_ACTX]OPT,"S")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,[F:AFP_ACTX]OPT,"N")<>0)+1
     Else : #fix
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=0
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=0
     Endif
    Else
     If [F:AFC_ACTX]TYP=2 : # Objet
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX) = 2
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX) = 2
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX) = 2
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX) = 2
     Else
      SELF._APROFIL.AFCT(IFCT).AOPTC(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"C")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTM(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"M")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTS(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"S")<>0)+1
      SELF._APROFIL.AFCT(IFCT).AOPTN(IDX)=(instr(1,sum([F:AFC_ACTX]FLAG),"N")<>0)+1
     Endif
    Endif
   Endif
  Endif
 Endif
 SELF.isReadonly = 1
 LogicClose File [AFC_ACTX],[AFP_ACTX],[AFF_ACTX]
Endif
Return

$AGET_IFCY
Local Integer IFCY
If SELF._APROFIL.AFCT(IFCT).AFCY(1)="\"
 IFCY=1
 Return
Elsif [L]ACODFCY="" & SELF._APROFIL.AFCT(IFCT).AFCY(1)="!"
 IFCY=1
 Return
Endif
If fmet SELF.AFINDFCY([L]ACODFCY)=0
 If AFLGERR
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(94,134,1)-[L]ACODFCY)
 Else
 [L]ASTATUS = [V]CST_AERROR
 Endif
 Return
Endif
IFCY=find([L]ACODFCY,SELF._APROFIL.AFCT(IFCT).AFCY(1..maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)))
If IFCY=0
 If SELF.AFOLDER=nomap
  Local File AFCTFCY   [AFF_ACTX]
 Else
  Local File =SELF.AFOLDER+".AFCTFCY"   [AFF_ACTX]
 Endif
 SELF.isReadonly = 0
 Filter [AFF_ACTX] Where PRFCOD=SELF.APRFCOD & FNC=[L]AFONCTION & FCY=[L]ACODFCY
 Read [AFF_ACTX]AFF0 First
 Filter [AFF_ACTX]
 If fstat
   IFCY=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
   SELF._APROFIL.AFCT(IFCT).AFCY(IFCY) = [L]ACODFCY
   SELF._APROFIL.AFCT(IFCT).AOPTC(IFCY)=0
   SELF._APROFIL.AFCT(IFCT).AOPTM(IFCY)=0
   SELF._APROFIL.AFCT(IFCT).AOPTS(IFCY)=0
   SELF._APROFIL.AFCT(IFCT).AOPTN(IFCY)=0
 Else
   IFCY=maxtab(SELF._APROFIL.AFCT(IFCT).AFCY)+1
   SELF._APROFIL.AFCT(IFCT).AFCY(IFCY) = [F:AFF_ACTX]FCY
   SELF._APROFIL.AFCT(IFCT).AOPTC(IFCY)=(instr(1,[F:AFF_ACTX]OPT,"C")<>0)+1
   SELF._APROFIL.AFCT(IFCT).AOPTM(IFCY)=(instr(1,[F:AFF_ACTX]OPT,"M")<>0)+1
   SELF._APROFIL.AFCT(IFCT).AOPTS(IFCY)=(instr(1,[F:AFF_ACTX]OPT,"S")<>0)+1
   SELF._APROFIL.AFCT(IFCT).AOPTN(IFCY)=(instr(1,[F:AFF_ACTX]OPT,"N")<>0)+1
 Endif
 SELF.isReadonly = 1
 LogicClose File [AFF_ACTX]
Endif
Return

#------------ $AGETAFCRIGHT internal use only ------------#
$AGETAFCRIGHTFCY
If [L]ACODFCY="" : Return : Endif
Gosub AGETAFCRIGHTR
Return
#------------ $AGETAFCRIGHT internal use only ------------#
$AGETAFCRIGHTCPY
If [L]ACODCPY="" : Return : Endif
Local Integer ICPY,NOFCY
Local Instance ACURCPY Using C_ACPY
#check , one site ok at least
ICPY=fmet SELF.ACACHE.ACPY.AGETINDEX([L]ACODCPY)
If ICPY=0
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(16,104,1)-[L]ACODCPY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
  [L]ARET_VALUE=[L]ASTATUS
  Return
Endif
[L]ACURCPY = cast(SELF.ACACHE.ACPY.ACOL(ICPY),"C_ACPY")
Case ACURCPY.CPYLEGFLG
 When 2  : # Société juridique
  If SELF.AFOLDER=nomap
   Local File FACILITY   [FCY_ACTX]
  Else
   Local File =SELF.AFOLDER+".FACILITY"   [FCY_ACTX]
  Endif
  For [FCY_ACTX]FCY1 Where LEGCPY=[L]ACODCPY
   If fmet SELF.AGETAFCRIGHTFCY(AINSTANCE,AFONCTION,[F:FCY_ACTX]FCY,[V]CST_AFALSE)<=[V]CST_AWARNING
    NOFCY = 1 : Break
   Endif
  Next
  LogicClose File [FCY_ACTX]
 When Default
  If SELF.AFOLDER=nomap
   Local File FACGROUP   [FGR_ACTX]
  Else
   Local File =SELF.AFOLDER+".FACGROUP"   [FGR_ACTX]
  Endif
  For [FGR_ACTX]FGR0 Where CPY=[L]ACODCPY
   If fmet SELF.AGETAFCRIGHTFCY(AINSTANCE,AFONCTION,[F:FGR_ACTX]FCY,[V]CST_AFALSE)<=[V]CST_AWARNING
    NOFCY = 1 : Break
   Endif
  Next
  LogicClose File [FGR_ACTX]
Endcase
[L]ACURCPY=null
If !NOFCY
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(31,104,1)-[L]ACODCPY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
  [L]ARET_VALUE=[L]ASTATUS
  Return
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETAFCRIGHT internal use only ------------#
$AGETAFCRIGHT

If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Gosub AGET_IFCT
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If SELF._APROFIL.AFCT(IFCT).AFCY(1)="\"
 [L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTC(1)<>0)|(SELF._APROFIL.AFCT(IFCT).AOPTM(1)<>0)|(SELF._APROFIL.AFCT(IFCT).AOPTS(1)<>0)
Else
 [L]ARET_VALUE=[V]CST_ATRUE
Endif
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(1,123,1)-[L]AFONCTION)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

$_AGETAFCRIGHTFCY
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 Return
Endif
Gosub AGET_IFCT
If [L]ASTATUS>[V]CST_AWARNING
 Return
Endif
Gosub AGET_IFCY
If [L]ASTATUS>[V]CST_AWARNING
 Return
Endif
Return
#------------ $AGETAFCRIGHTR internal use only ------------#
$AGETAFCRIGHTR
Gosub _AGETAFCRIGHTFCY
If [L]ASTATUS>[V]CST_AWARNING | IFCY=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTC(IFCY)<>0)|(SELF._APROFIL.AFCT(IFCT).AOPTM(IFCY)<>0)|(SELF._APROFIL.AFCT(IFCT).AOPTS(IFCY)<>0)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(2,104,1)-[L]ACODFCY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETAFCRIGHTC internal use only ------------#
$AGETAFCRIGHTC
Gosub _AGETAFCRIGHTFCY
If [L]ASTATUS>[V]CST_AWARNING | IFCY=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTC(IFCY)=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(2,104,1)-[L]ACODFCY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(327,139,1)-mess(328,139,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLICFCT([L]AFONCTION)<>[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(330,139,1)) : # mess(329,139,1)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return


#------------ $AGETAFCRIGHTU internal use only ------------#
$AGETAFCRIGHTU
Gosub _AGETAFCRIGHTFCY
If [L]ASTATUS>[V]CST_AWARNING | IFCY=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTM(IFCY)=2)

If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(2,104,1)-[L]ACODFCY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(327,139,1)-mess(328,139,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLICFCT([L]AFONCTION)<>[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(330,139,1)) : # mess(329,139,1)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETAFCRIGHTD internal use only ------------#
$AGETAFCRIGHTD
Gosub _AGETAFCRIGHTFCY
If [L]ASTATUS>[V]CST_AWARNING | IFCY=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTS(IFCY)=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(2,104,1)-[L]ACODFCY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(327,139,1)-mess(328,139,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLICFCT([L]AFONCTION)<>[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(330,139,1)) : # mess(329,139,1)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETAFCRIGHTN internal use only ------------#
$AGETAFCRIGHTN
Gosub _AGETAFCRIGHTFCY
If [L]ASTATUS>[V]CST_AWARNING | IFCY=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AFCT(IFCT).AOPTN(IFCY)=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(2,104,1)-[L]ACODFCY)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(327,139,1)-mess(328,139,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Elsif fmet SELF.AGETLICFCT([L]AFONCTION)<>[V]CST_ATRUE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(330,139,1)) : # mess(329,139,1)
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETACSRIGHTC internal use only ------------#
$AGETACSRIGHTC
If SELF.ALLACS=2 | [L]ACODACC=""
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Gosub AGET_IACS
If [L]ASTATUS>[V]CST_AWARNING | IACS=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AACS(IACS).ACONSUL=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(38,134,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return


#------------ $AGETACSRIGHTM internal use only ------------#
$AGETACSRIGHTM
If SELF.ALLACS=2 | [L]ACODACC=""
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Gosub AGET_IACS
If [L]ASTATUS>[V]CST_AWARNING | IACS=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AACS(IACS).AMODIF=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(38,134,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETACSRIGHTE internal use only ------------#
$AGETACSRIGHTE
If SELF.ALLACS=2 | [L]ACODACC=""
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Gosub AGET_IACS
If [L]ASTATUS>[V]CST_AWARNING | IACS=0
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
[L]ARET_VALUE=(SELF._APROFIL.AACS(IACS).AEXEC=2)
If [L]ARET_VALUE=[V]CST_AFALSE
  If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_FORBIDDEN,mess(38,134,1))
  Else
  [L]ASTATUS = [V]CST_AERROR
  Endif
Endif
[L]ARET_VALUE=[L]ASTATUS
Return

#------------ $AGETCRITROLE ------------#
$AGETCRITROLE
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Gosub AGET_IROLE
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If IROLE>0
 Gosub AGET_CRITROLE
 If [L]ASTATUS>[V]CST_AWARNING
  [L]ARET_VALUE=[L]ASTATUS
  Return
 Endif
Endif
Return

#-----
$AGET_CRITROLE
Local Char     WVALUE(250),LISTFLD(GLONAVB)(1..)
Local Integer TYPFLD,ICRITROLE,IDX,NBFLD,IFLD,OUVTAB

Raz ACRITROLE

For IDX=1 To SELF._APROFIL.AROLE(IROLE).ANBROLUSR
 If SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX)<>"" & !find(SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX),LISTFLD(1..NBFLD))
  NBFLD+= 1
  LISTFLD(NBFLD) = SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX)
 Endif
Next
If SELF.AFOLDER=nomap
 Local File AOBJET      [AOB_ACTX]
Else
 Local File =SELF.AFOLDER+".AOBJET"   [AOB_ACTX]
Endif
If clalev([F:__AAA])=0
 Read [F:AOB_ACTX]ABREV = [L]AOBJ
 If !fstat
  Onerrgo ERR_CRITROLE
  If SELF.AFOLDER=nomap
   Local File =[F:AOB_ACTX]NOMFIC [__AAA]: Endif
  Else
   Local File =SELF.AFOLDER+"."+[F:AOB_ACTX]NOMFIC [__AAA]
  Endif
  Onerrgo
Endif

If [L]ASTATUS = [V]CST_AERROR
 If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(33,100,1)) : # Erreur sur critère de sélection
 Endif
 [L]ARET_VALUE=[V]CST_AERROR
 Return
Endif
Local Integer ISFIND,NBFLD2
For IFLD=1 To NBFLD
 Raz ISFIND,NBFLD2
 For IDX=1 To SELF._APROFIL.AROLE(IROLE).ANBROLUSR
  If SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX)=LISTFLD(IFLD)
   NBFLD2+=1
  Endif
 Next
 If NBFLD2
  If NBFLD2>1
   Call ADDCRIT(SELF,ACRITROLE,ICRITROLE,"ACRITROLE",'find([F:'+ABRFIC+']'+LISTFLD(IFLD)," & ",AFLGERR) From ASYRFNC
   ISFIND = 1
  Else
   Call ADDCRIT(SELF,ACRITROLE,ICRITROLE,"ACRITROLE",'[F:'+ABRFIC+']'+LISTFLD(IFLD)," & ",AFLGERR) From ASYRFNC
   ISFIND = 0
  Endif
 Endif
 For IDX=1 To SELF._APROFIL.AROLE(IROLE).ANBROLUSR
  If SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX)=LISTFLD(IFLD)
   TYPFLD = evalue('type([F:__AAA]'+SELF._APROFIL.AROLE(IROLE).AROLEFLD(IDX)+')')
   WVALUE = SELF._APROFIL.AROLE(IROLE).AROLEKEY(IDX)
   If left$(WVALUE,1)="="
    WVALUE = right$(WVALUE,2)
   Elsif !find(TYPFLD,1,2,4,5,6,7,8)
    WVALUE = '"'+WVALUE+'"'
   Endif
   Call ADDCRIT(SELF,ACRITROLE,ICRITROLE,"ACRITROLE",string$(ISFIND>0,',')+string$(ISFIND=0,'=')+WVALUE,"",AFLGERR) From ASYRFNC
   If ACRITROLE="" : Break : Endif
  Endif
 Next
 If ISFIND
  Call ADDCRIT(SELF,ACRITROLE,ICRITROLE,"ACRITROLE",")<>0","",AFLGERR) From ASYRFNC
 Endif
Next
If ACRITROLE=""
 ACRITROLE = "1=1"
Endif
If clalev([F:__AAA])>0
 Close Local File [__AAA]
Endif
Close Local File [AOB_ACTX]
Return

#-----
$AGET_IROLE
Local Integer IROLE
IROLE = find([L]AOBJ,SELF._APROFIL.AROLE(1..maxtab(SELF._APROFIL.AROLE)).AOBJ)
If IROLE=0
 If SELF.AFOLDER=nomap
  Local File AROLE       [ARL_ACTX]
  Local File AUSRBPR    [AUB_ACTX]
 Else
  Local File =SELF.AFOLDER+".AROLE" [ARL_ACTX]
  Local File =SELF.AFOLDER+".AUSRBPR"   [AUB_ACTX]
 Endif
 SELF.isReadonly = 0
 IROLE=maxtab(SELF._APROFIL.AROLE)+1
 SELF._APROFIL.AROLE(IROLE) = NewInstance C_ACTXROLE AllocGroup SELF._APROFIL
 SELF._APROFIL.AROLE(IROLE).AOBJ=[L]AOBJ
 Raz SELF._APROFIL.AROLE(IROLE).ANBROLUSR
 For [ARL_ACTX]ARL0 Where OBJ=[L]AOBJ
  For [AUB_ACTX]AUB0 Where USR=SELF.USER & ROL=[ARL_ACTX]ROL
   SELF._APROFIL.AROLE(IROLE).ANBROLUSR=maxtab(SELF._APROFIL.AROLE(IROLE).AROLEUSR)+1
   SELF._APROFIL.AROLE(IROLE).AROLEUSR(SELF._APROFIL.AROLE(IROLE).ANBROLUSR) = [F:AUB_ACTX]ROL
   SELF._APROFIL.AROLE(IROLE).AROLEKEY(SELF._APROFIL.AROLE(IROLE).ANBROLUSR) = [F:AUB_ACTX]BPR
   SELF._APROFIL.AROLE(IROLE).AROLEFLD(SELF._APROFIL.AROLE(IROLE).ANBROLUSR) = [ARL_ACTX]FLD
  Next
 Next
 SELF.isReadonly = 1
 LogicClose File [ARL_ACTX],[AUB_ACTX]
Endif
Return

#------------ $ASTACRITROLE ------------#
$ASTACRITROLE
Local Integer ASTATUS,ASTAEVAL
Local Char    ACRITROLE(250)(1..)
[L]ASTATUS = fmet SELF.AGETCRITROLE(AINSTANCE,AOBJ,ABRFIC,ACRITROLE,[V]CST_ATRUE)
If [L]ASTATUS>[V]CST_AWARNING
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
Onerrgo ERR_CRITROLE
ASTAEVAL = evalue(ACRITROLE)
Onerrgo
If [L]ASTATUS = [V]CST_AERROR
 If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(33,100,1)) : # Erreur sur critère de sélection
 Endif
 [L]ARET_VALUE=[V]CST_AERROR
 Return
Elsif ASTAEVAL=0
 If AFLGERR
  [L]ASTATUS = func ASYRSUB._ASETSTATUS(AINSTANCE,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_ACCEPTABLE,mess(8,123,1)-AKEY) : # Accès impossible à cette fiche
 Endif
 [L]ARET_VALUE=[V]CST_AERROR
 Return
Endif
Return

$ERR_CRITROLE
[L]ASTATUS = [V]CST_AERROR
Resume

#------------ $AGETAFCRIGHTALL ------------#

$AGETAFCRIGHTALL
Local Integer NBFUNC,IFC
Local Char LISTFUNC(GLONAFC)(1..)
Call LISTAFCUSER(0,SELF.LAN,SELF.AFOLDER,SELF.USER,NBFUNC,LISTFUNC)
For IFC=1 To NBFUNC
 [L]ASTATUS = fmet SELF.AGETAFCRIGHT(SELF, LISTFUNC(IFC),[V]CST_AFALSE)
Next
[L]ASTATUS=[V]CST_AOK
Return


#**
#* Liste des fonctions autorisées indéxable pour un user
#*
#* @param UTILIS
#* @param NBFONC
#* @param LISTFONC
#*!
Subprog LISTAFCUSER(HISTO,LANGUE,DOSSIER,UTILIS,NBFONC,LISTFONC)
Value Integer HISTO
Value Char LANGUE
Value Char DOSSIER
Value Char UTILIS
Variable Integer NBFONC
Variable Char LISTFONC()(1..)

Local File =DOSSIER+".AUTILIS"   [AUS_ACTX]
Local File =DOSSIER+".AMENUSER"  [AMU_ACTX]
Local File =DOSSIER+".AFONCTION" [AFC_ACTX]
Local File =DOSSIER+".AFCTFCY"   [AFF_ACTX]
Local File =DOSSIER+".AFCTPRF"   [AFP_ACTX]
Local File =DOSSIER+".AFCTFCT"   [AFT_ACTX]
Local File =DOSSIER+".ATEXTE"    [ATX_ACTX]
Local File =DOSSIER+".AMETUTI"   [AME_ACTX]

Read [AUS_ACTX]CODUSR = UTILIS
If fstat<>0 : End : Endif
Local Char WPRFMEN(10)
Local Char WPRFFCT(10)
Local Char WDOSX3(GLONADS),WPAR(10),WCRITERIA(250)
Local Integer WADONIX
If [F:AUS_ACTX]PRFMEN=""
 Read [AME_ACTX]AME0 = [F:AUS_ACTX]CODMET
 WPRFMEN = [F:AME_ACTX]PRFMEN
 WPRFFCT = [F:AME_ACTX]PRFFCT
Else
 WPRFMEN = [F:AUS_ACTX]PRFMEN
 WPRFFCT = [F:AUS_ACTX]PRFFCT
Endif
Call PARAM("","SUPDOS",WDOSX3) From ADOVAL
Call PARAM("","ADONIX",WPAR) From ADOVAL
WADONIX = val(WPAR)
Read [AFT_ACTX]AFT0 = WPRFFCT

# Dans un dossier historique, on n'autorise que les fonctions définies dans le profil menu
If HISTO & [F:AFT_ACTX]ALLFCT=2
 Link [AFC_ACTX] With
& [AMU_ACTX]MENFCT ~= WPRFMEN;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
Elsif HISTO
 Link [AFC_ACTX] With
& [AFF_ACTX]AFF0 ~= "";WPRFFCT;[F:AFC_ACTX]CODINT,
& [AMU_ACTX]MENFCT ~= WPRFMEN;[F:AFC_ACTX]CODINT,
& [AFP_ACTX]AFP0 ~= WPRFFCT;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
& Where [F:AFP_ACTX]ACS=2
Elsif WDOSX3=DOSSIER & [F:AFT_ACTX]ALLFCT=2
 Link [AFC_ACTX] With
& [AMU_ACTX]MENFCT ~= WPRFMEN;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
Elsif WDOSX3=DOSSIER & WPRFMEN="ADMCA" : #F_add_admca_managment
 Link [AFC_ACTX] With
& [AMU_ACTX]MENFCT ~= "ADMIN";[F:AFC_ACTX]CODINT,
& [AFF_ACTX]AFF0 ~= "";WPRFFCT;[F:AFC_ACTX]CODINT,
& [AFP_ACTX]AFP0 ~= WPRFFCT;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
Elsif WDOSX3=DOSSIER
 Link [AFC_ACTX] With
& [AMU_ACTX]MENFCT ~= WPRFMEN;[F:AFC_ACTX]CODINT,
& [AFF_ACTX]AFF0 ~= "";WPRFFCT;[F:AFC_ACTX]CODINT,
& [AFP_ACTX]AFP0 ~= WPRFFCT;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
& Where [F:AFP_ACTX]ACS=2
Elsif [F:AFT_ACTX]ALLFCT=2
 Link [AFC_ACTX] With
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
Else
 Link [AFC_ACTX] With
& [AFF_ACTX]AFF0 ~= "";WPRFFCT;[F:AFC_ACTX]CODINT,
& [AFP_ACTX]AFP0 ~= WPRFFCT;[F:AFC_ACTX]CODINT,
& [ATX_ACTX]NUMERO = LANGUE;[F:AFC_ACTX]NOM
& As [AFC_]
& Where [F:AFP_ACTX]ACS=2
Endif

For [AFC_]CODINT(1)
  NBFONC+=1
  LISTFONC(NBFONC)=[F:AFC_ACTX]CODINT
Next

LogicClose File [AUS_ACTX],[AMU_ACTX],[AFC_ACTX],[AFP_ACTX],[AFF_ACTX],[AFT_ACTX],[ATX_ACTX],[AME_ACTX]
End


#------------ $AGETACSRIGHTALL ------------#

$AGETACSRIGHTALL
If SELF._APROFIL=null : Gosub _INIT_APROFIL : Endif
If SELF.ALLACS=2
 [L]ARET_VALUE=[L]ASTATUS
 Return
Endif
If SELF.AFOLDER=nomap
 Local File ACCES [ACC_ACTX]
Else
 Local File =SELF.AFOLDER+".ACCES"   [ACC_ACTX]
Endif
Local Integer NBACC,IACC : NBACC=0
Local Char LISTACC(GLONACS)(1..)
For [ACC_ACTX]CODACC(2) Where USR=SELF.USER & CONSUL=2
 NBACC+=1
 LISTACC(NBACC)=[F:ACC_ACTX]CODACC
Next
For IACC=1 To NBACC
 [L]ASTATUS = fmet SELF.AGETACSRIGHTC(SELF,LISTACC(IACC),[V]CST_AFALSE)
Next
[L]ASTATUS=[V]CST_AOK
LogicClose File [ACC_ACTX]
Return

Funprog _F_AGETAFCRIGHTFCY(SELF,AINSTANCE,AFONCTION,ACODFCY,AFLGERR)
Variable Instance SELF Using OBJECT : #
Variable Instance AINSTANCE Using OBJECT : #
Value Char AFONCTION ()
Value Char ACODFCY ()
Value Shortint AFLGERR
Local Integer ARET_VALUE,ASTATUS
Gosub AGETAFCRIGHTFCY
End [L]ARET_VALUE


#------------ $AGETLICACV ------------#
$AGETLICACV
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.ACTIVITIES=null
 [L]ARET_VALUE=[V]CST_ATRUE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODACV,SELF._ASYRLIC.ACTIVITIES(1..maxtab(SELF._ASYRLIC.ACTIVITIES)).CODE)
If IFOUND
 If SELF._ASYRLIC.ACTIVITIES(IFOUND).SVALUE="false"
  [L]ARET_VALUE=[V]CST_AFALSE
  Return
 Endif
Endif
[L]ARET_VALUE=[V]CST_ATRUE
Return

#------------ $AGETLICFCT ------------#
$AGETLICFCT
If SELF._ASYRLIC=null or CODFCT=""
 [L]ARET_VALUE=[V]CST_ATRUE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODFCT,SELF._ASYRLIC.KEYFCTFORBI)
If IFOUND
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
[L]ARET_VALUE=[V]CST_ATRUE
Return


#------------ $AGETLICKIT ------------#
$AGETLICKIT
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.KITS=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODKIT,SELF._ASYRLIC.KITS(1..maxtab(SELF._ASYRLIC.KITS)).CODE)
If IFOUND
 If SELF._ASYRLIC.KITS(IFOUND).SVALUE="true"
  [L]ARET_VALUE=[V]CST_ATRUE
 Else
  [L]ARET_VALUE=[V]CST_AFALSE
 Endif
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLICLAN ------------#
$AGETLICLAN
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LANGUAGES=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODLAN,SELF._ASYRLIC.LANGUAGES(1..maxtab(SELF._ASYRLIC.LANGUAGES)).CODE)
If IFOUND
 If SELF._ASYRLIC.LANGUAGES(IFOUND).SVALUE="true"
  [L]ARET_VALUE=[V]CST_ATRUE
 Else
  [L]ARET_VALUE=[V]CST_AFALSE
 Endif
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLICLEG ------------#
$AGETLICLEG
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LEGISLATIONS=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODLEG,SELF._ASYRLIC.LEGISLATIONS(1..maxtab(SELF._ASYRLIC.LEGISLATIONS)).CODE)
If IFOUND
 If SELF._ASYRLIC.LEGISLATIONS(IFOUND).SVALUE="true"
  [L]ARET_VALUE=[V]CST_ATRUE
 Else
  [L]ARET_VALUE=[V]CST_AFALSE
 Endif
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLICMOD ------------#
$AGETLICMOD
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.MODULES=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODMOD,SELF._ASYRLIC.MODULES(1..maxtab(SELF._ASYRLIC.MODULES)).CODE)
If IFOUND
 If SELF._ASYRLIC.MODULES(IFOUND).SVALUE="true"
  [L]ARET_VALUE=[V]CST_ATRUE
 Else
  [L]ARET_VALUE=[V]CST_AFALSE
 Endif
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLICPAR ------------#
$AGETLICPAR
[L]VALPAR=""
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.PARAMETERS=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find(CODPAR,SELF._ASYRLIC.PARAMETERS(1..maxtab(SELF._ASYRLIC.PARAMETERS)).CODE)
If IFOUND
 [L]VALPAR=SELF._ASYRLIC.PARAMETERS(IFOUND).SVALUE
 [L]ARET_VALUE=[V]CST_ATRUE
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLICLIC ------------#
$AGETLICLIC
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=[V]CST_AFALSE
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=[V]CST_ATRUE
 Return
Endif
[L]ARET_VALUE=[V]CST_AFALSE
Return

#------------ $AGETLIC_PARTNERID ------------#
$AGETLIC_PARTNERID
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=""
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).PARTNERID
 Return
Endif
[L]ARET_VALUE=""
Return

#------------ $AGETLIC_PRODUCTVER ------------#
$AGETLIC_PRODUCTVER
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=""
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).PRODUCTVER
 Return
Endif
[L]ARET_VALUE=""
Return

#------------ $AGETLIC_POLICYCODE ------------#
$AGETLIC_POLICYCODE
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=""
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).POLICYCODE
 Return
Endif
[L]ARET_VALUE=""
Return

#------------ $AGETLIC_POLICYVER ------------#
$AGETLIC_POLICYVER
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=""
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).POLICYVER
 Return
Endif
[L]ARET_VALUE=""
Return

#------------ $AGETLIC_EXPIRED ------------#
$AGETLIC_EXPIRED
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=[V]CST_ATRUE
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 If SELF._ASYRLIC.LICENSES(IFOUND).EXPIRED<>"false"
  [L]ARET_VALUE=[V]CST_ATRUE
 Else
  [L]ARET_VALUE=[V]CST_AFALSE
 Endif
 Return
Endif
[L]ARET_VALUE=[V]CST_ATRUE
Return

#------------ $AGETLIC_PRODUCTNAME ------------#
# product name can be empty ..
#    it will replace in Funprog _AGETPRODUCTNAME from APRODUCT is neeeded
#   we don' use anymore aml 2902
$AGETLIC_PRODUCTNAME
Local Integer IFOUND
[L]ARET_VALUE=""
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
       [L]ARET_VALUE=""
Else
      IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
      If IFOUND
            [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).PRODUCTNAME
      Endif
Endif
Return

#------------ $AGETLIC_SERIAL ------------#
$AGETLIC_SERIAL
If dim(SELF._ASYRLIC)<=0 | SELF._ASYRLIC=null | SELF._ASYRLIC.LICENSES=null
 [L]ARET_VALUE=""
 Return
Endif
Local Integer IFOUND
IFOUND=find([L]PRODUCTCODE,SELF._ASYRLIC.LICENSES(1..maxtab(SELF._ASYRLIC.LICENSES)).PRODUCTCODE)
If IFOUND
 [L]ARET_VALUE=SELF._ASYRLIC.LICENSES(IFOUND).SERIAL
 Return
Endif
[L]ARET_VALUE=""
Return


$EVENTS
Return


$OPERATIONS
Return

