#<AdxTL>@(#)4.0.0.0 $Revision$
# ACONTEXT_CMET

$METHODS
Local Instance SELF Using OBJECT
SELF = this
Case ACTION
 When "ACTX_INIT_LAN"        : Gosub ACTX_INIT_LAN
 When "ACTX_INIT_LANISO"     : Gosub ACTX_INIT_LANISO
 When "ACTX_SET_LANISO"      : Gosub ACTX_SET_LANISO
 #
 When "AFINDLEG"             : Gosub AFINDLEG
 When "AFINDCPY"             : Gosub AFINDCPY
 When "AFINDFCY"             : Gosub AFINDFCY
 #
 When "AGETNBLEG"            : Gosub AGETNBLEG
 When "AGETNBFCY"            : Gosub AGETNBFCY
 When "AGETNBCPY"            : Gosub AGETNBCPY
 #
 When "ACLEAN"               : Gosub ACLEAN
 #
 When "ACLEANRIGHT"          : Gosub ACLEANRIGHT
 When "AGETAFCRIGHT"         : Gosub AGETAFCRIGHT
 #
 When "AGETAFCRIGHTFCY"      : Gosub AGETAFCRIGHTFCY
 When "AGETAFCRIGHTCPY"      : Gosub AGETAFCRIGHTCPY
 #
 When "AGETAFCRIGHTC"        : Gosub AGETAFCRIGHTC
 When "AGETAFCRIGHTR"        : Gosub AGETAFCRIGHTR
 When "AGETAFCRIGHTU"        : Gosub AGETAFCRIGHTU
 When "AGETAFCRIGHTD"        : Gosub AGETAFCRIGHTD
 When "AGETAFCRIGHTN"        : Gosub AGETAFCRIGHTN

 #
 When "AGETACSRIGHTC"        : Gosub AGETACSRIGHTC
 When "AGETACSRIGHTM"        : Gosub AGETACSRIGHTM
 When "AGETACSRIGHTE"        : Gosub AGETACSRIGHTE
 #
 When "AGETCRITROLE"         : Gosub AGETCRITROLE
 When "ASTACRITROLE"         : Gosub ASTACRITROLE
 #
 When "AGETAFCRIGHTALL"      : Gosub AGETAFCRIGHTALL
 When "AGETACSRIGHTALL"      : Gosub AGETACSRIGHTALL
 #
 When "AGETPRFFCYDEF"        : Gosub AGETPRFFCYDEF
 #
 When "AGETLICACV"           : Gosub AGETLICACV
 When "AGETLICFCT"           : Gosub AGETLICFCT
 When "AGETLICKIT"           : Gosub AGETLICKIT
 When "AGETLICLAN"           : Gosub AGETLICLAN
 When "AGETLICLEG"           : Gosub AGETLICLEG
 When "AGETLICMOD"           : Gosub AGETLICMOD
 When "AGETLICPAR"           : Gosub AGETLICPAR
 #
 When "AGETLICLIC"           : Gosub AGETLICLIC
 When "AGETLIC_PARTNERID"    : Gosub AGETLIC_PARTNERID
 When "AGETLIC_PRODUCTVER"   : Gosub AGETLIC_PRODUCTVER
 When "AGETLIC_POLICYCODE"   : Gosub AGETLIC_POLICYCODE
 When "AGETLIC_POLICYVER"    : Gosub AGETLIC_POLICYVER
 When "AGETLIC_EXPIRED"      : Gosub AGETLIC_EXPIRED
 When "AGETLIC_PRODUCTNAME"  : Gosub AGETLIC_PRODUCTNAME
 When "AGETLIC_SERIAL"       : Gosub AGETLIC_SERIAL
Endcase
Return

$PROPERTIES
Return


