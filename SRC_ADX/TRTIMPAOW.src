#<AdxTL>@(#)2.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("AOW",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
 When "FIN"   : Gosub FIN : Gosub SETBOX From =GBIDC2
Endcase
Return
######################################################################################
$OUVRE
Local Integer IMPSTA
Local Char    MESSAGE(80), BOITE_CRIT(GLONFEN) , FENETRE(GLONFEN)
Local Integer K , NOFIC , NOENR  , TYP , ER , ERR
Local Integer C , NUMIMP , NBFIC , STA
Local Char    NOMTRT(GLONADC) , NOMVAR(40)
Local Char    TRTSRC(GDIMFIC)
Local Char    CLE(30) , NOMZONE(30) , NOMSUB(GLONASU)
Local Char    FIFO(GDIMFIC) , PRGBL(30)
Local Integer OPTCAR , NOLIB
Local Char    FICTMP(GDIMFIC) , FICFIN(GDIMFIC) , FICERR(GDIMFIC)
Local Char    REPTMP(GDIMFIC) , REPFIN(GDIMFIC) , REPERR(GDIMFIC)
Local Char    REPTRA(GDIMFIC),  FICDON(GDIMFIC) , FICCLI(GDIMFIC)
Local Char    FICBAS(GDIMFIC) , REPERT(GDIMFIC) , FICORG(GDIMFIC)
Local Char    LISTEFIC(GDIMFIC)(1..1000)
Local Char    MACHINE(GDIMFIC) , MACTMP(GDIMFIC) , OS(10)
Local Char    BASPAG(GLONAVA)
Local Char    MODELE(GLONAOE), FICHIER(GDIMFIC), ZONTABLO(GLONAVA)
Local Char    SEPDEC(1)
Local Char    LOT(20),MES(250)
Local Integer STAT,NBRLIGS,LIG,AOWENR,AOWSTA
Local Char    TRTSRCAOW(GDIMFIC)
Local Char    NOMTRTAOW(GLONADC)
Local Char    SAVFONC(GLONAFC) , SAVABR(GLONAOB) , SAVNAVIG(GLONANG)
Local Integer SAVPILNAV
Local Char    SYMBOLE(80),CPTAOW(GLONANM)
Local Integer GESSAS

If clalev([F:AOV2])=0 : Local File AOBJEXTMPD [AOV2] : Endif
Gosub OUVRE From GIMPOBJ
Return
######################################################################################
$DEBUT
If [M:AOW0]EXT<>""
 [M:AOW4]EXT = [M:AOW0]EXT
 Read [AOE]AOE0 = [M:AOW0]EXT
Endif
If [M:AOW0]FILEXT<>""
 [M:AOW4]NOMIMP = [M:AOW0]FILEXT
 If GOS(1)="unix"
  If pat([M:AOW0]FILEXT,"|:\") or instr(1,[M:AOW0]FILEXT,"\")
   [M:AOW4]TYPEXP = 1
  Else
   [M:AOW4]TYPEXP = 2
  Endif
 Else
  [M:AOW4]TYPEXP = 2
 Endif
Else
 [M:AOW4]NOMIMP = [F:AOE]FILEXT
 [M:AOW4]TYPEXP = [F:AOE]TYPEXP
Endif
Affzo
Return
######################################################################################
$OK
MODELE  = [M:AOW4]EXT
FICHIER = [M:AOW4]NOMIMP
If [M:AOW4]TYPEXP=1
 FICCLI = FICHIER
 CHAINE = FICCLI
 Call SET_FICNAM(FICCLI,FICHIER,CHAINE) From ORDSYS
 Call COPSRV(FICCLI,FICHIER,ER) From ORDSYS
 If ER=1
  GBIDC3 = FICCLI : IMPSTA = 19 : Return
 Elsif ER>1
  GBIDC3 = FICCLI-"("+num$(ER)+")" : IMPSTA = 2 : Return
 Endif
Else
 FICCLI = ""
 Call EXISTE(FICHIER,ER) From ORDSYS
 If ER=0
  GBIDC3 = FICHIER : IMPSTA = 2 : Return
 Endif
Endif
FICTMP  = FICHIER

Call CHARGE_MODELE([L]MODELE,IMPSTA) From GIMPOBJ
If IMPSTA : Gosub ERREUR : Return : Endif

CPTAOW = func SUBTCA.NAMCPT(1,3)
If CPTAOW="" : CPTAOW = "AOW" : Endif
Call NUMERO(CPTAOW,"",date$,[L]MODELE,[L]LOT,STAT) From SUBANM
If STAT<>0
 Gosub MESSAGE From SUBANM
 IMPSTA = 99 : Gosub ERREUR  : Return
Endif

SYMBOLE = "AOW"+[L]LOT
Lock =SYMBOLE With lockwait=0
If fstat
 IMPSTA = 6 : MESSAGE = SYMBOLE : Gosub ERREUR : Return
Endif

GESSAS = 1
Gosub COMPILE From SUBIMPAOW
If IMPSTA : Goto ERREUR : Endif

Call VALID("TRT",NOMTRTAOW,nomap,OK) From VALMSKSUB
If !OK : IMPSTA = 7 : Gosub ERREUR : Return : Endif

Gosub SET_SEPAR From TRTIMPOBJ

Onerrgo ERFIC
Openi FICTMP Using [IMP]
Onerrgo
If ERR
 IMPSTA = 5 : GBIDC3 = FICTMP : Gosub ERREUR : Return
Endif

OLDIRS = adxirs
OLDIFS = adxifs
OLDIUM = adxium
adxirs = IMPIRS
adxifs = IMPIFS
adxium = IMPIUM

Gosub IMPORT From =NOMTRTAOW

Openi Using [IMP]
adxirs = OLDIRS
adxifs = OLDIFS
adxium = OLDIUM

If IMPSTA<8
 Gosub TR_ERR
Endif
Return

######################################################################################
$FIN
If SYMBOLE<>""
 Unlock =SYMBOLE
Endif

If IMPSTA<8 : # Pour garder une trace si trt généré plante
 Call EFFACE(TRTSRCAOW,STA) From ORDSYS
 Call EFFACE_ADX("","",NOMTRTAOW,STA) From ORDSYS
Endif
Return

######################################################################################
$TR_ERR
GOK =1
Trbegin [AOU]
 For [AOV2]AOV0(2) Where NUMLOT=[F:AOW]NUMLOT
  [M:AOW0]NUMLOT = [F:AOV2]NUMLOT
  [M:AOW0]NUMLIG = [F:AOV2]NUMLIG
  [M:AOW0]LEVCOD = [F:AOV2]LEVCOD
  [M:AOW0]EXT    = [F:AOW]EXT
  Gosub CHARGE_MODELE From SUBAOW
  Gosub CHARGE_SUITE From SUBAOW
  For [AOV]AOV0 Where NUMLOT=[M:AOW0]NUMLOT & NUMLIG = [M:AOW0]NUMLIG
   [L]MES =""
   Call C_FLDVAL([F:AOV]FLDVAL,[F:AOV]FLDNUM-1,MES)
   If [L]MES <> ""
    MES = mess(17,115,1)-[M:AOW1]FLDNAM([F:AOV]FLDNUM-1)-":"-[M:AOW1]FLDINTIT([F:AOV]FLDNUM-1)-":"-[L]MES
    [AOU]NUMLOT = [F:AOV]NUMLOT
    [AOU]NUMLIG = [F:AOV]NUMLIG
    [AOU]FLDNUM = [F:AOV]FLDNUM
    [AOU]ERR    = [L]MES
    [AOU]ERRSTA = 1
    Write [AOU]
    If fstat
     GOK=0 : Call FSTA("AOU") From GLOCK
     Break 2
    Endif
   Endif
  Next AOV
 Next AOV2
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ERR : Endif
Return

######################################################################################
$ERREUR
Call ERR_IMPORT(IMPSTA,MESSAGE) From GIMPOBJ
Call MESSAGE(MESSAGE) From GESECRAN
Return

######################################################################################
$ERFIC
ERR = errn
Resume

######################################################################################
## Etiquette ajoutée par le superviseur (écran IMPAOW) 05/12/2006 12:22:21 (CCL)
######################################################################################
Subprog AS_EXT(VALEUR)
Variable Char    VALEUR()
If [M]TYPEXP=1
 Grizo NOMIMP
Else
 Actzo NOMIMP
Endif
End

Subprog AM_EXT(VALEUR)
Variable Char    VALEUR()
Read [AOE]AOE0 = VALEUR
If !fstat & [F:AOE]FILEXT<>""
 [M:AOW4]NOMIMP = [F:AOE]FILEXT
 If GOS(1)="unix"
  If pat([F:AOE]FILEXT,"|:\") or instr(1,[F:AOE]FILEXT,"\")
   [M:AOW4]TYPEXP = 1
   Grizo NOMIMP
  Else
   [M:AOW4]TYPEXP = 2
   Actzo NOMIMP
  Endif
 Else
  [M:AOW4]TYPEXP = 2
  Actzo NOMIMP
 Endif
Endif
Call SET_NOMFIC([F:AOE]FILEXT,[M]NOMIMP,[M]TYPEXP)
Affzo NOMIMP
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Call SET_NOMFIC([F:AOE]FILEXT,[M]NOMIMP,VALEUR)
If VALEUR=1
 Grizo NOMIMP
Else
 Actzo NOMIMP
Endif
End

Subprog AS_NOMIMP(VALEUR)
Variable Char VALEUR()
End

Subprog SET_NOMFIC(FICHIER,NOMIMP,TYPEXP)
Value Char FICHIER
Variable Char NOMIMP
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
NOMIMP = FICHIER
If TYPEXP=1
 Call SET_NAMCLI(NOMIMP) From ORDSYS
Elsif !instr(1,NOMIMP,"@") & !find(left$(NOMIMP,1),"/") & !pat(left$(NOMIMP,3),"!:\")
 Call GETREP("REPIMPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,FICHIER,MACHINE,NOMIMP) From SUBEXPOBJ
 Endif
Endif
End

Subprog C_NOMIMP(VALEUR)
Variable Char VALEUR()
Local Char    NAM(GDIMFIC) , SUF(30)
Local Integer ER, I
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(GDIMFIC)

#Local Char FICPATCH(250)
#
#Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
#mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[L]FICPATCH,E_TYPE_FILEOVERWRITE,GMESSAGE)
#
#End
##
If VALEUR=""
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat=1 : End
Elsif left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif
Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : End
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : End
 Endif
Endif
Call EXISTE(VALEUR,ER) From ORDSYS
Case ER
 When 2
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : End
 When 0
  GMESSAGE = mess(03,141,1) : # Fichier à importer inexistant
  mkstat = 2 : End
Endcase
End

######################################################################################
Subprog C_FLDVAL(FLD,RANG,MESSAGE)
Value    Char    FLD()
Value    Integer RANG
Variable Char    MESSAGE
Local    Integer ER
MESSAGE =""
If [M:AOW1]TYPFIL = 4
 If len(FLD) > [M:AOW1]FLDLNG(RANG)
  MESSAGE = mess(111,123,1) : #  Longueur incorrecte
  End
 Endif
Endif
If [M:AOW1]FLDNUMTAB(RANG) > 0
 Read [AOR]AOR1 = [M:AOW1]FLDNUMTAB(RANG);FLD
 If fstat
  GMESSAGE = mess(83,123,1)-":"-mess(212,124,1)
  End
 Endif
Else
 Case [M:AOW1]FLDTYP(RANG)
  When 1
   Read [ATZ]CODZONE=[M:AOW1]FLDATB(RANG);[M:AOW1]FLDNAM(RANG)
   Case [M:AOW1]OPTMNL
    When 0
     Call  CTLNUM(FLD,RANG,ER) From SUBAOW
     If !ER
     #If val(FLD) = 0 : ER = 1 : Endif
      If val(FLD) > len(mess(0,[F:ATZ]NOLIB,1))
       ER = 1
      Endif
     Endif
    When 1
     Local Char LIB
     LIB = mess(0,[F:ATZ]NOLIB,1)
     ER = 1
     For I=1 To len(mess(0,[F:ATZ]NOLIB,1))
      If FLD = mid$([L]LIB,I,1)
       ER = 0
       Break
      Endif
     Next I
    When Default
     ER = 1
     For I=1 To len(mess(0,[F:ATZ]NOLIB,1))
      If FLD = mid$(mess(I,[F:ATZ]NOLIB,1),1,[M:AOW1]OPTMNL)
       ER = 0
       Break
      Endif
     Next I
   Endcase
   If ER
    MESSAGE = mess(83,123,1)
    End
   Endif
  When 2,3,4,5,6
   Call CTLNUM(FLD,RANG,ER) From SUBAOW
   If ER
    MESSAGE = mess(83,123,1)-":"-mess(210,124,1)-mess(2,46,1)
    End
   Endif
  When 7
   ER = 0
   If !find([M:AOW1]FLDATY(RANG),"A","ATX")
    Read [ATY]CODTYP = [M:AOW1]FLDATY(RANG)
    If !fstat
     If len(FLD) > [F:ATY]LNGTYP & [F:ATY]LNGTYP>0
      ER =1 : MESSAGE = mess(111,123,1) : #  Longueur incorrecte
      mkstat=2 : End
     Endif
    Endif
   Endif
  When 8
   If FLD <> ""
    Call CTLDATE(FLD,ER) From SUBAOW
    If ER
     Case [M:AOW1]OPTDAT
      When 1 : GMESSAGE = mess(83,123,1)-":"-mess(210,124,1)-"JJMMAA"   :# Date sous forme JJMMAA
      When 2 : GMESSAGE = mess(83,123,1)-":"-mess(210,124,1)-"JJMMAAAA" :# Date sous forme JJMMAAAA
      When 3 : GMESSAGE = mess(83,123,1)-":"-mess(210,124,1)-"AAMMJJ"   :# Date sous forme AAMMJJ
      When 4 : GMESSAGE = mess(83,123,1)-":"-mess(210,124,1)-"AAAAMMJJ" :# Date sous forme AAAAMMJJ
      When 5 : GMESSAGE = mess(83,123,1)-":"-mess(210,124,1)-"AAAA-MM-JJ" :# Date sous forme AAAAMMJJ
     Endcase
     End
    Endif
   Endif
 Endcase
Endif
End
