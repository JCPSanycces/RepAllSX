# Parcours de SQUOTE (V6 : SYMEU)
$FIN_PJT_SQH
  If filinfo(filpath("FIL","SQUOTE","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: SQUOTE"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".SQUOTE Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de MFGITM
$FIN_PJT_MFI
  If filinfo(filpath("FIL","MFGITM","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: MFGITM"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".MFGITM Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de ORDERS
$FIN_PJT_ORD
  If filinfo(filpath("FIL","ORDERS","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: ORDERS"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".ORDERS Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de STOJOU
$FIN_PJT_STJ
  If filinfo(filpath("FIL","STOJOU","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: STOJOU"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".STOJOU Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Recherche/Insertion des codes non trouvés dans D_PJT
$FIN_PJT_CRE
  For (Char PJT(20)) From WBASE Sql WREQ As [REQ_]
    If vireblc([REQ_]PJT,2) <> "" Then             # FGR 18/06/2014 : X3SUIVI98998 : du coup ça pourrait devenir une chaine vide
      #Read [BBB_]PJT0=[REQ_]PJT                   # FGR 18/06/2014 : X3SUIVI98998
      Read [BBB_]PJT0=vireblc([REQ_]PJT,2)         # FGR 18/06/2014 : X3SUIVI98998
      If fstat Then
        Raz [BBB_]
        #[BBB_]PJT = [REQ_]PJT                     # FGR 18/06/2014 : X3SUIVI98998
        [BBB_]PJT = vireblc([REQ_]PJT,2)           # FGR 18/06/2014 : X3SUIVI98998
        [BBB_]PJTDES = WFIL
        CHAINE = [BBB_]PJT
        Write [BBB_]
        If fstat Then
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET = 2 Then
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Endif
  Next
Return

###################################################################
## FIN_POSCOD Mise à jour de la dimension POSCOD                  #
###################################################################
$FIN_POSCOD
Local Char WFIL      : WFIL=""
Local Char WREQ(255) : WREQ="" : # Requete générique pour base Oracle et SqlServer 7
Local Integer D, NB_AJOUT
Local Char WBASE     : WBASE=" "
Local Char WTABLE    : WTABLE=""

  Local File =MACHINE+"@"+[F:ABW]COD+".D_POSCOD" [BBB_]

  # Boucle sur le nombre de dossiers
  For D=1 To NBDOS
    GDOSSIER = TBDOS(D)
    Gosub OUVRE_DIM_POSCOD

    # 1/ Insertion des enregistrements issus de BPADDRESS
    WTABLE="BPADDRESS"
    Gosub FIN_POSCOD_TRT

    # ACA (2009-12-22) Bug 61032 : Paramètre BI pour alimentation table des codes postaux
    If GBIPOSCOD=1 : Goto NEXTDOS : Endif

    # 2/ Insertion des enregistrements issus de PINVOICE
    WTABLE="PINVOICE"
    Gosub FIN_POSCOD_TRT_PIH_SIH

    # 3/ Insertion des enregistrements issus de SINVOICE
    WTABLE="SINVOICE"
    Gosub FIN_POSCOD_TRT_PIH_SIH

    # V6 (SYMEU) - début
    # 4/ Insertion des enregistrements issus de SINVOICEV
    WTABLE="SINVOICEV"
    Gosub FIN_POSCOD_TRT

    # 5/ Insertion des enregistrements issus de PORDER
    WTABLE="PORDER"
    Gosub FIN_POSCOD_TRT_POH

    # 6/ Insertion des enregistrements issus de PRECEIPT
    WTABLE="PRECEIPT"
    Gosub FIN_POSCOD_TRT

    # 7/ Insertion des enregistrements issus de PRETURN
    WTABLE="PRETURN"
    Gosub FIN_POSCOD_TRT

    # 8/ Insertion des enregistrements issus de SDELIVERY
    WTABLE="SDELIVERY"
    Gosub FIN_POSCOD_TRT_SDH

    # 9/ Insertion des enregistrements issus de SORDER
    WTABLE="SORDER"
    Gosub FIN_POSCOD_TRT_SOH

    # 10/ Insertion des enregistrements issus de SQUOTE
    WTABLE="SQUOTE"
    Gosub FIN_POSCOD_TRT_SQH

    # 11/ Insertion des enregistrements issus de SRETURN
    WTABLE="SRETURN"
    Gosub FIN_POSCOD_TRT
    # V6 (SYMEU) - fin
    $NEXTDOS
    Gosub FERME_DIM_POSCOD
  Next D
$EXIT_FIN_POSCOD
  Close Local File [BBB_]
Return

##############
$FIN_POSCOD_TRT
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN
    # V6 (SYMEU) : cas particulier pour PRECEIPT, SINVOICEV et SRETURN, car les champs ne portent pas le même nom
    If WTABLE="PRECEIPT" Then
      WREQ="select distinct BPOCRY_0, BPOCTY_0, BPOPOSCOD_0, BPOSAT_0 From "+TBDOS(D)+"."+WTABLE
    Elsif WTABLE="SRETURN" or WTABLE="SINVOICEV" Then
      WREQ="select distinct BPDCRY_0, BPDCTY_0, BPDPOSCOD_0, BPDSAT_0 From "+TBDOS(D)+"."+WTABLE
    Else
      WREQ="select distinct CRY_0, CTY_0, POSCOD_0, SAT_0 From "+TBDOS(D)+"."+WTABLE
    Endif
    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE
    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD
  Endif
Return

############## V6 (SYMEU) ###########################################
# Méthode particulière car il y a 2 adresses dans la table PINVOICE/SINVOICE
#####################################################################
$FIN_POSCOD_TRT_PIH_SIH
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN

    #--- Adresse ---#
    WREQ="select distinct CRY_0, CTY_0, POSCOD_0, SAT_0 From "+TBDOS(D)+"."+WTABLE

    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE

    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD

    #--- Adresse du tiers payé ---#
    WREQ="select distinct BPYCRY_0, BPYCTY_0, BPYPOSCOD_0, BPYSAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD
  Endif
Return

############## V6 (SYMEU) ###########################################
# Méthode particulière car il y a 2 adresses dans la table PORDER
#####################################################################
$FIN_POSCOD_TRT_POH
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN

    #--- Adresse ---#
    WREQ="select distinct CRY_0, CTY_0, POSCOD_0, SAT_0 From "+TBDOS(D)+"."+WTABLE

    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE

    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD

    #--- Adresse de l'expéditeur ---#
    WREQ="select distinct BPOCRY_0, BPOCTY_0, BPOPOSCOD_0, BPOSAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD
  Endif
Return

############## V6 (SYMEU) ###########################################
# Méthode particulière car il y a 2 adresses dans la table SDELIVERY
#####################################################################
$FIN_POSCOD_TRT_SDH
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN

    #--- Adresse de livraison ---#
    WREQ="select distinct BPDCRY_0, BPDCTY_0, BPDPOSCOD_0, BPDSAT_0 From "+TBDOS(D)+"."+WTABLE

    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE

    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD

    #--- Adresse de facturation ---#
    WREQ="select distinct BPICRY_0, BPICTY_0, BPIPOSCOD_0, BPISAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD
  Endif
Return

############## V6 (SYMEU) ########################################
# Méthode particulière car il y a 3 adresses dans la table SORDER
##################################################################
$FIN_POSCOD_TRT_SOH
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN

    #--- Adresse de commande ---#
    WREQ="select distinct BPCCRY_0, BPCCTY_0, BPCPOSCOD_0, BPCSAT_0 From "+TBDOS(D)+"."+WTABLE

    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE

    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD

    #--- Adresse de livraison ---#
    WREQ="select distinct BPDCRY_0, BPDCTY_0, BPDPOSCOD_0, BPDSAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD

    #--- Adresse de facturation ---#
    WREQ="select distinct BPICRY_0, BPICTY_0, BPIPOSCOD_0, BPISAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD
  Endif
Return

############## V6 (SYMEU) ########################################
# Méthode particulière car il y a 2 adresses dans la table SQUOTE
##################################################################
$FIN_POSCOD_TRT_SQH
  If filinfo(filpath("FIL",WTABLE,"fde",TBDOS(D)),0)>0
    # 1/ Initialisation de l'ordre SQL de sélection dans WTABLE
    Call ECR_TRACE("**  TRTDIMBI: POSCOD"-mess(2,2246,1)-WTABLE,0) From GESECRAN

    #--- Adresse du devis ---#
    WREQ="select distinct BPCCRY_0, BPCCTY_0, BPCPOSCOD_0, BPCSAT_0 From "+TBDOS(D)+"."+WTABLE

    # 2/ Alimentation du type de Database
    Gosub ALIM_WBASE

    # 3/ Boucle de Recherche-Insertion des codes non trouvés dans D_POSCOD
    Gosub INSERT_POSCOD

    #--- Adresse de livraison ---#
    WREQ="select distinct BPDCRY_0, BPDCTY_0, BPDPOSCOD_0, BPDSAT_0 From "+TBDOS(D)+"."+WTABLE
    Gosub INSERT_POSCOD
  Endif
Return

##############
$INSERT_POSCOD
  NB_AJOUT = 0
  If clalev([F:TCY])=0 : Local File =GDOSSIER+".TABCOUNTRY"  [TCY] : Endif
  For (Char CRY(3), Char CTY(40), Char POSCOD(10), Char SAT(35)) From WBASE Sql WREQ As [REQ_]
    If [F:TCY]CRY<>CRY
      Read [TCY]TCY0=CRY
    Endif
    Read [BBB_]POS0=[REQ_]CRY;vireblc([REQ_]CTY,1);vireblc([REQ_]POSCOD,1)   # SYMEU 61649 et ACA 69512
    If fstat
      Raz [BBB_]
      [BBB_]CRY    = [REQ_]CRY
      [BBB_]POSCTY = vireblc([REQ_]CTY,1) # ACA 69512
      [BBB_]POSCOD = vireblc([REQ_]POSCOD,1)  # SYMEU 61649
      # Si l'état (province) de l'adresse est renseigné, on le récupère; sinon on récupère celui du code postal
      If [REQ_]SAT<>"" Then
        Case [F:TCY]ETAT
          When 2 : [BBB_]SATCOD = [REQ_]SAT : [BBB_]SATDES = [REQ_]SAT
          When 3 : [BBB_]DIVCOD = [REQ_]SAT : [BBB_]DIVDES = [REQ_]SAT
        Endcase
      Else
        #--CPO 78171
        #[BBB_]SATCOD = func SUBALB.CODSDV2([REQ_]CRY,[REQ_]POSCOD)
        #[BBB_]SATDES = func SUBALB.NAMSDV2([REQ_]CRY,[REQ_]POSCOD)
        #[BBB_]DIVCOD = func SUBALB.CODSDV1([REQ_]CRY,[REQ_]POSCOD)
        #[BBB_]DIVDES = func SUBALB.NAMSDV1([REQ_]CRY,[REQ_]POSCOD)
        [BBB_]SATCOD = func TRTDIMBI.CODSDV2([REQ_]CRY,[REQ_]POSCOD)
        [BBB_]SATDES = func TRTDIMBI.NAMSDV2([REQ_]CRY,[BBB_]SATCOD)
        [BBB_]DIVCOD = func TRTDIMBI.CODSDV1([REQ_]CRY,[REQ_]POSCOD)
        [BBB_]DIVDES = func TRTDIMBI.NAMSDV1([REQ_]CRY,[BBB_]DIVCOD)
        #--/CPO
      Endif
      CHAINE = "CRY='" +[BBB_]CRY + "' POSCTY='" + [BBB_]POSCTY + "' POSCOD='" + [BBB_]POSCOD + "'"
      Write [BBB_]
      If fstat
         Call ERREUR(TABLE-CHAINE,1) From DOSDIC
      Else
         CRE += 1
         NB_AJOUT += 1
         If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
         Endif
      Endif
    Else # le code postal existe : on ne le met à jour que si l'état n'est pas renseigné
      If [REQ_]SAT<>"" and
&     (([F:TCY]ETAT = 2 and [BBB_]SATCOD = "") or ([F:TCY]ETAT = 3 and [BBB_]DIVCOD = "")) Then
        Case [F:TCY]ETAT
          When 2 : [BBB_]SATCOD = [REQ_]SAT : [BBB_]SATDES = [REQ_]SAT
          When 3 : [BBB_]DIVCOD = [REQ_]SAT : [BBB_]DIVDES = [REQ_]SAT
        Endcase
        CHAINE = "CRY='" +[BBB_]CRY + "' POSCTY='" + [BBB_]POSCTY + "' POSCOD='" + [BBB_]POSCOD + "'"
        Rewrite [BBB_]
        If fstat
           Call ERREUR(TABLE-CHAINE,2) From DOSDIC
        Elsif [L]DET=2
           Call ECR_TRACE("**   "+mess(60,123,1)-CHAINE,0) From GESECRAN
        Endif
      Endif
    Endif
  Next
  Call ECR_TRACE("**  TRTDIMBI: POSCOD " + num$(NB_AJOUT)-mess(3,2246,1)-WTABLE,0) From GESECRAN
Return

##################################################################
## Mise à jour de la dimension STOLOC                           ##
## Insertion d'une ligne par site avec 2eme partie de clé à " " ##
##################################################################
$FIN_STOLOC
Local Char WFIL : WFIL=""

  Local File =MACHINE+"@"+[F:ABW]COD+".D_STOLOC" [BBB_]
  Call ECR_TRACE("**   TRTDIMBI: ",0) From GESECRAN
  For D=1 To NBDOS
    GDOSSIER = TBDOS(D)
    Local File =TBDOS(D)+".FACILITY" [FCY_]
    For [FCY_]FCY0
      If !fstat # & len([FCY_]FCY)<4  :  FCY pas plus que 3 caractères !!!
        Read [BBB_]LOC0 = [FCY_]FCY;WFIL
        If fstat
          Raz [BBB_]
          [BBB_]STOFCY = [FCY_]FCY
          [BBB_]LOC = WFIL
          CHAINE = [BBB_]STOFCY
          Write [BBB_]
          If fstat
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET=2
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Close Local File [FCY_]
  Next D
  Close Local File [BBB_]
Return

##################################################################
## Mise à jour de la dimension WORKSTATIO                       ##
##################################################################
$FIN_WORKSTATIO
Local Char WFIL : WFIL=""

  Local File =MACHINE+"@"+[F:ABW]COD+".D_WORKSTATIO" [BBB_]
  Call ECR_TRACE("**   TRTDIMBI: ",0) From GESECRAN
  For D=1 To NBDOS
    GDOSSIER = TBDOS(D)
    Gosub FIN_WST1
    Gosub FIN_WST2
  Next D
  Close Local File [BBB_]
Return

$FIN_WST1
  ## Insertion d'une ligne par site avec 2eme partie de clé à " " ##
  Local File =TBDOS(D)+".FACILITY" [FCY_]
  For [FCY_]FCY0
    If !fstat # & len([FCY_]FCY)<4  :  FCY pas plus que 3 caractères !!!
      Read [BBB_]MWS0 = [FCY_]FCY;WFIL
      If fstat
        Raz [BBB_]
        [BBB_]WCRFCY = [FCY_]FCY
        [BBB_]WST = WFIL
        CHAINE = [BBB_]WCRFCY
        Write [BBB_]
        If fstat
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Endif
  Next
  Close Local File [FCY_]
Return

$FIN_WST2
## Calcul de la capacité mensuelle selon capacité quotidienne et capacité hebdomadaire
Local Integer CPT_TEMP: CPT_TEMP=0

  For [BBB_]MWS0 Where MONCAP=0 & DAYCAP>0 & WEECAP>0
    If [BBB_]WEECAP = 7 * [BBB_]DAYCAP Then
      [BBB_]MONCAP = 30 * [BBB_]DAYCAP
    Else
      [BBB_]MONCAP = arr(4.5 * [BBB_]WEECAP,0)
    Endif
    CPT_TEMP+=1
    Rewrite [BBB_]
  Next
  Call ECR_TRACE("**   "+num$(CPT_TEMP)-mess(4,2246,1),0) From GESECRAN
Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de       #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
  Case GTYPDBA
    When 1 : WBASE = "3" : # Oracle
    When 2 : WBASE = "5" : # Sql
    When 3 : WBASE = "2" : # Cisam
    When 4 : WBASE = "4" : # DB2
  Endcase
Return

#####################################################################
# SYMEU - Fiche 61356                                               #
# Lecture de la dimension                                           #
#####################################################################
$READ_DIM
  If clalev([F:ABI]) = 0 : Local File =APPLI+".ABIDIM" [ABI] : Endif
  If [F:ABI]CODDIM <> right$(TABLE,3)
    Read [ABI]ABI0=right$(TABLE,3)
    If fstat Then
      Raz [F:ABI]
    Endif
  Endif
  # On teste si toutes les règles de synchronisation ayant la même table d'origine que la dimension
  # sont désactivées. Si c'est le cas, le traitement de la dimension n'est pas exécuté
  [L]DESFLG = 1
  [L]NBACT = 0 # nombre de règles activées
  [L]NBDES = 0 # nombre de règles désactivées
  If [F:ABI]TABORG <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    For [F:ABV] Where TABORG = [F:ABI]TABORG
      If dim([F:ABV]DESFLG) > 0 Then
        If [F:ABV]DESFLG = 2 Then # règle désactivée
          [L]NBDES+=1
        Else                      # règle activée
          [L]NBACT+=1
        Endif
      Endif
    Next
  Endif
  If [L]NBACT = 0 and [L]NBDES <> 0 Then # on n'a trouvé que des règles de synchro désactivées
    [L]DESFLG = 2
  Endif
Return

######################################################################################
#--CPO 78171
Funprog CODSDV1(CRY,POS)
Value Char CRY , POS

  Gosub SDV1
End CODSDV

$SDV1
Local Char CODSDV(10)
Local Integer TYP

  TYP = 2
  If [F:TCY]CRY<>CRY
    Read [TCY]TCY0 = CRY
  Endif
  If [F:TCY]CRY=CRY & ((TYP=2 & [F:TCY]ETATFLG=2) or (TYP=3 & [F:TCY]ETATFLG2=2))
    If [F:ALB1]CRY=[L]CRY & [F:ALB1]TYP=[L]TYP & pat([L]POS,[F:ALB1]POS)
      CODSDV = [F:ALB1]COD
    Else
      Filter [ALB1] Where [F]CRY=[L]CRY & [F]TYP=[L]TYP & pat([L]POS,[F]POS) <> 0
      Columns [F:ALB1](COD)
      Read [F:ALB1] First
      If fstat=0 : CODSDV = [F:ALB1]COD : Endif
      Columns [F:ALB1]
      Filter [ALB1]
    Endif
  Endif
Return

Funprog CODSDV2(CRY,POS)
Value Char CRY , POS

  Gosub SDV2
End CODSDV

$SDV2
Local Integer TYP
Local Char CODSDV(10)

  TYP = 3
  If [F:TCY]CRY<>CRY
    Read [TCY]TCY0 = CRY
  Endif
  If [F:TCY]CRY=CRY & ((TYP=2 & [F:TCY]ETATFLG=2) or (TYP=3 & [F:TCY]ETATFLG2=2))
    If [F:ALB2]CRY=[L]CRY & [F:ALB2]TYP=[L]TYP & pat([L]POS,[F:ALB2]POS)
      CODSDV = [F:ALB2]COD
    Else
      Filter  [F:ALB2] Where [F]CRY=[L]CRY & [F]TYP=[L]TYP & pat([L]POS,[F]POS)<>0
      Columns [F:ALB2](COD)
      Read [F:ALB2] First
      If fstat=0 : CODSDV = [F:ALB2]COD : Endif
      Columns [F:ALB2]
      Filter  [F:ALB2]
    Endif
  Endif
Return

Funprog NAMSDV1(CRY,CODSDV)
Value Char CRY,CODSDV

Local Char NAMSDV(80)

  If CODSDV <>""
    Call LECTEXTRA(NAMSDV,"TABSUBDIV","INTIT",CRY+"~2",CODSDV ) From ATEXTRA
  Endif
End NAMSDV

Funprog NAMSDV2(CRY,CODSDV)
Value Char CRY,CODSDV

Local Char NAMSDV(80)

  If CODSDV <>""
    Call LECTEXTRA(NAMSDV,"TABSUBDIV","INTIT",CRY+"~3",CODSDV ) From ATEXTRA
  Endif
End NAMSDV
