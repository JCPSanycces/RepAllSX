#<AdxTL>@(#)8.0.0.0 $Revision$
#############################################################################
# TRTDIMBI    Traitement pour les dimensions  BI                            #
# ------------------------------------------------------------------------- #
# FIN_PJT       : Mise à jour de la dimension PJT                           #
# FIN_POSCOD    : Mise à jour de la dimension POSCOD                        #
# FIN_STOLOC    : Mise à jour de la dimension STOLOC                        #
# FIN_WORKSTATIO: Mise à jour de la dimension WORKSTATIO                    #
# ------------------------------------------------------------------------- #
# Nota :                                                                    #
# [M]DET devient [L]DET                                                     #
#############################################################################

#############################################################################################
# V6 :
# FIN_PJT : alimentation par les autres documents de ventes et d'achats que les factures
# FIN_POSCOD : alimentation par les autres documents de ventes et d'achats que les factures
#############################################################################################

###################################################################################
# 06/01/2010 (SYMEU) : Si toutes les règles de synchronisation alimentées par la  #
# Fiche 61356          table d'origine de la dimension sont désactivées, le trai- #
#                      tement n'est pas exécuté                                   #
###################################################################################
# 15/01/2010 (SYMEU) : Pb d'écriture sous sql-server quand le code postal con-    #
# Fiche 61649          tient des espaces                                          #
###################################################################################

###################################################################
## ACTION Mise à jour des dimensions X3                           #
###################################################################
$ACTION
  Case ACTION
    When "DEBUT_DIM"
    When "OUVRE_DIM"  : Gosub OUVRE_DIM_POSCOD  :#--CPO 78171
    When "FERME_DIM"
    When "FIN_DIM"    : Gosub FIN_DIM
  Endcase
Return

$FIN_DIM
# SYMEU - Fiche 61356 - début
Local Integer DESFLG, NBACT, NBDES

  Gosub READ_DIM
  # Toutes les règles de synchronisation alimentées par la table d'origine de la dimension sont
  # désactivées : on n'exécute pas le traitement
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin

  Case TABLE
    When "D_PJT"        : Gosub FIN_PJT
    When "D_POSCOD"     : Gosub FIN_POSCOD
    When "D_STOLOC"     : Gosub FIN_STOLOC
    When "D_WORKSTATIO" : Gosub FIN_WORKSTATIO
  Endcase
Return

####################################################################
# ouverture des tables utilisées pour la dimension POSCOD, dont on a
# besoin dans les fonctions SUBALB.CODSDV*, SUBALB.NAMSDV*
####################################################################
$OUVRE_DIM_POSCOD
  Gosub FERME_DIM_POSCOD
  Local File =GDOSSIER+".TABCOUNTRY"  [TCY]
  Local File =GDOSSIER+".ALNKSUB" [ALB1]
  Local File =GDOSSIER+".ALNKSUB" [ALB2]
  #--CPO 78171
  Local File =GDOSSIER+".ATEXTRA" [AXX]
  #--/CPO
Return

####################################################################
# fermeture des tables utilisées pour la dimension POSCOD
####################################################################
$FERME_DIM_POSCOD
  If clalev([F:TCY])  : Close Local File [TCY] : Endif
  If clalev([F:ALB1]) : Close Local File [ALB1] : Endif
  If clalev([F:ALB2]) : Close Local File [ALB2] : Endif
  #--CPO 78171
  If clalev([F:AXX])  : Close Local File [AXX]  : Endif
  #--/CPO
Return

###################################################################
## FIN_PJT Mise à jour de la dimension PJT                        #
###################################################################
$FIN_PJT
Local Char WFIL : WFIL=""
Local Char WREQ(255) : WREQ="" : # Requete générique pour base Oracle et SqlServer 7
Local Integer D
Local Char WBASE   : WBASE=" "

  Local File =MACHINE+"@"+[F:ABW]COD+".D_PJT" [BBB_]

  # Alimentation du type de Database
  Gosub ALIM_WBASE

  For D=1 To NBDOS
    GDOSSIER = TBDOS(D)

    # Achats: on ne charge que les Factures dans le Datawarehouse en V5
    Gosub FIN_PJT_PID
    # V6 (SYMEU) - début : gestion des autres documents
    Gosub FIN_PJT_POP # PORDERP
    Gosub FIN_PJT_PTD # PRECEIPTD
    Gosub FIN_PJT_PSD # PREQUISD
    Gosub FIN_PJT_PND # PRETURND
    # V6 (SYMEU) - fin

    # Ventes: on ne charge que les Factures dans le Datawarehouse en V5
    Gosub FIN_PJT_SIV
    # V6 (SYMEU) - début : gestion des autres documents
    Gosub FIN_PJT_SDH # SDELIVERY
    Gosub FIN_PJT_SOH # SORDER
    Gosub FIN_PJT_SQH # SQUOTE
    # V6 (SYMEU) - fin

    # GPAO : le code PJT se trouve sur MFGITM et ORDERS
    Gosub FIN_PJT_MFI
    Gosub FIN_PJT_ORD
    # Stocks: le code PJT se trouve sur STOJOU
    Gosub FIN_PJT_STJ
  Next D
  Close Local File [BBB_]
Return

# Parcours de PINVOICED
$FIN_PJT_PID
  If filinfo(filpath("FIL","PINVOICED","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: PINVOICED"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".PINVOICED Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de PORDERP (V6 : SYMEU)
$FIN_PJT_POP
  If filinfo(filpath("FIL","PORDERP","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: PORDERP"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".PORDERP Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de PRECEIPTD (V6 : SYMEU)
$FIN_PJT_PTD
  If filinfo(filpath("FIL","PRECEIPTD","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: PRECEIPTD"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".PRECEIPTD Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de PREQUISD (V6 : SYMEU)
$FIN_PJT_PSD
  If filinfo(filpath("FIL","PREQUISD","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: PREQUISD"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".PREQUISD Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return


# Parcours de PRETURND (V6 : SYMEU)
$FIN_PJT_PND
  If filinfo(filpath("FIL","PRETURND","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: PRETURND"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".PRETURND Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de SINVOICEV
$FIN_PJT_SIV
  If filinfo(filpath("FIL","SINVOICEV","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: SINVOICEV"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".SINVOICEV Where PJT_0>' '"
