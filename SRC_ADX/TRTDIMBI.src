  Endif
Return

# Parcours de SDELIVERY (V6 : SYMEU)
$FIN_PJT_SDH
  If filinfo(filpath("FIL","SDELIVERY","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: SDELIVERY"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".SDELIVERY Where PJT_0>' '"
    Gosub FIN_PJT_CRE
  Endif
Return

# Parcours de SORDER (V6 : SYMEU)
$FIN_PJT_SOH
  If filinfo(filpath("FIL","SORDER","fde",TBDOS(D)),0)>0
    Call ECR_TRACE("**   TRTDIMBI: SORDER"-mess(1,2246,1),0) From GESECRAN
    WREQ="select distinct PJT_0 From "+TBDOS(D)+".SORDER Where PJT_0>' '"
