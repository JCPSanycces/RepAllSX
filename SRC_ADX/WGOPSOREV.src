#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OPSOREV

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:57"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OPSOREV",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="REVPSO0;REVPSO1;REVPSO2;REVPSO3;REVPSOH0;REVPSOH1;REVPSOH2;REVPSOH3;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "PSOREV"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "PSONUM+REVNUM"
If clalev([M:REVPSO0])=0 : Local Mask REVPSO0 [REVPSO0] : Endif
If clalev([M:REVPSO1])=0 : Local Mask REVPSO1 [REVPSO1] : Endif
If clalev([M:REVPSO2])=0 : Local Mask REVPSO2 [REVPSO2] : Endif
If clalev([M:REVPSO3])=0 : Local Mask REVPSO3 [REVPSO3] : Endif
If clalev([M:REVPSOH0])=0 : Local Mask REVPSOH0 [REVPSOH0] : Endif
If clalev([M:REVPSOH1])=0 : Local Mask REVPSOH1 [REVPSOH1] : Endif
If clalev([M:REVPSOH2])=0 : Local Mask REVPSOH2 [REVPSOH2] : Endif
If clalev([M:REVPSOH3])=0 : Local Mask REVPSOH3 [REVPSOH3] : Endif
Gosub TIT
nolign = 1
If clalev([F:PSOH])=0 : Local file PJMSOLITMH [PSOH] : Endif
Link [VPSOH] With
& [PSOH]PSOH0=[F:VPSOH]PSONUM
& As [VPSOH_]
Return

$DEF_BOITE
Gosub HORODAT From WGOPSOREV
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPSOREV" From GFONCTION At A_STAMP With A_WINDPREV Mask [REVPSO0]
&   Folder Mask [REVPSO1]
& , Folder Mask [REVPSO2]
& , Folder Mask [REVPSO3]
& , Invfol Mask [REVPSOH0]
& , Invfol Mask [REVPSOH1]
& , Invfol Mask [REVPSOH2]
& , Invfol Mask [REVPSOH3]
&  Listbox [VPSOH_] GAU_CHE
&   [L]SAIRAP(1) = [F:VPSOH]PSONUM Using "K:20X" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:VPSOH]REVNUM Using "N:4#" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = string$(num$([F:VPSOH]CURREVFLG)<>'2',mess([F:VPSOH]DOCTYP,7718,1))+string$(num$([F:VPSOH]CURREVFLG)='2',mess([F:PSOH]DOCTYP,7718,1)) Using "" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]OPPNUM)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]OPPNUM) Using "" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]BPCORD)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]BPCORD) Using "" Titled TITSEL(5) ,
&   [L]SAIRAP(6) = string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]HDOCNUM)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]HDOCNUM) Using "" Titled TITSEL(6) ,
&   [L]SAIRAP(7) = string$(num$([F:VPSOH]CURREVFLG)<>'2',[F:VPSOH]DOCDAT)+string$(num$([F:VPSOH]CURREVFLG)='2',[F:PSOH]DOCDAT) Using "" Titled TITSEL(7) ,
&   [L]SAIRAP(8) = [F:VPSOH]SALFCY Using "K:5c" Titled TITSEL(8)
&  Listbox [VPSOH9] GAU_CHE9
&   [L]SAIRAP(1) = [F:VPSOH9]A_TAB1 Using "K:20X" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = [F:VPSOH9]A_TAB2 Using "N:4#" Titled TITSEL9(2)  ,
&   [L]SAIRAP(3) = [F:VPSOH9]A_TAB3 Using "" Titled TITSEL9(3) ,
&   [L]SAIRAP(4) = [F:VPSOH9]A_TAB4 Using "" Titled TITSEL9(4) ,
&   [L]SAIRAP(5) = [F:VPSOH9]A_TAB5 Using "" Titled TITSEL9(5) ,
&   [L]SAIRAP(6) = [F:VPSOH9]A_TAB6 Using "" Titled TITSEL9(6) ,
&   [L]SAIRAP(7) = [F:VPSOH9]A_TAB7 Using "" Titled TITSEL9(7) ,
&   [L]SAIRAP(8) = [F:VPSOH9]A_TAB8 Using "K:5c" Titled TITSEL9(8) 
& As [REVPSO1]
Titled [REVPSO1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOPSOREV
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OPSOREV" From GFONCTION At A_STAMP With A_WINDPREV Mask [REVPSO0]
&   Folder Mask [REVPSO1]
& , Folder Mask [REVPSO2]
& , Folder Mask [REVPSO3]
& , Invfol Mask [REVPSOH0]
& , Invfol Mask [REVPSOH1]
& , Invfol Mask [REVPSOH2]
& , Invfol Mask [REVPSOH3]
& As [REVPSO1]
Titled [REVPSO1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [REVPSO1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [REVPSO1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [REVPSO1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(56314,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL(30)(1..8)
Call TEXTE(56316,TITSEL(1)) From OBJDIV
Call TEXTE(4861,TITSEL(2)) From OBJDIV
Call TEXTE(865,TITSEL(3)) From OBJDIV
Call TEXTE(18260,TITSEL(4)) From OBJDIV
Call TEXTE(2951,TITSEL(5)) From OBJDIV
Call TEXTE(171,TITSEL(6)) From OBJDIV
Call TEXTE(13676,TITSEL(7)) From OBJDIV
Call TEXTE(5060,TITSEL(8)) From OBJDIV
Local Char TITSEL9(30)(1..8)
Call TEXTE(56316,TITSEL9(1)) From OBJDIV
Call TEXTE(4861,TITSEL9(2)) From OBJDIV
Call TEXTE(865,TITSEL9(3)) From OBJDIV
Call TEXTE(18260,TITSEL9(4)) From OBJDIV
Call TEXTE(2951,TITSEL9(5)) From OBJDIV
Call TEXTE(171,TITSEL9(6)) From OBJDIV
Call TEXTE(13676,TITSEL9(7)) From OBJDIV
Call TEXTE(5060,TITSEL9(8)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(10129,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [VPSOH_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [REVPSO1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [REVPSO1] GAU_CHE
 Else
  Fillbox [REVPSO1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [VPSOH_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 2
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "PSONUM Desc;REVNUM Desc"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [VPSOH_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [VPSOH_] Order With CLELISTE
  Setlbox [REVPSO1] GAU_CHE
  Filter [VPSOH_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [REVPSO1] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [VPSOH_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [VPSOH_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "REVPSO0"      : ABMSK(0)  = "REVPSO0"  : AMA(0) = 1
NOMMSK(1) = "REVPSO1"      : ABMSK(1)  = "REVPSO1"  : AMA(1) = 1
NOMMSK(2) = "REVPSO2"      : ABMSK(2)  = "REVPSO2"  : AMA(2) = 1
NOMMSK(3) = "REVPSO3"      : ABMSK(3)  = "REVPSO3"  : AMA(3) = 1
NOMMSK(4) = "REVPSOH0"     : ABMSK(4)  = "REVPSOH0" : AMA(4) = 0
NOMMSK(5) = "REVPSOH1"     : ABMSK(5)  = "REVPSOH1" : AMA(5) = 0
NOMMSK(6) = "REVPSOH2"     : ABMSK(6)  = "REVPSOH2" : AMA(6) = 0
NOMMSK(7) = "REVPSOH3"     : ABMSK(7)  = "REVPSOH3" : AMA(7) = 0
NBMASK = 7
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:REVPSO0])>0 : Default Mask [REVPSO0] : Endif
 When 1 : If clalev([M:REVPSO1])>0 : Default Mask [REVPSO1] : Endif
 When 2 : If clalev([M:REVPSO2])>0 : Default Mask [REVPSO2] : Endif
 When 3 : If clalev([M:REVPSO3])>0 : Default Mask [REVPSO3] : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : Default Mask [REVPSOH0] : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : Default Mask [REVPSOH1] : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : Default Mask [REVPSOH2] : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : Default Mask [REVPSOH3] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:REVPSO0])>0 : Gosub TITRES From W1REVPSO0 : Endif
 When 1 : If clalev([M:REVPSO1])>0 : Gosub TITRES From W1REVPSO1 : Endif
 When 2 : If clalev([M:REVPSO2])>0 : Gosub TITRES From W1REVPSO2 : Endif
 When 3 : If clalev([M:REVPSO3])>0 : Gosub TITRES From W1REVPSO3 : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : Gosub TITRES From W1REVPSOH0 : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : Gosub TITRES From W1REVPSOH1 : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : Gosub TITRES From W1REVPSOH2 : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : Gosub TITRES From W1REVPSOH3 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:REVPSO0])>0 : Close Local Mask [REVPSO0] : Endif
If clalev([M:REVPSO1])>0 : Close Local Mask [REVPSO1] : Endif
If clalev([M:REVPSO2])>0 : Close Local Mask [REVPSO2] : Endif
If clalev([M:REVPSO3])>0 : Close Local Mask [REVPSO3] : Endif
If clalev([M:REVPSOH0])>0 : Close Local Mask [REVPSOH0] : Endif
If clalev([M:REVPSOH1])>0 : Close Local Mask [REVPSOH1] : Endif
If clalev([M:REVPSOH2])>0 : Close Local Mask [REVPSOH2] : Endif
If clalev([M:REVPSOH3])>0 : Close Local Mask [REVPSOH3] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:REVPSO0])>0 : Raz [M:REVPSO0] : Endif
 When 1 : If clalev([M:REVPSO1])>0 : Raz [M:REVPSO1] : Endif
 When 2 : If clalev([M:REVPSO2])>0 : Raz [M:REVPSO2] : Endif
 When 3 : If clalev([M:REVPSO3])>0 : Raz [M:REVPSO3] : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : Raz [M:REVPSOH0] : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : Raz [M:REVPSOH1] : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : Raz [M:REVPSOH2] : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : Raz [M:REVPSOH3] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:REVPSO0])>0 : Affzo [M:REVPSO0] : Endif
 When 1 : If clalev([M:REVPSO1])>0 : Affzo [M:REVPSO1] : Endif
 When 2 : If clalev([M:REVPSO2])>0 : Affzo [M:REVPSO2] : Endif
 When 3 : If clalev([M:REVPSO3])>0 : Affzo [M:REVPSO3] : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : Affzo [M:REVPSOH0] : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : Affzo [M:REVPSOH1] : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : Affzo [M:REVPSOH2] : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : Affzo [M:REVPSOH3] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:REVPSO0])>0 : [F:VPSOH] = [M:REVPSO0] : Endif
 When 1 : If clalev([M:REVPSO1])>0 : [F:VPSOH] = [M:REVPSO1] : Endif
 When 2 : If clalev([M:REVPSO2])>0 : [F:VPSOH] = [M:REVPSO2] : Endif
 When 3 : If clalev([M:REVPSO3])>0 : [F:VPSOH] = [M:REVPSO3] : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : [F:VPSOH] = [M:REVPSOH0] : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : [F:VPSOH] = [M:REVPSOH1] : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : [F:VPSOH] = [M:REVPSOH2] : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : [F:VPSOH] = [M:REVPSOH3] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:REVPSO0])>0 : [M:REVPSO0] = [F:VPSOH] : Endif
 When 1 : If clalev([M:REVPSO1])>0 : [M:REVPSO1] = [F:VPSOH] : Endif
 When 2 : If clalev([M:REVPSO2])>0 : [M:REVPSO2] = [F:VPSOH] : Endif
 When 3 : If clalev([M:REVPSO3])>0 : [M:REVPSO3] = [F:VPSOH] : Endif
 When 4 : If clalev([M:REVPSOH0])>0 : [M:REVPSOH0] = [F:VPSOH] : Endif
 When 5 : If clalev([M:REVPSOH1])>0 : [M:REVPSOH1] = [F:VPSOH] : Endif
 When 6 : If clalev([M:REVPSOH2])>0 : [M:REVPSOH2] = [F:VPSOH] : Endif
 When 7 : If clalev([M:REVPSOH3])>0 : [M:REVPSOH3] = [F:VPSOH] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [REVPSO0]REVNUM,PSONUM
Else
 Grizo [REVPSO1]REVNUM,PSONUM
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [REVPSO0]REVNUM,PSONUM
Else
 Actzo [REVPSO1]REVNUM,PSONUM
Endif
Return

$BOUTON
STDBOUT = "09<>RILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1801 : Call TEXTE(25595,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


