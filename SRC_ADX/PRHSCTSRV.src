#<AdxTL>@(#)1.0.0.0 $Revision$
#test timing
Local  Char      AXPARCOD(100)(0..20)
Local  Char      AXPARVAL(100)(0..20)
Local Char REFNUM(20)
Local Char PAGE(5)
Local Char COL(2)
Local Char COLTAB(5)(0..10)
Local Clbfile RESCLBLST(10),RESCLBUSR(10),RESCLBCOL(6),RESCLBCNG(6)
     
PAGE="CNG"
REFNUM="7101"
COL="1"
#COLTAB(0)="DCG"
COLTAB(0)="1"
COLTAB(1)="3"
COLTAB(2)="6"
Call PRHGETPREFSRV(AXPARCOD,AXPARVAL,REFNUM,PAGE,COL,COLTAB,RESCLBLST,RESCLBUSR,RESCLBCOL,RESCLBCNG)
End
################################################################################
# Script serveur
# Version : 20110527
# 20110527 : ajout page ppm
# 20110401 :On passe par subordonné flux
################################################################################
$NDF_ADD_AXE
Local     Integer   AXE       
Local  Char      NOMAXE(60)
Local  Char      LIBAXE(60)(0..5000)
Local  Char      CODAXE(30)(0..5000)
Local Char TMPSEP(1)
Local Integer WJ :WJ=1
SEP=","
While(WJ<10) 
Call GETLSTAXEANA(WJ,NOMAXE,CODAXE,LIBAXE) From PORNDF  
Append RESCLBLST,SEP+'NDFAXE'+num$(WJ)+":{"
Gosub NDF_WRITE_AXE
Gosub NDF_AXE_RAZ
Append RESCLBLST,'}'
SEP=","
WJ+=1
Wend
Return
$NDF_WRITE_AXE
TMPSEP=""
WI=0
While(CODAXE(WI)<>"")
Append RESCLBLST,TMPSEP+'"'+CODAXE(WI)+'":"'+LIBAXE(WI)+'"'
TMPSEP=","
WI+=1
Wend
Return
$NDF_AXE_RAZ
Raz NOMAXE,LIBAXE,CODAXE
Return 

$NDF_ADD_CONTROL
Local Char    CODEXP(30)(0..5000), DESEXP(60)(0..5000)
Local Integer DESFLG(0..5000)
Local Decimal PLAFOND(0..5000), FORFAIT(0..5000)
Local Char    VAT(30)(0..5000)
Local Integer DEB(0..5000)
Call GETLSTFRAIS(REFNUM,CODEXP,DESEXP,DESFLG,PLAFOND,FORFAIT,VAT,DEB) From PORNDF

WI=0
SEP=""
While(CODEXP(WI)<>"")
Append RESCLBLST,SEP+'{CODEXP:"'+CODEXP(WI)+'",DESFLG:'+num$(DESFLG(WI))+',PLAFOND:'+num$(PLAFOND(WI))+',FORFAIT:'+num$(FORFAIT(WI))+',VAT:"'+VAT(WI)+'",DEB:"'+num$(DEB(WI))+'"}'
SEP=","
WI+=1
Wend
Return

$NDF_ADD_LST
WI=0
SEP=""
While(CODEXP(WI)<>"")
Append RESCLBLST,SEP+'"'+CODEXP(WI)+'":"'+DESEXP(WI)+'"'
SEP=","
WI+=1
Wend
Return

$CNG_ADD_CONTROL
Local Char    TIM(30)(0..100), DES(30)(0..100), DSG(30)(0..100)
Local Integer ACS(0..100)
Local Integer PGN(0..100)
Local Integer COM(0..100)
Local Integer VLT(0..100)
Local Integer DSPSLD(0..100)
Call GETALLTYPCNG(TIM,DES,DSG,ACS,PGN,COM,VLT,DSPSLD)From PORDCG
WI=0
SEP=""
While(TIM(WI)<>"")
Append RESCLBLST,SEP+'{CODCNG:"'+TIM(WI)+'",ACS:'+num$(ACS(WI))+',PGN:'+num$(PGN(WI))
Append RESCLBLST,',COM:'+num$(COM(WI))+',DES:"'+DES(WI)+'",VLT:'+num$(VLT(WI))+',SLD:'+num$(DSPSLD(WI))+'}'
SEP=","
WI+=1
Wend
Return




$CNG_LOAD
TABCNG(0)="CNG"  : TABCNG(1)="DEM" : TABCNG(2)="VAL": TABCNG(3)="CNGANN"
TABCNG(4)="PLA" : TABCNG(5)="CAL" :  TABCNG(6)="SOLCOL"
If PAGE <>""
  WISCNG=find(PAGE,TABCNG)
Endif 
Return

$NDF_LOAD
TABNDF(0)="NDF" : TABNDF(1)="DEM" : TABNDF(2)="VAL"
If PAGE <>""
WISNDF=find(PAGE,TABNDF)
Endif
Return

$PREF_LOAD_INI
Local Char TMP_CODE(30),TMP_IDENT1(30),TMP_IDENT2(30),TMP_IDENT3(30)
Local Clbfile TMP_RESCLB(9)
Return 

$PREF_RAZ
Raz TMP_RESCLB
Return 

$ADD_CLOB
 If(len(TMP_RESCLB)=0)
      Append RESCLBUSR ,'{}'
    Else
      Append RESCLBUSR ,TMP_RESCLB
 Endif
Return

###########################################################################
#
# Récupération des données via le sript serveur
#
###########################################################################

Subprog PRHGETPREFSRV(AXPARCOD,AXPARVAL,REFNUM,PAGE,COL,COLTAB,RESCLBLST,RESCLBUSR,RESCLBCOL,RESCLBCNG)
    Value     Char     AXPARCOD()()
    Value     Char     AXPARVAL()()
    Value     Char     REFNUM()
    Value     Char     PAGE()
    Value     Char     COL()
    Value     Char     COLTAB()()
    Variable  Clbfile   RESCLBUSR()
    Variable  Clbfile   RESCLBLST()
    Variable  Clbfile   RESCLBCOL()
      Variable  Clbfile   RESCLBCNG()
    Raz RESCLBUSR
    Raz RESCLBLST
    Raz RESCLBCOL
    Raz RESCLBCNG
    Local Char TABCNG(30)(0..10)
    Local Char TABNDF(30)(0..10)
    Local Integer WISCNG : WISCNG=0
    Local Integer WISNDF : WISNDF=0
    Local Integer WI :WI=0
    Local Char SEP(1)
    Gosub NDF_LOAD
    Gosub CNG_LOAD
    Gosub PREF_LOAD_INI
    Append RESCLBUSR ,'{'
    #All
    Call READCLB("",REFNUM,"PRH","ALL",TMP_RESCLB)From INTRUTILB
    Append RESCLBUSR ,'ALL:'
    Gosub ADD_CLOB
     #WKG
    Gosub PREF_RAZ
    Call READCLB("WKGRP",REFNUM,"PRH","WKG",TMP_RESCLB)From INTRUTILB
    Append RESCLBUSR ,',WKG:{WKGRP:'
    Gosub ADD_CLOB
    Append RESCLBUSR ,'}'
    If(PAGE<>"" and PAGE<>"WKG")
      Gosub PREF_RAZ
     Call READCLB("",REFNUM,"PRH",PAGE,TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,','+PAGE+':'
      Gosub ADD_CLOB
    Endif
    #cng 
    If PAGE = "CNG"
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","CNG",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',CNG:'
      Gosub ADD_CLOB
    Endif
    If PAGE="PPH"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',PPH:{MODELE:'
      Gosub ADD_CLOB
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      If (len(TMP_RESCLB)>2)
      Append RESCLBUSR ,','+right$(TMP_RESCLB,2)
      Else
      Append RESCLBUSR ,'}'
      Endif
    Endif
    If PAGE="PPM"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',PPH:{MODELE:'
      Gosub ADD_CLOB
      Append RESCLBUSR ,'}'
    Endif

    If PAGE="NDF"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","NDF",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',NDF:{MODELE:'
      Gosub ADD_CLOB
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","NDF",TMP_RESCLB)From INTRUTILB
      If (len(TMP_RESCLB)>2)
      Append RESCLBUSR ,','+right$(TMP_RESCLB,2)
      Else
      Append RESCLBUSR ,'}'
      Endif
    Endif
    Append RESCLBUSR ,'}'
    #on load les listes et les controles
    Local Char SEP(1)
    SEP=""
    
    Append RESCLBLST,'{'
    Append RESCLBLST,'CNG:{CONTROL:{CNGTYP:['
    If WISCNG <> 0
      Gosub CNG_ADD_CONTROL
    Endif
    Append RESCLBLST,']}}'
    SEP=","
    Append RESCLBLST,SEP+'NDF:{CONTROL:{TYPEFRAIS:['
    If WISNDF <> 0
    Gosub NDF_ADD_CONTROL
    Endif
    Append RESCLBLST,']}}'
 
    SEP=","
    Append RESCLBLST,SEP+'LISTS:{SITE:{},POPULATION:{},SOCIETE:{},SERVICE:{},PROFILS:{},TYPEFRAIS:{'
    If WISNDF <> 0
    Gosub NDF_ADD_LST
    Endif
    Append RESCLBLST,'}'
    If WISNDF <> 0
    Gosub NDF_ADD_AXE
    Endif
    Append RESCLBLST,'}'
    Append RESCLBLST,'}'
    # Calcul des collaborateur :
    Local Char VALLM(70)
    If(COL<>"")
      If(COLTAB(0)<>"")
        Local Integer DIMTAB : DIMTAB=2000
        Local Char TMPREFNUM(30)(0..DIMTAB),TMPCTRNUM(30)(0..DIMTAB)
        Local Char TMPREFNUM1(30)(0..DIMTAB)
        Local Char TMPSUBNAM(0)(0..DIMTAB),TMPSUBSRN(0)(0..DIMTAB),TMPSUBNSRN(70)(0..DIMTAB)
        Local Char TMPNOM(70)
        Local Date DAT
  
        Raz TMPREFNUM,TMPCTRNUM
        Append RESCLBCOL,"{"
        If(num$(val(COLTAB(0)))=COLTAB(0) or val(COLTAB(0))<>0)
          Call GETMYSUBORDONNESNIVEAU(REFNUM,TMPREFNUM,TMPCTRNUM,COLTAB)From PRHUTIWEB
          SEP=""
           # LSTCONTRAT
          Local Integer WI : WI=0
          Local Integer CPT : CPT=0
          While(TMPREFNUM(WI)<>"" and WI <= DIMTAB)
            If(TMPREFNUM(WI)<>REFNUM and find(TMPREFNUM(WI),TMPREFNUM1)=0)
              TMPREFNUM1(CPT)=TMPREFNUM(WI)
              VALLM=func PRHUTIWEB.GETNOMEML(TMPREFNUM(WI),1)
              Gosub INIVALREP From PRHUTIFCTPRH 
              CPT+=1
              Append RESCLBCOL,SEP+'"'+TMPREFNUM(WI)+'":"'+VALLM+'"'
              SEP=","
            Endif
            WI+=1
           Wend
        Else
          Local Date DATFIN
          Local Char SOCIETE(1),SITE(1),SERVICE(1),PRFCOD(1),POPULATION(1),GROUPE(1)(0..10)
          Call GETSUBORDONNESFLUX(REFNUM,COLTAB(0),TMPREFNUM,TMPCTRNUM,DAT,TMPSUBNAM,TMPSUBSRN,TMPSUBNSRN,DATFIN,SOCIETE,SITE,SERVICE,PRFCOD,POPULATION,GROUPE) From PORMAT
          SEP=""
           # LSTCONTRAT
          Local Integer WI : WI=0
          Local Integer CPT : CPT=0
          While(TMPREFNUM(WI)<>"" and WI <= DIMTAB)
            If(TMPREFNUM(WI)<>REFNUM and find(TMPREFNUM(WI),TMPREFNUM1)=0)
              TMPREFNUM1(CPT)=TMPREFNUM(WI)
              VALLM=TMPSUBNSRN(WI)
              Gosub INIVALREP From PRHUTIFCTPRH 
              CPT+=1
              Append RESCLBCOL,SEP+'"'+TMPREFNUM(WI)+'":"'+VALLM+'"'
              SEP=","
            Endif
            WI+=1
          Wend
         Endif
         Append RESCLBCOL,'}'
      Else
        Append RESCLBCOL,'{}'
      Endif
     Endif
     # on ajoute la liste des types de congés
     Local Char     LSTTYPCNGLIB(60)(0..100)
     Local Char     LSTTYPCNGVAL(20)(0..100)
     Call GETLSTTYPCNG(LSTTYPCNGVAL,LSTTYPCNGLIB) From PORDCG
     Append RESCLBCNG ,'{'
     Local Integer WI : WI=0
     Local Char SEP :SEP=""
     While(LSTTYPCNGVAL(WI)<>"")
        VALLM=LSTTYPCNGLIB(WI)
        Gosub INIVALREP From PRHUTIFCTPRH
        Append RESCLBCNG ,SEP+'"'+LSTTYPCNGVAL(WI)+'":"'+VALLM+'"'
        SEP=","
        WI+=1
      Wend          
    Append RESCLBCNG ,'}'
End


Subprog PRHGETPREFSRV1(AXPARCOD,AXPARVAL,REFNUM,PAGE,COL,COLTAB,RESCLBLST,RESCLBUSR,RESCLBCOL,RESCLBCNG)
    Value     Char     AXPARCOD()()
    Value     Char     AXPARVAL()()
    Value     Char     REFNUM()
    Value     Char     PAGE()
    Value     Char     COL()
    Value     Char     COLTAB()()
    Variable  Clbfile   RESCLBUSR()
    Variable  Clbfile   RESCLBLST()
    Variable  Clbfile   RESCLBCOL()
    Variable  Clbfile   RESCLBCNG()
    Raz RESCLBUSR
    Raz RESCLBLST
    Raz RESCLBCOL
    Raz RESCLBCNG
    Local Char TABCNG(30)(0..10)
    Local Char TABNDF(30)(0..10)
    Local Integer WISCNG : WISCNG=0
    Local Integer WISNDF : WISNDF=0
    Local Integer WI :WI=0
    Local Char SEP(1)
    Gosub NDF_LOAD
    Gosub CNG_LOAD
    Gosub PREF_LOAD_INI
    Append RESCLBUSR ,'{'
    #All
    Call READCLB("",REFNUM,"PRH","ALL",TMP_RESCLB)From INTRUTILB
    Append RESCLBUSR ,'ALL:'
    Gosub ADD_CLOB
    #WKG
    Gosub PREF_RAZ
    Call READCLB("WKGRP",REFNUM,"PRH","WKG",TMP_RESCLB)From INTRUTILB
    Append RESCLBUSR ,',WKG:{WKGRP:'
    Gosub ADD_CLOB
    Append RESCLBUSR ,'}'
    If(PAGE<>"" and PAGE<>"WKG")
      Gosub PREF_RAZ
     Call READCLB("",REFNUM,"PRH",PAGE,TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,','+PAGE+':'
      Gosub ADD_CLOB
    Endif
    #cng 
    If PAGE = "CNG"
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","CNG",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',CNG:'
      Gosub ADD_CLOB
    Endif
    If PAGE="PPH"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',PPH:{MODELE:'
      Gosub ADD_CLOB
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      If (len(TMP_RESCLB)>2)
      Append RESCLBUSR ,','+right$(TMP_RESCLB,2)
      Else
      Append RESCLBUSR ,'}'
      Endif
    Endif
     If PAGE="PPM"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","PPH",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',PPH:{MODELE:'
      Gosub ADD_CLOB
      Append RESCLBUSR ,'}'
    Endif
    If PAGE="NDF"
      Gosub PREF_RAZ
       Call READCLB("MODELE",REFNUM,"PRH","NDF",TMP_RESCLB)From INTRUTILB
      Append RESCLBUSR ,',NDF:{MODELE:'
      Gosub ADD_CLOB
      Gosub PREF_RAZ
      Call READCLB("",REFNUM,"PRH","NDF",TMP_RESCLB)From INTRUTILB
      If (len(TMP_RESCLB)>2)
      Append RESCLBUSR ,','+right$(TMP_RESCLB,2)
      Else
      Append RESCLBUSR ,'}'
      Endif
    Endif
    Append RESCLBUSR ,'}'
    #on load les listes et les controles
    Local Char SEP(1)
    SEP=""
    
    Append RESCLBLST,'{'
    Append RESCLBLST,'CNG:{CONTROL:{CNGTYP:['
    If WISCNG <> 0
      Gosub CNG_ADD_CONTROL
    Endif
    Append RESCLBLST,']}}'
    SEP=","
    Append RESCLBLST,SEP+'NDF:{CONTROL:{TYPEFRAIS:['
    If WISNDF <> 0
    Gosub NDF_ADD_CONTROL
    Endif
    Append RESCLBLST,']}}'
 
    SEP=","
    Append RESCLBLST,SEP+'LISTS:{SITE:{},POPULATION:{},SOCIETE:{},SERVICE:{},PROFILS:{},TYPEFRAIS:{'
    If WISNDF <> 0
    Gosub NDF_ADD_LST
    Endif
    Append RESCLBLST,'}'
    If WISNDF <> 0
    Gosub NDF_ADD_AXE
    Endif
    Append RESCLBLST,'}'
    Append RESCLBLST,'}'
    # Calcul des collaborateur :
    
    If(COL<>"")
      Local Char WFLUX
      WFLUX=COLTAB(0)
      Case WFLUX
       When "PLA","CNG" :
          WFLUX="DCG"
       When "DPE" :
          WFLUX="DPI"
       When "NDF" :
          WFLUX="EXS"
        When  Default  : 
      Endcase
     Onerrgo REINIWFLUX
     Local Char CHECHKFLUX
     CHECHKFLUX=evalue("[V]GFLXPOR"+WFLUX)
     Onerrgo
       
# check flux :
#       When "DCG"    : [L]FLUX = [V]GFLXPORDCG
#  When "EXS"    : [L]FLUX = [V]GFLXPOREXS
#  When "DPI"    : [L]FLUX = [V]GFLXPORDPI
#  When "PPH"    : [L]FLUX = [V]GFLXPREPAI
#  When "PLA"    : [L]FLUX = [V]GFLXPORPLA
#  When "TPS"    : [L]FLUX = [V]GFLXPORTPS
#  When "DEM"    : [L]FLUX = [V]GFLXPORDEM
#  When "CAL"    : [L]FLUX = [V]GFLXPORCAL
#  When "CNGANN" : [L]FLUX = [V]GFLXCNGANN
      If(WFLUX<>"")
      Local Integer DIMTAB : DIMTAB=2000
      Local Char TMPREFNUM(30)(0..DIMTAB),TMPCTRNUM(30)(0..DIMTAB)
      Local Char TMPSUBNAM(0)(0..DIMTAB),TMPSUBSRN(0)(0..DIMTAB),TMPSUBNSRN(70)(0..DIMTAB)
      Local Date DAT
      Local Char TMPREFNUM1(30)(0..DIMTAB)
      Local Char VALLM(70)
      Raz TMPREFNUM,TMPCTRNUM
        
        # Call GETMYSUBORDONNESNIVEAU(REFNUM,TMPREFNUM,TMPCTRNUM,COLTAB)From PRHUTIWEB
      Local Date DATFIN
      Local Char SOCIETE(1),SITE(1),SERVICE(1),PRFCOD(1),POPULATION(1),GROUPE(1)(0..10)
      Call GETSUBORDONNESFLUX(REFNUM,WFLUX,TMPREFNUM,TMPCTRNUM,DAT,TMPSUBNAM,TMPSUBSRN,TMPSUBNSRN,DATFIN,SOCIETE,SITE,SERVICE,PRFCOD,POPULATION,GROUPE) From PORMAT
      SEP=""
      Append RESCLBCOL,"{"
           # LSTCONTRAT
      Local Integer WI : WI=0
      Local Integer CPT : CPT=0
          While(TMPREFNUM(WI)<>"" and WI <= DIMTAB)
          If(TMPREFNUM(WI)<>REFNUM and find(TMPREFNUM(WI),TMPREFNUM1)=0)
              TMPREFNUM1(CPT)=TMPREFNUM(WI)
              VALLM=TMPSUBNSRN(WI)
              Gosub INIVALREP From PRHUTIFCTPRH 
            CPT+=1
            Append RESCLBCOL,SEP+'"'+TMPREFNUM(WI)+'":"'+VALLM+'"'
              SEP=","
           Endif
          WI+=1
          Wend
          Append RESCLBCOL,'}'
      Else
        Append RESCLBCOL,'{}'
      Endif
     Endif
     # on ajoute la liste des types de congés
        Local Char     LSTTYPCNGLIB(60)(0..100)
        Local Char     LSTTYPCNGVAL(20)(0..100)
        Call GETLSTTYPCNG(LSTTYPCNGVAL,LSTTYPCNGLIB) From PORDCG
        Append RESCLBCNG ,'{'
        Local Integer WI : WI=0
        Local Char SEP :SEP=""
        While(LSTTYPCNGVAL(WI)<>"")
          VALLM=LSTTYPCNGLIB(WI)
          Gosub INIVALREP From PRHUTIFCTPRH
          Append RESCLBCNG ,SEP+'"'+LSTTYPCNGVAL(WI)+'":"'+VALLM+'"'
          SEP=","
          WI+=1
       Wend          
    Append RESCLBCNG ,'}'
End
$REINIWFLUX
WFLUX=""
Resume :
