#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SORDERP
#######################################################################################
End

#######################################################################################
$AREAD_AFTER

  [L]ASTATUS = fmet this.INIT_TSICODADI()

  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  # 107890 : Scheduled invoices : (LD:15/12/15)
  #--INVCND
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_INVCND_LEG(this, this.INVCND, this.CPY, this.SALFCY, this.LEG, this.INVCND_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

#######################################################################################
$AINIT

  [L]ASTATUS = fmet this.INIT_TSICODADI()

Return

#######################################################################################
$INIT_TSICODADI
Local Integer DIM_STI
Local Integer NI

  DIM_STI = func ASYRFNC.ACTIV("STI")
  # -------------------
  For NI = 1 To DIM_STI
    this.C_TSICOD(NI).TSICODADI = NI + 20
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

