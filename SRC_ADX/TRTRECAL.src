#<AdxTL>@(#)6.0.0.0 $Revision$
####################################################################################################################
# HCM V8 :
# To manage the filter by GCURLEG on the main process    : Already done by DBA
# To manage the filter on new concept of population      : Not yet
###################################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTRECAL","TRTRECAL",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1
 When "BOUTON"      : Gosub BOUTON From TRTAUT :#81085
Endcase
Return

$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Affzo [DIA]: Setmok [DIA] With 0
Call AFF_MEMO From DIVPAYE: #81085
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$INIT
Local Char    MATRI(GLONEML) , SYMBOLE(80) , CRITERE(250) , BULLETIN(GLONVCR), CTR(GLONHRCTR)
Local Integer NOK , OKC , PASAPAS
Local Date    DATMAT
TIT = mess(52,10703,1)     : # Recalcul des bulletins de paye
Gosub OUVFIC From TRTCAL
#LIPET - 08-05-2016 - X3PEOP-1006 - START
#Gosub OUVFIC From WPPLAN
#LIPET - 08-05-2016 - X3PEOP-1006 - END

If clalev([F:RUB2])=0 : Local File RUBRIQUE   [RUB2] : Endif
Local Mask TRTRECAL [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","rca") From GMEMO
Call AFF_MEMO From DIVPAYE: #81085
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 If [M]NBRRUB=0
  SAI = 1
 Else
  TMP = 1
  TRA = 1
 Endif
Endif
Return

$EXEC
Gosub OUVFIC From ="WP"+GCURLEG+"PLAN"
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

CRITERE = '[F:CPY]LEG="'+GCURLEG+'"'
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:VEP]FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:VEP]EMP>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:VEP]EMP<="'+[M:DIA]MATFIN+'"'
Endif
If [M:DIA]ALLSRV<>2  #service
 CRITERE -= '& [F:VEP]SRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE -= '& [F:VEP]PRF = "'+[M:DIA]PRF+'"'
Endif
If [M:DIA]DATPAYSTR<>[0/0/0]
 CRITERE -= '& [F:VEP]PYRDAT>=['+format$(GFMD,[M:DIA]DATPAYSTR)+']'
Endif
If [M:DIA]DATPAYEND<>[0/0/0]
 CRITERE -= '& [F:VEP]PYRDAT<=['+format$(GFMD,[M:DIA]DATPAYEND)+']'
Endif

If [M:DIA]POP<>""
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
& , [HRPOA]POA0 = [M:DIA]POP;[F:VEP]EMP
&   As [LNK]
&   Where evalue(CRITERE) & [F:HRPOA]REFNUM<>""
Else
 Link [VEP] With
&   [ID]ID0   = [F:VEP]EMP
& , [FCY]FCY0 = [F:VEP]FCY
& , [CPY]CPY0 = [F:FCY]LEGCPY
&   As [LNK]
&   Where evalue(CRITERE)
Endif

NBPCE = 0
For [LNK]
 Gosub TRTCONT
 If NOK=0
  Call DEBTRANS From GLOCK
  Gosub RECALCUL
  If GOK=1
   NBPCE += 1
  Endif
 Endif
 Unlock =SYMBOLE
Next
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
Return

$RECALCUL
Call ECR_TRACE(MATRI-[F:ID]NAM-[F:ID]SRN-":"-format$("D:"+GFMDAT,[F:VEP]PYRDAT)-[F:VEP]BUL,0) From GESECRAN
PASAPAS = -1
Call DEBTRANS From GLOCK
Gosub TR1
Call ECR_TRACE("",0) From GESECRAN
Return

$TR1
GOK = 1
Trbegin [HSP]
 Call PLAN([F:VEP]BUL,PASAPAS,0) From GPLAN
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MEMRUB
#87135: CICE (Cf. UUCALCICE)
#Local Integer IR
#IR = find(RUB,[M:DIA]RUB(0..[M:DIA]NBRRUB-1))
#If IR
# Call ECR_TRACE(format$("K:12X",RUB)+" : "+format$("N:9.2",MONT)+"    "+[M:DIA]ZRUB(IR-1),0) From GESECRAN
# If [M:DIA]SIM<>2

Local Integer IR, SIM
If dim(GRUBCICE)>0
 If RUB=GRUBCICE
   [L]IR=1
   Call ECR_TRACE(format$("K:12X",RUB)+" : "+format$("N:9.2",MONT),0) From GESECRAN
   [L]SIM=0
 Endif
Elsif dim([M:DIA]RUB)>0
 [L]IR = find(RUB,[M:DIA]RUB(0..[M:DIA]NBRRUB-1))
 If [L]IR
  Call ECR_TRACE(format$("K:12X",RUB)+" : "+format$("N:9.2",MONT)+"    "+[M:DIA]ZRUB(IR-1),0) From GESECRAN
  [L]SIM=[M:DIA]SIM
 Endif
Endif
If [L]IR
 If [L]SIM<>2
  If [L]TYP<=0 : [L]TYP = 1 : Endif
  Readlock [HSP]HSP3 = BULLETIN;RUB;[L]TYP
  If fstat=1
   GOK = -1 : GLOCK = "$HISTOPAYE"-MATRI-RUB : Return
  Elsif fstat
   If MEM :
    Raz [F:HSP]
    [F:HSP]BUL = BULLETIN
    [F:HSP]EMP = MATRI
    [F:HSP]DAT = DATPAY
    [F:HSP]CTRNUM = CTR
    [F:HSP]RUB = RUB
    Read[F:RUB2]RUB0=GCURLEG;RUB
    If !fstat : [F:HSP]ROW = [F:RUB2]ROW : Endif
    [F:HSP]TYP = [L]TYP
    [F:HSP]BAS = BASE
    [F:HSP]RAT = TAUX
    [F:HSP]AMT = MONT
    [F:HSP]LEG = GCURLEG
    If [F:HSP]TYP<=0 : [F:HSP]TYP = 1 : Endif
     Write [HSP]
   Else
    fstat=0 :# Do nothing
   Endif
  Else
   If MEM
    [F:HSP]BAS = BASE
    [F:HSP]RAT = TAUX
    [F:HSP]AMT = MONT
    Rewrite [HSP]
   Else
    Delete [HSP]HSP3 = BULLETIN;RUB;[L]TYP
   Endif
  Endif
  If fstat
   GOK = 0 : Call FSTA("HSP") From GLOCK : Return
  Endif
 Endif
Endif
Return

$TRTCONT
NOK = 1

Call CONTROLE([F:VEP]EMP,[F:VEP]PYRDAT,[F:VEP]CTRNUM,[M:DIA]CRI,OKC,0) From DIVPAYE
If !OKC : Return : Endif

# Verrou
##**82073
Call VEPSYMBOLE (SYMBOLE, "VEP") From DIVPAYE

Lock =SYMBOLE
If fstat
 Call ECR_TRACE([F:VEP]EMP-":"-mess(10,100,1),1) From GESECRAN
 Return
Endif

# Non comptabilisé
# Verrouillé US 2022 65062
If [F:VEP]PST>1 or [F:VEP]FLGLOCK=2 : Return : Endif     :# Déjà comptabilisé

NOK=0
Return

################################################################################
## Etiquettes écran TRTRECAL
################################################################################
#LIPET - 08-05-2016 - X3PEOP-1006 - START
Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_DATPAYEND(VALEUR)
Variable Date    VALEUR
Local Integer OK
If VALEUR<[M:DIA]DATPAYSTR
#Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
End
#LIPET - 08-05-2016 - X3PEOP-1006 - END

Subprog C_RUB(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If find([F:RUB]TYPRUB,5,6,10)
 GMESSAGE = mess(64,10702,1) : # Rubrique non recalculable
 mkstat = 2 : End
Endif
If [F:RUB]AMTPRN>1
 #Rubrique imprimable sur les bulletins
 Call AVERTIR(num$(VALEUR)-":"-mess(130,10702,1),OK) From GESECRAN
 If OK<>2 : mkstat=2 : Else mkstat=0 : End : Endif
Endif
End

