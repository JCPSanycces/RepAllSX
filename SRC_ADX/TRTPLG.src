#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
# Planning marketing                                                Module CRM          09 novembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIMAXLIG
Global Integer GIFIRCMG
Global Integer GIFIROPG
Global Integer GILASCMG
Global Integer GILASOPG
Global Integer GINEWPGC
Global Integer GINEWPGO
Global Integer GILNEWPGO
Global Integer GIFLOPG
Global Char WICOOMP(30)(10,2)  # FGR 23/07/2009 : X3SUIVI56686

  If !clalev([F:PLG]) : Local File PLGMKG [PLG] : Endif
  If !clalev([F:PLO]) : Local File PLGOPG [PLO] : Endif
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif
  GIMAXLIG = 0
  GIFIRCMG = 0
  GIFIROPG = 0
  GILASCMG = 0
  GILASOPG = 0
  GINEWPGC = 1
  GINEWPGO = 0
  GILNEWPGO = 0
  GIFLOPG = 0
  Call INIT_ICONE From TRTPLGB
Return

##########################################################################################################
$PREMIER
Local Integer ILIN
Local Integer IPBL

  IPBL = 0
  ILIN = 0
  Call LOADMKG(0, ILIN, IPBL) From TRTPLGB
  [M:PLG1]NBPLG = ILIN
  GIFIRCMG = 0
  GIFIROPG = 0
  Affzo [M:PLG1]1-99
Return

##########################################################################################################
$PRECEDENT
Local Integer ILIN
Local Integer IPBL

  #Si on a atteint le début du planning, pas la peine d'aller en arrière.
  If GIFIRCMG = 0 Then
    If GIFIROPG = 0 Then
      Return
    Endif
  Endif
  #Si on a presque atteint le début du planning, on revient tout au début
  If GIFIRCMG = 0 Then
    If GIFIROPG <= 10 Then
      Gosub PREMIER
      Return
    Endif
  Endif
  IPBL = 0
  ILIN = 0
  GINEWPGC = 1
  GINEWPGO = 1
  GILNEWPGO = 1
  GIFLOPG = 1
  Call LASTMKG("PREV", GIFIRCMG, ILIN, IPBL) From TRTPLGB
  [M:PLG1]NBPLG = ILIN
  Affzo [M:PLG1]1-99
Return

##########################################################################################################
$SUIVANT
Local Integer ILIN
Local Integer IPBL

  IPBL = 0
  ILIN = 0
  GINEWPGC = 1
  GINEWPGO = 1
  Call LOADMKG(GILASCMG, ILIN, IPBL) From TRTPLGB
  [M:PLG1]NBPLG = ILIN
  Affzo [M:PLG1]1-99
Return

##########################################################################################################
$DERNIER
Local Integer ILIN
Local Integer IPBL

  IPBL = 0
  ILIN = 0
  GINEWPGC = 1
  GILNEWPGO = 1
  GINEWPGO = 1
  Call LASTMKG("LAST", GIFIRCMG, ILIN, IPBL) From TRTPLGB
  [M:PLG1]NBPLG = ILIN
  Affzo [M:PLG1]1-99
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  ETAMEN(1) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Raz [M:PLG0]
  Raz [M:PLG1]
  [M:PLG0]CUR = GSYSCUR
  GIMAXLIG = dim([M:PLG1]CMG)-1
  #Nettoie les tables d'éventuelles sorties intempestives de X3.
  Call CLEANPLG From TRTPLGB
  Gosub FLOADCMG
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
  # FGR 06/04/2010 : X3SUIVI63636
  If BOUT = "B" Then
    If nolign < 1 Then
      FOK = 0
    Endif
  Endif
Return

##########################################################################################################
$FINSAI
  #Nettoie les tables de travail en cas de sortie normal du planning
  Call RAZ_PLG From TRTPLGB
  Raz [M:PLG0]
  Raz [M:PLG1]
  Kill GIMAXLIG
  Kill GIFIRCMG
  Kill GIFIROPG
  Kill GILASCMG
  Kill GILASOPG
  Kill GINEWPGC
  Kill GINEWPGO
  Kill GILNEWPGO
  Kill GIFLOPG
  Kill WICOOMP # FGR 23/07/2009 : X3SUIVI56686
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Chargement initial du planning marketing.
#########################################################
$FLOADCMG
Local Integer ILIN
Local Integer IPBL
Local Decimal ICMMPRC

  IPBL = 0
  ICMMPRC = 0
  ILIN = 0
  #Alimentation de la table PLG
  Call FILLPLG(IPBL) From TRTPLGB
  If IPBL Then
    GMESSAGE = mess(344,196,1) #Erreur lors du chargement du planning marketing.
    GERR = 1
    FIN = 1
    Return
  Endif
  #Chargement du planning marketing et calcul des budgets prévus et engagés
  Call LOADMKG(0, ILIN, IPBL) From TRTPLGB
  If IPBL Then
    FIN = 1
    Return
  Endif
  [M:PLG1]NBPLG = ILIN
  #Calcul du pourcentage
  If [M:PLG0]TOTBUDEXT <= 0 Then
    ICMMPRC = 0
  Else
    ICMMPRC = ([M:PLG0]TOTBUDCMM / [M:PLG0]TOTBUDEXT) * 100
  Endif
  If ICMMPRC < 10 Then
    [M:PLG0]CMMPRC = left$(num$(ICMMPRC), 4) + "%"
  Elsif ICMMPRC >= 10 and ICMMPRC < 100 Then
    [M:PLG0]CMMPRC = left$(num$(ICMMPRC), 5) + "%"
  Elsif ICMMPRC >= 100 and ICMMPRC < 1000 Then
    [M:PLG0]CMMPRC = left$(num$(ICMMPRC), 6) + "%"
  Elsif ICMMPRC >= 1000 Then
    [M:PLG0]CMMPRC = left$(num$(ICMMPRC), 7) + "%"
  Endif
  Affzo [M:PLG0]1-99
  Affzo [M:PLG1]1-99
Return

##########################################################################################################
# Traitement du bouton Opérations marketing.
#########################################################
$ONOPG
Local Integer IPBL
Local Integer ICLSNUM
Local Integer INUMLIGNE 

  IPBL = 0
  ICLSNUM = 0
  INUMLIGNE = 0
  #Si une opération est sélectionnée, on ne fait rien
  If [M:PLG1]CMGNUM(nolign-1) = "" Then
    Return
  Endif
  #S'il n' y a pas d'opérations pour la campagne, on ne fait rien
  If [M:PLG1]MOR(nolign-1) = "" Then
    Return
  Endif
  INUMLIGNE = nolign-1
  If [M:PLG1]MOR(nolign-1) = "-" Then
    Call SETDASH("+", [M:PLG1]CLSNUM(INUMLIGNE), IPBL) From TRTPLGB
    If IPBL Then
      Return
    Endif
    [M:PLG1]MOR(INUMLIGNE) = "+"
    Call LOADMKG([M:PLG1]CLSNUM(INUMLIGNE), INUMLIGNE, IPBL) From TRTPLGB
    [M:PLG1]NBPLG = INUMLIGNE
  Else
    Call SETDASH("-", [M:PLG1]CLSNUM(INUMLIGNE), IPBL) From TRTPLGB
    If IPBL Then
      Return
    Endif
    [M:PLG1]MOR(INUMLIGNE) = "-"
    Call LOADMKG([M:PLG1]CLSNUM(INUMLIGNE), INUMLIGNE, IPBL) From TRTPLGB
    [M:PLG1]NBPLG = INUMLIGNE
  Endif
  Affzo [M:PLG1]1-99
Return
