#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FOC0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:18"
A_USER  = "DOC"
A_STAMP = "20181109230418"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask FOC0 [FOC0]
Gosub HORODAT
Local Inpbox "FOC0" From GFONCTION At A_STAMP With A_WINDPREV Mask [FOC0] As [SIM_]
Grizo [FOC0]5
Grizo [FOC0]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [FOC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=75 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=75 : Y1(1)=4 : Y2(1)=28
Return

$ON_CODFOR
Onevent CONTROL Call C_CODFOR(zc) From W1FOC0
Onevent BEFORE_INPUT Call AS_CODFOR(zc) From W1FOC0
Onevent AFTER_CHANGE Gosub AMM_CODFOR From W1FOC0
Return

Subprog AS_CODFOR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_CODFOR(zc) From W1FOC0
Onkey 144 Titled GBOUTP Call P_CODFOR(zc) From W1FOC0
Onkey 146 Titled GBOUTA Call SA_CODFOR(zc) From W1FOC0
Gosub _AFF
End

Subprog C_CODFOR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODFOR" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJW"
 PARMSK(1) = "FOC"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CODFOR" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

$AMM_CODFOR
Call AM_CODFOR(zc)
If !mkstat & GOBJET
 zoncou = "CODFOR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODFOR(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODFOR)")>indice
 [M]CODFOR(indice) = VALEUR
 Affzo ZCODFOR(indice)
Endif
Gosub _AFF
End

Subprog S_CODFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJ1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJ1"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_CODFOR" : PROGSUB = "SUBFOC" : PROGSPE = "SPEFOC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "FOC"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 ACTION = "BS_CODFOR" : PROGSUB = "SUBFOC" : PROGSPE = "SPEFOC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_CODFOR(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FOC"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODFOR(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FOC",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODFOR
Onevent BEFORE_AREA Gosub AV_ZCODFOR From W1FOC0
Return

$AV_ZCODFOR
Call LECTEXTRA(zc,"FORCTR","DESFOR",num$([M]CODFOR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1FOC0
Onevent CONTROL Call C_LEG(zc) From W1FOC0
Onevent AFTER_CHANGE Gosub AMM_LEG From W1FOC0
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1FOC0
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1FOC0
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1FOC0
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1FOC0
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1FOC0
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"909","") From SUBADI
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"909",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBFOC
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1FOC0
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_DESFOR
Onevent INIT_AREA Call D_DESFOR(zc) From W1FOC0
Onevent BEFORE_INPUT Call AS_DESFOR(zc) From W1FOC0
Onevent CONTROL Call C_DESFOR(zc) From W1FOC0
Return

Subprog IB_DESFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_DESFOR(VALEUR)
Variable Char    VALEUR()
If varinit([M]DESFOR,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"FORCTR","DESFOR",[M:FOC0]LEG,[M:FOC0]CODFOR) From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_DESFOR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_DESFOR(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_DESFOR(zc) From W1FOC0
Gosub _AFF
End

Subprog C_DESFOR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DESFOR" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_DESFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_DESFOR" : PROGSUB = "SUBFOC" : PROGSPE = "SPEFOC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "FORCTR"
 PARMSK(2) = "DESFOR"
 PARMSK(3) = [M:FOC0]LEG
 PARMSK(4) = [M:FOC0]CODFOR
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_DESFOR" : PROGSUB = "SUBFOC" : PROGSPE = "SPEFOC0" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_TYPFOR
Onevent AFTER_CHANGE Gosub AMM_TYPFOR From W1FOC0
Onevent INIT_AREA Call D_TYPFOR(zc) From W1FOC0
Onevent BEFORE_INPUT Call AS_TYPFOR(zc) From W1FOC0
Return

Subprog D_TYPFOR(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPFOR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TYPFOR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_TYPFOR
Call AM_TYPFOR(zc)
If !mkstat & GOBJET
 zoncou = "TYPFOR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TYPFOR(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TYPFOR(VALEUR) From SUBFOC
If mkstat : GERR = 1 : GZONE = "TYPFOR" : GZNUM = 680 : Endif
Gosub _AFF
End

$ON_CAIVAL
Onevent BEFORE_INPUT Call AS_CAIVAL(zc) From W1FOC0
Onevent CONTROL Call C_CAIVAL(zc) From W1FOC0
Return

Subprog IB_CAIVAL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTBOUT
 Call BOUTSEL(VALEUR,"M",[M]CAILIB,"") From FMTVAR
Endif
Gosub _AFF
End

Subprog AS_CAIVAL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(877,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_CAIVAL(VALEUR)
## Action AFMTSAI
Call ASAISIE(VALEUR,"M") From FMTVAR
If mkstat=2
 [M]CAIVAL(INDIC) = VALEUR
 Affzo CAIVAL(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CAIVAL(zc) From W1FOC0
Onkey   2 Titled GBOUTS Call S_CAIVAL(zc) From W1FOC0
Gosub _AFF
End

Subprog C_CAIVAL(VALEUR)
Variable Char    VALEUR()
## Action AFMTCONT
Call CONTROLE(VALEUR,"M",[M]CAILIB,15,[M]CAIFOR) From FMTVAR
If mkstat : GERR = 1 : GZONE = "CAIVAL" : GZNUM = 55102 : Endif
If !mkstat
 ## Action ACONTACL
 Call CONTACL([M]CAIFOR,"M","","") From SUBACL
 If mkstat : GERR = 1 : GZONE = "CAIVAL" : GZNUM = 55102 : Endif
Endif
Gosub _AFF
End

Subprog S_CAIVAL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTSEL"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]CAILIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]CAIFOR
 PARMSK(5) = ""
 PARMSK(6) = ""
 PARMSK(7) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]CAIFOR = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFMTLIB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTLIB"
 PARMSK(1) = "M"
 PARMSK(2) = num$([M]CAILIB)
 PARMSK(3) = "15"
 PARMSK(4) = [M]CAIFOR
 PARMSK(5) = ""
 PARMSK(6) = ""
 Call S_LIS_CHAR(VALEUR,PARMSK,"","FMTVAR","") From GACTION
 [M]CAIFOR = PARMSK(4)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CAIVAL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFMTB1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFMTB1"
 PARMSK(1) = "M"
 PARMSK(2) = ""
 PARMSK(3) = num$([M]CAILIB)
 PARMSK(4) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFMTB1","FMTVAR","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CAILIB
Return

$ON_CAIFOR
Return

$ON_ADIFOR
Onevent CONTROL Call C_ADIFOR(zc) From W1FOC0
Onevent BEFORE_INPUT Call AS_ADIFOR(zc) From W1FOC0
Onevent AFTER_CHANGE Gosub AMM_ADIFOR From W1FOC0
Return

Subprog AS_ADIFOR(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Onkey   2 Titled GBOUTS Call S_ADIFOR(zc) From W1FOC0
Onkey 144 Titled GBOUTP Call P_ADIFOR(zc) From W1FOC0
Gosub _AFF
End

Subprog C_ADIFOR(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ADIFOR" : GZNUM = 5548 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTNUM("ADV","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ADIFOR" : GZNUM = 5548 : Endif
Endif
Gosub _AFF
End

$AMM_ADIFOR
Call AM_ADIFOR(zc)
If !mkstat & GOBJET
 zoncou = "ADIFOR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ADIFOR(VALEUR)
Variable Decimal VALEUR
If !mkstat & evalue("dim("+clanam([M])+"ZADIFOR)")>indice
 [M]ADIFOR(indice) = VALEUR
 Affzo ZADIFOR(indice)
Endif
Gosub _AFF
End

Subprog S_ADIFOR(VALEUR)
Variable Decimal VALEUR
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ADV"
PARMSK(2) = ""
Call S_TAB_NUM(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog P_ADIFOR(VALEUR)
Variable Decimal VALEUR
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ADV",num$(VALEUR),PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZADIFOR
Onevent BEFORE_AREA Gosub AV_ZADIFOR From W1FOC0
Return

$AV_ZADIFOR
Call LECTEXTRA(zc,"ATABTAB","LNGDES",num$([M]ADIFOR(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_CTRFOR
Onevent BEFORE_INPUT Call AS_CTRFOR(zc) From W1FOC0
Onevent CONTROL Call C_CTRFOR(zc) From W1FOC0
Return

Subprog AS_CTRFOR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]CTRFOR(INDIC) = VALEUR
  Affzo CTRFOR(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_CTRFOR(zc) From W1FOC0
Onkey 130 Titled GBOUT2 Call B2_CTRFOR(zc) From W1FOC0
Onkey 131 Titled GBOUT3 Call B3_CTRFOR(zc) From W1FOC0
Onkey   2 Titled GBOUTS Call S_CTRFOR(zc) From W1FOC0
Gosub _AFF
End

Subprog C_CTRFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRCONT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AFRCONT"
 PARMSK(1) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTRFOR" : GZNUM = 4574 : Endif
Endif
Gosub _AFF
End

Subprog S_CTRFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELEMPLO
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELEMPLO"
 Call SAISIE_CHAR(VALEUR,PARMSK,"SELEMP","SELEMP","XWSELEMP") From GSAISIE
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CTRFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,GEMPTAB(1),GEMPTAB(2),GEMPTAB(3),GEMPTAB(4),GEMPTAB(5)) From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_CTRFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_CTRFOR(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = GEMPTAB(1)
 PARMSK(2) = GEMPTAB(2)
 PARMSK(3) = GEMPTAB(3)
 PARMSK(4) = GEMPTAB(4)
 PARMSK(5) = GEMPTAB(5)
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


