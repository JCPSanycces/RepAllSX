#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT CONSOLIDATION
##############################################################################################################
# GETTING BACK
# GET_CSLFLO     : returns the flow Consolidation for a ledger, a journal, a account, a sign
# GET_CSLBPR     : returns the partner Consolidation
#
#
# CONTROLLING
# CTL_CSLFLO     : Controls the flow Consiolidation
# CTL_CSLBPR     : Controls the partner Consolidation
#
# Private routines :
# _GET_CSLFLGLED
# _GET_CSLFLOFLGACC
# _GET_CSLBPRFLGACC
##############################################################################################################

#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)
#*
#####################################################################################################################
## GET_CSLFLO
#####################################################################################################################
#**
#* Returns the value of a flow Consolidation for a ledger, a journal, a account, a sign
#*
#* @param ACTX    Context
#* @param LED     Ledger
#* @param JOU     Journal
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param SIGN    Sign Account  (Debit = 1 & Credit = -1)
#* @param CSLFLG  Management of consolisation
#* @param CSLFLO  Flow of consolisation
#* @param ERRMES  Error message
#*!
Funprog GET_CSLFLO(ACTX,CPY,LED,JOU,COA,ACC,SIGN,CSLFLG,CSLFLO,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    CPY       : # Company
Value    Char    LED       : # Ledger
Value    Char    JOU       : # Journal
Value    Char    COA       : # Chart of Account
Value    Char    ACC       : # Account
Value    Integer SIGN      : # Sign
Variable Tinyint CSLFLG    : # Consolidation Ledger
Variable Char    CSLFLO    : # Consolidation Flow
Variable Char    ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:JOU]) : Local File JOURNAL  [JOU] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

# Control if a ledger is flagued "Consolidation"
[L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,LED,CSLFLG,ERRMES)
If [L]CSLFLG <> [V]CST_AYES : End [L]ASTATUS : Endif

# Controle if a account have a flow : "Mandatory" or "Optional"
[L]CSLFLG = func FINCSLLIB._GET_CSLFLOFLGACC(GACTX,COA,ACC)
If [L]CSLFLG <> [V]CST_AYES : End [L]ASTATUS : Endif

# Initialization of flow
If [L]CSLFLO<>"" : End [L]ASTATUS : Endif

#--- by journal
Call LEC_JOU(JOU) From CPTLEC
If !fstat : [L]CSLFLO = [F:JOU]CSLFLO : Endif
If [L]CSLFLO<>"" : End [L]ASTATUS : Endif

#--- by account
If SIGN = -1
 [L]CSLFLO = [F:GAC]FLOCDT
Else
 [L]CSLFLO = [F:GAC]FLODEB
Endif
If [L]CSLFLO<>"" : End [L]ASTATUS : Endif

#--- by parameter
Local Integer LPRCSL : # X3-104535
LPRCSL = func AFNC.ACTIV("PRCSL")
If LPRCSL = G_OUI
 [L]CSLFLO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY,CPY,"CSLFLODEF")
Endif : # X3-104535
If [L]CSLFLO<>"" : End [L]ASTATUS : Endif

End [L]ASTATUS

#####################################################################################################################
## CTL_CSLFLO
#####################################################################################################################
#**
#* Controls the flow Consiolidation
#*
#* @param ACTX    Context
#* @param LED     Ledger
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param CSLFLG  Management of consolisation
#* @param CSLFLO  Flow of consolisation
#* @param ERRMES  Error message
#*!
Funprog CTL_CSLFLO(ACTX,LED,COA,ACC,CSLFLG,CSLFLO,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    LED       : # Ledger
Value    Char    COA       : # Chart of Account
Value    Char    ACC       : # Account
Variable Tinyint CSLFLG    : # Consolidation Ledger
Value    Char    CSLFLO    : # Consolidation Flow
Variable Char    ERRMES()  : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

# Control if a ledger is linked "Consolidation"
[L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,LED,CSLFLG,ERRMES)
If [L]CSLFLG <> [V]CST_AYES : End [L]ASTATUS : Endif

# Control if a flow is mandatory
If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

If [L]CSLFLO=""
 Call LEC_GAC(ACC,COA) From CPTLEC
 If !fstat & [F:GAC]CSLFLGFLW=3
  ERRMES = func ASYRFNC.MES2(mess(127,106,1),COA,ACC)
  [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
 Endif
Endif

End [L]ASTATUS

#####################################################################################################################
## _GET_CSLFLGLED
#####################################################################################################################
#**
#*  Return the flag Consolidation of Ledger
#*
#* @private
#* @param ACTX      Context
#* @param LED       Ledger
#* @param LEDFLGCSL Consolisation Ledget
#* @param ERRMES    Error message
#*!
Funprog _GET_CSLFLGLED(ACTX,LED,LEDFLGCSL,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    LED        : # Ledger
Variable Tinyint LEDFLGCSL  : # Consolidation Ledger
Variable Char    ERRMES()   : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
Local Integer ILED
ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LED)
If ILED = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(208,111,1)-LED-mess(23,100,1)
Endif
[L]LEDFLGCSL =  fmet ACTX.ACACHE.LED.AGETVALNUM(LED,"LEDFLGCSL")
End [L]ASTATUS


#####################################################################################################################
## _GET_CSLFLOFLGACC
#####################################################################################################################
#**
#*  Return the flag Consolidation of Account
#*
#* @private
#* @param ACTX      Context
#* @param COA     Chart of accounts
#* @param ACC       Account
#*!
Funprog _GET_CSLFLOFLGACC(ACTX,COA,ACC)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COA        : # Chart of Account
Value    Char    ACC        : # Account

If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

Call LEC_GAC(ACC,COA) From CPTLEC
If fstat | [F:GAC]CSLFLGFLW<2
 End [V]CST_ANO
Else
 End [V]CST_AYES
Endif
End [V]CST_ANO

#**
#* Returns the consolidation partner
#*
#* @param ACTX      Context
#* @param MAIN_BPR  Main partner
#* @param CPY       Company
#* @param LED       Ledger
#* @param BPR       Partner
#* @param COA       Chart of accounts
#* @param ACC       Account
#* @param CSLFLG    Management of consolisation
#* @param CSLBPR    Partner of consolisation
#* @param ERRMES    Error message
#*!
Funprog GET_CSLBPR(ACTX, MAIN_BPR, CPY, LED, BPR, COA, ACC, CSLFLG, CSLBPR, ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    MAIN_BPR()
Value    Char    CPY()
Value    Char    LED()
Value    Char    BPR()
Value    Char    COA()
Value    Char    ACC()
Variable Tinyint CSLFLG
Variable Char    CSLBPR()
Variable Char    ERRMES()

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

  If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
  If adxtyp=33 | !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif

  # Control if a ledger is flagued "Consolidation"
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,LED,CSLFLG,ERRMES)
  If [L]CSLFLG <> [V]CST_AYES
    End [L]ASTATUS
  Endif

  # Controle if an account has a partner : "Mandatory" or "Optional"
  [L]CSLFLG = func FINCSLLIB._GET_CSLBPRFLGACC(GACTX,COA,ACC)
  If [L]CSLFLG <> [V]CST_AYES
    End [L]ASTATUS
  Endif

  Call LEC_GAC(ACC, COA) From CPTLEC

  # collective account
  If [F:GAC]SAC = [V]CST_AYES
    Call LEC_BPR(BPR) From CPTLEC
    If fstat = 0
      [L]CSLBPR = [F:BPR]CSLBPR
    Endif

  # normal account
  Else
    # Entry partner
    If [F:GAC]CSLBPRACE = [V]CST_AYES

      [L]CSLBPR = [L]MAIN_BPR

    Endif
  Endif

  If [L]CSLBPR = AVOID.ACHAR
    Local Integer LPRCSL : # X3-104535
    LPRCSL = func AFNC.ACTIV("PRCSL")
    If LPRCSL = G_OUI
      [L]CSLBPR = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVCPY, CPY, "CSLBPRDEF")
    Endif : # X3-104535
  Endif

End [L]ASTATUS

#**
#* Controls the consolidation partner (when mandatory)
#*
#* @param ACTX    Context
#* @param LED     Ledger
#* @param COA     Chart of accounts
#* @param ACC     Account
#* @param CSLFLG  Management of consolisation
#* @param CSLBPR  Consolidation Bpr
#* @param ERRMES  Error message
#*!
Funprog CTL_CSLBPR(ACTX, LED, COA, ACC, CSLFLG, CSLBPR, ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    LED()
Value    Char    COA()
Value    Char    ACC()
Variable Tinyint CSLFLG
Value    Char    CSLBPR()
Variable Char    ERRMES()

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

  # Control if a ledger is linked "Consolidation"
  [L]ASTATUS = func FINCSLLIB._GET_CSLFLGLED(GACTX,LED,CSLFLG,ERRMES)
  If [L]CSLFLG <> [V]CST_AYES : End [L]ASTATUS : Endif

  # Control if a bpr is mandatory
  If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

  If [L]CSLBPR=""
    Call LEC_GAC(ACC, COA) From CPTLEC
    If !fstat and [F:GAC]CSLFLGBPR  = 3 # mandatory
      ERRMES = func ASYRFNC.MES2(mess(128,106,1),COA,ACC)
      [L]ASTATUS = [V]CST_AERROR
      End [L]ASTATUS
    Endif
  Endif

End [L]ASTATUS

#**
#*  Return the flag Consolidation of Account's Partner
#*
#* @private
#* @param ACTX    Context
#* @param COA     Chart of accounts
#* @param ACC     Account
#*!
Funprog _GET_CSLBPRFLGACC(ACTX,COA,ACC)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char    COA        : # Chart of Account
Value    Char    ACC        : # Account

  If adxtyp=33 | !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

  Call LEC_GAC(ACC,COA) From CPTLEC
  If fstat | [F:GAC]CSLFLGBPR < 2
    End [V]CST_ANO
  Endif

End [V]CST_AYES

