#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'une Intervention                                                    Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################
###############################################################################################################
Subprog ITNINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14563, SZHTMLTITLE) From OBJDIV      #Intervention
  SZSUBPROG = "ITNINXML"
  SZAOBABREV = "ITN"
  Gosub XMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

#########################################################################################################################
Subprog ITNLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZFILTER = "" Then
    SZFILTER = "1=1"
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14607, SZHTMLTITLE) From OBJDIV      #Interventions
  SZSUBPROG = "ITNLISTXML"
  SZAOBABREV = "ITN"
  Gosub XMLPART2B From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOLISTXML
  Gosub XMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML
  Gosub SETITNEXCEPT From CRMEXCEPT
  #On extrait
  Filter [ITN] Where evalue(SZFILTER)
  For [ITN]
    SZCTAOB = "ITN"
    SZCTAOBNUM = [F:ITN]NUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLITN From CRMEXCEPT
  Next
  Filter [ITN]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML
  Gosub SETITNEXCEPT From CRMEXCEPT
  Gosub SETSREEXCEPT From CRMEXCEPT
  Gosub SETBPREXCEPT From CRMEXCEPT
  Gosub SETBPCEXCEPT From CRMEXCEPT
  Gosub SETBPAEXCEPT From CRMEXCEPT
  Gosub SETRRSEXCEPT From CRMEXCEPT
  Gosub SETHDTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [ITN] Where [F:ITN]NUM = SZRECNUM
  For [ITN]
    SZCTAOB = "ITN"
    SZCTAOBNUM = [F:ITN]NUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLITN From CRMEXCEPT
    #Réservations de ressources
    If IDISPLAYRRS Then
      Gosub ADDRRS
    Endif
    #Consommations
    If IDISPLAYHDT Then
      Gosub ADDHDT
    Endif
    #Demande de service
    If IDISPLAYSRE Then
      Gosub ADDSRE
    Endif
    #Tiers
    If IDISPLAYBPR Then
      Gosub ADDBPR
    Endif
    #Client
    If IDISPLAYBPC Then
      Gosub ADDBPC
    Endif
    #Adresse
    If IDISPLAYBPA Then
      Gosub ADDBPA
    Endif
  Next
  Filter [ITN]
Return

##########################################################
# Demande de service
##########################################################
$ADDSRE
  Filter [SRE] Where [F:SRE]SRENUM = [F:ITN]SRVDEMNUM
  For [SRE]
    SZCTAOB = "SRE"
    SZCTAOBNUM = [F:SRE]SRENUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "ITN"
    SZCTPARENTNUM = [F:ITN]NUM
    Gosub XMLSRE From CRMEXCEPT
  Next
  Filter [SRE]
Return

##########################################################
# Tiers
##########################################################
$ADDBPR
  Filter [BPR] Where [F:BPR]BPRNUM = [F:ITN]BPC
  For [BPR]
    SZCTAOB = "BPR"
    SZCTAOBNUM = [F:BPR]BPRNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "ITN"
    SZCTPARENTNUM = [F:ITN]NUM
    Gosub XMLBPR From CRMEXCEPT
  Next
  Filter [BPR]
Return

##########################################################
# Client
##########################################################
$ADDBPC
  Filter [BPC] Where [F:BPC]BPCNUM = [F:ITN]BPC
  For [BPC]
    SZCTAOB = "BPC"
    SZCTAOBNUM = [F:BPC]BPCNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "ITN"
    SZCTPARENTNUM = [F:ITN]NUM
    Gosub XMLBPC From CRMEXCEPT
  Next
  Filter [BPC]
Return

##########################################################
# Adresse
##########################################################
$ADDBPA
  Filter [BPA] Where [F:BPA]BPATYP = 1 and [F:BPA]BPANUM = [F:ITN]BPC
  For [BPA]
    SZCTAOB = "BPA"
    SZCTAOBNUM = num$([F:BPA]BPATYP) + [F:BPA]BPANUM + [F:BPA]BPAADD
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "ITN"
    SZCTPARENTNUM = [F:ITN]NUM
    Gosub XMLBPA From CRMEXCEPT
  Next
  Filter [BPA]
Return

##########################################################
# Réservations de ressources
##########################################################
$ADDRRS
  For ITERRRS = 0 To dim([F:ITN]RER) - 1
    If [F:ITN]RER(ITERRRS) <> "" Then
      Read [RRS]RRS0=[F:ITN]RER(ITERRRS)
      If !fstat Then
        SZCTAOB = "RRS"
        SZCTAOBNUM = [F:ITN]RER(ITERRRS)
        SZCTLEVEL = "1"
        SZCTPARENTAOB = "ITN"
        SZCTPARENTNUM = [F:ITN]NUM
        Gosub XMLRRS From CRMEXCEPT
      Endif
    Endif
  Next
Return

##########################################################
# Consommations
##########################################################
$ADDHDT
  Filter [HDT] Where [F:HDT]ITNNUM = SZRECNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT = [00/00/00] Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
  For [HDT] Hint Key HDT2
    SZCTAOB = "HDT"
    SZCTAOBNUM = [F:HDT]HDTNUM
    SZCTLEVEL = "1"
    SZCTPARENTAOB = "ITN"
    SZCTPARENTNUM = [F:ITN]NUM
    Gosub XMLHDT From CRMEXCEPT
  Next
  Filter [HDT]
  If IHDTDON Then
    Filter [HDT] Where [F:HDT]ITNNUM = SZRECNUM and [F:HDT]TPL <> 2 and [F:HDT]HDTDONDAT <> [00/00/00] Order By [F:HDT]HDTDONDAT Desc; [F:HDT]HDTDONHOU Desc
    For [HDT] Hint Key HDT2
      SZCTAOB = "HDT"
      SZCTAOBNUM = [F:HDT]HDTNUM
      SZCTLEVEL = "1"
      SZCTPARENTAOB = "ITN"
      SZCTPARENTNUM = [F:ITN]NUM
      Gosub XMLHDT From CRMEXCEPT
    Next
    Filter [HDT]
  Endif
Return
