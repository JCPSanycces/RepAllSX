#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DSICTL 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTCPY"
  Call CONTSOC([M]CPY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CPY","A",[M]CPY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
indice = 0
WDATE = [M]STRDAT
SAVACT = GACTION : GACTION = "ADATRELI"
Call INIDAT([M]STRDAT,[M]STRDATF) From ADATREL
GACTION = SAVACT
If mkstat=1 : Raz [M]STRDAT : Endif
If !mkstat
 If varmode([M]STRDAT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
  Endif
  If WDATE<>[M]STRDAT or IMPMOD
   SAVACT = GACTION : GACTION = "ADATRELM"
   Call MODIFDAT([M]STRDAT,[M]STRDATF) From ADATREL
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call AM_STRDAT([M]STRDAT) From FUNDSICTL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
indice = 0
WDATE = [M]ENDDAT
SAVACT = GACTION : GACTION = "ADATRELI"
Call INIDAT([M]ENDDAT,[M]ENDDATF) From ADATREL
GACTION = SAVACT
If mkstat=1 : Raz [M]ENDDAT : Endif
If !mkstat
 If varmode([M]ENDDAT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]ENDDAT,[M]STRDAT) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WDATE<>[M]ENDDAT or IMPMOD
    SAVACT = GACTION : GACTION = "ADATRELM"
    Call MODIFDAT([M]ENDDAT,[M]ENDDATF) From ADATREL
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone ALLTYP
mkstat = 0
zoncou = "ALLTYP"
indice = 0
IMPENT = [M]ALLTYP
If varinit([M]ALLTYP,indice)=0
 IMPENT = 2
 SAVACT = GACTION : GACTION = "STD"
 Call D_ALLTYP(IMPENT) From FUNDSICTL
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ALLTYP,indice)=0
  [M]ALLTYP(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "ALLTYP" : Gosub ACTION From =IMPTRT
   IMPENT = [M]ALLTYP(indice)
  Endif
  SAVACT = GACTION : GACTION = "STD"
  Call C_ALLTYP(IMPENT) From FUNDSICTL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLTYP" : GZNUM = 10412 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ALLTYP = IMPENT

## Zone DOCTYP
mkstat = 0
zoncou = "DOCTYP"
indice = 0
IMPENT = [M]DOCTYP
If varinit([M]DOCTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]DOCTYP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_DOCTYP(IMPENT) From FUNDSICTL
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]DOCTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DOCTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DOCTYP(indice)
 Endif
Endif
[M]DOCTYP = IMPENT

## Zone ALLBP
mkstat = 0
zoncou = "ALLBP"
indice = 0
IMPENT = [M]ALLBP
If varinit([M]ALLBP,indice)=0
 IMPENT = 2
 SAVACT = GACTION : GACTION = "STD"
 Call D_ALLBP(IMPENT) From FUNDSICTL
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]ALLBP,indice)=0
  [M]ALLBP(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "ALLBP" : Gosub ACTION From =IMPTRT
   IMPENT = [M]ALLBP(indice)
  Endif
  SAVACT = GACTION : GACTION = "STD"
  Call C_ALLBP(IMPENT) From FUNDSICTL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLBP" : GZNUM = 8376 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ALLBP = IMPENT

## Zone BPRNUM
mkstat = 0
zoncou = "BPRNUM"
indice = 0
If varmode([M]BPRNUM,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_BPRNUM([M]BPRNUM) From FUNDSICTL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]BPRNUM : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  Call CONTROLE("BPR","!",[M]BPRNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "BPRNUM" : GZNUM = 19569 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DSICTL"
Return

