#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ODPAYANU 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ODPNUMDEB
mkstat = 0
zoncou = "ODPNUMDEB"
indice = 0
If varmode([M]ODPNUMDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ODPNUMDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ODPNUMFIN
mkstat = 0
zoncou = "ODPNUMFIN"
indice = 0
If varmode([M]ODPNUMFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ODPNUMFIN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ODPNUMFIN([M]ODPNUMFIN) From ODPAYANU
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ODPNUMFIN" : GZNUM = 1001181 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone MATDEB
mkstat = 0
zoncou = "MATDEB"
indice = 0
If varmode([M]MATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MATDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone MATFIN
mkstat = 0
zoncou = "MATFIN"
indice = 0
If varmode([M]MATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MATFIN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_MATFIN([M]MATFIN) From ODPAYANU
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MATFIN" : GZNUM = 45743 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DATDEB
mkstat = 0
zoncou = "DATDEB"
indice = 0
If varmode([M]DATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATFIN
mkstat = 0
zoncou = "DATFIN"
indice = 0
If varmode([M]DATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DATFIN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_DATFIN([M]DATFIN) From ODPAYANU
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DATFIN" : GZNUM = 44783 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone TRCFLG
mkstat = 0
zoncou = "TRCFLG"
indice = 0
IMPENT = [M]TRCFLG
If varinit([M]TRCFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]TRCFLG,indice)=0
 [M]TRCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRCFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TRCFLG(indice)
 Endif
Endif
[M]TRCFLG = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ODPAYANU"
Return

