#<AdxTL>@(#)5.0.0.0 $Revision$
###########################################################
## Action CALALH
###########################################################
Local Char PARAM(10)(1..3) , VALEUR(250)
PARAM(1) = "ZZCCL123s"
PARAM(2) = "1"
PARAM(3) = "9"
If GPRODUIT=1 : [V]GCHGENV=2 : Endif
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBALQ9","ALQ9",4,"SPEALQ") From GTRAITE
End

#######################################################################
$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "OUVRE_BATCH" : Gosub DECLARE
 When "CONTROLE"    : Gosub CONTROLE
Endcase
Return

#######################################################################
$INIT
Gosub DECLARE
Local Mask ALQ9 [DIA]

[L]SAVFONC = GFONCTION
LISTE = PARAM(1)
CHGLIS   = val(PARAM(2))
AFF     = val(PARAM(3))

If !GSERVEUR & LISTE="" & !CHGLIS
 FIN = 1 : Return
Elsif LISTE<>""
 Gosub CONTROLES From SUBALH2
 If GERR
  If !CHGLIS
   FIN = 1 :  Return
  Else
   LISTE = ""
  Endif
 Endif
Endif

If BCRIT="" : # Pour calculer directement sans saisir les paramètres
 If LISTE<>""
  Gosub CHARGE
  [M:DIA]COD = LISTE
 Else
  FIN = 1 : Return
 Endif
Endif
TMP=0
Return

$SET_VARIA
Local Char    TRAITEMENT(GLONADC), SAV_UTIL(15)
If PARAM(1) <> ""
 LISTE  = PARAM(1)
 CHGLIS = val(PARAM(2))
 AFF    = val(PARAM(3))
Elsif [M:DIA]COD <> ""
 LISTE    = [M:DIA]COD
Endif
Gosub PFIX From SUBALQ
TRAITEMENT = PREFPRG+LISTE
Gosub SET_UTIL
Return

$SORTIE
If !FIN
 GOK = 1
Else
 GOK = 0
Endif
Return

$CHARGE
Local Integer L , ER , OKDEF

If dim([M:LST]USR)>0 : UTIL=[M:LST]USR
Else  UTIL=""
Endif
Gosub SET_ENV From VISUSQL
If UTIL<>""
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL
 Else
  Read [ALR]ALR0 = LISTE;UTIL
 Endif
 If fstat
  UTIL = ""
 Endif
Endif
Gosub PFIX From SUBALQ
If dim([V]GCHGENV)>0 : [V]GCHGENV=0 : Endif
TRAITEMENT = PREFPRG+LISTE
Gosub PARAM From =TRAITEMENT

OKDEF = 0
If GACTION<>"CALALQ" & (dim(GFCTIMP)<1 or GFCTIMP="") or UTIL=""
 OKDEF = (dim(PARDEF)>0 & sum(PARDEF)<>"")
Endif

Raz [M:DIA]
For I=1 To dim(PARTIT)
 If PARTIT(I)<>""
  NOL = [M:DIA]NBLIG
  [M:DIA]INTIT(NOL)  = PARTIT(I)
  [M:DIA]NUMPAR(NOL) = I
  [M:DIA]CODTYP(NOL) = PARTYP(I)
  [M:DIA]NOLIB(NOL)  = PARLIB(I)
  Read [ATY]CODTYP   = PARTYP(I)
  If fstat
   [M:DIA]CODTYP(NOL) = "A"
   Read [ATY]CODTYP = "A"
  Endif
  If find([F:ATY]CODTYP,"ATX","AXX","AX1","AX2","AX3")
   [M:DIA]CODTYP(NOL) = "A"
   [M:DIA]TYP(NOL)    = 7
   If [M:ATY]LNGTYP<>0
    [M:DIA]LONG(NOL)  = [F:ATY]LNGTYP
   Else
    [M:DIA]LONG(NOL)  = 30
   Endif
  Else
   [M:DIA]TYP(NOL)    = [F:ATY]TYPTYP
   If [F:ATY]LNGTYP<>0
    [M:DIA]LONG(NOL) = [F:ATY]LNGTYP
   Endif
   Case [F:ATY]TYPTYP
    When 1
     [M:DIA]FMT(NOL) = "Nz+:3#"
     If [M:DIA]LONG(NOL)=0 : [M:DIA]LONG(NOL) = 3 : Endif
    When 2
     [M:DIA]FMT(NOL) = "Nz:5#"
     If [M:DIA]LONG(NOL)=0 : [M:DIA]LONG(NOL) = 5 : Endif
    When 3
     [M:DIA]FMT(NOL) = "Nz:8#"
     If [M:DIA]LONG(NOL)=0 : [M:DIA]LONG(NOL) = 8 : Endif
    When 7
     If [F:ATY]FORTYP<>""
      [M:DIA]FMT(NOL) = "K:"+[F:ATY]FORTYP
     Else
      [M:DIA]FMT(NOL) = "K:20X"
     Endif
     If [M:DIA]LONG(NOL)=0 : [M:DIA]LONG(NOL) = 30 : Endif
    When 8
     [M:DIA]FMT(NOL) = "DzZ:"+GFMDAT
    When Default
     [M:DIA]FMT(NOL) = "Nz:15F"
   Endcase
  Endif
  If OKDEF & PARDEF(I)<>""
   ER = 0
   Onerrgo ERR
   If find([F:ATY]TYPTYP,1,2,3,4,5,6)>0
    [M:DIA]DEB(NOL) = PARDEF(I)
   Else
    [M:DIA]DEB(NOL) = evalue(ctrans(PARDEF(I),'¨','"'))
   Endif
   Onerrgo
   If !ER
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
   Endif
  Endif

  If UTIL<>"" & !OKDEF
   If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
    Read [ALR]ALR0 = LISTE;LFCY;LDEP;UTIL;999;1;NOL+1
   Else
    Read [ALR]ALR0 = LISTE;UTIL;999;1;NOL+1
   Endif
   If !fstat
    [M:DIA]DEB(NOL) = [F:ALR]VLR
    Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
   Endif
  Endif

  If dim(GFCTIMP)>0 & GFCTIMP<>""
   If [V]GTYPIMP = 3
    Read[ARV]ARV0 = [V]GFCTIMP;[V]GTYPIMP;PARAM(1);num$(100+I)
    If !fstat & [F:ARV]VALDEF1 <> ""
     Call EVALE([F:ARV]VALDEF1,[M:DIA]DEB(NOL),[M:DIA]TYP(NOL)) From AIMP1
     Call CHARGE([M:DIA]DEB(NOL),[M:DIA]CODTYP(NOL),[M:DIA]NOLIB(NOL),[M:DIA]LONG(NOL),[M:DIA]VALDEB(NOL)) From FMTVAR
    Endif
   Endif
  Endif
  [M:DIA]NBLIG += 1
 Endif
Next I
Return

$ERR
ER = errn
Resume

$DEBUT
Local Char LISTE(GLONALH)
Local Integer NOL
If PARAM(1)<>""
 Gosub SET_VARIA
 [M]COD = PARAM(1)
 LISTE = [M]COD
 Raz [M:DIA]
 Gosub CHARGE
 [M:DIA]COD = LISTE
 If [M:DIA]COD <> "" : Grizo [M:DIA]COD : Endif
 Affzo
Endif
Return

$SET_UTIL
Local Char UTIL(15), UTIL0(15)
If [F:ALH]ALLUSR=2 | UTIL0="" : UTIL=GUSER
Else                          : UTIL=UTIL0
Endif

GPOINT = "SET_UTIL" : Gosub ENTREE From EXEFNC
Return

$DECLARE
Local Integer I , J , K , L , ER , OKTRT , PAGE , MAXLIG , NBLIG , NBPAG , CHGTLIS, AFF, EXEC,  NOL
Local Integer VERROU,CHGLIS,OKTRT
Local Char    FILTRE(250), LISTE(GLONALH), TITLIS(80)
Local Char    SAVFONC(GLONAFC), SAV_PARAM(15)(1..3), SAV_DIV0(30)
Local Char    TRAITEMENT(GLONADC) , UTIL(15), UTIL0(15), SAV_UTIL(15)
Local Shortint STAT
If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
 Local Char SAV_FCY(GLONFCY), SAV_DEP(GLONDEP)
Endif

If clalev([F:ATY])=0  : Local File ATYPE    [ATY]  : Endif
If clalev([F:AGB])=0  : Local File AGLOBVAR [AGB]  : Endif
If clalev([F:ALH])=0  : Local File ALISTEH  [ALH]  : Endif
If clalev([F:ACC])=0  : Local File ACCES    [ACC]  : Endif
If clalev([F:ARV])=0  : Local File AREPORTV [ARV] : Endif

Gosub ALISTER From SUBALH2
Return

$EXEC
Gosub SET_VARIA
Gosub SET_ENV From VISUSQL
Call EXISTE_ADX("","",TRAITEMENT,OKTRT) From ORDSYS
If LISTE ="" | !OKTRT : FIN=1 : Return : Endif
Gosub VERROU
If !VERROU  :  Return : Endif
Call TEMPON("O") From GESECRAN
Call DEBTRANS From GLOCK

GPOINT = "AV_EXEREQ" : Gosub ENTREE From EXEFNC

Gosub TR1

GPOINT = "AP_EXEREQ" : Gosub ENTREE From EXEFNC

Call TEMPOFF From GESECRAN
Gosub DEVERROU
Return

$TR1
GOK = 1
Trbegin [ALR]
 FILTRE = "COD='"+LISTE+"'"
 GCLE=LISTE
 If dim([F:ALH]TYPENV)>0 & GPRODUIT=1 : ## GEODE
  FILTRE-= "& FCY='"+LFCY+"' & DEP='"+LDEP+"'"
  GCLE-=LFCY-LDEP
 Endif
 If [F:ALH]ALLUSR<>2
  FILTRE-= "& USR='"+UTIL+"'"
  GCLE-=UTIL
 Endif
 Delete [ALR] Where evalue(FILTRE)
 If fstat=1
  GOK = 1 : GLOCK = "$ALISTER"-GCLE : Goto ROLL_TR1
 Endif
 Gosub LECTURE From =TRAITEMENT
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK or ER : GOK=0 : Goto AB_TR1
 Endif
 Gosub ENVALR From VISUSQL
 [F:ALR]LIG    = 0
 [F:ALR]COL    = 0
 [F:ALR]VLR    = num$(time-TIM)
 [F:ALR]NUM    = K
 Write [ALR]
 If fstat
  GOK = 0 : Call FSTA("ALR") From GLOCK : Goto AB_TR1
 Endif
 [F:ALR]NIV    = 999
 [F:ALR]LIG    = 1
 [F:ALR]NUM    = 0
 For K=1 To [M:DIA]NBLIG
  [F:ALR]COL    = K
  [F:ALR]VLR    = [M:DIA]DEB(K-1)
  Write [ALR]
  If fstat
   GOK = 0 : Call FSTA("ALR") From GLOCK : Break
  Endif
 Next K
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Gosub DEVERROU
If DEPLIG
 Call ECR_TRACE(mess(54,126,1)-"("+num$([F:ALH]MAXLIG)+")",0) From GESECRAN
 # Nb de lignes maximum dépassé
Endif
If DEPTIM
 Call ECR_TRACE(mess(53,126,1)-"("+num$([F:ALH]MAXTIM)+")",0) From GESECRAN
 # Temps maximum dépassé
Endif
Return

$VERROU
VERROU = 1
If [F:ALH]ALLUSR=2
 Lock = "ALQ9"-LISTE-GDIV(0)
 If fstat
  Call ECR_TRACE(mess(10,100,1),1) From GESECRAN : # Modif en cours
  VERROU=0 : FIN =1 : Return
 Endif
 Call QUILOCKE("ALH"-LISTE-"",I,GCLE) From SUBALH9
 If I
  Gosub DEVERROU
  # Fiche utilisée par un autre utilisateur
  Call ECR_TRACE(mess(98,126,1)-string$(GCLE<>"","("+GCLE+")"),1) From GESECRAN
  VERROU=0 : FIN = 1 : Return
 Endif
Endif
Return

$DEVERROU
If VERROU
 Unlock ="ALQ9"-LISTE-GDIV(0)
 VERROU = 0
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$CONTROLE
If BCRIT<>"" & GSTATUT<>GSTAOK : FIN=1 : Return : Endif
LISTE = [M:DIA]COD
If GSERVEUR : Call ECR_TRACE(mess(204,126,1)-LISTE,0) From GESECRAN : Endif
If LISTE=""
 FIN = 1
 Return
Elsif LISTE <> ""
 Gosub CONTROLES From SUBALH2
 If GERR
  FIN = 1
  Return
 Endif
Endif
Return

######################################################################################
Subprog C_COD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" & VALEUR <> [M:DIA]COD
 Local Char LISTE(10)
 Local Char TRAITEMENT(80)
 Local Integer OKTRT
 LISTE = VALEUR
 Gosub PFIX From SUBALQ
 TRAITEMENT = PREFPRG+LISTE
 Call EXISTE_ADX("","",TRAITEMENT,OKTRT) From ORDSYS
 If !OKTRT :
  GMESSAGE = TRAITEMENT-"TRT INEXISTANT"
  mkstat = 1 : FIN =1 : End
 Endif
 Gosub CHARGE
 Affzo 20
Endif
End
