#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier CMARKETING
Call OBJET ("CMG",GBIDC1,GBIDC2) From GOBJET
End

##########################################################################################################
$ACTION
  Case ACTION
    When "BOITE"          : Gosub BOITE       # FGR 31/07/2014 : X3SUIVI101463
    When "OUVRE_BOITE"    : Gosub OUVRE_BOITE
    When "OUVRE"          : Gosub OUVRE
    When "FERME"          : Gosub FERME
    When "RAZCRE"         : Gosub RAZCRE
    When "VERIF_CRE"      : Gosub VERIF_CRE
    When "VERIF_MOD"      : Gosub VERIF_MOD
    When "CREATION"       : Gosub CREATION
    When "MODIF"          : Gosub MODIF
    When "VERF_ANU"       : Gosub VERF_ANU
    When "AV_ANNULE"      : Gosub AV_ANNULE
    When "ANNULE"         : Gosub ANNULE
    When "AP_ANNULE"      : Gosub AP_ANNULE
    When "APRES_CRE"      : Gosub APRES_CRE
    When "APRES_MOD"      : Gosub APRES_MOD
    When "LIENS"          : Gosub LIENS
    When "INICRE"         : Gosub INICRE
    When "SETBOUT"        : Gosub SETBOUT
    When "FILGAUCHE"      : Gosub FILGAUCHE
    When "AVANTBOUT"      : Gosub AVANTBOUT
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCCMGCPT(GLONANM)  # Code compteur pour campagne marketing.
Global Char GSZTYPOPG(GLONAOB)
Global Char GSZDELCMGNUM(GLONCMG)

Local Char SZBOXCMG(10)
Local Char SZBOXCM2(10)
Local Char SZSITE(GLONFCY)     # FGR 21/05/2008 : X3SUIVI45391 : Longueur du site par GLONFCY

  GSZDELCMGNUM = ""
  GSZTYPOPG = ""
  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  If !clalev([F:CMG]) : Local File CMARKETING [CMG] : Endif
  If !clalev([F:OMM]) : Local File MAILING [OMM] : Endif
  If !clalev([F:OMP]) : Local File PHONING [OMP] : Endif
  If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
  If !clalev([F:OMT]) : Local File TRADESHOW [OMT] : Endif
  If !clalev([F:OMN]) : Local File MEDIA [OMN] : Endif
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(4)
  #  GCCMGCPT = [F:TCA]CODNUM(4)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$BOITE
Local Char STRTSUB(GLONADC)

  # FGR 31/07/2014 : X3SUIVI101463
  STRTSUB = "SUBCMG"
  Gosub BOITE_GOBJET From CRMUTIL150
Return

##########################################################################################################
$REDEFINE_LINK
  If !clalev([F:C_MG]) Then
    # FGR 11/02/2015 : X3SUIVI106120 : Si [C_MG] pas ouvert c'est que les browsers ont été redéfinis en SPE/SPV.
    # On part, c'est à ce niveau qu'on doit faire ce travail.
    Return
  Endif
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [CMG] With [C_MG]CMG0=[F:CMG]NUM,
&                 [AFF]AFF0~=[F:CMG]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:CMG]FCY
&              As [CM2]
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "CMG" Then
    SZBOXCMG = "GAU_CHE"
  Else
    SZBOXCMG = "GAU_CHE"+num$(find("CMG",OBJLIS(1..8))) : #Campagnes marketing actives
  Endif
  If OBJLIS(0) = "CM2" Then
    SZBOXCM2 = "GAU_CHE"
  Else
    SZBOXCM2 = "GAU_CHE"+num$(find("CM2",OBJLIS(1..8))) : #Campagnes marketing clôturées
  Endif
Return

##########################################################################################################
$FERME
  Kill GSZTYPOPG
  Kill GCCMGCPT            # Code compteur pour campagne marketing.
  Kill GSZDELCMGNUM
Return

##########################################################################################################
$RAZCRE
  #Initialise le site par défaut
  Call SITECRMDEF ("ACT", [M:CMG0]FCY) From CRM_UTIL
  GFCY = [M:CMG0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #Initialise la devise par défaut
  [M:CMG1]CUR = GSYSCUR
  [M:CMG1]CUR1 = [M:CMG1]CUR
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCMGB
  [M:CMG0]PREFULOBJ = [M:CMG2]FULOBJ
  [M:CMG0]PREDES = [M:CMG2]DES
  [M:CMG0]PRECLO = 1
  Affzo [M:CMG0]1-99
  Affzo [M:CMG1]1-99
  Affzo [M:CMG2]1-99
Return

##########################################################################################################
$FILGAUCHE
  Default File [CMG]
  If currbox = SZBOXCMG Then
    #Campagnes marketing
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLO <> 2", "&") From GOBJSUB
  Elsif currbox = SZBOXCM2 Then
    #Campagnes marketing clôturées
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLO = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "CMG") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:CMG0]FCY, 13, 4, GSOCIETE, GCURLEG, GCCMGCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:CMG0]FCY, GCCMGCPT, date$, "", [M:CMG0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:CMG]NUM = [M:CMG0]NUM
      Affzo [M:CMG0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:CMG]TYPFULOBJ = "CMG"
  [F:CMG]NUMFULOBJ = [M:CMG0]NUM
  [M:CMG2]TYPFULOBJ = "CMG"
  [M:CMG2]NUMFULOBJ = [M:CMG0]NUM
  [F:CMG]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERIF_CRE_MOD
Local Integer IOKREP

  #Contrôle de la présence de dates
  If [M:CMG1]DATSTR = [00/00/00] Then
    GMESSAGE = mess(108,177,1) #Une date de début et de fin de la campagne doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la présence de dates
  If [M:CMG1]DATEND = [00/00/00] Then
    GMESSAGE = mess(108,177,1) #Une date de début et de fin de la campagne doivent être précisées.
    GERR = 2
    OK = 0
    Return
  Endif
  #Contrôle de la cohérence des dates
  If [M:CMG1]DATSTR > [M:CMG1]DATEND Then
    GMESSAGE = mess(109,177,1) #La date de fin de la campagne ne peut pas être inférieure à la date de début.
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:CMG1]CUR = "" Then
    GMESSAGE = mess(384,196,1) #Aucun code devise n'est renseigné. Création refusée.
    GERR = 2
    OK = 0
    Return
  Endif
  Read [TCU]TCU0=[M:CMG1]CUR
  If fstat Then
    GMESSAGE = mess(84,116,1) #Devise incorrecte.
    GERR = 2
    OK = 0
    Return
  Else
    If [F:TCU]EURFLG = 2 Then
      If [F:TCU]CURENDDAT <> [00/00/00] Then
        If [F:TCU]CURENDDAT < date$ Then
          GMESSAGE = mess(84,116,1) #Devise incorrecte.
          GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse Objet de l'action
  #  If [M:CMG2]FULOBJ = "" Then
  #    [M:CMG2]DES = ""
  #  Else
  #    [M:CMG2]DES = left$([M:CMG2]FULOBJ,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  #LSE 17/10/2005 Cas cloture
  IOKREP = 0
  If [M:CMG0]CLO = 2 Then
    If [M:CMG0]PRECLO <> 2 Then
      #Confirmez-vous la clôture de la campagne marketing ?
      Call OUINON(mess(206,177,1), IOKREP) From GESECRAN
      If IOKREP <> 2 Then
        GERR = 2
        OK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
Local Integer INUMMES
Local Integer ICHAPTER
Local Integer IBRETOUR

  INUMMES = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Traitement de la cloture
  If [M:CMG0]CLO = 2 Then
    If [M:CMG0]PRECLO <> 2 Then
      Call CLOOPGCALL ([M:CMG0]NUM, INUMMES,ICHAPTER,IBRETOUR) From SUBCMGB
      If IBRETOUR = 0 Then
        GMESSAGE = mess(INUMMES,ICHAPTER,1)
        GERR = 2
        GOK = 0
        Return
      Endif
    Endif
  Endif
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCMGB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("CMG",1) From SUBPS2
Return

##########################################################################################################
$MODIF
Local Integer INUMMES
Local Integer ICHAPTER
Local Integer IBRETOUR

  INUMMES = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Traitement de la cloture
  If [M:CMG0]CLO = 2 Then
    If [M:CMG0]PRECLO <> 2 Then
      Call CLOOPGCALL ([M:CMG0]NUM, INUMMES, ICHAPTER, IBRETOUR) From SUBCMGB
      If IBRETOUR = 0 Then
        GMESSAGE = mess(INUMMES,ICHAPTER,1)
        GERR = 2
        GOK = 0
        Return
      Endif
    Endif
  Endif
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCMGB
  If GOK < 1 Then
     Return
  Endif
  # Maj des statistiques
  Call VALSTA("CMG",-1) From SUBPS2
  Call VALSTA("CMG",1) From SUBPS2
Return

##########################################################################################################
$VERF_ANU
Local Integer IMESSREP

  IMESSREP = 0
  #La suppression d'une campagne marketing interdit toute analyse ultérieure de ses retours. Confirmez-vous sa suppression ?
  Call OUINON(mess(702,182,1), IMESSREP) From GESECRAN
  If IMESSREP = 2 Then
    #Toutes les opérations marketing associées à cette campagne seront supprimés. Confirmez-vous la suppression ?
    Call OUINON(mess(703,182,1), IMESSREP) From GESECRAN
    If IMESSREP = 2 Then
      #Tous les historiques relatifs au différentes opérations seront supprimés. Confirmez-vous la suppression ?
      Call OUINON(mess(704,182,1), IMESSREP) From GESECRAN
      If IMESSREP <> 2 Then
        #La suppression de la campagne marketing est abandonnée.
        GMESSAGE = mess(701,182,1)
        GERR = 2
        OK = 0
      Endif
    Else
      #La suppression de la campagne marketing est abandonnée.
      GMESSAGE = mess(701,182,1)
      GERR = 2
      OK = 0
    Endif
  Else
    #La suppression de la campagne marketing est abandonnée.
    GMESSAGE = mess(701,182,1)
    GERR = 2
    OK = 0
  Endif
  If OK = 0 Then
    Return
  Endif
  [M:CMG0]CLLDELFLG = 0
  Filter [OMP] Where [F:OMP]CMGNUM = [M:CMG0]NUM
  For [OMP]OMP1
    #Souhaitez-vous supprimer les appels restant à effectuer pour les opérations associées à cette campagne ?
    Call OUINON(mess(917,182,1), IMESSREP) From GESECRAN
    If IMESSREP = 2 Then
      [M:CMG0]CLLDELFLG = 1
      GSZDELCMGNUM = [M:CMG0]NUM
    Else
      [M:CMG0]CLLDELFLG = 0
    Endif
    Break
  Next
  Filter [OMP]
Return

##########################################################################################################
$AV_ANNULE
Local Char GSZOPGNUM(GLONVCR)
Local Integer IDELTODOCALL

  IDELTODOCALL = 0
  Call TEMPON("A") From GESECRAN
  Filter [OMM] Where [F:OMM]CMGNUM = [M:CMG0]NUM
  For [OMM]OMM1
    GSZOPGNUM = [F:OMM]OMMNUM
    Gosub ANNULEOMM From SUBOMM
    If GOK = 0 Then
      Break
    Endif
  Next
  Filter [OMM]
  If GOK = 0 Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  Delete [OMM] Where [F:OMM]CMGNUM = [M:CMG0]NUM
  If fstat Then
    #Erreur lors de la suppression des publipostages associés à la campagne marketing. Transaction abandonnée.
    GMESSAGE = mess(918,182,1)
    GERR = 1
    Call FSTA("OMM") From GLOCK
    GOK = 0
    Return
  Endif
  If [M:CMG0]CLLDELFLG Then
    IDELTODOCALL = 1
  Endif
  Filter [OMP] Where [F:OMP]CMGNUM = [M:CMG0]NUM
  For [OMP]OMP1
    GSZOPGNUM = [F:OMP]OMPNUM
    Gosub ANNULEOMP From SUBOMP
    If GOK = 0 Then
      Break
    Endif
  Next
  Filter [OMP]
  If GOK = 0 Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  If IDELTODOCALL = 0 Then
    Delete [OMP] Where [F:OMP]CMGNUM = [M:CMG0]NUM
    If fstat Then
      #Erreur lors de la suppression des campagnes d'appels associées à la campagne marketing. Transaction abandonnée.
      GMESSAGE = mess(918,182,1)
      GERR = 1
      Call FSTA("OMP") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
  IDELTODOCALL = 0
  Filter [OMT] Where [F:OMT]CMGNUM = [M:CMG0]NUM
  For [OMT]OMT1
    GSZOPGNUM = [F:OMT]OMTNUM
    Gosub ANNULEOMT From SUBOMT
    If GOK = 0 Then
      Break
    Endif
  Next
  Filter [OMT]
  If GOK = 0 Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  Delete [OMT] Where [F:OMT]CMGNUM = [M:CMG0]NUM
  If fstat Then
    #Erreur lors de la suppression des salons associés à la campagne marketing. Transaction abandonnée.
    GMESSAGE = mess(920,182,1)
    GERR = 1
    Call FSTA("OMT") From GLOCK
    GOK = 0
    Return
  Endif
  Filter [OMN] Where [F:OMN]CMGNUM = [M:CMG0]NUM
  For [OMN]OMN1
    GSZOPGNUM = [F:OMN]OMNNUM
    Gosub ANNULEOMN From SUBOMN
    If GOK = 0 Then
      Break
    Endif
  Next
  Filter [OMN]
  If GOK = 0 Then
    Call TEMPOFF From GESECRAN
    Return
  Endif
  Delete [OMN] Where [F:OMN]CMGNUM = [M:CMG0]NUM
  If fstat Then
    #Erreur lors de la suppression des campagnes presse associés à la campagne marketing. Transaction abandonnée.
    GMESSAGE = mess(921,182,1)
    GERR = 1
    Call FSTA("OMN") From GLOCK
    GOK = 0
    Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB From SUBCMGB
  If GOK < 1 Then
    Return
  Endif
  Call TEMPOFF From GESECRAN
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("CMG",-1) From SUBPS2
Return

##########################################################################################################
$AP_ANNULE
Local Char SZCLE(GLONVCR)
Local Integer ICUT
Local Integer ICLECOUNT
Local Integer INTR
Local Integer IPERF

  If [M:CMG0]CLLDELFLG Then
    Call TEMPON("A") From GESECRAN
    #Suppression des appels générés par la campagne d'appels et restant à effectuer
    Filter [OMP] Where [F:OMP]CMGNUM = GSZDELCMGNUM
    For [OMP]OMP1
      SZCLE = ""
      ICUT = 2500
      ICLECOUNT = ICUT
      IPERF = 0
      INTR = 0
      While ICLECOUNT >= ICUT
        ICLECOUNT = 0
        Filter [CLL] Where [F:CLL]CLLOPGNUM = [F:OMP]OMPNUM and [F:CLL]CLLDON <> 2 and [F:CLL]CLLCMGFLG > 0 and [F:CLL]CLLNUM > SZCLE
        For [CLL]CLL0
          SZCLE = [F:CLL]CLLNUM
          If IPERF = 0 Then
            Trbegin [HD5], [HD4], [CTT]
            INTR = 1
          Endif
          Delete [HD4] Where [F:HD4]NUM = [F:CLL]CLLNUM and [F:HD4]TYP = "CLLRPO"
          If fstat Then
            #Erreur lors de la suppression des appels restant à effectuer
            GMESSAGE = mess(916,182,1)
            GERR = 1
            Rollback
            INTR = 0
            Break
          Endif
          Delete [HD5] Where [F:HD5]NUM = [F:CLL]CLLNUM and [F:HD5]TYP = "CLLOBJ"
          If fstat Then
            #Erreur lors de la suppression des appels restant à effectuer
            GMESSAGE = mess(916,182,1)
            GERR = 1
            Rollback
            INTR = 0
            Break
          Endif
          Delete [CTT] Where [F:CTT]CLLNUM = [F:CLL]CLLNUM
          If fstat Then
            #Erreur lors de la suppression des appels restant à effectuer
            GMESSAGE = mess(916,182,1)
            GERR = 1
            Rollback
            INTR = 0
            Break
          Endif
          If IPERF >= 478 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
          ICLECOUNT += 1
          If ICLECOUNT >= ICUT Then
            Break
          Endif
        Next
        Filter [CLL]
        If GERR Then
          Break
        Endif
      Wend
      If GERR Then
        Break
      Endif
      Delete [CLL] Where [F:CLL]CLLOPGNUM = [F:OMP]OMPNUM
      If fstat Then
        #Erreur lors de la suppression des appels restant à effectuer.
        GMESSAGE = mess(916,182,1)
        GERR = 1
        Rollback
        Break
      Endif
      If INTR Then
        If !GERR Then
          Commit
        Endif
      Endif
      If GERR Then
        Break
      Endif
    Next
    Filter [OMP]
    Call TEMPOFF From GESECRAN
  Endif
Return

##########################################################################################################
$APRES_CRE
  [M:CMG1]CREDAT = [F:CMG]CREDAT
  [M:CMG1]CREHOU = [F:CMG]CREHOU
  [M:CMG1]CREUSR = [F:CMG]CREUSR
  If [M:CMG1]CREUSR = "" Then
    [M:CMG1]FULNAMUSR = ""
  Else
    Read [AUS]CODUSR=[M:CMG1]CREUSR
    [M:CMG1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCMGB
  [M:CMG0]PREFULOBJ = [M:CMG2]FULOBJ
  [M:CMG0]PREDES = [M:CMG2]DES
  [M:CMG0]PRECLO = [M:CMG0]CLO
  Affzo [M:CMG1]1-99
  Affzo [M:CMG2]1-99
Return

##########################################################################################################
$APRES_MOD
  #Si la description a été modifiée, il faut mettre à jour l'objet des appels
  Call MNGUPDCLOB("CMG", [M:CMG0]NUM) From SUBCMGB
  If !GERR Then
    #Si la synthèse a été modifiée, il faut mettre à jour la synthèse de chaque appel
    Call MNGUPDSYN("CMG", [M:CMG0]NUM) From SUBCMGB
  Endif
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCMGB
  [M:CMG0]PREFULOBJ = [M:CMG2]FULOBJ
  [M:CMG0]PREDES = [M:CMG2]DES
  [M:CMG0]PRECLO = [M:CMG0]CLO
  Affzo [M:CMG2]1-99
Return

##########################################################################################################
$LIENS
  GFCY = [M:CMG0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBCMGB
  #---------------------------------------------------#
  #  Affiche le nom du créateur en clair
  #---------------------------------------------------#
  If [M:CMG1]CREUSR = "" Then
    [M:CMG1]FULNAMUSR = ""
  Else
    Read [AUS]CODUSR=[M:CMG1]CREUSR
    [M:CMG1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  Affzo [M:CMG1]FULNAMUSR
  [M:CMG1]CUR1 = [M:CMG1]CUR
  #Chargement du tableau des opérations marketing associées et calcul du budget engagé.
  Call LOAD_OPG From SUBCMGB
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBCMGB
  [M:CMG0]PREFULOBJ = [M:CMG2]FULOBJ
  [M:CMG0]PREDES = [M:CMG2]DES
  [M:CMG0]PRECLO = [M:CMG0]CLO
  Affzo [M:CMG2]1-99
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    If [M:CMG0]NUM <> "" Then
      If [M:CMG0]CLO <> 2 Then
        CHMEN += "GINO"           # FGR 18/12/2013 : X3SUIVI92373 : Publipostage toujours accessible
      Endif
    Endif
  Endif
  #
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  #Retours marketing
  If REP <> "" Then
    Call VIREBOUT(CHAINE,"12") From GOBJET
  Else
    If [M:CMG0]NUM = "" Then
      Call VIREBOUT(CHAINE,"12") From GOBJET
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  If BOUT = "G" or BOUT = "I" or BOUT = "N" or BOUT = "O" Then
    If !VERROU Then
      #Modification en cours sur un autre poste
      GMESSAGE = mess(10,100,1)
      GERR = 1
      OK = 0
    Endif
  Endif
Return

##########################################################################################################
Subprog AM_DATSTR(VALEUR)
Variable Date    VALEUR

  If [M:CMG1]DATEND = [00/00/00] Then
    [M:CMG1]DATEND = VALEUR
  Endif
End

##########################################################################################################
Subprog AS_NBLIG

  If nolign-1 >= dim([M:CMG1]OPEMKGNUM)-1 Then
    End
  Endif
  If nolign > 0 Then
    If [M:CMG1]OPEMKGNUM(nolign-1) <> "" Then
      Case [M:CMG1]OPEMKGTYP(nolign-1)
        When 1
          GSZTYPOPG = "OMM"
        When 2
          GSZTYPOPG = "OMP"
        When 3
          GSZTYPOPG = "OMT"
        When 4
          GSZTYPOPG = "OMN"
        When Default
      Endcase
    Endif
  Endif
End

##########################################################################################################
Subprog C_NBLIG

  If nolign-1 >= dim([M:CMG1]OPEMKGNUM)-1 Then
    End
  Endif
  If nolign > 0 Then
    If [M:CMG1]OPEMKGNUM(nolign-1) <> "" Then
      Case [M:CMG1]OPEMKGTYP(nolign-1)
        When 1
          GSZTYPOPG = "OMM"
        When 2
          GSZTYPOPG = "OMP"
        When 3
          GSZTYPOPG = "OMT"
        When 4
          GSZTYPOPG = "OMN"
        When Default
      Endcase
    Endif
  Endif
End

##########################################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  [M:CMG1]CUR = VALEUR
  [M:CMG1]CUR1 = VALEUR
  Affzo [M:CMG1]CUR1
  Call LOAD_OPG From SUBCMGB
End

##########################################################################################################
Subprog IB_FULOBJ

  Raz GBOUT1
  If [M:CMG2]FULOBJ <> "" Then
    If len([M:CMG2]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:CMG2]FULOBJ, VALEUR, [M:CMG2]DES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:CMG2]FULOBJ = VALEUR
  Gosub DISPICON From SUBCMGB
  Affzo [M:CMG2]1-99
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

