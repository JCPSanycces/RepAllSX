#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "IMPORT"   : Gosub IMPORT
 When "IMP_ZONE" : Gosub IMP_ZONE
Endcase
Return

$IMPORT
If !clalev([F:DIE]) : Local File GDIE [DIE] : Endif
Read [DIE]DIE0=[F:CCE]DIE
If fstat
 Call ECR_TRACE([F:CCE]DIE-mess(80,103,1),1) From GESECRAN
 OK = 0 : Return
Endif
GBIDC1 = [F:CCE]DIE
[M:CCE0]DIE= GBIDC1
Return

$IMP_ZONE

Case IMPZON


 When "NBRPYR" : 
  mkstat = 1

 When "CCE" :
  
 Call INICCEFMT([F:CCE]DIE) From SETGLBDIE
 If [F:CCE]CCE<>vireblc(format$("K:"+GCCEFMT,[F:CCE]CCE),2)
   # Format incorrect
  Call ECR_TRACE(mess(99,141,1)-"K:"+GCCEFMT-[F:CCE]CCE,1) From GESECRAN
  mkstat=2
 Endif


Endcase
Return






