#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################
# Subprog SELTRO(ALT)  Sélection des alternatives gammes  AL 19/01/98
#######################################################
Local Integer ALT(100)
ALT=0
Call SELTRO(ALT)
End

Subprog SELTRO(ALT)
Variable Integer ALT(0..)
Local    Integer I

Local Integer RELIT
Onerrgo ERREUR From CONTROLE
If clalev([F:TRO])=0
 Local File TABROUALT [TRO]
Else
 RELIT=1
Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Mask SLRA [SLRA]
Local Mesbox Mask SLRA Titled mess(26,195,1) As [SLRA]
Boxact [SLRA] : Raz [M]

# Alternatives
nolign = 0
For [TRO]
    nolign += 1
    [M:SLRA] = [F:TRO]
    If nolign > dim([M:SLRA]ROUALT) - 1 : Break : Endif
Next
If nolign > 0
 Affzo [SLRA] 
Else
 Call MESSAGE(mess(99,100,1)) From GESECRAN
 mkstat=2 : End
Endif
If status<>7
 For nolign = 1 To [M:SLRA]BASPAG
     If [M:SLRA]COCHE(nolign-1) = "x"
        ALT(I) = [M:SLRA]ROUALT(nolign-1)
        I += 1
     Endif
 Next nolign
Else
 mkstat=2
Endif
End

# Etiquettes de zones
Subprog AS_BASPAG
# Bouton Séléction
GBOUT1 = mess(36,198,1)
End

Subprog B1_BASPAG
If [M:SLRA]COCHE(nolign-1) = ""
   [M:SLRA]COCHE(nolign-1) = "x"
Else
   [M:SLRA]COCHE(nolign-1) = ""
Endif
Affzo [M:SLRA]COCHE(nolign-1)
End
########################################
