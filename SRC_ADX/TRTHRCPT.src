#* @param  WABRTAB  : Abréviation de la table
#* @param  WMSKFLDDIE  : Nom du champ DIE dans l'écran
#* @param  WMSKFLDCCE  : Nom du champ CCE dans l'écran
#* @param  WTABFLDDIE  : Nom du champ DIE dans la table
#* @param  WTABFLDCCE  : Nom du champ CCE dans la table
#*!
Subprog CHARG_DIE(WCODE,WSOCIETE,WABRMSK,WBASTAB,WABRTAB,WMSKFLDDIE,WMSKFLDCCE,WTABFLDDIE,WTABFLDCCE)
Value    Integer WCODE
Value    Char    WSOCIETE
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WABRTAB
Value    Char    WMSKFLDDIE
Value    Char    WMSKFLDCCE
Value    Char    WTABFLDDIE
Value    Char    WTABFLDCCE

Local    Char    WMSKFLDOTHER(30)
Local    Char    WTABFLDOTHER(30)
Local    Char    WVALUEOTHER(30)


Gosub FILL_DIE
End


#**
#* Chargement tableau axes analytiques des tables de base
#*         Appelé par l'action LIENS
#* Paramètres à passer au sous-programme :
#* @param  WCODE    : Numéro de la table à gérer (menu local 2230)
#* @param  WSOCIETE : Société ("" = pas de déclinaison par société)
#* @param  WABRMSK  : Abréviation du masque écran
#* @param  WBASTAB  : Nom de la variable de bas de tableau
#* @param  WABRTAB  : Abréviation de la table
#* @param  WMSKFLDDIE  : Nom du champ DIE dans l'écran
#* @param  WMSKFLDCCE  : Nom du champ CCE dans l'écran
#* @param  WMSKFLDOTHER: Nom d'un autre champ dans l'écran
#* @param  WTABFLDDIE  : Nom du champ DIE dans la table
#* @param  WTABFLDCCE  : Nom du champ CCE dans la table
#* @param  WTABFLDOTHER: Nom d'un autre champ dans la table
#* @param  WVALUEOTHER : Valeur d'Init d'un autre champ
#*!

Subprog CHARG_DIE2(WCODE,WSOCIETE,WABRMSK,WBASTAB,WABRTAB,WMSKFLDDIE,WMSKFLDCCE,WMSKFLDOTHER,WTABFLDDIE,WTABFLDCCE,WTABFLDOTHER,WVALUEOTHER)
Value    Integer WCODE
Value    Char    WSOCIETE
Value    Char    WABRMSK
Value    Char    WBASTAB
Value    Char    WABRTAB
Value    Char    WMSKFLDDIE
Value    Char    WMSKFLDCCE
Value    Char    WMSKFLDOTHER
Value    Char    WTABFLDDIE
Value    Char    WTABFLDCCE
Value    Char    WTABFLDOTHER
Value    Char    WVALUEOTHER

Gosub FILL_DIE

End


$FILL_DIE
#-----
Local    Integer J,WMAXJ

#----- Initialisation des codes axe analytique -----#

Gosub TR_INIT_DIE
WMAXJ=evalue("dim("+[L]ECRAN+WTABFLDDIE+")")
#----- Chargement des sections analytiques -----#
# FQ104400 - 02/12/14 - Ajout min sur GOPTCANA
#For [L]I=0 To [F:CDI]NBRDIE-1
For [L]I=0 To min(GOPTCANA,[F:CDI]NBRDIE)-1
    For [L]J=0 To WMAXJ-1
      If evalue([L]ECRAN+WMSKFLDDIE+"([L]I)")= evalue([L]TABLE+WTABFLDDIE+"([L]J)")
        Assign [L]ECRAN+WMSKFLDCCE+"([L]I)" With evalue([L]TABLE+WTABFLDCCE+"([L]J)")
        If WMSKFLDOTHER<>"" & WTABFLDOTHER<>""
         If evalue("dim("+[L]ECRAN+WMSKFLDOTHER+")")>0 & evalue("dim("+[L]ECRAN+WTABFLDOTHER+")")>0 Then
          Assign [L]ECRAN+WMSKFLDOTHER+"([L]I)" With evalue([L]TABLE+WTABFLDOTHER+"([L]J)")
         Endif
        Endif
        Break
      Endif
    Next [L]J
Next [L]I
#-----
Return

#---------------------------------------------------------#
# Traitement de l'initialisation des codes axe analytique #
#---------------------------------------------------------#
$TR_INIT_DIE
Local    Char    ECRAN(10)
Local    Char    BATAB(20)
Local    Char    TABLE(20)
Local    Integer I, WWCODE
#-----
If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
#-----
WWCODE = WCODE
If WWCODE>100 WWCODE-=100 Endif
#-----
If WABRMSK=""
  [L]ECRAN="[M]"
Else
  [L]ECRAN="[M:"+WABRMSK+"]"
Endif
If WBASTAB=""
  [L]BATAB=[L]ECRAN+"NBAXE"
Else
  [L]BATAB=[L]ECRAN+WBASTAB
Endif
If WABRTAB=""
  [L]TABLE="[F]"
Else
  [L]TABLE="[F:"+WABRTAB+"]"
Endif
#-----

Read [CDI] CDI0=WWCODE
If fstat  Raz [F:CDI] : Endif
#-----
For [L]I=0 To evalue("dim("+[L]ECRAN+WMSKFLDDIE+")")-1
  Assign [L]ECRAN+WMSKFLDDIE+"([L]I)" With ""
  Assign [L]ECRAN+WMSKFLDCCE+"([L]I)" With ""
  If WMSKFLDOTHER<>"" :  Call ASSIGN_FLDMASK([L]ECRAN+WMSKFLDOTHER,[L]I,"") :Endif
Next [L]I
#-----
# FQ104400 - 02/12/14 - Ajout min sur GOPTCANA
#Assign [L]BATAB With [F:CDI]NBRDIE
#For [L]I=0 To [F:CDI]NBRDIE-1
Assign [L]BATAB With min(GOPTCANA,[F:CDI]NBRDIE)
For [L]I=0 To min(GOPTCANA,[F:CDI]NBRDIE)-1
  Assign [L]ECRAN+WMSKFLDDIE+"([L]I)" With [F:CDI]DIE([L]I)
  If WMSKFLDOTHER<>"" : Call ASSIGN_FLDMASK([L]ECRAN+WMSKFLDOTHER,[L]I,WVALUEOTHER) :Endif
Next [L]I
Return


Subprog ASSIGN_FLDMASK(WMSKFLD,WI,WVALUE)
Value Char WMSKFLD
Value Integer WI
Value Char WVALUE

  If evalue("dim("+WMSKFLD+")")>0 Then
    Case evalue("type("+WMSKFLD+")")
      When 1, 2, 4, 5, 6, 7, 9 : Assign WMSKFLD+"("+num$(WI)+")" With val(WVALUE)
      When 3 : #not managed
      When Default : Assign WMSKFLD+"([L]I)" With WVALUE
    Endcase
  Endif
End


#FQ92876-US2582-
#**
#* Contrôle du code répartition analytique
#*         Appelé par l'action CTRLDSP
#* Paramètres à passer au sous-programme :
#* @param  WDSP   : Code répartition à contrôler
#* @param  WFCY   : Site financier de la société ou site comptable
#* @param  WDATE  : Date
#*!
Subprog CTRL_DSP(WDSP,WFCY,WDATE)
Variable Char    WDSP
Value    Char    WFCY
Value    Date    WDATE
#-----
If WDSP=""  End : Endif
If !clalev([F:DSP])  Local File =GTABCPT+"CADSP" [DSP] : Endif
Call CONTDSP(WDSP,WFCY,WDATE) From SUBDSP
If mkstat :  End : Endif
End

#FQ92876-US2675-
#--------------------------------------------------------#
# Sauvegarde des globales (en cas de tunnel par exemple) #
#--------------------------------------------------------#
$SAUV_GLOBAL_CPT
Local Integer WI,WMAXLED,WMAXCOA,WMAXDIE

If dim(GNBTYPLED)>0   Local Integer WGNBTYPLED            : WGNBTYPLED  =GNBTYPLED   : Endif
If dim(GNBCOA)>0      Local Integer WGNBCOA               : WGNBCOA     =GNBCOA      : Endif
If dim(GNBDIE)>0      Local Integer WGNBDIE               : WGNBDIE     =GNBDIE      : Endif
If dim(GSCRCOA)>0     Local Integer WGSCRCOA              : WGSCRCOA    =GSCRCOA     : Endif
If dim(GSCRDIE)>0     Local Integer WGSCRDIE              : WGSCRDIE    =GSCRDIE     : Endif
If dim(GSCRDIE2)>0    Local Integer WGSCRDIE2             : WGSCRDIE2   =GSCRDIE2    : Endif # FQ 59219
If dim(GSCRDIE3)>0    Local Integer WGSCRDIE3             : WGSCRDIE3   =GSCRDIE3    : Endif # FQ 59219
If dim(GHEADIE)>0     Local Integer WGHEADIE              : WGHEADIE    =GHEADIE     : Endif
If dim(GSTODIE)>0     Local Integer WGSTODIE              : WGSTODIE    =GSTODIE     : Endif
If dim(GSOC_ACTIVE)>0 Local Char    WGSOC_ACTIVE(GLONCPY) : WGSOC_ACTIVE=GSOC_ACTIVE : Endif
If dim(GSOC_UPDFLG)>0 Local Libelle WGSOC_UPDFLG          : WGSOC_UPDFLG=GSOC_UPDFLG : Endif
WMAXLED=10
WMAXCOA=10
WMAXDIE=20
#-----
If dim(GTYPLED)>0
  Local Integer WGTYPLED(1..WMAXLED)
  For WI=1 To WMAXLED
     WGTYPLED(WI) =GTYPLED(WI)
  Next
Endif
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
If dim(GTYPLED_X3TC)>0
  Local Integer WGTYPLED_X3TC(1..WMAXLED)
  For WI=1 To WMAXLED
    WGTYPLED_X3TC(WI) =GTYPLED_X3TC(WI)
  Next
Endif
If dim(GLEDSOC)>0
  Local Char WGLEDSOC(GLONLED)(1..WMAXLED)
  For WI=1 To WMAXLED
    WGLEDSOC(WI) =GLEDSOC(WI)
  Next
Endif
If dim(GDEVLED)>0
  Local Char WGDEVLED(GLONCUR)(1..WMAXLED)
  For WI=1 To WMAXLED
    WGDEVLED(WI) =GDEVLED(WI)
  Next
Endif
If dim(GCOA)>0
  Local Char WGCOA(GLONCOA)(1..WMAXCOA)
  For WI=1 To WMAXCOA
    WGCOA(WI) =GCOA(WI)
  Next
Endif
If dim(GCOLCOA)>0
  Local Char WGCOLCOA(20)(1..WMAXCOA)
  For WI=1 To WMAXCOA
    WGCOLCOA(WI) =GCOLCOA(WI)
  Next
Endif
If dim(GFMTCOA)>0
  Local Char WGFMTCOA(15)(1..WMAXCOA)
  For WI=1 To WMAXCOA
    WGFMTCOA(WI) =GFMTCOA(WI)
  Next
Endif
If dim(GDIE)>0
  Local Char WGDIE(GLONDIE)(1..WMAXDIE)
  For WI=1 To WMAXDIE
    WGDIE(WI) =GDIE(WI)
  Next
Endif
If dim(GOBLDIE)>0
  Local Integer WGOBLDIE(1..WMAXDIE)
  For WI=1 To WMAXDIE
    WGOBLDIE(WI) =GOBLDIE(WI)
  Next
Endif
If dim(GENVDIE)>0
  Local Integer WGENVDIE(1..WMAXDIE)
  For WI=1 To WMAXDIE
    WGENVDIE(WI) =GENVDIE(WI)
  Next
Endif
If dim(GCOLDIE)>0
  Local Char WGCOLDIE(20)(1..WMAXDIE)
  For WI=1 To WMAXDIE
    WGCOLDIE(WI) =GCOLDIE(WI)
  Next
Endif
If dim(GFMTDIE)>0
  Local Char WGFMTDIE(15)(1..WMAXDIE)
  For WI=1 To WMAXDIE
    WGFMTDIE(WI) =GFMTDIE(WI)
  Next
Endif
#-----
Return

#FQ92876-US2675-
#---------------------------------------------------#
# Restauration des globales (au retour d'un tunnel) #
#---------------------------------------------------#
$REST_GLOBAL_CPT
Local Integer WI,WMAXLED,WMAXCOA,WMAXDIE

If dim(WGNBTYPLED)>0   GNBTYPLED  =WGNBTYPLED   : Endif
If dim(WGNBCOA)>0      GNBCOA     =WGNBCOA      : Endif
If dim(WGNBDIE)>0      GNBDIE     =WGNBDIE      : Endif
If dim(WGSCRCOA)>0     GSCRCOA    =WGSCRCOA     : Endif
If dim(WGSCRDIE)>0     GSCRDIE    =WGSCRDIE     : Endif
If dim(WGSCRDIE2)>0    GSCRDIE2   =WGSCRDIE2    : Endif # FQ 59219
If dim(WGSCRDIE3)>0    GSCRDIE3   =WGSCRDIE3    : Endif # FQ 59219
If dim(WGHEADIE)>0     GHEADIE    =WGHEADIE     : Endif
If dim(WGSTODIE)>0     GSTODIE    =WGSTODIE     : Endif
If dim(WGSOC_ACTIVE)>0 GSOC_ACTIVE=WGSOC_ACTIVE : Endif
If dim(WGSOC_UPDFLG)>0 GSOC_UPDFLG=WGSOC_UPDFLG : Endif
WMAXLED=10
WMAXCOA=10
WMAXDIE=20

#-----
If dim(WGTYPLED)>0
  For WI=1 To WMAXLED
    GTYPLED(WI) =WGTYPLED(WI)
  Next
Endif
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
If dim(WGTYPLED_X3TC)>0
  For WI=1 To WMAXLED
    GTYPLED_X3TC(WI) =WGTYPLED_X3TC(WI)
  Next
Endif
If dim(WGLEDSOC)>0
  For WI=1 To WMAXLED
    GLEDSOC(WI) =WGLEDSOC(WI)
  Next
Endif
If dim(WGDEVLED)>0
  For WI=1 To WMAXLED
    GDEVLED(WI) =WGDEVLED(WI)
  Next
Endif
If dim(WGCOA)>0
  For WI=1 To WMAXCOA
    GCOA(WI) =WGCOA(WI)
  Next
Endif
If dim(WGCOLCOA)>0
  For WI=1 To WMAXCOA
    GCOLCOA(WI) =WGCOLCOA(WI)
  Next
Endif
If dim(WGFMTCOA)>0
  For WI=1 To WMAXCOA
    GFMTCOA(WI) =WGFMTCOA(WI)
  Next
Endif
If dim(WGDIE)>0
  For WI=1 To WMAXDIE
    GDIE(WI) =WGDIE(WI)
  Next
Endif
If dim(WGOBLDIE)>0
  For WI=1 To WMAXDIE
    GOBLDIE(WI) =WGOBLDIE(WI)
  Next
Endif
If dim(WGENVDIE)>0
  For WI=1 To WMAXDIE
    GENVDIE(WI) =WGENVDIE(WI)
  Next
Endif
If dim(WGCOLDIE)>0
  For WI=1 To WMAXDIE
    GCOLDIE(WI) =WGCOLDIE(WI)
  Next
Endif
If dim(WGFMTDIE)>0
  For WI=1 To WMAXDIE
  GFMTDIE(WI) =WGFMTDIE(WI)
  Next
Endif
#-----
Return
# FQ92876-US2683
#**
#* Function GCOMPTA<>3
#*!
Funprog ISCPT
Local Integer REP
#If dim(GCOMPTA)>0 & dim(GTABCPT)>0 & (GCOMPTA<>3 or GTABCPT <> "")
# End 1
#Endif
REP= dim(GCOMPTA)>0 & GCOMPTA<>3
End REP

#**
#* Function GCOMPTA<>3 & GPRODRUIT=0
#*!
Funprog ISCPT_ERP
Local Integer REP
#If dim(GCOMPTA)>0 & dim(GTABCPT)>0 & (GCOMPTA<>3 or GTABCPT <> "")
# End 1
#Endif
REP=0
If GPRODUIT=0
  REP= func TRHHRCPT.ISCPT
Endif
End REP

