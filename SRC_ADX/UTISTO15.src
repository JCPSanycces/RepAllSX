##########################################################################
# UTISTO15   VÃĐrification mÃĐthode de valo au coÃŧt standard               #
##########################################################################
# Bug 70418 - 2010-07-05 by CCC
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  #--- Issue 108760 by TS
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  #---
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    #--- Issue 108760 By TS
    #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    #---
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Valuation method control") From LECFIC
    Call MAJ_UTISTO15(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTISTO15(DOSSIER)
Value Char DOSSIER

Local Char LMSG(250)
Local Integer I

If filinfo(filpath("FIL","TABCOSTMET","fde",DOSSIER),0) < 0
    End
Endif

  Call ECR_TRACE("UTISTO15: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".TABCOSTMET"  [TCM]
  Local File =DOSSIER + ".TABCOSTMVT"  [TVM]

  Filter [TCM] Where (RCPVLTCOD=1 or RCPVLTCOD=2)
&                  & RCPVLTCOD<>RCPVLT2
  Look [F:TCM] First
  LTCM = fstat<>0

  Filter [TVM] Where (MVTVLT=1 or MVTVLT=2)
&                  & MVTVLT<>MVTVLT2
  Look [F:TVM] First
  LTVM = fstat<>0

  If LTCM & LTVM
      Call ECR_TRACE("Valuation method control : OK",0) From GESECRAN
  Else
      If !LTCM
          Call ECR_TRACE("Control of valuation methods is not OK",0) From GESECRAN
          For [TCM]
              LMSG = [F:TCM]VLTCOD-":"-mess(378,184,1)
              I=instr(1,LMSG,'%1')
              LMSG = left$(LMSG,I-1)+mess([F:TCM]RCPVLTCOD,263,1)+right$(LMSG,I+2)
              Call ECR_TRACE(LMSG,-1) From GESECRAN
          Next
      Endif
      If !LTVM
          Call ECR_TRACE("Control of valuation method exceptions is not OK",0) From GESECRAN
          For [TVM]
              LMSG = [F:TVM]VLTCOD+";"+mess([F:TVM]MVTTYP,704,1)+";"+num$([F:TVM]TRSCOD)
              Call ECR_TRACE(LMSG,0) From GESECRAN
              LMSG = mess(378,184,1)
              I=instr(1,LMSG,'%1')
              LMSG = left$(LMSG,I-1)+mess([F:TVM]MVTVLT,263,1)+right$(LMSG,I+2)
              Call ECR_TRACE(LMSG,-1) From GESECRAN
          Next
      Endif
  Endif
  Filter [TCM]
  Filter [TVM]

  Close Local File [TCM]
  Close Local File [TVM]

  Call ECR_TRACE("UTISTO15 : finish",0) From GESECRAN
End

########################################################################
# Pour exÃĐcution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 by TS
  #Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  #---
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","TABCOSTMET","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(APPLI,"TABCOSTMET") : End : Endif                  : # For Archive folder
  #---
  Call MAJ_UTISTO15(APPLI)
End

#######################################################################
# Pour exÃĐcution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","TABCOSTMET","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(APPLI,"TABCOSTMET") : End : Endif                  : # For Archive folder
  #---
  Call MAJ_UTISTO15(APPLI)
End

