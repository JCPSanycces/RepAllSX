#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM003 - Set activity code HRFRM value to OFF          #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Set activity code HRFRM value to OFF") From LECFIC

  Call MAJ_UTIHRM003(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIHRM003(DOSSIER)
Value Char DOSSIER
Local Char CODE (GLONACV)

If clalev([F:ACV])=0  : Local File =DOSSIER+".ACTIV" [ACV]  : Endif

Call ECR_TRACE("UTIHRM003 : Set activity code HRFRM value to OFF : "+DOSSIER,0) From GESECRAN

Call DEBTRANS From GLOCK

Trbegin [ACV]

[L]CODE="HRFRM"
Gosub MAJACV

If !GOK
  Rollback
Else
  Commit
Endif

Call ECR_TRACE("UTIHRM003: Process completed on : "+DOSSIER,0) From GESECRAN

Close Local File [ACV]

End

##############################
$MAJACV
Readlock [F:ACV]CODACT=[L]CODE
If !fstat
  If [F:ACV]FLACT=2
    [F:ACV]FLACT=1
    Rewrite [F:ACV]
    If fstat
     GOK = 0 : Call FSTA("ACV") From GLOCK
    Endif
  Endif
Endif

Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIHRM003(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTIHRM003(APPLI)

End

