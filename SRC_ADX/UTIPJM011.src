#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM011
# Issue X3-6915/119674 - 2017-01-03 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM011(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM011(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Integer IFOUND

  IERR = 0
  Call ECR_TRACE("UTIPJM011: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMPH
  #
  If filinfo(filpath("FIL", "ADOVAL", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ADOVAL" [ADW]
  # -------------------------
  Trbegin [ADW]
  NCOUNT = 0
  NCOUNTERROR = 0
  IFOUND = 0
  Call ECR_TRACE("UTIPJM011: Updating ADOVAL", 0) From GESECRAN
  Filter [ADW] Where [F:ADW]CMP = '' and [F:ADW]FCY = '' and [F:ADW]PARAM = 'SEPARCODE'
  For [ADW]ADW0
    IFOUND = 1
    If [F:ADW]VALEUR <> "!" Then
      [F:ADW]VALEUR = "!"
      NCOUNT += 1
      Rewrite [ADW]
      If fstat Then
        Call ECR_TRACE("File ADOVAL(a)" - [F:ADW]PARAM + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Endif
  Next
  Filter [ADW]
  If IFOUND = 0 Then
    Raz [F:ADW]
    [F:ADW]CMP = ''
    [F:ADW]FCY = ''
    [F:ADW]PARAM = 'SEPARCODE'
    [F:ADW]VALEUR = "!"
    NCOUNT += 1
    Write [ADW]
    If fstat Then
      Call ECR_TRACE("File ADOVAL(b)" - [F:ADW]PARAM + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Endif
  # -------------------------
  If NCOUNTERROR = 0 Then
    Call ECR_TRACE("UTIPJM011: ADOVAL" - num$(NCOUNT) - "updated.", 0) From GESECRAN
  Else
    Call ECR_TRACE("UTIPJM011: ADOVAL" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
  Endif
  # -----------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM011 : records processed without error.", 0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM011 : records processed with error(s).", 0) From GESECRAN
  Endif
  # -------------------------
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM011(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "ADOVAL") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM011(APPLI)
End

