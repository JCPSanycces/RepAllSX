#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SALESREP_C_COMRAT1
#######################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER
    Endcase
Endcase
Return
#######################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case CURPTH
    When ""
      Case [L]AMETHOD
        When Default
      Endcase
    When Default
  Endcase
Return
#######################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
#######################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Return

#######################################################################################
$AREAD_AFTER
  Gosub AREAD_AFTER_BPAPRI
Return

#######################################################################################
$AREAD_AFTER_BPAPRI
Local Integer NI
Local Integer ILINE
Local Integer NE
Local Integer NFOUND

  NFOUND = [V]CST_ANO
  NE = 0
  For NI = 1 To maxtab(this.BPR.BPA)
    If this.BPR.BPA(NI).BPAADDFLG = [V]CST_AYES Then
      NE = NI
    Endif
    If this.BPR.BPA(NI).BPAADD = this.BPAADD Then
      If this.BPAPRI(1) = null Then
        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      Else
        ILINE = 1
      Endif
      this.BPAPRI(ILINE) = this.BPR.BPA(NI)
      NFOUND = [V]CST_AYES
      Break
    Endif
  Next NI
  If NFOUND = [V]CST_ANO Then
    If NE = 0 Then
      If maxtab(this.BPR.BPA) > 0 Then
        NE = 1
      Endif
    Endif
    If NE > 0 Then
      If this.BPAPRI(1) = null Then
        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      Else
        ILINE = 1
      Endif
      this.BPAPRI(ILINE) = this.BPR.BPA(NE)
    Endif
  Endif
Return

