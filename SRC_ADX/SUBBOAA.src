#<AdxTL>@(#)4.0.0.0 $Revision$

#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Fonction : BUDAPP - Approbation/Refus (d'approbation)
#   Action   : BUDAPP
#   Fenêtre  : BUDAPP
#   Ecran concerné : BOAA
#   Description : Fonction permettant d'approuver ou de refus une demande
#                 d'approbation. (Utilise les règles de workflow)
#
#--------------------------------------------------------------------------

Local Char PARAM(10)(1..5) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"BUDAPP","SUBBOAA","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "OUVRE"       : Gosub OUVRE
 When "AVANT_OK"    : Gosub AVANT_OK
 When "OK"          : Gosub OK
 When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

$OUVRE
#Recup du parametrage du niveau d'approbation
Global Char GAPPNIV(3)
#Entité de l'utilisateur courant (GUSER)
Global Char GENTUSR
Global Integer GDEBAPP
Local Char DEBAPP(3)
Call PARAMUTIL("GDDENTUSR",GENTUSR,"","") From SUBAUS
Call PARAMUTIL("GDDDEBAPP",DEBAPP,"","") From SUBAUS
GDEBAPP=val(DEBAPP)
#Tables utiles
If !clalev([BUD]) : Local File BUD        [BUD] : Endif
If !clalev([ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([ENF]) : Local File ENVFIY     [ENF] : Endif
If !clalev([BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([LED]) : Local File GLED       [LED] : Endif
If !clalev([GCM]) : Local File GACM       [GCM] : Endif
If !clalev([CCE]) : Local File CACCE      [CCE] : Endif
If !clalev([CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([AUS]) : Local File AUTILIS    [AUS] : Endif
If !clalev([AWS]) : Local File AWRKHISSUI [AWS] : Endif
If !clalev([AWU]) : Local File AWRKUSR    [AWU] : Endif
If !clalev([AWH]) : Local File AWRKPARH   [AWH] : Endif
If !clalev([BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([BAD]) : Local File BUDAPPDET  [BAD] : Endif

#Masque
Local Mask BOAA
#Variables Utiles
Local Integer STAT
Local Char NUMREV
#Intitulé enveloppe
Local Char INTENV(30)

Local Integer OKACS, CTLACS
CTLACS = 1
Return

$DEBUT
Raz [M:BOAA]
If PARAM(1)<>""
 Gosub CHARGE_APPROBATION
Endif
Return

$AVANT_OK
Local Integer OK,COCHE : COCHE=0
For I=0 To [M]NBLIG-1
 If [M]TRT(I)<>1
  COCHE=1 : Break
 Endif
Next
If !COCHE
 #Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Else
 Local Char LISTLIG(50)
 LISTLIG ="["
 Local Integer DOIT : DOIT=0
 For I=0 To [M]NBLIG-1
  If [M]TRT(I)=3 & [M]RENTXT(I)=""
   If DOIT<>0 : LISTLIG += ", " : Endif
   LISTLIG += num$(I)
   DOIT+=1
  Endif
 Next
 LISTLIG+="]"
 If DOIT
  #Motif obligatoire pour les lignes
  Call MESSAGE(mess(216,108,1)-LISTLIG) From GESECRAN
  FOK=0
  FIN=0
 Endif
Endif
Return

$OK
Call DEBTRANS From GLOCK
Gosub TR_OK
Return

$TR_OK
GOK = 1
For I=0 To [M]NBLIG-1
 If [M]TRT(I)<>1
  #Mise à jour de la table des approbation
  Trbegin [BOA]
   Readlock [BOA]BOA0 = [M]NUM(I)
   If fstat=1
    GOK=-1 : GLOCK="$BUDAPP"-[M]NUM(I) : Break
   Elsif fstat
    GOK=0 : Call FSTA("BOA") From GLOCK : Break
   Elsif !fstat
    [F:BOA]AMTAPP = [M]AMTAPP(I)
    [F:BOA]RENTXT = [M]RENTXT(I)
    Rewrite [BOA]
    If fstat
     GOK=0 : Call FSTA("BOA") From GLOCK : Break
    Endif
   Endif
  Commit

  Filter [AWS] Where (CODEVT="APP" | CODEVT="BUOAPP") & CLEDEC=[M]NUM(I) & FLGSIG=3
  Read [AWS]AWS0 Last
  If !fstat
   If !clalev([AWM]) : Local File AWRKLNK [AWM] : Endif
   If !clalev([AWR]) : Local File AWRKREG [AWR] : Endif
   Call LECTURE("AWM","BUOAPP","") From CONTOBJ
   Call LECTURE("AWR","BUOAPP","") From CONTOBJ

   Case [M]TRT(I)
    When 2 : Call SIGWRK([F:AWS]CHRONO,[F:AWS]DEST,"VAL") From SAIWRKSIG
    When 3 : Call SIGWRK([F:AWS]CHRONO,[F:AWS]DEST,"REJ") From SAIWRKSIG
   Endcase

  Endif
  Filter [AWS]
 Endif
Next
If GOK<0 : Goto ROLL_TR_OK
Elsif !GOK : Goto AB_TR_OK
Endif
Return

$ROLL_TR_OK
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_OK : Endif
Return

$AB_TR_OK
Rollback
Return

$SETBOUT
If [M]NBLIG<=0
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
Return
#---------------------------------------------------------------#
# Dans le cas ou l'on vient du mail de soumission d'approbation #
#---------------------------------------------------------------#

$CHARGE_APPROBATION
Read [BOA]BOA0=PARAM(1)
If !fstat
 If [F:BOA]STA<>2
  #L'objet n'est plus à approuver
  Call MESSAGE(mess(184,108,1)) From GESECRAN
  Return
 Endif
Endif
OKUSR=0

#Workflow en cours ?
Filter [AWS] Where (CODEVT="APP" | CODEVT="BUOAPP") & CLEDEC=PARAM(1) & FLGSIG=3
Read [AWS]AWS0 Last
If !fstat
 #Acces garantit au signataire courant
 If GUSER=[F:AWS]USRTOP
  OKUSR=1
 Endif
 #& aux utilisateurs délégués selon les conditions de délégations
 Local Char DELEG(GLONAUS)(1..600) : Raz DELEG
 Local Integer NBDEL : NBDEL=0
 Read [AWH]AWH0 = "BUOAPP"
 If !fstat
  #Call GETUSRDELEG([F:AWH]NATURE,evalue("[F:AWS]USRSIG"+num$([F:AWS]LEVSIG+1)),[F:AWH]OPTDEL,NBDEL,DELEG) From TRTGDD
  Call GETUSRDELEG([F:AWH]NATURE,[F:AWS]USRTOP,[F:AWH]OPTDEL,NBDEL,DELEG) From TRTGDD
  If find(GUSER,DELEG(1..NBDEL))
   OKUSR=1
  Endif
 Endif
Endif
Filter [AWS]

If !OKUSR
 #Vous n'ètes pas le signataire courant de cette demande
 Call MESSAGE(mess(221,108,1)) From GESECRAN
 Return
Endif
Read [BOA]BOA0=PARAM(1)
If !fstat & [F:BOA]STA=2 & OKUSR
 Call LECTURE("ENV",[F:BOA]ENV,"") From CONTOBJ
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS
   Call MESSAGE(mess(55,109,1)) From GESECRAN
   Return
  Endif
 Endif
 Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
 [M]CFY=[F:ENV]FCY
 Call C_CFY([M]CFY)
 Call CONTACCCFY([M]CFY,"[M]INTCFY") From CFYSUB
 [M]NUM(0)    = [F:BOA]NUM
 [M]TYP(0)    = [F:BOA]TYP
 [M]ENV(0)    = [F:BOA]ENV
 [M]FIY(0)    = [F:BOA]FIY
 [M]ACCNUM(0) = [F:BOA]ACCNUM
 [M]CUR(0)    = [F:BOA]CUR
 If [F:BOA]TYP<>4
  [M]AMT(0)    = [F:BOA]AMT
  [M]AMTAPP(0) = [F:BOA]AMT
 Endif
 [M]ENVINT(0) = INTENV
 [M]PRJ(0)    = [F:BOA]PRJ
 If [F:BOA]TYP=3
  Read [BUD]BUD1=[F:BOA]ACCNUM
  If !fstat
   [M]ACC(0)    = [F:BUD]ACC
  Endif
 Endif
 [M]NBLIG +=1
Endif
Affzo [M]
Gosub COLORIZE
zonsui="[M]TRT(0)"
Return

#----------------------------------------------------------------#


######################################################################################

Subprog C_CFY(VALEUR)
Variable Char    VALEUR()
Local Integer ISOC, ISITE
ISOC   = find(VALEUR,GSOC(1..GNBSOC))
If !ISOC
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If !ISITE : End : Endif
 [M]FCY=VALEUR
 #06/10/09-Dmd54223:Autorisation site
 Call CONTFCY(VALEUR) From CPTSUB
 ISOC = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
 If !ISOC : End : Endif
Else
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
Endif
[M]CPY=GSOC(ISOC)
Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
[M]FCY=[F:CPY]MAIFCY
Call SETGLBAPP(GSOC(ISOC),GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
Affzo [M]
End

Subprog AM_CFY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 [M]CFY=VALEUR
 Gosub CHARGE_TAB
Endif
End

$CHARGE_TAB
#Intitulé enveloppe
Local Char INTENV(30)
Local Integer SOC,J, I
Local Char LISTFCY(GLONFCY)(1..GNBSITE)
Local Integer OKACS, CTLACS
CTLACS = 1

SOC=find([M]CFY,GSOC(1..GNBSOC))
J=1
If SOC
 For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
  LISTFCY(J)=[F:FCY]FCY
  J+=1
 Next
Endif
Local Integer OKBOA, OKUSR
I=0

#Parcours des demandes
For [BOA]BOA0 Where STA=2
 OKBOA=0
 Call LECTURE("ENV",[F:BOA]ENV,"") From CONTOBJ
 Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
 If [F:ENV]FCY=[M]CFY | find([F:ENV]FCY,LISTFCY(1..J))
  OKBOA=1

  OKUSR=0
  #Workflow en cours ?
  Filter [AWS] Where (CODEVT="APP" | CODEVT="BUOAPP") & CLEDEC=[F:BOA]NUM & FLGSIG=3
  Read [AWS]AWS0 Last
  If !fstat
  # [F:BOA]NUM-": Nb d'utilisateurs signataire =>"-num$([F:AWS]NBRUSR)+chr$(10)
  #&         +"Vous ètes :"-GUSER+chr$(10)
  #&         +"Dernier signataire :"-evalue("[F:AWS]USRSIG"+num$([F:AWS]NBRUSR))+chr$(10)
  #&         +"Signataire devant signer maintenant :"-evalue("[F:AWS]USRSIG"+num$([F:AWS]LEVSIG+1))+chr$(10)
  #&         +"Niveau de signature :"-num$([F:AWS]LEVSIG)

   #Acces garantit au signataire courant uniquement
   If GUSER=[F:AWS]USRTOP
    OKUSR=1
   Endif
   #& aux utilisateurs délégués selon les conditions de délégations
   Local Char DELEG(GLONAUS)(1..600) : Raz DELEG
   Local Integer NBDEL : NBDEL=0
   Read [AWH]AWH0 = "BUOAPP"
   If !fstat
    Call GETUSRDELEG([F:AWH]NATURE,[F:AWS]USRTOP,[F:AWH]OPTDEL,NBDEL,DELEG) From TRTGDD
    If find(GUSER,DELEG(1..NBDEL))
     OKUSR=1
    Endif
   Endif
  Endif
  Filter [AWS]
 Endif
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif


 If OKBOA & OKUSR & OKACS
  [M]NUM(I)    = [F:BOA]NUM
  [M]TYP(I)    = [F:BOA]TYP
  [M]ENV(I)    = [F:BOA]ENV
  [M]ENVINT(I) = INTENV
  [M]FIY(I)    = [F:BOA]FIY
  [M]ACCNUM(I) = [F:BOA]ACCNUM
  [M]CUR(I)    = [F:BOA]CUR
  [M]AMT(I)    = [F:BOA]AMT
  If [F:BOA]TYP=4
   Grizo [M]AMTAPP(I)
   Affzo [M]AMTAPP(I)
  Else
   [M]AMTAPP(I) = [F:BOA]AMT
  Endif
  [M]PRJ(I)    = [F:BOA]PRJ
  [M]ACC(I)    = [F:BOA]ACC
  [M]TRT(I)    = 1
  Raz [M]RENTXT(I)
  I+=1
  #----TB protection----
  If I>dim([M]TRT)-1
   #Tableau Plein
   Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
  Endif
  #--------------------
 Endif

Next
[M]NBLIG=I
Affzo [M]
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Gosub COLORIZE
Return

$COLORIZE
Local Integer K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For I=0 To [M]NBLIG-1
 If [M]ENV(I)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
  Chgstl [M]AMT(I)    With "GDD"+num$(K)+"G"
 Else
  Chgstl [M]NBLIG(I)  With "GDD"+num$(K)
  Chgstl [M]AMT(I)    With "GDD"+num$(K)+"G"
 Endif
 ENVCUR=[M]ENV(I)
Next
Affzo [M]
Return

Subprog IB_NBLIG
If [M]TYP(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
If [M]TYP(nolign-1)<>4
 Raz GBOUT3
Endif
End

Subprog AS_AMTAPP(VALEUR)
Variable Decimal VALEUR
Call LECTURE("ENV",[M]ENV(nolign-1),"") From CONTOBJ
If [F:ENV]EXTBUD=2
 mkstat=1
 End
Endif
[M]AMTAPP(nolign-1)=VALEUR
If [M]AMTAPP(nolign-1)=0
 VALEUR=[M]AMT(nolign-1)
Endif
Affzo [M]AMTAPP
End

Subprog C_AMTAPP(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M]TRT(nolign-1)=2 & [M]TYP(nolign-1)<>4
 #Obligatoire
  GMESSAGE=mess(4,65,1)
  VALEUR=[M]AMT(nolign-1)
  mkstat=2 : End
Endif
#-----------------------
# Contrôle des montants
#-----------------------
Case [M]TYP(nolign-1)
 When 1 :#Enveloppe
  #---------------------------------------------------------------------
  # Ctrl que pas inférieur au montant ventilé dans les budgets
  #---------------------------------------------------------------------
  Local Decimal VE_BUD : VE_BUD =0
  Filter [ENF] Where ENV=[M]ENV(nolign-1)
  For [ENF]ENF0
   VE_BUD += [F:ENF]AMTBUDFIY
  Next
  Filter [ENF]
  Call LECTURE("ENV",[M]ENV(nolign-1),"") From CONTOBJ
  If VE_BUD<>0 & (VALEUR-[F:ENV]AMTRES)<VE_BUD
   [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
   #Le montant disponible de l'enveloppe ne peut être inférieur au montant ventilé dans le ou les budget(s) exercice(s)
   GMESSAGE=mess(166,108,1)
   VALEUR=VE_BUD+[F:ENV]AMTRES
   mkstat=2 : End
  Endif
  #---------------------------------------------------------------------
 When 2 :#Budgets exe
  #---------------------------------------------------------------------
  #Ctrl que pas supérieur au montant disponible de l'enveloppe
  #---------------------------------------------------------------------
  Local Decimal DISPO_ENV,OTHERS_BUD
  DISPO_ENV = 0 : OTHERS_BUD = 0
  Call LECTURE("ENV",[M]ENV(nolign-1),"") From CONTOBJ
  DISPO_ENV=[F:ENV]AMTENV-[F:ENV]AMTRES
  Filter [ENF] Where ENV=[M]ENV(nolign-1) & FIYNUM<>[M]FIY(nolign-1)
  For [ENF]ENF0
   OTHERS_BUD += [F:ENF]AMTBUDFIY
  Next
  Filter [ENF]
  If (OTHERS_BUD+VALEUR)>DISPO_ENV
   [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
   #La somme des montants des budgets par exercice ne doit pas dépasser le montant disponible de l'enveloppe
   GMESSAGE=mess(116,108,1)
   VALEUR=DISPO_ENV-OTHERS_BUD
   mkstat=2 : End
  Endif
  #---------------------------------------------------------------------
  #Ctrl que pas inférieur au montant ventilé dans les lignes
  #---------------------------------------------------------------------
  Local Decimal VE_LIG :  VE_LIG =0
  Local Integer INDENV, INDENT, INDCCE3
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  Filter [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(nolign-1) & FIY=[M]FIY(nolign-1)
  For [BUD]BUD0
   VE_LIG += [F:BUD]AMT(0)
  Next
  Filter [BUD]
  Read [ENF]ENF0 = [M]ENV(nolign-1);[M]FIY(nolign-1)
  If VE_LIG<>0 & (VALEUR-[F:ENF]AMTRESFIY)<VE_LIG
   [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
   #Le montant disponible du budget ne peut être inférieur au montant ventilé dans les lignes
   GMESSAGE=mess(172,108,1)
   VALEUR=VE_LIG+[F:ENF]AMTRESFIY
   mkstat=2 : End
  Endif
  #---------------------------------------------------------------------
 When 3 :#Lignes
  #---------------------------------------------------------------------
  #Ctrl que pas supérieur au montant disponible du budget exe
  #---------------------------------------------------------------------
  Local Decimal DISPO_BUD,OTHERS_LIG
  DISPO_BUD = 0 : OTHERS_LIG = 0
  Read [ENF]ENF0 = [M]ENV(nolign-1);[M]FIY(nolign-1)
  DISPO_BUD=[F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY
  Local Integer INDENV, INDENT, INDCCE3
  Call LEC_ENV([M]ENV(nolign-1)) From CPTLEC
  Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
  Filter [BUD] Where evalue('CCE'+num$(INDENV))=[M]ENV(nolign-1) & FIY=[M]FIY(nolign-1) & ACCNUM<>[M]ACCNUM(nolign-1)
  For [BUD]BUD0
   OTHERS_LIG+= [F:BUD]AMT(0)
  Next
  Filter [BUD]
  If (OTHERS_LIG+VALEUR)>DISPO_BUD
   [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
   #La somme des montants des lignes budgétaire ne doit pas dépasser le montant disponible du budget exercice
   GMESSAGE=mess(133,108,1)
   VALEUR=DISPO_BUD-OTHERS_LIG
   mkstat=2 : End
  Endif
  #---------------------------------------------------------------------
Endcase
End

Subprog C_TRT(VALEUR)
Variable Integer VALEUR
If VALEUR=2 :#Approuver
 If [M]AMTAPP(nolign-1)=0
  [M]AMTAPP(nolign-1)=[M]AMT(nolign-1)
 Endif
 #Si nous ne sommes pas dans le cas d'une approbation multiple
 If [M]TYP(nolign-1)<>4
  #Selection automatique des objets supérieur
  Case TYP(nolign-1)
   When 2 : #Budget exercice
    For J=0 To [M]NBLIG-1
     If [M]TYP(J)=1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]TRT(J)<>2
      [M]TRT(J)=2
      Break
     Endif
    Next
   When 3 : #Ligne budgétaire
    If GDEBAPP=1
     For J=0 To [M]NBLIG-1
      If [M]TYP(J)<>3 & [M]ENV(J)=[M]ENV(nolign-1) & ([M]FIY(J)=[M]FIY(nolign-1) | [M]FIY(J)=0) & J<>(nolign-1) & [M]TRT(J)<>2
       [M]TRT(J)=2
      Endif
     Next
    Endif
  Endcase
 Endif
Elsif VALEUR=3 :#Refuser
 #Vérif que niveau d'en dessous non coché
 #Selection automatique objet inférieur
 #Si nous ne sommes pas dans le cas d'une approbation multiple
 If [M]TYP(nolign-1)<>4
  Case TYP(nolign-1)
   When 1 : #Enveloppe
    For J=0 To [M]NBLIG-1
     If [M]TYP(J)<>1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1)
      If (GAPPNIV="221" | GAPPNIV="222" | GAPPNIV="212") : [M]TRT(J)=3 : Endif
     Endif
    Next
   When 2 : #Budget exercice
    If GDEBAPP=1
     For J=0 To [M]NBLIG-1
      If [M]TYP(J)=3 & [M]ENV(J)=[M]ENV(nolign-1) & [M]FIY(J)=[M]FIY(nolign-1) & J<>(nolign-1)
       If GAPPNIV="222" | GAPPNIV="122" : [M]TRT(J)=3 : Endif
      Endif
     Next
    Endif
  Endcase
 Endif
#Else
# #Si on ne fait rien
# #Si nous ne sommes pas dans le cas d'une approbation multiple
# If [M]TYP(nolign-1)<>4
#  #Vérif que niveau d'en dessous non coché
#  Case TYP(nolign-1)
#   When 1 : #Enveloppe
#    For J=0 To [M]NBLIG-1
#     If [M]TYP(J)<>1 & [M]ENV(J)=[M]ENV(nolign-1) & J<>(nolign-1) & [M]TRT(J)=2
#      [M]TRT(J)=1
#     Endif
#    Next
#   When 2 : #Budget exercice
#    If GDEBAPP=1
#     For J=0 To [M]NBLIG-1
#      If [M]TYP(J)=3 & [M]ENV(J)=[M]ENV(nolign-1) & [M]FIY(J)=[M]FIY(nolign-1) & J<>(nolign-1) & [M]TRT(J)=2
#       [M]TRT(J)=1
#      Endif
#     Next
#    Endif
#  Endcase
# Endif
Endif
[M]TRT(nolign-1)=VALEUR
Affzo [M]
End

Subprog AS_RENTXT(VALEUR)
Variable Char    VALEUR()
If [M]TRT(nolign-1)=1
 mkstat = 1 : End
Endif
End

Subprog C_RENTXT(VALEUR)
Variable Char    VALEUR()
If [M]TRT(nolign-1)=3
 If VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Else
  #Héritage du motif pour les autres niveaux
  For I=0 To [M]NBLIG-1
   If I<>(nolign-1) & [M]ENV(I)=[M]ENV(nolign-1) & [M]TYP(I)<[M]TYP(nolign-1) & [M]RENTXT(I)=""
    [M]RENTXT(I)=VALEUR
    Affzo [M]RENTXT(I)
   Endif
  Next
 Endif
Endif
End

Subprog CL_COCHAPP(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]TRT(0)=2
  COCHE=1
 Else
  COCHE=2
 Endif
 For I=0 To [M]NBLIG-1
  [M]TRT(I)=COCHE
 Next
 Affzo [M]
Endif
End

Subprog CL_COCHREF(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]TRT(0)=3
  COCHE=1
 Else
  COCHE=3
 Endif
 For I=0 To [M]NBLIG-1
  [M]TRT(I)=COCHE
 Next
 Affzo [M]
Endif
End

