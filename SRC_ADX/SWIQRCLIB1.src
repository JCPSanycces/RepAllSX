######################################################################################################
# Project       : Swiss Localization
# File          : SWIQRCLIB1
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 18.05.2018
######################################################################################################
# Module        : Purchasing / AP/AR Accounting
# Description   : - QR code handling in purchase invoices (GESBIS / GESPIH)
#                 Calls some functions from SWIBVRLIB4
######################################################################################################
# Updates :
# Date       |Author   |Version|Description
# 2018-06-12 |Bader    |2018.R5|X3-95015 SET_AMOUNT_PIH: get VAT from QR code screen and calculate amount - tax
# 2018-06-21 |Bader    |2018.R6|X3-95015 OK_QRC_BIS: set correct BPNAMES and addresses
# 2018-07-30 |Bader    |2018.R?|X3-99013 don't set [M]BVRBID (only for ISR not for QR)
######################################################################################################

# OK_QRC: OK button pressed after entering the QR code -> QR code is checked and invoice is completed
#*****************************************************************************************************
Subprog OK_QRC()
Local Decimal AMOUNT
Local Char    BVRBID_(GLONBID)
Local Char    BIDNUM_(GLONBID)
Local Integer TYPE_PAM
Local Char    PAYTO_(GLONBPS)
Local Char    SUPPLIER_(GLONBPS)
Local Decimal VAT
Local Integer NEWINV, KO, I
Local Char    INTERM(20)
Local Integer SWIPAMBVR, TMPMSK

If !clalev([F:BID])  : Local File BID [BID]        : Endif
If !clalev([F:TPV])  : Local File TABPIVTYP [TPV]  : Endif
If !clalev([F:XFCY]) : Local File FACILITY [XFCY]  : Endif
If !clalev([F:XBID]) : Local File BID [XBID]       : Endif

Raz AMOUNT : Raz BIDNUM_ : Raz TYPE_PAM : Raz PAYTO_
Raz VAT : Raz NEWINV : Raz KO : Raz SUPPLIER_ : Raz BVRBID_

If [F:SWIQRC]QRCODTYP = "SPC"      # valid QR code?
    If GFONCTION = "GESBIS" Then   # Supplier BP invoice
       Gosub OK_QRC_BIS
    Elsif GFONCTION = "GESPIH"     # Invoice contol
       Gosub OK_QRC_PIH
    Endif
Endif
End
#*****************************************************************************************************

#*****************************************************************************************************
# OK_QRC_BIS: called by OK_QRC for supplier BP invoices -> QR code is checked and invoice is completed
#*****************************************************************************************************
$OK_QRC_BIS
    NEWINV=2
    Gosub FIND_PAYTO
    Gosub FIND_SUPPLIER From SWIBVRLIB4  # find supplier belonging to pay-to supplier

    Default Mask [M:BIS0]
    Default Mask [M:BIS1]

    Call LECTURE("BPS",PAYTO_,"") From CONTOBJ
    [F:XBPS] = [F:BPS]                           # needed for SWIBVRLIB4
    Call LECTURE("BPR",PAYTO_,"") From CONTOBJ
    [M:BIS1]BPRPAY=PAYTO_
    [M:BIS1]BPYNAM(0)=[F:BPR]BPRNAM(0)
    [M:BIS1]BPYNAM(1)=[F:BPR]BPRNAM(1)
    Read [BPA]BPA0 = 1;PAYTO_;[F:BPS]BPAPAY
    If !fstat
      For I=0 To min(dim([M:BIS1]BPYADDLIG),dim([F:BPA]BPAADDLIG))-1
       [M:BIS1]BPYADDLIG(I) = [F:BPA]BPAADDLIG(I)
      Next I
      [M:BIS1]BPYPOSCOD = [F:BPA]POSCOD
      [M:BIS1]BPYCTY    = [F:BPA]CTY
      [M:BIS1]BPYCRY    = [F:BPA]CRY
      [M:BIS1]BPYSAT    = [F:BPA]SAT
      If [F:BPA]CRYNAM<>""
       [M:BIS1]BPYCRYNAM = [F:BPA]CRYNAM
      Else
       [M:BIS1]BPYCRYNAM=""
       Call INIPAYS([F:BPA]CRY,[M:BIS1]BPYCRYNAM) From TRTDIV
      Endif
    Endif

    Call LECTURE("BPS",SUPPLIER_,"") From CONTOBJ
    Call LECTURE("BPR",SUPPLIER_,"") From CONTOBJ
    [M:BIS0]BPR=SUPPLIER_
    [M:BIS0]BPRNAM=[F:BPS]BPSNAM
    [M:BIS0]BPRNAMBIS(0)=[F:BPS]BPSNAM
    [M:BIS0]BPRNAMBIS(1)=[F:BPR]BPRNAM(1)
    Read [BPA]BPA0 = 1;SUPPLIER_;[F:BPS]BPAPAY
    If !fstat
      For I=0 To min(dim([M:BIS0]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
       [M:BIS0]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
      Next I
      [M:BIS0]POSCOD = [F:BPA]POSCOD
      [M:BIS0]CTY    = [F:BPA]CTY
      [M:BIS0]CRY    = [F:BPA]CRY
      [M:BIS0]SAT    = [F:BPA]SAT
      If [F:BPA]CRYNAM<>""
       [M:BIS0]CRYNAM = [F:BPA]CRYNAM
      Else
       [M:BIS0]CRYNAM=""
       Call INIPAYS([F:BPA]CRY,[M:BIS0]CRYNAM) From TRTDIV
      Endif
    Endif

    [M:BIS1]PTE=[F:BPS]PTE
    Call C_PTE([M:BIS1]PTE) From SUBBIS2
    [M:BIS1]DEP=[F:BPS]DEP
    Call AM_DEP([M:BIS1]DEP) From SUBBIS2
    [M:BIS1]PURPRITYP=[F:BPS]PURPRITYP
    Call AM_PURPRITYP([M:BIS1]PURPRITYP) From SUBBIS2
    Affzo [M:BIS0] : Affzo [M:BIS1]PTE : Affzo [M:BIS1]DEP : Affzo [M:BIS1]BPRPAY

    # set accounting date
    If [M:BIS0]ACCDAT=[0/0/0]
        [M:BIS0]ACCDAT=datesyst
    Endif

    Local Char CODCPT(GLONCAC)
    Call INIT_COMPTE([M:BIS0]BPR,GSOCIETE,"F",CODCPT) From CPTSUB
    If [L]CODCPT<>""
       Call LECTURE("CAC",[L]CODCPT,"3~"+GPLAN(1)) From CONTOBJ
       INTERM = [F:CAC]ACC(0)
    Endif

    If INTERM<>""
       Call LECTURE("GAC",INTERM,GPLAN(1)) From CONTOBJ
       If !fstat & [F:GAC]SAC=2
          [M:BIS0]BPRSAC= [F:GAC]ACCSHO
          [M:BIS0]SACACC = [F:GAC]ACC
       Else
          [M:BIS0]BPRSAC = ""
          Raz [M:BIS0]SACACC
       Endif
    Endif

    [M:BIS1]BPRDAT=[M:BIS0]ACCDAT : # date of original document

    Call LEC_TPV_LEG(GCURLEG,[M:BIS0]PIVTYP) From CPTLEC
    Gosub SET_PIVTYP From SUBBIS
    Call AM_BPRDAT([M:BIS1]BPRDAT) From SUBBICS

    If [F:SWIQRC]CUR <> ""
        [M:BIS1]CUR = [F:SWIQRC]CUR     # currency
    Else
        [M:BIS1]CUR = [F:BPR]CUR : # currency
    Endif
    [M:BIS1]STA=2 : # invoice
    [M:BIS1]STRDUDDAT = [M:BIS1]BPRDAT : # Due date basis
    Call INIT_REGIME([M:BIS0]BPR,[M:BIS0]FCY,"F",[M:BIS1]VAC) From CPTSUB : # tax
    If dim([F:BPS]CHGTYP)>0  : # currency type
        [M:BIS1]CURTYP= [F:BPS]CHGTYP
    Else
        [M:BIS1]CURTYP = 1
    Endif

    Call INI_COURS("BIS1",[M:BIS0]CPY,[M:BIS1]CUR,[M:BIS1]RATDAT,[M:BIS1]CURTYP) From SUBBICS # UBA

    Affzo [M:BIS0] : Affzo [M:BIS1]

    TMPMSK = 1
    Call VERIF_DTA_(TYPE_PAM,SWIPAMBVR,TMPMSK) From SWIBVRLIB4 # get PAM type

    # check consistency between QR code and payment method
    Local Integer OK_ : Raz OK_
    If TYPE_PAM = 3
#        Call VERIF_QR(TYPE_PAM,OK_)
    Endif

    If [F:SWIQRC]AMT <> ""                    # if amount in QR code -> take it into screen
        AMOUNT = val([F:SWIQRC]AMT)
        Gosub SET_AMOUNT_BIS From SWIBVRLIB4  # set amounts
    Endif
Return


# ---------------------------------------------------------------------------------------------------
# FIND_PAYTO: find the pay-to supplier either by the QR IBAN code provided by the QR code
# ---------------------------------------------------------------------------------------------------
$FIND_PAYTO
If [F:SWIQRC]IBACOD <> "" and len([F:SWIQRC]IBACOD)>2 and find(left$([F:SWIQRC]IBACOD,2),"CH", "LI") # there is a valid IBAN
    BIDNUM_ = right$([F:SWIQRC]IBACOD,5)
    Call FIND_PAYTO_BY_BIDNUM(BIDNUM_, PAYTO_)  : # look for the pay-to supplier
Endif
Return


#-----------------------------------------------------------------------------------------------------
# Search the pay-to supplier by a given BIDNUM (in QR code we have the complete IBAN and cut off the first 4 characters)
#-----------------------------------------------------------------------------------------------------
Subprog FIND_PAYTO_BY_BIDNUM(BIDNUM_, PAYTO_)
Variable Char BIDNUM_    # BID number (= QR IBAN without 4 first characters)
Variable Char PAYTO_     # pay-to supplier

Local Integer COUNT1
Local Integer VALEUR2
Local Char T1(GLONBPS), T2(20)
Local Integer REP
Local Char TEMP(50)
Local Integer NBRIB_
Local Char TIT(50)

Raz COUNT1,T1,T2
TEMP = ""
TIT=mess(81,3648,1) # Please select a pay-to supplier.

# Link BID table with BPSUPPLIER table to be able to sort by supplier name instead of supplier number
Link [F:BID] With [F:BPS]BPS0=[F:BID]BPANUM As [LBID]
&            Where [F:BID]BPATYP = 1 and [F:BID]BIDNUM = BIDNUM_
&            Order By Key LBIDK = [F:BPS]BPSNAM Asc

# create an array for the selection of a supplier. Length of the array depends on number of found accounts with BIDNUM = BIDNUM_
NBRIB_ = rowcount([F:LBID])
Local Char TBLIB (50) (NBRIB_+5)

For [F:LBID]
   If [F:BID]BPANUM <> TEMP
    COUNT1 += 1
    PAYTO_ = [F:BID]BPANUM
    Call LECTURE("BPS",[F:BID]BPANUM,"") From CONTOBJ
    TBLIB(COUNT1)=[F:BID]BPANUM+" "+[F:BPS]BPSNAM
    TEMP = [F:BID]BPANUM
   Endif
Next

If COUNT1>1 # more than 1 found
    Call SEL_SUPPLIER(COUNT1,TBLIB,TIT,PAYTO_) From SWIBVRLIB4
    # loop until a supplier has been chosen
    While  PAYTO_=""
        Call OUINON(mess(76,3648,1),REP) From GESECRAN # You didn't select a supplier. Wasn't he on the list?
        If REP=1
            Call SEL_SUPPLIER(COUNT1,TBLIB,TIT,PAYTO_) From SWIBVRLIB4
        Else
            Gosub SEL_SUPPLIER2 From SWIBVRLIB4
        Endif
    Wend
Elsif COUNT1=0 # nothing found -> tunnel to supplier management to choose a supplier
    Gosub SEL_SUPPLIER2 From SWIBVRLIB4
    While PAYTO_=""
        GERR=2 : GMESSAGE=mess(77,3648,1) # Please select a supplier.
        Gosub SEL_SUPPLIER2 From SWIBVRLIB4
    Wend
Endif
End
#-----------------------------------------------------------------------------------------------------


#*****************************************************************************************************
# OK_QRC_PIH: called by OK_QRC for invoice control -> QR code is checked and invoice is completed
#*****************************************************************************************************
$OK_QRC_PIH
If ([M:PIH0]BPR<>"" and [M:PIH1]PTE<>"")  # The supplier and the payment term are entered -> we suppose the invoice already exists
    NEWINV=1
    Gosub FIND_PAYTO

    If PAYTO_<>"" & [M:PIH1]BPRPAY<>PAYTO_   # found pay-to supplier differs from "pay to" supplier in invoice
        Call OUINON(mess(75,3648,1),KO) From GESECRAN  : # The supplier on the ISR reference line is different from the pay-to supplier. Do you want to update the pay-to supplier?
        If KO=2  # if yes
            [M:PIH1]BPRPAY=PAYTO_
            Affzo [M:PIH1]BPRPAY
            mkstat=4
        Endif
    Endif

    Gosub DO_CUR_AND_ADR From SWIBVRLIB4

    If [F:SWIQRC]AMT <> ""                   # if amount in QR code -> take it into screen
        AMOUNT = val([F:SWIQRC]AMT)
        Gosub SET_AMOUNT_PIH                 # set amounts
    Endif
Else  # new invoice to be created
    NEWINV=2
    Gosub FIND_PAYTO
    Gosub FIND_SUPPLIER From SWIBVRLIB4 # find supplier belonging to pay-to supplier

    Read [F:XBPS]BPS0=SUPPLIER_
    If fstat=0
        [M:PIH0]BPR=SUPPLIER_
        [M:PIH1]BPRPAY = PAYTO_
        [M:PIH0]BPRNAM1=[F:XBPS]BPSNAM
        [M:PIH1]PTE=[F:XBPS]PTE
        Call C_PTE([F:XBPS]PTE) From SUBPIH
        [M:PIH1]DEP=[F:XBPS]DEP
        Call AM_DEP([F:XBPS]DEP) From SUBPIH
        Affzo [M:PIH0] : Affzo [M:PIH1]PTE : Affzo [M:PIH1]DEP
    Endif

    # set accounting date
    If [M:PIH0]ACCDAT=[0/0/0]
        [M:PIH0]ACCDAT=datesyst
    Endif

    Local Char CODCPT(GLONCAC)
    Call INIT_COMPTE([M:PIH0]BPR,GSOCIETE,"F",CODCPT) From CPTSUB
    Call LECTURE("CAC",[L]CODCPT,"3~"+GCOA(1)) From CONTOBJ
    Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(1))  From CONTOBJ
    If !fstat & [F:GAC]SAC=2 [M:PIH0]BPRSAC=[F:GAC]ACCSHO : Endif

    [M:PIH1]BPRDAT=[M:PIH0]ACCDAT : # date of original document
    If [F:SWIQRC]CUR <> ""
        [M:PIH1]CUR = [F:SWIQRC]CUR     # currency
    Else
        Call LECTURE("BPR",[M:PIH0]BPR,"") From CONTOBJ
        [M:PIH1]CUR = [F:BPR]CUR :      # currency
    Endif
    [M:PIH0]PAZ=4 :                 # Authorized to pay

    If [M:PIH0]PIVTYP = ""                                    # don't change PIVTYP if already entered by user
       Call PARAM([M:PIH0]FCY,"TYPINVSUP",[M:PIH0]PIVTYP) From ADOVAL
       Call LEC_TPV_LEG(GCURLEG,[M:PIH0]PIVTYP) From CPTLEC
       Call AM_PIVTYP([M:PIH0]PIVTYP) From SUBPIH
    Endif

    [M:PIH1]STA=2 : # Status = to validate

    Gosub DO_CUR_AND_ADR From SWIBVRLIB4

    [M:PIH1]STRDUDDAT = [M:PIH1]BPRDAT      # Due date basis
    Call INIT_REGIME([M:PIH0]BPR,[M:PIH0]FCY,"F",[M:PIH1]VAC) From CPTSUB  # tax
    If dim([F:XBPS]CHGTYP)>0                # currency type
        [M:PIH1]CURTYP= [F:XBPS]CHGTYP
    Else
        [M:PIH1]CURTYP = 1
    Endif

    Call INI_COURS("PIH1",GSOCIETE,[M:PIH1]CUR,[M:PIH1]RATDAT,[M:PIH1]CURTYP) From SUBBICS

    Default Mask [M:PIH0]
    Affzo [M:PIH0] : Affzo [M:PIH1]

    TMPMSK = 2
    Call VERIF_DTA_(TYPE_PAM,SWIPAMBVR,TMPMSK) From SWIBVRLIB4 # get PAM type

    # check consistency between QR code and payment method
    Local Integer OK_ : Raz OK_
    If TYPE_PAM = 3
#        Call VERIF_QR(TYPE_PAM,OK_)
    Endif

    If [F:SWIQRC]AMT <> ""                    # if amount in QR code -> take it into screen
        AMOUNT = val([F:SWIQRC]AMT)
        Gosub SET_AMOUNT_PIH                  # set amounts
    Endif
Endif
Return


#-----------------------------------------------------------------------------------------------------
# Set new values in screens PIH1/PIH4
#-----------------------------------------------------------------------------------------------------
$SET_AMOUNT_PIH
Local Integer OK

If AMOUNT <> [M:PIH1]TOTATIAMT1  # amounts differ
    OK = 2
    If !GIMPORT
        If NEWINV<>2
            Call OUINON(mess(78,3648,1),OK) From GESECRAN # Totals incoherent. Do you want to update it?
        Endif
    Endif

    If OK<>2
        OK = 0 : Return
    Else
        [M:PIH1]TOTTAXAMT1 = [M:SWIQRC]TOTVAT
        [M:PIH4]TOTTAXAMT = [M:SWIQRC]TOTVAT
        [M:PIH1]TOTLINAMT1= AMOUNT-[M:PIH1]TOTTAXAMT1
        [M:PIH4]TOTLINAMT= AMOUNT-[M:PIH1]TOTTAXAMT1

        Default Mask [M:PIH1]

        If !GIMPORT
            Affzo [M:PIH1]TOTLINAMT1, TOTATIAMT1,TOTTAXAMT1
            Default Mask [M:PIH0] : Affzo [M:PIH4]
        Endif
        mkstat=4
    Endif
Endif
Return
#-----------------------------------------------------------------------------------------------------

