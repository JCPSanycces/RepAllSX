#<AdxTL>@(#)0.0.0.0 $Revision$
$SCHGH
Gosub OPEN_LNK_SGH From SAFTGENPORMG
For [F:MGT3]
   Read [F:PTDK2]DKD0="SAFT-PT";[F:PTSGH]SGHTYP;[F:PTSGH]VCRNUM
   Call LEC_TSG_LEG([F:PTFCY]LEG, [F:PTSGH]SGHTYP,[L]STAT) From TRTLECLEG
   If [L]SAFTTYPE = 8
     If !find([F:PTDK2]RECTYP,1) : Goto NEXTSGH2 : Endif
     If func PORLEGLIB1.CTRL_COMDAT([F:PTSGH]STOFCY,[F:PTSGH]DPEDAT,[F:PTSGH]ETD) <> 1 : Goto NEXTSGH2 : Endif
   Endif

   Gosub RAZVAR_MG From SAFTGENPORMG
   Gosub FEED_VARS
   $NEXTSGH2
Next
Gosub CLOSE_LNK_SGH From SAFTGENPORMG

Return

$FEED_VARS
#DocumentNumber
Call PTNUMDOC([F:PTSGH]SGHTYP,[F:PTSGH]VCRNUM,[L]MGDOCNUMB) From SAFTGENPORMG

#ATCUD
[L]MGATCUD = "0"

#MovementStatuts
[L]MGMOVSTAT = 'N'
#SystemEntryDate, Reason, SourceID(Modificacao), Hash, HashControl, SourceID(Criacao), ATDocCodeID,SourceID
# Issue 105227 - 2015-08-21 by BRBAN :[L]MGMOVTYPE - MovementType must come from DKSDATA
If [F:PTDK2]RECTYP=4 #External document
  Call DOCSTAT([F:PTSGH]SGHTYP,[F:PTSGH]VCRNUM,[F:PTSGH]IPTDAT,2,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Else
  Call DOCSTAT([F:PTSGH]SGHTYP,[F:PTSGH]VCRNUM,[F:PTSGH]IPTDAT,1,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Endif

#MovementType
# Issue 105227 - 2015-08-21 by BRBAN : If it's null, then fill with [F:TSG]SAFTTRNTYP
# RMA * Do not change, this is for previous cases when we didn't have SAFTTRNTYP on DKSDATA
If [L]MGMOVTYPE=''
  Call MANDOC_TEXT_GT([F:TSG]RECTYP,[F:TSG]SAFTTRNTYP,[L]MGMOVTYPE) From PORLEGLIB
Endif

If [L]MGCREUSER = ''
  [L]MGCREUSER = [F:PTSGH]CREUSR
Endif

#MovementStatusDate
[L]MGMOVSTDT = [L]MGSYSENTD
#SourceID -> DocumentStatus
[L]MGUPDUSER = [L]MGCREUSER
#Period
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
Call LEC_FCY([F:PTSGH]STOFCY) From CPTLEC
[L]MGPERIODE  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:FCY]LEGCPY, [F:PTSGH]IPTDAT)
Filter [F:FCY]
#Issue end
#MovementDate
[L]MGMOVEDAT  =  format$("D:YYYY[-]MM[-]DD",[F:PTSGH]IPTDAT)

#TransactionID
If [L]SAFTTYPE=2
  Filter [F:PTSTJ] Where VCRNUM=[F:PTSGH]VCRNUM & STOFCY= [F:PTSGH]STOFCY
  Read [F:PTSTJ] First
  If !fstat
    Read [F:HAE]HAE0 = [F:PTSTJ]GTE;[F:PTSTJ]NUMVCR
    If !fstat
      If len([F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/",""))>20
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + ctrans([F:HAE]NUM,"_-.\/","")
      Else
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + [F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/","")
      Endif
    Endif
  Endif
  Filter [F:PTSTJ]
Endif

#CustomerID,SupplierID
Case [F:PTSGH]BETFCYCOD
  When 4,5
    [L]MGSUPPLID = [F:PTSGH]BPSNUM
    [L]MGCUSTOID = ""
  When 2
    [L]MGSUPPLID = ""
    Read [F:PTFC2]FCY0=[F:PTSGH]FCYDES
    If !fstat
      [L]MGCUSTOID =  [F:PTFC2]LEGCPY
    Endif
Endcase

#MovementComments
[L]MGCOMMENT = ""
#DeliveryID
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
[L]MGDELIVID = vireblc([F:PTSGH]LICPLATE-[F:PTSGH]TRLLICPLATE, 2)
If [L]MGDELIVID = ""
  [L]MGDELIVID = "Desconhecido"
Endif
#Issue end
#DeliveryDate
[L]MGDELIVDT = [F:PTSGH]IPTDAT

#LocationID
[L]MGLOCATID = ""
#BuildingNumber
[L]MGBUIDNBR = "Desconhecido"

#ShipTo
Case [F:PTSGH]BETFCYCOD
  When 4,5
    #WarehouseID
    [L]MGWAREHID_ST = ""
    #StreetName,AddressDetail,City,PostalCode,Region
    Call ADDRESS(1,[F:PTSGH]BPSNUM,[F:PTSGH]BPSADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
  When 2
    #WarehouseID
    [L]MGWAREHID_ST = [F:PTSGH]FCYDES
    #StreetName,AddressDetail,City,PostalCode,Region
    Call ADDRESS(3,[F:PTSGH]FCYDES,[F:PTSGH]FCYADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
Endcase
If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

#ShipFrom
#WarehouseID
[L]MGWAREHID_SF = [F:PTSGH]STOFCY
#StreetName,AddressDetail,City,PostalCode,Region
Call ADDRESS(3,[F:PTSGH]STOFCY,[F:PTFCY]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
GPOINT = "SPESF" : Gosub ENTREE From EXEFNC
If [L]SPEMGSTREETN<>''
  [L]MGSTREETN_SF = [L]SPEMGSTREETN
Endif
If [L]SPEMGADDDETA<>''
  [L]MGADDDETA_SF = [L]SPEMGADDDETA
Endif
If [L]SPEMGCITY<>''
  [L]MGCITY_SF = [L]SPEMGCITY
Endif
If [L]SPEMGPOSTCOD<>''
  [L]MGPOSTCOD_SF = [L]SPEMGPOSTCOD
Endif
If [L]SPEMGREGION<>''
  [L]MGREGION_SF = [L]SPEMGREGION
Endif
If [L]SPEMGCOUNTRY<>''
  [L]MGCOUNTRY_SF = [L]SPEMGCOUNTRY
Endif

If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

#-

#MovementEndTime
If [F:PTSGH]ARVDAT<>[0/0/0] & [F:PTSGH]ETA<>"0000"
  [L]MGMOVENDT = format$("D:YYYY[-]MM[-]DD",[F:PTSGH]ARVDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSGH]ETA,":","")+"00")
Endif
#MovementStartTime
If [F:PTSGH]DPEDAT<>[0/0/0] & [F:PTSGH]ETD<>"0000"
  [L]MGMOVSTRT = format$("D:YYYY[-]MM[-]DD",[F:PTSGH]DPEDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTSGH]ETD,":","")+"00")
Else
  Call ECR_TRACE (mess(22,701,1)-[F:PTSGH]VCRNUM-mess(236,7711,1), 1) From GESECRAN
Endif
#Gosub SET_TZ From PORLEGLIB1

#VEHICLEID
[L]VEHICLEID = [F:PTSGH]LICPLATE+[F:PTSGH]TRLLICPLATE

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_H From SAFTGENPORMG
Endif

For [F:PTSGD] Where VCRNUM=[F:PTSGH]VCRNUM
  Gosub RAZVAR_MG_D From SAFTGENPORMG
  #LineNumber
  #[L]MGDLINNBR =  [F:PTSGD]VCRLIN
  [L]MGDLINNBR += 1
  #OriginatingON
  [L]MGDORIGIN  = ""
  #-
  #OrderDate
  [L]MGDORDDAT=[0/0/0]
  #ProductCode
  [L]MGDPRODUC = [F:PTSGD]ITMREF
  #ProductDescription
  Read [F:ITM]ITM0=[F:PTSGD]ITMREF
  If !fstat
    If [F:ITM]ITMDES1<>""
      [L]MGDPRODES = [F:ITM]ITMDES1
    Else
      [L]MGDPRODES = "Desconhecido"
    Endif
  Else
      [L]MGDPRODES = "Desconhecido"
  Endif

  #Quantity
  [L]MGDQUANTI  = [F:PTSGD]QTYSTUDES
  #UnitOfMeasure
  [L]MGDUOM    = [F:PTSGD]STU
  #UnitPrice
  [L]MGDNETPRI = 0
  #Description
  If[F:PTSGD]ITMDES1<>""
    [L]MGDLINDES = [F:PTSGD]ITMDES1
  Else
    [L]MGDLINDES = "Desconhecido"
  Endif
  #DebitAmount/CreditAmount
  [L]MGDDEBAMT = 0
  [L]MGDCREAMT = 0

  [L]MGDTAXPER = 0

  #SettlementAmount
  [L]MGDSETAMT = 0

  # Issue X3-31864 - 2017-05-08 by VV: Serial numbers
  If [F:ITM]ITMREF <> [F:PTSGD]ITMREF
    Read [F:ITM]ITM0 = [F:PTSGD]ITMREF
  Endif
  If [F:ITM]SERMGTCOD > 1
    For [F:STJ]STJ1 Where [F:STJ]STOFCY = [F:PTSGH]STOFCY & [F:STJ]VCRTYP = 29 & [F:STJ]VCRNUM = [F:PTSGH]VCRNUM & [F:STJ]VCRLIN = [F:PTSGD]VCRLIN & [F:STJ]SERNUM <> ""
      [L]SDLSERNUM(maxtab([L]SDLSERNUM)+1)=[F:STJ]SERNUM
    Next
  Endif

  If [L]SAFTWAY=1
    Gosub WRITE_MOVEG_D From SAFTGENPORMG
  Else
    Gosub FEED_VAR_WS From PORLEGLIB1
  Endif
Next
#TaxPayable
[L]MGTTAXPAY = 0
#NetTotal
[L]MGTNETTOT = 0
#GrossTotal
[L]MGTGROTOT = 0
#CurrencyAmount
[L]MGTCURAMT = 0
#CurrencyCode
[L]MGTCURCOD = ''
#ExchangeRate
[L]MGTEXCRAT = 1

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_T From SAFTGENPORMG
Endif

Return

