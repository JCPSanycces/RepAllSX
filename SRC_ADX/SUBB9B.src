#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
#    Process Name:    SUBB9B - 1099 Beginning Balance
#                     NA 1099 Enhancement 
#    Authors:          RxS,JrB Oct 11 2011
#
#    Modifications:
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "SETBOUT"     : Gosub SETBOUT
  When "LIENS"       : Gosub LIENS  
  When "VERIF_CRE"   : Gosub VERIF
  When "VERIF_MOD"   : Gosub VERIF
  When "VERF_ANU"    : Gosub VERIF
Endcase

Return

####################################################################################
$OUVRE

If clalev([F:BPS])=0 : Local File BPSUPPLIER  [BPS] : Endif # Used by TEN99LIB code
If clalev([F:B9G])=0 : Local File BPS1099GEN  [B9G] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
Gosub OUVRE From TEN99LIB    #1099.n Open BOX1099 [BX9] and set GS1099

Return
####################################################################################
$LIENS

[M]FRMBOX(nolign-1) = num$([F:B9B]FRM1099) + "/" + [F:B9B]BOX1099
  
Return
####################################################################################
$SETBOUT

# Enable Delete button
If [M:B9B1]NBBAN > 0
    CHAINE += "A"
Endif

Return

####################################################################################
$VERIF

Look [F:B9G]B9G1 = [M:B9B1]YR1099;[M:B9B1]CPY;[M:B9B1]BPSNUM
If [S]fstat <=2 # Generate record exists     
  If GREP="A"
  Call OUINON(mess(82,122,1),XOK) From GESECRAN
  Else
  Call OUINON(mess(81,122,1),XOK) From GESECRAN # Warning message prompt
  Endif
  If XOK<>2
    GERR=1 
    OK=0              
  Endif            
Endif 

Return
####################################################################################
Subprog AS_FRM1099(VALEUR)
##########################################################################
# Limit the drop down options                                            #
#                                                                        #
# Balance rowfor actual 1099 Form Types D, I, M                          #
##########################################################################

Variable Integer VALEUR

GMENLOC(1) = 1  # Remove "None" from valid values.

End

Subprog D_YR1099(VALEUR)
##########################################################################
# Default last year if before June, else default current  year           #
#                                                                        #
##########################################################################

Variable Decimal VALEUR

If month(date$) < 6
 VALEUR = year(date$) - 1
Else
 VALEUR = year(date$)
Endif
End
######################################################################################
Subprog C_BOX1099(VALEUR)
Variable Char    VALEUR()

  [M]FRMBOX(nolign-1) = num$([M]FRM1099(nolign-1)) + "/" + VALEUR
  Call UNICITE([M]FRMBOX(nolign-1), [M]FRMBOX) From OBJDIV

End


######################################################################################

######################################################################################
## Section automatically added (screen B9B1) 02/01/2012 17:19:40 (EWI)
######################################################################################
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
Read [CPY]CPY0=VALEUR 
 If !fstat
  [M:B9B1]CUR = [F:CPY]ACCCUR
 Else
  Raz [CPY]
 Endif
 Affzo [M:B9B1]CUR

End


######################################################################################


