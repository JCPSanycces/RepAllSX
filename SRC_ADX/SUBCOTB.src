#<AdxTL>@(#)9.0.0.0 $Revision$
#############################################################################################
#   Programmes utilitaires pour la gestion des modèles de contrats de services 
#
#   SETGRAY      : Grise ou dégrise des champs.
#   SETTZN       : Gestion du nommage des étiquettes de champs
#   MNGCOTCURCHG : Gère la modification de la devise du modèle de contrat
#   CHECKREWINV  : Vérifie sur la fréquence de facturation n'est pas supérieure à la fréquence de renouvellement.
#
#############################################################################################
#############################################################################################
# Grise ou dégrise certains champs
####################################################################
Subprog SETGRAY
  #Active ou désactive les champs associés aux éléments financiers
  #Fréquence de renouvellement
  If [M:COT2]REWFRY > 0 Then
    Actzo [M:COT2]REWFRYBAS
  Else
    [M:COT2]REWFRYBAS = 6
    Grizo [M:COT2]REWFRYBAS
  Endif
  #Préavis de résiliation
  If [M:COT2]RSILTI > 0 Then
    Actzo [M:COT2]RSILTIBAS
  Else
    [M:COT2]RSILTIBAS = 6
    Grizo [M:COT2]RSILTIBAS
  Endif
  #Dépendant de la catégorie
  Case [M:COT1]CONCAT
    When 1    #Garantie
      Actzo [M:COT1]EVRPBL
      Actzo [M:COT1]EVRMAC
      Actzo [M:COT2]CONREW
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        [M:COT2]PITCDT = 0
        If type([M:COT2]PITRQD) > 0 Then
          [M:COT2]PITRQD = 0
        Endif
        [M:COT2]PITTOL = 0
        Grizo [M:COT2]PITCDT
        If type([M:COT2]PITRQD) > 0 Then
          Grizo [M:COT2]PITRQD
        Endif
        Grizo [M:COT2]PITTOL
      Endif
      #Facturation et litiges acceptés
      [M:COT3]INVFRY = 0
      [M:COT3]INVFRYBAS = 6
      [M:COT3]INVFRYCOE = 1
      [M:COT3]INVLTI = 0
      [M:COT3]INVLTIBAS = 6
      Grizo [M:COT3]
      #Réévaluation
      [M:COT2]RVAFRY = 0
      [M:COT2]RVAFRYBAS = 6
      [M:COT2]CONBASIDX = ""
      [M:COT2]CONBASFOR = ""
      Grizo [M:COT2]10
    When 2,3    #Entretien et Maintenance
      Actzo [M:COT1]EVRPBL
      Actzo [M:COT1]EVRMAC
      Actzo [M:COT2]CONREW
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        [M:COT2]PITCDT = 0
        If type([M:COT2]PITRQD) > 0 Then
          [M:COT2]PITRQD = 0
        Endif
        [M:COT2]PITTOL = 0
        Grizo [M:COT2]PITCDT
        If type([M:COT2]PITRQD) > 0 Then
          Grizo [M:COT2]PITRQD
        Endif
        Grizo [M:COT2]PITTOL
      Endif
      #Facturation et litiges acceptés
      Actzo [M:COT3]
      If [M:COT3]INVFRY > 0 Then
        Actzo [M:COT3]INVFRYBAS
      Else
        [M:COT3]INVFRYBAS = 6
        Grizo [M:COT3]INVFRYBAS
      Endif
      If [M:COT3]INVLTI > 0 Then
        Actzo [M:COT3]INVLTIBAS
      Else
        [M:COT3]INVLTIBAS = 6
        Grizo [M:COT3]INVLTIBAS
      Endif
      #Réévaluation
      Actzo [M:COT2]10
      If [M:COT2]RVAFRY > 0 Then
        If [M:COT2]RVASSP = 1 Then
          Actzo [M:COT2]RVAFRYBAS
          Actzo [M:COT2]CONBASIDX
          Grizo [M:COT2]CONBASFOR
        Elsif [M:COT2]RVASSP = 2 Then
          Actzo [M:COT2]RVAFRYBAS
          Grizo [M:COT2]CONBASIDX
          Actzo [M:COT2]CONBASFOR
        Else
          Grizo [M:COT2]RVAFRYBAS
          Grizo [M:COT2]CONBASIDX
          Grizo [M:COT2]CONBASFOR
        Endif
      Else
        [M:COT2]RVAFRYBAS = 6
        Grizo [M:COT2]RVAFRYBAS
        Grizo [M:COT2]CONBASIDX
        Grizo [M:COT2]CONBASFOR
      Endif
    When 4
      [M:COT1]EVRMAC = 2
      [M:COT1]EVRPBL = 2
      [M:COT1]CRSCOVSAM = 2
      Grizo [M:COT1]EVRPBL
      Grizo [M:COT1]EVRMAC
      [M:COT2]CONREW = 1
      Grizo [M:COT2]CONREW
      Actzo [M:COT2]PITCDT
      If type([M:COT2]PITRQD) > 0 Then
        Actzo [M:COT2]PITRQD
      Endif
      Actzo [M:COT2]PITTOL
      #Facturation et litiges acceptés
      Actzo [M:COT3]
      [M:COT3]INVFRY = 0
      [M:COT3]INVFRYBAS = 6
      [M:COT3]INVFRYCOE = 1
      Grizo [M:COT3]INVFRY
      Grizo [M:COT3]INVFRYBAS
      Grizo [M:COT3]INVFRYCOE
      If [M:COT3]INVLTI > 0 Then
        Actzo [M:COT3]INVLTIBAS
      Else
        [M:COT3]INVLTIBAS = 6
        Grizo [M:COT3]INVLTIBAS
      Endif
      #Réévaluation
      [M:COT2]RVAFRY = 0
      [M:COT2]RVAFRYBAS = 6
      [M:COT2]CONBASIDX = ""
      [M:COT2]CONBASFOR = ""
      Grizo [M:COT2]10
  Endcase
  #Couverture croisée identique
  If [M:COT1]EVRMAC = 2 Then
    Grizo [M:COT1]CRSCOVSAM
  Else
    Actzo [M:COT1]CRSCOVSAM
  Endif
  Call SETTZN
  Affzo [M:COT1]
  Affzo [M:COT2]
  Affzo [M:COT3]
End

#############################################################################################
# Gestion du nommage des étiquettes de champs
######################################################
Subprog SETTZN
Local Char SZREWFRY
Local Char SZAMT

  If GIMPORT Then
    End
  Endif
  Call TEXTE(16269, SZREWFRY) From OBJDIV      #Fréquence de renouvellement
  Chgtzn [M:COT2]REWFRY With SZREWFRY
  If [M:COT1]CONCAT = 4 Then
    Call TEXTE(14433, SZREWFRY) From OBJDIV    #Durée
    Chgtzn [M:COT2]REWFRY With SZREWFRY
  Else
    If [M:COT2]CONREW <> 2 Then
      Call TEXTE(14433, SZREWFRY) From OBJDIV  #Durée
      Chgtzn [M:COT2]REWFRY With SZREWFRY
    Endif
  Endif
End

#############################################################################################
# Gère la modification de la devise du modèle de contrat
###########################################################
Subprog MNGCOTCURCHG
Local Integer CUROK

  If [M:COT0]OLDCUR = [M:COT0]CUR Then
    End
  Endif
  CUROK = 0
  If [M:COT1]EVRMAC <> 2 Then
    #Voulez-vous mettre à jour les montants relatifs à la couverture article ?
    Call OUINON(mess(414,196,1), CUROK) From GESECRAN
    If CUROK = 2 Then
      Call UPDITMCOV([M:COT0]OLDCUR, [M:COT0]CUR, 2) From TRTCONH
    Endif
  Endif
  #Conversion des contraintes qualités (Pénalités de retard)
  Call UPDQUALCUR([M:COT0]OLDCUR, [M:COT0]CUR, 2) From TRTCON3
End

#############################################################################################
#Vérifie sur la fréquence de facturation n'est pas supérieure à la fréquence de renouvellement.
#############################################################################################
$CHECKREWINV
Local Decimal INBINVDAY
Local Decimal INBREWDAY
Local Decimal INBRVADAY

  INBINVDAY = 0
  INBREWDAY = 0
  INBRVADAY = 0
  #Calcul la fréquence de facturation en nombre de jours
  If [M:COT3]INVFRYBAS = 1 Then
    #heure
    If [M:COT3]INVFRY <= 24 Then
      #La fréquence de facturation ne peut pas être inférieure à une journée.
      GMESSAGE = mess(358,182,1)
      GERR = 2
      OK = 0
      Return
    Else
      INBINVDAY = [M:COT3]INVFRY / 24
    Endif
  Elsif [M:COT3]INVFRYBAS = 2 Then
    #jours
    INBINVDAY = [M:COT3]INVFRY
  Elsif [M:COT3]INVFRYBAS = 3 Then
    #semaine
    INBINVDAY = [M:COT3]INVFRY * 7
  Elsif [M:COT3]INVFRYBAS = 4 Then
    #mois
    INBINVDAY = [M:COT3]INVFRY * (365.25 / 12)
  Elsif [M:COT3]INVFRYBAS = 5 Then
     #année
    INBINVDAY = [M:COT3]INVFRY * 365.25
  Elsif [M:COT3]INVFRYBAS = 6 Then
     #vide
    INBINVDAY = 0
  Endif
  #Calcul la fréquence de renouvellement en nombre de jours
  If [M:COT2]REWFRYBAS = 1 Then
    #heure
    If [M:COT2]REWFRY <= 24 Then
      INBREWDAY = 0
    Else
      INBREWDAY = [M:COT2]REWFRY / 24
    Endif
  Elsif [M:COT2]REWFRYBAS = 2 Then
    #jours
    INBREWDAY = [M:COT2]REWFRY
  Elsif [M:COT2]REWFRYBAS = 3 Then
    #semaine
    INBREWDAY = [M:COT2]REWFRY * 7
  Elsif [M:COT2]REWFRYBAS = 4 Then
    #mois
    INBREWDAY = [M:COT2]REWFRY * (365.25 / 12)
  Elsif [M:COT2]REWFRYBAS = 5 Then
    #année
    INBREWDAY = [M:COT2]REWFRY * 365.25
  Elsif [M:COT2]REWFRYBAS = 6 Then
    #vide
    INBREWDAY = 0
  Endif
  #Calcul la fréquence de réévaluation en nombre de jours
  If [M:COT2]RVAFRYBAS = 1 Then
    #heure
    If [M:COT2]RVAFRY <= 24 Then
      INBRVADAY = -1
    Else
      INBRVADAY = [M:COT2]RVAFRY / 24
    Endif
  Elsif [M:COT2]RVAFRYBAS = 2 Then
    #jours
    INBRVADAY = [M:COT2]RVAFRY
  Elsif [M:COT2]RVAFRYBAS = 3 Then
    #semaine
    INBRVADAY = [M:COT2]RVAFRY * 7
  Elsif [M:COT2]RVAFRYBAS = 4 Then
    #mois
    INBRVADAY = [M:COT2]RVAFRY * (365.25 / 12)
  Elsif [M:COT2]RVAFRYBAS = 5 Then
    #année
    INBRVADAY = [M:COT2]RVAFRY * 365.25
  Elsif [M:COT2]RVAFRYBAS = 6 Then
    #vide
    INBRVADAY = 0
  Endif
  If INBREWDAY < 1 Then
    #La fréquence de renouvellement ne peut pas être inférieure à une journée.
    GMESSAGE = mess(359,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  #Garantie
  If [M:COT1]CONCAT = 1 Then
    Return
  Endif
  #A point
  If [M:COT1]CONCAT = 4 Then
    Return
  Endif
  If INBINVDAY > INBREWDAY Then
    #La fréquence de facturation ne peut pas être supérieure à la fréquence de renouvellement.
    GMESSAGE = mess(357,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If INBRVADAY < 0 Then
    #La fréquence de réévaluation ne peut pas être inférieure à une journée.
    GMESSAGE = mess(360,182,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If INBRVADAY > 0 Then
    If INBRVADAY < INBINVDAY Then
      #La fréquence de réévaluation ne peut pas être inférieure à la fréquence de facturation.
      GMESSAGE = mess(361,182,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
Return
