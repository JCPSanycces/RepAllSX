#<AdxTL>@(#)0.0.0.0 $Revision$
#--CPO DM 105661 Ajout de la sous-traitance
#--------------------------------------------------------------------------------------------------#
#-- Script pour la gestion des flux sous-traitance d'envoi/réception de produit fini
#--------------------------------------------------------------------------------------------------#
$DEBG_SDH_SST

  If WMVT<>21 Return Endif

  #--Si mouvement à 21, l'appel à FLUX_REGNAT a déjà été effectué
#  Raz WTROUVE,WVALSTO
#  Call FLUX_REGNAT(WMVT,[F:SDH]STOFCY,[F:FCY]CRY,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  #--Cas de la ligne de livraison de produit fini
  #--c'est la somme des lignes composants (hors matières fournies)
  W_ALREADY_READ=0
  Filter [SDDW] Where SDHNUM=[SDD]SDHNUM and SDDLIN>[SDD]SDDLIN
  For [SDDW]
    WTMP_FISAMT = 0 : W_MTTHTLINVS = 0
    If [F:SDDW]LINTYP<10 or ([SDDW]LINTYP=10 and [SDDW]SDDLIN<>[SDD]SDDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    If [F:SDDW]NETPRINOT <> 0
      WTMP_FISAMT = [F:SDDW]NETPRINOT*[F:SDDW]QTY
      W_FOUND_NOTNULL = 1
    Else
      If WTROUVE and WVALSTO=2
        WTMP_FISAMT = [F:SDDW]CPRPRI*[F:SDDW]QTY
      Else
        #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          WTMP_FISAMT = [F:SDDW]CPRPRI*[F:SDDW]QTY
        Endif
      Endif
    Endif
    W_MTTHTLINVS = WTMP_FISAMT
    If [F:BPD]BPCNUM = [F:SDH]BPCORD and [F:BPD]BPAADD = [F:SDH]BPAADD
      If [F:BPD]EECINCRAT <> 0
        W_MTTHTLINVS = WTMP_FISAMT*[F:BPD]EECINCRAT
      Endif
    Else
      Read [BPD]BPD0=[F:SDH]BPCORD;[F:SDH]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        W_MTTHTLINVS = WTMP_FISAMT*[F:BPD]EECINCRAT
      Endif
    Endif
    #--- Prise en compte des éléments de facturation répartis sur la ligne
    WPIECE = "SDDW"
    Gosub VEN_TOTDISCRG From FUNDEB
    WDISCRGAMT   = WTOTDISCRG
    WDISCRGAMTVS = WTOTDISCRGVS
    Raz WPIECE
    # Si le total des lignes ne permet pas de proratiser,
    # il faut prendre en compte les éléments déjà éclatés sur les lignes
    If [F:SDH]DLVNOT <> 0
      #--- Il faut proratiser par rapport au [F:SDD]NETPRINOT*[F:SDD]QTY, même si = 0
      #--- car sinon, si on prend W_MTTHTLIN qui tient compte du CPRPRI,
      #--- nous risquons d'avoir un total des lignes > au [F:SDH]DLVNOT et un faux prorata !
      [M:DEBG]FISAMT  (nolign-1) += WTMP_FISAMT  + ((WINVDTAAMT  *([F:SDDW]NETPRINOT*[F:SDDW]QTY))/[F:SDH]DLVNOT) + WDISCRGAMT
      [M:DEBG]STAAMT  (nolign-1) += W_MTTHTLINVS + ((WINVDTAAMTVS*([F:SDDW]NETPRINOT*[F:SDDW]QTY))/[F:SDH]DLVNOT) + WDISCRGAMTVS
    Else
      [M:DEBG]FISAMT  (nolign-1) += WTMP_FISAMT  + WDISCRGAMT
      [M:DEBG]STAAMT  (nolign-1) += W_MTTHTLINVS + WDISCRGAMTVS
    Endif
  Next
  Filter [SDDW]
  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    [M:DEBG]FISAMT  (nolign-1) = [F:SDD]CPRPRI*[F:SDD]QTY
    If [F:BPD]BPCNUM = [F:SDH]BPCORD and [F:BPD]BPAADD = [F:SDH]BPAADD
      If [F:BPD]EECINCRAT <> 0
        [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]FISAMT  (nolign-1)*[F:BPD]EECINCRAT
      Endif
    Else
      Read [BPD]BPD0=[F:SDH]BPCORD;[F:SDH]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]FISAMT  (nolign-1)*[F:BPD]EECINCRAT
      Endif
    Endif
  Endif
Return
###################################################################################################
$DEBG_DTA_SDH_SST

  If WMVT<>21 Return Endif

  #--Pour le mouvement 21, l'appel à déjà été effectué
#  Raz WTROUVE,WVALSTO
#  Call FLUX_REGNAT(WMVT,[F:SDH]STOFCY,[F:FCY]CRY,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  #--Cas de la ligne de livraison de produit fini
  #--c'est la somme des lignes composants (hors matières fournies)
  #--Pour mémoire : on considère que les lignes de composants viennent après la ligne de composé
  #--de la facture; ligne associée au composé en cours d'extraction sur la livraison
  W_LIG_COMPOSE=[SID]SDDLIN
  W_ALREADY_READ=0
  Filter [SIDW] Where NUM=[SID]NUM and SIDLIN>[SID]SIDLIN and SDHNUM=[F:SDH]SDHNUM
  For [SIDW]
    WTMP_FISAMT = 0 : W_MTTHTLINVS = 0
    If [F:SIDW]LINTYP<10 or ([SIDW]LINTYP=10 and W_LIG_COMPOSE>0 and [SIDW]SDDLIN<>W_LIG_COMPOSE) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    If [F:SIDW]NETPRINOT <> 0
      WTMP_FISAMT = [F:SIDW]AMTNOTLIN
      W_FOUND_NOTNULL = 1
    Else
      If WTROUVE and WVALSTO=2
        WTMP_FISAMT = [F:SIDW]CPRPRI*[F:SIDW]QTY
      Else
        #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          WTMP_FISAMT = [F:SIDW]CPRPRI*[F:SIDW]QTY
        Endif
      Endif
    Endif
    W_MTTHTLINVS = WTMP_FISAMT
    #--- Prise en compte du coefficient de majoration CEE, le cas échéant
    If [F:BPD]BPCNUM = [F:SIV]BPCORD and [F:BPD]BPAADD = [F:SIV]BPAADD
     If [F:BPD]EECINCRAT <> 0
       W_MTTHTLINVS = WTMP_FISAMT*[F:BPD]EECINCRAT
     Endif
    Else
      Read [BPD]BPD0=[F:SIV]BPCORD;[F:SIV]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        W_MTTHTLINVS = WTMP_FISAMT*[F:BPD]EECINCRAT
      Endif
    Endif

    #--- Nous traitons la ligne de détail facture liée au détail de réception
    #--- Calcul de la somme des éléments de facturation répartis sur les lignes
    # Attention :
    # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
    # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
    WPIECE = "SIDW"
    Gosub VEN_TOTDISCRG From FUNDEB
    WFACDISCRG   = WTOTDISCRG
    WFACDISCRGVS = WTOTDISCRGVS
    Raz WPIECE
    # Si le total des lignes ne permet pas de proratiser,
    # il faut prendre en compte les éléments déjà éclatés sur les lignes
    If WTOTAMTNOT <> 0
      WFISAMT += WTMP_FISAMT +((WFACDTAAMT  *[F:SIDW]AMTNOTLIN)/WTOTAMTNOT) + WFACDISCRG
      WSTAAMT += W_MTTHTLINVS+((WFACDTAAMTVS*[F:SIDW]AMTNOTLIN)/WTOTAMTNOT) + WFACDISCRGVS #--Sur FISAMT car contient une somme de mtts lignes
    Else
      WFISAMT += WTMP_FISAMT  + WFACDISCRG
      WSTAAMT += W_MTTHTLINVS + WFACDISCRGVS
    Endif
  Next
  Filter [SIDW]
  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
  #--On garde la valeur du la livraison
    Raz WFISAMT,WSTAAMT
    WPASVALO = 1 : Return
#    [M:DEBG]FISAMT  (nolign-1) = [F:SID]CPRPRI*[F:SDD]QTY
#    If [F:BPD]BPCNUM = [F:SIV]BPCORD and [F:BPD]BPAADD = [F:SIV]BPAADD
#     If [F:BPD]EECINCRAT <> 0
#       [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]FISAMT  (nolign-1)*[F:BPD]EECINCRAT
#     Endif
#    Else
#      Read [BPD]BPD0=[F:SIV]BPCORD;[F:SIV]BPAADD
#      If fstat : Raz [F:BPD] : Endif
#      If [F:BPD]EECINCRAT <> 0
#        [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]FISAMT  (nolign-1)*[F:BPD]EECINCRAT
#      Endif
#    Endif
  Endif
Return
###################################################################################################
$DEBG_SRH_SST

  If WMVT<>24 Return Endif

  Read [SDH]SDH0=[F:SRD]SDHNUM
  If fstat : Raz [F:SDH] : Endif

  WNUMEROPIECE = [F:SDH]SDHNUM
  W_VCRTYP=2 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
  Gosub VEN_TOTDTA From FUNDEB
  WINVDTAAMT2   = WTOTDTA
  WINVDTAAMTVS2 = WTOTDTAVS
  Raz WNUMEROPIECE
  Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO

  Raz WTROUVE
  Raz WVALSTO
  #Type de flux - WMVT est positionné dans l'entête
  #--- Type de flux
  Call FLUX_REGNAT(WMVT,[F:SRH]STOFCY,W_CRYTO,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  #--Pour proratiser les montants de la livraison
  #--en fonction des qtés composé retour et livraison
  W_LIG_COMPOSE     = [SRD]SDDLIN
  W_LIG_COMPOSE_QTY = [SRD]QTYSTU
  W_ALREADY_READ=0

  Read [SDDW]SDD0=[SRD]SDHNUM;[SRD]SDDLIN
  If fstat<>0
    Raz [SDDW]
    [M:DEBG]FISAMT  (nolign-1) = 0
    [M:DEBG]STAAMT  (nolign-1) = 0
    Return
  Endif
  W_LIG_COMPOSE_QTY_LIV = [F:SDDW]QTYSTU

  Filter [SDDW] Where SDHNUM=[F:SRD]SDHNUM and SDDLIN>[F:SRD]SDDLIN
  For [SDDW]
    WTMP_FISAMT = 0
    #--LINTYP présent que sur la livraison
    #--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    If [F:SDDW]LINTYP<10 or ([F:SDDW]LINTYP=10 and W_LIG_COMPOSE>0 and [SDDW]SDDLIN<>W_LIG_COMPOSE) : Break : Endif

    If [F:SDDW]NETPRINOT <> 0
      #le prix net de la ligne de livraison est pour 1 UV
      #il faut transformer l'UV en US et prendre celui ci pour les quantités en US de retour
      If W_LIG_COMPOSE_QTY_LIV<>0
        WTMP_FISAMT = (([F:SDDW]NETPRINOT*[F:SDDW]QTY)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
        W_FOUND_NOTNULL = 1
      Endif
    Else
      If WTROUVE and WVALSTO=2
        If W_LIG_COMPOSE_QTY_LIV<>0
          WTMP_FISAMT = (([F:SDDW]CPRPRI*[F:SDDW]QTY)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
        Endif
      Else
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          If W_LIG_COMPOSE_QTY_LIV<>0
            WTMP_FISAMT = (([F:SDDW]CPRPRI*[F:SDDW]QTY)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
          Endif
        Endif
      Endif
    Endif

    W_MTTHTLIN   += WTMP_FISAMT
    W_MTTHTLINVS += WTMP_FISAMT
    If [F:BPD]BPCNUM = [F:SDH]BPCORD and [F:BPD]BPAADD = [F:SDH]BPAADD
      If [F:BPD]EECINCRAT <> 0
        W_MTTHTLINVS += (WTMP_FISAMT*[F:BPD]EECINCRAT-WTMP_FISAMT) :#--WTMP_FISAMT déjà pris en compte
      Endif
    Else
      Read [BPD]BPD0=[F:SDH]BPCORD;[F:SDH]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        W_MTTHTLINVS += (WTMP_FISAMT*[F:BPD]EECINCRAT-WTMP_FISAMT) :#--WTMP_FISAMT déjà pris en compte
      Endif
    Endif

    #--- Prise en compte des éléments de facturation répartis sur la ligne
    WPIECE = "SDDW"
    Gosub VEN_TOTDISCRG From FUNDEB
    Raz WPIECE
    #--- si la devise de la livraison est différente de la devise de déclaration, il faut convertir le mtt
    WDISCRGAMT   = WTOTDISCRG
    WDISCRGAMTVS = WTOTDISCRGVS

    If [F:SDH]DLVNOT <> 0 and W_LIG_COMPOSE_QTY_LIV<>0
      #--- Il faut proratiser par rapport au [F:SDD]NETPRINOT*[F:SDD]QTY, même si = 0
      #--- car sinon, si on prend W_MTTHTLIN qui tient compte du CPRPRI,
      #--- nous risquons d'avoir un total des lignes > au [F:SDH]DLVNOT et un faux prorata !
      W_MTTHTLIN   += (((WINVDTAAMT2  *([F:SDDW]NETPRINOT*[F:SDDW]QTY))/[F:SDH]DLVNOT)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
      W_MTTHTLINVS += (((WINVDTAAMTVS2*([F:SDDW]NETPRINOT*[F:SDDW]QTY))/[F:SDH]DLVNOT)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
    Endif
    #Il faut proratiser les éléments obtenus de la livraison, par rapport au quantités du retour
    If W_LIG_COMPOSE_QTY_LIV<>0
      W_MTTHTLIN   += (WDISCRGAMT  *W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
      W_MTTHTLINVS += (WDISCRGAMTVS*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_LIV
    Endif

  If WOK=0 or WOKLIG=0 : Break : Endif
  Next
  Filter [SDDW]
  If WOK = 0 or WOKLIG=0 : Return : Endif

  If W_MTTHTLIN >0
    If [F:SDH]CUR<> "" and [F:SDH]CUR <> WCUR
      WTMP_FISAMT=W_MTTHTLIN
      Raz STAT
      Call CONVERT([F:SDH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SDH]DLVDAT,WTMP_FISAMT,W_MTTHTLIN,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:SDH]CUR,WCUR,WCUR,[F:SDH]CHGTYP,[F:SDH]DLVDAT,WTMP_FISAMT,W_MTTHTLIN,STAT) From TRTDEV
        If STAT
          WOKLIG=0 :# Il n'y a pas de cours de change pour la pièce, donc le détail ne sera pas traité
          Call ECR_TRACE(mess(735,197,1)-[F:SDH]SDHNUM-mess(71,199,1),1) From GESECRAN
          Return
        Endif
      Endif
    Endif
  Endif
  If W_MTTHTLINVS >0
    If [F:SDH]CUR<> "" and [F:SDH]CUR <> WCUR
      WTMP_FISAMTVS=W_MTTHTLINVS
      Raz STAT
      Call CONVERT([F:SDH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SDH]DLVDAT,WTMP_FISAMTVS,W_MTTHTLINVS,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:SDH]CUR,WCUR,WCUR,[F:SDH]CHGTYP,[F:SDH]DLVDAT,WTMP_FISAMTVS,W_MTTHTLINVS,STAT) From TRTDEV
        If STAT
          WOKLIG=0 :# Il n'y a pas de cours de change pour la pièce, donc le détail ne sera pas traité
          Call ECR_TRACE(mess(735,197,1)-[F:SDH]SDHNUM-mess(71,199,1),1) From GESECRAN
          Return
        Endif
      Endif
    Endif
  Endif

  [M:DEBG]FISAMT  (nolign-1) = W_MTTHTLIN
  [M:DEBG]STAAMT  (nolign-1) = W_MTTHTLINVS

#  #--- Renseignement des pièces prises en compte lors de la valorisation
#  #--- Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
#  Raz WNOLINVALO
#  Raz WVCRNUMVALO
#  Raz WVCRLINVALO
#  If nolign > NBLIGNESDET
#    Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
#    Call ECR_TRACE(mess(735,197,1)-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN),1) From GESECRAN
#  Else
#    WINDICE=find([F:SRD]SDHNUM,WVCRNUMVALO(0..14,nolign-1))
#    If WINDICE<=0 or (WINDICE>0 and !find([F:SRD]SDDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
#      WNOLINVALO += 1
#      If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
#        Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
#        Call ECR_TRACE(mess(735,197,1)-[F:SRD]SRHNUM-num$([F:SRD]SRDLIN),1) From GESECRAN
#      Else
#        WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:SRD]SDHNUM
#        WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:SRD]SDDLIN
#      Endif
#    Endif
#  Endif
  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    [M:DEBG]FISAMT  (nolign-1) = [F:SRD]NETPRINOT*[F:SRD]QTY
    #--- si la devise de la livraison est différente de la devise de déclaration, il faut convertir le mtt
    If [M:DEBG]FISAMT  (nolign-1) > 0
      #--- Conversion du montant, le cas échéant
      If [F:SRD]CUR<>"" and [F:SRD]CUR <> WCUR
        WTMP_FISAMT=[M:DEBG]FISAMT  (nolign-1)
        Raz STAT
        Call CONVERT([F:SRD]CUR,WCUR,WCUR,GEECTYPCUR,[F:SRD]RTNDAT,WTMP_FISAMT,[M:DEBG]FISAMT  (nolign-1),STAT) From TRTDEV
        If STAT
          WOK=0
          Call ECR_TRACE(mess(735,197,1)-[F:SRH]SRHNUM-mess(71,199,1),1) From GESECRAN
          Return
        Endif
      Endif
    Endif
    #--- Prise en compte du coefficient de majoration CEE, le cas échéant
    [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]FISAMT  (nolign-1)
    If [F:BPD]BPCNUM = [F:SRH]BPCORD and [F:BPD]BPAADD = [F:SRH]BPAADD
     If [F:BPD]EECINCRAT <> 0
      [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]STAAMT  (nolign-1)*[F:BPD]EECINCRAT
     Endif
    Else
      Read [BPD]BPD0=[F:SRH]BPCORD;[F:SRH]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        [M:DEBG]STAAMT  (nolign-1) = [M:DEBG]STAAMT  (nolign-1)*[F:BPD]EECINCRAT
      Endif
    Endif
  Endif
Return
###################################################################################################
$DEBG_DTA_SRH_SST

  If WMVT<>24 Return Endif

  #--L'appel à déjà été fait
#  Raz WTROUVE
#  Raz WVALSTO
#  Call FLUX_REGNAT(WMVT,[F:SRH]STOFCY,W_CRYTO,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  #--SIV, SIH et SID sont en ligne, et selon les infos de la ligne de retour !!

  #--Cas de la ligne de livraison de produit fini
  #--c'est la somme des lignes composants (hors matières fournies)
  Raz WTMP_FISAMT, WTMP_FISAMTVS
  W_ALREADY_READ=0
  Filter [SIDW] Where NUM=[SID]NUM and SIDLIN>[SID]SIDLIN and SRHNUM=[SRH]SRHNUM
  For [SIDW]
    Raz WTMP_FISAMT, WTMP_FISAMTVS
    If [F:SIDW]LINTYP<11 : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    If [F:SIDW]NETPRINOT <> 0
      WTMP_FISAMT = [F:SIDW]AMTNOTLIN
      W_FOUND_NOTNULL = 1
    Else
      If WTROUVE and WVALSTO=2
        WTMP_FISAMT = [F:SIDW]CPRPRI*[F:SIDW]QTY
      Else
        #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          WTMP_FISAMT = [F:SIDW]CPRPRI*[F:SIDW]QTY
        Endif
      Endif
    Endif

    WTMP_FISAMTVS = WTMP_FISAMT
    #--- Prise en compte du coefficient de majoration CEE, le cas échéant
    If [F:BPD]BPCNUM = [F:SIV]BPCORD and [F:BPD]BPAADD = [F:SIV]BPAADD
     If [F:BPD]EECINCRAT <> 0
      WTMP_FISAMTVS = WTMP_FISAMT*[F:BPD]EECINCRAT
     Endif
    Else
      Read [BPD]BPD0=[F:SIV]BPCORD;[F:SIV]BPAADD
      If fstat : Raz [F:BPD] : Endif
      If [F:BPD]EECINCRAT <> 0
        WTMP_FISAMTVS = WTMP_FISAMT*[F:BPD]EECINCRAT
      Endif
    Endif

    #--- Nous traitons la ligne de détail facture liée au détail de réception
    #--- Calcul de la somme des éléments de facturation répartis sur les lignes
    # Attention :
    # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
    # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
    WPIECE = "SIDW"
    Gosub VEN_TOTDISCRG From FUNDEB
    WFACDISCRG   = WTOTDISCRG
    WFACDISCRGVS = WTOTDISCRGVS
    Raz WPIECE

    # Si le total des lignes ne permet pas de proratiser,
    # il faut prendre en compte les éléments déjà éclatés sur les lignes
    If WTOTAMTNOT <> 0
      WTMP_FISAMT   += ((WFACDTAAMT  *[F:SIDW]AMTNOTLIN)/WTOTAMTNOT) + WFACDISCRG
      WTMP_FISAMTVS += ((WFACDTAAMTVS*[F:SIDW]AMTNOTLIN)/WTOTAMTNOT) + WFACDISCRGVS
    Else
      WTMP_FISAMT   += WFACDISCRG
      WTMP_FISAMTVS += WFACDISCRGVS
    Endif

    #--- Conversion de la valeur fiscale, le cas échéant
    If [F:SIH]CUR <> WCUR
      WMONTANT = WTMP_FISAMT
      Raz STAT
      Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WMONTANT,WTMP_FISAMT,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WMONTANT,WTMP_FISAMT,STAT) From TRTDEV
        If STAT
          Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
          WPASVALO = 1 : Break
        Endif
      Endif
    Endif
    #--- Conversion de la valeur statistique, le cas échéant
    If [F:SIH]CUR <> WCUR
      WMONTANT = WTMP_FISAMTVS
      Raz STAT
      Call CONVERT([F:SIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:SIH]ACCDAT,WMONTANT,WTMP_FISAMTVS,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:SIH]CUR,WCUR,WCUR,[F:SIH]CURTYP,[F:SIH]ACCDAT,WMONTANT,WTMP_FISAMTVS,STAT) From TRTDEV
        If STAT
          Call ECR_TRACE(mess(742,197,1)-[F:SIH]NUM-mess(71,199,1),1) From GESECRAN
          WPASVALO = 1 : Break
        Endif
      Endif
    Endif
    WFISAMTDTA += WTMP_FISAMT   : Raz WTMP_FISAMT
    WSTAAMTDTA += WTMP_FISAMTVS : Raz WTMP_FISAMTVS
  Next
  Filter [SIDW]
  If WPASVALO : Return : Endif
  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    WPASVALO=1 : Return
  Endif
Return
###################################################################################################
$DEBG_PTH_SST

  If WMVT<>9 Return Endif

  #--Si le WMVT est à 9, l'appel à FLUX_REGNAT a déjà été effectué
#  Raz WTROUVE
#  Raz WVALSTO
#  Call FLUX_REGNAT(WMVT,[F:PTH]PRHFCY,W_CRYTO,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA
  W_ALREADY_READ=0 : W_FOUND_NOTNULL = 0
  Filter [PTDW] Where PTHNUM=[F:PTD]PTHNUM and PTDLIN>[F:PTD]PTDLIN
  For [PTDW]
    If [PTDW]LINTYP<2 or ([PTDW]LINTYP=2 and [PTDW]PTDLIN<>[PTD]PTDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    WTMP_FISAMT = 0
    If [F:PTDW]LINAMT > 0
      WTMP_FISAMT = [F:PTDW]LINAMT
      W_FOUND_NOTNULL = 1
    Else
      #--- Si le montant net de la ligne est 0, on prend le prix du mouvement
      #--- Ce dernier est libéllé dans la devise figurant dans "CPRCUR", est porte sur la quantité en UStock
      #--- On tient compte du paramétrage de la valeur stock du flux
      If WTROUVE and WVALSTO=2
        WTMP_FISAMT = [F:PTDW]QTYSTU*[F:PTDW]CPR
      Else
        #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          WTMP_FISAMT = [F:PTDW]QTYSTU*[F:PTDW]CPR
        Endif
      Endif
      If WTMP_FISAMT>0
        If [F:PTDW]CPRCUR <> [F:PTH]CUR
          #--- Il faut convertir le montant dans la devise du document
          WFISAMT=WTMP_FISAMT
          Raz STAT
          Call CONVERT([F:PTDW]CPRCUR,[F:PTH]CUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WFISAMT,WTMP_FISAMT,STAT) From TRTDEV
          If STAT
            Raz STAT
            Call CONVERT([F:PTDW]CPRCUR,[F:PTH]CUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WFISAMT,WTMP_FISAMT,STAT) From TRTDEV
            If STAT
              WOK=0
              Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
              Break
            Endif
          Endif
        Endif
      Endif
    Endif

    #--- Prise en compte du taux de majoration CEE
    If [F:PTDW]EECINCRAT <> 0
      W_MTTHTLINVS = WTMP_FISAMT*[F:PTDW]EECINCRAT
    Else
      W_MTTHTLINVS = WTMP_FISAMT
    Endif

    # Attention :
    # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
    # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
    WPIECE       = "PTH"
    WDETAILPIECE = "PTDW"
    Gosub ACH_TOTDISCRG From FUNDEB
    WFACDISCRG   = WTOTDISCRG
    WFACDISCRGVS = WTOTDISCRGVS
    Raz WPIECE : Raz WDETAILPIECE
    # Si le total des lignes ne permet pas de proratiser,
    # il faut prendre en compte les éléments déjà éclatés sur les lignes
    If [F:PTH]TOTLINAMT <> 0
      [M:DEBG]FISAMT(nolign-1) += WTMP_FISAMT  + ((WINVDTAAMT  *[F:PTDW]LINAMT)/[F:PTH]TOTLINAMT) + WFACDISCRG     :# WDISCRGAMT
      [M:DEBG]STAAMT(nolign-1) += W_MTTHTLINVS + ((WINVDTAAMTVS*[F:PTDW]LINAMT)/[F:PTH]TOTLINAMT) + WFACDISCRGVS :# WDISCRGAMTVS
    Else
      [M:DEBG]FISAMT(nolign-1) += WTMP_FISAMT  + WFACDISCRG     :# WDISCRGAMT
      [M:DEBG]STAAMT(nolign-1) += W_MTTHTLINVS + WFACDISCRGVS   :# WDISCRGAMTVS
    Endif

  Next
  Filter [PTDW]
  If WOK = 0 : Return : Endif
  #--La conversion de la valeur fiscale/statistique est faite après le return
  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    [M:DEBG]FISAMT(nolign-1) = [F:PTD]QTYSTU*[F:PTD]CPR
    If [M:DEBG]FISAMT(nolign-1)>0
      If [F:PTD]CPRCUR <> [F:PTH]CUR
        #--- Il faut convertir le montant dans la devise du document
        WFISAMT=[M:DEBG]FISAMT(nolign-1)
        Raz STAT
        Call CONVERT([F:PTD]CPRCUR,[F:PTH]CUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
        If STAT
          Raz STAT
          Call CONVERT([F:PTD]CPRCUR,[F:PTH]CUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
          If STAT
            WOK=0
            Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
            Return
          Endif
        Endif
      Endif
    Endif
    #--- Prise en compte du taux de majoration CEE
    If [F:PTD]EECINCRAT <> 0
      [M:DEBG]STAAMT(nolign-1) = [M:DEBG]FISAMT(nolign-1)*[F:PTD]EECINCRAT
    Else
      [M:DEBG]STAAMT(nolign-1) = [M:DEBG]FISAMT(nolign-1)
    Endif
  Endif
Return
###################################################################################################
$DEBG_DTA_PTHCPL_SST
#######################################################################
# Prise en compte des factures complémentaires sur réception
#----------------------------------------------------------------------
#---uniquement si la réception n'est pas encore facturée
#---(la facture complémentaire ne flague pas la ligne de réception)
#---on peut avoir une réception soldée ayant des factures complémentaires
Raz WFISAMT : Raz WSTAAMT
Raz WFACDTAAMT, WFACDTAAMTVS, WFISAMTDTA, WSTAAMTDTA, W_NUM, WPASVALO, WMAJ, WTRNOK, WTROUVE
Raz WRCPINVQTY, WORDINVQTY
Raz WSAVFISAMTDTA, WSAVSTAAMTDTA
Raz WNOLINVALO
W_ALREADY_READ=0
If [F:PTD]INVQTYSTU = 0
  #---recherche des lignes de factures ayant comme origine ma réception
  For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI>[F:PTD]PTDLIN) & INVTYP = 1
    If find([PID]LINTYP,2,3,4)=0 or ([PID]LINTYP=2 and [PID]LINORI<>[PTD]PTDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    If ([M]REG=1 & [F:PID]LINEECFLG <> 2) | [M]REG=2
      If [F:PIH]NUM <> [F:PID]NUM
        Read [PIH]PIH0 = [F:PID]NUM
        If fstat : Raz [F:PIH] : WPASVALO= 1 : Break : Endif
        # Uniquement les factures validées
        # si une des factures n'est pas validée, il ne faut pas valoriser, car les montants peuvent changer
        If [F:PIH]STA <> 3 : WPASVALO= 1 : Break : Endif
      Else
        If [F:PIH]STA <> 3 : WPASVALO= 1 : Break : Endif
      Endif
      #--- Vérification si la facture n'a pas fait l'objet d'une DEB
      If ([F:PIH]EECNUMDEB <> 0 & [F:PIH]EECNUMDEB <> [M]EECNUMDEB) : Break : Endif
      #--- Enregistrement PIV doit exister
      If [F:PIV]NUM <> [F:PIH]NUM
        Read [PIV]PIV0=[F:PIH]NUM
        If fstat : Raz [F:PIV] : WPASVALO= 1 : Break : Endif
      Endif
      WFISAMT = [F:PID]AMTNOTLIN
      #--- Prise en compte de EECINCRAT
      # içi, car après il peut y avoir des éléments de facturation pris en compte uniquement dans la valeur statistique
      # Pas de EECINCRAT dans le PID
      # Nous devons le chercher dans la pièce de réception
      If [F:PTD]EECINCRAT <> 0
        WSTAAMT  = [F:PID]AMTNOTLIN*[F:PTD]EECINCRAT
      Else
        WSTAAMT  = [F:PID]AMTNOTLIN
      Endif
      #--- En-tête, calculons la somme des éléments de facturation de l'en-tête
      #--- Eléments de facturation
      # Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
      # Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
      # a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
      # puis répartition sur les lignes, au prorata des montants de chaque ligne
      WNUMEROPIECE = [F:PID]NUM
      W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
      Gosub ACH_TOTDTA From FUNDEB
      WFACDTAAMT   = WTOTDTA
      WFACDTAAMTVS = WTOTDTAVS
      Raz WNUMEROPIECE
      Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
      W_NUM = [F:PID]NUM
      #--- Nous traitons la ligne de détail facture liée au détail de réception
      #--- Calcul de la somme des éléments de facturation répartis sur les lignes
      # Attention :
      # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
      # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
      WPIECE       = "PIV"
      WDETAILPIECE = "PID"
      Gosub ACH_TOTDISCRG From FUNDEB
      WFACDISCRG   = WTOTDISCRG
      WFACDISCRGVS = WTOTDISCRGVS
      Raz WPIECE : Raz WDETAILPIECE
      # Si le total des lignes ne permet pas de proratiser,
      # il faut prendre en compte les éléments déjà éclatés sur les lignes
      If [F:PIV]TOTLINAMT <> 0
        WFISAMT += ((WFACDTAAMT*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRG
        WSTAAMT += ((WFACDTAAMTVS*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRGVS
      Else
        # Si le total des lignes est 0
        # il faut prendre en compte les éléments déjà éclatés sur les lignes
        WFISAMT += WFACDISCRG
        WSTAAMT += WFACDISCRGVS
      Endif
      #--- Conversion de la valeur fiscale, le cas échéant
      If [F:PIH]CUR <> WCUR
         WMONTANT = WFISAMT
         Raz STAT
         Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
         If STAT
           Raz STAT
           Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
           If STAT
             Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
             WPASVALO= 1 : Break
           Endif
         Endif
      Endif
      #--- Conversion de la valeur statistique, le cas échéant
      If [F:PIH]CUR <> WCUR
         WMONTANT = WSTAAMT
         Raz STAT
         Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
         If STAT
           Raz STAT
           Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
           If STAT
             Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
             WPASVALO= 1 : Break
           Endif
         Endif
      Endif
      WFISAMTDTA += WFISAMT : Raz WFISAMT : Raz WMONTANT
      WSTAAMTDTA += WSTAAMT : Raz WSTAAMT : Raz WMONTANTVS
    Else
      WPASVALO= 1 : Break
    Endif
  Next
  If WPASVALO : Return : Endif
  #---Si ok on rajoute les valeurs calculées aux valeurs fiscales et stat de la réception
  If WFISAMTDTA <> 0
    [M:DEBG]FISAMT(nolign-1) += WFISAMTDTA
    [M:DEBG]LINVALOFLG(nolign-1)=2
  Endif
  #--- Valeur statistique valorisée avec les éléments de la facture cpl
  If WSTAAMTDTA <> 0
    [M:DEBG]STAAMT(nolign-1) += WSTAAMTDTA
    [M:DEBG]LINVALOFLG(nolign-1)=2
  Endif
  #--- Maj des pièces valorisées
  For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI>=[F:PTD]PTDLIN) & INVTYP = 1 :# Factures complémentaires origine réception
    If find([PID]LINTYP,2,3,4)=0 or ([PID]LINTYP=2 and [PID]LINORI<>[PTD]PTDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    #--- Renseignement des pièces prises en compte lors de la valorisation
    #--- Facture de la réception
    #--on retient uniquement les lignes composés, sinon on dépasse largement la taille du tableau...
    If [F:PID]LINTYP=2
      #--CPO 75397 Indice incorrect
      If nolign > NBLIGNESDET
        Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
        Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
        WTRNOK = 1
        Break
      Endif
      WINDICE=find([F:PID]NUM,WVCRNUMVALO(0..14,nolign-1))
      If WINDICE<=0 or (WINDICE>0 and !find([F:PID]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
        WNOLINVALO += 1
        If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
          Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
          Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
          WTRNOK = 1
          Break
        Endif
        WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PID]NUM
        WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PID]PIDLIN
      Endif
    Endif
    #---Maj des n°EECNUMDEB des entêtes des factures complémentaires
    #---Maj des LINEECFLG des lignes des factures complémentaires
    W_NUMPIECE   = [F:PID]NUM
    W_NUMLINPIEC = [F:PID]PIDLIN
    Update [PID] Where NUM=W_NUMPIECE and PIDLIN=W_NUMLINPIEC With LINEECFLG = 2
    If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break : Endif

    Update [PIH] Where NUM=[F:PID]NUM With EECNUMDEB = [M]EECNUMDEB
    If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif
  Next
  If WTRNOK : Return : Endif
Endif

Return
###################################################################################################
$DEBG_DTA_PTH_SST

  If WMVT<>9 Return Endif

  Raz WTROUVE
  Raz WVALSTO
  Call FLUX_REGNAT(WMVT,[F:PTH]PRHFCY,W_CRYTO,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  Raz WFACDTAAMT, WFACDTAAMTVS, WFISAMTDTA, WSTAAMTDTA, W_NUM, WPASVALO, WMAJ, WTRNOK, WTROUVE
  Raz WRCPINVQTY, WORDINVQTY
  Raz WSAVFISAMTDTA, WSAVSTAAMTDTA
  W_LIG_COMPOSE=[PTD]PTDLIN
  W_ALREADY_READ=0
#  Filter [PTDW] Where PTHNUM=[F:PTD]PTHNUM and PTDLIN>=[F:PTD]PTDLIN
#  For [PTDW]
#    #--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
#    #--d'où la seconde partie "or..."
#    If [PTDW]LINTYP<2 or ([PTDW]PTDLIN>[PTD]PTDLIN and [PTDW]LINTYP=2) : Break : Endif
#    #--- Valorisation avec les lignes facturées
#    #--- Factures origine Réception
#    For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTDW]PTHNUM & LINORI=[F:PTDW]PTDLIN) & INVTYP = 1
    For [PID]PID1 Where (TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI>=[F:PTD]PTDLIN) & INVTYP = 1
      If [PID]LINTYP<2 or ([PID]PTDLIN<>W_LIG_COMPOSE and [PID]LINTYP=2) : Break : Endif
      If ([M]REG=1 & [F:PID]LINEECFLG <> 2) | [M]REG=2
        If [F:PIH]NUM <> [F:PID]NUM
          Read [PIH]PIH0 = [F:PID]NUM
          If fstat : WPASVALO = 1 : Raz [F:PIH] : Break : Endif
          # Uniquement les factures validées
          # si une des factures n'est pas validée, il ne faut pas valoriser, car les montants peuvent changer
          If [F:PIH]STA <> 3 : WPASVALO = 1 : Break : Endif
        Else
          If [F:PIH]STA <> 3 : WPASVALO = 1 : Break : Endif
        Endif
        #--Si le composant n'est pas sur la réception, on continue à valoriser
        Read [PTDW]PTD0=[PID]NUMORI;[PID]LINORI
        If fstat : Raz [PTDW] : Endif
        #---Prise en compte des éléments de facturation
        #--Uniquement pour les composants
        If [PID]LINTYP<>2
          Gosub DEBG_DTA_PTH_PIH
          If WPASVALO : Break : Endif
        Else
          #--uniquement pour le composé
          WRCPINVQTY += [F:PID]QTYPUU
        Endif
      Else
        # Si pas de regénération et qu'une des lignes a déjà été prise en compte, il ne faut pas valoriser
        WPASVALO = 1 : Break
      Endif
      If WPASVALO=1 : Break : Endif
    Next
#    If WPASVALO=1 : Break : Endif
#  Next
#  Filter [PTDW]
  If WTRNOK=1 or WOK=0 or WPASVALO=1 : Return : Endif

  #--- Il faut calculer la quantité restant à facturer suite à la valo des factures sur réception
  #--- qté restant à facturer = qté facturée totale de la réception - qté des factures de réception
  #--on se base uniquement sur le composé !!
  WINVQTY = [F:PTD]INVQTYPUU - WRCPINVQTY
  #--- s'il reste des quantités à facturer par rapport au total facturé de la ligne de réception
  #--- nous devons les chercher sur les factures de la commande d'origine de la ligne de réception
  WSAVFISAMTDTA = WFISAMTDTA : Raz WFISAMTDTA
  WSAVSTAAMTDTA = WSTAAMTDTA : Raz WSTAAMTDTA
  If WINVQTY > 0
      #--- Factures origine Commande (pour les Réceptions de commandes)
      If (WPASVALO=0) and ([F:PTD]POHNUM <> '' and [F:PTD]POPLIN <> 0)
          If [F:POQ]POHNUM<>[F:PTD]POHNUM or [F:POQ]POPLIN<>[F:PTD]POPLIN
              Read [POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
              If fstat : Raz [F:POQ] : WPASVALO = 1 : Endif
          Endif
          If WPASVALO=0
            #--On se base uniquement sur le statut facturé/soldé du composé
            If [F:POQ]LINCLEFLG=2 and [F:POQ]LININVFLG=2
              #--- ATTENTION : la commande est considérée facturée aussi si est complétement soldée par la réception
              #--- ET si cette(ces) réception(s) ont été totalement facturée(s) !!!!
              #--- => il faut éviter de proratiser plus loins le mtt valorisé par rapport à la quantité de la cde !!!!
              #--- Uniquement si la ligne de commande est soldée par la réception et est facturée
#              Filter [PTDW] Where PTHNUM=[F:PTD]PTHNUM and PTDLIN>=[F:PTD]PTDLIN
#              For [PTDW]
#                If [PTDW]LINTYP<2  or ([PTDW]PTDLIN<>[PTD]PTDLIN and [PTDW]LINTYP=2) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
#                For [PID]PID1 Where (TYPORI=1 & NUMORI=[F:PTDW]POHNUM & LINORI=[F:PTDW]POPLIN) & INVTYP = 1
                For [PID]PID1 Where (TYPORI=1 & NUMORI=[F:PTD]POHNUM & LINORI>=[F:PTD]POPLIN & SEQORI>=[PTD]POQSEQ) & INVTYP = 1
                  If [PID]LINTYP<2 or ([PID]PTDLIN<>W_LIG_COMPOSE and [PID]LINTYP=2) : Break : Endif
                  If ([M]REG=1 & [F:PID]LINEECFLG <> 2) | [M]REG=2
                    If [F:PIH]NUM <> [F:PID]NUM
                      Read [PIH]PIH0 = [F:PID]NUM
                      If fstat : WPASVALO = 1 : Raz [F:PIH] : Break : Endif
                      #--- Uniquement les factures validées
                      # si une des factures n'est pas validée, il ne faut pas valoriser, car les montants peuvent changer
                      If [F:PIH]STA <> 3 : WPASVALO = 1 : Break : Endif
                    Else
                      If [F:PIH]STA <> 3 : WPASVALO = 1 : Break : Endif
                    Endif
                    #--Si le composant n'est pas sur la réception, on continue à valoriser
                    #Read [PTD]PTD2(4)=[PID]POHNUM;[PID]POPLIN;[PID]POPSEQ;[PID]PTHNUM
                    #If fstat : Raz [PTDW] : Endif
                    Filter [PTDW] Where PTHNUM=[PTD]PTHNUM and PTDLIN>[PTD]PTDLIN and POHNUM=[PID]POHNUM and POPLIN=[PID]POPLIN and POPSEQ=[PID]POPSEQ
                    Read [PTDW] First
                    If fstat : Raz [PTDW] : Endif
                    Filter [PTDW]
                    #--- Prise en compte des éléments de facturation
                    #--Uniquement pour les composants
                    If [PID]LINTYP<>2
                      Gosub DEBG_DTA_PTH_PIH
                      If WPASVALO : Break : Endif
                    Else
                      #--uniquement pour le composé
                      WORDINVQTY += [F:PID]QTYPUU
                    Endif
                    WTROUVE = 1
                  Else
                    #--- Si pas de regénération et qu'une des lignes a déjà été prise en compte, il ne faut pas valoriser
                    WPASVALO = 1 : Break
                  Endif
                Next
#                If WPASVALO=1 : Break : Endif
#              Next
#              Filter [PTDW]
              If WTRNOK=1 or WOK=0 or WPASVALO=1 : Return : Endif

              #--- Il faut proratiser le montant valorisé des cdes factureés par rapport aux quantités réceptionnées/facturées totales
              If WPASVALO = 0 & WTROUVE = 1
                If WORDINVQTY <> 0 and (WORDINVQTY > WINVQTY)
                  WFISAMTDTA = (WFISAMTDTA*WINVQTY)/WORDINVQTY
                  WSTAAMTDTA = (WSTAAMTDTA*WINVQTY)/WORDINVQTY
                Endif
              Endif
            Else
              #--- cde non soldée et/ou non facturée et différence de quantité facturée sur la réception et la somme
              #--- des quantités provenant des factures
              #--- => pas de valorisation
              WPASVALO=1
            Endif
          Endif
      Endif
  Endif
  WFISAMTDTA += WSAVFISAMTDTA
  WSTAAMTDTA += WSAVSTAAMTDTA

  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    WPASVALO=1
  Endif
  If WPASVALO = 1 : Return : Endif

  If WPASVALO = 0
    #--- Valeur fiscale valorisée avec les éléments de la facture
    If WFISAMTDTA <> 0 and WFISAMTDTA <> [M:DEBG]FISAMT(nolign-1)
      #--modifié après le succès de la mise à jours de doc valorisants
      #[M:DEBG]FISAMT(nolign-1) = WFISAMTDTA
      #[M:DEBG]LINVALOFLG(nolign-1)=2
      WMAJ = 1
    Endif
    #--- Valeur statistique valorisée avec les éléments de la facture
    If WSTAAMTDTA <> 0 and WSTAAMTDTA <> [M:DEBG]STAAMT(nolign-1)
      #--modifié après le succès de la mise à jours de doc valorisants
      #[M:DEBG]STAAMT(nolign-1) = WSTAAMTDTA
      #[M:DEBG]LINVALOFLG(nolign-1)=2
      WMAJ = 1
    Endif

    #If WMAJ=1
      Filter [PTDW] Where PTHNUM=[F:PTD]PTHNUM and PTDLIN>=[F:PTD]PTDLIN
      For [PTDW]
        If [PTDW]LINTYP<2  or ([PTDW]PTDLIN<>[PTD]PTDLIN and [PTDW]LINTYP=2) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc

        #--- Mise à jour LINEECFLG des détails factures pris en compte
        Raz WKCRITERE
        WKCRITERE = '(TYPORI=2 & NUMORI=[F:PTDW]PTHNUM & LINORI=[F:PTDW]PTDLIN)'
        If WORDINVQTY > 0
            WKCRITERE -= 'or (TYPORI=1 & NUMORI=[F:PTDW]POHNUM & LINORI=[F:PTDW]POPLIN)'
        Endif
        #--- Mise à jour EECNUMDEB des entêtes des factures de réception prises en compte
        If WTRNOK = 0
          For [PID]PID1 Where evalue(WKCRITERE) & INVTYP=1 :# Factures origine réception ou commande à l'origine de la réception
            #--- Renseignement des pièces prises en compte lors de la valorisation
            #--- Facture de la réception
            #--on retient uniquement les lignes composés, sinon on dépasse largement la taille du tableau...
            If [F:PID]LINTYP=2
              #--CPO 75397 Indice incorrect
              If nolign > NBLIGNESDET
                Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                WTRNOK = 1 : Break
              Endif
              #--CPO
              WINDICE=find([F:PID]NUM,WVCRNUMVALO(0..14,nolign-1))
              If WINDICE<=0 or (WINDICE>0 and !find([F:PID]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
                WNOLINVALO += 1
                If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
                  Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                  Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                  WTRNOK = 1 : Break
                Endif
                  WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PID]NUM
                  WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PID]PIDLIN
              Endif
            Endif
            #--- Mise à jour des entêtes et détails des avoirs/factures avec origine la(les) facture(s) de réception
            #--- uniquement si le paramètre général "EECVALOCPL" est à "Oui"
            If GEECVALOCPL=2
              For [PIDC]PID1 Where TYPORI=4 & NUMORI=[F:PID]NUM & LINORI=[F:PID]PIDLIN & INVTYP<3
                #--- Renseignement des avoirs/factures sur la facture de réception
                #--on retient uniquement les lignes composés, sinon on dépasse largement la taille du tableau...
                If [F:PIDC]LINTYP=2
                  #--CPO 75397 Indice incorrect
                  If nolign > NBLIGNESDET
                    Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                    Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                    WTRNOK = 1 : Break
                  Endif
                  #--CPO
                  WINDICE=find([F:PIDC]NUM,WVCRNUMVALO(0..14,nolign-1))
                  If WINDICE<=0 or (WINDICE>0 and !find([F:PIDC]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
                    WNOLINVALO += 1
                    If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
                      Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                      Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                      WTRNOK = 1 : Break
                    Endif
                    WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PIDC]NUM
                    WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PIDC]PIDLIN
                  Endif
                Endif
                #--- Mise à jour des entêtes et détails des avoirs avec origine factures complémentaires
                For [PIDW]PID1 Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & INVTYP<3 :# Ligne d'avoir sur facture
                  #--- Renseignement des avoirs/factures sur la facture de réception
                  #--on retient uniquement les lignes composés, sinon on dépasse largement la taille du tableau...
                  If [F:PIDW]LINTYP=2
                    #--CPO 75397 Indice incorrect
                    If nolign > NBLIGNESDET
                      Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                      Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                      WTRNOK = 1 : Break
                    Endif
                    #--CPO
                    WINDICE=find([F:PIDW]NUM,WVCRNUMVALO(0..14,nolign-1))
                    If WINDICE<=0 or (WINDICE>0 and !find([F:PIDW]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
                      WNOLINVALO += 1
                      If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
                        Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                        Call ECR_TRACE(mess(735,197,1)-[F:PTD]PTHNUM-num$([F:PTD]PTDLIN),1) From GESECRAN
                        WTRNOK = 1 : Break
                      Endif
                      WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PIDW]NUM
                      WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PIDW]PIDLIN
                    Endif
                  Endif
                  If WMAJ
                    W_NUMPIECE   = [F:PIDW]NUM
                    W_NUMLINPIEC = [F:PIDW]PIDLIN
                    Update [PIDW] Where NUM=W_NUMPIECE and PIDLIN=W_NUMLINPIEC With LINEECFLG = 2
                    If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break : Endif

                    Update [PIHC] Where NUM=[F:PIDW]NUM With EECNUMDEB=[M]EECNUMDEB
                    If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif
                  Endif
                Next
                If WTRNOK : Break : Endif
                If WMAJ
                  W_NUMPIECE   = [F:PIDC]NUM
                  W_NUMLINPIEC = [F:PIDC]PIDLIN
                  Update [PIDC] Where NUM=W_NUMPIECE and PIDLIN=W_NUMLINPIEC With LINEECFLG = 2
                  If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break : Endif

                  Update [PIHC] Where NUM=[F:PIDC]NUM With EECNUMDEB=[M]EECNUMDEB
                  If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif
                Endif
              Next
              If WTRNOK=1 or WOK=0 or WPASVALO=1 : Break : Endif
            Endif
            If WTRNOK : Break : Endif
            If WMAJ
              W_NUMPIECE   = [F:PID]NUM
              W_NUMLINPIEC = [F:PID]PIDLIN
              Update [PID] Where NUM=W_NUMPIECE and PIDLIN=W_NUMLINPIEC With LINEECFLG = 2
              If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break : Endif

              Update [PIH] Where NUM=[F:PID]NUM With EECNUMDEB = [M]EECNUMDEB
              If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif
            Endif
          Next
          If WTRNOK=1 or WOK=0 or WPASVALO=1 : Break : Endif
        Endif
      Next
      Filter [PTDW]
      If WTRNOK=1 or WOK=0 or WPASVALO=1 : Return : Endif
      #--- Valeur fiscale valorisée avec les éléments de la facture
      If WFISAMTDTA <> 0 and WFISAMTDTA <> [M:DEBG]FISAMT(nolign-1)
        #--modifié après le succès de la mise à jours de doc valorisants
        [M:DEBG]FISAMT(nolign-1) = WFISAMTDTA
        [M:DEBG]LINVALOFLG(nolign-1)=2
        WMAJ = 1
      Endif
      #--- Valeur statistique valorisée avec les éléments de la facture
      If WSTAAMTDTA <> 0 and WSTAAMTDTA <> [M:DEBG]STAAMT(nolign-1)
        #--modifié après le succès de la mise à jours de doc valorisants
        [M:DEBG]STAAMT(nolign-1) = WSTAAMTDTA
        [M:DEBG]LINVALOFLG(nolign-1)=2
        WMAJ = 1
      Endif
    #Endif
    If WTRNOK : WOK = 0 : Return : Endif
  Endif
  If WTRNOK=1 or WOK=0 or WPASVALO=1 : Return : Endif

Return
###################################################################################################
#######################################################################
#Prise en compte des éléments de facturation présents sur les factures lièes aux Réceptions
#dans le calcul de la valeur fiscale et/ou statistique,
#le cas échéant
#######################################################################
$DEBG_DTA_PTH_PIH
#--- Vérification si la facture n'a pas fait l'objet d'une DEB
If ([F:PIH]EECNUMDEB <> 0 & [F:PIH]EECNUMDEB <> [M]EECNUMDEB) : WPASVALO = 1 : Return : Endif
#--- Enregistrement PIV doit exister
If [F:PIV]NUM <> [F:PIH]NUM
  Read [PIV]PIV0=[F:PIH]NUM
  If fstat : WPASVALO = 1 : Raz [F:PIV] : Return : Endif
Endif
WFISAMT = [F:PID]AMTNOTLIN
#--- Prise en compte de EECINCRAT
# içi, car après il peut y avoir des éléments de facturation pris en compte uniquement dans la valeur statistique
# Pas de EECINCRAT dans le PID
# Nous devons le chercher dans la pièce de réception
If [F:PTDW]EECINCRAT <> 0
  WSTAAMT  = [F:PID]AMTNOTLIN*[F:PTDW]EECINCRAT
Else
  WSTAAMT  = [F:PID]AMTNOTLIN
Endif
If [F:PID]AMTNOTLIN=0
  #--- Si le montant net de la ligne est 0, on prend le prix du mouvement de la réception
  #--- Ce dernier est libéllé dans la devise figurant dans "CPRCUR", est porte sur la quantité en UStock
  #--- On tient compte du paramétrage de la valeur stock du flux
  If WTROUVE and WVALSTO=2
    WFISAMT = [F:PID]QTYSTU*[F:PTDW]CPR :# "Prix de revient" de la réception
  Else
    #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
    If W_ALREADY_READ=0
      Raz JL0,JL1
      Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
      If JL0>0 : Raz [F:TSC] : Endif
      Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
      If JL1>0 : Raz [F:TEC] : Endif
      W_ALREADY_READ=1
    Endif
    If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
    #--/
      WFISAMT = [F:PID]QTYSTU*[F:PTDW]CPR :# "Prix de revient" de la réception
    Endif
  Endif
  If WFISAMT>0
    If [F:PTDW]CPRCUR <> [F:PIH]CUR
      #--- Il faut convertir le montant dans la devise du document
      WKMONTANT=WFISAMT
      Raz STAT
      Call CONVERT([F:PTDW]CPRCUR,[F:PIH]CUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WKMONTANT,WFISAMT,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:PTDW]CPRCUR,[F:PIH]CUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WKMONTANT,WFISAMT,STAT) From TRTDEV
        If STAT
          Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
          WPASVALO = 1 : Return
        Endif
      Endif
    Endif
    If [F:PTDW]EECINCRAT <> 0
      WSTAAMT  = WFISAMT*[F:PTDW]EECINCRAT
    Else
      WSTAAMT  = WFISAMT
    Endif
  Endif
Else
  W_FOUND_NOTNULL = 1
Endif
#--- En-tête, nous calculons la somme des éléments de facturation de l'en-tête
#--- Eléments de facturation
# Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
# Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
# a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
# puis répartition sur les lignes, au prorata des montants de chaque ligne
WNUMEROPIECE = [F:PID]NUM
W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
Gosub ACH_TOTDTA From FUNDEB
WFACDTAAMT   = WTOTDTA
WFACDTAAMTVS = WTOTDTAVS
Raz WNUMEROPIECE
Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
W_NUM = [F:PID]NUM

#--- Nous traitons la ligne de détail facture liée au détail de réception
#--- Calcul de la somme des éléments de facturation répartis sur les lignes
# Attention :
# Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
# De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
WPIECE       = "PIV"
WDETAILPIECE = "PID"
Gosub ACH_TOTDISCRG From FUNDEB
WFACDISCRG   = WTOTDISCRG
WFACDISCRGVS = WTOTDISCRGVS
Raz WPIECE : Raz WDETAILPIECE
# Si le total des lignes ne permet pas de proratiser,
# il faut prendre en compte les éléments déjà éclatés sur les lignes
If [F:PIV]TOTLINAMT <> 0
  WFISAMT += ((WFACDTAAMT*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRG
  WSTAAMT += ((WFACDTAAMTVS*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRGVS
Else
   # il faut prendre en compte les éléments déjà éclatés sur les lignes
   WFISAMT += WFACDISCRG
   WSTAAMT += WFACDISCRGVS
Endif

#--- Conversion de la valeur fiscale, le cas échéant
If [F:PIH]CUR <> WCUR
   WMONTANT = WFISAMT
   Raz STAT
   Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
   If STAT
     Raz STAT
     Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
     If STAT
       Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
       WPASVALO = 1 : Return
     Endif
   Endif
Endif
#--- Conversion de la valeur statistique, le cas échéant
If [F:PIH]CUR <> WCUR
   WMONTANT = WSTAAMT
   Raz STAT
   Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
   If STAT
     Raz STAT
     Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
     If STAT
       Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
       WPASVALO = 1 : Return
     Endif
   Endif
Endif
#FQ 52777 - la valeur fiscale est modifiée uniquement si la ligne porte sur le même article de la réception
If [F:PID]ITMREF = [F:PTDW]ITMREF
  WFISAMTDTA += WFISAMT
Endif
Raz WFISAMT : Raz WMONTANT
WSTAAMTDTA += WSTAAMT : Raz WSTAAMT : Raz WMONTANTVS
#--- Recherche si existe des factures/avoirs complémentaires ayant comme origine une facture liée à ma réception
#--- Le cas échéant, il faut prendre en compte le montant de cette(ces) facture(s) dans la valorisation de ma réception pour la DEB
If WPASVALO : Return : Endif
#--- uniquement si le paramètre général "EECVALOCPL" est à "Oui"
If GEECVALOCPL=2
  For [PIDC]PID1 Where TYPORI=4 & NUMORI=[F:PIH]NUM & LINORI=[F:PID]PIDLIN & INVTYP < 3
    If [F:PIHC]NUM <> [F:PIDC]NUM
      Read [PIHC]PIH0 = [F:PIDC]NUM
      If fstat : WPASVALO = 1 : Raz [F:PIHC] : Break : Endif
    Endif
    #--- Vérification si la facture n'a pas fait l'objet d'une DEB
    If ([F:PIHC]EECNUMDEB <> 0 & [F:PIHC]EECNUMDEB <> [M]EECNUMDEB) : WPASVALO = 1 : Break : Endif
    #--- La pièce doit être validée
    If [F:PIHC]STA = 3
      If [F:PIVC]NUM <> [F:PIHC]NUM
        Read [PIVC]PIV0 = [F:PIHC]NUM
        If fstat : WPASVALO = 1 : Raz [F:PIVC] : Break : Endif
      Endif
      WMONTANT   = [F:PIDC]AMTNOTLIN
      WMONTANTVS = [F:PIDC]AMTNOTLIN
      #FQ 52776
      If [F:PTDW]EECINCRAT <> 0
        WMONTANTVS = WMONTANTVS*[F:PTDW]EECINCRAT
      Endif
      #--- Prise en compte des éléments de facturation non répartis
      WNUMEROPIECE = [F:PIDC]NUM
      W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
      Gosub ACH_TOTDTA From FUNDEB
      # calcul de WTOTDTA
      # calcul de WTOTDTAVS
      Raz WNUMEROPIECE
      Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
      #--- Prise en compte des éléments de facturation répartis sur les lignes
      WPIECE       = "PIVC"
      WDETAILPIECE = "PIDC"
      Gosub ACH_TOTDISCRG From FUNDEB
      # calcul de WTOTDISCRG
      # calcul de WTOTDISCRGVS
      Raz WPIECE : Raz WDETAILPIECE
      # Si le total des lignes ne permet pas de proratiser,
      # il faut prendre en compte les éléments déjà éclatés sur les lignes
      If [F:PIVC]TOTLINAMT <> 0
        WMONTANT   += ((WTOTDTA*[F:PIDC]AMTNOTLIN)/[F:PIVC]TOTLINAMT) + WTOTDISCRG
        WMONTANTVS += ((WTOTDTAVS*[F:PIDC]AMTNOTLIN)/[F:PIVC]TOTLINAMT) + WTOTDISCRGVS
      Else
         # il faut prendre en compte les éléments déjà éclatés sur les lignes
         WMONTANT   += WTOTDISCRG
         WMONTANTVS += WTOTDISCRGVS
      Endif
      #--- Conversion valeur fiscale
      If [F:PIHC]CUR <> WCUR
        WKMONTANT = WMONTANT
        Raz STAT
        Call CONVERT([F:PIHC]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIHC]ACCDAT,WKMONTANT,WMONTANT,STAT) From TRTDEV
        If STAT
          Raz STAT
          Call CONVERT([F:PIHC]CUR,WCUR,WCUR,[F:PIHC]CURTYP,[F:PIHC]ACCDAT,WKMONTANT,WMONTANT,STAT) From TRTDEV
          If STAT
            Call ECR_TRACE(mess(742,197,1)-[F:PIHC]NUM-mess(71,199,1),1) From GESECRAN
            WPASVALO = 1 : Break
          Endif
        Endif
      Endif
      #--- Conversion valeur statistique
      If [F:PIHC]CUR <> WCUR
        WKMONTANT = WMONTANTVS
        Raz STAT
        Call CONVERT([F:PIHC]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIHC]ACCDAT,WKMONTANT,WMONTANTVS,STAT) From TRTDEV
        If STAT
          Raz STAT
          Call CONVERT([F:PIHC]CUR,WCUR,WCUR,[F:PIHC]CURTYP,[F:PIHC]ACCDAT,WKMONTANT,WMONTANTVS,STAT) From TRTDEV
          If STAT
            Call ECR_TRACE(mess(742,197,1)-[F:PIHC]NUM-mess(71,199,1),1) From GESECRAN
            WPASVALO = 1 : Break
          Endif
        Endif
      Endif
    Else
      # Si pièce non validée, il n'y aura aucune valorisation
      WPASVALO=1 : Break
    Endif
    If [F:PIDC]INVTYP = 1
      #--- Si Facture, le montant vient s'ajouter
      #FQ 52777 - la valeur fiscale est modifiée uniquement
      #si la ligne porte sur le même article de la réception
      If [F:PIDC]ITMREF = [F:PTDW]ITMREF
        WFISAMTDTA += WMONTANT
      Endif
      WSTAAMTDTA += WMONTANTVS
    Elsif [F:PIDC]INVTYP = 2
      #--- Si Avoir, le montant vient en déduction
      #FQ 52777 - la valeur fiscale est modifiée uniquement
      #si la ligne porte sur le même article de la réception
      If [F:PIDC]ITMREF = [F:PTDW]ITMREF
        WFISAMTDTA -= WMONTANT
      Endif
      WSTAAMTDTA -= WMONTANTVS
    Endif
    #--- Prise en compte des factures/avoirs sur pièces complémentaires
    #--- Recherche si existe des factures/avoirs ayant comme origine une facture complémentaires de ma réception
    #--- Le cas échéant, il faut prendre en compte le montant de cette(ces) facture(s) dans la valorisation de ma réception pour la DEB
    For [PIDW]PID1 Where TYPORI=4 & NUMORI=[F:PIDC]NUM & LINORI=[F:PIDC]PIDLIN & INVTYP<3 :#=2 :# Ligne d'avoir sur facture complémentaire
      If [F:PIHC]NUM <> [F:PIDW]NUM
        Read [PIHC]PIH0 = [F:PIDW]NUM
        If fstat : WPASVALO = 1 : Raz [F:PIHC] : Break : Endif
      Endif
      #--- Vérification si la facture n'a pas fait l'objet d'une DEB
      If ([F:PIHC]EECNUMDEB <> 0 & [F:PIHC]EECNUMDEB <> [M]EECNUMDEB) : WPASVALO = 1 : Break : Endif
      #--- La pièce doit être validée
      If [F:PIHC]STA = 3
        If [F:PIVC]NUM <> [F:PIHC]NUM
          Read [PIVC]PIV0 = [F:PIHC]NUM
          If fstat : WPASVALO = 1 : Raz [F:PIVC] : Break : Endif
        Endif
        WMONTANT   = [F:PIDW]AMTNOTLIN
        WMONTANTVS = [F:PIDW]AMTNOTLIN
        #FQ 52776
        If [F:PTDW]EECINCRAT <> 0
          WMONTANTVS = WMONTANTVS*[F:PTDW]EECINCRAT
        Endif
        #--- Prise en compte des éléments de facturation non répartis
        WNUMEROPIECE = [F:PIDW]NUM
        W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
        Gosub ACH_TOTDTA From FUNDEB
        # calcul de WTOTDTA
        # calcul de WTOTDTAVS
        Raz WNUMEROPIECE
        Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
        #--- Prise en compte des éléments de facturation répartis sur les lignes
        WPIECE       = "PIVC"
        WDETAILPIECE = "PIDW"
        Gosub ACH_TOTDISCRG From FUNDEB
        # calcul de WTOTDISCRG
        # calcul de WTOTDISCRGVS
        Raz WPIECE : Raz WDETAILPIECE
        # Si le total des lignes ne permet pas de proratiser,
        # il faut prendre en compte les éléments déjà éclatés sur les lignes
        If [F:PIVC]TOTLINAMT <> 0
          WMONTANT   += ((WTOTDTA*[F:PIDW]AMTNOTLIN)/[F:PIVC]TOTLINAMT) + WTOTDISCRG
          WMONTANTVS += ((WTOTDTAVS*[F:PIDW]AMTNOTLIN)/[F:PIVC]TOTLINAMT) + WTOTDISCRGVS
        Else
           # il faut prendre en compte les éléments déjà éclatés sur les lignes
           WMONTANT   += WTOTDISCRG
           WMONTANTVS += WTOTDISCRGVS
        Endif
          #--- Conversion valeur fiscale
          If [F:PIHC]CUR <> WCUR
            WKMONTANT = WMONTANT
            Raz STAT
            Call CONVERT([F:PIHC]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIHC]ACCDAT,WKMONTANT,WMONTANT,STAT) From TRTDEV
            If STAT
              Raz STAT
              Call CONVERT([F:PIHC]CUR,WCUR,WCUR,[F:PIHC]CURTYP,[F:PIHC]ACCDAT,WKMONTANT,WMONTANT,STAT) From TRTDEV
              If STAT
                Call ECR_TRACE(mess(742,197,1)-[F:PIHC]NUM-mess(71,199,1),1) From GESECRAN
                WPASVALO = 1 : Break
              Endif
            Endif
          Endif
          #--- Conversion valeur statistique
          If [F:PIHC]CUR <> WCUR
            WKMONTANT = WMONTANTVS
            Raz STAT
            Call CONVERT([F:PIHC]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIHC]ACCDAT,WKMONTANT,WMONTANTVS,STAT) From TRTDEV
            If STAT
              Raz STAT
              Call CONVERT([F:PIHC]CUR,WCUR,WCUR,[F:PIHC]CURTYP,[F:PIHC]ACCDAT,WKMONTANT,WMONTANTVS,STAT) From TRTDEV
              If STAT
                Call ECR_TRACE(mess(742,197,1)-[F:PIHC]NUM-mess(71,199,1),1) From GESECRAN
                WPASVALO = 1 : Break
              Endif
            Endif
          Endif
      Else
        # Si pièce non validée, il n'y aura aucune valorisation
        WPASVALO=1 : Break
      Endif
      If [F:PIDW]INVTYP = 1
        #--- Si Facture, le montant vient s'ajouter
        #FQ 52777 - la valeur fiscale est modifiée uniquement
        #si la ligne porte sur le même article de la réception
        If [F:PIDW]ITMREF = [F:PTDW]ITMREF
          WFISAMTDTA += WMONTANT
        Endif
        WSTAAMTDTA += WMONTANTVS
      Elsif [F:PIDW]INVTYP = 2
        #--- Si Avoir, le montant vient en déduction
        #FQ 52777 - la valeur fiscale est modifiée uniquement
        #si la ligne porte sur le même article de la réception
        If [F:PIDW]ITMREF = [F:PTDW]ITMREF
          WFISAMTDTA -= WMONTANT
        Endif
        WSTAAMTDTA -= WMONTANTVS
      Endif
    Next :# du For [PIDW]
    If WPASVALO : Break : Endif
  Next :# du For [PIDC]
  If WPASVALO : Return : Endif
Endif
#--- fin traitement avoirs/factures complémentaires

Return
###################################################################################################
$DEBG_PNH_SST

  If WMVT<>22 Return Endif

  [M:DEBG]FISAMT(nolign-1) = 0
  [M:DEBG]STAAMT(nolign-1) = 0

  Raz WTROUVE
  Raz WVALSTO
  Call FLUX_REGNAT(WMVT,[F:PNH]PNHFCY,W_CRYFROM,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  #--- Elements de facturation
  #Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
  #Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
  #a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
  #puis répartition sur les lignes, au prorata des montants de chaque ligne
  If [F:PTH]PTHNUM<>[F:PND]PTHNUM
    Read [F:PTH]PTH0=[PND]PTHNUM
    If fstat : Raz [F:PTH] : Endif
  Endif
  #--On ne valorise que les éléments répartis
  WNUMEROPIECE = [F:PTH]PTHNUM
  W_VCRTYP=6 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
  Raz WTOTDTA,WTOTDTAVS
  Gosub ACH_TOTDTA From FUNDEB
  WINVDTAAMT2   = WTOTDTA
  WINVDTAAMTVS2 = WTOTDTAVS
  Raz WNUMEROPIECE
  Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO

  #--Pour proratiser les montants de la réception
  #--en fonction des qtés composé retour et réception
  W_LIG_COMPOSE     = [F:PND]PTDLIN
  W_LIG_COMPOSE_QTY = [F:PND]QTYSTU

  Read [PTDW]PTD0=[PND]PTHNUM;[PND]PTDLIN
  If fstat<>0
    Raz [PTDW]
    [M:DEBG]FISAMT  (nolign-1) = 0
    [M:DEBG]STAAMT  (nolign-1) = 0
    Return
  Endif
  W_LIG_COMPOSE_QTY_RCP = [F:PTDW]QTYSTU
  W_ALREADY_READ=0 : W_FOUND_NOTNULL = 0
  Filter [PTDW] Where PTHNUM=[F:PND]PTHNUM and PTDLIN>[F:PND]PTDLIN
  For [PTDW]
    Raz  WTMP_FISAMT,W_MTTHTLINVS
    If [PTDW]LINTYP<2 or ([PTDW]LINTYP=2 and [PTDW]PTDLIN<>W_LIG_COMPOSE) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
    #WTMP_FISAMT = [F:PTDW]LINAMT
    If W_LIG_COMPOSE_QTY_RCP<>0
      WTMP_FISAMT = ([F:PTDW]LINAMT*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
    Endif
    If WTMP_FISAMT<=0
      #--- Si le montant net de la ligne est 0, on prend le prix du mouvement
      #--- Ce dernier est libéllé dans la devise figurant dans "CPRCUR", est porte sur la quantité en UStock
      #--- On tient compte du paramétrage de la valeur stock du flux
      If WTROUVE and WVALSTO=2
        #WTMP_FISAMT = [F:PTDW]QTYSTU*[F:PTDW]CPR
        If W_LIG_COMPOSE_QTY_RCP<>0
          WTMP_FISAMT = (([F:PTDW]QTYSTU*[F:PTDW]CPR)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
        Endif
      Else
        #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
        If W_ALREADY_READ=0
          Raz JL0,JL1
          Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
          If JL0>0 : Raz [F:TSC] : Endif
          Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
          If JL1>0 : Raz [F:TEC] : Endif
          W_ALREADY_READ=1
        Endif
        If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
          #WTMP_FISAMT = [F:PTDW]QTYSTU*[F:PTDW]CPR
          If W_LIG_COMPOSE_QTY_RCP<>0
            WTMP_FISAMT = (([F:PTDW]QTYSTU*[F:PTDW]CPR)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
          Endif
        Endif
      Endif
      If WTMP_FISAMT>0
        If [F:PTDW]CPRCUR <> [F:PTH]CUR
          #--- Il faut convertir le montant dans la devise du document

          #--- Il faut convertir le montant dans la devise du document
          WFISAMT=WTMP_FISAMT
          Raz STAT
          Call CONVERT([F:PTDW]CPRCUR,[F:PTH]CUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WFISAMT,WTMP_FISAMT,STAT) From TRTDEV
          If STAT
            Raz STAT
            Call CONVERT([F:PTDW]CPRCUR,[F:PTH]CUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WFISAMT,WTMP_FISAMT,STAT) From TRTDEV
            If STAT
              WOK=0
              Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
              Break
            Endif
          Endif
        Endif
      Endif
    Else
      W_FOUND_NOTNULL = 1
    Endif

    #--- Prise en compte du taux de majoration CEE
    If [F:PTDW]EECINCRAT <> 0
      W_MTTHTLINVS = WTMP_FISAMT*[F:PTDW]EECINCRAT
    Else
      W_MTTHTLINVS = WTMP_FISAMT
    Endif

    # Attention :
    # Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
    # De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
    WPIECE       = "PTH"
    WDETAILPIECE = "PTDW"
    Gosub ACH_TOTDISCRG From FUNDEB
    WFACDISCRG   = WTOTDISCRG
    WFACDISCRGVS = WTOTDISCRGVS
    Raz WPIECE : Raz WDETAILPIECE
    # Si le total des lignes ne permet pas de proratiser,
    # il faut prendre en compte les éléments déjà éclatés sur les lignes
    [M:DEBG]FISAMT(nolign-1) += WTMP_FISAMT
    [M:DEBG]STAAMT(nolign-1) += W_MTTHTLINVS
    If [F:PTH]TOTLINAMT <> 0 and W_LIG_COMPOSE_QTY_RCP <> 0
      [M:DEBG]FISAMT(nolign-1) += (((WINVDTAAMT2  *[F:PTDW]LINAMT)/[F:PTH]TOTLINAMT)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
      [M:DEBG]STAAMT(nolign-1) += (((WINVDTAAMTVS2*[F:PTDW]LINAMT)/[F:PTH]TOTLINAMT)*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
    Endif
    #--On en prends que les éléments éclatés sur les lignes
    If W_LIG_COMPOSE_QTY_RCP <> 0
      [M:DEBG]FISAMT(nolign-1) +=  (WFACDISCRG  *W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
      [M:DEBG]STAAMT(nolign-1) +=  (WFACDISCRGVS*W_LIG_COMPOSE_QTY)/W_LIG_COMPOSE_QTY_RCP
    Endif

  Next
  Filter [PTDW]
  Raz WINVDTAAMT, WINVDTAAMTVS

  If WOK=0 : Return : Endif

  #--- Conversion de la valeur fiscale, le cas échéant
  If [F:PTH]CUR <> WCUR
    WFISAMT=[M:DEBG]FISAMT(nolign-1)
    Raz STAT
    Call CONVERT([F:PTH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
    If STAT
      Raz STAT
      Call CONVERT([F:PTH]CUR,WCUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
      If STAT
        WOK=0
        Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
        Return
      Endif
    Endif
  Endif
  #--- Conversion de la valeur statistique, le cas échéant
  If [F:PTH]CUR <> WCUR
    WSTAAMT=[M:DEBG]STAAMT(nolign-1)
    Raz STAT
    Call CONVERT([F:PTH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WSTAAMT,[M:DEBG]STAAMT(nolign-1),STAT) From TRTDEV
    If STAT
      Raz STAT
      Call CONVERT([F:PTH]CUR,WCUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WSTAAMT,[M:DEBG]STAAMT(nolign-1),STAT) From TRTDEV
      If STAT
        WOK=0
        Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
        Return
      Endif
    Endif
  Endif
#  #--- Renseignement des pièces prises en compte lors de la valorisation
#  #--- Variables contenant les pièces prises en compte lors de la valorisation de chaque ligne de détail
#  Raz WNOLINVALO
#  Raz WVCRNUMVALO
#  Raz WVCRLINVALO
#  If nolign > NBLIGNESDET
#    Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
#    Call ECR_TRACE(mess(735,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN),1) From GESECRAN
#  Else
#    WINDICE=find([F:PND]PTHNUM,WVCRNUMVALO(0..14,nolign-1))
#    If WINDICE<=0 or (WINDICE>0 and !find([F:PND]PTDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
#      WNOLINVALO += 1
#      If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
#        Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
#        Call ECR_TRACE(mess(735,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN),1) From GESECRAN
#      Else
#        WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PND]PTHNUM
#        WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PND]PTDLIN
#      Endif
#    Endif
#  Endif

  #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
  #--Si le paramètrage des mouvements par flux le permet
  If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
    [M:DEBG]FISAMT(nolign-1) = [F:PTD]QTYSTU*[F:PTD]CPR
    If [M:DEBG]FISAMT(nolign-1)>0
      If [F:PTD]CPRCUR <> [F:PTH]CUR
        #--- Il faut convertir le montant dans la devise du document
        WFISAMT=[M:DEBG]FISAMT(nolign-1)
        Raz STAT
        Call CONVERT([F:PTD]CPRCUR,[F:PTH]CUR,WCUR,GEECTYPCUR,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
        If STAT
          Raz STAT
          Call CONVERT([F:PTD]CPRCUR,[F:PTH]CUR,WCUR,[F:PTH]CHGTYP,[F:PTH]NDEDAT,WFISAMT,[M:DEBG]FISAMT(nolign-1),STAT) From TRTDEV
          If STAT
            WOK=0
            Call ECR_TRACE(mess(735,197,1)-[F:PTH]PTHNUM-mess(71,199,1),1) From GESECRAN
            Return
          Endif
        Endif
      Endif
    Endif
    #--- Prise en compte du taux de majoration CEE
    If [F:PTD]EECINCRAT <> 0
      [M:DEBG]STAAMT(nolign-1) = [M:DEBG]FISAMT(nolign-1)*[F:PTD]EECINCRAT
    Else
      [M:DEBG]STAAMT(nolign-1) = [M:DEBG]FISAMT(nolign-1)
    Endif
  Endif

Return
###################################################################################################
$DEBG_DTA_PNH_SST

  If WMVT<>22 Return Endif

#--Normalement le FLUX_REGNAT est déjà fait pour le mvt 22
#  Raz WTROUVE
#  Raz WVALSTO
#  Call FLUX_REGNAT(WMVT,[F:PNH]PNHFCY,W_CRYFROM,GBIDC2,GBIDC3,WVALSTO,WTROUVE) From FUNDEBA

  If [F:PND]LININVFLG = 2                          :#si ligne retour facturée (existe Avoir sur Retour)
    Raz WFACDTAAMT, WFACDTAAMTVS, WFISAMTDTA, WSTAAMTDTA, W_NUM, WPASVALO, WMAJ, WTRNOK
    W_LIG_COMPOSE=[PND]PNDLIN
    W_ALREADY_READ=0 : W_FOUND_NOTNULL = 0
#    Filter [PNDW] Where PNHNUM=[F:PND]PNHNUM and PNDLIN>[F:PND]PNDLIN
#    For [PNDW]
#      If [PNDW]LINTYP<2 or ([PNDW]LINTYP=2 and [PNDW]PNDLIN<>[PND]PNDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
#      #--- valorisation avec les lignes facturées
#      For [PID]PID1 Where TYPORI=3 & NUMORI=[F:PND]PNHNUM & LINORI=[F:PNDW]PNDLIN & INVTYP = 2
      For [PID]PID1 Where TYPORI=3 & NUMORI=[F:PND]PNHNUM & LINORI>[F:PND]PNDLIN & INVTYP = 2
        If [PID]LINTYP<2 or ([PID]LINTYP=2 and [PID]PNDLIN<>W_LIG_COMPOSE) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc
        If [F:PIH]NUM <> [F:PID]NUM
          Read [PIH]PIH0 = [F:PID]NUM
          If fstat : WPASVALO = 1 : Raz [F:PIH] : Break : Endif
        Endif
        #--- Uniquement les factures validées
        # si une des factures n'est pas validée, il ne faut pas valoriser, car les montants peuvent changer
        If [F:PIH]STA <> 3 : WPASVALO = 1 : Break : Endif
        Read [PNDW]PND0=[PID]PNHNUM;[PID]PNDLIN
        If fstat : Raz [F:PNDW] : Endif
        #--- Prise en compte des éléments de facturation
        Gosub DEBG_DTA_PNH_PIH
        If WPASVALO : Break : Endif
        # Au moins une pièce parcourue
        WNOLINVALO = 1
      Next
#      If WPASVALO=1 : Break : Endif
#    Next
#    Filter [PNDW]
    #--Si aucune des lignes de composant n'a de prix, on se reporte sur le CPR du composé
    #--Si le paramètrage des mouvements par flux le permet
    If W_FOUND_NOTNULL=0 and ((WTROUVE and WVALSTO=2)or (W_ALREADY_READ=1 and ([F:TSC]VALSTO=2|[F:TEC]VALSTO=2)))
      WPASVALO=1
    Endif
    If WPASVALO=1 : Return : Endif

    If WPASVALO = 0 and WNOLINVALO = 1
      WNOLINVALO = 0
      #--- Valeur fiscale valorisée avec les éléments de l'avoir
      If WFISAMTDTA <> 0 and WFISAMTDTA <> [M:DEBG]FISAMT(nolign-1)
        WMAJ = 1
      Endif
      #--- Valeur statistique valorisée avec les éléments de l'avoir
      If WSTAAMTDTA <> 0 and WSTAAMTDTA <> [M:DEBG]STAAMT(nolign-1)
        WMAJ = 1
      Endif
      If WMAJ
        Filter [PNDW] Where PNHNUM=[F:PND]PNHNUM and PNDLIN>=[F:PND]PNDLIN
        For [PNDW]
          If [PNDW]LINTYP<2 or WTRNOK = 1 or ([PNDW]LINTYP=2 and [PNDW]PNDLIN<>[PND]PNDLIN) : Break : Endif :#--Pas mis le test dans le filter car possible plusieures nomenclatures sur même doc

          #--- Mise à jour LINEECFLG des détails avoirs pris en compte
          Update [PID] Where TYPORI=3 & NUMORI=[F:PNDW]PNHNUM & LINORI=[F:PNDW]PNDLIN With LINEECFLG = 2
          If fstat : Call FSTA("PID") From GLOCK : WTRNOK = 1 : Break: Endif

          #--- Mise à jour EECNUMDEB des entêtes avoirs pris en compte
          For [PID]PID1 Where TYPORI=3 & NUMORI=[F:PNDW]PNHNUM & LINORI=[F:PNDW]PNDLIN
            Update [PIH] Where NUM=[F:PID]NUM With EECNUMDEB=[M]EECNUMDEB
            If fstat : Call FSTA("PIH") From GLOCK : WTRNOK = 1 : Break : Endif

            #--- Renseignement des pièces prises en compte lors de la valorisation
            If nolign > NBLIGNESDET
              Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
              Call ECR_TRACE(mess(735,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN),1) From GESECRAN
              WTRNOK = 1
              Break
            Endif
            WINDICE=find([F:PID]NUM,WVCRNUMVALO(0..14,nolign-1))
            If WINDICE<=0 or (WINDICE>0 and !find([F:PID]PIDLIN,WVCRLINVALO(WINDICE-1,nolign-1)))
              WNOLINVALO += 1
              If WNOLINVALO > 15 or nolign > NBLIGNESDET :#CPO 75397 100
                Call ECR_TRACE(mess(736,197,1),1) From GESECRAN  :#Dépassement du nombre de pièces à prendre en compte lors de la valorisation
                Call ECR_TRACE(mess(735,197,1)-[F:PND]PNHNUM-num$([F:PND]PNDLIN),1) From GESECRAN
                WTRNOK = 1
                Break
              Endif
              WVCRNUMVALO(WNOLINVALO-1,nolign-1)=[F:PID]NUM
              WVCRLINVALO(WNOLINVALO-1,nolign-1)=[F:PID]PIDLIN
            Endif
          Next
          If WTRNOK=1 : Break : Endif
        Next
        Filter [PNDW]

      Endif
      If WOK=0 or WTRNOK = 1 : Return : Endif

      #--- Valeur fiscale valorisée avec les éléments de l'avoir
      If WFISAMTDTA <> 0 and WFISAMTDTA <> [M:DEBG]FISAMT(nolign-1)
        [M:DEBG]FISAMT(nolign-1) = WFISAMTDTA
        [M:DEBG]LINVALOFLG(nolign-1)=2
      Endif
      #--- Valeur statistique valorisée avec les éléments de l'avoir
      If WSTAAMTDTA <> 0 and WSTAAMTDTA <> [M:DEBG]STAAMT(nolign-1)
        [M:DEBG]STAAMT(nolign-1) = WSTAAMTDTA
        [M:DEBG]LINVALOFLG(nolign-1)=2
      Endif
    Endif
  Endif

  If WTRNOK = 1 or WOK=0 : Return : Endif

Return
###################################################################################################
#######################################################################
#Prise en compte des éléments de facturation présents sur les avoirs lièes aux retours
#dans le calcul de la valeur fiscale et/ou statistique,
#le cas échéant
#######################################################################
$DEBG_DTA_PNH_PIH
#--- Vérification si les factures ne font pas l'objet d'une autre déclaration
If [M]REG=2
  If ([F:PIH]EECNUMDEB <> 0 & [F:PIH]EECNUMDEB <> [M]EECNUMDEB) : WPASVALO = 1 : Return : Endif
Else
  If  [F:PIH]EECNUMDEB <> 0 : WPASVALO = 1 : Return : Endif
Endif
#--- Enregistrement PIV doit exister
If [F:PIV]NUM <> [F:PIH]NUM
  Read [PIV]PIV0=[F:PIH]NUM
  If fstat : WPASVALO = 1 : Raz [F:PIV] : Return : Endif
Endif
WFISAMT = [F:PID]AMTNOTLIN
#--- La prise en compte de EECINCRAT est faite ici
#--- car après il peut y avoir des éléments de facturation pris en compte uniquement dans la valeur statistique
#--- Pas de EECINCRAT dans le PID
#--- Nous devons le chercher dans la pièce de retour
If [F:PNDW]EECINCRAT <> 0
  WSTAAMT  = [F:PID]AMTNOTLIN*[F:PNDW]EECINCRAT
Else
  WSTAAMT  = [F:PID]AMTNOTLIN
Endif
If [F:PID]AMTNOTLIN=0
  #--- Si le montant net de la ligne est 0, on prend le prix du mouvement du retour
  #--- Ce dernier est libéllé dans la devise figurant dans "CPRCUR", est porte sur la quantité en UStock
  #--- On tient compte du paramétrage de la valeur stock du flux
  If WTROUVE and WVALSTO=2
    WFISAMT = [F:PID]QTYSTU*[F:PNDW]CPR :# "Prix de revient" de la ligne de retour
  Else
    #--- Il faut tenir compte du paramétrage "Valeur stock" de la table des Régimes
    If W_ALREADY_READ=0
      Raz JL0,JL1
      Call LEC_TSC_LEG(GCURLEG,[M:DEBG]EECSCH(nolign-1),JL0) From TRTLECLEG
      If JL0>0 : Raz [F:TSC] : Endif
      Call LEC_TEC_LEG(GCURLEG,[M:DEBG]EECNAT(nolign-1),JL1) From TRTLECLEG
      If JL1>0 : Raz [F:TEC] : Endif
      W_ALREADY_READ=1
    Endif
    If [F:TSC]VALSTO=2 | [F:TEC]VALSTO=2
    #--/
      WFISAMT = [F:PID]QTYSTU*[F:PNDW]CPR :# "Prix de revient" de la ligne de retour
    Endif
  Endif
  If WFISAMT > 0
    If [F:PIH]CUR <> [F:PNDW]CPRCUR
      WKMONTANT = WFISAMT
      Raz STAT
      Call CONVERT([F:PNDW]CPRCUR,[F:PIH]CUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WKMONTANT,WFISAMT,STAT) From TRTDEV
      If STAT
        Raz STAT
        Call CONVERT([F:PNDW]CPRCUR,[F:PIH]CUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WKMONTANT,WFISAMT,STAT) From TRTDEV
        If STAT
          Call ECR_TRACE(mess(735,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
          WPASVALO = 1 : Return
        Endif
      Endif
      If [F:PNDW]EECINCRAT <> 0
        WSTAAMT  = WFISAMT*[F:PNDW]EECINCRAT
      Else
        WSTAAMT  = WFISAMT
      Endif
    Endif
  Endif
Else
  W_FOUND_NOTNULL = 1
Endif
#--- En-tête, nous calculons la somme des éléments de facturation de l'en-tête
#--- Eléments de facturation
#Les éléments de facturation sont présents sur les pieds des pièces autres que les factures
#Prise en compte des éléments non répartis sur les lignes : INVLINFLG = 1 ou 6,
#a condition qu'ils entrent dans le calcul de la valeur fiscale et/ou valeur statistique : CLCDEB = 2 ou 3
#puis répartition sur les lignes, au prorata des montants de chaque ligne
WNUMEROPIECE = [F:PID]NUM
W_VCRTYP=8 # Issue 110289 - 2015-08-12 by CPO : Invoicing elements when using same counter on different documents
Gosub ACH_TOTDTA From FUNDEB
WFACDTAAMT   = WTOTDTA
WFACDTAAMTVS = WTOTDTAVS
Raz WNUMEROPIECE
Raz W_VCRTYP # Issue 110289 - 2015-08-12 by CPO
W_NUM = [F:PID]NUM
#--- Nous traitons la ligne de détail avoir liée au détail de retour
#--- Calcul de la somme des éléments de facturation répartis sur les lignes
# Attention :
# Chaque DISCRGAMTx sera pris en compte si l'élément de facturation duquel il provient a CLCDEB > 1
# De plus les éléments peuvent rentrer différement dans le calcul de la valeur fiscale et/ou de la valeur statistique
WPIECE       = "PIV"
WDETAILPIECE = "PID"
Gosub ACH_TOTDISCRG From FUNDEB
WFACDISCRG   = WTOTDISCRG
WFACDISCRGVS = WTOTDISCRGVS
Raz WPIECE : Raz WDETAILPIECE
# Si le total des lignes ne permet pas de proratiser,
# il faut prendre en compte les éléments déjà éclatés sur les lignes
If [F:PIV]TOTLINAMT <> 0
  WFISAMT += ((WFACDTAAMT*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRG
  WSTAAMT += ((WFACDTAAMTVS*[F:PID]AMTNOTLIN)/[F:PIV]TOTLINAMT) + WFACDISCRGVS
Else
  WFISAMT += WFACDISCRG
  WSTAAMT += WFACDISCRGVS
Endif
#--- Conversion de la valeur fiscale, le cas échéant
If [F:PIH]CUR <> WCUR
  WMONTANT = WFISAMT
  Raz STAT
  Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
  If STAT
    Raz STAT
    Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WFISAMT,STAT) From TRTDEV
    If STAT
      Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
      WPASVALO = 1 : Return
    Endif
  Endif
Endif
#--- Conversion de la valeur statistique, le cas échéant
If [F:PIH]CUR <> WCUR
  WMONTANT = WSTAAMT
  Raz STAT
  Call CONVERT([F:PIH]CUR,WCUR,WCUR,GEECTYPCUR,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
  If STAT
    Raz STAT
    Call CONVERT([F:PIH]CUR,WCUR,WCUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,WMONTANT,WSTAAMT,STAT) From TRTDEV
    If STAT
      Call ECR_TRACE(mess(742,197,1)-[F:PIH]NUM-mess(71,199,1),1) From GESECRAN
      WPASVALO = 1 : Return
    Endif
  Endif
Endif
WFISAMTDTA += WFISAMT : Raz WFISAMT
WSTAAMTDTA += WSTAAMT : Raz WSTAAMT

Return
###################################################################################################
$VALO_AVR_RET_SST
If [F:SID]SRHNUM = "" or [F:SID]LINTYP<>10 : Return : Endif
#Lors de la valorisation de la ligne de retour, si le montant de l'avoir sur retour est 0
#on prend le prix de l'ordre de la ligne de retour.
#Donc, quand on extrait le flux de régul Expédition, sur la ligne d'avoir, si son montant est à 0
#il faut également valoriser cette ligne avec le prix de l'ordre du retour à l'origine de l'avoir
Raz WFISAMT : Raz WSTAAMT
Read [F:SRD]SRD0=[F:SID]SRHNUM;[F:SID]SRDLIN
If !fstat
  Raz WFACDTAAMT, WFACDTAAMTVS, WFISAMTDTA, WSTAAMTDTA, W_NUM, WTOTAMTNOT, WMAJ, WPASVALO, WTRNOK
  WSAVE_WMVT=WMVT : WMVT=24 #--Retour de sous-traitance produit fini
  Gosub DEBG_DTA_SRH From FUNDEB
  [M:DEBG]FISAMT(nolign-1) = WFISAMTDTA
  [M:DEBG]STAAMT(nolign-1) = WSTAAMTDTA
  WMVT=WSAVE_WMVT
Endif

Return

