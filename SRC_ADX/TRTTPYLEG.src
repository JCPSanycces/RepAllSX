#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################################################################
# Reports TRAITENR, LISREG, CONFVIR
###########################################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Char    SOCIETE(GLONCPY)
Local Char    ETAT(GLONARP)
Local Char    VALEUR(30) , PARAM(50)
Local Integer K
Local Integer NUMREQ
Local Integer NBSOC
Local Char    TBSOC(GLONCPY)(1..GNBSOC)
Local Integer NBRLEG
Local Char    TABLEG(GLONADI)(1..GNBSOC)

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:ARM])=0  : Local File AREPORTM   [ARM]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif
If clalev([F:TPY])=0  : Local File TABPAYTYP  [TPY]  : Endif
If clalev([F:TPY2])=0 : Local File TABPAYTYP  [TPY2] : Endif
If clalev([F:CDA])=0  : Local File GACCDENCOD [CDA]  : Endif
If clalev([F:CDA2])=0 : Local File GACCDENCOD [CDA2] : Endif
If clalev([F:TED])=0  : Local File TABCODEDT  [TED]  : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT) From ETAT
K = instr(1,ETAT,".")
If K
 ETAT = left$(ETAT,K-1)
Endif
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT : NUMREQ = val(PARAM)
PARAM = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT
Case ETAT
 When "TRAITENR","LISREG","CONFVIR"
  Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
  If SOCIETE<>""
   Read [CPY]CPY0 = SOCIETE
   If fstat
    # Société incorrecte
    Call ECR_TRACE(mess(81,116,1),1) From GESECRAN
    GOK = 0 : End
   Endif
   If [F:CPY]CPYLEGFLG<>2
    NBSOC = 0
    For [FGR]FGR0 Where CPY=SOCIETE
     Read [FCY]FCY0 = [F:FGR]FCY
     If !find([F:FCY]LEGCPY,TBSOC(1..NBSOC))
      NBSOC += 1
      TBSOC(NBSOC) = [F:FCY]LEGCPY
     Endif
    Next
   Else
    NBSOC = 1
    TBSOC(1) = SOCIETE
   Endif
  Else # Société non initialisée
   NBSOC = 0
   For [CPY]CPY0 Where CPYLEGFLG=2
    NBSOC += 1
    TBSOC(NBSOC) = [F:CPY]CPY
   Next
  Endif
  Call LEGCPY(TBSOC,NBRLEG,TABLEG) From CPTDIV
  Call DEBTRANS From GLOCK
  Gosub TR0 From RPTLEG
  Gosub TRT_TPY From RPTLEG
  If ETAT="LISREG"  : Gosub TRT_CDA From RPTLEG : Endif
  If ETAT="CONFVIR" : Gosub TRT_TED From RPTLEG : Endif
Endcase
End
