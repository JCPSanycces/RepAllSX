######################################################################################################
# Project       : Swiss Localization
# File          : SUBTPTSWI
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 19.11.15
######################################################################################################
# Module        : Sales
# Description   : Swiss specific checks for payment terms
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
######################################################################################################


$VERIF_CRE
# SAM 110033: Swiss localization: check if payment method is of type "ISR Printing" and if yes, apply additional controls
If func AFNC.ACTIV("KSW")
   Local Integer I, CNT, POK
   CNT = 0 : POK = 1
   If !clalev([F:TAM]) : Local File TABPAM [TAM] : Endif   # payment methods
   For I = 0 To [M:TPT1]BASTAB-1
      Call LEC_TAM([M:TPT1]LEG, [M:TPT1]PAM(I)) From CPTLEC
      If !fstat
         If [F:TAM]SWIPAMBVR = 2  # Print
            If [M:TPT1]BASTAB > 1 or CNT >= 1 : OK = 0 : POK = 0 : Break : Endif  # more than 1 line or already one PAM with "Print" found
            CNT += 1
            If [M:TPT1]DUDPRC(I) <> 100 : OK = 0 : POK = 0 : Break : Endif # "% due date" must be 100 %
            If [M:TPT1]PAMTYP(I) <> 1   : OK = 0 : POK = 0 : Break : Endif # "Payment type" must be "Open item"
            If [M:TPT1]GFY <> ""                                           # check if at least one company of the group has legislation SWI
               If !clalev([F:AGC]) : Local File AGRPCPY [AGC] : Endif
               If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
               Local Integer FOUND : FOUND = 0
               For [F:AGC] Where GRP = [M:TPT1]GFY
                 Read [F:CPY]CPY0 = [F:AGC]CPY
                 If [F:CPY]LEG = "SWI" : FOUND = 1 : Break : Endif
               Next
               If FOUND = 0
                  OK = 0
                  GERR=1
                  GMESSAGE=mess(60,3648,1) # For pymt. terms with pymt. methods used for ISR printing, at least one company of the group must belong to the Swiss leg.
                  Break
               Endif
            Endif
         Endif
      Endif
   Next I
   If not POK : GERR=1 : GMESSAGE=mess(61,3648,1) : Endif # For payment terms with payment methods used for ISR printing, the % due date must be 100% and the payment type = Open item
Endif
Return


