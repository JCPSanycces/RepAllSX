#<AdxTL>@(#)2.0.0.0 $Revision$
Local Integer NBFIC,I
Local Char FICHIERS(20)(1..1000)
Local Char REPERT_ORI(100),REPERT_DES(100),FICHIER_CONFIG(100),REPERT_BASE(100)

# A modifier selon le cas
# Si des chemin absolu sont mis, il sont respectés par le Call INIT
# Sinon, les chemins sont relatifs par rapport à REPERT_BASE
# Si REPERT_BASE est vide, il est renseigné par le Call INIT
REPERT_BASE="/home/mbz/fra/fonction"
REPERT_ORI="fc1"
REPERT_DES="fct"
FICHIER_CONFIG="html.cfg"

Call INIT(REPERT_BASE,REPERT_ORI,REPERT_DES,FICHIER_CONFIG) From DEFHTML

## dbgmode(1)=1

## System FICHIERS="cd"-REPERT_ORI+"; ls F_TOTO.htm"
System FICHIERS="cd"-REPERT_ORI+"; ls *.htm"
NBFIC=stat1
##
## les F_XXX.htm deviennent GESXXX.htm
##
For I=1 To NBFIC
  Openi REPERT_ORI+"/"+FICHIERS(I),0
  If mid$(FICHIERS(I),6,4)='.htm'
    FICHIERS(I)='GES' + mid$ (FICHIERS(I),3,9)
    Else
    FICHIERS(I)= mid$ (FICHIERS(I),3,20)
  Endif
  Openo REPERT_DES+"/"+FICHIERS(I),0
  Call TEMPON("Transcodage"-FICHIERS(I)) From GESECRAN
  Call TRANSCODE
  Call TEMPOFF From GESECRAN
Next I
Kill TRS_CO
End

Subprog TRANSCODE

Local Libelle OCT_LUS(10000)
Local Char CHAINE(255),CHAINE1(255),TITLE(255)
Local Integer LONG,BOUTON,PREMIER_H2,BOUTOK,II

# Prerequis important !
adxifs=chr$(0) : adxifs=chr$(0)
fstat=0
PREMIER_H2=0

# Recherche de la première clause H1 pour trouver le titre
Repeat
  Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
Until fstat<>0 | vireblc(toupper(CHAINE),3)="H1"

Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
CHAINE1=CHAINE
Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
While vireblc(toupper(CHAINE),3)<>"/H1" & fstat=0
  Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  CHAINE1+=CHAINE
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
Wend
If fstat=0 : TITLE=CHAINE1 : Else : TITLE="" : Endif
fstat=0
Seek First
While fstat=0
  Call COPIE_JUSQUE(ascii("<"))
  If fstat : Break : Endif

  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)

  CHAINE1=toupper(vireblc(CHAINE,3))
  Case CHAINE1
    When "HTML","HEAD","BODY","/HTML","/HEAD","/TITLE","/BODY",
&        "A","/A","P","/P"
       Call ECRIT_CHAINE("<"+CHAINE+">")
    When "TITLE"
       Gosub TRAITE_TITLE
    When "FONT"
       Gosub TRAITE_FONTES_SPECIALES
    When "H1","H2","H3","H4","H5","H6"
       Gosub TRAITE_EN_TETES
    When Default
       Call ECRIT_CHAINE("<"+CHAINE+">")
  Endcase
Wend
Openi:Openo
End

$TRAITE_FONTES_SPECIALES
# Lucida Console => on va mettre un bouton à la place...
If pat(vireblc(toupper(CHAINE),0),'FONT FACE="'+toupper(TRS_CO(6))+'"*')
  Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  CHAINE1=""
  While CHAINE="" & fstat=0 & CHAINE1<>"/F"
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE1,LONG)
    Call ECRIT_CHAINE('<'+CHAINE1+'>')
    Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  Wend
  If vireblc(CHAINE,4)<>""
    Call ECRIT_CHAINE('<Input type="button" value="')
    Call ECRIT_CHAINE(vireblc(ctrans(ctrans(CHAINE),'-/"'+"'()","  "),5))
    BOUTON+=1
    BOUTOK=1
  Else
    BOUTOK=0
  Endif
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  CHAINE1=vireblc(toupper(CHAINE),3)
  If find(CHAINE1,"H1","H2","H3","H4","H5")
    Repeat
      Call COPIE_JUSQUE(ascii("<"))
      Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
    Until vireblc(toupper(CHAINE),3)="/"+CHAINE1 | fstat=1
    Call COPIE_JUSQUE(ascii("<"))
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  Endif
  If BOUTOK=1
    Call ECRIT_CHAINE('" name="B'+num$(BOUTON)+'">')
  Endif
  CHAINE1=toupper(vireblc(CHAINE,3))
  While CHAINE1<>"/FONT" & fstat=0
    Call ECRIT_CHAINE("<")
    Call ECRIT_CHAINE(CHAINE+">")
    Call COPIE_JUSQUE(ascii("<"))
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
    CHAINE1=toupper(vireblc(CHAINE,3))
  Wend
# Arial Black => on va mettre une image à la place...
Elsif pat(vireblc(toupper(CHAINE),0),'FONT FACE="'+toupper(TRS_CO(10))+'"*')
  Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  While vireblc(CHAINE,4)="" & fstat=0
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
    Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  Wend
  Call ECRIT_CHAINE('<IMG src="'+vireblc(CHAINE,4)+'">')
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  While CHAINE<>"/FONT" & fstat=0
    Call COPIE_JUSQUE(ascii("<"))
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  Wend
# Arial Narrow => on va mettre un lien hyper-texte à la place
Elsif pat(vireblc(toupper(CHAINE),0),'FONT FACE="'+toupper(TRS_CO(11))+'"*')
  Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  While vireblc(CHAINE,4)="" & fstat=0
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
    Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
  Wend
  II=instr(1,CHAINE,"/")
  If II
    Call ECRIT_CHAINE(TRS_CO(13))
    Call ECRIT_CHAINE('<A HREF="../hlp/'+vireblc(right$(CHAINE,II+1),4)+'.htm">')
    Call ECRIT_CHAINE(left$(CHAINE,II-1))
    Call ECRIT_CHAINE("</A>")
    Call ECRIT_CHAINE("</FONT>")
  Endif
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  While CHAINE<>"/FONT" & fstat=0
    Call COPIE_JUSQUE(ascii("<"))
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  Wend
Else
  Call ECRIT_CHAINE("<"+CHAINE+">")
Endif
Return

$TRAITE_EN_TETES
  If CHAINE1="H1"
    Call ECRIT_CHAINE(TRS_CO(1))
  Elsif CHAINE1="H2"
    If PREMIER_H2=0
       PREMIER_H2=1
    Else
       Call ECRIT_CHAINE('<HR>')
    Endif
    Call ECRIT_CHAINE(TRS_CO(2))
  Elsif CHAINE1="H3"
    Call ECRIT_CHAINE(TRS_CO(3))
  Elsif CHAINE1="H4"
    Call ECRIT_CHAINE(TRS_CO(4))
  Elsif CHAINE1="H5"
    Call ECRIT_CHAINE(TRS_CO(5))
  Endif
  Call COPIE_JUSQUE(ascii("<"))
  Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  While fstat=0 & vireblc(toupper(CHAINE),3)<>"/"+CHAINE1
    Call ECRIT_CHAINE("<"+CHAINE+">")
    Call COPIE_JUSQUE(ascii("<"))
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  Wend
  Call ECRIT_CHAINE("</FONT></"+CHAINE1+">")
Return

$TRAITE_TITLE
  Call ECRIT_CHAINE('<TITLE>'+TITLE)
  Repeat
    Call LIT_CHAINE_JUSQUE(ascii("<"),CHAINE,LONG)
    Call LIT_CHAINE_JUSQUE(ascii(">"),CHAINE,LONG)
  Until fstat<>0 | vireblc(toupper(CHAINE),3)="/TITLE"
  Call ECRIT_CHAINE("</TITLE>")
Return

Subprog COPIE_JUSQUE(CARAC)
Value Integer CARAC
Local Libelle OCT_LUS
Getseq 1,OCT_LUS
While fstat=0 & OCT_LUS<>CARAC
  Putseq 1,OCT_LUS
  Getseq 1,OCT_LUS
Wend
End

Subprog ECRIT_CHAINE(CH_ECR)
Variable Char CH_ECR # FGR 01/02/2010 : X3SUIVI60986 : pas CHR_ECR()
  Wrseq CH_ECR;
End

Subprog LIT_CHAINE_JUSQUE(CARAC,CH_LUE,LONG)
Value Integer CARAC : Variable Integer LONG
Variable Char CH_LUE()
Local Libelle CAR
CH_LUE=""
[L]LONG=0
[L]CAR=0
Repeat
  CH_LUE+=chr$([L]CAR)
  Getseq 1,[L]CAR
  [L]LONG+=1
Until fstat=1 | ([L]CAR=[L]CARAC)
[L]LONG-=1
End


# Lecture du fichier de config optionnel
Subprog LIT_FICHIER_CONFIG(FICHIER)
Value Char FICHIER()
Local Char CHAINE(255)
Local Integer L
Onerrgo EROUV

# Valeurs par défaut au cas où...
TRS_CO(1)='<H1 ALIGN="CENTER"><FONT FACE="Comic Sans MS" SIZE="7" COLOR="#FF0000">'
TRS_CO(2)='<H2><FONT FACE="Comic Sans MS" SIZE="6" COLOR="#0000FF">'
TRS_CO(3)='<H3><FONT FACE="Comic Sans MS" SIZE="5" COLOR="#0000FF">'
TRS_CO(4)='<H4><FONT FACE="Comic Sans MS" SIZE="4" COLOR="#0000FF">'
TRS_CO(5)='<H5><FONT FACE="Comic Sans MS" SIZE="3" COLOR="#0000FF">'
TRS_CO(6)="Lucida Console"
TRS_CO(7)='<UL><FONT FACE="Comic Sans MS" SIZE="4" COLOR="#00FF00">'
TRS_CO(8)='<LI>'
TRS_CO(9)='</FONT></UL>'
TRS_CO(11)='<FONT FACE="Arial Narrow" SIZE=3>'

Openi FICHIER,0

# Fichiers aux normes UNIX svp !
adxifs=chr$(10):adxirs=chr$(0)

fstat=0
While fstat=0
  Rdseq CHAINE : CHAINE=vireblc(CHAINE,0)
  If left$(CHAINE,1)="<"
    L=instr(1,CHAINE,">")
    If L
      Case seg$(CHAINE,2,L-1)
        When "H1","H2","H3","H4","H5"
        TRS_CO(val(mid$(CHAINE,3,1)))=CHAINE
      When "BUTTON"
        TRS_CO(6)=vireblc(right$(CHAINE,L+1),0)
      When "STARTMENU"
        TRS_CO(7)=vireblc(right$(CHAINE,L+1),0)
      When "ENDMENU"
        TRS_CO(9)=vireblc(right$(CHAINE,L+1),0)
      When "LINEMENU"
        TRS_CO(8)=vireblc(right$(CHAINE,L+1),0)
      When Default
        # Rien pour le moment...
      Endcase
    Endif
  Endif
Wend
Openi
$EROUV
End
