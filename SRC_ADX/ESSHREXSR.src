#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
If clalev([F:EXSH1])   = 0 : Local File EXPENSESHEA    [EXSH1]     : Endif
If clalev([F:HREXS])  = 0 : Local File HREXPENSES     [HREXS]     : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID          [ID]      : Endif
Default File [F:EXSH1]
Return

$DEBUT
Local Integer STAT(1..10)

#Update header icon
#[M]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M]WSTADES2 = 2


STAT(1) = 2
STAT(2) = 6
Call POPULATE_MASK(STAT,PARAM(1)) From ESSHREXSR
Return

Subprog POPULATE_MASK(VSTAT,VEMP)
Value Integer VSTAT
Value Char VEMP
Local Char EMPCODE (GLONEML)
Local Decimal TOTPAY
If VEMP = AVOID.ACHAR
  EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Else
  EMPCODE = VEMP
Endif

Filter [F:EXSH1] Where REFNUM = EMPCODE and find(EXSSTA,VSTAT) Order By STRDAT Desc
nolign =0
For [F:EXSH1]
  nolign+=1
  If nolign > dim([M]REFNUM) : Break : Endif
  Raz TOTPAY
  For [F:HREXS] Where REFNUM = EMPCODE and EXSNUM = [F:EXSH1]EXSNUM
    TOTPAY+=[F:HREXS]PAYSHR
  Next
  [M] = [F]
  #Update TOTPAY
  [M]TOTPAY(nolign-1) = TOTPAY

  #Update icon
  #[M]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:EXSH1]EXSSTA)

  [M]NBRLIN = nolign
Next

Filter [F:EXSH1]
Affzo [M]1-99
End

