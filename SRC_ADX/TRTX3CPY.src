#CHECK IGNORE_SOURCE
#######################################################################
# TRTX3CPY         TRAITEMENTS COMMUNS X3  MULTI-SOCIETES             #
#######################################################################
#######################################################################
# ------------------------------------------------------------------- #
# Gosub OPEN_CPYVIEW                                                  #
# - Ouverture de toutes les vues des tables gerees en multi-societe   #
# - Si table de base est ouverte --> fermeture et ouverture de la vue #    
#######################################################################
$OPEN_CPYVIEW
If filinfo(filpath("FIL","BPARTNER","fde",nomap),0)  >0 : Gosub OPEN_BPR : Endif   : # Business Partner
If filinfo(filpath("FIL","BPCUSTOMER","fde",nomap),0)>0 : Gosub OPEN_BPC : Endif   : # Clients / Prospects
If filinfo(filpath("FIL","BPDLVCUST","fde",nomap),0) >0 : Gosub OPEN_BPD : Endif   : # Clients Livres

#If filinfo(filpath("FIL","BPSUPPLIER","fde",nomap),0)>0 : Gosub OPEN_BPS : Endif   : # Fournisseurs
#If filinfo(filpath("FIL","ITMMASTER","fde",nomap),0) >0 : Gosub OPEN_ITM : Endif   : # Articles
#If filinfo(filpath("FIL","ITMSALES","fde",nomap),0)  >0 : Gosub OPEN_ITS : Endif   : # Articles-Ventes
#If filinfo(filpath("FIL","ITMBPC","fde",nomap),0)    >0 : Gosub OPEN_ITU : Endif   : # Articles-Clients
#If filinfo(filpath("FIL","ITMBPS","fde",nomap),0)    >0 : Gosub OPEN_ITP : Endif   : # Articles-Fournisseurs
#If filinfo(filpath("FIL","SFOOTINV","fde",nomap),0)  >0 : Gosub OPEN_SFI : Endif   : # Elements fact. ventes
#If filinfo(filpath("FIL","PFOOTINV","fde",nomap),0)  >0 : Gosub OPEN_PFI : Endif   : # Elements fact. achats
Return
# ---------------------------------------------------------------------

$OPEN_BPR
If dim([F:BPR]WCPY)<=0
   If clalev([F:BPR]) : Close Local File [BPR] : Endif
   Local File WVCPYBR1 [BPR]
Endif
Return

$OPEN_BPC
If dim([F:BPC]WCPY)<=0
   If clalev([F:BPC]) : Close Local File [BPC] : Endif
   Local File WVCPYBC1 [BPC]
Endif
Return

$OPEN_BPD
If dim([F:BPD]WCPY)<=0
   If clalev([F:BPD]) : Close Local File [BPD] : Endif
   Local File WVCPYBD1 [BPD]
Endif
Return

$OPEN_BPS
If dim([F:BPS]WCPY)<=0
   If clalev([F:BPS]) : Close Local File [BPS] : Endif
   Local File WVCPYBPS [BPS]
Endif
Return

$OPEN_ITM
If dim([F:ITM]WCPY)<=0
   If clalev([F:ITM]) : Close Local File [ITM] : Endif
   Local File WVCPYITM [ITM]
Endif
Return

$OPEN_ITS
If dim([F:ITS]WCPY)<=0
   If clalev([F:ITS]) : Close Local File [ITS] : Endif
   Local File WVCPYITS [ITS]
Endif
Return

$OPEN_ITU
If dim([F:ITU]WCPY)<=0
   If clalev([F:ITU]) : Close Local File [ITU] : Endif
   Local File WVCPYITU [ITU]
Endif
Return

$OPEN_ITP
If dim([F:ITP]WCPY)<=0
   If clalev([F:ITP]) : Close Local File [ITP] : Endif
   Local File WVCPYITP [ITP]
Endif
Return

$OPEN_SFI
# If dim([F:SFI]WCPY)<=0
#    If clalev([F:SFI]) : Close Local File [SFI] : Endif
#    Local File WVCPYSFI [SFI]
# Endif
#If dim([F:SFI]WCPY)>0
#    If clalev([F:SFI]) : Close Local File [SFI] : Endif
#    Local File SFOOTINV [SFI]
# Endif
If !clalev([F:SFI]) : Local File SFOOTINV [SFI] : Endif
Return

$OPEN_PFI
If dim([F:PFI]WCPY)<=0
   If clalev([F:PFI]) : Close Local File [PFI] : Endif
   Local File WVCPYPFI [PFI]
Endif
Return

