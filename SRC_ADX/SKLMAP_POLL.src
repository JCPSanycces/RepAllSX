#Return

$SKM_POLL

Local Char WEBSERNAME (50)
Local Char HTTPMETHOD (10)
Local Char SUBURL(255)
Local Char PCOD(100)(1..10)
Local Char PVAL(100)(1..10)
Local Char HCOD(100)(1..10)
Local Char HVAL(100)(1..10)
Local Clbfile MYDATA(0)
Local Clbfile RESHEAD(0), RESBODY(0)
Local Integer MAXTEXT, MAXCOUNTER
Local Char WRES(250),WMES(250),WDOS(30)
Local Integer WI,I.XI,ZI
Local Integer RET
MAXTEXT = 250
Local Char W_MESS(MAXTEXT)
MAXCOUNTER = MAXTEXT

Local Clbfile TEST(0)

WEBSERNAME = "Skills_Map"
HTTPMETHOD = "PUT"
SUBURL =  "/Job/GetFill"

HCOD(1)="Accept-Language"
HVAL(1)='"fr, en-gb;q=0.8, en;q=0.7"'

HCOD(2)="Content-Type"
HVAL(2)= '"application/json"'


Local Clbfile MYDATA
Local Clbfile MYDATA(0)

Local Char APIKEY(100)
APIKEY=func AFNC.PARAMDOS(nomap,"RECAPIKEY")


Local Char VENDORID(100)
VENDORID=func AFNC.PARAMDOS(nomap,"RECVENID")

If clalev ([F:SKM]) = 0 : Local File SKLMAP [SKM] Endif
Filter [F:SKM] Where JOBSTAT = 3

    For [F:SKM]

          MYDATA = "{"
          MYDATA +=  '"JobId":'+[F:SKM]JOBIDS +','
          MYDATA +=  '"ReturnPhoto":false,'
          MYDATA +=  '"apiKey": "'+APIKEY+'",'
          MYDATA +=  '"vendorID":'+VENDORID
          MYDATA +=  '}'




        RETVAL=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, MYDATA, 0, "", RESHEAD, RESBODY)

        #Test the HTTP Status
        If RETVAL<> 200
          # Error from Syracuse server
          W_MESS=mid$(RESBODY,1,MAXTEXT)
          While W_MESS <> ""
          #  [L]ARET_VALUE  = fmet this.ASETERROR("",num$(W_MESS),[V]CST_AERROR)
            W_MESS=mid$(RESBODY,1+MAXCOUNTER,MAXTEXT)
            MAXCOUNTER += MAXTEXT
          Wend
        Else
          Gosub GET_MESSAGE_SYR_POLL
        Endif
    Next

Return

$GET_MESSAGE_SYR_POLL

  Local Integer WII,XII,ZII
  Local Char REFERENCENUMEMP(100)
  Local Char THISVALUE(30)
  Local Instance  NODES(1..) Using C_ASYRJSO
  Local Instance  NODE  Using C_ASYRJSO
  #Local Instance ENV Using =[V]CST_C_NAME_CLASS_CONTEXT
  #ENV = NewInstance [ENV] With =[V]CST_C_NAME_CLASS_CONTEXT
  Raz WI,WRES,WMES,WDOS
  ASTATUS = func ASYRJSONPARSE.PARSEJSON(GACTX,RESBODY,NODES,NODE)

  If clalev ([F:ID]) = 0 : Local File EMPLOID[ID] Endif
  If clalev ([F:SKMC]) = 0 : Local File SKLMAPC [SKMC] Endif
  If clalev ([F:SKM]) = 0 : Local File SKLMAP [SKM] Endif




  If ASTATUS=0

           REFERENCENUMEMP = ""


            For WII=maxtab(NODES) To 1 Step -1
                 If NODES(WII).TYP=5
                  Case NODES(WII).PRO
                      When "Success":
                         WRES=num$(mid$(NODES(WII).CLB.CLB,NODES(WII).START,NODES(WII).LENGTH))
                          If WRES = "true"
                              For XII=maxtab(NODES) To 1 Step -1
                                 If NODES(XII).TYP=3
                                    Case NODES(XII).PRO
                                     When "ReferenceKey":
                                        REFERENCENUMEMP = num$(mid$(NODES(XII).CLB.CLB,NODES(XII).START+1,NODES(XII).LENGTH-2))
                                    Endcase
                                 Endif
                               Next
                          Endif
                   Endcase
                 Endif
              Next

              If REFERENCENUMEMP <> "" Then

              Trbegin [F:ID]

              Filter [F:SKM]   Where REFERENCENUM=REFERENCENUMEMP
              Read [F:SKM]SKM0= REFERENCENUMEMP

                For ZII=maxtab(NODES) To 1 Step -1
                 If NODES(ZII).TYP=3
                      Case NODES(ZII).PRO
                          When "ReferenceKey":
                             WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                             [F:SKMC]REFERENCENUM=WRES
                             [F:ID]REFNUM=WRES

                         When "HighestQualification":
                                 WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                 [F:SKMC]QUALIFICA=WRES

                          When "City":
                                    WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                  #  ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)
                                   [F:ID]CTY=WRES
                                 #   [F:SKMC]CTY=WRES

                          When "StateProvinceRegion":
                                  WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                               #   ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)
                                #  [F:ID]CTY=WRES
                                # [F:SKMC]PROV=WRES

                          When "CountryCode":
                                  WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                              #
                                  [F:ID]CRY=WRES
                                  [F:ID]CRYBRN=WRES


                                If clalev ([F:AXX]) = 0 : Local File ATEXTRA [AXX] Endif
                                Filter [F:AXX] Where CODFIC = "TABCOUNTRY" & ZONE = "CRYDES" & LANGUE = "ENG" & IDENT1 = WRES
                                 Read [F:AXX]AXX0 Last

                               # ASTATUS = fmet this.ASETERROR("",[F:AXX]TEXTE,[V]CST_AINFO)

                                [F:ID]CRYNAM=[F:AXX]TEXTE
                                [F:ID]CRYNAMBRN=[F:AXX]TEXTE


                         When "Disability":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]DISABILITY=WRES

                          When "AlternatePhoneNumber":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))

                                      Case [F:ID]CRY
                                        When "ZA"
                                            Local Char MID(50)
                                             MID=mid$(WRES,4,9)
                                      Endcase


                                      [F:SKMC]ALTNUM=MID
                                      [F:ID]TEL = MID
                          When "MobileNumber":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))

                                      Case [F:ID]CRY
                                        When "ZA"
                                            Local Char MID(50)
                                             MID=mid$(WRES,4,9)
                                       Endcase

                                      [F:SKMC]MOB= MID
                                      [F:ID]MOB =MID


                          When "DateOfBirth":
                                     WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-11))
                                   # ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)

                                    Local Char RIGHT(50)
                                    Local Char LEFT(50)
                                    Local Char MID(50)

                                    RIGHT=right$(WRES,9)
                                    LEFT=left$(WRES,4)
                                    MID=mid$(WRES,6,2)

                                   [F:SKMC]DOB=gdat$(val(RIGHT),val(MID),val(LEFT))
                                   [F:ID]DATBRN =gdat$(val(RIGHT),val(MID),val(LEFT))


                          When "Ethnicity":
                                     WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                     [F:SKMC]RACE= WRES

            #              When "Gender":
            #                          WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
            #                          ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)
            #                          [F:SKMC]SEX=WRES
            #
                          When "Surname":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]NAM=WRES
                                      [F:ID]NAM =WRES
            #
                          When "CandidateFullName":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]SRN=WRES
                                      [F:ID]SRN  =WRES
            #
                          When "IDNumber":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]IDNUMBER=WRES
            #
                          When "CandidateEmail":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]CANEMAL=WRES
                                      [F:ID]EML = WRES
            ##
            #              When "JobTitle":
            #                          WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
            #                          ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)
            #                          [F:SKMC]POSITION=WRES
            #
                          When "SalaryCurrency":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]CURRENCY=WRES
            #

            #
            #              When "PlacementTitle":
            #                         WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
            #                         ASTATUS = fmet this.ASETERROR("",WRES,[V]CST_AINFO)
            #                         [F:SKMC]POSITION=WRES
            #
                          When "StartDate":
                                     WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))

                                    Local Char RIGHT(50)
                                    Local Char LEFT(50)
                                    Local Char MID(50)

                                    RIGHT=right$(WRES,9)
                                    LEFT=left$(WRES,4)
                                    MID=mid$(WRES,6,2)

                                   [F:SKMC]STARTDATE=gdat$(val(RIGHT),val(MID),val(LEFT))

                      Endcase
                    Endif

                    If NODES(ZII).TYP=4
                      Case NODES(ZII).PRO
                          When "CandidateId":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START+1,NODES(ZII).LENGTH-2))
                                      [F:SKMC]CANDIDATEID=WRES

                          When "JobId":
                                     WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START,NODES(ZII).LENGTH))
                                     [F:SKMC]JOBIDS=WRES

                          When "Salary":
                                      WRES=num$(mid$(NODES(ZII).CLB.CLB,NODES(ZII).START,NODES(ZII).LENGTH))
                                      [F:SKMC]SALARY=val(WRES)
                      Endcase
                    Endif
                 Next

                Write [F:SKMC]

                If clalev ([F:SKM]) = 0 : Local File SKLMAP [SKM] Endif
                Filter  [F:SKM] Where REFERENCENUM = REFERENCENUMEMP

                Read [F:SKM]SKM0 Last
                [F:SKM]JOBSTAT = 5
              #  this.JOBSTAT=5
                Rewrite [F:SKM]

#                #CREATE EMPLOYEE RECORD
#                 Local Char COMPTEUR(100)
#                 If clalev([F:TCA])=0 : Local File TABCOUAFF[TCA] : Endif
#
#                 Read [TCA]TCA0 = 9
#                 COMPTEUR = [F:TCA]CODNUM(2)
#                 If COMPTEUR=""
#                  GMESSAGE = mess(39,701,1) : # Compteur contrat non dĂ©fini
#                  GOK = 0 : Return
#                 Endif
#
#
#               Local Char NEWREFNUM(30)
#               Local Integer OK
#               Call NUMERO(COMPTEUR,"LITSHI",date$,"",NEWREFNUM,OK) From SUBANM


                 [F:ID]REFNUM = REFERENCENUMEMP
                 [F:ID]FLGNEWSAL = 2
                 [F:ID]CIV = 1
                 [F:ID]FLGPAY =2
#                [F:ID]NAM  = [F:SKMC]NAM
#                [F:ID]SRN  = [F:SKMC]SRN
#                [F:ID]TEL  = [F:SKMC]ALTNUM
#                [F:ID]MOB   = [F:SKMC]MOB
#                [F:ID]EML   =  [F:SKMC]CANEMAL
#                [F:ID]WETRFCY  = [F:SKM]BUSSUNIT

                Write[F:ID]
                Gosub MAJZONE
                Commit
            Endif
   Endif


Return



$MAJZONE


If clalev ([F:CTR]) = 0 : Local File EMPLOCTR [CTR] Endif
If clalev ([F:ECT]) = 0 : Local File EMPCTR [ECT] Endif

 [F:CTR]CTRNUM=REFERENCENUMEMP
 [F:CTR]REFNUM=REFERENCENUMEMP
 [F:CTR]CTRDAT=[F:SKMC]STARTDATE
 [F:CTR]POT=[F:SKM]POSITION
 [F:CTR]ETRFCY=[F:SKM]BUSSUNIT
 [F:CTR]MTH =[F:SKMC]SALARY

 [F:CTR]NUMLIG    = 1
 [F:CTR]WRKFLGADD = 2
 [F:CTR]TWDPAY    = 1
 [F:CTR]DATANC= [F:CTR]CTRDAT
 [F:CTR]DATCPY= [F:CTR]CTRDAT
 [F:CTR]DATFCY= [F:CTR]CTRDAT


 Gosub CREUSR

 Write  [F:CTR]
 If fstat
 # GOK = 0 : Call FSTA(TBABREV(I)) From GLOCK : Break
 Endif

 [F:ECT]REFNUM = [F:CTR]REFNUM
 [F:ECT]CTRNUM = [F:CTR]CTRNUM
 [F:ECT]NBRCTR = 1
 [F:ECT]CREUSR = [V]GUSER
 [F:ECT]CREDAT = date$
 [F:ECT]CRETIM = time
 Write [ECT]
 If fstat
  #GOK = 0 : Call FSTA("ECT") From GLOCK : Break
 Endif



Return

$CREUSR
If dim([F:CTR]CREDAT)>0 : [F:CTR]CREDAT = date$     : Endif
If dim([F:CTR]CRETIM)>0 : [F:CTR]CRETIM = time      : Endif
If dim([F:CTR]CREUSR)>0 : [F:CTR]CREUSR = GUSER     : Endif

Return

