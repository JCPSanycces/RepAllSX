#<AdxTL>@(#)%I%
#Traitement généré d'exécution de l'affichage du résultat d'un ciblage marketing
Subprog FILLQTX
If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif
If !clalev([F:BPR]) : Local file BPARTNER [BPR] : Endif
Link [BPR] With
& [QTP]QTP2 = [F:BPR]BPRNUM
& As [LNK]
& Order By Key KBID = [F:AIN]CNTLNA Asc; [F:BPR]BPRNUM Asc
Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Char SZMGCLASK
Local Integer STOPLOOP
Local Integer ICUTCOUNT
Local Integer COK
Local Integer CCOUNT
IPERF = 0
INTR = 0
IPBL = 0
STOPLOOP = 0
ICUTCOUNT = 0
CCOUNT = 0
COK = 0
$SNAPLOOP
If STOPLOOP = 1
STOPLOOP = 2
Filter [LNK] Where [F:QTP]QURNUM = "36"
& and [F:QTP]PPLORD = 100
& and [F:AIN]CNTLNA = UMGCLASF
& and [F:QTP]KEYTGR > SZMGCLASK
Elsif STOPLOOP = 2
STOPLOOP = 0
Filter [LNK] Where [F:QTP]QURNUM = "36"
& and [F:QTP]PPLORD = 100
& and [F:AIN]CNTLNA > UMGCLASF
Else
Filter [LNK] Where [F:QTP]QURNUM = "36"
& and [F:QTP]PPLORD = 100
Endif
ICUTCOUNT = 0
For [LNK] KBID
If IPERF = 0
Call DEBTRANS From GLOCK
Trbegin [QTX]
INTR = 1
Endif
[F:QTX]QURNUM = "36"
[F:QTX]MGCCOLSRTK = [F:BPR]BPRNUM
[F:QTX]MGCTIT1 = ""
[F:QTX]MGCTIT2 = ""
[F:QTX]MGCTIT3 = ""
[F:QTX]MGCTIT4 = ""
[F:QTX]MGCTIT5 = ""
[F:QTX]MGCTIT6 = ""
[F:QTX]MGCTIT7 = ""
[F:QTX]MGCTIT8 = ""
[F:QTX]MGCTIT9 = ""
[F:QTX]MGCTIT10 = ""
[F:QTX]MGCTIT11 = ""
[F:QTX]MGCTIT12 = ""
[F:QTX]MGCTIT13 = ""
[F:QTX]MGCTIT14 = ""
[F:QTX]MGCTIT15 = ""
Write [QTX]
If fstat
Rollback
GERR = 1
IPBL = 1
INTR = 0
STOPLOOP = 0
Break
Else
If IPERF >= 500
Commit
IPERF = 0
INTR = 0
Else
IPERF += 1
Endif
ICUTCOUNT += 1
If ICUTCOUNT >= 5000
SZMGCLASK = [F:QTP]KEYTGR
STOPLOOP = 1
Break
Endif
Endif
CCOUNT += 1
Call AFF_BOITE (mess(392, 196, 2), CCOUNT, COK) From GESECRAN
Next
Filter [LNK]
If STOPLOOP
Goto SNAPLOOP
Endif
If INTR
If !IPBL
Commit
Endif
Endif
End
#Fin du traitement généré
