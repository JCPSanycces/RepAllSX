#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITC1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone STDDET
mkstat = 0
zoncou = "STDDET"
indice = 0
If varinit([M]STDDET,indice)=0
 [M]STDDET = "152"
Endif
If varmode([M]STDDET,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "STDDET" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ACTDET
mkstat = 0
zoncou = "ACTDET"
indice = 0
If varinit([M]ACTDET,indice)=0
 [M]ACTDET = "152"
Endif
If varmode([M]ACTDET,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ACTDET" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BUDDET
mkstat = 0
zoncou = "BUDDET"
indice = 0
If varinit([M]BUDDET,indice)=0
 [M]BUDDET = "152"
Endif
If varmode([M]BUDDET,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BUDDET" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SIMDET
mkstat = 0
zoncou = "SIMDET"
indice = 0
If varinit([M]SIMDET,indice)=0
 [M]SIMDET = "152"
Endif
If varmode([M]SIMDET,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SIMDET" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITC1"
Return

