#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque FGR0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone GRP
mkstat = 0
zoncou = "GRP"
indice = 0
If varmode([M]GRP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRP" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]GRP,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 616 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "AGF"
  Local Char    VALEUR(250)
  VALEUR = [M]GRP
  Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]GRP = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 616 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_GRP([M]GRP) From SUBAGF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "GRP" : GZNUM = 616 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SHO
mkstat = 0
zoncou = "SHO"
indice = 0
If varmode([M]SHO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SHO" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone FLGCPY
mkstat = 0
zoncou = "FLGCPY"
indice = 0
IMPENT = [M]FLGCPY
If varinit([M]FLGCPY,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGCPY,indice)=0
 [M]FLGCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGCPY(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGCPY(IMPENT) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGCPY" : GZNUM = 8294 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGCPY = IMPENT

## Zone FLGLEG
mkstat = 0
zoncou = "FLGLEG"
indice = 0
IMPENT = [M]FLGLEG
If varinit([M]FLGLEG,indice)=0
 IMPENT = 1
Endif
[M]FLGLEG = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "FGR0"
Return

