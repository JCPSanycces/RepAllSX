#-------------------------------------------------------------------------------
$TRACE_FERME_BIEN
  LCRCHAR  = string$(LCRLINE, '*') : Call ECR_TRACE(LCRCHAR,0) From GESECRAN
Return

#-------------------------------------------------------------------------------
$TRACE_TABLEAU_BIEN
  LCRCHAR  = "*"+left$([F:FAS]AASREF+string$(LCRCOL1, ' '), LCRCOL1)
  LCRCHAR += "*"+left$(mess(LLSTPLN(N_E,LIN_PLAN),GML_NPLAN,1)+string$(LCRCOL2, ' '), LCRCOL2)
  LCRCHAR += "*"+left$(format$("D:" + GFMDAT4, [F:DEPS]FIYENDDAT)+string$(LCRCOL3, ' '), LCRCOL3)
  If [F:DEPS]PERENDDAT <> [0/0/0] Then
    LCRCHAR += "*"+left$(format$("D:" + GFMDAT4, [F:DEPS]PERENDDAT)+string$(LCRCOL4, ' '), LCRCOL4)
  Else
    LCRCHAR += "*"+string$(LCRCOL4, ' ')
  Endif
  LCRCHAR += "*"+func GLOBIENS.AX3_RIGHT(string$(LCRCOL5, ' ')+num$([F:DEPS]DPRCUM), LCRCOL5)
  LCRCHAR += "*"+func GLOBIENS.AX3_RIGHT(string$(LCRCOL6, ' ')+num$([F:DEPS]ALWCUM), LCRCOL6)
  LCRCHAR += "*"+func GLOBIENS.AX3_RIGHT(string$(LCRCOL7, ' ')+num$([F:DEPS]PERCLOCUM), LCRCOL7)
  LCRCHAR += "*"+func GLOBIENS.AX3_RIGHT(string$(LCRCOL8, ' ')+num$([F:DEPS]PSTDPE+[F:DEPS]PSTEXC), LCRCOL8)
  LCRCHAR += "*"
  Call ECR_TRACE(LCRCHAR,0) From GESECRAN
Return

#-------------------------------------------------------------------------------
$TRACE_BIEN_FINI
  LCRCHAR  = "*"+left$([F:FAS]AASREF+string$(LCRCOL1, ' '), LCRCOL1)
  LCRCHAR += "*"+left$(mess(LLSTPLN(N_E,LIN_PLAN),GML_NPLAN,1)+string$(LCRCOL2, ' '), LCRCOL2)
  LCRCHAR += "*"+string$(LCRCOL3, ' ')
  LCRCHAR += "*"+string$(LCRCOL4, ' ')
  LCRCHAR += "*"+string$(LCRCOL5, ' ')
  LCRCHAR += "*"+string$(LCRCOL6, ' ')
  LCRCHAR += "*"+string$(LCRCOL7, ' ')
  LCRCHAR += "*"+left$(mess(94,GML_MSGCAL,1)+string$(LCRCOL8, ' '), LCRCOL8)
  LCRCHAR += "*"
  Call ECR_TRACE(LCRCHAR,0) From GESECRAN
Return

########################################
Subprog TRACE_CNX (PSOCIETE, PTBCNX, RERROR)
# Envoi les info contextes.
# RERROR=-1 en cas d'échec, RERROR=0 sinon
Value    Char    PSOCIETE
Value    Integer PTBCNX(1..,0..)
Variable Integer RERROR

# Déclaration des colonnes du tableau de compte rendu
Local    Integer LCRCOL1  : LCRCOL1  = 18 : # Contextes
Local    Integer LCRCOL2  : LCRCOL2  = 10 : # Exercice
Local    Integer LCRCOL3  : LCRCOL3  = 22 : # Type clôture
Local    Integer LCRCOL4  : LCRCOL4  = 10 : # Exercice début et fin
Local    Integer LCRCOL5  : LCRCOL5  = 10 : # Période début et fin
Local    Integer LCRLINE  : LCRLINE  = LCRCOL1+LCRCOL2+LCRCOL3+LCRCOL4+LCRCOL5+6
Local    Char    LCRCHAR(LCRLINE)         : # Chaine de compte rendu

Local    Integer N_I

  #------------------------------------
  If clalev([F:CNX])=0  : Local File CONTEXT    [CNX]  : Endif        : # Contextes
  If clalev([F:FIS])=0  : Local File FISCYEAR   [FIS]  : Endif        : # Exercice (courant)
  If clalev([F:FISS])=0 : Local File FISCYEAR   [FISS] : Endif        : # Exercice (suivant)
  #------------------------------------
  LCRCHAR = string$(LCRLINE, '*') : Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  LCRCHAR  = "*"+string$(LCRCOL1, ' ')+"*"+string$(LCRCOL2, ' ')+"*"+string$(LCRCOL3, ' ')+"*"
  LCRCHAR += left$(mess(63,GML_MSGCAL,1)+string$(LCRCOL4, ' '), LCRCOL4)+"*"
  LCRCHAR += left$(mess(64,GML_MSGCAL,1)+string$(LCRCOL5, ' '), LCRCOL5)+"*"
  Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  LCRCHAR  = "*"+left$(mess(66,GML_MSGCAL,1)+string$(LCRCOL1, ' '), LCRCOL1)+"*"
  LCRCHAR += left$(mess(63,GML_MSGCAL,1)+string$(LCRCOL2, ' '), LCRCOL2)+"*"
  LCRCHAR += left$(mess(85,GML_MSGCAL,1)+string$(LCRCOL3, ' '), LCRCOL3)+"*"
  LCRCHAR += left$(mess(68,GML_MSGCAL,1)+string$(LCRCOL4, ' '), LCRCOL4)+"*"
  LCRCHAR += left$(mess(68,GML_MSGCAL,1)+string$(LCRCOL5, ' '), LCRCOL5)+"*"
  Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  LCRCHAR  = "*"+string$(LCRCOL1, ' ')+"*"+string$(LCRCOL2, ' ')+"*"+string$(LCRCOL3, ' ')+"*"
  LCRCHAR += left$(mess(69,GML_MSGCAL,1)+string$(LCRCOL4, ' '), LCRCOL4)+"*"
  LCRCHAR += left$(mess(69,GML_MSGCAL,1)+string$(LCRCOL5, ' '), LCRCOL5)+"*"
  Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  LCRCHAR = string$(LCRLINE, '*') : Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  #------------------------------------
  For [CNX]CNX0 Where CPY=PSOCIETE
    If [F:CNX]NBPLC > 0 Then
      If PTBCNX([F:CNX]CNX, GTBCNXTCLC) <> GVML_TCNOCLO Then
        #------------------------------------
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
        Read [FIS]FIY1 Last
        Filter [FIS]
        Filter [FISS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV
        Read [FISS]FIY1 Last
        Filter [FISS]
        #------------------------------------
        LCRCHAR  = "*"
        LCRCHAR += left$(mess([F:CNX]CNX,GML_NCONTEXT,1)+string$(LCRCOL1, ' '), LCRCOL1)+"*"
        LCRCHAR += left$(mess(PTBCNX([F:CNX]CNX, GTBCNXEXE),GML_TYPEXERC,1)+string$(LCRCOL2, ' '), LCRCOL2)+"*" : # REVENIR
        LCRCHAR += left$(mess(PTBCNX([F:CNX]CNX, GTBCNXTCLC),GML_TYPDECL0,1)+string$(LCRCOL3, ' '), LCRCOL3)+"*"
        LCRCHAR += left$(format$("D:" + GFMDAT4, [F:FIS]DATSTRFIY)+string$(LCRCOL4, ' '), LCRCOL4)+"*"
        LCRCHAR += left$(format$("D:" + GFMDAT4, [F:FIS]DATSTRPER([F:FIS]INDCURPER-1))+string$(LCRCOL5, ' '), LCRCOL5)+"*"
        Call ECR_TRACE(LCRCHAR,0) From GESECRAN

        LCRCHAR  = "*"
        LCRCHAR += string$(LCRCOL1, ' ')+"*"
        LCRCHAR += string$(LCRCOL2, ' ')+"*"
        LCRCHAR += string$(LCRCOL3, ' ')+"*"
        LCRCHAR += left$(format$("D:" + GFMDAT4, [F:FIS]DATENDFIY)+string$(LCRCOL4, ' '), LCRCOL4)+"*"
        LCRCHAR += left$(format$("D:" + GFMDAT4, [F:FIS]DATENDPER([F:FIS]INDCURPER-1))+string$(LCRCOL5, ' '), LCRCOL5)+"*"
        Call ECR_TRACE(LCRCHAR,0) From GESECRAN
        #------------------------------------
      Endif
    Endif
    #------------------------------------
    # Suite de la boucle
  Next
  #------------------------------------
  LCRCHAR = string$(LCRLINE, '*') : Call ECR_TRACE(LCRCHAR,0) From GESECRAN
  #------------------------------------
End

########################################
Subprog MAJ_CNX (PSOCIETE, PTBCNX, RERROR)
# Envoi les info contextes.
# RERROR=-1 en cas d'échec, RERROR=0 sinon
Value    Char    PSOCIETE
Value    Integer PTBCNX(1..,0..)
Variable Integer RERROR

Local    Integer N_I
Local    Char    SREQUETE(250)
Local    Integer LLSTPLN(0..G301NBPLNFC, 0..LDIMLSTPLN)               : # Liste des plans gérés sur le contexte
Local    Char    LLSTCPLN(15)(0..G301NBPLNFC, 0..LDIMLSTCPLN)         : # Liste des plans gérés sur le contexte (partie char)
Local    Integer NB_JOURS
Local    Integer NB_MOIS
Local    Integer NB_WEEK
Local    Decimal NB_YEAR
Local    Integer INDIC_SUIVANT2

  #------------------------------------
  If clalev([F:CNX])=0  : Local File CONTEXT    [CNX]  : Endif        : # Contextes
  If clalev([F:CNXA])=0 : Local File CONTEXT    [CNXA] : Endif        : # Contextes
  If clalev([F:FIS])=0  : Local File FISCYEAR   [FIS]  : Endif        : # Exercice
  #------------------------------------
  #--FQ79662 récupération du type de comptabilisation par défaut
  Local Char DEFTYPPST(15)
  Call PARAM(PSOCIETE, "DEFPSTTYP", DEFTYPPST) From ADOVAL
  #------------------------------------
  For [CNX]CNX0 Where CPY=PSOCIETE
    #------------------------------------
    If [F:CNX]NBPLC > 0 and PTBCNX([F:CNX]CNX, GTBCNXTCLC) <> GVML_TCNOCLO Then
      Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=PTBCNX([F:CNX]CNX, GTBCNXEXE)
      Read [FIS]FIY1 First
      Filter [FIS]

      # Plan de production : report dans la période qu'on clôture du prévu dans le réalisé si le réalisé vaut 0
      If [F:CNX]FLGCNXUO = G_OUI
          Gosub REPORT_PREVU_REALISE
          If RERROR = -1
            Break
          Endif
      Endif

      #------------------------------------
      If PTBCNX([F:CNX]CNX, GTBCNXTCLC) = GVML_TCCLOPE Then
        #------------------------------------
        # CLOTURE PERIODE
        #------------------------------------
        # Ancienne période courante
        [F:FIS]STAPER([F:FIS]INDCURPER-1) = GVML_SPCLOSE
        [F:FIS]INDCURPER                 += 1
        # Nouvelle période courante
        [F:FIS]STAPER([F:FIS]INDCURPER-1) = GVML_SPCOURA

        # Si rien n'était précisé (période fermée), on met par défaut le type de comptabilisation de la période qu'on clôture
        If [F:FIS]TYPPST([F:FIS]INDCURPER-1) = 0
          [F:FIS]TYPPST([F:FIS]INDCURPER-1) = [F:FIS]TYPPST([F:FIS]INDCURPER-2)
          Endif
        Rewrite [FIS]
        If fstat Then
          Call ECR_TRACE ("MAJ_CNX 1"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
          RERROR = -1
          Break
        Endif
      Else
        #------------------------------------
        # CLOTURE EXERCICE
        #------------------------------------
        # L'exercice courant prend le status CLOS
        [F:FIS]STAFIY                     = GVML_TEPREC
        [F:FIS]STAPER([F:FIS]INDCURPER-1) = GVML_SPCLOSE
        # L'exercice clos n'a plus de période courante
        [F:FIS]INDCURPER                  = 0
        # FQ67615
        WSV_LVATYP = [F:FIS]LVATYP
        WSV_LVALIM = [F:FIS]LVALIM

        Rewrite [FIS]
        If fstat Then
          Call ECR_TRACE ("MAJ_CNX 2"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
          RERROR = -1
          Break
        Endif
        #------------------------------------
        # L'exercice suivant prend le status COURANT
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV
        Read [FIS]FIY1 First
        Filter [FIS]
        [F:FIS]STAFIY                     = GVML_TECOURA
        [F:FIS]INDCURPER                  = 1
        [F:FIS]STAPER([F:FIS]INDCURPER-1) = GVML_SPCOURA

        #FQ79662 Si rien n'était précisé (période fermée), on met par défaut "comptabilisation provisoire"
        #FQ79662 If [F:FIS]TYPPST([F:FIS]INDCURPER-1) = 0
        #FQ79662   [F:FIS]TYPPST([F:FIS]INDCURPER-1) = GVML_TPSTPRO
        #FQ79662 Endif

        #--FQ79662
        # Désormais on se base sur la valeur du paramètre DEFPSTTYP (type de comptabilisation par défaut)
        # si le paramètre n'est pas renseigné et que le type de comptabilisation n'est pas déjà "Réel" :
        # on met "Simulation"
        If  ( [F:FIS]TYPPST([F:FIS]INDCURPER-1) <> GVML_TPSTDEF )
          If DEFTYPPST <> ""
            [F:FIS]TYPPST([F:FIS]INDCURPER-1) = val(DEFTYPPST)
          Else
            [F:FIS]TYPPST([F:FIS]INDCURPER-1) = GVML_TPSTPRO
          Endif
        Endif #--/FQ79662

        # FQ67615
        If [F:FIS]LVATYP <= GVML_GLVAAUC
          [F:FIS]LVATYP = WSV_LVATYP
          If [F:FIS]LVATYP = 0
            [F:FIS]LVATYP = GVML_GLVAAUC
          Endif
          [F:FIS]LVALIM = WSV_LVALIM
        Endif
        WSV_LVATYP = [F:FIS]LVATYP
        WSV_LVALIM = [F:FIS]LVALIM

        Rewrite [FIS]
        If fstat Then
          Call ECR_TRACE ("MAJ_CNX 3"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
          RERROR = -1
          Break
        Endif
        #------------------------------------
        # L'exercice SUIVANT2 prend le status SUIVANT s'il existe
        INDIC_SUIVANT2 = G_NON
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV2
        Read [FIS]FIY1 First
        Filter [FIS]
        If !fstat Then
          INDIC_SUIVANT2 = G_OUI
          [F:FIS]STAFIY  = GVML_TESUIV
          # FQ67615
          If [F:FIS]LVATYP <= GVML_GLVAAUC
            [F:FIS]LVATYP = WSV_LVATYP
            If [F:FIS]LVATYP = 0
              [F:FIS]LVATYP = GVML_GLVAAUC
            Endif
            [F:FIS]LVALIM = WSV_LVALIM
          Endif
          WSV_LVATYP = [F:FIS]LVATYP
          WSV_LVALIM = [F:FIS]LVALIM

          Rewrite [FIS]
          If fstat Then
            Call ECR_TRACE ("MAJ_CNX 4"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
            RERROR = -1
            Break
          Endif
        Endif
        #------------------------------------
        # Recherche de l'exercice après l'ancien exercice suivant ou suivant2 pour créer le nouveau SUIVANT
        # ou SUIVANT2 => le premier pour lequel STAFIY=0
        Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=0
        Read [FIS]FIY1 First
        Filter [FIS]
        #------------------------------------
        If fstat Then
          # Aucun exercice n'est défini après l'exercice courant (le nouveau) :
          # faut le créer à partir de l'ancien suivant ou suivant2 selon le même découpage
          If INDIC_SUIVANT2 = G_NON Then
            Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA
          Else
            Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV
          Endif
          #------------------------------------
          Read [FIS]FIY1 Last
          Filter [FIS]
          # Le début du nouvel exercice c'est le lendemain de la fin de l'ancien
          [F:FIS]DATSTRFIY = [F:FIS]DATENDFIY+1
          # La fin du nouvel exercice c'est la même fin que l'ancien plus 1 an
          [F:FIS]DATENDFIY = gdat$(  day([F:FIS]DATENDFIY),
&                                    month([F:FIS]DATENDFIY),
&                                    year([F:FIS]DATENDFIY) +1
&                                 )
          #------------------------------------
          If INDIC_SUIVANT2 = G_NON Then
             [F:FIS]STAFIY    = GVML_TESUIV
          Else
             [F:FIS]STAFIY    = GVML_TESUIV2
          Endif
          #------------------------------------
          [F:FIS]INDCURPER = 1
          [F:FIS]STAPER(0) = GVML_SPFERME : # Période non ouverte
          [F:FIS]TYPPST(0) = 0            : # Pas de type de comptabilisation
          # La début première période c'est forcément le début d'exercice
          [F:FIS]DATSTRPER([F:FIS]INDCURPER-1) = [F:FIS]DATSTRFIY
          #------------------------------------
          For N_I = 2 To [F:FIS]NBRPER
            [F:FIS]STAPER(N_I-1) = GVML_SPFERME : # Période non ouverte
            [F:FIS]TYPPST(N_I-1) = 0            : # Pas de type de comptabilisation
            #------------------------------------
            # On attaque à la deuxième période
            # La date de début de période COURANTE, c'est la même date que l'exercice passé plus 1 an
            [F:FIS]DATSTRPER(N_I-1) = gdat$(  day([F:FIS]DATSTRPER(N_I-1)),
&                                             month([F:FIS]DATSTRPER(N_I-1)),
&                                             year([F:FIS]DATSTRPER(N_I-1)) +1
&                                          )
            #------------------------------------
            # La date de fin de période PRECEDENTE, c'est la veille de la date de début de période COURANTE
            # qu'on vient de calculer
            [F:FIS]DATENDPER(N_I-2) = gdat$(  day([F:FIS]DATSTRPER(N_I-1)) -1,
&                                             month([F:FIS]DATSTRPER(N_I-1)),
&                                             year([F:FIS]DATSTRPER(N_I-1))
&                                          )
            #------------------------------------
            # Suite de la boucle
          Next N_I
          #------------------------------------
          # La fin de la dernière période c'est forcément la fin d'exercice
          [F:FIS]DATENDPER([F:FIS]NBRPER-1)    = [F:FIS]DATENDFIY
          #------------------------------------
          For N_I = 1 To [F:FIS]NBRPER
            Call CALCUL_NB_D_M_W_Y ([F:FIS]DATSTRPER(N_I-1), [F:FIS]DATENDPER(N_I-1),
&                                   NB_JOURS, NB_MOIS, NB_WEEK, NB_YEAR) From GLOBIENS
            # On recalcule le poids des jour, mois et semaines des périodes en fonction des date
            # du nouvel exercice. Les poids ne sont affectés QUE s'ils n'étaient pas à zéro dans
            # l'exercice utilisé comme modèle pour la création (l'ancien exercice SUIVANT)
            If [F:FIS]NBRMONPER(N_I-1) <> 0 Then
              [F:FIS]NBRMONPER(N_I-1) = NB_MOIS
            Endif
            If [F:FIS]NBRDAYPER(N_I-1) <> 0 Then
              [F:FIS]NBRDAYPER(N_I-1) = NB_JOURS
            Endif
            If [F:FIS]NBRWEKPER(N_I-1) <> 0 Then
              [F:FIS]NBRWEKPER(N_I-1) = NB_WEEK
            Endif
          Next N_I
          #------------------------------------
          # Remise à 0 du flag "Exercice de mise en oeuvre de la norme"
          If [F:CNX]FIYITSSTD=G_OUI Then
            [F:CNX]FIYITSSTD=G_NON
            Rewrite [F:CNX]
            If fstat Then
              Call ECR_TRACE ("MAJ_CNX 5"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
              RERROR = -1
              Break
            Endif
          Endif
          #------------------------------------
          # Report du nouveau découpage dans les plans de production
          If [F:CNX]FLGCNXUO = G_OUI
            Gosub MAJ_PPL
            If RERROR = -1
              Break
            Endif
          Endif

          # FQ67615
          If [F:FIS]LVATYP <= GVML_GLVAAUC
            [F:FIS]LVATYP = WSV_LVATYP
            If [F:FIS]LVATYP = 0
              [F:FIS]LVATYP = GVML_GLVAAUC
            Endif
            [F:FIS]LVALIM = WSV_LVALIM
          Endif
          WSV_LVATYP = [F:FIS]LVATYP
          WSV_LVALIM = [F:FIS]LVALIM

          #------------------------------------
          Write [FIS]
          If fstat Then
            Call ECR_TRACE ("MAJ_CNX 6"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
            RERROR = -1
            Break
          Endif
        Else
          # Il y a un exercice défini au-delà du suivant2, on ne le redécoupe pas mais on met à jour son statut
          [F:FIS]STAFIY    = GVML_TESUIV2

          # FQ67615
          If [F:FIS]LVATYP <= GVML_GLVAAUC
            [F:FIS]LVATYP = WSV_LVATYP
            If [F:FIS]LVATYP = 0
              [F:FIS]LVATYP = GVML_GLVAAUC
            Endif
            [F:FIS]LVALIM = WSV_LVALIM
          Endif
          WSV_LVATYP = [F:FIS]LVATYP
          WSV_LVALIM = [F:FIS]LVALIM

          #------------------------------------
          Rewrite [FIS] Curr
          If fstat Then
            Call ECR_TRACE ("MAJ_CNX 7"-[F:FIS]CPY-num$([F:FIS]CNX)-[F:FIS]DATSTRFIY-":"-num$(fstat),1) From GESECRAN
            RERROR = -1
            Break
          Endif
          #------------------------------------
        Endif
        #------------------------------------
      Endif
      #------------------------------------
    Endif
    #------------------------------------
  Next
  #------------------------------------
End

########################################
# Mise à jour des Plans de Production
# de la société et du contexte
$MAJ_PPL

  Local Integer N_I
  Local Decimal LRSDQTY, LEXTQTY

  If !clalev([F:PLH])  : Local File PROPLNH [PLH] : Endif : # Plans de production - en-tête
  If !clalev([F:PLP])  : Local File PROPLN  [PLP] : Endif : # Plans de production - ligne

  #For [PLH] Where CPY=[F:CNX]CPY : # FQ87713
  # On ne traite que les plans de production sans date de fin ou ayant une date de fin supérieure au début
  # du nouvel exercice créé dans MAJ_CNX
  For [PLH] Where (CPY=[F:CNX]CPY) and ((PPLENDDAT0 =  [0/0/0])
&                                   or ((PPLENDDAT0 <> [0/0/0]) and PPLENDDAT0 >= [F:FIS]DATSTRFIY))
    N_I = 0

    # Lecture de la dernière période de l'exercice précédent du plan pour avoir le résiduel et le prévu
    Read [PLP]PPL0=[F:PLH]PROPLN;[F:FIS]DATSTRPER(0)-1;[F:FIS]DATSTRPER(0)-1
    If fstat
      Call ECR_TRACE ("MAJ_PPL 1"-[F:PLH]PROPLN-format$("DD2",[F:FIS]DATSTRPER(0)-1)-format$("DD2",[F:FIS]DATSTRPER(0)-1)-":"-num$(fstat),1) From GESECRAN
      RERROR=-1
      Break
    Endif

    LRSDQTY = [F:PLP]RSDQTY
    LEXTQTY = [F:PLP]EXTQTY

    # Découpage de l'exercice du plan de production à l'image de l'exercice précédent
    #For [PLP]PPL0 Where PROPLN=[F:PLH]PROPLN and FIYENDDAT=[F:FIS]DATSTRPER(0)-1
    For [PLP]PPL0 Where PROPLN=[F:PLH]PROPLN and FIYENDDAT=[F:FIS]DATSTRPER(0)-1 With Stability : # FQ87713
      If ([F:PLH]PPLENDDAT0 <> [0/0/0] and [F:PLH]PPLENDDAT0 < [F:FIS]DATSTRPER(N_I))
        # La date de fin du plan de production est atteinte, on ne crée pas d'enregistrement au-delà : # FQ87713
        Break
      Endif

      [F:PLP]PROPLN    = [F:PLH]PROPLN
      [F:PLP]FIYSTRDAT = [F:FIS]DATSTRFIY
      [F:PLP]FIYENDDAT = [F:FIS]DATENDFIY
      [F:PLP]PERSTRDAT = [F:FIS]DATSTRPER(N_I)
      [F:PLP]PERENDDAT = [F:FIS]DATENDPER(N_I)

      [F:PLP]RSDQTY    = LRSDQTY - LEXTQTY : # mise à jour du résiduel
      If [F:PLP]RSDQTY < 0 : [F:PLP]RSDQTY = 0 : Endif

      LRSDQTY          = [F:PLP]RSDQTY
      LEXTQTY          = [F:PLP]EXTQTY

      Write [PLP]
      If fstat
        Call ECR_TRACE ("MAJ_PPL 2"-[F:PLP]PROPLN-format$("DD2",[F:PLP]FIYENDDAT)-format$("DD2",[F:PLP]PERENDDAT)-":"-num$(fstat),1) From GESECRAN
        RERROR=-1
        Break
      Endif

      N_I += 1
    Next
  Next

  If clalev([F:PLH])  : Close File [PLH] : Endif : # Plans de production - en-tête
  If clalev([F:PLP])  : Close File [PLP] : Endif : # Plans de production - ligne
Return

########################################
# Mise à jour des Plans de Production
# de la société et du contexte
$REPORT_PREVU_REALISE
  If !clalev([F:PLH])  : Local File PROPLNH [PLH] : Endif : # Plans de production - en-tête
  If !clalev([F:PLP])  : Local File PROPLN  [PLP] : Endif : # Plans de production - ligne

  For [PLH] Where CPY=[F:CNX]CPY and ( PPLENDDAT0 >= [F:FIS]DATSTRPER([F:FIS]INDCURPER-1) or PPLENDDAT0 = [0/0/0] )
    # Lecture de la période courante de l'exercice du plan
    Read [PLP]PPL0=[F:PLH]PROPLN;[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
    If fstat
      Call ECR_TRACE ("REPORT_PREVU_REALISE 1"-[F:PLH]PROPLN-format$("DD2",[F:FIS]DATENDFIY)-format$("DD2",[F:FIS]DATENDPER([F:FIS]INDCURPER-1))-":"-num$(fstat),1) From GESECRAN
      RERROR=-1
      Break
    Endif

    If [F:PLP]CPLQTY = 0
      # Report du prévu dans le réalisé
      [F:PLP]CPLQTY = [F:PLP]EXTQTY

      Rewrite [F:PLP] Curr
      If fstat
        Call ECR_TRACE ("REPORT_PREVU_REALISE 2"-[F:PLH]PROPLN-format$("DD2",[F:FIS]DATENDFIY)-format$("DD2",[F:FIS]DATENDPER([F:FIS]INDCURPER-1))-":"-num$(fstat),1) From GESECRAN
        RERROR=-1
        Break
      Endif
    Endif
  Next

  If clalev([F:PLH])  : Close File [PLH] : Endif : # Plans de production - en-tête
  If clalev([F:PLP])  : Close File [PLP] : Endif : # Plans de production - ligne
Return

# Gestion de la liste gauche des biens sortis
# dans un exercice antérieur.
#################################################################
# Mise à jour de la zone ISSFIYPRE pour les biens d'une société
#================================================================
Subprog MAJ_ISSFIYPRE(PCPY, RERR)
Value    Char    PCPY
Variable Integer RERR

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif


  Local Char    L_REQUETE(255)
  Local Integer L_IS_BCO_PRE
  Local Integer I_CNX
  Local Date    TRUEISSDAT  : # Date de sortie, soit ISSDAT soit pour un bien "1er bien de la concession" la fin effective de son contrat FQ54343

  Local Date    L_STRFIYCOU(1..G300MAX)
  Local Date    L_ENDFIYCOU(1..G300MAX)
  Local Date    L_STRPERCOU(1..G300MAX)
  Local Date    L_ENDPERCOU(1..G300MAX)
  Local Integer CDRET

  Call GET_CPY_DAT(PCPY,L_STRFIYCOU,L_ENDFIYCOU,L_STRPERCOU,L_ENDPERCOU,CDRET) From GLOBIENS

  L_REQUETE="CPY=PCPY & ISSDAT<>[0/0/0] & ISSFIYPRE<>G_OUI"
  Filter [WFAS] Where evalue(L_REQUETE)
  GOK=1

  For [WFAS]
    # Pour chaque bien : on regarde si la date de sortie est inférieure à la date de début d'exercice de tous les
    # contextes.
    L_IS_BCO_PRE = G_OUI

    # FQ54343 : traitement particulier pour les biens en concession "1er bien de la concession"
    If G_ACTCCN = G_OUI and [F:WFAS]OWNTYP = GVML_TDCONCE and [F:WFAS]CCNETRTYP = GVML_NA1ERBC Then
      # Le bien est "1er bien de la concession"
      # Lecture du contrat de concession pour avoir sa date de fin effective
      Read [F:CCN]CCN0=[F:WFAS]CCNREF
      If fstat
        GOK=0
        RERR=fstat
        Call ECR_TRACE([F:WFAS]AASREF-mess(783,7773,1)-[F:WFAS]CCNREF-num$(fstat),1) From GESECRAN
        Break
      Endif
      If [F:CCN]REAENDCCN<>[0/0/0]
        TRUEISSDAT = [F:CCN]REAENDCCN
      Else
        # Pas de date effective sur le contrat
        TRUEISSDAT = [0/0/0]
      Endif
    Else
      # Le bien n'est pas en concession ou pas "1er bien de la concession"
      [L]TRUEISSDAT = [F:WFAS]ISSDAT
    Endif

    For I_CNX=1 To G300MAX
      #If L_STRFIYCOU(I_CNX)<>[0/0/0] & [F:WFAS]ISSDAT>=L_STRFIYCOU(I_CNX) : # FQ54343
      If L_STRFIYCOU(I_CNX)<>[0/0/0] & ([L]TRUEISSDAT=[0/0/0] or [L]TRUEISSDAT>=L_STRFIYCOU(I_CNX))
        L_IS_BCO_PRE = G_NON
        Break
      Endif
    Next I_CNX

    # Bien sorti dans un exercice antérieur pour tous les contextes, on positionne le flag ISSFIYPRE à G_OUI

    If L_IS_BCO_PRE = G_OUI
     [F:WFAS]ISSFIYPRE = G_OUI
     Rewrite [F:WFAS]
     If fstat
      GOK=0
      RERR=fstat
      Break
     Endif
    Endif
  Next

  Filter [WFAS]
  If !GOK
  Else
  Endif
End

########################################
Funprog GET_CONDITION_DEP ()
#
# Rend la condition sur DEPREC pour les plan gérés du contexte
# Implique que [F:CNX] soit chargé
# Rend "" si aucun plan n'est géré (mais c'est pas bien normal de se retrouver dans ce cas !)
Local    Integer N_I
Local    Char    SREQUETE(250)
  SREQUETE = ""
  For N_I = 0 To [F:CNX]NBPLC-1
    If SREQUETE <> "" Then
      SREQUETE = SREQUETE + '|'
    Endif
    SREQUETE              = SREQUETE + 'DPRPLN='+num$([F:CNX]PLNCAA(N_I))
    #------------------------------------
    # Suite de la boucle
  Next N_I
End SREQUETE

########################################
Subprog ALIM_PLN (RLSTPLN, RLSTCPLN)
Variable Integer RLSTPLN(0..,0..)           : # Liste des plans gérés sur le contexte
Variable Char    RLSTCPLN()(0..,0..)        : # Liste des plans gérés sur le contexte
#
# Alimente les structures LSTPLN et LSTCPLN concernant les plans du contexte
Local    Integer N_I, N_E

  Raz RLSTPLN, RLSTCPLN
  N_E = 0
  For N_I = 0 To [F:CNX]NBPLC-1
    RLSTPLN(N_E,LIN_PLAN) = [F:CNX]PLNCAA(N_I)
    If [F:CNX]FLUTRATXS(N_I) <> "" or [F:CNX]FLUTRAACC(N_I) = G_OUI Then
      RLSTPLN(N_E,LIN_FLUX) = G_OUI
    Else
      RLSTPLN(N_E,LIN_FLUX) = G_NON
    Endif
    If dim(LIN_FLACC)>0 Then
      RLSTPLN(N_E,LIN_FLACC)  = [F:CNX]FLUTRAACC(N_I)
      RLSTCPLN(N_E,LIN_FLTXS) = [F:CNX]FLUTRATXS(N_I)
    Endif
    N_E += 1
    #------------------------------------
    # Suite de la boucle
  Next N_I
End

#-------------------------------------------------------------------------------
# Compteurs mal alimentés (remplacement classe FIYWS [trop longue] par FIYS).
# Fonction d'incrémentation des compteurs
#-------------------------------------------------------------------------------
$INCR_CPT_STAT
  #------------------------------------
  # Test sur la date de début d'amortissement
  #------------------------------------
  # FQ95251 Suppression de la relecture de DEPREC, trop coûteuse en temps. Remplacement par l'indicateur FAS_CLOSED
  ## FQ62087
  #Filter [DEPW] Where AASREF=[F:FAS]AASREF and CNX=[F:CNX]CNX and PERENDDAT=LDATCRT(LDT_FINPCO) and STRDPRDAT<=LDATCRT(LDT_FINPCO)
  #If rowcount([DEPW]) > 0
  # L_NBBCOCLO([F:CNX]CNX)+=1
  #Endif
  #Filter [DEPW]
  If FAS_CLOSED = G_OUI
   L_NBBCOCLO([F:CNX]CNX)+=1
  Endif

  #------------------------------------
  # Test sur la date de sortie
  #------------------------------------
  # FQ62087 : remplacement de DATDEBPER, DATFINPER, DATDEBEX et DATFINEX par le tableau LDATCRT()
  If [F:FAS]ISSDAT<>[0/0/0]
   If PTBCNX(N_I, GTBCNXTCLC) = GVML_TCCLOPE
    If (([F:FAS]ISSDAT >= LDATCRT(LDT_DEBPCO)) & ([F:FAS]ISSDAT <= LDATCRT(LDT_FINPCO)))
     L_NBBCOSOR([F:CNX]CNX)+=1
    Endif
   Else
    If (([F:FAS]ISSDAT >= LDATCRT(LDT_DEBEXO)) & ([F:FAS]ISSDAT <= LDATCRT(LDT_FINEXO)))
      L_NBBCOSOR([F:CNX]CNX)+=1
    Endif
   Endif
  Endif
Return

########################################
Subprog INIT_CNX_ACLOTURER (PSOCIETE, PTBCNX, PTYPCLC)
# Initialise les contextes à clôturer
Value Char PSOCIETE
Variable Integer PTBCNX(1..,0..)
Value Integer PTYPCLC

Local Integer N_I

  Call VIDE_LISTE_CNX_ACLOTURER (PTBCNX, GVML_TCNOCLC)
  If PTYPCLC <> GVML_TCNOCLC Then
    If clalev([F:CNX])  = 0 : Local File CONTEXT     [CNX]  : Endif : # Contextes
    #------------------------------
    For [CNX]CNX0 Where CPY=PSOCIETE
      If [F:CNX]NBPLC > 0 Then
        If GNIVTRACE > 2 Then
          # 14 Contexte à calculer :
          # 15 Type de calcul :
          Call ECR_TRACE(mess(14,GML_MSGCAL,1)-num$([F:CNX]CNX)-mess(15,GML_MSGCAL,1)-num$(PTYPCLC),0) From GESECRAN
        Endif
        #--------------------
        PTBCNX([F:CNX]CNX, GTBCNXTCLC) = PTYPCLC
      Endif
      #--------------------
      # Suite de la boucle
    Next CNX0
  Endif
End

########################################
Subprog VIDE_LISTE_CNX_ACLOTURER (PTBCNX, PCODECNX)
Variable Integer PTBCNX(1..,0..)
Value Integer PCODECNX

Local Integer N_I

  Raz PTBCNX
  For N_I = 1 To GMAXCNXC
    PTBCNX(N_I, GTBCNXTCLC) = PCODECNX          : # Type de calcul
    PTBCNX(N_I, GTBCNXEXE)  = GVML_TECOURA      : # Exercice calculé (courant/suivant)
    PTBCNX(N_I, GTBCNXCLS)  = G_NON             : # Calcul optimisé
    PTBCNX(N_I, GTBCNXEVE)  = G_NON             : # Création des événements exercice non périodique
    PTBCNX(N_I, GTBCNXCSO)  = G_NON             : # Calcul société
    #------------------------------
    # Suite de la boucle
  Next N_I
End

#-------------------------------------------------------------------------------
# Génère les flux liasse et compte pour le bien et le plan courant
#-------------------------------------------------------------------------------
$GENERE_FLUX
  If (!LDEP_FSTAT) and (LLSTPLN(N_E,LIN_FLUX) = G_OUI) and ([F:FAS]ISSFIYPRE <> G_OUI) Then
    If val(mid$([F:FAS]FLGCNXFLX, N_I, 1)) = GVML_FLXNOTG  # FQ66894
      # On gère les flux sur le plan
      # clôture période
      #    - Soit clôture période dans l'exercice
      #    - Soit clôture de la dernière période de l'exercice (dans ce cas c'est clôture exercice)
      If LLSTCPLN(N_E,LIN_FLTXS) <> "" Then
        # Suivi flux par liasse
        Call GENERE_FLUX (LLSTPLN(N_E,LIN_PLAN), GML_TFPLIASS, LLSTCPLN(N_E,LIN_FLTXS), GVML_TXSDEF, LERROR)  From TRTFLUX
        If LERROR < 0 Then
          RERROR = LERROR
          Call GERE_MSG_ERREUR_FLUX(RERROR, LMESSAGE) From TRTFLUX
          Call ECR_TRACE(mess(108,GML_MSGCAL,1)-'A'-num$(LLSTPLN(N_E,LIN_PLAN))-[F:FAS]AASREF-':'-LMESSAGE,1) From GESECRAN : # Erreur réécriture du plan :
          # On ne s'arrête pas dans ce cas d'erreur pour détecter les éventuelles autres
          # erreurs dans la suite des biens
        Endif
      Endif

      If LLSTPLN(N_E,LIN_FLACC) = G_OUI Then
        # Suivi flux par compte
        Call GENERE_FLUX (LLSTPLN(N_E,LIN_PLAN), GML_TFCOMPTE, "", GVML_TXSDEF, LERROR)  From TRTFLUX
        If LERROR < 0 Then
          RERROR = LERROR
          Call GERE_MSG_ERREUR_FLUX(RERROR, LMESSAGE) From TRTFLUX
          Call ECR_TRACE(mess(108,GML_MSGCAL,1)-'B'-num$(LLSTPLN(N_E,LIN_PLAN))-[F:FAS]AASREF-':'-LMESSAGE,1) From GESECRAN : # Erreur réécriture du plan :
          # On ne s'arrête pas dans ce cas d'erreur pour détecter les éventuelles autres
          # erreurs dans la suite des biens
        Endif
      Endif

      # FQ84727 : déplacement ce cette mise à jour car si plusieurs plans d'un même contextes suivent
      #           des flux, seul le premier plan sera traité
      ## On positionne le flag d'optimisation à "flux générés" FQ66894
      #[F:FAS]FLGCNXFLX=func GLOFUNC.SETRNGSTR([F:FAS]FLGCNXFLX, N_I, num$(GVML_FLXGENE))
    Else
      # Mise à jour du flag FLGSTATXS -> passage à "Flux définitif" FQ66894
      Update [F:FLU]
&     Where AASREF=[F:FAS]AASREF and DPRPLN=LLSTPLN(N_E,LIN_PLAN) and FIYSTRDAT=LDATCRT(LDT_DEBEXO) and PERSTRDAT=LDATCRT(LDT_DEBPCO)
&     With FLGSTATXS=GVML_TXSDEF
      If PTBCNX(N_I, GTBCNXTCLC) = GVML_TCCLOEX
        Update [F:FLU]
&       Where AASREF=[F:FAS]AASREF and DPRPLN=LLSTPLN(N_E,LIN_PLAN) and FIYSTRDAT=LDATCRT(LDT_DEBEXO) and PERSTRDAT=[0/0/0]
&       With FLGSTATXS=GVML_TXSDEF
      Endif
    Endif
  Endif
Return

#******************************************************************************
#*              MAJ CODE FORCAGE DES DEPENSES SUBVENTIONNEES                  *
#******************************************************************************
Subprog UPD_DEP_SUBV(PCPY, PAASREF, RERROR)
Value    Char    PCPY
Value    Char    PAASREF
Variable Integer RERROR
If !clalev([F:WFAS]) : Local File FXDASSETS  [WFAS] : Endif
If !clalev([F:LOF])  : Local File LAYOUTFAS  [LOF]  : Endif

Filter [LOF] Where (AASREF=PAASREF & FLGGRA = G_OUI & AMTGRA <> 0)
For [LOF]
  [F:LOF]FLGAMTGRA = G_OUI
  Rewrite [F:LOF]
  If fstat
    GOK=0
    RERROR= -1
    Break
  Endif
Next
Filter [LOF]

End

#******************************************************************************
#*              MAJ MONTANT REINTEGRATION SUBVENTIONS SUR LES BIENS           *
#*** 1-mise à jour du montant de réintégration cumulé                         *
#*** 2-remise à zéro du montant de réintégration exercice                     *
#******************************************************************************
Subprog UPD_CRBGRACUM( PCPY, PAASREF, MDPRCUM, MENDDPE, MEXCDPR, RERROR )
Value    Char        PCPY
Value    Char        PAASREF
Value    Decimal     MDPRCUM
Value    Decimal     MENDDPE
Value    Decimal     MEXCDPR

Variable Integer   RERROR
Local Decimal WCRBGRAAMT
Local Decimal WCRBGRACUM

WCRBGRAAMT =  MENDDPE + MEXCDPR
WCRBGRACUM =  MDPRCUM

[F:FAS]CRBGRAAMT = WCRBGRAAMT    #FQ96817
[F:FAS]CRBGRACUM +=WCRBGRAAMT    #FQ96817


#FQ96817    Update [FAS]
#FQ96817&     Where CPY= PCPY and AASREF = PAASREF
#FQ96817&     With  CRBGRAAMT = WCRBGRAAMT
#FQ96817    If ( fstat )
#FQ96817      RERROR = -1
#FQ96817    Endif

End

#******************************************************************************
#*             REMONTEE DU CUMUL DE REINTEGRATION SUR LES SUBVENTIONS         *
#******************************************************************************
$CALCUL_REINTEGRATION_SUBV
Local  Decimal WFCRBCUM, WGCRBCUM
Local  Decimal WRESCRB
Local  Decimal WTOTCRB, WTOTGRAAMT
Local  Integer LERROR
Local  Integer LCDRET
Local  Char    LCDINT
Local  Char    SINVPLN
Global Char    GREASON
Global Decimal G_GRAAMT
Global Decimal G_MAXGRAAMT
Global Decimal G_INVGRAAMT
Global Decimal G_REAGRAAMT
Global Decimal G_CRBGRAAMT
Global Decimal G_CRBGRACUM

  If clalev([F:GRT])=0    : Local File GRANTS         [GRT]    : Endif
  If clalev([F:GRTS])=0   : Local File GRANTS         [GRTS]   : Endif

#FQ-96817  Filter [GRT] Where (GRASTA=GVML_SUBENC & CPY =[F:CNX]CPY  & INVPLN <> "") Order By INVPLN Asc
#FQ-96817  For [GRT]
#FQ-96817    WTOTGRAAMT +=[F:GRT]GRAAMT
#FQ-96817  Next
#FQ-96817 Filter[GRT]

#FQ-96817  SINVPLN=""

  Filter [GRT] Where (GRASTA=GVML_SUBENC & CPY =[F:CNX]CPY  & INVPLN <> "") Order By INVPLN Asc
  For [GRT] With Stability

      [F:GRTS] = [F:GRT]
      WFCRBCUM=0
      WTOTGRAAMT=0  #FQ-96817
      # calcul du montant de réintégration pour chaque subvention liée au projet d'investissement
      #------------------------------------------------------------------
      Filter[FAS] Where INVPLN = [F:GRT]INVPLN
      For [FAS]
         WFCRBCUM += [F:FAS]CRBGRACUM
         WTOTGRAAMT +=[F:GRT]GRAAMT  #FQ-96817
      Next
      Filter [FAS]
      [F:GRT]CRBGRAAMT=0
      If WTOTGRAAMT <> 0
         WGCRBCUM  =   WFCRBCUM*([F:GRT]GRAAMT/WTOTGRAAMT)
         Call GET_MNT_ARRONDI(WGCRBCUM   ,[F:GRT]CUR,WGCRBCUM   ) From GLOBIENS
         [F:GRT]CRBGRACUM=WGCRBCUM
      Endif
      Rewrite[GRT]
      If fstat <>0
        GOK = 0 : Call FSTA("GRT") From GLOCK : Break
      Endif
      #-------------------------------------------------------------
      # Génération d'un évènement de type "Actualisation de Subvention"
      #------------------------------------------------------------------
      If [F:GRT]CRBGRAAMT <> [F:GRTS]CRBGRAAMT     or
&        [F:GRT]CRBGRACUM <> [F:GRTS]CRBGRACUM
        # FQ96429
        LCDINT= "GRTCRT"+num$(G301CPT)
        G_GRAAMT         = [F:GRT]GRAAMT    - [F:GRTS]GRAAMT
        G_MAXGRAAMT      = [F:GRT]MAXGRAAMT - [F:GRTS]MAXGRAAMT
        G_INVGRAAMT      = [F:GRT]INVGRAAMT - [F:GRTS]INVGRAAMT
        G_REAGRAAMT      = [F:GRT]REAGRAAMT - [F:GRTS]REAGRAAMT
        G_CRBGRAAMT      = [F:GRT]CRBGRAAMT - [F:GRTS]CRBGRAAMT
        G_CRBGRACUM      = [F:GRT]CRBGRACUM - [F:GRTS]CRBGRACUM
        GREASON = mess(93,7771,1)
        #Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,date$,LCDRET)  From GENEVE : # FQ64478 : paramètre manquant
        Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,date$,LDATCRT(LDT_FINPCO),LCDRET)  From GENEVE
        If (LCDRET > 20 )
          GOK = 0
          Call FSTA("EVEGRT") From GLOCK
        Endif
        If find(G301IAS, [M:FPC]DPRPLNCNX) > 0
          #  Evénement de création IAS
          LCDINT= "GRTCRT"+num$(G301IAS)
          Call GENER_EVE (GVML_OMSUBV,[F:GRT]CPY,[F:GRT]FCY,[F:GRT]GRAREF,0,LCDINT,date$,LDATCRT(LDT_FINPCO),LCDRET)  From GENEVE
          If (LCDRET > 20 ) Then
            GOK = 0
            Call FSTA("EGRTCRT") From GLOCK
          Endif
        Endif
      Endif

   Next
Filter[GRT]

If GOK=0
   LERROR = -1
Endif

Return


#******************************************************************************
Subprog CLORE_EXE_FAS_TVA ( PSOC, PPLN , PDTDBEX, PDTFNEX )
#
# - Objet  : Cloture exercice de FXDASSETS pour les informations  relatives à la TVA
#
# FQ 46680 : Nouvelles règles de TVA
#
Value  Char      PSOC
Value  Integer   PPLN
Value  Date      PDTDBEX
Value  Date      PDTFNEX

  If ( PPLN = G301CPT ) Then
    # --  Plan Comptable

    # Biens sortis dans l'exercice
    If ( [F:FAS]ISSDAT <> [0/0/0] and [F:FAS]ISSDAT >= PDTDBEX and [F:FAS]ISSDAT <= PDTFNEX ) Then
      If ([F:FAS]ISSVATRAT <> 0 ) Then
        [F:FAS]DEDCOEF = 1.
      Else
        [F:FAS]DEDCOEF = 0.
      Endif
    Endif
    # Durée résiduelle
    If ([F:FAS]VATRSD > 0 ) Then : [F:FAS]VATRSD -= 1 : Endif
    # Entretien des cumuls PCG
    [F:FAS]VATREGCUM  -= [F:FAS]VATREGAMT
    [F:FAS]VATREGCUM  += [F:FAS]VATREGDED
    [F:FAS]VATREGAMT   = 0
    [F:FAS]VATREGDED   = 0
    # RAZ des indicateurs de régul annuel et globale
    [F:FAS]VATYEAFLG   = G_NON
    [F:FAS]ASJCOEFGLO  = G_NON
    [F:FAS]TAXCOEFGLO  = G_NON
    [F:FAS]ADMCOEFGLO  = G_NON
    # Coefficients futurs alimentent les coef. de référence et les coef. annuels
    [F:FAS]ASJCOER     = [F:FAS]ASJCOEF
    [F:FAS]TAXCOER     = [F:FAS]TAXCOEF
    [F:FAS]ADMCOER     = [F:FAS]ADMCOEF
    [F:FAS]DEDCOER     = [F:FAS]DEDCOEF
    ###[F:FAS]ASJCOE      = [F:FAS]ASJCOEF
    ###[F:FAS]TAXCOE      = [F:FAS]TAXCOEF
    ###[F:FAS]ADMCOE      = [F:FAS]ADMCOEF
    ###[F:FAS]DEDCOE      = [F:FAS]DEDCOEF
    # Mise à jour des secteurs d'activité de la société
    Call CLORE_EXE_SECTEURS_TVA (PSOC)
  Endif

  If ( PPLN = G301IAS ) Then
    # -- Plan IAS/IFRS
    # Entretien des cumuls IAS
    [F:FAS]IASREGCUM  -= [F:FAS]IASVATREG
    [F:FAS]IASREGCUM  += [F:FAS]VATREGDEDI
    [F:FAS]IASVATREG   = 0
    [F:FAS]VATREGDEDI  = 0
  Endif

End

#******************************************************************************
Subprog CLORE_EXE_SECTEURS_TVA ( PSOC )
#
# - Objet  : Cloture des secteurs TVA de la société
#            Si coéfficient provisoire et définitif sont différents
#              Le coefficent définitif devient coefficient provisoire
#              Le flag coefficient définitif est déforcé
#            sinon
#              On laisse en l'état si coef provisoire est à 1. ou à 0.
#              sinon on déforce
#            finsi
#
# FQ 46680 : Nouvelles règles de TVA
#
#
Value  Char   PSOC

  If clalev([F:SEA]) =0  : Local File SECACT  [SEA]  : Endif  : # secteurs d'activité

  Filter [SEA] Where CPY=PSOC
  #>>>>
  For [SEA]SEA0
    If ( [F:SEA]TAXCOEINI <> [F:SEA]TAXCOEDEF ) Then
      [F:SEA]TAXCOEINI = [F:SEA]TAXCOEDEF
      [F:SEA]TAXCOEFLG = G_NON
    Else
      If ( [F:SEA]TAXCOEDEF <> 1. and [F:SEA]TAXCOEDEF <> 0. ) Then
        [F:SEA]TAXCOEFLG = G_NON
      Endif
    Endif
    Rewrite [SEA]
  Next
  #<<<<
  Filter [SEA]

End

####################################################################################################
$ERR_TEST
 Infbox [F:FAS]AASREF
 Resume
Return

