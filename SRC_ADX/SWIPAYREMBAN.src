#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Swiss Localization
# File          : SWIPAYREMBAN
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 08.04.15
######################################################################################################
# Module        : ACCOUNTING
# Description   : - Bank posting during import ISR
######################################################################################################
# Updates :
# Date      |Author|Version|Description
# 2018-04-30|Bader |2018.R4|X3-87501 MAJ_VALEURS_: read parameter to find out the payment entry type to use
######################################################################################################


######################################################################################################
#                     ACTION OBJET                                                                   #
######################################################################################################
$ACTION
Case ACTION
     When "INIT" : Gosub INIT_
     When "CONTROLE" : Gosub INIT_DIA_ : Gosub CONTROLE From PAYREMBAN
     When "EXEC" : Gosub EXEC_ : Gosub EXEC From PAYREMBAN
     When Default : Gosub ACTION From PAYREMBAN
Endcase
Return

#*****************************************************************************************************
# INIT: Action d'initialisation
#*****************************************************************************************************
$INIT_
Local Integer OK
Local Mask PAYREMBAN [DIA]
Default Mask [DIA]
Raz [DIA]
Return
#*****************************************************************************************************

#*****************************************************************************************************
#INIT_DIA_: Chargement de l'écran de saisie des critères
#*****************************************************************************************************
$INIT_DIA_
Local Integer OK

Gosub MAJ_VALEURS_

Return
#*****************************************************************************************************

#*****************************************************************************************************
#$EXEC
#*****************************************************************************************************
$EXEC_

TRA = 2
Return

$MAJ_VALEURS_

[M:DIA]ALLCPY = 2    #Toutes sociétés

[M:DIA]ALLFCY = 2    #Tous sites

[M:DIA]PAY5=2   #Bordereau de remise
[M:DIA]PAY7=2   #Domiciliation
[M:DIA]PAY9=2   #Règlement

[M:DIA]ALLTYP = 1    #Toutes transactions
# X3-87501 begin
Local Char TPY_(GLONTPY)
Call PARAM("","SWIBVRTPY",TPY_) From ADOVAL  # read parameter to find out the payment entry type to use
[M:DIA]TYP = TPY_
#[M:DIA]TYP = "SWBVR"
# X3-87501 end
[M:DIA]FRMTYP=0

[M:DIA]BIDON="X"

[M:DIA]ALLLOT = 2    #Tous lots de saisie

#Banque
[M:DIA]ALLBAN = 1
[M:DIA]BAN = XBAN_REM_

[M:DIA]ALLUSR = 1    #Tout utilisateur
[M:DIA]USR= GUSER

[M:DIA]PRO=2     #Génération écriture
[M:DIA]TRC=2     #Fichier trace

[M:DIA]ALLFRMTYP=2    #Tout type de remise

[M:DIA]ACCDAT=date$
[M:DIA]ACCSTA=9
GUSRFCY=XFCY_REM_
GUSRAUZ(1)="CMSG"
GCURLEG = "SWI"
Return
#*****************************************************************************************************

