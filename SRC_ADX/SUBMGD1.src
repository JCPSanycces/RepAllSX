#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque MGD1
##########################################################################################################
Subprog AS_NBQUR

  If nolign >= dim([M:MGD1]CREDAT) Then
    End
  Endif
  If nolign > 0 Then
    Call SETQURINFO([M:MGD1]QURNUM(nolign-1), [M:MGD1]TGR(nolign-1)) From TRTMGD1
  Endif
End

##########################################################################################################
# FGR 22/10/2012 : X3SUIVI84697 (début)
Subprog AVANT_NBQUR
  If nolign >= dim([M:MGD1]CREDAT) Then
    End
  Endif
  If nolign > 0 Then
    [M:MGD1]NBQURSEL(GPREMGD1NOL) = ""
    Affzo [M:MGD1]NBQURSEL(GPREMGD1NOL)
  Endif
End

##########################################################################################################
Subprog APRES_NBQUR
  If nolign >= dim([M:MGD1]CREDAT) Then
    End
  Endif
  If nolign > 0 Then
    Call SETQURINFO([M:MGD1]QURNUM(nolign-1), [M:MGD1]TGR(nolign-1)) From TRTMGD1
    GPREMGD1NOL = nolign-1
    [M:MGD1]NBQURSEL(nolign-1) = "->"
    Affzo [M:MGD1]NBQURSEL(GPREMGD1NOL)
  Endif
End
# FGR 22/10/2012 : X3SUIVI84697 (fin)

##########################################################################################################
Subprog AM_TGRFLT(VALEUR)
Variable Char    VALEUR()

  [M:MGD1]TGRFLT = VALEUR
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1) From TRTMGD1
  Affzo [M:MGD1]1-99
End


##########################################################################################################
Subprog C_TGRFLT(VALEUR)
Variable Char    VALEUR()

  # FGR 05/03/2009 : X3SUIVI28171
  If type(GSZWIZMGG) > 0 Then
    #Utilisation dans les assistants marketing
    If GICSTEP = GISTEPBPR Then
      # Si on est au niveau des tiers
      If VALEUR <> "BPARTNER" and VALEUR <> "BPCUSTOMER" and VALEUR <> "BPSUPPLIER" and VALEUR <> "BPCARRIER" and VALEUR <> "SALESREP" Then
        #Cette cible n'est pas autorisée
        GMESSAGE = mess(615,177,1) - VALEUR
        GERR = 2
        mkstat = 2
        End
      Else
        Read [TGP]TGP0=[M:MGD1]TGPNUM
        If [F:TGP]TGR <> VALEUR Then
          Raz [M:MGD1]TGPNUM
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_AUSFLT(VALEUR)
Variable Integer VALEUR

  [M:MGD1]AUSFLT = VALEUR
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1) From TRTMGD1
  Affzo [M:MGD1]1-99
End

##########################################################################################################
Subprog B3_TGPNUM(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR(type(VALEUR)-10)

  SZVALEUR = VALEUR
  Call SETUSERTGP(SZVALEUR, [M:MGD1]TGRFLT) From SUBTGPB
End

##########################################################################################################
Subprog AM_QURCATSEL(VALEUR)
Variable Char    VALEUR()

  [M:MGD1]QURCATSEL = VALEUR
  Call LOADMGD1([M:MGD1]TGRFLT, [M:MGD1]AUSFLT, [M:MGD1]QURCATSEL, 1) From TRTMGD1
  Affzo [M:MGD1]1-99
End

##########################################################################################################
Subprog C_TGPNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [TGP]TGP0=VALEUR
    If !fstat Then
      If [F:TGP]TGR <> [M:MGD1]TGRFLT Then
        #Le support de présentation sélectionné est incompatible avec la cible.
        GMESSAGE = mess(65,177,1)
        GERR = 2
        mkstat = 2
        End
      Endif
    Endif
  Endif
End
