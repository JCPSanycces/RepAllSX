#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(250)(1..2) , VALEUR(100)
PARAM(1) = '[F:HRCTR]QLF="DIV" & (pat([F:ID]NAM,"A*"))'
Call SAISIE_CHAR(VALEUR,PARAM,"SELEMP","SELEMP","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"    : Gosub DEBUT
 When "BOUTON"   : Gosub BOUTON
Endcase
Return

$DEBUT
If clalev([F:DIC])=0 : Local File DICOEMP [DIC] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
Local Integer ET , NET , I1, I2 , I3 , OPE , OKE, VALBOUT
Local Decimal LONG
Local Char    WCHAINE(250) , WEXP(250) , VARIA(20) , VALE(80) , VALINT(80)
# DBA le 10/08/04 : Bug no 24079
Raz [M]
#
[M]FLGCRIT=0
Link [DIC] With [ATZ]CODZONE=[F:DIC]TBL;[F:DIC]FLD , [ATY]CODTYP=[F:ATZ]CODTYP As [LDIC]
nolign = 0
For [LDIC]DIC1 Where [F:DIC]ENAFLG=2 & [F:DIC]ENASEL=2
 nolign += 1
 [M] = [F:DIC]
 Call TEXTE([F:DIC]DES,[M]INTIT(nolign-1)) From OBJDIV
 [M]CODTYP(nolign-1) = [F:ATZ]CODTYP
 If [F:ATZ]CODTYP="ADI"
  [M]NOLIB(nolign-1) = val([F:ATZ]EXPLIEN)
 Else
  [M]NOLIB(nolign-1)  = [F:ATZ]NOLIB
 Endif
 If [F:ATZ]LONG<>0
  [M]LONG(nolign-1) = [F:ATZ]LONG
 Else
  [M]LONG(nolign-1) = [F:ATY]LNGTYP
 Endif
Next
[M]NBLIG = nolign
Affzo 10
Effzo 30
OKE = 1
If type(PARAM(1))>10 & PARAM(1)<>""
 WCHAINE = vireblc(format$("KT:250X",PARAM(1)),2)
 If left$(WCHAINE,1)="(" & right$(WCHAINE,len(WCHAINE))=")"
  WCHAINE = vireblc(seg$(WCHAINE,2,len(WCHAINE)-1),2)
 Endif
 ET = 0
 While WCHAINE<>""
  NET = 0
  I1 = instr(1,WCHAINE,"&")
  I2 = instr(1,WCHAINE,"|")
  If I1 & I2 : I3 = min(I1,I2)
               If I3=I1 : NET = 1 : Else : NET = 2 : Endif
  Elsif I1   : I3 = I1
               NET = 1
  Else  I2   : I3 = I2
               NET = 2
  Endif
  If I3
   WEXP = vireblc(left$(WCHAINE,I3-1),2)
   WCHAINE = vireblc(right$(WCHAINE,I3+1),2)
   If left$(WCHAINE,1)="(" & right$(WCHAINE,len(WCHAINE))=")"
    WCHAINE = vireblc(seg$(WCHAINE,2,len(WCHAINE)-1),2)
   Endif
  Else
   WEXP = WCHAINE
   WCHAINE = ""
  Endif
  OPE = 0
  If left$(WEXP,4) = "pat("
   OPE = 8
   WEXP = vireblc(seg$(WEXP,2,len(WEXP)-1),2)
  Endif
  I1 = instr(1,WEXP,"]")
  If !I1 : OKE = 0 : Break : Endif
  I2 = I1
  While I2<=len(WEXP) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(WEXP,I2+1,1))
   I2 += 1
  Wend
  VARIA = seg$(WEXP,I1+1,I2)
  Read [DIC]DIC0 = VARIA
  If fstat : OKE = 0 : Break : Endif
  WEXP = vireblc(right$(WEXP,I2+1),2)
  If left$(WEXP,1)="="     : OPE = 2 : I1 = 2
  Elsif left$(WEXP,2)="<>" : OPE = 3 : I1 = 3
  Elsif left$(WEXP,1)=">"  : OPE = 4 : I1 = 2
  Elsif left$(WEXP,2)=">=" : OPE = 5 : I1 = 3
  Elsif left$(WEXP,1)="<"  : OPE = 6 : I1 = 2
  Elsif left$(WEXP,2)="<=" : OPE = 7 : I1 = 3
  Endif
  If OPE=0 : OKE = 0 : Break : Endif
  If OPE=8
   If left$(WEXP,1)=","
    WEXP = vireblc(right$(WEXP,2),2)
   Else
    OKE = 0 : Break
   Endif
  Else
   WEXP = vireblc(right$(WEXP,I1),2)
  Endif
  Read [ATZ]CODZONE = [F:DIC]TBL;VARIA
  Read [ATY]CODTYP  = [F:ATZ]CODTYP
  Case [F:ATY]TYPTYP
   When 7
    If  (left$(WEXP,1)='"' & right$(WEXP,len(WEXP))='"')
&    or (left$(WEXP,1)="'" & right$(WEXP,len(WEXP))="'")
      VALE = seg$(WEXP,2,len(WEXP)-1)
    Else
     OKE = 0 : Break
    Endif
   When 8
    VALE = format$("YYYYMMDD",evalue(WEXP))
   When Default
    VALE = WEXP
  Endcase
  If [F:ATZ]LONG<>0
   LONG = [F:ATZ]LONG
  Else
   LONG = [F:ATY]LNGTYP
  Endif
  Call CONTROLE(VALE,[F:ATY]CODTYP,[F:ATZ]NOLIB,LONG,VALINT) From FMTVAR
  NOL = [M]NBEXP
  [M]NBEXP += 1
  [M]ETOU(NOL) = ET
  [M]WCHP(NOL) = VARIA
  [M]WVAL(NOL) = VALINT
  [M]WOPE(NOL) = OPE
  Call TEXTE([F:DIC]DES,TEXTE) From OBJDIV
  [M]EXPR(NOL) = [F:ATX]TEXTE-mess(OPE,55,1)-VALE
  ET = NET
 Wend
Endif
If OKE
 Affzo 30
Else
 Effzo 30
Endif
#Quand on arrive vierge dans cette fonction, on veut prĂ©-sĂ©lectionner le 1er champ...
If ![M]NBEXP
 NOL=[M]NBEXP
 [M]CHAMP = [M]FLD(NOL)
 [M]LIBEL = [M]INTIT(NOL) : Affzo LIBEL
 [M]TYP = [M]CODTYP(NOL)
 [M]LIB = [M]NOLIB(NOL)
 [M]LNG = [M]LONG(NOL)
 If [M]TYP="ADI"
  [M]SUPP = num$([M]NOLIB(NOL))
 Else
  [M]SUPP = ""
 Endif
Endif
#
Return

$BOUTON
Case BOUT
 When "1","2"
  VALBOUT=val(BOUT)
  Gosub ET_OU
 When "3"
  If [M]FLGCRIT=0 : VALBOUT=1 : Gosub ET_OU : Endif
  Gosub CRITERE
  FIN = 1
  mkstat = 4
Endcase
Return

#DBA le 10/08/04 : Bug No 24089
$ET_OU
If [M]CHAMP<>"" & [M]OPE<>1
 NOL = [M]NBEXP
 [M]NBEXP += 1
 If [M]NBEXP>1
  [M]ETOU(NOL) = VALBOUT
 Else
  [M]ETOU(NOL) = 0
 Endif
 K = find([M]CHAMP,[M]FLD(0..[M]NBLIG))
 [M]WCHP(NOL) = [M]CHAMP
 [M]WVAL(NOL) = [M]VALINT
 [M]WOPE(NOL) = [M]OPE
 [M]EXPR(NOL) = [M]INTIT(K-1)-mess([M]OPE,55,1)-[M]VALEUR
 Affzo 30
 SUIZON = "VALEUR"
 [M]FLGCRIT=1
Endif
Return

$CRITERE
Local Char VALE(80) , CHAMP(20) , OPER(5) , VALCRI(250)
VALCRI = ""
For I=0 To [M]NBEXP-1
 If I>0
  If [M]ETOU(I)=1
   VALCRI -= "& ("
  Else
   VALCRI -= "| ("
  Endif
 Endif
 Read [DIC]DIC0 = [M]WCHP(I)
 Read [ATB]CODFIC = [F:DIC]TBL
 Read [ATZ]CODZONE = [F:DIC]TBL;WCHP(I)
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+WCHP(I)
 Case [F:ATY]TYPTYP
  When 1,2,3,4,5,6
   VALE = [M]WVAL(I)
  When 7
   VALE = '"'+[M]WVAL(I)+'"'
  When 8
   VALE = '['+format$(GFMD,gdat$([M]WVAL(I)))+']'
 Endcase
 Case [M]WOPE(I)
  When 2 : OPER = "="
  When 3 : OPER = "<>"
  When 4 : OPER = ">"
  When 5 : OPER = ">="
  When 6 : OPER = "<"
  When 7 : OPER = "<="
 Endcase
 If [M]WOPE(I)=8
  VALCRI += "pat("+CHAMP+","+VALE+")"
 Else
  VALCRI += CHAMP+OPER+VALE
 Endif
Next I
If [M]NBEXP>0
 VALCRI += string$([M]NBEXP-1,")")
Endif
If PARAM(2)="2" :  # Bouton bas d'Ă©cran sans remplissage du tableau des salariĂ©s
 PARAM(1) = VALCRI
Else
 If type(VALEUR)>10
  VALEUR = VALCRI
 Else
  PARAM(1) = VALCRI
 Endif
Endif
Return

########################################
Subprog AS_NBLIG
If status=71 or GBROWS #72698
 [M]CHAMP = [M]FLD(nolign-1)
 [M]LIBEL = [M]INTIT(nolign-1) : Affzo LIBEL
 [M]TYP = [M]CODTYP(nolign-1)
 [M]LIB = [M]NOLIB(nolign-1)
 [M]LNG = [M]LONG(nolign-1)
 If [M]TYP="ADI"
  [M]SUPP = num$([M]NOLIB(nolign-1))
 Else
  [M]SUPP = ""
 Endif
 [M]FLGCRIT=0
Endif
End

Subprog C_OPE(VALEUR)
Variable Integer VALEUR
# Pour supprimer une condition dans le tableau il fallait mettre une valeur<>1
#If VALEUR=1
 #mkstat = 1
#Elsif VALEUR=8
If VALEUR=8
 Read [DIC]DIC0 = [M]CHAMP
 Read [ATB]CODFIC = [F:DIC]TBL
 Read [ATZ]CODZONE = [F:DIC]TBL;[M]CHAMP
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP<>7
  mkstat = 1
 Endif
Endif
End

