#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char    DATAW,DATAM
Local Integer OK
DATAW = "YCOMPTAX"
DATAM = "YCOMPTA"
Call OUVRE_TRACE("Test") From LECFIC
Call TEMPON("F") From GESECRAN
Call MAJ_CONNEXION(DATAW,DATAM,OK)
Call TEMPOFF From GESECRAN
Call LEC_TRACE   From LECFIC
Call FERME_TRACE From LECFIC
TRA = 1
End

Subprog MAJ_CONNEXION(DATAW,DATAM,OK)
Value Char    DATAW
Value Char    DATAM
Variable Integer OK
OK =1
Local Char    SAVIFS(5),SAVIRS(5)
Local Integer SAVIUM
Local Char    FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC)
Local Char    EXE(50),SERV(20)
Local Char    USRBI(100),PWDBI(100),RETOUR(200)
Local Char    REPADXDIR(GDIMFIC)
Local Char    COMPBONAM(GDIMFIC)
Local Char    TYPBDA(100)
Local Char    DOSSIER(GDIMFIC)
Local Char    DATABASE(10)
Local Char    SERV_ODBC(100)
Local Integer MODESECBI
Local Char    REPERT(GDIMFIC)
Local Char    FICBAT(GDIMFIC)
Local Char    FICINI(GDIMFIC)
Local Char    FICTRA(GDIMFIC)
Local Char    CONNEXION(50)
Local Char    LIGNE(250)

# lecture du datawaherouse
If !clalev([F:ABW]) : Local File ABIDATWRH [F:ABW] : Endif
Read [F:ABW]ABW0 = DATAW
If fstat 
 OK =0
 End
Endif

# lecture du datamart
If !clalev([F:ABM]) : Local File ABIDATMRT [F:ABM] : Endif
Read [F:ABM]ABM0 = DATAM
If fstat 
 OK =0
 End
Endif

# Init des varaibles
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(13)+chr$(10) : # On est sous windows
adxium = GASCII
EXE = "maj_con.exe"
Call RECHPROP("component.busobj.servername",MACHINE,GBIDI1) From INTRUTILA
Call RECHPROP("busobj.adxadmin.port",SERV,GBIDI1) From INTRUTILA
Call VARPSEBO(GUSER,USRBI,PWDBI,GBIDC3,MODESECBI,GBIDI2) From GESUSER 
Call INCRYPT([L]USRBI,RETOUR) From INTRUTILA
[L]USRBI="CRYPT:"+RETOUR
Call INCRYPT([L]PWDBI,RETOUR) From INTRUTILA
[L]PWDBI="CRYPT:"+RETOUR
Call VARADX("ADXDIR",MACHINE+":"+SERV,REPADXDIR) From ADXD
Call RECHPROP("component.busobj.name",COMPBONAM,GBIDI1) From INTRUTILA
Call VAR_BOWORLD("type",[F:ABW]SOLBI,"database",[L]TYPBDA,GBIDI1) From ABICREBAS
Call VAR_BOWORLD("name",[F:ABW]SOLBI,"database",CONNEXION,GBIDI1) From ABICREBAS
If [L]TYPBDA="ORACLE"
 DATABASE = "oracle"
Elsif [L]TYPBDA="SQLSERVER"
 DATABASE = "sql"
Endif
DOSSIER  = [F:ABW]COD
Call VAR_BOWORLD("dblink","","",SERV_ODBC,GBIDI1) From ABICREBAS
Call RECHPROP("busobj.tools.path",REPERT,GBIDI1)From INTRUTILA
REPERT  += +"\BO_GEN"
FICBAT = REPADXDIR+"\tmp\"+COMPBONAM+"\BO_GEN\MAJ_CON.bat"
FICINI = REPADXDIR+"\tmp\"+COMPBONAM+"\BO_GEN\MAJ_CON.ini"
FICTRA = REPADXDIR+"\tmp\"+COMPBONAM+"\BO_GEN\MAJ_CON.tra"

## Verif repertoire de travail
Local Char    CHEMIN(250)
Local Integer EXISTE
CHEMIN = MACHINE+':'+SERV+'@'+REPADXDIR+'\tmp\'+COMPBONAM+'\BO_GEN'
Call EXISTE(CHEMIN,EXISTE) From ORDSYS
If !EXISTE
 Call SYSTEME(MACHINE+":"+SERV,"ae_mkdir"-REPADXDIR+'\tmp\'+COMPBONAM+'\BO_GEN',"",GBIDI1) From ORDSYS
 Call EXISTE(CHEMIN,EXISTE) From ORDSYS
 If EXISTE=0
  OK = 0 : Call ERREUR(mess(221,133,1)) From GESECRAN : # Le répertoire distant n'a pas pu être crée
  End
 Endif
Endif

## Creation dun fichier ini
Openo MACHINE+":"+SERV+"@"+FICINI ,0
Wrseq "User="+USRBI
Wrseq "Passe="+PWDBI
Wrseq "Serveur="+MACHINE
If GBIDI2=1
 Wrseq "Authen=enterprise" 
Else
 Wrseq "Authen="+mess(MODESECBI,7835,1)
Endif
Wrseq "Dossier="+DOSSIER
Wrseq "service="+[L]SERV_ODBC
Wrseq "FicTra="+FICTRA
If [L]DATABASE = "oracle"
 Wrseq "network="+mess(82,148,1)
 Wrseq "engine="+mess(79,148,1)
Elsif [L]DATABASE = "sql"
 Wrseq "network="+mess(81,148,1)
 Wrseq "engine="+mess(80,148,1)
Endif
Wrseq "connexion="+CONNEXION
Wrseq "niv0="+GREPBI
Wrseq "niv1="+GREPSOLIND
Wrseq "niv2="+GREPBOPROD
Wrseq "niv3="+"ALL"
Wrseq "abr="+[F:ABM]ABR
Openo

## Creation dun fichier ini
Openo MACHINE+":"+SERV+"@"+FICBAT ,0
If mid$(REPERT,2,1)=":"
 Wrseq "cd \"
 Wrseq left$(REPERT,2)
 Wrseq 'cd "'+right$(REPERT,4)+'"'
Else
 Wrseq 'cd "'+REPERT+'"'
Endif
Wrseq EXE-REPADXDIR+"\tmp\"+COMPBONAM+"\BO_GEN\MAJ_CON.ini"
Openo

# Exécution du .bat
System STAT = MACHINE+":"+SERV+'@"'+FICBAT+'"'

# Trace
If GTRACE<>""
 If filinfo(MACHINE+":"+SERV+"@"+FICTRA,7) <0
  OK =0
  Call ECR_TRACE("Probleme modification connexion",1) From GESECRAN
  End
 Endif
 Openi MACHINE+":"+SERV+"@"+FICTRA
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   Call ECR_TRACE(right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
 System STAT = MACHINE+":"+SERV+'@ae_rm "'+FICTRA+'"'
Endif

# Effacement du fichier bat et ini
System STAT = MACHINE+":"+SERV+'@ae_rm "'+FICBAT+'"'
System STAT = MACHINE+":"+SERV+'@ae_rm "'+FICINI+'"'

End
