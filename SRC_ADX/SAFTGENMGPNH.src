#<AdxTL>@(#)0.0.0.0 $Revision$
$PRETURN
Gosub OPEN_LNK_PNH From SAFTGENPORMG
For [MGT4]
    Read [F:PTDK2]DKD0="SAFT-PT";[F:PTPNH]PNHTYP;[F:PTPNH]PNHNUM
    Call LEC_TPN_LEG([F:PTFCY]LEG, [F:PTPNH]PNHTYP,[L]STAT) From TRTLECLEG
    If [L]SAFTTYPE = 8
      If !find([F:PTDK2]RECTYP,1)
        Goto NEXTPNH2
      Endif

      If func PORLEGLIB1.CTRL_COMDAT([F:PTPNH]PNHFCY,[F:PTPNH]DPEDATR,[F:PTPNH]ETDR)<>1 : Goto NEXTPNH2 : Endif

   Endif
   Gosub RAZVAR_MG From SAFTGENPORMG
   Gosub FEED_VARS
   $NEXTPNH2
Next
Gosub CLOSE_LNK_PNH From SAFTGENPORMG
Return

$FEED_VARS
#DocumentNumber
Call PTNUMDOC([F:PTPNH]PNHTYP,[F:PTPNH]PNHNUM,[L]MGDOCNUMB) From SAFTGENPORMG

#ATCUD
[L]MGATCUD = "0"

#MovementStatuts
[L]MGMOVSTAT = 'N'

#SystemEntryDate, Reason, SourceID, Hash, HashControl, SourceID, ATDocCodeID, SourceBilling
# Issue 105227 - 2015-08-21 by BRBAN :[L]MGMOVTYPE - MovementType must come from DKSDATA
If [F:PTDK2]RECTYP=4
  Call DOCSTAT([F:PTPNH]PNHTYP,[F:PTPNH]PNHNUM,[F:PTPNH]RTNDAT,2,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Else #Outros
  Call DOCSTAT([F:PTPNH]PNHTYP,[F:PTPNH]PNHNUM,[F:PTPNH]RTNDAT,1,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Endif

#MovementType
# Issue 105227 - 2015-08-21 by BRBAN : If it's null, then fill with [F:TPN]SAFTTRNTYP
# RMA * Do not change, this is for previous cases when we didn't have SAFTTRNTYP on DKSDATA
If [L]MGMOVTYPE=''
  Call MANDOC_TEXT_GT([F:TPN]RECTYP,[F:TPN]SAFTTRNTYP,[L]MGMOVTYPE) From PORLEGLIB
Endif

If [L]MGCREUSER = ''
  [L]MGCREUSER = [F:PTPNH]CREUSR
Endif

#MovementStatusDate
[L]MGMOVSTDT = [L]MGSYSENTD
#SourceID -> DocumentStatus
[L]MGUPDUSER = [L]MGCREUSER
#Period
[L]MGPERIODE  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:PTPNH]CPY, [F:PTPNH]RTNDAT)
#MovementDate
[L]MGMOVEDAT  = format$("D:YYYY[-]MM[-]DD",[F:PTPNH]RTNDAT)

#TransactionID
If [L]SAFTTYPE=2
  Filter [F:PTSTJ] Where VCRNUM=[F:PTPNH]PNHNUM & STOFCY=[F:PTPNH]PNHFCY
  Read [F:PTSTJ] First
  If !fstat
    Read [F:HAE]HAE0 = [F:PTSTJ]GTE;[F:PTSTJ]NUMVCR
    If !fstat
      If len([F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/",""))>20
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + ctrans([F:HAE]NUM,"_-.\/","")
      Else
        [L]MGTRANSID = format$("D:YYYY[-]MM[-]DD",[F:HAE]ACCDAT) + " " + [F:HAE]JOU + " " + [F:HAE]TYP+ctrans([F:HAE]NUM,"_-.\/","")
      Endif
    Endif
  Endif
  Filter [F:PTSTJ]
Endif

#CustomerID
[L]MGCUSTOID = ""
#SupplierID
[L]MGSUPPLID = [F:PTPNH]BPSNUM
#MovementComments
[L]MGCOMMENT = ""
#DeliveryID
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
[L]MGDELIVID = vireblc([F:PTPNH]LICPLATER-[F:PTPNH]TRLLICPLATER, 2)
If [L]MGDELIVID = ""
  [L]MGDELIVID = "Desconhecido"
Endif
#Issue end
#DeliveryDate
[L]MGDELIVDT = [F:PTPNH]RTNDAT

#LocationID
[L]MGLOCATID = ""
#BuildingNumber
[L]MGBUIDNBR = "Desconhecido"

#ShipTo
#WarehouseID
[L]MGWAREHID_ST = ""
#StreetName,AddressDetail,City,PostalCode,Region
If ctrans([F:PTPNH]BPAADDLIG(0)+[F:PTPNH]BPAADDLIG(1)+[F:PTPNH]BPAADDLIG(2),' ','')<>''
  [L]MGSTREETN_ST = ''
  [L]MGADDDETA_ST = vireblc([F:PTPNH]BPAADDLIG(0)-[F:PTPNH]BPAADDLIG(1)-[F:PTPNH]BPAADDLIG(2),2)
  [L]MGCITY_ST    = vireblc([F:PTPNH]CTY,2)
  [L]MGPOSTCOD_ST = vireblc([F:PTPNH]POSCOD,2)
  [L]MGCOUNTRY_ST = vireblc([F:PTPNH]CRY,2)
  [L]MGREGION_ST  = vireblc([F:PTPNH]SAT,2)
Else
  Call ADDRESS(1,[F:PTPNH]BPSNUM,[F:PTPNH]BPAADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
Endif

If [L]MGADDDETA_ST  = '' : [L]MGADDDETA_ST  = 'Desconhecido' : Endif
If [L]MGCITY_ST     = '' : [L]MGCITY_ST     = 'Desconhecido' : Endif
If [L]MGPOSTCOD_ST  = '' : [L]MGPOSTCOD_ST  = '0000000'      : Endif
If [L]MGREGION_ST   = '' : [L]MGREGION_ST   = 'Desconhecido' : Endif
If [L]MGCOUNTRY_ST  = '' : [L]MGCOUNTRY_ST  = 'PT'           : Endif

If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Return : Endif
If len([L]MGPOSTCOD_ST) = 7 & [L]MGCOUNTRY_ST = 'PT'
  [L]MGPOSTCOD_ST = format$("K:4#[-]3#", [L]MGPOSTCOD_ST)
Endif

#ShipFrom
#WarehouseID
[L]MGWAREHID_SF = [F:PTPNH]PNHFCY
#StreetName,AddressDetail,City,PostalCode,Region
Call ADDRESS(3,[F:PTPNH]PNHFCY,[F:PTFCY]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

#MovementEndTime
If [F:PTPNH]ARVDATR<>[0/0/0] & [F:PTPNH]ETAR <> "0000"
  [L]MGMOVENDT = format$("D:YYYY[-]MM[-]DD",[F:PTPNH]ARVDATR)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTPNH]ETAR,":","")+"00")
Endif
#MovementStartTime
If [F:PTPNH]DPEDATR<>[0/0/0] & [F:PTPNH]ETDR <> "0000"
  [L]MGMOVSTRT = format$("D:YYYY[-]MM[-]DD",[F:PTPNH]DPEDATR)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTPNH]ETDR,":","")+"00")
Else
  Call ECR_TRACE (mess(8,701,1)-[F:PTPNH]PNHNUM - mess(236,7711,1), 1) From GESECRAN
Endif
#Gosub SET_TZ From PORLEGLIB1

#VEHICLEID
[L]VEHICLEID = [F:PTPNH]LICPLATER+[F:PTPNH]TRLLICPLATER

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_H From SAFTGENPORMG
Endif

For [F:PTPND] Where [F:PTPND]PNHNUM = [F:PTPNH]PNHNUM
  Gosub RAZVAR_MG_D From SAFTGENPORMG
  #LineNumber
  #[L]MGDLINNBR = [F:PTPND]PNDLIN
  [L]MGDLINNBR +=1
  #OriginatingON, OrderDate
  [L]MGDORIGIN  = ""
  #ProductCode
  [L]MGDPRODUC = [F:PTPND]ITMREF
  #ProductDescription
  If [F:PTPND]ITMDES<>""
    [L]MGDPRODES = [F:PTPND]ITMDES
  Else
    [L]MGDPRODES = "Desconhecido"
  Endif
  #Quantity
  [L]MGDQUANTI  = [F:PTPND]QTYPUU
  #UnitOfMeasure
  [L]MGDUOM    = [F:PTPND]PUU
  #Description
  If [F:PTPND]ITMDES1<>""
    [L]MGDLINDES = [F:PTPND]ITMDES1
  Else
    [L]MGDLINDES = "Desconhecido"
  Endif
  #TaxType
  [L]MGDTAXTYP = "IVA"

  #TaxCountryRegion,TaxCode,TaxPercentage,TaxExemptionReason
  For YC = 0 To 0 #Alterar?
   If [F:PTPND]VAT(YC)<>""
    #Issue X3-31864 – 2017-04-11  by MANOW
    Call GETTAX([L]SOC,[F:PTPND]VAT(YC),[F:PTPNH]RTNDAT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXAMO,[L]MGDTAXEXA,[L]MGDTAXEXAC,[L]VENEXEFLG) From SAFTGENPORVAT
    #Issue X3-31864 end
   Endif
  Next

  If [F:ITM]ITMREF <> [F:PTPND]ITMREF
    Read [F:ITM]ITM0 = [F:PTPND]ITMREF
  Endif
  If !fstat
    If [F:ITM]SERMGTCOD > 1
      For [F:STJ]STJ1 Where [F:STJ]STOFCY = [F:PTPNH]PNHFCY & [F:STJ]VCRTYP = 8 & [F:STJ]VCRNUM = [F:PTPNH]PNHNUM & [F:STJ]VCRLIN = [F:PTPND]PNDLIN & [STJ]SERNUM <> ""
        [L]SDLSERNUM(maxtab([L]SDLSERNUM)+1)=[STJ]SERNUM
      Next
    Endif
  Endif

  If [L]SAFTWAY=1
    Gosub WRITE_MOVEG_D From SAFTGENPORMG
  Else
    Gosub FEED_VAR_WS From PORLEGLIB1
  Endif

Next

#CurrencyCode
[L]MGTCURCOD = ""

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_T From SAFTGENPORMG
Endif

Return

