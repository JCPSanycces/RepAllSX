#** #############################################################################################
#*Handler for the report preprocess.
#*
#* @param     NBPAR       Variable Integer      Number of parameters
#* @param     PARAMETRE   Variable Char()(1..)  Report parameters as strings.
#*
#*! #############################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char PARAMR, REPCODE

#Report generation is only possible when germant tax return dialog is open
#otherwise => End
If !clalev([M:TRG0])
   End
Endif

# Get the report code from report name.
Call GETPARAM("__REPORT",NBPAR,PARAMETRE,PARAMR)  From ETAT
K = instr(1,PARAMR,".")
If K : REPCODE = left$(PARAMR,K-1)  : Endif

# Get the report ID for the selection using AREPORTM.NUMREQ.
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAMR) From ETAT : NUMREQ = val(PARAMR)
PARAMR = num$(NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the datbegin (start date) parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]DATDEB
Call SETPARAM("datbegin",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the  (end date) parameter with the information from the header screen [M:TRG0]
PARAMR = [M:TRG0]DATFIN
Call SETPARAM("datende",NBPAR,PARAMETRE,PARAMR) From ETAT

#Set the  company parameter with the information from the header screen [M:TRG0]
PARAMR = func RPTTRGVAL1.GETCOMPANYNAME()
Call SETPARAM("cpyname",NBPAR,PARAMETRE,PARAMR) From ETAT

#write data in AREPORTM
Gosub INS_ARM
End

#** #############################################################################################################
#*INS_ARM writes data from the grid in mask [M:TRG3] to the AREPORTM table
#** #############################################################################################################
$INS_ARM
Local Integer J1
Local Integer KZ(106)
Local Decimal UMSATZ(106)
Local Decimal UST(106)
Local Char EUACCCHECK(2)
Local Char TAXACCCHECK(2)


#delete records for the same report and user
Call DELETEREPRECORDS(REPCODE)
#variable for numlig
J1 = 0
If !clalev([F:ARM])  : Local File AREPORTM [ARM]  :  Endif
If !clalev([F:VLI])  : Local File VATLINITMGER [VLI]  :  Endif
If !clalev([F:DAE])  : Local File GACENTRYD [DAE]  :  Endif
If !clalev([F:GAC])  : Local File GACCOUNT [GAC]  :  Endif
If !clalev([F:TRA])  : Local File TABRATVAT [TRA]  :  Endif
If !clalev([F:PIH])  : Local File PINVOICE [PIH]  :  Endif
GOK = 1
Call DEBTRANS From GLOCK
#If !clalev([M:XEV4]) : Default Mask [M:XEV4] : Endif
Filter [VLI] Where IDUSER = func CNSTRGSTD.GETUSERID()
EUACCCHECK = "-1"
TAXACCCHECK = "-1"
#For I= 0 To [M:XEV2]NBLIG-1
For [VLI]
    Trbegin [ARM]
    #if ivnum not treated yet go on
    If func CHECKIVNUM([F:VLI]IVNUM, REPCODE) = 0 Then

      Filter [DAE] Where TYP = [F:VLI]TYP & NUM =[F:VLI]IVNUM & COA =[F:VLI]COA

      For [DAE]
        #only with tax number
        If [F:DAE]TAX <> "" and [F:DAE]LEDTYP = func CNSTRGSTD.GETMAINLEDORINDEX([F:DAE]CPY, 2)
          J1 +=1
          Raz [ARM]

           #check if more than one account in the invoice lines is a eu-account
          If EUACCCHECK = "-1"
            [L]EUACCCHECK = func CHECKEUACCOUNTS()
          Endif
          #If func CHECKEUACCOUNTS() = 1 Then
            [F:ARM]CLEA11 = EUACCCHECK
          #Endif
          If TAXACCCHECK = "-1"
          TAXACCCHECK = func CHECKONLYTAXACCOUNTS()
          Endif
          [F:ARM]CLEA9 = TAXACCCHECK




          [F:ARM]RPTCOD = REPCODE
          [F:ARM]USR    = GUSER
          [F:ARM]NUMREQ = NUMREQ
          [F:ARM]NUMLIG = J1

          Read [F:PIH]PIH0 = [F:VLI]IVNUM
          If !fstat
            [F:ARM]CLEMD3 = [F:PIH]CEEFLG
          Endif

          [F:ARM]CLEA2 = [F:VLI]IVNUM
          [F:ARM]CLEA3 = [F:VLI]TYP

          If [F:DAE]BPR <>"" Then
             [F:ARM]CLEA4 = [F:DAE]BPR
          Else
             [F:ARM]CLEA4 = [F:DAE]OFFACC
          Endif

          [F:ARM]CLEA5    = [F:DAE]ACC
          [F:ARM]CLEA6 = [F:DAE]OFFACC
          [F:ARM]CLEN1    = [F:DAE]SNS
          [F:ARM]CLEMD1 = [F:DAE]AMTLED
          [F:ARM]CLEA7    = [F:DAE]TAX
          [F:ARM]CLEA10 =    [F:DAE]COA

          Read [F:GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
          If !fstat
             [F:ARM]CLEN2 = [F:GAC]FLGVAT
             [F:ARM]CLEN3 = [F:GAC]VATIPT
          Endif


          Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
          Filter [TRA] Where VAT=[F:DAE]TAX  & STRDAT<=[M:TRG0]DATDEB & LEG=[F:TVT]LEG & (CPY=[F:DAE]CPY | CPY="") Order By CPY Asc
          Read [TRA] Last #(3) = [F:DAE]TAX;[F:TVT]LEG;[F:DAE]CPY
          If !fstat
            #If GUSER = "ANGRE" : Infbox num$([F:TRA]VATRAT) : Endif
            [F:ARM]CLEMD2 = [F:TRA]VATRAT
            [F:ARM]CLEA8 = num$([F:TRA]STRDAT)
          Endif


#          Read [TRA]TRA0(2) =  [F:DAE]TAX;[F:DAE]CPY
#          If fstat
#           Read [TRA]TRA0(1) =  [F:DAE]TAX
#           If !fstat
#               Filter [TRA] Where VAT =  [F:DAE]TAX and [M:TRG0]DATDEB>=[TRA]STRDAT
#               For [TRA]
#                 [F:ARM]CLEMD2 = [F:TRA]VATRAT
#                 [F:ARM]CLEA8 = num$([F:TRA]STRDAT)
#               Next
#            Endif
#          Endif
#          Filter [TRA]
#

          Filter [TRA]

          [F:ARM]CREDAT = date$
           Write [ARM]
          If fstat
            #Infbox num$(fstat)
            GOK = 0
          Endif
       Endif

      Next
      Filter [DAE]
  Endif


  If GOK<1 : Rollback : Break : Endif
  Commit
Next

#Trbegin [ARM]
#
#For I = 0 To [M:TRG4]NBLIG-1
#  J1 +=1
#  If [M:TRG4]TAXNO(I) <> ""
#    Raz [F:ARM]
#    #Infbox [M:TRG4]TAXNO(I)
#    [F:ARM]RPTCOD = REPCODE
#    [F:ARM]USR    = GUSER
#    [F:ARM]NUMREQ = NUMREQ
#    [F:ARM]NUMLIG = J1
#
#    [F:ARM]CLEA1  = [M:TRG4]REFNO(I)
#    [F:ARM]CLEA2  = [M:TRG4]IVNUM(I)
#    [F:ARM]CLEA3  = [M:TRG4]TYP(I)
#    [F:ARM]CLEA4  = [M:TRG4]BPR(I)
#    [F:ARM]CLEA5  = [M:TRG4]ACC(I)
#    [F:ARM]CLEA6  = [M:TRG4]OFFACC(I)
#    [F:ARM]CLEA7  = [M:TRG4]TAXNO(I)
#    [F:ARM]CLEN1  = [M:TRG4]SNS(I)
#    [F:ARM]CLEN2  = [M:TRG4]FLGVAT(I)
#    [F:ARM]CLEN3  = [M:TRG4]VATIPT(I)
#    [F:ARM]CLEMD1  = [M:TRG4]AMTLOC(I)
#    [F:ARM]CLEMD2  = [M:TRG4]VATRAT(I)
#    [F:ARM]CLEMD3  = [M:TRG4]CEEFLG(I)
#    [F:ARM]CLEA10 = [M:TRG4]COA(I)
#    [F:ARM]CLEA8  = num$([M:TRG4]STRDAT(I))
#    [F:ARM]CREDAT = date$
#      Write [ARM]
#    If fstat
#     GOK = 0
#    Endif
#  Endif
#
#Next
#If GOK<1 : Rollback : Endif
#Commit
##Infbox("NUMREQ: " + num$(NUMREQ))
Return





#** #############################################################################################################
#*checks if at least two account contained in the invoice lines are eu-accounts
#* @return RESULT 1 if at least two eu-accounts
#** #############################################################################################################
#*!


Funprog CHECKEUACCOUNTS()
  Local Integer COUNT
  If !clalev([F:DAE2])  : Local File GACCENTRYD [DAE2] : Endif
  Local Char RESULT(2)
  Filter [DAE2] Where TYP = [F:VLI]TYP & NUM =[F:VLI]IVNUM & COA =[F:VLI]COA
  For [DAE2]
    Read [F:GAC]GAC0 = [F:DAE2]COA;[F:DAE2]ACC
    If [F:GAC]FLGVAT = 4 : COUNT +=1 : Endif
  Next
  If COUNT >= 2
    RESULT = "1"
  Endif
  Close File [DAE2]
End RESULT



#** #############################################################################################################
#*checks if only tax accounts contained in an invoice
#* in an Invoice
#* @return RESULT 1 if only tax accounts contained in an invoice
#** #############################################################################################################
#*!


Funprog CHECKONLYTAXACCOUNTS()
  Local Integer TAXCOUNT
  Local Integer OTHERCOUNT
  Local Char RESULT(2)
  If !clalev([F:DAE2])  : Local File GACCENTRYD [DAE2] : Endif
  #Local Integer RESULT : RESULT = 0
  Filter [DAE2] Where TYP = [F:VLI]TYP & NUM =[F:VLI]IVNUM & COA =[F:VLI]COA
  For [DAE2]
    Read [F:GAC]GAC0 = [F:DAE2]COA;[F:DAE2]ACC
    If [F:GAC]FLGVAT = 4 or [F:GAC]FLGVAT = 3
      TAXCOUNT +=1
    Else
      #OTHERCOUNT +=1
      End RESULT
    Endif
  Next
  If TAXCOUNT > 0 #and OTHERCOUNT = 0
    RESULT = "1"
  Endif
  Close File [DAE2]
End RESULT




#** #############################################################################################################
#*checks if a ivnum allready treated
#*
#* @param INVNUM Invoice number
#* @param REPORTCODE Report code
#** #############################################################################################################
#*!
Funprog CHECKIVNUM(INVNUM, REPORTCODE)
Value Char INVNUM
Value Char REPORTCODE
Local Integer RESULT
    #Infbox "Reportcode = " + REPORTCODE
    #Infbox "User = " + GUSER
    #Infbox "Invnum = " + INVNUM
    Filter [ARM] Where RPTCOD = REPORTCODE and USR = GUSER and CLEA2 = INVNUM
    RESULT = rowcount([ARM])
    #Infbox num$(RESULT)
    Filter [ARM]
End RESULT


#** #############################################################################################################
#*#delete records for a given reportcode from areportm
#*
#* @param REPORTCODE Report code
#** #############################################################################################################
Subprog DELETEREPRECORDS(REPORTCODE)
Value Char REPORTCODE

    # Delete temporary report data from AREPORTM table.
    If !clalev([ARM]): Local File AREPORTM[ARM] : Endif

    GOK = 1
    Call DEBTRANS From GLOCK
    Trbegin [ARM]
    Delete [ARM] Where RPTCOD = REPORTCODE & USR = GUSER # and CREDAT = date$
    If fstat=1
        GOK = 0
        Rollback: End
    Endif

    Commit
    Close Local File [ARM]

End

