#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(250)(1..2) , VALEUR(250)
PARAM(1) = "01  -502"
Call TRAITE_CHAR(VALEUR,PARAM,"","ADATREL","ADATREL",3,"") From GTRAITE
Infbox num$(VALEUR)-string$(VALEUR<>"",num$(evalue(VALEUR)))
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Mask ADATREL
If PARAM(1)=""
 PARAM(1) = "01000001"
Endif
[M]DATDEP = val(left$(PARAM(1),2))
If [M]DATDEP=func FORMULE
 [M]DATFRM = right$(PARAM(1),3)
 Affzo DATDEP,DATFRM
Else
 [M]DATNBR = val(vireblc(seg$(PARAM(1),3,6),2))
 [M]DATJRS = max(1,val(right$(PARAM(1),7)))
 Affzo DATDEP,DATNBR,DATJRS
Endif
[M]DATTST = datesyst
[M]DATRES = func CALDAT([M]DATTST,[M]DATDEP,[M]DATNBR,[M]DATJRS,[M]DATFRM)
Affzo DATTST,DATRES
Return

$EXEC
If [M]DATDEP=func ABSOLU
 PARAM(1) = ""
Else
 PARAM(1) = format$("N0:##",[M]DATDEP)
 If [M]DATDEP=func FORMULE
  PARAM(1) += [M]DATFRM
 Else
  PARAM(1) += format$("N:4#",[M]DATNBR)+format$("N0:##",[M]DATJRS)
 Endif
Endif
Case type(VALEUR)
 When 3
  VALEUR = [M]DATRES
 When Default
  Case [M]DATDEP
   When  1 : VALEUR = "date$"
   When  2 : VALEUR = "gdat$(1,month(date$),year(date$))"
   When  3 : VALEUR = "eomonth(date$)"
   When  4 : VALEUR = "gdat$(1,1,year(date$))"
   When  5 : VALEUR = "gdat$(31,12,year(date$))"
   When  6 : VALEUR = "gdat$(1,3*int((month(date$)-1)/3)+1,year(date$))"
   When  7 : VALEUR = "eomonth(gdat$(1,3*int((month(date$)-1)/3)+3,year(date$)))"
   When  8 : VALEUR = "aweek(week(date$),year(date$))"
   When  9 : VALEUR = "aweek(week(date$),year(date$))+6"
   When 10 : VALEUR = "gdat$(1+15*(day(date$)>=16),month(date$),year(date$))"
   When 11 : VALEUR = "min(eomonth(date$),gdat$(15+16*(day(date$)>=16),month(date$),year(date$)))"
   When 12 : VALEUR = "gdat$(1+10*(day(date$)>=11)+10*(day(date$)>=21),month(date$),year(date$))"
   When 13 : VALEUR = "min(eomonth(date$),gdat$(10+10*(day(date$)>=11)+11*(day(date$)>=21),month(date$),year(date$)))"
   When 14 : VALEUR = [M]DATFRM
  Endcase
  If [M]DATNBR<>0
   Case [M]DATJRS
    When  1 : VALEUR += vireblc(format$("N-:7F",[M]DATNBR),2)
    When  2 : VALEUR += vireblc(format$("N-:7F",[M]DATNBR),2)+"*7"
    When  3 : VALEUR  = "addmonth("+VALEUR+","+num$([M]DATNBR)+")"
    When  4 : VALEUR  = "addmonth("+VALEUR+","+num$(12*[M]DATNBR)+")"
   Endcase
  Endif
Endcase
GUPDDATREL = 1
Return

######################################################################################
## Ecran ADATREL
######################################################################################
Subprog C_DATDEP(VALEUR)
Variable Integer VALEUR
If VALEUR=func ABSOLU
 Chgfmt DATFRM With "-K:250X"
 Effzo DATNBR,DATJRS
 Grizo DATNBR,DATJRS
 [M]DATRES = [M]DATTST
 Affzo DATRES
Elsif VALEUR<>func FORMULE
 Chgfmt DATFRM With "-K:250X"
 Actzo DATNBR,DATJRS
Else
 Chgfmt DATFRM With "K:250X"
 Effzo DATNBR,DATJRS
 Grizo DATNBR,DATJRS
 If [M]DATFRM=""
  [M]DATFRM = "date$"
 Endif
Endif
End

Subprog AS_DATDEP(VALEUR)
Variable Integer VALEUR
If VALEUR<>func FORMULE
 Chgfmt DATFRM With "-K:250X"
 Actzo DATNBR,DATJRS
Else
 Chgfmt DATFRM With "K:250X"
 Effzo DATNBR,DATJRS
 Grizo DATNBR,DATJRS
Endif
End

Subprog C_DATJRS(VALEUR)
Variable Integer VALEUR
[M]DATRES = func CALDAT([M]DATTST,[M]DATDEP,[M]DATNBR,VALEUR,[M]DATFRM)
Affzo DATRES
End

Subprog C_DATFRM(VALEUR)
Variable Char    VALEUR()
[M]DATRES = func CALDAT([M]DATTST,[M]DATDEP,[M]DATNBR,[M]DATJRS,VALEUR)
Affzo DATRES
End

Subprog C_DATTST(VALEUR)
Variable Date    VALEUR
If [M]DATDEP=func ABSOLU
 [M]DATRES = VALEUR
Else
 [M]DATRES = func CALDAT(VALEUR,[M]DATDEP,[M]DATNBR,[M]DATJRS,[M]DATFRM)
Endif
Affzo DATRES
End

######################################################################################
Funprog CALDAT(DATORG,OPER,NOMBRE,TYP,FORMULE)
Value    Date    DATORG
Value    Integer OPER
Value    Integer NOMBRE
Value    Integer TYP
Value    Char    FORMULE
Local Date    DAT
Local Integer I

Case OPER
 When  1 : DAT = DATORG
 When  2 : DAT = gdat$(1,month(DATORG),year(DATORG))
 When  3 : DAT = eomonth(DATORG)
 When  4 : DAT = gdat$(1,1,year(DATORG))
 When  5 : DAT = gdat$(31,12,year(DATORG))
 When  6 : DAT = gdat$(1,3*int((month(DATORG)-1)/3)+1,year(DATORG))
 When  7 : DAT = eomonth(gdat$(1,3*int((month(DATORG)-1)/3)+3,year(DATORG)))
 When  8 : DAT = aweek(week(DATORG),year(DATORG))
 When  9 : DAT = aweek(week(DATORG),year(DATORG))+6
 When 10 : DAT = gdat$(1+15*(day(DATORG)>=16),month(DATORG),year(DATORG))
 When 11 : If day(DATORG)>=16
            DAT = eomonth(DATORG)
           Else
            DAT = gdat$(15,month(DATORG),year(DATORG))
           Endif
 When 12 : DAT = gdat$(1+10*(day(DATORG)>=11)+10*(day(DATORG)>=21),month(DATORG),year(DATORG))
 When 13 : If day(DATORG)>=21
            DAT = eomonth(DATORG)
           Elsif day(DATORG)>=11
            DAT = gdat$(20,month(DATORG),year(DATORG))
           Else
            DAT = gdat$(10,month(DATORG),year(DATORG))
           Endif
 When 14 : Repeat
            I = instr(1,FORMULE,"date$")
            If I
             FORMULE = left$(FORMULE,I-1)+"["+format$(GFMD,DATORG)+"]"+right$(FORMULE,I+5)
            Else
             I = instr(1,FORMULE,"datesyst")
             If I
              FORMULE = left$(FORMULE,I-1)+"["+format$(GFMD,DATORG)+"]"+right$(FORMULE,I+8)
             Endif
            Endif
           Until I=0
           Onerrgo RIEN
           DAT = DATORG
           DAT = evalue(FORMULE)
           Onerrgo
           TYP = 0
 When Default
           DAT = DATORG
Endcase
Case TYP
 When  1 : DAT += NOMBRE
 When  2 : DAT += 7*NOMBRE
 When  3 : DAT = addmonth(DAT,NOMBRE)
 When  4 : DAT = gdat$(day(DAT),month(DAT),year(DAT)+NOMBRE)
Endcase
End DAT

Funprog FORMULE
End 14

Funprog ABSOLU
End 15

$RIEN
Resume

##################################################
Subprog INIDAT(AZCDAT,FORMULE)
Variable Date    AZCDAT
Variable Char    FORMULE()
If FORMULE<>""
 AZCDAT = func CALDAT(datesyst,val(left$(FORMULE,2)),val(vireblc(seg$(FORMULE,3,6),2)),val(right$(FORMULE,7)),right$(FORMULE,3))
# Diszo =zoncou
Else
# Actzo =zoncou
Endif
Global Integer GUPDDATREL
GUPDDATREL = 0
End


##################################################
Subprog MODIFDAT(AZCDAT,FORMULE)
Variable Date    AZCDAT
Variable Char    FORMULE()
If dim(GUPDDATREL)<1 or !GUPDDATREL
 FORMULE = ""
Endif
If dim(GUPDDATREL)>0
 Kill GUPDDATREL
Endif
End

