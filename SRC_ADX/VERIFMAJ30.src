#<AdxTL>@(#)7.0.0.0 $Revision$
Local Integer OK
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "X3BUG"
If !fstat
 Call VERIF(OK)
Endif
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
##################################################################################
# VERIFMAJ30 : Vérification à effectuer avant le passage à la version V6 (BERYL)
##################################################################################

Subprog VERIF(OK)
Variable Integer OK

OK=1
#-------------------------------------#
#       Avant validation dossier      #
#-------------------------------------#
Onerrgo ERREUR

Call ECR_TRACE("************** VERIFMAJ30 ***************",-1) From GESECRAN

Local Char WDOSSIER
WDOSSIER=[F:ADS]DOSSIER

# Vérification stocks
If [F:ADS]MODULE(6)=2
   Gosub VERIF_STO
Endif

# Vérification GP
If [F:ADS]MODULE(7)=2
   Gosub VERIF_GPA
Endif

# Vérification ventes
If [F:ADS]MODULE(4)=2
   Gosub VERIF_VEN
Endif

# Vérification achats
If [F:ADS]MODULE(5)=2
   Gosub VERIF_ACH
Endif

# Vérification Tronc commun
If [F:ADS]MODULE(8)=2
   Gosub VERIF_TRC
   Gosub VERIF_CPT2
Endif

# Vérification Comptabilité/Tiers
If [F:ADS]MODULE(2)=2
   Gosub VERIF_CPT
Endif

Onerrgo
End

###################################################################################
###################################################################################
###################################################################################

$VERIF_STO

Return

###################################################################################
###################################################################################
###################################################################################
$VERIF_GPA

Return

###################################################################################
###################################################################################
###################################################################################
$VERIF_VEN

Return

###################################################################################
###################################################################################
###################################################################################

$VERIF_ACH

Return

###################################################################################
###################################################################################
###################################################################################
$VERIF_TRC

Return


###################################################################################
###################################################################################
###################################################################################
$VERIF_CPT
If func DOSSUB.ISHISTFOLD(WDOSSIER)=1 : Return : Endif

Local Integer NBENR
# Vérification qu'il n'y a plus de Lettrage en attente.
If (filinfo(filpath("FIL","MTCBATCH","fde",WDOSSIER),0))>0
 Local File =WDOSSIER+".MTCBATCH" [MTB]
 NBENR = nbrecord([MTB])
 If NBENR>0
  # Il y a # enregistrements trouvés
  Call ECR_TRACE(mess(56,123,1)+'="MTCBATCH" ->'-func AFNC.MES(mess(220,115,1),num$(NBENR)),0)  From GESECRAN
  OK = 0
 Endif
 Close Local File [MTB]
Endif
# Vérification qu'il n'y a plus de Pièce comptable en attente.
If (filinfo(filpath("FIL","GACCTMP","fde",WDOSSIER),0))>0
 Local File =WDOSSIER+".GACCTMP" [HAT]
 NBENR = nbrecord([HAT])
 If NBENR>0
  # Il y a # enregistrements trouvés
  Call ECR_TRACE(mess(56,123,1)+'="GACCTMP" ->'-func AFNC.MES(mess(220,115,1),num$(NBENR)),0)  From GESECRAN
  OK = 0
 Endif
 Close Local File [HAT]
Endif
If (filinfo(filpath("FIL","GACIASTMP","fde",WDOSSIER),0))>0
 Local File =WDOSSIER+".GACIASTMP" [HIT]
 NBENR = nbrecord([HIT])
 If NBENR>0
  # Il y a # enregistrements trouvés
  Call ECR_TRACE(mess(56,123,1)+'="GACIASTMP" ->'-func AFNC.MES(mess(220,115,1),num$(NBENR)),0)  From GESECRAN
  OK = 0
 Endif
 Close Local File [HIT]
Endif
Return

$VERIF_CPT2
If func DOSSUB.ISHISTFOLD(WDOSSIER)=1 : Return : Endif

# Ouverture des tables du dossier de copie
Local File =[F:ADS]DOSCOP+".GACM" [RGCM]  # Modèle comptable
Local File =[F:ADS]DOSCOP+".GLED" [RLED]  # Référentiel

Local Char WGCM(GLONADP)
Call PARAM("","MIGGCM",WGCM) From ADOVAL
If WGCM = ""
 # Paramètre non défini
 OK=0 : Call ECR_TRACE("MIGGCM : "-mess(141,105,1),1) From GESECRAN : Goto FIN_VERIF_CPT2
Endif

Read [RGCM]GCM0=WGCM
If fstat
 # Modèle comptable inexistant
 OK=0 : Call ECR_TRACE(WGCM-mess(198,105,1),1) From GESECRAN : Goto FIN_VERIF_CPT2
Endif

If !GSERVEUR
 # Modèle de migration retenu $1$ (de LEG='$2$') - Législation de référence de votre dossier $3$. Poursuivre la migration ?
 OK=2 : Call AVERTIR(func AFNC.MES3(mess(211,105,1),WGCM,[F:RGCM]LEG,[F:ADS]DOSLEG(0)),OK) From GESECRAN
 If OK<>2 : OK=0 : Goto FIN_VERIF_CPT2 : Endif
Else
 # Modèle de migration retenu $1$ (de LEG='$2$') - Législation de référence de votre dossier $3$.
 Call ECR_TRACE(func AFNC.MES3(mess(213,105,1),WGCM,[F:RGCM]LEG,[F:ADS]DOSLEG(0)),-1) From GESECRAN
Endif

# Lecture du modèle comptable du dossier de copie ayant la législation identique.
#Filter [RGCM] Where LEG=[F:ADS]DOSLEG(0)
#Read [RGCM] First
#If fstat
 # Aucun modèle comptable défini pour cette législation
# OK=0 : Call ECR_TRACE(mess(184,105,1),1) From GESECRAN
#Endif

# Initialisation des codes plans des référentiels principaux
Read [RLED]LED0 = [F:RGCM]LED(0)
If fstat
 # Pas de code référentiel saisi pour ce type de référentiel
 OK = 0 : Call ECR_TRACE(mess(97,104,1),1) From GESECRAN
Endif

$FIN_VERIF_CPT2
Close Local File [RGCM],[RLED]
Return

###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
LRET=1
Resume

