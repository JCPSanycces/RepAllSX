#<AdxTL>@(#)11.0.0.0 $Revision$
# Classe EXPENSES
# Représentation EXPENENT & EXPENENTM

###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When "EXS"
    Case [L]AEVENT
         When "AREAD_AFTER"            : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Case CURPRO
 When "EXS.DATEXS"     : Gosub DATEXS
 When "EXS.CODEXP"     : Gosub CODEXP
 When "EXS.FCY"        : Gosub FCY
 When "EXS.CUR"        : Gosub CUR
 When "EXS.AMTATI"     : Gosub AMTATI
 When "EXS.AMTPAY"     : Gosub AMTPAY
 When "EXS.QTY"        : Gosub QTY
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##########################################################################################################
$AREAD_AFTER
Gosub ATTRIBUTE_AMTATI
Gosub ATTRIBUTE_DIMCEN
Gosub ATTRIBUTE_RATEXPENS
Return

##################
$DATEXS
Case [L]ARULE
 When "INIT"    : Gosub DATEXS_INIT
Endcase
Return

$DATEXS_INIT

## Mobility : there is a difference with the initialization of the date
## If no line is entered, the date is initialized with the date of the day,
## otherwise, the date is initialized with the higher date of the entered lines.
Local File EXPENSES [EXS2]
Filter[EXS2] Where CLB=this.ACTX.USER
If rowcount([EXS2])=0
 this.DATEXS = date$
Else
 Read [EXS2]EXS0 Last
 this.DATEXS = [F:EXS2]DATEXS
Endif
Filter [EXS2]
Return


####################################
$CODEXP
Case [L]ARULE
 When "PROPAGATE" : Gosub CODEXP_PROPAGATE
Endcase
Return

$CODEXP_PROPAGATE
Gosub ATTRIBUTE_DIMCEN
Local Integer I
Local File TABEXPENS [TES]
Local File AUTILIS   [AUS]
Local File GACCOUNT  [GAC]
Local File GACCCODE  [CAC]
Local File GLED      [LED]
Read [TES]TES0 = this.CODEXP
If fstat=[V]CST_AOK
 For I=1 To maxtab(this.CODEXPENS)
  If this.CODEXPENS(I)<>null & !find(this.CODEXPENS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
   Read [CAC]CAC0=20;[F:TES]ACCCOD;this.CODEXPENS(I).COA
   If fstat=[V]CST_AOK
    this.CODEXPENS(I).ACC = [F:CAC]ACC(0)
   Else
    this.CODEXPENS(I).ACC = ""
   Endif
  Endif
 Next
 Gosub INIT_CCE From EXPENSES_CSTD
 Call CALCUL_AMTPAY(this.AMTPAY,this) From EXPENSES_CSTD
 Call CALCUL_AMTATI(this.AMTATI,this) From EXPENSES_CSTD
Endif
Return


####################################
$FCY
Case [L]ARULE
 When "PROPAGATE" : Gosub FCY_PROPAGATE
Endcase
Return

$FCY_PROPAGATE
Gosub ATTRIBUTE_RATEXPENS
Local File FACILITY [FCY]
Local File COMPANY  [CPY]
Local File GACM     [GCM]
Local File GLED     [LED]

Read [FCY]FCY0=this.FCY
If fstat<>[V]CST_AOK : Return : Endif

this.CPY = [F:FCY]LEGCPY
Read [CPY]CPY0=this.CPY
If fstat<>[V]CST_AOK : Return : Endif

Gosub LOAD_CODEXPENS From EXPENSES_CSTD

If this.CUR=""
 this.CUR = [F:CPY]ACCCUR
Else
 Gosub LOAD_RATEXPENS From EXPENSES_CSTD
Endif
Return

####################################
$CUR
Case [L]ARULE
 When "PROPAGATE" : Gosub CUR_PROPAGATE
Endcase
Return

$CUR_PROPAGATE
Gosub ATTRIBUTE_RATEXPENS
Local File COMPANY [CPY]
Local File GACM    [GCM]
Gosub LOAD_RATEXPENS From EXPENSES_CSTD
Call CALCUL_AMTPAY(this.AMTPAY,this) From EXPENSES_CSTD
Call CALCUL_AMTATI(this.AMTATI,this) From EXPENSES_CSTD
Return

####################################
$AMTATI
Case [L]ARULE
 When "INIT" : Gosub ATTRIBUTE_AMTATI
Endcase
Return

####################################
$AMTPAY
Case [L]ARULE
 When "PROPAGATE" : Gosub AMTPAY_PROPAGATE
Endcase
Return

$AMTPAY_PROPAGATE
Call CALCUL_AMTATI(this.AMTATI,this) From EXPENSES_CSTD
Return

####################################
$QTY
Case [L]ARULE
 When "PROPAGATE" : Gosub QTY_PROPAGATE
Endcase
Return

$QTY_PROPAGATE
Call CALCUL_AMTPAY(this.AMTPAY,this) From EXPENSES_CSTD
Call CALCUL_AMTATI(this.AMTATI,this) From EXPENSES_CSTD
Return


##########################################################################################################
## Set the Readonly attribute on the RATDIV2 and RATMLT2 properties of RATEXPENS collection
##########################################################################################################
$ATTRIBUTE_RATEXPENS
Local File COMPANY [CPY]
Local File GACM    [GCM]
Local Integer J, K , NUMCUR
Read [CPY]CPY0=this.CPY
If !fstat
 Read [GCM]GCM0=[F:CPY]ACM
Endif
For J=1 To len(mess(0,2644,1))
 # ledger currency <> expense currency
 If [F:GCM]LED(J-1)<>"" & [F:GCM]CUR(J-1)<>this.CUR
  ASTATUS = fmet this.RATEXPENS(this.LNKRATLED(J).LIGLED).ASETATTRIBUTE('RATDIV2','$isReadOnly','false')
  ASTATUS = fmet this.RATEXPENS(this.LNKRATLED(J).LIGLED).ASETATTRIBUTE('RATMLT2','$isReadOnly','false')
  Case [F:GCM]DACRAT(J-1)
    When 1 : # Multiplicateur
     ASTATUS = fmet this.RATEXPENS(this.LNKRATLED(J).LIGLED).ASETATTRIBUTE('RATDIV2','$isReadOnly','true')
    When 2 : # Diviseur
     ASTATUS = fmet this.RATEXPENS(this.LNKRATLED(J).LIGLED).ASETATTRIBUTE('RATMLT2','$isReadOnly','true')
  Endcase
 Endif
Next
Return

##########################################################################################################
## Set the Readonly attribute on the CCE properties of DIMCEN collection
##########################################################################################################
$ATTRIBUTE_DIMCEN
Local File TABEXPENS [TES]
Local File GACCOUNT  [GAC]
Local Integer I,J, RES1
Read [TES]TES0 = this.CODEXP
If fstat=[V]CST_AOK
 For J=1 To maxtab(this.DIMCEN)
  If !find(this.DIMCEN(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.DIMCEN(J).DIE<>""
   ASTATUS = fmet this.DIMCEN(J).ASETATTRIBUTE('CCE','$isReadOnly','true')
   For I=1 To maxtab(this.CODEXPENS)
    If !find(this.CODEXPENS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.CODEXPENS(I).LED<>""
     Read [GAC]GAC0=this.CODEXPENS(I).COA;this.CODEXPENS(I).ACC
     If find(this.DIMCEN(J).DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      RES1 = find(this.DIMCEN(J).DIE,[F:TES]DIE(0..dim([F:TES]DIE)-1))
      If !RES1 | [F:TES]CCEFLG(RES1-1)<>1
       ASTATUS = fmet this.DIMCEN(J).ASETATTRIBUTE('CCE','$isReadOnly','false')
      Endif
      Break
     Endif
    Endif
   Next
  Endif
 Next
Endif
Return


##########################################################################################################
## Set the Readonly attribute on the AMTATI property if the user doesn't have the functional authorization
##########################################################################################################
$ATTRIBUTE_AMTATI
If func EXPENSES_CSTD.NOUPD_AMTATI
 ASTATUS = fmet this.ASETATTRIBUTE('AMTATI','$isReadOnly','true')
Endif
Return

