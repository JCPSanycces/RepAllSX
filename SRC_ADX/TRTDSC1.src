#<AdxTL>@(#)8.0.0.0 $Revision$
############################################################################################################
#   Traitement de gestion du dispatching Help-Desk                Module CRM                  3 octobre 2000
############################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GIDSC1HBDISP
Global Integer GDSCNOL
Global Char GDSCKEY

  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif     : # FGR 28/04/2009 : X3SUIVIyyyyy : pour report V5
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  GIDSC1HBDISP = 0
  GDSCNOL = 0
  GDSCKEY = ""
  #Initialisation de la navigation désordonnées
  NAVIG = "FUNDSC1"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Définition du site par défaut.
  Read [AUS]CODUSR=GUSER
  If fstat Then
    GIDSC1HBDISP = 0
    Return
  Endif
  [M:DSC1]DSCFCY = func CRM_UTIL.GET_SITE_DEFAUT ("HDK", "")
  Gosub LOADDISP
  If [M:DSC1]NBSRE > 0 Then
    GDSCKEY = [M:DSC1]DSCNUM(0)
  Endif
  GIDSC1HBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIDSC1HBDISP Then
    #Nettoie l'écran avant de partir.
    Raz [M:DSC1]
  Endif
  Kill GIDSC1HBDISP
  Kill GDSCNOL
  Kill GDSCKEY
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
##########################################################################################################
$LOADDISP
Local Char LIBENCLAIR
Local Integer I
Local Integer IALDONE

  LIBENCLAIR = ""
  I = 0
  #Définition du filtre
  If [M:DSC1]DSCFCY = "" Then
    Filter [SRE] Where [F:SRE]SREASS = 1 Order By [F:SRE]CREDAT
    IALDONE = 1
  Else
    Filter [SRE] Where [F:SRE]SREASS = 1 and [F:SRE]SREDET = [M:DSC1]DSCFCY Order By [F:SRE]CREDAT
    IALDONE = 0
  Endif
  #Remplit le tableau
  For [SRE]
    [M:DSC1]DSCCREHOU(I) = [F:SRE]CREHOU
    [M:DSC1]DSCRESHOU(I) = [F:SRE]SRERESHOU
    [M:DSC1]DSCSAT(I) = [F:SRE]SRESAT
    Call GET_LIB(422, [F:SRE]SRESAT, LIBENCLAIR) From CRM_UTIL
    [M:DSC1]DSCSATCLA(I) = LIBENCLAIR
    [M:DSC1]DSCGRALEV(I) = [F:SRE]SREGRALEV
    Call GET_LIB(428, [F:SRE]SREGRALEV, LIBENCLAIR) From CRM_UTIL
    [M:DSC1]DSCGRACLA(I) = LIBENCLAIR
    [M:DSC1]DSCDATOPG(I) = [F:SRE]CREDAT
    [M:DSC1]DSCRESDAT(I) = [F:SRE]SRERESDAT
    If [F:SRE]SREBPC = "" Then
      Read [AIN]AIN0=[F:SRE]SRECCN
      If fstat Then
        [M:DSC1]DSCCMP(I) = [F:SRE]SRECCN
      Else
        Call BUILDFULNAM("AIN", [M:DSC1]DSCCMP(I)) From CRMUTIL140
      Endif
      [M:DSC1]DSCCMPX(I) = ""
      [M:DSC1]DSCCCNX(I) = [F:SRE]SRECCN
    Else
      Read [BPR]BPR0=[F:SRE]SREBPC
      If fstat Then
        [M:DSC1]DSCCMP(I) = [F:SRE]SREBPC
      Else
        [M:DSC1]DSCCMP(I) = [F:BPR]BPRNAM
      Endif
      [M:DSC1]DSCCMPX(I) = [F:SRE]SREBPC
      [M:DSC1]DSCCCNX(I) = ""
    Endif
    [M:DSC1]DSCTTR(I) = [F:SRE]SRETTR
    #Affichage du parc par défaut
    If [F:SRE]SREMAC = "" Then
      [M:DSC1]DSCMACDES(I) = ""
    Else
      Read [MAC]MAC0=[F:SRE]SREMAC
      If fstat Then
        [M:DSC1]DSCMACDES(I) = ""
      Else
        #Call LECTEXTRA([M:DSC1]DSCMACDES(I), "ITMMASTER", "DES1AXX", [F:MAC]MACPDTCOD, "") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MAC]MACPDTCOD,[M:DSC1]DSCMACDES(I), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      Endif
    Endif
    #Famille de compétence globale
    If [F:SRE]SREPBLGRP <> "" Then
      Read [PBL]PBL0=[F:SRE]SREPBLGRP
      If fstat Then
        [M:DSC1]DSCPBLGRP(I) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:DSC1]DSCPBLGRP(I) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:DSC1]DSCPBLGRP(I),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Else
      [M:DSC1]DSCPBLGRP(I) = ""
    Endif
    [M:DSC1]DSCCOV(I) = [F:SRE]OVRCOV
    [M:DSC1]DSCESC(I) = [F:SRE]SREESC
    [M:DSC1]DSCNUM(I) = [F:SRE]SRENUM
    [M:DSC1]DSCNUMBPC(I) = [F:SRE]SRENUMBPC
    I += 1
  Next
  Filter [SRE]
  If I = 0 and IALDONE = 0 Then
    I = 0
    Filter [SRE] Where [F:SRE]SREASS = 1
    For [SRE]SRE1
      [M:DSC1]DSCCREHOU(I) = [F:SRE]CREHOU
      [M:DSC1]DSCRESHOU(I) = [F:SRE]SRERESHOU
      [M:DSC1]DSCSAT(I) = [F:SRE]SRESAT
      Call GET_LIB(422, [F:SRE]SRESAT, LIBENCLAIR) From CRM_UTIL
      [M:DSC1]DSCSATCLA(I) = LIBENCLAIR
      [M:DSC1]DSCGRALEV(I) = [F:SRE]SREGRALEV
      Call GET_LIB(428, [F:SRE]SREGRALEV, LIBENCLAIR) From CRM_UTIL
      [M:DSC1]DSCGRACLA(I) = LIBENCLAIR
      [M:DSC1]DSCDATOPG(I) = [F:SRE]CREDAT
      [M:DSC1]DSCRESDAT(I) = [F:SRE]SRERESDAT
      If [F:SRE]SREBPC = "" Then
        Read [AIN]AIN0=[F:SRE]SRECCN
        If fstat Then
          [M:DSC1]DSCCMP(I) = [F:SRE]SRECCN
        Else
          Call BUILDFULNAM("AIN", [M:DSC1]DSCCMP(I)) From CRMUTIL140
        Endif
        [M:DSC1]DSCCMPX(I) = ""
        [M:DSC1]DSCCCNX(I) = [F:SRE]SRECCN
      Else
        Read [BPR]BPR0=[F:SRE]SREBPC
        If fstat Then
          [M:DSC1]DSCCMP(I) = [F:SRE]SREBPC
        Else
          [M:DSC1]DSCCMP(I) = [F:BPR]BPRNAM
        Endif
        [M:DSC1]DSCCMPX(I) = [F:SRE]SREBPC
        [M:DSC1]DSCCCNX(I) = ""
      Endif
      [M:DSC1]DSCTTR(I) = [F:SRE]SRETTR
      #Affichage du parc par défaut
      If [F:SRE]SREMAC = "" Then
        [M:DSC1]DSCMACDES(I) = ""
      Else
        Read [MAC]MAC0=[F:SRE]SREMAC
        If fstat Then
          [M:DSC1]DSCMACDES(I) = ""
        Else
          #Call LECTEXTRA([M:DSC1]DSCMACDES(I), "ITMMASTER", "DES1AXX", [F:MAC]MACPDTCOD, "") From ATEXTRA
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:MAC]MACPDTCOD,[M:DSC1]DSCMACDES(I), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
        Endif
      Endif
      #Famille de compétence globale
      If [F:SRE]SREPBLGRP <> "" Then
        Read [PBL]PBL0=[F:SRE]SREPBLGRP
        If fstat Then
          [M:DSC1]DSCPBLGRP(I) = ""
        Else
          # FGR 23/09/2009 : X3SUIVI58024
          #[M:DSC1]DSCPBLGRP(I) = [F:PBL]GRPPBLDES
          Call LECTEXTRA([M:DSC1]DSCPBLGRP(I),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
        Endif
      Else
        [M:DSC1]DSCPBLGRP(I) = ""
      Endif
      [M:DSC1]DSCCOV(I) = [F:SRE]OVRCOV
      [M:DSC1]DSCESC(I) = [F:SRE]SREESC
      [M:DSC1]DSCNUM(I) = [F:SRE]SRENUM
      [M:DSC1]DSCNUMBPC(I) = [F:SRE]SRENUMBPC
      I += 1
    Next
    Filter [SRE]
    [M:DSC1]DSCFCY = ""
  Endif
  If I = 0 Then
    GMESSAGE = mess(321,196,1)  #Il n' y a aucune demande de service en attente de Dispatching.
    GERR = 2
    FIN = 1
    Return
  Endif
  [M:DSC1]NBSRE = I
  I = 0
  Affzo [M:DSC1]
Return

#################################################################
# Réinitialisation du tableau des demandes de service
#################################################################
##########################################################################################################
$RAZDSC1
  Raz [M:DSC1]NBSRE
  Raz [M:DSC1]DSCTTR
  Raz [M:DSC1]DSCCMP
  Raz [M:DSC1]DSCDATOPG
  Raz [M:DSC1]DSCSAT
  Raz [M:DSC1]DSCRESDAT
  Raz [M:DSC1]DSCMACDES
  Raz [M:DSC1]DSCPBLGRP
  Raz [M:DSC1]DSCCOV
  Raz [M:DSC1]DSCCREHOU
  Raz [M:DSC1]DSCSATCLA
  Raz [M:DSC1]DSCGRACLA
  Raz [M:DSC1]DSCGRALEV
  Raz [M:DSC1]DSCRESHOU
  Raz [M:DSC1]DSCESC
  Raz [M:DSC1]DSCNUM
  Raz [M:DSC1]DSCNUMBPC
  Raz [M:DSC1]DSCCMPX
  Raz [M:DSC1]DSCCCNX
Return
