#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################################
# FUNPURTRS : Contient                                          MBT 30/10/98 #
#     - Le S/P de validation des transactions de saisie des achats           #
#     - Le traitement permettant de lancer manuellemnt le S/P de validation  #
##############################################################################
Local Integer OK
Local File   AMSK    [AMK]
Local File   AWINDOW [AWI]
Local File   PURTRS  [PTR]
Local Mask   PURTRS  [DIA] : Raz [M:DIA]
Call DIALWIN(OK,mess(100,196,1),"IPURTRS") From GESECRAN
If OK=2
  Call OUVRE_TRACE(mess(100,196,1)-[M]LIB-[M]PTRNUM) From LECFIC
  Call VAL_PURTRS([M]PTRTYP,[M]PTRNUM,nomap)
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Close Local File [PTR]
Close Local Mask [DIA]
End


#-------------------------------------------#
# Actions sur champ de l'écran PURTRS [DIA] #
#-------------------------------------------#
Subprog AV_LIB(VALEUR)
Variable Char    VALEUR()
If [M]PTRTYP>0 & [M]PTRTYP<9
  VALEUR=mess([M]PTRTYP,517,1)
Else
  VALEUR=mess(19,197,1)
Endif
End

Subprog AV_PTRDES(VALEUR)
Variable Char    VALEUR()
If [M]PTRNUM<>"" & [M]PTRTYP>0 & [M]PTRTYP<9
  Read [PTR] PTR0=[M]PTRTYP;[M]PTRNUM : If fstat Raz [F:PTR] : Endif
  VALEUR=[F:PTR]PTRDES
Endif
End


##################################################################################
# Traitement appelé par SUBPTA, SUBPTD, SUBPTC, SUBPTT, SUBPTR, SUBPTN et SUBPTF #
##################################################################################
$GENDOS
#----- Variable locales -----#
Local Char    FENETRE(GLONFEN)(0..2)
Local Char    ECRAN  (GLONAMK)(0..10)
Local Integer I, TOK(1..10)
#-----
Local File =APPLI+".PURTRS"    [PTR]
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]
#-----
Raz TOK
If TYP=0
  For I=1 To 10 : TOK(I)=1 : Next I
Elsif dim(GVALTRANS)>5 & GVALTRANS(6)=2
  TOK(TYP)=1
Else
  Raz FENETRE, ECRAN
  Case TYP
    When 1 : #----- Appels d'offre
      FENETRE(0)="OPQH"
      ECRAN  (0)="PQH1"
    When 2 : #----- Demandes d'achat
      FENETRE(0)="OPSH"
      ECRAN  (0)="PSH0" : ECRAN  (1)="PSH1" # Issue 119814 - 2016-11-18 by SR
    When 3 : #----- Commandes classiques
      FENETRE(0)="OPOH" : FENETRE(1)="OPOI"
      ECRAN  (0)="POH1" : ECRAN(1)="POH2" : ECRAN(2)="POH3" : ECRAN(3)="POI1"
    When 5 : #----- Commandes ouvertes
      FENETRE(0)="OPOC"
      ECRAN  (0)="POC0" : ECRAN(1)="POC1" : ECRAN(2)="POC2" : ECRAN(3)="POC3"
    When 6 : #----- Réceptions d'achat
      FENETRE(0)="OPTH"
      ECRAN  (0)="PTH0" : ECRAN  (1)="PTH1" : ECRAN(2)="PTH2" : ECRAN(3)="PTHPSTT" : # Issue 119814 - 2016-11-18 by SR
    When 7 : #----- Retours fournisseurs
      FENETRE(0)="OPNH"
      ECRAN  (0)="PNH1"
    When 8 : #----- Factures d'achat
      FENETRE(0)="OPIH"
      ECRAN  (0)="PIH0" : ECRAN(1)="PIH1" : ECRAN(2)="PIH2" : ECRAN(3)="PIH3"
      ECRAN  (4)="PIH4"
    When 9 : #----- Ordres de sous-traitance
      FENETRE(0)="OSCO"
      ECRAN  (0)="SCO0" : ECRAN(1)="SCO1" : ECRAN(2)="SCO2" : ECRAN(3)="SCO3"
  Endcase
  Raz I
  While FENETRE(I)<>"" & I<2
    Read [AWI] AWI0=FENETRE(I) : If fstat Raz [F:AWI] : Endif
    If [F:AWI]UPDFLG=1  TOK(TYP)=1 : Break : Endif
    I+=1
  Wend
  If TOK(TYP)<>1
    Raz I
    While ECRAN(I)<>"" & I<10
      Read [AMK] CODMSK=ECRAN(I) : If fstat Raz [F:AMK] : Endif
      If [F:AMK]UPDFLG=1  TOK(TYP)=1 : Break : Endif
      I+=1
    Wend
  Endif
Endif
#----- Appels des validations de transaction -----#
If sum(TOK(1..10))>6
  Call VAL_PURTRS(0,"",APPLI) From FUNPURTRS
Else
  If TOK(1)=1 Call VAL_PURTRS(1,"",APPLI) From FUNPURTRS : Endif
  If TOK(2)=1 Call VAL_PURTRS(2,"",APPLI) From FUNPURTRS : Endif
  If TOK(3)=1 Call VAL_PURTRS(3,"",APPLI) From FUNPURTRS : Endif
  If TOK(5)=1 Call VAL_PURTRS(5,"",APPLI) From FUNPURTRS : Endif
  If TOK(6)=1 Call VAL_PURTRS(6,"",APPLI) From FUNPURTRS : Endif
  If TOK(7)=1 Call VAL_PURTRS(7,"",APPLI) From FUNPURTRS : Endif
  If TOK(8)=1 Call VAL_PURTRS(8,"",APPLI) From FUNPURTRS : Endif
  If TOK(9)=1 Call VAL_PURTRS(9,"",APPLI) From FUNPURTRS : Endif
Endif
Return


#########################################################################################
# Traitement appelé par SUBPTA, SUBPTD, SUBPTC, SUBPTT, SUBPTR, SUBPTN SUBPTF et SUBPTE #
#########################################################################################
$GENPATCH
Local File =APPLI+".PURTRS"    [PTR]
Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]
Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]
Local File =APPLI+".ATYPE"     [ATY]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".ATEXTE"    [ATX]
Local File =APPLI+".ATABTAB"   [ADV]
Call VAL_PURTRS(TYP,"",APPLI) From FUNPURTRS
Return


##############################################################################
# VAL_PURTRS : S/P Validation en masse des transactions de saisie des achats #
# -------------------------------------------------------------------------- #
# Subprog VAL_PURTRS (TYP,NUM,APPLI)                                         #
#    TYP  : Type des transactions à valider (1n)                             #
#           0 = Toutes                                                       #
#           1 = Appels d'offre                                               #
#           2 = Demandes d'achat                                             #
#           3 = Commandes standards                                          #
#           4 =                                                              #
#           5 = Commandes ouvertes                                           #
#           6 = Réceptions fournisseurs                                      #
#           7 = Retours fournisseurs                                         #
#           8 = Factures/Avoirs                                              #
#           9 = Ordres de sous-traitance                                     #
#    NUM  : Code de la transaction à valider (5c)                            #
#           "" = Toutes                                                      #
#    APPLI: Nom de l'application à mettre à jour                             #
# -------------------------------------------------------------------------- #
# Table à partir de laquelle la validation est effectuée :                   #
#          [F:PTR]PURTRS   Table des transactions                            #
# Le fichier trace doit être ouvert avant l'appel du sous-programme          #
##############################################################################
Subprog VAL_PURTRS(TYP,NUM,APPLI)
Value  Integer  TYP
Value  Char     NUM
Value  Char     APPLI
#-----
Local  Integer  WTYP, OK, IMA
Local  Char     ACTION(20), CRITERES(30)
Local Char      WDIE_ABRFIC(3)  : WDIE_ABRFIC="PTR"
Local Integer   WDIE_DTRTYP
Local Char      WNOM_TRTFEN(GLONADC+20), WNOM_TRTSUB(GLONADC)
Local Char      WFONCTION : # Issue 79671 - 2012-01-30 by VPO : modif GFONCTION
#-----
ACTION="MASSE"
Case TYP
  When 0 : CRITERES="1=1"
  When 1 : CRITERES="PTRTYP=1"
  When 2 : CRITERES="PTRTYP=2"
  When 3 : CRITERES="PTRTYP=3"
  When 5 : CRITERES="PTRTYP=5"
  When 6 : CRITERES="PTRTYP=6"
  When 7 : CRITERES="PTRTYP=7"
  When 8 : CRITERES="PTRTYP=8"
  When 9 : CRITERES="PTRTYP=9"
  When Default : CRITERES=""
Endcase
If NUM<>"" & CRITERES<>"" CRITERES+=" & PTRNUM=NUM" : Endif
If clalev([F:PTR])<=0 Local File =APPLI+".PURTRS" [PTR] : Endif
WFONCTION=GFONCTION : # Issue 79671 - 2012-01-30 by VPO : modif GFONCTION
For [PTR] Where evalue(CRITERES)
  If [F:PTR]PTRTYP<>WTYP
    If WNOM_TRTFEN<>""
      Gosub FERME_MASK From =WNOM_TRTFEN : Raz WNOM_TRTFEN
    Endif
    # Issue 79671 - 2012-01-30 by VPO : modif GFONCTION
    Case [F:PTR]PTRTYP
      When 1 : WNOM_TRTFEN=APPLI+".WGOPTA" : WNOM_TRTSUB="SUBPTA"  : GFONCTION="GESPTA"
      When 2 : WNOM_TRTFEN=APPLI+".WGOPTD" : WNOM_TRTSUB="SUBPTD"  : GFONCTION="GESPTD"
      When 3 : WNOM_TRTFEN=APPLI+".WGOPTC" : WNOM_TRTSUB="SUBPTC"  : GFONCTION="GESPTC"
      When 5 : WNOM_TRTFEN=APPLI+".WGOPTT" : WNOM_TRTSUB="SUBPTT"  : GFONCTION="GESPTT"
      When 6 : WNOM_TRTFEN=APPLI+".WGOPTR" : WNOM_TRTSUB="SUBPTR"  : GFONCTION="GESPTR"
      When 7 : WNOM_TRTFEN=APPLI+".WGOPTN" : WNOM_TRTSUB="SUBPTN"  : GFONCTION="GESPTN"
      When 8 : WNOM_TRTFEN=APPLI+".WGOPTF" : WNOM_TRTSUB="SUBPTF"  : GFONCTION="GESPTF"
      When 9 : WNOM_TRTFEN=APPLI+".WGOPTE" : WNOM_TRTSUB="SUBPTE"  : GFONCTION="GESPTE"
    Endcase

    # Issue 79689 - 2012-01-27 by VPO : report modif de ccora
    #     Ajout du test d'existence du programme fenêtre
    If WNOM_TRTFEN<>"" and WNOM_TRTSUB<>""
      Local Integer OKTRT
      Call EXISTE_ADX("",APPLI,"WG"+right$(WNOM_TRTSUB,4),OKTRT) From ORDSYS
      If OKTRT<=0
        If dim(GVALIDDIFF)>0 & GVALIDDIFF=3
          GVALIDDIFF=1
          Call VALID("O"+right$(WNOM_TRTSUB,4),APPLI,0,OKTRT) From VALWIN
          GVALIDDIFF=3
        Else
          Call VALID("O"+right$(WNOM_TRTSUB,4),APPLI,0,OKTRT) From VALWIN
        Endif
      Endif
    Endif

    If WNOM_TRTFEN<>""
      Gosub DEFVAR From =WNOM_TRTFEN
      For IMA=0 To NBMASK
        Local Mask =APPLI+"."+NOMMSK(IMA)
      Next IMA
    Endif
    WTYP=[F:PTR]PTRTYP
  Endif
  If WNOM_TRTFEN<>""
    WDIE_DTRTYP=[F:PTR]PTRTYP
    ACTION="OUVRE" : Gosub TRT_DIETRS From SUBDST
    Call DEBTRANS From GLOCK
    nolign=1
    Trbegin [PTR]
    For IMA=0 To NBMASK
      Gosub CHARGEMSK From =WNOM_TRTFEN
    Next IMA
    ACTION="LIENS" : Gosub ACTION     From =WNOM_TRTSUB
    ACTION="MASSE" : Gosub TRT_ECRAN  From =WNOM_TRTSUB
    If GOK<1
      Call ECR_TRACE(mess(21,123,1)-mess([F:PTR]PTRTYP,517,1)-[F:PTR]PTRNUM,1) From GESECRAN
      Rollback
    Else
      Call ECR_TRACE(mess(14,123,1)-mess([F:PTR]PTRTYP,517,1)-[F:PTR]PTRNUM,0) From GESECRAN
      Commit
    Endif
  Endif
Next
GFONCTION=WFONCTION : # Issue 79671 - 2012-01-30 by VPO : modif GFONCTION
If WNOM_TRTFEN<>""
  Gosub FERME_MASK From =WNOM_TRTFEN : Raz WNOM_TRTFEN
Endif
End

