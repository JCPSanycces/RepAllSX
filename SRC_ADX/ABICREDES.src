#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GBIDC3 ="azer"
Call TRAITE_CHAR(VALEUR,PARAM,"","ABICREUNV","ABICREUNV",3,"") From GTRAITE
End

##################################################################
## Creation du fichier de description
##################################################################
Subprog CRE_DESCRIPTION(APPLI,MACHINE,FICTXT,DATAM,DATAW,HIERACH,HIERACH2,HIERACH3,HIERACH4,NBHIE,UNIVERS,LANBI,EXPR_CLE,EXPR_ID,EXPR_NOM,EXPR_CND1,EXPR_CND2,EXPR_CND3,EXPR_NB,STAT)
Value Char    APPLI
Value Char    MACHINE
Value Char    FICTXT
Value Char    DATAM
Value Char    DATAW
Value Char    HIERACH()
Value Char    HIERACH2()
Value Char    HIERACH3()
Value Char    HIERACH4()
Value Integer NBHIE
Value Char    UNIVERS
Value Char    LANBI
Value Char    EXPR_CLE      : # Condition predefinies
Value Char    EXPR_ID       : # Condition predefinies
Value Char    EXPR_NOM      : # Condition predefinies
Value Char    EXPR_CND1     : # Condition predefinies
Value Char    EXPR_CND2     : # Condition predefinies
Value Char    EXPR_CND3     : # Condition predefinies
Value Integer EXPR_NB       : # Condition predefinies
Variable Integer STAT
Local Integer NUMABM ,I

If !clalev([F:AHH])   : Local File =APPLI+".ABIHIERA"  [AHH]  : Endif


#### ABR univers
Local Char ABRUNV(GLONABR)
Read [ABM]ABM0 = [M:DIA]DATAM
If !fstat
 ABRUNV = [F:ABM]ABR
Endif

#### Ouverture tables
Gosub OUV_TABLES
#### Initialisation variables
Gosub INIT
Read [ABM]ABM0=[L]DATAM
If !fstat
 For NUMABM=0 To [F:ABM]NBRABF-1
  If func AFNC.ACTIV([ABM]ACTABF(NUMABM))= 1
   Gosub JOINTURES
   If KOOBJ : Break : Endif
  Endif
 Next NUMABM
Endif
If KOOBJ
 If GTRACE <> ""
  Call ECR_TRACE(mess(106,148,1)-num$(MAXOBJ),1) From GESECRAN
 Else
  Call ERREUR(mess(106,148,1)-num$(MAXOBJ)) From GESECRAN
 Endif
 STAT = 1
 End
Endif

#### Ouverture , ecriture et fermeture fichier txt
Local Char    IRS(2) , SAVIFS(2) , SAVIRS(2)
Local Integer SAVIUM
IRS = chr$(13)+chr$(10)
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxium = GUCS2
Openo MACHINE+"@"+FICTXT , 0
Wrseq chr$(254*256+255);
Gosub ECRITURE_FICHIER
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

##################################################################
## Liste de dimensions pour les hierachies
##################################################################
Subprog CRE_CLASS_OBJ(APPLI,DATAM,TCLASSE,TSCLASSE,TOBJ,TORD,TABDEF_,CHPDEF_,TABDEF2_,TYPDEF_,NBOBJ2,LANBI,STAT)
Value Char APPLI
Value Char DATAM
Variable Char    TCLASSE()
Variable Char    TSCLASSE()
Variable Char    TOBJ()
Variable Integer  TORD()
Variable Char    TABDEF_()
Variable Char    CHPDEF_()
Variable Char    TABDEF2_()
Variable Char    TYPDEF_()
Variable Integer  NBOBJ2
Value    Char     LANBI
Variable Integer STAT

Local Integer NUMABM
Local Integer NBTCLA
Local Char TSCLASSE2(50)(1..1000)  , TCLASSE2(50)(1..1000)
#### Tableau des conditions
Local Integer  NBCOND : NBCOND = 100
Local Char    EXPR_CND1(250)(0..NBCOND),EXPR_CND2(250)(0..NBCOND),EXPR_CND3(250)(0..NBCOND)
Local Char    EXPR_CLE(80)(0..NBCOND),EXPR_NOM(80)(0..NBCOND),EXPR_ID(80)(0..NBCOND)
Local Integer EXPR_NB,OKCND
Local Char    TEXTE(80) , NOM(80) , INVITE(80) , EXPR2(250)
Local Clbfile EXPR(2)

If !clalev([F:ABM])  : Local File =APPLI+".ABIDATMRT" [ABM]  : Endif

Read [ABM]ABM0 = [L]DATAM
If !fstat
 #### Ouverture tables
 Gosub OUV_TABLES

 #### Initialisation variables
 Gosub INIT

 For NUMABM=0 To [F:ABM]NBRABF-1
  If func AFNC.ACTIV([ABM]ACTABF(NUMABM))= 1
   Gosub JOINTURES
   If KOOBJ : Break : Endif
  Endif
 Next NUMABM

 If KOOBJ
  If GTRACE <> ""
   Call ECR_TRACE(mess(106,148,1)-num$(MAXOBJ),1) From GESECRAN
  Else
   Call ERREUR(mess(106,148,1)-num$(MAXOBJ)) From GESECRAN
  Endif
  STAT = 1
  End
 Endif

 For I=0 To NBCLASSE-1
  NBTCLA +=1
  If !instr(0,CLASSE(I),",")
   CLASSE2= CLASSE(I)
  Endif
 Next I

 For I=0 To NBOBJ-1
  If INFOBJ(I)  = "Dimension" & TABOBJ(I)<> ""
   TCLASSE(NBOBJ2)     =  CLASSE2
   TSCLASSE(NBOBJ2)    =  CLAOBJ(I)
   If CLAOBJ2(I)<> ""
    TOBJ(NBOBJ2)        =  "["+CLAOBJ2(I)+"]"-NOMOBJ(I)
   Else
    TOBJ(NBOBJ2)        =  NOMOBJ(I)
   Endif
   TABDEF_(NBOBJ2)     =  TABDEF(I)
   CHPDEF_(NBOBJ2)     =  CHPDEF(I)
   TABDEF2_(NBOBJ2)    =  TABDEF2(I)
   TYPDEF_(NBOBJ2)     =  TYPDEF(I)
   TORD(NBOBJ2)        =  NBOBJ2+1
   NBOBJ2 += 1
   Endif
 Next I
Endif
End
##################################################################
## Liste de tous les objets pour les conditions prefdefinies
##################################################################
Subprog CRE_CLASS_OBJ_INF(APPLI,DATAM,TCLASSE,TSCLASSE,TSCLASSE2SS,TCLAOBJ,TOBJ,TORD,TABDEF_,CHPDEF_,TABDEF2_,TYPDEF_,TABOBJ_,FLDOBJ_,NBOBJ2,LANBI,STA)
Value Char APPLI
Value Char DATAM
Variable Char    TCLASSE()
Variable Char    TSCLASSE()
Variable Char    TSCLASSE2SS()
Variable Char    TCLAOBJ()
Variable Char    TOBJ()
Variable Integer  TORD()
Variable Char    TABDEF_()
Variable Char    CHPDEF_()
Variable Char    TABDEF2_()
Variable Char    TYPDEF_()
Variable Char    TABOBJ_()
Variable Char    FLDOBJ_()
Variable Integer  NBOBJ2
Value    Char     LANBI
Variable Integer  STA


Local Integer NUMABM
Local Integer NBTCLA
Local Char TSCLASSE2(50)(1..500)  , TCLASSE2(50)(1..500)
#### Tableau des conditions
Local Integer NBCOND : NBCOND=100
Local Char   EXPR_CND1(250)(0..NBCOND),EXPR_CND2(250)(0..NBCOND),EXPR_CND3(250)(0..NBCOND)
Local Char   EXPR_CLE(80)(0..NBCOND),EXPR_NOM(80)(0..NBCOND),EXPR_ID(80)(0..NBCOND)
Local Integer EXPR_NB,OKCND
Local Char    TEXTE(80) , NOM(80) , INVITE(80) , EXPR2(250)
Local Clbfile EXPR(2)

If !clalev([F:ABM])  : Local File =APPLI+".ABIDATMRT" [ABM]  : Endif

Read [ABM]ABM0 = [L]DATAM
If !fstat
 #### Ouverture tables
 Gosub OUV_TABLES

 #### Initialisation variables
 Gosub INIT

 For NUMABM=0 To [F:ABM]NBRABF-1
  If func AFNC.ACTIV([ABM]ACTABF(NUMABM))= 1
   Gosub JOINTURES
   If KOOBJ : Break : Endif
  Endif
 Next NUMABM

 If KOOBJ
  If GTRACE <> ""
   Call ECR_TRACE(mess(106,148,1)-num$(MAXOBJ),1) From GESECRAN
  Else
   Call ERREUR(mess(106,148,1)-num$(MAXOBJ)) From GESECRAN
  Endif
  STAT = 1
  End
 Endif

 For I=0 To NBCLASSE-1
  NBTCLA +=1
  If !instr(0,CLASSE(I),",")
   CLASSE2= CLASSE(I)
  Endif
 Next I

 For I=0 To NBOBJ-1
  If TABOBJ(I)<> ""
   TCLASSE(NBOBJ2)     =  CLASSE2
   TSCLASSE(NBOBJ2)    =  CLAOBJ(I)
   TSCLASSE2SS(NBOBJ2) =  CLAOBJ2(I)
   TCLAOBJ(NBOBJ2)     =  CLAOBJ(I)+";"+CLAOBJ2(I)
   If CLAOBJ2(I)<> "" & GFONCTION="GESAII"
    TOBJ(NBOBJ2)        =  "["+CLAOBJ2(I)+"]"-NOMOBJ(I)
   Else
    TOBJ(NBOBJ2)        =  NOMOBJ(I)
   Endif
   TABDEF_(NBOBJ2)     =  TABDEF(I)
   CHPDEF_(NBOBJ2)     =  CHPDEF(I)
   TABDEF2_(NBOBJ2)    =  TABDEF2(I)
   TYPDEF_(NBOBJ2)     =  TYPDEF(I)
   TABOBJ_(NBOBJ2)     =  TABOBJ(I)
   FLDOBJ_(NBOBJ2)     =  FLDOBJ(I)
   TORD(NBOBJ2)        =  NBOBJ2+1
   NBOBJ2 += 1
  Endif
 Next I
Endif

End

############################################################################################
############################################################################################
$ECRITURE_FICHIER
Wrseq '# Tables' ;IRS;
For I=0 To NBJOINT-1
 If !find(TABORI(I),TABLES(0..NBTABLES)) & !instr(0,TABORI(I),"_1") & !instr(0,TABORI(I),"_2") & !instr(0,TABORI(I),"_3")
&  & !instr(0,TABORI(I),"_4") & !instr(0,TABORI(I),"_5") & !instr(0,TABORI(I),"_6") & !instr(0,TABORI(I),"_7")
&  & !instr(0,TABORI(I),"_8") & !instr(0,TABORI(I),"_9")
    Wrseq "Table,"+TABORI(I) ;IRS;
 Endif
 If !find(TABORI(I),TABLES(0..NBTABLES))
  TABLES(NBTABLES) = TABORI(I)
  NBTABLES +=1
 Endif
 If !find(TABDES(I),TABLES(0..NBTABLES)) & !instr(0,TABDES(I),"_1") & !instr(0,TABDES(I),"_2") & !instr(0,TABDES(I),"_3")
&  & !instr(0,TABDES(I),"_4") & !instr(0,TABDES(I),"_5") & !instr(0,TABDES(I),"_6") & !instr(0,TABDES(I),"_7")
&  & !instr(0,TABDES(I),"_8") & !instr(0,TABDES(I),"_9")
    Wrseq "Table,"+TABDES(I) ;IRS;
 Endif
 If !find(TABDES(I),TABLES(0..NBTABLES))
  TABLES(NBTABLES) = TABDES(I)
  NBTABLES +=1
 Endif
Next I
Wrseq  ;IRS;
Wrseq "# Pour la ligne 1000" ;IRS;
Call LIGNE1000([L]DATAW,[L]DATAM,[L]APPLI) From ABICREUNV
Wrseq ;IRS;
Wrseq '# Alias' ;IRS;
For I=0 To NBTABLES-1
 If  !instr(0,TABLES(I),"_1") & !instr(0,TABLES(I),"_2") & !instr(0,TABLES(I),"_3")
&  & !instr(0,TABLES(I),"_4") & !instr(0,TABLES(I),"_5") & !instr(0,TABLES(I),"_6") & !instr(0,TABLES(I),"_7")
&  & !instr(0,TABLES(I),"_8") & !instr(0,TABLES(I),"_9")
  # Wrseq "Alias,"+TABLES(I)+','+TABLES(I) ;IRS; : # Pour pas avoir des alias de meme nom
 Else
  Wrseq "Alias,"+left$(TABLES(I),instr(3,TABLES(I),"_")-1)+','+TABLES(I) ;IRS;
 Endif
Next I
Wrseq ;IRS;
Wrseq '# Contextes' ;IRS;
For I=0 To NBJOINT-1
 If left$(TABORI(I),2) = "F_" & !find(right$(TABORI(I),3),CONTEXTES(0..NBCONT))
  CONTEXTES(NBCONT) = right$(TABORI(I),3)
  Wrseq 'Contexte,'+CONTEXTES(NBCONT) ;IRS;
  NBCONT +=1
 Elsif left$(TABORI(I),2) <> "D_" & left$(TABORI(I),2) <> "F_" & !find(TABORI(I),CONTEXTES(0..NBCONT))
  CONTEXTES(NBCONT) = TABORI(I)
  Wrseq 'Contexte,'+CONTEXTES(NBCONT) ;IRS;
  NBCONT +=1
 Endif
Next I
Wrseq ;IRS;
Wrseq '# Jointures' ;IRS;
For I=0 To NBJOINT-1
 If TABDES(I)<>""
  Wrseq "Jointure,"+TABORI(I)+','+TABDES(I)+','+TYPJOIN(I)+',';
  CLEORI2 = CLEORI(I) : CLEDES2 = CLEDES(I)
  J= instr(0,CLEORI2,"-") : K= instr(0,CLEDES2,"-")
  While J>0
   If left$(CLEORI2,J-1) <> ""
    Wrseq  left$(CLEORI2,J-1)+','+left$(CLEDES2,K-1)+',';
   Endif
   CLEORI2 = right$(CLEORI2,J+1)
   CLEDES2 = right$(CLEDES2,K+1)
   J= instr(0,CLEORI2,"-") : K= instr(0,CLEDES2,"-")
  Wend
  If CLEORI2<> ""
   Wrseq  CLEORI2+','+CLEDES2+',,';
  Else
   Wrseq ',';
  Endif
  If left$(TABORI(I),2) = "F_"
   Wrseq right$(TABORI(I),3) ;IRS;
  Elsif left$(TABORI(I),2) = "D_"
   Wrseq "tous" ;IRS;
  Else
   Wrseq TABORI(I) ;IRS;
  Endif
 Endif
Next I
Wrseq  ;IRS;
Wrseq '# Classes' ;IRS;
For I=0 To NBCLASSE-1
 If !instr(1,CLASSE(I),func MESSBI(116,148,LANBI))
  Wrseq 'Classe,'+CLASSE(I) ;IRS;
  J =  find(func MESSBI(116,148,LANBI)-CLASSE(I)+","+CLASSE(I),CLASSE(0..NBCLASSE))
  If J : # si classse indicateur associé
   If find(left$(CLASSE(J-1),instr(1,CLASSE(J-1),",")-1),CLAOBJ2(0..NBOBJ-1)) or find(left$(CLASSE(J-1),instr(1,CLASSE(J-1),",")-1),CLAOBJ(0..NBOBJ-1))
    Wrseq 'Classe,'+CLASSE(J-1) ;IRS;
   Else
    For K=0 To NBOBJ-1
     If left$(TABOBJ(K),2) = "F_"
      If instr(3,TABOBJ(K),"_")
       TAB2 =  mid$(TABOBJ(K),3,instr(3,TABOBJ(K),"_")-3)
      Else
       TAB2 =  right$(TABOBJ(K),3)
      Endif
      Read [ABF]ABF0 = TAB2
      If !fstat
       If [ABF]NBRABF = 2 & [F:ABM]MESURE = 2
        Wrseq 'Classe,'+CLASSE(J-1) ;IRS;
        Break
       Endif
      Endif
     Endif
    Next I
   Endif
   THECLAIND = CLASSE(J-1)
   For K=0 To NBCLASSE-1
    If instr(1,CLASSE(K),func MESSBI(116,148,LANBI))
     If CLASSE(K) <> THECLAIND
      Wrseq 'Classe,'+CLASSE(K) ;IRS;
     Endif
    Endif
   Next
  Endif
 Endif
Next I

Wrseq ;IRS;
Wrseq '# Autorisations' ;IRS;
Local File (Char AUTODEB2(50), Char AUTOTAB2(50))
& From Variable AUTODEB,AUTOTAB As [AUTO] Order By Key CLE=AUTODEB2;AUTOTAB2
For [AUTO]CLE(1)
 If [AUTO]AUTODEB2 <> ""
  P =0
  For [AUTO]CLE
   OK =1
   If [M:DIA]AUTSIT <> 2 & [M:DIA]AUTACC =2
    If left$([AUTO]AUTOTAB2,9) = "AX3FCTFCY" : OK =0 : Endif
   Elsif [M:DIA]AUTACC <> 2 & [M:DIA]AUTSIT =2
    If left$([AUTO]AUTOTAB2,6) = "AX3ACC"    : OK =0 : Endif
   Elsif [M:DIA]AUTACC <> 2 & [M:DIA]AUTSIT <> 2
    If left$([AUTO]AUTOTAB2,9) = "AX3FCTFCY" | left$([AUTO]AUTOTAB2,6) = "AX3ACC"
     OK =0
    Endif
   Endif
   If OK
    If !P
     Wrseq 'Autorisation,'+[AUTO]AUTODEB2;
     P=1
    Endif
    Wrseq ','+[AUTO]AUTOTAB2;
   Endif
  Next
  Wrseq ;IRS;
 Endif
Next
Wrseq ;IRS;

Wrseq '# Objets' ;IRS;
For I=0 To NBOBJ-1
 If CLEOBJ(I) <>"compte"
  Wrseq "Objet,"+CLAOBJ(I)+";"+CLAOBJ2(I)+","+NOMOBJ(I)+","+TYPOBJ(I)+","+INFOBJ(I)+","+CLEOBJ(I)+","+AUTO(I)+",";
  Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)+";"+TABDEF2(I)+";;"+TYPDEF(I)+','+[L]TUNNEL(I)+',';
  If AGGOBJ(I) <> ""
   Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+AGGOBJ(I) ;IRS;
  Else
   Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+","+FLDOBJ(I) ;IRS;
  Endif
 Endif
Next I
Wrseq ;IRS;
Wrseq '# Nombres' ;IRS;
K=0
For I=0 To NBOBJ-1
 If left$(TABOBJ(I),2) = "D_" & !find(CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I),NOMBRES(0..NBNB))
  NOMBRES(NBNB) =  CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I)
  NBNB +=1
  If instr(3,TABOBJ(I),"_")
   TAB2 =  mid$(TABOBJ(I),3,instr(3,TABOBJ(I),"_")-3)
  Else
   TAB2 =  right$(TABOBJ(I),3)
  Endif
  Read [ABI]ABI0 = TAB2
  If !fstat
   If [ABI]NOMBRE = 2
    If !find(CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI),NOMBRE_DOUBLON(0..NBDOUB))
     Wrseq "Objet,"+CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
     Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)+";"+TABDEF2(I)+";;"+"NOMBRE"+',,';
     Wrseq  string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+','+FLDOBJ(I) ;IRS;
     NOMBRE_DOUBLON(NBDOUB) = CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI)
     NBDOUB +=1
    Else
     For J=0 To 20
      If !find(CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI)+"_"+num$(J),NOMBRE_DOUBLON(0..NBDOUB))
       Wrseq "Objet,"+CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI)+"_"+num$(J)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
       Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)+";"+TABDEF2(I)+";;"+"NOMBRE"+',,';
       Wrseq  string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+','+FLDOBJ(I) ;IRS;
       NOMBRE_DOUBLON(NBDOUB) = CLAOBJ(I)+';'+CLAOBJ2(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABI]INTIT,[F:ABI]INTEVAL,LANBI)+"_"+num$(J)
       NBDOUB +=1
       Break
      Endif
     Next J
    Endif
   Endif
  Endif
 Elsif val(GVERSION)>= 1.6
  If (left$(TABOBJ(I),2) = "F_" or left$(AGGOBJ(I),2) = "F_") & !find(CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I),NOMBRES(0..NBNB))
   If K=0
    NOMBRES(NBNB) =  CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I)
    NBNB +=1
    TAB2 = ""
    If instr(3,TABOBJ(I),"_")
     TAB2 =  mid$(TABOBJ(I),3,instr(3,TABOBJ(I),"_")-3)
    Else
     TAB2 =  right$(TABOBJ(I),3)
    Endif
    If TAB2 = "" & AGGOBJ(I) <> ""
     GBIDC1 = left$(AGGOBJ(I),instr(1,AGGOBJ(I),",")-1)
     If instr(3,GBIDC1 ,"_")
      TAB2 =  mid$(GBIDC1,3,instr(3,GBIDC1 ,"_")-3)
     Else
      TAB2 =  right$(GBIDC1,3)
     Endif
    Endif
    Read [ABF]ABF0 = TAB2
    If !fstat
     If [ABF]NBRABF = 2
      If [F:ABM]MESURE = 2
       If find(left$(func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),instr(1,func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),",")-1),CLAOBJ2(0..NBOBJ-1))
&        or find(left$(func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),instr(1,func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),",")-1),CLAOBJ(0..NBOBJ-1))
        Wrseq "Objet,"+CLAOBJ(I)+';'+func MESSBI(116,148,LANBI)-CLAOBJ(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
       Else
        Wrseq "Objet,"+CLAOBJ(I)+';'+""                       +','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
       Endif
      Else
       Wrseq "Objet,"+CLAOBJ(I)+';'+""                       +','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
      Endif
      # 118322
      #If right$(GREPSOLIND,len(GREPSOLIND))>="6"
       Wrseq  ABRUNV+';'+TABDEF(I)+";"+"NBRABFABF"+";"+    ""    +";;"+"NOMBRE"+',,';
      #Else
      # Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)  +";"+TABDEF2(I)+";;"+"NOMBRE"+',,';
      #Endif
      If AGGOBJ(I) <> ""
       Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+AGGOBJ(I) ;IRS;
      Else
      Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+","+FLDOBJ(I) ;IRS;
      Endif
      K=1
     Endif
    Endif
   Endif
  Endif
 Elsif val(GVERSION) < 1.6
  If (left$(TABOBJ(I),2) = "F_") & !find(CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I),NOMBRES(0..NBNB))
   If K=0
    NOMBRES(NBNB) =  CLAOBJ(I)-CLAOBJ2(I)-TABOBJ(I)
    NBNB +=1
    TAB2 = ""
    If instr(3,TABOBJ(I),"_")
     TAB2 =  mid$(TABOBJ(I),3,instr(3,TABOBJ(I),"_")-3)
    Else
     TAB2 =  right$(TABOBJ(I),3)
    Endif
    Read [ABF]ABF0 = TAB2
    If !fstat
     If [ABF]NBRABF = 2
      If [F:ABM]MESURE = 2
       If find(left$(func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),instr(1,func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),",")-1),CLAOBJ2(0..NBOBJ-1))
&        or find(left$(func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),instr(1,func MESSBI(116,148,LANBI)-CLAOBJ(I)+","+CLAOBJ(I),",")-1),CLAOBJ(0..NBOBJ-1))
        Wrseq "Objet,"+CLAOBJ(I)+';'+func MESSBI(116,148,LANBI)-CLAOBJ(I)+','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
       Else
        Wrseq "Objet,"+CLAOBJ(I)+';'+""                       +','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
       Endif
      Else
       Wrseq "Objet,"+CLAOBJ(I)+';'+""                       +','+func MESSBI(13,148,LANBI)-func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+','+TYPOBJ(I) +',Mesure,Nombre,'+""+",";
      Endif
      # 118322
      #If right$(GREPSOLIND,len(GREPSOLIND))>="6"
       Wrseq  ABRUNV+';'+TABDEF(I)+";"+"NBRABFABF"+";"+    ""    +";;"+"NOMBRE"+',,';
      #Else
      # Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)  +";"+TABDEF2(I)+";;"+"NOMBRE"+',,';
      #Endif
      Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+","+FLDOBJ(I) ;IRS;
      K=1
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
Wrseq ;IRS;

Wrseq '# Compte' ;IRS;
For I=0 To NBOBJ-1
 If CLEOBJ(I) = "compte"
  Wrseq "Objet,"+CLAOBJ(I)+';'+CLAOBJ2(I)+','+NOMOBJ(I)+","+TYPOBJ(I)+","+INFOBJ(I)+","+CLEOBJ(I)+","+""+",";
  Wrseq  ABRUNV+';'+TABDEF(I)+";"+CHPDEF(I)+";"+TABDEF2(I)+";;"+TYPDEF(I)+',,';
  If AGGOBJ(I) <> ""
   Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+AGGOBJ(I) ;IRS;
  Else
   Wrseq string$(BOVERSION="R3",TYPOBJ(I)+",")+TABOBJ(I)+","+FLDOBJ(I) ;IRS;
  Endif
 Endif
Next I
Wrseq ;IRS;

Wrseq "# Incompatiblités" ;IRS;
### Interdictions agg
Local File (Char CLAINT2(50), Char CLAAGG2(50) ,  Char OBJINT2(50))
& From Variable CLAINT,CLAAGG,OBJINT As [AGG] Order By Key CLE=CLAAGG2;CLAINT2
Raz K,TABCLA,M,TABOBJ
For [AGG]CLE(1)
 If [AGG]CLAAGG2 <> ""
  For [AGG]CLE
   If [AGG]OBJINT2 = ""
    TABCLA(K) = CLAINT2
    K+=1
   Else
    TABOBJ(M) = OBJINT2
    M+=1
   Endif
  Next
  Read [ABE]ABE1 = left$([AGG]CLAAGG2,instr(0,[AGG]CLAAGG2,"_")-1);right$([AGG]CLAAGG2,instr(0,[AGG]CLAAGG2,"_")+1)
  If !fstat
   Read [ABF]ABF0 = [ABE]CODABF
   If !fstat
    For J=0 To NBCLASSE-1
     K = instr(0,CLASSE(J),",")
     If K & right$(CLASSE(J),K+1) = func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)
      SCLASSE = left$(CLASSE(J),K-1)
      L = find(SCLASSE,TABCLA(0..K))
      If !L
       Wrseq 'Incompatible,'+[AGG]CLAAGG2+',,'+SCLASSE+',,' ;IRS;
      Endif
     Endif
    Next J
    For J=0 To NBOBJ-1
     If CLAOBJ(J) = func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)
      If !find(NOMOBJ(J),TABOBJ(0..M)) & INFOBJ(J)<> "Mesure"
       Wrseq 'Incompatible,'+[AGG]CLAAGG2+','+NOMOBJ(J)+','+func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)+',,' ;IRS;
      Endif
     Endif
    Next J
    Raz TABCLA,K,TABOBJ,M
   Endif
  Endif
 Endif
Next
Wrseq ;IRS;

Wrseq '# hierarchies' ;IRS;
For I=0 To NBHIE-1
 Wrseq 'Hierarchie,'+HIERACH(I)+HIERACH2(I)+HIERACH3(I)+HIERACH4(I) ;IRS;
Next
Wrseq ;IRS;

Wrseq '# Conditions' ;IRS;
For I=0 To EXPR_NB-1
 If !instr(0,EXPR_CLE(I),"~")
  Wrseq 'Condition,'+EXPR_CLE(I)+','+EXPR_NOM(I)+','+ABRUNV+';'+EXPR_ID(I)+','+EXPR_CND1(I)+EXPR_CND2(I)+EXPR_CND3(I) ;IRS;
 Endif
Next I
Wrseq ;IRS;

Return

$INIT
# On passe le maxmem à 50 Mo bug  61821
maxmem = max(50000,maxmem/1024)

# Pour forcer l'allocation de 6 Mo de mémoire (perfs)
Local Char TOTO(10)(1024,600)
Kill TOTO

### declaration variable
Local Shortint MAXFIL , MAXCNT , MAXLIE , MAXOBJ , MAXCLA , MAXFAT , MAXAUT

MAXFIL = 1300 : # Nombre maxi de tables
MAXCNT = 250  : # Nombre maxi de contextes
MAXLIE = 1000  : # Nombre maxi de liens
MAXOBJ = 3400 : # Nombre maxi d'objets
MAXCLA = 1000 : # Nombre maxi de class
MAXAGG = 250  : # Nombre maxi de jointure agregats
MAXAUT = 250  : # Nombre maxi d'autorisation

GPOINT = "INITMAX" : Gosub ENTREE From EXEFNC : # Init max

#### Variables Divers
Local Char    FLDDES(15),TAB1(15),TAB2(15),CLES(80),DIMCOD(15),JOINT_AGG2(80),RACOURCI(10),INTERNE(10)
Local Char    TYPOBJ2(10),TDAT(10),DATFLD(10),NOMADI(80),AUZAGG(80),TYPBDA(10)
Local Integer I,J,M,N,K,L,P,NBAGG,NBTAB,IDAT,NIV,J2,J3,J1,II,NBA,NBN
Local Integer NBNB,ACT,NBNACT,NB_FLDLIENS,DEB, FIN
Local Char    SCLASSE(80),CLEDAT(80),OBJINF(120),BOVERSION(80)

#### tableau pour la gestion des dimesion peres
#### Pour pas prendre deux la table lors d'un dimension avec une cle de 2
Local Char    SUPPFLD1(30)(0..100),SUPPFLD2(30)(0..100),SUPPFLD3(30)(0..100),SUPPFLD4(30)(0..100),SUPPFLD5(30)(0..100)
Local Char    SUPPFLD6(30)(0..100),SUPPFLD7(30)(0..100),SUPPFLD8(30)(0..100),SUPPFLD9(30)(0..100),SUPPFLD10(30)(0..100)
Local Integer  NBSUP1,NBSUP2,NBSUP3,NBSUP4,NBSUP5,NBSUP6,NBSUP7,NBSUP8,NBSUP9,NBSUP10

#### tableau temportaire pour la gestion de jointure des tables d'aggregats
Local Char    JOINT_AGG(80)(0..MAXAGG),NOM_AGG(30)(0..MAXAGG),NOM_TABAG(10)(0..MAXAGG)
Local Integer NIV_AGG(0..MAXAGG)

#### tableaux et variables temporaire pour la gestion des jointures
Local Char    LIENS(80),LIENS1(30)(0..MAXLIE),LIENS2(30)(0..MAXLIE)
Local Char    TAB_DES(15)(0..MAXFIL),FLD_LIENS(15)(0..250)
Local Integer ORD_TAB(0..MAXFIL),NBTAB

#### tableau des objets de type nombre
Local Char    NOMBRES(180)(0..MAXCLA)
### Pour la gestion des doublons dans les nombres
Local Char    NOMBRE_DOUBLON(80)(0..MAXCLA)
Local Integer NBDOUB

#### Variables Objets
Local Char    CLAOBJ(80)(0..MAXOBJ)
Local Char    CLAOBJ2(80)(0..MAXOBJ) : # sous classe de deuxieme niveau
Local Char    NOMOBJ(80)(0..MAXOBJ)
Local Char    TYPOBJ(15)(0..MAXOBJ)
Local Char    INFOBJ(15)(0..MAXOBJ)
Local Char    OPEOBJ(15)(0..MAXOBJ)
Local Char    TABOBJ(15)(0..MAXOBJ)
Local Char    FLDOBJ(15)(0..MAXOBJ)
Local Char    CLEOBJ(80)(0..MAXOBJ)
Local Char    AGGOBJ(250)(0..MAXOBJ)
Local Char    TUNNEL(20)(0..MAXOBJ)
Local Char    AUTO(60)(0..MAXOBJ)

# Pour la traduction chemin unique
Local Char    UNVDEF(15)(0..MAXOBJ)
Local Char    TABDEF(15)(0..MAXOBJ)
Local Char    CHPDEF(15)(0..MAXOBJ)
Local Char    TABDEF2(250)(0..MAXOBJ)
Local Char    TYPDEF(15)(0..MAXOBJ)
Local Integer NBOBJ,KOOBJ

### pour la verif des nom d'objets
Local Char    VERF_NOM(80)(0..MAXOBJ)
Local Integer ORD_NOM(0..MAXOBJ)
Local Integer NBVERF

#### Tableau des jointures
Local Char    TABORI(30)(0..MAXLIE) ,TABDES(30)(0..MAXLIE),TYPJOIN(80)(0..MAXLIE)
Local Char    CLEORI(100)(0..MAXLIE),CLEDES(100)(0..MAXLIE),CLEORI2(100),CLEDES2(100)
Local Integer NBJOINT

#### tableuu des tables
Local Char    TABLES(80)(0..MAXFIL)
Local Integer NBTABLES

#### tableau des contextes
Local Char    CONTEXTES(20)(0..MAXCNT)
Local Integer NBCONT

#### tableau des classes
Local Char    CLASSE(120)(0..MAXCLA),TABCLA(120)(0..MAXCLA),CLASSE1(120),CLASSE2(120),THECLAIND(120)
Local Char    S_CLASSE(120)(0..MAXCLA),SCLASSE2(120),S_CLAIND(120)(0..MAXCLA),CLACOU(120),SCLAIND2(120)
Local Integer NBCLASSE,NBSCLASSE,NBSCLAIND

#### tableau pour la verif des noms de classe
Local Integer ORD_CLASSE(0..MAXCLA)

#### tableau des interdiction
Local Char    CLAINT(50)(0..MAXCLA),CLAAGG(50)(0..MAXCLA),OBJINT(50)(0..MAXCLA)
Local Integer NBINT

####  jointures AGG - AX3FCTFCY
Local Char    TABFCTFCY(50)

#### tableau des autorisations
Local Char    AUTODEB(50)(0..MAXAUT),AUTOTAB(50)(0..MAXAUT)
Local Integer NBAUTO
Local Integer NBJOI

#### Complement dans les liens
Local Char COMPLEMENT(60)

#### pour verif_abi
Local Integer XINTIT
Local Char    XINTVAL(250)

Onerrgo ERRVERSION
Call GETBOVERSION(BOVERSION) From INTRUTILA
Onerrgo
Return

$ERRVERSION
BOVERSION = ""
Resume

$OUV_TABLES
If !clalev([F:ABF])  : Local File =APPLI+".ABITABDAT" [ABF]  : Endif
If !clalev([F:ABZ])  : Local File =APPLI+".ABITABFLD" [ABZ]  : Endif
If !clalev([F:ABZ2]) : Local File =APPLI+".ABITABFLD" [ABZ2] : Endif
If !clalev([F:ABX])  : Local File =APPLI+".ABITABIND" [ABX]  : Endif
If !clalev([F:ABK])  : Local File =APPLI+".ABITABLNK" [ABK]  : Endif
If !clalev([F:ABE])  : Local File =APPLI+".ABITABAGG" [ABE]  : Endif
If !clalev([F:ATY])  : Local File =APPLI+".ATYPE"     [ATY]  : Endif
If !clalev([F:ABI])  : Local File =APPLI+".ABIDIM"    [ABI]  : Endif
If !clalev([F:ABI2]) : Local File =APPLI+".ABIDIM"    [ABI2] : Endif
If !clalev([F:ABJ])  : Local File =APPLI+".ABIDIMFLD" [ABJ]  : Endif
If !clalev([F:ABJ2]) : Local File =APPLI+".ABIDIMFLD" [ABJ2] : Endif
If !clalev([F:ABJ3]) : Local File =APPLI+".ABIDIMFLD" [ABJ3] : Endif
If !clalev([F:ABJ4]) : Local File =APPLI+".ABIDIMFLD" [ABJ4] : Endif
If !clalev([F:ABJ5]) : Local File =APPLI+".ABIDIMFLD" [ABJ5] : Endif
If !clalev([F:ABJ6]) : Local File =APPLI+".ABIDIMFLD" [ABJ6] : Endif
If !clalev([F:ABJ7]) : Local File =APPLI+".ABIDIMFLD" [ABJ7] : Endif
If !clalev([F:ABJ8]) : Local File =APPLI+".ABIDIMFLD" [ABJ8] : Endif
If !clalev([F:ABJ9]) : Local File =APPLI+".ABIDIMFLD" [ABJ9] : Endif
If !clalev([F:AB10]) : Local File =APPLI+".ABIDIMFLD" [AB10] : Endif
If !clalev([F:ABJ_]) : Local File =APPLI+".ABIDIMFLD" [ABJ_] : Endif
If !clalev([F:ABM])  : Local File =APPLI+".ABIDATMRT" [ABM]  : Endif
If !clalev([F:ATB])  : Local File =APPLI+".ATABLE"    [ATB]  : Endif
If !clalev([F:ADV])  : Local File =APPLI+".ATABTAB"   [ADV]  : Endif
If !clalev([F:ATZ])  : Local File =APPLI+".ATABZON"   [ATZ]  : Endif
If !clalev([F:ABM2]) : Local File =APPLI+".ABIDATMRT" [ABM2] : Endif
If !clalev([F:AII])  : Local File =APPLI+".ABICOND"   [AII]  : Endif
If !clalev([F:AFC])  : Local File =APPLI+".AFONCTION" [AFC]  : Endif
If !clalev([F:AOB])  : Local File =APPLI+".AOBJET"    [AOB]  : Endif
If !clalev([F:ATX])  : Local File =APPLI+".ATEXTE"    [ATX]  : Endif
If !clalev([F:AST])  : Local File =APPLI+".APLSTD"    [AST]  : Endif
Return

##################################################################################################
###                             Jointures                                                      ###
##################################################################################################
$JOINTURES
Raz TABFCTFCY,P
For [ABF] Where CODABF =  [F:ABM]CODABF(NUMABM)
 If func AFNC.ACTIV([ABF]CODACT)<> 1 : Break : Endif
 Gosub TAB_AGG
 Gosub FLD_LIENS
 Raz VERF_NOM,NBVERF,ORD_NOM
 CLASSE1 = func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)
 If [F:ABM]MESURE=2
  Gosub AJOUT_CLA_INDICATEUR
  SCLAIND2 = CLASSE(NBCLASSE-1)
 Endif
 Gosub VERIF_CLASSE
 CLACOU  = CLASSE(NBCLASSE-1) :  # classe de la table de fait
 Gosub VERIF_AUTORISATION : If NBTAB : TABFCTFCY = TAB_DES(NBTAB-1) : Endif
 For I=0 To EXPR_NB-1
  If EXPR_CLE(I) = [F:ABF]CODABF+"~&~&"
   EXPR_CLE(I) = SCLASSE
  Endif
 Next I
 Filter [ABZ]  Order By Key CLE=TYPFLD;NUMFLD  :# CODFLD
 For [ABZ]CLE Where CODABF = [F:ABF]CODABF
  SCLASSE2 = ""
  If func AFNC.ACTIV([ABZ]ACTFLD)= 1
   If find([F:ABZ]TYPFLD,1) : # Mesure
    Gosub CRE_MESURE_STD
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break   : Endif
   Elsif find([F:ABZ]TYPFLD,2)  : # Info
    Gosub CRE_INFO_STD
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break   : Endif
   Elsif find([F:ABZ]TYPFLD,4) : # Technique
    Gosub CRE_TECH_STD
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break  : Endif
   Elsif find([F:ABZ]TYPFLD,3) & !find([ABZ]CODFLD,FLD_LIENS(0..NB_FLDLIENS))  : # dimension
    [L]RACOURCI = "False"
    [L]INTERNE = "Interne"
    [L]FLDDES =""
    If [F:ABZ]INTSSC>0
     CLASSE2 = CLACOU
     CLASSE1 = func TEXTEBI([F:ABZ]INTSSC,[F:ABZ]INTVALSSC,LANBI)
     Gosub VERIF_SCLADIMSTD
    Else
     CLASSE2  = ""
     SCLASSE2 = ""
    Endif
    Default File [F:ABZ] : Gosub CRE_JOINTURE_STD :
    If [L]FLDDES <> ""
     TABORI(NBJOINT) = "F_"+[F:ABF]CODABF
     TABDES(NBJOINT) = TAB_DES(NBTAB-1)
     TYPJOIN(NBJOINT)= [L]RACOURCI+','+[L]INTERNE
     CLEORI(NBJOINT) = [F:ABZ]CODFLD
     CLEDES(NBJOINT) = [L]FLDDES
     NBJOINT += 1
     [L]INTERNE = "Interne"
     Gosub CRE_DIM_STD
     If NBOBJ > MAXOBJ : KOOBJ= 1 : Break  : Endif
     For K=0 To NBAGG-1
      If [F:ABZ]CODFLD = JOINT_AGG(K)  : # si le champ appartient a un aggregat
       TABORI(NBJOINT) = [F:ABF]CODABF+'_'+NOM_AGG(K)
       TABDES(NBJOINT) = TAB_DES(NBTAB-1)
       TYPJOIN(NBJOINT)= "False,Interne"
       CLEORI(NBJOINT) = [F:ABZ]CODFLD
       If left$([L]FLDDES,3) = "DAT" & NIV_AGG(K)  > 0
        IDAT=NIV_AGG(K) : Gosub TYPDAT2
        If DATFLD<>"" : CLEDES(NBJOINT) = DATFLD : Endif
       Else
        CLEDES(NBJOINT) = [L]FLDDES
       Endif
       NBJOINT += 1
       If [F:ABZ]CODFLD = [F:ABF]FLDFCY
        TABORI(NBJOINT) = [F:ABF]CODABF+'_'+NOM_AGG(K)
        J=find("AX3FCTFCY",TAB_DES(0..NBTAB))
        [L]TAB1= "AX3FCTFCY"
        Gosub VERIF_TAB
        Gosub AJOUT_AUTO
        TABDES(NBJOINT) = TAB_DES(NBTAB-1)
        TYPJOIN(NBJOINT)= "False,Interne"
        CLEORI(NBJOINT) = [F:ABF]FLDFCY
        CLEDES(NBJOINT) = "FCY"
        NBJOINT += 1
       Endif
      Endif
     Next K
    Else
     CLAOBJ(NBOBJ) = CLACOU
     CLAOBJ2(NBOBJ)= SCLASSE2
     TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
     FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
     TYPOBJ2 =[F:ABZ]CODTYP : Gosub VERIF_TYP
     INFOBJ(NBOBJ) = "Dimension"
     NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
     CLEOBJ(NBOBJ) = ""
     TABDEF(NBOBJ) = [F:ABF]CODABF
     CHPDEF(NBOBJ) = [F:ABZ]CODFLD
     TABDEF2(NBOBJ)= ""
     TYPDEF(NBOBJ) = ""
     AUTO(NBOBJ)   = ""
     Gosub ADD_TUNNEL
     NBOBJ += 1
     If NBOBJ >= MAXOBJ : KOOBJ= 1 : Break : Endif
    Endif
   Endif
 Endif
 Next ABZ
 Filter [ABZ]
 If NBOBJ > MAXOBJ : KOOBJ= 1 : Break  : Endif
 If NBOBJ>0 & NBJOINT=0
  TABORI(NBJOINT) = "F_"+[F:ABF]CODABF
  TABDES(NBJOINT) = ""
  TYPJOIN(NBJOINT)= ""
  CLEORI(NBJOINT) = ""
  CLEDES(NBJOINT) = ""
  NBJOINT += 1
 Endif

 For [ABK] Where CODABF = [F:ABF]CODABF
  If [F:ABK]EXPLNK <> ""
   Gosub VERIF_LIENS
   If ACT
    If [F:ABK]TYPJNT<>2 : [L]RACOURCI = "False"  : Else : [L]RACOURCI = "True" : Endif
    Case [F:ABK]OPTJNT
     When 1  : [L]INTERNE = "Interne"
     When 2  : [L]INTERNE = "Gauche"
     When 3  : [L]INTERNE = "Droite"
     When Default : [L]INTERNE = "Interne"
    Endcase
    J = find("D_"+[F:ABK]CODLNK,TAB_DES(0..NBTAB))
    [L]TAB1= "D_"+[F:ABK]CODLNK
    Gosub VERIF_TAB
    TABORI(NBJOINT) = "F_"+[F:ABF]CODABF
    TABDES(NBJOINT) = TAB_DES(NBTAB-1)
    TYPJOIN(NBJOINT)= [L]RACOURCI+','+[L]INTERNE
    CLASSE2 = func TEXTEBI([F:ABF]INTIT,[F:ABF]INTEVAL,LANBI)
    # cherche dernier elements de cle vide
    For J=I To 0 Step -1
     If LIENS1(J)<> ""
      Break
     Endif
    Next J
    Read [ABZ]ABZ1 =[ABF]CODABF;LIENS1(J)
    If !fstat
     CLASSE1=func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
     If [F:ABK]INTLNK >0
      CLASSE1 = func TEXTEBI([F:ABK]INTLNK,[F:ABK]INTVALLNK,LANBI)
     Endif
     Gosub VERIF_CLASSE2
     If [F:ABZ]TYPOPE = 2
      CLAOBJ(NBOBJ) = SCLASSE
      CLAOBJ2(NBOBJ)= SCLASSE2
      TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
      FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
      TYPOBJ(NBOBJ) = "num"
      INFOBJ(NBOBJ) = "mesure"
      NOMOBJ(NBOBJ) = func MESSBI(59,148,LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI) : # "Nombre distinct de"
      CLEOBJ(NBOBJ) = "compte"
      TABDEF(NBOBJ) = [F:ABF]CODABF
      CHPDEF(NBOBJ) = [F:ABZ]CODFLD
      TABDEF2(NBOBJ)= ""
      TYPDEF(NBOBJ) = "compte"
      AUTO(NBOBJ)   = ""
      NBOBJ += 1
      If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
      Endif
    Endif
    For J=0 To NBJOI
     CLEORI(NBJOINT) += LIENS1(J)+"-"
     CLEDES(NBJOINT) += LIENS2(J)+"-"
    Next J
    CLEORI(NBJOINT) = left$(CLEORI(NBJOINT),len(CLEORI(NBJOINT))-1)
    CLEDES(NBJOINT) = left$(CLEDES(NBJOINT),len(CLEDES(NBJOINT))-1)
    NBJOINT += 1
    For J=0 To EXPR_NB-1
     If ([F:ABF]CODABF+"~&"+[F:ABK]CODLNK+"~&"+[F:ABK]EXPLNK) = EXPR_CLE(J)
      EXPR_CLE(J) = SCLASSE
     Elsif ([ABF]CODABF+"~&"+[ABK]CODLNK+"~&") = EXPR_CLE(J)
      EXPR_CLE(J) = SCLASSE
     Endif
    Next J
    For J=0 To I
     For K=0 To NBAGG-1
      If LIENS1(J) = JOINT_AGG(K) & J=0  & NOM_TABAG(K) = [F:ABK]CODLNK
       CLAINT(NBINT)   = SCLASSE
       CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
       OBJINT(NBINT)   = ""
       NBINT +=1
       TABORI(NBJOINT) = [F:ABF]CODABF+'_'+NOM_AGG(K)
       TABDES(NBJOINT) = TAB_DES(NBTAB-1)
       TYPJOIN(NBJOINT)= "False,Interne"
       For JJ=0 To I
        CLEORI(NBJOINT) += LIENS1(JJ)+"-"
        CLEDES(NBJOINT) += LIENS2(JJ)+"-"
       Next JJ
       CLEORI(NBJOINT) = left$(CLEORI(NBJOINT),len(CLEORI(NBJOINT))-1)
       CLEDES(NBJOINT) = left$(CLEDES(NBJOINT),len(CLEDES(NBJOINT))-1)
       NBJOINT += 1
       If AUZAGG <> "" & TABFCTFCY <> ""
        TABORI(NBJOINT) = TABORI(NBJOINT-1)
        TABDES(NBJOINT) = TABFCTFCY
        TYPJOIN(NBJOINT)= "False,Interne"
        CLEORI(NBJOINT) = AUZAGG
        CLEDES(NBJOINT) = "FCY"
        NBJOINT += 1
       Endif
      Endif
     Next K
    Next J
    AUZAGG = ""
    If [F:ABM]PREFIX <> 2 : Raz VERF_NOM,NBVERF,ORD_NOM : Endif
    Raz S_CLASSE,NBSCLASSE
    [L]RACOURCI = "False"
    DEBJOINT = "D_"+[F:ABK]CODLNK
    COMPLEMENT = ""
    If [F:ABM]COMPL =2
     COMPLEMENT = func TEXTEBI([F:ABK]INTCOMP,[F:ABK]INTVALCOMP,LANBI)
    Endif
    Filter [ABJ]  Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ2] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ3] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ4] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ5] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ6] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ7] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ8] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [ABJ9] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Filter [AB10] Order By Key CLE=TYPFLD;CODDIM;NUMDIM
    Raz SUPPFLD1,NBSUP1,SUPPFLD2,NBSUP2,SUPPFLD3,NBSUP3,SUPPFLD4,NBSUP4,SUPPFLD5,NBSUP5,SUPPFLD6,NBSUP6,SUPPFLD7,NBSUP7
    Raz SUPPFLD8,NBSUP8,SUPPFLD9,NBSUP9,SUPPFLD10,NBSUP10
    For [ABJ]CLE Where CODDIM = [F:ABK]CODLNK
     [L]NIV = 1
     DEBJOINT = "D_"+[F:ABK]CODLNK
     SCLASSE2 = ""
     Call LECTURE("ATY",[F:ABJ]CODTYP,"") From CONTOBJ
     Default File [F:ABJ] : Gosub VERIF_ABI
     If [F:ABJ]DIMFAT <> ""  & !find(func TEXTEBI([F:ABJ]DIMINT,[F:ABJ]DIMVALINT,LANBI),SUPPFLD1(0..NBSUP1)) & ACT
      Default File [F:ABJ] : Gosub CRE_JOINTURE  : : Gosub VERIF_CLASSE3
      DEBJOINT = "D_"+[F:ABJ]DIMFAT
      Raz SUPPFLD2,NBSUP2
      For [ABJ2]CLE Where CODDIM = [ABJ]DIMFAT
       [L]NIV = 2
       DEBJOINT = "D_"+[F:ABJ]DIMFAT
       Call LECTURE("ATY",[F:ABJ2]CODTYP,"") From CONTOBJ
       Default File [F:ABJ2] : Gosub VERIF_ABI
       If [ABJ2]DIMFAT <> "" & !find(func TEXTEBI([F:ABJ2]DIMINT,[F:ABJ2]DIMVALINT,LANBI),SUPPFLD2(0..NBSUP2)) & ACT
        Default File [F:ABJ2] : Gosub CRE_JOINTURE
        DEBJOINT = "D_"+[F:ABJ2]DIMFAT
        Raz SUPPFLD3,NBSUP3
        For [ABJ3] Where CODDIM = [ABJ2]DIMFAT
         [L]NIV = 3
         DEBJOINT = "D_"+[F:ABJ2]DIMFAT
         Call LECTURE("ATY",[F:ABJ3]CODTYP,"") From CONTOBJ
         Default File [F:ABJ3] : Gosub VERIF_ABI
         If [ABJ3]DIMFAT <> "" & !find(func TEXTEBI([F:ABJ3]DIMINT,[F:ABJ3]DIMVALINT,LANBI),SUPPFLD3(0..NBSUP3)) & ACT
          Default File [F:ABJ3] : Gosub CRE_JOINTURE
          DEBJOINT = "D_"+[F:ABJ3]DIMFAT
          Raz SUPPFLD4,NBSUP4
          For [ABJ4] Where CODDIM = [ABJ3]DIMFAT
           [L]NIV = 4
           DEBJOINT = "D_"+[F:ABJ3]DIMFAT
           Call LECTURE("ATY",[F:ABJ4]CODTYP,"") From CONTOBJ
           Default File [F:ABJ4] : Gosub VERIF_ABI
           If [ABJ4]DIMFAT <> "" & !find(func TEXTEBI([F:ABJ4]DIMINT,[F:ABJ4]DIMVALINT,LANBI),SUPPFLD4(0..NBSUP4)) & ACT
            Default File [F:ABJ4] : Gosub CRE_JOINTURE
            DEBJOINT = "D_"+[F:ABJ4]DIMFAT
            Raz SUPPFLD5,NBSUP5
            For [ABJ5] Where CODDIM = [ABJ4]DIMFAT
             [L]NIV = 5
             DEBJOINT = "D_"+[F:ABJ4]DIMFAT
             Call LECTURE("ATY",[F:ABJ5]CODTYP,"") From CONTOBJ
             Default File [F:ABJ5] : Gosub VERIF_ABI
             If [ABJ5]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD5(0..NBSUP5))& ACT
              Default File [F:ABJ5] : Gosub CRE_JOINTURE
              DEBJOINT = "D_"+[F:ABJ5]DIMFAT
              Raz SUPPFLD6,NBSUP6
              For [ABJ6] Where CODDIM = [ABJ5]DIMFAT
               [L]NIV = 6
               DEBJOINT = "D_"+[F:ABJ5]DIMFAT
               Call LECTURE("ATY",[F:ABJ6]CODTYP,"") From CONTOBJ
               Default File [F:ABJ6] : Gosub VERIF_ABI
               If [ABJ6]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD6(0..NBSUP6))& ACT
                Default File [F:ABJ6] : Gosub CRE_JOINTURE
                DEBJOINT = "D_"+[F:ABJ6]DIMFAT
                Raz SUPPFLD7,NBSUP7
                For [ABJ7] Where CODDIM = [ABJ6]DIMFAT
                 [L]NIV = 7
                 DEBJOINT = "D_"+[F:ABJ6]DIMFAT
                 Call LECTURE("ATY",[F:ABJ7]CODTYP,"") From CONTOBJ
                 Default File [F:ABJ7] : Gosub VERIF_ABI
                 If [ABJ7]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD7(0..NBSUP7))& ACT
                  Default File [F:ABJ7] : Gosub CRE_JOINTURE
                  DEBJOINT = "D_"+[F:ABJ7]DIMFAT
                  Raz SUPPFLD8,NBSUP8
                  For [ABJ8] Where CODDIM = [ABJ7]DIMFAT
                   [L]NIV = 8
                   DEBJOINT = "D_"+[F:ABJ9]DIMFAT
                   Call LECTURE("ATY",[F:ABJ8]CODTYP,"") From CONTOBJ
                   Default File [F:ABJ8] : Gosub VERIF_ABI
                   If [ABJ8]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD8(0..NBSUP8))& ACT
                    Default File [F:ABJ8] : Gosub CRE_JOINTURE
                    DEBJOINT = "D_"+[F:ABJ8]DIMFAT
                    Raz SUPPFLD9,NBSUP9
                    For [ABJ9] Where CODDIM = [ABJ8]DIMFAT
                     [L]NIV = 9
                     DEBJOINT = "D_"+[F:ABJ8]DIMFAT
                     Call LECTURE("ATY",[F:ABJ9]CODTYP,"") From CONTOBJ
                     Default File [F:ABJ9] : Gosub VERIF_ABI
                     If [ABJ9]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD9(0..NBSUP9))& ACT
                      Default File [F:ABJ9] : Gosub CRE_JOINTURE
                      DEBJOINT = "D_"+[F:ABJ9]DIMFAT
                      Raz SUPPFLD10,NBSUP10
                      For [AB10] Where CODDIM = [ABJ9]DIMFAT
                       [L]NIV = 10
                       DEBJOINT = "D_"+[F:ABJ9]DIMFAT
                       Call LECTURE("ATY",[F:AB10]CODTYP,"") From CONTOBJ
                       Default File [F:AB10] : Gosub VERIF_ABI
                       If [AB10]DIMFAT <> "" & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD10(0..NBSUP10))& ACT
                        DEBJOINT = "D_"+[F:AB10]DIMFAT
                       Elsif [F:AB10]TYPFLD=3 & func AFNC.ACTIV([F:AB10]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD10(0..NBSUP10))
                        Default File [AB10] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                        If KOOBJ : Break 12 : Endif
                       Elsif [F:AB10]TYPFLD=4 & func AFNC.ACTIV([F:AB10]ACTDIM)= 1
                        Default File [AB10] : Gosub ADD_JOIN_TECH
                        If KOOBJ : Break 12 : Endif
                       Elsif [F:AB10]TYPFLD=2 & func AFNC.ACTIV([F:AB10]ACTDIM)= 1
                        Default File [AB10] : Gosub ADD_OBJ
                        If KOOBJ : Break 12 : Endif
                       Elsif [F:AB10]TYPFLD=1 & func AFNC.ACTIV([F:AB10]ACTDIM)= 1
                        Default File [AB10] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                        If KOOBJ : Break 12 : Endif
                       Endif
                      Next AB10
                     Elsif [F:ABJ9]TYPFLD=3 & func AFNC.ACTIV([F:ABJ9]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD9(0..NBSUP9))
                      Default File [ABJ9] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                      If KOOBJ : Break 11 : Endif
                     Elsif [F:ABJ9]TYPFLD=4 & func AFNC.ACTIV([F:ABJ9]ACTDIM)= 1
                      Default File [ABJ9] : Gosub ADD_JOIN_TECH
                      If KOOBJ : Break 11 : Endif
                     Elsif [F:ABJ9]TYPFLD=2 & func AFNC.ACTIV([F:ABJ9]ACTDIM)= 1
                      Default File [ABJ9] : Gosub ADD_OBJ
                      If KOOBJ : Break 11 : Endif
                     Elsif [F:ABJ9]TYPFLD=1 & func AFNC.ACTIV([F:ABJ9]ACTDIM)= 1
                      Default File [ABJ9] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                      If KOOBJ : Break 11 : Endif
                     Endif
                    Next ABJ9
                   Elsif [F:ABJ8]TYPFLD=3 & func AFNC.ACTIV([F:ABJ8]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD8(0..NBSUP8))
                    Default File [ABJ8] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                    If KOOBJ : Break 10 : Endif
                   Elsif [F:ABJ8]TYPFLD=4 & func AFNC.ACTIV([F:ABJ8]ACTDIM)= 1
                    Default File [ABJ8] : Gosub ADD_JOIN_TECH
                    If KOOBJ : Break 10 : Endif
                   Elsif [F:ABJ8]TYPFLD=2 & func AFNC.ACTIV([F:ABJ8]ACTDIM)= 1
                    Default File [ABJ8] : Gosub ADD_OBJ
                    If KOOBJ : Break 10 : Endif
                   Elsif [F:ABJ8]TYPFLD=1 & func AFNC.ACTIV([F:ABJ8]ACTDIM)= 1
                    Default File [ABJ8] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                    If KOOBJ : Break 10 : Endif
                   Endif
                  Next ABJ8
                 Elsif [F:ABJ7]TYPFLD=3 & func AFNC.ACTIV([F:ABJ7]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD7(0..NBSUP7))
                  Default File [ABJ7] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                  If KOOBJ : Break 9 : Endif
                 Elsif [F:ABJ7]TYPFLD=4 & func AFNC.ACTIV([F:ABJ7]ACTDIM)= 1
                  Default File [ABJ7] : Gosub ADD_JOIN_TECH
                  If KOOBJ : Break 9 : Endif
                 Elsif [F:ABJ7]TYPFLD=2 & func AFNC.ACTIV([F:ABJ7]ACTDIM)= 1
                  Default File [ABJ7] : Gosub ADD_OBJ
                  If KOOBJ : Break 9 : Endif
                 Elsif [F:ABJ7]TYPFLD=1 & func AFNC.ACTIV([F:ABJ7]ACTDIM)= 1
                  Default File [ABJ7] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                  If KOOBJ : Break 9 : Endif
                 Endif
                Next ABJ7
               Elsif [F:ABJ6]TYPFLD=3 & func AFNC.ACTIV([F:ABJ6]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD6(0..NBSUP6))
                Default File [ABJ6] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                If KOOBJ : Break 8 : Endif
               Elsif [F:ABJ6]TYPFLD=4 & func AFNC.ACTIV([F:ABJ6]ACTDIM)= 1
                Default File [ABJ6] : Gosub ADD_JOIN_TECH
                If KOOBJ : Break 8 : Endif
               Elsif [F:ABJ6]TYPFLD=2 & func AFNC.ACTIV([F:ABJ6]ACTDIM)= 1
                Default File [ABJ6] : Gosub ADD_OBJ
                If KOOBJ : Break 8 : Endif
               Elsif [F:ABJ6]TYPFLD=1 & func AFNC.ACTIV([F:ABJ6]ACTDIM)= 1
                Default File [ABJ6] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
                If KOOBJ : Break 8 : Endif
               Endif
              Next ABJ6
             Elsif [F:ABJ5]TYPFLD=3 & func AFNC.ACTIV([F:ABJ5]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD5(0..NBSUP5))
              Default File [ABJ5] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
              If KOOBJ : Break 7 : Endif
             Elsif [F:ABJ5]TYPFLD=4 & func AFNC.ACTIV([F:ABJ5]ACTDIM)= 1
              Default File [ABJ5] : Gosub ADD_JOIN_TECH
              If KOOBJ : Break 7 : Endif
             Elsif [F:ABJ5]TYPFLD=2 & func AFNC.ACTIV([F:ABJ5]ACTDIM)= 1
              Default File [ABJ5] : Gosub ADD_OBJ
              If KOOBJ : Break 7 : Endif
             Elsif [F:ABJ5]TYPFLD=1 & func AFNC.ACTIV([F:ABJ5]ACTDIM)= 1
              Default File [F:ABJ5] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
              If KOOBJ : Break 7 : Endif
             Endif
            Next ABJ5
           Elsif [F:ABJ4]TYPFLD=3 & func AFNC.ACTIV([F:ABJ4]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD4(0..NBSUP4))
            Default File [ABJ4] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
            If KOOBJ : Break 6 : Endif
           Elsif [F:ABJ4]TYPFLD=4 & func AFNC.ACTIV([F:ABJ4]ACTDIM)= 1
            Default File [ABJ4] : Gosub ADD_JOIN_TECH
            If KOOBJ : Break 6 : Endif
           Elsif [F:ABJ4]TYPFLD=2 & func AFNC.ACTIV([F:ABJ4]ACTDIM)= 1
            Default File [ABJ4] : Gosub ADD_OBJ
            If KOOBJ : Break 6 : Endif
           Elsif [F:ABJ4]TYPFLD=1 & func AFNC.ACTIV([F:ABJ4]ACTDIM)= 1
            Default File [F:ABJ4] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
            If KOOBJ : Break 6 : Endif
           Endif
          Next ABJ4
         Elsif [F:ABJ3]TYPFLD=3 & func AFNC.ACTIV([F:ABJ3]ACTDIM)= 1 &  !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD3(0..NBSUP3))
          Default File [ABJ3] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
          If KOOBJ : Break 5 : Endif
         Elsif [F:ABJ3]TYPFLD=4 & func AFNC.ACTIV([F:ABJ3]ACTDIM)= 1
           Default File [ABJ3]: Gosub ADD_JOIN_TECH
          If KOOBJ : Break 5 : Endif
         Elsif [F:ABJ3]TYPFLD=2 & func AFNC.ACTIV([F:ABJ3]ACTDIM)= 1
          Default File [ABJ3] : Gosub ADD_OBJ
          If KOOBJ : Break 5 : Endif
         Elsif [F:ABJ3]TYPFLD=1 & func AFNC.ACTIV([F:ABJ3]ACTDIM)= 1
          Default File [F:ABJ3] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
          If KOOBJ : Break 5 : Endif
         Endif
        Next ABJ3
       Elsif [F:ABJ2]TYPFLD=3 & func AFNC.ACTIV([F:ABJ2]ACTDIM)= 1 & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD2(0..NBSUP2))
        Default File [ABJ2] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
        If KOOBJ : Break 4 : Endif
       Elsif [F:ABJ2]TYPFLD=4 & func AFNC.ACTIV([F:ABJ2]ACTDIM)= 1
        Default File [ABJ3] : Gosub ADD_JOIN_TECH
        If KOOBJ : Break 4 : Endif
       Elsif [F:ABJ2]TYPFLD=2 & func AFNC.ACTIV([F:ABJ2]ACTDIM)= 1
        Default File [ABJ2] : Gosub ADD_OBJ
        If KOOBJ : Break 4 : Endif
       Elsif [F:ABJ2]TYPFLD=1 & func AFNC.ACTIV([F:ABJ2]ACTDIM)= 1
        Default File [F:ABJ2] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
        If KOOBJ : Break 4 : Endif
       Endif
      Next ABJ2
     Elsif [F:ABJ]TYPFLD=3 & func AFNC.ACTIV([F:ABJ]ACTDIM)= 1 & !find(func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI),SUPPFLD1(0..NBSUP1))
      Default File [ABJ] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
      If KOOBJ : Break 3 : Endif
     Elsif [F:ABJ]TYPFLD=4 & func AFNC.ACTIV([F:ABJ]ACTDIM)= 1
      Default File [ABJ] : Gosub ADD_JOIN_TECH
      If KOOBJ : Break 3 : Endif
     Elsif [F:ABJ]TYPFLD=2 & func AFNC.ACTIV([F:ABJ]ACTDIM)= 1
      Default File [ABJ] : Gosub ADD_OBJ
      If KOOBJ : Break 3 : Endif
     Elsif [F:ABJ]TYPFLD=1 & func AFNC.ACTIV([F:ABJ]ACTDIM)= 1
      Default File [F:ABJ] : Gosub CRE_JOINTURE_STD  : Gosub ECR_JOINT
      If KOOBJ : Break 3 : Endif
     Endif
    Next ABJ
    If KOOBJ : Break 2 : Endif
    Filter [ABJ]
    Filter [ABJ2]
    Filter [ABJ3]
    Filter [ABJ4]
    Filter [ABJ5]
    Filter [ABJ6]
    Filter [ABJ7]
    Filter [ABJ8]
    Filter [ABJ9]
    Filter [AB10]
   Endif
  Endif
 Next ABK
 If KOOBJ : Break : Endif
Next ABF
Return

##########################################################################################################
#####                               Etiquettes liés aux tables de faits
##########################################################################################################
$VERIF_AUTORISATION
If [ABF]AUZFCY =2
 TABORI(NBJOINT) = "F_"+[F:ABF]CODABF
 J=find("AX3FCTFCY",TAB_DES(0..NBTAB))
 [L]TAB1= "AX3FCTFCY"
 Gosub VERIF_TAB
 TABDES(NBJOINT) = TAB_DES(NBTAB-1)
 TYPJOIN(NBJOINT)= "False,Interne"
 CLEORI(NBJOINT) = [F:ABF]FLDFCY
 CLEDES(NBJOINT) = "FCY"
 Gosub AJOUT_AUTO
 NBJOINT += 1
Endif
Return

$ECR_JOINT
If [L]FLDDES <> ""
 K= find ([L]DEBJOINT,TAB_DES(0..NBTAB))
 If K & ORD_TAB(K) > 0
  TABORI(NBJOINT) = [L]DEBJOINT+"_"+num$(ORD_TAB(K))
 Else
  TABORI(NBJOINT) = [L]DEBJOINT
 Endif
 TABDES(NBJOINT) = TAB_DES(NBTAB-1)
 Case [F]OPTJNT
  When 1  : [L]INTERNE = "Interne"
  When 2  : [L]INTERNE = "Gauche"
  When 3  : [L]INTERNE = "Droite"
  #When Default : [L]INTERNE = "Interne"
 Endcase
 TYPJOIN(NBJOINT)= [L]RACOURCI+','+[L]INTERNE   : # ccl9
 CLEORI(NBJOINT) = [F]FLDDIM
 CLEDES(NBJOINT) = [L]FLDDES
 NBJOINT += 1
Endif
Gosub ADD_OBJ
#[L]INTERNE = "Interne"
Return

$TAB_AGG
NBAGG =0
For [ABE] Where CODABF = [F:ABF]CODABF
 If func AFNC.ACTIV([F:ABE]ACTAGG)= 1
  For K=0 To dim([F:ABE]TYPAGG)-1
   JOINT_AGG2 = [F:ABE]LNKAGG(K)
   While instr(0,JOINT_AGG2,";")
    JOINT_AGG(NBAGG) = left$(JOINT_AGG2,instr(0,JOINT_AGG2,";")-1)
    NOM_AGG(NBAGG)   = [F:ABE]CODAGG
    NOM_TABAG(NBAGG) = [F:ABE]DIMAGG(K)
    JOINT_AGG2       = right$(JOINT_AGG2,instr(0,JOINT_AGG2,";")+1)
    NBAGG+=1
   Wend
   If JOINT_AGG2 <> ""
    JOINT_AGG(NBAGG) = JOINT_AGG2
    NOM_AGG(NBAGG)   = [F:ABE]CODAGG
    NIV_AGG(NBAGG)   = [F:ABE]NIVAGG
    NOM_TABAG(NBAGG) = [F:ABE]DIMAGG(K)
    NBAGG+=1
   Endif
  Next K
 Endif
Next ABE
Return

##########################################################################################################
#####                               Etiquettes liés aux table de dimensions
##########################################################################################################
$VERIF_ABI
ACT = 1
Read [ABI]ABI0 = [F]DIMFAT
If !fstat
 If func AFNC.ACTIV([ABI]CODACT) <> 1
  ACT =0 : Return
 Endif
Endif
## Verif de tout le champs de la jointure
[L]DIMCOD = [F]CODDIM
For [F:ABJ_] Where [F:ABJ_]CODDIM = [L]DIMCOD
 If [F:ABJ_]DIMFAT = [F]DIMFAT  & func TEXTEBI([F:ABJ_]DIMINT,[F:ABJ_]DIMVALINT,LANBI) = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI)
  If func AFNC.ACTIV([F:ABJ_]ACTDIM) <> 1
   ACT =0 : Break
  Endif
 Endif
Next ABJ_
Return

$CRE_JOINTURE
[L]FLDDES = ""
[L]TAB1 = "D_"+[F]DIMFAT
[L]TAB2 = [F]DIMFAT
J = find(TAB1,TAB_DES(0..NBTAB))
Gosub VERIF_TAB
K= find ([L]DEBJOINT,TAB_DES(0..NBTAB))
If K & ORD_TAB(K) > 0
 [L]DEBJOINT = [L]DEBJOINT+"_"+num$(ORD_TAB(K))
Endif
TABORI(NBJOINT) = [L]DEBJOINT
TABDES(NBJOINT) = TAB_DES(NBTAB-1)
Case [F]OPTJNT
 When 1  : [L]INTERNE = "Interne"
 When 2  : [L]INTERNE = "Gauche"
 When 3  : [L]INTERNE = "Droite"
Endcase
TYPJOIN(NBJOINT)= [L]RACOURCI+','+[L]INTERNE  : # ccl9
For [ABJ_] Where CODDIM = [L]DIMCOD
 If [F:ABJ_]DIMFAT = [F]DIMFAT  & func TEXTEBI([F:ABJ_]DIMINT,[F:ABJ_]DIMVALINT,LANBI) = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI)
  CLEORI(NBJOINT) += [F:ABJ_]FLDDIM+"-"
  CLEDES(NBJOINT) += [F:ABJ_]DIMFLD+"-"
 Endif
Next
CLEORI(NBJOINT) = left$(CLEORI(NBJOINT),len(CLEORI(NBJOINT))-1)
CLEDES(NBJOINT) = left$(CLEDES(NBJOINT),len(CLEDES(NBJOINT))-1)
NBJOINT += 1
Read [ABI2]ABI0 = TAB2
If !fstat
 CLES = [F:ABI2]CLE
 While instr(0,CLES,"+")
  CLES = right$(CLES,instr(0,CLES,"+")+1)
  I+=1
 Wend
 I +=1
Endif
If I>1
 Case NIV
  When 1  : SUPPFLD1(NBSUP1)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP1 +=1
  When 2  : SUPPFLD2(NBSUP2)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP2 +=1
  When 3  : SUPPFLD3(NBSUP3)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP3 +=1
  When 4  : SUPPFLD4(NBSUP4)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP4 +=1
  When 5  : SUPPFLD5(NBSUP5)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP5 +=1
  When 6  : SUPPFLD6(NBSUP6)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP6 +=1
  When 7  : SUPPFLD7(NBSUP7)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP7 +=1
  When 8  : SUPPFLD8(NBSUP8)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP8 +=1
  When 9  : SUPPFLD9(NBSUP9)   = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP9 +=1
  When 10 : SUPPFLD10(NBSUP10) = func TEXTEBI([F]DIMINT,[F]DIMVALINT,LANBI) : NBSUP10 +=1
 Endcase
Endif
Return


##########################################################################################################
#####                               Etiquettes liés aux creation d'objets
##########################################################################################################
$CRE_MESURE_STD
Default File [ABZ]
If [F:ABZ]TYPOPE = 2
 Gosub VERIF_CLA_INDICATEUR
 TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
 FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
 TYPOBJ(NBOBJ) = "num"
 INFOBJ(NBOBJ) = "mesure"
 NOMOBJ(NBOBJ) = func MESSBI(59,148,LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
 CLEOBJ(NBOBJ) = "compte"
 TABDEF(NBOBJ) = [F:ABF]CODABF
 CHPDEF(NBOBJ) = [F:ABZ]CODFLD
 TABDEF2(NBOBJ)= ""
 TYPDEF(NBOBJ) = "compte"
 AUTO(NBOBJ)   = ""
 NBOBJ += 1
 If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
Endif
Gosub VERIF_CLA_INDICATEUR
NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
Gosub VERIF_NOM__OBJ2
INFOBJ(NBOBJ) = "Mesure"
TYPOBJ2 =[F:ABZ]CODTYP : Gosub VERIF_TYP
Gosub VERIF_OPERATEUR
For [ABE] Where CODABF = [F:ABF]CODABF
 If func AFNC.ACTIV([F:ABE]ACTAGG)= 1
  AGGOBJ(NBOBJ) += [F:ABF]CODABF+'_'+[F:ABE]CODAGG+','+[F:ABZ]CODFLD+','
 Endif
Next ABE
AGGOBJ(NBOBJ) += "F_"+[F:ABF]CODABF+','+[F:ABZ]CODFLD
TABOBJ(NBOBJ) =  ""
FLDOBJ(NBOBJ) =  ""
TABDEF(NBOBJ) = [F:ABF]CODABF
CHPDEF(NBOBJ) = [F:ABZ]CODFLD
TABDEF2(NBOBJ)= ""
TYPDEF(NBOBJ) = ""
AUTO(NBOBJ)   = ""
Gosub ADD_TUNNEL
NBOBJ += 1
If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
Return

$CRE_INFO_STD
If [F:ABZ]INTSSC>0
 CLASSE2 = CLACOU
 CLASSE1 = func TEXTEBI([F:ABZ]INTSSC,[F:ABZ]INTVALSSC,LANBI)
 Gosub VERIF_SCLADIMSTD
Else
 CLASSE2  = ""
 SCLASSE2 = ""
Endif
If SCLASSE2 = ""
 OBJINF = func MESSBI(80,151,LANBI)-CLACOU
Else
 OBJINF = func MESSBI(80,151,LANBI)-SCLASSE2
Endif
If !find(OBJINF,NOMOBJ(0..NBOBJ-1)) & OBJINF<>""
 CLAOBJ(NBOBJ) = CLACOU
 CLAOBJ2(NBOBJ)= SCLASSE2
 TABOBJ(NBOBJ) = ""
 FLDOBJ(NBOBJ) = ""
 TYPOBJ(NBOBJ) = "Char"
 INFOBJ(NBOBJ) = "Dimension"
 NOMOBJ(NBOBJ) = OBJINF : # Infos 'classe de faits'
 TABDEF(NBOBJ) = [F:ABF]CODABF
 CLEOBJ(NBOBJ) = ""
 AUTO(NBOBJ)   = ""
 NBOBJ += 1
 If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
Endif
Default File [ABZ]
If [F:ABZ]TYPOPE = 2
 Gosub VERIF_CLA_INDICATEUR
 TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
 FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
 TYPOBJ(NBOBJ) = "num"
 INFOBJ(NBOBJ) = "mesure"
 NOMOBJ(NBOBJ) = func MESSBI(59,148,LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
 CLEOBJ(NBOBJ) = "compte"
 TABDEF(NBOBJ) = [F:ABF]CODABF
 CHPDEF(NBOBJ) = [F:ABZ]CODFLD
 TABDEF2(NBOBJ)= ""
 TYPDEF(NBOBJ) = "compte"
 AUTO(NBOBJ)   = ""
 NBOBJ += 1
 If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
Endif
CLAOBJ(NBOBJ) = CLACOU
CLAOBJ2(NBOBJ)= SCLASSE2
NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
Gosub VERIF_NOM__OBJ2
TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
INFOBJ(NBOBJ) = "Info"
TYPOBJ2 =[F:ABZ]CODTYP : Gosub VERIF_TYP
Gosub VERIF_OPERATEUR
If [F:ATY]TYPTYP = 8
 TYPOBJ(NBOBJ) = "Date"
Endif
CLEOBJ(NBOBJ) = OBJINF : # Infos 'classe de faits'
TABDEF(NBOBJ) = [F:ABF]CODABF
CHPDEF(NBOBJ) = [F:ABZ]CODFLD
TABDEF2(NBOBJ)= ""
TYPDEF(NBOBJ) = ""
AUTO(NBOBJ)   = ""
Gosub ADD_TUNNEL
NBOBJ += 1
If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
Return

$CRE_TECH_STD
If [F:ABZ]CODTYP = "ACS"
 TABORI(NBJOINT) = "F_"+[F:ABF]CODABF
 J=find("AX3ACC",TAB_DES(0..NBTAB))
 [L]TAB1= "AX3ACC"
 Gosub VERIF_TAB
 TABDES(NBJOINT) = TAB_DES(NBTAB-1)
 TYPJOIN(NBJOINT)= "False,Interne"
 CLEORI(NBJOINT) = [F:ABZ]CODFLD
 CLEDES(NBJOINT) = "ACC"
 Gosub AJOUT_AUTO
 NBJOINT += 1
Endif
Return

$CRE_DIM_STD
If [F:ABZ]TYPOPE = 2
 Gosub VERIF_CLA_INDICATEUR
 TABOBJ(NBOBJ) = "F_"+[F:ABF]CODABF
 FLDOBJ(NBOBJ) = [F:ABZ]CODFLD
 TYPOBJ(NBOBJ) = "num"
 INFOBJ(NBOBJ) = "mesure"
 NOMOBJ(NBOBJ) = func MESSBI(59,148,LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
 CLEOBJ(NBOBJ) = "compte"
 TABDEF(NBOBJ) = [F:ABF]CODABF
 CHPDEF(NBOBJ) = [F:ABZ]CODFLD
 TABDEF2(NBOBJ)= ""
 TYPDEF(NBOBJ) = "compte"
 AUTO(NBOBJ)   = ""
 NBOBJ += 1
 If NBOBJ >= MAXOBJ : KOOBJ= 1 : Return : Endif
Endif
CLAOBJ(NBOBJ) = CLACOU
CLAOBJ2(NBOBJ)= SCLASSE2
TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
FLDOBJ(NBOBJ) = [L]FLDDES
TYPOBJ2 =[F:ABZ]CODTYP : Gosub VERIF_TYP
Gosub VERIF_OPERATEUR
If FLDOBJ(NBOBJ)<> ""
 If TYPOBJ(NBOBJ) <> "Date" & TYPOBJ(NBOBJ) <> "Datestd"
  If TYPOBJ2 = "ADI"
   Read [ATB]CODFIC="ATABDIV"
   Read [ADV]CODE=[F]TABDIV
   Raz NBA,NBN
   For ZON="CODE","A1","LNGDES","SHODES"
    Case ZON
     When "LNGDES","SHODES","CODE"
      Read [ATZ]CODZONE="ATABDIV";ZON
      CLAOBJ(NBOBJ) = SCLASSE : #CLACOU
      CLAOBJ2(NBOBJ) = SCLASSE2
      TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
      TYPOBJ(NBOBJ) = "Char"
      If ZON="CODE"
       INFOBJ(NBOBJ) = "Dimension"
       NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
       Gosub VERIF_NOM__OBJ2
       NOMADI = NOMOBJ(NBOBJ)
       For K=0 To NBAGG-1
        If [F:ABZ]CODFLD = JOINT_AGG(K)
         CLAINT(NBINT)   = SCLASSE
         OBJINT(NBINT)   = NOMOBJ(NBOBJ)
         CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
         NBINT +=1
        Endif
       Next K
      Else
       INFOBJ(NBOBJ) = "Info"
       NOMOBJ(NBOBJ) = func TEXTEBI([F:ATZ]NOCOURT,"",LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
       Gosub VERIF_NOM__OBJ2
       For K=0 To NBAGG-1
        If [F:ABZ]CODFLD = JOINT_AGG(K)
         CLAINT(NBINT)   = SCLASSE
         OBJINT(NBINT)   = NOMOBJ(NBOBJ)
         CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
         NBINT +=1
        Endif
       Next K
      Endif
      CLEOBJ(NBOBJ) = [L]NOMADI
      FLDOBJ(NBOBJ) = [L]ZON
      TABDEF(NBOBJ) = [F:ABF]CODABF
      CHPDEF(NBOBJ) = [F:ABZ]CODFLD
      TABDEF2(NBOBJ)= ""
      TYPDEF(NBOBJ) = [L]ZON
      AUTO(NBOBJ)   = ""
      NBOBJ += 1
      #If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
      If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
      CHAINE = ""
     When Default

      # alphabetic columns
      For II=0 To dim([F:ADV]COLALPTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLALPDES",num$([F]TABDIV),num$(II)) From ATEXTRA
       If CHAINE<>""
        OLDTYP = TYPOBJ2
        CLAOBJ(NBOBJ)  = SCLASSE
        CLAOBJ2(NBOBJ) = SCLASSE2
        NOMOBJ(NBOBJ)  = CHAINE
        Gosub VERIF_NOM__OBJ2
        For K=0 To NBAGG-1
         If [F:ABZ]CODFLD = JOINT_AGG(K)
          CLAINT(NBINT)   = SCLASSE
          OBJINT(NBINT)   = NOMOBJ(NBOBJ)
          CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
          NBINT +=1
         Endif
        Next K
        TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
        INFOBJ(NBOBJ) = "Info"
        CLEOBJ(NBOBJ) = [L]NOMADI

        NBA +=1 :
        TYPDEF(NBOBJ) = "A"+num$(NBA)
        FLDOBJ(NBOBJ) = "A"+num$(NBA)
        TYPOBJ(NBOBJ) = "Char"
        TYPOBJ2 = OLDTYP
        TABDEF(NBOBJ) = [F:ABF]CODABF
        CHPDEF(NBOBJ) = [F:ABZ]CODFLD
        TABDEF2(NBOBJ)= ""
        AUTO(NBOBJ)   = ""
        NBOBJ += 1
        If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
       Endif
      Next

      # numeric columns
      For II=0 To dim([F:ADV]COLNUMTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLNUMDES",num$([F]TABDIV),num$(II)) From ATEXTRA
       If CHAINE<>""
        OLDTYP = TYPOBJ2
        CLAOBJ(NBOBJ)  = SCLASSE
        CLAOBJ2(NBOBJ) = SCLASSE2
        NOMOBJ(NBOBJ)  = CHAINE
        Gosub VERIF_NOM__OBJ2
        For K=0 To NBAGG-1
         If [F:ABZ]CODFLD = JOINT_AGG(K)
          CLAINT(NBINT)   = SCLASSE
          OBJINT(NBINT)   = NOMOBJ(NBOBJ)
          CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
          NBINT +=1
         Endif
        Next K
        TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
        INFOBJ(NBOBJ) = "Info"
        CLEOBJ(NBOBJ) = [L]NOMADI
        NBN +=1 :
        TYPDEF(NBOBJ) = "N"+num$(NBN)
        FLDOBJ(NBOBJ) = "N"+num$(NBN)
        Call LECTURE("ATY",[F:ADV]COLNUMTYP(II),"") From CONTOBJ
        If [F:ATY]TYPTYP = 1 : TYPOBJ(NBOBJ) = "Char"
        Else                 : TYPOBJ(NBOBJ) = "Num"
        Endif
        TYPOBJ2 = OLDTYP
        TABDEF(NBOBJ) = [F:ABF]CODABF
        CHPDEF(NBOBJ) = [F:ABZ]CODFLD
        TABDEF2(NBOBJ)= ""
        AUTO(NBOBJ)   = ""
        NBOBJ += 1
        If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
       Endif
      Next
    Endcase
   Next ZON
   Raz NOMADI
  Elsif TYPOBJ2 = "ADS"
   INFOBJ(NBOBJ) = "Dimension"
   NOMOBJ(NBOBJ) = func TEXTEBI([ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
   Gosub VERIF_NOM__OBJ2
   TABDEF(NBOBJ) = [F:ABF]CODABF
   CHPDEF(NBOBJ) = [F:ABZ]CODFLD
   TABDEF2(NBOBJ)= ""
   TYPDEF(NBOBJ) = ""
   AUTO(NBOBJ)   = ""
   NBOBJ += 1
   If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
   CLAOBJ(NBOBJ) = CLAOBJ(NBOBJ-1)
   CLAOBJ2(NBOBJ) = SCLASSE2
   NOMOBJ(NBOBJ) = func MESSBI(82,123,LANBI) : # Intitulé
   Gosub VERIF_NOM__OBJ2
   TABOBJ(NBOBJ) = TABOBJ(NBOBJ-1)
   TABDEF(NBOBJ) = [F:ABF]CODABF : # ccl1
   CHPDEF(NBOBJ) = [F:ABZ]CODFLD : # ccl1
   TABDEF2(NBOBJ)= ""
   TYPDEF(NBOBJ) = "ADXDOS"
   TYPOBJ(NBOBJ) = "Char"
   FLDOBJ(NBOBJ) = "ADXDOS"
   INFOBJ(NBOBJ) = "Info"
   CLEOBJ(NBOBJ) = NOMOBJ(NBOBJ-1)
   AUTO(NBOBJ)   = ""
   NBOBJ += 1
   If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  Else
   NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
   Gosub VERIF_NOM__OBJ2
   [L]INFOBJ(NBOBJ) = "Dimension"
   If [F:ATY]TYPTYP = 1
    TYPOBJ(NBOBJ) = "Num"
    For K=0 To NBAGG-1
     If [F:ABZ]CODFLD = JOINT_AGG(K) & NIV_AGG(K) = 1
      CLAINT(NBINT)   = CLACOU
      OBJINT(NBINT)   = NOMOBJ(NBOBJ)
      CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
      NBINT +=1
     Endif
    Next K
    TABDEF(NBOBJ) = [F:ABF]CODABF
    CHPDEF(NBOBJ) = [F:ABZ]CODFLD
    TABDEF2(NBOBJ)= ""
    TYPDEF(NBOBJ) = "LANNUM"
    AUTO(NBOBJ)   = ""
    NBOBJ += 1
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
    CLAOBJ(NBOBJ) = CLAOBJ(NBOBJ-1)
    CLAOBJ2(NBOBJ) = SCLASSE2
    NOMOBJ(NBOBJ) = func MESSBI(82,123,LANBI)-NOMOBJ(NBOBJ-1) : # Intitulé nom objet
    Gosub VERIF_NOM__OBJ2
    TYPOBJ(NBOBJ) = "Char"
    TABOBJ(NBOBJ) = TABOBJ(NBOBJ-1)
    FLDOBJ(NBOBJ) = "LANMES"
    INFOBJ(NBOBJ) = "Info"
    CLEOBJ(NBOBJ) = NOMOBJ(NBOBJ-1)
   Endif
   TABDEF(NBOBJ) = [F:ABF]CODABF
   CHPDEF(NBOBJ) = [F:ABZ]CODFLD
   TABDEF2(NBOBJ)= ""
   If [F:ATY]TYPTYP = 1
    TYPDEF(NBOBJ) = "LANMES"
   Else
    TYPDEF(NBOBJ) = ""
   Endif
   AUTO(NBOBJ)   = ""
   NBOBJ += 1
   If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  Endif
 Elsif [L]TYPOBJ(NBOBJ) = "Date" | [L]TYPOBJ(NBOBJ) = "Datestd"
  NOMOBJ(NBOBJ) = func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
  Gosub VERIF_NOM__OBJ2
  For K=0 To NBAGG-1
   If [F:ABZ]CODFLD = JOINT_AGG(K) & NIV_AGG(K) = 1
    CLAINT(NBINT)   = CLACOU
    OBJINT(NBINT)   = NOMOBJ(NBOBJ)
    CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
    NBINT +=1
   Endif
  Next K
  [L]INFOBJ(NBOBJ) = "Dimension"
  TABDEF(NBOBJ) = [F:ABF]CODABF
  CHPDEF(NBOBJ) = [F:ABZ]CODFLD
  TABDEF2(NBOBJ)= ""
  If [L]TYPOBJ(NBOBJ) = "Date"
   TYPDEF(NBOBJ) = FLDOBJ(NBOBJ)
   If len([F]TYPDAT) = 3 & instr(0,[F]TYPDAT,"Q") & instr(0,[F]TYPDAT,"Y") & instr(0,[F]TYPDAT,"M")
    TYPDEF(NBOBJ) = ""
   Endif
  Else
   If [F:ABZ]TYPDAT = "C"
    TYPDEF(NBOBJ) = ""
   Else
    TYPDEF(NBOBJ) = FLDOBJ(NBOBJ)
   Endif
  Endif
  If [F:ABM]DATNUL = 2 : TUNNEL(NBOBJ) = "NULL" : Endif
  AUTO(NBOBJ)   = ""
  NBOBJ += 1
  CLEDAT = NOMOBJ(NBOBJ-1)
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  If [L]TYPOBJ(NBOBJ-1) = "Datestd"
   For IDAT = 8,6,5
    Gosub TYPDAT2
    CLAOBJ(NBOBJ) = CLACOU
    CLAOBJ2(NBOBJ)= SCLASSE2
    NOMOBJ(NBOBJ) = func MESSBI(IDAT,7825,LANBI)-func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
    Gosub VERIF_NOM__OBJ2
    CLEOBJ(NBOBJ) = CLEDAT
    TYPOBJ(NBOBJ) = "NumStd"
    TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
    FLDOBJ(NBOBJ) = [L]DATFLD
    INFOBJ(NBOBJ) = "Dimension"
    TABDEF(NBOBJ) = [F:ABF]CODABF
    CHPDEF(NBOBJ) = [F:ABZ]CODFLD
    TABDEF2(NBOBJ)= ""
    TYPDEF(NBOBJ) = [L]DATFLD
    Case IDAT
     When 8 : TYPDEF(NBOBJ)+="_YSTD"
     When 6 : TYPDEF(NBOBJ)+="_QSTD"
     When 5 : TYPDEF(NBOBJ)+="_MSTD"
    Endcase
    AUTO(NBOBJ)   = ""
    NBOBJ += 1
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
   Next
  Endif
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  TDAT=[F:ABZ]TYPDAT
  While TDAT<> ""
   Gosub TYPDAT
   If DATFLD<>""
    CLAOBJ(NBOBJ) = CLACOU
    CLAOBJ2(NBOBJ)= SCLASSE2
    NOMOBJ(NBOBJ) = func MESSBI(IDAT,7825,LANBI)+"_"+func TEXTEBI([F:ABZ]INTFLD,[F:ABZ]INTVALFLD,LANBI)
    Gosub VERIF_NOM__OBJ2
    For K=0 To NBAGG-1
     If [F:ABZ]CODFLD = JOINT_AGG(K)
      If IDAT > =  NIV_AGG(K)
       CLAINT(NBINT)   = CLACOU
       OBJINT(NBINT)   = NOMOBJ(NBOBJ)
       CLAAGG(NBINT)   = [F:ABF]CODABF+'_'+NOM_AGG(K)
       NBINT +=1
      Endif
     Endif
    Next K
    CLEOBJ(NBOBJ) = CLEDAT
    TYPOBJ(NBOBJ) = "Char"
    TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
    FLDOBJ(NBOBJ) = [L]DATFLD
    INFOBJ(NBOBJ) = "Info"
    TABDEF(NBOBJ) = [F:ABF]CODABF
    CHPDEF(NBOBJ) = [F:ABZ]CODFLD
    TABDEF2(NBOBJ)= ""
    TYPDEF(NBOBJ) = [L]DATFLD
    AUTO(NBOBJ)   = ""
    NBOBJ += 1
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
   Endif
   TDAT = right$(TDAT,2)
  Wend
 Endif
Endif
Return

$ADD_OBJ
CLAOBJ(NBOBJ) = [L]SCLASSE
CLAOBJ2(NBOBJ)= [L]SCLASSE2
TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
If [L]FLDDES <> ""
 FLDOBJ(NBOBJ) = [L]FLDDES
Else
 FLDOBJ(NBOBJ) = [F]FLDDIM
Endif
Gosub CRE_OBJET
Return

$ADD_TUNNEL
If [F:ABZ]TUNNEL =2
 Read [F:ATY]CODTYP = [F:ABZ]CODTYP
 If !fstat & [F:ATY]OBJLIEN <> ""
  Read [AOB]ABREV = [F:ATY]OBJLIEN
  If !fstat
   Read [AFC]CODINT = "GES"+[F:AOB]ABREV
   If !fstat
    [L]TUNNEL(NBOBJ) = "GES"+[F:AOB]ABREV
   Endif
  Endif
 Endif
Endif
Return

$CRE_OBJET
Case [F]TYPFLD
 When 1,3  : [L]INFOBJ(NBOBJ) = "Dimension"
 When 2    : [L]INFOBJ(NBOBJ) = "Info"
 When Default
Endcase
If [L]FLDDES <> "" & [F]TYPFLD = 3
 [L]INFOBJ(NBOBJ) = "Info"
Endif
TYPOBJ2 =[F]CODTYP : Gosub VERIF_TYP
Gosub VERIF_OPERATEUR
If [L]INFOBJ(NBOBJ) = "Info" & [L]FLDDES=""
 CLEOBJ(NBOBJ) = ""
 Read [ABJ_]ABJ1 = [F]CODDIM ;[F]FLDLIE
 If !fstat
  Local Integer Y
  For Y=0 To NBOBJ
   If TABOBJ(Y)=TAB_DES(NBTAB-1) & FLDOBJ(Y)=[ABJ_]FLDDIM
    CLEOBJ(NBOBJ) = NOMOBJ(Y)
    Break
   Endif
  Next
  If CLEOBJ(NBOBJ) = ""
   If COMPLEMENT<>""
    CLEOBJ(NBOBJ) = func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)-COMPLEMENT
   Else
    CLEOBJ(NBOBJ) = SCLASSE+"."+func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)
   Endif
   J2=find(CLEOBJ(NBOBJ),NOMOBJ(0..NBOBJ))
   CLEOBJ(NBOBJ) = func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)
   J=find(CLEOBJ(NBOBJ),VERF_NOM(0..NBVERF))
   If J & ORD_NOM(J) > 0
    CLEOBJ(NBOBJ) = CLEOBJ(NBOBJ)+"_"+num$(ORD_NOM(J))
    J1=find(CLEOBJ(NBOBJ),NOMOBJ(0..NBOBJ))
   Elsif J
    CLEOBJ(NBOBJ) = CLEOBJ(NBOBJ)
    J3=find(CLEOBJ(NBOBJ),NOMOBJ(0..NBOBJ))
   Endif
   If J2 > J3 & J2>J1
    If COMPLEMENT<>""
     CLEOBJ(NBOBJ) = func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)-COMPLEMENT
    Else
     CLEOBJ(NBOBJ) = SCLASSE+"."+func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)
    Endif
   Elsif J1>J2 & J1 >J3
    J= find(func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI),VERF_NOM(0..NBVERF))
    CLEOBJ(NBOBJ) = func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)+string$(ORD_NOM(J)>0,"_"+num$(ORD_NOM(J)))
   Else
    CLEOBJ(NBOBJ) = func TEXTEBI([F:ABJ_]INTDIM,[F:ABJ_]INTVALDIM,LANBI)
   Endif
  Endif
 Endif
Endif
If [L]TYPOBJ(NBOBJ) = "Date" | [L]TYPOBJ(NBOBJ) = "Datestd"
 NOMOBJ(NBOBJ) = func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
 Gosub VERIF_NOM__OBJ2
 If [L]INFOBJ(NBOBJ) = "Dimension"
  TABDEF(NBOBJ) = [F:ABF]CODABF
  CHPDEF(NBOBJ) =  FLDOBJ(NBOBJ)
  Gosub NOM_UNIQUE
  TYPDEF(NBOBJ)  = ""
  If [F:ABM]DATNUL = 2 : TUNNEL(NBOBJ) = "NULL" : Endif
  AUTO(NBOBJ)   = func TEXTEBI([F]AUTO,[F]AUTOEVAL,LANBI)
  NBOBJ += 1
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  CLEDAT = NOMOBJ(NBOBJ-1)
  If [L]TYPOBJ(NBOBJ-1) = "Datestd"
   For IDAT = 8,6,5
    Gosub TYPDAT2
    CLAOBJ(NBOBJ) = [L]SCLASSE
    CLAOBJ2(NBOBJ)= SCLASSE2
    NOMOBJ(NBOBJ) = func MESSBI(IDAT,7825,LANBI)-func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
    Gosub VERIF_NOM__OBJ2
    CLEOBJ(NBOBJ) = CLEDAT
    TYPOBJ(NBOBJ) = "NumStd"
    TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
    FLDOBJ(NBOBJ) = [L]DATFLD
    INFOBJ(NBOBJ) = "Dimension"
    TABDEF(NBOBJ) = [F:ABF]CODABF
    CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
    TABDEF2(NBOBJ)= "" : # add Gosub Nom_UNIQUE 104638
    TYPDEF(NBOBJ) = FLDOBJ(NBOBJ)
    Case IDAT
     When 8 : TYPDEF(NBOBJ)+="_YSTD"
     When 6 : TYPDEF(NBOBJ)+="_QSTD"
     When 5 : TYPDEF(NBOBJ)+="_MSTD"
    Endcase
    AUTO(NBOBJ)   = ""
    NBOBJ += 1
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
   Next
  Endif
  TDAT=[F]TYPDAT
  While TDAT<> ""
   Gosub TYPDAT
   If DATFLD <> ""
    CLAOBJ(NBOBJ) = [L]SCLASSE
    CLAOBJ2(NBOBJ)= SCLASSE2
    NOMOBJ(NBOBJ) = func MESSBI(IDAT,7825,LANBI)+"_"+func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
    Gosub VERIF_NOM__OBJ2
    CLEOBJ(NBOBJ) = CLEDAT
    TYPOBJ(NBOBJ) = "Char"
    TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
    FLDOBJ(NBOBJ) = [L]DATFLD
    INFOBJ(NBOBJ) = "Info"
    TABDEF(NBOBJ) = [F:ABF]CODABF
    CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
    Gosub NOM_UNIQUE
    TYPDEF(NBOBJ)  = FLDOBJ(NBOBJ)
    AUTO(NBOBJ)   = ""
    NBOBJ += 1
    If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
   Endif
   TDAT = right$(TDAT,2)
  Wend
 Endif
Elsif TYPOBJ(NBOBJ) <> "Date"
 If TYPOBJ2 = "ADI"
  Read [ATB]CODFIC="ATABDIV"
  Read [ADV]CODE=[F]TABDIV
  Raz NBA,NBN
  For ZON="CODE","A1","LNGDES","SHODES"
    Case ZON
    When "LNGDES","SHODES","CODE"
     Read [ATZ]CODZONE="ATABDIV";ZON
     CLAOBJ(NBOBJ) = [L]SCLASSE
     CLAOBJ2(NBOBJ)= SCLASSE2
     TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
     TYPOBJ(NBOBJ) = "Char"
     If ZON="CODE"
      INFOBJ(NBOBJ) = "Dimension"
      NOMOBJ(NBOBJ) = func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
      Gosub VERIF_NOM__OBJ2
      [L]NOMADI = NOMOBJ(NBOBJ)
      CLEOBJ(NBOBJ) = ""
      AUTO(NBOBJ)   = func TEXTEBI([F]AUTO,[F]AUTOEVAL,LANBI)
     Else
      INFOBJ(NBOBJ) = "Info"
      NOMOBJ(NBOBJ) = func TEXTEBI([F:ATZ]NOCOURT,"",LANBI)-func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
      Gosub VERIF_NOM__OBJ2
      CLEOBJ(NBOBJ) = [L]NOMADI
      AUTO(NBOBJ)   = ""
     Endif
     FLDOBJ(NBOBJ) = ZON
     TABDEF(NBOBJ) = [F:ABF]CODABF
     CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
     Gosub NOM_UNIQUE
     TYPDEF(NBOBJ)  = ZON
     NBOBJ += 1
     If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
     CHAINE = ""
    When Default

      # alphabetic columns
      For II=0 To dim([F:ADV]COLALPTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLALPDES",num$([F]TABDIV),num$(II)) From ATEXTRA
       If CHAINE<>""
        OLDTYP = TYPOBJ2
        CLAOBJ(NBOBJ) = [L]SCLASSE
        CLAOBJ2(NBOBJ)= SCLASSE2
        NOMOBJ(NBOBJ) = CHAINE
        Gosub VERIF_NOM__OBJ2
        TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
        INFOBJ(NBOBJ) = "Info"
        CLEOBJ(NBOBJ) = [L]NOMADI
        NBA +=1
        TYPOBJ(NBOBJ) = "Char"
        FLDOBJ(NBOBJ) = "A"+num$(NBA)
        TYPDEF(NBOBJ) = "A"+num$(NBA)
        TYPOBJ2 = OLDTYP
        TABDEF(NBOBJ) = [F:ABF]CODABF
        CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
        Gosub NOM_UNIQUE
        AUTO(NBOBJ)   = ""
        NBOBJ += 1
        If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
       Endif
      Next

      # numeric columns
      For II=0 To dim([F:ADV]COLNUMTYP)-1
       Call LECTEXTRA(CHAINE,"ATABTAB","COLNUMDES",num$([F]TABDIV),num$(II)) From ATEXTRA
       If CHAINE<>""
        OLDTYP = TYPOBJ2
        CLAOBJ(NBOBJ) = [L]SCLASSE
        CLAOBJ2(NBOBJ)= SCLASSE2
        NOMOBJ(NBOBJ) = CHAINE
        Gosub VERIF_NOM__OBJ2
        TABOBJ(NBOBJ) = TAB_DES(NBTAB-1)
        INFOBJ(NBOBJ) = "Info"
        CLEOBJ(NBOBJ) = [L]NOMADI
        NBN +=1
        FLDOBJ(NBOBJ) = "N"+num$(NBN)
        TYPDEF(NBOBJ) = "N"+num$(NBN)
        Call LECTURE("ATY",[F:ADV]COLNUMTYP(II),"") From CONTOBJ
        If [F:ATY]TYPTYP = 1 : TYPOBJ(NBOBJ) = "Char"
        Else                 : TYPOBJ(NBOBJ) = "Num"
        Endif
        TYPOBJ2 = OLDTYP
        TABDEF(NBOBJ) = [F:ABF]CODABF
        CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
        Gosub NOM_UNIQUE
        AUTO(NBOBJ)   = ""
        NBOBJ += 1
        If NBOBJ > MAXOBJ : KOOBJ= 1 : Break : Endif
       Endif
      Next
   Endcase
  Next ZON
  Raz NOMADI
 Elsif TYPOBJ2 = "ADS"
  NOMOBJ(NBOBJ) = func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
  Gosub VERIF_NOM__OBJ2
  TABDEF(NBOBJ) = [F:ABF]CODABF
  CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
  Gosub NOM_UNIQUE
  TYPDEF(NBOBJ)  = ""
  AUTO(NBOBJ)   = func TEXTEBI([F]AUTO,[F]AUTOEVAL,LANBI)
  NBOBJ += 1
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  CLAOBJ(NBOBJ) = CLAOBJ(NBOBJ-1)
  CLAOBJ2(NBOBJ)= SCLASSE2
  NOMOBJ(NBOBJ) = func MESSBI(82,123,LANBI) : # Intitulé
  Gosub VERIF_NOM__OBJ2
  TYPOBJ(NBOBJ) = "Char"
  TABOBJ(NBOBJ) = TABOBJ(NBOBJ-1)
  FLDOBJ(NBOBJ) = "ADXDOS"
  INFOBJ(NBOBJ) = "Info"
  CLEOBJ(NBOBJ) = NOMOBJ(NBOBJ-1)
  TABDEF(NBOBJ) = [F:ABF]CODABF
  CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
  Gosub NOM_UNIQUE
  TYPDEF(NBOBJ)  = "ADXDOS"
  AUTO(NBOBJ)   = ""
  NBOBJ += 1
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
 Else
  NOMOBJ(NBOBJ) = func TEXTEBI([F]INTDIM,[F]INTVALDIM,LANBI)
  Gosub VERIF_NOM__OBJ2
  TABDEF(NBOBJ) = [F:ABF]CODABF
  CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
  Gosub NOM_UNIQUE
  TYPDEF(NBOBJ)  = ""
  Gosub ADD_TUNNEL2
  AUTO(NBOBJ)   = func TEXTEBI([F]AUTO,[F]AUTOEVAL,LANBI)
  NBOBJ += 1
  If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  If left$(TABOBJ(NBOBJ-1),6) = "AX3MNL"
   CLAOBJ(NBOBJ) = CLAOBJ(NBOBJ-1)
   CLAOBJ2(NBOBJ)= SCLASSE2
   NOMOBJ(NBOBJ) = func MESSBI(82,123,LANBI)-NOMOBJ(NBOBJ-1) : # Intitulé nom objet
   Gosub VERIF_NOM__OBJ2
   TYPOBJ(NBOBJ) = "Char"
   TABOBJ(NBOBJ) = TABOBJ(NBOBJ-1)
   FLDOBJ(NBOBJ) = "LANMES"
   INFOBJ(NBOBJ) = "Info"
   CLEOBJ(NBOBJ) = NOMOBJ(NBOBJ-1)
   TABDEF(NBOBJ) = [F:ABF]CODABF
   CHPDEF(NBOBJ) = FLDOBJ(NBOBJ)
   Gosub NOM_UNIQUE
   TYPDEF(NBOBJ)  = "LANMES"
   AUTO(NBOBJ)   = ""
   NBOBJ += 1
   If NBOBJ > MAXOBJ : KOOBJ= 1 : Return : Endif
  Endif
 Endif
Endif
If [L]FLDDES <> ""
 TAB_DES(NBTAB) = TAB_DES(NBTAB-2)
 NBTAB +=1
 Raz FLDDES
Endif
Return

$ADD_TUNNEL2
If [F]TUNNEL = 2
 Read [F:ATY]CODTYP = [F]CODTYP
 If !fstat & [F:ATY]OBJLIEN <> ""
  Read [AOB]ABREV = [F:ATY]OBJLIEN
  If !fstat
   Read [AFC]CODINT = "GES"+[F:AOB]ABREV
   If !fstat
    [L]TUNNEL(NBOBJ) = "GES"+[F:AOB]ABREV
   Endif
  Endif
 Endif
Else
 For J=0 To NBJOI
  If LIENS2(J) = [F]FLDDIM
   Read [ABZ2]ABZ1 = [ABF]CODABF;LIENS1(J)
   If !fstat & [F:ABZ2]TUNNEL = 2
    Read [F:ATY]CODTYP = [F:ABZ2]CODTYP
    If !fstat & [F:ATY]OBJLIEN <> ""
     Read [AOB]ABREV = [F:ATY]OBJLIEN
     If !fstat
      Read [AFC]CODINT = "GES"+[F:AOB]ABREV
      If !fstat
       [L]TUNNEL(NBOBJ) = "GES"+[F:AOB]ABREV
      Endif
     Endif
    Endif
   Endif
  Endif
 Next J
Endif
Return

$NOM_UNIQUE
CHPDEF(NBOBJ) = [F:ABZ]CODFLD
Case [L]NIV
 When 1 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM
 When 2 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM
 When 3 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM
 When 4 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM
 When 5 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM
 When 6 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM+";"+[F:ABJ6]CODDIM+";"+[F:ABJ6]FLDDIM
 When 7 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM+";"+[F:ABJ6]CODDIM+";"+[F:ABJ6]FLDDIM+";"
&                 +[F:ABJ7]CODDIM+";"+[F:ABJ7]FLDDIM
 When 8 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM+";"+[F:ABJ6]CODDIM+";"+[F:ABJ6]FLDDIM+";"
&                 +[F:ABJ7]CODDIM+";"+[F:ABJ7]FLDDIM+";"+[F:ABJ8]CODDIM+";"+[F:ABJ8]FLDDIM
 When 9 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM+";"+[F:ABJ6]CODDIM+";"+[F:ABJ6]FLDDIM+";"+[F:ABJ7]CODDIM+";"
&                 +[F:ABJ7]FLDDIM+";"+[F:ABJ8]CODDIM+";"+[F:ABJ8]FLDDIM+";"+[F:ABJ9]CODDIM+";"+[F:ABJ9]FLDDIM
 When 10 :
  TABDEF2(NBOBJ) = [F:ABJ]CODDIM+";"+[F:ABJ]FLDDIM+";"+[F:ABJ2]CODDIM+";"+[F:ABJ2]FLDDIM+";"+[F:ABJ3]CODDIM+";"+[F:ABJ3]FLDDIM+";"
&                 +[F:ABJ4]CODDIM+";"+[F:ABJ4]FLDDIM+";"+[F:ABJ5]CODDIM+";"+[F:ABJ5]FLDDIM+";"+[F:ABJ6]CODDIM+";"+[F:ABJ6]FLDDIM+";"+[F:ABJ7]CODDIM+";"
&                 +[F:ABJ7]FLDDIM+";"+[F:ABJ8]CODDIM+";"+[F:ABJ8]FLDDIM+";"+[F:ABJ9]CODDIM+";"+[F:ABJ9]FLDDIM+";"+[F:AB10]CODDIM+";"+[F:AB10]FLDDIM
Endcase
Return

##########################################################################################################
#####                               Etiquettes diverses
##########################################################################################################
$CRE_JOINTURE_STD
Raz [L]FLDDES
Call LECTURE("ATY",[F]CODTYP,"") From CONTOBJ
If [F:ATY]TYPTYP = 8
 J=find("AX3DAT",TAB_DES(0..NBTAB))
 [L]TAB1= "AX3DAT"
 Gosub VERIF_TAB
 FLDDES = 'DATDAT'
Elsif [F:ATY]TYPTYP = 1
 If [F:ATY]NOLIB > 0
  J=find("AX3MNL"+num$([F:ATY]NOLIB),TAB_DES(0..NBTAB))
  [L]TAB1= "AX3MNL"+num$([F:ATY]NOLIB)
  Gosub VERIF_TAB
  [L]FLDDES = 'LANNUM'
 Elsif [F]MENLOC > 0
  J=find("AX3MNL"+num$([F]MENLOC),TAB_DES(0..NBTAB))
  [L]TAB1= "AX3MNL"+num$([F]MENLOC)
  Gosub VERIF_TAB
  [L]FLDDES = 'LANNUM'
 Endif
Elsif [F]CODTYP = "ADI"
 If func AFNC.ACTIV([ABZ]ACTFLD)= 1 : # codact actif
  J=find("AX3ADI"+num$([F]TABDIV),TAB_DES(0..NBTAB))
  [L]TAB1 = "AX3ADI"+num$([F]TABDIV)
  Gosub VERIF_TAB
  [L]FLDDES = 'CODE'
 Endif
Elsif [F]CODTYP = "ACS"
 If func AFNC.ACTIV([ABZ]ACTFLD)= 1 : # codact actif
  J=find("AX3ACC",TAB_DES(0..NBTAB))
  [L]TAB1 = "AX3ACS"
  Gosub VERIF_TAB
  Gosub AJOUT_AUTO
  [L]FLDDES = 'ACC'
 Endif
Elsif [F]CODTYP = "ADS"
 If func AFNC.ACTIV([ABZ]ACTFLD)= 1 : # codact actif
  J=find("AX3DOS",TAB_DES(0..NBTAB))
  [L]TAB1 = "AX3DOS"
  Gosub VERIF_TAB
  [L]FLDDES = 'CODDOS'
 Endif
Endif
Return

$VERIF_TAB
If !J
 TAB_DES(NBTAB) = [L]TAB1
 NBTAB +=1
Else
 ORD_TAB(J) +=1
 TAB_DES(NBTAB) = [L]TAB1+"_"+num$(ORD_TAB(J))
 NBTAB +=1
Endif
Return

$VERIF_LIENS
LIENS = [F:ABK]EXPLNK
AUZAGG = ""
I=0 : ACT =1 : NBJOI =0
Raz LIENS1, LIENS2
While instr(0,LIENS,";")
 LIENS1(I) = left$(LIENS,instr(0,LIENS,";")-1)
 LIENS     = right$(LIENS,instr(0,LIENS,";")+1)
 If LIENS1(I) = [F:ABF]FLDFCY
  AUZAGG = LIENS1(I)
 Endif
 I+=1
Wend
If LIENS = [F:ABF]FLDFCY & AUZAGG = ""
 AUZAGG = LIENS
Endif
LIENS1(I) = LIENS
For J=0 To I
 Read [ABZ]ABZ1 = [F:ABF]CODABF;LIENS1(I)
 If !fstat & func AFNC.ACTIV([F:ABZ]ACTFLD) <> 1
  ACT =0
  Break
 Endif
Next J
If !ACT : Raz LIENS1,LIENS2 : Return : Endif
### Si tou ok au niveau de codact alors on continue
NBJOI = I
Read [ABI]ABI0 = [F:ABK]CODLNK
If !fstat
 If func AFNC.ACTIV([F:ABI]CODACT) <> 1 : ACT =0 : Return : Endif
 I=0
 LIENS = [F:ABI]CLE
 While instr(0,LIENS,"+") & ( (NBJOI>I & [F:ABK]OPTJNT=1) or ([F:ABK]OPTJNT<>1))
  LIENS2(I) = left$(LIENS,instr(0,LIENS,"+")-1)
  LIENS     = right$(LIENS,instr(0,LIENS,"+")+1)
  I+=1
 Wend
 If I=0 & instr(0,LIENS,"+")
  LIENS2(I) = left$(LIENS,instr(0,LIENS,"+")-1)
 Else
  LIENS2(I) = LIENS
 Endif
Endif
Return

$AJOUT_CLA_INDICATEUR
CLASSE(NBCLASSE) = func MESSBI(116,148,LANBI)-[L]CLASSE1+","+[L]CLASSE1
THECLAIND = func MESSBI(116,148,LANBI)-[L]CLASSE1
NBCLASSE +=1
Return

$VERIF_CLA_INDICATEUR
If [F:ABM]MESURE <> 2
 CLAOBJ(NBOBJ)  = CLACOU
 CLAOBJ2(NBOBJ) = ""
 Return
Endif
If [F:ABM]SCLASS <> 2 or [F:ABZ]INTSSC=0
 CLAOBJ(NBOBJ)  = CLACOU
 CLAOBJ2(NBOBJ) = func MESSBI(116,148,LANBI)-CLACOU
 Return
Endif
Local Integer J3
CLASSE1= func MESSBI(116,148,LANBI)-func TEXTEBI([F:ABZ]INTSSC,[F:ABZ]INTVALSSC,LANBI)
J3=find(func TEXTEBI([F:ABZ]INTSSC,[F:ABZ]INTVALSSC,LANBI),S_CLAIND(0..NBSCLAIND))
If !J3
 S_CLAIND(NBSCLAIND) = func TEXTEBI([F:ABZ]INTSSC,[F:ABZ]INTVALSSC,LANBI) : NBSCLAIND+=1
 J=find(CLASSE1+","+CLACOU,CLASSE(0..NBCLASSE))
 If !J
  CLASSE(NBCLASSE) = CLASSE1+","+CLACOU
  NBCLASSE +=1
 Endif
Endif
CLAOBJ(NBOBJ)  = CLACOU
CLAOBJ2(NBOBJ) = CLASSE1
Return

$VERIF_CLASSE3
If [F:ABM]SCLASS <> 2
 SCLASSE2 = ""
 Return
Endif
Local Integer J3
Raz XINTIT,XINTVAL
If func TEXTEBI([F:ABJ]DIMINT,[F:ABJ]DIMVALINT,LANBI) = ""
 XINTIT  = [F:ABI]INTIT
 XINTVAL = [F:ABI]INTEVAL
Else
 XINTIT  = [F:ABJ]DIMINT
 XINTVAL = [F:ABJ]DIMVALINT
Endif
J3=find(func TEXTEBI(XINTIT,XINTVAL,LANBI),S_CLASSE(0..NBSCLASSE))
If !J3
 CLASSE1= func TEXTEBI(XINTIT,XINTVAL,LANBI)
 J=find(CLASSE1+","+SCLASSE,CLASSE(0..NBCLASSE))
 If !J
  CLASSE(NBCLASSE) = CLASSE1+","+SCLASSE
  NBCLASSE +=1
 Else
  Local Integer NUM
  NUM = find(CLASSE1-SCLASSE+","+SCLASSE,CLASSE(0..NBCLASSE))
  If !NUM
   CLASSE(NBCLASSE) = CLASSE1-SCLASSE+","+SCLASSE
   CLASSE1 = CLASSE1-SCLASSE
   NBCLASSE +=1
  Else
   ORD_CLASSE(J) +=1
   CLASSE1 = CLASSE1-SCLASSE+"_"+num$(ORD_CLASSE(J))
   CLASSE(NBCLASSE) =CLASSE1+","+SCLASSE
   NBCLASSE +=1
  Endif
 Endif
Else
 CLASSE1 = ""
Endif
SCLASSE2  = CLASSE1
Return

$VERIF_SCLADIMSTD
If [F:ABM]SCLASS <> 2
 SCLASSE2 = ""
 Return
Endif
Local Integer J3
J3=find(CLASSE1+','+CLASSE2,CLASSE(0..NBCLASSE))
If !J3
 CLASSE(NBCLASSE) = [L]CLASSE1+","+[L]CLASSE2
 TABCLA(NBCLASSE) = [L]CLASSE1
 NBCLASSE +=1
Endif
SCLASSE2  = [L]CLASSE1
Return


$VERIF_CLASSE2  : # classe dimension
J=find(CLASSE2,CLASSE(0..NBCLASSE))
Goto VERIF_CLA

$VERIF_CLASSE  :  # classe tbf
J=find(CLASSE1,CLASSE(0..NBCLASSE))
Goto VERIF_CLA

$VERIF_CLA
If !J
 If CLASSE2<> ""
  CLASSE(NBCLASSE) = [L]CLASSE1+","+[L]CLASSE2
 Else
  CLASSE(NBCLASSE) = [L]CLASSE1
 Endif
 TABCLA(NBCLASSE) = [L]CLASSE1
 NBCLASSE +=1
Else
 J=find(CLASSE1,TABCLA(0..NBCLASSE))
 If !J
  CLASSE(NBCLASSE) = CLASSE1+","+CLASSE2
  TABCLA(NBCLASSE) = [L]CLASSE1
 Else
  Local Integer NUM
  NUM = find(CLASSE1-CLASSE2+","+CLASSE2,CLASSE(0..NBCLASSE))
  If !NUM
   CLASSE(NBCLASSE) =CLASSE1-CLASSE2+","+CLASSE2
   CLASSE1 = CLASSE1-CLASSE2
  Else
   ORD_CLASSE(J) +=1
   CLASSE1 = CLASSE1-CLASSE2+"_"+num$(ORD_CLASSE(J))
   CLASSE(NBCLASSE) =CLASSE1+","+CLASSE2
  Endif
 Endif
 NBCLASSE +=1
Endif
SCLASSE = CLASSE1
GASCLASSE = SCLASSE
Raz CLASSE1,CLASSE2
Return

$VERIF_NOM_OBJ
J= find(NOMOBJ(NBOBJ),VERF_NOM(0..NBVERF))
If !J
 VERF_NOM(NBVERF) =NOMOBJ(NBOBJ)
 NBVERF +=1
Else
 ORD_NOM(J) +=1
 NOMOBJ(NBOBJ) = NOMOBJ(NBOBJ)+"_"+num$(ORD_NOM(J))
Endif
Return

$VERIF_NOM__OBJ2 : # Pour les dimensions afin  d'alliaser les champs avec le nom qui va bien
J= find(NOMOBJ(NBOBJ),VERF_NOM(0..NBVERF))
If !J
 VERF_NOM(NBVERF) =NOMOBJ(NBOBJ)
 NBVERF +=1
Else
 Local Integer KK
 KK = find(SCLASSE+"."+NOMOBJ(NBOBJ),VERF_NOM(0..NBVERF))
 If COMPLEMENT <> ""
  If !find(NOMOBJ(NBOBJ)-COMPLEMENT,VERF_NOM(0..NBVERF))
   VERF_NOM(NBVERF) =   NOMOBJ(NBOBJ)-COMPLEMENT
   NOMOBJ(NBOBJ)    =   NOMOBJ(NBOBJ)-COMPLEMENT
   NBVERF +=1
  Elsif !KK
   VERF_NOM(NBVERF) =   SCLASSE+"."+NOMOBJ(NBOBJ)
   NOMOBJ(NBOBJ)    =   SCLASSE+"."+NOMOBJ(NBOBJ)
   NBVERF +=1
  Else
   ORD_NOM(J) +=1
   NOMOBJ(NBOBJ) = NOMOBJ(NBOBJ)+"_"+num$(ORD_NOM(J))
  Endif
 Elsif !KK
  VERF_NOM(NBVERF) =   SCLASSE+"."+NOMOBJ(NBOBJ)
  NOMOBJ(NBOBJ)    =   SCLASSE+"."+NOMOBJ(NBOBJ)
  NBVERF +=1
 Else
  ORD_NOM(J) +=1
  NOMOBJ(NBOBJ) = NOMOBJ(NBOBJ)+"_"+num$(ORD_NOM(J))
 Endif
Endif
Return

$VERIF_TYP
If TYPOBJ2 ="ADI"
 [L]TYPOBJ(NBOBJ) = "Char"
Else
 Call LECTURE("ATY",TYPOBJ2,"") From CONTOBJ
 Case [F:ATY]TYPTYP
  When 1
   If [L]INFOBJ(NBOBJ)="Dimension" : [L]TYPOBJ(NBOBJ) = "Num"
   Else                            : [L]TYPOBJ(NBOBJ) = "Char"
   Endif
  When 2,3       : [L]TYPOBJ(NBOBJ) = "Num"
  When 4,5,6     : [L]TYPOBJ(NBOBJ) = "Num"
   #If [L]INFOBJ(NBOBJ)="Mesure   " : [L]TYPOBJ(NBOBJ) = "Num"
   #Else                            : [L]TYPOBJ(NBOBJ) = "Numdcb"
   #Endif
  When 7         : [L]TYPOBJ(NBOBJ) = "Char"
  When 8
   If instr(0,[F]TYPDAT,"C")
    [L]TYPOBJ(NBOBJ) = "Datestd"
   Else
    [L]TYPOBJ(NBOBJ) = "Date"
   Endif
  When Default   : [L]TYPOBJ(NBOBJ) = "Char"
 Endcase
Endif
Return

$VERIF_OPERATEUR
If INFOBJ(NBOBJ) = "Dimension" | [L]TYPOBJ(NBOBJ) = "Char"
 [L]OPEOBJ(NBOBJ) = ""
Else
 Case [F:ABZ]TYPOPE
  When 1 : [L]OPEOBJ(NBOBJ) = "Somme"
  When 2 : [L]OPEOBJ(NBOBJ) = "Moyenne"
  When 3 : [L]OPEOBJ(NBOBJ) = "Minimun"
 Endcase
Endif
Return

$TYPDAT2
Case IDAT
 When 1 : TDAT = "D"
 When 2 : TDAT = "W"
 When 3 : TDAT = "T"
 When 4 : TDAT = "F"
 When 5 : TDAT = "M"
 When 6 : TDAT = "Q"
 When 7 : TDAT = "S"
 When 8 : TDAT = "Y"
 When 9 : TDAT = ""
Endcase
$TYPDAT
Case mid$(TDAT,1,1)
 When "D" : DATFLD = "DATDAY" : IDAT = 1
 When "W" : DATFLD = "DATWEK" : IDAT = 2
 When "T" : DATFLD = "DATDEC" : IDAT = 3
 When "F" : DATFLD = "DATQUI" : IDAT = 4
 When "M" : DATFLD = "DATMOI" : IDAT = 5
 When "Q" : DATFLD = "DATTRE" : IDAT = 6
 When "S" : DATFLD = "DATSIX" : IDAT = 7
 When "Y" : DATFLD = "DATYEA" : IDAT = 8
 When "C" : DATFLD = ""       : IDAT = 0
Endcase
Return

$ADD_JOIN_TECH
If [F]CODTYP = "ACS"
 K= find ([L]DEBJOINT,TAB_DES(0..NBTAB))
 If K & ORD_TAB(K) > 0
  TABORI(NBJOINT) = [L]DEBJOINT+"_"+num$(ORD_TAB(K))
 Else
  TABORI(NBJOINT) = [L]DEBJOINT
 Endif
 J=find("AX3ACC",TAB_DES(0..NBTAB))
 [L]TAB1= "AX3ACC"
 Gosub VERIF_TAB
 TABDES(NBJOINT) = TAB_DES(NBTAB-1)
 TYPJOIN(NBJOINT)= "False,"+[L]INTERNE
 CLEORI(NBJOINT) = [F]FLDDIM
 CLEDES(NBJOINT) = "ACC"
 Gosub AJOUT_AUTO
 NBJOINT += 1
Endif
Return

$FLD_LIENS
Raz  FLD_LIENS,NB_FLDLIENS,LIENS
For [ABK] Where CODABF = [ABF]CODABF
LIENS = [F:ABK]EXPLNK
While instr(0,LIENS,";")
 FLD_LIENS(NB_FLDLIENS) = left$(LIENS,instr(0,LIENS,";")-1)
 LIENS     = right$(LIENS,instr(0,LIENS,";")+1)
 NB_FLDLIENS+=1
Wend
FLD_LIENS(NB_FLDLIENS) = LIENS
Next ABK
Raz LIENS
Return

$AJOUT_AUTO
AUTODEB(NBAUTO) = "F_"+[F:ABF]CODABF
AUTOTAB(NBAUTO) = TAB_DES(NBTAB-1)
NBAUTO +=1
Return

Funprog TEXTEBI(NUMERO,INTEVAL,LANBI)
Value Integer NUMERO
Value Char    INTEVAL
Value Char    LANBI
If INTEVAL = ""
 Read [ATX]NUMERO = LANBI;NUMERO
 If !fstat
  End vireblc([F:ATX]TEXTE,1)
 Else
  Read [ATX]NUMERO = GLANGUE;NUMERO
  If !fstat
   End vireblc([F:ATX]TEXTE,1)
  Else
   Read [ATX]NUMERO = GLANDEF;NUMERO
   If !fstat
    End vireblc([F:ATX]TEXTE,1)
   Else
    End ""
   Endif
  Endif
 Endif
Else
 Local Char INTITULE(80)
 Onerrgo ERRS
 INTITULE = evalue(INTEVAL)
 INTITULE = ctrans(INTITULE,"'","")
 Onerrgo
 End vireblc(INTITULE,1)
Endif
End

$ERRS
INTITULE = ""
Resume

Funprog MESSBI(LANNUM,LANCHP,LANBI)
Value Integer LANNUM
Value Integer LANCHP
Value Char    LANBI
Read [F:AST]CLE = LANCHP;LANNUM;LANBI
If !fstat
 End [F:AST]LANMES
Else
 End mess(LANNUM,LANCHP,1)
Endif
End

