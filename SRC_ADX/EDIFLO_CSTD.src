#********************************************************************
# Method MET_POST_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_POST_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "flow"
  Local Char WKEY(250)          : WKEY = this.FLOCOD+"~"+this.FLOREL
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIFLO"
  Endif
  Gosub JSON_DELETE From EDILIBC
  Gosub JSON_CREATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_PUT_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_PUT_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WREP(20)           : WREP = ""
  If this.APARENT <> null
    WREP = this.APARENT.AINF.NAMCLA
  Else
    WREP = "R_EDIFLO"
  Endif
  Gosub JSON_UPDATE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_DEL_JSON
#********************************************************************
#*
#* @param WERR
#* @return WOK
#*!
$MET_DEL_JSON
  Local Integer WOK             : WOK = [V]CST_AOK
  Local Char WENTITY_TYPE(30)   : WENTITY_TYPE = "flow"
  Local Char WKEY(250)          : WKEY = this.FLOCOD+"~"+this.FLOREL
  Gosub JSON_DELETE From EDILIBC
  ARET_VALUE = WOK
Return

#********************************************************************
# Method MET_VALIDATE
#********************************************************************
# Step 1 : Analyse lines
# Step 2 : Update Valid flag
#********************************************************************
$MET_VALIDATE
  Local Integer WOK    : WOK = [V]CST_ATRUE
  Local Integer WNBERR : WNBERR = 0
  Local Char WERR(250) : WERR = ""
  Local Integer WRET_VALUE
  Local Integer I

#  WOK = fmet this.MET_UNVALIDATE()

  #test the protocol is valid
  If this.PTCVALID = [V]CST_ANO
    WNBERR = WNBERR + 1
    #"Invalid protocol"
    WERR = mess(44,2006,1)
    ASTATUS = fmet this.ASETERROR("PTCVALID",WERR,[V]CST_AWARNING)
  Endif

  Local Integer WNBLINE : WNBLINE = 0
  For I = 1 To maxtab(this.EFLD)
    If this.EFLD(I)<>null  & this.EFLD(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLD(I).ASTALIN <> [V]CST_ADEL
      WNBLINE = WNBLINE + 1
    Endif
  Next

  #test 1 : count nb line to validate
  If WNBLINE <= 0
    WNBERR = WNBERR + 1
    #"No line defined"
    WERR = mess(63,2006,1)
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AWARNING)
  Elsif WNBLINE > 1 #V1 only
    WNBERR = WNBERR + 1
    #"Only one line can be setup"
    WERR = mess(71,2006,1)
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Elsif WNBLINE = 1 #for further version : Elsif WNBLINE >= 1
    For I = 1 To maxtab(this.EFLD)
      If this.EFLD(I)<>null  and this.EFLD(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLD(I).ASTALIN <> [V]CST_ADEL
        WNBLINE = WNBLINE + 1
        If this.EFLD(I).PTCCOD="": this.EFLD(I).PTCCOD= this.PTCCOD: Endif        ### SAM 110699

        If WNBERR = 0
          #test 3 : tester les lignes
          WOK = func TEST_MSGDIR(this.EFLD(I))
          If WOK <> [V]CST_AOK
            #ASETERROR is made into func
            WNBERR = WNBERR + 1
          Endif

          If this.EFLD(I).MSGFILNOR = ""
            #ASETERROR is made into func
            WNBERR = WNBERR + 1
          Endif

          #test 4 : test that the message mapping is valid
          Local File EDIMSG [EMS]
          Read [EMS]EMS0 = this.EFLD(I).MSGCOD;this.EFLD(I).MSGREL
          If !fstat
            If [EMS]VALID <> [V]CST_AYES
              WNBERR = WNBERR + 1
              #"Invalid Message mapping setup"
              WERR = mess(43,2006,1)
              ASTATUS = fmet this.EFLD(I).ASETERROR("MSGREL",WERR,[V]CST_AWARNING)
            Endif
          Endif
          LogicClose File [EMS]

          #test 5 : test that the sequential files are valid
          If this.EFLD(I).MSGFOR=1
            Local File EDISEQFIL [ESF]
            Read [ESF]ESF0 = this.EFLD(I).MSGCOD;this.EFLD(I).MSGREL;this.EFLD(I).MSGFILNOR
            If !fstat
              If [ESF]VALID <> [V]CST_AYES
                WNBERR = WNBERR + 1
                #"Invalid Sequential file setup"
                WERR = mess(45,2006,1)
                ASTATUS = fmet this.EFLD(I).ASETERROR("MSGFILNOR",WERR,[V]CST_AWARNING)
              Endif
            Else
              Local File EDIXMLFIL [EXF]
              Read [EXF]EXF0 = this.EFLD(I).MSGCOD;this.EFLD(I).MSGREL;this.EFLD(I).MSGFILNOR #MSGFILXML
              If !fstat
                If [EXF]VALID <> [V]CST_AYES
                  WNBERR = WNBERR + 1
                  #"Invalid XML file setup"
                  WERR = mess(160,2006,1)
                  ASTATUS = fmet this.EFLD(I).ASETERROR("MSGFILNOR",WERR,[V]CST_AWARNING)
                Endif
              Endif
              LogicClose File [EXF]
            Endif
          Endif
        Endif
      Endif
    Next
  Endif


  # ckecking EFLA class
  If WNBERR=0 and this.EFLA<>null and this.CATACT=1
    For I=1 To maxtab(this.EFLA)
      If this.EFLA(I)<>null & this.EFLA(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLA(I).ASTALIN <> [V]CST_ADEL
        Case  this.EFLA(I).GENFLG
          When 1: If this.EFLA(I).FICNAM=""
                    WNBERR+=1
                    WERR = mess(10,123,1) # Mandatory field
                    ASTATUS = fmet this.EFLA(I).ASETERROR("FICNAM",WERR,[V]CST_AERROR)
                  Endif
                  If this.EFLA(I).FICNAM<>"" and this.EFLA(I).FICVOL=""
                    WNBERR+=1
                    WERR = mess(10,123,1) # Mandatory field
                    ASTATUS = fmet this.EFLA(I).ASETERROR("FICVOL",WERR,[V]CST_AERROR)
                  Endif
          When 2: If this.EFLA(I).FIXNAM=2 and this.EFLA(I).FICNAM=""
                    WNBERR+=1
                    WERR = mess(10,123,1) # Mandatory field
                    ASTATUS = fmet this.EFLA(I).ASETERROR("FICNAM",WERR,[V]CST_AERROR)
                  Endif
        Endcase
      Endif
    Next
  Endif

  # ckecking EFLA class
  If WNBERR=0 and this.CATACT=1
    If this.EFLP<>null
      For I=1 To maxtab(this.EFLP)
        If this.EFLP(I)<>null & this.EFLP(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLP(I).ASTALIN <> [V]CST_ADEL
          If this.EFLP(I).ALIAS="" and this.EFLP(I).CONSTANT=""
             WNBERR+=1
             WERR = "ALIAS/CONSTANT:" -mess(10,123,1) # Mandatory field
             ASTATUS = fmet this.EFLP(I).ASETERROR("ALIAS",WERR,[V]CST_AERROR)
             Endif
        Endif
      Next
    Endif
  Endif

  If WNBERR > 0
    WOK = fmet this.MET_UNVALIDATE()
  Else
    # Set Valid
    this.VALID = [V]CST_AYES
  Endif

  If this.VALID = [V]CST_AYES
    WRET_VALUE = [V]CST_ATRUE
  Else
    WRET_VALUE = [V]CST_AFALSE
  Endif

  ARET_VALUE = WRET_VALUE

Return

#********************************************************************
# Method MET_UNVALIDATE
#********************************************************************
# Unvalidate the flow
#********************************************************************
$MET_UNVALIDATE
  Local Integer WOK : WOK = [V]CST_AOK

  this.VALID  = [V]CST_ANO
  this.FLGACT = [V]CST_ANO

#  WOK = fmet this.AUPDATE()

  ARET_VALUE = WOK
Return

#####################################################################

#********************************************************************
# Funprog TEST_MSGDIR
#********************************************************************
#
#* Test if the MSGDIR is OK or not
#* @param WOBJECT --> OBJECT
#* @return WOK    --> Status [V]CST_AOK/[V]CST_AERROR
#*!
Funprog TEST_MSGDIR(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK     : WOK = [V]CST_AOK
  Local Char WERR(250)  : WERR = ""
  Local Integer WMAXTAB : WMAXTAB = 0
  Local Integer I, J

#V1 : Sens is set by the Message mapping Sens property
#If Action on flow is “Issue”, Message Mapping Sens must be “Send”, if Sens is not set to “Send” then error
#If Action on flow is “Receipt”, Message Mapping Sens must be “Receive”, if Sens is not set to “Receive” then error

  If WOBJECT.MSGCOD <> "" and WOBJECT.MSGREL <> ""
    If WOBJECT.APARENT.CATACT = 1 #1:Send / 2:Receive
      If WOBJECT.MSGDIR <> 1 #1:Issue / 2:Receipt
        #"Sense doesn't match with action"
        WERR = mess(77,2006,1)
        ASTATUS = fmet WOBJECT.ASETERROR("MSGDIR",WERR,[V]CST_AERROR)
        WOK = [V]CST_AERROR
      Endif
    Elsif WOBJECT.APARENT.CATACT = 2 #1:Send / 2:Receive
      If WOBJECT.MSGDIR <> 2 #1:Issue / 2:Receipt
         #"Sense doesn't match with action"
         WERR = mess(77,2006,1)
        ASTATUS = fmet WOBJECT.ASETERROR("MSGDIR",WERR,[V]CST_AERROR)
        WOK = [V]CST_AERROR
      Endif
    Endif
  Endif

End WOK


#********************************************************************
# Funprog GET_VALID_FLAG_EDIPTC
#********************************************************************
#
#* Get the VALID flag from EDIPTC
#* @param WPTCCOD
#* @return WVALID
#*!
Funprog GET_VALID_FLAG_EDIPTC(WPTCCOD)
Value Char WPTCCOD
  Local Integer WVALID

  Local File EDIPTC [EPT]
  Read [EPT]EPT0 = WPTCCOD
  If !fstat
    WVALID = [EPT]VALID
  Else
    WVALID = [V]CST_ANO
  Endif
  LogicClose File [EPT]
End WVALID

#********************************************************************
# Funprog GET_VALID_FLAG_EDIMSG
#********************************************************************
#
#* Get the VALID flag from EDIMSG
#* @param WMSGCOD
#* @param WMSGREL
#* @return WVALID
#*!
Funprog GET_VALID_FLAG_EDIMSG(WMSGCOD, WMSGREL)
Value Char WMSGCOD
Value Char WMSGREL
  Local Integer WVALID
  Local File EDIMSG [EMS]
  Read [EMS]EMS0 = WMSGCOD;WMSGREL
  If !fstat
    WVALID = [EMS]VALID
  Else
    WVALID = [V]CST_ANO
  Endif
  LogicClose File [EMS]
End WVALID

#********************************************************************
# Funprog GET_VALID_FLAG_EDISEQFIL
#********************************************************************
#
#* Get the VALID flag from EDISEQFIL
#* @param WMSGCOD
#* @param WMSGREL
#* @param WMSGFILNOR
#* @return WVALID
#*!
Funprog GET_VALID_FLAG_EDISEQFIL(WMSGCOD, WMSGREL, WMSGFILNOR)
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR
  Local Integer WVALID
  Local File EDISEQFIL [ESF]
  Read [ESF]ESF0 = WMSGCOD;WMSGREL;WMSGFILNOR
  If !fstat
    WVALID = [ESF]VALID
  Else
    WVALID = [V]CST_ANO
  Endif
  LogicClose File [ESF]
End WVALID


##********************************************************************
## Funprog GET_VALID_FLAG_EDIXMLFIL
##********************************************************************
##
##* Get the VALID flag from EDIXMLFIL
##* @param WMSGCOD
##* @param WMSGREL
##* @param WMSGFILXML
##* @return WVALID
##*!
Funprog GET_VALID_FLAG_EDIXMLFIL(WMSGCOD, WMSGREL, WMSGFILNOR)        ### SAM 110699
Value Char WMSGCOD
Value Char WMSGREL
Value Char WMSGFILNOR
  Local Integer WVALID
  Local File EDIXMLFIL [EXF]
  Read [EXF]EXF0 = WMSGCOD;WMSGREL;WMSGFILNOR
  If !fstat
    WVALID = [EXF]VALID
  Else
    WVALID = [V]CST_ANO
  Endif
  LogicClose File [EXF]
End WVALID

####################################################################################
# Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)

Funprog CHECK_CR(CR)
Variable Char CR

Local Integer WCROK
Local File AREPORT [ARP]
  Read [ARP]ARP0=CR
  If fstat<>[V]CST_AOK
    WCROK=1
  Endif
LogicClose File [ARP]
End WCROK

#-----------------------------
Funprog CHECK_DESTIN(DESTIN)
Variable Char DESTIN

Local Integer WDESTINOK
Local File APRINTER [AIM]
  Read [AIM]AIM0=DESTIN
  If fstat=[V]CST_AOK
    If [F:AIM]PRT=4
      WDESTINOK=0
    Else
      WDESTINOK=2
    Endif
  Else
    WDESTINOK=1
  Endif
LogicClose File [AIM]
End WDESTINOK

#********************************************************************
# Subprog CHARGE_CR_PARAM
#********************************************************************
#
#* Charge CR parameters
#* @param WOBJECT --> OBJECT
#* @param WRUSED  --> CR to use
#* @param WNUM    --> Line number
#*!
Subprog CHARGE_CR_PARAM(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WNBPAR, WSEQ
  Local Char WERR(250), WREP(20), CRNAM(20): CRNAM=WOBJECT.CRUSED
  Local Char CHAINE(100)
  Local File AREPORTD [ARD]
  Local File ATEXTE [ATX]

  Local File EDIMSG [EMS]
  Read [EMS]EMS0=WOBJECT.APARENT.EFLD.MSGCOD;WOBJECT.APARENT.EFLD.MSGREL
  If fstat=[V]CST_AOK
    WREP=[F:EMS]REPCOD
  Else
    WERR = mess(1646,10032,1) # Representation not found: {0}
    ASTATUS = fmet WOBJECT.APARENT.EFLA(WNUM).ASETERROR("CRUSED",WERR,[V]CST_AERROR)
    WOK = [V]CST_AERROR
  Endif

  LogicClose File  [EMS]
  Filter [ARD] Where RPTCOD=CRNAM
  WNBPAR= rowcount([F:ARD])
  If WNBPAR>0
    For [ARD]
      If [F:ARD]PARSAI=2
        WSEQ = fmet WOBJECT.APARENT.ADDLINE('EFLP',[V]CST_ALASTPOS)
        WOBJECT.APARENT.EFLP(WSEQ).FLOCOD=WOBJECT.APARENT.FLOCOD
        WOBJECT.APARENT.EFLP(WSEQ).FLOREL=WOBJECT.APARENT.FLOREL
        WOBJECT.APARENT.EFLP(WSEQ).NUMSEQ=WSEQ
        WOBJECT.APARENT.EFLP(WSEQ).PARNAM=[F:ARD]PARCOD
        WOBJECT.APARENT.EFLP(WSEQ).CODREP=WREP
        Read [ATX]NUMERO=WOBJECT.ACTX.LAN;[F:ARD]PARNAM
        If fstat=[V]CST_AOK
          WOBJECT.APARENT.EFLP(WSEQ).PARDES=[F:ATX]TEXTE
        Endif
        Local File ATYPE [ATY]
        Read [ATY]CODTYP=[F:ARD]PARTYP
        If fstat=[V]CST_AOK
          WOBJECT.APARENT.EFLP(WSEQ).VALTYPE=[F:ATY]TYPTYP
        Else
          WOBJECT.APARENT.EFLP(WSEQ).VALTYPE=7
        Endif
        LogicClose File [ATY]
        If len([F:ARD]PARCOD)>2
          If right$([F:ARD]PARCOD,(1+len([F:ARD]PARCOD))-3)="deb"
            CHAINE=left$([F:ARD]PARCOD,len([F:ARD]PARCOD)-3)+"fin"
            WSEQ = fmet WOBJECT.APARENT.ADDLINE('EFLP',[V]CST_ALASTPOS)
            WOBJECT.APARENT.EFLP(WSEQ).FLOCOD=WOBJECT.APARENT.FLOCOD
            WOBJECT.APARENT.EFLP(WSEQ).FLOREL=WOBJECT.APARENT.FLOREL
            WOBJECT.APARENT.EFLP(WSEQ).NUMSEQ=WSEQ
            WOBJECT.APARENT.EFLP(WSEQ).PARNAM=CHAINE
            WOBJECT.APARENT.EFLP(WSEQ).CODREP=WREP
            WOBJECT.APARENT.EFLP(WSEQ).VALTYPE=WOBJECT.APARENT.EFLP(WSEQ-1).VALTYPE
          Endif
        Endif
      Endif
    Next
  Endif

  LogicClose File [ARD], [ATX]
End

#-----------------------------
Funprog CHECK_PARAM(WOBJECT)
Variable Instance WOBJECT Using OBJECT

Local Integer I, WNBGEN: WNBGEN=0

  For I=1 To maxtab(WOBJECT.APARENT.EFLA)
    If WOBJECT.APARENT.EFLA(I)<>null and WOBJECT.APARENT.EFLA(I).ASTALIN <> [V]CST_ANEWDEL and WOBJECT.APARENT.EFLA(I).ASTALIN <> [V]CST_ADEL
      If WOBJECT.APARENT.EFLA(I).GENFLG=2: WNBGEN+=1: Endif
    Endif
  Next

End WNBGEN

