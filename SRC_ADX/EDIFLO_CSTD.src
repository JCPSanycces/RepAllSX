#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIFLO                                                           #
# Manages main class EDIFLO (this) and child class EDIFLOD (abbrev. EFLD)     #
# Author : JUCON+RBA                                                          #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
     Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE
        When "AINSERT_CONTROL_AFTER"   : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"   : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"   : Gosub ADELETE_CONTROL_AFTER
        When "AREAD_AFTER"             : Gosub AREAD_AFTER
      Endcase
    When "EFLD"
      Case [L]AEVENT
        When "AREAD_AFTER"             : Gosub EFLD_AREAD_AFTER
        When "ADDLINE_BEFORE"          : Gosub EFLD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"           : Gosub EFLD_ADDLINE_AFTER
        When "ADELLINE_AFTER"          : Gosub EFLD_ADELLINE_AFTER
      Endcase
    When "EFLA"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"          : Gosub EFLA_ADDLINE_BEFORE
        When "ADDLINE_AFTER"           : Gosub EFLA_ADDLINE_AFTER
        When "ADELLINE_AFTER"          : Gosub EFLA_ADELLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_VALIDATE"            : Gosub MET_VALIDATE
    When "MET_UNVALIDATE"          : Gosub MET_UNVALIDATE
    When "MET_POST_JSON"           : Gosub MET_POST_JSON
    When "MET_PUT_JSON"            : Gosub MET_PUT_JSON
    When "MET_DEL_JSON"            : Gosub MET_DEL_JSON
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "FLOCOD"
      Case [L]ARULE
        When "CONTROL" : Gosub FLOCOD_CONTROL
      Endcase
    When "FLOREL"
      Case [L]ARULE
        When "CONTROL" : Gosub FLOREL_CONTROL
      Endcase
    When "FLGACT"
      Case [L]ARULE
        When "CONTROL"    : Gosub FLGACT_CONTROL
      Endcase
    When "PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub PARCOD_PROPAGATE
      Endcase
    When "PARTYP"
      Case [L]ARULE
        When "INIT"      : Gosub PARTYP_INIT
      Endcase
    When "CATCOD"
      Case [L]ARULE
        When "INIT"      : Gosub CATCOD_INIT
        When "CONTROL"   : Gosub CATCOD_CONTROL
        When "PROPAGATE" : Gosub CATCOD_PROPAGATE
      Endcase
    When "CATTYP"
      Case [L]ARULE
        When "INIT"      : Gosub CATTYP_INIT
      Endcase
    When "PTCCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub PTCCOD_CONTROL
        When "PROPAGATE" : Gosub PTCCOD_PROPAGATE
      Endcase
    When "CATACT"
      Case [L]ARULE
        When "INIT"      : Gosub CATACT_INIT
        When "PROPAGATE" : Gosub CATACT_PROPAGATE
      Endcase
    When "CACHEUUID"
      Case [L]ARULE
        When "INIT"      : Gosub CACHEUUID_INIT
      Endcase
    When "EFLD.MSGCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLD_MSGCOD_CONTROL
        When "PROPAGATE" : Gosub EFLD_MSGCOD_PROPAGATE
      Endcase
    When "EFLD.MSGREL"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLD_MSGREL_CONTROL
        When "PROPAGATE" : Gosub EFLD_MSGREL_PROPAGATE
      Endcase
    When "EFLD.PTCCOD"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLD_PTCCOD_CONTROL
        When "PROPAGATE" : Gosub EFLD_PTCCOD_PROPAGATE
      Endcase
    When "EFLD.MSGDIR"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLD_MSGDIR_CONTROL
      Endcase
    When "EFLD.MSGFOR"
      Case [L]ARULE
        When "INIT"       : Gosub EFLD_MSGFOR_INIT
        When "PROPAGATE"  : Gosub EFLD_MSGFOR_PROPAGATE  #SAM 112148
      Endcase
    When "EFLD.MSGFILNOR"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLD_MSGFILNOR_CONTROL
        When "PROPAGATE" : Gosub EFLD_MSGFILNOR_PROPAGATE
      Endcase
    When "EFLD.SIGNATURE"   ## Ini X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)
      Case [L]ARULE
        When "PROPAGATE" : Gosub EFLD_SIGNATURE_PROPAGATE
      Endcase               ## End X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)
   # Init Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
    When "EFLA.GENFLG"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLA_GENFLG_CONTROL
        When "PROPAGATE" : Gosub EFLA_GENFLG_PROPAGATE
      Endcase
    When "EFLA.FIXNAM"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EFLA_FIXNAM_PROPAGATE
      Endcase
    When "EFLA.CRUSED"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLA_CRUSED_CONTROL
        When "PROPAGATE" : Gosub EFLA_CRUSED_PROPAGATE
      Endcase
    When "EFLA.DESTIN"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLA_DESTIN_CONTROL
      Endcase
    When "EFLA.FICNAM"
      Case [L]ARULE
        When "CONTROL" : Gosub EFLA_FICNAM_CONTROL
      Endcase
    When "EFLA.FICVOL"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLA_FICVOL_CONTROL
        When "PROPAGATE" : Gosub EFLA_FICVOL_PROPAGATE
      Endcase
    When "EFLP.ALIAS"
      Case [L]ARULE
        When "CONTROL"   : Gosub EFLP_ALIAS_CONTROL
        When "PROPAGATE" : Gosub EFLP_ALIAS_PROPAGATE
    Endcase
    # End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
  Endcase
Return

####################################################################

$FLOCOD_CONTROL
  If this.FLOCOD <> ""
  #  this.FLOCOD = format$("Kv4:20B",toupper(this.FLOCOD))
    this.FLOCOD = func EDILIBA.FORMATVAL("FLOCOD", this.FLOCOD)
  Endif
Return

####################################################################

$FLOREL_CONTROL
  If this.FLOREL <> ""
  #  this.FLOREL = format$("Kv4:5B",toupper(this.FLOREL))
    this.FLOREL = func EDILIBA.FORMATVAL("FLOREL", this.FLOREL)
  Endif
Return

####################################################################

$FLGACT_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  WERR = ""

  If this.FLGACT = [V]CST_AYES and this.VALID = [V]CST_ANO
    this.FLGACT = [V]CST_ANO
    #"Invalid flow"
    WERR = mess(41,2006,1)
    ASTATUS = fmet this.ASETERROR("FLGACT",WERR,[V]CST_AWARNING)
  Endif
Return


####################################################################

$PARCOD_PROPAGATE
  Local Integer WOK
  WOK = fmet this.MET_UNVALIDATE()
#  this.VALID = [V]CST_ANO

  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PARTYP = fmet this.ACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP")
  this.CATCOD = ""
Return

####################################################################

$PARTYP_INIT
  this.PARTYP = 2
Return

####################################################################

$CATCOD_INIT
  this.CATCOD = ""
Return

$CATCOD_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  If this.PARCOD <> "" and this.CATCOD <> ""
    If func EDILIBA.CATEGORY_IS_AUTHORIZED(this.PARCOD, this.CATCOD, WERR) = [V]CST_AFALSE
      ASTATUS = fmet this.ASETERROR("CATCOD",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

$CATCOD_PROPAGATE
  Local Integer WCATACT

  If this.CATCOD <> ""
    this.CATTYP = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATTYP")
    this.CATACT = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATACT")
    this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  Else
    this.CATTYP = 1
    this.CATACT = 1
    this.CATDES = ""
  Endif

  Call DELETELINES(this, "EFLD") From EDILIBA

  Local File EDIPARTNERD [EPRD]
  Filter [EPRD] Where PARCOD = this.PARCOD
  For [EPRD]
    If [EPRD]CATCOD = this.CATCOD
      this.PTCCOD = [EPRD]PTCCOD
      Break
    Endif
  Next
  LogicClose File [EPRD]
Return

####################################################################

$CATTYP_INIT
  this.CATTYP = 1
Return

####################################################################

$PTCCOD_CONTROL
  If this.PTCCOD <> ""
  #  this.PTCCOD=format$("Kv4:20B",toupper(this.PTCCOD))
    this.PTCCOD = func EDILIBA.FORMATVAL("PTCCOD", this.PTCCOD)
  Endif
Return

$PTCCOD_PROPAGATE
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
#  this.PTCVALID = fmet this.ACTX.ACACHE.EPT.AGETVALNUM(this.PTCCOD,"VALID")
  this.PTCVALID = func GET_VALID_FLAG_EDIPTC(this.PTCCOD)
  If this.EFLD<>null    # JCC pte
    this.EFLD(1).PTCCOD=this.PTCCOD
  Endif
Return

####################################################################

$CATACT_INIT
  this.CATACT = 1
Return

$CATACT_PROPAGATE
  Local Integer WOK
  WOK = fmet this.MET_UNVALIDATE()
#  this.VALID = [V]CST_ANO
#  this.FLGACT = [V]CST_ANO


  #tester les lignes
  Local Integer WOK    : WOK = [V]CST_AOK
  Local Integer I
  For I = 1 To maxtab(this.EFLD())
    If this.EFLD(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLD(I).ASTALIN <> [V]CST_ADEL
      WOK = func TEST_MSGDIR(this.EFLD(I))
    Endif
  Next I

Return

####################################################################

$CACHEUUID_INIT
  this.CACHEUUID = NullUuid()
Return

####################################################################

$EFLD_MSGCOD_CONTROL
  Local Char WERR(250) : WERR = ""
  If this.MSGCOD <> ""
  #  this.MSGCOD = format$("Kv4:20B",toupper(this.MSGCOD))
    this.MSGCOD = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCOD)

    Local Integer WFOUND_CATCOD : WFOUND_CATCOD = [V]CST_AFALSE
    Local File EDIMSG [EMS]
    Filter [EMS] Where [EMS]MSGCOD = this.MSGCOD and [EMS]CATCOD = this.CATCOD
    For [EMS]
      WFOUND_CATCOD = [V]CST_ATRUE
      Break
    Next
    Filter [EMS]
    If WFOUND_CATCOD = [V]CST_AFALSE
      #"Message mapping not assigned to the category"
      WERR = mess(57,2006,1)
      ASTATUS = fmet this.ASETERROR("MSGCOD",WERR,[V]CST_AERROR)
    Endif
    LogicClose File [EMS]

  Endif
Return

$EFLD_MSGCOD_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
  this.APARENT.FLGACT = [V]CST_ANO

  If this.MSGCOD = ""
    this.MSGREL = ""
    this.MSGDES = ""
    this.MSGVALID = [V]CST_ANO
    this.MSGDIR = this.APARENT.CATACT
    this.MSGFOR = 1
    this.MSGFILNOR = ""
    this.FILDES = ""
    this.FILVALID = [V]CST_ANO
  Endif
  If this.MSGCOD <> "" and this.MSGREL <> ""
    this.MSGDIR = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGDIR")
    this.MSGTYP = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGTYP")
    this.MSGOPE = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGOPE")
    this.MSGDES = fmet this.ACTX.ACACHE.EMS.AGETVALCHAR(this.MSGCOD,this.MSGREL,"MSGDES")
    this.MSGVALID = func GET_VALID_FLAG_EDIMSG(this.MSGCOD,this.MSGREL)
  Endif
Return

####################################################################

$EFLD_MSGREL_CONTROL
  Local Char WERR(250) : WERR = ""
  If this.MSGREL <> ""
  #  this.MSGREL = format$("Kv4:5B",toupper(this.MSGREL))
    this.MSGREL = func EDILIBA.FORMATVAL("MSGREL", this.MSGREL)

    If this.CATCOD <> "" and this.MSGCOD <> "" #and this.MSGREL <> ""
      Local File EDIMSG [EMS]
      Read [EMS]EMS0 = this.MSGCOD; this.MSGREL
      If fstat
        #"Nonexistent message mapping" #
        WERR = mess(118,2006,1)
        ASTATUS = fmet this.ASETERROR("MSGREL",WERR,[V]CST_AERROR)
      Endif
      LogicClose File [EMS]
    Endif
  Endif
Return

$EFLD_MSGREL_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
  this.APARENT.FLGACT = [V]CST_ANO
  this.MSGFILNOR = ""
  If this.MSGCOD <> "" and this.MSGREL <> ""
    this.MSGDIR = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGDIR")
    this.MSGTYP = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGTYP")
    this.MSGOPE = fmet this.ACTX.ACACHE.EMS.AGETVALNUM(this.MSGCOD,this.MSGREL,"MSGOPE")
    this.MSGDES = fmet this.ACTX.ACACHE.EMS.AGETVALCHAR(this.MSGCOD,this.MSGREL,"MSGDES")
    this.MSGVALID = func GET_VALID_FLAG_EDIMSG(this.MSGCOD,this.MSGREL)
  Endif

Return

####################################################################

$EFLD_MSGDIR_CONTROL
  Local Integer WOK
  WOK = func TEST_MSGDIR(this)
Return

####################################################################

$EFLD_MSGFOR_INIT
  this.MSGFOR = 1 #seq
Return

$EFLD_MSGFOR_PROPAGATE  #SAM 112148 Cleaning field after change
  If this.MSGCOD <> "" and this.MSGREL <> ""
    this.MSGFILNOR="":
#    this.MSGFILXML=""
    this.FILDES="":this.PTCCOD="": this.PTCDES="": this.SIGNATURE=0:  this.SIGNAEXT=""
  Endif
  this.FILVALID=[V]CST_ANO
Return

####################################################################

$EFLD_MSGFILNOR_CONTROL
  Local Char WERR(250) : WERR = ""
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Case this.MSGFOR
      When 1
        Local File EDISEQFIL [ESF]
        Read [ESF]ESF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
        If fstat <> [V]CST_AOK
          #"Nonexistent sequential file setup"
          WERR = mess(67,2006,1)
          ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AERROR)
        Endif
        LogicClose File [ESF]
      When 2
        Local File EDIXMLFIL [EXF]
        Read [EXF]EXF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
        If fstat <> [V]CST_AOK
          #"Nonexistent XML file setup"
          WERR = mess(159,2006,1)
          ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AERROR)
        Endif
        LogicClose File [EXF]
    Endcase
  Endif

Return

$EFLD_MSGFILNOR_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
  this.APARENT.FLGACT = [V]CST_ANO

  Local Char WERR(250) : WERR = ""
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
  Case this.MSGFOR
    When 1
      Local File EDISEQFIL [ESF]
      Read [ESF]ESF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
      If !fstat
#       this.FILDES = fmet this.ACTX.ACACHE.ESF.AGETVALCHAR(this.MSGCOD,this.MSGREL,this.MSGFILNOR,"FILDES")  # SAM 110699
       this.FILDES = [ESF]FILDES  # SAM 110699
       this.FILVALID = [ESF]VALID
       If [ESF]VALID = [V]CST_ANO
         #"Invalid Sequential file"
         WERR = mess(45,2006,1)
         ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AWARNING)
       Endif
      Else
        #"Nonexistent Sequential file setup"
        WERR = mess(67,2006,1)
        ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AERROR)
        this.FILDES = ""
        this.FILVALID = [V]CST_ANO
      Endif
      LogicClose File [ESF]
    When 2
      Local File EDIXMLFIL [EXF]
      Read [EXF]EXF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
      If !fstat
#       this.FILDES = fmet this.ACTX.ACACHE.EXF.AGETVALCHAR(this.MSGCOD,this.MSGREL,this.MSGFILNOR,"FILDES")   # SAM 110699
       this.FILDES = [EXF]FILDES  # SAM 110699
       this.FILVALID = [EXF]VALID
       If [EXF]VALID = [V]CST_ANO
         #"Invalid XMl file"
         WERR = mess(160,2006,1)
         ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AWARNING)
       Endif
      Else
        #"Nonexistent XML file setup"
        WERR = mess(159,2006,1)
        ASTATUS = fmet this.ASETERROR("MSGFILNOR",WERR,[V]CST_AERROR)
        this.FILDES = ""
        this.FILVALID = [V]CST_ANO
      Endif
      LogicClose File [EXF]
    Endcase
  Endif
Return

####################################################################

$EFLD_PTCCOD
  Case [L]ARULE
    When "CONTROL"   : Gosub EFLD_PTCCOD_CONTROL
    When "PROPAGATE" : Gosub EFLD_PTCCOD_PROPAGATE
  Endcase
Return

$EFLD_PTCCOD_CONTROL
Return

$EFLD_PTCCOD_PROPAGATE
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
Return

####################################################################
## Ini X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)
$EFLD_SIGNATURE_PROPAGATE
  If this.SIGNATURE=1: Raz this.SIGNAEXT: Endif
Return
## End X3-4752 Setup of the EDI flow toolkit (JUCON 22/11/16)

####################################################################
# Ini Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
$EFLA_GENFLG_CONTROL    #X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
  Local Integer I, WATT
  For I = 1 To maxtab(this.APARENT.EFLA)
    If this.APARENT.EFLA(I)<>null and this.APARENT.EFLA(I).ASTALIN <> [V]CST_ANEWDEL and this.APARENT.EFLA(I).ASTALIN <> [V]CST_ADEL
      If this.APARENT.EFLA(I).GENFLG=1: WATT+=1 : Endif
    Endif
  Next

  If WATT>2 and this.GENFLG=1
    this.GENFLG=2
    WERR= mess(204,2006,1) #"Only two not generate files can be defined"
    ASTATUS = fmet this.ASETERROR("GENFLG",WERR,[V]CST_AINFO)
  Endif
Return

$EFLA_GENFLG_PROPAGATE
  If this.APARENT.CATACT=2: Return: Endif
  Local Char WERR(250): WERR=""
  WOK=func CHECK_PARAM(this)
  If this.GENFLG=1
    this.EXCMSG=1
    this.SGNFLG=1
    this.CRUSED=""
    this.DESTIN=""
    this.FIXNAM=2
  Else
    this.EXCMSG=1
    this.SGNFLG=1
    this.FICVOL=""
    this.PATH=""
    this.FIXNAM=1
    this.FICNAM=""
  Endif

  If WOK=0: Call DELETELINES(this.APARENT, "EFLP") From EDILIBA
  Elsif WOK>1
    this.GENFLG=1
    this.FIXNAM=2
    WERR = mess(199,2006,1) #"Only one generated file is allowed"
    ASTATUS = fmet this.ASETERROR("GENFLG",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################
$EFLA_FIXNAM_PROPAGATE
If this.FIXNAM=1 and this.GENFLG=2 and (this.FICNAM<>"" or this.FICVOL<>"")
  this.FICNAM=""
  this.FICVOL=""
Endif
Return

####################################################################
$EFLA_FICNAM_CONTROL
Local Integer WOK,I
Local Char WERR(250): WERR=""
  I=instr(1,this.FICNAM,":")
  I+=instr(1,this.FICNAM,",")
  I+=instr(1,this.FICNAM,"/")
  I+=instr(1,this.FICNAM,"\")
  If I>0
    WERR=mess(316,139,1)
    ASTATUS = fmet this.ASETERROR("FICNAM",WERR,[V]CST_AERROR)
  Endif

Return

####################################################################
$EFLA_CRUSED_CONTROL
Local Integer WOK
Local Char WERR(250): WERR=""
If this.GENFLG=2
  If this.CRUSED<>""
    WOK=func CHECK_CR(this.CRUSED)
    If WOK<>0
      WERR = mess(163,123,1) :# Report does not exist
    Endif
  Else
    WERR = mess(10,123,1)# "Mandatory field"
  Endif
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("CRUSED",WERR,[V]CST_AERROR)
  Endif
Endif
Return

$EFLA_CRUSED_PROPAGATE
If this.GENFLG=2 and this.CRUSED<>""
  Call DELETELINES(this.APARENT, "EFLP") From EDILIBA
  Call CHARGE_CR_PARAM(this)
Elsif this.GENFLG=1
  WOK=func CHECK_PARAM(this)
  If WOK=0
    Call DELETELINES(this.APARENT, "EFLP") From EDILIBA
  Endif
Endif

Return

####################################################################
$EFLA_DESTIN_CONTROL
Local Integer WOK
Local Char WERR(250): WERR=""
If this.GENFLG=2
  If this.DESTIN<>""
    WOK=func CHECK_DESTIN(this.DESTIN)
    If WOK=1
      WERR = mess(200,2006,1)# Destination does not exist
    Elsif WOK=2
      WERR = mess(201,2006,1) :# Destination type only can be file
    Endif
  Else
    WERR = mess(10,123,1)# "Mandatory field"
  Endif
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("DESTIN",WERR,[V]CST_AERROR)
  Endif
Endif
Return

####################################################################
$EFLA_FICVOL_CONTROL
  Local Char WLINVAL(250), WFICPATCH(250), WERR(250)
  If this.FICVOL<>""
    Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
    WLINVAL = this.FICVOL
    If !pat(this.FICVOL,"["): WLINVAL = "["+this.FICVOL+"]":    Endif
    If func ASYRSTO.CTL_VOLFIL(2, WLINVAL,[L]WFICPATCH,E_TYPE_FOLDER,WERR) <> 0
      ASTATUS = fmet this.ASETERROR("FICVOL", WERR, [V]CST_AERROR)
    Endif
  Endif
Return

$EFLA_FICVOL_PROPAGATE
  this.PATH = func ASYRSTO.GETFULLPATH(this.FICVOL,"")
Return
####################################################################
$EFLP_ALIAS_CONTROL
Return

$EFLP_ALIAS_PROPAGATE
 Local Char WERR(250): WERR=""
  If this.ALIAS <> ""
    If this.CODREP <> ""
      Local File ASHWEXPPRO [ASWR]
      Read [ASWR]ASWR0 = this.CODREP;this.ALIAS
      If fstat=[V]CST_AOK
        this.PROPERTY = [ASWR]CODPRO
      Else
        this.PROPERTY=""
        WERR = mess(202,2006,1) #"Alias is not part of this representation"
        ASTATUS = fmet this.ASETERROR("ALIAS",WERR,[V]CST_AWARNING)
      Endif
    Endif
  Endif
Return


# End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
