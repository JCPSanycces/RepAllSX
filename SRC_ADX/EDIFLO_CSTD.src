#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$AREAD_AFTER
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.CATTYP = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATTYP")
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.PTCDES = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
#  this.PTCVALID = fmet this.ACTX.ACACHE.EPT.AGETVALNUM(this.PTCCOD,"VALID")
  this.PTCVALID = func GET_VALID_FLAG_EDIPTC(this.PTCCOD)
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#*
#*!
$EFLD_AREAD_AFTER
  this.CATTYP   = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATTYP")
  this.PTCDES   = fmet this.ACTX.ACACHE.EPT.AGETVALCHAR(this.PTCCOD,"PTCDES")
  this.MSGDES   = fmet this.ACTX.ACACHE.EMS.AGETVALCHAR(this.MSGCOD,this.MSGREL,"MSGDES")
  this.MSGVALID = func GET_VALID_FLAG_EDIMSG(this.MSGCOD,this.MSGREL)
  #V1 : seq fil
  #V2 : two types (seq and XML but only line)
  If this.MSGFOR=1
    this.FILDES   = fmet this.ACTX.ACACHE.ESF.AGETVALCHAR(this.MSGCOD,this.MSGREL,this.MSGFILNOR,"FILDES")
    this.FILVALID = func GET_VALID_FLAG_EDISEQFIL(this.MSGCOD,this.MSGREL,this.MSGFILNOR)
  Else

#   this.FILDES = fmet this.ACTX.ACACHE.EXF.AGETVALCHAR(this.MSGCOD,this.MSGREL,this.MSGFILXML,"FILDES")
    this.FILDES = fmet this.ACTX.ACACHE.EXF.AGETVALCHAR(this.MSGCOD,this.MSGREL,this.MSGFILNOR,"FILDES")
    this.FILVALID = func GET_VALID_FLAG_EDIXMLFIL(this.MSGCOD,this.MSGREL,this.MSGFILNOR)     ### SAM 110699
  Endif
Return

#********************************************************************
# Method EFLD_ADDLINE_BEFORE
#********************************************************************
#
#********************************************************************
$EFLD_ADDLINE_BEFORE
  ASTATUS = fmet this.ADELETEERROR("FLGACT")
  If this.PARCOD = ""
    #"EDI partner must be defined"
    ASTATUS = fmet this.ASETERROR("PARCOD",mess(19,2006,1),[V]CST_AERROR)
  Endif
  If this.CATCOD = ""
    #"Category must be defined"
    ASTATUS = fmet this.ASETERROR("CATCOD",mess(7,2006,1),[V]CST_AERROR)
  Endif

  Local Integer I
  Local Integer WNBLINE : WNBLINE = 0
  For I = 1 To maxtab(this.EFLD)
    If this.EFLD(I)<>null and this.EFLD(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLD(I).ASTALIN <> [V]CST_ADEL
      WNBLINE = WNBLINE + 1
    Endif
  Next
  If WNBLINE >= 1
    #Only one line can be defined
    ASTATUS = fmet this.ASETERROR("",mess(71,2006,1),[V]CST_AERROR)
  Endif
Return

#********************************************************************
# Method EFLD_ADDLINE_AFTER
#********************************************************************
#
#********************************************************************
$EFLD_ADDLINE_AFTER
  this.APARENT.VALID  = [V]CST_ANO
  this.APARENT.FLGACT = [V]CST_ANO

  this.CATCOD = this.APARENT.CATCOD
  this.CATTYP = this.APARENT.CATTYP
  this.PTCCOD = this.APARENT.PTCCOD

  #Add an new ligne number
  this.NUMLIN = 1 + max(this.APARENT.EFLD(1..maxtab(this.APARENT.EFLD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EFLD)
    If this.APARENT.EFLD(I) <> null
      If this.APARENT.EFLD(I).AORDER = this.AORDER - 1
        BEF_LINE = I
      Elsif this.APARENT.EFLD(I).AORDER = this.AORDER + 1
        AFT_LINE = I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EFLD(AFT_LINE).SORT
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EFLD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EFLD)
        If this.APARENT.EFLD(I) <> null
          OFFSET_LINE = this.APARENT.EFLD(I).AORDER - this.AORDER
#          If this.APARENT.EFLD(I).AORDER >= this.AORDER
          If OFFSET_LINE >= 0
            #Assign the SORT property
            this.APARENT.EFLD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EFLD(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif
Return

#********************************************************************
# Method EFLD_ADELLINE_AFTER
#********************************************************************
#
#********************************************************************
$EFLD_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO
  this.APARENT.FLGACT = [V]CST_ANO
Return

$AINSERT_CONTROL_BEFORE
Return

$AUPDATE_CONTROL_BEFORE
Return

# Ini Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)
#********************************************************************
# Method EFLA_ADDLINE_BEFORE
#********************************************************************
#
#********************************************************************
$EFLA_ADDLINE_BEFORE
If this.EFLA<>null
  Local Char WERR(250): WERR=""
  Local Integer I, WNBATT, WNBLINE : WNBLINE = 0

  If this.CATACT=2:
    WERR=mess(203,2006,1) #Attachments only allowed in outbound direction
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Return
  Endif

  For I = 1 To maxtab(this.EFLA)
    If this.EFLA(I)<>null and this.EFLA(I).ASTALIN <> [V]CST_ANEWDEL and this.EFLA(I).ASTALIN <> [V]CST_ADEL
      WNBLINE = WNBLINE + 1
      If this.EFLA(I).GENFLG=1: WNBATT+=1: Endif
    Endif
  Next
  If WNBATT >4
    #Only five not generate files can be defined
    WERR= mess(204,2006,1) #"Only five not generate files can be defined"
  Endif
  If WNBLINE>5
    WERR=mess(205,2006,1) #"Six lines is the maximun allowed"
  Endif
  If WERR<>""
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Endif
Endif

Return

#********************************************************************
# Method EFLA_ADDLINE_AFTER
#********************************************************************
#
#********************************************************************
$EFLA_ADDLINE_AFTER
  this.GENFLG = 1
  this.FLOCOD = this.APARENT.FLOCOD
  this.FLOREL = this.APARENT.FLOREL
  #Add an new ligne number
  this.NUMLIN = 1 + max(this.APARENT.EFLA(1..maxtab(this.APARENT.EFLA)).NUMLIN)
Return

#********************************************************************
# Method EFLA_ADELLINE_AFTER
#********************************************************************
#*
#*!
$EFLA_ADELLINE_AFTER
Local Integer WOK
WOK=func CHECK_PARAM(this)
If WOK=0: Call DELETELINES(this.APARENT, "EFLP") From EDILIBA: Endif
Return

# End Epic X3-64474 _ US X3-85220 Attachment file management in EDI (JUCON 04/06/2018)

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_POST_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Invalid flow"
    WERR = mess(41,2006,1)
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_VALIDATE()
  If WOK = [V]CST_ATRUE
    WOK = fmet this.MET_PUT_JSON(WERR)
    If WOK <> [V]CST_AINFO
      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    Endif
  Else
    this.CACHEUUID = NullUuid()
    #"Invalid flow"
    WERR = mess(41,2006,1)
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_DEL_JSON(WERR)
  If WOK <> [V]CST_AINFO
    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
  Endif
Return

