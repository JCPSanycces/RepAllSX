 #CHECK UNUSED_BEGIN
 When "EXTRTNCODD"  : Gosub EXTRTNCODD
 #CHECK UNUSED_END
 When "FLOPHYCODD"  : Gosub FLOPHYCODD
 When "FMICOD"      : Gosub FMICOD
 When "FMINUMCOD"   : Gosub FMINUMCOD
 When "FOCFLGCOD"   : Gosub FOCFLGCOD
 When "GROPRICOD"   : Gosub GROPRICOD
 When "INVCNDCODD"  : Gosub INVCNDCODD  : # 107890 : Scheduled invoices : (LD:08/12/15)
