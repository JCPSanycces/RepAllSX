$CCECODD
If dim([M]CCECODD)>0 & dim([M]CCESCRD)>0
  If [M]CCECODD(nolign-1)=3
     [M]CCESCRD(nolign-1)=1
     If !GIMPORT
        #CHECK UNUSED_BEGIN
        If FJL="SLC" : Affzo [M:SLC1]CCESCRD(nolign-1) : Endif
        If FJL="SLI" : If GFONCTION="GESSLA"
                          Affzo [M:SLA1]CCESCRD(nolign-1)
                       Else
                          Affzo [M:SLI1]CCESCRD(nolign-1)
                       Endif
        Endif
        #CHECK UNUSED_END
     Endif
  Endif
Endif
Return

