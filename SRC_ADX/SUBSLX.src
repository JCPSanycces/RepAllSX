 When "MVTDESCOD"   : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Else
                          Gosub MVTDESCOD
                      Endif
#### X3-81835  : LPN - sales Issues documents / X3-81989 (LCC 20/03/18)
 When "LPNCOD"        : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
