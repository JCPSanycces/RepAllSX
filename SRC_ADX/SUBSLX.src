 When "USELIMDCOD"  : Gosub USELIMDCOD
 When "DEMDLVLCOD"  : Gosub DEMDLVLCOD
 When "MAXDLVHCOD"  : Gosub MAXDLVHCOD
 When "MAXDLVDCOD"  : Gosub MAXDLVDCOD
# 106776  EDI fields

 When "LOTCOD"      : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Else
                          Gosub LOTCOD
                      Endif
 When "SLOCOD"      : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Else
