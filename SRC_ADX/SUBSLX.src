      If find (FJL, "SLD", "SLI")
        Affzo [SLS1]WRHCOD1 : Grizo [SLS1]WRHCOD1
        Affzo [SLS1]WRHSCR1 : Grizo [SLS1]WRHSCR1
      Endif
    Endif
  Elsif !GIMPORT
    If find (FJL, "SLD", "SLI")
      Affzo [M:SLS1]WRHCOD1 : Actzo [SLS1]WRHCOD1
      Affzo [M:SLS1]WRHSCR1
