# Gestion des retours client : Transaction de saisie des entrées en stock
If dim(NOMMSK(0))>0 & NOMMSK(0)="SLR0"
    WMODU+=num$([M:SLR0]STRTYP)
    Gosub LIENS From SUBETR
Endif
# Gestion des retours prêt   : Transaction de saisie des entrées en stock
If dim(NOMMSK(0))>0 & NOMMSK(0)="SLL0"
    WMODU+=num$([M:SLL0]STRTYP)
    Gosub LIENS From SUBETR
Endif
# Gestion des retours matière sous traitance : Transaction de saisie des entrées en stock
If dim(NOMMSK(0))>0 & NOMMSK(0)="SSC0"
    WMODU+=num$([M:SSC0]STRTYP)
    Gosub LIENS From SUBETR
Endif
# Gestion des avoirs : Transaction de saisie des entrées en stock
If GFONCTION="GESSLA"
    WMODU+=num$([M:SLI0]STRTYP)
    Gosub LIENS From SUBETR
    # Initialisation
    If [M:ETR2]UOMSAIFLG=1
        # Saisie UC décochée
        [M:SLI4]STUCOD=1    : [M:SLI4]STUSCR=1    : # Unité de stock invisible
        [M:SLI3]SAUCOECOD=3 : [M:SLI3]SAUCOESCR=1 : # Coef UV-US invisible
        [M:SLI3]SAUCOD=2    : [M:SLI3]SAUSCR=1    : # Unité de vente affichée
    Else
        # Saisie UC cochée
        [M:SLI4]STUCOD=2    : [M:SLI4]STUSCR=1    : # Unité de stock affichée
        [M:SLI3]SAUCOECOD=1 : [M:SLI3]SAUCOESCR=1 : # Coef UV-US saisissable
        [M:SLI3]SAUCOD=1    : [M:SLI3]SAUSCR=1    : # Unité de vente saisissable
    Endif
    Diszo [M:SLI4]STUCOD, STUSCR
    Diszo [M:SLI3]SAUCOECOD, SAUCOESCR
    Diszo [M:SLI3]SAUCOD, SAUSCR
Endif
Gosub PE_SALTRS
Return

