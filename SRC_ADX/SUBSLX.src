#### End X3-81835  : LPN - sales Issues documents / X3-81989 (LCC 20/03/18)

 When Default       : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Endif
                      Gosub PE_SALTRS
Endcase
Return

#----------------------------------------------------------------------
# 107888 : Scheduled invoices : (LD:04/03/16)
$INVPRCCOD
If dim([M]INVPRCCOD)>0 & dim([M]INVPRCSCR)>0
  If [M]INVPRCCOD=3
     [M]INVPRCSCR=1
     If !GIMPORT
       If FJL="SLI" : Affzo [M:SLI3]INVPRCSCR : Grizo [M:SLI3]INVPRCSCR : Endif
     Endif
  Else
     If !GIMPORT
       If FJL="SLI" : Actzo [M:SLI3]INVPRCSCR : Endif
     Endif
  Endif
Endif

Return
# 107888 : Scheduled invoices : (LD:04/03/16)
#----------------------------------------------------------------------

