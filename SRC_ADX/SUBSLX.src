       If FJL="SLC" : Affzo [M:SLC4]BPAADDSCRD : Grizo [M:SLC4]BPAADDSCRD : Endif
     Endif
  Else
     If !GIMPORT
       If FJL="SLQ" : Actzo [M:SLQ3]BPAADDSCRD : Endif
