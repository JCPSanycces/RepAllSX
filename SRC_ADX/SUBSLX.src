Return

$MAXDLVDCOD
If dim([M]MAXDLVDCOD)>0 & dim([M]MAXDLVDSCR)>0
  If [M]MAXDLVDCOD=3
     [M]MAXDLVDSCR=1
     If !GIMPORT
       If FJL="SLC" : Affzo [M:SLC4]MAXDLVDSCR : Grizo [M:SLC4]MAXDLVDSCR : Endif
     Endif
  Else
     If !GIMPORT
       If FJL="SLC" : Actzo [M:SLC4]MAXDLVDSCR : Endif
     Endif
  Endif
Endif
Return
