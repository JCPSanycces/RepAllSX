#<AdxTL>@(#)4.0.0.0 $Revision$
#######################################################################
# SUBSLX : Traitements communs aux transactions Ventes   JL  30/06/99 #
#---------------------------------------------------------------------#
# Action standards appelées à partir de :                             #
#    - SUBSLQ : Transactions Devis                                    #
#    - SUBSLC : Transactions Commandes                                #
#    - SUBSLO : Transactions Commandes ouvertes                       #
#    - SUBSLD : Transactions Livraisons                               #
#    - SUBSLI : Transactions Factures                                 #
#    - SUBSLA : Transactions Avoirs                                   #
#    - SUBSLR : Transactions Retours                                  #
#    - SUBSLL : Transactions Retours prêt                             #
#    - SUBSLS : Transactions Retours matière sous traitance           #
#######################################################################

#--- Suppression du libelle traduisible dans ATEXTRA
$ANNULE
Delete [AXX] Where CODFIC="SALTRS" & IDENT1=[F:SLT]STRTYPCAR & IDENT2=[F:SLT]STRNUM
Return

#######################################################################
$OUVRE
Local Char FJL (3)

If dim(NOMMSK(0))>0
  If NOMMSK(0)="SLQ0" : FJL="SLQ" : Endif
  If NOMMSK(0)="SLC0" : FJL="SLC" : Endif
  If NOMMSK(0)="SLO0" : FJL="SLO" : Endif
  If NOMMSK(0)="SLD0" : FJL="SLD" : Endif
  If NOMMSK(0)="SLI1" : FJL="SLI" : Endif
  If NOMMSK(0)="SLR0" : FJL="SLR" : Endif
  If NOMMSK(0)="SLL0" : FJL="SLL" : Endif
  If NOMMSK(0)="SLSCO0" : NOMMSK(0) = "SSC0" : FJL="SLS" : Endif
Endif
Return

#######################################################################
$APRES_MODIF
Local Char MAZONE
Local Char FJL (3)

#-- dans l'action apres_modif objet la classe [M] n'est pas encore chargée,
#   il faut le faire pour la suite du traitement

If COUZON="DIE" | COUZON="CCECOD"  Return : Endif : # MBT 01/07/2008 ?????????????

# FGR 04/02/2015 : X3SUIVI105938 (début)
#If COUZON="CCECODD"
#  [M]CCECODD(nolign-1)=val(CZ)
#Elsif evalue("type([M]"+num$(COUZON)+")")>10
#  MAZONE="[M]"+num$(COUZON) : Assign MAZONE With CZ
#Else
#  MAZONE="[M]"+num$(COUZON) : Assign MAZONE With val(CZ)
#Endif

If COUZON="CCECODD"
  [M]CCECODD(nolign-1)=val(CZ)
Elsif evalue("type([M]"+num$(COUZON)+")")>10 and evalue("type([M]"+num$(COUZON)+")")<500
  MAZONE="[M]"+num$(COUZON) : Assign MAZONE With CZ
Elsif evalue("type([M]"+num$(COUZON)+")")>500
  MAZONE="[M]"+num$(COUZON) : Assign MAZONE With num$(CZ)
Else
  MAZONE="[M]"+num$(COUZON) : Assign MAZONE With val(CZ)
Endif
# FGR 04/02/2015 : X3SUIVI105938 (fin)
#--

If dim(NOMMSK(0))>0
  If NOMMSK(0)="SLQ0" : FJL="SLQ" : Endif
  If NOMMSK(0)="SLC0" : FJL="SLC" : Endif
  If NOMMSK(0)="SLO0" : FJL="SLO" : Endif
  If NOMMSK(0)="SLD0" : FJL="SLD" : Endif
  If NOMMSK(0)="SLI0" : FJL="SLI" : Endif
  If NOMMSK(0)="SLR0" : FJL="SLR" : Endif
  If NOMMSK(0)="SLL0" : FJL="SLL" : Endif
  If NOMMSK(0)="SSC0" : FJL="SLS" : Endif
Endif
Case COUZON
 When "STRNUM"      :
            If dim(NOMMSK(0))>0
              If NOMMSK(0)="SLQ0" : [M]STRTYP=1 : Endif
              If NOMMSK(0)="SLC0" : [M]STRTYP=2 : Endif
              If NOMMSK(0)="SLO0" : [M]STRTYP=3 : Endif
              If NOMMSK(0)="SLD0" : [M]STRTYP=4 : Endif
              If NOMMSK(0)="SLI0" : [M]STRTYP=5 : Endif
              If NOMMSK(0)="SLR0" : [M]STRTYP=6 : Endif
              If NOMMSK(0)="SLL0" : [M]STRTYP=7 : Endif
              If NOMMSK(0)="SSC0" : [M]STRTYP=8 : Endif
            Endif
