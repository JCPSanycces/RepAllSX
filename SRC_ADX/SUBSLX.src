                      Endif
 When "IDECOD01"    : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Else
                          Gosub IDECOD01
                      Endif
 When "IDECOD02"    : If find(GFONCTION, "GESSLR","GESSLL","GESSLA","GESSLS")
                      # Gestion des retours et des avoirs : Transaction de saisie des entrées en stock
                          Gosub APRES_MODIF From SUBETR
                      Else
