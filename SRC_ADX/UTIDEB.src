#<AdxTL>@(#)7.0.0.0 $Revision$
Local Integer COMPTE_EEC,NB_FIC,CAS_TRT(1..10),OK
# On se prépare pour les traces
Local Char    Z_ADXIFS(1),Z_ADXIRS(2)
Z_ADXIFS=adxifs
Z_ADXIRS=adxirs

adxifs=""
If GOS(1)="unix"
   adxirs=chr$(10)
Else
   adxirs=chr$(13)+chr$(10)
Endif

Local File ADOSSIER [ADS]
Read [ADS]DOSSIER=nomap

# Comptage de ce qui doit être traiter
Raz NB_FIC,CAS_TRT
For FICHIER="TABMODELIV","DEB","PRECEIPT","PRETURN","SDELIVERY","SRETURN","SINVOICEV","PINVOICE"
   If find(FICHIER,"TABMODELIV","DEB")
&     | [F:ADS]MODULE(4)=2 & find(FICHIER,"SDELIVERY","SRETURN","SINVOICEV")
&     | [F:ADS]MODULE(5)=2 & find(FICHIER,"PRECEIPT","PRETURN","PINVOICE")
      NB_FIC+=1
      Gosub TEST
   Endif
Next

NB_FIC=0
# Rien à traiter
If max(CAS_TRT)=0 : End : Endif
# Traitement long
#If max(CAS_TRT)>1000
#   OK=2
#   Call AVERTIR("LONG process",OK) From GESECRAN
#   If OK=1 : End : Endif
#Endif

Call MONO(OK) From AX3MONO
If !OK : End : Endif

# Traitement
Call OUVRE_TRACE(mess(81,125,1)-"DEB") From LECFIC

Call TEMPON("") From GESECRAN

For FICHIER="TABMODELIV","DEB","PRECEIPT","PRETURN","SDELIVERY","SRETURN","SINVOICEV","PINVOICE"
   If find(FICHIER,"TABMODELIV","DEB")
&     | [F:ADS]MODULE(4)=2 & find(FICHIER,"SDELIVERY","SRETURN","SINVOICEV")
&     | [F:ADS]MODULE(5)=2 & find(FICHIER,"PRECEIPT","PRETURN","PINVOICE")
      NB_FIC+=1
      Gosub MAJ
   Endif
Next

Call TEMPOFF From GESECRAN

Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

# On restaure la situation
adxifs=Z_ADXIFS
adxirs=Z_ADXIRS

Call MULTI(OK) From AX3MONO

Close Local File [ADS]

End

###########################
$TEST
Local File=FICHIER [XXX]
COMPTE_EEC=0
For [XXX] Where EECTRN>=6
   COMPTE_EEC+=1
Next
CAS_TRT(NB_FIC)=COMPTE_EEC
Close Local File [XXX]

Return

###########################
$MAJ
If filinfo(filpath("tmp",FICHIER,"eec"),0)>0
   Call ERREUR("File"-FICHIER-":"-"update already done") From GESECRAN
   Return
Endif

Local File=FICHIER [XXX]

Trbegin [XXX]
Update  [XXX] Where EECTRN>=6 With EECTRN+=1
Commit

Close Local File [XXX]

Call ECR_TRACE("File"-FICHIER-":"-num$(CAS_TRT(NB_FIC))-"lines updated",0)
&              From GESECRAN

Openo filpath("tmp",FICHIER,"eec") Using [TMP]
Wrseq "File"-FICHIER-":"-num$(CAS_TRT(NB_FIC))-"lines updated" Using [TMP]
Openo Using [TMP]

Return

