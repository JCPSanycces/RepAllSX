  Endif
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_BPRWAC(IMPENT) From SUBDLA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "BPRWAC" : GZNUM = 46358 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]BPRWAC = IMPENT

## Zone BPRNAM
mkstat = 0
zoncou = "BPRNAM"
