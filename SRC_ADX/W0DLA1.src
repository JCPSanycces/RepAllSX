 If !mkstat
  IMPMOD = 0 : IMPZON = "CODRSK" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLGVIC
mkstat = 0
zoncou = "FLGVIC"
indice = 0
IMPENT = [M]FLGVIC
If varinit([M]FLGVIC,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGVIC,indice)=0
 [M]FLGVIC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGVIC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGVIC(indice)
 Endif
Endif
