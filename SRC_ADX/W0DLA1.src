#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone SEX
mkstat = 0
zoncou = "SEX"
indice = 0
IMPENT = [M]SEX
If varinit([M]SEX,indice)=0
 IMPENT = 1
Endif
If varmode([M]SEX,indice)=0
 [M]SEX(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SEX" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SEX(indice)
 Endif
Endif
[M]SEX = IMPENT

## Zone NUMSSC
mkstat = 0
zoncou = "NUMSSC"
indice = 0
SAVACT = GACTION : GACTION = "LECPAY"
Call LECPAY(func TRTDIV.LECPAYSIT([F:HRCTR]ETRFCY)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]NUMSSC : Endif
If !mkstat
 If varmode([M]NUMSSC,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NUMSSC" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone NUMSSC2
mkstat = 0
zoncou = "NUMSSC2"
indice = 0
SAVACT = GACTION : GACTION = "LECPAY"
Call LECPAY(func TRTDIV.LECPAYSIT([F:HRCTR]ETRFCY)) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]NUMSSC2 : Endif
If !mkstat
 If varmode([M]NUMSSC2,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "NUMSSC2" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone CRYBRN
mkstat = 0
zoncou = "CRYBRN"
indice = 0
If varinit([M]CRYBRN,indice)=0
 [M]CRYBRN = GPAYS
Endif

## Zone OLDNAM
mkstat = 0
zoncou = "OLDNAM"
indice = 0
If varmode([M]OLDNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OLDNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DATBRN
mkstat = 0
zoncou = "DATBRN"
