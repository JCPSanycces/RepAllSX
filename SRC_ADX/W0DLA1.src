 If !mkstat
  IMPMOD = 0 : IMPZON = "WTSNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone WTSADD
mkstat = 0
zoncou = "WTSADD"
For indice=0 To 1
 If varmode([M]WTSADD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "WTSADD" : Gosub ACTION From =IMPTRT
  Endif
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

## Zone WTSPOSCOD
mkstat = 0
zoncou = "WTSPOSCOD"
indice = 0
WCHAR = [M]WTSPOSCOD
SAVACT = GACTION : GACTION = "FMTPOSPAY"
Call FMTPOSPAY("") From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]WTSPOSCOD : Endif
If !mkstat
 If varmode([M]WTSPOSCOD,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "WTSPOSCOD" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "POSCNTOBL"
  PARAM(1) = ""
  PARAM(2) = ""
  Local Char    VALEUR(250)
  VALEUR = [M]WTSPOSCOD
  Call S_AFF_CHAR(VALEUR,PARAM,"POSCNTOBL","SUBPOS","") From GACTION
  [M]WTSPOSCOD = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WTSPOSCOD" : GZNUM = 210 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]WTSPOSCOD or IMPMOD
    SAVACT = GACTION : GACTION = "CPCONT"
    PARAM(1) = ""
    PARAM(2) = ""
    PARAM(3) = ""
    Local Char    VALEUR(250)
    VALEUR = [M]WTSPOSCOD
    Call S_AFF_CHAR(VALEUR,PARAM,"CPCONT","SUBPOS","") From GACTION
    [M]WTSPOSCOD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WTSPOSCOD" : GZNUM = 210 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone RPTFLG
mkstat = 0
zoncou = "RPTFLG"
indice = 0
IMPENT = [M]RPTFLG
WNUM = IMPENT
If varinit([M]RPTFLG,indice)=0
 IMPENT = 1
 SAVACT = GACTION : GACTION = "STD"
 Call D_RPTFLG(IMPENT) From SUBDLA
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]RPTFLG,indice)=0
  [M]RPTFLG(indice) = IMPENT
  If !mkstat
   IMPMOD = 0 : IMPZON = "RPTFLG" : Gosub ACTION From =IMPTRT
   IMPENT = [M]RPTFLG(indice)
  Endif
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_RPTFLG(IMPENT) From SUBDLA
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "RPTFLG" : GZNUM = 46372 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]RPTFLG = IMPENT

## Zone RPTNAM
mkstat = 0
zoncou = "RPTNAM"
indice = 0
If varmode([M]RPTNAM,indice)=0
