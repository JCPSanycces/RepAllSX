## Zone NTTTYP
mkstat = 0
zoncou = "NTTTYP"
indice = 0
IMPENT = [M]NTTTYP
If varinit([M]NTTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]NTTTYP,indice)=0
 [M]NTTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "NTTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]NTTTYP(indice)
 Endif
Endif
[M]NTTTYP = IMPENT

####################################
