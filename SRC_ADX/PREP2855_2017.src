#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################
# Program : PREP2855_2017
#
# Maj de la table TMP2855  pour l'état FAS2855_2017 : Taxe sur véhicules sociétés
# Populating TMP2855 table for the report FAS2855_2017 : Tax on Company Cars
#
# Issue X3-55190 - 2017-11-09 by FHA : Copy of PREP2855-2014 updated and used for FAS2855-2017 report
#                                      Copie modifiée de PREP2855-2014 pour l'état FAS2855-2017
########################################################################################################

$ACTION
Case ACTION
    When "OUVRE" :   Gosub OUVRE
    When "FIN"   :   Gosub FIN
Endcase
Return

######################################################################################
$OUVRE
If clalev([F:FAS])=0     :    Local File FXDASSETS       [FAS]    : Endif
If clalev([F:TVS])=0     :    Local File TMP2855         [TVS]    : Endif
If clalev([F:TVSM])=0    :    Local File TMP2855         [TVSM]   : Endif
If clalev([F:FIY])=0     :    Local File FISCYEAR        [FIY]    : Endif
If clalev([F:A965])=0    :    Local File ATABDIV         [A965]   : Endif
SYMBOLE = "PREP2855"
Lock SYMBOLE With lockwait = 3
If fstat
   Return
Endif
Return

######################################################################################
$FIN
Unlock=SYMBOLE
Return

#=================================================================
# PREP2855 : alimentation de la table TMP2855 / Populating TMP2855
#=================================================================
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)
Local Char       VALEUR(30)
Gosub OUVRE
Gosub MAJ_TMP2855
End

###################################################
$MAJ_TMP2855
#-------------------------------------------------------------------------------------------#
#--- Création table temporaire TMP2855 pour la liasse fiscale Taxe sur véhicules sociétés---#
#--- Creation of temporary tab TMP2855 for Tax on Company Cars                           ---#
#-------------------------------------------------------------------------------------------#
Local Integer I                 # Compteur de paramètres / Parameter counter
Local Char    LCPY(GLONCPY)     # Société/Company
Local Char    LCPYNAM(35)       # Raison sociale/Company name
Local Date    LIMPSTRDAT        # Date imposition début/Start date of taxation
Local Date    LIMPENDDAT        # Date imposition fin/End date of taxation
Local Integer LEDTNUM           # Identifiant session/Session No
Local Char    LCRITERE  (250)   # Critère de sélection/Select criteria
Local Char    LCRITERE2 (250)   # Critère de sélection/Select criteria
Local Date    LDATNULL         : LDATNULL    = [01/01/1900]
Local Integer LANNEE            # Année d'imposition/Year of taxation
Local Date    DATEXOTRIM1       # 1st quarter year of 1st use / 1er trim. année de mise en circul.
Local Date    DATEXOTRIM2       # 2d quarter year of 1st use  / 2e trim. année de mise en circul.
Local Date    DATEXOTRIM3       # 3d quarter year of 1st use  / 3e trim. année de mise en circul.
Local Date    DATEXOTRIM4       # 4th quarter year of 1st use / 4e trim. année de mise en circul.

Local Integer LYEAR17           # 2017 Exception
Local Integer LTRIMI,LMAXTRIM   # quarter cal. vars/variable de travail calcul des trim.
Local Date    LDATW             # date cal var/var travail calcul de dates

Local Date    LDEBTRIM1
Local Date    LDEBTRIM2
Local Date    LDEBTRIM3
Local Date    LDEBTRIM4
Local Date    LDEBTRIM5                :# 2017 Exception
Local Date    DEBEXODAT,  FINEXODAT    :# Star End of the exoneration (8 quarters)/Debut fin de l'exoneration temporaire (8 trim.)
Local Date    STRRNTTVS,  ENDRNTTVS    :# Start and end of the taxable rent period/Debut fin de periode de location taxable
Local Integer LRNTDUR                  :# Duration of rent period in the exercice/Durée periode de location dans l'exercice
Local Date    STRRNTEXO,  ENDRNTEXO    :# Start and end of the exoneratable rent period/Debut fin de periode de location exonerable
Local Integer LRNTDUREXO               :# Duration of rent exonerated period/Durée periode de location exonérée

If clalev([TVS])=0 : Local File TMP2855 [TVS] : Endif
Trbegin [TVS]
Delete [TVS] Where CREUSR = GUSER #Fq-84228 & CREDAT < date$
If fstat = 1
  Rollback
  #  'Problem in deleting the temporary file'/'Problème à l'effacement du fichier temporaire'
  Call MESSAGE (mess(155,197,1)) From GESECRAN
Else
   Commit
Endif

Call GETPARAM("cpy",NBPAR,PARAMETRE,LCPY)
Call GETPARAM("annee",NBPAR,PARAMETRE,PARAM)  :  LANNEE  = val(PARAM)
Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM) :  LEDTNUM = val(PARAM)

# 2017 Exception / 2018+ calendar year
Raz LYEAR17
If LANNEE=2017
  LYEAR17 = 1
Endif
If LYEAR17
  LIMPSTRDAT = gdat$(01, 10, LANNEE-1)
  LIMPENDDAT = gdat$(31, 12, LANNEE)
Else
  LIMPSTRDAT = gdat$(01, 01, LANNEE)
  LIMPENDDAT = gdat$(31, 12, LANNEE)
Endif

[L]FINEXODAT   = gdat$(01,01,1900)

# 2017 Exception / 2018+ calendar year
If LYEAR17
   [L]LDEBTRIM1 = gdat$(01, 10, year(LIMPSTRDAT))
   [L]LDEBTRIM2 = gdat$(01, 01, year(LIMPSTRDAT)+1)
   [L]LDEBTRIM3 = gdat$(01, 04, year(LIMPSTRDAT)+1)
   [L]LDEBTRIM4 = gdat$(01, 07, year(LIMPSTRDAT)+1)
   [L]LDEBTRIM5 = gdat$(01, 10, year(LIMPSTRDAT)+1)
Else
   [L]LDEBTRIM1 = gdat$(01, 01, year(LIMPSTRDAT))
   [L]LDEBTRIM2 = gdat$(01, 04, year(LIMPSTRDAT))
   [L]LDEBTRIM3 = gdat$(01, 07, year(LIMPSTRDAT))
   [L]LDEBTRIM4 = gdat$(01, 10, year(LIMPSTRDAT))
Endif

# Select Criteria / Criteres de selection
LCRITERE  = "1=1"
For I=1 To NBPAR
   J=instr(1,[L]PARAMETRE(I),"=")
   If J
       [L]PARAM  = left$([L]PARAMETRE(I),J-1)
       [L]VALEUR = right$([L]PARAMETRE(I),J+1)
       Case [L]PARAM
          When "cpy"            :     LCRITERE    =   "CPY='"+LCPY+"'"
          When "datimpfin"      :     LCRITERE   +=   "& PURDAT<=["+format$(GFMD,LIMPENDDAT)+"]"
       Endcase
   Endif
Next
LCRITERE2    =    "OWNTYP>="+num$(1)
LCRITERE2   +=  "& OWNTYP<="+num$(3)
LCRITERE2   +=  "& (ISSDAT    <=  ["+format$(GFMD,LDATNULL)+"]"
LCRITERE2   +=  "| ISSDAT     >=  ["+format$(GFMD,LIMPSTRDAT)+"])"
LCRITERE2   +=  "& FIRICIDAT  >=  ["+format$(GFMD,LDATNULL)+"]"
LCRITERE2   +=  "& FUEL  <= 3"      :# Excluding "Other" Fuel type / On exclut les type de carburant "Autre"
LCRITERE2   +=  "& ENAFAS = 2"      :# Only active assets / Uniquement les biens actifs
LCRITERE2   +=  "& PURDAT<=["+format$(GFMD,LIMPENDDAT)+"]" :# Cars entered before the end of the Taxing period / Vehicules entrés avant la fin exercice

If clalev([F:TVS])=0    :    Local File TMP2855         [TVS]    : Endif
#--------------------------------
Call DEBTRANS From GLOCK
Trbegin [TVS]
Delete [TVS] Where  (CREUSR =  GUSER) #Fq-84228 &  (EDTNUM = LEDTNUM)
If fstat=1 | fstat>5
    GOK = 0
    Call RSTA("TVS","") From GLOCK
    Rollback
Endif
Commit
If !GOK : Return : Endif

If clalev([F:CPY])=0     :    Local File COMPANY         [CPY]    : Endif
If clalev([F:FAS])=0     :    Local File FXDASSETS       [FAS]    : Endif
If clalev([F:TVS])=0     :    Local File TMP2855         [TVS]    : Endif
If clalev([F:TVSM])=0    :    Local File TMP2855         [TVSM]   : Endif
If clalev([F:FIY])=0     :    Local File FISCYEAR        [FIY]    : Endif
If clalev([F:A965])=0    :    Local File ATABDIV         [A965]    : Endif

# Company / Société
Read [CPY]CPY0=LCPY
If fstat= 0
  LCPYNAM = [F:CPY]CPYNAM
Endif

###########################################################################
#                          Main loop / Boucle principale
###########################################################################
Call DEBTRANS From GLOCK
Trbegin [TVS], [TVSM]
Filter [FAS] Where (evalue(LCRITERE) and evalue(LCRITERE2)) and NPL <> ""
For [FAS]
   Read[A965]=965;[F:FAS]VEHTYP
   If fstat=0
     If [F:A965]N1 <> G_OUI
       Goto NEXTFAS
     Endif
   Endif
   # Excluding cars rented out of the taxation period / Exclusion des vehicules loués en dehors de l'exercice d'imposition
   If   [F:FAS]OWNTYP=2 and
&     ( ([F:FAS]RNTENDDAT > LDATNULL and [F:FAS]RNTENDDAT < [L]LIMPSTRDAT) or
&       ([F:FAS]RNTSTRDAT > LDATNULL and [F:FAS]RNTSTRDAT > [L]LIMPENDDAT) )
      Goto NEXTFAS
   Endif
   Raz[TVS]
   Raz[TVSM]
   [F:TVSM] = [F:FAS]
   GOK=1
   #========================================================
   Gosub CHARGE_TVSM
   #========================================================
   [F:TVS]           =  [F:TVSM]
   [F:TVS]EDTNUM     =  LEDTNUM
   [F:TVS]CREUSR     =  GUSER
   [F:TVS]CREDAT     =  date$
   [F:TVS]CPY        =  LCPY
   [F:TVS]CPYNAM     =  LCPYNAM
   [F:TVS]IMPSTRDAT  =  LIMPSTRDAT
   [F:TVS]IMPENDDAT  =  LIMPENDDAT
    If EDTNUM <> 0
      Write [F:TVS]
      If fstat : GOK=0 : Call FSTA("TVS") From GLOCK : Endif
      If !GOK : Break :  Goto ROLL_TR1 : Endif
   Endif
   $NEXTFAS
Next
Filter [FAS]
If GOK : Commit : Else Gosub ROLL_TR1 : Endif

Return

######################################################################################
$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return  : Endif
Return

######################################################################################
# Issue X3-55190 New cinematics based on new specifications
#                Nouvelle cinématique suite aux nouvelles specifications
######################################################################################
$CHARGE_TVSM
#########################################
# CO2 price table / Barème CO2
#########################################
If         [F:FAS]VEHCO2  > 0   and [F:FAS]VEHCO2  <= 50  : [F:TVSM]TARIFCO2 = 0
    Elsif  [F:FAS]VEHCO2  > 50  and [F:FAS]VEHCO2  <= 100 : [F:TVSM]TARIFCO2 = 2
    Elsif  [F:FAS]VEHCO2  > 100 and [F:FAS]VEHCO2  <= 120 : [F:TVSM]TARIFCO2 = 4
    Elsif  [F:FAS]VEHCO2  > 120 and [F:FAS]VEHCO2  <= 140 : [F:TVSM]TARIFCO2 = 5.5
    Elsif  [F:FAS]VEHCO2  > 140 and [F:FAS]VEHCO2  <= 160 : [F:TVSM]TARIFCO2 = 11.5
    Elsif  [F:FAS]VEHCO2  > 160 and [F:FAS]VEHCO2  <= 200 : [F:TVSM]TARIFCO2 = 18
    Elsif  [F:FAS]VEHCO2  > 200 and [F:FAS]VEHCO2  <= 250 : [F:TVSM]TARIFCO2 = 21.5
    Elsif  [F:FAS]VEHCO2  > 250                           : [F:TVSM]TARIFCO2 = 27
Endif
#########################################
# Fiscal Power / Puissance fiscale
#########################################
If           [F:FAS]VEHPWR  = 0                             : [F:TVSM]TARIFPWR = 0
    Elsif    [F:FAS]VEHPWR  > 0    and [F:FAS]VEHPWR   <=3  : [F:TVSM]TARIFPWR = 750
    Elsif    [F:FAS]VEHPWR  >= 4   and [F:FAS]VEHPWR  <= 6  : [F:TVSM]TARIFPWR = 1400
    Elsif    [F:FAS]VEHPWR  >= 7   and [F:FAS]VEHPWR  <= 10 : [F:TVSM]TARIFPWR = 3000
    Elsif    [F:FAS]VEHPWR  >= 11  and [F:FAS]VEHPWR  <= 15 : [F:TVSM]TARIFPWR = 3600
    Elsif    [F:FAS]VEHPWR  >= 16                           : [F:TVSM]TARIFPWR = 4500
Endif
#########################################
# Air Tax / Tarif Air
#########################################
If [F:FAS]FUEL> 0
    [F:TVSM]FUELDES=mess([F:FAS]FUEL,3167,1) #FQNEW
Endif
If [F:FAS]FIRICIDAT <= [31/12/1996]
    If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 70  : Endif
    If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 600 : Endif
Endif
If [F:FAS]FIRICIDAT > [31/12/1996]  and  [F:FAS]FIRICIDAT <= [31/12/2000]
    If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
    If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 400 : Endif
Endif
If [F:FAS]FIRICIDAT > [31/12/2000]  and  [F:FAS]FIRICIDAT <= [31/12/2005]
    If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
    If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 300 : Endif
Endif
If [F:FAS]FIRICIDAT > [31/12/2005]  and  [F:FAS]FIRICIDAT <= [31/12/2010]
    If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 45  : Endif
    If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 100 : Endif
Endif
If [F:FAS]FIRICIDAT > [31/12/2010]
    If  [F:FAS]FUEL  = 1 :   [F:TVSM]TARIFAIR = 20  : Endif
    If  [F:FAS]FUEL  = 2 :   [F:TVSM]TARIFAIR = 40  : Endif
Endif
##########################################
# Exoneration period/Période d'exonération
##########################################
#-----------------------------------------------------------------------
# Cars with exoneration (TAXPLI = 3 Exoneration )
# Exoneration runs over 8 quarters beginning the 1st day of the quarter
# whithin which is the date of first circulation of the car
#-----------------------------------------------------------------------
# Véhicules en exonération (TAXPLI = 3 Exonération )
# l'exonération s'applique pendant 8 trimestres à partir du 1er jour du trimestre
# dans lequel se situe la date de 1ère mise en circulation
#-----------------------------------------------------------------------
Raz [L]DEBEXODAT, [L]FINEXODAT
If [F:FAS]TAXPLI = 3   :# Total exoneration / Exonération totale
     DATEXOTRIM1 =  gdat$(01, 01, year([F:FAS]FIRICIDAT))
     DATEXOTRIM2 =  gdat$(01, 04, year([F:FAS]FIRICIDAT))
     DATEXOTRIM3 =  gdat$(01, 07, year([F:FAS]FIRICIDAT))
     DATEXOTRIM4 =  gdat$(01, 10, year([F:FAS]FIRICIDAT))
     If  [F:FAS]FIRICIDAT>= DATEXOTRIM1 and [F:FAS]FIRICIDAT < DATEXOTRIM2
        [L]DEBEXODAT = DATEXOTRIM1
     Else
        If [F:FAS]FIRICIDAT >= DATEXOTRIM2 and [F:FAS]FIRICIDAT < DATEXOTRIM3
           [L]DEBEXODAT = DATEXOTRIM2
        Else
           If  [F:FAS]FIRICIDAT >= DATEXOTRIM3 and [F:FAS]FIRICIDAT < DATEXOTRIM4
              [L]DEBEXODAT = DATEXOTRIM3
           Else
              If  [F:FAS]FIRICIDAT >= DATEXOTRIM4
                 [L]DEBEXODAT = DATEXOTRIM4
              Endif
           Endif
        Endif
     Endif
     [L]FINEXODAT =  gdat$(day([L]DEBEXODAT)-1, month([L]DEBEXODAT), year([L]DEBEXODAT)+2)
Else
     [L]FINEXODAT=[F:FAS]FIRICIDAT
Endif
[F:TVSM]EXOENDDAT = [L]FINEXODAT
#######################################################
# Rent Duration and period / Durée et periode location
#######################################################
Raz [L]LRNTDUR, [L]STRRNTTVS, [L]ENDRNTTVS
If [F:FAS]OWNTYP = 2 :# Rented car / Vehicule en location
      If    func IS_INSIDE([F:FAS]RNTSTRDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)   and func IS_INSIDE([F:FAS]RNTENDDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)
        [F:TVSM]RNTDUR = (([F:FAS]RNTENDDAT - [F:FAS]RNTSTRDAT)+1)
        [L]STRRNTTVS = [F:FAS]RNTSTRDAT
        [L]ENDRNTTVS = [F:FAS]RNTENDDAT
      Elsif func IS_INSIDE([F:FAS]RNTSTRDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)   and func IS_INSIDE([F:FAS]RNTENDDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)=0
        [F:TVSM]RNTDUR = (([L]LIMPENDDAT- [F:FAS]RNTSTRDAT)+1)
        [L]STRRNTTVS = [F:FAS]RNTSTRDAT
        [L]ENDRNTTVS = [L]LIMPENDDAT
      Elsif func IS_INSIDE([F:FAS]RNTSTRDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)=0 and func IS_INSIDE([F:FAS]RNTENDDAT,[L]LIMPSTRDAT,[L]LIMPENDDAT)
        [F:TVSM]RNTDUR = (([F:FAS]RNTENDDAT- [L]LIMPSTRDAT)+1)
        [L]STRRNTTVS = [L]LIMPSTRDAT
        [L]ENDRNTTVS = [F:FAS]RNTENDDAT
      Elsif [F:FAS]RNTSTRDAT <= [L]LIMPSTRDAT and [F:FAS]RNTENDDAT >= [L]LIMPENDDAT
        [F:TVSM]RNTDUR = ((LIMPENDDAT- LIMPSTRDAT)+1)
        [L]STRRNTTVS = [L]LIMPSTRDAT
        [L]ENDRNTTVS = [L]LIMPENDDAT
      Else
        [F:TVSM]RNTDUR = 0
      Endif
      [L]LRNTDUR = [F:TVSM]RNTDUR
      # Correcting february to 30 / Correction du mois de fevrier à 30
      Call FEB_MNGT([L]STRRNTTVS,[L]ENDRNTTVS,[L]LANNEE,[L]LRNTDUR)
      # If the rent start and end dates has exact match with calendar start and end of month
      # Si les debut et fin de location cadrent avec des debut et fin de mois calendaires
      If  func IS_FOMONTH([L]STRRNTTVS, [L]LIMPSTRDAT, LYEAR17) and
&         func IS_EOMONTH([L]ENDRNTTVS, [L]LIMPSTRDAT, LYEAR17) and
&         [L]LRNTDUR >= 30
          [L]LRNTDUR = [L]LRNTDUR - mod([L]LRNTDUR,30)
      Endif
Endif
######################################################
# Rent exo duration / Durée période location exonérée
######################################################
Raz [L]LRNTDUREXO,[L]STRRNTEXO,[L]ENDRNTEXO
# Total exoneration & Rented car / Exo totale & vehicule en location
If [F:FAS]TAXPLI = 3 and [F:FAS]OWNTYP = 2 and [L]FINEXODAT<>[F:FAS]FIRICIDAT
      If    func IS_INSIDE([L]DEBEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)   and func IS_INSIDE([L]FINEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)
        [L]LRNTDUREXO = (([L]FINEXODAT - [L]DEBEXODAT)+1)
        [L]STRRNTEXO = [L]DEBEXODAT
        [L]ENDRNTEXO = [L]FINEXODAT
      Elsif func IS_INSIDE([L]DEBEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)   and func IS_INSIDE([L]FINEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)=0
        [L]LRNTDUREXO = (([L]ENDRNTTVS - [L]DEBEXODAT)+1)
        [L]STRRNTEXO = [L]DEBEXODAT
        [L]ENDRNTEXO = [L]ENDRNTTVS
      Elsif func IS_INSIDE([L]DEBEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)=0 and func IS_INSIDE([L]FINEXODAT,[L]STRRNTTVS,[L]ENDRNTTVS)
        [L]LRNTDUREXO = (([L]FINEXODAT - [L]STRRNTTVS)+1)
        [L]STRRNTEXO = [L]STRRNTTVS
        [L]ENDRNTEXO = [L]FINEXODAT
      Elsif [L]DEBEXODAT <= [L]STRRNTTVS and [L]FINEXODAT >= [L]ENDRNTTVS
        [L]LRNTDUREXO = (([L]ENDRNTTVS- [L]STRRNTTVS)+1)
        [L]STRRNTEXO = [L]STRRNTTVS
        [L]ENDRNTEXO = [L]ENDRNTTVS
      Else
        [L]LRNTDUREXO = 0
      Endif
      # Correcting february to 30 / Correction du mois de fevrier à 30
      Call FEB_MNGT([L]STRRNTEXO,[L]ENDRNTEXO,[L]LANNEE,[L]LRNTDUREXO)
      # If the rent start and end dates has exact match with calendar start and end of months of the exercice
      # Si les debut et fin de location cadrent avec des debut et fin de mois calendaires de l'exercice
      If  func IS_FOMONTH([L]STRRNTEXO, [L]LIMPSTRDAT, LYEAR17) and
&         func IS_EOMONTH([L]ENDRNTEXO, [L]LIMPSTRDAT, LYEAR17) and
&         [L]LRNTDUREXO >= 30
          [L]LRNTDUREXO = [L]LRNTDUREXO - mod([L]LRNTDUREXO,30)
      Endif
Endif
#########################################
# Quarter calculation / Calcul trimestres
#########################################
# If Fuel type is Electric then no taxe = full exoneration
# Si Type carburant Electrique alors pas de taxe = exo totale
If [F:FAS]FUEL>2
  [F:TVSM]NBTRIM1E = [F:TVSM]NBTRIM1P
  [F:TVSM]NBTRIM1P = 0
Else        :# Fuel Diesel & similar/Essence Diesel et assimilé
  Raz [F:TVSM]NBTRIM1E
  # No of quarters calculation / Calcul des trimestres
  Case [F:FAS]OWNTYP
    When 2
      Gosub CAL_QUARTERS_RENT         # Rented cars : Full tax quarters / locations : Nbr trim Taxe plain
      If  [F:FAS]TAXPLI=3             # Rented cars : Exonerated / Exonéré
        Gosub CAL_QUARTERS_RENT_EXO   # Rented cars : Tax exonerated quarters / Locations : Nbr trim Taxe exo
      Endif
    When Default
      Gosub CAL_QUARTERS_NORENT       # Other cars : Full tax quarters / Autres : Nbr trim Taxe plein
      If  [F:FAS]TAXPLI=3             # Other cars : Exonerated / Exonéré
        Gosub CAL_QUARTERS_NORENT_EXO # Other cars : Tax exonerated quarters / Autres : Nbr trim Taxe exo autres
      Endif
  Endcase
  If [F:TVSM]NBTRIM1E>0 and [F:TVSM]NBTRIM1P>=[F:TVSM]NBTRIM1E
    # Full tax quarters corrected by tax exo quarters
    # Correction nbr de trim taxe plein par le nbr trim taxe exo
    [F:TVSM]NBTRIM1P -= [F:TVSM]NBTRIM1E
  Endif
Endif
#########################################
# First Component / 1ère Composante
#########################################
# Applied on the non exonerated quarters / porte sur le nb de trimestres non exonérés dans la période
If [F:FAS]VEHTAXRUL = 2
  #------------------------------ CO2
  [F:TVSM]TAXECOL1 =  (([F:FAS]VEHCO2 * [F:TVSM]TARIFCO2 ) * [F:TVSM]NBTRIM1P) / 4
Else
  #------------------------------ Fiscal Power / Puissance fiscale
  [F:TVSM]TAXECOL3 =  ([F:TVSM]TARIFPWR * [F:TVSM]NBTRIM1P) / 4
Endif
#########################################
# Second Component / 2e Composante
#########################################
#------------------------------ Air Tax / Tarif Air
[F:TVSM]NBTRIM1T =  [F:TVSM]NBTRIM1P + [F:TVSM]NBTRIM1E
[F:TVSM]TAXECOL2 =  ([F:TVSM]TARIFAIR * [F:TVSM]NBTRIM1T) / 4
#########################################
# Total tax / Total Taxe
#########################################
If [F:FAS]VEHTAXRUL = 2
  # Total tax CO2 / Total CO2
  [F:TVSM]TAXECOL1 =[F:TVSM]TAXECOL1 + [F:TVSM]TAXECOL2
Else
  # Total tax Fiscal Power / Total Puissance fiscale
  [F:TVSM]TAXECOL3 =[F:TVSM]TAXECOL3 + [F:TVSM]TAXECOL2
Endif
Return

####################################################################
# Quarter calculation for rented cars / calcul trim. vehicules loués
####################################################################
$CAL_QUARTERS_RENT
# No of quarters based on the duration of the rental
# Nbr de trimestres basé sur la durée de location
Call RENT_QUARTER_NO([L]LRNTDUR,LYEAR17,[F:TVSM]NBTRIM1P)
Return

######################################################################################
# Exonerated quarter calculation for rented cars / calcul tim exonérés vehicules loués
######################################################################################
$CAL_QUARTERS_RENT_EXO
Call RENT_QUARTER_NO([L]LRNTDUREXO,LYEAR17,[F:TVSM]NBTRIM1E)
Return

#######################################################################
# Quarter calculation for owned cars / calcul trim. vehicules non-loués
#######################################################################
$CAL_QUARTERS_NORENT
Raz [F:TVSM]NBTRIM1P
Raz LTRIMI,LMAXTRIM, LDATW
# 2017 Exception : 5 quarters to consider / 5 trim à prendre en cpte
If LYEAR17 : LMAXTRIM=5 : Else : LMAXTRIM=4 : Endif
# Looping on the quarters of the taxing period
# Boucle sur les trim de la période d'imposition
For LTRIMI=1 To LMAXTRIM
    # Should the quarter be taxed ? / le trim doit il etre compté ?
    LDATW=evalue("[L]LDEBTRIM"+num$(LTRIMI))
    If  LDATW >= [F:FAS]PURDAT and ( LDATW<[F:FAS]ISSDAT or [F:FAS]ISSDAT<LDATNULL )
      [F:TVSM]NBTRIM1P += 1
    Endif
Next
Return

#########################################################################################
# Exonerated quarter calculation for owned cars / calcul tim exonérés vehicules non-loués
#########################################################################################
$CAL_QUARTERS_NORENT_EXO
Raz [F:TVSM]NBTRIM1E
Raz LTRIMI,LMAXTRIM,LDATW
# 2017 exception : 5 quarters to consider / 5 trim à prendre en cpte
If LYEAR17 : LMAXTRIM=5 : Else : LMAXTRIM=4 : Endif
# Looping on the quarters of the taxing period
# Boucle sur les trim de la période d'imposition
For LTRIMI=1 To LMAXTRIM
    LDATW=evalue("[L]LDEBTRIM"+num$(LTRIMI))
    # Is the quarter exonerated ? / le trim est-il exonéré ?
    If  LDATW >= [F:FAS]PURDAT and ( LDATW<[F:FAS]ISSDAT or [F:FAS]ISSDAT<LDATNULL )
      If  LDATW >= [L]DEBEXODAT and LDATW<[L]FINEXODAT
        [F:TVSM]NBTRIM1E += 1
      Endif
    Endif
Next
Return

####################################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
Endif
End

###################################################
#**
#* Sub program Quarter calculation for rented cars
#* Routine de  Calcul de nbr de trimestres pour locations
#* @param PDUR  Rent Duration / Durée location
#* @param PYEA  2017 exception (1= 2017 0=2018+)
#* @param RNBQ  No of quarters / Nbr de trimestres
#*!
Subprog RENT_QUARTER_NO(PDUR,PYEA,RNBQ)
Value    Integer    PDUR
Value    Integer    PYEA
Variable Shortint   RNBQ
Raz RNBQ
 If  PDUR < 31
     RNBQ = 0
 Else
    If  PDUR> 30 and PDUR < 91
        RNBQ = 1
    Else
       If  PDUR> 90 and PDUR < 181
           RNBQ = 2
       Else
          If  PDUR> 180 and PDUR < 271
              RNBQ = 3
          Else
            If PYEA                             :# 2017 Exception
               If  PDUR> 270 and PDUR < 361     :# 2017 Exception
                   RNBQ =4                      :# 2017 Exception
               Else                             :# 2017 Exception
                  If PDUR> 360                  :# 2017 Exception
                     RNBQ =5                    :# 2017 Exception
                  Endif                         :# 2017 Exception
               Endif                            :# 2017 Exception
            Else                                :# 2017 Exception
               If  PDUR> 270
                   RNBQ =4
               Endif
            Endif                               :# 2017 Exception
          Endif
       Endif
    Endif
 Endif
End

###################################################
#**
#* Is a date between 2 dates / Date incluse entre 2 dates ?
#* RRET 0=No 1=Yes
#* @param PDATW   Date
#* @param PDSTR   Start date
#* @param PDEND   End date
#*!
Funprog IS_INSIDE(PDATW,PDSTR,PDEND)
Value Date PDATW
Value Date PDSTR
Value Date PDEND
Local Integer RRET : Raz RRET
If PDATW >= PDSTR and PDATW <= PDEND
  RRET=1
Endif
End RRET

###################################################
#**
#* Is a date a first of month in a taxing period
#* Une date est-elle un premier de mois dans la periode d'imposition
#* RRET 0=No 1=Yes
#* @param PDATW     Date
#* @param PSTRDAT   Start date of the taxation exercice
#* @param PYEA      2017 exception
#*!
Funprog IS_FOMONTH(PDATW,PSTRDAT,PYEA)
Value Date PDATW
Value Date PSTRDAT
Value Integer PYEA
Local Integer RRET
Local Integer IMONTH,MAXMON
Raz RRET
[L]MAXMON=12
If PYEA : MAXMON = 15 Endif
For [L]IMONTH = 0 To [L]MAXMON
    If PDATW = addmonth(PSTRDAT,[L]IMONTH)
      RRET=1
      Break
    Endif
Next
End RRET

###################################################
#**
#* Is a date an end of month in a taxing period
#* Une date est-elle un dernier de mois dans la periode d'imposition
#* RRET 0=No 1=Yes
#* @param PDATW     Date
#* @param PSTRDAT   Start date of the taxation exercice
#* @param PYEA      2017 exception
#*!
Funprog IS_EOMONTH(PDATW,PSTRDAT,PYEA)
Value Date PDATW
Value Date PSTRDAT
Value Integer PYEA
Local Integer RRET
Local Integer IMONTH,MAXMON
Raz RRET
[L]MAXMON=12
If PYEA : MAXMON = 15 Endif
For [L]IMONTH = 0 To [L]MAXMON
    If PDATW = eomonth( addmonth(PSTRDAT,[L]IMONTH) )
      RRET=1
      Break
    Endif
Next
End RRET

###################################################
#**
#* If the a rent period includes february : correcting the duration to acheive 30 for february
#* Si une periode de loc inclut février : corriger la durée de location par rapport à 30 pour fevrier
#*
#* @param PDSTR     Start date of the rent period
#* @param PDEND     End date of the rent period
#* @param PYEAR     Year of the taxation exercice
#* @param RDUR      Duration of the rent period
#*!
Subprog FEB_MNGT(PDSTR,PDEND,PYEAR,RDUR)
Value Date    PDSTR
Value Date    PDEND
Value Integer PYEAR
Variable Integer RDUR
Local Integer LGAP
If PDSTR <= gdat$(1,2,PYEAR) and PDEND >= eomonth(gdat$(1,2,PYEAR))
  # gap between no of days of february and 30
  # ecrat en nb de jours entre le nb de jour de fevrier et 30
  [L]LGAP = 30 - (day(gdat$(0,3,PYEAR)))
  # February was counted in the duration, we correct the calculated duration to count it as 30 days.
  # Necessary for the "modulo 30" following the call of this sub-program
  # Le mois de férier a été compté, on corrige la durée calculé pour le compter comme 30 jours
  # nécessaire pour le "modulo 30" qui suit l'appel de ce sous-programe
  RDUR += [L]LGAP
Endif
End

