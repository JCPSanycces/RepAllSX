#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Initialisation des nouveaux champs "Téléphone"
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Init 'Phone' fied") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTEL
End

#-------------------#
$MAJTEL
Local Integer I , RW

Local File =DOSSIER+".BPADDRESS" [BPA]

If dim([F:BPA]TEL)<=1 : Return : Endif

# Mise à jour de la table BPADDRESS
Call ECR_TRACE(mess(81,125,1)-"BPADDRESS:"-time$,0) From GESECRAN

Trbegin [BPA]
 For [BPA]
  RW = 0

  # tél
  If [F:BPA]TEL(1)="" & [F:BPA]FAX<>""
   [F:BPA]TEL(1)    = [F:BPA]FAX
   RW = 1
  Endif
  If [F:BPA]TEL(4)="" & [F:BPA]MOB<>""
   [F:BPA]TEL(4)    = [F:BPA]MOB
   RW = 1
  Endif

  If RW
   Rewrite [BPA]
   If fstat
    Call ERREUR("BPADDRESS"-num$([F:BPA]BPATYP)-[F:BPA]BPANUM-[F:BPA]BPAADD,2) From DOSDIC
   Endif
  Endif
 Next BPA
Commit
Return
