####################################################################
# 10 : FINTAXCLC Final tax calc. ( Field Local menu number 11656)
####################################################################

$SET_FINTAXCLC
If [L]_AOLDVAL<>this.FINTAXCLC
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_FINTAXCLC
