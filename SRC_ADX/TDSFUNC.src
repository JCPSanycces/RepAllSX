#<AdxTL>@(#)3.0.0.0 $Revision$
Funprog MENU(NOMZONE)
Value Char NOMZONE()
Local Char VARIA (20)
Local Integer IMESS
Case NOMZONE
 When "X" : RESULTAT="AZERTY"
 When "[F:DAE]TYPJOB" :
  Case evalue(NOMZONE)
   When 1,2,4,5 : RESULTAT="0"+ num$(evalue(NOMZONE))
   When 9  : RESULTAT="06"
   When 10 : RESULTAT="07"
   When 11 : RESULTAT="90"
   When 13 : RESULTAT="08"
   When Default : RESULTAT="90"
  Endcase
 When "[F:DAE]WRKSTG" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT="01" :#Etranger
   When 2 : RESULTAT="" 
   When 3 : RESULTAT="02" :#Frontalier
   When Default : RESULTAT=""
  Endcase
 When "[F:DAE]TIP" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT=""
   When 2 : RESULTAT="P"
   When Default : RESULTAT=""
  Endcase
 When "[F:DAE]NTIC" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT=""
   When 2 : RESULTAT="T"
   When Default : RESULTAT=""
  Endcase
 When "[F:DAE]OPEDED" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT="R"
   When 2 : RESULTAT="F"
   When Default : RESULTAT=""
  Endcase
 When "[F:DFC]TAXWAG" :
  Case evalue(NOMZONE)
   When 1 : RESULTAT="02"
   When 2 : RESULTAT="01"
   When Default : RESULTAT="02"
  Endcase
 When "[M:DIA]SRV"
  Case evalue(NOMZONE)
   When 1 : RESULTAT="10"
   When 2 : RESULTAT="11"
   When 3 : RESULTAT="12"
   When 4 : RESULTAT="40"
   When 5 : RESULTAT="50"
   When 6 : RESULTAT="51"
   When 7 : RESULTAT="52"
   When Default : RESULTAT="40"
  Endcase
 When "[M:DIA]TEST"
  Case evalue(NOMZONE)
  When 1,2 : RESULTAT="0"+ num$(evalue(NOMZONE))
  When Default : RESULTAT="01"
  Endcase
 When "[F:TD0]DENCODCOM","[F:TD0]CNTCODCOM"
  Case evalue(NOMZONE)
   When 1,2,3,4,5 : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT=""
  Endcase
 When "[F:DAE]CIV"
  Case evalue(NOMZONE)
   When 1,2,3   : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT=""
  Endcase
 When "[F:WAC]CODOFC"
  Case evalue(NOMZONE)
   When 1 : RESULTAT=""
   When 2 : RESULTAT="B"
   When Default : RESULTAT=""
  Endcase
 When "[F:DAE]SEVEMP"
  Case evalue(NOMZONE)
   When 1,2     : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]MOVPAY"
  RESULTAT="0"+ num$(evalue(NOMZONE))
 When "[F:DAE]UOMTIMWRK"
  Case evalue(NOMZONE)
   When 1 : RESULTAT="01"
   When 2 : RESULTAT="03"
   When 3 : RESULTAT="07"
   When Default : RESULTAT="01"
  Endcase
 When "[F:SIT]REGPRH"
  Case evalue(NOMZONE)
   When 1,2,3,4 : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="04"
  Endcase
 When "[F:DAP]CODTYPBAS"
  Case evalue(NOMZONE)
   When 1,2,3   : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="03"
  Endcase
 When "[F:DAP]CODSITFAM","[F:DAE]BUISITFAM"
  Case evalue(NOMZONE)
   When 1,2,3,4,5,6,7   : RESULTAT="0"+ num$(evalue(NOMZONE))
   When 8 : RESULTAT="90"
   When Default : RESULTAT="90"
  Endcase
 When "[F:DAE]BUICODTIM", "[F:DAE]SPETIMEVE"
  Case evalue(NOMZONE)
   When 1 : RESULTAT="01"
   When 2 : RESULTAT="03"
   When 3 : RESULTAT="07"
   When 4 : RESULTAT="09"
   When Default : RESULTAT="07"
  Endcase
 When "[F:DAE]BUICODASS"
  Case evalue(NOMZONE)
   When 1 : RESULTAT="02"
   When 2 : RESULTAT="01"
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]BUICODSAL"
  Case evalue(NOMZONE)
   When 1,2,3 : RESULTAT="0"+ num$(evalue(NOMZONE))
  Endcase
 When "[F:DAE]BUICODHRS"
  Case evalue(NOMZONE)
   When 1,2 : RESULTAT="0"+ num$(evalue(NOMZONE))
  Endcase
 When "[F:DAE]BUISTAPAY"
  Case evalue(NOMZONE)
   When 1,2,3   : RESULTAT="0"+ num$(evalue(NOMZONE))
   When 4       : RESULTAT="90" 
   When Default : RESULTAT="90"
  Endcase
 When "[F:DAE]PRUCOL"
  Case evalue(NOMZONE)
   When 1   : RESULTAT="02"
   When 2   : RESULTAT="01"
   When Default : RESULTAT="02"
  Endcase
 When "[F:DAE]PRUACV" 
  Case evalue(NOMZONE)
   When 1,2,3,4,5  : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="04"
  Endcase
 When "[F:DAE]PRUVOT" 
  Case evalue(NOMZONE)
   When 1,2  : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]PRUCTR" 
  Case evalue(NOMZONE)
   When 1,2  : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]PRUFLG" 
  Case evalue(NOMZONE)
   When 1  : RESULTAT="02"
   When 2  : RESULTAT="01"    :#Présent au 31/12
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]BUIRETPRV" 
  Case evalue(NOMZONE)
   When 1,2,3  : RESULTAT="0"+ num$(evalue(NOMZONE))
   When Default : RESULTAT="01"
  Endcase
 When "[F:DAE]OLDSPE"
  Case evalue(NOMZONE)
   When 2       : RESULTAT="01"
  Endcase
Endcase
End RESULTAT

#########################################

Funprog TABLE(VARIA, NOMZONE)
Value Char VARIA ()
Value Char NOMZONE ()
Local Char VALZONE (50)
Local Integer I,NUMTAB
Local Char RESULTAT (100)
NUMTAB = evalue(VARIA)
VALZONE= evalue(NOMZONE)
If VALZONE<>""
 Read [ADI]CODE=NUMTAB;VALZONE
 If fstat<>0
  Call ECR_TRACE("Erreur de lecture sur le fichier :"-"ATABDIV [ADI]",0) From GESECRAN
 Else
  RESULTAT=[F:ADI]A1
 Endif
Endif
End RESULTAT
