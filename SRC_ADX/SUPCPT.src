#<AdxTL>@(#)8.0.0.0 $Revision$
############################################################################
## Contrôles interface compta du superviseur
############################################################################
$ACTION
Case ACTION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

$SEL_TABLE
Case TABLE
 When "SELSAC"    : Gosub S_SAC
 When "SELSACBPR" : Gosub S_SACBPR
Endcase
Return

$S_SAC
#40051
#If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
#Default File [GAC]
#CRITERE = "TYP=3"
CRITERE = "SAC=2"
ORDRE   = "ACCSHO;ACC"
START   = "ACCSHO"
OBJET   = "GAC"
Return

$S_SACBPR
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Default File [GAC]
#CRITERE = "TYP=3 & AUZBPR(5)=2"
CRITERE = "SAC=2 & AUZBPR(5)=2"
ORDRE   = "ACCSHO;ACC"
START   = "ACCSHO"
OBJET = "GAC"
Return

#########################################################################
Subprog CONTSAC(SAC)
Variable Char SAC()
If SAC="" : End : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
Read [GAC]GAC1 = SAC
#If fstat | [F:GAC]TYP<>3
If fstat | [F:GAC]SAC<>2
 GMESSAGE = mess(9,106,1) : mkstat = 2 : End
# Collectif inexistant
Endif
End

#########################################################################
Subprog SECTION(VALEUR,CTLFCY,FCY,DAT,AXE)
Variable Char     VALEUR
Value    Integer  CTLFCY
Value    Char     FCY
Value    Date     DAT
Value    Char     AXE

If VALEUR="" : End : Endif

If clalev([F:CCE])= 0  : Local File CACCE [CCE] : Endif

Call LECTURE("CCE",VALEUR,num$(AXE)) From CONTOBJ
If fstat
 # Section inexistante
 GMESSAGE = VALEUR-mess(35,106,1)
 mkstat = 2 : End
Endif

If CTLFCY=2
 Call VERIF([F:CCE]FCY,FCY,VALEUR) From CFYSUB
 If mkstat : End : Endif
Endif

#----------------------------#
# controle section imputable #
#----------------------------#
If [F:CCE]IPT<>2
 GMESSAGE = VALEUR-mess(24,106,1) : # Section non imputable
 mkstat=1 : End
Endif

#--------------------------#
# controle date expiration #
#--------------------------#
If DAT<>[0/0/0]
 Call CTLVLYDAT(DAT,[F:CCE]VLYSTR,[F:CCE]VLYEND)
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : Endif
Endif

#----------------------#
# controle code accés  #
#----------------------#
Call CONTEXE([F:CCE]ACS) From SUBACS
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif

End

#################################################################
#   Contrôle de limite de validité d'une date                   #
#################################################################
Subprog CTLVLYDAT(DAT,DATDEB,DATFIN)
Value    Date     DAT
Value    Date     DATDEB
Value    Date     DATFIN
Call CTLVLYDAT(DAT,DATDEB,DATFIN) From EXEFNC
End

#############################################################
## Appel d'un compte par son code court                    ##
#############################################################
Subprog CONTCPT(VALEUR)
Variable Char VALEUR
If VALEUR<>""
 If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT" [GAC] : Endif
 Call LECTURE("GAC",VALEUR,"") From CONTOBJ
 If fstat
  Read [GAC]GAC1 = VALEUR
  If !fstat : VALEUR = [F:GAC]ACC : Endif
 Endif
Endif
End


#################################################################
## Contrôle que le site est autorisé pour la fonction courante ##
#################################################################
Subprog CONTFCY(VALEUR)
Variable Char     VALEUR
Call CONTFCY(VALEUR) From EXEFNC
End

Subprog CONTCPY(SOC)
Variable Char    SOC
Call CONTCPY(SOC) From EXEFNC
End

#################################################################
## Recherche du site par défaut d'une société                  ##
#################################################################
Subprog INIFCY(SITE,SOC)
Variable Char    SITE
Value    Char    SOC
Call INIFCY(SITE,SOC) From EXEFNC
End

Subprog INICPY(SOC)
Variable Char     SOC
Call INICPY(SOC) From EXEFNC
End

Subprog CONTFCYCPY(SITE,SOC)
Value    Char    SITE
Value    Char    SOC
Call CONTFCYCPY(SITE,SOC) From EXEFNC
End

################################################################
## Contrôle que tous les sites d'une société sont accessibles  #
################################################################
Subprog CONTALLFCY(SOC)
Value Char    SOC
Call CONTALLFCY(SOC) From EXEFNC
End

Subprog VERFALLFCY(SOC,OK)
Value    Char     SOC
Variable Integer  OK
Call VERFALLFCY(SOC,OK) From EXEFNC
End

################################################################
## Contrôle qu'une date de fin est inférieure à date début    ##
################################################################
Subprog DATDEBFIN(DATFIN,DATDEB)
Value Date DATDEB
Value Date DATFIN
Call DATDEBFIN(DATFIN,DATDEB) From EXEFNC
End

################################################################
## Droit de modifier la zone utilisateur                      ##
################################################################
Subprog CONTUSR(SOCIETE,SITE)
Value Char    SOCIETE, SITE
Call CONTAUZ(SOCIETE,SITE,"U")
End

################################################################
## Contrôle droit pour une option d'une fonction              ##
################################################################
Subprog CONTAUZ(SOCIETE,SITE,OPT)
Value Char    SOCIETE, SITE, OPT
Call CONTAUZ(SOCIETE,SITE,OPT) From EXEFNC
End

################################################################
##  Droits sur site pour la fonction                          ##
##  Avec recherche droit sur la fonction associée à l'option  ##
################################################################
Subprog DROITSITE(SITE,AUZ,OK)
Value    Char     SITE
Variable Char     AUZ
Variable Integer  OK
Call DROITSITE(SITE,AUZ,OK) From EXEFNC
End

################################################################
## Droits sur site pour une fonction                          ##
################################################################
Subprog DROITSITEF(FNC,SITE,AUZ,OK)
Value    Char    FNC
Value    Char    SITE
Variable Char    AUZ
Variable Integer OK
Call DROITSITEF(FNC,SITE,AUZ,OK) From EXEFNC
End

