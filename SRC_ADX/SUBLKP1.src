##########################################################################################################
Subprog AS_NBCMG

  If nolign >= dim([M:LKP1]NUM) Then
    End
  Endif
  If nolign > 0 Then
    Call LOADOPG(nolign-1) From TRTLKP1
    If [M:LKP1]PRECMGNOL <> nolign-1 Then
      [M:LKP1]NBCMGSEL([M:LKP1]PRECMGNOL) = ""
      [M:LKP1]NBCMGSEL(nolign-1) = "->"
      [M:LKP1]PRECMGNOL = nolign-1
    Endif
  Endif
  Affzo [M:LKP1]1-99
End

##########################################################################################################
Subprog C_NBCMG

  If nolign >= dim([M:LKP1]NUM) Then
    End
  Endif
  If nolign > 0 Then
    Call LOADOPG(nolign-1) From TRTLKP1
    If [M:LKP1]PRECMGNOL <> nolign-1 Then
      [M:LKP1]NBCMGSEL([M:LKP1]PRECMGNOL) = ""
      [M:LKP1]NBCMGSEL(nolign-1) = "->"
      [M:LKP1]PRECMGNOL = nolign-1
    Endif
  Endif
  Affzo [M:LKP1]1-99
End

##########################################################################################################
Subprog AS_NBOPG

  If nolign >= dim([M:LKP1]OPG) Then
    End
  Endif
  If nolign > 0 Then
    Call LOADMASK([M:LKP1]PRECMGNOL, nolign-1) From TRTLKP1
    If [M:LKP1]PREOPGNOL <> nolign-1 Then
      Raz [M:LKP1]NBOPGSEL
      [M:LKP1]NBOPGSEL(nolign-1) = "->"
      [M:LKP1]PREOPGNOL = nolign-1
    Endif
  Endif
  Affzo [M:LKP1]1-99
End

##########################################################################################################
Subprog C_NBOPG

  If nolign >= dim([M:LKP1]OPG) Then
    End
  Endif
  If nolign > 0 Then
    Call LOADMASK([M:LKP1]PRECMGNOL, nolign-1) From TRTLKP1
    If [M:LKP1]PREOPGNOL <> nolign-1 Then
      Raz [M:LKP1]NBOPGSEL
      [M:LKP1]NBOPGSEL(nolign-1) = "->"
      [M:LKP1]PREOPGNOL = nolign-1
    Endif
  Endif
  Affzo [M:LKP1]1-99
End

##########################################################################################################
Subprog C_CRIDATSTR(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [00/00/00] Then
    If [M:LKP1]CRIDATEND <> [00/00/00] Then
      If VALEUR > [M:LKP1]CRIDATEND Then
        #La date de début de période est supérieure à la date de fin de période.
        GMESSAGE = mess(33,177,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_CRIDATEND(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [00/00/00] Then
    If [M:LKP1]CRIDATSTR <> [00/00/00] Then
      If VALEUR < [M:LKP1]CRIDATSTR Then
        #La date de fin de période est inférieure à la date de début de période.
        GMESSAGE = mess(34,177,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End
