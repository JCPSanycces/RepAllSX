#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
######################################################################
# IMPGRA : Import / Export des Subventions                     #
######################################################################
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "SAIMSK"    : Gosub SAIMSK
 When "VALID"     : Gosub VALID
Endcase
Return

###################################################################################
$IMP_OUVRE
Local Mask GRA0 [GRA0], GRA1 [GRA1], GRA2 [GRA2], GRA3 [GRA3], GRA4 [GRA4]
Gosub OUVRE From DEFTABLE
#Fichier utilisés par les controles
If clalev ([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev ([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev ([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif

If clalev ([F:CCE])=0 : Local File =GTABCPT+"CACCE"      [CCE] : Endif

Local Integer INDNOL, I
nolign=0
Return

###################################################################################
$RAZCRE
#Initialisation des masks et des variables
Raz [M:EMP0], [M:GRA1], [M:EMP2], [M:GRA3], [M:GRA4]
Return

###################################################################################
$SAIMSK
#Affectation des masks
Case IMPFIC
 When "GRA"
  nolign = 1
  [M:GRA0] = [F:GRA]
  [M:GRA1] = [F:GRA]
  [M:GRA2] = [F:GRA]
  [M:GRA3] = [F:GRA]
  [M:GRA4] = [F:GRA]
Endcase
Return

###################################################################################
$VALID
GOK=1
If nolign=0 : Return : Endif
Call TRACE(0,[M:GRA0]GRAREF) From SUBIMPOBJ
Gosub VERIF_OBLIGATOIRE

If GOK<>0
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GOK<1 : Gosub AB_TR1 : Endif
Endif
Return

###################################################################################
$VERIF_OBLIGATOIRE

If [M:GRA0]GRAREF=""
 # Erreur  Référence non renseignée
 Call TRACE(2,mess(4,146,1)) From SUBIMPOBJ
 GOK=0 : Return
Else
 Look[F:GRA]GRA0=[M:GRA0]GRAREF
 If fstat=0
 # Erreur Import impossible : référence déjà attribuée
  Call TRACE(2,mess(22,146,1)) From SUBIMPOBJ
  GOK=0 : Return
 Endif
Endif

If [M:GRA0]FCY=""
 # Erreur  subvention non importée -> Site non renseigné
 Call TRACE(2,mess(1,146,1)-"->"-mess(14,146,1)) From SUBIMPOBJ
 GOK=0 : Return
Else
 Call LECTURE("FCY",[M:GRA0]FCY,"") From CONTOBJ
 If fstat<>0
  # Erreur  subvention non importée ->YYYY Site inexistant
  Call TRACE(2,mess(1,146,1)-"->"-[M:GRA0]FCY-mess(19,116,1)) From SUBIMPOBJ
  GOK=0 : Return
 Endif
Endif

Return
#######################################################################################
#                               ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1
Trbegin [GRA]

 Raz[F:GRA]
 [F:GRA]=[M:GRA0]
 [F:GRA]=[M:GRA1]
 [F:GRA]=[M:GRA2]

 [F:GRA]=[M:GRA2]

 Write [F:GRA]
 If fstat
  GOK=0 : Call FSTA("GRA") From GLOCK : Return
 Endif

 Raz[F:CAS]
 [F:CAS]GRAREF=[M:GRA0]GRAREF   
 [F:CAS]=[M:GRA3]
 Write [F:CAS]
 If fstat
  GOK=0 : Call FSTA("CAS") From GLOCK : Return
 Endif
 
Commit
Return
#########################
$AB_TR1
Rollback
#Rollback suite à erreur dans la transaction
Call TRACE(2,mess(17,107,1)) From SUBIMPOBJ
GOK=0 : Return
Return

#######################################################################################
#                                    TABLES DIVERSES
#######################################################################################
Subprog TABLE_DIVERSES (NUMTABLE,VALEUR, OBLIG)
Value  Integer NUMTABLE 
Variable Char VALEUR
Value Integer OBLIG
Read [ADI]CODE=NUMTABLE;VALEUR
If fstat<>0
 #Si il n'existe pas : Affectation de la valeur par défaut si elle existe...
 Filter [ADI] Where NUMTAB=NUMTABLE & DEFVAL=2
 Read [ADI]CODE First
 Filter [ADI]
 If fstat=0
  VALEUR=[F:ADI]CODE
 Else
  If OBLIG=0 :#Zone non obligatoire
    VALEUR=""
  Else
   # Erreur : Subvention non importée -> YYY Valeur obligatoire inexistante.
   Call TRACE(2,VALEUR-mess(3,146,1)) From SUBIMPOBJ
   GOK=0 : End
  Endif
 Endif
Endif
End
