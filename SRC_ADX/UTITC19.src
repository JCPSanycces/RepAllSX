#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTITC19   Table HISTOOMM Nettoyage lignes d'entête de        Module TC #
#           OMMRESULT                                                    #
##########################################################################
# FGR 29/09/2009 : X3SUIVI57726
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "X3INDV6" Then
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      # Issue 108760 - 2015-08-07 by MAE :
      #Read [ADS]DOSSIER=[L]DOSSIER
      #If fstat THEN
      #  Raz [F:ADS]
      #Endif
      If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTITC19(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTITC19(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC19(SZAPPLI)
Value Char SZAPPLI

Local Integer IDELETE

  IDELETE = 0
  Call ECR_TRACE("UTITC19: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table HISTOOMM
  #
  If filinfo(filpath("FIL", "HISTOOMM", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".HISTOOMM" [HIM]
    If filinfo(filpath("FIL", "OMMRESULT", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".OMMRESULT" [MRE]
      Trbegin [HIM]
      Filter [MRE] Where [F:MRE]MRENUM = '0' and [F:MRE]CLSNUM = 0
      For [MRE]
        Filter [HIM] Where [F:HIM]OMMNUM = [F:MRE]OPGNUM Order By [F:HIM]HIMNUM
        For [HIM]
          If [F:HIM]BPRNUM = left$([F:MRE]BPRNUM, len([F:HIM]BPRNUM)) and [F:HIM]CCNNUM = left$([F:MRE]CCNNUM, len([F:HIM]CCNNUM)) Then
            Delete [HIM]Curr
            IDELETE += 1
            Break
          Endif
        Next
        Filter [HIM]
      Next
      Filter [MRE]
      Commit
      Close Local File [MRE]
    Endif
    Close Local File [HIM]
  Endif
  Call ECR_TRACE("UTITC19 : records processed" - num$(IDELETE), 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"HISTOOMM") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC19(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"HISTOOMM") : End : Endif
  Call MAJ_UTITC19(APPLI)
End

