#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:55"
A_USER  = "DOC"
A_STAMP = "20181109230555"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTACT0 [PJTAC0]
Gosub HORODAT
Local Inpbox "PJMTACT0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0] As [SIM_]
Grizo [PJTAC0]5
Grizo [PJTAC0]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTAC0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=86 : Y1(0)=1 : Y2(0)=8
X1(1)=1 : X2(1)=45 : Y1(1)=9 : Y2(1)=20
X1(2)=1 : X2(2)=-2 : Y1(2)=1 : Y2(2)=0
Return

$ON_TASFCY
Return

$ON_ZTASFCY
Onevent BEFORE_AREA Gosub AV_ZTASFCY From W1PJMTACT0
Return

$AV_ZTASFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]TASFCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYNAM
Gosub _AFF
Return

$ON_OPENUM
Return

$ON_ROODESAXX
Onevent INIT_AREA Call D_ROODESAXX(zc) From W1PJMTACT0
Onevent AFTER_CHANGE Gosub AMM_ROODESAXX From W1PJMTACT0
Onevent BEFORE_INPUT Call AS_ROODESAXX(zc) From W1PJMTACT0
Onevent CONTROL Call C_ROODESAXX(zc) From W1PJMTACT0
Return

Subprog IB_ROODESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action BOUTTEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "BOUTTEXTRA"
 Call S_AFF_CHAR(VALEUR,PARMSK,"","ATEXTRA","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog D_ROODESAXX(VALEUR)
Variable Char    VALEUR()
If varinit([M]ROODESAXX,indice)=0
 ## Action LECTEXTRA
 Call LECTEXTRA(VALEUR,"PJMTSKOPE","ROODESAXX",func SUBPJTAC.GET_KEYCONCAT_SCREEN_PJTAC0(),"") From ATEXTRA
Endif
Gosub _AFF
End

Subprog AS_ROODESAXX(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(9637,GBOUT1) From OBJDIV
Call IB_ROODESAXX(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_ROODESAXX(zc) From W1PJMTACT0
Gosub _AFF
End

Subprog C_ROODESAXX(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ROODESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

$AMM_ROODESAXX
Call AM_ROODESAXX(zc)
If !mkstat & GOBJET
 zoncou = "ROODESAXX" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ROODESAXX(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ROODESAXX(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "ROODESAXX" : GZNUM = 8 : Endif
Gosub _AFF
End

Subprog B1_ROODESAXX(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ATEXTRA
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ATEXTRA"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_ROODESAXX" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJMTSKOPE"
 PARMSK(2) = "ROODESAXX"
 PARMSK(3) = func SUBPJTAC.GET_KEYCONCAT_SCREEN_PJTAC0()
 PARMSK(4) = ""
 Call SAISIE_CHAR(VALEUR,PARMSK,"ATEXTRA","ATEXTRA","") From GSAISIE
 ACTION = "BB1_ROODESAXX" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_OPESTA
Onevent INIT_AREA Call D_OPESTA(zc) From W1PJMTACT0
Return

Subprog D_OPESTA(VALEUR)
Variable Integer VALEUR
If varinit([M]OPESTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_OPEDATH
Onevent BEFORE_AREA Gosub AV_OPEDATH From W1PJMTACT0
Return

$AV_OPEDATH
Chgfmt [M]OPEDATH(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OPEDATS
Onevent BEFORE_AREA Gosub AV_OPEDATS From W1PJMTACT0
Return

$AV_OPEDATS
Chgfmt [M]OPEDATS(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_OPESTR
Onevent BEFORE_INPUT Call AS_OPESTR(zc) From W1PJMTACT0
Onevent AFTER_CHANGE Gosub AMM_OPESTR From W1PJMTACT0
Onevent BEFORE_AREA Gosub AV_OPESTR From W1PJMTACT0
Return

$AV_OPESTR
Chgfmt [M]OPESTR(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_OPESTR(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_OPESTR(VALEUR) From SUBPJTAC
If mkstat=2
 [M]OPESTR(INDIC) = VALEUR
 Affzo OPESTR(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_OPESTR
Call AM_OPESTR(zc)
If !mkstat & GOBJET
 zoncou = "OPESTR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPESTR(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_OPESTR(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPESTR" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_OPEEND
Onevent BEFORE_INPUT Call AS_OPEEND(zc) From W1PJMTACT0
Onevent AFTER_CHANGE Gosub AMM_OPEEND From W1PJMTACT0
Onevent BEFORE_AREA Gosub AV_OPEEND From W1PJMTACT0
Return

$AV_OPEEND
Chgfmt [M]OPEEND(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_OPEEND(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_OPEEND(VALEUR) From SUBPJTAC
If mkstat=2
 [M]OPEEND(INDIC) = VALEUR
 Affzo OPEEND(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$AMM_OPEEND
Call AM_OPEEND(zc)
If !mkstat & GOBJET
 zoncou = "OPEEND" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OPEEND(VALEUR)
Variable Date    VALEUR
## Action STD
Call AM_OPEEND(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "OPEEND" : GZNUM = 1806 : Endif
Gosub _AFF
End

$CHG_STY
Return


