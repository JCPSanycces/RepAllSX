#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#                    CALCUL
#
#*********************************************************************
#    Création
#    MWA - 16.03.2005
#
#*********************************************************************
#    Modification
#    MWA - 05.07.2018 X3-74074  Exceptionnal depreciation when disposal cancelation
#    MWA - 26.10.2017 X3-54580  Wear & Tear Depreciation
#    MWA - 15.02.2016 FQ114311  Si la dotation exe. est forcèe on ne lui ajoute pas le cumul P-1 lorsque PERREFCLC <> FIYSTRDAT.
#    MWA - 01.02.2016 FQ114113  Points d'entrée
#    MWA - 08.04.2015 FQ107461  Le calcul boucle en reconstitution de cumul E_1 porata mois découpage exercice particulier.
#    MWA - 08.04.2015 FQ106778  Mode RE et changement de méthode avec rattrapage cumul E_1 dans la période
#    MWA - 17.12.2014 FQ104870  Gestion de l'amortissement exceptionnel combiné avec d'autres flux gérant l'exceptionnel.
#    MWA - 02.12.2014 FQ102893  Dotations périodiques érronées suite à changement de méthode avec rattrapage d'écart sur période
#    MWA - 30.10.2014  F103697  Intialisation à 0 de EXEIMLCUM, EXERVECUM, EXETRFCUM et reconstitution de cumul E-1
#    MWA - 30.10.2014  F103690  Modes des suivis Théorique et Initial écrasés à tort par le mode du suivi réel.
#    MWA - 02.01.2012  F101738  Mode DF Date de fin d'amortissement erronée reconstitution de cumul
#    MWA - 14.02.2014  FQ90084  Annulation d'une sortie rétroactivement (voir réserves émises dans TRTFASISS)
#    MWA - 13.02.2014  FQ96840  Fonctions permettant de savoir si le plan d'un bien a été ou non déprécié ou réévalué
#    MWA - 24.09.2013  FQ90432  Différé espagnol 2013 2014
#    MWA - 16.01.2013  FQ87300  Révision des tests d'héritage Reel vers Théorique et Théorique dans Intial
#    MWA - 01.04.2012  FQ77877  Roumanie
#    MWA - 02.02.2012  FQ79813  Optimisation calcul
#    MWA - 02.01.2012  FQ77734  Mode DF Date de fin d'amortissement erronée reconstitution de cumul
#    MWA - 07.07.2011  FQ74870  Problème rattrapage écart sur bien négatif
#    MWA - 14.05.2011  FQ73777  Création d'un bien antérieur à l'exercice avec modification de la situation antérieure interdite
#                               Maj des champs changement de méthode pour qu'un rattapage du cumul E-1 soit fait dans la période courante.
#    MWA - 25.02.2011  FQ71919  Cumul E-1 théorique erroné  en cas de reprise avec cumul E-1 dans dotation Exercice
#    MWA - 12.10.2010  FQ61186  Résult. erronnés en cas de sortie sur bien repris avec report cumul E-1 sur dot. pér. de reprise
#    MWA - 17.06.2010  FQ65464  Problème rattrapage écart lorsque suite à chgt meth  le bien devient totalement amorti
#    MWA - 15.06.2010  FQ59941  Gestion des modes russes
#    MWA - 18.03.2009  FQ63366  Réévaluation par valeur marché = à la base intiale considéré comme non réévalué par le calcul
#    MWA - 02.09.2009  FQ57526  Mode PC basé sur période répartision periodique de la dotation exercice incorrecte sur 1er exercice
#    MWA - 25.09.2008  FQ50931  Résultats de calcul incorrects si remise en cause situation interdite et changement de méthode
#    MWA - 25.09.2008  FQ49345  Erreur si remise en cause situation interdite et dotation exercice forcée
#    MWA - 22.09.2008  FQ49303  Perte du taux d'amortissement entre calcul réel et calcul initial
#
#


# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


#########################################################
Subprog  DOTATION_EXERCICE
#
# - Objet  : Calcule la dotation de l'exercice pour le Réel, Théorique, Initial
#
#
# - Entrée : [M:DIV] Structure Cdota
#

Local Integer I_P
Local Date    LDATBID

  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301FIS ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1 ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Call ECR_FICH("FS1", 5, "..................................................................." ) From =G_GLOB0
  Call ECR_FICH("FS1", 5, "DOTATION_EXERCICE - Exercice "+
&      format$([M:DIV]DATFMT,[F:DEPC]FIYSTRDAT)+" - "+ format$([M:DIV]DATFMT,[F:DEPC]FIYENDDAT) ) From =G_GLOB0

  # Evaluation du mode et de la Période de référence pour suivi "Reel", "Théorique" et "Initial"
  # =====================================================================================
  # Changement de méthode
  If ( [F:DEPC]MTCTIATYP = GVML_PEDBPE ) Then
    # Si changement de méthode avec prise d'effet "début de période"
    # Le transactionnel a passé le mode "Reelle" en résiduel
    # Le mode "réelle" résiduel s'applique au théorique et à l'initial
    [F:DEPC]DPMT = [F:DEPC]DPM
    [F:DEPC]DPMI = [F:DEPC]DPM
    # La période de référence pour le calcul de la dotation exercice est la période "courante"
    [F:DEPC]PERREFCLC  = [F:DEPC]PERSTRDAT
    [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT
    [F:DEPC]PERREFCLCI = [F:DEPC]PERSTRDAT
  Elsif ( [F:DEPC]MTCTIATYP = GVML_PEDBEX
&      or ([F:DEPC]MTCTIATYP = GVML_PEDBAM and
&          func GLOBB9.CAL_DAT_INSIDE([F:DEPC]STRDPRDAT,
&                      [M:FIY]DATSTRFIY([M:DIV]FEC-1),[M:FIY]DATENDFIY([M:DIV]FEC-1),"I"))) Then
    [F:DEPC]DPMT = [F:DEPC]DPM
    [F:DEPC]DPMI = [F:DEPC]DPM
  Elsif ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)) Then
    # FQ103690
#    [F:DEPC]DPMT = [F:DEPC]DPM
#    [F:DEPC]DPMI = [F:DEPC]DPM
  Endif
  # Dépréciation
    # Si une dépréciation est constatée dans la période courante P
    # le traitement ci-dessous est pris en charge par le traitement de clôture
    # Sur P+1, passage du mode réelle en résiduel. Les modes "Théorique" et "Initial" restent inchangés
    # Sur P+1; la période de référence pour la dotation exercice "Réelle" est la période P+1
    #          la période de référence pour le "Théorique" et "Initial" reste inchangée
  # Réévaluation
  If ( [F:DEPC]RVAAMT <> 0 ) Then

    If ( [F:DEPC]RVATIADAT = GVML_ERDBPE ) Then
    # Si "Réévaluation" avec prise d'effet "début de période"
      If (  [F:DEPC]RVATYP = GVML_MODVMA ) Then
        # S'il s'agit d'une réévaluation par valeur marché
        # Le transactionnel a passé le mode "Reelle" en résiduel
        # Le mode "réelle" résiduel s'applique au théorique. L'initial reste inchangé.
        [F:DEPC]DPMT = [F:DEPC]DPM
        # La période de référence pour la dotation exercice "Réel" "Théorique" est la période "courante"
        # La période de référence pour la dotation exercice "Initial" reste inchangées
        [F:DEPC]PERREFCLC  = [F:DEPC]PERSTRDAT
        [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT
      Else
      # S'il ne s'agit pas d'une réévaluation par valeur marché
        # Pas de changement sur les modes, ni sur la période de référence pour le calcul de la dot. exe.
      Endif
    Else
    # Si "Réévaluation" avec prise d'effet "début d'exercice"
      If (  [F:DEPC]RVATYP = GVML_MODVMA ) Then
        # S'il s'agit d'une réévaluation par valeur marché
        # Le transactionnel a passé le mode "Reelle" en résiduel
        # Le mode "réelle" résiduel s'applique au théorique. L'initial reste inchangé.
        [F:DEPC]DPMT = [F:DEPC]DPM
        # Pas de changement sur la période de référence pour le calcul de la dot. exe.
      Else
      # S'il ne s'agit pas d'une réévaluation par valeur marché
        # Pas de changement sur les modes, ni sur la période de référence pour le calcul de la dot. exe.
      Endif
    Endif
  Endif

  # Mode d'amortissement
  # FQ59941
  If ( [F:DEPC]DPM  = G_DPMUO or [F:DEPC]DPM  = G_DPMUR ) Then
    [F:DEPC]PERREFCLC  = [F:DEPC]PERSTRDAT
  Endif
  If ( [F:DEPC]DPMT = G_DPMUO or [F:DEPC]DPMT  = G_DPMUR ) Then
    [F:DEPC]PERREFCLCT  = [F:DEPC]PERSTRDAT
  Endif
  If ( [F:DEPC]DPMI = G_DPMUO or [F:DEPC]DPMI  = G_DPMUR ) Then
    [F:DEPC]PERREFCLCI  = [F:DEPC]PERSTRDAT
  Endif
  # =====================================================================================


  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301IAS ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #  If ( [M:DIV]BDEBUG and [F:DEPC]PERENDDAT = [31/03/2007] and
  #&      not ([M:DIV]BCUME_1) ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #******************************
  # Dotation exercice REELLE
  #******************************
  [M:DIV]TYPCAL = "R"

  # Initialisation à priori
  #==========
  # Date de fin d'amortissement
  [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
  # Actualisation du taux d'amortissement
  [M:DIV]TXAMT   = [F:DEPC]DPRRAT
  # Actualisation de la durée d'amortissement
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR
  #==========

  # Préparation avant calcul d'une dotation exercice REEL
  [M:DIV]MODAMT = [F:DEPC]DPM
  [M:DIV]LVLLIB = "4.CAL_AVANT_CAL_DOT_EXE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_AVANT_CAL_DOT_EXE  From  =G_GLOB4
  If ([M:DIV]ERROR) Then :  End : Endif
  # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
  [M:DIV2]RGRPPER_R = [M:DIV2]RGRPPER

  # Base d'amortissement
  [M:DIV]BASAMT = [F:DEPC]DPRBAS
  # Valeur amortissable
  [M:DIV]VALAMT = [F:DEPC]DPRBAS - [F:DEPC]RSDVAL
  # Evaluation date de référence & Valeur nette amortissable
  #-- 2 ---------------------------------------
  If ( [F:DEPC]PERREFCLC = [F:DEPC]FIYSTRDAT  ) Then : # FQ103697
    [M:DIV]BOTHPER   = 0
    #-- Début exercice (par défaut)
    # Dans les autres cas,  Date de référence = Début d'exercice
    [M:DIV]EXEDATREF = [M:DIV]DTDBEXE
    # Valeur nette amortissable début d'exercice
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDE (3)" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
    [M:DIV]PC(0)= "RDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [M:DIV]VLNAMT = [M:DIV]RV(1)
  Elsif ( [F:DEPC]PERREFCLC = [F:DEPC]PERSTRDAT  ) Then
    [M:DIV]BOTHPER   = 0
    #-- Début de période courante
    [M:DIV]EXEDATREF = [M:DIV]DTDBPER
    # Valeur nette amortissable début de période
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDP (1)" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
    [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [M:DIV]VLNAMT = [M:DIV]RV(1)
  #-- 2 ---------------------------------------
  Elsif ( [F:DEPC]PERREFCLC > [F:DEPC]FIYSTRDAT and not ([M:DIV]BCUME_1) ) Then
    [M:DIV]BOTHPER   = 1
    #-- Début d'une autre période
    # Positionnement de [F:DEPC] sur [M:DEP] période de référence
    I_P = find([F:DEPC]PERREFCLC, [M:DEP]PERSTRDAT)
    # Sauvegarde DEPC dans DEPS
    [F:DEPS] = [F:DEPC]
    # [M:DEP] période de référence dans [F:DEPC]
    nolign = I_P : [F:DEPC] = [M:DEP]
    # Ajustement dates période pour affectation [M:DIV]EXEDATREF
    Call ECR_FICH("FS1",9,"Période de référence pour le calcul de la dotation exercice" ) From =G_GLOB0
    Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO, [M:DEP]PERSTRDAT(I_P-1), [M:DEP]PERENDDAT(I_P-1),
&   [M:DIV]EXEDATREF, LDATBID ) From =G_GLOB5
    # Valeur nette amortissable début de période
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDP (2)" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
    [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [M:DIV]VLNAMT = [M:DIV]RV(1)
    # Après calcul, il faut se repositionner sur la période courante
  #-- 2 ---------------------------------------
  Else
    [M:DIV]BOTHPER   = 0
    #-- Début exercice (par défaut)
    # Dans les autres cas,  Date de référence = Début d'exercice
    [M:DIV]EXEDATREF = [M:DIV]DTDBEXE
    # Valeur nette amortissable début d'exercice
    [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDE (3)" : Gosub CAL_ADDLVL  From =G_GLOB0
    #Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
    [M:DIV]PC(0)= "RDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
    Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
    [M:DIV]VLNAMT = [M:DIV]RV(1)
  Endif
  #-- 2 ---------------------------------------

  # FQ106778
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1 and [F:DEPC]FIYENDDAT = [31/12/2006] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  # Lorsqu'un changt de méth a lieu, c'est la val. nette deb exe. après changt de méth. qui doit être prise en compte
  # A la val. nette déb. exe. doit donc être intégré l'écart de cumulE_1 dû au changement de méthode
  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]VLNAMT = [M:DIV]VLNAMT - [M:DIV]ECACUME_1R
    When "T"
      [M:DIV]VLNAMT = [M:DIV]VLNAMT - [M:DIV]ECACUME_1T
    When "I"
      [M:DIV]VLNAMT = [M:DIV]VLNAMT - [M:DIV]ECACUME_1I
  Endcase

  # Calcul dotation exercice selon le mode d'amortissement
  Call ECR_FICH("FS1",5,"** REEL **") From =G_GLOB0
  #    ============
  [M:DIV]LVLLIB = "4.CAL_DOT_EXE - Réelle" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_DOT_EXE  From =G_GLOB4
  #    ============
  If ([M:DIV]ERROR) Then : End : Endif

  # Actualisation [F:DEPC] après calcul dotation exercice
  [F:DEPC]EXCDPR  = [M:DIV]AMTEXC
  [F:DEPC]ENDDPE  = [M:DIV]DOTEXE
  [F:DEPC]APLDUR  = [M:DIV]APLDUR

  #========================
  # Changement de méthode
  #========================
  #- 2 ----------------------------------------------------
  If ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) ) Then
    # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
    #-- 3 ---------------------------------------
    If ( [F:DEPC]MTCDEVADJ = GVML_RDOTEXE or [F:DEPC]MTCDEVADJ = GVML_RDOTPER ) Then
      # la modalité de gestion de l'écart Cumul E-1 est "Régularisation sur dotation exercice"
      #                                              ou "Régularisation sur dotation période"
      # l'écart Cumul E-1 doit être réintégré dans la dotation exercice
      [F:DEPC]ENDDPEFLG  = G_NON
      [F:DEPC]ENDDPE    += [M:DIV]ECACUME_1R
    Endif
    #-- 3 ---------------------------------------
    If ( [F:DEPC]MTCDEVADJ = GVML_REXCEXE or [F:DEPC]MTCDEVADJ = GVML_REXCPER ) Then
      # la modalité de gestion de l'écart Cumul E-1 est "Régularisation en Amt Except. Exercice"
      #                                              ou "Régularisation en Amt Except. période"
      # l'écart Cumul E-1 doit être réintégré dans l'amortissement exceptionnel de l'exercice
      [F:DEPC]EXCDPR   += [M:DIV]ECACUME_1R
    Endif
    #-- 3 ---------------------------------------
  Endif
  #- 2 ----------------------------------------------------
  # La dotation exercice a été calculée à début de période P, il faut intégrer le Cumul P-1
  #- 2 ----------------------------------------------------
  # FQ114311
  #If ( [F:DEPC]PERREFCLC = [F:DEPC]PERSTRDAT ) Then
  If ( [F:DEPC]PERREFCLC = [F:DEPC]PERSTRDAT and [F:DEPC]ENDDPEFLG <> G_OUI  ) Then
    # Si la période de référence est "Début de période",
    # Le cumul P-1 doit être intégré à la dotation exercice
    [F:DEPC]ENDDPE    += [F:DEPC]PERCLOCUM
    [F:DEPC]EXCDPR    += [F:DEPC]PERCLOEXC
  Endif
  #- 2 ----------------------------------------------------

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2 ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-- Lien entre plan Fiscal et plan Minimum
  #   Amortissement minimum / Règle du minimum / Différable / Différé & Reprise Différé
  # FQ90432
  If ([M:DIV]LEGSOC = "FRA") Then
    [M:DIV]LVLLIB = "6.CAL_LNK_FISC_MINI" : Gosub CAL_ADDLVL  From =G_GLOB0
    Gosub CAL_LNK_FISC_MINI From =G_GLOB6
  Endif
  # FQ90432
  If ([M:DIV]LEGSOC = "SPA" ) Then
    [M:DIV]LVLLIB = "6.CAL_DIF_ESP_2013_2014" : Gosub CAL_ADDLVL  From =G_GLOB0
    Gosub CAL_DIF_ESP_2013_2014 From =G_GLOB6
  Endif

  #-- Montant à répartir sur les périodes  ( par défaut la dotation calculée)
  #   [M:DIV]DOTEXE a pu être actualisé dans CAL_LNK_FISC_MINI après application de la règle du mimimum
  If ([M:DIV]BOTHPER) Then
    # La dotation exercice a été recalculée en Pc avec en Pc-n de l'exercice
    [F:DEPS]ENDDPE = [F:DEPC]ENDDPE : [F:DEPS]EXCDPR = [F:DEPC]EXCDPR
    [F:DEPS]DFD    = [F:DEPC]DFD    : [F:DEPS]DFDRVE = [F:DEPC]DFDRVE : [F:DEPS]DFDLIM = [F:DEPC]DFDLIM
    # Restauration DEPS dans DEPC
    [F:DEPC] = [F:DEPS]
    # Dotation résiduelle pour répartition
    [M:DIV]DOTEXE = [F:DEPC]ENDDPE - [F:DEPC]PERCLOCUM
    [M:DIV]AMTEXC = [F:DEPC]EXCDPR - [F:DEPC]PERCLOEXC
  Endif

  [M:DIV]EXCREPR = [M:DIV]AMTEXC
  If ( [F:DEPC]DPM = G_DPMPC or [F:DEPC]DPM = G_DPMPD ) Then
    [M:DIV]MNTREPR = ( [F:DEPC]DPRBAS - [F:DEPC]RSDVAL ) * [M:DIV]TXAMT
    #Call CAL_ARRONDI_MNT ([M:DIV]MNTREPR, [M:DIV]CUR , [M:DIV]MNTREPR) From =G_GLOB8
    [M:DIV]PV(0)= [M:DIV]MNTREPR : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]MNTREPR = [M:DIV]RV(1)
  Else
    [M:DIV]MNTREPR = [M:DIV]DOTEXE
  Endif


  # Sauvegarde informations liées au mode du suivi "Réel" pour calcul du périodique
  [M:DIV]TYPPROR    = [M:DIV]TYPPRO
  [M:DIV]TYPPRODATR = [M:DIV]TYPPRODAT
  [M:DIV]MODTYPR    = [M:DPM]DPRMODTYP([M:DIV]INDMOD-1)
  [M:DIV]DTDBAMTRGR = [M:DIV]DTDBAMTREG
  [M:DIV]DATSORRGR  = [M:DIV]DATSORREG
  [M:DIV]DTFNAMTR   = [M:DIV]DTFNAMT
  [M:DIV]SORREG([F:DEPC]DPRPLN-1) = [M:DIV]DATSORREG

  # Uniquement en suivi "Réel"
  #==========
  # Actualisation de la date de fin d'amortissement
  [F:DEPC]ENDDPRDAT = [M:DIV]DTFNAMT
  # Actualisation du taux d'amortissement
  #FQ49303
  #[F:DEPC]DPRRAT = [M:DIV]TXAMT
  If( [F:DEPC]DPRRATFLG <> G_OUI ) Then :  [F:DEPC]DPRRAT = [M:DIV]TXAMT : Endif
  # Actualisation de la durée d'amortissement
  [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  #==========

  #******************************
  # Dotation exercice THEORIQUE
  #******************************
  [M:DIV]TYPCAL = "T"

  #- 1 ----------------------------------- FQ71919 FQ87300
#  If ( [F:DEPC]IMLBLC = 0 and [F:DEPC]DPM = [F:DEPC]DPMT and
#&      [F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMT and [F:DEPC]PERCLOCUM = [F:DEPC]PERCLOCUMT  ) Then
#  If ( [F:DEPC]EXEIMLCUM = 0 and [F:DEPC]EXERVECUM = 0 and
#&      [F:DEPC]PERIMLCUM = 0 and [F:DEPC]PERRVECUM = 0 and [F:DEPC]IMLBLC = 0 ) Then
# FQ96840
  If not (func TRTFAS.IMPAIRED_ASSET_PLN)
    # Le "Théorique" hérite du "Réel" si :
    #     pas de dépréciation constatée
    #     et pas de différé sur le réel constaté sur l'exercice ou antérieurement
    [F:DEPC]EXCDPRT  = [F:DEPC]EXCDPR
    [F:DEPC]ENDDPET  = [F:DEPC]ENDDPE
    # Montant à reporter
    [M:DIV]EXCREPT   = [F:DEPC]EXCDPR
    [M:DIV]MNTREPT   = [F:DEPC]ENDDPE

  #- 1 -----------------------------------
  Else
    # Préparation avant calcul d'une dotation exercice THEORIQUE
    If ([F:DEPC]DPMT <> [F:DEPC]DPM ) Then
      [M:DIV]MODAMT = [F:DEPC]DPMT
      [M:DIV]LVLLIB = "4.CAL_AVANT_CAL_DOT_EXE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_AVANT_CAL_DOT_EXE  From  =G_GLOB4
      If ([M:DIV]ERROR) Then : End : Endif
      # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
      [M:DIV2]RGRPPER_T = [M:DIV2]RGRPPER
    Else
      # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
      [M:DIV2]RGRPPER_T = [M:DIV2]RGRPPER_R
    Endif
    # Base d'amortissement
    [M:DIV]BASAMT = [F:DEPC]DPRBAS
    # Valeur amortissable
    [M:DIV]VALAMT = [F:DEPC]DPRBAS - [F:DEPC]RSDVAL

    # Evaluation date de référence & Valeur nette amortissable
    #-- 2 ---------------------------------------
    If ( [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT  ) Then
      [M:DIV]BOTHPER   = 0
      #-- Début de période courante
      [M:DIV]EXEDATREF = [M:DIV]DTDBPER
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDP (4)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    #-- 2 ---------------------------------------
    Elsif ( [F:DEPC]PERREFCLCT > [F:DEPC]FIYSTRDAT and not ([M:DIV]BCUME_1) ) Then
      [M:DIV]BOTHPER   = 1
      #-- Début d'une autre période
      # Positionnement de [F:DEPC] sur [M:DEP] période de référence
      I_P = find([F:DEPC]PERREFCLC, [M:DEP]PERSTRDAT)
      # Sauvegarde DEPC dans DEPS
      [F:DEPS] = [F:DEPC]
      # [M:DEP] période de référence dans [F:DEPC]
      nolign = I_P : [F:DEPC] = [M:DEP]
      # Ajustement dates période pour affectation [M:DIV]EXEDATREF
      Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO, [M:DEP]PERSTRDAT(I_P-1), [M:DEP]PERENDDAT(I_P-1),
&     [M:DIV]EXEDATREF, LDATBID ) From =G_GLOB5
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDP (5)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    #-- 2 ---------------------------------------
    Else
      [M:DIV]BOTHPER   = 0
      #-- Début exercice (par défaut)
      # Dans les autres cas,  Date de référence = Début d'exercice
      [M:DIV]EXEDATREF = [M:DIV]DTDBEXE
      # Valeur nette amortissable début d'exercice
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDE (6)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDE", [F:DEPC]DPRBAS, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    Endif
    #-- 2 ---------------------------------------

    # Calcul dotation exercice selon le mode d'amortissement
    Call ECR_FICH("FS1",5,"** THEORIQUE **") From =G_GLOB0
    #    ============
    [M:DIV]MODAMT = [F:DEPC]DPMT
    [M:DIV]LVLLIB = "4.CAL_DOT_EXE - Théorique" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_DOT_EXE  From =G_GLOB4
    #    ============
    If ([M:DIV]ERROR) Then : End : Endif

    # Actualisation [F:DEPC] après calcul dotation exercice
    [F:DEPC]EXCDPRT  = [M:DIV]AMTEXC
    [F:DEPC]ENDDPET  = [M:DIV]DOTEXE


    # Après calcul de la dotation exercice Théorique
    #- 2 ----------------------------------------------------
    If ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)  ) Then
      # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
      If ( [F:DEPC]MTCDEVADJ = GVML_RDOTEXE or [F:DEPC]MTCDEVADJ = GVML_RDOTPER ) Then
        # la modalité de gestion de l'écart Cumul E-1 est "Régularisation sur dotation exercice"
        #                                              ou "Régularisation sur dotation période"
        # l'écart Cumul E-1 doit être réintégré dans la dotation exercice
        [F:DEPC]ENDDPET   += [M:DIV]ECACUME_1T
      Endif
      If ( [F:DEPC]MTCDEVADJ = GVML_REXCEXE or [F:DEPC]MTCDEVADJ = GVML_REXCPER ) Then
        # la modalité de gestion de l'écart Cumul E-1 est "Régularisation en Amt Except. Exercice"
        #                                              ou "Régularisation en Amt Except. période"
        # l'écart Cumul E-1 doit être réintégré dans l'amortissement exceptionnel de l'exercice
        [F:DEPC]EXCDPRT  += [M:DIV]ECACUME_1T
      Endif
    Endif
    #- 2 ----------------------------------------------------

    # La dotation exercice a été calculée à début de période P, il faut intégrer le Cumul P-1
    #- 2 ----------------------------------------------------
    If ( [F:DEPC]PERREFCLCT = [F:DEPC]PERSTRDAT ) Then
      # Si la période de référence est "Début de période",
      # Le cumul P-1 doit être intégré à la dotation exercice
      [F:DEPC]ENDDPET    += [F:DEPC]PERCLOCUMT
      [F:DEPC]EXCDPRT    += [F:DEPC]PERCLOEXCT
    Endif
    #- 2 ----------------------------------------------------

    #-- Montant à répartir sur les périodes  ( par défaut la dotation calculée)
    If ([M:DIV]BOTHPER) Then
      # La dotation exercice a été recalculée en Pc avec en Pc-n de l'exercice
      [F:DEPS]ENDDPET = [F:DEPC]ENDDPET : [F:DEPS]EXCDPRT = [F:DEPC]EXCDPRT
      # Restauration DEPS dans DEPC
      [F:DEPC] = [F:DEPS]
      # Dotation résiduelle pour répartition
      [M:DIV]DOTEXE = [F:DEPC]ENDDPET - [F:DEPC]PERCLOCUMT
      [M:DIV]AMTEXC = [F:DEPC]EXCDPRT - [F:DEPC]PERCLOEXCT
    Endif

    [M:DIV]EXCREPT = [M:DIV]AMTEXC
    # FQ57526
    If ( [F:DEPC]DPMT = G_DPMPC or [F:DEPC]DPMT = G_DPMPD ) Then
      [M:DIV]MNTREPT = ( [F:DEPC]DPRBAS - [F:DEPC]RSDVAL ) * [M:DIV]TXAMT
      #Call CAL_ARRONDI_MNT ([M:DIV]MNTREPT, [M:DIV]CUR , [M:DIV]MNTREPT) From =G_GLOB8
      [M:DIV]PV(0)= [M:DIV]MNTREPT : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]MNTREPT = [M:DIV]RV(1)
    Else
      [M:DIV]MNTREPT = [M:DIV]DOTEXE
    Endif

  Endif
  #- 1 -----------------------------------

  # Sauvegarde informations liées au mode du suivi "Théorique" pour calcul du périodique
  [M:DIV]TYPPROT    = [M:DIV]TYPPRO
  [M:DIV]TYPPRODATT = [M:DIV]TYPPRODAT
  [M:DIV]MODTYPT    = [M:DPM]DPRMODTYP([M:DIV]INDMOD-1)
  [M:DIV]DTDBAMTRGT = [M:DIV]DTDBAMTREG
  [M:DIV]DATSORRGT  = [M:DIV]DATSORREG
  [M:DIV]DTFNAMTT   = [M:DIV]DTFNAMT
  [M:DIV]SORREGT([F:DEPC]DPRPLN-1) = [M:DIV]DATSORREG

  #******************************
  # Dotation exercice INITIALE
  #******************************
  [M:DIV]TYPCAL = "I"

  #- 1 ----------------------------------- FQ63366 FQ71919 FQ87300
#  If ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]DPMI = [F:DEPC]DPMT and
#&      [F:DEPC]EXECLOCUMI = [F:DEPC]EXECLOCUMT and [F:DEPC]PERCLOCUMI = [F:DEPC]PERCLOCUMT ) Then
#   If ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]EXERVADEV = 0 and [F:DEPC]PERRVADEV = 0 ) Then
# FQ96840
   If not (func TRTFAS.REVALUED_ASSET_PLN)
    # L'"Initial" hérite du "Théorique" si : la base initiale est égale à la base réévalué
    [F:DEPC]EXCDPRI  = [F:DEPC]EXCDPRT
    [F:DEPC]ENDDPEI  = [F:DEPC]ENDDPET
    # Montant à reporter
    [M:DIV]EXCREPI   = [F:DEPC]EXCDPRT
    [M:DIV]MNTREPI   = [F:DEPC]ENDDPET
  #- 1 -----------------------------------
  Else

    # If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
    # Préparation avant calcul d'une dotation exercice INITIAL
    If ([F:DEPC]DPMI <> [F:DEPC]DPMT ) Then
      [M:DIV]MODAMT = [F:DEPC]DPMI
      [M:DIV]LVLLIB = "4.CAL_AVANT_CAL_DOT_EXE" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_AVANT_CAL_DOT_EXE  From  =G_GLOB4
      If ([M:DIV]ERROR) Then : End : Endif
      # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
      [M:DIV2]RGRPPER_I = [M:DIV2]RGRPPER
    Else
      # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
      [M:DIV2]RGRPPER_I = [M:DIV2]RGRPPER_T
    Endif

    # Base d'amortissement
    [M:DIV]BASAMT = [F:DEPC]BSEVAL
    # Valeur amortissable
    [M:DIV]VALAMT = [F:DEPC]BSEVAL - [F:DEPC]RSDVAL
    # Evaluation date de référence & Valeur nette amortissable
    #-- 2 ---------------------------------------
    If ( [F:DEPC]PERREFCLCI = [F:DEPC]PERSTRDAT ) Then
      [M:DIV]BOTHPER   = 0
      #-- Début de période courante
      [M:DIV]EXEDATREF = [M:DIV]DTDBPER
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDP (7)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    #-- 2 ---------------------------------------
    Elsif ( [F:DEPC]PERREFCLCI > [F:DEPC]FIYSTRDAT and not ([M:DIV]BCUME_1) ) Then
      [M:DIV]BOTHPER   = 1
      #-- Début d'une autre période
      # Positionnement de [F:DEPC] sur [M:DEP] période de référence
      I_P = find([F:DEPC]PERREFCLC, [M:DEP]PERSTRDAT)
      # Sauvegarde DEPC dans DEPS
      [F:DEPS] = [F:DEPC]
      # [M:DEP] période de référence dans [F:DEPC]
      nolign = I_P : [F:DEPC] = [M:DEP]
      # Ajustement dates période pour affectation [M:DIV]EXEDATREF
      Call CAL_AJUST_PERIODE ( [M:DIV]TYPPRO, [M:DEP]PERSTRDAT(I_P-1), [M:DEP]PERENDDAT(I_P-1),
&     [M:DIV]EXEDATREF, LDATBID ) From =G_GLOB5
      # Valeur nette amortissable début de période
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDP (8)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    #-- 2 ---------------------------------------
    Else
      [M:DIV]BOTHPER   = 0
      #-- Début exercice (par défaut)
      # Dans les autres cas,  Date de référence = Début d'exercice
      [M:DIV]EXEDATREF = [M:DIV]DTDBEXE
      # Valeur nette amortissable début d'exercice
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDE (9)" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDE", [F:DEPC]BSEVAL , 1, [M:DIV]BMDR, [M:DIV]VLNAMT ) From =G_GLOB4
      [M:DIV]PC(0)= "IDE" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 1 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      [M:DIV]VLNAMT = [M:DIV]RV(1)
    Endif
    #-- 2 ---------------------------------------

    # Calcul dotation exercice selon le mode d'amortissement
    Call ECR_FICH("FS1",5,"** INITIAL **") From =G_GLOB0
    #    ============
    [M:DIV]MODAMT = [F:DEPC]DPMI
    [M:DIV]LVLLIB = "4.CAL_DOT_EXE - Initiale" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_DOT_EXE  From =G_GLOB4
    #    ============
    If ([M:DIV]ERROR) Then : End : Endif

    # Actualisation [F:DEPC] après calcul dotation exercice
    [F:DEPC]EXCDPRI  = [M:DIV]AMTEXC
    [F:DEPC]ENDDPEI  = [M:DIV]DOTEXE


    # Après calcul de la dotation exercice Initial
    #- 2 ----------------------------------------------------
    If ( [F:DEPC]MTCTIATYP = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)   ) Then
      # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
      If ( [F:DEPC]MTCDEVADJ = GVML_RDOTEXE or [F:DEPC]MTCDEVADJ = GVML_RDOTPER ) Then
        # la modalité de gestion de l'écart Cumul E-1 est "Régularisation sur dotation exercice"
        #                                              ou "Régularisation sur dotation période"
        # l'écart Cumul E-1 doit être réintégré dans la dotation exercice
        [F:DEPC]ENDDPEI   += [M:DIV]ECACUME_1I
      Endif
      If ( [F:DEPC]MTCDEVADJ = GVML_REXCEXE or [F:DEPC]MTCDEVADJ = GVML_REXCPER ) Then
        # la modalité de gestion de l'écart Cumul E-1 est "Régularisation en Amt Except. Exercice"
        #                                              ou "Régularisation en Amt Except. période"
        # l'écart Cumul E-1 doit être réintégré dans l'amortissement exceptionnel de l'exercice
        [F:DEPC]EXCDPRI  += [M:DIV]ECACUME_1I
      Endif
    Endif
    #- 2 ----------------------------------------------------
    # La dotation exercice a été calculée à début de période P, il faut intégrer le Cumul P-1
    #- 2 ----------------------------------------------------
    If ( [F:DEPC]PERREFCLCI = [F:DEPC]PERSTRDAT  ) Then
      # Si la période de référence est "Début de période",
      # Le cumul P-1 doit être intégré à la dotation exercice
      [F:DEPC]ENDDPEI    += [F:DEPC]PERCLOCUMI
      [F:DEPC]EXCDPRI    += [F:DEPC]PERCLOEXCI
    Endif
    #- 2 ----------------------------------------------------

    #-- Montant à répartir sur les périodes  ( par défaut la dotation calculée)
    If ([M:DIV]BOTHPER) Then
      # La dotation exercice a été recalculée en Pc avec en Pc-n de l'exercice
      [F:DEPS]ENDDPEI = [F:DEPC]ENDDPEI : [F:DEPS]EXCDPRI = [F:DEPC]EXCDPRI
      # Restauration DEPS dans DEPC
      [F:DEPC] = [F:DEPS]
      # Dotation résiduelle pour répartition
      [M:DIV]DOTEXE = [F:DEPC]ENDDPEI - [F:DEPC]PERCLOCUMI
      [M:DIV]AMTEXC = [F:DEPC]EXCDPRI - [F:DEPC]PERCLOEXCI
    Endif

    [M:DIV]EXCREPI = [M:DIV]AMTEXC
    If ( [F:DEPC]DPMI = G_DPMPC or [F:DEPC]DPMI = G_DPMPD ) Then
      [M:DIV]MNTREPI = ( [F:DEPC]BSEVAL - [F:DEPC]RSDVAL ) * [M:DIV]TXAMT
      #Call CAL_ARRONDI_MNT ([M:DIV]MNTREPI, [M:DIV]CUR , [M:DIV]MNTREPI) From =G_GLOB8
      [M:DIV]PV(0)= [M:DIV]MNTREPI : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]MNTREPI = [M:DIV]RV(1)
    Else
      [M:DIV]MNTREPI = [M:DIV]DOTEXE
    Endif

  Endif
  #- 1 -----------------------------------

  # Sauvegarde informations liées au mode du suivi "Initial" pour calcul du périodique
  [M:DIV]TYPPROI    = [M:DIV]TYPPRO
  [M:DIV]TYPPRODATI = [M:DIV]TYPPRODAT
  [M:DIV]MODTYPI    = [M:DPM]DPRMODTYP([M:DIV]INDMOD-1)
  [M:DIV]DTDBAMTRGI = [M:DIV]DTDBAMTREG
  [M:DIV]DATSORRGI  = [M:DIV]DATSORREG
  [M:DIV]DTFNAMTI   = [M:DIV]DTFNAMT
  [M:DIV]SORREGI([F:DEPC]DPRPLN-1) = [M:DIV]DATSORREG


  If ( [M:DIV]NIVDET > 4 ) Then
  Call ECR_FICH ("FS1", 5, "DOTATION_EXERCICE - Dotation exercice   REEL.="+
&     format$([M:DIV]CURFMT, [F:DEPC]ENDDPE)) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "DOTATION_EXERCICE - Amort. exceptionnel REEL.="+
&     format$([M:DIV]CURFMT, [F:DEPC]EXCDPR)) From =G_GLOB0
  If not ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPSTD or [F:DEPC]IMLBLC = 0 ) Then
  Call ECR_FICH("FS1", 5, "DOTATION_EXERCICE - Dotation exercice   THEO.="+
&     format$([M:DIV]CURFMT, [F:DEPC]ENDDPET)) From =G_GLOB0
  Call ECR_FICH("FS1", 5, "DOTATION_EXERCICE - Amort. exceptionnel THEO.="+
&     format$([M:DIV]CURFMT, [F:DEPC]EXCDPRT)) From =G_GLOB0
  Endif
  #FQ63366
  If not ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPSTD or
&          ([F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMI and [F:DEPC]PERCLOCUM = [F:DEPC]PERCLOCUMI ) ) Then
  Call ECR_FICH("FS1", 5, "DOTATION_EXERCICE - Dotation exercice   INIT.="+
&     format$([M:DIV]CURFMT, [F:DEPC]ENDDPEI)) From =G_GLOB0
  Call ECR_FICH("FS1", 5, "DOTATION_EXERCICE - Amort. exceptionnel INIT.="+
&     format$([M:DIV]CURFMT, [F:DEPC]EXCDPRI)) From =G_GLOB0
  Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#
#########################################################
Subprog  DOTATION_PERIODE
#
# - Objet  :
#
#
# - Objet  :  Calcul de la dotation et de l'amortissement exceptionnel de la période
#             pour le Réel, l'Initial et le Théorique.
#             La dotation equivaut à la part du montant de dotation exercice à répartir sur les périodes.
#             Cette part est calculée par différence entre le cumul P-1 et le cumul fin de période P
#
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#

Local Decimal LMNTAREP
Local Decimal LMNTBID

Local Decimal WPERMTCEXC

  # If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Calcul de la durée résiduelle ( à faire dans tous les cas)
  Call CAL_DUREE_RESIDUELLE ([M:DIV]DTDBAMTRGR, [F:DEPC]PERSTRDAT, [M:DIV]DTFNAMTR, [F:DEPC]RSDDUR ) From =G_GLOB8

  If ( [F:DEPC]FIYSTRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]FIYENDDAT = [F:DEPC]PERENDDAT  ) Then

    If ( [F:DEPC]DPM = "UO" and [F:DEPC]FIYQTY <> 0) Then
      # UO de la période
      [F:DEPC]PERQTY = [F:DEPC]FIYQTY
      # UO résiduelle de la période
      Local Integer WIPN : # Indice période n
      WIPN   = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
      [F:DEPC]RSDQTY = sum([M:PPL]PERQTY(WIPN-1..[M:PPL]IFNA-1))  : # UO résiduelle periode n
    Endif

    If ( [F:DEPC]DPM = G_DPMRD ) Then
      # Dégressif roumain FQ77877
      I_P = find([F:DEPC]FIYENDDAT, [M:DIV2]PERENDDAT)
      If (I_P <> 0) Then
        [F:DEPC]KBIRDAT  = [M:DIV2]BIRDAT (I_P-1)
        [F:DEPC]KBIRNBV  = [M:DIV2]BIRNBV (I_P-1) + [F:DEPC]RSDVAL
        [F:DEPC]KBIRNBVT = [M:DIV2]BIRNBVT(I_P-1) + [F:DEPC]RSDVAL
        [F:DEPC]KBIRNBVI = [M:DIV2]BIRNBVI(I_P-1) + [F:DEPC]RSDVAL
      Endif
    Endif

    # Reel
    [F:DEPC]PERENDDPE  = [F:DEPC]ENDDPE
    [F:DEPC]PEREXCDPR  = [F:DEPC]EXCDPR
    # Théorique
    [F:DEPC]DPET       = [F:DEPC]ENDDPET
    [F:DEPC]PEREXCDPRT = [F:DEPC]EXCDPRT
    # Initial
    [F:DEPC]DPEI       = [F:DEPC]ENDDPEI
    [F:DEPC]PEREXCDPRI = [F:DEPC]EXCDPRI
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #If ( [M:DIV]BDEBUG and [F:DEPC]PERSTRDAT = [01/01/2007]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Call ECR_FICH("FS1", 6, ". . . . . . . . . . . . . . . . . . . ." ) From =G_GLOB0
  Call ECR_FICH("FS1", 6, "DOTATION_PERIODE  Période "+
&      format$([M:DIV]DATFMT,[F:DEPC]PERSTRDAT)+" - "+ format$([M:DIV]DATFMT,[F:DEPC]PERENDDAT) ) From =G_GLOB0

    #   *********
    #--   Réel
    #   *********
    [M:DIV]TYPCAL = "R"
    # Informations propres au suivi "Reel"
    [M:DIV]PERDATREF  = [M:DIV]PERDATREFR
    [M:DIV]MODAMT     = [F:DEPC]DPM
    [M:DIV]MODTYP     = [M:DIV]MODTYPR
    [M:DIV]DTDBAMTREG = [M:DIV]DTDBAMTRGR
    [M:DIV]DATSORREG  = [M:DIV]DATSORRGR
    [M:DIV]DTFNAMT    = [M:DIV]DTFNAMTR


  #- 1 ---------------------------------------------------
  ##If ( [F:DEPC]IML <> 0 or [F:DEPC]IMLRVE <> 0  ) Then
  If ( [F:DEPC]IML <> 0 ) Then
    #-- Si dépréciation dans la période pas de calcul pour la période courante
    Call ECR_FICH ("FS1", 6, "DOTATION_PERIODE - Dépréciation PAS de Calcul Période Courante") From =G_GLOB0
  #- 1 ---------------------------------------------------
  Else

    #If ([M:DIV]BDEBUG and [F:DEPC]DPRPLN = 6 ) Then : [M:DIV]BDEBUG -= 1 : Dbgaff : Endif

    #- 2 -------------------------
    # Si la dotation période n'est pas forcée
    If ( [F:DEPC]PERDPEFLG <> G_OUI ) Then
      #-- Réel
      Call ECR_FICH("FS1",6,"** REEL **") From =G_GLOB0
      # Calcul de l'amortissement exceptionnel de la période suite à un changement de méthode
      WPERMTCEXC  = 0
      #-3 -------------------------------------------
      If ( [M:DIV]RGLDATMTC = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)  ) Then
        # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
        If ( [F:DEPC]EXCDPR <> 0 and  [M:DIV]RGLECAE_1 = GVML_REXCEXE) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Exercice"
          Call ECR_FICH( "FS1",7,
&              "DOTATION_PERIODE - Ecart E-1 rattrapé en Amt Excp. suite à chg. méth." ) From =G_GLOB0
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Réelle (1)" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_PER ( [F:DEPC]EXCDPR, [F:DEPC]EXCDPR, [M:DIV]CUMEXCP_1R, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                            WPERMTCEXC, LMNTBID  ) From =G_GLOB5
        Elsif ( [F:DEPC]MTCDEVADJ = GVML_REXCPER  ) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Période"
          LMNTAREP = [F:DEPC]EXCDPR - [M:DIV]ECACUME_1R
          If ( LMNTAREP <> 0 )  Then
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Réelle (2)" : Gosub CAL_ADDLVL  From =G_GLOB0
            Call CAL_DOT_PER ( LMNTAREP , LMNTAREP , [M:DIV]CUMEXCP_1R, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                WPERMTCEXC, LMNTBID  ) From =G_GLOB5  : # FQ64478
          Endif
          If ([F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
            # Si l'on calcule la période dans laquelle a eu lieu le changement de méthode
            WPERMTCEXC  += [M:DIV]ECACUME_1R
          Endif
        Endif
      Endif
      #-3 -------------------------------------------

#####      # Si Jean-claude change d'avis c'est tout prêt ( à faire aussi pour le théorique et l'intial
#####      # Aide fiscale 25%, 50% 39 bis intégrée dans la première période d'amortissement
#####      If ( [M:DIV]AFI <> 0 and [F:DEPC]ALWCUM = 0 and
#####&          find ([F:DEPC]ALWCOD, GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) ) Then
#####        [M:DIV]MNTREPR = [M:DIV]MNTREPR - [M:DIV]AFI
#####        If ([F:DEPC]PERCLOCUM <> 0 ) Then
#####          [M:DIV]CUMP_1R = [M:DIV]CUMP_1R - [M:DIV]AFI
#####        Endif
#####      Endif

      # Calcul de l'amortissement de la période
      #    ============
      Call ECR_FICH( "FS1",7,"DOTATION_PERIODE - Cas standard" ) From =G_GLOB0
      [M:DIV]LVLLIB = "5.CAL_DOT_PER - Réelle (3)" : Gosub CAL_ADDLVL  From =G_GLOB0
      # FQ104870
#      Call CAL_DOT_PER ( [M:DIV]MNTREPR, [F:DEPC]ENDDPE, [M:DIV]CUMP_1R, [M:DIV]EXCREPR, [F:DEPC]PERCLOEXC,
#&                        [F:DEPC]PERENDDPE, [F:DEPC]PEREXCDPR  ) From =G_GLOB5
      Call CAL_DOT_PER ( [M:DIV]MNTREPR, [F:DEPC]ENDDPE, [M:DIV]CUMP_1R, [M:DIV]EXCREPR, [M:DIV]CUMEXCP_1R,
&                        [F:DEPC]PERENDDPE, [F:DEPC]PEREXCDPR  ) From =G_GLOB5
      #    ============

#####      # Si Jean-claude change d'avis c'est tout prêt
#####      # Aide fiscale 25%, 50% 39 bis intégrée dans la première période d'amortissement
#####      If ( [M:DIV]AFI <> 0 and [F:DEPC]ALWCUM = 0 and
#####&          find ([F:DEPC]ALWCOD, GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) ) Then
#####        [M:DIV]MNTREPR = [M:DIV]MNTREPR + [M:DIV]AFI
#####        If ([F:DEPC]PERCLOCUM = 0 ) Then
#####          [F:DEPC]PERENDDPE += [M:DIV]AFI
#####        Else
#####          [M:DIV]CUMP_1R = [M:DIV]CUMP_1R + [M:DIV]AFI
#####        Endif
#####      Endif

      # Amt Exc période = Part de l'exercice + Part relatif à un changement de méthode
      [F:DEPC]PEREXCDPR = [F:DEPC]PEREXCDPR + WPERMTCEXC

      # Si mode d'amortissement libre avec amortissement exceptionnel réintégré dans la 1ère période
      If ( [M:DPM]EXCDPRTYP([M:DIV]INDMOD-1) = GVML_CO1ERPE and [F:DEPC]PERCLOCUM = 0  and
&          func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
          [F:DEPC]PEREXCDPR = [F:DEPC]EXCDPR
      Endif

      # Ecart CUME-1 à rattraper
      # --------------------------
      #If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER ) Then FQ65464
      # FQ74870
      #If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and ([F:DEPC]PERENDDPE+[F:DEPC]PERCLOCUM+[M:DIV]ECACUME_1R) <= [F:DEPC]ENDDPE ) Then
      #If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and abs([F:DEPC]PERENDDPE+[F:DEPC]PERCLOCUM+[M:DIV]ECACUME_1R) <= abs([F:DEPC]ENDDPE) ) Then
      #  # Lorsque suite à un changement de méthode
      #  # la modalité de gestion de l'écart E-1 est "Régularisation sur dotation période"
      #  [F:DEPC]PERENDDPE += [M:DIV]ECACUME_1R
      #Endif
      # FQ102893 En cas de rattrapage de l'écart sur la période, il faut ajouter l'écart
      If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
        Call ECR_FICH( "FS1",8,"DOTATION_PERIODE - Dans la période du changement de méthode " ) From =G_GLOB0
        Call ECR_FICH( "FS1",8,"DOTATION_PERIODE - Règle : Rattrapage d'écart dans la période " ) From =G_GLOB0
        Call ECR_FICH( "FS1",8,"DOTATION_PERIODE - On ajoute l'écart E-1 à la dotation période " ) From =G_GLOB0
        Call ECR_FICH ("FS1",8,"DOTATION_PERIODE - Ecart E_1                  = "+num$([M:DIV]ECACUME_1R)    ) From =G_GLOB0

        [F:DEPC]PERENDDPE += [M:DIV]ECACUME_1R

        Call ECR_FICH ("FS1",8,"DOTATION_PERIODE - Nouvelle Dotation Période  = "+num$([F:DEPC]PERENDDPE)    ) From =G_GLOB0
      Endif
    Endif
    #- 2 -------------------------


    # FQ90084
    # Annulation de sortie
    If ([F:DEPC]FLGUPDISS = G_OUI and [F:WFAS]ISSDAT = [0/0/0]) Then
      # Lecture événement de sortie
      If clalev([F:E26])  = 0 : Local File EFASISS     [E26]  : Endif
      Filter [E26] Where REF= [F:DEPC]AASREF and SNSEVE= GVML_TEACT
      Read[E26] Last
      Filter [E26]
      If (fstat = 0) Then
        # Si la Date d'effet est antérieure au début de la période courante
        If ([F:E26]EVTDAT >= [F:DEPC]FIYSTRDAT and [F:E26]EVTDAT < [F:DEPC]PERSTRDAT) Then
          Local Integer LDPC, LDEP, B_DEPFND
          LDPC = find([F:DEPC]PERSTRDAT, [M:DEP]PERSTRDAT)
          B_DEPFND = 0
          # Issue X3-74074
          If ([F:DEPC]DPRPLN = G301SUB) Then
            If (LDPC > 1) Then
              For LDEP = LDPC-1 To 1  Step  -1
                If (func GLOBB9.CAL_DAT_INSIDE([F:E26]CURPERSTR, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                  B_DEPFND = 1 : Break
                Endif
              Next LDEP
              If(B_DEPFND) Then
                [F:DEPC]PEREXCDPR += [M:DEP]IMLRVETRF(LDEP-1) - [M:DEP]PEREXCDPR(LDEP-1)
              Endif
            Endif
          Else
            If (LDPC > 1) Then
              For LDEP = LDPC-1 To 1  Step  -1
                If (func GLOBB9.CAL_DAT_INSIDE([F:E26]EVTDAT, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                  B_DEPFND = 1 : Break
                Endif
              Next LDEP
              If(B_DEPFND) Then
                [F:DEPC]PEREXCDPR += [M:DEP]IMLRVETRF(LDEP-1) - [M:DEP]PEREXCDPR(LDEP-1)
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif


    #   *********
    #-- Théorique
    #   *********
    # Informations propres au suivi "Théorique"
    [M:DIV]TYPCAL = "T"
    [M:DIV]PERDATREF  = [M:DIV]PERDATREFT
    [M:DIV]MODAMT     = [F:DEPC]DPMT
    [M:DIV]MODTYP     = [M:DIV]MODTYPT
    [M:DIV]DTDBAMTREG = [M:DIV]DTDBAMTRGT
    [M:DIV]DATSORREG  = [M:DIV]DATSORRGT
    [M:DIV]DTFNAMT    = [M:DIV]DTFNAMTT
    #- 2 -------------------------
    # FQ87300
    #If ( [F:DEPC]IMLBLC = 0   ) Then
    If ( [F:DEPC]EXEIMLCUM = 0 and [F:DEPC]EXERVECUM = 0 and
&        [F:DEPC]PERIMLCUM = 0 and [F:DEPC]PERRVECUM = 0 and [F:DEPC]IMLBLC = 0 ) Then
      # Le "Théorique" hérite du "Réel" si :
      #     pas de dépréciation constatée
      #     et pas de différé sur le réel constaté sur l'exercice ou antérieurement
      [F:DEPC]PEREXCDPRT = [F:DEPC]PEREXCDPR
      [F:DEPC]DPET       = [F:DEPC]PERENDDPE
    #- 2 -------------------------
    Else
      Call ECR_FICH("FS1",6,"** THEORIQUE **") From =G_GLOB0
      # Calcul de l'amortissement exceptionnel de la période suite à un changement de méthode
      WPERMTCEXC  = 0
      #-3 -------------------------------------------
      If ( [M:DIV]RGLDATMTC = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)  ) Then
        # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
        If ( [F:DEPC]EXCDPRT <> 0 and [M:DIV]RGLECAE_1 = GVML_REXCEXE) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Exercice"
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Théorique (1)" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_PER ( [F:DEPC]EXCDPRT, [F:DEPC]EXCDPRT, [M:DIV]CUMEXCP_1T, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                            WPERMTCEXC, LMNTBID  ) From =G_GLOB5
        Elsif ( [F:DEPC]MTCDEVADJ = GVML_REXCPER) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Période"
          LMNTAREP = [F:DEPC]EXCDPRT - [M:DIV]ECACUME_1T
          If ( LMNTAREP <> 0 )  Then
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Théorique (2)" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_PER ( LMNTAREP , LMNTAREP , [M:DIV]CUMEXCP_1T, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                            WPERMTCEXC, LMNTBID  ) From =G_GLOB5  : # FQ64478
          Endif
          If ([F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
            # En cas de recalcul ultérieur à la période du dernier changement de méthode
            WPERMTCEXC  += [M:DIV]ECACUME_1T
          Endif
        Endif
      Endif
      #-3 -------------------------------------------

      # Calcul de l'amortissement de la période
      #    ============
      [M:DIV]LVLLIB = "5.CAL_DOT_PER - Théorique (3)" : Gosub CAL_ADDLVL  From =G_GLOB0
      # FQ104870
#      Call CAL_DOT_PER( [M:DIV]MNTREPT, [F:DEPC]ENDDPET, [M:DIV]CUMP_1T, [M:DIV]EXCREPT, [F:DEPC]PERCLOEXCT,
#&                       [F:DEPC]DPET, [F:DEPC]PEREXCDPRT  ) From =G_GLOB5
      Call CAL_DOT_PER ( [M:DIV]MNTREPT, [F:DEPC]ENDDPET, [M:DIV]CUMP_1T, [M:DIV]EXCREPT, [M:DIV]CUMEXCP_1T,
&                        [F:DEPC]DPET, [F:DEPC]PEREXCDPRT  ) From =G_GLOB5
      #    ============

      # Amt Exc période = Part de l'exercice + Part relatif à un changement de méthode
      [F:DEPC]PEREXCDPRT = [F:DEPC]PEREXCDPRT + WPERMTCEXC

      # Ecart CUME-1 à rattraper
      # -------------------------
      # FQ102893 En cas de rattrapage de l'écart sur la période, il faut ajouter l'écart
      If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
        [F:DEPC]DPET += [M:DIV]ECACUME_1T
      Endif

      # Si mode d'amortissement libre avec amortissement exceptionnel réintégré dans la 1ère période
      If ( [M:DPM]EXCDPRTYP([M:DIV]INDMOD-1) = GVML_CO1ERPE and [F:DEPC]PERCLOCUMT = 0  and
&          func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
        [F:DEPC]PEREXCDPRT = [F:DEPC]EXCDPRT
      Endif

      # FQ90084
      # Annulation de sortie
      If ([F:DEPC]FLGUPDISS = G_OUI and [F:WFAS]ISSDAT = [0/0/0]) Then
        # Lecture événement de sortie
        If clalev([F:E26])  = 0 : Local File EFASISS     [E26]  : Endif
        Filter [E26] Where REF= [F:DEPC]AASREF and SNSEVE= GVML_TEACT
        Read[E26] Last
        Filter [E26]
        If (fstat = 0) Then
          # Si la Date d'effet est antérieure au début de la période courante
          If ([F:E26]EVTDAT >= [F:DEPC]FIYSTRDAT and [F:E26]EVTDAT < [F:DEPC]PERSTRDAT) Then
            Local Integer LDPC, LDEP, B_DEPFND
            LDPC = find([F:DEPC]PERSTRDAT, [M:DEP]PERSTRDAT)
            B_DEPFND = 0
            # Issue X3-74074
            If ([F:DEPC]DPRPLN = G301SUB) Then
              If (LDPC > 1) Then
                For LDEP = LDPC-1 To 1  Step  -1
                  If (func GLOBB9.CAL_DAT_INSIDE([F:E26]CURPERSTR, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                    B_DEPFND = 1 : Break
                  Endif
                Next LDEP
                If(B_DEPFND) Then
                  [F:DEPC]PEREXCDPRT = [F:DEPC]PEREXCDPRT - [M:DEP]PEREXCDPRT(LDEP-1)
                Endif
              Endif
            Else
              If (LDPC > 1) Then
                For LDEP = LDPC-1 To 1  Step  -1
                  If (func GLOBB9.CAL_DAT_INSIDE([F:E26]EVTDAT, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                    B_DEPFND = 1 : Break
                  Endif
                Next LDEP
                If(B_DEPFND) Then
                  [F:DEPC]PEREXCDPRT = [F:DEPC]PEREXCDPRT - [M:DEP]PEREXCDPRT(LDEP-1)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif

    Endif
    #- 2 -------------------------

    #   *********
    #-- Initial
    #   *********

#  If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 6 and
#&      [F:DEPC]PERENDDAT = [30/06/2006]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

    [M:DIV]TYPCAL = "I"
    # Informations propres au suivi "Théorique"
    [M:DIV]PERDATREF  = [M:DIV]PERDATREFI
    [M:DIV]MODAMT     = [F:DEPC]DPMI
    [M:DIV]MODTYP     = [M:DIV]MODTYPI
    [M:DIV]DTDBAMTREG = [M:DIV]DTDBAMTRGI
    [M:DIV]DATSORREG  = [M:DIV]DATSORRGI
    [M:DIV]DTFNAMT    = [M:DIV]DTFNAMTI

    #- 2 ------------------------- FQ63366 FQ87300
    #If ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS  and [F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMI and [F:DEPC]PERCLOCUM = [F:DEPC]PERCLOCUMI ) Then
    If ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]EXERVADEV = 0 and [F:DEPC]PERRVADEV = 0 ) Then
      # L'"Initial" hérite du "Théorique" si : la base initiale est égale à la base réévalué
      [F:DEPC]PEREXCDPRI = [F:DEPC]PEREXCDPRT
      [F:DEPC]DPEI       = [F:DEPC]DPET
    #- 2 -------------------------
    Else
      Call ECR_FICH("FS1",6,"** INITIAL **") From =G_GLOB0
      # Calcul de l'amortissement exceptionnel de la période suite à un changement de méthode
      WPERMTCEXC  = 0
      #-3 -------------------------------------------
      If (  [M:DIV]RGLDATMTC = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)  ) Then
        # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
        If ( [F:DEPC]EXCDPRI <> 0 and [M:DIV]RGLECAE_1 = GVML_REXCEXE) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Exercice"
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Intiale (1)" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_PER ( [F:DEPC]EXCDPRI, [F:DEPC]EXCDPRI, [M:DIV]CUMEXCP_1I, [M:DIV]MNTNUL,[M:DIV]MNTNUL,
&                            WPERMTCEXC, LMNTBID  ) From =G_GLOB5
        Elsif ( [F:DEPC]MTCDEVADJ = GVML_REXCPER) Then
          # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Période"
          LMNTAREP = [F:DEPC]EXCDPRI - [M:DIV]ECACUME_1I
          If ( LMNTAREP <> 0 )  Then
          [M:DIV]LVLLIB = "5.CAL_DOT_PER - Intiale (2)" : Gosub CAL_ADDLVL  From =G_GLOB0
          Call CAL_DOT_PER ( LMNTAREP , LMNTAREP , [M:DIV]CUMEXCP_1I, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                            WPERMTCEXC , LMNTBID  ) From =G_GLOB5  : # FQ64478
          Endif
          If ([F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
            # En cas de recalcul ultérieur à la période du dernier changement de méthode
            WPERMTCEXC  += [M:DIV]ECACUME_1I
          Endif
        Endif
      Endif
      #-3 -------------------------------------------

      # Calcul de l'amortissement de la période
      #    ============
      [M:DIV]LVLLIB = "5.CAL_DOT_PER - Intiale (3)" : Gosub CAL_ADDLVL  From =G_GLOB0
      # FQ104870
#      Call CAL_DOT_PER( [M:DIV]MNTREPI, [F:DEPC]ENDDPEI, [M:DIV]CUMP_1I, [M:DIV]EXCREPI, [F:DEPC]PERCLOEXCI,
#&                       [F:DEPC]DPEI, [F:DEPC]PEREXCDPRI  ) From =G_GLOB5
      Call CAL_DOT_PER ( [M:DIV]MNTREPI, [F:DEPC]ENDDPEI, [M:DIV]CUMP_1I, [M:DIV]EXCREPI, [M:DIV]CUMEXCP_1I,
&                        [F:DEPC]DPEI, [F:DEPC]PEREXCDPRI  ) From =G_GLOB5
      #    ============
      # Amt Exc période = Part de l'exercice + Part relatif à un changement de méthode
      [F:DEPC]PEREXCDPRI = [F:DEPC]PEREXCDPRI + WPERMTCEXC

      # Ecart CUME-1 à rattraper
      # ------------------------
      # FQ102893 En cas de rattrapage de l'écart sur la période, il faut ajouter l'écart
      If ( [M:DIV]RGLECAE_1 = GVML_RDOTPER and [F:DEPC]MTCDPEDAT <> [0/0/0] ) Then
        [F:DEPC]DPEI += [M:DIV]ECACUME_1I
      Endif
      # Si mode d'amortissement libre avec amortissement exceptionnel réintégré dans la 1ère période
      If ( [M:DPM]EXCDPRTYP([M:DIV]INDMOD-1) = GVML_CO1ERPE and [F:DEPC]PERCLOCUMI = 0  and
&          func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) Then
        [F:DEPC]PEREXCDPRI = [F:DEPC]EXCDPRI
      Endif

      # FQ90084
      # Annulation de sortie
      If ([F:DEPC]FLGUPDISS = G_OUI and [F:WFAS]ISSDAT = [0/0/0]) Then
        # Lecture événement de sortie
        If clalev([F:E26])  = 0 : Local File EFASISS     [E26]  : Endif
        Filter [E26] Where REF= [F:DEPC]AASREF and SNSEVE= GVML_TEACT
        Read[E26] Last
        Filter [E26]
        If (fstat = 0) Then
          # Si la Date d'effet est antérieure au début de la période courante
          If ([F:E26]EVTDAT >= [F:DEPC]FIYSTRDAT and [F:E26]EVTDAT < [F:DEPC]PERSTRDAT) Then
            Local Integer LDPC, LDEP, B_DEPFND
            LDPC = find([F:DEPC]PERSTRDAT, [M:DEP]PERSTRDAT)
            B_DEPFND = 0
            # Issue X3-74074
            If ([F:DEPC]DPRPLN = G301SUB) Then
              If (LDPC > 1) Then
                For LDEP = LDPC-1 To 1  Step  -1
                  If (func GLOBB9.CAL_DAT_INSIDE([F:E26]CURPERSTR, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                    B_DEPFND = 1 : Break
                  Endif
                Next LDEP
                If(B_DEPFND) Then
                  [F:DEPC]PEREXCDPRI = [F:DEPC]PEREXCDPRI - [M:DEP]PEREXCDPRI(LDEP-1)
                Endif
              Endif
            Else
              If (LDPC > 1) Then
                For LDEP = LDPC-1 To 1  Step  -1
                  If (func GLOBB9.CAL_DAT_INSIDE([F:E26]EVTDAT, [M:DEP]PERSTRDAT(LDEP-1), [M:DEP]PERENDDAT(LDEP-1), "I") ) Then
                    B_DEPFND = 1 : Break
                  Endif
                Next LDEP
                If(B_DEPFND) Then
                  [F:DEPC]PEREXCDPRI = [F:DEPC]PEREXCDPRI - [M:DEP]PEREXCDPRI(LDEP-1)
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif

    Endif
    #- 2 -------------------------

  Endif
  #- 1 ---------------------------------------------------

  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Dotation période    REEL.="+
&     format$([M:DIV]CURFMT, [F:DEPC]PERENDDPE)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Amort. exceptionnel REEL.="+
&     format$([M:DIV]CURFMT, [F:DEPC]PEREXCDPR)) From =G_GLOB0
  If not ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPSTD or [F:DEPC]IMLBLC = 0 ) Then
  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Dotation période    THEO.="+
&     format$([M:DIV]CURFMT, [F:DEPC]DPET)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Amort. exceptionnel THEO.="+
&     format$([M:DIV]CURFMT, [F:DEPC]PEREXCDPRT)) From =G_GLOB0
  #FQ63366
  If not ( [M:DIV]PLNSTD(find([F:DEPC]DPRPLN, [M:DIV]PLNCAA)-1) = GVML_NPSTD or
&          ( [F:DEPC]BSEVAL = [F:DEPC]DPRBAS and [F:DEPC]DPRCUM = [F:DEPC]EXECLOCUMI and [F:DEPC]PERCLOCUM = [F:DEPC]PERCLOCUMI ) ) Then
  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Dotation période    INIT.="+
&     format$([M:DIV]CURFMT, [F:DEPC]DPEI)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"DOTATION_PERIODE - Amort. exceptionnel INIT.="+
&     format$([M:DIV]CURFMT, [F:DEPC]PEREXCDPRI)) From =G_GLOB0
  Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#
#########################################################
Subprog  MTC_AMT_EXC_PERIODE ( PEXCEXE, PECACUME_1, PCUMEXCP_1, REXCPER, RERROR )
#
# - Objet  :
#
#
# - Entrée :
#
#
# - Sortie : [F:DEPn]
#
#   Boite noire
#

Value Decimal    PEXCEXE      : # Amort. except. Exercice
Value Decimal    PECACUME_1   : # Ecart sur cumul E-1
Value Decimal    PCUMEXCP_1   : # Cumul amortissement exeptionnel P-1
Variable Decimal REXCPER      : # Amortissement exceptionnel de la période
Variable Decimal RERROR

Local Decimal LMNTAREP     : # Montant de dotation à repartir
Local Decimal LMNTBID


  REXCPER  = 0

  #-1 -------------------------------------------
  If ( [M:DIV]RGLDATMTC = GVML_PEDBAM and [F:DEPC]STRDPRDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1)  ) Then
  # Lorsque suite à un changement de méthode la prise d'effet est "Début d'amortissement"
    #-2 -------------------------------------------
    If ( PEXCEXE <> 0 and [M:DIV]RGLECAE_1 = GVML_REXCEXE) Then
      # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Exercice"
      [M:DIV]LVLLIB = "5.CAL_DOT_PER (A)" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_DOT_PER ( PEXCEXE, PEXCEXE, PCUMEXCP_1, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                        REXCPER, LMNTBID  ) From =G_GLOB5
    #-2 -------------------------------------------
    Elsif ( [F:DEPC]MTCDEVADJ = GVML_REXCPER) Then
      # la modalité de gestion de l'écart E-1 est "Régularisation en Amt Except Période"
      LMNTAREP = PEXCEXE - PECACUME_1
      If ( LMNTAREP <> 0 )  Then
      [M:DIV]LVLLIB = "5.CAL_DOT_PER (B)" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_DOT_PER ( LMNTAREP , LMNTAREP , PCUMEXCP_1, [M:DIV]MNTNUL, [M:DIV]MNTNUL,
&                        REXCPER, LMNTBID  ) From =G_GLOB5  : # FQ64478
      Endif
      REXCPER  += PECACUME_1
    Endif
    #-2 -------------------------------------------
  Endif
  #-1 -------------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#################################################################################

#
#*********************************************************************
Subprog  CAL_CUMUL_E_1
&      ( RCUME_1R, RCUME_1T, RCUME_1I, REXCE_1R, REXCE_1T, REXCE_1I, RAFIE_1, RVEHE_1 )
#
# - Objet  : Calcul de cumul des amortissements pratiqués
#            dans les exercices antérieurs (CUM E-1)
#
# - Tech.  : Travaille avec DEPC initialisé avec [M:DEP] période courante
#            Travaille avec DEPS qui reçoit le résultat de clôtures successives
#
# - Entrée : [M:DEP]
#
# - Sortie :
#

#   Boite noire gcfc06
#
Variable Decimal RCUME_1R
Variable Decimal RCUME_1T
Variable Decimal RCUME_1I
Variable Decimal REXCE_1R
Variable Decimal REXCE_1T
Variable Decimal REXCE_1I
Variable Decimal RAFIE_1
Variable Decimal RVEHE_1

Local Date    WDTDBEXE
Local Integer WINDEXE


  # ---------------------------------------------
  # - CUMUL
  # ---------------------------------------------

  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301FIS ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #-1 ------------------------------
  If ( [M:DEP]STRDPRDAT([M:DIV]DPC-1) >= [M:FIY]DATSTRFIY ([M:DIV]FEC-1) ) Then
    # La date de début d'amortissement se situe dans l'exercice courant ou au delà
    # Pas de CUM E-1
    Call ECR_FICH("FS1", 5, "CAL_CUMUL_E_1 - Pas de CUM E-1") From =G_GLOB0 : # Contextes
  #-1 ------------------------------
  Else
    # La date de début d'amortissement est antérieure à l'exercice courant
    Call ECR_FICH("FS1", 5, "CAL_CUMUL_E_1 - RECONSTITUTION de CUM E-1") From =G_GLOB0

    # Buffer pour reconstitution (calcul & clôture succesifs)
    #If clalev([F:DEPC])   =0  : Local File DEPREC     [DEPC]    :  Endif        : # DEPREC FQ79813
    #If clalev([F:DEPS])   =0  : Local File DEPREC     [DEPS]    :  Endif        : # DEPREC FQ79813
    #If clalev([F:SEPC])   =0  : Local File DEPREC     [SEPC]    :  Endif        : # DEPREC FQ79813
    #If clalev([F:SEPS])   =0  : Local File DEPREC     [SEPS]    :  Endif        : # DEPREC FQ79813

    # Sauvegarde DEPC DEPS
    [F:SEPC] = [F:DEPC]
    [F:SEPS] = [F:DEPS]

    # Initialisation du cumul à 0.
    Raz [F:DEPC]DPRCUM
    Raz [F:DEPC]EXECLOCUMT
    Raz [F:DEPC]EXECLOCUMI
    Raz [F:DEPC]EXCCUM
    Raz [F:DEPC]EXCCUMT
    Raz [F:DEPC]EXCCUMI
    Raz [F:DEPC]ALWCUM
    # FQ103697
    Raz [F:DEPC]EXEIMLCUM
    Raz [F:DEPC]EXERVECUM
    Raz [F:DEPC]EXETRFCUM
    Raz [F:DEPC]PERCLOCUM
    Raz [F:DEPC]PERCLOCUMT
    Raz [F:DEPC]PERCLOCUMI
    Raz [F:DEPC]PERCLOEXC
    Raz [F:DEPC]PERCLOEXCT
    Raz [F:DEPC]PERCLOEXCI
    Raz [F:DEPC]PEREXCDPR
    Raz [F:DEPC]PEREXCDPRT
    Raz [F:DEPC]PEREXCDPRI
    Raz [F:DEPC]CRBCUM
    Raz [F:DEPC]CRBAMT
    Raz [F:DEPC]ALWAMT
    Raz [F:DEPC]PERQTYCUM
    Raz [F:DEPC]PERRVACUM
    Raz [F:DEPC]RVAAMT
    Raz [F:DEPC]RVACRB
    Raz [F:DEPC]PERIMLCUM
    Raz [F:DEPC]PERRVECUM
    Raz [F:DEPC]PERTRFCUM
    Raz [F:DEPC]IML
    Raz [F:DEPC]IMLRVE
    Raz [F:DEPC]IMLRVETRF


    # Reconstitution à partir de l'exercice d'investissement
    # avec la méthode en vigeur dans la période courante


    # Il faut déterminer le type de prorata car il est nécessaire
    # à la détermination de l'exercice lorsque celui-ci n'existe pas (365 ou 366 jours)
    # Recherche indice du mode d'amortissement
    [M:DIV]LVLLIB = "8.CAL_LOCALISE_MODE" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_LOCALISE_MODE
&        ( [F:DEPC]DPM,
&          [F:DEPC]STRDPRDAT,
&          [F:DEPC]FIYSTRDAT,
&          [F:DEPC]FIYENDDAT,
&          [M:DIV]INDMOD,
&          [M:DIV]INDANNLB,
&          [M:DIV]TXLB,
&          [M:DIV]TX2LB,
&          [M:DIV2]RGRPPER ) From =G_GLOB8  : # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation
    If ([M:DIV]ERROR) Then : End : Endif

    [F:DEPC]DPMT       = [F:DEPC]DPM
    [F:DEPC]DPMI       = [F:DEPC]DPM

    # Type de prorata
    Call CAL_TYPE_PRORATA ( [F:DEPC]DPM, [F:DEPC]ALWCOD,
&          [F:DEPC]PRATYP, [M:CNX]PROWEK ([F:DEPC]CNX-1)-1,  [M:DIV]PROEXEMDB,
&          [M:DIV]PROEXEMLB, [M:DPM]PROTYP([M:DIV]INDMOD-1), [M:DIV]TYPPRO, [M:DIV]TYPPRODAT ) From =G_GLOB8
    If ( [M:DIV]ERROR ) Then : End : Endif

#   Call CAL_EXERCICE_SELON_DATE ( [M:DEP]STRDPRDAT([M:DIV]DPC-1),[M:DIV]TYPPRO,
#&       [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT, WINDEXE ) From =G_GLOB8
    [M:DIV]PD(0)= [M:DEP]STRDPRDAT([M:DIV]DPC-1) : [M:DIV]PV(0)= [M:DIV]TYPPRO
    Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
    [F:DEPC]FIYSTRDAT = [M:DIV]RD(1) : [F:DEPC]FIYENDDAT = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH ( "FS1", 4, "CAL_PLAN - Exercice d'investissement"-
&        format$([M:DIV]DATFMT, [F:DEPC]FIYSTRDAT)-format$([M:DIV]DATFMT, [F:DEPC]FIYENDDAT) ) From =G_GLOB0


    # Suivant devient Courant
    [F:DEPS] = [F:DEPC]

    # FQ107461 Détermination de la date de début d'exercice à calculer  à comparer avec la date de début dexercice courant.
    # En reconstitution de cumul, cette date est incrementée de 1 an pour chaque exercice calculée jusqu'à atteindre l'exercice courant.
    Local Date L_DATSTRFIY
    L_DATSTRFIY = gdat$(day([M:FIY]DATSTRFIY([M:DIV]FEC-1)),month([M:FIY]DATSTRFIY([M:DIV]FEC-1)), year([F:DEPC]FIYSTRDAT) )

    # >2 >>>>>>>>>>>
    # FQ107461
    While ( L_DATSTRFIY < [M:FIY]DATSTRFIY ([M:DIV]FEC-1) )
    #While ( [F:DEPC]FIYSTRDAT < [M:FIY]DATSTRFIY ([M:DIV]FEC-1) )

      # Tant que l'exercice à calculer n'est pas l'exercice courant

     #If (GUSER = "MWA" and [F:DEPC]DPRPLN = G301MIN and [F:DEPC]FIYSTRDAT = [01/01/2001] ) Then : Dbgaff : Endif

     [F:DEPC]PERSTRDAT  = [F:DEPC]FIYSTRDAT
     # FQ107461
     #[F:DEPC]PERENDDAT  = [F:DEPC]PERENDDAT
     [F:DEPC]PERENDDAT  = [F:DEPC]FIYENDDAT
     [F:DEPC]PERREFCLC  = [F:DEPC]FIYSTRDAT
     [F:DEPC]PERREFCLCT = [F:DEPC]FIYSTRDAT
     [F:DEPC]PERREFCLCI = [F:DEPC]FIYSTRDAT
     [F:DEPC]PERCLOCUM  = 0
     [F:DEPC]PERCLOCUMT = 0
     [F:DEPC]PERCLOCUMI = 0
     [F:DEPC]PERCLOEXC  = 0
     [F:DEPC]PERCLOEXCT = 0
     [F:DEPC]PERCLOEXCI = 0

      # Dotation exercice
      [M:DIV]LVLLIB = "3.DOTATION_EXERCICE (E-1)" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call DOTATION_EXERCICE From =G_GLOB3

      # Avant clôture
      [F:DEPS] = [F:DEPC]
      # Clôture exercice [F:DEPC] -> [F:DEPS]
      [M:DIV]LVLLIB = "6.CAL_CLORE_EXERCICE_AMT (E-1)" : Gosub CAL_ADDLVL  From =G_GLOB0
      Gosub CAL_CLORE_EXERCICE_AMT From =G_GLOB6
      # Début/Fin du nouvel exercice
      WDTDBEXE  = func GLOBB9.CAL_DAT_PLUS( [F:DEPC]FIYENDDAT, 1, "D" )
#     Call CAL_EXERCICE_SELON_DATE
#&          ( WDTDBEXE , [M:DIV]TYPPRO, [F:DEPS]FIYSTRDAT, [F:DEPS]FIYENDDAT, WINDEXE ) From =G_GLOB8
      [M:DIV]PD(0)= WDTDBEXE  : [M:DIV]PV(0)= [M:DIV]TYPPRO
      Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
      [F:DEPS]FIYSTRDAT = [M:DIV]RD(1) : [F:DEPS]FIYENDDAT = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
      If ([M:DIV]ERROR) Then : Break : Endif
      # Suivant devient Courant
      [F:DEPC] = [F:DEPS]


      # FQ107461
      L_DATSTRFIY = func GLOBB9.CAL_DAT_PLUS( L_DATSTRFIY, +1, "Y")

    Wend
    # <2 <<<<<<<<<<<<<

    If ([M:DIV]ERROR) Then : End : Endif

    # Cumul E-1 reconstitué
    # -- Dotation
    RCUME_1R = [F:DEPC]DPRCUM
    RCUME_1I = [F:DEPC]EXECLOCUMI
    RCUME_1T = [F:DEPC]EXECLOCUMT
    #-- Amortissement exceptionnel
    REXCE_1R = [F:DEPC]EXCCUM
    REXCE_1I = [F:DEPC]EXCCUMI
    REXCE_1T = [F:DEPC]EXCCUMT
    #-- Aide fiscale
    RAFIE_1  = [F:DEPC]ALWCUM
    #-- Réintégration véhicule
    RVEHE_1  = [F:DEPC]CRBCUM

    Call ECR_FICH("FS1", 5,
&   "Cumul E-1 reconstitué REEL"-"="-format$([M:DIV]CURFMT,RCUME_1R) ) From =G_GLOB0 : # Cumul E-1 réel
    Call ECR_FICH("FS1", 5,
&   "Cumul E-1 reconstitué THEO"-"="-format$([M:DIV]CURFMT,RCUME_1T) ) From =G_GLOB0 : # Cumul E-1 théorique
    Call ECR_FICH("FS1", 5,
&   "Cumul E-1 reconstitué INIT"-"="-format$([M:DIV]CURFMT,RCUME_1I) ) From =G_GLOB0 : # Cumul E-1 initial
    Call ECR_FICH("FS1", 5,
&   "Aide fiscale reconstituée  "-"="-format$([M:DIV]CURFMT,RAFIE_1) ) From =G_GLOB0  : # Aide fiscale E-1
    Call ECR_FICH("FS1", 5,
&   "Réint. Véhic reconstituée  "-"="-format$([M:DIV]CURFMT,RVEHE_1) ) From =G_GLOB0  : # Réint Véhicule E-1


    # Restauration DEPC DEPS
    #If ([F:DEPC]DPM = G_DPMDF) Then : [F:DEPC]ENDDPRDAT = [F:SEPC]ENDDPRDAT : Endif : # FQ77734 FQ85343 F101738
    [F:DEPC] = [F:SEPC]
    If ([F:DEPC]DPM = G_DPMDF) Then : [F:DEPC]ENDDPRDAT = [M:DIV]DTFNAMT : Endif : # F101738
    [F:DEPS] = [F:SEPS]

    # Fermeture SDEPC SDEPS
    #If clalev([F:SEPC])  : Close File [SEPC]   :  Endif        : # DEPREC FQ79813
    #If clalev([F:SEPS])  : Close File [SEPS]   :  Endif        : # DEPREC FQ79813
  Endif
  #-1 ------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#
#*********************************************************************
Subprog  CAL_ECART_CUMUL_E_1 ( RECACUME_1R, RECACUME_1T, RECACUME_1I )
#
# - Objet  : Calcul de l'écart sur cumul d'amortissement pratiqués sur les exercices antérieurs
#            suite à un changement de méthode
#
#
# - Entrée : [M:DEP]
#
# - Sortie :
#
#   Boite noire gcfc03b
#

Variable Decimal RECACUME_1R
Variable Decimal RECACUME_1T
Variable Decimal RECACUME_1I

Local Decimal WCUME_1R  : Raz WCUME_1R
Local Decimal WCUME_1T  : Raz WCUME_1T
Local Decimal WCUME_1I  : Raz WCUME_1I
Local Decimal WEXCE_1R  : Raz WEXCE_1R
Local Decimal WEXCE_1T  : Raz WEXCE_1T
Local Decimal WEXCE_1I  : Raz WEXCE_1I
Local Decimal WAFIE_1   : Raz WAFIE_1
Local Decimal WVEHE_1   : Raz WVEHE_1


  # ---------------------------------------------
  # - CUMUL
  # ---------------------------------------------

    # Nouveau Cumul E-1
    [M:DIV]LVLLIB = "3.CAL_CUMUL_E_1" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_CUMUL_E_1
&        ( WCUME_1R, WCUME_1T, WCUME_1I, WEXCE_1R, WEXCE_1T, WEXCE_1I, WAFIE_1, WVEHE_1) From =G_GLOB3
    If ([M:DIV]ERROR) Then : End : Endif

    # Ecart sur Cumul E-1
    RECACUME_1R = WCUME_1R - ( [F:DEPC]DPRCUM      + [F:DEPC]DFDBLC )
    RECACUME_1T = WCUME_1T - ( [F:DEPC]EXECLOCUMT  + [F:DEPC]DFDBLC )
    RECACUME_1I = WCUME_1I - ( [F:DEPC]EXECLOCUMI  + [F:DEPC]DFDBLC )

    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Nouveau Cumul E-1 ="-format$([M:DIV]CURFMT,WCUME_1R) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Ancien  Cumul E-1 ="-format$([M:DIV]CURFMT,[F:DEPC]DPRCUM)) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 5, "CAL_ECART_CUMUL_E_1 - Ecart Cumul E-1 REEL ="-format$([M:DIV]CURFMT,RECACUME_1R) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Nouveau Cumul E-1 ="-format$([M:DIV]CURFMT,WCUME_1I) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Ancien  Cumul E-1 ="-format$([M:DIV]CURFMT,[F:DEPC]EXECLOCUMI)) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 5, "CAL_ECART_CUMUL_E_1 - Ecart Cumul E-1 INIT ="-format$([M:DIV]CURFMT,RECACUME_1I) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Nouveau Cumul E-1 ="-format$([M:DIV]CURFMT,WCUME_1T) ) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 6, "CAL_ECART_CUMUL_E_1 - Ancien  Cumul E-1 ="-format$([M:DIV]CURFMT,[F:DEPC]EXECLOCUMT)) From =G_GLOB0
    Call ECR_FICH
&   ("FS1", 5, "CAL_ECART_CUMUL_E_1 - Ecart Cumul E-1 THEO ="-format$([M:DIV]CURFMT,RECACUME_1T) ) From =G_GLOB0


  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End



#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343



#########################################################
Subprog  PROVISION_EXERCICE
#
# - Objet  : Calcule la provsion pour l'exercice
#
#
# - Entrée : [M:DIV] Structure Cdota
#

Local Integer I_P
Local Date    LDATBID

  # If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Call ECR_FICH("FS1", 5, "..................................................................." ) From =G_GLOB0
  Call ECR_FICH("FS1", 5, "PROVSION_EXERCICE - Exercice "+
&      format$([M:DIV]DATFMT,[F:RPRC]FIYSTRDAT)+" - "+ format$([M:DIV]DATFMT,[F:RPRC]FIYENDDAT) ) From =G_GLOB0


  Call CAL_AVANT_CCN_PROV_EXE  From  =G_GLOB4FR
  If ([M:DIV]ERROR) Then :  End : Endif

  Call ECR_FICH("FS1",5,"** PROVISION **") From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Valeur Remplacement Initiale    ="+
&   format$([M:DIV]CURFMT, [F:RPRC]STRRNWVAL)) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Coefficient d'actualisation     = "+
&   num$([M:DIV]COEACT) ) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Valeur Remplacement Actualisée  ="+
&   format$([M:DIV]CURFMT, [F:RPRC]ENDRNWVAL)) From =G_GLOB0

  # Calcul provision exercice

  #    ============
  Call CCN_PROV_EXE  From  =G_GLOB4FR
  #    ============
  If ([M:DIV]ERROR) Then :  End : Endif

  # =====================================================================================

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTRPREXE               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI3 ) Then : # FQ114113
    GPOINT = "AFTRPREXE"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : End
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE


  [F:RPRC]EXEACGRPR = [M:DIV]EXEACGRPR
  [F:RPRC]EXEFISRPR = [M:DIV]EXEFISRPR
  [F:RPRC]EXERVERPR = [M:DIV]EXERVERPR
  [F:RPRC]EXESUPCAD = [M:DIV]EXESUPCAD

  If ( [M:DIV]NIVDET > 4 ) Then
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Provision comptable    ="+
&     format$([M:DIV]CURFMT, [F:RPRC]EXEACGRPR)) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Provision fiscale      ="+
&     format$([M:DIV]CURFMT, [F:RPRC]EXEFISRPR)) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Reprise provision fis. ="+
&     format$([M:DIV]CURFMT, [F:RPRC]EXERVERPR)) From =G_GLOB0
  Call ECR_FICH ("FS1", 5, "PROVISION_EXERCICE - Suppl de caducité fis. ="+
&     format$([M:DIV]CURFMT, [F:RPRC]EXESUPCAD)) From =G_GLOB0
  Endif


End

#
#########################################################
Subprog  PROVISION_PERIODE
#
# - Objet  :
#
#
# - Objet  :  Calcul de la provision pour renouvellement de la période.
#             La provision équivaut à la part de la provision exercice à répartir sur les périodes.
#             Cette part est calculée par différence entre le cumul P-1 et le cumul fin de période P
#
#
#
# - Sortie : [F:RPRn]
#
#   Boite noire
#

Local Decimal LMNTAREP
Local Decimal LMNTBID



  If ( [F:RPRC]FIYSTRDAT = [F:RPRC]PERSTRDAT and [F:RPRC]FIYENDDAT = [F:RPRC]PERENDDAT  ) Then
    # Une seule période d'un exercice
    [F:RPRC]PERACGRPR  = [F:RPRC]EXEACGRPR
    [F:RPRC]PERFISRPR  = [F:RPRC]EXEFISRPR
    [F:RPRC]PERRVERPR  = [F:RPRC]EXERVERPR
    [F:RPRC]PERSUPCAD  = [F:RPRC]EXESUPCAD
    End
  # ***
  Endif

  #If ( [M:DIV]BDEBUG and [F:RPRC]PERSTRDAT = [01/01/2010]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Call ECR_FICH("FS1", 6, ". . . . . . . . . . . . . . . . . . . ." ) From =G_GLOB0
  Call ECR_FICH("FS1", 6, "PROVISION_PERIODE  Période "+
&      format$([M:DIV]DATFMT,[F:RPRC]PERSTRDAT)+" - "+ format$([M:DIV]DATFMT,[F:RPRC]PERENDDAT) ) From =G_GLOB0


  # Calcul de l'amortissement de la période
  #    ============
  Call ECR_FICH( "FS1",7,"PROVSION_PERIODE" ) From =G_GLOB0
  Call CCN_PROV_PER ([M:DIV]EXEACGRPR, [M:DIV]EXEFISRPR, [M:DIV]EXERVERPR, [M:DIV]EXESUPCAD,
&                    [M:DIV]P_1ACGRPR, [M:DIV]P_1FISRPR, [M:DIV]P_1RVERPR, [M:DIV]P_1SUPCAD,
&                    [F:RPRC]PERACGRPR,[F:RPRC]PERFISRPR,[F:RPRC]PERRVERPR,[F:RPRC]PERSUPCAD) From =G_GLOB5
  #    ============

If ( [M:DIV]NIVDET = 6 or [M:DIV]NIVDET = 7 ) Then
  Call ECR_FICH("FS1",6,"PROVISION_PERIODE - Provision comptable       ="+
&     format$([M:DIV]CURFMT, [F:RPRC]PERACGRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"PROVISION_PERIODE - Provision fiscale         ="+
&     format$([M:DIV]CURFMT, [F:RPRC]PERFISRPR)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"PROVISION_PERIODE - Reprise provision fiscale ="+
&     format$([M:DIV]CURFMT, [F:RPRC]PERRVERPR)) From =G_GLOB0
  Call ECR_FICH("FS1",6,"PROVISION_PERIODE - Supplément caducité       ="+
&     format$([M:DIV]CURFMT, [F:RPRC]PERSUPCAD)) From =G_GLOB0
Endif
End

