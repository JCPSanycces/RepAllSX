#<AdxTL>@(#)0.0.0.0 $Revision$ Hist. fiche technique
Local Char PARAM(20)(1..8)
PARAM(1) = "0"
PARAM(2) = "CQ"
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""
PARAM(8) = ""
Call GCONSULT("SH3","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSHQ]:Transmask [M:SHQ1] To [M:CSHQ] #[M:CSHQ] = [M:SHQ1]  # Issue 25606_Transmask
  When "FIN_CRIT"   : [M:SHQ1] = [M:CSHQ]
  When "AP_MAGNETO" : Gosub AP_MAGNETO

  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "SEL_LISTE"    : Gosub SEL_LISTE



  When Default
Endcase
Return

$SEL_TABLE
Case TABLE
  When "STKSELQL3"    : Gosub STKSELQL3
 # When "STKSELQL31"   : Gosub STKSELQL31
Endcase
Return
############################################################
$VERF_TABLE
Case TABLE
  When "STKSELQL3"    : Gosub V_STKSELQL3
#  When "STKSELQL31"   : Gosub V_STKSELQL31
Endcase
Return

############################################################
# Sélection analyse qualité
############################################################

$STKSELQL3
Local Char    WFIC(10)        : WFIC = "STOQUAL"
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Integer WOPT            : WOPT = val(PARAM(2))
Local Char    WITM(GLONITM)   : WITM = PARAM(3)
Local Char    WLOT(GLONLOT)   : WLOT = PARAM(4)
#

If clalev([F:STQ]) = 0 : Local File STOQUAL   [STQ] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
#
TIT(0) = mess(2,721,1)
NBCOL  = 1 : COL(NBCOL) = "QLYCTLDEM"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOT"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ENDCTLDAT"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STQ]STAFLG,1,1)"
Call TEXTFIC(WFIC,"STAFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:STQ]CRDFLG,1,1)"
Call TEXTFIC(WFIC,"CRDFLG",2,TIT(NBCOL)) From OBJDIV
#

CRITERE = "QLYCTLDEM>=VALEUR"
If WOPT = 0
  CRITERE += "&(CRDFLG<>2|STAFLG<>2)"
Else
  CRITERE += "&!(CRDFLG<>2|STAFLG<>2)"
Endif
If WFCY <> ""
  CRITERE  += "&STOFCY=WFCY"
Endif
If WITM <> ""
  CRITERE += "&ITMREF=WITM"
Endif
If WLOT <> ""
  CRITERE += "&pat([F:STQ]LOT,WLOT)"
Endif
ORDRE   = "QLYCTLDEM"
START   = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 260
Default File [STQ]
Return
############################################################
$V_STKSELQL3
PARAM(03) = [F:STQ]ITMREF
PARAM(04) = [F:STQ]LOT
Return


$SEL_LISTE

Case LISTE
     When "STKSELQL31"       : Gosub STKSELQL31
Endcase
Return


$STKSELQL31
Local Char    LITM(GLONITM)      : LITM =      PARAM(1)
Local Char NUMLOT(GLONLOT)
NUMLOT = ""
Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""
If clalev([F:STQ]) = 0 : Local File STOQUAL   [STQ] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif

Filter [STQ] Where [F:STQ]ITMREF = LITM Order By Key STQ1
For [STQ] With Nohint
    If NUMLOT = [F:STQ]LOT
       Goto NEXTLIS
    Endif
    NUMLOT = [F:STQ]LOT

    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX(Z) = [F:STQ]LOT
    TEXTE(Z) = [F:STQ]LOT
$NEXTLIS
Next

Filter [STQ]
ORDRE   = "ITMREF;LOT"

NBTEX = Z
SZTIT = mess(23,107,1) #Lot
TIT = left$(SZTIT, 20)

Return











############################################################
$AP_MAGNETO
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:STQ]) = 0 : Local File STOQUAL    [STQ]  : Endif
If clalev([F:QLA]) = 0 : Local File QLYCRDASW  [QLA]  : Endif
If clalev([F:QLA1])= 0 : Local File QLYCRDASW  [QLA1] : Endif
If clalev([F:QLQ]) = 0 : Local File QLYCRDQST  [QLQ]  : Endif
If clalev([F:QLC]) = 0 : Local File QLYCRD     [QLC]  : Endif
If clalev([F:QLC]) = 0 : Local File QLYCRD     [QLC]  : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL]  : Endif
#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I
#
Local Char    WFIRDEM(20)
Local Decimal WFIRSEQ
#
Local Char    WLASDEM(20)
Local Decimal WLASSEQ
#
Local Char    WCURITM(GLONITM)    # hcb 121825
Local Char    WCURLOT(GLONLOT)
Local Char    WCURDEM(20)
Local Decimal WCURSEQ
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSH3"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FERME
If clalev([F:QLA]) <> 0 : Filter [QLA] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return
#############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SHQ1]       = [F:ITM]
        Endif
      Endif
    When 3 :
      If PARAM(I) <> "" & dim([M:SHQ1]LOTSEL) > 0
        [M:SHQ1]LOTSEL = PARAM(I)
      Endif
    When 4 :
      If PARAM(I) <> ""
        [M:SHQ1]DEMSEL = PARAM(I)
      Endif
    When 5 :
      If val(PARAM(I)) <> 0
        [M:SHQ1]VCRTYPSEL = val(PARAM(I))+1
      Else
        [M:SHQ1]VCRTYPSEL = 1
      Endif
    When 6 :
      If PARAM(I) <> ""
        [M:SHQ1]VCRNUMSEL = PARAM(I)
      Endif
    When 7 :
      If val(PARAM(I)) <> 0
        [M:SHQ1]VCRLINSEL = val(PARAM(I))
      Endif
    When 8 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I
If clalev([M:CSHQ]) <> 0 & [M:CSHQ]MEMO = "STD"
  [M:SHQ1] = [M:CSHQ]
Endif
Return
############################################################
$LECTURE
NBLU   = 2
If [M:SHQ1]ITMREF = ""
  NBLU = 0
  Return
Endif
Case CHGPAG
  When 1 :
    Gosub TRT_FILTER
    If NBLU <> 0
      nolign = 1
      WINCR  = 1
      Gosub LOA_PAGE
    Endif
  When 2 :
    Gosub LEC_SUI
    If NBLU <> 0
      nolign = 1
      WINCR  = 1
      Gosub LOA_PAGE
    Endif
  When -1 :
    Read [QLAL] Last
    If fstat = 0
      nolign = MAXLIG
      WINCR  = -1
      Gosub LOA_PAGE
    Endif
  When -2 :
    Gosub LEC_PRE
    If NBLU <> 0
      nolign = MAXLIG
      WINCR  =  -1
      Gosub LOA_PAGE
    Endif
Endcase
If [F:QLA]QLYCTLDEM = WFIRDEM &
&  [F:QLA]CRDSEQ    = WFIRSEQ
  RETOUR = 1
Else
  RETOUR = 0
Endif
If [F:QLA]QLYCTLDEM = WLASDEM &
&  [F:QLA]CRDSEQ    = WLASSEQ
  SUITE = 1
Else
  SUITE = 0
Endif
Return
############################################################
$TRT_FILTER
Raz [M:SHQ2]
Gosub LOAD_FILTER
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
Link [QLA] With [STQ]STQ0=[F:QLA]QLYCTLDEM
&                As [QLAL]
&                Where evalue(WFIL)  &
&                  evalue(WFILSPE)
&             Order By Key CLE = ITMREF;QLYCTLDEM;CRDSEQ;QSTNUM




#Filter [QLA] Where evalue(WFIL)  &
#&                  evalue(WFILS) &
#&                  evalue(WFILSPE)
#&             Order By Key CLE = ITMREF;QLYCTLDEM;CRDSEQ;QSTNUM
#            Order By Key QLA1

Raz [F:QLA]
Raz [F:STQ]

Raz WFIRDEM, WFIRSEQ
Raz WLASDEM, WLASSEQ
Raz WCURITM, WCURLOT, WCURDEM, WCURSEQ
Read [QLAL] Last
  If fstat = 0
    WLASDEM = [F:QLA]QLYCTLDEM
    WLASSEQ = [F:QLA]CRDSEQ
   Endif
Read [QLAL] First
  If fstat = 0
    WFIRDEM = [F:QLA]QLYCTLDEM
    WFIRSEQ = [F:QLA]CRDSEQ
  Else
    NBLU = 0
  Endif
Return
############################################################
$LOAD_FILTER
WFIL = "[F:QLA]ITMREF=[M:SHQ1]ITMREF"
If dim([M:SHQ1]LOTSEL) > 0 & [M:SHQ1]LOTSEL <> ""
  WFIL += "&pat([F:STQ]LOT,[M:SHQ1]LOTSEL)"
Endif
If [M:SHQ1]DEMSEL <> ""
  WFIL += "&pat([F:QLA]QLYCTLDEM,[M:SHQ1]DEMSEL)"
Endif
If [M:SHQ1]VCRTYPSEL > 1
  WFIL += "&[F:STQ]VCRTYP=[M:SHQ1]VCRTYPSEL-1"
Endif
If [M:SHQ1]VCRNUMSEL <> ""
  WFIL += "&pat([F:STQ]VCRNUM,[M:SHQ1]VCRNUMSEL)"
Endif
If [M:SHQ1]VCRLINSEL <> 0
  WFIL += "&[F:STQ]VCRLIN=[M:SHQ1]VCRLINSEL"
Endif
Return
############################################################
$LEC_SUI
Read [QLAL] Next
  If fstat
    NBLU = 0
  Endif
# [F:QLA]LOT       = WCURLOT

If [F:QLA]ITMREF    = WCURITM &
&  [F:QLA]QLYCTLDEM = WCURDEM &
&  [F:QLA]CRDSEQ    = WCURSEQ
  Goto LEC_SUI
Endif
Return
############################################################
$LEC_PRE
Read [QLAL] Prev
  If fstat
    NBLU = 0
  Endif
#  [F:QLA]LOT       = WCURLOT

If [F:QLA]ITMREF    = WCURITM &
&  [F:QLA]QLYCTLDEM = WCURDEM &
&  [F:QLA]CRDSEQ    = WCURSEQ
  Goto LEC_PRE
Endif
Return
############################################################
$LOA_PAGE

[M:SHQ2] = [F:QLA]
If [M:SHQ2]TRKSTRDAT = [0/0/0]
  [M:SHQ2]TRKSTRDAT = [F:QLA]IPTDAT
  [M:SHQ2]TRKENDDAT = [F:QLA]IPTDAT
Endif
If [F:QLA]IPTDAT < [M:SHQ2]TRKSTRDAT
  [M:SHQ2]TRKSTRDAT = [F:QLA]IPTDAT
Endif
If [F:QLA]IPTDAT > [M:SHQ2]TRKENDDAT
  [M:SHQ2]TRKENDDAT = [F:QLA]IPTDAT
Endif
[M:SHQ2]MVTSEQ1 = 10000 - [F:QLA]CRDSEQ
#
Read [QLC]QLC0=[F:QLA]QLYCRD
If fstat = 0
  # FGR 24/09/2009 : X3SUIVI58062
  #[M:SHQ2]QLYCRDDES = [F:QLC]QLYCRDDES
  Call LECTEXTRA([M:SHQ2]QLYCRDDES,"QLYCRD","QLYDESAXX",[F:QLC]QLYCRD,"") From ATEXTRA
Endif
# lecture STOQUAL pour recuperer le LOT   (en 140 le LOT à disparu du QLYCRDASW)
#Read [STQ]STQ0=[F:QLA]QLYCTLDEM
#If fstat
#   Raz [F:STQ]
#Else
  [M:SHQ2]LOT    = [F:STQ]LOT
#Endif
# lecture STOLOT pour recuperer le BPSLOT (en 140 le BPSLOT à disparu du QLYCRDASW)
Read [STL]STL0=[F:QLA]ITMREF;[F:STQ]LOT;""
If fstat
   Raz [F:STL]
Else
   [M:SHQ2]BPSLOT = [F:STL]BPSLOT
Endif

#
WCURITM = [F:QLA]ITMREF
#WCURLOT = [F:QLA]LOT
WCURDEM = [F:QLA]QLYCTLDEM
WCURSEQ = [F:QLA]CRDSEQ
#
If WINCR > 0
  Filter [QLA1] Where QLYCTLDEM = [F:QLA]QLYCTLDEM &
&                     CRDSEQ    = [F:QLA]CRDSEQ
&               Order By Key QLA0
Else
  Filter [QLA1] Where QLYCTLDEM = [F:QLA]QLYCTLDEM &
&                     CRDSEQ    = [F:QLA]CRDSEQ
&               Order By Key QLA0 Desc
Endif
For [QLA1]
  If nolign > 0 & nolign <= dim([M:SHQ2]ASW)
    [M:SHQ2] = [F:STQ]
    [M:SHQ2] = [F:QLA1]
    [M:SHQ2]VCRLIN(nolign-1) = [F:STQ]VCRLIN
    Read [QLQ]QLQ0=[F:QLA1]QSTNUM
    If fstat = 0
      Call LECTEXTRA([M:SHQ2]QSTDESAXX(nolign-1),"QLYCRDQST","QSTDESAXX",[F:QLQ]QSTNUM,"") From ATEXTRA  # hcb 57138
    Else
      fstat = 0
      [M:SHQ2]QSTDESAXX(nolign-1) = "?"                                                                  # hcb 57138
    Endif
    nolign += WINCR
    NOL    += WINCR
  Else
    Break
  Endif
Next
Filter [QLA1]
Return
############################################################
Subprog C_LOTSEL(VALEUR)
Variable Char     VALEUR
VALEUR = toupper(VALEUR)
End
############################################################
Subprog C_DEMSEL(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Affzo [M:SHQ1]ITMREF
Affzo [M:SHQ1]LOTSEL
End
############################################################

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"SH3") From SUBGTC

End

