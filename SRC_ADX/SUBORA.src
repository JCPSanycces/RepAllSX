#######################################
Subprog ORGBAN(ORG,SOC,MODPAY,BAN1,BAN2)
Value    Char    ORG ()
Value    Char    SOC ()
Variable Integer MODPAY ()
Variable Char    BAN1 ()
Variable Char    BAN2 ()

If clalev([F:ORB])=0  : Local File ORGBAN    [ORB] : Endif
Raz MODPAY, BAN1, BAN2
If SOC<>""
 Read[F:ORB]ORB0=GCURLEG;ORG;3;SOC
 If !fstat
  MODPAY=[F:ORB]MODPAY
  BAN1=[F:ORB]BANFCY(0)
  BAN2=[F:ORB]BANFCY(1)
  End
 Endif
Endif
Read[F:ORB]ORB0=GCURLEG;ORG;1;""
If !fstat
 MODPAY=[F:ORB]MODPAY
 BAN1=[F:ORB]BANFCY(0)
 BAN2=[F:ORB]BANFCY(1)
 End
Endif
End

