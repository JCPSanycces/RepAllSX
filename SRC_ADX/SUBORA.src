Subprog AS_BANFCY2(VALEUR)
Variable Char    VALEUR()
#JOJAC - 2016-08-15 - X3PEOP-743 - START
#If [M]MODPAY(nolign-1)<>3 : mkstat=1 : Endif
If [M]MODPAY(nolign-1)<>"C" : mkstat=1 : Endif
#JOJAC - 2016-08-15 - X3PEOP-743 - END
End

Subprog C_BANFCY2(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]BANFCY1 (nolign-1)
 #Code banque déjà saisi
 GMESSAGE=mess(99,10703,1)
 mkstat=2 : End
Endif
Call CONTBAN (VALEUR)
If mkstat : End : Endif
End

Subprog CONTBAN (VALEUR)
Value Char VALEUR
If VALEUR="" : End : Endif
Call LECTURE("BAN",[L]VALEUR,"") From CONTOBJ
If dim([F:BAN]ACS)>0 & [F:BAN]ACS<>""
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
Endif
If [M]CPYPAY(nolign-1)<>"" & [M]CPYPAY(nolign-1)<>[F:BAN]CPY
  # Banque/Caisse de la société CPY
  GMESSAGE=mess(1,653,1)-mess(5,117,1)-[F:BAN]CPY : mkstat=2 : End
Endif
If [M]CPYPAY(nolign-1)=""
 Call LECTURE("CPY",[F:BAN]CPY,"") From CONTOBJ
 If [F:CPY]LEG<>GCURLEG
  #Fiche inexistante pour la législation courante
  GMESSAGE=mess(14,10712,1): mkstat=2 : End
 Endif
Endif
End

########################################
Subprog ORGAFFIL (ORG,SITE,EMP,CTR,AFFIL,CTRAT)
Value    Char    ORG ()
Value    Char    SITE ()
Value    Char    EMP ()
Value    Char    CTR ()
Variable Char    AFFIL ()
Variable Char    CTRAT ()
Gosub ORGAFF2
End

#Need it in MATPCA source
########################################
Subprog ORGAFFIL_LEV (ORG,SITE,EMP,CTR,AFFIL,CTRAT,LEVEL)
Value    Char    ORG ()
Value    Char    SITE ()
Value    Char    EMP ()
Value    Char    CTR ()
Variable Char    AFFIL ()
Variable Char    CTRAT ()
Variable Integer LEVEL
Gosub ORGAFF2
LEVEL=[F:ORA]LEV
End

########################################
$ORGAFF2
If clalev([F:ORA])=0 : Local File ORGAFFIL [ORA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
AFFIL = "" : CTRAT = ""
## Recherche au niveau Contrat
If CTR<>""
#LIPET - 2018-08-03 - X3-103478 - START
 # Read[ORA]ORA0=6;"";"";"";"";CTR;GCURLEG;ORG
  Read[ORA]ORA0=6;"";"";"";"";CTR;"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
  If !fstat
   AFFIL = [F:ORA]NUMAFF
   CTRAT = [F:ORA]NUMCTR
  Endif
Endif
## Recherche au niveau Salarié
If AFFIL="" & EMP<>""
#LIPET - 2018-08-03 - X3-103478 - START
 #Read[ORA]ORA0=5;"";"";"";EMP;"";GCURLEG;ORG
 Read[ORA]ORA0=5;"";"";"";EMP;"";"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
 If !fstat
#JOJAC - 2016-08-08 - X3PEOP-858 - START
  #AFFIL = [F:ORA]NUMAFF
  #CTRAT = [F:ORA]NUMCTR
  Gosub SETVAL_ORGAFF2
#JOJAC - 2016-08-08 - X3PEOP-858 - END
 Endif
 ## Recherche au niveau Population/Site du salarié
 If AFFIL="" & SITE<>""
  If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
  #79360
  If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
   ##67516 : Recherche au niveau Population/Société du salarié
   #Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
   Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";"";ORG
&        As [ORK]
&        Where REFNUM=EMP & COD>""
   Read [ORK]POA1 First
   If !fstat
#JOJAC - 2016-08-08 - X3PEOP-858 - START
  #AFFIL = [F:ORA]NUMAFF
  #CTRAT = [F:ORA]NUMCTR
  Gosub SETVAL_ORGAFF2
  #JOJAC - 2016-08-08 - X3PEOP-858 - END
   Endif
  Else # C'est un site
    #Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
    Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";"";"";ORG
&             As [ORK]
&         Where REFNUM=EMP & COD>""
    Read [ORK]POA1 First
    If !fstat
#JOJAC - 2016-08-08 - X3PEOP-858 - START
  #AFFIL = [F:ORA]NUMAFF
  #CTRAT = [F:ORA]NUMCTR
  Gosub SETVAL_ORGAFF2
#JOJAC - 2016-08-08 - X3PEOP-858 - END
    Endif
    #Société du site
    If AFFIL=""
     Read[FCY]FCY0=SITE
     If !fstat
     # Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
      Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";"";ORG
&           As [ORK]
&           Where REFNUM=EMP & COD>""
      Read [ORK]POA1 First
      If !fstat
#JOJAC - 2016-08-08 - X3PEOP-858 - START
  #AFFIL = [F:ORA]NUMAFF
  #CTRAT = [F:ORA]NUMCTR
  Gosub SETVAL_ORGAFF2
#JOJAC - 2016-08-08 - X3PEOP-858 - END
      Endif
     Endif
   Endif
  Endif
 Endif
Endif
If AFFIL=""
 If SITE<>""
  If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
#LIPET - 2018-08-03 - X3-103478 - START
