   Read[ORA]ORA0=4;"";"";SITE;"";"";GCURLEG;ORG
#LIPET - 2018-08-03 - X3-103478 - END
   If !fstat
    OPT = [F:ORA]CODOPT
    POP = [F:ORA]CODPOP
   Endif
   If OPT=""
     Read[FCY]FCY0=SITE
     If !fstat
#LIPET - 2018-08-03 - X3-103478 - START
      #Read[ORA]ORA0=3;"";[F:FCY]LEGCPY;"";"";"";GCURLEG;ORG
      Read[ORA]ORA0=3;"";[F:FCY]LEGCPY;"";"";"";"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
      If !fstat
       OPT = [F:ORA]CODOPT
       POP = [F:ORA]CODPOP
      Endif
     Endif
   Endif
  Endif
 Endif
Endif

#63715 : Recherche au niveau Population/Site sans infos salarié
If OPT="" & SITE<>""
 If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
 #79360
 If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
  #67516 : Recherche au niveau Population/Société sans infos salarié
  #Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
  Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";"";ORG
&        As [ORK]
&        Where COD>""
  Read [ORK]POA1 First
  If !fstat
   OPT = [F:ORA]CODOPT
   POP = [F:ORA]CODPOP
  Endif
 Else # C'est un site
  #Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
  Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";"";ORG
&       As [ORK]
&       Where COD>""
  Read [ORK]POA1 First
  If !fstat
   OPT = [F:ORA]CODOPT
   POP = [F:ORA]CODPOP
  Endif
  #Société du site
  If OPT=""
   Read[FCY]FCY0=SITE
   If !fstat
    #Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
    Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";"";ORG
&         As [ORK]
&         Where REFNUM=EMP & COD>""
    Read [ORK]POA1 First
    If !fstat
     OPT = [F:ORA]CODOPT
     POP = [F:ORA]CODPOP
    Endif
   Endif
  Endif
 Endif
