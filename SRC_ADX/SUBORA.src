#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ORA",GBIDC1,"") From GOBJET
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran ORA0) 17/07/2007 14:46:07 (DBA)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "LIENS"      : Gosub LIENS
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "INIMOD"     : Gosub INIMOD
 When "BB1_NBLIG"  : Gosub BB1_NBLIG
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:ORG]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:ORA0]LEG)>=0 : [M:ORA0]LEG=[F:ORG]LEG: Endif
 GCURLEG=[F:ORG]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:ORA0]LEG)>=0
  GCURLEG=[M:ORA0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return


########################################
$OUVRE
If !clalev([F:HRPOP]) : Local File POPUL   [HRPOP] : Endif
#JOJAC - 2016-08-08 - X3PEOP-858 - START
# US 3730
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
#JOJAC - 2016-08-08 - X3PEOP-858 - END
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

#JOJAC - 2016-08-08 - X3PEOP-858 - START
#US3316
Local Integer NBORB
NBORB=func AFNC.ACTIV('ORB')
#JOJAC - 2016-08-08 - X3PEOP-858 - END

Return

########################################
$FILGAUCHE
FILGAUSUP = "TYP=3 | TYP=5" :#Caisse ou groupe de caisses
Return

########################################
$FILTRE
FILTSUP = "TYP=3 | TYP=5" :#Caisse ou groupe de caisses
Return

########################################
$LIENS
GCURLEG = [F:ORG]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call DISPLAY_HIDE() From SUBORALEG
Gosub CHARGE_ECRAN
Return

########################################
$INIMOD
Gosub SAUVE_ECRAN
Return

########################################
$CHARGE_ECRAN
nolign=1
For [F:ORA]ORA0 Where ORG=[F:ORG]COD & LEG=[F:ORG]LEG
 [M]=[F:ORA]
 [M]POPFCY (nolign-1)=[F:ORA]POP+"|"+[F:ORA]CPY+"|"+[F:ORA]FCY
 nolign+=1
Next
[M]NBLIG=nolign-1
Affzo [M]10

nolign=1


For [F:ORB]ORB0 Where ORG=[F:ORG]COD & LEG=[F:ORG]LEG
#JOJAC - 2016-08-08 - X3PEOP-858 - START
 #US3316
 If nolign>NBORB : Break : Endif
#JOJAC - 2016-08-08 - X3PEOP-858 - END
 [M]LEVPAY(nolign-1)=[F:ORB]LEV
 [M]CPYPAY(nolign-1)=[F:ORB]CPY
 [M]MODPAY(nolign-1)=[F:ORB]MODPAY
 [M]BANFCY1(nolign-1)=[F:ORB]BANFCY(0)
 [M]BANFCY2(nolign-1)=[F:ORB]BANFCY(1)
 nolign+=1
Next
[M]NBLIG2=nolign-1
Affzo [M]20
Return

########################################
$SAUVE_ECRAN
Delete [F:ORA] Where ORG=[M]COD & LEG=GCURLEG
If fstat=1
 GOK =-1 : GLOCK = "$ORGAFFIL" : Return
Endif
For nolign=1 To [M]NBLIG
 [F:ORA]LEV    = [M]LEV(nolign-1)
 [F:ORA]POP    = [M]POP(nolign-1)
 [F:ORA]CPY    = [M]CPY(nolign-1)
 [F:ORA]FCY    = [M]FCY(nolign-1)
 [F:ORA]REFNUM = [M]REFNUM(nolign-1)
 [F:ORA]CTR    = [M]CTR(nolign-1)
 [F:ORA]ORG    = [M]COD
 [F:ORA]LEG    = GCURLEG
 [F:ORA]NUMAFF = [M]NUMAFF(nolign-1)
#JOJAC - 2016-08-08 - X3PEOP-858 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
 #JOJAC - 2016-08-08 - X3PEOP-858 - END
 [F:ORA]NUMCTR = [M]NUMCTR(nolign-1)
 [F:ORA]CODOPT = [M]CODOPT(nolign-1)
 [F:ORA]CODPOP = [M]CODPOP(nolign-1)
##JOJAC - 2016-08-08 - X3PEOP-858 - START
 [F:ORA]ORGCRT = [M]ORGCRT(nolign-1)Endif
#JOJAC - 2016-08-08 - X3PEOP-858 - END

 Write [ORA]
 If fstat<>0
  GOK = 0 : Call FSTA("ORA") From GLOCK
 Endif
Next

Delete [F:ORB] Where ORG=[M]COD & LEG=GCURLEG
If fstat=1
 GOK =-1 : GLOCK = "$ORGBAN" : Return
Endif
For nolign=1 To [M]NBLIG2
 [F:ORB]LEV = [M]LEVPAY(nolign-1)
 [F:ORB]CPY = [M]CPYPAY(nolign-1)
 [F:ORB]ORG    = [M]COD
 [F:ORB]LEG    = GCURLEG
 [F:ORB]MODPAY = [M]MODPAY(nolign-1)
 [F:ORB]BANFCY(0) = [M]BANFCY1(nolign-1)
 [F:ORB]BANFCY(1) = [M]BANFCY2(nolign-1)
 Write [ORB]
 If fstat<>0
  GOK = 0 : Call FSTA("ORB") From GLOCK
 Endif
Next
Return

########################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

Subprog AS_LEV(VALEUR)
Variable Integer VALEUR
# WGA suite ajout de la valeur service dans le menu local
Raz GMENLOC
GMENLOC(7)=1
End

Subprog C_LEV(VALEUR)
Variable Integer VALEUR
# pas 2 fois la valeur dossier...
If VALEUR=1
 Call UNICITE(VALEUR,[M]LEV(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

###Population
Subprog AS_POP(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>2 : mkstat=1 : End : Endif
End

###Population
Subprog C_POP(VALEUR)
Variable Char    VALEUR()
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
MATRI=VALEUR : Raz SITSOC,CTR
Gosub CTRL_ORG
If mkstat
 #Population non valide pour cet organisme
 GMESSAGE=mess(30,10714,1)
 mkstat=2 : End
Endif
End

###Population
Subprog AM_POP(VALEUR)
Variable Char    VALEUR()
#67516
[M]POPFCY(nolign-1)= VALEUR+"|"+[M]CPY(nolign-1)+"|"+[M]FCY(nolign-1)
Read[HRPOP]POP0=VALEUR
[M]LIB=[F:HRPOP]DES
Affzo[M]LIB
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
#67516
If [M]LEV(nolign-1)<>2 & [M]LEV(nolign-1)<>3 : mkstat=1 : End : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
If [M]LEV(nolign-1)=3
 If VALEUR=""
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
 SITSOC=VALEUR : Raz MATRI,CTR
 Gosub CTRL_ORG
 If mkstat
  #Société non valide pour cet organisme
  GMESSAGE=mess(18,10714,1)
  mkstat=2 : End
 Endif
Endif
# pas 2 fois le même couple société+population
If [M]LEV(nolign-1)=2 | [M]LEV(nolign-1)=3
 ZONE=[M]POP(nolign-1)+"|"+VALEUR+"|"+[M]FCY(nolign-1)
 Call UNICITE(ZONE,[M]POPFCY(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
#67516
[M]POPFCY(nolign-1)= [M]POP(nolign-1)+"|"+VALEUR+"|"+[M]FCY(nolign-1)
Read[CPY]CPY0=VALEUR
[M]LIB=[F:CPY]CPYNAM
Affzo[M]LIB
End

###Population
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
#67516
If ([M]LEV(nolign-1)<>2 | ([M]LEV(nolign-1)=2 & [M]CPY(nolign-1)<>'')) & [M]LEV(nolign-1)<>4 : mkstat=1 : End : Endif
End

###Population
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Local Char ZONE (50)
Local Integer I
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
If [M]LEV(nolign-1)=4
 SITSOC=VALEUR : Raz MATRI,CTR
 Gosub CTRL_ORG
 If mkstat
  #Site non valide pour cet organisme
  GMESSAGE=mess(19,10714,1)
  mkstat=2 : End
 Endif
Endif
# pas 2 fois le même couple site+population
If [M]LEV(nolign-1)=2 | [M]LEV(nolign-1)=4
 ZONE=[M]POP(nolign-1)+"|"+[M]CPY(nolign-1)+"|"+VALEUR
 Call UNICITE(ZONE,[M]POPFCY(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
###Population
#67516
[M]POPFCY(nolign-1)=[M]POP(nolign-1)+"|"+[M]CPY(nolign-1)+"|"+VALEUR
Read[FCY]FCY0=VALEUR
[M]LIB=[F:FCY]FCYNAM
Affzo[M]LIB
End

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>5 : mkstat=1 : End : Endif
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
MATRI=VALEUR : SITSOC=[F:ID]FCY : Raz CTR
Gosub CTRL_ORG
If mkstat
 #Salarié non valide pour cet organisme
 GMESSAGE=mess(26,10714,1)
 mkstat=2 : End
Endif
# pas 2 fois la même valeur salarié...
If [M]LEV(nolign-1)=5
 Call UNICITE(VALEUR,[M]REFNUM(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Read[ID]ID0=VALEUR
[M]LIB=[F:ID]NAM-[F:ID]SRN
Affzo[M]LIB
End

###Population
Subprog AS_NBLIG
Case [M]LEV(nolign-1)
 When 2 : Call AM_POP([M]POP(nolign-1))
 When 3 : Call AM_CPY([M]CPY(nolign-1))
 When 4 : Call AM_FCY([M]FCY(nolign-1))
 When 5 : Call AM_REFNUM([M]REFNUM(nolign-1))
 When Default : Raz[M]LIB : Affzo[M]LIB
Endcase
End

Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
If [M]LEV(nolign-1)<>6 : mkstat=1 : End : Endif
End

Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char MATRI (GLONEML)
Local Char SITSOC (10)
Local Char CTR (GLONHRCTR)
CTR=VALEUR : MATRI=[F:HRCTR]REFNUM : SITSOC=[F:HRCTR]ETRFCY
Gosub CTRL_ORG
If mkstat
 #Contrat non valide pour cet organisme
 GMESSAGE=mess(27,10714,1)
 mkstat=2 : End
Endif
# pas 2 fois la même valeur salarié...
If [M]LEV(nolign-1)=6
 Call UNICITE(VALEUR,[M]CTR(0..[M]NBLIG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()
#72068
#Read[HRCTR]CTR0=VALEUR
Filter [HRCTR] Where CTRNUM=VALEUR
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#
If !fstat
 Read[ID]ID0=[F:HRCTR]REFNUM
 [M]LIB=[F:ID]NAM-[F:ID]SRN
Else
 Raz [M]LIB
Endif
Affzo[M]LIB
End

