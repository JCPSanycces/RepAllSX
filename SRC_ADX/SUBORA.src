########################################
Subprog ORGPRV (ORG,SITE,EMP,CTR,OPT,POP)
Value    Char    ORG ()
Value    Char    SITE ()
Value    Char    EMP ()
Value    Char    CTR ()
Variable Char    OPT ()
Variable Char    POP ()
Gosub ORGPRV2
End

########################################
$ORGPRV2
If clalev([F:ORA])=0 : Local File ORGAFFIL [ORA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
OPT = "" : POP = ""
## Recherche au niveau Contrat
If CTR<>""
#LIPET - 2018-08-03 - X3-103478 - START
  #Read[ORA]ORA0=6;"";"";"";"";CTR;GCURLEG;ORG
  Read[ORA]ORA0=6;"";"";"";"";CTR;"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
  If !fstat
   OPT = [F:ORA]CODOPT
   POP = [F:ORA]CODPOP
  Endif
Endif
## Recherche au niveau Salarié
If OPT="" & EMP<>""
#LIPET - 2018-08-03 - X3-103478 - START
  #Read[ORA]ORA0=5;"";"";"";EMP;"";GCURLEG;ORG
 Read[ORA]ORA0=5;"";"";"";EMP;"";"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
 If !fstat
  OPT = [F:ORA]CODOPT
  POP = [F:ORA]CODPOP
 Endif
 ## Recherche au niveau Population/Site du salarié
 If OPT="" & SITE<>""
  If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
  #79360
  If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
   ##67516 : Recherche au niveau Population/Société du salarié
   #Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
   Link [HRPOA] With [ORA]ORA0~=2;COD;SITE;"";"";"";"";ORG
&       As [ORK]
&       Where REFNUM=EMP & COD>""
   Read [ORK]POA1 First
   If !fstat
    OPT = [F:ORA]CODOPT
    POP = [F:ORA]CODPOP
   Endif
  Else # C'est un site
  #Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
   Link [HRPOA] With [ORA]ORA0~=2;COD;"";SITE;"";"";"";ORG
&        As [ORK]
&        Where REFNUM=EMP & COD>""
   Read [ORK]POA1 First
   If !fstat
    OPT = [F:ORA]CODOPT
    POP = [F:ORA]CODPOP
   Endif
   #Société du site
   If OPT=""
    Read[FCY]FCY0=SITE
    If !fstat
     #Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";GCURLEG;ORG : #LIPET - 2018-08-03 - X3-103478
     Link [HRPOA] With [ORA]ORA0~=2;COD;[F:FCY]LEGCPY;"";"";"";"";ORG
&          As [ORK]
&          Where REFNUM=EMP & COD>""
     Read [ORK]POA1 First
     If !fstat
      OPT = [F:ORA]CODOPT
      POP = [F:ORA]CODPOP
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
If OPT=""
 If SITE<>""
  If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
#LIPET - 2018-08-03 - X3-103478 - START
   #Read[ORA]ORA0=3;"";SITE;"";"";"";GCURLEG;ORG
   Read[ORA]ORA0=3;"";SITE;"";"";"";"";ORG
#LIPET - 2018-08-03 - X3-103478 - END
   If !fstat
    OPT = [F:ORA]CODOPT
    POP = [F:ORA]CODPOP
