#L'organisme doit être défini, peu importe dans quelle caisse...
$CTRL_ORG
Local Char ORGCOURANT (GLONORG)
Local Integer I
For I=0 To len(mess(0,10329,1))-1
 Call ORGANISME ([L]MATRI,[L]SITSOC,[L]CTR,[L]ORGCOURANT,I) From SUBORG
 If ORGCOURANT<>[M]COD
  mkstat=2
 Else
  mkstat=0 : Break
 Endif
Next
Return

######################
Subprog IB_NBLIG
If [V]GREP <> "" : Raz [V]GBOUT1 : Endif
If [M:ORA0]LEV(nolign-1) <> 2 : Raz [V]GBOUT1 : Endif
End
######################

$BB1_NBLIG
# Rafraichissement de l'écran en retour de TRTPCACTR
# Repositionnement du contexte pour être sur du coup, $CHARGE_ECRAN se base sur [F:ORG]
Local Char S_COD([V]GLONORG)
[L]S_COD = [M:ORA0]COD
Raz [M:ORA0]
[M:ORA0]COD = [L]S_COD
Read [F:ORG]ORG0 = GCURLEG;[M:ORA0]COD
Gosub CHARGE_ECRAN
Return

