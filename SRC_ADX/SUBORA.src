Subprog AS_ORGCRT(VALEUR)
Variable Char    VALEUR()
If !func AFNC.ACTIV("KFR") | ([M]TYPIRC<>1 & [M]TYPIRC<>3 & [M]TYPIRC<>11 ) | !find([M]LEV(nolign-1),2,5,6)
  mkstat=1
  End
Endif
End

