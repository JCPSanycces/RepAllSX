Variable Integer VALEUR
GMENLOC(2)=1
For I=4 To len(mess(0,10506,1))
 GMENLOC(I)=1
Next
End

Subprog C_LEVPAY(VALEUR)
Variable Integer VALEUR
# pas 2 fois la valeur dossier...
If VALEUR=1
 Call UNICITE(VALEUR,[M]LEVPAY(0..[M]NBLIG2-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

