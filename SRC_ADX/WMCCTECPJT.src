If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SSITE From WMC1TECPJT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SSITE From WMC1TECPJT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SSOCIETE From WMC1TECPJT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SSOCIETE From WMC1TECPJT : Gosub TESTALLSTAT :  Endif
