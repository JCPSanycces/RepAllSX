####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0TECPJT
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_IMODULE From WMC1TECPJT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_IMODULE From WMC1TECPJT : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SFROM From WMC1TECPJT : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SFROM From WMC1TECPJT : Gosub TESTALLSTAT :  Endif
