#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la saisie des plans d'entretien             Module CRM        25 avril 2004
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Code contrat de service
#PARAM(2) = Flag modèle de contrat de service
Global Integer GPREMATNOL
Global Integer GINSERT

  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:CCA]) : Local File CONTCARE [CCA] : Endif
  GPREMATNOL = 0
  GINSERT = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:CONI]DIRTYFLG Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CONI]CONNUM = PARAM(1)
  [M:CONI]TPL = val(PARAM(2))
  If [M:CONI]TPL < 1 Then
    [M:CONI]TPL = 1
  Endif
  If [M:CONI]TPL > 2 Then
    [M:CONI]TPL = 2
  Endif
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  Read [TCA]TCA0=12
  If fstat Then
    GERR = 1
    GMESSAGE = mess(64,199,1)
    FIN = 1
    Return
  Endif
  [M:CONI]CCAMANCOU = [F:TCA]MANCOU(9)
  [M:CONI]CCACPT = [F:TCA]CODNUM(9)
  Call LOADSET
  Affzo [M:CONI]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:CONI]
  Kill GPREMATNOL
  Kill GINSERT
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  [M:CONI]DIRTYFLG = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSAVE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ZI
Local Integer SVGMANCOU

  Call DEBTRANS From GLOCK
  Trbegin [CCA]
  Delete [CCA] Where [F:CCA]CONNUM = [M:CONI]CONNUM and [F:CCA]TPL = [M:CONI]TPL
  If fstat Then
    #Erreur lors de l'enregistrement du plan d'entretien.
    GMESSAGE = mess(150,182,1)
    GERR = 1
    Rollback
  Else
    Commit
  Endif
  If GERR Then
    Return
  Endif
  #Enregistrement du plan
  SVGMANCOU = GMANCOU
  GMANCOU = [M:CONI]CCAMANCOU
  Call DEBTRANS From GLOCK
  Trbegin [CCA]
  For ZI = 0 To ([M:CONI]NBSET-1)
    If [M:CONI]SET(ZI) <> "" Then
      If [M:CONI]CCANUM(ZI) = "" Then
        #Calcul d'une nouvelle clé
        If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", "", [M:CONI]CCACPT, date$, "", [M:CONI]CCANUM(ZI), IERRINF, ICHAPTER, IBRETOUR) = 1 Then
          If IBRETOUR = 0 Then
            # problème lors de la récupération du compteur
            GERR = 1
            GMESSAGE = mess(IERRINF,ICHAPTER,1)
            Rollback
            Break
          Endif
        Endif
        [F:CCA]CREUSR = GUSER
        [F:CCA]CREDAT = date$
      Else
        [F:CCA]CREUSR = [M:CONI]CREUSR(ZI)
        [F:CCA]CREDAT = [M:CONI]CREDAT(ZI)
      Endif
      [F:CCA]CONNUM = [M:CONI]CONNUM
      [F:CCA]TPL = [M:CONI]TPL
      [F:CCA]CCANUM = [M:CONI]CCANUM(ZI)
      [F:CCA]SET = [M:CONI]SET(ZI)
      [F:CCA]FRYTYP = [M:CONI]FRYTYP(ZI)
      [F:CCA]INVTYP = [M:CONI]INVTYP(ZI)
      [F:CCA]LASSREDAT = [M:CONI]LASSREDAT(ZI)
      [F:CCA]CNDTAB = [M:CONI]CNDTAB(ZI)
      [F:CCA]CNDFLT = [M:CONI]CNDFLT(ZI)
      [F:CCA]CND = [M:CONI]CND(ZI)
      [F:CCA]FRY = [M:CONI]FRY(ZI)
      [F:CCA]FRYBAS = [M:CONI]FRYBAS(ZI)
      [F:CCA]APE = [M:CONI]APE(ZI)
      [F:CCA]UPDUSR = GUSER
      [F:CCA]UPDDAT = date$
      Write [CCA]
      If fstat Then
        #Erreur lors de l'enregistrement du plan d'entretien.
        GMESSAGE = mess(150,182,1)
        Rollback
        Break
      Endif
    Endif
  Next
  GMANCOU = SVGMANCOU
  If !GERR Then
    Commit
  Endif
  Raz [M:CONI]DIRTYFLG
Return


##########################################################################################################
# Chargement du tableau des plan d'entretien
#########################################################################
Subprog LOADSET
Local Integer IB

  Raz [M:CONI]NBSET
  Raz [M:CONI]NBSETSEL
  Raz [M:CONI]SET
  Raz [M:CONI]FRYTYP
  Raz [M:CONI]INVTYP
  Raz [M:CONI]LASSREDAT
  Raz [M:CONI]CNDTAB
  Raz [M:CONI]CNDFLT
  Raz [M:CONI]CND
  Raz [M:CONI]FRY
  Raz [M:CONI]FRYBAS
  Raz [M:CONI]APE
  Raz [M:CONI]CCANUM
  Raz [M:CONI]CREUSR
  Raz [M:CONI]CREDAT
  IB = 0
  Filter [CCA] Where [F:CCA]CONNUM = [M:CONI]CONNUM and [F:CCA]TPL = [M:CONI]TPL Order By [F:CCA]CCANUM Asc
  For [CCA]
    If IB >= dim([M:CONI]SET)-1 Then
      Break
    Endif
    If IB = 0 Then
      [M:CONI]NBSETSEL(IB) = "->"
    Else
      [M:CONI]NBSETSEL(IB) = ""
    Endif
    [M:CONI]SET(IB) = [F:CCA]SET
    [M:CONI]FRYTYP(IB) = [F:CCA]FRYTYP
    [M:CONI]INVTYP(IB) = [F:CCA]INVTYP
    [M:CONI]LASSREDAT(IB) = [F:CCA]LASSREDAT
    [M:CONI]CNDTAB(IB) = [F:CCA]CNDTAB
    [M:CONI]CNDFLT(IB) = [F:CCA]CNDFLT
    [M:CONI]CND(IB) = [F:CCA]CND
    [M:CONI]FRY(IB) = [F:CCA]FRY
    [M:CONI]FRYBAS(IB) = [F:CCA]FRYBAS
    [M:CONI]APE(IB) = [F:CCA]APE
    [M:CONI]CCANUM(IB) = [F:CCA]CCANUM
    [M:CONI]CREUSR(IB) = [F:CCA]CREUSR
    [M:CONI]CREDAT(IB) = [F:CCA]CREDAT
    IB += 1
  Next
  [M:CONI]NBSET = IB
  Filter [CCA]
  Call LOADMASK(0)
End

##########################################################################################################
# Chargement du masque de saisie des caractéristique d'un plan d'entretien
###########################################################
Subprog LOADMASK(INOL)
Value Integer INOL

  Raz [M:CONI]CNDTABX
  Raz [M:CONI]CNDFLTX
  Raz [M:CONI]CNDX
  Raz [M:CONI]FRYX
  Raz [M:CONI]FRYBASX
  Raz [M:CONI]APEX
  [M:CONI]CNDTABX = [M:CONI]CNDTAB(INOL)
  [M:CONI]CNDFLTX = [M:CONI]CNDFLT(INOL)
  [M:CONI]CNDX = [M:CONI]CND(INOL)
  [M:CONI]FRYX = [M:CONI]FRY(INOL)
  [M:CONI]FRYBASX = [M:CONI]FRYBAS(INOL)
  [M:CONI]APEX = [M:CONI]APE(INOL)
End

##########################################################################################################
# Enregistrement du masque de saisie des caractéristique d'un plan d'entretien
###########################################################
Subprog SAVEMASK(INOL)
Value Integer INOL

  [M:CONI]CNDTAB(INOL) = [M:CONI]CNDTABX
  [M:CONI]CNDFLT(INOL) = [M:CONI]CNDFLTX
  [M:CONI]CND(INOL) = [M:CONI]CNDX
  [M:CONI]FRY(INOL) = [M:CONI]FRYX
  [M:CONI]FRYBAS(INOL) = [M:CONI]FRYBASX
  [M:CONI]APE(INOL) = [M:CONI]APEX
End

##########################################################################################################
# Contrôle du changement de ligne
#####################################################################################
Subprog GESNBSET(INOL)
Value Integer INOL

  If INOL >= dim([M:CONI]SET)-1 Then
    End
  Endif
  Call SAVEMASK(GPREMATNOL)
  Call LOADMASK(INOL)
  GPREMATNOL = INOL
End

##########################################################################################################
# Annulation de tous les plans d'entretiens pour un contrat.
############################################################
Subprog RAZPCARE(SZOBJTYP, SZCONNUM)
Value Char SZOBJTYP
Value Char SZCONNUM

Local Integer IBDEBTRANSFLG

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCA]
  Endif
  Delete [CCA] Where [F:CCA]CONNUM = SZCONNUM and [F:CCA]TPL <> 2
  If fstat Then
    GOK = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
End
