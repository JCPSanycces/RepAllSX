#<AdxTL>@(#)1.0.0.0 $Revision$
###############################################################################################
# UTIACH27                                                                  Module ACHAT      #
#                                                                             24/03/2011      #
# Concerne le bug 72056 :                                                                     #
# Lors du passage V6.0 à V6.1, les chps STRDAT ENDDAT sur PINVOICED n'ont pas été initialisés #
#                                                                                             #
# But de l'utilitaire :                                                                       #
#     Initialiser STRDAT ENDDAT de PINVOICED à partir de STRDATSVC ENDDATSVC de PINVOICE      #
#                                                                                             #
###############################################################################################


Call MAJ_UTIACH27
End


Subprog MAJ_UTIACH27
Local Char DOSSIER(30)
DOSSIER=nomap
#--- Issue 108760 by TS
#Call SAIDOS(DOSSIER,"UTIACH27 - Purchase invoice Process : Update PINVOICED") From SAIDOS
Call SAIDOSHIS(DOSSIER,"UTIACH27 - Purchase invoice Process : Update PINVOICED") From SAIDOSHIS
#---
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH27 - Purchase invoice Process : Update PINVOICED") From LECFIC
  Call EXE_UTIACH27(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH27(DOSSIER)
Value Char    DOSSIER
#-----
Call ECR_TIME("UTIACH27 : Start folder's process"-DOSSIER) From DOSSUB

#----- Chargement globale GMAXUPDTRS -----#
If dim([V]GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]

#----- Début du traitement -----#
Gosub TRT_PIH    : # Traitement des factures
#----- Fin du traitement -----#

$FIN_UTIACH27
Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
Call ECR_TIME("UTIACH27 : End folder's process"-DOSSIER) From DOSSUB
End


#----------------------------------------------------------------#
#   Initialisation champs dans les factures                      #
# -------------------------------------------------------------- #
# Table PINVOICED   - Lignes factures                            #
#   STRDAT         Date début prestation                         #
#   ENDDAT         Date fin   prestation                         #
#----------------------------------------------------------------#
$TRT_PIH
If filinfo(filpath("FIL","PINVOICE","fde", DOSSIER),0) < 0 : Return : Endif
If filinfo(filpath("FIL","PINVOICED","fde",DOSSIER),0) < 0 : Return : Endif
Call ECR_TIME("UTIACH27 : Purchase Invoice Process : Update PINVOICED") From DOSSUB
Local File =DOSSIER+".PINVOICE"    [PIH]
Local File =DOSSIER+".PINVOICED"   [PID]

Local Shortint STOP
Local Integer  COMPTEUR, NBENR
Local Char     CLE1(GLONPIH), CRITERE(100), CRITERE1(100), CRITERE2(100)

CRITERE1 = '([F:PIH]STRDATSVC<>[0/0/0] | [F:PIH]ENDDATSVC<>[0/0/0])'
CRITERE2 = '([F:PID]STRDAT=[0/0/0] | [F:PID]ENDDAT=[0/0/0])'

Link [PID] With [PIH]PIH0~=[PID]NUM As [KPID]

$B_TRT_PIH
If  STOP=1
    CRITERE = '[F:PIH]NUM>"'+CLE1+'"'
    STOP = 0
Else
    CRITERE = "1=1"
Endif
# Pour test
# Issue 76405 - 2011-09-20 by VPO : supp du critere
#CRITERE = 'find(NUM,"FAF1103ASN00014","FAF1103ASN00015","FAF1103ASN00016")'

Raz COMPTEUR

Trbegin [KPID]
  For [KPID] PID0 Where evalue(CRITERE) & evalue(CRITERE1) & evalue(CRITERE2)

    If [F:PID]ENDDAT=[0/0/0] [F:PID]ENDDAT=[F:PIH]ENDDATSVC Endif
    If [F:PID]STRDAT=[0/0/0] [F:PID]STRDAT=[F:PIH]STRDATSVC Endif
    Rewrite [PID]
    If fstat
        Call ECR_TRACE("File PINVOICED"-[F:PID]NUM-num$([F:PID]PIDLIN)+", Error ="-num$(fstat),1) From GESECRAN
    Endif
    NBENR+=1 : COMPTEUR+=1

    If COMPTEUR>GMAXUPDTRS CLE1=[F:PIH]NUM : STOP=1 : Break : Endif
  Next
Commit
If STOP Goto B_TRT_PIH : Endif

Close Local File [PIH]
Close Local File [PID]

Call ECR_TIME("UTIACH27 : Purchase Invoice Process : Ended :"+"("-num$(NBENR)-")") From DOSSUB
Return


Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=DOSSIER : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(DOSSIER)=0 : End : Endif
#---
If [F:ADS]MODULE(5)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","PINVOICED","fde",DOSSIER),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(DOSSIER,"PINVOICED") : End : Endif                  : # For Archive folder
  #---
  Call ECR_TRACE("UTIACH27 - Purchase invoice Process : Update PINVOICED",0) From GESECRAN
  Call EXE_UTIACH27(DOSSIER)
Endif
#-----
End



#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  #--- Issue 108760 by TS
  If filinfo(filpath("FIL","PINVOICED","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
  If func DOSVUE.ISVIEW(APPLI,"PINVOICED") : End : Endif                  : # For Archive folder
  #---
  Call EXE_UTIACH27(APPLI)
Endif
End

