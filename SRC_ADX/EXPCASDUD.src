#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################################
#
# -- Interface V5 --
#
#     Sage X3 Entreprise
#
#     Gestion de la trésorerie et des flux financiers
#
#*X3-104535 MWA  Parameters linked to activity code (04.09.2018)

##################################################################################################
#
#  Code Activité CASIN
#
#    Paramètre EXPCASDUD  : Export tréso Sage - Echéances
#    Paramètre EXPCASPAY  : Export tréso Sage - Règlements
#    Paramètre CASTREGDUD : Code statut  - Echéances
#
#
##################################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Local Integer TST
Call TRAITE_CHAR(VALEUR,PARAM,"","EXPCASDUD","EXPCASDUD",4,"") From GTRAITE
End

######################################################################
$ACTION
Case ACTION

 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE

 When "DEBUT"       : Gosub DEBUT

 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0

 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
Endcase
Return

######################################################################
$INIT
$OUVRE_BATCH
If !clalev([M:CAD]) : Local Mask EXPCASDUD [CAD] : Endif

# Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SFRPT")
 [M]LIBTREG=""
Elsif func AFNC.ACTIV("T1000")
 [M]LIBTREG=mess(19,173,1)  # Type de mouvement
Else
 [M]LIBTREG=mess(18,173,1)  # Statut
Endif
Return

$DEBUT
If GCONSDIA : Return : Endif
Raz [M:CAD]
Call LECMEMO("STD","[M:CAD]","cas") From GMEMO
#-- Recherche du répertoire
Local Char NOMFIC(GDIMFIC)
[M]TYPEXP=2
If [M]VOLFIL="" & !GBATCH
 Local Integer LCASIN : # X3-104535
 LCASIN = func AFNC.ACTIV("CASIN")
 If LCASIN = G_OUI
  Call PARAMUTIL("EXPCASDUD",NOMFIC,"","") From SUBAUS
 Endif : # X3-104535
 If NOMFIC<>"" & left$(NOMFIC,1)="["
  [M]VOLFIL = NOMFIC
 Else
  [M]VOLFIL = "["+GDIRCASH+"]/"+nomap+".cas"
 Endif
Endif
Actzo [M]VOLFIL

#-- Recherche code staut
If [M]TREG=""
 Local Integer LCASIN : # X3-104535
 LCASIN = func AFNC.ACTIV("CASIN")
 If LCASIN = G_OUI
 Call PARAM("","CASTREGDUD",[M]TREG) From ADOVAL
 Endif : # X3-104535
Endif

# Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SFRPT")
  Effzo [M]TREG : Grizo [M]TREG
Elsif [M]TREG=""
 # Paramètre non renseigné
 Call ERREUR("CASTREGDUD : "-mess(136,199,1)) From GESECRAN
 FIN = 1 : GOK=0
Endif
Return

######################################################################
$CONTROLE
If GOK=0 : FIN=1 : Return : Endif
TRA = 0 : TMP = 1
Return

######################################################################
$EXEC

# Ouverture des fichiers
If !clalev([F:AGC]) : Local File AGRPCPY    [AGC] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY    [AGF] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP   [FGR] : Endif
If !clalev([F:GCU]) : Local File GRPCUR     [GCU] : Endif
If !clalev([F:GSC]) : Local File GRPSAC     [GSC] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif

#--- Paramètrage des zones
If !clalev([F:TFC]) : Local File TABFILCASH [TFC] : Endif
If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:DAA]) : Local File GACCENTRYA [DAA] : Endif
If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev([F:PIH]) : Local File PINVOICE   [PIH] : Endif
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

If GMODU(5)=2 & !clalev([F:SIV]) : Local File SINVOICEV [SIV] : Endif
If GMODU(6)=2 & !clalev([F:PIV]) : Local File PINVOICEV [PIV] : Endif

# Variables pour le filtre standard
Local Char   FILTRE(250), CRITSPE(250)
Local Integer IFILT

# Variables totaux
Local Integer NBCUR
NBCUR=max(1,nbrecord([TCU]))
Local Decimal TOTCUR(1..NBCUR)
Local Char    LIBCUR(GLONCUR)(1..NBCUR)

# Variables Trace
Local Char SVGTIME  : SVGTIME=time$
# Variables diverses
Local Char    EXPCUR(GLONCUR), EXPSNS(1), BEF_SEP(16), AFT_SEP(16)
Local Decimal AMT, EXPAMT
Local Integer LIGNE
Local Char    WCPTA(128),WCDC(128),WDESCR(128),WCODRIF(128),WNASS(128),WTRANS(128), WREFXRT(128), WBUDG(128)

# Initialisation des variables de fichiers
adxifs = ""                      # adxifs, séparateur de champ
adxirs = chr$(13)+chr$(10)       # adxirs, séparateur d'enregistrement
adxium = GUTF8                   # adxium, mode de codage. (50=Fichier ASCII

# Variables et initialisation pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT
If [M]TYPEXP=1 : # Client
 Call SET_FICNAM([M]FIC,[L]FICDON,URL) From ORDSYS
Else
 [L]FICDON = [M]FIC
Endif

# EMERAUDE - Feature MULTILEG- Requirement 71216
Local Char    FILT_GTE(250)(1..5)
Local Integer GFILT

Local Integer NBTYP
Filter [GTE] Where DUDCASFLG = 2
NBTYP = rowcount([F:GTE])
Filter [GTE]
Local Char    TTYP(GLONGTE)(1..NBTYP)

##################
Openo [L]FICDON,0
Gosub FILTRE

Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif

#Link [DUD] With [GTE]GTE0=[F:DUD]TYP
#&     As [LNK]
#&     Order By Key CLE=CUR;CPY;TYP;NUM;LIG;DUDLIG
#Filter [LNK] Where evalue(FILTRE)

Filter [DUD] Where evalue(FILTRE) & evalue([L]CRITSPE) Order By Key CLE=CPY;CUR;TYP;NUM;LIG;DUDLIG

Raz LIGNE,NBCUR
For [DUD]CLE(1)
 Gosub LEC_GTE
 For [DUD]CLE(2)

  # Recherche du code ISO de la devise
  Raz EXPCUR
  Read [TCU]TCU0 =[F:DUD]CUR
  If !fstat
   If [F:TCU]ISOCOD<>""
    EXPCUR=[F:TCU]ISOCOD
   Else
    EXPCUR=[F:TCU]CUR
   Endif
  Endif

  # Sauvegarde des totaux par devises
  NBCUR+=1
  LIBCUR(NBCUR) = EXPCUR

  For [DUD]CLE(3)
   If evalue(FILT_GTE)
    For [DUD]CLE
     LIGNE += 1
     TOTCUR(NBCUR)+=(arr([F:DUD]AMTCUR-[F:DUD]PAYCUR,0.01))

     If func AFNC.ACTIV("SFRPT")
      # Recherche du sens de l'échéance
      If [F:DUD]SNS>0
       If [F:DUD]AMTCUR>0 : EXPSNS = "C" : Else EXPSNS = "D" : Endif
      Else
       If [F:DUD]AMTCUR>0 : EXPSNS = "D" : Else EXPSNS = "C" : Endif
      Endif

      # Arrondi
      AMT = arr([F:DUD]AMTCUR-[F:DUD]PAYCUR,[F:TCU]CURRND)
      If fix(AMT)=AMT
       EXPAMT=val(sum(num$(abs(AMT)),string$([F:TCU]DECNBR,"0")))
      Else
       BEF_SEP = left$(num$(AMT),len(num$(fix(AMT))))
       AFT_SEP = right$(num$(AMT),len(BEF_SEP)+2)
       If len(AFT_SEP)<[F:TCU]DECNBR
        AFT_SEP = sum(num$(AFT_SEP),string$([F:TCU]DECNBR-len(AFT_SEP),"0"))
       Endif
       EXPAMT  = val(BEF_SEP+AFT_SEP)
      Endif
     Else
      # Recherche du sens de l'échéance
      If [F:DUD]SNS>0
       If [F:DUD]AMTCUR>0 : EXPSNS = "R" : Else EXPSNS = "D" : Endif
      Else
       If [F:DUD]AMTCUR>0 : EXPSNS = "D" : Else EXPSNS = "R" : Endif
      Endif

      # Arrondi
      EXPAMT=abs([F:DUD]AMTCUR-[F:DUD]PAYCUR)

     Endif

     # Lignes
     Wrseq "FIC";                                                         : # 1) BANCA     : Banque
     Wrseq format$("K:5X",[F:DUD]CPY);                                    : # 2) SOCIETA   : Société
     Wrseq format$("K:3X",EXPCUR);                                        : # 3) CONTO     : Compte
     Wrseq EXPSNS+format$("K:3X",[F:DUD]PAM);                             : # 4) CAUSALE   : Code support
     Wrseq format$("N:16F",arr(EXPAMT,0.01));                             : # 5) IMPORTO   : Montant devise compte    #"N:13.2"
     Wrseq format$("K:3X",EXPCUR);                                        : # 6) DIVISA    : Devise opération
     Wrseq format$("D:DDMMYYYY",[F:DUD]DUDDAT);                           : # 7) DOPE      : Date d'Opération

     # Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
     If !func AFNC.ACTIV("SFRPT")
      Wrseq format$("K:2X",[M]TREG);                                       : # 8) TREG      : Statut
     Endif

     # Zone paramètrable
     Raz WCPTA,WCDC,WDESCR,WCODRIF,WNASS,WTRANS,WREFXRT,WBUDG
     Read [HAE]HAE0 = [F:DUD]TYP;[F:DUD]NUM
     Read [DAE]DAE2 = [F:DUD]ACCNUM
     Read [DAA]DAA0 = [F:DUD]TYP;[F:DUD]NUM;[F:DUD]LIG;1
     If fstat : Raz [F:DAA] : Endif
     Case [F:HAE]ORIMOD
      When 3 :
       Read [BPC]BPC0=[F:DUD]BPR
       If fstat : Raz [BPC] : Endif
       Read [SIH]SIH0=[F:DUD]NUM
       If !fstat & GMODU(5)=2
        Read [SIV]SIV0=[F:DUD]NUM
        If fstat : Raz [SIV] : Endif
       Else
        Read [BPS]BPS0=[F:DUD]BPR
        If fstat : Raz [BPS] : Endif
        Read [PIH]PIH0=[F:DUD]NUM
        If !fstat & GMODU(6)=2
         Read [PIV]PIV0=[F:DUD]NUM
         If fstat : Raz [PIV] : Endif
        Endif
       Endif
      When 5 :
       Read [BPC]BPC0=[F:DUD]BPR
       If fstat : Raz [BPC] : Endif
       Read [SIH]SIH0=[F:DUD]NUM
       If fstat : Raz [SIH] : Endif
       If GMODU(5)=2
        Read [SIV]SIV0=[F:DUD]NUM
        If fstat : Raz [SIV] : Endif
       Endif
      When 6 :
       Read [BPS]BPS0=[F:DUD]BPR
       If fstat : Raz [BPS] : Endif
       Read [PIH]PIH0=[F:DUD]NUM
       If fstat : Raz [PIH] : Endif
       If GMODU(6)=2
        Read [PIV]PIV0=[F:DUD]NUM
        If fstat : Raz [PIV] : Endif
       Endif
     Endcase
     Read [BPR]BPR0=[F:DUD]BPR

     # Element paramétré pour alimenter les zones du fichier des flux du règlements

     # Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
     If func AFNC.ACTIV("SFRPT")
      Filter [TFC] Where MODULE=[F:HAE]ORIMOD and CODPAR=[F:DUD]TYP
      Onerrgo ERR
      For [TFC]
       Case [TFC]CODCAS
         When "DESCR"  : WDESCR  = evalue([F:TFC]CLCFOR)
         When "REFXRT" : WREFXRT = evalue([F:TFC]CLCFOR)
       Endcase
      Next
      Onerrgo

      Wrseq format$("K:32X",WDESCR);         : # 12) DESCR    : Description
      Wrseq format$("K:16X",WREFXRT);        : # 13) REFXRT   : Référence
      Wrseq

     Elsif func AFNC.ACTIV("T1000")
      Filter [TFC] Where MODULE=[F:HAE]ORIMOD and CODPAR=[F:DUD]TYP
      Onerrgo ERR
      For [TFC]
       Case [TFC]CODCAS
         When "TRANS"  : WTRANS  = evalue([F:TFC]CLCFOR)
         When "DESCR"  : WDESCR  = evalue([F:TFC]CLCFOR)
         When "BUDG"   : WBUDG   = evalue([F:TFC]CLCFOR)
       Endcase
      Next
      Onerrgo

      Wrseq format$("K:128X",WTRANS);         : # 12) TRANS    : Transfert
      Wrseq format$("K:128X",WDESCR);         : # 13) DESCR    : Commentaire
      Wrseq format$("K:128X",WBUDG);          : # 14) BUDG     : Code budget
      Wrseq

     Else

      Filter [TFC] Where MODULE=[F:HAE]ORIMOD and CODPAR=[F:DUD]TYP
      Onerrgo ERR
      For [TFC]
       Case [TFC]CODCAS
        When "CPTA"   : WCPTA   = evalue([F:TFC]CLCFOR)
        When "CDC"    : WCDC    = evalue([F:TFC]CLCFOR)
        When "DESCR"  : WDESCR  = evalue([F:TFC]CLCFOR)
        When "CODRIF" : WCODRIF = evalue([F:TFC]CLCFOR)
        When "NASS"   : WNASS   = evalue([F:TFC]CLCFOR)
        When "REFXRT" : WREFXRT = evalue([F:TFC]CLCFOR)
       Endcase
      Next
      Onerrgo

      Wrseq format$("K:16X",WCPTA);          : # 12) CPTA     : Code nature
      Wrseq format$("K:16X",WCDC);           : # 13) CDC      : Code annexe
      Wrseq format$("K:32X",WDESCR);         : # 14) DESCR    : Commentaire
      Wrseq format$("K:8X",WCODRIF);         : # 15) CODRIF   : Code référence
      Wrseq format$("K:8X",WNASS);           : # 16) NASS     :
      Wrseq
     Endif
    Next
   Endif
  Next
 Next
Next
Openo

If [M]TYPEXP=1
 Call COPCLI([L]FICDON,[M]FIC,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN=1 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN=1 : Return
 Endif
Endif

If !LIGNE
 If !GSERVEUR
  # Aucune échéance à proposer
  Call ERREUR(mess(66,117,1)) From GESECRAN
 Endif
 If GTRACE<>""
  # Aucune échéance à proposer
  Call ECR_TRACE(mess(66,117,1),0) From GESECRAN
 Endif
 FIN=1 : Return
Endif

Return

$ERR
#If GTRACE<>""
 # Erreur en évaluation de zone
 #Call ECR_TRACE(mess(65,106,1)-[F:TFC]CODCAS-":"-errmes$(errn)-"("+num$(errn)+")",1) From GESECRAN
# GOK=0
#Endif
Resume


######################################################################################
$LEC_GTE
Raz NBTYP
Call LEC_CPY([F:DUD]CPY) From CPTLEC

Filter  [GTE] Where LEG=[F:CPY]LEG | LEG="" Order By Key CLE = TYP Asc ; LEG Desc

For [GTE]CLE(1)
 If [F:GTE]DUDCASFLG=2
  NBTYP+=1
  TTYP(NBTYP) = [F:GTE]TYP
 Endif
Next

Filter [GTE]

If NBTYP<60
 Call ADDCRIT(FILT_GTE,GFILT,"DUDCASFLG",'find([F:DUD]TYP,TTYP(1..NBTYP))<>0'," ") From GOBJSUB
Else
 Call ADDCRIT(FILT_GTE,GFILT,"DUDCASFLG",'find([F:DUD]TYP,TTYP(1..NBTYP))'," ") From GOBJSUB
Endif
Return

######################################################################################
$TERMINE

If [M]TRC<>2 : Return : Endif

# Trace
If !GSERVEUR
 Call OUVRE_TRACE(TITCRIT) From LECFIC : TRA =1
Endif

If GTRACE<>""
 Call ECR_TRACE(TITCRIT-SVGTIME,0) From GESECRAN
 Call LECTURE("AGF",[M]GRPCPY,"") From  CONTOBJ
 # Périmètre
 Call ECR_TRACE(mess(3,173,1)-[M]GRPCPY-[F:AGF]DES,0) From GESECRAN
#<YYFIN_93938_US341>
 If [M]TYPEXP=1
  # fichier créé sur le poste client....lignes exportées
  Call ECR_TRACE(mess(178,115,1)+"     "+num$(LIGNE)-mess(82,141,1),0) From GESECRAN
 Else
  # fichier....lignes exportées
  Call ECR_TRACE("|"+mess(14,9003,1)-[M]VOLFIL+"     "+num$(LIGNE)-mess(82,141,1),0) From GESECRAN #<YYFIN_93938_US351>
 Endif
#</YYFIN_93938_US341>
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Endif

Call WORKFLOW(1,"CSD","","") From AWRK
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


######################################################################################

$FILTRE
Raz FILTRE, IFILT

# Critères imposés
#Call ADDCRIT(FILTRE,IFILT,"TYPDUD",'TYPDUD=2'," & ") From GOBJSUB    # Echéances de type FACTURE
#Call ADDCRIT(FILTRE,IFILT,"DUDCASFLG",'[F:GTE]DUDCASFLG=2'," & ") From GOBJSUB  # Echéances flagué "Echéancier trésorerie".

Call ADDCRIT(FILTRE,IFILT,"DUDSTA",'DUDSTA=2'," & ") From GOBJSUB     # Echéances validées
Call ADDCRIT(FILTRE,IFILT,"FLGCLE",'FLGCLE<>2'," & ") From GOBJSUB    # Echéances non soldées.

# Périmètre
Filter [AGC] Where GRP = [M]GRPCPY
If rowcount([AGC])=1
 For [AGC]AGC0
  Call ADDCRIT(FILTRE,IFILT,"CPY",'CPY="'+[F:AGC]CPY+'"'," & ") From GOBJSUB
 Next
Else
 Call ADDCRIT(FILTRE, IFILT,"CPY",'find(CPY'," & ") From GOBJSUB
 For [AGC]AGC0
  Call ADDCRIT(FILTRE,IFILT,"CPY",'"'+[F:AGC]CPY+'"',",") From GOBJSUB
 Next
 Call ADDCRIT(FILTRE,IFILT,"CPY",')',"") From GOBJSUB
Endif
Filter [AGC]
Return


#############################################################################
## Ecran EXPCASDUD
############################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL, [M]FIC
 Grizo [M]VOLFIL
 End
Else
 [M]VOLFIL = "["+GDIRCASH+"]/"+nomap+".cas"
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#-- Pas d'enregistrement en local lors de l'extraction en Batch ou en Web.
#If instr(1,VALEUR,"#@") and (GBROWS or GBATCH) : mkstat=2 : End : Endif
If GBATCH : mkstat=2 : End : Endif
#Control that the file exists
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FIC,E_TYPE_FILEWRITE,GMESSAGE)
End

######################################################################################
Subprog C_TREG(VALEUR)
Variable Char    VALEUR()
# Différence selon L'Interface : SCTE (Concept) ou L1000 ou SFRPT (XRT)
If func AFNC.ACTIV("SCTE")
 If len(VALEUR)=1
  If VALEUR<"A" or VALEUR>"Z" : GMESSAGE=mess(16,173,1) : mkstat=2 : End : Endif
 Elsif len(VALEUR)=2
  If left$(VALEUR,1)<"A"  or left$(VALEUR,1)>"Z"  : GMESSAGE=mess(16,173,1) : mkstat=2 : End : Endif
  If right$(VALEUR,2)<"A" or right$(VALEUR,2)>"Z" : GMESSAGE=mess(16,173,1) : mkstat=2 : End : Endif
 Endif
Else
 If len(VALEUR)>2
  GMESSAGE=mess(16,173,1) : mkstat=2 : End
 Endif
Endif
End

###############################################################################
##  Contrôle en saisie du paramètre EXPCASDUD
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Case PARAM
 When "EXPCASDUD"
  If VALEUR="" : End : Endif
  # Called when we set the value in EXPCASDUD parameter: this value should be defined as
  # [VOL]/name_of_file so the TYPEXP = 2 = server by default
  Local Char FIL(GDIMFIC)
  Gosub ENUM_VOLFIL_TYPE From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL(2,VALEUR,[L]FIL,E_TYPE_FILEWRITE,GMESSAGE)
  If mkstat=2 : OK=0 : Else OK=1 : Endif
 When "CASTREGDUD"
  # 2 caractères alphabétiques maximum
  # Différence selon L'Interface : SCTE (Concept) ou L1000
  If len(VALEUR)>2
   GMESSAGE=mess(16,173,1) : OK=0 : End
  Elsif VALEUR<>""
   If func AFNC.ACTIV("SCTE")
    If len(VALEUR)=1
     If VALEUR<"A" or VALEUR>"Z" : GMESSAGE=mess(16,173,1) : OK=0 : End : Endif
    Elsif len(VALEUR)=2
     If left$(VALEUR,1)<"A"  or left$(VALEUR,1)>"Z"  : GMESSAGE=mess(16,173,1) : OK=0 : End : Endif
     If right$(VALEUR,2)<"A" or right$(VALEUR,2)>"Z" : GMESSAGE=mess(16,173,1) : OK=0 : End : Endif
    Endif
   Endif
  Endif
Endcase
End

######################################################################################

