#<AdxTL>@(#)0.0.0.0 $Revision$
# Class AQCOPR11

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Local Char TMP_ACTION: TMP_ACTION="EVENTS"
Gosub MESSAGE
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
If [L]AMETHOD<>AVOID.ACHAR
  Local Char TMP_ACTION: TMP_ACTION="METHODS"
  Gosub MESSAGE
  Case [L]AMETHOD
  Endcase
Endif
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Local Char TMP_ACTION: TMP_ACTION="OPERATIONS"
Gosub MESSAGE
Case [L]AOPERATION
Endcase
Return

##########################################################################################################


$MESSAGE
Local Integer ASTATUS
If dim([L]AMETHOD)<=0 Local Char AMETHOD : Endif
If dim([L]AOPERATION)<=0 Local Char AOPERATION : Endif
If dim([L]CURPTH)<=0 Local Char CURPTH : Endif
If dim([L]AEVENT)<=0 Local Char AEVENT : Endif
[L]ASTATUS = fmet this.ASETERROR(TMP_ACTION, this.ObjectType-"Execute ["+TMP_ACTION+"] Action "+"CURPTH=["+CURPTH+"] AEVENT=["
& +AEVENT+"] AMETHOD=["+[L]AMETHOD+"] AOPERATION=["+[L]AOPERATION+"]",[V]CST_AINFO)
Return

