#<AdxTL>@(#)5.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Validation fenêtre et écrans V7.0 Patch 4
# Ecran avec au moins un tableau ayant D dans ses options.
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update windows and screens") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("\*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Call VALID(DOSSIER,2,1)
End

#------------------------------------------------------------------#
Subprog VALID(APPLI,DIFFERE,SILENCE)
Value Char    APPLI   : # Nom du dossier
Value Integer DIFFERE : # Validation différée
Value Integer SILENCE : # 1=pas de fenêtre de tempon pendant la validation

Local Integer I , OK , VALDIF , SAVGVALIDDIF
Local Integer TYPVAL , STAT , NBMSKVAL
Local Char    TABLE(GLONATB) , SYMBOLE(80)
Local Char    MSKVAL(GLONAMK)(1..)

TYPVAL = 1 : # On valide dans toutes les langues

SAVGVALIDDIF=GVALIDDIFF
If DIFFERE=2
 GVALIDDIFF = 3
Else
 GVALIDDIFF = 1
Endif

If GVALIDDIFF=3
 # Validation différée des écrans et fenêtres
 Call ECR_TRACE(mess(251,125,1),0) From GESECRAN
Endif

SYMBOLE = "APLSTD"
If APPLI=nomap
 Lock =SYMBOLE With lockwait=0
Else
 Lock =SYMBOLE From =APPLI With lockwait=0
Endif
If !fstat
 If [L]TYPVAL=2 : # Ajout de langue ->
  Call GENMENU(APPLI,SILENCE,2,"") From GENMENULOC
 Else
  Call GENMENU(APPLI,SILENCE,1,GLANGUE) From GENMENULOC
 Endif
 If APPLI=nomap
  Unlock =SYMBOLE
 Else
  Unlock =SYMBOLE From =APPLI
 Endif
Endif

Gosub VALECRS

GVALIDDIFF = SAVGVALIDDIF

End

#--------------------------------------------#
$VALECRS
# Validation écran
Call TIM_TRACE(mess(139,123,1))
Gosub OUVTAB
Gosub OUVFIC From VALMSKLEC
If clalev([F:AMK4])=0 : Local File =APPLI+".AMSK" [AMK4] : Endif
If clalev([F:AMZ4])=0 : Local File =APPLI+".AMSKZON" [AMZ4] : Endif
If clalev([F:AMZ5])=0 : Local File =APPLI+".AMSKZON" [AMZ5] : Endif
If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"  [AWI2] : Endif

NBMSKVAL = 0


# Find screens with link fields
#For [AMZ4]DICO Where CODZON>="Z"
# Look [AMZ5]CODE=[F:AMZ4]CODMSK;right$([F:AMZ4]CODZON,2)
# If !fstat
#  If !find([F:AMZ4]CODMSK,MSKVAL(1..NBMSKVAL))
#   NBMSKVAL += 1
#   MSKVAL(NBMSKVAL) = [F:AMZ4]CODMSK
#  Endif
# Endif
#Next AMZ4

# Find screens with graphics bloc
#For [AMK4] Where find(8,[F:AMK4]TYPBLOC(0..[F:AMK4]NBBLOC-1))<>0
# NBMSKVAL += 1
# MSKVAL(NBMSKVAL) = [F:AMK4]CODMSK
#Next AMK4

# Find screens with option "D"
For [AMK4] Where find(1,[F:AMK4]TYPBLOC(0..[F:AMK4]NBBLOC))<>0
 For I=1 To [F:AMK4]NBBLOC
  If [F:AMK4]TYPBLOC(I-1)=1 : # Tableau
   If (instr(1,[F:AMK4]OPTION(I-1),"D")>0)
    NBMSKVAL += 1
    MSKVAL(NBMSKVAL) = [F:AMK4]CODMSK
    Break
   Endif
  Endif
 Next I
Next AMK4

# Validation
For I=1 To NBMSKVAL
 TABLE = MSKVAL(I)
 Gosub VALECR
 #For [AWI2]AWI0 Where MSKENT=MSKVAL(I) or find(MSKVAL(I),NOMMSK(0..NBMSK-1))<>0
 # TABLE = [F:AWI2]WIN
 # OBJET = [F:AWI2]OBJ
 # Gosub VALFEN
 #Next AWI2
Next I

For [AWI2]AWI0 Where MDL<>2
 TABLE = [F:AWI2]WIN
 OBJET = [F:AWI2]OBJ
 Gosub VALFEN
Next AWI2

Close Local File
Return

#-----------------------------------#
$OUVTAB
If APPLI="" or APPLI=nomap
 Local File ACTIV   [ACV]
 Local File ATEXTE  [ATX]
 Local File ATEXTRA [AXX]
Else
 Local File =APPLI+".ACTIV"   [ACV]
 Local File =APPLI+".ATEXTE"  [ATX]
 Local File =APPLI+".ATEXTRA" [AXX]
Endif
Return

#------------------------------------------------------#
$VALFEN
If !SILENCE
  # Validation fenêtre
 Call TEMPON(mess(28,126,1)-TABLE) From GESECRAN
Endif
# Validation fenêtre
If APPLI=nomap
 Lock ="AWI"+TABLE With lockwait=0
Else
 Lock ="AWI"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
 Call ECR_TRACE(mess(28,126,1)-TABLE,0) From GESECRAN
 Call VALID(TABLE,APPLI,SILENCE,OK) From VALWIN
 If APPLI=nomap
  Unlock ="AWI"+TABLE With lockwait=0
 Else
  Unlock ="AWI"+TABLE From =APPLI With lockwait=0
 Endif
Else
#Modification en cours sur un autre poste
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

#------------------------------------------------------#
$VALECR
If !SILENCE
 Call TEMPON(mess(28,126,1)-TABLE) From GESECRAN
Endif
# Validation écrans
If APPLI=nomap
 Lock ="AMK"+TABLE With lockwait=0
Else
 Lock ="AMK"+TABLE From =APPLI With lockwait=0
Endif
If fstat=0
# Validation écran
 Call ECR_TRACE(mess(139,123,1)-TABLE,0) From GESECRAN
 Call VALID(TABLE,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,STAT) From VALMSK
 If APPLI=nomap
  Unlock ="AMK"+TABLE With lockwait=0
 Else
  Unlock ="AMK"+TABLE From =APPLI With lockwait=0
 Endif
Else
 Call ECR_TRACE(mess(10,100,1),1) From GESECRAN
Endif
Return

#--------------------------------------#
Subprog TIM_TRACE(MESSA)
Value Char MESSA
Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(format$("D:"+GFMDAT,date$)-time$-":"-MESSA,0) From GESECRAN
End
