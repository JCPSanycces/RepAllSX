#<AdxTL>@(#)1.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Consultation : BOA - consultation des approbations budgétaires
#   Action       : CONSBOA
#   Fenêtres     : FCNSBOA / DCNSBOA
#   Ecrans concernés : CONSBOA1, CONSBOA2 / CRITBOA
#   Description : Consultations des approbations budgétaires
#
#--------------------------------------------------------------------------

Local Char PARAM(250)(1..10)
PARAM(1)  = "0"        :# Numéro d'aprobation
PARAM(2)  = "1"        :# Type d'approbation (enveloppe/budget/ligne)
PARAM(3)  = "JHA"      :# Société
PARAM(4)  = "VSA"      :# Site
PARAM(5)  = "20080101" :# Date début
PARAM(6)  = "20091231" :# Date fin
PARAM(7)  = ""         :# Projet
PARAM(8)  = ""         :# Envelolppe
PARAM(9)  = ""         :# ACCNUM Numéro de ligne
PARAM(10) = ""         :# Compte
Call GCONSULT("BOA","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
Local File ACTIV [ACV]
Read [ACV]CODACT="GDD"
If !fstat & [F:ACV]FLACT<>2  : End  : Endif
Call VALGTC(APPLI,"BOA") From SUBGTC
End

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "LECTURE"      : Gosub LECTURE
 When Default
Endcase
Return

$OUVRE
If !clalev([F:BOA]) : Local File BUDAPP     [BOA] : Endif
If !clalev([F:BOA2]): Local File BUDAPP     [BOA2]: Endif
If !clalev([F:BAD]) : Local File BUDAPPDET  [BAD] : Endif
If !clalev([F:PRJ]) : Local File PROJET     [PRJ] : Endif
If !clalev([F:ENV]) : Local File ENVELOPPE  [ENV] : Endif
If !clalev([F:BUD]) : Local File BUD        [BUD] : Endif
If !clalev([F:BUP]) : Local File BUDPAR     [BUP] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
#
If !clalev([F:ENV2]) : Local File ENVELOPPE [ENV2] : Endif
If !clalev([F:ENF2]) : Local File ENVFIY    [ENF2] : Endif
If !clalev([F:BUD2]) : Local File BUD       [BUD2] : Endif
#
Local Char CRITBOA(250),CRITENV(250),CRITENF(250),CRITBUD(250),INFO(250),WFIL(250)
Local Char SOCIETE(GLONCPY),SITE(GLONFCY)
Local Char LISTENV(GLONENV)(1..max(1,nbrecord([ENV])))
Local Integer OKTYP
Local Integer DOLIG
Local Char    DEBNUM, FINNUM
Local Decimal REALISE
#
Local Char    FILTBOA(250)
Local Integer IFILT : IFILT = 1
#
Local Integer OKACS, CTLACS
#
Raz [M:BOA1],[M:BOA2]
Gosub DEFCRIT
Return

$DEFCRIT
# Valeurs par défaut
Default Mask [M:BOA1]
# Paramètres
For I=1 To dim(PARAM)
 Case I
  When 1 : #Numéro d'approbation
   If PARAM(I)<>""
    Call LECTURE("BOA",PARAM(I),"") From CONTOBJ
    [M:BOA1]SELNUM=PARAM(I)
   Endif
  When 2 : #Type révision
   If PARAM(I)<>""
    [M:BOA1]SELTYP=val(PARAM(I))
    [M:BOA1]ALLTYP=1
   Endif
  When 3 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BOA1]CPY = PARAM(I)
     If [M:BOA1]FCY<>""
      Call LECTURE("FCY",[M:BOA1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:BOA1]CPY : [M:BOA1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 4 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:BOA1]FCY = PARAM(I)
     [M:BOA1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
   ##
   If PARAM(8)<>"" :#Enveloppe
    Call LECTURE("ENV",PARAM(8),"") From CONTOBJ
    Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
    If [F:BUP]LEV=1
     [M:BOA1]FCY = ""
    Endif
   Endif
   ##
  When 5 : # Date début
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BOA1]DATDEB = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:BOA1]DATDEB = PARAM(I)
    Endif
    Call AS_DATDEB([M:BOA1]DATDEB)
    Call C_DATDEB([M:BOA1]DATDEB)
   Endif
  When 6 : # Date fin
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:BOA1]DATFIN = evalue("["+PARAM(I)+"]")
    Elsif PARAM(I)<>""
     [M:BOA1]DATFIN = PARAM(I)
    Endif
    Call C_DATFIN([M:BOA1]DATFIN)
   Endif
  When 7 : # Projet
   If PARAM(I)<>""
    Call LECTURE("PRJ",PARAM(I),"") From CONTOBJ
    If !fstat : [M:BOA1]PRJ = PARAM(I) : Endif
   Endif
  When 8 : # Enveloppe
   If PARAM(I)<>""
    Call LECTURE("ENV",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:BOA1]ENVSTR = PARAM(I)
     [M:BOA1]ENVEND = PARAM(I)
     Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
     [M:BOA1]COA=[F:BUP]COA
    Endif
   Endif
  When 9 : # ACCNUM Numéro de ligne
   If PARAM(I)<>""
    Read [BUD]BUD1 = val(PARAM(I))
    If !fstat
     [M:BOA1]SELACCNUM=val(PARAM(I))
    Endif
   Endif
  When 10 : # Compte
   If PARAM(I)<>""
    If [M:BOA1]ENVSTR<>""
     Read [GAC]GAC0 = [M:BOA1]COA;PARAM(I)
     If !fstat : [M:BOA1]SELACC=PARAM(I) : Endif
    Else
     J=0
     Filter [GAC] Where ACC=PARAM(I)
      For [GAC]GAC0
       J+=1 : Break
      Next
     Filter [GAC]
     If J : [M:BOA1]SELACC=PARAM(I) : Endif
    Endif
   Endif
 Endcase
Next I
Return

$LECTURE
CTLACS = 1

If [M]CPY="" : Return : Endif

If CHGPAG<0 : NOL = MAXLIG : Endif

#Les filtres
Gosub LOAD_FILTRE
#-- dans les traitements standards uniquement :  appel au spécifique
If PROGSPE<>""
 ACTION="FILTRE" : Gosub ACTION From =PROGSPE
Endif

J=1
For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS = 0 : Endif
 Endif
 If OKACS=1
  LISTENV(J)=[F:ENV]ENV
  J+=1
 Endif
Next

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
 Filter [BOA] Where evalue(WFIL) & evalue(CRITBOA) Order By Key BOA0
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
 Filter [BOA] Where evalue(WFIL) & evalue(CRITBOA) Order By Key BOA0 Desc
Endif

#Raz du masque si 1ère ou dernière page
If CHGPAG<>2 & CHGPAG<>-2
 Raz [M:BOA2]
Endif

[M:BOA2]NBLIG =0
For [BOA]BOA0
 If find([F:BOA]ENV,LISTENV(1..(J-1)))
   OKTYP=0
   #---------------------
   #Il faut aussi afficher les approbations multiples qui compte les approbations du type demandé,
   #voir de l'objet demandé si l'on vient directement depuis l'objet
   If [F:BOA]TYP=4 & [M]ALLTYP=1 & [M]SELTYP<>4
    Filter [BAD] Where NUMAPP=[F:BOA]NUM & TYP=[M]SELTYP
    For [BAD]BAD0
     Case [M]SELTYP
       When 1 : If [F:BAD]TYP=1 : OKTYP=1 : Break : Endif
       When 2 : If [F:BAD]TYP=2 : OKTYP=1 : Break : Endif
       When 3 : If [F:BAD]TYP=3 : OKTYP=1 : Break : Endif
#85095
#       When 2 : If [F:BAD]FIY>=[M]DFIY & [F:BAD]FIY<=[M]FFIY :
#        OKTYP=1 : Break : Endif
#       When 3
#        If [M]SELACC<>""
#         If [F:BAD]ACC=[M]SELACC & [F:BAD]FIY>=[M]DFIY & [F:BAD]FIY<=[M]FFIY
#          OKTYP=1 : Break
#         Endif
#        Elsif [F:BAD]FIY>=[M]DFIY & [F:BAD]FIY<=[M]FFIY
#         OKTYP=1 : Break
#        Endif
#        If [M]SELACCNUM<>0
#         If [F:BAD]ACCNUM=[M]SELACCNUM : OKTYP=1 : Break : Endif
#        Endif
     Endcase
    Next
    Filter [BAD]
   Else
    OKTYP=1
   Endif
   #--------------------
   If OKTYP
    PLEIN=0
    If NBLU=1
     NBLU=2
    Endif
    If CHGPAG>0
     If NOL>=MAXLIG-1 : SUITE = 2 : PLEIN = 1 : Break : Endif
     NOL += 1
     If NOL=0
      DEBNUM = [F:BOA]NUM
     Endif
     FINNUM = [F:BOA]NUM
    Else
     If NOL<=0 : RETOUR = 2 : PLEIN = 1 : Break : Endif
     NOL -= 1
     If NOL=MAXLIG-1
      FINNUM = [F:BOA]NUM
     Endif
     DEBNUM = [F:BOA]NUM
    Endif
    nolign = NOL+1
    Gosub REMPLIT
#85095
#    Case [F:BOA]TYP
#     When 1,4
#      INFO += [F:BOA]NUM+chr$(10)
#      Gosub REMPLIT
#     When 2
#      If [F:BOA]FIY>=[M]DFIY & [F:BOA]FIY<=[M]FFIY
#       INFO += [F:BOA]NUM+chr$(10)
#       Gosub REMPLIT
#      Endif
#    When 3
#      DOLIG=1
#      Read [BUD]BUD1 = [F:BOA]ACCNUM
#      If !fstat
#       If [M]DFIY>[F:BUD]FIY | [M]FFIY<[F:BUD]FIY
#        DOLIG=0
#       Endif
#       If [M]SELACC<>""
#        If [F:BUD]ACC<>[M]SELACC : DOLIG=0 : Endif
#       Endif
#       If DOLIG
#        INFO += [F:BOA]NUM+chr$(10)
#        Gosub REMPLIT
#       Endif
#      Endif
#    Endcase
   Endif
 Endif
Next
Filter [BOA]
If [M:BOA2]NBLIG=0
 #Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Else
 If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
 Gosub COLORIZE
Endif
Return

$COLORIZE
For I=0 To [M:BOA2]NBLIG-1
 Chgstl [M:BOA2]AMTAPP(I) With "GDD2G"
 Affzo [M:BOA2]AMTAPP(I)
Next
Return

$REMPLIT
[M:BOA2]NUM(nolign-1) = [F:BOA]NUM
[M:BOA2]TYP(nolign-1) = [F:BOA]TYP
[M:BOA2]ENV(nolign-1) = [F:BOA]ENV
[M:BOA2]FIY(nolign-1) = [F:BOA]FIY
Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;[F:BOA]FIY
If !fstat
 [M:BOA2]INTFIY(nolign-1) = [F:FIY]DESSHO
Endif
[M:BOA2]ACCNUM(nolign-1) = [F:BOA]ACCNUM
[M:BOA2]ACC(nolign-1)    = [F:BOA]ACC
[M:BOA2]AMT(nolign-1)    = [F:BOA]AMT
[M:BOA2]AMTAPP(nolign-1) = [F:BOA]AMTAPP
[M:BOA2]CUR(nolign-1)    = [F:BOA]CUR
[M:BOA2]STA(nolign-1)    = [F:BOA]STA
[M:BOA2]RENTXT(nolign-1) = [F:BOA]RENTXT
[M:BOA2]CREDAT(nolign-1) = [F:BOA]CREDAT
[M:BOA2]CREUSR(nolign-1) = [F:BOA]CREUSR
[M:BOA2]UPDDAT(nolign-1) = [F:BOA]UPDDAT
[M:BOA2]UPDUSR(nolign-1) = [F:BOA]UPDUSR
[M:BOA2]NBLIG +=1
Return

$LOAD_FILTRE
WFIL="1=1"
Case CHGPAG
 When 3 : #Rafraichissement
  WFIL -='& NUM>="'+DEBNUM+'"'
 When 2 : #Suite
  WFIL -='& NUM>"'+FINNUM+'"'
 When -2 : #Retour
  WFIL -='& NUM<"'+DEBNUM+'"'
Endcase

CRITBOA="1=1"
CRITENV="1=1"
CRITBUD="1=1"
CRITLIG="1=1"

If [M]SELNUM<>""
 CRITBOA = 'NUM="'+[M]SELNUM+'"'
Endif

If [M]ALLTYP=1
 Case [M]SELTYP
  When 1,2,3 : CRITBOA -= '& (TYP='+num$([M]SELTYP)-'| TYP=4)'
  When 4     : CRITBOA -= '& TYP=4'
 Endcase
Endif

If [M]CPY<>""
 SOCIETE=[M]CPY
 If [M]FCY<>""
  CRITENV -='& FCY="'+[M]FCY+'"'
  SITE=[M]FCY
 Else
  Local Char LISTFCY(GLONFCY)(1..GNBSITE)
  Local Integer SOC,J
  SOC=find([M]CPY,GSOC(1..GNBSOC))
  J=1
  If SOC
   For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
    LISTFCY(J)=[F:FCY]FCY
    J+=1
   Next
  Endif
  CRITENV -='& (FCY="'+[M]CPY+'" | find(FCY,LISTFCY(1..'+num$(J-1)+')))'
  Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
  SITE=[F:CPY]MAIFCY
 Endif
Elsif [M]FCY<>""
 SITE=[M]FCY
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE=[F:FCY]LEGCPY
 CRITENV -='& FCY="'+[M]FCY+'"'
Endif

If [M]DATDEB<>[0/0/0] & [M]DATFIN<>[0/0/0]
 CRITBOA -='& ((UPDDAT<>[0/0/0] & UPDDAT>=['+format$(GFMD,[M]DATDEB)+'] & UPDDAT<=['+format$(GFMD,[M]DATFIN)+'])'
 CRITBOA -='| (CREDAT>=['+format$(GFMD,[M]DATDEB)+'] & CREDAT<=['+format$(GFMD,[M]DATFIN)+']))'
Endif

If [M]PRJ<>""
 CRITENV -='& PRJ="'+[M]PRJ+'"'
Endif
If [M]ENTMSTR<>""
 CRITENV -= '& ENTMNA>="'+[M]ENTMSTR+'" & ENTMNA<="'+[M]ENTMEND+'"'
Endif
If [M]ENTASTR<>""
 CRITENV -= '& ENTAPP>="'+[M]ENTASTR+'" & ENTAPP<="'+[M]ENTAEND+'"'
Endif
If [M]ENVSTR<>""
 CRITENV -= '& ENV>="'+[M]ENVSTR+'" & ENV<="'+[M]ENVEND+'"'
Endif

If [M]SELACC<>""
 CRITLIG -='& [F:BUD]ACC="'+[M]ACC+'"'
Endif
If [M]SELACCNUM<>0
 CRITLIG -='& [F:BUD]ACCNUM='+num$([M]SELACCNUM)
Endif
Return

##-----------------------------------------##
## Etiquettes écrans CONSBOA1&2 & CRITBOA  ##
##-----------------------------------------##

Subprog IB_NBLIG
If [M]TYP(nolign-1)<>4
 Raz GBOUT1
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
Call C_CPY(VALEUR) From CONSSUB
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If [M]CPY<>""
 Local Libelle LEDTYPGEN,LEDTYPANA
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 [M]LEDTYP=LEDTYPANA
 Call LECPLAN([M]CPY,LEDTYPANA,[M]COA) From CPTDIV
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]DFIY=EXERCICE
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
Local Decimal EXERCICE
Call GETEXE([M]CPY,[M]LEDTYP,VALEUR,EXERCICE) From CPTSUB
[M]FFIY=EXERCICE
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2 : Grizo [M]SELTYP : Else : Actzo [M]SELTYP : Endif
End

Subprog AS_SELTYP(VALEUR)
Variable Integer VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : End : Endif
End

Subprog C_PRJ(VALEUR)
Variable Char    VALEUR()
If clalev([F:PRJ]) = 0 : Local File PROJET [PRJ] : Endif
Call LECTURE("PRJ",VALEUR,"") From CONTOBJ
If !fstat & [F:PRJ]ACS<>""
 Local Integer OKACC
 Call CONSACC([F:PRJ]ACS,OKACC) From CPTSUB
 If !OKACC
  Call MESSAGE(mess(4,104,1)) From GESECRAN
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTMSTR<>""
 VALEUR=[M]ENTMSTR
 Affzo [M]ENTMEND
Endif
End

Subprog C_ENTMEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTMSTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End

Subprog AS_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENTASTR<>""
 VALEUR=[M]ENTASTR
 Affzo [M]ENTAEND
Endif
End

Subprog C_ENTAEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]ENTASTR
 #La borne fin est inférieure à la borne début
 GMESSAGE=mess(44,199,1)
 mkstat=2
Endif
End


Subprog C_ENVSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If [M]FCY=""
   If [F:ENV]FCY<>[M]CPY
    Local Integer SOC,J
    Local Char LISTFCY(GLONFCY)(1..GNBSITE)
    SOC=find([M]CPY,GSOC(1..GNBSOC))
    J=1
    If SOC
     For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
      LISTFCY(J)=[F:FCY]FCY
      J+=1
     Next
    Endif
    If !find([F:ENV]FCY,LISTFCY(1..J))
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Else
   If [F:ENV]FCY<>[M]FCY
    Local Integer SITE
    SITE=find([M]FCY,GSITE(1..GNBSITE))
    If SITE
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
 Endif
Endif
End


Subprog AS_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]ENVSTR<>""
 VALEUR=[M]ENVSTR
 Affzo [M]ENVEND
Endif
End

Subprog C_ENVEND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACS
  If [F:ENV]ACS<>""
   Call CONSACC([F:ENV]ACS,OKACS) From CPTSUB
   If !OKACS
    Call MESSAGE(mess(4,104,1)) From GESECRAN
    mkstat = 2 : End
   Endif
  Endif
  If [M]FCY=""
   If [F:ENV]FCY<>[M]CPY
    Local Integer SOC,J
    Local Char LISTFCY(GLONFCY)(1..GNBSITE)
    SOC=find([M]CPY,GSOC(1..GNBSOC))
    J=1
    If SOC
     For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
      LISTFCY(J)=[F:FCY]FCY
      J+=1
     Next
    Endif
    If !find([F:ENV]FCY,LISTFCY(1..J))
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Else
   If [F:ENV]FCY<>[M]FCY
    Local Integer SITE
    SITE=find([M]FCY,GSITE(1..GNBSITE))
    If SITE
     #L'enveloppe n'est pas définie sur cette société/site
     GMESSAGE=mess(183,108,1)
     mkstat=2 : End
    Endif
   Endif
  Endif
 Endif
 If VALEUR<[M]ENVSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE=mess(44,199,1)
  mkstat=2 :End
 Endif

 If VALEUR=[M]ENVSTR
  Call LECTURE("ENV",VALEUR,"") From CONTOBJ
  Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
  [M]COA=[F:BUP]COA
 Endif

Endif
End
