##########################################################################################################
# Retourne la nature du tiers en clair en fonction d'une prioritÃĐ arbitraire
##########################################################################################################
Subprog GETBPRTYP(SZBPRNUM, SZBPRTYP, SZBPXAOB)
Value Char SZBPRNUM
Variable Char SZBPRTYP
Variable Char SZBPXAOB

  # -----------------
  #PrioritÃĐ rÃĐtenue :
  #Tiers divers
  #Transporteur
  #ReprÃĐsentant
  #Prestataire
  #Fournisseur
  #Donneur d'ordre
  #Prospect/Client
  # -----------------
  SZBPXAOB = "BPR"
  If SZBPRNUM = "" Then
    SZBPRTYP = mess(142,121,1)
    End
  Endif
  Local File BPARTNER [BPR]
  Read [BPR]BPR0=SZBPRNUM
  If fstat Then
    SZBPRTYP = mess(142,121,1)
    End
  Endif
  If [F:BPR]BPRACC = 2 : SZBPRTYP = mess(6,277,1)   :                    Endif   #Tiers divers
  If [F:BPR]BPTFLG = 2 : SZBPRTYP = mess(3,277,1)   : SZBPXAOB = "BPT" : Endif   #Transporteur
  If [F:BPR]REPFLG = 2 : SZBPRTYP = mess(5,277,1)   : SZBPXAOB = "REP" : Endif   #ReprÃĐsentant
  If [F:BPR]PRVFLG = 2 : SZBPRTYP = mess(238,196,1) :                    Endif   #Prestataire
  If [F:BPR]BPSFLG = 2 : SZBPRTYP = mess(2,277,1)   : SZBPXAOB = "BPS" : Endif   #Fournisseur
  If [F:BPR]DOOFLG = 2 : SZBPRTYP = mess(239,196,1) :                    Endif   #Donneur d'ordre
  If [F:BPR]PPTFLG = 2 : SZBPRTYP = mess(240,196,1) : SZBPXAOB = "BPP" : Endif   #Prospect
  If [F:BPR]BPCFLG = 2 : SZBPRTYP = mess(1,277,1)   : SZBPXAOB = "BPC" : Endif   #Client
  If SZBPRTYP = "" Then
    SZBPRTYP = mess(142,121,1)
  Endif
End

##########################################################################################################
# DÃĐfini le site par rapport Ã  celui du reprÃĐsentant suivant le paramÃĻtre CRMREPSIT pour un objet des
# modules Action commerciale et Support client.
##########################################################################################################
Subprog SITECRMREP(CTX, SZMODULE, SZREP, SZSITE)
Value Instance CTX Using C_WMACONTEXT
Value Char SZMODULE   #ACT ou HDK
Value Char SZREP
Variable Char SZSITE

Local Char SZNEWSITE(GLONFCY)
Local Char SZMESS(250)
Local Integer IASK
Local Integer ICRMREPSIT

  ICRMREPSIT = fmet CTX.APARAM.AGETUSERVALNUM("CRMREPSIT")
  # 1-Ne rien faire
  # 2-Proposer celui du reprÃĐsentant
  # 3-Remplacer par celui du reprÃĐsentant
  # -------------
  SZNEWSITE = ""
  IASK = 0
  SZMESS = ""
  # -------------
  If ICRMREPSIT = 1 Then
    If SZSITE <> "" Then
      End
    Endif
  Endif
  If ICRMREPSIT = 2 or ICRMREPSIT = 3 Then
    If SZREP <> "" Then
      Local File SALESREP [REP]
      Read [REP]REP0=SZREP
      If !fstat Then
        SZNEWSITE = [F:REP]FCY
      Endif
    Endif
  Endif
  If SZNEWSITE = "" Then
    End
  Endif
  If SZSITE = "" Then
    SZSITE = SZNEWSITE
    End
  Endif
  #Affecte les valeurs souhaitÃĐes
  Case ICRMREPSIT
    When 2
      If SZNEWSITE <> SZSITE Then
        #On demande si on veut remplacer
        #Voulez-vous remplacer le site par celui du reprÃĐsentant?
        IASK = [V]CST_AYES
        #SZMESS = mess(205,177,1)
        #Call OUINON(SZMESS, IASK) From GESECRAN
        If IASK = [V]CST_AYES Then
          SZSITE = SZNEWSITE
        Endif
      Endif
    When 3
      If SZNEWSITE <> SZSITE Then
        SZSITE = SZNEWSITE
      Endif
    When Default
  Endcase
End

##########################################################################################################
Subprog READ_COUNTER(CTX, IMODULE, IND, SCPY, SCODE, IMANUAL, SMESSAGE, IERROR)
Value Instance CTX Using C_WMACONTEXT
Value Integer IMODULE
Value Integer IND
Value Char SCPY
Variable Char SCODE
Variable Integer IMANUAL
Variable Char SMESSAGE
Variable Integer IERROR

Local Char L_LEG(GLONADI)
Local Integer B_TCAFND

  Raz SMESSAGE
  IERROR = [V]CST_ANO
  Raz SCODE
  Raz IMANUAL
  # ----------------------------------------------------
  Local File TABCOUAFF [TCA]
  # ----------------------------------------------------
  If SCPY <> "" Then
    # look for the counter for the given company
    Read [TCA]TCA0=IMODULE;"";SCPY
    If !fstat Then
      B_TCAFND = 1
    Else
      # look for the legislation of the given company in GLECSOC
      L_LEG = fmet CTX.ACACHE.ACPY.AGETVALCHAR(SCPY,"LEG")
      If L_LEG <> "" Then
        # look for the counter for the legislation of the given company
        Read [TCA]TCA0=IMODULE;L_LEG;""
        If !fstat Then
          B_TCAFND = 1
        Else
          # if still not found, look for the counter of the whole module
          Read [TCA]TCA0=IMODULE;"";""
          If !fstat Then
            B_TCAFND = 1
          Endif
        Endif
      Else
        # if still not found, look for the counter of the whole module
        Read [TCA]TCA0=IMODULE;"";""
        If !fstat Then
          B_TCAFND = 1
        Endif
      Endif
    Endif
  Else
    Read [TCA]TCA0=IMODULE;"";""
    If !fstat Then
      B_TCAFND = 1
    Endif
  Endif
  # ----------------------------------------------------
  If !B_TCAFND Then
    IERROR = [V]CST_AYES
    SMESSAGE = mess(58,105,1) - mess(IMODULE,14,1) -  ":" - mess(250,199,1)
    End
  Endif
  # ----------------------------------------------------
  IMANUAL = [F:TCA]MANCOU(IND)
  SCODE = [F:TCA]CODNUM(IND)
  # ----------------------------------------------------
End

##########################################################################################################
# Retourne une heure augmentÃĐe du nombre de minutes indiquÃĐes
##########################################################################################################
Subprog GETNEWHOUR(SZHOU, INBMIN, SZNEWHOU)
Value Char SZHOU
Value Integer INBMIN
Variable Char SZNEWHOU

Local Integer INBHOU
Local Integer IREMMIN
Local Integer IHOUPART
Local Integer IMINPART
Local Char SZHOUPART(50)
Local Char SZMINPART(50)

  INBHOU = 0
  IREMMIN = 0
  IHOUPART = 0
  IMINPART = 0
  SZHOUPART = ""
  SZMINPART = ""
  If INBMIN < 60 Then
    If (INBMIN + val(mid$(SZHOU,3,2))) < 60 Then
      IHOUPART = val(left$(SZHOU,2))
      IMINPART = INBMIN + val(mid$(SZHOU,3,2))
    Else
      IHOUPART = val(left$(SZHOU, 2)) + 1
      IMINPART = (INBMIN + val(mid$(SZHOU,3,2))) - 60
    Endif
  Else
    INBHOU = INBMIN / 60
    IREMMIN = INBMIN - (60 * INBHOU)
    If (IREMMIN + val(mid$(SZHOU,3,2))) < 60 Then
      IHOUPART = val(left$(SZHOU,2)) + INBHOU
      IMINPART = IREMMIN + val(mid$(SZHOU,3,2))
    Else
      IHOUPART = val(left$(SZHOU,2)) + INBHOU + 1
      IMINPART = (IREMMIN + val(mid$(SZHOU,3,2))) - 60
    Endif
  Endif
  If IHOUPART < 10 Then
    SZHOUPART = "0" + num$(IHOUPART)
    If IHOUPART = 0 Then
      SZHOUPART = "00"
    Endif
  Else
    SZHOUPART = num$(IHOUPART)
  Endif
  If IMINPART < 10 Then
    SZMINPART = "0" + num$(IMINPART)
    If IMINPART = 0 Then
      SZMINPART = "00"
    Endif
  Else
    SZMINPART = num$(IMINPART)
  Endif
  SZNEWHOU = SZHOUPART + SZMINPART
End

##########################################################################################################
# Calcul la durÃĐe d'une rendez-vous
##########################################################################################################
Subprog GETDUR(IDATDEB, SZHOUDEB, IDATFIN, SZHOUFIN, SZDUR)
Value Integer IDATDEB
Value Char SZHOUDEB
Value Integer IDATFIN
Value Char SZHOUFIN
Variable Char SZDUR

Local Integer I
Local Integer IDUR
Local Integer ISTART
Local Integer ISTOP
Local Integer INBHOU
Local Integer INBMIN
Local Char SZNBHOU(10)
Local Char SZNBMIN(10)

  # ----------------------------------------------
  If IDATFIN = IDATDEB and SZHOUFIN < SZHOUDEB Then
    SZDUR = ""
    End
  Endif
  # -----------------------
  If IDATDEB <> IDATFIN Then    # FGR 04/04/2013 : X3SUIVI88542
    If SZHOUDEB < "0900" Then
      SZHOUDEB = "0900"         # De toute faÃ§on la journÃĐe commence Ã  9h00
    Elsif SZHOUDEB > "1800" Then
      SZHOUDEB = "0900"         # On passe au dÃĐbut du jour suivant
      IDATDEB += 1
    Endif
    # -----------------------
    If SZHOUFIN > "1800" Then
      SZHOUFIN = "1800"         # De toute faÃ§on la journÃĐe termine Ã  18h00
    Elsif SZHOUFIN < "0900" Then
      SZHOUFIN = "1800"         # On passe Ã  la fin du jour prÃĐcÃĐdent
      IDATFIN -= 1
    Endif
  Endif
  # -----------------------
  If IDATFIN < IDATDEB Then
    SZDUR = "0000"
    End
  Endif
  # ----------------------------------------------
  ISTART = IDATDEB + 1
  ISTOP = IDATFIN - 1
  I = ISTART
  INBHOU = 0
  INBMIN = 0
  IDUR = 0
  SZNBHOU = ""
  SZNBMIN = ""
  SZDUR = ""
  # -----------------------
  If IDATDEB = IDATFIN Then
    # Traitement des heures Ã  la mÃŠme dates.
    # -------------------------------------------------------------
    # Pas les samedis et dimanches
    If val(mid$(SZHOUDEB,3,2)) > val(mid$(SZHOUFIN,3,2)) Then
      # Minutes heure dÃĐbut supÃĐrieure Ã  minute heure de fin
      INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
      INBHOU -= 1
      INBMIN = 60 - abs((val(mid$(SZHOUDEB,3,2)) - val(mid$(SZHOUFIN,3,2))))
    Elsif val(mid$(SZHOUDEB,3,2)) < val(mid$(SZHOUFIN,3,2)) Then
      # Minutes heure dÃĐbut infÃĐrieure Ã  minute heure de fin
      INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
      INBMIN = abs(val(mid$(SZHOUFIN,3,2)) - val(mid$(SZHOUDEB,3,2)))
    Elsif val(mid$(SZHOUDEB,3,2)) = val(mid$(SZHOUFIN,3,2)) Then
      # Minutes heure dÃĐbut ÃĐgale Ã  minute heure de fin
      INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
      INBMIN = 0
    Endif
    If INBHOU < 10 Then
      SZNBHOU = "0" + num$(INBHOU)
    Else
      SZNBHOU = num$(INBHOU)
    Endif
    If INBMIN < 10 Then
      SZNBMIN = "0" + num$(INBMIN)
    Else
      SZNBMIN = num$(INBMIN)
    Endif
    SZDUR = SZNBHOU + SZNBMIN
  Else
    # Traitement des heures des jours compris entre les deux dates.
    # -------------------------------------------------------------
    For I = ISTART To ISTOP
      If dayn(nday$(I)) < 6 Then
        IDUR += 9
      Endif
    Next
    SZDUR = num$(IDUR)
    # -----------------------------------------
    # Traitement des heures de la date de dÃĐbut
    INBHOU = 0
    INBMIN = 0
    If dayn(nday$(IDATDEB)) < 6 Then
      # On ignore les samedis et dimanche
      INBHOU = 18 - val(left$(SZHOUDEB,2))
      If val(mid$(SZHOUDEB,3,2)) > 0 Then
        INBHOU -= 1
        INBMIN = 60 - val(mid$(SZHOUDEB,3,2))
      Else
        INBMIN = 0
      Endif
    Endif
    IDUR += INBHOU
    If IDUR < 10 Then
      SZNBHOU = "0" + num$(IDUR)
    Else
      SZNBHOU = num$(IDUR)
    Endif
    If INBMIN < 10 Then
      SZNBMIN = "0" + num$(INBMIN)
    Else
      SZNBMIN = num$(INBMIN)
    Endif
    SZDUR = SZNBHOU + SZNBMIN
    # -----------------------------------------
    #Traitement des heures de la date de fin
    INBHOU = 0
    If dayn(nday$(IDATFIN)) < 6 Then
      # On ignore les samedis et dimanche
      If val(left$(SZHOUFIN,2)) >= 9 Then
        INBHOU = val(left$(SZHOUFIN,2)) - 9
        INBMIN += val(mid$(SZHOUFIN,3,2))
        If INBMIN > 59 Then
          INBHOU += 1
          INBMIN = INBMIN - 60
        Endif
      Endif
      IDUR += INBHOU
      If IDUR < 10 Then
        SZNBHOU = "0" + num$(IDUR)
      Else
        SZNBHOU = num$(IDUR)
      Endif
      If INBMIN < 10 Then
        SZNBMIN = "0" + num$(INBMIN)
      Else
        SZNBMIN = num$(INBMIN)
      Endif
      SZDUR = SZNBHOU + SZNBMIN
    Endif
  Endif
  If val(SZNBHOU) > 99 Then
    SZDUR = "9900"
  Endif
End

