#<AdxTL>@(#)10.0.0.0 $Revision$
# Traitement de sélections pour coûts et PRF    Avril-Mai 2003
##################################################################
# SELECTION D'UN ENREGISTREMENT ARTICLE COUT ou PRF
# remplace le sous-pro SELITC
# utilisé depuis des zones dates ou MFGNUM


$ACTION
#Dbgaff
Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "VERF_TABLE"   : Gosub VERF_TABLE
    When "SEL_LISTE"    : Gosub SEL_LISTE
    When Default
Endcase
Return

###################################################################
#    Choix dans les tables                                        #
###################################################################

$SEL_TABLE
Case TABLE
    When "SELITC"    : If PARAM(3)<"5" Gosub S_ITC Else Gosub S_MFC Endif
    When "SELCSTCOU" : Gosub SEL_CSTCOU
    # le type est obligatoire TYP<5 : ITMCOST ; TYP>=5 : MFGCOST
    # PARAM(3) : type selon le menu local 347
Endcase
Return

$VERF_TABLE
Case TABLE
    When "SELITC" : If PARAM(3)<"5" Gosub V_ITC Else Gosub V_MFC Endif
Endcase
Return

$SEL_LISTE
Case LISTE
    When "SELFCYICU" : Gosub S_FCYICU
Endcase
Return

S_ITC
Local Char SITE
Local Char ART
Local Integer TYP
Local Integer SEQUENCE
Local Date    LDAT

If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
##OBJET = "ITC"  # << peut-être plus utile

LDAT   = VALEUR
SITE   = PARAM(1)
ART    = PARAM(2)
TYP    = val(PARAM(3))

TIT(0) = mess(5,198,1)

NBCOL  += 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "mess([F:ITC]CSTTYP,347,1)"
Call TEXTFIC("ITMCOST","CSTTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITCSTRDAT"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITCENDDAT"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITCDAT"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITCSEQ"
Call TEXTFIC("ITMCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

# alimentation de CRITERE
CRITERE = "CSTTYP = TYP"
If SITE <> ""
  CRITERE -= "& STOFCY = SITE"
Endif
If ART <> ""
  CRITERE -= "& ITMREF = ART"
Endif
If LDAT <> [0/0/0]
    CRITERE -= "& ITCDAT >= LDAT" :# années suivantes pour std et bud
Endif

Default File [ITC]
Return

$V_ITC
# charger les paramètres variables
PARAM(4) = num$([F:ITC]ITCSEQ)
# utiliser TYPARG (variable de GACTION) pour détecter qu'on est sur la date : (ou ajouter param Zone)
If TYPARG = 3
  VALEUR = [F:ITC]ITCDAT
Endif
Return

$S_MFC
# le type est >=5 : sélection sur MFGCOST
# type selon le menu local 347 (regroupant types de coût std ET types de coût d'OF !)
Local Char SITE
Local Char ART
Local Integer TYP, LVCRTYP
Local Date LDAT
Local Integer SEQUENCE

If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
##OBJET = "MFC"
If TYPARG = 3
    LDAT = VALEUR
Endif
SITE   = PARAM(1)
ART    = PARAM(2)
TYP    = val(PARAM(3)) - 4 # correspond au ML 2355 (MFCTYP)
LVCRTYP = val(PARAM(7))
TIT(0) = mess(TYP,2355,1)  # coût de fabrication

NBCOL  += 1 : COL(NBCOL) = "VCRNUM"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "VCRLIN"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "CSTTOT"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "OVETOT"
Call TEXTFIC("MFGCOST",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

# alimentation de CRITERE
Raz GBIDI1, CRITERE
Call ADDCRIT(CRITERE,GBIDI1,"","MFCTYP = TYP","&") From GOBJSUB
Call ADDCRIT(CRITERE,GBIDI1,"","VCRTYP ="+num$(LVCRTYP),"&") From GOBJSUB
If SITE <> ""
    Call ADDCRIT(CRITERE,GBIDI1,"","STOFCY='"+SITE+"'","&") From GOBJSUB
Endif
If ART <> ""
    Call ADDCRIT(CRITERE,GBIDI1,"","ITMREF='"+ART+"'","&") From GOBJSUB
Endif
If LDAT <> [0/0/0]
   CRITERE -= "& MFCDAT>=LDAT"
Endif

Default File [MFC]
If TYPARG <> 3
  START = "VCRNUM" # !! sert au focus ET à alimenter VALEUR à la fin !! Pb si on sélect s/date
Endif            # si elle n'est pas modifiée on ne passera pas dans APRES_MODIF !
Return

$V_MFC
# charger les paramètres variables : VCRNUM, VCRLIN
PARAM(5) = [F:MFC]VCRNUM
PARAM(6) = num$([F:MFC]VCRLIN)
# utiliser TYPARG (variable de GACTION) pour détecter qu'on est sur la date :
If TYPARG = 3
  VALEUR = [F:MFC]MFCDAT  #>> renvoyer aussi Année
Endif

Return

###########################################################################################
$S_FCYICU
Local Char TEXTE(80)(1..dim(TEX),1..2)

TIT(0) = mess(5,198,1)
Link [ITC] With [FCY]FCY0=[F:ITC]STOFCY
&          As [LNK]
&          Where [ITC]UID<>0
&              & [ITC]UPDFLG=2
&            Order By Key K=STOFCY
For [LNK]K(1)
    NBTEX += 1
    TEX(NBTEX)   = [F:ITC]STOFCY
    TEXTE(NBTEX,1) = [F:ITC]STOFCY
    TEXTE(NBTEX,2) = [F:FCY]FCYNAM
    If NBTEX>dim(TEX)
        Break
    Endif
Next
Return

###########################################################################################
$SEL_CSTCOU
  Local Char SITE
  Local Char PRODUCT

  If !clalev([F:STJ]) : Local File STOJOU [STJ] : Endif

  SITE    = PARAM(1)
  PRODUCT = PARAM(2)

  TIT(0) = mess(5,198,1)

  NBCOL  += 1 : COL(NBCOL) = "CSTCOU"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "CSTDAT"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "CSTTIM"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "VCRNUM"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "QTYSTU"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  NBCOL  += 1 : COL(NBCOL) = "AMTVAL"
  Call TEXTFIC("STOJOU",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV


  # alimentation de CRITERE
  CRITERE  = "STOFCY = SITE"
  CRITERE += " & ITMREF = PRODUCT"
  CRITERE += " & QTYSTU > 0"
  CRITERE += " & REGFLG = 1"


  Default File [STJ]

Return

