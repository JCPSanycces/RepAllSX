#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE(mess(1006,182,1)) From LECFIC
    Call GENPIT(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#####################################################################################################################
#                                                                                                                   #
# Régénération des points                                                             Module CRM   24 octobre 2003  #
#                                                                                                                   #
#####################################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
    End
  Endif
  #Si Module Support client non actif. On ne fait rien.
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif
  Call GENPIT(APPLI)
End

#######################################################################
Subprog GENPIT(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRINFPIT
Local Integer ITSTPRONUM

  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME(mess(1004,182,1)) From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #############################
  # Ouverture des tables utiles
  #############################
  If !clalev([F:PCT]) : Local File =SZAPPLI+".PITCOUNT" [PCT] : Endif
  If !clalev([F:DVA]) : Local File =SZAPPLI+".DEFVAL" [DVA] : Endif
  ITSTPRONUM = 0
  IERRINFPIT = 0
  #Exécution du traitement
  Gosub EXECPIT
  If IERRINFPIT Then
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TIME(mess(1003,182,1)) From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Else
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    Call ECR_TIME(mess(1005,182,1)) From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
End

####################################################################
$EXECPIT
Local Integer STAT, I, J
Local Integer WADXUID(1..1000)
Local Integer WDIM
Local Integer WTRBEGIN : Raz WTRBEGIN

  Call UIDADX(WADXUID,WDIM) From TRTX3
  Raz I, J
  # Si pas de transaction en cours
  If adxlog <> 1 Then 
    Trbegin [PCT]
    WTRBEGIN = 1
  Endif
  Filter [DVA] Where [F:DVA]OBC = "PIT"
  For [DVA]
    If !find([F:DVA]INTX(0),WADXUID(1..WDIM)) Then
      If [F:DVA]ALHX(0) = "" Then
        #Création
        Delete [PCT] Where [F:PCT]SRENUM = [F:DVA]ALHX(1)
&                      and [F:PCT]TPYFLG = [F:DVA]INTX(2)
&                      and [F:PCT]BPC = [F:DVA]ALHX(2)
&                      and [F:PCT]MAC = [F:DVA]ALHX(3)
&                      and [F:PCT]PBL = [F:DVA]ALHX(4)
&                      and [F:PCT]HDT = [F:DVA]ALHX(5)
&                      and [F:PCT]HDTSEQ = [F:DVA]ALHX(6)
      Else
        Readlock [PCT]PCT0=[F:DVA]ALHX(1);[F:DVA]INTX(2);0;[F:DVA]ALHX(2);[F:DVA]ALHX(3);[F:DVA]ALHX(4);[F:DVA]ALHX(5);[F:DVA]ALHX(6)
        If !fstat Then
          [F:PCT]PIT = [F:DVA]INTX(1)
          Rewrite [PCT]
        Endif
        Unlock [PCT]
        If !fstat Then
          Delete [PCT] Where [F:PCT]SRENUM = [F:DVA]ALHX(1)
&                        and [F:PCT]TPYFLG = [F:DVA]INTX(2)
&                        and [F:PCT]FGVCAH = 1
&                        and [F:PCT]BPC = [F:DVA]ALHX(2)
&                        and [F:PCT]MAC = [F:DVA]ALHX(3)
&                        and [F:PCT]PBL = [F:DVA]ALHX(4)
&                        and [F:PCT]HDT = [F:DVA]ALHX(5)
&                        and [F:PCT]HDTSEQ = [F:DVA]ALHX(6)
        Endif
      Endif
      If fstat Then
        #Error while processing a point record.
        IERRINFPIT = 1
        Break
      Endif
      Delete [DVA]Curr
      If fstat Then
        #Error while processing a point record.
        IERRINFPIT = 1
        Break
      Endif
    Endif
  Next
  Filter [DVA]
  # Si on a ouvert une transaction
  If WTRBEGIN = 1 Then
    If IERRINFPIT Then
      Rollback
      ITSTPRONUM = 1
    Else
      Commit
    Endif
    Raz WTRBEGIN
  Endif
Return
