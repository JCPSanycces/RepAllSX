#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PIMPL
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PIMPL_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PIMPL_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PIMPL_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PIMPL_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PIMPL_CSTD_METHODS  # Issue X3-51863 - 2017-08-07 by FGR
    When "IS_USED_IN_ERP"              : Gosub IS_USED_IN_ERP                  From PIMPL_CSTD_METHODS  # Issue X3-4071/119443 - 2016-10-27 by FGR
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "OPPNUM"                      : Gosub OPPNUM                          From PIMPL_CSTD_PROPERTIES
    When "FCY"                         : Gosub FCY                             From PIMPL_CSTD_PROPERTIES
    When "CPY"                         : Gosub CPY                             From PIMPL_CSTD_PROPERTIES
    When "PBUCOD"                      : Gosub PBUCOD                          From PIMPL_CSTD_PROPERTIES
    When "TASCOD"                      : Gosub TASCOD                          From PIMPL_CSTD_PROPERTIES
    When "PIMSTA"                      : Gosub PIMSTA                          From PIMPL_CSTD_PROPERTIES
    When "FINRSPFCY"                   : Gosub FINRSPFCY                       From PIMPL_CSTD_PROPERTIES
    When Default
  Endcase
Return

