#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque SLT0
#######################################################################
# SUBSLT : Transactions de saisie des modifs de lots                  #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                                                                     #
# Nom des écrans générés : WT4yyy                                     #
#                          yyy = nom de la transaction (SRTNUM)       #
#                                                                     #
#######################################################################
Call OBJET("SLT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "FILTRE"      : Gosub FILTRE
    When "EFFMASK"     : [M:SLT0]SRTTYP = 4
    When "SETBOUT"     : Gosub SETBOUT
    When "EXEBOUT"     : Gosub EXEBOUT
    When "LIENS"       : Gosub LIENS
    When "RAZCRE"      : Gosub RAZCRE
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "INICRE"      : Gosub INICRE
    When "INIMOD"      : Gosub INIMOD
    When "CREATION"    : Gosub TRT_ECRAN
    When "MODIF"       : Gosub TRT_ECRAN
    When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                         Gosub TRT_ECRAN
    When "AV_IMPRIME"  : Gosub COP_ECRAN
    When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
    When "FERME"       : Call IMPSCR        From ATRTX3
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When Default
Endcase
Return

$PE_STKTRS
   Gosub PE_STKTRS From SUBSKX
Return

############################################################
$COP_ECRAN
Local Char WINT(20)(2)
Local Char WTIT(100)
Local Char WMSK(GLONAMK)(3)
Local Char WABR(06)(3)

Raz WMSK, WABR
Call TEXTFIC("STKTRS","TRSNUM",2,WINT(0)) From OBJDIV
Call TEXTFIC("STKTRS","ACSCOD",2,WINT(1)) From OBJDIV
WTIT = WINT(0)+" : "+[M:SLT0]SRTNUM-[M:SLT0]DESAXX-WINT(1)+" : "+[M:SLT0]ACSCOD
WMSK(0) = "SLT1"
WMSK(1) = "SLT2"
Call PRTSCR(WMSK,WABR,WTIT,0,0) From ATRTX3
Return

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Integer  WNUM(2)          : WNUM = 4
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)

Local    Mask ITGSTA [ISTA] # pour statuts en tableau

Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE
FILTSUP = "SRTTYP=4"
Return

#----------------------------------------------#
# Désactivation bouton "Validation" et "Copie" #
#----------------------------------------------#
$SETBOUT
If GREP <> "" or !CLECUR : Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Return

#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT
Case BOUT
    When "1" : Call DEBTRANS From GLOCK
               Trbegin ADOVAL
               Gosub TRT_ECRAN : If GOK < 1 : Rollback : Else : Commit : Endif
    When Default
Endcase
Return

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
Local Integer I

WMODU += format$("N0:2",[M:SLT0]SRTTYP)

#-- Positionnement des valeurs si non renseignées
If [M:SLT0]ENAFLG=0    : [M:SLT0]ENAFLG=2     : Endif
If [M:SLT1]PJTCOD=0    : [M:SLT1]PJTCOD=1     : Endif      # affaire
If [M:SLT1]TRSFAMCOD=0 : [M:SLT1]TRSFAMCOD=1  : Endif      # famille mouvement

If [M:SLT1]MVTDESCOD = 0 : [M:SLT1]MVTDESCOD = 3  : Endif   # désignation mouvement

#----------- Affichage --------------#

If dim([M:SLT1]LOTCOD) > 0
    If [M:SLT1]LOTCOD = 0 : [M:SLT1]LOTCOD = 2 : Endif :
Endif
If dim([M:SLT1]LOTCOD1) > 0
    If [M:SLT1]LOTCOD1 = 0 : [M:SLT1]LOTCOD1 = 2 : Endif :
Endif

If dim([M:SLT1]SLOCOD) > 0
    If [M:SLT1]SLOCOD = 0 : [M:SLT1]SLOCOD = 2 : Endif :
Endif

If dim([M:SLT1]ECCCOD) > 0
    If [M:SLT1]ECCCOD = 0  : [M:SLT1]ECCCOD = 1  : Endif   # hcb 71276
Endif
If dim([M:SLT2]BPSLOTCOD) > 0
    If [M:SLT2]BPSLOTCOD = 0  : [M:SLT2]BPSLOTCOD = 2  : Endif   # lot fournisseur
Endif


If dim([M:SLT2]SERCOD) > 0
    If [M:SLT2]SERCOD = 0  : [M:SLT2]SERCOD = 2  : [M:SLT2]SERSCR = 1   : Endif   # n° série
Endif

If dim([M:SLT2]IDECOD1) > 0
    If [M:SLT2]IDECOD1 = 0 : [M:SLT2]IDECOD1 = 2 : [M:SLT2]IDESCR1 = 1  : Endif   # Palnum
Endif

If dim([M:SLT2]IDECOD2) > 0
    If [M:SLT2]IDECOD2 = 0 : [M:SLT2]IDECOD2 = 2 : [M:SLT2]IDESCR2 = 1   : Endif  # Ctrnum
Endif


Gosub GRISAGE
Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
Local Integer I

Raz [M:SLT0]
Raz [M:SLT1]
Raz [M:SLT2]
[M:SLT0]ENAFLG = 2

[M:SLT1]CHANGECOD = 1
[M:SLT1]PJTCOD = 3
[M:SLT1]TRSFAMCOD = 3
#                                      # hcb 71276 deb
[M:SLT1]LOTCOD1 = 2
If dim([M:SLT1]ECCCOD)>0
   [M:SLT1]ECCCOD = 1
Endif
#                                      # hcb 71276 fin


[M:SLT2]BPSLOTCOD = 1
[M:SLT2]PRNSCR1 = 1
[M:SLT2]PRNNBFLG1 = 1
[M:SLT2]PRNNBSCR1 = 1

WMODU += format$("N0:2",[M:SLT0]SRTTYP)
[M:SLT1]MVTDESCOD = 3

Gosub GRISAGE
Gosub PE_STKTRS

Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
    When "PRNCOD1":       If val(CZ) = 1
                              [M:SLT2]PRNSCR1 = 1
                              [M:SLT2]PRNNBFLG1 = 1
                              [M:SLT2]PRNNBSCR1 = 1
                              If !GIMPORT
                                  Grizo [M:SLT2]PRNSCR1    : Affzo [M:SLT2]PRNSCR1
                                  Grizo [M:SLT2]PRNNBFLG1  : Affzo [M:SLT2]PRNNBFLG1
                                  Grizo [M:SLT2]PRNNBSCR1  : Affzo [M:SLT2]PRNNBSCR1
                              Endif
                          Else
                              If !GIMPORT & [M:SLT1]CHANGECOD = 2
                                  Actzo [M:SLT2]PRNSCR1
                                  Actzo [M:SLT2]PRNNBFLG1
                                  Actzo [M:SLT2]PRNNBSCR1
                              Endif
                          Endif
    When "PRNNBFLG1":     If val(CZ) = 1
                              [M:SLT2]PRNNBSCR1 = 1
                              If !GIMPORT : Grizo [M:SLT2]PRNNBSCR1: Affzo [M:SLT2]PRNNBSCR1 : Endif
                          Else
                              If !GIMPORT & [M:SLT1]CHANGECOD = 2 : Actzo [M:SLT2]PRNNBSCR1 : Endif
                          Endif
    When "SERCOD":        If dim([M:SLT2]SERCOD) > 0
                              If val(CZ) = 2
                                  [M:SLT2]SERSCR = 1
                                  If !GIMPORT  : Grizo [M:SLT2]SERSCR : Affzo [SLT2]SERSCR : Endif
                              Else
                                  If !GIMPORT & [M:SLT1]CHANGECOD = 2 :  Actzo [SLT2]SERSCR : Endif
                              Endif
                          Endif
    When "IDECOD1":       If val(CZ) = 2
                              [M:SLT2]IDESCR1 = 1
                              If !GIMPORT : Grizo [M:SLT2]IDESCR1 : Affzo [M:SLT2]IDESCR1 : Endif
                          Else
                              If !GIMPORT & [M:SLT1]CHANGECOD = 2 : Actzo [M:SLT2]IDESCR1 : Endif
                          Endif
    When "IDECOD2":       If val(CZ) = 2
                              [M:SLT2]IDESCR2 = 1
                              If !GIMPORT : Grizo [M:SLT2]IDESCR2 : Affzo [M:SLT2]IDESCR2 : Endif
                          Else
                              If !GIMPORT & [M:SLT1]CHANGECOD = 2 : Actzo [M:SLT2]IDESCR2 : Endif
                          Endif
Endcase

Gosub PE_STKTRS
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "SLT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "SLT0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

$FILGAUCHE
CRITERE = "SRTTYP=4"
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI) < 0 : Local Char APPLI : Endif
If dim(WMODU) < 0 : Local Char WMODU : Endif
If APPLI = ""     : APPLI=nomap      : Endif
If dim(OK) < 0    : Local Integer OK : Endif

Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
# Local Char     TEXTE(40), LISTE(3), REPONS(1)
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK

If WMODU = "" : WMODU = "T" + format$("N0:2",[M:SLT0]SRTTYP) : Endif

#---------------- Noms fenêtres et traitement ---------#
Local Char     WINREF1(GLONFEN)
Local Char     NOMWIN1(GLONFEN)
Local Char     NOMMSKENT(GLONAMK)

Case [M:SLT1]CHANGECOD
    When 1:    WINREF1="OSMX"
               NOMWIN1="WOSMX"+[M:SLT0]SRTNUM
               #MFROM="SMX1"     # Issue 99277 - 2018-09-03 by MAE : responsive UI
    When 2:    WINREF1="OSLM"
               NOMWIN1="WOSLM"+[M:SLT0]SRTNUM
               MFROM="SLM1"
#MAE, bg 50003
#    When 3:    WINREF1="DSMU"
#               NOMWIN1="WDSMU"+[M:SLT0]SRTNUM
#               MFROM="SMU1"

Endcase
# Issue 99277 - 2018-09-03 by MAE : responsive UI deb
#MTO="W"+WMODU+[M:SLT0]SRTNUM+"1"
#génération de l'écran d'entête
If [M:SLT1]CHANGECOD = 1
  MFROM = "SMX0"
  MTO="W"+WMODU+[M:SLT0]SRTNUM+"0"
  NOMMSKENT=MTO
  #--------------------------
  Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
  If ACTION <> "ANNULE"
    If [M:SLT1]PJTCOD > 1
         TZONE(IZON) = "PJT"
         TMOD(IZON)  = [M:SLT1]PJTCOD
         IZON += 1
    Endif
    If [M:SLT1]TRSFAMCOD > 1
        TZONE(IZON) = "TRSFAM"
        TMOD(IZON)  = [M:SLT1]TRSFAMCOD
        IZON += 1
    Endif
    If [M:SLT1]MVTDESCOD > 1
        TZONE(IZON) = "MVTDES"
        TMOD(IZON)  = [M:SLT1]MVTDESCOD
        IZON += 1
    Endif
    OPT1 = 2
    Gosub PE_STKTRS
  Else
    OPT1 = 9
  Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR <> 0 : GOK=0 : Return : Endif
Endif
# Issue 99277 - 2018-09-03 by MAE : responsive UI end

#--------------------------
MTO="W"+WMODU+[M:SLT0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION <> "ANNULE"
  If [M:SLT1]CHANGECOD = 2      # Issue 99277 - 2018-09-03 by MAE : responsive UI
    If [M:SLT1]PJTCOD > 1
         TZONE(IZON) = "PJT"
         TMOD(IZON)  = [M:SLT1]PJTCOD
         IZON += 1
    Endif
    If [M:SLT1]TRSFAMCOD > 1
        TZONE(IZON) = "TRSFAM"
        TMOD(IZON)  = [M:SLT1]TRSFAMCOD
        IZON += 1
    Endif
    If [M:SLT1]MVTDESCOD > 1
        TZONE(IZON) = "MVTDES"
        TMOD(IZON)  = [M:SLT1]MVTDESCOD
        IZON += 1
    Endif
   Else                      # Issue 99277 - 2018-09-03 by MAE : responsive UI deb
     MFROM = "SMX1"
   Endif                     # Issue 99277 - 2018-09-03 by MAE : responsive UI end
#                                                   # hcb 71276 deb
    If dim([M:SLT1]ECCCOD) > 0
         If [M:SLT1]ECCCOD = 1
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "ECCSTA"
            TMOD(IZON)  = 2
            IZON += 1
         Else
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 1
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 1
            IZON += 1
            TZONE(IZON) = "ECCSTA"
            TMOD(IZON)  = 2
            IZON += 1
         Endif
    Endif
#                                                   # hcb 71276 fin

    # si modification caractéristiques
    If [M:SLT1]CHANGECOD = 1
        If dim([M:SLT2]POTCOD) > 0
            If [M:SLT2]POTCOD > 1
                TZONE(IZON) = "POTOLD"
                TMOD(IZON)  = [M:SLT2]POTCOD
                IZON += 1
                TZONE(IZON) = "POT"
                TMOD(IZON)  = [M:SLT2]POTCOD
                IZON += 1
            Endif
        Endif
        If dim([M:SLT2]BPSLOTCOD) > 0
            If [M:SLT2]BPSLOTCOD > 1
                TZONE(IZON) = "BPSLOTOLD"
                TMOD(IZON)  = [M:SLT2]BPSLOTCOD
                IZON += 1
                TZONE(IZON) = "BPSLOT"
                TMOD(IZON)  = [M:SLT2]BPSLOTCOD
                IZON += 1
            Endif
        Endif

        If [M:SLT2]PERCOD > 1
            TZONE(IZON) = "REFPER"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHL"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLDAT"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
#                                            V6per deb
            TZONE(IZON) = "SHLUOM"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "DLU"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "DLUDAT"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLLTI"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLLTIUOM"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "NEWLTIDAT"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
#                                            V6per fin
        Endif
        If find([M:SLT2]PERCOD,2,3)
            TZONE(IZON) = "XREFPEROLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "XSHLDATOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
#                                            V6per deb
            TZONE(IZON) = "SHLUOMOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "DLUOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "XDLUDATOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLLTIOLD"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "SHLLTIUOMO"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
            TZONE(IZON) = "XNEWLTIDAT"
            TMOD(IZON)  = [M:SLT2]PERCOD
            IZON += 1
#                                            V6per fin
        Else
            TZONE(IZON) = "XREFPEROLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "SHLOLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "XSHLDATOLD"
            TMOD(IZON)  = 2
            IZON += 1
#                                            V6per deb
            TZONE(IZON) = "SHLUOMOLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "DLUOLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "XDLUDATOLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "SHLLTIOLD"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "SHLLTIUOMO"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "XNEWLTIDAT"
            TMOD(IZON)  = 2
            IZON += 1
#                                            V6per fin
        Endif
        # champ util 1
        TZONE(IZON) = "USRFLD1"
        If [M:SLT2]SRUB1FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD2"
        If [M:SLT2]SRUB2FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD3"
        If [M:SLT2]SRUB3FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD4"
        If [M:SLT2]SRUB4FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD1OLD"
        If [M:SLT2]SRUB1FLG = 2 : TMOD(IZON)  = 2 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD2OLD"
        If [M:SLT2]SRUB2FLG = 2 : TMOD(IZON)  = 2 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD3OLD"
        If [M:SLT2]SRUB3FLG = 2 : TMOD(IZON)  = 2 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
        TZONE(IZON) = "USRFLD4OLX"
        If [M:SLT2]SRUB4FLG = 2 : TMOD(IZON)  = 2 : Else : TMOD(IZON) = 2 : Endif     # hcb 71276
        IZON += 1
    Else
        If dim([M:SLT1]LOTCOD) > 0
            If [M:SLT1]LOTCOD > 1
                TZONE(IZON) = "LOTDES"
                TMOD(IZON)  = [M:SLT1]LOTCOD
                IZON += 1
            Endif
        Endif
        If dim([M:SLT1]SLOCOD) > 0
            If [M:SLT1]SLOCOD > 1
                TZONE(IZON) = "SLODES"
                TMOD(IZON)  = [M:SLT1]SLOCOD
                IZON += 1
            Endif
        Endif
        If [M:SLT2]PRNCOD1 = 1
            TZONE(IZON) = "LBEFMT"
            TMOD(IZON)  = 3
           IZON += 1
        Endif
        If [M:SLT2]PRNSCR1 > 1
            TZONE(IZON) = "LBEFMT"
            TMOD(IZON)  = 9
            TINT(IZON)  = num$([M:SLT2]PRNSCR1)
            IZON += 1
       Endif
       If [M:SLT2]PRNNBFLG1=1
           TZONE(IZON) = "LBENBR"
           TMOD(IZON)  = 3
           IZON += 1
       Endif
       If [M:SLT2]PRNNBSCR1 > 1
           TZONE(IZON) = "LBENBR"
           TMOD(IZON)  = 9
           TINT(IZON)  = num$([M:SLT2]PRNNBSCR1)
           IZON += 1
       Endif
       If dim([M:SLT2]SERCOD) > 0
           If [M:SLT2]SERCOD > 1
               TZONE(IZON) = "SERNUM"
               TMOD(IZON)  = 3
               IZON += 1
           Endif
           If [M:SLT2]SERSCR > 1
               TZONE(IZON) = "SERNUM"
               TMOD(IZON)  = 9
               TINT(IZON)  = num$([M:SLT2]SERSCR)
               IZON += 1
           Endif
       Endif
       If [M:SLT2]IDECOD1 > 1
           TZONE(IZON) = "PALNUM"
           TMOD(IZON)  = 3
           IZON += 1
       Endif
       If [M:SLT2]IDESCR1 > 1
           TZONE(IZON) = "PALNUM"
           TMOD(IZON)  = 9
           # FGR 15/01/2010 : X3SUIVI60986
           #TINT(IZON)  = num$([M:SLT2]IDESCR)
           TINT(IZON)  = num$([M:SLT2]IDESCR1)
           IZON += 1
       Endif
       If [M:SLT2]IDECOD2 > 1
           TZONE(IZON) = "CTRNUM"
           TMOD(IZON)  = 3
           IZON += 1
       Endif
       If [M:SLT2]IDESCR2 > 1
           TZONE(IZON) = "CTRNUM"
           TMOD(IZON)  = 9
           # FGR 15/01/2010 : X3SUIVI60986
           #TINT(IZON)  = num$([M:SLT2]IDESCR)
           TINT(IZON)  = num$([M:SLT2]IDESCR2)
           IZON += 1
       Endif
    Endif
    OPT1 = 2
    Gosub PE_STKTRS
Else
    OPT1 = 9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR <> 0 : GOK=0 : Return : Endif

If ACTION = "ANNULE" : Gosub TRT_SUP_FEN : Else : Gosub TRT_GEN_FEN : Endif

# génération pour la modification série
If [M:SLT1]CHANGECOD <> 1 : Return : Endif

# écran critère
WINREF1="DSMXUPD"
NOMWIN1="WDSMX"+[M:SLT0]SRTNUM
Raz NOMMSKENT   # Issue 99277 - 2018-09-11 by MAE : raz de l'écran entête
MFROM="SMXUPD1"
MTO="W"+WMODU+[M:SLT0]SRTNUM+"D"

If ACTION <> "ANNULE"
    If [M:SLT1]PJTCOD > 1
         TZONE(IZON) = "PJT"
         TMOD(IZON)  = [M:SLT1]PJTCOD
         IZON += 1
    Endif
    If [M:SLT1]TRSFAMCOD > 1
        TZONE(IZON) = "TRSFAM"
        TMOD(IZON)  = [M:SLT1]TRSFAMCOD
        IZON += 1
    Endif
    If [M:SLT1]MVTDESCOD > 1
        TZONE(IZON) = "MVTDES"
        TMOD(IZON)  = [M:SLT1]MVTDESCOD
        IZON += 1
    Endif
#                                          # hcb 71276 deb
    If dim([M:SLT1]ECCCOD) > 0
        If [M:SLT1]ECCCOD = 2
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 1
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 1
            IZON += 1
        Else
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 2
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 2
            IZON += 1
        Endif
    Endif
#                                          # hcb 71276 fin
    If dim([M:SLT2]POTCOD) > 0
        If [M:SLT2]POTCOD > 1
            TZONE(IZON) = "POT"
            TMOD(IZON)  = [M:SLT2]POTCOD
            IZON += 1
        Endif
    Endif
    If dim([M:SLT2]BPSLOTCOD) > 0
        If [M:SLT2]BPSLOTCOD > 1
            TZONE(IZON) = "BPSLOT"
            TMOD(IZON)  = [M:SLT2]BPSLOTCOD
            IZON += 1
        Endif
    Endif

    If [M:SLT2]PERCOD > 1
        TZONE(IZON) = "REFPER"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHL"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
#                                            V6per deb
        TZONE(IZON) = "SHLUOM"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "DLU"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "DLUDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLLTI"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLLTIUOM"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "NEWLTIDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
#                                            V6per fin
    Endif
    # champ util 1
    TZONE(IZON) = "USRFLD1"
    If [M:SLT2]SRUB1FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif    # hcb 71276
    IZON += 1
    TZONE(IZON) = "USRFLD2"
    If [M:SLT2]SRUB2FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif    # hcb 71276
    IZON += 1
    TZONE(IZON) = "USRFLD3"
    If [M:SLT2]SRUB3FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif    # hcb 71276
    IZON += 1
    TZONE(IZON) = "USRFLD4"
    If [M:SLT2]SRUB4FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 2 : Endif    # hcb 71276
    IZON += 1
    OPT1 = 2
    Gosub PE_STKTRS
Else
    OPT1 = 9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR <> 0 : GOK=0 : Return : Endif

If ACTION = "ANNULE" : Gosub TRT_SUP_FEN : Else : Gosub TRT_GEN_FEN : Endif

# écran modif
WINREF1="FSMXUPD"
NOMWIN1="WFSMX"+[M:SLT0]SRTNUM
MFROM="SMXUPD2"
MTO="W"+WMODU+[M:SLT0]SRTNUM+"F"
If ACTION <> "ANNULE"
    If [M:SLT1]PJTCOD > 1
         TZONE(IZON) = "PJT"
         TMOD(IZON)  = [M:SLT1]PJTCOD
         IZON += 1
    Endif
    If [M:SLT1]TRSFAMCOD > 1
        TZONE(IZON) = "TRSFAM"
        TMOD(IZON)  = [M:SLT1]TRSFAMCOD
        IZON += 1
    Endif
    If [M:SLT1]MVTDESCOD > 1
        TZONE(IZON) = "MVTDES"
        TMOD(IZON)  = [M:SLT1]MVTDESCOD
        IZON += 1
    Endif
    If dim([M:SLT2]POTCOD) > 0
        If [M:SLT2]POTCOD > 1
            TZONE(IZON) = "POT"
            TMOD(IZON)  = [M:SLT2]POTCOD
            IZON += 1
        Endif
    Endif
#                                          # hcb 71276 deb
    If dim([M:SLT1]ECCCOD) > 0
        If [M:SLT1]ECCCOD = 2
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 1
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 1
            IZON += 1
        Else
            TZONE(IZON) = "ECCVALMAJ"
            TMOD(IZON)  = 3
            IZON += 1
            TZONE(IZON) = "ECCVALMIN"
            TMOD(IZON)  = 3
            IZON += 1
        Endif
    Endif
#                                          # hcb 71276 fin

    If dim([M:SLT2]BPSLOTCOD) > 0
        If [M:SLT2]BPSLOTCOD > 1
            TZONE(IZON) = "BPSLOT"
            TMOD(IZON)  = [M:SLT2]BPSLOTCOD
            IZON += 1
        Endif
    Endif

    If [M:SLT2]PERCOD > 1
        TZONE(IZON) = "REFPER"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHL"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
#                                            V6per deb
        TZONE(IZON) = "SHLUOM"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "DLU"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "DLUDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLLTI"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "SHLLTIUOM"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
        TZONE(IZON) = "NEWLTIDAT"
        TMOD(IZON)  = [M:SLT2]PERCOD
        IZON += 1
#                                            V6per fin

    Endif
    # champ util 1
    TZONE(IZON) = "USRFLD1"
    If [M:SLT2]SRUB1FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 3 : Endif
    IZON += 1
    TZONE(IZON) = "USRFLD2"
    If [M:SLT2]SRUB2FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 3 : Endif
    IZON += 1
    TZONE(IZON) = "USRFLD3"
    If [M:SLT2]SRUB3FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 3 : Endif
    IZON += 1
    TZONE(IZON) = "USRFLD4"
    If [M:SLT2]SRUB4FLG = 2 : TMOD(IZON)  = 1 : Else : TMOD(IZON) = 3 : Endif
    IZON += 1
    OPT1 = 2
    Gosub PE_STKTRS
Else
    OPT1 = 9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR <> 0 : GOK=0 : Return : Endif

If ACTION = "ANNULE" : Gosub TRT_SUP_FEN : Else : Gosub TRT_GEN_FEN : Endif
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI]) = 0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP]) = 0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB]) = 0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT]) = 0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -----#
Gosub TRT_SUP_FEN
If [M:SLT0]ENAFLG = 1  : Return : Endif
#----- Génération fenêtre pour réception si transaction active -----#
Read [AWI]AWI0=WINREF1
If !fstat
    [F:AWI]WIN       = NOMWIN1
    [F:AWI]MSKENT    = NOMMSKENT
    WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
    Case [M:SLT1]CHANGECOD
        When 1: I=find("SMX1",[F:AWI]NOMMSK(0..7))-1 : If I < 0 : I = 0 : Endif
        When 2: I=find("SLM1",[F:AWI]NOMMSK(0..7))-1 : If I < 0 : I = 0 : Endif
        #MAE, bg 50003
        #When 3: I=find("SMU1",[F:AWI]NOMMSK(0..7))-1 : If I < 0 : I = 0 : Endif
    Endcase
    [F:AWI]NOMMSK(I) = WNOMMSK
    [F:AWI]FLGMSK(I) = WFLGMSK
    [F:AWI]ACS       = [M:SLT0]ACSCOD
    [F:AWI]LIBEL     = [M:SLT0]DESAXX
    [F:AWI]ENAFLG    = 2
    [F:AWI]TRN       = [M:SLT0]SRTNUM
    [F:AWI]MDL       = 1            # !!
    Write [AWI]
    If fstat : GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
    For [AWP]AWP0 Where WIN=WINREF1
        [F:AWP]WIN = NOMWIN1
        Write [AWP]
        If fstat : GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
    Next
    For [AWB]AWB0 Where WIN=WINREF1
        [F:AWB]WIN = NOMWIN1
        Write [AWB]
        If fstat : GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
    Next
    For [AWT]AWT0 Where WIN=WINREF1
        [F:AWT]WIN = NOMWIN1
        Write [AWT]
        If fstat : GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
    Next
    If GOK < 1 : Return : Endif
Endif
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
If !OK  : GOK=0 : Return : Endif
Return

#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 : Local File =APPLI+".AMSK"    [AMK] : Endif
Read [AMK]CODMSK=WNOMMSK
If fstat
    Raz [F:AMK]
    WFLGMSK=2
    Return
Endif

WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
    If [F:AMK]TYPBLOC(I)<>5
        WFLGMSK=2
        Break
    Endif
Next I
Return

#########################################################################
#                   Actions sur champs écran [M:SRT1]                   #
#########################################################################

########################################
Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
[M:SLT0]SRTTYP = 4
End

########################################
$GRISAGE

Case [M:SLT1]CHANGECOD
    When 1:    Grizo [M:SLT1]10
               Grizo [M:SLT1]15
               Grizo [M:SLT1]25
               Actzo [M:SLT1]LOTCOD1              # hcb 71276
               If dim([SLT1]ECCCOD) > 0           # hcb 71276
                  Actzo [M:SLT1]ECCCOD            # hcb 71276
               Else                               # hcb 71276
                  [M:SLT1]LOTCOD1 = 2             # hcb 71276
                  Diszo [M:SLT1]LOTCOD1           # hcb 71276
               Endif                              # hcb 71276
               If dim([SLT1]ECCCOD) > 0           # hcb 71276
                  Actzo [M:SLT1]ECCCOD            # hcb 71276
                  Actzo  [M:SLT1]LOTCOD1          # hcb 71276
               Else
                  Diszo  [M:SLT1]LOTCOD1          # hcb 71276
               Endif                              # hcb 71276
               Actzo [M:SLT2]5
               Grizo [M:SLT2]15
               Grizo [M:SLT2]PRNSCR1
               Grizo [M:SLT2]PRNNBSCR1
               [M:SLT1]RENUMCOD = 1
               [M:SLT1]MIXCOD = 1
    When 2:    Actzo [M:SLT1]10
               Actzo [M:SLT1]15
               Actzo [M:SLT1]25
               [M:SLT1]LOTCOD1 = 1              # hcb 71276
               Diszo [M:SLT1]LOTCOD1            # hcb 71276
               If dim([SLT1]ECCCOD) > 0         # hcb 71276
                  Grizo [M:SLT1]ECCCOD          # hcb 71276
                  [M:SLT1]ECCCOD = 1            # hcb 71276
               Endif                            # hcb 71276

               Grizo [M:SLT2]5
               Actzo [M:SLT2]15
               Actzo [M:SLT2]PRNSCR1
               Actzo [M:SLT2]PRNNBSCR1
Endcase

If [M:SLT2]PRNCOD1 = 1   : Grizo [SLT2]PRNSCR1, PRNNBSCR1, PRNNBFLG1
Else                     : Actzo [SLT2]PRNSCR1, PRNNBSCR1, PRNNBFLG1                : Endif
If [M:SLT2]PRNNBFLG1 = 1 : Grizo [SLT2]PRNNBSCR1   : Else : Actzo [SLT2]PRNNBSCR1   : Endif

If dim([M:SLT2]SERCOD) > 0 & [M:SLT1]CHANGECOD = 2
    If [M:SLT2]SERCOD = 2  : Grizo [M:SLT2]SERSCR  : Else : Actzo [SLT2]SERSCR    : Endif
Endif
If dim([M:SLT2]IDECOD1)> 0  & [M:SLT1]CHANGECOD = 2
    If [M:SLT2]IDECOD1 = 2 : Grizo [M:SLT2]IDESCR1 : Else : Actzo [SLT2]IDESCR1   : Endif
Endif
If dim([M:SLT2]IDECOD2)> 0 & [M:SLT1]CHANGECOD = 2
    If [M:SLT2]IDECOD2 = 2 : Grizo [M:SLT2]IDESCR2 : Else : Actzo [SLT2]IDESCR2   : Endif
Endif

# Issue 110121 - 2015-08-10 by MUARN : ajout rang
Affzo [M:SLT0]1-99
Affzo [M:SLT1]1-99
Affzo [M:SLT2]1-99
Return

Subprog AS_PRNCOD1(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1                     # hcb X3-92342
GMENLOC(7) = 1                     # hcb X3-92342
End

Subprog AS_LOTCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

Subprog AS_SLOCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

Subprog AM_CHANGECOD(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    Grizo [M:SLT1]10 : Grizo [M:SLT1]15
               Grizo [M:SLT1]25
               [M:SLT1]LOTCOD1 = 2                  # hcb 71276
               Actzo  [M:SLT1]LOTCOD1               # hcb 71276
               If dim([SLT1]ECCCOD) > 0             # hcb 71276
                  Actzo [M:SLT1]ECCCOD              # hcb 71276
                  [M:SLT1]ECCCOD = 1                # hcb 71276
                  Actzo  [M:SLT1]LOTCOD1            # hcb 71276
               Else
                  Diszo  [M:SLT1]LOTCOD1            # hcb 71276
               Endif                                # hcb 71276
               Actzo [M:SLT2]5
               Grizo [M:SLT2]15
               Grizo [M:SLT2]PRNSCR1
               Grizo [M:SLT2]PRNNBSCR1
               [M:SLT1]RENUMCOD = 1
               [M:SLT1]MIXCOD = 1
    When 2:    Actzo [M:SLT1]10 : Actzo [M:SLT1]15
               Actzo [M:SLT1]25
               [M:SLT1]LOTCOD1 = 1                  # hcb 71276
               Diszo [M:SLT1]LOTCOD1                # hcb 71276
               If dim([SLT1]ECCCOD) > 0             # hcb 71276
                  [M:SLT1]ECCCOD = 1                # hcb 71276
                  Diszo [M:SLT1]ECCCOD              # hcb 71276
               Endif                                # hcb 71276
               Grizo [M:SLT2]5
               Actzo [M:SLT2]15
               Actzo [M:SLT2]PRNSCR1
               Actzo [M:SLT2]PRNNBSCR1
Endcase
Affzo [M:SLT1]10
Affzo [M:SLT1]25
Affzo [M:SLT2]
End

Subprog C_MIXCOD(VALEUR)
Variable Integer VALEUR
If [M:SLT1]CHANGECOD = 1 : End : Endif
If VALEUR <> 2 & [M:SLT1]RENUMCOD <> 2
    mkstat = 2
Endif
End

Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()
# contrôle en cas de saisie directe :
VALEUR = toupper(VALEUR)
Call CTR_LIST_SST(VALEUR,[M:SLT1]AUZSTA) From TRTCATEG

# construction de la formule :
Call DECODE_STAT(VALEUR,[M:SLT1]FORSTA) From TRTCATEG

End

Subprog PATCH(APPLI)
Value Char APPLI

If APPLI = "X3" : End : Endif
If !clalev([F:ADS]) :  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6) <> 2 : End : Endif

Call GENPATCH(4,APPLI) From FUNSTKTRS
End

###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI
Call GENDOS(4,APPLI) From FUNSTKTRS
End


Subprog AV_LOTCOD(VALEUR)
Variable Integer VALEUR
If GFONCTION <> "GESSLT" : End : Endif
If [M:SLT1]MIXCOD = 2
    VALEUR = 1 : Diszo [M:SLT1]LOTCOD
    If dim([M:SLT1]SLOCOD) > 0 : [M:SLT1]SLOCOD = 1 : Diszo [M:SLT1]SLOCOD : Endif
Else
    If [M:SLT1]CHANGECOD = 2
        Actzo [M:SLT1]LOTCOD
        If dim([M:SLT1]SLOCOD) > 0 : Actzo [M:SLT1]SLOCOD : Endif
    Endif
Endif
End



#################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File STKTRS [SRT1]
Else
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif
If [M]DOSDES=nomap
 Local File STKTRS [SRT2]
Else
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1

If GTRACE=""
 Read [SRT2]SRT0 = 4;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 4 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=4;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#                                                      # hcb 71276 deb
Subprog AM_ECCCOD(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
   Diszo [M:SLT2]5
   Actzo [M:SLT1]LOTCOD1
   [M:SLT1]LOTCOD1   = 1
   [M:SLT2]BPSLOTCOD = 2
   [M:SLT2]POTCOD    = 2
   [M:SLT2]PERCOD    = 2
   [M:SLT2]SRUB1FLG  = 1
   [M:SLT2]SRUB2FLG  = 1
   [M:SLT2]SRUB3FLG  = 1
   [M:SLT2]SRUB4FLG  = 1
Else
   Actzo [M:SLT2]5
   Actzo [M:SLT1]LOTCOD1
   [M:SLT1]LOTCOD1   = 2
   [M:SLT2]BPSLOTCOD = 2
   [M:SLT2]POTCOD    = 2
   [M:SLT2]PERCOD    = 2
   [M:SLT2]SRUB1FLG  = 1
   [M:SLT2]SRUB2FLG  = 1
   [M:SLT2]SRUB3FLG  = 1
   [M:SLT2]SRUB4FLG  = 1
Endif
Affzo [M:SLT1]LOTCOD1
Affzo [M:SLT2]BPSLOTCOD
Affzo [M:SLT2]POTCOD
Affzo [M:SLT2]PERCOD
Affzo [M:SLT2]SRUB1FLG
Affzo [M:SLT2]SRUB2FLG
Affzo [M:SLT2]SRUB3FLG
Affzo [M:SLT2]SRUB4FLG

End
Subprog AM_LOTCOD1(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
   Diszo [M:SLT2]5
   Actzo [M:SLT1]ECCCOD
   [M:SLT1]ECCCOD    = 2
   [M:SLT2]BPSLOTCOD = 2
   [M:SLT2]POTCOD    = 2
   [M:SLT2]PERCOD    = 2
   [M:SLT2]SRUB1FLG  = 1
   [M:SLT2]SRUB2FLG  = 1
   [M:SLT2]SRUB3FLG  = 1
   [M:SLT2]SRUB4FLG  = 1
Else
   Actzo [M:SLT2]5
   Actzo [M:SLT1]ECCCOD
   [M:SLT1]ECCCOD    = 1
   [M:SLT2]BPSLOTCOD = 2
   [M:SLT2]POTCOD    = 2
   [M:SLT2]PERCOD    = 2
   [M:SLT2]SRUB1FLG  = 1
   [M:SLT2]SRUB2FLG  = 1
   [M:SLT2]SRUB3FLG  = 1
   [M:SLT2]SRUB4FLG  = 1
Endif
Affzo [M:SLT1]LOTCOD1
Affzo [M:SLT2]BPSLOTCOD
Affzo [M:SLT2]POTCOD
Affzo [M:SLT2]PERCOD
Affzo [M:SLT2]SRUB1FLG
Affzo [M:SLT2]SRUB2FLG
Affzo [M:SLT2]SRUB3FLG
Affzo [M:SLT2]SRUB4FLG


End


######################################################################################

