#<AdxTL>@(#)11.0.0.0 $Revision$
#
# Issue X3-57738 - 2017-10-18 by CBO : Year end interface - Forced ledger amount on analytical table
#

Raz GPILOBJ
GBIDC2="" : GBIDC3="" : GFLAG=""
Call OBJET("GAS",GBIDC2,GBIDC3) From GOBJET
End

$WRIDAA

  Gosub DECLARE_C From SUBGAS

  # Lectures diverses
  Call LEC_TCU([M:HAEW]CURLED(NOL)) From CPTLEC
  AROLED = [F:TCU]CURRND
  Call INDLED([F:DAE]LED, "", IND, K) From CPTDIV
  If !IND
    Return # End : CBO
  Endif
  Call LEC_GAC([F:DAE]ACC, [F:DAE]COA) From CPTLEC
  If [F:GAC]DACDIENBR = 0 and GLEDDIEIPT(IND) <> 2
    Return
  Endif
  Raz INDANA

  ##--- Réparation manuelle
  If [M:HAEW]DSP(NOL)="$"

    [L]TOTANA = sum([M:VT2]TBAMT([M:HAEW]PTV(NOL)..[M:HAEW]PTF(NOL)))
    If [F:DAE]AMTCUR=[L]TOTANA
      Gosub REPART_MAN
    Else
      Gosub REPART_KRU From SUBGASD
    Endif

  ##--- Réparation standard
  Elsif [M:HAEW]DSP(NOL)<>""
    Gosub REPART_STD

  ##--- Répartition saisie sur la ligne d'écriture générale
  Elsif [F:DAE]ACC<>""

    Raz [F:DAA]
    [F:DAA] = [F:HAE]
    [F:DAA] = [F:DAE]
    [F:DAA]ANALIN = 1

    For J=1 To GLEDDIENBR(IND)
      [F:DAA]DIE(J-1) = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
      If find([F:DAA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        [F:DAA]CCE(J-1) = evalue("[M:HAEW]CCE"+num$(J)+"("+num$(NOL)+")")
      Endif
      If [F:DAA]CCE(J-1)<>""
        INDANA+=1
      Endif
    Next

    If INDANA or GLEDDIEIPT(IND)=2
      Write [DAA]
      If fstat
        GOK = 0
        Call FSTA("DAA") From GLOCK
        Return
      Endif
    Endif
  Endif

Return

###############################################################################################################
$REPART_MAN

  #--- Calcul le montant en devise de référentiel
  If dim([M:VT2]TBLED)>0 and GIMPORT
    K = 0
    For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
      TMPLED(K) = [M:VT2]TBLED(I)
      K += 1
    Next I
  Elsif [F:DAE]AMTFLG<>0 and [F:DAE]AMTCUR<>0

    # Issue X3-57738
    If GFONCTION = "FIYEND"
        K = 0
        For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
          If I<>[M:HAEW]PTF(NOL)
            TMPLED(K) = arr([M:VT2]TBAMTLED(I), AROLED)
          Else
            TMPLED(K) = [F:DAE]AMTLED - sum(TMPLED(0..K-1))
          Endif
          K += 1
        Next I
    # End Issue X3-57738
    Else
        K = 0
        For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
          If I<>[M:HAEW]PTF(NOL)
            TMPLED(K) = arr([M:VT2]TBAMT(I) * [F:DAE]AMTLED/[F:DAE]AMTCUR,AROLED)
          Else
            TMPLED(K) = [F:DAE]AMTLED - sum(TMPLED(0..K-1))
          Endif
          K += 1
        Next I
    Endif
  Else
    If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=1 # Comportement V140
      COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)
    Else
      # Normalemant à ce niveau RADIVC<>0
      If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=0
        # Pas de cours devise
        GOK=0
        Call ERREUR(mess(16,114,1)) From GESECRAN
        Return
      Endif
      COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)/[M:HAEF]RATDIVC([F:DAE]LEDTYP-1)
    Endif
    Call CONVERT_DEV([M]CUR,[M:HAEW]CURLED(NOL),[F:CPY]ACCCUR,[M:HAEW]PTF(NOL)-[M:HAEW]PTV(NOL)+1
&     ,[M:VT2]TBAMT([M:HAEW]PTV(NOL)..[M:HAEW]PTF(NOL)),TMPLED,COURS
&     ,[M]TYPRAT,[M]RATDAT,AROLED) From CPTSUB

    TMPLED([M:HAEW]PTF(NOL)-[M:HAEW]PTV(NOL)) = [F:DAE]AMTLED-sum(TMPLED(0..[M:HAEW]PTF(NOL)-[M:HAEW]PTV(NOL)-1))
  Endif

  #--- Enregistrement
  K = 0
  For I=[M:HAEW]PTV(NOL) To [M:HAEW]PTF(NOL)
    K += 1
    Raz [F:DAA]
    [F:DAA] = [F:HAE]
    [F:DAA] = [F:DAE]
    [F:DAA]AMTCUR =  [M:VT2]TBAMT(I)
    [F:DAA]AMTLED = TMPLED(K-1)
    [F:DAA]QTY    = [M:VT2]TBQTY(I)
    If [F:DAE]SNS=-1 and [M:HAEW]CDT(NOL)=0 # DdM51478
      [F:DAA]QTY    = -[F:DAA]QTY
    Endif
    [F:DAA]ANALIN = K

    For J=1 To GLEDDIENBR(IND)
      [F:DAA]DIE(J-1) = evalue("GDIE"+num$(J)+"("+num$(IND)+")")
      If find([F:DAA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        AXE = find([F:DAA]DIE(J-1),[M:VT2]TBDIE(0..dim([M:VT2]TBDIE)-1))
        If AXE
          [F:DAA]CCE(J-1) = evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(I)+")")
        Endif
      Endif
      If [F:DAA]CCE(J-1)<>""
        INDANA+=1
      Endif
    Next
    If INDANA or GLEDDIEIPT(IND)=2
      Write [DAA]
      If fstat
        GOK = 0
        Call FSTA("DAA") From GLOCK
        Return
      Endif
    Endif
  Next I

Return

###############################################################################################################
$REPART_STD

  [M:VTL]TOTREP  = [F:DAE]AMTCUR
  [M:VTL]QTOTREP = [F:DAE]QTY

  #--- Chargement de la répartition
  Call LEC_TCU([M]CUR) From CPTLEC
  If dim(GNBSTR)>0
    GNBSTR=0
  Endif
  Call CHARGE_VTE_STR([M:HAEW]DSP(NOL),[M:HAEW]UOM(NOL),[M:HAEW]LED(NOL),[M:HAEW]ACC(NOL),"") From VENTILE

  #--- Calcul le montant en devise de référentiel
  If [M:HAEW]AMTFLG(NOL)<>0 and [F:DAE]AMTCUR<>0
    K = 0
    For I=0 To [M:VTL]BAS-1
      If I<>[M:VTL]BAS-1
        TMPLED(K) = arr([M:VTL]AMT(I) * [F:DAE]AMTLED/[F:DAE]AMTCUR,AROLED)
      Else
        TMPLED(K) = [F:DAE]AMTLED-sum(TMPLED(0..K-1))
      Endif
      K += 1
    Next I
  Elsif [M:HAEW]AMTFLG(NOL)<>0 and [F:DAE]AMTCUR=0 and [F:DAE]AMTLED<>0

    Local Decimal SUMPOI, SUMP
    SUMPOI = sum([M:VTL]PRC)
    SUMP = 0
    If SUMPOI<>0
      K = 0
      For I=0 To [M:VTL]BAS-1
        If I<>[M:VTL]BAS-1
          TMPLED(K) = arr([F:DAE]AMTLED*(SUMP+[M:VTL]PRC(I))/SUMPOI,AROLED)-arr([F:DAE]AMTLED*SUMP/SUMPOI,AROLED)
        Else
          TMPLED(K) = [F:DAE]AMTLED-sum(TMPLED(0..K-1))
        Endif
        K += 1
        SUMP += [M:VTL]PRC(I)
      Next I
    Endif
  Else
    If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=1 # Comportement V140
      COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)
    Else
      # Normalemant à ce niveau RADIVC<>0
      If [M:HAEF]RATDIVC([F:DAE]LEDTYP-1)=0
        # Pas de cours devise
        GOK=0
        Call ERREUR(mess(16,114,1)) From GESECRAN
        Return
      Endif
      COURS  = [M:HAEF]RATMLTC([F:DAE]LEDTYP-1)/[M:HAEF]RATDIVC([F:DAE]LEDTYP-1)
    Endif
    Call CONVERT_DEV([M]CUR,[M:HAEW]CURLED(NOL),[F:CPY]ACCCUR,[M:VTL]BAS,[M:VTL]AMT,TMPLED,COURS
&                 ,[M]TYPRAT,[M]RATDAT,AROLED) From CPTSUB
    TMPLED([M:VTL]BAS-1) = [F:DAE]AMTLED-sum(TMPLED(0..[M:VTL]BAS-2))
  Endif

  #--- Enregistrement
  Raz [F:DAA]
  [F:DAA] = [F:HAE]
  [F:DAA] = [F:DAE]
  K = 0
  For I=0 To [M:VTL]BAS-1
    K += 1
    [F:DAA]AMTCUR = [M:VTL]AMT(I)
    [F:DAA]AMTLED = TMPLED(I)
    [F:DAA]QTY    = [M:VTL]QTY(I)
    [F:DAA]ANALIN = K
    For J=1 To dim([F:DAA]CCE)
      [F:DAA]DIE(J-1) = evalue("[M:VTL]DIE("+num$(J-1)+")")
      If find([F:DAA]DIE(J-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
        [F:DAA]CCE(J-1) = evalue("[M:VTL]CCE"+num$(J)+"("+num$(I)+")")
      Endif
    Next J
    Write [DAA]
    If fstat
      GOK = 0
      Call FSTA("DAA") From GLOCK
      Return
    Endif
  Next I

Return

