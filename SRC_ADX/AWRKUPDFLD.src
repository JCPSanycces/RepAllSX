#<AdxTL>@(#)4.0.0.0 $Revision$
Local File AWRKHISSUI [AWS]
Read [AWS] First
Call MAJ("AWS","ZZFLG","1","ZZDAT",date$,"","","","") From AWRKUPDFLD
End

#--------------------------------------------------------------------------------------------#
# Ce traitement permet de mettre à jour les champs FLD1 , FLD2 , FLD3 , FLD4 de la table
# d'abréviation ABR avec les valeurs respectives VALEUR1 , VALEUR2 , VALEUR3 , VALEUR4
#--------------------------------------------------------------------------------------------#

Subprog MAJ(ABR,FLD1,VALEUR1,FLD2,VALEUR2,FLD3,VALEUR3,FLD4,VALEUR4)
Value    Char    ABR
Value    Char    FLD1
Value    Char    VALEUR1
Value    Char    FLD2
Value    Char    VALEUR2
Value    Char    FLD3
Value    Char    VALEUR3
Value    Char    FLD4
Value    Char    VALEUR4

Local Char NAMFLD(80) , VALFLD(80)

If ABR="" | (FLD1="" & FLD2="" & FLD3="" & FLD4="") | evalue("clalev([F:"+ABR+"])")=0
 GOK = 0 : End
Endif

If !adxlog
 Call DEBTRANS From GLOCK
 Gosub TR1
Else
 Gosub MAJFLD
Endif

End

#-------------#
$TR1
Trbegin ADOVAL
 Gosub MAJFLD
 If GOK<0 : Goto ROLL_TR1
 Elsif GOK<1 : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-------------#
$MAJFLD
Default File "["+ABR+"]"
Readlock [F] =
If fstat=1
 GOK=-1 : Call FSTA(ABR) From GLOCK : Return
Elsif fstat
 GOK=0 : Call FSTA(ABR) From GLOCK : Return
Endif
Onerrgo RIEN
For NAMFLD=FLD1,FLD2,FLD3,FLD4
 If NAMFLD<>""
  Case NAMFLD
   When FLD1 : VALFLD = VALEUR1
   When FLD2 : VALFLD = VALEUR2
   When FLD3 : VALFLD = VALEUR3
   When FLD4 : VALFLD = VALEUR4
  Endcase
  If evalue("dim([F:"+ABR+"]"+NAMFLD+")")>0
   If VALFLD = "" : VALFLD = '""' : Endif 
   VALFLD = num$(evalue(VALFLD))
   Case evalue("type([F:"+ABR+"]"+NAMFLD+")")
    When 1,2,4,5,6,7,8,9 : Assign "[F:"+ABR+"]"+NAMFLD With val(VALFLD)
    When Default         : Assign "[F:"+ABR+"]"+NAMFLD With VALFLD
   Endcase
  Endif
 Endif
Next NAMFLD
Onerrgo
Rewrite [F]
If fstat
 GOK=0 : Call FSTA(ABR) From GLOCK : Return
Endif
Return

$RIEN
Resume
