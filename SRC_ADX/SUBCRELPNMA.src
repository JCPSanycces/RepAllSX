######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRELPNMA) 24/11/2017 10:35:08 (MAE)
######################################################################################
Subprog AM_NBRLPN(VALEUR)
Variable Decimal VALEUR
Local Char WMESSAGE(250)
Local Integer WRET

If VALEUR <> 0
#controle du nb de LPN
  Call CTRCOMPTEUR([M:CLPN]LPNREFCOU,VALEUR,WMESSAGE,WRET)
  If WRET <> 0
    Call ERREUR(WMESSAGE)From GESECRAN
    mkstat = 2
  Endif
Endif

End
######################################################################################
Subprog CTRCOMPTEUR(L_CPT,L_NBR,L_MESS,L_RET)
Value Char L_CPT       #Numéro de compteur
Value Decimal L_NBR    #nombre d'occurence
Variable Char L_MESS         #message retour
Variable Integer L_RET       #code retour

Local File AVALNUM [AVN]
Local File ACODNUM [ANM]
Local Char NUMLPN (GLONVCR)
Local Integer SEQ
Local Integer VALMAX, I, VALEUR

L_RET = 0
L_MESS = ""
#Récupération de la longueur de la séquence du compteur
Read[ANM]ANM0 = L_CPT
If fstat
  L_RET = 1
  L_MESS = mess(12,114,1)
  End
Endif
I = find(8,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
If !I
 L_RET = 1
 L_MESS = mess(21,143,1)
 End
Endif
If [F:ANM]POSLNG(I-1) >9
  VALMAX = val(string$(9,"9"))     #valeur max admise par le compteur
Else
  VALMAX = val(string$([F:ANM]POSLNG(I-1),"9"))     #valeur max admise par le compteur
Endif



#récupération de la derniére valeur du compteur
Read [AVN]AVN0 = L_CPT
If fstat = 5
  VALEUR = 0
Elsif fstat = 0
  VALEUR = [F:AVN]VALEUR
Else
 L_RET = 1
 L_MESS = mess(12,114,1)
 End
Endif

#controle que ça passe
If VALEUR + L_NBR >VALMAX
  L_RET = 2
  L_MESS = mess(13,114,1)
  End
Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRELPNMA) 17/04/2018 06:56:25 (MAE)
######################################################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If VALEUR <> AVOID.ACHAR
  Read [STC]STC0=[M:CLPN]STOFCY;VALEUR
  If fstat
    GMESSAGE = mess(125,184,1)
    mkstat=2 : End
  Elsif [F:STC]LOCCAT >2
    GMESSAGE = mess(16,196,1)
    mkstat=2 : End
  Endif
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRELPNMA) 15/05/2018 14:31:26 (MAE)
######################################################################################
Subprog AM_PRTFLG(VALEUR)
Variable Integer VALEUR
Local Integer OBLIG
If VALEUR = 2
  Read[TCTR]TCTR0 = [M:CLPN]TCTRNUM
  If fstat
    Raz [TCTR] : mkstat=2 : End
  Endif
  [M:CLPN]LBEFMT = [F:TCTR]LBEFMT
  Call DEFIMP([M:CLPN]LBEFMT,GUSER,"",[M:CLPN]PRT,OBLIG) From IMPRIME
  Actzo [M:CLPN]LBEFMT : Affzo [M:CLPN]LBEFMT
  Actzo [M:CLPN]PRT    : Affzo [M:CLPN]PRT
Else
  Raz [M:CLPN]LBEFMT: Diszo [M:CLPN]LBEFMT
  Raz [M:CLPN]PRT   : Diszo [M:CLPN]PRT
Endif
End


