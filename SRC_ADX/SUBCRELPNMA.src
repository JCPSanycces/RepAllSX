#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement SUBCRELPNMA - Creation LPN en masse              #
########################################################################
# Action CRELPNMA
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "FINSAI"    : Gosub FINSAI
 When "OK"        : Gosub CREATION_LPN
Endcase

Return

##########################################################################
$OUVRE

If clalev([F:LPN])=0  Local File   LPN           [LPN]   Endif
If clalev([F:FCY])=0  Local File   FACILITY      [FCY]   Endif
If clalev([F:TCTR])=0 Local File   TABCONTAINER  [TCTR]  Endif
If clalev([F:STC])=0  Local File   STOLOC        [STC]   Endif

#gestion de la classe des LPN
Global Instance WLPN Using C_LPN

Local Integer RET

Return

##########################################################################
$DEBUT

Raz   [M:CLPN]
#[M:CLPN]PRTFLG = CST_AYES
Gosub INIT
SetInstance [M:CLPN] With WLPN
Affzo [M:CLPN]
# chargement des droits pour la fonction GESLPN
Local Char OFONCTION(20)
OFONCTION=GFONCTION
GFONCTION="GESLPN" : Call AUTORIS From EXEFNC

Return

##########################################################################
$FINSAI

mkstat = 4

Return
##########################################################################
#--------------------------------------------#
# creation LPN
#--------------------------------------------#
$CREATION_LPN

Local Char    WMSG(140)
Local Integer NBCREA
Local Integer I
Local Char WLPNDEB, WLPNEND (GLONLPN)
#for printing
Local Char WLPNNUM (GLONLPN)
Local Integer WREQNUM
Local Char WREPORT (GLONARP)
Local Integer WDET, WRET
Local File LABELPRN[LBP]    #pour l'impression

Call OUVRE_TRACE("CRELPNMA") From LECFIC

Call DEBTRANS From GLOCK
#for printing
WREQNUM = uniqid([LBP])
WREPORT = [M:CLPN]LBEFMT
WDET    = 1

Gosub OUVRE_TRACE

#message opération en cours ...
Call TEMPON("O") From GESECRAN


#Affectation des roles
Local Char ABROL(GLONAOB)
ABROL = "LPN"
Gosub FILROLE From GOBJACT

For I=1 To [M:CLPN]NBRLPN
  #init de la classe
  Gosub INIT
  If [L]RET>= [V]CST_AERROR
    Break
  Endif
  #affectation de la classe
  Gosub AFFECT
  #insertion de la classe
  Gosub INSER
  If [L]RET>= [V]CST_AERROR
    Break
  Endif
Next
WMSG=mess(103,141,1)+" "+num$(NBCREA)
Call ECR_TRACE(WMSG,0) From GESECRAN
If [M:CLPN]PRTFLG = 2
  #remplissage des paramétres
  Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
  TBPAR(1) = "usr"
  TBVAL(1) = GUSER
  TBPAR(2) = "etat"
  TBVAL(2) = WREPORT
  TBPAR(3) = "numedt"
  TBVAL(3) = num$(WREQNUM)
  TBPAR(4) = "impselections"
  TBVAL(4) = "1"

  Call ETAT([M:CLPN]LBEFMT,[M:CLPN]PRT,"",1,"",TBPAR,TBVAL) From AIMP3
Endif

#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN


Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

########################################################################
# OUVRE_TRACE                                    Ouverture fichier trace
########################################################################
$OUVRE_TRACE
Call OUVRE_TRACE(mess(512,184,1)) From LECFIC

Call ECR_TRACE("---------------------------------------------------------------",0) From GESECRAN

Return

######################################################################################
$INIT
 WLPN=NewInstance C_LPN AllocGroup null
  [L]RET=fmet WLPN.AINIT()
  If [L]RET >= [V]CST_AERROR
    Call WRITE_ERRORS(WLPN)
    FreeGroup WLPN
    Return
  Endif
Return
######################################################################################
$AFFECT
SetInstance WLPN With [M:CLPN]
WLPN.MONLOTFLG = [M:CLPN]MONLOTFLG
WLPN.MONITMFLG = [M:CLPN]MONITMFLG
Return
######################################################################################
$INSER
Trbegin [F:LPN]
If [M:CLPN]PRTFLG = 2
  WLPN.PRTFLG = 2
Endif

[L]RET=fmet WLPN.AINSERT()

Call WRITE_ERRORS(WLPN)
If [L]RET>=[V]CST_AERROR
  GOK=0
  Rollback
Else
  If I=1
    WLPNDEB = WLPN.LPNNUM
  Elsif I = [M:CLPN]NBRLPN
    WLPNEND = WLPN.LPNNUM
  Endif
  NBCREA +=1
  Commit
  Call ECR_TRACE("-"-mess(46,197,1)-" : "-WLPN.LPNNUM,0) From GESECRAN   # LPN number
Endif
#fill the LABELPRN table for printing
If [M:CLPN]PRTFLG = 2
  WLPNNUM = WLPN.LPNNUM
  WRET = 1
  Call REMPLBP(WLPNNUM,WREQNUM,I,WREPORT,WDET,WRET) From STKLPN
Endif

FreeGroup WLPN
Return


######################################################################################
## Action ecran
######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran CRELPNMA) 09/10/2017 08:34:51 (MAE)
######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()

WLPN=NewInstance C_LPN AllocGroup null

SetInstance WLPN With [M:CLPN]
WLPN.TCTRNUM = VALEUR
SetInstance [M:CLPN] With WLPN
Affzo [M:CLPN]

End


######################################################################################
#------------------------------------#
#--- Write the errors                #
#------------------------------------#
Subprog WRITE_ERRORS(WLPN)
Variable Instance WLPN Using C_LPN

Local Integer I
Local Char WMESSAGE(250)

WMESSAGE=AVOID.ACHAR

# Head errors
WMESSAGE=func LCCLIB.MAXMSG(WLPN)
If WMESSAGE<>AVOID.ACHAR
  Call WRITE_ERROR_STACK_CLASSIC(WLPN, 0) From LCCLIB
Endif

End

