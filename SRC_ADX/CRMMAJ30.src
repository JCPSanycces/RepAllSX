#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################################################
# Pour exécution hors intégration de patch
#########################################################################
# Issue 106947 - 20151105 by LD : Migration of historic folder

Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 106947
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # End issue 106947
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Migration V5 to V6. CRM module") From LECFIC
    Call MAJHDKV5V6(DOSSIER)
    Call MAJCRMV5V6(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End
#########################################################################

##########################################################################################################
#                                                                                                      #
# Migration V5 vers V6 Module CRM                                            Module CRM   23 mai 2002  #
#                                                                                                      #
##########################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI="X3" : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947
  #Read [ADS] DOSSIER=APPLI
  #If fstat Then
  #  Raz [F:ADS]
  #  End
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  # End issue 106947
  #Si Module Support client non actif. On ne fait rien.
  If [F:ADS]MODULE(11) = 2 Then
    Call MAJHDKV5V6(APPLI)
  Endif
  #Si Module Action Co non actif. On ne fait rien.
  If [F:ADS]MODULE(12) = 2 Then
    Call MAJCRMV5V6(APPLI)
  Endif
End

#######################################################################
#Moulinette AVANT
#Module Support client
Subprog ACR1MAJ30

  Call MAJHDKV5V6([F:ADS]DOSSIER)
End

#######################################################################
#Moulinette AVANT
#Module Action commerciale
Subprog ACR2MAJ30

  Call MAJCRMV5V6([F:ADS]DOSSIER)
End

#######################################################################
#Moulinette APRES
#Module Support client
Subprog CR1MAJ30
End

#######################################################################
#Moulinette APRES
#Module Action commerciale
Subprog CR2MAJ30
End

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
#                SUPPORT CLIENT
#Mise à jour mosdule Support client
Subprog MAJHDKV5V6(SZAPPLI)
Value Char SZAPPLI

Global Integer WSFINUM (0..99)
Global Integer WSFIAMTCOD (0..99)

Local Integer IERRFLG
Local Integer IERRCOUNT

  IERRFLG = 0
  IERRCOUNT = 0
  #Appels des différentes moulinettes successives
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Start HDK Migration V5 to V6 version") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call CHARG_SFI
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 1
  # Mise à jour de la table SERREQUEST
  #    alimentation champs DIE
  #
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if SERREQUEST is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"SERREQUEST")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 1 : Update table SERREQUEST") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP1(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 1 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 1 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 2
  #
  # Transfère les sections analytiques de la table HDKTASK dans CPTANALIN
  #
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if HDKTASK is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"HDKTASK")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 2 : Fill CPTANALIN table from HDKTASK table.") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP2(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 2 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 2 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 3
  #
  # Transfère les sections analytiques de la table HDKTASKINV dans CPTANALIN
  #
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 3 : Fill CPTANALIN table from HDKTASKINV table.") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP3(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 3 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 3 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 4
  # Mise à jour de la table CONTSERV
  #    alimentation champs DIE
  #
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if CONTSERV is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"CONTSERV")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 4: Update table CONTSERV") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP4(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 4 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 4 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 5
  # Mise à jour de la table CONTSERVX
  #    alimentation champs DIE
  #
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if CONTSERVX is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"CONTSERVX")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 5 : Update table CONTSERVX") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP5(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 5 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 5 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 6
  # Mise à jour de la table transaction pour Parc client HTRTYP=1
  #
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 6 : Update table HDKTRS and table HDKTRSVAL (HTRTYP=1)") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP6(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 6 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 6 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 7
  # Mise à jour de la table transaction pour Demande de service HTRTYP=2
  #
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 7 : Update table HDKTRS and table HDKTRSVAL (HTRTYP=2)") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP7(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 7 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 7 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 8
  # Mise à jour de la table transaction pour Intervention HTRTYP=3
  #
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 8 : Update table HDKTRS and table HDKTRSVAL (HTRTYP=3)") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP8(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 8 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 8 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 9
  # Mise à jour de la table Intervention Pour initialiser HTOTTIMSPG avec TIMSPG
  #    si ça n'a pas été fait, avant la destruction de TIMSPG
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if INTERVEN is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"INTERVEN")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("HDK Step 9 : Update table INTERVEN") From DOSSUB
      IERRFLG = 0
      Call HDKSTEP9(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("HDK Step 9 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("HDK Step 9 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
End

#########################################################################
## Chargement des éléments de facturation dans un tableau memoire
## - Pour connaître le type de valeur : Taux/Montant
#########################################################################
Subprog CHARG_SFI
Local Integer WI

  Gosub OPEN_SFI From TRTX3CPY
  For [SFI]
    WSFINUM(WI) = [F:SFI]SFINUM
    WSFIAMTCOD(WI) = [F:SFI]AMTCOD
    WI += 1
    If WI >= dim(WSFINUM) Then
      Break
    Endif
  Next
End

###########################################################################################
# Mise à jour de la table SERREQUEST
#    alimentation champs DIE
###########################################################################################
Subprog HDKSTEP1(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J, WI, WJ
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI+".SERREQUEST"  [SRE]
  Raz COMPTEUR, CLE1, STOP, WNBR

$BOUCLE_HDKSTEP1
  If STOP = 1 Then
    CRITERE = 'SRENUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  # Pour tester
  #CRITERE = 'find(SRENUM,"GAL070000001015", "GAL060000000982")'
  Raz COMPTEUR
  Trbegin [SRE]
  For [SRE]SRE0 Where evalue(CRITERE)
    #Readlock [SRE]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File SERREQUEST" - [F:SRE]SRENUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Call RECUP_GLOBAL_CPT(SZAPPLI, [F:SRE]SALFCY) From TRTX3CPT
      For J = 1 To max(GNBDIE,GOPTCANA)
        [F:SRE]DIE(J-1) = GDIE(J)
      Next J
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI = 0 To dim([F:SRE]INVDTA)-1
        If [F:SRE]INVDTA(WI) <> 0 Then
          [F:SRE]INVDTATYP(WI) = 1
          WJ = find([F:SRE]INVDTA(WI),WSFINUM(0..99))
          If WJ > 0 and WSFIAMTCOD(WJ-1) = 1 Then
            [F:SRE]INVDTATYP(WI) = 3
          Endif
        Endif
      Next
      Rewrite [SRE]
      If fstat Then
        Call ECR_TRACE("File SERREQUEST " - [F:SRE]SRENUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:SRE]SRENUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP1
  Endif
  Close Local File [SRE]
End

###########################################################################################
# met à jour la table des axes analytiques pour la table HDKTASK Consommations SAV
###########################################################################################
Subprog HDKSTEP2(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI + ".HDKTASK"    [HDT]
  Local File =SZAPPLI + ".CPTANALIN"  [CAL]
  Local File =SZAPPLI + ".SERREQUEST" [SRE]
  Raz COMPTEUR, CLE1, STOP, WNBR

$BOUCLE_HDKSTEP2
  If STOP = 1 Then
    CRITERE = 'HDTNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [HDT]
  For [HDT]HDT0 Where evalue(CRITERE) and [F:HDT]TPL <> 2
    #Readlock [HDT]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File HDKTASK" - [F:HDT]HDTNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Look [CAL]CAL0="HDT";0;[F:HDT]HDTNUM;0;0;"";1
      If fstat Then
        Read [SRE]SRE0=[F:HDT]SRENUM
        If fstat Then
          Call ECR_TRACE("File SERREQUEST HDT 0" -[F:HDT]SRENUM - "0, Error =" - num$(fstat),1) From GESECRAN
        Else
          Call RECUP_GLOBAL_CPT(SZAPPLI, [F:SRE]SALFCY) From TRTX3CPT
          Raz [F:CAL]
          [F:CAL]ABRFIC = "HDT"
          [F:CAL]VCRNUM = [F:HDT]HDTNUM
          [F:CAL]VCRLIN = 0
          [F:CAL]VCRSEQ = 0
          [F:CAL]CPLCLE = ""
          [F:CAL]ANALIG = 1
          For J = 1 To max(GNBDIE, GOPTCANA)
            [F:CAL]DIE(J-1) = GDIE(J)
            If evalue("dim([F:HDT]CCE" + num$(J) + ")") < 0 Then
              [F:CAL]CCE(J-1) = ""
            Else
              [F:CAL]CCE(J-1) = evalue("[F:HDT]CCE"+num$(J))
            Endif
          Next J
          Write [CAL]
          If fstat Then
            Call ECR_TRACE("File CPTANALIN HDT 0" - [F:HDT]HDTNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:HDT]HDTNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP2
  Endif
  Close Local File [HDT], [CAL], [SRE]
End

###########################################################################################
# met à jour la table des axes analytiques pour la table HDKTASKINV Consommations à facturer
###########################################################################################
Subprog HDKSTEP3(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer J
Local Integer CLE2
Local Char    CLE1(30), CRITERE(90)

  Local File =SZAPPLI + ".HDKTASKINV" [HDI]
  Local File =SZAPPLI + ".CPTANALIN"  [CAL]
  Local File =SZAPPLI + ".SERREQUEST" [SRE]
  Raz COMPTEUR, CLE1, STOP, WNBR
  Raz CLE2

$BOUCLE_HDKSTEP3
  If STOP = 1 Then
    CRITERE = 'SRENUM="' + CLE1 + '" and HDTORD > ' + num$(CLE2)
    STOP = 2
  Elsif STOP = 2 Then
    CRITERE = 'SRENUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [HDI]
  For [HDI]HDI0 Where evalue(CRITERE)
    #Readlock [HDI]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File HDKTASKINV" - [F:HDI]SRENUM + " / " - [F:HDI]HDTORD + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Look [CAL]CAL0="HDI";0;[F:HDI]SRENUM;[F:HDI]HDTORD;0;"";1
      If fstat Then
        Read [SRE]SRE0=[F:HDI]SRENUM
        If fstat Then
          Call ECR_TRACE("File SERREQUEST HDT 0" - [F:HDI]SRENUM - "0, Error =" - num$(fstat),1) From GESECRAN
        Else
          Call RECUP_GLOBAL_CPT(SZAPPLI,[F:SRE]SALFCY) From TRTX3CPT
          Raz [F:CAL]
          [F:CAL]ABRFIC = "HDI"
          [F:CAL]VCRNUM = [F:HDI]SRENUM
          [F:CAL]VCRLIN = [F:HDI]HDTORD
          [F:CAL]VCRSEQ = 0
          [F:CAL]CPLCLE = ""
          [F:CAL]ANALIG = 1
          For J = 1 To max(GNBDIE,GOPTCANA)
            [F:CAL]DIE(J-1) = GDIE(J)
            If evalue("dim([F:HDI]CCE" + num$(J) + ")") < 0 Then
              [F:CAL]CCE(J-1) = ""
            Else
              [F:CAL]CCE(J-1) = evalue("[F:HDI]CCE"+num$(J))
            Endif
          Next J
          Write [CAL]
          If fstat Then
            Call ECR_TRACE("File CPTANALIN HDI 0" - [F:HDI]SRENUM - "/" - [F:HDI]HDTORD - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:HDI]SRENUM
      CLE2 = [F:HDI]HDTORD
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP3
  Endif
  Close Local File [HDI], [CAL], [SRE]
End

###########################################################################################
# Mise à jour de la table CONTSERV
#    alimentation champs DIE
###########################################################################################
Subprog HDKSTEP4(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J, WI, WJ
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI + ".CONTSERV" [CON]
  Raz COMPTEUR, CLE1, STOP, WNBR

$BOUCLE_HDKSTEP4
  If STOP = 1 Then
    CRITERE = 'CONNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  # Pour tester
  #CRITERE = 'find(CONNUM,"CON070000010945", "CON050000005889")'
  Raz COMPTEUR
  Trbegin [CON]
  For [CON] CON0 Where evalue(CRITERE)
    #Readlock [CON]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File CONTSERV" - [F:CON]CONNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Call RECUP_GLOBAL_CPT(SZAPPLI,[F:CON]SALFCY) From TRTX3CPT
      For J = 1 To max(GNBDIE,GOPTCANA)
        [F:CON]DIE(J-1) = GDIE(J)
      Next J
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI = 0 To dim([F:CON]INVDTA)-1
        If [F:CON]INVDTA(WI) <> 0  Then
          [F:CON]INVDTATYP(WI) = 1
          WJ = find([F:CON]INVDTA(WI),WSFINUM(0..99))
          If WJ > 0 and WSFIAMTCOD(WJ-1) = 1 Then
            [F:CON]INVDTATYP(WI) = 3
          Endif
        Endif
      Next
      Rewrite [CON]
      If fstat Then
        Call ECR_TRACE("File CONTSERV" - [F:CON]CONNUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:CON]CONNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP4
  Endif
  Close Local File [CON]
End

###########################################################################################
# Mise à jour de la table CONTSERVX
#    alimentation champs DIE
###########################################################################################
Subprog HDKSTEP5(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J, WI, WJ
Local Char     CLE1(30), CRITERE(90)

  Local File =SZAPPLI + ".CONTSERVX" [COX]
  Raz COMPTEUR, CLE1, STOP, WNBR

$BOUCLE_HDKSTEP5
  If STOP = 1 Then
    CRITERE = 'CONNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [COX]
  For [COX]COX0 Where evalue(CRITERE)
    #Readlock [COX]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File CONTSERVX" - [F:COX]CONNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Call RECUP_GLOBAL_CPT(SZAPPLI,[F:COX]SALFCY) From TRTX3CPT
      For J = 1 To max(GNBDIE,GOPTCANA)
        [F:COX]DIE(J-1) = GDIE(J)
      Next J
      # Initialisation ds le tableau des éléments de facturation
      # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
      For WI = 0 To dim([F:COX]INVDTA)-1
        If [F:COX]INVDTA(WI) <> 0 Then
          [F:COX]INVDTATYP(WI) = 1
          WJ = find([F:COX]INVDTA(WI),WSFINUM(0..99))
          If WJ > 0 and WSFIAMTCOD(WJ-1) = 1 Then
            [F:COX]INVDTATYP(WI) = 3
          Endif
        Endif
      Next
      Rewrite [COX]
      If fstat Then
        Call ECR_TRACE("File CONTSERVX" - [F:CON]CONNUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:COX]CONNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP5
  Endif
  Close Local File [COX]
End

###########################################################################################
# Mise à jour de la table transaction pour Parc client HTRTYP=1
#
###########################################################################################
Subprog HDKSTEP6(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Integer INBFIENAM
Local Integer INBONGLETINVI
Local Integer INBBLOCINVI
Local Integer IBEXISTE

  Local File =SZAPPLI + ".HDKTRS" [HTR]
  Local File =SZAPPLI + ".HDKTRSVAL" [HTV]
  Raz COMPTEUR, CLE1, STOP, WNBR
  INBFIENAM = 0
  INBONGLETINVI = 0
  INBBLOCINVI = 0
  IBEXISTE = 0

$BOUCLE_HDKSTEP6
  If STOP = 1 Then
    CRITERE = 'HTRTYP=1 and HTRNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "HTRTYP=1"
  Endif
  Raz COMPTEUR
  Trbegin [HTR]
  For [HTR]HTR0 Where evalue(CRITERE)
    #Readlock [HTR]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Raz [F:HTR]BLOCINVI
      Raz [F:HTR]COLFIXNAM
      Raz [F:HTR]ONGINVISI
      Look [HTV] HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
      If fstat = 0 Then
        IBEXISTE = 1
        Raz [F:HTV]FIENAM
        Raz [F:HTV]FIEVAL
      Else
        IBEXISTE = 0
        Raz [HTV]
      Endif
      INBFIENAM = 0
      INBBLOCINVI = 0
      INBONGLETINVI = 0
      [F:HTV] = [F:HTR]
      #Marque
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACBRA"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]BRACOD)
      INBFIENAM += 1
      # Date mise en service
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACITSDAT"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]ITSDATCOD)
      INBFIENAM += 1
      # Date d'installation
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACITNDAT"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]ITNDATCOD)
      INBFIENAM += 1
      # Prix d'achat
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACBPCPRI"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]BPCPRICOD)
      INBFIENAM += 1
      # Devise d'achat
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACBPCCUR"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]BPCCURCOD)
      INBFIENAM += 1
      # Date d'achat
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACBPCDAT"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]BPCDATCOD)
      INBFIENAM += 1
      # Prix de vente
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACSALPRI"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]SALPRICOD)
      INBFIENAM += 1
      # Devise de vente
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]CUR"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]CURCOD)
      INBFIENAM += 1
      # Date de vente
      [F:HTV]FIENAM(INBFIENAM) = "[MAC1]MACPURDAT"
      [F:HTV]FIENAM(INBFIENAM) = num$([F:HTR]PURDATCOD)
      INBFIENAM += 1
      If [F:HTR]MACCONFLG <> 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[MAC2]5"
        INBBLOCINVI += 1
      Endif
      If [F:HTR]FLYWARFLG <> 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[MAC2]5"
        INBBLOCINVI += 1
      Endif
      #Onglet 2 invisible
      If [F:HTR]MACCONFLG <> 2 and [F:HTR]FLYWARFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI) = "MAC2"
        INBONGLETINVI += 1
      Endif
      #Onglet 3 invisible
      If [F:HTR]FCYITNFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI) = "MAC3"
        INBONGLETINVI += 1
      Endif
      #Onglet 4 invisible
      If [F:HTR]MAIFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI) = "MAC4"
        INBONGLETINVI += 1
      Endif
      Rewrite [HTR]
      If fstat Then
        Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Else
        If IBEXISTE = 0 Then
          Write [HTV]
          If fstat Then
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Else
          Rewrite [HTV]
          If fstat
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:HTR]HTRNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP6
  Endif
  Close Local File [HTR]
  Close Local File [HTV]
End

###########################################################################################
# Mise à jour de la table transaction pour Intervention HTRTYP=2
#
###########################################################################################
Subprog HDKSTEP7(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Integer INBFIENAM
Local Integer INBONGLETINVI
Local Integer INBBLOCINVI
Local Integer IBEXISTE

  Local File =SZAPPLI + ".HDKTRS"    [HTR]
  Local File =SZAPPLI + ".HDKTRSVAL" [HTV]
  Raz COMPTEUR, CLE1, STOP, WNBR
  INBFIENAM = 0
  INBONGLETINVI = 0
  INBBLOCINVI = 0
  IBEXISTE = 0

$BOUCLE_HDKSTEP7
  If STOP = 1 Then
    CRITERE = 'HTRTYP=2 and HTRNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "HTRTYP=2"
  Endif
  Raz COMPTEUR
  Trbegin [HTR]
  For [HTR]HTR0 Where evalue(CRITERE)
    #Readlock [HTR]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Raz [F:HTR]BLOCINVI
      Raz [F:HTR]COLFIXNAM
      Raz [F:HTR]ONGINVISI
      Look [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
      If fstat = 0 Then
        IBEXISTE = 1
        Raz [F:HTV]FIENAM
        Raz [F:HTV]FIEVAL
      Else
        IBEXISTE = 0
        Raz [HTV]
      Endif
      INBFIENAM = 0
      INBBLOCINVI = 0
      INBONGLETINVI = 0
      [F:HTV]=[F:HTR]
      # Chrono client
      [F:HTV]FIENAM(INBFIENAM) = "[SRE0]SRENUMBPC"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]NUMBPCCOD)
      INBFIENAM += 1
      # Donneur d'ordre
      [F:HTV]FIENAM(INBFIENAM) = "[SRE0]SREDOO"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DOOCOD)
      INBFIENAM += 1
      If [F:HTR]DOOCOD > 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE0]SREDOOX"
        [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DOOCOD)
        INBFIENAM += 1
      Endif
      # Icône Etat
      [F:HTV]FIENAM(INBFIENAM) = "[SRE0]ICOSAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SATCOD)
      INBFIENAM += 1
       # Icône Niveau de gravité
      [F:HTV]FIENAM(INBFIENAM) = "[SRE0]ICOGRALEV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]GRALEVCOD)
      INBFIENAM += 1
      # Familles statistiques
      [F:HTV]FIENAM(INBFIENAM) = "[SRE1]TSDCOD"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SRETSDCOD)
      INBFIENAM += 1
      #Compétence
      If [F:HTR]TSREPBLFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]PBL"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]PBLCLA"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      #Couverture
      If [F:HTR]TSRECOVFLG <> 2 Then
        #Couverture parc
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]COVFLG"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]COVSPT"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]COVVCR"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        #Couverture composant
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVFLG"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVSPT"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]CPNCOVVCR"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      #Points débités (Forfait)
      If [F:HTR]TSREPITFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE7]PITMAC"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      # Etat
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRESAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SATCOD)
      INBFIENAM += 1
      # Niveau de gravité
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREGRALEV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]GRALEVCOD)
      INBFIENAM += 1
      # Date de résolution souhaitée
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRERESDAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]RESDATCOD)
      INBFIENAM += 1
      # Heure de résolution souhaitée
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRERESHOU"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]RESHOUCOD)
      INBFIENAM += 1
      # Contrat support
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]CONSPT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]CONSPTCOD)
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]CONSPTCLA"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]CONSPTCOD)
      INBFIENAM += 1
      # Motif
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRERESREN"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]RESRENCOD)
      INBFIENAM += 1
      #Couverture et statut de facturation en fond d'écran
      If [F:HTR]TSRECOVFLG <> 2 or [F:HTR]TSREINVFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE2]OVRCOVCLA"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      #Couverture globale
      If [F:HTR]TSRECOVFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE2]OVRCOV"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      # Client facture
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREBPCINV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]BPCINVCOD)
      INBFIENAM += 1
      # Tiers payeur
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREBPCPYR"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]BPCPYRCOD)
      INBFIENAM += 1
      # Client groupe
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREBPCGRU"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]BPCGRUCOD)
      INBFIENAM += 1
      # Affaire
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREPJT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]PJTCOD)
      INBFIENAM += 1
      # Représentant
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREREP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]REPCOD)
      INBFIENAM += 1
      # Régime de taxe
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREVACBPR"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]VACBPRCOD)
      INBFIENAM += 1
      # Type de cours
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRECHGTYP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]CHGTYPCOD)
      INBFIENAM += 1
      # Type de prix
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREPRITYP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]PRITYPCOD)
      INBFIENAM += 1
      # Devise
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SRECUR"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]CURCOD)
      INBFIENAM += 1
      # Condition de paiement
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREPTE"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]PTECOD)
      INBFIENAM += 1
      # Escompte
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]SREDEP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DEPCOD)
      INBFIENAM += 1
      #Site de stockage
      [F:HTV]FIENAM(INBFIENAM) = "[SRE2]STOFCY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]STOFCYCOD)
      INBFIENAM += 1
      #Eléments de facturation
      #% ou montant
      [F:HTV]FIENAM(INBFIENAM) = "[SRE8]INVDTAAMT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]INVDTACOD)
      INBFIENAM += 1
      # Type d'intervenant
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTAUSTYP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTYPCOD)
      INBFIENAM += 1
      # Intervenant
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTAUS"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AUSTYPCOD)
      INBFIENAM += 1
      # Intervenant en clair
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTAUSCOD"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AUSTYPCOD)
      INBFIENAM += 1
      # Planifié le
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTPLNDAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]PLNDATCOD)
      INBFIENAM += 1
      # Effectué le
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTDONDAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DONDATCOD)
      INBFIENAM += 1
      # Effectué à
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]BHDTDONHOU"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DONHOUCOD)
      INBFIENAM += 1
      # Montant consommé
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTAMT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTAMTCOD)
      INBFIENAM += 1
      # Texte
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTTEX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTEXCOD)
      INBFIENAM += 1
      # Chrono consommation
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTNUM"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTNUMCOD)
      INBFIENAM += 1
      # Chrono intervention
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]ITNNUM"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]ITNNUMCOD)
      INBFIENAM += 1
      # Site de stockage
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTSTOFCY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HSTOFCYCOD)
      INBFIENAM += 1
      # Sortie de stock
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTSTOISS"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]STOISSCOD)
      INBFIENAM += 1
      # Quantité à sortir
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTISSQTY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]ISSQTYCOD)
      INBFIENAM += 1
      # Quantité sortie
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTISSISS"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]ISSISSCOD)
      INBFIENAM += 1
      #Parc
      If [F:HTR]TSREMACFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTMACSRE"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      #Composant
      If [F:HTR]TSREMACFLG <> 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTCPN"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      #Montant à facturer
      SZREFERENCE="[SRE9]HDTAMTINV"
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTAMTINV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AMTINVCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTINV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AMTINVCOD)
      INBFIENAM += 1
      #Devise
      If [F:HTR]AMTINVCOD > 2  Then     #Montant facturable invisible
        If [F:HTR]HDTAMTCOD > 2 Then    #Montant consommé invisible
          [F:HTV]FIENAM(INBFIENAM) = "[SRE9]HDTCUR"
          [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AMTINVCOD)
          INBFIENAM += 1
        Endif
      Endif
      If [F:HTR]SRETSDCOD > 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE1]25"
        INBBLOCINVI += 1
      Endif
      #Gestion du parc
      If [F:HTR]TSREMACFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]5"
        INBBLOCINVI += 1
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]10"
        INBBLOCINVI += 1
      Endif
      #Gestion des composants parc
      If [F:HTR]TSRECPNFLG <> 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]15"
        INBBLOCINVI += 1
      Endif
      #Gestion des compétences
      If [F:HTR]TSRECPNFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE7]20"
        INBBLOCINVI += 1
      Endif
      #Horodatage
      If [F:HTR]TSREHORFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE2]20"
        INBBLOCINVI += 1
      Endif
      #Escalade
      If [F:HTR]TSREESCFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE2]25"
        INBBLOCINVI += 1
      Endif
      #Eléments de facturation
      If [F:HTR]INVDTACOD =3 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE8]20"
        INBBLOCINVI += 1
      Endif
      #Gestion des consommations
      If [F:HTR]TSREHDTFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE9]5"
        INBBLOCINVI += 1
      Endif
      #Sous totaux
      If [F:HTR]SBBTOTFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE9]10"
        INBBLOCINVI += 1
      Endif
      #Totaux
      If [F:HTR]HDTTOTFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE9]15"
        INBBLOCINVI += 1
      Endif
      #Totalisation s points
      If [F:HTR]TSREPITFLG <>2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[SRE9]20"
        INBBLOCINVI += 1
      Endif
      If [F:HTR]TSREMACFLG <> 2 and [F:HTR]TSREPBLFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "SRE7"
        INBONGLETINVI += 1
      Endif
      If [F:HTR]TSREINVFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "SRE8"
        INBONGLETINVI += 1
      Endif
      If [F:HTR]TSREPITFLG <> 2 and [F:HTR]TSREHDTFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "SRE9"
        INBONGLETINVI += 1
      Endif
      Rewrite [HTR]
      If fstat Then
        Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Else
        If IBEXISTE = 0 Then
          Write [HTV]
          If fstat Then
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Else
          Rewrite [HTV]
          If fstat Then
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:HTR]HTRNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP7
  Endif
  Close Local File [HTR]
  Close Local File [HTV]
End

###########################################################################################
# Mise à jour de la table transaction pour Intervention HTRTYP=3
#
###########################################################################################
Subprog HDKSTEP8(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Integer INBFIENAM
Local Integer INBONGLETINVI
Local Integer INBBLOCINVI
Local Integer IBEXISTE

  Local File =SZAPPLI + ".HDKTRS" [HTR]
  Local File =SZAPPLI + ".HDKTRSVAL" [HTV]
  Raz COMPTEUR, CLE1, STOP, WNBR
  INBFIENAM = 0
  INBONGLETINVI = 0
  INBBLOCINVI = 0
  IBEXISTE = 0

$BOUCLE_HDKSTEP8
  If STOP = 1 Then
    CRITERE = 'HTRTYP=3 and HTRNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "HTRTYP=3"
  Endif
  Raz COMPTEUR
  Trbegin [HTR]
  For [HTR]HTR0 Where evalue(CRITERE)
    #Readlock [HTR]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      Raz [F:HTR]BLOCINVI
      Raz [F:HTR]COLFIXNAM
      Raz [F:HTR]ONGINVISI
      Look [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
      If fstat = 0 Then
        IBEXISTE = 1
        Raz [F:HTV]FIENAM
        Raz [F:HTV]FIEVAL
      Else
        IBEXISTE = 0
        Raz [HTV]
      Endif
      INBFIENAM = 0
      INBBLOCINVI = 0
      INBONGLETINVI = 0
      [F:HTV]=[F:HTR]
      # Sous-traité
      [F:HTV]FIENAM(INBFIENAM) = "[ITN1]SCO"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SCOCOD)
      INBFIENAM += 1
      # Montant sous-traité
      [F:HTV]FIENAM(INBFIENAM) = "[ITN1]SCOAMT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SCOAMTCOD)
      INBFIENAM += 1
      # Devise
      [F:HTV]FIENAM(INBFIENAM) = "[ITN1]CUR"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]SCOAMTCOD)
      INBFIENAM += 1
      # Complément d'informations
      [F:HTV]FIENAM(INBFIENAM) = "[ITN1]FULOBJ"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]OBJCOD)
      INBFIENAM += 1
      # Complément d'informations
      If [F:HTR]OBJCOD > 1 Then
        [F:HTV]FIENAM(INBFIENAM) = "[ITN1]OBJICO"
        [F:HTV]FIEVAL(INBFIENAM) = "3"
        INBFIENAM += 1
      Endif
      # Distance
      [F:HTV]FIENAM(INBFIENAM) = "[ITN3]DTCKIL"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DTCKILCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[ITN3]DTCKILX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DTCKILCOD)
      INBFIENAM += 1
      # Temps de trajet
      [F:HTV]FIENAM(INBFIENAM) = "[ITN3]TRITIM"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TRITIMCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[ITN3]TRITIMX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TRITIMCOD)
      INBFIENAM += 1
      # Indications particulières
      [F:HTV]FIENAM(INBFIENAM) = "[ITN3]IFFADD"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]IFFADDCOD)
      INBFIENAM += 1
      # Parc
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTMACSRE"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTMACCOD)
      INBFIENAM += 1
      # Composant
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTCPN"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTCPNCOD)
      INBFIENAM += 1
      # Type de consommation
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTTYP"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTYPCOD)
      INBFIENAM += 1
      # Site de stockage
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTSTOFCY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HSTOFCYCOD)
      INBFIENAM += 1
      # Sortie de stock
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTSTOFCY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]STOISSCOD)
      INBFIENAM += 1
      # Quantité à sortir
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTISSQTY"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]ISSQTYCOD)
      INBFIENAM += 1
      # Quantité sortie
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTISSISS"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]ISSISSCOD)
      INBFIENAM += 1
      # Effectué le
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTDONDAT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DONDATCOD)
      INBFIENAM += 1
      # Effectué à
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]BHDTDONHOU"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]DONHOUCOD)
      INBFIENAM += 1
      # Durée réelle
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]SPGTIMHOU"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTIMCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]SPGTIMMNT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTIMCOD)
      INBFIENAM += 1
      # Facturable
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTINV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTINVCOD)
      INBFIENAM += 1
      # Montant consommé
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTAMT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTAMTCOD)
      INBFIENAM += 1
      # Montant facturable
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTAMTINV"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]AMTINVCOD)
      INBFIENAM += 1
      #Devise
      If [F:HTR]HDTAMTCOD > 2 Then
        If [F:HTR]AMTINVCOD > 2 Then
          [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTCUR"
          [F:HTV]FIEVAL(INBFIENAM) = "3"
          INBFIENAM += 1
        Endif
      Endif
      # Points débités
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]PITHDT"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTPITCOD)
      INBFIENAM += 1
      # Texte
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTTEX"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTEXCOD)
      INBFIENAM += 1
      # Chrono
      [F:HTV]FIENAM(INBFIENAM) = "[ITN8]HDTNUM"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]HDTTEXCOD)
      INBFIENAM += 1
      #Temps réellement passé
      [F:HTV]FIENAM(INBFIENAM) = "[ITN4]HTOTTIMSPG"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TIMSPGCOD)
      INBFIENAM += 1
      #Temps réellement passé
      [F:HTV]FIENAM(INBFIENAM) = "[ITN4]HTOTTIMSPG"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TIMSPGCOD)
      INBFIENAM += 1
      [F:HTV]FIENAM(INBFIENAM) = "[ITN4]MTOTTIMSPG"
      [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TIMSPGCOD)
      INBFIENAM += 1
      If [F:HTR]TIMSPGCOD > 2 Then
        [F:HTV]FIENAM(INBFIENAM) = "[ITN4]TIMSPGX"
        [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TIMSPGCOD)
        INBFIENAM += 1
        [F:HTV]FIENAM(INBFIENAM) = "[ITN4]TIMSPGY"
        [F:HTV]FIEVAL(INBFIENAM) = num$([F:HTR]TIMSPGCOD)
        INBFIENAM += 1
      Endif
      #Gestion du temps
      If [F:HTR]ITNTIMFLG <> 2 Then
        [F:HTR]BLOCINVI(INBBLOCINVI) = "[ITN8]10"
        INBBLOCINVI += 1
      Endif
      If [F:HTR]TITNADDFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "ITN3"
        INBONGLETINVI += 1
      Endif
      If [F:HTR]TITNRSEFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "ITN7"
        INBONGLETINVI += 1
      Endif
      If [F:HTR]TITNHDTFLG <> 2 Then
        [F:HTR]ONGINVISI(INBONGLETINVI)= "ITN8"
        INBONGLETINVI += 1
      Endif
      Rewrite [HTR]
      If fstat Then
        Call ECR_TRACE("File HDKTRS" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
       Else
        If IBEXISTE = 0 Then
          Write [HTV]
          If fstat Then
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Else
          Rewrite [HTV]
          If fstat Then
            Call ECR_TRACE("File HDKTRSVAL" - [F:HTR]HTRNUM - "0, Error =" - num$(fstat),1) From GESECRAN
          Endif
        Endif
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:HTR]HTRNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_HDKSTEP8
  Endif
  Close Local File [HTR]
  Close Local File [HTV]
End

###########################################################################################
# Mise à jour de la table Intervention Pour initialiser HTOTTIMSPG avec TIMSPG
#    si ça n'a pas été fait, avant la destruction de TIMSPG
###########################################################################################
Subprog HDKSTEP9(DOSSIER, IERR)
Value Char DOSSIER
Variable Integer IERR

Local Integer N_REWRITE
Local Integer IBINTERVEN

  # FGR 17/02/2009 : X3SUIVI52520
  #------------------------------------------------------
  N_REWRITE = 0
  IBINTERVEN = 1
  If filinfo(filpath("FIL","INTERVEN","fde",DOSSIER),0) <= 0 Then
    IBINTERVEN = 0
  Endif
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    If !clalev ([F:ITN]) : Local File =DOSSIER+".INTERVEN" [ITN] : Endif
  Endif
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    Trbegin [ITN]
    # Toutes les intervention qui ont une durée (en heure) dans l'ancienne rubrique (TIMSPG)
    # et qui n'en n'ont pas dans les nouvelles (HTOTTIMSPG et MTOTTIMSPG)
    Filter [ITN] Where TIMSPG <> 0 and HTOTTIMSPG = 0 and MTOTTIMSPG = 0
    For [ITN]ITN0
      [F:ITN]HTOTTIMSPG = [F:ITN]TIMSPG
      Rewrite [ITN]
      If fstat <> 0 Then
        Call ECR_TRACE("File INTERVEN :" - [F:ITN]NUM - ":" - num$(fstat), 1) From GESECRAN
        IERR = 1
      Endif
      N_REWRITE += 1
    Next
    Filter [ITN]
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Call ECR_TIME("File INTERVEN :" - num$(N_REWRITE) - "records updated") From DOSSUB
  Endif
  #------------------------------------------------------
  If IBINTERVEN = 1 Then
    Close Local File [ITN]
  Endif
End

#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
#                ACTION COMMERCIALE
#######################################################################
#Mise à jour module action commerciale
Subprog MAJCRMV5V6(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRFLG
Local Integer IERRCOUNT

  IERRFLG = 0
  IERRCOUNT = 0
  #Appels des différentes moulinettes successives
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Start CRM Migration V5 to V6 ") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 1
  # Alimentation des champs de la table MARSCT
  #
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 1 : Update table MARSCT") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP1(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 1 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 1 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 2
  # Alimentation des champs de la table TGRLIS, SELSSP, TGRSSP, FIEDIC
  #  libellé traduisibles
  #---------------------------------------------------#
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 2 : Update tables TGRLIS, SELSSP, TGRSSP, FIEDIC") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP2(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 2 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 2 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 3
  # Alimentation des champs de la table OPPOR
  #  correction de la gestion de l'étape en cours
  #---------------------------------------------------#
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, to do only if OPPOR is not a view
  If func DOSVUE.ISVIEW(SZAPPLI,"OPPOR")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 3 : Update tables OPPOR") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP3(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 3 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 3 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947

  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 4
  # Alimentation des champs de la table ATABDIV/N2 433 N2 à NON
  #
  #---------------------------------------------------#
  #---------------------------------------------------#
  # Issue 106947
  # For historic folder, not to do if ATABDIV is a view
  If func DOSVUE.ISVIEW(SZAPPLI,"ATABDIV")<> 1
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 4 : Update tables ATABDIV:433") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP4(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 4 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 4 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947

  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 5
  # Modification de la présentation de la liste de gauche des correspondants
  #
  #---------------------------------------------------#
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 5 : Object COR") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP5(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 5 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 5 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947

  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  #Moulinette 6
  # Entretien du statut CLO des opérations marketing
  #
  #---------------------------------------------------#
  #---------------------------------------------------#
  # Issue 106947
  # Not to do in a historic folder
  If func DOSSUB.ISHISTFOLD(SZAPPLI)=0
  # End issue 106947
      Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Call ECR_TIME("CRM Step 6 : Objects OMM/OMT/OMN") From DOSSUB
      IERRFLG = 0
      Call CRMSTEP6(SZAPPLI, IERRFLG)
      If IERRFLG Then
        Call ECR_TIME("CRM Step 6 migration aborted due to errors.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
        IERRCOUNT += 1
      Else
        Call ECR_TIME("CRM Step 6 : Completed.") From DOSSUB
        Call ECR_TRACE("--------------------------------------",0) From GESECRAN
      Endif
  # Issue 106947
  Endif
  # End issue 106947

End

###########################################################################################
# Mise à jour des champs de la table MARSCT et MARDEF
#
###########################################################################################
Subprog CRMSTEP1(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer COMPTEUR, STOP, WNBR
Local Integer  J
Local Char     CLE1(30), CRITERE(90)
Local Integer ICRITERE
Local Char SZSYNTHESE
Local Char SZCHAINE
Local Integer ITROUVECRIT
Local Integer ITROUVECRIT1
Local Integer IVALEUR
Local Char SZVALEUR
Local Integer INBRECORD
Local Integer INUMRECORD
Local Char SZDEBUT
Local Char SZFIN
Local Integer IINDICE
Local Integer INBPARDEB
Local Integer INBPARFIN
Local Integer IBCONTINUE
Local Integer IBREWRITE
Local Integer IBCREE
Local Integer ICRINUM

  Local File =SZAPPLI + ".MARSCT"    [MST]
  Local File =SZAPPLI + ".MARDEF"    [MDF]
  Local File =SZAPPLI + ".MARDEF"    [MDF1]
  Local File =SZAPPLI + ".MARDEFVAL" [MDV]
  Local File =SZAPPLI + ".ATABZON"   [ATZ]
  Local File =SZAPPLI + ".ATABLE"    [ATB]
  Raz COMPTEUR, CLE1, STOP, WNBR
  ICRITERE = 1
  Raz SZSYNTHESE
  Raz SZCHAINE
  ITROUVECRIT = 0
  ITROUVECRIT1 = 0
  IVALEUR = 0
  Raz SZVALEUR
  INBRECORD=0
  INUMRECORD = 1
  Raz SZDEBUT
  Raz SZFIN
  IINDICE = 0
  INBPARDEB = 0
  INBPARFIN = 0
  IBCONTINUE = 1
  IBREWRITE = 0
  IBCREE = 0
  ICRINUM = 0

$BOUCLE_CRMSTEP1
  If STOP = 1 Then
    CRITERE = 'MARSCTNUM>"' + CLE1 + '"'
    STOP = 0
  Else
    CRITERE = "1=1"
  Endif
  Raz COMPTEUR
  Trbegin [MST]
  For [MST]MST0 Where evalue(CRITERE)
    #Readlock [MST]Curr  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
    #If fstat Then
    #  Call ECR_TRACE("File MARSCT" - [F:MST]MARSCTNUM + ", Error =" - num$(fstat),1) From GESECRAN
    #Else
      If [F:MST]MSTENA = 0 Then
        [F:MST]MSTENA = 2
      Endif
      If [F:MST]MSTCRI = 0 Then
        [F:MST]MSTCRI = 1
      Endif
      If [F:MST]MSTFOROPD = 0 Then
        [F:MST]MSTFOROPD = 1
      Endif
      ICRITERE = 0
      SZSYNTHESE = [F:MST]GRUDEF
      SZCHAINE = [F:MST]GRUDEF
      Filter [MDF] Where [F:MDF]MARSCTNUM = [F:MST]MARSCTNUM
      For [MDF]MDF1
        #traitement des valeurs
        Filter [MDV] Where [F:MDV]MARSCTNUM=[F:MDF]MARSCTNUM and [F:MDV]CRINUM=[F:MDF]CRINUM Order By [F:MDV]MARSCTNUM Asc;[F:MDV]CRINUM Asc;[F:MDV]SCTVALNUM Asc
        INBRECORD = rowcount([MDV])
        If INBRECORD > 0 Then
          ICRITERE += 1
          ITROUVECRIT = instr(0, SZCHAINE, num$(ICRITERE))
          If ITROUVECRIT <> 0 Then
            If ICRITERE > 1 Then
              ITROUVECRIT1 = instr(0, SZCHAINE, num$(ICRITERE-1))
              SZDEBUT = mid$(SZCHAINE,ITROUVECRIT1+len(num$(ICRITERE-1)), ITROUVECRIT-ITROUVECRIT1-1)
            Else
              SZDEBUT = left$(SZCHAINE, ITROUVECRIT-1)
            Endif
          Endif
          ITROUVECRIT1 = instr(0, SZCHAINE, num$(ICRITERE+1))
          If ITROUVECRIT1 = 0 Then
            SZFIN = right$(SZCHAINE, ITROUVECRIT+len(num$(ICRITERE)))
          Else
            SZFIN = mid$(SZCHAINE,ITROUVECRIT+len(num$(ICRITERE)), ITROUVECRIT1-ITROUVECRIT-1)
          Endif
          #calcul nombre parenthèse ouvrantes
          INBPARDEB = 0
          IBCONTINUE = 1
          While IBCONTINUE = 1
            If SZDEBUT = "" Then
              IBCONTINUE = 0
              Break
            Endif
            If right$(SZDEBUT,len(SZDEBUT)) = "("  Then
              INBPARDEB += 1
            Endif
            SZDEBUT = left$(SZDEBUT, len(SZDEBUT)-1)
          Wend
          IBCONTINUE = 1
          INBPARFIN = 0
          While IBCONTINUE = 1
            If SZFIN = "" Then
              IBCONTINUE = 0
              Break
            Endif
            If right$(SZFIN,len(SZFIN)) = ")"  Then
              INBPARFIN += 1
            Endif
            SZFIN = left$(SZFIN, len(SZFIN)-1)
          Wend
          [F:MDF]NBPARDEB = INBPARDEB
          [F:MDF]NBPARFIN = INBPARFIN
          Case [F:MDF]MARSCTTAB
            When 1
              [F:MDF]MDFABRFIC = "BPR"
              [F:MDF]MDFTAB = "BPARTNER"
            When 2
              [F:MDF]MDFABRFIC = "BPC"
              [F:MDF]MDFTAB = "BPCUSTOMER"
            When 3
              [F:MDF]MDFABRFIC = "BPA"
              [F:MDF]MDFTAB = "BPADDRESS"
            When 4
              [F:MDF]MDFABRFIC = "AIN"
              [F:MDF]MDFTAB = "CONTACTCRM"
          Endcase
          #
          Local File =SZAPPLI + "." + [F:MDF]MDFTAB [XXX0]
          # FGR 11/02/2009 : X3SUIVI52449 : conséquence de la prise en compte de cette fiche.
          #                  Plus erreur sur la façon de déterminer si un champs est dimensionné.
          #                  C'était fait en regardant dans ATZ. Ca ne tenait pas compte du dimensionnement via un secteur d'activité
          SZCHAMPSSIND = func CRMUTIL150.GET_CHAMP_SSIND ([F:MDF]MARSCTFIE)
          If evalue("dim([F:XXX0]" + SZCHAMPSSIND + ")") > 1 Then
            # Le champs est dimensionné
            [F:MDF]MDFINDOK = 1
            If SZCHAMPSSIND = [F:MDF]MARSCTFIE Then
              # On n'avait pas indiqué l'indice : on prend donc zéro
              [F:MDF]MDFINDNUM = 0
            Else
              # On avait indiqué l'indice : on prend donc cette valeur
              [F:MDF]MDFINDNUM = evalue(mid$([F:MDF]MARSCTFIE, len(SZCHAMPSSIND)+1, len([F:MDF]MARSCTFIE)))
            Endif
          Else
            # Le champs n'est pas dimensionné
            [F:MDF]MDFINDOK = 0
            [F:MDF]MDFINDNUM = 0
          Endif
          #
          SZVALEUR = "type([F:XXX0]" + [F:MDF]MARSCTFIE + ")"
          IVALEUR = evalue(SZVALEUR)
          Case IVALEUR
            When 1, 2, 4, 5, 6, 7, 9
              #Numerique
              [F:MDF]MDFFIETYP = 2
            When 3
              #date
              [F:MDF]MDFFIETYP = 3
            When Default
              #Alphanumerique
              [F:MDF]MDFFIETYP = 1
          Endcase
          Close Local File [XXX0]
          # FGR 11/02/2009 : X3SUIVI52449
          #Read [ATZ]CODZONE=[F:MDF]MDFTAB;[F:MDF]MARSCTFIE
          #If fstat = 0 Then
          #  If [F:ATZ]DIME > 1 Then
          #    [F:MDF]MDFINDOK = 1
          #    [F:MDF]MDFINDNUM = 0
          #  Else
          #    [F:MDF]MDFINDOK = 0
          #    [F:MDF]MDFINDNUM = 0
          #  Endif
          #Else
          #  Call ECR_TRACE("File ATABZON" - [F:MDF]MDFTAB + "/" + [F:MDF]MARSCTFIE - "0, Error =" - num$(fstat),1) From GESECRAN
          #Endif
          #traitement des valeurs
          Filter [MDV] Where [F:MDV]MARSCTNUM = [F:MDF]MARSCTNUM and [F:MDV]CRINUM = [F:MDF]CRINUM
          INBRECORD = rowcount([MDV])
          INUMRECORD = 1
          For [MDV]MDV1
            Raz SZVALEUR
            If [F:MDF]MDFFIETYP = 3 Then
              Call CONVDI([F:MDV]MARVALDAT, SZVALEUR) From CRMUTIL150
            Else
              SZVALEUR = [F:MDV]MARSCTVAL
            Endif
            If INBRECORD < 2 Then
              IBCREE = 0
            Else
              If INUMRECORD = 1 Then
                IBCREE = 0
              Else
                IBCREE = 1
              Endif
            Endif
            If IBCREE = 0 Then
              #On modife l'enregistrement actuell
              [F:MDF]MDFVAL = SZVALEUR
              INBPARDEB = [F:MDF]NBPARDEB
              INBPARFIN = [F:MDF]NBPARFIN
              If INBRECORD > 1 Then
                [F:MDF]NBPARDEB = INBPARDEB + 1
                [F:MDF]NBPARFIN = 0
              Endif
              Rewrite [MDF]
              If fstat <> 0 Then
                Call ECR_TRACE("File MARDEF" - [F:MDF]MARSCTNUM - "/" - [F:MDF]CRINUM - "0, Error =" - num$(fstat),1) From GESECRAN
              Endif
            Else
              IBREWRITE = 0
              ICRINUM = [F:MDV]CRINUM + [F:MDV]SCTVALNUM
              #Readlock [MDF1]MDF1=[F:MDF]MARSCTNUM;ICRINUM  # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
              Read [MDF1]MDF1=[F:MDF]MARSCTNUM;ICRINUM       # FGR 11/03/2010 : X3SUIVI63191 : Ne sert à rien ici
              If fstat = 0 Then
                IBREWRITE = 1
              Else
                IBREWRITE = 0
                Raz [F:MDF1]
              Endif
              [F:MDF1] = [F:MDF]
              [F:MDF1]CRINUM = ICRINUM
              [F:MDF1]MARSCTOPD = 3
              [F:MDF1]NBPARDEB = 0
              [F:MDF1]MDFVAL = SZVALEUR
              If INUMRECORD = INBRECORD Then
                [F:MDF1]NBPARFIN = INBPARFIN + 1
              Else
                [F:MDF1]NBPARFIN = 0
              Endif
              If IBREWRITE = 1 Then
                Rewrite [MDF1]
              Else
                Write [MDF1]
              Endif
              If fstat <> 0 Then
                Call ECR_TRACE("File MARDEF 1" - [F:MDF1]MARSCTNUM - "/" - ICRINUM - "0, Error =" - num$(fstat),1) From GESECRAN
              Endif
            Endif
            INUMRECORD += 1
          Next
        Endif
        Filter [MDV]
      Next
      Filter [MDF]
      Rewrite [MST]
      If fstat Then
        Call ECR_TRACE("File MARSCT" - [F:MST]MARSCTNUM - "0, Error =" - num$(fstat),1) From GESECRAN
      Endif
    #Endif
    WNBR += 1
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS Then
      CLE1 = [F:MST]MARSCTNUM
      STOP = 1
      Break
    Endif
  Next
  Commit
  If STOP Then
    Goto BOUCLE_CRMSTEP1
  Endif
  Close Local File [MST]
End

###########################################################################################
# Mise à jour des textes traduisibles table TGRLIS
###########################################################################################
Subprog CRMSTEP2(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

  IERR = 0
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "TGRLIS", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".TGRLIS" [TGL]
    If dim([F:TGL]TGRNAM) > 0 Then
      For [TGL]TGL0
        Call MAJTEXTRA([F:TGL]TGRNAM, "TGRLIS", "TGRNAMAXX", [F:TGL]TGRTAB, "") From ATEXTRA
        If GOK < 1 Then
          Call ECR_TRACE("File ATEXTRA TGRLIS-TGRNAMAXX" - [F:TGL]TGRTAB + ",Error =" - num$(fstat), 1) From GESECRAN
          GOK = 1
          IERR = 1
          Break
        Endif
      Next
    Endif
    Close Local File [TGL]
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "SELSSP", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".SELSSP" [SSP]
      If dim([F:SSP]SPTNAM) > 0 Then
        For [SSP]SSP0
          Call MAJTEXTRA([F:SSP]SPTNAM, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA SELSSP-SPTNAMAXX" - [F:SSP]SPTNUM + ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [SSP]
    Endif
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "FIEDIC", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".FIEDIC" [FID]
      If dim([F:FID]CRITABNAM) > 0 Then
        For [FID]FID0
          Call MAJTEXTRA([F:FID]CRITABNAM, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA FIEDIC-CRITABAXX" - [F:FID]CRITAB - [F:FID]CAT - ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [FID]
    Endif
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "FIEDICFIE", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".FIEDICFIE" [FDF]
      If dim([F:FDF]SELCRINAM) > 0 Then
        For [FDF]FDF0
          Call MAJTEXTRA([F:FDF]SELCRINAM, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA FIEDICFIE-SELCRIAXX" - [F:FDF]CRITAB - [F:FDF]SELCRIFIE - [F:FDF]CAT - ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [FDF]
    Endif
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "MARSCT", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".MARSCT" [MST]
      If dim([F:MST]MARSCTNAM) > 0 Then
        For [MST]MST0
          Call MAJTEXTRA([F:MST]MARSCTNAM, "MARSCT", "MARSCTAXX", [F:MST]MARSCTNUM, "") From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA MARSCT-MARSCTAXX" - [F:MST]MARSCTNUM - ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [MST]
    Endif
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "SECPST", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".SECPST" [SPT]
      If dim([F:SPT]SPTNAM) > 0 Then
        For [SPT]SPT0
          Call MAJTEXTRA([F:SPT]SPTNAM, "SECPST", "SECPSTAXX", [F:SPT]SPTNUM, "") From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA SECPST-SECPSTAXX" - [F:SPT]SPTNUM - ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [SPT]
    Endif
  Endif
  #
  If IERR = 0 Then
    If filinfo(filpath("FIL", "TGRSSP", "fde", SZAPPLI), 0) > 0 Then
      Local File =SZAPPLI + ".TGRSSP" [TGP]
      If dim([F:TGP]DES) > 0 Then
        For [TGP]TGP0
          Call MAJTEXTRA([F:TGP]DES, "TGRSSP", "TGRAXX", [F:TGP]TGRSSPNUM, "") From ATEXTRA
          If GOK < 1 Then
            Call ECR_TRACE("File ATEXTRA TGRSSP-TGRAXX" - [F:TGP]TGRSSPNUM - ",Error =" - num$(fstat), 1) From GESECRAN
            GOK = 1
            IERR = 1
            Break
          Endif
        Next
      Endif
      Close Local File [TGP]
    Endif
  Endif
  #
  Close Local File [AXX]
End

###########################################################################################
# Mise à jour de l'étapes en cours dans les affaires OPPOR
###########################################################################################
Subprog CRMSTEP3(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer I
Local Integer IEXIT

  IERR = 0
  # FGR 10/03/2009 : X3SUIVIX3SUIVI53266
  If filinfo(filpath("FIL", "OPPOR", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".OPPOR" [OPP]
    If dim([F:OPP]OPPSTECLA) > 0 Then
      Trbegin [OPP]
      # Si la colonne OPPSTECLA existe encore il faut entretenir OPPSTEADI
      For [OPP]OPP0
        If [F:OPP]OPPSTE = "" Then
          # cas normalement impossible... mais au pire on est en avant vente
          [F:OPP]OPPSTEADI = 400
        Else
          # détecter si on est en avant-vente ou en après-vente
          If [F:OPP]STEX(0) = "" Then
            # Si le tableau après-vente est vide, on est en avant-vente
            [F:OPP]OPPSTEADI = 400
          Else
            #######################
            IEXIT = 0
            For I = 0 To dim([F:OPP]STE)-1
              If [F:OPP]STE(I) = [F:OPP]OPPSTE Then
                [F:OPP]OPPSTEADI = 400
                IEXIT = 1
                Break
              Endif
            Next
            If !IEXIT or 1=1 Then
              # Je passe ici même si IEXIT=1 pour le cas où le même code avant et après vente existerait
              For I = 0 To dim([F:OPP]STEX)-1
                If [F:OPP]STEX(I) = [F:OPP]OPPSTE Then
                  [F:OPP]OPPSTEADI = 421
                  Break
                Endif
              Next
            Endif
            #######################
          Endif
        Endif
        Rewrite [OPP]
        If fstat <> 0 Then
          Call ECR_TRACE("File OPPOR :" - [F:OPP]OPPNUM - ":" - num$(fstat), 1) From GESECRAN
          IERR = 1
        Endif
      Next
      If IERR Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Close Local File [OPP]
  Endif
End

###########################################################################################
# Mise à jour de la table diverse "433 : Catégories rendez-vous" (N2 = 1:Non)
###########################################################################################
Subprog CRMSTEP4(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer I
Local Integer IEXIT

  IERR = 0
  # FGR 23/03/2009 : X3SUIVI53600
  If filinfo(filpath("FIL", "ATABDIV", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".ATABDIV" [ADI]
    Trbegin [ADI]
    Filter [ADI] Where [F:ADI]NUMTAB = 433 and [F:ADI]N2 = 0
    For [ADI]CODE
      [F:ADI]N2 = 1  : # 1:NON
      Rewrite [ADI]
      If fstat <> 0 Then
        Call ECR_TRACE("File ATABDIV :" - [F:ADI]NUMTAB - "/" - [F:ADI]CODE - ":" - num$(fstat), 1) From GESECRAN
        IERR = 1
      Endif
    Next
    Filter [ADI]
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [ADI]
  Endif
End

###########################################################################################
# Mise à jour de la liste de gauche des correspondants
###########################################################################################
Subprog CRMSTEP5(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

Local Integer B_OK

  IERR = 0
  # FGR 26/03/2009 : X3SUIVI50275
  If filinfo(filpath("FIL", "AOBJLST", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI+".AOBJLST" [AOL]
    Trbegin [AOL]
    Read [AOL]AOL0="COR"
    If not fstat Then
      If [F:AOL]SELZON(2) = "FNC" or [F:AOL]SELZON(2) = "FNCLIB" Then
        [F:AOL]SELZON(2) = ""
        [F:AOL]SELFIC(2) = ""
        [F:AOL]SELEXP(2) = "string$([F:COR]FNC>0,mess([F:COR]FNC,233,1)) - string$(len([F:COR]FNCLIB)>0,'('+[F:COR]FNCLIB+')')"
        [F:AOL]SELINT(2)  = 103
        [F:AOL]SELTYP(2) = "A"
        [F:AOL]SELSAI(2) = ""
        [F:AOL]SELLNG(2) = 0
        Rewrite [AOL]
        If fstat <> 0 Then
          Call ECR_TRACE("Rewrite [F:AOL] Error="-num$(fstat), 1) From GESECRAN
          IERR = 1
        Endif
      Endif
    Endif
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [AOL]
  Endif
End

###########################################################################################
# Mise à jour du status "Cloturé" : OMM / OMT / OMN
###########################################################################################
Subprog CRMSTEP6(SZAPPLI, IERR)
Value Char SZAPPLI
Variable Integer IERR

  IERR = 0
  # FGR 15/04/2009 : X3SUIVI54325
  If filinfo(filpath("FIL", "MAILING", "fde", SZAPPLI), 0) > 0 and filinfo(filpath("FIL", "CMARKETING", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI+".CMARKETING" [CMG]
    Local File =SZAPPLI+".MAILING" [OMM]
    Trbegin [OMM]
    Filter [OMM] Where [F:OMM]CLO <> 1 and [F:OMM]CLO <> 2
    For [OMM]OMM0
      Read [CMG]CMG0=[F:OMM]CMGNUM
      If !fstat Then
        If [F:CMG]CLO = 2 Then
          [F:OMM]CLO = 2
          If [F:CMG]UPDDAT <> [0/0/0] and [F:CMG]UPDDAT >= [F:CMG]CREDAT Then
            [F:OMM]CLODAT = [F:CMG]UPDDAT
          Elsif [F:CMG]CREDAT <> [0/0/0] Then
            [F:OMM]CLODAT = [F:CMG]CREDAT
          Else
            [F:OMM]CLODAT = [F:CMG]DATEND
          Endif
        Else
          [F:OMM]CLO = 1
        Endif
      Else
        [F:OMM]CLO = 1
      Endif
      Rewrite [OMM]
      If fstat <> 0 Then
        Call ECR_TRACE("File MAILING :" - [F:OMM]OMMNUM - "/" - [F:OMM]CMGNUM - ":" - num$(fstat), 1) From GESECRAN
        IERR = 1
      Endif
    Next
    Filter [OMM]
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [OMM]
    Close Local File [CMG]
  Endif
  #-----------------------
  If filinfo(filpath("FIL", "TRADESHOW", "fde", SZAPPLI), 0) > 0 and filinfo(filpath("FIL", "CMARKETING", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI+".CMARKETING" [CMG]
    Local File =SZAPPLI+".TRADESHOW" [OMT]
    Trbegin [OMT]
    Filter [OMT] Where [F:OMT]CLO <> 1 and [F:OMT]CLO <> 2
    For [OMT]OMT0
      Read [CMG]CMG0=[F:OMT]CMGNUM
      If !fstat Then
        If [F:CMG]CLO = 2 Then
          [F:OMT]CLO = 2
          If [F:CMG]UPDDAT <> [0/0/0] and [F:CMG]UPDDAT >= [F:CMG]CREDAT Then
            [F:OMT]CLODAT = [F:CMG]UPDDAT
          Elsif [F:CMG]CREDAT <> [0/0/0] Then
            [F:OMT]CLODAT = [F:CMG]CREDAT
          Else
            [F:OMT]CLODAT = [F:CMG]DATEND
          Endif
        Else
          [F:OMT]CLO = 1
        Endif
      Else
        [F:OMT]CLO = 1
      Endif
      Rewrite [OMT]
      If fstat <> 0 Then
        Call ECR_TRACE("File TRADESHOW :" - [F:OMT]OMTNUM - "/" - [F:OMT]CMGNUM - ":" - num$(fstat), 1) From GESECRAN
        IERR = 1
      Endif
    Next
    Filter [OMT]
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [OMT]
    Close Local File [CMG]
  Endif
  #-----------------------
  If filinfo(filpath("FIL", "MEDIA", "fde", SZAPPLI), 0) > 0 and filinfo(filpath("FIL", "CMARKETING", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI+".CMARKETING" [CMG]
    Local File =SZAPPLI+".MEDIA" [OMN]
    Trbegin [OMN]
    Filter [OMN] Where [F:OMN]CLO <> 1 and [F:OMN]CLO <> 2
    For [OMN]OMN0
      Read [CMG]CMG0=[F:OMN]CMGNUM
      If !fstat Then
        If [F:CMG]CLO = 2 Then
          [F:OMN]CLO = 2
          If [F:CMG]UPDDAT <> [0/0/0] and [F:CMG]UPDDAT >= [F:CMG]CREDAT Then
            [F:OMN]CLODAT = [F:CMG]UPDDAT
          Elsif [F:CMG]CREDAT <> [0/0/0] Then
            [F:OMN]CLODAT = [F:CMG]CREDAT
          Else
            [F:OMN]CLODAT = [F:CMG]DATEND
          Endif
        Else
          [F:OMN]CLO = 1
        Endif
      Else
        [F:OMN]CLO = 1
      Endif
      Rewrite [OMN]
      If fstat <> 0 Then
        Call ECR_TRACE("File MEDIA :" - [F:OMN]OMNNUM - "/" - [F:OMN]CMGNUM - ":" - num$(fstat), 1) From GESECRAN
        IERR = 1
      Endif
    Next
    Filter [OMN]
    If IERR Then
      Rollback
    Else
      Commit
    Endif
    Close Local File [OMN]
    Close Local File [CMG]
  Endif
End

