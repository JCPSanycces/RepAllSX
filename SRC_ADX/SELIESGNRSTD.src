#<AdxTL>@(#)3.0.0.0 $Revision$
###############################################################################################################
###############################################################################################################
$ACTION

Case ACTION
    When "SEL_LISTE" : Gosub SEL_LISTE
Endcase

Return
###############################################################################################################
###############################################################################################################
$SEL_LISTE

Local Char FLD(20)
Local Char CPY(GLONCPY)
Local Char FLDFCY(GLONFCY)
Local Date DATAINI
Local Date DATAFIM

[L]FLD     = PARAM(1)
[L]CPY     = PARAM(2)
[L]DATAINI = PARAM(3)
[L]DATAFIM = PARAM(4)
[L]FLDFCY  = PARAM(5)

NBTEX    = 0
TIT(0)   = mess(52,7711,1)    # Selecção em Lista
TIT(1)   = mess(53,7711,1)    # Process No.
TIT(2)   = mess(54,7711,1)    # Company
TIT(3)   = mess(55,7711,1)    # Start date
TIT(4)   = mess(56,7711,1)    # End date

Gosub SEL

Return
###############################################################################################################
###############################################################################################################
$SEL

Local Char     TEXTE(GLONDES)(1..200,1..4)
Local Shortint I
Local Char     FILCRIT(255)
Local Char     TEX (50)(0..200)


If !clalev([F:DVPH1]) : Local File DCLVATPORH     [DVPH1]  : Endif
If !clalev([F:DVPF])  : Local File DCLVATPORF     [DVPF]   : Endif
If !clalev([F:TXP])   : Local File TXSP           [TXP]    : Endif
If !clalev([F:CSRH])  : Local File CSFRESH        [CSRH]   : Endif

I=1
Raz TEX
Raz TEXTE

Case FLD
  When "VAT"
    Filter [F:DVPH1] Where ([F:DVPH1]DCLTYP=2 and [F:DVPH1]CPY=[L]CPY and [F:DVPH1]STRDAT=[L]DATAINI and [F:DVPH1]ENDDAT=[L]DATAFIM)
    For [F:DVPH1]
      If dim(TEX)>0
        NBTEX = I

        TEX(I)=[F:DVPH1]DCLNUM
        TEXTE(I,1)=[F:DVPH1]DCLNUM
        TEXTE(I,2)=[F:DVPH1]CPY
        TEXTE(I,3)=format$("D:DD[-]MM[-]YYYY",[F:DVPH1]STRDAT)
        TEXTE(I,4)=format$("D:DD[-]MM[-]YYYY",[F:DVPH1]ENDDAT)
        I=I+1
      Endif
    Next
    Filter [F:DVPH1]
  When "04C"
    Filter [F:CSRH] Where ([F:CSRH]CPY=[L]CPY and [F:CSRH]DATDEB=[L]DATAINI  and [F:CSRH]DATFIN=[L]DATAFIM )

    For [F:CSRH]
      If dim(TEX)>0
        NBTEX = I

        TEX(I)=num$([F:CSRH]NUMRPT)
        TEXTE(I,1)=num$([F:CSRH]NUMRPT)
        TEXTE(I,2)=[F:CSRH]CPY
        TEXTE(I,3)=format$("D:DD[-]MM[-]YYYY",[F:CSRH]DATDEB)
        TEXTE(I,4)=format$("D:DD[-]MM[-]YYYY",[F:CSRH]DATFIN)
        I=I+1
      Endif
    Next
    Filter [F:CSRH]
  When "03A", "04A", "05241A", "0526A", "05281A", "05283A", "05284A", "05292A", "061A"
    FILCRIT = "[F:TXP]CPY=[L]CPY & [F:TXP]STRDAT=[L]DATAINI & [F:TXP]ENDDAT=[L]DATAFIM & [F:TXP]TXSNAM = [L]FLD & [F:TXP]COL = 1"
    Gosub SEL_TABORD
  When "05041A", "05071A", "05081A", "05121A", "0516A", "05191A", "05192A", "0522A", "0531A"
    FILCRIT = "[F:TXP]CPY=[L]CPY & [F:TXP]STRDAT=[L]DATAINI & [F:TXP]ENDDAT=[L]DATAFIM & [F:TXP]TXSNAM = [L]FLD & [F:TXP]COL = 2"
    Gosub SEL_TABORD
  When "ANEXOR"
  	FILCRIT = "[F:TXP]CPY=[L]CPY & [F:TXP]FCY=[L]FLDFCY & [F:TXP]STRDAT=[L]DATAINI & [F:TXP]ENDDAT=[L]DATAFIM & [F:TXP]TXSNAM = [L]FLD & [F:TXP]COL = 1"
  	Gosub SEL_TABORD
Endcase

Return
###############################################################################################################
###############################################################################################################
$SEL_TABORD

Filter [F:TXP] Where evalue (FILCRIT)
For [F:TXP]
  NBTEX = I
  If dim(TEX)>0
    TEX(I)=[F:TXP]VERSION
    TEXTE(I,1)=[F:TXP]VERSION
    TEXTE(I,2)=[F:TXP]CPY
    TEXTE(I,3)=format$("D:DD[-]MM[-]YYYY",[F:TXP]STRDAT)
    TEXTE(I,4)=format$("D:DD[-]MM[-]YYYY",[F:TXP]ENDDAT)
  Endif
  I=I+1
Next
Filter [F:TXP]

Return
###############################################################################################################
###############################################################################################################
$SET_FCY_LIST

[M]NBLIG1 = 0
Raz [M]LINNUM
Raz [M]FCY

Filter [F:FCY] Where [F:FCY]LEGCPY = [M]CPY & [F:FCY]FINFLG = 2 Order By [F:FCY]CREDAT; [F:FCY]FCY
For [F:FCY]
  [M]NBLIG1  += 1
  [M]LINNUM([M]NBLIG1-1) = [M]NBLIG1
  [M]FCY([M]NBLIG1-1) = [F:FCY]FCY
Next
Filter [F:FCY]

Return
#############################################################################################
#############################################################################################

