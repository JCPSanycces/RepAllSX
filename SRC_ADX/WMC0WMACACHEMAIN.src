 If this.AFCY(AINDCLA)<>null
  [L]ASTATUS = fmet this.AFCY(AINDCLA)._ASEARCHINFOS([L]AINS_ORI,ERR_TYPE,PROPERTY,ASTAT,SELSTAT,string$(PATH<>'',PATH+'.')+'AFCY('+num$(AINDCLA)+')')
