#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################
# UTISTO04   Moulinette pour initialiser SPERFLG,SPOTFLG    Module STOCK #
#            dans les tables STKTRS,BENCHTRS,MFGTRS,SALTRS,PURTRS        #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTISTO04(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO04(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR
Local Integer  WEXY, WTIT

Call ECR_TRACE("UTISTO04: Process Start on : "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:SRT])  =0  Local File =DOSSIER+".STKTRS"   [SRT] : Endif
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"    [ACV] : Endif

Read [ACV] CODACT="EXY"
If !fstat WEXY=[F:ACV]FLACT Endif
Read [ACV] CODACT="TIT"
If !fstat WTIT=[F:ACV]FLACT Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [SRT]
For [SRT] Where find(SRTTYP,1,5,7)
  Readlock [SRT] Curr    
  If !fstat
    If WEXY=2 [F:SRT]SPERFLG=2 Else [F:SRT]SPERFLG=1 Endif
    If WTIT=2 [F:SRT]SPOTFLG=2 Else [F:SRT]SPOTFLG=1 Endif
    Rewrite [F:SRT]
  Endif
  COMPTEUR += 1
Next
Commit
Close Local File [SRT]

If [F:ADS]MODULE(6)=2
  If clalev([F:BTS])  =0  Local File =DOSSIER+".BENCHTRS" [BTS] : Endif
  Trbegin [BTS]
  For [BTS] Where find(BTSTYP,62,63)
    Readlock [BTS] Curr    
    If !fstat
      If WEXY=2 [F:BTS]SPERFLG=2 Else [F:BTS]SPERFLG=1 Endif
      If WTIT=2 [F:BTS]SPOTFLG=2 Else [F:BTS]SPOTFLG=1 Endif
      Rewrite [F:BTS]
    Endif
    COMPTEUR += 1
  Next
  Commit
  Close Local File [BTS]
Endif

If [F:ADS]MODULE(7)=2
  If clalev([F:MTS])  =0  Local File =DOSSIER+".MFGTRS"   [MTS] : Endif
  Trbegin [MTS]
  For [MTS] Where MTSTYP=2
    Readlock [MTS] Curr     
    If !fstat
      If WEXY=2 [F:MTS]SPERFLG=2 Else [F:MTS]SPERFLG=1 Endif
      If WTIT=2 [F:MTS]SPOTFLG=2 Else [F:MTS]SPOTFLG=1 Endif
      Rewrite [F:MTS]
    Endif
    COMPTEUR += 1
  Next
  Commit
  Close Local File [MTS]
Endif

If [F:ADS]MODULE(4)=2
  If clalev([F:SLT])  =0  Local File =DOSSIER+".SALTRS"   [SLT] : Endif
  Trbegin [SLT]
  For [SLT] Where find(STRTYP,5,6,7)
    Readlock [SLT] Curr    
    If !fstat
      If WEXY=2 [F:SLT]SPERFLG=2 Else [F:SLT]SPERFLG=1 Endif
      If WTIT=2 [F:SLT]SPOTFLG=2 Else [F:SLT]SPOTFLG=1 Endif
      Rewrite [F:SLT]
    Endif
    COMPTEUR += 1
  Next
  Commit
  Close Local File [SLT]
Endif

If [F:ADS]MODULE(5)=2
  If clalev([F:PTR])  =0  Local File =DOSSIER+".PURTRS"   [PTR] : Endif
  Trbegin [PTR]
  For [PTR] Where PTRTYP=6
    Readlock [PTR] Curr    
    If !fstat
      If WEXY=2 [F:PTR]SPERFLG=2 Else [F:PTR]SPERFLG=1 Endif
      If WTIT=2 [F:PTR]SPOTFLG=2 Else [F:PTR]SPOTFLG=1 Endif
      Rewrite [F:PTR]
    Endif
    COMPTEUR += 1
  Next
  Commit
  Close Local File [PTR]
Endif

Call ECR_TRACE("UTISTO04 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO04(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTISTO04(APPLI)
End

