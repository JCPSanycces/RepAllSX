#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("DAD",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : Gosub EFFMASK
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "ANNULE"      : Gosub ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When Default
Endcase
Return

$INICRE
$INIMOD
If dim([F:DAD]DES)>0
 [F:DAD]DES = [M:DAD1]DESTRA
Endif
Return

$OUVRE
If clalev([F:DAD]) = 0 Local File CDIADSP [DAD] Endif
If clalev([F:LED]) = 0 Local File GLED [LED] Endif

#si 1ere consultation on se met sur le premier réf ana existant
#sinon sur la dernière consultation.
If !GIMPORT
 If CLE2=""
  Read [DAD]DAD0 First
  If !fstat
   CLE2 = [F:DAD]LED
  Else
   Filter [LED] Where [LED]ANA=2
   Read [LED] First
   CLE2 = [F:LED]LED
   Filter
  Endif
 Endif
 GBIDC1 = CLE2
Endif
Return

$LIENS
Call LECTEXTRA([M:DAD1]DESTRA,"CDIADSP","DESTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Call LECTEXTRA([M:DAD1]SHOTRA,"CDIADSP","SHOTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Return

$EFFMASK
# Zone réf en haut tjs vide en création . Pb avant MA=0 alors qu'ici un seul masque
# pas comme GESGAC .
If MA=1
 [M:DAD1]LED = GBIDC1
 Affzo [M:DAD1]LED
Endif
Return

$FILGAUCHE
FILGAUCHE = '[F:DAD]LED="'+GBIDC1+'"'
Return

$FILTRE
If GIMPORT : GBIDC1 = [F:DAD]LED : Endif
If GFONCTION="GESDAD"
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:DAD]LED="'+GBIDC1+'"'
 # Qd 1ére init. du dossier on se met sur le 1er Réf ana même si pas
 # de répartitions definies sur ce réf.
 If [M:DAD1]LED=""
  [M:DAD1]LED = GBIDC1
  Affzo [M:DAD1]LED
 Endif
Endif
Return

$SETBOUT
CHAINE += "H"
If GBIDC1 = ""
 Call VIREBOUT(CHAINE,"CA") From GOBJET
Else
 If !find('A',CHAINE) Then CHAINE += 'A' : Endif
 If CLECUR = 0 Then
  Call VIREBOUT(CHAINE,"A") From GOBJET
 Endif
 # si nouvelle répartition pour un réf donné , bouton réf inaccessible.
 If GREP="C"
  Call VIREBOUT(CHAINE,"1") From GOBJET
 Endif
Endif
Return

#--------------#
$SET_TYP
Local Integer NBTEX
Local Char    TEX(10)(1..500),TEXTE(50)(1..500,1..2)
NBTEX = 0
For [GSP]GSP0(2) Where DIE=[M]DIE(nolign-1)
 NBTEX += 1 : TEX(NBTEX) = [F:GSP]COD : TEXTE(NBTEX,2) = [F:GSP]DIE
 If NBTEX>=dim(TEX)
  Call ERREUR(mess(26,100,1)) From GESECRAN
  Break
 Endif
Next
Return

$SEL_LISTE
Gosub SET_TYP
For I=1 To NBTEX
 TEXTE(I,1) = TEX(I)
Next I
Sorta NBTEX TEX Order By TEX(indice+1)
For I=1 To NBTEX
 J = find(TEX(I),TEXTE(1..NBTEX,1))
 If J<>I
  TEXTE(J,1) = TEXTE(I,2)
  TEXTE(I,2) = TEXTE(J,2)
  TEXTE(J,2) = TEXTE(J,1)
  TEXTE(J,1) = TEXTE(I,1)
  TEXTE(I,1) = TEX(I)
 Endif
Next I
# Choix d'un groupe récepteur
TIT(0) = mess(297,195,1)
# Code
TIT(1) = mess(15,159,1)
# Axe
TIT(2) = mess(206,111,1)
# Intitulé
TIT(3) = mess(82,123,1)
Return

$EXEBOUT
Case REP
 When "1"
  If (VALBOUT = "") : Return : Endif
  Gosub DEVERROU From GOBJET
  Effzo
  [M:DAD1]LED = VALBOUT
  GBIDC1 = [M]LED
  Affzo [M]LED
  Gosub REMPLIT From GOBJSUB
  Filter [DAD] Where LED=GBIDC1
  Read [DAD]DAD0 First
  Filter [DAD]
  If !fstat
   CLECUR  = 1
   CLECUR1 = [F:DAD]LED
   CLECUR2 = GBIDC1
   Gosub LECTURE From GOBJSUB
  Endif
Endcase
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("CDIADSP","DESTRA",CLECUR2,CLECUR1,"CDIADSP","DESTRA",[M:DAD1]LED,[M:DAD1]COD)  From ATEXTRA
 Call DUPTEXTRA("CDIADSP","SHOTRA",CLECUR2,CLECUR1,"CDIADSP","SHOTRA",[M:DAD1]LED,[M:DAD1]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M:DAD1]DESTRA,"CDIADSP","DESTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Call MAJTEXTRA([M:DAD1]SHOTRA,"CDIADSP","SHOTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("CDIADSP","DESTRA",[M:DAD1]LED,[M:DAD1]COD,[M:DAD1]LED,NCODE) From ATEXTRA
Call CHGTEXTRA("CDIADSP","SHOTRA",[M:DAD1]LED,[M:DAD1]COD,[M:DAD1]LED,NCODE) From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("CDIADSP","DESTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Call SUPTEXTRA("CDIADSP","SHOTRA",[M:DAD1]LED,[M:DAD1]COD) From ATEXTRA
Return


###############################################################
#  Etiquette du masque DAD1 Répartitions à posteriori
###############################################################

Subprog AS_DIE(VALEUR)
Variable Char  VALEUR
If GOPTCANA=1 : mkstat = 2 : End : Endif
For I=9 To GOPTCANA+1 Step -1
 GMENLOC(I) = 1
Next I
End

Subprog C_PRC(VALEUR)
Variable Decimal  VALEUR
End

Subprog AS_UOM(VALEUR)
Variable Char     VALEUR
If [M]TYP(nolign-1)<>1
 mkstat = 1 : End
Endif
End

Subprog C_UOM(VALEUR)
Variable Char     VALEUR
End

Subprog C_ACCREF(VALEUR)
Variable Char    VALEUR
Local    Char    CHAINE(40)
VALEUR = toupper(VALEUR)
CHAINE = VALEUR
If CHAINE<>""
For I=1 To len(CHAINE)
  If !instr(1,"?*-ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",mid$(CHAINE,I,1))
   # Expression incorrecte
   GMESSAGE = num$(mid$(CHAINE,I,1))-":"-mess(37,124,1)
   mkstat = 2 : End
  Endif
 Next I
 Gosub SETGAC
 If JOKER=0
  Call CONTROLE("GAC","",VALEUR,[M]COA(nolign-1),mkstat) From CONTOBJ
  If !fstat & [F:GAC]SAC=2
  # Compte collectif non autorisé
  GMESSAGE = mess(123,106,1)
  mkstat = 2 : End
  Endif
 Endif
Endif
End


Subprog AS_ACCDSP(VALEUR)
Variable Char     VALEUR
If [M]TYP(nolign-1)=1
 mkstat = 1
Endif
End

Subprog C_ACCDSP(VALEUR)
Variable Char    VALEUR
Local    Char    CHAINE(40)
VALEUR = toupper(VALEUR)
CHAINE = VALEUR
If CHAINE<>""
 For I=1 To len(CHAINE)
  If !instr(1,"?*-ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",mid$(CHAINE,I,1))
   # Expression incorrecte
   GMESSAGE = num$(mid$(CHAINE,I,1))-":"-mess(37,124,1)
   mkstat = 2 : End
  Endif
 Next I
 Gosub SETGAC
 If JOKER=0
  Call CONTROLE("GAC","",VALEUR,[M]COA(nolign-1),mkstat) From CONTOBJ
  If !fstat & [M]TYP(nolign-1)=3 & [F:GAC]FLGUOM<>2
   #Nature sans unité d'oeuvre
   GMESSAGE = mess(23,103,1)
   mkstat = 2 : End
  Endif
  If !fstat & [F:GAC]SAC=2
  # Compte collectif non autorisé
  GMESSAGE = mess(123,106,1)
  mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_CCEREF(VALEUR)
Variable Char     VALEUR
If VALEUR="" : VALEUR = "*" : Endif
If VALEUR = [M]CCERCP(nolign-1)
 Gosub SETCCE
 If JOK
  # "Section à répartir et réceptrice identiques"
  # "Jockers non autorisés"
  GMESSAGE = mess(71,103,1)-":"+"\"+tolower(mess(74,103,1))
  mkstat = 2 : End
 Endif
Endif
If VALEUR<>"*"
 Gosub SETCCE
 If len(CCE)=len(VALEUR)
  Call CONTROLE("CCE","",CCE,num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
  If !mkstat : VALEUR = CCE : Endif
 Else
  VALEUR = toupper(VALEUR)
 Endif
Endif
End

$SETGAC
Local Integer I, JOKER
For I=1 To len(VALEUR)
 If instr(1,"?*",mid$(VALEUR,I,1)) : JOKER = 1 : Break: Else JOKER = 0 : Endif
Next I
JOKER
Return

$SETCCE
Local Char CCE(GLONCCE)
Local Integer I, L, JOK
JOK = 0
For I=1 To len(VALEUR)
 If instr(1,"?*",mid$(VALEUR,I,1)) : JOK = 1 : Break: Else L+=1 : Endif
Next I
CCE=toupper(left$(VALEUR,L))
Return

Subprog AS_CCERCP(VALEUR)
Variable Char    VALEUR()
If [M]GSP(nolign-1)<>"" : mkstat = 1 : End : Endif
End

Subprog C_CCERCP(VALEUR)
Variable Char     VALEUR
If VALEUR="" : VALEUR = "*" : Endif
If VALEUR = [M]CCEREF(nolign-1)
 Gosub SETCCE
 If JOK
  # "Section à répartir et réceptrice identiques"
  # "Jockers non autorisés"
  GMESSAGE = mess(71,103,1)-":"+"\"+tolower(mess(74,103,1))
  mkstat = 2 : End
 Endif
Endif
If VALEUR<>"*"
 Gosub SETCCE
 If len(CCE)=len(VALEUR)
  Call CONTROLE("CCE","",CCE,num$([M]DIE(nolign-1)),mkstat) From CONTOBJ
  If!mkstat : VALEUR=CCE : Endif
 Else VALEUR=toupper(VALEUR)
 Endif
Endif
End

Subprog C_GSP(VALEUR)
Variable Char    VALEUR()
Filter [GSP] Where DIE=[M]DIE(nolign-1) and COD=VALEUR
Read [GSP] First
Filter [GSP]
If VALEUR<>"" & [F:GSP]DIE<>[M]DIE(nolign-1)
 # Axe incorrect
 GMESSAGE = mess(100,105,1)-[F:GSP]DIE
 mkstat = 2 : End
Endif
End


Subprog AS_COA(VALEUR)
# Le plan de compte doit tjs être celui du référentiel choisit
Variable Char    VALEUR()
If ([M]DIE(nolign-1)) <> ""
 Call LECTURE("LED",[M]LED,"") From CONTOBJ
 VALEUR = [F:LED]COA
Endif
End

Subprog AS_COD(VALEUR)
# Le référentiel choisit doit être analytique
Variable Char    VALEUR()
If [M]COD = "" & [M]LED <> ""
Call LECTURE("LED",[M]LED,"") From CONTOBJ
 If [F:LED]ANA<>2
  #Le référentiel doit être coché analytique
  GMESSAGE = mess(108,103,1)
  mkstat = 2 : End
  #zonsui = "[M]COD" : End
 Endif
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
Call LECTURE("LED",[M]LED,"") From CONTOBJ
 If [F:LED]ANA<>2
  #Le référentiel doit être coché analytique
  GMESSAGE = mess(108,103,1)
  mkstat = 1  : End
 Endif
Endif
End

Subprog B1_ACCREF(VALEUR)
Variable Char    VALEUR()
End

Subprog D_COA(VALEUR)
Variable Char    VALEUR()
If ([M]DIE(nolign-1)) <> ""
 Call LECTURE("LED",[M]LED,"") From CONTOBJ
 VALEUR = [F:LED]COA
Endif
End

Subprog S_ACCORI(VALEUR)
Variable Char    VALEUR()
End

Subprog S_DIE(VALEUR)
Variable Char    VALEUR()
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M]DIE
 Read [LED]LED0= [M]LED
 If !find(VALEUR,[F:LED]DIE(0..([F:LED]DIENBR)-1))
  # Axe non défini sur le référentiel
  GMESSAGE = mess(81,103,1)
  mkstat=1 : End
 Endif
Endif
End

Subprog B1_ACCDSP(VALEUR)
Variable Char    VALEUR()
End

Subprog C_ACCORI(VALEUR)
# Ctrl sur le compte saisi de type alpha
# les mêmes que ceux pour ceux de type GAC
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR <> ""
 Call INIACCFMT([M]COA(nolign-1)) From SETGLBCOA
 Call CONTROLE("GAC","",VALEUR,[M]COA(nolign-1),mkstat) From CONTOBJ
  If !fstat & [F:GAC]SAC=2
   # Compte collectif non autorisé
   GMESSAGE = mess(123,106,1)
   mkstat = 2 : End
  Endif
Endif
End

Subprog C_ACCDEN(VALEUR)
# Ctrl sur le compte saisi de type alpha
# les mêmes que ceux pour ceux de type GAC
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR <> ""
 Call INIACCFMT([M]COA(nolign-1)) From SETGLBCOA
 Call CONTROLE("GAC","",VALEUR,[M]COA(nolign-1),mkstat) From CONTOBJ
  If !fstat & [F:GAC]SAC=2
   # Compte collectif non autorisé
   GMESSAGE = mess(123,106,1)
   mkstat = 2 : End
  Endif
Endif
End




