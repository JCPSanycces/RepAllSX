#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# CLASS PJMACOPY
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
# Control method should be in the class not in the screen !
$EVENTS
  Case [L]CURPTH
     When ""
      Case [L]AEVENT
      Endcase
  Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "INIT_FROM_PROJECT"       :  Gosub INIT_FROM_PROJECT
        When "GET_TASK_RECODIFIED"     :  Gosub GET_TASK_RECODIFIED            # make sure the parent is aligned on the task during the copy
        When "GET_BUDGET_RECODIFIED"   :  Gosub GET_BUDGET_RECODIFIED          # make sure the parent is aligned on the budget during the copy
        When Default
      Endcase
    When Default
  Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

##########################################################################################################
# PJMACOPY METHOD
##########################################################################################################
$INIT_FROM_PROJECT
#Variable Instance OPPOR Using C_OPPOR : #
#Local Integer ARET_VALUE

Local Integer NI
Local Integer ILINE

  ARET_VALUE = [V]CST_ASUCCESS
  # see file name: C_PJMACOPY; App:GX3APP;  Directory: STC;  Type: .stc
  # this will show what has been setup by the supervisor to pass the parameters
  # Global comment : you have to put in the class only properties which are necessary for doing the copy.
  # Those which are used to help the user must not be in the class. It's "expensive" to manage them and they are using memory
  #####################################
  # PJMACOPY HEADER
  #####################################
  this.SALFCY   = OPPOR.SALFCY             # I'm not sure that this value should be in the class.
  this.OPPNUM   = OPPOR.OPPNUM             # This is a display information. It should be only in the screen.
  this.OPPDES   = OPPOR.PIMPL.PIMDESAXX    # About description, if in the screen the datatype PIM is set, it will be automatic with long link set to "yes"
  this.OPPSTATE = OPPOR.PJM.OPPSTATE       # Same comment about OPPSTATE. This is a display information. Is the right class referenced ?
  this.DESDES   = OPPOR.PIMPL.PIMDESAXX    # About description, if in the screen the datatype PIM is set, it will be automatic with long link set to "yes"
  #####################################
  # PJMACOPY HEADER BLOCKS
  #####################################
  this.AFFDESC   = [V]CST_AYES
  this.AFFCOM    = [V]CST_ANO
  this.BUDALL    = [V]CST_ANO
  this.BLIGNES   = [V]CST_AYES
  this.TACALL    = [V]CST_ANO
  this.TASPRL    = [V]CST_AYES
  this.TASOPL    = [V]CST_AYES
  this.TASASSL   = [V]CST_ANO
  #####################################
  # PJMACOPY ADDITIONAL CRITERIA
  #####################################
  this.TACDES    = [V]CST_AYES
  this.TACCOM    = [V]CST_ANO
  this.TACDAT    = [V]CST_AYES
  this.TASPRDES  = [V]CST_AYES
  this.TASPRCOM  = [V]CST_ANO
  this.TASOPDES  = [V]CST_AYES
  this.TASOPCOM  = [V]CST_ANO
  this.TASOPDAT  = [V]CST_AYES
  this.TASASSDES = [V]CST_AYES
  this.TASASSCOM = [V]CST_ANO
  this.TASASSDAT = [V]CST_AYES
  this.BUDDES    = [V]CST_AYES
  this.BUDCOM    = [V]CST_ANO
  this.BUDDAT    = [V]CST_AYES
  this.BUDLDES   = [V]CST_AYES
  this.BUDLCOM   = [V]CST_ANO
  ###########################################################################################################
  # PJMACOPY TASK GRID
  ###########################################################################################################
  For NI = 1 To maxtab(OPPOR.PJM(1).TAS)
    #If OPPOR.PJM(1).TAS(NI) <> null and find(OPPOR.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
    If OPPOR.PJM(1).TAS(NI) <> null and find(OPPOR.PJM(1).TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ILINE = fmet this.ADDLINE("TASK",[V]CST_ALASTPOS)
      If ILINE = [V]CST_ANOTDEFINED Then
        ARET_VALUE = [V]CST_AERROR
        Break
      Endif
      this.TASK(ILINE).SELTAC   = this.TACALL
      this.TASK(ILINE).TASCOD   = OPPOR.PJM(1).TAS(NI).PIMPL.TASCOD              # This is a display information. It should be only in the screen. Referencing the right class ?
      this.TASK(ILINE).TASDES   = OPPOR.PJM(1).TAS(NI).PIMPL.PIMDESAXX           # I'm not sure that this value should be in the class.
      this.TASK(ILINE).TASNCOD  = OPPOR.PJM(1).TAS(NI).PIMPL.TASCOD              # Referencing the right class ?
      this.TASK(ILINE).TASNDES  = OPPOR.PJM(1).TAS(NI).PIMPL.PIMDESAXX
      this.TASK(ILINE).TASPBU   = OPPOR.PJM(1).TAS(NI).PBUCOD                    # Don't know what to reference
      this.TASK(ILINE).TASSTATE = OPPOR.PJM(1).TAS(NI).TASSTATE                  # I'm not sure that this one is needed for the copy
      this.TASK(ILINE).TASPAE   = OPPOR.PJM(1).TAS(NI).TASPAE                    # Need for selecting/deselecting for now
      this.TASK(ILINE).TASFCY   = OPPOR.PJM(1).TAS(NI).TASFCY
      this.TASK(ILINE).TASLINE  = NI
      #--------------------------------------------------------------------------------------------------------------------------
      # In performance way, I suggest to add in the collection, a property which contain the line of the budget in OPPOR class
      # It will be easier after.
      # It will not be necessary to find the budget line in OPPOR collection.
      # For example to get the OPPOR.PJM(1).BUD(NI).PIMPL.PIMDESAXX value for the screen
      # this.BUDGET(ILINE).BUDLIN = NI
      #--------------------------------------------------------------------------------------------------------------------------
    Endif
  Next NI
  ###########################################################################################################
  # PJMACOPY BUDGET GRID
  ###########################################################################################################
  For NI = 1 To maxtab(OPPOR.PJM(1).BUD)
    #If OPPOR.PJM(1).BUD(NI) <> null and find(OPPOR.PJM(1).BUD(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0 Then
    If OPPOR.PJM(1).BUD(NI) <> null and find(OPPOR.PJM(1).BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      ILINE = fmet this.ADDLINE("BUDGET",[V]CST_ALASTPOS)
      If ILINE = [V]CST_ANOTDEFINED Then
        ARET_VALUE = [V]CST_AERROR
        Break
      Endif

      this.BUDGET(ILINE).SELBUD   = this.BUDALL
      this.BUDGET(ILINE).PBUCOD   = OPPOR.PJM(1).BUD(NI).PBUCOD                     # This is a display information. It should be only in the screen. Referencing the right class ?
      this.BUDGET(ILINE).PBUDES   = OPPOR.PJM(1).BUD(NI).PIMPL.PIMDESAXX            # I'm not sure that this value should be in the class.
      this.BUDGET(ILINE).DESTCOD  = OPPOR.PJM(1).BUD(NI).PIMPL.PBUCOD               # Referencing the right class ?
      this.BUDGET(ILINE).DESTDES  = OPPOR.PJM(1).BUD(NI).PIMPL.PIMDESAXX            # I'm not sure that this value should be in the class
      this.BUDGET(ILINE).PBUSTATE = OPPOR.PJM(1).BUD(NI).PBUSTATE                   # Don't know what to reference
      this.BUDGET(ILINE).PBUPAE   = OPPOR.PJM(1).BUD(NI).PBUPAE                     # Need for selecting/deselecting for now
#      If this.ACTX.USER = "FGR" Then
#        Dbgaff
#        this.BUDGET(ILINE).PBUFCY   = OPPOR.PJM(1).BUD(NI).PBUFCY
#      Endif
      this.BUDGET(ILINE).PBUFCY   = OPPOR.PJM(1).BUD(NI).PBUFCY
      this.BUDGET(ILINE).BUDLINE  = NI

      #--------------------------------------------------------------------------------------------------------------------------
      # In performance way, I suggest to add in the collection, a property which contain the line of the budget in OPPOR class
      # It will be easier after.
      # It will not be necessary to find the budget line in OPPOR collection.
      # For example to get the OPPOR.PJM(1).BUD(NI).PIMPL.PIMDESAXX value for the screen
      # this.BUDGET(ILINE).BUDLIN = NI
      #--------------------------------------------------------------------------------------------------------------------------
    Endif
  Next NI
Return

##########################################################################################################
# Make sure copied task is linked to the correct parent
# We are in the process of copying a task that is linked to a parent
# Find the old parent code in the TECCLA task grid/collection,
# and see if the destination task for the parent has changed
# If it has then replace the parent with the new destination code
##########################################################################################################
$GET_TASK_RECODIFIED
#Value Char CODTAC ()
#Local Char ARET_VALUE(250)

Local Integer TI

  Raz [L]ARET_VALUE
  If CODTAC <> "" Then                                               # task being copied has a parent
    For TI = 1 To maxtab(this.TASK)                                  # go through TECCLA task grid/collection
      If this.TASK(TI) <> null and find(this.TASK(TI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        # if source project task code is same as target see if changed
        If this.TASK(TI).TASCOD = CODTAC Then                        # if source from TECCLA class is same as parent on current task
          [L]ARET_VALUE = this.TASK(TI).TASNCOD                      # replace parent on the task with new code
          Break
        Endif
      Endif
    Next TI
  Endif
Return

##########################################################################################################
# Make sure copied budget is linked to the correct parent
# We are in the process of copying a budget that is linked to a parent
# Find the old parent code in the TECCLA budget grid/collection,
# and see if the destination budget code for the parent has changed
# If it has then replace the parent with the new destination code
##########################################################################################################
$GET_BUDGET_RECODIFIED
#Value Char CODPBU ()
#Local Integer ARET_VALUE

Local Integer TI

  Raz [L]ARET_VALUE
  If CODPBU <> "" Then
    For TI = 1 To maxtab(this.BUDGET)
      If this.BUDGET(TI) <> null and find(this.BUDGET(TI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        # if source project budget code is same as target see if changed
        If this.BUDGET(TI).PBUCOD = CODPBU Then
          [L]ARET_VALUE = this.BUDGET(TI).DESTCOD                    # new destination code of parent
          Break
        Endif
      Endif
    Next TI
  Endif
Return

