#<AdxTL>@(#)11.0.0.0 $Revision$
##############################################################################
## DEMANDE 50922
## Suppression des ACCMIS(11) et ACCMIS(12)
##   Ligne 12 Compte de bénéfice
##   Ligne 13 Compte de perte
##
##  L'utilitaire ne peut être lancé une seule fois donc :
##   - vendredi : valeur bidon en ligne 19
##   - WE utilitaire se lance en automatique
##   - lundi : suppression de la valeur bidon
##############################################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".APLSTD" [AST]
Filter [AST] Where LANCHP=2649 & LANNUM=19 & LAN="FRA"
Read [AST] First
If !fstat and [F:AST]LANMES="inter"


 Local File =DOSSIER+".GCOA" [COA]
 Local Integer GOK

 GOK = 0
 Trbegin  [COA]

 For [COA]
 
  [F:COA]ACCMIS(11) = [F:COA]ACCMIS(13)
  [F:COA]ACCMIS(12) = [F:COA]ACCMIS(14)
  [F:COA]ACCMIS(13) = [F:COA]ACCMIS(15)
  [F:COA]ACCMIS(14) = [F:COA]ACCMIS(16)
  [F:COA]ACCMIS(15) = [F:COA]ACCMIS(17)
  [F:COA]ACCMIS(16) = [F:COA]ACCMIS(18)
  [F:COA]ACCMIS(17) = [F:COA]ACCMIS(19)
  [F:COA]ACCMIS(18) = ""
  [F:COA]ACCMIS(19) = ""

  Rewrite [COA]
  If fstat : GOK=1 : Break : Endif
 
 Next

 If !GOK
  Commit
 Else
  Rollback
 Endif

Endif

Close Local File
End
