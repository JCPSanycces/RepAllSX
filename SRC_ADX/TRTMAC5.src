##########################################################################################################
$BOUTON
#Case BOUT
#    When "A"
#        VALEUR = [M:MAC5]CCNNUM(GMAC5NOL)
#        If type(GSZCUTBPCTYP) > 0
#            GSZCUTBPCTYP = "CCN"
#        Endif
#        FIN = 1
#    When Default
#Endcase

Case BOUT
    When "A"
        If (nolign-1)>=0
            If [M:MAC5]CCNNUM(nolign-1)<>""
                VALEUR = [M:MAC5]CCNNUM(nolign-1)
                FIN = 1
            Endif
        Endif
    When "C"
        Gosub ONLOAD
    When Default
Endcase

Return

##########################################################################################################
$ONMENU
Return


##########################################################################################################
$ONLOAD

Local Char SZWHERE (250)
Raz SZWHERE
Local Char SZVALEUR (250)
Raz SZVALEUR
Local Char SZRECHERCHE (250)
Raz SZRECHERCHE
Local Integer ILIGNE
ILIGNE = 0

Local Integer INBLIGNETOTAL
INBLIGNETOTAL=0

#Raz [M:MAC5]NBREC
#Raz [M:MAC5]NAM
#Raz [M:MAC5]ZIP
#Raz [M:MAC5]CTY
#Raz [M:MAC5]TEL
#Raz [M:MAC5]CRY
#Raz [M:MAC5]CCNNUM

Effzo [M:MAC5]15
[M:MAC5]NBREC=0

If !clalev([F:AIN]) : Local File "CONTACTCRM" [AIN] : Endif

SZWHERE=" [F:AIN]CNTTYP=1 "

If [M:MAC5]CCNLNA<>""
    SZVALEUR=[M:MAC5]CCNLNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE= SZWHERE +" and pat ( toupper([F:AIN]CNTLNA)," +SZRECHERCHE+" )<>0 "
Endif

If [M:MAC5]CCNFNA<>""
    SZVALEUR=[M:MAC5]CCNFNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE='"'+toupper(SZVALEUR)+'*"'
    SZWHERE=SZWHERE + " and pat (toupper([F:AIN]CNTFNA)," +SZRECHERCHE+" )<>0 "
Endif

If SZWHERE <>""
    Filter  [AIN] Where evalue (SZWHERE ) Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
Else
    Filter  [AIN] Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
Endif

INBLIGNETOTAL=rowcount([AIN])

For [AIN]
    If ILIGNE >= dim([M:MAC5]NAM) - 1 : Break : Endif
    Call BUILDFULNAM("AIN", [M:MAC5]NAM(ILIGNE)) From CRMUTIL140
    [M:MAC5]CCNNUM(ILIGNE) = [F:AIN]CNTNUM
    [M:MAC5]ZIP(ILIGNE) = [F:AIN]ZIP
    [M:MAC5]CTY(ILIGNE) = [F:AIN]CTY
    [M:MAC5]TEL(ILIGNE) = [F:AIN]CNTETS
    [M:MAC5]CRY(ILIGNE) = [F:AIN]CRY
    
    ILIGNE += 1
Next

Filter [AIN]

[M:MAC5]NBREC = ILIGNE

Affzo [M:MAC5]1-99

If ILIGNE<INBLIGNETOTAL
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963, 182, 2)
    GERR = 2
Endif

Return


