########################################
Subprog AS_NBCSE
If nolign - 1 >= dim([M:CONE]CONNUM) - 1
    End
Endif
If nolign > 0
    GSZCSENUM = [M:CONE]CONNUM(nolign - 1)
Endif
End

########################################
Subprog C_NBCSE
If nolign - 1 >= dim([M:CONE]CONNUM) - 1
    End
Endif
If nolign > 0
    GSZCSENUM = [M:CONE]CONNUM(nolign - 1)
Endif
End

