#<AdxTL>@(#)5.0.0.0 $Revision$
Call OBJET("SMR", GBIDC1, GBIDC2) From GOBJET
End

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#######################################################################
# Les etiquettes suivantes sont définies pour la gestion de l'objet   #
#######################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If GFONC1 <> "GESSMR" Raz GFLAG Endif

If GFLAG<>""
  Read [F:SRT] SRT0=1;GFLAG
  If fstat | [F:SRT]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0
        Local File ACCES  [ACC]
        OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif

Read [SRT]SRT0=1;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2
   OK = 0
Endif
Return
######################################################################
$SETTRANS
Global Integer  GCCECOD    : # Flag saisie des sections analytiques
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif

If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=1;GFLAG

#MAE, le 28/01/08, evol GRP_SITE
GGRPFCY = [SRT]GFY
GSMRNUM = [SRT]SRTNUM                # hcb 50197
# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:SRT]WRHOBY
Else
  GWRHOBY = 1
Endif
GSVGWRHOBY = GWRHOBY
Return

######################################################################
$OUVRE
If dim(GSVGWRHOBY)<0 Global Integer GSVGWRHOBY Endif
Local  Integer  LRET
# Si on vient par tunnel il faut sauvegarder les variables globales
Raz GSOC_ACTIVE                                               # Ana

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
# en import test il ne faut pas controler les compteurs  bug 28275

    Global Integer GRELITSMR
    Raz GRELITSMR

    GSRTNUM = GFLAG
    GSMRNUM = GFLAG              # hcb 50197


    # TRSTYP = type de mouvement stock (menu local 704)
    # Sa valeur est utilisée en particulier
    # pour le contrôle de statut
    [M:SMR0]VCRTYP = 19
    [M:SMR0]TRSTYP = 1
    # Récupération des codes compteur et effacement fichier de travail
    # Compteur module stock




 $OUVRE_SUIT

GFCY=GFCYDEF(7)                                                # Ana
Gosub CHARG_PARAM                                              # Ana
If GMODU(2)=2 : # Si module compta actif                       # Ana
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif    # Ana
Endif                                                          # Ana
GORITITCOL=1                                                   # Ana

                                # hcb 090205 28275

    # Initialisation des tables nécessaires à la gestion d'emplacements
    Gosub STK_INILOC From STKLOC

    #  ecran stockage mvt du document
    If clalev([M:ENTW])=0
        Local Mask STOENTW   [ENTW]
    Endif
    Raz [M:ENTW]

    [M:ENTW]WZONPCU = "PCU"
    [M:ENTW]WZONQUC = "QTYPCU"
    [M:ENTW]WZONCCS = "PCUSTUCOE"
    [M:ENTW]WZONQUS = "QTYSTU"
    [M:ENTW]WZONSTOUPD = ""

    Call DELSTOENTW(-1,-1,"SMR1",1,1,[M:SMR0]STOFCY,1,"") From STKENT
    #  ecran de travail enreg mvt du document
    If clalev([M:STW])=0
        Local Mask STOWORK   [STW]
    Endif
    Raz [M:STW]
    If clalev([M:VALW])=0
        Local Mask STOVALW   [VALW]
    Endif
    Raz [M:VALW]
    [M:VALW]ZONPRI = "[M:SMR1]PRI"
    [M:VALW]ZONPRIORD = "[M:SMR1]PRIORD"
    If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

    If !GVTMOD : Gosub DECLARE From TABLEAUX : Endif
Return

$FILTRE
    Default File [SMH]
    # Limite les enregistrement de la liste gauche
    # aux entrées diverses (m701-19)
    FILTSUP = "VCRTYP=19"
Return

$LIENS
Local Integer I

If GFCY<>[F:SMH]STOFCY GFCY=[F:SMH]STOFCY : Gosub CHARG_PARAM : Endif    # Ana
#----- Affichage entêtes de colonne variables -----#                     # Ana
Gosub AFF_TITCOL                                                         # Ana

# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDAT) > 0
   Kill GCTRDAT
Endif


    Raz GRELITSMR
#    Call GETDEV([M:SMR0]STOFCY) From DEVSUB                   # ana
    Call DELSTOENTW(-1,-1,"SMR1",1,1,[M:SMR0]STOFCY,1,"") From STKENT

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif

    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0       # Ana
    If fstat                                                    # Ana
       Raz [F:DTR]                                              # Ana
    Endif                                                       # Ana

    Actzo [M:SMR0]VCRNUM    # Car il y a un diszo en RAZCRE (et RAZDUP)
    Grizo [M:SMR0]STOFCY
    Grizo [M:SMR0]IPTDAT
    Grizo [M:SMR0]PJT
    Grizo [M:SMR0]TRSFAM
    Grizo [M:SMR0]ENTCOD

    [M:SMR0]SRGWAIFLG = [F:SRT]SRGWAIFLG    # hcb 50197
    [M:SMR0]MVTPRICOD = [F:SRT]MVTPRICOD    # hcb 50197

    Actzo [M:SMR1]
    Gosub LIENS From TABLEAUX
#   [M:SMR0]CCECODS = [F:SRT]HEACCECOD
    [M:SMR0]CCECODS = [F:DTR]HEACCECOD               # Ana
    For I=1 To GNBDIE                                # Ana
        [M:SMR0]CCE(I-1) =  [F:SMH]CCE(I-1)          # Ana
        [M:SMR0]DIE(I-1) =  GDIE(I)   # hcb 69574
    Next                                             # Ana

    # Ce qui suit ne fonctionne pas dans LIEN_LIG, càd que rien n'est grisé

    # Force l'affichage afin que les Diszo
    # appelés ensuite fonctionnent
    Affzo [M:SMR1]5
    Call STKCTRIPT( [M:SMR0]IPTDAT,[M:SMR0]STOFCY, "1") From STKLIB
    If GERR=1
        Call ERREUR(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:SMR1]5
    Elsif GERR=2
        Call MESSAGE(GMESSAGE) From GESECRAN
        Raz GERR
        Raz GMESSAGE
        Grizo [M:SMR1]5
    Else
        # Rend insaisissables toutes les colonnes, puis...
        # ( Diszo du tableau empêche la réactivation)
        # ...rend saisissable la dernière ligne (la ligne vide)
        # Car celle-ci peut avoir été rendue inactive
        # par le chargement précédent d'un document (comportant plus de lignes)
        Call STKDISCOL("SMR1",[M]NBLIG) From STKECR
        Diszo [M]ITMREF,ITMDES1
        Actzo [M]ITMREF([M]NBLIG),ITMDES1([M]NBLIG)
        If dim([M]PCU)>0
            Diszo [M]PCU,QTYPCU
            Actzo [M]PCU([M]NBLIG),QTYPCU([M]NBLIG)
        Endif
        If dim(PCUSTUCOE)>0
            Diszo [M]PCUSTUCOE
            Actzo [M]PCUSTUCOE([M]NBLIG)
        Endif
        If dim(STU)>0
            Diszo [M]STU,QTYSTU
            Actzo [M]STU([M]NBLIG),QTYSTU([M]NBLIG)
        Endif
        If dim([M]PRIORD)>0
            Diszo [M]PRIORD
            Actzo [M]PRIORD([M]NBLIG)
        Endif
        If dim([M]MVTDES)>0
            Diszo [M]MVTDES
            Actzo [M]MVTDES([M]NBLIG)
        Endif
    Endif

# Actzo ou Grizo des dépôts selon le site
GWRHOBY = GSVGWRHOBY
Gosub WRH_ETAT

Return


$DEFLIG
    Default Mask [SMR1]
    Default File [SMD]
    CRIT = 'VCRTYP='+num$([M:SMR0]VCRTYP)+' and VCRNUM="'+[M:SMR0]VCRNUM+'"'
    FICLIG="SMVTD"
    ABLIG="SMD"
    ZONLIG="VCRLIN"
Return

################
# Chargement de la ligne en cours
$LIENS_LIG
    Gosub SET_NOL

    Read [ITM]ITM0=[M:SMR1]ITMREF(NOL)

    Call RECSTO_F ("SMR1", [M:SMR0]STOFCY, [M:SMR0]VCRTYP,
&                  [M:SMR0]VCRNUM, [M:SMR1]VCRLIN(NOL), NOL, "") From STKECR

###############################                         # Ana   deb
Call CHARG_ACCCCE(NOL,"","","[M:SMR1]CCE",
&                "SMD",[F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"") From TRTX3CPT
###############################                         # Ana   fin

    If [F:SMD]UPDPRI=2
        [M:SMR1]PRISAI(NOL) = GPRISAIMAN
    Else
        [M:SMR1]PRISAI(NOL) = GPRISAIAUT
    Endif
Return

$RAZCRE
Local Char LSEC

If GFCY<>GFCYDEF(7)                             # Ana
  GFCY=GFCYDEF(7) : Gosub CHARG_PARAM           # Ana
Endif                                           # Ana
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL                                # Ana

    Call DELSTOENTW(-1,-1,"SMR1",1,1,[M:SMR0]STOFCY,0,"") From STKENT
    If GSTKCPTMAN(9)<>2
        Effzo [M:SMR0]VCRNUM
        Diszo [M:SMR0]VCRNUM
    Endif
    Actzo [M:SMR0]STOFCY
    Actzo [M:SMR0]IPTDAT
    Actzo [M:SMR0]PJT
    Actzo [M:SMR0]TRSFAM
    [M:SMR0]VCRTYP = 19
    [M:SMR0]TRSTYP = 1

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif

    Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0    # Ana
    If fstat                                                 # Ana
       Raz [F:DTR]                                           # Ana
    Endif                                                    # Ana

    [M:SMR0]TRSCOD    = [F:SRT]TRSCOD
    [M:SMR0]TRSFAM    = [F:SRT]TRSFAMDEF
    [M:SMR0]SRGWAIFLG = [F:SRT]SRGWAIFLG    # hcb 50197
    [M:SMR0]MVTPRICOD = [F:SRT]MVTPRICOD    # hcb 50197
    Affzo [M:SMR0]TRSFAM
    [M:SMR0]ENTCOD = [F:SRT]ENTCOD
    Call STKASFCY([M:SMR0]STOFCY) From STKACT
#   [M:SMR0]CCECODS = [F:SRT]HEACCECOD    # L'action SAISTOANA utilise le champ CCECODS...
    [M:SMR0]CCECODS = [F:DTR]HEACCECOD                       # Ana

    #------- Initialisation des sections ana --------#
    # doit être fait en am_stofcy car des sections peuvent être fonction du site #
    For I=1 To GNBDIE                                        # Ana
        If dim([M:SMR0]CCE)>0
            Call INISEC (LSEC, "STKENDH", I) From TRTX3CPT  # Ana
            [M:SMR0]CCE(I-1)=LSEC
            [M:SMR0]DIE(I-1)= GDIE(I)   # hcb 69574
        Else
            Break
        Endif
    Next

If dim([M:SMR0]WRHE)>0
   Call WRHINIT([M:SMR0]WRHE,[M:SMR0]STOFCY,5) From STKWRH
Endif
# Actzo ou Grizo des dépôts selon le site
Gosub WRH_ETAT

Return

$RAZDUP
Local Integer  I, LRET
Local Shortint WRET
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Gosub RAZCRE
GFCY = [M:SMR0]STOFCY                      # hcb 53363
Gosub CHARG_PARAM                          # hcb 53363

    Raz [M:SMR1]VCRLIN
    Raz [M:SMR1]UPDFLG
    Raz [M:SMR1]CREFLG
    If dim([M:SMR1]LOT)>0
        Raz [M:SMR1]BPSLOT
        Raz [M:SMR1]LOT
    Endif
    If dim([M:SMR1]SLO)>0
        Raz [M:SMR1]NBSLO
        Raz [M:SMR1]SLO
        Raz [M:SMR1]SLOF
    Endif
    Raz [M:SMR1]GESLOT
    Raz [M:SMR1]STA
    If dim([M:SMR1]LOC)>0
        Raz [M:SMR1]LOCTYP
        Raz [M:SMR1]LOC
    Endif
    If dim([M:SMR1]SERNUM)>0
        Raz [M:SMR1]SERNUM
        Raz [M:SMR1]SERNUMF
    Endif
#                                 # hcb 71276 deb
    If dim([M:SMR1]ECCVALMAJ)>0
        Raz [M:SMR1]ECCVALMAJ
        Raz [M:SMR1]ECCVALMIN
        Raz [M:SMR1]ECCSAIFLG
    Endif
#                                 # hcb 71276 fin
#                                 # hcb X3-98216 deb
    If dim([M:SMR1]LPNNUM)>0
        Raz [M:SMR1]LPNNUM
        Raz [M:SMR1]TCTRNUM
    Endif
#                                 # hcb X3-98216 deb
    Raz [M:SMR1]PRIORD
    Raz [M:SMR1]MVTDES

    Affzo [M:SMR1]

    For I=0 To [M:SMR1]NBLIG-1
        Call REINILIG([M:SMR1]ITMREF(I), I) From SUBSMRB
        Call OUVENT( [M:SMR0]STOFCY, "SMR1", [M:SMR0]TRSTYP, [M:SMR0]TRSCOD, "", [M:SMR0]VCRTYP, [M:SMR0]IPTDAT, I, [M:SMR1]NBLIG, "SRT", "", WRET) From STKENT
        [M:SMR1]PRISAI(I) = GPRISAIAUT
        Raz LECCMAJ, LECCMIN
        If dim([M:SMR1]ECCVALMAJ)>0
            [L]LECCMAJ = string$([M:SMR1]ECCVALMAJ(I)<>"$",[M:SMR1]ECCVALMAJ(I))
            [L]LECCMIN = string$([M:SMR1]ECCVALMIN(I)<>"$",[M:SMR1]ECCVALMIN(I))
        Endif
        Call SETNEWPRIOVE([M:SMR1]ITMREF(I),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(I),[M:SMR1]PRI(I),1,[M:SMR1]QTYSTU(I),"",LRET) From STKVAL
    Next I
    Affzo [M:SMR1]


Return


$SETBOUT

# Menu Options / Visu transaction
    CHMEN += "c"
# Menu Options / Sections analytiques
    If ([M:SMR0]VCRNUM<>"" | GREP="C") &  find([M:SMR0]CCECODS,1,2)
        CHMEN += "a"
    Endif
#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
Gosub SET_BOUT_SPE From GSAISIE
Return

$STATUT
    If BOUT="a" & mkstat=4 & REP=""
        REP = "M"
    Endif
Return


$VERIF_CRE
    Call CTLSTOENT( "SMR1", "QTYSTU", [M:SMR1]NBLIG, OK ) From STKECR
    # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
    If OK & !GIMPORT & !GWEBSERV & GSTOTRACE>1
        Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
    Endif
Return

$VERIF_MOD
    Call CTLSTOENT( "SMR1", "QTYSTU", [M:SMR1]NBLIG, OK ) From STKECR
    # Issue X3-106909 - 2018-09-21 by MAE : Ajout du GSTOTRACE
    If OK & !GIMPORT & !GWEBSERV & GSTOTRACE>1
        Call OUVRE_TRACE(mess(177,198,1)) From LECFIC
    Endif
Return


$INICRE
#If left$(GUSER,4) <> "ROBO"
#   Call ACTIVE From TIMING
#Endif
Local Integer LSTAT
Local Char    LNUM
Local Integer I
    # Création du numéro de document si nécessaire
    If GSTKCPTMAN(9)<>2 | [M:SMR0]VCRNUM = ""
        Call NUMERO(GSTKCPT(9), [M:SMR0]STOFCY, [M:SMR0]IPTDAT,
&                   "", LNUM, LSTAT) From SUBANM
        If GOK<0 Return Endif
        If LSTAT=0
            [M:SMR0]VCRNUM = LNUM
            [F:SMH]VCRNUM  = LNUM
        Else
            GERR=1:GMESSAGE = mess(60,199,1)
            GOK=0
        Endif
    Endif

    For I=1 To GNBDIE                               # Ana
         [F:SMH]CCE(I-1) =  [M:SMR0]CCE(I-1)        # Ana
         [F:SMH]DIE(I-1) =  GDIE(I)                 # Ana
    Next
    # Alimentation dépôt entête si mono-dépôt
    If dim([M:SMR0]WRHE)>0 & GWRHOBY=2
      [F:SMH]WRHE = [M:SMR0]WRHE
    Else
      [F:SMH]WRHE = ""
    Endif
Return

$AVANT_MODFIC
# Réalimenter [M]WRHE avec [F]WRHE pour ne pas écraser le mono-dépôt
If dim([M:SMR0]WRHE)>0
   [M:SMR0]WRHE = [F:SMH]WRHE
Endif
Return

$INIMOD

Local Integer I
    For I=1 To GNBDIE                              # Ana
        [F:SMH]CCE(I-1) =  [M:SMR0]CCE(I-1)        # Ana
        [F:SMH]DIE(I-1) =  GDIE(I)                 # Ana
    Next
Return

$CREATION
    Gosub CREATION From TABLEAUX
Return

$MODIF
    Gosub MODIF From TABLEAUX
Return

$ANNULE
    Global Integer GDELDOC : GDELDOC=1
    Call DELETEMVT("SMR1",0, [M:SMR1]NBLIG-1, [M:SMR0]VCRTYP, "SRT", [M:SMR0]STOFCY, "", 1, [M:SMR0]TRSCOD) From STKENT
    Kill GDELDOC
    If GOK
        Gosub ANNULE From TABLEAUX
    Endif
Return

$INICRE_LIG
    [F:SMD]VCRTYP = [F:SMH]VCRTYP
    [F:SMD]VCRNUM = [F:SMH]VCRNUM
    [F:SMD]UPDPRI = 1+([M:SMR1]PRISAI(nolign-1)=GPRISAIMAN)
    # Alimentation dépôt ligne si renseigné
    If dim([M:SMR1]WRH)>0 & [M:SMR1]WRH(nolign-1)<>""
      [F:SMD]WRH = [M:SMR1]WRH(nolign-1)
    Else
      [F:SMD]WRH = ""
    Endif
Return

$VALLIG
If SIGN=1
    Call ALISTW (nolign-1) From SUBSMRB
    #----- Ecriture des sections analytiques dans la table CPTANALIN -----#
    Call ENREG_ACCCCE(nolign-1,"","","[M:SMR1]CCE","SMD",
&                     [F:SMD]VCRTYP,[F:SMD]VCRNUM,[F:SMD]VCRLIN,0,"",TRTLIG) From TRTX3CPT
    If GOK<1  Return : Endif
    #-----
Return

Endif

Return

$APRES_CRE
    Gosub APRES_ENR
Return

$APRES_MOD
    Gosub APRES_ENR
Return

$AB_CREATION
    Effzo [M:SMR0]VCRNUM
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$AB_MODIF
    If !GIMPORT & !GWEBSERV & GTRACE<>""
        Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
    Endif
Return

$APRES_ENR
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif

    #--- Bug 80092
    Local Integer LRET
    Call STKDELRES(0,[M:SMR0]STOFCY,"",LRET) From STKLOC
    #---

    #---- Impression automatique du document ----------#
    If [F:SRT]DOCFLG=2 & !GIMPORT & !GWEBSERV & [F:SRT]DOCNAM<>"" & !GVTMOD       #--- Lot V01
        Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
        Call ETAT([F:SRT]DOCNAM,"GESSMR",TBPAR,TBVAL) From ETAT
    Endif

    #--- Impression des étiquettes ----#
    If [F:SRT]PRNCOD1 > 1 & !GIMPORT & !GWEBSERV & !GVTMOD
        Local Char    LCRIT(250)
        Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
        Local Integer WCREATION
        WPARAM(1) = [M:SMR0]STOFCY
        WPARAM(2) = num$([M:SMR0]VCRTYP)
        WPARAM(3) = [M:SMR0]VCRNUM
        WPARAM(4) = [M:SMR0]VCRNUM
#                                                                                           # hcb X3-91077 - X3-92342 deb
#       Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
        Case [F:SRT]PRNCOD1
             When 2 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
             When 6 :
               Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE2","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette nouveau contenant
             When 7 :
               If !clalev([F:LPN])  : Local File LPN          [LPN]  : Endif
               Raz WCREATION
               LCRIT   = "STOFCY=[M:SMR0]STOFCY"
               LCRIT  += "&VCRNUM>=[M:SMR0]VCRNUM"
               LCRIT  += "&VCRNUM<=[M:SMR0]VCRNUM"
               LCRIT  += "&PRTFLG <> 2"
               Filter [F:LPN] Where evalue(LCRIT)
&              Order By Key LPN0
               For [LPN]
                   WCREATION = 2
                   Break
               Next
               Filter [LPN]
               If WCREATION = 2
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE3","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock et contenant créé
               Else
                  Call TRAITE_CHAR(WVALEUR,WPARAM,"IRCPLBE1","SUBRCPLBE","",4,"SPERCPLBE") From GTRAITE  # Etiquette stock
               Endif
             When Default
        Endcase
#                                                                                           # hcb X3-91077 - X3-92342 fin
    Endif

    #---- Régularisation des mouvements et alloc -----#
    Call REGFROMENT( 0, "SMR1", "[M:SMR1]CREFLG(I)=0", "ITMREF", [M:SMR0]STOFCY ) From TRTSHTCOM

    If !GIMPORT & !GWEBSERV & GTRACE<>""
       If dim(GTRAVT)>0 GTRAVT=mess(39,7750,1)-[F:SMH]VCRNUM Endif
       Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
       If dim(GTRAVT)>0 Raz GTRAVT Endif
   Endif

   If !GIMPORT & !GVTMOD
      Gosub RELIT From GOBJSUB
   Endif
Return

$APRES_MODIF
    If GRELITSMR
        Gosub RELIT From GOBJSUB
        Raz GRELITSMR
        OK=0
    Endif
Return

$ABANDON
    Actzo [M:SMR0]VCRNUM
    Call DELSTOENTW(-1,-1,"SMR1",1,1,[M:SMR0]STOFCY,1,"") From STKENT
Return

$FERME
Raz GORITITCOL                                         # Ana

# globales servant à tester la date d imputation par rapport à la date du jour
If dim(GCTRDAT) > 0
   Kill GCTRDAT
Endif


#If GTRTIME<>"" Call ARRET From TIMING Endif
    Kill GRELITSMR

#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

Return

###############################                         # Ana   deb
$CHARG_PARAM
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY(GFCY,"SRT",1,GSMRNUM) From TRTX3CPT          # hcb 50197

# en import test il ne faut pas controler les compteurs   # hcb 090205 28275
If dim([M:IMP2]TEST)>0
   If [M:IMP2]TEST = 2
      Return
   Endif
Endif
Local Integer LRET
# Récupération des codes compteur
If clalev ([F:TCA])<=0
   Local File TABCOUAFF [TCA]
Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif
GSTKCPTMAN(9) = [F:TCA]MANCOU(9) # Cpt des entrées diverses
GSTKCPT   (9) = [F:TCA]CODNUM(9)

#Controle compteur pièce entrée diverse
Call CTRCPT(GSTKCPT(9),type([M:SMR0]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif
#compteur chrono stock
GSTKCPTMAN(0) = [F:TCA]MANCOU(0) # Cpt du chrno stock
GSTKCPT   (0) = [F:TCA]CODNUM(0)
#compteur chrono fifo
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT & !GVTMOD & dim([M:SMR1]CCE1)>0
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT01"+GSMRNUM+"1"         # hcb 50197
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:SMR1]NBLIG=0
    [M:SMR1]NBLIG=1 : Affzo [SMR1]5 : Effzo [SMR1]5
  Endif
Endif
Raz GSOC_UPDFLG
Return

#########################################
$GRISE
# Accès à un document créé en multi-dépôt avec une transaction mono-dépôt
# --> pas d'application du mono-dépôt
If [F:SMH]WRHE="" & GWRHOBY=2
   GWRHOBY=1
   If [M]STOFCY<>[F:FCY]FCY : Read [FCY]FCY0=[M]STOFCY : Endif
   If [F:FCY]WRHGES=2 : Call MESSAGE(mess(351,184,1)) From GESECRAN : Endif
Endif
Return

#------------------------------------------#
# Actzo ou Grizo des dépôts selon le site  #
#------------------------------------------#
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]STOFCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES=2
   If find(GREP,"C","D")
      Actzo [M:SMR0]WRHE
      If GWRHOBY=2
         Diszo [M:SMR1]WRH
      Else
         Actzo [M:SMR1]WRH
      Endif
   Elsif [M:SMR0]WRHE<>""
      Diszo [M:SMR0]WRHE
      Diszo [M:SMR1]WRH
   Else
      Actzo [M:SMR0]WRHE
      Actzo [M:SMR1]WRH
   Endif
Else
  Raz   [M:SMR0]WRHE
  Grizo [M:SMR0]WRHE
  Grizo [M:SMR1]WRH
Endif
Return

