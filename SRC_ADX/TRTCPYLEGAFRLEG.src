Subprog DISPLAY_HIDE()
#Call generated scripts

 Call SHOW_HIDE() From WCPYLEGAFRSHOWHIDE
 Gosub MANAGE_TITLE

#Else
#
#Call HIDE_ACTIVITYFIELDS From WCPYLEGAFRHIDE
#Call SHOW_LEGACTCALLS From WCPYLEGAFRSHOW
##JOJAC - 2016-07-18 - END
#
##Show all SPECIFIC fields
#If clalev([F:AMKW])=0     : Local File AMSK [AMKW]       : Endif
#If clalev([F:AMZW])=0     : Local File AMSKZON [AMZW]    : Endif
#Local Char WSIGN(1)
#Local Char WSAV_LEG(5)
#
#
##No need to show all fields as the window will only be opened for one legislation at a time
##WSAV_LEG= GCURLEG
##GCURLEG=""
##Gosub SHOW_ALL_SPECIFIC
##GCURLEG=WSAV_LEG
#WSIGN="-"
#Gosub HIDE_SPECIFIC
#Endif
End



$MANAGE_TITLE
# need to be add in a local menu
# Swaziland
If func DIVPAYE.IS_KSZ_LEG(GCURLEG)>0 Then
  Chgtzn [M:CLAFR]TINNUM         With "TIN No"
Endif
#Lesotho
If func DIVPAYE.IS_KLS_LEG(GCURLEG)>0 Then
    Chgtzn [M:CLAFR]ADDSUB         With "Village"
    Chgtzn [M:CLAFR]ADDTWN         With "Town"
    Chgtzn [M:CLAFR]TINNUM         With "TIN No"
Endif
 #Malawi
If func DIVPAYE.IS_KMW_LEG(GCURLEG)>0 Then
  Chgtzn [M:CLAFR]TINNUM         With "TPIN"
Endif
#Ghana
# SBA : need to add to the local menu
If func DIVPAYE.IS_KGH_LEG(GCURLEG)>0 Then
    Chgtzn [M:CLAFR]SSCBRANAM       With mess(27, 11706, 1)
    Chgtzn [M:CLAFR]SSCCATNAM       With mess(28, 11706, 1)
    Chgtzn [M:CLAFR]SSCZONCOD       With mess(29, 11706, 1)
    Chgtzn [M:CLAFR]SSCPAYCEN       With mess(30, 11706, 1)
    Chgtzn [M:CLAFR]OLDTINNUM       With mess(26, 11706, 1)
    Chgtzn [M:CLAFR]TINNUM          With mess(23, 11706, 1)
    Chgtzn [M:CLAFR]TAXOFCADDR      With mess(25, 11706, 1)
Endif


Return
#initialisation of var call in Call MANAGE_LOCALISATIONNEW("CPYLEGAFR","TRTCPYLEGAFRLEG") From DIVPAYE with the second parameter

$INI_VAR_SHOW_HIDE

Gosub INI_TABSPE_FIELDS From TRTLEGACTSHOWHIDE
Gosub INI_TABSPE_FIELDSTOHIDE
Gosub INI_TABSPE_FIELDSTOSHOW

Return


$INI_TABSPE_FIELDSTOSHOW
# nothing to add in this case

Return


$INI_TABSPE_FIELDSTOHIDE
