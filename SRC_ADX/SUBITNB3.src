# CPTNBSREHDT   : Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
# ITNNBRSREHDT  :
# ADDHDTMAC     : Ajoute le parc concerné par défaut sur une ligne de consommation
# SETTZN        : Gestion du nommage des étiquettes de champs
# SETENTCOD     : Charge le code pièce automatique de la demande de service.
# AVMCTLLOCKITN : Contrôle que l'on peut rentrer en modification de la demande.
# CHKITNDISP : Vérifie la disponibilité du technicien
# SETPREVAL : Gestion des valeurs modifiées
# CHECKCANDONE
# ITNCHECKSTO : Verifie si toutes les sorties de stock on été FAITE
#  GERE_LCM_CREATION  : gere les données  pour la gestion des en cours en creation
#  GERE_LCM_MODIF     : gere les données  pour la gestion des en cours en modification
#  GERE_LCM_ANNULE    : gere les données  pour la gestion des en cours en annulation
#
##########################################################################################################
##########################################################################################################
# Calcul le nombre maximum d'intervention que l'on peut ajouter sur une intervention.
##########################################################################################################
# FGR 14/10/2015 : X3SUIVI111730 (début)
Subprog CPTNBSREHDT(INB)
Variable Integer INB

Local Integer INBHDT

  If [M:ITN0]SRVDEMNUM = "" Then
    INB = dim([M:ITN8]HDTITM)
  Else
    INBHDT = 0
    Filter [HDT] Where [F:HDT]SRENUM = [M:ITN0]SRVDEMNUM and [F:HDT]TPL <> 2
    INBHDT = rowcount([F:HDT])
    Filter [HDT]
    INB = dim([M:ITN8]HDTITM) - INBHDT + [M:ITN8]NBLIG
  Endif
End

##########################################################################################################
Subprog ITNNBRSREHDT
Local Integer INBSREHDT

  INBSREHDT = 0
  Call CPTNBSREHDT(INBSREHDT)
  [M:ITN0]NBRSREHDT = INBSREHDT
End

