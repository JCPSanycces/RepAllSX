##########################################################################################################
# Ajoute le parc concerné par défaut sur une ligne de consommation
#####################################################
$ADDHDTMAC
Local Integer INBSRM
Local Char SZSRN
Local Integer INBSRN

  Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
  If fstat Then
    Return
  Endif
  INBSRN = 0
  INBSRM = 0
  SZSRN = ""
  If [F:SRE]SREMAC = "" Then
    Return
  Endif
  [M:ITN8]HDTMACSRE(nolign-1) = [F:SRE]SREMAC
  Filter [SRM] Where [F:SRM]SRENUM = [M:ITN0]SRVDEMNUM
  For [SRM]
    INBSRM += 1
  Next
  Filter [SRM]
  If INBSRM <> 1 Then
    Return
  Endif
  Filter [SRN] Where [F:SRN]SRENUM = [M:ITN0]SRVDEMNUM
  For [SRN]
    SZSRN = [F:SRN]CPNITM
    INBSRN += 1
  Next
  Filter [SRN]
  If INBSRN = 1 Then
    [M:ITN8]HDTCPN(nolign-1) = SZSRN
  Endif
Return

##########################################################################################################
# Gestion du nommage des étiquettes de champs
######################################################
Subprog SETTZN
Local Char SZASS

  If GIMPORT Then
    End
  Endif
  Call TEXTE(16058, SZASS) From OBJDIV      #Collaborateur
  Chgtzn [M:ITN1]ITNASS With SZASS
  If [M:ITN1]SCO = 2 Then
    Call TEXTE(11203, SZASS) From OBJDIV      #Prestataire
    Chgtzn [M:ITN1]ITNASS With SZASS
  Endif
End

##########################################################################################################
# Gestion du nommage des étiquettes de champs
######################################################
Subprog SETENTCOD(SZSRENUM, SZENTCOD, SZTRSFAM, SZTRSCOD)
Value Char SZSRENUM
Variable Char SZENTCOD
Variable Char SZTRSFAM
Variable Char SZTRSCOD

  If SZSRENUM = "" Then
    If type([F:SRE]ENTCOD) > 0 Then
      SZENTCOD = [F:SRE]ENTCOD
      SZTRSFAM = [F:SRE]TRSFAM
      SZTRSCOD = [F:SRE]TRSCOD
    Endif
  Else
    Read [SRE]SRE0=SZSRENUM
    If !fstat Then
      SZENTCOD = [F:SRE]ENTCOD
      SZTRSFAM = [F:SRE]TRSFAM
      SZTRSCOD = [F:SRE]TRSCOD
    Endif
  Endif
End

##########################################################################################################
$AVMCTLLOCKITN
#Contrôle que l'on peut rentrer en modification de la demande.
Local Integer IUPDSRE

  Call LOCKSRE([M:ITN0]SRVDEMNUM, IUPDSRE) From SUBITNB1
  If !IUPDSRE Then
    #Modification impossible. Intervention en cours de saisie sur un autre poste.
    GMESSAGE = mess(592,182,1)
    GERR = 2
    Return
  Endif
Return

##########################################################################################################
# Vérifie la disponibilité du technicien
$CHKITNDISP
Local Char SZDSTR(100)
Local Char SZDEND(100)
Local Integer IONREP
Local Char SZREPMESS(250)
Local Integer REPISDISP
Local Char SZREPNAM(50)
Local Char SZSTRDAT
Local Char SZSTRHOU
Local Char SZENDDAT
Local Char SZENDHOU
Local Char SZTYPREP
Local Char SZMESSAGE(250)
Local Integer IREP

  REPISDISP = 0
  IREP = 0
  SZREPNAM = ""
  SZSTRDAT = ""
  SZSTRHOU = ""
  SZENDDAT = ""
  SZENDHOU = ""
  SZTYPREP = ""
  SZMESSAGE = ""
  IONREP = 0
  SZREPMESS = ""
  SZDSTR = ""
  SZDEND = ""
  Raz GITN1CFLRS
  # Première étape
  #Contrôle de conflits horaires avec d'autres interventions
  If [M:ITN1]DAT <> [00/00/00] Then
    If [M:ITN1]REP <> "" Then
      SZTYPREP = "REP"
    Else
      If [M:ITN1]SCONUM <> "" Then
        SZTYPREP = "SCO"
      Else
        Gosub MNGUPDITNDAT From SUBITNB1
        Return
      Endif
    Endif
    If [M:ITN0]DON <> 2 Then
      Gosub CHKAUSDISP From SUBITNB1
    Endif
  Endif
  While REPISDISP > 0
    If SZTYPREP = "REP" Then
      Read [AUS]CODUSR=[M:ITN1]REP
      If fstat Then
        SZREPNAM = [M:ITN1]REP
      Else
        SZREPNAM = [F:AUS]NOMUSR
      Endif
      #Case 1 : XXXX est déjà en intervention du WWWW au XXXX. Saisie refusée.
      #Case 2 : XXXXX est déjà en intervention du WWWW au XXXX. Confirmez-vous la saisie ?
      #Case 3 : XXXXX est déjà en intervention après vente sur site du WWWW au XXXX. Confirmez-vous la saisie ?
      #Case 4 : Le nombre de conflits détectés est trop important.
      #         Il est déconseillé de surcharger de façon concurrente l'agenda du collaborateur : XXXX
      #         Par conséquent, la saisie du rendez-vous est refusée.
      Case REPISDISP
        When 1
          GMESSAGE = SZREPNAM - mess(634,196,1) - SZSTRDAT - SZSTRHOU - mess(95,100,1) - SZENDDAT - SZENDHOU - mess(300,196,1)
          GERR = 3
          OK = 0
        When 2
          SZMESSAGE = SZREPNAM - mess(299,196,1) - SZSTRDAT - SZSTRHOU - mess(95,100,1) - SZENDDAT - SZENDHOU - mess(326,196,1)
          Call OUINON(SZMESSAGE, IREP) From GESECRAN
          If IREP <> 2 Then
            OK = 0
          Endif
        When 3
          SZMESSAGE = SZREPNAM - mess(634,196,1) - SZSTRDAT - SZSTRHOU - mess(95,100,1) - SZENDDAT - SZENDHOU - mess(326,196,1)
          Call OUINON(SZMESSAGE, IREP) From GESECRAN
          If IREP <> 2 Then
            OK = 0
          Endif
        When 4
          GMESSAGE = mess(628,196,1) - mess(629,196,1) - SZREPNAM + '.' - mess(631,196,1)
          GERR = 3
          OK = 0
        When Default
      Endcase
    Elsif SZTYPREP = "SCO" Then
      Read [BPR]BPR0=[M:ITN1]SCONUM
      If fstat Then
        SZREPNAM = [M:ITN1]SCONUM
      Else
        SZREPNAM = [F:BPR]BPRNAM
      Endif
      #Case 2 : XXXXX est déjà en intervention du WWWW au XXXX. Confirmez-vous la saisie ?
      #Case 4 : Le nombre de conflits détectés est trop important.
      #         Il est déconseillé de surcharger de façon concurrente l'agenda du collaborateur : XXXX
      #         Par conséquent, la saisie du rendez-vous est refusée.
      Case REPISDISP
        When 2
          SZMESSAGE = SZREPNAM - mess(299,196,1) - SZSTRDAT - SZSTRHOU - mess(95,100,1) - SZENDDAT - SZENDHOU - mess(326,196,1)
          Call OUINON(SZMESSAGE, IREP) From GESECRAN
          If IREP <> 2 Then
            OK = 0
          Endif
        When 3
          SZMESSAGE = SZREPNAM - mess(634,196,1) - SZSTRDAT - SZSTRHOU - mess(95,100,1) - SZENDDAT - SZENDHOU - mess(326,196,1)
          Call OUINON(SZMESSAGE, IREP) From GESECRAN
          If IREP <> 2 Then
            OK = 0
          Endif
        When 4
          GMESSAGE = mess(628,196,1)  -  mess(631,196,1)
          GERR = 3
          OK = 0
        When Default
      Endcase
    Endif
    If OK = 0 Then
      Break
    Endif
    Gosub CHKAUSDISP From SUBITNB1
  Wend
  # Deuxième étape
  #Contrôle de conflits horaires avec les réservations de ressources
  If OK > 0 Then
    Gosub MNGUPDITNDAT From SUBITNB1
  Endif
  # Troisième étape
  #Contrôle de conflits horaires avec les rendez-vous commerciaux
  If SZTYPREP = "REP" Then
    If [M:ITN0]DON <> 2 Then
      If OK Then
        Read [AUS]CODUSR=[M:ITN1]REP
        If fstat Then
          SZREPNAM = [M:ITN1]REP
        Else
          SZREPNAM = [F:AUS]NOMUSR
        Endif
        Raz GITN1CFLRS
        Call CHKDISIBAP(SZDSTR, SZDEND, [M:ITN1]REP, REPISDISP) From SUBITNB1
        While REPISDISP > 0
          #Case 1 : SZREPNAM est déjà en rendez-vous en tant qu'intervenant principal aux horaires suivants :
          #         Saisie refusée.
          #Case 2 : SZREPNAM est déjà en rendez-vous aux horaires suivants :
          #         Confirmez-vous la saisie ?
          #Case 3 : SZREPNAM est déjà en rendez-vous en tant qu'intervenant principal aux horaires suivants :
          #         Confirmez-vous la saisie ?
          #Case 4 : Le nombre de conflits détectés est trop important.
          #         Il est déconseillé de surcharger de façon concurrente l'agenda du collaborateur : XXXX
          #         Par conséquent, la saisie du rendez-vous est refusée.
          Case REPISDISP
            When 1
              GMESSAGE = SZREPNAM - mess(632,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(627,196,1)
              GERR = 3
              OK = 0
            When 2
              SZREPMESS = SZREPNAM - mess(633,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(623,196,1)
              Call OUINON(SZREPMESS, IONREP) From GESECRAN
              If IONREP <> 2 Then
                OK = 0
              Endif
            When 3
              SZREPMESS = SZREPNAM - mess(632,196,1) - SZDSTR - mess(560,196,1) - SZDEND + '.' - mess(623,196,1)
              Call OUINON(SZREPMESS, IONREP) From GESECRAN
              If IONREP <> 2 Then
                OK = 0
              Endif
            When 4
              GMESSAGE = mess(628,196,1) - mess(629,196,1) - SZREPNAM + '.' - mess(631,196,1)
              GERR = 3
              OK = 0
            When Default
          Endcase
          If OK = 0 Then
            Break
          Endif
          Call CHKDISIBAP(SZDSTR, SZDEND, [M:ITN1]REP, REPISDISP) From SUBITNB1
        Wend
      Endif
    Endif
  Endif
Return

##########################################################################################################
# Gestion des valeurs modifiées
#####################################################
$SETPREVAL
  [M:ITN1]DATXINI = [M:ITN1]DATX
  [M:ITN1]HOUINI = [M:ITN1]HOU
  [M:ITN1]DATENDINI = [M:ITN1]DATEND
  [M:ITN1]HOUENDINI = [M:ITN1]HOUEND
  [M:ITN1]WEEINI = [M:ITN1]WEE
  [M:ITN0]DONINI = [M:ITN0]DON
  [M:ITN4]PREPBLSOL = [M:ITN4]PBLSOL
  [M:ITN4]WISCLOFLG = 0
  [M:ITN4]WISSATFLG = 0
  [M:ITN8]DONDATFLG = 0
  [M:ITN0]SALFCYINI=[M:ITN0]SALFCY
Return

##########################################################################################################
$CHECKCANDONE
  If GREP = "C" Then
    If [M:ITN0]DON <> 2 Then
      mkstat = 2
      Return      # FGR 13/10/2010 : X3SUIVI68214
    Endif
  Endif
Return

##########################################################################################################
$NO_MODIF_SSTOK
Local Integer NOL

  # FGR 13/10/2010 : X3SUIVI68214 : Non modifiable si sortie de stock faite
  NOL = nolign-1
  If [M:ITN8]HDTTYP(NOL) = 2 Then               # 2-Pièce
    If [M:ITN8]HDTSTOISS(NOL) = 2 Then          # "Sortie de stock" effectuée
      If [M:ITN8]HDTISSQTY(nolign-1) > 0 Then   # "Quantité à sortir" saisie
        If [M:ITN8]HDTISSISS(nolign-1) > 0 Then # "Quantité sortie" saisie
          mkstat = 2
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
#Verifie si toutes les sorties de stock on été faite
Subprog ITNCHECKSTO (IERRINF,ICHAPTER,IBRETOUR)
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer  ILIGNE
Local Integer IBSTOCK

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  IBSTOCK = 1
  #Contrôle que toutes les sorties de stock prévuées ont été réalisées.
  For ILIGNE = 0 To [M:ITN8]NBLIG-1
    If [M:ITN8]HDTTYP(ILIGNE) = 2 Then
      If [M:ITN8]HDTSTOISS(ILIGNE) = 2 Then
        If [M:ITN8]HDTDONDAT(ILIGNE) = [00/00/00] Then
          IBSTOCK = 0
          Break
        Else
          If [M:ITN8]HDTISSISS(ILIGNE) < [M:ITN8]HDTISSQTY(ILIGNE) Then
            IBSTOCK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  If IBSTOCK = 0 Then
    #Des sorties de stock n'ont pas été enregistrées. Clôture refusée.
    IERRINF = 527
    ICHAPTER = 182
    IBRETOUR = 0
  Endif
End

##########################################################################################################
# gere les données  pour la gestion des en cours en creation
$GERE_LCM_CREATION
  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  If [M:ITN0]DON = 2 Then
    If [M:ITN0]BPC <> "" Then
      Raz [BPR]
      Read [BPR]BPR0=[M:ITN0]BPC
      If fstat <> 0 Then
        #Erreur lors de la lecture du tiers + " : " +[M:ITN0]BPC
        GMESSAGE = mess(445,177,1) - [M:ITN0]BPC
        GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
        Return
      Endif
      Call LCM_BPRLASTITN ([M:ITN0]BPC, GSOCIETE, [M:ITN0]SALFCY, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
# gere les données  pour la gestion des en cours en modification
$GERE_LCM_MODIF
Local Integer IBTRAITBPR
Local Integer IBTRAITBPRINI
Local Char SZSOCINI
Local Integer IBCHANGE_LCMKEY

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  IBTRAITBPR = 0
  IBTRAITBPRINI = 0
  Raz SZSOCINI
  IBCHANGE_LCMKEY = 0
  If [M:ITN0]SALFCYINI = [M:ITN0]SALFCY and [M:ITN0]DONINI = [M:ITN0]DON and [M:ITN1]DATEND = [M:ITN1]DATENDINI Then
    #Rien n'a été changé sur les données encours, on sort
    Return
  Endif
  If [M:ITN0]BPC <> "" Then
    Raz [BPR]
    Read [BPR]BPR0=[M:ITN0]BPC
    If fstat <> 0 Then
      #Erreur lors de la lecture du tiers  - [M:ITN0]BPC
      GMESSAGE = mess(445,177,1) - [M:ITN0]BPC
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
      IBTRAITBPR = 1
    Endif
  Endif
  If [M:ITN0]SALFCYINI <> [M:ITN0]SALFCY Then
    #On recherche la société initiale
    If [M:ITN0]SALFCYINI <> ""
      Read [FCY]FCY0=[M:ITN0]SALFCYINI
      If fstat = 0 Then
        SZSOCINI = [F:FCY]LEGCPY
      Else
        #Erreur lors de la lecture de la table des sites
        GMESSAGE = mess(444,177,1)
        GERR = 2
        OK = 0
        GOK = 0
        Return
      Endif
      If SZSOCINI <> GSOCIETE Then
        IBCHANGE_LCMKEY = 1
      Endif
    Else
      SZSOCINI = ""
    Endif
  Else
    SZSOCINI = GSOCIETE
  Endif
  IBTRAITBPRINI = IBTRAITBPR  # Le tiers ne peut pas changer
  If IBCHANGE_LCMKEY = 1 and IBTRAITBPRINI = 1 Then
    # On a changé de société. On remet à jour les infos pour l'ancienne société
    # FGR 13/01/2010 : X3SUIVI60986
    #Call LCM_BPRLASTITN ([M:ITN0]BPCINI, SZSOCINI, [M:ITN0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
    Call LCM_BPRLASTITN ([M:ITN0]BPC, SZSOCINI, [M:ITN0]SALFCYINI, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
  Endif
  #
  If IBTRAITBPR = 1 Then
    # C'est un client ou un prospect
    # GERE_LCM_CREATION fait tout ce qu'il faut.
    Gosub GERE_LCM_CREATION
  Endif
Return

##########################################################################################################
# gere les données pour la gestion des en cours en annulation
$GERE_LCM_ANNULE
Local Integer IBSUPR

  # FGR 12/08/2009 : X3SUIVI57005 : Revu toute cette partie pour laisser faire S/P qui vont bien
  IBSUPR = 0
  If [M:ITN0]BPC = "" Then
    Return
  Endif
  Raz [BPR]
  Read [BPR]BPR0=[M:ITN0]BPC
  If fstat <> 0 Then
    #Erreur lors de la lecture du tiers  - [M:ITN0]BPC
    GMESSAGE = mess(445,177,1) - [M:ITN0]BPC
    GERR = 2
    OK = 0
    GOK = 0
    Return
  Endif
  If [F:BPR]BPCFLG <> 2 and [F:BPR]PPTFLG <> 2 Then
    Return
  Endif
  #If faut supprimer les anciennes données
  If [M:ITN0]DONINI = 2 Then
    Call LCM_DELKEY(8, [M:ITN0]NUM, IBSUPR, IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 2
      OK = 0
      GOK = 0
      Return
    Endif
    If IBSUPR = 1 Then
      # on a supprimé quelque chose : donc on refait la recherche
      # GERE_LCM_CREATION fait tout ce qu'il faut.
      Gosub GERE_LCM_CREATION
    Endif
  Endif
Return

