#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Traitement SELTRS                                                     #
# --------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                  #
#   - VISUxxx : Visualisation des transactions de saisie                #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                #
#   - COPTRS  : Copie des transactions vers un autre dossier            #
#########################################################################

$ACTION
########################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                           #
# -------------------------------------------------------------------- #
# Module 5 Ventes                                                      #
# VISUSLQ  : Visu transaction Devis                                    #
# VISUSLC  : Visu transaction Commande                                 #
# VISUSLO  : Visu transaction Commande ouverte                         #
# VISUSLD  : Visu transaction Livraison                                #
# VISUSLI  : Visu transaction Facture/avoir                            #
# VISUSLR  : Visu transaction Retour client                            #
# VISUSLL  : Visu transaction Retour prêt                              #
# VISUSLS  : Visu transaction Retour matière sous traitance            #
# -------------------------------------------------------------------- #
# Module 6 Achats                                                      #
# VISUPTA  : Visu transaction Appel d'offre                            #
# VISUPTD  : Visu transaction DA                                       #
# VISUPTE  : Visu transaction Ordre de sous-traitance (V150)           #
# VISUPTC  : Visu transaction Commande                                 #
# VISUPTT  : Visu transaction Commande ouverte                         #
# VISUPTR  : Visu transaction Réception fournisseur (V140)             #
# VISUPTN  : Visu transaction Retour fournisseur    (V140)             #
# VISUPTF  : Visu transaction Facture                                  #
# -------------------------------------------------------------------- #
# Module 7 Stock                                                       #
# VISUSRT  : Entrée diverse                                            #
# VISUSOT  : Sortie diverse                                            #
# VISUSCT  : Changement stock                                          #
# VISUSLT  : Modification lot                                          #
# VISUSRG  : Plan de rangement                                         #
# VISUSNP  : Inventaire                                                #
# VISUPBY  : Assemblage/Desassemblage                                  #
# VISUSQT  : Contrôle qualité                                          #
# VISUREO  : Plan réappro zone consommation                            #
# VISUPRE  : Plan préparation d'expéditions                            #
# VISUSPK  : Colisage                                                  #
# VISUPRT  : Bons de préparation                                       #
# -------------------------------------------------------------------- #
# Module 8 GPAO                                                        #
# VISUMFL  : Visu transaction OF                                       #
# VISUMGL  : Visu transaction Planning global                          #
# VISUMDL  : Visu transaction Plan de travail                          #
# VISUMRL  : Visu transaction Regroupements                            #
# VISUMTL  : Visu transaction Suivi de fabrication                     #
# VISUMOL  : Visu transaction Plan de suivi des temps                  #
# VISUMIL  : Visu transaction Plan de production                       #
# VISUMML  : Visu transaction Plan de consommation                     #
# VISUMRE  : Visu transaction Plan de réintégration                    #
# VISUMWL  : Visu transaction Plan de pesée                            #
# VISUMCL  : Visu transaction Plan des fiches techniques               #
# VISUMPL  : Visu transaction Pilotage des plans                       #
# -------------------------------------------------------------------- #
# Module 11 Support client                                             #
# VISUCMA  : Visu transaction Parc client                              #
# VISUCMS  : Visu transaction Demandes de service                      #
# VISUCMI  : Visu transaction Interventions                            #
# VISUCMH  : Visu transaction Plan de travail                          #
# VISUCMD  : Visu transaction Agenda Support
# -------------------------------------------------------------------- #
# Module 12 Action commercial                                             #
# VISUCBA  : Visu transaction agenda commercial
########################################################################
Case ACTION
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Local Char    WDIE_ABRFIC(3)
  Local Integer WDIE_DTRTYP
  Gosub OUVRE_DIETRS From SUBDST
  #-----
  Local Integer WTYP
  Case GACTION
   When "VISUSLQ"   : WTYP=1 : Gosub OUV_VSL
   When "VISUSLC"   : WTYP=2 : Gosub OUV_VSL
   When "VISUSLO"   : WTYP=3 : Gosub OUV_VSL
   When "VISUSLD"   : WTYP=4 : Gosub OUV_VSL
   When "VISUSLI"   : WTYP=5 : Gosub OUV_VSL
   When "VISUSLR"   : WTYP=6 : Gosub OUV_VSL
   When "VISUSLL"   : WTYP=7 : Gosub OUV_VSL
   When "VISUSLS"   : WTYP=8 : Gosub OUV_VSL

   When "VISUPTA"   : WTYP=1 : Gosub OUV_PSL
   When "VISUPTD"   : WTYP=2 : Gosub OUV_PSL
   When "VISUPTC"   : WTYP=3 : Gosub OUV_PSL
   When "VISUPTT"   : WTYP=5 : Gosub OUV_PSL
   When "VISUPTR"   : WTYP=6 : Gosub OUV_PSL
   When "VISUPTN"   : WTYP=7 : Gosub OUV_PSL
   When "VISUPTF"   : WTYP=8 : Gosub OUV_PSL
   When "VISUPTE"   : WTYP=9 : Gosub OUV_PSL

   When "VISUSRT"   : WTYP=1  : Gosub OUV_SRT
   When "VISUSOT"   : WTYP=2  : Gosub OUV_SRT
   When "VISUSCT"   : WTYP=3  : Gosub OUV_SRT
   When "VISUSLT"   : WTYP=4  : Gosub OUV_SRT
   When "VISUSRG"   : WTYP=5  : Gosub OUV_SRT
   When "VISUSNP"   : WTYP=6  : Gosub OUV_SRT
   When "VISUPBY"   : WTYP=7  : Gosub OUV_SRT
   When "VISUSQT"   : WTYP=8  : Gosub OUV_SRT
   When "VISUREO"   : WTYP=9  : Gosub OUV_SRT
   When "VISUPRE"   : WTYP=10 : Gosub OUV_SRT
   When "VISUSPK"   : WTYP=11 : Gosub OUV_SRT
   When "VISUPRT"   : WTYP=12 : Gosub OUV_SRT

   When "VISUMFL"   : WTYP=1 : Gosub OUV_MTS
   When "VISUMTL"   : WTYP=2 : Gosub OUV_MTS

   When "VISUMGL"   : WTYP=51: Gosub OUV_BTS
   When "VISUMDL"   : WTYP=52: Gosub OUV_BTS
   When "VISUMRL"   : WTYP=53: Gosub OUV_BTS
   When "VISUMOL"   : WTYP=60: Gosub OUV_BTS
   When "VISUMML"   : WTYP=61: Gosub OUV_BTS
   When "VISUMIL"   : WTYP=62: Gosub OUV_BTS
   When "VISUMRE"   : WTYP=63: Gosub OUV_BTS
   When "VISUMWL"   : WTYP=90: Gosub OUV_BTS
   When "VISUMPL"   : WTYP=65: Gosub OUV_BTS
   When "VISUMCL"   : WTYP=66: Gosub OUV_BTS

   When "VISUCMA"   : WTYP=1: Gosub OUV_HDK
   When "VISUCMS"   : WTYP=2: Gosub OUV_HDK
   When "VISUCMI"   : WTYP=3: Gosub OUV_HDK
   When "VISUCMH"   : WTYP=4: Gosub OUV_HDK
   When "VISUCMD"   : WTYP=5: Gosub OUV_HDK

   When "VISUCBA"   : WTYP=1: Gosub OUV_CRM



  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  #-----
  Local Integer I
  Case GACTION
   When "VISUSLQ"   : Gosub DEB_VISUSLQ
   When "VISUSLC"   : Gosub DEB_VISUSLC
   When "VISUSLO"   : Gosub DEB_VISUSLO
   When "VISUSLD"   : Gosub DEB_VISUSLD
   When "VISUSLI"   : Gosub DEB_VISUSLI
   When "VISUSLR"   : Gosub DEB_VISUSLR
   When "VISUSLL"   : Gosub DEB_VISUSLL
   When "VISUSLS"   : Gosub DEB_VISUSLS
   When "VISUPTA"   : Gosub DEB_VISUPTA
   When "VISUPTD"   : Gosub DEB_VISUPTD
   When "VISUPTC"   : Gosub DEB_VISUPTC
   When "VISUPTT"   : Gosub DEB_VISUPTT
   When "VISUPTR"   : Gosub DEB_VISUPTR
   When "VISUPTN"   : Gosub DEB_VISUPTN
   When "VISUPTF"   : Gosub DEB_VISUPTF
   When "VISUPTE"   : Gosub DEB_VISUPTE

   When "VISUSRT"   : Gosub DEB_VISUSRT
   When "VISUSOT"   : Gosub DEB_VISUSOT
   When "VISUSCT"   : Gosub DEB_VISUSCT
   When "VISUSLT"   : Gosub DEB_VISUSLT
   When "VISUSRG"   : Gosub DEB_VISUSRG
   When "VISUSNP"   : Gosub DEB_VISUSNP
   When "VISUPBY"   : Gosub DEB_VISUPBY
   When "VISUSQT"   : Gosub DEB_VISUSQT
   When "VISUREO"   : Gosub DEB_VISUREO
   When "VISUPRE"   : Gosub DEB_VISUPRE
   When "VISUSPK"   : Gosub DEB_VISUSPK
   When "VISUPRT"   : Gosub DEB_VISUPRT


   When "VISUMFL"   : Gosub DEB_VISUMFL
   When "VISUMGL"   : Gosub DEB_VISUMGL
   When "VISUMDL"   : Gosub DEB_VISUMDL
   When "VISUMRL"   : Gosub DEB_VISUMRL
   When "VISUMTL"   : Gosub DEB_VISUMTL
   When "VISUMOL"   : Gosub DEB_VISUMOL
   When "VISUMML"   : Gosub DEB_VISUMML
   When "VISUMIL"   : Gosub DEB_VISUMIL
   When "VISUMRE"   : Gosub DEB_VISUMRE
   When "VISUMWL"   : Gosub DEB_VISUMWL
   When "VISUMPL"   : Gosub DEB_VISUMPL
   When "VISUMCL"   : Gosub DEB_VISUMCL

   When "VISUCMA"   : Gosub DEB_VISUCMA
   When "VISUCMS"   : Gosub DEB_VISUCMS
   When "VISUCMI"   : Gosub DEB_VISUCMI
   When "VISUCMD"   : Gosub DEB_VISUCMD

   When "VISUCBA"   : Gosub DEB_VISUCBA
  Endcase
  #----- Traitement de l'onglet "Analytique" si nécessaire -----#
  If clalev([M:DST])
    Gosub LIENS_DIETRS From SUBDST :
    Gosub INVISIBLE    From SUBDST
    Diszo [DST]1-99 : Affzo [DST]1-99
  Endif
####################################################
# Actions sur le traitement standard (GTRAITE)     #
# ------------------------------------------------ #
# COPTRS : Copie de transaction vers autre dossier #
# VISUSLI: Visu transaction Facture/avoir          #
####################################################
 When "INIT"      :
  Case GACTION
   When "VISUSLI" : Gosub INI_VISUSLI
  Endcase
 When "INIT_DIA"  :
  Case GACTION
   When "COPTRS"  : Gosub INIT_DIA
  Endcase
 When "CONTROLE"  :
  Case GACTION
   When "COPTRS"  : Gosub CONTROLE
  Endcase
 When "EXEC"      :
  Case GACTION
   When "COPTRS"  : Gosub EXEC
  Endcase
 When "FINSAI"
  Case GACTION
   When "VISUCMA" : Gosub FINSAI_VISUCMA
  Endcase
Endcase
Return

$INI_VISUSLI
Local Integer WINVTYP : WINVTYP=val(PARAM(2))
#----- Transaction facture vente : Déterminer au préalable si visu txn facture ou txn avoir
If WINVTYP=2
    BOITE = "ISLA"    : # Avoir
Else
    BOITE = "ISLI"    : # Facture ou proforma
Endif
Return

$OUV_VSL
#----- Ouverture du fichier TRS pour les ventes -----#
[L]WDIE_ABRFIC="SLT"
[L]WDIE_DTRTYP=WTYP
If clalev ([F:SLT])<=0 Local File SALTRS [SLT] : Endif
Read [SLT] SLT0=WTYP;PARAM(1)
If fstat Raz [F:SLT] : FIN=1 : GMESSAGE="" Endif
Return

$OUV_PSL
#----- Ouverture du fichier TRS pour les achats -----#
[L]WDIE_ABRFIC="PTR"
[L]WDIE_DTRTYP=WTYP
If clalev ([F:PTR])<=0 Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=WTYP;PARAM(1)
If fstat Raz [F:PTR] : FIN=1 : GMESSAGE="" Endif
Return

$OUV_SRT
#----- Ouverture du fichier SRT pour les stocks  ----#
[L]WDIE_ABRFIC="SRT"
[L]WDIE_DTRTYP=WTYP
If clalev ([F:SRT])<=0 Local File STKTRS [SRT] : Endif
Read [SRT]SRT1=PARAM(1);WTYP
If fstat Raz [F:SRT] : FIN=1 : GMESSAGE="" Endif
Return

$OUV_MTS
#----- Ouverture du fichier MTS pour la GPAO -----#
[L]WDIE_ABRFIC="MTS"
[L]WDIE_DTRTYP=WTYP
If clalev ([F:MTS])<=0 Local File MFGTRS [MTS] : Endif
Read [MTS]MTS1=PARAM(1);WTYP
If fstat Raz [F:MTS] : FIN=1 : GMESSAGE="" Endif
Return

$OUV_BTS
[L]WDIE_ABRFIC="BTS"
[L]WDIE_DTRTYP=WTYP
#----- Ouverture du fichier BTS pour les outils d'approvisionnement -----#
If clalev ([F:BTS])<=0 Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS1=PARAM(1);WTYP
If fstat Raz [F:BTS] : FIN=1 : GMESSAGE="" Endif
Local Char    LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local Integer ER
If clalev ([F:AMZ]) <= 0 : Local File AMSKZON  [AMZ] : Endif
Return


$OUV_HDK
[L]WDIE_ABRFIC="HTR"
[L]WDIE_DTRTYP=WTYP
#----- Ouverture du fichier TRS pour support HDK -----#
If clalev ([F:HTR])<=0 Local File HDKTRS [HTR] : Endif
If clalev ([F:HTV])<=0 Local File HDKTRSVAL [HTV] : Endif
If !clalev([F:AMZ]) : Local File AMSKZON  [AMZ] : Endif

Read [HTR] HTR0=WTYP;PARAM(1)
If fstat Raz [F:HTR] : FIN=1 : GMESSAGE="" Endif

If WTYP = 1
    Global Char GCMABRACLATXT
    #Obtention du libellé du champ Marque
    Local Char SZTXTNUM
    Call PARAM("", "MACBRAUSE", SZTXTNUM) From ADOVAL
    Call TEXTE(val(SZTXTNUM), GCMABRACLATXT) From OBJDIV
    If GCMABRACLATXT = ""
        Call TEXTE(14543, GCMABRACLATXT) From OBJDIV
    Endif
Endif
Return

$OUV_CRM
[L]WDIE_ABRFIC="CRM"
[L]WDIE_DTRTYP=WTYP
#----- Ouverture du fichier TRS pour la CRM -----#
If clalev ([F:CTR])<=0 Local File CRMTRS [CTR] : Endif
If clalev ([F:CTV])<=0 Local File CRMTRSVAL [CTV] : Endif
If !clalev([F:AMZ]) : Local File AMSKZON  [AMZ] : Endif

Read [CTR] CTR0=WTYP;PARAM(1)
If fstat Raz [F:CTR] : FIN=1 : GMESSAGE="" Endif
Return

$FINSAI_VISUCMA
Kill GCMABRACLATXT
Return

$DEB_VISUSLQ
[M:SLQ0]=[F:SLT] : [M:SLQ1]=[F:SLT] : [M:SLQ2]=[F:SLT] : [M:SLQ3]=[F:SLT] : [M:SLX1]=[F:SLT]
Affzo [M:SLQ0]     : Affzo [M:SLQ1]     : Affzo [M:SLQ2]     : Affzo [M:SLQ3]    : Affzo [M:SLX1]
Diszo [M:SLQ0]     : Diszo [M:SLQ1]     : Diszo [M:SLQ2]     : Diszo [M:SLQ3]    : Diszo [M:SLX1]
Return

$DEB_VISUSLC
[M:SLC0]=[F:SLT] : [M:SLC1]=[F:SLT] : [M:SLC2]=[F:SLT] : [M:SLC3]=[F:SLT] : [M:SLC4]=[F:SLT]
[M:SLC5]=[F:SLT]
[M:SLX1]=[F:SLT]
If dim([M:SLC1]NBAXE)>0 : [M:SLC1]NBAXE=GOPTCANA : Endif
Affzo [SLC0]     : Affzo [SLC1]     : Affzo [SLC2]     : Affzo [SLC3]
Affzo [SLC4]     : Affzo [SLC5]     : Affzo [SLX1]
Diszo [SLC0]     : Diszo [SLC1]     : Diszo [SLC2]     : Diszo [SLC3]
Diszo [SLC4]     : Diszo [SLC5]     : Diszo [SLX1]
Return

$DEB_VISUSLO
[M:SLO0]=[F:SLT] : [M:SLO1]=[F:SLT] : [M:SLO2]=[F:SLT] : [M:SLO3]=[F:SLT] : [M:SLX1]=[F:SLT]
If dim([M:SLO1]NBAXE)>0 : [M:SLO1]NBAXE=GOPTCANA : Endif
Affzo [SLO0]     : Affzo [SLO1]     : Affzo [SLO2]     : Affzo [SLO3] : Affzo [SLX1]
Diszo [SLO0]     : Diszo [SLO1]     : Diszo [SLO2]     : Diszo [SLO3] : Diszo [SLX1]
Return

$DEB_VISUSLD
[M:SLD0]=[F:SLT] : [M:SLD1]=[F:SLT] : [M:SLD2]=[F:SLT] : [M:SLD3]=[F:SLT]: [M:SLD4]=[F:SLT]
[M:SLX1]=[F:SLT] : [M:SLS1]=[F:SLT]
Affzo [M:SLD0] : Affzo [M:SLD1] : Affzo [M:SLD4] : Affzo [M:SLD2] : Affzo [M:SLD3]
Affzo [M:SLX1] : Affzo [M:SLS1]
Diszo [M:SLD0] : Diszo [M:SLD1] : Diszo [M:SLD4] : Diszo [M:SLD2] : Diszo [M:SLD3]
Diszo [M:SLX1] : Diszo [M:SLS1]
Return

$DEB_VISUSLI
Local Integer WINVTYP : WINVTYP=val(PARAM(2))
[M:SLI0]=[F:SLT] : [M:SLI2]=[F:SLT] : [M:SLI3]=[F:SLT] : [M:SLI4]=[F:SLT] : [M:SLX1]=[F:SLT]
If WINVTYP=2
    [M:SLA1]=[F:SLT] : [M:ETR2]=[F:SLT]
    If [M:ETR2]UOMSAIFLG=1
        [M:SLI4]STUCOD=1
        [M:SLI3]SAUCOECOD=3
        [M:SLI3]SAUCOD=2
    Else
        [M:SLI4]STUCOD=2
        [M:SLI3]SAUCOECOD=1
        [M:SLI3]SAUCOD=1
    Endif
    [M:SLI4]STUSCR=1 : [M:SLI3]SAUCOESCR=1 : [M:SLI3]SAUSCR=1
    If dim([M:SLA1]NBAXE)>0 : [M:SLA1]NBAXE=GOPTCANA : Endif
    If dim([M:ETR2]STACOD)>0 & dim([M:ETR2]STASCR)>0 :# Particularité pour les avoirs : Statut
        [M:ETR2]STACOD=[F:SLT]AQRCOD
        [M:ETR2]STASCR=[F:SLT]AQRSCR
    Endif
Else
    [M:SLI1]=[F:SLT] : [M:SLS1]=[F:SLT]

    Case [F:SLT]INVTYP
     When 1 : [M:SLI1]INVTYPFAC=1
     When 3 : [M:SLI1]INVTYPFAC=2
     When 4 : [M:SLI1]INVTYPFAC=3
    Endcase
    [M:SLI2]CNORENCOD=3
    If dim([M:SLI1]NBAXE)>0 : [M:SLI1]NBAXE=GOPTCANA : Endif
Endif

If WINVTYP=2
    Affzo [M:SLA1] : Affzo [M:ETR2]
    Diszo [M:SLA1] : Diszo [M:ETR2]
Else
    Affzo [M:SLI1] : Affzo [M:SLS1]
    Diszo [M:SLI1] : Diszo [M:SLS1]
Endif
Affzo [M:SLI0] : Affzo [M:SLI4] : Affzo [M:SLI2] : Affzo [M:SLI3] : Affzo [M:SLX1]
Diszo [M:SLI0] : Diszo [M:SLI4] : Diszo [M:SLI2] : Diszo [M:SLI3] : Diszo [M:SLX1]
Return

$DEB_VISUSLR
Raz [SLR1]
[M:SLR0]=[F:SLT] : [M:SLR1]=[F:SLT] : [M:SLR2]=[F:SLT] : [M:ETR2]=[F:SLT]
Affzo [SLR0]     : Affzo [SLR1]     : Affzo [SLR2]    : Affzo [ETR2]
Diszo [SLR0]     : Diszo [SLR1]     : Diszo [SLR2]    : Diszo [ETR2]
Return

$DEB_VISUSLL
Raz [SLL1]
[M:SLL0]=[F:SLT] : [M:SLL1]=[F:SLT] : [M:SLL2]=[F:SLT] : [M:ETR2]=[F:SLT]
Affzo [SLL0]     : Affzo [SLL1]     : Affzo [SLL2]    : Affzo [ETR2]
Diszo [SLL0]     : Diszo [SLL1]     : Diszo [SLL2]    : Diszo [ETR2]
Return

$DEB_VISUSLS
Raz [SSC1]
[M:SSC0]=[F:SLT] : [M:SSC1]=[F:SLT] : [M:SSC2]=[F:SLT] : [M:ETR2]=[F:SLT]
Affzo [SSC0]     : Affzo [SSC1]     : Affzo [SSC2]    : Affzo [ETR2]
Diszo [SSC0]     : Diszo [SSC1]     : Diszo [SSC2]    : Diszo [ETR2]
Return


$DEB_VISUPTA
# Appels d'offres
[M:PTA0]=[F:PTR] : [M:PTA1]=[F:PTR] : [M:PTA2]=[F:PTR]
Affzo [PTA0]     : Affzo [PTA1]     : Affzo [PTA2]
Diszo [PTA0]     : Diszo [PTA1]     : Diszo [PTA2]
Return

$DEB_VISUPTD
# Demandes d'achats
[M:PTD0]=[F:PTR] : [M:PTD1]=[F:PTR] : [M:PTD2]=[F:PTR]
[M:PTD1]NBLEDTYP=len(mess(0,2644,1))
Affzo [PTD0]     : Affzo [PTD1]     : Affzo [PTD2]
Diszo [PTD0]     : Diszo [PTD1]     : Diszo [PTD2]
Return

$DEB_VISUPTC
# Commandes d'achats
[M:PTC0]=[F:PTR] : [M:PTC1]=[F:PTR] : [M:PTC2]=[F:PTR] : [M:PTC3]=[F:PTR] : [M:PTC4]=[F:PTR]
[M:PTX4]=[F:PTR]
[M:PTC2]BPSINVCOD=[F:PTR]BPSCOD(1)
[M:PTC2]BPRPAYCOD=[F:PTR]BPSCOD(2)
[M:PTC1]NBLEDTYP=len(mess(0,2644,1))
Affzo [PTC0]     : Affzo [PTC1]     : Affzo [PTC2]     : Affzo [PTC3]     : Affzo [PTC4]
Affzo [PTX4]
Diszo [PTC0]     : Diszo [PTC1]     : Diszo [PTC2]     : Diszo [PTC3]     : Diszo [PTC4]
Diszo [PTX4]
Return

$DEB_VISUPTT
# Commandes ouvertes d'achats
[M:PTT0]=[F:PTR] : [M:PTT1]=[F:PTR] : [M:PTT2]=[F:PTR] : [M:PTX4]=[F:PTR]
Affzo [PTT0]     : Affzo [PTT1]     : Affzo [PTT2]     : Affzo [PTX4]
Diszo [PTT0]     : Diszo [PTT1]     : Diszo [PTT2]     : Diszo [PTX4]
Return

$DEB_VISUPTR
# Réception fournisseurs
[M:PTR0]=[F:PTR] : [M:PTR1]=[F:PTR] : [M:PTR2]=[F:PTR] : [M:PTR3]=[F:PTR] : [M:ETR2]=[F:PTR]
[M:PTR1]NBLEDTYP=len(mess(0,2644,1))
Affzo [PTR0]     : Affzo [PTR1]     : Affzo [PTR2]     : Affzo [PTR3]     : Affzo [ETR2]
Diszo [PTR0]     : Diszo [PTR1]     : Diszo [PTR2]     : Diszo [PTR3]     : Diszo [ETR2]
Return

$DEB_VISUPTN
# Retours fournisseurs
[M:PTN0]=[F:PTR] : [M:PTN1]=[F:PTR] : [M:PTN2]=[F:PTR] : [M:PTN3]=[F:PTR] : [M:PTN4]=[F:PTR]
[M:PTN1]NBLEDTYP=len(mess(0,2644,1))
Affzo [PTN0]     : Affzo [PTN1]     : Affzo [PTN2]     : Affzo [PTN3]     : Affzo [PTN4]
