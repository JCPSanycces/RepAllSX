#######################################################################
# Chargement des codes accés (éxécution = NON) du profil utilisateur  #
#    Ce sous programme doit être appelé en action 'DEFTRANS'          #
#######################################################################
Subprog CHARGE_ACC(NBACS,TABACS)

Variable Integer NBACS
Variable Char    TABACS()()

If clalev([F:ACC])=0 Local File ACCES [ACC] Endif

Raz NBACS
# Chargement des codes accés du profil utilisateur qui ont 'éxécution à NON'
For [ACC]CODACC Where USR=GUSER
   If [F:ACC]EXEC<>2
      TABACS(NBACS)=[F:ACC]CODACC
      NBACS +=1
   Endif
   If NBACS>99 Break : Endif
Next
End


#######################################################################
# Recherche si le code accés de la transaction appartient à la liste  #
# code accés interdit en éxécution pour l'utilisateur                 #
#    Ce sous programme doit être appelé en action 'VARIANTE'          #
#    Le sous programme CHARGE_ACC doit auparavant être appelé         #
#    WACSCOD doit contenir le code accés de la transaction            #
#######################################################################
Subprog VERIF_ACC(NBACS,TABACS,WACSCOD,WOK)
Value    Integer NBACS
Value    Char    TABACS()(1..)
Value    Char    WACSCOD()
Variable Integer WOK
WOK=1
If WACSCOD<>"" & NBACS>0
   If find(WACSCOD,TABACS(1..NBACS))
      WOK = 0
   Endif
Endif
End


############################################################################
# COPTRS : Action de copie de transaction                                  #
############################################################################

$INIT_DIA
Local Integer MODULE
Local Integer MSG
Local Integer TYP
Local Char    CODTAB(GLONTRS)
Local Integer BATCH
Local Integer OK
Local Char    L_TITRE(GDIMFIC)
#-----
MODULE=val(PARAM(1))
MSG   =val(PARAM(2))
TYP   =val(PARAM(3))
CODTAB=PARAM(4)
BATCH =val(PARAM(5))
#-----
Raz [M:DIA]
[M:DIA]OBJET=mess(143,195,1)-":"-CODTAB
Case TYP
 When 51 : OK = 1 : # Plan global
 When 52 : OK = 2 : # Plan de travail
 When 53 : OK = 3 : # Regroupement
 When 60 : OK = 4 : # Plan suivi des temps
 When 61 : OK = 5 : # Plan suivi matière
 When 62 : OK = 6 : # Plan production
 When 63 : OK = 7 : # Plan suivi réintégration
 When 65 : OK = 9 : # Pilotage des plans
 When 65 : OK = 10: # Plan des fiches techniques
 When Default : OK = TYP
Endcase
L_TITRE = mess(OK,MSG,1)
OK=2 : zonsui="DOSDES"
Return

$CONTROLE
Gosub OUVRE_COPTRS
If MODULE = 5
    Look [SLT2] SLT0=TYP;CODTAB
Elsif MODULE = 6
    Look [PTR2] PTR0=TYP;CODTAB
Elsif MODULE = 7
    If TYP > 50
        Look [BTS2] BTS0=TYP;CODTAB
    Else
        Look [SRT2] SRT0=TYP;CODTAB
    Endif
Elsif MODULE = 8
    If TYP < 3
        Look [MTS2] MTS0=TYP;CODTAB
  Else
        Look [BTS2] BTS0=TYP;CODTAB
    Endif
Elsif MODULE = 12
    Look [HTR2] HTR0=TYP;CODTAB

Elsif MODULE = 13
    Look [CTR2] CTR0=TYP;CODTAB

Endif
If !fstat
  If !BATCH : # JML 06/09/00
    OK= 2 : Call AVERTIR([M]DOSDES-num$(TYP)-CODTAB-mess(148,196,1),OK) From GESECRAN
    If OK<>2 : FIN=1 : Return : Endif
  Else
    GMESSAGE = mess(135,197,1)
    #### Enregistrement existant écrasé
    # JML 06/09/00 On laisse écraser
  Endif
Endif
Return

$EXEC
If !BATCH : # JML 06/09/00
 Call TEMPON("T") From GESECRAN
Endif
Gosub EXEC_COPTRS
If GOK<1  GMESSAGE=mess(14,100,1) : Endif
If !BATCH : # JML 06/09/00
 Call TEMPOFF From GESECRAN
Endif
Return


#----------------------------------------------------------#
# Overture des tables origine et destination pour la copie #
# -------------------------------------------------------- #
# Variables à renseigner avant l'appel :                   #
#  MODULE : Module de la transaction de saisie à copier    #
#  TYP    : Type de la transaction de saisie à copier      #
#----------------------------------------------------------#
$OUVRE_COPTRS
If [M]DOSORG=nomap
  Local File ATEXTRA  [AXX1]
  Local File DIETRS   [DTR1]
  Case MODULE
    When  5 : Local File SALTRS  [SLT1]
    When  6 : Local File PURTRS  [PTR1]
    When  7 : If TYP>50
                Local File BENCHTRS [BTS1]
              Else
                Local File STKTRS   [SRT1]
              Endif
    When  8 : If TYP<3
                Local File MFGTRS   [MTS1]
              Else
                Local File BENCHTRS [BTS1]
              Endif
    When 12 : Local File HDKTRS    [HTR1]
              Local File HDKTRSVAL [HTV1] # FGR 13/01/2009
    When 13 : Local File CRMTRS    [CTR1]
              Local File CRMTRSVAL [CTV1] # FGR 13/01/2009
  Endcase
Else
  Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
  Local File =[M]DOSORG+".DIETRS"   [DTR1]
  Case MODULE
    When  5 : Local File =[M]DOSORG+".SALTRS" [SLT1]
    When  6 : Local File =[M]DOSORG+".PURTRS" [PTR1]
    When  7 : If TYP>50
                Local File =[M]DOSORG+".BENCHTRS" [BTS1]
              Else
                Local File =[M]DOSORG+".STKTRS"   [SRT1]
              Endif
    When  8 : If TYP<3
                Local File =[M]DOSORG+".MFGTRS"   [MTS1]
              Else
                Local File =[M]DOSORG+".BENCHTRS" [BTS1]
              Endif
    When 12 : Local File =[M]DOSORG+".HDKTRS"    [HTR1]
              Local File =[M]DOSORG+".HDKTRSVAL" [HTV1] # FGR 13/01/2009
    When 13 : Local File =[M]DOSORG+".CRMTRS"    [CTR1]
              Local File =[M]DOSORG+".CRMTRSVAL" [CTV1] # FGR 13/01/2009
  Endcase
Endif
If [M]DOSDES=nomap
  Local File ATEXTRA  [AXX2]
  Local File DIETRS   [DTR2]           # FQ 51623 avant DTR1
  Case MODULE
    When  5 : Local File SALTRS  [SLT2]
    When  6 : Local File PURTRS  [PTR2]
    When  7 : If TYP>50
                Local File BENCHTRS [BTS2]
              Else
                Local File STKTRS   [SRT2]
              Endif
    When  8 : If TYP<3
                Local File MFGTRS   [MTS2]
              Else
                Local File BENCHTRS [BTS2]
              Endif

    When 12 : Local File HDKTRS    [HTR2]
              Local File HDKTRSVAL [HTV2] # FGR 13/09/2009
    When 13 : Local File CRMTRS    [CTR2]
              Local File CRMTRSVAL [CTV2] # FGR 13/09/2009
  Endcase
Else
  Local File =[M]DOSDES+".ATEXTRA"  [AXX2]           # FQ 51623 avant DOSORG
  Local File =[M]DOSDES+".DIETRS"   [DTR2]           # FQ 51623 avant DOSORG et DTR1
  Case MODULE
    When  5 : Local File =[M]DOSDES+".SALTRS" [SLT2]
    When  6 : Local File =[M]DOSDES+".PURTRS" [PTR2]
    When  7 : If TYP>50
                Local File =[M]DOSDES+".BENCHTRS" [BTS2]
              Else
                Local File =[M]DOSDES+".STKTRS"   [SRT2]
              Endif
    When  8 : If TYP<3
                Local File =[M]DOSDES+".MFGTRS"   [MTS2]
              Else
                Local File =[M]DOSDES+".BENCHTRS" [BTS2]
              Endif

    When 12 : Local File =[M]DOSDES+".HDKTRS"    [HTR2]
              Local File =[M]DOSDES+".HDKTRSVAL" [HTV2] # FGR 13/01/2009
    When 13 : Local File =[M]DOSDES+".CRMTRS"    [CTR2]
              Local File =[M]DOSDES+".CRMTRSVAL" [CTV2] # FGR 13/01/2009
  Endcase
Endif
Gosub OUVDOS From ATEXTRA
Return


#---------------------------------------------------------#
# Fermeture des tables origine et destination après copie #
# ------------------------------------------------------- #
# Variables à renseigner avant l'appel :                  #
#  MODULE : Module de la transaction de saisie à copier   #
#  TYP    : Type de la transaction de saisie à copier     #
#---------------------------------------------------------#
$FERME_COPTRS
Close Local File [AXX1], [AXX2]
Close Local File [DTR1], [DTR2]
Case MODULE
  When  5 : Close Local File [SLT1], [SLT2]
  When  6 : Close Local File [PTR1], [PTR2]
  When  7 : If TYP>50
              Close Local File [BTS1], [BTS2]
            Else
              Close Local File [SRT1], [SRT2]
            Endif
  When  8 : If TYP<3
              Close Local File [MTS1], [MTS2]
            Else
              Close Local File [BTS1], [BTS2]
            Endif
  When 12 : Close Local File [HTR1], [HTR2]
            Close Local File [HTV1], [HTV2] # FGR 13/01/2009
  When 13 : Close Local File [CTR1], [CTR2]
            Close Local File [CTV1], [CTV2] # FGR 13/01/2009
Endcase
Return


#-------------------------------------------------------#
# Exécution de la transaction de copie                  #
# ----------------------------------------------------- #
# Variables à renseigner avant l'appel :                #
#  MODULE : Module de la transaction de saisie à copier #
#  TYP    : Type de la transaction de saisie à copier   #
#  CODTAB : Code de la transaction de saisie à copier   #
#-------------------------------------------------------#
EXEC_COPTRS
Call DEBTRANS From GLOCK
Gosub TR_COP
Return

#-----
$TR_COP
GOK=1
Case MODULE
  When  5
    Trbegin [SLT2]
      Delete [SLT2] Where STRTYP=TYP & STRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".SALTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("SLT2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Read [SLT1] SLT0=TYP;CODTAB
      If !fstat
        [F:SLT2]=[F:SLT1]
        If dim([F:SLT2]UPDUSR)>0  [F:SLT2]UPDUSR=GUSER : Endif
        If dim([F:SLT2]UPDDAT)>0  [F:SLT2]UPDDAT=date$ : Endif
        Call COPTEXTRA("SALTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Write [SLT2]
        If fstat  GOK=0 : Call FSTA("SLT2") From GLOCK : Goto AB_TR_COP : Endif
        Call COPDIETRS("SLT",TYP,CODTAB) From SUBDST
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
      Endif
    Commit
  When  6
    Trbegin [PTR2]
      Delete [PTR2] Where PTRTYP=TYP & PTRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".PURTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("PTR2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Read [PTR1] PTR0=TYP;CODTAB
      If !fstat
        [F:PTR2]=[F:PTR1]
        If dim([F:PTR2]UPDUSR)>0  [F:PTR2]UPDUSR=GUSER : Endif
        If dim([F:PTR2]UPDDAT)>0  [F:PTR2]UPDDAT=date$ : Endif
        Call COPTEXTRA("PURTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Write [PTR2]
        If fstat  GOK=0 : Call FSTA("PTR2") From GLOCK : Goto AB_TR_COP : Endif
        Call COPDIETRS("PTR",TYP,CODTAB) From SUBDST
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
      Endif
    Commit
  When  7
    If TYP>50
      Trbegin [BTS2]
        Delete [BTS2] Where BTSTYP=TYP & BTSNUM=CODTAB
        If fstat=1
          GOK=-1 : GLOCK="$"+[M]DOSDES+".BENCHTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
        Elsif fstat
          GOK= 0 : Call RSTA("BTS2",num$(TYP)-CODTAB) From GLOCK    : Goto AB_TR_COP
        Endif
        Read [BTS1] BTS0=TYP;CODTAB
        If !fstat
          [F:BTS2]=[F:BTS1]
          If dim([F:BTS2]UPDUSR)>0  [F:BTS2]UPDUSR=GUSER : Endif
          If dim([F:BTS2]UPDDAT)>0  [F:BTS2]UPDDAT=date$ : Endif
          Call COPTEXTRA("BENCHTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
          Write [BTS2]
          If fstat  GOK=0 : Call FSTA("BTS2") From GLOCK : Goto AB_TR_COP : Endif
          Call COPDIETRS("BTS",TYP,CODTAB) From SUBDST
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Endif
      Commit
    Else
      Trbegin [SRT2]
        Delete [SRT2] Where SRTTYP=TYP & SRTNUM=CODTAB
        If fstat=1
          GOK=-1 : GLOCK="$"+[M:DIA]DOSDES+".STKTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
        Elsif fstat
          GOK= 0 : Call RSTA("SRT2",num$(TYP)-CODTAB) From GLOCK      : Goto AB_TR_COP
        Endif
        Read [SRT1] SRT0=TYP;CODTAB
        If !fstat
          [F:SRT2]=[F:SRT1]
          If dim([F:SRT2]UPDUSR)>0  [F:SRT2]UPDUSR=GUSER : Endif
          If dim([F:SRT2]UPDDAT)>0  [F:SRT2]UPDDAT=date$ : Endif
          Call COPTEXTRA("STKTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
          Write [SRT2]
          If fstat  GOK=0 : Call FSTA("SRT2") From GLOCK : Goto AB_TR_COP : Endif
          Call COPDIETRS("SRT",TYP,CODTAB) From SUBDST
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Endif
      Commit
    Endif
  When  8
    If TYP<3
      Trbegin [MTS2]
        Delete [MTS2] Where MTSTYP=TYP & MTSNUM=CODTAB
        If fstat=1
          GOK=-1 : GLOCK="$"+[M]DOSDES+".MFGTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
        Elsif fstat
          GOK= 0 : Call RSTA("MTS2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
        Endif
        Read [MTS1] MTS0=TYP;CODTAB
        If !fstat
          [F:MTS2]=[F:MTS1]
          If dim([F:MTS2]UPDUSR)>0  [F:MTS2]UPDUSR=GUSER : Endif
          If dim([F:MTS2]UPDDAT)>0  [F:MTS2]UPDDAT=date$ : Endif
          Call COPTEXTRA("MFGTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
          Write [MTS2]
          If fstat  GOK=0 : Call FSTA("MTS2") From GLOCK : Goto AB_TR_COP : Endif
          If TYP=1
            Call COPDIETRS("MTS",TYP,CODTAB) From SUBDST
            If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
          Endif
        Endif
      Commit
    Else
      Trbegin [BTS2]
        Delete [BTS2] Where BTSTYP=TYP & BTSNUM=CODTAB
        If fstat=1
          GOK=-1 : GLOCK="$"+[M]DOSDES+".BENCHTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
        Elsif fstat
          GOK= 0 : Call RSTA("BTS2",num$(TYP)-CODTAB) From GLOCK    : Goto AB_TR_COP
        Endif
        Read [BTS1] BTS0=TYP;CODTAB
        If !fstat
          [F:BTS2]=[F:BTS1]
          If dim([F:BTS2]UPDUSR)>0  [F:BTS2]UPDUSR=GUSER : Endif
          If dim([F:BTS2]UPDDAT)>0  [F:BTS2]UPDDAT=date$ : Endif
          Call COPTEXTRA("BENCHTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
          Write [BTS2]
          If fstat  GOK=0 : Call FSTA("BTS2") From GLOCK : Goto AB_TR_COP : Endif
          Call COPDIETRS("BTS",TYP,CODTAB) From SUBDST
          If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Endif
      Commit
    Endif
  When 12 :
    Trbegin [HTR2]
      Delete [HTV2] Where HTRTYP=TYP & HTRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".HDKTRSVAL"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("HTV2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Delete [HTR2] Where HTRTYP=TYP & HTRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".HDKTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("HTR2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Read [HTR1] HTR0=TYP;CODTAB
      If !fstat
        [F:HTR2]=[F:HTR1]
        If dim([F:HTR2]UPDUSR)>0  [F:HTR2]UPDUSR=GUSER : Endif
        If dim([F:HTR2]UPDDAT)>0  [F:HTR2]UPDDAT=date$ : Endif
        Call COPTEXTRA("HDKTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Write [HTR2]
        If fstat  GOK=0 : Call FSTA("HTR2") From GLOCK : Goto AB_TR_COP : Endif
        Call COPDIETRS("HTR",TYP,CODTAB) From SUBDST
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Look [HTV1] HTV0=TYP;CODTAB
        #If fstat
        If fstat = 0 Then                        # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
            Read [HTV1] HTV0=TYP;CODTAB
            If !fstat
                [F:HTV2]=[F:HTV1]
                If dim([F:HTV2]UPDUSR)>0  [F:HTV2]UPDUSR=GUSER : Endif
                If dim([F:HTV2]UPDDAT)>0  [F:HTV2]UPDDAT=date$ : Endif
                Look [HTV2]HTV0=TYP;CODTAB       # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                If fstat = 0 Then                # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                  Rewrite [HTV2]                 # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                Else                             # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                  Write [HTV2]                   # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                Endif                            # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                If fstat  GOK=0 : Call FSTA("HTV2") From GLOCK : Goto AB_TR_COP : Endif
            Endif
        Endif
      Endif
    Commit

  When 13 :
    Trbegin [CTR2]
      Delete [CTV2] Where CTRTYP=TYP & CTRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".CRMTRSVAL"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("CTV2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Delete [CTR2] Where CTRTYP=TYP & CTRNUM=CODTAB
      If fstat=1
        GOK=-1 : GLOCK="$"+[M]DOSDES+".CRMTRS"-num$(TYP)-CODTAB : Goto ROLL_TR_COP
      Elsif fstat
        GOK= 0 : Call RSTA("CTR2",num$(TYP)-CODTAB) From GLOCK  : Goto AB_TR_COP
      Endif
      Read [CTR1] CTR0=TYP;CODTAB
      If !fstat
        [F:CTR2]=[F:CTR1]
        If dim([F:CTR2]UPDUSR)>0  [F:CTR2]UPDUSR=GUSER : Endif
        If dim([F:CTR2]UPDDAT)>0  [F:CTR2]UPDDAT=date$ : Endif
        Call COPTEXTRA("CRMTRS","DESAXX",num$(TYP),CODTAB) From ATEXTRA
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Write [CTR2]
        If fstat  GOK=0 : Call FSTA("CTR2") From GLOCK : Goto AB_TR_COP : Endif
        Call COPDIETRS("CTR",TYP,CODTAB) From SUBDST
        If GOK=0 Goto AB_TR_COP Elsif GOK<0 Goto ROLL_TR_COP : Endif
        Look [CTV1] CTV0=TYP;CODTAB
        #If fstat
        If fstat = 0 Then                        # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
            Read [CTV1] CTV0=TYP;CODTAB
            If !fstat
                [F:CTV2]=[F:CTV1]
                If dim([F:CTV2]UPDUSR)>0  [F:CTV2]UPDUSR=GUSER : Endif
                If dim([F:CTV2]UPDDAT)>0  [F:CTV2]UPDDAT=date$ : Endif
                Look [CTV2] CTV0=TYP;CODTAB      # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                If fstat = 0 Then                # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                  Rewrite [CTV2]                 # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                Else                             # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                  Write [CTV2]                   # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                Endif                            # FGR 25/03/2013 : X3SUIVI88597 si ça existe fstat = 0
                If fstat  GOK=0 : Call FSTA("CTV2") From GLOCK : Goto AB_TR_COP : Endif
            Endif
        Endif
      Endif
    Commit
Endcase
Return
#-----
$AB_TR_COP
Rollback : Return
#-----
$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL  Return  Else  Goto TR_COP : Endif
