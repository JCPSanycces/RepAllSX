$DEB_VISUMRL
Local Integer I
# regroupements
[M:MRL0]=[F:BTS] : [M:MRL1]=[F:BTS] : [M:MRL2]=[F:BTS]
Default Mask [MRL2]
[M]NBRFLD = 0
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER<>2 : # If [F:BTS]PLANNER = 2 : # GH 06/03/2014 bug 97645
    [M:MRL1]USRPRF = 1
    MASKREF = "MFGPICK"
Endif
## GH 06/03/2014 bug 97645 cas du planificateur SST ajouté
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER=2
    [M:MRL1]USRPRF = 4
    MASKREF = "MFGPICK"
Endif
##
If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
    [M:MRL1]USRPRF = 2
    MASKREF = "MFGPICKA"
Endif
If [F:BTS]PLANNER<>2 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) : # If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2 : # GH 06/03/2014 bug 97645
    [M:MRL1]USRPRF = 3
    MASKREF = "MFGPICKA"
Endif
If find([M:MRL1]USRPRF,2,3)
    If [M:MRL1]USRPRF = 2
        If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 1 : [M:MRL1]APPPRF = 1 : Endif
        If [F:BTS]APPBUY = 1 & [F:BTS]APPINT = 2 : [M:MRL1]APPPRF = 2 : Endif
        If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 2 : [M:MRL1]APPPRF = 3 : Endif
        If !find([M:MRL1]APPPRF,1,2,3) : [M:MRL1]APPPRF = 3 : [M:MRL1]APPBUY = 2 : [M:MRL1]APPINT = 2 : Endif
    Else
        If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 1 : [M:MRL1]APPPRF = 1 : Endif
        If [F:BTS]BUYER  = 1 & [F:BTS]INTBUY = 2 : [M:MRL1]APPPRF = 2 : Endif
        If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 2 : [M:MRL1]APPPRF = 3 : Endif
        If !find([M:MRL1]APPPRF,1,2,3) : [M:MRL1]APPPRF = 3 : [M:MRL1]BUYER  = 2 : [M:MRL1]INTBUY = 2 : Endif
    Endif
Endif

Gosub CHARGE_CHAMP From SUBMRL
Raz [M]DAC
For I=0 To [F:BTS]NBRFLD-1
    K = find([F:BTS]FLD(I),[M]FLD(0..[M]NBRFLD))
    If K
      [M]DAC(K-1) = [F:BTS]DAC(I)
     Endif
Next I
Gosub TRI          From SUBMRL
Affzo [MRL0]     : Affzo [MRL1]
Affzo [MRL2]
Diszo [MRL0]     : Diszo [MRL1]
Diszo [MRL2]
Return

