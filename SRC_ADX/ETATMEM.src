#<AdxTL>@(#)12.0.0.0 $Revision$
####################################################################
## Traitement des mémos (independant, raison : optimisation)
####################################################################
$ACTION
Case PARAM(1)
 When "M" : Gosub MEMO
 When "R" : Gosub LECTURE
 When "E" : Gosub EFFACE
Endcase
Return

$MEMO
Local Char ETAT(20) , EXT(5)
ETAT = PARAM(2)
EXT  = "rpt"
Case ACTION
 When "DEBUT"    : Gosub DEB_MEMO
 When "OK"       : Gosub EXEC_MEMO
 When "FINSAI"   : Gosub FIN_MEMO
Endcase
Return

$LECTURE
Local Char ETAT(20) , EXT(5)
ETAT = PARAM(2)
EXT  = "rpt"
Case ACTION
 When "DEBUT"    : Gosub DEB_MEMO
 When "OK"       : Gosub LEC_MEMO
 When "FINSAI"   : Gosub FIN_MEMO
Endcase
Return

$EFFACE
Local Char ETAT(20) , EXT(5)
ETAT = PARAM(2)
EXT  = "rpt"
Case ACTION
 When "DEBUT"    : Gosub DEB_MEMO
 When "OK"       : Gosub EFF_MEMO
 When "FINSAI"   : Gosub FIN_MEMO
Endcase
Return

$DEB_MEMO
[M:MEM]CODE   = ""
[M:MEM]OBJECT = ETAT
[M:MEM]TYP    = EXT
Return

$FIN_MEMO
If PARAM(1)="R" & GSTATUT=GSTAOK
 NBAFF = 2 : # Pour raffraîchir la fenêtre du dessous
Endif
Return

$EXEC_MEMO
Local Integer I
Local Integer STAT  
Local Char    FICMEM(250) , SAVIFS(5) , SAVIRS(5) 

If [M:MEM]CODE = "" : Return : Endif
SAVIFS = adxifs 
SAVIRS = adxirs 
FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+[M:MEM]CODE,EXT,0)
Openo FICMEM , 0 
adxifs = tab$ 
adxirs = chr$(10) 
For I=0 To [M:RPT]NBRPAR-1 
 Wrseq [M:RPT]PARCOD(I), [M:RPT]VALEUR1(I) , [M:RPT]VALEUR2(I) 
Next I 
Openo 
GERR = 2 : GMESSAGE = mess(11,109,1) : # Paramètres enregistrés 
adxifs = SAVIFS 
adxirs = SAVIRS 
Return

$LEC_MEMO
Call LECMEMO(ETAT,EXT,[M:MEM]CODE)
Return

Subprog LECMEMO(ETAT,EXT,MEMO)
Value Char ETAT
Value Char EXT
Value Char MEMO
Local Integer I
Local Char    FICMEM(250)
Local Char    MEMCOD(50) , MEMVAL1(50) , MEMVAL2(50) 
Local Char    SAVIFS(5) , SAVIRS(5) 
SAVIFS = adxifs 
SAVIRS = adxirs 
FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+MEMO,EXT,0)
If filinfo(FICMEM,0)>=0
 Openi FICMEM 
 adxifs = tab$ 
 adxirs = chr$(10) 
 Rdseq MEMCOD , MEMVAL1 , MEMVAL2 
 While fstat=0 
  I = find(MEMCOD,[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1)) 
  If I 
   [M:RPT]VALEUR1(I-1) = MEMVAL1 
   If [M:RPT]DEBFIN(I-1)=2 
    [M:RPT]VALEUR2(I-1) = MEMVAL2 
   Endif 
  Endif 
  Rdseq MEMCOD , MEMVAL1 , MEMVAL2 
 Wend 
 Openi 
Endif 
adxifs = SAVIFS 
adxirs = SAVIRS 
End

$EFF_MEMO
Local Char    FICMEM(250)
Local Integer STAT
FICMEM = filpath("ETM",GUSER+"_"+ETAT+"_"+[M:MEM]CODE,EXT,0)
If filinfo(FICMEM,0)>=0 
 Call  EFFACE(FICMEM,STAT) From ORDSYS 
 GERR = 2 : GMESSAGE = mess(39,109,1)
Endif 
Return

