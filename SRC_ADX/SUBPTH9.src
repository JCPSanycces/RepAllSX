#<AdxTL>@(#)11.0.0.0 $Revision$  Gestion du masque PTH9
########################################################################
# SUBPTH9 : Saisie des compléments réceptions fournisseurs             #
# -------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par l'action       #
# SAIPTHCOM "saisie des compléments" et ne sert qu'à gérer le          #
# masque écran "PTH9 [PTH9]".                                          #
# Issue 100619 - 2014-07-24 by SR : [M:PTH9] remplacés par [M]         #
# Car le Webservice ouvre une autre abréviation que PTH9               #
########################################################################


Subprog C_BPSINV(VALEUR)
#--------------------------------#
# Contrôle fournisseur facturant #
#--------------------------------#
Variable Char    VALEUR()
#----- Vérification que la structure soit identique -----#
If [F:BPS]PLISTC<>GPLISTC
  GMESSAGE=mess(141,199,1)-"("+[F:BPS]PLISTC-"<>"-GPLISTC+")"
  mkstat=1 : End
Endif
End


Subprog AM_BPSINV(VALEUR)
#---------------------------------------------#
# Après modification du fournisseur facturant #
#---------------------------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPSINV=VALEUR
  [M]BPAINV=[F:BPS2]BPAINV
Elsif [F:BPS]BPSINV=VALEUR
  [M]BPAINV=[F:BPS]BPAINV
Else
  [M]BPAINV=[F:BPS]BPAADD
Endif
#----- Si commande piquée, pas de réinitialisation éléments facturation et escompte -----#
If [M:PTH1]NBLIG=0 | !sigma(I=0,[M:PTH1]NBLIG-1,[M:PTH1]POHNUM(I)<>"")
  [M]BPSINV=VALEUR
  Call INIT_ELEMENTS (6,[M:PTH0]CHGTYP,[F:BPS2]CUR,GCUR) From TRTACHELT1
  Call INIT_ESCOMPTE([M]BPSINV,GSOCIETE,"F",[M]DEP) From CPTSUB
  Call AM_DEP([M]DEP) From SUBPTH9
  If !GIMPORT Affzo [M]BPAINV, DEP : Affzo [PTH2]1-99 : Endif
Else
  If !GIMPORT  Affzo [M]BPAINV : Endif
Endif
#-----
# Issue X3-68064 - 2018-01-17 by MUARN : numéro de TVA intracommunautaire
If GACTDEB=2
  If [F:BPR2]BPRNUM<>VALEUR
    Read [BPR2] BPR0=VALEUR : If fstat  Raz [F:BPR2] : Endif
  Endif
  [M:PCEX]EECNUM=[F:BPR2]EECNUM : # Identification CEE
Endif
End


Subprog C_BPAINV(VALEUR)
#---------------------------------------------#
# Contrôle code adresse fournisseur facturant #
#---------------------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M]BPSINV;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End


Subprog AM_BPRPAY(VALEUR)
#---------------------------#
# Après modif du tiers payé #
#---------------------------#
Variable Char    VALEUR()
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2] : Endif
Read [BPS2] BPS0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPS2] : Endif
If [F:BPS2]BPRPAY=VALEUR
  [M]BPAPAY=[F:BPS2]BPAPAY
Else
  If [F:BPS2]BPSNUM<>VALEUR
    Read [BPS2] BPS0=VALEUR : If fstat  Raz [F:BPS2] : Endif
  Endif
  If [F:BPS2]BPRPAY=VALEUR
    [M]BPAPAY=[F:BPS2]BPAPAY
  Elsif [F:BPS2]BPAADD<>""
    [M]BPAPAY=[F:BPS2]BPAADD
  Else
    If [F:BPR]BPRNUM<>VALEUR
      Read [BPR] BPR0=VALEUR : If fstat  Raz [F:BPR] : Endif
    Endif
    [M]BPAPAY=[F:BPR]BPAADD
    #----- Rechargement du  business partner commande si nécessaire -----#
    If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
      Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPR] : Endif
    Endif
  Endif
Endif
If !GIMPORT  Affzo [M]BPAPAY : Endif
End


Subprog C_BPAPAY(VALEUR)
#----------------------------------#
# Contrôle code adresse tiers payé #
#----------------------------------#
Variable Char    VALEUR()
Look [BPA] BPA0=1;[M]BPRPAY;VALEUR
If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : End : Endif
End


Subprog AM_DEP(VALEUR)
#----------------------#
# Après modif Escompte #
#----------------------#
Variable Char    VALEUR()
Call ALIDISVAT(VALEUR,"PTH2") From TRTACHELT1
End


Subprog C_WEU(VALEUR)
#----------------------------------------------------------#
# Contrôle unité de poids : Obligatoire si poids renseigné #
#----------------------------------------------------------#
Variable Char    VALEUR()
If [M]TOTGROWEI<>0 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End


Subprog C_VOU(VALEUR)
#------------------------------------------------------------#
# Contrôle unité de volume : Obligatoire si volume renseigné #
#------------------------------------------------------------#
Variable Char    VALEUR()
If [M]TOTVOL<>0 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=1 : End
Endif
End

######################################################################################
Subprog C_DPEDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If VALEUR > [M:PTH0]RCPDAT Then
      GMESSAGE = mess(474,194,1) - format$(GFMDAT, VALEUR) - ">" - format$(GFMDAT, [M:PTH0]RCPDAT)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog AM_DPEDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M]ARVDAT = [0/0/0] or ([M]ARVDAT <> [0/0/0] and (VALEUR > [M]ARVDAT or [M]DPEDAT = [M]ARVDAT)) Then
      [M]ARVDAT = VALEUR
      Affzo [M]ARVDAT
    Endif
  Endif
End

######################################################################################
Subprog C_ARVDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M]DPEDAT <> [0/0/0] and VALEUR < [M]DPEDAT Then
      GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M]DPEDAT) - ">" - format$(GFMDAT, VALEUR)
      mkstat = 2
      End
    Endif
  Endif
End

