#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################
#
#  Legal datas for legislation AUT for table COMPANY
#
# Window AWI=>CPYLEGAUT
# Mask/Screen AMK=>CPYLEGAUT [CLAUT]
#
############################################################


$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
Endcase
Return


$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
Local Char COD(max(GLONCPY,GLONVAT,5))
[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:CPY]) : Local File TABCPY [CPY] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif

#----- Masque local -----#
Local Mask CPYLEGAUT [CLAUT]

#----- Variables locales pour sauvegarde du masque -----#
Local Char		AUSFINSRV(10)
Local Integer	GERDEFVAL(0..8)
Local Char		GEREECNUM(20)(0..8)
Local Char		GERTAXCEN(GLONBPR)(0..8)
Local Char		GERTAXIDT(20)(0..8)
Local Integer	NBLIG
Return

$DEBUT
Raz [M]NBLIG
#--- Alimentation des champs de l'écran ---#
Read [CPY]CPY0 = [L]COD
If !fstat
 [M:CLAUT] = [F:CPY]
 For I=0 To dim([F:CPY]GERDEFVAL)-1
  If [M]GEREECNUM(I)<>"" | [M]GERTAXCEN(I)<>"" | [M]GERTAXIDT(I)<>""
   [M]NBLIG+=1
  Endif
 Next
Endif
#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:CLAUT]

Affzo [M:CLAUT]
Return

$AVANT_ENR
Local Integer VALDEF : VALDEF=0
For I=0 To [M]NBLIG-1
 If [M]GERDEFVAL(I)=2
  VALDEF=1 : Break
 Endif
Next
If !VALDEF
 #Une case au moins doit être cochée dans ce bloc !
 GMESSAGE=mess(359,199,1)
 FOK=0
 GERR=1
Endif
Return

$ENR
Trbegin [CPY]
Readlock [CPY]CPY0 = [L]COD
If !fstat
 [F:CPY]= [M:CLAUT]
 Rewrite [CPY]
 If fstat
  GOK = 0 : Call FSTA("CPY") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:CLAUT] : REP=""
Return

$ABA
[M:CLAUT]=[L] : REP=""
Gosub ENR
Affzo [M:CLAUT]
Return

$APRES_MODIF
Read [ALK]LCKCLE="CPY"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:CLAUT]=[L]
 Affzo [M:CLAUT] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="CPY"+[L]COD
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return

######################################################################################

Subprog C_NBLIG
If status=65
 If [M]GEREECNUM(nolign-1)=[F:CPY]EECNUM
  #EECNUM de la fiche société : Suppression impossible
  #mess(00034,00127,1) : No de TVA intracommunautaire
  #mess(00005,00117,1) : de la société
  GMESSAGE=mess(54,123,1)+"\"+"("+mess(34,127,1)-mess(5,117,1)+")"
  mkstat=2
 Endif
Endif
End


Subprog AS_GERDEFVAL(VALEUR)
Variable Integer VALEUR
If [M]GEREECNUM(nolign-1)=""
 mkstat=1
 zonsui=[M]GEREECNUM(nolign-1)
Endif
End

Subprog AM_GERDEFVAL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 For I=0 To [M]NBLIG-1
  If I<>(nolign-1)
   [M]GERDELVAL(I)=1
  Endif
 Next
 [M]GERDEFVAL(nolign-1)=2
 Affzo[M]
Endif
End

Subprog C_GEREECNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 #mess(10,123,1) : Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2
Else
 Call UNICITE(VALEUR,[M]GEREECNUM) From OBJDIV
Endif
End



######################################################################################
