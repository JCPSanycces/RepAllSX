#<AdxTL>@(#)7.0.0.0 $Revision$
# action TPTSIM (remplace le sous-pro SIMUL de SUBTPT)
# simule la répartition des paiements échelonnés (conditions de paiement)

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When Default
Endcase
Return

$OUVRE
If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
If clalev([F:TPT])=0 : Local File TABPAYTERM [TPT] : Endif
Return

$DEBUT
# taille du code GLONPTE au lieu de 15  (29/09/04)
Local Char    DEV(GLONCUR), PTECOD(GLONPTE), SOCIETE(GLONCPY)
Local Decimal MNT
Local Date    DAT
If GFONCTION="GESTPT"
   PTECOD = [M:TPT1]PTE
Else
   PTECOD = VALEUR
Endif
If PTECOD="" : PTECOD=[F:TPT]PTE : Endif
DEV = PARAM(1)
MNT = val(PARAM(2))
DAT = PARAM(3)
SOCIETE = PARAM(4)
If DEV = "" 
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 DEV = [F:CPY]ACCCUR 
Endif
Call LECTURE("TCU",DEV,"") From CONTOBJ
Case GACTION
 When "TPTSIM" :
  [M]SIMPTE = PTECOD
  If MNT=0 : MNT=1000 : Endif 
  [M]SIMTOT = MNT
  [M]DEVISE = DEV
  [M]SIMDAT = DAT
  Gosub TR2
Endcase
Return

$TR1
Case COUZON
 When "SIMTOT" : [M]SIMTOT = val(CZ)
 When "SIMDAT" : [M]SIMDAT = gdat$(val(mid$(CZ,1,2)),val(mid$(CZ,4,2)),val(mid$(CZ,7,4)))
Endcase
$TR2
Call SIMULECHE([M]SIMPTE,[M]SIMDAT,[M]SIMTOT,[F:TCU]CURRND,[M]SIMPAM,[M]SIMPAMTYP,
&                [M]SIMAMT,[M]SIMDUD,[M]SIMSOI,[M]BASTAB,[M]SIMRPLPTE,GFCYDEF(0))
&  From SUBTPT
Affzo [M]

[F:TPT]PTE = [M]SIMPTE
Return

########################################
Subprog AM_SIMTOT(VALEUR)
Variable Decimal VALEUR
[M]SIMTOT=VALEUR
Gosub TR2
End

########################################
Subprog AM_SIMDAT(VALEUR)
Variable Date    VALEUR
[M]SIMDAT=VALEUR
Gosub TR2
End

