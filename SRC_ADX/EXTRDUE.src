#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR([L]VALEUR,[L]PARAM,"","EXTRDUE","DEXTRDUE",4,"") From GTRAITE
End

$ACTION
Case [L]ACTION
 When "INIT"     : Goto OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Goto CONTROLE
 When "EXEC"     : Goto EXEC
 When "TERMINE"  : Goto TERMINE
 When "SORTIE"   : Gosub SORTIE
 When "BOUTON"   : Gosub BOUTON
Endcase
Return

################################################################################
#
# GTRAITE
#
################################################################################
$OUVRE
Local Integer STAT
Local Char    CRITERE(250), SYMBOLE(50)
Local Char    CRITERE2(250)
Local Char    CRITERE3(250)

If !clalev([F:ADI])   : Local File ATABDIV   [ADI]    : Endif
If !clalev([F:ID])    : Local File EMPLOID   [ID]     : Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR  [HRCTR]  : Endif
If !clalev([F:DUE])   : Local File DUEEMP    [DUE]    : Endif
If !clalev([F:HRPOA])  : Local File POPULA    [HRPOA]    : Endif
If !clalev([F:CPY])   : Local File COMPANY   [CPY]    : Endif
If !clalev([F:FCY])   : Local File FACILITY  [FCY]    : Endif
If !clalev([F:BPAF])  : Local File BPADDRESS [BPAF]   : Endif
If !clalev([F:BPAC])  : Local File BPADDRESS [BPAC]   : Endif
If !clalev([F:FEL])   : Local File FILEDIL   [FEL]    : Endif
If !clalev([F:FGR])   : Local File FACGROUP2 [FGR]    : Endif

Local Mask EXTRDUE
Raz [M:EDUE]
Call LECMEMO("STD","[M:EDUE]","due") From GMEMO
Call AFF_MEMO From DIVPAYE
Return

#-------------------------------------------------------------------------------
$SORTIE
Call DELOCK("DUE") From GLOCK
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#-------------------------------------------------------------------------------
$BOUTON
Case BOITE
When "DEXTRDUE", "DTRTDUE"
 Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Call AFF_MEMO From DIVPAYE
  Endcase
Endcase
Return


#-------------------------------------------------------------------------------
$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

If PARAM(1)<>""
 [M:EDUE]MATDEB = PARAM(1)
 [M:EDUE]MATFIN = PARAM(1)
 [M:EDUE]DATDEB = [0/0/0]
Endif
GCURLEG="FRA"
If dim([M:EDUE]LEG)>=0 : [M:EDUE]LEG=GCURLEG : Endif
Effzo [M:EDUE]DINI
Affzo [EDUE] : Setmok [EDUE] With 0
Call AFF_MEMO From DIVPAYE
Return

#-------------------------------------------------------------------------------
$CONTROLE
If [V]GSTATUT<>[V]GSTAOK : [L]FIN=1 : Return : Endif
[L]TMP=1
[L]TIT=mess(3,10721,1) : # Extraction en cours
If [V]GSERVEUR | 1 : [L]TRA=1 : Endif

Gosub OUVRE From WPDEFTABLE

If dim([M:EDUE]LEG)>=0 : GCURLEG=[M:EDUE]LEG : Endif :#because superviseur did GCURLEG = SAVCURLEG in GSAISIE

Raz [L]CRITERE, [L]CRITERE2
For [ADI] Where NUMTAB=10386 & N2=2
  If len([L]CRITERE)<210
    [L]CRITERE+=',"'+[F:ADI]CODE+'"'
  Else
    [L]CRITERE2+=',"'+[F:ADI]CODE+'"'
  Endif
Next

If instr(2,[L]CRITERE,",")
 # Plusieurs codes dans la table diverse
 [L]CRITERE='([ID]ENAFLG=2 & find(CTRGRD'+[L]CRITERE+')<>0)'
 If [L]CRITERE2=""
  [L]CRITERE2='[ID]FLGNEWSAL=2'
 Else
  [L]CRITERE2='([ID]ENAFLG=2 & find(CTRGRD'+[L]CRITERE2+')<>0) | [ID]FLGNEWSAL=2'
 Endif
Else
 [L]CRITERE='([ID]ENAFLG=2 & CTRGRD='+right$([L]CRITERE,2)+')'
 [L]CRITERE2='[ID]FLGNEWSAL=2'
Endif

[L]CRITERE3='[F:CPY]LEG="'+GCURLEG+'"'

If [M:EDUE]ALLFCY<>2      : [L]CRITERE3-='& ETRFCY="'+[M:EDUE]FCY+'"'           : Endif
If [M:EDUE]ALLSRV<>2      : [L]CRITERE3-='& ETRSRV="'+[M:EDUE]SRV+'"'           : Endif
If [M:EDUE]ALLPRF<>2      : [L]CRITERE3-='& PROPRF="'+[M:EDUE]PRF+'"'           : Endif
If [M:EDUE]MATDEB>""      : [L]CRITERE3-='& REFNUM>="'+[M:EDUE]MATDEB+'"'       : Endif
If [M:EDUE]MATFIN>""      : [L]CRITERE3-='& REFNUM<="'+[M:EDUE]MATFIN+'"'       : Endif
If [M:EDUE]DATDEB>[0/0/0] : [L]CRITERE3-='& CTRDAT>=['+num$([M:EDUE]DATDEB)+']' : Endif
If [M:EDUE]DATFIN>[0/0/0] : [L]CRITERE3-='& CTRDAT<=['+num$([M:EDUE]DATFIN)+']' : Endif
If [M:EDUE]FLGUPD<>2      : [L]CRITERE3-='& FLGDUE<2'                           : Endif
CRITERE3-= '& [HRCTR]FLGRET<>2'


If [M:EDUE]POP<>""
 If [M:EDUE]CPY<>""
  Link [HRCTR] With [ID]ID0   =REFNUM
&             , [HRPOA]POA0~=[M:EDUE]POP;REFNUM
&             , [FGR]FGR0~=[M:EDUE]CPY;ETRFCY
&             , [CPY]CPY0=[M:EDUE]CPY
&            As [CTRK]
&         Where (evalue([L]CRITERE) | evalue([L]CRITERE2)) & evalue([L]CRITERE3)
 Else
  Link [HRCTR] With [ID]ID0   =REFNUM
&             , [HRPOA]POA0~=[M:EDUE]POP;REFNUM
&             , [FCY]FCY0 = [F:HRCTR]ETRFCY
&             , [CPY]CPY0 = [F:FCY]LEGCPY
&            As [CTRK]
&         Where (evalue([L]CRITERE) | evalue([L]CRITERE2)) & evalue([L]CRITERE3)
 Endif
Else
 If [M:EDUE]CPY<>""
  Link [HRCTR] With [ID]ID0   =REFNUM
&             , [FGR]FGR0~=[M:EDUE]CPY;ETRFCY
&             , [CPY]CPY0=[M:EDUE]CPY
&            As [CTRK]
&         Where (evalue([L]CRITERE) | evalue([L]CRITERE2)) & evalue([L]CRITERE3)
 Else
  Link [HRCTR] With [ID]ID0   =REFNUM
&             , [FCY]FCY0 = [F:HRCTR]ETRFCY
&             , [CPY]CPY0 = [F:FCY]LEGCPY
&            As [CTRK]
&         Where (evalue([L]CRITERE) | evalue([L]CRITERE2)) & evalue([L]CRITERE3)
 Endif
Endif

Link [FCY] With [CPY]CPY0    =[FCY]LEGCPY
&             , [BPAF]BPA0(2)=3;[FCY]FCY
&             , [BPAC]BPA0(2)=2;[FCY]LEGCPY
&            As [FCYK]
&         Where [BPAF]CRY="FR" & [BPAC]CRY="FR" & [F:CPY]LEG=GCURLEG
&  Order By Key CLE=FCY;[BPAF]BPAADDFLG Desc;[BPAC]BPAADDFLG Desc
Return

#-------------------------------------------------------------------------------
$EXEC
If [L]TRA
 If ![V]GSERVEUR
  Call OUVRE_TRACE([L]TIT) From LECFIC
 Else
  Call ECR_TRACE([L]TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif

[L]OK=-1
For [CTRK]CTR0
 Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:EDUE]CRI,[L]STAT,0
&             ) From DIVPAYE
 # Un salarié provisoire n'est pas flagué ENAFLG
 If [L]STAT & [F:ID]ENAFLG<>2 & [F:ID]FLGNEWSAL<>2
  [L]STAT = 0
 Endif

 If [L]STAT
  [L]SYMBOLE="DUE"+[F:HRCTR]CTRNUM+"\"+[F:HRCTR]REFNUM+"\"+num$([F:HRCTR]CTRDAT)
  Lock =[L]SYMBOLE
  [L]OK=!fstat
  If fstat
   Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
   If [L]TRA
    Call ECR_TRACE([F:HRCTR]REFNUM-[F:HRCTR]CTRNUM-num$([F:HRCTR]CTRDAT)+"\"+[V]GMESSAGE,1) From GESECRAN
    [V]GMESSAGE=""
   Else
    Break
   Endif
  Endif
 Endif
Next

If [L]OK=-1
 [L]OK=0
 If [L]TRA
  Call ECR_TRACE(mess(4,10721,1) ,1) From GESECRAN : # Aucun salarié à déclarer
 Else
  [V]GMESSAGE=mess(4,10721,1) : # Aucun salarié à déclarer
 Endif
Endif
If ![L]OK : If ![L]TRA : [V]GERR=1 : [L]SAI=1 : Endif : Return : Endif

Call EXTRACTION([L]TRA)
Return

#-------------------------------------------------------------------------------
$TERMINE
If ![V]GSERVEUR & [L]TRA
 Call FERME_TRACE From LECFIC
Endif
If ![L]OK & [L]TRA : [L]SAI=1 : Endif
Return

################################################################################
#
# Routines
#
################################################################################

Subprog EXTRACTION(TRA)
Value Integer TRA

Local Integer STAT, NBERR
Local Char    MATRI([V]GLONEML), FEH([V]GLONADI), CTR([V]GLONHRCTR)
Local Date    DATMAT

[L]FEH="DUE"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
[L]EXTRACTION=1

Call DEBTRANS From GLOCK

$TR_EXTRACT
[V]GOK=1
Trbegin [DUE]
 Gosub EXTRACT
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : End : Else Goto TR_EXTRACT : Endif
 Elsif ![V]GOK
  Rollback
  End
 Endif
Commit

End

#-------------------------------------------------------------------------------
$EXTRACT
Local Char ETRFCYCTR(GLONFCY)
Filter [CTRK] Order By Key CLE=ETRFCY;CTRNUM;CTRDAT

For [CTRK]CLE(1)
 Read [FCYK]CLE(1)=[F:HRCTR]ETRFCY
 If !fstat
  For [CTRK]CLE
   Call CONTROLE( [F:HRCTR]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,[M:EDUE]CRI,[L]STAT,0
&               ) From DIVPAYE
   # Un salarié provisoire n'est pas flagué ENAFLG
   If [L]STAT & [F:ID]ENAFLG<>2 & [F:ID]FLGNEWSAL<>2
    [L]STAT = 0
   Endif
   If [L]STAT
     Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
     Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     If dim([F:CPY]LEG)>0 &  [F:CPY]LEG<>GCURLEG
      [L]STAT = 0
     Endif
   Endif

   If [L]STAT
    Readlock [DUE]DUE0=[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
    If fstat=1
     [V]GOK  =-1
     [V]GLOCK="$DUEEMP"-[F:HRCTR]REFNUM-[F:HRCTR]CTRNUM-num$([F:HRCTR]CTRDAT)
     Break 2
    Elsif fstat
     # Rien
    Elsif [F:DUE]STA<3
     [L]STAT=2
    Else
     [L]STAT=0
     Call ECR_TRACE("",0) From GESECRAN
     Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
     Call ECR_TRACE([F:HRCTR]REFNUM-[F:HRCTR]CTRNUM- format$([V]GFMD,[F:HRCTR]CTRDAT) -': DUE Validée',1) From GESECRAN
    Endif
   Endif

   If [L]STAT
    If [M:EDUE]CRI=""
     [L]MATRI =[F:HRCTR]REFNUM
     [L]DATMAT=[F:HRCTR]CTRDAT
     [L]CTR   =[F:HRCTR]CTRNUM
     Gosub LECEMP From WPDEFTABLE
    Endif
    Raz [F:DUE]
    Gosub RAZVAR From =[L]FEHTRT

    If [L]TRA
     Call ECR_TRACE("",0) From GESECRAN
     Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
     Call ECR_TRACE( [F:HRCTR]REFNUM-[F:ID]NAM-[F:ID]SRN-[F:HRCTR]CTRNUM
&                  - format$([V]GFMD,[F:HRCTR]CTRDAT)-format$("K:##[:]##",[F:HRCTR]ETRTIM),0
&                  ) From GESECRAN
    Endif

    Onerrgo ERREURWW
    Gosub EXTRACTION From =[L]FEHTRT
    [L]NBERR=0
    Gosub CONTROLE From =[L]FEHTRT
    Onerrgo

    Gosub MAJFIC From =[L]FEHTRT
    [F:DUE]STA=1+![L]NBERR
    If [F:DUE]REFNUM="" : [F:DUE]REFNUM=[F:HRCTR]REFNUM : Endif
    If [F:DUE]CTRNUM="" : [F:DUE]CTRNUM=[F:HRCTR]CTRNUM : Endif
    If [F:DUE]CTRDAT=[0/0/0] : [F:DUE]CTRDAT=[F:HRCTR]CTRDAT : Endif
    If [F:DUE]ETRFCY="" : [F:DUE]ETRFCY=[F:HRCTR]ETRFCY : Endif
    If [L]STAT=2 : Rewrite [DUE] Curr : Else Write [DUE] : Endif
    If fstat
     [V]GOK=0
     Call FSTA("DUE") From GLOCK
     Break 2
    Endif

    If [F:HRCTR]FLGDUE<2
     Readlock [HRCTR] Curr
     If fstat=1
      [V]GOK  =-1
      [V]GLOCK="$EMPLOCTR"
      Break 2
     Endif
     [F:HRCTR]FLGDUE=2
     Rewrite [HRCTR] Curr
     If fstat
      [V]GOK=0
      Call FSTA("HRCTR") From GLOCK
      Break 2
     Endif
    Endif
   Endif
  Next
 Endif
Next
Filter [CTRK]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
End
######################################################################################

