#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################
# SUBPOIA : Gestion des commandes d'achat par article     MBT 03/02/98 #
#           Modifié                                       HN Juil 2003 #
# -------------------------------------------------------------------- #
# Traitement des actions "Gosub" de l'objet "POI"                      #
# Les traitements sur champ "Call" se trouvent dans le SUBPOI          #
########################################################################

$ACTION
#--------------------------------------------------#
# Actions sur la saisie de fenêtre (GSAISIE)       #
# SAIPECB2   : Prise en compte des besoins d'achat #
#--------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE_FEN
 When "TITRE"       : Gosub TITRE_FEN
 When "DEBUT"       : Gosub DEBUT_FEN
 When "OK"          : Gosub OK_FEN
 When "ABA"         : Gosub ABA_FEN
 When "APRES_MODIF" : Gosub APRES_MODIF_FEN
 When "SETBOUT"     : Gosub SETBOUT_FEN
 When "FINSAI"      : Gosub FINSAI_FEN
Endcase
Return

#################################################################
# Actions sur la saisie de fenêtre (GSAISIE)                    #
# ------------------------------------------------------------- #
# SAIPECB2   : Prise en compte des besoins d'achat              #
#################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_FEN
Case GACTION
 When "SAIPECB2"   : Gosub OUV_SAIPECB2
Endcase
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenêtre #
#-------------------------------------------#
$TITRE_FEN
Case GACTION
 When "SAIPECB2"   : TIT=mess(42,195,1)
Endcase
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT_FEN
Case GACTION
 When "SAIPECB2"   : Gosub DEB_SAIPECB2
Endcase
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_FEN
Case GACTION
 When "SAIPECB2"   : Gosub OK_SAIPECB2
Endcase
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_FEN
Case GACTION
 When "SAIPECB2"   : Gosub ABA_SAIPECB2
Endcase
Return
#------------------------------------#
# Après chaque modification de champ #
#------------------------------------#
$APRES_MODIF_FEN
Case GACTION
 When "SAIPECB2"   : REP="M"
Endcase
Return
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
$SETBOUT_FEN
Case GACTION
 When "SAIPECB2"   : Gosub SETB_SAIPECB2
Endcase
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_FEN
Case GACTION
 When "SAIPECB2"   : Gosub FINSAI_SAIPECB2
Endcase
Return


$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
If !clalev([F:PTR])  Local File PURTRS [PTR] : Endif
If GFLAG<>""
  Read [PTR] PTR0=3;GFLAG
  If fstat | [F:PTR]ENAFLG=1 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:PTR]ACSCOD<>"" & GPROFIL<>GSUPER
    If !clalev([F:ACC])  Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:PTR]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1 Close Local File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [PTR] PTR0=3;VARCOD
If fstat | [F:PTR]ENAFLG=1 OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:PTR])=0  Local File PURTRS [PTR] : Endif
Read [PTR] PTR0=3;GFLAG : If fstat Raz [F:PTR] : Endif
# Issue 118480 - 2016-11-18 by SR : Faire après SAUV_GLOB sinon valeur sauvegardée incorrecte
#GPTRNUM=[F:PTR]PTRNUM
Return

$FILTRE
#------------------------------#
# Pas de filtre pour l'instant #
#------------------------------#
Default File [POI]
# FILTSUP=""
Return

$BOITE
#----------------------------------------------#
# Ouverture de la fenêtre sans liste de gauche #
#----------------------------------------------#
GNBGAUCHE=0
Return

$AV_IMPRIME
#------------------#
# Avant impression #
#------------------#
Return

$OUVRE
#----- Vérification si fonction appelable dans le contexte ! -----#
If clalev([M:POH0]) | clalev([M:POH1]) | clalev([M:POH2]) | clalev([M:POH3])
  GMESSAGE=mess(17,130,1) : # Fonction non appelable dans le contexte !
  GERR=1 : OK=0 : Return
Endif
#-----
Raz GSOC_ACTIVE
#---------------------------------------------------------------------#
# Dans EXEFNC si pas de site par défaut pour le module concerné       #
# GFCYDEF(0) = premier site de la table sites (modif Beinat 15/12/99) #
# FAUX, il faut toujours avoir GFCYDEF(0) = site par défaut du module #
# même si ce site par défaut est vide !                               #
#---------------------------------------------------------------------#
GFCYDEF(0)=GFCYDEF(6)
#----- Ouverture fichier BUDPAR si module Compta à Oui -----#
If GMODU(2)=2  : # Compta
  If !clalev([F:BUP])  Local File BUDPAR    [BUP] : Endif
Endif
#-----
If !clalev([F:GCM])  Local File GACM      [GCM] : Endif
#----- Sauvegarde de GNBGAUCHE -----#
Local Decimal SAV_GNBGAUCHE : SAV_GNBGAUCHE=GNBGAUCHE
#----- Sauvegarde variables globales -----#
# Issue 112754 - 2016-11-08 by SR
maxmem=max(int(maxmem/1024),45000)

Gosub SAUV_GLOB From TRTX3GLOB
# Issue 118480 - 2016-11-18 by SR : Faire après SAUV_GLOB
GPTRNUM=[F:PTR]PTRNUM
#-----------------------------------------------------#
# Contrôle existence de la structure tarif par défaut #
# et chargement des libellés colonnes par défaut      #
#-----------------------------------------------------#
Raz GRCPFCY, GPLISTC, GPUU, GPLIFLG, GCOEUOM
Local  Char     CODE(3)
Local  Integer  WRET
# Issue 112754 - 2016-11-15 by SR : : PEC sur bouton droit
Global Integer  GPECBOUT1  : GPECBOUT1 = 1
Call CTLSTRUCT(2,WRET) From TRTPRICE
If WRET<>0 OK=0 : Return : Endif
Call COLREM("C",2,"") From TRTPRICE : GPLISTC=""
Call TARIFCHGT(6)     From TRTPRICE
#-----------------------------------------------------------------#
# Récupération des paramètres achats                              #
# Chargement GPLIFLG : 0 et 1= pas de recalcul tarif ligne        #
#                      2=recalcul tarif ligne suite aux modif.    #
#-----------------------------------------------------------------#
GFCY=GFCYDEF(6)
Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
Gosub CHARG_PARAM
If !clalev([M:ORDK])  Local Mask ORDK [ORDK] : Endif : # Masque paramètres encours
If !clalev([M:SBCK])  Local Mask SBCK [SBCK] : Endif
If !clalev([M:SCOK])  Local Mask SCOK [SCOK] : Endif
GPLIFLG=0 : GORITITCOL=1
#----- Ouverture fichiers pour pec besoins contremarque et inter-sociétés -----#
If !clalev([F:BPC])    Local File BPCUSTOMER [BPC] : Endif
If !clalev([F:BPD])    Local File BPDLVCUST  [BPD] : Endif
If GMODU(5)=2 : # Si module Ventes présent
  If !clalev([F:ITS])  Local File ITMSALES   [ITS] : Endif
  If !clalev([F:MVC])  Local File BPCUSTMVT  [MVC] : Endif
  If !clalev([F:SOH])  Local File SORDER     [SOH] : Endif
  If !clalev([F:SOQ])  Local File SORDERQ    [SOQ] : Endif
  If !clalev([F:SOP])  Local File SORDERP    [SOP] : Endif
  Raz [F:SOH], [F:SOP] : # à cause de l'INISEC "POW" et "POID"
Endif
#----- Ouverture fichier des destinations pour choix imprimante -----#
If !clalev([F:AIM])    Local File APRINTER   [AIM] : Endif
#----- Ouverture fichiers ordre de fabrication -----#
If GMODU(8)=2 : # Si module GPAO présent
  Gosub OPEN_FILES_MFG From MFGLIB
Endif
#----- Ouverture fichiers ordre de sous-traitance -----#
Gosub OPEN_FILES_SCO From SCOLIB
Return

$SETBOUT
#-------------------------------#
# Activation menu "Transaction" #
#-------------------------------#
CHMEN+="F"
#--------------------------------------------------#
# Suppression des boutons  D duplication et # code #
#--------------------------------------------------#
Call VIREBOUT(CHAINE,"DH") From GOBJET
If [M:POI1]POHFCY="" Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Raz GFLAG
#----- Restitution de GNBGAUCHE à cause des tunnels -----#
GNBGAUCHE=SAV_GNBGAUCHE
Return

$AVANTBOUT
#-----------------------------------#
# Avant exécution des boutons       #
# --------------------------------- #
# F = Visu transaction de saisie    #
#-----------------------------------#
Local  Char     SAV_ZONCOU(GLONAVA)
If GREP<>"" SAV_ZONCOU=COUZON Else SAV_ZONCOU="" : Endif
Case BOUT
Endcase
Return

$EXEBOUT
#------------------------------------#
# Après exécution des boutons du bas #
#------------------------------------#
Case BOUT
Endcase
Return

$STATUT
#-------------------------------------------#
# Après exécution des boutons de la ToolBar #
# F = Visu transaction de saisie            #
#-------------------------------------------#
Case BOUT
Endcase
#VPO 14/03/11 72298 ajout test dim(SAV_ZONCOU)
If dim(SAV_ZONCOU)>0 & SAV_ZONCOU<>"" & !GIMPORT  SUIZON=SAV_ZONCOU : Endif
Return

$EXEACT
#---------------------------------------------------------#
# Après exécution de l'action TRTGENPOH sur bouton du bas #
# Empêcher la màj de l'objet après la génération des cdes #
#---------------------------------------------------------#
If [M:POI1]POHFCY<>"" & (BOUT="E" | BOUT="C") OK=0 : Return : Endif
Case BOUT
  When "E" : OK=0 : REP="" : GREP="" : # Bouton "Enregistrer"
  When "C" : OK=0 : REP="" : GREP="" : # Bouton "Créer"
Endcase
Return

$APRES_CHOI
#-------------#
# Après choix #
#-------------#
#-- Si fichier nouveau l'enregistrement ne doit pas exister pour cet opérateur --#
If REPONSE=GSTANEW
  Look [POI] POI0=GUSER;1
  If !fstat GMESSAGE=mess(22,100,1) : GERR=1 : REPONSE=GSTAFIR : Endif
Endif
Return

$RAZCRE
#------------------------------------------------------#
# Valeurs par défaut et initialisations avant création #
#------------------------------------------------------#
If GFCY<>GFCYDEF(6)
  GFCY=GFCYDEF(6)
  Call GETFCYDEF(GFCY,"[F:FCY]PURFLG=2") From TRTX3
  Gosub CHARG_PARAM
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#----- Ecran POI1 -----#
Actzo [POI1]1-99
[M:POI1]POHFCY=GFCY
If GNBAUZ=1 & GFCY<>""  Diszo [POI1]POHFCY : Endif
[M:POI1]USR   =GUSER
[M:POI1]ORDDAT=date$
If GPURGRUDIS=1 [M:POI1]TARGRP=1 Else [M:POI1]TARGRP=2 : Endif
#--------------------------------------------#
# Raz GPLIFLG : Recalcul tarif ligne         #
# Contrôle unicité sur opérateur en création #
#--------------------------------------------#
[M:POI1]PCLFLG=2 : # Appel automatique du picking des besoins la 1ère fois
GPLIFLG=0
[M:POI1]BUY=GUSER
Raz [M:POI1]POICOU : [M:POI1]PRONUM=adxuid(2)
Gosub EFFAC_PWRKORDERS : # Effacement fichier de travail
#-----
If dim([M:POI1]NBAXE)>0 & GHEADIE>1 : # Sections d'entête non saisissables
  [M:POI1]NBAXE=GNBDIE
  For nolign=1 To GNBDIE
    [M:POI1]DIE(nolign-1)=GDIE(nolign)
    Call INISEC([M:POI1]CCE(nolign-1),"POI",GDIE(nolign)) From SUBCDE
  Next nolign
Endif
#----- Lecture de la transaction si nécessaire -----#
If [F:PTR]PTRTYP<>3 | [F:PTR]PTRNUM<>GPTRNUM
  Read [PTR] PTR0=3;GPTRNUM : If fstat Raz [F:PTR] : Endif
Endif
#----- Initialisation des caractéristiques d'impression -----#
[M:POI1]PRTFLG=max([F:PTR]DOCFLG,1)
If [M:POI1]PRTFLG=1
  Diszo [POI1]DOCNAM, PRTCOD
Else
  [M:POI1]DOCNAM=[F:PTR]DOCNAM
  If [M:POI1]DOCNAM<>""
    Call AIMDEF([M:POI1]PRTCOD,[M:POI1]DOCNAM,GBIDC1,GBIDC2)  From IMPRIME
    Call CONTROLE("AIM","!A",[M:POI1]PRTCOD,"",mkstat) From CONTOBJ
    If mkstat
      [M:POI1]PRTCOD="" : Raz mkstat, GMESSAGE, GERR
    Else
      [M:POI1]PRTSRV=[F:AIM]PRTSRV
      [M:POI1]PRTNAM=[F:AIM]PRTNAM
      Affzo [POI1]PRTCOD
      If dim([M:POI1]ZPRTCOD)>0  Affzo [POI1]ZPRTCOD : Endif
      Affzo [POI1]PRTSRV, PRTNAM
      # sr 08.11 Demande 86824
      [M:POI1]PRTCOP=func TRTVENIMP.GET_NBRCPY_AIM([M:POI1]PRTCOD)
    Endif
  Endif
Endif
#-----

# 106430 - Purchase planning
[M:POI1]TCTRWEU = GSALDSPWEU
[M:POI1]TCTRVOU = GSALDSPVOU
[M:POI1]TOTCUR  = GLOCALDEV
Diszo [M:POI1]TCTRQTY

If GPURGRUDIS=3 Actzo [POI1]TARGRP Else Diszo [POI1]TARGRP : Endif
If !GIMPORT Affzo [POI1]5-19 : Endif
Return

$INICRE
#--------------------------------#
# Avant le Write de chaque ligne #
#--------------------------------#
Local Shortint NOL : NOL=nolign-1
[F:POI]NOLIG=nolign
If dim([M:POI1]TSICOD1(NOL))>0 [F:POI]TSICOD(0)=[M:POI1]TSICOD1(NOL) : Endif
If dim([M:POI1]TSICOD2(NOL))>0 [F:POI]TSICOD(1)=[M:POI1]TSICOD2(NOL) : Endif
If dim([M:POI1]TSICOD3(NOL))>0 [F:POI]TSICOD(2)=[M:POI1]TSICOD3(NOL) : Endif
If dim([M:POI1]TSICOD4(NOL))>0 [F:POI]TSICOD(3)=[M:POI1]TSICOD4(NOL) : Endif
If dim([M:POI1]TSICOD5(NOL))>0 [F:POI]TSICOD(4)=[M:POI1]TSICOD5(NOL) : Endif
[F:POI]VAT(0)=[M:POI1]VAT1(NOL)
[F:POI]VAT(1)=[M:POI1]VAT2(NOL)
[F:POI]VAT(2)=[M:POI1]VAT3(NOL)
#----- Ecriture des comptes et sections de la ligne de commande -----#
Call ENREG_ACCCCE(nolign-1,"[M:POI1]LINACC","[M:POI1]LINDSP","[M:POI1]CCE","POI",
&                 0,[F:POI]USR,[F:POI]NOLIG,0,"","C") From TRTX3CPT
If GOK<1  Return : Endif
Return

$APRES_CRE
#---------------------------------------------------#
# Après création : Choix génération des commandes ? #
#---------------------------------------------------#
Call GENERE_CDE([M:POI1]USR,3,[M:POI1]TARGRP) From TRTACHCDE1
GPLIFLG=0
Return

$LIENS
#------------------------------------------------#
# Après le chargement de chaque ligne du tableau #
#------------------------------------------------#
Local Shortint NOL : NOL=nolign-1
If dim([M:POI1]TSICOD1(NOL))>0 [M:POI1]TSICOD1(NOL)=[F:POI]TSICOD(0) : Endif
If dim([M:POI1]TSICOD2(NOL))>0 [M:POI1]TSICOD2(NOL)=[F:POI]TSICOD(1) : Endif
If dim([M:POI1]TSICOD3(NOL))>0 [M:POI1]TSICOD3(NOL)=[F:POI]TSICOD(2) : Endif
If dim([M:POI1]TSICOD4(NOL))>0 [M:POI1]TSICOD4(NOL)=[F:POI]TSICOD(3) : Endif
If dim([M:POI1]TSICOD5(NOL))>0 [M:POI1]TSICOD5(NOL)=[F:POI]TSICOD(4) : Endif
[M:POI1]VAT1(NOL)=[F:POI]VAT(0)
[M:POI1]VAT2(NOL)=[F:POI]VAT(1)
[M:POI1]VAT3(NOL)=[F:POI]VAT(2)
[M:POI1]UPDFLG(nolign-1)=0
[M:POI1]CREFLG(nolign-1)=nolign
[M:POI1]LINFLG(nolign-1)=1
#----- Chargement de l'indicateur de modification du coefficient -----#
Gosub CHARG_COEFLG From SUBPOI
#----- Chargement comptes et sections analytiques -----#
Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                "POI",0,[F:POI]USR,[F:POI]NOLIG,0,"") From TRTX3CPT
#----- Lecture article-fournisseur -----#
If [F:ITP]ITMREF<>[M:POI1]ITMREF(nolign-1) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(nolign-1)
   Read [ITP] ITP0=[M:POI1]ITMREF(nolign-1);[M:POI1]BPSNUM(nolign-1)
   If fstat  Raz [F:ITP] : Endif
Endif
If [F:ITP]ITMREF<>""
  Call CONVERT_QTY([F:ITP]PURMINQTY,[F:ITP]PUU,
&                  [M:POI1]PURMINQTY(nolign-1),[M:POI1]PUU(nolign-1)) From SUBPOI
Else
  [M:POI1]PURMINQTY(nolign-1)=0
Endif
#----- Calcul et chargement dans le masque des montants ligne -----#
Local Char    VAT(GLONVAT)(3)
Local Decimal WCLCAMT(1..7)
VAT(0)=[M:POI1]VAT1(NOL) : VAT(1)=[M:POI1]VAT2(NOL) : VAT(2)=[M:POI1]VAT3(NOL)
[M:POI1]LINAMT(NOL)=[M:POI1]NETPRI(NOL)*[M:POI1]QTYUOM(NOL)
Call ARRDEV([M:POI1]LINAMT(NOL),[M:POI1]CUR(NOL))    From TRTDIV
WCLCAMT(1)=[M:POI1]CLCAMT1(NOL)
WCLCAMT(2)=[M:POI1]CLCAMT2(NOL)
WCLCAMT(3)=[M:POI1]CLCAMT3(NOL)
Call CLCTAXEMNT2([M:POI1]LINAMT(NOL),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                [M:POI1]LINATIAMT(NOL)) From TRTX3
Call ARRDEV([M:POI1]LINATIAMT(NOL),[M:POI1]CUR(NOL)) From TRTDIV
Return

$LIENS2
#---------------------------------------#
# A la fin du chargement des lignes :   #
# Chargement GFCY : Site de la commande #
# Récupération des paramètres achats    #
#---------------------------------------#
If GFCY<>[F:POI]POHFCY GFCY=[F:POI]POHFCY : Gosub CHARG_PARAM : Endif
#----- Chargement des sections analytiques entête -----#
If dim([M:POI1]NBAXE)>0
  Call CHARG_CCEH("POI1","NBAXE","POI") From TRTX3CPT
Endif
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
#-----
If GPURGRUDIS=1 [M:POI1]TARGRP=1   Else [M:POI1]TARGRP=2   : Endif
If GPURGRUDIS=3 Actzo [POI1]TARGRP Else Diszo [POI1]TARGRP : Endif
Gosub EFFAC_BADLIN_PWRKORDERS : # Effacement lignes inexistantes
Return

$VERIF_CRE
#---------------------------#
# Vérifications en création #
#---------------------------#
Gosub VERIF
Return

$VERIF_MOD
#-------------------------------#
# Vérifications en modification #
#-------------------------------#
Gosub VERIF
Return

$VERIF
#----------------------------------------------------#
# Vérifications : Au moins une ligne,                #
#                 Fournisseur obligatoire, ...etc    #
#                 Recalcul tarif ligne si nécessaire #
#----------------------------------------------------#
OK=0 : Return : # Blocage car màj faite par l'action TRTGENPOH
Local Integer WOK
Local Shortint I, J, K
If [M:POI1]NBLIG=0
  GMESSAGE=mess(61,199,1) : GERR=1 : OK=0 : Goto RETOURNBLIG
Endif
For I=0 To [M:POI1]NBLIG-1
  If [M:POI1]BPSNUM(I)=""
    GMESSAGE=mess(131,194,1)-num$(I+1) : GERR=1
    OK=0 : Break
  Endif
  If [M:POI1]BETFCY(I)=2 & [M:POI1]LINSTOFCY(I)=""
    GMESSAGE=mess(311,194,1)-num$(I+1) : GERR=1
    OK=0 : Break
  Endif
  #----- Si inter-sites, contrôle que l'unité de commande convienne pour les ventes -----#
  If [M:POI1]BETFCY(I)=2 & [M:POI1]BPCORD(I)<>""
    Call CTLUOM([M:POI1]ITMREF(I),2,[M:POI1]BPCORD(I),[M:POI1]UOM(I),GBIDD2,
&               GBIDC2,GBIDC3,GBIDI2) From STKACT
    If mkstat
      Raz mkstat
      GMESSAGE=mess(18,197,1)-num$(I+1)-GMESSAGE
      GERR=1 : OK=0 : Break
    Endif
  Endif
  #-----
  If [M:POI1]QTYPUU(I)<[M:POI1]PURMINQTY(I)
    Raz J, GBIDD1
    While J<[M:POI1]NBLIG
      K=find([M:POI1]ITMREF(I),[M:POI1]ITMREF(J..[M:POI1]NBLIG-1))
      If K=0
        J=[M:POI1]NBLIG
      Else
        If [M:POI1]BPSNUM(J+(K-1))=[M:POI1]BPSNUM(I)
          GBIDD1+=[M:POI1]QTYPUU(J+(K-1))
        Endif
        J+=K
      Endif
    Wend
    #VPO 15/10/10 17730/59532 contrôle selon paramètre
    If GPOHMINQTY=0 : GPOHMINQTY=1 : Endif
    #If GBIDD1<[M:POI1]PURMINQTY(I)
    If GBIDD1<[M:POI1]PURMINQTY(I) & GPOHMINQTY<3
      GMESSAGE =mess(18,197,1)-num$(I+1)
      GMESSAGE-=mess(14,194,1)-format$("N:15F",[M:POI1]PURMINQTY(I))
      GMESSAGE-=[M:POI1]PUU(I)
      If GPOHMINQTY=1
          GERR=1 : OK=0 : Break
      Else : #GPOHMINQTY=2
          #pour ne pas afficher 2 fois le message si meme article
          If I=0 | find([M:POI1]ITMREF(I),[M:POI1]ITMREF(0..I-1))=0
              WOK=2
              Call AVERTIR (GMESSAGE, WOK)From GESECRAN
              If WOK=1
                  Raz GMESSAGE
                  GERR=1 : OK=0 : Break
              Endif
          Endif
          Raz GMESSAGE
      Endif
    Endif
  Endif
Next I
If OK=0 Goto RETOURNBLIG : Endif
Gosub RECALCUL_TARLIG
OK=2 : Call OUINON(mess(86,194,1),OK) From GESECRAN
If OK=1  OK=0 : Goto RETOURNBLIG : Endif
Return
#----- Retour à la saisie des lignes -----#
$RETOURNBLIG
OK=0
Return

$AVANT_MOD
#----------------------------------------------------------------------#
# Après l'appui sur le bouton "Modif"                                  #
# Effacement d'éventuelles lignes parasites dans le fichier de travail #
#----------------------------------------------------------------------#
GPLIFLG=0
Gosub EFFAC_BADLIN_PWRKORDERS : # Effacement lignes inexistantes
Return

$DEBUT_MOD
#-----------------------------------------------------------------------------#
# Début transaction de modification, avant Delete des anciens enregistrements #
#-----------------------------------------------------------------------------#
#----- Suppression comptes et sections de toutes les lignes -----#
Delete [CAL] Where ABRFIC="POI" & VCRNUM=[M:POI1]USR
If fstat=1
  GOK=-1 : GLOCK="$CPTANALIN POI 0"-[M:POI1]USR : Return
Endif
#-----
Return

$APRES_MOD
#-------------------------------------------------------#
# Après modification : Choix génération des commandes ? #
#-------------------------------------------------------#
Call GENERE_CDE([M:POI1]USR,3,[M:POI1]TARGRP) From TRTACHCDE1
GPLIFLG=0
Return

$ANNULE
#----------------------------------------------------------------------#
# Annulation totale des lignes de commande existantes pour l'opérateur #
#----------------------------------------------------------------------#
Delete [PWO] Where PRONUM=[M:POI1]PRONUM & CODFNC="POI"
If fstat=1  GOK=-1 : GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"
Elsif fstat GOK=0  : Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI") From GLOCK
Endif
Return

$ABANDON
#-------------------------------------------------#
# Abandon création/modification par l'utilisateur #
#-------------------------------------------------#
Local Shortint SAVGOK : SAVGOK=GOK
If REP="C" Gosub EFFAC_PWRKORDERS        : # Effacement fichier de travail
      Else Gosub EFFAC_BADLIN_PWRKORDERS : # Effacement lignes inexistantes
Endif
GOK=SAVGOK
GPLIFLG=0
Actzo [POI1]POHFCY, BUY
Return

$FERME
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Call IMPSCR From ATRTX3
#-----
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESPOI"
  Raz GFONC1, GORITITCOL
Endif
If dim(GPECBOUT1)>0        Kill GPECBOUT1 : Endif
#----- Restitution de GNBGAUCHE -----#
GNBGAUCHE=SAV_GNBGAUCHE
Return

$CHARG_PARAM
#----------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = site de la commande            #
# -------------------------------------------------------------------- #
# Chargement GSOCIETE   : Société juridique                            #
#            GLOCALDEV  : Devise société juridique                     #
#            GFINRSP    : Site financier                               #
#            GRCPFCY    : Site réception par défaut                    #
# Récupération des paramètres achats                                   #
#----------------------------------------------------------------------#
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"PTR",3,GPTRNUM) From TRTX3CPT
If GFINRSP="" GFINRSP=GFCY : Endif
Call DEFRCPFCY(GFCY)  From TRTACHDEF1
Call GLOBVAR(GFCY)    From WWGLOBACH
If GMODU(5)=2 : # Si module Ventes actif
  Call PARAM (GFCY,"DIRORDCTL",GBIDC3) From ADOVAL  : GDIRORDCTL=val(GBIDC3)
Endif
If GMODU(2)=2 : # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
Endif
# Issue 71069 - 2015-12-24 by MUARN : PJT
GPJTSNGDOC = func TRTPJT.GET_PARAM_PJTSNGDOC(GFCY)
Return

$RECALCUL_TARLIG
#---------------------------------------------------------#
# Recalcul tarif ligne : prix, remises et dates livraison #
#---------------------------------------------------------#
If GPLIFLG<>2 GPLIFLG=0 : Return : Endif
Local Char     VAT(GLONVAT)(3)
Local Decimal  WCLCAMT(1..7)
Local Date     OLDRCPDAT
Local Decimal  OLDNETPRI
Local Shortint I
For I=0 To [M:POI1]NBLIG-1
  OLDRCPDAT=[M:POI1]RETRCPDAT(I) : OLDNETPRI=[M:POI1]NETPRI(I)
  If RETQTYSTU(I)=0 & [M:POI1]LINTYP(I)<2
    If [F:ITM]ITMREF<>[M:POI1]ITMREF(I)
      Read [ITM] ITM0=[M:POI1]ITMREF(I) : If fstat Raz [F:ITM] : Endif
    Endif
    If [F:ITF]ITMREF<>[M:POI1]ITMREF(I) | [F:ITF]STOFCY<>GFCY
      Read [ITF] ITF0=[M:POI1]ITMREF(I);GFCY
      If fstat Raz [F:ITF] : [F:ITF]OFS=[F:ITM]OFS : Endif
    Endif
    [M:POI1]RETRCPDAT(I)=[M:POI1]ORDDAT+[F:ITF]OFS
  Endif
  #----- Pas de prix sur une ligne d'article sous-traité -----#
  If [M:POI1]LINTYP(I)<>2
    #----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
    If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(I)
      Read [BPS] BPS0=[M:POI1]BPSNUM(I) : If fstat Raz [F:BPS] : Endif
    Endif
    #----- Chargement paramètres et libellés colonnes tarif -----#
    If GPLISTC<>[F:BPS]PLISTC
      GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
      Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Endif
    #-----
    [M:POI1]LINFLG(I)=0 : GPUU=[M:POI1]PUU(I) : Call RECH_TARIF("POI",I) From TRTACHTAR1
    If OLDRCPDAT<>[M:POI1]RETRCPDAT(I) | OLDNETPRI<>[M:POI1]NETPRI(I)
      If RETQTYSTU(I)=0 [M:POI1]EXTRCPDAT(I)=RETRCPDAT(I) : Endif
      VAT(0)=VAT1(I) : VAT(1)=VAT2(I) : VAT(2)=VAT3(I)
      [M:POI1]LINAMT(I)=[M:POI1]NETPRI(I)*[M:POI1]QTYUOM(I)
      Call ARRDEV([M:POI1]LINAMT(I),[M:POI1]CUR(I)) From TRTDIV
      WCLCAMT(1)=[M:POI1]CLCAMT1(I)
      WCLCAMT(2)=[M:POI1]CLCAMT2(I)
      WCLCAMT(3)=[M:POI1]CLCAMT3(I)
      Call CLCTAXEMNT2([M:POI1]LINAMT(I),VAT,1,GSOCIETE,[M:POI1]ORDDAT,WCLCAMT,
&                      [M:POI1]LINATIAMT(I)) From TRTX3
      Call ARRDEV([M:POI1]LINATIAMT(I),[M:POI1]CUR(I)) From TRTDIV
    Endif
  Endif
  #-----
  If [M:POI1]CREFLG(I)<>0 [M:POI1]UPDFLG(I)=1 : Endif
Next I
GPLIFLG=0 : If !GIMPORT Affzo [POI1]1-99 : Endif
Return

$EFFAC_PWRKORDERS
#--------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte" #
#--------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=[M:POI1]PRONUM & CODFNC="POI"
  If fstat=1  GOK=-1 : OK=0 : GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"
              Goto ROLL_PWO
  Elsif fstat GOK=0  : OK=0 : Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI") From GLOCK
              Goto AB_PWO
  Endif
Commit
Return
$AB_PWO
Rollback : Return
$ROLL_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_PWO : Endif : Return

EFFAC_LIG_PWRKORDERS
#--------------------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte" d'une ligne #
#--------------------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_LIG_PWO
GOK=1
Trbegin [PWO]
  Delete [PWO] Where PRONUM=[M:POI1]PRONUM
&                  & CODFNC="POI"
&                  & LINNUM=[M:POI1]POILIN(nolign-1)
  If fstat=1
    GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(nolign-1))
    GOK=-1 : Goto ROLL_LIG_PWO
  Elsif fstat
    Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI"-num$([M:POI1]POILIN(nolign-1))) From GLOCK
    GOK=0  : Goto AB_LIG_PWO
  Endif
Commit
Return
$AB_LIG_PWO
Rollback : Return
$ROLL_LIG_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_LIG_PWO : Endif : Return

EFFAC_BADLIN_PWRKORDERS
#---------------------------------------------------------#
# Effacement fichier de travail "Besoins pris en compte"  #
# de lignes mauvaises (n'ayant plus d'existence physique) #
#---------------------------------------------------------#
Call DEBTRANS From GLOCK
$TR_BADLIN_PWO
GOK=1
Trbegin [PWO]
  For [PWO] PWO0 Where PRONUM=[M:POI1]PRONUM & CODFNC="POI"
    Look [POI] POI1=[M:POI1]USR;[F:PWO]LINNUM
    If fstat
      Delete [PWO] Curr
      If fstat=1
        GLOCK="$PWRKORDERS"-num$([M:POI1]PRONUM)-"POI"-num$([F:PWO]LINNUM)
        GOK=-1 : Break
      Elsif fstat
        Call RSTA("PWO",num$([M:POI1]PRONUM)-"POI"-num$([F:PWO]LINNUM)) From GLOCK
        GOK=0  : Break
      Endif
    Endif
  Next
  If GOK=-1 Goto ROLL_BADLIN_PWO : Endif
  If GOK=0  Goto AB_BADLIN_PWO   : Endif
Commit
Return
$AB_BADLIN_PWO
Rollback : Return
$ROLL_BADLIN_PWO
Rollback : Call ROLL From GLOCK : If !GROLL Goto TR_BADLIN_PWO : Endif : Return



#############################################################################
# PICKING : S/P de prise en compte des besoins d'achat                      #
#   NUMPRO   : Numéro de process                                            #
#   REFART   : Référence de l'article (***** = Appel depuis NBLIG)          #
#   ACHETEUR : Code de l'acheteur                                           #
#   CODE     : Code traitement  1 = Prise en compte des "POS"               #
#                               2 = Prise en compte des "POP"               #
#                               3 = Prise en compte des "POS" & "POP"       #
#                               6 = Prise en compte des  DA                 #
# ------------------------------------------------------------------------- #
# Remplacé par l'action SAIPECB2 avec paramètres :             MBT 13/12/00 #
#   PARAM(1) = NUMPRO : Numéro de process                                   #
#   PARAM(2) = CODFNC : Code fonction ("POI")                               #
#   PARAM(3) = ITMREF : Référence de l'article (***** = Appel depuis NBLIG) #
#   PARAM(4) = BUY    : Code de l'acheteur                                  #
#   PARAM(5) = TRAIT  : Code traitement (idem ci-dessus)                    #
#   PARAM(6) = WITMKND : Type d'article                                     #
#############################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUV_SAIPECB2
Local Integer  NUMPRO            : NUMPRO=val(PARAM(1))
Local Char     FONCTION(3)       : FONCTION=PARAM(2)
Local Char     REFART  (GLONITM) : REFART=PARAM(3)
Local Char     ACHETEUR(GLONAUS) : ACHETEUR=PARAM(4)
Local Integer  CODE              : CODE=val(PARAM(5))
# Issue 112754 - 2016-10-19 by MUARN : SERVICE
Local Integer  WITMKND           : WITMKND=val(PARAM(6))
# Issue 112754 - 2016-09-27 by SR :Services
Local Char     FONCTIONB(3)  : FONCTIONB = FONCTION
#----- Variables locales -----#
Local Char     CCELIG(200),  CCEPSD(200),  SECTION(GLONCCE)
Local Char     WITMDES(GLONDES),  WITMDES1(GLONDES), WPJT(20), WVCRNUM(GLONVCR)
Local Libelle  WLINPURTYP
Local Char     WLINTEX(GLONTXC),  WLINTEXPSD(GLONTXC)
Local Char     WVACBPR(3),   VAT(GLONVAT)(3)
Local Decimal  QTE2, MT1, MT2, DISCRGVAL(0..8)
Local Integer  OK, STAT
Local Shortint I, J, NBRGR, ORIAPPEL
Local Shortint SAVNOLIGN, SAVNBLIG, NOL : NOL=nolign-1
Local Char     WPOHFCY(GLONFCY) : WPOHFCY=[M:POI1]POHFCY
Local Char     WBPSNUM(GLONBPS)
Local Libelle  WORI : WORI=3
# Issue X3-55891 - 2018-08-21 by SR : Données déclinées par site
Local Integer WITMBPS, WRETOUR
#----- Sauvegarde de nolign et NBLIG -----#
SAVNOLIGN=nolign : SAVNBLIG=[M:POI1]NBLIG
# Issue 112754 - 2016-11-15 by SR :  PEC sur plan de l'acheteur selon flag
If ([F:PTR]PICRETFLG = 1 & GPECBOUT1 = 1) & WITMKND <> 2
  FIN = 1
  Return
Endif
#-----
If REFART="*****" ORIAPPEL=1 : REFART="" Else ORIAPPEL=0 : Endif
# Issue 112754 - 2016-10-19 by MUARN : Services
# FONCTION = "POI" : appel de l'action depuis  ITMREF et NBLIG
# FONCTION = "PO1" : appel de l'action depuis  ITMKND
# Depuis l'article, Pas d'ouverture si sous-traitance ou service et type d'article saisissable
If FONCTION = "POI"
   If varmode([M:POI1]ITMKND)=0  &  WITMKND > 1  & GPECBOUT1 <> 2  : FIN = 1 : Return
   Endif
Endif
## Depuis le type d'article, Pas d'ouverture  si type = "Standard"
If FONCTION = "PO1" & WITMKND =1 : FIN = 1 : Return : Endif
## On remet "POI" dans FONCTION pour suite du traitement
If FONCTION = "PO1" : FONCTION = "POI" : Endif
# End issue 112754
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIPECB2
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
# Issue 85565 & 84500 GA 10/2012 AML=588 PEC des EOx ou(exclusif) SCx
If [F:ITM]SCPFLG=2 [M:PPI2]SCOFLG=1 Else  [M:PPI2]SCOFLG=2 Endif
Affzo [M:PPI2]SCOFLG
#----- Lecture du premier article-fournisseur -----#
# Issue X3-55891 - 2018-08-21 by SR : données déclinées par site
#Filter [ITP] Where ITMREF=REFART & DOUFLG<3
#Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
#Filter [F:ITP]
Filter [ITPF] Where ITMREF=REFART & DOUFLG<3
Read [ITPF] ITPF1 First
If fstat
  Raz [F:ITPF]
  Filter [ITP] Where ITMREF=REFART & DOUFLG<3
  Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
Else
  Read [F:ITP]ITP0 = [F:ITPF]ITMREF;[F:ITPF]BPSNUM
  If fstat : Raz [F:ITP]: Endif
Endif
Filter [ITPF]
Filter [ITP]
# End issue X3-55891
#----- Chargement des zones dans le masque -----#
Raz [M:PPI2]
[M:PPI2]WPRONUM = NUMPRO
[M:PPI2]WCODFNC = FONCTION
[M:PPI2]WITMREF = REFART
If REFART<>"" Call AM_WITMREF(REFART) From SUBPPI2 Endif # Issue 85565 GA 10/2012
# Issue 10622 - 2012-07-02 by MUARN : borne article fin
[M:PPI2]WITMREFEND = REFART
# Issue 112754 - 2016-10-21 by MUARN : SERVICE
[M:PPI2]ITMKND  = WITMKND
[M:PPI2]ORDBUY  = ACHETEUR
[M:PPI2]CODE    = CODE
[M:PPI2]CHXDAT  = 2
[M:PPI2]CTMFLG  = 1

# 106430 - Purchase planning, display product UOM
[M:PPI2]WEU    = [M:POI1]TCTRWEU
[M:PPI2]VOU    = [M:POI1]TCTRVOU

#----- Affichage foreground -----#
Affzo [PPI2]
If GMODU(5)<>2
  Grizo [PPI2]CTMFLG
Endif
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIPECB2
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
If !clalev([F:PWO0])   Local File PWRKORDERS   [PWO0] : Endif
#----- Validation de la prise en compte -----#
If [M:PPI2]TOTQTY=0  FIN=1 : Return : Endif
#----- Chargement des fournisseurs non renseignés et contrôle si valides -----#
Raz [F:ITM]
For I=0 To [M:PPI2]NBLIG-1
  If [M:PPI2]PICQTY(I)<>0
    If [M:PPI2]BPRNUM(I)=""
      #----- Lecture article et article-fournisseur si nécessaire -----#
      If [F:ITM]ITMREF<>[M:PPI2]ITMREF(I)
        Read [ITM] ITM0=[M:PPI2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
        # Issue X3-55891 - 2018-08-21 by SR : Déclinaison des données par site
#        Filter [ITP] Where ITMREF=[M:PPI2]ITMREF(I) & DOUFLG<3
#        Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
#        Filter [ITP]
       Endif
       Raz WITMBPS,WBPSNUM
       # contremarque déjà fait
       If [M:PPI2]WIPTYP(I) <> 1
          Call DEFBPSNUM([M:PPI2]ITMREF(I),[M:POI1]POHFCY,[M:PPI2]STOFCY(I),"",1,WBPSNUM,WITMBPS) From TRTACHDEF1
          If [F:ITP]BPSNUM<>"" & WITMBPS <> 0
            [M:PPI2]BPRNUM(I)=[F:ITP]BPSNUM
          Endif
       Endif
    Else
      Call BPSNUM_DOUBTFUL_LEVEL(1,[M:PPI2]ITMREF(I),[M:PPI2]BPRNUM(I),[M:PPI2]STOFCY(I),WITMBPS,WRETOUR) From TRTACHCTL1
      If WRETOUR <> 0 : Raz [M:PPI2]BPRNUM(I) : Endif
    Endif
    # End issue X3-55891
    #----- Lecture fournisseur si nécessaire -----#
    If [F:BPS]BPSNUM<>[M:PPI2]BPRNUM(I)
      Read [BPS] BPS0=[M:PPI2]BPRNUM(I) : If fstat  Raz [F:BPS] : Endif
    Endif
    # déjà fait dans le composant
#    #----- Effacement du fournisseur si non actif ou prospect -----#
#    If [F:BPS]ENAFLG<>2 | [F:BPS]BPSTYP=2
#      Raz [M:PPI2]BPRNUM(I)
#      #----- Recherche d'un autre fournisseur actif et non prospect -----#
#      Filter [ITP] Where ITMREF=[M:PPI2]ITMREF(I) & DOUFLG<3
#      For [ITP] ITP1
#        If [F:BPS]BPSNUM<>[F:ITP]BPSNUM
#          Read [BPS] BPS0=[F:ITP]BPSNUM : If fstat  Raz [F:BPS] : Endif
#        Endif
#        If [F:BPS]ENAFLG=2 & [F:BPS]BPSTYP<>2
#          [M:PPI2]BPRNUM(I)=[F:ITP]BPSNUM : Break
#        Endif
#      Next
#      Filter [ITP]
#    Endif
  # Issue X3-55891 - 2018-09-20 by SR :
  Else
     Raz [F:ITP]
  Endif
Next I
#----------------------------------------------------------------------#
# Point d'entrée ECLBESOINS pour modifier la gestion des regroupements #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée :                        #
# La classe [M:PPI2]                                                   #
# FOURN     : Numéro du fournisseur  (non utilisé)                     #
# REFART    : Référence de l'article (facultative)                     #
# WSRTFLG   : Indicateur de tri (0=Tri à faire,  1=Tri effectué)       #
# TRAIT     : Code traitement                                          #
#             1 = Prise en compte besoins depuis commandes classiques  #
#             2 = Prise en compte besoins depuis plan de l'acheteur    #
#             3 = Prise en compte besoins depuis les plans d'appro     #
# -------------------------------------------------------------------- #
# Variable modifiable par le point d'entrée :                          #
# ECLAT_PSH : Eclatement par demandes d'achat     (1=Non / 2=Oui)      #
# ECLAT_DAT : Eclatement par dates de besoin      (1=Non / 2=Oui)      #
# ECLAT_PJT : Eclatement par codes affaire        (1=Non / 2=Oui)      #
# ECLAT_LPT : Eclatement par type d'achat         (1=Non / 2=Oui)      #
# ECLAT_CCE : Eclatement par sections analytiques (1=Non / 2=Oui)      #
# ECLAT_DES : Eclatement par désignation article  (1=Non / 2-4=Oui)    #
#               2 = Oui, avec désignation traduite ITMDES              #
#               3 = Oui, avec désignation standard ITMDES1             #
#               4 = Oui, avec code texte ligne LINTEX                  #
#----------------------------------------------------------------------#
Local Char    FOURN(GLONBPS)
Local Libelle WSRTFLG   : WSRTFLG=0
Local Libelle TRAIT     : TRAIT=2
Local Libelle ECLAT_PSH : ECLAT_PSH=1
Local Libelle ECLAT_DAT : ECLAT_DAT=1
Local Libelle ECLAT_PJT : ECLAT_PJT=2
Local Libelle ECLAT_LPT : ECLAT_LPT=2
Local Libelle ECLAT_CCE : ECLAT_CCE=2
Local Libelle ECLAT_DES : ECLAT_DES=2
Gosub POINT_ECLBESOINS From TRTACHCDE1
#VPO 25/01/11 70999 un art ss-traité peut aussi être acheté via POS (cas 92,93,98,96)
# il faut mettre les lignes normales à la fin donc ajout tri sur WIPTYP desc
If !WSRTFLG
  If ECLAT_DAT>1
    If ECLAT_PSH>1 | (ECLAT_CCE>1 & ECLAT_PJT<2)
      #---- Tri du tableau picking par article, fourniss, site, date, no DA et affaire ----#
      Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                                [M:PPI2]ITMREF(indice),
&                                                [M:PPI2]BPRNUM(indice),
&                                                [M:PPI2]STOFCY(indice),
&                                                [M:PPI2]SOHNUM(indice),
&                                                [M:PPI2]ENDDAT(indice),
&                                                [M:PPI2]VCRNUM(indice),
&                                                [M:PPI2]WPJT(indice),
&                                                [M:PPI2]VCRLIN(indice)
    Else
      #---- Tri du tableau picking par article, fournisseur, site, date et affaire ----#
      Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                                [M:PPI2]ITMREF(indice),
&                                                [M:PPI2]BPRNUM(indice),
&                                                [M:PPI2]STOFCY(indice),
&                                                [M:PPI2]SOHNUM(indice),
&                                                [M:PPI2]ENDDAT(indice),
&                                                [M:PPI2]WPJT(indice),
&                                                [M:PPI2]VCRNUM(indice),
&                                                [M:PPI2]VCRLIN(indice)
    Endif
  Elsif ECLAT_PSH>1
    #----- Tri du tableau de picking par article, fourniss, site, no DA et affaire -----#
    Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                              [M:PPI2]ITMREF(indice),
&                                              [M:PPI2]BPRNUM(indice),
&                                              [M:PPI2]STOFCY(indice),
&                                              [M:PPI2]SOHNUM(indice),
&                                              [M:PPI2]VCRNUM(indice),
&                                              [M:PPI2]WPJT(indice),
&                                              [M:PPI2]VCRLIN(indice)
  Elsif ECLAT_PJT>1 & ECLAT_CCE<2
    #----- Tri du tableau de picking par article, fourniss, site et affaire -----#
    Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                              [M:PPI2]ITMREF(indice),
&                                              [M:PPI2]BPRNUM(indice),
&                                              [M:PPI2]STOFCY(indice),
&                                              [M:PPI2]SOHNUM(indice),
&                                              [M:PPI2]WPJT(indice),
&                                              [M:PPI2]VCRNUM(indice),
&                                              [M:PPI2]VCRLIN(indice)
  Elsif ECLAT_CCE>1 & ECLAT_PJT<2
    #----- Tri du tableau de picking par article, fourniss, site et no DA -----#
    Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                              [M:PPI2]ITMREF(indice),
&                                              [M:PPI2]BPRNUM(indice),
&                                              [M:PPI2]STOFCY(indice),
&                                              [M:PPI2]SOHNUM(indice),
&                                              [M:PPI2]VCRNUM(indice),
&                                              [M:PPI2]VCRLIN(indice)
  Elsif ECLAT_PJT<2
    #----- Tri du tableau picking par article, fourniss et site -----#
    Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                              [M:PPI2]ITMREF(indice),
&                                              [M:PPI2]BPRNUM(indice),
&                                              [M:PPI2]STOFCY(indice),
&                                              [M:PPI2]SOHNUM(indice),
&                                              [M:PPI2]ENDDAT(indice),
&                                              [M:PPI2]VCRNUM(indice),
&                                              [M:PPI2]VCRLIN(indice)
  Else
    #----- Tri du tableau picking par article, fourniss, site et affaire -----#
    Sorta [M:PPI2]NBLIG [M:PPI2]NBLIG Order By [M:PPI2]WIPTYP(indice) *(-1),
&                                              [M:PPI2]ITMREF(indice),
&                                              [M:PPI2]BPRNUM(indice),
&                                              [M:PPI2]STOFCY(indice),
&                                              [M:PPI2]SOHNUM(indice),
&                                              [M:PPI2]WPJT(indice),
&                                              [M:PPI2]VCRNUM(indice),
&                                              [M:PPI2]VCRLIN(indice)
  Endif
Endif
#----- Exploitation du picking avec regroupement éventuel -----#
Default Mask [POI1]
Raz [F:ITM], [F:ITP]
Call TEMPON ("O") From GESECRAN
Call DEBTRANS From GLOCK
Trbegin [PWO]
  If ORIAPPEL=1
    NOL=[M:POI1]NBLIG
  Endif
  Raz [M:POI1]PRHFCY(NOL),[M:POI1]FCYADD(NOL), [M:POI1]QTYSTU(NOL), [F:PWO]
  [M:POI1]RETRCPDAT(NOL)=GHIDATE
  nolign=NOL+1 : Call LINNUM("SRTLIN") From TABLEAUX
  [M:POI1]POICOU+=1 : [M:POI1]POILIN(NOL)=[M:POI1]POICOU
  [F:PWO]PRONUM = [M:POI1]PRONUM
  [F:PWO]CODFNC = "POI"
  [F:PWO]LINNUM = [M:POI1]POILIN(NOL)
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO0]=[F:PWO]
  For I=0 To [M:PPI2]NBLIG-1
      If [M:PPI2]PICQTY(I)<>0 Gosub CHARG_LIG_CDE : Endif
      If GOK=0 | mkstat Break : Endif
  Next I
  If GOK=0 | mkstat Goto AB_PICKING : Endif
  Gosub FIN_CHARG_LIG_CDE                    : If GOK=0 | mkstat Goto AB_PICKING : Endif
  Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1 : If GOK=0 | mkstat Goto AB_PICKING : Endif
  If NOL+1>SAVNOLIGN & ORIAPPEL<>1 mkstat=99
                Else [M:POI1]CTLPOICOU=[M:POI1]POILIN(NOL) : Endif
Commit
Call TEMPOFF From GESECRAN
FIN=1
Return
#----- Abandon transaction en cas d'erreur d'écriture sur [F:PWO] -----#
$AB_PICKING
If GOK=0  Call FSTA("PWO") From GLOCK : Endif
Rollback : mkstat=1
Call TEMPOFF From GESECRAN
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIPECB2
Gosub DEB_SAIPECB2
Raz REP
Return
#-------------------------------#
# Grisage/dégrisage des boutons #
#-------------------------------#
$SETB_SAIPECB2
If [M:PPI2]TOTQTY=0
  ETABOU(GVALI)=0 : # Désactivation OK
Else
  ETABOU(GVALI)=1 : # Activation OK
Endif
If [M:PPI2]NBLIG=0
  ETABOU(GSPE1)=0 : ETABOU(GSPE2)=0 : # Désactivation Inclure / Exclure
Else
  ETABOU(GSPE1)=1 : ETABOU(GSPE2)=1 : # Activation    Inclure / Exclure
Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPECB2
nolign=SAVNOLIGN
# si Art. service et type d'article saisissable et ouverture automatique depuis article  : on part
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITM]SCSFLG=2 & varmode([M:POI1]ITMKND,NOL) = 0 & FONCTIONB = "POI" & GPECBOUT1 <> 2 : Return : Endif
# Issue 112754 - 2016-11-15 by SR
GPECBOUT1 = 1
If ORIAPPEL<>1
  PARAM(3)=[M:POI1]ITMREF(nolign-1)
  [M:POI1]NBLIG=SAVNBLIG
  If mkstat=1              Return : Endif
  If mkstat=99  GMODIF=1 : Return : Endif
  #-----
  # Issue 82533 GA 06/2012 selon MUARN dans SUBPOHB
  #If [F:ITM]PURFLG<>2
    #----- Des besoins doivent être pris en cpte pour un article sous-traitance -----#
    # Issue 112754 - 2016-10-20 by MUARN : services
    If [F:ITM]SCSFLG=2 & [M:POI1]RETQTYSTU(nolign-1)=0 & [M:POI1]ITMKND(NOL)=2
      If mkstat=98 GMESSAGE=mess(126,194,1) : GERR=1
              # Issue 112754 - 2016-10-03 by SR : Services
 #             Else GMESSAGE=mess(121,194,1) : GERR=1 : Endif
              Else GMESSAGE=mess(573,194,1) : GERR=1 : : mkstat = 1 : Endif
      Return
    Endif
    #----- Des besoins doivent être pris en cpte pour un article sous-traité non acheté -----#
    If [F:ITM]SCPFLG=2 & [F:ITM]PURFLG<>2 & [M:POI1]RETQTYSTU(nolign-1)=0
      If mkstat=98 GMESSAGE=mess(355,194,1) : GERR=1
              Else GMESSAGE=mess(354,194,1) : GERR=1 : Endif
      # Issue 112754 - 2016-10-20 by MUARN : services
      mkstat = 1
      Return
    Endif
  #Endif
  #----- Des besoins POP doivent être pris pour un article avec DA obligatoire -----#
  If [F:ITM]PRQFLG=2 & [M:POI1]RETQTYSTU(nolign-1)=0
    GMESSAGE=mess(164,194,1) : GERR=1 : Return
  Endif
  #-----
  If [M:POI1]RETQTYSTU(nolign-1)=0  Return : Endif
  If !GIMPORT Affzo [POI1]20 : Endif
  mkstat=99
Elsif [M:POI1]NBLIG>SAVNBLIG
  If sigma(I=SAVNBLIG,[M:POI1]NBLIG-1,[M:POI1]LINTYP(I)>1)
    Raz GBIDI2
    Local Shortint NOL : NOL=max(nolign-2,0)
    For I=SAVNBLIG To [M:POI1]NBLIG-1
      If [M:POI1]VCRTYPORI(I)=[M:POI1]VCRTYPORI(I+1) &
&        [M:POI1]VCRNUMORI(I)=[M:POI1]VCRNUMORI(I+1) &
&        [M:POI1]LINTYP(I)=3 & [M:POI1]LINTYP(I+1)=2
        GBIDI1=1
        GBIDI2=[M:POI1]SRTLIN(I)
        [M:POI1]SRTLIN(I)  =[M:POI1]SRTLIN(I+1)
        [M:POI1]SRTLIN(I+1)=GBIDI2
      Endif
    Next I
    If GBIDI1
      Sorta [M:POI1]NBLIG [M:POI1]NBLIG Order By [M:POI1]SRTLIN(indice),
&                                                [M:POI1]VCRTYPORI(indice),
&                                                [M:POI1]LINTYP(indice)
    Endif
  Endif
  If !GIMPORT Affzo [POI1]20 : Endif
  mkstat=4
Endif
Return

Subprog INCLURE
#--------------------------------------------#
# Chargement des qtés prises par les besoins #
#--------------------------------------------#
# Issue 13072 - 2012-01-19 by MUARN : contrôle mini de commande
#For I=0 To [M:PPI2]NBLIG-1
#  [M:PPI2]PICQTY(I)=[M:PPI2]RMNEXTQTY(I)
#Next I
#[M:PPI2]TOTQTY=sum([M:PPI2]PICQTY)
#Affzo [PPI2]TOTQTY, 10
Local Decimal WQTEUA
If !clalev([F:ITM]) Local File ITMMASTER [ITM] : Endif
For I=0 To [M:PPI2]NBLIG-1
  Read [ITM] ITM0=[M:PPI2]ITMREF(I)
  Call PCAL_QTY([M:PPI2]RMNEXTQTY(I),[M:PPI2]STU(I),WQTEUA,[F:ITM]PUU,
&            [M:PPI2]ITMREF(I),[M:PPI2]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
  Read [ITP] ITP0=[M:PPI2]ITMREF(I);[M:PPI2]BPRNUM(I)
  If fstat
    [M:PPI2]PICQTY(I)= [M:PPI2]RMNEXTQTY(I)
  Else
    If WQTEUA < [F:ITP]PURMINQTY
      Call PCAL_QTY([F:ITP]PURMINQTY, [F:ITM]PUU, [M:PPI2]PICQTY(I), [M:PPI2]STU(I),
&               [M:PPI2]ITMREF(I), [M:PPI2]BPRNUM(I),1,GBIDD1) From TRTACHQTE1
    Else
      [M:PPI2]PICQTY(I)= [M:PPI2]RMNEXTQTY(I)
    Endif
  Endif

  # 106430.sn - Update PP fields
  [M:PPI2]LINWEI(I)     = [F:ITM]ITMWEI * [M:PPI2]PICQTY(I)
  [M:PPI2]LINVOL(I)     = [F:ITM]ITMVOU * [M:PPI2]PICQTY(I)
  [M:PPI2]LINTCTRWEI(I) = [M:PPI2]LINWEI(I)
  [M:PPI2]LINTCTRVOL(I) = [M:PPI2]LINVOL(I)
  If [M:PPI2]LINWEU(I)<>[M:PPI2]WEU
    Call CONVERT_QTY([M:PPI2]LINWEU(I),[M:PPI2]WEU,[M:PPI2]LINTCTRWEI(I))From TRTX3
  Endif
  If [M:PPI2]LINVOU(I)<>[M:PPI2]VOU
    Call CONVERT_QTY([M:PPI2]LINVOU(I),[M:PPI2]VOU,[M:PPI2]LINTCTRVOL(I))From TRTX3
  Endif
  # 106430.en
Next I
[M:PPI2]TOTQTY=sum([M:PPI2]PICQTY)
[M:PPI2]WEITOT=sum([M:PPI2]LINTCTRWEI)  # 106430.n
[M:PPI2]VOLTOT=sum([M:PPI2]LINTCTRVOL)  # 106430.n
Affzo [PPI2]TOTQTY, WEITOT, VOLTOT, 10
End

Subprog EXCLURE
#------------------------------------#
# Raz de toutes les quantités prises #
#------------------------------------#
Raz [M:PPI2]TOTQTY, [M:PPI2]PICQTY
Raz [M:PPI2]LINWEI, [M:PPI2]LINVOL, [M:PPI2]LINTCTRWEI, [M:PPI2]LINTCTRVOL  # 106430.n
Raz [M:PPI2]WEITOT, [M:PPI2]VOLTOT  # 106430.n
Affzo [PPI2]TOTQTY, WEITOT, VOLTOT, 10
End

$CHARG_LIG_CDE
#-------------------------------------------------------------------#
# Chargement de la ligne de commande à partir de l'écran de picking #
#-------------------------------------------------------------------#
#VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
[F:PWO0]WIPTYP = [M:PPI2]WIPTYP(I)
[F:PWO0]WIPSTA = [M:PPI2]WIPSTA(I)
[F:PWO0]ITMREF = [M:PPI2]ITMREF(I)   # FQ 73188 GA 04/2011 pb suite 70999
If [M:PPI2]WIPNUM(I)<>"" [F:PWO0]WIPNUM = [M:PPI2]WIPNUM(I)
                         [F:PWO0]PSDLIN = 0
                    Else [F:PWO0]WIPNUM = [M:PPI2]VCRNUM(I)
                         [F:PWO0]PSDLIN = [M:PPI2]VCRLIN(I) : Endif
If [M:PPI2]WIPCOD(I)="SOF"
  [F:PWO0]WIPNUM = [M:PPI2]SOHNUM(I)
  [F:PWO0]PSDLIN = [M:PPI2]SOPLIN(I)
Endif
[F:PWO0]STU    = [M:PPI2]STU(I)
[F:PWO0]QTYSTU = min([M:PPI2]PICQTY(I),[M:PPI2]RMNEXTQTY(I))
#----- Lecture article et article-fournisseur si nécessaire -----#
If [F:ITM]ITMREF<>[M:PPI2]ITMREF(I)
   Read [ITM] ITM0=[M:PPI2]ITMREF(I) : If fstat Raz [F:ITM] : Endif
   # Issue X3-55891 - 2018-08-23 by SR : Données déclinées par site
#   Filter [ITP] Where ITMREF=[M:PPI2]ITMREF(I) & DOUFLG<3
#   Read [ITP] ITP1 First : If fstat Raz [F:ITP] : Endif
#   Filter [ITP]
Endif
# Pour la contremarque, la recherche a déjà été faite
If [M:PPI2]WIPTYP(I) <> 1
   Call DEFBPSNUM([M:PPI2]ITMREF(I),[M:POI1]POHFCY,[M:PPI2]STOFCY(I),"",2,WBPSNUM,WITMBPS) From TRTACHDEF1
   If [M:PPI2]BPRNUM(I)="" & [F:ITP]BPSNUM<>"" & WITMBPS <> 0
      [M:PPI2]BPRNUM(I)=[F:ITP]BPSNUM
   Endif
Endif
# End issue X3-55891
#----- Lecture fournisseur si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PPI2]BPRNUM(I)
  Read [BPS] BPS0=[M:PPI2]BPRNUM(I)
  If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Effacement du fournisseur si non actif ou prospect -----#
If [F:BPS]ENAFLG<>2 | [F:BPS]BPSTYP=2
  Raz [M:PPI2]BPRNUM(I)
Endif
#-----
If [F:ITP]ITMREF<>[M:PPI2]ITMREF(I) | [F:ITP]BPSNUM<>[M:PPI2]BPRNUM(I)
   Read [ITP] ITP0=[M:PPI2]ITMREF(I);[M:PPI2]BPRNUM(I)
   If fstat Raz [F:ITP] : Endif
Endif
If [F:ITP]PUU=""  [F:ITP]PUU=[F:ITM]PUU  : Endif
#----- Lecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PPI2]BPRNUM(I)
  Read [BPR] BPR0=[M:PPI2]BPRNUM(I)
  If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES) From TRTX3
#If WITMDES="" WITMDES=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#WITMDES1=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES1, "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

[F:PWO0]PUU=[F:ITP]PUU : Raz WPJT
#----- Chargement section analytiques de la DA pour contrôle -----#
Raz CCEPSD, WLINTEXPSD, WLINPURTYP
If [M:PPI2]WIPCOD(I)="POP"
   Read [PSD] PSD0=[M:PPI2]VCRNUM(I);[M:PPI2]VCRLIN(I)
   If fstat Raz [F:PSD] : Endif
   Read [CAL] CAL0="PSD";0;[M:PPI2]VCRNUM(I);[M:PPI2]VCRLIN(I);0;"";1
   If fstat  Raz [F:CAL] : Endif
   If GNBDIE>0
     For J=1 To GNBDIE : CCEPSD+=[F:CAL]CCE(J-1) : Next J
   Endif
   WPJT=[M:PPI2]WPJT(I)
   If [F:PSD]ITMDES<>""  WITMDES  = [F:PSD]ITMDES  : Endif
   If [F:PSD]ITMDES1<>"" WITMDES1 = [F:PSD]ITMDES1 : Endif
   If [F:PSD]PJT   <>""  WPJT     = [F:PSD]PJT     : Endif
   WLINTEXPSD=[F:PSD]LINTEX
   WLINPURTYP=[F:PSD]LINPURTYP
Elsif [M:PPI2]WIPCOD(I)="SOF"
   If [F:SOP]SOHNUM<>[M:PPI2]SOHNUM(I) |
&     [F:SOP]SOPLIN<>[M:PPI2]SOPLIN(I) |
&     [F:SOP]SOPSEQ<>[M:PPI2]SOPLIN(I)
     Read [SOP] SOP0=[M:PPI2]SOHNUM(I);[M:PPI2]SOPLIN(I);[M:PPI2]SOPLIN(I)
     If fstat  Raz [F:SOP] : Endif
   Endif
   WPJT=[M:PPI2]WPJT(I)
   If [F:SOP]ITMDES<>""  WITMDES  = [F:SOP]ITMDES  : Endif
   If [F:SOP]ITMDES1<>"" WITMDES1 = [F:SOP]ITMDES1 : Endif
Else
  WPJT=[M:PPI2]WPJT(I)
Endif
#-- Si prise en compte sous-traitance (SCx ou EOx) rupture à chaque ligne --#
If find([M:PPI2]WIPTYP(I),4,13)
  CCEPSD=num$(I) : # Provoque la rupture[
Endif
#----- Si 1ère fois -----#
If [M:POI1]PRHFCY(NOL)=""
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  Gosub DEB_CHARG_LIG_CDE
Endif
#-------------------------------------------------------------------#
# Si rupture, fin de la ligne en cours et passage à une autre ligne #
#-------------------------------------------------------------------#
If  [M:POI1]ITMREF(NOL)   <>[M:PPI2]ITMREF(I)                |
&  ([M:POI1]BPSNUM(NOL)   <>[M:PPI2]BPRNUM(I) & [M:PPI2]BPRNUM(I)<>"") |
&   [M:POI1]PRHFCY(NOL)   <>[M:PPI2]STOFCY(I)                |
&   [M:POI1]SOHNUM(NOL)   <>[M:PPI2]SOHNUM(I)                |
&   [M:POI1]SOPLIN(NOL)   <>[M:PPI2]SOPLIN(I)                |
&  ([M:POI1]RETRCPDAT(NOL)<>[M:PPI2]ENDDAT(I) & ECLAT_DAT>1) |
&  (WVCRNUM               <>[M:PPI2]VCRNUM(I) & ECLAT_PSH>1) |
&  ([M:POI1]PJT(NOL)      <>WPJT              & ECLAT_PJT>1) |
&  ([M:POI1]LINPURTYP(NOL)<>WLINPURTYP        & ECLAT_LPT>1) |
&  (CCELIG                <>CCEPSD            & ECLAT_CCE>1) |
&  ([M:POI1]ITMDES(NOL)   <>WITMDES           & ECLAT_DES=2) |
&  ([M:POI1]ITMDES1(NOL)  <>WITMDES1          & ECLAT_DES=3) |
&  (WLINTEX               <>WLINTEXPSD        & ECLAT_DES=4)
  #-----
  Gosub FIN_CHARG_LIG_CDE                    : If GOK=0 | mkstat  Return : Endif
  Gosub CHARG_LIG_SUPPLEMENT From TRTACHSCO1 : If GOK=0 | mkstat  Return : Endif
  #-----
  Gosub NEW_LINE : If mkstat  Return : Endif
  #VPO 27/01/11 70999 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
  Gosub DEB_CHARG_LIG_CDE
Else
  #VPO 18/02/11 71725 on doit passer par une struct intermediaire PWO0
  [F:PWO]=[F:PWO0]
Endif
#----- Conversion qté prise en UA -----#
Call PCAL_QTY([F:PWO]QTYSTU,[F:PWO]STU,[F:PWO]QTYPUU,[F:PWO]PUU,
&             [M:PPI2]ITMREF(I),[M:PPI2]BPRNUM(I),1,GBIDD2) From TRTACHQTE1
#----- Mise à jour qté en US -----#
[M:POI1]STU(NOL)       =[M:PPI2]STU(I)
[M:POI1]QTYSTU(NOL)   +=[M:PPI2]PICQTY(I)
[M:POI1]RETQTYSTU(NOL)+=[F:PWO]QTYSTU
#-----
If dim(WUOMFLG)>0 & find(WUOMFLG,1,2,3)
  If ECLAT_PSH=9  ECLAT_PSH=1 : Endif
  If ECLAT_CCE=9  ECLAT_CCE=1 : Endif
  WUOMFLG=0
Endif
#--------------------#
# Mises à jour si DA #
#--------------------#
If [M:PPI2]WIPCOD(I)="POP"
  #----- Mise à jour des prix, frais, remises et motif si DA -----#
  If NBRGR=0 : # Si première fois : Chargement prix ...
    #----- Chargement comptes et sections analytiques -----#
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "PSD",0,[F:PSD]PSHNUM,[F:PSD]PSDLIN,0,"") From TRTX3CPT
    #-----
    [M:POI1]=[F:PSD]
    [M:POI1]ITMREF(NOL)    = [M:PPI2]ITMREF(I)
    # Issue 89832 GA 05/2013 DA multi-site, Raz de l'adresse ligne précédente avant de changer de site de rcp
    If NOL>0 & [M:POI1]PRHFCY(NOL)<> "" & [M:POI1]PRHFCY(NOL)<>[M:PPI2]STOFCY(I)
       Raz [M:POI1]FCYADD(NOL)
    Endif
    [M:POI1]PRHFCY(NOL)    = [M:PPI2]STOFCY(I)
    [M:POI1]BPSNUM(NOL)    = [M:PPI2]BPRNUM(I)
    [M:POI1]ITMDES(NOL)    = WITMDES
    [M:POI1]ITMDES1(NOL)   = WITMDES1
    [M:POI1]PJT(NOL)       = WPJT
    [M:POI1]LINPURTYP(NOL) = WLINPURTYP
    [M:POI1]UOM(NOL)       = [F:PWO]PUU
    [M:POI1]PUU(NOL)       = [F:PWO]PUU
    [M:POI1]STU(NOL)       = [F:PWO]STU
    Call PCAL_QTY([M:PPI2]PICQTY(I),[F:PWO]STU,[M:POI1]QTYPUU(NOL),[F:PWO]PUU,
&                 [M:PPI2]ITMREF(I),[M:PPI2]BPRNUM(I),1,GBIDD2) From TRTACHQTE1
    [M:POI1]QTYSTU(NOL)    = [M:PPI2]PICQTY(I)
    [M:POI1]RETQTYSTU(NOL) = [F:PWO]QTYSTU
    Raz [M:POI1]LINAMT(NOL)
    #----- Appel point d'entrée UOMPSHPOH pour récup unité de la DA -----#
    Gosub POINT_UOMPSHPOH From TRTACHCDE1
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
      Read [BPR] BPR0=[M:POI1]BPSNUM(NOL)
      If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
    If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
      Read [BPS] BPS0=[M:POI1]BPSNUM(NOL)
      If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
    Endif
    #----- Chargement libellés colonnes et paramètres tarif -----#
    If GPLISTC<>[F:BPS]PLISTC
      GPLISTC=[F:BPS]PLISTC
      Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
      Call TYPREM(2,[F:BPS]PLISTC)     From TRTPRICE
      Call TARIFCHGT(6)                From TRTPRICE
    Endif
    #----- Effacement prix si fournisseur commande différent du fournisseur DA -----#
    If [M:POI1]BPSNUM(NOL)<>[F:PSD]BPSNUM
      Raz [M:POI1]GROPRI(NOL), [M:POI1]NETPRI(NOL), [M:POI1]PRIREN(NOL)
      For J=1 To 9
        If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
          Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With 0
          Assign "[M:POI1]DISCRGREN"+num$(J)+"(NOL)" With 0
        Endif
      Next J
      # Issue X3-55891 - 2018-09-20 by SR : Seulement si pas vide
      If [M:POI1]BPSNUM(NOL) <> ""
        # Issue 78279 - 2011-11-29 by VPO : affecter devise art-fourn
        AVNOLIGN=nolign
        nolign=NOL+1
        Call AM_BPSNUM([M:POI1]BPSNUM(NOL)) From SUBPOI
        nolign=AVNOLIGN
      Endif
      # End issue X3-55891
    #----- Fournisseut identique, on récupère les prix -----#
    Else
      #----- Conversion prix unitaire si unités DA et commande différentes -----#
      If [F:PSD]PUU<>[M:POI1]UOM(NOL)
        Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),MT1,[F:PSD]PUU,
&                     [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,MT2) From TRTACHQTE1
        [M:POI1]GROPRI(NOL)=arr([M:POI1]GROPRI(NOL)*MT2,10^-GDECPRI)
        For J=1 To 9
          If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
            If GDISCRGTYP(J-1)=1 & GCLCRUL(J-1)=1
&             MT1=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)*MT2")
              Call ARRDEV(MT1,[M:POI1]CUR(NOL)) From TRTDIV
              Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With MT1
            Endif
            DISCRGVAL(J-1)=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
          Endif
        Next J
        If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
        If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
        Call CALNET(2,[F:BPS]PLISTC,[M:POI1]GROPRI(NOL),DISCRGVAL,[M:POI1]QTYPUU(NOL),
&                     [M:POI1]NETPRI(NOL),[M:POI1]CUR(NOL)) From TRTPRICE
      Endif
      #----- Conversion prix si devises DA et commande différentes -----#
      If [M:POI1]CUR(NOL)<>[F:PSD]CUR
        Call CONVERT2([F:PSD]CUR,[M:POI1]CUR(NOL),GLOCALDEV,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,
&                     [M:POI1]GROPRI(NOL),MT2,STAT) From TRTDEV
        [M:POI1]GROPRI(NOL)=arr(MT2,10^-GDECPRI)
        For J=1 To 9
          If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
            If GFMTREM(J-1)="M"
              MT1=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
              Call CONVERT([F:PSD]CUR,[M:POI1]CUR(NOL),GLOCALDEV,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,
&                          MT1,MT2,STAT) From TRTDEV
              Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With MT2
            Endif
            DISCRGVAL(J-1)=evalue("[M:POI1]DISCRGVAL"+num$(J)+"(NOL)")
          Endif
        Next J
        If dim(GCALNETLIN)>0  GCALNETLIN=NOL+1      : Endif
        If dim(GCALNETABR)>0  GCALNETABR="[M:POI1]" : Endif
        Call CALNET(2,[F:BPS]PLISTC,[M:POI1]GROPRI(NOL),DISCRGVAL,[M:POI1]QTYPUU(NOL),
&                     [M:POI1]NETPRI(NOL),[M:POI1]CUR(NOL)) From TRTPRICE
      Endif
      #-----
    Endif
  #----- Si plusieurs DA sur la même ligne : Effacement prix ... -----#
  Else
    Raz [M:POI1]GROPRI(NOL), [M:POI1]NETPRI(NOL), [M:POI1]PRIREN(NOL)
    Raz [M:POI1]CUR(NOL),    [M:POI1]CHGTYP(NOL), [M:POI1]CHGCOE(NOL)
    For J=1 To 9
      If evalue("dim([M:POI1]DISCRGVAL"+num$(J)+"(NOL))")>0
        Assign "[M:POI1]DISCRGVAL"+num$(J)+"(NOL)" With 0
        Assign "[M:POI1]DISCRGREN"+num$(J)+"(NOL)" With 0
      Endif
    Next J
  Endif
Endif
#----- Mise à jour date de réception -----#
If [M:POI1]RETRCPDAT(NOL)>[M:PPI2]ENDDAT(I)
   [M:POI1]RETRCPDAT(NOL)=[M:PPI2]ENDDAT(I)
Endif

#-----------------------------------------------------------------------#
# Point d'entrée TRTZONSPE pour traitement de zones spécifiques         #
# --------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                           #
#                                                                       #
# NOL   : Indice de la ligne en cours de chargement dans l'écran POI1   #
# I     : Indice de la ligne en cours de traitement dans l'écran PPI2   #
#-----------------------------------------------------------------------#
GPOINT="TRTZONSPE" : Gosub ENTREE From EXEFNC
#----- Ecriture fichier de travail -----#
NBRGR+=1
Write [PWO]
If fstat GOK=0 : Endif
Return


$NEW_LINE
#----------------#
# Nouvelle ligne #
#----------------#
# ------------------------------------------------------------------------ #
# Cette fonction est utilisée par TRTACHSCO1 pour ajout d'une ligne POI1   #
# ------------------------------------------------------------------------ #
status=8 : nolign+=1 : NOL+=1
If dim([M:POI1]ITMREF)<[M:POI1]NBLIG+2  mkstat=1 : Return : Endif
If ORIAPPEL<>1
  Insa NOL,1,[M:POI1]NBLIG [M:POI1]NBLIG : [M:POI1]NBLIG+=1
  [M:POI1]NBCRELIG+=1
Endif
status=0 : Call LINNUM("SRTLIN")  From TABLEAUX
[M:POI1]POICOU+=1 : [M:POI1]POILIN(NOL)=[M:POI1]POICOU
[F:PWO0]LINNUM=[M:POI1]POILIN(NOL)    # FQ 73188 GA 04/2011 avant [F:PWO]LINNUM
Raz [M:POI1]QTYSTU(NOL), [M:POI1]LINFLG(NOL)
#----- reprise valeurs ligne précédente -----#
[M:POI1]PRHFCY   (NOL)=[M:POI1]PRHFCY   (NOL-1)
[M:POI1]FCYADD   (NOL)=[M:POI1]FCYADD   (NOL-1)
[M:POI1]USEPLC   (NOL)=[M:POI1]USEPLC   (NOL-1)
[M:POI1]PJT      (NOL)=[M:POI1]PJT      (NOL-1)
[M:POI1]BPSNUM   (NOL)=[M:POI1]BPSNUM   (NOL-1)
[M:POI1]LINSTOFCY(NOL)=[M:POI1]LINSTOFCY(NOL-1)
[M:POI1]EXTRCPDAT(NOL)=[M:POI1]EXTRCPDAT(NOL-1)
[M:POI1]CUR      (NOL)=[M:POI1]CUR      (NOL-1)
[M:POI1]CHGTYP   (NOL)=[M:POI1]CHGTYP   (NOL-1)
[M:POI1]CHGCOE   (NOL)=[M:POI1]CHGCOE   (NOL-1)
[M:POI1]SALFCY   (NOL)=[M:POI1]SALFCY   (NOL-1)
[M:POI1]BPCORD   (NOL)=[M:POI1]BPCORD   (NOL-1)
[M:POI1]BPCINV   (NOL)=[M:POI1]BPCINV   (NOL-1)
[M:POI1]INVFCY   (NOL)=[M:POI1]INVFCY   (NOL-1)
[M:POI1]DME      (NOL)=[M:POI1]DME      (NOL-1)
[M:POI1]BETFCY   (NOL)=[M:POI1]BETFCY   (NOL-1)
[M:POI1]BETCPY   (NOL)=[M:POI1]BETCPY   (NOL-1)
[M:POI1]ORIFCY   (NOL)=[M:POI1]ORIFCY   (NOL-1)
[M:POI1]SOHCAT   (NOL)=[M:POI1]SOHCAT   (NOL-1)
[M:POI1]LINBUY   (NOL)=[M:POI1]LINBUY   (NOL-1)
If !find([M:POI1]VCRTYPORI(NOL-1),36,10)      # Issue 88156 GA 03/2013 sauf ss-traitance
   [M:POI1]ORDFCY   (NOL)=[M:POI1]POHFCY
Else
   [M:POI1]ORDFCY   (NOL)=[M:POI1]ORDFCY(NOL-1)
   [M:POI1]RETRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL-1) # Issue 88261 GA 03/2013
Endif
Return


$DEB_CHARG_LIG_CDE
#------------------------------------#
# Début chargement ligne de commande #
#------------------------------------#
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>[M:PPI2]ITMREF(I) # Issue 100475 - 2014-06-02 by MUARN : ajout indice
  Read [ITM]ITM0=[M:PPI2]ITMREF(I) : If fstat : Raz [F:ITM] : Endif
Endif
#-----
[M:POI1]ORDFCY(NOL)   = [M:POI1]POHFCY : # GH 26/12/12 bug 85454
[M:POI1]CUR(NOL)      = ""
[M:POI1]CHGTYP(NOL)   = 0
[M:POI1]CHGCOE(NOL)   = 0
[M:POI1]ITMREF(NOL)   = [M:PPI2]ITMREF(I)
[M:POI1]PRHFCY(NOL)   = [M:PPI2]STOFCY(I)
[M:POI1]RETRCPDAT(NOL)= [M:PPI2]ENDDAT(I)
WVCRNUM               = [M:PPI2]VCRNUM(I)
CCELIG                = CCEPSD
NBRGR                 = 0
[M:POI1]BPSNUM(NOL)   = [M:PPI2]BPRNUM(I)
[M:POI1]ITMDES(NOL)   = WITMDES
[M:POI1]ITMDES1(NOL)  = WITMDES1
WLINTEX               = WLINTEXPSD
[M:POI1]PJT(NOL)      = WPJT
[M:POI1]LINPURTYP(NOL)= WLINPURTYP
[M:POI1]PUU(NOL)      = [F:PWO]PUU
[M:POI1]SOHNUM(NOL)   = [M:PPI2]SOHNUM(I)
[M:POI1]SOPLIN(NOL)   = [M:PPI2]SOPLIN(I)
[M:POI1]SOQSEQ(NOL)   = [M:PPI2]SOPLIN(I)
REFART                = [M:PPI2]ITMREF(I)
[M:POI1]ITMWEI(NOL)   = [F:ITM]ITMWEI       # 106430.n
[M:POI1]ITMVOL(NOL)   = [F:ITM]ITMVOU       # 106430.n
[M:POI1]LINWEU(NOL)   = [F:ITM]WEU          # 106430.n
[M:POI1]LINVOU(NOL)   = [F:ITM]VOU          # 106430.n

WBPSNUM=[M:PPI2]BPRNUM(I) : Gosub CTRL_INTERSITE From SUBPOI : Raz mkstat
# Issue 112754 - 2016-10-24 by SR : Services si PEC depuis NBLIG
If WITMKND = 0
  [M:POI1]ITMKND(NOL) = 1
  If [F:ITM]SCSFLG = 2
    If find([F:PWO]WIPTYP,4,13) : [M:POI1]ITMKND(NOL) = 2 : Else : [M:POI1]ITMKND(NOL) = 3 : Endif
  Endif
Else
  [M:POI1]ITMKND(NOL) = WITMKND
Endif
# End issue 112754
#----- Suite chargement pour sous-traitance -----#
If find([F:PWO]WIPTYP,4,13)
  Gosub CHARG_LIG_STT From TRTACHSCO1
Else
  [M:POI1]LINTYP(NOL)=1  : # Ligne classique (indépendante)
Endif
Return


$FIN_CHARG_LIG_CDE
#----------------------------------#
# Fin chargement ligne de commande #
#----------------------------------#
#----- Chargement code adresse par défaut du site de réception -----#
If [F:FCY]FCY<>[M:POI1]PRHFCY(NOL)
  Read [FCY] FCY0=[M:POI1]PRHFCY(NOL) : If fstat Raz [F:FCY] : Endif
Endif
# Issue 120908 - 2017-01-16 by MUARN : en PEC si 2 sites différents on garde l'adresse du site précédent
#If [M:POI1]FCYADD(NOL)=""          # FQ 73618 GA 05/2011 ne pas écraser si déjà renseigné
If [M:POI1]FCYADD(NOL)="" |( NOL>0 & [M:POI1]PRHFCY(NOL)<> [M:POI1]PRHFCY(NOL-1))
   [M:POI1]FCYADD(NOL)=[F:FCY]BPAADD
Endif
#----- Lecture article, article-fournisseur et article-site si nécessaire -----#
If [F:ITM]ITMREF<>[M:POI1]ITMREF(NOL)
   Read [ITM] ITM0=[M:POI1]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:POI1]BPSNUM(NOL)
   Read [ITP] ITP0=[M:POI1]ITMREF(NOL);[M:POI1]BPSNUM(NOL)
   If fstat Raz [F:ITP] : Endif
Endif
If [F:ITF]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:POI1]POHFCY
   Read [ITF] ITF0=[M:POI1]ITMREF(NOL);[M:POI1]POHFCY
   If fstat Raz [F:ITF] : Endif
Endif
#-----
If [M:POI1]LINBUY(NOL)="" | [M:POI1]LINTYP(NOL)=1
  If [F:ITM]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITM]BUY : Endif
  If [F:ITF]BUY<>"" [M:POI1]LINBUY(NOL)=[F:ITF]BUY : Endif
Endif
# GH 10/04/2015 bug 104152 déplacé plus bas, car l'article-site n'est pas le bon
#If !find([M:POI1]VCRTYPORI(NOL),10,36)
#  If [F:ITM]OFS<>0  [M:POI1]OFS(NOL) =[F:ITM]OFS : Endif
#  If [F:ITF]OFS<>0  [M:POI1]OFS(NOL) =[F:ITF]OFS : Endif
#Endif
#----- Calcul quantité en UA -----#
Call PCAL_QTY([M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&             [M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&             [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),3,GBIDD1) From TRTACHQTE1
#----- Appel au point d'entrée permettant de choisir l'arrondi de la qté UA -----#
Local Decimal QTEUA, SAV_QTEUA
[L]QTEUA=[M:POI1]QTYSTU(NOL)*GBIDD1
# Issue 80765 - 2012-03-15 by MUARN : qte besoin non reprise en qte commandee
SAV_QTEUA=[M:POI1]QTYSTU(NOL)*GBIDD1
Gosub POINT_PURQTYRND From SUBPOHB
[M:POI1]QTYPUU(NOL)=[L]QTEUA
#----- Recalcul quantité US après arrondi éventuel de l'UA -----#
Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&             [M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&             [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
#----- Si qté US inférieure au besoin pris en compte, ajuster qtés à la hausse -----#
If [M:POI1]QTYSTU(NOL)<[M:POI1]RETQTYSTU(NOL)
  QTEARR=arr(SAV_QTEUA,10^-WNBDEC)
  If QTEARR>=SAV_QTEUA-10^-(WNBDEC+3)
    [M:POI1]QTYPUU(NOL)=QTEARR
  Else
    [M:POI1]QTYPUU(NOL)=QTEARR+10^-WNBDEC
  Endif
  Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&               [M:POI1]QTYSTU(NOL),[M:POI1]STU(NOL),
&               [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
Endif
#-----
GCOEUOM=1
If [F:ITF]ITMREF<>[M:POI1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:POI1]PRHFCY(NOL)
  Read [ITF] ITF0=[M:POI1]ITMREF(NOL);[M:POI1]PRHFCY(NOL)
  If fstat  Raz  [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
Endif
[M:POI1]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
#----- si lignes sous-traitance, délai réappro déjà chargé ! -----#
# GH 10/04/2015 bug 104152
If !find([M:POI1]VCRTYPORI(NOL),10,36)
  If [F:ITM]OFS<>0  [M:POI1]OFS(NOL) =[F:ITM]OFS : Endif
  If [F:ITF]OFS<>0  [M:POI1]OFS(NOL) =[F:ITF]OFS : Endif
Endif
#-----
If [M:POI1]SOHNUM(NOL)<>""
  If [F:SOP]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&    [F:SOP]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&    [F:SOP]SOPSEQ<>[M:POI1]SOQSEQ(NOL)
    Read [SOP] SOP0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
    If fstat  Raz [F:SOP] : Endif
  Endif
Endif
If [M:POI1]SOHNUM(NOL)<>"" & [F:SOP]SAU<>"" &
&  (find ([F:SOP]SAU,[F:ITM]PCU) | [F:SOP]SAU=[F:ITP]PCU)
  [M:POI1]UOM(NOL)      =[F:SOP]SAU
  #----- Calcul qté en unité de conditionnement -----#
  Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&               [M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&               [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
  #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
  Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&               GBIDD1,[M:POI1]PUU(NOL),
&               [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GCOEUOM) From TRTACHQTE1
  [M:POI1]UOMPUUCOE(NOL) = GCOEUOM
  #-----
  [M:POI1]UOMFLG(NOL)   =2
Else
  If [M:POI1]UOMFLG(NOL)=2 & find([M:POI1]VCRTYPORI(NOL),10,36)
     # Issue 77611 GA 11/2012 Achat en UC déjà renseigné en cas de sous-traitance
  Elsif dim(WUOMFLG)>0 & find(WUOMFLG,1,2,3)
    #----- Calcul qté en unité de conditionnement -----#
    Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&                 [M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                 [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
    #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
    Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                 GBIDD1,[M:POI1]PUU(NOL),
&                 [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GCOEUOM) From TRTACHQTE1
    [M:POI1]UOMPUUCOE(NOL) = GCOEUOM
    #-----
    [M:POI1]UOMFLG(NOL)   =2
  Else
    [M:POI1]UOM(NOL)      =[M:POI1]PUU(NOL)
    [M:POI1]QTYUOM(NOL)   =[M:POI1]QTYPUU(NOL)
    [M:POI1]UOMPUUCOE(NOL)=1
    [M:POI1]UOMFLG(NOL)   =1
    # Issue 78615 - 2011-12-15 by VPO : appel PE ALIUOMPOH
    #--------------------------------------------------------------------------------#
    # Point d'entrée ALIUOMPOH pour alimentation unité de commande (conditionnement) #
    # ------------------------------------------------------------------------------ #
    # Variables utilisables par le point d'entrée                                    #
    #                                                                                #
    # NOL   : Indice de la ligne en cours de chargement dans l'écran POI1            #
    # I     : Indice de la ligne en cours de traitement dans l'écran PURMGT          #
    #                                                                                #
    # [M:POI1]UOM(NOL) : Unité de commande modifiable                                #
    #--------------------------------------------------------------------------------#
    Gosub POINT_ALIUOMPOH From TRTACHPOH1
    If [M:POI1]UOM(NOL) <> [M:POI1]PUU(NOL)
      #----- Calcul qté en unité de conditionnement -----#
      Call PCAL_QTY([M:POI1]QTYPUU(NOL),[M:POI1]PUU(NOL),
&                   [M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GBIDD1)  From TRTACHQTE1
      #----- Appel du S/P pour chargement du coefficient avec précision maxi -----#
      Call PCAL_QTY([M:POI1]QTYUOM(NOL),[M:POI1]UOM(NOL),
&                   GBIDD1,[M:POI1]PUU(NOL),
&                   [M:POI1]ITMREF(NOL),[M:POI1]BPSNUM(NOL),1,GCOEUOM) From TRTACHQTE1
      [M:POI1]UOMPUUCOE(NOL) = GCOEUOM
      #-----
      [M:POI1]UOMFLG(NOL)   =2
    Endif
  Endif
Endif
#-----
If [M:POI1]RETRCPDAT(NOL)<[M:POI1]ORDDAT  [M:POI1]RETRCPDAT(NOL)=[M:POI1]ORDDAT : Endif
[M:POI1]EXTRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL)
[M:POI1]PREQTYPUU(NOL)=[M:POI1]QTYPUU(NOL)
#----- Lecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:POI1]BPSNUM(NOL)
   Read [BPR] BPR0=[M:POI1]BPSNUM(NOL)
   If fstat  Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Lecture BPSUPPLIER si nécessaire pour nom & structure tarif -----#
If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(NOL)
   Read [BPS] BPS0=[M:POI1]BPSNUM(NOL)
   If fstat  Raz [F:BPS] : [F:BPS]CUR=GLOCALDEV : Endif
Endif
#----- Chargement paramètres et libellés colonnes tarif -----#
If GPLISTC<>[F:BPS]PLISTC
   GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
   Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
Endif
#----- Chargement devise, type de cours et cours -----#
If [M:POI1]CUR(NOL)=""
  [M:POI1]CUR(NOL)   =[F:BPS]CUR
Endif
If [M:POI1]CHGTYP(NOL)=0
  [M:POI1]CHGTYP(NOL)=[F:BPS]CHGTYP
Endif
If [M:POI1]CHGCOE(NOL)=0
  Call COURSITE([M:POI1]CUR(NOL),GFCY,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,[M:POI1]CHGCOE(NOL),OK) From TRTDEV
Endif
#-----
If [F:ITF]QUAFLG>1 [M:POI1]QUAFLG(NOL)=2                                # hcb V6CQ
              Else [M:POI1]QUAFLG(NOL)=1 : Endif
If dim([M:POI1]TSICOD1(NOL))>0 [M:POI1]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
If dim([M:POI1]TSICOD2(NOL))>0 [M:POI1]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
If dim([M:POI1]TSICOD3(NOL))>0 [M:POI1]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
If dim([M:POI1]TSICOD4(NOL))>0 [M:POI1]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
If dim([M:POI1]TSICOD5(NOL))>0 [M:POI1]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
Call INIT_REGIME([M:POI1]BPSNUM(NOL),[M:POI1]POHFCY,"F",WVACBPR) From CPTSUB
# Issue 117079 - 2016-06-15 by MUARN : il faut alimenter les codes taxes
# Issue 93038 GA 10/2013 sauf sur article sous-traité
#If [M:POI1]LINTYP(NOL)<>2
   Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
#Endif
If [F:ITP]ITMREF<>""
   If [F:ITP]QUAFLG>1 [M:POI1]QUAFLG(NOL)=2
                 Else [M:POI1]QUAFLG(NOL)=1 : Endif
   Call CONVERT_QTY([F:ITP]PURMINQTY,[F:ITP]PUU,QTE2,[M:POI1]PUU(NOL)) From SUBPOI
   [M:POI1]PURMINQTY(NOL)=QTE2
Endif
If GACTDEB=2
  If [F:ITP]EECINCRAT<>0 [M:POI1]EECINCRAT(NOL)=[F:ITP]EECINCRAT : Endif
Endif
#----- Initialisation des comptes et du type d'achat -----#
If [M:POI1]LINACC1(NOL)="" & [M:POI1]LINACC2(NOL)="" & [M:POI1]LINACC3(NOL)=""
  Call INIT_COMPTES_LIGNE(NOL) From SUBPOI
Endif
If [M:POI1]LINPURTYP(NOL)=0
  Call D_LINPURTYP([M:POI1]LINPURTYP(NOL)) From SUBPOI
Endif
#----- Initialisation sections analytiques si nécessaire -----#
If GNBDIE>0
  #----- Lecture ligne commande vente contremarque à cause de l'INISEC "POID" -----#
  If GMODU(5)=2 & [M:POI1]SOHNUM(NOL)<>""
    If [F:SOP]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&      [F:SOP]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&      [F:SOP]SOPSEQ<>[M:POI1]SOQSEQ(NOL)
      Read [SOP] SOP0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
      If fstat  Raz [F:SOP] : Endif
    Endif
  Elsif GMODU(5)=2
    Raz [F:SOP]
  Endif
  #----- Lecture de l'opération si sous-traitance à cause de l'INISEC "POID" -----#
  If clalev([F:MFO]) & GMODU(8)=2 & find([M:POI1]LINTYP(NOL),1,3)
    If [M:POI1]VCRTYPORI(NOL)=10
      If [F:MFO]MFGNUM   <>[M:POI1]VCRNUMORI(NOL) |
&        [F:MFO]OPENUM   <>[M:POI1]VCRLINORI(NOL) |
&        [F:MFO]OPESPLNUM<>[M:POI1]VCRSEQORI(NOL)
        Read [MFO] MFO0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
        If fstat  Raz [F:MFO] : Endif
      Endif
    Else
      Raz [F:MFO]
    Endif
  Endif
  #----- Lecture de l'article sous-traité si sous-traitance à cause de l'INISEC "POID" -----#
  If clalev([F:SCI]) & [M:POI1]LINTYP(NOL)=2
    If [M:POI1]VCRTYPORI(NOL)=36
      If [F:SCI]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&        [F:SCI]SCILIN <>[M:POI1]VCRLINORI(NOL)
        Read [SCI] SCI0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL)
        If fstat  Raz [F:SCI] : Endif
      Endif
    #Else
    #  Raz [F:SCI]
    Endif
  Endif
  #----- Lecture de l'opération si sous-traitance à cause de l'INISEC "POID" -----#
  If clalev([F:SCS]) & [M:POI1]LINTYP(NOL)=3
    If [M:POI1]VCRTYPORI(NOL)=36
      If [F:SCS]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&        [F:SCS]SCILIN <>[M:POI1]VCRLINORI(NOL) |
&        [F:SCS]SCSLIN <>[M:POI1]VCRSEQORI(NOL)
        Read [SCS] SCS0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
        If fstat  Raz [F:SCS] : Endif
      Endif
    #Else
    #  Raz [F:SCS]
    Endif
  Endif
  #----- Lecture du composant si sous-traitance à cause de l'INISEC "POID" -----#
  If clalev([F:SCM]) & [M:POI1]LINTYP(NOL)=4
    If [M:POI1]VCRTYPORI(NOL)=36
      If [F:SCM]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&        [F:SCM]SCILIN <>[M:POI1]VCRLINORI(NOL) |
&        [F:SCM]SCMLIN <>[M:POI1]VCRSEQORI(NOL)
        Read [SCM] SCM0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
        If fstat  Raz [F:SCM] : Endif
      Endif
    Else
      Raz [F:SCM]
    Endif
  Endif
  #-----
  For J=1 To GNBDIE
    If evalue("[M:POI1]CCE"+num$(J)+"(NOL)")=""
      # Issue 119084 - 2016-10-17 by MUARN : init si comptes existants
      #Call INIT_CCE(SECTION,J,"POID","[M:POI1]LINACC",NOL) From TRTX3CPT
      #Assign "[M:POI1]CCE"+num$(J)+"(NOL)" With SECTION
      If dim(SAV_I)<1  Local Integer SAV_I : Endif
      SAV_I = I
      GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPOI
      If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
      WCCE=evalue("[M:POI1]CCE"+num$(J)+"(NOL)")
      Raz mkstat
      Call SAIS_CCE(WCCE,J,"[M:POI1]LINACC","") From TRTX3CPT
      If !mkstat
        Call INIT_CCE(SECTION,J,"POID","[M:POI1]LINACC",NOL) From TRTX3CPT
        Assign "[M:POI1]CCE"+num$(J)+"(NOL)" With SECTION
      Endif
      I = SAV_I
      # End issue 119084
      # Issue X3-55071 - 2017-09-28 by MUARN : mkstat positionné par SAIS_CCE non razé si aucun axe sur les comptes
      Raz mkstat
    Endif
  Next J
Endif
#-----
If GACTDEB=2
  If !varinit([M:POI1]EECINCRAT,NOL)  [M:POI1]EECINCRAT(NOL)=[F:BPS]EECINCRAT : Endif
Endif
If !varinit([M:POI1]ORICRY,NOL)
   [M:POI1]ORICRY(NOL)   =[F:BPR]CRY       : Endif
If [M:POI1]LINBUY(NOL)=""
   [M:POI1]LINBUY(NOL)   =[M:POI1]BUY      : Endif
#----- Recherche tarif (Pas de recherche si prix chargé par DA) -----#
If [M:POI1]LINTYP(NOL)<>2 & [M:POI1]GROPRI(NOL)=0 & [M:POI1]NETPRI(NOL)=0
  GPUU=[M:POI1]PUU(NOL) : Call RECH_TARIF ("POI",NOL) From TRTACHTAR1
Elsif [M:POI1]LINTYP(NOL)=2
  #----- Effacement des éléments tarif si article composé (produit fini) -----#
  Raz [M:POI1]GROPRI(NOL), [M:POI1]NETPRI(NOL), [M:POI1]PRIREN(NOL)
  For J=0 To 8
    If evalue("dim([M:POI1]DISCRGVAL"+num$(J+1)+"(NOL))")>0
      Assign "[M:POI1]DISCRGVAL"+num$(J+1)+"(NOL)" With 0
      Assign "[M:POI1]DISCRGREN"+num$(J+1)+"(NOL)" With 0
    Endif
  Next J
  Raz [M:POI1]LINAMT(NOL),  [M:POI1]LINATIAMT(NOL)
  Raz [M:POI1]CLCAMT1(NOL), [M:POI1]CLCAMT2(NOL), [M:POI1]CLCAMT3(NOL)
  If dim([M:POI1]CLCAMT4)>0  Raz [M:POI1]CLCAMT4(NOL) : Endif
  If dim([M:POI1]CLCAMT5)>0  Raz [M:POI1]CLCAMT5(NOL) : Endif
  If dim([M:POI1]CLCAMT6)>0  Raz [M:POI1]CLCAMT6(NOL) : Endif
  If dim([M:POI1]CLCAMT7)>0  Raz [M:POI1]CLCAMT7(NOL) : Endif
  # Issue 117079 - 2016-06-15 by MUARN : ne pas effacer codes taxe
  ##----- Effacement de codes taxes -----#
  #Raz [M:POI1]VAT1(NOL), [M:POI1]VAT2(NOL), [M:POI1]VAT3(NOL)
  #If dim([M:POI1]TAXRCP)>0   Raz [M:POI1]TAXRCP(NOL)  : Endif
  #If dim([M:POI1]TAXISS)>0   Raz [M:POI1]TAXISS(NOL)  : Endif
  #If dim([M:POI1]TAXOTH1)>0  Raz [M:POI1]TAXOTH1(NOL) : Endif
  #If dim([M:POI1]TAXOTH2)>0  Raz [M:POI1]TAXOTH2(NOL) : Endif
Endif
[M:POI1]LINFLG(NOL)=1
#----- Ajustement date théorique de réception en fonction des indisponibilités -----#
If [M:POI1]LINTYP(NOL)<>4
  # Issue 87823 GA 02/2013 site courant Ko car modifié par INIT_COMPTES_LIGNE
  If [F:FCY]FCY<>[M:POI1]PRHFCY(NOL)
     Read [FCY] FCY0=[M:POI1]PRHFCY(NOL) : If fstat Raz [F:FCY] : Endif
  Endif
  Call CTL_JOU2([M:POI1]RETRCPDAT(NOL),[M:POI1]ORDDAT,[M:POI1]OFS(NOL)) From TRTACHCDE1
  If mkstat
    GMESSAGE=mess(245,194,1)-[M:POI1]PRHFCY(NOL)+"\"+GMESSAGE
    GMESSAGE=format$("D:"+GFMDAT,[M:POI1]RETRCPDAT(NOL))-GMESSAGE
    Call MESSAGE(GMESSAGE) From GESECRAN
  Endif
  Raz mkstat, GMESSAGE
  [M:POI1]EXTRCPDAT(NOL)=[M:POI1]RETRCPDAT(NOL)
#----- Pour les matières fournies, on reprend les valeurs du service -----#
Else
  [M:POI1]EXTRCPDAT(NOL)=[M:POI1]EXTRCPDAT(max(NOL-1,0))
  [M:POI1]RETRCPDAT(NOL)=[M:POI1]RETRCPDAT(max(NOL-1,0))
  [M:POI1]OFS      (NOL)=[M:POI1]OFS      (max(NOL-1,0))
Endif
#----- Traitement après ligne -----#
If ORIAPPEL=1
  #----- Traitement après ligne systématique si appel picking depuis NBLIG -----#
  [M:POI1]NBLIG+=1  : Call APRES_NBLIG From SUBPOI
Else
  #----- Traitement après ligne pour lignes après ligne courante -----#
  If NOL+1>SAVNOLIGN Call APRES_NBLIG From SUBPOI : Endif
Endif
Return


$EXPLOITE_PWO
#----------------------------------------------------------------------#
# Exploitation fichier de travail "Besoins pris en compte" d'une ligne #
#----------------------------------------------------------------------#
If !clalev([F:PWO])  Return : Endif
Local Char CLEFIC(60), SYMBOL2(30)
For [PWO] PWO0 Where PRONUM=[M:POI1]PRONUM
&                  & CODFNC="POI"
&                  & LINNUM=[M:POI1]POILIN(nolign-1)
  Gosub TRT_EXPLOITE_PWO From SUBPOHB : If GOK<1  Break : Endif
Next
If SYMBOL2<>"" Unlock=SYMBOL2 : Raz SYMBOL2 : Endif
Return


$AFF_TITCOL
#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables (comptes et sections analytiques) #
#------------------------------------------------------------------------#
If GSOC_UPDFLG & !GIMPORT & (dim([M:POI1]LINACC1)>0 | dim([M:POI1]CCE1)>0)
  Local Char BASPAG(10)
  BASPAG="NBLIG" : Gosub TIT_COL From ="W1WE3"+GPTRNUM+"9"
  #----- Pour forcer l'utilisation des formats évalués si tableau vide -----#
  If [M:POI1]NBLIG=0
    [M:POI1]NBLIG=1 : Affzo [POI1]20 : Effzo [POI1]20
  Endif
  #-----
Endif
Raz GSOC_UPDFLG
Return

# 106430.sn - Purchase planning
######################################################################################
Subprog UPDATE_CONTAINER (TCTRNUM,TCTRQTY)
Value Char    TCTRNUM
Value Integer TCTRQTY
Local Char    CURWEU(3), CURVOU(3)
Local Integer I
Local Decimal LINWEI, LINVOL

#Display updates only, don't run on import.
If GIMPORT : End : Endif

If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif
Read [TCTR]TCTR0 = [L]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

#Get the current UOMs
[L]CURWEU=[M:POI1]TCTRWEU
[L]CURVOU=[M:POI1]TCTRVOU

#Set the UOM for both weight and volume
If [F:TCTR]WEU=""
  [M:POI1]TCTRWEU = GSALDSPWEU
Else
  [M:POI1]TCTRWEU = [F:TCTR]WEU
Endif

If [F:TCTR]VOU=""
  [M:POI1]TCTRVOU = GSALDSPVOU
Else
  [M:POI1]TCTRVOU = [F:TCTR]VOU
Endif

If [L]TCTRNUM = ""
  Raz [M:POI1]TCTRQTY : Diszo [M:POI1]TCTRQTY
  Actzo [M:POI1]WEICAP, VOLCAP
Else
  Actzo [M:POI1]TCTRQTY

  #Set the weight and volume capacity for the container
  If [L]TCTRQTY <= 0 : [L]TCTRQTY=1 : Endif
  [M:POI1]WEICAP = [F:TCTR]MAXWEI  * [L]TCTRQTY
  [M:POI1]VOLCAP = [F:TCTR]TCTRVOL * [L]TCTRQTY

  Diszo [M:POI1]WEICAP, VOLCAP
Endif

If [L]CURWEU<>[M:POI1]TCTRWEU | [L]CURVOU<>[M:POI1]TCTRVOU
  For I=0 To [M:POI1]NBLIG-1
    #Reset the values back to product UOM
    [M:POI1]LINTCTRWEI(I) = [M:POI1]LINWEI(I)
    [M:POI1]LINTCTRVOL(I) = [M:POI1]LINVOL(I)

    # Call convert to convert if needed
    Call CONVERT_QTY([M:POI1]LINWEU(I),[M:POI1]TCTRWEU,[M:POI1]LINTCTRWEI(I))From TRTX3
    Call CONVERT_QTY([M:POI1]LINVOU(I),[M:POI1]TCTRVOU,[M:POI1]LINTCTRVOL(I))From TRTX3
  Next I
Endif

Affzo [M:POI1]TCTRWEU, TCTRVOU, WEICAP, VOLCAP

Call UPDATE_TCTRVOLWEI

End

######################################################################################
Subprog UPDATE_LINVOLWEI
Local Decimal TOTWEI, TOTVOL
Local Integer NOL, STAT

NOL = nolign-1

#Display updates only, don't run on import.
If GIMPORT : End : Endif

# Total up the lines
TOTWEI = [M:POI1]ITMWEI(NOL) * [M:POI1]QTYSTU(NOL)
TOTVOL = [M:POI1]ITMVOL(NOL) * [M:POI1]QTYSTU(NOL)

[M:POI1]LINWEI(NOL) = TOTWEI
[M:POI1]LINVOL(NOL) = TOTVOL
Call CONVERT_QTY([M:POI1]LINWEU(NOL),[M:POI1]TCTRWEU,TOTWEI)From TRTX3
Call CONVERT_QTY([M:POI1]LINVOU(NOL),[M:POI1]TCTRVOU,TOTVOL)From TRTX3
[M:POI1]LINTCTRWEI(NOL) = TOTWEI
[M:POI1]LINTCTRVOL(NOL) = TOTVOL

If [M:POI1]CUR(NOL) <> GLOCALDEV
  Call CONVERT ([M:POI1]CUR(NOL),GLOCALDEV,GLOCALDEV,[M:POI1]CHGTYP(NOL),[M:POI1]ORDDAT,[M:POI1]LINAMT(NOL),[M:POI1]LINAMTHCUR(NOL),STAT) From TRTDEV
Else
  [M:POI1]LINAMTHCUR(NOL)=[M:POI1]LINAMT(NOL)
Endif

Affzo [M:POI1]LINWEI(NOL), LINVOL(NOL)

End

######################################################################################
Subprog UPDATE_TCTRVOLWEI

#Display updates only, don't run on import.
If GIMPORT : End : Endif

Raz [M:POI1]WEIAVL, VOLAVL

# Get the total of all lines (already converted to container UOM or header currency)
[M:POI1]TOTCOST = sum([M:POI1]LINAMTHCUR)
[M:POI1]WEITOT  = sum([M:POI1]LINTCTRWEI)
[M:POI1]VOLTOT  = sum([M:POI1]LINTCTRVOL)
If [M:POI1]WEICAP > 0 : [M:POI1]WEIAVL = [M:POI1]WEICAP - [M:POI1]WEITOT : Endif
If [M:POI1]VOLCAP > 0 : [M:POI1]VOLAVL = [M:POI1]VOLCAP - [M:POI1]VOLTOT : Endif

Affzo [M:POI1]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST

End
######################################################################################
# 106430.en - Purchase planning

