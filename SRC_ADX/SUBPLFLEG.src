############################################################
#
# Library of Legislation procedures for Sessions screens
#
# Window  : OPLF
# Screens : PLF1
#
############################################################


########################################
#Display\Hide fields based on legislation
########################################
Subprog DISPLAY_HIDE()
Case GCURLEG
 When "FRA"

   #Chgfmt [M:PLF1]NATFIS       With "LA:10452"  #Fiscal nature
   Chgfmt [M:PLF1]NATFIS       With "K:5X"  #Fiscal nature
   #Chgfmt [M:PLF1]CATACN       With "LA:10453"  #Action category
   Chgfmt [M:PLF1]CATACN       With "K:5X"  #Action category
   Chgfmt [M:PLF1]CATFRT        With "K:10BX"
   #SBA 27/06/2012 : show/hide column title
   Chgfmt [M:PLF1]ZCATFRT       With "KP:20X"
   #TIVAN - 10/07/2017 - X3-35993 - Start
#   Chgfmt [M:PLF4]DESTYPFRTBUD  With "K:20AX"
#   Chgfmt [M:PLF4]DESTYPFRTBUD  With "LA:10455"
   Chgfmt [M:PLF4]DESTYPFRTBUD  With "K:20AX"
   #TIVAN - 10/07/2017 - X3-35993 - End
When Default
   #Chgfmt [M:PLF1]NATFIS       With "-LA:10452"  : Raz [M:PLF1]NATFIS : #Fiscal nature
     Chgfmt [M:PLF1]NATFIS       With "-K:5X"  : Raz [M:PLF1]NATFIS : #Fiscal nature
     #Chgfmt [M:PLF1]CATACN       With "-LA:10453"  : Raz [M:PLF1]CATACN : #Action category
   Chgfmt [M:PLF1]CATACN       With "-K:5X"  : Raz [M:PLF1]CATACN : #Action category
   Chgfmt [M:PLF1]CATFRT        With "-K:10AX"    : Raz [M:PLF1]CATFRT
   #SBA 27/06/2012 : show/hide column title
   Chgfmt [M:PLF1]ZCATFRT       With "-KP:20X"
   #TIVAN - 10/07/2017 - X3-35993 - Start
#   Chgfmt [M:PLF4]DESTYPFRTBUD  With "-K:20AX"
#   Chgfmt [M:PLF4]DESTYPFRTBUD  With "-LA:10455"  : Raz [M:PLF4]DESTYPFRTBUD
   Chgfmt [M:PLF4]DESTYPFRTBUD  With "-K:20AX"  : Raz [M:PLF4]DESTYPFRTBUD
   #TIVAN - 10/07/2017 - X3-35993 - End
Endcase
End

