#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SPRICESEARCH
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AINIT"            : #Gosub AINIT            : Return
          When "AREAD_AFTER"      : #Gosub AREAD_AFTER      : Return
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#--------------------------------------------------------------------------
$PROPERTIES
Case [L]CURPRO

Endcase

Return
#--------------------------------------------------------------------------
$AINIT

#  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.CPY","$isHidden","true")

Return
#--------------------------------------------------------------------------
$AREAD_AFTER

#  WATTRIBUT_CRIT        = "true"
#  WATTRIBUT_ADDCRIT     = "true"
#  WATTRIBUT_PRICERESULT = "true"
#  WATTRIBUT_PRICELIST   = "true"
#
#  Gosub MODIFY_ATTRIBUTS_ALL

Return
#--------------------------------------------------------------------------
$NEXT_CRITERIA

#  WATTRIBUT_CRIT        = "false"
#  Gosub MODIFY_ATTRIBUTS_CRITERIA
#
#  WATTRIBUT_ADDCRIT     = "false"
#  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA

Return
#--------------------------------------------------------------------------
$PRICESEARCH_MET

#  WATTRIBUT_PRICERESULT = "false"
#  WATTRIBUT_PRICELIST   = "false"
#
#  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
#  Gosub MODIFY_ATTRIBUTS_PRICE_LIST

Return
#--------------------------------------------------------------------------
$MODIFY_ATTRIBUTS_ALL

  Gosub MODIFY_ATTRIBUTS_CRITERIA
  Gosub MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA
  Gosub MODIFY_ATTRIBUTS_PRICE_RESULT
  Gosub MODIFY_ATTRIBUTS_PRICE_LIST

Return
#--------------------------------------------------------------------------
$MODIFY_ATTRIBUTS_CRITERIA

  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.STOFCY" ,"$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.DATEREF","$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.CURREF" ,"$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PLISTC" ,"$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PRITYP" ,"$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.QTYREF" ,"$isHidden",WATTRIBUT_CRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.SAUREF" ,"$isHidden",WATTRIBUT_CRIT)

  If WATTRIBUT_CRIT="false"

    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.STOFCY" ,"$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.DATEREF","$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.CURREF" ,"$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PLISTC" ,"$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PRITYP" ,"$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.QTYREF" ,"$isDisabled","false")
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.SAUREF" ,"$isDisabled","false")
  Endif

Return
#--------------------------------------------------------------------------
$MODIFY_ATTRIBUTS_ADDITIONAL_CRITERIA

  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.BPAADD"    ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.VACBPR"    ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.VACBPR_LEG","$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PTE"       ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PTE_LEG"   ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.MDL"       ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.EECICT"    ,"$isHidden",WATTRIBUT_ADDCRIT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PJT"       ,"$isHidden",WATTRIBUT_ADDCRIT)

  If WATTRIBUT_ADDCRIT="false"
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.BPAADD"    ,"$isDisabled",WATTRIBUT_ADDCRIT)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.VACBPR"    ,"$isDisabled",WATTRIBUT_ADDCRIT)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PTE"       ,"$isDisabled",WATTRIBUT_ADDCRIT)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.MDL"       ,"$isDisabled",WATTRIBUT_ADDCRIT)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.EECICT"    ,"$isDisabled",WATTRIBUT_ADDCRIT)
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.PJT"       ,"$isDisabled",WATTRIBUT_ADDCRIT)
  Endif

Return
#--------------------------------------------------------------------------
$MODIFY_ATTRIBUTS_PRICE_RESULT

  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.C_PRICE.LIBPRIX"   ,"$isHidden",WATTRIBUT_PRICERESULT)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SPRISEA.C_PRICE.GROPRI"    ,"$isHidden",WATTRIBUT_PRICERESULT)
