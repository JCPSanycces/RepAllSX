#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################
##  Contrôle du RIB                                    ###
##########################################################
Subprog RIB(RIB,SPSTAT)
Value Char RIB()
Variable Integer SPSTAT

Local Integer I,J,K
Local Char TCPT(20)


If     RIB=""      : SPSTAT=0 : End
Elsif len(RIB)<>23 : SPSTAT=2 : End
Endif


I = mod(val(left$(RIB,10)),97)
TCPT = ""
For J=11 To 21
 K = ascii(mid$(RIB,J,1))
 If K>=83 : K-=81-48
 Elsif K>=74 : K-=73-48
 Elsif K>=65 : K -= 64-48
 Endif
 TCPT += chr$(K)
Next J
I = mod(val(num$(I)+TCPT+mid$(RIB,22,2)),97)
If I=0 : SPSTAT=0
Else   : SPSTAT=1
Endif
End

##########################################################
##  Contrôle du SIRET ou du SIREN                      ###
##########################################################
Subprog SIRET(SIRET,SITE,SPSTAT)
Variable Char SIRET()
Value    Char SITE
Variable Integer SPSTAT

Local Integer I,N1,N2,N3,N4

SPSTAT = 0
If SIRET=""          : End
Elsif len(SIRET)<>14 & len(SIRET)<>9 : SPSTAT=2
Elsif SIRET=string$(14,"0") : SPSTAT=1
Else
 For I=1 To len(SIRET)
  If mid$(SIRET,I,1)<"0" | mid$(SIRET,I,1)>"9"
   SPSTAT=1 : Break
  Endif
 Next I
Endif
If SPSTAT : End : Endif

N1=0 : N2=0 : N3=1 : N4=0
For I=1 To 9
 N4=N3*val(mid$(SIRET,I,1))
 N1=N1+mod(N4,10)+int(N4/10)
 N3=3-N3
Next I

# Vilab 12-06-13 gestion SIRET La Poste
#Nouvel algorithme de vérification de la clé des NIC des établissements de La Poste (SIREN 356 000 000)
#LES SIREN ET SIRET CONTINUENT DE COMPORTER RESPECTIVEMENT 9 ET 14 CHIFFRES. LA CLÉ DE CONTRÔLE EXISTANTE EST MAINTENUE POUR TOUS LES SIRET AUTRES QUE CEUX DES ÉTABLISSEMENTS DE LA POSTE.
#Pour les SIRET de La Poste, un nouvel algorithme est proposé pour permettre d'immatriculer jusqu'à 18 000 établissements environ, soit presque deux fois plus que dans le cas général, tout en
# maintenant un contrôle sur l'identifiant.
#Tous les utilisateurs qui font des contrôles de clé devront adapter leur système informatique, de la façon suivante :
#Si SIREN <> 356 000 000 , alors effectuer contrôle A sur le Siret
#Si SIREN = 356 000 000 , alors effectuer contrôle B sur le Siret
#avec :
#Contrôle A (algorithme habituel de contrôle du SIRET composé de 14 chiffres) :
#-          on multiplie les chiffres de rang impair à partir de la droite par 1, ceux de rang pair par 2 ;
#-          la somme des chiffres obtenus doit être congrue à 0 modulo 10, c'est-à-dire qu'elle doit être multiple de 10.
#Contôle B (nouvel algorithme de contrôle du SIRET pour le SIREN 356 000 000) :
#-          le SIRET ne doit pas vérifier l'algorithme de contrôle de clé d'un siret classique (contrôle A) ;
#la somme simple des chiffres du SIRET doit être congrue à 0 modulo 5, c?est à dire qu'elle doit être un multiple de 5.

If len(SIRET)=14
 If left$(SIRET,9)<>"356000000" or SIRET="35600000000048"
   N3=2
    For I=1 To 14
     N4=N3*val(mid$(SIRET,I,1))
     N2=N2+mod(N4,10)+int(N4/10)
     N3=3-N3
    Next I
 Else
    For I=1 To 14
     N4=val(mid$(SIRET,I,1))
     N2=N2+mod(N4,10)+int(N4/10)
    Next I
 Endif
Endif
If (left$(SIRET,9)<>"356000000" & !(mod(N1,10)=0 & mod(N2,10)=0)) | (left$(SIRET,9)="356000000" &!(mod(N1,10)=0 & mod(N2,5)=0))
 SPSTAT=1 : End
Endif

#If len(SIRET)=14
# N3=2
# For I=1 To 14
#  N4=N3*val(mid$(SIRET,I,1))
#  N2=N2+mod(N4,10)+int(N4/10)
#  N3=3-N3
# Next I
#Endif
#If !(mod(N1,10)=0 & mod(N2,10)=0)
# SPSTAT=1 : End
#Endif

If len(SIRET)=14 & SITE<>""
 If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
 I = find(SITE,GSITE(1..GNBSITE))
 If I
  Read [CPY]CPY0 = GSOCSITE(I)
 Elsif GFONCTION="GESFCY" & dim([M:CPY1]LEGCPY)>0 : # cas où on est en train de créer ce site
  Read [CPY]CPY0 = [M:CPY1]LEGCPY
 Else
  Raz [F:CPY]
 Endif
 If !fstat & [F:CPY]CRN<>"" & left$(SIRET,9)<>left$([F:CPY]CRN,9)
  SPSTAT = 3
 Endif
 Close Local File [CPY]
Endif
If SPSTAT : End : Endif
End

##########################################################
##  Contrôle du Numéro TVA                             ###
##########################################################
Subprog TVA(TVA,SPSTAT)
Value Char TVA()
Variable Integer SPSTAT

If TVA='' : SPSTAT=0 : End : Endif

Local Char    SIRET(GLONCRN)
Local Integer N1 , N3 , N4

SIRET=right$(TVA,5)
If len(SIRET)<>9 : SPSTAT=1 : End : Endif

N1=0 : N3=1 : N4=0
For I=1 To 9
 N4=N3*val(mid$(SIRET,I,1))
 N1=N1+mod(N4,10)+int(N4/10)
 N3=3-N3
Next I
If mod(N1,10)=0
 SPSTAT=0
Else
 SPSTAT=1
Endif
End

######################################################
##  Contrôle du no d'immatriculation sociale       ###
######################################################
Subprog SS(NOSS,ETR,SEX,DNAISS,DEPT,COMNNO,SPSTAT)
Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

Local Char NO(13), CLE(2), MSG(240), CHAN(2), CHMOIS(2)
Local Integer OK
#50858
Local Char CTLNO(13)

SPSTAT=0
NO=left$(NOSS,13)
CLE=right$(NOSS,14)

#50858
If instr(1,NO,"A")
 CTLNO = ctrans(NO,"A","0")
 CTLNO = num$(val(CTLNO)-1000000)
Elsif instr(1,NO,"B")
 CTLNO = ctrans(NO,"B","0")
 CTLNO = num$(val(CTLNO)-2000000)
Else
 CTLNO = NO
Endif
# fin 50858

If val(CLE)<>0
 #50858
 #N1=97-mod(val(NO),97)
 N1=97-mod(val(CTLNO),97)
 If val(CLE)<>N1 : SPSTAT=1 : End
 Endif
Endif
MSG=""
If left$(NO,1)<>num$(SEX) & left$(NO,1)<>num$(SEX+6)
 # No incompatible avec le sexe
 MSG+=mess(144,105,1)+"\"
Endif
If !find(left$(NO,1),"7","8")
 If DNAISS<>[0/0/0]
  CHAN=format$("D:YY",DNAISS) : CHMOIS=format$("D:MM",DNAISS)
  If mid$(NO,2,2)<>CHAN
   # No incompatible avec l'année de naissance
   MSG+=mess(145,105,1)+"\"
  Endif
  If mid$(NO,4,2)<>CHMOIS
   # No incompatible avec le mois de naissance
   MSG+=mess(146,105,1)+"\"
  Endif
 Endif
#49599
 #If ETR=1 & DEPT<>"" & mid$(NO,6,2)<>format$("N0:#B",DEPT)
 If ETR=1 & DEPT<>""
  If (DEPT="2A" | DEPT="2B") &  DNAISS<[01/01/1976] & mid$(NO,6,2)<>"20"
   # No incompatible avec le département de naissance
   MSG+=mess(147,105,1)+"\"
  Elsif (DEPT="2A" | DEPT="2B") & DNAISS>=[01/01/1976] & mid$(NO,6,2)<>format$("K:#B",DEPT)
   # No incompatible avec le département de naissance
   MSG+=mess(147,105,1)+"\"
  Elsif DEPT<>"2A" & DEPT<>"2B" & mid$(NO,6,2)<>format$("K:#B",DEPT)
   # No incompatible avec le département de naissance
   MSG+=mess(147,105,1)+"\"
  Endif
 Endif
 # fin 49599
 #49599
 #If ETR=1 & COMNNO<>"" & mid$(NO,8,3)<>right$(format$("N0:5#",COMNNO),3)
 If ETR=1 & COMNNO<>"" & mid$(NO,8,3)<>right$(format$("K:#B###",COMNNO),3)
  # No incompatible avec la commune de naissance
  MSG+=mess(148,105,1)+"\"
 Endif
Endif
If MSG<>""
 MSG=left$(MSG,len(MSG)-1)
 OK=1 : Call AVERTIR(MSG,OK) From GESECRAN
 If OK=1 : SPSTAT=3 : Endif
Endif
End

######################################################
##  Contrôle du no d'immatriculation sociale n°2   ###
######################################################
Subprog SS2(NOSS,ETR,SEX,DNAISS,DEPT,COMNNO,SPSTAT)
Value Char NOSS(), DEPT(), COMNNO()
Value Integer SEX
Value Date DNAISS
Value Libelle ETR : # =1 si non etranger
Variable Integer SPSTAT

End

###############################################################
##  Valeur par défaut du no d'immatriculation sociale       ###
###############################################################
Subprog VDSS(ETR,SEX,DNAISS,DEPT,COMNNO,NOSS)
Value Libelle ETR : # =1 si non etranger
Value Integer SEX
Value Date DNAISS
Value Char DEPT
Value Char COMNNO
Variable Char NOSS()

If clalev([F:TCY])>0 & [F:TCY]CRY="FR" Then
  NOSS=num$(SEX)

  If DNAISS<>[0/0/0]
    NOSS+=format$("D:YYMM",DNAISS)
    If ETR=1 & DEPT<>""
      If (DEPT="2A" |DEPT="2A")
        If year(DNAISS)<1976
          NOSS+="20"
        Else
          NOSS+=DEPT
        Endif
      Else
        NOSS+=format$("N0:#B",DEPT)
      Endif
      NOSS+=format$("N0:3#",right$(COMNNO,3))
    Endif
#    For I=len(NOSS) To 1 Step -1
#      If mid$(NOSS,I,1)<>"0" : NOSS=left$(NOSS,I) : Break : Endif
#    Next I
  Endif
Endif
End

Subprog VDSS2(ETR,SEX,DNAISS,DEPT,COMNNO,NOSS)
Value Libelle ETR : # =1 si non etranger
Variable Char NOSS()
Value Integer SEX
Value Date DNAISS
Value Char DEPT
Value Char COMNNO

End

#######################################################################
##   Mise à jour de l'enregistrement DEB : echanges CEE              ##
##     traitement des arrondis                                       ##
##-------------------------------------------------------------------##
##  Flux :  11 Introduction Achats     12 Introduction Ventes        ##
##          21 Expedition   Achats     22 Expedition   Ventes        ##
#######################################################################
Subprog DEB (FLUX, SPSTAT)
Value    Integer FLUX
Variable Integer SPSTAT

#---Si Expédition et Régime <> 29 et pas de n° d'identification CEE
#--la ligne n'est pas extraite
#--FQ 52809 - également régime "FR29"
If [F:DEB]FLO=2 and [F:DEB]EECSCH <> "29" and [F:DEB]EECSCH <> "FR29" :# Expédition et Régime
  If [F:DEB]EECNUM=""
    SPSTAT=1 : End
  Endif
Endif

If [F:DEB]STAAMT    : # valeur statistique
   If mod([F:DEB]STAAMT,int([F:DEB]STAAMT)) = 0.5
      [F:DEB]STAAMT = arr([F:DEB]STAAMT,1)-1
   Else
      [F:DEB]STAAMT = arr([F:DEB]STAAMT,1)
   Endif
Endif

If [F:DEB]FISAMT    : # valeur fiscale
   If mod([F:DEB]FISAMT,int([F:DEB]FISAMT)) = 0.5
      [F:DEB]FISAMT = arr([F:DEB]FISAMT,1)-1
   Else
      [F:DEB]FISAMT = arr([F:DEB]FISAMT,1)
   Endif
Endif

If [F:DEB]EECUNT    : # unites CEE
   [F:DEB]EECUNT=arr([F:DEB]EECUNT,1)
   If [F:DEB]EECUNT=0 [F:DEB]EECUNT=1 Endif
Endif

If [F:DEB]NETMAS    : # masse nette
   If [F:DEB]NETMAS < 0.5
      [F:DEB]NETMAS = 0
   Elsif [F:DEB]NETMAS < 1.5
     [F:DEB]NETMAS = 1
   Else
     [F:DEB]NETMAS=arr([F:DEB]NETMAS,1)
   Endif
Endif

End

