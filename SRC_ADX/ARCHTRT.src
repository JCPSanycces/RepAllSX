#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ARCHTRT","ARCHTRT",4,"XYARCHTRT") From GTRAITE
End

#-----------------------------------------------#
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "DEBUT"    : Gosub DEBUT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Char    MACARC(GDIMFIC) , DOSARC(GDIMFIC)
Local Char    MACREP(GDIMFIC) , DOSREP(GDIMFIC)
Local Char    FICADX_ARC(GDIMFIC) , FICADX_REP(GDIMFIC)
Local Char    FICSRC_ARC(GDIMFIC) , FICSRC_REP(GDIMFIC)
Local Char    FICXRC_ARC(GDIMFIC)
Local Char    MESSAGE(250)(1..3) , ORDSYS(250)(1..2) , OPT(10)
Local Char    NAMADX(250) , SUFADX(30) , NAMSRC(250) , SUFSRC(30)
Local Integer STAT , K , OK
Local Mask ARCHTRT [DIA]
Local File APARIMPEXP [APX]
TMP = 1
Return

$DEBUT
Raz [M]TRT
Gosub GRISE_TYP
Gosub GRISE_REP
Affzo
Return

$CONTROLE
If GSTATUT=GSTAESC : FIN = 1 : Endif
Return

$EXEC
ORDSYS(2) = filpath("tmp",[M]TRT,"tra",[M]DOSSIER)
If filinfo(ORDSYS(2),0)>0
 Call EFFACE(ORDSYS(2),STAT) From ORDSYS
Endif
K = instr(1,[M]DOSSIER,"@")
If K
 MACARC = left$([M]DOSSIER,K-1)
 DOSARC = right$([M]DOSSIER,K+1)
Else
 MACARC = ""
 DOSARC = [M]DOSSIER
Endif
If [M]TYPEXP=1
 MACREP = ""
 DOSREP = ""
 Call SET_NAMCLI(DOSREP) From ORDSYS
Else
 K = instr(1,[M]REPERT,"@")
 If K
  MACREP = left$([M]REPERT,K-1)
  DOSREP = right$([M]REPERT,K+1)
 Else
  MACREP = ""
  DOSREP = [M]REPERT
 Endif
Endif
Case [M]OPTION
 When 1 : # Extraction de l'archive
  OK = 1
  If filinfo(filpath("TRT",[M]TRT,"adx",[M]DOSSIER),7)<0
   Call ECR_TRACE(mess(090,123,1),1) From GESECRAN : #  : Traitement inexistant
   OK = 0
  Endif
  If OK
   FICADX_ARC = filpath("TRT",[M]TRT,"adx",[M]DOSSIER)
   FICSRC_ARC = filpath("TRT",[M]TRT,"src",[M]DOSSIER)
   If [M]TYPEXP=1
    FICADX_REP = DOSREP+[M]TRT+".adx"
    FICSRC_REP = DOSREP+[M]TRT+".src"
    Call COPCLI(FICADX_ARC,FICADX_REP,STAT) From ORDSYS
    If STAT<>0 : Return : Endif
    Call SETNAM(FICADX_REP,NAMADX,SUFADX) From GOBJTXT
    If SUFADX<>"adx"
     # Traitement incorrect
     Call ECR_TRACE(NAMADX+"."+SUFADX-":"-mess(13,123,1),-1) From GESECRAN
    Endif
    If [M]SRC=2
     Call COPCLI(FICSRC_ARC,FICSRC_REP,STAT) From ORDSYS
     If STAT=0
      Call SETNAM(FICSRC_REP,NAMSRC,SUFSRC) From GOBJTXT
      If SUFSRC<>"src"
       # Traitement incorrect
       Call ECR_TRACE(NAMSRC+"."+SUFSRC-":"-mess(13,123,1),-1) From GESECRAN
      Elsif NAMSRC<>NAMADX
       # Traitement incorrect
       Call ECR_TRACE(NAMSRC+"."+SUFSRC-"<>"-NAMADX+"."+SUFADX-":"-mess(13,123,1),-1) From GESECRAN
      Endif
     Endif
    Endif
   Else
    If MACREP<>""
     FICADX_REP = filpath(DOSREP,[M]TRT,"adx","","",MACREP)
     FICSRC_REP = filpath(DOSREP,[M]TRT,"src","","",MACREP)
    Else
     FICADX_REP = filpath(DOSREP,[M]TRT,"adx")
     FICSRC_REP = filpath(DOSREP,[M]TRT,"src")
    Endif
    Call COPIE(FICADX_ARC,FICADX_REP,STAT) From ORDSYS
    If [M]SRC=2
     If filinfo(FICSRC_ARC,0)>0
      Call COPIE(FICSRC_ARC,FICSRC_REP,STAT) From ORDSYS
     Else
      Call ECR_TRACE([M]TRT+".src"-":"-mess(90,123,1),1) From GESECRAN : # Traitement inexistant
     Endif
    Endif
   Endif
   Call VARADX("ADXGEN",MACARC,OPT) From ADXD
   If OPT="FALSE" & filinfo(filpath("FIL","ADOSSIER","fde",[M]DOSSIER),0)<=0
    Call EFFACE(FICADX_ARC,STAT) From ORDSYS
   Endif
  Endif
 When 2 : # Intégration dans l'archive
  FICADX_ARC = filpath("TRT",[M]TRT,"adx",[M]DOSSIER)
  FICSRC_ARC = filpath("TRT",[M]TRT,"src",[M]DOSSIER)
  FICXRC_ARC = filpath("TRT",[M]TRT,"xrc",[M]DOSSIER)
  If [M]TYPEXP=1
   FICADX_REP = DOSREP+[M]TRT+".adx"
   FICSRC_REP = DOSREP+[M]TRT+".src"
   Call COPSRV(FICADX_REP,FICADX_ARC,STAT) From ORDSYS
   If STAT<>0 : Return : Endif
   Call SETNAM(FICADX_REP,NAMADX,SUFADX) From GOBJTXT
   If SUFADX<>"adx"
    # Traitement incorrect
    Call ECR_TRACE(NAMADX+"."+SUFADX-":"-mess(13,123,1),1) From GESECRAN
    Return
   Endif
   If [M]SRC=2
    Call COPSRV(FICSRC_REP,FICSRC_ARC,STAT) From ORDSYS
    If STAT=0
     Call SETNAM(FICSRC_REP,NAMSRC,SUFSRC) From GOBJTXT
     If SUFSRC<>"src"
      # Traitement incorrect
      Call ECR_TRACE(NAMSRC+"."+SUFSRC-":"-mess(13,123,1),1) From GESECRAN
     Elsif NAMSRC<>NAMADX
      # Traitement incorrect
      Call ECR_TRACE(NAMSRC+"."+SUFSRC-"<>"-NAMADX+"."+SUFADX-":"-mess(13,123,1),1) From GESECRAN
     Endif
    Endif
   Endif
  Else
   If MACREP<>""
    FICADX_REP = filpath(DOSREP,[M]TRT,"adx","","",MACREP)
    FICSRC_REP = filpath(DOSREP,[M]TRT,"src","","",MACREP)
   Else
    FICADX_REP = filpath(DOSREP,[M]TRT,"adx")
    FICSRC_REP = filpath(DOSREP,[M]TRT,"src")
   Endif
   Call COPIE(FICADX_REP,FICADX_ARC,STAT) From ORDSYS
   If [M]SRC=2
    If filinfo(FICSRC_REP,0)>0
     Call COPIE(FICSRC_REP,FICSRC_ARC,STAT) From ORDSYS
    Else
     Call ECR_TRACE([M]TRT+".src"-":"-mess(90,123,1),1) From GESECRAN : # Traitement inexistant
    Endif
    If filinfo(FICXRC_ARC,0)>0
     Call EFFACE(FICXRC_ARC,STAT) From ORDSYS
    Endif
   Endif
  Endif
  # on vire le traitement dans l'archive
  If DOSARC=""
   ORDSYS(1) = 'archive -d'-nomap-'-t'-'-e'-'"'+[M]TRT+'"'
  Else
   ORDSYS(1) = 'archive -d'-DOSARC-'-t'-'-e'-'"'+[M]TRT+'"'
  Endif
  If MACARC=""
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Else
   Call SYSTEME(MACARC,ORDSYS,"",STAT) From ORDSYS
  Endif
  # On l'intègre
  If DOSARC=""
   ORDSYS(1) = 'archive -d'-nomap-'-t'-'-s'-'"'+[M]TRT+'"'
  Else
   ORDSYS(1) = 'archive -d'-DOSARC-'-t'-'-s'-'"'+[M]TRT+'"'
  Endif
  If MACARC=""
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Else
   Call SYSTEME(MACARC,ORDSYS,"",STAT) From ORDSYS
  Endif
  Gosub STA
  If OK
   Call VARADX("ADXGEN",MACARC,OPT) From ADXD
   If OPT="FALSE" & filinfo(filpath("FIL","ADOSSIER","fde",[M]DOSSIER),0)<=0
    Call EFFACE(FICADX_ARC,STAT) From ORDSYS
   Endif
   Call ECR_TRACE([M]TRT-":"-mess(240,139,1),0) From GESECRAN : # Traitement archivé
  Endif
 When 3 : # Suppression de l'archive
  If DOSARC=""
   ORDSYS(1) = 'archive -d'-nomap-'-t'-'-e'-'"'+[M]TRT+'"'
  Else
   ORDSYS(1) = 'archive -d'-DOSARC-'-t'-'-e'-'"'+[M]TRT+'"'
  Endif
  If MACARC=""
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
  Else
   Call SYSTEME(MACARC,ORDSYS,"",STAT) From ORDSYS
  Endif
  Gosub STA
  If OK
   Call ECR_TRACE([M]TRT-":"-mess(241,139,1),0) From GESECRAN : # Traitement supprimé
   FICADX_ARC = filpath("TRT",[M]TRT,"adx",[M]DOSSIER)
   If filinfo(FICADX_ARC,0)>0
    Call EFFACE(FICADX_ARC,STAT) From ORDSYS
   Endif
   If [M]SRC=2 
    FICSRC_ARC = filpath("TRT",[M]TRT,"src",[M]DOSSIER)
    If filinfo(FICSRC_ARC,0)>0
     Call EFFACE(FICSRC_ARC,STAT) From ORDSYS
    Endif
    FICXRC_ARC = filpath("TRT",[M]TRT,"xrc",[M]DOSSIER)
    If filinfo(FICXRC_ARC,0)>0
     Call EFFACE(FICXRC_ARC,STAT) From ORDSYS
    Endif
   Endif
  Endif
Endcase
adxmpr = adxmpr
SAI = 1
Return

$STA
OK = 1
Openi ORDSYS(2) Using [TR_]
Iomode adxifs "" Using [TR_]
Iomode adxirs chr$(10) Using [TR_]
Iomode adxium GUTF8 Using [TR_]
Raz MESSAGE
Rdseq MESSAGE(1) Using [TR_]
Rdseq MESSAGE(2) Using [TR_]
Rdseq MESSAGE(3) Using [TR_]
Openi Using [TR_]
If MESSAGE(1)<>""
 Call ECR_TRACE("|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
 OK = 0
Endif
Return

######################################
Subprog IB_TRT
Raz GBOUTS , GBOUT1
Case [M]OPTION
 When 1,3 : GBOUTS = mess(18,100,1) : # Sélection
 When 2   : GBOUT1 = mess(18,100,1) : # Sélection
Endcase
End

Subprog B1_TRT(VALEUR)
Variable Char VALEUR
Local Char    CHEMIN(GDIMFIC)
Local Char    MACREP(GDIMFIC) , DOSREP(GDIMFIC)
Local Integer K , I
If [M]TYPEXP=1
 Call SET_NAMCLI([L]CHEMIN) From ORDSYS
 [L]CHEMIN = "#@"+[L]CHEMIN+"*.adx"
Else
 K = instr(1,[M]REPERT,"@")
 If K
  MACREP = left$([M]REPERT,K-1)
  DOSREP = right$([M]REPERT,K+1)
 Else
  MACREP = ""
  DOSREP = [M]REPERT
 Endif
 If VALEUR<>""
  If MACREP<>""
   [L]CHEMIN = filpath(DOSREP,VALEUR,"adx","","",MACREP)
  Else
   [L]CHEMIN = filpath(DOSREP,VALEUR,"adx") 
  Endif
 Else
  If MACREP<>""
   [L]CHEMIN = filpath(DOSREP,"","","","",MACREP)
  Else
   [L]CHEMIN = filpath(DOSREP,"","") 
  Endif
 Endif
Endif
Call SELFICREP(CHEMIN) From SELFICREP
If find(right$(CHEMIN,len(CHEMIN)-2),"adx","src")
 K = 0
 For I=len(CHEMIN) To 1 Step -1
  If instr(1,"/\",mid$(CHEMIN,I,1))
   K = I : Break
  Endif
 Next I
 If K
  VALEUR = seg$(CHEMIN,K+1,len(CHEMIN)-4)
 Endif
Endif
End

Subprog C_TRT(VALEUR)
Variable Char    VALEUR()
Local Char    MACARC(GDIMFIC) , DOSARC(GDIMFIC)
Local Char    MACREP(GDIMFIC) , DOSREP(GDIMFIC)
Local Char    CHEMIN(GDIMFIC) , FICHIER(GDIMFIC)
Local Integer OKTRT , I , K , OK
K = instr(1,[M]DOSSIER,"@")
If K
 MACARC = left$([M]DOSSIER,K-1)
 DOSARC = right$([M]DOSSIER,K+1)
Else
 MACARC = ""
 DOSARC = [M]DOSSIER
Endif
If DOSARC<>""
 OK = (filinfo(filpath("","archive","atx",[M]DOSSIER),0)>0)
Else
 OK = (filinfo(filpath("","archive","atx"),0)>0)
Endif
If !OK : End : Endif
If [M]TYPEXP=1
 MACREP = "#"
 DOSREP = ""
 [L]CHEMIN = ""
Else
 K = instr(1,[M]REPERT,"@")
 If K
  MACREP = left$([M]REPERT,K-1)
  DOSREP = right$([M]REPERT,K+1)
 Else
  MACREP = ""
  DOSREP = [M]REPERT
 Endif
 If MACREP<>""
  [L]CHEMIN = filpath(DOSREP,VALEUR,"adx","","",MACREP)
 Else
  [L]CHEMIN = filpath(DOSREP,VALEUR,"adx")
 Endif
Endif
Case [M]OPTION
 When 1 : # Extraction de l'archive
  Call EXISTE_ADX(MACARC,DOSARC,VALEUR,OKTRT) From ORDSYS
  If !OKTRT
   Call ERREUR(mess(158,139,1)) From GESECRAN : # Traitement inexistant dans l'archive
   mkstat = 2 : End
  Endif
  FICHIER = filpath("TRT",VALEUR,"src",[M]DOSSIER)
  Gosub GRISE_SRC
 When 2 : # Intégration dans l'archive
  If filinfo(CHEMIN,0)<=0
   Call ERREUR("|"+CHEMIN-"|:"-mess(101,100,1)) From GESECRAN : # Fichier inexistant
   mkstat = 2 : End
  Else
   Call EXISTE_ADX(MACARC,DOSARC,VALEUR,OKTRT) From ORDSYS
   If OKTRT
    # Traitement existant dans l'archive du dossier\Voulez-vous continuer ?
    Call AVERTIR(mess(159,139,1)-DOSARC+"\"+mess(205,100,1),OKTRT) From GESECRAN
    If OKTRT<>2 : mkstat = 2 : End : Endif
   Endif
  Endif
  If MACREP<>""
   FICHIER = filpath(DOSREP,VALEUR,"src","","",MACREP)
  Else
   FICHIER = filpath(DOSREP,VALEUR,"src")
  Endif
  Gosub GRISE_SRC
 When 3 : # Suppression
  Call EXISTE_ADX(MACARC,DOSARC,VALEUR,OKTRT) From ORDSYS
  If !OKTRT
   Call ERREUR(mess(158,139,1)) From GESECRAN : # Traitement inexistant dans l'archive
   mkstat = 2 : End
  Endif
  FICHIER = filpath("TRT",VALEUR,"src",[M]DOSSIER)
  Gosub GRISE_SRC
Endcase
End

$GRISE_SRC
If [M]TYPEXP=1
 Actzo SRC
Elsif filinfo(FICHIER,0)>0
 Actzo SRC
Else
 SRC = 1
 Affzo SRC
 Grizo SRC
Endif 
Return

Subprog D_DOSSIER(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSSIER(VALEUR)
Variable Char    VALEUR()
If !GMODIF : mkstat = 2 : Endif
GMODIF = 1
End

Subprog C_DOSSIER(VALEUR)
Variable Char VALEUR
End

Subprog C_REPERT(VALEUR)
Variable Char    VALEUR()
Local Char    MACARC(GDIMFIC) , DOSARC(GDIMFIC)
Local Char    MACREP(GDIMFIC) , DOSREP(GDIMFIC)
Local Char    CHEMIN(GDIMFIC) , CHEMIN2(GDIMFIC)
Local Integer OKTRT , I , K , OK
K = instr(1,[M]DOSSIER,"@")
If K
 MACARC = left$([M]DOSSIER,K-1)
 DOSARC = right$([M]DOSSIER,K+1)
Else
 MACARC = ""
 DOSARC = [M]DOSSIER
Endif
If DOSARC<>""
 CHEMIN = filpath("TRT","","",[M]DOSSIER)
Else
 CHEMIN = filpath("TRT","","")
Endif
K = instr(1,VALEUR,"@")
If K
 MACREP = left$(VALEUR,K-1)
 DOSREP = right$(VALEUR,K+1)
Else
 MACREP = ""
 DOSREP = VALEUR
Endif
If MACREP="#"
 Call ERREUR(mess(162,141,1)) From GESECRAN : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Elsif MACREP<>""
 CHEMIN2 = filpath(DOSREP,"","","","",MACREP)
Else
 CHEMIN2 = filpath(DOSREP,"","")
Endif
If CHEMIN=CHEMIN2
 Call ERREUR("|"+CHEMIN2-":"-mess(203,139,1)) From GESECRAN : # Répertoire non autorisé
 mkstat = 2 : End
Endif
Call EXISTE(VALEUR,OK) From ORDSYS
Case OK
 When 0 : # Fichier inexistant
  Call ERREUR("|"+VALEUR-"|\"-mess(9,141,1)) From GESECRAN : # Répertoire inexistant
  mkstat = 2 : End
 When 1 : # C'est un fichier, pas un répertoire
  Call ERREUR("|"+VALEUR-"|\"-mess(117,139,1)) From GESECRAN : # Ce fichier n'est pas un répertoire
  mkstat = 2 : End
 When 2 : # C'est bien un répertoire
Endcase
End

Subprog AM_OPTION(VALEUR)
Variable Integer VALEUR
[M]OPTION = VALEUR
Gosub GRISE_TYP
Gosub GRISE_REP
End

$GRISE_TYP
Case [M]OPTION
 When 3
  [M]TYPEXP = 0 : Affzo TYPEXP : Grizo TYPEXP
 When Default
  If [M]TYPEXP=0 : [M]TYPEXP = 2 : Affzo TYPEXP : Endif
  Actzo TYPEXP
Endcase
Return

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
[M]TYPEXP = VALEUR
Gosub GRISE_REP
End

$GRISE_REP
Call SET_NOMFIC("",[M]REPERT,[M]DOSSIER,[M]TYPEXP)
If [M]TYPEXP=1
 Grizo [M]REPERT
Else
 Actzo [M]REPERT
Endif
Return

Subprog SET_NOMFIC(FICHIER,NOMEXP,DOSSIER,TYPEXP)
Value Char FICHIER
Variable Char NOMEXP
Value    Char DOSSIER
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
Local Char    REPTMP(GDIMFIC)
NOMEXP = FICHIER
If TYPEXP=1
 Call SET_NAMCLI(NOMEXP) From ORDSYS
Elsif !instr(1,NOMEXP,"@") & !find(left$(NOMEXP,1),"/") & !pat(left$(NOMEXP,3),"!:\")
 Call GETREP("REPEXPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  Call SETFIC(REPERT,FICHIER,MACHINE,NOMEXP) From SUBEXPOBJ
 Endif
 If REPERT=""
  REPTMP = filpath("tmp","","",DOSSIER)
  If filinfo(REPTMP,0)>0
   [M]REPERT = REPTMP
  Endif
 Endif
Endif
End

