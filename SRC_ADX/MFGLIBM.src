#<AdxTL>@(#)11.0.0.0 $Revision$
#################################################################
# Librairie de sous-programme de gestion des matières   MFGLIBM #
## modif le 240101   par HCB  rubrique PKC  (code a servir)     #
#################################################################
# Subprog UPDMAT(L, LMSG)                                       #
# Subprog GENMAT(L,CDAT)                                        #
# Subprog CREMAT(LFCY,LITM,LALT,LDAT,LQTY,LLOT,LRET,LOPE,LOFS)  #
# Subprog DISPLAY_MAT                                           #
# (L,LLIG,WLIEN, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,WBAS,LGHOST) #
# Subprog SUPMAT(L)                                             #
# Subprog UPD_MAT_QTY(L, LQTY)                                  #
# Subprog UPD_MAT_SEQ(L)                                        #
# Subprog UPD_MAT_DAT(WORIDAT)                                  #
# Subprog UPD_MAT_PJT(L, LPJT)                                  #
# Subprog TRI_MAT (S)                                           #
# Subprog GETLINE(L)                                            #
# Subprog UPDATE_MFX(LCOD, LPJT, LALT, LMOD)                    #
# Subprog UPDATE_ALL(LCOD)                                      #
# Subprog CALCUL_BESOIN(WBASQTY,WLIKQTYCOD,WLIKQTY,             #
# &                     WQTYRND,WSCA,WLIEN,WQTY)                #
# Subprog CAL_AVAMFGQTY(LMSK,L)                                 #
# Subprog MAJ_AVAMFGQTY(LMSK)                                   #
# Subprog MAT_INTSTO(LFCY, LITM, LLOT, LLOC, LSTA)              #
# Subprog ALLOC_MAT(L)                                          #
# Subprog ANALYSE_LOC(ABMSK, LOPENUM, LLIG, LITM)               #
# Subprog ANALYSE_STR(ABMSK, LOPENUM, LLIG)                     #
# Subprog CONT_SOLDE_MAT(LFCY, LITM, LCPL, LEXT, LRET)          #
# Subprog STODISALL(FCY,ITM,ECCVALMAJ,DIS)                      #
#################################################################
# Issue X3-25054 - 2017-07-12 by BAKHA : when adding an assembly, copy revreason to all component lines for auditing
# Issue X3-48941 - 2017-08-01 by BAKHA : Check new GMFGREV parameter for audit
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking versioning fields, make sure Versioning is in use

# Mise à jour de la liste des matières liées à l'OF
Subprog UPDMAT(L, LMSG)
Value    Integer  L
Value    Integer  LMSG
Local    Date     WDAT
# Issue 110935 - 2016-04-20 by BEEBE : Deactivate EP PE_BOMDATCTL for product managed by version
Local    Char     WITMREF(GLONITM)
Local    Integer  WHLT

If LMSG<0
   LMSG -= LMSG
   WHLT  = 0
Else
   WHLT  = 1
Endif

# un petit message pour patienter ...
If LMSG = 1 : Call TEMPON(mess(74,195,1)) From GESECRAN : Endif

WITMREF = [M:MFG1]ITMREF

# Issue 105251 GA 04/2015 EP to use end date instead of [M:MFG1]STRDAT to check availability of component
#If [M:MFG1]STRDAT=[0/0/0]
#    WDAT=date$
#Else
#    WDAT=[M:MFG1]STRDAT
#Endif
# Check validity date of the link
Local Integer WBOMDATCTL : WBOMDATCTL=2
If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
    Gosub PE_BOMDATCTL From MFGAUTLIB
Endif
# End issue 110935
Case WBOMDATCTL
  When 1       : WDAT=[M:MFG1]ENDDAT
  When Default : WDAT=[M:MFG1]STRDAT  # standard mode
Endcase
If WDAT=[0/0/0]  WDAT=date$ Endif

# on trie le tableau par article/séquence
# c'est + simple pour les mises à jour
If GSORT = 1 : Call TRI_MAT("S") : Endif

# ajout, suppression des matières concernées
Case GMODIF
    When 1
      Call SUPMAT(L)
    When 2
      # Issue 113561 - 2016-01 by GH : Material load for a version in derogation
      If dim([M:MFG1]ECCVALMAJ)>0 & [M:MFG1]ECCVALMAJ(L)<>""
         Call CORDAT([M:MFG1]ITMREF(L),[M:MFG1]ECCVALMAJ(L),[M:MFG1]ECCVALMIN(L),2,WDAT) From ECCLIB
      Endif
      Call GENMAT(L,WDAT)
      # Issue X3-48941 - 2017-08-17 by JUSYN : Call prog to clarify if BOM load is modification for a versioned product
      If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
        Call VBOMLOAD(L)
      Endif  # Issue X3-55832
Endcase

# comme on est vachement sympa on remet le tableau comme avant ...
If GSORT = 1 : Call TRI_MAT("O") : Endif

If WHLT  : # Issue 122638 GH 15/05/2017 - performance enhancement
   # Issue 119469 GH 04/11/16 - performance enhancement
   Call HIGHLIGHT("MFG2",-1) From ECCLIB
Endif

If LMSG = 1 : Call TEMPOFF From GESECRAN : Endif
End

############################################################
# Recherche des matières d'un article lancé
Subprog GENMAT(L,CDAT)
Value    Integer  L
Value    Date     CDAT
Local    Char     WFCY(GLONFCY)  : WFCY = [M:MFG0]MFGFCY
Local    Char     WITM(GLONITM)  : WITM = [M:MFG1]ITMREF(L)
Local    Integer  WALT           : WALT = [M:MFG1]BOMALT(L)
Local    Date     WDAT           : WDAT = CDAT
Local    Decimal  WQTY           : WQTY = [M:MFG1]EXTQTY(L)
Local    Char     WLOT(GLONLOT) : WLOT = [M:MFG1]LOT(L)
Local    Integer  WOPE           : WOPE = 0         # llc 12.01 11561 propagation en traversée fantôme
Local    Integer  WOFS           : WOFS = 0         # llc 12.01 11561 propagation en traversée fantôme
Local    Integer  WLIKQTYCOD     : WLIKQTYCOD = 1   # FQ 73109 GA 05/2011
Local    Decimal  WLIK           : WLIK = 1         # llc 01.03 16961
Local    Decimal  WSCA           : WSCA = 1         # mm  11.06 38064
Local    Decimal  WBAS           : WBAS = 1         # mm  11.06 38064
Local    Integer  WVISUGHOST     : WVISUGHOST = 0   # llc 02.03 (R) 17425
Local    Integer  WRET           : WRET = 0


# numéro ligne tableau matières
Local    Integer  WLIG           : WLIG = [M:MFG2]NBLIG
# llc 12.01 11561 propagation en traversée fantôme
# FQ 73109 GA 05/2011 + param WLIKQTYCOD
Call CREMAT(L,WLIG,WFCY,WITM,WALT,WDAT,WQTY,WLOT,WOPE,WOFS,WLIKQTYCOD,WLIK,WSCA,0,WBAS,WVISUGHOST,WRET)         # llc 01.03 16961 + 17425 + 38064
LRET=WRET

# il faut trier le tableau dans le cas de la traversée de fantômes, sinon c'est le binz ...
# Issue 119469 GH 04/11/16 - performance enhancement
#Call TRI_MAT("S")
#If [M:MFG2]NBLIG <> 0 : Affzo [M:MFG2] : Endif         # llc 08.01  10038
If WVISUGHOST & GSORT=0
   Call TRI_MAT("S")
Endif

# Demande PE 26503 11.04 MM Ne pas afficher la boite de dialogue
# mettre GPE=0 pour court-circuiter l'action standard
GPE=1
GPOINT ="SHOWBOX"
Gosub ENTREE From EXEFNC
If GPE<>0
    # llc 02.03 (R) 17425
    If WVISUGHOST
        Local Integer OK : OK = 0
        Call OUINON(mess(181,190,1),OK) From GESECRAN
        If OK=2
            Local Char PARAM(250)(1..20) , SAVACT(10)
            Local Char VALEUR(20)
            SAVACT = GACTION : GACTION = "VISUGHOST"
            PARAM(1) = [M:MFG0]MFGFCY
            PARAM(2) = [M:MFG1]ITMREF(L)
            PARAM(3) = num$([M:MFG1]BOMALT(L))
            # Issue 113561 - 2016-01 by GH : Material load for a version in derogation
            If dim([M:MFG1]ECCVALMAJ)>0 & [M:MFG1]ECCVALMAJ(L)<>""
               Call CORDAT([M:MFG1]ITMREF(L),[M:MFG1]ECCVALMAJ(L),[M:MFG1]ECCVALMIN(L),2,WDAT) From ECCLIB
            Endif
            PARAM(4) = WDAT

            Call SAISIE_CHAR(VALEUR,PARAM,"IVISUGHOST","VISUMFG","") From GSAISIE
            GACTION = SAVACT
        Endif
    Endif
Endif

End

########################################################################
# llc 12.01 11561 propagation en traversée fantôme
# llc 01.03 16961 + 17425
Subprog CREMAT(L,LLIG, LFCY,LITM,LALT,LDAT,LQTY,LLOT,LOPE,LOFS,LLIKQTYCOD,LLIK,LSCA,LSCATIAORI,LBAS,LGHOST,LRET)
Value    Integer  L
Variable Integer  LLIG
Value    Char     LFCY
Value    Char     LITM
Value    Integer  LALT
Value    Date     LDAT
Value    Decimal  LQTY
Value    Char     LLOT
Value    Integer  LOPE                            # llc 12.01 11561 propagation en traversée fantôme
Value    Integer  LOFS                            # llc 12.01 11561 propagation en traversée fantôme
Value    Integer  LLIKQTYCOD                      # FQ 73109 GA 04/2011 fantome avec qté Forfaitaire
Value    Decimal  LLIK                            # llc 01.03 16961
Value    Decimal  LSCA                            # mm  11.06 38064
Value    Integer  LSCATIAORI                      # Issue 104942 - 2015-01-06 by CCC
Value    Decimal  LBAS                            # mm  11.06 38064
Variable Integer  LGHOST                          # llc 03.03 (R) 17425
Variable Integer  LRET           : LRET = 0
#

Local    Decimal WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Decimal WBAS
Local    Integer WLIKQTYCOD
Local    Decimal WLIKQTY
Local    Integer WQTYRND
Local    Decimal WSCA            # 49281 mm 09.08
Local    Integer WSCATIA
Local    Integer WOPE            # FQ 70236 GA 02/2011 propagation OPENUM si fantôme

Local    Integer WRET
Local    Char    WSTU(GLONUOM)   # llc 01.02 UOM
Local    Char    XMSG(120)
Local    Integer OK
Local    Decimal WWRK
# 107513
Local    Char    LERRMSG(250)
Local    Integer LERRCOD, LGHOSTERR, LGHTFLG
Local    Integer LITMECCFLG    # Indicates if the product is managed by version (0=no, 1=yes)
If GACTION="MFMFAN"
    LITMECCFLG = func ECCLIB.NBRCPN([M:MFG1]ITMREF(0))>0
Else
    LITMECCFLG = func ECCLIB.NBRCPN(LITM)>0
Endif
# LGHTFLG = 0:component - 1:ghost - 2:component of ghost
LGHTFLG = (LGHOST>0)*2

# sr 09.04 demande 25090
Local    Integer WORITRT : WORITRT = 1

# point d'entrée génération liste composant 12264
GPOINT = "BOMDET" : Gosub ENTREE From EXEFNC
If LRET = 9 : LRET = 0 : End : Endif

# lecture entête
Gosub LEC_FILES                    # llc 05.01 9169

# Issue 104942 - 2015-01-06 by CCC
LSCATIAORI = max(LSCATIAORI,WSCATIA)

# FQ 71053 GA 02/2011 sortir si nomenclature non utilisable
# Issue 122178 GH 25/03/2017 - an error is displayed in case of anomaly
Local    Integer WALT : WALT=LALT
Call CONTMFGNOM(LFCY,WALT,LDAT,1) From MFGLIB
If WALT=0
   If GMESSAGE<>""
      Call ECR_TRACE("("+LITM+")"-GMESSAGE,1) From GESECRAN
      GMESSAGE=""
   Endif
   LRET = 0 : End
Endif

# lecture liens
Local File BOMD [BOD] Where ITMREF = LITM & BOMALT = LALT & BOMALTTYP = 2 &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT)) &
&                    CPNTYP <> 6

# lecture premier enregistrement
Read [BOD]BOD0 First                          # 10.02 Performances

# tant qu'y en a !
While !fstat

# contrôle lot valide
    If LLOT <> ""
        If ([F:BOD]BOMSTRLOT <> "" & LLOT < [F:BOD]BOMSTRLOT) | ([F:BOD]BOMENDLOT <>"" &
&               LLOT > [F:BOD]BOMENDLOT)
&        & !LITMECCFLG
            Goto NEXT_BOD
        Endif
    Endif
# lecture composant
    If [F:BOD]CPNTYP <> 5
# 107513
        Raz LERRCOD, LERRMSG
        Call CONTMATITM([F:BOD]CPNITMREF, LFCY, "MFG2", LERRCOD, LERRMSG) From MFGLIB
        If LERRCOD=4
            [M:MFG0]CMPUSBFLG =2
        Endif

        If [F:BOD]LIKQTY <> 0
        # calcul quantité
            WQTY         = LQTY
            WSTU         = [F:ITM]STU
            WBAS         = [F:BOH]BASQTY
            WLIKQTYCOD   = [F:BOD]LIKQTYCOD
            WLIKQTY      = [F:BOD]LIKQTY
            WQTYRND      = [F:BOD]QTYRND
            WSCA         = [F:BOD]SCA
            Call LIKQTY(WQTY,WSTU,WBAS,WLIKQTYCOD,WLIKQTY,WQTYRND,
&               WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
            If WSCATIA
                WLIEN = WQTYBA
            Else
                WLIEN = WQTYNA
            Endif
        Else
                WLIEN = 0
        Endif

        # 11.08
        If [F:ITM]PHAFLG = 2 & WLIEN = 0 : Goto NEXT_BOD : Endif

        # llc 05.03 18321
        If WBAS = 0 : WBAS = 1 : Endif

        WLIKQTY = WLIKQTY  * LLIK                     # mm 11.06 38064

# Issue 104942 - 2015-01-06 by CCC : cumulate only if shrinkage has to be taken into account
        If WSCATIA
            # mm 11.06 38064
            # cumuler les pourcentages de perte
            WSCA = (1 + (WSCA /100)) * LSCA
        Else
            WSCA = LSCA
        Endif
        # cumuler les unités de gestion
        Case [F:BOH]QTYCOD
            When 1 :  WBAS = 1* LBAS
            When 2 :  WBAS = 100* LBAS
            When 3 :  WBAS = 1000* LBAS
            When 4 :  WBAS = 100 * LBAS
            When 5 :  WBAS = [F:BOH]BASQTY * LBAS
        Endcase

# Issue 85197 - 2018-06-01 by STLIG : link quantity code applies to current level only,
#                                     don't override next level - next level may be 'proportional'.
#
#        # FQ 73109 GA 04/2011 tenir compte de WLIKQTYCOD=Forfait si descente récursive
#        If LLIKQTYCOD=2
#           [F:BOD]LIKQTYCOD=LLIKQTYCOD : WLIKQTYCOD=2
#        Endif

    # si sous-produit, traitement particulier
        If [F:BOD]CPNTYP = 4
            # mm 11.06 38064 - cas des composants fantôme
            If clalev ([F:ITMW])<=0 :  Local File ITMMASTER [ITMW] : Endif    # 11.07 mm 44159
            Read [ITMW]ITM0 = [F:BOD]ITMREF
            If [F:ITMW]PHAFLG = 2 : WLIEN = WQTYB : Endif
           # FQ 70236 GA 02/2011 propagation OPENUM si fantôme
            If [F:BOD]CPNOPE=0 WOPE=LOPE Else WOPE=[F:BOD]CPNOPE Endif
             # llc 01.03 16961
            Call DISPLAY_SOUSPROD(L, WLIEN, WOPE, LOFS , LLIK, WSCA, WBAS, LITMECCFLG, LERRCOD, LERRMSG)        # llc 12.01 11561 propagation en traversée fantôme + 38064
        Else
    # composant normal
            # recherche stock disponible
            # Issue 94453 GA 11/2013 sauf si Texte
            # Issue 87587 si et seulement si article géré en stock
            If [F:BOD]CPNTYP <> 5 & [F:ITF]STOMGTCOD=2
               #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
               #Call STODISALL(LFCY,[F:ITM]ITMREF,10,1,2,1,2,"","",WDIS,LRET) From STKALL
               Call STODISALL(LFCY,[F:ITM]ITMREF,[F:BOD]ECCVALMAJ,WDIS) From MFGLIBM
            Else WDIS=0 Endif
            # demande 21559 Possibilité de traverser les articles autres que fantôme
            # Mettre GPE = 1 pour forcer la récursivité quel que soit la catégorie article
            # Il faut positionner aussi LGHOST si l'on veut bénéficier de la fenêtre de récap
            GPE = 0
            GPOINT = "CROSSTEST"
            Gosub  ENTREE From EXEFNC

            # 44023 mm 02.08 - relecture de [ITM] car RAZ par les stocks si article non géré en stock
            If [F:ITM]ITMREF<>[F:BOD]CPNITMREF : Read [ITM]ITM0=[F:BOD]CPNITMREF : Endif
            # si article fantôme descente par récursivité  (llc 03.01 8467 + 8791)
            If ([F:ITM]PHAFLG = 2 | GPE)
                If LGHOST <> 9 : LGHOST = 1 : Endif        # llc 02.03 (R) 17425
                LGHTFLG=1
                # FQ 70236 GA 02/2011 propagation OPENUM si fantôme
                If [F:BOD]CPNOPE=0 WOPE=LOPE Else WOPE=[F:BOD]CPNOPE Endif

                LGHOSTERR=0
                If LERRCOD<>4 & [F:BOD]ECCVALMAJ<>""
                    Call CTRECC([F:BOD]CPNITMREF,"MFMF","GHTECCMIN",[F:BOD]ECCVALMAJ,[F:BOD]ECCVALMIN,
&                               [M:MFG1]STRDAT,WRET,XMSG) From ECCLIB
                    If find(WRET,1,4)
                        [M:MFG0]CMPUSBFLG =2
                        LGHOSTERR = 1
                    Endif
                Endif
                If !LGHOSTERR & LERRCOD<>4
                    If WDIS = 0 | GPE
    # Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
    #                    # llc 12.01 11561 propagation en traversée fantôme
    #                    # llc 01.03 16961 + 17425 + 38064
    #                    WLIEN = WQTYB    # 38064 mm 11.06 : on n'arrondit pas la quantité en cas de traversée de fantôme
                        If WSCATIA
                            WLIEN = WQTYB
                        Else
                            WLIEN = WQTYN
                        Endif
                        # FQ 70236 GA 02/2011 propagation OPENUM si fantôme avant [F:BOD]CPNOPE
                        # FQ 73109 GA 05/2011 + param WLIKQTYCOD
                        Call CREMAT(L,LLIG,LFCY,[F:ITM]ITMREF,LALT,LDAT,WLIEN,LLOT,WOPE,[F:BOD]BOMOFS,
&                                   WLIKQTYCOD,WLIKQTY,WSCA, LSCATIAORI, WBAS, LGHOST, LRET)
                        Gosub LEC_FILES               # llc 05.01 9169
                    Else
                        If WDIS < WLIEN
                            OK = 1
                            XMSG = "("+[F:ITM]ITMREF+")"-mess(139,190,1)
                            Call OUINON(XMSG,OK) From GESECRAN
                            If OK = 2
                                # llc 12.01 11561 propagation en traversée fantôme
                                # llc 01.03 16961 + mm 11.06 38064   # FQ 67713 GA 09/2010
                                # FQ 75808 GA 01/09/2011 WDIS = qté disponible substituée sur le fantome
                                Call DISPLAY_MAT(L, LLIG, WDIS, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,LSCATIAORI,WBAS,0, LITMECCFLG, LERRCOD, LERRMSG)
                                WWRK = WLIEN - WDIS
                            Else
                                WWRK = WLIEN # FQ 75808 GA 01/09/2011 pas de substitution
                            Endif
                            # llc 12.01 11561 propagation en traversée fantôme
                            # llc 01.03 16961 + 17425 + 38064
                            # FQ 70236 GA 02/2011 propagation OPENUM si fantôme avant [F:BOD]CPNOPE
                            # FQ 73109 GA 05/2011 + param WLIKQTYCOD
                            # FQ 75808 GA 01/09/2011 WLIEN remplacé par WWRK : qté restant à produire sur le fantome
                            Call CREMAT(L,LLIG,LFCY,[F:ITM]ITMREF,LALT,LDAT,WWRK,LLOT,WOPE,[F:BOD]BOMOFS,
&                                       WLIKQTYCOD,WLIKQTY,WSCA, LSCATIAORI, WBAS, LGHOST, LRET)
                            Gosub LEC_FILES        # llc 05.01 9169
                        Else
                            # llc 12.01 11561 propagation en traversée fantôme
                            # llc 01.03 16961 + mm 11.06 38064   # FQ 67713 GA 09/2010
                            # 107513 -
                            Call DISPLAY_MAT(L,LLIG,WLIEN, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,LSCATIAORI,WBAS,0, LITMECCFLG, LERRCOD, LERRMSG)
                        Endif
                    Endif
                Else
                    Call DISPLAY_MAT(L,LLIG,WLIEN, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,LSCATIAORI,WBAS,LGHTFLG, LITMECCFLG, LERRCOD, LERRMSG)
                Endif
            Else
                # llc 12.01 11561 propagation en traversée fantôme
                # llc 01.03 16961+ mm 11.06 38064   # FQ 67713 GA 09/2010
                Call DISPLAY_MAT(L,LLIG,WLIEN, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,LSCATIAORI,WBAS,LGHTFLG, LITMECCFLG, LERRCOD, LERRMSG)
            Endif
        Endif
    Else
        # ligne de type texte
        # mm 11.06 38064   # FQ 67713 GA 09/2010
       Call DISPLAY_MAT(L,LLIG,WLIEN, WDIS, WSCATIA,LOPE,LOFS,LLIK,WSCA,LSCATIAORI,WBAS,LGHTFLG, LITMECCFLG, LERRCOD, LERRMSG)
    Endif
#
$NEXT_BOD
    If dim([M:MFG2]ITMREF) < [M:MFG2]NBLIG + 2 : Break : Endif
    Read [BOD]BOD0 Next
Wend

# Issue 119469 GH 04/11/16 - performance enhancement
#Affzo [M:MFG2]
#Call HIGHLIGHT("MFG2", -1) From ECCLIB

If LGHOSTERR
    LGHOST=0    # Avoid to open window
Endif
End

############################################################
# # llc 05.01 9169
$LEC_FILES
# lecture entete nomenclature
Read [BOH]BOH0=LITM;LALT;2
If fstat : Return : Endif

WSCATIA = 0
# lecture article/site composé
If [F:ITF]ITMREF <> LITM | [F:ITF]STOFCY <> LFCY
    Read [ITF]ITF0=LITM;LFCY
    If fstat : WSCATIA = 1 : Endif
Endif
If WSCATIA = 0
    If [F:ITF]RELSCATIA <> 1 : WSCATIA = 1 : Endif
Endif

Return

############################################################
# insertion sous-produit
# llc 12.01 11561 propagation en traversée fantôme
# llc 01.03 16961
Subprog DISPLAY_SOUSPROD(L, LQ, LOPE,LOFS, LLIK, LSCA, LBAS, LITMECCFLG, LERRCOD, LERRMSG)
Value Integer L
Value Decimal LQ
#Value Decimal LDIS           # FQ 69909 Ctrl des sources
Value Integer LOPE            # llc 12.01 11561 propagation en traversée fantôme
Value Integer LOFS            # llc 12.01 11561 propagation en traversée fantôme
Value Decimal LLIK            # llc 01.03 16961
Value Decimal LSCA            # mm  11.06 38064
Value Decimal LBAS            # mm  11.06 38064
Value Integer LITMECCFLG      # 107513
Value Integer LERRCOD         # 107513
Value Char    LERRMSG         # 107513

Local Date    WORIDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Date    WDSTDAT
Local Integer WRET            # 04.05 29614

Local Integer LIG : LIG =  [M:MFG1]NBLIG
# mm  11.06 38064 - récupération de la quantité lancé sans le pourcentage de perte
If LSCA <>0 : LQ = LQ /LSCA : Endif

[M:MFG1]ITMREF(LIG)    = [F:BOD]CPNITMREF
# 107513
If dim([M:MFG1]ECCVALMAJ)>0
    [M:MFG1]ECCVALMAJ(LIG) = [F:BOD]ECCVALMAJ
    [M:MFG1]ECCVALMIN(LIG) = [F:BOD]ECCVALMIN
Endif
[M:MFG1]ITMSTA(LIG)    = 1
[M:MFG1]ITMTYP(LIG)    = 2
[M:MFG1]CSTFLG(LIG)    = [F:BOD]CSTFLG    # (llc 05.00 sous-produit)
[M:MFG1]UOM(LIG)       = [F:ITM]STU
[M:MFG1]UOMEXTQTY(LIG) = LQ
[M:MFG1]UOMSTUCOE(LIG) = 1
[M:MFG1]STU(LIG)       = [F:ITM]STU
[M:MFG1]EXTQTY(LIG)    = LQ
#[M:MFG1]ITMDES1(LIG)   = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFG1]ITMDES1(LIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MFG1]PLANNER(LIG)   = [F:ITF]PLANNER
[M:MFG1]BOMALT(LIG)    = 0
[M:MFG1]TBOSHO(LIG)    = ""
[M:MFG1]PJT(LIG)       = [M:MFG1]PJT(L)
# 09.05
[M:MFG1]VCRTYPORI(LIG) = [M:MFG1]VCRTYPORI(L)
[M:MFG1]VCRNUMORI(LIG) = [M:MFG1]VCRNUMORI(L)
[M:MFG1]VCRLINORI(LIG) = [M:MFG1]VCRLINORI(L)
[M:MFG1]VCRSEQORI(LIG) = [M:MFG1]VCRSEQORI(L)

If [F:ITF]PTOCOD <> ""
   [M:MFG1]PTOCOD(LIG) = [F:ITF]PTOCOD
Else
   Call PARAM([M:MFG0]MFGFCY,"DEFPTO",[M:MFG1]PTOCOD(LIG)) From ADOVAL : #  GDEFPTO : # GH 20/11/13 bug 94608
Endif

# 04.05 29614
# si pas de gestion de lot, on sort
If [F:ITM]LOTMGTCOD > 1

    If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif

    # Lecture de la règle de gestion à utiliser
    Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB

    # 10.05 32769
    If [F:ITM]LOTCOU = ""
       If !WRET & [F:SRU]LOTSUPINH=3
          [M:MFG1]GESLOT(LIG)    = "V"
       Endif
    Else
      [M:MFG1]GESLOT(LIG)       = "C"
    Endif
    If [F:MTS]LOTAFF > 1 | find([M:MFG1]GESLOT(LIG),"C","V"): [M:MFG1]LOT(LIG) = mess(62,193,1) : Endif
Endif

[M:MFG1]BPCTYPDEN(LIG) = 1
[M:MFG1]BPCNUM(LIG)    = [M:MFG0]MFGFCY
If [F:FCY]FCY <> [M:MFG0]MFGFCY
    Read [FCY]FCY0=[M:MFG0]MFGFCY
    If fstat : Raz [F:FCY] : Endif
Endif
[M:MFG1]BPCDES(LIG)    = [F:FCY]FCYSHO
[M:MFG1]TCLCOD(LIG)     =[F:ITM]TCLCOD
[M:MFG1]ABCCLS(LIG)     =[F:ITF]ABCCLS
If dim([M:MFG1]TSICOD1(LIG))>0 [M:MFG1]TSICOD1(LIG)=[F:ITM]TSICOD(0) : Endif
If dim([M:MFG1]TSICOD2(LIG))>0 [M:MFG1]TSICOD2(LIG)=[F:ITM]TSICOD(1) : Endif
If dim([M:MFG1]TSICOD3(LIG))>0 [M:MFG1]TSICOD3(LIG)=[F:ITM]TSICOD(2) : Endif
If dim([M:MFG1]TSICOD4(LIG))>0 [M:MFG1]TSICOD4(LIG)=[F:ITM]TSICOD(3) : Endif
If dim([M:MFG1]TSICOD5(LIG))>0 [M:MFG1]TSICOD5(LIG)=[F:ITM]TSICOD(4) : Endif

[M:MFG1]MFGDES(LIG)    = [M:MFG1]MFGDES(L)
# FQ 60890 GA 09/2010 Oubli de report sur X3INDV6 ? fait en 02/2010 sur la V5
# FQ 60890 GA 02/2010 Raz de cette numérotation avec [F:BOD]BOMSEQ, ok avec 10*[F:BOD]BOMSEQ mais risqué
#If [F:BOD]BOMSEQ>0
#   #[M:MFG1]MFGLIN(LIG) = [M:MFG1]MFGLIN(L) + [F:BOD]BOMSEQ       # FQ 50547 GA 06/2009
#   [M:MFG1]MFGLIN(LIG) = [M:MFG1]MFGLIN(L) + [F:BOD]BOMSEQ + LIG  # FQ 60890 GA 12/2009 pb si 2x le sous-produit
#Else
   [M:MFG1]MFGLIN(LIG) = [M:MFG1]MFGLIN(L) + LIG            # 03.05 28875
#Endif
[M:MFG1]XMFGLIN(LIG)   = [M:MFG1]MFGLIN(L)
# mémo donnée lien nomenclature (pour répercuter modif quantité lancée)
[M:MFG1]BASQTY(LIG)    = [F:BOH]BASQTY
[M:MFG1]LIKQTYCOD(LIG) = [F:BOD]LIKQTYCOD
[M:MFG1]LIKQTY(LIG)    = [F:BOD]LIKQTY * LLIK                # llc 01.03 16961
[M:MFG1]QTYRND(LIG)    = [F:BOD]QTYRND
# llc 12.01 11561 propagation en traversée fantôme
If [F:BOD]CPNOPE = 0 & LOPE <> 0
    [M:MFG1]SPOPE(LIG)      = LOPE
    [M:MFG1]SPOFS(LIG)      = LOFS
Else
    [M:MFG1]SPOPE(LIG)      = [F:BOD]CPNOPE
    [M:MFG1]SPOFS(LIG)      = [F:BOD]BOMOFS
Endif


# application du délai par rapport à date début OF si les opérations
# n'ont pas encore été générées ni jalonnées ou si no opé = 0
# sinon date besoin = date opération correspondante
# llc 12.01 11561 propagation en traversée fantôme

If [M:MFG1]SPOPE(LIG) = 0 & [M:MFG1]SPOFS(LIG) = 0
    [M:MFG1]SPDAT(LIG) = [M:MFG1]ENDDAT
Else
    WORIDAT    = [M:MFG1]STRDAT
    WORIFCY    = [M:MFG0]MFGFCY
    WLTI       = [M:MFG1]SPOFS(LIG)
    If [M:MFG3]NBLIG <> 0 & [M:MFG3]SCDFLG > 1 & [M:MFG1]SPOPE(LIG) <> 0
        For  I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = [M:MFG1]SPOPE(LIG)
                WORIDAT = [M:MFG3]OPESTR(I)
                Break
            Endif
        Next I
    Endif

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB

    [M:MFG1]SPDAT(LIG)  = WDSTDAT
Endif

# mm 11.06 38064 - cas des composants fantôme + 44159
If [F:ITMW]PHAFLG = 2
    # en cas de cumul des unités de gestion, on attribue
    # la nouvelle unité calculée à la quantité de base
    [M:MFG1]BASQTY(LIG)  = LBAS
Endif

[M:MFG1]NBLIG += 1

# 107513
[M:MFG1]ITMERRCOD(LIG) = [L]LERRCOD
[M:MFG1]ITMERRMSG(LIG) = [L]LERRMSG
If dim([M:MFG1]ECCVALMAJ)>0
    # Issue 119469 GH 04/11/16 - performance enhancement
    # Call CTRECCPRD(LIG) From SUBMFGECC
    Call CTRECC([M:MFG1]ITMREF(LIG),"MFG1","STRDAT",[M:MFG1]ECCVALMAJ(LIG),[M:MFG1]ECCVALMIN(LIG),
&               [M:MFG1]STRDAT,WRET,[M:MFG1]ECCERRMSG(LIG)) From ECCLIB
    [M:MFG1]ECCERRCOD(LIG) = WRET
Endif

# Issue 110957 - 2015-10-07 by CCC : check if a change request exists
If dim([M:MFG1]CRID)>0 & varmode([M:MFG1]CRID)<>3
    [M:MFG1]CRID(LIG) = func TRTX3FNC.CCMID([M:MFG1]ITMREF(LIG), [F:BOD]ECCVALMAJ, [F:BOD]ECCVALMIN)
    If dim([M:MFG1]CRFLG)>0
        [M:MFG1]CRFLG(LIG) = string$([M:MFG1]CRID(LIG)<>"","151")
    Endif
Endif

# Issue 79820 - Globale créée/affectée dans SUBMFGA, perdue si on est passé dans les plans
GMFMORI = "GESMFG"
# point d'entrée ajout de composant (9307 + 28957)
GPOINT = "MFMCRE" : Gosub ENTREE From EXEFNC

# Affzo [M:MFG1]5 : # Issue 119469 GH 04/11/16 - performance enhancement
# 107513 - Highlight the line. To do after Affzo.
Call HIGHLIGHT("MFG1", LIG) From ECCLIB

End

############################################################
# llc 12.01 11561 propagation en traversée fantôme
# llc 01.03 16961 + mm 11.06 38064
# 107513 - LGHTFLG = 0:component - 1:ghost - 2:component of ghost
Subprog DISPLAY_MAT(L,LIG,LQ,LDIS,LSCATIA,LOPE,LOFS, LLIK, LSCA, LSCATIAORI, LBAS,LGHTFLG, LITMECCFLG, LERRCOD, LERRMSG)
Value    Integer L
Variable Integer LIG
Value    Decimal LQ
Value    Decimal LDIS
Value    Integer LSCATIA
Value    Integer LOPE                    # llc 12.01 11561 propagation en traversée fantôme
Value    Integer LOFS                    # llc 12.01 11561 propagation en traversée fantôme
Value    Decimal LLIK                    # llc 01.03 16961
Value    Decimal LSCA                    # mm  11.06 38064
Value    Integer LSCATIAORI              # Issue 104942 - 2015-01-06 by CCC
Value    Decimal LBAS                    # mm  11.06 38064
Value    Integer LGHTFLG                  # FQ 67713 GA 09/2010
Value    Integer LITMECCFLG              # 107513
Value    Integer LERRCOD                 # 107513
Value    Char    LERRMSG                 # 107513

Local    Date    WORIDAT
Local    Char    WORIFCY(GLONFCY)
Local    Integer WLTI
Local    Date    WDSTDAT
Local    Integer SLIG :# sauvegarde du nolign
Local    Decimal WUSE
Local    Decimal XTOT
Local    Integer I,X,J
Local    Decimal WWRK
Local    Decimal WBAS
Local    Decimal WLIK
Local    Char    WCCE(GLONCCE)
Local    Integer WOPE                   # llc 12.01 11561 propagation en traversée fantôme
Local    Integer WOFS                   # llc 12.01 11561 propagation en traversée fantôme
Local    Integer CUMMATCH               # llc 12.01 11561 + 11937 pb fantôme
Local    Integer WRET
Local    Decimal WQTY : WQTY =1                      # mm 12.16  117947
Local    Decimal WQTYN,WQTYNA,WQTYB,WQTYBA           # mm 12.16  117947
Local    Decimal WBAS : WBAS =1                      # mm 03.17  121923

# test mode de cumul matières
If GCUMMAT <> 2 |[F:BOD]CPNTYP = 5 : Goto AJOUT : Endif

# llc 12.01 11561 propagation en traversée fantôme
If [M:MFG2]NBLIG = 0 : Goto AJOUT : Endif

If [F:BOD]CPNOPE = 0 & LOPE <> 0
    WOPE      = LOPE
    WOFS      = LOFS
Else
    WOPE      = [F:BOD]CPNOPE
    WOFS      = [F:BOD]BOMOFS

Endif

# recherche composant identique déjà présent
# llc 12.01 11561 + 11937 pb fantôme

CUMMATCH = 0
For X = 0 To [M:MFG2]NBLIG - 1
    If [M:MFG2]ITMREF(X) = [F:BOD]CPNITMREF & [M:MFG2]BOMOPE(X) = WOPE & [M:MFG2]MATSTA(X) < 3
&    & (dim([M:MFG2]ECCVALMAJ)<0 | [M:MFG2]ECCVALMAJ(X)=[F:BOD]ECCVALMAJ & [M:MFG2]ECCVALMIN(X)=[F:BOD]ECCVALMIN)   # 107513
        # 10.04 25961 si matière existe mais est allouée, pas d'ajout sauf si ligne déjà cumulée
        If [M:MFG2]ALLSTA(X) <= 3 | [M:MFG2]MFGLIN(X) = 0
            CUMMATCH = 1
            Break
        Endif
    Endif
Next X

If !CUMMATCH : Goto AJOUT : Endif

# on "marque" la ligne cumulée
[M:MFG2]CUMFLG(X) = 2
# cumul des matières au lancement
Case [M:MFG2]LIKQTYCOD(X)
    When 1: Case [F:BOD]LIKQTYCOD
                When 1: WWRK = [M:MFG2]RETQTY(X) + LQ - [M:MFG2]CUMFXDQTY(X)
                        If [M:MFG1]MFGLIN(L) = [M:MFG2]MFGLIN(X) & [M:MFG2]MFGLIN(X) <> 0
                            WBAS = [M:MFG1]EXTQTY(L) / [M:MFG2]BASQTY(X)
                        Else
                            WBAS = [M:MFG1]MFGEXTQTY / [M:MFG2]BASQTY(X)
                            [M:MFG2]MFGLINK(X) = 1
                            [M:MFG2]MFGLIN(X)  = 0                    # (correction llc 09.00)
                        Endif
                        WLIK = WWRK              / WBAS
                        [M:MFG2]LIKQTY(X) = WLIK

                        # UML inactif - mm 11.06 38064 + 44171
                        If dim([M:MFG2]BOMSTUCOE(X))>0  &  [M:MFG2]BOMSTUCOE(X)
                            [M:MFG2]BOMQTY(X) = WLIK / [M:MFG2]BOMSTUCOE(X)
                        Endif
                        [M:MFG2]RETQTY(X) = WWRK + [M:MFG2]CUMFXDQTY(X)
                        [M:MFG2]STDQTY(X) = [M:MFG2]RETQTY(X)
                When 2: [M:MFG2]CUMFXDQTY(X) += LQ
                        [M:MFG2]RETQTY(X)    += LQ
                        [M:MFG2]STDQTY(X)     = [M:MFG2]RETQTY(X)
                        If [M:MFG1]MFGLIN(L) <> [M:MFG2]MFGLIN(X) & [M:MFG2]MFGLIN(X) <> 0
                            [M:MFG2]MFGLINK(X) = 1
                            [M:MFG2]MFGLIN(X)  = 0                    # (correction llc 09.00)
                        Endif
            Endcase
    When 2: Case [F:BOD]LIKQTYCOD
                When 1: [M:MFG2]CUMFXDQTY(X) += [M:MFG2]RETQTY(X)
                        [M:MFG2]BASQTY(X)    = [F:BOH]BASQTY
                        [M:MFG2]QTYCOD(X)    = [F:BOH]QTYCOD
                        [M:MFG2]LIKQTYCOD(X) = [F:BOD]LIKQTYCOD
                        [M:MFG2]LIKQTY(X)    = [F:BOD]LIKQTY
                        [M:MFG2]RETQTY(X)   += LQ
                        [M:MFG2]STDQTY(X)    = [M:MFG2]RETQTY(X)
                        If [M:MFG1]MFGLIN(L) <> [M:MFG2]MFGLIN(X) & [M:MFG2]MFGLIN(X) <> 0
                            [M:MFG2]MFGLINK(X) = 1
                            [M:MFG2]MFGLIN(X)  = 0                    # (correction llc 09.00)
                        Endif
                When 2: [M:MFG2]CUMFXDQTY(X)  += [M:MFG2]RETQTY(X)
                        [M:MFG2]CUMFXDQTY(X)  += LQ
                        [M:MFG2]RETQTY(X)     += LQ
                        [M:MFG2]STDQTY(X)      = [M:MFG2]RETQTY(X)
                        If [M:MFG1]MFGLIN(L) <> [M:MFG2]MFGLIN(X) & [M:MFG2]MFGLIN(X) <> 0
                            [M:MFG2]MFGLINK(X) = 1
                            [M:MFG2]MFGLIN(X)  = 0                    # (correction llc 09.00)
                        Endif
            Endcase
Endcase

# le % perte a été pris en compte dans le calcul de la qté du lien cumulé,
# on le met donc à zéro
[M:MFG2]SCA(X)    = 0

# si délai nouvelle matière < précédent
# llc 12.01 11561 + 11937 pb fantôme
If WOFS < [M:MFG2]BOMOFS(X)
    WORIDAT    = [M:MFG1]STRDAT
    WORIFCY    = [M:MFG0]MFGFCY
    WLTI       = WOFS
    If [M:MFG3]NBLIG <> 0 & [M:MFG3]SCDFLG > 1 & WOPE <> 0
        For  I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = WOPE
                WORIDAT = [M:MFG3]OPESTR(I)
                Break
            Endif
        Next I
    Endif

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB

    [M:MFG2]RETDAT(X)  = WDSTDAT
    [M:MFG2]BOMOFS(X)  = WOFS
Endif
Goto FIN

# ajout d'une nouvelle matière
$AJOUT

#    llc 03.01 8593
nolign = LIG + 1
[M:MFG2] = [F:BOD]
[M:MFG2]MFMTEX(LIG)      = [F:BOD]BOMTEXNUM
# 107513 - If status of component is not good => exclusion unless product managed by version
If LITMECCFLG=0 & find(LERRCOD,1,4)
    [M:MFG2]MATSTA(LIG)      = 4
    [M:MFG1]DMATNBR   -= 1  # 1 is added afterwards
Else
    [M:MFG2]MATSTA(LIG)      = 1
Endif
[M:MFG2]XMATSTA(LIG) = mess([M:MFG2]MATSTA(LIG),363,1)

# Issue X3-25054 - copy Revision reason to all lines created
# Issue X3-48941 - check audit parameter
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If (GMFGREV=2 and GACTION ="MFMFAN")
    If ([M:MFMF]REVREASON<>"")
      [M:MFG2]REVREASON(LIG)    = [M:MFMF]REVREASON
      [M:MFG2]REVCOD(LIG)       = 1  # = Add
    Endif
  Endif
Endif # Issue X3-55832

If [F:BOD]CPNTYP = 5
    Raz [M:MFG2]ITMREF(LIG)
    [M:MFG2]XMATSTA(LIG)     = mess(38,198,1)
    [M:MFG2]BOMOPE(LIG)      = [F:BOD]CPNOPE
    [M:MFG2]MFGLIN(LIG)      = [M:MFG1]MFGLIN(L)
    [M:MFG2]MFGLINK(LIG)     = 2
    [M:MFG2]PJT(LIG)         = [M:MFG1]PJT(L)
    [M:MFG2]BOMALT(LIG)      = [M:MFG1]BOMALT(L)
    [M:MFG2]PICPRN(LIG)      = [F:BOD]PICPRN
    If dim([M:MFG2]PKC) > 0  : [M:MFG2]PKC(LIG) = 1  : Endif
    If dim([M:MFG2]CTN) > 0  : [M:MFG2]CTN(LIG) = [F:BOD]CTN  : Endif         # CATUA X3-30179 manage container fields in WO
    [M:MFG2]RETDAT(LIG)      = [M:MFG1]STRDAT
    [M:MFG2]PRPSTA(LIG)      = 1
    [M:MFG2]MFMTRKFLG(LIG)   = 1

    [M:MFG2]MATSTA(LIG)      = 1
    Gosub DBL_SEQ            : # GH 28/01/13 bug 86950
    LIG += 1
    [M:MFG2]NBLIG     += 1
    Goto FIN2
Endif

[M:MFG2]ITMREF(LIG)      = [F:BOD]CPNITMREF

# llc 12.01 11561 propagation en traversée fantôme
If [F:BOD]CPNOPE = 0 & LOPE <> 0
    [M:MFG2]BOMOPE(LIG)      = LOPE
    [M:MFG2]BOMOFS(LIG)      = LOFS
Else
    [M:MFG2]BOMOPE(LIG)      = [F:BOD]CPNOPE
    [M:MFG2]BOMOFS(LIG)      = [F:BOD]BOMOFS
Endif

[M:MFG2]BOMSEQ(LIG)      = [F:BOD]BOMSEQ
Gosub DBL_SEQ

[M:MFG2]BASQTY(LIG)      = [F:BOH]BASQTY
[M:MFG2]QTYCOD(LIG)      = [F:BOH]QTYCOD
[M:MFG2]LIKQTYCOD(LIG)   = [F:BOD]LIKQTYCOD
[M:MFG2]QTYRND(LIG)      = [F:BOD]QTYRND

# Issue 85197 - 2018-05-18 by STLIG : Maintain link quantity for "Fixed" link ..
If ([F:BOD]LIKQTYCOD = 1)
  [M:MFG2]LIKQTY(LIG) = [F:BOD]LIKQTY * LLIK
Else
  [M:MFG2]LIKQTY(LIG) = [F:BOD]LIKQTY
Endif

# mm 11.07 44171
If dim([M:MFG2]BOMQTY(LIG))>0    # UML inactif
    [M:MFG2]BOMQTY(LIG)      = [F:BOD]BOMQTY * LLIK                    # mm  11.06 38064
Endif
[M:MFG2]CUMFLG(LIG)      = 1

[M:MFG2]BOMSHO(LIG)      = [F:BOD]BOMSHO
[M:MFG2]SCA(LIG)         = [F:BOD]SCA
#[M:MFG2]ITMDES1(LIG)     = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFG2]ITMDES1(LIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:MFG2]STU(LIG)         = [F:ITM]STU
Call ANALYSE_LOC("MFG2", [M:MFG0]MFGFCY, [M:MFG2]BOMOPE(LIG), LIG, [M:MFG2]ITMREF(LIG))
[M:MFG2]STOMGTCOD(LIG)   = [F:ITF]STOMGTCOD

[M:MFG2]RELSCATIA(LIG) = LSCATIAORI + 1

# mm 11.06 38064 - cas des composants fantôme + 44159
If clalev([F:ITMW])<=0 : Local File ITMMASTER [ITMW] : Endif
Read [ITMW]ITM0 = [F:BOD]ITMREF
If [F:ITMW]PHAFLG = 2  | LGHTFLG        # FQ 67713 GA 09/2010
    [M:MFG2]SCA(LIG)     = (LSCA -1)*100
    # en cas de cumul des unités de gestion, on force l'unité à "au lot"
    # et on attribue la nouvelle unité calculée à la quantité de base
    [M:MFG2]QTYCOD(LIG)  = 5
    [M:MFG2]BASQTY(LIG)  = LBAS
Endif

# Issue 104942 - 2015-01-06 by CCC
If [M:MFG2]RELSCATIA(LIG)<>2
    [M:MFG2]SCA(LIG) = 0
Endif

# mm 12.16  117947 + mm 03.17 121923
If [M:MFG2]LIKQTYCOD(LIG) = 2   # forfait
  # Issue 85197 - 2018-05-18 by STLIG : Reset requirement quantity and
  #                                     re-apply cumulative % scrap (component + phantom parent (if any)) ..
  [M:MFG2]RETQTY(LIG) = [M:MFG2]LIKQTY(LIG)
  Call LIKQTY(WQTY,[M:MFG2]STU(LIG),WBAS,[M:MFG2]LIKQTYCOD(LIG),[M:MFG2]RETQTY(LIG),
&     [M:MFG2]QTYRND(LIG),[M:MFG2]SCA(LIG),WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
  If [M:MFG2]RELSCATIA(I) <> 1
      [M:MFG2]RETQTY(LIG)  = WQTYBA
  Else
      [M:MFG2]RETQTY(LIG)  = WQTYNA
  Endif
Else
  [M:MFG2]RETQTY(LIG) = LQ
Endif

# Issue 85197 - 2018-05-21 by STLIG : Update cumulative total quantity with requirement quantity ..
If ([F:BOD]LIKQTYCOD = 1)
    [M:MFG2]CUMFXDQTY(LIG) = 0
Else
    [M:MFG2]CUMFXDQTY(LIG) += [M:MFG2]RETQTY(LIG)
Endif

[M:MFG2]STDQTY(LIG)      = [M:MFG2]RETQTY(LIG)
# application du délai par rapport à date début OF si les opérations
# n'ont pas encore été générées ni jalonnées ou si no opé = 0
# sinon date besoin = date opération correspondante
WORIDAT    = [M:MFG1]STRDAT
WORIFCY    = [M:MFG0]MFGFCY
WLTI       = [M:MFG2]BOMOFS(LIG)         # llc 12.01 11561 propagation en traversée fantôme
If [M:MFG3]NBLIG <> 0 & [M:MFG3]SCDFLG > 1 & [M:MFG2]BOMOPE(LIG) <> 0
    For  I=0 To [M:MFG3]NBLIG-1
        If [M:MFG3]OPENUM(I) = [M:MFG2]BOMOPE(LIG)
            WORIDAT = [M:MFG3]OPESTR(I)
            Break
        Endif
    Next I
Endif

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB

[M:MFG2]RETDAT(LIG)  = WDSTDAT
[M:MFG2]USEQTY(LIG)  = 0
[M:MFG2]ALLQTY(LIG)  = 0
[M:MFG2]ALLSTA(LIG)  = 1
[M:MFG2]SHTQTY(LIG)  = 0
[M:MFG2]AVAQTY(LIG)  = LDIS
[M:MFG2]MFGLIN(LIG)      = [M:MFG1]MFGLIN(L)
[M:MFG2]MFGLINK(LIG)     = 2
[M:MFG2]PJT(LIG)         = [M:MFG1]PJT(L)
[M:MFG2]BOMALT(LIG)      = [M:MFG1]BOMALT(L)
[M:MFG2]PLANNER(LIG)     = [F:ITF]PLANNER
[M:MFG2]PICPRN(LIG)      = [F:BOD]PICPRN

If [F:ITF]PTOCOD <> ""
   [M:MFG2]PTOCOD(LIG) = [F:ITF]PTOCOD
Else
   Call PARAM([M:MFG0]MFGFCY,"DEFPTO",[M:MFG2]PTOCOD(LIG)) From ADOVAL : #  GDEFPTO : # GH 20/11/13 bug 94608
Endif

If dim([M:MFG2]PKC(LIG)) > 0 : [M:MFG2]PKC(LIG) = [F:BOD]PKC  : Endif         # hcb le 240101
If dim([M:MFG2]CTN(LIG)) > 0 : [M:MFG2]CTN(LIG) = [F:BOD]CTN  : Endif         # CATUA X3-30179 manage container fields in WO

[M:MFG2]PRPSTA(LIG)      = 1
[M:MFG2]MFMTRKFLG(LIG)   = 1
Call ANALYSE_STR("MFG2", [M:MFG2]BOMOPE(LIG), LIG)

# (titres llc 130)
If [F:ITF]STOMGTCOD <> 3
    If dim([M:MFG2]TYPQTY(LIG)) > 0 : [M:MFG2]TYPQTY(LIG) = 2 : Endif
Else
    If dim([M:MFG2]DEFPOT(LIG)) > 0 : [M:MFG2]DEFPOT(LIG) = [F:ITM]DEFPOT : Endif
    If dim([M:MFG2]TYPQTY(LIG)) > 0 : [M:MFG2]TYPQTY(LIG) = 1 : Endif
    If dim([M:MFG2]RETQTY2(LIG)) > 0
       # FQ 77034 avoid to divide by zero
       If dim([M:MFG2]DEFPOT(LIG)) > 0 & [M:MFG2]DEFPOT(LIG)<>0
           [M:MFG2]RETQTY2(LIG) = ([M:MFG2]RETQTY(LIG) * 100) / [M:MFG2]DEFPOT(LIG)
        Else
           [M:MFG2]RETQTY2(LIG) = [M:MFG2]RETQTY(LIG)
        Endif
        Call QTEARR([M:MFG2]RETQTY2(LIG),[M:MFG2]STU(LIG)) From TRTDIV
        If dim([M:MFG2]TYPQTY2(LIG)) > 0 :  [M:MFG2]TYPQTY2(LIG) = 2 : Endif
    Endif

Endif

# 107513
[M:MFG2]ITMERRCOD(LIG) = [L]LERRCOD
[M:MFG2]ITMERRMSG(LIG) = [L]LERRMSG
[M:MFG2]GHTFLG(LIG)    = LGHTFLG

# Issue 110957 - 2015-10-07 by CCC : check if a change request exists
If dim([M:MFG2]CRID)>0 & varmode([M:MFG2]CRID)<>3
    [M:MFG2]CRID(LIG) = func TRTX3FNC.CCMID([M:MFG2]ITMREF(LIG), [F:BOD]ECCVALMAJ, [F:BOD]ECCVALMIN)
    If dim([M:MFG2]CRFLG)>0
        [M:MFG2]CRFLG(LIG) = string$([M:MFG2]CRID(LIG)<>"","151")
    Endif
Endif

# Issue 118057 - 2016-12-12 by STLIG : Try to re-link old allocations to new material after re-load.
If ([M:MFG1]ALLSTA>1)
  Local Decimal ITMREF_ALLOCATION # Product / work order old allocations.
  If (clalev([F:MFM])<1) : Local File MFGMAT [MFM] : Endif
  # (Filter) materials by work order and product..
  Filter [MFM] Where MFGNUM=[M:MFG0]MFGNUM and
&                    ITMREF=[M:MFG2]ITMREF(LIG)
  For [MFM]
    ITMREF_ALLOCATION+=[F:MFM]ALLQTY
    # Re-link old allocations to new material (quantity and status)
    # if old and new material matches..
# Issue 120704 GH 04/01/2017 - crashed in a folder with no versioning
#    If ([F:MFM]MFGLIN=[M:MFG2]MFGLIN(LIG) &
#&       [F:MFM]BOMSEQ=[M:MFG2]BOMSEQ(LIG) &
#&       [F:MFM]ECCVALMAJ=[M:MFG2]ECCVALMAJ(LIG) &
#&       [F:MFM]ECCVALMIN=[M:MFG2]ECCVALMIN(LIG) &
#&       [F:MFM]ALLSTA<>1)
    If [F:MFM]MFGLIN=[M:MFG2]MFGLIN(LIG) &
&      [F:MFM]BOMSEQ=[M:MFG2]BOMSEQ(LIG) &
&      [F:MFM]ALLSTA<>1 &
&      (dim([M:MFG2]ECCVALMAJ)<0 | ([F:MFM]ECCVALMAJ=[M:MFG2]ECCVALMAJ(LIG) & [F:MFM]ECCVALMIN=[M:MFG2]ECCVALMIN(LIG)))
      [M:MFG2]ALLSTA(LIG)=[F:MFM]ALLSTA
      [M:MFG2]ALLQTY(LIG)=[F:MFM]ALLQTY
      [M:MFG2]SHTQTY(LIG)=[F:MFM]SHTQTY
    Endif
  Next
  # Available stock does not incorporate old allocations..
  [M:MFG2]AVAQTY(LIG)+=ITMREF_ALLOCATION
  Filter [MFM]
Endif

# chargement des sections analytiques   car l'init ne se fait pas   (TB  17/02/00)
SLIG = nolign
nolign = LIG + 1 : # pour que le parametrage section par défaut marche ( 22/02/00)
For J = 1 To GNBDIE
  Call INISEC(WCCE,"MFM",J) From TRTX3CPT
  Assign "[M:MFG2]CCE"+num$(J)+"("+num$(LIG)+")" With WCCE
Next
nolign = SLIG

# incrémentation du nombre de ligne
LIG += 1
[M:MFG2]NBLIG     += 1
[M:MFG1]DMATNBR   += 1

$FIN
# FQ 70409 GA 01/2011
# Gosub MAJSTATUT

# 107513 - Control of versions depends on requirement date
If dim([M:MFG2]ECCVALMAJ)>0
    If !CUMMATCH
        X = LIG-1
    Endif
    If LGHTFLG=1
        Call CTRECC([M:MFG2]ITMREF(X),"MFMF","GHTECCMIN",[M:MFG2]ECCVALMAJ(X),[M:MFG2]ECCVALMIN(X),
&                   [M:MFG2]RETDAT(X),WRET,[M:MFG2]ECCERRMSG(X)) From ECCLIB
    Else
        Call CTRECC([M:MFG2]ITMREF(X),"MFG2","STRDAT",[M:MFG2]ECCVALMAJ(X),[M:MFG2]ECCVALMIN(X),
&                   [M:MFG2]RETDAT(X),WRET,[M:MFG2]ECCERRMSG(X)) From ECCLIB
    Endif
    [M:MFG2]ECCERRCOD(X) = WRET
Endif

$FIN2
# Issue 79820 - Globale créée/affectée dans SUBMFGA, perdue si on est passé dans les plans
GMFMORI = "GESMFG"
# point d'entrée ajout de composant
GPOINT = "MFMCRE" : Gosub ENTREE From EXEFNC

End

$DBL_SEQ
# détection doublon éventuel (traversée fantôme)
Repeat
    J=0
    For I = 0 To LIG - 1
        If [M:MFG2]ITMREF(I) = [M:MFG2]ITMREF(LIG) & [M:MFG2]BOMSEQ(I) = [M:MFG2]BOMSEQ(LIG)
            [M:MFG2]BOMSEQ(LIG) += 1
            J=1
        Endif
    Next I
Until !J
Return

############################################################
# Suppression des matières
Subprog SUPMAT(L)
Value    Integer  L
Local    Integer  L_FLT : L_FLT  = GMFGLIN
Local    Integer  L_STR : L_STR  = 0
Local    Integer  NL    :    NL  = 0
Local    Integer  NL2   :    NL2 = 0
Local    Integer  FLG   :   FLG  = 0
Local    Integer  I

# recherche bornes des lignes matières concernées
For I=0 To [M:MFG2]NBLIG-1
    If ([M:MFG2]MFGLIN(I) = L_FLT)  & (FLG = 0)
        FLG = 1
        L_STR = I
    Endif
    If [M:MFG2]MFGLIN(I) = L_FLT
        NL += 1
        # Issue X-48941 - 2017-08-18 by JUSYN : Revision treatment for deletion of versioned products
        If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
          If GMFGREV=2 & func ECCLIB.CTRECCPROD(I)=1
            [M:MFG2]REVCOD(I) = 3 # Excluded (Cancelled)
            [M:MFG2]REVREASON(I) = mess(402,193,1)   # Component has been deleted
            Call HISTO_REVMFG ("MMR",3 , I, "G") From TRTREVMFG
          Endif
        Endif # Issue X3-55832
        # End issue number
        If [M:MFG2]CPNTYP(I) <> 5
            NL2+=1
        Endif
    Endif
Next I
If NL <= 0 : Goto SP1 : Endif

# suppression des lignes
Dela L_STR,NL [M:MFG2]NBLIG
# mise à jour NBLIG et réaffichage
[M:MFG2]NBLIG     -= NL
[M:MFG1]DMATNBR   -= NL2

# FQ 70409 GA 01/2011
#Gosub MAJSTATUT

#Affzo [M:MFG2]10 : # Issue 119469 GH 04/11/16 - performance enhancement

$SP1
FLG = 0
NL  = 0
# traitement des éventuels sous-produits
If !find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1))
    End
Endif

For I=0 To [M:MFG1]NBLIG-1
    If I <> L
        If ([M:MFG1]XMFGLIN(I) = L_FLT) & (FLG = 0)
            FLG = 1
            L_STR = I
        Endif
        If [M:MFG1]XMFGLIN(I) = L_FLT
            NL += 1
        Endif
    Endif
Next I

If NL <= 0 : End : Endif

# suppression des lignes
Dela L_STR,NL [M:MFG1]NBLIG
# mise à jour NBLIG et réaffichage
[M:MFG1]NBLIG     -= NL


End

############################################################
# modification des matières
Subprog UPD_MAT_QTY(L, LQTY)
Value    Integer  L
Value    Decimal  LQTY
Local    Decimal  WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Char     WSTU(GLONUOM)     # llc 01.02 UOM
Local    Integer  I
Local    Decimal  WEXT,WCPL
Local    Integer  WRET
Local    Integer  WVISUGHOST : WVISUGHOST = 0        # llc 02.03 (R)
# sr 09.04 demande 25090
Local    Integer  WORITRT : WORITRT = 2
Local    Integer  OK :  OK=1   # 60494 mm 11.09

# un petit message pour patienter ...
Call TEMPON(mess(74,195,1)) From GESECRAN

# 60494 mm 11.09 - modification du comportement vis à vis des matières soldées
For I=0 To [M:MFG2]NBLIG-1
    # matière soldée et non forfaitaire
      If [M:MFG2]MATSTA(I)= 3 & [M:MFG2]LIKQTYCOD(I)<> 2
        Call OUINON( mess(248,190,1), OK) From GESECRAN
        Break
      Endif
Next I

# boucle de recherche des matières concernées
For I=0 To [M:MFG2]NBLIG-1
    If (([M:MFG2]MFGLIN(I)=[M:MFG1]XMFGLIN(L) | [M:MFG2]MFGLIN(I) = 0) & ([M:MFG2]MATSTA(I)<3) &
&       [M:MFG2]CPNTYP(I) <> 5 ) |  ([M:MFG2]MATSTA(I)= 3 & [M:MFG2]LIKQTYCOD <> 2 & OK = 2)

# llc 01.02 12502
# lecture article pour vérifier si fantôme et avertir
        If [F:ITM]ITMREF <> [M:MFG2]ITMREF(I)
            Read [ITM]ITM0 = [M:MFG2]ITMREF(I)
            If fstat : Raz [ITM] : Endif
        Endif
        # sr 09.04 demande 25090
        # Mettre GPE = 1
        # Il faut positionner aussi WVISUGHOST si l'on veut bénéficier de la fenêtre de récap
        GPE = 0
        GPOINT = "CROSSTEST"
        Gosub  ENTREE From EXEFNC

        # llc 02.03 (R) - FQ 51005 GA code déplacé après le PE pour tenir compte de GPE
        If [F:ITM]PHAFLG = 2 | GPE : WVISUGHOST = 1 : Endif

# calcul nouvelle quantité
        If [M:MFG2]LIKQTY(I) <> 0
            If [M:MFG2]MFGLIN(I) <> 0
                WQTY = LQTY
            Else
                WQTY = [M:MFG1]MFGEXTQTY
            Endif
            WSTU = [M:MFG2]STU(I)
            Call LIKQTY(WQTY,WSTU,[M:MFG2]BASQTY(I),[M:MFG2]LIKQTYCOD(I),[M:MFG2]LIKQTY(I),
&                   [M:MFG2]QTYRND(I),[M:MFG2]SCA(I),WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
            If [M:MFG2]RELSCATIA(I) <> 1
                WLIEN = WQTYBA
            Else
                WLIEN = WQTYNA
            Endif
        Else
            WLIEN = 0
        Endif
        # llc 13460 ne pas diminuer en deça de la quantité déjà sortie
        If WLIEN >= [M:MFG2]USEQTY(I)
            [M:MFG2]RETQTY(I) = WLIEN
        Else
            [M:MFG2]RETQTY(I) = [M:MFG2]USEQTY(I)
        Endif

        If [M:MFG2]CUMFLG = 2
            [M:MFG2]RETQTY(I) += [M:MFG2]CUMFXDQTY(I)
        Endif

        [M:MFG2]STDQTY(I) = [M:MFG2]RETQTY(I)
# raffraichissement stock disponible
        Call LECITV2([M:MFG0]MFGFCY,[M:MFG2]ITMREF(I),WRET) From MFGLIB
        If [M:MFG2]STOMGTCOD(I)=2
           #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
           #Call STODISALL([M:MFG0]MFGFCY,[M:MFG2]ITMREF(I),10,1,2,1,2,"","",WDIS,WRET) From STKALL
           Call STODISALL([M:MFG0]MFGFCY,[M:MFG2]ITMREF(I),func TRTX3FNC.VALFLD_C("[M:MFG2]ECCVALMAJ("+num$(I)+")"),WDIS) From MFGLIBM
        Else WDIS=0 Endif
        [M:MFG2]AVAQTY(I) = WDIS + [M:MFG2]ALLQTY(I)            # llc 09.02 15756
        WEXT = [M:MFG2]RETQTY(I)
        WCPL = [M:MFG2]USEQTY(I)
        Call CONT_SOLDE_MAT([M:MFG0]MFGFCY, [M:MFG2]ITMREF(I), WCPL, WEXT, WRET)
        If WRET = 1
            [M:MFG2]MATSTA(I) = 3
            [M:MFG2]XMATSTA(I) = mess([M:MFG2]MATSTA(I),363,1)
        Endif

        # (titres llc 130)
        If dim([M:MFG2]TYPQTY(I)) > 0
            If [M:MFG2]TYPQTY(I) = 1
                If dim([M:MFG2]RETQTY2(I)) > 0
                  # FQ 77034 avoid to divide by zero
                  If dim([M:MFG2]DEFPOT(I)) > 0 & [M:MFG2]DEFPOT(I)<>0
                     [M:MFG2]RETQTY2(I) = ([M:MFG2]RETQTY(I) * 100) / [M:MFG2]DEFPOT(I)
                  Else
                     [M:MFG2]RETQTY2(I) = [M:MFG2]RETQTY(I)
                  Endif
                  Call QTEARR([M:MFG2]RETQTY2(I),[M:MFG2]STU(I)) From TRTDIV
                  If dim([M:MFG2]TYPQTY2(I)) > 0 :  [M:MFG2]TYPQTY2(I) = 2 : Endif
                Endif
            Endif
        Endif

         # 60494 mm 11.09 - Modification du statut d'une matière soldée
        If [M:MFG2]MATSTA(I)= 3
         # si qté besoin > qté consommée
          If [M:MFG2]RETQTY(I) > [M:MFG2]USEQTY(I)
            If [M:MFG2]USEQTY(I)=0
              [M:MFG2]MATSTA(I)= 1   # en attente
              [M:MFG2]MFMTRKFLG(I) = 1
            Elsif [M:MFG2]USEQTY(I)>0
              [M:MFG2]MATSTA(I)=  2     # matière en cours
              [M:MFG2]MFMTRKFLG(I) = 4
            Endif
            [M:MFG2]XMATSTA(I) = mess([M:MFG2]MATSTA(I),363,1)
          Endif
        Endif
        # Issue X-48941 - 2017-08-18 by JUSYN : Revision treatment for quantity change for versioned products
        If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
          If GMFGREV=2 & func ECCLIB.CTRECCPROD(I)=1
            [M:MFG2]REVCOD(I) = 2 # = Modify
            [M:MFG2]REVREASON(I) = mess(406,193,1)   # Product quantity has been changed
          Endif
        Endif # Issue X3-55832
    Endif
Next I
#
Affzo [M:MFG2]10


# traitement des éventuels sous-produits
# llc 02.03 (R)
If !find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1)) : Goto UPD_MAT_QTY_FIN : Endif

For I = 0 To [M:MFG1]NBLIG - 1
    If I <> L
        If [M:MFG1]XMFGLIN(I) = [M:MFG1]MFGLIN(L)
            WQTY = [M:MFG1]EXTQTY(L)
            WSTU = [M:MFG1]STU(I)
            Call LIKQTY(WQTY,WSTU,[M:MFG1]BASQTY(I),[M:MFG1]LIKQTYCOD(I),[M:MFG1]LIKQTY(I),
&                       [M:MFG1]QTYRND(I),0,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
            WLIEN = WQTYBA
            # llc 13460 ne pas diminuer en deça du réalisé
            If WLIEN >= [M:MFG1]CPLQTY(I)
                [M:MFG1]EXTQTY(I)    = WLIEN
                [M:MFG1]UOMEXTQTY(I) = WLIEN
            Else
                [M:MFG1]EXTQTY(I) = [M:MFG1]CPLQTY(I)
                [M:MFG1]UOMEXTQTY(I) = [M:MFG1]CPLQTY(I)
            Endif
            [M:MFG1]UPDFLG(I)    = 1
        Endif
    Endif
Next I

Affzo [M:MFG1]5

# llc 02.03 (R)
$UPD_MAT_QTY_FIN
Call TEMPOFF From GESECRAN

# llc 02.03 (R)
If WVISUGHOST
    Local Integer OK : OK = 0
    Call OUINON(mess(163,190,1),OK) From GESECRAN
    If OK=2
        Local Char PARAM(250)(1..20) , SAVACT(10)
        Local Char VALEUR(20)
        Local Date WDAT       : WDAT = [M:MFG1]STRDAT
        SAVACT = GACTION : GACTION = "VISUGHOST"
        PARAM(1) = [M:MFG0]MFGFCY
        PARAM(2) = [M:MFG1]ITMREF(L)
        PARAM(3) = num$([M:MFG1]BOMALT(L))
        # Issue 113561 - 2016-01 by GH : Material load for a version in derogation
        If dim([M:MFG1]ECCVALMAJ)>0 & [M:MFG1]ECCVALMAJ(L)<>""
           Call CORDAT([M:MFG1]ITMREF(L),[M:MFG1]ECCVALMAJ(L),[M:MFG1]ECCVALMIN(L),2,WDAT) From ECCLIB
        Endif
        PARAM(4) = WDAT

        Call SAISIE_CHAR(VALEUR,PARAM,"IVISUGHOST","VISUMFG","") From GSAISIE
        GACTION = SAVACT
    Endif
Endif

End

#################################################################
# renumérotation des matières (en création parce que tableaux y
# renumérote ...)
Subprog UPD_MAT_SEQ(L)
Value    Integer  L
Local    Integer  I
#
For I=0 To [M:MFG2]NBLIG-1
    If [M:MFG2]MFGLIN(I) = [M:MFG1]XMFGLIN(L)
       [M:MFG2]MFGLIN(I) = [M:MFG1]MFGLIN(L)        # FQ 50547 GA 06/2009 avant [F:MFI]MFGLIN
    Endif
Next I

# traitement des éventuels sous-produits
If !find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1))
    End
Endif
For I=0 To [M:MFG1]NBLIG-1
    If I <> L
        If [M:MFG1]XMFGLIN(I) = [M:MFG1]XMFGLIN(L)
            [M:MFG1]XMFGLIN(I)= [M:MFG1]MFGLIN(L)   # FQ 50547 GA 06/2009 avant [F:MFI]MFGLIN
            [M:MFG1]UPDFLG(I) = 1
        Endif
    Endif
Next I
End

#################################################################
# renumérotation des sous-produits
# renumérote ...)
Subprog UPD_SOUSPROD_SEQ(L)
Value    Integer  L
Local    Integer  I


For I=0 To [M:MFG1]NBLIG-1
    If I <> L
        If [M:MFG1]XMFGLIN(I) = [M:MFG1]XMFGLIN(L)
            [M:MFG1]XMFGLIN(I)= [M:MFG1]MFGLIN(L)
            [M:MFG1]UPDFLG(I) = 1
        Endif
    Endif
Next I


End

#############################################################
# recalcul des dates matières
Subprog UPD_MAT_DAT(WORIDAT,WFCY)
Value    Date     WORIDAT
Value    Char     WFCY
Local    Char     WORIFCY(GLONFCY)
Local    Integer  WLTI
Local    Date     WDSTDAT
Local    Integer  I
#
For I=0 To [M:MFG2]NBLIG-1
# application du délai
    WORIFCY    = WFCY
    WLTI       = [M:MFG2]BOMOFS(I)

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB


    [M:MFG2]RETDAT(I)  = WDSTDAT
Next I
Affzo [M:MFG2]10

# 107513 : refresh line color depending on new dates
If dim([M:MFG2]ECCVALMAJ)>0
    Call CTRECCCPN(-1) From SUBMFGECC
    Call HIGHLIGHT("MFG2",-1) From ECCLIB # Issue 119469 GH 04/11/16 - performance enhancement
Endif
#
End

############################################################
# modification des matières
Subprog UPD_MAT_PJT(L, LPJT)
Value    Integer  L
Value    Char     LPJT
Local    Integer  I

# boucle de recherche des matières concernées
For I=0 To [M:MFG2]NBLIG-1
    If [M:MFG2]MFGLIN(I) = [M:MFG1]XMFGLIN(L)
        [M:MFG2]PJT(I) = LPJT
    Endif
Next I
Affzo [M:MFG2]10

# traitement des éventuels sous-produits
If !find(2,[M:MFG1]ITMTYP(0..[M:MFG1]NBLIG-1))
    End
Endif
For I = 0 To [M:MFG1]NBLIG - 1
    If I <> L
        If [M:MFG1]XMFGLIN(I) = [M:MFG1]MFGLIN(L)
            [M:MFG1]PJT(I) = LPJT
            [M:MFG1]UPDFLG(I) = 1
        Endif
    Endif
Next I

Affzo [M:MFG1]5

#
End

#########################################################
# tri du tableau des matières (2 tris pour l'instant ...)
Subprog TRI_MAT (S)
Value Char S        # code tri "S" par séquence, "O" par opération
#
Case S
  When "O":
    Sorta [M:MFG2]NBLIG [M:MFG2]NBLIG Order By [M:MFG2]BOMOPE(indice), [M:MFG2]ITMREF(indice)
  When "S":
    Sorta [M:MFG2]NBLIG [M:MFG2]NBLIG Order By [M:MFG2]MFGLIN(indice),[M:MFG2]BOMSEQ(indice),
&                                              [M:MFG2]ITMREF(indice)
Endcase
#
# Affzo [M:MFG2]10        # llc 08.01 10038
#

# Issue 119469 GH 04/11/16 - performance enhancement
## 107513 : refresh colour for error or warnings concerning components
#If dim([M:MFG2]ECCVALMAJ)>0
#    Call HIGHLIGHT("MFG2",-1) From ECCLIB
#Endif
End

############################################################
# génération d'un numéro de ligne valide
Subprog GETLINE(L)
Value    Integer  L
Local    Integer  LMAX

# si sous-produit, pas de traitement
If [M:MFG1]ITMTYP(L) = 2 : End : Endif

# FQ 50547 GA 06/2009 affectation immediate du no ligne article lancé
If [M:MFG1]MFGLIN(L)=0
   # FQ 68683 GA 06/2011 pb si ligne 1 (indice 0) porte le numéro 2000
   # If L>1 & [M:MFG1]MFGLIN(L-1)>=1000*(L+1)
    If L>0 & [M:MFG1]MFGLIN(L-1)>=1000*(L+1)
       [M:MFG1]MFGLIN(L)=1000+[M:MFG1]MFGLIN(L-1)
    Else
       [M:MFG1]MFGLIN(L)=1000*(L+1)
    Endif
Endif

# llc 05.00 sous-produit
[M:MFG1]XMFGLIN(L)= [M:MFG1]MFGLIN(L)

End

##################################################################
# Routine de mise à jour de l'encours matières
# [F:MFM] doit être chargé avant l'appel
# LCOD = C,    Création MFx
# LCOD = M,    Modification MFx
# LCOD = A,    Suppression MFx
# LALL = 1     avec mise à jour allocation
##################################################################
Subprog UPDATE_MFX(LCOD, LPJT, LALT, LALL)
Value Char    LCOD
Value Char    LPJT
Value Integer LALT
Value Integer LALL
Local Integer STAT
Local Char    WITM(GLONITM)
Local Integer WRET
Local Integer LTYP
Local Char    WBPC(GLONBPR)
Local Integer WTYPORI, WLINORI, WSEQORI
Local Char    WNUMORI(GLONVCR)

# Issue 88677
Local Integer SAVGOK : SAVGOK=GOK
GOK=1
#
# Issue 98921 GA 04/2014
Raz [M:ORDK]

If [F:MFM]MATSTA > 2 : LCOD = "A" : LALL = 1 : Endif
If [F:MFM]CPNTYP = 5 : End : Endif
If find(LCOD,"C","M","U")
    If GFONC1 = "FUNMCLOSE" : LTYP = 3
    Else                    : LTYP = 1
    Endif
    Call RECH_ITMORI(LTYP, LCOD, WITM, WBPC, WTYPORI, WNUMORI, WLINORI, WSEQORI, WRET)
    If WRET <> 0 : End : Endif

    # lecture article/site
    Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
    If fstat : Raz [ITF] : Endif
Endif
Case LCOD
    When "C" : Case LALL
                   When 1: Call UPDATE_ALL(LCOD)
                   When 2: Call UPDATE_ALL("G")
                   When 3: Call UPDATE_ALL("D")
               Endcase
               If GOK<1 Goto UPDATE_MWX_FIN  Endif # Issue 88677

               # création encours
               Call NUMERO(GWIP,[F:MFM]MFGFCY,[F:MFM]RETDAT,"",[F:MFM]WIPNUM,STAT) From SUBANM
               If STAT <> 0 : Call ERREUR("WIP"-mess(60,199,1)-GWIP-num$(STAT)) From GESECRAN : Endif
              #
               [M:ORDK]MAJCOD     = "C"
               [M:ORDK]WIPTYP     = 6
               [M:ORDK]WIPSTA     = [F:MFM]MFGSTA
               [M:ORDK]WIPNUM     = [F:MFM]WIPNUM
               [M:ORDK]ITMREF     = [F:MFM]ITMREF
               [M:ORDK]ORIFCY     = [F:MFM]PLNFCY
               [M:ORDK]STOFCY     = [F:MFM]MFGFCY
               [M:ORDK]PJT        = LPJT
               [M:ORDK]BPRNUM     = WBPC
               [M:ORDK]STRDAT     = [F:MFM]RETDAT
               [M:ORDK]ENDDAT     = [F:MFM]RETDAT
               [M:ORDK]VCRTYP     = 10
               [M:ORDK]VCRNUM     = [F:MFM]MFGNUM
               [M:ORDK]VCRLIN     = [F:MFM]MFGLIN
               [M:ORDK]VCRSEQ     = [F:MFM]BOMSEQ
               [M:ORDK]EXTQTY     = [F:MFM]RETQTY
               [M:ORDK]CPLQTY     = 0
               [M:ORDK]ALLQTY     = [F:MFM]ALLQTY
               [M:ORDK]SHTQTY     = [F:MFM]SHTQTY
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
               [M:ORDK]VCRTYPORI  = WTYPORI                        # 10.04 26006
               [M:ORDK]VCRNUMORI  = WNUMORI                        # 10.04 26006
               [M:ORDK]VCRLINORI  = WLINORI                        # 10.04 26006
               [M:ORDK]VCRSEQORI  = WSEQORI                        # 10.04 26006
               [M:ORDK]ITMREFORI  = WITM
               [M:ORDK]BOMALT     = LALT
               [M:ORDK]BOMALTTYP  = 2                              # V6
               [M:ORDK]ORI        = 4
               [M:ORDK]ABBFIL     = "MFM"
               [M:ORDK]PIO        = [F:MFM]MFGPIO
               [M:ORDK]BOMOPE     = [F:MFM]BOMOPE
# Issue 107513 - 2015-04-29 by JUSYN : ECC versions into ORDERS
               [M:ORDK]ECCVALMAJ  = [F:MFM]ECCVALMAJ
               [M:ORDK]ECCVALMIN  = [F:MFM]ECCVALMIN
               Call WIP From TRTWIP
    When "M", "U" : # modification allocation                    # llc 10.00 bug 6553
               If LCOD="U"
                   Case LALL
                       When 1: Call UPDATE_ALL2("M","R")
                       When 2: Call UPDATE_ALL2("G","R")
                       When 3: Call UPDATE_ALL2("D","R")
                   Endcase
               Else
                   Case LALL
                       When 1: Call UPDATE_ALL("M")
                       When 2: Call UPDATE_ALL("G")
                       When 3: Call UPDATE_ALL("D")
                   Endcase
               Endif
               If GOK<1 Goto UPDATE_MWX_FIN  Endif # Issue 88677

               # modification encours
               [M:ORDK]MAJCOD     = "M"
               [M:ORDK]WIPTYP     = 6
               [M:ORDK]WIPSTA     = [F:MFM]MFGSTA
               [M:ORDK]WIPNUM     = [F:MFM]WIPNUM
               [M:ORDK]ITMREF     = [F:MFM]ITMREF
               [M:ORDK]ORIFCY     = [F:MFM]PLNFCY
               [M:ORDK]STOFCY     = [F:MFM]MFGFCY
               [M:ORDK]PJT        = LPJT
               [M:ORDK]BPRNUM     = WBPC                        # llc 10.00 bug 6553
               [M:ORDK]STRDAT     = [F:MFM]RETDAT
               [M:ORDK]ENDDAT     = [F:MFM]RETDAT
               [M:ORDK]VCRTYP     = 10
               [M:ORDK]VCRNUM     = [F:MFM]MFGNUM
               [M:ORDK]VCRLIN     = [F:MFM]MFGLIN
               [M:ORDK]VCRSEQ     = [F:MFM]BOMSEQ
               [M:ORDK]EXTQTY     = [F:MFM]RETQTY
               [M:ORDK]CPLQTY     = [F:MFM]USEQTY
               [M:ORDK]ALLQTY     = [F:MFM]ALLQTY
               [M:ORDK]SHTQTY     = [F:MFM]SHTQTY
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
               [M:ORDK]VCRTYPORI  = WTYPORI                     # 10.04 26006
               [M:ORDK]VCRNUMORI  = WNUMORI                     # 10.04 26006
               [M:ORDK]VCRLINORI  = WLINORI                     # 10.04 26006
               [M:ORDK]VCRSEQORI  = WSEQORI                     # 10.04 26006
               [M:ORDK]ITMREFORI  = WITM
               [M:ORDK]BOMALT     = LALT
               [M:ORDK]BOMALTTYP  = 2                           # V6
               [M:ORDK]ORI        = 4
               [M:ORDK]ABBFIL     = "MFM"
               [M:ORDK]PIO        = [F:MFM]MFGPIO
               [M:ORDK]BOMOPE     = [F:MFM]BOMOPE
               [M:ORDK]ORDSTA     = [F:MFM]MATSTA
# Issue 107513 - 2015-04-29 by JUSYN : ECC versions into ORDERS
               [M:ORDK]ECCVALMAJ  = [F:MFM]ECCVALMAJ
               [M:ORDK]ECCVALMIN  = [F:MFM]ECCVALMIN
               Call WIP From TRTWIP
               # si qté besoin = 0 ou qté restante = 0, encours supprimé par TRTWIP
               If ([F:MFM]RETQTY<=[F:MFM]USEQTY)
                   [F:MFM]WIPNUM=""
               Else
                   [F:MFM]WIPNUM = [M:ORDK]WIPNUM
               Endif
    When "A" : # suppression allocation
               If LALL = 1 : Call UPDATE_ALL(LCOD) : Endif
               If GOK<1 Goto UPDATE_MWX_FIN  Endif # Issue 88677
               # suppression encours
               [M:ORDK]MAJCOD     = "A"
               [M:ORDK]WIPTYP     = 6
               [M:ORDK]WIPNUM     = [F:MFM]WIPNUM
               [M:ORDK]ITMREF     = [F:MFM]ITMREF
               Call WIP From TRTWIP
               [F:MFM]WIPNUM      = ""
Endcase
#
If GOK=0
   GMESSAGE="UPDATE_MFX: Erreur de mise à jour de l'encours "-num$([M:ORDK]WIPTYP)-" No="-[M:ORDK]WIPNUM
   mkstat=1
Endif
$UPDATE_MWX_FIN   # Issue 88677
If GOK=1 GOK=SAVGOK Endif
End

##################################################################
# Routine de mise à jour des allocations matières
# [F:MFM] doit être chargé avant l'appel
# LCOD = M,    Modification allocation
# LCOD = A,    Suppression  allocation
##################################################################
Subprog UPDATE_ALL(LCOD)
Value    Char     LCOD

Call UPDATE_ALL2(LCOD,"")

End

Subprog UPDATE_ALL2(LCOD,LSUP)
Value    Char     LCOD
Value    Char     LSUP

Local    Integer  WRET
Local    Decimal  WALL, WSHT, WWRK, WDIFF
Local    Integer  WALLTYP
Local    Char     WCOD(1),XCOD(1)
Local    Integer  MEMSTA : MEMSTA = [F:MFM]ALLSTA # mémo statut
Local    Char     WSUP(1)
#
XCOD = LCOD
If [F:MFM]ALLSTA = 1 & LCOD = "M" : End : Endif
If [F:MFM]ALLSTA = 1 & LCOD = "A" : End : Endif
If [F:MFM]CPNTYP = 5  : End : Endif
#sr 06.01 demande 9734
#Pas d'allocation sur une matière soldée ou dont la quantité prévue est déjà réalisée
If LCOD = "M" & ([F:MFM]MFMTRKFLG = 5 | ([F:MFM]RETQTY - [F:MFM]USEQTY <= 0))
    # Issue 88151 - 2013-03-07 by CCC : Si RETQTY=0 on continue pour effacer les éventuelles allocations existantes
    If [F:MFM]RETQTY=0
        LCOD = "A"
    Else
        End
    Endif
Endif
# 21102 05.04  MM
# Ne pas éliminer allocation de rupture si qté besoin inchangée et mode allocation trs = manuel
If  LCOD = "M" & [F:MFM]SHTQTY<>0
    If ([F:MFM]ALLQTY + [F:MFM]SHTQTY = [F:MFM]RETQTY- [F:MFM]USEQTY) & [F:MTS]MODALL=1
       # FQ 70409 GA 01/2011
       #If dim([M:MFG1]DOVRALLNBR)> 0 : Gosub MAJMFG : Endif :   End
        Goto END_UPDATE_ALL # avant  End
    Endif
Endif
If LCOD = "C" : End : Endif
If find(LCOD,"G","D")
    If LCOD = "G" : WALLTYP = 1 : Endif
    If LCOD = "D" : WALLTYP = 2 : Endif
    LCOD = "C"
Else
    Case [F:MFM]ALLSTA
        When 1:      WALLTYP = 1
        When 2,3:    WALLTYP = 1    # allocation globale
        When 4,5:    WALLTYP = 2    # allocation détaillée
    Endcase
Endif
#
Case LCOD
    When "C":    WALL = [F:MFM]RETQTY
                 WSHT = 0
                 WCOD = "C"
    When "M":    WWRK = [F:MFM]ALLQTY + [F:MFM]SHTQTY
                     If WWRK > [F:MFM]RETQTY - [F:MFM]USEQTY   # si diminution allocation # llc 04.02 13460
                        WDIFF = WWRK - ([F:MFM]RETQTY - [F:MFM]USEQTY)                    # llc 04.02 13460
                        If WDIFF <= [F:MFM]SHTQTY
                            WALL    = 0
                            WSHT    = WDIFF
                        Else
                            WALL    = WDIFF - [F:MFM]SHTQTY
                            WSHT    = [F:MFM]SHTQTY
                        Endif
                        WCOD = "D"
                     Else
                        WALL = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY  # llc 04.02 13460
                        WSHT = [F:MFM]SHTQTY
                        WCOD = "M"
                     Endif
    When "A":        WALL = [F:MFM]ALLQTY
                     WSHT = [F:MFM]SHTQTY
                     WCOD = "A"
Endcase
#
If instr(1,LSUP,"R")
    WSUP = "R"
Endif
Call ALLOCATION2(WCOD, WALLTYP, WSUP, WALL, WSHT, WRET) From MFGALL
If WRET <> 0 : End : Endif
# mise à jour matière
Case WCOD
    When "C": [F:MFM]ALLQTY     = WALL
              [F:MFM]SHTQTY     = WSHT
    When "M": [F:MFM]ALLQTY    += WALL
              [F:MFM]SHTQTY     = WSHT
    When "D": [F:MFM]ALLQTY    -= WALL
              [F:MFM]SHTQTY    -= WSHT
    When "A": # llc 04.02 13460
              [F:MFM]ALLQTY = 0
# Issue 84767 - 2012-11-13 by CCC : Selon WSUP, toutes les ruptures ne sont pas forcément supprimées
#              [F:MFM]SHTQTY = 0
              [F:MFM]SHTQTY -= WSHT
Endcase
# mise à jour statut allocation
# sr 03.05 demande 29007 : On ne touche pas cet indicateur si on solde la matière (WCOD = "A")
If  WCOD <> "A"
    Case [F:MFM]ALLSTA
        When 2,4:   If [F:MFM]SHTQTY = 0  : [F:MFM]ALLSTA += 1 : Endif
        When 3,5:   If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
    Endcase
Endif
Case XCOD
    When "G": If [F:MFM]SHTQTY = 0 : [F:MFM]ALLSTA = 3 : Else : [F:MFM]ALLSTA = 2 : Endif
    When "D": If [F:MFM]SHTQTY = 0 : [F:MFM]ALLSTA = 5 : Else : [F:MFM]ALLSTA = 4 : Endif
Endcase
$END_UPDATE_ALL
# FQ 70409 GA 01/2011 performances à faire une seule fois en fin de maj
# If dim([M:MFG1]DOVRALLNBR)> 0  Gosub MAJMFG endif
# FQ 70633 GA 01/2011 supression appel MAJMFGHEAD car plantage en cloture d'OF
# If GFONCTION<>"GESMFG" Gosub MAJMFGHEAD From MFGLIB Endif
End


###########################################################################
## calcul du besoin (quantite matière)
#########################################################################
Subprog CALCUL_BESOIN(WBASQTY,WSTU,WLIKQTYCOD,WLIKQTY,WQTYRND,WSCA,WSCATIA,WLIEN,WQTY)
Value    Decimal WBASQTY
Value    Integer WLIKQTYCOD
Value    Decimal WLIKQTY
Value    Integer WQTYRND
Value    Char    WSTU
Value    Decimal WSCA
Value    Integer WSCATIA
Variable Decimal WLIEN
Value    Decimal WQTY
Local    Decimal WQTYN, WQTYNA, WQTYB, WQTYBA
#
If WLIKQTY <> 0
    Call LIKQTY(WQTY,WSTU,WBASQTY,WLIKQTYCOD,WLIKQTY,
&           WQTYRND,WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    If WSCATIA <> 1
        WLIEN = WQTYBA
    Else
        WLIEN = WQTYNA
    Endif
Else
    WLIEN = 0
Endif
#
End

#########################################################################
## calcul du quantité productible - Nouvelle formule multi-article
#########################################################################
Subprog CAL_AVAMFGQTY_V6(LMSK,IMAT,IITM)
Value    Char    LMSK
Value    Integer IMAT
Value    Integer IITM

Local    Decimal PCTMAT
Local    Decimal WAVAMFGQTY,WEXTQTY
# on se base sur la quantité allouée ...
Case LMSK
    When "MFG2":
        If IITM<0 | ([M:MFG1]ITMTYP(IITM)<>1 & [M:MFG2]MFGLIN(IMAT) = [M:MFG1]MFGLIN(IITM)) End Endif   # Calcul sur Article lancé uniquement
        If [M:MFG2]USEQTY(IMAT) >= [M:MFG2]RETQTY(IMAT)
&        | [M:MFG2]ALLQTY(IMAT)-[M:MFG2]SHTQTY(IMAT) >= [M:MFG2]RETQTY(IMAT)-[M:MFG2]USEQTY(IMAT)
           # Qté totalement allouée ou consommée, pas de maj (déjà calculé)
            WAVAMFGQTY=GAVAMFG
        Else
            # Pourcentage de manquant sur le reste à consommer # FQ 69695 tenir compte du déjà consommé
            PCTMAT = [M:MFG2]SHTQTY(IMAT) / ([M:MFG2]RETQTY(IMAT)-[M:MFG2]USEQTY(IMAT))
            If IITM>=0 & [M:MFG1]MFGLIN(IITM)>0 & [M:MFG2]MFGLIN(IMAT) = [M:MFG1]MFGLIN(IITM)
            # Matière rattachée à un article lancé: reste à produire
              WEXTQTY     = [M:MFG1]EXTQTY(IITM) - [M:MFG1]CPLQTY(IITM)
            Else
            # Matière globale à l'OF: reste à produire
              WEXTQTY     = [M:MFG1]MFGEXTQTY - [M:MFG1]MFGCPLQTY
            Endif
            WAVAMFGQTY  = [M:MFG1]MFGEXTQTY - [M:MFG1]MFGCPLQTY - (WEXTQTY * PCTMAT)
            # FQ 75141 GA 08/2011 qté productible arrondi à la qté inférieure
            #Call QTEARR(WAVAMFGQTY,[M:MFG1]MFGSTU) From TRTDIV
            Call QTEARR2(WAVAMFGQTY,[M:MFG1]MFGSTU,3) From TRTDIV
        Endif
        If (WAVAMFGQTY <= GAVAMFG) | (GAVAMFG = 9999999999)
            [M:MFG2]AVAMFGQTY = WAVAMFGQTY
            GAVAMFG           = WAVAMFGQTY
        Endif
    When "MFM":
        If [F:MFI2]ITMTYP<>1 & [F:MFM2]MFGLIN=[F:MFI2]MFGLIN End Endif   # Calcul sur Article lancé uniquement
        If [F:MFM2]USEQTY >= [F:MFM2]RETQTY
&        | [F:MFM2]ALLQTY-[F:MFM2]SHTQTY  >= [F:MFM2]RETQTY - [F:MFM2]USEQTY
           # Qté totalement allouée ou consommée, pas de maj (déjà calculé)
            WAVAMFGQTY=GAVAMFG
        Else
           # Pourcentage de manquant sur le reste à consommer
            PCTMAT = [F:MFM2]SHTQTY / ([F:MFM2]RETQTY - [F:MFM2]USEQTY) # FQ 69695 tenir compte du déjà consommé
            If [F:MFI2]MFGLIN>0 & [F:MFM2]MFGLIN=[F:MFI2]MFGLIN
            # Matière rattachée à un article lancé: reste à produire
              WEXTQTY     = [F:MFI2]EXTQTY - [F:MFI2]CPLQTY
            Else
            # Matière globale à l'OF: reste à produire
              WEXTQTY     = [F:MFG]EXTQTY - [F:MFG]CPLQTY
            Endif
            WAVAMFGQTY  = [F:MFG]EXTQTY - [F:MFG]CPLQTY - (WEXTQTY * PCTMAT)
            # FQ 75141 GA 08/2011 qté productible arrondi à la qté inférieure
            #Call QTEARR(WAVAMFGQTY,[F:MFG]STU) From TRTDIV
            Call QTEARR2(WAVAMFGQTY,[F:MFG]STU,3) From TRTDIV
        Endif
        If (WAVAMFGQTY <= GAVAMFG) | (GAVAMFG = 9999999999)
            [F:MFG]AVAMFGQTY  = WAVAMFGQTY
            GAVAMFG           = WAVAMFGQTY
        Endif
Endcase
End
#########################################################################
## calcul du quantité productible - Ancienne formule mono-article
#########################################################################
Subprog CAL_AVAMFGQTY(LMSK,L)     ##### Obsolète !!!! ####
Value    Char    LMSK
Value    Integer L

Local    Decimal PCTMAT
Local    Decimal WAVAMFGQTY
# pour l'instant le système est on ne peut plus simple
# on se base sur la quantité allouée ...
# et on ignore le cas troublant du multi articles lancés !
Case LMSK
    When "MFG2":
                    If [M:MFG1]NBLIG > 1 : End : Endif
                    If [M:MFG2]USEQTY(L) >= [M:MFG2]RETQTY(L)
                        WAVAMFGQTY  = [M:MFG1]MFGEXTQTY - [M:MFG1]CPLQTY(0)
                    Else
                        # llc 06.04 si ligne non allouée, qté productible nulle
                        If [M:MFG2]ALLSTA(L) = 1
                            WAVAMFGQTY = 0
                        Else
                            PCTMAT      = [M:MFG2]SHTQTY(L) / [M:MFG2]RETQTY(L)
                            WAVAMFGQTY  = [M:MFG1]MFGEXTQTY - ([M:MFG1]MFGEXTQTY * PCTMAT)
                            WAVAMFGQTY -= [M:MFG1]CPLQTY(0)
                            Call QTEARR(WAVAMFGQTY,[M:MFG1]MFGSTU) From TRTDIV    # 03.05 29253
                        Endif
                    Endif
                    If (WAVAMFGQTY < GAVAMFG) | (GAVAMFG = 9999999999)
                        [M:MFG2]AVAMFGQTY = WAVAMFGQTY
                        GAVAMFG           = WAVAMFGQTY
                    Endif
    When "MFM":
                    If [F:MFG]ITMLINNBR > 1 : End : Endif
                    If [F:MFM2]USEQTY >= [F:MFM2]RETQTY
                        WAVAMFGQTY  = [F:MFG]EXTQTY - [F:MFG]CPLQTY
                    Else
                        # llc 06.04 si ligne non allouée, qté productible nulle
                        If [F:MFM2]ALLSTA = 1
                            WAVAMFGQTY = 0
                        Else
                            PCTMAT      = [F:MFM2]SHTQTY / [F:MFM2]RETQTY
                            WAVAMFGQTY  = [F:MFG]EXTQTY - ([F:MFG]EXTQTY * PCTMAT)
                            WAVAMFGQTY -= [F:MFG]CPLQTY
                            Call QTEARR(WAVAMFGQTY,[F:MFG]STU) From TRTDIV    # 03.05 29253
                        Endif
                    Endif
                    If (WAVAMFGQTY < GAVAMFG) | (GAVAMFG = 9999999999)
                        [F:MFG]AVAMFGQTY  = WAVAMFGQTY
                        GAVAMFG           = WAVAMFGQTY
                    Endif
Endcase
End

###########################################################################
## boucle de recalcul quantité productible
#########################################################################
Subprog MAJ_AVAMFGQTY(LMSK)
Value Char LMSK

Local Integer I,J

Case LMSK
    When "MFG2":    If [M:MFG1]ALLSTA < 3 # | [M:MFG1]NBLIG > 1         # FQ 69919 GA 01/2011 cas multi-articles
                        [M:MFG2]AVAMFGQTY = 0 : GAVAMFG = 0
                        End
                    Endif
                    GAVAMFG = [M:MFG1]MFGEXTQTY - [M:MFG1]MFGCPLQTY
                    For I=0 To [M:MFG2]NBLIG-1
                        If [M:MFG2]MATSTA(I) <> 4 & [M:MFG2]CPNTYP(I) <> 5
                            # Issue 81049 GA 03/2012 Error when J=-1, [M:MFG1]NBLIG=0
                            If [M:MFG2]MFGLIN(I)>0 & J>=0 & [M:MFG2]MFGLIN(I)<>[M:MFG1]MFGLIN(J)  # Ajout FQ 69919 GA 01/2011
                                J = find([M:MFG2]MFGLIN(I),[M:MFG1]MFGLIN(0..[M:MFG1]NBLIG-1))-1
                            Endif
                            Call CAL_AVAMFGQTY_V6(LMSK,I,J)
                        Endif
                    Next I
                    If [M:MFG2]AVAMFGQTY < 0 : [M:MFG2]AVAMFGQTY = 0 : Endif
    When "MFM":     If [F:MFG]ALLSTA < 3  # | [F:MFG]ITMLINNBR > 1              # FQ 69919 GA 01/2011 cas multi-articles
                        [F:MFG]AVAMFGQTY = 0 : GAVAMFG = 0
                        End
                    Endif
                    If clalev([F:MFM2]) = 0 : Local File MFGMAT [MFM2] : Endif
                    If clalev([F:MFI2]) = 0 : Local File MFGITM [MFI2] : Endif
                    GAVAMFG = [F:MFG]EXTQTY - [F:MFG]CPLQTY
                    For [MFM2] Where MFGNUM = [F:MFG]MFGNUM & [F:MFM2]CPNTYP <> 5 & [F:MFM2]MATSTA <> 4
                        If [F:MFM2]MFGLIN>0 & [F:MFI2]MFGLIN<>[F:MFM2]MFGLIN          # Ajout FQ 69919 GA 01/2011
                           Read [F:MFI2]MFI0=[F:MFM2]MFGNUM;[F:MFM2]MFGLIN
                           If fstat Break Endif
                        Endif
                        Call CAL_AVAMFGQTY_V6(LMSK,0,0)
                    Next
Endcase
End

#########################################################################
## Interrogation de stock
#########################################################################
Subprog MAT_INTSTO(LFCY, LITM, LLOT, LLOC, LSTA)
Value Char    LFCY
Value Char    LITM
Value Char    LLOT
Value Char    LLOC
Value Char    LSTA
#
Local Char    WFCY(GLONFCY) : WFCY = LFCY
Local Char    WITM(GLONITM) : WITM = LITM
Local Char    WLOT(GLONLOT) : WLOT = ""
Local Char    WLOC(GLONLOC) : WLOC = ""
Local Char    WPAL(GLONPAL) : WPAL = ""
Local Char    WCTR(GLONCTR) : WCTR = ""
Local Char    WSER(GLONSER) : WSER = ""
Local Date    WDAT           : WDAT = date$
Local Integer WOPT           : WOPT = 1
Call INTSTO(WFCY,WITM,WLOT,WLOC,WPAL,WCTR,WSER,WDAT,WOPT) From SUBSTOI
#
End

#########################################################################
# Allocation globale d'une matière                                      #
# nouvelle version (08.01 9147)                                         #
#########################################################################
Subprog ALLOC_MAT(L)
#Value Char    WTRT    # FQ 69909 Ctrl des sources
Value Integer L
Local Integer WALLTYP
Local Integer WRET
Local Decimal WCPLQTY
Local Decimal WALL, WSHT
Local Integer MEMSTA
Local Char    WCLE(50)

# constitution de la clé pour les éventuels messages d'erreur ...
WCLE = [M:MFG0]MFGNUM-num$([M:MFG2]MFGLIN(L))-num$([M:MFG2]BOMSEQ(L))-[M:MFG2]ITMREF(L)

WALLTYP = 1

# début de la transaction d'allocation
GOK=1
Call DEBTRANS From GLOCK
$TR_ALLOC
Trbegin ADOVAL

    Readlock [MFM]MFM0=[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(L);[M:MFG2]BOMSEQ(L);[M:MFG2]ITMREF(L)
    If fstat=1  GOK=-1: GLOCK="$MFGMAT"-WCLE              : Goto ROLL_ALLOC
    Elsif fstat GOK=0 : Call RSTA("MFM", WCLE) From GLOCK : Goto AB_ALLOC   : Endif

    If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
        TRTLIG = "C"
    Else
        TRTLIG = "M"
    Endif
    WALL = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY
    WSHT = [F:MFM]SHTQTY
    # Issue 88151 - 2013-03-07 by CCC
    #If WALL = 0 & WSHT = 0 : Goto TR_FIN : Endif
    If [F:MFM]RETQTY<>0 & WALL = 0 & WSHT = 0 : Goto TR_FIN : Endif

    MEMSTA = [F:MFM]ALLSTA # mémo statut    llc 08.02 15532

# appel à la routine de gestion des allocations
    Call ALLOCATION(TRTLIG, WALLTYP, WALL, WSHT, WRET) From MFGALL
    If WRET <> 0 : Goto AB_ALLOC : Endif

# mise à jour matière
    [F:MFM]ALLQTY    += WALL
    [F:MFM]SHTQTY     = WSHT
    [F:MFM]ALLSTA     = 3
# si rupture, maj statut allocation
    If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
# mise à jour matière
    Rewrite [MFM]
    If fstat GOK=0 : Call FSTA("MFM") From GLOCK : Goto AB_ALLOC : Endif
# mise à jour de l'encours
    Call UPDATE_MFX("M", [M:MFG2]PJT(L), [M:MFG2]BOMALT(L), 0)

# FQ 70409 GA 01/2011
# mise à jour écran
   #Gosub MAJMFG
    Gosub MAJMFGHEAD From MFGLIB

# v6 affectations
    Gosub MAJ_MTO_MFM From MFGMTOLIB
#
$TR_FIN
# Issue 117986 - 2016-09-21 by YARAM : Updated [MFG] table &XALLSTA to reflect global allocation through right click on component tab.
Rewrite [MFG]
Commit
[M:MFG1]XALLSTA = mess([F:MFG]ALLSTA,336,1)
Affzo [M:MFG1]XALLSTA
Gosub LIENS From SUBMFG2
Call HIGHLIGHT("MFG2", -1) From ECCLIB : # Affzo [M:MFG2] : # Issue 119469 GH 04/11/16 - display lines with their style
End

$ROLL_ALLOC
Rollback  : Call ROLL From GLOCK
If !GROLL : Goto TR_ALLOC : Endif
End

$AB_ALLOC
Rollback
End



