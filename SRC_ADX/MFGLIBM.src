#########################################################################
# Analyse et mise à jour de l'emplacement matière par défaut            #
#########################################################################
Subprog ANALYSE_LOC(ABMSK, LFCY, LOPENUM, LLIG, LITM)
Value Char    ABMSK
Value Char    LFCY
Value Integer LOPENUM
Value Integer LLIG
Value Char    LITM
Local Integer I
# récupération emplacement préférentiel
# si le stock atelier est géré, on recherche l'opération associée
# si les opérations ne sont pas présentes (cas de la création),
# c'est au moment de la génération des opérations que seront mis à jour
# les emplacements matières
Read [ITF]ITF0=LITM;LFCY
If fstat : End : Endif
Case ABMSK
    When "MFMW":   If [M:MFG3]NBLIG <> 0
                       #If find(LOPENUM,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))
                       #    For I=0 To [M:MFG3]NBLIG-1
                       #        If [M:MFG3]OPENUM(I) = LOPENUM : Break : Endif
                       #    Next I
                       I=find(LOPENUM,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))-1
                       If I>-1
                           Read [MWS]WST0=[M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
                           If !fstat
                               If [F:MWS]STOLOC <> "" : [M:MFMW]LOC      = [F:MWS]STOLOC : Endif
                           Endif
                         # FQ 60622 & 60379 GA 12/2009 Emplacement sous-traitance ?
                           If [M:MFMW]LOC = "" & [M:MFG3]SCOWST(I)<>""
                               Read [MWS]WST0=[M:MFG3]SCOWST(I);[M:MFG0]MFGFCY
                               If !fstat
                                   If [F:MWS]STOLOC <> "" : [M:MFMW]LOC      = [F:MWS]STOLOC : Endif
                               Endif
                           Endif
                           If [M:MFMW]LOC = "" & [M:MFG3]BPRNUM(I)<>"" & [M:MFG3]BPAADD(I)<>""
                              Call FIND_SCOLOC([M:MFG3]BPRNUM(I), [M:MFG3]BPAADD(I), [M:MFMW]LOC, GBIDC1, GBIDC2) From BPRLIB
                           Endif
                       Endif
                   Endif
    When "MFM":    For [MFO]MFO0 Where MFGNUM = [F:MFG]MFGNUM
                       If [F:MFO]OPENUM = LOPENUM
                           Read [MWS]WST0=[F:MFO]EXTWST;[F:MFG]MFGFCY
                           If !fstat
                               If [F:MWS]STOLOC <> "" : [F:MFM]LOC = [F:MWS]STOLOC : Endif
                           Endif
                         # FQ 60622 & 60379 GA 12/2009 Emplacement sous-traitance ?
                           If [F:MFO]SCOWST<>"" & [F:MFM]LOC=""
                               Read [MWS]WST0=[F:MFO]SCOWST;[F:MFG]MFGFCY
                               If !fstat
                                   If [F:MWS]STOLOC <> "" : [F:MFM]LOC = [F:MWS]STOLOC : Endif
                               Endif
                           Endif
                           If [F:MFM]LOC = "" & [F:MFO]BPRNUM<>"" & [F:MFO]BPAADD<>""
                              Call FIND_SCOLOC([F:MFO]BPRNUM, [F:MFO]BPAADD, [F:MFM]LOC, GBIDC1, GBIDC2) From BPRLIB
                           Endif
                       Endif
                   Next
    When Default:  If [M:MFG3]NBLIG <> 0
                       #If find(LOPENUM,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))
                       #    For I=0 To [M:MFG3]NBLIG-1
                       #        If [M:MFG3]OPENUM(I) = LOPENUM : Break : Endif
                       #    Next I
                       I=find(LOPENUM,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))-1
                       If I>-1
                           Read [MWS]WST0=[M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
                           If !fstat
                               If [F:MWS]STOLOC <> "" : [M:MFG2]LOC(LLIG) = [F:MWS]STOLOC : Endif
                           Endif
                         # FQ 60622 & 60379 GA 12/2009 Emplacement sous-traitance ?
                           If [M:MFG2]LOC(LLIG) = "" & [M:MFG3]SCOWST(I)<>""
                               Read [MWS]WST0=[M:MFG3]SCOWST(I);[M:MFG0]MFGFCY
                               If !fstat
                                   If [F:MWS]STOLOC <> "" : [M:MFG2]LOC(LLIG) = [F:MWS]STOLOC : Endif
                               Endif
                           Endif
                           If [M:MFG2]LOC(LLIG) = "" & [M:MFG3]BPRNUM(I)<>"" & [M:MFG3]BPAADD(I)<>""
                              Call FIND_SCOLOC([M:MFG3]BPRNUM(I), [M:MFG3]BPAADD(I), [M:MFG2]LOC(LLIG), GBIDC1, GBIDC2) From BPRLIB
                           Endif
                       Endif
                   Endif
Endcase
End


#########################################################################
# Analyse et mise à jour de l'emplacement matière par défaut            #
#########################################################################
Subprog ANALYSE_STR(ABMSK, LOPENUM, LLIG)
Value Char    ABMSK
Value Integer LOPENUM
Value Integer LLIG
Local Integer I
Local Integer TROUVE
#
Case ABMSK
    When "MFMW" : [M:MFMW]SCOFLG = 1
    When "MFM"  : [F:MFM]SCOFLG = 1
                  For [MFO]MFO0 Where MFGNUM = [F:MFG]MFGNUM
                      If [F:MFO]OPENUM = LOPENUM
                        Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
                        If !fstat
                            If [F:MWS]WSTTYP = 3
                                [F:MFM]SCOFLG = 2
                            Endif
                        Endif
                      Endif
                  Next
                  End
    When Default: [M:MFG2]SCOFLG(LLIG) = 1
Endcase

If [M:MFG3]NBLIG <> 0
    If find(LOPENUM,[M:MFG3]OPENUM(0..[M:MFG3]NBLIG-1))
        For I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = LOPENUM : Break : Endif
        Next I
        Read [MWS]WST0=[M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
        If !fstat
            If [F:MWS]WSTTYP = 3
                Case ABMSK
                    When "MFMW" : [M:MFMW]SCOFLG = 2
                    When Default: [M:MFG2]SCOFLG(LLIG) = 2
                Endcase
                TROUVE=0
                # stock conso
                # 12.03 MM : multi-emplacement
                # Recherche de l'emplacement du client livré
                If [M:MFG3]BPRNUM(I) <> "" & [M:MFG3]BPAADD(I) <> ""
                    If clalev([F:BPD])   = 0 : Local File BPDLVCUST   [BPD]   : Endif
                    Read [BPD]BPD0=[M:MFG3]BPRNUM(I);[M:MFG3]BPAADD(I)
                    If fstat : End : Endif
                    If [F:BPD]SCOLOC <>""
                       # 06.06 demande 36661 mettre à jour aussi si code écran est MFMW
                       Case ABMSK
                            When "MFMW" : [M:MFMW]LOC = [F:BPD]SCOLOC
                            When Default: [M:MFG2]LOC(I) = [F:BPD]SCOLOC
                       Endcase
                       TROUVE =1
                    Endif
                Endif
                # Recherche de l'emplacement du fournisseur
                If TROUVE =0
                    If [M:MFG3]BPRNUM(I) <> ""
                        If clalev([F:BPS])   = 0 : Local File BPSUPPLIER    [BPS]   : Endif
                        Read [BPS]BPS0=[M:MFG3]BPRNUM(I)
                        If !fstat
                            If [F:BPS]LOC <> ""
                                Case ABMSK
                                    When "MFMW" : [M:MFMW]LOC = [F:BPS]LOC
                                    When Default: [M:MFG2]LOC(LLIG) = [F:BPS]LOC
                                Endcase
                            Endif
                        Endif
                    Endif
                 Endif
            Endif
        Endif
    Endif
Endif


#
End

#########################################################################
# Recherche article origine                                             #
#########################################################################
Subprog RECH_ITMORI(LTYP, LCOD, LITM, LBPC, LTYPORI, LNUMORI, LLINORI, LSEQORI, LRET)                # llc 10.00 bug 6553 + 10.04 26006
Value    Integer LTYP
Value    Char    LCOD
Variable Char    LITM
Variable Char    LBPC                                            # llc 10.00 bug 6553
Variable Integer LTYPORI                                         # 10.04 26006
Variable Char    LNUMORI                                         # 10.04 26006
Variable Integer LLINORI                                         # 10.04 26006
Variable Integer LSEQORI                                         # 10.04 26006
Variable Integer LRET
Local    Integer I
#
LRET = 0

Case LTYP
    When 1:
              Case LCOD
                   When "C","U":                                  # llc 10.00 bug 6553
                       If [M:MFG1]NBLIG = 1
                           LITM = [M:MFG1]ITMREF(0)
                           LBPC = [M:MFG1]BPCNUM(0)               # llc 10.00 bug 6553
                           LTYPORI = [M:MFG1]VCRTYPORI(0)         # 10.04 26006
                           LNUMORI = [M:MFG1]VCRNUMORI(0)         # 10.04 26006
                           LLINORI = [M:MFG1]VCRLINORI(0)         # 10.04 26006
                           LSEQORI = [M:MFG1]VCRSEQORI(0)         # 10.04 26006
                       Else
                           If [F:MFM]MFGLIN = 0
                               LITM = [M:MFG1]ROUNUM
                               LBPC = [M:MFG0]MFGFCY               # llc 10.00 bug 6553
                           Else
                               For I = 0 To [M:MFG1]NBLIG-1
                                   If [M:MFG1]MFGLIN(I) = [F:MFM]MFGLIN
                                       LITM = [M:MFG1]ITMREF(I)
                                       LBPC = [M:MFG1]BPCNUM(I)               # llc 10.00 bug 6553
                                       LTYPORI = [M:MFG1]VCRTYPORI(I)         # 10.04 26006
                                       LNUMORI = [M:MFG1]VCRNUMORI(I)         # 10.04 26006
                                       LLINORI = [M:MFG1]VCRLINORI(I)         # 10.04 26006
                                       LSEQORI = [M:MFG1]VCRSEQORI(I)         # 10.04 26006
                                       Break
                                   Endif
                               Next I
                           Endif
                       Endif
                   When "M": Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF
                             If fstat : End : Endif
                             LITM = [F:ORD]ITMREFORI
                             LBPC = [F:ORD]BPRNUM                 # llc 04.02 13868
                             LTYPORI = [F:ORD]VCRTYPORI           # 10.04 26006
                             LNUMORI = [F:ORD]VCRNUMORI           # 10.04 26006
                             LLINORI = [F:ORD]VCRLINORI           # 10.04 26006
                             LSEQORI = [F:ORD]VCRSEQORI           # 10.04 26006
             Endcase
    When 2:   Case LCOD
                   When "C": For I = 0 To [M:MFG1]NBLIG - 1
                                 If [M:MFG1]MFGLIN(I) = [F:MFI]ITMLIN
                                     LITM = [M:MFG1]ITMREF(I)
                                     LBPC = [M:MFG1]BPCNUM(I)               # llc 04.02 13868
                                     LTYPORI = [M:MFG1]VCRTYPORI(I)         # 10.04 26006
                                     LNUMORI = [M:MFG1]VCRNUMORI(I)         # 10.04 26006
                                     LLINORI = [M:MFG1]VCRLINORI(I)         # 10.04 26006
                                     LSEQORI = [M:MFG1]VCRSEQORI(I)         # 10.04 26006
                                     Break
                                 Endif
                             Next I
                   When "M": Read [ORD]ORD0=9;[F:MFI]WIPNUM;[F:MFI]ITMREF
                             If fstat : End : Endif
                             LITM = [F:ORD]ITMREFORI
                             LBPC = [F:ORD]BPRNUM                 # llc 04.02 13868
                             LTYPORI = [F:ORD]VCRTYPORI           # 10.04 26006
                             LNUMORI = [F:ORD]VCRNUMORI           # 10.04 26006
                             LLINORI = [F:ORD]VCRLINORI           # 10.04 26006
                             LSEQORI = [F:ORD]VCRSEQORI           # 10.04 26006
                   Endcase
     When 3:       Read [ORD]ORD0=9;[F:MFI]WIPNUM;[F:MFI]ITMREF
                   If fstat : End : Endif
                   LITM = [F:ORD]ITMREFORI
                   LBPC = [F:ORD]BPRNUM
                   LTYPORI = [F:ORD]VCRTYPORI           # 10.04 26006
                   LNUMORI = [F:ORD]VCRNUMORI           # 10.04 26006
                   LLINORI = [F:ORD]VCRLINORI           # 10.04 26006
                   LSEQORI = [F:ORD]VCRSEQORI           # 10.04 26006
Endcase
#
End

#########################################################################################
# contrôle d'atteinte du seuil de solde automatique
Subprog CONT_SOLDE_MAT(LFCY, LITM, LCPL, LEXT, LRET)
Value     Char     LFCY    # site
Value     Char     LITM    # matière
Value     Decimal  LCPL    # quantité réalisée
Value     Decimal  LEXT    # quantité prévue
Variable  Integer  LRET    # code retour        0 = rien, 1 = à solder
Local     Decimal  LWRK
Local     Decimal  LPCT

# 11.08 si lien de type nul, pas de contrôle, le solde se fait manuellement ou a la clôture
If LEXT <= 0 : LRET = 0 : End : Endif

# lecture article/site si nécessaire
If [F:ITF]ITMREF <> LITM
    Read [ITF]ITF0=LITM;LFCY
    If fstat : LRET = 0 : End : Endif
Endif
# calcul seuil pour solde
If [F:ITF]CLEPCTAUT = 0
    LPCT = 100
Else
    LPCT = [F:ITF]CLEPCTAUT
Endif
LWRK = LEXT * (LPCT / 100)
If LWRK <= LCPL
    LRET = 1
Else  # CCC (10/12/08) Bug 50774 : forcer la valeur à 0 si pas de solde
    LRET = 0
Endif
#
End

#########################################################################################
# contrôle présence matières cumulées avec quantité forfaitaire
Subprog CONT_MAT_CUM(LRET)
Variable Integer LRET
Local    Integer I
#
LRET = 0
For I = 0 To [M:MFG2]NBLIG-1
    If [M:MFG2]CUMFLG(I) = 2 & [M:MFG2]MFGLIN(I) = 0
        LRET = 1
        Break
    Endif
Next I
#
End

#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 10
[M:ALL]VCRNUM    = [M:MFG0]MFGNUM
[M:ALL]VCRLIN    = [M:MFG2]MFGLIN(LNOL)
[M:ALL]VCRSEQ    = [M:MFG2]BOMSEQ(LNOL)
[M:ALL]PCU       = [M:MFG2]STU(LNOL)
[M:ALL]STU       = [M:MFG2]STU(LNOL)
# 11.05 demande 33011
[M:ALL]STOLOC    = [M:MFG2]LOC(LNOL)
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [M:MFG2]RETQTY(LNOL) - [M:MFG2]USEQTY(LNOL)
If [M:ALL]RETQTY < 0  : [M:ALL]RETQTY = 0  : Endif
[M:ALL]OLDALLQTY = [M:MFG2]ALLQTY(LNOL)
[M:ALL]SHTQTY    = [M:MFG2]SHTQTY(LNOL)
# Alimentation de la qté à allouer
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
# sr 05.05
If find([M:MFG2]ALLSTA(LNOL),2,3)
     [M:ALL]ALLTYP = 1
     [M:ALL]GLOALLQTY = [M:MFG2]ALLQTY(LNOL)
Else
     [M:ALL]ALLTYP = 2
     Raz [M:ALL]GLOALLQTY
Endif
[M:ALL]RETDAT    = [M:MFG2]RETDAT(LNOL)
[M:ALL]DLVDAT    = [M:MFG2]RETDAT(LNOL)
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2
If [M:MFG2]SCOFLG(LNOL) = 2 : # Prise en compte emplacements sous-traitants
    [M:ALL]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [M:MFG2]BOMOPE(LNOL) <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[M:MFG0]MFGNUM & OPENUM=[M:MFG2]BOMOPE(LNOL)
&                    Order By Key MFO0
        For [MFO]
            [M:ALL]BPCORD = [F:MFO]BPRNUM
            [M:ALL]BPAADD = [F:MFO]BPAADD
            If [M:ALL]BPCORD <> "" : Break : Endif
        Next
        Filter [MFO]
    Endif
Else
    [M:ALL]PECSCOLOC = 1
Endif
[M:ALL]XLOT      = [M:MFG2]LOT(LNOL)
[M:ALL]XLOC      = [M:MFG2]LOC(LNOL)
[M:ALL]XSTA      = [M:MFG2]STA(LNOL)
# 107513
If dim([M:MFG2]ECCVALMAJ) >= 0
  [M:ALL]WECCVALMAJ = [M:MFG2]ECCVALMAJ(LNOL)
Endif

Diszo [M:ALL]QTYTOALL
Return

#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
# Utilisé en mode Allocation manuelle uniquement                        #
#---------------------------------------------------------------------- #


$AVANT_STOALL
Return

$APRES_STOALL
Local Integer WRET : WRET=0
Local Decimal WDIS

# FQ 70409 GA 01/2011
Call MAJALLMAT2([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, [M:ALL]ALLTYP, WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Return : Endif

# FQ 70409 GA 01/2011 dernier composant alloué => maj de l'entete d'OF  # FQ 73894 LLC 05/2011 suppression du test dernier
Call MAJALLMFG([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF,WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Return : Endif

# relecture données OF (mises à jour par MAJALLMAT)
# lecture entête OF
If [F:MFG]MFGNUM <> [M:MFG0]MFGNUM
    Read [MFG]MFG0=[M:MFG0]MFGNUM
    If fstat : Return : Endif
Endif

# lecture matière
Read [MFM]MFM0=[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(LNOL);[M:MFG2]BOMSEQ(LNOL);[M:MFG2]ITMREF(LNOL)
If fstat : Return : Endif

[M:MFG2]ALLQTY(LNOL) = [F:MFM]ALLQTY
[M:MFG2]SHTQTY(LNOL) = [F:MFM]SHTQTY
[M:MFG2]ALLSTA(LNOL) = [F:MFM]ALLSTA

WDIS = 0
Call LECITV2([M:MFG0]MFGFCY, [M:MFG2]ITMREF(LNOL), WRET) From MFGLIB
If WRET = 0 &  [F:MFM]STOMGTCOD=2 # Issue 87587 si et seulement si article géré en stock
    # recherche stock disponible
    #--- Issue 115110 & 120426 : Added LECCVAL parameter in 10th position
    #Call STODISALL(LFCY,[F:ITM]ITMREF,10,1,2,1,2,"","",WDIS,WRET) From STKALL
    Call STODISALL(LFCY,[F:ITM]ITMREF,func TRTX3FNC.VALFLD_C("[M:MFG2]ECCVALMAJ("+num$(LNOL)+")"),WDIS) From MFGLIBM
    Call QTEARR(WDIS,[M]STU) From TRTDIV
Endif

[M:MFG2]AVAQTY(LNOL) = WDIS + [F:MFM]ALLQTY

[M:MFG1]ALLSTA = [F:MFG]ALLSTA
[M:MFG1]XALLSTA = mess([F:MFG]ALLSTA,336,1)

[M:MFG1]DALLSTA    = [F:MFG]ALLSTA
[M:MFG1]DOVRALLNBR = [F:MFG]OVRALLNBR
[M:MFG1]DDETALLNBR = [F:MFG]DETALLNBR
[M:MFG1]DSHTMATNBR = [F:MFG]SHTMATNBR

Call UPDATE_FDMA(0) From SUBMFG2    # X3-3999 Display the first date of availability of each component
Call UPDATE_FDMA() From SUBMFG3    # X3-3999 Display the first date of availability of each operation

Affzo [M:MFG2]5-10
Affzo [M:MFG1]20

Return

###########################################################################################
# Issue 120426 GH 19/12/2016 - Available stock, considering a potential major version
###########################################################################################
Subprog STODISALL(FCY,ITM,ECCVALMAJ,DIS)
Value    Char    FCY()
Value    Char    ITM()
Value    Char    ECCVALMAJ()
Variable Decimal DIS

Local Integer WRET

If ECCVALMAJ<>''
   If [F:ITM]ITMREF<>ITM
      Read [ITM]ITM0=ITM
      If fstat : WRET=1 : Endif
   Endif
   If !WRET
      If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
      Call LECSRU(FCY,[F:ITM]TCLCOD,6,"","",WRET) From STKLIB
   Endif
   If WRET | [F:SRU]ORDVER<>2
      ECCVALMAJ=''
   Endif
Endif

#--- Issue 115110 : Added LECCVAL parameter in 10th position
Call STODISALL(FCY,ITM,10,2,2,1,2,"","",ECCVALMAJ,DIS,WRET) From STKALL
End

#############################################################################################################
# Issue X3-48941 - 2017-08-17 by JUSYN : Check for BOM load for versioned product for audit material changes
#############################################################################################################
Subprog VBOMLOAD(L)
Value Integer L
Local Integer I,J,K

If dim([M:MFG1]ECCVALMAJ)<0 : End : Endif # Issue X3-55832

If GMFGREV <> 2 : End : Endif
If GREP = "C"   : End : Endif

If [M:MFG1]ECCVALMAJ(L) <> ""
    J = find([M:MFG1]MFGLIN(L),GMFGLINVCH)
    If J < 1
        K = find(0,GMFGLINVCH)
        GMFGLINVCH(K-1) = [M:MFG1]MFGLIN(L)
    Endif
Endif

End

