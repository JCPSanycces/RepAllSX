#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# UTIVEN69438 TOOL TO INITIALIZE THE LPNCOD & LPNSCR FIELDS IN THE
# TRANSACTION OF CUSTOMER RETURNS  (LCC 27/02/2018)                                               #
######################################################################################

  Call MAJ_UTIVEN69438
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIVEN69438
Local Char DOSSIER(30)

  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTIVEN69438 - New sales custormer returns & credit memo transaction fields initialisation") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIVEN69438 - New sales custormer returns & credit memo transaction fields initialisation") From LECFIC
    Call EXE_UTIVEN69438(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTIVEN69438(DOSSIER)
Value Char    DOSSIER

  If clalev([F:ACV])>0 : Close File [ACV] : Endif
  Local File =DOSSIER+".ACTIV" [ACV]

  Call ECR_TIME("UTIVEN69438 : Start folder's process"-DOSSIER) From DOSSUB

  If func AFNC.ACTIV("LPN")=0 : Goto FIN_UTIVEN69438 : Endif

  #----- Chargement globale GMAXUPDTRS -----#
  If dim([V]GMAXUPDTRS) < 1 Then
    Global Integer GMAXUPDTRS
  Endif
  Local File =DOSSIER+".ADOVAL" [ADW]
  Read [ADW] ADW0="";"";"MAXUPDTRS"
  If fstat Then
    Raz [F:ADW]
  Endif
  If val([F:ADW]VALEUR) > 0 Then
    GMAXUPDTRS = val([F:ADW]VALEUR)
  Else
    GMAXUPDTRS = 1000
  Endif
  Close Local File [ADW]
  #----- Début mise à jour SALTRS -----#
  Gosub TRT_SLT
  #----- Fin mise à jour SALTRS   -----#

$FIN_UTIVEN69438
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTIVEN69438 : End folder's process"-DOSSIER) From DOSSUB

  Close File [ACV]
End

#-------------------------------------------------------------------------------#
#   Initialisation des nouveaux champs dans les transactions vente              #
# ----------------------------------------------------------------------------- #
# Table SALTRS - Transactions vente                                             #
#-------------------------------------------------------------------------------#
$TRT_SLT
Local Shortint INDIC

  If filinfo(filpath("FIL","SALTRS","fde",DOSSIER),0) <= 0 Then
    Return
  Endif
  #-------------------------------------------------------------------------------#
  # Initialisation transactions ventes pour les nouvelles zones                   #
  #-------------------------------------------------------------------------------#
  Call ECR_TIME("UTIVEN69438 Sales Transactions Process : Update SALTRS") From DOSSUB
  Local File =DOSSIER+".SALTRS"    [SLT]
  #
  Call ECR_TIME("UTIVEN69438 Customer return & Credit memo Transactions Process") From DOSSUB
  Gosub TXN_SRH_SIH

  Close Local File [SLT]
Return

#-------------------------------------------------------------------------------#
# Customer returns transaction                                      #
#-------------------------------------------------------------------------------#
$TXN_SRH_SIH
  Trbegin [SLT]
  For [SLT]SLT0 Where STRTYP = 6 or STRTYP = 5 # Customer return & Credit memos
    Raz INDIC
    If dim([F:SLT]LPNCOD) > 0 Then
      If !find([F:SLT]LPNCOD ,1,2,3) Then
        # Container fields = Hidden
        INDIC = 1
        [F:SLT]LPNCOD  = 3
      Endif
    Endif
    If dim([F:SLT]LPNSCR) > 0 Then
      If !find([F:SLT]LPNSCR ,1,2,3) Then
        # Container fields entry mode = Form & table
        INDIC = 1
        [F:SLT]LPNSCR  = 1
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [SLT]
      If fstat Then
        Call ECR_TRACE("File SALTRS, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
  Commit
Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN69438(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call EXE_UTIVEN69438(APPLI)
End

