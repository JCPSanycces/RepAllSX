#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DICROW","DICROW",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"    : Gosub INIT
 When "EXEC"    : Gosub EXEC
Endcase
Return

$INIT
Local Mask DICROW [DIA]
If clalev([F:DIC])=0  : Local File DICOEMP [DIC]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE  [ATX]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON [ATZ]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV   [ACV]  : Endif

Local Char CRITERE (200)
CRITERE = "1=1"
For [DIC]DIC2(1) Where CODACT<>""
 Read [ACV]CODACT=[F:DIC]CODACT
 If fstat | [F:ACV]FLACT<>2
  CRITERE -= "& CODACT<>'"+[F:DIC]CODACT+"'"
 Endif
Next

nolign = 0
For [DIC]DIC0 Where evalue(CRITERE)
 nolign += 1
 [M:DIA] = [F:DIC]
 Call TEXTE([F:DIC]DES,[M:DIA]WDES(nolign-1)) From OBJDIV
Next
[M:DIA]NBRLIG = nolign
Sorta [M:DIA]NBRLIG [M:DIA]NBRLIG Order By [M:DIA]ROW(indice)
Return

$EXEC
 Trbegin [DIC]
  Sorta [M:DIA]NBRLIG [M:DIA]NBRLIG Order By [M:DIA]ROW(indice)
  For nolign=1 To [M:DIA]NBRLIG
   Read [DIC]DIC0 = [M:DIA]FLD(nolign-1)
   [F:DIC] = [M:DIA] : # JML 20/08/10 For my new zone POTFLG LOT P01
   [F:DIC]ENAFLG = [M:DIA]ENAFLG(nolign-1)
   [F:DIC]ENASEL = [M:DIA]ENASEL(nolign-1)
   #58002
   If dim([M:DIA]MSFLG)>0
    [F:DIC]MSFLG  = [M:DIA]MSFLG(nolign-1)
   Endif
   [F:DIC]ROW    = [M:DIA]ROW(nolign-1)
#  Read [ATZ]CODZONE = [F:DIC]TBL;[F:DIC]FLD
#   [F:DIC]DES = [F:ATZ]NOLONG
   Rewrite [DIC]
   If fstat
    GOK = 0 : Call FSTA("DIC") From GLOCK : Break
   Endif
  Next nolign
 Commit
Return

Subprog AS_POTFLG(VALEUR)
Variable Integer VALEUR
If [M]TBL(nolign-1)<>"EMPLOCTR"
 mkstat = 1 : End
Endif
End

Subprog B1_POTFLG(VALEUR)
Variable Integer VALEUR
Local Integer L_IJ
For L_IJ=nolign To [M]NBRLIG-1
 If [M]TBL(L_IJ)="EMPLOCTR"
  [M]POTFLG(L_IJ) = VALEUR
  Affzo POTFLG(L_IJ)
 Endif
Next L_IJ
End

#72211
Subprog AS_FLGRET(VALEUR)
Variable Integer VALEUR
If [M]TBL(nolign-1)<>"EMPLOCTR"
 mkstat = 1 : End
Endif
End

#72211
Subprog B1_FLGRET(VALEUR)
Variable Integer VALEUR
Local Integer L_IJ
For L_IJ=nolign To [M]NBRLIG-1
 If [M]TBL(L_IJ)="EMPLOCTR"
  [M]FLGRET(L_IJ) = VALEUR
  Affzo FLGRET(L_IJ)
 Endif
Next L_IJ
End

