#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HREQGOA
#ADNGO - 2017-07-11 - X3-11515 - START
#FRLAA - 2015-09-09 - REQUIREMENT 104631 US 3878 - START
$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "MODIF"          : Gosub MODIF
  When "CREATION"       : Gosub CREATION
  When "RAZCRE"         : Gosub LIENS
  When "FERME"          : Gosub FERME #ADNGO - 2017-07-26 - X3-11515
 When Default
Endcase
Return


$OUVRE
If clalev([F:HREQDET])=0        : Local File HREQNUMDET        [HREQDET]             : Endif
If clalev([F:HREQGOA])=0        : Local File HREQNUMGOAL       [HREQGOA]             : Endif
#ADNGO - 2017-11-07 - X3-11515 - START
  #If dim(GCURLEG) > 0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG=GCURLEG : Endif
#ADNGO - 2017-11-07 - X3-11515 - END
Return

$MODIF
$CREATION
Local Integer ADDCNT, K

Filter [F:HREQDET]
Delete [F:HREQDET] Where PLNNUM = [M:HREQGOA0]PLNNUM
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("HREQDET",[M:HREQGOA0]PLNNUM) From GLOCK : Return
Endif

If dim([F:HREQDET]PLNNUM)> 0
  Filter [F:HREQDET]
  Delete [F:HREQDET] Where PLNNUM = [M:HREQGOA0]PLNNUM
  If fstat=1 | fstat>5
    GOK=0 : Call RSTA("HREQDET",[M:HREQGOA0]PLNNUM) From GLOCK : Return
  Endif
Endif

For K = 1 To 2
 If K = 1 : Default Mask [HREQGOA1] : Else Default Mask [HREQGOA2] : Endif

  nolign = 0
  Raz [F:HREQDET]
  [F:HREQDET]                     = [M:HREQGOA0]
  [F:HREQDET]PLNTYP               = K
  For I = 1 To 6
    nolign += 1
    [F:HREQDET]AFRMAL(nolign-1)   = [M]AFRMAL(nolign-1)
    [F:HREQDET]COLMAL(nolign-1)   = [M]COLMAL(nolign-1)
    [F:HREQDET]INDMAL(nolign-1)   = [M]INDMAL(nolign-1)
    [F:HREQDET]WHIMAL(nolign-1)   = [M]WHIMAL(nolign-1)
    [F:HREQDET]AFRFEM(nolign-1)   = [M]AFRFEM(nolign-1)
    [F:HREQDET]COLFEM(nolign-1)   = [M]COLFEM(nolign-1)
    [F:HREQDET]INDFEM(nolign-1)   = [M]INDFEM(nolign-1)
    [F:HREQDET]WHIFEM(nolign-1)   = [M]WHIFEM(nolign-1)
    [F:HREQDET]FGNMAL(nolign-1)   = [M]FGNMAL(nolign-1)
    [F:HREQDET]FGNFEM(nolign-1)   = [M]FGNFEM(nolign-1)
  Next

  nolign += 2
  [F:HREQDET]AFRMAL(nolign-2)   = [M]AFRMAL(nolign-1)
  [F:HREQDET]COLMAL(nolign-2)   = [M]COLMAL(nolign-1)
  [F:HREQDET]INDMAL(nolign-2)   = [M]INDMAL(nolign-1)
  [F:HREQDET]WHIMAL(nolign-2)   = [M]WHIMAL(nolign-1)
  [F:HREQDET]AFRFEM(nolign-2)   = [M]AFRFEM(nolign-1)
  [F:HREQDET]COLFEM(nolign-2)   = [M]COLFEM(nolign-1)
  [F:HREQDET]INDFEM(nolign-2)   = [M]INDFEM(nolign-1)
  [F:HREQDET]WHIFEM(nolign-2)   = [M]WHIFEM(nolign-1)
  [F:HREQDET]FGNMAL(nolign-2)   = [M]FGNMAL(nolign-1)
  [F:HREQDET]FGNFEM(nolign-2)   = [M]FGNFEM(nolign-1)
  Write [F:HREQDET]
  If fstat
    GOK=0 : Call FSTA("HREQDET") From GLOCK
  Endif
Next
Gosub LIENS

Return

$LIENS
Local Integer K
#ADNGO - 2017-11-07 - X3-11515 - START
[M:HREQGOA0]LEG = "ZAF"
GCURLEG = [M:HREQGOA0]LEG
#ADNGO - 2017-11-07 - X3-11515 - END
For K = 1 To 2
  If K = 1 : Default Mask [HREQGOA1] : Else Default Mask [HREQGOA2] : Endif
  Raz [HREQDET]
  Filter [HREQDET] Where PLNNUM = [F:HREQGOA]PLNNUM & PLNTYP = K
  Read [HREQDET] First
  nolign = 0
  For I=1 To 6
    nolign += 1
    [M]OCCLEV(nolign-1) = mess(nolign,11670,1)
    [M]AFRMAL(nolign-1) = [F:HREQDET]AFRMAL(nolign-1)
    [M]COLMAL(nolign-1) = [F:HREQDET]COLMAL(nolign-1)
    [M]INDMAL(nolign-1) = [F:HREQDET]INDMAL(nolign-1)
    [M]WHIMAL(nolign-1) = [F:HREQDET]WHIMAL(nolign-1)
    [M]AFRFEM(nolign-1) = [F:HREQDET]AFRFEM(nolign-1)
    [M]COLFEM(nolign-1) = [F:HREQDET]COLFEM(nolign-1)
    [M]INDFEM(nolign-1) = [F:HREQDET]INDFEM(nolign-1)
    [M]WHIFEM(nolign-1) = [F:HREQDET]WHIFEM(nolign-1)
    [M]FGNMAL(nolign-1) = [F:HREQDET]FGNMAL(nolign-1)
    [M]FGNFEM(nolign-1) = [F:HREQDET]FGNFEM(nolign-1)
  Next
  nolign += 1
  [M]OCCLEV(nolign-1) = mess(00052,00103,1) - mess(00001,11671,1)
  nolign += 1
  [M]OCCLEV(nolign-1) = mess(00019,02288,1)
  [M]AFRMAL(nolign-1) = [F:HREQDET]AFRMAL(nolign-2)
  [M]COLMAL(nolign-1) = [F:HREQDET]COLMAL(nolign-2)
  [M]INDMAL(nolign-1) = [F:HREQDET]INDMAL(nolign-2)
  [M]WHIMAL(nolign-1) = [F:HREQDET]WHIMAL(nolign-2)
  [M]AFRFEM(nolign-1) = [F:HREQDET]AFRFEM(nolign-2)
  [M]COLFEM(nolign-1) = [F:HREQDET]COLFEM(nolign-2)
  [M]INDFEM(nolign-1) = [F:HREQDET]INDFEM(nolign-2)
  [M]WHIFEM(nolign-1) = [F:HREQDET]WHIFEM(nolign-2)
  [M]FGNMAL(nolign-1) = [F:HREQDET]FGNMAL(nolign-2)
  [M]FGNFEM(nolign-1) = [F:HREQDET]FGNFEM(nolign-2)

  nolign += 1
  [M]OCCLEV(nolign-1) = mess(00052,00103,1)

  Assign "[M]EQGOANUM" With nolign
  Filter [HREQDET]

  #Do the calculations
  Call CALCTOT()
  Gosub CHNGESTYLE
Next



Return

#ADNGO - 2017-11-07 - X3-11515 - START
$FERME
  #If dim(SAV_GCURLEG) : GCURLEG = SAV_GCURLEG : Endif
Return
#ADNGO - 2017-11-07 - X3-11515 - END
$CHNGESTYLE

  Diszo [M]AFRMAL(6) : Diszo [M]AFRMAL(8) : Chgstl [M]AFRMAL(6) With "PLGCUR" : Chgstl [M]AFRMAL(8) With "PLGCUR2"
  Diszo [M]COLMAL(6) : Diszo [M]COLMAL(8) : Chgstl [M]COLMAL(6) With "PLGCUR" : Chgstl [M]COLMAL(8) With "PLGCUR2"
  Diszo [M]INDMAL(6) : Diszo [M]INDMAL(8) : Chgstl [M]INDMAL(6) With "PLGCUR" : Chgstl [M]INDMAL(8) With "PLGCUR2"
  Diszo [M]WHIMAL(6) : Diszo [M]WHIMAL(8) : Chgstl [M]WHIMAL(6) With "PLGCUR" : Chgstl [M]WHIMAL(8) With "PLGCUR2"
  Diszo [M]AFRFEM(6) : Diszo [M]AFRFEM(8) : Chgstl [M]AFRFEM(6) With "PLGCUR" : Chgstl [M]AFRFEM(8) With "PLGCUR2"
  Diszo [M]COLFEM(6) : Diszo [M]COLFEM(8) : Chgstl [M]COLFEM(6) With "PLGCUR" : Chgstl [M]COLFEM(8) With "PLGCUR2"
  Diszo [M]INDFEM(6) : Diszo [M]INDFEM(8) : Chgstl [M]INDFEM(6) With "PLGCUR" : Chgstl [M]INDFEM(8) With "PLGCUR2"
  Diszo [M]WHIFEM(6) : Diszo [M]WHIFEM(8) : Chgstl [M]WHIFEM(6) With "PLGCUR" : Chgstl [M]WHIFEM(8) With "PLGCUR2"
  Diszo [M]FGNMAL(6) : Diszo [M]FGNMAL(8) : Chgstl [M]FGNMAL(6) With "PLGCUR" : Chgstl [M]FGNMAL(8) With "PLGCUR2"
  Diszo [M]FGNFEM(6) : Diszo [M]FGNFEM(8) : Chgstl [M]FGNFEM(6) With "PLGCUR" : Chgstl [M]FGNFEM(8) With "PLGCUR2"
  Chgstl [M]OCCLEV(6) With "PLGCUR" : Chgstl [M]OCCLEV(8) With "PLGCUR2" : Chgstl [M]TOT(8) With "PLGCUR2"
Return

Subprog CALCTOT()
nolign = 0
Gosub CLEARTOT

For I=1 To 6
  nolign += 1
  [M]AFRMAL(6) = [M]AFRMAL(6) + [M]AFRMAL(nolign-1)
  [M]COLMAL(6) = [M]COLMAL(6) + [M]COLMAL(nolign-1)
  [M]INDMAL(6) = [M]INDMAL(6) + [M]INDMAL(nolign-1)
  [M]WHIMAL(6) = [M]WHIMAL(6) + [M]WHIMAL(nolign-1)
  [M]AFRFEM(6) = [M]AFRFEM(6) + [M]AFRFEM(nolign-1)
  [M]COLFEM(6) = [M]COLFEM(6) + [M]COLFEM(nolign-1)
  [M]INDFEM(6) = [M]INDFEM(6) + [M]INDFEM(nolign-1)
  [M]WHIFEM(6) = [M]WHIFEM(6) + [M]WHIFEM(nolign-1)
  [M]FGNMAL(6) = [M]FGNMAL(6) + [M]FGNMAL(nolign-1)
  [M]FGNFEM(6) = [M]FGNFEM(6) + [M]FGNFEM(nolign-1)
  [M]TOT(nolign-1) = [M]AFRMAL(nolign-1)+[M]COLMAL(nolign-1)+[M]INDMAL(nolign-1)+[M]WHIMAL(nolign-1)+[M]AFRFEM(nolign-1)+[M]COLFEM(nolign-1)+[M]INDFEM(nolign-1)+[M]WHIFEM(nolign-1)+[M]FGNMAL(nolign-1)
& +[M]FGNFEM(nolign-1)
Next
nolign += 2
[M]AFRMAL(nolign) = [M]AFRMAL(nolign-1) + [M]AFRMAL(nolign-2)
[M]COLMAL(nolign) = [M]COLMAL(nolign-1) + [M]COLMAL(nolign-2)
[M]INDMAL(nolign) = [M]INDMAL(nolign-1) + [M]INDMAL(nolign-2)
[M]WHIMAL(nolign) = [M]WHIMAL(nolign-1) + [M]WHIMAL(nolign-2)
[M]AFRFEM(nolign) = [M]AFRFEM(nolign-1) + [M]AFRFEM(nolign-2)
[M]COLFEM(nolign) = [M]COLFEM(nolign-1) + [M]COLFEM(nolign-2)
[M]INDFEM(nolign) = [M]INDFEM(nolign-1) + [M]INDFEM(nolign-2)
[M]WHIFEM(nolign) = [M]WHIFEM(nolign-1) + [M]WHIFEM(nolign-2)
[M]FGNMAL(nolign) = [M]FGNMAL(nolign-1) + [M]FGNMAL(nolign-2)
[M]FGNFEM(nolign) = [M]FGNFEM(nolign-1) + [M]FGNFEM(nolign-2)

nolign -=2
For I=7 To 9
  nolign += 1
  [M]TOT(nolign-1) = [M]AFRMAL(nolign-1)+[M]COLMAL(nolign-1)+[M]INDMAL(nolign-1)+[M]WHIMAL(nolign-1)+[M]AFRFEM(nolign-1)+[M]COLFEM(nolign-1)+[M]INDFEM(nolign-1)+[M]WHIFEM(nolign-1)+[M]FGNMAL(nolign-1)
& +[M]FGNFEM(nolign-1)
Next
Affzo [M]
End

$CLEARTOT
[M]AFRMAL(6) = 0
[M]COLMAL(6) = 0
[M]INDMAL(6) = 0
[M]WHIMAL(6) = 0
[M]AFRFEM(6) = 0
[M]COLFEM(6) = 0
[M]INDFEM(6) = 0
[M]WHIFEM(6) = 0
[M]FGNMAL(6) = 0
[M]FGNFEM(6) = 0
Return



