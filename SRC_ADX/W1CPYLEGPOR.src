#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGPOR 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:32"
A_USER  = "DOC"
A_STAMP = "20181109230332"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBCFE"
  If [M]NBCFE=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGPOR [CLPOR]
Gosub HORODAT
Local Inpbox "CPYLEGPOR" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLPOR] As [SIM_]
Grizo [CLPOR]5
Grizo [CLPOR]10
Grizo [CLPOR]15
Grizo [CLPOR]20
Grizo [CLPOR]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLPOR]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=27 : X2(0)=86 : Y1(0)=7 : Y2(0)=9
X1(1)=27 : X2(1)=86 : Y1(1)=10 : Y2(1)=15
X1(2)=27 : X2(2)=86 : Y1(2)=16 : Y2(2)=17
X1(3)=27 : X2(3)=86 : Y1(3)=18 : Y2(3)=21
X1(4)=27 : X2(4)=86 : Y1(4)=22 : Y2(4)=21
Return

$ON_PORCPYACT
Onevent INIT_AREA Call D_PORCPYACT(zc) From W1CPYLEGPOR
Onevent CONTROL Call C_PORCPYACT(zc) From W1CPYLEGPOR
Onevent BEFORE_INPUT Call AS_PORCPYACT(zc) From W1CPYLEGPOR
Onevent AFTER_CHANGE Gosub AMM_PORCPYACT From W1CPYLEGPOR
Return

Subprog D_PORCPYACT(VALEUR)
Variable Char    VALEUR()
If varinit([M]PORCPYACT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"395","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PORCPYACT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"395") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PORCPYACT(zc) From W1CPYLEGPOR
Onkey   2 Titled GBOUTS Call S_PORCPYACT(zc) From W1CPYLEGPOR
Onkey 144 Titled GBOUTP Call P_PORCPYACT(zc) From W1CPYLEGPOR
Onkey 146 Titled GBOUTA Call SA_PORCPYACT(zc) From W1CPYLEGPOR
Gosub _AFF
End

Subprog C_PORCPYACT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"395","") From SUBADI
If mkstat : GERR = 1 : GZONE = "PORCPYACT" : GZNUM = 48831 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"395",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PORCPYACT" : GZNUM = 48831 : Endif
Endif
Gosub _AFF
End

$AMM_PORCPYACT
Call AM_PORCPYACT(zc)
If !mkstat & GOBJET
 zoncou = "PORCPYACT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PORCPYACT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZPORCPYACT)")>indice
 [M]PORCPYACT(indice) = VALEUR
 Affzo ZPORCPYACT(indice)
Endif
Gosub _AFF
End

Subprog S_PORCPYACT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "395"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PORCPYACT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"395") From GOBJET
Gosub _AFF
End

Subprog SA_PORCPYACT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "395"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PORCPYACT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "395"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPORCPYACT
Onevent BEFORE_AREA Gosub AV_ZPORCPYACT From W1CPYLEGPOR
Return

$AV_ZPORCPYACT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","395",num$([M]PORCPYACT(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_PORHQR
Onevent BEFORE_INPUT Call AS_PORHQR(zc) From W1CPYLEGPOR
Onevent INIT_AREA Call D_PORHQR(zc) From W1CPYLEGPOR
Onevent CONTROL Call C_PORHQR(zc) From W1CPYLEGPOR
Return

Subprog D_PORHQR(VALEUR)
Variable Integer VALEUR
If varinit([M]PORHQR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PORHQR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2274) From COMBOS
## Action STD
Call AS_PORHQR(VALEUR) From TRTCPYLEGPOR
If mkstat=2
 [M]PORHQR(INDIC) = VALEUR
 Affzo PORHQR(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2274,1))))
Endif
If !mkstat
 Discombo 0 From PORHQR(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From PORHQR(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_PORHQR(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_PORDCLPER
Onevent BEFORE_INPUT Call AS_PORDCLPER(zc) From W1CPYLEGPOR
Onevent INIT_AREA Call D_PORDCLPER(zc) From W1CPYLEGPOR
Onevent CONTROL Call C_PORDCLPER(zc) From W1CPYLEGPOR
Return

Subprog D_PORDCLPER(VALEUR)
Variable Integer VALEUR
If varinit([M]PORDCLPER,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PORDCLPER(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(2226) From COMBOS
## Action STD
Call AS_PORDCLPER(VALEUR) From TRTCPYLEGPOR
If mkstat=2
 [M]PORDCLPER(INDIC) = VALEUR
 Affzo PORDCLPER(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,2226,1))))
Endif
If !mkstat
 Discombo 0 From PORDCLPER(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From PORDCLPER(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_PORDCLPER(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_PORRESFISCDA
