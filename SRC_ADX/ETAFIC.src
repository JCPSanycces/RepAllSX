#<AdxTL>@(#)6.0.0.0 $Revision$
Close Local Mask
If nomap=adxmother(1)
 Call ETAFIC("")
Else
 If adxmac(0)=""
  Call ETAFIC(nomap)
 Else
  Call ETAFIC(adxmac(0)+"@"+nomap)
 Endif
Endif
End

########################################################################
Subprog ETAFIC(APPLI)
Value Char APPLI
Local Char PARAM(30)(1..2)
Call SAISIE_CHAR(APPLI,PARAM,"ETAFIC","ETAFIC","") From GSAISIE
End

####################
$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "OK"           : Gosub OK
 When "BOUTON"       : Gosub BOUTON
 When "DEBUT"        : Gosub DEBUT
 When "FIN"          : Gosub FIN
 #VPO 23/11/06 BUG38284 : ajout possibilité édition état des tables
 When "SETBOUT" : Gosub SETBOUT
 When "EDI"     : Gosub EDIT
 When Default
Endcase
Return

####################
$EDIT
Local Char TABMSK(10)(2)
Local Char TABABR(5)(2)
#on les mets dans ce sens pour avoir les info regroupées
TABMSK(0)="ETAFIC2" : TABABR(0)="ETF2"
TABMSK(1)="ETAFIC1" : TABABR(1)="ETF1"
Call PRTSCR(TABMSK,TABABR,mess(112,124,1),0,0) From ATRTX3
Call IMPSCR From ATRTX3
Return

####################
$SETBOUT
CHBOU += "I" : # Impression
Return

####################
$OUVRE
Local File ADOSSIER [ADS]
Return

####################
$DEBUT
If VALEUR<>""
 [M:ETF0]DOSSIER = VALEUR
 Call CALCUL(VALEUR)
 Affzo [M:ETF1]
 Affzo [M:ETF2]
 Gosub AFFERR
Endif
Return

####################
$OK
Call CALCUL([M:ETF0]DOSSIER)
Affzo [M:ETF1]
Affzo [M:ETF2]
Gosub AFFERR
FIN = 0
Return

####################
$BOUTON
Case BOUT
 When "E" : Gosub ERREURS
Endcase
Return

$ERREURS
Local Integer I , J , K
Call OUVRE_BOITE(mess(6,100,1),[M:ETF1]NBFIC) From GESECRAN
Raz I , J
K = 1
#VPO 26/12/05
#While J<[M:ETF1]NBFIC-1
While J<[M:ETF1]NBFIC
 Call AFF_BOITE([M:ETF1]FICHIER(I),J,K) From GESECRAN
 If [M:ETF1]ANOMALIE(J)>0
  [M:ETF1]FICHIER(I)  = [M:ETF1]FICHIER(J)
  [M:ETF1]NOMFIC(I)   = [M:ETF1]NOMFIC(J)
  [M:ETF1]NBREC(I)    = [M:ETF1]NBREC(J)
  [M:ETF1]NBPRE(I)    = [M:ETF1]NBPRE(J)
  [M:ETF1]TAILLE(I)   = [M:ETF1]TAILLE(J)
  [M:ETF1]EXTDAT(I)   = [M:ETF1]EXTDAT(J)
  [M:ETF1]EXTIDX(I)   = [M:ETF1]EXTIDX(J)
  [M:ETF1]NBIDX(I)    = [M:ETF1]NBIDX(J)
  [M:ETF1]TAILDAT(I)  = [M:ETF1]TAILDAT(J)
  [M:ETF1]TAILIDX(I)  = [M:ETF1]TAILIDX(J)
  [M:ETF1]MAXIDX(I)   = [M:ETF1]MAXIDX(J)
  [M:ETF1]NBFLD(I)    = [M:ETF1]NBFLD(J)
  [M:ETF1]MAXFLD(I)   = [M:ETF1]MAXFLD(J) : #VPO 26/12/05
  [M:ETF1]CLFLD(I)    = [M:ETF1]CLFLD(J)
  [M:ETF1]MAXCOL(I)   = [M:ETF1]MAXCOL(J) : #VPO 26/12/05
  [M:ETF1]LGFLD(I)    = [M:ETF1]LGFLD(J)
  [M:ETF1]MAXLG(I)    = [M:ETF1]MAXLG(J) : #VPO 26/12/05
  [M:ETF1]BLOB(I)     = [M:ETF1]BLOB(J)
  [M:ETF1]MAXBLOB(I)  = [M:ETF1]MAXBLOB(J) : #VPO 26/12/05
  [M:ETF1]ANOMALIE(I) = [M:ETF1]ANOMALIE(J)
  [M:ETF1]TEXTEANO(I) = [M:ETF1]TEXTEANO(J) : #VPO 26/12/05
  I += 1
 Endif
 J += 1
Wend
[M:ETF1]NBFIC = I
Affzo [M:ETF1]
Gosub AFFERR
Call FERME_BOITE From GESECRAN
Return

$AFFERR
For I=0 To [M:ETF1]NBFIC-1
 Case [M:ETF1]ANOMALIE(I)
  When 1       : Chgstl [M:ETF1]NBFIC(I) With "AWARNHIGH" : #34205 VPO 10/01/06 avant "ALERTEHAU"
  When 2       : Chgstl [M:ETF1]NBFIC(I) With "AWARNLOW" : #34205 VPO 10/01/06 avant "ALERTEBAS"
  When 3       : Chgstl [M:ETF1]NBFIC(I) With "AWARN" : #34205 VPO 10/01/06 avant "ALERTE"
  When Default : Chgstl [M:ETF1]NBFIC(I) With ""
 Endcase
Next I
Return

####################
$FIN
If [M:ETF0]DOSSIER <> ""
 VALEUR = [M:ETF0]DOSSIER
Endif
Return

##################################################################
Subprog CALCUL(APPLI)
Value Char APPLI
Local Integer I, J, K, L, TYPDBA, KDBA, CDBA, MODE, ER, INTERRUPT, TIMREQ, IDX
Local Integer OK
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC), LIGNE(250)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
# VPO 28/11/05 passe de 10 a 30
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    OBJET(25) , INDEX(25) , OBJCUR(25) , INDCUR(25)
Local Integer OBJMAX , INDMAX
# VPO 28/11/05 passe de 10 a 30
Local Char    TBDAT(30) , TBIDX(30)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC) , MACBID(GDIMFIC) , OS(10)
Local Char    SQLDBA(50) , IRS(2)
Local Char    WINSTANCE(50)
Local Integer STAT
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20) , WORDRE(250)
Local Integer SAVIUM
Local Decimal NOMBRE(1..10)
Local Integer LOB
Local Decimal OCTET
Local Decimal OCTETUSED : # VPO 22/12/05

TIMREQ = 50
Raz [M:ETF1]

Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
If APPLI=nomap
 Local File ADOVAL [ADW]
Else
 Onerrgo ERFIC
 ER = 0
 Local File =[M:ETF0]DOSSIER+".ADOVAL" [ADW]
 Onerrgo
 If ER
  Local File ADOVAL [ADW]
 Endif
Endif
Read [ADW]ADW0 = "";"";"TYPDBA"
ER = fstat
TYPDBA = val([F:ADW]VALEUR)
Close Local File [ADW]
If ER
 Call ERREUR(mess(12,100,1)-"ADOVAL") From GESECRAN
Else
 Gosub SET_DBA
 Gosub CALCUL2
 If INTERRUPT=0 : End : Endif
Endif
End


$SET_DBA
#Local Integer CDBA , KDBA : # Uniquement pour le contrôle de la taille d'un enregistrement
Local File ADOSSIER [ADS_]
Read [ADS_]DOSSIER = nomap
If !fstat
 CDBA = [F:ADS_]CODDBA
 If CDBA<=0 : CDBA = 1 : Endif
Else
 CDBA = 1
Endif
Close Local File [ADS_]
If GADONIX=2
 KDBA = 2 : # Pour contrôler par rapport à SQL unicode
Else
 Case GTYPDBA
  When 1 : # Oracle
   KDBA = val(getenv$("STUSIZE"))
   If KDBA<=0 : KDBA = 2 : Endif
  When 2 : # Sql
   Case CDBA
    When 1 : # Ascii
     KDBA = 1
    When 2 : # Unicode
     KDBA = 2
    When Default
     KDBA = 1
   Endcase
 Endcase
Endif
Return

#############################################################
## Nb de lignes et infos
#############################################################
$CALCUL2
Local Char    COMMANDE(250)
Raz [M:ETF1]
Raz [M:ETF2]
If MACHINE=""
 [M:ETF0]DOSSIER = NOMDOS
Else
 [M:ETF0]DOSSIER = MACHINE+"@"+NOMDOS
Endif

If clalev([F:ATB])=0  : Local File =[M:ETF0]DOSSIER+".ATABLE"  [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =[M:ETF0]DOSSIER+".ATABZON" [ATZ]  : Endif
If clalev([F:ATX])=0  : Local File =[M:ETF0]DOSSIER+".ATEXTE"  [ATX]  : Endif
If clalev([F:ATY])=0  : Local File =[M:ETF0]DOSSIER+".ATYPE"   [ATY]  : Endif
If clalev([F:ACV])=0  : Local File =[M:ETF0]DOSSIER+".ACTIV"   [ACV]  : Endif

Call OUVRE_BOITE(mess(6,100,1),nbrecord([ATB])+TIMREQ) From GESECRAN
INTERRUPT=1
I = 0
For [ATB]CODFIC
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",[M:ETF0]DOSSIER),0)>0
  [M:ETF1]FICHIER(I) = [F:ATB]CODFIC
  Call TEXTE([F:ATB]INTITFIC,[M:ETF1]NOMFIC(I)) From OBJDIV
  Onerrgo ERFIC
  ER = 0
  Local File =[M:ETF0]DOSSIER+"."+[M:ETF1]FICHIER(I) [AAA_]
  Onerrgo
  If ER=0
   Onerrgo ERFIC
   [M:ETF1]NBREC(I)   = nbrecord([AAA_])
   Onerrgo
   If ER=0
    If TYPDBA=3
     [M:ETF1]TAILDAT(I) = filinfo(filpath("FIL",[M:ETF1]FICHIER(I),"dat",NOMDOS,"",MACHINE),7)/1024
     [M:ETF1]TAILIDX(I) = filinfo(filpath("FIL",[M:ETF1]FICHIER(I),"idx",NOMDOS,"",MACHINE),7)/1024
     [M:ETF1]TAILLE(I)  = [M:ETF1]TAILDAT(I)+[M:ETF1]TAILIDX(I)
    Endif
    [M:ETF1]NBIDX(I) = [G:AAA_]nbind
   Endif
   Close Local File [AAA_]
  Endif
  [M:ETF1]NBPRE(I) = [F:ATB]NBENREG
  If [M:ETF1]NBREC(I)>3*[M:ETF1]NBPRE(I)
   [M:ETF1]ANOMALIE(I) = 1
   #[M:ETF1]TEXTEANO(I) = mess(225,123,1) : #VPO 26/12/05
   #34205 VPO 10/01/06 modification du message pour afficher Rapport données / prévues
   [M:ETF1]TEXTEANO(I) = mess(225,123,1)-":"-num$(arr([M:ETF1]NBREC(I)/max([M:ETF1]NBPRE(I),1),0.1))
  Endif
  Gosub INFOS
  #VPO 26/12/05 déplacé dans INFOS
  #If [M:ETF1]NBFLD(I)>255 | [M:ETF1]CLFLD(I)>512 | [M:ETF1]LGFLD(I)>8060
  # [M:ETF1]ANOMALIE(I) = 3
  #Endif
  Call AFF_BOITE([M:ETF1]FICHIER(I),I,INTERRUPT) From GESECRAN
  If INTERRUPT=0 : Break : Endif
  I += 1
 Endif
Next ATB
[M:ETF1]NBFIC = I
If INTERRUPT=0 : Goto FIN_CALC : Endif

#VPO 27/12/05 devrait marcher dans tous les cas (car on a toujours un client oracle ou sqs)
#If adxmac(0)=""
 Call AFF_BOITE(mess(227,123,1),I+5,INTERRUPT) From GESECRAN : #VPO 26/12/05
 Call GET_OS(MACHINE,OS) From ORDSYS
 If OS="unix"
  IRS = chr$(10)
 Else
  IRS = chr$(13)+chr$(10)
 Endif
 Onerrgo ERFIC
 Case TYPDBA
  When 1 : Gosub TAIL_ORA
  When 2 : Gosub TAIL_SQL
 Endcase
 Onerrgo
#Endif

[M:ETF1]TAILTOT  = sum([M:ETF1]TAILLE(0..[M:ETF1]NBFIC-1))
[M:ETF1]TAILTOT /= 1024
[M:ETF1]TAILTOT = int([M:ETF1]TAILTOT+.5)

$FIN_CALC
Call FERME_BOITE From GESECRAN
[M]COMMENT2 = mess(115,124,1) : # Méga-octets
Close Local File [ATB] , [ATX]
Return

#############################################################
## Pour Oracle
#############################################################
## Cette version est censée marcher avec oracle 8 et 9
#############################################################
$TAIL_ORA
SQLDBA = "sqlplus" : # Ca existe dans les 2 versions
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""
 FICSQL = filpath("tmp","oraspace"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oraspace"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "connect"-USER+"/"+PASSE+WINSTANCE
 Wrseq "spool"-TRAFIC
# Place libre
# VPO 22/12/05
# Wrseq "select tablespace_name , sum(bytes) from user_free_space"
# Wrseq " group by tablespace_name ;"
 Wrseq "set linesize 100"
 Wrseq "column TABLESPACE_NAME format A30"
 Wrseq "column FBYTES format A30"
 Wrseq "column UBYTES format A30"
 Wrseq "select F.tablespace_name TABLESPACE_NAME, to_char(sum(F.bytes)) FBYTES, to_char(Q.BYTES) UBYTES"
 Wrseq "From user_free_space F, user_ts_quotas Q"
 Wrseq "where F.tablespace_name=Q.tablespace_name"
 Wrseq "group by F.tablespace_name,Q.BYTES ;"
# Place occupée
 Wrseq "column segment_name format A25"
 Wrseq "select segment_name , bytes from user_extents order by segment_name ;"
 Wrseq "exit"
 Openo
 WORDRE = SQLDBA-'/NOLOG @'+SQLFIC
 Call SYSTEME(MACHINE,WORDRE,"",ER) From ORDSYS
 Call AFF_BOITE("",[M:ETF1]NBFIC+TIMREQ/2,INTERRUPT) From GESECRAN
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0
  LOB = [M:ETF1]NBFIC
  [M:ETF1]NBFIC += 1
  [M:ETF1]FICHIER(LOB) = "SYS_LOB"
  [M:ETF1]NOMFIC(LOB)  = mess(101,139,1) : # Blobs/Clobs
  Openi FICTRA
  Rdseq LIGNE
  MODE=0
  INDCUR = ""
  OBJCUR = ""
  While fstat=0
   If    left$(LIGNE,15) = "TABLESPACE_NAME"
    MODE=1
   Elsif left$(LIGNE,12) = "SEGMENT_NAME"
    MODE=2
   Elsif MODE=1
#    OBJET = vireblc(left$(LIGNE,25),2)
#    OCTET = val(vireblc(right$(LIGNE,26),2))
#    If OBJET<>string$(len(OBJET),"-") & [M:ETF2]NBTBL<dim([M:ETF2]TABLESP)
#&    & !instr(1,"0123456789",left$(OBJET,1))
#     [M:ETF2]TABLESP([M:ETF2]NBTBL) = OBJET
#     [M:ETF2]FRESPA([M:ETF2]NBTBL) = OCTET/(1024*1024)
#     [M:ETF2]NBTBL += 1
#    Endif
    OBJET = vireblc(left$(LIGNE,30),2)
    OCTET = val(vireblc(mid$(LIGNE,31,30),2))
    OCTETUSED= val(vireblc(right$(LIGNE,62),2))
    If OBJET<>string$(len(OBJET),"-") & [M:ETF2]NBTBL<dim([M:ETF2]TABLESP)
&    & !instr(1,"0123456789",left$(OBJET,1))
     [M:ETF2]TABLESP([M:ETF2]NBTBL) = OBJET
     [M:ETF2]FRESPA([M:ETF2]NBTBL) = arr(OCTET/(1024*1024),1)
     [M:ETF2]USED([M:ETF2]NBTBL) = arr(OCTETUSED/(1024*1024),1)
     [M:ETF2]NBTBL += 1
    Endif
   Elsif MODE=2
    OBJET = vireblc(left$(LIGNE,25),2)
    OCTET = val(vireblc(right$(LIGNE,26),2))
    If left$(OBJET,7)="SYS_LOB"
     [M:ETF1]TAILDAT(LOB) += OCTET
     [M:ETF1]TAILLE(LOB)  += OCTET
     [M:ETF1]EXTDAT(LOB)  += 1
    Elsif left$(OBJET,6)="SYS_IL"
     [M:ETF1]TAILIDX(LOB) += OCTET
     [M:ETF1]TAILLE(LOB)  += OCTET
     [M:ETF1]EXTIDX(LOB)  += 1
    Else
     J = instr(1,OBJET,"_")
     If J
      INDEX = right$(OBJET,J+1)
      OBJET = left$(OBJET,J-1)
      If OBJET=OBJCUR
       If INDEX=INDCUR
        INDMAX += 1
       Else
        INDMAX = 1
        INDCUR = INDEX
       Endif
       OBJMAX = max(OBJMAX,INDMAX)
      Else
       INDMAX = 1
       OBJMAX = 1
       OBJCUR = OBJET
       INDCUR = INDEX
      Endif
      IDX = 1
     Else
      IDX = 0
     Endif
     If OCTET>0
      J = find(OBJET,[M:ETF1]FICHIER(0..[M:ETF1]NBFIC-1))-1
      If J<0
       J = [M:ETF1]NBFIC
       [M:ETF1]NBFIC += 1
       [M:ETF1]FICHIER(J) = OBJET
      Endif
      [M:ETF1]TAILLE(J) += OCTET
      Case IDX
       When 0 : # table
        [M:ETF1]EXTDAT(J)  += 1
        [M:ETF1]TAILDAT(J) += OCTET
       When 1 : # index
        [M:ETF1]EXTIDX(J)  += 1
        [M:ETF1]MAXIDX(J)   = OBJMAX
        [M:ETF1]TAILIDX(J) += OCTET
      Endcase
      If [M:ETF1]EXTDAT(J)>30 or [M:ETF1]MAXIDX(J)>30
       [M:ETF1]ANOMALIE(J) = 2
       [M:ETF1]TEXTEANO(J) = mess(226,123,1) : #VPO 26/12/05
      Endif
     Endif
    Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 For I=0 To [M:ETF1]NBFIC-1
  [M:ETF1]TAILLE(I)  /= 1024
  [M:ETF1]TAILDAT(I) /= 1024
  [M:ETF1]TAILIDX(I) /= 1024
 Next I
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
Endif
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Chgfmt [ETF1]UNUSED With "-N:8#"
Chgfmt [ETF1]EXTDAT With "Nz:3#"
Chgfmt [ETF1]EXTIDX With "Nz:3#"
Chgfmt [ETF1]MAXIDX With "Nz:3#"
Return

#############################################################
## Pour SQL-server
#############################################################
$TAIL_SQL
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char VERSION_SQL(30)
Local Integer  OK
Local Char XINSTANCE(200)
Local Char XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host

VERSION_SQL=""
# jira X3-86047 86048 86049 replace osql by sqlcmd
If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
     SQLDBA = "sqlcmd"
     # instance ?
     Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,OK) From DOSBASE
     If OK
        Return
     Endif
     # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
     XHOSTNAME = getenv$("CONNECTSTR")
     If (instr(0,XHOSTNAME,"\") > 0)
         XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
     Endif
     If (instr(0,XHOSTNAME,"#") > 0)
        XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
     Endif
     #XINSTANCE = ".\"+XINSTANCE
     XINSTANCE = XHOSTNAME+'\'+XINSTANCE
Else
     SQLDBA = "osql"
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII


Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""
      FICCMD = filpath("tmp","sqlspace"+num$(adxuid(2)),"BAT",APPLI)
      Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
      FICSQL = filpath("tmp","sqlspace"+num$(adxuid(2)),"sql",APPLI)
      Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
      FICTRA = filpath("tmp","sqlspace"+num$(adxuid(2)),"log",APPLI)
      Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
      System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
      adxifs = "" : adxirs = IRS : adxium = GASCII
      ##
      ## On ecrit le fichier de commande pour le déclenchement
      ## car bug sur probleme de PATH
      ##WORDRE = SQLDBA-"-D"-BASE-"-U"-USER-"-P"-PASSE-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"
      ##
      Openo FICCMD , 0
      Wrseq "@ECHO OFF"
      Wrseq "BREAK OFF"
      # jira X3-86047 86048 86049 replace osql by sqlcmd
      If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
           Wrseq "SET SQLCMD_EXE="+SQLDBA
           WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
           Wrseq WORDRE
           WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w250'
           Wrseq WORDRE
      Else
           Wrseq "SET OSQL_EXE="+SQLDBA
           WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
           Wrseq WORDRE
           WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U'-USER-'-P'-PASSE-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w250'
           Wrseq WORDRE
      Endif
      Wrseq "BREAK ON"
      Openo


      System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
      System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 ##
 ## On ecrit le fichier sql pour recuperer la version
 ##
      Openo FICSQL , 0
      Wrseq "select 'VERSION='+cast(serverproperty('ProductVersion') as varchar(200))"
      Wrseq "GO"
      Wrseq "EXIT"
      Openo
      System COMMANDE = MACHINE+'@'+CMDFIC
      If filinfo(FICTRA,0)>=0
          adxifs = "" : adxirs = IRS : adxium = GASCII
          Openi FICTRA
          Rdseq LIGNE
          While fstat=0
                LIGNE = vireblc(LIGNE,2)
                If len(LIGNE)>0
                # on recupere la version
                      If left$(LIGNE,8)="VERSION="
                          Call CALC_NOVERS_SQL(right$(LIGNE,9),VERSION_SQL) From SQLPROP
                      Endif
                Endif
                Rdseq LIGNE
          Wend
          Openi
      Endif

      If VERSION_SQL<>""
          System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
          System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
     ##
     ## On ecrit le fichier sql pour recuperer les tables
     ##
          Openo FICSQL , 0
          Wrseq "select 'TABLE='+o.name from sysobjects o where o.type='U'"
          If VERSION_SQL="8"
              Wrseq "and USER_NAME(o.uid)='"+NOMDOS+"'"
          Else
              Wrseq "and SCHEMA_NAME(o.uid)='"+NOMDOS+"'"
          Endif
          Wrseq "order by o.name"
          Wrseq "GO"
          Wrseq "EXIT"
          Openo
          System COMMANDE = MACHINE+'@'+CMDFIC
          If filinfo(FICTRA,0)>=0
              adxifs = "" : adxirs = IRS : adxium = GASCII
              Openi FICTRA
              Rdseq LIGNE
              While fstat=0
                  LIGNE = vireblc(LIGNE,2)
                  If len(LIGNE)>0
                  # on recupere la version
                      If left$(LIGNE,6)="TABLE="
                          OBJET = right$(LIGNE,7)
                          J = find(OBJET,[M:ETF1]FICHIER(0..[M:ETF1]NBFIC-1))-1
                          If J<0
                              J = [M:ETF1]NBFIC
                              [M:ETF1]NBFIC += 1
                              [M:ETF1]FICHIER(J) = OBJET
                          Endif
                      Endif
                  Endif
                  Rdseq LIGNE
              Wend
              Openi
          Endif
      Endif

      System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
      System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 ##
 ## On ecrit le fichier sql pour les tables
 ##
 Openo FICSQL , 0
 #For [ATB]CODFIC
 # If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",APPLI),0)>=0
 #  Wrseq "exec sp_spaceused '"+NOMDOS+"."+[F:ATB]CODFIC+"'"
 # Endif
 #Next
 #JPGA 28/01/2010 BUG-58485 : A partir de Sqlserver2005 : Positionner la base part défaut, sinon les tables sont pris depuis Master
 Wrseq "USE"-XBASE
 For J=0 To [M:ETF1]NBFIC-1
   #VPO 27/03/06 BUG35506
   Wrseq "print 'TABLE="+[M:ETF1]FICHIER(J)+"'"
   Wrseq "exec sp_spaceused '"+NOMDOS+"."+[M:ETF1]FICHIER(J)+"'"
 Next J
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 Call AFF_BOITE("",[M:ETF1]NBFIC+TIMREQ/2,INTERRUPT) From GESECRAN
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  Openi FICTRA


  Rdseq LIGNE
  Raz OBJTROUV
  Raz OBJET

  While fstat=0
       # on vire les tab si il y en a
       LIGNE  = func AFNC.TRANSF(LIGNE,chr$(09)," ")
       LIGNE = vireblc(LIGNE,2)
       LIGNE = vireblc(LIGNE,5)
       If len(LIGNE)>0
            If left$(LIGNE,6)="TABLE="
                    OBJTROUV= right$(LIGNE,7)
                    Raz OBJET
            Else
                J = instr(1,LIGNE," ")
                If J > 0 and OBJET = ""
                    OBJET = left$(LIGNE,J-1)
                    If OBJET = OBJTROUV
                        # ancienne trace-les infos sont à la suite
                        LIGNE = vireblc(right$(LIGNE,J+1),2)
                        Gosub NOMBRE
                        Gosub REMPLI_ECRAN
                    Endif
                    Raz OBJET
                    Raz OBJTROUV
                Else
                    # nouvelle trace infos lignes suivantes
                    J = instr(1,LIGNE,".")
                    If J > 0
                        OBJET = right$(LIGNE,J+1)
                    Else
                        If OBJET = OBJTROUV and OBJTROUV <> ""
                            Gosub NOMBRE
                            Gosub REMPLI_ECRAN
                            Raz OBJET
                            Raz OBJTROUV
                        Endif
                    Endif
                Endif
           Endif
       Endif
       Rdseq LIGNE
  Wend
  Openi
 Endif

 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 Openo FICSQL,0
 #JPGA 28/01/2010 BUG-58485 : A partir de Sqlserver2005 : Positionner la base part défaut, sinon les tables sont pris depuis Master
 Wrseq "USE"-XBASE
 Wrseq "exec sp_spaceused"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 If filinfo(FICTRA,0)>=0
  adxifs = "" : adxirs = IRS : adxium = GASCII
  L = 0
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   # with sqlcmd one line more in log with contexte .
   # need to jump this line
   If pat(LIGNE,"*Changed database context*") > 0
        # on saute ligne
   Else
       If len(LIGNE)>0
          If L=0
              J = instr(1,LIGNE," ")
              If J
                  LIGNE = vireblc(right$(LIGNE,J+1),2)
                  Gosub NOMBRE
                  [M:ETF2]TAILBASE = NOMBRE(1) : [M:ETF2]MB1 = "MB"
                  [M:ETF2]ESPACE   = NOMBRE(2) : [M:ETF2]MB2 = "MB"
              Endif
              L = 1
          Else
              Gosub NOMBRE
              [M:ETF2]TOTAL   = NOMBRE(1) : [M:ETF2]MB3 = "KB"
              [M:ETF2]DONNEES = NOMBRE(2) : [M:ETF2]MB4 = "KB"
              [M:ETF2]INDEX   = NOMBRE(3) : [M:ETF2]MB5 = "KB"
              [M:ETF2]UNUSED  = NOMBRE(4) : [M:ETF2]MB6 = "KB"
          Endif
        Endif
     Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
#
Endif
#
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Chgfmt [ETF1]EXTDAT With "-N:3#"
Chgfmt [ETF1]EXTIDX With "-N:3#"
Chgfmt [ETF1]MAXIDX With "-N:3#"
Chgfmt [ETF1]UNUSED With "Nz:8#"
Return


$REMPLI_ECRAN
J = find(OBJET,[M:ETF1]FICHIER(0..[M:ETF1]NBFIC-1))-1
If J<0
    J = [M:ETF1]NBFIC
    [M:ETF1]NBFIC += 1
    [M:ETF1]FICHIER(J) = OBJET
Endif
[M:ETF1]TAILLE(J)  = NOMBRE(2)
[M:ETF1]TAILDAT(J) = NOMBRE(3)
[M:ETF1]TAILIDX(J) = NOMBRE(4)
[M:ETF1]UNUSED(J)  = NOMBRE(5)

Return



$NOMBRE
K = 0
Raz NOMBRE
Repeat
 J = instr(1,LIGNE," ")
 If !J : Break : Endif
 K += 1
 NOMBRE(K) = val(left$(LIGNE,J-1))
 LIGNE = vireblc(right$(LIGNE,J+1),2)
 If find(toupper(left$(LIGNE,2)),"KB","MB")
  LIGNE = vireblc(right$(LIGNE,3),2)
 Endif
Until K>=5
Return

$ERFIC
ER=errn
Resume

$LIMITES
#VPO 26/12/05
Local Integer MAXCOL , MAXLNG , MAXZON, MAXBLOB
Raz MAXCOL , MAXLNG , MAXZON, MAXBLOB
# Limites
# extrait de DOSTAB
########################################################################
#
# La limite de 512 colonnes pour une table est imposée par Adonix
# Le nombre de colonnes maximum est de
#  1000 pour Oracle
#  1024 pour SQL7
#  pas de limite sous DB2
#
########################################################################
#
# Le nombre de champs dans une table est limité à 255
#
########################################################################
#
#  La taille maximum d'un enreg pour le moteur Adonix est 32k mais
#  les vraies limites sont en fait imposées par les bases de données
#
#  Oracle : Pas de limite connue
#
#  SQLServer 7 : 8060 octets
#
######################################################################################

If dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2 : # Version 130
 MAXCOL    = 256
 MAXZON    = 255
 MAXBLOB   = 65536
Else                  : # Version 140
 MAXCOL    = 512
 MAXZON    = 255
 MAXBLOB   = 65536
Endif
If GADONIX=2
 MAXLNG = 8060 : # Spécial développement
Else
 Case TYPDBA
  When 1       : MAXLNG = 32000 : # Oracle
  When Default : MAXLNG = 32000 : : # SAM 114549 8060
 Endcase
Endif
[M:ETF1]MAXCOL(I)  = MAXCOL    : # Nb Max de colonnes
[M:ETF1]MAXLG(I)   = MAXLNG    : # Longueur Max
[M:ETF1]MAXFLD(I)  = MAXZON    : # Nb Max de champs
[M:ETF1]MAXBLOB(I) = MAXBLOB   : # Max Blob
Return

#######################################################
## Infos dictionnaire
#######################################################
$INFOS
Local Integer NBCOL, LGENR, NBFLD, NBBLOB, DIMZON, LNGZON, LNGBLOB
Raz NBCOL , LGENR , NBFLD , NBBLOB, LNGBLOB
#VPO 26/12/05
Gosub LIMITES
For [ATZ] Where CODFIC=[F:ATB]CODFIC & find(CODTYP,"AXX","AX1","AX2","AX3")=0
 DIMZON = [F:ATZ]DIME
 Call REPTAB([F:ATZ]CODACT,DIMZON) From DOSSUB
 If DIMZON<>0
  Read [ATY]CODTYP = [F:ATZ]CODTYP
  If fstat
   LNGZON = 1
   DIMZON = 1
  Else
   DIMZON = abs(DIMZON)
   Case [F:ATY]TYPTYP
    When 1 : LNGZON = 1                  : # Libellé
    When 2 : LNGZON = 2                  : # Entier court
    When 3 : LNGZON = 4                  : # Entier long
    When 4 : LNGZON = 8                  : # DCB
    When 5 : LNGZON = 4                  : # Float
    When 6 : LNGZON = 8                  : # Double
    When 7,12                            : # Alphanumérique
     If [F:ATY]LNGTYP<>0
      LNGZON = [F:ATY]LNGTYP+1
     Else
      LNGZON = [F:ATZ]LONG+1
     Endif
     LNGZON *= KDBA                      : # Coeff x (Ascii/Utf8)
    When 8  : LNGZON = 3                 : # Date
    When 9, 10                           : # Blob, Clob
     LNGZON = 0
     #VPO 26/12/05
     #If [F:ATY]LNGTYP<>0
     # LNGBLOB = [F:ATY]LNGTYP
     #Else
     # LNGBLOB = [F:ATZ]LONG
     #Endif
     #LNGBLOB = 2^LNGBLOB
     #NBBLOB += DIMZON*LNGBLOB
     NBBLOB += DIMZON
     If [F:ATY]LNGTYP<>0
      LNGBLOB += DIMZON*(2^[F:ATY]LNGTYP)
     Else
      LNGBLOB += DIMZON*(2^[F:ATZ]LONG)
     Endif
    When 10
     LNGZON = 16*KDBA
   Endcase
  Endif
 Endif
 NBCOL += DIMZON
 LGENR += DIMZON*LNGZON
 NBFLD += 1
Next ATZ
[M:ETF1]CLFLD(I) = NBCOL    : # Nb de colonnes
[M:ETF1]LGFLD(I) = LGENR    : # Longueur
[M:ETF1]NBFLD(I) = NBFLD    : # Nb de champs
If NBBLOB>0
 #[M:ETF1]BLOB(I) = NBBLOB   : # Blob
 [M:ETF1]BLOB(I) = LNGBLOB   : # Blob en K
Endif

If [M:ETF1]CLFLD(I)>[M:ETF1]MAXCOL(I)
 [M:ETF1]ANOMALIE(I) = 3
 [M:ETF1]TEXTEANO(I) = mess(213,123,1)-":"-num$([M:ETF1]CLFLD(I))-"("+num$([M:ETF1]MAXCOL(I))+")" : # Nombre de colonnes trop grand
Endif
If [M:ETF1]NBFLD(I)>[M:ETF1]MAXFLD(I) & [F:ATB]CODFIC<>"SALTRS" : # mb 1.3.4 mb exception réclamée à corps et à cris
 [M:ETF1]ANOMALIE(I) = 3
 [M:ETF1]TEXTEANO(I) = mess(49,123,1)-":"-num$([M:ETF1]NBFLD(I))-"("+num$([M:ETF1]MAXFLD(I))+")" : # Nombre de zones trop grand
Endif
If [M:ETF1]LGFLD(I)>[M:ETF1]MAXLG(I) & [F:ATB]CODFIC<>"CFGSEL" : # mb 1.3.4 mb exception réclamée à corps et à cris (bug 21738)
 [M:ETF1]ANOMALIE(I) = 3
 [M:ETF1]TEXTEANO(I) = mess(50,123,1)-":"-num$([M:ETF1]LGFLD(I))-"("+num$([M:ETF1]MAXLG(I))+")" : # Longueur de ligne trop grande
Endif
If ([M:ETF1]BLOB(I) * 1024 )+[M:ETF1]LGFLD(I)>[M:ETF1]MAXBLOB(I) & NBBLOB>1
 [M:ETF1]ANOMALIE(I) = 3
 # Longueur des blobs trop grande
 [M:ETF1]TEXTEANO(I) = mess(212,123,1)-":"-num$(([M:ETF1]BLOB(I)*1024)+[M:ETF1]LGFLD(I))-"("+num$([M:ETF1]MAXBLOB(I))+")"
Endif

Return

########################################
Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
End

