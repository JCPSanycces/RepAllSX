#<AdxTL>@(#)9.0.0.0 $Revision$  Consultation SHS
$ACTION
Case GACTION
  When "CONSSHS"
    Case ACTION
      When "AUTORIS"    : Gosub AUTORIS
      When "FERME"      : Gosub FERME
      When "OUVRE"      : Gosub OUVRE
      When "LECTURE"    : Gosub LECTURE
      When "DEB_CRIT"   : Gosub DEB_CRIT
      When "FIN_CRIT"   : Gosub FIN_CRIT
      When "AP_MAGNETO" : Gosub AP_MAGNETO
      When "SEL_LISTE"  : Gosub SEL_LISTE
      When "SETBOUT"    : Gosub SETBOUT
      When Default
    Endcase
Endcase
Return
############################################################
$SEL_LISTE
Case LISTE
  When "SELITH" :
    Local Char WSEL(25)
    Gosub SELITH
    If WSEL <> ""
      zc = WSEL
    Endif
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV])=0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITH])=0 : Local File ITMMVTHIS  [ITH] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:TUN])=0 : Local File TABUNIT    [TUN] : Endif
#
Local  Char    WFIL(250)
Global  Char    WFILS(250), WFILSPE(250)               # hcb graphique
#Local  Integer WFSTAT, WREAD, WSKIP, WLIG             # hcb graphique
Local  Integer WFSTAT, WREAD, WSKIP                    # hcb graphique
Local  Integer WGCONSULT : WGCONSULT = GCONSULT
Local  Integer I, J, K, L
#
Local  Integer WNBC  : WNBC = 29
Local  Integer INBC
Local  Integer ICOD, ICOF
Global Integer WNBL  : WNBL = 12                       # hcb graphique
Global Integer INBL                                    # hcb graphique
#
Global Char    GSCOLDES(25)(WNBC)
Global Char    WFLD(11)(WNBL)
Local  Char    WFLDS(10)
Local  Integer WDEF
#Global  Char    WLIG(10)(WNBL)   # hcb graphique
Global  Char    GLIG(10)(WNBL)   # MAE bg 48961
Global  Char    WINT(25)(WNBL)   # hcb graphique
#MAE, bg 73900
#Global  Char    WTYP(3)(WNBL)    # hcb graphique
Global  Char    GTYP(3)(WNBL)    # hcb graphique
Global  Decimal WLON(WNBL)       # hcb graphique
#
I = 0
WFLD(I) = "2MONRCPMVT" : I += 1
WFLD(I) = "2MONRCPQTY" : I += 1
WFLD(I) = "2MONRCPAMT" : I += 1
WFLD(I) = "2MONISSMVT" : I += 1
WFLD(I) = "2MONISSQTY" : I += 1
WFLD(I) = "2MONISSAMT" : I += 1
WFLD(I) = "1YEARCPMVT" : I += 1
WFLD(I) = "1YEARCPQTY" : I += 1
WFLD(I) = "1YEARCPAMT" : I += 1
WFLD(I) = "1YEAISSMVT" : I += 1
WFLD(I) = "1YEAISSQTY" : I += 1
WFLD(I) = "1YEAISSAMT" : I += 1
#
Global Date    WDTE(WNBC)                      # hcb graphique
Local  Integer WCOL(WNBC)
Global Decimal WCUM(WNBL,WNBC)
Local  Integer ZDTE, ZJOU
Local  Integer WAVG
Local  Integer WTOT
Local  Integer WVAR
Local  Integer WETY
Local  Date    WDAT
Local  Char    WEVA(80)
#
Global Integer WDATOK, WMONNBR : WDATOK=0
Global Char    WFCY, WITMREF
Global Date    WENDDAT
#
Gosub LOAD_SCREEN
Gosub TXT_LIGNES
Gosub TXT_COLONNES
#
NAVIG="CONSSHS"
SUITE  = 1
RETOUR = 1
Return
###########################################################
$SETBOUT
If [M:SHS1]ITMREF <> ""    # hcb graphique
   CHMEN += "123"
Endif                      # hcb graphique
Return
###########################################################
$DEB_CRIT
[M:CSHS]       = [M:SHS1]
Return
############################################################
$FIN_CRIT
[M:SHS1] = [M:CSHS]
# hcb deb 76301
WFCY    =[M:SHS1]FCY
WENDDAT =[M:SHS1]ENDDAT
WMONNBR =[M:SHS1]MONNBR
Gosub CAL_DATE
# hcb fin 76301

[M:SHS1]FLG = 0
Return
############################################################
$AP_MAGNETO
[M:SHS1]FLG = 0
Return
############################################################
$FERME
If clalev([F:ITV]) <> 0 : Filter [ITV] : Endif
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SHS1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SHS1] = [F:ITM]
        Endif
      Endif
    When 4 :
      If PARAM(I) = ""
           [M:SHS1]ENDDAT = date$
      Else [M:SHS1]ENDDAT = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = num$(evalue(PARAM(I)))
      Endif
  Endcase
Next I
If clalev([M:CSHS]) <> 0 & [M:CSHS]MEMO = "STD"  : # <MG> 26/04/00
  [M:SHS1] = [M:CSHS]                            : # <MG> 26/04/00
Else                                             : # <MG> 26/04/00
  [M:SHS1]TOTFLG = 2                             : # <MG> 26/04/00
  [M:SHS1]AVGFLG = 2                             : # <MG> 26/04/00
  [M:SHS1]VARFLG = 1                             : # <MG> 26/04/00
  [M:SHS1]ETYFLG = 1                             : # <MG> 26/04/00
Endif                                            : # <MG> 26/04/00
If [M:SHS1]SRTCOD = 0
  [M:SHS1]SRTCOD = 1
Endif
#--- périodes
If [M:SHS1]MONNBR = 0
  [M:SHS1]MONNBR = 12
Endif
#--- date début et fin
WFCY    =[M:SHS1]FCY
WENDDAT =[M:SHS1]ENDDAT
WMONNBR =[M:SHS1]MONNBR
Gosub CAL_DATE
Return

############################################################
#--- date début et fin de période consultée
$CAL_DATE
Local    Char    SOC(20)
Local    Decimal EXE
Local    Decimal PER

If WDATOK = 1  Return Endif
If WFCY=""     Return Endif

Call LECTURE("FCY",WFCY,"") From CONTOBJ
SOC = [F:FCY]LEGCPY

Call GETPERSOC(SOC,1,WENDDAT,EXE,PER) From CPTSUB

If WMONNBR > 1
   Filter [PER] Where CPY=SOC
   For I = 2 To WMONNBR
    Read [PER]PER0 Prev
    If fstat WMONNBR=I-1 : [M:SHS1]MONNBR=I-1 Endif
   Next I
   Filter [PER]
Endif

[M:SHS1]STRDAT = [F:PER]PERSTR
Affzo [M:SHS1]STRDAT
Return

############################################################
# traitement des colonnes
$TXT_COLONNES
Local    Char    SOC(20)
Raz INBC, ICOD, ICOF, WTOT, WAVG, WVAR, WETY
Raz WDTE, WCOL, GSCOLDES
#
Call LECTURE("FCY",[M:SHS1]FCY,"") From CONTOBJ
SOC = [F:FCY]LEGCPY

Filter [PER] Where CPY=SOC
#ZJOU  = year(date$)*100+month(date$)
Case [M:SHS1]SRTCOD
  When 1 :
    WDAT  = [M:SHS1]STRDAT
    Call GETPERSOC(SOC,1,WDAT,EXE,PER) From CPTSUB
    GSCOLDES(INBC) = format$("D:"+GFMDAT,[F:PER]PERSTR)
    WDTE(INBC) = [F:PER]PERSTR
    WCOL(INBC) = INBC
    INBC += 1
    If [M:SHS1]MONNBR > 1
       For I = 2 To [M:SHS1]MONNBR
         Read [PER]PER0 Next
         GSCOLDES(INBC) =  format$("D:"+GFMDAT,[F:PER]PERSTR)
         WDTE(INBC) = [F:PER]PERSTR
         WCOL(INBC) = INBC
         INBC += 1
         ICOF += 1
       Next I
    Endif
    Gosub TRT_COLSPE

  When Default :
    Gosub TRT_COLSPE
    ICOD  = INBC
    ICOF  = INBC
    WDAT  = [M:SHS1]ENDDAT
    Call GETPERSOC(SOC,1,WDAT,EXE,PER) From CPTSUB
    GSCOLDES(INBC) = format$("D:DD[-]MM[-]YYYY",[F:PER]PERSTR)
    WDTE(INBC) = [F:PER]PERSTR
    WCOL(INBC) = INBC
    INBC += 1
    If [M:SHS1]MONNBR > 1
       For I = 2 To [M:SHS1]MONNBR
          Read [PER]PER0 Prev
          GSCOLDES(INBC) = format$("D:DD[-]MM[-]YYYY",[F:PER]PERSTR)
          WDTE(INBC) = [F:PER]PERSTR
          WCOL(INBC) = INBC
          INBC += 1
          ICOF += 1
       Next I
   Endif
Endcase
Filter [PER]
Return
############################################################
$TRT_COLSPE
If [M:SHS1]TOTFLG = 2
  GSCOLDES(INBC) = mess(47,187,1)
  WTOT = INBC
  INBC += 1
Endif
If [M:SHS1]AVGFLG = 2
  GSCOLDES(INBC) = mess(46,187,1)
  WAVG = INBC
  INBC += 1
Endif
If [M:SHS1]VARFLG = 2
  GSCOLDES(INBC) = mess(48,187,1)
  WVAR = INBC
  INBC += 1
Endif
If [M:SHS1]ETYFLG = 2
  GSCOLDES(INBC) = mess(49,187,1)
  WETY = INBC
  INBC += 1
Endif
Return
############################################################
$TXT_LIGNES
#Raz WLIG, INBL #MAE, bg 48961
Raz GLIG, INBL

For I = 0 To WNBL-1
  WFLDS = mid$(WFLD(I),2,10)
  WDEF  = val(left$(WFLD(I),1))
  If evalue("dim([M:SHS1]"+WFLDS+")>0&[M:SHS1]"+WFLDS+"=2") |
&    evalue("dim([M:SHS1]"+WFLDS+")<0&WDEF=2")
        Read [ATZ]CODZONE = "ITMMVTHIS";WFLDS
        If fstat = 0
          #WLIG(INBL) = WFLDS     #MAE, bg 48961
          GLIG(INBL) = WFLDS
          Call TEXTE([F:ATZ]NOCOURT,WINT(INBL)) From OBJDIV
          #MAE, bg 73900
          #WTYP(INBL) = [F:ATZ]CODTYP
          GTYP(INBL) = [F:ATZ]CODTYP
          WLON(INBL) = [F:ATZ]LONG
          INBL += 1
        Endif
  Endif
Next I
Return
###########################################################
$LECTURE
NBLU   = 2
If [M:SHS1]ITMREF = "" | [M:SHS1]FCY = ""
  NBLU = 0
  Goto LECTURE_FIN
Endif
#
Read [ITM]ITM0=[M]ITMREF
If fstat
  NBLU = 0
  Goto LECTURE_FIN
Endif
Read [TUN]TUN0=[F:ITM]STU
If fstat
  Raz [F:TUN]
Endif
Raz [M:SHS2]
Raz WCUM
If [M:SHS1]FLG = 0
  Gosub TXT_LIGNES
  Gosub TXT_COLONNES
Endif
nolign = 0
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Filter [ITH] Where ITMREF = [M:SHS1]ITMREF &
&                  STOFCY = [M:SHS1]FCY    &
&                  evalue (WFILS)          &
&                  evalue (WFILSPE)
&            Order By Key ITH0
For [ITH]
  J = find([F:ITH]PERSTR,WDTE)
  If J <> 0 Gosub TRT_CUMUL Endif
Next
Filter [ITH]


# Chargement code unite et intitulé ligne
For I = 0 To INBL-1
  COL000(I) = WINT(I)
  #MAE, bg 73900
  #Case WTYP(I)
  Case GTYP(I)
    When "QTY" :
      [M:SHS2]UOM(I) = num$([F:TUN]UOMDEC)
      [M:SHS2]STU(I) = [F:ITM]STU
    When "DCB" :
      [M:SHS2]UOM(I) = num$(mod(WLON(I)*10,10))
      [M:SHS2]STU(I) = ""
    When "C", "L" :
      [M:SHS2]UOM(I) = "0"
      [M:SHS2]STU(I) = ""
    When Default :
      [M:SHS2]UOM(I) = "2"
      [M:SHS2]STU(I) = ""
  Endcase
Next I

# Moyenne cumuls variance et écart type
For I = 0 To INBL-1
  If [M:SHS1]AVGFLG = 2
    #--- Bug 74161
    #WCUM(I,WAVG) = arr(avg(WCUM(I,ICOD..ICOF)),10^-val([M:SHS2]UOM(I)))
    If left$(GLIG(I),3)="MON"
      WCUM(I,WAVG) = arr(avg(WCUM(I,ICOD..ICOF)),10^-val([M:SHS2]UOM(I)))
    Else
      WCUM(I,WAVG) = 0
    Endif
    #---
  Endif
  If [M:SHS1]TOTFLG = 2
    #--- Bug 74161
    #WCUM(I,WTOT) = sum(WCUM(I,ICOD..ICOF))
    If left$(GLIG(I),3)="MON"
      WCUM(I,WTOT) = sum(WCUM(I,ICOD..ICOF))
    Else
      WCUM(I,WTOT) = 0
    Endif
    #---
  Endif
  If [M:SHS1]VARFLG = 2
    #--- Bug 74161
    #WCUM(I,WVAR) = arr(var(WCUM(I,ICOD..ICOF)),10^-val([M:SHS2]UOM(I)))
    If left$(GLIG(I),3)="MON"
      WCUM(I,WVAR) = arr(var(WCUM(I,ICOD..ICOF)),10^-val([M:SHS2]UOM(I)))
    Else
      WCUM(I,WVAR) = 0
    Endif
    #---
  Endif
  If [M:SHS1]ETYFLG = 2
    #--- Bug 74161
    #WCUM(I,WETY) = sqr(var(WCUM(I,ICOD..ICOF)))
    #WCUM(I,WETY) = arr(WCUM(I,WETY),10^-val([M:SHS2]UOM(I)))
    If left$(GLIG(I),3)="MON"
      WCUM(I,WETY) = sqr(var(WCUM(I,ICOD..ICOF)))
      WCUM(I,WETY) = arr(WCUM(I,WETY),10^-val([M:SHS2]UOM(I)))
    Else
      WCUM(I,WETY) = 0
    Endif
    #---
  Endif
Next I
# Chargement valeurs tableau
For I = 0 To INBL-1
  For J = 0 To INBC-1
    WEVA = "[M:SHS2]COL"+format$("N0:3",J+1)+"(I)"
    Assign WEVA With WCUM(I,J)
  Next J
Next I
#
NOL += INBL
SUITE  = 1
RETOUR = 1
$LECTURE_FIN
Return
############################################################
# Cumul (J contient la colonne)
$TRT_CUMUL
For I = 0 To INBL-1
      #WCUM(I,J-1) = evalue("[F:ITH]"+WLIG(I))  MAE, bg 48961
      WCUM(I,J-1) = evalue("[F:ITH]"+GLIG(I))
Next I
Return

############################################################
$SELITH
If clalev([F:AMZ2])=0 : Local File AMSKZON    [AMZ2] : Endif
Filter [AMZ2] Where CODMSK = "CRITSHS" &
&                 find([F:AMZ2]NUMBLOC,2)
&            Order By Key CODZON
TIT = mess(18,100,1)
NBTEX = 0
For [AMZ2]
  If evalue("[M]"+[F:AMZ2]CODZON+"=2")
    NBTEX += 1
    Call TEXTE([F:AMZ2]INTIT,TEX(NBTEX)) From OBJDIV
  Endif
Next
Filter [AMZ2]
Return

############################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GCONSULT <> 0
  mkstat = 2
Endif
End
############################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
WFCY    =VALEUR
WENDDAT =[M:SHS1]ENDDAT
WMONNBR =[M:SHS1]MONNBR
WDATOK=0
Gosub CAL_DATE
[M:SHS1]FLG = 0
End
############################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SHS1] = [F:ITM]
End
############################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
[M:SHS1]FLG = 0
End
###########################################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
[M:SHS1]FLG = 0
End
###########################################################
Subprog AP_SRTCOD(VALEUR)
Variable Integer VALEUR
End
###########################################################
Subprog AV_ENDDAT(VALEUR)
Variable Date     VALEUR
If VALEUR = [0/0/0]
  VALEUR = eomonth(addmonth(date$,-1))
Endif
End
###########################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date     VALEUR
WFCY    =[M:SHS1]FCY
WENDDAT =VALEUR
WMONNBR =[M:SHS1]MONNBR
WDATOK=0
Gosub CAL_DATE
[M:SHS1]FLG = 0
End
###########################################################
Subprog AM_MONNBR(VALEUR)
Variable Decimal  VALEUR
WFCY    =[M:SHS1]FCY
WENDDAT =[M:SHS1]ENDDAT
WMONNBR =VALEUR
WDATOK=0
Gosub CAL_DATE
[M:SHS1]FLG = 0
End
###########################################################
Subprog C_MONNBR(VALEUR)
Variable Decimal VALEUR
If VALEUR < 1 | VALEUR > 24
  mkstat = 2
Endif
End
############################################################
Subprog AV_COL000(VALEUR)
Variable Char    VALEUR()
If [M]STU(nolign-1) <> ""
  pcolor = GCOUL(0)
Else
  If [M]UOM(nolign-1) = "0"
    pcolor = GCOUL(1)
  Else
    pcolor = GCOUL(3)
  Endif
Endif
End
############################################################
Subprog CTR_FLAG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  Local Char WINT(25)
  If clalev([F:AMZ2])=0 : Local File AMSKZON    [AMZ2] : Endif
  Read [AMZ2]CODE="CRITSHS";zoncou
  If fstat = 0
    Call TEXTE([F:AMZ2]INTIT,WINT) From OBJDIV
  Endif
Endif
End
############################################################
Subprog C_PHYSTO(VALEUR)
Variable Integer VALEUR
Call CTR_FLAG(VALEUR)
End
