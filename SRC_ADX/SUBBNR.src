#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################################
# Process Name: SUBBNR
# Description : Manual Bank Reconciliation
# Date        : April 20th, 2011
####################################################################################
# Revision 88201, June 26th, 2013
# Revision 90865, July 1st, 2013
# Revision 91546, July 31st, 2013
####################################################################################
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FBNR","SUBBNR","") From GSAISIE
End

$ACTION

Case ACTION

 When "OUVRE"        : Gosub OUVRE
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF

 When "FIR"          : Gosub FIRSTPAGE
 When "LAS"          : Gosub LASTPAGE
 When "SUI"          : Gosub PAGEFORWARD
 When "PRE"          : Gosub PAGEBACK

 When "AVANT_CRE"    : Gosub AVANT_CRE
 When "CRE"          : Gosub CRE
 When "SUP"          : Gosub SUP

 When "AVANT_NEW"    : Gosub AVANT_NEW

 When "ENR"          : Gosub SAVE_UPDATE
 When "ABA"          : Gosub ABANDON
 When "END"          : Gosub FIN
 When "MEN"          : Gosub BOUTON_MENU
 When "BOUTON"       : Gosub BOUTON
 When "RAF"          : Gosub SEARCH_DISPLAY
 When "AB1_NBLIG"    : GCONSULT = 1
 When "BB1_NBLIG"    : GCONSULT = 0

 When "INIT_DIA"     : If GACTION = "BANRECADJ" or GACTION = "BNRCRIT"
                         Gosub INIT_DIA
                       Endif
 When "SORTIE"       : If GACTION = "BANRECADJ" or GACTION = "BNRCRIT"
                         Gosub SORTIE
                       Endif
 When "CONTROLE"     : If GACTION = "BANRECADJ"
                         [M:BNR2] = [M:DIA]
                       Endif
                       If GACTION = "BNRCRIT"
                         [M:BNR1] = [M:DIA]
                       Endif

Endcase
Return

####################################################################################
$OUVRE
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:BAL])=0 : Local File BALANCE    [BAL] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
If clalev([F:ALS])=0 : Local File ALSTRD     [ALS] : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON    [AMZ] : Endif
If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif
If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif

If clalev([F:BEH])=0 : Local File BANREC   [BEH] : Endif
If clalev([F:BED])=0 : Local File BANRECD  [BED] : Endif

Gosub OUVRE_CHN From CHKLIB

Global Char    GADJREA(20)    # Adjustment reason, captured here, used by GL Entry

# Title Description
Global Char    GAMTDESC(25)
GAMTDESC = mess(00174,00105,1) # Ledger Amount
#GAMTDESC = mess(00023,00173,1) # Transaction Amount

Local Char    SYMBCHK(20)

Local Char    CAR(1)
Local Integer I,J, STAT

Local Char    CURBNR(20)

Local Mask    RAPBAN3 [RB3] : # Sort Criteria Screen
Local Mask    BNR1    [BNR1]
Local Mask    BNR2    [BNR2]

# Paging Variables
Local Integer CURPAGE, MOREPAGES, JUSTBNR, SOMEDAE, SKIPBNR
Local Date    FIRACCDAT, NXTACCDAT, PRVACCDAT
Local Integer FIRACCNUM, NXTACCNUM, PRVACCNUM

Local Integer POSEVERROU, VERROU, SAVNOL, NOL,  RECHOK


Local Integer MAXLIG
Local Libelle KIAOK         : # Activity Code KIA : Bank Date(Italie)

Local Integer OKTCA, OK
Local Char    SEQNUM(GLONANM)
Local Char    MESSA(80)

# Retrieve the Bank Statement Sequence Code
SEQNUM = ""
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA : SEQNUM = [F:TCA]CODNUM(5) : Endif
If SEQNUM="" : SEQNUM = "RBK" : Endif

Return
####################################################################################
$DEBUT

Raz [M]
Filter [BAN]
REP = ""
KIAOK = (dim([M]BANDAT)>0)
MAXLIG = dim([M]REF)
CURPAGE = 0
MOREPAGES = 0
JUSTBNR = 0
SKIPBNR = 0
Grizo [M]
Actzo [M]RBKNUM
Affzo [M]

Return
####################################################################################
$SETBOUT

Raz ETABOU
CHMEN = ""

# If records are displayed
If [M]NBLIG > 0
  If CURPAGE > 1
    ETABOU(GPREC) = 1  # Page Backward
    ETABOU(GPREM) = 1  # First Page
  Endif

  If MOREPAGES
    ETABOU(GSUIV) = 1  # Page forward
    ETABOU(GDERN) = 1  # Last Page
  Endif

  If [M]STAFLG < 3 and not JUSTBNR
    CHMEN += "3"    # Mark
  Endif

Endif

#
# If a Statement  is being displayed
#
If [M]RBKNUM <> ""
  Grizo [M]MRKCHRS

  If [M]STAFLG < 3
    CHMEN += "124"  # Adjustment/Close/Payment-Receipt Entry
    CHMEN += "V"   # Can Search and add more records to the Bank Rec
    If GREP = "" and REP = ""
      ETABOU(GSUPP) = 1  # Delete
    Endif
    Actzo [M]RBKDES, ENDSTMT
    Actzo [M]20
  Else
    Local Char RETVAL(3)
    Call PARAMUTIL("REOPENREC",RETVAL,GUSER,"") From SUBAUS
    If RETVAL = "2"
      CHMEN += "R"   # Reopen
    Endif
    Grizo [M]
    Actzo [M]RBKNUM
  Endif

Endif

#
# If they are in modification/creation mode
#
If REP = "C" or REP="M" or GREP = "M"

 Grizo [M]RBKNUM

 If REP <> "C"
     Grizo [M]BAN
 Endif

 CHMEN = ""

 If [M]RBKNUM = ""
    ETABOU(GCREE) = 1 # Create
 Else
    ETABOU(GENRE) = 1 # Save
 Endif

 ETABOU(GABAN) = 1  #Cancel

Elsif REP=""
 ETABOU(GNOUV) = 1           # New
 ETABOU(GRAFF) = 1
 Actzo [M]RBKNUM
 Grizo [M]BAN, BNKDAT
Endif

ETABOU(GBFIN) = 1 # End

Return
####################################################################################
$INIT_DIA
Raz [M:DIA]
Return
####################################################################################
$SORTIE
PARAM(1)=num$(OK)   :# Indicate whether OK or End was pushed
Return
####################################################################################
$AVANT_NEW

JUSTBNR = 0
FIRACCNUM = -1
FIRACCDAT = [00/00/00]
Raz [M]
Effzo [M]
Actzo [M]
Grizo [M]RBKNUM
zonsui = "[M]BAN"
REP = "C"

Return
####################################################################################
$AVANT_CRE

# Obtain Sequence Number
Local Char SIT(GLONFCY)
SIT = [M]FCY
If SIT = ""
 Call LEC_BAN([M]BAN) From CPTLEC
 If [F:BAN]FCY<>""
  SIT = [F:BAN]FCY
 Else
  Call LEC_CPY([F:BAN]CPY) From CPTLEC
  If [F:CPY]MAIFCY=""
   # No main site attached to the company
   Call ECR_TRACE(mess(68,107,1)-[F:BAN]CPY,1) From GESECRAN
   GOK = 0    #77886
   Return
  Else
   SIT = [F:CPY]MAIFCY
  Endif
 Endif
Endif
Call NUMERO(SEQNUM,SIT,[M]BNKDAT,[M]BAN,[M]RBKNUM,STAT) From SUBANM
If STAT | GOK<1
  Gosub MESSAGE From SUBANM
  # Problem in recovering the sequence number (Follow-up of the message indicating the origin of the problem)
  Call ECR_TRACE(mess(60,199,1)-"("+SEQNUM+") : "+MESSA,1) From GESECRAN
  Return
Endif

[M]STAFLG = 2 #Open
Affzo [M]RBKNUM, STAFLG
If [M]MRKCHRS = ""
  [M]MRKCHRS = right$([M]RBKNUM, len([M]RBKNUM) - 4)
  Affzo [M]MRKCHRS
Endif

Return
####################################################################################
$CRE

Trbegin [BEH]

Raz [BEH]

[F:BEH] = [M]

If [F:BEH]STAFLG < 3
  [F:BEH]OUTDEP = 0
  [F:BEH]OUTWTH = 0
  [F:BEH]BLC = 0
Endif

If [F:BEH]BNKDAT = [00/00/00]
  [F:BEH]BNKDAT = date$
  [M]BNKDAT = [F:BEH]BNKDAT
  Affzo [M]BNKDAT
Endif
[F:BEH]CREDAT = date$
[F:BEH]CREUSR = GUSER
Write [F:BEH]
If fstat
  GOK = 0: Call FSTA("BEH") From GLOCK
Else
  # Add the marked lines to the Bank Rec and mark the GACCENTRYD records
  For I = 0 To [M]NBLIG - 1

    If [M]MRK(I) = 2

      If [M]CHK(I) = ""
        [M]CHK(I) = [M]MRKCHRS
      Endif
      [F:BED]RBKNUM = [F:BEH]RBKNUM
      [F:BED]ACCNUM = [M]ACCNUM(I)
      [F:BED]CREDAT = date$
      [F:BED]CREUSR = GUSER
      Write [F:BED]
      If fstat
        GOK = 0: Call FSTA("BED") From GLOCK : Break
      Endif

    Endif

    If [M]CHGDAT(I)<>0
     GCLE = num$([M]ACCNUM(I))
     Readlock [DAE]DAE2 = [M]ACCNUM(I)
     If fstat=1
      GOK = -1 : GLOCK = "$GACCENTRYD"-GCLE : Break
     Elsif fstat
      GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK
     Elsif !fstat
      [F:DAE]CHK    = [M]CHK(I)
      [F:DAE]CHKDAT = date$
      Rewrite [DAE]
      If fstat
        GOK = 0 : Call FSTA("DAE") From GLOCK : Break
      Endif
      GCLE = [F:DAE]TYP-[F:DAE]NUM
      Readlock [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
      If fstat=1
       GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break
      Elsif fstat
       GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK
      Elsif !fstat
       [F:HAE]VALDAT = [M]VALDAT(I)
       If KIAOK : [F:HAE]BANDAT = [M]BANDAT(I) : Endif
       Rewrite [HAE]
       If fstat
        GOK = 0 : Call FSTA("HAE") From GLOCK : Break
       Endif
       If GOK<1 : Break : Endif
      Endif
     Endif
     [M]CHGDAT(I)=0
    Endif
  Next
Endif

If GOK < 1
  Raz [M]RBKNUM
  Affzo [M]RBKNUM
  Rollback
  Return
Endif

Commit

REP = ""
GREP = ""
Return
####################################################################################
$SUP

# Delete the Bank Rec header and details and uncheck the GACCENTRYD records
Trbegin [F:BEH]

Delete [F:BEH] Where RBKNUM = [M]RBKNUM

If !fstat
    For [F:BED] Where RBKNUM = [M]RBKNUM

      Readlock [DAE]DAE2 = [F:BED]ACCNUM
      If fstat=1
        GOK = -1 : GLOCK = "$GACCENTRYD"-GCLE : Break
      Elsif fstat
        GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK
      Elsif !fstat
        [F:DAE]CHK    = ""
        [F:DAE]CHKDAT = [00/00/00]
        Rewrite [F:DAE]
        If fstat
          GOK = 0 : Call FSTA("DAE") From GLOCK : Break
        Endif
        If GOK<1 : Break : Endif
        Delete [F:BED]
        If fstat
          GOK = 0 : Break
        Endif
      Endif
    Next
Else
    GOK = 0 : Call FSTA("BEH") From GLOCK
Endif

If GOK < 1 : Rollback : Return : Endif

Commit

Diszo [M]
Effzo [M]
Actzo [M]RBKNUM
zonsui = "RBKNUM"

Return
####################################################################################
$BOUTON_MENU

Case BOUT
  When "R" : Gosub REOPEN_BNR
Endcase
Return

####################################################################################
$BOUTON

Case BOUT
  When "U" : If RECHOK=2 : Gosub SORTSCREEN   : Endif
  #When "V" : JUSTBNR = 0 : Gosub SEARCH_DISPLAY #101252.o
  When "V" : JUSTBNR = 0 : SKIPBNR =0 : Gosub SEARCH_DISPLAY #101252.n
  When "1" : If RECHOK=2 : Gosub ADJUSTMENT   : Endif
  When "2" : Gosub CLOSE_BNR
  When "3" : If RECHOK = 2 : Gosub MASSMARK   : Endif
  When "4" : Gosub AFTERPAYMENT

Endcase

Return
####################################################################################
$AFTERPAYMENT

Gosub SEARCH_DISPLAY
Gosub UPDATE_TOTALS

Return

####################################################################################
$UPDATE_TOTALS

Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,[M]BNKDAT,[M]BLC) From SUBCHK
If [M]SNSBLC = 2
  [M]BLC = -1 * [M]BLC
Endif
Affzo [M]BLC
Call CALC_OUTSTANDING()
Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)

Return

####################################################################################
$MASSMARK

Local Integer NUMMARKED
Local Integer I
Local Decimal THEAMT

NUMMARKED = 0
Default Mask [BNR0]

# Make sure something was entered
If [M:BNR1]CACCDATDEB = [00/00/00] & [M:BNR1]CACCDATFIN = [00/00/00] & [M:BNR1]CTYP = "" & [M:BNR1]CAMT = 0 & [M:BNR1]CNUMDEB = "" & [M:BNR1]CNUMFIN = ""
&    & [M:BNR1]CREFDEB = "" & [M:BNR1]CREFFIN = "" & [M:BNR1]CDESDEB = "" & [M:BNR1]CDESFIN = ""
  Return
Endif

For I = 0 To [M]NBLIG - 1

  If [M:BNR1]CACCDATDEB <> [00/00/00] and [M:BNR0]ACCDAT(I) <  [M:BNR1]CACCDATDEB
    Goto SKIPREC
  Endif

  If [M:BNR1]CACCDATFIN <> [00/00/00] and [M:BNR0]ACCDAT(I) >  [M:BNR1]CACCDATFIN
    Goto SKIPREC
  Endif

  If [M:BNR1]CTYP <> "" and [M:BNR0]TYP(I) <> [M:BNR1]CTYP
    Goto SKIPREC
  Endif

  If [M:BNR1]CAMT <> 0 and [M:BNR0]AMTBNQ(I) <> [M:BNR1]CAMT and [M:BNR0]AMTBNQD(I) <> [M:BNR1]CAMT
    Goto SKIPREC
  Endif

  If [M:BNR1]CNUMDEB <> "" and [M:BNR0]NUM(I) < [M:BNR1]CNUMDEB
    Goto SKIPREC
  Endif

  If [M:BNR1]CNUMFIN <> "" and [M:BNR0]NUM(I) > [M:BNR1]CNUMFIN
    Goto SKIPREC
  Endif

  # Description
  If [M:BNR1]CDESDEB <> "" and [M:BNR0]DES(I) < [M:BNR1]CDESDEB
    Goto SKIPREC
  Endif

  If [M:BNR1]CDESFIN <> "" and [M:BNR0]DES(I) > [M:BNR1]CDESFIN
    Goto SKIPREC
  Endif

  # Reference
  If [M:BNR1]CREFDEB <> "" and [M:BNR0]REF(I) < [M:BNR1]CREFDEB
    Goto SKIPREC
  Endif

  If [M:BNR1]CREFFIN <> "" and [M:BNR0]REF(I) > [M:BNR1]CREFFIN
    Goto SKIPREC
  Endif

  # Mark Record if it isn't already
  If [M:BNR0]MRK(I) <>  2
      [M:BNR0]MRK(I) = 2
      [M:BNR0]MRKT(I) = 1
      [M:BNR0]CHK(I) = [M]MRKCHRS
      [M:BNR0]CHGDAT(I) = 1

      # Add to Reconciled, subtract from outstanding
      If [M:BNR0]SNS(I) = 1
        [M:BNR0]DEBREC += [M]AMTBNQD(I)
        [M:BNR0]OUTDEP -= [M]AMTBNQD(I)
      Else
        [M:BNR0]CRDREC += [M]AMTBNQ(I)
        [M:BNR0]OUTWTH -= [M]AMTBNQ(I)
      Endif

      NUMMARKED += 1
  Endif
$SKIPREC
Next

If NUMMARKED > 0
  Affzo [M:BNR0]MRK, DEBREC, CRDREC, OUTDEP, OUTWTH
  Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)
  mkstat = 4
  GREP = "M"
Endif

Return
####################################################################################
$SORTSCREEN

Local Char    CRIT1(20), CRIT2(20), CRIT3(20), CRIT4(20), CRIT5(20), CRIT6(20), CRIT7(20)
Default Mask [BNR0]

For J=1 To 7
 I = find(J,[M:RB3]ORDRE(0..[M:RB3]NBLIG-1))
 If I=1 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "AMTBNQT([S]INDICE)"  : Endif
 If I=1 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "AMTBNQDT([S]INDICE)" : Endif
 If I=2 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "ACCDAT([S]INDICE)"  : Endif
 If I=2 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "ACCDATT([S]INDICE)" : Endif
 If I=3 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "BANCIB([S]INDICE)"  : Endif
 If I=3 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "BANCIBT([S]INDICE)" : Endif
 If I=4 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "REF([S]INDICE)"     : Endif
 If I=4 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "REFT([S]INDICE)"    : Endif
 If I=5 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "NUM([S]INDICE)"     : Endif
 If I=5 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "NUMT([S]INDICE)"    : Endif
 If I=6 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "DES([S]INDICE)"     : Endif
 If I=6 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "DEST([S]INDICE)"    : Endif
 If I=7 & [M:RB3]TRI(I-1)=1 : Assign "CRIT"+num$(J) With "MRK([S]INDICE)"     : Endif
 If I=7 & [M:RB3]TRI(I-1)=2 : Assign "CRIT"+num$(J) With "MRKT([S]INDICE)"    : Endif
Next J

If CRIT1="" & CRIT2="" & CRIT3="" & CRIT4="" & CRIT5="" & CRIT6="" & CRIT7="" : Return : Endif
If CRIT1="" : CRIT1 = "1=1" : Endif
If CRIT2="" : CRIT2 = "1=1" : Endif
If CRIT3="" : CRIT3 = "1=1" : Endif
If CRIT4="" : CRIT4 = "1=1" : Endif
If CRIT5="" : CRIT5 = "1=1" : Endif
If CRIT6="" : CRIT6 = "1=1" : Endif
If CRIT7="" : CRIT7 = "1=1" : Endif

Sorta NBLIG NBLIG Order By evalue(CRIT1),evalue(CRIT2),evalue(CRIT3),evalue(CRIT4),evalue(CRIT5),evalue(CRIT6), evalue(CRIT7)
Affzo [M]20

Return
####################################################################################
$FIRSTPAGE

If GREP = "M" or REP = "M"
  Call ECR_TRACE(mess(00038,00193,1),1) From GESECRAN
  Return
Endif

PRVACCDAT = [00/00/00]
PRVACCNUM = 0
FIRACCDAT = [00/00/00]
FIRACCNUM = 0
NXTACCNUM = 0
NXTACCDAT = [00/00/00]
CURPAGE = 1

Gosub SEARCH_DISPLAY

Return
####################################################################################
$LASTPAGE

If GREP = "M" or REP = "M"
  Call ECR_TRACE(mess(00038,00193,1),1) From GESECRAN
  Return
Endif

Local Integer KOUNT, KOUNTDAE, KOUNTBNR, TOTKOUNT, FIRREC, PRVREC, NUMPAGES

MOREPAGES = 0

# Count the Additional Search Records
KOUNTDAE = func COUNT_SEARCH_RECS(JUSTBNR)    #88201.n

# Count the Bank Rec Records
KOUNTBNR = func COUNT_BNR_RECS()

# Determine number of pages and where begin the last page
TOTKOUNT = KOUNTDAE + KOUNTBNR
NUMPAGES = TOTKOUNT / MAXLIG
If mod(TOTKOUNT,MAXLIG) = 0
  NUMPAGES -= 1
Endif
CURPAGE = NUMPAGES + 1
FIRREC = NUMPAGES * MAXLIG + 1
PRVREC = FIRREC - MAXLIG

# If the last page begins after the bank rec records and within the search records
If FIRREC > KOUNT
  FIRREC = FIRREC - KOUNT
  If PRVREC > KOUNT
    PRVREC = PRVREC - KOUNT
  Else
    PRVACCNUM = 0
    PRVACCDAT = [00/00/00]
    PRVREC = -1
  Endif

  KOUNT = 0
  SKIPBNR = 1
  For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""
    Raz OK
    If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
      Gosub CTL
    Endif
    If OK
      KOUNT += 1
      If KOUNT = FIRREC
        FIRACCDAT = [F:DAE]ACCDAT
        FIRACCNUM = [F:DAE]ACCNUM
        Break
      Endif
    Endif
  Next

# Last page will begin with Bank Rec records
Else
  SKIPBNR = 0
  FIRREC = NUMPAGES * MAXLIG + 1
  PRVREC = FIRREC - MAXLIG
  KOUNT = 0
  Link [DAE] With [F:BED]BED1 = [F:DAE]ACCNUM As [LNK] Where [F:BED]RBKNUM = [M]RBKNUM Order By [DAE]ACCDAT

  For [LNK]
    KOUNT += 1
    If KOUNT = PRVREC
      PRVACCNUM = [F:DAE]ACCNUM
      PRVACCDAT = [F:DAE]ACCDAT
    Endif
    If KOUNT = FIRREC
      FIRACCDAT = [F:DAE]ACCDAT
      FIRACCNUM = [F:DAE]ACCNUM
      Break
    Endif
  Next
Endif

Gosub SEARCH_DISPLAY
Return
####################################################################################
$PAGEFORWARD

If GREP = "M" or REP = "M"
  Call ECR_TRACE(mess(00038,00193,1),1) From GESECRAN
  Return
Endif

# If some Search records were displayed on the previous page, then we can skip the Bank Rec records for the Next Page
If SOMEDAE
  SKIPBNR = 1
Endif

PRVACCDAT = FIRACCDAT
PRVACCNUM = FIRACCNUM
FIRACCDAT = NXTACCDAT
FIRACCNUM = NXTACCNUM
NXTACCNUM = 0
NXTACCDAT = [00/00/00]
CURPAGE += 1

Gosub SEARCH_DISPLAY

Return
####################################################################################
$PAGEBACK

If GREP = "M" or REP = "M"
  Call ECR_TRACE(mess(00038,00193,1),1) From GESECRAN
  Return
Endif

Local Integer KOUNT, KOUNTDAE, KOUNTBNR, TOTKOUNT, FIRREC, PRVREC, NUMPAGES

CURPAGE -= 1

# Special/optimized case
If JUSTBNR and PRVACCNUM <> 0 and PRVACCDAT <> FIRACCDAT or PRVACCNUM <> FIRACCNUM
  FIRACCDAT = PRVACCDAT
  FIRACCNUM = PRVACCNUM
  PRVACCDAT = [00/00/00]
  PRVACCNUM = 0
Elsif CURPAGE = 1
  FIRACCDAT = [00/00/00]
  FIRACCNUM = 0
  PRVACCDAT = [00/00/00]
  PRVACCNUM = 0
Else
  # Count the Additional Search Records
  KOUNTDAE = func COUNT_SEARCH_RECS(JUSTBNR)        #88201.n

  # Count the Bank Rec Records
  KOUNTBNR = func COUNT_BNR_RECS()

  # Determine where begin the CURPAGE
  FIRREC = (CURPAGE - 1) * MAXLIG + 1
  PRVREC = FIRREC - MAXLIG
  If FIRREC > KOUNTBNR
    FIRREC = FIRREC - KOUNTBNR
    If PRVREC > KOUNTBNR
      PRVREC = PRVREC - KOUNTBNR
    Else
      PRVREC = 0
    Endif

    KOUNT = 0
    SKIPBNR = 1
    For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""
      Raz OK
      If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
        Gosub CTL
      Endif
      If OK
        KOUNT += 1
        If KOUNT = FIRREC
          FIRACCDAT = [F:DAE]ACCDAT
          FIRACCNUM = [F:DAE]ACCNUM
          Break
        Endif
      Endif
    Next

  Else
    SKIPBNR = 0
    KOUNT = 0
    Link [DAE] With [F:BED]BED1 = [F:DAE]ACCNUM As [LNK] Where [F:BED]RBKNUM = [M]RBKNUM Order By [DAE]ACCDAT

    For [LNK]
      KOUNT += 1
      If KOUNT = PRVREC
        PRVACCNUM = [F:DAE]ACCNUM
        PRVACCDAT = [F:DAE]ACCDAT
      Endif
      If KOUNT = FIRREC
        FIRACCDAT = [F:DAE]ACCDAT
        FIRACCNUM = [F:DAE]ACCNUM
        Break
      Endif
    Next
  Endif
Endif

Gosub SEARCH_DISPLAY

Return

####################################################################################
#Remplit les zones d'entête
$LECTURE

If [M]RBKNUM = ""
  Effzo [M]10
Endif
Effzo [M]15
Read [BAN]BAN0=[F:BAN]BAN
[M] = [F:BAN]
Call SETCUR(1,[F:BAN]CPY,[M]CURLED) From CPTDIV

If [M]CUR = [M]CURLED            # Case #1 Bank Currency = Ledger Currency
  GAMTDESC = mess(00023,00173,1) # Transaction Amount
Else                             # Case #2 Bank Currency <> Ledger Currency
  GAMTDESC = mess(00174,00105,1) # Ledger Amount
Endif

Gosub UPDATE_TOTALS

Return
####################################################################################
#
# Find and display the detail lines with items that could be added to a Bank Reconciliation
#
$SEARCH_DISPLAY

Local Integer I, OK
Call TEMPON("L") From GESECRAN

VERROU = 0
nolign = 0
Raz [M]DEBREC, [M]CRDREC

#
# If there is already a Bank Rec header loaded, then display bank reconciliation detail records
#
If [M]RBKNUM <> ""
  Read [F:BEH]BEH0=[M]RBKNUM
  If fstat = 0
    Gosub DISPLAY_BNR
    nolign = [M]NBLIG
  Endif

  If [M]STAFLG >= 3 or JUSTBNR
    Call TEMPOFF From GESECRAN
    Return
  Endif
Else
  SKIPBNR = 1
Endif

POSEVERROU = 1
For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""

 Raz OK
 If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
  Gosub CTL
 Endif

 If OK

  If SKIPBNR and FIRACCNUM <> 0 and FIRACCDAT <> [00/00/00] and ([DAE]ACCDAT < FIRACCDAT or ([DAE]ACCDAT = FIRACCDAT and [DAE]ACCNUM < FIRACCNUM))
   Goto SKIPIT
  Endif

  If FIRACCNUM = 0 and FIRACCDAT = [00/00/00]
   FIRACCNUM = [F:DAE]ACCNUM
   FIRACCDAT = [F:DAE]ACCDAT
  Endif

  If nolign >= MAXLIG
   MOREPAGES = 1
   NXTACCNUM = [F:DAE]ACCNUM
   NXTACCDAT = [F:DAE]ACCDAT
   Break
  Endif
  [M]NUM(nolign)    = [F:DAE]NUM
  I = 1
  While I<=len([F:DAE]NUM)
   CAR = mid$([F:DAE]NUM,I,1)
   If 256-ascii(CAR)>0 : [M]NUMT(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:DAE]NUM)=0
   [M]NUMT(nolign) = chr$(256-1)
  Endif

  JUSTBNR = 0
  [M]MRK(nolign) = 1
  [M]MRKT(nolign) = 2

  [M]DES(nolign)    = [F:DAE]DES
  I = 1
  While I<=len([F:DAE]DES)
   CAR = mid$([F:DAE]DES,I,1)
   If 256-ascii(CAR)>0 : [M]DEST(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:DAE]DES)=0
   [M]DEST(nolign) = chr$(256-1)
  Endif
  [M]ACCNUM(nolign)  = [F:DAE]ACCNUM
  [M]TYP(nolign)     = [F:HAE]TYP

  Gosub DISPLAY_AMOUNTS

  [M]REF(nolign)     = [F:HAE]REF
  I = 1
  While I<=len([F:HAE]REF)
   CAR = mid$([F:HAE]REF,I,1)
   If 256-ascii(CAR)>0 : [M]REFT(nolign) += chr$(256-ascii(CAR)) : Endif
   I +=1
  Wend
  If len([F:HAE]REF)=0
   [M]REFT(nolign) = chr$(256-1)
  Endif
  [M]ACCDAT(nolign)  = [F:HAE]ACCDAT
  [M]ACCDATT(nolign) = -nday([F:HAE]ACCDAT)
  [M]BANCIB(nolign)  = [F:HAE]BANCIB
  [M]BANCIBT(nolign) = -val([F:HAE]BANCIB)
  [M]VALDAT(nolign)  = [F:HAE]VALDAT
  If KIAOK
   [M]BANDAT(nolign) = [F:HAE]BANDAT
  Endif
  Filter [PAN] Where ACCNUM=[F:DAE]ACCNUM & CPTBAN=2 & TYPNUM=1
  Read [PAN]PAN0 First
  Filter [PAN]
  If !fstat
   [M]FRMNUM(nolign) = [F:PAN]NUM
  Else
   [M]FRMNUM(nolign) = ""
  Endif

  nolign +=1

 Endif

$SKIPIT
Next

[M]NBLIG = nolign
Call TEMPOFF From GESECRAN

If sum([M:RB3]ORDRE(0..dim([M:RB3]ORDRE)-1))=0
 Call LECMEMO("STD","[M:RB3]","tri") From GMEMO
Endif

Gosub SORTSCREEN

If [M]NBLIG > 0
  Affzo
Else
  Effzo [M]20
Endif

Return

####################################################################################
#
# Display only the lines from a previously created Bank Reconciliation
#
$DISPLAY_BNR

Local Integer I, RECNUM
Local Decimal TAMTLED, THEAMT

VERROU = 0
nolign = 0
RECNUM = 0
MOREPAGES = 0

POSEVERROU = 1

Raz [M]CRDREC, [M]DEBREC

Link [DAE] With [F:BED]BED1 = [F:DAE]ACCNUM, [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM  As [LNK]
&       Where [F:BED]RBKNUM = [F:BEH]RBKNUM
&       Order By [DAE]ACCDAT; [DAE]ACCNUM

For [LNK]

  If FIRACCNUM = 0 and FIRACCDAT = [00/00/00]
    FIRACCNUM = [F:DAE]ACCNUM
    FIRACCDAT = [F:DAE]ACCDAT
  Endif

  # Only display what can fit on a page, but continue calculating totals
  If (([F:DAE]ACCDAT = FIRACCDAT and [F:DAE]ACCNUM >= FIRACCNUM) or ([F:DAE]ACCDAT > FIRACCDAT)) and nolign < MAXLIG

    [M]NUM(nolign)    = [F:DAE]NUM
    I = 1
    While I<=len([F:DAE]NUM)
     CAR = mid$([F:DAE]NUM,I,1)
     If 256-ascii(CAR)>0 : [M]NUMT(nolign) += chr$(256-ascii(CAR)) : Endif
     I +=1
    Wend
    If len([F:DAE]NUM)=0
     [M]NUMT(nolign) = chr$(256-1)
    Endif

    [M]DES(nolign)    = [F:DAE]DES
    I = 1
    While I<=len([F:DAE]DES)
     CAR = mid$([F:DAE]DES,I,1)
     If 256-ascii(CAR)>0 : [M]DEST(nolign) += chr$(256-ascii(CAR)) : Endif
     I +=1
    Wend
    If len([F:DAE]DES)=0
     [M]DEST(nolign) = chr$(256-1)
    Endif

    [M]CHK(nolign)     = [F:DAE]CHK
    [M]MRK(nolign)     = 2
    [M]MRKT(nolign)    = 1
    [M]ACCNUM(nolign)  = [F:DAE]ACCNUM
    [M]TYP(nolign)     = [F:HAE]TYP

    Gosub DISPLAY_AMOUNTS

    [M]REF(nolign)     = [F:HAE]REF

    I = 1
    While I<=len([F:HAE]REF)
     CAR = mid$([F:HAE]REF,I,1)
     If 256-ascii(CAR)>0 : [M]REFT(nolign) += chr$(256-ascii(CAR)) : Endif
     I +=1
    Wend
    If len([F:HAE]REF)=0
     [M]REFT(nolign) = chr$(256-1)
    Endif

    [M]ACCDAT(nolign)  = [F:HAE]ACCDAT
    [M]ACCDATT(nolign) = -nday([F:HAE]ACCDAT)
    [M]BANCIB(nolign)  = [F:HAE]BANCIB
    [M]BANCIBT(nolign) = -val([F:HAE]BANCIB)
    [M]VALDAT(nolign)  = [F:HAE]VALDAT
    If KIAOK
     [M]BANDAT(nolign) = [F:HAE]BANDAT
    Endif
    Filter [PAN] Where ACCNUM=[F:DAE]ACCNUM & CPTBAN=2 & TYPNUM=1
    Read [PAN]PAN0 First
    Filter [PAN]
    If !fstat
     [M]FRMNUM(nolign) = [F:PAN]NUM
    Else
     [M]FRMNUM(nolign) = ""
    Endif

    [M]ADJREA(nolign) = [F:BED]ADJREA
    [M]RBKNUMD(nolign) = [F:BED]RBKNUM

    nolign +=1
    RECNUM += 1

  Elsif RECNUM = MAXLIG
    NXTACCNUM = [F:DAE]ACCNUM
    NXTACCDAT = [F:DAE]ACCDAT
    MOREPAGES  = 1
    RECNUM += 1
  Endif

  # Calculate totals, even after a page has past
  If [F:DAE]SNS=1
    If [M]CUR = [M]CURLED
      If [F:DAE]AMTFLG <> 0
        [M]DEBREC += [F:DAE]AMTLED1
      Else
        [M]DEBREC += [F:DAE]AMTLED
      Endif
    Else
      [M]DEBREC += [F:DAE]AMTCUR
    Endif
  Else
    If [M]CUR = [M]CURLED
      If [F:DAE]AMTFLG <> 0
        [M]CRDREC += [F:DAE]AMTLED1
      Else
        [M]CRDREC += [F:DAE]AMTLED
      Endif
    Else
      [M]CRDREC += [F:DAE]AMTCUR
    Endif
  Endif

Next

[M]NBLIG = nolign

If sum([M:RB3]ORDRE(0..dim([M:RB3]ORDRE)-1))=0
 Call LECMEMO("STD","[M:RB3]","tri") From GMEMO
Endif

Gosub SORTSCREEN

Affzo

Return

######################################################################################
$DISPLAY_AMOUNTS

[M:BNR0]AMTBNQ(nolign)   = 0
[M:BNR0]AMTBNQD(nolign)  = 0
[M:BNR0]AMTBNQT(nolign)  = 0
[M:BNR0]AMTBNQDT(nolign) = 0

# Case #1 Bank Currency = Ledger Currency
If [M]CUR = [M]CURLED

  [M]BANCUR(nolign) = [F:DAE]CUR
  [M]AMTLED(nolign) = [F:DAE]AMTCUR
  If [F:DAE]SNS=1                   # Deposit
    [M]SNS(nolign)    = 1
    [M]SNS2(nolign)   = "D"
    If [F:DAE]AMTFLG <> 0
      [M]AMTBNQD(nolign) = [F:DAE]AMTLED1
    Else
      [M]AMTBNQD(nolign) = [F:DAE]AMTLED
    Endif
    # These amounts are for sorting, they are not split into deposits and withdrawals.  Just positive and negative.
    [M]AMTBNQT(nolign) = [M]AMTBNQD(nolign)
    [M]AMTBNQDT(nolign) = -[M]AMTBNQD(nolign)

  Else                              # Withdrawal
    [M]SNS(nolign)    = 2
    [M]SNS2(nolign)   = "C"
    If [F:DAE]AMTFLG <> 0
      [M]AMTBNQ(nolign) = [F:DAE]AMTLED1
    Else
      [M]AMTBNQ(nolign) = [F:DAE]AMTLED
    Endif

    # These amounts are for sorting, they are not split into deposits and withdrawals.  Just positive and negative.
    [M]AMTBNQT(nolign) = [M]AMTBNQ(nolign)
    [M]AMTBNQDT(nolign) = -[M]AMTBNQ(nolign)

  Endif

# Case #2 Bank Currency <> Ledger Currency
Else
  [M]BANCUR(nolign) = [M]CURLED
  If [F:DAE]AMTFLG <> 0
    [M]AMTLED(nolign) = [F:DAE]AMTLED1
  Else
    [M]AMTLED(nolign) = [F:DAE]AMTLED
  Endif
  If [F:DAE]SNS=1                   # Deposit
    [M]SNS(nolign)     = 1
    [M]SNS2(nolign)    = "D"
    [M]AMTBNQD(nolign) = [F:DAE]AMTCUR
  Else                              # Withdrawal
    [M]SNS(nolign)    = 2
    [M]SNS2(nolign)   = "C"
    [M]AMTBNQ(nolign) = [F:DAE]AMTCUR
  Endif
  # These amounts are for sorting, they are not split into deposits and withdrawals.  Just positive and negative.
    [M]AMTBNQT(nolign) = [F:DAE]AMTCUR
    [M]AMTBNQDT(nolign) = -[F:DAE]AMTCUR

  Endif

Return
######################################################################################
$CTL
OK = 1
Read [HAE]HAE0 = [F:DAE]TYP; [F:DAE]NUM
If fstat : OK = 0 : Return : Endif
If [F:HAE]CAT <> 1 | [F:HAE]FLGREP = 2  : OK = 0 : Return : Endif
If [F:HAE]REFINT = "CNVEC" : OK = 0 : Return : Endif
If [F:HAE]ACCDAT > [M]BNKDAT : OK = 0 : Return : Endif
If [M]CUR <> [M]CURLED and [F:DAE]CUR = [M]CURLED : OK = 0 : Return : Endif
If [F:DAE]AMTCUR = 0    : OK = 0 : Return : Endif
#Issue 74113 – 2018-02-16 by MADOR - Adjustments driven from the FIFRC automatic journal
If left$([F:HAE]REFINT, 4) = "FIFO" : OK = 0 : Return : Endif
#Issue end
Return
######################################################################################
$CLEANUP

SYMBCHK ="AUTCHK"+"\"+[M]BAN
Unlock =SYMBCHK
Call DEBTRANS From GLOCK
Trbegin [HAE]
 Call DELOCK("HAE") From GLOCK
Commit

Kill GADJREA
Kill GAMTDESC

Return
######################################################################################
$APRES_MODIF

Case COUZON

 When "BAN"
  Read [BAN]BAN0 = CZ
  Gosub LECTURE
  Raz [M]BNKDAT
  Affzo [M]BNKDAT
  Effzo [M]15
  Effzo [M]20
  If VERROU : mkstat = 2 : Endif

 When "MRK", "VALDAT", "BANDAT"
  If REP = "" : REP = "M" : Endif
  Grizo [M]BAN
  Grizo [M]BNKDAT
  [M]CHGDAT(nolign-1)=1

 When "RBKDES", "ENDSTMT", "MRKCHRS"
    If REP = "" : REP = "M" : Endif
    Grizo [M]BAN
    If COUZON = "ENDSTMT"
        zonsui = "[M]RBKDES"
    Endif

 When "BNKDAT"
   Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,CZ,[M]BLC) From SUBCHK
   If [M]SNSBLC = 2
     [M]BLC = -1 * [M]BLC
   Endif
   Affzo [M]BLC
   Call D_SNSBLC2([M]SNSBLC2) From SUBBNR :   Affzo [M]SNSBLC2
   [M]BNKDAT = CZ
   Call CALC_OUTSTANDING()
   Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)
   If not JUSTBNR
     Gosub SEARCH_DISPLAY
   Elsif [M]RBKNUM <> ""
     REP = "M"
     Grizo [M]BAN
   Endif

 When "RBKNUM"
    CURBNR = CZ
    Read [F:BEH]BEH0=CURBNR
    Gosub GET_BNR

Endcase
OK = 1
Return
######################################################################################
$SAVE_UPDATE

Call DEBTRANS From GLOCK
Trbegin [DAE], [HAE]

# Update Bank Reconciliation Header
GCLE = [M]RBKNUM
Read [F:BEH]BEH0 = [M]RBKNUM
If fstat = 0
  [F:BEH] = [M]

  # Only store these for reference on a Closed Bank Rec
  If [F:BEH]STAFLG < 3
    [F:BEH]OUTDEP = 0
    [F:BEH]OUTWTH = 0
    [F:BEH]BLC = 0
  Endif

  [F:BEH]UPDDAT = date$
  [F:BEH]UPDUSR = GUSER
  If [F:BEH]BNKDAT = [00/00/00]
    [F:BEH]BNKDAT = date$
  Endif
  Rewrite [F:BEH]
  If fstat
    GOK = 0 : Call FSTA("BEH") From GLOCK : Goto ROLL_SAVE_UPDATE
  Endif
Else
    GOK = 0 : Call RSTA("BEH", GCLE) From GLOCK : Goto ROLL_SAVE_UPDATE
Endif

For NOL = 0 To [M]NBLIG-1

  # Update Accounting Document and Lines
  If [M]CHGDAT(NOL)<>0
    GCLE = num$([M]ACCNUM(NOL))
    Readlock [DAE]DAE2 = [M]ACCNUM(NOL)
    If fstat=1
      GOK = -1 : GLOCK = "$GACCENTRYD"-GCLE : Break
    Elsif fstat
      GOK = 0 : Call RSTA("DAE",GCLE) From GLOCK
    Elsif !fstat
      If [F:DAE]CHK <> [M]CHK(NOL)
        [F:DAE]CHK    = [M]CHK(NOL)
        [F:DAE]CHKDAT = date$
        Rewrite [DAE]
        If fstat
          GOK = 0 : Call FSTA("DAE") From GLOCK : Break
        Endif
      Endif
      GCLE = [F:DAE]TYP-[F:DAE]NUM
      Readlock [HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
      If fstat=1
        GOK = -1 : GLOCK = "$GACCENTRY"-GCLE : Break
      Elsif fstat
        GOK = 0 : Call RSTA("HAE",GCLE) From GLOCK
      Elsif !fstat
        If [F:HAE]VALDAT <> [M]VALDAT(NOL) or (KIAOK and [F:HAE]BANDAT <> [M]BANDAT(NOL))
          [F:HAE]VALDAT = [M]VALDAT(NOL)
          If KIAOK : [F:HAE]BANDAT = [M]BANDAT(NOL) : Endif
          Rewrite [HAE]
          If fstat
            GOK = 0 : Call FSTA("HAE") From GLOCK : Break
          Endif
        Endif
        If GOK<1 : Break : Endif

        # If marked, then see if the Bank Rec Line exists, if not, create it
        If [M]MRK(NOL) = 2
          Read [F:BED]BED0=[F:BEH]RBKNUM;[M]ACCNUM(NOL)
          If fstat
            Raz [F:BED]
            [F:BED]RBKNUM = [F:BEH]RBKNUM
            [F:BED]ACCNUM = [M]ACCNUM(NOL)
            [F:BED]CREDAT = date$
            [F:BED]CREUSR = GUSER
            Write [F:BED]
            If fstat
              GOK = 0 : Call FSTA("BED") From GLOCK : Break
            Endif
          Endif
        Else
          # Delete the Bank Rec Line if it exists
          Read [F:BED]BED0=[F:BEH]RBKNUM;[M]ACCNUM(NOL)
          If !fstat
            Delete [F:BED]
            If fstat
              GOK = 0 : Call FSTA("BED") From GLOCK : Break
            Endif
          Endif
        Endif
        [M]CHGDAT(NOL)=0
      Endif
    Endif

  Endif

Next NOL

$ROLL_SAVE_UPDATE
If GOK < 1 : Rollback : Return : Endif

Commit

OK = 1
REP = ""
GREP = ""
Return
######################################################################################
$GET_BNR

  Local Char THEBANK

  FIRACCNUM = 0
  FIRACCDAT = [00/00/00]

  If CURBNR <> ""

    [M]RBKNUM = CURBNR
    [M]BNKDAT = [F:BEH]BNKDAT
    [M]MRKCHRS = [F:BEH]MRKCHRS
    [M]RBKDES = [F:BEH]RBKDES

    # Handle Bank
    Read [F:BAN]BAN0 = [F:BEH]BAN
    THEBANK = [F:BEH]BAN
    Call C_BAN(THEBANK)
    Call AM_BAN(THEBANK)
    Gosub LECTURE

    Effzo [M]20

    [M]STAFLG  = [F:BEH]STAFLG
    [M]ENDSTMT = [F:BEH]ENDSTMT
    [M]DEBREC  = [F:BEH]DEBREC
    [M]CRDREC  = [F:BEH]CRDREC

    If [M]STAFLG = 3
      [M]OUTDEP  = [F:BEH]OUTDEP
      [M]OUTWTH  = [F:BEH]OUTWTH
      [M]BLC     = [F:BEH]BLC
    Else
      # Calculate Book Balance as of Statement Date
      Call SOLDEBAL([M]CUR,[M]CPY,[M]FCY,[M]BANACC,[M]BANBPR,[M]SNSBLC,[M]BNKDAT,[M]BLC) From SUBCHK
      If [M]SNSBLC = 2
        [M]BLC = -1 * [M]BLC
      Endif
      Affzo [M]BLC
      Actzo [M]RBKDES, ENDSTMT
      Actzo [M]20
    Endif

    JUSTBNR = 1

    Gosub DISPLAY_BNR
    If [M]STAFLG < 3  : Call CALC_OUTSTANDING() : Endif     #87965 - only for ones that are not closed
    Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)

  Else
    Raz [M]RBKDES, STAFLG, ENDSTMT
    Raz [M]DEBREC, [M]CRDREC, [M]MRKCHRS, [M]ADJBAL, [M]RBKNUM
    Affzo [M]1-42
    Gosub SEARCH_DISPLAY
  Endif

Return
######################################################################################
$ABANDON

#Abandon the modification

Raz [M]DEBREC, CRDREC
If JUSTBNR
  CURBNR = [M]RBKNUM
  Gosub GET_BNR
Elsif [M]NBLIG > 0 and REP <> "C"
  Gosub SEARCH_DISPLAY
Else
  Unlock ="AUTCHK"+"\"+[M]BAN
  Raz [M]
  Grizo [M]
  Actzo [M]RBKNUM
  Affzo [M]
Endif
REP = ""
GREP = ""

Return
######################################################################################
$FIN
Gosub CLEANUP
Return
######################################################################################
$ADJUSTMENT

Local Integer FLGEXE
Local Char    PARBOUT(250)(1..20)
Local Char    SAVACT(GLONACT)

SAVACT = GACTION

# Put adjustment reason in a Global variable
GADJREA = [M:BNR2]TADJREA

# Tunnel to GL Entry
GTUNCPT(16)=1   # This lets GL Entry know it is being called from Bank Rec

PARBOUT(1) = ""
PARBOUT(2) = "GAS"
PARBOUT(3) = ""
FLGEXE = 1
GACTION = "GOBJETC"
Call OBJET_CHAR(PARBOUT(1),PARBOUT(2),PARBOUT(3)) From GOBJET
GACTION = SAVACT

GOK = 1

# If records were created in Journal entry for the Bank Rec, make sure we mark the GACCENTRYD records so they will not be available
Trbegin [DAE]
For [F:BED] Where RBKNUM = [F:BEH]RBKNUM

    Read [F:DAE]DAE2=[F:BED]ACCNUM

    If fstat = 0 and [F:DAE]CHK = ""
        [F:DAE]CHK    = [M]MRKCHRS
        [F:DAE]CHKDAT = date$
        Rewrite [DAE]
        If fstat
            Call FSTA("DAE") From GLOCK
            GOK = 0
            Break
        Endif
    Endif

Next

If GOK : Commit : Else : Rollback : Endif

# Refresh screen to display any newly created records
If JUSTBNR
  Gosub DISPLAY_BNR
Else
  Gosub SEARCH_DISPLAY
Endif

Gosub UPDATE_TOTALS

GTUNCPT(16)=0
Return

######################################################################################
$CLOSE_BNR

If [M]RBKNUM <> "" and [M]STAFLG < 3
  Trbegin [F:BEH]
  Read [F:BEH]BEH0 = [M]RBKNUM
  If fstat = 0
    [M]STAFLG = 3
    [F:BEH]STAFLG = [M]STAFLG
    [F:BEH]OUTDEP = [M]OUTDEP
    [F:BEH]OUTWTH = [M]OUTWTH
    [F:BEH]BLC    = [M]BLC
    Rewrite [F:BEH]
    If fstat
      GOK=0 : Call FSTA("BEH") From GLOCK
    Else
      # Mark any associated checks as cleared
      For NOL=0 To [M]NBLIG-1
        If [M]MRK(NOL)=2
          Read [DAE]DAE2=[M]ACCNUM(NOL)
          If !fstat
            Gosub CLEAR_CHN From CHKLIB
          Endif
        Endif
      Next
    Endif
  Endif
  If GOK : Commit : Else : Rollback : Endif
  Affzo [M]STAFLG
Endif

Return

######################################################################################
$REOPEN_BNR

If [M]RBKNUM <> "" and [M]STAFLG = 3

  Trbegin [F:BEH]
  Read [F:BEH]BEH0 = [M]RBKNUM
  If fstat = 0
    [M]STAFLG = 2
    [F:BEH]STAFLG = [M]STAFLG
    Rewrite [F:BEH]
    If fstat
      GOK=0 : Call FSTA("BEH") From GLOCK
    Else
      # Mark any associated checks as cleared
      For NOL=0 To [M]NBLIG-1
        If [M]MRK(NOL)=2
          Read [DAE]DAE2=[M]ACCNUM(NOL)
          If !fstat
            Gosub REVERSE_CHN From CHKLIB
          Endif
        Endif
      Next
    Endif
  Endif
  If GOK : Commit : Else : Rollback : Endif

  Affzo [M]STAFLG

  Gosub UPDATE_TOTALS

Endif

Return
######################################################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()

Call ACCES_POINTAGE(GOK,VALEUR) From SUBCHK
If !GOK
  GMESSAGE = mess(25,120,1)-" "-VALEUR : # User does not have access to Bank
  mkstat = 2
  End
Endif

End
######################################################################################
Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()

If [M]BAN <> ""
  Unlock ="AUTCHK"+"\"+[M]BAN
Endif

Lock ="AUTCHK"+"\"+VALEUR
If fstat
  GMESSAGE = mess(23,120,1) : # Account in Reconciliation
  mkstat = 2
  End
Endif

End
######################################################################################
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
  Call BANDEF(VALEUR)
Endif

End
######################################################################################
Subprog D_SNSBLC2(VALEUR)
Variable Char    VALEUR()

If [M]SNSBLC=1
  VALEUR = "D"
Else
  VALEUR = "C"
Endif

End
######################################################################################
Subprog IB_NBLIG

GBOUT1 = mess(145,117,1)  :# Accounting Journal

# If it is a payment, enable zoom
Raz GBOUT4
Read [HAE]HAE0 = [M]TYP(nolign-1);[M]NUM(nolign-1)
If fstat = 0 and left$([F:HAE]REFINT,3)="PYH"

  GBIDC1 = vireblc(right$([F:HAE]REFINT,4),2)

  Read [PYH]PYH0 = GBIDC1
  If !fstat
    GFLAG = [F:PYH]PAYTYP
    GBOUT4 = mess(47,109,1) #Payment
  Endif

Endif

End
######################################################################################
Subprog AM_MRK(VALEUR)
Variable Integer    VALEUR
Local Decimal MNT, THEAMT
Local Integer NOL : NOL = nolign-1
Local Integer TSIGN

# Reread
Read [DAE]DAE2=[M]ACCNUM(NOL)
If fstat
  # Entry does not exist
  GMESSAGE = mess(33,110,1)
  mkstat=1 : End
Endif

TSIGN = 1
[M]CHK(NOL) = [M]MRKCHRS

If VALEUR = 1 and [M]MRK(NOL) = 2
  TSIGN = -1  # The user unchecked the line, so take away from running totals
  [M]CHK(NOL) = ""
Endif

If [M]SNS(NOL) = 1
  [M]DEBREC = [M]DEBREC + TSIGN * [M:BNR0]AMTBNQD(NOL)
  [M]OUTDEP = [M]OUTDEP - TSIGN * [M:BNR0]AMTBNQD(NOL)
  Affzo [M]DEBREC, OUTDEP
Else
  [M]CRDREC = [M]CRDREC + TSIGN * [M:BNR0]AMTBNQ(NOL)
  [M]OUTWTH = [M]OUTWTH - TSIGN * [M:BNR0]AMTBNQ(NOL)
  Affzo [M]CRDREC, OUTWTH
Endif

Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)

End
######################################################################################
Subprog GET_AMT(IACCDAT, IAMTLED, IAMTBNQ, ISIGN, OAMT)
Value Date    IACCDAT
Value Decimal IAMTLED
Value Decimal IAMTBNQ
Value Integer ISIGN
Variable Decimal OAMT

Local Integer STAT

Case [M]CUR
  When [M]CURLED      : OAMT = ISIGN * IAMTLED
  When [F:DAE]CUR     : OAMT = ISIGN * IAMTBNQ
  When Default  :
    Call CONVERT([M]CURLED,[M]CUR,[M]CURLED,1,IACCDAT,IAMTLED,OAMT,STAT) From TRTDEV
    OAMT = ISIGN * OAMT
Endcase

End
######################################################################################
Subprog BANDEF(BANK)
Variable Char    BANK()

If GBANDEF=""
 If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
 Read [AUS]CODUSR = GPROFIL
 Call PARAMUTIL("BANKDEF",BANK,"","") From SUBAUS
Else
 BANK = GBANDEF
Endif

If BANK <> ""
  Lock ="AUTCHK"+"\"+BANK
  If fstat
    BANK = ""
  Endif
Endif

End
######################################################################################
Subprog AP_ENDSTMT(VALEUR)
Variable Decimal VALEUR

Call CALC_BALVAR(VALEUR,[M]OUTDEP,[M]OUTWTH,[M]BLC)

End
######################################################################################
Subprog CALC_BALVAR(IENDSTMT, IOUTDEP, IOUTWTH, IBOOKBAL)
Value Decimal IENDSTMT, IOUTDEP, IOUTWTH, IBOOKBAL

[M]ADJBAL = IENDSTMT + IOUTDEP - IOUTWTH
[M]STMTVAR = [M]ADJBAL - IBOOKBAL
Affzo [M]ADJBAL, STMTVAR

End
######################################################################################
Subprog CALC_OUTSTANDING()

Local Decimal THEAMT, TAMTLED
Local Integer OK

[M]OUTDEP = 0
[M]OUTWTH = 0
For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""

  Raz OK
  If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
    Gosub CTL
  Endif
  If OK
    If [F:DAE]AMTFLG <> 0
      TAMTLED = [F:DAE]AMTLED1
    Else
      TAMTLED = [F:DAE]AMTLED
    Endif

    # Get the correct currency amount
    Call GET_AMT([F:DAE]ACCDAT,TAMTLED,[F:DAE]AMTCUR,1,THEAMT)

    If [F:DAE]SNS=1
      [M]OUTDEP += THEAMT
    Else
      [M]OUTWTH += THEAMT
    Endif
  Endif
Next

Affzo [M]OUTDEP, OUTWTH
End
#######################################################################################
Subprog C_RBKNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> ""
    Read [F:BEH]BEH0 = VALEUR
    If fstat
      GMESSAGE = mess(23,100,1)  : mkstat = 2 : End
    Endif
    #91546.sn
    Call ACCES_POINTAGE(GOK,[F:BEH]BAN) From SUBCHK
    If !GOK
      GMESSAGE = mess(25,120,1)-" "-[F:BEH]BAN : # User does not have access to Bank
      mkstat = 2
      End
    Endif
    #91546.en
  Endif

End
######################################################################################
Subprog AM_RBKNUM(VALEUR)
Variable Char    VALEUR()


End

######################################################################################
Subprog B2_NBLIG

# Yes to all the rest
Local Integer I
Local Decimal THEAMT

For I=nolign To [M]NBLIG

  If [M]MRK(I-1) <> 2
    [M]MRK(I-1) = 2
    [M]CHK(I-1) = [M]MRKCHRS
    [M]MRKT(I-1) = 1
    [M]CHGDAT(I-1) = 1

    # Calc Reconciliations
    If [M]SNS(I-1) = 1
      [M]DEBREC += [M]AMTBNQD(I-1)
      [M]OUTDEP -= [M]AMTBNQD(I-1)
    Else
      [M]CRDREC += [M]AMTBNQ(I-1)
      [M]OUTWTH -= [M]AMTBNQ(I-1)
    Endif

  Endif

Next I

Affzo [M]MRK, DEBREC, CRDREC, OUTDEP, OUTWTH
Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)
mkstat = 4
GREP = "M"
End

######################################################################################
Subprog B3_NBLIG

# No to all the rest
Local Integer I
Local Decimal THEAMT

For I=nolign To [M]NBLIG

  If [M]MRK(I-1) = 2
    [M]MRK(I-1) = 1
    [M]CHK(I-1) = ""
    [M]MRKT(I-1) = 2
    [M]CHGDAT(I-1) = 1

    # Calc Reconciliations
    If [M]SNS(I-1) = 1
      [M]DEBREC -= [M]AMTBNQD(I-1)
      [M]OUTDEP += [M]AMTBNQD(I-1)
    Else
      [M]CRDREC -= [M]AMTBNQ(I-1)
      [M]OUTWTH += [M]AMTBNQ(I-1)
    Endif

  Endif
Next I

Affzo [M]MRK, DEBREC, CRDREC, OUTDEP, OUTWTH
Call CALC_BALVAR([M]ENDSTMT,[M]OUTDEP,[M]OUTWTH,[M]BLC)
mkstat = 4
GREP = "M"

End

######################################################################################
Subprog AM_CACCDATDEB(VALEUR)
Variable Date    VALEUR

  [M]CACCDATFIN = VALEUR

End
######################################################################################
Subprog AM_CNUMDEB(VALEUR)
Variable Char    VALEUR()

  [M]CNUMFIN = VALEUR + left$("zzzzzzzzzzzzzzzzzzzz", 20 - len(VALEUR))

End
######################################################################################
Funprog COUNT_SEARCH_RECS(JUSTBNR)
Value Integer JUSTBNR                #88201.n
Local Integer NUMRECS
Local Integer OK                     #90865.n

NUMRECS = 0
If not JUSTBNR
  For [DAE]DAE3 Where LEDTYP=GTYPGEN & CPY=[M]CPY & ACC=[M]BANACC & BPR=[M]BANBPR & CHK=""
    Raz OK
    If ([F:DAE]BPR="" | [F:DAE]BPR=[M]BANBPR) & ([M]FCY="" | [M]FCY=[F:DAE]FCYLIN)
      Gosub CTL
    Endif
    If OK
      NUMRECS += 1
    Endif
  Next
Endif

End NUMRECS

######################################################################################
# Count the Bank Rec Records
Funprog COUNT_BNR_RECS()

Local Integer NUMRECS

If [M]RBKNUM <> ""
    Filter [F:BED] Where RBKNUM = [M]RBKNUM
    For [F:BED]
      NUMRECS+=1
    Next
    Filter [F:BED]
Endif

End NUMRECS


