#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Structure TABCOUNTRY
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
     When "AINSERT_CONTROL_BEFORE"        : Gosub AINSERT_CONTROL_BEFORE
     When "AINSERT_BEFORE"                : Gosub AINSERT_BEFORE
     When "AUPDATE_CONTROL_BEFORE"        : Gosub AINSERT_CONTROL_BEFORE
     When "AUPDATE_BEFORE"                : Gosub AUPDATE_BEFORE
     When "AREAD_AFTER"                   : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding  on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the  code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CRY"       : Gosub CRY
  When "EECFLG"    : Gosub EECFLG
  When "CUR"       : Gosub CUR
  When "CRYVATNUM" : Gosub CRYVATNUM
  When "ADRNUMFMT" : Gosub ADRNUMFMT
  When "POSCODFMT" : Gosub POSCODFMT
  When "CTYNUMFMT" : Gosub CTYNUMFMT
  When "TELFMT"    : Gosub TELFMT
  When "ETATFLG"   : Gosub ETATFLG
  When "ETATFLG2"  : Gosub ETATFLG2
  When "ETATFMT"   : Gosub ETATFMT
  When "ETATFMT2"  : Gosub ETATFMT2
  When "ETAT"      : Gosub ETAT
  When "CRNFMT"    : Gosub CRNFMT
  When "NAFFMT"    : Gosub NAFFMT
  When "BIDFMT"    : Gosub BIDFMT
  When "PABFMT"    : Gosub PABFMT
  When "SOCNUMFMT" : Gosub SOCNUMFMT
  When "SOCNUMFMT2": Gosub SOCNUMFMT2
  When "SOCNUMFLG1": Gosub SOCNUMFLG1
  When "SOCNUMFLG2": Gosub SOCNUMFLG2
  When "EMPNUMFMT" : Gosub EMPNUMFMT
  When "POSCODCTL" : Gosub POSCODCTL
  When "BIDCTL"    : Gosub BIDCTL
  When "CRNFMTFLG" : Gosub CRNFMTFLG
  When "NIDFMTFLG" : Gosub NIDFMTFLG
  When "EECFMTFLG" : Gosub EECFMTFLG
  When "NAFFMTFLG" : Gosub NAFFMTFLG
  When "CRTFMTFLG" : Gosub CRTFMTFLG
  When "ISO"       : Gosub ISO
  When "TELTCY"    : Gosub TELTCY
  When "TELREG"    : Gosub TELREG
  When "MINZIP"    : Gosub MINZIP
  When "CTLPRG"    : Gosub CTLPRG
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





##########################################################################################################
$AINSERT_CONTROL_BEFORE
# Initialisation des formats CP et RIB pour Crystal Report
Call FMTREPORT(this.POSCODFMT,this.POSCODCRY)
Call FMTREPORT(this.BIDFMT,this.BIDCRY)
Gosub CONTROLS
Gosub MANDATORIES
Gosub SYNCHRONIZE_PROPERTIES
Return

##########################################################################################################
$AUPDATE_CONTROL_BEFORE
# Initialisation des formats CP et RIB pour Crystal Report
Call FMTREPORT(this.POSCODFMT,this.POSCODCRY)
Call FMTREPORT(this.BIDFMT,this.BIDCRY)
Gosub CONTROLS
Gosub MANDATORIES
Gosub SYNCHRONIZE_PROPERTIES
Return

##########################################################################################################
$AREAD_AFTER
Gosub TRANS_COLUMN_CLASS
Gosub MANDATORIES
Return

##########################################################################################################
$AINSERT_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

##########################################################################################################
$AUPDATE_BEFORE
Gosub TRANS_CLASS_COLUMN
Return

##########################################################################################################
$CONTROLS
If this.FLIBAN=[V]CST_AYES and this.ISO=AVOID.ACHAR
# To manage the IBAN code, enter an ISO code
  [L]ASTATUS = fmet this.ASETERROR("FLIBAN", mess(8,143,1),[V]CST_AERROR)
Endif

If this.EECFLG=[V]CST_AYES and this.FLGSEPA<>[V]CST_AYES
  # A country belonging to the EU necessarily belongs to the SEPA area
 [L]ASTATUS = fmet this.ASETERROR("FLGSEPA", mess(69,143,1),[V]CST_AERROR)
Endif

If this.TELREG<>AVOID.ACHAR & this.TELREG=this.TELTCY
  # The position of the country must be different from that of the region
  [L]ASTATUS = fmet this.ASETERROR("TELREG", this.TELREG-":"-mess(63,143,1),[V]CST_AERROR)
Endif

Gosub CTLPRG_EXISTS

Return

##########################################################################################################
$SYNCHRONIZE_PROPERTIES
If this.EECFLG<>[V]CST_AYES
  this.EECDAT = AVOID.ADATE
  this.CRYVATNUM = AVOID.ACHAR
Endif
If this.ETATFLG<>[V]CST_AYES
  this.ETATFMT = num$(GLONSAT)+"X"
  this.ETATNAM = AVOID.ACHAR
Endif
If this.POSCODCTL<>[V]CST_AYES
  this.CTYNUMFMT = "5B"
Endif
If this.BIDCTL<>[V]CST_AYES
  this.BANLNG= 0
Endif
If this.CRNFMTFLG<>[V]CST_AYES
  this.CRNFMT = "10X"
Endif
If this.NIDFMTFLG<>[V]CST_AYES
  this.NIDFMT = "10X"
Endif
If this.EECFMTFLG<>[V]CST_AYES
  this.EECFMT = "10X"
Endif
If this.NAFFMTFLG<>[V]CST_AYES
  this.NAFFMT= "10X"
Endif
If this.CRTFMTFLG<>[V]CST_AYES
  this.CRTFMT= "10X"
Endif
If this.CRNFMTFLG<>[V]CST_AYES or this.NIDFMTFLG<>[V]CST_AYES or this.EECFMTFLG<>[V]CST_AYES
  this.CRNOBL = [V]CST_ANO
Endif

If dim(this.SOCNUMFLG1)>0
 If this.SOCNUMFLG1<>[V]CST_AYES
   this.SOCNUMFMT= AVOID.ACHAR
 Endif
Endif

If dim(this.SOCNUMFLG2)>0
 If this.SOCNUMFLG2<>[V]CST_AYES
   this.SOCNUMFMT2= AVOID.ACHAR
 Endif
Endif
Return

##########################################################################################################
$MANDATORIES
Gosub MANDATORY_BIDCTL
Gosub MANDATORY_SOCNUMFLG1
Gosub MANDATORY_SOCNUMFLG2
Return

##########################################################################################################
$MANDATORY_BIDCTL
If this.BIDCTL=[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BANLNG","$isMandatory","true")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("BANLNG","$isMandatory","false")
Endif
Return

##########################################################################################################
$MANDATORY_SOCNUMFLG1
If dim(this.SOCNUMFLG1)>0
  If this.SOCNUMFLG1=[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT","$isMandatory","true")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT","$isMandatory","false")
  Endif
Elsif dim(this.SOCNUMFMT)>0
  [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT","$isMandatory","true")
Endif
Return

##########################################################################################################
$MANDATORY_SOCNUMFLG2
If dim(this.SOCNUMFLG2)>0
  If this.SOCNUMFLG2=[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT2","$isMandatory","true")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("SOCNUMFMT2","$isMandatory","false")
  Endif
Endif
Return

##########################################################################################################
$TRANS_CLASS_COLUMN
#address label lines
If clalev([F:TCY])<=0 : Return : Endif
[F:TCY]ADRNAM(0)=this.ADRNAM1
[F:TCY]ADRNAM(1)=this.ADRNAM2
[F:TCY]ADRNAM(2)=this.ADRNAM3
Return

##########################################################################################################
$TRANS_COLUMN_CLASS
#address label lines
Local File TABCOUNTRY [TCY]
Read [F:TCY]TCY0=this.CRY
#If dim(this.ADRNAM1)>0
 this.ADRNAM1=[F:TCY]ADRNAM(0)
 this.ADRNAM2=[F:TCY]ADRNAM(1)
 this.ADRNAM3=[F:TCY]ADRNAM(2)
#Endif
Return

##########################################################################################################
$CRY
Case [L]ARULE
  When "INIT"          : this.CRY=AVOID.ACHAR
Endcase
Return

##########################################################################################################
$CUR
 Case [L]ARULE
   When "PROPAGATE"     : Gosub CUR_PROPAGATE
Endcase
Return

$CUR_PROPAGATE
If this.CUR<>AVOID.ACHAR
  If this.EECFLG=[V]CST_AYES
    If  this.CRYVATNUM=AVOID.ACHAR
        this.CRYVATNUM=left$(this.CUR,2)
      Endif
    Endif
Endif
Return

##########################################################################################################
$EECFLG
Case [L]ARULE
  When "PROPAGATE"         : Gosub EECFLG_PROPAGATE
Endcase
Return

$EECFLG_PROPAGATE
If this.EECFLG<>[V]CST_AYES
  this.EECDAT = AVOID.ADATE
  this.CRYVATNUM=AVOID.ACHAR
Else
  If this.CUR<>AVOID.ACHAR
    this.CRYVATNUM=left$(this.CUR,2)
  Endif
  this.FLGSEPA = [V]CST_AYES
  If dim(this.GSPFLG)>=0 : this.GSPFLG = [V]CST_ANO :Endif :#X3-58867
Endif
Return

##########################################################################################################
$CRYVATNUM
 Case [L]ARULE
   When "INIT"            : Gosub CRYVATNUM_INIT
 Endcase
Return

$CRYVATNUM_INIT
If this.CUR<>AVOID.ACHAR
  If this.EECFLG=[V]CST_AYES
    this.CRYVATNUM=left$(this.CUR,2)
  Else
    this.CRYVATNUM = AVOID.ACHAR
  Endif
Endif

##########################################################################################################
$ADRNUMFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub ADRNUMFMT_CONTROL
 Endcase
Return

$ADRNUMFMT_CONTROL
If  func FORMA(this,CURPRO,this.ADRNUMFMT,GLONADL)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$POSCODFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub POSCODFMT_CONTROL
Endcase
Return

$POSCODFMT_CONTROL
If  func FORMA(this,CURPRO,this.POSCODFMT,GLONPOS)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$CTYNUMFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub CTYNUMFMT_CONTROL
Endcase
Return

$CTYNUMFMT_CONTROL
If  func FORMA(this,CURPRO,this.CTYNUMFMT,GLONCTY)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$TELFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub TELFMT_CONTROL
Endcase
Return

$TELFMT_CONTROL
If  func FORMA(this,CURPRO,this.TELFMT,GLONTEL)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$ETATFLG
 Case [L]ARULE
   When "PROPAGATE"     : Gosub  ETATFLG_PROPAGATE
 Endcase
Return

$ETATFLG_PROPAGATE
 If this.ETATFLG<>[V]CST_AYES
   this.ETATFMT = num$(GLONSAT)+"X"
   this.ETATNAM = AVOID.ACHAR
   If this.ETAT = 2         # subdivision 1
    this.ETAT=1
   Endif
 Endif

 Return
 ##########################################################################################################
$ETATFLG2
 Case [L]ARULE
   When "PROPAGATE"         : Gosub ETATFLG2_PROPAGATE
Endcase
Return

$ETATFLG2_PROPAGATE
If this.ETATFLG2<>[V]CST_AYES
  this.ETATFMT2 = num$(GLONSAT)+"X"
  this.ETATNAM2 = AVOID.ACHAR
  If this.ETAT = 3         # subdivision 2
    this.ETAT=1
  Endif
Endif
Return

##########################################################################################################
$ETATFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub ETATFMT_CONTROL
Endcase
Return

$ETATFMT_CONTROL
If  func FORMA(this,CURPRO,this.ETATFMT,GLONSAT)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$ETATFMT2
 Case [L]ARULE
   When "CONTROL"         : Gosub ETATFMT2_CONTROL
Endcase
Return

$ETATFMT2_CONTROL
If  func FORMA(this,CURPRO,this.ETATFMT2,GLONSAT)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$ETAT
  Case [L]ARULE
    When "CONTROL"          :  Gosub ETAT_CONTROL
    When "PROPAGATE"        :  Gosub ETAT_PROPAGATE
  Endcase
Return

$ETAT_CONTROL
If this.ETATFLG<>[V]CST_AYES
  If this.ETAT = 2          # Subdivision 1
    [L]ASTATUS = fmet this.ASETERROR("ETAT",mess(2,7831,1)-mess(83,123,1),[V]CST_AERROR)
  Endif
Endif

If this.ETATFLG2<>[V]CST_AYES
  If this.ETAT = 3          # Subdivision 2
   [L]ASTATUS = fmet this.ASETERROR("ETAT",mess(3,7831,1)-mess(83,123,1),[V]CST_AERROR)
  Endif
Endif
Return

$ETAT_PROPAGATE
If this.ETAT = 1         # None
  this.ETATCTL = [V]CST_ANO
Endif
Return

##########################################################################################################
$CRNFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub CRNFMT_CONTROL
Endcase
Return

$CRNFMT_CONTROL
If  func FORMA(this,CURPRO,this.CRNFMT,GLONCRN)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$NAFFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub NAFFMT_CONTROL
Endcase
Return

$NAFFMT_CONTROL
If  func FORMA(this,CURPRO,this.NAFFMT,[V]GLONNAF)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return
##########################################################################################################
$BIDFMT
 Case [L]ARULE
     When "CONTROL"         : Gosub BIDFMT_CONTROL
Endcase
Return

$BIDFMT_CONTROL
If  func FORMA(this,CURPRO,this.BIDFMT,GLONBID)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$PABFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub PABFMT_CONTROL
Endcase
Return

$PABFMT_CONTROL
If  func FORMA(this,CURPRO,this.PABFMT,GLONPAB)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$SOCNUMFMT
 Case [L]ARULE
   When "INIT"            : If dim(this.SOCNUMFMT)>0 : this.SOCNUMFMT = AVOID.ACHAR : Endif
   When "CONTROL"         : Gosub SOCNUMFMT_CONTROL
Endcase
Return

$SOCNUMFMT_CONTROL
If dim(this.SOCNUMFMT)>0
 If  func FORMA(this,CURPRO,this.SOCNUMFMT,25)=[V]CST_AFALSE
   [L]ASTATUS= [V]CST_AERROR
 Endif
Endif
Return

##########################################################################################################
$SOCNUMFMT2
 Case [L]ARULE
   When "INIT"           : If dim(this.SOCNUMFMT2)>0 : this.SOCNUMFMT2 = AVOID.ACHAR : Endif
Endcase
Return

##########################################################################################################
$SOCNUMFLG1
 Case [L]ARULE
   When "INIT"            : Gosub SOCNUMFLG1_INIT
   When "PROPAGATE"       : Gosub SOCNUMFLG1_PROPAGATE
Endcase
Return

$SOCNUMFLG1_INIT
If dim(this.SOCNUMFLG1)>0
 this.SOCNUMFLG1 = [V]CST_ANO
 this.SOCNUMFMT  = AVOID.ACHAR
Endif
Gosub MANDATORY_SOCNUMFLG1
Return

$SOCNUMFLG1_PROPAGATE
If dim(this.SOCNUMFLG1)>0 & this.SOCNUMFLG1<>[V]CST_AYES
  this.SOCNUMFMT= AVOID.ACHAR
  Gosub MANDATORY_SOCNUMFLG1
Endif
Return

##########################################################################################################
$SOCNUMFLG2
 Case [L]ARULE
   When "INIT"            : Gosub SOCNUMFLG2_INIT
   When "PROPAGATE"       : Gosub SOCNUMFLG2_PROPAGATE
Endcase
Return

$SOCNUMFLG2_INIT
If dim(this.SOCNUMFLG2)>0
 this.SOCNUMFLG2 = [V]CST_ANO
 this.SOCNUMFMT2 = AVOID.ACHAR
Endif
Gosub MANDATORY_SOCNUMFLG2
Return

$SOCNUMFLG2_PROPAGATE
If dim(this.SOCNUMFLG2)>0 & this.SOCNUMFLG2<>[V]CST_AYES
  this.SOCNUMFMT2= AVOID.ACHAR
Endif
Gosub MANDATORY_SOCNUMFLG2
Return

##########################################################################################################
$EMPNUMFMT
 Case [L]ARULE
   When "CONTROL"         : Gosub EMPNUMFMT_CONTROL
Endcase
Return

$EMPNUMFMT_CONTROL
If  func FORMA(this,CURPRO,this.EMPNUMFMT,10)=[V]CST_AFALSE
  [L]ASTATUS= [V]CST_AERROR
Endif
Return

##########################################################################################################
$CTLPRG
Case [L]ARULE
  When "CONTROL"           : Gosub CTLPRG_CONTROL
Endcase
Return

$CTLPRG_CONTROL
Gosub CTLPRG_EXISTS
Return

##########################################################################################################
$POSCODCTL
 Case [L]ARULE
   When "PROPAGATE"
     If this.POSCODCTL<>[V]CST_AYES
       this.CTYNUMFMT = "5B"
     Endif
Endcase
Return

##########################################################################################################
$BIDCTL
 Case [L]ARULE
   When "PROPAGATE"     : Gosub BIDCTL_PROPAGATE
Endcase
Return

$BIDCTL_PROPAGATE
 If this.BIDCTL<>[V]CST_AYES
   this.BANLNG= 0
 Endif
 Gosub MANDATORY_BIDCTL
 Return

##########################################################################################################
$CRNFMTFLG
Case [L]ARULE
   When "PROPAGATE"             : Gosub CRNFMTFLG_PROPAGATE
Endcase
Return

$CRNFMTFLG_PROPAGATE
 If this.CRNFMTFLG<>[V]CST_AYES
   this.CRNFMT = "10X"
 Endif
 If this.CRNFMTFLG<>[V]CST_AYES or this.NIDFMTFLG<>[V]CST_AYES or this.EECFMTFLG<>[V]CST_AYES
   this.CRNOBL = [V]CST_ANO
 Endif
 Return

##########################################################################################################
$NIDFMTFLG
 Case [L]ARULE
   When "PROPAGATE"           : Gosub NIDFMTFLG_PROPAGATE
Endcase
Return

$NIDFMTFLG_PROPAGATE
 If this.NIDFMTFLG<>[V]CST_AYES
   this.NIDFMT = "10X"
 Endif
 If this.CRNFMTFLG<>[V]CST_AYES or this.NIDFMTFLG<>[V]CST_AYES or this.EECFMTFLG<>[V]CST_AYES
   this.CRNOBL = [V]CST_ANO
 Endif
Return

##########################################################################################################
$EECFMTFLG
Case [L]ARULE
  When "PROPAGATE"          : Gosub EECFMTFLG_PROPAGATE
Endcase
Return

$EECFMTFLG_PROPAGATE
 If this.EECFMTFLG<>[V]CST_AYES
   this.EECFMT = "10X"
 Endif
 If this.CRNFMTFLG<>[V]CST_AYES or this.NIDFMTFLG<>[V]CST_AYES or this.EECFMTFLG<>[V]CST_AYES
   this.CRNOBL = [V]CST_ANO
 Endif
 Return

##########################################################################################################
$NAFFMTFLG
Case [L]ARULE
  When "PROPAGATE"           : Gosub NAFFMTFLG_PROPAGATE
Endcase
Return

$NAFFMTFLG_PROPAGATE
If this.NAFFMTFLG<>[V]CST_AYES
  this.NAFFMT= "10X"
Endif
Return

##########################################################################################################
$CRTFMTFLG
Case [L]ARULE
  When "PROPAGATE"           : Gosub CRTFMTFLG_PROPAGATE
Endcase
Return

$CRTFMTFLG_PROPAGATE
 If this.CRTFMTFLG<>[V]CST_AYES
   this.CRTFMT= "10X"
 Endif
 If this.CRNFMTFLG<>[V]CST_AYES or this.NIDFMTFLG<>[V]CST_AYES or this.EECFMTFLG<>[V]CST_AYES
   this.CRNOBL = [V]CST_ANO
 Endif
 Return

##########################################################################################################
$ISO
Case [L]ARULE
  When "CONTROL"         : Gosub ISO_CONTROL
Endcase

$ISO_CONTROL
 If this.ISO<>AVOID.ACHAR & len(this.ISO)<2
   #Invalid value
   [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(83,123,1),[V]CST_AERROR)
 Endif
Return

##########################################################################################################
$TELTCY
 Case [L]ARULE
   When "CONTROL"         : Gosub TELTCY_CONTROL
Endcase
Return

$TELTCY_CONTROL
Local Char  MESSAGE (250)
If func SET_CTL(this.TELTCY,MESSAGE) = [V]CST_AFALSE
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,MESSAGE,[V]CST_AERROR)
Endif
Return
##########################################################################################################
$TELREG
Case [L]ARULE
   When "CONTROL"           : Gosub TELREG_CONTROL
Endcase
Return

$TELREG_CONTROL
Local Char  MESSAGE (250)
If func SET_CTL(this.TELREG,MESSAGE)=[V]CST_AFALSE
  [L]ASTATUS = fmet this.ASETERROR(CURPRO,MESSAGE,[V]CST_AERROR)
Endif
Return

##########################################################################################################
$MINZIP
Case [L]ARULE
  When "CONTROL"            : Gosub MINZIP_CONTROL
Endcase
Return

$MINZIP_CONTROL
If this.MINZIP>= [V]GLONPOS Then
  [L]ASTATUS = fmet this.ASETERROR(CURPRO, mess(97,143,1) - "(" + num$(GLONPOS) + ")",[V]CST_AERROR)
Endif
Return

##########################################################################################################
$CTLPRG_EXISTS
Local Integer OKTRT
If this.CTLPRG<>AVOID.ACHAR
  Call EXISTE_ADX("","",this.CTLPRG,[L]OKTRT) From ASYRSYS
  If !OKTRT
    # Programme inexistant
    [L]ASTATUS = fmet this.ASETERROR(CURPRO,mess(159,100,1),[V]CST_AERROR)
  Endif
 Endif
 Return

##########################################################################################################
Funprog FORMA(MYFORMA,CURPRO,FMT,LNG)
Variable Instance MYFORMA Using C_TABCOUNTRY
Value    Char    CURPRO()
Value    Char    FMT()
Value    Integer LNG

Local    Integer OK,ASTATUS
OK = [V]CST_ATRUE

If FMT<>AVOID.ACHAR
 Local Decimal L , D , COM
 Local Char    C(1)
 COM = 0 : D = 0
 For I=1 To len(FMT)
  C = mid$(FMT,I,1)
  If C="["
   If COM=0 & D=0 : COM = 1 : Else : OK = [V]CST_AFALSE : Break : Endif
  Elsif C="]"
   If COM=1 & D=0 : COM = 0 : Else : OK = [V]CST_AFALSE : Break : Endif
  Elsif COM=1
   L += 1
  Elsif instr(1,"0123456789",C)
   D = 10*D+val(C)
  Elsif !instr(1,"AaBbCLX#",C)
   ERR = [V]CST_ATRUE : Break
  Else
   If D=0 : L += 1
   Else   : L += D
   Endif
   D = 0
  Endif
 Next I
 If D<>0 or COM=1 : OK = [V]CST_AFALSE : Endif
 If OK = [V]CST_AFALSE
   # format incorrect
   [L]ASTATUS = fmet MYFORMA.ASETERROR(CURPRO,mess(149,100,1),[V]CST_AERROR)
 Elsif L>LNG
   # format too long
   [L]ASTATUS = fmet MYFORMA.ASETERROR(CURPRO,mess(150,100,1)-"(>"+num$(LNG)+")",[V]CST_AERROR)
 Endif
Endif
End OK

##########################################################################################################
Funprog SET_CTL (PROP,MESSAGE)
Value Char PROP
Variable Char MESSAGE
Local Integer K , D , F, OK
OK=[V]CST_ATRUE
If PROP<>AVOID.ACHAR
 K = instr(1,PROP,"-")
 If K>0
  D = val(left$(PROP,K-1))
  F = val(right$(PROP,K+1))
  If D=0 or F=0 or F<D
   K = 0
  Endif
 Endif
 If !K
   # Incorrect expression
   MESSAGE = PROP-":"-mess(37,124,1)
   OK=[V]CST_AFALSE
 Endif
Endif
End OK

##########################################################################################################
Subprog FMTREPORT(FMT1,FMT2)
Value    Char FMT1()
Variable Char FMT2()

Local Integer I, J, L
Local Libelle CMT
Local Char    LETTRE(1)
I = 1 : L = len(FMT1) : FMT2 = AVOID.ACHAR
While I<=L
 LETTRE = mid$(FMT1,I,1)
 If LETTRE="[" & !CMT   : CMT = 1
 Elsif LETTRE="]" & CMT : CMT = 0
 Elsif CMT : FMT2 += LETTRE
 Else
  J = 0
  While instr(1,"0123456789",LETTRE)
   J = J*10+val(LETTRE)
   I += 1 : If I>L : Break : Endif
   LETTRE = mid$(FMT1,I,1)
  Wend
  If !J : FMT2 += "x" : Else : FMT2 += string$(J,"x") : Endif
 Endif
 I += 1
Wend
FMT2 = vireblc(FMT2,1)
End

