#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FBUD","BUDGET","DBUDCRI",4,"") From GTRAITE
End

## Programmes communs à tous les types de budgets

$ACTION
Case ACTION
 When "INIT"      : If BCRIT="DBUDCRI" : Gosub INIT
                    Else                 Gosub INIT From SUBCMM2     : # Zoom Engagement
                    Endif
 When "CONTROLE"  : If BCRIT="DBUDCRI" : Gosub CONTROLE
                    Else                 Gosub CONTROLE From SUBCMM2 : # Zoom Engagement
                    Endif
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "TERMINE"   : If BCRIT="DBUDCRI"
                     If GOK=2 : SAI = 1 : GOK = 1 : Endif : # Bouton critères
                    Endif
 When "SORTIE"    : Gosub SORTIE
 When Default
  Case GBOITE
   When "DBUDCRI" : Gosub FCRIT
   When Default   : Gosub FPRINC
  Endcase
Endcase
Return

########################## ACTIONS COMMUNES #################################
$INIT
Onerrgo ERREUR From CONTROLE
If clalev([F:TBU])=0  : Local File TABBUDTYP   [TBU]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR      [TCU]  : Endif
If clalev([F:BUD])=0  : Local File BUD         [BUD]  : Endif
If clalev([F:BUD2])=0 : Local File BUD         [BUD2] : Endif
If clalev([F:BUD3])=0 : Local File BUD         [BUD3] : Endif
If clalev([F:BUD9])=0 : Local File BUD         [BUD9] : Endif
If clalev([F:BUP])=0  : Local File BUDPAR      [BUP]  : Endif
If clalev([F:BUV])=0  : Local File BUDVER      [BUV]  : Endif
If clalev([F:BUP2])=0 : Local File BUDPAR      [BUP2] : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY]  : Endif
If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY]  : Endif
If clalev([F:PER])=0  : Local File PERIOD      [PER]  : Endif
If clalev([F:ACV])=0  : Local File ACTIV       [ACV]  : Endif
If clalev([F:BLA])=0  : Local File BALANA      [BLA]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON     [ATZ]  : Endif
If clalev([F:DTP])=0  : Local File CADISTMP    [DTP]  : Endif
If clalev([F:GYM])=0  : Local File GACCPYM     [GYM]  : Endif : # Pyramides comptes
If clalev([F:GYK])=0  : Local File GACCPYMLIK  [GYK]  : Endif : # Liens pyramides comptes
If clalev([F:GRY])=0  : Local File GACCGRUPYM  [GRY]  : Endif : # Groupe Pyramides comptes
If clalev([F:GRY2])=0  : Local File GACCGRUPYM  [GRY2] : Endif : # Groupe Pyramides comptes
If clalev([F:CYM])=0  : Local File GCCEPYM     [CYM]  : Endif : # Pyramides sections
If clalev([F:CYK])=0  : Local File GCCEPYMLIK  [CYK]  : Endif : # Liens pyramides sections
If clalev([F:CRY])=0  : Local File GCCEGRUPYM  [CRY]  : Endif : # Groupes pyramides analytiques
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC]  : Endif : # Comptes
If clalev([F:CCE])=0  : Local File CACCE       [CCE]  : Endif : # Sections
If clalev([F:COA])=0  : Local File GCOA        [COA]  : Endif : # Plan de comptes
If clalev([F:CLS])=0  : Local File GACCCLS     [CLS]  : Endif : # Classes de comptes
If clalev([F:LED])=0  : Local File GLED        [LED]  : Endif : # Referentiel
If clalev([F:DIE])=0  : Local File GDIE        [DIE]  : Endif : # Axes  analytiques
If clalev([F:GCM])=0  : Local File GACM        [GCM]  : Endif : # Modèle comptable
If clalev([F:BLM])=0  : Local File BLACMM      [BLM]  : Endif : # Balance analytique engagements
If clalev([F:BLQ])=0  : Local File BLAQTY      [BLQ]  : Endif : # Balance analytique en quantité

Onerrgo
Local Mask BUDCRI [BCR]
Local Integer INDDIE
Raz [M:BCR]
GOK = 1
GFMT = "15c"
Return

$CONTROLE
If GOK=0 : FIN = 1 : GOK = 1 : Return : Endif
BOITE = "WFBUD"+[M:BCR]BUDTYP
Return

$SEL_TABLE
Case GACTION
 When "SELACCPYM"
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If [F:BUP]PYMACC=""
   Local Char FCYSEL(GLONFCY), CPYSEL(GLONCPY), BUDSEL(GLONBUP)
   FCYSEL = PARAM(3)
   CPYSEL = PARAM(4)
   BUDSEL = PARAM(2)
   Raz PARAM
   PARAM(1) = [F:BUP]COA
   If FCYSEL<>""
    PARAM(2) = FCYSEL
   Else
    PARAM(2) = CPYSEL
   Endif
   Gosub SELGAC From SELGAC
   PARAM(2) = BUDSEL
  Else
   If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
   If clalev([F:GRC])=0 : Local File GACCGRUPYM [GRC] : Endif
   OBJET = "GRC"
   Call TITOBJ("GRC","",TIT(0)) From CONTOBJ
   # Sélection
   TIT(0)  = mess(12,123,1)-TIT(0)
   CRITERE = "PYM='"+[F:BUP]PYMACC+"' & LIN=1 & BUDTRK = 2 & LEV="+num$([F:BUP]PYMACCLEV)
   Filter [GRC]
  Endif

 When "SELCCEPYM"
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  Local Integer IND
  Local Char LDIE(GLONDIE), BUDG(GLONBUP)
  Local Char FCYSEL(GLONFCY), CPYSEL(GLONCPY)
  LDIE   = PARAM(1)
  BUDG   = PARAM(2)
  FCYSEL = PARAM(3)
  CPYSEL = PARAM(4)
  Call LECTURE("BUP",BUDG,"") From CONTOBJ
  Case zoncou
   When "CCE1" : IND=1
   When "CCE2" : IND=2
   When "CCE3" : IND=3
   When "CCE4" : IND=4
   When "CCE5" : IND=5
   When "CCE6" : IND=6
   When "CCE7" : IND=7
   When "CCE8" : IND=8
   When "CCE9" : IND=9
   When "CCED", "CCEF", "CODCCE3"
    If [F:BUP]DIE(8)<>"" : IND=9
    Elsif [F:BUP]DIE(7)<>"" : IND=8
    Elsif [F:BUP]DIE(6)<>"" : IND=7
    Elsif [F:BUP]DIE(5)<>"" : IND=6
    Elsif [F:BUP]DIE(4)<>"" : IND=5
    Elsif [F:BUP]DIE(3)<>"" : IND=4
    Elsif [F:BUP]DIE(2)<>"" : IND=3
    Elsif [F:BUP]DIE(1)<>"" : IND=2
    Elsif [F:BUP]DIE(0)<>"" : IND=1
    Endif
  Endcase
  If IND
   If [F:BUP]PYMCCE(IND-1)<>""
     Default File [CRY]
     Filter [CRY]
     CRITERE  = "PYM='"+[F:BUP]PYMCCE(IND-1)+"'"
     CRITERE -= " & LEV="+num$([F:BUP]PYMCCELEV(IND-1))
     CRITERE -= " & LIN=1 & BUDTRK=2"
     FICHE = "GCCEGRUPYM"
     Call TITOBJ("CRY","",TIT(0)) From CONTOBJ
     TIT(0)  = mess(12,123,1)-TIT(0) : # Sélection
     NBCOL = 0
     NBCOL += 1 : COL(NBCOL) = "GRU"    : Gosub TEXTE
     NBCOL += 1 : COL(NBCOL) = "PYM"    : Gosub TEXTE
     NBCOL += 1 : COL(NBCOL) = "LEV"    : Gosub TEXTE
     NBCOL += 1 : COL(NBCOL) = "PRNROW" : Gosub TEXTE
     Filter [CRY]
   Elsif [F:BUP]DIE(IND-1)<>""
     Raz PARAM
     PARAM(1) = num$(LDIE)
     If FCYSEL<>""
      PARAM(2) = FCYSEL
     Else
      PARAM(2) = CPYSEL
     Endif
     Gosub SELCCE From SELCCE
   Endif
  Endif
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELBUDVER"
  Local Integer KLEDTYP, KFIY
  Local Char KBUD(GLONBUP), KCPY(GLONCPY), KFCY(GLONFCY), KVER
  TIT = mess(126,105,1) : # Version
  If clalev([F:BUD])=0  : Local File  BUD   [BUD]  : Endif
  Local Integer TYPLED : TYPLED=val(PARAM(2))
  NBTEX = 0
  KLEDTYP = 0
  KBUD    = ""
  KCPY    = ""
  KFCY    = ""
  KFIY    = 0
  KVER    = ""
  Call LECTURE("BUP",PARAM(1),"") From CONTOBJ
  If PARAM(3)="" and PARAM(4)=""
    PARAM(3) = GDEFSOC
    If [F:BUP]LEV=1
     PARAM(4) = ""
    Else
     PARAM(4) = GFCYDEF
    Endif
  Endif
  If PARAM(4)=""
   Filter [BUD] Where BUD=PARAM(1) & LEDTYP=TYPLED & CPY=PARAM(3)
  Else
   Filter [BUD] Where BUD=PARAM(1) & LEDTYP=TYPLED & CPY=PARAM(3) & FCY=PARAM(4)
  Endif
  For [BUD]BUD0
   If [F:BUD]LEDTYP <> KLEDTYP or
&     [F:BUD]BUD <> KBUD or
&     [F:BUD]CPY <> KCPY or
&     [F:BUD]FCY <> KFCY or
&     [F:BUD]FIY <> KFIY or
&     [F:BUD]VER <> KVER
    If find([F:BUD]VER, TEX(1..NBTEX))=0 and [F:BUD]VER<>""
     NBTEX += 1
     TEX  (NBTEX)  = [F:BUD]VER
     TEXTE(NBTEX)  = [F:BUD]BUD+"/"+format$("K:5X",TEX(NBTEX))
     KLEDTYP       = [F:BUD]LEDTYP
     KBUD          = [F:BUD]BUD
     KCPY          = [F:BUD]CPY
     KFCY          = [F:BUD]FCY
     KFIY          = [F:BUD]FIY
     KVER          = [F:BUD]VER
    Endif
   Endif
  Next
  Filter [BUD]
If NBTEX=0
 NBTEX += 1
 TEX  (NBTEX)  = "1"
Endif
Endcase
Return

$TEXTE
Read [ATZ]CODZONE = FICHE;COL(NBCOL)
Call TEXTE([F:ATZ]NOCOURT,TIT(NBCOL)) From OBJDIV
Return

$SORTIE
#Call UNLOCKCPY() From AX3MONO
Return

########################## FENETRE SAISIE DES CRITERES #################################

$FCRIT
Case ACTION
 When "DEBUT"     : Gosub DEB_FCRIT
 When "OK"        : Gosub CTL_OK
 When "END"       : GOK = 0 : FIN = 1
Endcase
Return

$CTL_OK
# bouton OK cliqué
GOK = 1
FIN = 1
If [M:BCR]BUD=""
 # Les codes budgets n'ont pas été définis
 Call ERREUR(mess(21,108,1)) From GESECRAN
 FIN = 0
Endif
If [M:BCR]BUDCAT=1
 For I=1 To [M]NBCRI
  If [M]DATDEB(I-1)<>[00/00/00]
   nolign = I
   Call CTL_DATE([M:BCR]CPY(nolign-1),[M:BCR]LEDTYP(nolign-1),[M:BCR]DATDEB(nolign-1),1) From SUBBCR
   If mkstat
    GOK = 1 : FIN = 0 : Break
   Endif
  Endif
  If [M]DATFIN(I-1)<>[00/00/00]
   nolign = I
   Call CTL_DATE([M:BCR]CPY(nolign-1),[M:BCR]LEDTYP(nolign-1),[M:BCR]DATFIN(nolign-1),2) From SUBBCR
   If mkstat
    GOK = 1 : FIN = 0 : Break
   Endif
  Endif
 Next
Endif
If !FIN : Return : Endif
If [M:BCR]NBCRI<[M:BCR]NBRBUD
 # Nombre de budgets saisis différent du nombre de budgets paramétrés pour la transaction
 OK = 1 : Call AVERTIR(mess(70,108,1),OK) From GESECRAN
 If OK<>2 : FIN = 0 : Endif
Elsif [M:BCR]NBCRI>[M:BCR]NBRBUD
 Call ERREUR(mess(70,108,1)) From GESECRAN :  FIN = 0
Endif
Return

$DEB_FCRIT
# Tunnel depuis GESCCE
If GFONCTION="GESCCE" & [M:BCR]BUDTYP=""
 Filter [TBU] Where BUDCAT=3
 Read [TBU]TBU0 First
 Filter [TBU]
 If fstat : Return : Endif
 [M:BCR]BUDTYP = [F:TBU]BUDTYP
 If [M:BCR]BUDTYP<>""
  Call C_BUDTYP([M:BCR]BUDTYP) From SUBBCR
  Call AM_BUDTYP([M:BCR]BUDTYP) From SUBBCR #<CP:25898>
 Endif
 Filter [BUP] Where DIE(0)=[M:CCE0]DIE or DIE(1)=[M:CCE0]DIE or DIE(2)=[M:CCE0]DIE or DIE(3)=[M:CCE0]DIE
& or DIE(4)=[M:CCE0]DIE or DIE(5)=[M:CCE0]DIE or DIE(6)=[M:CCE0]DIE or DIE(7)=[M:CCE0]DIE or DIE(8)=[M:CCE0]DIE

 SUIZON = "NBCRI(0)"
 Return
Endif
If [M:BCR]BUDTYP=""
 Call LECMEMO("STD","[M:BCR]","bud") From GMEMO
Endif

# S'il n'y a pas de mémo, on ne fait rien de spécial
#If [M:BCR]BUDTYP=""
