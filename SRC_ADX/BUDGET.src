# Affzo [BCR]10
#Else
 Call C_BUDTYP([M:BCR]BUDTYP) From SUBBCR
 Affzo [BCR]
 # obligatoire pour rendre l'écran invalide
 Setmok [M:BCR] With 0
#Endif
SUIZON = "BUDTYP"
Return

########################## FENETRE PRINCIPALE SAISIE BUDGET ###########################
$FPRINC
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEB_FPRINC
 When "APRES_MODIF" : Gosub APRES_MODIF2
 When "SETBOUT"     : Gosub SETBOUT
 When "NEW"         : Gosub NOUVEAU
 When "ENR"         : Gosub ENREGISTRER
 When "ABA"         : Gosub ABANDON
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "PRE"         : Gosub PRECEDENT
 When "SUI"         : Gosub SUIVANT
 When "FIN"         : Gosub FIN
 When "BOUTON"      : Gosub BOUTON
 When "RAF"         : Gosub RAFRAICHIR
 When "TITRE"       : Gosub TIT
 When "SEL_LISTE"   : Gosub SEL_LISTE From SUBCMM2
 When "FIN_LISTE"   : Gosub FIN_LISTE From SUBCMM2
Endcase
Return

$TIT
# Lecture du titre (de la fenêtre) traduisibles dans la langue de connection
Call LECTEXTRA(TIT,"TABBUDTYP","DESTRA",[M:BCR]BUDTYP,"") From ATEXTRA
TIT = [M:BCR]BUDTYP-":"-TIT
Return

$BOUTON
If BOUT="O"
 Gosub ABORT
 If [L]OK
  FIN = 1 : GOK = 2
 Endif
Endif
Return

$RAFRAICHIR
Call LECTURE("TBU",[M:BCR]BUDTYP,num$(1)) From CONTOBJ
# On stocke le nombre de comptes ou sections préchargées dans NBRLIN car les zones comptes et sections préchargées ne sont pas modifiables
Case [M:BCR]BUDCAT
 When 1 : # Budget période
  Gosub LOAD_BUDPER From BUDGET2
 When 2 : # Budget compte
  If [F:TBU]LODFLG=2
   Gosub LOAD_BUDACC From BUDGET2
  Else
   For I=0 To [M:BCR]NBCRI-1
    Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
    Gosub INDDIE From BUDGET3
    CLECUR1 = [M:BCR]CPY(I)
    If [F:BUP]LEV=1
     CLECUR2(12) = ""
    Else
     CLECUR2(12) = [M:BCR]FCY(I)
    Endif
    CLECUR2(2) = [M:BUD]ACC
    For nolign=1 To [M:BUD]NBLIG
     CLECUR2(3)  = [M:BUD]CCE1
     CLECUR2(4)  = [M:BUD]CCE2
     CLECUR2(5)  = [M:BUD]CCE3
     CLECUR2(6)  = [M:BUD]CCE4
     CLECUR2(7)  = [M:BUD]CCE5
     CLECUR2(8)  = [M:BUD]CCE6
     CLECUR2(9)  = [M:BUD]CCE7
     CLECUR2(10) = [M:BUD]CCE8
     CLECUR2(INDDIE+2) = [M:BUD]CODCCE3(nolign-1)
     If INDDIE = 1
      Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 2
      Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 3
      Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 4
      Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 5
      Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 6
      Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 7
      Raz CLECUR2(10), CLECUR2(11)
     Elsif INDDIE = 8
      Raz CLECUR2(11)
     Endif
     Gosub READ_AMT_QTY From BUDGET2
    Next
   Next
   Affzo [BUD] 20
  Endif
 When 3 : # Budget section
  If [F:TBU]LODFLG=2
   Gosub LOAD_BUDCCE From BUDGET2
  Else
   For I=0 To [M:BCR]NBCRI-1
    Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
    Gosub INDDIE From BUDGET3
    CLECUR1 = [M:BCR]CPY(I)
    If [F:BUP]LEV=1
     CLECUR2(12) = ""
    Else
     CLECUR2(12) = [M:BCR]FCY(I)
    Endif
    CLECUR2(3)  = [M:BUD]CCE1
    CLECUR2(4)  = [M:BUD]CCE2
    CLECUR2(5)  = [M:BUD]CCE3
    CLECUR2(6)  = [M:BUD]CCE4
    CLECUR2(7)  = [M:BUD]CCE5
    CLECUR2(8)  = [M:BUD]CCE6
    CLECUR2(9)  = [M:BUD]CCE7
    CLECUR2(10) = [M:BUD]CCE8
    CLECUR2(11) = [M:BUD]CCE9
    If INDDIE = 1
     Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 2
     Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 3
     Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 4
     Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 5
     Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 6
     Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 7
     Raz CLECUR2(10), CLECUR2(11)
    Elsif INDDIE = 8
     Raz CLECUR2(11)
    Endif
    For nolign=1 To [M:BUD]NBLIG
     CLECUR2(2) = [M:BUD]CODACC(nolign-1)
     Gosub READ_AMT_QTY From BUDGET2
    Next
   Next
   Affzo [BUD] 20
  Endif
Endcase
If GOK=0 : GOK = 1 : Return : Endif
Return

$AFFICHE
Local Char T(250), T2(5)
Local Integer P, C
If zoncou<>""
 P = len(zoncou)
 While P>0 and seg$(zoncou, P, P)>="0" and seg$(zoncou, P, P)<="9"
  P-=1
 Wend
 C = val(seg$(zoncou, P+1, len(zoncou)))
 If C>0
  Read [TBU]TBU0=[M:BCR]BUDTYP;C
  C = [F:TBU]LINSELCRI-1

  If C<0 : Return : Endif
  If [F:BUP]LEV=1 # niveau société
   [M:BUD]AFFICHE = [M:BCR]CPY(C)
  Else # niveau site
   [M:BUD]AFFICHE = [M:BCR]FCY(C)
  Endif
  [M:BUD]AFFICHE -= [M:BCR]BUD(C)
  Call LECTEXTRA(T,"BUDPAR","SHOTRA",[M:BCR]BUD(C),"") From ATEXTRA
  If len(T)>0
   [M:BUD]AFFICHE -= "["+T+"]"
  Endif
  [M:BUD]AFFICHE -= "-"-[M:BCR]VER(C)
  Call LECTEXTRA(T,"BUDVER","SHOTRA",[M:BCR]BUD(C),[M:BCR]VER(C)) From ATEXTRA
  If len(T)>0
   [M:BUD]AFFICHE -= "["+T+"]"
  Endif
  If [F:TBU]BUDCAT=2 or [F:TBU]BUDCAT=3
   [M:BUD]AFFICHE -= "["+num$([M:BCR]DATDEB(C))-"-"-num$([M:BCR]DATFIN(C))+"]"
  Endif
  Affzo [M]AFFICHE
 Endif
Endif
Return

$DEB_FPRINC
Gosub DEFVAR
Raz [M:BUD]
If [F:BUP]PYMACC=""
 [M:BUD]COA=[F:BUP]COA
Else
 [M:BUD]COA=[F:GYM]COA
Endif
BASPAG = "NBLIG" : Gosub TIT_COL From ="W1WMBUD"+[M:BCR]BUDTYP

Gosub INDDIE From BUDGET3
Gosub INIAXE

Gosub AFFICHE

# changement d'intitulés des colonnes du tableau
Local Char INTIT(250)
If [M:BCR]BUDCAT=3
 Call LECTEXTRA(INTIT,"GCOA","COLHEA",[M:BUD]COA,"") From ATEXTRA
 Titcol [M:BUD]NBLIG INTIT For CODACC
Endif

Affzo [M:BUD]

Case [M:BCR]BUDCAT
 When 1 : # Periode
  If INDDIE>1
   Actzo CCE2, DEFIL(2), DESCCE2, DIE2
  Else
   Grizo CCE2, DEFIL(2), DESCCE2, DIE2
  Endif
  If INDDIE>2
   Actzo CCE3, DEFIL(3), DESCCE3, DIE3
  Else
   Grizo CCE3, DEFIL(3), DESCCE3, DIE3
  Endif
  If INDDIE>3
   Actzo CCE4, DEFIL(4), DESCCE4, DIE4
  Else
   Grizo CCE4, DEFIL(4), DESCCE4, DIE4
  Endif
  If INDDIE>4
   Actzo CCE5, DEFIL(5), DESCCE5, DIE5
  Else
   Grizo CCE5, DEFIL(5), DESCCE5, DIE5
  Endif
  If INDDIE>5
   Actzo CCE6, DEFIL(6), DESCCE6, DIE6
  Else
   Grizo CCE6, DEFIL(6), DESCCE6, DIE6
  Endif
  If INDDIE>6
   Actzo CCE7, DEFIL(7), DESCCE7, DIE7
  Else
   Grizo CCE7, DEFIL(7), DESCCE7, DIE7
  Endif
  If INDDIE>7
   Actzo CCE8, DEFIL(8), DESCCE8, DIE8
  Else
   Grizo CCE8, DEFIL(8), DESCCE8, DIE8
  Endif
  If INDDIE>8
   Actzo CCE9, DEFIL(9), DESCCE9, DIE9
  Else
   Grizo CCE9, DEFIL(9), DESCCE9, DIE9
  Endif
 When 2 : # Compte
  If INDDIE>1
   Actzo CCE1, DESCCE1, DEFIL(1), DIE1
  Else
   Grizo CCE1, DESCCE1, DEFIL(1), DIE1
  Endif
  If INDDIE>2
   Actzo CCE2, DESCCE2, DEFIL(2), DIE2
  Else
   Grizo CCE2, DESCCE2, DEFIL(2), DIE2
  Endif
  If INDDIE>3
   Actzo CCE3, DESCCE3, DEFIL(3), DIE3
  Else
   Grizo CCE3, DESCCE3, DEFIL(3), DIE3
  Endif
  If INDDIE>4
   Actzo CCE4, DESCCE4, DEFIL(4), DIE4
  Else
   Grizo CCE4, DESCCE4, DEFIL(4), DIE4
  Endif
  If INDDIE>5
   Actzo CCE5, DESCCE5, DEFIL(5), DIE5
  Else
   Grizo CCE5, DESCCE5, DEFIL(5), DIE5
  Endif
  If INDDIE>6
   Actzo CCE6, DESCCE6, DEFIL(6), DIE6
  Else
   Grizo CCE6, DESCCE6, DEFIL(6), DIE6
  Endif
  If INDDIE>7
   Actzo CCE7, DESCCE7, DEFIL(7), DIE7
  Else
   Grizo CCE7, DESCCE7, DEFIL(7), DIE7
  Endif
  If INDDIE>8
   Actzo CCE8, DESCCE8, DEFIL(8), DIE8
  Else
   Grizo CCE8, DESCCE8, DEFIL(8), DIE8
  Endif
 When 3 : # Section
  NATD = [M:BCR]ACCD
  NATF = [M:BCR]ACCF
  If INDDIE>1
   Actzo CCE2, DESCCE2, DEFIL(1), DIE2
  Else
   Grizo CCE2, DESCCE2, DEFIL(1), DIE2
  Endif
  If INDDIE>2
   Actzo CCE3, DESCCE3, DEFIL(2), DIE3
  Else
   Grizo CCE3, DESCCE3, DEFIL(2), DIE3
  Endif
  If INDDIE>3
   Actzo CCE4, DESCCE4, DEFIL(3), DIE4
  Else
   Grizo CCE4, DESCCE4, DEFIL(3), DIE4
  Endif
  If INDDIE>4
   Actzo CCE5, DESCCE5, DEFIL(4), DIE5
  Else
   Grizo CCE5, DESCCE5, DEFIL(4), DIE5
  Endif
  If INDDIE>5
   Actzo CCE6, DESCCE6, DEFIL(5), DIE6
  Else
   Grizo CCE6, DESCCE6, DEFIL(5), DIE6
  Endif
  If INDDIE>6
   Actzo CCE7, DESCCE7, DEFIL(6), DIE7
  Else
   Grizo CCE7, DESCCE7, DEFIL(6), DIE7
  Endif
  If INDDIE>7
   Actzo CCE8, DESCCE8, DEFIL(7), DIE8
  Else
   Grizo CCE8, DESCCE8, DEFIL(7), DIE8
  Endif
  If INDDIE>8
   Actzo CCE9, DESCCE9, DEFIL(8), DIE9
  Else
   Grizo CCE9, DESCCE9, DEFIL(8), DIE9
  Endif

  # Tunnel venant des sections analytiques pour saisie budget direct  (CP : 18/07/01)
  If GFONCTION="GESCCE"
   Case [M:CCE0]DIE
    When [F:BUP]DIE(0) : [M:BUD]CCE1 = [M:CCE0]CCE
    When [F:BUP]DIE(1) : [M:BUD]CCE2 = [M:CCE0]CCE
    When [F:BUP]DIE(2) : [M:BUD]CCE3 = [M:CCE0]CCE
    When [F:BUP]DIE(3) : [M:BUD]CCE4 = [M:CCE0]CCE
    When [F:BUP]DIE(4) : [M:BUD]CCE5 = [M:CCE0]CCE
    When [F:BUP]DIE(5) : [M:BUD]CCE6 = [M:CCE0]CCE
    When [F:BUP]DIE(6) : [M:BUD]CCE7 = [M:CCE0]CCE
    When [F:BUP]DIE(7) : [M:BUD]CCE8 = [M:CCE0]CCE
    When [F:BUP]DIE(8) : [M:BUD]CCE9 = [M:CCE0]CCE
   Endcase
  Endif
Endcase
If !find(2,[M]DEFIL)
 [M:BUD]DEFIL(0) = 2
Endif

Onevent BEFORE_INPUT Gosub AFFICHE
Setmok [M:BUD] With 0
Return

$DEFVAR
Local Integer I, J, K, L, ERR, TROUVE, M, N
Local Integer NOL
Local Integer AEFF                   : # Fait effzo en Apres modif si toutes les clés saisies
Local Integer AFFIC                  : # Affiche colonnes qté et mt en AM_CODACC et AM_CODCCE3
Local Integer PDEB, PFIN
Local Integer DEFILE, TYPDEF
Local Decimal DIV                    : # Diviseur montant defini pour le budget dans BUDPAR
Local Char    BASPAG(10), CRITERE(250)
Local Char    NEWCLE1(10), CLECUR1(10)
Local Char    NEWCLE2(30)(1..12), CLECUR2(30)(1..12)
Local Char    TPVAL(9)               : # Type de montant
Local Char    TSYMBOLE(50)(0..9)     : # Table des symboles pour gestion des verrous
Local Char    EFFZON(7)              : # Zone à effacer
Local Char    QTYZON(20), MTZON(20)  : # Nom du champ Qté budget et Mt budget de l'écran
Local Char    TXZON(20)              : # Nom du champ Texte de l'écran
Local Char    NOMCOL(20)             : # Nom de la colonne
Local Integer VERROU
Local Integer CLECUR
Local Decimal VALDEC                 : # Calcul le montant de chaque cellule du tableau
Local Date    DATDEB,DATFIN          : # Date début et fin d'une période
# Calcul de la répartition du budget par compte
Local Decimal SUMCOE, SUMAMT, SUMQTY, MTREP, QTREP
Local Integer EXO, INAT
Local Integer DIMPER
DIMPER = dim([M:BUD]NUMLIG)
Local Decimal AMTREA(1..DIMPER)      : # Montant réel
Local Decimal QTYREA(1..DIMPER)      : # Quantité réelle
Local Decimal AMTCMM(1..DIMPER)      : # Montant engagé
Local Decimal QTYCMM(1..DIMPER)      : # Quantité engagée
Local Decimal AMTPRP(1..DIMPER)      : # Montant pré-engagé
Local Decimal QTYPRP(1..DIMPER)      : # Quantité pré-engagé
Local Decimal CONVMT                 : # Permet la conversion en devise budget des montants
Local Decimal COEDTP(1..DIMPER,1..99)
Local Char NUMCPT (GLONVCR)          : # No pour compteur d'OD budgétaires.
Local Integer NBRLIG                 : # Nb de ligne par OD budgétaires.

Local Char DIE(GLONDIE), LDIE1(GLONDIE), LDIE2(GLONDIE), LDIE3(GLONDIE)  : # Name of axe section
Local Char LDIE4(GLONDIE), LDIE5(GLONDIE), LDIE6(GLONDIE)                : # Name of axe section
Local Char LDIE7(GLONDIE), LDIE8(GLONDIE), LDIE9(GLONDIE)                : # Name of axe section

# Local Integer INDDIE                 : # Number of the last valorized axe on budget parametrage
Global Char LIBBUD(GLONBUP)(0..[M:BCR]NBRBUD+1)          : # Le code budget  # Demande 23636

Local Char CODLED(GLONLED), DEVLED(GLONCUR)       : # Ledger code, currency of the ledger
Local Char BUDDIE(GLONDIE)(9), BUDCCE(GLONCCE)(9) : # To relate dimension of the budget to dimension of the ledger
Return

$OUVRE
# Préchargement total (Ddm28200)
Local Mask ="WMBUD"+[M:BCR]BUDTYP [BU9_]
Local Integer SVG_ADXLIG
SVG_ADXLIG=adxlig
adxlig=dim([M:BU9_]NUMLIG)
Close Local Mask [BU9_]
Return

$FIN
Gosub DEVERROU
If dim(SVG_ADXLIG)>0 : adxlig=SVG_ADXLIG : Endif
Return

$INIAXE
#[M:BUD]VER    = [M:BCR]VER
#[M:BUD]COA    = [M:BCR]COA
[M:BUD]LED    = [M:BCR]LED
[M:BUD]LEDTYP = [M:BCR]LEDTYP

# NB : [M:BUD]DIE3 contiendra l'axe réel des sections qui seront affichées dans le tableau (pas dans l'en-tête)
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
Gosub INDDIE From BUDGET3
If dim([M]INTITACC)>0
 Effzo INTITACC
 If [F:BUP]PYMACC=""
  Call LECTURE("COA",[M:BUD]COA,"") From CONTOBJ
  [M:BUD]COA = [F:COA]COA
  [M:BUD]INTITACC=""
  Call LECTEXTRA([M:BUD]INTITACC,"GCOA","DESTRA",[F:COA]COA,"") From ATEXTRA
  If [M:BUD]INTITACC=""
   [M:BUD]INTITACC = mess(36,113,1)-[F:COA]COA
  Endif
 Else
  Call LECTURE("GYM",[F:BUP]PYMACC,"") From CONTOBJ
  [M:BUD]COA = [F:GYM]COA
  [M:BUD]INTITACC=""
  Call LECTEXTRA([M:BUD]INTITACC,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
  If [M:BUD]INTITACC=""
   [M:BUD]INTITACC = mess(33,103,1)-[F:GYM]PYM
  Endif
 Endif
Endif
If dim([M:BUD]INTITCCE1)>0 : Effzo INTITCCE1,DIE1 : Endif
If dim([M:BUD]INTITCCE2)>0 : Effzo INTITCCE2,DIE2 : Endif
If dim([M:BUD]INTITCCE3)>0 : Effzo INTITCCE3,DIE3 : Endif
If dim([M:BUD]INTITCCE4)>0 : Effzo INTITCCE4,DIE4 : Endif
If dim([M:BUD]INTITCCE5)>0 : Effzo INTITCCE5,DIE5 : Endif
If dim([M:BUD]INTITCCE6)>0 : Effzo INTITCCE6,DIE6 : Endif
If dim([M:BUD]INTITCCE7)>0 : Effzo INTITCCE7,DIE7 : Endif
If dim([M:BUD]INTITCCE8)>0 : Effzo INTITCCE8,DIE8 : Endif
If dim([M:BUD]INTITCCE9)>0 : Effzo INTITCCE9,DIE9 : Endif

If [M:BCR]BUDCAT=1 or [M:BCR]BUDCAT=3
## Budget par période ou Budget par section
 Effzo ="INTITCCE"+num$([F:BUP]DIENBR)
 Effzo ="DIE"+num$([F:BUP]DIENBR)
 [M:BUD]DIE1 = [F:BUP]DIE(0)
 [M:BUD]DIE2 = [F:BUP]DIE(1)
 [M:BUD]DIE3 = [F:BUP]DIE(2)
 [M:BUD]DIE4 = [F:BUP]DIE(3)
 [M:BUD]DIE5 = [F:BUP]DIE(4)
 [M:BUD]DIE6 = [F:BUP]DIE(5)
 [M:BUD]DIE7 = [F:BUP]DIE(6)
 [M:BUD]DIE8 = [F:BUP]DIE(7)
 [M:BUD]DIE9 = [F:BUP]DIE(8)
 For I=0 To INDDIE-1
  Gosub INIDIE
 Next
Else
## Budget par compte
 Gosub INIDIE_COMPTE
Endif

If [M:BCR]BUDCAT=1 : Gosub DISPLAYPER From BUDGET2 : Endif
Affzo [M:BUD]
Return

$APRES_MODIF2
Call LECTURE("TBU",[M:BCR]BUDTYP,num$(1)) From CONTOBJ
# On stocke le nombre de comptes ou sections préchargées dans NBRLIN car les zones comptes et sections préchargées ne sont pas modifiables
Case [M:BCR]BUDCAT
 When 1 : # Budget détail
  If find(COUZON,"ACC","CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9")
   Gosub LOAD_BUDPER From BUDGET2
  Endif
 When 2 : # Budget compte
  If find(COUZON,"ACC","CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8")
   If [F:TBU]LODFLG=2
    Assign "[M]"+COUZON With CZ
    Gosub LOAD_BUDACC From BUDGET2
   Else
    Gosub INIT_BUDACC From BUDGET2
   Endif
  Endif
 When 3 : # Budget section
  If find(COUZON,"CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9")
   If [F:TBU]LODFLG=2
    Assign "[M]"+COUZON With CZ
    Gosub LOAD_BUDCCE From BUDGET2
   Else
    Gosub INIT_BUDCCE From BUDGET2
   Endif
  Endif
Endcase
If GOK=0 : GOK = 1 : Return : Endif
If [M:BUD]NBLIG>0 : CLECUR=1 : Endif
If !find(COUZON,"ACC","CCE1","CCE2","CCE3","CCE4","CCE5","CCE6","CCE7","CCE8","CCE9") & REP="" & CLECUR<>0
 # On tente d'entrer en modif
 If !VERROU
  Gosub VERROU
  If !VERROU
   # Modification en cours sur un autre poste
   Call ERREUR(mess(10,100,1)) From GESECRAN
   mkstat=1 : Return
  Endif
  # Si tous les budgets sont rattachés à des budgets de référence, on reste en consultation
  If VERROU=2 : VERROU=0 : Return : Endif
 Endif
 REP = "M" : GREP = "M"
 Gosub GRISE_CLE
 Gosub SETBOUT
Endif
Return

$SETBOUT
Local Integer OKACC
#Call LECACC([F:CCE]ACS,OKACC) From SUBACS
#If !OKACC

If find(REP,"M")
 ETABOU(GSPE2) = 0
 Call VIREBOUT(CHBOU,"=") From GOBJET
 ETABOU(GSPE1) = 0
Else
 ETABOU(GSPE2) = 1
 CHBOU += "="
 ETABOU(GSPE1) = 1
Endif
Return


$NOUVEAU
Gosub ABORT
If !OK : Return : Endif
If VERROU : Gosub DEVERROU : Endif
If REP = "M"
 Gosub DEGRISE_CLE
Endif
CLECUR = 0 : Gosub RELIT
Gosub EFFBUD
Return

$ABORT
OK = 2
If find(REP,"M")
 Call ABANDON(OK) From GESECRAN
 If OK<>2
  OK = 0
 Endif
Endif
Return

$DEVERROU
For I=0 To [M:BCR]NBCRI-1
 If TSYMBOLE(I)<>""
  Unlock =TSYMBOLE(I)
 Endif
Next
VERROU = 0
Return

$VERROU
For I=0 To [M:BCR]NBCRI-1
 TSYMBOLE(I) = "BUD"+[M:BCR]BUD(I)+"\"+CLECUR1+"\"+CLECUR2(12)+"\"+[M:BCR]VER(I)+"\"+CLECUR2(1)
 Lock =TSYMBOLE(I) With lockwait=0
 If fstat
  VERROU = 0
  Break
 Else
  VERROU = 1
 Endif
Next
Return

$DEGRISE_CLE
Case [M:BCR]BUDCAT
 When 1
  Actzo ACC, CCE1
  If [F:BUP]DIE(1)<>"" : Actzo CCE2 : Endif
  If [F:BUP]DIE(2)<>"" : Actzo CCE3 : Endif
  If [F:BUP]DIE(3)<>"" : Actzo CCE4 : Endif
  If [F:BUP]DIE(4)<>"" : Actzo CCE5 : Endif
  If [F:BUP]DIE(5)<>"" : Actzo CCE6 : Endif
  If [F:BUP]DIE(6)<>"" : Actzo CCE7 : Endif
  If [F:BUP]DIE(7)<>"" : Actzo CCE8 : Endif
  If [F:BUP]DIE(8)<>"" : Actzo CCE9 : Endif
 When 2
  Actzo ACC
  If [F:BUP]DIE(1)<>"" : Actzo CCE1 : Endif  # Because If DIE(1)<>"" then DIE(0)<>"" and it relates to CCE1
  If [F:BUP]DIE(2)<>"" : Actzo CCE2 : Endif
  If [F:BUP]DIE(3)<>"" : Actzo CCE3 : Endif
  If [F:BUP]DIE(4)<>"" : Actzo CCE4 : Endif
  If [F:BUP]DIE(5)<>"" : Actzo CCE5 : Endif
  If [F:BUP]DIE(6)<>"" : Actzo CCE6 : Endif
  If [F:BUP]DIE(7)<>"" : Actzo CCE7 : Endif
  If [F:BUP]DIE(8)<>"" : Actzo CCE8 : Endif
 When 3
  Actzo CCE1
  If [F:BUP]DIE(1)<>"" : Actzo CCE2 : Endif
  If [F:BUP]DIE(2)<>"" : Actzo CCE3 : Endif
  If [F:BUP]DIE(3)<>"" : Actzo CCE4 : Endif
  If [F:BUP]DIE(4)<>"" : Actzo CCE5 : Endif
  If [F:BUP]DIE(5)<>"" : Actzo CCE6 : Endif
  If [F:BUP]DIE(6)<>"" : Actzo CCE7 : Endif
  If [F:BUP]DIE(7)<>"" : Actzo CCE8 : Endif
  If [F:BUP]DIE(8)<>"" : Actzo CCE9 : Endif
Endcase
Return

$GRISE_CLE
Case [M:BCR]BUDCAT
 When 1
  Grizo ACC
  For I=1 To [F:BUP]DIENBR
   Grizo ="CCE"+num$(I)
  Next
 When 2
  Grizo ACC
  For I=1 To [F:BUP]DIENBR-1
   Grizo ="CCE"+num$(I)
  Next
 When 3
  For I=1 To [F:BUP]DIENBR
   Grizo ="CCE"+num$(I)
  Next
Endcase
Return

$RELIT
If CLECUR
 CLECUR = 0
 NEWCLE1    = CLECUR1
 NEWCLE2(1) = CLECUR2(1)
 NEWCLE2(2) = CLECUR2(2)
 NEWCLE2(3) = CLECUR2(3)
 NEWCLE2(4) = CLECUR2(4)
 NEWCLE2(5) = CLECUR2(5)
 NEWCLE2(6) = CLECUR2(6)
 NEWCLE2(7)  = CLECUR2(7)
 NEWCLE2(8)  = CLECUR2(8)
 NEWCLE2(9)  = CLECUR2(9)
 NEWCLE2(10) = CLECUR2(10)
 NEWCLE2(11) = CLECUR2(11)
 NEWCLE2(12) = CLECUR2(12)
 Case [M:BCR]BUDCAT
   When 1 : Gosub LOAD_BUDPER From BUDGET2
   When 2 : If [F:TBU]LODFLG=1 : Gosub INIT_BUDACC From BUDGET2   : # Ecran vierge
            Else                 Gosub LOAD_BUDACC From BUDGET2   : # Ecran pré chargé
            Endif
   When 3 : If [F:TBU]LODFLG=1 : Gosub INIT_BUDCCE From BUDGET2   : # Ecran vierge
            Else                 Gosub LOAD_BUDCCE From BUDGET2   : # Ecran pré chargé
            Endif
 Endcase
Endif
Return

$EFFBUD
For EFFZON="ACC", "CCE1","CCE2", "CCE3", "CCE4", "CCE5", "CCE6", "CCE7", "CCE8", "CCE9", "DESACC",
&          "DESCCE1", "DESCCE2", "DESCCE3", "DESCCE4", "DESCCE5", "DESCCE6", "DESCCE7", "DESCCE8", "DESCCE9"
 If evalue("dim([M]"+EFFZON+")")>0
  Effzo =EFFZON
 Endif
Next
Effzo 20-40
[M:BUD]LED    = [M:BCR]LED
[M:BUD]LEDTYP = [M:BCR]LEDTYP
Affzo [M:BUD]LEDTYP
[M]NBLIG=0
If [M:BCR]BUDCAT=1
 Gosub DISPLAYPER From BUDGET2
 Affzo [M:BUD]25
Endif
Return

$ENREGISTRER
Local Char CPY(GLONCPY), FCY(GLONFCY)
# Contrôles Euro : bug 9662
Call CONTDEV([F:BUP]CUR,datesyst) From TRTDEV
If mkstat : Return : Endif
# Fin 9662
OK = 1
Call DEBTRANS From GLOCK
Case [M:BCR]BUDCAT
 When 1 : Gosub TR_BUDPER From BUDGET2
 When 2 : Gosub TR_BUDACC From BUDGET2
 When 3 : Gosub TR_BUDCCE From BUDGET2
Endcase
If GOK<1 : Return : Endif
REP = "" : GREP = "" : # Retour en consultation
Gosub DEGRISE_CLE
Return

$ABANDON
Case REP
 When ""
  If VERROU : Gosub DEVERROU : Endif
  CLECUR = 0
  Gosub RELIT
 When "M"
  Gosub RELIT
  REP = "" : GREP = ""
  Gosub DEGRISE_CLE
Endcase
Return

$PREMIER
Gosub DEB_DEFILE
If !OK : Return : Endif
Case TYPDEF
 When 1
  Filter [GAC] Where evalue(CRITERE)
  Read [GAC]GAC0 First
 When 2
  Filter [CCE] Where evalue(CRITERE)
  Read [CCE]CCE0 First
 When 3
  Filter [GRY] Where evalue(CRITERE)
  Read [GRY]GRY0 First
 When 4
  Filter [CRY] Where evalue(CRITERE)
  Read [CRY]CRY0 First
Endcase
SENSDEF = +1
Goto SUIVPREC
Return

$DERNIER
Gosub DEB_DEFILE
If !OK : Return : Endif
Case TYPDEF
 When 1
  Filter [GAC] Where evalue(CRITERE)
  Read [GAC]GAC0 Last
 When 2
  Filter [CCE] Where evalue(CRITERE)
  Read [CCE]CCE0 Last
 When 3
  Filter [GRY] Where evalue(CRITERE)
  Read [GRY]GRY0 Last
 When 4
  Filter [CRY] Where evalue(CRITERE)
  Read [CRY]CRY0 Last
Endcase
SENSDEF = -1
Goto SUIVPREC
Return

$PRECEDENT
Gosub DEB_DEFILE
If !OK : Return : Endif
Case TYPDEF
 When 1
  If [M:BCR]BUDCAT=1
   CRITERE -= "& ACC<'"+NEWCLE2(2)+"' & COA ='"+[F:BUP]COA+"'"
  Else
   CRITERE -= "& ACC<'"+CLECUR2(2)+"' & COA ='"+[F:BUP]COA+"'"
  Endif
  Filter [GAC] Where evalue(CRITERE)
  Read [GAC]GAC0 Last
 When 2
  If [M:BCR]BUDCAT=1
   CRITERE -= ' & CCE<"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= ' & CCE<"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [CCE] Where evalue(CRITERE)
  Read [CCE]CCE0 Last
 When 3
  If [M:BCR]BUDCAT=1
   CRITERE -= ' & GRU<"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= ' & GRU<"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [GRY] Where evalue(CRITERE)
  Read [GRY]GRY0 Last
 When 4
  If [M:BCR]BUDCAT=1
   CRITERE -= ' & GRU<"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= ' & GRU<"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [CRY] Where evalue(CRITERE)
  Read [CRY]CRY0 Last
Endcase
SENSDEF = -1
Goto SUIVPREC
Return

$SUIVANT
Gosub DEB_DEFILE
If !OK : Return : Endif
Case TYPDEF
 When 1
  If [M:BCR]BUDCAT=1
   CRITERE -= ' & ACC>"'+NEWCLE2(2)+'"  & COA ="'+[F:BUP]COA+'"'
  Else
   CRITERE -= ' & ACC>"'+CLECUR2(2)+'"  & COA ="'+[F:BUP]COA+'"'
  Endif
  Filter [GAC] Where evalue(CRITERE)
  Read [GAC]GAC0 First
 When 2
  If [M:BCR]BUDCAT=1
   CRITERE -= '& CCE>"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= '& CCE>"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [CCE] Where evalue(CRITERE)
  Read [CCE]CCE0 First
 When 3
  If [M:BCR]BUDCAT=1
   CRITERE -= '& GRU>"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= '& GRU>"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [GRY] Where evalue(CRITERE)
  Read [GRY]GRY0 First
 When 4
  If [M:BCR]BUDCAT=1
   CRITERE -= '& GRU>"'+NEWCLE2(I_DEF)+'"'
  Else
   CRITERE -= '& GRU>"'+CLECUR2(I_DEF)+'"'
  Endif
  Filter [CRY] Where evalue(CRITERE)
  Read [CRY]CRY0 First
Endcase
SENSDEF = +1
Goto SUIVPREC
Return

$SUIVPREC
If fstat>2 : Goto ERR_DEFILE : Endif
ERR = 0
Repeat
 For I=0 To [M:BCR]NBCRI-1
  Gosub VERF_DEFILE From BUDGET2
  If !OK : Raz GMESSAGE, mkstat : Break : Endif
 Next
 If !OK
  Case SENSDEF
   When +1
    Case TYPDEF
     When 1 : Read [GAC]GAC0 Next
     When 2 : Read [CCE]CCE0 Next
     When 3 : Read [GRY]GRY0 Next
     When 4 : Read [CRY]CRY0 Next
    Endcase
   When -1
    Case TYPDEF
     When 1 : Read [GAC]GAC0 Prev
     When 2 : Read [CCE]CCE0 Prev
     When 3 : Read [GRY]GRY0 Prev
     When 4 : Read [CRY]CRY0 Prev
    Endcase
  Endcase
  If fstat>2 : ERR = 1 : Break : Endif
 Endif
Until OK=1
If ERR : Goto ERR_DEFILE : Endif
If VERROU : Gosub DEVERROU : Endif
Case [M:BCR]BUDCAT
 When 1
   Gosub DEFILEPER From BUDGET2
   Effzo [BUD]25-40
   Gosub DISPLAYPER From BUDGET2 :# Budget par période toujours préchargé(LOADFLG=2) et Affzo fait
   If [F:TBU]LODFLG=2
    For I=0 To [M:BCR]NBCRI-1
     NOL = 1
     Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
     NEWCLE1 = [M:BCR]CPY(I)
     NEWCLE2(12) = [M:BCR]FCY(I)
     For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
      NEWCLE2(1) = num$(J)
      If NEWCLE2(2)<>"" & (NEWCLE2(3)<>"" | INDDIE<1) & (NEWCLE2(4)<>"" | INDDIE<2) & (NEWCLE2(5)<>"" | INDDIE<3)
&      & (NEWCLE2(6)<>"" | INDDIE<4) & (NEWCLE2(7)<>"" | INDDIE<5) & (NEWCLE2(8)<>"" | INDDIE<6)
&      & (NEWCLE2(9)<>"" | INDDIE<7) & (NEWCLE2(10)<>"" | INDDIE<8) & (NEWCLE2(11)<>"" | INDDIE<9)
       # Toutes les clés ont été saisies
       REP = "" : GREP = ""
       nolign = NOL
       CLECUR1 = NEWCLE1       : CLECUR2(1) = NEWCLE2(1) : CLECUR2(2) = NEWCLE2(2)
       CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5): CLECUR2(6) = NEWCLE2(6)
       CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9): CLECUR2(10) = NEWCLE2(10)
       CLECUR2(11) = NEWCLE2(11) : CLECUR2(12) = NEWCLE2(12)
       Gosub INIVAR_BUDCCE From BUDGET2
       Read [F:BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);NEWCLE1;NEWCLE2(12);val(NEWCLE2(1));[M:BCR]VER(I);NEWCLE2(2);
&                  BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
       If fstat: Raz [F:BUD] : Endif
       Gosub READ_BUDPER From BUDGET2
       If GOK=0 : Break 2 : Endif
       If nolign>[M:BUD]NBLIG : Break : Endif
      Endif
     Next J
    Next I
    Affzo [M:BUD]20-40
   Endif
 When 2
   Gosub DEFILEACC From BUDGET2
   Effzo [BUD]25-40 : Effzo [BUD]TEX
   If [F:TBU]LODFLG=2
    For I=0 To [M:BCR]NBCRI-1
     nolign = 0
     Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
     CLECUR1 = [M:BCR]CPY(I)
     CLECUR2(12) = [M:BCR]FCY(I)
     Gosub READ_BUDACC From BUDGET2
    Next I
    Affzo [M:BUD]20-40
   Endif
   Affzo [M:BUD]TEX
 When 3
  Gosub DEFILECCE From BUDGET2
  Effzo [BUD]25-40 : Effzo [BUD]TEX
  If [F:TBU]LODFLG=2
   For I=0 To [M:BCR]NBCRI-1
    nolign = 0
    Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
    CLECUR1 = [M:BCR]CPY(I)
    CLECUR2(12) = [M:BCR]FCY(I)
    Gosub READ_BUDCCE From BUDGET2
   Next I
   Affzo [M:BUD]20-40
  Endif
  Affzo [M:BUD]TEX
Endcase
If dim([M]ACC)>0
 Affzo ACC, CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9, DESACC, UOMACC
 Affzo DESCCE1, DESCCE2, DESCCE3, DESCCE4, DESCCE5, DESCCE6, DESCCE7, DESCCE8, DESCCE9
Else
 Affzo CCE1, CCE2, CCE3, CCE4, CCE5, CCE6, CCE7, CCE8, CCE9
 Affzo DESCCE1, DESCCE2, DESCCE3, DESCCE4, DESCCE5, DESCCE6, DESCCE7, DESCCE8, DESCCE9
Endif
GMODIF = 1 : # Pour que la coche de AS_DEFIL reste bien positionnée

$FIN_DEFILE
Filter [CCE]
Filter [GAC]
Filter [GRY]
Filter [CRY]
Return

$ERR_DEFILE
GMODIF = 1 : # Pour que la coche de AS_DEFIL reste bien positionnée
Call ERREUR(mess(11,100,1)) From GESECRAN : # Debut/Fin de fichier
Gosub RELIT
Goto FIN_DEFILE
Return

$DEB_DEFILE
Gosub ABORT
If !OK : Return : Endif
If VERROU : Gosub DEVERROU : Endif
If [M:BCR]BUDCAT=1 : # Period
 DEFILE = find(2,[M]DEFIL(0..INDDIE))
Else
 If INDDIE>1
  DEFILE = find(2,[M:BUD]DEFIL(0..INDDIE-1))
 Else
  DEFILE = 1
 Endif
Endif
Call LECTURE("BUP",[M:BCR]BUD(0),"") From CONTOBJ
Call LECTURE("FIY",num$([M:BCR]LEDTYP(0)),[M:BCR]CPY(0)+'~'+num$([M:BCR]FIYSTR(0))) From CONTOBJ

## Clecur(0)=sté Clecur(1)=exo Clecur(2)=compte Clecur(3)=axe1 Clecur(4)=axe2 Clecur(5)=axe3 ...
## Pour les budgets par période et par compte
##   defile=1 si défilement par compte / defile=2 si défilement sur axe1
##   defile=3 si défilement sur axe2   / defile=4 si défilement sur axe3
## Pour les budgets par section
##   defile=1 si défilement sur axe1 / defile=2 si défilement sur axe2
##   defile=3 si défilement sur axe3
## Pour faire correspondre defile et l'indice de Clecur on maj la variable I_DEF

Case [M:BCR]BUDCAT
 When 1 : Gosub DEFCRITPER From BUDGET2 : I_DEF = DEFILE+1
 When 2 : Gosub DEFCRITACC From BUDGET2 : I_DEF = DEFILE+1
 When 3 : Gosub DEFCRITCCE From BUDGET2 : I_DEF = DEFILE+2
Endcase
Return

$INIDIE
If [F:BUP]PYMCCE(I)=""
 Call LECTURE("DIE",[F:BUP]DIE(I),"") From CONTOBJ
 Assign " [M:BUD]DIE"+num$(I+1) With [F:DIE]DIE
 Case I
  When 0 : [M:BUD]INTITCCE1 = ""
           Call LECTEXTRA([M:BUD]INTITCCE1,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE1=""
            [M:BUD]INTITCCE1 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 1 : [M:BUD]INTITCCE2 = ""
           Call LECTEXTRA([M:BUD]INTITCCE2,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE2=""
            [M:BUD]INTITCCE2 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 2 : [M:BUD]INTITCCE3 = ""
           Call LECTEXTRA([M:BUD]INTITCCE3,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE3=""
            [M:BUD]INTITCCE3 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 3 : [M:BUD]INTITCCE4 = ""
           Call LECTEXTRA([M:BUD]INTITCCE4,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE4=""
            [M:BUD]INTITCCE4 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 4 : [M:BUD]INTITCCE5 = ""
           Call LECTEXTRA([M:BUD]INTITCCE5,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE5=""
            [M:BUD]INTITCCE5 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 5 : [M:BUD]INTITCCE6 = ""
           Call LECTEXTRA([M:BUD]INTITCCE6,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE6=""
            [M:BUD]INTITCCE6 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 6 : [M:BUD]INTITCCE7 = ""
           Call LECTEXTRA([M:BUD]INTITCCE7,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE7=""
            [M:BUD]INTITCCE7 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 7 : [M:BUD]INTITCCE8 = ""
           Call LECTEXTRA([M:BUD]INTITCCE8,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE8=""
            [M:BUD]INTITCCE8 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
  When 8 : [M:BUD]INTITCCE9 = ""
           Call LECTEXTRA([M:BUD]INTITCCE9,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
           If [M:BUD]INTITCCE9=""
            [M:BUD]INTITCCE9 = mess(17,103,1)-[F:BUP]DIE(I)
           Endif
 Endcase
Else
 Call LECTURE("CYM",[F:BUP]PYMCCE(I),"") From CONTOBJ
 Assign "[M:BUD]DIE"+num$(I+1) With [F:CYM]PYM
 Case I
  When 0 : Call LECTEXTRA([M:BUD]INTITCCE1,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE1=""
            [M:BUD]INTITCCE1 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 1 : Call LECTEXTRA([M:BUD]INTITCCE2,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE2=""
            [M:BUD]INTITCCE2 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 2 : Call LECTEXTRA([M:BUD]INTITCCE3,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE3=""
            [M:BUD]INTITCCE3 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 3 : Call LECTEXTRA([M:BUD]INTITCCE4,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE4=""
            [M:BUD]INTITCCE4 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 4 : Call LECTEXTRA([M:BUD]INTITCCE5,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE5=""
            [M:BUD]INTITCCE5 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 5 : Call LECTEXTRA([M:BUD]INTITCCE6,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE6=""
            [M:BUD]INTITCCE6 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 6 : Call LECTEXTRA([M:BUD]INTITCCE7,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE7=""
            [M:BUD]INTITCCE7 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 7 : Call LECTEXTRA([M:BUD]INTITCCE8,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE8=""
            [M:BUD]INTITCCE8 = mess(34,103,1)-[F:CYM]PYM
           Endif
  When 8 : Call LECTEXTRA([M:BUD]INTITCCE9,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
           If [M:BUD]INTITCCE9=""
            [M:BUD]INTITCCE9 = mess(34,103,1)-[F:CYM]PYM
           Endif
 Endcase
Endif
Return

$INIDIE_COMPTE
# 83749 The dimension type displayed in the first column is stored in DIE9. In a budget/account DIE9 is always invisible
[M:BUD]DIE9 = [F:BUP]DIE(INDDIE-1)
If INDDIE>1
 # INDDIE -2 because the last dimension is in the column
 For I=0 To INDDIE-2
  If [F:BUP]PYMCCE(I)=""
   Assign "[M:BUD]DIE"+num$(I+1) With [F:BUP]DIE(I)
   Call LECTURE("DIE",[F:BUP]DIE(I),"") From CONTOBJ
   Case I
    When 0 : [M:BUD]INTITCCE1 = ""
             Call LECTEXTRA([M:BUD]INTITCCE1,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE1=""
              [M:BUD]INTITCCE1 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 1 : [M:BUD]INTITCCE2 = ""
             Call LECTEXTRA([M:BUD]INTITCCE2,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE2=""
              [M:BUD]INTITCCE2 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 2 : [M:BUD]INTITCCE3 = ""
             Call LECTEXTRA([M:BUD]INTITCCE3,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE3=""
              [M:BUD]INTITCCE3 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 3 : [M:BUD]INTITCCE4 = ""
             Call LECTEXTRA([M:BUD]INTITCCE4,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE4=""
              [M:BUD]INTITCCE4 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 4 : [M:BUD]INTITCCE5 = ""
             Call LECTEXTRA([M:BUD]INTITCCE5,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE5=""
              [M:BUD]INTITCCE5 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 5 : [M:BUD]INTITCCE6 = ""
             Call LECTEXTRA([M:BUD]INTITCCE6,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE6=""
              [M:BUD]INTITCCE6 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 6 : [M:BUD]INTITCCE7 = ""
             Call LECTEXTRA([M:BUD]INTITCCE7,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE7=""
              [M:BUD]INTITCCE7 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
    When 7 : [M:BUD]INTITCCE8 = ""
             Call LECTEXTRA([M:BUD]INTITCCE8,"GDIE","DESTRA",[F:DIE]DIE,"") From ATEXTRA
             If [M:BUD]INTITCCE8=""
              [M:BUD]INTITCCE8 = mess(17,103,1)-[F:BUP]DIE(I)
             Endif
   Endcase
  Else
   Call LECTURE("CYM",[F:BUP]PYMCCE(I),"") From CONTOBJ
   Assign "[M:BUD]DIE"+num$(I+1) With [F:CYM]PYM
   Case I
    When 0 : Call LECTEXTRA([M:BUD]INTITCCE1,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE1=""
              [M:BUD]INTITCCE1 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 1 : Call LECTEXTRA([M:BUD]INTITCCE2,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE2=""
              [M:BUD]INTITCCE2 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 2 : Call LECTEXTRA([M:BUD]INTITCCE3,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE3=""
              [M:BUD]INTITCCE3 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 3 : Call LECTEXTRA([M:BUD]INTITCCE4,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE4=""
              [M:BUD]INTITCCE4 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 4 : Call LECTEXTRA([M:BUD]INTITCCE5,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE5=""
              [M:BUD]INTITCCE5 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 5 : Call LECTEXTRA([M:BUD]INTITCCE6,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE6=""
              [M:BUD]INTITCCE6 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 6 : Call LECTEXTRA([M:BUD]INTITCCE7,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE7=""
              [M:BUD]INTITCCE7 = mess(34,103,1)-[F:CYM]PYM
             Endif
    When 7 : Call LECTEXTRA([M:BUD]INTITCCE8,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From ATEXTRA
             If [M:BUD]INTITCCE8=""
              [M:BUD]INTITCCE8 = mess(34,103,1)-[F:CYM]PYM
             Endif
   Endcase
  Endif
 Next
Endif
Return

