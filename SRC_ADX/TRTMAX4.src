          [F:SCL1]SCLCRY = [F:AIN]CRY
          [F:SCL1]SCLSAT = [F:AIN]SAT
          [F:SCL1]SCLZIP = [F:AIN]ZIP
          [F:SCL1]SCLCTY = [F:AIN]CTY
        Endif
      Endif
      Write [SCL1]
      If fstat Then
        Rollback
        GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
        GERR = 1
        IPBL = 1
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZRECNUM = [F:SCL2]RECNUM
      SZBPRNUM = [F:SCL2]BPRNUM
      STOPLOOP = 1
      Break
    Endif
  Next
  If STOPLOOP Then
    Goto SNAPLOOP5
  Endif 
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #Alimente l'échantillon tampon sur la base d'une lecture dans l'échantillon de gauche.
  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  IUSESCLCOD = 0
  IC = 0
  Raz ICCNADDEMP
  SZRECNUM = ""
  SZBPRNUM = ""
  #
$SNAPLOOP6
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' + " & [F:SCL2]RECNUM = SZRECNUM & [F:SCL2]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' + " & [F:SCL2]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL2] Where evalue(LOOPCRIT) Order By [F:SCL2]RECNUM Asc; [F:SCL2]BPRNUM Asc
  For [SCL2] Hint Key SCL0
    Read [SCL1]SCL2=SZOPGCOD;"CCN";[F:SCL2]RECNUM;[F:SCL2]BPRNUM
    If fstat Then
      #On ajoute cet enregistrement dans l'échantillon tampon
      If IPERF = 0 Then
