  Filter [SCL2]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon de gauche
  Call DEBTRANS From GLOCK
  Trbegin [SCL1]
  Delete [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP = "CCN"
  If fstat Then
    Rollback
    GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
    GERR = 1
    End
  Else
    Commit
  Endif
  If GERR Then
    End
  Endif
  #On recrée l'échantillon de gauche sur la base de l'échantillon tampon
  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  IC = 0
