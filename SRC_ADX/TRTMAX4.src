            [F:SCL1]SCLCTY = [F:BPA]CTY
          Endif
        Endif
      Else
        #L'adresse du contact doit être chargée.
        Read [AIN]AIN0=[F:SCL1]RECNUM
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
        Else
          [F:SCL1]SCLCRY = [F:AIN]CRY
          [F:SCL1]SCLSAT = [F:AIN]SAT
          [F:SCL1]SCLZIP = [F:AIN]ZIP
          [F:SCL1]SCLCTY = [F:AIN]CTY
