#<AdxTL>@(#)9.0.0.0 $Revision$
##########################################################################################################
# Récupération de sélection                                        Module CRM          04 décembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$PREMIER
  If GIMAX4NBSEC <= dim([M:MAX4]OPGDES) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADSEC(1)
  Affzo [M:MAX4]1-99
Return

##########################################################################################################
$PRECEDENT
  If GIMAX4NBSEC <= dim([M:MAX4]OPGDES) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADSEC(2)
  Affzo [M:MAX4]1-99
Return

##########################################################################################################
$SUIVANT
  If GIMAX4NBSEC <= dim([M:MAX4]OPGDES) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADSEC(3)
  Affzo [M:MAX4]1-99
Return

##########################################################################################################
$DERNIER
  If GIMAX4NBSEC <= dim([M:MAX4]OPGDES) Then
    #Tous les éléments sont affichés dans le tableau.
    GMESSAGE = mess(712,196,1)
    GERR = 2
    Return
  Endif
  Call LOADSEC(4)
  Affzo [M:MAX4]1-99
Return

##########################################################################################################
$OUVRE
Global Date GDMAX4FDAT 
Global Char GSZMAX4FNUM
Global Date GDMAX4LDAT 
Global Char GSZMAX4LNUM
Global Char GSZINTUNI
Global Char GSZTYPPRO
Global Char GSZPREOPG
Global Integer GIMAX4NOL
Global Integer GIMAX4NBSEC

  GDMAX4FDAT = [00/00/00]
  GSZMAX4FNUM = ""
  GDMAX4LDAT = [00/00/00]
  GSZMAX4LNUM = ""
  GIMAX4NOL = 0
  GSZPREOPG = ""
  GIMAX4NBSEC = 0
  GSZTYPPRO = PARAM(1) # Intersection ou Union demandée (INTER ou UNION)
  If GSZTYPPRO = "INTER" Then
    GSZINTUNI = mess(359,196,1) #Intersection avec
  Elsif GSZTYPPRO = "UNION" Then
    GSZINTUNI = mess(360,196,1) #Union avec
  Elsif GSZTYPPRO = "UNIONX" Then
    GSZINTUNI = mess(795,196,1) #Union exclusive
  Elsif GSZTYPPRO = "INTERX" Then
    GSZINTUNI = mess(796,196,1) #Intersection exclusive
  Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:MOG]) : Local File MKGOPG [MOG] : Endif
  If !clalev([F:MQP]) : Local File MKGQURPPL [MQP] : Endif
  If !clalev([F:SSP]) : Local File SELSSP [SSP] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Call LOADSEC(1)
  Affzo [M:MAX4]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Raz [M:MAX4]
  Kill GSZPREOPG
  Kill GSZTYPPRO
  Kill GSZINTUNI
  Kill GIMAX4NOL
  Kill GDMAX4FDAT 
  Kill GSZMAX4FNUM
  Kill GDMAX4LDAT 
  Kill GSZMAX4LNUM
  Kill GIMAX4NBSEC
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
#########################################################
##########################################################################################################
# Chargement du tableau des sélections existantes
#########################################################
Subprog LOADSEC(IWHATTODO)
Value Integer IWHATTODO

Local Integer IFEEDMGC1
Local Integer IFIRLOOP
Local Integer IPRECNT
Local Integer ICANFOR
Local Integer IT
Local Integer IZ
Local Integer IDISPSEC

  IFEEDMGC1 = 1
  IFIRLOOP = 0
  IPRECNT = 0
  ICANFOR = 0
  IT = 0
  IZ = 0
  IDISPSEC = 0
  Call RAZMAX4
  If IWHATTODO = 1 Then
    GIMAX4NBSEC = 0
    If GSZTYPSEA = "CCN" Then
      Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR= 2 and [F:SEC]OPGNUM <> GSZOPGNUM Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
    Elsif GSZTYPSEA = "BPR" Then
      Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 1 and [F:SEC]OPGNUM <> GSZOPGNUM Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
    Endif
    For [SEC]
      If IT < dim([M:MAX4]OPGNUM) Then
        IDISPSEC = 0
        Case [F:SEC]OPGTYP
          When "OMM"
            Read [OMM]OMM0=[F:SEC]OPGNUM
            If !fstat Then
              [M:MAX4]OPGDES(IT) = [F:OMM]DES
              Read [CMG]CMG0=[F:OMM]CMGNUM
              If !fstat Then
                [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
              Endif
              If [F:OMM]CREDAT <> [00/00/00] Then
                [M:MAX4]CREDAT(IT) = [F:OMM]CREDAT
              Endif
              If [F:OMM]CREUSR <> "" Then
                Read [AUS]CODUSR=[F:OMM]CREUSR
                If fstat Then
                  [M:MAX4]CREUSR(IT) = [F:OMM]CREUSR
                Else
                  [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                Endif
              Endif
              IDISPSEC = 1
            Endif
          When "OMP"
            Read [OMP]OMP0=[F:SEC]OPGNUM
            If !fstat Then
              [M:MAX4]OPGDES(IT) = [F:OMP]DES
              Read [CMG]CMG0=[F:OMP]CMGNUM
              If !fstat Then
                [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
              Endif
              If [F:OMP]CREDAT <> [00/00/00] Then
                [M:MAX4]CREDAT(IT) = [F:OMP]CREDAT
              Endif
              If [F:OMP]CREUSR <> "" Then
                Read [AUS]CODUSR=[F:OMP]CREUSR
                If fstat Then
                  [M:MAX4]CREUSR(IT) = [F:OMP]CREUSR
                Else
                  [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                Endif
              Endif
              IDISPSEC = 1
            Endif
          When Default
        Endcase
        If IDISPSEC Then
          If IT = 0 Then
            GDMAX4FDAT = [F:SEC]SELDAT
            GSZMAX4FNUM = [F:SEC]OPGNUM
          Endif
          GDMAX4LDAT = [F:SEC]SELDAT
          GSZMAX4LNUM = [F:SEC]OPGNUM
          [M:MAX4]OPGNUM(IT) = [F:SEC]OPGNUM
          [M:MAX4]OPGTYP(IT) = [F:SEC]OPGTYP
          [M:MAX4]NBXOPG += 1
          IT += 1
        Endif
        GIMAX4NBSEC += 1
      Else
        GIMAX4NBSEC += 1
      Endif
    Next
    Filter [SEC]
  Endif
  If IWHATTODO = 2 Then
    #Précédent
    While IFEEDMGC1
      If IFIRLOOP = 0 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR= 2 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]OPGNUM > GSZMAX4FNUM and [F:SEC]SELDAT = GDMAX4FDAT
&                   Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 1 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]OPGNUM > GSZMAX4FNUM and [F:SEC]SELDAT = GDMAX4FDAT
&                   Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 1 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 2 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]SELDAT > GDMAX4FDAT
&                   Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 1 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]SELDAT > GDMAX4FDAT
&                   Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
        Endif            
        IFIRLOOP += 1
        IFEEDMGC1 = 0
      Endif
      If !ICANFOR Then
        IFEEDMGC1 = 1
        For [SEC]
          If IT >= dim([M:MAX4]OPGNUM)-1 Then
            ICANFOR = 1
            IFIRLOOP = 0
            Break
          Endif
          IT += 1
        Next
        IPRECNT += 1
        If IPRECNT >= 6 Then
          ICANFOR = 1
          IFIRLOOP = 0
        Endif
      Else
        For [SEC]
          If IT >= 0 Then
            IDISPSEC = 0
            Case [F:SEC]OPGTYP
              When "OMM"
                Read [OMM]OMM0=[F:SEC]OPGNUM
                If !fstat Then
                  [M:MAX4]OPGDES(IT) = [F:OMM]DES
                  Read [CMG]CMG0=[F:OMM]CMGNUM
                  If !fstat Then
                    [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
                  Endif
                  If [F:OMM]CREDAT <> [00/00/00] Then
                    [M:MAX4]CREDAT(IT) = [F:OMM]CREDAT
                  Endif
                  If [F:OMM]CREUSR <> "" Then
                    Read [AUS]CODUSR=[F:OMM]CREUSR
                    If fstat Then
                      [M:MAX4]CREUSR(IT) = [F:OMM]CREUSR
                    Else
                      [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                    Endif
                  Endif
                  IDISPSEC = 1
                Endif
              When "OMP"
                Read [OMP]OMP0=[F:SEC]OPGNUM
                If !fstat Then
                  [M:MAX4]OPGDES(IT) = [F:OMP]DES
                  Read [CMG]CMG0=[F:OMP]CMGNUM
                  If !fstat Then
                    [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
                  Endif
                  If [F:OMP]CREDAT <> [00/00/00] Then
                    [M:MAX4]CREDAT(IT) = [F:OMP]CREDAT
                  Endif
                  If [F:OMP]CREUSR <> "" Then
                    Read [AUS]CODUSR=[F:OMP]CREUSR
                    If fstat Then
                      [M:MAX4]CREUSR(IT) = [F:OMP]CREUSR
                    Else
                      [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                    Endif
                  Endif
                  IDISPSEC = 1
                Endif
              When Default
            Endcase
            If IDISPSEC Then
              If [M:MAX4]NBXOPG = 0 Then
                GDMAX4LDAT = [F:SEC]SELDAT
                GSZMAX4LNUM = [F:SEC]OPGNUM
              Endif
              GDMAX4FDAT = [F:SEC]SELDAT
              GSZMAX4FNUM = [F:SEC]OPGNUM
              [M:MAX4]OPGNUM(IT) = [F:SEC]OPGNUM
              [M:MAX4]OPGTYP(IT) = [F:SEC]OPGTYP
              IT -= 1
              IZ += 1
              [M:MAX4]NBXOPG += 1
            Endif
          Else
            Break
          Endif
        Next
      Endif
      Filter [SEC]
      If IT < 0 Then
        Break
      Endif
      If IZ >= dim([M:MAX4]OPGNUM) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 3 Then
    While IFEEDMGC1
      If IFIRLOOP = 0 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 2 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]OPGNUM < GSZMAX4LNUM and [F:SEC]SELDAT = GDMAX4LDAT
&                   Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 1 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]OPGNUM < GSZMAX4LNUM and [F:SEC]SELDAT = GDMAX4LDAT
&                   Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
        Endif
        IFIRLOOP += 1
      Elsif IFIRLOOP = 1 Then
        If GSZTYPSEA = "CCN" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 2 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]SELDAT < GDMAX4LDAT
&                   Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
        Elsif GSZTYPSEA = "BPR" Then
          Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR  = 1 and [F:SEC]OPGNUM <> GSZOPGNUM and [F:SEC]SELDAT < GDMAX4LDAT
&                   Order By [F:SEC]SELDAT Desc; [F:SEC]OPGNUM Desc
        Endif            
        IFIRLOOP += 1
        IFEEDMGC1 = 0
      Endif
      For [SEC]
        If IT >= dim([M:MAX4]OPGNUM) Then
          Break
        Endif
        IDISPSEC = 0
        Case [F:SEC]OPGTYP
          When "OMM"
            Read [OMM]OMM0=[F:SEC]OPGNUM
            If !fstat Then
              [M:MAX4]OPGDES(IT) = [F:OMM]DES
              Read [CMG]CMG0=[F:OMM]CMGNUM
              If !fstat Then
                [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
              Endif
              If [F:OMM]CREDAT <> [00/00/00] Then
                [M:MAX4]CREDAT(IT) = [F:OMM]CREDAT
              Endif
              If [F:OMM]CREUSR <> "" Then
                Read [AUS]CODUSR=[F:OMM]CREUSR
                If fstat Then
                  [M:MAX4]CREUSR(IT) = [F:OMM]CREUSR
                Else
                  [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                Endif
              Endif
              IDISPSEC = 1
            Endif
          When "OMP"
            Read [OMP]OMP0=[F:SEC]OPGNUM
            If !fstat Then
              [M:MAX4]OPGDES(IT) = [F:OMP]DES
              Read [CMG]CMG0=[F:OMP]CMGNUM
              If !fstat Then
                [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
              Endif
              If [F:OMP]CREDAT <> [00/00/00] Then
                [M:MAX4]CREDAT(IT) = [F:OMP]CREDAT
              Endif
              If [F:OMP]CREUSR <> "" Then
                Read [AUS]CODUSR=[F:OMP]CREUSR
                If fstat Then
                  [M:MAX4]CREUSR(IT) = [F:OMP]CREUSR
                Else
                  [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
                Endif
              Endif
              IDISPSEC = 1
            Endif
          When Default
        Endcase
        If IDISPSEC Then
          If IT = 0 Then
            GDMAX4FDAT = [F:SEC]SELDAT
            GSZMAX4FNUM = [F:SEC]OPGNUM
          Endif
          GDMAX4LDAT = [F:SEC]SELDAT
          GSZMAX4LNUM = [F:SEC]OPGNUM
          [M:MAX4]OPGNUM(IT) = [F:SEC]OPGNUM
          [M:MAX4]OPGTYP(IT) = [F:SEC]OPGTYP
          [M:MAX4]NBXOPG += 1
          IT += 1
        Endif
      Next
      Filter [SEC]
      If IT >= dim([M:MAX4]OPGNUM) Then
        Break
      Endif
    Wend
  Elsif IWHATTODO = 4 Then
    #Dernier
    If GSZTYPSEA = "CCN" Then
      Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR= 2 and [F:SEC]OPGNUM <> GSZOPGNUM Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
    Elsif GSZTYPSEA = "BPR" Then
      Filter [SEC] Where [F:SEC]SELTBL = "CCN" and [F:SEC]USEQUR = 1 and [F:SEC]OPGNUM <> GSZOPGNUM Order By [F:SEC]SELDAT Asc; [F:SEC]OPGNUM Asc
    Endif
    IT = dim([M:MAX4]OPGNUM)-1
    For [SEC]
      If IT < 0 Then
        Break
      Endif
      IDISPSEC = 0
      Case [F:SEC]OPGTYP
        When "OMM"
          Read [OMM]OMM0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]OPGDES(IT) = [F:OMM]DES
            Read [CMG]CMG0=[F:OMM]CMGNUM
            If !fstat Then
              [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
            Endif
            If [F:OMM]CREDAT <> [00/00/00] Then
              [M:MAX4]CREDAT(IT) = [F:OMM]CREDAT
            Endif
            If [F:OMM]CREUSR <> "" Then
              Read [AUS]CODUSR=[F:OMM]CREUSR
              If fstat Then
                [M:MAX4]CREUSR(IT) = [F:OMM]CREUSR
              Else
                [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
              Endif
            Endif
            IDISPSEC = 1
          Endif
        When "OMP"
          Read [OMP]OMP0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]OPGDES(IT) = [F:OMP]DES
            Read [CMG]CMG0=[F:OMP]CMGNUM
            If !fstat Then
              [M:MAX4]CMGTTR(IT) = [F:CMG]TTR
            Endif
            If [F:OMP]CREDAT <> [00/00/00] Then
              [M:MAX4]CREDAT(IT) = [F:OMP]CREDAT
            Endif
            If [F:OMP]CREUSR <> "" Then
              Read [AUS]CODUSR=[F:OMP]CREUSR
              If fstat Then
                [M:MAX4]CREUSR(IT) = [F:OMP]CREUSR
              Else
                [M:MAX4]CREUSR(IT) = [F:AUS]NOMUSR
              Endif
            Endif
            IDISPSEC = 1
          Endif
        When Default
      Endcase
      If IDISPSEC Then
        If [M:MAX4]NBXOPG = 0 Then
          GDMAX4LDAT = [F:SEC]SELDAT
          GSZMAX4LNUM = [F:SEC]OPGNUM
        Endif
        GDMAX4FDAT = [F:SEC]SELDAT
        GSZMAX4FNUM = [F:SEC]OPGNUM
        [M:MAX4]OPGNUM(IT) = [F:SEC]OPGNUM
        [M:MAX4]OPGTYP(IT) = [F:SEC]OPGTYP
        [M:MAX4]NBXOPG += 1
        IT -= 1
      Endif
    Next
    Filter [SEC]
  Endif
End

##########################################################################################################
Subprog RAZMAX4
  Raz [M:MAX4]NBXOPG
  Raz [M:MAX4]OPGDES
  Raz [M:MAX4]CMGTTR
  Raz [M:MAX4]CREDAT
  Raz [M:MAX4]CREUSR
  Raz [M:MAX4]OPGNUM
  Raz [M:MAX4]OPGTYP
  Raz [M:MAX4]SELDAT
  Raz [M:MAX4]SELTBL
  Raz [M:MAX4]SELREC
  Raz [M:MAX4]SELOBJ
  Raz [M:MAX4]NBDESBPR
  Raz [M:MAX4]PPLDESBPR
  Raz [M:MAX4]NBDESCCN
  Raz [M:MAX4]PPLDESCCN
End

##########################################################################################################
$ONOK
  Local File SELCMGLIS [SCL1]
  Local File SELCMGLIS [SCL2]
  Call TEMPON("C") From GESECRAN
  If GSZTYPPRO = "INTER" Then
    Call INTERSEC([M:MAX4]OPGNUM(GIMAX4NOL))
  Elsif GSZTYPPRO = "UNION" Then
    Call UNION([M:MAX4]OPGNUM(GIMAX4NOL))
  Elsif GSZTYPPRO = "UNIONX" Then
    Call UNIONX([M:MAX4]OPGNUM(GIMAX4NOL))
  Elsif GSZTYPPRO = "INTERX" Then
    Call INTERX([M:MAX4]OPGNUM(GIMAX4NOL))
  Endif
  Call TEMPOFF From GESECRAN
  Close Local File [SCL1]
  Close Local File [SCL2]
  Call LOADRESULT(1,1) From TRTMAI4
  Affzo [M:MAI4]1-99
Return

##########################################################################################################
# Chargement des caractéristiques de la sélection sélectionnée.
#########################################################
Subprog LOADOPGINF(SZOPGNUM)
Value Char SZOPGNUM

Local Char SZQUR
Local Char SZPPLDESTYP

  SZQUR = ""
  SZPPLDESTYP = ""
  Raz [M:MAX4]SELDAT
  Raz [M:MAX4]SELTBL
  Raz [M:MAX4]SELREC
  Raz [M:MAX4]SELOBJ
  Raz [M:MAX4]NBDESBPR
  Raz [M:MAX4]PPLDESBPR
  Raz [M:MAX4]NBDESCCN
  Raz [M:MAX4]PPLDESCCN
  If GSZTYPSEA = "CCN" Then
    Read [SEC]SEC0=SZOPGNUM;"CCN"
    If !fstat Then
      [M:MAX4]SELDAT = [F:SEC]SELDAT
      [M:MAX4]SELTBL = 3
      [M:MAX4]SELREC = [F:SEC]SELREC
      Case [F:SEC]OPGTYP
        When "OMM"
          Read [OMM]OMM0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]SELOBJ = [F:OMM]OBJ
          Endif
        When "OMP"
          Read [OMP]OMP0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]SELOBJ = [F:OMP]OBJ
          Endif
        When Default
      Endcase
      #Recherche le ciblage associé à l'opération
      Filter [MOG] Where [F:MOG]OPGNUM = [F:SEC]OPGNUM and [F:MOG]TGR = "CONTACTCRM"
      For [MOG] MOG2
        SZPPLDESTYP = "CCN"
        SZQUR = [F:MOG]MKGQUR
        Gosub DISPPPLDES
        Break
      Next
      Filter [MOG]
      Filter [SEC] Where [F:SEC]OPGNUM = SZOPGNUM and [F:SEC]SELTBL <> "CCN"
      For [SEC]
        #Recherche le ciblage associé à l'opération
        Filter [MOG] Where [F:MOG]OPGNUM = [F:SEC]OPGNUM and [F:MOG]TGR <> "CONTACTCRM"
        For [MOG] MOG2
          SZPPLDESTYP = "BPR"
          SZQUR = [F:MOG]MKGQUR
          Gosub DISPPPLDES
          Break
        Next
        Filter [MOG]
        Break
      Next
      Filter [SEC]
    Endif
  Elsif GSZTYPSEA = "BPR" Then
    Filter [SEC] Where [F:SEC]OPGNUM = SZOPGNUM and [F:SEC]SELTBL <> "CCN"
    For [SEC]
      [M:MAX4]SELDAT = [F:SEC]SELDAT
      [M:MAX4]SELTBL = 2
      [M:MAX4]SELREC = [F:SEC]SELREC
      Case [F:SEC]OPGTYP
        When "OMM"
          Read [OMM]OMM0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]SELOBJ = [F:OMM]OBJ
          Endif
        When "OMP"
          Read [OMP]OMP0=[F:SEC]OPGNUM
          If !fstat Then
            [M:MAX4]SELOBJ = [F:OMP]OBJ
          Endif
        When Default
      Endcase
      #Recherche le ciblage associé à l'opération
      Filter [MOG] Where [F:MOG]OPGNUM = [F:SEC]OPGNUM and [F:MOG]TGR <> "CONTACTCRM"
      For [MOG] MOG2
        SZPPLDESTYP = "BPR"
        SZQUR = [F:MOG]MKGQUR
        Gosub DISPPPLDES
        Break
      Next
      Filter [MOG]
      Break
    Next
    Filter [SEC]
  Endif
End

##########################################################################################################
#Affiche le résumé du ciblage
####################################################################
$DISPPPLDES
Local Integer ISUMUPITER
Local Integer INBSUM
Local Char SZOPER
Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZTEXTE(GLONDCO)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  ISUMUPITER = 0
  INBSUM = 0
  SZOPER = ""
  Filter [MQP] Where [F:MQP]QURNUM = SZQUR
  For [MQP] MQP1
    If [F:MQP]PPLSELSPT = "" Then
      Break
    Endif
    If [F:MQP]PPLOPD > 1 Then
      SZOPER = mess([F:MQP]PPLOPD,2959,1)
      If [F:MQP]PPLDES = "" Then
        Read [SSP]SSP0=[F:MQP]PPLSELSPT
        If fstat Then
          If SZPPLDESTYP = "BPR" Then
            [M:MAX4]PPLDESBPR(ISUMUPITER) = SZOPER
          Elsif SZPPLDESTYP = "CCN" Then
            [M:MAX4]PPLDESCCN(ISUMUPITER) = SZOPER
          Endif
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          If SZPPLDESTYP = "BPR" Then
            [M:MAX4]PPLDESBPR(ISUMUPITER) = SZOPER - SZTEXTE
          Elsif SZPPLDESTYP = "CCN" Then
            [M:MAX4]PPLDESCCN(ISUMUPITER) = SZOPER - SZTEXTE
          Endif
        Endif
      Else
        If SZPPLDESTYP = "BPR" Then
          [M:MAX4]PPLDESBPR(ISUMUPITER) = SZOPER - left$([F:MQP]PPLDES, 108-len(SZOPER))
        Elsif SZPPLDESTYP = "CCN" Then
          [M:MAX4]PPLDESCCN(ISUMUPITER) = SZOPER - left$([F:MQP]PPLDES, 108-len(SZOPER))
        Endif
      Endif
    Else
      If [F:MQP]PPLDES = "" Then
        Read [SSP]SSP0=[F:MQP]PPLSELSPT
        If fstat Then
          If SZPPLDESTYP = "BPR" Then
            [M:MAX4]PPLDESBPR(ISUMUPITER) = ""
          Elsif SZPPLDESTYP = "CCN" Then
            [M:MAX4]PPLDESCCN(ISUMUPITER) = ""
          Endif
        Else
          Call LECTEXTRA(SZTEXTE, "SELSSP", "SPTNAMAXX", [F:SSP]SPTNUM, "") From ATEXTRA
          If SZPPLDESTYP = "BPR" Then
            [M:MAX4]PPLDESBPR(ISUMUPITER) = SZTEXTE
          Elsif SZPPLDESTYP = "CCN" Then
            [M:MAX4]PPLDESCCN(ISUMUPITER) = SZTEXTE
          Endif
        Endif
      Else
        If SZPPLDESTYP = "BPR" Then
          [M:MAX4]PPLDESBPR(ISUMUPITER) = left$([F:MQP]PPLDES, 110)
        Elsif SZPPLDESTYP = "CCN" Then
          [M:MAX4]PPLDESCCN(ISUMUPITER) = left$([F:MQP]PPLDES, 110)
        Endif
      Endif
    Endif
    #On enlève les retours chariots et les line feed de la ligne
    If SZPPLDESTYP = "BPR" Then
      While instr(1, [M:MAX4]PPLDESBPR(ISUMUPITER), chr$(10))
        ISTR = instr(1, [M:MAX4]PPLDESBPR(ISUMUPITER), chr$(10))
        SZ1 = left$([M:MAX4]PPLDESBPR(ISUMUPITER), ISTR - len(chr$(10)))
        SZ2 = right$([M:MAX4]PPLDESBPR(ISUMUPITER), ISTR + 1)
        SZ3 = SZ1 + SZ2
        [M:MAX4]PPLDESBPR(ISUMUPITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 10000 Then
          Break
        Endif
      Wend
    Elsif SZPPLDESTYP = "CCN" Then
      While instr(1, [M:MAX4]PPLDESCCN(ISUMUPITER), chr$(10))
        ISTR = instr(1, [M:MAX4]PPLDESCCN(ISUMUPITER), chr$(10))
        SZ1 = left$([M:MAX4]PPLDESCCN(ISUMUPITER), ISTR - len(chr$(10)))
        SZ2 = right$([M:MAX4]PPLDESCCN(ISUMUPITER), ISTR + 1)
        SZ3 = SZ1 + SZ2
        [M:MAX4]PPLDESCCN(ISUMUPITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 10000 Then
          Break
        Endif
      Wend
    Endif
    ISTR = 0
    SZ1 = ""
    SZ2 = ""
    SZ3 = ""
    If SZPPLDESTYP = "BPR" Then
      While instr(1, [M:MAX4]PPLDESBPR(ISUMUPITER), chr$(13))
        ISTR = instr(1, [M:MAX4]PPLDESBPR(ISUMUPITER), chr$(13))
        SZ1 = left$([M:MAX4]PPLDESBPR(ISUMUPITER), ISTR - len(chr$(13)))
        SZ2 = right$([M:MAX4]PPLDESBPR(ISUMUPITER), ISTR + 1)
        SZ3 = SZ1 - SZ2
        [M:MAX4]PPLDESBPR(ISUMUPITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 20000 Then
          Break
        Endif
      Wend
    Elsif SZPPLDESTYP = "CCN" Then
      While instr(1, [M:MAX4]PPLDESCCN(ISUMUPITER), chr$(13))
        ISTR = instr(1, [M:MAX4]PPLDESCCN(ISUMUPITER), chr$(13))
        SZ1 = left$([M:MAX4]PPLDESCCN(ISUMUPITER), ISTR - len(chr$(13)))
        SZ2 = right$([M:MAX4]PPLDESCCN(ISUMUPITER), ISTR + 1)
        SZ3 = SZ1 - SZ2
        [M:MAX4]PPLDESCCN(ISUMUPITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 20000 Then
          Break
        Endif
      Wend
    Endif
    ISUMUPITER += 1
    If SZPPLDESTYP = "BPR" Then
      [M:MAX4]NBDESBPR += 1
    Elsif SZPPLDESTYP = "CCN"
      [M:MAX4]NBDESCCN += 1
    Endif
  Next
  Filter [MQP]
Return

##########################################################################################################
Subprog INTERSEC(SZOPGCOD)
Value Char SZOPGCOD

  If GSZTYPSEA = "CCN" Then
    Call INTERCCN(SZOPGCOD)
  Elsif GSZTYPSEA = "BPR" Then
    Call INTERBPR(SZOPGCOD)
  Endif
End

##########################################################################################################
Subprog INTERCCN(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
Local Char SZRECNUM
Local Char SZBPRNUM

  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  SZRECNUM = ""
  SZBPRNUM = ""
  #Contrôle l'existence d'un enregistrement de la population de gauche dans celle de droite
$SNAPLOOP1
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:SCL1]OPGNUM = GSZOPGNUM & [F:SCL1]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL1]RECNUM = SZRECNUM & [F:SCL1]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL1]OPGNUM = GSZOPGNUM & [F:SCL1]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL1]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL1]OPGNUM = GSZOPGNUM & [F:SCL1]RECTYP = " + '"' + "CCN" + '"'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL1] Where evalue(LOOPCRIT) Order By [F:SCL1]RECNUM Asc; [F:SCL1]BPRNUM Asc
  For [SCL1] Hint Key SCL0
    Read [SCL2]SCL2=SZOPGCOD;"CCN";[F:SCL1]RECNUM;[F:SCL1]BPRNUM
    If fstat Then
      #On supprime cet enregistrement dans la population de gauche
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL1]
        INTR = 1
      Endif
      Delete [SCL1] Curr
      If fstat Then
        Rollback
        GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
        GERR = 1
        IPBL = 1
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZRECNUM = [F:SCL1]RECNUM
      SZBPRNUM = [F:SCL1]BPRNUM
      STOPLOOP = 1
      Break
    Endif
  Next
  If STOPLOOP Then
    Goto SNAPLOOP1
  Endif 
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL1]
End

##########################################################################################################
Subprog INTERBPR(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Char SZOPGTYP1
Local Char SZOPGTYP2
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  SZOPGTYP1 = ""
  SZOPGTYP2 = ""
  #Obtient le type de la sélection tiers dans la population de droite
  Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP <> "CCN" Order By [F:SCL1]CLSNUM Desc
  For [SCL1] Hint Key SCL0
    SZOPGTYP1 = [F:SCL1]RECTYP
    Break
  Next
  Filter [SCL1]
  #Obtient le type de la sélection tiers dans la population de droite
  Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP <> "CCN" Order By [F:SCL2]RECNUM Asc
  For [SCL2] Hint Key SCL0
    SZOPGTYP2 = [F:SCL2]RECTYP
    Break
  Next
  Filter [SCL2]
  #Contrôle l'existence d'un enregistrement de la population de gauche dans celle de droite
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM & [F:SCL1]RECTYP = SZOPGTYP1 & [F:SCL1]RECNUM > SZLOOPCLE Order By [F:SCL1]RECNUM Asc
    For [SCL1] Hint Key SCL1
      SZLOOPCLE = [F:SCL1]RECNUM
      Read [SCL2]SCL1=SZOPGCOD;SZOPGTYP2;[F:SCL1]RECNUM
      If fstat Then
        #On supprime cet enregistrement dans la population de gauche
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL1]
          INTR = 1
        Endif
        Delete [SCL1] Curr
        If fstat Then
          Rollback
          GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL1]
End

##########################################################################################################
Subprog UNION(SZOPGCOD)
Value Char SZOPGCOD

  If GSZTYPSEA = "CCN" Then
    Call UNIONCCN(SZOPGCOD)
  Elsif GSZTYPSEA = "BPR" Then
    Call UNIONBPR(SZOPGCOD)
  Endif
End

##########################################################################################################
Subprog UNIONCCN(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Integer IUSESCLCOD
Local Integer IC
Local Integer ICCNADDEMP(6)
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
Local Char SZRECNUM
Local Char SZBPRNUM

  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  IUSESCLCOD = 0
  IC = 0
  Raz ICCNADDEMP
  SZRECNUM = ""
  SZBPRNUM = ""
  #Obtient le dernier numéro de chrono dans la population de gauche
  Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP = "CCN" Order By [F:SCL1]CLSNUM Desc
  For [SCL1] Hint Key SCL0
    ILASTCLSNUM = [F:SCL1]CLSNUM
    Break
  Next
  Filter [SCL1]
  #Transfère le complèment résident dans la population de droite dans celle de gauche.
$SNAPLOOP2
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' + " & [F:SCL2]RECNUM = SZRECNUM & [F:SCL2]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' + " & [F:SCL2]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL2] Where evalue(LOOPCRIT) Order By [F:SCL2]RECNUM Asc; [F:SCL2]BPRNUM Asc
  For [SCL2] Hint Key SCL0
    Read [SCL1]SCL2=GSZOPGNUM;"CCN";[F:SCL2]RECNUM;[F:SCL2]BPRNUM
    If fstat Then
      #On ajoute cet enregistrement dans la population de gauche
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL1]
        INTR = 1
      Endif
      ILASTCLSNUM += 1
      [F:SCL1]CLSNUM = ILASTCLSNUM
      [F:SCL1]OPGNUM = GSZOPGNUM
      [F:SCL1]RECTYP = "CCN"
      [F:SCL1]RECNUM = [F:SCL2]RECNUM
      [F:SCL1]BPRNUM = [F:SCL2]BPRNUM
      If GIDEFADD = 2 Then
        [F:SCL1]BPAADD = ""
      Else
        If [F:SCL1]BPRNUM = "" Then
          [F:SCL1]BPAADD = ""
        Else
          Read [BPR]BPR0=[F:SCL1]BPRNUM
          If fstat Then
            [F:SCL1]BPAADD = ""
          Else
            [F:SCL1]BPAADD = [F:BPR]BPAADD
          Endif
        Endif
      Endif
      If [F:SCL1]BPRNUM <> "" Then
        #Un tiers peut être mentionné dans le tableau.
        Read [BPR]BPR0=[F:SCL1]BPRNUM
        If fstat Then
          IUSESCLCOD = 1
        Else
          IUSESCLCOD = 0
        Endif
        If GIDEFADD = 2 Then
          #L'adresse du contact doit être chargée.
          If GIHIEBPR = 2 Then
            #Une affectation hiérarchique d'adresse est demandée.
            #Test si l'adresse contact est complétement vide.
            Read [AIN]AIN0=[F:SCL1]RECNUM
            If fstat Then
              ICCNADDEMP(0) = 1
              ICCNADDEMP(1) = 1
              ICCNADDEMP(2) = 1
              ICCNADDEMP(3) = 1
              ICCNADDEMP(4) = 1
              ICCNADDEMP(5) = 1
              Raz [F:AIN]
            Else
              ICCNADDEMP(0) = 1
              If [F:AIN]ADD(0) = "" Then
                ICCNADDEMP(1) = 1
              Else
                ICCNADDEMP(1) = 0
              Endif
              If [F:AIN]ADD(1) = "" Then
                ICCNADDEMP(2) = 1
              Else
                ICCNADDEMP(2) = 0
              Endif
              If [F:AIN]ADD(2) = "" Then
                ICCNADDEMP(3) = 1
              Else
                ICCNADDEMP(3) = 0
              Endif
              If [F:AIN]ZIP = ""
                ICCNADDEMP(4) = 1
              Else
                ICCNADDEMP(4) = 0
              Endif
              If [F:AIN]CTY = "" Then
                ICCNADDEMP(5) = 1
              Else
                ICCNADDEMP(5) = 0
              Endif
            Endif
            For IC = 1 To dim(ICCNADDEMP)-1
              If ICCNADDEMP(IC) = 0 Then
                ICCNADDEMP(0) = 0
                Break
              Endif
            Next
            If ICCNADDEMP(0) = 1 Then
              #L'adresse contact est complétement vide. On charge l'adresse Tiers
              If IUSESCLCOD Then
                Read [BPA]BPA0=1;[F:SCL2]BPRNUM;[F:SCL2]BPAADD
              Else
                Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
              Endif
              If fstat Then
                [F:SCL1]SCLCRY = ""
                [F:SCL1]SCLSAT = ""
                [F:SCL1]SCLZIP = ""
                [F:SCL1]SCLCTY = ""
              Else
                [F:SCL1]SCLCRY = [F:BPA]CRY
                [F:SCL1]SCLSAT = [F:BPA]SAT
                [F:SCL1]SCLZIP = [F:BPA]POSCOD
                [F:SCL1]SCLCTY = [F:BPA]CTY
              Endif
            Else
              [F:SCL1]SCLCRY = [F:AIN]CRY
              [F:SCL1]SCLSAT = [F:AIN]SAT
              [F:SCL1]SCLZIP = [F:AIN]ZIP
              [F:SCL1]SCLCTY = [F:AIN]CTY
            Endif
          Else
            Read [AIN]AIN0=[F:SCL2]RECNUM
            If fstat Then
              [F:SCL1]SCLCRY = ""
              [F:SCL1]SCLSAT = ""
              [F:SCL1]SCLZIP = ""
              [F:SCL1]SCLCTY = ""
            Else
              [F:SCL1]SCLCRY = [F:AIN]CRY
              [F:SCL1]SCLSAT = [F:AIN]SAT
              [F:SCL1]SCLZIP = [F:AIN]ZIP
              [F:SCL1]SCLCTY = [F:AIN]CTY
            Endif
          Endif
        Else
          #L'adresse Tiers par défaut doit être chargée.
          If IUSESCLCOD Then
            Read [BPA]BPA0=1;[F:SCL2]BPRNUM; [F:SCL2]BPAADD
          Else
            Read [BPA]BPA0=1;[F:BPR]BPRNUM; [F:BPR]BPAADD
          Endif
          If fstat Then
            [F:SCL1]SCLCRY = ""
            [F:SCL1]SCLSAT = ""
            [F:SCL1]SCLZIP = ""
            [F:SCL1]SCLCTY = ""
          Else
            [F:SCL1]SCLCRY = [F:BPA]CRY
            [F:SCL1]SCLSAT = [F:BPA]SAT
            [F:SCL1]SCLZIP = [F:BPA]POSCOD
            [F:SCL1]SCLCTY = [F:BPA]CTY
          Endif
        Endif
      Else
        #L'adresse du contact doit être chargée.
        Read [AIN]AIN0=[F:SCL1]RECNUM
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
        Else
          [F:SCL1]SCLCRY = [F:AIN]CRY
          [F:SCL1]SCLSAT = [F:AIN]SAT
          [F:SCL1]SCLZIP = [F:AIN]ZIP
          [F:SCL1]SCLCTY = [F:AIN]CTY
        Endif
      Endif
      Write [SCL1]
      If fstat Then
        Rollback
        GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
        GERR = 1
        IPBL = 1
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZRECNUM = [F:SCL2]RECNUM
      SZBPRNUM = [F:SCL2]BPRNUM
      STOPLOOP = 1
      Break
    Endif
  Next
  If STOPLOOP Then
    Goto SNAPLOOP2
  Endif 
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
End

##########################################################################################################
Subprog UNIONBPR(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Char SZOPGTYP1
Local Char SZOPGTYP2
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  SZOPGTYP1 = ""
  SZOPGTYP2 = ""
  #Obtient le dernier numéro de chrono dans la population de gauche
  Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP <> "CCN" Order By [F:SCL1]CLSNUM Desc
  For [SCL1] Hint Key SCL0
    ILASTCLSNUM = [F:SCL1]CLSNUM
    SZOPGTYP1 = [F:SCL1]RECTYP
    Break
  Next
  Filter [SCL1]
  #Obtient le type de la sélection tiers
  Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP <> "CCN" Order By [F:SCL2]RECNUM Asc
  For [SCL2] Hint Key SCL0
    SZOPGTYP2 = [F:SCL2]RECTYP
    Break
  Next
  Filter [SCL2]
  #Transfère le complèment résident dans la population de droite dans celle de gauche.
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = SZOPGTYP2 & [F:SCL2]RECNUM > SZLOOPCLE Order By [F:SCL2]RECNUM Asc
    For [SCL2] Hint Key SCL1
      SZLOOPCLE = [F:SCL2]RECNUM
      Read [SCL1]SCL1=GSZOPGNUM;SZOPGTYP1;[F:SCL2]RECNUM
      If fstat Then
        #On ajoute cet enregistrement dans la population de gauche
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL1]
          INTR = 1
        Endif
        ILASTCLSNUM += 1
        [F:SCL1]CLSNUM = ILASTCLSNUM
        [F:SCL1]OPGNUM = GSZOPGNUM
        [F:SCL1]RECTYP = SZOPGTYP1
        [F:SCL1]RECNUM = [F:SCL2]RECNUM
        [F:SCL1]BPRNUM = ""
        [F:SCL1]BPAADD = ""
        Read [BPR]BPR0=[F:SCL1]RECNUM
        If fstat Then
          Read [BPA]BPA0=1;[F:SCL2]RECNUM;[F:SCL2]BPAADD
        Else
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        Endif
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
        Else
          [F:SCL1]SCLCRY = [F:BPA]CRY
          [F:SCL1]SCLSAT = [F:BPA]SAT
          [F:SCL1]SCLZIP = [F:BPA]POSCOD
          [F:SCL1]SCLCTY = [F:BPA]CTY
        Endif
        Write [SCL1]
        If fstat Then
          Rollback
          GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
End

##########################################################################################################
Subprog UNIONX(SZOPGCOD)
Value Char SZOPGCOD

  If GSZTYPSEA = "CCN" Then
    Call UNIONXCCN(SZOPGCOD)
  Elsif GSZTYPSEA = "BPR" Then
    Call UNIONXBPR(SZOPGCOD)
  Endif
End

##########################################################################################################
Subprog UNIONXCCN(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Integer IC
Local Integer ICCNADDEMP(6)
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
Local Char SZBPRNUM
Local Char SZRECNUM
Local Char SZCNTNAM(50)

  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  SZBPRNUM = ""
  SZRECNUM = ""
  SZCNTNAM = ""
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  IC = 0
  Raz ICCNADDEMP
$SNAPLOOP3
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:CNT]CCNCRM <> " + '"' + '"' + " & [F:CNT]BPATYP=1 & [F:CNT]BPANUM=SZBPRNUM & [F:CNT]CCNCRM>SZCNTNAM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:CNT]CCNCRM <> " + '"' + '"' + " & [F:CNT]BPATYP=1 & [F:CNT]BPANUM>SZBPRNUM"
  Else
    LOOPCRIT = "[F:CNT]CCNCRM <> " + '"' + '"' + " & [F:CNT]BPATYP=1"
  Endif
  ICLECOUNT3 = 0
  Filter [CNT] Where evalue(LOOPCRIT)
  For [CNT] CNT0
    #On regarde dans la population de droite
    Read [SCL1]SCL2=SZOPGCOD;"CCN";[F:CNT]CCNCRM;[F:CNT]BPANUM
    If fstat Then
      #Le contact n'est pas présent dans la population de droite.
      #On regarde dans la population de gauche
      Read [SCL1]SCL2=GSZOPGNUM;"CCN";[F:CNT]CCNCRM;[F:CNT]BPANUM
      If fstat Then
        #Le contact n'est pas présent dans la population de gauche.
        #On regarde dans l'échantillon tampon
        Read [SCL2]SCL2=GSZOPGNUM;"TMP";[F:CNT]CCNCRM;[F:CNT]BPANUM
        If fstat Then
          #On l'ajoute dans l'échantillon tampon
          Raz [F:SCL2]
          If IPERF = 0 Then
            Call DEBTRANS From GLOCK
            Trbegin [SCL2]
            INTR = 1
          Endif
          ILASTCLSNUM += 1
          [F:SCL2]CLSNUM = ILASTCLSNUM
          [F:SCL2]OPGNUM = GSZOPGNUM
          [F:SCL2]RECTYP = "TMP"
          [F:SCL2]RECNUM = [F:CNT]CCNCRM
          [F:SCL2]BPRNUM = [F:CNT]BPANUM
          If GIDEFADD = 2 Then
            [F:SCL2]BPAADD = ""
          Else
            If [F:SCL2]BPRNUM = "" Then
              [F:SCL2]BPAADD = ""
            Else
              Read [BPR]BPR0=[F:SCL2]BPRNUM
              If fstat Then
                [F:SCL2]BPAADD = ""
              Else
                [F:SCL2]BPAADD = [F:BPR]BPAADD
              Endif
            Endif
          Endif
          If [F:SCL2]BPRNUM <> "" Then
            #Un tiers peut être mentionné dans le tableau.
            If GIDEFADD = 2 Then
              #L'adresse du contact doit être chargée.
              If GIHIEBPR = 2 Then
                #Une affectation hiérarchique d'adresse est demandée.
                #Test si l'adresse contact est complétement vide.
                Read [AIN]AIN0=[F:SCL2]RECNUM
                If fstat Then
                  ICCNADDEMP(0) = 1
                  ICCNADDEMP(1) = 1
                  ICCNADDEMP(2) = 1
                  ICCNADDEMP(3) = 1
                  ICCNADDEMP(4) = 1
                  ICCNADDEMP(5) = 1
                  Raz [F:AIN]
                Else
                  ICCNADDEMP(0) = 1
                  If [F:AIN]ADD(0) = "" Then
                    ICCNADDEMP(1) = 1
                  Else
                    ICCNADDEMP(1) = 0
                  Endif
                  If [F:AIN]ADD(1) = "" Then
                    ICCNADDEMP(2) = 1
                  Else
                    ICCNADDEMP(2) = 0
                  Endif
                  If [F:AIN]ADD(2) = "" Then
                    ICCNADDEMP(3) = 1
                  Else
                    ICCNADDEMP(3) = 0
                  Endif
                  If [F:AIN]ZIP = "" Then
                    ICCNADDEMP(4) = 1
                  Else
                    ICCNADDEMP(4) = 0
                  Endif
                  If [F:AIN]CTY = "" Then
                    ICCNADDEMP(5) = 1
                  Else
                    ICCNADDEMP(5) = 0
                  Endif
                Endif
                For IC = 1 To dim(ICCNADDEMP)-1
                  If ICCNADDEMP(IC) = 0 Then
                    ICCNADDEMP(0) = 0
                    Break
                  Endif
                Next
                If ICCNADDEMP(0) = 1 Then
                  #L'adresse contact est complétement vide. On charge l'adresse Tiers
                  Read [BPR]BPR0=[F:SCL2]BPRNUM
                  If fstat Then
                    [F:SCL2]SCLCRY = ""
                    [F:SCL2]SCLSAT = ""
                    [F:SCL2]SCLZIP = ""
                    [F:SCL2]SCLCTY = ""
                  Else
                    Read [BPA]BPA0=1;[F:BPR]BPRNUM; [F:BPR]BPAADD
                    If fstat Then
                      [F:SCL2]SCLCRY = ""
                      [F:SCL2]SCLSAT = ""
                      [F:SCL2]SCLZIP = ""
                      [F:SCL2]SCLCTY = ""
                    Else
                      [F:SCL2]SCLCRY = [F:BPA]CRY
                      [F:SCL2]SCLSAT = [F:BPA]SAT
                      [F:SCL2]SCLZIP = [F:BPA]POSCOD
                      [F:SCL2]SCLCTY = [F:BPA]CTY
                    Endif
                  Endif
                Else
                  [F:SCL2]SCLCRY = [F:AIN]CRY
                  [F:SCL2]SCLSAT = [F:AIN]SAT
                  [F:SCL2]SCLZIP = [F:AIN]ZIP
                  [F:SCL2]SCLCTY = [F:AIN]CTY
                Endif
              Else
                Read [AIN]AIN0=[F:SCL2]RECNUM
                If fstat Then
                  [F:SCL2]SCLCRY = ""
                  [F:SCL2]SCLSAT = ""
                  [F:SCL2]SCLZIP = ""
                  [F:SCL2]SCLCTY = ""
                Else
                  [F:SCL2]SCLCRY = [F:AIN]CRY
                  [F:SCL2]SCLSAT = [F:AIN]SAT
                  [F:SCL2]SCLZIP = [F:AIN]ZIP
                  [F:SCL2]SCLCTY = [F:AIN]CTY
                Endif
              Endif
            Else
              #L'adresse Tiers par défaut doit être chargée.
              Read [BPR]BPR0=[F:SCL2]BPRNUM
              If fstat Then
                [F:SCL2]SCLCRY = ""
                [F:SCL2]SCLSAT = ""
                [F:SCL2]SCLZIP = ""
                [F:SCL2]SCLCTY = ""
              Else
                Read [BPA]BPA0=1;[F:BPR]BPRNUM; [F:BPR]BPAADD
                If fstat Then
                  [F:SCL2]SCLCRY = ""
                  [F:SCL2]SCLSAT = ""
                  [F:SCL2]SCLZIP = ""
                  [F:SCL2]SCLCTY = ""
                Else
                  [F:SCL2]SCLCRY = [F:BPA]CRY
                  [F:SCL2]SCLSAT = [F:BPA]SAT
                  [F:SCL2]SCLZIP = [F:BPA]POSCOD
                  [F:SCL2]SCLCTY = [F:BPA]CTY
                Endif
              Endif
            Endif
          Else
            #L'adresse du contact doit être chargée.
            Read [AIN]AIN0=[F:SCL2]RECNUM
            If fstat Then
              [F:SCL2]SCLCRY = ""
              [F:SCL2]SCLSAT = ""
              [F:SCL2]SCLZIP = ""
              [F:SCL2]SCLCTY = ""
            Else
              [F:SCL2]SCLCRY = [F:AIN]CRY
              [F:SCL2]SCLSAT = [F:AIN]SAT
              [F:SCL2]SCLZIP = [F:AIN]ZIP
              [F:SCL2]SCLCTY = [F:AIN]CTY
            Endif
          Endif
          Write [SCL2]
          If fstat Then
            Rollback
            GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
            GERR = 1
            IPBL = 1
            INTR = 0
            Break
          Else
            If IPERF >= 500 Then
              Commit
              IPERF = 0
              INTR = 0
            Else
              IPERF += 1
            Endif
          Endif
        Endif
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZBPRNUM = [F:CNT]BPANUM
      SZCNTNAM = [F:CNT]CCNCRM
      STOPLOOP = 1
      Break
    Endif
  Next
  If STOPLOOP Then
    Goto SNAPLOOP3
  Endif 
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [CNT]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon de gauche
  Call DEBTRANS From GLOCK
  Trbegin [SCL1]
  Delete [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP = "CCN"
  If fstat Then
    Rollback
    GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
    GERR = 1
    End
  Else
    Commit
  Endif
  If GERR Then
    End
  Endif
  #On recrée l'échantillon de gauche sur la base de l'échantillon tampon
  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  IC = 0
  Raz ICCNADDEMP
  SZBPRNUM = ""
  SZRECNUM = ""
  #
$SNAPLOOP4
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"' + " & [F:SCL2]RECNUM = SZRECNUM & [F:SCL2]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"' + " & [F:SCL2]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL2] Where evalue(LOOPCRIT) Order By [F:SCL2]RECNUM Asc; [F:SCL2]BPRNUM Asc
  For [SCL2] Hint Key SCL0
    If IPERF = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SCL1]
      INTR = 1
    Endif
    [F:SCL1] = [F:SCL2]
    [F:SCL1]RECTYP = "CCN"
    Write [SCL1]
    If fstat Then
      Rollback
      GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
      GERR = 1
      IPBL = 1
      INTR = 0
      Break
    Else
      If IPERF >= 500 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZRECNUM = [F:SCL2]RECNUM
      SZBPRNUM = [F:SCL2]BPRNUM
      STOPLOOP = 1
      Break
    Endif
  Next
  If STOPLOOP Then
    Goto SNAPLOOP4
  Endif 
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon tampon
  Call DEBTRANS From GLOCK
  Trbegin [SCL2]
  Delete [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM and [F:SCL2]RECTYP = "TMP"
  If fstat Then
    Rollback
    GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
    GERR = 1
    End
  Else
    Commit
  Endif
End

##########################################################################################################
Subprog UNIONXBPR(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Char SZOPGTYP1
Local Char SZOPGTYP2
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  ILASTCLSNUM = 0
  SZOPGTYP1 = ""
  SZOPGTYP2 = ""
  #Obtient le dernier numéro de chrono dans la population de gauche
  Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP <> "CCN" Order By [F:SCL1]CLSNUM Desc
  For [SCL1] Hint Key SCL0
    SZOPGTYP1 = [F:SCL1]RECTYP
    Break
  Next
  Filter [SCL1]
  #Obtient le type de la sélection tiers
  Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP <> "CCN" Order By [F:SCL2]RECNUM Asc
  For [SCL2] Hint Key SCL0
    SZOPGTYP2 = [F:SCL2]RECTYP
    Break
  Next
  Filter [SCL2]
  #Transfère le complèment résident dans la population de droite dans celle de gauche.
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [BPR] Where [F:BPR]BPRNUM > SZLOOPCLE
    For [BPR] BPR0
      SZLOOPCLE = [F:BPR]BPRNUM
      #On regarde dans la population de droite
      Read [SCL1]SCL1=SZOPGCOD;SZOPGTYP2;[F:BPR]BPRNUM
      If fstat Then
        #Le contact n'est pas présent dans la population de droite.
        #On regarde dans la population de gauche
        Read [SCL1]SCL1=GSZOPGNUM;SZOPGTYP1;[F:BPR]BPRNUM
        If fstat Then
          #Le contact n'est pas présent dans la population de gauche.
          #On regarde dans l'échantillon tampon
          Read [SCL1]SCL1=GSZOPGNUM;"TMP";[F:BPR]BPRNUM
          If fstat Then
            #On l'ajoute dans l'échantillon tampon
            Raz [F:SCL2]
            If IPERF = 0 Then
              Call DEBTRANS From GLOCK
              Trbegin [SCL2]
              INTR = 1
            Endif
            ILASTCLSNUM += 1
            [F:SCL2]CLSNUM = ILASTCLSNUM
            [F:SCL2]OPGNUM = GSZOPGNUM
            [F:SCL2]RECTYP = "TMP"
            [F:SCL2]RECNUM = [F:BPR]BPRNUM
            [F:SCL2]BPRNUM = ""
            [F:SCL2]BPAADD = ""
            Read [BPR]BPR0=[F:SCL2]RECNUM
            If fstat Then
              [F:SCL2]SCLCRY = ""
              [F:SCL2]SCLSAT = ""
              [F:SCL2]SCLZIP = ""
              [F:SCL2]SCLCTY = ""
            Else
              Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
              If fstat Then
                [F:SCL2]SCLCRY = ""
                [F:SCL2]SCLSAT = ""
                [F:SCL2]SCLZIP = ""
                [F:SCL2]SCLCTY = ""
              Else
                [F:SCL2]SCLCRY = [F:BPA]CRY
                [F:SCL2]SCLSAT = [F:BPA]SAT
                [F:SCL2]SCLZIP = [F:BPA]POSCOD
                [F:SCL2]SCLCTY = [F:BPA]CTY
              Endif
            Endif
            Write [SCL2]
            If fstat Then
              Rollback
              GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
              GERR = 1
              IPBL = 1
              INTR = 0
              Break
            Else
              If IPERF >= 500 Then
                Commit
                IPERF = 0
                INTR = 0
              Else
                IPERF += 1
              Endif
            Endif
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [BPR]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon de gauche
  Call DEBTRANS From GLOCK
  Trbegin [SCL1]
  Delete [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP = SZOPGTYP1
  If fstat Then
    Rollback
    GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
    GERR = 1
    End
  Else
    Commit
  Endif
  If GERR Then
    End
  Endif
  #Transfère le complèment résident dans la population de droite dans celle de gauche.
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = "TMP" & [F:SCL2]RECNUM > SZLOOPCLE Order By [F:SCL2]RECNUM Asc
    For [SCL2] Hint Key SCL1
      SZLOOPCLE = [F:SCL2]RECNUM
      #On ajoute cet enregistrement dans la population de gauche
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL1]
        INTR = 1
      Endif
      [F:SCL1] = [F:SCL2]
      [F:SCL1]RECTYP = SZOPGTYP1
      Write [SCL1]
      If fstat Then
        Rollback
        GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
        GERR = 1
        IPBL = 1
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon tampon
  Call DEBTRANS From GLOCK
  Trbegin [SCL2]
  Delete [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM and [F:SCL2]RECTYP = "TMP"
  If fstat Then
    Rollback
    GMESSAGE = mess(362,196,1) #Erreur lors du traitement de calcul des unions.
    GERR = 1
    End
  Else
    Commit
  Endif
End

##########################################################################################################
Subprog INTERX(SZOPGCOD)
Value Char SZOPGCOD

  If GSZTYPSEA = "CCN" Then
    Call INTERXCCN(SZOPGCOD)
  Elsif GSZTYPSEA = "BPR" Then
    Call INTERXBPR(SZOPGCOD)
  Endif
End

##########################################################################################################
Subprog INTERXCCN(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Integer IUSESCLCOD
Local Integer IC
Local Integer ICCNADDEMP(6)
Local Integer ICLECOUNT3
Local Integer ICUT3
Local Integer STOPLOOP
Local Char LOOPCRIT(250)
Local Char SZRECNUM
Local Char SZBPRNUM

  STOPLOOP = 0
  LOOPCRIT = ""
  ICUT3 = 2750
  ICLECOUNT3 = 0
  IPERF = 0
  INTR = 0
  IPBL = 0
  IUSESCLCOD = 0
  IC = 0
  Raz ICCNADDEMP
  SZRECNUM = ""
  SZBPRNUM = ""
  ILASTCLSNUM = 0
  #Alimente l'échantillon tampon sur la base d'une lecture dans l'échantillon de droite.
$SNAPLOOP5
  If STOPLOOP = 1 Then
    STOPLOOP = 2
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' +" & [F:SCL2]RECNUM = SZRECNUM & [F:SCL2]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""' +" & [F:SCL2]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = " + '"' + "CCN" + '"' + " & [F:SCL2]RECNUM <> " + '""'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL2] Where evalue(LOOPCRIT) Order By [F:SCL2]RECNUM Asc; [F:SCL2]BPRNUM Asc
  For [SCL2] Hint Key SCL0
    Read [SCL1]SCL2=GSZOPGNUM;"CCN";[F:SCL2]RECNUM;[F:SCL2]BPRNUM
    If fstat Then
      #On ajoute cet enregistrement dans l'échantillon tampon
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL1]
        INTR = 1
      Endif
      ILASTCLSNUM += 1
      [F:SCL1]CLSNUM = ILASTCLSNUM
      [F:SCL1]OPGNUM = GSZOPGNUM
      [F:SCL1]RECTYP = "TMP"
      [F:SCL1]RECNUM = [F:SCL2]RECNUM
      [F:SCL1]BPRNUM = [F:SCL2]BPRNUM
      If GIDEFADD = 2 Then
        [F:SCL1]BPAADD = ""
      Else
        If [F:SCL1]BPRNUM = "" Then
          [F:SCL1]BPAADD = ""
        Else
          Read [BPR]BPR0=[F:SCL1]BPRNUM
          If fstat Then
            [F:SCL1]BPAADD = ""
          Else
            [F:SCL1]BPAADD = [F:BPR]BPAADD
          Endif
        Endif
      Endif
      If [F:SCL1]BPRNUM <> "" Then
        #Un tiers peut être mentionné dans le tableau.
        Read [BPR]BPR0=[F:SCL1]BPRNUM
        If fstat Then
          IUSESCLCOD = 1
        Else
          IUSESCLCOD = 0
        Endif
        If GIDEFADD = 2 Then
          #L'adresse du contact doit être chargée.
          If GIHIEBPR = 2 Then
            #Une affectation hiérarchique d'adresse est demandée.
            #Test si l'adresse contact est complétement vide.
            Read [AIN]AIN0=[F:SCL1]RECNUM
            If fstat Then
              ICCNADDEMP(0) = 1
              ICCNADDEMP(1) = 1
              ICCNADDEMP(2) = 1
              ICCNADDEMP(3) = 1
              ICCNADDEMP(4) = 1
              ICCNADDEMP(5) = 1
              Raz [F:AIN]
            Else
              ICCNADDEMP(0) = 1
              If [F:AIN]ADD(0) = "" Then
                ICCNADDEMP(1) = 1
              Else
                ICCNADDEMP(1) = 0
              Endif
              If [F:AIN]ADD(1) = "" Then
                ICCNADDEMP(2) = 1
              Else
                ICCNADDEMP(2) = 0
              Endif
              If [F:AIN]ADD(2) = "" Then
                ICCNADDEMP(3) = 1
              Else
                ICCNADDEMP(3) = 0
              Endif
              If [F:AIN]ZIP = "" Then
                ICCNADDEMP(4) = 1
              Else
                ICCNADDEMP(4) = 0
              Endif
              If [F:AIN]CTY = "" Then
                ICCNADDEMP(5) = 1
              Else
                ICCNADDEMP(5) = 0
              Endif
            Endif
            For IC = 1 To dim(ICCNADDEMP)-1
              If ICCNADDEMP(IC) = 0 Then
                ICCNADDEMP(0) = 0
                Break
              Endif
            Next
            If ICCNADDEMP(0) = 1 Then
              #L'adresse contact est complétement vide. On charge l'adresse Tiers
              If IUSESCLCOD Then
                Read [BPA]BPA0=1;[F:SCL2]BPRNUM;[F:SCL2]BPAADD
              Else
                Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
              Endif
              If fstat Then
                [F:SCL1]SCLCRY = ""
                [F:SCL1]SCLSAT = ""
                [F:SCL1]SCLZIP = ""
                [F:SCL1]SCLCTY = ""
              Else
                [F:SCL1]SCLCRY = [F:BPA]CRY
                [F:SCL1]SCLSAT = [F:BPA]SAT
                [F:SCL1]SCLZIP = [F:BPA]POSCOD
                [F:SCL1]SCLCTY = [F:BPA]CTY
              Endif
            Else
              [F:SCL1]SCLCRY = [F:AIN]CRY
              [F:SCL1]SCLSAT = [F:AIN]SAT
              [F:SCL1]SCLZIP = [F:AIN]ZIP
              [F:SCL1]SCLCTY = [F:AIN]CTY
            Endif
          Else
            Read [AIN]AIN0=[F:SCL2]RECNUM
            If fstat Then
              [F:SCL1]SCLCRY = ""
              [F:SCL1]SCLSAT = ""
              [F:SCL1]SCLZIP = ""
              [F:SCL1]SCLCTY = ""
            Else
              [F:SCL1]SCLCRY = [F:AIN]CRY
              [F:SCL1]SCLSAT = [F:AIN]SAT
              [F:SCL1]SCLZIP = [F:AIN]ZIP
              [F:SCL1]SCLCTY = [F:AIN]CTY
            Endif
          Endif
        Else
          #L'adresse Tiers par défaut doit être chargée.
          If IUSESCLCOD Then
            Read [BPA]BPA0=1;[F:SCL2]BPRNUM;[F:SCL]BPAADD
          Else
            Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
          Endif
          If fstat Then
            [F:SCL1]SCLCRY = ""
            [F:SCL1]SCLSAT = ""
            [F:SCL1]SCLZIP = ""
            [F:SCL1]SCLCTY = ""
          Else
            [F:SCL1]SCLCRY = [F:BPA]CRY
            [F:SCL1]SCLSAT = [F:BPA]SAT
            [F:SCL1]SCLZIP = [F:BPA]POSCOD
            [F:SCL1]SCLCTY = [F:BPA]CTY
          Endif
        Endif
      Else                              #L'adresse du contact doit être chargée.
        Read [AIN]AIN0=[F:SCL1]RECNUM
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
