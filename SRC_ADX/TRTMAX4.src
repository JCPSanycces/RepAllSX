  Trbegin [SCL2]
  Delete [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM and [F:SCL2]RECTYP = "TMP"
  If fstat Then
    Rollback
    GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
    GERR = 1
    End
  Else
    Commit
  Endif
End

##########################################################################################################
Subprog INTERXBPR(SZOPGCOD)
Value Char SZOPGCOD

Local Integer IPERF
Local Integer INTR
Local Integer IPBL
Local Integer ILASTCLSNUM
Local Char SZOPGTYP1
Local Char SZOPGTYP2
Local Char SZLOOPCLE
Local Integer ILOOPCLECOUNT
Local Integer ILOOPCUT

  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  SZOPGTYP1 = ""
  SZOPGTYP2 = ""
  ILASTCLSNUM = 0
  #Obtient le type de la sélection tiers de gauche
  Filter [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP <> "CCN" Order By [F:SCL1]CLSNUM Desc
  For [SCL1] Hint Key SCL0
    SZOPGTYP1 = [F:SCL1]RECTYP
    Break
  Next
  Filter [SCL1]
  #Obtient le type de la sélection tiers de droite
  Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP <> "CCN" Order By [F:SCL2]RECNUM Asc
  For [SCL2] Hint Key SCL0
    SZOPGTYP2 = [F:SCL2]RECTYP
    Break
  Next
  Filter [SCL2]
  #Alimente l'échantillon tampon sur la base d'une lecture dans l'échantillon de droite.
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL2] Where [F:SCL2]OPGNUM = SZOPGCOD & [F:SCL2]RECTYP = SZOPGTYP2 & [F:SCL2]RECNUM > SZLOOPCLE Order By [F:SCL2]RECNUM Asc
    For [SCL2] Hint Key SCL1
      SZLOOPCLE = [F:SCL2]RECNUM
      Read [SCL1]SCL1=GSZOPGNUM;SZOPGTYP1;[F:SCL2]RECNUM
      If fstat Then
        #On ajoute cet enregistrement dans l'échantillon tampon
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL1]
          INTR = 1
        Endif
        ILASTCLSNUM += 1
        [F:SCL1]CLSNUM = ILASTCLSNUM
        [F:SCL1]OPGNUM = GSZOPGNUM
        [F:SCL1]RECTYP = "TMP"
        [F:SCL1]RECNUM = [F:SCL2]RECNUM
        [F:SCL1]BPRNUM = ""
        [F:SCL1]BPAADD = ""
        Read [BPR]BPR0=[F:SCL1]RECNUM
        If fstat Then
          Read [BPA]BPA0=1;[F:SCL2]RECNUM;[F:SCL2]BPAADD
        Else
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        Endif
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
        Else
          [F:SCL1]SCLCRY = [F:BPA]CRY
          [F:SCL1]SCLSAT = [F:BPA]SAT
          [F:SCL1]SCLZIP = [F:BPA]POSCOD
          [F:SCL1]SCLCTY = [F:BPA]CTY
        Endif
        Write [SCL1]
        If fstat Then
          Rollback
          GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #Alimente l'échantillon tampon sur la base d'une lecture dans l'échantillon de gauche.
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = SZOPGTYP1 & [F:SCL2]RECNUM > SZLOOPCLE Order By [F:SCL2]RECNUM Asc
    For [SCL2] Hint Key SCL1
      SZLOOPCLE = [F:SCL2]RECNUM
      Read [SCL1]SCL1=SZOPGCOD;SZOPGTYP2;[F:SCL2]RECNUM
      If fstat Then
        #On ajoute cet enregistrement dans l'échantillon tampon
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL1]
          INTR = 1
        Endif
        ILASTCLSNUM += 1
        [F:SCL1]CLSNUM = ILASTCLSNUM
        [F:SCL1]OPGNUM = GSZOPGNUM
        [F:SCL1]RECTYP = "TMP"
        [F:SCL1]RECNUM = [F:SCL2]RECNUM
        [F:SCL1]BPRNUM = ""
        [F:SCL1]BPAADD = ""
        Read [BPR]BPR0=[F:SCL1]RECNUM
        If fstat Then
          Read [BPA]BPA0=1;[F:SCL2]RECNUM;[F:SCL2]BPAADD
        Else
          Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
        Endif
        If fstat Then
          [F:SCL1]SCLCRY = ""
          [F:SCL1]SCLSAT = ""
          [F:SCL1]SCLZIP = ""
          [F:SCL1]SCLCTY = ""
        Else
          [F:SCL1]SCLCRY = [F:BPA]CRY
          [F:SCL1]SCLSAT = [F:BPA]SAT
          [F:SCL1]SCLZIP = [F:BPA]POSCOD
          [F:SCL1]SCLCTY = [F:BPA]CTY
        Endif
        Write [SCL1]
        If fstat Then
          Rollback
          GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
          GERR = 1
          IPBL = 1
          INTR = 0
          Break
        Else
          If IPERF >= 500 Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon de gauche
  Call DEBTRANS From GLOCK
  Trbegin [SCL1]
  Delete [SCL1] Where [F:SCL1]OPGNUM = GSZOPGNUM and [F:SCL1]RECTYP = SZOPGTYP1
  If fstat Then
    Rollback
    GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
    GERR = 1
    End
  Else
    Commit
  Endif
  If GERR Then
    End
  Endif
  #On recrée l'échantillon de gauche sur la base de l'échantillon tampon
  SZLOOPCLE = ""
  ILOOPCUT = 2750
  ILOOPCLECOUNT = ILOOPCUT
  IPERF = 0
  INTR = 0
  IPBL = 0
  While ILOOPCLECOUNT >= ILOOPCUT
    ILOOPCLECOUNT = 0
    Filter [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = "TMP" & [F:SCL2]RECNUM > SZLOOPCLE Order By [F:SCL2]RECNUM Asc
    For [SCL2] Hint Key SCL1
      SZLOOPCLE = [F:SCL2]RECNUM
      #On ajoute cet enregistrement dans la population de gauche
      If IPERF = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [SCL1]
        INTR = 1
      Endif
      [F:SCL1] = [F:SCL2]
      [F:SCL1]RECTYP = SZOPGTYP1
      Write [SCL1]
      If fstat Then
        Rollback
        GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
        GERR = 1
        IPBL = 1
        INTR = 0
        Break
      Else
        If IPERF >= 500 Then
          Commit
          IPERF = 0
          INTR = 0
        Else
          IPERF += 1
        Endif
      Endif
      ILOOPCLECOUNT += 1
      If ILOOPCLECOUNT >= ILOOPCUT Then
        Break
      Endif
    Next
  Wend
  If INTR Then
    If !IPBL Then
      Commit
    Endif
  Endif
  Filter [SCL2]
  If GERR Then
    End
  Endif
  #On supprime l'échantillon tampon
  Call DEBTRANS From GLOCK
  Trbegin [SCL2]
  Delete [SCL2] Where [F:SCL2]OPGNUM = GSZOPGNUM and [F:SCL2]RECTYP = "TMP"
  If fstat Then
    Rollback
    GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
    GERR = 1
    End
  Else
    Commit
  Endif
End
