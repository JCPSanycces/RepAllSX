    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"' + " & [F:SCL2]RECNUM = SZRECNUM & [F:SCL2]BPRNUM > SZBPRNUM"
  Elsif STOPLOOP = 2 Then
    STOPLOOP = 0
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"' + " & [F:SCL2]RECNUM > SZRECNUM"
  Else
    LOOPCRIT = "[F:SCL2]OPGNUM = GSZOPGNUM & [F:SCL2]RECTYP = " + '"' + "TMP" + '"'
  Endif
  ICLECOUNT3 = 0
  Filter [SCL2] Where evalue(LOOPCRIT) Order By [F:SCL2]RECNUM Asc; [F:SCL2]BPRNUM Asc
