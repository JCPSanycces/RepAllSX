    If IPERF = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [SCL1]
      INTR = 1
    Endif
    [F:SCL1] = [F:SCL2]
    [F:SCL1]RECTYP = "CCN"
    Write [SCL1]
    If fstat Then
      Rollback
      GMESSAGE = mess(361,196,1) #Erreur lors du traitement de calcul des intersections.
      GERR = 1
      IPBL = 1
      INTR = 0
      Break
    Else
      If IPERF >= 500 Then
        Commit
        IPERF = 0
        INTR = 0
      Else
        IPERF += 1
      Endif
    Endif
    ICLECOUNT3 += 1
    If ICLECOUNT3 >= ICUT3 Then
      SZRECNUM = [F:SCL2]RECNUM
      SZBPRNUM = [F:SCL2]BPRNUM
      STOPLOOP = 1
      Break
