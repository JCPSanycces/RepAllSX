#<AdxTL>@(#)0.0.0.0 $Revision$
#Class PIHRMFAIR


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
 When "COD"         : Gosub PIHRMFAIR_COD
 When "BATCFGSTR"   : Gosub PIHRMFAIR_BATCFGSTR
 When "BATCFGEND"   : Gosub PIHRMFAIR_BATCFGEND
 When "PAGSIZ"      : Gosub PIHRMFAIR_PAGSIZ
Endcase
Return


$PIHRMFAIR_COD
Local Integer I,K,L
Case [L]ARULE
  When "PROPAGATE"    : Gosub PIHRMFAIR_COD_PROPAGATE
Endcase
Return

$PIHRMFAIR_BATCFGSTR
Case [L]ARULE
  When "PROPAGATE"    : Gosub PIHRMFAIR_BATCFGSTR_PROPAGATE
Endcase
Return

$PIHRMFAIR_BATCFGEND
Case [L]ARULE
  When "PROPAGATE"    : Gosub PIHRMFAIR_BATCFGEND_PROPAGATE
Endcase
Return

$PIHRMFAIR_PAGSIZ
Case [L]ARULE
  When "PROPAGATE"    : Gosub PIHRMFAIR_PAGSIZ_PROPAGATE
Endcase
Return

$PIHRMFAIR_COD_PROPAGATE


If this.COD = "" : Return : Endif
Local Char ORIGINAL_CREUSR(GLONAUS)
Local Integer I, OK
Local Datetime NEWDATTIM

ORIGINAL_CREUSR = this.CREUSR
NEWDATTIM = this.CREDATTIM
#Do a class transfer from the setup screen
Local File PIHRMFAIRSET [PIFS2]
Read [PIFS2]PIFS0 = this.COD
If fstat = [V]CST_AOK
  SetInstanceNoSys this With [F:PIFS2]
Endif

If this.SRV <> null
  For I = 1 To maxtab(this.SRV)
    If this(I).SRV <> null
      OK=fmet this.ADELLINE("SRV", 1)
    Endif
  Next
Endif

For I = 1 To len(mess(0,11817,1))
  K += 1
  L = fmet this.ADDLINE("SRV",[V]CST_ALASTPOS)
  this.SRV(L).SRVTYP = [F:PIFS2]SRVTYP(K-1)
  this.SRV(L).SRVINC = [F:PIFS2]SRVINC(K-1)
Next

LogicClose File [PIFS2]

this.CREUSR     = ORIGINAL_CREUSR
this.CREDATTIM  = NEWDATTIM


Return

$PIHRMFAIR_BATCFGSTR_PROPAGATE
Gosub BUILD_CFG
Return

$PIHRMFAIR_BATCFGEND_PROPAGATE
Gosub BUILD_CFG
Return

$PIHRMFAIR_PAGSIZ_PROPAGATE
Gosub BUILD_CFG
Return

$BUILD_CFG
Local Char PAYSTRDAT(10)
Local Char PAYENDDAT(10)

PAYSTRDAT = num$(year(this.BATCFGSTR))+"-"+num$(month(this.BATCFGSTR))+"-"+num$(day(this.BATCFGSTR))
PAYENDDAT = num$(year(this.BATCFGEND))+"-"+num$(month(this.BATCFGEND))+"-"+num$(day(this.BATCFGEND))

this.PAYBATCFG = '{"config":{"startDate":"'+PAYSTRDAT+'","endDate":"'+PAYENDDAT+'","pageSize":'+num$(this.PAGSIZ)+'}}'
Return

