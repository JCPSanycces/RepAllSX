#<AdxTL>@(#)11.0.0.0 $Revision$
$CREFAC
Local Char    CODCPT(GLONCAC), CPTANA(GLONGAC)
Local Char    PLGEN(GLONCOA), PLANA(GLONCOA)
Local Char    TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    TCPTFRAIS(GLONGAC)(1..len(mess(0,2644,1)))
Local Integer TLED, NLED, NBLED, NBPLAN
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer SEQ

Local Char    CODLED(GLONLED)
Local Char    DEVLED(GLONCUR)
Local Decimal COURS, COURDIV, COURMUL
Local Integer TYPCOURS
Local Decimal EXERCICE , PERIODE

If !clalev([F:SIH1]) : Local File SINVOICE [SIH1] : Endif

GOK=1
Call LECTURE("FCY",[F:UNP]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call LECMAINPLAN(1,[F:CPY]CPY,PLGEN) From CPTDIV
Call LSTLEDTYP([F:CPY]CPY,1,TLEDTYP,NBLED) From CPTDIV
For NLED=1 To NBLED
 Call LECPLAN([F:CPY]CPY,TLEDTYP(NLED),TPLAN(NLED)) From CPTDIV
 Call RECH_ACCMIS([F:CPY]CPY,TLEDTYP(NLED),18,TCPTFRAIS(NLED)) From CPTDIV
 If TCPTFRAIS(NLED)="" & TLEDTYP(NLED)=GTYPGEN
  Call ECR_TRACE(mess(18,2649,1)-tolower(mess(176,105,1))-TPLAN(NLED),1) From GESECRAN
  GOK=0
 Endif
Next
If !GOK : Return : Endif

Gosub EN_TETE
If GOK=1
 NUMFAC=[F:SIH]NUM
 Gosub LIGNES
Endif
Return

$EN_TETE
GOK=1
Call LEC_TSV_LEG([F:CPY]LEG,NOTEDEB) From CPTLEC
If fstat : GOK=0 : Return : Endif
# En-tête de facture client
Raz [F:SIH]
[F:SIH]SIVTYP    = NOTEDEB            : # Type de facture
[F:SIH]INVTYP    = [F:TSV]INVTYP      : # Catégorie
[F:SIH]GTE       = [F:TSV]GTE         : # Type de pièce
[F:SIH]JOU       = [F:TSV]JOU         : # Journal
[F:SIH]CPY       = [F:CPY]CPY         : # Société
[F:SIH]FCY       = [F:UNP]FCY         : # Site
[F:SIH]ACCDAT    = [F:UNP]ACCDAT      : # Date de fgacture (=date comptable)
[F:SIH]BPR       = [F:UNP]BPR         : # Tiers
[F:SIH]BPRDAT    = [F:UNP]ACCDAT      : # Date origine
[F:SIH]BPRVCR    = ""                 : # Document origine
[F:SIH]CUR       = [F:UNP]CUR         : # Devise
[F:SIH]STRDUDDAT = [F:UNP]ACCDAT      : # Départ échéance
[F:SIH]STA       = 1                  : # Statut
[F:SIH]ORIMOD    = 3                  : # Module origine (LA14)
[F:SIH]SNS       = 1                  : # 1:Facture -1:Avoir
[F:SIH]DIRINVFLG = 2                  : # Facture directe
Call LECTURE("BPC",[F:UNP]BPR,"") From CONTOBJ
[F:SIH]BPRPAY    = [F:BPC]BPCPYR      : # Tiers payeur
Gosub COURS

If [F:BPC]BPCTYP=2 & [F:SIH]BPRPAY=[F:SIH]BPR
 [F:SIH]BPAPAY = [F:BPC]BPAINV
Else
 [F:SIH]BPAPAY = [F:BPC]BPAPYR
Endif

# Initialisation du code condition de paiement
Call INIPTE ([F:BPC]BPCPYR,[F:BPC]BPCNUM,"C",[F:SIH]PTE) From TRTX3
# Collectif associé au tiers
Call INIT_COMPTE([F:SIH]BPR,[F:SIH]CPY,"C",CODCPT) From CPTSUB
If [L]CODCPT<>""
 Call LECTURE("CAC",[L]CODCPT,"2~"+PLGEN) From CONTOBJ
 INTERM = [F:CAC]ACC(0)
Endif
If INTERM<>""
 Call LECTURE("GAC",INTERM,PLGEN) From CONTOBJ
 If !fstat & [F:GAC]SAC=2
  [F:SIH]BPRSAC = [F:GAC]ACCSHO
 Else
  [F:SIH]BPRSAC = ""
 Endif
Endif
Call INIT_REGIME([F:SIH]BPR,[F:SIH]FCY,"C",[F:SIH]VAC) From CPTSUB
# Sections analytiques pour l'en-tête
For I=0 To dim([F:SIH]CCE)-1
 [F:SIH]DIE(I) = [F:UNP]DIE(I)
 [F:SIH]CCE(I) = [F:UNP]CCE(I)
Next

# Raison sociale, adresse, ligne adresse, pays, ville,...
Call LECTURE("BPR",[F:UNP]BPR,"") From CONTOBJ
Gosub LECADR

Call GETPERSOC([F:CPY]CPY,GTYPGEN,[F:SIH]ACCDAT,EXERCICE,PERIODE) From CPTSUB
[F:SIH]FIY = EXERCICE
[F:SIH]PER = PERIODE

# Type de pièce
If [F:TSV]GTE=""
 Call EVALAUTO([F:TSV]COD2,"GTE",GTECOD)From SUBBIC
 If GTECOD=""
  # Type de pièce non défini
  Call ECR_TRACE(mess(27,110,1),1) From GESECRAN
  GOK=0 : Return
 Endif
Else
 GTECOD=[F:TSV]GTE
Endif
# Contrôles sur type de pièce
Gosub CONT_GTE
If GOK=0
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Return
Endif
[F:SIH]GTE = GTECOD
# Journal
If [F:TSV]JOU=""
 Call EVALAUTO([F:TSV]COD2,"JOU",JOUCOD)From SUBBIC
 If JOUCOD=""
  Call LEC_GTE_LEG([F:CPY]LEG,GTECOD) From CPTLEC
  JOUCOD = [F:GTE]DEFJOU
  If JOUCOD=""
   Call ECR_TRACE(mess(53,141,1),1) From GESECRAN   # Journal non défini
   GOK=0 : Return
  Endif
 Endif
Else
 JOUCOD=[F:TSV]JOU
Endif
# Contrôles sur journal
Gosub CONT_JOU
If GOK=0
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 Return
Endif
[F:SIH]JOU = JOUCOD
# Numéro de facture
Call LEC_GTE_LEG([F:CPY]LEG,[F:SIH]GTE) From CPTLEC
Call NUMERO([F:GTE]COU,[F:SIH]FCY,[F:SIH]ACCDAT,[F:SIH]JOU,[F:SIH]NUM,STAT) From SUBANM
If GOK<0 : Return
Elsif GOK<1 | STAT
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  Call ECR_TRACE(mess(60,199,1)-"("+[F:GTE]COU+") : "+MESSA,1) From GESECRAN
 Endif
 GOK=0 : Return
Endif

#85785
# ----------------------------------------------------------- #
# Digital signature                                           #
# ----------------------------------------------------------- #
If func PORLEGLIB.DIGSIGN("", [F:SIH]CPY)
  Local Char DKSORIG : DKSORIG = "SIH"
  Local Integer DKSRET : DKSRET  = 1
  Gosub DKS_INICRE_TRIGGER From DKSLIB
  If !GOK | DKSRET = 0
    GOK = 0
    Call FSTA("SIH") From GLOCK : Return
    Call MESSAGE(GMESSAGE) From GESECRAN
  Endif
Endif

 #Controle de chronologie du numéro de facture
If [F:GTE]COU<>""
 Read [ANM]ANM0 = [F:GTE]COU
 If fstat
  Call RSTA("ANM",[F:GTE]COU) From GLOCK : GOK=0 : Return
 Endif
 If [F:ANM]CTLCHR=2     # Le controle de chronologie est positionné
  NUMERO = [F:SIH]NUM : OK1 = 1
  Repeat
   Call NUMERO_PREC([F:GTE]COU,[F:SIH]FCY,[F:SIH]ACCDAT,[F:SIH]JOU,NUMERO,[L]SEQ,STAT)
&  From SUBANM
   If NUMERO = [F:SIH]NUM : Break : Endif
   If STAT : GOK = 0 : Break : Endif
   Read [SIH1]SIH0 = NUMERO
   If !fstat
    If [F:SIH1]ACCDAT > [F:SIH]ACCDAT
     #--- Date incorrecte par rapport à la facture précédente
     Call ECR_TRACE(mess(101,121,1),1) From GESECRAN
     GOK = 0
    Endif
    OK1 = 0
   Endif
  Until OK1=0 or SEQ=1
  If GOK=0 : Return : Endif
 Endif
Endif
Call ACCNUM([F:SIH]ACCNUM) From SUBGAS       : # Numéro interne
[F:SIH]AMTNOT = [F:UNP]AMTCRG                : # HT
[F:SIH]AMTATI = [F:UNP]AMTCRG+[F:UNP]AMTVAT  : # TTC
[F:SIH]TAX(0) = [F:UNP]TAX
[F:SIH]BASTAX(0) = [F:UNP]AMTCRG
[F:SIH]AMTTAX(0) = [F:UNP]AMTVAT
[F:SIH]NBRTAX = 1

# Législation Belge (exigence 82614) : VCS Sequencing number --str
If func AFNC.ACTIV("KBE") Then
 # Pour les factures et Notes de débit
 If  find([F:SIH]INVTYP,1,3)>0 Then
  Local Char MESSA(255)
  Call BELSETVCS([F:SIH]FCY,[F:SIH]ACCDAT,[F:SIH]BELVCS,STAT,MESSA) From INVVCSLIB
  If GOK<0 Then Return
  Elsif GOK<1 | STAT
   If STAT
    Call ECR_TRACE(MESSA,1) From GESECRAN
   Endif
   GOK=0 : Return
  Endif
 Endif
Endif
#Localisation Belge (exigence 82614) --end

##Initialization UMRNUM
If func AFNC.PARAM("SDDMGT",[F:SIH]CPY)="2"
 Local Integer FLG_UMRNUM
 Call PTESDD([F:SIH]PTE,FLG_UMRNUM) From INVSDDLIB
 If FLG_UMRNUM
  Call INIT_UMRNUM([F:SIH]CPY,[F:SIH]BPRPAY,2,2,[F:SIH]UMRNUM) From INVSDDLIB
 Endif
Endif
##

If dim([F:SIH]CREDAT)>0 : [F:SIH]CREDAT = date$ : Endif
If dim([F:SIH]CREUSR)>0 : [F:SIH]CREUSR = GUSER : Endif
If dim([F:SIH]EXPNUM)>0 : [F:SIH]EXPNUM = [C]EXPORT : Endif

#angre 02/29/16 SAM 114876 Generate ISR reference line
# X3-103717 Bader 2018-08-27 Parameters managed by activity code - Development rules update begin
If func AFNC.ACTIV("KSW") Then
# X3-103717 Bader end
  Call CALC_BVRFIELDS([F:SIH]FCY,[F:SIH]INVTYP,[F:SIH]PTE,[F:SIH]BPRPAY,[F:SIH]CUR) From SUBSIHSWI
# X3-103717 Bader 2018-08-27 Parameters managed by activity code - Development rules update begin
  If not GOK : Return : Endif
Endif
# X3-103717 Bader end

Write [SIH]
If fstat
 GOK = 0 : Call FSTA("SIH") From GLOCK : Return
Endif
Return

$LIGNES
Local Char    P_COA (GLONCOA)
Local Char    CRIBLE(20)
# Ligne de facture client
Raz [F:SIL]
[F:SIL]INVTYP    = [F:SIH]INVTYP  : # Type de facture
[F:SIL]NUM       = [F:SIH]NUM     : # Numéro de facture
[F:SIL]LIG       = 1              : # No ligne
[F:SIL]DES       = [F:UNP]DES
[F:SIL]FCYLIN    = [F:UNP]FCY     : # Site
[F:SIL]BPRLIN    = ""             : # Tiers
For NLED=1 To NBLED
 If TCPTFRAIS(NLED)="" &  [F:GTE]AUZLED(TLEDTYP(NLED)-1)>1
  Call LECPLAN([F:CPY]CPY,TLEDTYP(NLED),P_COA) From CPTDIV
  Call INIACC(PLGEN,TCPTFRAIS(1),P_COA,TCPTFRAIS(NLED),[L]CRIBLE) From CPTINI
  If TCPTFRAIS(NLED)="" & [F:GTE]AUZLED(TLEDTYP(NLED)-1)=3
   Call ECR_TRACE(mess(18,2649,1)-tolower(mess(176,105,1))-TPLAN(NLED),1) From GESECRAN
   GOK=0 : Break
  Endif
 Endif
 [F:SIL]COA(TLEDTYP(NLED)-1) = TPLAN(NLED)         : # Plan de comptes
 [F:SIL]ACC(TLEDTYP(NLED)-1) = TCPTFRAIS(NLED)     : # Compte de frais bancaires
 TLED = TLEDTYP(NLED) : Gosub LECLED From SUBBICS
 [F:SIL]LED(TLEDTYP(NLED)-1) = [L]LED
Next
If GOK=0 : Return : Endif
[F:SIL]SAC       = ""             : # Collectif (il sera à vide)
Call RECH_ACC(2,[F:SIH]CPY,TLEDTYP,NBLED,[F:SIL]COA,[F:SIL]ACC,PLANA,CPTANA) From CPTDIV
FLGANA=0
If [L]CPTANA<>""
 Call LECTURE("GAC",[L]CPTANA,PLANA) From CONTOBJ
 [F:SIL]DSP = [F:GAC]DSP          : # Répartition
 [F:SIL]UOM = [F:GAC]UOM          : # Unité d'eouvre
 FLGANA=1
Endif
[F:SIL]AMTNOTLIN = [F:UNP]AMTCRG  : # Montant HT
[F:SIL]AMTATILIN = [F:UNP]AMTCRG+[F:UNP]AMTVAT : # Montant TTC
[F:SIL]VAT       = [F:UNP]TAX     : # Code TVA
[F:SIL]AMTVAT    = [F:UNP]AMTVAT  : # Montant TVA
Write [SIL]
If fstat
 GOK = 0 : Call FSTA("SIL") From GLOCK : Return
Endif
If FLGANA
 # Lignes de facture client (analytique)
 Raz [F:SIA]
 [F:SIA]NUM       = [F:SIL]NUM       : # Numéro de facture
 [F:SIA]LIG       = [F:SIL]LIG       : # No ligne (la facture contiendra 1 ligne)
 [F:SIA]ANALIG    = 1                : # Numéro d'ordre
 [F:SIA]INVTYP    = [F:SIL]INVTYP    : # Type facture
 [F:SIA]AMT       = [F:SIL]AMTNOTLIN : # Montant HT
 For NLED=0 To dim([F:SIA]COA)-1
  [F:SIA]COA(NLED) = [F:SIL]COA(NLED)
  [F:SIA]ACC(NLED) = [F:SIL]ACC(NLED)
 Next
 [F:SIA]UOM       = [F:SIL]UOM       : # Unité d'oeuvre

 For I=0 To dim([F:SIA]CCE)-1
  [F:SIA]DIE(I) = [F:UNP]DIE(I)   : # Axes analytiques
  [F:SIA]CCE(I) = [F:UNP]CCE(I)   : # Sections analytiques
 Next I
 Write [SIA]
 If fstat
  GOK = 0 : Call FSTA("SIA") From GLOCK : Return
 Endif
Endif

# Relevé & Relance
If !clalev([F:TPT])  : Local File TABPAYTERM [TPT]  : Endif
If !clalev([F:BPC2]) : Local File BPCUSTOMER [BPC2] : Endif

Local Integer XSOI
Local Integer XFLGFUP

If GPAYTERM=1   :# tiers payeur
 If [F:BPC2]BPCNUM<>[F:SIH]BPRPAY
  Read [BPC2]BPC0 = [F:SIH]BPRPAY
  If fstat
   If [F:BPC2]BPCNUM<>[F:SIH]BPR
    Read [BPC2]BPC0 = [F:SIH]BPR
    If fstat : Raz [F:BPC2] : Endif
   Endif
  Endif
 Endif
Else
 If [F:BPC2]BPCNUM<>[F:SIH]BPR
  Read [BPC2]BPC0 = [F:SIH]BPR
  If !fstat : Raz [F:BPC2] : Endif
 Endif
Endif

XSOI = 1+([F:BPC2]SOIPER>1)
If XSOI=2
 Call LEC_TPT_LEG(GCURLEG,[F:SIH]PTE,1) From CPTLEC
 XSOI = [F:TPT]SOIFLG
Endif


If dim([F:BPC]FUPTYP)>0 & [F:BPC]FUPTYP=1
 XFLGFUP = 1
Else
 XFLGFUP = 2
Endif

# Création des échéances de la facture
Call CREECHE(1,XSOI,XFLGFUP,len(mess(0,510,1))) From SUBBIH
Return

#######################
$LECADR
Call LEC_BPC([F:UNP]BPR) From CPTLEC
Read [BPA]BPA0 = 1;[F:UNP]BPR;[F:BPC]BPAADD
If !fstat
 [F:SIH]BPAINV = [F:BPA]BPAADD
 For I=0 To min(dim([F:SIH]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
  [F:SIH]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [F:SIH]POSCOD = [F:BPA]POSCOD
 [F:SIH]CTY    = [F:BPA]CTY
 [F:SIH]CRY    = [F:BPA]CRY
 [F:SIH]CRYNAM = [F:BPA]CRYNAM
Endif
For I=0 To min(dim([F:SIH]BPRNAM),dim([F:BPC]BPCNAM))-1
 [F:SIH]BPRNAM(I) = [F:BPC]BPCNAM(I)
Next I
Read [BPA]BPA0 = 1;[F:SIH]BPRPAY;[F:SIH]BPAPAY
If !fstat
 For I=0 To min(dim([F:SIH]BPYADDLIG),dim([F:BPA]BPAADDLIG))-1
  [F:SIH]BPYADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [F:SIH]BPYPOSCOD = [F:BPA]POSCOD
 [F:SIH]BPYCTY    = [F:BPA]CTY
 [F:SIH]BPYCRY    = [F:BPA]CRY
 [F:SIH]BPYSAT    = [F:BPA]SAT
 If [F:BPA]CRYNAM<>"" : [F:SIH]BPYCRYNAM = [F:BPA]CRYNAM
 Else [F:SIH]BPYCRYNAM="" : Call INIPAYS([F:BPA]CRY,[F:SIH]BPYCRYNAM) From TRTDIV
 Endif
Endif
Call LEC_BPC([F:SIH]BPRPAY) From CPTLEC
For I=0 To min(dim([F:SIH]BPYNAM),dim([F:BPC]BPCNAM))-1
 [F:SIH]BPYNAM(I) = [F:BPC]BPCNAM(I)
Next I
Call LEC_BPC([F:UNP]BPR) From CPTLEC
Return

#######################
$CONT_GTE
If !clalev([F:GTE])    : Local File GTYPACCENT  [GTE]  : Endif
Call LEC_GTE_LEG([F:CPY]LEG,GTECOD) From CPTLEC
If fstat
 GOK=0 : Call RSTA("GTE",GTECOD) From GLOCK : Return
Else
 If [F:GTE]ENAFLG<>2    # Type de pièce : GTE \ Fiche inactive
  GMESSAGE = mess(22,107,1)-":"-GTECOD+"\"+mess(2,126,1)
  GOK=0 : Return
 Elsif [F:GTE]ACS<>""    # Code d'accès
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If mkstat
   GMESSAGE = [F:GTE]ACS-GMESSAGE    # Vous n'avez pas les droits d'exécution
   GOK=0 : Return
  Endif
 Endif
 mkstat=0 : Call CTLVLYDAT([F:SIH]ACCDAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
 If mkstat
  GMESSAGE=mess(22,107,1)-GTECOD-GMESSAGE    # Type de pièce
  GOK=0 : Return
 Endif
 If [F:GTE]VCRREA<>2
  # Type de pièce non réel
  GMESSAGE=mess(59,119,1)
  GOK=0 : Return
 Endif
Endif
Return


#######################
$CONT_JOU
If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
Call LEC_JOU_LEG([F:CPY]LEG,JOUCOD) From CPTLEC
If fstat
 GOK=0 : Call RSTA("JOU",JOUCOD) From GLOCK : Return
Else
 If [F:JOU]ENAFLG<>2    # Journal : JOU \ Fiche inactive
  GMESSAGE = mess(13,105,1)-":"-JOUCOD+"\"+mess(2,126,1)
  GOK=0 : Return
 Elsif [F:JOU]ACS<>""      # Code d'accès
  Call CONTEXE([F:JOU]ACS) From CPTSUB
  If mkstat
   GMESSAGE = [F:JOU]ACS-GMESSAGE
   GOK=0 : Return
  Endif
 Endif
 If [F:JOU]FCY<>""      # Société/site
  Call VERSOC([F:JOU]FCY,[F:CPY]CPY,[F:UNP]FCY,[F:JOU]JOU) From CFYSUB
  If mkstat
   GOK=0 : Return
  Endif
 Endif
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE = [F:JOU]JOU-mess(8,106,1)-[F:GTE]TYP   # Journal non autorisé sur le type de pièce
  GOK=0 : Return
 Endif
Endif
Return

#######################
$COURS
Call LEC_GTE_LEG([F:CPY]LEG,[F:SIH]GTE) From CPTLEC
If [F:GTE]RATDAT=2 & [F:SIH]BPRDAT<>[0/0/0]
 [F:SIH]RATDAT = [F:SIH]BPRDAT
Else
 [F:SIH]RATDAT = [F:SIH]ACCDAT
Endif

#
[F:SIH]CURTYP= [F:BPC]CHGTYP
If [F:SIH]CURTYP=0 : [F:SIH]CURTYP = 1 : Endif

#
Call SETFLGDEV([F:SIH]CUR,[F:SIH]CPY,[F:SIH]RATDAT) From CPTDIV
For J=1 To len(mess(0,2644,1))
 Call LECLED([F:SIH]CPY,J,[L]CODLED,[L]DEVLED) From CPTDIV
 [F:SIH]LED(J-1)    = [L]CODLED
 [F:SIH]CURLED(J-1) = [L]DEVLED
 If DEVLED=[F:SIH]CUR
  [F:SIH]RATDIV(J-1) = 1
  [F:SIH]RATMLT(J-1) = 1
 Else
  Gosub INIT_COURS_LED
  If STAT : Break : Endif
 Endif
Next
Return


#######################
$INIT_COURS_LED
If [F:GCM]FLGVCRRAT(J-1)=2
 TYPCOURS = [F:SIH]CURTYP
Else
 TYPCOURS = [F:GCM]TYPRAT(J-1)
Endif
Call INI_COURS2([F:SIH]CUR,[F:SIH]CURLED(J-1),TYPCOURS,[F:SIH]RATDAT,COURDIV,COURMUL,STAT) From SUBSCL
If STAT
 Raz STAT : Return
Elsif STAT
 Raz STAT
Endif

Case [F:GCM]DACRAT(J-1)
 When 1 :
  [F:SIH]RATDIV(J-1)=1 :
  [F:SIH]RATMLT(J-1) = arr(COURMUL/COURDIV,10^-GDECRCU)
 When 2 :
  [F:SIH]RATDIV(J-1) = arr(COURDIV/COURMUL,10^-GDECRCU)
  [F:SIH]RATMLT(J-1) = 1
 When 3 :
  [F:SIH]RATDIV(J-1) = COURDIV
  [F:SIH]RATMLT(J-1) = COURMUL
Endcase
Return

