#<AdxTL>@(#)4.0.0.0 $Revision$ Inquiry TRA
#################################################################################################################
#
#   Tax declaration Austria
#
#   PURPOSE :    Handles GUI and calculates the Austrian VAT declaration (X3 function CONSTRA)
#   AUTHORS :    DNE
#   DATE    :    2012-10-11
#   UPDATES :    2013-12-06 DNE - Inclusion of chamber of commerce fee for U31 form (SAM #90740)
#                2015-08-12 ANGRE New fields 006, 007, 008 SAM# 112760
#
#################################################################################################################

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "TRA", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################



#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
       When "EXEBOUT" : Gosub EXEBOUT
       When "FERME"   : Gosub FERME
       When "LECTURE" : Gosub ACTION From CNSTRASTD2
       When Default   : Gosub ACTION From CNSTRGSTD
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  EXEBOUT
#*
#* Purpose:    Button dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button.
#*
#*! #############################################################################################################

$EXEBOUT
    Case BOUT
        When "A" # OK button
            # Start VAT processing and calculation
            Gosub CALC_VAT_DECLARATION
        When "1" # Button "Output type"
            # Recalculate VAT declaration (if necessary which is indicated
            # by the flag MODIFFLAG).
# DNE SAM #90740 MODIFIED
            Gosub EXEBOUT_RECALC

            # Open the tax declaration export/report dialog
            Gosub OPEN_VAT_DECLARATION_EXPORT_DIALOG
# DNE SAM #90740 MODIFIED
        When "2" # Button "Chamber of commerce fee"
            # Open the tax declaration export/report dialog
            Gosub OPEN_VAT_DECLARATION_CHAMBER_FEE_DIALOG
        When "4" # RECALL button
            Gosub ACTION From CNSTRASTD2
            Gosub EXEBOUT From CNSTRGSTD
        When Default
            Gosub EXEBOUT From CNSTRGSTD
    Endcase
Return
# DNE SAM #90740 MODIFIED
$EXEBOUT_RECALC
    If MODIFFLAG
        Call TEMPON( "C" ) From GESECRAN
        Gosub CALC_VAT_DECLARATION
        Call TEMPOFF From GESECRAN
    Endif
Return


#** #############################################################################################################
#*
#* Sub chunk:  FERME
#*
#* Purpose:    Handler after closing the window. Does some cleaning up:
#*             - Deletes temporary report data from VATLINITMGER table.
#*             - Deletes temporary report data from AREPORTM table.
#*             - Reenables inquiry exports.
#*
#*! #############################################################################################################

$FERME
# DNE SAM #90740 MODIFIED
    # Delete temporary report data from VATLINITMGER table.
    Call DELETELINEITEMS() From CNSTRGSTD

    # Delete temporary report data from AREPORTM table.
    If !clalev([ARM]): Local File AREPORTM[ARM] : Endif

    GOK = 1
    Call DEBTRANS From GLOCK
    Trbegin [ARM]
    Delete [ARM] Where
&       ( ( left$( RPTCOD, 5 ) = "AT-TR" ) or ( left$( RPTCOD, 9 ) = "GERVATVAL" ) )
&       & USR = GUSER
    If fstat
        Rollback
    Else
        Commit
    Endif
    File [ARM]

    # Reenable inquiry exports.
    Enable GSTAXLS
    Enable GSTAXLS2
Return



#** #############################################################################################################
#*
#* Sub chunk:  OPEN_VAT_DECLARATION_EXPORT_DIALOG
#*
#* Purpose:    Opens the tax declaration export/report dialog
#*
#*! #############################################################################################################

$OPEN_VAT_DECLARATION_EXPORT_DIALOG
    Call OPEN_DIALOG( "TRAP" ) From CNSRSGSTDLIB
Return



# DNE SAM #90740 MODIFIED
#** #############################################################################################################
#*
#* Sub chunk:  OPEN_VAT_DECLARATION_CHAMBER_FEE_DIALOG
#*
#* Purpose:    Opens the tax declaration export/report dialog
#*
#*! #############################################################################################################

$OPEN_VAT_DECLARATION_CHAMBER_FEE_DIALOG
    Call OPEN_DIALOG( "TRAQ" ) From CNSRSGSTDLIB
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALC_VAT_DECLARATION
#*
#* Purpose:    Calculates the Austrian VAT declaration and gives a preview of the VAT boxes.
#*
#*! #############################################################################################################

$CALC_VAT_DECLARATION
    # Reset data
    Call DELETELINEITEMS() From CNSTRGSTD
    NOL = 0 : J = 0 : I= 0 : K= 0 : M= 0 : C = 0
    Raz [M:TRG1]
    Raz [M:TRG2]
    [M:TRG1]NBLIG = 0
    [M:TRG2]NBLIG = 0

    # Reset warning flag
    WARNING = 0

    # Parameter that indicates if reference date is accounting date or document date
   # [L]OPT = func CNSTRGSTD.GETCOMPANYVATDAT([M:TRG0]CPY)
     If [M:TRG0]CPY <> ""
      [L]OPT = func CNSTRGSTD.GETCOMPANYVATDAT([M:TRG0]CPY) #Call PARAM([M:TRG0]CPY,"DCLVATDAT",[L]OPT) From ADOVAL
     Elsif [M:TRG0]GRP <> ""
      [L]OPT = func CNSTRGSTD.GETCOMPANYVATDAT([M:TRG0]GRP)
     Endif

    # Set start and end date
    Call SETSTARTANDENDDATE(DATEBEGIN, DATEEND, [M:TRG0]DATDEB, [M:TRG0]DATFIN ) From CNSTRGSTD

    # Set the filter string needed to get the required data
    Call SETFILTERSTRINGS([M:TRG0]CPY, [M:TRG0]GRP, [M:TRG0]FCY, OPT, DATEBEGIN, DATEEND, FIL1, FIL2, FIL3, FIL4, FIL5, FIL6, FIL7) From CNSTRGSTD

    # Set the count of the linecodes in table REPLINDEF for a given legislation
    [L]COUNT = func CNSTRGSTD.LINECODECOUNT([M:TRG0]LEG, 0)

    # Definition and setting of required data arrays
    Gosub KEYDATA From CNSTRGSTD

    # ...
    Call SETLEGISLATIONANDGROUP(LEGISLATION, GROUP, [M:TRG0]LEG, [M:TRG0]GRP) From CNSTRGSTD

    # Joins all required tables with FILTERSTRING
    Gosub QUERY From CNSTRGSTD

    # Set lineitems and write lines in grid
    Gosub SETDATA

    # DNE SAM #90740 MODIFIED
    # ...
    While ( COUNT > 0 ) and (KZDIST( [L]COUNT - 1 ) >= "900" )
        [L]COUNT -= 1
    Wend

    # Set the preview of vat declaration in the grid
    Gosub SETVATPREVIEWGRID From CNSTRGSTD

    [M:TRG1]NBLIG = [L]NOL
    [M:TRG2]NBLIG = K

    # Setup additional vat box numbers (e. g. KZ000) etc.
    Local Decimal AMTVATBASE
    Local Decimal AMTVATBASE2
    Local Decimal AMTVAT
    Local Decimal AMTVAT2
    Local Decimal TOTAMTVATBASE
    Local Decimal TOTAMTVAT
    Local Char VATBOX(8)

    Gosub CALC_UPDATE_SIGNS
    Gosub CALC_VAT_DECLARATION_VAT
    Gosub CALC_RECALC_NEGATIVE_VALUES

    # Sort data by box number.
    Sorta [M:TRG1]NBLIG [M:TRG1]NBLIG Order By [M:TRG1]REPLINE(indice)

    # Update masks.
    Affzo [M:TRG1]
    Affzo [M:TRG2]

    # Reset modification flag (for everything is calculated, now).
    MODIFFLAG = 0

    # If there were problems warn.
    If WARNING
        Call WARNINGMESSAGE( 0 ) From CNSTRGSTD
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  SETDATA
#*
#* Purpose:    ...
#*
#*! #############################################################################################################

$SETDATA
  # NOTE: This is a copy of CNSTRGSTD.SETDATA without the call to round down to the next integer.
  #
  Local Char USERID(30)         : USERID = func CNSTRGSTD.GETUSERID()
  Local Integer ITMCOUNT        : ITMCOUNT = 0
  Local Integer MAX_OCCURRENCES : MAX_OCCURRENCES = dim([M:TRG2]SNS)

  J = 0 : I= 0 : M= 0 : K=0






#issue X3-94050

 #X3-69522 new group handling
   If [M:TRG0]GRP <> ""
    Filter [F:AGC] Where [F:AGC]GRP = GROUP
    For [F:AGC]
      Call SETFILTERSTRINGS([F:AGC]CPY, "", [M:TRG0]FCY, OPT, DATEBEGIN, DATEEND, FIL1, FIL2, FIL3, FIL4, FIL5, FIL6, FIL7) From CNSTRGSTD
      LEDINDEX = func CNSTRGSTD.GETMAINLEDORINDEX([F:AGC]CPY,1)
      Link [DAE] With
&  [F:CPY]CPY0  = [F:DAE]CPY
& ,[F:HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM
& ,[F:GCM]GCM0 = [F:CPY]ACM
& ,[F:LED]LED0 = [F:GCM]LED(LEDINDEX)
& ,[F:COA]COA0 = [F:LED]COA
& ,[F:GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
& ,[F:GTE]GTE0 = [F:DAE]TYP
& ,[F:TRP]TRPG4 = LEGISLATION;[F:DAE]TAX
& ,[F:BPR]BPR0 = [F:DAE]OFFACC
& As [LNK]
& Where evalue(FIL1 + FIL2 + FIL3 + FIL4 + FIL5 + FIL6 + FIL7)
& & [F:HAE]CAT = 1
& & [F:TRP]REPLINE <>""
& & [F:DAE]COA = [F:COA]COA
& & [F:TRP]FLGVAT = [F:GAC]FLGVAT
& & [F:TRP]VATIPT = [F:GAC]VATIPT
& & ([F:GTE]VAT = 2 or [F:GTE]VATPAI = 2)
& & ([F:GTE]LEG = LEGISLATION or [F:GTE]LEG = "")


      Gosub SETITEMS From CNSTRGSTD
      Filter [LNK]
    Next
    Filter [F:AGC]
     #X3-69522 new group handling end
  Else
    Gosub SETITEMS From CNSTRGSTD
  Endif



#orig
#  # Loop through the list of line codes
#  For I = 0 To dim([L]KZDIST) - 1
#    SUM_TRANSVOLUME = 0
#    SUM_TAX = 0
#    # Calculate line amounts.
#    Call SETLINEITEMS( [L]KZDIST(I), SUM_TRANSVOLUME, SUM_TAX, K, WARNING, EXTFLAG, USERID, MAX_OCCURRENCES, ITMCOUNT  ) From CNSTRGSTD
#    TRANSVOLUME(I) = SUM_TRANSVOLUME
#    TTAX(I) = SUM_TAX
#  Next
#orig end
  If ( EXTFLAG = 0 ) and ( ITMCOUNT > MAX_OCCURRENCES )
      Call ECR_TRACE (mess(321,107,1) + " " + mess(322,107,1) + " " + mess(323,107,1),0) From GESECRAN
      # "The maximum number of records for display has been exceeded. "
      # "This will no effect the correct processing of your data. "
      # "Please use the report function instead."
  Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALC_RECALC_NEGATIVE_VALUES
#*
#* Purpose:    ...
#*
#*! #############################################################################################################

$CALC_RECALC_NEGATIVE_VALUES
    # Create box KZ067
    [M:TRG1]REPLINE(    [M:TRG1]NBLIG ) = "067"
    [M:TRG1]AMTVATBASE( [M:TRG1]NBLIG ) = 0
    [M:TRG1]AMTVAT(     [M:TRG1]NBLIG ) = 0
    [M:TRG1]NBLIG += 1

    # Create box KZ090
    [M:TRG1]REPLINE(    [M:TRG1]NBLIG ) = "090"
    [M:TRG1]AMTVATBASE( [M:TRG1]NBLIG ) = 0
    [M:TRG1]AMTVAT(     [M:TRG1]NBLIG ) = 0
    [M:TRG1]NBLIG += 1

    # Treat VAT when negative.
    For VATBOX= "001"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVATBASE2 < 0 or AMTVAT2< 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "000",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "000",  AMTVATBASE + AMTVATBASE2, 0 )
        Endif
    Next

    # Treat VAT when negative.
    # 2015-08-12 new fields 006, 007 SAM# 112760 ANGRE
     For VATBOX= "011", "012", "015", "017", "016", "018", "019", "020",
&               "022", "006", "007", "029","025", "037", "038", "052",
&               "056", "057", "048", "044", "032",
&               "021"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVATBASE2 < 0 or AMTVAT2< 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "000",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "000",  AMTVATBASE - AMTVATBASE2, 0 )
            Call GET_BOX_CONTENT( "090",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "090",  0, AMTVAT + AMTVAT2 )
        Endif
    Next

    # Treat VAT when negative.
    For VATBOX= "071"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVATBASE2 < 0 or AMTVAT2< 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "070",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "070",  AMTVATBASE - AMTVATBASE2, 0 )
        Endif
    Next

    # Treat VAT when negative.
    # 2015-08-12 new field 008 SAM# 112760
    For VATBOX= "072", "073", "008", "076", "077", "088"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVATBASE2 < 0 or AMTVAT2< 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "070",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "070",  AMTVATBASE - AMTVATBASE2, 0 )
            Call GET_BOX_CONTENT( "067",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "067",  0, AMTVAT - AMTVAT2 )
            Call GET_BOX_CONTENT( "090",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "090",  0, AMTVAT + AMTVAT2 )
        Endif
    Next

    # Box KZ065 ("corrected")
    # 2015-08-12 new field 008 SAM# 112760
    TOTAMTVAT = 0
    For VATBOX = "072", "073", "008", "088"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
        TOTAMTVAT -= AMTVAT
    Next
    Call SET_BOX_CONTENT( "065", 0, TOTAMTVAT )

    # Treat VAT when negative.
    For VATBOX= "060", "061", "064", "065", "066", "067",
&               "082", "083", "087", "089"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVAT2 > 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "067",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "067",  0, AMTVAT + AMTVAT2 )
        Endif
    Next

    # Treat VAT when negative (exclusive for box KZ062).
    For VATBOX= "062"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE2, AMTVAT2 )
        If AMTVAT2 < 0
            Call SET_BOX_CONTENT( VATBOX, 0, 0 )
            Call GET_BOX_CONTENT( "067",  AMTVATBASE, AMTVAT )
            Call SET_BOX_CONTENT( "067",  0, AMTVAT + AMTVAT2 )
        Endif
    Next


    # Box KZ095
    TOTAMTVATBASE = 0
    TOTAMTVAT = 0
# 2015-08-12 new fields 006, 007, 008 SAM# 112760 ANGRE
    For VATBOX= "022", "006", "007", "008", "029", "025", "037", "052", "038", "056", "057",
&               "048", "044", "032", "072", "073", "088",
&               "060", "061", "083", "065", "066", "082", "087", "089",
&               "064", "062", "063", "067",
&               "090"
# 2013-11-15 DNE MODIF ORIG
#    For VATBOX= "022", "029", "025", "037", "052", "038", "056", "057",
#&               "048", "044", "032", "072", "073", "088",
#&               "060", "061", "083", "065", "066", "082", "087", "089",
#&               "064", "062", "063", "067",
#&               "027", "028", "090"
# 2013-11-15 DNE MODIF END
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
        TOTAMTVAT += AMTVAT
    Next
    [M:TRG1]REPLINE(    [M:TRG1]NBLIG ) = "095"
    [M:TRG1]AMTVATBASE( [M:TRG1]NBLIG ) = TOTAMTVATBASE
    [M:TRG1]AMTVAT(     [M:TRG1]NBLIG ) = TOTAMTVAT
    [M:TRG1]NBLIG += 1
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALC_VAT_DECLARATION_VAT
#*
#* Purpose:    ...
#*
#*! #############################################################################################################

$CALC_VAT_DECLARATION_VAT
    # Box ST022
    VATBOX= "022"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.20 ) )

    # 2015-08-12 new fields 006, 007, 008 SAM# 112760 ANGRE
    # Box ST006
    VATBOX = "006"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.13 ) )

    # Box ST007
    VATBOX = "007"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.07 ) )

    # Box ST008
    VATBOX = "008"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.13 ) )

    # Box ST029
    VATBOX= "029"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.10 ) )

    # Box ST025
    VATBOX= "025"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.12 ) )

    # Box ST037
    VATBOX= "037"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.19 ) )

    # Box ST052
    VATBOX= "052"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.10 ) )

    # Box ST038
    VATBOX= "038"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.08 ) )

    # Box ST072
    VATBOX= "072"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.20 ) )

    # Box ST073
    VATBOX= "073"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.10 ) )

    # Box ST088
    VATBOX= "088"
    Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
    Call SET_BOX_CONTENT( VATBOX, AMTVATBASE, ar2( AMTVATBASE * 0.19 ) )
Return



#** #############################################################################################################
#*
#* Sub chunk:  CALC_UPDATE_SIGNS
#*
#* Purpose:    ...
#*
#*! #############################################################################################################

$CALC_UPDATE_SIGNS
    # NOTE: We only need the bases for the tax amount is calculated afterwards.
    #
    # Reverse all VAT bases.
    For I = 0 To [M:TRG1]NBLIG - 1
        [M:TRG1]AMTVATBASE( I ) = - [M:TRG1]AMTVATBASE( I )
    Next

    # Reverse sign(s) where needed.
    # 2015-08-12 new field 008 SAM# 112760 ANGRE
    For VATBOX= "008", "027", "028",
&               "060", "061", "062", "063", "064", "065", "066",
&               "070", "071", "072", "073", "076", "077",
&               "082", "083", "087", "088", "089"
        Call GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
        Call SET_BOX_CONTENT( VATBOX, -AMTVATBASE, -AMTVAT )
    Next
Return



#** #############################################################################################################
#*
#* Procedure:  GET_BOX_CONTENT
#*
#* Purpose:    Gets the values of the named box in VATBOX as base amount (AMTVATBASE) and tax amount (AMTVAT).
#*
#* Parameters:
#*
#* @param VATBOX      VAT box name/id
#* @oaram AMTVATBASE  Reference to the VAT base amount, returns its value
#* @oaram AMTVAT      Reference to the VAT tax amount, returns its value
#*
#*! #############################################################################################################

Subprog GET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
Value Char VATBOX()
Variable Decimal AMTVAT
Variable Decimal AMTVATBASE
    Local Integer I

    AMTVAT = 0
    AMTVATBASE = 0

    # Search for the given vat box in the result grid.
    I = find( VATBOX, [M:TRG1]REPLINE(0..( [M:TRG1]NBLIG - 1 ) ) ) - 1
    If I >= 0
        AMTVATBASE = [M:TRG1]AMTVATBASE(I)
        AMTVAT     = [M:TRG1]AMTVAT(I)
    Endif
End



#** #############################################################################################################
#*
#* Procedure:  SET_BOX_CONTENT
#*
#* Purpose:    Sets the values of the named box in VATBOX from base amount (AMTVATBASE) and tax amount (AMTVAT).
#*
#* Parameters:
#*
#* @param VATBOX      VAT box name/id
#* @oaram AMTVATBASE  VAT base amount to set
#* @oaram AMTVAT      VAT tax amount to set
#*
#*! #############################################################################################################

Subprog SET_BOX_CONTENT( VATBOX, AMTVATBASE, AMTVAT )
Value Char VATBOX()
Value Decimal AMTVAT
Value Decimal AMTVATBASE
    Local Integer I

    # Search for the given vat box in the result grid.
    I = find( VATBOX, [M:TRG1]REPLINE(0..( [M:TRG1]NBLIG - 1 ) ) ) - 1
    If I >= 0
        [M:TRG1]AMTVATBASE(I) = AMTVATBASE
        [M:TRG1]AMTVAT(I)     = AMTVAT
    Endif
End

