#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OECP

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:35"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OECP",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="ECP0;ECP1;EMP9;ECP3;ECP6;ECP2;ECP4;ECP5;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = "ECP0"
BOX1 = "GAU_CHE1"
OBJLIS(1) = "ECT"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 1
DESLIS(1) = "REFNUM+CTRNUM"
OBJLIS(2) = "EC2"
CHGLIS(2) = 2
BROLIS(2) = 2
TRELIS(2) = 2
DESLIS(2) = "FCY+SRV+REFNUM"
If clalev([M:ECP0])=0 : Local Mask ECP0 [ECP0] : Endif
If clalev([M:ECP1])=0 : Local Mask ECP1 [ECP1] : Endif
If clalev([M:EMP9])=0 : Local Mask HRMAT9 [EMP9] : Endif
If clalev([M:ECP3])=0 : Local Mask ECP3 [ECP3] : Endif
If clalev([M:ECP6])=0 : Local Mask ECP6 [ECP6] : Endif
If clalev([M:ECP2])=0 : Local Mask ECP2 [ECP2] : Endif
If clalev([M:ECP4])=0 : Local Mask ECP4 [ECP4] : Endif
If clalev([M:ECP5])=0 : Local Mask ECP5 [ECP5] : Endif
Gosub TIT
nolign = 1
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
Link [ECT] With
& [ID]ID0=[F:ECT]REFNUM,
& [FCY]FCY0=[F:ECT]FCY,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [CPY]CPY0=[F:FCY]LEGCPY
& As [ECT_]
If clalev([F:ECT])=0 : Local file EMPCTR [ECT] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [ECT] With
& [ID]ID0=[F:ECT]REFNUM,
& [FCY]FCY0=[F:ECT]FCY,
& [SRV]SRV0=[F:ECT]SRV,
& [CPY]CPY0=[F:FCY]LEGCPY,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [AXX]AXX0="SERVICE";"DES";GLANGUE;[F:SRV]COD;""
& As [EC2]
& Order By Key ECT2
Return

$DEF_BOITE
Gosub HORODAT From WGOECP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OECP" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP0]
&   Folder Mask [ECP1]
& , Folder Mask [EMP9]
& , Folder Mask [ECP3]
& , Folder Mask [ECP6]
& , Folder Mask [ECP2]
& , Folder Mask [ECP4]
& , Folder Mask [ECP5]
&  Listbox [ECT_] GAU_CHE1
&   [L]SAIRAP(1) = [F:ECT]REFNUM Using "K:15c" Titled TITSEL1(1) ,
&   [L]SAIRAP(2) = [F:ECT]CTRNUM Using "K:20X" Titled TITSEL1(2) ,
&   [L]SAIRAP(3) = [F:ID]NAM Using "K:40X" Titled TITSEL1(3) ,
&   [L]SAIRAP(4) = [F:ID]SRN Using "K:40X" Titled TITSEL1(4) ,
&   [L]SAIRAP(5) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL1(5) ,
&   [L]SAIRAP(6) = [F:ECT]FCY Using "K:5c" Titled TITSEL1(6) ,
&   [L]SAIRAP(7) = mess([F:ID]ENAFLG(0),1,1) Using "" Titled TITSEL1(7)
&  Treebox [EC2] GAU_CHE2
&   [F:CPY]CPY-[F:CPY]CPYNAM-'/'-[F:ECT]FCY-[F:FCY]FCYNAM Using "K:80X" Titled TITSEL2(1) ,
&   [F:ECT]SRV-[F:AXX]TEXTE Using "K:20X" Titled TITSEL2(2) ,
&   [F:ECT]REFNUM-[F:ID]NAM-[F:ID]SRN
&   +" "+string$([F:CPY]LEG<>'',[F:CPY]LEG)+string$([F:CPY]LEG='',mess(91,187,1))
&   Titled ""
& As [ECP1]
Titled [ECP1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOECP
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OECP" From GFONCTION At A_STAMP With A_WINDPREV Mask [ECP0]
&   Folder Mask [ECP1]
& , Folder Mask [EMP9]
& , Folder Mask [ECP3]
& , Folder Mask [ECP6]
& , Folder Mask [ECP2]
& , Folder Mask [ECP4]
& , Folder Mask [ECP5]
& As [ECP1]
Titled [ECP1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [ECP1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [ECP1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [ECP1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS1(30)
Call TEXTE(47966,TITLIS1) From OBJDIV
Local Char TITLIS2(30)
Call TEXTE(47967,TITLIS2) From OBJDIV
Local Char TITSEL1(30)(1..7)
Call TEXTE(10793,TITSEL1(1)) From OBJDIV
Call TEXTE(5481,TITSEL1(2)) From OBJDIV
Call TEXTE(55,TITSEL1(3)) From OBJDIV
Call TEXTE(1825,TITSEL1(4)) From OBJDIV
Call TEXTE(1343,TITSEL1(5)) From OBJDIV
Call TEXTE(1344,TITSEL1(6)) From OBJDIV
Call TEXTE(188,TITSEL1(7)) From OBJDIV
Local Char TITSEL2(30)(1..4)
Call TEXTE(8730,TITSEL2(1)) From OBJDIV
Call TEXTE(18735,TITSEL2(2)) From OBJDIV
Call TEXTE(10793,TITSEL2(3)) From OBJDIV
Call TEXTE(26213,TITSEL2(4)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(45441,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$REMPLIT_1
Gosub SETCLE_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [ECT_] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [ECP1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [ECP1] GAU_CHE1
 Else
  Fillbox [ECP1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [ECT_]
Return

$REMPLIT_2
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [EC2] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order By Key ECT2
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(2)<>'' or NOHLIS(2)<>0
 Fillbox [ECP1] GAU_CHE2 Hint Key =HINTLIS(2)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [ECP1] GAU_CHE2
 Else
  Fillbox [ECP1] GAU_CHE2 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [EC2]
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 2
GAUTRELIS = 1
CLELISTE = "REFNUM;CTRNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_2
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 3
SNSLIS = 1
LENLIS = 3
GAUTRELIS = 2
CLELISTE = "FCY;SRV;REFNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 1 : Default file [ECT_]
 When 2 : Default file [EC2]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_] Order With CLELISTE
  Setlbox [ECP1] GAU_CHE1
  Filter [ECT_]
 When "GAU_CHE2"
  Setlbox [ECP1] GAU_CHE2
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE1"
  Gosub SETCLE_1
  Filter [ECT_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "ECP0"         : ABMSK(0)  = "ECP0"     : AMA(0) = 1
NOMMSK(1) = "ECP1"         : ABMSK(1)  = "ECP1"     : AMA(1) = 1
NOMMSK(2) = "HRMAT9"       : ABMSK(2)  = "EMP9"     : AMA(2) = 1
NOMMSK(3) = "ECP3"         : ABMSK(3)  = "ECP3"     : AMA(3) = 1
NOMMSK(4) = "ECP6"         : ABMSK(4)  = "ECP6"     : AMA(4) = 1
NOMMSK(5) = "ECP2"         : ABMSK(5)  = "ECP2"     : AMA(5) = 1
NOMMSK(6) = "ECP4"         : ABMSK(6)  = "ECP4"     : AMA(6) = 1
NOMMSK(7) = "ECP5"         : ABMSK(7)  = "ECP5"     : AMA(7) = 1
NBMASK = 7
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:ECP0])>0 : Default Mask [ECP0] : Endif
 When 1 : If clalev([M:ECP1])>0 : Default Mask [ECP1] : Endif
 When 2 : If clalev([M:EMP9])>0 : Default Mask [EMP9] : Endif
 When 3 : If clalev([M:ECP3])>0 : Default Mask [ECP3] : Endif
 When 4 : If clalev([M:ECP6])>0 : Default Mask [ECP6] : Endif
 When 5 : If clalev([M:ECP2])>0 : Default Mask [ECP2] : Endif
 When 6 : If clalev([M:ECP4])>0 : Default Mask [ECP4] : Endif
 When 7 : If clalev([M:ECP5])>0 : Default Mask [ECP5] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:ECP0])>0 : Gosub TITRES From W1ECP0 : Endif
 When 1 : If clalev([M:ECP1])>0 : Gosub TITRES From W1ECP1 : Endif
 When 2 : If clalev([M:EMP9])>0 : Gosub TITRES From W1HRMAT9 : Endif
 When 3 : If clalev([M:ECP3])>0 : Gosub TITRES From W1ECP3 : Endif
 When 4 : If clalev([M:ECP6])>0 : Gosub TITRES From W1ECP6 : Endif
 When 5 : If clalev([M:ECP2])>0 : Gosub TITRES From W1ECP2 : Endif
 When 6 : If clalev([M:ECP4])>0 : Gosub TITRES From W1ECP4 : Endif
 When 7 : If clalev([M:ECP5])>0 : Gosub TITRES From W1ECP5 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:ECP0])>0 : Close Local Mask [ECP0] : Endif
If clalev([M:ECP1])>0 : Close Local Mask [ECP1] : Endif
If clalev([M:EMP9])>0 : Close Local Mask [EMP9] : Endif
If clalev([M:ECP3])>0 : Close Local Mask [ECP3] : Endif
If clalev([M:ECP6])>0 : Close Local Mask [ECP6] : Endif
If clalev([M:ECP2])>0 : Close Local Mask [ECP2] : Endif
If clalev([M:ECP4])>0 : Close Local Mask [ECP4] : Endif
If clalev([M:ECP5])>0 : Close Local Mask [ECP5] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:ECP0])>0 : Raz [M:ECP0] : Endif
 When 1 : If clalev([M:ECP1])>0 : Raz [M:ECP1] : Endif
 When 2 : If clalev([M:EMP9])>0 : Raz [M:EMP9] : Endif
 When 3 : If clalev([M:ECP3])>0 : Raz [M:ECP3] : Endif
 When 4 : If clalev([M:ECP6])>0 : Raz [M:ECP6] : Endif
 When 5 : If clalev([M:ECP2])>0 : Raz [M:ECP2] : Endif
 When 6 : If clalev([M:ECP4])>0 : Raz [M:ECP4] : Endif
 When 7 : If clalev([M:ECP5])>0 : Raz [M:ECP5] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:ECP0])>0 : Affzo [M:ECP0] : Endif
 When 1 : If clalev([M:ECP1])>0 : Affzo [M:ECP1] : Endif
 When 2 : If clalev([M:EMP9])>0 : Affzo [M:EMP9] : Endif
 When 3 : If clalev([M:ECP3])>0 : Affzo [M:ECP3] : Endif
 When 4 : If clalev([M:ECP6])>0 : Affzo [M:ECP6] : Endif
 When 5 : If clalev([M:ECP2])>0 : Affzo [M:ECP2] : Endif
 When 6 : If clalev([M:ECP4])>0 : Affzo [M:ECP4] : Endif
 When 7 : If clalev([M:ECP5])>0 : Affzo [M:ECP5] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Affzo [M:ECP0]ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:ECP0])>0 : [F:ID] = [M:ECP0] : Endif
 When 1 : If clalev([M:ECP1])>0 : [F:ID] = [M:ECP1] : Endif
 When 2 : If clalev([M:EMP9])>0 : [F:ID] = [M:EMP9] : Endif
 When 3 : If clalev([M:ECP3])>0 : [F:ID] = [M:ECP3] : Endif
 When 4 : If clalev([M:ECP6])>0 : [F:ID] = [M:ECP6] : Endif
 When 5 : If clalev([M:ECP2])>0 : [F:ID] = [M:ECP2] : Endif
 When 6 : If clalev([M:ECP4])>0 : [F:ID] = [M:ECP4] : Endif
 When 7 : If clalev([M:ECP5])>0 : [F:ID] = [M:ECP5] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:ECP0])>0 : [M:ECP0] = [F:ID] : Endif
 When 1 : If clalev([M:ECP1])>0 : [M:ECP1] = [F:ID] : Endif
 When 2 : If clalev([M:EMP9])>0 : [M:EMP9] = [F:ID] : Endif
 When 3 : If clalev([M:ECP3])>0 : [M:ECP3] = [F:ID] : Endif
 When 4 : If clalev([M:ECP6])>0 : [M:ECP6] = [F:ID] : Endif
 When 5 : If clalev([M:ECP2])>0 : [M:ECP2] = [F:ID] : Endif
 When 6 : If clalev([M:ECP4])>0 : [M:ECP4] = [F:ID] : Endif
 When 7 : If clalev([M:ECP5])>0 : [M:ECP5] = [F:ID] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [ECP0]REFNUM
Else
 Grizo [ECP1]REFNUM
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [ECP0]REFNUM
Else
 Actzo [ECP1]REFNUM
Endif
Return

$BOUTON
STDBOUT = "EAN09<>RILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


