#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier AMEMO
Call OBJET("AMM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS2"     : Gosub LIENS2
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "APRES_MOD"  : Gosub APRES_MOD
 When "INICRE"     : Gosub INICRE
 When "ANNULE"     : Gosub ANNULE
Endcase
Return

$OUVRE
Local Char WSCMTABCLE(GLONAMM) (1..)
Local Char WSCMTABFLG(1) (1..)
Local Integer WSCMNBCLE
Return

$LIENS2
For I=0 To [M]NBLIG-1
 Call TEXTE([M]DES(I),[M]ZDES(I)) From OBJDIV
Next I
Return

$VERIF_MOD
Raz WSCMTABFLG
Raz WSCMTABCLE
WSCMNBCLE=0
For I=0 To [M]NBLIG-1
 Read [AMM]AMM0 = [M]MEMO(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:AMM]WIN<>[M]WIN(I) or [F:AMM]DES<>[M]DES(I) or [F:AMM]CODACT<>[M]CODACT(I)
  [M]MODIF(I) = 1
 Else
  [M]MODIF(I) = 0
 Endif
Next I
If GADONIX=2
 For I=0 To [M]NBLIG-1
  Read [AMM]AMM0 = [M]MEMO(I)
  If fstat
   #SCM
   WSCMNBCLE+=1
   WSCMTABCLE(WSCMNBCLE)=[M]MEMO(I)
   WSCMTABFLG(WSCMNBCLE)="C"
   #Call TRACE_COR(ABREV,[M]MEMO(I),"","C") From GOBJET
  Endif
 Next I
 For [AMM]
  I = find([F:AMM]MEMO,[M]MEMO(0..[M]NBLIG-1))
  If I
   If [F:AMM]WIN<>[M]WIN(I-1) or [F:AMM]DES<>[M]DES(I-1) or [F:AMM]CODACT<>[M]CODACT(I-1)
    #SCM
    WSCMNBCLE+=1
    WSCMTABCLE(WSCMNBCLE)=[F:AMM]MEMO
    WSCMTABFLG(WSCMNBCLE)="m"
    #Call TRACE_COR(ABREV,[F:AMM]MEMO,"","m") From GOBJET
   Endif
  Else
   #SCM
   WSCMNBCLE+=1
   WSCMTABCLE(WSCMNBCLE)=[F:AMM]MEMO
   WSCMTABFLG(WSCMNBCLE)="A"
   #Call TRACE_COR(ABREV,[F:AMM]MEMO,"","A") From GOBJET
  Endif
 Next
Endif
NOL = nolign
Return

$ANNULE
If GADONIX=2 : Call TRACE_COR(ABREV,[L]CODE,"","A") From GOBJET : Endif
Return

$APRES_MOD
#SCM
If GADONIX=2
 Local Integer I
 For I=1 To WSCMNBCLE
  Call TRACE_COR(ABREV,WSCMTABCLE(I),"",WSCMTABFLG(I)) From GOBJET
 Next I
Endif
SUIZON = "[M]NBLIG("+num$(NOL-1)+")"
Return

$INICRE
Case [M]MODIF(nolign-1)
 When 0
  If dim([F:AMM]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AMM]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AMM]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AMM]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:AMM]UPDUSR)>0 : [F:AMM]UPDUSR = ""      : Endif
  If dim([F:AMM]UPDDAT)>0 : [F:AMM]UPDDAT = [0/0/0] : Endif
 When 1 : # Modification
  If dim([F:AMM]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AMM]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AMM]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AMM]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:AMM]UPDUSR)>0 : [F:AMM]UPDUSR = GUSER   : Endif
  If dim([F:AMM]UPDDAT)>0 : [F:AMM]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:AMM]CREUSR)>0 : [F:AMM]CREUSR = GUSER   : Endif
  If dim([F:AMM]CREDAT)>0 : [F:AMM]CREDAT = date$   : Endif
  If dim([F:AMM]UPDUSR)>0 : [F:AMM]UPDUSR = ""      : Endif
  If dim([F:AMM]UPDDAT)>0 : [F:AMM]UPDDAT = [0/0/0] : Endif
Endcase
Return


###########################################
$TRTCOP
If [M]DOSORG=nomap
 Local File AMEMO     [AMM1]
 Local File ATEXTE    [ATX1]
Else
 Local File =[M]DOSORG+".AMEMO"     [AMM1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1]
Endif
If [M]DOSDES=nomap
 Local File AMEMO     [AMM2]
 Local File ATEXTE    [ATX2]
Else
 Local File =[M]DOSDES+".AMEMO"     [AMM2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [AMM1], [ATX1], [AMM2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [AMM2] ,  [ATX2]
 Read [AMM1]AMM0 = TABLE
 If !fstat
  Readlock [AMM2]AMM0 = TABLE
  If fstat=1
   GOK=-1 : GLOCK = "$AMEMO"-TABLE : Goto ROLL_TR_COP
  Elsif fstat
   [F:AMM2] = [F:AMM1]
   Call COPTEXTE([F:AMM1]DES,[F:AMM2]DES) From OBJDIV
   If GOK<1 : Goto AB_TR_COP : Endif
   Write [AMM2]
  Else
   [F:AMM2] = [F:AMM1]
   Call COPTEXTE([F:AMM1]DES,[F:AMM2]DES) From OBJDIV
   If GOK<1 : Goto AB_TR_COP : Endif
   Rewrite [AMM2]
  Endif
  If fstat
   GOK=0 : Call FSTA("AMM2") From GLOCK : Goto AB_TR_COP
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
Subprog C_MEMO(VALEUR)
Variable Char    VALEUR()
Local Integer I, NOL
NOL = 0
For I=1 To [M]NBLIG
 If I<>nolign
  If toupper(VALEUR)=toupper([M]MEMO(I-1))
   NOL = I : Break
  Endif
 Endif
Next I
If NOL
 GERR = 1
 GMESSAGE = mess(24,123,1)-num$(NOL) : # Code déjà existant en ligne
 mkstat = 2 : End
Endif
End

