#----------------------------------------------------------------------------------
$OUVRE_DIM_PADPOQPVF
  Gosub OUVRE_DIM_DETAIL
  Local File =MACHINE+"@"+[F:ABW]COD+".D_PADPOQ"           [BBB_]
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PADPOQ
  Gosub OUVRE_DIM_DETAIL

  #Call ECR_TIME("***********************************************OUVRE_DIM_PADPOQ Début") From DOSSUB
  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPPORDERQ"                     [BIPOQ_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".PORDERP"                          [WPOP_]
  Local File =GDOSSIER+".PORDERQ"                          [WPOQ_]

  Local Char SWHERE(250)
  Local Char SVID1 (type([F:WAUI_]ID1)-10)
  Local Char SVID2 (type([F:WAUI_]ID1)-10)(1..2)

  Local Integer IADXLOG
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BIPOQ_]
  Endif

  Delete [BIPOQ_] Where [BIPOQ_]BIPOQADXUID = adxuid(1)

	If [L]GEN <> 2 Then
		Raz SVID1
		Filter [WAUI_] Where (TBL = [F:ABI]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1;ID2;SEQ Desc

		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (POHNUM ='"+[F:WAUI_]ID1+"')"
				Call DECOUPE_TILDES([F:WAUI_]ID2,SVID2)
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (POPLIN="+SVID2(1)-"& POQSEQ="+SVID2(2)+")"
				  Gosub CREATE_BIPOQ_TRAVAIL
				  SVID1 = [F:WAUI_]ID1+"~"+[F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BIPOQ_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BIPOQ_]
  Close Local File [WAUI_]
  Close Local File [WPOP_]
  Close Local File [WPOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_PADPOQ Fin") From DOSSUB
Return

#----------------------------------------------------------------------------------
$CREATE_BIPOQ_TRAVAIL
  #--Commandes ouvertes
  Filter [WPOQ_] Where POHTYP=2 and evalue(SWHERE)
  For [WPOQ_]
    Raz [F:BIPOQ_]
    [F:BIPOQ_]BIPOQADXUID = adxuid(1)
    [F:BIPOQ_]POHNUM      = [WPOQ_]POHNUM
    [F:BIPOQ_]POPLIN      = [WPOQ_]POPLIN
    [F:BIPOQ_]POQSEQ      = [WPOQ_]POQSEQ
    [F:BIPOQ_]POPSEQ      = 0
    Filter [WPOP_] Where POHNUM=[WPOQ_]POHNUM and POPLIN=[WPOQ_]POPLIN and STRDAT<=[WPOQ_]DEMRCPDAT Order By STRDAT Desc
    For [WPOP_]
      [F:BIPOQ_]POPSEQ    = [WPOP_]POPSEQ
      Break
    Next
    Filter [WPOP_]
    Write [F:BIPOQ_]
  Next
  Filter [WPOQ_]
  #--Commandes normales
  Filter [WPOQ_] Where POHTYP<>2 and evalue(SWHERE)
  For [WPOQ_]
    Raz [F:BIPOQ_]
    [F:BIPOQ_]BIPOQADXUID = adxuid(1)
    [F:BIPOQ_]POHNUM      = [WPOQ_]POHNUM
    [F:BIPOQ_]POPLIN      = [WPOQ_]POPLIN
    [F:BIPOQ_]POQSEQ      = [WPOQ_]POQSEQ
    [F:BIPOQ_]POPSEQ      = [WPOQ_]POQSEQ
    Write [F:BIPOQ_]
  Next
  Filter [WPOQ_]
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PADPOP
Local Integer IADXLOG
Local Char SWHERE(250)

  Gosub OUVRE_DIM_DETAIL
  #Call ECR_TIME("***********************************************OUVRE_DIM_PADPOQ Début") From DOSSUB
  #--Remplissage table temporaire paramétrée dans le link de la dimension
  Local File =GDOSSIER+".BITMPPORDERP"                     [BIPOP_]
  Local File =GDOSSIER+".AUDITBI"                          [WAUI_]

  Local File =GDOSSIER+".PORDERP"                          [WPOP_]
  Local File =GDOSSIER+".PORDERQ"                          [WPOQ_]

Local Char SVID1 (type([F:WAUI_]ID1)-10)
Local Char SVID2 (type([F:WAUI_]ID1)-10)(1..2)

  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BIPOP_]
  Endif
  Delete [BIPOP_] Where [BIPOP_]BIPOPADXUID = adxuid(1)
	If [L]GEN <> 2 Then
		Raz SVID1
		Filter [WAUI_] Where (TBL = [F:ABI]TABORG) and (STABI = 2 or STABI = 4) and EVT <> "DELETE" Order By ID1; ID2; SEQ Desc
		For [WAUI_]
			If SVID1 <> ([F:WAUI_]ID1+"~"+[F:WAUI_]ID2) Then
				SWHERE = " (POHNUM ='"+[F:WAUI_]ID1+"')"
				Call DECOUPE_TILDES([F:WAUI_]ID2,SVID2)
				If SVID2(1)<>"" and SVID2(2)<>""
				  SWHERE -= "& (POPLIN="+SVID2(1)-"& POQSEQ="+SVID2(2)+")"
				  Gosub CREATE_BIPOP_TRAVAIL
				  SVID1 = [F:WAUI_]ID1+"~"+[F:WAUI_]ID2
				Endif
			Endif
		Next
		Filter [WAUI_]
	Else
		SWHERE = " (1=1)"
		Gosub CREATE_BIPOP_TRAVAIL
	Endif
	If IADXLOG = 0 Then
    Commit
  Endif
  Close Local File [BIPOP_]
  Close Local File [WAUI_]
  Close Local File [WPOP_]
  Close Local File [WPOQ_]
  #Call ECR_TIME("***********************************************OUVRE_DIM_PADPOQ Fin") From DOSSUB
Return

#----------------------------------------------------------------------------------
$CREATE_BIPOP_TRAVAIL
  #--Commandes ouvertes
  Filter [WPOQ_] Where POHTYP=2 and WIPSTA=1 and evalue(SWHERE)
  For [WPOQ_]
    Raz [F:BIPOP_]
    [F:BIPOP_]BIPOPADXUID = adxuid(1)
    [F:BIPOP_]POHNUM      = [WPOQ_]POHNUM
    [F:BIPOP_]POPLIN      = [WPOQ_]POPLIN
    [F:BIPOP_]POPSEQ      = 0
    Filter [WPOP_] Where POHNUM=[WPOQ_]POHNUM and POPLIN=[WPOQ_]POPLIN and STRDAT<=[WPOQ_]DEMRCPDAT Order By STRDAT Desc
    For [WPOP_]
      [F:BIPOP_]POPSEQ    = [WPOP_]POPSEQ
      Break
    Next
    Filter [WPOP_]
    Write [F:BIPOP_]
  Next
  Filter [WPOQ_]
  #--Commandes normales
  Filter [WPOQ_] Where POHTYP<>2 and evalue(SWHERE)
  For [WPOQ_]
    Raz [F:BIPOP_]
    [F:BIPOP_]BIPOPADXUID = adxuid(1)
    [F:BIPOP_]POHNUM      = [WPOQ_]POHNUM
    [F:BIPOP_]POPLIN      = [WPOQ_]POPLIN
    [F:BIPOP_]POPSEQ      = [WPOQ_]POQSEQ
    Write [F:BIPOP_]
  Next
  Filter [WPOQ_]
Return

###################################################################################
$FIN_DIM
  Case TABLE
    When "D_PADPIDPVF"       : Gosub DELETE_DIM_PADPIDPVF
    When "D_PADPIDDUD"       : Gosub DELETE_DIM_PADPIDDUD
    When "D_PADPTDPVF"       : Gosub DELETE_DIM_PADPTDPVF
    When "D_PADPOQPVF"       : Gosub DELETE_DIM_PADPOQPVF
    When "D_PADPOP"          : Gosub FIN_DIM_PADPOP
    When Default
  Endcase
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_PADPIDPVF
  Call DELETE_D_PADLINE_MANAGE("PADPID", "PVCRFOOT")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_PADPIDDUD
  Call DELETE_D_PADLINE_MANAGE("PADPID", "GACCDUDATE")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_PADPTDPVF
  Call DELETE_D_PADLINE_MANAGE("PADPTD", "PVCRFOOT")
Return

#----------------------------------------------------------------------------------
$DELETE_DIM_PADPOQPVF
  Call DELETE_D_PADLINE_MANAGE("PADPOQ", "PVCRFOOT")
Return

#----------------------------------------------------------------------------------
$FIN_DIM_PADPOP
  #--For Open Orders ([POQ]POHTYP=2)
  #--In some cases, and due to the [POP]STRDAT<=[POQ]DEMRCPDAT restriction,
  #--A [POQ] delivery request line is not associated to a [POP]Product line (no price applied)
  #--We therefor need to create the entries from BITMPPORDERQ that have the POPLIN=0 in the PADPOP dimension

Return

###################################################################################
$FERME_DIM

  If clalev([F:TVB])  : Close Local File [TVB] : Endif
  If clalev([F:TVT])  : Close Local File [TVT] : Endif
  If clalev([F:TPT])  : Close Local File [TPT] : Endif
  If clalev([F:TDA])  : Close Local File [TDA] : Endif
  If clalev([F:TSC])  : Close Local File [TSC] : Endif
  If clalev([F:TEC])  : Close Local File [TEC] : Endif

  If clalev([F:TPV])  : Close Local File [TPV] : Endif

  If clalev([F:BBB_])  : Close Local File [BBB_]  : Endif
  If clalev([F:BBB1_]) : Close Local File [BBB1_] : Endif

  # --- CAS DELETE (début)
  #  If clalev([F:WDUSI_])  : Close Local File [WDUSI_]   : Endif # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  # --- CAS DELETE (fin)
  Case [L]TABLE
    When "D_PADPOQ" : Gosub RAZ_PADPOQ_BITMPPORDER
    When "D_PADPOP" : Gosub RAZ_PADPOP_BITMPPORDER
  Endcase

Return

###################################################################################
$RAZ_PADPOQ_BITMPPORDER
Local Integer IADXLOG

  If clalev([F:BIPOQ]) = 0 Then
    Return
  Endif
  #--Raz all entries from BITMPPORDER table for current adxuid(1)
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BIPOQ]
  Endif
  Delete [BIPOQ] Where [BIPOQ]BIPOQADXUID = adxuid(1)
  If IADXLOG = 0 Then
    Commit
  Endif
Return

###################################################################################
$RAZ_PADPOP_BITMPPORDER
Local Integer IADXLOG

  If clalev([F:BIPOP]) = 0 Then
    Return
  Endif
  #--Raz all entries from BITMPPORDER table for current adxuid(1)
  IADXLOG = adxlog
  If IADXLOG = 0 Then
    Trbegin [BIPOP]
  Endif
  Delete [BIPOP] Where [BIPOP]BIPOPADXUID = adxuid(1)
  If IADXLOG = 0 Then
    Commit
  Endif
Return

###################################################################################
###################################################################################
Subprog DECOUPE_TILDES(SCHAINE, STAB)
Value Char SCHAINE
Variable Char STAB()(0..)

Local Integer NI0
Local Integer NI1
Local Integer NINDTAB
Local Integer NEXIT

  Raz STAB
  NINDTAB = 0
  If instr(0, SCHAINE, "~") = 0 Then
    STAB(NINDTAB) = SCHAINE
  Else
    NI0 = 1
    NEXIT = 0
    Repeat
      NI1 = instr(NI0, SCHAINE, "~")
      If NI1 = 0 Then
        NI1 = len(SCHAINE) + 1
        NEXIT = 1
      Endif
      STAB(NINDTAB) = seg$(SCHAINE, NI0, NI1-1)
      NI0 = NI1 + 1
      NINDTAB += 1
    Until NEXIT = 1
  Endif
End

###################################################################################
Subprog DELETE_D_PADLINE_MANAGE(SDIMENSION, STABLE)
Value Char SDIMENSION
Value Char STABLE

Local Char STAB(GLONVCR)(0..10)
Local Integer NI
Local Char SKEY(GLONVCR)
Local Integer IKEY
Local Integer ISKEY0
Local Integer ISKEY1
Local Integer IDOCTYPLIN

  Local File =GDOSSIER+".AUDITBI" [WAUI_]
  Local File =GDOSSIER+".AUDITBI" [WAUIJ_]

  # -------------------------
  For [WAUI_] Where [F:WAUI_]TBL = STABLE and [F:WAUI_]EVT = "DELETE" and [F:WAUI_]STABI = 4
    #-- Il ne faut pas effectuer le "delete" si l'événement "DELETE" est accompagné par un "INSERT" ayant un n° de seq supérieur !!!
    #-- et parce que nous sommes dans le $FIN_DIM et que la dimension STABLE a déjà été synchonisée ("INSERT" effectué qu'il ne faut pas supprimer)
    Filter [WAUIJ_] Where [F:WAUIJ_]TBL = STABLE and [F:WAUIJ_]EVT = "INSERT" and [F:WAUIJ_]STABI = 4 and [WAUIJ_]SEQ>[WAUI_]SEQ and
&                         [F:WAUIJ_]ID1 = [WAUI_]ID1 and [F:WAUIJ_]ID2 = [WAUI_]ID2
    Look [WAUIJ_] First
    If fstat
      Case SDIMENSION
        When "PADPID"
          # -------------------------
          If STABLE = "PVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Elsif STABLE = "GACCDUDATE" Then
            IDOCTYPLIN = 3
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = STAB(0)
            ISKEY0 = val(STAB(1))
            ISKEY1 = val(STAB(2))
            IKEY = func FORMAT_PIDLIN_DOCTYPLIN3(ISKEY0, ISKEY1)
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]PIHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]PIDLIN = IKEY
          Endif
        When "PADPTD"
          # -------------------------
          If STABLE = "PVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]PTHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]PTDLIN = IKEY
          Endif
        When "PADPOQ"
          # -------------------------
          If STABLE = "PVCRFOOT" Then
            IDOCTYPLIN = 2
            Call DECOUPE_TILDES([F:WAUI_]ID2, STAB)
            SKEY = [F:WAUI_]ID1
            IKEY = val(STAB(1))
          Endif
          If SKEY<>"" and IKEY>0
            Delete [BBB_] Where [F:BBB_]POHNUM = SKEY and [F:BBB_]DOCTYPLIN = IDOCTYPLIN and [F:BBB_]POPLIN = IKEY and [F:BBB_]POQSEQ = 1000
          Endif
        When Default
      Endcase
    Endif
    Filter [WAUIJ_]
  Next
  # -------------------------
  Close Local File [WAUI_]
  Close Local File [WAUIJ_]
End

###################################################################################
###################################################################################
###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PADPID Lignes factures
###################################################################################
Funprog CREATEPADPIDPVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]PPID0=[F:PVF]VCRNUM;IDOCTYPLIN;[F:PVF]IND
  If fstat Then
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]PIHNUM                = [F:PVF]VCRNUM
  [F:BBB_]PIDLIN                = [F:PVF]IND
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  Gosub DATA_KEY_PVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
Funprog FORMAT_PIDLIN_DOCTYPLIN3(ILIG, IDUDLIG)
Value Integer ILIG
Value Integer IDUDLIG

Local Integer IARENDRE

  IARENDRE = (ILIG * 1000) + IDUDLIG
End IARENDRE

###################################################################################
## Parcours de GACCDUDATE pour alimenter la dimension PADPID Lignes factures
###################################################################################
Funprog CREATEPADPIDDUD(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD
Local Integer IKEY

  IREAD = 0
  IKEY = func FORMAT_PIDLIN_DOCTYPLIN3([F:DUD]LIG, [F:DUD]DUDLIG)
  Read [F:BBB_]PPID0=[F:DUD]NUM;IDOCTYPLIN;IKEY
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]PIHNUM                = [F:DUD]NUM
  [F:BBB_]PIDLIN                = IKEY
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  #
  If dim([F:BBB_]DUDTYP)>0      : [F:BBB_]DUDTYP     = [F:DUD]TYP : Endif
  If dim([F:BBB_]DUDNUM)>0      : [F:BBB_]DUDNUM     = [F:DUD]NUM : Endif
  If dim([F:BBB_]DUDLIG)>0      : [F:BBB_]DUDLIG     = [F:DUD]LIG : Endif
  If dim([F:BBB_]DUDDUDLIG)>0   : [F:BBB_]DUDDUDLIG  = [F:DUD]DUDLIG : Endif
  # ---------------------
  If IREAD = 1 Then
    Write [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
###################################################################################
###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PADPTD Lignes livraisons
###################################################################################
###################################################################################
Funprog CREATEPADPTDPVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]PPTD0=[F:PVF]VCRNUM;IDOCTYPLIN;[F:PVF]IND
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]PTHNUM                = [F:PVF]VCRNUM
  [F:BBB_]PTDLIN                = [F:PVF]IND
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  Gosub DATA_KEY_PVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
###################################################################################
###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PADPSD Lignes devis
###################################################################################
Funprog CREATEPADPSDPVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]PPSD0=[F:PVF]VCRNUM;IDOCTYPLIN;[F:PVF]IND
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]PSHNUM                = [F:PVF]VCRNUM
  [F:BBB_]PSDLIN                = [F:PVF]IND
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  Gosub DATA_KEY_PVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
###################################################################################
###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PADPOQ Lignes commandes
###################################################################################
Funprog CREATEPADPOQPVF(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]PPOQ0=[F:PVF]VCRNUM;IDOCTYPLIN;[F:PVF]IND;1000
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  [F:BBB_]POHNUM                = [F:PVF]VCRNUM
  [F:BBB_]POPLIN                = [F:PVF]IND
  [F:BBB_]POPLIN1               = [F:PVF]IND
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  [F:BBB_]POQSEQ                = 1000
  If dim([F:BBB_]POPSEQ)>0      : [F:BBB_]POPSEQ      = 0              : Endif
  If dim([F:BBB_]TODIMPADPOH)>0 : [F:BBB_]TODIMPADPOH = [F:PVF]VCRNUM : Endif
  Gosub DATA_KEY_PVCRFOOT
  # ---------------------
  If IREAD = 1 Then
    Write [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN

###################################################################################
$DATA_KEY_PVCRFOOT
#  If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:PVF]INVDTAVAT : Endif
#  If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:PVF]INVDTAVAT, [F:CPY]LEG) : Endif
  If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:PFI]ITMREF) : Endif
  If dim([F:BBB_]DTAVCRNUM)>0   : [F:BBB_]DTAVCRNUM  = [F:PVF]VCRNUM : Endif
  If dim([F:BBB_]DTAVCRTYP)>0   : [F:BBB_]DTAVCRTYP  = [F:PVF]VCRTYP : Endif
  If dim([F:BBB_]DTAIND)>0      : [F:BBB_]DTAIND     = [F:PVF]IND : Endif
Return

###################################################################################
## Parcours de PREQUISO pour alimenter la dimension PADPSD Lignes demandes achat
###################################################################################
Funprog CREATEPADPSDPSO(IDOCTYPLIN)
Value Integer IDOCTYPLIN

Local Integer IREAD

  IREAD = 0
  Read [F:BBB_]PPSD0=[F:PSO]PSHNUM;IDOCTYPLIN;[F:PSO]PSDLIN;[F:PSO]POHNUM+num$([F:PSO]POPLIN)+num$([F:PSO]POQSEQ)
  If fstat Then
    Raz [F:BBB_]
    IREAD = 1
  Endif
  # ---------------------
  If IREAD = 1
    Read [F:BBB1_]PPSD0=[F:PSO]PSHNUM;IDOCTYPLIN;[F:PSO]PSDLIN;""
    If fstat = 0
      [F:BBB_] = [F:BBB1_]
    Endif
  Endif
  [F:BBB_]PSHNUM                = [F:PSO]PSHNUM
  [F:BBB_]PSDLIN                = [F:PSO]PSDLIN
  [F:BBB_]DOCTYPLIN             = IDOCTYPLIN
  [F:BBB_]PSHPOH                = [F:PSO]POHNUM+num$([F:PSO]POPLIN)+num$([F:PSO]POQSEQ)
  If dim([F:BBB_]WPSHNUM)>0     : [F:BBB_]WPSHNUM     = [F:PSO]PSHNUM : Endif
  If dim([F:BBB_]WPSDLIN)>0     : [F:BBB_]WPSDLIN     = [F:PSO]PSDLIN : Endif
  If dim([F:BBB_]WDOCTYPLIN)>0  : [F:BBB_]WDOCTYPLIN  = IDOCTYPLIN    : Endif
  If dim([F:BBB_]POHNUM)>0      : [F:BBB_]POHNUM      = [F:PSO]POHNUM : Endif
  If dim([F:BBB_]POPLIN)>0      : [F:BBB_]POPLIN      = [F:PSO]POPLIN : Endif
  If dim([F:BBB_]POQSEQ)>0      : [F:BBB_]POQSEQ      = [F:PSO]POQSEQ : Endif
  # ---------------------
  If IREAD = 1 Then
    Write   [F:BBB_]
  Else
    Rewrite [F:BBB_]
  Endif
End IDOCTYPLIN
###################################################################################
###################################################################################
###################################################################################
###################################################################################
###################################################################################
# Déclarations des variables de travail communes
###################################################################################
$DECL_VAR
Local Integer DESFLG, NBACT, NBDES
Return

###################################################################################
# Lecture de la dimension, pour voir si elle gère le multi-dossiers
# Lecture de(s) la (les) règles de synchro
###################################################################################
$READ_DIM
  If clalev([F:ABI]) = 0 : Local File =APPLI+".ABIDIM" [ABI] : Endif
  If [F:ABI]CODDIM <> right$(TABLE,3) Then
    Read [ABI]ABI0=right$(TABLE,3)
    If fstat Then
      Raz [F:ABI]
    Endif
  Endif
  # On teste si toutes les règles de synchronisation ayant la même table d'origine que la dimension
  # sont désactivées. Si c'est le cas, le traitement de la dimension n'est pas exécuté
  [L]DESFLG = 1
  [L]NBACT = 0 # nombre de règles activées
  [L]NBDES = 0 # nombre de règles désactivées
  If [F:ABI]TABORG <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    For [F:ABV] Where TABORG = [F:ABI]TABORG
      If dim([F:ABV]DESFLG) > 0 Then
        If [F:ABV]DESFLG = 2 Then # règle désactivée
          [L]NBDES += 1
        Else                      # règle activée
          [L]NBACT += 1
        Endif
      Endif
    Next
  Endif
  If [L]NBACT = 0 and [L]NBDES <> 0 Then # on n'a trouvé que des règles de synchro désactivées
    [L]DESFLG = 2
  Endif
Return

###################################################################################
## ALIM_WBASE alimentation de la variable donnant le type de
## DATABASE à partir de GTYPDBA
###################################################################################
$ALIM_WBASE

  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  WBASE = num$((fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, GACTX.AFOLDER, "TYPDBA") * 2) + 1)

Return

##########################################################################################
# LECT_DES_TRAD : Lecture de la désignation traduite d'un article reçu en paramètre
##########################################################################################
# Parameters E : code de l'article
# Return       : désignation 1 traduite de l'article
##########################################################################################
Funprog LECT_DES_TRAD(P_ITMREF)
Value Char P_ITMREF

Local Char WBASE(1)
Local Char DESAXX(80)
Local Char WREQ2(250)

  Gosub ALIM_WBASE
  DESAXX = ""
  WREQ2 = "select TEXTE_0 From "+GDOSSIER+".ATEXTRA Where CODFIC_0='ITMMASTER' and ZONE_0='DES1AXX' and LANGUE_0='"+GLANGUE+"' and IDENT1_0='"+P_ITMREF+"'"
  For (Char TEXTE(80)) From WBASE Sql WREQ2 As [RE2_]
    DESAXX = [RE2_]TEXTE
    Break
  Next
End DESAXX

##########################################################################################
# READ_REGLE : Lecture des règles de synchro
##########################################################################################
# Parameters E : règle de synchro à lire
# Return       : flag de désactivation de la règle de synchro
##########################################################################################
Funprog READ_REGLE(CODE_REGLE)
Value Char CODE_REGLE

Local Integer DESACT

  DESACT = 1
  If CODE_REGLE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_REGLE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT
###############################################################################
$FILTRE_DIM_INC
  Case TABLE
    When "D_PADPID"          : Gosub FILTRE_DIM_INC_PADPID
    When "D_PADPIH"          : Gosub FILTRE_DIM_INC_PADPIH
    When "D_PADPIDPVF"       : Gosub FILTRE_DIM_INC_PADPIDPVF
    When "D_PADPIDDUD"       : Gosub FILTRE_DIM_INC_PADPIDDUD
    When "D_PADPSH"          : Gosub FILTRE_DIM_INC_PADPSH
    When "D_PADPSD"          : Gosub FILTRE_DIM_INC_PADPSD
    When "D_PADPSO"          : Gosub FILTRE_DIM_INC_PADPSO
    When "D_PADPSDPVF"       : Gosub FILTRE_DIM_INC_PADPSDPVF
  Endcase
Return

