###################################################################################
## ACTION Mise à jour des dimensions X3                                           #
###################################################################################
$ACTION
  Case ACTION
    When "OUVRE_DIM"         : Gosub OUVRE_DIM
    When "FILTRE_DIM_INC"    : #Gosub FILTRE_DIM_INC
    When "FIN_DIM"           : Gosub FIN_DIM
    When "FERME_DIM"         : Gosub FERME_DIM
  Endcase
Return

###################################################################################
$OUVRE_DIM
  #--------------------------
  # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  #--called from the wanted dimensions
  #Gosub TRIGGER_AUDIBI From TRTSYNBIPAD
  # End issue X3-38377
  #--------------------------
  Case TABLE
    When "D_PADPIH"          : Gosub OUVRE_DIM_PADPIH
    When "D_PADPID"          : Gosub OUVRE_DIM_PADPID
    When "D_PADPIDPVF"       : Gosub OUVRE_DIM_PADPIDPVF
    When "D_PADPIDDUD"       : Gosub OUVRE_DIM_PADPIDDUD
    When "D_PADPTH"          : Gosub OUVRE_DIM_PADPTH
    When "D_PADPTD"          : Gosub OUVRE_DIM_PADPTD
    When "D_PADPTDPVF"       : Gosub OUVRE_DIM_PADPTDPVF
    When "D_PADPSH"          : Gosub OUVRE_DIM_PADPSH
    When "D_PADPSD"          : Gosub OUVRE_DIM_PADPSD
    When "D_PADPSO"          : Gosub OUVRE_DIM_PADPSO
    When "D_PADPSDPVF"       : Gosub OUVRE_DIM_PADPSDPVF
    When "D_PADPNH"          : Gosub OUVRE_DIM_PADPNH
    When "D_PADPND"          : Gosub OUVRE_DIM_PADPND
    When "D_PADPOQ"          : Gosub OUVRE_DIM_PADPOQ
    When "D_PADPOP"          : Gosub OUVRE_DIM_PADPOP
    When "D_PADPOQPVF"       : Gosub OUVRE_DIM_PADPOQPVF
    When "D_PADPOH"          : Gosub OUVRE_DIM_PADPOH    # Issue X3-38377 - 2017-06-12 by CPO : [118249] Performance issue with Business Object
  Endcase
Return

