#<AdxTL>@(#)12.0.0.0 $Revision$
Call SELCFY(GBIDC1)
End

###########################################################
## Subprog CONTACCCFY(VALEUR,ZONE)
## Subprog CONTCFY(VALEUR)
## Subprog SELCFY(VALEUR)
## Subprog VERIF(ZONE,SITE,VALEUR)
## Subprog VERSOC(ZONE,SOCIETE,SITE,VALEUR)
## Subprog BUDSITE(SITE,NIVEAU,BUDSIT,BUDSOC,VALEUR)
## Subprog COMPAT(SIT1,SIT2,VALEUR)
## Subprog CTLGFYFCY(GFY,FCY,TYP,RES)
###########################################################

$ACTION
Case ACTION
 When "SEL_LISTE"
  Case LISTE
   When "SELCFY" : Gosub S_CFY
  Endcase
Endcase
Return

$S_CFY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Local Char TEX(30)(1..GDIMSIT+GDIMSOC), TEXTE(GLONDES)(1..GDIMSIT+GDIMSOC,1..3)
Local Char TIT(GLONDES)(0..3)
For [FCY]FCY0
 If GUSRFCY(1)="\" or GNBAUZ=GNBSITE or find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
  If NBTEX>=dim(TEX)-1 : Break : Endif
  NBTEX += 1
  TEX(NBTEX) = [F:FCY]FCY
  TEXTE(NBTEX,2) = [F:FCY]FCYNAM
  TEXTE(NBTEX,3) = mess(3,45,1) : # Site
 Endif
Next
For [CPY]CPY0
 If NBTEX>=dim(TEX)-1 : Break : Endif
 mkstat = 0
 If GUSRFCY(1)<>"\"
  Call CONTALLFCY([F:CPY]CPY)
 Endif
 If !mkstat
  NBTEX += 1
  TEX(NBTEX)   = [F:CPY]CPY
  TEXTE(NBTEX,2) = [F:CPY]CPYNAM
  TEXTE(NBTEX,3) = mess(2,45,1) : # Société
 Endif
Next
TIT(0) = mess(60,133,1) : # Choix société / site
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Raz mkstat, GMESSAGE
Return

###########################################################
## Contrôle accès zone société/site
###########################################################
Subprog CONTACCCFY(VALEUR,ZONE)
Value Char VALEUR
Value Char ZONE
If VALEUR=""
 If ZONE<>""
  Assign ZONE With ""
 Endif
 End
Endif
ISITE = find(VALEUR,GSITE(1..GNBSITE))
ISOC  = find(VALEUR,GSOC(1..GNBSOC))
# Vérification de l'existence (CP : 05/04/01)
If !ISITE & !ISOC
 GMESSAGE = VALEUR-":"-mess(61,133,1) : # Socièté ou site inexistant
 mkstat = 2 : End
Endif
If GUSRFCY(1)<>"\"
 If ISITE
  Call CONTSNGFCY(VALEUR) : # Refus d'accès si non autorisation site
 Else
  Call CONTALLFCY(VALEUR) : # Refus d'accès si non autorisation à tous les sites de la société
 Endif
Endif
If ZONE<>""
 Call LIENFCYCPY(VALEUR,ZONE)
Endif
End

Subprog LIENFCYCPY(VALEUR,ZONE)
Value Char VALEUR
Value Char ZONE
If ZONE<>""
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 ISOC  = find(VALEUR,GSOC(1..GNBSOC))
 If ISITE
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  Call LEC_FCY(VALEUR) From CPTLEC
  Assign ZONE With [F:FCY]FCYNAM
 Elsif ISOC
  If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
  Call LEC_CPY(VALEUR) From CPTLEC
  Assign ZONE With [F:CPY]CPYNAM
 Endif
Endif
End

###########################################################
## Contrôle
###########################################################
Subprog CONTCFY(VALEUR)
Value Char VALEUR
If VALEUR="" : End : Endif
ISITE = find(VALEUR,GSITE(1..GNBSITE))
ISOC  = find(VALEUR,GSOC(1..GNBSOC))
If !ISITE & !ISOC
 GMESSAGE = mess(62,133,1) : # Société ou site incorrect
 mkstat = 2 : End
Endif
End

#################################################################
## Contrôle que le site est autorisé pour la fonction courante ##
#################################################################
Subprog CONTSNGFCY(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
 GMESSAGE = VALEUR-":"-mess(63,133,1) : # Vous n'avez pas les droits pour ce site
 mkstat = 2
Else
 mkstat = 0    # CP : 13/04/01
Endif
End


###########################################################
## Sélection
###########################################################
Subprog SELCFY(VALEUR)
Variable Char VALEUR
Local Integer NBTEX , CHOI, OK , I
Local Char    TEX(GLONDES)(1..GDIMSIT+GDIMSOC,1..3) , TIT(GLONDES)(0..3)
Local Char    SIT(GLONFCY)(1..GDIMSIT+GDIMSOC) , DES(GLONDES)(1..GDIMSIT+GDIMSOC)
Local Integer TYP(1..GDIMSIT+GDIMSOC)
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
For [FCY]FCY0
 If GUSRFCY(1)="\" or GNBAUZ=GNBSITE or find([F:FCY]FCY,GUSRFCY(1..GNBAUZ))
  NBTEX += 1
  SIT(NBTEX) = [F:FCY]FCY
  DES(NBTEX) = [F:FCY]FCYNAM
  TYP(NBTEX) = 2
 Endif
Next
For [CPY]CPY0
 mkstat = 0
 If GUSRFCY(1)<>"\"
  Call CONTALLFCY([F:CPY]CPY)
 Endif
 If !mkstat
  NBTEX += 1
  SIT(NBTEX) = [F:CPY]CPY
  DES(NBTEX) = [F:CPY]CPYNAM
  TYP(NBTEX) = 1
 Endif
Next
Sorta NBTEX SIT(1..NBTEX) , TYP(1..NBTEX) , DES(1..NBTEX)
For I=1 To NBTEX
 TEX(I,1) = SIT(I)
 TEX(I,2) = DES(I)
 TEX(I,3) = mess(1+TYP(I),45,1) : # Société/Site
Next I
CHOI = find(VALEUR,SIT(1..NBTEX))
TIT(0) = mess(60,133,1) : # Choix société / site
TIT(1) = mess(37,100,1) : # Code
TIT(2) = mess(30,109,1) : # Intitulé
Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,150) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = SIT(CHOI)
Endif
End

###########################################################
## Vérif par rapport à un site
###########################################################
Subprog VERIF(ZONE,SITE,VALEUR)
Value Char ZONE
Value Char SITE
Value Char VALEUR
If ZONE="" : End : Endif
If find(ZONE,GSITE(1..GNBSITE))
 If ZONE<>SITE
  GMESSAGE = VALEUR-":"-mess(64,133,1)-ZONE : # réservé au site
  mkstat = 2 : End
 Endif
Else
 If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
 Call LEC_CPY(ZONE) From CPTLEC
 If [F:CPY]CPYLEGFLG=2
  If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
  Call LEC_FCY(SITE) From CPTLEC
  If [F:FCY]LEGCPY<>ZONE
   GMESSAGE = VALEUR-":"-mess(65,133,1)-ZONE : # réservé à la société
   mkstat = 2 : End
  Endif
 Else
  If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
  Read [FGR]FGR0 = ZONE;SITE
  If fstat
   GMESSAGE = VALEUR-":"-mess(66,133,1)-ZONE : # réservé au groupe de site
   mkstat = 2 : End
  Endif
 Endif
Endif
End

###########################################################
## Vérif par rapport à une société et/ou un site
###########################################################
Subprog VERSOC(ZONE,SOCIETE,SITE,VALEUR)
Value Char ZONE
Value Char SOCIETE
Value Char SITE
Value Char VALEUR
Local Integer RET

If ZONE="" : End : Endif
If find(ZONE,GSITE(1..GNBSITE))
 If ZONE<>SITE
  GMESSAGE = VALEUR-":"-mess(64,133,1)-ZONE : # réservé au site
  mkstat = 2 : End
 Endif
Else
 If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
 Call LEC_CPY(ZONE) From CPTLEC
 If [F:CPY]CPYLEGFLG=2
  If SOCIETE="" & SITE<>""
   If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
   Call LEC_FCY(SITE) From CPTLEC
   SOCIETE = [F:FCY]LEGCPY
  Endif
  If SOCIETE<>ZONE
   GMESSAGE = VALEUR-":"-mess(65,133,1)-ZONE : # réservé à la société
   mkstat = 2 : End
  Endif
 Else
  If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
  Call GETTYPSOCSITGRP(ZONE,RET) From CPTDIV
  If RET=3 : # groupe de sites
   If SITE<>""
    Read [FGR]FGR0 = ZONE;SITE
    If fstat
     GMESSAGE = VALEUR-":"-mess(66,133,1)-ZONE : # réservé au groupe de sites
     mkstat = 2 : End
    Endif
   Else
    For [FGR]FGR0 Where CPY=ZONE
     Call LEC_FCY([F:FGR]FCY) From CPTLEC
     If  [F:FCY]LEGCPY=SOCIETE : Break :Endif
    Next
    If [F:FCY]LEGCPY<>SOCIETE
     GMESSAGE = VALEUR-":"-mess(66,133,1)-ZONE : # réservé au groupe de sites
     mkstat = 2 : End
    Endif
   Endif
  Elsif RET=4 : # groupe de sociétés
   For [FGR]FGR0 Where CPY=ZONE
    Call LEC_FCY([F:FGR]FCY) From CPTLEC
    If  [F:FCY]LEGCPY=SOCIETE : Break :Endif
   Next
   If [F:FCY]LEGCPY<>SOCIETE
    GMESSAGE = VALEUR-":"-mess(63,127,1)-ZONE : # réservé au groupe de société
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
End

##################################################################
## Vérif pour les budgets
##################################################################
Subprog BUDSITE(SITE,NIVEAU,BUDSIT,BUDSOC,VALEUR)
Value Char    SITE
Value Integer NIVEAU
Value Char    BUDSIT
Value Char    BUDSOC
Value Char    VALEUR

Local Integer OK
If SITE<>""
 If find(SITE,GSITE(1..GNBSITE)) : # C'est un site
  Case NIVEAU
   When 2 : # Niveau site, il faut que ce soit le bon
    If BUDSIT<>SITE
     GMESSAGE = VALEUR-":"-mess(64,133,1)-SITE : # réservé au site
     mkstat = 2 : End
    Endif
   When 1 : # Niveau société, on accepte la société du site
    Call LEC_FCY(SITE) From CPTLEC
    If [F:FCY]LEGCPY<>BUDSOC
     GMESSAGE = VALEUR-":"-mess(64,133,1)-SITE : # réservé au site
     mkstat = 2 : End
    Endif
  Endcase
 Else
  Call LEC_CPY(SITE) From CPTLEC
  If [F:CPY]CPYLEGFLG=2 : # C'est une société juridique
   Case NIVEAU
    When 1 : # Niveau société il faut que ce soit la bonne
     If BUDSOC<>SITE
      GMESSAGE = VALEUR-":"-mess(65,133,1)-SITE : # réservé à la société
      mkstat = 2 : End
     Endif
    When 2 : # Niveau site, il doit être dans la société
     Call LEC_FCY(BUDSIT) From CPTLEC
     If [F:FCY]LEGCPY<>SITE
      GMESSAGE = VALEUR-":"-mess(65,133,1)-SITE : # réservé à la société
      mkstat = 2 : End
     Endif
   Endcase
  Else : # C'est un groupe de société
   If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
   Case NIVEAU
    When 1 : # Niveau société, il doit y avoir un site de la société
     OK = 0
     For [FGR]FGR0 Where CPY=SITE
      Call LEC_FCY([F:FGR]FCY) From CPTLEC
      If [F:FCY]LEGCPY=BUDSOC : OK = 1 : Break : Endif
     Next
     If !OK
      GMESSAGE = VALEUR-":"-mess(66,133,1)-SITE : # réservé au groupe de site
      mkstat = 2 : End
     Endif
    When 2 : # Niveau site, il doit être dans le groupe
     Read [FGR]FGR0 = SITE;BUDSIT
     If fstat
      GMESSAGE = VALEUR-":"-mess(66,133,1)-SITE : # réservé au groupe de site
      mkstat = 2 : End
     Endif
   Endcase
  Endif
 Endif
Endif
End

##########################################################################
## Vérif de compatibilité
##########################################################################
Subprog COMPAT(SIT1,SIT2,VALEUR)
Value Char SIT1
Value Char SIT2
Value Char VALEUR
If SIT1="" or SIT2="" or SIT1=SIT2 : End : Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If find(SIT1,GSITE(1..GNBSITE))
 If find(SIT2,GSITE(1..GNBSITE))
  mkstat = 2 : GMESSAGE = VALEUR-":"-mess(64,133,1)-SIT2 : # Réservé au site
 Else
  Call LEC_CPY(SIT2) From CPTLEC
  If [F:CPY]CPYLEGFLG=2
   Call LEC_FCY(SIT1) From CPTLEC
   If [F:FCY]LEGCPY<>SIT2
    mkstat = 2 : GMESSAGE = VALEUR-":"-mess(65,133,1)-SIT2 : # Réservé à la société
   Endif
  Else
   OK=0
   For [FGR]FGR0 Where CPY=SIT2
    If [F:FGR]FCY=SIT1 : OK = 1 : Break   : Endif
   Next
   If !OK
    mkstat = 2 : GMESSAGE = VALEUR-":"-mess(66,133,1)-SIT2 : # Réservé au groupe de site
   Endif
  Endif
 Endif
Else
 Call LEC_CPY(SIT1) From CPTLEC
 If [F:CPY]CPYLEGFLG=2
  If find(SIT2,GSITE(1..GNBSITE))
   Call LEC_FCY(SIT2) From CPTLEC
   If [F:FCY]LEGCPY<>SIT1
    mkstat = 2 : GMESSAGE = VALEUR-":"-mess(64,133,1)-SIT2 : # Réservé au site
   Endif
  Else
   Call LEC_CPY(SIT2) From CPTLEC
   If [F:CPY]CPYLEGFLG=2
    mkstat = 2 : GMESSAGE = VALEUR-":"-mess(65,133,1)-SIT2 : # Réservé à la société
   Else
    OK = 0
    For [FGR]FGR0 Where CPY=SIT2
     Read [FCY]FCY0 = [F:FGR]FCY
     If [F:FCY]LEGCPY=SIT1 : OK = 1 : Break : Endif
    Next
    If !OK
     mkstat = 2 : GMESSAGE = VALEUR-":"-mess(66,133,1)-SIT2 : # Réservé au groupe de site
    Endif
   Endif
  Endif
 Else
  If find(SIT2,GSITE(1..GNBSITE))
   OK=0
   For [FGR]FGR0 Where CPY=SIT1
    If [F:FGR]FCY=SIT2 : OK = 1 : Break   : Endif
   Next
   If !OK
    mkstat =2 : GMESSAGE = VALEUR-":"-mess(64,133,1)-SIT2 : # Réservé au site
   Endif
  Else
   Call LEC_CPY(SIT2) From CPTLEC
   If [F:CPY]CPYLEGFLG=2
    OK = 0
    For [FGR]FGR0 Where CPY=SIT1
     Read [FCY]FCY0 = [F:FGR]FCY
     If [F:FCY]LEGCPY=SIT2 : OK = 1 : Break : Endif
    Next
    If !OK
     mkstat = 2 : GMESSAGE = VALEUR-":"-mess(65,133,1)-SIT2 : # Réservé à la société
    Endif
   Else
    If clalev([F:FGR2])=0 : Local File FACGROUP [FGR2] : Endif
    OK=0
    For [FGR]FGR0 Where CPY=SIT1
     For [FGR2]FGR0 Where CPY=SIT2
      If [F:FGR]FCY=[F:FGR2]FCY : OK = 1 : Break 2  : Endif
     Next
    Next
    If !OK
     mkstat = 2 : GMESSAGE = VALEUR-":"-mess(66,133,1)-SIT2 : # Réservé au groupe de site
    Endif
   Endif
  Endif
 Endif
Endif
End

################################################################
## Contrôle que tous les sites d'une société sont accessibles  #
################################################################
Subprog CONTALLFCY(SOC)
Variable Char     SOC
Local    Integer  I, OK
If [L]SOC="" : End : Endif
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
Call LEC_CPY([L]SOC) From CPTLEC

Raz OK
Case [F:CPY]CPYLEGFLG
 When 2 : # Société juridique
  OK = find([L]SOC,GSOCSITE(1..GNBSITE))
  For I=1 To GNBSITE
   If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next I
 When Default
  For [FGR]FGR0 Where CPY=[L]SOC
   OK = 1
   If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
    OK = -1 : Break
   Endif
  Next
Endcase
Case OK
 When  0
  GMESSAGE = [L]SOC-mess(67,133,1) : # Aucun site n'est accessible dans cette société
  mkstat = 2 : End
 When -1
  GMESSAGE = mess(68,133,1)-[L]SOC : # Tous les sites ne sont pas accessibles dans la société
  mkstat = 2 : End
Endcase
End


#################################################################################################
## Consistency control between two data that could be company/facility/group of company-facility#
#################################################################################################

Subprog CTLGFYFCY(GFY,FCY,TYP,RES)
Value Char GFY()
Value Char FCY()
Value Char TYP()
Variable Integer RES
Local Integer OK,RET
If GUSRFCY(1)="\" : End : Endif
If clalev([F:CPY])=0  : Local File COMPANY  [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY [FCY] : Endif
If clalev([F:FGRG])=0 : Local File FACGROUP [FGRG] : Endif

OK=find([L]FCY,GSITE(1..GNBSITE))
# If second value is a facility
If OK
 Call VERIF([L]GFY,[L]FCY,[L]TYP) From CFYSUB
 If mkstat=2 : OK=-1 : Else OK=0 : Endif
 RES=OK
Else
 # If it is a company
 OK=find([L]FCY,GSOC(1..GNBSOC))
 If OK
  Call LEC_CPY([L]FCY) From CPTLEC
  If [F:CPY]CPYLEGFLG=2
   Call VERSOC([L]GFY,[L]FCY,"",[L]TYP)From CFYSUB
   If mkstat=2 : OK=-1 :Else OK = 0 Endif
  Else
   # else second value is a group
   # Check first value is also a group
   Call GETTYPSOCSITGRP([L]FCY,RET) From CPTDIV
   # group of facilities or companies
   If RET = 3 | RET=4
    If [L]GFY <> [L]FCY
     mkstat=2 : OK=-1
    Else
     OK=0 : RES=OK
    Endif
   Else
    # If first value is not a group
    # check if at least one company or facility is consistency with this first value
    For [FGRG]FGR0 Where CPY=[L]FCY
     OK=find([F:FGRG]FCY,GUSRFCY(1..GNBAUZ))
     If OK
      Call VERSOC([L]GFY,"",[F:FGRG]FCY,[L]TYP)From CFYSUB
      If mkstat=2 : OK=-1 : Else OK=0 : Break : Endif
     Endif
    Next
   Endif
   RES=OK
  Endif
 Endif
Endif
RES=OK
End RES
