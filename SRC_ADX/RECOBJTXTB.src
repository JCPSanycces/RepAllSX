#<AdxTL>@(#)4.0.0.0 $Revision$
Local Char PARAM(10)(1..3) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECOBJTXT","RECOBJTXT",3,"") From GTRAITE
End

#-------------------------------------------------#
$ACTION
Case ACTION
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "EXEC"      : Gosub EXEC
Endcase
Return

#-------------------------------------------------#
$AVANT_PAR
# Configurateur
Local Integer WCFG
If clalev([F:ACV]) = 0 : Local File ACTIV [ACV] : Endif
Read [ACV]CODACT="CFG"
If fstat = 0
    If [F:ACV]FLACT=2 : WCFG=1 : Endif
Endif
If WCFG
    I += 1 : [M]TYP(I) = "CFG" : [M]REC(I) = 2 : [M]OPT(I) = 0 : [M]OBJ(I) = mess(0,188,1)-"-"-mess(174,115,1) : # Configurateur - Photos
Endif
[M]NBLIG = I+1
Return

#--------------------#
$EXEC
For I=1 To [M]NBLIG
 If [M]REC(I-1)=2
  Case [M]TYP(I-1)
   When "CFG" : Call BLOB_PHOTO_UTIL([M]DOSSIER,TEST) From CFGPIC140 : # Photos configurateur
  Endcase
 Endif
Next I
Call VIRE_PARAM([M]DOSSIER)
Return

#-------------------------------#
Subprog VIRE_PARAM(APPLI)
Value Char APPLI
Local File =APPLI+".ADOVAL" [ADW]
Trbegin [ADW]
 Delete [ADW] Where PARAM="BLOB140"
Commit
End

