#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGCTLSAL07   Contrôle Pre-migration Retours              Module Ventes #
#                                                                          #
# Toutes versions :                                                        #
# ---------------                                                          #
# SRETURN  without SRETURND                                                #
# SRETURND without SRETURN                                                 #
# SRETURND with STOFCY different from SRETURN                              #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLSAL07") From LECFIC
  Endif

  Call MAJ_UUMGCTLSAL07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLSAL07(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(4)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLSAL07 Sales Return Process : SRETURN-D") From DOSSUB
Call ECR_TRACE("UUMGCTLSAL07 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1 : # SRETURN  without SRETURND
Gosub CTL2 : # SRETURND without SRETURN
Gosub CTL3 : # SRETURND with STOFCY different from SRETURN

$FIN
Call ECR_TIME("UUMGCTLSAL07 : Sales Return Process END.") From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
# SRETURN without SRETURND
###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SRETURN")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SRETURND") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SRH.SRHNUM_0 FROM "-DOSSIER+".SRETURN SRH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SRETURND SRD WHERE SRH.SRHNUM_0=SRD.SRHNUM_0) "
REQSQL(2)="ORDER BY SRH.SRHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SRETURN without SRETURND",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSRHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SRHNUM="-[BXX]VSRHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################
###################################################################################
# SRETURND without SRETURN
###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SRETURN")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SRETURND") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SRD.SRHNUM_0,SRD.SRDLIN_0 FROM "-DOSSIER+".SRETURND SRD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SRETURN SRH WHERE SRH.SRHNUM_0=SRD.SRHNUM_0) "
REQSQL(2)="ORDER BY SRD.SRHNUM_0,SRD.SRDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SRETURND without SRETURN",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSRHNUM(50),Integer VSRDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SRHNUM/SRDLIN="-[BXX]VSRHNUM+'/'+num$([BXX]VSRDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################
###################################################################################
# SRETURND with STOFCY different from SRETURN
###################################################################################
$CTL3
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SRETURN")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SRETURND") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SRD.SRHNUM_0,SRD.SRDLIN_0 FROM "-DOSSIER+".SRETURND SRD "
REQSQL(1)="WHERE SRD.STOFCY_0<>(SELECT SRH.STOFCY_0 FROM"-DOSSIER+".SRETURN SRH WHERE SRH.SRHNUM_0=SRD.SRHNUM_0) "
REQSQL(2)="ORDER BY SRD.SRHNUM_0,SRD.SRDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SRETURND with STOFCY different from SRETURN",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSRHNUM(50),Integer VSRDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SRHNUM/SRDLIN="-[BXX]VSRHNUM+'/'+num$([BXX]VSRDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif

Return
###################################################################################

