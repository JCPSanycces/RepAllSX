#########################################################
Subprog CAL_LOCALISE_MODE ( PMODAMT, PDTDBAMT, PDTDBEXE, PDTFNEXE, RINDMOD, RINDANNLB, RTXLB, RTX2LB, RRGRPPER )
#
# - Objet  : Renvoie l'indice du tableau des méthodes
#            dans lequel se situe le mode à calculer.
#            Dans le cas d'un mode libre les informations
#            supplémentaires suivantes sont renvoyées :
#              Indice de l'annuité
#              Taux
#              Taux 2 (si calcul à date anniversaire)
#
#
# - Entrée :
#            Mode d'amortissement
#            Date début d'amortissement
#            Date début d'exercice
#            Date fin d'exercice
#            Mode d'amortissement
#            [M:DPM] Tableau des modes d'amortissement
#
# - Sortie :
#            Indice du mode
#            Indice de l'annuité mode libre
#            Taux mode libre
#            Taux 2 mode libre
#
#   Boite noire gcfc82
#


Value     Char     PMODAMT    # Mode d'amortissement
Value     Date     PDTDBAMT   # Date début d'amortissement
Value     Date     PDTDBEXE   # Date début d'exercice
Value     Date     PDTFNEXE   # Date fin   d'exercice

Variable  Decimal  RINDMOD    # Indice du mode
Variable  Decimal  RINDANNLB  # Indice de l'annuité mode libre
Variable  Decimal  RTXLB      # Taux mode libre
Variable  Decimal  RTX2LB     # Taux 2 mode libre
Variable  Integer  RRGRPPER   # Issue X3-54580 - 2017-10-31 by MWA : Wear & Tear Dpepreciation

Local     Integer  LRGLTXAMT  # Règle application taux
Local     Integer  LINDANN    # Indice de l'annuité

#If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  RINDMOD = find(PMODAMT,[M:DPM]DPM)
  # -1 --------------------------------------------
  If ( RINDMOD = 0 ) Then
    # Le mode n'est pas trouvé dans la tables des méthodes
    [M:DIV]ERRID = 5 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
  Else
  # -1 --------------------------------------------
    # -2 --------------------------------------------
    # Le mode est trouvé dans la tables des méthodes
    If ( [M:DPM]DPRMODTYP(RINDMOD-1) = GVML_TMSTAND ) Then
      # Il s'agit d'un mode d'amortissement standard
      RINDANNLB = 0
      RTXLB     = 0
      RTX2LB    = 0
      # X3-54580
      RRGRPPER  = GVML_REPPERIO
    Elsif ( [M:DPM]DPRMODTYP([M:DIV]INDMOD-1) = GVML_TMLIBRE ) Then
    # -2 --------------------------------------------
      # -3 --------------------------------------------
      # Il s'agit d'un mode d'amortissement libre
      RRGRPPER = [M:DPM]DPRDISRUL(RINDMOD-1)    : # X3-54580

      LRGLTXAMT = [M:DPM]RATCOETYP(RINDMOD-1)
      If ( LRGLTXAMT = GVML_COBSMTC ) Then
        # Si Application taux correspond à BASE X TAUX CONSTANT
        RINDANNLB = 0
        # FQ51062
        If ( [M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)-1) <> 0 ) Then
          RTXLB = [M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)-1)
        Else
          RTXLB = 0
        Endif
        RTX2LB  = 0
      Elsif ( LRGLTXAMT = GVML_COBSDTC ) Then
      # -3 --------------------------------------------
        # Si Application taux correspond à BASE / TAUX CONSTANT
        RINDANNLB = 0
        # FQ51062
        If ( [M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)-1) <> 0 ) Then
          RTXLB = arr( 1 / ([M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)-1)), 0.001)
        Else
          RTXLB = 0
        Endif
        RTX2LB  = 0
      Elsif ( LRGLTXAMT = GVML_COANNUI ) Then
      # -3 --------------------------------------------
        # Si Application taux correspond à TAUX PAR ANNUITE
        # Recherche du n° d'exercice pour récupération du taux de l'exercice correspondant
        LINDANN = func GLOBB8.CAL_NUMERO_EXERCICE( PDTDBAMT, PDTDBEXE, PDTFNEXE)
        If ( LINDANN > [M:DPM]RATNBR(RINDMOD-1) ) Then
          # Si le nbre d'annuité dépasse le nombre de taux disponibles
          # On prend le premier taux défini
          LINDANN = 1
        Elsif ( LINDANN = 0 ) Then
          # Si l'amortissement démarre après l'exercice
          # On prend le dernier taux défini
          LINDANN = [M:DPM]RATNBR(RINDMOD-1)
        Endif
        RINDANNLB = LINDANN
        RTXLB     = [M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)+LINDANN-2)
        If ([M:DPM]ANIDATFLG(RINDMOD-1) = G_OUI and LINDANN > 1) Then
          # Calcul à date anniversaire et pas la première annuité
          #FQ82482
          #RTX2LB    = [M:DPM]RAT(LINDANN-2)
          RTX2LB    = [M:DPM]RAT([M:DPM]INDDEBRAT(RINDMOD-1)+LINDANN-3)
        Else
          # Pas de calcul à date anniversaire ou première annuité
          RTX2LB    = 0
        Endif
      Elsif ( LRGLTXAMT = GVML_COBSMTM ) Then
      # -3 --------------------------------------------
        # Si Application taux correspond BASE X TAUX MENSUEL
        # Ce cas est traité via une fonction spécifique executée en aval.
        # La dotation est calculée en appliquant N taux mensuels
        RINDANNLB = 0
        RTXLB     = 0
        RTX2LB    = 0
      Else
      # -3 --------------------------------------------
        # La règle "Application taux" est inconnue
        [M:DIV]ERRID = 7 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
      Endif
      # -3 --------------------------------------------
    Else
    # -2 --------------------------------------------
      # Type du mode d'amortissement inconnu
      [M:DIV]ERRID = 6 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
    # -2 --------------------------------------------
  Endif
  # -1 --------------------------------------------

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#
#########################################################
Subprog  CAL_DUR_EXE_REF (PDTDBEXE, PDTFNEXE, PTYPPRO, RDUR_EXE_REF)
#
# - Objet  : Calcule la durée de l'exercice de référence
#            selon le type de prorata
#   Jours    (365 ou 366 si un 29/02/ssaa est inclus dans l'exercice )
#   Mois     (12 mois )
#   Jours    (52 semaines )
#
# - Entrée :
#
# - Sortie : Durée exercice de référence
#   Boite noire det_nbj_ex_ref (gcfc10)
#
Value     Date     PDTDBEXE, PDTFNEXE
Value     Integer  PTYPPRO
Variable  Decimal  RDUR_EXE_REF

Local Integer    LANN
Local Date       LDAT
  Case PTYPPRO
    When GVML_TPMOIS : RDUR_EXE_REF = 12
    When GVML_TPHLFY : RDUR_EXE_REF = 12
    When GVML_TPSEMA : RDUR_EXE_REF = 52
    When GVML_TPJOUR
      If ([M:DIV]CALPERSAN = G_OUI) Then
        # Durée de détention selon type de prorata FQ77529
        #Call CAL_DAT_DIFF( PDTDBEXE, PDTFNEXE, "D", RDUR_EXE_REF ) From =G_GLOB9
        [M:DIV]PD(0)= PDTDBEXE : [M:DIV]PD(1)= PDTFNEXE : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : RDUR_EXE_REF = [M:DIV]RV(0)
      Else
        LANN = year(PDTDBEXE)
                       RDUR_EXE_REF = 365
                       Repeat
                       If ( func GLOBB9.CAL_DAT_BISS( LANN ) = 366 ) Then
                         LDAT = gdat$(29,02,LANN)
                         If ( func GLOBB9.CAL_DAT_INSIDE(LDAT, PDTDBEXE, PDTFNEXE, "I") ) Then
                          RDUR_EXE_REF = 366 : Break
                         Endif
                       Endif
                       LANN += 1
                     Until LANN > year(PDTFNEXE)
      Endif
    When GVML_TPHLFM : RDUR_EXE_REF = 24
# FQ88728   When GVML_TPHLFQ : RDUR_EXE_REF = 8
    When GVML_TPHLFQ : RDUR_EXE_REF = 24
    When Default : RDUR_EXE_REF = 0
  Endcase

End

#
#########################################################
Subprog CAL_EXERCICE_SELON_DATE ( E03DATE, E03TYPPRO, S03DTDBEXE, S03DTFNEXE, S03INDEXE )
#
# - Objet  : Renvoie la date de début et de fin de l'exercice dans lequel se situe
#            la date.
#
# - Entrée : [M:FIY] Exercices/Périodes d'un contexte
#            Date de reférence
# - Sortie : Date début d'exercice
#            Date fin d'exercice
#            Indice de l'exercice dans le tableau des exercices

#   Boite noire gcfc81
#
Value    Date      E03DATE
Value    Decimal   E03TYPPRO
Variable Date      S03DTDBEXE
Variable Date      S03DTFNEXE
Variable Integer   S03INDEXE

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E03
Goto $DEB_CAL_EXERCICE_SELON_DATE
$GSB_CAL_EXERCICE_SELON_DATE
  # Déclaration des paramètres en entrée
  Local Date      E03DATE         : E03DATE     = [M:DIV]PD(0)
  Local Decimal   E03TYPPRO       : E03TYPPRO   = [M:DIV]PV(0)
  Local Date      S03DTDBEXE
  Local Date      S03DTFNEXE
  Local Integer   S03INDEXE

$DEB_CAL_EXERCICE_SELON_DATE
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Integer  E03I

  S03DTDBEXE = [0/0/0]
  S03DTFNEXE = [0/0/0]
  S03INDEXE  = 0

  #----------------------------------
  # La date de référence doit être renseignée.
  If ( E03DATE = [0/0/0] ) Then
    [M:DIV]ERRID = 23 : Call ERRFND From =G_GLOB0  : # Dépilement suite à erreur logique
    If (dim(CALL_E03)<0) Then : Return : Else : End : Endif
  Endif
  #----------------------------------

  #-1 -------------
  If (func GLOBB9.CAL_DAT_INSIDE( E03DATE, [M:FIY]DATSTRFIY(0), [M:FIY]DATENDFIY([M:FIY]NB_EXE-1),"I" )) Then
    # La date se situe dans un exercice défini
    E03I = func GLOBB9.CAL_LOCALISE_DAT (E03DATE, [M:FIY]DATSTRFIY, [M:FIY]DATENDFIY, 0, [M:FIY]NB_EXE-1)
    #Call CAL_AJUST_DATE_SELON_PRORATA ( E03TYPPRO, [M:FIY]DATSTRFIY(E03I), "D", S03DTDBEXE ) From =G_GLOB8
    [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATSTRFIY(E03I) : [M:DIV]PC(0)= "D"
    Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
    S03DTDBEXE = [M:DIV]RD(0)
    #Call CAL_AJUST_DATE_SELON_PRORATA ( E03TYPPRO, [M:FIY]DATENDFIY(E03I), "F", S03DTFNEXE ) From =G_GLOB8
    [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATENDFIY(E03I) : [M:DIV]PC(0)= "F"
    Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
    S03DTFNEXE = [M:DIV]RD(0)
    S03INDEXE = E03I+1
  #-1 -------------
  Else
    # Si l'exercice dans lequel se situe la date n'est pas dans le tableau des exercices
    #-2 -------------
    If ( E03DATE > [M:FIY]DATENDFIY([M:FIY]NB_EXE-1) ) Then
      # Exercice ultérieur - recherche de l'exercice
      #Call CAL_AJUST_DATE_SELON_PRORATA(E03TYPPRO,[M:FIY]DATSTRFIY([M:FIY]NB_EXE-1),"D",S03DTDBEXE) From =G_GLOB8
      [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATSTRFIY([M:FIY]NB_EXE-1) : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
      S03DTDBEXE = [M:DIV]RD(0)
      #Call CAL_AJUST_DATE_SELON_PRORATA(E03TYPPRO,[M:FIY]DATENDFIY([M:FIY]NB_EXE-1),"F",S03DTFNEXE) From =G_GLOB8
      [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATENDFIY([M:FIY]NB_EXE-1) : [M:DIV]PC(0)= "F"
      Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
      S03DTFNEXE = [M:DIV]RD(0)
      # >>>>>
      While ( E03DATE > S03DTFNEXE )
        # Début du nouvel exercice
        S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE, 1, "D")
        # Fin du nouvel exercice
        #-----------------
        Case E03TYPPRO
          When GVML_TPJOUR
            # + 1 an
            S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE,  1, "Y")
          When GVML_TPMOIS, GVML_TPHLFY
            # + 12 mois avec ajustement fin de mois
            S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE, 12, "M")
            S03DTFNEXE = func GLOBB9.CAL_DAT_DERN( S03DTFNEXE    , "M")
          When GVML_TPSEMA
            # + 52 semaines avec ajustement fin de semaine
            S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE, 52, "W")
            S03DTFNEXE = func GLOBB9.CAL_DAT_DERN( S03DTFNEXE,     "W")
         When GVML_TPHLFM
            # + 12 mois avec ajustement fin de quinzaine
            S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE, 12, "M")
            S03DTFNEXE = func GLOBB9.CAL_DAT_DERN( S03DTFNEXE,     "Q")
         When GVML_TPHLFQ
            # + 12 mois avec ajustement fin de trimestre
            S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTFNEXE, 12, "M")
            S03DTFNEXE = func GLOBB9.CAL_DAT_DERN( S03DTFNEXE,     "T")
        Endcase
        #-----------------
      Wend
      # >>>>>
    #-2 -------------
    Else
      # Exercice antérieur - recherche de l'exercice
      #Call CAL_AJUST_DATE_SELON_PRORATA ( E03TYPPRO, [M:FIY]DATSTRFIY(0), "D", S03DTDBEXE ) From =G_GLOB8
      [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATSTRFIY(0) : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
      S03DTDBEXE = [M:DIV]RD(0)
      #Call CAL_AJUST_DATE_SELON_PRORATA ( E03TYPPRO, [M:FIY]DATENDFIY(0), "F", S03DTFNEXE ) From =G_GLOB8
      [M:DIV]PE(0)= E03TYPPRO : [M:DIV]PD(0)= [M:FIY]DATENDFIY(0) : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
      S03DTFNEXE = [M:DIV]RD(0)
      # >>>>>
      While ( E03DATE < S03DTDBEXE )
        # Fin d'un nouvel exercice
        S03DTFNEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -1, "D")
        # Début du nouvel exercice
        #-----------------
        Case E03TYPPRO
          When GVML_TPJOUR
            # - 1 an
            S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -1, "Y")
         When GVML_TPMOIS, GVML_TPHLFY
            # - 12 mois avec ajustement fin de mois
            S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -12, "M")
            S03DTDBEXE = func GLOBB9.CAL_DAT_PREM( S03DTDBEXE,      "M")
          When GVML_TPSEMA
            # - 52 semaines avec ajustement fin de semaine
            S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -52, "W")
            S03DTDBEXE = func GLOBB9.CAL_DAT_PREM( S03DTDBEXE,      "W")
         When GVML_TPHLFM
            # - 24 quinzaines avec ajustement fin de quinzaine
            S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -12, "M")
            S03DTDBEXE = func GLOBB9.CAL_DAT_PREM( S03DTDBEXE,      "Q")
         When GVML_TPHLFQ
            # - 8 1/2 trimestres avec ajustement fin de trimestre
            S03DTDBEXE = func GLOBB9.CAL_DAT_PLUS( S03DTDBEXE, -12, "M")
            S03DTDBEXE = func GLOBB9.CAL_DAT_PREM( S03DTDBEXE,      "T")
        Endcase
        #-----------------
      Wend
      # >>>>>
    Endif
    #-2 -------------
  Endif
  #-1 -------------


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E03)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RD(1) = S03DTDBEXE
 [M:DIV]RD(2) = S03DTFNEXE
 [M:DIV]RE(0) = S03INDEXE
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End


#
#########################################################
Subprog CAL_PERIODE_SELON_DATE ( PDATE, RDTDBPER, RDTFNPER, RINDPER )
#
# - Objet  : Renvoie la date de début et de fin de la période dans lequel se situe
#            la date. Les périodes sont sensées être définies.
#
# - Entrée : [M:FIY] Exercices/Périodes d'un contexte
#            Date de reférence
# - Sortie : Date début de période
#            Date fin de période
#            Indice de la période dans le tableau des périodes

#   Boite noire
#
Value    Date      PDATE
Variable Date      RDTDBPER
Variable Date      RDTFNPER
Variable Integer   RINDPER

Local Integer      I

  RDTDBPER = [0/0/0]
  RDTFNPER = [0/0/0]
  RINDPER  = 0
  I = func GLOBB9.CAL_LOCALISE_DAT (PDATE, [M:FIY]DATSTRPER, [M:FIY]DATENDPER,
&     [M:FIY]INDDEBPER ([M:DIV]FEC-1)-1,
&     [M:FIY]INDDEBPER ([M:DIV]FEC-1) +[M:FIY]NBRPER ([M:DIV]FEC-1) - 2 )
  # FQ74785
  #RDTDBPER = [M:FIY]DATSTRPER(I)
  #RDTFNPER = [M:FIY]DATENDPER(I)
  # FQ87444
  #RDTDBPER = [M:FIY]DATSTRPER(I+1)
  #RDTFNPER = [M:FIY]DATENDPER(I+1)
  RDTDBPER = [M:FIY]DATSTRPER([M:FIY]INDDEBPER ([M:DIV]FEC-1)-1+I)
  RDTFNPER = [M:FIY]DATENDPER([M:FIY]INDDEBPER ([M:DIV]FEC-1)-1+I)

  RINDPER = I+1
End

#
#########################################################
Subprog CAL_LOCALISE_PERIODE_SELON_DATE ( PDATE, RDTDBPER, RDTFNPER, RINDPER )
#
# - Objet  : Renvoie la date de début et de fin de la période dans lequel se situe
#            la date. Les périodes sont sensées être définies.
#
# - Entrée : [M:FIY] Exercices/Périodes d'un contexte
#            Date de reférence
# - Sortie : Date début de période
#            Date fin de période
#            Indice de la période dans le tableau des périodes

#   FQ85563
#
Value    Date      PDATE
Variable Date      RDTDBPER
Variable Date      RDTFNPER
Variable Integer   RINDPER

Local Integer      I

  RDTDBPER = [0/0/0]
  RDTFNPER = [0/0/0]
  RINDPER  = 0
  I = func GLOBB9.CAL_LOCALISE_DAT (PDATE, [M:FIY]DATSTRPER, [M:FIY]DATENDPER, 0, [M:FIY]NB_PER-1 )
  RDTDBPER = [M:FIY]DATSTRPER(I+1)
  RDTFNPER = [M:FIY]DATENDPER(I+1)

  RINDPER = I+1
End

#########################################################
Subprog  CAL_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, S04DURDET)
#
# - Objet  : Calcule la durée de détention dans l'intervalle (exercice ou période) qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#
# - Rem.   : Date de début 1 et Date de fin 1 doivent être obligatoirement renseignées
#            Si l'une ou l'autre est nulle alors la durée de détention sera nulle
#
#
# - Entrée : Table des périodes
#            Date de début de l'intervalle (période ou exercice ) (obligatoire)
#            Date de fin de l'intervalle (période ou exercice)    (obligatoire)
#            Date de début divers
#            Date de fin divers
#            Date de début d'amortissement
#            Date de fin d'amortissement
#            Date de sortie
#            Date de classement du bien comme détenu pour la vente
#
# - Sortie : Durée de détention
#
#   Boite noire gcfcd3
#
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT
Variable Decimal   S04DURDET : S04DURDET = 0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E04
Goto $DEB_CAL_DUR_DET
$GSB_CAL_DUR_DET
  # Déclaration des paramètres en entrée
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Decimal   S04DURDET

$DEB_CAL_DUR_DET
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Date    L04DTDBDET , L04DTFNDET


  # Date de début & fin dans l'intervalle (exercice ou période)
  #Call CAL_DAT_BORNES
  #&    ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3, E04DTFN4,
  #&      E04DTFN5, L04DTDBDET, L04DTFNDET) From =G_GLOB9
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From =G_GLOB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif

  # -1 --------------------------
  # Contrôle des dates obtenues
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  # -1 --------------------------
  Else
    # Durée de détention selon type de prorata
    #Call CAL_DAT_DIFF( L04DTDBDET, L04DTFNDET, PTYPPRODAT, S04DURDET ) From =G_GLOB9
    [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : S04DURDET = [M:DIV]RV(0)
  Endif
  # -1 --------------------------


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E04)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%


End


#
#########################################################
Subprog  CAL_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, PTYPPRODAT, RDUR_REST_AMT)
#
# - Objet  : Calcule la durée restant à amortir qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#            restant à courir jusqu'à la fin de l'amortissement
#
# - Entrée :
#
# - Sortie : Durée restant à amortir
#   Boite noire calc_dur_rest_amt (gcfc10)
#

Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Value     Char     PTYPPRODAT
Variable  Decimal  RDUR_REST_AMT : RDUR_REST_AMT = 0

Local     Date     LDAT

  LDAT = max(PDTDBAMT, PDTDB)
  # Si date de début > fin d'amortissement
  # la durée restant à amortir est nulle
  # ---------------------------
  If ( LDAT <= PDTFNAMT ) Then
    # Durée restant à amortir selon type de prorata
    #Call CAL_DAT_DIFF(LDAT, PDTFNAMT, PTYPPRODAT, RDUR_REST_AMT ) From =G_GLOB9
    [M:DIV]PD(0)= LDAT: [M:DIV]PD(1)= PDTFNAMT : [M:DIV]PC(0)= PTYPPRODAT
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : RDUR_REST_AMT = [M:DIV]RV(0)
  Endif
  # ---------------------------

End


#
#########################################################
Subprog  CAL_AJUST_DATE_SELON_PRORATA ( E05TYPPRO, E05DAT, E05DBFN, S05DAT)
#
# - Objet  : Ajuste une date selon le type de prorata
#            La date de début est ajustée en début de semaine, quinzaine, mois, ...
#            La date de fin   est ajustée en fin   de semaine, quinzaine, mois, ...
#
# - Entrée : Type de prorata
#            Date
#            Indicateur "D"ébut/"F"in
#
# - Sortie : Date ajustée

#   Boite noire
#

Value     Integer  E05TYPPRO
Value     Date     E05DAT
Value     Char     E05DBFN
Variable  Date     S05DAT



#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E05
Goto $DEB_CAL_AJUST_DATE_SELON_PRORATA
$GSB_CAL_AJUST_DATE_SELON_PRORATA
  # Déclaration des paramètres en entrée
  Local Integer   E05TYPPRO       : E05TYPPRO   = [M:DIV]PE(0)
  Local Date      E05DAT          : E05DAT      = [M:DIV]PD(0)
  Local Char      E05DBFN         : E05DBFN     = [M:DIV]PC(0)
  Local Date      S05DAT

$DEB_CAL_AJUST_DATE_SELON_PRORATA
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

 S05DAT = E05DAT

 #-----------------
 Case E05TYPPRO

   When GVML_TPMOIS, GVML_TPHLFY
   #-----------------
     If (E05DBFN = "D" ) Then
       # Début d'exercice ajustée à début de mois
       S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT, "M")
     Else
       # Date de fin d'exercice
       If !( func GLOBB9.CAL_DAT_ISENDOFMONTH (E05DAT ) ) Then
         # La date de fin d'exercice n'est pas une fin de mois, ajustement au dernier jour du mois précédent
         S05DAT = func GLOBB9.CAL_DAT_PLUS( E05DAT, -1, "M")
         S05DAT = func GLOBB9.CAL_DAT_DERN( S05DAT, "M")
       Else
         S05DAT = E05DAT
       Endif
     Endif

   When GVML_TPSEMA
   #-----------------
     If (E05DBFN = "D" ) Then
       # Début d'exercice ajustée à 1er jour de la semaine
       S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT , "W")
     Else
       # Date de fin d'exercice
       If !( func GLOBB9.CAL_DAT_ISENDOFWEEK (E05DAT ) ) Then
         # La fin d'exercice n'est pas une fin de semaine, ajustement au dernier jour de la semaine précédente
         S05DAT = func GLOBB9.CAL_DAT_PLUS( E05DAT , -7, "D")
         S05DAT = func GLOBB9.CAL_DAT_DERN( S05DAT , "W")
       Else
         S05DAT = E05DAT
       Endif
     Endif

   When GVML_TPHLFM
   #-----------------

     If (E05DBFN = "D" ) Then
       # Début d'exercice ajustée à début de quinzaine
       S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT , "Q")
     Else
       # Date de fin d'exercice
       If !( func GLOBB9.CAL_DAT_ISENDOFHLFM (E05DAT ) ) Then
         # La date de fin d'exercice n'est pas une fin de quinzaine, ajustement à fin de quinzaine précédente
         S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT, "Q")
         S05DAT = func GLOBB9.CAL_DAT_PLUS( S05DAT , -1, "D")
       Else
         S05DAT = E05DAT
       Endif
     Endif

   When GVML_TPHLFQ
   #-----------------
     If (E05DBFN = "D" ) Then
       # Début d'exercice ajustée à début du 1/2 trimestre
       S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT , "T")
     Else
       # Date de fin d'exercice
       If !( func GLOBB9.CAL_DAT_ISENDOFHLFQ (E05DAT ) ) Then
         # La fin d'exercice n'est pas une fin de 1/2 trimestre, ajustement à fin de 1/2 trimestre précédent
         S05DAT = func GLOBB9.CAL_DAT_PREM( E05DAT, "T")
         S05DAT = func GLOBB9.CAL_DAT_PLUS( S05DAT , -1, "D")
       Else
         S05DAT = E05DAT
       Endif
     Endif

 Endcase
 #-----------------


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E05)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RD(0) = S05DAT
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Subprog CAL_TYPE_PRORATA ( PMODAMT, PALWCOD, PPRATYP, PBSEMAINE, PPROEXEMDB, PPROEXEMLB, PTYPPROLB,
&                          RTYPPRO, RTYPPRODAT )
# - Objet  : Renvoie le type de prorata à appliquer.
#            Pour les modes standards, il est fonction
#            de la règle particulière, du mode, du paramètre société "prorata en semaine"
#            Pour les modes libres, il est fonction du  paramètre  "type de prorata"
#
# - Entrée : Mode d'amortissement
#            Règle particulière
#            Mode UL/UD - Type de Prorata saisi
#            Indicateur prorata en semaine
#            Mode DB/LB - Type de Prorata à appliquer
#            Type de prorata d'un mode d'amortissement libre
#
# - Sortie : Type de prorata à appliquer
#            Type de prorata pour fonction sur date à utiliser

#   Boite noire gcfc6k
#
Value    Char      PMODAMT       : # Mode d'amortissement
Value    Integer   PALWCOD       : # Règle particulière
Value    Integer   PPRATYP       : # Mode UD/UL - Type de Prorata préciser à la saisie
Value    Integer   PBSEMAINE     : # Indicateur prorata en Mois ou en Semaine
Value    Integer   PPROEXEMDB    : # Mode DB - Type de Prorata à appliquer
Value    Integer   PPROEXEMLB    : # Mode LB - Type de Prorata à appliquer
Value    Integer   PTYPPROLB     : # Type de prorata mode libre

Variable Integer   RTYPPRO       : # Type de prorata à utiliser
Variable Char      RTYPPRODAT    : # Type de prorata pour fonction sur date à utiliser

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    PROTYP                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI8 ) Then
    G_SKPSTD = 0
    GPOINT = "PROTYP" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9120 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then

    Case PMODAMT

      When G_DPMLV, G_DPMIT, G_DPMDI, G_DPMDE, G_DPMUO, G_DPMSA, G_DPMCA, G_DPMRA,
&          G_DPMSL, G_DPM1P, G_DPMAL, G_DPMAD
        # Modes d'amt standard dont le type de prorata est uniquement en JOURS
        # FQ82075 FQ84110 FQ84283
        RTYPPRO = GVML_TPJOUR

      When G_DPMDF, G_DPMPC, G_DPMPD, G_DPMDV, G_DPMFM, G_DPMLG, G_DPMDP, G_DPMDM,
&          G_DPMLR, G_DPMDR, G_DPMCR, G_DPMSR, G_DPMUR, G_DPMML, G_DPMMD, G_DPMRL,
&          G_DPMRX, G_DPMRD
        # Modes d'amortissement standard dont le type de prorata est uniquement en MOIS
        # FQ55960 FQ59941 FQ67577 FQ72372 FQ7877
        RTYPPRO = GVML_TPMOIS

      When G_DPMLP
        # Modes d'amt standard dont le type de prorata est en JOURS (ou MOIS)
        If ( PALWCOD = GVML_RPALOGI ) Then
          RTYPPRO = GVML_TPMOIS
        Else
          RTYPPRO = GVML_TPJOUR
        Endif

      When G_DPMRE, G_DPMHL, G_DPMHD, G_DPMTL
        # Modes d'amt standard dont le type de prorata peut être saisi FQ84821, FQ105809
        If ( PPRATYP <> 0 ) Then
          RTYPPRO = PPRATYP
        Else
          # Le type de prorata selon le mode n'a pas pu être déterminée
          [M:DIV]ERRID = 24 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
        Endif

      When G_DPMSY, G_DPMPR, G_DPMDX, G_DPMDA, G_DPMLE
        # Modes d'amt standard dont le type de prorata est en MOIS (ou SEMAINE)
        If ( PBSEMAINE ) Then
          RTYPPRO = GVML_TPSEMA
        Else
          RTYPPRO = GVML_TPMOIS
        Endif

      When G_DPMUD, G_DPMUL, G_DPMTD
        # FQ105809
        # Modes d'amt standard dont le type de prorata est précisé à la saisie
        If ( PPRATYP <> 0 ) Then
          RTYPPRO = PPRATYP
        Else
          # Le type de prorata selon le mode n'a pas pu être déterminée
          [M:DIV]ERRID = 24 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
        Endif

      When G_DPMDB
        # Modes d'amt standard dont le type de prorata est selon option précisée au niveau du mode d'amt
        # Dégressif belge
        Case PPROEXEMDB
          When GVML_COPJOUR
            RTYPPRO = GVML_TPJOUR
          When GVML_COPMOIS
            RTYPPRO = GVML_TPMOIS
          When GVML_COPSANS
            RTYPPRO = GVML_TPMOIS
          When Default
            RTYPPRO = GVML_TPMOIS
        Endcase

      When G_DPMLB
        # Modes d'amt standard dont le type de prorata est selon option précisée au niveau du mode d'amt
        # Linéaire Belge
        Case PPROEXEMLB
          When GVML_COPJOUR
            RTYPPRO = GVML_TPJOUR
          When GVML_COPMOIS
            RTYPPRO = GVML_TPMOIS
          When GVML_COPSANS
            RTYPPRO = GVML_TPMOIS
          When Default
            RTYPPRO = GVML_TPMOIS
        Endcase

      When Default
        # Modes d'amt libre type de prorata selon paramètrage
        If ( PTYPPROLB <> 0 )  Then
          RTYPPRO = PTYPPROLB
        Else
          # Le type de prorata selon le mode n'a pas pu être déterminée
          [M:DIV]ERRID = 24 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
        Endif
    Endcase

  Endif
  # -1 --------------------------------------------

  # Transcodification type prorata => type fonction date
  Case RTYPPRO
    When GVML_TPJOUR :RTYPPRODAT = "D"
    When GVML_TPMOIS :RTYPPRODAT = "M"
    When GVML_TPHLFY :RTYPPRODAT = "M"
    When GVML_TPSEMA :RTYPPRODAT = "W"
    When GVML_TPHLFM :RTYPPRODAT = "Q"
    When GVML_TPHLFQ :RTYPPRODAT = "T"
    When Default :    RTYPPRODAT = "D"
  Endcase

End

#
#########################################################
Subprog CAL_DATE_DEB_AMT_SELON_MODE
&     ( PMODAMT, PALWCOD, PDTDBEXE, PDTDBAMT,  PDTDBEXI, PDTFNEXI, PDATMES, PPROEXEMDB, PPROEXEMLB, PRGLSIMPL,
&       PTYPPRO, PTYPPRODAT, RDTDBAMTREG )
#
# - Objet  : Renvoie la date de début d'amortissement selon mode, règle et autres paramétrages
#
#
# - Entrée :
#            Mode d'amortissement
#            règle particulière
#            Date de début d'exercice
#            Date de début d'amortissement (fichier)
#            Date de début d'exercice d'investissement
#            date mise en service FQ59941
#            Prorata selon mode belge (DB)
#            Prorata selon mode belge (LB)
#            Regle de simplication selon mode allemand (DA,DX)
#            type de prorata
#            type de prorata pour fonction date
#
# - Sortie : Date de début d'amortissement régularisée
#
#   Boite noire gcfc6a
#
Value    Char      PMODAMT
Value    Integer   PALWCOD
Value    Date      PDTDBEXE
Value    Date      PDTDBAMT
Value    Date      PDTDBEXI
Value    Date      PDTFNEXI
Value    Date      PDATMES     : # FQ59941
Value    Integer   PPROEXEMDB
Value    Integer   PPROEXEMLB
Value    Integer   PRGLSIMPL
Value    Integer   PTYPPRO
Value    Char      PTYPPRODAT
Variable Date      RDTDBAMTREG

Local Date WDTDBEXIS
Local Integer BROUTEUR : BROUTEUR = 0

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    STRDPCDAT               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI8 ) Then
    G_SKPSTD = 0
    GPOINT = "STRDPCDAT" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9130 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then

    #-------------------------
    Case PMODAMT
      When  G_DPMUO, G_DPMLV, G_DPMDI, G_DPMDE, G_DPMCA, G_DPMRA, G_DPMSL, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMTL
      #-------------------------
        # AU Jour près
        # FQ82075 FQ84110 FQ84283, FQ105809
        RDTDBAMTREG  = PDTDBAMT

      When  G_DPMIT
      #-------------------------
        If ( [M:DIV]PROEXEINV <> G_OUI ) Then
          # AU 1er Jour de l'exercice
          RDTDBAMTREG  = PDTDBEXE
        Else
          # AU Jour près
          RDTDBAMTREG  = PDTDBAMT
        Endif

      When  G_DPMLP
      #-------------------------
          If ( PALWCOD = GVML_RPALOGI ) Then
          # Au premier jour du mois
          RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
        Else
          # AU Jour près
          RDTDBAMTREG  = PDTDBAMT
        Endif
      When  G_DPMDF, G_DPMPD, G_DPMDP, G_DPMDV, G_DPMFM, G_DPMLG, G_DPMLE, G_DPMDM
      #-------------------------
        # FQ55960
        # Au premier Jour du mois d'investissement
        RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )

      When  G_DPMSY, G_DPMPR
      #-------------------------
        # Au premier jour du mois ou au premier jour de la semaine selon prorata
        If ( PTYPPRO = GVML_TPSEMA ) Then
          # Au premier jour de la semaine (lundi)
          RDTDBAMTREG = func GLOBB9.CAL_DAT_PREM(PDTDBAMT, PTYPPRODAT)
        Else
          # Au premier jour du mois
          RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
        Endif

      When  G_DPMDX, G_DPMDA
      #-------------------------
        If ( PRGLSIMPL = G_OUI) Then
          # Au premier jour du semestre courant
          Call CAL_DAT_DEBUT_SEMESTRE ( PDTDBEXI, PDTFNEXI, PDTDBAMT, RDTDBAMTREG ) From =G_GLOB9
        Else
          # Au premier jour du mois
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
        Endif
        If ( PTYPPRO = GVML_TPSEMA ) Then
          If !( func GLOBB9.CAL_DAT_ISBEGINNINGOFWEEK(RDTDBAMTREG) ) Then
            # Cadrage - Au premier jour de la 1ère semaine du mois (lundi)
            RDTDBAMTREG = func GLOBB9.CAL_DAT_PLUS(RDTDBAMTREG, 7 , "D")
            RDTDBAMTREG = func GLOBB9.CAL_DAT_PREM(RDTDBAMTREG, PTYPPRODAT)
          Endif
        Endif

      When G_DPMUD, G_DPMUL, G_DPMTD
      #-------------------------
      # FQ105809
        Case PTYPPRO
          When GVML_TPHLFY
            # Half year
            # AU début du 2ème semestre d'acquisition
            RDTDBAMTREG = func GLOBB9.CAL_DAT_PLUS( PDTDBEXI , 6 , "M")
          When GVML_TPMOIS
            # Mois
            # AU Premier Jour du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
          When GVML_TPHLFM
            # 1/2 mois
            # AU début de la 2ème quinzaine du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(16, month(PDTDBAMT), year(PDTDBAMT))
          When GVML_TPHLFQ
            # 1/2 trimestre
            # AU début 2ème 1/2 trimestre du Trimestre du début d'amortissement
            If    ( PDTDBAMT > gdat$(30, 09, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 11, year(PDTDBAMT))
            Elsif ( PDTDBAMT > gdat$(30, 06, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 08, year(PDTDBAMT))
            Elsif ( PDTDBAMT > gdat$(31, 03, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 05, year(PDTDBAMT))
            Else
              RDTDBAMTREG = gdat$(16, 02, year(PDTDBAMT))
            Endif
          When Default
            # Pas d'ajustement
            RDTDBAMTREG  = PDTDBAMT
        Endcase

      When G_DPMDB
      #-------------------------
        #-2 ------------------------
        Case PPROEXEMDB
          When GVML_COPJOUR
            #-2 ------------------------
            # Jour
            # AU Jour Pécisé
            RDTDBAMTREG  = PDTDBAMT
          When GVML_COPMOIS
            #-2 ------------------------
            # Mois
            # AU Premier Jour du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
          When GVML_COPSANS
            #-2 ------------------------
            # Sans prorata
            # AU Premier Jour de l'exercice d'investissement
            Call CAL_DATE_DEB_AMT_SELON_REGLE
&           ( GVML_DA1ERE,PDTDBAMT,PDTDBEXI,[M:DIV]DATNUL,[M:DIV]DATNUL,PTYPPRO,RDTDBAMTREG ) From =G_GLOB7
          When Default
            # Pas d'ajustement
            RDTDBAMTREG  = PDTDBAMT
        Endcase
        #-2 ------------------------

      When G_DPMLB
      #-------------------------
        #-2 ------------------------
        Case PPROEXEMLB
          When GVML_COPJOUR
            #-2 ------------------------
            # Jour
            # AU Jour Pécisé
            RDTDBAMTREG  = PDTDBAMT
          When GVML_COPMOIS
            #-2 ------------------------
            # Mois
            # AU Premier Jour du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
          When GVML_COPSANS
            #-2 ------------------------
            # Sans prorata
            # AU Premier Jour de l'exercice d'investissement
            Call CAL_DATE_DEB_AMT_SELON_REGLE
&           ( GVML_DA1ERE,PDTDBAMT,PDTDBEXI,[M:DIV]DATNUL,[M:DIV]DATNUL,PTYPPRO,RDTDBAMTREG ) From =G_GLOB7
          When Default
            # Pas d'ajustement
            RDTDBAMTREG  = PDTDBAMT
        Endcase
        #-2 ------------------------

      When G_DPMPC
      #-------------------------
        Case PALWCOD
          When GVML_RPPERIO
            If ( day(PDTDBAMT) <> 1 ) Then
              # Début de mois suivant si début d'amortissement en cours de mois
              Call CAL_DATE_DEB_AMT_SELON_REGLE
&             (GVML_DA1ERMS,PDTDBAMT,[M:DIV]DATNUL,[M:DIV]DATNUL,[M:DIV]DATNUL,PTYPPRO,RDTDBAMTREG) From =G_GLOB7
            Else
              # Début de mois si début d'amortissement le 1er jour du mois
              RDTDBAMTREG = PDTDBAMT
            Endif
          When GVML_RPEXERC
            # Début de l'exercice suivant l'acquisition
            WDTDBEXIS = func GLOBB9.CAL_DAT_PLUS(PDTFNEXI, 1 , "D")
            Call CAL_DATE_DEB_AMT_SELON_REGLE
&           ( GVML_DA1ERES,PDTDBAMT,[M:DIV]DATNUL,[M:DIV]DATNUL,WDTDBEXIS,PTYPPRO,RDTDBAMTREG ) From =G_GLOB7
          When Default
            # La règle particulière associée au mode PC est inconsistante.
            [M:DIV]ERRID = 25 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
        Endcase


      When  G_DPMRE
      #-------------------------
        Case PTYPPRO
          When GVML_TPJOUR
            # -- Résiduel Jour
            # AU Jour près
            RDTDBAMTREG  = PDTDBAMT
          When GVML_TPSEMA
            # -- Résiduel Semaine
            # Au premier jour de la semaine (lundi)
            RDTDBAMTREG = func GLOBB9.CAL_DAT_PREM(PDTDBAMT, PTYPPRODAT)
          When GVML_TPHLFM
            # -- Résiduel 1/2 mois
            # AU début de la 2ème quinzaine du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(16, month(PDTDBAMT), year(PDTDBAMT))
          When GVML_TPMOIS
            # Mois
            # AU Premier Jour du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
          When GVML_TPHLFQ
            #-2 ------------------------
            # -- Résiduel 1/2 trimestre
            # AU début 2ème 1/2 trimestre du Trimestre du début d'amortissement
            If    ( PDTDBAMT > gdat$(30, 09, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 11, year(PDTDBAMT))
            Elsif ( PDTDBAMT > gdat$(30, 06, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 08, year(PDTDBAMT))
            Elsif ( PDTDBAMT > gdat$(31, 03, year(PDTDBAMT)) ) Then
              RDTDBAMTREG = gdat$(16, 05, year(PDTDBAMT))
            Else
              RDTDBAMTREG = gdat$(16, 02, year(PDTDBAMT))
            Endif
          When GVML_TPHLFY
            # -- Résiduel 1/2 année
            # AU Premier Jour du Mois du début d'amortissement
            RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
          When Default
            # AU Jour près
            RDTDBAMTREG  = PDTDBAMT
        Endcase

      When  G_DPMHL, G_DPMHD
      #-------------------------
        # FQ84281
        If ( [F:DEPC]ALWCOD = GVML_RPA1EXD ) Then
            # AU Premier Jour de l'exercice d'investissement
            Call CAL_DATE_DEB_AMT_SELON_REGLE
&           ( GVML_DA1ERE,PDTDBAMT,PDTDBEXI,[M:DIV]DATNUL,[M:DIV]DATNUL,PTYPPRO,RDTDBAMTREG ) From =G_GLOB7
        Else
          Case PTYPPRO
            When GVML_TPJOUR
              # -- Résiduel Jour
              # AU Jour près
              RDTDBAMTREG  = PDTDBAMT
            When GVML_TPMOIS
              # Mois
              # AU Premier Jour du Mois du début d'amortissement
              RDTDBAMTREG = gdat$(01,month(PDTDBAMT), year(PDTDBAMT) )
            When Default
              # AU Jour près
              RDTDBAMTREG  = PDTDBAMT
          Endcase
        Endif

      When  G_DPMLR, G_DPMDR, G_DPMCR, G_DPMSR, G_DPMUR
      #-------------------------
        # FQ59941
        # If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
        # Attention : Utilisé également dans TRTIMMOFEN arrêter/démarrer la dotation
        If (BROUTEUR) Then :
          $DEB_AMT_MODES_RUSSES
          Local Integer BROUTEUR
          BROUTEUR = 1
        Endif
        RDTDBAMTREG  = PDTDBAMT
        # AU Début du mois suivant sauf si 1er jour du mois
        # FQ67049 If ( day(PDTDBAMT)  <> 1 or PDATMES = PDTDBAMT ) Then
        If ( day(PDTDBAMT)  <> 1 ) Then
          If (month(PDTDBAMT) = 12) Then
            RDTDBAMTREG  = gdat$(01,01, year(PDTDBAMT)+1 )
          Else
            RDTDBAMTREG  = gdat$(01,month(PDTDBAMT)+1, year(PDTDBAMT) )
          Endif
        Endif

      When  G_DPMML, G_DPMMD
      #-------------------------
        # FQ67577 FQ72372
        RDTDBAMTREG  = PDTDBAMT
        # AU Début du mois suivant sauf si 1er jour du mois
        If ( day(PDTDBAMT)  <> 1 ) Then
          If (month(PDTDBAMT) = 12) Then
            RDTDBAMTREG  = gdat$(01,01, year(PDTDBAMT)+1 )
          Else
            RDTDBAMTREG  = gdat$(01,month(PDTDBAMT)+1, year(PDTDBAMT) )
          Endif
        Endif

      When  G_DPMRL, G_DPMRX, G_DPMRD
      #-------------------------
        # Attention : Utilisé également dans TRTIMMOFEN arrêter/démarrer la dotation FQ80825
        If (BROUTEUR) Then :
          $DEB_AMT_MODES_ROUMAINS
          Local Integer BROUTEUR
          BROUTEUR = 1
        Endif
        # FQ77877
        RDTDBAMTREG  = PDTDBAMT
        # AU Début du mois suivant y compris si 1er jour du mois
        If (month(PDTDBAMT) = 12) Then
          RDTDBAMTREG  = gdat$(01,01, year(PDTDBAMT)+1 )
        Else
          RDTDBAMTREG  = gdat$(01,month(PDTDBAMT)+1, year(PDTDBAMT) )
        Endif

      When Default
      #-------------------------
        # La date de début d'amt régularisée par défaut est égale à la date de début d'amt
        RDTDBAMTREG  = PDTDBAMT

    Endcase
    #-------------------------

  Endif
  # -1 --------------------------------------------

  # Routage FQ59941
  If (BROUTEUR) Then : Return : Endif

End


#
#########################################################
Subprog CAL_DATE_SORTIE_SELON_MODE
&     ( PMODAMT, PALWCOD, PPROEXESOR, PPROEXEMDB, PPROEXEMLB, PTYPPRO, PTYPPRODAT, PDATSOR, PPLN,  RDATSORREG )
#
# - Objet  : Renvoie la date de sortie régularisée selon mode, règle et autres paramétrages
#
#
# - Entrée :
#            Mode d'amortissement
#            Régle particulière
#            Indicateur avec Prorata lors de l'exercice de sortie (IT)
#            Type de Prorata à appliquer (DB)
#            Type de Prorata à appliquer (LB)
#            Type de prorata ( saisi )
#            Type de prorata ( pour fonction sur date )
#            Date de sortie (fichier)
# - Sortie : Date de sortie régularisée

#   Boite noire gcfc6f
#
Value    Char      PMODAMT
Value    Integer   PALWCOD
Value    Integer   PPROEXESOR    : # Mode IT    - Indicateur Prorata exercice de désinvestissement
Value    Integer   PPROEXEMDB    : # Mode DB    - Type de Prorata à appliquer
Value    Integer   PPROEXEMLB    : # Mode LB    - Type de Prorata à appliquer
Value    Integer   PTYPPRO
Value    Char      PTYPPRODAT
Value    Date      PDATSOR
Value    Integer   PPLN

Variable Date      RDATSORREG

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    ISSDAT                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If ( G_ETP_GLOBI8 ) Then
    G_SKPSTD = 0
    GPOINT = "ISSDAT" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9140 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then

    #-----------------------
    Case PMODAMT

      When G_DPMRA
      #-----------------------
        # FQ54343
        If ( [M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCFIR ) Then
          # Dotation calculée jusqu'au jour de sortie
          # AU JOUR PRES
          RDATSORREG = PDATSOR
        Endif
        If ( [M:DIV]BACTCCN and [M:DIV]CCNMOD = GVML_GCRNW and [M:DIV]CNT = G300CPFI ) Then
          If ( PPLN = [M:DIV]CCNCADPLN ) Then
            # Plan de caducité
            # Dotation calculée jusqu'au jour de sortie
            # AU JOUR PRES
            RDATSORREG = PDATSOR
         Else
            # Plan autre que le plan de caducité
            # Dotation calculée comme si le bien n'était pas sorti
            RDATSORREG = [0/0/0]
          Endif
        Endif

      When G_DPMIT, G_DPMSA, G_DPMUO, G_DPMLV, G_DPMDI, G_DPMDE, G_DPMSL, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMTL
      #-----------------------
        # Dotation calculée jusqu'au jour de sortie
        # AU JOUR PRES
        # FQ82075 FQ84110 FQ84283, FQ105809
        RDATSORREG = PDATSOR
      When G_DPMLP
      #-----------------------
        If ( PALWCOD = GVML_RPALOGI ) Then
          # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
          # AU dernier JOUR DU MOIS PRECEDANT la sortie
          Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7

          If ( PTYPPRO = GVML_TPSEMA ) Then
            If !( func GLOBB9.CAL_DAT_ISENDOFWEEK(RDATSORREG) ) Then
              # Cadrage - Au dernier jour de la semaine du mois de sortie (dimanche)
              RDATSORREG = func GLOBB9.CAL_DAT_PLUS(RDATSORREG , -7 , "D")
              RDATSORREG = func GLOBB9.CAL_DAT_DERN(RDATSORREG , PTYPPRODAT)
            Endif
          Endif
        Else
          # Dotation calculée jusqu'au jour de sortie
          # AU JOUR PRES
          RDATSORREG = PDATSOR
        Endif

      When G_DPMDF, G_DPMDP, G_DPMLE, G_DPMFM, G_DPMLG, G_DPMPD
      #-----------------------
        # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
        # AU dernier JOUR DU MOIS PRECEDANT la sortie
        Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
        If ([M:DIV]ERROR) Then : End : Endif

        If ( PTYPPRO = GVML_TPSEMA ) Then
          If !( func GLOBB9.CAL_DAT_ISENDOFWEEK(RDATSORREG) ) Then
            # Cadrage - Au dernier jour de la semaine du mois de sortie (dimanche)
            RDATSORREG = func GLOBB9.CAL_DAT_PLUS(RDATSORREG , -7 , "D")
            RDATSORREG = func GLOBB9.CAL_DAT_DERN(RDATSORREG , PTYPPRODAT)
          Endif
        Endif

      When G_DPMCA
      #-----------------------
        # FQ54343
        # If ( [M:DIV]BSOR and [F:DEPC]ALWCOD = GVML_RPCONCE and [F:WFAS]ISSDATRUL = GVML_IRCONCE  ) Then
        If ( [M:DIV]BSOR and [F:DEPC]ALWCOD = GVML_RPCONCE and
&            ( not([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and[F:WFAS]CCNETRTYP = GVML_NA1ERBC)  )  ) Then

          # Règle Part. "Regul/Reint Amort." & Règle de sortie de sortie "1er bien cédé de la concession"
          # Dotation calculée normalement ( 1er bien sorti de la concession)
          RDATSORREG = [0/0/0]
        Else
          # Dotation calculée jusqu'au jour de sortie
          # AU JOUR PRES
          RDATSORREG = PDATSOR
        Endif

      When G_DPMPC, G_DPMDM, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMSR, G_DPMUR, G_DPMML, G_DPMMD,
&          G_DPMRL, G_DPMRX, G_DPMRD
      #-----------------------
        # FQ55960 FQ59941 FQ67577 FQ72372 FQ77877
        # Dotation complète pour le mois de sortie
        # AU dernier JOUR DU MOIS de sortie
        Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMC, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
        If ([M:DIV]ERROR) Then : End : Endif

      When G_DPMDX, G_DPMDA
      #-----------------------
        # Dotation complète pour le mois de sortie
        # AU dernier JOUR DU MOIS de sortie
        Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMC, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
        If ([M:DIV]ERROR) Then : End : Endif

        If ( PTYPPRO = GVML_TPSEMA ) Then
          If !( func GLOBB9.CAL_DAT_ISENDOFWEEK(RDATSORREG ) ) Then
            # Cadrage - Au dernier jour de la semaine du mois de sortie (dimanche)
            RDATSORREG = func GLOBB9.CAL_DAT_PLUS(RDATSORREG , -7 , "J")
            RDATSORREG = func GLOBB9.CAL_DAT_DERN(RDATSORREG , PTYPPRODAT)
          Endif
        Endif

      When G_DPMUD, G_DPMUL, G_DPMTD
      #-------------------------
      # FQ105809
        Case PTYPPRO
          When GVML_TPHLFY
            # 1/2 année
            # A la fin du Premier Semestre de l'année de sortie
            RDATSORREG = gdat$(30, 06, year(PDATSOR))
          When GVML_TPMOIS
            # Mois
            # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
            # AU dernier JOUR DU MOIS PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When GVML_TPHLFM
            # 1/2 mois
            # A la fin de la 1ère quinzaine du Mois de sortie
            RDATSORREG = gdat$(15, month(PDATSOR), year(PDATSOR))
          When GVML_TPHLFQ
            # 1/2 trimestre
            # A la fin du 1er 1/2 trimestre du Trimestre de sortie
            If    ( PDATSOR > gdat$(30, 09, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 11, year(PDATSOR ))
            Elsif ( PDATSOR > gdat$(30, 06, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 08, year(PDATSOR ))
            Elsif ( PDATSOR > gdat$(31, 03, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 05, year(PDATSOR ))
            Else
              RDATSORREG = gdat$(15, 02, year(PDATSOR ))
            Endif
          When Default
            # Pas d'ajustement
            RDATSORREG   = PDATSOR
        Endcase

      When G_DPMSY, G_DPMPR
      #-------------------------
        If ( PTYPPRO = GVML_TPSEMA  ) Then
          # Au dernier jour de la semaine de sortie (dimanche)
          RDTSORREG = func GLOBB9.CAL_DAT_DERN( PDATSOR, "W" )
        Else
          # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
          # AU dernier JOUR DU MOIS PRECEDANT la sortie
          Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
          If ([M:DIV]ERROR) Then : End : Endif
        Endif

      When G_DPMDB
      #-----------------------
        #-2 ------------------------
        Case PPROEXEMDB
          When GVML_COPJOUR
            #-2 ------------------------
            # Jour
            # Au jour précisé (Uniquement pour le LB. Pas de prorata jour pour le DB).
            RDATSORREG = PDATSOR
          When GVML_COPMOIS
            #-2 ------------------------
            # Mois
            # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
            # AU dernier JOUR DU MOIS PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When GVML_COPSANS
            #-2 ------------------------
            # Sans prorata
            # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
            # AU dernier JOUR DE L'EXERCICE PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDEREP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When Default
            # Pas d'ajustement
            RDATSORREG = PDATSOR
        Endcase
        #-2 ------------------------

      When G_DPMLB
      #-----------------------
        #-2 ------------------------
        Case PPROEXEMLB
          When GVML_COPJOUR
            #-2 ------------------------
            # Jour
            # Au jour précisé (Uniquement pour le LB. Pas de prorata jour pour le DB).
            RDATSORREG = PDATSOR
          When GVML_COPMOIS
            #-2 ------------------------
            # Mois
            # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
            # AU dernier JOUR DU MOIS PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When GVML_COPSANS
            #-2 ------------------------
            # Sans prorata
            # Pas de dotation le mois de sortie, sauf si sortie fin de mois.
            # AU dernier JOUR DE L'EXERCICE PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDEREP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When Default
            # Pas d'ajustement
            RDATSORREG = PDATSOR
        Endcase
        #-2 ------------------------

      When  G_DPMRE, G_DPMAL, G_DPMAD
      #-------------------------
        Case PTYPPRO
          When GVML_TPJOUR
            # -- Résiduel Jour
            # AU JOUR PRES
            RDATSORREG = PDATSOR
          When GVML_TPSEMA
            # -- Résiduel Semaine
            If !( func GLOBB9.CAL_DAT_ISENDOFWEEK(PDATSOR) ) Then
               # Cadrage - Au dernier jour de la semaine du mois de sortie (dimanche)
               RDATSORREG = func GLOBB9.CAL_DAT_PLUS(PDATSOR , -7 , "D")
               RDATSORREG = func GLOBB9.CAL_DAT_DERN(RDATSORREG , PTYPPRODAT)
            Endif
          When GVML_TPHLFM
            # -- Résiduel 1/2 mois
            # A la fin de la 1ère quinzaine du Mois de sortie
            RDATSORREG = gdat$(15, month(PDATSOR), year(PDATSOR))
          When GVML_TPMOIS
            # -- Résiduel mois
            # AU dernier JOUR DU MOIS PRECEDANT la sortie
            Call CAL_DATE_SORTIE_SELON_REGLE( GVML_DSDERMP, PDATSOR, PTYPPRO, RDATSORREG ) From =G_GLOB7
            If ([M:DIV]ERROR) Then : End : Endif
          When GVML_TPHLFQ
            # -- Résiduel 1/2 trimestre
            # 1/2 trimestre
            # A la fin du 1er 1/2 trimestre du Trimestre de sortie
            If    ( PDATSOR > gdat$(30, 09, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 11, year(PDATSOR ))
            Elsif ( PDATSOR > gdat$(30, 06, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 08, year(PDATSOR ))
            Elsif ( PDATSOR > gdat$(31, 03, year(PDATSOR )) ) Then
              RDATSORREG = gdat$(15, 05, year(PDATSOR ))
            Else
              RDATSORREG = gdat$(15, 02, year(PDATSOR ))
            Endif
          When GVML_TPHLFY
            # -- Résiduel 1/2 année
            # 1/2 année
            # A la fin du Premier Semestre de l'année de sortie
            RDATSORREG = gdat$(30, 06, year(PDATSOR ))
          When Default
            RDATSORREG = PDATSOR
        Endcase

      When Default
      #-----------------------
        # Pas de régularisation
        RDATSORREG = PDATSOR
    Endcase
    #-----------------------

  Endif
  # -1 --------------------------------------------

End
#
#########################################################
Subprog CAL_REGLE_SORTIE_APPLICABLE
&     ( PMODAMT,  PPRATYP, PRGLSOR, PALWCOD, PPROEXEMLB, PPROEXEMDB, RAPPLICABLE )
#
# - Objet  : Renvoie si la règle de sortie est applicable au mode précisé pour le plan
#
#
# - Entrée : Mode d'amortissement
#            Régle de sortie
#            Régle particulière
#            Type de Prorata à appliquer (LB)
#            Type de Prorata à appliquer (DB)

# - Sortie : Booleen règle de sortie applicable
#
#   Boite noire
#
Value    Char      PMODAMT
Value    Integer   PPRATYP   : # FQ67222
Value    Integer   PRGLSOR
Value    Integer   PALWCOD
Value    Integer   PPROEXEMLB    : # Mode LB    - Type de Prorata à appliquer
Value    Integer   PPROEXEMDB    : # Mode DB    - Type de Prorata à appliquer

Variable Integer   RAPPLICABLE

  RAPPLICABLE = 0

  #-----------------------
  Case PMODAMT

    When G_DPMLP
    #-----------------------
      If ( PALWCOD = GVML_RPALOGI ) Then
        # Linéaire (logiciel 12 mois)
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Else
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRJPREC, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Pas de dotation le jour de sortie
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Endif

    When G_DPMLB
    #-----------------------
      If ( PPROEXEMLB = GVML_COPJOUR ) Then
        # Prorata en jours
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRJPREC, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Pas de dotation le jour de sortie
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Else
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Endif

    When G_DPMDB
    #-----------------------
      If ( PPROEXEMDB = GVML_COPJOUR ) Then
        # Prorata en jours
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRJPREC, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Pas de dotation le jour de sortie
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Else
        Case PRGLSOR
          When GVML_IRDEREP, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
            # Fin d'exercice précédent
            # Fin d'exercice courant
            RAPPLICABLE = 1
        Endcase
      Endif

    When G_DPMUD, G_DPMUL, G_DPMDF, G_DPMDX, G_DPMDP, G_DPMFM, G_DPMLE, G_DPMLG,
&        G_DPMPR, G_DPMSY, G_DPMDV, G_DPMPC, G_DPMPD, G_DPMDA, G_DPMDM, G_DPMTD
    # FQ55960 FQ105809
    #-------------------------
      Case PRGLSOR
        When GVML_IRDEREP, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
          # Fin d'exercice précédent
          # Fin d'exercice courant
          RAPPLICABLE = 1
      Endcase

    When G_DPMDE, G_DPMDI, G_DPMLV, G_DPMSL
    # FQ82075
    #-------------------------
      Case PRGLSOR
        When GVML_IRDEREP, GVML_IRJPREC, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
          # Fin d'exercice précédent
          # Pas de dotation le jour de sortie
          # Fin d'exercice courant
          RAPPLICABLE = 1
      Endcase

    When G_DPMIT
    #-------------------------
      # Modes pour lesquels la règle de sortie saisi s'applique toujours
      RAPPLICABLE = 1

    When G_DPMRA
    #-------------------------
      Case PRGLSOR
        When GVML_IRJPREC
          # FQ54343
          # Pas de dotation le jour de sortie
          RAPPLICABLE = 1
      Endcase

    When G_DPMRE
    #-------------------------
      # FQ67222 Modes résiduels selon type de prorata (PRATYP)
      # Pas de dotation jour de sortie applicable au résiduel jour.
      #
      Case PPRATYP
        When GVML_TPJOUR
          Case PRGLSOR
            When GVML_IRJPREC
              # FQ54343
              # Pas de dotation le jour de sortie
              RAPPLICABLE = 1
          Endcase
      Endcase

    When G_DPMSA, G_DPMUO, G_DPMLR, G_DPMDR, G_DPMCR, G_DPMSR, G_DPMUR, G_DPMML, G_DPMMD,
&        G_DPMRL, G_DPMRX, G_DPMRD, G_DPM1P, G_DPMAL, G_DPMAD, G_DPMHL, G_DPMHD
    #-------------------------
      # FQ59941 FQ67577 FQ72372 FQ77877 FQ84110 FQ84283 FQ84821
      # Modes pour lesquels la règle de sortie saisi ne s'applique jamais
      RAPPLICABLE = 0


    When G_DPMCA
    #-----------------------
      # FQ54343
      # If ( PALWCOD = GVML_RPCONCE and PRGLSOR = GVML_IRCONCE  ) Then
      If ( PALWCOD = GVML_RPCONCE and ( not([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and[F:WFAS]CCNETRTYP = GVML_NA1ERBC)  )  ) Then
       # Règle Part. "Regul/Reint Amort." & Règle de sortie de sortie "1er bien cédé de la concession"
        # Dotation calculée normalement ( 1er bien sorti de la concession)
        RAPPLICABLE = 1
      Endif

    When G_DPMTL
    #-----------------------
      # FQ105809
      Case PRGLSOR
        When GVML_IRDEREP, GVML_IRJPREC, GVML_IRDEREC, GVML_IRDERMP, GVML_IRDERMC, GVML_IRDERSP, GVML_IRDERSC
          # Fin d'exercice précédent
          # Pas de dotation le jour de sortie
          # Fin d'exercice courant
          RAPPLICABLE = 1
      Endcase


    When Default
    #-----------------------
      RAPPLICABLE = 0
  Endcase
  #-----------------------

End

#
#########################################################
Subprog CAL_DATE_FIN_AMORT_MODE_UD ( PDTDBEXI, PDTFNEXI, PDTDBAMT, PDURAMT, PTYPPRO, RDTFNAMT )
#
# - Objet  : Renvoie la date de fin d'amortissement lorsque le mode UD - Declining balance est utilisé
#            en fonction du type de prorata, de la date de début d'amortissement et d'une durée
#
#
# - Entrée :
#            Date de début d'amortissement (fichier)
#            Durée d'amortissement
#            Type de prorata
# - Sortie :
#            Date de fin d'amortissement

#   Boite noire
#
Value    Date      PDTDBEXI
Value    Date      PDTFNEXI
Value    Date      PDTDBAMT
Value    Decimal   PDURAMT
Value    Integer   PTYPPRO
Variable Date      RDTFNAMT

Local    Date      WDATE
Local    Decimal   WDURAMT
Local    Date      WDTDBAMT

  # Selon type prorata
  Case PTYPPRO
    When GVML_TPHLFY
      # -- 1/2 Année
      # Comme la 1ère dotation compte pour une 1/2 dotation annuelle et que
      # Date de fin d'amt = 1er jour du mois du Début d'Exercice "Suivant" l'Acquisition + (Durée - 0.5)
      # AU début du deuxième Semestre de l'année du début d'amortissement
      # FQ88728
      #WDTDBAMT= gdat$(01, 07, year(PDTDBAMT))
      # AU début du 2ème semestre d'acquisition
      WDTDBAMT = func GLOBB9.CAL_DAT_PLUS( PDTDBEXI , 6 , "M")
      Call CAL_DAT_FIN_SELON_DUREE ( WDTDBAMT, PDURAMT, PTYPPRO, RDTFNAMT ) From =G_GLOB9
    When GVML_TPMOIS
      # -- Mois
      # 1er jour du mois de Début d'amortissement  + Durée - un jour
      WDTDBAMT= gdat$(01, month(PDTDBAMT), year(PDTDBAMT))
      Call CAL_DAT_FIN_SELON_DUREE ( WDTDBAMT, PDURAMT, PTYPPRO, RDTFNAMT ) From =G_GLOB9
    When GVML_TPHLFM
      # -- Demi mois
      # Comme la 1ère dotation compte le 1er mois pour un 1/2 mois et que
      # Date de fin = "1er jour" du mois du début d'amortissement  + Durée + 0.5 mois - un jour
      # AU début 2ème quinzaine du Mois du début d'amortissement
      WDTDBAMT= gdat$(16, month(PDTDBAMT), year(PDTDBAMT))
      Call CAL_DAT_FIN_SELON_DUREE ( WDTDBAMT, PDURAMT, PTYPPRO, RDTFNAMT ) From =G_GLOB9
    When GVML_TPHLFQ
      # -- Demi trimestre
      # Comme la 1ère dotation compte le 1er trimstre pour un 1/2 trimestre et que
      # Date de fin = "1er jour" du deuxième 1/2 trimestre du trimestre du début d'amortissement
      #               + Durée + 0.5 trimestre - un jour
      # AU début 2ème 1/2 trimestre du Trimestre du début d'amortissement
      If    ( PDTDBAMT > gdat$(30, 09, year(PDTDBAMT)) ) Then
        WDTDBAMT= gdat$(16, 11, year(PDTDBAMT))
      Elsif ( PDTDBAMT > gdat$(30, 06, year(PDTDBAMT)) ) Then
        WDTDBAMT= gdat$(16, 08, year(PDTDBAMT))
      Elsif ( PDTDBAMT > gdat$(31, 03, year(PDTDBAMT)) ) Then
        WDTDBAMT= gdat$(16, 05, year(PDTDBAMT))
      Else
       WDTDBAMT= gdat$(16, 02, year(PDTDBAMT))
      Endif
      Call CAL_DAT_FIN_SELON_DUREE ( WDTDBAMT, PDURAMT, PTYPPRO, RDTFNAMT ) From =G_GLOB9
    When Default
      RDTFNAMT = [0/0/0]
  Endcase
End

#
#########################################################
Subprog CAL_DATE_FIN_AMORT_MODE_DF ( PDTDBAMT, PDTDBEXI, PDTFNEXE, PDURAMT, PDTFNAMT, RDTFNAMT )
#
# - Objet  : Renvoie la date de fin d'amortissement lorsque le mode DF est utilisé.
#            La date de fin d'amortissement est égale à
#            Date de début de l'exercice suivant + nombre d'année restant à amortir
#            Durée restant à amortir  =  Durée d'amortissement - Durée amortie ( exerice courant inclu)
#            Durée amortie = Date fin d'exercice courant - Début d'exercice d'acquisition
#            Les durées sont exprimées en mois puis converties en années après calcul.
#            Si le nombre d'années n'est pas entier, il est ajusté à l'année supérieure.
#
#   Attn.  : 1°) Ce calcul est aussi utilisé pour le LP avec 1er exercice décompté comme une année entière.
#            2°) Lorsque la date de fin d'amortissement n'est pas calculée, il doit rester en l'état.
#
# - Entrée :
#            Date de début d'exercice d'acquisition
#            Date de fin d'exercice
#            Date de début d'amortissement
#            Durée d'amortissement
#            Type de prorata
#            Date de fin d'amortissement fichier (Deprec lorsque la date ne peut plus être que déduite)
# - Sortie : Date de fin d'amortissement

#   Boite noire gcfc64
#
Value    Date      PDTDBAMT   : # FQ85343
Value    Date      PDTDBEXI
Value    Date      PDTFNEXE
Value    Decimal   PDURAMT
Value    Date      PDTFNAMT
Variable Date      RDTFNAMT

Local Date         WDTDBEXES
Local Decimal      WDURRES
Local Decimal      WDURENT
Local Decimal      WDURAMT
  #
  #-------------------------------
  # Début exercice suivant
  WDTDBEXES = func GLOBB9.CAL_DAT_PLUS( PDTFNEXE, 1, "D" )
  #-------------------------------

  #-------------------------------
  # Nombre d'années restant à amortir
  #        Durée d'amortissement - Durée déjà amortie à fin exercice courant
  # -- Nbre de mois amortis à fin ex. cour
  Call CAL_DAT_DIFF( PDTDBEXI, PDTFNEXE, "M", WDURENT ) From =G_GLOB9
  WDURAMT = arr( PDURAMT*12, 1)   :  # Durée à amortir  ( en mois )
  #-1 ------------------------------
  If ( WDURAMT > WDURENT ) Then
    WDURRES = (WDURAMT-WDURENT)/12  :  # Nombre d'années restant à amortir ( en mois )
    If (WDURENT >WDURAMT) Then : WDURRES = 0 : Endif
    If ( WDURRES - fix(WDURRES) <> 0 ) Then
      # Nombre d'années restant à amortir ( en année entière supérieure )
      WDURRES = fix(WDURRES)+1
    Endif
    #-------------------------------
    # Date de fin d'amortissement est égale à
    #         Début d'exercice suivant + Nombre d'années restant à amortir
    Call CAL_DAT_FIN_SELON_DUREE ( WDTDBEXES, WDURRES, GVML_TPMOIS,  RDTFNAMT ) From =G_GLOB9
  #-1 ------------------------------
  Else
    # La date de fin d'amortissement reste inchangée
    # Il faut donc imérativement la reporter systèmatiquement à la clôture.
    If (PDTFNAMT <> [0/0/0]) Then
      RDTFNAMT = PDTFNAMT
    Else
      # FQ85343
      If ( WDURENT > WDURAMT ) Then
        # Soit calcul date de fin
        RDTFNAMT = func GLOBB9.CAL_DAT_PLUS( PDTDBAMT, WDURAMT, "M" )-1
        If (RDTFNAMT <> gdat$(31,12,year(RDTFNAMT)) ) Then
          RDTFNAMT = gdat$(31,12,year(RDTFNAMT)-1)
        Endif
      Else
        RDTFNAMT = PDTFNEXE
    Endif
  Endif
  Endif
  #-1 ------------------------------

End

#
#########################################################
Subprog EXT_DATE_FIN_AMORT_SELON_MODE (
& PMODAMT, PRGLPAR, PPRATYP, PDTDBAMT, PSOC, PCNX, PDTDBEXE, PDTFNEXE, PDATMES, PDURAMT, PDTFNAMT,
& PREFPPL, PREFCON, RDTFNAMT, RTRN )
#
# - Objet  : Renvoie la date de fin d'amortissement selon mode, règle et autres paramétrages
#
#   Rem.   : Pour une utilisation externe, il faut appeler le sous-programme From GLOBB8
#                                                                            ***********
#
# - Entrée :
#            Mode d'amortissement
#            Règle particulière
#            Type de prorata (saisi)
#            Date de début d'amortissement (fichier)
#            Société
#            Contexte
#            Date de début d'exercice courant
#            Date de fin   d'exercice courant
#            Date de mise en service FQ59941
#            Durée d'amortissement (fichier)
#            Date de fin d'amortissement (fichier)
#            Référence du plan de production (UO)
#            Reference concession (RA,CA)

# - Sortie : Date de fin d'amortissement

#   Boite noire gcfc60 et suivants
#
Value    Char      PMODAMT
Value    Integer   PRGLPAR
Value    Integer   PPRATYP
Value    Date      PDTDBAMT
Value    Char      PSOC
Value    Integer   PCNX
Value    Date      PDTDBEXE
Value    Date      PDTFNEXE
Value    Date      PDATMES   : # FQ59941
Value    Decimal   PDURAMT
Value    Date      PDTFNAMT
Value    Char      PREFPPL
Value    Char      PREFCON

Variable Date      RDTFNAMT
Variable Integer   RTRN

Local Integer   BDEPOPN
Local Date      LENDDPRDAT
Local Integer   LALWCOD
Local Date      LSTRDPRDAT
Local Decimal   LDURAMT
Local Integer   LPRATYP



  # Par défaut par d'erreur
  RTRN = 0

  #-- Ouverture fichier DEPC
  BDEPOPN = 0
  If clalev([F:DEPC])=0  : Local File DEPREC     [DEPC] : BDEPOPN = 1  :  Endif
  If not ( BDEPOPN ) Then
    # [F:DEPC] déjà ouvert avant l'appel du sous-programme
    # Sauvegarde information
    LENDDPRDAT = [F:DEPC]ENDDPRDAT
    LALWCOD    = [F:DEPC]ALWCOD
    LSTRDPRDAT = [F:DEPC]STRDPRDAT
    # FQ68347 LDURAMT    = [F:DEPC]DURAMT
    LDURAMT    = [F:DEPC]DPRDUR
    LPRATYP    = [F:DEPC]PRATYP
  Endif
  [F:DEPC]ENDDPRDAT = PDTFNAMT
  [F:DEPC]ALWCOD    = PRGLPAR
  [F:DEPC]STRDPRDAT = PDTDBAMT
  [F:DEPC]DPRDUR    = PDURAMT
  [F:DEPC]PRATYP    = PPRATYP


  #-- Ouverture écran CALDIV
  If clalev([M:DIV])=0  : Local Mask CALDIV     [DIV]  :  Endif             : # Infos diverses
  If clalev([M:DIV2])=0  : Local Mask CALDIV2    [DIV2] :  Endif             : # Infos diverses  FQ77877
  [M:DIV]DATNUL    = [0/0/0]
  [M:DIV]MNTNUL    = 0
  [M:DIV]DATFMT    = "D:" + GFMDAT4

  # Lecture des contextes
  If clalev([M:CNX])=0  : Local Mask CALCNX     [CNX]  :  Endif
  [M:DIV]LVLLIB = "0.CAL_LEC_CONTEXTES" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LEC_CONTEXTES (PSOC, [M:DIV]ERROR) From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : RTRN = [M:DIV]ERROR : End : Endif

  # Exercice
  If clalev([M:FIY])=0  : Local Mask CALFIY     [FIY]  :  Endif
  [M:DIV]LVLLIB="0.CAL_LEC_EXERCICES_PERIODES"-mess(G300CPFI,GML_NCONTEXT,1): Gosub CAL_ADDLVL From =G_GLOB0
  Call CAL_LEC_EXERCICES_PERIODES ( PSOC, PCNX ) From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : Return : Endif

  # Lecture des modes, options et taux
  If clalev([M:DPM])=0  : Local Mask CALDPM     [DPM]  :  Endif
  [M:DIV]LVLLIB = "0.CAL_LEC_MODES" : Gosub CAL_ADDLVL  From =G_GLOB0
  Gosub CAL_LEC_MODES From =G_GLOB0
  If ( [M:DIV]ERROR ) Then : RTRN = [M:DIV]ERROR : End : Endif

  # Recherche du mode d'amortissement
  [M:DIV]LVLLIB = "8.CAL_LOCALISE_MODE" : Gosub CAL_ADDLVL  From =G_GLOB0
  Call CAL_LOCALISE_MODE ( PMODAMT, PDTDBAMT, PDTDBEXE, PDTFNEXE,
&        [M:DIV]INDMOD, [M:DIV]INDANNLB, [M:DIV]TXLB, [M:DIV]TX2LB, [M:DIV2]RGRPPER ) From =G_GLOB8  : # X3-54580
  If ([M:DIV]ERROR) Then :  RTRN = [M:DIV]ERROR : End : Endif

  # Type de prorata
  Call CAL_TYPE_PRORATA ( PMODAMT, PRGLPAR, PPRATYP, [M:CNX]PROWEK (PCNX-1), [M:DIV]PROEXEMDB,
&                         [M:DIV]PROEXEMLB, [M:DPM]PROTYP([M:DIV]INDMOD-1),
&        [M:DIV]TYPPRO, [M:DIV]TYPPRODAT ) From =G_GLOB8
    If ( [M:DIV]ERROR ) Then : RTRN = [M:DIV]ERROR : End : Endif

  # Exercice d'investissement
  Local Integer WINDEXE
  #  Call CAL_EXERCICE_SELON_DATE
  #&      ( PDTDBAMT, [M:DIV]TYPPRO, [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, WINDEXE ) From =G_GLOB8
  [M:DIV]PD(0)= PDTDBAMT : [M:DIV]PV(0)= [M:DIV]TYPPRO
  Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
  [M:DIV]DTDBEXI = [M:DIV]RD(1) : [M:DIV]DTFNEXI = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
  If ([M:DIV]ERROR) Then : RTRN = [M:DIV]ERROR : End : Endif

  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, PDTDBEXE, "D", [M:DIV]DTDBEXE) From =G_GLOB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= PDTDBEXE : [M:DIV]PC(0)= "D"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
  [M:DIV]DTDBEXE = [M:DIV]RD(0)
  #Call CAL_AJUST_DATE_SELON_PRORATA ( [M:DIV]TYPPRO, PDTFNEXE, "F", [M:DIV]DTFNEXE) From =G_GLOB8
  [M:DIV]PE(0)= [M:DIV]TYPPRO : [M:DIV]PD(0)= PDTFNEXE : [M:DIV]PC(0)= "F"
  Gosub GSB_CAL_AJUST_DATE_SELON_PRORATA From =G_GLOB8
  [M:DIV]DTFNEXE = [M:DIV]RD(0)

  # Date de début d'amortissement régularisée
  #--------------
  If ( [M:DPM]DPRMODTYP([M:DIV]INDMOD -1 ) = GVML_TMSTAND ) Then
    # -- Mode standard FQ59941
    Call CAL_DATE_DEB_AMT_SELON_MODE
&        ( PMODAMT, PRGLPAR, [M:DIV]DTDBEXE, PDTDBAMT, [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, PDATMES,
&          [M:DIV]PROEXEMDB, [M:DIV]PROEXEMLB, [M:DIV]RGLSIMPL, [M:DIV]TYPPRO, [M:DIV]TYPPRODAT,
&          [M:DIV]DTDBAMTREG ) From =G_GLOB8
    If ([M:DIV]ERROR) Then : RTRN = [M:DIV]ERROR : End : Endif
  #--------------
  Else
    # -- Mode libre
    # Détermination exercice d'investissement
    Local Date     WDTDBEXIS
    # Début exercice suivant l'investissement
    WDTDBEXIS  = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXI, 1, "D" )

    Call CAL_DATE_DEB_AMT_SELON_REGLE
&        ( [M:DPM]ETRDATTYP([M:DIV]INDMOD -1 ),
&          PDTDBAMT,
&          [M:DIV]DTDBEXI,
&          [M:DIV]DTFNEXI,
&          WDTDBEXIS,
&          [M:DIV]TYPPRO,
&          [M:DIV]DTDBAMTREG) From =G_GLOB7
  Endif
  #--------------
  If ([M:DIV]ERROR) Then : RTRN = [M:DIV]ERROR : End : Endif

  # Durée d'amortissement
  [M:DIV]DURAMTREG = PDURAMT

  # Récupération de la date de fin de concession (à voir si cela est nécessaire)
  If ( PREFCON <> "" ) Then
    #Call CAL_DATE_FIN_CONCESSION ( PSOC, PREFCON, [M:DIV]DTFNCON ) From =G_GLOB0
    [M:DIV]LVLLIB = "0.CAL_DATE_FIN_CONCESSION" : Gosub CAL_ADDLVL  From =G_GLOB0
    [M:DIV]PC(0)= PSOC : [M:DIV]PC(1)= PREFCON
    Gosub GSB_CAL_DATE_FIN_CONCESSION From =G_GLOB0
    [M:DIV]DTFNCON = [M:DIV]RD(0)
  Else
    [M:DIV]DTFNCON = [0/0/0]
  Endif

  # Lecture du plan de production
  If ( PREFPPL <> "" ) Then
    [M:DIV]LVLLIB = "0.CAL_LEC_PROPLN" : Gosub CAL_ADDLVL  From =G_GLOB0
    Call CAL_LEC_PROPLN ( "[M:FIY]", PREFPPL ) From =G_GLOB0
  Endif

  # FQ114113
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    ENDDPCDAT               E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  If (dim(G_SKPSTD) <= 0) Then
    Global Integer G_SKPSTD
  Endif
  G_SKPSTD = 0
  If (dim(G_ETP_GLOBI8) <=0) Then
    Global Integer G_ETP_GLOBI8
    G_ETP_GLOBI8   = find('GLOBI8',  GENTSTD(1..GNBENTREE))
  Endif
  If ( G_ETP_GLOBI8 ) Then
    GPOINT = "ENDDPCDAT" #CHECK IGNORE_LINE
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9150 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite à erreur logique
    Endif
  Endif
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # -1 --------------------------------------------
  If ( not G_SKPSTD ) Then
    #--------------------------
    # FQ59941 FQ67577 FQ82075 FQ105809
    Case PMODAMT
      When G_DPMSA, G_DPMLV, G_DPMIT, G_DPMDR, G_DPMCR
        Gosub CAL_DATE_FIN_AMORT_CAS1
      When G_DPMLP, G_DPMSL, G_DPMTL
        # FQ105809
        Gosub CAL_DATE_FIN_AMORT_CAS2
      When G_DPMDF
        Gosub CAL_DATE_FIN_AMORT_CAS3
      When G_DPMSY , G_DPMPR
        Gosub CAL_DATE_FIN_AMORT_CAS4
      When G_DPMFM, G_DPMLG, G_DPMDV, G_DPMDX, G_DPMDA, G_DPMPC,
&          G_DPMDP, G_DPMDE, G_DPMDI, G_DPMDB, G_DPMLB, G_DPMLE
        Gosub CAL_DATE_FIN_AMORT_CAS5
      When G_DPMRE
        Gosub CAL_DATE_FIN_AMORT_CAS6
      When G_DPMUO, G_DPMUR
        Gosub CAL_DATE_FIN_AMORT_CAS7
      When G_DPMCA, G_DPMRA
        Gosub CAL_DATE_FIN_AMORT_CAS8
      When G_DPMPD
        Gosub CAL_DATE_FIN_AMORT_CAS9
      When G_DPMUD, G_DPMUL, G_DPMTD
        # FQ105809
        Gosub CAL_DATE_FIN_AMORT_CAS10
      When G_DPMLR
        Gosub CAL_DATE_FIN_AMORT_CAS11
      When G_DPMSR
        Gosub CAL_DATE_FIN_AMORT_CAS12
      When G_DPMML
        Gosub CAL_DATE_FIN_AMORT_CAS13
      When Default
        RDTFNAMT = [0/0/0]
    Endcase
    #--------------------------

  Endif
  # -1 --------------------------------------------


  If not ( BDEPOPN ) Then
    # [F:DEPC] déjà ouvert avant l'appel du sous-programme
    # Restauration information
    [F:DEPC]ENDDPRDAT = LENDDPRDAT
    [F:DEPC]ALWCOD    = LALWCOD
    [F:DEPC]STRDPRDAT = LSTRDPRDAT
    [F:DEPC]DPRDUR    = LDURAMT
    [F:DEPC]PRATYP    = LPRATYP
  Endif

  RDTFNAMT = [M:DIV]DTFNAMT

End

$CAL_DATE_FIN_AMORT_CAS1
$CAL_DATE_FIN_AMORT_SA
$CAL_DATE_FIN_AMORT_LV
$CAL_DATE_FIN_AMORT_IT
$CAL_DATE_FIN_AMORT_DR
$CAL_DATE_FIN_AMORT_CR
$CAL_DATE_FIN_AMORT_1P
$CAL_DATE_FIN_AMORT_HD
  # Sans Date de Fin d'Amortissement
  # FQ84110 FQ84281
  [M:DIV]DTFNAMT = [0/0/0]
Return

$CAL_DATE_FIN_AMORT_CAS2
$CAL_DATE_FIN_AMORT_LP
$CAL_DATE_FIN_AMORT_SL
$CAL_DATE_FIN_AMORT_HL
$CAL_DATE_FIN_AMORT_TL
# FQ84281 FQ105809
#If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Date de fin d'amortissement fonction de l'indicateur 1er exercice décompté pour une année entière
  If ( [F:DEPC]ALWCOD = GVML_RPA1EXD) Then
    # 1er exercice décompté pour une année entière
    # La date de fin d'amortissement est calculée de la même manière que pour le dégressif français
    Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_LP - Décompte 1er exercice "  ) From =G_GLOB0
    # FQ85343
    Call CAL_DATE_FIN_AMORT_MODE_DF
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DTDBEXI, [M:DIV]DTFNEXE, [M:DIV]DURAMTREG, [F:DEPC]ENDDPRDAT, [M:DIV]DTFNAMT) From =G_GLOB8
  Else
    # Linéaire français : Durée en années ajoutée à la Date de Début d'Amort (fichier) moins un jour
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT) From =G_GLOB9
  Endif
Return

$CAL_DATE_FIN_AMORT_CAS3
$CAL_DATE_FIN_AMORT_DF
  # Date de fin d'amortissement pour le mode DF Dégressif français  FQ85343
  Call CAL_DATE_FIN_AMORT_MODE_DF
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DTDBEXI, [M:DIV]DTFNEXE, [M:DIV]DURAMTREG, [F:DEPC]ENDDPRDAT, [M:DIV]DTFNAMT ) From =G_GLOB8
Return

$CAL_DATE_FIN_AMORT_CAS4
$CAL_DATE_FIN_AMORT_SY
$CAL_DATE_FIN_AMORT_PR
  If ( [M:DIV]TYPPRO = GVML_TPSEMA ) Then
    # Date début cadrée sur un début de semaine + durée en semaine (cadrée sur une fin de semaine)
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS ([M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG * 52 , "W")
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, -1, "D" )
    # Prorata en mois - Ajustement à la fin de la semaine
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_DERN( [M:DIV]DTFNAMT , "W" )
  Else
    # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB9
  Endif
Return

$CAL_DATE_FIN_AMORT_CAS5
$CAL_DATE_FIN_AMORT_FM
$CAL_DATE_FIN_AMORT_LG
$CAL_DATE_FIN_AMORT_DV
$CAL_DATE_FIN_AMORT_DX
$CAL_DATE_FIN_AMORT_DA
$CAL_DATE_FIN_AMORT_DP
$CAL_DATE_FIN_AMORT_DE
$CAL_DATE_FIN_AMORT_DI
$CAL_DATE_FIN_AMORT_DB
$CAL_DATE_FIN_AMORT_LB
$CAL_DATE_FIN_AMORT_LE
$CAL_DATE_FIN_AMORT_PC
$CAL_DATE_FIN_AMORT_DM
$CAL_DATE_FIN_AMORT_RL
$CAL_DATE_FIN_AMORT_RX
$CAL_DATE_FIN_AMORT_RD
$CAL_DATE_FIN_AMORT_AL
$CAL_DATE_FIN_AMORT_AD
  # FQ55960 FQ77877 FQ84283
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Call CAL_DAT_FIN_SELON_DUREE
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB9


Return

$CAL_DATE_FIN_AMORT_CAS6
$CAL_DATE_FIN_AMORT_RE
  If ( [M:DIV]TYPPRO = GVML_TPHLFM or  [M:DIV]TYPPRO = GVML_TPHLFY or [M:DIV]TYPPRO = GVML_TPHLFQ ) Then
    # Prise en compte du passage en résiduel du Straight Line ( UL -> RM )
    # Selon type de prorata saisi avec Date de début d'amortissement (fichier) FQ88728
    Call CAL_DATE_FIN_AMORT_MODE_UD ( [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, [F:DEPC]STRDPRDAT, [F:DEPC]DPRDUR, [F:DEPC]PRATYP,
&                                     [M:DIV]DTFNAMT) From =G_GLOB8
  Else
    # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
    Call CAL_DAT_FIN_SELON_DUREE
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB9
  Endif
Return

$CAL_DATE_FIN_AMORT_CAS7
$CAL_DATE_FIN_AMORT_UO
$CAL_DATE_FIN_AMORT_UR

  If ( [F:DEPC]ENDDPRDAT = [0/0/0] ) Then
    # Date de fin d'amortissement non renseignée
    If ( [F:DEPC]DPRDUR <> 0 ) Then
      # Durée renseignée : Date fin = Date de Début + Durée en années  selon prorata
      Call CAL_DAT_FIN_SELON_DUREE
&       ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB9
    Else
      # Durée non renseignée : Date fin hérite de la date de fin du plan de production
      [M:DIV]DTFNAMT = [M:PPL]PPLENDDAT
    Endif
  Else
    # La date de fin d'amortissement est renseignée
    If ( [M:PPL]PPLENDDAT <> [0/0/0] ) Then
      # La fin de plan de production est précisée, la fin d'amort est égale à MIN(fin d'amort, fin plan prod)
      [M:DIV]DTFNAMT = min([F:DEPC]ENDDPRDAT, [M:PPL]PPLENDDAT)
    Else
      # La date de fin d'amortissement reste inchangée
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
    Endif
  Endif
Return

$CAL_DATE_FIN_AMORT_CAS8
$CAL_DATE_FIN_AMORT_CA
$CAL_DATE_FIN_AMORT_RA
  #-1 -----------------------------
  If ( [F:DEPC]DPRDUR = 0 ) Then
    #-2 -----------------------------
    If ( [F:DEPC]ENDDPRFLG = G_OUI ) Then
      # La durée d'amort. n'est pas renseignée et la fin d'amort. est forcée, la fin d'amort. est égale à min(fin concession-fin amort.)
      Local Date LDATMIN
      If ( [M:DIV]DTFNCON > [F:DEPC]ENDDPRDAT and [F:DEPC]ENDDPRDAT <> [0/0/0] ) Then
        LDATMIN = [F:DEPC]ENDDPRDAT
      Else
        LDATMIN = [M:DIV]DTFNCON
      Endif
      [M:DIV]DTFNAMT = LDATMIN
    #-2 -----------------------------
    Else
      # La durée d'amort. n'est pas renseignée et la fin d'amort. n'est pas forcée, la fin d'amort. est égale à la fin de concession
      [M:DIV]DTFNAMT   = [M:DIV]DTFNCON
    Endif
    #-2 -----------------------------
  #-1 -----------------------------
  Else
    # Détermination de la date de fin d'amortissement à partir de la durée d'amortissement
    Call CAL_DAT_FIN_SELON_DUREE
&        ( [M:DIV]DTDBAMTREG, [F:DEPC]DPRDUR, [M:DIV]TYPPRO, [M:DIV]DTFNAMT) From =G_GLOB9
    If ( [M:DIV]DTFNAMT > [M:DIV]DTFNCON and [M:DIV]DTFNCON <> [0/0/0] ) Then
      # Si la fin d'amortissement calculée est au delà de la fin de concession
      # la fin d'amortissement est ramenée à la fin de concession
      [M:DIV]DTFNAMT   = [M:DIV]DTFNCON
    Endif
  Endif
  #-1 -----------------------------
Return

$CAL_DATE_FIN_AMORT_CAS9
$CAL_DATE_FIN_AMORT_PD
  # Date de Début d'amort (régularisée pour "dotation exercice" ) + Durée en années - 1 jour
  Call CAL_DAT_FIN_SELON_DUREE
&      ( WDTDBAMTEXE, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT) From =G_GLOB9
Return

$CAL_DATE_FIN_AMORT_CAS10
$CAL_DATE_FIN_AMORT_UD
$CAL_DATE_FIN_AMORT_UL
$CAL_DATE_FIN_AMORT_TD
  # FQ88728 FQ105809
  Call CAL_DATE_FIN_AMORT_MODE_UD ( [M:DIV]DTDBEXI, [M:DIV]DTFNEXI, [F:DEPC]STRDPRDAT, [F:DEPC]DPRDUR, [M:DIV]TYPPRO,
&                                   [M:DIV]DTFNAMT) From =G_GLOB8
Return

$CAL_DATE_FIN_AMORT_CAS11
$CAL_DATE_FIN_AMORT_LR
  # FQ59941
  Call CAL_DATE_FIN_AMORT_MODE_LR
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB4RU
Return

$CAL_DATE_FIN_AMORT_CAS12
$CAL_DATE_FIN_AMORT_SR
  # FQ59941
  # Durée en années ajoutée à la Date de Début d'amortissement (régularisée) moins un jour
  Call CAL_DAT_FIN_SELON_DUREE
&      ( [M:DIV]DTDBAMTREG, [M:DIV]DURAMTREG, [M:DIV]TYPPRO, [M:DIV]DTFNAMT ) From =G_GLOB9
  # Ajout du nombre de mois d'arrêt
  [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT,  [F:DEPC]KNBMSTPDEP, "M" )
Return

$CAL_DATE_FIN_AMORT_CAS13
$CAL_DATE_FIN_AMORT_ML
  # FQ67577 FQ79813
  Call CAL_DATE_FIN_AMORT_MODE_ML
&      (  [M:DIV]PD(0), [M:DIV]PE(0), [M:DIV]PSEPLN, [M:DIV]SESFLG, [M:DIV]DTFNAMT ) From =G_GLOB4PL

Return
#
#########################################################
Funprog CAL_NUMERO_EXERCICE( PDTDBAMT, PDTDBEXE, PDTFNEXE)
# - Objet  : Renvoie le numéro d'exercices c'est-à-dire
#            l'intervalle en exercice bornes incluses
#            entre l'exercice dans lequel se situe la date début d'amortissement
#            et l'exercice passé en paramètre.
#
#
#
# - Entrée :
#            Date de début d'amortissement
#            Date de début d'exercice
#            Date de fin   d'exercice
#
# - Sortie : Numéro d'exercice
#


Value Date    PDTDBAMT
Value Date    PDTDBEXE
Value Date    PDTFNEXE
Local Integer RTRN

Local Integer LZERO : LZERO = 0
Local Integer LINDDBEXE
Local Integer LINDFNEXE
Local Integer LINDDBAMT
Local Date    LDTDBEX
Local Date    LDTFNEX
Local Integer LPOSAMT
Local Integer LPOSEXE


  #-1 -------------------------
  If ( PDTDBAMT > PDTFNEXE ) Then
    # L'amortissement du bien commence après l'exercice courant
    RTRN = 0
  #-1 -------------------------
  Else
    #-2 -------------------------
    If (func GLOBB9.CAL_DAT_INSIDE( PDTDBAMT, PDTDBEXE , PDTFNEXE , "I" )) Then
      # L'amortissement du bien commence dans l'exercice
      RTRN = 1
    #-2 -------------------------
    Else
      # Le début d'amortissement du bien est antérieur à l'exercice courant
      LINDDBAMT = func GLOBB9.CAL_LOCALISE_DAT
&                 (PDTDBAMT,[M:FIY]DATSTRFIY,[M:FIY]DATENDFIY,LZERO,[M:FIY]NB_EXE-1)
      # Indice exercice courant
      LINDDBEXE = func GLOBB9.CAL_LOCALISE_DAT
&                 (PDTDBEXE, [M:FIY]DATSTRFIY, [M:FIY]DATENDFIY, LZERO, [M:FIY]NB_EXE-1)
      #-3 -------------------------
      If (LINDDBAMT < 0 or LINDDBEXE < 0  ) Then
        # Position Début Amortissement par rapport au début de la table des exercices
        #-4 -------------------------
        If ( LINDDBAMT =  -1 ) Then
          # Le début d'amortissement du bien est antérieur au 1er exercice de la table des exercices
          # Initialisation position
          LPOSAMT = 0
          # Exercice antérieur - recherche de l'exercice
          LDTDBEXE = [M:FIY]DATSTRFIY(0)
          # >>>>>
          While ( PDTDBAMT < LDTDBEXE )
            # Incrément position
            LPOSAMT -= 1
            # Exercice Début amortissement < à début table des exercices - recherche de l'exercice
            LDTDBEXE = func GLOBB9.CAL_DAT_PLUS( LDTDBEXE, -1, "Y" )
          Wend
          # >>>>>
        #-4 -------------------------
        Elsif ( LINDDBAMT =  -2 ) Then
          # Le début d'amortissement est > au dernier exercice de la table
            # Initialisation position
            LPSOAMT = [M:FIY]NB_EXE-1
            # Exercice Début amortissement > à fin table des exercices - recherche de l'exercice
            LDTFNEXE = [M:FIY]DATENDFIY([M:FIY]NB_EXE-1)
            # >>>>>
            While ( LDTFNEXE < PDTDBAMT )
              # Incrément position
              LPOSAMT += 1
              # Début du nouvel exercice ultérieur
              LDTFNEXE = func GLOBB9.CAL_DAT_PLUS( LDTFNEXE, +1, "Y" )
            Wend
            # >>>>>
        #-4 -------------------------
        Else
            LPOSAMT = LINDDBAMT
        Endif
        #-4 -------------------------

        # Position Exercice courant par rapport au début de la table des exercices
        #-4 -------------------------
        If ( LINDDBEXE =  -1 ) Then
          # L'exercice courant est antérieur au 1er exercice de la table des exercices
          # Initialisation position
          LPOSEXE = 0
          # Exercice antérieur - recherche de l'exercice
          LDTDBEXE = [M:FIY]DATSTRFIY(0)
          # >>>>>
          While ( PDTDBEXE < LDTDBEXE )
            # Incrément position
            LPOSEXE -= 1
            # Exercice courant < à début table des exercices - recherche de l'exercice
            LDTDBEXE = func GLOBB9.CAL_DAT_PLUS( LDTDBEXE, -1, "Y" )
          Wend
          # >>>>>
        #-4 -------------------------
        Elsif ( LINDDBEXE =  -2 ) Then
          # L'exercice courant est > au dernier exercice de la table
            # Initialisation position
            LPOSEXE = [M:FIY]NB_EXE-1
            # Exercice Début amortissement > à fin table des exercices - recherche de l'exercice
            LDTFNEXE = [M:FIY]DATENDFIY([M:FIY]NB_EXE-1)
            # >>>>>
            While ( LDTFNEXE < PDTDBEXE )
              # Incrément position
              LPOSEXE += 1
              # Début du nouvel exercice ultérieur
              LDTFNEXE = func GLOBB9.CAL_DAT_PLUS( LDTFNEXE, +1, "Y" )
            Wend
            # >>>>>
        #-4 -------------------------
        Else
            LPOSEXE = LINDDBEXE
        Endif
        #-4 -------------------------

        # Numéro d'annuité
        If (LPOSAMT < 0 and LPOSEXE > 0 ) Then
          RTRN = LPOSEXE + abs(LPOSAMT) + 1
        Else
          RTRN = abs(LPOSEXE - LPOSAMT) + 1
        Endif
      #-3 -------------------------
      Else
        # Numéro d'annuité = Indice exercice - Indice début d'amortissement
        RTRN = ( LINDDBEXE - LINDDBAMT ) + 1
      Endif
      #-3 -------------------------
    Endif
    #-2 -------------------------
  Endif
  #-1 -------------------------


End RTRN

#
#########################################################
Funprog TX_ANTICIPATO_PERMIS ( PSOC, PCNT, PNATACH, PDTDBAMT, PDTDBEXE, PDTFNEXE)
#
# - Objet  : Renvoie si un taux d'amortissement exceptionnel peut être pris en compte.
#            Il peut l'être
#               uniquement dans l'exercice d'acquisition pour les biens achetés d'occasion
#               les 3 premiers exercices d'amortissement pour les bien achetés neufs.
#
#
# - Entrée :
#            Société
#            Contexte
#            Nature d'achat
#            Date de début d'amortissement
#            Date de début d'exercice courant
#            Date de fin   d'exercice courant
#
# - Sortie : Booleen
#


Value Char    PSOC
Value Integer PCNT
Value Integer PNATACH
Value Date    PDTDBAMT
Value Date    PDTDBEXE
Value Date    PDTFNEXE

Local Integer RTRN

Local Date    LCURDTDB
Local Date    LCURDTFN

Local Integer BCLOFIL   : BCLOFIL = 0
Local Integer BFIYLU

  #If ( GUSER = "MWA" ) Then :  Dbgaff : Endif


  RTRN = 0
  If ( PNATACH <> GVML_NANEUF and PNATACH <> GVML_NAOCCAS ) Then
    RTRN = 0 : End RTRN
  Endif

  #-1 -------------------------
  If ( PDTDBAMT > PDTFNEXE ) Then
    # L'amortissement du bien commence après l'exercice courant
    RTRN = 0 : End RTRN
  #-1 -------------------------
  Else
    #-2 -------------------------
    If (func GLOBB9.CAL_DAT_INSIDE( PDTDBAMT, PDTDBEXE , PDTFNEXE , "I" )) Then
      # L'amortissement du bien commence dans l'exercice courant
      RTRN = 1 : End RTRN
    #-2 -------------------------
    Else
      # A ce niveau, si le bien est d'occasion un taux d'anticipato ne peut plus être précisé
      If ( PNATACH = GVML_NAOCCAS ) Then : RTRN = 0 : End RTRN : Endif
      # L'amortissement a t'il commencé dans l' Exercice courant -1 ?
      If clalev([F:WFIS])=0 Then : Local File FISCYEAR [WFIS] : BCLOFIL = 1  :  Endif
      Filter [F:WFIS] Where CPY= PSOC and CNX= PCNT and DATENDFIY= PDTDBEXE-1
      Read [WFIS] Last : Filter [F:WFIS]
      BFIYLU = 0
      If !(fstat) Then
        BFIYLU = 1 : LCURDTDB = [F:WFIS]DATSTRFIY : LCURDTFN = [F:WFIS]DATENDFIY
      Else
        LCURDTDB = func GLOBB9.CAL_DAT_PLUS( PDTDBEXE, -1, "Y" )
        LCURDTFN = PDTDBEXE-1
      Endif
      If (func GLOBB9.CAL_DAT_INSIDE( PDTDBAMT, LCURDTDB, LCURDTFN, "I" )) Then
        # L'amortissement du bien commence dans l' Exercice courant - 1
        RTRN = 1 : End RTRN
      Endif
      # L'amortissement a t'il commencé dans l' Exercice courant -2 ?
      If (BFIYLU) Then
        Filter [F:WFIS] Where CPY= PSOC and CNX= PCNT and DATENDFIY= LCURDTDB-1
        Read [WFIS] Last : Filter [F:WFIS]
        If !(fstat) Then
          LCURDTDB = [F:WFIS]DATSTRFIY : LCURDTFN = [F:WFIS]DATENDFIY
        Else
          LCURDTDB = func GLOBB9.CAL_DAT_PLUS( LCURDTDB, -1, "Y" )
          LCURDTFN = LCURDTFN-1
        Endif
      Else
        LCURDTDB = func GLOBB9.CAL_DAT_PLUS( LCURDTDB, -1, "Y" )
        LCURDTFN = LCURDTFN-1
      Endif
      If (func GLOBB9.CAL_DAT_INSIDE( PDTDBAMT, LCURDTDB, LCURDTFN, "I" )) Then
        # L'amortissement du bien commence dans l' Exercice courant - 2
        RTRN = 1 : End RTRN
      Endif
    Endif
    #-2 -------------------------
  Endif
  #-1 -------------------------

  If (BCLOFIL) Then : Close Local File [WFIS] :  Endif


End RTRN


#
#########################################################
Funprog CAL_NUM_ANN ( PDTDBAMT, PDTDBEXE, PDTFNEXE)
# - Objet  : Renvoie le nombre d'années  qu'il a été nécéssaire
#            d'ajouter à la date de début d'amortissement pour qu'elle
#            se situe dans l'exercice passé en paramètre
#
#
# - Entrée :
#            Date de début d'amortissement
#            Date de début d'exercice
#            Date de fin   d'exercice
#
# - Sortie : Numéro d'annuité
#
#

Value Date    PDTDBAMT
Value Date    PDTDBEXE
Value Date    PDTFNEXE

Local Integer RTRN       : RTRN = 0

Local Date    LDTDBAMT


  #-1 -------------------------
  If ( PDTDBAMT > PDTFNEXE ) Then
    # L'amortissement du bien commence après l'exercice
    RTRN = 0
  #-1 -------------------------
  Else
    #-2 -------------------------
    If (func GLOBB9.CAL_DAT_INSIDE( PDTDBAMT, PDTDBEXE , PDTFNEXE , "I" )) Then
      # L'amortissement du bien commence dans l'exercice
      RTRN = 1
    #-2 -------------------------
    Else
      RTRN = 1
      LDTDBAMT = PDTDBAMT
      # Le début d'amortissement du bien est antérieur à l'exercice courant
        # >>>>>
        While ( LDTDBAMT < PDTDBEXE )
          # Incrément du n° d'annuité
          RTRN += 1
          # Ajout d'une année à la date de début d'amortissement
          LDTDBAMT = func GLOBB9.CAL_DAT_PLUS( LDTDBAMT, +1, "Y" )
        Wend
        # >>>>>
    Endif
    #-2 -------------------------
  Endif
  #-1 -------------------------


End RTRN


#
#########################################################
Subprog  CAL_TAUX_LINEAIRE (PRNDCHG, PDURAMT, RTXAMT )
#
# - Objet  : Calcul du taux linéaire
#
#            En règle générale, il est égal à 1 / Durée d'amortissement sans arrondi
#            Dans certains cas, le taux est déduit directement de la durée.
#            Durée Taux
#            6.66  0.15
#            6.67  0.15
#
#
# - Entrée :
#            Chamgement arrondi
#            Durée d'amortissement
#            Taux d'amortissement
#
# - Sortie : Taux d'amortissement
#   Boite noire gcfc70
#
#   FQ62812

Value    Integer   PRNDCHG
Value    Decimal   PDURAMT
Variable Decimal   RTXAMT

Local Integer I

  # Détermination du taux linéaire à partir de la durée
  If ( PRNDCHG = G_OUI) Then
    Case PDURAMT
      When 6.66,  6.67, 6.666, 6.6667  : RTXAMT = 0.15
      When Default      : If ( PDURAMT <> 0 ) Then
                              RTXAMT = 1/PDURAMT
                          Else
                            RTXAMT = 0
                          Endif
    Endcase
  Else
    Case PDURAMT
      When 6.66,  6.67, 6.666, 6.6667  : RTXAMT = 0.15
      When Default      : If ( PDURAMT <> 0 ) Then
                            RTXAMT = arr( 1/PDURAMT, 0.0001)
                          Else
                            RTXAMT = 0
                          Endif
    Endcase
  Endif

End


#
#########################################################
Subprog  CAL_DUREE_SELON_TAUX_LINEAIRE (PTXAMT, RDURAMT )
#
# - Objet  : Calcul de la durée selon un taux linéaire
#
#            En règle générale, il est égal à 1 / Taux.
#            arrondi à la 2ème décimale.
#            Dans certains cas, la durée est déduite directement du taux.
#            Taux   Durée
#            0.667  15
#
#
# - Entrée : Taux d'amortissement
#
# - Sortie : Durée d'amortissement
#   Boite noire gcfc70
#

Value    Decimal   PTXAMT
Variable Decimal   RDURAMT

Local Integer I


  # Détermination du taux linéaire à partir de la durée

  Case PTXAMT
    When 0.0667        : RDURAMT = 15
    When Default       : If ( PTXAMT <> 0 ) Then
                           # FQ51562
                           RDURAMT = arr( 1/PTXAMT, 0.01)
                         Else
                           RDURAMT = 0
                         Endif
  Endcase

End

#
#########################################################
Subprog  CAL_DUREE_SELON_TAUX_SL (PTXAMT, RDURAMT )
#
# - Objet  : Calcul de la durée selon un taux linéaire
#
#            En règle générale, il est égal à 1 / Taux.
#            arrondi à la 3ème décimale.
#            Dans certains cas, la durée est déduite directement du taux.
#            Taux   Durée
#            0.667  15
#
#
# - Entrée : Taux d'amortissement
#
# - Sortie : Durée d'amortissement
#   Boite noire gcfc70
#

Value    Decimal   PTXAMT
Variable Decimal   RDURAMT

Local Integer I


  # Détermination du taux linéaire à partir de la durée

  Case PTXAMT
    When 0.0667        : RDURAMT = 15
    When Default       : If ( PTXAMT <> 0 ) Then
                           # FQ51562
                           RDURAMT = arr( 1/PTXAMT, 0.001)
                         Else
                           RDURAMT = 0
                         Endif
  Endcase

End
#
#########################################################
Subprog  CAL_DUREE_RESIDUELLE (PDEBAMT, PDATDEB, PDATFIN, RRSDDUR )
#
# - Objet  : Calcul de la durée résiduelle
#
#            Elle est égale à l'intervalle [Début (exercice ou pérode), Fin d'amortissement]
#            exprimé en années arrondi à la 2ème décimale.
#
# - Entrée : Date début
#            Date fin
# - Sortie : Durée résiduelle
#

Value    Date     PDEBAMT
Value    Date     PDATDEB
Value    Date     PDATFIN
Variable Decimal  RRSDDUR

Local Date LDATDEB

  # Max de ( début d'amortissement, début exercice ou période )
  If ( PDEBAMT <> [0/0/0] and PDEBAMT > PDATDEB ) Then
    LDATDEB = PDEBAMT
  Else
    LDATDEB = PDATDEB
  Endif

  # Détermination de la durée résiduelle
  RRSDDUR = 0

  # Si la date de début reste antérieure à la date de fin
  If (LDATDEB < PDATFIN) Then
    # La durée résiduelle est égale à l'intervalle [Début - Fin] en centième d'années
    If ( day(PDATFIN+1) = day(LDATDEB) and month(PDATFIN+1) = month(LDATDEB) ) Then
      # Durée année entière si jjmm(date fin+1) = jjmm(date début)
      RRSDDUR = year(PDATFIN +1 )- year(LDATDEB)
    Else
      RRSDDUR = arr( (PDATFIN - LDATDEB + 1) / 365, 0.01)
    Endif
  Endif

End


#
#########################################################
Subprog  CAL_ARRONDI_MNT (E02MNT, E02CUR, S02MNT )
#
# - Objet  : Montant arrondi en fonction d'une devise
#
# - Entrée : Montant à arrondir
#            Devise
#
# - Sortie : Montant arrondi en fonction de la devise
#

Value    Decimal E02MNT
Value    Char    E02CUR
Variable Decimal S02MNT

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E02
Goto $DEB_CAL_ARRONDI_MNT
$GSB_CAL_ARRONDI_MNT
  # Déclaration des paramètres en entrée
  Local Decimal E02MNT         : E02MNT = [M:DIV]PV(0)
  Local Char    E02CUR         : E02CUR = [M:DIV]PC(0)
  Local Decimal S02MNT
$DEB_CAL_ARRONDI_MNT
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local    Integer E02IC

  S02MNT = E02MNT
  #---------------
  E02IC = find( E02CUR, GDEVISE(1..GNBDEV))
  If ( E02IC <> 0 ) Then
      # Arrondi en fonction de la devise
      S02MNT = arr( E02MNT, GDEVRND (E02IC) )
  Endif

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E02)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S02MNT
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Subprog  CAL_TRONCAT_MNT (E02MNT, E02CUR, S02MNT )
#
# - Objet  : Montant tronquée en fonction d'une devise
#
# - Entrée : Montant à tronquer
#            Devise
#
# - Sortie : Montant tronqué en fonction de la devise
#

Value    Decimal E02MNT
Value    Char    E02CUR
Variable Decimal S02MNT

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E02
Goto $DEB_CAL_TRONCAT_MNT
$GSB_CAL_TRONCAT_MNT
  # Déclaration des paramètres en entrée
  Local Decimal E02MNT         : E02MNT = [M:DIV]PV(0)
  Local Char    E02CUR         : E02CUR = [M:DIV]PC(0)
  Local Decimal S02MNT
$DEB_CAL_TRONCAT_MNT
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local    Integer E02IC

  S02MNT = E02MNT
  #---------------
  E02IC = find( E02CUR, GDEVISE(1..GNBDEV))
  If ( E02IC <> 0 ) Then
      # Troncature en fonction de la devise
      S02MNT = arr( E02MNT, GDEVRND (E02IC) )
      If ( abs(S02MNT) > abs(E02MNT) ) Then
        S02MNT -= GDEVRND (E02IC)
      Endif
  Else
      S02MNT = fix (E02MNT)
  Endif

#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E02)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S02MNT
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Subprog  CAL_TAUX_MODE_DF ( PRNDCHG, PDATACH, PDTFNEXE, PDTDBAMT, PDURAMT, PVARCOEDEG, RTXAMT )
#
# - Objet  : Calcul du taux d'amortissement pour le mode Dégressif Francais
#            Il est égal à : coefficient de dégressivité * (1/Durée d'amortissement)
#            Le résultat est arrondi à 4 déc.
#
# - Entrée :
#            Chamgement arrondi
#            Date d'achat
#            Début d'exercice
#            Début d'amortissement
#            Durée d'amortissement
#            Code variation coef. de dégressivité
#
# - Sortie : Taux d'amortissement DF
#
#   Boite noire gcfc72
#

# FQ51021 FQ62812
Value    Integer   PRNDCHG        : # Changement arrondi
Value    Date      PDATACH        : # Date d'achat
Value    Date      PDTFNEXE       : # Date de fin d'exercice
Value    Date      PDTDBAMT       : # Date de début d'amortissement
Value    Decimal   PDURAMT        : # Durée d'amortissement
Value    Integer   PVARCOEDEG     : # Code variation du coef. de dégressivité
Variable Decimal   RTXAMT         : # Taux d'amortissement

Local    Decimal   LCOE
Local    Decimal   LVARCOE
Local    Decimal   LTXAMT

  # Coefficient de dégressivité (avant règle particulière)
  #-1 --------------------------------
  If ( PDATACH >= [04/12/2008] and PDATACH <= [31/12/2009] ) Then
    # FQ51021
    # Pour les biens acquis dans la période [04/12/2008 - 31/12/2009]
    If ( PDURAMT > 6 ) Then
      LCOE = 2.75
    Elsif ( PDURAMT >= 5 ) Then
      LCOE = 2.25
    Else
      LCOE = 1.75
    Endif
  #-1 --------------------------------
  Elsif ( PDTDBAMT >= [01/01/2001] ) Then
    # Pour les biens acquis à compter du 01/01/2001 mais pas dans la période [04/12/2008 - 31/12/2009]
    If ( PDURAMT > 6 ) Then
      LCOE = 2.25
    Elsif ( PDURAMT >= 5 ) Then
      LCOE = 1.75
    Else
      LCOE = 1.25
    Endif
  #-1 --------------------------------
  Elsif ( PDTDBAMT >= [01/02/1996] and PDTDBAMT <= [31/01/1997] ) Then
    # Pour les biens acquis dans la période [01/02/1996 - 31/01/1997] sans dérogation
    If ( PDURAMT > 6 ) Then
      LCOE = 3.5
    Elsif ( PDURAMT >= 5 ) Then
      LCOE = 3.0
    Else
      LCOE = 2.5
    Endif
  #-1 --------------------------------
  Else
    # Pour les biens acquis avant le 01/01/2001 mais pas dans la période [01/02/1996 - 31/01/1997]
    If ( PDURAMT > 6 ) Then
      LCOE = 2.5
    Elsif ( PDURAMT >= 5 ) Then
      LCOE = 2.0
    Else
      LCOE = 1.5
    Endif
  Endif
  #-1 --------------------------------

  # Actualisation du coefficient selon règles particulières
  #---------------------------------
  Case PVARCOEDEG
    When GVML_RPENERG : LVARCOE =  0.75  : # Economie d'énergie
    When GVML_RPDRECH : LVARCOE =  0.25  : # Dédié à la recherche
    When GVML_RPMAJ10 : LVARCOE =  1.00  : # Majo 1.0 du coef dégressivité
    When Default      : LVARCOE =  0.00
  Endcase
  LCOE = LCOE + LVARCOE

  # Evaluation du taux d'amortissement
  #-1 --------------------------------
  If (  PDURAMT = 6.66 or PDURAMT = 6.67 ) Then
    # Cas particulier
    Case LCOE
    When 2.25    : LTXAMT = 0.3375
    When 2.50    : LTXAMT = 0.3750
    When 3.00    : LTXAMT = 0.4500
    When 3.50    : LTXAMT = 0.5250
    When Default : If ( PDURAMT <> 0 ) Then
                     #FQ51562 FQ62812
                     If ( PRNDCHG = G_OUI ) Then
                       LTXAMT = arr(((LCOE * 0.15)),0.0001)
                     Else
                       LTXAMT = arr(((LCOE * 0.15)),0.000001)
                     Endif
                   Else
                     LTXAMT = 0
                   Endif
    Endcase
  Else
  #-1 --------------------------------
    # Cas classique
    # Evaluation du taux dégessif
    If ( PDURAMT <> 0 ) Then
      #FQ51562 FQ62812
      If ( PRNDCHG = G_OUI ) Then
        LTXAMT = arr(((LCOE * (1./PDURAMT))),0.0001)
      Else
        LTXAMT = arr(((LCOE * (1./PDURAMT))),0.000001)
      Endif
    Else
      LTXAMT = 0
    Endif
  Endif
  #-1 --------------------------------

  # FQ96004
#  If ( PVARCOEDEG = GVML_RPBOI30 and PDTFNEXE >= [13/04/2001] and PDTFNEXE <= [31/12/2005] ) Then
#    # Majo taux 30% Bois [13/04/01-31/12/05]
#    LTXAMT = LTXAMT + 0.3
#  Endif
  If ( PVARCOEDEG = GVML_RPBOI30 ) Then
    If ( PDTFNEXE >= [13/04/2001] and PDTFNEXE <= [31/12/2005] )     Then
      # Majo taux 30% Bois [13/04/01-31/12/05]
      LTXAMT =  arr((LTXAMT * 1.3),0.0001)
    Endif
    If ( PDATACH >= [26/09/2008]  and PDATACH <= [31/12/2011] ) or
&      ( PDATACH >= [13/11/2013]  and PDATACH <= [31/12/2016] )     Then
      # Majo taux 30% Bois [13/04/01-31/12/05]
      LTXAMT =  arr((LTXAMT * 1.3),0.0001)
    Endif
  Endif

  RTXAMT = LTXAMT

End


#
#########################################################
Subprog  CAL_TAUX_MODE_DP ( PDURAMT, RTXAMT )
#
# - Objet  : Calcul du taux d'amortissement pour le mode Dégressif Portugais Mixte
#            Il est égal à : (1/Durée d'amortissement) * coefficient de dégressivité
#            Le coefficient de dégressivité varie en fonction de la durée.
#            Le résultat est arrondi à 6 déc.
#
# - Entrée :
#            Début d'exercice
#            Début d'amortissement
#            Durée d'amortissement
#            Code variation coef. de dégressivité
#
# - Sortie : Taux d'amortissement DP
#
#   Boite noire
#

Value    Decimal   PDURAMT        : # Durée d'amortissement
Variable Decimal   RTXAMT         : # Taux d'amortissement

Local    Decimal   LCOE
Local    Decimal   LTXAMT

  # Coefficient de dégressivité (avant règle particulière)
  #-1 --------------------------------
  If ( PDURAMT > 6 ) Then
    LCOE = 2.5
  Elsif ( PDURAMT >= 5 ) Then
    LCOE = 2.
  Else
    LCOE = 1.5
  Endif
  #-1 --------------------------------

  # Evaluation du taux dégessif
  If ( PDURAMT <> 0 ) Then
    If ( PDURAMT = 6.66 or PDURAMT = 6.67 ) Then
      LTXAMT = 0.3750
    Else
      LTXAMT = arr(((LCOE * (1./PDURAMT))),0.0001)
    Endif
  Else
    LTXAMT = 0.
  Endif

  RTXAMT = LTXAMT

End


#
#########################################################
Subprog  CAL_TAUX_MODE_DE ( PDURAMT, RTXAMT )
#
# - Objet  : Calcul du taux d'amortissement pour les modes Dégressifs Espagnols
#            Il est égal à : (1/Durée d'amortissement) * coefficient de dégressivité
#            Le coefficient de dégressivité varie en fonction de la durée.
#            Le résultat est arrondi à 6 déc.
#
# - Entrée :
#            Début d'exercice
#            Début d'amortissement
#            Durée d'amortissement
#            Code variation coef. de dégressivité
#
# - Sortie : Taux d'amortissement DE
#
#   Boite noire
#


Value    Decimal   PDURAMT        : # Durée d'amortissement
Variable Decimal   RTXAMT         : # Taux d'amortissement

Local    Decimal   LCOE
Local    Decimal   LTXAMT


  # Coefficient de dégressivité (avant règle particulière)
  #-1 --------------------------------
  If ( PDURAMT >= 8 ) Then
    LCOE = 2.5
  Elsif ( PDURAMT >= 5 ) Then
    LCOE = 2.
  Else
    LCOE = 1.5
  Endif
  #-1 --------------------------------

  # Evaluation du taux dégessif
  If ( PDURAMT <> 0 ) Then
    If ( PDURAMT = 6.66 or PDURAMT = 6.67 ) Then
      LTXAMT = 0.3000
    Else
      LTXAMT = arr(((LCOE * (1./PDURAMT))),0.0001)
    Endif
  Else
    LTXAMT = 0.
  Endif

  RTXAMT = LTXAMT

End

#
#########################################################
Subprog  CAL_TAUX_MODE_RD ( PDURAMT, RTXAMT, RTXARR )
#
# - Objet  : Calcul du taux d'amortissement pour le mode Dégressif Roumain FQ77877
#
# - Entrée :
#            Durée d'amortissement
#
# - Sortie : Taux d'amortissement
#
#   Boite noire
#
Value    Decimal   PDURAMT        : # Durée d'amortissement
Variable Decimal   RTXAMT         : # Taux d'amortissement
Variable Decimal   RTXARR         : # Taux d'amortissement arrondi

Local    Decimal   LCOE

  # Coefficient de dégressivité
  #-1 --------------------------------
  If ( PDURAMT > 10 ) Then
    LCOE = 2.5
  Elsif ( PDURAMT > 5 ) Then
    LCOE = 2.
  Else
    LCOE = 1.5
  Endif
  #-1 --------------------------------

  # Evaluation du taux dégessif
  If ( PDURAMT <> 0 ) Then
    RTXAMT = LCOE * (1./PDURAMT)
    RTXARR = arr(RTXAMT,0.000001)
  Else
    RTXAMT = 0.
    RTXARR = 0.
  Endif


End

