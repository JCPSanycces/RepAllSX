#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################
# DOSMAJ32 : Mises à jour à effectuer lors du passage à la version 160 (Release 32)
# moulinette avant la version V6.2
#################################################################################
# moulinette avant la Release 32 si necessaire
##################################################################################
# Issue 106947 - 20151105 by LD : Migration of historic folder

Subprog AMAJ
#----------------------------------------#
#       Avant mise à jour                #
#----------------------------------------#
Onerrgo ERREUR

# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH
WPATCH = 0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

###########################################
# module tiers
# MOULINETTE EN AVANT maj
# A CAUSE DU MOTEUR moins tolerant sinon valid gpc ne passera pas
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(13) = 2
          If WPATCH < 11
              Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM014
          Endif
      Endif
  Endif
Endif

Onerrgo
End

###################################################################################
Subprog MAJ
#----------------------------------------#
# Après mise à jour
#----------------------------------------#

Onerrgo ERREUR
# recupération dernier patch installé chez le client
# lecture table APATCH du dossier en cours de validation
Local Char WVERSION (5)
Local Shortint WPATCH, ZOK
WPATCH = 0
ZOK=0
Raz WVERSION

If clalev([F:ZAP])=0  : Local File =[F:ADS]DOSSIER+".APATCH" [ZAP]  : Endif
If clalev([F:ZAX])=0  : Local File APATCH [ZAX]  : Endif

Filter [ZAP] Where TYP = "P"
Read [ZAP] Last
If fstat
 [F:ZAP]PATNUM = 0
Endif
Filter [ZAP]

Filter [ZAX] Where TYP = "P"
Read [ZAX] Last
If fstat
    [F:ZAX]PATNUM = 0
Else

Endif
Filter [ZAX]

# recuperation du dernier numéro de patch du dossier a valider et du dossier X3
WPATCH = [F:ZAP]PATNUM
WVERSION = [F:ZAP]RELEASE

Close Local File

If left$(WVERSION,3) = "1.3"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.4"
    WPATCH =0
Endif
If left$(WVERSION,3) = "1.5"
    WPATCH =0
Endif

###########################################################
# a voir pour mieux faire......................

Call MAJ      From SUPMAJ32     : # Moulinettes Superviseur


###########################################
# module tronc commun
# pas de test du module
###########################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If WPATCH < 6
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITC30
      Endif
      If WPATCH < 9
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITC33
         If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
          Call UTI_MOUL([F:ADS]DOSSIER) From UTITRS003
         Endif
      Endif
      If WPATCH < 11
         Call UTI_MOUL([F:ADS]DOSSIER) From UTITC35
      Endif
  Endif
Endif

###########################################
# module immos -- a faire uniquement sur la v6.1 vers la v6.2
############################################
If left$(WVERSION,3) = "1.6"
    If [F:ADS]MODULE(13) = 2
        If WPATCH < 6
            Call UTI_MOUL([F:ADS]DOSSIER) From UPROPLN
        Endif
        If WPATCH < 7
            Call UTI_MOUL([F:ADS]DOSSIER) From UUCCNACT
            Call UTI_MOUL([F:ADS]DOSSIER) From UUAOBCCN
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM012
            Call UTI_MOUL([F:ADS]DOSSIER) From UUAOBTPE
            Call UTI_MOUL([F:ADS]DOSSIER) From UUINIPARMIS01
        Endif
        If WPATCH < 9
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM013
        Endif
        If WPATCH < 11
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM015
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM016
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM03
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM018
            Call UTI_MOUL([F:ADS]DOSSIER) From UTIIMM017
        Endif
    Endif
Endif

###########################################
# module achats
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(5)=2
          If WPATCH < 7
              Call UTI_MOUL([F:ADS]DOSSIER) From UUACHV62
          Endif
      Endif
      If WPATCH < 9
           Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH19
      Endif
      If [F:ADS]MODULE(5)=2
          If WPATCH < 11
              Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH21
              Call UTI_MOUL([F:ADS]DOSSIER) From UTIACH23
          Endif
      Endif
  Endif
Endif

###########################################
# module ventes
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(4)= 2
          If WPATCH < 11
              Call UTI_MOUL([F:ADS]DOSSIER) From UTIVEN621
          Endif
      Endif
  Endif
Endif

###########################################
# MODULE stock
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
  If left$(WVERSION,3) = "1.6"
      If [F:ADS]MODULE(6)=2
         If WPATCH < 7
              Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO12
         Endif
      Endif
      If WPATCH < 11
           Call UTI_MOUL([F:ADS]DOSSIER) From UTISTO14
      Endif
  Endif
Endif

###########################################
# MODULE gpao
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 111795 - 2015-10-15 by GH : To be checked
    If left$(WVERSION,3) = "1.6"
       If WPATCH < 6
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA18
       Endif
       If WPATCH < 7
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA19
       Endif
       If WPATCH < 11
                Call UTI_MOUL([F:ADS]DOSSIER) From UTIGPA21
       Endif
    Endif
Endif

###########################################
# module tiers
############################################
If [F:ADS]MODULE(2)= 2 & func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        If WPATCH < 7
           Call UTI_MOUL([F:ADS]DOSSIER) From UUTITRS03
           Call UTI_MOUL([F:ADS]DOSSIER) From UTITRS001
        Endif
        If WPATCH < 11
           Call UTI_MOUL([F:ADS]DOSSIER) From UUTITRS04
           Call UTI_MOUL([F:ADS]DOSSIER) From UUTITRS05
        Endif
Endif

###########################################
# module compta
############################################
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  If WPATCH < 7
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT20
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT21
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT22
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT30
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT24
  Endif
  If WPATCH < 8
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT25
  Endif
  If WPATCH < 9
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT27
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT42
  Endif
  If WPATCH < 11
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT43
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT41
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT23
        Call UTI_MOUL([F:ADS]DOSSIER) From UTICPT44
  Endif
Endif

###########################################
# module action co
############################################
# Issue 106947
# To do if historic folder
#If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
# End issue 106947
  If WPATCH < 7
       Call UTI_MOUL([F:ADS]DOSSIER) From UTICRM01
       Call UTI_MOUL([F:ADS]DOSSIER) From UTITC32
  Endif

# Issue 106947
# Not to do if historic folder
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0 # Issue 108760 - 2015-06-12 by SR : To be checked
# End issue 106947
  If left$(WVERSION,3) = "1.6"
        If WPATCH < 6
              Call UTI_MOUL([F:ADS]DOSSIER) From UTITC29
        Endif
        If WPATCH < 7
              Call UTI_MOUL([F:ADS]DOSSIER) From UTITC31
        Endif
  Endif
Endif

Onerrgo
End
###################################################################################
###################################################################################
###################################################################################
$ERREUR
Call ECR_TRACE(errp-"("+num$(errl)+")"-mess(6,123,1)-":"-num$(errn)-errmes$(errn)-errm,1) From GESECRAN
# Erreur
Resume

