#<AdxTL>@(#)4.0.0.0 $Revision$
#------------------------------------------------------------------------
# SUBPPCT
# --- génération du traitement de recherche de ce tarif WATxxxxxx
#------------------------------------------------------------------------
# Type de tarif 1 = Normal / 2 = Groupé / 3 = Interdit / 4 = Composant
#------------------------------------------------------------------------
# Issue 122499 - 20170505 by LD : Grouped price list priority in a modification context

$GEN_TRT
Local Char NOMTRT(GLONAVA),FICTRT(GDIMFIC),TEX(100)(0..3),INDN
Local Char    ABR_XPL  (5)              : # Int-societe : Abr. table lignes tarifs (SPL ou PPL)
Local Integer IX, PASSAGE
Local Integer TESTUOM
Local Integer ATYOPEN, AMZOPEN, ACVOPEN, NBRCOLONNE
Local Char    FORMULEPRI (250)
Local Char    AMZ_CODTYP  (5) (0..10)   : # type donnees prix et frais/remises
Local Char    ATY_FORTYP (50) (0..10)   : # format dur type de donnee

NOMTRT="WAT"+num$([F:PPC]PLI)
FICTRT=filpath("TRT",NOMTRT,"src",APPLI)

If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : ATYOPEN=1 : Endif
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : AMZOPEN=1 : Endif
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : ACVOPEN=1 : Endif

# Issue 121765 - 2017-03-24 by SR : Retrieving the dimension of PPR data type
Local Shortint WLONPPR
Read [ATY] CODTYP="PPR"  : If fstat  Raz [F:ATY] : [F:ATY]LNGTYP=2 : Endif
WLONPPR=[F:ATY]LNGTYP
# End issue 121765

#--- Inter-societes : table des lignes tarifs
If [F:PPC]PLIBPRCNR=2
       ABR_XPL="SPL"
  Else ABR_XPL="PPL"
Endif

#--- Recherche du nombre de colonnes actives dans le code activite PPR
Read [ACV]CODACT="PPR"
NBRCOLONNE=[F:ACV]DIME
If fstat : NBRCOLONNE=0 : Endif
If ACVOPEN=1 : Close Local File [ACV] : Endif

#--- Recherche du type de donnee et du format du prix et colonnes frais/remise
#-   type de donnee par defaut MD5
For IX=0 To dim(AMZ_CODTYP)-1 : AMZ_CODTYP(IX)="MD5" : Next IX
#-   type de donnee du prix
Read [AMZ]CODE="WA1"+num$([F:PPC]PLI)+"1";"PRI"
If !fstat
   AMZ_CODTYP(0)=[F:AMZ]CODTYP
   If [F:AMZ]LONG>0 : ATY_FORTYP(0)=num$([F:AMZ]LONG) : Endif
Endif
#-   type de donnee frais/remises
For IX=1 To 9
    Read [AMZ]CODE="WA1"+num$([F:PPC]PLI)+"1";"XFRAREM"+num$(IX)
    If !fstat
       AMZ_CODTYP(IX)=[F:AMZ]CODTYP
       If [F:AMZ]LONG>0 : ATY_FORTYP(IX)=num$([F:AMZ]LONG) : Endif
    Endif
Next IX
#-   stockage du format (ou de la variable contenant le format)
For IX=0 To dim(AMZ_CODTYP)-1
    If ATY_FORTYP(IX)=""
       Read [ATY] CODTYP=AMZ_CODTYP(IX)
       If !fstat : ATY_FORTYP(IX)=[F:ATY]FORTYP : Else : ATY_FORTYP(IX)="12.4#" : Endif
       If instr(1,ATY_FORTYP(IX),"GDEVFMT") : ATY_FORTYP(IX)="=[F:TCU]CURFMT1" : Endif
    Endif
Next IX

Openo FICTRT,0
adxifs=""
adxirs=chr$(10)
Wrseq "#<AdxT"+GADOVERS+">@(#)%|%","Gén.traitement tarif "+[F:PPC]PLI
Wrseq "#-----------------------------------------------------------------"
Wrseq "# WAT";[F:PPC]PLI;"                                            ";format$(GFMD,date$)
Wrseq "#-----------------------------------------------------------------"
Wrseq "Subprog TARIF(TRAIT,DAT,QTY,UOM,CHGTYP,CUR,PRITYP,VAT,"
Wrseq "&             PIO,PARAM_T,MONTANT,MOTIF,PRIORITE,PLI,PLICRD,PLILIN,"
Wrseq "&             FOCITMREF,FOCQTY,FOCUOM,FOCMOTIF,"
Wrseq "&             PLISTRDAT,PLIENDDAT,INTERDIT)"
Wrseq "#          zones de link"
Wrseq "Value    Char     TRAIT              : # type de traitement"
Wrseq "Value    Date     DAT                : # date de commande"
Wrseq "Value    Decimal  QTY                : # qté commandée"
Wrseq "Value    Char     UOM                : # unité"
Wrseq "Value    Integer  CHGTYP             : # type de cours"
Wrseq "Value    Char     CUR                : # devise d'appel"
Wrseq "Value    Integer  PRITYP             : # type ht/ttc du client"
Wrseq "Value    Char     VAT () (0..2)      : # code taxes"
Wrseq "Value    Shortint PIO                : # priorité du tarif"
Wrseq "Variable Char     PARAM_T ()   (0..) : # parametres complementaires"
Wrseq "Variable Decimal  MONTANT    (0..10) : # valeur(prix+remises+com)"
Wrseq "Variable Shortint MOTIF      (0..10) : # motif (prix+remises+com)"
Wrseq "Variable Shortint PRIORITE   (0..10) : # prior (prix+remises+com)"
Wrseq "Variable Char     PLI     () (0..10) : # code du tarif"
Wrseq "Variable Char     PLICRD  () (0..10) : # code de la fiche"
Wrseq "Variable Integer  PLILIN     (0..10) : # no. ligne de la fichie"
Wrseq "Variable Char     FOCITMREF () (0..) : # article gratuit"
Wrseq "Variable Decimal  FOCQTY       (0..) : # qté gratuite"
Wrseq "Variable Char     FOCUOM ()    (0..) : # unité gratuité"
Wrseq "Variable Shortint FOCMOTIF     (0..) : # unité gratuité"
Wrseq "Variable Date     PLISTRDAT          : # date début validité"
Wrseq "Variable Date     PLIENDDAT          : # date fin   validité"
Wrseq "Variable Libelle  INTERDIT           : # 1 si interdit"

Wrseq ""
Wrseq "Local    Char     CODENTPNT (3)      : # Code point entree"

Case [F:PPC]PLITYP
  When 1,4   Wrseq "Local    Shortint TACHE (0..11)      : # traitements a effectuer ?"
Endcase
# Issue 121765 - 2017-03-27 by SR : Dimension XPRIREN according to PPR data type
Case [F:PPC]PLITYP
  When 1,2,4 Wrseq "local    Char     XPRIREN ("+num$(WLONPPR)+")"  : # recup. motif"
             #Wrseq "local    Char     XPRIREN (2)        : # recup. motif"
             Wrseq "local    Integer  WPRIREN            : # recup. motif"
             Wrseq "local    Char     XPRITYP (1)        : # recup. type prix"
             Wrseq "local    Integer  WPRITYP            : # recup. type prix"
             Wrseq "Local    Integer  WMODULE            : # module"
             Wrseq "Local    Char     WPLI    (10)       : # code tarif"
             Wrseq "Local    Decimal  COEFDEVISE         : # coef.conv. devise"
             Wrseq "Local    Decimal  COEFUNITE          : # coef.conv. unite"
             Wrseq "Local    Decimal  COEFPOURN          : # coef. si tarif pour n"
             Wrseq "Local    Decimal  WFOCQTYMIN         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCQTYBKT         : # calcul gratuits : tranche qte"
             Wrseq "Local    Decimal  WFOCAMTMIN         : # calcul gratuits : tranche prix"
             Wrseq "Local    Decimal  WFOCAMTBKT         : # calcul gratuits : tranche prix"
             Wrseq "Local    Decimal  WMANDEC            : # manoeuvre decimal"
             Wrseq "Local    Integer  WRET               : # code retour"
            #Wrseq "Local    Decimal  CLCAMT1            : # Montant1 pour taxe suivant formule"
            #Wrseq "Local    Decimal  CLCAMT2            : # Montant2 pour taxe suivant formule"
             Wrseq "local    decimal  CLCAMT(1..7)       : # Montants 1-7 pour taxe suivant formule"
             Wrseq "Local    Char     APDC_CUR (5)       : # Arrondi : Code devise"
             Wrseq "Local    Char     APDC_FMT (50)      : # Arrondi : Format sous forme 12.4#"
             Wrseq "Local    Decimal  APDC_RND           : # Arrondi : Code arrondi pour instruction arr"
Endcase
Case [F:PPC]PLITYP
  When 2     Wrseq "Local    Shortint SELGRP (0..[M]NBLIG) : # flag sélection de la ligne"
             Wrseq "Local    Shortint UPDGRP (0..[M]NBLIG) : # flag maj ligne par ce tarif"
             Wrseq "Local    Shortint NLD                : # = nolign boucle primaire (A)"
             Wrseq "Local    Shortint NLG                : # = nolign boucle secondaire (B)"
             Wrseq "                                       #   (recherche lignes de meme criteres que NLD)"
             Wrseq "Local    Char     FOCUPDTST (50) (0..dim(FOCITMREF)) : # pour m.a.j. des gratuits "
             Wrseq "Local    Integer  SAVNOLIGN          : # sauvegarde de nolign"
             Wrseq "local    Decimal  CUMQTY             : # cumul qté des lignes"
             Wrseq "local    Decimal  CONVQTY            : # qté après les coeff"
             Wrseq "local    Decimal  CUMAMT             : # cumul mt des lignes"
             Wrseq "local    Decimal  CONVPRI            : # prix après coeff"
             Wrseq "Local    Char     WCRIT (GLONPPX)    : # concaténation critères"
             Wrseq "Local    Integer  UPDNULPRI          : # groupes : flag modif prix nul"
Endcase
If [F:PPC]PLITYP=2
  Wrseq "If dim(GPPLXGRP)<0 : Global Shortint GPPLXGRP : Endif"
  Wrseq "UPDNULPRI="+num$([F:PPC]UPDNULPRI)
Endif
Case [F:PPC]PLITYP
  When 1,2,4 Wrseq "#           initialisations"
             Wrseq "XPRIREN='"+num$([F:PPC]PRIREN)+"' : WPRIREN=val(XPRIREN)"
             Wrseq "XPRITYP='"+num$([F:PPC]PRITYP)+"' : WPRITYP=val(XPRITYP)"
             Wrseq "WMODULE=4                            : # Module Achat"
             Wrseq "WPLI='"+[F:PPC]PLI+"'"
             Wrseq "COEFDEVISE=1 : COEFUNITE=1 : COEFPOURN=1"
Endcase
Wrseq "INTERDIT=0"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:PPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : End : Endif"
 Endif
Next I

Wrseq ""
Wrseq "# Application des tarifs Hors groupe / Groupe"
Wrseq "# Si [F:PPK]PLIBPRCNR=3 application de tous les tarifs (Hors groupe et Groupe)"
Wrseq "If dim([F:PPK]PLIBPRCNR)<=0 | [F:PPK]PLIBPRCNR<>3"
Wrseq "    # Application des tarifs Hors groupe ou Groupe en fonction des flags intersociété et intersite"
Wrseq "    # Tarif concernant les tiers ( ";
Wrseq mess([F:PPC]PLIBPRCNR,2210,1);
Wrseq " )"
Wrseq "    If dim([F:PPK]BETCPY)>0 & dim([F:PPK]BETFCY)>0"
If [F:PPC]PLIBPRCNR=1
   Wrseq "       If [F:PPK]BETCPY=2 | [F:PPK]BETFCY=2 : End : Endif"
Endif
If [F:PPC]PLIBPRCNR=2
   Wrseq "       If [F:PPK]BETCPY<>2 & [F:PPK]BETFCY<>2 : End : Endif"
Endif
Wrseq "    Endif"
Wrseq "Endif"

Wrseq ""
Wrseq "# Faut-il ouvrir le fichier tarif ?"
If [F:PPC]PLIBPRCNR=2
        Wrseq "If clalev([F:SPL])<=0 : Local File SPRICLIST : Endif"
  Else  Wrseq "If clalev([F:PPL])<=0 : Local File PPRICLIST : Endif"
Endif
If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : ouverture autres fichers"
Wrseq "If clalev([F:PPK])<=0 : Local File PPRICLINK [PPK] : Endif"
Wrseq "If clalev([F:ITV])<=0 : Local File ITMMVT    [ITV] : Endif"
Wrseq "If clalev([F:ITP])<=0 : Local File ITMBPS    [ITP] : Endif"
Wrseq "If clalev([F:ITC])<=0 : Local File ITMCOST   [ITC] : Endif"
Endif

Wrseq ""
Wrseq "If PLI(0)='*SIMU*'    : # Pour simulation chgt toutes les lignes utilisable"
Wrseq "  Gosub CONSULTATION"
Wrseq "  End"
Wrseq "Endif"
Wrseq ""

Case [F:PPC]PLITYP
  When 1 : Gosub TR_NORMAL   : # Tarif normal
  When 2 : Gosub TR_GROUPE   : # Tarif groupe
  When 3 : Gosub TR_INTERDIT : # Tarif interdit
  When 4 : Gosub TR_NORMAL   : # Tarif composant (idem normal)
Endcase
Wrseq "#-----------------------------------------------------------------"

# Génération du traitement à la ligne du tarif groupe
If [F:PPC]PLITYP=2 : Gosub TR_GRPLIG : Endif
# Génération traitement erreur si prix par coefficient
If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
  Wrseq ""
  Wrseq "$ERR_PRI"
  Wrseq "GERR=2"
  Wrseq "GMESSAGE = mess(15,197,1)+': '+[F:";ABR_XPL;"]PLI+'  '+";
  If [F:PPC]PRIPRO=4
    Wrseq "mess(16,197,1)+'\'+";
  Endif
  If [F:PPC]PRIPRO=5
    Wrseq "mess(17,197,1)+'\'+";
  Endif
  Wrseq "mess(65,106,1)"
  If [F:PPC]PRIPRO=4
    Wrseq "[F:";ABR_XPL;"]PRI=0"
  Endif
  If [F:PPC]PRIPRO=5
    Wrseq "CONVPRI=0"
  Endif
  Wrseq "Resume"
Endif

Gosub FORMAT_ARRONDI    : # constitution de l'arrondi pour l'instruction arr
Gosub TYPE_CRITERES     : # Saisie des tarif : savoir si type de donnée interne est alpha ou num
Gosub FILTRE_CRITERES   : # consultation tarif : filtre complementaire des lignes d'une fiche
Gosub CONSULTATION      : # consultation tarif
Gosub INI_IMPORT        : # traitement d'init de la classe F lors de l'import

Wrseq "#-----------------------------------------------------------------"

Openo

#--- Validation du traitement généré
Call VALID("TRT", NOMTRT,APPLI,OK) From VALMSKSUB
If !OK  GOK=0 : Endif

#--- Fermeture
If ATYOPEN=1 : Close Local File [ATY] : Endif
If AMZOPEN=1 : Close Local File [AMZ] : Endif

Return

#------------------------------------------------------------------------
# Génération de l'instruction Filter (suivant critères et conditions)
#------------------------------------------------------------------------
$LE_FILTRE
Gosub LE_FILTRE_BIS : Return


Wrseq ""
Wrseq "CODENTPNT='T01' : Gosub PE_TARIFS From TRTPRICE"
Wrseq ""

Wrseq "# Lecture des tarifs"
Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
Wrseq "&  & [L]DAT>=PLISTRDAT & [L]DAT<=PLIENDDAT"
If [F:PPC]UOMCNVFLG=1 & ZZ(8)=1
  Wrseq "&  & UOM=[L]UOM"
  If ZZ(9)=1
    Wrseq "&  & [L]QTY>=MINQTY & [L]QTY<=MAXQTY"
  Endif
Endif
If [F:PPC]CURCNVFLG=1 & SAISIEDEV=1
  Wrseq "&  & CUR=[L]CUR"
Endif
Wrseq "&    Order by Key ";ABR_XPL;"1"
Return

#------------------------------------------------------------------------
$LE_FILTRE_BIS

Wrseq "Local Char CRITERE (250)"
Wrseq "Local Char CRITSUP (250)"
Wrseq "CRITSUP='1=1'"
Wrseq ""

Wrseq "CRITERE = 'PLICRI="+chr$(34)+"'"
For I=0 To 4
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "CRITERE += num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'"
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "CRITERE += num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'"
     Else
        Wrseq "CRITERE += num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'"
     Endif
  Else
     Wrseq "CRITERE +='~'"
  Endif
Next
Wrseq "CRITERE += '"+chr$(34)+"'"

Wrseq "CRITERE -= '& [L]DAT>=PLISTRDAT & [L]DAT<=PLIENDDAT'"

If [F:PPC]UOMCNVFLG=1 & ZZ(8)=1
  Wrseq "CRITERE -= '& UOM=[L]UOM'"
  If ZZ(9)=1
    Wrseq "CRITERE -= '& [L]QTY>=MINQTY & [L]QTY<=MAXQTY'"
  Endif
Endif
If [F:PPC]CURCNVFLG=1 & SAISIEDEV=1
  Wrseq "CRITERE -= '& CUR=[L]CUR'"
Endif

Wrseq ""
Wrseq "CODENTPNT='T01' : Gosub PE_TARIFS From TRTPRICE"
Wrseq ""

Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"+" & evalue(CRITERE) & evalue(CRITSUP)"
Wrseq "&    Order by Key ";ABR_XPL;"1"

Return

#------------------------------------------------------------------------
# Tarif normal : génération du traitement (utilisé pour composants)
#------------------------------------------------------------------------
$TR_NORMAL
If [F:PPC]ATICNVFLG=1
  Wrseq "# Si le tarif n'est pas bon (HT/TTC), on s'arrête"
  Wrseq "If PRITYP<>WPRITYP : End : Endif"
Endif

Wrseq "# On teste le remplissage effectue"
Wrseq "Raz TACHE"

# Prix
If [F:PPC]PRIPRO>1
  Wrseq "TACHE(0)=(MOTIF(0)=0 | PRIORITE(0)=PIO)"
Endif
# Remises
For I=0 To NBRCOLONNE-1
  If find([F:PPC]DISCRGPRO(I),1,3)
    INDN=num$(I+1)
    Wrseq "TACHE("+INDN+")=(MOTIF("+INDN+")=0 | PRIORITE("+INDN+")=PIO)"
  Endif
Next I

# Coeff comm inexistant pour les achats

# Gratuits
If [F:PPC]FOCPRO=2 | [F:PPC]FOCPRO=3
Wrseq "TACHE(11)=(FOCQTY=0)"
Endif

Wrseq "# Toutes les colonnes sont garnies ?"
Wrseq "If sum(TACHE)=0 : End : Endif"

# Le filtre
Gosub LE_FILTRE

# La boucle des enregistrements lus
Wrseq "For [";ABR_XPL;"]"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
If ABR_XPL="SPL"
   Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
Else
   Wrseq "  If [F:PPL]UOM='*' : [F:PPL]UOM=[F:ITM]PUU : Endif"
Endif
Wrseq "  WFOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN"
Wrseq "  WFOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT"

# On détermine le conversions (unite/devise/pour n)
Raz TEX
ICONV=0
If [F:PPC]PRIPRO=3
  Wrseq "# Prix pour N articles"
  Wrseq "  If [F:";ABR_XPL;"]PRIDIV<>0 : COEFPOURN=[F:";ABR_XPL;"]PRIDIV : Endif"
  TEX(2)="/COEFPOURN" : ICONV=1
Endif
If [F:PPC]UOMCNVFLG=2
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:";ABR_XPL;"]UOM<>UOM"
  Wrseq "    WMANDEC=[F:";ABR_XPL;"]MINQTY"
  Wrseq "    Call PCAL_QTY (WMANDEC,[F:";ABR_XPL;"]UOM,WMANDEC,UOM,[F:ITM]ITMREF,[F:BPS]BPSNUM,2,"
  Wrseq "&                 COEFUNITE) From TRTACHQTE1"
  Wrseq "    If COEFUNITE=0 : COEFUNITE=1 : Endif"
  Wrseq "    [F:";ABR_XPL;"]MINQTY=[F:";ABR_XPL;"]MINQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]MAXQTY=[F:";ABR_XPL;"]MAXQTY/COEFUNITE"
  If [F:PPC]FOCPRO>1
    Wrseq "# Tarif normal mini et seuil toujours en qte"
    Wrseq "# Conversion conditions gratuité (pas d'arrondi)"
    Wrseq "    [F:";ABR_XPL;"]FOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN/COEFUNITE"
    Wrseq "    [F:";ABR_XPL;"]FOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT/COEFUNITE"
  Endif
  If [F:PPC]FOCPRO=2
    Wrseq "# Conversion qte gratuite sur le meme article (arrondi)"
    Wrseq "    [F:";ABR_XPL;"]FOCQTY=[F:";ABR_XPL;"]FOCQTY/COEFUNITE"
    Wrseq "    Call QTEARR ([F:";ABR_XPL;"]FOCQTY,UOM) From TRTDIV"
  Endif
  TEX(1)="*COEFUNITE" : ICONV=1
Wrseq "  Endif"
  If ZZ(9)=1
    Wrseq "  If [F:";ABR_XPL;"]MINQTY>QTY | [F:";ABR_XPL;"]MAXQTY<QTY : Goto TAR_SUIVANT : Endif"
  Endif
#--- Issue  105410
Else
  If ZZ(9)=1
    Wrseq "  If [F:";ABR_XPL;"]UOM=UOM"
    Wrseq "    If [F:";ABR_XPL;"]MINQTY>QTY | [F:";ABR_XPL;"]MAXQTY<QTY : Goto TAR_SUIVANT : Endif"
    Wrseq "  Else"
    Wrseq "    Goto TAR_SUIVANT"
    Wrseq "  Endif"
  Endif
#---
Endif

If [F:PPC]CURCNVFLG=2
  Wrseq "# Conversion devise"
  Wrseq "  If [F:";ABR_XPL;"]CUR<>CUR"
  Wrseq "    Call CONVERT([F:";ABR_XPL;"]CUR,CUR,GLOCALDEV,CHGTYP,DAT,1000000000000.00,COEFDEVISE,GBIDI3)";
  Wrseq " From TRTDEV"
  Wrseq "    If GBIDI3=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "  Endif"
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif

# On traite la colonne prix
If [F:PPC]PRIPRO>1
Wrseq "  If TACHE(0)"
  If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5
Wrseq "# Prix par coeff. ou calcul : lecture ITP et ITV"
Wrseq "#   Articles-Fournisseurs ITMBPS"
Wrseq "If [F:ITP]ITMREF<>[F:ITM]ITMREF | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
Wrseq "  Read [ITP]ITP0 = [F:ITM]ITMREF;[F:BPS]BPSNUM"
Wrseq "  If fstat : Raz [F:ITP] : Endif"
Wrseq "Endif"
Wrseq "#   Cumuls Mouvements Articles-Sites ITMMVT"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>[F:PPK]PRHFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; [F:PPK]PRHFCY"
Wrseq "  If fstat : raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim([F:PPK]CSTTYP)>0"
Wrseq "   If find([F:PPK]CSTTYP,1,2,99) : [L]CSTTYP=[F:PPK]CSTTYP : Endif"
Wrseq "   If find([F:PPK]CSTTYP,3,4) : [L]CSTTYP=[F:PPK]CSTTYP*-1 : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>[F:PPK]PRHFCY | [F:ITC]ITMREF<>[F:ITM]ITMREF |"
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| ITCSTRDAT>DAT | DAT>ITCENDDAT"
Wrseq "       Raz [F:ITC]"
Wrseq "       Call GETPRI([F:ITM]ITMREF,'','',[F:PPK]PRHFCY,DAT,1,'','',[L]CSTTYP,GBIDD3,WRET) From STKVAL"
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:PPC]PRIPRO=4
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "    [F:";ABR_XPL;"]PRI=[F:";ABR_XPL;"]PRI*(";FORMULEPRI;")"
Wrseq "    Onerrgo"
  Endif
  If [F:PPC]PRIPRO=5
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "    Onerrgo ERR_PRI"
Wrseq "    [F:";ABR_XPL;"]PRI=(";FORMULEPRI;")"
Wrseq "    Onerrgo"
  Endif
  If ICONV<> 0
Wrseq "    [F:";ABR_XPL;"]PRI=[F:";ABR_XPL;"]PRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:PPC]ATICNVFLG<>1
Wrseq "# Possibilité conversion ht/ttc"
#Wrseq "    If PRITYP<>WPRITYP"
#Wrseq "      Raz CLCAMT1, CLCAMT2"
#Wrseq "      If dim([F:PPK]CLCAMT1)>0 : CLCAMT1=[F:PPK]CLCAMT1 : Endif"
#Wrseq "      If dim([F:PPK]CLCAMT2)>0 : CLCAMT2=[F:PPK]CLCAMT2 : Endif"
#Wrseq "      Call CLCTAXEPRI ([F:";ABR_XPL;"]PRI,VAT,WPRITYP,GSOCIETE,DAT,QTY,";
#Wrseq "CLCAMT1,CLCAMT2,[F:";ABR_XPL;"]PRI) From TRTX3"
Wrseq "    If PRITYP<>WPRITYP"
Wrseq "      Raz CLCAMT"
Wrseq "      If dim([F:PPK]CLCAMT1)>0 : CLCAMT(1)=[F:PPK]CLCAMT1 : Endif"
Wrseq "      If dim([F:PPK]CLCAMT2)>0 : CLCAMT(2)=[F:PPK]CLCAMT2 : Endif"
Wrseq "      If dim([F:PPK]CLCAMT3)>0 : CLCAMT(3)=[F:PPK]CLCAMT3 : Endif"
Wrseq "      Call CLCTAXEPRI2([F:";ABR_XPL;"]PRI,VAT,WPRITYP,GSOCIETE,DAT,QTY,";
Wrseq "CLCAMT,[F:";ABR_XPL;"]PRI) From TRTX3"
Wrseq "    Endif"
  Endif
Wrseq "    If (MONTANT(0)=0 & MOTIF(0)=0) | MONTANT(0)>[F:";ABR_XPL;"]PRI"
Wrseq "      MONTANT(0)=arr([F:";ABR_XPL;"]PRI,10^-GDECPRI) : MOTIF(0)=WPRIREN : PRIORITE(0)=PIO"
Wrseq "      PLI(0)=[F:";ABR_XPL;"]PLI : PLICRD(0)=[F:";ABR_XPL;"]PLICRD : PLILIN(0)=[F:";ABR_XPL;"]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
Endif

# on traite les 9 colonnes frais/remises
For I=0 To NBRCOLONNE-1
  If find ([F:PPC]DISCRGPRO(I),1,3)
     INDR=num$(I)
     INDN=num$(I+1)
    If [F:PPC]DISCRGPRO(I)=1
      If [F:PRS]VALTYP(I)=1
Wrseq "# frais/rem en montant"
Wrseq "  If TACHE(";INDN;")"
        If ICONV<>0
Wrseq "    [F:";ABR_XPL;"]DCGVAL(";INDR;")=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(3);
          If [F:PRS]CLCRUL(I)=1
Wrseq TEX(1);TEX(2);
          Endif
Wrseq

#         arrondi suivant type donnee ecran saisie tarifs si montant par unite
          If [F:PRS]CLCRUL=1
Wrseq "    Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If pat(GFMTCOL(";num$(I);"),'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=GFMTCOL(";num$(I);") : Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
          Endif

#         arrondi suivant type donnee ecran saisie tarifs si montant par ligne
          If [F:PRS]CLCRUL=2
Wrseq "    Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
            I1=instr(1,ATY_FORTYP(I+1),"=")
            If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
            Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If pat(GFMTCOL(";num$(I);"),'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=GFMTCOL(";num$(I);") : Endif"
            Endif
Wrseq "    Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
          Endif
        Endif

        If [F:PPC]ATICNVFLG<>1 & [F:PRS]NPRNOTFLG=2
Wrseq "    If PRITYP<>WPRITYP"
#Wrseq "      Raz CLCAMT1, CLCAMT2"
#Wrseq "      If dim([F:PPK]CLCAMT1)>0 : CLCAMT1=[F:PPK]CLCAMT1 : Endif"
#Wrseq "      If dim([F:PPK]CLCAMT2)>0 : CLCAMT2=[F:PPK]CLCAMT2 : Endif"
#Wrseq "      Call CLCTAXEPRI ([F:";ABR_XPL;"]DCGVAL(";INDR;"),VAT,WPRITYP,GSOCIETE,DAT,QTY,";
#Wrseq "CLCAMT1,CLCAMT2,[F:";ABR_XPL;"]DCGVAL(";INDR;")) From TRTX3"
Wrseq "      Raz CLCAMT"
Wrseq "      If dim([F:PPK]CLCAMT1)>0 : CLCAMT(1)=[F:PPK]CLCAMT1 : Endif"
Wrseq "      If dim([F:PPK]CLCAMT2)>0 : CLCAMT(2)=[F:PPK]CLCAMT2 : Endif"
Wrseq "      If dim([F:PPK]CLCAMT3)>0 : CLCAMT(3)=[F:PPK]CLCAMT3 : Endif"
Wrseq "      Call CLCTAXEPRI2([F:";ABR_XPL;"]DCGVAL(";INDR;"),VAT,WPRITYP,GSOCIETE,DAT,QTY,";
Wrseq "CLCAMT,[F:";ABR_XPL;"]DCGVAL(";INDR;")) From TRTX3"
Wrseq "      Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
             I1=instr(1,ATY_FORTYP(I+1),"=")
             If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
             Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If pat(GFMTCOL(";num$(I);"),'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=GFMTCOL(";num$(I);") : Endif"
             Endif
Wrseq "      Gosub ARRFMT : [F:";ABR_XPL;"]DCGVAL(";INDR;")=arr([F:";ABR_XPL;"]DCGVAL(";INDR;"),APDC_RND)"
Wrseq "    Endif"
        Endif

        Else
Wrseq "# frais/rem en %"
Wrseq "  If TACHE(";INDN;")"
      Endif
      If [F:PRS]INCDCR(I)=1
#       c'est une majoration
Wrseq "    If (MONTANT(";INDN;")=0 & MOTIF(";INDN;")=0) | MONTANT(";INDN;")>[F:";ABR_XPL;"]DCGVAL(";INDR;")"
      Else
#       c'est une minoration
Wrseq "    If (MONTANT(";INDN;")=0 & MOTIF(";INDN;")=0) | MONTANT(";INDN;")<[F:";ABR_XPL;"]DCGVAL(";INDR;")"
      Endif
Wrseq "      MONTANT(";INDN;")=[F:";ABR_XPL;"]DCGVAL(";INDR;") : ";
Wrseq " MOTIF(";INDN;")=WPRIREN : PRIORITE(";INDN;")=PIO"
Wrseq "      PLI(";INDN;")=[F:";ABR_XPL;"]PLI : PLICRD(";INDN;")=[F:";ABR_XPL;"]PLICRD :";
Wrseq " PLILIN(";INDN;")=[F:";ABR_XPL;"]PLILIN"
Wrseq "    Endif"
Wrseq "  Endif"
    Endif
    If [F:PPC]DISCRGPRO(I)=3
Wrseq "# frais/rem initialisation"
Wrseq "  If TACHE(";INDN;")"
Wrseq "    MONTANT(";INDN;")=0 : MOTIF(";INDN;")=WPRIREN"
Wrseq "    PLI(";INDN;")=[F:";ABR_XPL;"]PLI : PLICRD(";INDN;")=[F:";ABR_XPL;"]PLICRD :";
Wrseq " PLILIN(";INDN;")=[F:";ABR_XPL;"]PLILIN"
Wrseq "  Endif"
    Endif
  Endif
Next I

# on ne traite pas le coef de commission dans les achats

# on traite les gratuits
If [F:PPC]FOCPRO=2 | [F:PPC]FOCPRO=3
Wrseq "# les gratuits"
Wrseq "  If TACHE(11)"
Wrseq "    If [F:",ABR_XPL;"]FOCQTYMIN<=QTY"
#    seuil
  If [F:PPC]FOCTYP=1
Wrseq "      FOCQTY=[F:";ABR_XPL;"]FOCQTY"
Wrseq "      FOCMOTIF=WPRIREN"
  Endif
#    multiple
  If [F:PPC]FOCTYP=2
Wrseq "      If WFOCQTYBKT=0 WFOCQTYBKT=1 Endif"
Wrseq "      FOCQTY= fix (((QTY*COEFUNITE)-WFOCQTYMIN)/WFOCQTYBKT)*[F:";ABR_XPL;"]FOCQTY"
Wrseq "      FOCMOTIF=WPRIREN"
  Endif
  If [F:PPC]FOCPRO=3
Wrseq "      If FOCQTY<>0"
Wrseq "        FOCITMREF=[F:";ABR_XPL;"]FOCITMREF"
Wrseq "        FOCUOM=[F:";ABR_XPL;"]UOM"
Wrseq "      Endif"
  Endif

Wrseq "    Endif"
Wrseq "  Endif"
Endif

Wrseq "  PLISTRDAT=[F:";ABR_XPL;"]PLISTRDAT"
Wrseq "  PLIENDDAT=[F:";ABR_XPL;"]PLIENDDAT"
#Pour les achats récupération du plus grand délai dans MONTANT(10)
Wrseq "#Récupération du plus grand délai"
Wrseq "  If MONTANT(10) < [F:";ABR_XPL;"]LTI"
Wrseq "     MONTANT(10) = [F:";ABR_XPL;"]LTI"
Wrseq "  Endif"
Wrseq "$TAR_SUIVANT"
Wrseq "Next"
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "End"
Return


#------------------------------------------------------------------------
# tarif groupe : génération traitement
#------------------------------------------------------------------------
$TR_GROUPE
Local Shortint ILK            : # pour ne pas generer Call ALIPLK
#--- pas d'appel à ALIPLK si : absence de PPRICLINK dans les critères
#                              si traitement du prix ( par formule ou coefficient)
#                              si maj des prix nul ( pour test de [F:PPK]FOCITM )
#
ILK= find("PPK",[F:PPC]ABB) + find([F:PPC]PRIPRO,4,5) + ([F:PPC]UPDNULPRI=2)

Wrseq "Raz UPDGRP"
Wrseq "If !GPPLXGRP           : # pour faire une recherche multiple des groupes"
Wrseq "  If sum([M]GRPFLG)=[M]NBLIG : End : Endif"
Wrseq "Endif"

#------------------------------------------------------------------------
#     Generation Boucle primaire (A:NLD) sur les lignes du document

Wrseq ""
Wrseq "#--- Boucle (A:NLD) sur les lignes du document -------------------"
Wrseq "For NLD=1 To [M]NBLIG"
Wrseq "  If !GPPLXGRP"
Wrseq "    If sum([M]GRPFLG)=[M]NBLIG : Break : Endif"
Wrseq "  Endif"
Wrseq "  If ([M]GRPFLG(NLD-1)=0 | GPPLXGRP) & UPDGRP(NLD-1)=0"

If ILK                                       : # appel de ALIPLK uniquement si necessaire
  Wrseq "    SAVNOLIGN=nolign : nolign=NLD"
  Wrseq "    GALIPLK=TRAIT : Gosub GALIPLK From TRTPRICE"
  Wrseq "    nolign=SAVNOLIGN"
Endif

If find("ITM",[F:PPC]ABB)                    : # lecture ITMMASTER si present dans les criteres
  Wrseq "      If [F:ITM]ITMREF<>[M]ITMREF(NLD-1)"
  Wrseq "        Read [ITM]ITM0=[M]ITMREF(NLD-1)"
  Wrseq "        If fstat : Raz [F:ITM] : Endif"
  Wrseq "      Endif"
Endif
If find("ITP",[F:PPC]ABB)                    : # lecture ITMBPS si present dans les criteres
  Wrseq "      If [F:ITP]ITMREF<>[M]ITMREF(NLD-1) | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
  Wrseq "        Read [ITP]ITP0=[M]ITMREF(NLD-1);[F:BPS]BPSNUM"
  Wrseq "        If fstat : Raz [F:ITP] : Endif"
  Wrseq "      Endif"
Endif

Wrseq "      WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
    Case [F:PPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "    Gosub CRIT_IDEM_NLD"
Wrseq "  Endif"
Wrseq "Next"
Wrseq "End"
Wrseq ""

#------------------------------------------------------------------------
#     Generation Boucle secondaire (B:PPL) sur les lignes de tarif ayant :
#        - critères de la ligne en cours de la boucle (A:NLD)
#        - valides a la date du document
#        - de meme devise ( uniquement si conversion devise a Non )
#        - pas de filtre des unites ( selection effectuee sur les lignes )

Gosub TR_GRP_CI_NLD

Return

$TR_GRP_CI_NLD
Wrseq "#-----------------------------------------------------------------"
Wrseq "#--- Pour chaque ligne de la Boucle (A:NLD) en cours -------------"
Wrseq "#--- Boucle (B:PPL) : lignes tarifs ayant criteres ligne NLD -----"
Wrseq ""
Wrseq "$CRIT_IDEM_NLD"
Wrseq "For [";ABR_XPL;"]";ABR_XPL;"1 Where [F:";ABR_XPL;"]PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=WCRIT"
Wrseq "&  & [L]DAT>=[F:";ABR_XPL;"]PLISTRDAT & [L]DAT<=[F:";ABR_XPL;"]PLIENDDAT"
If [F:PPC]CURCNVFLG=1 & SAISIEDEV=1          : # si tarif sans conversion devise (filtre devise identique)
  Wrseq "&  & [F:";ABR_XPL;"]CUR=[L]CUR"
Endif

Wrseq "  If !GPPLXGRP"
Wrseq "    If sum([M]GRPFLG)=[M]NBLIG : break : Endif"
Wrseq "  Endif"
Wrseq "  Raz CUMQTY, CUMAMT, SELGRP"
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
Raz TEX : ICONV=0
If [F:PPC]CURCNVFLG=2                        : # si tarif avec conversion devise
Wrseq "  If [F:";ABR_XPL;"]CUR<>CUR"
Wrseq "    Call CONVERT([F:";ABR_XPL;"]CUR,CUR,GLOCALDEV,CHGTYP,DAT,1000000000000.00,COEFDEVISE,GBIDI3) From TRTDEV"
Wrseq "    If GBIDI3=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
Wrseq "  Endif"
  TEX(3)="*COEFDEVISE" : ICONV=1
Endif
Wrseq "#--- Pour chaque ligne tarif de la Boucle (B:PPL) ----------------"
Wrseq "#--- Boucle (C:NLG) : lignes du documents ------------------------"
Wrseq "  For NLG=1 to [M]NBLIG"
Wrseq "    If ([M]GRPFLG(NLG-1)=0 | GPPLXGRP) & UPDGRP(NLG-1)=0"

If ILK                                       : # appel de ALIPLK uniquement si necessaire
  Wrseq "      SAVNOLIGN=nolign : nolign=NLG"
  Wrseq "      GALIPLK=TRAIT : Gosub GALIPLK From TRTPRICE"
  Wrseq "      nolign=SAVNOLIGN"
Endif

If find("ITM",[F:PPC]ABB)                    : # lecture ITMMASTER si present dans les criteres
  Wrseq "      If [F:ITM]ITMREF<>[M]ITMREF(NLG-1)"
  Wrseq "        Read [ITM]ITM0=[M]ITMREF(NLG-1)"
  Wrseq "        If fstat : Raz [F:ITM] : Endif"
  Wrseq "      Endif"
Endif

If find("ITP",[F:PPC]ABB)                    : # lecture ITMBPS si present dans les criteres
  Wrseq "      If [F:ITP]ITMREF<>[M]ITMREF(NLG-1) | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
  Wrseq "        Read [ITP]ITP0=[M]ITMREF(NLG-1);[F:BPS]BPSNUM"
  Wrseq "        If fstat : Raz [F:ITP] : Endif"
  Wrseq "      Endif"
Endif

Wrseq "      WCRIT=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
    Case [F:PPC]FLDTYP(I)
    When "CCE"
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0))+'~'";
    When "C", "L", "DCB", "M"
      Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));"))+'~'";
    When "D"
      Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")))+'~'";
    When Default
      Wrseq "[F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";num$([F:PPC]CRIIND(I));")+'~'";
    Endcase
  Else
    Wrseq "'~'";
  Endif
Next I
Wrseq
Wrseq "      If WCRIT=[F:";ABR_XPL;"]PLICRI"
Wrseq "        CONVQTY=[M]QTYUOM(NLG-1)"
If [F:PPC]PRIQTYFLG=5                        : # si tranches tarifs sur prix nets
Wrseq "        CONVPRI=[M]NETPRI(NLG-1)"
  Else                                       : # si tranches tarifs sur prix bruts
Wrseq "        CONVPRI=[M]GROPRI(NLG-1)"
Endif
Wrseq "        NONSEL=0"
Wrseq "        COEFUNITE=1"

If [F:PPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites
  If [F:PPC]UOMCNVFLG=2                      : # si tarif avec conversion unites
Wrseq "        If [F:";ABR_XPL;"]UOM<>[M]UOM(NLG-1)"
Wrseq "          Call PCAL_QTY(CONVQTY,[M]UOM(NLG-1),CONVQTY,[F:";ABR_XPL;"]UOM,"
Wrseq "&                       [M]ITMREF(NLG-1),[F:BPS]BPSNUM,1,COEFUNITE) From TRTACHQTE1"
Wrseq "          If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "#         en sortie de PCAL_QTY, CONVQTY est en unite du tarif"
Wrseq "        Endif"
  Else                                       : # si tarif sans conversion unites
Wrseq "        If [F:";ABR_XPL;"]UOM<>[M]UOM(NLG-1) : NONSEL=1 : CONVQTY=0 : Endif"
  Endif
Endif

#If [F:PPC]UPDNULPRI=2                        : # si maj des prix nuls
#Wrseq "        If [F:PPK]FOCITM=2 : NONSEL=1 : Endif"
#Endif

Wrseq "        If NONSEL=0"
Wrseq "          CUMQTY += CONVQTY"
Wrseq "#         attention on reste dans devise tarif (donc /coefdevise)"
Wrseq "          If COEFDEVISE=0 : COEFDEVISE=1 : Endif"
Wrseq "          CUMAMT += (CONVPRI*[M]QTYUOM(NLG-1)/COEFDEVISE)"
Wrseq "          SELGRP(NLG-1)=1"
Wrseq "        Endif"
Wrseq "      Endif"
Wrseq "    Endif"
Wrseq "  Next NLG"
Wrseq ""
Wrseq "  If sum(SELGRP)>0"
If [F:PPC]PRIQTYFLG=3                        : # si tranches tarifs sur quantites
    Wrseq "    If CUMQTY>=[F:";ABR_XPL;"]MINQTY & CUMQTY<=[F:";ABR_XPL;"]MAXQTY"
    Wrseq "      CUMALL=CUMQTY"
  Else                                       : # si tranches tarifs sur prix bruts ou nets
    Wrseq "    If CUMAMT>=[F:";ABR_XPL;"]MINAMT & CUMAMT<=[F:";ABR_XPL;"]MAXAMT"
    Wrseq "      CUMALL=CUMAMT"
Endif

Wrseq "      COEFUNITE=1 : COEFPOURN=1 "

Wrseq "      LIGMAJ=0 : # pour tester si 1ere ligne en m.a.j."
Wrseq "#           boucle des lignes de cde .."
Wrseq "      For NLG=1 to [M]NBLIG"
Wrseq "        If SELGRP(NLG-1)<>0"
Wrseq "          UPDGRP(NLG-1)=1"
Wrseq "          LIGMAJ +=1"
Wrseq "          Gosub TR_GRPLIG : # Traitement 1 ligne"
Wrseq "        Endif"
Wrseq "      Next NLG"

If [F:PPC]FOCPRO=4                           : # attribution art. gratuits sur total document
Wrseq "#           les gratuits"
  If [F:PPC]PRIQTYFLG=3                      : # test sur quantite
Wrseq "      If [F:";ABR_XPL;"]FOCITMREF<>'' & [F:";ABR_XPL;"]FOCQTYMIN<=CUMQTY"
  Endif
  If find([F:PPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net
Wrseq "      If [F:";ABR_XPL;"]FOCITMREF<>'' & [F:";ABR_XPL;"]FOCAMTMIN<=CUMALL"
  Endif
Wrseq "        If !find([F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN),FOCUPDTST)"
Wrseq "          IGR = find('',FOCITMREF(0..dim(FOCITMREF)-1))"
Wrseq "          If IGR<>0"
  If [F:PPC]FOCTYP=1                         : # type de gratuite : seuil
Wrseq "            FOCUPDTST(IGR-1)=[F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN)"
Wrseq "            FOCITMREF(IGR-1)=[F:";ABR_XPL;"]FOCITMREF"
Wrseq "            FOCQTY(IGR-1)=[F:";ABR_XPL;"]FOCQTY"
Wrseq "            FOCUOM(IGR-1)=[F:";ABR_XPL;"]UOM"
Wrseq "            FOCMOTIF(IGR-1)=WPRIREN"
Wrseq "          Endif"

  Elsif [F:PPC]FOCTYP=2                      : # type de gratuite : multiple
Wrseq "            FOCUPDTST(IGR-1)=[F:";ABR_XPL;"]PLI+'~'+[F:";ABR_XPL;"]PLICRD+'~'+num$([F:";ABR_XPL;"]PLILIN)"
Wrseq "            FOCITMREF(IGR-1)=[F:";ABR_XPL;"]FOCITMREF"
    If [F:PPC]PRIQTYFLG=3                      : # test sur quantite
Wrseq "            If [F:";ABR_XPL;"]FOCQTYBKT=0 [F:";ABR_XPL;"]FOCQTYBKT=1 Endif"
Wrseq "            FOCQTY(IGR-1)= fix ((CUMALL-[F:";ABR_XPL;"]FOCQTYMIN)/[F:";ABR_XPL;"]FOCQTYBKT)*[F:";ABR_XPL;"]FOCQTY"
    Endif
    If find([F:PPC]PRIQTYFLG,4,5)              : # test sur prix brut ou net
Wrseq "            If [F:";ABR_XPL;"]FOCAMTBKT=0 [F:";ABR_XPL;"]FOCAMTBKT=1 Endif"
Wrseq "            FOCQTY(IGR-1)= fix ((CUMALL-[F:";ABR_XPL;"]FOCAMTMIN)/[F:";ABR_XPL;"]FOCAMTBKT)*[F:";ABR_XPL;"]FOCQTY"
    Endif
Wrseq "            FOCUOM(IGR-1)=[F:";ABR_XPL;"]UOM"
Wrseq "            FOCMOTIF(IGR-1)=WPRIREN"
Wrseq "          Endif"

  Else
Wrseq "          Endif"
  Endif

Wrseq "        Endif"
Wrseq "      Endif"
Endif

Wrseq "    Endif"
Wrseq "  Endif"

Wrseq "Next"
Wrseq "Return"
Return


$TR_GRPLIG
# --- Mise a jour une ligne (devis, cde, etc..) suivant tarif groupé
Wrseq ""
Wrseq "$TR_GRPLIG"
Wrseq "COEFUNITE=1"
# On détermine la conversion unité
If [F:PPC]UOMCNVFLG=2                        : # si tarif avec conversion unites
  Raz TESTUOM
  TESTUOM=find(1,[F:PRS]VALTYP(0..NBRCOLONNE-1)) : # si une colonne de tarif est en montant
  If [F:PPC]PRIPRO>1 : TESTUOM=1 : Endif         : # si le tarif gere le prix
  If TESTUOM>0
Wrseq "# Conversion unite"
Wrseq "If [F:";ABR_XPL;"]UOM<>[M]UOM(NLG-1)"
Wrseq "  Call PCAL_QTY(CONVQTY,[M]UOM(NLG-1),CONVQTY,[F:";ABR_XPL;"]UOM,"
Wrseq "&               [M]ITMREF(NLG-1),[F:BPS]BPSNUM,1,COEFUNITE) From TRTACHQTE1"
Wrseq "  If COEFUNITE=0 : COEFUNITE=1 : Endif"
Wrseq "Endif"
    TEX(1)="*COEFUNITE"
    ICONV=1
  Endif
Endif

# On traite la colonne prix
If [F:PPC]PRIPRO>1                           : # si le tarif gere les prix

  If [F:PPC]PRIPRO=2                         : # prix en valeur
Wrseq "# Prix en valeur"
Wrseq "CONVPRI=[F:";ABR_XPL;"]PRI"
  Endif
  If [F:PPC]PRIPRO=4 | [F:PPC]PRIPRO=5       : # prix par coefficient ou par calcul (formule)
Wrseq "# Prix par coeff. ou calcul : lecture ITP et ITV"
Wrseq "If [F:ITP]ITMREF<>[F:ITM]ITMREF | [F:ITP]BPSNUM<>[F:BPS]BPSNUM"
Wrseq "  Read [ITP]ITP0 = [F:ITM]ITMREF;[F:BPS]BPSNUM"
Wrseq "  If fstat : Raz [F:ITP] : Endif"
Wrseq "Endif"
Wrseq "If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>[F:PPK]PRHFCY"
Wrseq "  Read [ITV]ITV0 = [F:ITM]ITMREF; [F:PPK]PRHFCY"
Wrseq "  If fstat : raz [F:ITV] : Endif"
Wrseq "Endif"
Wrseq "#   Articles-Couts ITMCOST"
Wrseq "#   ( utilisation de GETPRI pour delivrer le bon enregistrement [F:ITC] )"
Wrseq "Local Integer CSTTYP : CSTTYP=1 : # Prix standard par defaut"
Wrseq "If dim([F:PPK]CSTTYP)>0"
Wrseq "   If find([F:PPK]CSTTYP,1,2,3,99) : [L]CSTTYP=[F:PPK]CSTTYP : Endif"
Wrseq "Endif"
Wrseq "If [L]CSTTYP=99"
Wrseq "   Raz [F:ITC]"
Wrseq " Else"
Wrseq "   If [F:ITC]STOFCY<>[F:PPK]PRHFCY | [F:ITC]ITMREF<>[F:ITM]ITMREF |"
Wrseq "&     [F:ITC]CSTTYP<>[L]CSTTYP| ITCSTRDAT>DAT | DAT>ITCENDDAT"
Wrseq "       Raz [F:ITC]"
Wrseq "       Call GETPRI([F:ITM]ITMREF,'','',[F:PPK]PRHFCY,DAT,1,'','',[L]CSTTYP,GBIDD3,WRET) From STKVAL"
Wrseq "   Endif"
Wrseq "Endif"
  Endif
  If [F:PPC]PRIPRO=4                         : # prix par coefficient (formule)
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par coefficient"
Wrseq "Onerrgo ERR_PRI"
Wrseq "CONVPRI=[F:";ABR_XPL;"]PRI*(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If [F:PPC]PRIPRO=5                         : # prix par calcul (formule)
       FORMULEPRI=format$("KTv1:250X",[F:PPC]PRIFLD)
Wrseq "# Prix par formule"
Wrseq "Onerrgo ERR_PRI"
Wrseq "CONVPRI=(";FORMULEPRI;")"
Wrseq "Onerrgo"
  Endif
  If ICONV<>0
Wrseq "CONVPRI=CONVPRI";TEX(1);TEX(2);TEX(3)
  Endif
  If [F:PPC]ATICNVFLG<>1                     : # si tarif avec conversion de prix HT<-->TTC
Wrseq "#   Possibilité conversion ht/ttc"
Wrseq "If PRITYP<>WPRITYP"
Wrseq "  Raz VAT"
Wrseq "  If dim([M]VAT1)>0 : VAT(0)=[M]VAT1(NLG-1) : Endif"
Wrseq "  If dim([M]VAT2)>0 : VAT(1)=[M]VAT2(NLG-1) : Endif"
Wrseq "  If dim([M]VAT3)>0 : VAT(2)=[M]VAT3(NLG-1) : Endif"
#Wrseq "  Raz CLCAMT1, CLCAMT2"
#Wrseq "  If dim([F:PPK]CLCAMT1)>0 : CLCAMT1=[F:PPK]CLCAMT1 : Endif"
#Wrseq "  If dim([F:PPK]CLCAMT2)>0 : CLCAMT2=[F:PPK]CLCAMT2 : Endif"
#Wrseq "  Call CLCTAXEPRI (CONVPRI,VAT,WPRITYP,GSOCIETE,DAT,QTY,CLCAMT1,CLCAMT2,CONVPRI) From TRTX3"
Wrseq "  Raz CLCAMT"
Wrseq "  If dim([F:PPK]CLCAMT1)>0 : CLCAMT(1)=[F:PPK]CLCAMT1 : Endif"
Wrseq "  If dim([F:PPK]CLCAMT2)>0 : CLCAMT(2)=[F:PPK]CLCAMT2 : Endif"
Wrseq "  If dim([F:PPK]CLCAMT3)>0 : CLCAMT(3)=[F:PPK]CLCAMT3 : Endif"
Wrseq "  Call CLCTAXEPRI2(CONVPRI,VAT,WPRITYP,GSOCIETE,DAT,QTY,CLCAMT,CONVPRI) From TRTX3"
Wrseq "Endif"
  Endif
Wrseq "If CONVPRI<>0"
# Issue 122499
# En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "   If CONVPRI<[M]GROPRI(NLG-1) | [M]PRIREN(NLG-1)=0 | ([M]GROPRI(NLG-1)=0 & UPDNULPRI=2)"
Wrseq "   If CONVPRI<=[M]GROPRI(NLG-1) | [M]PRIREN(NLG-1)=0 | ([M]GROPRI(NLG-1)=0 & UPDNULPRI=2)"
# End issue 122499
Wrseq "      [M]GROPRI(NLG-1)=arr(CONVPRI,10^-GDECPRI) : [M]PRIREN(NLG-1)=WPRIREN"
Wrseq "      [M]GRPFLG(NLG-1)=1"
Wrseq "   Endif"
Wrseq "Endif"
Endif

# On traite les 9 colonnes frais/remises
For I=0 To NBRCOLONNE-1
  If find ([F:PPC]DISCRGPRO(I),1,3)          : # si colonne tarif geree ou initialisee
    INDR=num$(I)
    INDN=num$(I+1)
# Génération du libelle
    Wrseq ""
    Wrseq "# ";
    If [F:PRS]INCDCR(I)=1 : Wrseq "Frais-"; : Endif
    If [F:PRS]INCDCR(I)=2 : Wrseq "Remise-"; : Endif
    Wrseq INDN;" ";
    If [F:PRS]VALTYP(I)=1 : Wrseq "en Montant "; : Endif
    If [F:PRS]VALTYP(I)=2 : Wrseq "en %Cumul "; : Endif
    If [F:PRS]VALTYP(I)=3 : Wrseq "en %Cascade "; : Endif
    If [F:PRS]CLCRUL(I)=1 : Wrseq "par Unité "; : Endif
    If [F:PRS]CLCRUL(I)=2 : Wrseq "par Ligne "; : Endif
    If [F:PRS]CLCRUL(I)=3 : Wrseq "par Document "; : Endif
    If [F:PPC]DISCRGPRO(I)=3 : Wrseq "(Initialisation)"; : Endif
    Wrseq

    If [F:PPC]DISCRGPRO(I)=1                 : # si colonne tarif geree

#                Montant à la ligne ou unité

      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)<>3      : # si colonne montant par unite
Wrseq "CONVPRI=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(1);TEX(3)
        If ICONV<>0
#Wrseq "If [F:";abr_xpl;"]CUR<>CUR | [M]PUU(NLG-1)<>[F:";abr_xpl;"]UOM"
Wrseq "If [F:";ABR_XPL;"]CUR<>CUR | [M]UOM(NLG-1)<>[F:";ABR_XPL;"]UOM"
Wrseq "  Raz APDC_RND : APDC_CUR=CUR : Gosub LECTCU : ";
         I1=instr(1,ATY_FORTYP(I+1),"=")
         If I1
Wrseq "APDC_FMT=";right$(ATY_FORTYP(I+1),I1+1)
         Else
#Gbn-78037
#Wrseq "APDC_FMT='";ATY_FORTYP(I+1);"'"
Wrseq "If pat(GFMTCOL(";num$(I);"),'[F:TCU]') : APDC_FMT='' : Else : APDC_FMT=GFMTCOL(";num$(I);") : Endif"
         Endif
Wrseq "  Gosub ARRFMT : CONVPRI=arr(CONVPRI,APDC_RND)"
Wrseq "Endif"
        Endif

        If [F:PRS]INCDCR(I)=1                : # c est une majoration
#         c est une majoration
Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)=0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>CONVPRI"
Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>=CONVPRI"
# Bug 73486
        Else                                 : # c est une minoration
#         c est une minoration
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<CONVPRI"
Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<=CONVPRI"
# Bug 73486
        Endif
Wrseq "  [M]DISCRGVAL";INDN;"(NLG-1)=CONVPRI"
Wrseq "  [M]DISCRGREN";INDN;"(NLG-1)=WPRIREN"
Wrseq "  [M]GRPFLG(NLG-1)=1"
Wrseq "Endif"
      Endif

#                Montant au document (trt sur 1ere ligne)

      If [F:PRS]VALTYP(I)=1 & [F:PRS]CLCRUL(I)=3       : # si colonne montant par document
Wrseq "If LIGMAJ=1"
Wrseq "  CONVPRI=[F:";ABR_XPL;"]DCGVAL(";INDR;")";TEX(3)
        If ICONV<>0
Wrseq "  If [F:";ABR_XPL;"]CUR<>CUR"
#               la valeur va dans le pied (arrondi devise obligatoire)
Wrseq "    Call ARRDEV(CONVPRI,CUR) From TRTDIV"
Wrseq "  Endif"
        Endif
#        on met la remise montant dans la rubrique d'appel
Wrseq "  MONTANT(";INDN;")=MONTANT(";INDN;")+CONVPRI"
Wrseq "  MOTIF(";INDN;")=[F:PRS]INVDTA(";INDR;")"

Wrseq "Endif"
      Endif

#                % ligne

      If [F:PRS]VALTYP(I)>1                  : # colonne en pourcentage
        If [F:PRS]INCDCR(I)=1                : # c est une majoration
#         c est une majoration
Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)=0 | ";
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>[F:";ABR_XPL;"]DCGVAL(";INDR;")"
Wrseq "[M]DISCRGVAL";INDN;"(NLG-1)>=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
# Bug 73486
        Else                                 : # c est une minoration
#         c est une minoration
# Bug 73486 : En cas de nvelle recherche tarif groupé sans modif du doc, il faut réappliquer le tarif
#Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<[F:";ABR_XPL;"]DCGVAL(";INDR;")"
Wrseq "If [M]DISCRGVAL";INDN;"(NLG-1)<=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
# Bug 73486
        Endif
Wrseq "  [M]DISCRGVAL";INDN;"(NLG-1)=[F:";ABR_XPL;"]DCGVAL(";INDR;")"
Wrseq "  [M]DISCRGREN";INDN;"(NLG-1)=WPRIREN"
Wrseq "  [M]GRPFLG(NLG-1)=1"
Wrseq "Endif"
      Endif
    Endif

#                Frais/rem Initialisation

    If [F:PPC]DISCRGPRO(I)=3                 : # colonne tarif a initialiser
      If [F:PRS]CLCRUL(I)=3                  : # colonne par document
Wrseq "MONTANT(";INDN;")=0"
Wrseq "MOTIF(";INDN;")=0"
      Else                                   : # colonne par unite ou par ligne
Wrseq "  [M]DISCRGVAL";INDN;"(NLG-1)=0"
Wrseq "  [M]DISCRGREN";INDN;"(NLG-1)=0"
Wrseq "  [M]GRPFLG(NLG-1)=1"
      Endif

    Endif
  Endif
Next I

Wrseq "Return"

Return

#------------------------------------------------------------------------
# tarif interdit : génération traitement
#------------------------------------------------------------------------
$TR_INTERDIT
Gosub LE_FILTRE
Wrseq "For [";ABR_XPL;"]"
Wrseq "INTERDIT=1 : Break"
Wrseq "Next"
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "End"
Return

#------------------------------------------------------------------------
# Constitution de l'arrondi en fonction d'un format
# (utilise pour les arrondis des colonnes frais/remises
#------------------------------------------------------------------------
$FORMAT_ARRONDI
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Constitution de l'arrondi en fonction d'un format"
Wrseq "#------------------------------------------------------------------------"
Wrseq "# Utilisé notamment dans la recherche tarif pour les colonnes frais/rem"
Wrseq "# Entree : APDC_CUR = Code devise"
Wrseq "# Entrée : APDC_FMT = Format sous la forme 12.4#"
Wrseq "# Sortie : APDC_RND = Arrondi sous la forme 0.0001 (pour instruction arr)"
Wrseq "#------------------------------------------------------------------------"
Wrseq "$LECTCU"
Wrseq "If APDC_CUR='' : APDC_CUR=GLOCALDEV : Endif"
Wrseq "If clalev([F:TCU])<=0 : Local File TABCUR [TCU] : Endif"
Wrseq "If APDC_CUR<>[F:TCU]CUR"
Wrseq "   Read [TCU]TCU0=APDC_CUR"
Wrseq "Endif"
Wrseq "Return"
Wrseq "$ARRFMT"
Wrseq "APDC_RND=min([F:TCU]CURRND,10^-(mod(val(APDC_FMT),1)*10))"
Wrseq "Return"
Wrseq "#------------------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Filtre sur les critères:
#   pour lecture des lignes de la fiche qui répondent aux critères
#   Utilisé si objet utilisé à partir de la recherche tarif FUNACHPPSI
#------------------------------------------------------------------------
$FILTRE_CRITERES
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour visualiser uniquement les lignes de la fiche répondant"
Wrseq "# aux critères ( utilisé dans la simulation )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$FILTRE_CRITERES"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:PPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I
Wrseq 'CRIT += " & PLICRI=';
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq '"'
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Type de donnée des critères:
#   pour permettre la gestion correcte de tous les types de données
#   ( y compris ceux définis par l'utilisateur )
#------------------------------------------------------------------------
$TYPE_CRITERES
Local Char WFLDTYPINT (3)
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour connaitre le type de donnée des critères "
Wrseq "# Fournir le type de donnée dans FLDTYPEXT  ( ex : BPC, ADI, ...)"
Wrseq "# Pour récuperer FLDTYPINT ( M, C, L, DCB, A, D )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$TYPE_CRITERES"
Wrseq "Local char    TFLDTYPEXT (3) (0..5)"
Wrseq "Local char    TFLDTYPINT (3) (0..5)"
Wrseq "Local Integer IJLS"
Wrseq "If dim(FLDTYPEXT)>0 & dim(FLDTYPINT)>0"

For I=0 To 4
 If [F:PPC]ABB(I)<>""
   Read [ATY] CODTYP=[F:PPC]FLDTYP(I)
   If fstat
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:PPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='A'"
   Else
     Case [F:ATY]TYPTYP
       When 1      : WFLDTYPINT="M"    : # Menu local
       When 2      : WFLDTYPINT="C"    : # Entier court
       When 3      : WFLDTYPINT="L"    : # Entier long
       When 4,5,6  : WFLDTYPINT="DCB"  : # Decimal, Flottant, Double
       When 7      : WFLDTYPINT="A"    : # Alpha
       When 8      : WFLDTYPINT="D"    : # Date
     Endcase
Wrseq "  TFLDTYPEXT(";num$(I);")='";num$([F:PPC]FLDTYP(I));"' : TFLDTYPINT(";num$(I);")='";WFLDTYPINT;"'"
   Endif
 Endif
Next I

Wrseq "  IJLS = find (FLDTYPEXT,TFLDTYPEXT)"
Wrseq "  If IJLS : FLDTYPINT=TFLDTYPINT(IJLS-1) : Endif"
Wrseq "Endif"
Wrseq "Return"

Wrseq "#-----------------------------------------------------------------"
Return

#------------------------------------------------------------------------
# Extraction des lignes de tarif pour la consultation dans FUNACHPPSI
#   stockage dans le masque PPSIMUL0
#------------------------------------------------------------------------
$CONSULTATION
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Pour extraction et stockage des lignes de toutes les fiches"
Wrseq "# stockage dans le masque PPSIMUL0 ( utilisé dans FUNACHPPSI )"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$CONSULTATION"
Wrseq "Local Date DATPLUS     : # date borne de simulation des tarifs (+1mois par défaut)"
Wrseq "Local Decimal QTYPLUS  : # qté  borne de simulation des tarifs (+100% si QTY<>0)"
Wrseq "Local Decimal QTYMOINS : # qté  borne de simulation des tarifs (-50%  si QTY<>0)"
Wrseq "Local Integer ONPREND"
Wrseq "If dim([M:PPM0]XMOIS)>0 DATPLUS=addmonth(DAT,[M:PPM0]XMOIS) Else DATPLUS=addmonth(DAT,1) Endif"
Wrseq "If QTY<>0 : QTYMOINS=QTY*0.5 : QTYPLUS=QTY*2 : Endif"
Wrseq "# Les critères existent ?"
For I=0 To 4
 If [F:PPC]ABB(I)<>""
  Wrseq "If dim([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")) < 0 : Return : Endif"
 Endif
Next I

Wrseq "# Lecture des tarifs"
Wrseq "Filter [";ABR_XPL;"] Where PLI='"+[F:PPC]PLI+"'"
Wrseq "&  & PLICRI=";
For I=0 To 4
  If I>0 : Wrseq "+"; : Endif
  If [F:PPC]FLD(I)<>""
     If [F:PPC]FLDTYP(I)="CCE"
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(max(find('";[F:PPC]CRIDIE(I);"',[F:";[F:PPC]ABB(I);"]DIE)-1,0)))+'~'";
     Elsif [F:PPC]FLDTYP(I)="D"
        Wrseq "num$(val([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);")))+'~'";
     Else
        Wrseq "num$([F:";[F:PPC]ABB(I);"]";[F:PPC]FLD(I);"(";[F:PPC]CRIIND(I);"))+'~'";
     Endif
  Else
     Wrseq "'~'";
  Endif
Next
Wrseq
Wrseq "&  & PLISTRDAT<=[L]DATPLUS"
Wrseq "&  & PLIENDDAT>=[L]DAT"
If [F:PPC]UOMCNVFLG=1 & ZZ(8)=1
  Wrseq "&  & UOM=[L]UOM"
Endif
If [F:PPC]CURCNVFLG=1 & SAISIEDEV=1
  Wrseq "&  & CUR=[L]CUR"
Endif
Wrseq "&    Order by PLI; PLICRI; PLISTRDAT; MAXQTY"

Wrseq "For [";ABR_XPL;"]"
If [F:PPC]PRIQTYFLG=2
  Wrseq "Raz ONPREND"
Else
  Wrseq "ONPREND=1"
Endif
Wrseq "  COEFUNITE=1 : COEFPOURN=1 : COEFDEVISE=1"
If ABR_XPL="SPL"
   Wrseq "  If [F:SPL]UOM='*' : [F:SPL]UOM=[F:ITM]SAU : Endif"
Else
   Wrseq "  If [F:PPL]UOM='*' : [F:PPL]UOM=[F:ITM]PUU : Endif"
Endif
If [F:PPC]PRIPRO<4
  Wrseq "  If [F:";ABR_XPL;"]PRIDIV<>0 : COEFPOURN=[F:";ABR_XPL;"]PRIDIV : Endif"
Endif
If [F:PPC]CURCNVFLG=2
  Wrseq "  If [F:";ABR_XPL;"]CUR<>CUR"
  Wrseq "    Call CONVERT([F:";ABR_XPL;"]CUR,CUR,GLOCALDEV,CHGTYP,DAT,1000000000000.00,COEFDEVISE,GBIDI3) From TRTDEV"
  Wrseq "    If GBIDI3=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000000000.00 Else COEFDEVISE=1 Endif"
  Wrseq "  Endif"
Endif
If [F:PPC]UOMCNVFLG=2 : # si conversion unité acceptée
  Wrseq "# Conversion qte mini maxi (pas d'arrondi)"
  Wrseq "  If [F:";ABR_XPL;"]UOM<>UOM"
  Wrseq "    WMANDEC=[F:";ABR_XPL,"]MINQTY"
  Wrseq "    Call PCAL_QTY (WMANDEC,[F:";ABR_XPL;"]UOM,WMANDEC,UOM,[F:ITM]ITMREF,[F:BPS]BPSNUM,2,"
  Wrseq "&                 COEFUNITE) From TRTACHQTE1"
  Wrseq "    If COEFUNITE=0 : COEFUNITE=1 : Endif"
  Wrseq "    [F:";ABR_XPL;"]MINQTY=[F:";ABR_XPL;"]MINQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]MAXQTY=[F:";ABR_XPL;"]MAXQTY/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]FOCQTYMIN=[F:";ABR_XPL;"]FOCQTYMIN/COEFUNITE"
  Wrseq "    [F:";ABR_XPL;"]FOCQTYBKT=[F:";ABR_XPL;"]FOCQTYBKT/COEFUNITE"
  If [F:PPC]FOCPRO=2 : # si qté gratuite sur meme article
  Wrseq "    [F:";ABR_XPL;"]FOCQTY=[F:";ABR_XPL;"]FOCQTY/COEFUNITE"
  Wrseq "    Call QTEARR ([F:";ABR_XPL;"]FOCQTY,UOM) From TRTDIV"
  Endif
  Wrseq "  Endif"
Endif
If [F:PPC]PRIQTYFLG=2
  Wrseq "  If    QTY=0"
  Wrseq "    ONPREND=1"
  Wrseq "  Elsif QTYPLUS>=[F:";ABR_XPL;"]MINQTY & QTYMOINS<=[F:";ABR_XPL;"]MAXQTY"
  Wrseq "    ONPREND=1"
  Wrseq "  Endif"
Endif
Wrseq "  If ONPREND=1"
Wrseq "    JLV=[M:PPM0]NBTAR"
Wrseq "    [M:PPM0]VDATDEB(JLV)   =[F:";ABR_XPL;"]PLISTRDAT"
Wrseq "    [M:PPM0]VDATFIN(JLV)   =[F:";ABR_XPL;"]PLIENDDAT"
Wrseq "    [M:PPM0]VMINQTY(JLV)   =[F:";ABR_XPL;"]MINQTY"
Wrseq "    [M:PPM0]VMAXQTY(JLV)   =[F:";ABR_XPL;"]MAXQTY"
Wrseq "    [M:PPM0]VMINAMT(JLV)   =[F:";ABR_XPL;"]MINAMT"
Wrseq "    [M:PPM0]VMAXAMT(JLV)   =[F:";ABR_XPL;"]MAXAMT"
Wrseq "    [M:PPM0]VCUR(JLV)      =[F:";ABR_XPL;"]CUR"
Wrseq "    If [F:";ABR_XPL;"]UOM<>''"
Wrseq "      [M:PPM0]VUOM(JLV)      =UOM"
Wrseq "    Endif"
Wrseq "    [M:PPM0]VLTI(JLV)      =[F:";ABR_XPL;"]LTI"
Wrseq "    [M:PPM0]VPRIDIV(JLV)   =[F:";ABR_XPL;"]PRIDIV"

If [F:PPC]PRIPRO=4
    Wrseq "    [M:PPM0]VCOE(JLV)      =[F:";ABR_XPL;"]PRI"  : # coefficient
  Else
    Wrseq "    [M:PPM0]VPRI(JLV)      =[F:";ABR_XPL;"]PRI"  : # prix
Endif

If [F:PPC]PRIPRO<4
  Wrseq "    If [F:";ABR_XPL;"]PRIDIV<>0 : [M:PPM0]VPRI(JLV)=[F:";ABR_XPL;"]PRI/[F:";ABR_XPL;"]PRIDIV : Endif"
  Wrseq "    [M:PPM0]VPRI(JLV)=[M:PPM0]VPRI(JLV)*COEFUNITE"
Endif

For I=1 To 9
  Wrseq "    If dim([M:PPM0]VXFRAREM";I;")>0"
  Wrseq "      [M:PPM0]VXFRAREM";I;"(JLV)=[F:";ABR_XPL;"]DCGVAL(";I-1;")";
#           si colonne en montant et par unité
  If [F:PRS]VALTYP(I-1)=1 & [F:PRS]CLCRUL(I-1)=1
    Wrseq "/COEFPOURN*COEFUNITE"
  Else
    Wrseq ""
  Endif
  Wrseq "    Endif"
Next I
Wrseq "    [M:PPM0]VFOCQTYMIN(JLV)=[F:";ABR_XPL;"]FOCQTYMIN"
Wrseq "    [M:PPM0]VFOCQTYBKT(JLV)=[F:";ABR_XPL;"]FOCQTYBKT"
Wrseq "    [M:PPM0]VFOCUOM(JLV)   =[F:";ABR_XPL;"]UOM"
Wrseq "    [M:PPM0]VFOCQTY(JLV)   =[F:";ABR_XPL;"]FOCQTY"
Wrseq "    If dim([M:PPM0]VPLISEA)>0"
Wrseq "        [M:PPM0]VPLISEA(JLV)=";num$([F:PPC]PLISEA)
Wrseq "    Endif"
Wrseq "    [M:PPM0]VPLI(JLV)      =[F:";ABR_XPL;"]PLI"
Wrseq "    [M:PPM0]VPLICRD(JLV)   =[F:";ABR_XPL;"]PLICRD"
Wrseq "    [M:PPM0]VPLILIN(JLV)   =[F:";ABR_XPL;"]PLILIN"
Wrseq "    [M:PPM0]VPPLSPL(JLV)   ='";ABR_XPL;"'"
Wrseq "    Gosub PE_SIMTARIF From TRTPRICE"
Wrseq "    [M:PPM0]NBTAR += 1"
Wrseq "  Endif"

Wrseq "Next"
Wrseq ""
Wrseq "Filter [";ABR_XPL;"]"
Wrseq "Return"

Return

#------------------------------------------------------------------------
# Import de tarif: Raz des zones non accessibles lors du paramétrage mais
#                  qui ont pu être alimentées par le paramétrage du modèle
#                  d'import
#------------------------------------------------------------------------
$INI_IMPORT
Wrseq ""
Wrseq "#-----------------------------------------------------------------"
Wrseq "# Traitment appelé par Gosub dans l'import de tarif"
Wrseq "# init. de la classe F des zones non saisissables pour ce tarif"
Wrseq "#-----------------------------------------------------------------"
Wrseq "$INI_IMPORT"
Wrseq "Raz [F:";ABR_XPL;"]PLICRI1, [F:";ABR_XPL;"]PLICRI2, ",
Wrseq "[F:";ABR_XPL;"]PLICRI3, [F:";ABR_XPL;"]PLICRI4, [F:";ABR_XPL;"]PLICRI5"
Wrseq "Raz [F:";ABR_XPL;"]CPNITMREF"
For I=1 To 5
  If [F:PPC]FLD(I-1)=""
    Wrseq "Raz GIMP("+num$(I)+")          : # Critere "+num$(I)
  Endif
Next
If ZZ(7)=0  : Wrseq "Raz [F:";ABR_XPL;"]CUR       : # Devise"              : Endif
If ZZ(8)=0  : Wrseq "Raz [F:";ABR_XPL;"]UOM       : # Unite"               : Endif
If ZZ(9)=0  : Wrseq "Raz [F:";ABR_XPL;"]MINQTY    : # Qte mini"            : Endif
If ZZ(10)=0 : Wrseq "Raz [F:";ABR_XPL;"]MAXQTY    : # Qte maxi"            : Endif
If ZZ(11)=0 : Wrseq "Raz [F:";ABR_XPL;"]LTI       : # Delai"               : Endif
If ZZ(12)=0 : Wrseq "Raz [F:";ABR_XPL;"]PRIDIV    : # Diviseur prix"       : Endif
If ZZ(13)=0 : Wrseq "Raz [F:";ABR_XPL;"]PRI       : # Prix"                : Endif
If ZZ(14)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(0) : # Frais/remise 1"      : Endif
If ZZ(15)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(1) : # Frais/remise 2"      : Endif
If ZZ(16)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(2) : # Frais/remise 3"      : Endif
If ZZ(17)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(3) : # Frais/remise 4"      : Endif
If ZZ(18)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(4) : # Frais/remise 5"      : Endif
If ZZ(19)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(5) : # Frais/remise 6"      : Endif
If ZZ(20)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(6) : # Frais/remise 7"      : Endif
If ZZ(21)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(7) : # Frais/remise 8"      : Endif
If ZZ(22)=0 : Wrseq "Raz [F:";ABR_XPL;"]DCGVAL(8) : # Frais/remise 9"      : Endif
If ZZ(23)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTYMIN : # Qte mini gratuite"   : Endif
#If ZZ(24)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCBKT   : # Seuil gratuite"      : Endif
If ZZ(25)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCITMREF : # Article gratuit"     : Endif
If ZZ(27)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTY    : # Qte gratuite"        : Endif
If ZZ(28)=0 : Wrseq "Raz [F:";ABR_XPL;"]COMCOE    : # Coef. commission"    : Endif
If ZZ(29)=0 : Wrseq "Raz [F:";ABR_XPL;"]MINAMT    : # Montant mini"        : Endif
If ZZ(30)=0 : Wrseq "Raz [F:";ABR_XPL;"]MAXAMT    : # montant maxi"        : Endif
If ZZ(31)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCAMTMIN : # Prix mini gratuite"  : Endif
If ZZ(32)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCQTYBKT : # Qte seuil gratuite"  : Endif
If ZZ(33)=0 : Wrseq "Raz [F:";ABR_XPL;"]FOCAMTBKT : # Prix seuil gratuite" : Endif

Wrseq "Return"

Return
#------------------------------------------------------------------------

