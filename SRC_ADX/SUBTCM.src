#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "LIENS"       : Gosub LIENS
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "AVANT_MODFIC": Gosub AVANT_MODFIC
    When "INICRE"      : Gosub ENR
    When "INIMOD"      : Gosub ENR
    When "ANNULE"      : Gosub ANNULE
    When "APRES_CRE"   : Gosub RELIT From GOBJSUB
    When "APRES_MOD"   : Gosub RELIT From GOBJSUB
    When "STYLE"       : Gosub STYLE
    When "CHANGE"      : Call CHANGE_AXX ("TABCOSTMET", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
Endcase
Return

######################################################################################
$OUVRE
    Local Mask TVM [TVM1]
    Local Mask TVM [TVM2]
Return

######################################################################################
$LIENS

Raz [M:TVM1]
Raz [M:TVM2]

[M:TVM1] = [F:TCM]
nolign = 0

For [TVM] Where VLTCOD=[M:TCM1]VLTCOD & NUM=1
  nolign += 1
  [M:TVM1] = [F:TVM]
  [M:TVM1]CONCATKEY(nolign-1) = num$([M:TVM1]MVTTYP(nolign-1)) + [M:TVM1]TRSCOD(nolign-1)
Next
[M:TVM1]NBLIG = nolign
[M:TCM1]ISS1 = [M:TVM1]ISSVLTCOD

If GACTVLT2
    Call TRANSF2M("TVM2","TCM",1)
    nolign = 0
    For [TVM] Where VLTCOD=[M:TCM1]VLTCOD & NUM=2
      nolign += 1
      [M:TVM2] = [F:TVM]
      [M:TVM2]CONCATKEY(nolign-1) = num$([M:TVM2]MVTTYP(nolign-1)) + [M:TVM2]TRSCOD(nolign-1)
    Next
    [M:TVM2]NBLIG = nolign

    [M:TCM1]ISS2 = [M:TVM2]ISSVLTCOD

    If [M:TCM1]ISS2>0
        [M:TCM1]FLGTCM2 = 2
    Else
        [M:TCM1]FLGTCM2 = 1
    Endif

    Actzo [M:TCM1]ISS2
    Actzo [M:TCM1]DETISS2
Endif

Gosub CTRVLT

Return

$STYLE
If GACTVLT2 & [M:TCM1]ISS2=0
    Grizo [M:TCM1]ISS2
    Affzo [M:TCM1]DETISS2
    Grizo [M:TCM1]DETISS2
Endif
Return

######################################################################################
$APRES_MODIF
Local Integer LNUM
    Case COUZON
        When "DETISS1","DETISS2":
            LNUM = val(right$(COUZON,len(COUZON)))
            Assign "[M:TCM1]ISS"+num$(LNUM) With evalue("[M:TVM"+num$(LNUM)+"]ISSVLTCOD")
            Affzo [M:TCM1]10
            Gosub CTRVLT
        When "ISS1":
            [M]ISS1 = val(CZ)
            Gosub CTRVLT
    Endcase
Return

######################################################################################
$AVANT_MODFIC
If [M:TCM1]PRIREGS=2 & [M:TCM1]ISS1<>6
    If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
    Filter [ADW] Where PARAM="MAXABSCOD"
&                    & VALEUR="3"
    Look [ADW] First
    Filter [ADW]
    If !fstat
        Local Integer LOK
        # suite 87100
        # Valeur déconseillée avec la valeur du paramètre MAXABSCOD = 'Absorp. base site/lot'.
        LOK=1
        Call AVERTIR(mess(409,184,1),LOK) From GESECRAN
        If LOK=1
            GOK=0
            Return
        Endif
    Endif
Endif

Return

######################################################################################
$ENR
Local Integer I, NB

[F:TCM] = [M:TVM1]
Call TRANSM2F("TCM","TVM2",1)

Delete [TVM] Where VLTCOD=[M:TCM1]VLTCOD

Raz [F:TVM]

If dim([M:TVM1]MVTTYP) > 0  # au cas où on le conditionne
 [F:TVM] = [M:TCM1]
 For nolign=1 To [M:TVM1]NBLIG
   [F:TVM] = [M:TVM1]
   [F:TVM]NUM    = 1
   [F:TVM]CREDAT = date$
   [F:TVM]CREUSR = GUSER
   [F:TVM]EXPNUM = [C]EXPORT
   Write [TVM]
   If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABCOSTMVT"
    Break
   Endif
 Next
Endif
If GACTVLT2
    If [M:TVM1]ISSVLTCOD = [M:TVM2]ISSVLTCOD
&    & [M:TVM1]ISSVLT2 = [M:TVM2]ISSVLT2
&    & [M:TVM1]RCPVLTCOD = [M:TVM2]RCPVLTCOD
&    & [M:TVM1]RCPVLT2 = [M:TVM2]RCPVLT2
&    & [M:TVM1]PRIREG = [M:TVM2]PRIREG
&    & [M:TVM1]NULPRI = [M:TVM2]NULPRI
&    & [M:TVM1]CUNNEG = [M:TVM2]CUNNEG
&    & [M:TVM1]CUNNEG2 = [M:TVM2]CUNNEG2
&    & [M:TVM1]CUNPOS = [M:TVM2]CUNPOS
&    & [M:TVM1]CUNPOS2 = [M:TVM2]CUNPOS2
&    & [M:TVM1]NBLIG = [M:TVM2]NBLIG
        Raz NB
        For I=0 To [M:TVM1]NBLIG-1
            NB += sigma(0,[M:TVM2]NBLIG-1,[M:TVM1]MVTTYP(I)  = [M:TVM2]MVTTYP(indcum)
&                                        &[M:TVM1]TRSCOD(I)  = [M:TVM2]TRSCOD(indcum)
&                                        &[M:TVM1]MVTVLT(I)  = [M:TVM2]MVTVLT(indcum)
&                                        &[M:TVM1]MVTVLT2(I) = [M:TVM2]MVTVLT2(indcum)
&                                        &[M:TVM1]PRIREGX(I) = [M:TVM2]PRIREGX(indcum)
&                                        &[M:TVM1]MVTNUL(I)  = [M:TVM2]MVTNUL(indcum) )
        Next
        If NB = [M:TVM1]NBLIG
            Call MESSAGE(mess(330,184,1)) From GESECRAN    # Méthodes de valorisations identiques
        Endif
    Endif
 For nolign=1 To [M:TVM2]NBLIG
   [F:TVM] = [M:TVM2]
   [F:TVM]NUM    = 2
   [F:TVM]CREDAT = date$
   [F:TVM]CREUSR = GUSER
   [F:TVM]EXPNUM = [C]EXPORT
   Write [TVM]
   If fstat
    GOK = 0
    GMESSAGE=mess(13,100,1)-"TABCOSTMVT"
    Break
   Endif
 Next
Endif

Call MAJTEXTRA([M:TCM1]TCMAXX,"TABCOSTMET","TCMAXX",[M:TCM1]VLTCOD,"") From ATEXTRA
Call MAJTEXTRA([M:TCM1]TCMSHOAXX,"TABCOSTMET","TCMSHOAXX",[M:TCM1]VLTCOD,"") From ATEXTRA
Return

$ANNULE
    Delete [AXX] Where CODFIC="TABCOSTMET" & ZONE="TCMAXX" & CLE1= [M:TCM1]VLTCOD
    Delete [AXX] Where CODFIC="TABCOSTMET" & ZONE="TCMSHOAXX" & CLE1= [M:TCM1]VLTCOD
Return

# Gestion du masque TCM
######################################################################################
Subprog AS_PFMCLCBAS(VALEUR)
Variable Integer VALEUR
GMENLOC(7) = 1    # Ordre
End

########################################
Subprog AS_PFMCLC2(VALEUR)
Variable Integer VALEUR
GMENLOC(7) = 1    # Ordre
End

######################################################################################
# Issue X3-26713 23/03/2017 ALMON  : Start : Set PJM Methods depending on PJMBUDMAN
Subprog EVALUATE_PJMBUDMAN(VALEUR)
Variable Integer VALEUR

    If VALEUR < 2 Then
      Diszo [M:TCM1]PJMBUDVLTCOD
      Diszo [M:TCM1]PJMBUDVLT2
      Effzo [M:TCM1]PJMBUDVLTCOD
      Effzo [M:TCM1]PJMBUDVLT2
      [M:TCM1]PJMBUDVLTCOD = 0
      [M:TCM1]PJMBUDVLT2 = 0
      Grizo [M:TCM1]PJMBUDVLTCOD
      Grizo [M:TCM1]PJMBUDVLT2
    Else
      Actzo [M:TCM1]PJMBUDVLTCOD
      Actzo [M:TCM1]PJMBUDVLT2
    Endif
    Affzo [M:TCM1]
# Issue X3-26713 23/03/2017 ALMON : End
End

######################################################################################
Subprog TRANSF2M(PABR,PFABR,PFIND)
Value Char    PABR
Value Char    PFABR
Value Integer PFIND
Local Integer LMDIM, LMIND

Onerrgo $RES

If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
For [ATZ] Where CODFIC="TABCOSTMET"
    LMDIM = evalue("dim([M:"+PABR+"]"+[F:ATZ]CODZONE+")")
    If LMDIM>0
        LFDIM = evalue("dim([F:"+PFABR+"]"+[F:ATZ]CODZONE+")")
        If LFDIM>PFIND
            Assign "[M:"+PABR+"]"+[F:ATZ]CODZONE With evalue("[F:"+PFABR+"]"+CODZONE+"(PFIND)")
        Else
            Assign "[M:"+PABR+"]"+[F:ATZ]CODZONE With evalue("[F:"+PFABR+"]"+CODZONE)
        Endif
    Endif
Next

Onerrgo

End

######################################################################################
Subprog TRANSM2F(PFABR,PMABR,PFIND)
Value Char    PFABR
Value Char    PMABR
Value Integer PFIND
Local Integer LMDIM, LFDIM

Onerrgo $RES

If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
For [ATZ] Where CODFIC="TABCOSTMET"
    LFDIM = evalue("dim([F:"+PFABR+"]"+[F:ATZ]CODZONE+")")
    If LFDIM>0
        LMDIM = evalue("dim([M:"+PMABR+"]"+[F:ATZ]CODZONE+")")
        If LFDIM>PFIND & LMDIM>0
            Assign "[F:"+PFABR+"]"+[F:ATZ]CODZONE+"(PFIND)" With evalue("[M:"+PMABR+"]"+CODZONE)
        Else
            Assign "[F:"+PFABR+"]"+[F:ATZ]CODZONE With evalue("[M:"+PMABR+"]"+CODZONE)
        Endif
    Endif
Next

Onerrgo

End

$RES
Resume


######################################################################################
$CTRVLT
Local Integer LTEST

For I=1 To 1+(GACTVLT2 & ([M:TCM1]FLGTCM2=2))
    LTEST = 1
    # Existe-t-il des exceptions
    If LTEST & evalue("[M:TVM"+num$(I)+"]NBLIG")>0
        LTEST=0
    Endif

    # La régularisation est-t-elle activée
    If LTEST & evalue("[M:TVM"+num$(I)+"]PRIREG")<>2
        LTEST=0
    Endif

    # Si prix standard en sortie => prix standard en entrée
    # Si prix standard actualisé en sortie => prix standard actualisé en entrée
    If LTEST & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")<=2
&            & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")<>evalue("[M:TVM"+num$(I)+"]RCPVLTCOD")
&            & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")<>evalue("[M:TVM"+num$(I)+"]CUNPOS")
&            & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")<>evalue("[M:TVM"+num$(I)+"]CUNNEG")
        LTEST=0
    Endif

    # Si autre méthode => prix saisi en entrée
    If LTEST & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")>2
&            & evalue("[M:TVM"+num$(I)+"]RCPVLTCOD")<>7
        LTEST=0
    Endif

    If LTEST & evalue("[M:TVM"+num$(I)+"]ISSVLTCOD")=4
&            & evalue("[M:TVM"+num$(I)+"]CUNNEG")<>4
        LTEST=0
    Endif

    If LTEST=1
        Case I
            When 1: Effzo [M:TCM1]EXC1
            When 2: Effzo [M:TCM1]EXC2
        Endcase
    Else
        Case I
            When 1: [M:TCM1]EXC1 = mess(216,184,1)
            When 2: [M:TCM1]EXC2 = mess(216,184,1)
        Endcase
    Endif
    If I=1
        If !find([M:TCM1]ISS1,4,5,8,6) # PMP, FIFO, LIFO, PM lot
            [M:TCM1]PRIREGS = 1
            Grizo [M:TCM1]PRIREGS
        Else
            Actzo [M:TCM1]PRIREGS
        Endif
        Affzo [M:TCM1]PRIREGS
    Endif
Next

If GACTVLT2 & [M:TCM1]FLGTCM2<>2
    Effzo [M:TCM1]EXC2
Endif

# Issue X3-26713 23/03/2017 ALMON  : Start : Set PJM Methods depending on PJMBUDMAN
If func ASYRFNC.ACTIV("PJM") Then
  Call EVALUATE_PJMBUDMAN([M:TCM1]PJMBUDMAN)
Endif
# Issue X3-26713 23/03/2017 ALMON  : END
Return


######################################################################################
Subprog INITVLT(PVLT,PNUM)
Value Integer PVLT
Value Integer PNUM

If PNUM=2 & !GACTVLT2 : End : Endif

Case PNUM
    When 1 : Raz [M:TVM1]
    When 2 : Raz [M:TVM2]
Endcase

Assign "[M:TVM"+num$(PNUM)+"]PRIREG" With 2
Assign "[M:TVM"+num$(PNUM)+"]NULPRI" With 1

Assign "[M:TVM"+num$(PNUM)+"]ISSVLTCOD" With PVLT
Assign "[M:TVM"+num$(PNUM)+"]ISSVLT2"   With PVLT

Case PVLT
    When 1, 2 : # standard ou standard actualisé
        Assign "[M:TVM"+num$(PNUM)+"]RCPVLTCOD" With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]RCPVLT2"   With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNNEG"    With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNNEG2"   With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNPOS"    With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNPOS2"   With PVLT
    When Default
        Assign "[M:TVM"+num$(PNUM)+"]RCPVLTCOD" With 7
        Assign "[M:TVM"+num$(PNUM)+"]RCPVLT2"   With 7

        Assign "[M:TVM"+num$(PNUM)+"]CUNNEG"    With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNNEG2"   With PVLT
        Assign "[M:TVM"+num$(PNUM)+"]CUNPOS"    With 4
        Assign "[M:TVM"+num$(PNUM)+"]CUNPOS2"   With 4
Endcase
End

######################################################################################
Subprog AM_FLGTCM2(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Actzo [M:TCM1]ISS2
        Actzo [M:TCM1]DETISS2
    Else
        Diszo [M:TCM1]ISS2
        Effzo [M:TCM1]ISS2
        Grizo [M:TCM1]DETISS2
        Effzo [M:TCM1]EXC2
        Raz [M:TVM2]
    Endif
Affzo [M:TCM1]
End


######################################################################################
Subprog AM_ISS1(VALEUR)
Variable Integer VALEUR

Call INITVLT(VALEUR,1)
Gosub CTRVLT
End

######################################################################################
Subprog AM_ISS2(VALEUR)
Variable Integer VALEUR

Call INITVLT(VALEUR,2)
Gosub CTRVLT

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TCM1) 20/10/2006 09:29:32 (CCC)
######################################################################################
Subprog AS_ISS1(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,263,1))
    If func SUBTVM.AUZVLT(I,2,0,0,"")=0
        GMENLOC(I)=1
    Endif
Next
End

Subprog AS_ISS2(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,263,1))
    If func SUBTVM.AUZVLT(I,2,0,0,"")=0
        GMENLOC(I)=1
    Endif
Next
End

######################################################################################
## Section automatically added (screen TCM1) 03/23/2017 06:28:48 (ALMON)
######################################################################################
# Issue X3-26713 23/03/2017 ALMON  : Start : Set PJM Methods depending on PJMBUDMAN
Subprog AM_PJMBUDMAN(VALEUR)
Variable Integer VALEUR
  Call EVALUATE_PJMBUDMAN(VALEUR)
End

######################################################################################
## Section automatically added (screen TCM1) 03/27/2017 08:37:31 (ALMON)
######################################################################################
# Issue X3-26713 23/03/2017 ALMON : Start : Trap changes on these fields
Subprog AM_PJMBUDVLTCOD(VALEUR)
Variable Integer VALEUR

  If VALEUR > 0 Then
    If [M:TCM1]PJMBUDVLT2 = 0 Then
      [M:TCM1]PJMBUDVLT2 = VALEUR
      Affzo [M:TCM1]PJMBUDVLT2
    Endif
  Endif
End
# Issue X3-26713 23/03/2017 ALMON : End

######################################################################################
# Issue X3-26713 23/03/2017 ALMON : Start : Trap changes on these fields
Subprog AM_PJMBUDVLT2(VALEUR)
Variable Integer VALEUR

  If VALEUR > 0 Then
    If [M:TCM1]PJMBUDVLTCOD = 0 Then
      [M:TCM1]PJMBUDVLTCOD = VALEUR
      Affzo [M:TCM1]PJMBUDVLTCOD
    Endif
  Endif
End
# Issue X3-26713 23/03/2017 ALMON : End

######################################################################################
$TRTCOP
# TABLE contient la valeur du paramètre 2 de l'action ACOPIE (ici [M]VLTCOD)
If [M]DOSORG=nomap
 Local File TABCOSTMVT [TVM1]
 Local File TABCOSTMET [TCM1]
Else
 Local File =[M]DOSORG+".TABCOSTMVT" [TVM1]
 Local File =[M]DOSORG+".TABCOSTMET" [TCM1]
Endif
If [M]DOSDES=nomap
 Local File TABCOSTMVT [TVM2]
 Local File TABCOSTMET [TCM2]
 Local File ATABDIV    [ADI2]
Else
 Local File =[M]DOSDES+".TABCOSTMVT" [TVM2]
 Local File =[M]DOSDES+".TABCOSTMET" [TCM2]
 Local File =[M]DOSDES+".ATABDIV"    [ADI2]
Endif
OK = 1
If GTRACE=""
 Read [TCM2]TCM0 = TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [TVM1], [TCM1], [TVM2], [TCM2], [ADI2]
Return

$TR_COP
Local Integer LCOP
GOK = 1
Trbegin [TVM2] , [TCM2]
 Delete [TCM2] Where VLTCOD=TABLE
 Delete [TVM2] Where VLTCOD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABCOSTMET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TCM2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TCM1] Where VLTCOD=TABLE
  [F:TCM2] = [F:TCM1]
  If dim([F:TCM2]UPDUSR)>0 : [F:TCM2]UPDUSR = GUSER : Endif
  If dim([F:TCM2]UPDDAT)>0 : [F:TCM2]UPDDAT = date$ : Endif
  If dim([F:TCM2]UPDTIM)>0 : [F:TCM2]UPDTIM = time  : Endif
  Write [TCM2]
  If fstat
   GOK=0 : Call FSTA("TCM2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [TVM1] Where VLTCOD=TABLE
    LCOP=1
    If [F:TVM1]TRSCOD<>""
        Read [ADI2]CODE=14;[F:TVM1]TRSCOD
        If fstat
            Call MESSAGE([F:TVM1]TRSCOD-":"-mess(375,184,1)) From GESECRAN
            LCOP=0
        Endif
    Endif
    If LCOP
        [F:TVM2] = [F:TVM1]
        Write [TVM2]
        If fstat
         GOK=0 : Call FSTA("TVM2") From GLOCK : Break
        Endif
    Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

