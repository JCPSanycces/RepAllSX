#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
# Traitement : SUBRBBVAL
# -----------------------------------------------------------------------------------
# Description: Releves belges - Validation d'un releve
# -----------------------------------------------------------------------------------
######################################################################################
#**
#* PARAM(1) = statement number
#* PARAM(2) = line number (=0: all lines)
#*!
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = "BE00200000038"
PARAM(2) = "0"
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBRBBVAL","",1,"SPERBBVAL") From GTRAITE
End

$ACTION
Case ACTION
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

$CONTROLE
If !GSERVEUR
  Local Integer OK
  OK=2
  If val(PARAM(2))<>0
    Call OUINON(mess(191,121,1)-PARAM(1)-mess(61,100,1)-PARAM(2),OK) From GESECRAN
  Else
    Call OUINON(mess(191,121,1)-PARAM(1),OK) From GESECRAN
  Endif
  If OK=2
    TMP = 1  :##--tempon/tempoff
  Else
    FIN=1
  Endif
Endif
Return

$EXEC
Local Integer WSTAT
Local Char WCRIT(100)
[L]WSTAT=0
If !GSERVEUR
 ## Validation du relevé
 Call OUVRE_TRACE(mess(191,121,1) - PARAM(1))From LECFIC
Endif

If !clalev([F:RBD2]) : Local File RBKBELDET [RBD2] : Endif
[L]WCRIT="RBKNUM='"+PARAM(1)+"' & STATUT=2"
If val(PARAM(2))<>0
  [L]WCRIT-="& RBKLIN="+PARAM(2)
Else
  [L]WCRIT-="& VALFLG=2"
Endif

For [F:RBD2]RBD0 Where evalue([L]WCRIT)
  Call ECR_TRACE(mess(191,121,1)-[F:RBD2]RBKNUM-mess(61,100,1)-num$([F:RBD2]RBKLIN),0) From GESECRAN
  If [F:RBD2]FRMNUM= ""
    Call RBKVALPAY([F:RBD2]RBKNUM, [F:RBD2]RBKLIN, [L]WSTAT) From SUBRBB4
  Else
    Call RBKVALFRM([F:RBD2]RBKNUM, [F:RBD2]RBKLIN, [L]WSTAT)  From SUBRBB5
  Endif
Next

If !GSERVEUR
  Call FERME_TRACE From LECFIC
  TRA=1
Endif
Return

