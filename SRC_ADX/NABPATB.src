#<AdxTL>@(#)3.0.0.0 $Revision$
####################################################################################
# Program Name: NABPATB Aged Trial Balance
####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End
####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "asofdate"
    ASOFDATE = [L]VALEUR
   When "societe"  # 94221
    SOCIETE = [L]VALEUR  # 94221
   When "ledger"
    LEDGER = [L]VALEUR
   When "sitedeb"
    SITEDEB = [L]VALEUR
   When "sitefin"
    SITEFIN = [L]VALEUR
   When "coldeb"
    COLDEB = [L]VALEUR
   When "colfin"
    COLFIN = [L]VALEUR
   When "tiersdeb"
    TIERSDEB = [L]VALEUR
   When "tiersfin"
    TIERSFIN = [L]VALEUR
   When "datebase"
    DATEBASE = [L]VALEUR
   When "bprtype"
    BPRTYPE = [L]VALEUR
   When "summary"
    SUMMARY = [L]VALEUR
   When "namesort"
    NAMESORT = [L]VALEUR
   When "txncur"
    TXNCUR = [L]VALEUR
   When "rptcur"
    RPTCUR = [L]VALEUR
   When "numedt"
    [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
 Endcase
 Endif
Next



Lock [ARM]
   Delete[ARM] Where [ARM]NUMREQ=[L]NUMREQ | CREDAT<date$-7 | ([ARM]CREUSR=GUSER & [ARM]RPTCOD = "NA-BPATB")
Unlock [ARM]

# Write the ARM Records
# Gosub ARM_LOOP # 96878
# 96878.n I removed the preprocessor routine here and added back the Record selection in the Crystal Report
# 96878.n Additional checks (GACCENTRY.FLGREP<>2 (carry forward) and GACCENTRY.FLGCLE<>2 (closed)) were added to the Records selection
# 96878.n Therefore these selections now match the BALAGEGRP record selection

End
####################################################################################
$OUVRE

If !clalev([F:ARM])  : Local File AREPORTM    [ARM]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL    [JOU]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD  [DAE]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT  [GTE]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL    [JOU]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER    [BPR]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY   [HAE]  : Endif
If !clalev([F:CPY])  : Local File COMPANY     [CPY]  : Endif

If !clalev([F:DUD2])  : Local File GACCDUDATE  [DUD2]  : Endif
If !clalev([F:DAE2])  : Local File GACCENTRYD  [DAE2]  : Endif


Local Char    LTYP(3)

Return
####################################################################################
$DECLARE

Local Char    PARAM(30),VALEUR(30),ETAT(15),USR(15),XNUM(35)
Local Date    DTEDEB,DTEFIN
Local Integer NUMREQ,WNUMLIG,PERDEB,PERFIN,XRET

Return
####################################################################################
$ARM_LOOP
Local Char SAV_CPY # 95807.n

#{@RECSEL} = 1 and  # 93042.o from Crystal
#{GACCDUDATE.DUDSTA_0}=2 and                            DUD
# 94221.start
#{GACCDUDATE.CPY_0} = {?SOCIETE} and                    DUD
# 94221.fin
#{BPARTNER.BPRNUM_0} IN {?TIERSDEB} To {?TIERSFIN} and  BPR
#{GACCDUDATE.FCY_0} IN {?SITEDEB} To {?SITEFIN} and     DUD
#{GACCDUDATE.SAC_0} IN {?COLDEB} To {?COLFIN} and       DUD
#{GACCENTRYD.ACCDAT_0} <= {?ASOFDATE} and               DAE
#{GACCDUDATE.BPRTYP_0} = {?BPRTYPE} and                 DUD
#{GACCENTRYD.LEDTYP_0} = {?LEDGER}                      DAE

## 94221.o Filter [DUD] Where [DUD]DUDSTA=2 & [DUD]FCY >= SITEDEB and [DUD]FCY <= SITEFIN and [DUD]SAC >= COLDEB and
## 94221.o & [DUD]SAC <= COLFIN and [DUD]BPRTYP = BPRTYPE and [DUD]BPR >= TIERSDEB and [DUD]BPR <= TIERSFIN
Filter [DUD] Where [DUD]DUDSTA=2 & [DUD]CPY = SOCIETE and [DUD]FCY >= SITEDEB and [DUD]FCY <= SITEFIN and [DUD]SAC >= COLDEB and
& [DUD]SAC <= COLFIN and [DUD]BPRTYP = BPRTYPE and [DUD]BPR >= TIERSDEB and [DUD]BPR <= TIERSFIN

Filter [DAE] Where [DAE]ACCDAT <= num$(ASOFDATE) and [DAE]LEDTYP = val(LEDGER)
Filter [HAE] Where [HAE]NUM = [DUD]NUM
Filter [CPY] Where [CPY]CPY=[DUD]CPY

Link [DUD] With [DAE]DAE0(3)=[DUD]TYP;[DUD]NUM;[DUD]LIG, [F:HAE]HAE0=[DUD]TYP;[DUD]NUM, [F:GTE]GTE0(1)=[DUD]TYP As [LNK]
& Where [DAE]LEDTYP = val(LEDGER) Order By Key DUD0

For [LNK]

If XNUM = [DUD]NUM | [DAE]ACCDAT > num$(ASOFDATE) : Goto SKIP : Endif

If func MTCCHECK([DUD]NUM,[DUD]TYP,[DUD]FCY,2,[DUD]SAC,[DUD]LIG,[DUD]BPRTYP,ASOFDATE,XRET)=0: Goto SKIP : Endif # recsel

If SAV_CPY<>[DUD]CPY : Call LEC_CPY([DUD]CPY) From CPTLEC : SAV_CPY=[DUD]CPY : Endif # Read CPY # 95807.n and moved line down after MTCCHECK
##Call LEC_CPY([DUD]CPY) From CPTLEC # Read CPY # 95807.o

#Filter [GTE] Where [GTE]TYP=[DUD]TYP & [GTE]LEG=[CPY]LEG  # 95285.o
Filter [GTE] Where [GTE]TYP=[DUD]TYP & [GTE]LEG=[CPY]LEG and [GTE]PER=1 # 95285.n

    Read [GTE] First
      If fstat
        fstat=0
        Filter [GTE] Where [GTE]TYP=[DUD]TYP and [GTE]PER=1 # 95285.n
        Read [GTE] First
      Endif
    If !fstat
  # 95285.so
  #Filter [JOU] Where [JOU]JOU=[GTE]DEFJOU # Skip carry over journals so No need to check TYP
  # Read [JOU] First
   #If !fstat and [JOU]TYP=7 : Infbox [DUD]NUM : Endif
  # If (!fstat & [JOU]TYP<>7) | fstat # FSTAT needed since DEFJOU not a mandatory field
     Gosub WRITE_RECORD
  # Endif
  # Filter [JOU]   # 95285.eo
   Endif
$SKIP
XNUM = [DUD]NUM
Next

Filter [DUD]
Filter [BPR]
Filter [DAE]

Return
####################################################################################
$WRITE_RECORD

Readlock [ARM]ARM0=[L]NUMREQ;GUSER;[L]ETAT;[L]WNUMLIG

If fstat # New record

GOK = 1
Trbegin [ARM]
  Raz [F:ARM]
  [F:ARM]USR     = GUSER
  [F:ARM]RPTCOD  = [L]ETAT
  [F:ARM]NUMREQ  = [L]NUMREQ
  [F:ARM]NUMLIG  = [L]WNUMLIG
  [F:ARM]CLEA1 =  [DUD]NUM
  [F:ARM]CLEN1 =  [JOU]TYP
  [F:ARM]CREDAT  = date$
  WNUMLIG += 1
  Write [ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Rollback : Endif

If fstat
  Rollback
Else
  Commit
Endif

Endif

Filter [ARM]
Return
#########################################################################################################
Funprog MTCCHECK(XNUM,XTYP,XSITE,XSTA,XSAC,XLIG,XBPRTYP,XDAT,XRET)
Value Char XNUM,XSITE,XSAC,XTYP
Value Date XDAT
Value Integer XSTA, XBPRTYP, XLIG, XRET

Filter [DAE2] Where [DAE2]ACCNUM=XNUM and [DAE2]TYP = XTYP

Link [DUD2] With [DAE2]DAE0(3)=XTYP;XNUM;XLIG As [LNK2]

Read [LNK2] First
If !fstat
  If [DAE2]MTC ="" : End  1 : Endif # 95807.n moved line up to here
  If [DAE2]MTC >= '65' & [DAE2]MTC <= '96' & [DAE2]MTCDATMAX > XDAT
    End 1
  Else If [DAE2]MTC > '96'
    If [DAE2]MTCDATMAX > XDAT
      End 1
    Else If [DUD2]AMTCUR - [DUD2]PAYCUR = 0
      End 0
    Else
      End 1
    Endif
    Endif
  Endif
  ##If [DAE2]MTC ="" : End  1 : Endif # 95807.o moved line up
  Endif
Endif

End XRET
####################################################################################################
