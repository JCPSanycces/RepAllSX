Subprog SETUP(DOSSIER)
Value Char DOSSIER

#If !GSERVEUR
# Call OUVRE_TRACE(mess(00004,00036,1)-mess(00002,00107,1)) From LECFIC #Transaction Deactivation
#Endif

Local Char    TRANSAC(20)
Local Integer NBREC

Gosub PAYTRS
Gosub PURTRS
Gosub SALTRS
Gosub STKTRS
Gosub BENCHTRS
Gosub PAY_ATTRIBUTE
Gosub MAJLEG

#If !GSERVEUR
# Call FERME_TRACE From LECFIC
#Endif

End

#----------------
$PAYTRS
Local File =DOSSIER+".TABPAYTYP" [TPY]
TRANSAC="PAY_TRANSACTION"
Filter [TPY] Where
& ([F:TPY]LEG='FRA' & find([F:TPY]PAYTYP,'CBOR','CLCR','CPREL','CTRA','FVIRN','FVIRP','FVIRV','BSI',
& 'FLCR','FPRL','FTIP','FTRT','FVIRM','CTRT','FBORB','FBORP','FCBR','FESP','FVIRI')>0)
& or [F:TPY]PAYTYP='SDD'


Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [TPY]
 NBREC = 0
 For [TPY]
  NBREC += 1
  GCLE = num$([F:TPY]PAYTYP)-num$([F:TPY]LEG)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:TPY]ENAFLG = 1
  Rewrite [TPY]
  If fstat
    GOK = 0 : Call FSTA("TPY") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return


#----------------
$PURTRS
Local File =DOSSIER+".PURTRS" [PTR]
TRANSAC='PUR_TRANSACTION'
Filter [PTR] Where find([F:PTR]PTRTYP,1,2,3,5,6,7,8,9)>0 & find([F:PTR]PTRNUM,'STD','VT')>0

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [PTR]
 NBREC = 0
 For [PTR]
  NBREC += 1
  GCLE = num$([F:PTR]PTRTYP)-num$([F:PTR]PTRNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:PTR]ENAFLG = 1
  Rewrite [PTR]
  If fstat
    GOK = 0 : Call FSTA("PTR") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$SALTRS
Local File =DOSSIER+".SALTRS" [SLT]
TRANSAC='SAL_TRANSACTION'

Filter [SLT] Where (find([F:SLT]STRTYP,1,2,3,4,5,6,7)>0 & [F:SLT]STRNUM ='STD')
& or ([F:SLT]STRTYP=5 & [F:SLT]STRNUM ='STA')

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [SLT]
 NBREC = 0
 For [SLT]
  NBREC += 1
  GCLE = num$([F:SLT]STRTYP)-num$([F:SLT]STRNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:SLT]ENAFLG = 1
  Rewrite [SLT]
  If fstat
    GOK = 0 : Call FSTA("SLT") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$STKTRS
Local File =DOSSIER+".STKTRS" [SRT]
TRANSAC='STK_TRANSACTION'

Filter [SRT] Where
& (find([F:SRT]SRTNUM,'FOM','LOM','ENT','VT','REP','CHU','SUR','TRF','TRS','TSA','CHS','CHG','REB',
& 'ISS','DEC','POS','RGP','ASS','DES')>0) or (find([F:SRT]SRTTYP,1,2,3,6,8,12) & [F:SRT]SRTNUM ='STD')

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [SRT]
 NBREC = 0
 For [SRT]
  NBREC += 1
  GCLE = num$([F:SRT]SRTTYP)-num$([F:SRT]SRTNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:SRT]ENAFLG = 1
  Rewrite [SRT]
  If fstat
    GOK = 0 : Call FSTA("SRT") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

#----------------
$BENCHTRS
Local File =DOSSIER+".BENCHTRS" [BTS]
TRANSAC='BENCH_TRANSACTION'

Filter [BTS] Where
& (find([F:BTS]BTSNUM,'PLN','POS','REA','SST','STD','SUB','WOF','WOS','CTR','INR','INT')>0 & [F:BTS]BTSTYP =51)
& or [F:BTS]BTSTYP =52 or [F:BTS]BTSTYP =53

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [BTS]
 NBREC = 0
 For [BTS]
  NBREC += 1
  GCLE = num$([F:BTS]BTSTYP)-num$([F:BTS]BTSNUM)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:BTS]ENAFLG = 1
  Rewrite [BTS]
  If fstat
    GOK = 0 : Call FSTA("BTS") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return


#----------------
$PAY_ATTRIBUTE
Local File =DOSSIER+".GACCDENCOD" [CDA]
TRANSAC="PAY_ATTRIBUTE"
Filter [CDA] Where [F:CDA]LEG="FRA" & [F:CDA]COD='PAY'

Call DEBTRANS From GLOCK
Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

GOK = 1
Trbegin [CDA]
 NBREC = 0
 For [CDA]
  NBREC += 1
  GCLE = num$([F:CDA]COD)-num$([F:CDA]LEG)
  Call ECR_TRACE(mess(33,141,1)-GCLE,0) From GESECRAN
  [F:CDA]ENAFLG = 1
  Rewrite [CDA]
  If fstat
    GOK = 0 : Call FSTA("CDA") From GLOCK : Break
  Endif
Next
Filter
If GOK<1 : Goto AB_TR1 : Endif
Commit
Call ECR_TRACE(TRANSAC-num$(NBREC)-mess(192,124,1),0) From GESECRAN

Return

$AB_TR1
Rollback
Return

#----------------
$MAJLEG

Local File ADOSSIER [ZADS]
Local Integer ZOK
TRANSAC="MAJ_LEG"

Call ECR_TRACE(TRANSAC-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

Read [ZADS]DOSSIER = [L]DOSSIER
If !fstat
 ZOK = func COPLEG([F:ZADS]DOSSIER,[F:ZADS]DOSREF,"FRA")
Endif

Return

#**
#*
#*
#* @param DOSSIER
#* @param DOSREF
#* @param LEG
#*!
Funprog COPLEG(DOSSIER,DOSREF,LEG)
Value Char DOSSIER()
Value Char DOSREF()
Value Char LEG()

Local File =[L]DOSSIER+".ADOVAL" [ADW]
Local File =[L]DOSREF+".ADOVAL" [LEC]

Local Integer IFLOG

IFLOG = adxlog

If IFLOG=0
  Trbegin [LEC],[ADW]
Endif

For [LEC] Where CMP='*' and FCY=LEG
  Read [ADW]ADW1=[LEC]PARAM;"";""
  If fstat=0
    If [ADW]VALEUR<>[LEC]VALEUR
        [ADW]=[LEC]
        [ADW]CMP="" : [ADW]FCY=""
        Rewrite [ADW]
        Break (fstat<>0)
    Endif
  Else
      [ADW]=[LEC]
      [ADW]FCY=""
      [ADW]CMP=""
      Write [ADW]
      Break (fstat<>0)
  Endif
Next

If fstat<>0
  If IFLOG=0
    Rollback
  Endif
  End 1
Endif

If IFLOG=0
  Commit
Endif

End 0

