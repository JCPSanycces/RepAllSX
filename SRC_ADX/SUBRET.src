######################################################################################

#Ajout en clic droit 'Chargement' (invisible si fiche validée)
Subprog IB_NBVRVL
If [M:RET0]STATUT = 3 :  Raz [V]GBOUT1 : End : Endif
End

#Ajout en clic droit 'Chargement'
Subprog B1_NBVRVL
Local Char ZB1 (3)
ZB1="1"
Call CL_LOAD (ZB1)
End


#Bouton Icône 'Chargement'
Subprog CL_LOAD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
OK=2
If [M:RET4]NBVRVL > 0
   # mess(161,10702,1) : Attention, des données sont présentes, elles seront effacées.
   # mess(172,100,1) : Voulez-vous-poursuivre le traitement en cours
   OK=1
   Call OUINON(mess(161, 10702, 1)+"\"+mess(172, 100, 1),OK) From GESECRAN
Endif
If OK<>2 : End : Endif
Gosub SETNOL
Gosub LOAD_VARVAL
End

Subprog C_NBVRVL
#MIPEA - 2016-07-04 - REQ 114309 US128 - START
# Table prohibited for casual workers
Call LECTURE("EML",[M]VMATSEL,"") From CONTOBJ
If ([M:RET0]STATUT=3 | (GINTMT & [F:ID]FLGINT=2)) & !adxgtb
 mkstat=2 : End
Endif
#  If [M:RET0]STATUT=3 & !adxgtb
#   mkstat=2 : End
#  Endif
#MIPEA - 2016-07-04 - REQ 114309 US128 - END
End

Subprog AM_NBVRVL
Local Char IDSALCTRLIG([V]GLONEML+1+[V]GLONHRCTR+9)
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
Local Integer RANG

  If status = 73 | status = 65 | status = 83 | status = 68
    IDSALCTRLIG=func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP), nolign)
    IDSALCTR=func SUBRET.GET_IDSALCTR([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP))

    If status=73  :#insert line
      [L]RANG = find([L]IDSALCTR, [M:RET4]TIDSALCTRREC)
      [L]RANG += nolign-1
      Insa RANG-1,1 NBRVL
      NBRVL+=1
      [M:RET4]LIG(RANG-1) = nolign
      Call UPDLIG([L]IDSALCTR, RANG, "+", 1)
      [M:RET4]TIDSALCTRREC(RANG-1) = [L]IDSALCTR
      [M:RET4]TIDSALCTRLIG(RANG-1)=func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP), nolign)
    Else
      #suppression  d'une ou plusieurs lignes (status =65 ou 83 ou 68)
      #on va commencer par modifier la zone LIG
      [L]RANG = find([L]IDSALCTRLIG, [M:RET4]TIDSALCTRLIG)
      [L]RANG -= 1
      If status = 65
        Call UPDLIG([L]IDSALCTR, [L]RANG, "-", 1)
        Dela [L]RANG,1 NBRVL
        NBRVL-=1
      Else
        Call UPDLIG([L]IDSALCTR, [L]RANG, "-", (nolign1-nolign)+1)
        Dela [L]RANG,(nolign1-nolign)+1 NBRVL
        NBRVL-=(nolign1-nolign)+1
      Endif
      End
    Endif
  Endif
End

Subprog APRES_NBVRVL
Local Char IDSALCTRLIG([V]GLONEML+1+[V]GLONHRCTR+9)
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
Local Integer RANG

  #si on est en suppression de ligne, rien à reporter dans le tableau invisible
  If status = 65 | status = 83 | status = 68 : End : Endif

  IDSALCTRLIG=func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP), nolign)
  IDSALCTR=func SUBRET.GET_IDSALCTR([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP))

  [L]RANG = find([L]IDSALCTRLIG, [M:RET4]TIDSALCTRLIG)
  [L]RANG -= 1

  If [L]RANG < 0
    #on a ajouté une ligne
    If [M:RET4]VVARCOD(nolign-1) = "" : End : Endif

    [L]RANG = find([L]IDSALCTR, [M:RET4]TIDSALCTRREC)
    [L]RANG += nolign-1
    If [L]RANG>0 : [L]RANG -=1 : Endif
    Insa RANG,1 NBRVL
    NBRVL+=1
    [M:RET4]LIG(RANG) = nolign-1
    [M:RET4]TIDSALCTRREC(RANG) = [L]IDSALCTR
    Call UPDLIG([L]IDSALCTR, RANG, "+", 1)
  Endif

  [M:RET4]TYPRVL([L]RANG) = [M:RET4]VTYPRVL(nolign-1)
  [M:RET4]VARCOD([L]RANG) = [M:RET4]VVARCOD(nolign-1)
  [M:RET4]TYP([L]RANG)    = [M:RET4]VTYP(nolign-1)
  [M:RET4]STRPAY([L]RANG) = [M:RET4]VSTRPAY(nolign-1)
  [M:RET4]ENDPAY([L]RANG) = [M:RET4]VENDPAY(nolign-1)
  [M:RET4]STRBUL([L]RANG) = [M:RET4]VSTRBUL(nolign-1)
  [M:RET4]ENDBUL([L]RANG) = [M:RET4]VENDBUL(nolign-1)
  [M:RET4]VALORI([L]RANG) = [M:RET4]VVALORI(nolign-1)
  [M:RET4]VALDEN([L]RANG) = [M:RET4]VVALDEN(nolign-1)
End

#Type variable du tableau limité à "variable" et "taux d'AT"
Subprog AS_VTYPRVL(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1
End

Subprog AM_VTYPRVL(VALEUR)
Variable Integer VALEUR
[M:RET4]VTYPRVL(nolign-1)=VALEUR
Call CHARGE_COD([M:RET4]VTYPRVL(nolign-1),[M:RET4]CODTYP(nolign-1),[M:RET4]LONG(nolign-1),[M:RET4]OPT(nolign-1))
End

Subprog C_VVARCOD(VALEUR)
Variable Char    VALEUR()
If [M:RET4]VTYPRVL(nolign-1)=1
 Call CONTSEL([M:RET4]CODTYP(nolign-1),"R",VALEUR,GCURLEG,mkstat) From CONTOBJ
 Else
  Call CONTSEL([M:RET4]CODTYP(nolign-1),"",VALEUR,GCURLEG,mkstat) From CONTOBJ
 Endif
If mkstat : End : Endif
End

Subprog AM_VVARCOD(VALEUR)
Variable Char    VALEUR()
[M:RET4]VVARCOD(nolign-1)=VALEUR
Call CHARGE_DES([M:RET4]VTYPRVL(nolign-1),[M:RET4]CODTYP(nolign-1),[M:RET4]VVARCOD(nolign-1),[M:RET4]VARDES(nolign-1))
End

Subprog AS_VSTRPAY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If !clalev([F:VEPW]): Local File VALEMP [VEPW] : Endif
Filter [VEPW] Where EMP=[M:RET4]REFNUM(VNOLEMP) & CTRNUM=[M:RET4]CTRNUM(VNOLEMP) & CTRDAT=[M:RET4]DATLSTREV(VNOLEMP)
&                 & STRDAT>=[M:RET1]DATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
Read [VEPW]VEP5 First
Filter [VEPW]
If !fstat
 VALEUR=[F:VEPW]PYRDAT
 [M:RET4]VSTRBUL(nolign-1)=[F:VEPW]BUL
Endif
End

Subprog C_VSTRPAY(VALEUR)
Variable Date    VALEUR
#DBA : Suppression du param envoyant la date de contrat
Call SELBUL([M:RET4]REFNUM(VNOLEMP),VALEUR,[M:RET4]CTRNUM(VNOLEMP),[0/0/0],[M:RET4]VSTRBUL(nolign-1)) From DIVPAYE
If [M:RET4]VSTRBUL(nolign-1) = ""
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 2 : End
Else
 If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
 Read [VEPW]VEP5=[M:RET4]VSTRBUL(nolign-1)
 If fstat | [VEPW]STRDAT<[M:RET1]DATEFF | [VEPW]STA<=1 | [VEPW]RVS=2 | [VEPW]RVSDAT<>[0/0/0]
  GMESSAGE = mess(83,123,1)   : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_VSTRPAY(VALEUR)
Variable Date    VALEUR

#on récupère la valeur d'origine
If [M:RET4]VTYPRVL(nolign-1)=1 :#variable
  Call GETVARVAL([M:RET4]LEGCPY(VNOLEMP), [M:RET4]ETRFCY(VNOLEMP), [M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP),
&                 VALEUR, [M:RET4]VSTRBUL(nolign-1), [M:RET4]VVARCOD(nolign-1), [M:RET4]VVALORI(nolign-1),[M:RET4]VTYP(nolign-1))
Elsif [M:RET4]VTYPRVL(nolign-1)=2 :#tx at
  Call GETTXATVAL([M:RET4]VVARCOD(nolign-1), VALEUR, [M:RET4]VVALORI(nolign-1), [M:RET4]VTYP(nolign-1))
Endif
Affzo [M:RET4]VSTRBUL(nolign-1)
Affzo [M:RET4]VVALORI(nolign-1)
End

Subprog AS_VENDPAY(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
Filter [VEPW] Where EMP=[M:RET4]REFNUM(VNOLEMP) & CTRNUM=[M:RET4]CTRNUM(VNOLEMP) & CTRDAT=[M:RET4]DATLSTREV(VNOLEMP)
&                 & STRDAT>=[M:RET1]DATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
Read [VEPW]VEP5 Last
Filter [VEPW]
If !fstat
 VALEUR=[F:VEPW]PYRDAT
 [M:RET4]VENDBUL(nolign-1)=[F:VEPW]BUL
Endif
End

Subprog C_VENDPAY(VALEUR)
Variable Date    VALEUR
#DBA : Suppression du param envoyant la date de contrat
Call SELBUL([M:RET4]REFNUM(VNOLEMP),VALEUR,[M:RET4]CTRNUM(VNOLEMP),[0/0/0],[M:RET4]VENDBUL(nolign-1)) From DIVPAYE
If [M:RET4]VENDBUL(nolign-1) = ""
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 2 : End
Else
 If !clalev([F:VEPW]): Local File VALEMP      [VEPW] : Endif
 Read [VEPW]VEP5=[M:RET4]VENDBUL(nolign-1)
 If fstat | [VEPW]STRDAT<[M:RET1]DATEFF | [VEPW]STA<=1 | [VEPW]RVS=2 | [VEPW]RVSDAT<>[0/0/0]
  GMESSAGE = mess(83,123,1)    : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_VENDPAY(VALEUR)
Variable Date    VALEUR

Affzo [M:RET4]VENDBUL(nolign-1)
#on récupère la valeur destination (si vide sinon l'utilisateur l'a peut être déjà modifiée)
If [M:RET4]VVALDEN(nolign-1)>0 : End : Endif

If [M:RET4]VTYPRVL(nolign-1)=1 :#variable
  Call GETVARVAL([M:RET4]LEGCPY(VNOLEMP), [M:RET4]ETRFCY(VNOLEMP), [M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP),
&                 VALEUR, [M:RET4]VENDBUL(nolign-1), [M:RET4]VVARCOD(nolign-1), [M:RET4]VVALDEN(nolign-1),[M:RET4]VTYP(nolign-1))
Elsif [M:RET4]VTYPRVL(nolign-1)=2 :#tx at
  Call GETTXATVAL([M:RET4]VVARCOD(nolign-1), VALEUR, [M:RET4]VVALDEN(nolign-1), [M:RET4]VTYP(nolign-1))
Endif
Affzo [M:RET4]VVALDEN(nolign-1)
End

#Charge (ou recharge) les variables définit dans le tableau "Variables" pour le matricule sélectionné.
#####################################
$LOAD_VARVAL
  Local Integer NOLVRA
  Local Char CURIDSALCTR(40)
  Local Integer NOLLIG

  [L]CURIDSALCTR=func SUBRET.GET_IDSALCTR([M:RET4]VMATSEL, [M:RET4]VCTRSEL)
  [L]NOL=[M:RET4]VNOLEMP
  #Par sécurité si pas de focus sur tableau des salariés
  If NOL<1 : NOL=0 : Endif

  If find([L]CURIDSALCTR, [M:RET4]TIDSALCTRREC)
    Gosub RAZRET4
  Endif

  nolign=[M:RET4]NBRVL+1
  [L]NOLLIG=1
  For [L]NOLVRA = 0 To [M:RET2]NBVRA-1
    If [M:RET2]TYPREV(NOLVRA)=1 :#type=Variable
      Gosub LOAD_VARIABLE_VALUE
    Elsif [M:RET2]TYPREV(NOLVRA)=2
      Gosub LOAD_TXAT_VALUE
    Endif
  Next

  [M:RET4]NBRVL=nolign-1

  #Maj tableau vu par l'utilisateur
  nolign=[L]NOL+1
  Call AV_NBEML

  If [M:RET4]NBVRVL>0
    mkstat=4
  Endif
Return

#Suppression du tableau de travail des enregistrements concernant un matricule
$RAZRET4
  Local Integer I, VNBRVL
  If !clalev([M:RED4]) : Local Mask RET4 [M:RED4]  : Endif

  For I=0 To [M:RET4]NBRVL-1
    [M:RED4]LIG(I)          =[M:RET4]LIG(I)
    [M:RED4]TYPRVL(I)       =[M:RET4]TYPRVL(I)
    [M:RED4]VARCOD(I)       =[M:RET4]VARCOD(I)
    [M:RED4]TYP(I)          =[M:RET4]TYP(I)
    [M:RED4]STRPAY(I)       =[M:RET4]STRPAY(I)
    [M:RED4]ENDPAY(I)       =[M:RET4]ENDPAY(I)
    [M:RED4]STRBUL(I)       =[M:RET4]STRBUL(I)
    [M:RED4]ENDBUL(I)       =[M:RET4]ENDBUL(I)
    [M:RED4]VALORI(I)       =[M:RET4]VALORI(I)
    [M:RED4]VALDEN(I)       =[M:RET4]VALDEN(I)
    [M:RED4]TIDSALCTRREC(I) =[M:RET4]TIDSALCTRREC(I)
    [M:RED4]TIDSALCTRLIG(I) =[M:RET4]TIDSALCTRLIG(I)
  Next I
  [M:RED4]NBRVL=[M:RET4]NBRVL

  Effzo [M:RET4]50
  VNBRVL=0

  For I=0 To [M:RED4]NBRVL-1
    If [M:RED4]TIDSALCTRREC(I)<>[L]CURIDSALCTR
      [M:RET4]LIG(VNBRVL)          =[M:RED4]LIG(I)
      [M:RET4]TYPRVL(VNBRVL)       =[M:RED4]TYPRVL(I)
      [M:RET4]VARCOD(VNBRVL)       =[M:RED4]VARCOD(I)
      [M:RET4]TYP(VNBRVL)          =[M:RED4]TYP(I)
      [M:RET4]STRPAY(VNBRVL)       =[M:RED4]STRPAY(I)
      [M:RET4]ENDPAY(VNBRVL)       =[M:RED4]ENDPAY(I)
      [M:RET4]STRBUL(VNBRVL)       =[M:RED4]STRBUL(I)
      [M:RET4]ENDBUL(VNBRVL)       =[M:RED4]ENDBUL(I)
      [M:RET4]VALORI(VNBRVL)       =[M:RED4]VALORI(I)
      [M:RET4]VALDEN(VNBRVL)       =[M:RED4]VALDEN(I)
      [M:RET4]TIDSALCTRREC(VNBRVL) =[M:RED4]TIDSALCTRREC(I)
      [M:RET4]TIDSALCTRLIG(VNBRVL) =[M:RED4]TIDSALCTRLIG(I)
      VNBRVL+=1
    Endif
  Next I
  [M:RET4]NBRVL=VNBRVL
  Close Local Mask [RED4]
Return

#charge les variables de type "variable"
$LOAD_VARIABLE_VALUE
 Local Decimal VALDEF, VALVRA
 Local Integer TYPLEV
 If !clalev([F:VEPW]) : Local File VALEMP [VEPW]  : Endif

 #Récupération du n° de bulletin du bulletin de référence
# Filter [F:VEPW] Where EMP=[M:RET4]REFNUM([L]NOL) & CTRNUM=[M:RET4]CTRNUM([L]NOL) & CTRDAT=[M:RET4]DATLSTREV([L]NOL) & PYRDAT=[M:RET2]DATVAL(NOLVRA)
# Read [F:VEPW]VEP5 Last
 Filter [F:VEPW] Where EMP=[M:RET4]REFNUM([L]NOL) & CTRNUM=[M:RET4]CTRNUM([L]NOL) & PYRDAT<=[M:RET2]DATVAL(NOLVRA)
 Read [F:VEPW]VEP0 Last
 Filter [F:VEPW]
 If !fstat
  #on récupère la valeur par défaut
  Call GETVARVAL([M:RET4]LEGCPY([L]NOL), [M:RET4]ETRFCY([L]NOL), [M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL),
&                [M:RET2]DATVAL(NOLVRA), [F:VEPW]BUL, [M:RET2]VRACOD(NOLVRA), [L]VALDEF, [L]TYPLEV)

  Filter [VEPW] Where EMP=[M:RET4]REFNUM([L]NOL) & CTRNUM=[M:RET4]CTRNUM([L]NOL) & STRDAT>=[M:RET1]DATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
  For [VEPW]VEP0

   If nolign>dim([M:RET4]VARCOD)
    Break
   Endif
   Call GETVARVAL([M:RET4]LEGCPY([L]NOL), [F:VEPW]FCY, [F:VEPW]EMP, [F:VEPW]CTRNUM,
&                 [F:VEPW]PYRDAT, [F:VEPW]BUL, [M:RET2]VRACOD(NOLVRA), [L]VALVRA, [L]TYPLEV)
   If [L]VALDEF<>[L]VALVRA
    #on ajoute une ligne dans le tableau.
    [M:RET4]LIG(nolign-1)   = [L]NOLLIG
    [M:RET4]TYPRVL(nolign-1)=[M:RET2]TYPREV(NOLVRA)
    [M:RET4]VARCOD(nolign-1)=[M:RET2]VRACOD(NOLVRA)
    [M:RET4]TYP(nolign-1)=[L]TYPLEV
    [M:RET4]STRPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:RET4]ENDPAY(nolign-1)=[F:VEPW]PYRDAT
    [M:RET4]STRBUL(nolign-1)=[F:VEPW]BUL
    [M:RET4]ENDBUL(nolign-1)=[F:VEPW]BUL
    [M:RET4]VALORI(nolign-1)=[L]VALVRA
    [M:RET4]VALDEN(nolign-1)=[L]VALDEF
    [M:RET4]TIDSALCTRREC(nolign-1) = func SUBRET.GET_IDSALCTR([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL))
    [M:RET4]TIDSALCTRLIG(nolign-1) = func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL), [L]NOLLIG)
    nolign+=1 : [L]NOLLIG+=1
   Endif
  Next
  Filter [VEPW]
 Endif
 Close File [VEPW]
Return


#Charge les variables de type Taux d'AT
########################################
$LOAD_TXAT_VALUE
  Local Decimal VALDEF, VALVRA
  Local Integer TYPLEV

  If !clalev([F:CTRW]) : Local File EMPLOCTR  [CTRW] : Endif
  If !clalev([F:VEPW]) : Local File VALEMP    [VEPW]  : Endif

  #on récupère la valeur par défaut
  Call GETTXATVAL([M:RET2]VRACOD(NOLVRA), [M:RET2]DATVAL(NOLVRA), [L]VALDEF, [L]TYPLEV)

  Filter [VEPW] Where EMP=[M:RET4]REFNUM([L]NOL) & CTRNUM=[M:RET4]CTRNUM([L]NOL) & STRDAT>=[M:RET1]DATEFF & STA>1 & RVS<>2 & RVSDAT=[0/0/0]
  For [VEPW]VEP0
    If nolign>dim([M:RET4]VARCOD)
      Break
    Endif
    Read [F:CTRW]CTR0=[F:VEPW]EMP;[F:VEPW]CTRNUM;[F:VEPW]CTRDAT
      If !fstat & [F:CTRW]RSKWRK=[M:RET2]VRACOD(NOLVRA)
      Call GETTXATVAL([M:RET2]VRACOD(NOLVRA), [F:VEPW]PYRDAT, [L]VALVRA, [L]TYPLEV)
      If [L]VALVRA<>[L]VALDEF
        #on ajoute une ligne dans le tableau.
        [M:RET4]LIG(nolign-1)   = [L]NOLLIG
        [M:RET4]TYPRVL(nolign-1)=[M:RET2]TYPREV(NOLVRA)
        [M:RET4]VARCOD(nolign-1)=[M:RET2]VRACOD(NOLVRA)
        [M:RET4]TYP(nolign-1)=[L]TYPLEV
        [M:RET4]STRPAY(nolign-1)=[F:VEPW]PYRDAT
        [M:RET4]ENDPAY(nolign-1)=[F:VEPW]PYRDAT
        [M:RET4]STRBUL(nolign-1)=[F:VEPW]BUL
        [M:RET4]ENDBUL(nolign-1)=[F:VEPW]BUL
        [M:RET4]VALORI(nolign-1)=[L]VALVRA
        [M:RET4]VALDEN(nolign-1)=[L]VALDEF
        [M:RET4]TIDSALCTRREC(nolign-1) = func SUBRET.GET_IDSALCTR([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL))
        [M:RET4]TIDSALCTRLIG(nolign-1) = func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL), [L]NOLLIG)
        nolign+=1 : [L]NOLLIG+=1
      Endif
    Endif
  Next
  Filter [VEPW]
  Close File [CTRW], [VEPW]
Return

########################################
Subprog GETTXATVAL(VCODVAR, VDAT, VAMT, VLEV)
  Value Char VCODVAR
  Value Date VDAT
  Variable Decimal VAMT
  Variable Integer VLEV

  If !clalev([F:WARW]) : Local File TRVACCRAT [WARW] : Endif

  VAMT=0 : VLEV=1

  Filter [F:WARW] Where CODWAC=VCODVAR & DATWAC<=VDAT
  Read [F:WARW]WAR0 Last
  If !fstat
    VAMT=[F:WARW]RATWAC
  Endif
  Filter [F:WARW]

  Close File [WARW]
End


##Retourne la valeur d'une variable ainsi que le niveau où celle-ci a été définie.
########################################
Subprog GETVARVAL(VCPY, VFCY, VEMP, VCTRNUM, VDAT, VBUL, VCODVAR, VAMT, VLEV)
  Value Char VCPY, VFCY, VEMP, VCTRNUM, VBUL, VCODVAR
  Value Date VDAT
  Variable Decimal VAMT
  Variable Integer VLEV

  Local Integer VALEUR_TROUVEE

  If !clalev([F:VLAW]) : Local File VALEUR [VLAW] : Endif
  If !clalev([F:VEPZ]) : Local File VALEMP [VEPZ]  : Endif

  VAMT=0 : VLEV=1

  VALEUR_TROUVEE=0
  #On récupère la valeur par défaut en tenant compte de la date de valeur de la variable
  #en faisant une recherche par employé/site/société/dossier
  Link [F:VLAW] With
&   [F:VEPZ]VEP5 = [F:VLAW]BUL
&   As [LNK]
&   Where [F:VLAW]TYP = 4 & [F:VLAW]CPY = "" & [F:VLAW]FCY = "" & [F:VLAW]EMP = VEMP
&         & [F:VLAW]DAT<=VDAT
&         & [F:VLAW]VARCOD=VCODVAR
&         & [F:VEPZ]CTRNUM=VCTRNUM
&         & [F:VEPZ]BUL=VBUL
&         Order By Key CLE = [F:VLAW]EMP ; [F:VEPZ]CTRNUM ; [F:VLAW]VARCOD ; [F:VLAW]DAT ; [F:VEPZ]PYRDAT ; [F:VEPZ]BUL

  Read [F:LNK]CLE Last
   If fstat <= 2
    VAMT=[F:VLAW]VARVAL
    VLEV=[F:VLAW]TYP
    [L]VALEUR_TROUVEE = 1
  Endif

  If ![L]VALEUR_TROUVEE
    Filter [F:VLAW] Where [F:VLAW]TYP = 3 & [F:VLAW]CPY = "" & [F:VLAW]FCY = VFCY & [F:VLAW]EMP = ""
&          & [F:VLAW]DAT<=VDAT & BUL = ""
&          & [F:VLAW]VARCOD = VCODVAR

    Read [F:VLAW]VLA0 Last
    If fstat <= 2
      VAMT=[F:VLAW]VARVAL
      VLEV=[F:VLAW]TYP
      [L]VALEUR_TROUVEE = 1
    Endif
    Filter [F:VLAW]
  Endif

  If ![L]VALEUR_TROUVEE
    Filter [F:VLAW] Where [F:VLAW]TYP = 2 & [F:VLAW]CPY = VCPY & [F:VLAW]FCY = "" & [F:VLAW]EMP = ""
&          & [F:VLAW]DAT<=VDAT & BUL = ""
&          & [F:VLAW]VARCOD = VCODVAR

    Read [F:VLAW]VLA0 Last
    If fstat <= 2
      VAMT=[F:VLAW]VARVAL
      VLEV=[F:VLAW]TYP
      [L]VALEUR_TROUVEE = 1
    Endif
    Filter [F:VLAW]
  Endif

  If ![L]VALEUR_TROUVEE
    Filter [F:VLAW] Where [F:VLAW]TYP = 1 & [F:VLAW]CPY = "" & [F:VLAW]FCY = "" & [F:VLAW]EMP = ""
&          & [F:VLAW]DAT<=VDAT & BUL = ""
&          & [F:VLAW]VARCOD = VCODVAR

    Read [F:VLAW]VLA0 Last
    If fstat <= 2
      VAMT=[F:VLAW]VARVAL
      VLEV=[F:VLAW]TYP
    Endif
    Filter [F:VLAW]
  Endif
  Close File [VLAW], [VEPZ]
End

$GRISE_RET4_LOAD
If [M:RET4]NBEML=0 | [M:RET4]VMATSEL="" | [M:RET0]STATUT<>2
  Grizo [M:RET4]LOAD, 10
Else
  Actzo  [M:RET4]LOAD, 10
Endif
Return

#Fonction qui recalcul le champ LIG et TIDSALCTRLIG en fonction des insertions ou suppressions
Subprog UPDLIG(IDSALCTR, RANG, OPE, NBLIG)
Value Char IDSALCTR, OPE
Value Integer RANG, NBLIG
Local Integer I

For I=RANG To [M:RET4]NBRVL-1
  If [M:RET4]TIDSALCTRREC(I)<>IDSALCTR : Break : Endif
  If OPE="-"
    [M:RET4]LIG(I)-=NBLIG
    [M:RET4]TIDSALCTRLIG(I)=func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP), [M:RET4]LIG(I))
  Else
    [M:RET4]LIG(I)+=NBLIG
    [M:RET4]TIDSALCTRLIG(I)=func SUBRET.GET_IDSALCTRLIG([M:RET4]REFNUM(VNOLEMP), [M:RET4]CTRNUM(VNOLEMP), [M:RET4]LIG(I))
  Endif
Next I
End

Subprog INIT_B1_B2
# Suppression du bouton 1 - Préchargement - si fiche validée
# Suppression du bouton 2 - Recalcul - Si un recalcul précédent est pris en compte sur un
#                                      bulletin
#                                      Si on est en cours de saisie
#                                      SI on est sur une fiche d'extourne
If [M:RET0]STATUT = 3
 Raz [V]GBOUT1, [V]GBOUT2
 End
Endif
If [V]GREP <> "" : [V]GBOUT2 = "" : Endif
If [M:RET0]RETTYP > 2 : [V]GBOUT2 = "" : Endif
If [V]GREP = "" & [M:RET0]RETTYP <= 2
  Gosub SETNOL
  Gosub CONTROLE_RECALCUL
  If not [L]OK_RECALCUL : [V]GBOUT2 = ""  : Endif
Endif
End

Subprog CHARGEMENT_SALARIE
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Local Decimal VALEUR
Local Integer I, OK_CONTROLE, NBSAL_SANS_ACCES
Local Char NOMVAR(250), MESSAGE(250)

SAVACT = GACTION : GACTION = "TRTRETSAL"
PARMSK(1) = "RET_B1_NBSAL"
PARMSK(2) = ""
PARMSK(3) = ""
PARMSK(4) = ""
PARMSK(5) = ""
PARMSK(6) = ""
PARMSK(7) = ""
PARMSK(8) = ""
PARMSK(9) = ""
PARMSK(10) = [M:RET1]DATAVTEFF
PARMSK(11) = num$([M:RET0]RETTYP)
Call SAISIE_NUM([L]VALEUR, [L]PARMSK, "TRTRETSAL", "TRTRETSAL", "XYTRTRETSAL") From GSAISIE
GACTION = SAVACT

If [L]PARMSK(1) = "OK"
    Local Char CPY([V]GLONCPY), FCY([V]GLONFCY), SRV([V]GLONSRV), PRF([V]GLONPRF),
&        MATDEB([V]GLONEML), MATFIN([V]GLONEML), POP([V]GLONPOP), CRITERE(250)
    Local Date DATAVTEFF
    Local Char CRILNK(250)
    Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
    # Exploitation des PARMSK
    [L]I = 1
    For [L]NOMVAR = "CPY", "FCY", "SRV", "PRF", "MATDEB", "MATFIN", "POP", "CRITERE", "DATAVTEFF"
        [L]I += 1
        Assign "[L]"+[L]NOMVAR With [L]PARMSK([L]I)
    Next
    [L]CRILNK="1=1"
    If [L]CPY <> ""
        [L]CRILNK -= "& [F:FCY]LEGCPY='"+[L]CPY+"'"
    Endif
    If [L]FCY <> ""
        [L]CRILNK -= "& [F:HRCTR]ETRFCY='"+[L]FCY+"'"
    Endif
    If [L]SRV <> ""
        [L]CRILNK -= "& [F:HRCTR]ETRSRV='"+[L]SRV+"'"
    Endif
    If [L]PRF <> ""
        [L]CRILNK -= "& [F:HRCTR]PROPRF='"+[L]PRF+"'"
    Endif
    If [L]MATDEB <> ""
        [L]CRILNK -= "& [F:HRCTR]REFNUM>='"+[L]MATDEB+"'"
    Endif
    If [L]MATFIN <> ""
        [L]CRILNK -= "& [F:HRCTR]REFNUM<='"+[L]MATFIN+"'"
    Endif
    # ajout du filtre pour ne prendre en compte que les contrats "retroactivité"
    # si on est en mode 1 ou 3
    If find([M:RET0]RETTYP, 1, 3)
        # Contrat avec rétroactivité non pris en compte (statut = en cours)
        # ... au niveau du contrat actif avant la date d'intégration ... ???
        [L]CRILNK -= "& [F:HRCTR]FLGRET=2 & [F:HRCTR]RETSTATUT=2"
        # Du bon type de rétroactivité
        [L]CRILNK -= "& [F:HRCTR]RETTYP="+num$([M:RET0]RETTYP)
        # Dont la date d'effet de l'avenant est <= à la date maximum saisie (Avenant jusqu'au...)
        #MIPEA - 2016-06-24 - REQ 114309 US128 - START
        [L]CRILNK -= "& [F:HRCTR]RETDATEFF>=[M:RET1]DATEFF"
        [L]CRILNK -= "& [F:HRCTR]CTRDAT<=[M:RET1]DATAVTEFF"
        #[L]CRILNK -= "& [F:HRCTR]RETDATEFF<=[M:RET1]DATAVTEFF"
        #MIPEA - 2016-06-24 - REQ 114309 US128 - END
    Else
        #MIPEA - 2016-06-24 - REQ 114309 US128 - START
        #111698
#       [L]CRILNK -= "& [F:HRCTR]CTRDAT<=[M:RET1]DATMININT"
        [L]CRILNK -= "& [F:HRCTR]CTRDAT<=gdat$(1,month([M:RET1]DATMININT),year([M:RET1]DATMININT))"
#       [L]CRILNK -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:RET1]DATMININT)"
        [L]CRILNK -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=gdat$(1,month([M:RET1]DATMININT),year([M:RET1]DATMININT)))"
        #[L]CRILNK -= "& [F:HRCTR]CTRDAT<=[M:RET1]DATMININT"
        #[L]CRILNK -= "& ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=[M:RET1]DATMININT)"
        #MIPEA - 2016-06-24 - REQ 114309 US128 - END
     Endif
    If vireblc([L]CRITERE,4) = "" : [L]CRITERE = "1" : Endif

    If [L]POP = ""
        Link [F:HRCTR] With
&            [F:ID]ID0 = [F:HRCTR]REFNUM,
&            [F:FCY]FCY0 = [F:HRCTR]ETRFCY,
&            [F:CPY]CPY0 = [F:FCY]LEGCPY
&            As [WLNK]
&            Where evalue([L]CRILNK)
&                & evalue([L]CRITERE)
    Else
        Link [F:HRCTR] With
&            [F:ID]ID0 = [F:HRCTR]REFNUM,
&            [F:FCY]FCY0 = [F:HRCTR]ETRFCY,
&            [F:CPY]CPY0 = [F:FCY]LEGCPY,
&            [F:POA]POA0 = [L]POP ; [F:ID]REFNUM
&            As [WLNK]
&            Where evalue([L]CRILNK)
&                & evalue([L]CRITERE)
&                & [F:POA]REFNUM <> ""
    Endif
    # mess(110,10701,1) : Chargement automatique des rétroactivités à effectuer
    Call OUVRE_TRACE(mess(110,10701,1)) From LECFIC
    # Mettre les critères de chargement utilisés dans le fichier de trace ?
    nolign = [M:RET4]NBEML
    For [F:WLNK]
        If [M:RET4]NBEML >= dim([M:RET4]REFNUM)
            # mess(26,100,1) : Tableau plein
            Call ECR_TRACE(mess(26,100,1), 1) From GESECRAN
            Break
        Endif
        [L]IDSALCTR = func SUBRET.GET_IDSALCTR([F:HRCTR]REFNUM, [F:HRCTR]CTRNUM)
        If not find([L]IDSALCTR, [M:RET4]TIDSALCTR)
            # Vérification des droits d'accès
            Call CONTROLE([F:ID]REFNUM, [F:HRCTR]CTRDAT, [F:HRCTR]CTRNUM, "", [L]OK_CONTROLE, 1) From DIVPAYE
            If [L]OK_CONTROLE
                # Dont une paie doit être générée (ou l’est déjà) à partir de la date d’intégration
                #MIPEA - 2016-06-24 - REQ 114309 US128 - START
                #111698
#                                Filter [F:VEP] Where [F:VEP]EMP = [F:CTR]REFNUM
#&                                & [F:VEP]CTRNUM = [F:CTR]CTRNUM
#&                                & [F:VEP]PYRDAT >= [M:RET1]DATMININT
                Filter [F:VEP] Where [F:VEP]EMP = [F:CTR]REFNUM
&                                & [F:VEP]CTRNUM = [F:CTR]CTRNUM
&                                & [F:VEP]PYRDAT >= gdat$(1,month([M:RET1]DATMININT),year([M:RET1]DATMININT))

#                Filter [F:VEP] Where [F:VEP]EMP = [F:HRCTR]REFNUM
#&                                & [F:VEP]CTRNUM = [F:HRCTR]CTRNUM
#&                                & [F:VEP]PYRDAT >= [M:RET1]DATMININT
                #MIPEA - 2016-06-24 - REQ 114309 US128 - END
                Read [F:VEP] First
                Filter [F:VEP]
                If fstat <= 2
                    nolign += 1
                    [M:RET4] = [F:CPY]
                    [M:RET4] = [F:FCY]
                    [M:RET4] = [F:HRCTR]
                    [M:RET4]TIDSALCTR(nolign-1) = [L]IDSALCTR
                    [M:RET4]DATLSTREV(nolign-1) = [F:HRCTR]CTRDAT
                    If [F:VEP]STA > 1
                        # Warning si paye calculée au delà de la date d'intégration
                        [L]MESSAGE = [F:HRCTR]REFNUM-[F:HRCTR]CTRNUM
                        #A défaut d'un recalcul du bulletin de paie en date de paie du xx/xx/xxxx
                        #le rappel sera pris en compte sur la date de paie suivante.
                        [L]MESSAGE -= "-"-mess(199,10702,1)-format$([V]GFMD, [F:VEP]PYRDAT)+","-mess(200,10702,1)
                        Call ECR_TRACE([L]MESSAGE, -1) From GESECRAN
                    Endif
                Else
                #MIPEA - 2016-06-24 - REQ 114309 US128 - START
                If !GINTMT | [F:ID]FLGINT<>2
                  # On ne génère pas le prochain bulletin si le salarié est sorti (régul sur ancien contrat)
                  If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=gdat$(1,month([M:RET1]DATMININT),year([M:RET1]DATMININT)) :#111698
                   [L]MESSAGE = [F:HRCTR]REFNUM-[F:HRCTR]CTRNUM
                   Gosub CREPAY
                   If !GOK
                     # Pas de paye générée au delà du
                     #LIPET - 2018-02-28 - X3-12020 - START
                     #[L]MESSAGE -= "-" - mess(208,702,1)-format$([V]GFMD, DATPAY)
                     [L]MESSAGE -= "-" - mess(208,10702,1)-format$([V]GFMD, DATPAY)
                     #LIPET - 2018-02-28 - X3-12020 - END
                     Call ECR_TRACE([L]MESSAGE,1) From GESECRAN
                   Elsif GOK<0
                     # Echec en génération du bulletin de paie en date du
                      #LIPET - 2018-02-28 - X3-12020 - START
                      #[L]MESSAGE -= "-"-mess(234,702,1)-format$([V]GFMD, DATPAY)
                      [L]MESSAGE -= "-"-mess(234,10702,1)-format$([V]GFMD, DATPAY)
                      #LIPET - 2018-02-28 - X3-12020 - END
                      Call ECR_TRACE([L]MESSAGE,1) From GESECRAN
                   Else
                     # Génération du bulletin de paie en date du
                     #LIPET - 2018-02-28 - X3-12020 - START
                     #[L]MESSAGE -= "-"-mess(235,702,1)-format$([V]GFMD, DATPAY)
                     [L]MESSAGE -= "-"-mess(235,10702,1)-format$([V]GFMD, DATPAY)
                     #LIPET - 2018-02-28 - X3-12020 - END
                     Call ECR_TRACE([L]MESSAGE,-1) From GESECRAN
                   Endif
                  Endif
                 Endif
                 If GOK
                  nolign += 1
                  [M:RET4] = [F:CPY]
                  [M:RET4] = [F:FCY]
                  [M:RET4] = [F:HRCTR]
                  [M:RET4]TIDSALCTR(nolign-1) = [L]IDSALCTR
                  [M:RET4]DATLSTREV(nolign-1) = [F:HRCTR]CTRDAT
                 Endif
                Endif
            Else
                [L]NBSAL_SANS_ACCES += 1
            Endif
        Endif
    Next
            #MIPEA - 2016-06-24 - REQ 114309 US128 - END
    If [L]NBSAL_SANS_ACCES > 0
        # mess(111,10701,1) : Nombre de salariés non traités en raison de vos droits utilisateur :
        Call ECR_TRACE(mess(111,10701,1)-num$([L]NBSAL_SANS_ACCES), -1) From GESECRAN
    Endif
    Call FERME_TRACE From LECFIC
    [M:RET4]NBEML = nolign

    Raz [M:RET3]
    [M:RET3] = [M:RET4]
    [M:RET3]NBSAL=[M:RET4]NBEML

    Call LEC_TRACE From LECFIC
    #MIPEA - 2016-06-24 - REQ 114309 US128 - START
    Affzo [M:RET4] : mkstat = 4
    #mkstat = 4
    #MIPEA - 2016-06-24 - REQ 114309 US128 - END

    Affzo [M:RET4]
Endif
End

######################################################################################
## Autres sous-programmes
######################################################################################
Subprog CHARGE_COD (VTYPREV, VCODTYP, VLONG, VOPT)
Value Integer VTYPREV
Variable Char VCODTYP, VOPT
Variable Decimal VLONG
Case VTYPREV
 When 2 :
  VCODTYP="VAC"
  VLONG  = GLONVAC
  VOPT   = ""
 When 3 :
  VCODTYP ="GRI"
  VLONG   = GLONGRI
  VOPT    = ""
 When Default :
  VCODTYP ="VRA"
  VLONG   = GLONVRA
  VOPT    = "R"            :#Cochée Rétro only
Endcase
End

Subprog CHARGE_DES(VTYPREV, VCODTYP, VVARCOD, VVARDES)
Value Integer VTYPREV
Value Char VCODTYP, VVARCOD
Variable Char VVARDES

Raz VVARDES
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
Case VTYPREV
 When 1 :
   Call LECTEXTRA(VVARDES,"VARIA","DES",GCURLEG,VVARCOD) From ATEXTRA
   Call LECTURE(VCODTYP,VVARCOD,"") From CONTOBJ
   VVARDES=[F:VRA]DES
 When 2 :
   Read[F:WAC]WAC0=VVARCOD
   If !fstat : VVARDES=[F:WAC]DESWAC : Endif
 When 3 :
   Call LECTEXTRA(VVARDES,"GRILLE","DES",VVARCOD,"") From ATEXTRA
   Call LECTURE(VCODTYP,VVARCOD,"") From CONTOBJ
   VVARDES=[F:GRI]DES
   Call CHARGE_DATRIL(VVARCOD)
Endcase
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
End

# Recherche de la date exacte pour tunnel vers valeurs de grille
Subprog CHARGE_DATRIL(VALEUR)
Variable Char    VALEUR()
If[M:RET2]TYPREV(nolign-1)<>3 : End : Endif
If clalev ([F:RIL])=0 : Local File GGRILLE [RIL] : Endif
Local Date DATRIL
If [M:RET2]DATVAL(nolign-1)<>[0/0/0]
 [L]DATRIL =[M:RET2]DATVAL(nolign-1)
Else
 [L]DATRIL =[M:RET1]DATMININT
Endif
Filter [F:RIL] Where CODGRI=VALEUR & STRDAT<=[L]DATRIL
Read [F:RIL]RIL0 Last
Filter [F:RIL]
If !fstat
 [M:RET2]DATRIL(nolign-1)=[F:RIL]STRDAT
Endif
End

$CONTROLE_RECALCUL
Local Integer RANG, OK_RECALCUL
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
[L]IDSALCTR = func SUBRET.GET_IDSALCTR([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL))
[L]OK_RECALCUL = 1
[L]RANG = find([L]IDSALCTR, [M:RET4]TIDSALCTRREC)
[L]RANG -= 1
If [L]RANG >= 0
    While [M:RET4]TIDSALCTRREC([L]RANG) = [L]IDSALCTR & [L]RANG < dim([M:RET4]TIDSALCTRREC)
        If [M:RET3]RECBUL([L]RANG) <> ""
            [L]OK_RECALCUL = 0
            Break
        Endif
        [L]RANG += 1
    Wend
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End

Subprog AS_TYPREV(VALEUR)
Variable Integer VALEUR
If GCURLEG<>'FRA' : GMENLOC(2)=1 : Endif
End

