#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet RET
#--------------------------------
# SUBRET : Fiche de rétroactivité
#---------------------------------
Call OBJET("RET", [V]GBIDC1, [V]GBIDC2) From GOBJET
End

########################################
$ACTION
Case [L]ACTION
    When "OUVRE"      :    Gosub OUVRE
    When "RAZDUP"     :    Gosub RAZDUP
    When "INICRE"     :    Gosub INICRE
    When "LIENS"      :    Gosub LIENS
    When "VERIF_CRE"  :    Gosub VERIF_CRE
    When "VERIF_MOD"  :    Gosub VERIF_MOD
    When "CREATION"   :    Gosub CREATION
    When "APRES_CRE"  :    Gosub APRES_CRE
    When "MODIF"      :    Gosub MODIF
    When "APRES_MOD"  :    Gosub APRES_MOD
    When "ANNULE"     :    Gosub ANNULE
    When "AV_ANNULE"  :    Gosub AV_ANNULE
    When "SETBOUT"    :    Gosub SETBOUT
    When "STATUT"     :    Gosub STATUT
    When "BB2_NBVCAL" :    Gosub BB2_NBVCAL
    When "FERME"      :    Gosub FERME
    When "AP_CHANGE"  :    Gosub AP_CHANGE
    When "AS_RETNUM"  :    Gosub AS_RETNUM
    When "BS_RETNUM"  :    Gosub BS_RETNUM
Endcase
Return



#Before selection on field COD
#############
$AS_RETNUM
Raz GCURLEG
Return

#After selection on field COD
############
$BS_RETNUM
# To do nothing if the user doesn't select a record
If [F:RET]RETNUM<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:RET0]LEG)>=0 : [M:RET0]LEG=[F:RET]LEG: Endif
 GCURLEG=[F:RET]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_RETNUM
 If dim([M:RET0]LEG)>=0
  GCURLEG=[M:RET0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

########################################
$OUVRE
Local Char WCODNUM([V]GLONANM), WFCY([V]GLONFCY), WRETNUM([V]GLONRET), WCOMPLEMENT(250)
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
Local Date WDAT
#Local Integer WMANCOU
Local Integer STAT, NOL, I, VOIDINT, OK_CONTROLE
Local Char TBUL(type([F:VEP]BUL)-10)(100), BUL(type([F:VEP]BUL)-10)
Local Integer NBBUL
Local Char WMESSAGE(250) # ajout test Verrouillé US 2022 65062

If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif

##**72216
If !clalev([F:RVL]) : Local File RETROVAL     [RVL] : Endif
If !clalev([F:HRHSR]) : Local File HISTOREGUL [HRHSR] : Endif
If !clalev([F:THR]) : Local File TMPHSR       [THR] : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

#Call GET_PARCPT(2, 8, [L]WCODNUM, [L]WMANCOU) From DIVPPH
#MIPEA - 2016-06-23 - REQ 114309 US128 - START
#BB 27-05-2014 Table opening for KPO
If func AFNC.ACTIV("KPO")>0
  If clalev([F:VRA])=0 : Local File VARIA      [VRA] : Endif
  If clalev([F:RUB])=0 : Local File RUBRIQUE   [RUB] : Endif
  If clalev([F:TIP])=0 : Local File TIMEMP     [TIP] : Endif
  #If clalev([F:TIG])=0 : Local File TIMREGUL   [TIG] : Endif
  If clalev([F:HRLOD])=0 : Local File LEGOBGSETD [HRLOD] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
  #LIPET - 2018-02-28 - X3-12020 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR   [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR   [HRCTR] : Endif
  #If clalev([F:PEO])=0 : Local File PERIOD     [PEO] : Endif
  If clalev([F:HRPEOD])=0 : Local File HRPEODET     [HRPEOD] : Endif
  #LIPET - 2018-02-28 - X3-12020 - END
Endif
#MIPEA - 2016-06-23 - REQ 114309 US128 - END
Return

##**72216 : La fiche est lockée, donc THR ne doit pas etre déchargé :)
########################################
$FERME
If VERROU
 Gosub DELETE_THR
Endif
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
$RAZDUP
[M:RET0]STATUT = 2
Actzo [M:RET0]RETTYP
Affzo [M:RET0]
Actzo [M:RET1]5 : Affzo [M:RET1]5
Raz   [M:RET3]  : Affzo [M:RET3]
Raz   [M:RET4]  : Affzo [M:RET4]
Return

########################################
$LIENS

If GNBLEG = 1
  GCURLEG = GDOSLEG
Else
  GCURLEG=[M:RET0]LEG
Endif

# To manage translated texts (data type AX3)
Call LECTEXTRA([M]INTITULE,"RETRO","INTITULE",[M]RETNUM,"") From ATEXTRA

If [M:RET0]STATUT = 3 :  Diszo [M:RET1]5 : Else : Actzo [M:RET1]5 : Endif
Effzo [M:RET2]
Raz nolign
For [F:REV]REV0 Where [F:REV]RETNUM = [M:RET0]RETNUM
    nolign += 1
    If nolign >= dim([M:RET2]VRACOD) - 1
        Break
    Endif
    [M:RET2] = [F:REV]
    ##**72216
    Call CHARGE_COD([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]LONG(nolign-1),[M:RET2]OPT(nolign-1))
    Call CHARGE_DES([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]VRACOD(nolign-1),[M:RET2]VRADES(nolign-1))
    [M:RET2]UNQ(nolign-1) = num$([M:RET2]TYPREV(nolign-1))+"~"+[M:RET2]VRACOD(nolign-1)
    #
Next
[M:RET2]NBVRA = nolign
Affzo [M:RET2]

Effzo [M:RET4]
Raz nolign
For [F:RES]RES0 Where [F:RES]RETNUM = [M:RET0]RETNUM
    nolign += 1
    If nolign >= dim([M:RET4]REFNUM) - 1
        Break
    Endif
    [M:RET4] = [F:RES]
    [L]IDSALCTR = func SUBRET.GET_IDSALCTR([F:RES]REFNUM, [F:RES]CTRNUM)
    [M:RET4]TIDSALCTR(nolign-1) = [L]IDSALCTR
    #MIPEA - 2016-06-23 - REQ 114309 US128 - START
    Read [F:HRCTR]CTR0=[F:RES]REFNUM;[F:RES]CTRNUM;[F:RES]CTRDAT
    #MIPEA - 2016-06-23 - REQ 114309 US128 - END
Next
[M:RET3]=[M:RET4]
[M:RET4]NBEML = nolign
[M:RET3]NBSAL = nolign

##**72216 : Si la fiche est lockée (VERROU=0), c'est que THR est déjà chargé :)
Call LOAD_REC([M:RET0]RETNUM,VERROU)

Gosub LOAD_RETVAL

Affzo [M:RET4]
Affzo [M:RET3]
#94898
If [M:RET0]RETTYP<3
  #si pas type Extourne, on remplit le tableau des rubriques
  #sinon GRISE_RET2 s'occupera de vider et interdire le tableau des rubriques.
  Raz nolign
  Effzo [M:RET5]
  For [F:RER]RER0 Where [F:RER]RETNUM = [M:RET0]RETNUM
      nolign += 1
      If nolign >= dim([M:RET5]RUBCOD) - 1
          Break
      Endif
      [M:RET5] = [F:RER]
  Next
  [M:RET5]NBRUB = nolign
  Affzo [M:RET5]
Endif
#end 94898
# si on est ici, c'est qu'on a chargé un enregistrement
Grizo [M:RET0]RETTYP
Call GRISE_RET2([M:RET0]RETTYP)
Return

########################################
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif

Gosub WRITE_REV
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RER
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RES
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RVL
If [V]GOK < 1 : Return : Endif
Gosub WRITE_THR
If [V]GOK < 1 : Return : Endif
Return

########################################
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Gosub MAJSTATUT_CTR
If [V]GOK < 1 : Return : Endif
Gosub DELETE_ALL
If [V]GOK < 1 : Return : Endif
Gosub WRITE_REV
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RER
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RES
If [V]GOK < 1 : Return : Endif
Gosub WRITE_REC
If [V]GOK < 1 : Return : Endif
Gosub WRITE_RVL
If [V]GOK < 1 : Return : Endif
Gosub WRITE_THR
If [V]GOK < 1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("RETRO","INTITULE",CLECUR1,"","RETRO","INTITULE",[F:RET]RETNUM,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M]INTITULE,"RETRO","INTITULE",[F:RET]RETNUM,"") From ATEXTRA
Return

########################################
$AV_ANNULE
Gosub MAJSTATUT_CTR
If [V]GOK < 1 : Return : Endif
Return

########################################
$ANNULE
Call SUPTEXTRA("RETRO","INTITULE",[L]CODE,"") From ATEXTRA
Gosub DELETE_ALL
If [V]GOK < 1 : Return : Endif
##**72216
Gosub DELETE_HSR
If [V]GOK < 1 : Return : Endif
Gosub DELETE_THR
If [V]GOK < 1 : Return : Endif
Return

########################################
$DELETE_ALL
Gosub DELETE_REV
If [V]GOK < 1 : Return : Endif
Gosub DELETE_RER
If [V]GOK < 1 : Return : Endif
Gosub DELETE_RES
If [V]GOK < 1 : Return : Endif
Gosub DELETE_REC
If [V]GOK < 1 : Return : Endif
Gosub DELETE_RVL
If [V]GOK < 1 : Return : Endif
##**72216
#Surtout ne pas faire de 'Gosub DELETE_HSR' ni le 'Gosub DELETE_THR' ici, car de $DELETE_ALL est appelé dans $MODIF !
Return

########################################
$AP_CHANGE
Call CHGTEXTRA("RETRO","INTITULE",[L]OCODE,"",[L]NCODE,"") From ATEXTRA
Return

########################################
$SETBOUT
If [L]CLECUR & [M:RET0]STATUT = 2
 # Si "en cours" , alors
 Case [M:RET0]RETTYP
  When 3
   # Extourne
   [L]CHMEN += "V"
  When 1, 2
   [L]CHMEN += "R"
  Endcase
Endif

# Ajout de l'édition en masse
If [L]CLECUR
    If  [M:RET0]STATUT = 3
        # Si validé pour une extourne
        [L]CHMEN += "I"
        # Ajout de l'annulation en masse sous réserver de faisabilité ( pas de bulletin comptabilisé )
        [L]CHMEN += "A"
    Endif
    If [M:RET0]RETTYP < 3
        # Quel que soit l'état si rétroactivité autre que extourne
        [L]CHMEN += "I"
    Endif
Endif
#MIPEA - 2016-06-23 - REQ 114309 US128 - START
If REP <> "" | [M:RET4]NBEML=0
#If REP <> ""
#MIPEA - 2016-06-23 - REQ 114309 US128 - END
 Call VIREBOUT([L]CHMEN, "VRI") From GOBJET
Endif

If [M:RET0]STATUT = 3
 # Avec les contrôles sur toutes les zones écrans, seule la zone 'commentaires' est modifiable si statut=3
 Call VIREBOUT([L]CHAINE, "A") From GOBJET :
Endif

# Plus généralement, on s'interdit d'annuler si on a un lien sur un bulletin
For [L]I = 0 To [M:RET3]NBCAL - 1
    If [M:RET3]RECBUL([L]I) <> ""
        Call VIREBOUT([L]CHAINE, "A") From GOBJET
        Break
    Endif
Next
Return

########################################
$STATUT
Case [L]BOUT
    When "V"
        # Traité par une action indépendante (TRTRETVAL)
        # Mais on force une relecture
        Gosub RELIT From GOBJSUB
    When "R"
        Gosub RECALCUL
        Gosub RELIT From GOBJSUB
    When "A"
        Gosub ANNULATION_MASSE
        Gosub RELIT From GOBJSUB
Endcase
Return

########################################
$EXEBOUT
Return

$VERIF_CRE
Gosub VERIFICATION
Return

$VERIF_MOD
Gosub VERIFICATION
Return

$VERIFICATION
If [M:RET1]ENAFLG <> 2 & [M:RET0]RETTYP <> 3
    # mess(206,10702,1) : Attention, cette fiche est inactive\Les rappels ne seront pas intégrés en paie\tant que vous n'aurez pas activé la fiche.
    # mess(207,10702,1) : Confirmez-vous votre choix ?
    Call OUINON(mess(206,10702,1)+"\"+mess(207,10702,1), [L]OK) From GESECRAN
    If [L]OK = 1 : [L]OK = 0: Endif
Endif
Return

########################################
$APRES_CRE
#MIPEA - 2016-06-23 - REQ 114309 US128 - START
Local Char VALEUR(250), PARAM(250)(1..20) , SAVACT(30) :#93276
If [M:RET4]NBEML>0
  If [M:RET0]RETTYP = 3
    #LIPET - 2018-02-28 - X3-12020 - START
    #Call OUINON(mess(244,10702,1), [L]OK) From GESECRAN
    Call OUINON(mess(259,10702,1), [L]OK) From GESECRAN
    #LIPET - 2018-02-28 - X3-12020 - END
    If [L]OK = 2
      SAVACT = GACTION : GACTION = "TRTRETVAL"
      PARAM(1)=[M:RET0]RETNUM : PARAM(2)=[M:RET1]DATMININT : PARAM(3)=[M:RET1]DATMININT
      Call SAISIE_CHAR(VALEUR,PARAM,"TRTRETVAL","TRTRETVAL","XYTRTRETVAL") From GSAISIE
      GACTION = SAVACT
    Endif
  Else
    Call OUINON(mess(233,10702,1), [L]OK) From GESECRAN
    If [L]OK = 2
      Gosub RECALCUL
    Endif
  Endif
  Gosub RELIT From GOBJSUB
Endif
#If [M:RET4]NBEML>0
#  Call OUINON(mess(230,10702,1), [L]OK) From GESECRAN
#  If [L]OK = 2
#    Gosub RECALCUL
#    Gosub RELIT From GOBJSUB
#  Endif
#Endif
#MIPEA - 2016-06-23 - REQ 114309 US128 - END
Return

########################################
$APRES_MOD
Gosub RELIT From GOBJSUB
Return

#-------------------------------------------
# WRITE_REV : Ecriture RETROVRA / Variables
#-------------------------------------------
########################################
$WRITE_REV
For nolign = 1 To [M:RET2]NBVRA
    Raz [F:REV]
    [F:REV] = [M:RET0]
    [F:REV] = [M:RET2]
    [F:REV]NUMLIG = nolign
    Write [F:REV]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("REV") From GLOCK
        Break
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

#-------------------------------------------
# WRITE_RER : Ecriture RETRORUB / Rubriques
#-------------------------------------------
########################################
$WRITE_RER
#94898
For nolign = 1 To [M:RET5]NBRUB
    Raz [F:RER]
    [F:RER] = [M:RET0]
    [F:RER] = [M:RET5]
    [F:RER]NUMLIG = nolign
    Write [F:RER]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("RER") From GLOCK
        Break
    Endif
Next
#end 94898
If [V]GOK < 1 : Return : Endif
Return

#-------------------------------------------
# WRITE_RES : Ecriture RETROSAL / Salariés
#-------------------------------------------
########################################
$WRITE_RES
For nolign = 1 To [M:RET4]NBEML
    Raz [F:RES]
    [F:RES] = [M:RET0]
    [F:RES] = [M:RET4]
    [F:RES]NUMLIG = nolign
    [F:RES]CTRDAT=[M:RET4]DATLSTREV(nolign-1) : ##**82073
    Write [F:RES]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("RES") From GLOCK
        Break
    Endif
    # Le contrat avec avenant rétroactif est flaggué comme pris en compte
    ##**72216 : Ajout critère sur CTRDAT
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:RES]REFNUM & [F:HRCTR]CTRNUM = [F:RES]CTRNUM  & [F:HRCTR]CTRDAT=[F:RES]CTRDAT
&                        & [F:HRCTR]FLGRET = 2 & [F:HRCTR]RETSTATUT = 2
&                        & [F:HRCTR]RETTYP = [M:RET0]RETTYP
    Readlock [F:HRCTR]CTR0 Last
    Filter [F:HRCTR]
    If fstat = 0
        [F:HRCTR]RETSTATUT = 3
        Rewrite [F:HRCTR]
    Elsif fstat = 1
        [V]GOK = -1 : [V]GLOCK = "$EMPLOCTR"
        Break
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

#--------------------------------------------------
# WRITE_REC : Ecriture RETROCAL / Rappels calculés
#--------------------------------------------------
########################################
$WRITE_REC
For nolign = 1 To [M:RET3]NBCAL
    [L]IDSALCTR = func SUBRET.GET_IDSALCTR([M:RET3]RECREFNUM(nolign-1), [M:RET3]RECCTRNUM(nolign-1))
    If find([L]IDSALCTR, [M:RET3]TIDSALCTR)    : # Pour gérer des suppression dans le tableau salarié
        Raz [F:REC]
        [F:REC] = [M:RET0]
        [F:REC] = [M:RET3]
        Write [F:REC]
        If fstat <> 0
            [V]GOK = 0
            Call FSTA("REC") From GLOCK
            Break
        Endif
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

#--------------------------------------------------
# WRITE_RVL : Ecriture RETROVAL / Valeur des variables
#--------------------------------------------------
########################################
$WRITE_RVL
Local Integer RANG
RANG=0
For nolign = 1 To [M:RET4]NBRVL
  If [M:RET4]TIDSALCTRREC(nolign-1)<>[M:RET4]TIDSALCTR(RANG)
    #On récupère la ligne du salarié concerné.
    [L]RANG = find([M:RET4]TIDSALCTRREC(nolign-1), [M:RET4]TIDSALCTR)
    [L]RANG -= 1
  Endif
  If [L]RANG >= 0
    #si rang<0, la ligne du salarié a dû être supprimée.
    Raz [F:RVL]
    [F:RVL] = [M:RET0]
    [F:RVL] = [M:RET4]
    [F:RVL]CTRNUM = [M:RET4]CTRNUM(RANG)
    [F:RVL]CTRDAT = [M:RET4]DATLSTREV(RANG)
    [F:RVL]REFNUM = [M:RET4]REFNUM(RANG)
    Write [F:RVL]
    If fstat <> 0
        [V]GOK = 0
        Call FSTA("RVL") From GLOCK
        Break
    Endif
  Else
    RANG=0
  Endif
Next
Return

##**72216
#-----------------------------------
# WRITE_THR : Ecriture HISTOREGUL avec le contenu de TMPHSR
#-----------------------------------
########################################
$WRITE_THR
Gosub DELETE_HSR
If [V]GOK < 1 : Return : Endif
For [F:THR]THR0 Where RETNUM=[M:RET0]RETNUM & CODTRT='RET'
 [F:HRHSR]=[THR]
 Write [HRHSR]
 If fstat <> 0
  [V]GOK = 0
  Call FSTA("HSR") From GLOCK
  Break
 Endif
Next
If [V]GOK < 1 : Return : Endif
Return


########################################
$DELETE_REV
Delete [F:REV] Where [F:REV]RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("REV") From GLOCK
    Return
Endif
Return

########################################
$MAJSTATUT_CTR
For [F:RES]RES0 Where [F:RES]RETNUM = [M:RET0]RETNUM
    # Déflagguer le contrat comme pris en compte
    ##**72216 : Ajout critère sur CTRDAT
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:RES]REFNUM & [F:HRCTR]CTRNUM = [F:RES]CTRNUM & [F:HRCTR]CTRDAT=[F:RES]CTRDAT
&                        & [F:HRCTR]FLGRET = 2 & [F:HRCTR]RETSTATUT = 3
&                        & [F:HRCTR]RETTYP = [M:RET0]RETTYP
    Readlock [F:HRCTR]CTR0 Last
    Filter [F:HRCTR]
    If fstat = 0
        [F:HRCTR]RETSTATUT = 2
        Rewrite [F:HRCTR]
    Elsif fstat = 1
        [V]GOK = -1 : [V]GLOCK = "$EMPLOCTR"
        Break
    Endif
Next
If [V]GOK < 1 : Return : Endif
Return

########################################
$DELETE_RES
Delete [F:RES] Where [F:RES]RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("RES") From GLOCK
    Return
Endif
Return

########################################
$DELETE_RER
Delete [F:RER] Where [F:RER]RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("RER") From GLOCK
    Return
Endif
Return

########################################
$DELETE_REC
Delete [F:REC] Where [F:REC]RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("REC") From GLOCK
    Return
Endif
Return

##**72216
########################################
$DELETE_RVL
Delete [F:RVL] Where [F:RVL]RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("RVL") From GLOCK
    Return
Endif
Return

##**72216
########################################
$DELETE_HSR
Delete [F:HRHSR] Where RETNUM = [M:RET0]RETNUM
If fstat <> 0 & fstat <> 4
    [V]GOK = 0
    Call FSTA("HSR") From GLOCK
    Return
Endif
If [V]GOK < 1 : Return : Endif
Return

##**72216
########################################
$DELETE_THR
Delete [F:THR] Where RETNUM = [M:RET0]RETNUM  & CODTRT='RET'
If fstat <> 0 & fstat <> 4
 [V]GOK = 0
 Call FSTA("THR") From GLOCK
 Return
Endif
Return

#------------------------------------------
# RECALCUL : Calcul des rappels en masse
#------------------------------------------
########################################
$RECALCUL
If [M:RET0]RETTYP = 3  | [M:RET4]NBEML<=0 : Return : Endif

# mess(195,10702,1) : Calcul des rappels
Call OUVRE_BOITE(mess(195,10702,1), [M:RET4]NBEML) From GESECRAN

##**85110
Local Char TIT (250)
TIT=mess(195,10702,1)
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN

For [L]NOL = 0 To [M:RET4]NBEML-1
    Call AFF_BOITE([M:RET4]REFNUM([L]NOL)-[M:RET4]CTRNUM([L]NOL), [L]NOL+1, [L]VOIDINT) From GESECRAN
    Call RETRO([M:RET0]RETNUM, [M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL), 1) From TRTRETVAL
Next
Call FERME_BOITE From GESECRAN

Call FERME_TRACE From LECFIC

nolign = 1
[M:RET3]=[M:RET4]
[M:RET3]NBSAL = [M:RET4]NBEML

Call LOAD_REC([M:RET0]RETNUM,1) From SUBRET
nolign = 1
Call AV_NBSAL

Call LEC_TRACE From LECFIC
Return

#------------------------------------------------------------
# INICRE : Initialisation création - Attribution N° de fiche
#------------------------------------------------------------
########################################
$INICRE
If [M:RET0]RETNUM = ""
    Raz [L]WRETNUM
    [L]WDAT = [M:RET1]DATEFF
    [L]WCOMPLEMENT = ""
    GCURLEG=[M:RET0]LEG
    Call LECTCA(15,STAT) From SUBTCA
    If !STAT
      GMESSAGE = mess(12,114,1) : # Compteur inexistant
      GOK = 0 : Return
    Else
      [L]WCODNUM= [F:TCA]CODNUM(8)
    Endif

    Call NUMERO([L]WCODNUM, [L]WFCY, [L]WDAT, [L]WCOMPLEMENT, [L]WRETNUM, [L]STAT) From SUBANM
    If not [L]STAT
        [F:RET]RETNUM = [L]WRETNUM
        [M:RET0]RETNUM = [F:RET]RETNUM
    Else
        [V]GMESSAGE = mess(4,10702,1)-[L]WCODNUM    : # Erreur sur compteur
        [V]GOK = 0 : Return
    Endif
Endif
Return

#-----------------------------------------------------------
# Annulation en masse des bulletins "extournés"
#-----------------------------------------------------------
################################################################################
$ANNULATION_MASSE

Call TEMPON("F") From GESECRAN
# Petite vérif , les bulletins associés à la fiche ne doivent pas être comptabilisés
Filter [F:REC] Where [F:REC]RETNUM = [M:RET0]RETNUM
&                & [F:REC]RECBUL <> ""
&                Order By Key CLE = [F:REC]RETNUM ; [F:REC]RECBUL

[L]OK_CONTROLE = 2

For [F:REC]CLE
    Read [F:VEP]VEP5 = [F:REC]RECBUL
    # ajout test Verrouillé US 2022 65062
    If fstat <> 0 or ( fstat = 0 & ([F:VEP]PST > 1 | [F:VEP]FLGLOCK=2 ))
        [L]OK_CONTROLE = 1
        [L]WMESSAGE = mess(226,10703,1)
        # mess(196,702,1) : Annulation en masse impossible\Présence de bulletins comptabilisés
        If [F:VEP]PST > 1 : [L]WMESSAGE = mess(196,10702,1) : Endif
        # mess(226,703,1)\mess(227,703,1) : Annulation en masse impossible\Présence de bulletins verrouillés
        If [F:VEP]FLGLOCK=2 : [L]WMESSAGE += "\"+mess(227,10703,1) : Endif
        Break
    Endif
Next

Filter [F:REC]

Call TEMPOFF From GESECRAN

If [L]OK_CONTROLE = 1
    # US 2022 65062
    Call ERREUR([L]WMESSAGE) From GESECRAN
    Return
Endif

Case [M:RET0]RETTYP
 When 1,2 : Gosub ANNULE_RAPPEL
 When 3   : Gosub ANNULE_EXTOURNE
Endcase
Return

####################################
$ANNULE_RAPPEL
# mess(197,10702,1) : Annulation en masse
Call OUVRE_TRACE(mess(197,10702,1)-[M:RET0]RETNUM) From LECFIC

Call DEBTRANS From GLOCK
Trbegin [VEP],[REC],[RET],[HRCTR]
[V]GOK = 1

# mess(198,10702,1) : Annulation
Call OUVRE_BOITE(mess(198,10702,1), [M:RET3]NBCAL) From GESECRAN

I=1
For [F:REC]REC0 Where RETNUM = [M:RET0]RETNUM & RECBUL<> ""
 Call AFF_BOITE([F:REC]RECBUL, I, [L]OK_CONTROLE) From GESECRAN
 # Annule calcul bulletin
 Call ANNULE_BULLETIN([F:REC]RECBUL, 0, [L]OK_CONTROLE) From TRTSUP
 If [V]GOK < 1 : Break : Endif
 I+=1
Next
If [V]GOK>0
 #Supprime les lignes de rappels
 Gosub DELETE_REC
 If [V]GOK>0
  ##**72216 : Supprime les lignes de détails des rappels
  Gosub DELETE_HSR
  If [V]GOK>0
   Gosub DELETE_THR
   If [V]GOK>0
    #Si retro indiv repasse le statut du contrat à 'en cours'
    If [M:RET0]RETTYP =1
     For nolign = 1 To [M:RET3]NBSAL
       # Le dernier contrat avec avenant rétroactif est flaggué comme pris en compte
       ##**72216 : Ajout critère sur CTRDAT
       Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [F:RES]REFNUM & [F:HRCTR]CTRNUM = [F:RES]CTRNUM
&                          & [F:HRCTR]CTRDAT = [M:RET3]DATLSTREV(nolign-1)
&                          & [F:HRCTR]FLGRET = 2 & [F:HRCTR]RETSTATUT = 3
&                          & [F:HRCTR]RETTYP = [M:RET0]RETTYP
       Readlock [F:HRCTR]CTR0 Last
       Filter [F:HRCTR]
       If fstat = 0
        [F:HRCTR]RETSTATUT = 2
        Rewrite [F:HRCTR]
        If fstat : GOK=0 : Endif
       Elsif fstat = 1
        [V]GOK = -1 : [V]GLOCK = "$EMPLOCTR"
        Break
       Endif
      Next
    Endif
   Endif
  Endif
  If [V]GOK>0
   #Repasse le statut de la fiche retro à 'en cours'
   Readlock [F:RET]RET0 = [M:RET0]RETNUM
   If !fstat :
    [F:RET]STATUT = 2
    Rewrite [F:RET]
    If fstat : GOK=0 : Endif
   Endif
  Endif
 Endif
Endif
Call FERME_BOITE From GESECRAN
Call FERME_TRACE() From LECFIC

If [V]GOK = 1
    Commit
Else
    Rollback
Endif

Call LEC_TRACE From LECFIC
Return

####################################
$ANNULE_EXTOURNE
Raz [L]NBBUL
If clalev([F:RTP])=0 : Local File RETROTMP [RTP] : Endif

Look [F:RTP]RTP1=GUSER;[M:RET0]RETNUM
If !fstat
  Delete [F:RTP]RTP1=GUSER;[M:RET0]RETNUM
Endif

For [F:RES]RES0 Where [F:RES]RETNUM = [M:RET0]RETNUM
  Raz [F:RTP]
  [F:RTP]USR=GUSER
  [F:RTP]RETNUM = [F:RES]RETNUM

 #Annulation du bulletin de 'référence' pour valeurs de variables (si pas calculé)
 Filter [F:VEP] Where [F:VEP]EMP = [F:RES]REFNUM
&                    & [F:VEP]CTRNUM = [F:RES]CTRNUM & [VEP]STA<2
&                    & [F:VEP]PYRDAT >= [M:RET1]DATMININT
&                    & [F:VEP]FLGLOCK<>2  : # Verrouillé US 2022 65062
 For [F:VEP]VEP0
  [F:RTP]RECBUL = [F:VEP]BUL
  [F:RTP]NUMORD = [L]NBBUL
  Write [RTP]
  If !fstat
    [L]NBBUL += 1
  Endif
 Next
 Filter [VEP]

    # Pour un salarié, récupérer les bulletins dans le bon ordre :
    # On va annuler les nouveaux bulletins dans l'ordre inverse de la création
    # Décembre, puis novembre, puis septembre par exemple
    # Puis annulation des extournes
    # Deux boucles pour ca pour prévoir deux types de tri => au final non ....

    Filter [F:REC] Where [F:REC]RETNUM = [M:RET0]RETNUM
&                    & [F:REC]RECREFNUM = [F:RES]REFNUM
&                    & [F:REC]RECCTRNUM = [F:RES]CTRNUM
&                    & [F:REC]RECRUBCOD = ""
&                    & [F:REC]RECTYP = "N"
&                    Order By Key CLE = [F:REC]RECORD Desc

    For [F:REC]CLE
        [F:RTP]RECBUL = [F:REC]RECBUL
        [F:RTP]NUMORD = [L]NBBUL
        Write [RTP]
        If !fstat
          [L]NBBUL += 1
        Endif
    Next

    Filter [F:REC]

    Filter [F:REC] Where [F:REC]RETNUM = [M:RET0]RETNUM
&                    & [F:REC]RECREFNUM = [F:RES]REFNUM
&                    & [F:REC]RECCTRNUM = [F:RES]CTRNUM
&                    & [F:REC]RECRUBCOD = ""
&                    & [F:REC]RECTYP = "E"
&                    Order By Key CLE = [F:REC]RECORD Desc
#                      Si on voulait être parfait on devrait le faire en "ASC" de manière
#                      à supprimer les bulletins dans l'ordre de création ( septembre, puis aout, puis ... )
#                      mais cela pose un souci avec le controle que l'on a fait sur la chronologie n° bulletin
# &                    Order By Key CLE = [F:REC]RECORD Asc

    For [F:REC]CLE
        [F:RTP]RECBUL = [F:REC]RECBUL
        [F:RTP]NUMORD = [L]NBBUL
        Write [RTP]
        If !fstat
          [L]NBBUL += 1
        Endif
    Next

    Filter [F:REC]

Next
# mess(197,10702,1) : Annulation en masse
Call OUVRE_TRACE(mess(197,10702,1)-[M:RET0]RETNUM) From LECFIC

Call DEBTRANS From GLOCK
Trbegin [VEP],[HRCTR]
[V]GOK = 1
# mess(198,10702,1) : Annulation
Filter [F:RTP] Where USR=GUSER & RETNUM=[M:RET0]RETNUM
Call OUVRE_BOITE(mess(198,10702,1), rowcount([RTP])) From GESECRAN
[L]I=1
For [RTP]
  Call AFF_BOITE([F:RTP]RECBUL, [L]I, [L]OK_CONTROLE) From GESECRAN
  Call ANNULE_BULLETIN([F:RTP]RECBUL, 2, [L]OK_CONTROLE) From TRTSUP
  If [V]GOK < 1 : Break : Endif
  [L]I+=1
Next
Filter [F:RTP]
#end 85077
If [V]GOK>0
 For nolign = 1 To [M:RET3]NBSAL
    # Le dernier contrat avec avenant rétroactif est flaggué comme pris en compte
    ##**72216 : Ajout critère sur CTRDAT
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [M:RET3]REFNUM (nolign-1) & [F:HRCTR]CTRNUM = [M:RET3]CTRNUM (nolign-1)
&                        & [F:HRCTR]CTRDAT = [M:RET3]DATLSTREV(nolign-1)
&                        & [F:HRCTR]FLGRET = 2 & [F:HRCTR]RETSTATUT = 3
&                        & [F:HRCTR]RETTYP = [M:RET0]RETTYP
    Readlock [F:HRCTR]CTR0 Last
    Filter [F:HRCTR]
    If fstat = 0
        [F:HRCTR]RETSTATUT = 2
        Rewrite [F:HRCTR]
    Elsif fstat = 1
        [V]GOK = -1 : [V]GLOCK = "$EMPLOCTR"
        Break
    Endif
 Next
Endif
Call FERME_BOITE From GESECRAN
Call FERME_TRACE() From LECFIC

If [V]GOK = 1
   Commit
Else
   Rollback
Endif
Delete [F:RTP]RTP1=GUSER;[M:RET0]RETNUM
Call LEC_TRACE From LECFIC
Return

#-----------------------------------
# LOAD_REC : Chargement des rappels
#-----------------------------------
########################################
Subprog LOAD_REC(RETNUM, FLGREG)
Value Char RETNUM()
Value Integer FLGREG
Effzo [M:RET3] 80
Raz nolign
For [F:REC]REC2 Where [F:REC]RETNUM = [L]RETNUM
  nolign += 1
  [M:RET3] = [F:REC]
  [M:RET3]TIDREC(nolign-1) = func SUBRET.GET_IDREC([F:REC]RECREFNUM, [F:REC]RECCTRNUM, [F:REC]RECRUBCOD)
  [M:RET3]TIDSALCTRREC(nolign-1) = func SUBRET.GET_IDSALCTR([F:REC]RECREFNUM, [F:REC]RECCTRNUM)
Next
[M:RET3]NBCAL = nolign
##**72216 : Si la fiche est lockée, c'est que THR est déjà chargé :)
If [L]FLGREG : Gosub LOAD_THR : Endif
End

#-------------------------------------
# LOAD_RETVAL : Chargement des valeurs
#-------------------------------------
########################################
#Remplis tableau depuis les valeurs stockés dans la table RETROVAL
$LOAD_RETVAL
Gosub GRISE_RET4_LOAD

Effzo [M:RET4]50
Raz nolign
For [F:RVL]RVL0 Where RETNUM=[M:RET0]RETNUM
  nolign +=1
  [M:RET4]LIG(nolign-1)    = [F:RVL]LIG
  [M:RET4]TYPRVL(nolign-1) = [F:RVL]TYPRVL
  [M:RET4]VARCOD(nolign-1) = [F:RVL]VARCOD
  [M:RET4]TYP(nolign-1)    = [F:RVL]TYP
  [M:RET4]STRPAY(nolign-1) = [F:RVL]STRPAY
  [M:RET4]ENDPAY(nolign-1) = [F:RVL]ENDPAY
  [M:RET4]STRBUL(nolign-1) = [F:RVL]STRBUL
  [M:RET4]ENDBUL(nolign-1) = [F:RVL]ENDBUL
  [M:RET4]VALORI(nolign-1) = [F:RVL]VALORI
  [M:RET4]VALDEN(nolign-1) = [F:RVL]VALDEN
  [M:RET4]TIDSALCTRREC(nolign-1) = func SUBRET.GET_IDSALCTR([F:RVL]REFNUM, [F:RVL]CTRNUM)
  [M:RET4]TIDSALCTRLIG(nolign-1) = func SUBRET.GET_IDSALCTRLIG([F:RVL]REFNUM, [F:RVL]CTRNUM, [F:RVL]LIG)
Next
[M:RET4]NBRVL = nolign
Return

##**72216
#-----------------------------------
# LOAD_THR : Chargement temporaire du détail des rappels
#-----------------------------------
########################################
$LOAD_THR
Gosub DELETE_THR
If [V]GOK < 1 : Return : Endif
For [F:HRHSR]HRHSR0 Where RETNUM=[M:RET0]RETNUM
 [F:THR]=[F:HRHSR]
 [F:THR]CODTRT="RET"
 Write [THR]
 If fstat <> 0
  [V]GOK = 0
  Call FSTA("THR") From GLOCK
  Break
 Endif
Next
If [V]GOK < 1 : Return : Endif
Return

#--------------------------------------------------------------
# GET_IDREC : Fabrication standardisée d'un identifiant rappel
#--------------------------------------------------------------
########################################
Funprog GET_IDREC(REFNUM, CTRNUM, RUBCOD)
Value Char REFNUM(), CTRNUM(), RUBCOD()
Local Char IDREC(250)
[L]IDREC = [L]REFNUM + "~" + [L]CTRNUM + "~" + [L]RUBCOD
End [L]IDREC

#-----------------------------------------------------------------
# GET_IDSALCTR : Fabrication standardisée d'un id salarié/contrat
#-----------------------------------------------------------------
########################################
Funprog GET_IDSALCTR(REFNUM, CTRNUM)
Value Char REFNUM(), CTRNUM()
Local Char IDSALCTR(250)
[L]IDSALCTR = [L]REFNUM + "~" + [L]CTRNUM
End [L]IDSALCTR

#-----------------------------------------------------------------
# GET_IDSALCTRLIG : Fabrication standardisée d'un id salarié/contrat/Ligne
#-----------------------------------------------------------------
########################################
Funprog GET_IDSALCTRLIG(REFNUM, CTRNUM, LIGNE)
Value Char REFNUM(), CTRNUM()
Value Integer LIGNE
Local Char IDSALCTRLIG(250)

[L]IDSALCTRLIG = [L]REFNUM + "~" + [L]CTRNUM +"~" + num$([L]LIGNE)
End [L]IDSALCTRLIG

#--------------------------------- ECRAN ---------------------------------

$SETNOL
Local Integer NOL
[L]NOL = nolign-1
Return

######################################################################################
## Ecran RET0
######################################################################################

Subprog AS_STATUT(VALEUR)
Variable Integer  VALEUR
# On interdit le statut "validé" en saisie
[V]GMENLOC(len(mess(0,10645,1))) = 1
End

Subprog AM_RETTYP(VALEUR)
Variable Integer  VALEUR
Call GRISE_RET2([L]VALEUR)
End

Subprog GRISE_RET2(VALEUR)
Value Integer  VALEUR
#94898
Case [L]VALEUR
    When 1  : If [M:RET0]STATUT <> 3 : Actzo [M:RET1]DATAVTEFF : Endif
              Actzo [M:RET5]
    When 2  : Effzo [M:RET1]DATAVTEFF : Grizo [M:RET1]DATAVTEFF : Actzo [M:RET5]
    When 3  : If [M:RET0]STATUT <> 3 : Actzo [M:RET1]DATAVTEFF : Endif
              Effzo [M:RET5] :  Grizo [M:RET5] :# Extourne, le tableau des rubriques est inutile
Endcase
#end 94898
End

######################################################################################
## Ecran RET1
######################################################################################

Subprog AV_ENAFLG(VALEUR)
Variable Integer  VALEUR
If [M:RET0]RETTYP = 3 | [M:RET0]STATUT = 3
   Grizo [M:RET1]ENAFLG
Else
   Actzo [M:RET1]ENAFLG
Endif
End

Subprog C_DATMININT(VALEUR)
Variable Date    VALEUR
If [L]VALEUR < [M:RET1]DATEFF
 GMESSAGE=mess(98,10701,1) #: Cette date ne peut pas être inférieure à la date d'effet de la fiche.
 mkstat = 2 : End
Endif
End

Subprog AS_DATAVTEFF(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M:RET1]DATEFF : Endif
End

Subprog C_DATAVTEFF(VALEUR)
Variable Date    VALEUR
If [L]VALEUR < [M:RET1]DATEFF
 GMESSAGE=mess(98,10701,1) #: Cette date ne peut pas être inférieure à la date d'effet de la fiche.
 mkstat = 2 :  End
Endif
End

######################################################################################
## Ecran RET2
######################################################################################

Subprog IB_NBVRA
If [M:RET0]STATUT = 3 :  Raz [V]GBOUT1 : End : Endif
End

Subprog C_NBVRA
If [M:RET0]STATUT=3 & !adxgtb
 mkstat=2 : End
Endif
End

#--------------- --------
# Préchargement variables
###**72216 revu
#--------------- --------
Subprog B1_NBVRA
nolign=[M:RET2]NBVRA+1
For [F:VRA]VRA0 Where [F:VRA]FLGRET = 2 & [F:VRA]LEG=GCURLEG
    If nolign >= dim([M:RET2]VRACOD)-1
        Call ERREUR(mess(26, 100, 1)) From GESECRAN  :# Tableau plein
        Break
    Endif
    If !find("1~"+[F:VRA]COD, [M:RET2]UNQ)
        [M:RET2]VRACOD(nolign-1) = [F:VRA]COD
        [M:RET2]DATVAL(nolign-1) = [M:RET1]DATMININT
        [M:RET2]TYPREV(nolign-1) = 1
        Call CHARGE_COD([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]LONG(nolign-1),[M:RET2]OPT(nolign-1))
        Call CHARGE_DES([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]VRACOD(nolign-1),[M:RET2]VRADES(nolign-1))
        [M:RET2]UNQ(nolign-1) = "1~"+[F:VRA]COD
        nolign+=1
    Endif
Next
[M:RET2]NBVRA=nolign-1
Affzo [M:RET2] : mkstat = 4
End

Subprog AS_DATVAL(VALEUR)
Variable Date     VALEUR
If [L]VALEUR = [0/0/0] :   [L]VALEUR = [M:RET1]DATMININT : Endif
End

Subprog IB_NBRUB
If [M:RET0]STATUT = 3 :  Raz [V]GBOUT1 : End : Endif
End

Subprog C_NBRUB
If [M:RET0]STATUT=3 & !adxgtb
 mkstat=2 : End
Endif
End

#--------------- --------
# Préchargement rubriques
#--------------- --------
Subprog B1_NBRUB
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
#95878
If nbrecord([RUB])>0
   Local Char LSTOFNOTRETHEADING(GLONRUB)(0..nbrecord([RUB]))
Else
   Local Char LSTOFNOTRETHEADING(GLONRUB)
Endif
#end 95878
#Local Char LSTOFNOTRETHEADING(GLONRUB)(0..)
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
Local Integer NBOFNOTRET
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
Local Integer OLDNBRUB :#95878

OLDNBRUB=[M:RET5]NBRUB :#95878
#MIPEA - 2016-06-24 - REQ 114309 US128 - END

#91912
## On veut précharger uniquement les rubriques "rétroactives" concernées
## par les variables, taux at, grilles, champs salariés saisis dans la fiche de rétro
Call GETRUBIMPACTED(LSTOFNOTRETHEADING, NBOFNOTRET)

## Si des rubriques non cochées "rétroactives" sont aussi concernées par la saisie
## on l'indique dans une trace
If NBOFNOTRET>0
   Local Char TIT (250)
   Local Integer I
   #LIPET - 2018-02-28 - X3-12020 - START
   #TIT=mess(228,703,1)
   TIT=mess(228,10703,1)
   #LIPET - 2018-02-28 - X3-12020 - END
   Call OUVRE_TRACE(TIT) From LECFIC
   Call ECR_TRACE(TIT,0) From GESECRAN
   Call ECR_TRACE("",0) From GESECRAN
   For I=0 To NBOFNOTRET-1
    Call ECR_TRACE(LSTOFNOTRETHEADING(I),0) From GESECRAN
   Next I

   Call LEC_TRACE From LECFIC
Endif
#end 91912
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
Affzo [M:RET5]
#95878
If [M:RET5]NBRUB > OLDNBRUB
  mkstat = 4
Endif
#end 95878
#Affzo [M:RET5] : mkstat = 4
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
End

###################################
#91912
###################################
#Fonction qui récupère les rubriques impactés en parcourant le fichier XML des rubriques et leurs dépendances.
#Cette fonction va copier les rubriques cochées "rétroactive" directement dans le tableau des rubriques
#et retourner une liste des rubriques impactées mais non rétroactives (avec le nombre d'élément de ce tableau).
###################################
Subprog GETRUBIMPACTED(LSTOFNOTRETHEADING, NBOFNOTRET)
Variable Char LSTOFNOTRETHEADING()(0..)
Variable Integer NBOFNOTRET
Local Integer I, VNBOBJ, VNBRUB, ISRETRO, ADDHEADING
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
Local Integer K :#95878
#Local Char LSTOFOBJ(max(GLONAVA,GLONRUB,GLONCUM,GLONVRA))(0..,1..2)
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
Local Char CURREC(250), CURHEADING(GLONRUB), XMLTYPOBJ(1), XMLCODOBJ(20) :#datas from xml file
Local Char LEGPLAN(GLONADI)
[L]LEGPLAN=GCURLEG
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
#95878
Local Char CODACV(4)
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
VNBOBJ=0
For CODACV="RVRA", "RVAL", "RRUB"
  Read [ACV]CODACT=CODACV
  If !fstat & VNBOBJ<32700
    VNBOBJ+=[ACV]DIMMAX
  Endif
Next
If VNBOBJ=0
  If clalev([F:CUM])=0 : Local File CUMUL [CUM] : Endif
  VNBOBJ=nbrecord([CUM])
Endif
Local Char LSTOFOBJ(max(GLONAVA,GLONRUB,GLONCUM,GLONVRA))(0..VNBOBJ,1..2)
VNBOBJ=0
#end 95878
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
#On créé une liste avec toutes les variables, champs salariés, taux at, grilles
#saisis dans la fiche

Call SETLSTOFOBJ(LSTOFOBJ,VNBOBJ)

Raz LSTOFNOTRETHEADING, NBOFNOTRET

#Si rien de saisi, rien à précharger.
If VNBOBJ>0
  #si plan de paie pas à jour ou fichier xml inexistant, on le génère
  If GPLANOK | filinfo(filpath("BQE","W"+[L]LEGPLAN+"XMLRUBDEP","xml"),1) <0
    Gosub GENRUBXML From GENPLAN
  Endif

  VNBRUB=0

  Openi filpath('BQE','W'+[L]LEGPLAN+'XMLRUBDEP','xml'),0 Using [HHH]

  #On parcours le fichier XML, pour chaque "objet" utilisé, on contrôle si il correspond à un "objet"
  #de la liste (un objet = code + type)
  Rdseq CURREC Using [HHH]
  While fstat=0
    If pat(CURREC,"*<heading code*>*")
      #On récupère le code de la rubrique et l'info cochée rétroactive ou pas.
      POSDEB=instr(1,CURREC,'code=')+6 : POSFIN=instr(POSDEB,CURREC,'" backpay')-1
      CURHEADING=seg$(CURREC,POSDEB,POSFIN)
      ISRETRO=val(mid$(CURREC,instr(1,CURREC,'backpay=')+9,1))
    Elsif pat(CURREC,"*<use*>*") and  CURHEADING<>""
      POSDEB=instr(1,CURREC,'type=')+6
      XMLTYPOBJ=mid$(CURREC,POSDEB,1) :#type de l'objet trouvé
      POSDEB+=3 : POSFIN=instr(POSDEB,CURREC,'</use>')-1
      XMLCODOBJ=seg$(CURREC,POSDEB,POSFIN) :#code de l'objet trouvé
      #si ce code objet existe dans ma liste, je vais contrôler que l'objet existe dans la liste
      ADDHEADING=0
      If XMLTYPOBJ="T" & find(XMLTYPOBJ,LSTOFOBJ(0..VNBOBJ-1,2)):#TXRISK
        ADDHEADING=1
      #MIPEA - 2016-06-24 - REQ 114309 US128 - START
        #95878
        K=find(XMLCODOBJ,LSTOFOBJ(0..VNBOBJ-1,1))
        #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
        If K>0
          For I=K-1 To VNBOBJ-1
            If (LSTOFOBJ(I,1)=XMLCODOBJ & LSTOFOBJ(I,2)=XMLTYPOBJ)
              ADDHEADING=1 : Break
            Endif
          Next I
        Endif
        #end 95878
      #Elsif find(XMLCODOBJ,LSTOFOBJ(0..VNBOBJ-1,1))
      #MIPEA - 2016-06-24 - REQ 114309 US128 - END
        #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
        For I=0 To VNBOBJ-1
          If (LSTOFOBJ(I,1)=XMLCODOBJ & LSTOFOBJ(I,2)=XMLTYPOBJ)
            ADDHEADING=1 : Break
          Endif
        Next I
      Endif
      #l'objet existe dans la liste, on doit ajouter la rubrique
      If ADDHEADING
        If ISRETRO
          #ajout directement dans le tableau des rubriques
          If !find(CURHEADING,[M:RET5]RUBCOD)
            If [M:RET5]NBRUB >= dim([M:RET5]RUBCOD)
                Call ERREUR(mess(26, 100, 1)) From GESECRAN  :# Tableau plein
                Break
            Else
              [M:RET5]RUBCOD([M:RET5]NBRUB) = CURHEADING
              [M:RET5]NBRUB += 1
            Endif
          Endif
        Else
          #ajout dans la liste utilisée pour la trace
          If !find(CURHEADING,LSTOFNOTRETHEADING)
            LSTOFNOTRETHEADING(NBOFNOTRET) = CURHEADING
            NBOFNOTRET+=1
          Endif
        Endif
      Endif
    Endif
    Rdseq CURREC Using [HHH]
  Wend
  Openi Using [HHH]
Endif
End

#####################
#Remplissage de la liste des objets saisis dans la fiche rétro
#####################
Subprog SETLSTOFOBJ(LSTOFOBJ,VNBOBJ)
Variable Integer VNBOBJ
Variable Char LSTOFOBJ()(0..,1..)
Local Integer I, J, ADDOBJ
Local Char CURFLD(GLONAVA), VTYPE(1)

Raz LSTOFOBJ, VNBOBJ
## Get obj from table of variables
For I=0 To [M:RET2]NBVRA-1
  If VNBOBJ>dim(LSTOFOBJ,1) : Break : Endif
  Case [M:RET2]TYPREV(I)
    When 1 : VTYPE="V"
    When 2 : VTYPE="T"
    When 3 : VTYPE="G"
    When Default : VTYPE=""
  Endcase
  LSTOFOBJ(I,1)= [M:RET2]VRACOD(I)
  LSTOFOBJ(I,2)= VTYPE
  VNBOBJ+=1
Next I
## Get obj from table of values
For I=0 To [M:RET4]NBRVL-1
  If VNBOBJ>=dim(LSTOFOBJ,1) : Break : Endif
  ADDOBJ=1
  Case [M:RET4]TYPRVL(I)
    When 1 : VTYPE="V"
    When 2 : VTYPE="T"
    When 3 : VTYPE="G"
    When Default : VTYPE=""
  Endcase
  #MIPEA - 2016-06-24 - REQ 114309 US128 - START
  #95878
  K=find([M:RET4]VARCOD(I),LSTOFOBJ(0..VNBOBJ-1,1))
  If K>0
  #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
    For J=K-1 To VNBOBJ-1
      If ([M:RET4]VARCOD(I)=LSTOFOBJ(J,1) & VTYPE=LSTOFOBJ(J,2))
        ADDOBJ=0 : Break
      Endif
    Next J
  Endif
  #end 95878
#  If find([M:RET4]VARCOD(I),LSTOFOBJ(0..VNBOBJ-1,1))
#  #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
#    For J=0 To VNBOBJ-1
#      If ([M:RET4]VARCOD(I)=LSTOFOBJ(J,1) & VTYPE=LSTOFOBJ(J,2))
#        ADDOBJ=0 : Break
#      Endif
#    Next J
#  Endif
  #MIPEA - 2016-06-24 - REQ 114309 US128 - END
  If ADDOBJ
    LSTOFOBJ(VNBOBJ,1)= [M:RET4]VARCOD(I)
    LSTOFOBJ(VNBOBJ,2)= VTYPE
    VNBOBJ+=1
  Endif
Next I
## Get obj from table of backpay fields of the contract
If !clalev([F:RCR]) : Local File RETROCTR [RCR] : Endif
For I=0 To [M:RET4]NBEML-1
  If VNBOBJ>=dim(LSTOFOBJ,1) : Break : Endif
  Filter [RCR] Where REFNUM=[M:RET4]REFNUM(I) & CTRNUM=[M:RET4]CTRNUM(I) & CTRDAT=[M:RET4]DATLSTREV(I)
  Raz CURFLD
  For [F:RCR]RCR2(4)
    If CURFLD<>[F:RCR]FLD
      CURFLD=[F:RCR]FLD : ADDOBJ=1
      #MIPEA - 2016-06-24 - REQ 114309 US128 - START
            #95878
      K=find(CURFLD,LSTOFOBJ(0..VNBOBJ-1,1))
      If K>0
      #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
        For J=K-1 To VNBOBJ-1
          If (CURFLD=LSTOFOBJ(J,1) & LSTOFOBJ(J,2)="F")
            ADDOBJ=0 : Break
          Endif
        Next J
      Endif
      #end 95878
#      If find(CURFLD,LSTOFOBJ(0..VNBOBJ-1,1))
#      #Attention, dans la liste, plusieurs objets peuvent avoir le même code avec un type différent
#        For J=0 To VNBOBJ-1
#          If (CURFLD=LSTOFOBJ(J,1) & LSTOFOBJ(J,2)="F")
#            ADDOBJ=0 : Break
#          Endif
#        Next J
#      Endif
      #MIPEA - 2016-06-24 - REQ 114309 US128 - END
    Endif
    If ADDOBJ
      LSTOFOBJ(VNBOBJ,1)= CURFLD
      LSTOFOBJ(VNBOBJ,2)= "F"
      VNBOBJ+=1
    Endif
  Next
Next I
End
#end 91912

##########
##**72216
##########
Subprog AM_TYPREV(VALEUR)
Variable Integer VALEUR
[M]TYPREV(nolign-1)=VALEUR
Call CHARGE_COD([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]LONG(nolign-1),[M:RET2]OPT(nolign-1))
End

Subprog C_VRACOD(VALEUR)
Variable Char    VALEUR()
If [M:RET2]TYPREV(nolign-1)=1
 Call CONTSEL([M:RET2]CODTYP(nolign-1),"R",VALEUR,GCURLEG,mkstat) From CONTOBJ
Else
 Call CONTSEL([M:RET2]CODTYP(nolign-1),"",VALEUR,GCURLEG,mkstat) From CONTOBJ
Endif
If mkstat : End : Endif
[M:RET2]UNQ(nolign-1) = num$([M:RET2]TYPREV(nolign-1))+"~"+VALEUR
Call UNICITE([M:RET2]UNQ(nolign-1),[M:RET2]UNQ(0..[M:RET2]NBVRA-1)) From OBJDIV
If mkstat : GMESSAGE = VALEUR - GMESSAGE : End : Endif
End

Subprog AM_VRACOD(VALEUR)
Variable Char    VALEUR()
[M:RET2]VRACOD(nolign-1)=VALEUR
Call CHARGE_DES([M:RET2]TYPREV(nolign-1),[M:RET2]CODTYP(nolign-1),[M:RET2]VRACOD(nolign-1),[M:RET2]VRADES(nolign-1))
End

Subprog IB_VRACOD
If[M:RET2]TYPREV(nolign-1)<>3
 Raz [V]GBOUT3        :#Valeurs de grilles
Endif
End

######################################################################################
## Ecran RET3 - Tableau des salariés
######################################################################################
Subprog IB_NBSAL
#Tunnel bulletins
GBIDC1=[M:RET3]CTRNUM(nolign-1)
Call INIT_B1_B2
End

Subprog AV_NBSAL
Local Integer RANG, POS
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
If clalev([F:VEP2])=0 : Local File VALEMP     [VEP2] : Endif
Gosub SETNOL
Effzo [M:RET3] 10
[L]IDSALCTR = func SUBRET.GET_IDSALCTR([M:RET3]REFNUM([L]NOL), [M:RET3]CTRNUM([L]NOL))
[L]RANG = find([L]IDSALCTR, [M:RET3]TIDSALCTRREC)
[L]RANG -= 1
If [L]RANG >= 0
 Raz [L]POS
 #Maj tableau 2 de l'écran des salariés (liste de bulletins).
 While [M:RET3]TIDSALCTRREC([L]RANG) = [L]IDSALCTR & [L]RANG < dim([M:RET3]TIDSALCTRREC)
  [M:RET3]VRECBUL([L]POS) = [M:RET3]RECBUL([L]RANG)
  [M:RET3]VRECRUBCOD([L]POS) = [M:RET3]RECRUBCOD([L]RANG)
  [M:RET3]VAMTRAPSAL([L]POS) = [M:RET3]AMTRAPSAL([L]RANG)
  [M:RET3]VAMTRAPPAT([L]POS) = [M:RET3]AMTRAPPAT([L]RANG)
  [M:RET3]VTIDREC([L]POS) =  [M:RET3]TIDREC([L]RANG)
  ##**72216
  [M:RET3]VLIGSAL([L]POS) = [L]NOL
  If [M:RET0]RETTYP=3
   Read [F:VEP2]VEP5=[M:RET3]VRECBUL([L]POS)
   If !fstat
    [M:RET3]VSTRDAT([L]POS) = [F:VEP2]STRDAT
    [M:RET3]VENDDAT([L]POS) = [F:VEP2]ENDDAT
    [M:RET3]VPYRDAT([L]POS) = [F:VEP2]PYRDAT
    [M:RET3]VORIBUL([L]POS) = [F:VEP2]ORIBUL
    [M:RET3]VORIDAT([L]POS) = [F:VEP2]ORIDAT
    If [M:RET3]VORIBUL([L]POS)  <>""
     Read [F:VEP2]VEP5=[M:RET3]VORIBUL([L]POS)
     If !fstat
      [M:RET3]VRVSDAT([L]POS) = [F:VEP2]RVSDAT
     Endif
    Endif
   Endif
  Endif
  #
  [L]RANG += 1
  [L]POS += 1
 Wend
 [M:RET3]NBVCAL = [L]POS
 Affzo [M:RET3] 10
Endif
End



Subprog B2_NBSAL
Gosub SETNOL
Gosub CONTROLE_RECALCUL
If [L]OK_RECALCUL
   ##**85110
   Local Char TIT (250)
   TIT=mess(195,10702,1)
   Call OUVRE_TRACE(TIT) From LECFIC
   Call ECR_TRACE(TIT,0) From GESECRAN

   Call RETRO([M:RET0]RETNUM, [M:RET3]REFNUM([L]NOL), [M:RET3]CTRNUM([L]NOL), 1) From TRTRETVAL

   Call FERME_TRACE From LECFIC

   Call LOAD_REC([M:RET0]RETNUM,1) From SUBRET
   nolign = [L]NOL + 1        : # Sécurité
   Call AV_NBSAL

   Call LEC_TRACE From LECFIC
Endif
End

########################################
$SETCTR
Local Char CRICTR(250)
If [M:RET3]REFNUM([L]NOL) <> "" & [M:RET3]CTRNUM([L]NOL) <> ""
    Case [M:RET0]RETTYP
        When 1,3
            [L]CRICTR = "[F:HRCTR]RETTYP = [M:RET0]RETTYP"
            [L]CRICTR += "&"
            [L]CRICTR += "[F:HRCTR]FLGRET = 2"
            [L]CRICTR += "&"
            [L]CRICTR += "[F:HRCTR]RETDATEFF<=[M:RET1]DATAVTEFF"
            [L]CRICTR -= "&"
            [L]CRICTR -= "[F:HRCTR]CTRDAT <= [M:RET1]DATMININT" :##**72216
        When 2
            [L]CRICTR = "[F:HRCTR]CTRDAT <= [M:RET1]DATMININT"
    Endcase
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [M:RET3]REFNUM([L]NOL)
&                    & [F:HRCTR]CTRNUM = [M:RET3]CTRNUM([L]NOL)
&                    & evalue([L]CRICTR)

    Read [F:HRCTR]CTR0 Last

    Filter [F:HRCTR]
Endif
Return

########################################
$CTRL_CTR
# Vérification si contrat compatible
If [M:RET0]RETTYP = 1 or [M:RET0]RETTYP = 3
    Filter [F:HRCTR] Where [F:HRCTR]REFNUM = [L]REFNUM
&                    & [F:HRCTR]CTRNUM = [L]CTRNUM

    Read [F:HRCTR]CTR0 Last
    Filter [F:HRCTR]
    If fstat <= 2
        If [F:HRCTR]FLGRET <> 2
            # mess(105,10701,1) : Pas de rétroactivité constatée sur ce contrat.
            Call AVERTIR(mess(105,10701,1), [L]OK) From GESECRAN
            If [L]OK = 1 : mkstat = 2 : Return : Endif
        Else
            If [F:HRCTR]RETTYP <> [M:RET0]RETTYP
                # mess(106,10701,1) : Type de rétroactivité de l'avenant différent de celui de la fiche.
                Call ERREUR(mess(106,10701,1)) From GESECRAN
                mkstat = 2 : Return
            Endif
            If [F:HRCTR]RETDATEFF > [M:RET1]DATAVTEFF
                # mess(107,10701,1) : Date d'effet de l'avenant postérieure à celle de la fiche.
                Call ERREUR(mess(107,10701,1)) From GESECRAN
                mkstat = 2 : Return
            Endif
        Endif
        # Présence d'un paye ?
        Filter [F:VEP] Where [F:VEP]EMP = [F:HRCTR]REFNUM
&               & [F:VEP]CTRNUM = [F:HRCTR]CTRNUM
&               & [F:VEP]PYRDAT >= [M:RET1]DATMININT
        Read [F:VEP] First
        Filter [F:VEP]
        If fstat <= 2
            If [F:VEP]STA > 1
                # Warning si paye calculée au delà de la date d'intégration
                #A défaut d'un recalcul du bulletin de paie en date de paie du xx/xx/xxxx
                #le rappel sera pris en compte sur la date de paie suivante.
                [L]MESSAGE = [F:HRCTR]REFNUM-[F:HRCTR]CTRNUM
                [L]MESSAGE -= "-"-mess(199,10702,1)-format$([V]GFMD, [F:VEP]PYRDAT)+","-mess(200,10702,1)
                Call AVERTIR([L]MESSAGE, [L]OK) From GESECRAN
                If [L]OK = 1 : mkstat = 2 : Return : Endif
            Endif
        Else
        #MIPEA - 2016-06-23 - REQ 114309 US128 - START
        If !GINTMT | [F:ID]FLGINT<>2
          # On ne génère pas le prochain bulletin si le salarié est sorti (régul sur ancien contrat)
          #LIPET - 2018-02-28 - X3-12020 - START
          #If [F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>[M:RET1]DATMININT
          If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>[M:RET1]DATMININT
          #LIPET - 2018-02-28 - X3-12020 - END
            #LIPET - 2018-02-28 - X3-12020 - START
            #[L]MESSAGE = [F:CTR]REFNUM-[F:CTR]CTRNUM
            [L]MESSAGE = [F:HRCTR]REFNUM-[F:HRCTR]CTRNUM
            #LIPET - 2018-02-28 - X3-12020 - END
            #[L]MESSAGE = [F:HRCTR]REFNUM-[F:HRCTR]CTRNUM
        #MIPEA - 2016-06-23 - REQ 114309 US128 - END
            Gosub CREPAY
            If !GOK
             # Pas de paye générée au delà du
             [L]MESSAGE -= "-" - mess(208,10702,1)-format$([V]GFMD, [M:RET1]DATMININT)
             Call ERREUR([L]MESSAGE) From GESECRAN
             mkstat = 2 : Return
            Elsif GOK<0
             # Echec en génération du bulletin de paie en date du
              [L]MESSAGE -= "-"-mess(231,10702,1)-format$([V]GFMD, [M:RET1]DATMININT)
              Call ERREUR([L]MESSAGE) From GESECRAN
              mkstat = 2 : Return
            Else
             # Génération du bulletin de paie en date du
             [L]MESSAGE -= "-"-mess(232,10702,1)-format$([V]GFMD, [M:RET1]DATMININT)
             Call MESSAGE([L]MESSAGE) From GESECRAN
            Endif
           Endif
         Endif
        Endif
    Endif
Endif
Return

#Génération en sous marin d'un bulletin 'destination'
##########################
$CREPAY
Local Integer PRESTAT(1..100)
Local Char    BULLETIN(GLONVCR)
Local Date    DATDEB, DATFIN
Local Char    VALPAR(10)
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
Local Date    DATPAY, DATPAI
Local Integer DECALE
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
Gosub OUVFIC From TRTAUT
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
#LIPET - 2018-02-28 - X3-12020 - START
#If !clalev([F:PEO]) : Local File PERIOD [PEO] : Endif
If !clalev([F:HRPEOD]) : Local File HRPEODET [HRPEOD] : Endif
#LIPET - 2018-02-28 - X3-12020 - START
#MIPEA - 2016-06-24 - REQ 114309 US128 - END

GOK=1

# Hors intermittents.
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
#If [F:ID]FLGINT=2 & GINTMT=1
# GOK=0 : Return
#Endif
#MIPEA - 2016-06-24 - REQ 114309 US128 - END

#MIPEA - 2016-06-24 - REQ 114309 US128 - START
DATPAY = [M:RET1]DATMININT
DATPAI = [M:RET1]DATMININT
#LIPET - 2018-02-28 - X3-12020 - START
#Call PARAML([F:CTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
Call PARAML([F:HRCTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
#LIPET - 2018-02-28 - X3-12020 - END
If val(VALPAR)<>0 & val(VALPAR)<>day([M:RET1]DATMININT)
 #LIPET - 2018-02-28 - X3-12020 - START
 #Call ECR_TRACE([F:ID]REFNUM-":"-mess(117,702,1)-VALPAR,-1) From GESECRAN
 Call ECR_TRACE([F:ID]REFNUM-":"-mess(117,10702,1)-VALPAR,-1) From GESECRAN
 #LIPET - 2018-02-28 - X3-12020 - END
 While day(DATPAY)<>val(VALPAR)
  DATPAY += 1
 Wend
Endif
#LIPET - 2018-02-28 - X3-12020 - START
#DECALE = (val(func AFNC.PARAM('DMA',[F:CTR]ETRFCY))<>12)
#Filter [F:PEO] Where FCY=[F:CTR]ETRFCY & [F:PEO]PYRDAT>=DATPAY & [F:PEO]PYRDAT<=eomonth(addmonth(DATPAY,DECALE))
#Read [F:PEO]PEO0 First
#Filter [F:PEO]
#If !fstat & DECALE
#  [L]DATDEB=[F:PEO]PERSTR(1)
#  [L]DATFIN=[F:PEO]PEREND(1)
#  If [L]DATPAY<[F:PEO]PYRDAT : [L]DATPAY=[F:PEO]PYRDAT : Endif
#Else
#  [L]DATDEB = max(gdat$(1,month([M:RET1]DATMININT), year([M:RET1]DATMININT)),[F:CTR]CTRDAT)
#  If [F:CTR]XITDAT=[0/0/0] | [F:CTR]XITDAT>eomonth([M:RET1]DATMININT)
#   [L]DATFIN = eomonth([M:RET1]DATMININT)
#  Else
#   [L]DATFIN = max ([L]DATDEB,[F:CTR]XITDAT)
#  Endif
#Endif
DECALE = (val(func AFNC.PARAM('DMA',[F:CTR]ETRFCY))<>12)
Filter [F:HRPEOD] Where PERCOD=[HRCTR]PERCOD & [F:HRPEOD]PYRDAT>=DATPAY & [F:HRPEOD]PYRDAT<=eomonth(addmonth(DATPAY,DECALE))
Read [F:HRPEOD]HRPEOD0 First
Filter [F:HRPEOD]
If !fstat & DECALE
  [L]DATDEB=[F:HRPEOD]PERSTR(1)
  [L]DATFIN=[F:HRPEOD]PEREND(1)
  If [L]DATPAY<[F:HRPEOD]PYRDAT : [L]DATPAY=[F:HRPEOD]PYRDAT : Endif
Else
  [L]DATDEB = max(gdat$(1,month([M:RET1]DATMININT), year([M:RET1]DATMININT)),[F:HRCTR]CTRDAT)
  If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>eomonth([M:RET1]DATMININT)
   [L]DATFIN = eomonth([M:RET1]DATMININT)
  Else
   [L]DATFIN = max ([L]DATDEB,[F:HRCTR]XITDAT)
  Endif
Endif
#LIPET - 2018-02-28 - X3-12020 - END

#Call PARAML([F:HRCTR]ETRFCY,"JPAY",VALPAR) From ADOVAL
#If val(VALPAR)<>0 & val(VALPAR)<>day([M:RET1]DATMININT)
# # Salarié en décalage de paye. Date de paye le
# Call ECR_TRACE([F:HRCTR]REFNUM-":"-mess(117,10702,1)-VALPAR,1) From GESECRAN
# GOK=0 : Return
#Endif
#
#[L]DATDEB = max(gdat$(1,month([M:RET1]DATMININT), year([M:RET1]DATMININT)),[F:HRCTR]CTRDAT)
#If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>eomonth([M:RET1]DATMININT)
# [L]DATFIN = eomonth([M:RET1]DATMININT)
#Else
# [L]DATFIN = max ([L]DATDEB,[F:HRCTR]XITDAT)
#Endif

If DATPAI<DATPAY
 DATPAI=DATPAY
Endif
#MIPEA - 2016-06-24 - REQ 114309 US128 - END

Raz [L]PRESTAT, [L]BULLETIN
Call CREPAY([F:HRCTR]REFNUM,[M:RET1]DATMININT,[L]DATDEB,[L]DATFIN,[M:RET1]DATMININT,0,[F:HRCTR]CTRNUM,[L]PRESTAT,
&           [F:HRCTR]CALPAY,[L]BULLETIN,1,"",[F:HRCTR]CTRDAT) From TRTAUT

#MIPEA - 2016-06-24 - REQ 114309 US128 - START
#FQ92876-US2675-
GORITITCOL = 0
#----- Variables globales pour le multi-référenciels comptabilité -----#
Gosub REST_GLOBAL_CPT From TRTHRCPT
#END FQ92876-US2675-
#MIPEA - 2016-06-24 - REQ 114309 US128 - END

Return

