## Ecran RET3 - Tableau visible des bulletins
######################################################################################

Subprog IB_NBVCAL
#MIPEA - 2016-07-04 - REQ 114309 US128 - START
If GBIDC1<>[M:RET3]CTRNUM([M:RET3]VLIGSAL(nolign-1))
  GBIDC1=[M:RET3]CTRNUM([M:RET3]VLIGSAL(nolign-1))
Endif
#GBIDC1=[M:RET3]RECCTRNUM(nolign-1)
##**72216
#MIPEA - 2016-07-04 - REQ 114309 US128 - END
If [M:RET3]VRECBUL(nolign-1)=''
 Raz [V]GBOUT1 :#Bulletins
Endif
If[M:RET0]RETTYP=3
 Raz [V]GBOUT2 :#Détails des rappels
Endif
End

Subprog C_NBVCAL
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
# Table prohibited for casual workers
Call LECTURE("EML",[M]VMATSEL,"") From CONTOBJ
If ([M:RET0]STATUT=3 | (GINTMT & [F:ID]FLGINT=2)) & !adxgtb
 mkstat=2 : End
Endif
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
#If [M:RET0]STATUT=3 & !adxgtb
# mkstat=2 : End
#Endif
End

Subprog APRES_NBVCAL
Local Integer RANG
Gosub SETNOL
[L]RANG = find([M:RET3]VTIDREC([L]NOL), [M:RET3]TIDREC)
[L]RANG -= 1
If [L]RANG >= 0
  [M:RET3]AMTRAPSAL([L]RANG) = [M:RET3]VAMTRAPSAL([L]NOL)
  [M:RET3]AMTRAPPAT([L]RANG) = [M:RET3]VAMTRAPPAT([L]NOL)
Endif
End

##**72216
# Pas de modif si présence d'un bulletin (élément déjà pris en compte dans la paie) & si pas de changement...
$BB2_NBVCAL
Gosub SETNOL
If [M:RET3]VRECBUL([L]NOL) = "" &  GBIDI1
 [M:RET3]VAMTRAPSAL([L]NOL) = GBIDD1
 [M:RET3]VAMTRAPPAT([L]NOL) = GBIDD2
 Affzo [M:RET3]VAMTRAPSAL([L]NOL)
 Affzo [M:RET3]VAMTRAPPAT([L]NOL)
 Call APRES_NBVCAL
 mkstat=4
Endif
Return

######################################################################################
## ## Ecran RET4 - Tableau des salariés
######################################################################################
Subprog IB_NBEML
#Tunnel bulletins
GBIDC1=[M:RET4]CTRNUM(nolign-1)
Call INIT_B1_B2
End

Subprog AV_NBEML
Local Integer RANG, POS
Local Char IDSALCTR([V]GLONEML+1+[V]GLONHRCTR)
If clalev([F:VEP2])=0 : Local File VALEMP     [VEP2] : Endif
Gosub SETNOL
#MIPEA - 2016-06-24 - REQ 114309 US128 - START
If GBIDC1<>[M:RET4]CTRNUM(nolign-1)
  GBIDC1=[M:RET4]CTRNUM(nolign-1)
Endif
#MIPEA - 2016-06-24 - REQ 114309 US128 - END
#Maj bandeau au-dessus du tableau
[M:RET4]VMATSEL=[M:RET4]REFNUM([L]NOL)
[M:RET4]VCTRSEL=[M:RET4]CTRNUM([L]NOL)
[M:RET4]VNOLEMP=[L]NOL

Gosub GRISE_RET4_LOAD

#Maj du tableau
Affzo [M:RET4] 8
Effzo [M:RET4] 10
[L]IDSALCTR = func SUBRET.GET_IDSALCTR([M:RET4]REFNUM([M:RET4]VNOLEMP), [M:RET4]CTRNUM([M:RET4]VNOLEMP))
[L]RANG = find([L]IDSALCTR, [M:RET4]TIDSALCTRREC)
[L]RANG -= 1
If [L]RANG >= 0
 Raz [L]POS
 #Maj tableau 2 de l'écran des valeurs (liste des valeurs).
 While [M:RET4]TIDSALCTRREC([L]RANG) = [L]IDSALCTR & [L]RANG < dim([M:RET4]TIDSALCTRREC)
  [M:RET4]VTYPRVL([L]POS) = [M:RET4]TYPRVL([L]RANG)
  [M:RET4]VVARCOD([L]POS) = [M:RET4]VARCOD([L]RANG)
  Call CHARGE_COD([M:RET4]VTYPRVL([L]POS),[M:RET4]CODTYP([L]POS),[M:RET4]LONG([L]POS),[M:RET4]OPT([L]POS))
  Call CHARGE_DES([M:RET4]VTYPRVL([L]POS),[M:RET4]CODTYP([L]POS),[M:RET4]VVARCOD([L]POS),[M:RET4]VARDES([L]POS))
  [M:RET4]VTYP([L]POS)    = [M:RET4]TYP([L]RANG)
  [M:RET4]VSTRPAY([L]POS) = [M:RET4]STRPAY([L]RANG)
  [M:RET4]VENDPAY([L]POS) = [M:RET4]ENDPAY([L]RANG)
  [M:RET4]VSTRBUL([L]POS) = [M:RET4]STRBUL([L]RANG)
  [M:RET4]VENDBUL([L]POS) = [M:RET4]ENDBUL([L]RANG)
  [M:RET4]VVALORI([L]POS) = [M:RET4]VALORI([L]RANG)
  [M:RET4]VVALDEN([L]POS) = [M:RET4]VALDEN([L]RANG)
  #
  [L]RANG += 1
  [L]POS += 1
 Wend
 [M:RET4]NBVRVL = [L]POS
 Affzo [M:RET4] 10
Endif
End

Subprog C_NBEML
  If [M:RET0]STATUT=3 & !adxgtb
   Call AV_NBEML
   mkstat=2 : End
  Endif
  Gosub SETNOL
  Case status
      When 65
          # Annulation de la ligne
          # => non autorisé si bulletin associé ( ligne prise en compte )
          Gosub CONTROLE_RECALCUL
          If not [L]OK_RECALCUL : mkstat = 2 : Endif
      When 75
          # Modification de la ligne
          # => non autorisé si bulletin associé ( ligne prise en compte )
          Gosub CONTROLE_RECALCUL
          If not [L]OK_RECALCUL : mkstat = 2 : Endif
  Endcase
End

Subprog B1_NBEML
Call CHARGEMENT_SALARIE
End

Subprog B2_NBEML
Gosub SETNOL
Gosub CONTROLE_RECALCUL
If [L]OK_RECALCUL
   ##**85110
   Local Char TIT (250)
   TIT=mess(195,10702,1)
   Call OUVRE_TRACE(TIT) From LECFIC
   Call ECR_TRACE(TIT,0) From GESECRAN

   Call RETRO([M:RET0]RETNUM, [M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL), 1) From TRTRETVAL

   Call FERME_TRACE From LECFIC

   Call LOAD_REC([M:RET0]RETNUM,1) From SUBRET
   nolign = [L]NOL + 1        : # Sécurité
   Call AV_NBSAL
   Call LEC_TRACE From LECFIC
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM([V]GLONEML), CTRNUM([V]GLONHRCTR)
Local Char MESSAGE(250)
Local Date DATREF
Local Integer OK
If [F:ID]FLGMULCTR <> 2
 If find([M:RET0]RETTYP, 1, 3) :  DATREF=[M:RET1]DATAVTEFF : Else :  DATREF=[M:RET1]DATMININT : Endif
 Call CHERCHE_CTR([L]VALEUR, [L]DATREF, [M:RET4]CTRNUM([L]NOL)) From DIVPAYE
 [L]REFNUM = [L]VALEUR
 [L]CTRNUM = [M:RET4]CTRNUM([L]NOL)
 Gosub CTRL_CTR
 If mkstat=2 : Raz [M:RET4]CTRNUM([L]NOL) : End: Endif
 Affzo [M:RET4]CTRNUM([L]NOL)
 [M:RET4]REFNUM([L]NOL) = [L]REFNUM
 Call C_CTRNUM([M:RET4]CTRNUM([L]NOL))
 If mkstat=2 : Raz [M:RET4]CTRNUM([L]NOL) : End: Endif
Endif
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RET4]CTRNUM([L]NOL) = ""
  Call SELCTR([M:RET4]REFNUM([L]NOL),[M:RET1]DATAVTEFF,[M:RET1]DATEFF,VALEUR) From DIVPAYE
Endif
# Pas accès du chrono contrat si mono-ctr
Read[F:ID]ID0=[M:RET4]REFNUM([L]NOL)
If [F:ID]FLGMULCTR<>2
 mkstat=2 : End
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Local Char REFNUM(GLONEML), CTRNUM(GLONHRCTR)
Local Integer I, OK
Local Char MESSAGE(250)

For [L]I=0 To [M:RET4]NBEML-1
    If [L]I <> [L]NOL
        If [M:RET4]REFNUM([L]NOL) = [M:RET4]REFNUM([L]I)
&                & [L]VALEUR = [M:RET4]CTRNUM([L]I)
            [V]GMESSAGE = mess(24,123,1)-num$(I+1) : # Code déjà existant en ligne
            mkstat=2 : Break
        Endif
    Endif
Next
If mkstat : End : Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char     VALEUR()
Local Char REFNUM(GLONEML), CTRNUM(GLONHRCTR)
Local Integer I, OK
Local Char MESSAGE(250)
Gosub SETNOL
[L]REFNUM = [M:RET4]REFNUM([L]NOL)
[L]CTRNUM = VALEUR
Gosub CTRL_CTR
If mkstat=2 : End: Endif
End

Subprog AV_NAM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
[L]VALEUR = func SUBHRPPH.GET_NAM([M:RET4]REFNUM([L]NOL), 4)    :##** 4 au lieu de 3
[M:RET3]NAM([L]NOL)=[L]VALEUR
End

Subprog AV_LEGCPY(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RET4]REFNUM([L]NOL) = "" or [M:RET4]CTRNUM([L]NOL) = ""
    Raz [L]VALEUR
    End
Endif
Gosub SETCTR
Read [F:FCY]FCY0 = [F:HRCTR]ETRFCY
If fstat = 0
    [L]VALEUR = [F:FCY]LEGCPY
Endif
[M:RET4]LEGCPY([L]NOL)=[L]VALEUR
[M:RET3]LEGCPY([L]NOL)=[L]VALEUR
End

Subprog AV_ETRFCY(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RET4]REFNUM([L]NOL) = "" or [M:RET4]CTRNUM([L]NOL) = ""
 Raz [L]VALEUR
 End
Endif
Gosub SETCTR
[L]VALEUR = [F:HRCTR]ETRFCY
[M:RET4]ETRFCY([L]NOL)=[L]VALEUR
[M:RET3]ETRFCY([L]NOL)=[L]VALEUR
End

Subprog AV_DATLSTREV(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If [M:RET4]REFNUM([L]NOL) = "" or [M:RET4]CTRNUM([L]NOL) = ""
 Raz [L]VALEUR : End
Endif
Gosub SETCTR
[L]VALEUR = [F:HRCTR]CTRDAT
[M:RET4]DATLSTREV([L]NOL) = [L]VALEUR
[M:RET4]CTRNUMORI(NOL) = [F:HRCTR]RETCTRNUMORI
[M:RET4]CTRDATORI(NOL) = [F:HRCTR]RETCTRDATORI

[M:RET3]DATLSTREV([L]NOL) = [L]VALEUR
[M:RET3]CTRNUMORI([L]NOL) = [M:RET4]CTRNUMORI(NOL)
[M:RET3]CTRDATORI([L]NOL) = [M:RET4]CTRDATORI(NOL)
End

Subprog AV_SALDATEFF(VALEUR)
Variable Date    VALEUR
If [M:RET0]RETTYP = 2 : Raz [L]VALEUR : End : Endif
Gosub SETNOL
If [M:RET4]REFNUM([L]NOL) = "" or [M:RET4]CTRNUM([L]NOL) = ""
    Raz [L]VALEUR
    End
Endif
Gosub SETCTR
[L]VALEUR = [F:HRCTR]RETDATEFF
[M:RET4]SALDATEFF([L]NOL) = [L]VALEUR
[M:RET3]SALDATEFF([L]NOL) = [L]VALEUR
End

Subprog AV_RENREV(VALEUR)
Variable Char    VALEUR()
  If [M:RET0]RETTYP = 2 : Raz [L]VALEUR : End : Endif
  Gosub SETNOL
  If [M:RET4]REFNUM([L]NOL) = "" or [M:RET4]CTRNUM([L]NOL) = ""
      Raz [L]VALEUR
      End
  Endif
  Gosub SETCTR
  [L]VALEUR = [F:HRCTR]RETGRD
  [M:RET4]RENREV([L]NOL) = [L]VALEUR
  [M:RET3]RENREV([L]NOL) = [L]VALEUR
End

Subprog AV_TIDSALCTR(VALEUR)
Variable Char    VALEUR()
  Gosub SETNOL
  [L]VALEUR = func SUBRET.GET_IDSALCTR([M:RET4]REFNUM([L]NOL), [M:RET4]CTRNUM([L]NOL))
  [M:RET4]TIDSALCTR([L]NOL)=[L]VALEUR
  [M:RET3]TIDSALCTR([L]NOL)=[L]VALEUR
End

