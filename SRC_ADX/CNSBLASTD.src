$ACTION
Case ACTION
 When "INIT"      : Gosub INIT From SUBCMM2       : # Zoom Engagement
 When "SEL_LISTE" : Gosub SEL_LISTEB From SUBCMM2 : # Zoom Engagement
 When "FIN_LISTE" : Gosub FIN_LISTE From SUBCMM2  : # Zoom Engagement
