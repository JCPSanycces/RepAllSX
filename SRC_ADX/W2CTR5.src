$ON_OCPCOD
Onevent INIT_AREA Call D_OCPCOD(zc) From W2CTR5
Onevent CONTROL Call C_OCPCOD(zc) From W2CTR5
Onevent BEFORE_INPUT Call AS_OCPCOD(zc) From W2CTR5
Onevent AFTER_CHANGE Gosub AMM_OCPCOD From W2CTR5
Return

Subprog D_OCPCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]OCPCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11552","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_OCPCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11552") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_OCPCOD(zc) From W2CTR5
Onkey   2 Titled GBOUTS Call S_OCPCOD(zc) From W2CTR5
Onkey 144 Titled GBOUTP Call P_OCPCOD(zc) From W2CTR5
Onkey 146 Titled GBOUTA Call SA_OCPCOD(zc) From W2CTR5
Gosub _AFF
End

Subprog C_OCPCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11552","") From SUBADI
If mkstat : GERR = 1 : GZONE = "OCPCOD" : GZNUM = 33079 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11552",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "OCPCOD" : GZNUM = 33079 : Endif
 If !mkstat
  ## Action STD
  Call C_OCPCOD(VALEUR) From SUBCTR
  If mkstat : GERR = 1 : GZONE = "OCPCOD" : GZNUM = 33079 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_OCPCOD
Call AM_OCPCOD(zc)
If !mkstat & GOBJET
 zoncou = "OCPCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OCPCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZOCPCOD)")>indice
 [M]OCPCOD(indice) = VALEUR
 Affzo ZOCPCOD(indice)
Endif
Gosub _AFF
End

Subprog S_OCPCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11552"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_OCPCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11552") From GOBJET
Gosub _AFF
End

Subprog SA_OCPCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11552"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_OCPCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11552"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZOCPCOD
Onevent BEFORE_AREA Gosub AV_ZOCPCOD From W2CTR5
Return

$AV_ZOCPCOD
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11552",num$([M]OCPCOD(indice))) From ATEXTRA
Gosub _AFF
Return

