#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ZON1
Onevent CONTROL Call C_ZON1(zc) From W2CTR5
Return

Subprog C_ZON1(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$ON_ZON2
Onevent CONTROL Call C_ZON2(zc) From W2CTR5
Return

Subprog C_ZON2(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$ON_NBRSAL
Onevent AFTER_LINE Call APRES_NBRSAL From W2CTR5
Onevent BEFORE_AREA Call AV_NBRSAL From W2CTR5
Return

Subprog AV_NBRSAL
Local Decimal BASPAG
If adxgtb=1 & !GORITITCOL & nolign=1
 Local Char BASPAG(10)
 BASPAG = "NBRSAL" : Gosub TIT_COL From W5CTR5
Endif
Gosub _AFF
End

Subprog APRES_NBRSAL
Local Decimal BASPAG
## Action STD
Call APRES_NBRSAL From SUBCTR
If mkstat : End : Endif
Gosub _AFF
End

$ON_SALDAT
Onevent BEFORE_AREA Gosub AV_SALDAT From W2CTR5
Return

$AV_SALDAT
Chgfmt [M]SALDAT(indice) With "DPZ:"+GFMDAT4
Gosub _AFF
Return

$ON_SALVAL
Onevent BEFORE_AREA Gosub AV_SALVAL From W2CTR5
Return

$AV_SALVAL
If [M:CTR5]FRMSAL(0)<>""
 Chgfmt [M]SALVAL(indice) With [M:CTR5]FRMSAL(0)
Else
 Chgfmt [M]SALVAL(indice) With "-K:1X"
Endif
Gosub _AFF
Return

