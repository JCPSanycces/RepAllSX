#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ODPAYVAL 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone ALLCPY
mkstat = 0
zoncou = "ALLCPY"
indice = 0
IMPENT = [M]ALLCPY
If varinit([M]ALLCPY,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLCPY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ALLCPY(IMPENT) From ODPAYVAL
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]ALLCPY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLCPY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLCPY(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ALLCPY(IMPENT) From ODPAYVAL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLCPY" : GZNUM = 6052 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ALLCPY = IMPENT

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CPY([M]CPY) From ODPAYVAL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CPY : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "INICPY"
  Call INICPY([M]CPY) From EXEFNC
  GACTION = SAVACT
  If mkstat=1 : Raz [M]CPY : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]CPY,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTCPY"
    Call CONTSOC([M]CPY) From SUBAGF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("CPY","",[M]CPY,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CONTCPY"
      Call CONTCPY([M]CPY) From EXEFNC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ALLFCY
mkstat = 0
zoncou = "ALLFCY"
indice = 0
IMPENT = [M]ALLFCY
If varinit([M]ALLFCY,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLFCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ALLFCY(IMPENT) From ODPAYVAL
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]ALLFCY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLFCY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLFCY(indice)
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_ALLFCY(IMPENT) From ODPAYVAL
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLFCY" : GZNUM = 6053 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]ALLFCY = IMPENT

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
If varmode([M]FCY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_FCY([M]FCY) From ODPAYVAL
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FCY : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "INIFCY"
  Call INIFCY([M]FCY,[M]CPY) From EXEFNC
  GACTION = SAVACT
  If mkstat=1 : Raz [M]FCY : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]FCY,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 4165 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTFCY"
    Call CONTSITE([M]FCY) From SUBAGF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 4165 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("FCY","C",[M]FCY,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 4165 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CONTFCY"
      Call CONTFCY([M]FCY) From EXEFNC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 4165 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "CONTFCYCPY"
       Call CONTFCYCPY([M]FCY,[M]CPY) From EXEFNC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 4165 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ODPNUMDEB
mkstat = 0
zoncou = "ODPNUMDEB"
indice = 0
If varmode([M]ODPNUMDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ODPNUMDEB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ODPNUMFIN
mkstat = 0
zoncou = "ODPNUMFIN"
indice = 0
If varmode([M]ODPNUMFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ODPNUMFIN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_ODPNUMFIN([M]ODPNUMFIN) From ODPAYVAL
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ODPNUMFIN" : GZNUM = 1001181 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone CAT
mkstat = 0
zoncou = "CAT"
indice = 0
IMPENT = [M]CAT
If varinit([M]CAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CAT,indice)=0
 Call INICOMBO(618) From COMBOS
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CAT(IMPENT) From ODPAYVAL
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 If IMPENT<1 | GMENLOC(IMPENT)=1
  IMPENT = find(0,GMENLOC(1..len(mess(0,618,1))))
 Endif
 [M]CAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CAT(indice)
 Endif
 If !mkstat
  If IMPENT=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CAT" : GZNUM = 707 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If IMPENT>0 & IMPENT<dim(GMENLOC) & GMENLOC(IMPENT)<>0
    mkstat = 1 : GMESSAGE = mess(99,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "CAT" : GZNUM = 707 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]CAT = IMPENT

## Zone DAT
mkstat = 0
zoncou = "DAT"
indice = 0
If varinit([M]DAT,indice)=0
 [M]DAT = date$
Endif
If varmode([M]DAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SIMFLG
mkstat = 0
zoncou = "SIMFLG"
indice = 0
IMPENT = [M]SIMFLG
If varinit([M]SIMFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]SIMFLG,indice)=0
 [M]SIMFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SIMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SIMFLG(indice)
 Endif
Endif
[M]SIMFLG = IMPENT

## Zone TRCFLG
mkstat = 0
zoncou = "TRCFLG"
indice = 0
IMPENT = [M]TRCFLG
If varinit([M]TRCFLG,indice)=0
 IMPENT = 2
Endif
If varmode([M]TRCFLG,indice)=0
 [M]TRCFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TRCFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TRCFLG(indice)
 Endif
Endif
[M]TRCFLG = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ODPAYVAL"
Return

