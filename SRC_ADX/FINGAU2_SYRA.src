#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT AUTOMATIC JOURNALS
##############################################################################################################
# Private routines :
# _EVAL_ACC  : Evaluates the accounts according to the automatic journal parameterization for all given ledger types
# _ISACCFLG  : Checks if an account must be found/initialized for the current ledger type
##############################################################################################################

########################################################################################################
## _EVAL_ACC
########################################################################################################
#**
#* Evaluates the accounts according to the automatic journal parameterization for every ledger types used as parameters (NBRLED, LEDTYP)
#*
#* @private
#* @param ACTX    Context
#* @param COMPANY Company
#* @param NBRLED  Number of ledgers
#* @param LEDTYP  Ledger Types
#* @param IDT     Identifier
#* @param DAT     Date
#* @param COA     Charts of accounts
#* @param ACC     Accounts
#* @param SAC     Collective Codes
#* @param BPR     Business Partner
#* @param ERRMES  Error messsage
#*!
Funprog _EVAL_ACC(ACTX,COMPANY,NBRLED,LEDTYP,IDT,DAT,COA,ACC,SAC,BPR,ERRMES)
Variable Instance ACTX   Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY          : # Company
Value    Integer  NBRLED           : # Number of ledgers
Value    Libelle  LEDTYP(1..)      : # Ledger Types
Value    Char     IDT              : # Identifier
Value    Date     DAT              : # Date
Variable Char     COA()(1..)       : # Charts of accounts
Variable Char     ACC()(1..)       : # Accounts
Variable Char     SAC()(1..)       : # Collective Codes
Variable Char     BPR()            : # Business Partner
Variable Char     ERRMES()         : # Error messsage

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

If adxtyp=33 | !clalev([F:CAC]) : Local File GACCCODE                      [CAC] : Endif
If adxtyp=33 | !clalev([F:COA]) : Local File =ACTX.ACPT.TABCPT+"GCOA"      [COA] : Endif
If adxtyp=33 | !clalev([F:GAC]) : Local File =ACTX.ACPT.TABCPT+"GACCOUNT"  [GAC] : Endif

Local Char    CPYLEG(GLONADI)                            : # Company's Legislation
Local Char    LEDCUR(GLONCUR)(1..len(mess(0,2644,1)))    : # Ledger Currencies
Local Char    LEDCOD(GLONLED)(1..len(mess(0,2644,1)))    : # Ledger Codes
Local Char    COA(GLONCOA)(1..len(mess(0,2644,1)))       : # Charts of accounts
Local Char    COAFMT(15)(1..len(mess(0,2644,1)))         : # Charts of accounts Formats
Local Char    COACOLHEA(GLONAX1)(1..len(mess(0,2644,1))) : # Charts of accounts Column Header
Local Char    LCOA(GLONCOA), LACC(GLONGAC)               : # Chart of account & account
Local Char    FLD(15)                                    : # Miscellaneous Variables
Local Char    MODKEY(30), MODKEY1(30), MODKEY2(30)       : # Accounting Modifier Key (Ex:[F:PIL]VAT)
Local Char    ACCCOD(GLONCAC), ACCCOD2(GLONCAC)          : # Accounting Code (Ex:STD)
Local Char    TAX(GLONVAT)                               : # Tax Code (use in the account creation processing)
Local Integer NBRDIE                                     : # Number of Dimension Types
Local Integer OBYFLG                                     : # Obligatory Flag (Mandatory allocation for the accounts)
Local Integer ICPY, ILED, WO_WEEKS,K, L, OK, ACC_FOUND   : # Miscellaneous Variables
Local Integer ERR                                        : # Miscellaneous Variables
Local Libelle LEDTYPGEN, LEDTYPANA, LEDTYPIAS            : # Main Ledger Types
Local Integer NBRDIEMAX                                  : # Maximum number of dimension type

Raz COA, ACC, SAC, BPR

ICPY = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If ICPY = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : End [L]ASTATUS
Endif

NBRDIEMAX = fmet ACTX.ACACHE.ACPY.AGETVALNUM(COMPANY,"NBRDIE")
Local Char    DIE(GLONDIE)(1..max(1,NBRDIEMAX))       : # Dimension Types
Local Char    DIEFMT(15)(1..max(1,NBRDIEMAX))         : # Dimension Type Formats
Local Char    DIECOLHEA(GLONAX1)(1..max(1,NBRDIEMAX)) : # Dimension Types Column Header
Local Integer DIEOBYFLG(1..max(1,NBRDIEMAX))          : # Obligatory Flags (Y/N)

CPYLEG = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"LEG")

[L]ASTATUS = func FINACM_SYRA.GET_FINREDSTC(ACTX,COMPANY,1,NBRLED,LEDTYP,LEDCOD,LEDCUR,COA,COAFMT,COACOLHEA,NBRDIE,DIE,DIEFMT,DIECOLHEA,DIEOBYFLG,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

[L]ASTATUS = func FINACM_SYRA.GET_MAINLEDTYP(ACTX,COMPANY,LEDTYPGEN,LEDTYPANA,LEDTYPIAS,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

For ILED=1 To NBRLED
 If func FINGAU2_SYRA._ISACCFLG(ACTX,ILED,COA,ACC)
  LCOA = COA(ILED)
  LACC = ACC(ILED)
  ACC_FOUND = 0
  If LACC = ""
   FLD = "ACC"+num$(LEDTYP(ILED))
   [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,FLD,2,"",LACC,ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : ERRMES = "GAC"-"("+COA(ILED)+")"-ERRMES : Break : Endif
  Endif

  ## If the account is existing and is compatible with the account entered previously, we don't apply the
  ## accounting modifiers
  If LACC<>""
   Gosub CTL_ACC
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   If !ACC_FOUND
    Gosub CTL_ACCSHO
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   Endif
  Endif

  If !ACC_FOUND
   ## We have a look the modifier by month and by 2-week period
   K = instr(1,LACC,"mm")
   If K=0 : K = instr(1,LACC,"MM") : Endif
   If K
    LACC = left$(LACC,K-1)+format$("N0:2#",month(DAT))+right$(LACC,K+2)
   Endif
   K = instr(1,LACC,"qq")
   If K=0 : K = instr(1,LACC,"QQ") : Endif
   If K
    TWOWEEKS = 2*month(DAT)-(day(DAT)<16)
    LACC = left$(LACC,K-1)+format$("N0:2#",TWOWEEKS)+right$(LACC,K+2)
   Endif

   ## Application of the accounting modifiers if the account has not be initialized by the Account Formula
   ## or if the account contains the letter 'x'
   If LACC = "" | instr(1,LACC,"x")
    LACC = left$(LACC+string$(GLONGAC,"x"),GLONGAC)
    For K=0 To [F:GAD]NBRTYP-1
     OK = 1
     If [F:GAD]ACCCND(K)<>""
      Onerrgo ERREUR
      OK = evalue([F:GAD]ACCCND(K))
      Onerrgo
      If ERR : [L]ASTATUS = [V]CST_AERROR : ERRMES = [F:GAD]ACCCND(K)-mess(65,106,1) : Break 2 : Endif
     Endif
     If OK
      [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,num$(K),3,"",MODKEY,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR : ERRMES = "CAC"-"("+COA(ILED)+")"-ERRMES : Break 2 : Endif
      ACCCOD = ""
      If left$(MODKEY,1)="~"
       If evalue("dim([F:TB1]"+right$(MODKEY,2)+")")>0
        ACCCOD = evalue("[F:TB1]"+right$(MODKEY,2))
       Elsif evalue("dim([F:TB0]"+right$(MODKEY,2)+")")>0
        ACCCOD = evalue("[F:TB0]"+right$(MODKEY,2))
       Else
        ACCCOD = ""
       Endif
       MODKEY = ""
      Endif
      If MODKEY<>""
       ACCCOD = func FINCAC_SYRA.GET_ACCCOD(ACTX,COMPANY,CPYLEG,[F:GAD]TYPACCCOD(K),MODKEY)
      Elsif ACCCOD = ""
       # If the Accounting Code is void, we take the accounting code attached to the Trigerring Tables
       If dim([F:TB1]ACCCOD)>0
        ACCCOD = [F:TB1]ACCCOD
       Elsif dim([F:TB0]ACCCOD)>0
        ACCCOD = [F:TB0]ACCCOD
       Endif
      Endif
      If ACCCOD<>""
       Read [CAC]CAC0 = [F:GAD]TYPACCCOD(K);ACCCOD;LCOA
       If fstat
        [L]ASTATUS = [V]CST_AERROR : ERRMES = ACCCOD-mess(11,114,1) : Break 2
       Endif
       ACCCOD2 = [F:CAC]ACC([F:GAD]ACCNUM(K)-1)
       For J=1 To len(ACCCOD2)
        If mid$(ACCCOD2,J,1)<>"x" & mid$(LACC,J,1)="x"
         LACC = left$(LACC,J-1)+mid$(ACCCOD2,J,1)+right$(LACC,J+1)
        Endif
       Next J
       If right$(ACCCOD2,len(ACCCOD2))<>"x"
        Read [GAC]GAC0 = LCOA;vireblc(ctrans(LACC,"x"," "),1)
        If !fstat
         Break
        Endif
       Endif
      Endif
     Endif
    Next K
    # Substitution of the "x" by " ". Note : the vireblc instruction allows the elimination of the "x" at the end
    LACC = vireblc(ctrans(LACC,"x"," "),1)
    # Substitution of the "x" become " " by "0"
    LACC = ctrans(LACC," ","0")
   Endif : # Application of the accounting modifiers

   If !ACC_FOUND & LACC<>""
    Gosub CTL_ACC
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    If !ACC_FOUND
     Gosub CTL_ACCSHO
     If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif

   Else
    ## Propagation : if the account has not be initialized for the ledger type ILED, we try to initialize it
    ## from the other ledger types
    If !ACC_FOUND & ILED>1
     Gosub INI_OTHACC
     If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
     If [L]LACC<>""
      Gosub CTL_ACC
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
     Endif
    Endif

    ## Last solution : the default account if and only if NO account attached to the other ledger types previously initialized
    ## is defined 'Mandatory Allocation' on the current chart of account (LCOA)
    ## If no account is found, a blocking message is gotten back if and only if an account attached to the
    ## other ledger types previously initialized is defined 'Mandatory Allocation' on the current chart of account (LCOA)
    If !ACC_FOUND & !OBYFLG
     Call LEC_COA(LCOA) From CPTLEC
     LACC = [F:COA]ACCMIS(1)
     If LACC<>""
      Gosub CTL_ACC
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
     Endif
    Endif

    If LACC=string$(len(LACC),"0") & !OBYFLG & ILED>1
     [L]ASTATUS=[V]CST_AERROR : ACC(ILED) = "" : ERRMES = mess(LEDTYP(ILED),2644,1)-":"-mess(107,106,1) : Break
    Endif
   Endif

   If LACC<>"" & !ACC_FOUND
    Call LEC_COA(LCOA) From CPTLEC
    If [F:COA]FXDLEN = 2
     LACC = left$(LACC+string$(GLONGAC,"0"),[F:COA]ACCLEN)
    Endif
    Gosub CTL_ACC
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Gosub CTL_ACCSHO
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    If !ACC_FOUND
     If [F:COA]CREAUT=2
      [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,"TAX",2,"",TAX,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR : ACC(ILED) = "" : Break : Endif
      [L]ASTATUS = func FINGAU3_SYRA.CRE_ACC(ACTX,COMPANY,LCOA,LACC,"XXX"-IDT-"XXX",TAX,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR : ACC(ILED) = "" : Break : Endif
      [L]ASTATUS = func FINACC_SYRA.CTL_IPTACC(ACTX,ILED,COA,ACC,0,ERRMES)
      If [L]ASTATUS>=[V]CST_AERROR : ACC(ILED) = "" : Break
      Else ACC(ILED) = LACC : SAC(ILED) = [F:GAC]ACCSHO : ACC_FOUND = 1
      Endif
     Else
      # Nonexistent account
      [L]ASTATUS=[V]CST_AERROR : ERRMES = mess(38,106,1)-"("+LCOA+")" : Break
     Endif
    Endif
   Endif

  Endif

 Endif : # func FINGAU2_SYRA._ISACCFLG
Next
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

If sigma(1,NBRLED,SAC(indcum)<>"")<>0
 [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,"BPR",2,"",BPR,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
Else
 BPR = ""
Endif
End [L]ASTATUS


########
$CTL_ACC
Call LEC_GAC(LACC,LCOA) From CPTLEC
If !fstat
 ACC(ILED) = LACC
 [L]ASTATUS = func FINACC_SYRA.CTL_IPTACC(ACTX,ILED,COA,ACC,0,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : ACC(ILED) = "" : ERRMES = "GAC"-"("+COA(ILED)+")"-ERRMES : Return
 Else SAC(ILED) = [F:GAC]ACCSHO : ACC_FOUND = 1
 Endif
Endif
Return

###########
$CTL_ACCSHO
## We try the Short Code if LACC=""
If LACC="" : Return : Endif
Read [GAC]GAC1 = LCOA ; LACC
If !fstat
 LACC = [F:GAC]ACC : ACC(ILED) = LACC
 [L]ASTATUS = func FINACC_SYRA.CTL_IPTACC(ACTX,ILED,COA,ACC,0,ERRMES)
 If [L]ASTATUS>=[V]CST_AERROR : ACC(ILED) = "" : ERRMES = "GAC"-"("+COA(ILED)+")"-ERRMES : Return
 Else SAC(ILED) = [F:GAC]ACCSHO : ACC_FOUND = 1
 Endif
Endif
Return

###########
$INI_OTHACC
Local Char    DENACCSCR(20)  : # Destination Account Screening
Local Integer ILED2
OBYFLG = 0
For ILED2=1 To ILED-1
 If ILED2<>ILED
  If ACC(ILED2)<>""
   If !OBYFLG
    [L]ASTATUS = func FINACC_SYRA.CTL_OBYIPTACC(ACTX,COA(ILED2),ACC(ILED2),COA(ILED),OBYFLG,ERRMES)
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   Endif
   [L]ASTATUS = func FINACC_SYRA.GET_DENACC(GACTX,COA(ILED2),ACC(ILED2),COA(ILED),LACC,DENACCSCR,ERRMES)
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
   If LACC<>""
    Gosub CTL_ACC
    If [L]ASTATUS>=[V]CST_AERROR : Break
    Elsif ACC_FOUND = 1 : Break : ## The current ledger type has been initialized through the Default Account, and the controls are OK
    Endif
   Endif
  Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#######
$ERREUR
ERR = errn
Resume


########################################################################################################
## _ISACCFLG
########################################################################################################
#**
#* Confirm that an account must be found/initialized for the current ledger type<br>
#*  -> If the function gets back the value 0, it means that the current ledger type must NOT be initialized because:<br>
#*          - The current chart of account is not tracked on the previous chart of account<br>
#*          - The current chart of account is the same as a previous chart of account. In that case, the account<br>
#*            is automatically initialized by the previous one attached to the same chart of account<br>
#*  -> If the function gets back the value 1, it means that the current ledger type must be initialized<br>
#*
#* @private
#* @param ACTX   Context
#* @param LEDTYP Current Ledger Type
#* @param COA    Chart of accounts
#* @param ACC    Account
#*!
Funprog _ISACCFLG(ACTX,LEDTYP,COA,ACC)
Variable Instance ACTX    Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Libelle  LEDTYP()              : # Current Ledger Type
Value    Char     COA()(1..)            : # Chart of accounts
Variable Char     ACC()(1..)            : # Account

If LEDTYP<=1        : End 1 : Endif
If COA(LEDTYP) = "" : End 0 : Endif

If adxtyp=33 | !clalev([F:GAC]) : Local File =ACTX.ACPT.TABCPT+"GACCOUNT"  [GAC] : Endif

Local Integer PRE_LEDTYP  : # Previous Ledger Type
Local Integer CUR_LEDTYP  : # Current Ledger Type
CUR_LEDTYP = LEDTYP

Local Integer ISACCFLG : ISACCFLG = 1


For PRE_LEDTYP=1 To CUR_LEDTYP-1
 If COA(PRE_LEDTYP) = COA(CUR_LEDTYP)
  ACC(CUR_LEDTYP) = ACC(PRE_LEDTYP)
  ISACCFLG = 0 : Break
 Endif
 If ACC(PRE_LEDTYP)<>""
  Call LEC_GAC(ACC(PRE_LEDTYP),COA(PRE_LEDTYP)) From CPTLEC
  If fstat | !find(COA(CUR_LEDTYP),[F:GAC]OTHCOA(0..dim([F:GAC]OTHCOA)-1))
   ISACCFLG = 0 : Break
  Endif
 Endif
Next
If ISACCFLG = 0 : End 0 : Endif
End 1

