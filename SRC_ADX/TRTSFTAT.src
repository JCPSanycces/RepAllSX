#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Shop floor tracking Adjust team screen
# allow employees to change the number of members on a Summary team
#
######################################################################################
$ACTION

  Case [L]ACTION
    When "DEBUT"    : Gosub DEBUT
    When "OK"       : Gosub OK
    When "FERME"    : Gosub FERME
  Endcase

Return

######################################################################################
$DEBUT

  # Assign passing in employee id
  [M:SFTAT]EMPNUM = val(PARAM(1))

  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif
  # Get site and # of employees
  Read [TMA]TMA0=[M:SFTAT]EMPNUM
  If !fstat
    [M:SFTAT]SUMEMP = [F:TMA]SUMEMP
  Endif

  Affzo [M:SFTAT]

Return
######################################################################################
$OK

  Local Datetime  STOPSTARTTIME : STOPSTARTTIME   = datetime$

  # Check for open activities
  If func SFTLIB.OPEN_ACTIVITIES(AVOID.AINT,[M:SFTAT]EMPNUM) = [V]CST_AYES
    # Stop and restart open activities
    Call RESTART_SUMMARY_OPERATIONS([M:SFTAT]SUMEMP, STOPSTARTTIME, [M:SFTAT]EMPNUM)
  Endif

  # Update the Employee table with new number of employees
  Read [TMA]TMA0=[M:SFTAT]EMPNUM
  If fstat
     GOK = 0 : Call FSTA("TMA") From GLOCK : Return
  Endif

  If [M:SFTAT]SUMEMP <> [F:TMA]SUMEMP
    [F:TMA]SUMEMP = [M:SFTAT]SUMEMP

    Rewrite [TMA]
    If fstat
       GOK = 0 : Call FSTA("TMA") From GLOCK
    Endif
  Endif

Return

######################################################################################
$FERME
  LogicClose File [TMA]
Return
######################################################################################
Subprog RESTART_SUMMARY_OPERATIONS(SUMEMP, IDATETIM, IEMPNUM)
  Value   Integer   SUMEMP
  Value   Integer   IEMPNUM
  Value   Datetime  IDATETIM
  Local   Integer   ICOUNT
  Local   Integer   LOCAL_STATUS
  Local Integer   ERRNUM
  Local Char      ERRMSG(255)

  # Open tables
  Local File SFTTXN [SFTXN]
  Local Instance SFTTXN_RESTART Using C_SFTTXN

  Trbegin [F:SFTXN]
  Filter [F:SFTXN] Where EMPNUM = IEMPNUM & SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM & MACFLG <> [V]CST_AYES
  #############################
  # Stop....
  #############################
  For [F:SFTXN]
    #End each operation and update table
    [F:SFTXN]UTCENDDATTIM = IDATETIM
    [F:SFTXN]ACTENDDATTIM = IDATETIM
    [F:SFTXN]DURATION = func SFTLIB.CALC_DURATION([F:SFTXN]UTCSTRDATTIM, [F:SFTXN]UTCENDDATTIM, [F:SFTXN]NUMJOBS, [F:SFTXN]SUMEMP)

    # Update the record
    Rewrite [F:SFTXN]

    # Fail update
    If fstat <> 0
      [V]GOK=-1
      Break
    Endif

    #############################
    # Restart the operation...
    #############################
    SFTTXN_RESTART = NewInstance C_SFTTXN AllocGroup null

    # Assign the pass in values to the table fields
    SFTTXN_RESTART.EMPNUM       = [F:SFTXN]EMPNUM        # Employee ID
    SFTTXN_RESTART.TEAMNUM      = [F:SFTXN]TEAMNUM       # Team ID
    SFTTXN_RESTART.TXNUUID      = [F:SFTXN]TXNUUID       # Transaction ID
    SFTTXN_RESTART.SUMEMP       = SUMEMP                 # new # of employees
    SFTTXN_RESTART.MACFLG       = [F:SFTXN]MACFLG        # Machine Flag
    SFTTXN_RESTART.FCY          = [F:SFTXN]FCY           # Site
    SFTTXN_RESTART.SFTTYP       = [F:SFTXN]SFTTYP        # Type
    SFTTXN_RESTART.VCRNUM       = [F:SFTXN]VCRNUM        # Work order
    SFTTXN_RESTART.SFTSEQ       = func SFTTXN_CSTD.NEXT_SEQ([F:SFTXN]EMPNUM, [F:SFTXN]SFTTYP, [F:SFTXN]VCRNUM)  # Sequence
    SFTTXN_RESTART.UTCSTRDATTIM = IDATETIM               # Start date/time
    SFTTXN_RESTART.UTCOFFSET    = [F:SFTXN]UTCOFFSET     # Time zone difference
    SFTTXN_RESTART.OPENUM       = [F:SFTXN]OPENUM        # Operation number
    SFTTXN_RESTART.OPEUOM       = [F:SFTXN]OPEUOM        # UOM
    SFTTXN_RESTART.NUMMAC       = [F:SFTXN]NUMMAC        # Number of machine(s)
    SFTTXN_RESTART.WCENTER      = [F:SFTXN]WCENTER       # Work center
    SFTTXN_RESTART.LCENTER      = [F:SFTXN]LCENTER       # Labor center
    SFTTXN_RESTART.INDREF       = [F:SFTXN]INDREF        # Indirect reference code
    SFTTXN_RESTART.INDTYP       = [F:SFTXN]INDTYP        # Indirect reference type
    SFTTXN_RESTART.NUMJOBS      = [F:SFTXN]NUMJOBS       # Number of jobs

    [L]LOCAL_STATUS   = fmet SFTTXN_RESTART.AINSERT
    If [L]LOCAL_STATUS >= [V]CST_AERROR
      [V]GOK=-1
      [L]LOCAL_STATUS = fmet SFTTXN_RESTART.ASETERROR ("RESTART_SUMMARY_OPERATIONS", mess(5,2422,1), [V]CST_AERROR)    # Restart operation(s) failed.
      [L]ARET_VALUE = [V]CST_AERROR
      Return
    Else
      FreeGroup SFTTXN_RESTART
    Endif
  Next

  # check if update/insert record fail then display message
  If [V]GOK = -1
    Rollback
    ERRMSG = mess(5,2422,1)   # Restart operation(s) failed.
    ERRNUM = [V]CST_AERROR
  Else
    Commit
  Endif

  LogicClose File [F:SFTXN]
  Kill SFTTXN_RESTART

End

