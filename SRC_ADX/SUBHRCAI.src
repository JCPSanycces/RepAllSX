#<AdxTL>@(#)0.0.0.0 $Revision$ Object management HRCAI
Call OBJET("HRCAI",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "FILTRE"      : FILTSUP = "[F:BAN]BANCSH=2"
 When "OUVRE"       : Gosub OUVRE    :#92876-US2590
 When "APRES_MODIF" : Gosub APRES_MODIF
  When "VERIF_CRE"  : Gosub VERIF_CRE From SUBHRBAN
 When "LIENS"       : Gosub LIENS
Endcase
Return

#92876
$OUVRE
If clalev([HRBAN2])=0  : Local File BANK            [BAN2] : Endif
  If clalev([F:COA])=0 : Local File =GTABCPT+"GCOA"  [COA]  : Endif
Return

$APRES_MODIF
If COUZON=CLEPRIM
 Read [F:BAN2]BAN0=CZ
 If fstat=0 & [F:BAN2]BANCSH=1  :# Banque
  GMESSAGE = mess(1,653,1)
  mkstat=2 : [L]OK=0
 Endif
Endif
Return


$LIENS

  Call FIND_COA([M:HRCAI1]CPY) From SUBHRBAN
Return

