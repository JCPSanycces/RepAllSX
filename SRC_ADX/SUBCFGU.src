#<AdxTL>@(#)6.0.0.0 $Revision$
# Exécution sous mode 'PATCH'
Call OUVRE_TRACE(mess(138,188,1)) From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
# Sous programme de revalidation automatique inter release
Subprog PATCH(LMAP)
Value Char LMAP
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=LMAP
If fstat = 0
  GMODU(8) = [F:ADS]MODULE(7)
  If LMAP <> "X3"
    GFONCTION = ""
    GFONC1    = "FUNCFGUTI"
    Global Char  S_DOSSIER   : S_DOSSIER = LMAP
    Local Char   W_APPLI     : W_APPLI   = LMAP
    Local Integer IVALREL
    Local File    =W_APPLI+".ACTIV" [ACV]
    Read [ACV]CODACT="CFG"
    If fstat = 0 & [F:ACV]FLACT = 2
      # FQ 77122 GA 10/2011      #Local Mask =W_APPLI+".CFGUTI" [CFGU]
      Gosub CTRL_MSK
      Local Mask =W_APPLI+".CFGUTI" [CFGU]   # FQ 77537 GA 11/2011 ligne perdue suite 77122
      Gosub DEBUT_CFGUTI
      [M:CFGU]TLPFLG = 2
      [M:CFGU]SELFLG = 2
      [M:CFGU]SHAFLG = 2
      [M:CFGU]SCEFLG = 2
      [M:CFGU]MSTFLG = 2
      [M:CFGU]CFMFLG = 1
      Gosub OK_CFGUTI
      Close Local Mask [CFGU]
    Endif
    Close Local File [ACV]
  Endif
Endif
End


###########################################################################
# Pour éxécution de la validation des scénarios, sélections...            #
# par la gestion de dossier                                               #
###########################################################################
Subprog GENDOS(LMAP)
Value Char LMAP

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=LMAP
If fstat = 0
  GMODU(8) = [F:ADS]MODULE(7)
  If LMAP <> "X3"
    GFONCTION = ""
    GFONC1    = "FUNCFGUTI"
    Global Char  S_DOSSIER   : S_DOSSIER = LMAP
    Local Char   W_APPLI     : W_APPLI   = LMAP
    Local Integer IVALREL
    Local File    =W_APPLI+".ACTIV" [ACV]
    Read [ACV]CODACT="CFG"
    If fstat = 0 & [F:ACV]FLACT = 2
      # FQ 77122 GA 10/2011      #Local Mask =W_APPLI+".CFGUTI" [CFGU]
      Gosub CTRL_MSK
      Local Mask =W_APPLI+".CFGUTI" [CFGU]   # FQ 77537 GA 11/2011 ligne perdue suite 77122
      Gosub DEBUT_CFGUTI
      [M:CFGU]TLPFLG = 2
      [M:CFGU]SELFLG = 2
      [M:CFGU]SHAFLG = 2
      [M:CFGU]SCEFLG = 2
      [M:CFGU]MSTFLG = 2
      [M:CFGU]CFMFLG = 1
      Gosub OK_CFGUTI
      Close Local Mask [CFGU]
    Endif
    Close Local File [ACV]
  Endif
Endif
End


############################################################
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_CFGUTI
  When "DEBUT"    : Gosub DEBUT_CFGUTI
  When "OK"       : Gosub OK_CFGUTI
  When "END"      : Gosub END_CFGUTI
  When "FIN"      : Gosub FIN_CFGUTI
Endcase
Return
############################################################
$OUVRE_CFGUTI
Local Char W_APPLI : W_APPLI = nomap
If clalev([F:ITM])  = 0 : Local File ITMMASTER [ITM]  : Endif
Call OUVRE_TRACE(mess(138,188,1)) From LECFIC
Return
############################################################
$DEBUT_CFGUTI
Raz [M:CFGU]
Affzo [M:CFGU]
Grizo [M:CFGU]SELENA
Grizo [M:CFGU]SCEENA
If GINTRA
  [M:CFGU]CFMFLG = 1
  Grizo [M:CFGU]CFMFLG
Endif
Return
############################################################
$OK_CFGUTI
#If dim(S_DOSSIER) < 0
#  Global Char  S_DOSSIER   : S_DOSSIER = nomap
#Endif
#
#If clalev([F:CLN])  = 0 : Local File =W_APPLI+".CFGLNK"    [CLN]  : Endif
# CCC (02/07/07) bug 42023 : Ouverture de tables et écran utilisés lors de la génération des transactions configurateur
If clalev([F:ACV])  = 0 : Local File =W_APPLI+".ACTIV"     [ACV]  : Endif
If clalev([F:CSE])  = 0 : Local File =W_APPLI+".CFGSEL"    [CSE]  : Endif
If clalev([F:CBB])  = 0 : Local File =W_APPLI+".CBLOB"     [CBB]  : Endif : # GA 20/09/07 suite 42023
If clalev([F:CSE0]) = 0 : Local File =W_APPLI+".CFGSEL"    [CSE0] : Endif
If clalev([F:COV0]) = 0 : Local File =W_APPLI+".CFGOPTVAR" [COV0] : Endif
If clalev([F:CFM0]) = 0 : Local File =W_APPLI+".CFGMAC"    [CFM0] : Endif
If clalev([F:CSH0]) = 0 : Local File =W_APPLI+".CFGSHA"    [CSH0] : Endif
If clalev([F:TFO1]) = 0 : Local File =W_APPLI+".TABFOR"    [TFO1] : Endif
If clalev([F:CSC0]) = 0 : Local File =W_APPLI+".CFGSCE"    [CSC0] : Endif
If clalev([F:CSL0]) = 0 : Local File =W_APPLI+".CFGSCELIN" [CSL0] : Endif
If clalev([F:CLN])  = 0 : Local File =W_APPLI+".CFGLNK"    [CLN]  : Endif
If clalev([F:CLN0]) = 0 : Local File =W_APPLI+".CFGLNK"    [CLN0] : Endif    # FQ 50486 GA 11/2008
If clalev([F:CLN1]) = 0 : Local File =W_APPLI+".CFGLNK"    [CLN1] : Endif    # FQ 50486 GA 11/2008
If clalev([F:CLN2]) = 0 : Local File =W_APPLI+".CFGLNK"    [CLN2] : Endif    # FQ 50486 GA 11/2008
If clalev([F:AXX])  = 0 : Local File =W_APPLI+".ATEXTRA"   [AXX]  : Endif    # FQ 52854

If clalev([M:CFV1]) = 0 : Local Mask =W_APPLI+".CFGVAL1"   [CFV1] : Endif
#
If [M:CFGU]TLPFLG =  2 |
&  [M:CFGU]SELFLG =  2 |
&  [M:CFGU]SHAFLG =  2 |
&  [M:CFGU]SCEFLG =  2 |
&  [M:CFGU]MSTFLG =  2 |
&  [M:CFGU]SYMWUS =  2 |
&  [M:CFGU]SYMNUS =  2 |
&  [M:CFGU]ITMREF <> ""
  If dim(IVALREL) < 0
    I = 1
    Call AVERTIR(mess(139,188,1),I) From GESECRAN
    If I = 1
      FIN = 0
      Return
    Endif
  Endif
#
  If clalev([F:CQU])  = 0 : Local File =W_APPLI+".CFGQST" [CQU]  : Endif
  If clalev([F:CQU0]) = 0 : Local File =W_APPLI+".CFGQST" [CQU0] : Endif

# FQ 50431 pb si WUVAR inexistant sur dossier fille
  #If W_APPLI<>nomap : # Issue 120564 GH 27/12/2016 - TRT WUVAR is wrong or not existent for a imported folder
     Call GEN_WUVAR(W_APPLI,"","") From CFGLIBA
  #Endif

  Call GEN_VARSYS      From CFGLIBA
  Gosub CFG_CONSTANTES From CFGLIB
  Gosub CFG_SYMBOLES   From CFGLIB
  Call TEMPON(W_APPLI-mess(76,188,1)) From GESECRAN
  #Call GEN_WUVAR(W_APPLI,"","") From CFGLIBA
  Call TEMPOFF From GESECRAN
  adxmbm = adxmbm : # Vidange de la mémoire
  Gosub SUP_GLOBALES From =W_APPLI+".WUVAR"

# FQ 60365 GA 11/2009 pour analyse syntaxique des formules CFGLIBE.CFGWUSEXP
  Gosub TAB_SYMBOLES   From =W_APPLI+".WUVAR"
  Gosub CFG_CONSTANTES From CFGLIB
  Gosub CFG_SYMBOLES   From CFGLIB
Endif
#
Call CFGWUS(1,"*",1)  From CFGLIBE
Call CFGWUS(2,"*",1)  From CFGLIBE
Call CFGWUS(30,"*",1) From CFGLIBE
#
If [M:CFGU]TLPFLG = 2
  Call VALTLP(2,[M:CFGU]CFMFLG,W_APPLI)
Endif
If [M:CFGU]SELFLG = 2
  Call CFGWUS(4,"*",1) From CFGLIBE
  Call CFGWUS(5,"*",1) From CFGLIBE
  Call VALSEL(2,[M:CFGU]CFMFLG,W_APPLI)
  Call VALOPV(2,[M:CFGU]CFMFLG,W_APPLI)
Endif
If [M:CFGU]SHAFLG = 2
  Call CFGWUS(9,"*",1) From CFGLIBE
  Call VALSHA(2,[M:CFGU]CFMFLG,W_APPLI)
Endif
If [M:CFGU]SCEFLG = 2
  Call CFGWUS(3,"*",1) From CFGLIBE
  Call VALSCE(2,[M:CFGU]CFMFLG,W_APPLI)
Endif
If [M:CFGU]MSTFLG = 2
  Call CFGWUS(7,"*",1) From CFGLIBE
  Call VALCFM(2,[M:CFGU]CFMFLG,W_APPLI)
Endif
# Regénération de tous les cas d'emploi
If [M:CFGU]SYMWUS = 2 | [M:CFGU]SYMNUS = 2
  Call PURCLN(99,"*",1) From CFGLIBE
  Call CFGWUS(1,"*",1)  From CFGLIBE
  Call CFGWUS(2,"*",1)  From CFGLIBE
  Call CFGWUS(3,"*",1)  From CFGLIBE
  Call CFGWUS(4,"*",1)  From CFGLIBE
  Call CFGWUS(5,"*",1)  From CFGLIBE
  Call CFGWUS(7,"*",1)  From CFGLIBE
  Call CFGWUS(9,"*",1)  From CFGLIBE
  Call CFGWUS(30,"*",1) From CFGLIBE
Endif
If [M:CFGU]SYMWUS = 2
  Call SYMWUS
Endif
If [M:CFGU]SYMNUS = 2
  Call SYMNUS
Endif
If [M:CFGU]ITMREF <> ""
  Call SEAITM
  FIN = 0
Else
  FIN = 1
Endif
Return
############################################################
$END_CFGUTI
FIN = 1
Return
############################################################
$FIN_CFGUTI
If dim(S_DOSSIER) > 0
  Kill S_DOSSIER
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Return
############################################################
Subprog VALTLP(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Global   Integer GCFGVAL : GCFGVAL = LCFM
Local    Integer WFLD    : WFLD = 6
Local    Integer WNUF    (WFLD)
Local    Integer WNUS    (WFLD)
Local    Char    WNUT(05)(WFLD)
Local    Integer WALF    (WFLD)
Local    Integer WALS    (WFLD)
Local    Char    WALT(05)(WFLD)
Local    Integer I
#
If clalev([F:TLP])=0 : Local File =LAPL+".TABLINCFG"  [TLP] : Endif
If clalev([F:ATB])=0 : Local File =LAPL+".ATABLE"     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =LAPL+".ATABZON"    [ATZ] : Endif
Filter [TLP]
For [TLP]
  Call GET_ATEXTRA("TABLINCFG","CFGLINAXX",GLANGUE,GBIDC1) From TRTX3TEX
  [M:CFGU]PRO = mess(14,188,1)-[F:TLP]CFGLIN-GBIDC1
  Affzo [M:CFGU]PRO
  GOK = 1
  Trbegin [TLP]
  Readlock [TLP] Curr
  If fstat = 0
    For I = 1 To WFLD
      Assign "WNUF("+num$(I-1)+")" With evalue("[F:TLP]CFGNUM"+num$(I))
      Assign "WNUS("+num$(I-1)+")" With evalue("[F:TLP]CFGNUMCOD"+num$(I))
      Assign "WNUT("+num$(I-1)+")" With evalue("[F:TLP]CFGNUMTCT"+num$(I))
      Assign "WALF("+num$(I-1)+")" With evalue("[F:TLP]CFGALP"+num$(I))
      Assign "WALS("+num$(I-1)+")" With evalue("[F:TLP]CFGALPCOD"+num$(I))
      Assign "WALT("+num$(I-1)+")" With evalue("[F:TLP]CFGALPTCT"+num$(I))
    Next I
    Call GEN_LIN(LAPL,"CFGLIN","WUL"+[F:TLP]CFGLIN,WNUF,WNUS,WNUT,WALF,WALS,WALT) From CFGLIBA
    If GOK = 1
      If LTRA = 2
        Call ECR_TRACE(mess(133,188,1)-[F:TLP]CFGLIN,0) From GESECRAN
      Endif
      Commit
    Else
      Rollback
      Call ECR_TRACE(mess(137,188,1)-mess(133,188,1)-[F:TLP]CFGLIN,1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE(mess(20,100,1)-[F:TLP]CFGLIN,1) From GESECRAN
  Endif
Next
Filter [TLP]
Kill GCFGVAL
End
############################################################
Subprog VALSEL(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Global   Integer GCFGVAL : GCFGVAL = LCFM
#
Local Mask =LAPL+".CSE0"    [CSE0]
Local Mask =LAPL+".CSE1"    [CSE1]
Local Mask =LAPL+".CSE2SE"  [CSE2]
If clalev([F:CSE])=0 : Local File =LAPL+".CFGSEL"     [CSE] : Endif
If clalev([F:ATB])=0 : Local File =LAPL+".ATABLE"     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =LAPL+".ATABZON"    [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =LAPL+".ATABIND"    [ATI] : Endif
If clalev([F:ATX])=0 : Local File =LAPL+".ATEXTE"     [ATX] : Endif
If clalev([F:TLP])=0 : Local File =LAPL+".TABLINCFG"  [TLP] : Endif
If clalev([F:CQU])=0 : Local File =LAPL+".CFGQST"     [CQU] : Endif
If clalev([F:COV])=0 : Local File =LAPL+".CFGOPTVAR"  [COV] : Endif
If clalev([F:CFM])=0 : Local File =LAPL+".CFGMAC"     [CFM] : Endif
If clalev([F:CSC])=0 : Local File =LAPL+".CFGSCE"     [CSC] : Endif
If clalev([F:CSL])=0 : Local File =LAPL+".CFGSCELIN"  [CSL] : Endif
If clalev([F:ITM])=0 : Local File =LAPL+".ITMMASTER"  [ITM] : Endif
#
adxmbm = adxmbm : # Vidange de la mémoire
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Local Char    W_SYMAV(10)(100)
Local Decimal W_NBRAV
Local Char    W_SCE(5)
Local Char    W_SCM(5)(100)
Local Char    W_MSG(250)
Local Integer I_SCM, W_I, W_J
#
Local Char PARBOUT(250)(1..20)

#
Filter [CSE] Where SELTYP = 1
For [CSE]
  GOK = 1
  Trbegin [CSE]
  Readlock [CSE] Curr
  If fstat = 0
    Raz [M:CSE0]
    Raz [M:CSE1]
    Raz [M:CSE2]
    [M:CSE0] = [F:CSE]
    [M:CSE1] = [F:CSE]
    [M:CSE2] = [F:CSE]
    [M:CSE0]PAR001 = LAPL
    Gosub LIENS From SUBCSE
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR) From SUBCSE
    If [M:CSE0]SELMOD = 2
      [M:CSE0]PAR001 = LAPL
      [M:CSE0]PAR002 = "CFGINI"
      [M:CSE0]PAR006 = mess(4,752,1)
      BOUT = "c"
      # Issue GA 06/2012 Pb de validation différée/migration depuis la V5
      Local    Integer W_O
      Call VALIDDIRECT("OCSE",LAPL,0,W_O) From VALWIN
      Gosub EXEBOUT  From =LAPL+".WGOCSE"
      If [M:CSE0]RETCOD <> 0
        GOK = 0
      Endif
    Endif
    If GOK = 1
      Gosub GEN_ECRAN From SUBCSE
      If [M:CFGU]SELENA = 2
        [F:CSE]ENAFLG = 2
        Rewrite [CSE]
        If fstat
          Call FSTA("CSE") From GLOCK
          GOK = 0
        Endif
      Endif
    Endif
    If GOK = 1
      If LTRA = 2
        Call ECR_TRACE(mess(134,188,1)-[F:CSE]SELNUM,0) From GESECRAN
      Endif
      Commit
    Else
      Rollback
      Call ECR_TRACE(mess(137,188,1)-mess(134,188,1)-[F:CSE]SELNUM,1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE(mess(20,100,1)-[F:CSE]SELNUM,1) From GESECRAN
  Endif
Next
Filter [CSE]
Close Local Mask [CSE0]
Close Local Mask [CSE1]
Close Local Mask [CSE2]
Kill GCFGVAL
Gosub SUP_GLOBALES From =LAPL+".WUVAR"
End
############################################################
Subprog VALOPV(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Global   Integer GCFGVAL : GCFGVAL = LCFM
#
Local Mask =LAPL+".CSE0"    [CSE0]
Local Mask =LAPL+".CSE1OV"  [CSE1]
Local Mask =LAPL+".CSE2"    [CSE2]
If clalev([F:CSE])=0 : Local File =LAPL+".CFGSEL"     [CSE] : Endif
If clalev([F:ATB])=0 : Local File =LAPL+".ATABLE"     [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =LAPL+".ATABZON"    [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =LAPL+".ATABIND"    [ATI] : Endif
If clalev([F:ATX])=0 : Local File =LAPL+".ATEXTE"     [ATX] : Endif
If clalev([F:TLP])=0 : Local File =LAPL+".TABLINCFG"  [TLP] : Endif
If clalev([F:CQU])=0 : Local File =LAPL+".CFGQST"     [CQU] : Endif
If clalev([F:COV])=0 : Local File =LAPL+".CFGOPTVAR"  [COV] : Endif
If clalev([F:CFM])=0 : Local File =LAPL+".CFGMAC"     [CFM] : Endif
If clalev([F:CSC])=0 : Local File =LAPL+".CFGSCE"     [CSC] : Endif
If clalev([F:CSL])=0 : Local File =LAPL+".CFGSCELIN"  [CSL] : Endif
If clalev([F:ITM])=0 : Local File =LAPL+".ITMMASTER"  [ITM] : Endif
#
adxmbm = adxmbm : # Vidange de la mémoire
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
Local Char    W_SYMAV(10)(100)
Local Decimal W_NBRAV
Local Char    W_SCE(5)
Local Char    W_SCM(5)(100)
Local Char    W_MSG(250)
Local Integer I_SCM, W_I, W_J
#
Filter [CSE] Where SELTYP = 2
For [CSE]
  GOK = 1
  Trbegin [CSE]
  Readlock [CSE] Curr
  If fstat = 0
    Raz [M:CSE0]
    Raz [M:CSE1]
    Raz [M:CSE2]
    [M:CSE0] = [F:CSE]
    [M:CSE1] = [F:CSE]
    [M:CSE2] = [F:CSE]
    [M:CSE0]PAR001 = LAPL
    Gosub LIENS From SUBCSE
    Call GEN_LABELS([M:CSE0]SYMNUM,[M:CSE0]SYMNBR) From SUBCSE
    If [M:CSE0]SELMOD = 2
      [M:CSE0]PAR001 = LAPL
      [M:CSE0]PAR002 = "CFGINI"
      [M:CSE0]PAR006 = mess(5,752,1)
      BOUT = "c"
      # Issue GA 06/2012 Pb de validation différée/migration depuis la V5
      Local    Integer W_O
      Call VALIDDIRECT("OCOV",LAPL,0,W_O) From VALWIN
      Gosub EXEBOUT  From =LAPL+".WGOCOV"
      If [M:CSE0]RETCOD <> 0
        GOK = 0
      Endif
    Endif
    If GOK = 1
      Gosub GEN_ECRAN From SUBCSE
      If [M:CFGU]SELENA = 2
        [F:CSE]ENAFLG = 2
        Rewrite [CSE]
        If fstat
          Call FSTA("CSE") From GLOCK
          GOK = 0
        Endif
      Endif
    Endif
    If GOK = 1
      If LTRA = 2
        Call ECR_TRACE(mess(134,188,1)-[F:CSE]SELNUM,0) From GESECRAN
      Endif
      Commit
    Else
      Rollback
      Call ECR_TRACE(mess(137,188,1)-mess(134,188,1)-[F:CSE]SELNUM,1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE(mess(20,100,1)-[F:CSE]SELNUM,1) From GESECRAN
  Endif
Next
Filter [CSE]
Close Local Mask [CSE0]
Close Local Mask [CSE1]
Close Local Mask [CSE2]
Kill GCFGVAL
Gosub SUP_GLOBALES From =LAPL+".WUVAR"
End
############################################################
Subprog VALSHA(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Local    Char    W_FOR(250)
Local    Char    W_TXT(40)(3)
Local    Integer W_I, W_J
Global   Integer GCFGVAL : GCFGVAL = LCFM
#
Local Mask =LAPL+".CSH1"    [CSH1]
If clalev([F:CSH])=0  : Local File =LAPL+".CFGSHA"     [CSH]  : Endif
If clalev([F:CSH1])=0 : Local File =LAPL+".CFGSHA"     [CSH1] : Endif
If clalev([F:CQU])=0  : Local File =LAPL+".CFGQST"     [CQU]  : Endif
If clalev([F:CFM])=0  : Local File =LAPL+".CFGMAC"     [CFM]  : Endif
If clalev([F:CSC])=0  : Local File =LAPL+".CFGSCE"     [CSC]  : Endif
If clalev([F:CSL])=0  : Local File =LAPL+".CFGSCELIN"  [CSL]  : Endif
If clalev([F:CBB])=0  : Local File =LAPL+".CBLOB"      [CBB]  : Endif : # GA 20/09/2007 suite 42023
#
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
#
Filter [CSH]
For [CSH]
  GOK = 1
  Trbegin [CSH]
  Readlock [CSH] Curr
  If fstat = 0
    Raz [M:CSH1]
    [M:CSH1] = [F:CSH]
    Call GEN_LABELS([M:CSH1]SYMNUM000,[M:CSH1]SYMNBR000) From SUBCSH
#    If [M:CSH1]SHAPCT = ""     en 130
    Raz [F:CBB]
    Read [CBB]CBB0="CSH";[F:CSH]SHACAT;[F:CSH]SHANUM
    If len([M:CSH1]CSHPIC) = 0         # 140: conditionnement image
      [M:CSH1]PAR001 = LAPL
      [M:CSH1]PAR002 = "CFGMOD"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "VWUF12"
      [M:CSH1]PAR010 = ""
    Else
      [M:CSH1]PAR001 = LAPL
      [M:CSH1]PAR002 = "CFGSHA"
      [M:CSH1]PAR003 = [M:CSH1]SHACAT+[M:CSH1]SHANUM
      [M:CSH1]PAR004 = "VWUF20"
      [M:CSH1]PAR010 = ""
    Endif
    BOUT = "b"
     # Issue GA 06/2012 Pb de validation différée/migration depuis la V5
    Local    Integer W_O
    Call VALIDDIRECT("OCSH",LAPL,0,W_O) From VALWIN
    Gosub EXEBOUT  From =LAPL+".WGOCSH"
    If [M:CSH1]RETCOD <> 0
      GOK = 0
    Endif
    If GOK = 1
      If LTRA = 2
        Call ECR_TRACE(mess(135,188,1)-[F:CSH]SHACAT-[F:CSH]SHANUM,0) From GESECRAN
      Endif
      Commit
    Else
      Rollback
      Call ECR_TRACE(mess(137,188,1)-mess(135,188,1)-[F:CSH]SHACAT-[F:CSH]SHANUM,1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE(mess(20,100,1)-[F:CSH]SHACAT-[F:CSH]SHANUM,1) From GESECRAN
  Endif
Next
Filter [CSH]
Close Local Mask [CSH1]
Kill GCFGVAL
Gosub SUP_GLOBALES From =LAPL+".WUVAR"
End
############################################################
Subprog VALSCE(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Global   Integer GCFGVAL : GCFGVAL = LCFM
#
If clalev([F:CSC]) = 0 : Local File =LAPL+".CFGSCE"     [CSC] : Endif
If clalev([F:ATB]) = 0 : Local File =LAPL+".ATABLE"     [ATB] : Endif
If clalev([F:ATZ]) = 0 : Local File =LAPL+".ATABZON"    [ATZ] : Endif
If clalev([F:ATX]) = 0 : Local File =LAPL+".ATEXTE"     [ATX] : Endif
If clalev([F:ACV]) = 0 : Local File =LAPL+".ACTIV"      [ACV] : Endif
If clalev([F:CQU]) = 0 : Local File =LAPL+".CFGQST"     [CQU] : Endif
If clalev([F:CAB]) = 0 : Local File =LAPL+".CFGABQ"     [CAB] : Endif
If clalev([F:CSL]) = 0 : Local File =LAPL+".CFGSCELIN"  [CSL] : Endif
If clalev([F:CSE]) = 0 : Local File =LAPL+".CFGSEL"     [CSE] : Endif
If clalev([F:CFM]) = 0 : Local File =LAPL+".CFGMAC"     [CFM] : Endif
If clalev([F:CSH]) = 0 : Local File =LAPL+".CFGSHA"     [CSH] : Endif
If clalev([F:TCT]) = 0 : Local File =LAPL+".TABCTL"     [TCT] : Endif
If clalev([F:ITG]) = 0 : Local File =LAPL+".ITMCATEG"   [ITG] : Endif
If clalev([F:TLP]) = 0 : Local File =LAPL+".TABLINCFG"  [TLP] : Endif
If clalev([F:ITM]) = 0 : Local File =LAPL+".ITMMASTER"  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File =LAPL+".ITMFACILIT" [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File =LAPL+".ITMMVT"     [ITV] : Endif
If clalev([F:ITS]) = 0 : Local File =LAPL+".ITMSALES"   [ITS] : Endif
If clalev([F:BOH]) = 0 : Local File =LAPL+".BOM"        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File =LAPL+".BOMD"       [BOD] : Endif
If clalev([F:CSC1])= 0 : Local File =LAPL+".CFGSCE"     [CSC1] : Endif
If clalev([F:CSL1])= 0 : Local File =LAPL+".CFGSCELIN"  [CSL1] : Endif
If clalev([F:CFM1])= 0 : Local File =LAPL+".CFGMAC"     [CFM1] : Endif
If clalev([F:CBB])=0   : Local File =LAPL+".CBLOB"      [CBB]  : Endif : # GA 20/09/2007 suite 42023
If GMODU(8) = 2
  If clalev([F:ROH]) = 0 : Local File =LAPL+".ROUTING"   [ROH] : Endif
  If clalev([F:ROO]) = 0 : Local File =LAPL+".ROUOPE"    [ROO] : Endif
  If clalev([F:ROS]) = 0 : Local File =LAPL+".ROUSCD"    [ROS] : Endif
  If clalev([F:ROT]) = 0 : Local File =LAPL+".ROUOPESTD" [ROT] : Endif
Endif
#
Local Mask =LAPL+".CFG0" [CFG0]
Local Mask =LAPL+".CFG1" [CFG1]
Local Mask =LAPL+".CFG2" [CFG2]
Local Mask =LAPL+".CFG4" [CFG4]
Local Mask =LAPL+".CFG5" [CFG5]
Local Mask =LAPL+".CFG6" [CFG6]
Local Mask =LAPL+".CFG8" [CFG8]
Local Mask =LAPL+".CFG9" [CFG9]
Local Mask =LAPL+".CFGW" [CFGW]
Local Mask =LAPL+".CFGX" [CFGX]
#
Local  Char    W_PAR(1)
Local  Char    W_MSK(1)
Local  Char    W_TXT(30)(3)
Local  Char    W_MSG(250)
Local  Char    W_FOR(250)
Local  Char    W_EVA1(80)
Local  Char    W_EVA2(80)
Local  Char    W_SYMAV(10)(dim([M:CFG0]QSTNUM))
Local  Decimal W_NBRAV
Local  Decimal W_NBSAV
Local  Decimal W_NBR
Local  Integer W_I, W_J
#
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
#
Filter [CSC]
For [CSC]
  GOK = 1
  Trbegin [CSC]
  Readlock [CSC] Curr
  If fstat = 0
    Raz [M:CFG0]
    Raz [M:CFG1]
    Raz [M:CFG2]
    Raz [M:CFG4]
    Raz [M:CFG5]
    Raz [M:CFG6]
    Raz [M:CFG8]
    Raz [M:CFG9]
    [M:CFG0] = [F:CSC]
    [M:CFG1] = [F:CSC]
    [M:CFG2] = [F:CSC]
    [M:CFG4] = [F:CSC]
    [M:CFG5] = [F:CSC]
    [M:CFG6] = [F:CSC]
    [M:CFG8] = [F:CSC]
    [M:CFG9] = [F:CSC]
#
  # FQ 59026 GA 11/2009 + 1 param appel GEN_LABELS
    Gosub LIENS From SUBCFG
    Call GEN_LABELS([M:CFG0]QSTNUM,[M:CFG0]QSTNBR,[M:CFG0]SUBNBR,"[M:CFG0]") From SUBCFG
    [M:CFG0]PAR001 = LAPL
    [M:CFG0]PAR002 = "CFGSCE"
    [M:CFG0]PAR003 = [M:CFG0]SCENUM        # FQ 52854
    [M:CFG0]PAR004 = "VWUX234567"          # FQ 52854 6 blocs en V6
    BOUT = "a"
    # Issue GA 06/2012 Pb de validation différée/migration depuis la V5
    Local    Integer W_O
    Call VALIDDIRECT("OCFG",LAPL,0,W_O) From VALWIN
    Gosub EXEBOUT  From =LAPL+".WGOCFG"
    If [M:CFG0]RETCOD <> 0
      GOK = 0
    Else
      Gosub GEN_ECRAN From SUBCFG
      If [M:CFGU]SCEENA = 2
        [F:CSC]ENAFLG = 2
        Rewrite [CSC]
        If fstat
          Call FSTA("CSC") From GLOCK
          GOK = 0
        Endif
      Endif
    Endif
    If GOK = 1
      If LTRA = 2
        Call ECR_TRACE(mess(136,188,1)-[F:CSC]SCENUM,0) From GESECRAN
      Endif
      Commit
    Else
      Rollback
      Call ECR_TRACE(mess(137,188,1)-mess(136,188,1)-[F:CSC]SCENUM,1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE(mess(20,100,1)-[F:CSC]SCENUM,1) From GESECRAN
  Endif
Next
Filter [CSC]
Close Local Mask [CFG0]
Close Local Mask [CFG1]
Close Local Mask [CFG2]
Close Local Mask [CFG4]
Close Local Mask [CFG5]
Close Local Mask [CFG6]
Close Local Mask [CFG8]
Close Local Mask [CFG9]
Close Local Mask [CFGW]
Close Local Mask [CFGX]
Kill GCFGVAL
Gosub SUP_GLOBALES From =LAPL+".WUVAR"
End
############################################################
Subprog VALCFM(LTRA,LCFM,LAPL)
Value    Integer LTRA
Value    Integer LCFM
Value    Char    LAPL
#
Global   Integer GCFGVAL : GCFGVAL = LCFM
#
If clalev([F:CFM])=0  : Local File =LAPL+".CFGMAC"     [CFM]  : Endif
If clalev([F:ATB])=0  : Local File =LAPL+".ATABLE"     [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =LAPL+".ATABZON"    [ATZ]  : Endif
If clalev([F:ATX])=0  : Local File =LAPL+".ATEXTE"     [ATX]  : Endif
If clalev([F:CQU])=0  : Local File =LAPL+".CFGQST"     [CQU]  : Endif
If clalev([F:CAB])=0  : Local File =LAPL+".CFGABQ"     [CAB]  : Endif
If clalev([F:CSH])=0  : Local File =LAPL+".CFGSHA"     [CSH]  : Endif
If clalev([F:CSE])=0  : Local File =LAPL+".CFGSEL"     [CSE]  : Endif
If clalev([F:COV])=0  : Local File =LAPL+".CFGOPTVAR"  [COV]  : Endif
If clalev([F:CSC])=0  : Local File =LAPL+".CFGSCE"     [CSC]  : Endif
If clalev([F:CSL])=0  : Local File =LAPL+".CFGSCELIN"  [CSL]  : Endif
If clalev([F:CFM0])=0 : Local File =LAPL+".CFGMAC"     [CFM0] : Endif
If clalev([F:CBB])=0  : Local File =LAPL+".CBLOB"      [CBB]  : Endif : # GA 20/09/2007 suite 42023
#
Local Mask =LAPL+".CFM1" [CFM1]
#
Local Char    W_TBL
Local Char    W_FOR(250)
Local Char    W_SCE(10)
Local Char    W_SYMAV(10)(100)
Local Char    W_SEL(10)(100)
Local Integer W_SELIND
Local Char    W_TXT(30)(3)
Local Decimal W_NBRAV
Local Decimal W_NBR
Local Decimal W_NBS
Local Char    W_PAR(1)
Local Char    W_MSG(250)
Local Char    W_MSG1(250)
Local Integer W_I, W_J, W_K, W_L
#
Gosub CFG_CONSTANTES From CFGLIB
Gosub CFG_SYMBOLES   From CFGLIB
#
Filter [CFM0] Where MACLIN = 1 & MACCOD = 3
For [CFM0]
  Raz [M:CFM1]
  Filter [CFM] Where MACNUM = [F:CFM0]MACNUM
  For [CFM]
    If [M:CFM1]NBLIG < dim([M:CFM1]SYMNUM)
      [M:CFM1] = [F:CFM]
      [M:CFM1]NBLIG += 1
    Endif
  Next
  Filter [CFM]
#
  GOK = 1
  Trbegin [CSC]
#
  Call GEN_LABELS([M:CFM1]QSTNUM,W_NBR) From SUBCFM
  BOUT = "c"
  [M:CFM1]PAR001 = LAPL
  # Issue GA 06/2012 Pb de validation différée/migration depuis la V5
  Local    Integer W_O
  Call VALIDDIRECT("OCFM",LAPL,0,W_O) From VALWIN
  Gosub EXEBOUT  From =LAPL+".WGOCFM"
  If [M:CFM1]RETCOD <> 0
    GOK = 0
  Endif
  If GOK = 1
    If LTRA = 2
      Call ECR_TRACE(mess(136,188,1)-[F:CFM0]MACNUM,0) From GESECRAN
    Endif
    Commit
  Else
    Rollback
    Call ECR_TRACE(mess(137,188,1)-mess(136,188,1)-[F:CFM0]MACNUM,1) From GESECRAN
  Endif
Next
Filter [CFM0]
Close Local Mask [CFM1]
Kill GCFGVAL
Gosub SUP_GLOBALES From =LAPL+".WUVAR"
End
############################################################
Subprog SYMWUS
Local Char    W_TXT(120)
Local Integer WTYP, WI, W0, W1, W2, W3, W4
Local Char    WSYM
#
Gosub OPEN_FILES From CFGLIB
#
Call ECR_TRACE(mess(141,188,1),0) From GESECRAN
#
Filter [CQU1] Where QSTORI = 1
&             Order By Key CQU1
For [CQU1]
  WTYP = [F:CQU1]QSTTYP
  WSYM = [F:CQU1]QSTNUM
  Raz [M:VCFG]
  Gosub CALWUSTRT From CFGLIBD
  W_TXT = mess([F:CQU1]QSTTYP,752,1)-[F:CQU1]QSTNUM
  If [M:VCFG]NBLIG = 0
    W_TXT -= mess(82,188,1)
    Call ECR_TRACE(W_TXT,0) From GESECRAN
  Else
    Call ECR_TRACE(W_TXT,0) From GESECRAN
    For WI = 0 To [M:VCFG]NBLIG-1
      W_TXT = "______"-[M:VCFG]SYMTYP1(WI)
      If [M:VCFG]SYMTYP2(WI) <> ""
        W_TXT += " / "+[M:VCFG]SYMTYP2(WI)
      Endif
      If [M:VCFG]SYMTYP3(WI) <> ""
        W_TXT += " / "+[M:VCFG]SYMTYP3(WI)
      Endif
      If [M:VCFG]SYMTYP4(WI) <> ""
        W_TXT += " / "+[M:VCFG]SYMTYP4(WI)
      Endif
      If [M:VCFG]SYMTYP5(WI) <> ""
        W_TXT += " / "+[M:VCFG]SYMTYP5(WI)
      Endif
      Call ECR_TRACE(W_TXT,0) From GESECRAN
     Next WI
  Endif
Next
Filter [CQU1]
End
############################################################
Subprog SYMNUS
Local Char    W_TXT(120)
Local Integer WTYP, WI, W0, W1, W2, W3, W4
Local Char    WSYM
#
Gosub OPEN_FILES From CFGLIB
#
Call ECR_TRACE(mess(142,188,1),0) From GESECRAN
Filter [CQU1] Where QSTORI = 1
&             Order By Key CQU1
For [CQU1]
  WTYP = [F:CQU1]QSTTYP
  WSYM = [F:CQU1]QSTNUM
  Raz [M:VCFG]
  Gosub CALWUSTRT From CFGLIBD
  If [M:VCFG]NBLIG = 0
    W_TXT = mess([F:CQU1]QSTTYP,752,1)-[F:CQU1]QSTNUM-mess(82,188,1)
    Call ECR_TRACE(W_TXT,0) From GESECRAN
  Endif
Next
Filter [CQU1]
End
############################################################
Subprog SEAITM
Call TEMPON(mess(76,188,1)) From GESECRAN
Call GEN_SEAITM From CFGLIBD
Call TEMPOFF From GESECRAN
Call CFG_SEAITM([M:CFGU]ITMREF,1) From WUVARU
Affzo [M:CFGU]20
End
############################################################
# Actions écran
############################################################
Subprog AS_CFMFLG(VALEUR)
Variable Integer VALEUR
If GINTRA
  VALEUR = 1
  mkstat = 2
Endif
End
############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Read [ITM]ITM0=VALEUR
If fstat
  [M:CFGU]ITMDES1 = "?????"
Else
  #[M:CFGU]ITMDES1 =  [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:CFGU]ITMDES1, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif
Affzo [M:CFGU]ITMDES1
End
############################################################
Subprog C_SELFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:CFGU]SELENA = 1
  Affzo [M:CFGU]SELENA
  Grizo [M:CFGU]SELENA
Else
  Actzo [M:CFGU]SELENA
Endif
End
############################################################
Subprog C_SCEFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:CFGU]SCEENA = 1
  Affzo [M:CFGU]SCEENA
  Grizo [M:CFGU]SCEENA
Else
  Actzo [M:CFGU]SCEENA
Endif
End
############################################################
Subprog AS_SELENA(VALEUR)
Variable Integer VALEUR
If [M:CFGU]SELFLG = 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_SCEENA(VALEUR)
Variable Integer VALEUR
If [M:CFGU]SCEFLG = 1
  mkstat = 2
Endif
End

