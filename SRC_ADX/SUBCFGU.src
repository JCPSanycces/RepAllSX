$CTRL_MSK_OLD                        # FQ 77122 GA 10/2011 #
Local Integer W_O
If filinfo(filpath("ECR","CFGUTI","msk",0),0)<0
   Call VALIDDIRECT("CFGUTI",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK

   Call VALIDDIRECT("CFG0",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG1",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG2",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG4",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG5",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG6",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG8",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFG9",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFGW",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFGX",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK

   Call VALIDDIRECT("CSE0",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O)   From VALMSK
   Call VALIDDIRECT("CSE1",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O)   From VALMSK
   Call VALIDDIRECT("CSE1OV",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CSE2",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O)   From VALMSK
   Call VALIDDIRECT("CSE2SE",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK

   Call VALIDDIRECT("CSH1",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK
   Call VALIDDIRECT("CFM1",W_APPLI,[F:ADS1]NBRLAN,[F:ADS1]LAN,0,W_O) From VALMSK

Endif
Return
