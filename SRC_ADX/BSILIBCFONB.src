#**
#* Convert a Signed field (Amount) to Separate Sign field.
#*
#* @param PACKED_AMOUNT   Amount, with sign embedded in rightmost byte
#*                        (along with the least-significant digit).
#* @param NUM_DECIMALS    Number of decimal positions implied in PACKED_AMOUNT.
#* @param RECORD_TYPE     Type of record being processed. Depending on this record
#*                        type, "Credit" or "Debit" will be fed into one field or
#*                        another.
#*
#* See https://confluence-sage.valiantyscloud.net/display/X3WILDCATS/X3-109895+-+AFB+file+import+-+Last+character+of+each+line+to+be+considered
#* for an explanation and examples.
#*!

Funprog UNPACK_AMOUNT(PACKED_AMOUNT, NUM_DECIMALS, RECORD_TYPE)
Variable Clbfile  PACKED_AMOUNT
Value Char        NUM_DECIMALS
Value Char        RECORD_TYPE
Local Decimal     UNPACKED_AMOUNT
Local Char        TABLE_OF_CHARS(20) : TABLE_OF_CHARS = "{ABCDEFGHI}JKLMNOPQR"

Local Char        W_CREDIT(1)        : W_CREDIT = "C"
Local Char        W_DEBIT(1)         : W_DEBIT = "D"
Local Char        ENDSNS(1)

Local Tinyint I
  UNPACKED_AMOUNT = val(left$(PACKED_AMOUNT, len(PACKED_AMOUNT) - 1)) * 10
  I = instr(1, TABLE_OF_CHARS, right$(PACKED_AMOUNT, len(PACKED_AMOUNT)))

  If I
    If I < 11
      UNPACKED_AMOUNT += I - 1
    Else
      UNPACKED_AMOUNT = (UNPACKED_AMOUNT + (I - 11)) * -1
    Endif
  Endif
  If val(NUM_DECIMALS)
    Local Char THE_DECIMALS(10) : THE_DECIMALS = "1000000000"
    UNPACKED_AMOUNT /= val(left$(THE_DECIMALS, val(NUM_DECIMALS) + 1))
  Endif
  PACKED_AMOUNT = num$(abs(UNPACKED_AMOUNT))
  If UNPACKED_AMOUNT < 0
    Case RECORD_TYPE
      When "01"
        [F:BSIIMP]BLCSTRSNS = W_DEBIT
      When "04"
        [F:BSIIMPD]SNS = W_DEBIT
      When "07"
        ENDSNS = W_DEBIT
        Gosub PRESERVE_ENDSNS
    Endcase
  Else
    Case RECORD_TYPE
      When "01"
        [F:BSIIMP]BLCSTRSNS = W_CREDIT
      When "04"
        [F:BSIIMPD]SNS = W_CREDIT
      When "07"
        ENDSNS = W_CREDIT
        Gosub PRESERVE_ENDSNS
    Endcase
  Endif
End PACKED_AMOUNT

#**
#* The sign of field [F:BSIIMP]BLCENDSNS was being assigned correctly, but was
#* subsequently lost, as the header was read in BSIIMPORT.HANDLE_SEGMENT prior
#* to updating. This is a way to preserve said sign.
#*!

$PRESERVE_ENDSNS
  Read [F:BSIIMP]BSIIMP0 = [F:BSIIMP]STMCOD
  If fstat
    GOK=0 : Call FSTA("BSIIMP") From GLOCK
  Else
    [F:BSIIMP]BLCENDSNS = ENDSNS
    Rewrite [F:BSIIMP]
    If fstat
      GOK=0 : Call FSTA("BSIIMP") From GLOCK
    Endif
  Endif
Return

#**
#* Reformat a date so that it is interpreted correctly.
#*
#* @param SRC_DATE        Source date, as received from the import file.
#*
#* The input date is in format DDMMYY. It is returned as YYMMDD.
#*!

Funprog FLIP_DATE(SRC_DATE)
Value Char    SRC_DATE
Local Decimal NUM_DATE
Local Char    ALPHA_DATE(6)
  NUM_DATE = (val(right$(SRC_DATE,5)) * 10000) + (val(mid$(SRC_DATE,3,2)) * 100) + val(left$(SRC_DATE,2))
  ALPHA_DATE = format$("N0:6.0", num$(NUM_DATE))
End ALPHA_DATE


Funprog SETFREREF(CURFIELD)
Value Clbfile        CURFIELD
Local Clbfile W_FIELD(0)

  W_FIELD = [F:BSIIMPD]FREREF(0) + left$([F:BSIIMPD]FREREF(1),1) + CURFIELD  : Setlob [F:BSIIMPD]FREREF With W_FIELD

End W_FIELD

