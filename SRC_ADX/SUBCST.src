#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
    When "BOUTON" : Gosub BOUTON
    When "DEBUT"  : Gosub DEBUT
Endcase
Return

######################################################################################
$DEBUT
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITV]) : Local File ITMMVT     [ITV] : Endif

If !clalev([F:AMZ]) : Local File AMSKZON    [AMZ] : Endif

[M:CST0]AFFZON = 2

Local Integer NBPARMAX : NBPARMAX= 10
Local Integer NBTYP : NBTYP = len(mess(0,482,1))
If dim(GTABPAR)<=0
    Global Char GTABPAR(15)(1..NBTYP,NBPARMAX)
Endif

Raz GTABPAR
Raz I
GTABPAR(1,I) = "CLCDAT"
I+=1
GTABPAR(1,I) = "ITMREF"
I+=1
GTABPAR(1,I) = "QTYCLC"
I+=1
GTABPAR(1,I) = "ROUALT"
I+=1
GTABPAR(1,I) = "BOMALT"
I+=1
GTABPAR(1,I) = "BOMALTTYP"
I+=1
GTABPAR(1,I) = "FXDCSTDSP"
I+=1
GTABPAR(1,I) = "SLTOVECOL"

I=0
GTABPAR(2,I) = "VCRTYP"
I+=1
GTABPAR(2,I) = "VCRNUM"
I+=1
GTABPAR(2,I) = "SLTOVECOL"
I+=1
GTABPAR(2,I) = "QTYITMTYP"
I+=1
GTABPAR(2,I) = "QTYMATTYP"
I+=1
GTABPAR(2,I) = "QTYOPETYP"
I+=1
GTABPAR(2,I) = "CSTMATTYP"
I+=1
GTABPAR(2,I) = "CSTOPETYP"
I+=1
GTABPAR(2,I) = "PROCPLEXT"

GTABPAR(3,0) = "VCRTYP"
GTABPAR(3,1) = "VCRNUM"
GTABPAR(3,2) = "SLTOVECOL"

[M:CTP]TYPCST = 1
If GFONC1="ZCLCCST"
    [M:CTP]TYPCST = 1
    [M:CTP]CLCDAT = date$
    [M:CTP]ITMREF = ""
    [M:CTP]ROUALT = 0
    [M:CTP]BOMALT = 0
    [M:CTP]BOMALTTYP = 2
    [M:CTP]FXDCSTDSP = 1
    [M:CTP]NIV = 1
    [M:CTP]SLTOVECOL = 1
    [M:CTP]QTYITMTYP = 1
    [M:CTP]QTYMATTYP = 1
    [M:CTP]QTYOPETYP = 1
    [M:CTP]CSTMATTYP = 1
    [M:CTP]CSTOPETYP = 1
    [M:CTP]PROCPLEXT = 1
Endif
Call AFFPAR([M:CTP]TYPCST)
Affzo [M:CST]
Affzo [M:CST0]
Return

######################################################################################
$BOUTON

Case BOUT
    When "I" : Gosub INIT
    When "C" :
        Call CLCCST  From TRTCST
        If [M:CST0]AFFZON=2
            Affzo [M:CST]
        Endif
Endcase

Return


######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call LECITM([M]STOFCY,VALEUR,"",0,"",LRET) From STKLIB
[M:CST]ISTU(nolign-1)    = [F:ITM]STU
[M:CST]IOVECOD(nolign-1) = [F:ITF]OVECOD
[M:CST]IBRDCOD(nolign-1) = [F:ITM]BRDCOD
Affzo [M]ISTU(nolign-1), IOVECOD(nolign-1), IBRDCOD(nolign-1)
End

######################################################################################
Subprog AM_MATREF(VALEUR)
Variable Char    VALEUR()

Local Integer LRET

Call LECITM([M]STOFCY,VALEUR,"",0,"",LRET) From STKLIB
[M:CST]MSTU(nolign-1)    = [F:ITM]STU
[M:CST]MOVECOD(nolign-1) = [F:ITF]OVECOD
[M:CST]MBRDCOD(nolign-1) = [F:ITM]BRDCOD
[M:CST]MCSTCOD(nolign-1) = 9
Affzo [M]MSTU(nolign-1), MBRDCOD(nolign-1), MOVECOD(nolign-1), CSTCOD(nolign-1)
End


######################################################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
    If [M:CST]ITMTYP(nolign-1) = 2
        pcolor = GCOUL(2)
    Else
        pcolor = GCOUL(0)
    Endif
End


######################################################################################

$INIT
If GFONC1="ZCLCCST"
    Local Integer LAFFZON, LFXDCSTDSP
    LAFFZON = [M:CST0]AFFZON
    LFXDCSTDSP= [M:CTP]FXDCSTDSP
    Effzo [M:CST]1-99
    Effzo [M:CST0]1-99
    Effzo [M:CTP]1-99
    [M:CST0]AFFZON = LAFFZON
    [M:CTP]FXDCSTDSP= LFXDCSTDSP

    [M:CST0]STOFCY= "CCP"

    [M:CTP]TYPCST = 2
    [M:CTP]ITMREF = "CCREFSF1"
    [M:CTP]BOMALT = 3
    [M:CTP]ROUALT = 2
    [M:CTP]QTYCLC = 500
    If [M:CTP]FXDCSTDSP=0
        [M:CTP]FXDCSTDSP=1    # Dans le cas des WIP et coûts prévi, il faut mettre 2
    Endif

    #[M:CTP]VCRNUM="CCP0602000272"
    [M:CTP]VCRTYP = 10
    [M:CTP]VCRNUM="CCP0511000267"
    [M:CTP]QTYITMTYP=3 # réel
    [M:CTP]QTYMATTYP=3
    [M:CTP]QTYOPETYP=3
    [M:CTP]CSTMATTYP=3
    [M:CTP]CSTOPETYP=3
    [M:CTP]PROCPLEXT=1
    If [M:CTP]QTYITMTYP=3 & [M:CTP]QTYMATTYP=2
        [M:CTP]PROCPLEXT=2 # 2 --> QTYMAT = EXTQTYMAT *CPLQTYITM/EXTQTYITM
    Endif
Endif

Call AFFPAR([M:CTP]TYPCST)

Return

######################################################################################
Subprog AM_TYPCST(VALEUR)
Variable Integer VALEUR
Local Integer LTYP
Local Integer LNBPARMAX

Call AFFPAR(VALEUR)
End

######################################################################################
Subprog AFFPAR(PTYP)
Value Integer PTYP

Local Integer LNBPARMAX
Local Integer LTYP
Local Char LMSK : LMSK = "CLCCSTPAR"
LNBPARMAX = dim(GTABPAR,2)-1

Effzo [M:CTP]20
For I=0 To LNBPARMAX
    If GTABPAR(PTYP,I) = ""
        Break
    Endif
    Read [AMZ]CODE=LMSK;GTABPAR(PTYP,I)
    If !fstat
        [M:CTP]NOMPAR([M:CTP]NBPAR) = GTABPAR(PTYP,I)
        Call TEXTE([F:AMZ]INTIT,[M:CTP]INTPAR([M:CTP]NBPAR)) From OBJDIV
        [M:CTP]TYP([M:CTP]NBPAR)    = [F:AMZ]CODTYP
        [M:CTP]NOLIB([M:CTP]NBPAR)  = [F:AMZ]NOLIB
        [M:CTP]LONG([M:CTP]NBPAR)   = [F:AMZ]LONG
        LTYP = evalue("type([M:CTP]"+[M:CTP]NOMPAR([M:CTP]NBPAR)+")")

        If LTYP=3
            [M:CTP]VALPAR([M:CTP]NBPAR) = format$("DD2",evalue("[M:CTP]"+[M:CTP]NOMPAR([M:CTP]NBPAR)))
        Elsif 0<LTYP & LTYP<8 & LTYP<>3
            [M:CTP]VALPAR([M:CTP]NBPAR) = num$(evalue("[M:CTP]"+[M:CTP]NOMPAR([M:CTP]NBPAR)))
        Elsif LTYP>0
            [M:CTP]VALPAR([M:CTP]NBPAR) = evalue("[M:CTP]"+[M:CTP]NOMPAR([M:CTP]NBPAR))
        Endif

        [M:CTP]NBPAR += 1
    Endif
Next

Call AFFINT

Affzo [M:CTP]1-99
End


######################################################################################
Subprog CL_ITM(VALEUR)
Variable Char    VALEUR()
Local Integer LRET
    Effzo [M:CST]10
    Case [M:CTP]TYPCST
        When 1 :
            Call LOADITM(LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
        When 2 :
            If [M:CTP]VCRTYP = 10
                Call LOADMFG(1,LRET) From SUBCSTB
                If LRET
                    Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                    Raz GMESSAGE
                Endif
            Endif
        When 3 :
            Call LOADWIP(1,LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
    Endcase
    Affzo [M:CST]10
End

Subprog CL_MAT(VALEUR)
Variable Char    VALEUR()
    Effzo [M:CST]20
    Case [M:CTP]TYPCST
        When 1 :
            Call LOADBOM(LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
        When 2 :
            If [M:CTP]VCRTYP = 10
                Call LOADMFG(2,LRET) From SUBCSTB
                If LRET
                    Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                    Raz GMESSAGE
                Endif
            Endif
        When 3 :
            Call LOADWIP(2,LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
    Endcase
    Affzo [M:CST]20
End

Subprog CL_OPE(VALEUR)
Variable Char    VALEUR()
    Effzo [M:CST]30,40
    Case [M:CTP]TYPCST
        When 1 :
            Call LOADROU(LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
        When 2 :
            If [M:CTP]VCRTYP = 10
                Call LOADMFG(3,LRET) From SUBCSTB
                If LRET
                    Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                    Raz GMESSAGE
                Endif
            Endif
        When 3 :
            Call LOADWIP(3,LRET) From SUBCSTB
            If LRET
                Call ERREUR([F:MAW]ITMREF-[F:MAW]STOFCY-":"-GMESSAGE) From GESECRAN
                Raz GMESSAGE
            Endif
    Endcase
    Affzo [M:CST]30,40
End


######################################################################################
Subprog C_VALPAR(VALEUR)
Variable Char    VALEUR()
    If [M:CTP]NOMPAR(nolign-1)="VCRTYP"
        If !find(VALEUR,mess(10,701,1),mess(36,701,1))
            mkstat=2
            GMESSAGE=mess(83,123,1)
        Endif
    Endif
    If [M:CTP]NOMPAR(nolign-1)="VCRNUM" & [M:CTP]VCRTYP=10
        If !clalev([F:MFG]) : Local File MFGHEAD : Endif
        Read [MFG]MFG0=VALEUR
        If [F:MFG]MFGFCY<>[M:CST0]STOFCY
            mkstat=2
            GMESSAGE = mess(224,193,1)
            End
        Endif
    Endif
End


######################################################################################
Subprog AM_VALPAR(VALEUR)
Variable Char    VALEUR()

If [M:CTP]NOMPAR(nolign-1)="MFCTYP"
    If val([M:CTP]VALINT(nolign-1))>=4
        mkstat=2
        GMESSAGE = mess(83,123,1)
        End
    Endif
Endif

Local Integer LTYP
LTYP = evalue("type([M:CTP]"+[M:CTP]NOMPAR(nolign-1)+")")

If 0<LTYP & LTYP<8 & LTYP<>3
    Assign "[M:CTP]"+[M:CTP]NOMPAR(nolign-1) With val([M:CTP]VALINT(nolign-1))
Elsif LTYP>0
    Assign "[M:CTP]"+[M:CTP]NOMPAR(nolign-1) With [M:CTP]VALINT(nolign-1)
Endif

Call AFFINT

End


########################################################################
Subprog AS_VALPAR(VALEUR)
Variable Char     VALEUR
    pcolor = GCOUL(0)
End

########################################################################
Subprog AFFINT

Raz [M:CTP]INTIT
If [M:CTP]TYPCST=2
    If    [M:CTP]QTYITMTYP=2 & [M:CTP]QTYMATTYP=1 & [M:CTP]QTYOPETYP=1 & [M:CTP]CSTMATTYP<3 & [M:CTP]CSTOPETYP<3 & [M:CTP]PROCPLEXT=1
        [M:CTP]INTIT = mess(1,2369,1)

    Elsif [M:CTP]QTYITMTYP=2 & [M:CTP]QTYMATTYP=2 & [M:CTP]QTYOPETYP=2 & [M:CTP]CSTMATTYP<3 & [M:CTP]CSTOPETYP<3 & [M:CTP]PROCPLEXT=1
        [M:CTP]INTIT = mess(2,2369,1)

    Elsif [M:CTP]QTYITMTYP=3 & [M:CTP]QTYMATTYP=2 & [M:CTP]QTYOPETYP=2 & [M:CTP]CSTMATTYP<3 & [M:CTP]CSTOPETYP<3 & [M:CTP]PROCPLEXT=2
        [M:CTP]INTIT = mess(3,2369,1)
    Endif
Endif
End   # FGR 09/02/2010 : X3SUIVI60986
######################################################################################

