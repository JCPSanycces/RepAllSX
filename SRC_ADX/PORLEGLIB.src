Subprog SHOW_HIDE_TSG(P_LEG, P_BETFCYCOD)
Value Char    P_LEG
Value Integer P_BETFCYCOD

Local Char    SHOWFIELD(10) : [L]SHOWFIELD = "-"
Local Integer STAT

If ([L]P_LEG = "POR" | [L]P_LEG = "") & find(P_BETFCYCOD, 2, 4, 5)
  [L]SHOWFIELD = ""
Endif

Actzo [M:TSG1]SAFTTRNTYP
Actzo [M:TSG1]RECTYP
Actzo [M:TSG1]CODNUMEND

If dim([M:TSG1]RECTYP) > 0
  Chgfmt [M:TSG1]RECTYP   With [L]SHOWFIELD+"LA2029:15X"
Endif

If dim([M:TSG1]SAFTTRNTYP) > 0
  Chgfmt [M:TSG1]SAFTTRNTYP With [L]SHOWFIELD+"LA2046:15X"
Endif

If dim([M:TSG1]CODNUMEND) > 0
  If [L]SHOWFIELD = "-"
    Diszo [M:TSG1]CODNUMEND
  Endif
Endif

End
