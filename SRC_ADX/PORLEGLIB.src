##94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Funprog VAL_BPC_CASHVAT (P_BPR,P_DOCDAT)
  Value Char P_BPR
  Value Date P_DOCDAT

  Local File BPCUSTOMER [BPC]
  Read [F:BPC]BPC0 = P_BPR

  Local Integer I
  Local Integer RES

  For [L]I=0 To dim([F:BPC]VATSTRDAT)-1
    If ([F:BPC]VATSTRDAT(I)<= P_DOCDAT &  P_DOCDAT <= [F:BPC]VATENDDAT(I)) |
&    ([F:BPC]VATSTRDAT(I)<= P_DOCDAT & [F:BPC]VATSTRDAT(I) <> [0/0/0] & [F:BPC]VATENDDAT(I) = [0/0/0])
      [L]RES = [F:BPC]CSHVATRGM([L]I)
      Break
    Endif
  Next

  If [L]RES = 0 : [L]RES = 1 : Endif

End [L]RES
#94635 RICAR 2014/04/21 - CASH VAT - END
######################################################################################
######################################################################################
#94635 RICAR 2014/04/21 - CASH VAT - BEGIN
Funprog CSHVATREG (ABPR, ADOCNUM)
Value Char ABPR
Value Char ADOCNUM

Local Date DOCDAT

Local Integer RES : [L]RES = 1
Local Integer Y

Local File SINVOICE [SIH]
Read [F:SIH]SIH0 = [L]ADOCNUM
If!fstat
  [L]DOCDAT = [F:SIH]ACCDAT
Else
  Local File PINVOICE [PIH]
  Read [F:PIH]PIH0 = [L]ADOCNUM
  If!fstat
    [L]DOCDAT = [F:PIH]ACCDAT
  Else
    Goto FINRIC
  Endif
Endif

Local File BPCUSTOMER [BPC]
Read [F:BPC]BPC0 = [L]ABPR
If fstat : Goto FINRIC : Endif

For [L]Y=0 To dim([F:BPC]VATSTRDAT)-1
  If ([F:BPC]VATSTRDAT(Y)<= [L]DOCDAT &  [L]DOCDAT <= [F:BPC]VATENDDAT(Y)) |
&    ([F:BPC]VATSTRDAT(Y)<= [L]DOCDAT & [F:BPC]VATSTRDAT(Y) <> [0/0/0] & [F:BPC]VATENDDAT(Y) = [0/0/0])
    [L]RES = [F:BPC]CSHVATRGM([L]Y)
    Break
  Endif
Next

If [L]RES = 0 : [L]RES = 1 : Endif

$FINRIC
End [L]RES
#94635 RICAR 2014/04/21 - CASH VAT - END
###################################################################################################
###################################################################################################
#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
$VAL_SIMINV_BIC

If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif
If !clalev([F:TVB]) : Local File TABVACBPR [TVB] : Endif

Local Integer SRVINV
Local Decimal SIMINVLIM

If func VAL_SIMINV([M:BIC0]SIVTYP) <> 2
  Return
Endif

Call LEC_TVB(GCURLEG,[M:BIC1]VAC) From CPTLEC

If !fstat
   If [F:BPC]BPCNUM <> [M:BIC0]BPR
      Read [F:BPC]BPC0 = [M:BIC0]BPR
      If fstat <> 0 : Raz [F:BPC] : Endif
   Endif
   If [F:BPR]BPRNUM <> [F:BPC]BPCNUM
      Read [F:BPR]BPR0 = [F:BPC]BPCNUM
      If fstat <> 0 : Raz [F:BPR] : Endif
   Endif
   If [F:FCY]FCY <> [M:BIC0]FCY
      Read [F:FCY]FCY0 = [M:BIC0]FCY
      If fstat <> 0 : Raz [F:FCY] : Endif
   Endif
   If [F:CPY]CPY <> [M:BIC0]CPY
      Read [F:CPY]CPY0 = [M:BIC0]CPY
      If fstat <> 0 : Raz [F:CPY] : Endif
   Endif

   If [F:BPR]LEGETT <> 2 | instr(1, [F:BPR]EECNUM, "PT") = 0
     OK       = 0
     GMESSAGE = mess(77,7711,1)
     GERR     = 1
   Endif

   If OK = 0 : Return : Endif

   [L]SRVINV    = 0
   [L]SIMINVLIM = 0

   For I = 0 To [M:BIC3]NBLIG-1
     If [M:BIC3]SALTYP(I) = 3
       [L]SRVINV = 1
       Break
     Endif
   Next

   If [F:CPY]PORCPYACTTYP = 2 & [F:BPR]LEGETT = 2 & [L]SRVINV = 0
      [L]SIMINVLIM = [F:CPY]PORAMTITMINV
   Else
      [L]SIMINVLIM = [F:CPY]PORAMTSERINV
   Endif

   If [M:BIC3]TOTNOT > [L]SIMINVLIM
      OK       = 0
      GMESSAGE = mess(76,7711,1)
      GERR     = 1
   Endif

   If OK = 0 : Return : Endif

Endif

Return
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END
######################################################################################
######################################################################################
#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
$VAL_SIMINV_SIH
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:BPR]) : Local File BPARTNER  [BPR] : Endif
If !clalev([F:TVB]) : Local File TABVACBPR [TVB] : Endif

Local Integer SRVINV
Local Decimal SIMINVLIM

If func VAL_SIMINV([M:SIH0]SIVTYP) <> 2
  Return
Endif

Call LEC_TVB(GCURLEG,[M:SIH1]VACBPR) From CPTLEC

If !fstat
   If [F:BPC]BPCNUM <> [M:SIH0]BPCINV
      Read [F:BPC]BPC0 = [M:SIH0]BPCINV
      If fstat <> 0 : Raz [F:BPC] : Endif
   Endif
   If [F:BPR]BPRNUM <> [F:BPC]BPCNUM
      Read [F:BPR]BPR0 = [F:BPC]BPCNUM
      If fstat <> 0 : Raz [F:BPR] : Endif
   Endif
   If [F:FCY]FCY <> [M:SIH0]SALFCY
      Read [F:FCY]FCY0 = [M:SIH0]SALFCY
      If fstat <> 0 : Raz [F:FCY] : Endif
   Endif
   If [F:CPY]CPY <> [F:FCY]LEGCPY
      Read [F:CPY]CPY0 = [F:FCY]LEGCPY
      If fstat <> 0 : Raz [F:CPY] : Endif
   Endif

   If [F:BPR]LEGETT <> 2 | instr(1, [F:BPR]EECNUM, "PT") = 0
     OK       = 0
     GMESSAGE = mess(77,7711,1)
     GERR     = 1
   Endif

   If OK = 0 : Return : Endif

   [L]SRVINV    = 0
   [L]SIMINVLIM = 0

   For I = 0 To [M:SIH4]NBLIG-1
      Read [F:ITM]ITM0 = [M:SIH4]ITMREF(I)
      If [F:ITM]ITMSFTTYP = 3
         [L]SRVINV = 1
         Break
      Endif
   Next

   If [F:CPY]PORCPYACTTYP = 2 & [F:BPR]LEGETT = 2 & [L]SRVINV = 0
      [L]SIMINVLIM = [F:CPY]PORAMTITMINV
   Else
      [L]SIMINVLIM = [F:CPY]PORAMTSERINV
   Endif

   If [M:SIH4]INVNOT > [L]SIMINVLIM
     OK       = 0
     GMESSAGE = mess(76,7711,1)
     GERR     = 1
   Endif

   If OK = 0 : Return : Endif

Endif

Return
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END
