Subprog SHOW_HIDE_ORIDOCNUM(P_FCY,P_TSV,P_MSK)
Value Char P_FCY
Value Char P_TSV
Value Char P_MSK

Local Char    SHOWFIELD(1) : [L]SHOWFIELD = "-"
Local Integer STAT

If func ORIDOCNUM_IS_MANDATORY(P_FCY,P_TSV)
  [L]SHOWFIELD = ""
Endif

Case P_MSK
  When "SIH0"
    Chgfmt [M:SIH0]ORIDOCNUM With [L]SHOWFIELD+"K:30X"
  When "BIC1"
    Chgfmt [M:BIC1]ORIDOCNUM With [L]SHOWFIELD+"K:30X"
Endcase

End
######################################################################################
######################################################################################
Subprog SHOW_HIDE_PORIDOCNUM(P_FCY,P_TPV,P_MSK)
Value Char P_FCY
Value Char P_TPV
Value Char P_MSK

Local Char    SHOWFIELD(1) : [L]SHOWFIELD = "-"
Local Integer STAT

If func PORIDOCNUM_IS_MANDATORY(P_FCY,P_TPV)
  [L]SHOWFIELD = ""
Endif

Case P_MSK
  When "PIH0"
    Chgfmt [M:PIH0]ORIDOCNUM With [L]SHOWFIELD+"K:30X"
  When "BIS1"
    Chgfmt [M:BIS1]ORIDOCNUM With [L]SHOWFIELD+"K:30X"
Endcase

End
######################################################################################
######################################################################################
Funprog ORIDOCNUM_IS_MANDATORY(P_FCY,P_TSV)
Value Char P_FCY
Value Char P_TSV

Local Integer STAT, RETVAL

If func AFNC.ACTIV("KPO") & func PORLEGLIB.DIGSIGN(P_FCY,"")
  If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
  If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

  If [F:FCY]FCY <> P_FCY
    Read [F:FCY]FCY0 = P_FCY
  Endif

  Call LEC_TSV_LEG([F:FCY]LEG,P_TSV,STAT) From TRTLECLEG
  If find([F:TSV]RECTYP,2,3) : [L]RETVAL = [F:TSV]RECTYP : Endif

Endif

End RETVAL
######################################################################################
######################################################################################
Funprog PORIDOCNUM_IS_MANDATORY(P_FCY,P_TPV)
Value Char P_FCY
Value Char P_TPV

Local Integer STAT, RETVAL

If func AFNC.ACTIV("KPO") #& func PORLEGLIB.DIGSIGNPIH(P_FCY,"",P_TPV)
  If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif
  If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif

  If [F:FCY]FCY <> P_FCY
    Read [F:FCY]FCY0 = P_FCY
  Endif

  Call LEC_TPV_LEG([F:FCY]LEG,P_TPV,STAT) From TRTLECLEG
  If find([F:TPV]RECTYP,2,3) : [L]RETVAL = [F:TPV]RECTYP : Endif

Endif

End RETVAL
######################################################################################
######################################################################################
Funprog GET_PARVAL_LEGPOR(P_PARAM)
Value Char P_PARAM

Local Char RETVAL(255)

If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Read [ADW]ADW0 = "*";"POR";P_PARAM
If fstat
  Read [ADW]ADW0 = "";"";P_PARAM
Endif
If !fstat
  RETVAL = [F:ADW]VALEUR
Endif

End RETVAL
