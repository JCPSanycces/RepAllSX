######################################################################################
######################################################################################
Funprog SHWHID4041(ALEG,AVAC,AORI,ATYP,AFLD)
Value Char    ALEG
Value Char    AVAC
Value Integer AORI
Value Char    ATYP
Value Integer AFLD
Local Char    RETVAL(1)
Local Integer RET

If [L]ALEG <> "POR" : RETVAL = "-" : Goto OUT : Endif

If !clalev([F:TVB]) : Local File TABVACBPR [TVB] : Endif
Call LEC_TVB_LEG([L]ALEG,[L]AVAC,[L]RET) From TRTLECLEG
If [L]RET : Raz [F:TVB] : Endif

Local Integer WRET

Case AORI
  When 1
    If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
    Call LEC_TSV_LEG([L]ALEG,ATYP,WRET) From TRTLECLEG
    If [L]WRET : Raz [F:TSV] : Endif
  When 2
    If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif
    Call LEC_TPV_LEG([L]ALEG,ATYP,WRET) From TRTLECLEG
    If [L]WRET : Raz [F:TPV] : Endif
Endcase

Case AORI
  When 1 #Customer
    If find([F:TVB]REGVAC,2)
      RETVAL = "-" : Goto OUT
    Endif
    Case [F:TSV]SAFTINVTYP
      When 1, 2
        RETVAL = "-" : Goto OUT
      When 4
        If AFLD = 41 & !find([F:TVB]REGVAC,4)
          RETVAL = "-" : Goto OUT
        Endif
      When 3
        If AFLD = 40 & !find([F:TVB]REGVAC,4)
          RETVAL = "-" : Goto OUT
        Endif
      When Default
        RETVAL = "-" : Goto OUT
    Endcase
  When 2 #Supplier
    Case [F:TPV]SAFTINVTYP
      When 1, 2
        RETVAL = "-" : Goto OUT
      When 4
        If AFLD = 40 & !find([F:TVB]REGVAC,4)
          RETVAL = "-" : Goto OUT
        Endif
      When 3
        If AFLD = 41 & !find([F:TVB]REGVAC,4)
          RETVAL = "-" : Goto OUT
        Endif
      When Default
        RETVAL = "-" : Goto OUT
    Endcase
Endcase

$OUT
End [L]RETVAL
######################################################################################
######################################################################################
Funprog DIGSIGN(PFCY, PCPY)
Value Char PFCY
Value Char PCPY

Local Integer RETVAL : [L]RETVAL = 0

If [L]PCPY = ""
  Local File FACILITY [FCY]
  Read [F:FCY]FCY0 = [L]PFCY
  If fstat > 1 : Raz [F:FCY] : Endif
  [L]PCPY = [F:FCY]LEGCPY
Endif

If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[L]PCPY)="2"
  [L]RETVAL = 1
Endif

End [L]RETVAL
######################################################################################
######################################################################################
Funprog DIGSIGNPIH(PFCY, PCPY, PTYP)
Value Char PFCY
Value Char PCPY
Value Char PTYP

Local Integer RETVAL : [L]RETVAL = 0
Local Char    LLEG(GLONADI)
Local Integer WRET

If [L]PCPY = ""
  Local File FACILITY [FCY]
  Read [F:FCY]FCY0 = [L]PFCY
  If fstat > 1 : Raz [F:FCY] : Endif
  [L]PCPY = [F:FCY]LEGCPY
  [L]LLEG = [F:FCY]LEG
Else
  Local File COMPANY [CPY]
  Read [F:CPY]CPY0 = [L]PCPY
  [L]LLEG = [F:CPY]LEG
Endif

Local File TABPIVTYP [TPV]
Call LEC_TPV_LEG([L]LLEG,PTYP,WRET) From TRTLECLEG

If func AFNC.ACTIV("DKS") & func AFNC.PARAM("PORDKS",[L]PCPY)="2" & [F:TPV]AUTINV = 2
  [L]RETVAL = 1
Endif

End [L]RETVAL
######################################################################################
######################################################################################
Funprog PORLEG(PFCY, PCPY)
Value Char PFCY
Value Char PCPY

Local Integer RETVAL : [L]RETVAL = 0

If [L]PCPY <> ""
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If [F:CPY]CPY <> [L]PCPY
    Read [F:CPY]CPY0 = [L]PCPY : If fstat > 1 : Raz [F:CPY] : Endif
  Endif
  If [F:CPY]LEG = "POR" : RETVAL = 1 : Endif
Elsif [L]PFCY <> ""
  If !clalev([FCY]) : Local File FACILITY [FCY] : Endif
  If [F:FCY]FCY <> [L]PFCY
    Read [F:FCY]FCY0 = [L]PFCY : If fstat > 1 : Raz [F:FCY] : Endif
  Endif
  If [F:FCY]LEG = "POR" : RETVAL = 1 : Endif
Endif

End [L]RETVAL
######################################################################################
######################################################################################
Funprog ANM_OK(ANMCOD, ERRMESS)
Value    Char ANMCOD
Variable Char ERRMESS

Local File ACODNUM [ANM]

Local Integer RETVAL
Local Integer I
Local Integer NIVDEFOK
Local Integer NIVRAZOK
Local Integer COMPLEOK

Read [ANM]ANM0 = ANMCOD
If fstat
  [L]ERRMESS = [L]ANMCOD+":"-mess(12,114,1): Goto $EXIT_ANM_OK
Endif

If [F:ANM]POSTYP([F:ANM]NBPOS-1) <> 8
  [L]ERRMESS = func AFNC.MES3(mess(36,7711,1), [L]ANMCOD, mess(8,47,1), mess([F:ANM]POSTYP([F:ANM]NBPOS-1),47,1)) : Goto $EXIT_ANM_OK
Endif

If [F:ANM]POSTYP([F:ANM]NBPOS-2) <> 1 | [F:ANM]POSCTE([F:ANM]NBPOS-2)<>"/"
  [L]ERRMESS = func AFNC.MES1(mess(44,7711,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
Endif

If [F:ANM]CTLCHR<>2
  [L]ERRMESS = func AFNC.MES1(mess(43,7711,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
Endif

If [F:ANM]NIVDEF = 1
  NIVDEFOK = 1
Endif

If [F:ANM]NIVRAZ = 1
  NIVRAZOK = 1
Elsif [F:ANM]NIVRAZ <> 2 & [F:ANM]NIVRAZ <> 4
  [L]ERRMESS = func AFNC.MES2(mess(45,7711,1), [L]ANMCOD, mess(1,48,1)+";"+mess(2,48,1)+";"+mess(4,48,1)) : Goto $EXIT_ANM_OK
Endif

For [L]I = 0 To [F:ANM]NBPOS-1
  Case [F:ANM]POSTYP([L]I)
    When 2  # Année
      If [F:ANM]NIVRAZ <> 2
        [L]ERRMESS = func AFNC.MES2(mess(47,7711,1), mess([F:ANM]POSTYP([L]I),47,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
      Else
        NIVRAZOK = 1
      Endif
    When 10 # Exercice
      If [F:ANM]NIVRAZ <> 4
        [L]ERRMESS = func AFNC.MES2(mess(47,7711,1), mess([F:ANM]POSTYP([L]I),47,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
      Else
        NIVRAZOK = 1
      Endif
    When 3, 4, 5, 11, 12 # Mois, Semaine, Jours, Période, Formule
      [L]ERRMESS = func AFNC.MES2(mess(46,7711,1), mess([F:ANM]POSTYP([L]I),47,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
    When 6  # Société
      If [F:ANM]NIVDEF <> 2
        [L]ERRMESS = func AFNC.MES2(mess(48,7711,1), mess([F:ANM]POSTYP([L]I),47,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
      Else
        NIVDEFOK = 1
      Endif
    When 7  # Site
      If [F:ANM]NIVDEF <> 3
        [L]ERRMESS = func AFNC.MES2(mess(48,7711,1), mess([F:ANM]POSTYP([L]I),47,1), [L]ANMCOD) : Goto $EXIT_ANM_OK
      Else
        NIVDEFOK = 1
      Endif
#    When 8  # Séquence
#      If  [L]I <> [F:ANM]NBPOS-1
#        [L]ERRMESS = mess(12,4440,1) : Goto $EXIT_ANM_OK
#      Endif
#    When 9  # Complément
#      COMPLEOK = 1
  Endcase
Next

If NIVDEFOK <> 1
  [L]ERRMESS = mess(50,7711,1) : Goto $EXIT_ANM_OK
Endif

If NIVRAZOK <> 1
  [L]ERRMESS = mess(49,7711,1) : Goto $EXIT_ANM_OK
Endif

[L]RETVAL = 1

$EXIT_ANM_OK
End [L]RETVAL
######################################################################################
######################################################################################
Funprog REVGASOK(P_GTE,P_ORI)
Value    Char P_GTE
Value Integer P_ORI

Local Integer RES : RES = 1
Local Integer STAT

If P_ORI = 5
  RES = 0 : Goto EXIT_REVGASOK
Elsif !find(P_ORI, 3, 6)
  Goto EXIT_REVGASOK
Endif

If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif
If [L]P_ORI = 3
  If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
Endif

### check if the document it's a purchase auto-invoice
Call LEC_TPV_LEG(GCURLEG,P_GTE,STAT) From TRTLECLEG
If !fstat & [F:TPV]AUTINV = 2
  RES = 0
  Goto EXIT_REVGASOK
Endif

### check if the document it's a sales invoice
If [L]P_ORI = 3
  Call LEC_TSV_LEG(GCURLEG,P_GTE,STAT) From TRTLECLEG
  If !fstat & [F:TSV]INVTYP <> 5
    RES = 0
    Goto EXIT_REVGASOK
  Endif
Endif

$EXIT_REVGASOK
End RES
######################################################################################
######################################################################################
Funprog CREGASOK(P_JOU,P_NUM,P_MESS)
Value    Char P_JOU
Value    Char P_NUM
Variable Char P_MESS

Local Integer RES : RES = 1
Local Integer STAT
If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif

### check if the document it's on signed documents table
If P_NUM <> ""
  If !clalev([F:DKD]) : Local File DKSDATA [DKD] : Endif
  Filter [F:DKD] Where [F:DKD]DOCNUM = P_NUM & [F:DKD]KEYCODE = 'SAFT-PT'
  Read [F:DKD] First
  Filter [F:DKD]
  If !fstat
    P_MESS = mess(51,7711,1) + mess(654,7773,1)
    RES    = 0
    Goto EXIT_CREGASOK
  Endif
Endif

If !clalev([F:JOU]) : Local File GJOURNAL [JOU] : Endif
Call LEC_JOU_LEG(GCURLEG,P_JOU,STAT) From TRTLECLEG

If [F:JOU]TYP = 1
  P_MESS = mess(77,106,1)
  RES    = 0
Elsif [F:JOU]TYP = 2
  If !clalev([F:PIH2]) : Local File PINVOICE [PIH2] : Endif
  Read [F:PIH2]PIH0=P_NUM
  If !fstat
    Filter [F:TPV] Where [F:TPV]AUTINV = 2 & [F:TPV]PIVTYP =  [F:PIH2]PIVTYP
    Read [F:TPV] First
    If !fstat
      P_MESS = mess(77,106,1)
      RES    = 0
    Endif
    Filter [F:TPV]
  Endif
Endif

$EXIT_CREGASOK
End RES
