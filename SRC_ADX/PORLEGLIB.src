Funprog DOCTYP(FONCTION)
Value Char FONCTION

Local Integer RET : [L]RET=0
Case FONCTION
   When "GESSDH" : [L]RET = 2
   When "GESTNH" : [L]RET = 10
   When "GESPNH" : [L]RET = 9
   When "GESSIS" : [L]RET = 6
   When "GESSST" : [L]RET = 7
   When "GESSTR" : [L]RET = 8
   When "GESSRH" : [L]RET = 3
   When "GESSRL" : [L]RET = 4
   When "GESSRS" : [L]RET = 5
Endcase

End [L]RET
######################################################################################
######################################################################################
Funprog DOCCTR(TYP,BP,DOCTYP,FCY)
Value Integer TYP
Value Char    BP
Value Char    DOCTYP
Value Char    FCY

If clalev([F:PTBPR]) = 0 : Local File BPARTNER   [PTBPR] : Endif
If clalev([F:PTFCY]) = 0 : Local File FACILITY   [PTFCY] : Endif
If clalev([F:PTBPA]) = 0 : Local File BPADDRESS  [PTBPA] : Endif
If clalev([F:TSD]) = 0 : Local File TABSDHTYP  [TSD] : Endif
If clalev([F:TRE]) = 0 : Local File TABSRHTYP  [TRE] : Endif
If clalev([F:TSG]) = 0 : Local File TABSGHTYP  [TSG] : Endif
If clalev([F:TPN]) = 0 : Local File TABPNHTYP  [TPN] : Endif

If func AFNC.ACTIV('TRSNE')>0
  If clalev([F:TTN]) = 0 : Local File TABTNHTYP  [TTN] : Endif
Endif

Local Integer RET       : [L]RET   = 0
Local Integer STAT      : [L]STAT  = 0
Local Char    LEG(30)   : [L]LEG   = ''

Read [F:PTFCY]FCY0=[L]FCY
If fstat : Raz [F:PTFCY] : Endif

Read [F:PTBPA]BPA0=3;[F:PTFCY]FCY;[F:PTFCY]BPAADD
If fstat : Raz [F:PTBPA] : Endif

[L]LEG = [F:PTFCY]LEG
Read [F:PTBPR]BPR0=[L]BP : If fstat : Raz [F:PTBPR] : Endif

Case TYP
  When 2
    Call LEC_TSD_LEG([L]LEG,[L]DOCTYP, STAT) From TRTLECLEG
    If [F:TSD]RECTYP=1 & [F:PTBPR]LEGETT=1 & find([F:TSD]SAFTTRNTYP,1,2,4) & [F:PTBPA]CRY='PT'
      [L]RET=1
    Else
      [L]RET=0
    Endif
  When 3,4,5
    # BRBAN 07/04/2015 107403 - [F:TRE]COMAT must be 2
    Call LEC_TRE_LEG([L]LEG,[L]DOCTYP, STAT) From TRTLECLEG
    If [F:TRE]RECTYP=1 & [F:TRE]SAFTTRNTYP=5 & [F:PTBPR]LEGETT=1 & [F:PTBPA]CRY='PT' & [F:TRE]COMAT=2
      [L]RET=1
    Else
      [L]RET=0
    Endif
  When 6,7,8
    Call LEC_TSG_LEG([L]LEG, [L]DOCTYP, STAT) From TRTLECLEG
    If [F:TSG]RECTYP=1 & find([F:TSG]SAFTTRNTYP,1,2) & [F:PTBPA]CRY='PT'
      [L]RET=1
    Else
      [L]RET=0
    Endif
  When 9
    Call LEC_TPN_LEG([L]LEG, [L]DOCTYP, STAT) From TRTLECLEG
    If [F:TPN]RECTYP=1 & [F:TPN]SAFTTRNTYP=5 & [F:PTBPA]CRY='PT'
      [L]RET=1
    Else
      [L]RET=0
    Endif
  When 10
    Call LEC_TTN_LEG([L]LEG, [L]DOCTYP, STAT) From TRTLECLEG
    If [F:TTN]RECTYP=1 & !find([F:TTN]SAFTTRNTYP,3) & [F:PTBPA]CRY='PT'
      [L]RET=1
    Else
      [L]RET=0
    Endif
Endcase
End [L]RET
######################################################################################
######################################################################################
$PNH_ADD_MNG

If func AFNC.ACTIV('KPO')>0 & func PORLEGLIB.DIGSIGN("", [F:PNH]CPY)=1
  Diszo [M:PNH2]ATDTCODR
  If func PORLEGLIB.DOCCTR(9,[F:PNH]BPSNUM,[F:PNH]PNHTYP,[F:PNH]PNHFCY)=1
    If [F:PNH]CFMFLG<>2
      Actzo [M:PNH2]ATDTCODR
    Else
      If clalev([F:DKD])=0 : Local File DKSDATA [DKD] : Endif
      Read [F:DKD]DKD0 = "SAFT-PT";[F:PNH]PNHTYP;[F:PNH]PNHNUM
      If !fstat & [F:DKD]ATDTCOD<>''
        Diszo [M:PNH2]ARVDATR,DPEDATR,ETDR,ETAR,LICPLATER,TRLLICPLATER
        Diszo [M:PNH2]ATDTCODR,MANDOCR
      Endif
    Endif
  Endif
  Call DIS_MANDOC(GFONCTION) From TRNDOC
Else
  If func AFNC.ACTIV('KPO')>0
    Diszo [M:PNH2]ATDTCODR
    Diszo [M:PNH2]MANDOCR
  Endif
Endif

Return

Subprog PORDIGSIG(CPY,FCY)
Value Char CPY
Value Char FCY

If func PORLEGLIB.DIGSIGN(FCY, CPY)<>1
  GMESSAGE = mess(130,7711,1)
  mkstat = 2
Endif

End
######################################################################################
Subprog MANDOC_TEXT(RECTYP,SAFTINVTYP,RET)
Value Integer RECTYP
Value Integer SAFTINVTYP
Variable Char RET

Case [L]SAFTINVTYP
  When 1 : [L]RET='FT'
  When 2 : [L]RET='FS'
  When 3 : [L]RET='ND'
  When 4 : [L]RET='NC'
  When 5 : [L]RET='AA'
  When 6 : [L]RET='DA'
  When 7 : [L]RET='FR'
  When 8 : [L]RET='PF'
  When 9 : [L]RET='FC'
Endcase

Case [L]RECTYP
  When 2 : [L]RET+='M'
  When 3 : [L]RET+='D'
Endcase
[L]RET+=' '
End
