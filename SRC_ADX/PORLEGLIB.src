######################################################################################
#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
Subprog DES_CONTROL(ITM,DESIDX)
Value Char     ITM
Value Shortint DESIDX

If GIMPORT
  Local File ITMMASTER [ITM1]
  Read [F:ITM1]ITM0 = [L]ITM
  Case DESIDX
    When 1
      If [F:ITM1]ITMDES1 = [M:ITM0]DES1AXX : End : Endif
    When 2, 3
      If evalue("[F:ITM1]ITMDES"+num$(DESIDX)) = evalue("[M:ITM1]DES"+num$(DESIDX)+"AXX") : End : Endif
    Endcase
Endif

Local File COMPANY     [CPY]
Local File FACILITY    [FCY]
Local File TABPIVTYP   [TPV]
If GMODU(5) = 2
  Local File SINVOICE    [SIH]
  Local File SINVOICED   [SID]
  Local File SDELIVERY   [SDH]
  Local File SDELIVERYD  [SDD]
  Local File SRETURN     [SRH]
  Local File SRETURND    [SRD]
Endif
If GMODU(6) = 2
  Local File PINVOICE    [PIH]
  Local File PINVOICED   [PID]
  Local File PRETURN     [PNH]
  Local File PRETURND    [PND]
Endif
If GMODU(7) = 2
  Local File SCHGH       [SGH]
  Local File SCHGD       [SGD]
Endif

Local Char DYN_ARRAY(GLONCPY)(1..)
Local Integer NUM : [L]NUM = 1

For [CPY] Where [F:CPY]LEG = "POR"
  #If func AFNC.PARAM("PORLEG",[F:CPY]CPY)="2" #RMA PORLEG abandoned
    DYN_ARRAY([L]NUM) = [F:CPY]CPY
    [L]NUM += 1
  #Endif
Next

If GMODU(5) = 2

  #Filter [F:SID] Where [F:SID]ITMREF = [L]ITM & find([F:SIH]CPY,DYN_ARRAY) & [F:SIH]ACCDAT>=[01/01/2012]
  #Read [SID] First
  #If !fstat
  #  Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #  mkstat = 2 : End
  #Endif
  #Filter [F:SID]

  Link [F:SID] With [F:SIH]SIH0 = [F:SID]NUM    As [LNK]
& Where [F:SID]ITMREF = [L]ITM & find([F:SIH]CPY,DYN_ARRAY) & [F:SIH]ACCDAT>=[01/01/2012]
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif
  Close File [LNK]

  #Filter [F:SDD] Where [F:SDD]ITMREF = [L]ITM & find([F:SDH]CPY,DYN_ARRAY) & [F:SDH]SIHDAT>=[01/01/2012]
  #Read [SDD] First
  #If !fstat
  #  Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #  mkstat = 2 : End
  #Endif
  #Filter [F:SDD]

  Link [F:SDD] With [F:SDH]SDH0 = [F:SDD]SDHNUM  As [LNK]
& Where [F:SDD]ITMREF = [L]ITM & find([F:SDH]CPY,DYN_ARRAY) & [F:SDH]SHIDAT>=[01/01/2012]
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif
  Close File [LNK]

  #Filter [F:SRD] Where [F:SRD]ITMREF = [L]ITM & find([F:SRH]CPY,DYN_ARRAY) & [F:SRH]RTNDAT>=[01/01/2012]
  #Read [SRD] First
  #If !fstat
  #  Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #  mkstat = 2 : End
  #Endif
  #Filter [F:SRD]

  Link [F:SRD] With [F:SRH]SRH0 = [F:SRD]SRHNUM As [LNK]
& Where [F:SRD]ITMREF = [L]ITM & find([F:SRH]CPY,DYN_ARRAY)  & [F:SRH]RTNDAT >=[01/01/2012]
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif
  Close File [LNK]
Endif

If GMODU(6) = 2
  #Filter [F:PID] Where [F:PID]ITMREF = [L]ITM & find([F:PIH]CPY,DYN_ARRAY) & [F:PIH]ACCDAT >=[01/01/2012] & [F:TPV]AUTINV = 2
  #Read [PID] First
  #If !fstat
  #  Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #  mkstat = 2 : End
  #Endif
  #Filter [F:PID]

  Link [F:PID] With [F:PIH]PIH0 = [F:PID]NUM, [F:TPV]TPV0=[F:PIH]PIVTYP As [LNK]
& Where [F:PID]ITMREF = [L]ITM & find([F:PIH]CPY,DYN_ARRAY) & [F:PIH]ACCDAT >=[01/01/2012] & [F:TPV]AUTINV = 2
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif

  #Filter [F:PND] Where [F:PND]ITMREF = [L]ITM & find([F:PNH]CPY,DYN_ARRAY) & [F:PND]RTNDAT >=[01/01/2012]
  #Read [PND] First
  #If !fstat
  #  Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #  mkstat = 2 : End
  #Endif
  #Filter [F:PND]

  Link [F:PND] With [F:PNH]PNH0 = [F:PND]PNHNUM  As [LNK]
& Where [F:PND]ITMREF = [L]ITM & find([F:PNH]CPY,DYN_ARRAY) & [F:PND]RTNDAT  >=[01/01/2012]
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif
  Close File [LNK]
Endif

If GMODU(7) = 2
  #For [F:FCY] Where [F:FCY]FCY = [F:SGH]STOFCY
  #  If find([F:FCY]LEGCPY, DYN_ARRAY)
  #    Filter [F:SGD] Where [F:SGD]ITMREF = [L]ITM & [F:SGH]IPTDAT >=[01/01/2012] & find([F:SGH]BETFCYCOD,2,4,5)
  #    Read [SGD] First
  #    If !fstat
  #      Call MESSAGE (mess(124,7711,1)) From GESECRAN
  #      mkstat = 2 : End
  #    Endif
  #    Filter [F:SGD]
  #  Endif
  #Next

  Link [F:SGD] With [F:SGH]SGH0 = [F:SGD]VCRNUM, [F:FCY]FCY0=[F:SGH]STOFCY  As [LNK]
& Where [F:SGD]ITMREF = [L]ITM & find([F:FCY]LEGCPY, DYN_ARRAY) & [F:SGH]IPTDAT >=[01/01/2012] & find([F:SGH]BETFCYCOD,2,4,5)
  Read [LNK] First
  If !fstat
    Call MESSAGE (mess(124,7711,1)) From GESECRAN
    mkstat = 2 : End
  Endif
  Close File [LNK]
Endif

End
#97101 RICAR 2014/07/03 - 50001 Law decret - END
