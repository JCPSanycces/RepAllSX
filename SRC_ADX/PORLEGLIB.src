Subprog VALIDATE_CSHVATRGM_CRY(P_CRY)
Value Char P_CRY

If func AFNC.ACTIV("KPO")
  If [L]P_CRY = "PT"
    Actzo [M:BPC3]NBVAT
  Else
    Diszo [M:BPC3]NBVAT
  Endif
  Affzo [M:BPC3]NBVAT
Endif

End
