######################################################################################
$VERIF_SUBTVT_POR

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If find([M:TVT1]LEG,"POR","") & func AFNC.ACTIV("KPO")

  If [F:TVT]POREXEMOT = ""
    If find (2,[M:TVT1]VATEXEFLG(0.. [M:TVT1]NBRRAT))
      GMESSAGE = mess(139,7711,1) : GERR = 1 : OK = 0 : Return
    Else
      Call VERF_EXEVCL([M:TVT1]VAT)
    Endif
  Endif

Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

Return
######################################################################################
Subprog VERF_EXEVCL(P_VAT)
Variable Char P_VAT

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If !clalev([F:VCL])  Local File VATCLS   [VCL] : Endif

For [VCL] Where VAT = P_VAT
  If [F:VCL]TAXLEV = 4
    GMESSAGE = mess(139,7711,1) : GERR = 1 : OK = 0 : Break
  Endif
Next
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End
######################################################################################
######################################################################################
$VLD_CREDIT_NOTE_BIC

If [F:SIH]INVNUM = '' & ([F:SIH]PERDEB = [0/0/0] or [F:SIH]PERFIN = [0/0/0])

  If !clalev ([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
  If !clalev ([F:CPY]) : Local File COMPANY   [CPY] : Endif

  Local Integer STAT
  If dim(OK)<1 : Local Integer OK : OK = 1 : Endif

  If [F:CPY]CPY <> [F:SIH]CPY
    Read [F:CPY]CPY0 = [F:SIH]CPY
  Endif

  Call LEC_TSV_LEG([F:CPY]LEG, [F:SIH]SIVTYP, STAT) From TRTLECLEG

  If [F:CPY]LEG = "POR" & [F:TSV]RECTYP <> 4 & find([F:TSV]SAFTINVTYP,3,4) # Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
    #GMESSAGE = mess(148,7711,1)
    GMESSAGE = func AFNC.MES1(mess(148,7711,1),mess([F:TSV]SAFTINVTYP,2028,1))
    OK       = 0
    GERR     = 1
  Endif

Endif

Return
######################################################################################
######################################################################################
$VLD_CREDIT_NOTE_SIH

If [F:SIH]PERDEB = [0/0/0] or [F:SIH]PERFIN = [0/0/0]

  If clalev([F:SID1])= 0 : Local File SINVOICED [SID1] : Endif
  If clalev([F:CPY]) = 0 : Local File COMPANY   [CPY]  : Endif
  If clalev([F:TSV]) = 0 : Local File TABSIVTYP [TSV]  : Endif

  Local Integer STAT
  If dim(OK)<1 : Local Integer OK : OK = 1 : Endif

  If [F:CPY]CPY <> [F:SIH]CPY
    Read [F:CPY]CPY0 = [F:SIH]CPY
  Endif

  Call LEC_TSV_LEG([F:CPY]LEG, [F:SIH]SIVTYP, STAT) From TRTLECLEG

  If [F:CPY]LEG = "POR" & [F:TSV]RECTYP <> 4 & find([F:TSV]SAFTINVTYP,3,4) # Issue 115715 - 2016-04-05 by RICAR : POR Leg.: debit notes without reference period
    Filter [F:SID1] Where [F:SID1]NUM = [F:SIH]NUM & [F:SID1]SIHORINUM = ''
    Read [F:SID1] First
    If !fstat
      #GMESSAGE = mess(148,7711,1)
      GMESSAGE = func AFNC.MES1(mess(148,7711,1),mess([F:TSV]SAFTINVTYP,2028,1))
      OK       = 0
      GERR     = 1
    Endif
    Filter [F:SID1]
  Endif

Endif

Return
######################################################################################
######################################################################################
$READ_SIH_FIELDS

  If clalev([F:SIH]) = 0 : Local File SINVOICE [SIH] : Endif

  Read [F:SIH]SIH0 = [M:SIH0]NUM
  If !fstat
    [M:SIH1]PERDEB = [F:SIH]PERDEB
    [M:SIH1]PERFIN = [F:SIH]PERFIN
  Endif

Return
######################################################################################
######################################################################################
Subprog SHOW_HIDE_PERDEB_PERFIN(P_FCY,P_SIVTYP,P_MSK)
Value Char P_FCY
Value Char P_SIVTYP
Value Char P_MSK

Local Char    SHOWFIELD(1) : [L]SHOWFIELD = "-"

Local Integer STAT
If !clalev ([F:FCY]) : Local File FACILITY   [FCY] : Endif

If [F:FCY]FCY <> P_FCY
  Read [F:FCY]FCY0 = P_FCY
Endif

Call LEC_TSV_LEG([F:FCY]LEG, P_SIVTYP, STAT) From TRTLECLEG

If find([F:TSV]SAFTINVTYP,3,4)
  If func PORLEGLIB.DIGSIGN(P_FCY,"") : [L]SHOWFIELD = "" : Endif
Endif

Case P_MSK
  When "SIH1"
    Chgfmt [M:SIH1]PERDEB With [L]SHOWFIELD+"DZ:"+GFMDAT
    Chgfmt [M:SIH1]PERFIN With [L]SHOWFIELD+"DZ:"+GFMDAT
  When "BIC1"
    Chgfmt [M:BIC1]PERDEB With [L]SHOWFIELD+"DZ:"+GFMDAT
    Chgfmt [M:BIC1]PERFIN With [L]SHOWFIELD+"DZ:"+GFMDAT
Endcase

End
######################################################################################
# Issue 110705US5 - 2016-01-07 by BRBAN : Control document type after integrating a SVG
######################################################################################
Funprog CTLDOCTYP(TYPDOC,OBJET,WMESS)
Value Char TYPDOC
Value Char OBJET
Variable Char WMESS

Local Datetime WDATSVG

Local Integer RETVAL : RETVAL = 0

Case [L]OBJET
  When "PNH"

    #Verify the RECTYP
    Local File TABPNHTYP  [TPN]
    Call LEC_TPN_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TPN]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("PRETURN",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File PRETURN    [PNH]
    Filter [F:PNH] Where [F:PNH]PNHTYP=[L]TYPDOC & [L]WDATSVG>[F:PNH]CREDATTIM
    Read [F:PNH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:PNH]

  When "PIV"

    #Verify the RECTYP
    Local File  TABPIVTYP [TPV]
    Call LEC_TPV_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TPV]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("PINVOICE",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File  PINVOICE  [PIH]
    Filter [F:PIH] Where [F:PIH]PIVTYP=[L]TYPDOC & [L]WDATSVG>[F:PIH]CREDATTIM
    Read [F:PIH] First
    If !fstat
      [L]RETVAL = 1
    Endif
    Filter [F:PIH]

  When "SDH"

    #Verify the RECTYP
    Local File TABSDHTYP  [TSD]
    Call LEC_TSD_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TSD]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("SDELIVERY",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File SDELIVERY  [SDH]
    Filter [F:SDH] Where [F:SDH]SDHTYP=[L]TYPDOC & [L]WDATSVG>[F:SDH]CREDATTIM
    Read [F:SDH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:SDH]

  When "SGH"

    #Verify the RECTYP
    Local File  TABSGHTYP [TSG]
    Call LEC_TSG_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TSG]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("SCHGH",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File  SCHGH     [SGH]
    Filter [F:SGH] Where [F:SGH]SGHTYP=[L]TYPDOC & [L]WDATSVG>[F:SGH]CREDATTIM
    Read [F:SGH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:SGH]

  When "SIV"

    #Verify the RECTYP
    Local File  TABSIVTYP [TSV]
    Call LEC_TSV_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TSV]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("SINVOICE",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File  SINVOICE  [SIH]
    Filter [F:SIH] Where [F:SIH]SIVTYP=[L]TYPDOC & [L]WDATSVG>[F:SIH]CREDATTIM
    Read [F:SIH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:SIH]

  When "SRH"

    #Verify the RECTYP
    Local File  TABSRHTYP [TRE]
    Call LEC_TRE_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TRE]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("SRETURN",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File  SRETURN   [SRH]
    Filter [F:SRH] Where [F:SRH]SRHTYP=[L]TYPDOC & [L]WDATSVG>[F:SRH]CREDATTIM
    Read [F:SRH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:SRH]

  When "TNH"

    #Verify the RECTYP
    Local File TABTNHTYP  [TTN]
    Call LEC_TTN_LEG('POR',[L]TYPDOC,RETVAL) From TRTLECLEG
    If RETVAL <> 0 | [F:TTN]RECTYP<>3 : RETVAL = 0 : Goto END_CTLDOCTYP : Endif

    #Verify the last time a backup was integrated
    Call READ_BREN("TRANNOTEH",[L]WDATSVG)
    If [L]WDATSVG=gdatetime$("") : Goto END_CTLDOCTYP : Endif

    #Verify the date of the last document created
    Local File TRANNOTEH  [TNH]
    Filter [F:TNH] Where [F:TNH]TNHTYP=[L]TYPDOC & [L]WDATSVG>[F:TNH]CREDATTIM
    Read [F:TNH] First
    If !fstat
      [L]RETVAL  = 1
    Endif
    Filter [F:TNH]

Endcase

#Set error message
If [L]RETVAL = 1
  WMESS   = func AFNC.MES1(mess(197,7711,1), [L]TYPDOC)
Endif

$END_CTLDOCTYP
End RETVAL
######################################################################################
# Issue 110704 - 2016-01-08 by BRBAN : Verify the last time a backup was integrated
######################################################################################
Subprog READ_BREN(WTAB,WDAT)
Value Char    WTAB
Variable Datetime WDAT

Local Datetime TMPDAT
Local File BCKITOREN [BREN]

[L]WDAT = gdatetime$("")

Filter [F:BREN] Where [F:BREN]DOSSIER=nomap & [F:BREN]FICHIER=[L]WTAB Order By CREDATTIM Desc
Read [F:BREN] First
If !fstat
  If [F:BREN]CREDATTIM<>gdatetime$("")
    [L]WDAT = [F:BREN]CREDATTIM
  Endif
Endif
Filter [F:BREN]

End
