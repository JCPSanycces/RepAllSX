Subprog CTRL_STRUCT(MANDOC,WOK)
Value Char MANDOC
Variable Integer WOK
Local Char CTRL(30)

[L]CTRL =''
[L]WOK = 1

If instr(1,[L]MANDOC,"/") = 0
 [L]WOK=0
 End
Endif

[L]CTRL = right$([L]MANDOC, instr(1,[L]MANDOC,"/")+1)

For I=1 To len([L]CTRL)-1
  If !find(right$(left$([L]CTRL,I),I),"1","2","3","4","5","6","7","8","9","0")
    [L]WOK = 0
    End
  Endif
Next

End
