######################################################################################
Subprog MANDOC_TEXT_GT(RECTYP,SAFTTRNTYP,RET)
Value Integer RECTYP
Value Integer SAFTTRNTYP
Variable Char RET

Case [L]SAFTTRNTYP
  When 1 : [L]RET='GT'
  When 2 : [L]RET='GR'
  When 3 : [L]RET='GA'
  When 4 : [L]RET='GC'
  When 5 : [L]RET='GD'
Endcase

Case [L]RECTYP
  When 2 : [L]RET+='M'
  When 3 : [L]RET+='D'
Endcase
[L]RET+=' '
End
