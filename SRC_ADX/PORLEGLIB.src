# Issue X3-43209 by MRDAB
Funprog SEQNUMCORRECT(P_SALFCY, P_SEQNUM)
Value Char P_SALFCY, P_SEQNUM

Local Tinyint RETVAL : [L]RETVAL = 1

If func AFNC.ACTIV("KPO")>0 & func PORLEGLIB.PORLEG(P_SALFCY, "")= 1
  If func PORLEGLIB.ANM_OK(P_SEQNUM, GMESSAGE) <> 1
    If GMESSAGE <> ""
      [L]RETVAL = 0
    Endif
  Endif
Endif

End [L]RETVAL
# Issue End
######################################################################################
######################################################################################
Subprog IS_BPR_USED(P_BPR , P_BPRSTAT)
Value Char P_BPR
Variable Shortint P_BPRSTAT

If !clalev([F:LCM])  : Local File LASTCUSMVT [LCM]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:SIV])  : Local File SINVOICEV  [SIV]  : Endif

Link [LCM] With [F:CPY]CPY0 = [F:LCM]CPY  As [LNK]
&          Where [F:LCM]BPCNUM = P_BPR & find([F:LCM]IFFTYP,4 ,6 ,7 ,8 ,9 ,10) & [F:CPY]LEG = "POR"
For [LNK]
  P_BPRSTAT = 1 : Break
Next

If P_BPRSTAT = 1 : End : Endif

Link [SIV] With [F:CPY]CPY0 = [F:SIV]CPY  As [LNK]
&          Where [F:SIV]BPCINV = P_BPR & [F:SIV]INVTYP = 5 & [F:CPY]LEG = "POR"
For [LNK]
  P_BPRSTAT = 1 : Break
Next

End
######################################################################################
##Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
######################################################################################
Subprog CTL_CODNUM_NORMAL(SEQ_NUM,LEG,DOC_TYP,OBJ,WMESS)
Value Char SEQ_NUM
Value Char LEG
Value Char DOC_TYP
Value Char OBJ
Variable Char WMESS

If func AFNC.ACTIV("KPO") <= 0 | SEQ_NUM = '': End : Endif

Local File TABSDHTYP  [TSD2]
Local File TABSRHTYP  [TRE2]
Local File TABPNHTYP  [TPN2]
Local File TABSGHTYP  [TSG2]
Local File TABSIVTYP  [TSV3]
Local File TABPIVTYP  [TPV3]
Local File GTYPACCENT [GTE2]
Local File TABTNHTYP  [TTN2]

Local Char CTL_CRIT(100)(0..7)
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(0) = '([F:TSD2]LEG = "" | [F:TSD2]LEG = "POR")' : Else : CTL_CRIT(0) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(1) = '([F:TRE2]LEG = "" | [F:TRE2]LEG = "POR")' : Else : CTL_CRIT(1) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(2) = '([F:TPN2]LEG = "" | [F:TPN2]LEG = "POR")' : Else : CTL_CRIT(2) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(3) = '([F:TSG2]LEG = "" | [F:TSG2]LEG = "POR")' : Else : CTL_CRIT(3) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(4) = '([F:TSV3]LEG = "" | [F:TSV3]LEG = "POR")' : Else : CTL_CRIT(4) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(5) = '([F:TPV3]LEG = "" | [F:TPV3]LEG = "POR")' : Else : CTL_CRIT(5) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(6) = '([F:GTE2]LEG = "" | [F:GTE2]LEG = "POR")' : Else : CTL_CRIT(6) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(7) = '([F:TTN2]LEG = "" | [F:TTN2]LEG = "POR")' : Else : CTL_CRIT(7) = '1=1' : Endif

If OBJ = "TSD" :  CTL_CRIT(0) += ' & [F:TSD2]SDHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TRE" :  CTL_CRIT(1) += ' & [F:TRE2]SRHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TPN" :  CTL_CRIT(2) += ' & [F:TPN2]PNHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSG" :  CTL_CRIT(3) += ' & [F:TSG2]SGHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSV" :  CTL_CRIT(4) += ' & [F:TSV3]SIVTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TPV" :  CTL_CRIT(5) += ' & [F:TPV3]PIVTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "GTE" :  CTL_CRIT(6) += ' & [F:GTE2]TYP<>"'+DOC_TYP+'"'    : Endif
If OBJ = "TTN" :  CTL_CRIT(7) += ' & [F:TTN2]TNHTYP<>"'+DOC_TYP+'"' : Endif

#Check if normal counter is used as final counter on an existent delivery type
#GESTSD(delivery type) --> CODNUM  CODNUMFCY  CODNUMCPY  CODNUMEND  CODNUMFCYD  CODNUMCPYD
Filter [F:TSD2] Where find(SEQ_NUM,[F:TSD2]CODNUMEND,[F:TSD2]CODNUMFCYD,[F:TSD2]CODNUMCPYD) & evalue(CTL_CRIT(0))
Read [F:TSD2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSD2]SDHTYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:TSD2]

#Check if normal counter is used as final counter on an existent sales return type
#GESTRE(return type)   --> CODNUM  CODNUMFCY  CODNUMCPY  CODNUMEND  CODNUMFCYD  CODNUMCPYD
Filter [F:TRE2] Where find(SEQ_NUM,[F:TRE2]CODNUMEND,[F:TRE2]CODNUMFCYD,[F:TRE2]CODNUMCPYD) & evalue(CTL_CRIT(1))
Read [F:TRE2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TRE2]SRHTYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:TRE2]

#Check if normal counter is used as final counter on an existent purchase return
#GESTPN(return types)  --> CODNUM  CODNUMEND  CODNUMCPYD)
Filter [F:TPN2] Where find(SEQ_NUM,[F:TPN2]CODNUMEND,[F:TPN2]CODNUMFCYD,[F:TPN2]CODNUMCPYD) & evalue(CTL_CRIT(2))
Read [F:TPN2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TPN2]PNHTYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:TPN2]

#Check if normal counter is used as final counter on an existent stock type
#GESTSG(Stock change types)  -->  CODNUM  CODNUMEND
Filter [F:TSG2] Where find(SEQ_NUM,[F:TSG2]CODNUMEND) & evalue(CTL_CRIT(3))
Read [F:TSG2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSG2]SGHTYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:TSG2]

#Check if normal counter is used as final counter on an existent accounting document type
#GESGTE(Document types)  -->  COU
Filter [F:GTE2] Where find(SEQ_NUM,[F:GTE2]COU) & evalue(CTL_CRIT(6))
Read [F:GTE2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:GTE2]TYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:GTE2]

#Check if normal counter is used as final counter on an existent transportation note
#GESTTN(Transportation note types)  -->  CODNUM  CODNUMEND
Filter [F:TTN2] Where find(SEQ_NUM,[F:TTN2]CODNUMEND) & evalue(CTL_CRIT(7))
Read [F:TTN2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TTN2]TNHTYP) : Goto $END_CODNUM_NORMAL : Endif
Filter [F:TTN2]

##Entry type control
#If find(OBJ,"TSV","TPV")
#  Link [GTE2] With [F:TSV3]TSV0  = [F:GTE2]TYP;[F:GTE2]LEG As [LTSV]
#& Where   [F:TSV3]SIVTYP = DOC_TYP
#For[LTSV]
#  WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[LTSV]TYP) : Break
#Next
#If WMESS <> "" : Goto $END_CODNUM_NORMAL : Endif
#
#  Link [GTE2] With [F:TPV3]TPV0  = [F:GTE2]TYP;[F:GTE2]LEG As [LTSV]
#& Where   [F:TPV3]PIVTYP = DOC_TYP
#For[LTSV]
#  WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[LTSV]TYP) : Break
#Next
#Endif
#If WMESS <> "" : Goto $END_CODNUM_NORMAL : Endif

$END_CODNUM_NORMAL
Close File [TSD2],[TRE2],[TPN2],[TSG2],[TSV3],[TPV3],[GTE2],[TTN2]

End
######################################################################################
##Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
######################################################################################
Subprog CTL_CODNUM_FINAL(SEQ_NUM,LEG,DOC_TYP,OBJ,WMESS)
Value Char SEQ_NUM
Value Char LEG
Value Char DOC_TYP
Value Char OBJ
Variable Char WMESS

If func AFNC.ACTIV("KPO") <= 0 | SEQ_NUM = '': End : Endif

Local File TABSDHTYP  [TSD2]
Local File TABSRHTYP  [TRE2]
Local File TABPNHTYP  [TPN2]
Local File TABSGHTYP  [TSG2]
Local File TABSIVTYP  [TSV3]
Local File TABPIVTYP  [TPV3]
Local File GTYPACCENT [GTE2]
Local File TABTNHTYP  [TTN2]
Local File TABSQHTYP  [TSQ2]
Local File TABSOHTYP  [TSO2]

Local Char CTL_CRIT(100)(0..9)
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(0) = '([F:TSD2]LEG = "" | [F:TSD2]LEG = "POR")' : Else : CTL_CRIT(0) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(1) = '([F:TRE2]LEG = "" | [F:TRE2]LEG = "POR")' : Else : CTL_CRIT(1) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(2) = '([F:TPN2]LEG = "" | [F:TPN2]LEG = "POR")' : Else : CTL_CRIT(2) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(3) = '([F:TSG2]LEG = "" | [F:TSG2]LEG = "POR")' : Else : CTL_CRIT(3) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(4) = '([F:TSV3]LEG = "" | [F:TSV3]LEG = "POR")' : Else : CTL_CRIT(4) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(5) = '([F:TPV3]LEG = "" | [F:TPV3]LEG = "POR")' : Else : CTL_CRIT(5) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(6) = '([F:GTE2]LEG = "" | [F:GTE2]LEG = "POR")' : Else : CTL_CRIT(6) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(7) = '([F:TTN2]LEG = "" | [F:TTN2]LEG = "POR")' : Else : CTL_CRIT(7) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(8) = '([F:TSQ2]LEG = "" | [F:TSQ2]LEG = "POR")' : Else : CTL_CRIT(8) = '1=1' : Endif
If [L]LEG <> "" & [L]LEG <> "POR" : CTL_CRIT(9) = '([F:TSO2]LEG = "" | [F:TSO2]LEG = "POR")' : Else : CTL_CRIT(9) = '1=1' : Endif

If OBJ = "TSD" :  CTL_CRIT(0) += ' & [F:TSD2]SDHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TRE" :  CTL_CRIT(1) += ' & [F:TRE2]SRHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TPN" :  CTL_CRIT(2) += ' & [F:TPN2]PNHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSG" :  CTL_CRIT(3) += ' & [F:TSG2]SGHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSV" :  CTL_CRIT(4) += ' & [F:TSV3]SIVTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TPV" :  CTL_CRIT(5) += ' & [F:TPV3]PIVTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "GTE" :  CTL_CRIT(6) += ' & [F:GTE2]TYP<>"'+DOC_TYP+'"'    : Endif
If OBJ = "TTN" :  CTL_CRIT(7) += ' & [F:TTN2]TNHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSQ" :  CTL_CRIT(8) += ' & [F:TSQ2]SQHTYP<>"'+DOC_TYP+'"' : Endif
If OBJ = "TSO" :  CTL_CRIT(9) += ' & [F:TSO2]SOHTYP<>"'+DOC_TYP+'"' : Endif

#Check if final counter is used as normal or final counter on an existent delivery type
#GESTSD(delivery type) --> CODNUM  CODNUMFCY  CODNUMCPY  CODNUMEND  CODNUMFCYD  CODNUMCPYD
Filter [F:TSD2] Where find(SEQ_NUM,[F:TSD2]CODNUM,[F:TSD2]CODNUMFCY, [F:TSD2]CODNUMCPY,[F:TSD2]CODNUMEND,[F:TSD2]CODNUMFCYD,[F:TSD2]CODNUMCPYD) & evalue(CTL_CRIT(0))
Read [F:TSD2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSD2]SDHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TSD2]

#Check if final counter is used as normal or final counter on an existent sales return type
#GESTRE(return type)   --> CODNUM  CODNUMFCY  CODNUMCPY  CODNUMEND  CODNUMFCYD  CODNUMCPYD
Filter [F:TRE2] Where find(SEQ_NUM,[F:TRE2]CODNUM,[F:TRE2]CODNUMFCY, [F:TRE2]CODNUMCPY,[F:TRE2]CODNUMEND,[F:TRE2]CODNUMFCYD,[F:TRE2]CODNUMCPYD) & evalue(CTL_CRIT(1))
Read [F:TRE2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TRE2]SRHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TRE2]

#Check if final counter is used as normal or final counter on an existent purchase return type
#GESTPN(return types)  --> CODNUM  CODNUMFCY  CODNUMCPY  CODNUMEND  CODNUMFCYD  CODNUMCPYD
Filter [F:TPN2] Where find(SEQ_NUM,[F:TPN2]CODNUM,[F:TPN2]CODNUMFCY, [F:TPN2]CODNUMCPY,[F:TPN2]CODNUMEND,[F:TPN2]CODNUMFCYD,[F:TPN2]CODNUMCPYD) & evalue(CTL_CRIT(2))
Read [F:TPN2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TPN2]PNHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TPN2]

#Check if final counter is used as normal or final counter on an existent stock type
#GESTSG(Stock change types)  -->  CODNUM  CODNUMEND
Filter [F:TSG2] Where find(SEQ_NUM,[F:TSG2]CODNUM,[F:TSG2]CODNUMEND) & evalue(CTL_CRIT(3))
Read [F:TSG2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSG2]SGHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TSG2]

If !find(OBJ,"TSV","TPV")
  #Check if final counter is used as normal or final counter on an existent accounting document type
  #GESGTE(Document types)  -->  COU
  Filter [F:GTE2] Where find(SEQ_NUM,[F:GTE2]COU) & evalue(CTL_CRIT(6))
  Read [F:GTE2] First
  If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:GTE2]TYP) : Goto $END_CODNUM_FINAL : Endif
  Filter [F:GTE2]
Endif

#Entry type control
If find(OBJ,"TSV","TPV")

  #GESTSV(invoice type)  -->  CODNUM
  Filter [F:TSV3] Where find(SEQ_NUM,[F:TSV3]GTE) & evalue(CTL_CRIT(4))
  Read [F:TSV3] First
  If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSV3]SIVTYP) : Goto $END_CODNUM_FINAL : Endif
  Filter [F:TSV3]

  #GESTPV(invoice type)  -->  CODNUM
  Filter [F:TPV3] Where find(SEQ_NUM,[F:TPV3]GTE) & evalue(CTL_CRIT(5))
  Read [F:TPV3] First
  If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TPV3]PIVTYP) : Goto $END_CODNUM_FINAL : Endif
  Filter [F:TPV3]

Endif

#Check if final counter is used as normal or final counter on an existent transportation note
#GESTTN(Transportation note types)  -->  CODNUM  CODNUMEND
Filter [F:TTN2] Where find(SEQ_NUM,[F:TTN2]CODNUM,[F:TTN2]CODNUMEND) & evalue(CTL_CRIT(7))
Read [F:TTN2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TTN2]TNHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TTN2]

#Check if normal counter is used as final counter on an existent quote type
#GESSQH(Quote type)  -->  CODNUM
Filter [F:TSQ2] Where find(SEQ_NUM,[F:TSQ2]CODNUM) & evalue(CTL_CRIT(8))
Read [F:TSQ2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSQ2]SQHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TSQ2]

#Check if normal counter is used as final counter on an existent order type
#GESSOH(Order type)  -->  CODNUM
Filter [F:TSO2] Where find(SEQ_NUM,[F:TSO2]CODNUM) & evalue(CTL_CRIT(9))
Read [F:TSO2] First
If !fstat : WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[F:TSO2]SOHTYP) : Goto $END_CODNUM_FINAL : Endif
Filter [F:TSO2]

#  Link [GTE2] With [F:TSV3]TSV0  = [F:GTE2]TYP;[F:GTE2]LEG As [LTSV]
#& Where   [F:TSV3]SIVTYP = DOC_TYP & evalue(CTL_CRIT(5))
#For[LTSV]
#  WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[LTSV]COU) : Break
#Next
#If WMESS <> "" : Goto $END_CODNUM_FINAL : Endif
#
#  Link [GTE2] With [F:TPV3]TPV0  = [F:GTE2]TYP;[F:GTE2]LEG As [LTSV]
#& Where   [F:TPV3]PIVTYP = DOC_TYP & evalue(CTL_CRIT(5))
#For[LTSV]
#  WMESS = func AFNC.MES2(mess(129,7711,1),SEQ_NUM,[LTSV]COU) : Break
#Next

$END_CODNUM_FINAL
Close File [TSD2],[TRE2],[TPN2],[TSG2],[TSV3],[TPV3],[GTE2],[TTN2],[TSQ2],[TSO2]

End
######################################################################################
##Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
######################################################################################
Subprog CTL_CODNUM_LEG(LEG,DOCTYP_LEG,OBJ,WMESS)
Value Char LEG
Value Char DOCTYP_LEG
Value Char OBJ
Variable Char WMESS

Local Char FIELD_ID(GLONAVA)(0..5)
Local Integer ID
Local Char    LABRECR(GLONABR)

FIELD_ID(0) = "CODNUM"
FIELD_ID(1) = "CODNUMEND"
FIELD_ID(2) = "CODNUMFCY"
FIELD_ID(3) = "CODNUMFCYD"
FIELD_ID(4) = "CODNUMCPY"
FIELD_ID(5) = "CODNUMCPYD"

Case OBJ
  When "TSD"
    [L]LABRECR ="TSD1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    For [L]ID = 0 To dim(FIELD_ID)-1
      If find(FIELD_ID([L]ID),"CODNUM","CODNUMFCY","CODNUMCPY")
        Call CTL_CODNUM_NORMAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)    From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
      If find(FIELD_ID([L]ID),"CODNUMEND","CODNUMFCYD","CODNUMCPYD")
        Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)  From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
    Next
  When "TRE"
    [L]LABRECR ="TRE1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    For [L]ID = 0 To dim(FIELD_ID)-1
      If find(FIELD_ID([L]ID),"CODNUM","CODNUMFCY","CODNUMCPY")
        Call CTL_CODNUM_NORMAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)    From PORLEGLIB
         If WMESS<>"" : Break : Endif
      Endif
      If find(FIELD_ID([L]ID),"CODNUMEND","CODNUMFCYD","CODNUMCPYD")
        Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)  From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
    Next
  When "TPN"
    [L]LABRECR ="TPN1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    For [L]ID = 0 To dim(FIELD_ID)-1
      If find(FIELD_ID([L]ID),"CODNUM","CODNUMFCY","CODNUMCPY")
        Call CTL_CODNUM_NORMAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)    From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
      If find(FIELD_ID([L]ID),"CODNUMEND","CODNUMFCYD","CODNUMCPYD")
        Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)  From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
    Next
  When "TSG"
    [L]LABRECR ="TSG1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    For [L]ID = 0 To dim(FIELD_ID)-1
      If find(FIELD_ID([L]ID),"CODNUM")
        Call CTL_CODNUM_NORMAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)    From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
      If find(FIELD_ID([L]ID),"CODNUMEND")
        Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID([L]ID)),LEG,[L]DOCTYP_LEG,OBJ,WMESS)  From PORLEGLIB
        If WMESS<>"" : Break : Endif
      Endif
    Next
  When "GTE"
    [L]LABRECR ="GTE1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    Call CTL_CODNUM_FINAL([M:GTE1]COU,LEG,[L]DOCTYP_LEG,OBJ,WMESS) From PORLEGLIB
  When "TSV"
    [L]LABRECR ="TSV1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    Call CTL_CODNUM_FINAL([M:TSV1]GTE,LEG,[L]DOCTYP_LEG,OBJ,WMESS) From PORLEGLIB
  When "TPV"
    [L]LABRECR ="TPV1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    Call CTL_CODNUM_FINAL([M:TPV1]GTE,LEG,[L]DOCTYP_LEG,OBJ,WMESS) From PORLEGLIB
  When "TSQ"
    [L]LABRECR ="TSQ1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID(0)),LEG,[L]DOCTYP_LEG,OBJ,WMESS) From PORLEGLIB
  When "TSO"
    [L]LABRECR ="TSO1"
    If evalue("[M:"+LABRECR+"]LEG") = LEG : End : Endif
    Call CTL_CODNUM_FINAL(evalue("[M:"+LABRECR+"]"+FIELD_ID(0)),LEG,[L]DOCTYP_LEG,OBJ,WMESS) From PORLEGLIB
Endcase

End
######################################################################################
## Issue X3-101174 - by MRDAB : 122007 - Datetime handling for e.g. usage of
##                                      UPDDATTIM or CREDATTIM
######################################################################################
## TRANSFORM_TO_LOCAL_TIME - transforms the datetime passed from datetime like
##                           UPDDATTIM or CREDATTIM into local server time
## P_DATETIME (Datetime) - UTC datetime to be converted into local time
######################################################################################
Funprog TRANSFORM_TO_LOCAL_TIME(P_DATETIME)
  Value Datetime P_DATETIME

  Local Datetime LOCAL_DATETIME, UTC_DATETIME, CONVERTED_DATETIME
  Local Char COMP(1)
  Local Integer STA, OFFSET
  Local Integer LDD, LMM, LYYYY, LHH, LMIN, LSS
  Local Integer UDD, UMM, UYYYY, UHH, UMIN, USS
  Local Integer PDD, PMM, PYYYY, PHH, PMIN, PSS
  Local Tinyint DAY_CHANGE, LOCAL_IN_DST, P_DATETIME_IN_DST

  # get local server and UTC times for OFFSET calculation
  [L]LOCAL_DATETIME = gdatetime$(num$(format$("D:YYYY[-]MM[-]DD[T]",date$)) + time$ + "Z")
  [L]UTC_DATETIME = datetime$

  # Decompose dates
  [L]STA = func TIMEZONE_CSTD.CONVERT_FROM_DATETIME(P_DATETIME, [L]PDD, [L]PMM, [L]PYYYY, [L]PHH, [L]PMIN, [L]PSS)
  [L]STA = func TIMEZONE_CSTD.CONVERT_FROM_DATETIME([L]LOCAL_DATETIME, [L]LDD, [L]LMM, [L]LYYYY, [L]LHH, [L]LMIN, [L]LSS)
  [L]STA = func TIMEZONE_CSTD.CONVERT_FROM_DATETIME([L]UTC_DATETIME, [L]UDD, [L]UMM, [L]UYYYY, [L]UHH, [L]UMIN, [L]USS)

  # Check if local server datetime and datetime to be transformed are in Daylight Saving Time (DST) or not
  [L]LOCAL_IN_DST = func PORLEGLIB.DAYLIGHT_SAVING_TIME_POR([L]LDD, [L]LMM, [L]LOCAL_DATETIME)
  [L]P_DATETIME_IN_DST = func PORLEGLIB.DAYLIGHT_SAVING_TIME_POR([L]PDD, [L]PMM, P_DATETIME)

  #  Check if offset calculation needed
  If format$("D:YYYY[-]MM[-]DD[T]hh", [L]LOCAL_DATETIME) <> format$("D:YYYY[-]MM[-]DD[T]hh", [L]UTC_DATETIME)

    # Recognize if the time shift is positive or negative
    If [L]LOCAL_DATETIME > [L]UTC_DATETIME
      [L]COMP = '+'
    Else
      [L]COMP = '-'
    Endif

    # Recognize the change of the day
    If gdat$([L]LOCAL_DATETIME) <> gdat$([L]UTC_DATETIME)
      [L]DAY_CHANGE = 1
    Else
      [L]DAY_CHANGE = 0
    Endif

    #calculate offset
    [L]OFFSET = func PORLEGLIB.CALCULATE_OFFSET([L]COMP, [L]DAY_CHANGE, [L]LHH, [L]UHH)

    # Convert datetime to local server time
    [L]CONVERTED_DATETIME = func TIMEZONE_CSTD.ADD_OFFSET(P_DATETIME, evalue([L]COMP + num$([L]OFFSET)))

  Else
    # No difference between local server time and UTC time so UTC time is local server time
    [L]CONVERTED_DATETIME = P_DATETIME
  Endif

  # check if daylight time saving needed to be considered
  If [L]LOCAL_IN_DST <> [L]P_DATETIME_IN_DST
    If [L]LOCAL_IN_DST
      [L]CONVERTED_DATETIME = func TIMEZONE_CSTD.ADD_OFFSET([L]CONVERTED_DATETIME, -1)
    Else
      [L]CONVERTED_DATETIME = func TIMEZONE_CSTD.ADD_OFFSET([L]CONVERTED_DATETIME, +1)
    Endif
  Endif

End [L]CONVERTED_DATETIME
######################################################################################
## CALCULATE_OFFSET - calculates offset between local server time and UTC time
## P_SIGN (Char) - Sign of the offset
## P_DAY_CHANGE (tinyint) - flag informing if current local server date is the same
##                          as UTC date
## P_LOCAL_HOUR - current local server time hour
## P_UTC_HOUR - current UTC time hour
######################################################################################
Funprog CALCULATE_OFFSET(P_SIGN, P_DAY_CHANGE, P_LOCAL_HOUR, P_UTC_HOUR)
  Value Char P_SIGN
  Value Tinyint P_DAY_CHANGE
  Value Integer P_LOCAL_HOUR
  Value Integer P_UTC_HOUR

  Local Integer OFFSET

  If !P_DAY_CHANGE
    [L]OFFSET = abs(P_LOCAL_HOUR - P_UTC_HOUR)
  Else
    If P_SIGN = "+"
      [L]OFFSET = abs(P_LOCAL_HOUR -(24 - P_UTC_HOUR))
    Else
      [L]OFFSET = abs(P_UTC_HOUR - (24 - P_LOCAL_HOUR))
    Endif
  Endif

End [L]OFFSET
######################################################################################
## DAYLIGHT_SAVING_TIME - check if the given datetime is in Daylight Saving Time
## P_DAY (Char) - day number in the month
## P_MONTH (tinyint) - month number in the year
## P_DATETIME - datetime to be checked
######################################################################################
Funprog DAYLIGHT_SAVING_TIME_POR(P_DAY, P_MONTH, P_DATETIME)
  Value Integer P_DAY
  Value Integer P_MONTH
  Value Datetime P_DATETIME

  Local Integer DAY_OF_WEEK, IS_DST

  [L]DAY_OF_WEEK = dayn(P_DATETIME)

  If P_MONTH < 3 or P_MONTH > 10
    [L]IS_DST = 0
  Elsif P_MONTH > 3 and P_MONTH < 10
    [L]IS_DST = 1
  Elsif P_MONTH = 3
    [L]IS_DST = P_DAY - mod([L]DAY_OF_WEEK, 7) >= 25
  Elsif P_MONTH = 10
    [L]IS_DST = P_DAY - mod([L]DAY_OF_WEEK, 7) < 25
  Endif

End [L]IS_DST
######################################################################################
## Issue end X3-101174
######################################################################################

