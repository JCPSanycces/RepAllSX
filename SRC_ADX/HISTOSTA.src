#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"  : Gosub OUVRE
 When "HISTO"  : Gosub HISTO
 When "EPURE"  : Gosub EPURE
 When "FERME"  : Gosub FERME
Endcase
Return

$OUVRE
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
Local Char    CODMAJ(10) , LIBEL(80)
Local Date    DATRAZ
Return

$HISTO
If [F:F1]COD<>CODMAJ
 Filter [PS2] Where UPDCOD=[F:F1]COD
 Read [PS2]PS20 First : # on prend le premier arbitrairement
 Filter [PS2]
 If !fstat
  CODMAJ = [F:F1]COD
  DATRAZ = eomonth(addmonth(datesyst,-[F:PS2]TIM-1))
  Call LECTEXTRA(LIBEL,"PARSTA2","INTIT",[F:PS2]COD,"") From ATEXTRA
  Call ECR_TRACE(CODMAJ+":"-LIBEL-"DAT<"-format$(GFMD,DATRAZ),0) From GESECRAN
 Else
  Return
 Endif
Endif
If [F:F1]DAT>=DATRAZ
 [L]OKHIS=0
Endif
If [L]OKHIS
 Case [F:PS2]UPDLEV  
  When 2,3 : # Société, site
   If [L]SOCIETE<>"" & [F:F1]CPY<>[L]SOCIETE
    [L]OKHIS = 0
   Endif
 Endcase
Endif
Return

$EPURE
If [F:F1]COD<>CODMAJ
 Filter [PS2] Where UPDCOD=[F:F1]COD
 Read [PS2]PS20 First : # on prend le premier arbitrairement
 Filter [PS2]
 If !fstat
  CODMAJ = [F:F1]COD
  DATRAZ = eomonth(addmonth(datesyst,-[F:PS2]TIM-1))
  Call LECTEXTRA(LIBEL,"PARSTA2","INTIT",[F:PS2]COD,"") From ATEXTRA
  Call ECR_TRACE(CODMAJ+":"-LIBEL-"DAT<"-format$(GFMD,DATRAZ),0) From GESECRAN
 Else
  Return
 Endif
Endif
If [F:F1]DAT>=DATRAZ
 [L]OKEPU=0
Endif
If [L]OKEPU
 Case [F:PS2]UPDLEV  
  When 2,3 : # Société, site
   If [L]SOCIETE<>"" & [F:F1]CPY<>[L]SOCIETE
    [L]OKEPU = 0
   Endif
 Endcase
Endif
Return

$FERME
Close Local File [PS2]
Return
