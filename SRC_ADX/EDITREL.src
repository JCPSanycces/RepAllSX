#<AdxTL>@(#)4.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char       PARAM(30)

# Recalcul du champs [SOI]TPYPAYCUR soit
# à partir des échéances relevés si le relevé n'est pas comptabilisé
# à partir des échéances de la pièce comptable s'il est comptabilisé 

Local File       SOI [SOI], FACGROUP [FGR]
&        ,       GACCDUDATE [DUD1] Where SOINUM<>"" Order By Key SOINUM = SOINUM
&        ,       GACCDUDATE [DUD2] Where NUM<>""    Order By Key NUM = NUM

Local Char       SOCIETE(GLONCPY), SITEDEB(GLONFCY), SITEFIN(GLONFCY), X3SIT1(10), X3SIT2(10)
Local Char       RELDEB(GLONVCR), RELFIN(GLONVCR), COLDEB(GLONSAC), COLFIN(GLONSAC), DEVISE(GLONCUR)
Local Date       DATDEB, DATFIN
Local Char       CRITERE(250)

Call GETPARAM("societe",NBPAR,PARAMETRE,SOCIETE) From ETAT
Call GETPARAM("sitedeb",NBPAR,PARAMETRE,SITEDEB) From ETAT
Call GETPARAM("sitefin",NBPAR,PARAMETRE,SITEFIN) From ETAT
Call GETPARAM("reldeb",NBPAR,PARAMETRE,RELDEB) From ETAT
Call GETPARAM("relfin",NBPAR,PARAMETRE,RELFIN) From ETAT
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) From ETAT : DATDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) From ETAT : DATFIN = PARAM
Call GETPARAM("devise",NBPAR,PARAMETRE,DEVISE) From ETAT
Call GETPARAM("coldeb",NBPAR,PARAMETRE,COLDEB) From ETAT
Call GETPARAM("colfin",NBPAR,PARAMETRE,COLFIN) From ETAT
Call GETPARAM("X3SIT1",NBPAR,PARAMETRE,X3SIT1) From ETAT
Call GETPARAM("X3SIT2",NBPAR,PARAMETRE,X3SIT2) From ETAT

CRITERE  = "FCY>='"+SITEDEB+"' & FCY<='"+SITEFIN+"'"
CRITERE += " & SOINUM>='"+RELDEB+"' & SOINUM<='"+RELFIN+"'"
If DATDEB<>[0/0/0]
 CRITERE += " & SOIDAT>=["+format$(GFMD,DATDEB)+"]"
Endif
If DATFIN<>[0/0/0]
 CRITERE += " & SOIDAT<=["+format$(GFMD,DATFIN)+"]"
Endif
CRITERE += " & pat(FCY,'"+X3SIT1+"') & FCY<>'"+X3SIT2+"'"
If DEVISE<>""
 CRITERE  += " & CUR='"+SOCIETE+"'"
Endif
CRITERE += " & SAC>='"+COLDEB+"' & SAC<='"+COLFIN+"'"

Call DEBTRANS From GLOCK
Gosub TR1
End

$TR1
GOK = 1
Trbegin [SOI]
 For [SOI]SOI0 Where evalue(CRITERE)
  Look [FGR]FGR0 = SOCIETE ; [F:SOI]FCY
  If !fstat
   Raz [F:SOI]TPYPAYCUR
   If [F:SOI]FLGPST=2 : # Comptabilisé
    For [DUD2]NUM Where NUM=[F:SOI]NUMSOI
     [F:SOI]TPYPAYCUR += ([F:DUD2]PAYCUR + [F:DUD2]TMPCUR) * [F:DUD2]SNS
    Next 
   Else
    For [DUD1]SOINUM Where SOINUM=[F:SOI]SOINUM
     [F:SOI]TPYPAYCUR += ([F:DUD1]PAYCUR + [F:DUD1]TMPCUR) * [F:DUD1]SNS
    Next
   Endif
   Rewrite [SOI]
   If fstat=1 
    GOK=-1 : GLOCK="$SOI" : Break 
   Elsif fstat
    GOK=0 : Call FSTA("SOI") From GLOCK : Break
   Endif
  Endif
 Next 
If GOK=0     : Goto AB_TR1
Elsif GOK=-1 : Goto ROLL_TR1
Endif
Commit
Return

$AB_TR1 
Rollback 
Return 
 
$ROLL_TR1 
Rollback 
Call ROLL From GLOCK 
If GROLL : Return : Else : Goto TR1 : Endif 
