#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################
## Subprog SELFIC(FICHIER)
## Subprog SELVAR(FICHIER,ABREV,VARIA)
## Subprog SELFICDOS(DOSSIER,FICHIER)
## Subprog SELVARDOS(DOSSIER,FICHIER,ABREV,VARIA)
## Subprog C_FICHIER(FICHIER)
######################################################
# Issue 108342 - 2015-11-06 by MAE : passage de 3 à 8
Local Char FICHIER(12),ABREV(GLONABR),VARIA(15)
#Local Char FICHIER(12),ABREV(5),VARIA(15)
Call SELVAR(FICHIER,ABREV,VARIA)
End

############################################
Subprog SELFIC(FICHIER)
############################################
Variable Char FICHIER
Call SELECT("ATB","",FICHIER,"") From SELOBJ
End

############################################
Subprog SELFICDOS(DOSSIER,FICHIER)
############################################
Value Char DOSSIER()
Variable Char FICHIER()
Local File =DOSSIER+".ATABLE" [ATB]
Call SELECT("ATB","",FICHIER,"") From SELOBJ
End

############################################
Subprog C_FICHIER(FICHIER)
############################################
Variable Char FICHIER
Local Integer OK
Call CONTROLE("ATB","",FICHIER,"",mkstat) From CONTOBJ
End

####################################################
Subprog SELVAR(FICHIER,ABREV,VARIA)
####################################################
Variable Char FICHIER()
Variable Char ABREV()
Variable Char VARIA()
Onerrgo ERREUR From CONTROLE
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
Goto SELV

####################################################
Subprog SELVARDOS(DOSSIER,FICHIER,ABREV,VARIA)
########################################################
Value Char    DOSSIER()
Variable Char FICHIER()
Variable Char ABREV()
Variable Char VARIA()
Onerrgo ERREUR From CONTROLE
Local File =DOSSIER+".ATABLE" [ATB], =DOSSIER+".ATABZON" [ATZ]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

$SELV
Call SAVBOUT From GESECRAN
Onerrgo ERREUR From CONTROLE
Local Mask SELVAR [SVAR]
Local Mesbox Mask [SVAR]
& Button mess(64,123,1),mess(65,123,1)
& With left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
& Coded GSTAOK , GSTAFIN
& Titled mess(109,124,1)
& As [SVAR]
# Choix d'un champ
Onerrgo
If GERREUR : GERREUR=0 : End : Endif
# Issue 108342 - 2015-11-06 by MAE : passage de 3 à 8
#Local Char    ABFIC(5)
Local Char    ABFIC(GLONABR)
Local Integer ETABOU(1..GNBBOU) , REPONSE
Local Integer SAVGOBJET

SAVGOBJET = GOBJET
GOBJET = 0
Boxact [SVAR]

Raz ETABOU
ETABOU(GABAN) = 1
ETABOU(GVALI) = 1
Call SETBOUT(ETABOU) From GESECRAN
Raz [M]
If FICHIER<>""
 [M]FICHIER = FICHIER
 Affzo FICHIER
 Gosub REMPLIT
 Grizo FICHIER
 [M]LIGNE = find(VARIA,[M]CODZONE(0..[M]NBLIG-1))
 If ![M]LIGNE : [M]LIGNE=1 : Endif
 zonsui = "NBLIG("+num$([M]LIGNE-1)+")"
Endif
pcolor = GCOUL(0)

$SAIFIC
Boxinp [SVAR] Using REPONSE
Case REPONSE
 When GSTARET
  Goto SAIFIC
 When GSTAOK
  FICHIER = [M]FICHIER
  ABREV   = [M]ABFIC
  VARIA   = [M]CODZONE([M]LIGNE-1)
 When GSTAESC, GSTAFIN : mkstat=2
Endcase
Call RESTBOUT From GESECRAN
Boxclr [SVAR]
GOBJET = SAVGOBJET
End

$REMPLIT
Read [ATB]CODFIC = [M]FICHIER
[M]ABFIC = [F:ATB]ABRFIC
Call TEXTE([F:ATB]INTITFIC,[M]INTIT) From OBJDIV
nolign = 0
For [ATZ]NUMLIG Where CODFIC=[M]FICHIER
 nolign += 1
 [M] = [F:ATZ]
 Call TEXTE([M]NOCOURT(nolign-1),[M]INTITZONE(nolign-1)) From OBJDIV
Next
[M]NBLIG = nolign
pcolor = GCOUL(0)
Affzo INTIT,30
Return

Subprog AM_FICHIER(VALEUR)
Variable Char VALEUR()  # FGR 01/02/2010 : X3SUIVI60986 : pas FICHIER()
[M]FICHIER = VALEUR
Gosub REMPLIT
[M]LIGNE = 0
End

Subprog AV_NBLIG
If status=71 or status=1
 Local Integer NOL
 NOL = min(nolign,[M]NBLIG)
 If [M]LIGNE<>0
  [M]LIGNE -= 1
  pcolor = GCOUL(0) : # Noir
  Affzo CODZONE([M]LIGNE) , INTITZONE([M]LIGNE)
 Endif
 pcolor = GCOUL(1) : # Rouge
 Affzo CODZONE(NOL-1) , INTITZONE(NOL-1)
 [M]LIGNE = NOL
Endif
End

