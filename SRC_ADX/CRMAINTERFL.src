#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# MODULE CRM/HDK gestion des interactions avec les agendas mars 2007
##########################################################################################################
##########################################################################################################
Subprog CRMLINK (FONCTION,OBJET,PARAM)
Value Char FONCTION  #  FONCTION :  Nom de la fonction à appeler
Value Char OBJET     #  OBJET    :  Code de l'objet
Value Char PARAM     #  PARAM    :  Paramètres à passer (clé objet par exemple)

Local Char CLE1(30), CLE2(30)
Local Integer I
Local Char SZOBJET(GLONAOB)
Local Char SZMASKCOURANT(GLONABR)
Local Char SZABRMSKCOURANT(GLONABR)
Local Integer TROUVE  # FGR 12/07/2010 : X3SUIVI65841
Local Integer NLIGNE  # FGR 12/07/2010 : X3SUIVI65841
Local Integer NIDX    # FGR 12/07/2010 : X3SUIVI65841

  If !clalev([F:AMK]) : Local File AMSK [AMK] : Endif
  Raz SZOBJET
  Raz SZABRMSKCOURANT
  SZMASKCOURANT = maskcou
  If SZMASKCOURANT = "" Then
    If GFONCTION = "FUNCRMAGD" Then
      SZMASKCOURANT = "CRMAGD1"
    Elsif GFONCTION = "FUNHDKAGD" Then
      SZMASKCOURANT="HDKAGD2"
    Endif
  Endif
  Read [AMK]CODMSK=SZMASKCOURANT
  If fstat = 0 Then
    SZABRMSKCOURANT = ABRMSK
  Endif
  If PARAM <> "" Then
    I = instr(1,PARAM,"~")
    If I <> 0 Then
      CLE1 = left$(PARAM,I-1)
      CLE2 = right$(PARAM,I+1)
    Else
      CLE1 = PARAM
      CLE2 = ""
    Endif
  Endif
  #--------------------------------------
  # FGR 12/07/2010 : X3SUIVI65841 (début)
  # * Provisoire en attendant correction sur le flash (cf. commentaire dans ficher 65841 et 65960
  If GFONCTION = "FUNCRMAGD" Then
    NLIGNE = 0
    TROUVE = 0
    NIDX = 0
    While TROUVE = 0
      NLIGNE = find(CLE1, [M:CRM1]KEYACT(NLIGNE..[M:CRM1]NBLIGAGD-1))
      If NLIGNE <> 0 Then
        If [M:CRM1]OBJ(NLIGNE+NIDX-1) = OBJET Then
          TROUVE = 1
        Else
          NIDX += NLIGNE
          NLIGNE += 1
        Endif
      Else
        Break
      Endif
    Wend
    If TROUVE Then
      [M:CRM0]CRMCMP = [M:CRM1]BPR(NLIGNE+NIDX-1)
      [M:CRM0]CRMCCN = [M:CRM1]CCN(NLIGNE+NIDX-1)
    Else
      # Cas très improbable ici !
      Raz [M:CRM0]CRMCMP
      Raz [M:CRM0]CRMCCN
    Endif
  Elsif GFONCTION = "FUNHDKAGD" Then
    NLIGNE = 0
    TROUVE = 0
    NIDX = 0
    While TROUVE = 0
      #NLIGNE = find(CLE1, [M:HDK2]ITNNUM(NLIGNE..[M:HDK2]NBLIGAGD-1))
      NLIGNE = find(CLE1, [M:HDK2]ITNNUM(NLIGNE..[M:HDK2]NBLIGITN-1))   # FGR 23/08/2010 : X3SUIVI66826
      If NLIGNE <> 0 Then
        #If [M:HDK2]OBJET(NLIGNE+NIDX-1) = OBJET Then      # FGR 07/10/2015 : X3SUIVI111561 : L'agenda est cablé en dur.
        If [M:HDK2]OBJET(NLIGNE+NIDX-1) = "ITN" Then       # FGR 07/10/2015 : X3SUIVI111561 : Pour le support client on utilise TSK pour ITN
          TROUVE = 1
        Else
          NIDX += NLIGNE
          NLIGNE += 1
        Endif
      Else
        Break
      Endif
    Wend
    If TROUVE Then
      [M:HDK0]HDKSRE = [M:HDK2]SRENUM(NLIGNE+NIDX-1)
      [M:HDK0]HDKSALFCY = [M:HDK2]SALFCY(NLIGNE+NIDX-1)
      [M:HDK0]HDKBPR = [M:HDK2]BPC(NLIGNE+NIDX-1)
      [M:HDK0]HDKCCN = [M:HDK2]CCN(NLIGNE+NIDX-1)
    Else
      # Cas très improbable ici !
      Raz [M:HDK0]HDKSRE
      Raz [M:HDK0]HDKSALFCY
      Raz [M:HDK0]HDKBPR
      Raz [M:HDK0]HDKCCN
    Endif
  Endif
  # FGR 12/07/2010 : X3SUIVI65841 (fin)
  #--------------------------------------
  # Appel objet
  # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
  SZOBJET = OBJET
  If SZABRMSKCOURANT = "HDK2" Then
    If OBJET = "TSK" Then
      SZOBJET = "ITN"
    Endif
  Endif
  If OBJET <> "" Then
    Call OBJET(SZOBJET, CLE1, CLE2) From GOBJET
  Endif
  # Suivant l'agenda on recharge
  If SZABRMSKCOURANT = "CRM1" Then
    Gosub ONLOAD From TRTCRMAGD
  Elsif SZABRMSKCOURANT = "HDK2" Then
    Gosub ONLOAD From TRTHDKAGD
  Endif
End

##########################################################################################################
Subprog AINTERFL(CLOBD,MESSAG,GRAV,OK)
Variable Clbfile CLOBD()     # CLOBD  : contient le clob de description des paramètres (spécifique à chaque interaction flash)
Variable Char MESSAG()(1..)  # MESSAG : contient le texte des messages à afficher (0 à 5)
Variable Integer GRAV(1..)   # GRAV   : contient la gravité des messages 1=info, 2=avertissement, 3=bloquant
Variable Integer OK          # OK=1 si pas de pb, 0 sinon

Local Char ATROUV(100), VTROUV(100), TYPFL(100)
Local Integer IT1, IT2, IT3
#  Recherche TYPFL
Local Char SZVALEUR(100)
Local Date DTDATEDEB
Local Date DTDATEFIN
Local Char HMHOURDEB(100)
Local Char HMHOURFIN(100)
Local Char SZTEXTE(250)
Local Char SZOBJET(GLONAOB)

Local Char SZMASKCOURANT(GLONABR)
Local Char SZABRMSKCOURANT(GLONABR)

  #--------------------------------------
  # FGR 12/07/2010 : X3SUIVI65841 (début)
  # * Provisoire en attendant correction sur le flash (cf. commentaire dans ficher 65841 et 65960
  If GFONCTION = "FUNCRMAGD" Then
    Raz [M:CRM0]CRMCMP
    Raz [M:CRM0]CRMCCN
  Elsif GFONCTION = "FUNHDKAGD" Then
    Raz [M:HDK0]HDKSRE
    Raz [M:HDK0]HDKSALFCY
    Raz [M:HDK0]HDKBPR
    Raz [M:HDK0]HDKCCN
  Endif
  # FGR 12/07/2010 : X3SUIVI65841 (fin)
  #--------------------------------------
  #Raz MESSAG,GRAV
  OK = 1
  If !clalev([F:AMK]) : Local File AMSK [AMK] : Endif
  #   Exemple de CLOBD pour une modification de valeur d'une barre dans un graphique
  #   <INTERFL>
  #     <TYPFL>GRAPH</TYPFL>                               Type de flash
  #     <TYPINTER>MODFIELD</TYPINTER>                      Type d'interaction
  #     <NL>6</NL>                                         Numéro de ligne
  #     <FIELD>QTE</FIELD>                                 Nom du champ (ou un identifiant)
  #     <VAL>456.5</VAL>                                   Nouvelle valeur en alpha
  #   </INTERFL>
  #
  Raz SZABRMSKCOURANT
  SZMASKCOURANT = maskcou
  If SZMASKCOURANT = "" Then
    If GFONCTION = "FUNCRMAGD" Then
      SZMASKCOURANT = "CRMAGD1"
    Elsif GFONCTION = "FUNHDKAGD" Then
      SZMASKCOURANT = "HDKAGD2"
    Endif
  Endif
  Read [AMK]CODMSK=SZMASKCOURANT
  If fstat = 0 Then
    SZABRMSKCOURANT = ABRMSK
  Endif
  #Type evenement
  #EVENTTYPE
  ATROUV = "EVENTTYPE"
  Gosub TROUVT
  #LSE 30/05/2007  En attente d'avoir un paramétrage
  # Pb car en dur
  # On affecte pour un type
  #    1 TSK
  #    2 CLL
  #    3 BAP
  # Correct sur Agenda commercial mais pas sur agenda Support
  If SZABRMSKCOURANT = "CRM1" Then
    Case VTROUV
      When "1"
        SZOBJET = "TSK"
      When "2"
        SZOBJET = "CLL"
      When "3"
        SZOBJET = "BAP"
    Endcase
  Elsif SZABRMSKCOURANT = "HDK2" Then
    Case VTROUV
      When "1"
        SZOBJET = "ITN"
    Endcase
  Endif
  If SZABRMSKCOURANT = "HDK2" Then
    If SZOBJET = "ITN" Then
      Call MESSAGE (mess(609,177,1 )) From GESECRAN
      #Gosub ONLOAD From TRTHDKAGD
      End
    Endif
  Endif
  #Date de début
  ATROUV = "DATSTART"
  Gosub TROUVT
  Call CONVID(VTROUV, DTDATEDEB) From CRMUTIL150
  #Date de FIN
  ATROUV = "DATEND"
  Gosub TROUVT
  Call CONVID(VTROUV, DTDATEFIN) From CRMUTIL150
  #   Heure de début
  ATROUV = "HOURSTART"
  Gosub TROUVT
  HMHOURDEB = VTROUV
  #   Heure de fin
  ATROUV = "HOUREND"
  Gosub TROUVT
  HMHOURFIN = VTROUV
  #   Description du RDV
  ATROUV = "DESCR"
  Gosub TROUVT
  SZTEXTE = VTROUV
  If SZABRMSKCOURANT = "CRM1" Then
    [M:CRM0]CRMDATDEB = DTDATEDEB
    #[M:CRM0]CRMHOUDEB = HMHOURDEB     # FGR 05/10/2015 : X3SUIVI110908 : Ne pas récupérer les heures de l'agenda
    [M:CRM0]CRMDATFIN = DTDATEFIN
    #[M:CRM0]CRMHOUFIN = HMHOURFIN     # FGR 05/10/2015 : X3SUIVI110908 : Ne pas récupérer les heures de l'agenda
    [M:CRM0]CRMTEXTE = SZTEXTE
  Elsif SZABRMSKCOURANT = "HDK2" Then
    [M:HDK0]HDKDATDEB = DTDATEDEB
    #[M:HDK0]HDKHOUDEB = HMHOURDEB     # FGR 05/10/2015 : X3SUIVI110908 : Ne pas récupérer les heures de l'agenda
    [M:HDK0]HDKDATFIN = DTDATEFIN
    #[M:HDK0]HDKHOUFIN = HMHOURFIN     # FGR 05/10/2015 : X3SUIVI110908 : Ne pas récupérer les heures de l'agenda
    [M:HDK0]HDKTEXTE = SZTEXTE
  Endif
  If SZOBJET <> "" Then
    Local Char PARMSK(250)(1..20) , SAVACT(20)

    GBCRMFLGNEW = 1
    SAVACT = GACTION : GACTION = "GOBJETC1"
    Call OBJET_CHAR(SZVALEUR,SZOBJET,"") From GOBJET
    GACTION = SAVACT
    #On recharge l'agenda
    If SZABRMSKCOURANT = "CRM1" Then
      Gosub ONLOAD From TRTCRMAGD
    Elsif SZABRMSKCOURANT = "HDK2" Then
      Gosub ONLOAD From TRTHDKAGD
    Endif
  Endif
End

##########################################################################################################
$TROUVT
  VTROUV = ""
  IT1 = instr(1,CLOBD,"<"+ATROUV)
  IT2 = instr(IT1,CLOBD,">")
  IT3 = instr(IT2,CLOBD,"</")
  If IT2 > 0 and IT3 > IT2 Then
    VTROUV = mid$(CLOBD,IT2+1,IT3-IT2-1)
  Endif
Return

