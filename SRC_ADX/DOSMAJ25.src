####################################################################################
# DOSMAJ25 : Mises à jour à effectuer lors du passage à la version 150 (Release 25) 
# moulinette avant la version 150
####################################################################################

Subprog AMAJ
#-------------------------------------#
#         Avant mise à jour           #
#-------------------------------------#
Onerrgo ERREUR

# Avant suppression des textes des tableaux de bord -F58563
Call ECR_TRACE("************** ADICMAJ30 CPTMAJ30 ***************",-1) From GESECRAN
If [F:ADS]MODULE(1)=2
 Call ADICMAJ30 From CPTMAJ30 : # Moulinettes Comptabilisation
Endif

#-----
# Rajout des types de données
# Rajout des codes activités
# Rajout des nouveaux champs 150
# Les index sont préservés
#-----

Call MAJDIC From SUPMAJ25

#----- Superviseur en premier

Call AMAJ   From SUPMAJ25      : # Moulinettes Superviseur

GVALIDE(2) = 1 : # Ecrans
GVALIDE(3) = 1 : # Objets
GVALIDE(4) = 1 : # Fenêtres et TRT générés superviseur
GVALIDE(5) = 1 : # Consultations

#--- Bug 54269 
#Call ECR_TRACE("************** ATCMAJ25 TCMAJ25 ***************",-1) From GESECRAN
#If [F:ADS]MODULE(8)=2
#  Call ATCMAJ25 From TCMAJ25 : # Moulinettes Tronc commun
#Endif

#--- Bug 54272 
#Call ECR_TRACE("************** ASTOMAJ25 STOMAJ25 ***************",-1) From GESECRAN
#If [F:ADS]MODULE(6)=2
#  Call ASTOMAJ25 From STOMAJ25 : # Moulinettes Stock
#  GVALTRANS(7)=2               : # TRT générés stocks (transactions)
#Endif

# FGR 19/12/2011 : X3SUIVI78240
Call ECR_TRACE("************** ACR1MAJV5 CRMMAJV5***************",-1) From GESECRAN
If [F:ADS]MODULE(11)=2
  Call ACR1MAJV5 From CRMMAJV5 : # Moulinettes Support clients
  GVALTRANS(12)=2            
Endif

# FGR 19/12/2011 : X3SUIVI78240
Call ECR_TRACE("************** ACR2MAJV5 CRMMAJV5 ***************",-1) From GESECRAN
If [F:ADS]MODULE(12)=2
  Call ACR2MAJV5 From CRMMAJV5 : # Moulinettes Action commerciale
  GVALTRANS(13)=2             
Endif



Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

Subprog MAJ
#-------------------------------------#
#          Après mise à jour          #
#-------------------------------------#
Onerrgo ERREUR

#----- Superviseur en premier

Call ECR_TRACE("************** MAJ SUPMAJ25 ***************",-1) From GESECRAN
Call MAJ      From SUPMAJ25     : # Moulinettes Superviseur

#--- Bug 54269 
#Call ECR_TRACE("************** MAJ TCMAJ25 ***************",-1) From GESECRAN
#If [F:ADS]MODULE(9)=2
#  Call TCMAJ25  From TCMAJ25  : # Moulinettes Tronc commun
#Endif

#--- Bug 54272 
#Call ECR_TRACE("************** STOMAJ25 STOMAJ25 ***************",-1) From GESECRAN
#If [F:ADS]MODULE(6)=2
#  Call STOMAJ25  From STOMAJ25  : # Moulinettes Stock
#Endif

# FGR 19/12/2011 : X3SUIVI78240
Call ECR_TRACE("************** CR1MAJ14 CRMMAJV5 ***************",-1) From GESECRAN
If [F:ADS]MODULE(11)=2
  Call CR1MAJV5 From CRMMAJV5 : # Moulinettes Support clients
Endif

# FGR 19/12/2011 : X3SUIVI78240
Call ECR_TRACE("************** CR2MAJ14 CRMMAJV5 ***************",-1) From GESECRAN
If [F:ADS]MODULE(12)=2
  Call CR2MAJV5 From CRMMAJV5 : # Moulinettes Action commerciale
Endif


Onerrgo
End


###################################################################################
###################################################################################
###################################################################################

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

