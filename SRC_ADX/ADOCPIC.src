#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char    VALEUR(30), PARAM(250)(1..20)
PARAM(1) = "FRA"
PARAM(2) = "CS"
PARAM(3) = "ZZMB"
PARAM(4) = "50"
PARAM(5) = "10"
Call SAISIE_CHAR(VALEUR,PARAM,"ADOCPIC","ADOCPIC","") From GSAISIE
End

#-------------------------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "OK"          : Gosub OK
 When "FIN"         : Gosub FIN
Endcase
Return

$OUVRE
Local Date     DAT
Local Char     USR(GLONAUS)
Local Integer  TIM , L , TEMPO
Local Datetime DATTIM
Local Char     DOSX3(GLONADS)
Call PARAM("","SUPDOS",DOSX3) From ADOVAL
If clalev([F:ADO])=0  : Local File ADOCUMENT [ADO]          : Endif
If clalev([F:ADBX])=0 : Local File =DOSX3+".ADOCBLB" [ADBX] : Endif
If clalev([F:ADB])=0  : Local File ADOCBLB [ADB]            : Endif
If clalev([F:ADI])=0  : Local File ATABDIV [ADI]            : Endif
If clalev([F:ADBT])=0 : Local File ADOCBLB [ADBT]           : Endif
Return

$DEBUT
[M]LAN = PARAM(1)
[M]TYP = PARAM(2)
[M]COD = PARAM(3)
[M]LEV = val(PARAM(4))
[M]SUBLEV = val(PARAM(5))

#JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
Read [ADO]ADO0=[M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
If ![S]fstat
  #JPGA 11/10/2012 EXI-79953-11 BUG-79339 : Utilisation de la Notion GROUPE superviseur dans dossiers de DEV seuls
  If !func AGENLIBA.CONTROLE_GROUPE_OK("ADO", [M]LAN, [M]TYP, [M]COD)
    GERR=1 :  FIN=1  :  Return
  Endif
Endif

TEMPO = 0
Call SUP_BLB(OK)
Effzo 10-25
Actzo [M]TYPBLB , NAM , REPERT
Raz nolign , [M]NBPIC , NOPIC
If nomap<>DOSX3
 For [ADBX]ADB0 Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
  If !TEMPO
   Call TEMPON(mess(90,151,1)) From GESECRAN : # Chargement en cours...
   TEMPO = 1
  Endif
  Gosub INSERE_PIC
  If !K : Break : Endif
  nolign += 1
  [M] = [F:ADBX]
  [M]NUM(nolign-1) = [M]NBPIC
  [M]NOPIC(K-1)    = [M]NBPIC
  Call MAJ_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]TYPBLB(nolign-1),[F:ADBX]PICTUR,K-1,OK)
  [M]FLGLOC(K-1)   = 1
 Next ADBX
Endif
For [ADB]ADB0 Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
 If !TEMPO
  Call TEMPON(mess(90,151,1)) From GESECRAN : # Chargement en cours...
  TEMPO = 1
 Endif
 Gosub INSERE_PIC
 If !K : Break : Endif
 nolign += 1
 [M] = [F:ADB]
 [M]NUM(nolign-1) = [M]NBPIC
 [M]NOPIC(K-1)    = [M]NBPIC
 Call MAJ_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]TYPBLB(nolign-1),[F:ADB]PICTUR,K-1,OK)
 [M]FLGLOC(K-1)   = 2
Next ADB
[M]NBLIG = nolign
Affzo
For I=1 To [M]NBLIG
 If [M]FLGLOC(I-1)<>2
  Grizo [M]TYPBLB(I-1) , NAM(I-1) , REPERT(I-1)
 Endif
Next I
If TEMPO
 Call TEMPOFF From GESECRAN
 TEMPO = 0
Endif
REP = "M"
Return

$OK
If GADONIX=2
 Local Char CLETRA(30)(0..5)
 CLETRA(0) = [M]LAN
 CLETRA(1) = [M]COD
 CLETRA(2) = num$([M]LEV)
 CLETRA(3) = num$([M]SUBLEV)
 Call TRACE_COR("ADO",[M]TYP,CLETRA,"M") From GOBJET
Endif
Call DEBTRANS From GLOCK
Gosub TR1
Return

$FIN
Call SUP_BLB(OK)
Return

$TR1
Trbegin [ADB]
 Look [ADB]ADB0(5) = [M]LAN;[M]TYP;[M]COD;[M]LEV;[M]SUBLEV
 If !fstat
  If dim([F:ADB]CREUSR)>0    : USR    = [F:ADB]CREUSR    : Endif
  If dim([F:ADB]CREDATTIM)>0 : DATTIM = [F:ADB]CREDATTIM
    If dim([F:ADB]CREDAT)>0  : DAT    = func SUBADC.DAT_DATETIME(DATTIM) : Endif
  Else
    If dim([F:ADB]CREDAT)>0  : DAT    = [F:ADB]CREDAT    : Endif
    If dim([F:ADB]CRETIM)>0  : TIM    = [F:ADB]CRETIM    : Endif
  Endif
 Else
  Raz USR , DAT , TIM , DATTIM
 Endif
 Delete [ADB] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & LEV=[M]LEV & SUBLEV=[M]SUBLEV
 If fstat=1
  GOK=-1 : Call RSTA("ADB",[M]TYP-[M]COD) From GLOCK : Goto ROLL_TR1
 Endif
 L = 0
 For nolign=1 To [M]NBLIG
  If [M]NUM(nolign-1)<>0 & [M]FLGLOC(nolign-1)=2
   K = find([M]NUM(nolign-1),[M]NOPIC)
   If K<>0
    Raz [F:ADB]
    L += 1
    [F:ADB] = [M]
    [F:ADB]LIG = L
    Call LEC_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[F:ADB]PICTUR,K-1,OK)
    If USR<>"" # Ancien Enregistrement
     If dim([F:ADB]CREUSR)>0    : [F:ADB]CREUSR    = USR                                        : Endif
     If dim([F:ADB]CREDATTIM)>0 : [F:ADB]CREDATTIM = DATTIM
       If dim([F:ADB]CREDAT)>0  : [F:ADB]CREDAT    = func SUBADC.DAT_DATETIME([F:ADB]CREDATTIM) : Endif
     Else
       If dim([F:ADB]CREDAT)>0  : [F:ADB]CREDAT    = DAT                                        : Endif
       If dim([F:ADB]CRETIM)>0  : [F:ADB]CRETIM    = TIM                                        : Endif
     Endif
     If dim([F:ADB]UPDUSR)>0    : [F:ADB]UPDUSR    = GUSER                                      : Endif
     If dim([F:ADB]UPDDATTIM)>0 : [F:ADB]UPDDATTIM = datetime$
       If dim([F:ADB]UPDDAT)>0  : [F:ADB]UPDDAT    = func SUBADC.DAT_DATETIME([F:ADB]UPDDATTIM) : Endif
     Else
       If dim([F:ADB]UPDDAT)>0  : [F:ADB]UPDDAT    = date$                                      : Endif
       If dim([F:ADB]UPDTIM)>0  : [F:ADB]UPDTIM    = time                                       : Endif
     Endif
    Else       # Nouvel Enregistrement
     If dim([F:ADB]CREUSR)>0    : [F:ADB]CREUSR    = GUSER                                      : Endif
     If dim([F:ADB]CREDATTIM)>0 : [F:ADB]CREDATTIM = datetime$
       If dim([F:ADB]CREDAT)>0  : [F:ADB]CREDAT    = func SUBADC.DAT_DATETIME([F:ADB]CREDATTIM) : Endif
     Else
       If dim([F:ADB]CREDAT)>0 : [F:ADB]CREDAT     = date$                                      : Endif
       If dim([F:ADB]CRETIM)>0 : [F:ADB]CRETIM     = time                                       : Endif
     Endif
    Endif
    Write [ADB]
    If fstat
     GOK = 0 : Call FSTA("ADB") From GLOCK : Break
    Endif
   Endif
  Endif
 Next nolign
 If GOK<1 : Goto AB_TR1 : Endif
 Call MAJ_ENVINDUS_DOC ([M]LAN,[M]TYP,[M]COD,2) From AGENREM : # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
Commit

 #VPO 02/10/08 49500 proposer validation sur AD et AM
 #VPO 06/12/08 49552 ajout fichiers liés traduisibles + AM+AD+FI
 # SI024 94779_1 TCH : Split AGENLIBA + Trace dans remontée des traductions
 If !func AGENREM.IS_ENVINDUS_DOC("") & (find([M]TYP,"AM","AD","FI") | find(2,[M]TRAFIL(0..[M]NBLIG-1)) )
    ##VPO 21/11/07 BUG44225 ne pas proposer validation si doc jamais validée
    If clalev([ADO3])=0 : Local File ADOCUMENT [ADO3] : Endif
    For [ADO3] Where LAN=[M]LAN & TYP=[M]TYP & COD=[M]COD & VLDFLG=2 & VLDDAT<>date$
        #s'il existe un paragraphe validé à une autre date que aujourd'hui
        ##VPO 16/11/07 bug43240 ajouter proposition de validation
        MESSA  = 'LAN = "'+[M]LAN+'"'
        MESSA -= 'TYP = "'+[M]TYP+'"'
        MESSA -= 'COD = "'+[M]COD+'"'
        OK=1 : Call OUINON(MESSA+"\"+mess(80,176,1),OK) From GESECRAN
        If OK=2
          Local Char VALBOUT(250) , PARBOUT(250)(1..20)
          PARBOUT(1) = [M]LAN
          PARBOUT(2) = [M]TYP
          PARBOUT(3) = [M]COD
          Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ADOCVAL","ADOCVAL",3,"") From GTRAITE
        Endif
        Break
    Next
 Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$APRES_MODIF
Case zoncou
 When "PHOTO"
  If [M]NUM([M]NOLIG-1)<>0
   K = find([M]NUM([M]NOLIG-1),[M]NOPIC)
   If K
    Case [M]TYPBLB([M]NOLIG-1)
     When 3 : # Photo
      [M]PHOTO = zc : # mb 24.6.13 bug 87056
      Call MAJ_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]TYPBLB([M]NOLIG-1),[M]PHOTO,K-1,OK)
    Endcase
   Else
    [M]NUM([M]NOLIG-1)=0
   Endif
  Endif
  If [M]NUM([M]NOLIG-1)=0
   Gosub INSERE_PIC
   If K
    [M]NUM([M]NOLIG-1) = [M]NBPIC
    [M]FLGLOC([M]NOLIG-1) = 2
    [M]NOPIC(K-1) = [M]NBPIC
    Case [M]TYPBLB([M]NOLIG-1)
     When 3 : # Photo
      [M]PHOTO = zc : # mb 24.6.13 bug 87056
      Call MAJ_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]TYPBLB([M]NOLIG-1),[M]PHOTO,K-1,OK)
    Endcase
   Endif
  Endif
Endcase
Return

$INSERE_PIC
K = find(0,[M]NOPIC)
If !K
 Call ERREUR(mess(195,133,1)-num$(dim([M]NOPIC))) From GESECRAN : # Le nombre de photos est limité à
Else
 [M]NBPIC += 1
Endif
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog MAJ_BLB(LAN,TYP,COD,LEV,SUBLEV,TYPBLB,PIC,IND,OK)
Value Char LAN , TYP , COD
Value Integer LEV , SUBLEV , TYPBLB
Value Blbfile PIC
Value Integer IND
Variable Integer OK
OK = 1
Trbegin [ADBT]
 #JPGA 11/05/2010 BUG-64060 : Passage Stockage fichiers joints : BLOB de 9 à 10(En V6). Utilisation table temporaire ADOCBLB
 Gosub INIT_CLE_BLB
 Readlock [ADBT]ADB0  =
 If !fstat
  [F:ADBT]PICTUR      = [L]PIC
  [F:ADBT]TYPBLB      = [L]TYPBLB
  [F:ADBT]REPERT      = [L]TYP
  Rewrite [ADBT]
  If fstat : OK = 0 : Endif
 Elsif fstat=1
  OK = 0
 Else
  Raz [F:ADBT]
  Gosub INIT_CLE_BLB
  [F:ADBT]PICTUR      = [L]PIC
  [F:ADBT]TYPBLB      = [L]TYPBLB
  [F:ADBT]REPERT      = [L]TYP
  Write [ADBT]
  If fstat : OK = 0 : Endif
 Endif
Commit
End

Subprog LEC_BLB(LAN,TYP,COD,LEV,SUBLEV,PIC,IND,OK)
Value Char LAN , TYP , COD
Value Integer LEV , SUBLEV
Variable Blbfile PIC
Value Integer IND
Variable Integer OK
#JPGA 11/05/2010 BUG-64060 : Passage Stockage fichiers joints : BLOB de 9 à 10(En V6). Utilisation table temporaire ADOCBLB
Raz [F:ADBT]
Gosub INIT_CLE_BLB
Read [ADBT] =
If !fstat
 OK = 1
 [L]PIC = [F:ADBT]PICTUR
Else
 OK = 0
 Raz [L]PIC
Endif
End

Subprog SUP_BLB(OK)
Variable Integer OK
OK = 1
#JPGA 11/05/2010 BUG-64060 : Passage Stockage fichiers joints : BLOB de 9 à 10(En V6). Utilisation table temporaire ADOCBLB
Trbegin [ADBT]
 Delete [ADBT] Where TYP=num$(adxuid(1))
 If fstat : OK = 0 : Endif
Commit
End

$INIT_CLE_BLB
  [F:ADBT]TYP    = num$(adxuid(1))
  [F:ADBT]LAN    = [L]LAN
  [F:ADBT]COD    = [L]COD
  [F:ADBT]LEV    = [L]LEV
  [F:ADBT]SUBLEV = [L]SUBLEV
  [F:ADBT]LIG    = [L]IND
Return

#----------------------------------------------------------------------------------------------------#
# Etiquettes écran ADOX
#----------------------------------------------------------------------------------------------------#

Subprog AS_NBLIG
Local Integer K , OK
Gosub SETNOL
[M]NOLIG = NOL+1
If [M]NUM([M]NOLIG-1)=0
 Effzo PHOTO , TAILLE
Else
 K = find([M]NUM([M]NOLIG-1),[M]NOPIC)
 If K<>0
  Call LEC_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]PHOTO,K-1,OK)
  [M]TAILLE = arr(len([M]PHOTO)/1024,0.1)
  Case [M]TYPBLB([M]NOLIG-1)
   When 3
    Affzo PHOTO
   When Default
    Effzo PHOTO
  Endcase
  Affzo TAILLE
 Else
  Effzo PHOTO , TAILLE
 Endif
Endif
End

Subprog IB_NAM
If [M]TYPBLB(nolign-1)=3
 GBOUT1 = ""
Endif
End

Subprog B1_NAM(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(GDIMFIC) , NAM(GDIMFIC) , TAB(10)
Local Integer K , OK
Gosub SETNOL
Call SELFIC(FICHIER,NAM)
If FICHIER="" : End : Endif
Gosub INSERE_PIC
If K
 Openi FICHIER Using [TST]
 Getseq 1,[M]PHOTO Using [TST]
 If !fstat
  If VALEUR=""
   VALEUR = NAM
  Endif
  [M]NUM(NOL)    = [M]NBPIC
  [M]FLGLOC(NOL) = 2
  [M]NOPIC(K-1)  = [M]NBPIC
  [M]TAILLE = arr(len([M]PHOTO)/1024,0.1)
  Call MAJ_BLB([M]LAN,[M]TYP,[M]COD,[M]LEV,[M]SUBLEV,[M]TYPBLB(NOL),[M]PHOTO,K-1,OK)
  Affzo TAILLE
  Effzo PHOTO
 Endif
 Openi Using [TST]
Endif
End

Subprog SELFIC(FICHIER,NAM)
Variable Char FICHIER,NAM
Local Integer OK , STAT
Local Char    URL(10) , SUF(30)
Local Mask ADOCFIC [DIA]
Call DIALWIN(OK,mess(230,139,1),"ADOCFIC") From GESECRAN : # Ajout d'un document
If OK<>2
 [L]FICHIER = ""
Elsif [M:DIA]TYPEXP=1
 Call SET_FICNAM([M:DIA]FICHIER,[L]FICHIER,URL) From ORDSYS
 Call COPSRV([M:DIA]FICHIER,[L]FICHIER,STAT) From ORDSYS
 If STAT
  [L]FICHIER = ""
 Else
  Call SETNAM([M:DIA]FICHIER,NAM,SUF) From GOBJTXT
  If SUF<>""
   NAM += "."+SUF
  Endif
  Gosub SELFIC_TEST_ACCENTS
 Endif
Else
 #JPGA 09/04/2010 BUG-61364 : Récupération du Nom du fichier qui n'était pas fait : FICHIER était à vide.
 [L]FICHIER=[M:DIA]FICHIER
 Call EXISTE([L]FICHIER,STAT) From LECFIC
 If STAT<>1
  Call ERREUR("|"+[L]FICHIER+"|\"+mess(101,100,1)) From GESECRAN : # Fichier inexistant
  [L]FICHIER = ""
 Else
  Call SETNAM([L]FICHIER,NAM,SUF) From GOBJTXT
  If SUF<>""
   NAM += "."+SUF
  Endif
  Gosub SELFIC_TEST_ACCENTS
 Endif
Endif
End

$SELFIC_TEST_ACCENTS
  #JPGA 11/05/2010 BUG-64060 : Passage Stockage fichiers joints : BLOB de 9 à 10(En V6). Le fichier joint ne doit pas contenir d'accents
  CPT = 0 : I = 1 : LISTE_CAR="éèëêçàäâöôùüûîï&$£µ%§!?"
  Repeat
    CPT = pat(LISTE_CAR,"*"+mid$(NAM,I,1)+"*") : I += 1
  Until I>=len(NAM) or CPT
  If CPT
    Call ERREUR("|"+NAM+"| :"-mess(94,123,1)-"("-LISTE_CAR-")") From GESECRAN : # Fichier inexistant
    [L]FICHIER = ""
  Endif
Return

Subprog C_NBLIG
If adxgtb=0 & find(status,65,68,73)
 If nolign>dim([M]FLGLOC) or [M]FLGLOC(nolign-1)<>2
  mkstat = 1
 Endif
Endif
End

Subprog AS_TYPBLB(VALEUR)
Variable Integer VALEUR
GMENLOC(2) = 1 : # Texte
End

#----------------------------------------------------------------------------------------------------#
# Etiquettes écran ADOFIC
#----------------------------------------------------------------------------------------------------#

Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Grizo FICHIER
Else
 Actzo FICHIER
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Grizo FICHIER
Else
 Actzo FICHIER
Endif
End

Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
Local Char    NAM(GDIMFIC) , SUF(30)
Local Integer ER , I
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(GDIMFIC)
If VALEUR="" : End : Endif
If left$(VALEUR,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : End
Endif
Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : End
Endif
Raz ER
Call EXISTE(VALEUR,ER) From ORDSYS
Case ER
 When 2
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : End
 When 0
  GMESSAGE = mess(03,141,1) : # Fichier à importer inexistant
  mkstat = 2 : End
Endcase
End
