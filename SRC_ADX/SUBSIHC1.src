#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
#
#  SUBSIHC was created because SUBSIHC is too large to add more code to it and generated an error 128
#
#############################################################################
###########################################################################
# STODETKIT : Détermination de la quantité à livrer d'un kit              #
#             à partir des quantités livrables des composants             #
###########################################################################
$STODETKIT

Local    Decimal WQUS, WQTYDIM
Local    Decimal WQTYCPS, WQTYSTUCPS
Local    Decimal WDISCPS, WDISSTUCPS
Local    Integer WSTA, WA, WQ, WR
Local    Integer WINDICE, I
Local    Integer WSTOSEQ
Local    Integer WMODQTYCPE : Raz WMODQTYCPE

If WQTYSTUCPE=0
   Raz OK : Return
Endif

If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1]:Endif
If clalev ([F:SOP1]) = 0 Local File SORDERP [SOP1]:Endif

WINDICE = [M:SIH4]NBLIG
# --- Recherche stock disponible des composants
For [SOP1]SOP0 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN > [F:SOQ]SOPLIN
   # Sortie de la boucle quand on est plus sur un composant
   If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) Break Endif
   Read [SOQ1]SOQ0 = [F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
   If fstat
      Call RSTA("SOQ",[F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ))
&               From GLOCK
      Raz WQTYCPE, WQTYSTUCPE
      Raz OK : Break
   Endif
   If [F:ITM]ITMREF <> [F:SOQ1]ITMREF
      Read [ITM]ITM0=[F:SOQ1]ITMREF
      If fstat Raz [F:ITM] Endif
   Endif

   WINDICE += 1
   If [F:SOQ1]STOMGTCOD<>1
      # Calcul de la qté à traiter du composant en UV et en US
      WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
      WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
      Call QTEARR (WQTYSTUCPS,[F:SOP1]STU) From TRTDIV

      # Recherche de la quantité livrable du composant
      Gosub RECH_QTEDIS  From SUBSIHC

      # Qté disponible du composant nulle, rien à livrer
      If OK=0 & WDISSTUCPS<=0
         Raz WQTYCPE, WQTYSTUCPE
         Break
      # Qté disponible du composant < qté origine du composant
      Elsif WDISSTUCPS < WQTYSTUCPS
         # Flag : la qté à livrer du composé a été modifiée
         WMODQTYCPE = 1
         # La qté à livrer du cpsa doit être un multiple du rapport cpsé/cpsa
         WDISCPS    = WDISCPS-mod(WDISCPS,[F:SOQ1]QTY/[F:SOQ]QTY)
         WDISSTUCPS = WDISCPS*[F:SOP1]SAUSTUCOE
         Call QTEARR(WDISSTUCPS,[F:SOP1]STU) From TRTDIV
         # Recalcul de la nouvelle qté à livrer du composé
         WQTYCPE    = WDISCPS*([F:SOQ]QTY/[F:SOQ1]QTY)
         WQTYSTUCPE = WQTYCPE*[F:SOP]SAUSTUCOE
         Call QTEARR(WQTYSTUCPE,[F:SOP]STU) From TRTDIV
      Endif
   Endif
Next

# Nettoyage du STOSORW si la quantité livrable a diminuée
If WMODQTYCPE=1
   WINDICE = [M:SIH4]NBLIG
   If [F:SOQ]STOMGTCOD<>1
      WQUS=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=[M:SIH4]WSTOSEQ(WINDICE))))
      # La qté composé stockée dans STOSORW est > à celle qui est livrable
      If WQUS>WQTYSTUCPE
         # Diminution de la qté stockée dans STOSORW
         WQTYDIM=WQUS-WQTYSTUCPE
#         Call DIM_STOSORW(WINDICE,"SIH4",[M:SIH1]STOFCY,WQTYDIM,WRET) From STKSOR
         Call DIM_STOSORW(WINDICE,"SIH4",[F:SOQ]STOFCY,WQTYDIM,WRET) From STKSOR
         If WRET<>0 Goto STODETKIT_SUI Endif
      Else
         Raz WMODQTYCPE
      Endif
   Endif
   If WMODQTYCPE=1
      For [SOP1]SOP0 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN>[F:SOQ]SOPLIN
         # Sortie de la boucle quand on est plus sur un composant
         If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) Break Endif
         Read [SOQ1]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
         WINDICE += 1
         # Calcul de la qté à traiter du composant
         WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
         WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
         If [F:SOQ1]STOMGTCOD<>1
            WQUS=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=[M:SIH4]WSTOSEQ(WINDICE))))
            # La qté composé stockée dans STOSORW est > à celle qui est livrable
            If WQUS>WQTYSTUCPS
               # Diminution de la qté stockée dans STOSORW
               WQTYDIM=WQUS-WQTYSTUCPS
#               Call DIM_STOSORW(WINDICE,"SIH4",[M:SIH1]STOFCY,WQTYDIM,WRET) From STKSOR
               Call DIM_STOSORW(WINDICE,"SIH4",[F:SOQ1]STOFCY,WQTYDIM,WRET) From STKSOR
               If WRET<>0 Goto STODETKIT_SUI Endif
            Endif
         Endif
      Next
   Endif
Endif

$STODETKIT_SUI
# Nettoyage du STOSORW s'il y a eu un problème
If OK=0 & WINDICE >= [M:SIH4]NBLIG
#--- Bug 68375
   Call DELSTOSORW([M:SIH4]NBLIG,WINDICE,"SIH4",[M:SIH1]STOFCY,WRET) From STKSOR
   For I=[M:SIH4]NBLIG To WINDICE
      Raz [M:SIH4]WSTOSEQ(I)
   Next
   #For I=[M:SIH4]NBLIG To WINDICE
#  # Call DELSTOSORW([M:SIH4]NBLIG,WINDICE,"SIH4",[M:SIH1]STOFCY,WRET) From STKSOR
   #   Call DELSTOSORW(I,I,"SIH4",[M:SIH4]DSTOFCY(I),WRET) From STKSOR
   #   #--- Bug 51776
   #   Raz [M:SIH4]WSTOSEQ(I)
   #Next
#---
Endif

Return
#############################################################################
$FILGAUCHE
# BRBAN 105200 #US2 - invoice cancellation picking list
If func AFNC.ACTIV("INVCA")>0
  If currbox="GAU_CHE"
    # Issue 110570 - 2015-09-02 by BRBAN : Needed to filter Invoice cancellation on the main left list
    If  [F:SLT]INVTYP=2
      Case [F:SLT]INVCAN
        When 2 : [L]FILGAUCHE = "[F:SIH]REVCANSTA=2"
        When Default : [L]FILGAUCHE = "[F:SIH]REVCANSTA<>2"
      Endcase
    Endif
  Else
    If [F:SLT]INVCAN=2 & currbox = GBOXINVCA
      Gosub FILGAUCHE7
    Endif
  Endif
Endif
# -
Return
#############################################################################
$FILGAUCHE7
#------------------------------
# Filtre picking des factures
#------------------------------
# Si pas de clé courante (sauf si création) ou pas avoir ou validée:rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]INVTYP<>2 | ([M]SIHORI <> 4 & [M]SIHORI <> 1) | [M]INVSTA=3
   FILGAUSUP(0)='[F:SIV]BPCINV=""'
   Return
Endif

FILGAUSUP(0) ='[F:SIV]BPCINV=[M]BPCINV'

If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SIV]SALFCY=[M]SALFCY'   Endif

# Utilisation des critères de picking renseignés depuis l'option Critères picking
If [M:SIH0]CRISIHNUM<>"" FILGAUSUP(0)+=' & [F:SIV]NUM=[M:SIH0]CRISIHNUM' Endif
#If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+=' & [F:SID]ITMREF=[M:SIH0]CRIITMREF' Endif

#--CPO 87923 Gestion des prélèvements SDD
If dim([M:SIH0]CRIUMRNUM)>0 and find([M:SIH0]CRIUMRNUM,"","~~~~") < 1
  FILGAUSUP(2) += '& [F:SIH]UMRNUM="'+ [M:SIH0]CRIUMRNUM + '"'
Endif

# Ce doit être des factures validées
FILGAUSUP(0) +='&[F:SIV]INVTYP=1&[F:SIV]INVSTA=3'

If [M]NBLIG <> 0
   If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SIV]BPRPAY=[M]BPRPAY'    Endif

   If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SIV]BPCGRU=[M]BPCGRU'    Endif

   If dim ([M]BPRFCT) > 0
     If [M]BPRFCT<>"" FILGAUSUP(0)+='&[F:SIV]BPRFCT=[M]BPRFCT' Endif
   Endif

   If [M]BPRSAC<>"" FILGAUSUP(0)+='&[F:SIH]BPRSAC=[M]BPRSAC'    Endif
Endif

If [M]NBLIG <> 0
#   Ne pas filtrer sur la devise pour le passage à l'euro
    If [M]VACBPR<>""  FILGAUSUP(1)+='&[F:SIH]VAC=[M]VACBPR'    Endif

#   If func AFNC.ACTIV("LTA") & GLOCUSATAX : FILGAUSUP(1)+='&[F:SIH]SSTENTCOD=[M]SSTENTCOD' : Endif #LTA.n 79065   # 106867.o
    If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(1)+='&[F:SIH]SSTENTCOD=[M]SSTENTCOD' : Endif #LTA.n 79065   # 106867.n

    If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SIV]PRITYP=[M]PRITYP'  Endif

    If [M]STOMVTFLG<>0 FILGAUSUP(1)+='&[F:SIV]STOMVTFLG>=[M]STOMVTFLG'   Endif
Endif

# V6.2 : Certification
# Si ctrl date documents : La facture doit avoir une date <= à la date de l'avoir
If GCTLDATORI=2  FILGAUSUP(1) +='& [F:SIV]INVDAT<=[M:SIH0]INVDAT' : Endif

FILGAUSUP(1) += "& [F:SIH]REVCANSTA=0"

#--CPO 71065 Code affaire
If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(1)+='&[F:SIV]PJT=[M]PJT'
   Endif
Endif
#--/CPO

#--CPO 87923 Gestion des prélèvements SDD
If dim([M:SIH0]CRIUMRNUM)>0 and [M:SIH0]CRIUMRNUM = "~~~~"
  #--Dans ce cas l'utilisateur est passé par "Options/Critères picking" et a remis à "" le n° mandat !!!
  Raz [M:SIH0]CRIUMRNUM
Else
  If dim([M:SIH2]UMRNUM)>0 and GSDDMGT=2 and [M:SIH2]SDDFLG=2
    If [M:SIH2]PTE<>"" and [M:SIH2]UMRNUM<>"" and find([M:SIH0]CRIUMRNUM,"","~~~~") > 0
      FILGAUSUP(2)+='&[F:SIH]UMRNUM="'+[M]UMRNUM+'"'
    Endif
  Endif
Endif
#--/


# X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#GBIDC3="" : Call FILROLE("SIH",GBIDC3) From SUBARL
#If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif
#Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SIH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


Return
#############################################################################
$PICKE
If func AFNC.ACTIV("INVCA")>0
  If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
    Filter [F:SID] Where [F:SID]NUM=[F:SIV]NUM
    For [F:SID]
      Gosub SEL5 From SUBSIHC
    Next
    Filter [F:SID]

    Grizo [M:SIH1]
    Grizo [M:SIH2]
    Grizo [M:SIH4]
    Grizo [M:SIHV]
  Endif
Endif
Return
#############################################################################
$DEPICK
If func AFNC.ACTIV("INVCA")>0
  If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
    Filter [F:SID] Where [F:SID]NUM=[F:SIV]NUM
    For [F:SID]
      Gosub DESEL5 From SUBSIHC
    Next
    Filter [F:SID]
  Endif
Endif
Return
######################################################################################
$SEL5
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
  Filter [F:ISID] Where [F:ISID]SIHORINUM=[F:SIV]NUM
  Read [F:ISID] First
  If !fstat
    Call ERREUR(mess(45,191,1)) From GESECRAN
    OK=0
    GERR=1
    Return
  Endif
  Filter [F:ISID]
  Endif

  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN<>2
    Filter [F:ISID] Where [F:ISID]SIHORINUM=[F:SIV]NUM
    Read [F:ISID] First
    If !fstat
      Read [F:ISIH]SIH0=[F:ISID]NUM
      If !fstat
        If [F:ISIH]REVCANSTA<>0
          Call ERREUR(mess(2,7712,1)) From GESECRAN
          OK=0
          GERR=1
          Return
        Endif
      Endif
    Endif
    Filter [F:ISID]
  Endif
Endif
Return
######################################################################################
$LEC_TABART
If func AFNC.ACTIV("INVCA")>0
  If [F:SLT]INVCAN=2 & WONFAITQUOI = GBOXINVCA
    WITMREF=[F:SID]ITMREF : WBPCORD=[F:SIV]BPCINV
  Endif
Endif
Return
######################################################################################

