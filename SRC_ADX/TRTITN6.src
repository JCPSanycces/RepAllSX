#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion de la consultation des prestataires compétents   Module CRM   septembre 2000 #
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZSELBPR
Global Integer GIHBDISP

  GIHBDISP = 0
  GSZSELBPR = ""
  If !GINTRA Then
    Gosub SEARCHPRX
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:ITN6]NBPRX > 0 Then
    ETABOU(GSPE1) = 1
  Else
    ETABOU(GSPE1) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  If GINTRA Then
    Gosub SEARCHPRX
  Endif
  Call CLEANLUP
  Gosub LOADPRX
  GSZSELBPR = [M:ITN6]BPRNUM(0)
  GIHBDISP = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  If GIHBDISP Then
    #Vide la table des résultats si elle a été remplie
    If !clalev([F:LUP]) : Local File SEARESULT [LUP] : Endif
    Call DEBTRANS From GLOCK
    Trbegin [LUP]
    Delete [LUP] Where [F:LUP]SSS = GIDENT
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    #Nettoie l'écran avant de partir.
    Raz [M:ITN6]
  Endif
  Kill GIHBDISP
  Kill GSZSELBPR
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
#
#  ONSELECT   : Gestion du bouton "Sélectionner".
#  LOADPRX    : Charge les prestataires compétents dans la fenêtre de résultat.
#  SEARCHPRX  : Exécute la recherche des prestataires compétents.
#
##########################################################################################################
##########################################################################################################
$ONSELECT
  VALEUR = GSZSELBPR
  mkstat = 4
  FIN = 1
Return

##########################################################################################################
$LOADPRX
Local Integer IZ
Local Char SZEXPCOD

  If !clalev([F:PRX]) : Local File SUBCONT [PRX] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  IZ = 0
  SZEXPCOD = ""
  Filter [LUP] Where [F:LUP]SSS = GIDENT
  For [LUP] LUP2
    If IZ >= dim([M:ITN6]BPRNUM)-1 Then
      Break
    Endif
    Read [PRX]PRX0=[F:LUP]OBJNUM
    If !fstat Then
      [M:ITN6]BPRNUM(IZ) = [F:PRX]BPRNUM
      [M:ITN6]RATHOU(IZ) = [F:PRX]RATHOU
      [M:ITN6]EXSINV(IZ) = [F:PRX]EXSINV
      Call GET_LIB(423, [M:ITN6]EXSINV(IZ), [M:ITN6]EXSINVCLA(IZ)) From CRM_UTIL
      [M:ITN6]EXSVLT(IZ) = [F:PRX]EXSVLT
      [M:ITN6]PTE(IZ) = [F:PRX]PTE
      [M:ITN6]CUR1(IZ) = [F:PRX]CUR
      [M:ITN6]CUR2(IZ) = [F:PRX]CUR
      Read [ADI]CODE=423;[M:ITN6]EXSINV(IZ)
      If !fstat Then
        SZEXPCOD = [F:ADI]A1
      Endif
      Case SZEXPCOD
        When "A"
          [M:ITN6]EXSVLTX(IZ) = ""
        When "B"
          [M:ITN6]EXSVLTX(IZ) = mess(228,196,1)  #en tant que montant forfaitaire
        When "C"
          [M:ITN6]EXSVLTX(IZ) = mess(229,196,1)  #par kilomètre parcouru
        When "D"
          [M:ITN6]EXSVLTX(IZ) = mess(230,196,1)  #par heure écoulée
        When Default
      Endcase
      IZ += 1    
    Endif
  Next
  Filter [LUP]
  [M:ITN6]NBPRX = IZ
  Sorta [M:ITN6]NBPRX [M:ITN6]NBPRX Order By [M:ITN6]RATHOU([S]indice)
  Affzo [M:ITN6]1-99
Return

##########################################################################################################
$SEARCHPRX
Local Char SZPBLNUM
Local Char SZCRY
Local Char SZZIP
Local Integer IZIPLEN
Local Integer IRESNUM
Local Integer INBF

  IZIPLEN = 0
  SZPBLNUM = ""
  IRESNUM = 0
  INBF = 0
  SZCRY = [M:ITN3]CRY
  SZZIP = [M:ITN3]ZIP
  If !clalev([F:LUP]) : Local File SEARESULT [LUP] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  #Recherche la demande de service associée à l'intervention.
  If [M:ITN0]SRVDEMNUM <> "" Then
    #Une demande de service est renseignée
    Read [SRE]SRE0=[M:ITN0]SRVDEMNUM
    If fstat Then
      Gosub LKUPARA
      If !GERR Then
        GMESSAGE = mess(295,196,1)
        #Aucune famille de compétence n'a pu être identifiée. Seule une recherche par zone géographique a été effectuée.
        GERR = 2
      Endif
      Gosub CPTCOUNT
      Return
    Endif
    SZPBLNUM = [F:SRE]SREPBLGRP
    If SZPBLNUM <> "" Then
      Gosub LKUPPBL
      Gosub LKARAEMP
    Else
      Gosub LKUPARA
      If !GERR Then
        GMESSAGE = mess(295,196,1)
        #Aucune famille de compétence n'a pu être identifiée. Seule une recherche par zone géographique a été effectuée.
        GERR = 2
      Endif
    Endif
  Else
    #Aucune demande de service n'est renseignée.
    Gosub LKUPARA
    If !GERR Then
      GMESSAGE = mess(296,196,1)
      #Aucune demande de service n'a pu être traitée. Seule une recherche par zone géographique a été effectuée.
      GERR = 2
    Endif
  Endif
  Gosub CPTCOUNT
Return

##########################################################################################################
$CPTCOUNT
  INBF = 0
  Filter [LUP] Where [F:LUP]SSS = GIDENT
  For [LUP] LUP2
    INBF += 1
  Next
  Filter [LUP]
  If GERR <> 1 Then
    If !INBF Then
      GMESSAGE = mess(298,196,1) #Aucun prestataire ne correspond aux critères de l'intervention.
      GERR = 2
      If !GINTRA Then
        FIN = 1
      Endif
    Endif
  Endif
Return

##########################################################################################################
$LKUPPBL
  #Enregistre tous les prestataires compétents sur la famille de compétence indiquée.
  If !clalev([F:SBP]) : Local File SBPBL [SBP] : Endif
  Filter [SBP] Where [F:SBP]PBL = SZPBLNUM
  For [SBP]SBP1
    Read [BPR]BPR0=[F:SBP]BPRNUM
    If !fstat Then
      If [F:BPR]PRVFLG = 2 Then
        Read [LUP]LUP3=[F:SBP]BPRNUM;GIDENT
        If fstat Then
          Call DEBTRANS From GLOCK
          Trbegin [LUP]
          [F:LUP]OBJNUM = [F:SBP]BPRNUM
          [F:LUP]RESNUM = IRESNUM
          [F:LUP]SSS = GIDENT
          [F:LUP]CREDAT = date$
          Write [LUP]
          If fstat Then
            GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
            GERR = 1
            Rollback
            Break
          Else
            Commit
            IRESNUM += 1
          Endif
        Else
          Call DEBTRANS From GLOCK
          Trbegin [LUP]
          [F:LUP]OBJNUM = [F:SBP]BPRNUM
          [F:LUP]RESNUM = IRESNUM
          [F:LUP]SSS = GIDENT
          [F:LUP]CREDAT = date$
          Rewrite [LUP]
          If fstat Then
            GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
            GERR = 1
            Rollback
            Break
          Else
            Commit
            IRESNUM += 1
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [SBP]
Return

##########################################################################################################
$LKARAEMP
#Elimine tous les prestataires non présent sur la zone géographique demandée.
Local Integer IMUSTDEL
Local Integer IERROR   # FGR 08/02/2010 : X3SUIVI60986

  IERROR = 0   # FGR 08/02/2010 : X3SUIVI60986
  IMUSTDEL = 1
  If !clalev([F:SBG]) : Local File SBGEO [SBG] : Endif
  If !clalev([F:PRX]) : Local File SUBCONT [PRX] : Endif
  Filter [LUP] Where [F:LUP]SSS = GIDENT
  For [LUP]LUP2
    Filter [SBG] Where [F:SBG]BPRNUM = [F:LUP]OBJNUM
    For [SBG]
      If SZCRY = [F:SBG]CRY Then
        IZIPLEN = len([F:SBG]ARACOD)
        If left$(SZZIP, IZIPLEN) = [F:SBG]ARACOD Then
          IMUSTDEL = 0
          Break
        Else
          IMUSTDEL = 1
        Endif
      Else
        IMUSTDEL = 1
      Endif
    Next
    If IMUSTDEL Then
      Read [PRX]PRX0=[F:LUP]OBJNUM
      If !fstat Then
        If [F:PRX]EVRARA = 2 Then
          IMUSTDEL = 0
        Endif
      Endif
    Endif
    If IMUSTDEL Then
      Call DEBTRANS From GLOCK
      Trbegin [LUP]
      Delete [LUP]Curr
      If fstat Then
        GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
        GERR = 1
        Rollback
        Filter [SBG]
        # FGR 08/02/2010 : X3SUIVI60986
        #Return
        IERROR = 1
        Break
      Else
        Commit
      Endif
    Endif
    Filter [SBG]
  Next
  Filter [LUP]
  If IERROR Then
    # FGR 08/02/2010 : X3SUIVI60986
    Return
  Endif
Return

##########################################################################################################
$LKUPARA
Local Char ZSWHERE(250)(20)
Local Char ZSOR(6)
Local Integer ITER
Local Integer IINDICE

  If !clalev([F:SBG]) : Local File SBGEO [SBG] : Endif
  If !clalev([F:PRX]) : Local File SUBCONT [PRX] : Endif
  IZIPLEN = len(SZZIP)
  #
  Raz ZSWHERE
  ZSOR = ""
  IINDICE = 0
  ZSWHERE(IINDICE) = "[F:SBG]CRY = SZCRY"
  For ITER = 1 To IZIPLEN
    If ITER = 1 Then
      ZSWHERE(IINDICE) = ZSWHERE(IINDICE) - "and ("
    Endif
    IINDICE += 1
    ZSWHERE(IINDICE) = ZSOR - "[F:SBG]ARACOD = left$(SZZIP," + num$(ITER) +")"
    ZSOR = "or"
  Next ITER
  If IZIPLEN > 0 Then
    IINDICE += 1
    ZSWHERE(IINDICE) = ")"
  Endif
  #
  Filter [SBG] Where evalue(ZSWHERE)
  For [SBG]SBG1
    Read [BPR]BPR0=[F:SBG]BPRNUM
    If !fstat Then
      If [F:BPR]PRVFLG = 2 Then
        Read [LUP]LUP3=[F:SBG]BPRNUM;GIDENT
        If fstat Then
          Call DEBTRANS From GLOCK
          Trbegin [LUP]
          [F:LUP]OBJNUM = [F:SBG]BPRNUM
          [F:LUP]RESNUM = IRESNUM
          [F:LUP]SSS = GIDENT
          [F:LUP]CREDAT = date$
          Write [LUP]
          If fstat Then
            GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
            GERR = 1
            Rollback
            Break
          Else
            Commit
            IRESNUM += 1
          Endif
        Else
          Call DEBTRANS From GLOCK
          Trbegin [LUP]
          [F:LUP]OBJNUM = [F:SBG]BPRNUM
          [F:LUP]RESNUM = IRESNUM
          [F:LUP]SSS = GIDENT
          [F:LUP]CREDAT = date$
          Rewrite [LUP]
          If fstat Then
            GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
            GERR = 1
            Rollback
            Break
          Else
            Commit
            IRESNUM += 1
          Endif
        Endif
      Endif
    Endif
  Next
  Filter [SBG]
  If !GERR Then
    #Chargement des prestataires toutes zones.
    Filter [PRX] Where [F:PRX]EVRARA = 2 Order By [F:PRX]RATHOU Desc
    For [PRX]
      Read [BPR]BPR0=[F:PRX]BPRNUM
      If !fstat Then
        If [F:BPR]PRVFLG = 2 Then
          Read [LUP]LUP3=[F:PRX]BPRNUM;GIDENT
          If fstat Then
            Call DEBTRANS From GLOCK
            Trbegin [LUP]
            [F:LUP]OBJNUM = [F:PRX]BPRNUM
            [F:LUP]RESNUM = IRESNUM
            [F:LUP]SSS = GIDENT
            [F:LUP]CREDAT = date$
            Write [LUP]
            If fstat Then
              GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
              GERR = 1
              Rollback
              Break
            Else
              Commit
              IRESNUM += 1
            Endif
          Else
            Call DEBTRANS From GLOCK
            Trbegin [LUP]
            [F:LUP]OBJNUM = [F:PRX]BPRNUM
            [F:LUP]RESNUM = IRESNUM
            [F:LUP]SSS = GIDENT
            [F:LUP]CREDAT = date$
            Rewrite [LUP]
            If fstat Then
              GMESSAGE = mess(297,196,1) #Erreur lecture. La recherche a été abandonnée.
              GERR = 1
              Rollback
              Break
            Else
              Commit
              IRESNUM += 1
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [PRX]
  Endif
Return

##########################################################################################################
# Nettoie la table SEARESULT d'éventuelles sorties par plantage.
#########################################################
Subprog CLEANLUP
Local Date DMON

  DMON = date$ - 15
  Call DEBTRANS From GLOCK
  Trbegin [LUP]
  Delete [LUP] Where [F:LUP]CREDAT <= DMON
  If fstat Then
    Rollback
  Else
    Commit
  Endif
End
