#    Modification
#    MWA - 15.03.2016 FQ112798 Prise en compte d'une nième modernisation dans l'exercice
#    MWA - 15.03.2016 FQ115034 Dotation erronée si modernisation est effectuée sur dernière période d'amortissement
#    MWA - 11.06.2012 FQ80825  Arrêt/redemarrage modes roumains
#    MWA - 17.01.2012 FQ72372  Dégressif  polonais
#    MWA - 03.12.2010 FQ67577  Gestion des modes polonais


#***********************************************************
#
#         D O T A T I O N   -   P E R I O D E
#
#   M o d e   a m o r t i s s e m e n t   P O L O N A I S
#
#***********************************************************
#
# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


#
#=====================================================================
#  M O D E S    D ' A M O R T I S S E M E N T    S T A N D A R D S
#=====================================================================
#
#***********************************************************
#      D O T A T I O N   -   E X E R C I C E
#***********************************************************

#########################################################
$CAL_DOT_PER_ML


      #If ( [M:DIV]BDEBUG and [M:DIV]DTFNPER >= [31/03/2009] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
      #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

      WEXCPER = 0.
      WDOTPER = 0.

      Local Decimal L_DOTEXEREF
      Case [M:DIV]TYPCAL
          When "R" : L_DOTEXEREF =[M:DIV]DOTEXEREF
          When "T" : L_DOTEXEREF =[M:DIV]DOTEXEREFT
          When "I" : L_DOTEXEREF =[M:DIV]DOTEXEREFI
      Endcase

      # La saisonnalité est-elle à appliquer pour le plan
      Local Integer L_SESFLG
      L_SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

      # Si la modernisation n'est pas à prendre en compte,
      # elle n'entre pas dans la détermination de la durée de détention.
      Local Date L_MDRDAT
      # FQ112798
      If ([M:DIV]BMDR) Then
        If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
          L_MDRDAT = [M:DIV2]LSTMDRDAT
        Else
          L_MDRDAT = [F:DEPC]KMDRDAT
        Endif
      Else
        L_MDRDAT = [0/0/0]
      Endif

      # Détention dans la période [P-1 à Pc]
#     Call  KPL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, L_MDRDAT, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,
#&           [M:DIV]PSEPLN, [M:DIV]SESFLG, WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= L_MDRDAT
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
      Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
      WDURDET = [M:DIV]RV(1)

      # Détention dans l'exercice
#     Call  KPL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,
#&           [M:DIV]PSEPLN, [M:DIV]SESFLG, WDETEXE) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
      Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
      WDETEXE = [M:DIV]RV(1)

      # Durée de l'exercice de reférence
      Local Integer WDUREXE
      WDUREXE = 12
      If (L_SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif

      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dot. Exerc. référence      = "+num$(L_DOTEXEREF) ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET)          ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDUREXE)          ) From =G_GLOB0

      #-1 -----------
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
        Endif
      #-1 -----------
      Else
        # Dotation de la période n
        #-2 -----------
        If ( abs(PCUMP_1) - abs([M:DIV]MDRCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
        Else
          WDOTPERCUM = L_DOTEXEREF * ( WDURDET / WDUREXE)
          #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
          [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)      ) From =G_GLOB0
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)         ) From =G_GLOB0
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1 avant modern.    = "+num$([M:DIV]MDRCUMP_1)) From =G_GLOB0
          WDOTPER    = WDOTPERCUM - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
          If (abs(WDOTPERCUM) >= abs(PDOTEXE) or [F:DEPC]PERENDDAT = [F:DEPC]ENDDPRDAT) Then
            # FQ115034
            #WDOTPER    = PDOTEXE - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
            WDOTPER    = PDOTEXE - PCUMP_1
          Endif
        Endif
      Endif
      #-1 -----------

      Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)    ) From =G_GLOB0

Return



#########################################################
$CAL_DOT_PER_MD

      # Degressif polonais # FQ72372

      #If ( [M:DIV]BDEBUG and [M:DIV]DTFNPER >= [31/05/2010] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
      #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

      WEXCPER = 0.
      WDOTPER = 0.

      Local Decimal L_LINEXEREF
      Local Decimal L_LINPERREF
      Case [M:DIV]TYPCAL
          When "R" : L_LINEXEREF =[M:DIV]DOTEXEREF  : L_LINPERREF =[M:DIV]DOTEXEREF /12
          When "T" : L_LINEXEREF =[M:DIV]DOTEXEREFT : L_LINPERREF =[M:DIV]DOTEXEREFT/12
          When "I" : L_LINEXEREF =[M:DIV]DOTEXEREFI : L_LINPERREF =[M:DIV]DOTEXEREFI/12
      Endcase
      #Call CAL_ARRONDI_MNT (L_LINPERREF, [M:DIV]CUR, L_LINPERREF) From =G_GLOB8
      [M:DIV]PV(0)= L_LINPERREF : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : L_LINPERREF = [M:DIV]RV(1)

      # La saisonnalité est-elle à appliquer pour le plan
      Local Integer L_SESFLG
      L_SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

      # Si la modernisation n'est pas à prendre en compte,
      # elle n'entre pas dans la détermination de la durée de détention.
      Local Date L_MDRDAT
      # FQ112798
      If ([M:DIV]BMDR) Then
        If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
          L_MDRDAT = [M:DIV2]LSTMDRDAT
        Else
          L_MDRDAT = [F:DEPC]KMDRDAT
        Endif
      Else
        L_MDRDAT = [0/0/0]
      Endif

      # Détention dans la période [P-1 à Pc]
#     Call  KPL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, L_MDRDAT, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,
#&           [M:DIV]PSEPLN, [M:DIV]SESFLG, WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= L_MDRDAT
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
      Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
      WDURDET = [M:DIV]RV(1)

      # Détention dans l'exercice
#     Call  KPL_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,
#&           [M:DIV]PSEPLN, [M:DIV]SESFLG, WDETEXE) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= L_MDRDAT
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
      Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
      WDETEXE = [M:DIV]RV(1)

      # Durée de l'exercice de reférence
      Local Integer WDUREXE
      WDUREXE = 12
      If (L_SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET)     ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDETEXE)     ) From =G_GLOB0

      #-1 -----------
      If ([M:DIV]LINFLG <> G_OUI) Then
        # Dégressif
        #-2 -----------
        If (WDETEXE = 0 ) Then
          WDOTPER = 0.
          WEXCPER = 0.
          If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
          Endif
        #-2 -----------
        Else
          # Dotation de la période n
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = (PDOTEXE - [M:DIV]MDRCUMP_1) * ( WDURDET / WDETEXE)
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)    ) From =G_GLOB0
            Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)       ) From =G_GLOB0
            Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1 avant modern.    = "+num$([M:DIV]MDRCUMP_1) ) From =G_GLOB0
            WDOTPER    = WDOTPERCUM - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
            If (abs(WDOTPERCUM) >= abs(PDOTEXE - [M:DIV]MDRCUMP_1) ) Then
              WDOTPER    = PDOTEXE - PCUMP_1
            Endif
          Endif
        Endif
        #-2 -----------
      #-1 -----------
      Else
        # Linéaire
      #-1 -----------
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      #-1 -----------
      Else
        # Dotation de la période n
        #-2 -----------
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Else
          WDOTPERCUM = L_LINEXEREF * ( WDURDET / WDUREXE)
          #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
          [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)    ) From =G_GLOB0
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)       ) From =G_GLOB0
          Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1 avant modern.    = "+num$([M:DIV]MDRCUMP_1) ) From =G_GLOB0
          WDOTPER    = WDOTPERCUM - ( PCUMP_1 - [M:DIV]MDRCUMP_1 )
          If (abs(PCUMP_1 + WDOTPER) >= abs(PDOTEXE) or [F:DEPC]PERENDDAT = [F:DEPC]ENDDPRDAT) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Endif
        Endif
      Endif
      #-1 -----------
      Endif
      #-1 -----------

      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1) ) From =G_GLOB0

Return

#***********************************************************
#
#         D O T A T I O N   -   P E R I O D E
#
#   M o d e   a m o r t i s s e m e n t   R O U M A I N
#
#***********************************************************
#
# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


#
#=====================================================================
#  M O D E S    D ' A M O R T I S S E M E N T    S T A N D A R D S
#=====================================================================
#
#***********************************************************
#      D O T A T I O N   -   P E R I O D E
#***********************************************************

$CAL_DOT_PER_RL

      #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

      WDTDBAMT = [M:DIV]DTDBAMTREG

  #- 0 ------------------------------------------
    If ( ([F:DEPC]KNBMSTPDEP = 0  and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP)          or
&        ([F:DEPC]KNBMSTPDEP <> 0 and find ([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSRSTPR) <> 0)  ) Then

      # Linéaire
      #------------
      # Détention dans la période [P-1 à Pc]
#     Call  KRO_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
      WDURDET = [M:DIV]RV(1)

      # Détention dans l'exercice
#     Call  KRO_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE   : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= WDTDBAMT         : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
      WDETEXE = [M:DIV]RV(1)
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET) ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDETEXE) ) From =G_GLOB0

      #-1 -----------
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      #-1 -----------
      Else
        # Dotation de la période n
        #-2 -----------
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Else
          WDOTPERCUM = ( PMNTREF * (WDURDET / WDETEXE) )
          #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
          [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
          WDOTPER    = WDOTPERCUM - PCUMP_1
        Endif
        # Amt Exceptionnel  de la période n
        #-2 -----------
        If ( PAMTEXC <> 0 ) Then
          If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
            WEXCPER = 0
          Else
          WDOTEXCCUM = ( PAMTEXC * (WDURDET / WDETEXE) )
          #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
          [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
          Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
          WEXCPER    = WDOTEXCCUM - PEXCP_1
          Endif
        Endif
        #-2 -----------
      Endif
      #-1 -----------

      Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)    ) From =G_GLOB0

  #- 0 ------------------------------------------
  Else
      # Résiduel
      #------------
      # Détention dans la période [P-1 à Pc]
#     Call  CAL_DUR_DET
#&          ([F:DEPC]PERSTRDAT, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [F:DEPC]PERSTRDAT : [M:DIV]PD(1)= [M:DIV]DTFNPER   : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL     : [M:DIV]PD(4)= WDTDBAMT         : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG  : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)

      # Détention dans l'exercice
#     Call  CAL_DUR_DET
#&          ([F:DEPC]PERSTRDAT, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, WDTDBAMT,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From =G_GLOB4PL
      [M:DIV]PD(0)= [F:DEPC]PERSTRDAT : [M:DIV]PD(1)= [M:DIV]DTFNEXE   : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL     : [M:DIV]PD(4)= WDTDBAMT         : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG  : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDETEXE = [M:DIV]RV(1)
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET) ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDETEXE) ) From =G_GLOB0

      #-1 -----------
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      #-1 -----------
      Else
        # Dotation de la période n
        #-2 -----------
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Else
          WDOTPER    = ( (PDOTEXE - PCUMP_1) * (WDURDET / WDETEXE) )
        Endif
        # Amt Exceptionnel  de la période n
        #-2 -----------
        If ( PAMTEXC <> 0 ) Then
          If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
            WEXCPER = 0
          Else
            WEXCPER = ( (PDOTEXE - PEXCP_1) * (WDURDET / WDETEXE) )
          Endif
        Endif
        #-2 -----------
      Endif
      #-1 -----------

      Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)    ) From =G_GLOB0
  Endif
  #- 0 ------------------------------------------

Return

#########################################################
$CAL_DOT_PER_RX

Local Decimal WDURD50    : WDURD50     = 0.     : # Durée restant à amortir à 50%

      #If ( [M:DIV]BDEBUG and [M:DIV]DTFNPER >= [31/10/2013] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
      #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

      WEXCPER = 0.
      WDOTPER = 0.

      # Fin du 12ème mois à 50%  - FQ80825
      Local Date WDTFN50
      WDTFN50 = func GLOBI9.CAL_DAT_PLUS( [M:DIV]DTDBAMTREG-1, 12+[F:DEPC]KNBMSTPDEP, [M:DIV]TYPPRODAT )
      # Ajustement à la fin du mois
      WDTFN50 = func GLOBB9.CAL_DAT_DERN( WDTFN50 , "M")
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - 12 mois à 50% soit jusqu'au  " + num$(WDTFN50) ) From =G_GLOB0


      # 50% de la valeur amortissable arrondie dans la devise du contexte
      Local Decimal WVALA50
      #Call CAL_ARRONDI_MNT ([M:DIV]VALAMT * 0.5, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
      [M:DIV]PV(0)= [M:DIV]VALAMT * 0.5 : [M:DIV]PC(0)= [M:DIV]CUR
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WVALA50 = [M:DIV]RV(1)

      # Détention dans l'exercice
#     Call  KRO_DUR_DET
#&              ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, DIV.DTDBAMTREG,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDETEXE) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
      WDETEXE = [M:DIV]RV(1)

      # Détention dans la période [P-1 à Pc]
#         Call  KRO_DUR_DET
#&              ([M:DIV]EXEDATREF, [M:DIV]DTFNPER, [M:DIV]DATNUL, [M:DIV]DATNUL, DIV.DTDBAMTREG,
#&              [M:DIV]DTFNAMT, [M:DIV]DATSORREG , [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
      WDURDET = [M:DIV]RV(1)

      # Durée de l'exercice de reférence
      Local Integer WDUREXE
      WDUREXE = 12

      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée détention [P-1 à Pc] = "+num$(WDURDET)          ) From =G_GLOB0
      Call ECR_FICH("FS1",8,"CAL_DOT_PER - Durée Exercice             = "+num$(WDUREXE)          ) From =G_GLOB0

      #-1 -----------
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA and abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Endif
      #-1 -----------
      Else
        # Dotation de la période n
        #-2 -----------
        If ([M:DIV]DTFNPER <= WDTFN50) Then
          # =============================
          # ===  50% selon détention  ===
          # =============================
          #-3 -----------
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( WVALA50 * (WDURDET / WDUREXE) )
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          # Amt Exceptionnel  de la période n
          #-3 -----------
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WDURDET / WDETEXE) )
            #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-3 -----------
        #-2 -----------
        Elsif( WDTFN50 < [M:DIV]DTFNEXE and func GLOBB9.CAL_DAT_INSIDE(WDTFN50, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
          # =====================================
          # ==  linéaire roumain avec du 50% ==
          # =====================================
          #--
          # Durée de détention à 50%
      #   Call  KRO_DUR_DET
      #&        ([M:DIV]EXEDATREF, WDTFN50,        [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
      #&         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
          [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= WDTFN50 : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
          WDURD50 = [M:DIV]RV(1)
          If ([M:DIV]ERROR) Then : End : Endif
          Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée Détention à 50% =" + num$(WDURDET) ) From =G_GLOB0
          # Durée de détention dans l'exercice en linéaire
          WDURDET -= WDURD50
          Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée Dét. en linéaire=" + num$(WDURDET) ) From =G_GLOB0
          # Durée de l'exercice en linéaire
          WDETEXE -= WDURD50
          Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_LP - Durée Dét. en linéaire=" + num$(WDURDET) ) From =G_GLOB0

          # Linéaire roumain
          #-3 -----------
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( (PDOTEXE-(WVALA50-[F:DEPC]DPRCUM)) * (WDURDET / WDETEXE) )
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
            WDOTPER    = WDOTPERCUM - (PCUMP_1 - (WVALA50-[F:DEPC]DPRCUM))
          Endif
          # Amt Exceptionnel  de la période n
          #-3 -----------
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( PAMTEXC * (WDURDET / WDETEXE) )
            #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-3 -----------
        #-2 -----------
        Else
          # ==========================
          # ===  Linéaire roumain  ===
          # ==========================
          # Durée de détention résiduel dans l'exercice
        # Call  CAL_DUR_DET
        #&      ([F:DEPC]PERSTRDAT, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
        #&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
          [M:DIV]PD(0)= [F:DEPC]PERSTRDAT : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From =G_GLOB8
          WDURDET = [M:DIV]RV(1)
          If ([M:DIV]ERROR) Then : End : Endif
          Call ECR_FICH("FS1", 7, "CAL_DOT_PER - Durée Dét. Rési Exe.  =" + num$(WDURDET) ) From =G_GLOB0


          #-3 -----------
          If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
            WDOTPER    = PDOTEXE - PCUMP_1
          Else
            WDOTPERCUM = ( (PDOTEXE - PCUMP_1) / WDURDET ) + PCUMP_1
            #Call CAL_ARRONDI_MNT (WDOTPERCUM, [M:DIV]CUR, WDOTPERCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTPERCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$(WDOTPERCUM)) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)   ) From =G_GLOB0
            WDOTPER    = WDOTPERCUM - PCUMP_1
          Endif
          # Amt Exceptionnel  de la période n
          #-3 -----------
          If ( PAMTEXC <> 0 ) Then
            If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
              WEXCPER = 0
            Else
            WDOTEXCCUM = ( (PAMTEXC - PEXCP_1) / WDURDET ) + PEXCP_1
            #Call CAL_ARRONDI_MNT (WDOTEXCCUM, [M:DIV]CUR, WDOTEXCCUM) From =G_GLOB8
            [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXCCUM = [M:DIV]RV(1)
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Période P-1 + Pc    = "+num$(WDOTEXCCUM) ) From =G_GLOB0
            Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Excpt. Cumul P-1           = "+num$(PEXCP_1)    ) From =G_GLOB0
            WEXCPER    = WDOTEXCCUM - PEXCP_1
            Endif
          Endif
          #-3 -----------
        Endif
        #-2 -----------
      Endif
      #-1 -----------

      Call ECR_FICH ("FS1",8,"CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)    ) From =G_GLOB0

Return

#########################################################
$CAL_DOT_PER_RD
  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]PERSTRDAT >= [01/01/2016] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  Local Integer I_P

  WDOTPER = 0.
  WEXCPER = 0.

#  #-0 -------------------------------------------------------
#  If ( [F:DEPC]FIYSTRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]FIYENDDAT = [F:DEPC]PERENDDAT ) Then
#    # Une période d'un exercice
#    WDOTPER = [M:DIV]DOTEXE
#    I_P = find([F:DEPC]PERENDDAT, [M:DIV]PERENDDAT)
#    [F:DEPC]KBIRDAT  = [M:DIV2]BIRDAT(I_P-1)
#    [F:DEPC]KBIRNBV  = [M:DIV2]BIRNBV(I_P-1) + [F:DEPC]RSDVAL
#  Else
      #- 1 -------------------------
      If ( [M:DIV]DTDBAMTREG < [F:DEPC]PERENDDAT ) Then
        #-2 -----------
        If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [F:DEPC]PERENDDAT ) Then
          I_P = find([F:DEPC]PERENDDAT, [M:DIV2]PERENDDAT)
          [F:DEPC]KBIRDAT  = [M:DIV2]BIRDAT(I_P-1)
          Case [M:DIV]TYPCAL
            When "R"
              [F:DEPC]KBIRNBV  = [M:DIV2]BIRNBV(I_P-1) + [F:DEPC]RSDVAL
              Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$([M:DIV2]DOT1AP(I_P-1)) ) From =G_GLOB0
              WDOTPER          = [M:DIV2]DOT1AP (I_P-1) - PCUMP_1
            When "T"
              [F:DEPC]KBIRNBVT = [M:DIV2]BIRNBVT(I_P-1) + [F:DEPC]RSDVAL
              Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$([M:DIV2]DOT1APT(I_P-1)) ) From =G_GLOB0
              WDOTPER          = [M:DIV2]DOT1APT(I_P-1) - PCUMP_1
            When "I"
              [F:DEPC]KBIRNBVI = [M:DIV2]BIRNBVI(I_P-1) + [F:DEPC]RSDVAL
              Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Dotation période P-1 + Pc  = "+num$([M:DIV2]DOT1API(I_P-1)) ) From =G_GLOB0
              WDOTPER          = [M:DIV2]DOT1API(I_P-1) - PCUMP_1
          Endcase
          Call ECR_FICH("FS1", 8, "CAL_DOT_PER - Cumul P-1                  = "+num$(PCUMP_1)) From =G_GLOB0
        Endif
        #-2 -----------
      Endif
      #- 1 -------------------------
#  Endif
#  #-0 -------------------------------------------------------

Return

