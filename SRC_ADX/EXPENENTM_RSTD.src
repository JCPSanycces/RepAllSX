#<AdxTL>@(#)4.0.0.0 $Revision$
# Représentation EXPENENTM

###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "EXS"
   Case [L]AEVENT
    When "AREAD_AFTER"            : Gosub AREAD_AFTER
    When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
    When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
  Endcase
  When ""
   Case [L]AEVENT
    When "AQUERY_TRANS_AFTER" :  Gosub AQUERY_TRANS_AFTER
  Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Case [L]CURPRO
 When "EXS.DATEXS" : Gosub DATEXS
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##########################################################################################################
$AREAD_AFTER
Gosub ATTRIBUTE_AMTATI
Gosub ATTRIBUTE_DIMCEN
Return

$AINSERT_CONTROL_BEFORE
$AUPDATE_CONTROL_BEFORE
Local File FACILITY  [FCY]
Local File COMPANY   [CPY]
Local File GACM      [GCM]
Local File GLED      [LED]
Local File TABEXPENS [TES]
Local File GACCCODE  [CAC]

Read [FCY]FCY0=this.FCY
If fstat<>[V]CST_AOK
 ASTATUS = fmet this.ASETERROR("FCY",mess(15,104,1),[V]CST_AERROR)
 Return
Endif
this.CPY = [F:FCY]LEGCPY
If this.CUR=""
 this.CUR = [F:CPY]ACCCUR # The control label occurs and the error message is displayed
 If this.CUR="" : Return : Endif
Endif

Read [CPY]CPY0=this.CPY
Gosub LOAD_CODEXPENS From EXPENSES_CSTD
If this.CODEXP<>""
 Read [TES]TES0 = this.CODEXP
 If fstat=[V]CST_AOK
  For I=1 To maxtab(this.CODEXPENS)
   If this.CODEXPENS(I).LED<>"" # & this.CODEXPENS(I)<>null & !find(this.CODEXPENS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
    Read [CAC]CAC0=20;[F:TES]ACCCOD;this.CODEXPENS(I).COA
    If fstat=[V]CST_AOK
     this.CODEXPENS(I).ACC = [F:CAC]ACC(0)
    Else
     this.CODEXPENS(I).ACC = ""
    Endif
   Endif
  Next
 Endif
Endif
Gosub LOAD_RATEXPENS From EXPENSES_CSTD
Return

$AQUERY_TRANS_AFTER
Local File BLOBEXPENSES [BEXP]
Look [BEXP]BEXP0=this.EXS.ACCNUM
If !fstat
 this.FLGPCT = 1
Else
 this.FLGPCT = 0
Endif
Return

##################
$DATEXS
Case [L]ARULE
 When "INIT" : Gosub DATEXS_INIT
Endcase
Return

$DATEXS_INIT
## Mobility : there is a difference with the initialization of the date
## If no line is entered, the date is initialized with the date of the day,
## otherwise, the date is initialized with the higher date of the entered lines.
Local File EXPENSES [EXS2]
Filter[EXS2] Where CLB=this.ACTX.USER
If rowcount([EXS2])=0
 this.DATEXS = date$
Else
 Read [EXS2]EXS0 Last
 this.DATEXS = [F:EXS2]DATEXS
Endif
Filter [EXS2]
Return


##########################################################################################################
## Set the Readonly attribute on the CCE properties of DIMCEN collection
##########################################################################################################
$ATTRIBUTE_DIMCEN
Local File TABEXPENS [TES]
Local File GACCOUNT  [GAC]
Local Integer I,J, RES1
Read [TES]TES0 = this.CODEXP
If fstat=[V]CST_AOK
 For J=1 To maxtab(this.DIMCEN)
  If !find(this.DIMCEN(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.DIMCEN(J).DIE<>""
   ASTATUS = fmet this.DIMCEN(J).ASETATTRIBUTE('CCE','$isReadOnly','true')
   For I=1 To maxtab(this.CODEXPENS)
    If !find(this.CODEXPENS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.CODEXPENS(I).LED<>""
     Read [GAC]GAC0=this.CODEXPENS(I).COA;this.CODEXPENS(I).ACC
     If find(this.DIMCEN(J).DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
      RES1 = find(this.DIMCEN(J).DIE,[F:TES]DIE(0..dim([F:TES]DIE)-1))
      If !RES1 | [F:TES]CCEFLG(RES1-1)<>1
       ASTATUS = fmet this.DIMCEN(J).ASETATTRIBUTE('CCE','$isReadOnly','false')
      Endif
      Break
     Endif
    Endif
   Next
  Endif
 Next
Endif
Return

##########################################################################################################
## Set the Readonly attribute on the AMTATI property if the user doesn't have the functional authorization
##########################################################################################################
$ATTRIBUTE_AMTATI
If func EXPENSES_CSTD.NOUPD_AMTATI
 ASTATUS = fmet this.ASETATTRIBUTE('AMTATI','$isReadOnly','true')
Endif
Return

