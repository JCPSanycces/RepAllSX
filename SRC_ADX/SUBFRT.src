#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
#    Process Name:    SUBFRT - Freight Class management  SAM #101090
#
#    Authors:         Eric Millspaugh   Oct, 2014
#
#    Modifications:
#
######################################################################################
######################################################################################
$ACTION
Case ACTION
  When "ANNULE"     : Gosub ANNULE
  When "AFFMASK"    : Gosub AFFMASK
  When "FERME"      : Gosub FERME
  When "INICRE"     : Gosub INICRE
  When "INIMOD"     : Gosub INIMOD
  When "LIENS"      : Gosub LIENS
  When "OUVRE"      : Gosub OUVRE
  When "RAZCRE"     : Gosub RAZCRE
  When "SEL_TABLE"  : Case TABLE    : When "SELFRT" : Gosub SELFRT :  Endcase
Endcase

Return

######################################################################################
$AFFMASK
Call FMTLEG From TRTX3 # Hide LEG when single legislation folder
Gosub GRILEG
Return

######################################################################################
$RAZCRE
[M:FRT1]ENAFLG=2 : Affzo [M:FRT1]
Gosub GRILEG
Return

######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # If single leg - default the legislation field.
  Diszo [FRT1]LEG
  [M:FRT1]LEG=GDOSLEG(1)
  Affzo [FRT1]LEG : If dim([M:FRT1]ZLEG)>0  Affzo [FRT1]ZLEG : Endif
Endif
Return

######################################################################################
$ANNULE
  # Text deletion
  Delete [AXX] Where CODFIC = "FRTCLS" and ZONE = "DESAXX" and IDENT1 = [M:FRT1]FRTCLS and IDENT2 = [M:FRT1]LEG
  Delete [AXX] Where CODFIC = "FRTCLS" and ZONE = "SHOAXX" and IDENT1 = [M:FRT1]FRTCLS and IDENT2 = [M:FRT1]LEG
Return

######################################################################################
$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Return

######################################################################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONGTE) : Endif
VCOD = CLE2

Return

######################################################################################
$INIMOD

Gosub MAJ_AXX

Return

######################################################################################
$INICRE

Gosub MAJ_AXX

Return

######################################################################################
$LIENS

Call LECTEXTRA ([M:FRT1]DESAXX,"FRTCLS","DESAXX",[M:FRT1]FRTCLS,[M:FRT1]LEG) From ATEXTRA
Call LECTEXTRA ([M:FRT1]SHOAXX,"FRTCLS","SHOAXX",[M:FRT1]FRTCLS,[M:FRT1]LEG) From ATEXTRA
Affzo [M:FRT1]DESAXX,SHOAXX

Return

######################################################################################
$MAJ_AXX
  # Creation/Modification of ATEXTRA
  Call MAJTEXTRA ([M:FRT1]DESAXX,"FRTCLS","DESAXX",[M:FRT1]FRTCLS,[M:FRT1]LEG) From ATEXTRA
  Call MAJTEXTRA ([M:FRT1]SHOAXX,"FRTCLS","SHOAXX",[M:FRT1]FRTCLS,[M:FRT1]LEG) From ATEXTRA
  #    SOS libellés
  If dim([F:FRT]LANDESSHO)>0
    [F:FRT]LANDESSHO=GLANGUE+"~"+[M:FRT1]DESAXX+"~"+[M:FRT1]SHOAXX
  Endif
Return

######################################################################################
$SELFRT
If !clalev([F:FRT]) : Local File FRTCLS     [FRT] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP   [FGR] : Endif
If !clalev([F:AXX]) : Local File ATEXTRA    [AXX] : Endif
If !clalev([F:AGF]) : Local File AGRPFCY    [AGF] : Endif

Local Char    FCY(GLONFCY),CPY(GLONCPY),LEG(GLONADI),GRP(GLONAGC)
Local Integer WNOL, ERR

Local Char AUTRE_CRIT (250)
Local Char SZVIEW (GLONAVW)

LEG = PARAM(1)
FCY = PARAM(2)
CPY = PARAM(3)
GRP = PARAM(4)

If GFONCTION = "GESFRT" Then
  OBJET = "FRT"
  Return
Endif

#-- Initialize the legislation
If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Endif

If [L]LEG=""
  If [L]FCY<>""
    Call LEC_FCY([L]FCY) From CPTLEC
    Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
    [L]LEG = [F:CPY]LEG
  Elsif [L]CPY<>""
    Call LEC_CPY([L]CPY) From CPTLEC
    [L]LEG = [F:CPY]LEG
  Endif
Endif

If [L]LEG="" : [L]LEG = GCURLEG : Endif

# Setup the selection screen

Gosub OUVRE_LISTE From WOFRT
For I=1 To NBSEL
  If SELEXP(I)<>""
    COL(I) = SELEXP(I)
  Else
    COL(I) = SELZON(I)
  Endif
  TIT(I)  = SELLIB(I)
  If left$(SELFMT(I),2)="LA"
    COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
  Endif
Next I

NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)  # Choix
Call TITOBJ("FRT","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:FRT]FRTCLS"
ORDRE   = "[F:FRT]FRTCLS;[F:FRT]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------
CRITERE(1) = '1=1 & [F:FRT]ENAFLG=2'

#--Group of companies/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
  Read [F:AGF]AGF0=[L]GRP
  If !fstat
    If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
  Endif
Endif

# - Add criteria for site
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:FRT]SOC="" | ([F:FRT]SOC<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
Endif

# - Legsilation
If LEG<>""
  CRITERE(2) -= '& ([F:FRT]LEG="'+[L]LEG+'" | [F:FRT]LEG="")'
Endif

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:FRT]FRTCLS,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : No error
      # ERR=-1 : Error opening the view, attemping to reopen
      # ERR>0  : Error opening view, leave the
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGFRTYGRP"
      Local File =SZVIEW [FRTY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "FRT"
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGFRTZGRP"
      Local File =SZVIEW [FRTZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "FRT"
      Return
    Endif
  Endif
Endif

ERR = 0
Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGFRTCPY"
  Local File =SZVIEW [FRTC]
  Onerrgo
Until ERR <> -1
If ERR Then
  # Si problème, on se déroute sur le select standard
  OBJET = "FRT"
  Return
Endif

If [L]LEG<>""
 #--View throughout GCURLEG
 #--------------------------------------------------------------------------------------------------
 ## Appel à la vue
 #--------------------------------------------------------------------------------------------------
 ERR = 0
 Repeat
  # -----------------------------------------------------------------------------------------------
  # ERR=0  : Pas d'erreur, on sort
  # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
  # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
  # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
  # -----------------------------------------------------------------------------------------------
  Onerrgo ERRVUE
  SZVIEW = "LEGFRTSEL"
  Local File =SZVIEW [FRTS]
  Onerrgo
 Until ERR <> -1

 If ERR : OBJET = "FRT" : Return : Endif    :   #-- Si problème, on se déroute sur le select standard

 If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
    Link [FRT] With [F:AXX]AXX0    = "FRTCLS";"DESAXX";GLANGUE;[F:FRT]FRTCLS;[F:FRT]LEG,
&                   [F:FRTY]FRTY0 ~= [L]GRP;[F:FRT]FRTCLS;[F:FRT]SOC;[F:FRT]LEG,
&                   [F:FRTS]FRT0  ~= [F:FRT]FRTCLS;[F:FRT]LEG;[L]LEG
&                As [LFRT]
 Else
    Link [FRT] With [F:AXX]AXX0    = "FRTCLS";"DESAXX";GLANGUE;[F:FRT]FRTCLS;[F:FRT]LEG,
&                   [F:FGR]FGR1    = [L]FCY;[F:FRT]SOC,
&                   [F:FRTC]FRT0   = [F:FRT]FRTCLS;[F:FRT]LEG;[F:FRT]SOC;[L]CPY,
&                   [F:FRTS]FRT0  ~= [F:FRT]FRTCLS;[F:FRT]LEG;[L]LEG
&                As [LFRT]
 Endif

Else
 #--View without legislation
  ERR = 0
  Repeat
   # -----------------------------------------------------------------------------------------------
   # ERR=0  : Pas d'erreur, on sort
   # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
   # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
   # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
   # -----------------------------------------------------------------------------------------------
   Onerrgo ERRVUE
   SZVIEW = "LEGFRTPAR"
   Local File =SZVIEW [FRTP]
   Onerrgo
  Until ERR <> -1

 If ERR : OBJET = "FRT" : Return : Endif :  #-- Si problème, on se déroute sur le select standard

  If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
    Link [FRT] With [F:AXX]AXX0    = "FRTCLS";"DESAXX";GLANGUE;[F:FRT]FRTCLS;[F:FRT]LEG,
&                   [F:FRTZ]FRTZ0 ~= [L]GRP;[F:FRT]FRTCLS;[F:FRT]SOC;[F:FRT]LEG
&                As [LFRT]
  Else
    Link [FRT] With [F:AXX]AXX0    = "FRTCLS";"DESAXX";GLANGUE;[F:FRT]FRTCLS;[F:FRT]LEG,
&                   [F:FGR]FGR1    = [L]FCY;[F:FRT]SOC,
&                   [F:FRTC]FRT0   = [F:FRT]FRTCLS;[F:FRT]LEG;[F:FRT]SOC;[L]CPY,
&                   [F:FRTP]FRT0  ~= [F:FRT]FRTCLS;[F:FRT]LEG
&                As [LFRT]
  Endif
Endif

Default File [LFRT]
DEFPAG = 1

Return

################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

##################################################
Subprog CONTFRT(AZC,LEG,GROUPE)
Variable Char    AZC()
Value    Char    LEG
Value    Char    GROUPE

Local Integer CAS

If GFONCTION = "GESFRT" | AZC="" : End : Endif
If !clalev([F:FRT]) : Local File FRTCLS [FRT] : Endif

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
Endif

# CAS=1 => Record without Legislation (LEG = "")
# CAS=2 => Record with    Legislation (LEG <>"")

CAS = 1 : # Legislation is empty

If LEG<>""
  Read [FRT]FRT0=AZC;LEG
  If fstat
    Read [FRT]FRT0=AZC;""
  Else
    CAS = 2 : # Legislation isn't empty
  Endif
Else
  Filter [FRT] Where ENAFLG=2
  Read [FRT]FRT0(1)=[L]AZC
  Filter [FRT]
  If !fstat
    LEG = [F:FRT]LEG
    CAS = 2
  Else
    # To display the right message : either the recording is disable either it doesn't exist
    Read [FRT]FRT0(1)=AZC
  Endif
Endif

If !fstat & [F:FRT]ENAFLG<>2
  # Type de pièces : xxx Fiche inactive
  Gosub TIT From WOFRT
  GMESSAGE = TIT-":"-[L]AZC
  GMESSAGE += "\"+mess(2,126,1)
  mkstat = 2 : End
Elsif fstat
  If LEG<>""
    # LEG=FRA and the recording exists for the ITA legislation.
    Filter [FRT] Where FRTCLS=[L]AZC
    Look [FRT]FRT0 First
    Filter [FRT]
    If !fstat
      GMESSAGE = [L]AZC-":"-mess(232,107,1)-"["+[L]LEG+"]"
      mkstat = 2 : End
    Endif
  Endif
  # Fiche inexistante
  GMESSAGE = [L]AZC-":"-mess(23,100,1)
  mkstat = 2 : End
Endif

If [L]GROUPE<>"" & [F:FRT]SOC<>"" & [L]GROUPE<>[F:FRT]SOC
 Call COMPAT([L]GROUPE,[F:FRT]SOC,"") From CFYSUB
 If mkstat=2
   Gosub TIT From WOFRT
   GMESSAGE = TIT-":"-[L]AZC-[F:FRT]LEG
   GMESSAGE += "\"+mess(23,127,1)-":"-[F:FRT]SOC
   End
 Endif
Endif

If CAS=2
 Call CONTROLE("FRT","",LEG,AZC,mkstat) From CONTOBJ
Else
 Call CONTROLE("FRT","","",AZC,mkstat) From CONTOBJ
Endif

End

##################################################
Subprog TUNFRT(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer O_GNBDERNIER, O_GNBDERCLE
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(5)
  TOKILL = 1
Endif

If !clalev([F:FRT]) : Local File FRTCLS [FRT] : Endif

VCOD = COD

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
Elsif LEG=""
  Read [FRT]FRT0 = VCOD;LEG
  If fstat
    Read [FRT]FRT0(1)=VCOD
    If !fstat
      LEG = [F:FRT]LEG
    Endif
  Endif
Endif

Read [FRT]FRT0 = COD;LEG
If fstat : LEG = "" : Endif

O_GNBDERNIER = GNBDERNIER
O_GNBDERCLE = GNBDERCLE
Raz GNBDERNIER, GNBDERCLE
Call OBJET("FRT",LEG,VCOD) From GOBJET
GNBDERNIER = O_GNBDERNIER
GNBDERCLE = O_GNBDERCLE

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
######################################################################################
Subprog C_FRTCLS(VALEUR)
Variable Char    VALEUR()

If instr(0,VALEUR,"'")<>0 | instr(0,VALEUR,'"')<>0
  Call ERREUR(mess(113,123,1)) From GESECRAN : mkstat=2
Endif

End


######################################################################################
