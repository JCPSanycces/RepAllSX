#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char TP(50)(50), TV(50)(50)
Call ETAT("ITMCOST","",TP,TV) From ETAT
End

$ACTION
If ACTION="OUVRE"
    Call CONT_PRT([M]PRT) From AIMP1
Endif
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Local Integer TABUID(500), NB, LWRI
Local Char    LITMSTR(GLONITM), LITMEND(GLONITM)
Local Char    LFCY(GLONFCY), LTMP(100)
Local Integer LUID, LTYPSTR, LTYPEND, LSEQ, LDETMAT, LPRNUID, LNIV
Local Date    LDATSTR, LDATEND
Local Char    CRIT(250)(3)
Local Integer ICRIT

If !clalev([F:ICP]) : Local File ITCDETPRT [ICP] : Endif
If !clalev([F:ICC]) : Local File ITCMAT    [ICC] : Endif
Local File ITMCOST [ITC]

#Local Char VALEUR(10)
#If GFONCTION<>"AIMP"    # Si ce n'est pas une impression directe de l'état on force UID à 0 sauf...
#    VALEUR = "0"
#    Call SETPARAM("uid",NBPAR,PARAMETRE,VALEUR) From ETAT
#Endif

##... pour les fonctions de calcul de coût
#If find(GFONC1,"STD","CUT","SIM","BUD")    # Calcul du coût standard
#    If find([M:DIA]MAJ,1,2)    # Si pas de mise à jour ou mise à jour différée
#        VALEUR = num$(adxuid(1))
#        Call SETPARAM("uid",NBPAR,PARAMETRE,VALEUR) From ETAT
#    Endif
#Endif

Call GETPARAM("itmdeb",NBPAR,PARAMETRE,LITMSTR) From ETAT
Call GETPARAM("itmfin",NBPAR,PARAMETRE,LITMEND) From ETAT
Call GETPARAM("site",NBPAR,PARAMETRE,LFCY) From ETAT
Call GETPARAM("uid",NBPAR,PARAMETRE,LTMP) From ETAT
LUID = val(LTMP)
Call GETPARAM("itcseq",NBPAR,PARAMETRE,LTMP) From ETAT
LSEQ = val(LTMP)
Call GETPARAM("typdeb",NBPAR,PARAMETRE,LTMP) From ETAT
LTYPSTR = val(LTMP)
Call GETPARAM("typfin",NBPAR,PARAMETRE,LTMP) From ETAT
LTYPEND = val(LTMP)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,LTMP) From ETAT
LDATSTR = LTMP
Call GETPARAM("datfin",NBPAR,PARAMETRE,LTMP) From ETAT
LDATEND = LTMP
Call GETPARAM("detmat",NBPAR,PARAMETRE,LTMP) From ETAT
LDETMAT = val(LTMP)
Call GETPARAM("prnuid",NBPAR,PARAMETRE,LTMP) From ETAT
LPRNUID = val(LTMP)

Call GETPARAM("niv",NBPAR,PARAMETRE,LTMP) From ETAT
LNIV = val(LTMP)

# Remplissage de la table ITCDET

Call UIDADX(TABUID,NB) From TRTX3

Trbegin [ICP]

Delete [ICP] Where !find([F:ICP]CURUID,TABUID)
Delete [ICP] Where [F:ICP]CURUID=adxuid(1)

# On enrgistre le détail car l'état se base sur ces enregistrements
# S'ils n'existent pas, aucune matière n'apparaitra !
Raz CRIT, ICRIT
Call ADDCRIT(CRIT,ICRIT,"","LITMSTR<=[F:ITC]ITMREF & [F:ITC]ITMREF<=LITMEND","&") From GOBJSUB
Call ADDCRIT(CRIT,ICRIT,"","[F:ITC]STOFCY = LFCY","&") From GOBJSUB
Call ADDCRIT(CRIT,ICRIT,"","[F:ITC]UID    = LUID","&") From GOBJSUB
If LDATEND<>[0/0/0] | LDATSTR<>[0/0/0]
    Call ADDCRIT(CRIT,ICRIT,"","[F:ITC]ITCSTRDAT <= LDATEND","&") From GOBJSUB
    Call ADDCRIT(CRIT,ICRIT,"","[F:ITC]ITCENDDAT >= LDATSTR","&") From GOBJSUB
Endif
If LSEQ<>0
    Call ADDCRIT(CRIT,ICRIT,"","[F:ITC]ITCSEQ = LSEQ","&") From GOBJSUB
Endif
Call ADDCRIT(CRIT,ICRIT,"","LTYPSTR<=[F:ITC]CSTTYP & [F:ITC]CSTTYP<=LTYPEND","&") From GOBJSUB
If LPRNUID<>0
    Call ADDCRIT(CRIT,ICRIT,"","PRNUID=LPRNUID","&") From GOBJSUB
Endif

Filter [ITC] Where evalue(CRIT)
For [ITC]ITC0
    # CCC (2010-01-21) Bug 61804
    Delete [ICP] Where ITMREF = [F:ITC]ITMREF
&                    & STOFCY = [F:ITC]STOFCY
&                    & CSTTYP = [F:ITC]CSTTYP
&                    & ITCSEQ = [F:ITC]ITCSEQ
&                    & UID    = [F:ITC]UID
    Raz [F:ICP]
    # Issue 74153 - 2011-06-07 by CCC : Ce n'est pas la peine de créer les enregistrements qui ne serviront pas
    If LNIV=1
        Filter [ICC] Where QTYTOP<>0
    Else
        Filter [ICC] Where MATFLG=2
    Endif
    For [ICC] Where ITMREF = [F:ITC]ITMREF
&                 & STOFCY = [F:ITC]STOFCY
&                 & CSTTYP = [F:ITC]CSTTYP
&                 & ITCSEQ = [F:ITC]ITCSEQ
&                 & UID    = [F:ITC]UID
        [F:ICP] = [F:ICC]
        [F:ICP]CURUID=adxuid(1)
        For I=0 To max(GACTMAT,GACTMAC,GACTLAB)-1
            Raz LWRI
            Raz [F:ICP]MATCST,[F:ICP]MACCST,[F:ICP]LABCST
            If I<GACTMAT
                [F:ICP]MATCST = [F:ICC]MATCST(I)
                LWRI = 1
            Endif
            If I<GACTMAC
                [F:ICP]MACCST = [F:ICC]MACCST(I)
                LWRI = 1
            Endif
            If I<GACTLAB
                [F:ICP]LABCST = [F:ICC]LABCST(I)
                LWRI = 1
            Endif
            If LWRI
                [F:ICP]BRDCOD=I+1
                Write [ICP]
                If fstat
                    Call FSTA("ICP") From GLOCK
                    Break
                Endif
            Endif
        Next
    Next
    Filter [ICC]
    # Si aucune ligne n'a été écrite sur ITCDETPRT, il faut écrire un enreg bidon pour que l'impression se fasse
    If [F:ICP]ITMREF=""
        [F:ICP] = [F:ITC]
        [F:ICP]CURUID=adxuid(1)
        Raz [F:ICP]MATCST, [F:ICP]MACCST, [F:ICP]LABCST
        Write [ICP]
    Endif
Next

Commit

End

