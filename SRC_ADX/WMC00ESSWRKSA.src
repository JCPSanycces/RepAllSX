#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## CRUD-CLASSE ## ESSWRKSA
# 2018-10-23 06:53:26 326

Gosub TEST From WMCR_ESSWRKSA : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,UID)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# ESSWRKSA : ESSWRKSA
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet ESSWRKSA._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = ESSWRKSA.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(ESSWRKSA.ACTX.AFOLDER,nomap,"")>0
 Local File ESSWRKSA [EWSA]
 Local File ESSWRKSA [AAA_]
Else
 Local File =ESSWRKSA.ACTX.AFOLDER+".ESSWRKSA" [EWSA]
 Local File =ESSWRKSA.ACTX.AFOLDER+".ESSWRKSA" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKSA.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EWSA] With
& [AAA_]EWSA0 = UID
& As [LNK_]
Return

############################################################################################
### ESSWRKSA(WEWSA)
############################################################################################
Funprog  _MAJSQL_ESSWRKSA(WEWSA)
Variable Instance WEWSA Using C_ESSWRKSA
Local Integer ASTATUS,A_I,A_J
Default File [F:EWSA]
If WEWSA.ASTALIN=[V]CST_ANEW
 Call INICRE(WEWSA) From ASYRSUB
 SetInstance [F:EWSA] With WEWSA
 Write [F:EWSA]
 If fstat
  Call FSTA("EWSA",WEWSA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWSA.updTick = [F:EWSA]updTick
Elsif WEWSA.ASTALIN=[V]CST_ALL or WEWSA.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEWSA) From ASYRSUB
 SetInstance [F:EWSA] With WEWSA
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWSA,"ESSWRKSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EWSA]EWSA0 = [F:EWSA]UID
 If fstat
  Call FSTA("EWSA",WEWSA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWSA.updTick = [F:EWSA]updTick
Elsif WEWSA.ASTALIN=[V]CST_ADEL
 SetInstance [F:EWSA] With WEWSA
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWSA,"ESSWRKSA")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EWSA]EWSA0 = [F:EWSA]UID
 If fstat
  Call FSTA("EWSA",WEWSA,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



