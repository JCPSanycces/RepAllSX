#<AdxTL>@(#)2.0.0.0 $Revision$
##################################################################################
# TRTPSAISCM: Réception des articles sous-traités selon TRTPSAISTT   GA 10/2005  #
# ------------------------------------------------------------------------------ #
# Ce traitement est utilisé par l'action TRTPSAISCM pour l'écran IPSAISCM        #
#               il sert à gérer                                                  #
#               - le masque  écran "PTHPSCM [PSCM]"                              #
##################################################################################
# parametrages [F:PTR]STOCODMAN,[F:PTR]CONSMAT, [F:PTR]STKFLG
##################################################################################

$ACTION
#---------------------------------------#
# Action de saisie TRTPSAISCO (GTRAITE) #
#---------------------------------------#
Case ACTION
 When "INIT"         : Gosub  INIT               : # GTRAITE
 When "OUVRE_BOITE"  : Gosub  OUVRE_BOITE        : # GSAISIE
 When "TITRE"        : Gosub  TIT                  # FQ 51144
 When "SETBOUT"      : Gosub  SETBOUT            : # GSAISIE
 When "DEBUT"        : Gosub  DEB                : # GSAISIE
 When "AP_CHOIX"     : Gosub  AP_CHOIX
 When "ENR"          : Gosub  ENR
 When "AVANT_OK"     : Gosub  AVANT_OK
 When "APRES_MODIF"  : REP="M"
 When "OK"           : Gosub  OK
 When "ABA"          : Gosub  ABA
 When "END"          : Gosub  ENDF
 When "FIN"          : Gosub  FIN
 When "FINSAI"       : Gosub  FINSAI
 When "AB6_NBMAT"    : Gosub  AB6_NBMAT
 When "BB6_NBMAT"    : Gosub  BB6_NBMAT
 When "AAPRES_NBMAT" : Gosub  AAPRES_NBMAT
Endcase
Return

#-----------------------------------------------#
# Initialisations avant exécution du traitement #
#-----------------------------------------------#
$INIT
#--- Facture à recevoir comptabilisée pour cette réception ! Voulez-vous continuer ? ---#
If GREP=""
  Gosub AVANT_MOD From SUBPTHA : If !OK  FIN=1 : Return : Endif
Endif
#-----
Local Char     LBOI(GLONFEN) : LBOI     =PARAM(1)
BOITE = "IPSAISCM" : # GA à remettre si on utilise une transaction = LBOI
BCRIT = ""
Global Integer GCONSMAT : GCONSMAT = 2 : # Mode de conso des matières: à paramètrer par la suite ?
If [F:PTR]CONSMAT>=1 GCONSMAT=[F:PTR]CONSMAT Endif
Return

#########################################################################
$TIT       # FQ 51144 Titre traduit pour les transactions V6
    Call LECTEXTRA(TIT,"PURTRS","DESAXX",num$([F:PTR]PTRTYP),[F:PTR]PTRNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:PTR]PTRNUM-":"-TIT
Return
#########################################################################


#-----------------------------#
# Avant ouverture de la boite #
#-----------------------------#
$OUVRE_BOITE
#Local Char     LBOI(GLONFEN) : LBOI     =PARAM(1)
Local Shortint NOL           : NOL      =val(PARAM(2))
Local Shortint SAVNOLIGN     : SAVNOLIGN=NOL+1
Local Char     LUSCAV(2)
Local Char     LLBEFMT(GLONARP)
Local Integer  LDACCOE
Gosub OPEN_FILES_SCO From SCOLIB
#----- Ne pas relire la transaction si import -----#
If !GIMPORT
  If [F:PTR]PTRTYP<>6 | [F:PTR]PTRNUM<>GPTRNUM : # Relecture transaction si nécessaire
    Read [PTR] PTR0=6;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
  If [F:PTR]CONSMAT>=1 GCONSMAT=[F:PTR]CONSMAT Endif
Endif
Return

#-------------------------------------------------
$DEB
Case GACTION
  When "TRTPSAISCM": Gosub DEB_SAIPSCM
Endcase
Return

#-------------------------------------------------
$SETBOUT
Case GACTION
  When "TRTPSAISCM": Gosub SETB_SAIPSCM
Endcase
Return

#-------------------------------------------------
$AP_CHOIX
If REPONSE=GSTAEND
  #-- Ne pas faire d'autres contrôles on peut sortir même si non renseigné
Endif
Return

#-------------------------------------------------
$ENR
Case GACTION
  When "TRTPSAISCM": Gosub ENR_SAIPSCM
Endcase
Return

#-------------------------------------------------
$AVANT_OK
Case GACTION
  When "TRTPSAISCM": Gosub AVANT_OK_SAIPSCM
Endcase
Return

#-------------------------------------------------
$OK
Case GACTION
  When "TRTPSAISCM": Gosub OK_SAIPSCM
Endcase
Return

#-------------------------------------------------
$ABA
Case GACTION
  When "TRTPSAISCM": Gosub ABA_SAIPSCM
Endcase
Return

#-------------------------------------------------
$ENDF
Case GACTION
  When "TRTPSAISCM":
Endcase
Return

#-------------------------------------------------
$FIN
Case GACTION
  When "TRTPSAISCM": Gosub FIN_SAIPSCM
Endcase
Return

#-------------------------------------------------
$FINSAI
Case GACTION
  When "TRTPSAISCM": Gosub FINSAI_SAIPSCM
Endcase
Return


#######################################################################
#########      Actions TRTPSAISCM                            ##########
#######################################################################

$SETB_SAIPSCM
#----------------------------#
# Positionnement des boutons #
#----------------------------#
Gosub SET_BOUT_STD From GSAISIE
Return


#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEB_SAIPSCM
If dim(NOL)<0 Local Shortint NOL : Endif
NOL=nolign-1
Raz [M:PSCM]
GMODIF=2
Gosub INIT_TRSTYP
# Ordre de sous-traitance
# -----------------------
# Issue 94547 - 2014-03-06 by CCC : handle only materials
#Call CHARG_STT_EO(NOL) From SUBPTHC
Local Integer LRET
Raz LRET
Call CHARG_SCM(NOL, LRET) From SUBPTHC
If LRET : [M:PTH1]WSTOFLG(NOL) = 0 : Endif

If !GIMPORT # Issue 96008 GA 10/2014
   Affzo [M:PSCM]
Endif
# Issue 101383 GA 08/2014
# Issue 90923 GA 08/2013 pas de modif des mvts de sortie
#If !find(GREP,"C","D") : Grizo [M:PSCM] : Endif
If !find(GREP,"C","D") & [M:PTH1]CREFLG(NOL)<>0 : Grizo [M:PSCM] : Endif
Return


#---------------------------------#
# Avant l'exécution du bouton OK  #
#---------------------------------#
$AVANT_OK_SAIPSCM
Return


#---------------------------------#
# Après l'exécution du bouton OK  #
#---------------------------------#
$OK_SAIPSCM
If dim(I)<0 Local Integer I : Endif
If dim(K)<0 Local Integer K : Endif

# ---------------------------
# Détail des sorties de stock
# ---------------------------
Default Mask [PSCM]
For K=0 To [M:PSCM]NBMAT-1
  nolign=K+1
  Local Integer WRET
  Raz WRET
  # Issue 93349 GA 11/2013 suppression matière non prévue et qté=0
  If ([M:PSCM]USEQTY(K)=0 | [M:PSCM]ITMREF(K)="") & [M:PSCM]BOMSEQ(K)=0
    Local   Integer  WSCICLE
    # Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
    #WSCICLE=[M:PSCM]ORINOL+[M:PSCM]SCILIN                                       # Issue 90806 GA 08/2013
    WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PSCM]SCILIN
    Call EFFACE_LIGD_PWS("PTH",36,[M:PSCM]SCONUM,WSCICLE,[M:PSCM]SCMLIN(nolign-1),WRET) From PWSLIB
    Call DELSTOSORW(K,K,"PSCM",[M:PSCM]STOFCY(K),WRET) From STKSOR
  Else
   #----- Sauvegarde puis effacement des données écran de stock [M:SOW] -----#
    Gosub ENR_PWS_SCMD From SUBPTHC
  Endif
Next K
# Raz de WSTOFLG si toutes les sorties ne sont pas Ok
# If !find(0,[M:PSCM]WSTOFLG(0..[M:PSCM]NBMAT-1))
#   [M:PTH1]WSTOFLG([M:PSCM]ORINOL)=0
# Endif
If !GIMPORT  FIN=1 : Endif
Return

#---------------------------------#
# Après l'exécution du bouton ENR #
#---------------------------------#
$ENR_SAIPSCM
Return

#---------------------------------#
# Après l'exécution du bouton ABA #
#---------------------------------#
$ABA_SAIPSCM
If dim(K)<0 Local Integer K : Endif
# ---------------------------
# Détail des sorties de stock
# ---------------------------
Default Mask [PSCM]
For K=0 To [M:PSCM]NBMAT-1
  nolign=K+1
  Local Integer WRET
  Raz WRET
 #----- supression des enreg écran de stock -----#
  Call DELSTOSORW(K,K,"PSCM",[M:PSCM]STOFCY(K),WRET) From STKSOR
Next K
# à vérifier: faut-il réafficher ???
# Gosub DEB_SAIPSCM
Return


#---------------------------------#
# Après l'exécution du bouton OK  #
#---------------------------------#
$FIN_SAIPSCM
Return

#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIPSCM
nolign=[M:PSCM]ORINOL
If !GIMPORT # Issue 96008 GA 10/2014
   Affzo [M:PTH1]ITMREF(nolign-1)
Endif
Return



#######################################################################
#########      Actions champs de l'écran PTHPSCM [PSCM]      ##########
#######################################################################

Subprog IB_NBMAT
#----------------------------------#
# Initialisation des boutons       #
# -------------------------------- #
# B6  Stock/lot                    #
#----------------------------------#
Local Integer WMAT : WMAT = nolign-1


# Pour autoriser la saisie du détail sortie
GOUVSOR = 1
If [M:PSCM]ITMREF(nolign-1) = ""
   GBOUT3 = mess(180,198,1)    # ajout matière non prévue # Issue 93349 GA 10/2013 Action SCKFICH
   GBOUT6 = ""
Else
   GBOUT3 = ""
Endif

End


$AB2_NBMAT
#----------------------------------------------#
# Avant l'appel à l'écran de saisie des stocks #
#----------------------------------------------#
Local Shortint WMAT : WMAT=nolign-1
Return


Subprog B2_NBMAT
#----------------------------------------------------#
# Pour signaler au moteur qu'on a fait un clic droit #
#----------------------------------------------------#
GOUVSOR=16384 : # =2^14
End


Subprog B4_NBMAT
#---------------------------------------------------------------------#
# Ouverture du complément lot par clic droit (1er bit de GOUVLOT à 0) #
#---------------------------------------------------------------------#
GOUVLOT=GOUVLOT-mod(GOUVLOT,2): # Ouvert.compl.lot par clic droit (1er bit de GOUVLOT à 0)
GOUVENT=1                     : # Permet de passer le test ouverture fenêtre complément lot
End

######################################################################################
$AB6_NBMAT           # idem SUBMTK3
#------------------------------------------------------#
# Avant détail stock                                   #
#------------------------------------------------------#
Local Integer WNOLIGN : WNOLIGN = nolign
Return

######################################################################################
$BB6_NBMAT           # idem SUBMTK3
#------------------------------------------------------#
# Après détail stock                                   #
#------------------------------------------------------#
# on revient de la fenêtre détail donc à priori c'est ok
nolign = WNOLIGN
[M:PSCM]WSTODET(nolign-1) = 2
Call AV_ITMREF([M:PSCM]ITMREF(nolign-1))
Affzo [M:PSCM]ITMREF(nolign-1)
Return

######################################################################################
Subprog AVANT_NBMAT           # idem SUBMTK3
#---------------------------#
# Avant NBMAT selon SUBMTK3 #
#---------------------------#
Local Integer WOK, WMAT : WMAT = nolign-1

WOK = func ITMLIB.READ_ITM_ITF([M:PSCM]ITMREF(WMAT),[M:PSCM]STOFCY(WMAT))

Call INIZONSOR("PSCM",[M:PSCM]ITMREF(WMAT),[M:PSCM]STOFCY(WMAT),WMAT,[M:PSCM]TRSTYP,[M:PSCM]TRSCODS,"") From STKECR

If dim([M:PSCM]LOC)>0
   Call STKINIEMPS([M:PSCM]LOC(WMAT)) From STKLOC
Endif

End


######################################################################################
$AAPRES_NBMAT                 # idem SUBMTK3
#-------------------------------------------------#
# Appelé avant l'action SAISTOSOR                 #
# Permet de vérifier s'il faut la lancer ou non   #
#-------------------------------------------------#
Local Integer  WRET,WAUTO,WLINMAT
Local Integer I : I = nolign-1
Raz WRET
Raz GOUVSOR

If [M:PSCM]USEQTY(I) = 0    : Return : Endif

Call ALI_ALP("PSCM",I) From SCOSTKLIB

# Issue 95735 GA 01/2014 revérifier la correction 72505
# FQ 72505 GA 03/2011 WAUTO toujours à 2=Oui sortie automatique ssi stock disponible
If [F:PTR]STKFLG = 1 : WAUTO = 1
Else
    # Issue 102243 GA 09/2014 WMAT=>I
    If [F:PTR]STOCODMAN = 2 & [M:PSCM]STOCODL(I) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
    Else
        WAUTO = 2
    Endif
Endif
# Issue 101541 GA 08/2014 [F:SRU] must be read before OUVSOR
If [F:ITM]ITMREF<>[M:PSCM]ITMREF(I)
   Read [ITM]ITM0=[M:PSCM]ITMREF(I) : If fstat  Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF <> [M:PSCM]ITMREF(I) | [F:ITF]STOFCY <> [M:PSCM]STOFCY(I)
    Read [F:ITF]ITF0 = [M:PSCM]ITMREF(I);[M:PSCM]STOFCY(I)
    If fstat  Raz [F:ITF] : Endif
Endif
# Issue 102243 GA 09/2014 WOK=> WRET
Call LECSRU([M:PSCM]STOFCY(I),[F:ITM]TCLCOD, 29, "", "",WRET) From STKLIB
#WAUTO = 2 # Issue 95735 GA 01/2014 autoriser STOCODMAN pour forcer sortie manuelle
Call OUVSOR("PSCM",I,[M:PSCM]NBMAT,[M:PSCM]WSTOSEQ(I),WAUTO,WRET) From STKSOR
# Si GOUVSOR = 1, la fenêtre détail va s'ouvrir

# sr 05.05 demande 30321
If GOUVSOR = 1 : [M:PSCM]WSTODET(I) = 2
Elsif [M:PSCM]USEQTY(I) <> 0
    Call AV_ITMREF([M:PSCM]ITMREF(I))
    Affzo [M:PSCM]ITMREF(I)
Endif
Return

# --------------------------------------------------
# Issue 89531 GA 08/2013 idem TRTPSAISTT ?
# --------------------------------------------------
Subprog C_NBMAT
#-------------------------------------------------#
# Il y a généralement des contrôles pour vérifier #
# qu'on peut annuler ou modifier une ligne        #
#-------------------------------------------------#
GMODIF=2
Local Shortint NOL
Local Decimal  NEWMAXQTY, NEWQTE
If    status=65             : # Annulation simple
      NOL=nolign-1 : Gosub TEST_ANU
Elsif status=68 | status=83 : # Annulation multiple
      For NOL=nolign-1 To nolign1-1
          Gosub TEST_ANU
          If mkstat : Break : Endif
      Next NOL
Endif
If status=75             NOL=nolign-1  : Gosub TEST_MOD    : Endif
If status=73 | status=82 NOL=nolign-1  : Gosub TEST_INSERT : Endif
If find(status,1,4,5,20,21,26,92,93) |
&      (status>128 & status<141)         Gosub TEST_VALID  : Endif
End

$TEST_INSERT
#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If [M:PSCM]ITMREF(NOL)="" GMODIF=1 : mkstat=2 : Endif
Return

$TEST_ANU
#----------------------------------#
# Test pour annulation de la ligne #
#----------------------------------#
Return

$TEST_MOD
#------------------------------------#
# Test pour modification d'une ligne #
#------------------------------------#
If [M:PSCM]ITMREF(NOL)="" GMODIF=1 : Endif
Return

$TEST_VALID
#-----------------------------------------------#
# Test et traitement à la validation des lignes #
#-----------------------------------------------#
Return


######################################################################################
Subprog AM_ITMREF(VALEUR)         # voir SUBMTK3.AM_MATITMREF
Variable Char    VALEUR()
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:PSCM]STOFCY(nolign-1)
    Read [F:ITF]ITF0 = VALEUR;[M:PSCM]STOFCY(nolign-1)
    If fstat : Call ERREUR(mess(2,196,1)-VALEUR-[M:PSCM]STOFCY(nolign-1)) From GESECRAN
       mkstat = 1
       End
    Endif
Endif
If [F:ITG]TCLCOD <> [F:ITM]TCLCOD # Issue 93349 GA 10/2013
   Read [ITG]ITG0=[M:PSCM]STOFCY(nolign-1);[F:ITM]TCLCOD
   If fstat
       Read [ITG]ITG0="";[F:ITM]TCLCOD
       If fstat Raz [F:ITG] Endif
   Endif
Endif
[M:PSCM]STU(nolign-1)     = [F:ITM]STU
[M:PSCM]STOCODL(nolign-1) = [F:ITF]STOCOD
Affzo [M:PSCM]STU,STOCODL

  # appel INIZONSOR et STKINIEMPS pour les sorties matières
    Call INIZONSOR("PSCM",[M:PSCM]ITMREF(nolign-1),[M:PSCM]STOFCY(nolign-1),nolign-1,
&                  [M:PSCM]TRSTYP,[M:PSCM]TRSCODS,"") From STKECR
    If dim([M:PSCM]LOC)>0
       Call STKINIEMPS([M:PSCM]LOC(nolign-1)) From STKLOC
    Endif
End

######################################################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
# selon AV_MATITMREF de SUBMTK2
    Local    Decimal WQTY
    Local    Integer J
    Local    Integer WMAT : WMAT = nolign-1

    pcolor=GCOUL(0)
    If GREP <> "C" : End : Endif
# Issue 100529 GA 03/2015 added STOCODMAN condition (see SUBMTK3 or SUBPNH)
    If [M:PSCM]USEQTY(WMAT) = 0  |
&     ([F:PTR]STOCODMAN = 2 & [F:ITF]STOCOD=1 & [M:PSCM]WSTODET(WMAT) <> 2)
        pcolor = GCOUL(1)
        End
    Endif
    #Local Integer  WOK : WOK=2
    #WOK = func ITMLIB.READ_ITM_ITF([M:PSCM]ITMREF(WMAT),[M:PSCM]STOFCY(WMAT))
    # Colorisation de l'article
    # - si tout le stock à sortir n'a pas été renseigné
    # - s'il y a une quantité en rupture
    # Nouvelle ligne ou ligne modifiée
    If [M:PSCM]CREFLG(WMAT)=0 | ([M:PSCM]CREFLG(WMAT)<>0 & [M:PSCM]UPDFLG(WMAT)<>0)
             WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:PSCM]WSTOSEQ(WMAT)))
             # Tout le stock à sortir n'a pas été renseigné
             If WQTY<>[M:PSCM]USEQTY(WMAT)
                [M:PSCM]WSTODET(WMAT) = 1
                pcolor=GCOUL(1)
             Else
                WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*
&                         ([M:SOW]WSTOSEQ(J)=[M:PSCM]WSTOSEQ(WMAT)&[M:SOW]WSTOCOU(J)<>0))
                # Il y a une quantité en rupture
                If WQTY<>[M:PSCM]USEQTY(WMAT)
                   pcolor=GCOUL(2)
                Endif
             Endif
    Elsif [M:PSCM]FLGRUP(WMAT) = 1
          pcolor=GCOUL(2)
    Endif
End

######################################################################################
Subprog C_IPTDAT(VALEUR)
Variable Date    VALEUR
#On ne peut pas saisir une date > date du jour
If VALEUR > date$ : GMESSAGE = mess(129,194,1) : mkstat = 1 : End : Endif
End


Subprog AM_USEQTY(VALEUR)
Variable Decimal VALEUR
# selon AM_USEQTY de SUBMTK3
  Local Decimal WTOTUSEQTY
  Local Integer WRET : Raz WRET
  Local Integer WMAT : WMAT = nolign-1

# FQ 55088 GA 22/06/2009 inutile car cela n'enleve pas la sortie dans [M:SOW] on laisse faire le OUVSOR
#  If [M:PSCM]WSTOSEQ(WMAT)<>0
#    #----- Maj des enreg écran de stock -----#
#    Call DELSTOSORW(WMAT, WMAT,"PSCM",[M:PSCM]STOFCY(WMAT),WRET) From STKSOR
#  Endif
#  If VALEUR=0 :   End :  Endif

  #--- Attention acceptation de la valeur          ---#
  #--- sinon pb de maj du stock par CHARGE_STOSOR  ---#
  [M:PSCM]USEQTY(WMAT)=VALEUR :  Affzo [M:PSCM]USEQTY(WMAT)
  # FQ 72505 GA 03/2011 ne pas le faire 2 fois si appel depuis SUBPTHC/CHARG_ECRSCMD
  If [M:PSCM]WSTODET(WMAT) = 2
     Gosub TRT_STOCKLIGNE
  Endif
End

Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
Local Integer WASW
# Issue 97904 GA 12/2014 Message if partial receipt
If VALEUR=2 & [F:SCI]RMNEXTQTY>0 & [F:SCI]RMNEXTQTY<>[M:PTH1]QTYSTU([M:PSCM]ORINOL) & !GIMPORT
    WASW=1  # Le besoin va être soldé. Poursuivre ?
    Call AVERTIR(num$([M:PSCM]BOMSEQ(nolign-1))-[M:PSCM]ITMREF(nolign-1)-mess(53,190,1),WASW) From GESECRAN
    If WASW = 1
       VALEUR=1
    Endif
Endif
End

Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
# selon AM_SERNUM de SUBMTK3
    Local    Char    LSERF(GLONSER)
    Local    Decimal LQTYF
    Local Integer WMAT : WMAT = nolign-1
    If VALEUR<>""
       # Maj de [M:ALP]
       Call ALI_ALP("PSCM",WMAT) From SCOSTKLIB
       # Détermination no série fin
       Call CTLSORSER("PSCM",WMAT,VALEUR,[M:PSCM]USEQTY(WMAT),LSERF,LQTYF) From STKSOR
       If LQTYF=0
          Raz VALEUR, [M:PSCM]SERNUMF(WMAT)
       Else
          [M:PSCM]SERNUMF(WMAT)=LSERF
       Endif
    Else
       Raz [M:PSCM]SERNUMF(WMAT)
    Endif
End

######################################################################################
# Type de mvt stock
$INIT_TRSTYP
[M:PSCM]TRSTYP = 29           : # Menu 704: 29=Sortie SCO
Return


######################################################################################
# 1er calcul de la qté de matière consommée, puis
# Calculs suivants si la qté réceptionnée est modifiée
######################################################################################
$CALC_PSCM_USEQTY
Local Decimal WTOTUSEQTY,WUSEQTY,WRETQTY,WRCPQTY #, WCOEFFPROD
Local Integer WRET
  # Calcul automatique de la qté consommée
  # --------------------------------------
  # Si mode de conso = Immediat CONSMAT=1 ou qté forfaitaire, on consomme tout ce qui reste
  If [F:PTR]CONSMAT=1 | [M:PSCM]LIKQTYCOD(WMAT) = 2
     WUSEQTY=[M:PSCM]RETQTY(WMAT)-[M:PSCM]SCMUSEQTY(WMAT)
  Elsif [F:SCI]EXTQTY<>0
     # Si mode de conso = Proportionnel à la qté réceptionnée CONSMAT=3
     WRCPQTY=[M:PTH1]QTYSTU([M:PSCM]ORINOL)
     #WCOEFFPROD = arr(WRCPQTY / [F:SCI]EXTQTY,0.000001) # avant WCOEFFPROD mais pb arrondi
     WUSEQTY = [M:PSCM]SCMRETQTY(WMAT)  * WRCPQTY / [F:SCI]EXTQTY
     # Issue 79611 - GA 02/2012 before & [F:PTR]CONSMAT<>1
     If WUSEQTY + [M:PSCM]SCMUSEQTY(WMAT) > [M:PSCM]SCMRETQTY(WMAT) & [F:PTR]CONSMAT=2
        # Si mode de conso = Proportionnel et borné CONSMAT=2
        WUSEQTY = [M:PSCM]SCMRETQTY(WMAT)-[M:PSCM]SCMUSEQTY(WMAT)
     Endif
  Else
     Raz WRCPQTY, WUSEQTY #, WCOEFFPROD
  Endif
  If WUSEQTY < 0 : WUSEQTY = 0 : Endif
  Call QTEARR(WUSEQTY,[M:PSCM]STU(WMAT)) From TRTDIV
  [M:PSCM]USEQTY(WMAT)=WUSEQTY
  [M:PSCM]RETQTY(WMAT)=WUSEQTY  : # Qté de composant pour la qté réceptionnée article lancé

  Affzo [M:PSCM]CLEFLG(WMAT),USEQTY(WMAT),RETQTY(WMAT),SCMUSEQTY(WMAT)

Return



######################################################################################
# ATTENTION: WMAT doit pointer sur la ligne courante matière dans [M:PSCM]
######################################################################################
$TRT_STOCKLIGNE    : # selon TRT_STOCKLIGNE de SUBMTKB
# Stocks 1.5.0
Local Integer WRET, WRUP, WAUTO
Local Decimal WTOTUSEQTY,WRESTQTY,WDIS,WOLDQTY,WDIMQTY,WQTY
Local Char    WMSG(250)
Local Integer K # Issue X3-84077 - 2018-06-05 by MUARN : pour diminution automatique sortie matière

# pour avertir si une ligne n'a pas été réajustée demande 18344
# inutile sur les EO ?
Local Integer WNO_REAJUST
Raz WNO_REAJUST
Raz WRET
If [F:ITM]ITMREF <> [M:PSCM]ITMREF(WMAT)
    Read [ITM]ITM0=[M:PSCM]ITMREF(WMAT)
    If fstat : Raz [ITM] : Endif
Endif

#----- article géré en stock ?              -----#
If [M:PSCM]STOMGTCOD(WMAT)=2
  # recherche stock disponible site
  Call LECITV2([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),WRET) From MFGLIB
  # Issue 95585 & 95735 ITF et ITG sont chargées par LECITV2
  Call LECSRU([M:PSCM]STOFCY(WMAT),[F:ITM]TCLCOD, 29, "", "",WRET) From STKLIB

  #--- Issue 115110 : Added LECCVAL parameter in 10th position
  Local Char    WECCVALMAJ(GLONECS) : WECCVALMAJ=""
  If dim([M:PSCM]ECCVALMAJ)>0 & [F:SRU]ORDVER=2
    WECCVALMAJ=[M:PSCM]ECCVALMAJ(WMAT)
  Endif
  Local Integer WINTLOC
  If [M:PSCM]LOC(WMAT)<>""     # Issue 89901 GA 07/2013 parameter LPECINTLOC=1 except internal stock
    WINTLOC=1
  Else
    WINTLOC=2
  Endif
  Call STODISALL([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),36,1,WINTLOC,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
  #If [M:PSCM]LOC(WMAT)<>""     # Issue 89901 GA 07/2013 parameter LPECINTLOC=1 except internal stock
  #  Call STODISALL([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),36,1,1,1,2,"","",WDIS,WRET) From STKALL
  #Else
  #  Call STODISALL([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),36,1,2,1,2,"","",WDIS,WRET) From STKALL
  #Endif
  #--- End issue 115110

  [M:PSCM]AVAQTY(WMAT)    = WDIS + [M:PSCM]ALLQTY(WMAT)
Endif
# Issue 96382 GA 02/2014 idem SUBMTKB: si alloc partielle et insuffisante, il faut toujours relire les allocs
# FQ 51330 ne pas repasser dans ALLSTOSORW si on a déjà lu les qtés allouées
#If find([M:PSCM]ALLSTA(WMAT),4,5) &  [M:PSCM]USEQTY(WMAT) <> 0 & [M:PSCM]WSTOSEQ(WMAT)=0
# Issue 109664 by TS/GA 07/2015 Correction 96382 need to be rechecked -
#If find([M:PSCM]ALLSTA(WMAT),4,5) &  [M:PSCM]USEQTY(WMAT) <> 0
If find([M:PSCM]ALLSTA(WMAT),4,5) &  [M:PSCM]USEQTY(WMAT) <> 0 & [M:PSCM]WSTOSEQ(WMAT)=0
        Call CTLALL([M:PSCM]STOFCY(WMAT),36,[M:PSCM]SCONUM,[M:PSCM]SCILIN,[M:PSCM]SCMLIN(WMAT),
&                   [M:PSCM]TRSTYP,[M:PSCM]TRSCODS,"",1,[M:PSCM]ALLQTY(WMAT),[M:PSCM]ALLQTYSHT(WMAT),WRET) From STKALL
        #If WRET : LRET+=1 : Return : Endif # FQ 72505 GA 03/2011
        If WRET : Return : Endif # Issue 92325 GA 10/2013 don't touch LRET !

     Raz WRET
     WRUP = [F:ITM]NEGSTO - 1
    # Issue 100529 GA 03/2015 selon TS
     WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:PSCM]WSTOSEQ(WMAT)))
     If [M:PSCM]ALLQTY(WMAT)<>WQTY
        [M:ALP]TRSTYP     = [M:PSCM]TRSTYP  : # Menu 704 29=Sortie sous-traitance
        [M:ALP]TRSCOD     = [M:PSCM]TRSCODS
        [M:ALP]VCRTYP     = 36
        [M:ALP]VCRNUM     = [M:PSCM]SCONUM
        [M:ALP]VCRLIN     = [M:PSCM]SCILIN
        [M:ALP]VCRSEQ     = [M:PSCM]SCMLIN(WMAT)
        [M:ALP]STOFCY     = [M:PSCM]STOFCY(WMAT)
        [M:ALP]ITMREF     = [M:PSCM]ITMREF(WMAT)
        [M:ALP]QTY        = [M:PSCM]USEQTY(WMAT)
        [M:ALP]TYPQTY     = 2
        # FQ 55088 # Les champs STA, LOC et LOT sont des filtres exclusifs (pas préférentiels)
        #[M:ALP]STA       = [M:PSCM]STAPREF(WMAT)
        #[M:ALP]LOT       = [M:PSCM]LOTPREF(WMAT)
        #[M:ALP]LOC       = [M:PSCM]LOC(WMAT)     : # FQ 55088 ?
        #[M:ALP]PECOWNER  = [M:PSCM]STOFCY(WMAT)  : # FQ 55088 ?
        [M:ALP]BESDAT     = [M:PSCM]DLVDAT(WMAT)
        [M:ALP]PECSCOLOC  = 2
        If [M:ALP]STOLOC<>"" & max([F:TRU]LOCFLT)=2 # Issue 100529 GA 03/2015
           [M:ALP]PECINTLOC = 1  # Pas d'emplacement interne pour les matières sous-traitance V6 05/2008
        Else
           [M:ALP]PECINTLOC = 2  # Issue 100529 GA 03/2015 # not exclusive location authorized now
        Endif
        #--- Issue 101789
        If dim([M:PSCM]LOC)>0
          [M:ALP]STOLOC     = [M:PSCM]LOC(WMAT)     : # FQ 55088
        #--- Issue 101789
        Endif
        # Issue 88318 GA 05/2013 avec paramètre LCHGQTY=1 on ne voit que la qté en rupture si conso partielle
        #Call ALLSTOSORW("PSCM",WMAT,[M:PSCM]NBMAT,WRUP,1,0,WRET) From STKSOR
        Call ALLSTOSORW("PSCM",WMAT,[M:PSCM]NBMAT,WRUP,0,0,WRET) From STKSOR
        If WRET : OK = 0 : Return : Endif # FQ 72505 GA 03/2011
     Endif
     Call ALI_ALP("PSCM",WMAT) From SCOSTKLIB
     If find([M:PSCM]ALLSTA(WMAT),2,3,4,5)
        [M:ALP]ALLQTY  = [M:PSCM]ALLQTY(WMAT)
     Else
        Raz [M:ALP]ALLQTY
     Endif
Else
     Raz WRET
     WRUP = [F:ITM]NEGSTO - 1
     Call ALI_ALP("PSCM",WMAT) From SCOSTKLIB
     If find([M:PSCM]ALLSTA(WMAT),2,3,4,5)
        [M:ALP]ALLQTY  = [M:PSCM]ALLQTY(WMAT)
     Else
        Raz [M:ALP]ALLQTY
     Endif
#
# GA 07/2008 selon CCC (13/05/08) Bug 47296 : On laisse faire le OUVSOR
#     If [F:PTR]STKFLG = 2 & ([F:PTR]STOCODMAN<>2 |[F:ITF]STOCOD=2)
#        Call GENSTOSORW("PSCM",WMAT,[M:PSCM]NBMAT,WRUP,"C",WRET) From STKSOR
#     Endif
     [M:PSCM]ALLQTY(WMAT)    = [M:ALP]ALLQTY
     [M:PSCM]ALLQTYSHT(WMAT) = [M:ALP]ALLQTYSHT
Endif

# FQ 54484 ne pas raz les qtés ici: on laisse planter la sortie de stock
# si stock négatif interdit, réajustement de la qté à sortir selon le disponible
#If [F:ITM]NEGSTO < 2  & [M:PSCM]USEQTY(WMAT) > [M:PSCM]ALLQTY(WMAT)
#    [M:PSCM]USEQTY(WMAT) = [M:PSCM]ALLQTY(WMAT)
#    WNO_REAJUST = 1
#Endif
Raz WRET

# Issue 95735 GA 01/2014 revérifier la correction 72505
# FQ 72505 GA 03/2011 WAUTO toujours à 2=Oui sortie automatique ssi stock disponible
If [F:PTR]STKFLG = 1 : WAUTO = 1
Else
    If [F:PTR]STOCODMAN = 2 & [M:PSCM]STOCODL(WMAT) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
    Else
        WAUTO = 2
    Endif
Endif
#WAUTO = 2 # Issue 95735 GA 01/2014 autoriser STOCODMAN pour forcer sortie manuelle

[M:ALP]PECQLYCTL  =  1
# FQ 55088 GA 06/2009 Maj en cas de sortie partielle des composants
If [M:PSCM]WSTOSEQ(WMAT)>0
   WOLDQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTUACT(J)*([M:SOW]WSTOSEQ(J)=[M:PSCM]WSTOSEQ(WMAT)))
Else
   WOLDQTY=0
Endif
If WOLDQTY=[M:PSCM]USEQTY(WMAT)
   Return
Elsif WOLDQTY>[M:PSCM]USEQTY(WMAT)
   # on diminue la qté sortie idem BBYNBLIG dans TRTBBYBOD
   WDIMQTY=WOLDQTY-[M:PSCM]USEQTY(WMAT)
   # Issue X3-84077 - 2018-06-05 by MUARN : ne faire la diminution automatique que si une seule ligne de stock sur la matière, ou import
   K = sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WSTOSEQ(I)=[M:PSCM]WSTOSEQ(WMAT)))
   If K =1 | GIMPORT
     Call DIM_STOSORW(WMAT,"PSCM",[M:PSCM]STOFCY(WMAT),WDIMQTY,WRET) From STKSOR
   Endif
    #If WRET : LRET+=1 : Return : Endif # FQ 72505 GA 03/2011
    If WRET : Return : Endif # Issue 92325 GA 10/2013 don't touch LRET !
Else
   # Issue 100529 GA 03/2015 do not loose manual allocated stock
   # If [M:PSCM]WSTOSEQ(WMAT)<>0  # Issue 92008 GA 08/2012
   #  #----- Maj des enreg écran de stock -----#
   #  Call DELSTOSORW(WMAT, WMAT,"PSCM",[M:PSCM]STOFCY(WMAT),WRET) From STKSOR
   # Endif
   #
   # # FQ 72505 GA 03/2011: vu avec TS
   # # 1) utiliser GENSTOSORW pour affectation automatique du stock à sortir
   # # 2) forcer l'indicateur sans rupture WRUT
   # # 3) vérifier si qté ok ([M:PSCM]WSTOFLG(WMAT) est maz en cas d'anomalie)
   # #Call OUVSOR("PSCM",WMAT,[M:PSCM]NBMAT,[M:PSCM]WSTOSEQ(WMAT),WAUTO,WRET) From STKSOR
   # #

   #--- Issue 109590
   [M:ALP]QTY=[M:PSCM]USEQTY(WMAT)-WOLDQTY

   WRUP = [F:ITM]NEGSTO - 1 # Issue 89399 GA 04/2013 avant WRUP = 0
   Call GENSTOSORW("PSCM",WMAT,[M:PSCM]NBMAT,WRUP,"C",WRET) From STKSOR
   If WRET : GOK = 0 : Return : Endif
   If WOLDQTY+[M:ALP]ALLQTY<>[M:PSCM]USEQTY(WMAT)
     If dim(GSCOTRACE)>0 & GSCOTRACE>0
        # Issue 100529 GA 03/2015 open trace if not already opened
        Gosub OUVERTURE_TRACE From SUBPTHA
        # Quantité supérieure au stock disponible
        WMSG=[M:PSCM]SCONUM-mess(148,199,1)-[M:PSCM]ITMREF(WMAT)-num$([M:PSCM]BOMSEQ(WMAT))
        Call ECR_TRACE(WMSG,-1) From GESECRAN
     Endif
     #LRET+=1 # Issue 92325 GA 10/2013 don't touch LRET !
     #Return  # Issue 100529 GA 03/2015 [M:PSCM]CLEFLG(WMAT) should be affected/displayed
     # Issue 112642 - 2016-02-10 by MUARN : matière soldée à tord.
     Return
   Endif
Endif

# la qté totale consommée à contrôler est la somme de ce qui a déjà été
# consommé et de ce qui va l'être
Raz WRET
WTOTUSEQTY = [M:PSCM]USEQTY(WMAT) + [M:PSCM]SCMUSEQTY(WMAT)
Call CONT_SOLDE_MAT([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),WTOTUSEQTY,[M:PSCM]SCMRETQTY(WMAT),WRET) From SCOLIB
If WRET = 0 : [M:PSCM]CLEFLG(WMAT) = 1
Else        : [M:PSCM]CLEFLG(WMAT) = 2
Endif
Affzo [M:PSCM]CLEFLG(WMAT)

Return

######################################################################################

