#<AdxTL>@(#)11.0.0.0 $Revision$
############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return
############################################################
$AUTORIS
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC] : Endif
If clalev([F:PRH]) = 0 : Local File STOPREH    [PRH] : Endif
If clalev([F:PRE]) = 0 : Local File STOPRED    [PRE] : Endif
If clalev([F:AUS]) = 0 : Local File AUTILIS    [AUS] : Endif
Return
############################################################
$OUVRE
Local  Char    WPAR
Local  Char    WFILPRH  (250)
Local  Char    WFILPRH1  (250)
Local  Char    WFILPRH2  (250)
Local  Integer WFSTAT, WREAD, WSKIP, WLIG
Local  Integer WGCONSULT : WGCONSULT = GCONSULT
Local  Char WITMREF(GLONITM)
Local  Integer WNBITM

Local Integer WAGR

Local Integer I, J, L, M

Gosub LOAD_SCREEN
NAVIG="CONSPRH"
SUITE  = 1
RETOUR = 1
nolign = 1
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      If PARAM(I) <> ""
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:CRH1]FCY      = PARAM(I)
        Endif
      Endif
    When 2 :
      If PARAM(I) <> ""
         [M:CRH1]PRLNUM    = PARAM(I)
      Endif
    When 3 :
      If PARAM(I) <> ""
         [M:CRH1]PRHNUMSTR    = PARAM(I)
      Endif
    When 4 :
      If PARAM(I) <> ""
         [M:CRH1]PRHNUMEND    = PARAM(I)
      Endif
    When 5 :
      If PARAM(I) <> ""
         [M:CRH1]BPCORDSTR    = PARAM(I)
      Endif
    When 6 :
      If PARAM(I) <> ""
         [M:CRH1]BPCORDEND = PARAM(I)
      Endif
    When 7 :
      If PARAM(I) <> ""
         [M:CRH1]PREUSR = PARAM(I)
      Endif
    When 8 :
      If PARAM(I) <> ""
         [M:CRH1]SDHNUMSTR = PARAM(I)
      Endif
    When 9 :
      If PARAM(I) <> ""
         [M:CRH1]SDHNUMEND = PARAM(I)
      Endif
    When 10 :
      If PARAM(I) <> ""
         [M:CRH1]SHIDATSTR = PARAM(I)
      Endif
    When 11 :
      If PARAM(I) <> ""
         [M:CRH1]SHIDATEND = PARAM(I)
      Endif

  Endcase
Next I
If clalev([M:CPRH]) <> 0 & [M:CPRH]MEMO = "STD"
  [M:CRH1] = [M:CPRH]
Endif
[M:CRH1]ECFLG      = 2              # En cours
[M:CRH1]LBFLG      = 2              # Livrable
[M:CRH1]LVFLG      = 2              # Livré

[M:CRH1]PACFLG     = 2              # Colisage réalisé
[M:CRH1]PRNNPR     = 2              # Bon de prépa imprimé

Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$DEB_CRIT
[M:CPRH]   = [M:CRH1] : [M:CPRH]STOFCY = [M:CRH1]FCY

Return

############################################################
$FIN_CRIT
[M:CRH1]   = [M:CPRH] : [M:CRH1]FCY = [M:CPRH]STOFCY
Return
############################################################
$LECTURE

If [M:CRH1]FCY = ""
   NBLU = 0 : Return
Endif
Gosub TRT_FILTER
SUITE  = 0 : RETOUR = 0 : NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1 : WPAGE  = 0
    For [PRH]
        If nolign <= MAXLIG
           Gosub LOA_LIGNE
           NBLU    = 2 : nolign += 1 : NOL += 1
        Else
            Break
        Endif
    Next
    WPAGE += 1 : RETOUR = 1
    If nolign < MAXLIG : SUITE = 1:  Endif
  When 2 :
    nolign = 1 : WSKIP = WPAGE * MAXLIG : WLIG  = 0
    For [PRH]
        If WLIG >= WSKIP
           If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU    = 2 : nolign += 1 : NOL += 1
           Else
                Break
           Endif
        Else
           WLIG += 1
        Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG : SUITE = 1 : Endif
  When -1 :
    Effzo [M:CRH2] : WLIG = 0
    For [PRH]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [PRH]
         If WLIG >= WSKIP
            If nolign <= MAXLIG
               Gosub LOA_LIGNE
               NBLU = 2 : nolign += 1 : NOL -= 1
            Else
                  Break
            Endif
         Else
            WLIG += 1
         Endif
    Next
    If WPAGE = 1 : RETOUR = 1 : Endif
    SUITE  = 1
  When -2 :
    nolign = 1 : WPAGE -= 1 : WSKIP  = (WPAGE-1) * MAXLIG : WLIG   = 0
    For [PRH]
        If WLIG >= WSKIP
           If nolign <= MAXLIG
              Gosub LOA_LIGNE
              NBLU = 2 : nolign += 1
           Else
                 Break
           Endif
        Else
           WLIG += 1
        Endif
    Next
    If WPAGE = 1 : RETOUR = 1 : Endif
    NOL = 0 : nolign = MAXLIG
Endcase
$LECTURE_FIN

Filter [PRH]
Filter [PRE]
Return
############################################################
$TRT_FILTER

   Raz [M:CRH2]
   Gosub LOAD_FILTER
   If PROGSPE<>""
      ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
   Endif
   #--- Bug 59289
   Case [M]PRHKEY
        When 1 : Filter [PRH] Where evalue(WFILPRH)   &
&                                   evalue(WFILPRH1)  &
&                                   evalue(WFILPRH2)
&                Order By Key CLE = [F:PRH]SHIDAT;[F:PRH]BPCORD;[F:PRH]PRHNUM;[F:PRH]PREUSR
        When 2 : Filter [PRH] Where evalue(WFILPRH)   &
&                                   evalue(WFILPRH1)  &
&                                   evalue(WFILPRH2)
&                Order By Key CLE = [F:PRH]PRHNUM
        When 3 : Filter [PRH] Where evalue(WFILPRH)   &
&                                   evalue(WFILPRH1)  &
&                                   evalue(WFILPRH2)
&                Order By Key CLE = [F:PRH]BPCORD;[F:PRH]PRHNUM
        When 4 : Filter [PRH] Where evalue(WFILPRH)   &
&                                   evalue(WFILPRH1)  &
&                                   evalue(WFILPRH2)
&                Order By Key CLE = [F:PRH]PREUSR;[F:PRH]PRHNUM
   Endcase

Return
############################################################
$LOA_LIGNE
#
[M:CRH2]                      = [F:PRH]
#[M:CRH2]                      = [F:PRE]

If [M:CRH2]PACFLG(nolign-1) = 0 : [M:CRH2]PACFLG(nolign-1) = 1 : Endif

If [M:CRH2]PRNNPR(nolign-1) = 0 : [M:CRH2]PRNNPR(nolign-1) = 1 : Endif

If [M:CRH2]PREUSR (nolign-1) <> ""
   If [M:CRH2]PREUSR (nolign-1) <> [F:AUS]USR
      Read [F:AUS]CODUSR=[M:CRH2]PREUSR (nolign-1)
      If fstat
         Raz [F:AUS]
      Endif
   Endif
Else
    Raz [F:AUS]
Endif

If [M:CRH2]BPCORD (nolign-1) <> ""
   If [M:CRH2]BPCORD (nolign-1) <> [F:BPC]BPCNUM
      Read [F:BPC]BPC0=[M:CRH2]BPCORD (nolign-1)
      If fstat
         Raz [F:BPC]
      Endif
   Endif
Else
    Raz [F:BPC]
Endif

If [M:CRH2]PRHNUM (nolign-1) <> ""
   If [M:CRH2]PRHNUM (nolign-1) <> [F:PRE]PRHNUM
      Raz WITMREF
      WNBITM = 0
      Filter [PRE] Where [F:PRE]PRHNUM = [M:CRH2]PRHNUM (nolign-1) Order By [F:PRE]ITMREF
      For [PRE]
      If fstat
         Raz [F:PRE]
      Endif
      If WITMREF <> [F:PRE]ITMREF
        WITMREF = [F:PRE]ITMREF
        WNBITM += 1
      Endif
    Next
   Endif
Else
    Raz [F:PRE]
Endif

[M:CRH2]NBRLIG(nolign-1) = WNBITM

Return
############################################################
$LOAD_FILTER
#
#
WFILPRH = "1=1"
WFILPRH = "[F:PRH]STOFCY=[M]FCY"                                                   # Site stockage
If [M]PRLNUM <> ""
   WFILPRH = WFILPRH+"&[F:PRH]PRLNUM=[M]PRLNUM"                                    # N° liste de prépa
Endif
#                                                                                     hcb 86352
#If [M]BPCORDSTR <> "" & [M]BPCORDEND <> ""
#   WFILPRH = WFILPRH+"&[F:PRH]BPCORD>=[M]BPCORDSTR & [F:PRH]BPCORD<=[M]BPCORDEND"  # Client livré
#Endif
If [M]BPCORDSTR <> ""
   WFILPRH = WFILPRH+"&[F:PRH]BPCORD>=[M]BPCORDSTR"  # Client livré
Endif
If [M]BPCORDEND <> ""
   WFILPRH = WFILPRH+"&[F:PRH]BPCORD<=[M]BPCORDEND"  # Client livré
Endif
#If [M]PRHNUMSTR <> ""
#   WFILPRH = WFILPRH+"&[F:PRH]PRHNUM>=[M]PRHNUMSTR & [F:PRH]PRHNUM<=[M]PRHNUMEND"  # N°bon de prépa
#Endif
If [M]PRHNUMSTR <> ""
   WFILPRH = WFILPRH+"&[F:PRH]PRHNUM>=[M]PRHNUMSTR"                                 # N°bon de prépa
Endif
If [M]PRHNUMEND <> ""
   WFILPRH = WFILPRH+"&[F:PRH]PRHNUM<=[M]PRHNUMEND"                                 # N°bon de prépa
Endif
#                                                                                     hcb 86352
If [M]PREUSR <> ""
   WFILPRH = WFILPRH+"&[F:PRH]PREUSR=[M]PREUSR"                                    # Préparateur
Endif

#
WFILPRH1 = "1=1"
If [M]ECFLG = 2 or [M]LBFLG = 2 or [M]LVFLG = 2
    WFILPRH1 = WFILPRH1 +" &("
    If [M]ECFLG = 2
        WFILPRH1 = WFILPRH1 +"[F:PRH]DLVFLG = 1 "                                   #BP en cours
        If [M]LBFLG = 2 or [M]LVFLG = 2
            WFILPRH1 = WFILPRH1 + " or "
        Endif
    Endif
    If [M]LBFLG = 2
        WFILPRH1 = WFILPRH1 +"[F:PRH]DLVFLG = 2 "                                   #BP livrable
        If [M]LVFLG = 2
            WFILPRH1 = WFILPRH1 + " or "
        Endif
    Endif
    If [M]LVFLG = 2
        WFILPRH1 = WFILPRH1 +"[F:PRH]DLVFLG = 3 "                                   #BP livré
    Endif
    WFILPRH1 = WFILPRH1 + ")"
Else
    WFILPRH1 = WFILPRH1 + "&[F:PRH]DLVFLG = 4"
Endif
If [M]SDHNUMSTR <> "" & [M]SDHNUMEND <> ""
   WFILPRH1 = WFILPRH1+"&[F:PRH]SDHNUM>=[M]SDHNUMSTR & [F:PRH]SDHNUM<=[M]SDHNUMEND"  # N°livraison
Endif
If [M]SHIDATSTR <> [0/0/0] | [M]SHIDATEND <> [0/0/0]
   WFILPRH1 = WFILPRH1+"&[F:PRH]SHIDAT>=[M]SHIDATSTR&[F:PRH]SHIDAT<=[M]SHIDATEND"    # Date d'expédition
Endif
WFILPRH2 = "1=1"
If [M]PRECOD <> ""
    WFILPRH2 = WFILPRH2 + "&[F:PRH]PRECOD = [M]PRECOD"                               #Code préparation
Endif
If [M]PACFLG <> 2
    WFILPRH2 = WFILPRH2 + "&[F:PRH]PACFLG <> 2 "                                     #Colisage réalisé
Endif
If [M]PRNNPR <> 2
    WFILPRH2 = WFILPRH2 + "&[F:PRH]PRNNPR <> 2 "                                     #Bon de prépa imprimé
Endif
#
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSPRH2) 21/07/2009 09:38:54 (MAE)
######################################################################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2
If [M:CRH2]PRHNUM(nolign-1) <> ""
        GBOUT1 = mess(662,197,1)-[M]PRHNUM(nolign-1)
Else
    Raz GBOUT1
Endif

If [M:CRH2]SDHNUM(nolign-1) <> ""
        GBOUT2 = mess(129,197,1)-[M]SDHNUM(nolign-1)
Else
    Raz GBOUT2
Endif

End

#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"PRH") From SUBGTC

End

######################################################################################

