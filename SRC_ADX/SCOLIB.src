#########################################################################
# Maj réutilisée par les fonctions de SUBSCO*, ...
$DELETE_SCK
Local Integer WUPDTRBEGIN
Raz WUPDTRBEGIN

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [SCK]
   WUPDTRBEGIN=1
Endif

#
 # point d'entrée avant suppression ligne(s)
   GPOINT = "DELSCKMAJ" : Gosub ENTREE From EXEFNC
   # Issue X3-69394 - 2018-04-10 by SR : Ne supprimer que les enregistrements liés
   # à la ligne de réception "article sous-traité" en cours de suppression
   #Delete [SCK]SCK0=[F:SCK]SCONUM;[F:SCK]SCILIN
   Delete [SCK] Where SCONUM=LSCONUM & SCILIN=LSCILIN & PTHNUM=LPTHNUM
   If fstat : GOK=0 : Call FSTA("SCK") From GLOCK : Goto ROLL_DELETE_SCK : Endif

 #----- Mise à jour statistiques matière -----#
   Call VALSTA("SCK",-1) From SUBPS2

# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
Endif
Return
$ROLL_DELETE_SCK
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

########################################################################
Funprog CTRL_ALLMGT()             # extrait de TEST_DOSSIER de SUBMFGA
Local Integer WOK : WOK=0
Local Integer WRET : WRET=0
Local Char    XMESS(110)
Local Integer WALLTYP : WALLTYP=2   # FQ 55997 Alloc détaillée si allocation automatique

Gosub OPEN_FILES_SCO

# statut = ferme
If [F:SCO]SCONUM="" | [F:SCO]SCOSTA <> 1 : End WOK : Endif

# Issue 86083 GA 12/2012 Transaction avec alloc manuelle
If [F:PTR]MODALL=1 : End WOK : Endif

# Issue 79164 - 2012-03-15 by CCC : Suppression du paramètre EOMALLMGT
## l'ordre est-il alloué au moins en global(selon GEOMALLMGT)
#If GEOMALLMGT = 2 & !find([F:SCO]ALLSTA,3,5) & [F:SCO]MATLINNBR <> 0
If !find([F:SCO]ALLSTA,3,5) & [F:SCO]MATLINNBR <> 0
   # FQ 55997 Call ALLOC_EO("C", 0, [F:SCO]SCONUM, 1, 1, WRET) From SCOALL
   Call ALLOC_EO("C", 0, [F:SCO]SCONUM, WALLTYP, 1, WRET) From SCOALL
   If WRET <> 0
      # Issue 86612 GA 12/2012 pas de message, sauf si on est en saisie de réception
      #FQ 54054 pas d'erreur si alloc auto en saisie d'EO
      #If clalev([M:SCO0])<=0
      If clalev([M:PTH0])>0
        # Ordre de sous-traitance XXXX : Allocation incomplète. Suivi impossible
        XMESS = mess(641,197,1)-[F:SCO]SCONUM-":"-mess(18,190,1)
        Call MESSAGE(XMESS) From GESECRAN
        End WOK
      Else
        WOK=1
        End WOK
     Endif
   Endif
Endif
#
WOK=1
# Issue 86612 GA 12/2012
#### boucle d'analyse des matières bloquantes si rupture
###For [SCM] Where SCONUM = [F:SCO]SCONUM & SCOFLG=2 & MATSTA<>4
###    If [F:SCM]SHTQTY <> 0
###        Read [ITF]ITF0=[F:SCM]CPNITMREF;[F:SCM]STOFCY
###        If fstat : WOK=0 : Break : Endif
###        #FQ 54054 pas d'erreur si alloc auto en saisie d'EO
###        If clalev([M:SCO0])<=0 & [F:ITF]MFGSHTCOD = 1
###            XMESS = mess(157,193,1)+" ("+[F:SCM]CPNITMREF+"/"+[F:SCM]STOFCY+")"
###            Call MESSAGE(XMESS) From GESECRAN
###            WOK=0 : Break
###        Endif
###    Endif
###Next
End WOK

