#                                                                          #
# Affectation des codes statuts SCOSTA, ITMSTA, MATSTA,OPESTA              #
# dans l'ecran [M:SCOx] ou dans l'enregistrement [F:SCx]                   #
#                                                                          #
# $CTRL_ITMSTA vérifie que ITMSTA correspond aux qtés ORDQTY,CPLQTY,...    #
# $CTRL_OPESTA vérifie que OPESTA correspond aux qtés ORDQTY,CPLQTY,...    #
# $CTRL_MATSTA vérifie que MATSTA correspond aux qtés DLVQTY,USEQTY,...    #
#                                                                          #
# $SCO_SCOSTA_CLO Ordre     "Clos/Soldé"                                   #
# $SCI_ITMSTA_CLO Article   "Soldé"                                        #
# $SCS_OPESTA_CLO Service   "Soldé"                                        #
# $SCM_MATSTA_CLO Matière   "Soldée"                                       #
#                                                                          #
# $SCI_ITMTRKFLG_CAL Article   "Prix de revient calculé"                   #
# $SCS_OPETRKFLG_CAL Service   "Prix de revient calculé"                   #
# $SCM_MATTRKFLG_CAL Matière   "Prix de revient calculé"                   #
#                                                                          #
# $SCI_ITMSTA_PUR Passage du statut à  "Commandé"                          #
# $SCM_MATSTA_PUR Passage du statut à  "Commandé"                          #
# $SCS_OPESTA_PUR Passage du statut à  "Commandée"                         #
# $SCI_ITMSTA_RCP Passage du statut à  "Réceptionné"                       #
# $SCM_MATSTA_RCP Passage du statut à  "Réceptionnée"                      #
#                                                                          #
# $MAJSCOHEAD Compte les lignes détails et complète l'entête ordre ss-trait#
# $OPEN_FILES_SCO                                                          #
# $READ_SCOPTRNUM charge transaction de maj automatique des EO - FQ 78121  #
#                                                                          #
############################################################################
# Librairie de sous-programme Objets Sous-traitance                        #
############################################################################
# $REWRITE_SCO Rewrite [F:SCO] + appel de VALSTA + ?                       #
# $REWRITE_SCI Rewrite [F:SCI] + appel de VALSTA + ?                       #
# $REWRITE_SCS Rewrite [F:SCS] + appel de VALSTA + ?                       #
# $REWRITE_SCM Rewrite [F:SCM] + appel de VALSTA + ?                       #
# $REWRITE_SCK Rewrite [F:SCK] + appel de VALSTA + ?                       #
#                                                                          #
# $WRITE_SCO   Write [F:SCO] + appel de VALSTA + ?                         #
# $WRITE_SCI   Write [F:SCI] + appel de VALSTA + ?                         #
# $WRITE_SCS   Write [F:SCS] + appel de VALSTA + ?                         #
# $WRITE_SCM   Write [F:SCM] + appel de VALSTA + ?                         #
# $WRITE_SCK   Write [F:SCK] + appel de VALSTA + ?                         #
#                                                                          #
# $DELETE_SCO  Delete [F:SCO] + appel de VALSTA + ?                        #
# $DELETE_SCI  Delete [F:SCI] + appel de VALSTA + ?                        #
# $DELETE_SCS  Delete [F:SCS] + appel de VALSTA + ?                        #
# $DELETE_SCM  Delete [F:SCM] + appel de VALSTA + ?                        #
# $DELETE_SCK  Delete [F:SCK] + appel de VALSTA + ?                        #
#                                                                          #
############################################################################

#########################################################################
# Contrôle de validité (pour prod) d'un article                         #
# ITM & ITF doivent être chargés ...                                    #
#-----------------------------------------------------------------------#
Subprog CONTSCOITM(LFCY, LMSG)
Variable Char     LFCY
Value    Integer  LMSG
Local    Integer  VS
Local    Integer  WSTOMGTCOD

WSTOMGTCOD = func ITMLIB.GET_STOMGTCOD([F:ITM]ITMREF, LFCY)


Case [F:ITM]ITMSTA
    When 1:       #   Article actif = ok
    When 2,3:     #   Article non disponible (non bloquant)
              If LMSG=1
                  VS=1
                  Call AVERTIR(mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")",VS) From GESECRAN
                  If VS = 1 : mkstat = 2 : End : Endif
              Else
                  mkstat=2
                  End
              Endif
    When Default: #   Article non disponible (bloquant)
              If LMSG=1 : GMESSAGE = (mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")") : Endif
              mkstat = 2
              End
Endcase
# "L'article doit être de catégorie sous-traitée."
If [F:ITM]SCPFLG <> 2
  If LMSG=1 : GMESSAGE = mess(513,199,1) : Endif
  mkstat = 2
  End
Endif
#    Article non géré en stock
If !find(WSTOMGTCOD,2,3,4)
  If LMSG=1 : GMESSAGE = mess(147,199,1) : Endif
  mkstat = 2
  End
Endif
End

######################################################################################
Subprog FIND_BPRNUM (LITMREF,LBOMALT,LPOHFCY,LPRHFCY,LBPRNUM)
########################################################################
# RECHERCHE  FOURNISSEUR PAR DEFEAUT                                   #
#     - LITMREF    : article                                           #
#     - LBOMALT    : alternative                                       #
#     - LPOHFCY    : site commande achats                              #
#     - LPRHFCY    : site réception achats                             #
#     - LBPSNUM    : fournisseur                                       #
########################################################################
Value    Char     LITMREF
Value    Integer  LBOMALT
Value    Char     LPOHFCY
Value    Char     LPRHFCY
Variable Char     LBPRNUM

Local Integer WTROUVE : WTROUVE=1

If LBPRNUM<>"" : End : Endif

If clalev([F:ITP])=0 : Local File ITMBPS [ITP] : Endif

# Issue X3-55891 - 2018-09-13 by MUARN : exploitation table article/fournisseur/site
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS]  : Endif

#Issue X3-114520 by GEBIL 25/10/2018 : Open file if it's not already
If clalev([F:BPR])=0 : Local File BPARTNER [BPR]  : Endif

# Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
If clalev([F:ITPF])=0 : Local File ITMBPSFCY [ITPF] : Endif
Local Integer WITMBPS : WITMBPS = 0

If LITMREF<> "" and LBOMALT <> 0
  # Issue X3-55891 - 2018-09-10 by MUARN : exploitation table article/fournisseur/site
  # on cherche dans ITMBPS (art/fourn) si cette nomenclature est paramétrée
  #For [ITP] Where ITMREF=LITMREF and BOMALT=LBOMALT & DOUFLG<3
  #  LBPRNUM= [F:ITP]BPSNUM
  #  WTROUVE=2
  #  Break
  #Next
  If LPRHFCY<>""
    Link [ITPF] With [ITP] ITP0=[F:ITPF]ITMREF;[F:ITPF]BPSNUM As [ITPFX]
&               Where [F:ITPF]ITMREF=LITMREF & [F:ITPF]STOFCY=LPRHFCY & [F:ITP]BOMALT=LBOMALT & [F:ITPF]DOUFLG<3
&               Order By Key ITPF1
    For [ITPFX]
      # contrôle fournisseur non site achat
      Read [BPR] BPR0=[F:ITPF]BPSNUM : If fstat  Raz [F:BPR] : Endif
      If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>LPOHFCY & [F:BPR]FCY<>LPRHFCY)
        # contrôle fournisseur non site achat
        Read [BPS] BPS0=[F:ITPF]BPSNUM
        If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
          LBPRNUM=[F:ITPF]BPSNUM
          WTROUVE=2
          Break
        Endif
      Endif
    Next
    # on ne remonte pas au niveai article/fournisseur si GITMBPSFCY est à obligatoire
    If WTROUVE=1 & GITMBPSFCY > 1
      # on cherche dans ITMBPS (art/fourn) si cette nomenclature est paramétrée
      For [ITP] ITP1 Where ITMREF=LITMREF and BOMALT=LBOMALT & DOUFLG<3
        # contrôle fournisseur non site achat
        Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
        If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>LPOHFCY & [F:BPR]FCY<>LPRHFCY)
          # contrôle fournisseur non site achat
          Read [BPS] BPS0=[F:ITP]BPSNUM
          If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
            LBPRNUM= [F:ITP]BPSNUM
            WTROUVE=2
            Break
          Endif
        Endif
      Next
    Endif
  Elsif GITMBPSFCY > 1
    # on cherche dans ITMBPS (art/fourn) si cette nomenclature est paramétrée
    For [ITP] ITP1 Where ITMREF=LITMREF and BOMALT=LBOMALT & DOUFLG<3
      # contrôle fournisseur non site achat
      Read [BPR] BPR0=[F:ITP]BPSNUM : If fstat  Raz [F:BPR] : Endif
      If [F:BPR]BETFCY=1 | ([F:BPR]FCY<>LPOHFCY & [F:BPR]FCY<>LPRHFCY)
        # contrôle fournisseur non site achat
        Read [BPS] BPS0=[F:ITP]BPSNUM
        If [F:BPS]ENAFLG=2 & [F:BPS]DOUFLG<3 & [F:BPS]BPSTYP<>2
          LBPRNUM= [F:ITP]BPSNUM
          WTROUVE=2
          Break
        Endif
      Endif
    Next
  Endif

Endif
# Issue 86491 GA 02/2013 cas où LBOMALT n'est pas associée sur la fiche ITP
#Elsif LITMREF<>""
If LITMREF<>"" & WTROUVE=1
  # Issue X3-55891 - 2018-08-22 by MUARN : exploitation table article/fournisseur/site
  # on cherche dans ITMBPS (art/fourn) si un fournisseur est associé à cet article
  # For [ITP] ITP1 Where ITMREF=LITMREF & DOUFLG<3
  #    LBPRNUM= [F:ITP]BPSNUM
  #    Break
  # Next
  Call DEFBPSNUM(LITMREF,LPOHFCY,LPRHFCY,"",1,LBPRNUM,WITMBPS) From TRTACHDEF1
  # End issue X3-55891
Endif
End


######################################################################################
Subprog FIND_BOMALT (LITMREF,LBPRNUM,LBOMALT)
Value    Char     LITMREF
Value    Char     LBPRNUM
Variable Integer  LBOMALT

Local    Char    WITMREF(GLONITM): WITMREF=LITMREF
Local    Char    WBPRNUM(GLONBPR): WBPRNUM=LBPRNUM
Gosub READ_ITP From ITMLIB

If [F:ITP]BOMALT <> 0
   LBOMALT        = [F:ITP]BOMALT
# Issue 85534 GA 10/2012 ne rien proposer sinon
#Else
#   Filter [BOH] Where ITMREF=LITMREF & BOMALTTYP = 3 & USESTA=2
#&                  &   ( BOHSTRDAT=[0/0/0] | BOHSTRDAT<=date$ )
#&                  &   ( BOHENDDAT=[0/0/0] | BOHENDDAT>=date$ )
#   Read [BOH] First
#   LBOMALT        = [F:BOH]BOMALT
#   Filter [BOH]
Endif
End

######################################################################################
# Fiche client livré: propose un site de réception
# RCPFCY  Site de réception du client livré
#       = Site de production
# STOFCY  Site d'expédition du client livré (sur lequel se trouve l'emplacement sous-traitance)
#       = Site de stockage des matières
#       = Site de réception du produit sous-traité (par défaut)
######################################################################################
# selon DEFBETRCPFCY de TRTACHDEF1
######################################################################################
Subprog FIND_PRHFCY (LPOHFCY,LBPRNUM,LBPAADD,LMFGFCY,LPRHFCY,LPRHADD,LLOC)
Value    Char     LPOHFCY
Value    Char     LBPRNUM
Variable Char     LBPAADD
Variable Char     LMFGFCY
Variable Char     LPRHFCY
Variable Char     LPRHADD
Variable Char     LLOC

Local Shortint ITROUVE : ITROUVE=0

If !clalev([F:BPD])  Local File BPDLVCUST  [BPD] : Endif
If !clalev([F:BPC])  Local File BPCUSTOMER [BPC] : Endif
Local File FACILITY [FCYW]

# Issue 86974 GA 01/2013 cas particulier intersoc: LMFGFCY et LPRHFCY sont déjà prédéfinis
If !ITROUVE & LMFGFCY<>"" & LPRHFCY<>""
  # Issue X3-95319 - 2018-06-19 by MUARN : regarder en premier l'adresse du client livré par défaut
  Read [BPC] BPC0=LBPRNUM
  If fstat
    Raz [F:BPC]
  Else
    # contrôler que l'adresse a un site de réception différent du site de réception de l'EO
    Read [BPD] BPD0=LBPRNUM;[F:BPC]BPDADD
    If !fstat & [F:BPD]RCPFCY <> LPRHFCY & [F:BPD]ENAFLG=2
      LLOC    = [F:BPD]SCOLOC
      LBPAADD = [F:BPD]BPAADD
      ITROUVE=1
    Endif
  Endif
  # End issue X3-95319
  # Issue X3-95319 - 2018-06-19 by MUARN : si l'adresse client livré par défaut ne convient pas,
  # recherche d'une autre adresse de client livré
  If ITROUVE =0
    # Issue X3-95319 - 2018-06-19 by MUARN : recherche adresse client livré avec un site de réception différent du site de réception de l'EO
    #For [BPD] BPD1 Where BPCNUM=LBPRNUM & STOFCY=LPRHFCY & RCPFCY=LMFGFCY & ENAFLG=2
    For [BPD] BPD0 Where BPCNUM=LBPRNUM & ENAFLG=2 & RCPFCY <> LPRHFCY
      LLOC    = [F:BPD]SCOLOC
      LBPAADD = [F:BPD]BPAADD
      ITROUVE=1
      Break
    Next
  Endif
Endif

# Issue X3-95319 - 2018-06-19 by MUARN : inutile l'adress a été déterminée au dessus
#----- Site d'expédition correspondant au site de réception déjà connu (intersite) -----#
#If !ITROUVE & LMFGFCY<>""
#  For [BPD] BPD1 Where BPCNUM=LBPRNUM & RCPFCY=LMFGFCY & ENAFLG=2
#    LPRHFCY = [F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
#    LLOC    = [F:BPD]SCOLOC
#    LBPAADD = [F:BPD]BPAADD
#    ITROUVE=1
#    Break
#  Next
#Endif

If !ITROUVE & LPRHFCY<>""
  # Issue 116483 - 2016-06-23 by MUARN : adresse par défaut
  Read [BPC] BPC0=LBPRNUM
  If fstat
    Raz [F:BPC]
  Else
    Read [BPD] BPD0=LBPRNUM;[F:BPC]BPDADD
    # Issue X3-95319 - 2018-06-19 by MUARN : ne pas contrôler STOFCY
    #If !fstat & [F:BPD]STOFCY = LPRHFCY & [F:BPD]ENAFLG=2
    If !fstat & [F:BPD]ENAFLG=2
      # Issue X3-95319 - 2018-06-21 by MUARN : pas en inter-site donc contrôle inutile
      #If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
      #If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
      #Read [FCY1]FCY0=[M:SCO0]POHFCY : If fstat : Raz [F:FCY1] : Endif
      #Read [FCY2]FCY0=LPRHFCY         : If fstat : Raz [F:FCY2] : Endif
      #If [F:FCY1]LEGCPY = [F:FCY2]LEGCPY
        LLOC    = [F:BPD]SCOLOC
        LBPAADD = [F:BPD]BPAADD
        ITROUVE=1
      #Endif
    Endif
  Endif
  # Issue 116483 - 2016-06-23 by MUARN : si pas l'adresse par défaut, recherche autre adresse
  If ITROUVE = 0
    # Issue X3-95319 - 2018-06-21 by MUARN : Pas de contreôle sur STOFCY
    #For [BPD] BPD1 Where BPCNUM=LBPRNUM & STOFCY=LPRHFCY & ENAFLG=2
    For [BPD] BPD1 Where BPCNUM=LBPRNUM & ENAFLG=2
      #LMFGFCY= [F:BPD]RCPFCY : # Site de réception de l'adresse client livré
      #LPRHFCY= [F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
      # Issue 116483 - 2016-06-23 by MUARN : controle adresse trouvée
      # Issue X3-95319 - 2018-06-21 by MUARN : pas en inter-site donc contrôle inutile
      #If clalev([F:FCY1]) = 0 : Local File FACILITY   [FCY1] : Endif
      #If clalev([F:FCY2]) = 0 : Local File FACILITY   [FCY2] : Endif
      #Read [FCY1]FCY0=[M:SCO0]POHFCY : If fstat : Raz [F:FCY1] : Endif
      #Read [FCY2]FCY0=LPRHFCY         : If fstat : Raz [F:FCY2] : Endif
      #If [F:FCY1]LEGCPY = [F:FCY2]LEGCPY
        LLOC    = [F:BPD]SCOLOC
        LBPAADD = [F:BPD]BPAADD
        ITROUVE=1
        Break
      #Endif
    Next
  Endif
Endif

# Issue X3-95319 - 2018-06-19 by MUARN : inutile l'adress a été déterminée au dessus
# Issue 86439 GA 12/2012 Site de l'alternative => site de réception, ne pas écraser ...
#If !ITROUVE & LPRHFCY=""
#  #----- Site de l'adresse par défaut du client livré -----#
#  If LBPAADD=""
#     Read [BPC] BPC0=LBPRNUM : If fstat  Raz [F:BPC] : Endif
#     LBPAADD = [F:BPC]BPDADD
#  Endif
#  If LBPAADD<>""
#    Read [BPD] BPD0=LBPRNUM;LBPAADD
#    If !fstat & [F:BPD]STOFCY<>"" & [F:BPD]ENAFLG=2
#      Read [FCYW] FCY0=[F:BPD]STOFCY : If fstat  Raz [F:FCYW] : Endif
#      #----- Doit appartenir à la même société que le site de commande d'achat -----#
#      If [F:FCYW]LEGCPY=GSOCIETE
#        #LMFGFCY= [F:BPD]RCPFCY : # Site de réception de l'adresse client livré
#        LPRHFCY= [F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
#        LLOC   = [F:BPD]SCOLOC
#        ITROUVE=1
#      Endif
#    Endif
#  Endif
#  If ITROUVE=0
#    #----- Autres sites du client livré -----#
#    For [BPD] BPD0 Where BPCNUM=LBPRNUM & STOFCY<>"" & ENAFLG=2
#      Read [FCYW] FCY0=[F:BPD]STOFCY : If fstat  Raz [F:FCYW] : Endif
#      #----- Doit appartenir à la même société que le site de commande d'achat -----#
#      If [F:FCYW]LEGCPY=GSOCIETE
#        #LMFGFCY= [F:BPD]RCPFCY : # Site de réception de l'adresse client livré
#        LPRHFCY= [F:BPD]STOFCY : # Site d'expédition de l'adresse client livré
#        LLOC   = [F:BPD]SCOLOC
#        LBPAADD= [F:BPD]BPAADD : # Site d'expédition de l'adresse client livré
#        ITROUVE=1
#        Break
#      Endif
#    Next
#  Endif
#Endif

Call FIND_FCYADD(LPRHFCY,LPRHADD) From BPRLIB

Close Local File [FCYW]
End

######################################################################################
# FQ 74682 GA 07/2011 devise Fournisseur versus devise locale
######################################################################################
Subprog FIND_CUR (LBPRNUM,LDATREF,LCUR,LCHGTYP,LCHGCOE)
Value    Char     LBPRNUM
Value    Date     LDATREF
Variable Char     LCUR
Variable Shortint LCHGTYP
Variable Decimal  LCHGCOE

Local Integer STAT : STAT=0

If LBPRNUM="" : End : Endif
If [F:BPS]BPSNUM<>LBPRNUM
  #----- Lecture BPSUPPLIER si nécessaire pour chargement CUR, CHGTYP -----#
  WBPRNUM = LBPRNUM
  Gosub READ_BPS From BPRLIB
Endif
If [F:BPR]BPRNUM<>LBPRNUM
  #----- Lecture BPARTNER  -----#
  WBPRNUM = LBPRNUM
  Gosub READ_BPR From BPRLIB
Endif
If [F:BPS]CUR<>""
  LCUR=[F:BPS]CUR
  LCHGTYP=[F:BPS]CHGTYP
Elsif [F:BPR]CUR=""
  LCUR=GLOCALDEV
  LCHGTYP=1
  LCHGCOE=1.0
Else
  LCUR=[F:BPR]CUR
  LCHGTYP=[F:BPS]CHGTYP
Endif
Call COURSITE(LCUR,GFCY,LCHGTYP,LDATREF,LCHGCOE,STAT) From TRTDEV

End

# ------------------------------------------------
# Délai article sous-traité
# Issue 80129 & 77115 Piloté par délai du Service
# ------------------------------------------------
Subprog FIND_SCI_LTI(LITMREF,LBPRNUM,LFCY,LBOMALT,LSRVITMREF,LLTI)
Value    Char     LITMREF
Value    Char     LBPRNUM
Value    Char     LFCY
Value    Integer  LBOMALT
Variable Char     LSRVITMREF
Variable Decimal  LLTI

  Local    Char     WFCY   (GLONFCY): WFCY=LFCY
  Local    Char     WITMREF(GLONITM): WITMREF=LITMREF
  Local    Char     WBPRNUM(GLONBPR): WBPRNUM=LBPRNUM
  Local    Char     WSRVITMREF(GLONITM): WSRVITMREF=LSRVITMREF
  Local    Date     WDATBES : WDATBES=date$
  Local    Integer  WLTI    : WLTI=LLTI

  # Issue 82748 GA 06/2012 déplacé sinon pb lorsque LSRVITMREF<>""
  # Issue 80129 CBN avec Délai gamme toujours
  If clalev([BODW])<=0  Local File BOMD       [BODW]   Endif
  If LSRVITMREF="" & LBOMALT>0
     Filter  [BODW] Where ITMREF    = LITMREF    &
&                         BOMALT    = LBOMALT    &
&                         BOMALTTYP = 3 &
&                        (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDATBES)) &
&                        (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDATBES)) &
&                         CPNTYP    = 7
&             Order By Key BOD0
     For [BODW]
         WSRVITMREF=[F:BODW]CPNITMREF
         Break
     Next
     Filter  [BODW]
     LSRVITMREF=WSRVITMREF
  Elsif LSRVITMREF<>[F:BODW]CPNITMREF
    # Issue 82748 GA 06/2012 ajouté
     Filter  [BODW] Where ITMREF    = LITMREF    &
&                         BOMALT    = LBOMALT    &
&                         CPNITMREF = LSRVITMREF &
&                         BOMALTTYP = 3 &
&                        (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDATBES)) &
&                        (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDATBES)) &
&                         CPNTYP    = 7
&             Order By Key BOD0
     For [BODW]
         Break
     Next
     Filter  [BODW]
  Endif
  # Issue 80128 GA 03/2012 Délai du Service dans la nomenclature
  # Issue 90223 & 89511 GH/GA 06/2013 rectifié pour le CBN qui conservait le délai ITF/ITP article sous-traité
  # If WSRVITMREF=[F:BODW]CPNITMREF & WLTI=0 & [F:BODW]BOMOFS>0
  If WSRVITMREF=[F:BODW]CPNITMREF & [F:BODW]BOMOFS>0
     WLTI=[F:BODW]BOMOFS
  Elsif WSRVITMREF<>""
     Call FIND_LTI(WSRVITMREF,WBPRNUM,LFCY,WLTI)
     # on se repositionne sur article lancé [F:ITM],[F:ITF],[F:ITP]
     Gosub READ_ITM From ITMLIB
     If GOK < 1 : End : Endif
     If WFCY<>""
        Gosub READ_ITF From ITMLIB
        #If GOK < 1 : End : Endif
     Endif
     If WBPRNUM<>""
        Gosub READ_ITP From ITMLIB
        #If GOK < 1 : End : Endif
     Endif
  Endif
  If WLTI=0 | WSRVITMREF=""
     Call FIND_LTI(LITMREF,LBPRNUM,LFCY,WLTI)
  Endif
  LLTI=WLTI
End

# ------------------------------------------------
# Délai article-fourn, ou article-site, ou article
# ------------------------------------------------
Subprog FIND_LTI(LITMREF,LBPRNUM,LFCY,LLTI)
Value    Char     LITMREF
Value    Char     LBPRNUM
Value    Char     LFCY
Variable Integer  LLTI

If dim(WFCY)   <=0 : Local    Char     WFCY   (GLONFCY) : Endif
If dim(WITMREF)<=0 : Local    Char     WITMREF(GLONITM) : Endif
If dim(WBPRNUM)<=0 : Local    Char     WBPRNUM(GLONBPR) : Endif

WFCY    = LFCY
WITMREF = LITMREF
WBPRNUM = LBPRNUM

LLTI = 0

If LITMREF="" : End : Endif

Gosub READ_ITM From ITMLIB
If GOK < 1 : End : Endif
If LFCY<>""
   Gosub READ_ITF From ITMLIB
   #If GOK < 1 : End : Endif
Endif
If LBPRNUM<>""
   Gosub READ_ITP From ITMLIB
   #If GOK < 1 : End : Endif
Endif
# GA 20/10/2006 [F:ITP]SCOLTI ajout V6 sous-traitance
If dim([F:ITP]SCOLTI)>0 & [F:ITP]ITMREF=LITMREF & [F:ITP]BPSNUM=LBPRNUM & [F:ITP]SCOLTI > 0
      LLTI = [F:ITP]SCOLTI
Elsif [F:ITF]ITMREF=LITMREF & [F:ITF]STOFCY=LFCY & [F:ITF]OFS > 0
# FQ 77115 GA 12/2011 demande VA utiliser uniquement [F:ITF]OFS délai calendaire
# quel délai MFGLTI ? OFS ? TOTLTI ? ...
      LLTI = [F:ITF]OFS
Else
      LLTI = [F:ITM]OFS
Endif

End

#########################################################################
# Contrôle de validité (pour prod) d'une alternative                    #
# TBO & BOH doivent être chargés ...                                    #
#-----------------------------------------------------------------------#
Subprog CONTSCONOM(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG
LALT=0
# Alternative de sous-traitance ?
If [F:TBO]BOMALTTYP<>3
  # L'alternative de nomenclature doit être de type sous-traitance !
    If LMSG<>0 : GMESSAGE=mess(00344,00194,1) : Endif
    End
Endif
# Issue 90090 GA 06/2013 Cette nomenclature est en cours d'élaboration (exploitation non autorisée) !
If [F:BOH]USESTA<>2
    If LMSG<>0 : GMESSAGE=mess(51,193,1) : Endif
    End
Endif
# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TBO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif
# Site ?
If ([F:TBO]FCY<>"" & [F:TBO]FCY<>LFCY )
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif
# Nomenclature valide ?
If ([F:BOH]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH]BOHSTRDAT)
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
If ([F:BOH]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH]BOHENDDAT)
     If LMSG<>0 : GMESSAGE=mess(50,193,1) : Endif
     End
Endif
#
LALT=[F:BOH]BOMALT
End

#######################################################################
# Sous programme d'accès au fichier BOM avec filtre sur nomenclatures
# propres au lancement
# LFCY = Site
# LITM = Article
# LRET = alternative sélectionnée ou 0
#---------------------------------------------------------#
Subprog SELSCONOM(LFCY,LITM,LRET)
Variable Char    LFCY
Variable Char    LITM
Variable Integer LRET
#
Local    Char    WFILT(255)
Local    Char    WFILB(255)
Local    Char    WINT(20)(4)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif  # FGR 16/09/2009 : X3SUIVI57824
#
Call TEXTFIC("BOM","ITMREF",1,WINT(0))        From OBJDIV
Call TEXTFIC("BOM","BOMALT",1,WINT(1))        From OBJDIV
#Call TEXTFIC("TBO","TBOSHO",1,WINT(2))        From OBJDIV
Call TEXTFIC("TABBOMALT","TBOSHOAXX",1,WINT(2))     From OBJDIV # FGR 16/09/2009 : X3SUIVI57824
Call TEXTFIC("BOM","BOHENDDAT",1,WINT(3))     From OBJDIV
#
# Filtre Alternative [TBO]
WFILT = '([F:TBO]FCY=LFCY | [F:TBO]FCY="") & [F:TBO]BOMALTTYP=3'
#filtre nomenclature [BOH]
WFILB = "[F:BOH]ITMREF = LITM"
#

# FGR 16/09/2009 : X3SUIVI57824 (début)
#Link [BOH] With [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT As [NOM]
#&            Where evalue(WFILT)&evalue(WFILB)
#&            Order By Key BOH0
#Choose [NOM]
#&  Using  [F:BOH]ITMREF  Titled WINT(0),
#&         [F:BOH]BOMALT  Titled WINT(1),
#&         [F:TBO]TBOSHO  Titled WINT(2),
#&         [F:BOH]BOHENDDAT Titled WINT(3)
#&  Sized(80,250)
#&  Titled mess(153,198,1)
Link [BOH] With [TBO]TBO0=[F:BOH]BOMALTTYP;[F:BOH]BOMALT,
&               [AXX]AXX0="TABBOMALT";"TBOSHOAXX";GLANGUE;num$([F:TBO]BOMALTTYP);num$([F:TBO]BOMALT)
&          As [NOM]
&            Where evalue(WFILT)&evalue(WFILB)
&            Order By Key BOH0
Choose [NOM]
&  Using  [F:BOH]ITMREF  Titled WINT(0),
&         [F:BOH]BOMALT  Titled WINT(1),
&         [F:AXX]TEXTE   Titled WINT(2),
&         [F:BOH]BOHENDDAT Titled WINT(3)
&  Sized(80,250)
&  Titled mess(153,198,1)
# FGR 16/09/2009 : X3SUIVI57824 (fin)

LRET = 0
If status = 7
   End
Else
   LRET = [F:BOH]BOMALT
Endif
End


#---------------------------------------------#
# Le prix par défaut est le coût std article  #
#---------------------------------------------#
Subprog UPD_ITM_PRI(LITM)
Value    Integer  LITM
#-----
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN
Local Integer  STAT
Local Char     CUR(GLONCUR), UOM(GLONUOM)
Local  Decimal GROPRI, DISCRGVAL(0..8), NETPRI, REFPRI, COEFUNITE, QTYUOM, LINAMT
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Raz [L]REFPRI, [L]NETPRI, [L]GROPRI, [L]PRIREN, [L]LINAMT, [L]QTYUOM
Raz LECCMAJ, LECCMIN
#-----
If clalev([M:SCO1])=0 | LITM=-1
   Call READ_ITM_ITF ([F:SCI]ITMREF,[F:SCI]PRHFCY) From ITMLIB
   #If GOK<1 : End : Endif # Issue 83440 GA 11/2012
   [L]QTYUOM = [F:SCI]QTYPUU
   [L]UOM    = [F:SCI]PUU
   [L]CUR    = [F:SCO]CUR
   [L]LECCMAJ  =[F:SCI]ECCVALMAJ
   [L]LECCMIN  =[F:SCI]ECCVALMIN
Else
   Call READ_ITM_ITF ([M:SCO0]ITMREF,[M:SCO1]PRHFCY) From ITMLIB
   #If GOK<1 : End : Endif # Issue 83440 GA 11/2012
   [L]QTYUOM = [M:SCO1]QTYPUU
   [L]UOM    = [M:SCO1]PUU
   [L]CUR    = [M:SCO1]CUR
   If dim([M:SCO1]ECCVALMAJ)>0
       [L]LECCMAJ  =[M:SCO1]ECCVALMAJ
       [L]LECCMIN  =[M:SCO1]ECCVALMIN
   Endif
Endif
#-----
Gosub COUT_STD
#-----
If clalev([M:SCO1])=0 | LITM=-1
   [F:SCI]REFPRI = [L]REFPRI   # FQ 74682 GA 07/2011 cout std en devise locale avant [L]NETPRI
   # Issue 96192 GA 01/2014 tester GPURPRICE
   If GPURPRICE=2 & [F:SCI]NETPRI=0
   [F:SCI]NETPRI = [L]NETPRI
   [F:SCI]GROPRI = [L]NETPRI
   [F:SCI]PRIREN = [L]PRIREN
   Endif
   #[F:SCI]LINAMT = [L]LINAMT # FQ 65646
Else
   [M:SCO1]REFPRI = [L]REFPRI  # FQ 74682 GA 07/2011 cout std en devise locale avant [L]NETPRI
   # Issue 96192 GA 01/2014 tester GPURPRICE
   If GPURPRICE=2 & [M:SCO1]NETPRI=0
   [M:SCO1]NETPRI = [L]NETPRI
   [M:SCO1]GROPRI = [L]NETPRI
   [M:SCO1]PRIREN = [L]PRIREN
   Endif
   #[M:SCO1]LINAMT = [L]LINAMT # FQ 65646
   # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
   Affzo [M:SCO1]1-99
Endif
End

#---------------------------------------------#
# Le prix par défaut est le coût std article  #
#---------------------------------------------#
Subprog UPD_SRV_PRI(LSRV)
Value    Integer  LSRV
#-----
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN
Local Integer  STAT,WOFS
Local Char     CUR(GLONCUR), UOM(GLONUOM), WFCY(GLONFCY), WBPRNUM(GLONBPR)
Local Decimal  GROPRI, DISCRGVAL(0..8), NETPRI, REFPRI, COEFUNITE, QTYUOM, LINAMT
Local Decimal  SAVGROPRI  # Issue 87680 GA 07/2013
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Raz [L]NETPRI, [L]REFPRI, [L]GROPRI, [L]PRIREN, [L]LINAMT, [L]QTYUOM
Raz LECCMAJ, LECCMIN
#-----
If clalev([M:SCO3])=0 | LSRV=-1
   Call READ_ITM_ITF ([F:SCS]SRVITMREF,[F:SCS]PRHFCY) From ITMLIB
   #If GOK<1 : End : Endif
   [L]QTYUOM = [F:SCS]EXTSTRQTY
   [L]UOM    = [F:SCS]SCOPUU
   [L]CUR    = [F:SCO]CUR
   If [F:SCS]SCOLTI = 0 [F:SCS]SCOLTI=[F:SCI]LTI Endif # FQ 52859
   [L]WOFS   = [F:SCS]SCOLTI
Else
   Call READ_ITM_ITF ([M:SCO3]SRVITMREF,[M:SCO1]PRHFCY) From ITMLIB
   #If GOK<1 : End : Endif
   [L]QTYUOM = [M:SCO3]EXTSTRQTY
   [L]UOM    = [M:SCO3]SCOPUU
   [L]CUR    = [M:SCO1]CUR
   If [M:SCO3]SCOLTI = 0 [M:SCO3]SCOLTI=[M:SCO1]LTI Endif # FQ 52859
   [L]WOFS   = [M:SCO3]SCOLTI
Endif
# FQ 74682 GA 07/2011
Local Char SAVGCUR(GLONCUR) : [L]SAVGCUR=GCUR
GCUR=[L]CUR
#-----
# Tarif d'achat du service au fournisseur
If clalev([M:SCO3])=0 | LSRV=-1
  # FQ 74682 GA 07/2011 nécessaire pour la lecture du tarif
  If [F:BPS]BPSNUM<>[F:SCO]BPRNUM
     WBRPNUM=[F:SCO]BPRNUM
     Gosub READ_BPR From BPRLIB
     Gosub READ_BPS From BPRLIB
  Endif
  If GPLISTC<>[F:BPS]PLISTC
     GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
     Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Endif

  Call RECH_TARIF ("FSCS",LSRV) From TRTACHTAR1
  Gosub CALC_LINAMT_SCS
Else
  If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
     WBRPNUM=[M:SCO0]BPRNUM
     Gosub READ_BPR From BPRLIB
     Gosub READ_BPS From BPRLIB
  Endif
  #----- Chargement paramètres et libellés colonnes tarif -----#
  If GPLISTC<>[F:BPS]PLISTC
     GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
     Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
  Endif

  Call RECH_TARIF ("PSCS",LSRV) From TRTACHTAR1
  Gosub CALC_LINAMT_SCO3
Endif

# FQ 74682 GA 07/2011 cout std en devise locale
# Recherche du cout standard
Gosub COUT_STD
If clalev([M:SCO3])=0 | LSRV=-1
  [F:SCS]REFPRI  = [L]REFPRI
  # Issue 96192 GA 01/2014 tester GPURPRICE
  If GPURPRICE=2 & [F:SCS]NETPRI = 0
     [F:SCS]NETPRI = [L]NETPRI
     [F:SCS]NETPRIL= [L]REFPRI
     [F:SCS]GROPRI = [L]NETPRI
     [F:SCS]PRIREN = [L]PRIREN
     [F:SCS]LINAMT = [L]LINAMT
  Endif
Else
  [M:SCO3]REFPRI = [L]REFPRI
  # Issue 96192 GA 01/2014 tester GPURPRICE
  If GPURPRICE=2 & [M:SCO3]NETPRI = 0
     [M:SCO3]NETPRI = [L]NETPRI
     [M:SCO3]NETPRIL= [L]REFPRI
     [M:SCO3]GROPRI = [L]NETPRI
     [M:SCO3]PRIREN = [L]PRIREN
     [M:SCO3]LINAMT = [L]LINAMT
  Endif
Endif

#-----
# le tarif peut avoir maj le délai SCOLTI
If clalev([M:SCO3])=0 | LSRV=-1
   If [F:SCS]SCOLTI<>[L]WOFS | [F:SCS]OPEEND=[0/0/0] # FQ 52859 pour maj OPEEND
      [F:SCS]OPESTR=[0/0/0]
      [L]WOFS = [F:SCS]SCOLTI
      Call UPD_SRV_DAT([L]WOFS, [F:SCS]OPESTR, [F:SCS]OPEEND, LSRV)
   Endif
Else
   If [M:SCO3]SCOLTI<>[L]WOFS | [M:SCO3]OPEEND=[0/0/0] # FQ 52859 pour maj OPEEND
      [M:SCO3]OPESTR=[0/0/0]
      [L]WOFS = [M:SCO3]SCOLTI
      Call UPD_SRV_DAT(WOFS, [M:SCO3]OPESTR, [M:SCO3]OPEEND, LSRV)
   Endif
   # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
   Affzo [M:SCO3]1-99
Endif
# FQ 74682 GA 07/2011
GCUR=[L]SAVGCUR
End

#---------------------------------------------#
# Le prix par défaut est le coût std article  #
#---------------------------------------------#
Subprog UPD_MAT_PRI(LMAT)
Value    Integer  LMAT
#-----
Local Libelle  CHGTYP, BETFCY
Local Shortint PRIREN, WSCOFLG
Local Integer  STAT, WOFS
Local Char     CUR(GLONCUR), UOM(GLONUOM), WFCY(GLONFCY), WBPRNUM(GLONBPR)
Local Decimal  GROPRI, DISCRGVAL(0..8), NETPRI, REFPRI, COEFUNITE, QTYUOM, LINAMT
Local Date     WSTRDAT,WENDDAT
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
Raz [L]NETPRI, [L]REFPRI, [L]GROPRI, [L]PRIREN, [L]LINAMT, [L]QTYUOM
Raz LECCMAJ, LECCMIN
#-----
If clalev([M:SCO2])=0 | LMAT=-1
   If [F:SCM]STOFCY<>""
      WFCY=[F:SCM]STOFCY
   Else
      WFCY=[F:SCI]PRHFCY # FQ 65646 avant [F:SCO]PRHFCY
   Endif
   Call READ_ITM_ITF ([F:SCM]CPNITMREF,WFCY) From ITMLIB
   #If GOK<1 : End : Endif # Issue 83440 GA 11/2012
   # Issue 113031 - 2016-02-12 by MUARN : gestion de l'erreur
   If GOK<1 : End : Endif
   [L]QTYUOM = [F:SCM]RETQTY
   [L]UOM    = [F:SCM]STU
   [L]CUR    = [F:SCO]CUR
   [L]WOFS   = [F:SCM]BOMOFS
   [L]WSCOFLG= [F:SCM]SCOFLG
   [L]NETPRI = [F:SCM]NETPRI
   [L]REFPRI = [F:SCM]REFPRI
   [L]LECCMAJ  =[F:SCM]ECCVALMAJ
   [L]LECCMIN  =[F:SCM]ECCVALMIN
Else
   If [M:SCO2]STOFCY(LMAT)<>""
      WFCY=[M:SCO2]STOFCY(LMAT)
   Else
      WFCY=[M:SCO1]PRHFCY
   Endif
   Call READ_ITM_ITF ([M:SCO2]CPNITMREF(LMAT),WFCY) From ITMLIB
   #If GOK<1 : End : Endif # Issue 83440 GA 11/2012
   [L]QTYUOM = [M:SCO2]RETQTY(LMAT)
   [L]UOM    = [M:SCO2]STU(LMAT)
   [L]CUR    = [M:SCO1]CUR
   [L]WOFS   = [M:SCO2]BOMOFS(LMAT)
   [L]WSCOFLG= [M:SCO2]SCOFLG(LMAT)
   [L]REFPRI = [M:SCO2]REFPRI(LMAT)
   [L]NETPRI = [M:SCO2]NETPRI(LMAT)
   If dim([M:SCO2]ECCVALMAJ)>0
       [L]LECCMAJ  =[M:SCO2]ECCVALMAJ(LMAT)
       [L]LECCMIN  =[M:SCO2]ECCVALMIN(LMAT)
   Endif
Endif
# FQ 74682 GA 07/2011
Local Char SAVGCUR(GLONCUR) : [L]SAVGCUR=GCUR
GCUR=[L]CUR
#-----
If WSCOFLG=3
  # Tarif d'achat de la matière chez ce fournisseur
  If clalev([M:SCO2])=0 | LMAT=-1
    # FQ 74682 GA 07/2011 nécessaire pour la lecture du tarif
    If [F:BPS]BPSNUM<>[F:SCO]BPRNUM
       WBRPNUM=[F:SCO]BPRNUM
       Gosub READ_BPR From BPRLIB
       Gosub READ_BPS From BPRLIB
    Endif
    If GPLISTC<>[F:BPS]PLISTC
       GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
       Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Endif

    Call RECH_TARIF ("FSCM",LMAT) From TRTACHTAR1
    Gosub CALC_LINAMT_SCM
  Else
    # FQ 74682 GA 07/2011 nécessaire pour la lecture du tarif
    If [F:BPS]BPSNUM<>[M:SCO0]BPRNUM
       WBRPNUM=[M:SCO0]BPRNUM
       Gosub READ_BPR From BPRLIB
       Gosub READ_BPS From BPRLIB
    Endif
    If GPLISTC<>[F:BPS]PLISTC
       GPLISTC=[F:BPS]PLISTC : Call TARIFCHGT(6) From TRTPRICE
       Call COLREM("C",2,[F:BPS]PLISTC) From TRTPRICE
    Endif

    Call RECH_TARIF ("PSCM",LMAT) From TRTACHTAR1
    Gosub CALC_LINAMT_SCO2
  Endif
Endif

# Recherche du cout standard
Gosub COUT_STD
If clalev([M:SCO2])=0 | LMAT=-1
  [F:SCM]REFPRI = [L]REFPRI        # FQ 74682 GA 07/2011 cout std en devise locale
  # Issue 96192 GA 01/2014 tester GPURPRICE
  If GPURPRICE=2 & [F:SCM]NETPRI = 0
     [F:SCM]NETPRI = [L]NETPRI
     [F:SCM]NETPRIL= [L]REFPRI     # devise locale
     [F:SCM]GROPRI = [L]NETPRI
     [F:SCM]PRIREN = [L]PRIREN
     [F:SCM]LINAMT = [L]LINAMT
  Endif
Else
  [M:SCO2]REFPRI(LMAT) = [L]REFPRI    # FQ 74682 GA 07/2011 cout std en devise locale
  # Issue 96192 GA 01/2014 tester GPURPRICE
  If GPURPRICE=2 & [M:SCO2]NETPRI(LMAT) = 0
     [M:SCO2]NETPRI(LMAT) = [L]NETPRI
     [M:SCO2]NETPRIL(LMAT)= [L]REFPRI   # devise locale
     [M:SCO2]GROPRI(LMAT) = [L]NETPRI
     [M:SCO2]PRIREN(LMAT) = [L]PRIREN
     [M:SCO2]LINAMT(LMAT) = [L]LINAMT
  Endif
Endif
#-----
# le tarif peut avoir maj le délai BOMOFS
If clalev([M:SCO2])=0 | LMAT=-1
   If [F:SCM]BOMOFS<>WOFS
      [F:SCM]DLVDAT=[0/0/0]
      If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Endif # Else WSTRDAT=[F:SCO]ORDDAT Endif # FQ 77115
      If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[F:SCO]RETDAT Endif
      # FQ 72600 GA 03/2011 remplacer [F:SCM]BOMOFS par WOFS
      WOFS = [F:SCM]BOMOFS
      Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[F:SCM]STOFCY, WOFS, [F:SCM]DLVDAT)
   Endif
Else
   If [M:SCO2]BOMOFS(LMAT)<>WOFS
      [M:SCO2]DLVDAT(LMAT)=[0/0/0]
      If [M:SCO3]OPESTR<>[0/0/0] WSTRDAT=[M:SCO3]OPESTR Endif # Else WSTRDAT=[M:SCO1]ORDDAT Endif # FQ 77115
      If [M:SCO3]OPEEND<>[0/0/0] WENDDAT=[M:SCO3]OPEEND Else WENDDAT=[M:SCO1]RETDAT Endif
      # FQ 72600 GA 03/2011 remplacer [M:SCO2]BOMOFS(LMAT) par WOFS
      WOFS = [F:SCM]BOMOFS
      Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[M:SCO2]STOFCY(LMAT), WOFS, [M:SCO2]DLVDAT(LMAT))
   Endif
  #Affzo [M:SCO2] # Issue 82189 GA 05/2012 Performances
Endif
# FQ 74682 GA 07/2011
GCUR=[L]SAVGCUR
End


############################################################
$COUT_STD
If !clalev([F:ITC])  Local File ITMCOST [ITC] : Endif
Call GETPRI([F:ITF]ITMREF,LECCMAJ,LECCMIN,[F:ITF]STOFCY,GBIDA1,1,"","",1,[L]NETPRI,STAT) From STKVAL
If !STAT & [F:ITC]VLTTOT<>0
  [L]NETPRI=[F:ITC]VLTTOT
  [L]REFPRI=[F:ITC]VLTTOT  # FQ 74682 GA 07/2011 on conserve la valeur en devise locale
  #----- Conversion prix si devise différente -----#
  If GLOCALDEV<>[L]CUR
    Call CONVERT2(GLOCALDEV,[L]CUR,GLOCALDEV,[L]CHGTYP,date$,
&                 [F:ITC]VLTTOT,[L]NETPRI,[L]STAT) From TRTDEV
  Endif
  #----- Conversion prix si unité différente -----#
  If [L]UOM<>[F:ITM]STU
    Call PCAL_QTY(GBIDD1,[F:ITM]STU,GBIDD1,[L]UOM,
&                 [F:ITF]ITMREF,[F:BPS]BPSNUM,2,[L]COEFUNITE) From TRTACHQTE1
    If [L]COEFUNITE=0   [L]COEFUNITE=1 : Endif
    [L]NETPRI=[L]NETPRI*[L]COEFUNITE
  Endif
  #----- Chargement prix net, prix brut et motif du prix -----#
  [L]NETPRI=arr([L]NETPRI,10^-GDECPRI)
  [L]PRIREN=GUPDPRIPUR
Endif
#-----
If [L]QTYUOM> 0 & [L]NETPRI<>0
   [L]LINAMT=[L]NETPRI*[L]QTYUOM
   Call ARRDEV([L]LINAMT,[L]CUR) From TRTDIV
Endif
Return

# Issue 88337 GA 03/2013
#---------------------------------------------#
# Recherche des Unités/Coeff du Service       #
#---------------------------------------------#
Subprog UPD_ITM_UOM(LITM)
Value    Integer  LITM
If clalev([M:SCO1])=0 | LITM=-1
  Local    Char    WITMREF(GLONITM): WITMREF=[F:SCI]ITMREF
  Local    Char    WBPRNUM(GLONBPR): WBPRNUM=[F:SCI]BPRNUM

  Gosub READ_ITM From ITMLIB
  Gosub READ_ITP From ITMLIB

   # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
   # => PUU de l'article lancé
   If [F:ITP]PUU<>""
      [F:SCI]PUU       = [F:ITP]PUU
      [F:SCI]PUUSTUCOE = [F:ITP]PUUSTUCOE
   Else
      [F:SCI]PUU       = [F:ITM]PUU
      [F:SCI]PUUSTUCOE = [F:ITM]PUUSTUCOE
   Endif
   [F:SCI]STU       = [F:ITM]STU
Else
  Local    Char    WITMREF(GLONITM): WITMREF=[M:SCO0]ITMREF
  Local    Char    WBPRNUM(GLONBPR): WBPRNUM=[M:SCO0]BPRNUM

  Gosub READ_ITM From ITMLIB
  Gosub READ_ITP From ITMLIB

   # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
   # => PUU de l'article lancé
   If [F:ITP]PUU<>""
      [M:SCO1]PUU       = [F:ITP]PUU
      [M:SCO1]PUUSTUCOE = [F:ITP]PUUSTUCOE
   Else
      [M:SCO1]PUU       = [F:ITM]PUU
      [M:SCO1]PUUSTUCOE = [F:ITM]PUUSTUCOE
   Endif
   [M:SCO1]STU       = [F:ITM]STU
Endif
GOK=1
End
#---------------------------------------------#
# Recherche des Unités/Coeff du Service       #
#---------------------------------------------#
Subprog UPD_SRV_UOM(LSRV)
Value    Integer  LSRV

If clalev([M:SCO3])=0 | LSRV=-1
  Local    Char    WITMREF(GLONITM): WITMREF=[F:SCS]SRVITMREF
  Local    Char    WBPRNUM(GLONBPR): WBPRNUM=[F:SCS]BPRNUM

  #----- Lecture [F:ITM] selon WITMREF
  If [F:ITM]ITMREF<>WITMREF
     Gosub READ_ITM From ITMLIB
  Endif
  Call READ_ITM_ITF ([F:SCS]SRVITMREF,[F:SCS]PRHFCY) From ITMLIB
  #If GOK<1 : End : Endif # Issue 83440 GA 11/2012

  #----- Lecture [F:ITP] selon WITMREF et WBPRNUM
  If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPRNUM
     Gosub READ_ITP From ITMLIB
  Endif

  # Issue 80045 & 69609 GA 02/2012
  If !clalev([F:BODW]) : Local File BOMD  [BODW] : Endif
  Local Date WDATE
  If [F:SCO]ORDDAT<>[0/0/0] WDATE=[F:SCO]ORDDAT Else WDATE=date$ Endif
  Filter [BODW] Where ITMREF = [F:SCS]ITMREF  & CPNITMREF = [F:SCS]SRVITMREF
&                   & BOMALT = [F:SCS]BOMALT & BOMALTTYP=3 & CPNTYP=7
&                 &  (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= WDATE)
&                 &  (BOMENDDAT = [0/0/0] | BOMENDDAT >= WDATE)
  # lecture premier enregistrement
  Read [F:BODW]BOD0 First
  # Issue 87383 GA 01/2013 si on a choisi un service hors nomenclature
  #If fstat : GOK=0 : End Endif
  If fstat : Raz [F:BODW] : Endif
  Filter [BODW]

  # FQ 69609 GA 02/2012
  # => UOM lue dans [F:BOD] avec coeff saisi sur la nomenclature
  # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
  # => STU de l'article service
  [F:SCS]OPESTU    = [F:ITM]STU
  [F:SCS]STDQTY    = 1
  If [F:SCS]SCOPUU<>""
    # Issue 76111 suite 05/2012 on garde l'UO saisie
     If [F:SCS]OPESTUCOE=0 [F:SCS]OPESTUCOE=1 Endif # Issue 87383 GA 01/2013
     If [F:SCS]OPESTRCOE=0 [F:SCS]OPESTRCOE=1 Endif # Issue 87383 GA 01/2013
  Else
   [F:SCS]OPESTRCOE = 1
   [F:SCS]OPESTUCOE = 1
   # Issue 87021 GA 01/2013 ce coeff renseigne plutôt [F:SCS]OPESTUCOE
   If dim([F:BODW]BOMUOM)>0 & [F:BODW]BOMUOM<>""
     [F:SCS]SCOPUU    = [F:BODW]BOMUOM
     [F:SCS]OPESTUCOE = [F:BODW]BOMSTUCOE
   Endif
   If [F:SCS]SCOPUU="" | [F:SCS]SCOPUU = [F:ITP]PUU
     [F:SCS]SCOPUU = [F:ITP]PUU
     If [F:ITP]PUUSTUCOE<>0                      # Issue 77611
        [F:SCS]OPESTRCOE = 1/[F:ITP]PUUSTUCOE    # Issue 87021 remplacement [M:SCO3]
     Endif
   Elsif [F:SCS]SCOPUU="" | [F:SCS]SCOPUU = [F:ITM]PUU
     [F:SCS]SCOPUU = [F:ITM]PUU
     If [F:ITM]PUUSTUCOE<>0                      # Issue 77611
        [F:SCS]OPESTRCOE = 1/[F:ITM]PUUSTUCOE    # Issue 87021 remplacement [M:SCO3]
     Endif
   Else
   Endif
  Endif
  If [F:SCS]OPESTU<>[F:SCS]SCOPUU & [F:SCS]OPESTRCOE=1 & [F:SCS]STRQTYCOD<>2
    # Issue 80045 Suite FQ 74274 GA 02/2012
    # Coef de conversion entre "Unité lancement" et "Unité oeuvre"
    Call RECH_COEFF([F:SCS]SRVITMREF,[F:SCO]BPRNUM,[F:SCS]OPESTU,[F:SCS]SCOPUU,GBIDD1) From SCOLIB
    [F:SCS]OPESTRCOE = GBIDD1
  Endif
Else

  Local    Char    WITMREF(GLONITM): WITMREF=[M:SCO3]SRVITMREF
  Local    Char    WBPRNUM(GLONBPR): WBPRNUM=[M:SCO0]BPRNUM

  #----- Lecture [F:ITM] selon WITMREF
  If [F:ITM]ITMREF<>WITMREF
     Gosub READ_ITM From ITMLIB
  Endif
  Call READ_ITM_ITF ([M:SCO3]SRVITMREF,[M:SCO3]PRHFCY) From ITMLIB
  #If GOK<1 : End : Endif # Issue 83440 GA 11/2012

  #----- Lecture [F:ITP] selon WITMREF et WBPRNUM
  If [F:ITP]ITMREF<>WITMREF | [F:ITP]BPSNUM<>WBPRNUM
     Gosub READ_ITP From ITMLIB
  Endif

  # Issue 80045 & 69609 GA 02/2012
  If !clalev([F:BODW]) : Local File BOMD  [BODW] : Endif
  Local Date WDATE
  If [M:SCO1]ORDDAT<>[0/0/0] WDATE=[M:SCO1]ORDDAT Else WDATE=date$ Endif
  Filter [BODW] Where ITMREF = [M:SCO0]ITMREF  & CPNITMREF = [M:SCO3]SRVITMREF
&                   & BOMALT = [M:SCO0]BOMALT & BOMALTTYP=3 & CPNTYP=7
&                 &  (BOMSTRDAT = [0/0/0] | BOMSTRDAT <= WDATE)
&                 &  (BOMENDDAT = [0/0/0] | BOMENDDAT >= WDATE)
  # lecture premier enregistrement
  Read [F:BODW]BOD0 First
  # Issue 87383 GA 01/2013 si on a choisi un service hors nomenclature
  #If fstat : GOK=0 : End Endif
  If fstat : Raz [F:BODW] : Endif
  Filter [BODW]

  # Issue 69609 GA 02/2012
  # => UOM lue dans [F:BOD] avec coeff saisi sur la nomenclature
  # => PUU lue dans [F:ITP] avec coeff saisi sur Article-Fournisseur
  # => STU de l'article service
  [M:SCO3]OPESTU    = [F:ITM]STU
  [M:SCO3]STDQTY    = 1
  If [M:SCO3]SCOPUU<>""
    # Issue 76111 suite 05/2012 on garde l'UO saisie
     If [M:SCO3]OPESTUCOE=0 [M:SCO3]OPESTUCOE=1 Endif # Issue 87383 GA 01/2013
     If [M:SCO3]OPESTRCOE=0 [M:SCO3]OPESTRCOE=1 Endif # Issue 87383 GA 01/2013
  Else
   [M:SCO3]OPESTRCOE = 1
   [M:SCO3]OPESTUCOE = 1
    # Issue 87021 GA 01/2013 ce coeff renseigne plutôt [F:SCS]OPESTUCOE
   If dim([F:BODW]BOMUOM)>0 & [F:BODW]BOMUOM<>""
     [M:SCO3]SCOPUU    = [F:BODW]BOMUOM
     [M:SCO3]OPESTUCOE = [F:BODW]BOMSTUCOE
   Endif
   If [M:SCO3]SCOPUU="" | [M:SCO3]SCOPUU = [F:ITP]PUU
     [M:SCO3]SCOPUU    = [F:ITP]PUU
     If [F:ITP]PUUSTUCOE<>0            # Issue 77611
        [M:SCO3]OPESTRCOE = 1/[F:ITP]PUUSTUCOE
     Endif
   Elsif [M:SCO3]SCOPUU="" | [M:SCO3]SCOPUU = [F:ITM]PUU
     [M:SCO3]SCOPUU    = [F:ITM]PUU
     If [F:ITM]PUUSTUCOE<>0            # Issue 77611
        [M:SCO3]OPESTRCOE = 1/[F:ITM]PUUSTUCOE
     Endif
   Endif
  Endif
  If [M:SCO3]OPESTU<>[M:SCO3]SCOPUU & [M:SCO3]OPESTRCOE=1 & [M:SCO3]STRQTYCOD<>2
    # Coef de conversion entre "Unité lancement" et "Unité oeuvre"
    Call RECH_COEFF([M:SCO3]SRVITMREF,[M:SCO0]BPRNUM,[M:SCO3]OPESTU,[M:SCO3]SCOPUU,GBIDD1) From SCOLIB
    [M:SCO3]OPESTRCOE = GBIDD1
  Endif
Endif

End

# --------------------------------------------------------------------------------
# FQ 74682 GA 07/2011
# Etiquettes utilisées par SUBSCO1 si changt du coeff de conversion devise locale
# --------------------------------------------------------------------------------
$CALC_LINAMT_SCS
Local Integer WRET
# Recalcul du montant et montant converti d'une ligne SCOSRV
  [F:SCS]LINAMT=[F:SCS]NETPRI*[F:SCS]EXTSTRQTY
  Call ARRDEV([F:SCS]LINAMT,[F:SCO]CUR) From TRTDIV
  # FQ 74682 GA 07/2011 ajout montant converti devise locale
  If dim([F:SCS]LINAMTL)>0 & dim([F:SCO]CHGTYP)>0
    # FQ 77488 GA 10/2011 avant [F:SCO]ORDDAT remplacé par [F:SCS]OPESTR
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                [F:SCS]LINAMT,[F:SCS]LINAMTL,[F:SCO]CHGCOE,WRET) From TRTDEV
   # FQ 75607 GA 08/2011 ne pas arrondir le prix unitaire selon devise locale , mais selon GDECPRI
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,0,
&                [F:SCS]NETPRI,[F:SCS]NETPRIL,[F:SCO]CHGCOE,WRET) From TRTDEV
    [F:SCS]NETPRIL = arr([F:SCS]NETPRIL,10^-GDECPRI)
  Endif
  If [F:SCS]REFPRI=0 # si pas de cout standard, GROPRI devient le prix de reference
     If [F:SCO]CUR=GLOCALDEV
        [F:SCS]REFPRI=[F:SCS]GROPRI
     Else
       # FQ 77488 GA 10/2011 avant [F:SCO]ORDDAT remplacé par [F:SCS]OPESTR
        Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                    [F:SCS]GROPRI,[F:SCS]REFPRI,[F:SCO]CHGCOE,WRET) From TRTDEV
     Endif
  Endif
Return
$CALC_LINAMT_SCO3
Local Integer WRET
# Recalcul du montant et montant converti d'une ligne [M:SCO3]
  [M:SCO3]LINAMT=[M:SCO3]NETPRI*[M:SCO3]EXTSTRQTY
  Call ARRDEV([M:SCO3]LINAMT,[M:SCO1]CUR) From TRTDIV
  # FQ 74682 GA 07/2011 ajout montant converti devise locale
  If dim([M:SCO3]LINAMTL)>0 & dim([M:SCO1]CHGTYP)>0
    # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
    Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,1,
&                [M:SCO3]LINAMT,[M:SCO3]LINAMTL,[M:SCO1]CHGCOE,WRET) From TRTDEV
   # FQ 75607 GA 08/2011 ne pas arrondir le prix unitaire selon devise locale , mais selon GDECPRI
    Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,0,
&                [M:SCO3]NETPRI,[M:SCO3]NETPRIL,[M:SCO1]CHGCOE,WRET) From TRTDEV
    [M:SCO3]NETPRIL = arr([M:SCO3]NETPRIL,10^-GDECPRI)
  Endif
# Issue 84760 - 2012-10-12 by CCC : Si PRIREF n'a pas été initialisé, il reste màj par GROPRI pendant la création de l'EO
#  If [M:SCO3]REFPRI=0 # si pas de cout standard, GROPRI devient le prix de reference
  If [M:SCO3]REFPRI=0 | [M:SCO3]SAIREFPRI=2
     If [M:SCO1]CUR=GLOCALDEV
        [M:SCO3]REFPRI=[M:SCO3]GROPRI
     Else
       # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
        Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,1,
&                    [M:SCO3]GROPRI,[M:SCO3]REFPRI,[M:SCO1]CHGCOE,WRET) From TRTDEV
     Endif
     If [M:SCO3]REFPRI<>0
        [M:SCO3]SAIREFPRI=2
     Endif
  Endif
Return

$CALC_LINAMT_SCM
Local Integer WRET
# Recalcul du montant et montant converti d'une ligne SCOMAT
  [F:SCM]LINAMT=[F:SCM]NETPRI*[F:SCM]RETQTY
  Call ARRDEV([F:SCM]LINAMT,[F:SCO]CUR) From TRTDIV
  # FQ 74682 GA 07/2011 ajout montant converti devise locale
  If dim([F:SCM]LINAMTL)>0 & dim([F:SCO]CHGTYP)>0
       # FQ 77488 GA 10/2011 avant [F:SCO]ORDDAT remplacé par [F:SCS]OPESTR
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                [F:SCM]LINAMT,[F:SCM]LINAMTL,[F:SCO]CHGCOE,WRET) From TRTDEV
   # FQ 75607 GA 08/2011 ne pas arrondir le prix unitaire selon devise locale , mais selon GDECPRI
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,0,
&                [F:SCM]NETPRI,[F:SCM]NETPRIL,[F:SCO]CHGCOE,WRET) From TRTDEV
    [F:SCM]NETPRIL = arr([F:SCM]NETPRIL,10^-GDECPRI)
  Endif
  If [F:SCM]REFPRI=0 # si pas de cout standard, GROPRI devient le prix de reference
     If [F:SCO]CUR=GLOCALDEV
        [F:SCM]REFPRI=[F:SCM]GROPRI
     Else
       # FQ 77488 GA 10/2011 avant [F:SCO]ORDDAT remplacé par [F:SCS]OPESTR
        Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                    [F:SCM]GROPRI,[F:SCM]REFPRI,[F:SCO]CHGCOE,WRET) From TRTDEV
     Endif
  Endif
Return
$CALC_LINAMT_SCMW
Local Integer WRET
# Issue 93349 GA 10/2013  fields [M:SCO1]xxx replaced for SCKFICH
# Recalcul du montant et montant converti d'une ligne [M:SCMW]
  [M:SCMW]LINAMT=[M:SCMW]NETPRI*[M:SCMW]RETQTY
  Call ARRDEV([M:SCMW]LINAMT,[F:SCO]CUR) From TRTDIV
  # FQ 74682 GA 07/2011 ajout montant converti devise locale
  If dim([M:SCMW]LINAMTL)>0 & dim([F:SCO]CHGTYP)>0
    # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                [M:SCMW]LINAMT,[M:SCMW]LINAMTL,[F:SCO]CHGCOE,WRET) From TRTDEV
   # FQ 75607 GA 08/2011 ne pas arrondir le prix unitaire selon devise locale , mais selon GDECPRI
    Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,0,
&                [M:SCMW]NETPRI,[M:SCMW]NETPRIL,[F:SCO]CHGCOE,WRET) From TRTDEV
    [M:SCMW]NETPRIL = arr([M:SCMW]NETPRIL,10^-GDECPRI)
  Endif
  If [M:SCMW]REFPRI=0 # si pas de cout standard, GROPRI devient le prix de reference
     If [F:SCO]CUR=GLOCALDEV
        [M:SCMW]REFPRI=[M:SCMW]GROPRI
     Else
       # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
        Call COURMNT([F:SCO]CUR,GLOCALDEV,GLOCALDEV,[F:SCO]CHGTYP,[F:SCS]OPESTR,1,
&                    [M:SCMW]GROPRI,[M:SCMW]REFPRI,[F:SCO]CHGCOE,WRET) From TRTDEV
     Endif
  Endif
Return

$CALC_LINAMT_SCO2
Local Integer WRET
# Recalcul du montant et montant converti d'une ligne [M:SCO2]
  [M:SCO2]LINAMT(LMAT)=[M:SCO2]NETPRI(LMAT)*[M:SCO2]RETQTY(LMAT)
  Call ARRDEV([M:SCO2]LINAMT(LMAT),[M:SCO1]CUR) From TRTDIV
  # FQ 74682 GA 07/2011 ajout montant converti devise locale
  If dim([M:SCO2]LINAMTL)>0 & dim([M:SCO1]CHGTYP)>0
      # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
      Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,1,
&                  [M:SCO2]LINAMT(LMAT),[M:SCO2]LINAMTL(LMAT),[M:SCO1]CHGCOE,WRET) From TRTDEV
      # FQ 75607 GA 08/2011 ne pas arrondir le prix unitaire selon devise locale , mais selon GDECPRI
      Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,0,
&                  [M:SCO2]NETPRI(LMAT),[M:SCO2]NETPRIL(LMAT),[M:SCO1]CHGCOE,WRET) From TRTDEV
      [M:SCO2]NETPRIL(LMAT) = arr([M:SCO2]NETPRIL(LMAT),10^-GDECPRI)
  Endif
  If [M:SCO2]REFPRI(LMAT)=0 # si pas de cout standard, GROPRI devient le prix de reference
     If [M:SCO1]CUR=GLOCALDEV
        [M:SCO2]REFPRI(LMAT)=[M:SCO2]GROPRI(LMAT)
     Else
        # FQ 77488 GA 10/2011 avant [M:SCO1]ORDDAT remplacé par [M:SCO3]OPESTR
        Call COURMNT([M:SCO1]CUR,GLOCALDEV,GLOCALDEV,[M:SCO1]CHGTYP,[M:SCO3]OPESTR,1,
&                    [M:SCO2]GROPRI(LMAT),[M:SCO2]REFPRI(LMAT),[M:SCO1]CHGCOE,WRET) From TRTDEV
     Endif
  Endif
Return
$CALC_LINAMT_SCO2_ALL
# Recalcul du montant et montant converti toutes les lignes de [M:SCO2]
Local Integer LMAT
For LMAT=0 To [M:SCO2]NBLIG-1
    Gosub CALC_LINAMT_SCO2
Next
Return

############################################################
# modification qté UA ou US pour SUBSCO1, SCOSBCLIB, ...
############################################################
Subprog UPD_ITM_QTY(LSENS,LUOM1,LQTY1,LUOM2,LQTY2,LCOEF,LITM)
Value    Integer  LSENS
Value    Char     LUOM1
Value    Decimal  LQTY1
Value    Char     LUOM2
Variable Decimal  LQTY2
Variable Decimal  LCOEF
Value    Integer  LITM
If LUOM2=LUOM1 : LQTY2=LQTY1 : LCOEF=1 : End : Endif
If clalev([M:SCO1])=0 | LITM=-1
   Call PCAL_QTY(LQTY1,LUOM1,LQTY2,LUOM2,
&               [F:SCI]ITMREF,[F:SCO]BPRNUM,1,GBIDD1) From TRTACHQTE1
Else
   Call PCAL_QTY(LQTY1,LUOM1,LQTY2,LUOM2,
&                [M:SCO0]ITMREF,[M:SCO0]BPRNUM,1,GBIDD1) From TRTACHQTE1
Endif
If GBIDD1<>0 & LSENS=2 : # Coeff PUU => STU
   LCOEF = GBIDD1
Endif
End

############################################################
# Calcul de la quantité de service
############################################################
Subprog UPD_SRV_QTY(LQTY,LOPESTU,LSCOPUU,LSRV)
Value    Decimal  LQTY
Variable Char     LOPESTU()
Variable Char     LSCOPUU()
Value    Integer  LSRV

Local Decimal    WCOEFF,WQTY
If clalev([M:SCO3])=0 | LSRV=-1
  # ----------------------------------
  # accès aux enreg [F:SCI] et [F:SCS]
  # ----------------------------------
     If [F:SCS]ITMREF="" End Endif   # Issue 87383 GA 01/2013
    #If [F:SCS]STRQTYCOD <> 2
       # Issue 80045 GA 02/2012 check units & qty conversion rate
        If LOPESTU<>[F:SCS]OPESTU | LSCOPUU<>[F:SCS]SCOPUU | [F:SCS]OPESTRCOE=0 # Issue 77611 GA 11/2012
           [F:SCS]OPESTU=LOPESTU
           [F:SCS]SCOPUU=LSCOPUU
           Call UPD_SRV_UOM(LSRV)
           LOPESTU=[F:SCS]OPESTU
           LSCOPUU=[F:SCS]SCOPUU
        Endif
    #Else
    #    [F:SCS]OPESTRCOE = 1
    #Endif
    #
    # FQ 76925 GA 10/2011 - FQ 74137 GA 06/2011 unité de gestion de la nomenclature
    # If [F:SCI]BASQTY>1
    #    WQTY=LQTY/[F:SCI]BASQTY
    # Else
    #    WQTY=LQTY
    # Endif
    # FQ 77115 GA 12/2011 tenir compte aussi de LIKQTY si qté non forfaitaire
    # If [F:SCI]BASQTY>1
    # Issue 101293 GA 09/2014 case 0<[F:BOH]BASQTY<1
    #If [F:SCI]BASQTY<>1 | [F:SCS]STRQTYCOD <> 2
    # Issue 107897 GA 04/2015 fixed qty have to be loaded/estimated as well
    If [F:SCI]BASQTY<>1 | [F:SCS]STRQTYCOD=2
        Local    Decimal  WQTY, WLIKQTY, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN, WSCA
        Local    Integer  WQTYRND
        If !clalev([F:BODW]) : Local File BOMD  [BODW] : Endif
        # Issue 96598 GA 02/2014 pb si [F:SCS]BOMSEQ = 0
        # Issue 77611 GA 11/2012 pb sur le Read clé partielle
        #Read [F:BODW]BOD4=[F:SCS]BOMALT;[F:SCS]ITMREF;3;[F:SCS]SRVITMREF;[F:SCS]BOMSEQ
        If [F:SCS]BOMSEQ = 0
           For [F:BODW] Where BOMALT=[F:SCS]BOMALT & BOMALTTYP=3 & CPNTYP=7
&                           & ITMREF=[F:SCS]ITMREF & CPNITMREF=[F:SCS]SRVITMREF
               Break
           Next
           [F:SCS]BOMSEQ=[F:BODW]BOMSEQ # Issue 96598 GA 02/2014
        Else
           Read [F:BODW]BOD4=[F:SCS]BOMALT;[F:SCS]ITMREF;3;[F:SCS]SRVITMREF;[F:SCS]BOMSEQ
        Endif
        If !fstat
            WLIKQTY=[F:BODW]LIKQTY
            WQTYRND=[F:BODW]QTYRND
        Else
            WLIKQTY=1
            WQTYRND=1
        Endif
        Call LIKQTY(LQTY,LOPESTU,[F:SCI]BASQTY,[F:SCS]STRQTYCOD,WLIKQTY,
&                   WQTYRND,WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
        WQTY=WQTYN
    Else
        WQTY=LQTY
    Endif

    If [F:SCS]OPESTUCOE<>0 # Issue 77611 GA 11/2012
        WCOEFF = [F:SCS]OPESTUCOE
    Else
    # Coef de conversion entre "Unité Stock (article lancé)" et "Unité Stock (article commandé)"
        Call RECH_COEFF([F:SCS]SRVITMREF,[F:SCO]BPRNUM,[F:SCI]STU,LOPESTU,WCOEFF) From SCOLIB
        If WCOEFF=0 WCOEFF=1 Endif
        [F:SCS]OPESTUCOE = WCOEFF
    Endif
    [F:SCS]STDQTY = WQTY

    # Issue 77611 GA 04/2012 revu 11/2012 ajout EXTSTUQTY & OPESTUCOE sur SCS
    [F:SCS]EXTSTUQTY = WQTY

    If [F:SCS]STRQTYCOD = 2
        # calcul quantité sous-traitance si lien Forfait
        [F:SCS]EXTSTRQTY = [F:SCS]STDQTY  # Issue 77611 GA 04/2012 avant 1
        If [F:SCS]OPESTRCOE<>0
           [F:SCS]EXTQTY = [F:SCS]STDQTY/[F:SCS]OPESTRCOE # Issue 81748 GA 04/2012
        Else
           [F:SCS]EXTQTY = [F:SCS]STDQTY
        Endif
        WCOEFF = 1
    Elsif [F:SCS]STRQTYCOD = 1
        # calcul quantité sous-traitance si lien Proportionnel
        # quantité opération selon qté US de l'article commandé
        If [F:SCS]OPESTUCOE=0 [F:SCS]OPESTUCOE=1 Endif # Issue 87383 GA 01/2013
        If [F:SCS]OPESTRCOE=0 [F:SCS]OPESTRCOE=1 Endif # Issue 87383 GA 01/2013
        [F:SCS]EXTSTRQTY  = [F:SCS]EXTSTUQTY / [F:SCS]OPESTUCOE
        [F:SCS]EXTQTY     = [F:SCS]EXTSTRQTY / [F:SCS]OPESTRCOE
        # Issue 80045 GA 02/2012
        If LSCOPUU=[F:ITP]PUU & [F:SCS]EXTSTRQTY<[F:ITP]PURMINQTY
           [F:SCS]EXTSTRQTY=[F:ITP]PURMINQTY
        Endif
    Endif
    # FQ 77413 GA 10/2011 arrondir
    Call QTEARR([F:SCS]EXTQTY   ,LOPESTU) From TRTDIV
    Call QTEARR([F:SCS]EXTSTRQTY,LSCOPUU) From TRTDIV
    Call QTEARR([F:SCS]EXTSTUQTY,[F:SCI]STU) From TRTDIV

Else
  # ----------------------------------
  # écran de saisie
  # ----------------------------------
     If [M:SCO3]ITMREF="" End Endif   # Issue 87383 GA 01/2013
    #If [M:SCO3]STRQTYCOD <> 2
       # Issue 80045 GA 02/2012 check units & qty conversion rate
        If LOPESTU<>[M:SCO3]OPESTU | LSCOPUU<>[M:SCO3]SCOPUU | [M:SCO3]OPESTRCOE=0 # Issue 77611 GA 11/2012
          [M:SCO3]OPESTU=LOPESTU
          [M:SCO3]SCOPUU=LSCOPUU
          Call UPD_SRV_UOM(LSRV)
          LOPESTU=[M:SCO3]OPESTU
          LSCOPUU=[M:SCO3]SCOPUU
        Endif
    #Else
    #    [M:SCO3]OPESTRCOE = 1
    #Endif

    #
    # FQ 76925 GA 10/2011 - FQ 74137 GA 06/2011 unité de gestion de la nomenclature
    #If [M:SCO1]BASQTY>1
    #   WQTY=LQTY/[M:SCO1]BASQTY
    #Else
    #   WQTY=LQTY
    #Endif
    # FQ 77115 GA 12/2011 tenir compte aussi de LIKQTY si qté non forfaitaire
    # If [M:SCO1]BASQTY>1
    # Issue 101293 GA 09/2014 case 0<[F:BOH]BASQTY<1
    #If [M:SCO1]BASQTY<>1 | [M:SCO3]STRQTYCOD <> 2
    # Issue 107897 GA 04/2015 fixed qty have to be loaded/estimated as well
    If [M:SCO1]BASQTY<>1 | [M:SCO3]STRQTYCOD=2
        Local    Decimal  WQTY, WLIKQTY, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN, WSCA
        Local    Integer  WQTYRND
        If !clalev([F:BODW]) : Local File BOMD  [BODW] : Endif
        # Issue 77611 GA 11/2012 pb sur le Read clé partielle
        # Read [F:BODW]BOD4=[M:SCO0]BOMALT;[M:SCO0]ITMREF;3;[M:SCO3]SRVITMREF;[M:SCO3]BOMSEQ
        # Issue 82288 GA 05/2012 pb si [M:SCO3]BOMSEQ = 0
        If [M:SCO3]BOMSEQ = 0
           For [F:BODW] Where BOMALT=[M:SCO0]BOMALT & BOMALTTYP=3 & CPNTYP=7
&                           & ITMREF=[M:SCO0]ITMREF & CPNITMREF=[M:SCO3]SRVITMREF
               Break
           Next
        Else
           Read [F:BODW]BOD4=[M:SCO0]BOMALT;[M:SCO0]ITMREF;3;[M:SCO3]SRVITMREF;[M:SCO3]BOMSEQ
        Endif
        If !fstat
            WLIKQTY=[F:BODW]LIKQTY
            WQTYRND=[F:BODW]QTYRND
        Else
            WLIKQTY=1
            WQTYRND=1
        Endif
        Call LIKQTY(LQTY,LOPESTU,[M:SCO1]BASQTY,[M:SCO3]STRQTYCOD,WLIKQTY,
&                   [M:SCO3]QTYRND,WSCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
        WQTY=WQTYN
    Else
        WQTY=LQTY
    Endif

    If [M:SCO3]OPESTUCOE<>0 # Issue 77611 GA 11/2012
        WCOEFF = [M:SCO3]OPESTUCOE
    Else
        # Coef de conversion entre "Unité Stock (article lancé)" et "Unité Stock (article commandé)"
        Call RECH_COEFF([M:SCO3]SRVITMREF,[M:SCO0]BPRNUM,[M:SCO1]STU, LOPESTU,WCOEFF) From SCOLIB
        If WCOEFF=0 WCOEFF=1 Endif
        [M:SCO3]OPESTUCOE = WCOEFF
    Endif
    # Issue 87727 GA 02/2013 conversion en US du Service
    [M:SCO3]STDQTY = WQTY / [M:SCO3]OPESTUCOE
    Call QTEARR([M:SCO3]STDQTY,LOPESTU) From TRTDIV

    # Issue 77611 GA 04/2012 revu 11/2012 ajout EXTSTUQTY & OPESTUCOE sur SCS
    [M:SCO3]EXTSTUQTY = WQTY

    If [M:SCO3]STRQTYCOD = 2
       # calcul quantité sous-traitance si lien Forfait
        [M:SCO3]EXTSTRQTY = WQTY                   # Issue 77611 avant 1
        If [M:SCO3]OPESTRCOE<>0
           [M:SCO3]EXTQTY = WQTY/[M:SCO3]OPESTRCOE # Issue 81748 GA 04/2012
        Else
           [M:SCO3]EXTQTY = WQTY
        Endif
        WCOEFF = 1
    Elsif [M:SCO3]STRQTYCOD = 1
       # calcul quantité sous-traitance si lien Proportionnel
        If [M:SCO3]OPESTUCOE=0 [M:SCO3]OPESTUCOE=1 Endif # Issue 87383 GA 01/2013
        If [M:SCO3]OPESTRCOE=0 [M:SCO3]OPESTRCOE=1 Endif # Issue 87383 GA 01/2013
        [M:SCO3]EXTSTRQTY  = [M:SCO3]EXTSTUQTY / [M:SCO3]OPESTUCOE
        [M:SCO3]EXTQTY     = [M:SCO3]EXTSTRQTY / [M:SCO3]OPESTRCOE
       # Issue 80045 GA 02/2012
        If LSCOPUU=[F:ITP]PUU & [M:SCO3]EXTSTRQTY<[F:ITP]PURMINQTY
           [M:SCO3]EXTSTRQTY=[F:ITP]PURMINQTY
        Endif
    Else
       [M:SCO3]EXTSTRQTY  = [M:SCO3]EXTQTY
    Endif
    # FQ 77413 GA 10/2011 arrondir
    Call QTEARR([M:SCO3]EXTQTY   ,LOPESTU) From TRTDIV
    Call QTEARR([M:SCO3]EXTSTRQTY,LSCOPUU) From TRTDIV
    Call QTEARR([M:SCO3]EXTSTUQTY,[M:SCO1]STU) From TRTDIV

    Affzo [M:SCO3]EXTSTRQTY,OPESTUCOE # Issue 76111 suite 05/2012 avant OPESTUCOE
Endif
End
############################################################
# modification des matières selon UPD_MAT_QTY de MFGLIBM
############################################################
Subprog UPD_MAT_QTY(LQTY,LMAT)
Value    Decimal  LQTY
Value    Integer  LMAT
Local    Decimal  WQTY, WDIS, WQTYN, WQTYNA, WQTYB, WQTYBA, WLIEN
Local    Char     WSTU(GLONUOM)     # llc 01.02 UOM
Local    Decimal  WEXT,WCPL
Local    Integer  WRET
#Local    Integer  WVISUGHOST : WVISUGHOST = 0   :     # llc 02.03 (R)
#Local    Integer  WORITRT : WORITRT = 2

If clalev([M:SCO2])=0 | LMAT=-1
  # ----------------------------------
  # ligne courante [F:SCM] et [F:SCS]
  # ----------------------------------
    If [F:SCM]MATSTA<>4 & [F:SCM]CPNTYP<>5

      # calcul nouvelle quantité
        WQTY = LQTY
        WSTU = [F:SCM]STU
        Call LIKQTY(WQTY,WSTU,[F:SCM]BASQTY,[F:SCM]LIKQTYCOD,[F:SCM]LIKQTY,
&                   [F:SCM]QTYRND,[F:SCM]SCA,WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
      # Issue 78122 GA 08/2012 toujours tenir compte du SCA indiqué sur la nomenclature de sous-traitance
      ###  If [F:SCM]RELSCATIA <> 1
            WLIEN = WQTYBA
      ###  Else
      ###      WLIEN = WQTYNA
      ###  Endif
        # llc 13460 ne pas diminuer en deça de la quantité déjà sortie
        If WLIEN >= [F:SCM]USEQTY
            [F:SCM]RETQTY = WLIEN
        Else
            [F:SCM]RETQTY = [F:SCM]USEQTY
        Endif
        [F:SCM]STDQTY = [F:SCM]RETQTY

        # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
        # Issue 82823 GA 06/2012
        #If [F:SCM]SCOFLG <> 3
        #If [F:SCM]SCOFLG = 2
        If [F:SCM]SCOFLG <> 3
            WEXT = [F:SCM]RETQTY
            WCPL = [F:SCM]USEQTY
            Call CONT_SOLDE_MAT([F:SCM]STOFCY, [F:SCM]CPNITMREF, WCPL, WEXT, WRET)
            If WRET = 1 : [F:SCM]MATSTA = 3 : Endif
        Endif
    Endif : # [F:SCM]MATSTA<3
Else
  # -----------------------------------
  # maj ligne courante [M:SCO2]
  # -----------------------------------
  If [M:SCO2]MATSTA(LMAT)<>4 & [M:SCO2]CPNTYP(LMAT)<>5
   # calcul nouvelle quantité
     WQTY = LQTY
     WSTU = [M:SCO2]STU(LMAT)
     Call LIKQTY(WQTY,WSTU,[M:SCO2]BASQTY(LMAT),[M:SCO2]LIKQTYCOD(LMAT),[M:SCO2]LIKQTY(LMAT),
&                [M:SCO2]QTYRND(LMAT),[M:SCO2]SCA(LMAT),WQTYN,WQTYNA,WQTYB,WQTYBA) From MFGLIB
    # Issue 78122 GA 08/2012 toujours tenir compte du SCA indiqué sur la nomenclature de sous-traitance
    ### If [M:SCO2]RELSCATIA(LMAT) <> 1
         WLIEN = WQTYBA
    ### Else
    ###     WLIEN = WQTYNA
    ### Endif
     # llc 13460 ne pas diminuer en deça de la quantité déjà sortie
     If WLIEN >= [M:SCO2]USEQTY(LMAT)
         [M:SCO2]RETQTY(LMAT) = WLIEN
     Else
         [M:SCO2]RETQTY(LMAT) = [M:SCO2]USEQTY(LMAT)
     Endif
     [M:SCO2]STDQTY(LMAT) = [M:SCO2]RETQTY(LMAT)

     # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
#     # Issue 82823 GA 06/2012
#     If [M:SCO2]SCOFLG(LMAT)=2 & [M:SCO2]STOMGTCOD(LMAT)<2
#        [M:SCO2]SCOFLG(LMAT)=1
#     Endif

     If [M:SCO2]SCOFLG(LMAT)=2

       # affichage stock disponible
       Call LECITV2([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),WRET) From MFGLIB

       #--- Issue 115110 : Added LECCVAL parameter in 10th position
       Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
       If dim([M:SCO2]ECCVALMAJ)>0 & [M:SCO2]ECCVALMAJ(LMAT)<>""
         If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
         Call LECSRU([M:SCO2]STOFCY(LMAT),[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
         If WRET=0 & [F:SRU]ORDVER=2
           WECCVALMAJ=[M:SCO2]ECCVALMAJ(LMAT)
         Endif
       Endif
       Call STODISALL([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
       #Call STODISALL([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),36,1,2,1,2,"","",WDIS,WRET) From STKALL
       #--- End issue 115110

       [M:SCO2]AVAQTY(LMAT) = WDIS + [M:SCO2]ALLQTY(LMAT)            # llc 09.02 15756
       WEXT = [M:SCO2]RETQTY(LMAT)
       WCPL = [M:SCO2]USEQTY(LMAT)
       Call CONT_SOLDE_MAT([M:SCO2]STOFCY(LMAT), [M:SCO2]CPNITMREF(LMAT), WCPL, WEXT, WRET)
       If WRET = 1 : [M:SCO2]MATSTA(LMAT) = 3 : Endif

     Endif

  Endif : # [M:SCO2]MATSTA(LMAT)<>4
  #Affzo [M:SCO2] # Issue 82189 GA 05/2012 Performances
Endif

$UPD_MAT_QTY_FIN

End

############################################################
# Site des matières - Extraits de SCOAUTLIB et SUBSCO2
# Issue 81641 maj site des composants
############################################################
Subprog UPD_MAT_FCY(LFCY,LMAT)
Value    Char  LFCY
Value    Integer  LMAT

Local    Integer  WRET,WALL,WALLTYP
Local    Decimal  WDIS

If LFCY="" End Endif

If clalev([M:SCO2])=0 | LMAT=-1
  # ----------------------------------
  # ligne courante [F:SCM] et [F:SCI]
  # ----------------------------------
   If [F:SCM]STOFCY<>LFCY & [F:SCM]ALLQTY+[F:SCM]SHTQTY<>0
     Case [F:SCM]ALLSTA
         When 2,3: WALLTYP = 1
         When 4,5: WALLTYP = 2
     Endcase
     # désallouer sur l'ancien site
     Call ALLOCATION("A", WALLTYP, [F:SCM]ALLQTY, [F:SCM]SHTQTY, WRET) From SCOALL
     WALL=1 # pour réallouer ensuite
   Endif

   # Issue 86384 GA 12/2012 sauf matière exclue
   If [F:SCM]SCOFLG < 3 & [F:SCM]CPNTYP=1 & [F:SCM]MATSTA<>4
      [F:SCM]STOFCY=LFCY
      Call READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY) From ITMLIB
      #If GOK<1 : End : Endif # Issue 83440 GA 11/2012

      If [F:SCM]SCA <> 0  & [F:ITF]RELSCATIA<>0
         [F:SCM]RELSCATIA = [F:ITF]RELSCATIA
      Endif

      [F:SCM]LOC    = [F:SCI]LOC     # emplacement sous-traitance
      [F:SCM]MFGFCY = [F:SCO]MFGFCY
      [F:SCM]STOMGTCOD = func ITMLIB.GET_STOMGTCOD([F:SCM]CPNITMREF,[F:SCM]STOFCY)
      # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
      #If [F:SCM]STOMGTCOD<2 [F:SCM]SCOFLG=1 Endif # Issue 82823 GA 06/2012 Matière interne
   Elsif [F:SCM]SCOFLG = 3 | [F:SCM]MATSTA = 4
      # pas de site de stockage, pas d'adresse sous-traitant
      Raz [F:SCM]MFGFCY : Raz [F:SCM]STOFCY : Raz [F:SCM]LOC
      [F:SCM]STOMGTCOD = 1
   Endif

   If WALL=1 & [F:SCM]STOMGTCOD=2
      Call ALLOCATION("C", WALLTYP, [F:SCM]ALLQTY, [F:SCM]SHTQTY, WRET) From SCOALL
   Endif

Else
  # -----------------------------------
  # maj ligne courante [M:SCO2]
  # -----------------------------------
   If [M:SCO2]STOFCY(LMAT)<>LFCY & [M:SCO2]ALLQTY(LMAT)+[M:SCO2]SHTQTY(LMAT)>0
     Case [M:SCO2]ALLSTA(LMAT)
         When 2,3: WALLTYP = 1
         When 4,5: WALLTYP = 2
     Endcase
     # désallouer sur l'ancien site
     nolign=LMAT
     [F:SCM] = [M:SCO2]
     Call ALLOCATION("A", WALLTYP, [M:SCO2]ALLQTY(LMAT), [M:SCO2]SHTQTY(LMAT), WRET) From SCOALL
     [M:SCO2] = [F:SCM]
     [M:SCO1]ALLSTA = 1 : Affzo [M:SCO1]ALLSTA
     WALL=1
   Endif

    # Issue 86384 GA 12/2012 sauf matière exclue
    If [M:SCO2]SCOFLG(LMAT) < 3 & [M:SCO2]CPNTYP(LMAT)=1 & [M:SCO2]MATSTA(LMAT)<>4
       [M:SCO2]STOFCY(LMAT)=LFCY
       Call READ_ITM_ITF ([M:SCO2]CPNITMREF(LMAT),[M:SCO2]STOFCY(LMAT)) From ITMLIB
       #If GOK<1 : End : Endif # Issue 83440 GA 11/2012

       If [M:SCO2]SCA(LMAT) <> 0  & [F:ITF]RELSCATIA<>0
          [M:SCO2]RELSCATIA(LMAT) = [F:ITF]RELSCATIA
       Endif

       [M:SCO2]LOC(LMAT)    = [M:SCO1]LOC     # emplacement sous-traitance
       [M:SCO2]MFGFCY(LMAT) = [M:SCO1]MFGFCY
       [M:SCO2]STOMGTCOD(LMAT) = func ITMLIB.GET_STOMGTCOD([M:SCO2]CPNITMREF(LMAT),[M:SCO2]STOFCY(LMAT))
       # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
       #If [M:SCO2]STOMGTCOD(LMAT)<2 [M:SCO2]SCOFLG(LMAT)=1 Endif
    Elsif [M:SCO2]SCOFLG(LMAT) = 3  | [M:SCO2]MATSTA(LMAT) = 4
     # pas de site de stockage, pas d'adresse sous-traitant
       Raz [M:SCO2]MFGFCY(LMAT) : Raz [M:SCO2]STOFCY(LMAT) : Raz [M:SCO2]LOC(LMAT)
       [M:SCO2]STOMGTCOD(LMAT) = 1
    Endif

    If [M:SCO2]STOMGTCOD(LMAT)=2    # recherche stock disponible site
      If WALL=1
         [F:SCM]STOFCY=LFCY
         Call ALLOCATION("C", WALLTYP, [M:SCO2]ALLQTY(LMAT), [M:SCO2]SHTQTY(LMAT), WRET) From SCOALL
         [M:SCO2] = [F:SCM]
         [M:SCO1]ALLSTA = [F:SCO]ALLSTA : Affzo [M:SCO1]ALLSTA
      Endif

      Call LECITV2([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),WRET) From MFGLIB

      #--- Issue 115110 : Added LECCVAL parameter in 10th position
      Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
      If dim([M:SCO2]ECCVALMAJ)>0 & [M:SCO2]ECCVALMAJ(LMAT)<>""
        If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
        Call LECSRU([M:SCO2]STOFCY(LMAT),[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
        If WRET=0 & [F:SRU]ORDVER=2
          WECCVALMAJ=[M:SCO2]ECCVALMAJ(LMAT)
        Endif
      Endif
      Call STODISALL([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
      #Call STODISALL([M:SCO2]STOFCY(LMAT),[M:SCO2]CPNITMREF(LMAT),36,1,2,1,2,"","",WDIS,WRET) From STKALL
      #--- End issue 115110

      [M:SCO2]AVAQTY(LMAT)    = WDIS + [M:SCO2]ALLQTY(LMAT)
    Endif
Endif

End

############################################################
Subprog UPD_MAT_FCY2(LNEWFCY, LNEWLOC, LLINMAT)
Value    Char    LNEWFCY
Value    Char    LNEWLOC
Value    Integer LLINMAT

Local    Integer  WRET
Local    Decimal  WDIS, WALLQTY

If LNEWFCY="" End Endif

If [M:SCO2]STOFCY(LLINMAT)=LNEWFCY
& & [M:SCO2]LOC(LLINMAT)=LNEWLOC
    End
Endif

If clalev([F:STA])=0 : Local File STOALL [STA] : Endif
If clalev([F:STO])=0 : Local File STOCK  [STO] : Endif

Call READ_ITM_ITF ([M:SCO2]CPNITMREF(LLINMAT),LNEWFCY) From ITMLIB
If GOK<>1 & [M:SCO2]SCOFLG(LLINMAT)=2 : End # Issue 83440 GA 11/2012
Else GOK=1 : Raz GMESSAGE
Endif

If [M:SCO2]SCA(LLINMAT) <> 0  & [F:ITF]RELSCATIA<>0
    [M:SCO2]RELSCATIA(LLINMAT) = [F:ITF]RELSCATIA
Endif
[M:SCO2]STOMGTCOD(LLINMAT)=[F:ITF]STOMGTCOD # Issue 83440 GA 11/2012

If [M:SCO2]STOMGTCOD(LLINMAT)=2    # recherche stock disponible site
    Call LECITV2(LNEWFCY,[M:SCO2]CPNITMREF(LLINMAT),WRET) From MFGLIB

    #--- Issue 115110 : Added LECCVAL parameter in 10th position
    Local Char WECCVALMAJ(GLONECS) : WECCVALMAJ=""
    If dim([M:SCO2]ECCVALMAJ)>0 & [M:SCO2]ECCVALMAJ(LLINMAT)<>""
      If clalev([F:SRU])=0  : Local File TABSTORUL [SRU] : Endif
      Call LECSRU(LNEWFCY,[F:ITM]TCLCOD,29,"","",WRET) From STKLIB
      If WRET=0 & [F:SRU]ORDVER=2
        WECCVALMAJ=[M:SCO2]ECCVALMAJ(LLINMAT)
      Endif
    Endif
    Call STODISALL(LNEWFCY,[M:SCO2]CPNITMREF(LLINMAT),36,1,2,1,2,"","",WECCVALMAJ,WDIS,WRET) From STKALL
    #Call STODISALL(LNEWFCY,[M:SCO2]CPNITMREF(LLINMAT),36,1,2,1,2,"","",WDIS,WRET) From STKALL
    #--- End issue 115110

    If [M:SCO2]ALLSTA(LLINMAT)<4
        Filter [STA] Where STOFCY = LNEWFCY
&                        & ITMREF = [M:SCO2]CPNITMREF(LLINMAT)
&                        & VCRTYP = 36
&                        & VCRNUM = [M:SCO0]SCONUM
        Look [STA] First
        Filter [STA]
        If !fstat
            # Les allocations correspondent au site => on prend en compte les alloc dans le dispo
            [M:SCO2]AVAQTY(LLINMAT)    = WDIS + [M:SCO2]ALLQTY(LLINMAT)
        Else
            [M:SCO2]AVAQTY(LLINMAT)    = WDIS
        Endif
    Else
        Link [STA] With [STO]STO0 ~= [STA]STOFCY;[STA]STOCOU
&                  As [LNK]
&                  Where [STA]STOFCY = LNEWFCY
&                      & [STA]ITMREF = [M:SCO2]CPNITMREF(LLINMAT)
&                      & [STA]VCRTYP = 36
&                      & [STA]VCRNUM = [M:SCO0]SCONUM
&                      & [STO]LOC    = LNEWLOC
&                      & [STA]ALLTYP = 2
        For [LNK]
            WALLQTY += [F:STA]QTYSTUACT
        Next
        [M:SCO2]AVAQTY(LLINMAT)    = WDIS + WALLQTY
        # Issue 87038 GA 01/2013 performances
        #Affzo [M:SCO2]AVAQTY(LLINMAT)
    Endif
Endif

# Issue 86384 GA 12/2012 sauf matière exclue
#If [M:SCO2]SCOFLG(LLINMAT) < 3 & [M:SCO2]CPNTYP(LLINMAT)=1
    If [M:SCO2]SCOFLG(LLINMAT) < 3 & [M:SCO2]CPNTYP(LLINMAT)=1 & [M:SCO2]MATSTA(LLINMAT)<>4
    [M:SCO2]STOFCY(LLINMAT) = LNEWFCY
    [M:SCO2]LOC(LLINMAT)    = LNEWLOC
    [M:SCO2]MFGFCY(LLINMAT) = [M:SCO1]MFGFCY
    [M:SCO2]STOMGTCOD(LLINMAT) = func ITMLIB.GET_STOMGTCOD([M:SCO2]CPNITMREF(LLINMAT),[M:SCO2]STOFCY(LLINMAT))
    # Issue 115728 - 2016-04-01 by MUARN : SCOFLG = 1 ne doit pas être exploité
    #If [M:SCO2]STOMGTCOD(LLINMAT)<2 [M:SCO2]SCOFLG(LLINMAT)=1 Endif
Elsif [M:SCO2]SCOFLG(LLINMAT) = 3
    # pas de site de stockage, pas d'adresse sous-traitant
    Raz [M:SCO2]MFGFCY(LLINMAT) : Raz [M:SCO2]STOFCY(LLINMAT) : Raz [M:SCO2]LOC(LLINMAT)
    [M:SCO2]STOMGTCOD(LLINMAT) = 1
Endif

# Issue 87038 GA 01/2013 performances
#Affzo [M:SCO2]STOFCY(LLINMAT) : Affzo [M:SCO2]LOC(LLINMAT)

End



#########################################################################
# Contrôle de validité (pour sous-traitance) d'une matière              #
# [F:ITM] & [F:ITF] doivent être chargés ...                            #
#-----------------------------------------------------------------------#
# Issue 114967 - 2016-03-14 by MUARN : toujours utiliser CONTMATITM, ancien renommé
Subprog CONTMATITM_OLD(LCPNITMREF, LFCY, LSCOFLG, LMSG) #### Obsolete !!!! #####
Value    Char     LCPNITMREF
Value    Char     LFCY
Value    Integer  LSCOFLG
Value    Integer  LMSG

Local    Integer  WOK : WOK=2
Local    Integer  WSTOMGTCOD : WSTOMGTCOD =2

# Issue 83440 GA 11/2012 pour les ctrl [F:ITF]
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif
If [F:FCY]WRHFLG<>2 End Endif # ne rien contrôler ?

If LSCOFLG=2
 #----- Type de Gestion stock -----#
  WSTOMGTCOD = func ITMLIB.GET_STOMGTCOD(LCPNITMREF, LFCY)
  If WSTOMGTCOD=1
   # Article non géré en stock pour le site
     GMESSAGE=LCPNITMREF-mess(2,196,1)-LFCY
     mkstat=1 : End
  Endif

  GPE=0 : GPOINT = "CTLITMSTA" : Gosub ENTREE From EXEFNC # Issue 94144
 If !GPE
  # Ctrl supplémentaire sous-traitance:
  # une matière mise à dispo sous-traitant doit être active, non périmée
    WOK = func ITMLIB.IS_ACTIVE (LCPNITMREF)
    If WOK=1 : mkstat=1: End : Endif
  Endif

  GPE=0 : GPOINT = "CTLDLVFLG" : Gosub ENTREE From EXEFNC # Issue 94144
  If !GPE
  # une matière mise à dispo sous-traitant doit être vendue ou livrable
    WOK = func ITMLIB.IS_DELIVERABLE (LCPNITMREF)
    If WOK=1 : mkstat=1: End : Endif
  Endif

### Call CONTMATITM (LFCY, LMSG ) From MFGLIB

Elsif LSCOFLG=3

 # Est-ce que cet article est acheté ? sinon pb génération de la commande
   WOK = func ITMLIB.IS_BOUGHT ( LCPNITMREF)
   If WOK=1 : mkstat=1: End : Endif

Endif
End

# Issue 114967 - 2016-03-14 by MUARN : renommer sans ECC comme fait sur OF
#**----------------------------------------------------------------<br/>
#* CONTMATITMECC : Control of a component for EO<br/>
#* (!!! [F:ITM] & [F:ITF] are read !!!)
#**<br/>----------------------------------------------------------------<br/>
#* @param LCPNITMREF   = component
#* @param LFCY         = site
#* @param LSCOFLG      = type of component
#* @param PABR         = Origin of the call (optional)
#* @param PRET(return) = error code (0=OK, 1=Error to correct before tracking, 3=Warning, 4=Error can't create WO/EO)
#* @param PMSG(return) = error message
#**<br/>----------------------------------------------------------------
#*!
Subprog CONTMATITM(LCPNITMREF, LFCY, LSCOFLG, PABR, PRET, PMSG)
Value Char       LCPNITMREF
Value Char       LFCY
Value Integer    LSCOFLG
Value Char       PABR
Variable Integer PRET
Variable Char    PMSG

Local    Integer  WOK : WOK=2
Local    Integer  WSTOMGTCOD : WSTOMGTCOD =2

Local Char    WCTLFLG(10)
Local Integer VS
Local Integer WCTL,WCTLITLCTLMSTA

# Issue 83440 GA 11/2012 pour les ctrl [F:ITF]
If [F:FCY]FCY<>LFCY
   Read [FCY]FCY0=LFCY
   If fstat Raz [F:FCY] Endif
Endif

# Issue 114967 - 2016-03-14 by MUARN : inutile pour la SST sans OF
## Default value : error for all except the case where item is not managed in stock (no phantom here)
#WCTLFLG="1111111110"
#If find(PABR, "SCO2", "SCM", "SCMW") & GCMPUSBCTR=2
#    # General parameter CMPUSBCTR doesn't allow creation of EO if status of component is "not usable"
#    # => blocking error for this control
#    # WCTLFLG = xxxxxxYxxx --> xxxxxx4xxx
#    WCTLFLG=left$(WCTLFLG,6)+"4"+right$(WCTLFLG,8)
#Endif

If LSCOFLG=2
 #----- Type de Gestion stock -----#
  WSTOMGTCOD = func ITMLIB.GET_STOMGTCOD(LCPNITMREF, LFCY)
  If WSTOMGTCOD=1
   # Article non géré en stock pour le site
     GMESSAGE=LCPNITMREF-mess(2,196,1)-LFCY
     # Issue 114967 - 2016-03-15 by MUARN : gestion erreur
     PRET = 4
     mkstat=1 : End
  Endif

  GPE=0 : GPOINT = "CTLITMSTA" : Gosub ENTREE From EXEFNC # Issue 94144
  If !GPE
  # Ctrl supplémentaire sous-traitance:
  # une matière mise à dispo sous-traitant doit être active, non périmée
    WOK = func ITMLIB.IS_ACTIVE (LCPNITMREF)
    # Issue 114967 - 2016-03-15 by MUARN : gestion erreur
    #If WOK=1 : mkstat=1: End : Endif
    If WOK=1 : mkstat=1: : PRET = 4 : End : Endif
  Else WCTLITMSTA=GPE
  Endif

  GPE=0 : GPOINT = "CTLDLVFLG" : Gosub ENTREE From EXEFNC # Issue 94144
  If !GPE
  # une matière mise à dispo sous-traitant doit être vendue ou livrable
    WOK = func ITMLIB.IS_DELIVERABLE (LCPNITMREF)
    # Issue 114967 - 2016-03-15 by MUARN : gestion erreur
    #If WOK=1 : mkstat=1: End : Endif
    If WOK=1 : mkstat=1: : PRET = 4 : End : Endif
  Endif

  # 1 - ITM exists
  If [F:ITM]ITMREF<>LCPNITMREF
      Raz [F:ITM]
      Read [ITM]ITM0=LCPNITMREF
      # Issue 114967 - 2016-03-14 by MUARN : contrôle bloquant
      #WCTL=val(mid$(WCTLFLG,1,1))
      WCTL=4
      If WCTL & fstat
          Call ADDMSG(PRET, PMSG, WCTL, mess(212,199,1)) From ECCLIB
      Endif
      If find(PRET,1,4) : End : Endif
  Endif

  # 2 - ITF exists
  If [F:ITF]ITMREF<>LCPNITMREF | [F:ITF]STOFCY<>LFCY
      Raz [F:ITF]
      Read [ITF]ITF0=LCPNITMREF;LFCY
      # Issue 114967 - 2016-03-14 by MUARN : contrôle bloquant
      #WCTL=val(mid$(WCTLFLG,1,1))
      WCTL=4
      If WCTL & fstat
          Call ADDMSG(PRET, PMSG, WCTL, mess(260,199,1)) From ECCLIB
      Endif
      If find(PRET,1,4) : End : Endif
  Endif

  # 3- In development
  # 4- On shortage
  # 5- Not renewed
  # 6- Obsolete
  # 7- Not usable
  If [F:ITM]ITMSTA>=2 & [F:ITM]ITMSTA<=6 & WCTLITMSTA=0
      # Issue 114967 - 2016-03-14 by MUARN : contrôle bloquant
      #WCTL = val(mid$(WCTLFLG,[F:ITM]ITMSTA+1,1))
      WCTL=4
      If WCTL
          Call ADDMSG(PRET, PMSG, WCTL, mess(46,200,1)-":"-mess([F:ITM]ITMSTA,246,1)) From ECCLIB
      Endif
      If find(PRET,1,4) : End : Endif
  Endif

  # 8- control of categorie (????)
  #WCTL = val(mid$(WCTLFLG,8,1))
  #If WCTL & [F:ITM]PURFLG <> 2 & [F:ITM]MFGFLG <> 2 & [F:ITM]SCPFLG <> 2
  #    Call ADDMSG(PRET, PMSG, WCTL, mess(65,193,1)) From ECCLIB
  #Endif
  #If find(PRET,1,4) : End : Endif

  # 9/10- if component not managed in stock and ...
  # Issue 114967 - 2016-03-14 by MUARN : pas de gestion des fantômes
#  If !find([F:ITF]STOMGTCOD,2,3,4)
#      If [F:ITM]PHAFLG <> 2
#          # it's not a phantom
#          WCTL = val(mid$(WCTLFLG,9,1))
#          If WCTL
#              Call ADDMSG(PRET, PMSG, WCTL, mess(147,199,1)) From ECCLIB
#          Endif
#      Else
#          # it's a phantom
#          WCTL = val(mid$(WCTLFLG,10,1))
#          If WCTL
#              Call ADDMSG(PRET, PMSG, WCTL, mess(147,199,1)) From ECCLIB
#          Endif
#      Endif
#  Endif
#  If find(PRET,1,4) : End : Endif

Elsif LSCOFLG=3

 # product must be bought to generate the PO
   WOK = func ITMLIB.IS_BOUGHT ( LCPNITMREF)
   If WOK=1 : mkstat=1: End : Endif

Endif

End

#########################################################################################
# contrôle d'atteinte du seuil de solde automatique
#########################################################################################
Subprog CONT_SOLDE_MAT(LFCY, LITM, LCPL, LEXT, LRET)
Value     Char     LFCY    # site
Value     Char     LITM    # matière
Value     Decimal  LCPL    # quantité réalisée
Value     Decimal  LEXT    # quantité prévue
Variable  Integer  LRET    # code retour        0 = rien, 1 = à solder
#
# Issue 112081 - 2015-10-30 by SR : [F:ITF]CLEPCTAUT exclusivement pour le manufacturing, pas pour la sous-traitance
#Call CONT_SOLDE_ITM(LFCY, LITM, LCPL, LEXT, LRET)
If LEXT <= LCPL : LRET = 1 : Endif
# End issue 112081
#
End

#########################################################################################
# contrôle d'atteinte du seuil de solde automatique
#########################################################################################
Subprog CONT_SOLDE_OPE(LFCY, LITM, LCPL, LEXT, LRET)
Value     Char     LFCY    # site
Value     Char     LITM    # matière
Value     Decimal  LCPL    # quantité réalisée
Value     Decimal  LEXT    # quantité prévue
Variable  Integer  LRET    # code retour        0 = rien, 1 = à solder
#
# Issue 112081 - 2015-10-30 by SR : [F:ITF]CLEPCTAUT exclusivement pour le manufacturing, pas pour la sous-traitance
#Call CONT_SOLDE_ITM(LFCY, LITM, LCPL, LEXT, LRET)
If LEXT <= LCPL : LRET = 1 : Endif
# End issue 112081
#
End

