##########################################################################
# Maj réutilisée par les fonctions de SCOSTKLIB, SCOSBCLIB, SCOAUTLIB, ...
$REWRITE_SCO
#point d'entrée  pour récup infos supplémentaires avant ré écriture ligne
GPOINT = "UPDSCOMAJ" : Gosub ENTREE From EXEFNC
Local Integer WUPDTRBEGIN
Raz WUPDTRBEGIN

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [SCO]
   WUPDTRBEGIN=1
Endif

#
[F:SCO]UPDDAT = date$
[F:SCO]UPDUSR = GUSER
#
If find(GREP,"M","A")
#----- MISE à jour statistiques entête d'EO -----#
   Call VALSTA("SCO",-1)   From SUBPS2
   If GOK < 1 :  Goto ROLL_REWRITE_SCO : Endif
Endif

Rewrite [SCO]
If fstat : GOK = 0 : Call FSTA ("SCO") From GLOCK  :  Goto ROLL_REWRITE_SCO : Endif

If find(GREP,"C","M")
#----- MISE à jour statistiques Entête d'EO -----#
   Call VALSTA("SCO",1)   From SUBPS2
   If GOK < 1 :  Goto ROLL_REWRITE_SCO : Endif
Endif

# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
Endif
Return
$ROLL_REWRITE_SCO
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return


