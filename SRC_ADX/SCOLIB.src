#########################################################################
# Maj réutilisée par les fonctions de SUBSCO*, ...
$DELETE_SCO
Local Integer WUPDTRBEGIN
Raz WUPDTRBEGIN

# Si pas de transaction en cours
If adxlog<>1
   GOK=1
   Trbegin [SCO]
   WUPDTRBEGIN=1
Endif

#
 # Màj allocations matières + màj de ORDERS
   Call UPDATE_MSX("A", 0) From SCOLIB

 # point d'entrée avant suppression ligne
   GPOINT = "DELSCOMAJ" : Gosub ENTREE From EXEFNC

   Delete [SCO]SCO0=[F:SCO]SCONUM
   If fstat : GOK=0 : Call FSTA("SCO") From GLOCK : Goto ROLL_DELETE_SCO : Endif

 #----- Mise à jour statistiques matière -----#
   Call VALSTA("SCO",-1) From SUBPS2

# Si on a ouvert une transaction
If WUPDTRBEGIN=1
   Commit
   Raz WUPDTRBEGIN
Endif
Return
$ROLL_DELETE_SCO
If WUPDTRBEGIN=1
   Rollback
   Raz WUPDTRBEGIN
Endif
Return

#########################################################################
# Maj réutilisée par les fonctions de SUBSCO*, ...
$DELETE_SCI
