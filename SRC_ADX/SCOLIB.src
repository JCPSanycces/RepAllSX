   Call UPDATE_EOX("A") From SCOLIB

 # point d'entrée avant suppression ligne
   GPOINT = "DELSCIMAJ" : Gosub ENTREE From EXEFNC

   Delete [SCI]SCI0=[F:SCI]SCONUM;[F:SCI]SCILIN
