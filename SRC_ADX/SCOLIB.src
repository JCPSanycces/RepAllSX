############################################################
# Délai + date de l'article lancé
############################################################
Subprog UPD_ITM_DAT(LLTI,LFCY, LSTRDAT, LENDDAT)
Value    Integer LLTI
Value    Char    LFCY
Value    Date    LSTRDAT
Variable Date    LENDDAT
  If LSTRDAT<>[0/0/0] & LENDDAT=[0/0/0]
  #  Calcul de la date : ENDDAT = STRDAT + LTI
  ####   Call CALC_DAT_FCY(LSTRDAT,LLTI,LFCY,0,LENDDAT) From TRTACHDAT
  Endif
End

############################################################
Subprog CALSTRDAT(LSCOLTI, LOPESTR, LOPEEND)
Value    Integer LSCOLTI
Variable Date    LOPESTR
Value    Date    LOPEEND

Local Decimal  WOFS : WOFS=LSCOLTI
Local Integer  WCOR : WCOR=8  # Arrondi date
Local Integer  WCOD : WCOD=1  # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés (???)
Local Shortint WUPD : WUPD=0  # flag recalcul enddat
Local Decimal  WCAP(31)
Local Date     WCALDATD : Raz WCALDATD

# Issue 88819 GA 03/2013
If LOPESTR=[0/0/0] & LOPEEND=[0/0/0]
   LOPESTR=date$
Endif
If LOPESTR=[0/0/0] & LOPEEND<>[0/0/0]
    # FQ 77115 GA 12/2011 idem FUNCBNA $TRT_DATSCS calcul en jours selon WCOD
    #  Calcul de la date de début de l'opération: OPESTR = OPEEND - SCOLTI
    Call CALDAT("-",WCOR,LOPEEND,WCOD,WOFS,WCAP,WCALDATD,LOPESTR) From CBNLIB
    # Issue 83274 GA 07/2012 sauf si on n'a pas maj la date de début !!!!
    # FQ 77115 GA 12/2011 pas de date antérieure ????
    If LOPESTR<date$ : LOPESTR=date$ : Endif
Endif

End

############################################################
Subprog CALENDDAT(LSCOLTI, LOPESTR, LOPEEND)
Value    Integer LSCOLTI
Value    Date    LOPESTR
Variable Date    LOPEEND

Local Decimal  WOFS : WOFS=LSCOLTI
Local Integer  WCOR : WCOR=8  # Arrondi date
Local Integer  WCOD : WCOD=1  # 1=Calendar days, 2=Workable days
Local Decimal  WCAP(31)
Local Date     WCALDATD : Raz WCALDATD

If LOPESTR=[0/0/0]
   LOPESTR=date$
Endif
#  Calcul de la date de fin de l'opération: OPEEND = OPESTR + SCOLTI
Call CALDAT("+",WCOR,LOPESTR,WCOD,WOFS,WCAP,WCALDATD,LOPEEND) From CBNLIB

End
############################################################
# Délai + dates de l'opération de sous-traitance
############################################################
Subprog UPD_SRV_DAT(LSCOLTI, LOPESTR, LOPEEND, LSRV)
Variable Integer LSCOLTI
Variable Date    LOPESTR
Variable Date    LOPEEND
Value    Integer LSRV

# FQ 77115 GA 12/2011 recalcul systématique de la date selon début du Service LSTRDAT
Local Decimal  WOFS : WOFS=LSCOLTI
Local Integer  WCOR : WCOR=8  # Arrondi date
Local Integer  WCOD : WCOD=1  # 1=délai achat en jours calendaires, 2=délai fab en jours ouvrés (???)
Local Shortint WUPD : WUPD=0  # flag recalcul enddat
Local Decimal  WCAP(31)
Local Date     WCALDATD : Raz WCALDATD

# Issue 100424 GA 07/2014 keep zero to be able to use [F:ITF]LTI on subcontrated product
#  Minimum 1 jour de délai ?
# If LSCOLTI < 1  : LSCOLTI = 1 : Endif

Call CALSTRDAT(LSCOLTI,LOPESTR,LOPEEND)

If LOPEEND=[0/0/0] & LOPESTR<>[0/0/0]
  # FQ 77115 GA 12/2011 idem FUNCBNA $TRT_DATSCS calcul en jours selon WCOD
  WDATR = LOPESTR
  Call CALDAT("+",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
  LOPEEND = WDATR
Endif

If clalev([M:SCO3])=0 | LSRV=-1
  # -------------------------------------------
  # accès aux enreg [F:SCO],[F:SCI] et [F:SCS]
  # -------------------------------------------

  # FQ 77115 GA 12/2011 la SCS pilote date+délai article lancé
  # If LOPESTR < [F:SCO]ORDDAT # FQ 52859 & 53567 GA 18/03/2009
  If LOPESTR <> [F:SCO]ORDDAT | [F:SCI]LTI <> LSCOLTI | WUPD=1
  #  (re)Calcul de la date de début de l'opération: OPESTR = ORDDAT + (LTI - SCOLTI)
   ###  If [F:SCI]LTI > LSCOLTI
   ###    # Call CALC_DAT_FCY([F:SCO]ORDDAT,[F:SCI]LTI-LSCOLTI,[F:SCI]PRHFCY,0,LOPESTR) From TRTACHDAT
   ###     WDATR = LOPESTR
   ###     WOFS  = [F:SCI]LTI-LSCOLTI
   ###     Call CALDAT("-",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
   ###     [F:SCO]ORDDAT = WDATR
   ###  Else
       # LOPESTR = [F:SCO]ORDDAT
       [F:SCO]ORDDAT = LOPESTR
       [F:SCI]LTI    = LSCOLTI
   ###  Endif
  #  re-Calcul de la date de fin de l'opération: OPEEND = OPESTR + SCOLTI
     Raz LOPEEND
     WDATR = LOPESTR
     Call CALDAT("+",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
     LOPEEND = WDATR
  Endif
  If LOPEEND <> [F:SCO]RETDAT
     If [F:SCO]RETDAT<>[0/0/0]
     #  Date de réception reportée au
        Call ECR_TRACE(mess(351,194,1)+' '+format$("D:"+GFMDAT,LOPEEND),0) From GESECRAN
     Endif
     [F:SCO]RETDAT = LOPEEND
  Endif
  # FQ 77488 GA 10/2011 taux de conversion à la date LOPESTR
  If dim([F:SCO]CHGTYP)>0 & LOPESTR<>[0/0/0]
     Local Decimal  WCHGCOE : WCHGCOE=[F:SCO]CHGCOE
     Local Shortint WCHGTYP : WCHGTYP=[F:SCO]CHGTYP
     Call FIND_CUR([F:SCO]BPRNUM,LOPESTR,[F:SCO]CUR,WCHGTYP,[F:SCO]CHGCOE) From SCOLIB
     [F:SCO]CHGTYP=WCHGTYP
     If [F:SCO]CUR<>"" & [F:SCO]CUR<>GCUR # FQ 79340 GA 01/2011 relecture du tarif selon GCUR
       GCUR=[F:SCO]CUR
       #[f:scs]CUR=[F:SCO]CUR # suite FQ 79340 ctrl des sources
       Call UPD_SRV_PRI(LSRV)
     Else
       If WCHGCOE<>[F:SCO]CHGCOE
          Gosub CALC_LINAMT_SCS     From SCOLIB
       Endif
     Endif
  Endif

Else
  # ----------------------------------
  # écran de saisie
  # ----------------------------------

  # FQ 77115 GA 12/2011 la SCS pilote date+délai article lancé
  # If LOPESTR < [M:SCO1]ORDDAT # FQ 52859 & 53567 GA 18/03/2009
  If LOPESTR <> [M:SCO1]ORDDAT | [M:SCO1]LTI <> LSCOLTI | WUPD=1
  #  Calcul de la date de début de l'opération: OPESTR = ORDDAT + (LTI - SCOLTI)
    ### If [M:SCO1]LTI > LSCOLTI
    ###   # Call CALC_DAT_FCY([M:SCO1]ORDDAT,[M:SCO1]LTI-LSCOLTI,[M:SCO1]PRHFCY,0,LOPESTR) From TRTACHDAT
    ###    WDATR = LOPESTR
    ###    WOFS  = [M:SCO1]LTI-LSCOLTI
    ###    Call CALDAT("-",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
    ###    [M:SCO1]ORDDAT = WDATR
    ### Else
       # LOPESTR = [M:SCO1]ORDDAT
       [M:SCO1]ORDDAT = LOPESTR : Affzo [M:SCO1]ORDDAT
       [M:SCO1]LTI    = LSCOLTI : Affzo [M:SCO1]LTI
    ### Endif
  #  re-Calcul de la date de fin de l'opération: OPEEND = OPESTR + SCOLTI
     Raz LOPEEND
     WDATR = LOPESTR
     Call CALDAT("+",WCOR,WDATR,WCOD,WOFS,WCAP,WCALDATD,WDATR) From CBNLIB
     LOPEEND = WDATR
  Endif
  If LOPEEND <> [M:SCO1]RETDAT
     If [M:SCO1]RETDAT<>[0/0/0]
    #  Date de réception reportée au
       Call MESSAGE(mess(351,194,1)+' '+format$("D:"+GFMDAT,LOPEEND)) From GESECRAN
     Endif
     [M:SCO1]RETDAT = LOPEEND
     Affzo [M:SCO1]RETDAT : Affzo [M:SCO1]ORDDAT
  Endif
  Affzo [M:SCO3]SCOLTI : Affzo [M:SCO3]OPESTR : Affzo [M:SCO3]OPEEND

  # FQ 77488 GA 10/2011 déplacé depuis AM_ORDDAT de SUBSCO1
  If dim([M:SCO1]CHGTYP)>0
     Local Decimal  WCHGCOE : WCHGCOE=[M:SCO1]CHGCOE
     Local Shortint WCHGTYP : WCHGTYP=[M:SCO1]CHGTYP
     Call FIND_CUR([M:SCO0]BPRNUM,LOPESTR,[M:SCO1]CUR,WCHGTYP,[M:SCO1]CHGCOE) From SCOLIB
     [M:SCO1]CHGTYP=WCHGTYP
     If [M:SCO1]CUR<>"" & [M:SCO1]CUR<>GCUR # FQ 79340 GA 01/2011 relecture du tarif selon GCUR
       GCUR=[M:SCO1]CUR
       [M:SCO3]CUR=[M:SCO1]CUR : Affzo [M:SCO3]CUR
       Call UPD_SRV_PRI(LSRV)
     Else
       If WCHGCOE<>[M:SCO1]CHGCOE
          Gosub CALC_LINAMT_SCO3     From SCOLIB
          Gosub CALC_LINAMT_SCO2_ALL From SCOLIB
       Endif
     Endif
  Endif

  # FQ 77115 GA 11/2011 Date de livraison des matières
  Local Shortint IMAT
  For IMAT=0 To [M:SCO2]NBLIG-1
     If [M:SCO2]SCOFLG(IMAT)=2
        Local Integer WOFS : WOFS=[M:SCO2]BOMOFS(IMAT)
        Call UPD_MAT_DAT(LOPESTR, [M:SCO3]OPEEND,[M:SCO2]STOFCY(IMAT),WOFS,[M:SCO2]DLVDAT(IMAT)) From SCOLIB
        # Issue X3-68900 - 2018-03-15 by MUARN : affichage date
        Affzo [SCO2]DLVDAT(IMAT)
     Endif
  Next
  # Issue 87038 GA 01/2013 performances
  #Affzo [M:SCO2]DLVDAT
Endif
End

############################################################
# Délai + date livraison des matières
############################################################
Subprog UPD_MAT_DAT(LSTRDAT,LENDDAT,LFCY, LBOMOFS, LDLVDAT)
Value    Date    LSTRDAT
Value    Date    LENDDAT
Value    Char    LFCY
Variable Integer LBOMOFS
Variable Date    LDLVDAT

# FQ 77115 GA 11/2011 recalcul systématique de la date selon début du Service LSTRDAT
Local Decimal WOFS
Local Integer WCOR     :   WCOR=8  # Arrondi date
Local Integer WCOD     :   WCOD=1  # Type de délai
Local Decimal WCAP(31)
Local Date    WCALDATD : Raz WCALDATD

  If LSTRDAT = [0/0/0] End Endif
  If LBOMOFS=0
    # Date de début du service si aucun délai
      LDLVDAT=LSTRDAT
  Elsif LBOMOFS > 0
    # Calcul de la date de mise à dispo des matières: DLVDAT = STRDAT + BOMOFS
    ###  Call CALC_DAT_FCY(LSTRDAT,LBOMOFS,LFCY,0,LDLVDAT) From TRTACHDAT
     WOFS = LBOMOFS
     Call CALDAT("+",WCOR,LSTRDAT,WCOD,WOFS,WCAP,WCALDATD,LDLVDAT) From CBNLIB
  Else
     WOFS = LBOMOFS * -1
     Call CALDAT("-",WCOR,LSTRDAT,WCOD,WOFS,WCAP,WCALDATD,LDLVDAT) From CBNLIB
  Endif
End



############################################################################################
Subprog UPD_SCOTRKFLG(LSCONUM, LRET)
Value     Char     LSCONUM
Variable  Integer  LRET
Local     Integer  WWIP
Local     Integer  WPRN
Local     Integer  WSCILIN : WSCILIN = 1000
Local     Integer  WSCSLIN : WSCSLIN = 5
LRET = 0

# Ouverture des tables si nécessaire
Gosub OPEN_FILES_SCO From SCOLIB

Readlock [SCO]SCO0 = LSCONUM
If fstat : LRET = 1 : Endif

WWIP = 0
WPRN = 0
# analyse de l'état d'avancement ordre de sous-traitance
# ------------------------------------------------------
If [F:SCI]SCONUM<>LSCONUM
#  Article lancé
   Read [SCI]SCI0=LSCONUM;WSCILIN
   If fstat : Raz [F:SCI] : Endif
Endif
If [F:SCI]ITMSTA > 1 & [F:SCI]ITMSTA <> 5 : WWIP += 1 : Endif

# on ne regarde que les matières "mises à dispo du sous-traitant"
For [SCM]SCM0 Where SCONUM = LSCONUM & SCOFLG=2 & MATSTA<>4
    If [F:SCM]MATSTA > 1 : WWIP += 1 : Endif
Next

If [F:SCS]SCONUM<>LSCONUM
#  Service de sous-traitance
   Read [SCS]SCS0=LSCONUM;WSCILIN;WSCSLIN
   If fstat : Raz [F:SCS] : Endif
Endif
If [F:SCS]OPESTA > 3 & [F:SCS]OPESTA <> 6 : WWIP += 1 : Endif

# FQ 75630 & 75631 GA 09/2011 impact de la commande sur l'EO
If [F:SCS]OPEEND>[F:SCO]RETDAT
   Local Integer  WOFS : [L]WOFS = [F:SCS]SCOLTI
   Call UPD_SRV_DAT([L]WOFS, [F:SCS]OPESTR, [F:SCS]OPEEND, -1)
Endif

If WWIP <> 0
    [F:SCO]SCOTRKFLG = 4         # SCO en cours
Else
# pas d'édition du dossier de fabrication pour les SCO
#    If WPRN <> 0
#        [F:SCO]SCOTRKFLG =  3    # SCO édité
#    Else
        [F:SCO]SCOTRKFLG =  1    # SCO en attente
#    Endif
Endif

# FQ 53925 en dernier pour ne pas écraser SCOTRKFLG si soldé
Gosub MAJSCOHEAD

Rewrite [SCO]
If fstat : LRET = 1 : Endif

End

######################################################################################

Subprog UPDATE_EOX (LCOD)
Value Char    LCOD
Local Integer WRET
Local Char    TRTORD(1)
Local Decimal WQTY
Local Decimal WTOTPEC, WECART, WECART2, WTOTCOV, WTOTEOP, WTOTEOPC
Local Integer WTYPORI, WLINORI, WSEQORI    # 10.04 26006
Local Char    WNUMORI(GLONVCR)             # 10.04 26006
If dim(GMEMSTA)<=0 : Global Integer  GMEMSTA : GMEMSTA=[F:SCO]SCOSTA : Endif
#-------------------------------#
# Maj de l'en-cours dans ORDERS #
#-------------------------------#

# Issue 88677
Local Integer SAVGOK : SAVGOK=GOK
GOK=1 # Issue 88411 GA 03/2013

Raz [M:ORDK]
Local Integer STAT
If [F:SCI]WIPNUM = ""
 # Issue 84787 avant STOFCY=[F:SCO]POHFCY
 # Recherche d'un ancien encours EOx dont on aurait perdu la référence
   For [ORD]ORD3 Where STOFCY=[F:SCI]PRHFCY
&                  and VCRTYP=36 and VCRNUM=[F:SCI]SCONUM
&                  and VCRLIN=[F:SCI]SCILIN and VCRSEQ=0
&                  and WIPTYP=13
     [F:SCI]WIPNUM = [F:ORD]WIPNUM : Break
   Next
   # Issue 103007 GA 09/2014 when [F]WIPNUM is lost
   If [F:SCI]WIPNUM<>"" Rewrite [F:SCI] : Endif
Else
   # FQ 54554 vérif de la présence de l'EOX
   Read [ORD]ORD0=[F:SCI]WIPTYP;[F:SCI]WIPNUM;[F:SCI]ITMREF
   If fstat Raz [F:ORD] : Raz [F:SCI]WIPNUM : Endif    # Issue 88411 GA 03/2013 vider [F:SCI]WIPNUM si encours absent ?
Endif
If [F:SCI]WIPNUM = "" & LCOD<>"A"
 # affectation d'un n° d'encours EOx
   WCOD = "C"
Else
   WCOD = LCOD
Endif
[F:SCI]WIPSTA  = [F:SCO]SCOSTA
[F:SCI]WIPTYP  = 13 : # Encours EO*

# Issue 103007 GA 09/2014 except when EOX has to be recreated
#If [F:SCI]WIPNUM = [F:ORD]WIPNUM & WCOD="C"
If [F:SCI]WIPNUM<>"" & [F:SCI]WIPNUM = [F:ORD]WIPNUM & WCOD="C"
   WCOD="M"   # FQ 54554 passer en modif si l'EOF existe déjà (génération de commande)
Endif

Case WCOD
    When "C":
      # création encours
        Call NUMERO(GWIP,[F:SCI]PRHFCY,[F:SCO]ORDDAT,"", [F:SCI]WIPNUM,STAT) From SUBANM
        #--CPO  68322/59141
        #If STAT <> 0 : Call ERREUR("EOX"-mess(60,199,1)) From GESECRAN : End : Endif
        If GOK<1 | STAT<>0
          Local Char MESSA(80)
          Gosub MESSAGE From SUBANM
          Call ERREUR("EOX"-mess(60,199,1)-"("+GWIP+") :"-MESSA) From GESECRAN : End
        Endif
        #--/CPO 68322/59141
 #
        [M:ORDK]MAJCOD     = "C"
        [M:ORDK]WIPTYP     = [F:SCI]WIPTYP
        [M:ORDK]WIPSTA     = [F:SCI]WIPSTA
        [M:ORDK]WIPNUM     = [F:SCI]WIPNUM
        [M:ORDK]ITMREF     = [F:SCI]ITMREF
        [M:ORDK]ORIFCY     = [F:SCO]POHFCY
        [M:ORDK]STOFCY     = [F:SCI]PRHFCY
        [M:ORDK]PJT        = [F:SCI]PJT
        [M:ORDK]PIO        = [F:SCI]PIO
        [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
        [M:ORDK]STRDAT     = [F:SCO]ORDDAT
        [M:ORDK]ENDDAT     = [F:SCO]RETDAT
        [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de SUBMFGA
        [M:ORDK]VCRNUM     = [F:SCI]SCONUM
        [M:ORDK]VCRLIN     = [F:SCI]SCILIN
        [M:ORDK]VCRSEQ     = 0
        [M:ORDK]EXTQTY     = [F:SCI]EXTQTY    : #GA avant EXTQTY
        [M:ORDK]CPLQTY     = [F:SCI]ORDQTY    : # Total Qté commandée
        [M:ORDK]ALLQTY     = 0
        [M:ORDK]SHTQTY     = 0
        [M:ORDK]FMI        = 1  : #GA à revoir 5=Ordre de production, 1=Achat
        [M:ORDK]MRPMES     = 1
        [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
        [M:ORDK]ITMREFORI  = ""
        If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
         [M:ORDK]ECCVALMAJ  = [F:SCI]ECCVALMAJ
         [M:ORDK]ECCVALMIN  = [F:SCI]ECCVALMIN
        Endif
        [M:ORDK]BOMALT     = [F:SCI]BOMALT
        [M:ORDK]BOMALTTYP  = 3
        [M:ORDK]ORI        = 1                : # ORI: 1=Achats, avant 4=Production extrait de SUBMFGA
        [M:ORDK]ABBFIL     = "SCI"
        #GA à revoir: contre-marque au niveau des Ventes
#        If [F:SCI]FMI = 5  : #GA à revoir 5=Ordre de production (Menu Local 445)
#            Call MAJFMISOQ([F:SCI]VCRNUMORI, [F:SCI]VCRLINORI, [F:SCI]VCRSEQORI,
#&                          [F:SCI]SCONUM, [F:SCI]SCILIN, 0, 1, WRET) From TRTVENMAJ
#        Endif
        Call WIP From TRTWIP

    When "M":
     #  Maj si modification ligne
        [M:ORDK]MAJCOD     = "M"
        [M:ORDK]WIPTYP     = [F:SCI]WIPTYP
        [M:ORDK]WIPSTA     = [F:SCI]WIPSTA
        [M:ORDK]WIPNUM     = [F:SCI]WIPNUM
        [M:ORDK]ITMREF     = [F:SCI]ITMREF
        [M:ORDK]ORIFCY     = [F:SCO]POHFCY
        [M:ORDK]STOFCY     = [F:SCI]PRHFCY
        [M:ORDK]PJT        = [F:SCI]PJT
        [M:ORDK]PIO        = [F:SCI]PIO
        [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
        [M:ORDK]STRDAT     = [F:SCO]ORDDAT
        [M:ORDK]ENDDAT     = [F:SCO]RETDAT
        [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de SUBMFGA
        [M:ORDK]VCRNUM     = [F:SCI]SCONUM
        [M:ORDK]VCRLIN     = [F:SCI]SCILIN
        [M:ORDK]VCRSEQ     = 0
        [M:ORDK]EXTQTY     = [F:SCI]EXTQTY
        [M:ORDK]CPLQTY     = [F:SCI]ORDQTY    : # Total Qté commandée
        [M:ORDK]ALLQTY     = 0
        [M:ORDK]SHTQTY     = 0
        [M:ORDK]FMI        = 1  : #GA à revoir 5=Ordre de production, 1=Achat
        [M:ORDK]MRPMES     = 1
        [M:ORDK]MRPQTY     = 0
        [M:ORDK]MRPDAT     = [0/0/0]
        [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
        [M:ORDK]ITMREFORI  = ""
        If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
         [M:ORDK]ECCVALMAJ  = [F:SCI]ECCVALMAJ
         [M:ORDK]ECCVALMIN  = [F:SCI]ECCVALMIN
        Endif
        [M:ORDK]BOMALT     = [F:SCI]BOMALT
        [M:ORDK]BOMALTTYP  = 3
        [M:ORDK]ORI        = 1                : # ORI: 1=Achats, avant 4=Production extrait de SUBMFGA
        [M:ORDK]ABBFIL     = "SCI"
        Call WIP From TRTWIP

    When "A":
        [M:ORDK]MAJCOD     = "A"
       # Supprimer l'encours EOX dont la référence n'est peut-être plus dans [F:SCI]WIPxxx
         For [ORD] Where WIPTYP=13 and ITMREF=[F:SCI]ITMREF
&                    and VCRTYP=36 and VCRNUM=[F:SCI]SCONUM and VCRLIN=[F:SCI]SCILIN
             [M:ORDK]WIPTYP     = [F:ORD]WIPTYP
             [M:ORDK]WIPNUM     = [F:ORD]WIPNUM
             [M:ORDK]ITMREF     = [F:ORD]ITMREF
             Call WIP From TRTWIP
         Next
         Raz [F:SCI]WIPNUM,[F:SCI]WIPTYP,[F:SCI]WIPSTA
Endcase
# mise à jour quantité en commande article
If [F:SCO]SCOSTA <> 1 : End : Endif

#GA cette synchro est faite par ailleurs cf SCOAUTLIB après appels UPDATE_EOX
#GA Gosub MAJ_ITMMVT

If GOK=0
   GMESSAGE="UPDATE_EOX: Erreur de mise à jour de l'encours "-num$([M:ORDK]WIPTYP)-" No="-[M:ORDK]WIPNUM
   mkstat=1
Endif
$UPDATE_EOX_FIN  # Issue 88677
If GOK=1 GOK=SAVGOK Endif
End


##################################################################
# Routine de mise à jour de l'encours service sous-traitance
# [F:SCS],[F:SCO],[F:SCI] doivent être chargé avant l'appel
# Fonction appelée par SBCLIB en création/maj de commande
# LCOD = C,    Création     SCx
# LCOD = M,    Modification SCx
# LCOD = A,    Suppression  SCx
##################################################################
Subprog UPDATE_SCX(LCOD)
Value Char    LCOD
Local Integer STAT
Local Char    WITM(GLONITM)
Local Integer WRET
#
# Issue 88677
Local Integer SAVGOK : SAVGOK=GOK
GOK=1 # Issue 88411 GA 03/2013

Raz [M:ORDK]
If [F:SCS]WIPNUM = ""
 # Issue 84787 avant STOFCY=[F:SCO]POHFCY
 # Recherche d'un ancien encours SCx dont on aurait perdu la référence
   For [ORD]ORD3 Where STOFCY=[F:SCS]PRHFCY
&                  and VCRTYP=36 and VCRNUM=[F:SCS]SCONUM
&                  and VCRLIN=[F:SCS]SCILIN and VCRSEQ=[F:SCS]SCSLIN
&                  and WIPTYP=4
     [F:SCS]WIPNUM = [F:ORD]WIPNUM : Break
   Next
   # Issue 103007 GA 09/2014 when [F]WIPNUM is lost
   If [F:SCS]WIPNUM<>"" Rewrite [F:SCS] : Endif
Else
   # Issue 88411 GA 03/2013 vider [F:SCI]WIPNUM si encours absent ?
   Read [ORD]ORD0=[F:SCS]WIPTYP;[F:SCS]WIPNUM;[F:SCS]SRVITMREF
   If fstat Raz [F:ORD] : Raz [F:SCS]WIPNUM : Endif
Endif
If [F:SCS]WIPNUM = "" & LCOD<>"A"
# pour affectation WIPNUM et rectification des opérations sur lesquelles il n'y a pas d'encours
   WCOD = "C"
Else
   WCOD = LCOD
Endif

[F:SCS]WIPTYP = 4             : # Encours de type SCx
[F:SCS]WIPSTA = [F:SCO]SCOSTA : # Statut de l'Encours de type SCx = Statut de l'ordre de sous-traitance

Case WCOD
    When "C":
               # création encours
               Call NUMERO(GWIP,[F:SCS]PRHFCY,[F:SCS]OPESTR,"",[F:SCS]WIPNUM,STAT) From SUBANM
               #--CPO  68322/59141
               #If STAT <> 0 : Call ERREUR("SCX"-mess(60,199,1)) From GESECRAN : End : Endif
               If GOK<1 | STAT<>0
                 Local Char MESSA(80)
                 Gosub MESSAGE From SUBANM
                 Call ERREUR("SCX"-mess(60,199,1)-"("+GWIP+") :"-MESSA) From GESECRAN : End
               Endif
               #--/CPO 68322/59141
               #
               [M:ORDK]MAJCOD     = "C"
               [M:ORDK]WIPTYP     = [F:SCS]WIPTYP
               [M:ORDK]WIPSTA     = [F:SCS]WIPSTA
               [M:ORDK]WIPNUM     = [F:SCS]WIPNUM
               [M:ORDK]ITMREF     = [F:SCS]SRVITMREF
               [M:ORDK]ORIFCY     = [F:SCO]POHFCY
               [M:ORDK]STOFCY     = [F:SCS]PRHFCY
               [M:ORDK]PJT        = [F:SCI]PJT
               [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
               [M:ORDK]STRDAT     = [F:SCS]OPESTR
               [M:ORDK]ENDDAT     = [F:SCS]OPEEND
               [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de MFGLIBO
               [M:ORDK]VCRNUM     = [F:SCS]SCONUM
               [M:ORDK]VCRLIN     = [F:SCS]SCILIN
               [M:ORDK]VCRSEQ     = [F:SCS]SCSLIN
               [M:ORDK]EXTQTY     = [F:SCS]EXTQTY      # FQ 77413 GA 11/2011 en OPESTU avant [F:SCS]EXTSTRQTY
               #[M:ORDK]CPLQTY     = [F:SCS]CPLQTY     # FQ 64064 GA 04/2010
               [M:ORDK]CPLQTY     = [F:SCS]ORDQTY    : # Total Qté commandée
               [M:ORDK]ALLQTY     = 0
               [M:ORDK]SHTQTY     = 0
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
              ### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
              ### [M:ORDK]VCRTYPORI  = 36
              ### [M:ORDK]VCRNUMORI  = [F:SCS]SCONUM
              ### [M:ORDK]VCRLINORI  = [F:SCS]SCILIN
              ### [M:ORDK]VCRSEQORI  = [F:SCS]SCSLIN
               [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
               [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
               [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
               [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
               [M:ORDK]ITMREFORI  = [F:SCS]ITMREF
               If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
                 #[M:ORDK]ECCVALMAJ  = [F:SCI]ECCVALMAJ # no version on [F:SCS]
                 #[M:ORDK]ECCVALMIN  = [F:SCI]ECCVALMIN
               Endif
               [M:ORDK]BOMALT     = [F:SCS]BOMALT
               [M:ORDK]BOMALTTYP  = 3
               [M:ORDK]PIO        = [F:SCI]PIO     : # GA 10/01/2006 PIO déplacée de SCS dans SCI
               [M:ORDK]ORI        = 1              : # ORI: 1=Achats, avant 4=Production extrait de MFGLIBO
               [M:ORDK]ABBFIL     = "SCS"
               Call WIP From TRTWIP
    When "M","U": # modification encours
               [M:ORDK]MAJCOD     = "M"
               [M:ORDK]WIPTYP     = [F:SCS]WIPTYP
               [M:ORDK]WIPSTA     = [F:SCS]WIPSTA
               [M:ORDK]WIPNUM     = [F:SCS]WIPNUM
               [M:ORDK]ITMREF     = [F:SCS]SRVITMREF
               [M:ORDK]ORIFCY     = [F:SCO]POHFCY
               [M:ORDK]STOFCY     = [F:SCS]PRHFCY
               [M:ORDK]PJT        = [F:SCI]PJT
               [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
               [M:ORDK]STRDAT     = [F:SCS]OPESTR
               [M:ORDK]ENDDAT     = [F:SCS]OPEEND
               [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de MFGLIBO
               [M:ORDK]VCRNUM     = [F:SCS]SCONUM
               [M:ORDK]VCRLIN     = [F:SCS]SCILIN
               [M:ORDK]VCRSEQ     = [F:SCS]SCSLIN
               [M:ORDK]EXTQTY     = [F:SCS]EXTQTY      # FQ 77413 GA 11/2011 en OPESTU avant [F:SCS]EXTSTRQTY
               #[M:ORDK]CPLQTY     = [F:SCS]CPLQTY     # FQ 64064 GA 04/2010
               [M:ORDK]CPLQTY     = [F:SCS]ORDQTY    : # Total Qté commandée
               [M:ORDK]ALLQTY     = 0
               [M:ORDK]SHTQTY     = 0
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
              ### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
              ### [M:ORDK]VCRTYPORI  = 36
              ### [M:ORDK]VCRNUMORI  = [F:SCS]SCONUM
              ### [M:ORDK]VCRLINORI  = [F:SCS]SCILIN
              ### [M:ORDK]VCRSEQORI  = [F:SCS]SCSLIN
               [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
               [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
               [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
               [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
               [M:ORDK]ITMREFORI  = [F:SCS]ITMREF
               If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
                 #[M:ORDK]ECCVALMAJ  = [F:SCI]ECCVALMAJ # no version on [F:SCS]
                 #[M:ORDK]ECCVALMIN  = [F:SCI]ECCVALMIN
               Endif
               [M:ORDK]BOMALT     = [F:SCS]BOMALT
               [M:ORDK]BOMALTTYP  = 3
               [M:ORDK]PIO        = [F:SCI]PIO     : # GA 10/01/2006 PIO déplacée de SCS dans SCI
               [M:ORDK]ORI        = 1              : # ORI: 1=Achats, avant 4=Production extrait de MFGLIBO
               [M:ORDK]ABBFIL     = "SCS"
               Call WIP From TRTWIP
    When "A": # suppression encours
               [M:ORDK]MAJCOD     = "A"
             # Supprimer l'encours SCX dont la référence n'est peut-être plus dans [F:SCS]WIPxxx
### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
###               For [ORD] Where WIPTYP=4     and ITMREF   =[F:SCS]SRVITMREF
###&                          and VCRTYPORI=36 and VCRNUMORI=[F:SCS]SCONUM and VCRLINORI=[F:SCS]SCILIN
               For [ORD] Where WIPTYP=4             and ITMREF=[F:SCS]SRVITMREF
&                          and VCRTYP=36            and VCRNUM=[F:SCS]SCONUM
&                          and VCRLIN=[F:SCS]SCILIN and VCRSEQ=[F:SCS]SCSLIN
                   [M:ORDK]WIPTYP     = [F:ORD]WIPTYP
                   [M:ORDK]WIPNUM     = [F:ORD]WIPNUM
                   [M:ORDK]ITMREF     = [F:ORD]ITMREF
                   Call WIP From TRTWIP
               Next
               Raz [F:SCS]WIPNUM,[F:SCS]WIPTYP,[F:SCS]WIPSTA
    When "P": # rien à faire ...
Endcase
#
If GOK=0
   GMESSAGE="UPDATE_SCX: Erreur de mise à jour de l'encours "-num$([M:ORDK]WIPTYP)-" No="-[M:ORDK]WIPNUM
   mkstat=1
Endif
$UPDATE_SCX_FIN  # Issue 88677
If GOK=1 GOK=SAVGOK Endif
End



##################################################################
# Routine de mise à jour de l'encours matières
# [F:SCO],[F:SCI],[F:SCM] doivent être chargé avant l'appel
# LCOD = C,    Création MFx
# LCOD = M,    Modification MFx
# LCOD = A,    Suppression MFx
# LALL = 1     avec mise à jour allocation
# GA selon UPDATE_MFX dans MFGLIBM
##################################################################
Subprog UPDATE_MSX(LCOD, LALL)
Value Char    LCOD
Value Integer LALL : # Méthode d'alloc automatique 2 si globale ou 3 si détaillée
Local Integer STAT
Local Char    WCOD(1)
Local Integer WALL

Raz [M:ORDK]

# Issue 88677
Local Integer ALLGOK, SAVGOK : SAVGOK=GOK
GOK=1 : ALLGOK=1

# si l'EO n'est pas en statut 1=Ferme, pas d'allocation
If [F:SCO]SCOSTA <> 1 : WALL=0 : Else WALL=LALL : Endif

# si la matière n'est pas allouée et pas d'alloc auto (LALL<2), UPDATE_ALL ne fait rien
# voir SUBMFG2
If [F:SCM]ALLSTA<2 & WALL<2 : WALL=0 : Endif

WCOD = LCOD
# pas de MSX et pas d'allocations dans les cas suivants:
# - si matière exclue,
# - si matière non fournie au sous-traitant,
# - si composant <> Normal (texte, ...),
If [F:SCM]MATSTA > 2 | [F:SCM]SCOFLG<>2 | [F:SCM]CPNTYP<>1
 # on force la rectif des alloc s'il y en avait, quel que soit le statut de l'EO
   WCOD = "A" : WALL = 1
Elsif [F:SCM]WIPNUM="" & LCOD="M"   # Issue 105891 GA 02/2015 pb on import PEO
 # Issue 84787 avant STOFCY=[F:SCO]POHFCY
 # Recherche d'un ancien encours SCx dont on aurait perdu la référence
   For [ORD]ORD3 Where STOFCY=[F:SCM]STOFCY
&                  and VCRTYP=36 and VCRNUM=[F:SCM]SCONUM
&                  and VCRLIN=[F:SCM]SCILIN and VCRSEQ=[F:SCM]SCMLIN
&                  and WIPTYP=4
     [F:SCM]WIPNUM = [F:ORD]WIPNUM : Break
   Next
   # Issue 103007 GA 09/2014 when [F]WIPNUM is lost
   If [F:SCM]WIPNUM<>"" Rewrite [F:SCM] : Endif
Endif
If [F:SCM]WIPNUM = "" & WCOD<>"A"
# pour affectation WIPNUM et rectification des matières sur lesquelles il n'y a pas d'encours
   WCOD = "C"
Endif

[F:SCM]WIPTYP = 3             : # Encours de type 3=MS Matière sous-traitance
[F:SCM]WIPSTA = [F:SCO]SCOSTA : # Statut de l'Encours de type MSx = Statut de l'ordre de sous-traitance

Case WCOD
    When "M", "U" : # modification
     #  Maj si modification ligne
        # modification allocation

# Issue 85550 - 2012-11-02 by CCC : si un changement d'emplacement ou de site a eu lieu, il faut supprimer les alloc avant de les recréer
        If clalev([F:SCM2])=0 : Local File SCOMAT [SCM2] : Endif
        Read [SCM2]SCM0=[F:SCM]SCONUM;[F:SCM]SCILIN;[F:SCM]SCMLIN
        If [F:SCM]ALLSTA>3 & ( [F:SCM]LOC<>[F:SCM2]LOC | [F:SCM]STOFCY<>[F:SCM2]STOFCY)
&        | [F:SCM]ALLSTA>1 & [F:SCM]STOFCY<>[F:SCM2]STOFCY
            Call UPDATE_ALL("A") From SCOALL
        Else
            WALL=LALL # Issue 90321 GA 07/2013 Avant 1=Pas d'alloc auto
        Endif

        Case WALL
             When 1: Call UPDATE_ALL("M") From SCOALL : # Allocation manuelle
             When 2: Call UPDATE_ALL("G") From SCOALL : # Allocation automatique globale
             When 3: Call UPDATE_ALL("D") From SCOALL : # Allocation automatique détaillée
        Endcase
        If GOK<1 : ALLGOK=GOK : GOK=1 :Endif # Issue 88677

       # modification encours
        [M:ORDK]MAJCOD     = "M"
        [M:ORDK]WIPTYP     = [F:SCM]WIPTYP
        [M:ORDK]WIPSTA     = [F:SCM]WIPSTA
        [M:ORDK]WIPNUM     = [F:SCM]WIPNUM
        [M:ORDK]ITMREF     = [F:SCM]CPNITMREF
        [M:ORDK]ORIFCY     = [F:SCO]POHFCY
        [M:ORDK]STOFCY     = [F:SCM]STOFCY
        [M:ORDK]PJT        = [F:SCI]PJT
        [M:ORDK]PIO        = [F:SCM]PIO
        [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
        [M:ORDK]STRDAT     = [F:SCM]DLVDAT
        [M:ORDK]ENDDAT     = [F:SCM]DLVDAT      # FQ 77115 GA 12/2011 avant [F:SCO]RETDAT
        [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de MFGLIBM
        [M:ORDK]VCRNUM     = [F:SCM]SCONUM
        [M:ORDK]VCRLIN     = [F:SCM]SCILIN
        [M:ORDK]VCRSEQ     = [F:SCM]SCMLIN
        [M:ORDK]EXTQTY     = [F:SCM]RETQTY
        [M:ORDK]CPLQTY     = [F:SCM]USEQTY
        [M:ORDK]ALLQTY     = [F:SCM]ALLQTY
        [M:ORDK]SHTQTY     = [F:SCM]SHTQTY
        [M:ORDK]FMI        = 1                : #GA 1=Stock (Menu Local 445)
        [M:ORDK]MRPMES     = 1
        [M:ORDK]MRPQTY     = 0
        [M:ORDK]MRPDAT     = [0/0/0]
       ### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
       ### [M:ORDK]VCRTYPORI  = 36
       ### [M:ORDK]VCRNUMORI  = [F:SCM]SCONUM
       ### [M:ORDK]VCRLINORI  = [F:SCM]SCILIN
       ### [M:ORDK]VCRSEQORI  = [F:SCM]SCMLIN
        [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
        [M:ORDK]ITMREFORI  = [F:SCM]ITMREF    : #GA On enregistre ici l'article sous-traité
        If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
           [M:ORDK]ECCVALMAJ  = [F:SCM]ECCVALMAJ
           [M:ORDK]ECCVALMIN  = [F:SCM]ECCVALMIN
        Endif
        [M:ORDK]BOMALT     = [F:SCM]BOMALT
        [M:ORDK]BOMALTTYP  = 3
        [M:ORDK]ORI        = 1                : # ORI: 1=Achats, avant 4=Production extrait de MFGLIBM
        [M:ORDK]ABBFIL     = "SCM"
        Call WIP From TRTWIP

    When "C" :  #  Maj si création ou suppression ligne
        Case WALL
             When 1: Call UPDATE_ALL("C")  From SCOALL : # cas impossible ????
             When 2: Call UPDATE_ALL("G")  From SCOALL
             When 3: Call UPDATE_ALL("D")  From SCOALL
        Endcase
        If GOK<1 : ALLGOK=GOK : GOK=1 :Endif # Issue 88677

       # création encours
        Call NUMERO(GWIP,[F:SCM]STOFCY,[F:SCM]DLVDAT,"",[F:SCM]WIPNUM,STAT) From SUBANM
        #--CPO  68322/59141
        #If STAT <> 0 : Call ERREUR("WIP"-mess(60,199,1)) From GESECRAN : Endif
        If GOK<1 | STAT<>0
          Local Char MESSA(80)
          Gosub MESSAGE From SUBANM
          Call ERREUR("MSX"-mess(60,199,1)-"("+GWIP+") :"-MESSA) From GESECRAN : End
        Endif
        #--/CPO 68322/59141
      #
        [M:ORDK]MAJCOD     = "C"
        [M:ORDK]WIPTYP     = [F:SCM]WIPTYP
        [M:ORDK]WIPSTA     = [F:SCM]WIPSTA
        [M:ORDK]WIPNUM     = [F:SCM]WIPNUM
        [M:ORDK]ITMREF     = [F:SCM]CPNITMREF
        [M:ORDK]ORIFCY     = [F:SCO]POHFCY
        [M:ORDK]STOFCY     = [F:SCM]STOFCY
        [M:ORDK]PJT        = [F:SCI]PJT
        [M:ORDK]PIO        = [F:SCM]PIO
        [M:ORDK]BPRNUM     = [F:SCO]BPRNUM
        [M:ORDK]STRDAT     = [F:SCM]DLVDAT
        [M:ORDK]ENDDAT     = [F:SCM]DLVDAT      # FQ 77115 GA 12/2011 avant [F:SCO]RETDAT
        [M:ORDK]VCRTYP     = 36               : # 36=Ordre sous-traitance, avant 10=OF extrait de MFGLIBM
        [M:ORDK]VCRNUM     = [F:SCM]SCONUM
        [M:ORDK]VCRLIN     = [F:SCM]SCILIN
        [M:ORDK]VCRSEQ     = [F:SCM]SCMLIN
        [M:ORDK]EXTQTY     = [F:SCM]RETQTY
        [M:ORDK]CPLQTY     = [F:SCM]USEQTY
        [M:ORDK]ALLQTY     = [F:SCM]ALLQTY
        [M:ORDK]SHTQTY     = [F:SCM]SHTQTY
        [M:ORDK]FMI        = 1                : #GA 1=Stock (Menu Local 445)
        [M:ORDK]MRPMES     = 1
       ### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
       ### [M:ORDK]VCRTYPORI  = 36
       ### [M:ORDK]VCRNUMORI  = [F:SCM]SCONUM
       ### [M:ORDK]VCRLINORI  = [F:SCM]SCILIN
       ### [M:ORDK]VCRSEQORI  = [F:SCM]SCMLIN
        [M:ORDK]VCRTYPORI  = [F:SCI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:SCI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:SCI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:SCI]VCRSEQORI
        [M:ORDK]ITMREFORI  = [F:SCI]ITMREF    : #GA On enregistre ici l'article sous-traité
        If dim([M:ORDK]ECCVALMAJ)>0  # Issue 107513/US2 GA 04/2015
         [M:ORDK]ECCVALMAJ  = [F:SCM]ECCVALMAJ
         [M:ORDK]ECCVALMIN  = [F:SCM]ECCVALMIN
        Endif
        [M:ORDK]BOMALT     = [F:SCI]BOMALT
        [M:ORDK]BOMALTTYP  = 3
        [M:ORDK]ORI        = 1                : # ORI: 1=Achats, avant 4=Production extrait de MFGLIBM
        [M:ORDK]ABBFIL     = "SCM"
        Call WIP From TRTWIP
    When "A" : # suppression allocation
        Call UPDATE_ALL("A") From SCOALL
        If [F:SCM]WIPNUM<>""
          # suppression encours
           [M:ORDK]MAJCOD     = "A"
           [M:ORDK]WIPTYP     = [F:SCM]WIPTYP
           [M:ORDK]WIPNUM     = [F:SCM]WIPNUM
           [M:ORDK]ITMREF     = [F:SCM]CPNITMREF
           Call WIP From TRTWIP
         # Après suppression du WIP, on raz la référence
           Raz [F:SCM]WIPNUM,[F:SCM]WIPTYP,[F:SCM]WIPSTA
         Else
           [M:ORDK]MAJCOD     = "A"
          # Supprimer l'encours MSX dont la référence n'est peut-être plus dans [F:SCM]WIPxxx
### FQ 78916 GA 01/2012 idem UPDATE_EOX pour recréer les en-cours
             For [ORD] Where WIPTYP=3             and ITMREF=[F:SCM]CPNITMREF
&                        and VCRTYP=36            and VCRNUM=[F:SCM]SCONUM
&                        and VCRLIN=[F:SCM]SCILIN and VCRSEQ=[F:SCM]SCMLIN
                 [M:ORDK]WIPTYP     = [F:ORD]WIPTYP
                 [M:ORDK]WIPNUM     = [F:ORD]WIPNUM
                 [M:ORDK]ITMREF     = [F:ORD]ITMREF
                 Call WIP From TRTWIP
             Next
             Raz [F:SCM]WIPNUM,[F:SCM]WIPTYP,[F:SCM]WIPSTA
           Endif
Endcase
# Issue 87038 GA 01/2013 performances
#If clalev([M:SCO2])<>0 : # ssi on est dans la fenêtre OSCO
#   [M:SCO2]WIPNUM(nolign-1) = [F:SCM]WIPNUM : Affzo [M:SCO2]WIPNUM(nolign-1)
#   [M:SCO2]WIPTYP(nolign-1) = [F:SCM]WIPTYP : Affzo [M:SCO2]WIPTYP(nolign-1)
#   [M:SCO2]WIPSTA(nolign-1) = [F:SCM]WIPSTA : Affzo [M:SCO2]WIPSTA(nolign-1)
#Endif
If GOK=0
   GMESSAGE="UPDATE_MSX: Erreur de mise à jour de l'encours "-num$([M:ORDK]WIPTYP)-" No="-[M:ORDK]WIPNUM
   mkstat=1
Endif
If ALLGOK<1 & WCOD<>"A"
   # ne pas renvoyer d'erreur sur les matières fournies par le sous-traitant
   # pour lesquelles on a juste supprimé les allocs/encours éventuels
   GMESSAGE="UPDATE_MSX: Erreur de mise à jour des allocations "-num$(ALLGOK)-[F:SCM]CPNITMREF-" No="-num$([F:SCM]BOMSEQ)
   #Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Endif
$UPDATE_MSX_FIN  # Issue 88677
If GOK=1 GOK=SAVGOK Endif
End

#######################################################################

# ----------------------------------------#
# Dans la table SCO SCOHEAD               #
# ----------------------------------------#
$SCO_SCOSTA_CLO
  If clalev([M:SCO1])>0
     #[M:SCO1]SCOSTA   = 4 : # Menu 317: ordre de sous-traitance => "4=Clos"
     [M:SCO1]SCOTRKFLG = 5 : # Menu 339: Situation ordre         => "5=Soldé"
  Endif
  If clalev([F:SCO])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     #[F:SCO]SCOSTA    = 4 : # Menu 317: ordre de sous-traitance => "4=Clos"
     [F:SCO]SCOTRKFLG  = 5 : # Menu 339: Situation ordre         => "5=Soldé"
  Endif
Return

$SCO_SCOSTA_INI
  If clalev([M:SCO1])>0
     [M:SCO1]SCOSTA    = 1 : # Menu 317: ordre de sous-traitance => "1=Ferme"
     [M:SCO1]SCOTRKFLG = 1 : # Menu 339: Situation ordre         => "1=En attente"
  Endif
  If clalev([F:SCO])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCO]SCOSTA     = 1 : # Menu 317: ordre de sous-traitance => "1=Ferme"
     [F:SCO]SCOTRKFLG  = 1 : # Menu 339: Situation ordre         => "1=En attente"
  Endif
Return

$SCO_SCOSTA_DEF
  If clalev([M:SCO1])>0
     [M:SCO1]SCOSTA    = 2 : # Menu 317: ordre de sous-traitance => "2=Planifié"
     [M:SCO1]SCOTRKFLG = 1 : # Menu 339: Situation ordre         => "1=En attente"
  Endif
  If clalev([F:SCO])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCO]SCOSTA     = 2 : # Menu 317: ordre de sous-traitance => "2=Planifié"
     [F:SCO]SCOTRKFLG  = 1 : # Menu 339: Situation ordre         => "1=En attente"
  Endif
Return

# ----------------------------------------#
# Dans la table SCI SCOITM                #
# ----------------------------------------#
$CTRL_ITMSTA
    If [F:SCI]CPLQTY-[F:SCI]REJCPLQTY >= [F:SCI]EXTQTY | [F:SCI]ITMSTA = 5
      Gosub SCI_ITMSTA_CLO
    Elsif [F:SCI]CPLQTY > 0
      Gosub SCI_ITMSTA_RCP
    Elsif [F:SCI]POHNUM<>"" | [F:SCI]ORDQTY>0
      Gosub SCI_ITMSTA_PUR
    Else
      Gosub SCI_ITMSTA_DEF
    Endif
Return

$SCI_ITMSTA_PUR
  If clalev([M:SCO1])>0
     [M:SCO1]ITMSTA    = 3 : # Menu local 2221: statut => "Commandé"
     [M:SCO1]SCITRKFLG = 4 : # Menu local 2238: Situation => "4=En cours"
  Endif
  If clalev([F:SCI])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCI]ITMSTA    = 3 : # Menu local 2221: statut => "Commandé"
     [F:SCI]SCITRKFLG = 4 : # Menu local 2238: Situation => "4=En cours"
  Endif
Return

$SCI_ITMSTA_RCP
  If clalev([M:SCO1])>0
     [M:SCO1]ITMSTA    = 4 : # Menu local 2221: statut => "Réceptionné"
     [M:SCO1]SCITRKFLG = 4 : # Menu local 2238: Situation => "4=En cours"
     [M:SCO1]RMNEXTQTY = [M:SCO1]EXTQTY-[M:SCO1]CPLQTY
     If [M:SCO1]RMNEXTQTY<0 [M:SCO1]RMNEXTQTY=0 Endif
  Endif
  If clalev([F:SCI])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCI]ITMSTA    = 4 : # Menu local 2221: statut => "Réceptionné"
     [F:SCI]SCITRKFLG = 4 : # Menu local 2238: Situation => "4=En cours"
     [F:SCI]RMNEXTQTY = [F:SCI]EXTQTY-[F:SCI]CPLQTY
     If [F:SCI]RMNEXTQTY<0 [F:SCI]RMNEXTQTY=0 Endif
  Endif
Return

$SCI_ITMSTA_CLO
  If clalev([M:SCO1])>0
     [M:SCO1]ITMSTA    = 5    : # Menu local 2221: statut => "Soldé"
     If [M:SCO1]SCITRKFLG < 5   # sauf si SCxTRKFLG à 6=Prix de revient calculé
        [M:SCO1]SCITRKFLG = 5 : # Menu local 2238: Situation => "5=Soldé"
     Endif
     [M:SCO1]RMNEXTQTY = 0
  Endif
  If clalev([F:SCI])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCI]ITMSTA    = 5    : # Menu local 2221: statut => "Soldé"
     If [F:SCI]SCITRKFLG < 5   # sauf si SCxTRKFLG à 6=Prix de revient calculé
        [F:SCI]SCITRKFLG = 5 : # Menu local 2238: Situation => "5=Soldé"
     Endif
     [F:SCI]RMNEXTQTY = 0
  Endif
Return

$SCI_ITMTRKFLG_CAL
  # Mise a jour faite par Update dans FUNWIPMFC
Return

$SCI_ITMSTA_INI
  If clalev([M:SCO1])>0
     [M:SCO1]ITMSTA    = 2 : # Menu local 2221: statut => "2=En cours"
     [M:SCO1]SCITRKFLG = 1 : # Menu local 2238: Situation => "1=En attente"
  Endif
  If clalev([F:SCI])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCI]ITMSTA    = 2 : # Menu local 2221: statut => "2=En cours"
     [F:SCI]SCITRKFLG = 1 : # Menu local 2238: Situation => "1=En attente"
  Endif
Return

$SCI_ITMSTA_DEF
  If clalev([M:SCO1])>0
     [M:SCO1]ITMSTA    = 1 : # Menu local 2221: statut => "1=En attente"
     [M:SCO1]SCITRKFLG = 1 : # Menu local 2238: Situation => "1=En attente"
  Endif
  If clalev([F:SCI])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCI]ITMSTA    = 1 : # Menu local 2221: statut => "1=En attente"
     [F:SCI]SCITRKFLG = 1 : # Menu local 2238: Situation => "1=En attente"
  Endif
Return



# ----------------------------------------#
# Dans la table SCM SCOMAT                #
# ----------------------------------------#
$CTRL_MATSTA
    If [F:SCM]USEQTY >= [F:SCM]RETQTY | [F:SCM]MATSTA    = 3
      #If [F:SCM]SCOFLG = 3   # FQ 53925 Matière soldée
      #   Gosub SCM_MATSTA_RCP
      #Else
         Gosub SCM_MATSTA_CLO
      #Endif
    Elsif [F:SCM]SCOFLG=3 & [F:SCM]POHNUM<>""
      If [F:SCM]USEQTY>0      # FQ 53925 Réception partielle
         Gosub SCM_MATSTA_RCP
      Else
         Gosub SCM_MATSTA_PUR
      Endif
    Elsif [F:SCM]USEQTY > 0 | [F:SCM]DLVQTY > 0 | [F:SCM]ALLQTY>0
      Gosub SCM_MATSTA_INI
    Else
      Gosub SCM_MATSTA_DEF
    Endif
Return

$SCM_MATSTA_CLO
  If clalev([M:SCO2])>0 & dim(NOL)>0 & NOL>-1
     [M:SCO2]MATSTA   (NOL)= 3    : # Menu local 2223 : statut => "Soldé"
     If [M:SCO2]SCMTRKFLG(NOL)<5    # sauf si SCMTRKFLG à 6=Prix de revient calculé
        [M:SCO2]SCMTRKFLG(NOL)= 5 : # Menu local 2238 : Situation => "Soldée"
     Endif
  Endif
  If clalev([F:SCM])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCM]MATSTA    = 3    : # Menu local 2223 : statut => "Soldé"
     If [F:SCM]SCMTRKFLG < 5   # sauf si SCMTRKFLG à 6=Prix de revient calculé
        [F:SCM]SCMTRKFLG = 5 : # Menu local 2238 : Situation => "Soldée"
     Endif
  Endif
Return

$SCM_MATTRKFLG_CAL
  # Mise a jour faite par Update dans FUNWIPMFC
Return

$SCM_MATSTA_PUR
  If clalev([M:SCO2])>0 & dim(NOL)>0 & NOL>-1
     [M:SCO2]MATSTA   (NOL)= 5 : # Menu local 2223 : statut => "Commandé"
     [M:SCO2]SCMTRKFLG(NOL)= 4 : # Menu local 2238 : Situation => "En cours"
  Endif
  If clalev([F:SCM])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCM]MATSTA    = 5 : # Menu local 2223 : statut => "Commandé"
     [F:SCM]SCMTRKFLG = 4 : # Menu local 2238 : Situation => "En cours"
  Endif
Return

$SCM_MATSTA_RCP
  If clalev([M:SCO2])>0 & dim(NOL)>0 & NOL>-1
     [M:SCO2]MATSTA(NOL)   = 6 : # Menu local 2223 : statut => "Réceptionnée"
     [M:SCO2]SCMTRKFLG(NOL)= 4 : # Menu local 2238 : Situation => "En cours"
  Endif
  If clalev([F:SCM])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCM]MATSTA    = 6 : # Menu local 2223: statut => "Réceptionnée"
     [F:SCM]SCMTRKFLG = 4 : # Menu local 2238 : Situation => "En cours"
  Endif
Return

$SCM_MATSTA_INI
  If clalev([M:SCO2])>0 & dim(NOL)>0 & NOL>-1
     [M:SCO2]MATSTA   (NOL)= 2 : # Menu local 2223 : statut => "En cours"
     [M:SCO2]SCMTRKFLG(NOL)= 4 : # Menu local 2238 : Situation => "En cours"
  Endif
  If clalev([F:SCM])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCM]MATSTA    = 2 : # Menu local 2223 : statut => "En cours"
     [F:SCM]SCMTRKFLG = 4 : # Menu local 2238 : Situation => "En cours"
  Endif
Return

$SCM_MATSTA_DEF
  If clalev([M:SCO2])>0 & dim(NOL)>0 & NOL>-1
     [M:SCO2]MATSTA   (NOL)= 1 : # Menu local 2223 : statut => "En attente"
     [M:SCO2]SCMTRKFLG(NOL)= 1 : # Menu local 2238 : Situation => "En attente"
  Endif
  If clalev([F:SCM])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCM]MATSTA    = 1 : # Menu local 2223 : statut => "En attente"
     [F:SCM]SCMTRKFLG = 1 : # Menu local 2238 : Situation => "En attente"
  Endif
Return



# ----------------------------------------#
# Dans la table SCS SCOSRV                #
# ----------------------------------------#
$CTRL_OPESTA
    If [F:SCS]CPLQTY-[F:SCS]REJCPLQTY >= [F:SCS]EXTQTY | [F:SCS]OPESTA = 3
      Gosub SCS_OPESTA_CLO
    Elsif [F:SCS]CPLQTY > 0
      Gosub SCS_OPESTA_RCP
    Elsif [F:SCS]POHNUM<>""
      Gosub SCS_OPESTA_PUR
    Else
      Gosub SCS_OPESTA_INI
    Endif
Return

$SCS_OPESTA_PUR
  If clalev([M:SCO3])>0
     [M:SCO3]OPESTA    = 4 : # Menu 2239: statut => "Commandé"
     [M:SCO3]SCSTRKFLG = 4 : # Menu 2238: Situation Service => "En cours"
  Endif
  If clalev([F:SCS])>0
     [F:SCS]OPESTA    = 4 : # Menu 2239: statut => "Commandé"
     [F:SCS]SCSTRKFLG = 4 : # Menu 2238: Situation Service => "En cours"
  Endif
Return

$SCS_OPESTA_RCP
  If clalev([M:SCO3])>0
     [M:SCO3]OPESTA    = 5 : # Menu 2239: statut => "Réceptionné"
     [M:SCO3]SCSTRKFLG = 4 : # Menu 2238: Situation => "En cours"
     [M:SCO3]RMNEXTQTY = [M:SCO3]EXTQTY-[M:SCO3]CPLQTY
     If [M:SCO3]RMNEXTQTY<0 [M:SCO3]RMNEXTQTY=0 Endif
  Endif
  If clalev([F:SCS])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCS]OPESTA    = 5 : # Menu 2239: statut => "Réceptionné"
     [F:SCS]SCSTRKFLG = 4 : # Menu 2238: Situation => "En cours"
     [F:SCS]RMNEXTQTY = [F:SCS]EXTQTY-[F:SCS]CPLQTY
     If [F:SCS]RMNEXTQTY<0 [F:SCS]RMNEXTQTY=0 Endif
  Endif
Return

$SCS_OPESTA_INI
  If clalev([M:SCO3])>0
     [M:SCO3]OPESTA    = 1 # Menu 2239: statut => "En attente"
     [M:SCO3]SCSTRKFLG = 1 # Menu 2238: Situation => "1=En attente"
  Endif
  If clalev([F:SCS])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCS]OPESTA    = 1 : # Menu 2239: statut => "En attente"
     [F:SCS]SCSTRKFLG = 1 : # Menu 2238: Situation => "1=En attente"
  Endif
Return

$SCS_OPESTA_CLO
  If clalev([M:SCO3])>0
     [M:SCO3]OPESTA    = 3    : # Menu 2239: statut => "Soldé"
     If [M:SCO3]SCSTRKFLG < 5   # sauf si SCxTRKFLG à 6=Prix de revient calculé
        [M:SCO3]SCSTRKFLG = 5 : # Menu 2238: Situation => "Soldé"
     Endif
     [M:SCO3]RMNEXTQTY = 0
  Endif
  If clalev([F:SCS])>0 # FQ 57911 GA 09/2009 remplact du else pour SCOSBCLIB
     [F:SCS]OPESTA    = 3    : # Menu 2239: statut => "Soldé"
     If [F:SCS]SCSTRKFLG < 5   # sauf si SCxTRKFLG à 6=Prix de revient calculé
        [F:SCS]SCSTRKFLG = 5 : # Menu 2238: Situation => "Soldé"
     Endif
     [F:SCS]RMNEXTQTY = 0
  Endif
Return

$SCS_OPETRKFLG_CAL
  # Mise a jour faite par Update dans FUNWIPMFC
Return




#######################################################################

#-----------------------------------------------------------------------#
# Mise à jour de l'entete Ordre de sous-traitance                       #
#-----------------------------------------------------------------------#
$MAJSCOHEAD
  Gosub OPEN_FILES_SCO

# ------------------------------------------------------
# on recompte les matières et allocations
# ------------------------------------------------------
  [F:SCO]MATCLENBR = 0
  [F:SCO]MATLINNBR = 0
  [F:SCO]OVRALLNBR = 0
  [F:SCO]DETALLNBR = 0
  [F:SCO]SHTMATNBR = 0
# parcours des Matières de l'ordre de sous-traitance
  For [SCM]SCM0 Where SCONUM=[F:SCO]SCONUM

  # on compte les matières à envoyer au sous-traitant qui ne sont pas exclues
  # Issue 98109 GA 04/2014 ne pas compter les matières dont le besoin est qté nulle
    If [F:SCM]SCOFLG = 2 & [F:SCM]MATSTA <> 4 & [F:SCM]RETQTY<>0
       [F:SCO]MATLINNBR+=1
       If [F:SCM]MATSTA = 3       : # Menu local 2223 : statut => "Soldé"
        # on compte les matières soldées
          [F:SCO]MATCLENBR+=1
       Endif
       If find([F:SCM]ALLSTA,2,3) : # Menu local 340
       # Allocation globale
         [F:SCO]OVRALLNBR += 1
       Endif
       If find([F:SCM]ALLSTA,4,5) : # Menu local 340
       # Allocation détaillée
         [F:SCO]DETALLNBR += 1
       Endif
       If [F:SCM]SHTQTY<>0
       # Rupture
         [F:SCO]SHTMATNBR += 1
       Endif

    Endif
  Next
#
  # qté productible selon SHTQTY
  If dim(GAVASCO) <= 0 : Global Decimal GAVASCO : Endif
  GAVASCO = 9999999999
  Call  MAJ_AVASCOQTY("SCM") From SCOLIBM

  Gosub MAJSTATUT

# ----------------------------------------------------------
# on compte les opérations (une seule pour le moment :-) )
# ----------------------------------------------------------
  [F:SCO]OPECLENBR = 0
  [F:SCO]OPELINNBR = 0
  For [SCS]SCS0 Where SCONUM=[F:SCO]SCONUM

       [F:SCO]OPELINNBR+=1
       If [F:SCS]OPESTA = 3   : # Menu 2239: statut => "Soldé"
        # on compte les opérations soldées
          [F:SCO]OPECLENBR+=1
       Endif
  Next

# ------------------------------------------------------
# on compte les articles (un seul pour le moment :-) )
# ------------------------------------------------------
  [F:SCO]ITMCLENBR = 0
  [F:SCO]ITMLINNBR = 0
  For [SCI]SCI0 Where SCONUM=[F:SCO]SCONUM
       [F:SCO]ITMLINNBR+=1
       If [F:SCI]ITMSTA = 5   :# Menu local 2221
        # on compte les articles soldés
          [F:SCO]ITMCLENBR+=1
       Endif
  Next

# FQ 53925 si tout est soldé, SCOTRKFLG passe aussi à soldé
  If [F:SCO]OPECLENBR = [F:SCO]OPELINNBR &
&    [F:SCO]ITMCLENBR = [F:SCO]ITMLINNBR &
&    [F:SCO]MATCLENBR = [F:SCO]MATLINNBR
     If [F:SCO]SCOTRKFLG < 6 # sauf si Prix de revient calculé
        [F:SCO]SCOTRKFLG = 5
     Endif
# 54539 attention on passe ici aussi en création, d'ou la disparition du else ... = 4
  Endif

#Maj de l'écran si nécessaire
  If clalev([M:SCO1])<> 0
     [M:SCO1] = [F:SCO]
     # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
     Affzo [M:SCO1]1-99
  Endif
  If clalev([M:SCO0])<> 0
     [M:SCO0] = [F:SCO]
     # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
     Affzo [M:SCO0]1-99
  Endif
  If clalev([M:SCA1])<> 0
     [M:SCA1] = [F:SCO]
     # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
     Affzo [M:SCA1]1-99
  Endif


Return


#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
 Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:SCO]OVRALLNBR + [F:SCO]DETALLNBR
If (XTOT = 0)
    [F:SCO]ALLSTA = 1
Else
    If (XTOT < [F:SCO]MATLINNBR - [F:SCO]MATCLENBR)
        [F:SCO]ALLSTA = 2
    Else
        [F:SCO]ALLSTA = 3
    Endif
Endif
# si des ruptures existent, statut allocation += 2
If [F:SCO]SHTMATNBR <> 0 : [F:SCO]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:SCO]MATCLENBR = [F:SCO]MATLINNBR & [F:SCO]MATLINNBR>0
   [F:SCO]ALLSTA = 3
Endif
Return

#-------------------------------------------------------------------------------#
# Ajustement du délai de l'ordre de sous-traitance                              #
#-------------------------------------------------------------------------------#
# La  classe  [ITF] de l'article lancé doit être chargée avant l'appel          #
# Les classes [SCO],[SCI],[SCS] ou écrans [M:SCO3],[M:SCO2] doivent être ok     #
#-------------------------------------------------------------------------------#
Subprog CALCUL_DELAI(WEXTQTY, WSCOLTI, WQUALTI)
Value    Decimal     WEXTQTY
Variable Decimal     WSCOLTI
Variable Decimal     WQUALTI

Local    Integer    WLTI
Local    Decimal    XLTI
Local    Integer    ILTI
Local    Decimal    WRMD

### FQ 77115 GA 12/2011 délai du service uniquement
# estimation du délai réalisation article sous-traité
# délai service  : temps de réalisation de l'opération de sous-traitance
# délai composant: BOMOFS uniquement pour positionner la date de besoin par rapport début du service
# -------------------------------------------------------------------------------------
XLTI    = [F:ITF]OFS
If clalev([M:SCO3])>0 & clalev([M:SCO2])>0
 ###  # ce délai tient compte des autres délais max (composants, service)
 ###  XLTI = max([F:ITF]OFS,max([M:SCO3]SCOLTI,max([M:SCO2]BOMOFS(0..[M:SCO2]NBLIG-1))))
 XLTI = [M:SCO3]SCOLTI
Elsif [F:SCO]SCONUM<>""
 # ce délai tient compte des autres délais max (composants, service)
 # NB: composants exclus ou fournis par le sous-traitant BOMOFS=0
  ###   XLTI = max([F:ITF]OFS,[F:SCS]SCOLTI)
  ###   For [F:SCM]SCM0 Where SCONUM=[F:SCO]SCONUM & SCOFLG=2 & BOMOFS>0
  ###       If [F:SCM]BOMOFS > XLTI
  ###          XLTI = [F:SCM]BOMOFS
  ###       Endif
  ###   Next
  XLTI = [F:SCS]SCOLTI
Endif

ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD > 0 : ILTI += 1 : Endif
WSCOLTI = ILTI

# délai qualité
XLTI    = [F:ITF]QUALTI
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD > 0 : ILTI += 1 : Endif
WQUALTI = ILTI

# Issue 100424 GA 07/2014 special for workbench
If WSCOLTI=0 & dim([F:ORD1]ITMREF)>0 & [F:ORD1]ITMREF=[F:ITF]ITMREF
   Local    Char       WSRVITMREF(GLONITM) # Issue 100424 GA 07/2014
   Call FIND_SCI_LTI([F:ORD1]ITMREF,[F:BPR]BPRNUM,[F:ITF]STOFCY,[F:ORD1]BOMALT,WSRVITMREF,WSCOLTI) From SCOLIB
Endif

#
End


###########################################################################
# RECH_COEFF : Coeff de conversion (selon PCAL_QTY de TRTACHQTE1)         #
#            Recherche sur article-fournisseur et article ainsi que       #
#            la table des coefficients de conversion                      #
# ----------------------------------------------------------------------- #
# Subprog RECH_COEFF (WITMREF,WBPRNUM,WUOM1,WUOM2,WCOEUOM)                #
#   WITMREF : Référence article                                           #
#   WBPRNUM : Numéro du fournisseur                                       #
#   WUOM1   : Unité 1                                                     #
#   WUOM2   : Unité 2                                                     #
#   WCOEUOM : Coefficient de conversion calculé                           #
#                                                                         #
# En sortie : coefficient de conversion WCOEUOM                           #
###########################################################################
Subprog RECH_COEFF (WITMREF,WBPRNUM,WUOM1,WUOM2,WCOEUOM)
Value    Char    WITMREF
Value    Char    WBPRNUM
Value    Char    WUOM1
Value    Char    WUOM2
Variable Decimal WCOEUOM
#-----
If clalev([F:TCO]) = 0 Local File TABCOEFF [TCO] : Endif

Raz [F:TCO] : [F:TCO]UOM1=WUOM1
WCOEUOM=1
If WUOM1=WUOM2  End : Endif

#----- Lecture [F:ITM] selon WITMREF
Gosub READ_ITM From ITMLIB
If [F:ITM]ITMREF<>WITMREF : Gosub RECH_TCO : End : Endif

##----- Lecture [F:ITP] selon WITMREF et WBPRNUM
Gosub READ_ITP From ITMLIB

# FQ 77413 GA 10/2011 prendre en priorité le coef sur [ITM] au lieu de table de conversion
#If [F:ITP]ITMREF<>WITMREF : Gosub RECH_TCO : End : Endif

#------------------------------------------------------#
# On recherche les deux unités dans [F:ITM] et [F:ITP] #
# Attention l'ordre des tests est important            #
#------------------------------------------------------#
Local Shortint I1 : I1=find(WUOM1,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))-1
Local Shortint I2 : I2=find(WUOM2,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))-1
#----- Vérification des coefficients nuls et mise à 1 si nécessaire -----#
If [F:ITP]PCUPUUCOE=0  [F:ITP]PCUPUUCOE=1 : Endif
If [F:ITP]PUUSTUCOE=0  [F:ITP]PUUSTUCOE=1 : Endif
If [F:ITM]PUUSTUCOE=0  [F:ITM]PUUSTUCOE=1 : Endif
If I1>=0
  If [F:ITM]PCUSTUCOE(I1)=0 [F:ITM]PCUSTUCOE(I1)=1 : Endif
Endif
If I2>=0
  If [F:ITM]PCUSTUCOE(I2)=0 [F:ITM]PCUSTUCOE(I2)=1 : Endif
Endif
#-----
If WUOM1=[F:ITP]PUU
  Case WUOM2
    When [F:ITP]PCU : WCOEUOM=1/[F:ITP]PCUPUUCOE
    When [F:ITM]STU : WCOEUOM=[F:ITP]PUUSTUCOE
    When [F:ITM]PUU : WCOEUOM=[F:ITP]PUUSTUCOE/[F:ITM]PUUSTUCOE
    When Default
      If I2>=0
        WCOEUOM=[F:ITP]PUUSTUCOE/[F:ITM]PCUSTUCOE(I2)
      Else
        Gosub RECH_TCO
      Endif
  Endcase
Elsif WUOM1=[F:ITP]PCU
  Case WUOM2
    When [F:ITP]PUU : WCOEUOM=[F:ITP]PCUPUUCOE
    When [F:ITM]STU : WCOEUOM=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE
    When [F:ITM]PUU : WCOEUOM=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE/[F:ITM]PUUSTUCOE
    When Default
      If I2>=0
        WCOEUOM=[F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE/[F:ITM]PCUSTUCOE(I2)
      Else
        Gosub RECH_TCO
      Endif
  Endcase
Elsif WUOM1=[F:ITM]STU
  Case WUOM2
    When [F:ITP]PUU : WCOEUOM=1/[F:ITP]PUUSTUCOE
    When [F:ITP]PCU : WCOEUOM=1/([F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE)
    When [F:ITM]PUU : WCOEUOM=1/[F:ITM]PUUSTUCOE
    When Default
      If I2>=0
        WCOEUOM=1/[F:ITM]PCUSTUCOE(I2)
      Else
        Gosub RECH_TCO
      Endif
  Endcase
Elsif WUOM1=[F:ITM]PUU
  Case WUOM2
    When [F:ITP]PUU : WCOEUOM=[F:ITM]PUUSTUCOE/[F:ITP]PUUSTUCOE
    When [F:ITP]PCU : WCOEUOM=[F:ITM]PUUSTUCOE/([F:ITP]PUUSTUCOE*[F:ITP]PCUPUUCOE)
    When [F:ITM]STU : WCOEUOM=[F:ITM]PUUSTUCOE
    When Default
      If I2>=0
        WCOEUOM=[F:ITM]PUUSTUCOE/[F:ITM]PCUSTUCOE(I2)
      Else
        Gosub RECH_TCO
      Endif
  Endcase
Elsif I1>=0
  Case WUOM2
    When [F:ITP]PUU : WCOEUOM=[F:ITM]PCUSTUCOE(I1)/[F:ITP]PUUSTUCOE
    When [F:ITP]PCU : WCOEUOM=[F:ITM]PCUSTUCOE(I1)/([F:ITP]PUUSTUCOE*[F:ITP]PCUPUUCOE)
    When [F:ITM]STU : WCOEUOM=[F:ITM]PCUSTUCOE(I1)
    When [F:ITM]PUU : WCOEUOM=[F:ITM]PCUSTUCOE(I1)/[F:ITM]PUUSTUCOE
    When Default
      If I2>=0
        WCOEUOM=[F:ITM]PCUSTUCOE(I1)/[F:ITM]PCUSTUCOE(I2)
      Else
        Gosub RECH_TCO
      Endif
  Endcase
Else
  Gosub RECH_TCO
Endif
#-----
End
############################################################
# Recherche avec poids puis dans la table des coefficients #
############################################################
$RECH_TCO
#----- Recherche avec poids d'une unité de stock -----#
If [F:ITM]ITMWEI<>0
  If WUOM1=[F:ITM]STU & WUOM2=[F:ITM]WEU
    WCOEUOM=[F:ITM]ITMWEI   : Return
  Elsif WUOM1=[F:ITM]WEU & WUOM2=[F:ITM]STU
    WCOEUOM=1/[F:ITM]ITMWEI : Return
  Endif
Endif
#-----
Read [TCO] TCO0=WUOM1;WUOM2
If !fstat
  WCOEUOM=[F:TCO]COEUOM
Else
  Read [TCO] TCO0=WUOM2;WUOM1
  If fstat
    Raz [F:TCO] : WCOEUOM=1
  Elsif [F:TCO]COEUOM=0
    WCOEUOM=1
  Else
    WCOEUOM=1/[F:TCO]COEUOM
  Endif
Endif
Return


#######################################################################
$OPEN_FILES_SCO
If !clalev([F:SCO]) : Local File SCOHEAD  [SCO] : Endif
If !clalev([F:SCI]) : Local File SCOITM   [SCI] : Endif
If !clalev([F:SCS]) : Local File SCOSRV   [SCS] : Endif
If !clalev([F:SCM]) : Local File SCOMAT   [SCM] : Endif
If !clalev([F:VEO]) : Local File VWSCO    [VEO] : Endif : # Vue SCO+SCI+SCS pour fonction de Solde
If filinfo(filpath("FIL","SCOTRK","fde",nomap),0)>0       # Issue 79859 GA 03/2012
   If !clalev([F:SCK]) : Local File SCOTRK   [SCK] : Endif
Endif

If clalev([M:SBCK])=0 : Local Mask SBCK   [SBCK] : Endif
If clalev([M:SCOK])=0 : Local Mask SCOK   [SCOK] : Endif
# transactions achat / EO
If clalev([F:PTR])=0 : Local File PURTRS  [PTR] : Endif
If filinfo(filpath("FIL","CPTANALIN","fde",nomap),0)>0
   If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
Endif
# Issue 97606 GA 05/2014
If !clalev([F:ORD])   Local File ORDERS       [ORD] : Endif
If !clalev([F:TBO])   Local File TABBOMALT    [TBO] : Endif
If !clalev([F:BOH])   Local File BOM          [BOH] : Endif
If !clalev([F:BOD])   Local File BOMD         [BOD] : Endif
Return

#######################################################################
# charge transaction de maj automatique des EO            # FQ 78121  #
#######################################################################
$READ_SCOPTRNUM
    If dim(GSCOPTRNUM)<=0 | GSCOPTRNUM = "" : Return : Endif
    If clalev([F:PTR])=0 : Local File PURTRS  [PTR] : Endif
    If [F:PTR]PTRNUM<>GSCOPTRNUM |  [F:PTR]PTRTYP <> 9 | [F:PTR]TRSAUTO <> 2
        Read [PTR]PTR0=9;GSCOPTRNUM
        If fstat : Raz [F:PTR] : Endif
    Endif
Return


