#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS0B 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PRCCPL
mkstat = 0
zoncou = "PRCCPL"
indice = 0
WNUM = [M]PRCCPL
If varmode([M]PRCCPL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRCCPL" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]PRCCPL or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PRCCPL([M]PRCCPL) From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRCCPL" : GZNUM = 1003276 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PRCCPLADI
mkstat = 0
zoncou = "PRCCPLADI"
indice = 0
WCHAR = [M]PRCCPLADI
If varinit([M]PRCCPLADI,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PRCCPLADI,"387","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PRCCPLADI,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PRCCPLADI" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]PRCCPLADI,"387","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]PRCCPLADI,"387",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]PRCCPLADI or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_PRCCPLADI([M]PRCCPLADI) From SUBPJTA
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone TASSOR
mkstat = 0
zoncou = "TASSOR"
indice = 0
WNUM = [M]TASSOR
If varmode([M]TASSOR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TASSOR" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]TASSOR or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_TASSOR([M]TASSOR) From SUBPJTA
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TASSOR" : GZNUM = 50781 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMTAS0B"
Return

