#<AdxTL>@(#)2.0.0.0 $Revision$
###################################################
# Maj texte traduisibles des propriété OBJ
###################################################
Call PATCH(nomap)
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AOBJPROP"    [AOP] 
Local File =DOSSIER+".ATEXTRA"     [AXX]

If dim([F:AOP]DES)<0 
 Close Local File [AOP],[AXX]
 End 
Endif

# Mise à jour de la table AOBJPROP
Call ECR_TRACE(mess(81,125,1)-"AOBJPROP:"-time$,0) From GESECRAN
Trbegin [AOP]
For [AOP]AOP0
  If [F:AOP]DES <> ""
   Call MAJTEXTRA([F:AOP]DES,"AOBJPROP","INTIT",[F:AOP]OBJ,num$([F:AOP]NUM))  From SUPMAJ30
  Endif
 Next
Commit

Close Local File [AOP],[AXX]
End
