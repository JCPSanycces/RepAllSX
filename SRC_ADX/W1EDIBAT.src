#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque EDIBAT 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:06"
A_USER  = "DOC"
A_STAMP = "20181109230406"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask EDIBAT [DIA]
Gosub HORODAT
Local Inpbox "EDIBAT" From GFONCTION At A_STAMP With A_WINDPREV Mask [DIA] As [SIM_]
Grizo [DIA]5
Grizo [DIA]10
Grizo [DIA]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DIA]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=94 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=94 : Y1(1)=3 : Y2(1)=7
X1(2)=1 : X2(2)=94 : Y1(2)=8 : Y2(2)=18
Return

$ON_NUM
Onevent CONTROL Call C_NUM(zc) From W1EDIBAT
Onevent AFTER_CHANGE Gosub AMM_NUM From W1EDIBAT
Return

Subprog C_NUM(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
If !mkstat
 ## Action STD
 Call C_NUM(VALEUR) From EDIBATSTD
 If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
Endif
Gosub _AFF
End

$AMM_NUM
Call AM_NUM(zc)
If !mkstat & GOBJET
 zoncou = "NUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_NUM(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_NUM(VALEUR) From EDIBATSTD
If mkstat : GERR = 1 : GZONE = "NUM" : GZNUM = 41947 : Endif
Gosub _AFF
End

$ON_PARCOD
Return

$ON_ZPARCOD
Onevent BEFORE_AREA Gosub AV_ZPARCOD From W1EDIBAT
Return

$AV_ZPARCOD
If clalev([F:EPR])=0 : Local File EDIPARTNER [EPR] : Endif
Call LECTURE("EPR",num$([M]PARCOD(indice)),"") From CONTOBJ
zc = [F:EPR]PARDES
Gosub _AFF
Return

$ON_CATCOD
Return

$ON_CATTYP
Onevent INIT_AREA Call D_CATTYP(zc) From W1EDIBAT
