$ON_FLG
Onevent CONTROL Call C_FLG(zc) From W1EDIBAT
Onevent AFTER_CHANGE Gosub AMM_FLG From W1EDIBAT
Onevent INIT_AREA Call D_FLG(zc) From W1EDIBAT
Onevent BEFORE_INPUT Call AS_FLG(zc) From W1EDIBAT
Return

Subprog D_FLG(VALEUR)
Variable Integer VALEUR
If varinit([M]FLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLG(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FLG(VALEUR)
Variable Integer VALEUR
## Action STD
Call C_FLG(VALEUR) From EDIBATSTD
If mkstat : GERR = 1 : GZONE = "FLG" : GZNUM = 51308 : Endif
Gosub _AFF
End

