#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OHRENT

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:58"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OHRENT",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="ENT0;ENT1;ENT2;ENT3;CTR3;ENT4;ENT6;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "HRENT"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "REFNUM"
If clalev([M:ENT0])=0 : Local Mask ENTSAL0 [ENT0] : Endif
If clalev([M:ENT1])=0 : Local Mask ENTSAL1 [ENT1] : Endif
If clalev([M:ENT2])=0 : Local Mask ENTSAL2 [ENT2] : Endif
If clalev([M:ENT3])=0 : Local Mask ENTSAL3 [ENT3] : Endif
If clalev([M:CTR3])=0 : Local Mask CTR3 [CTR3] : Endif
If clalev([M:ENT4])=0 : Local Mask ENTSAL4 [ENT4] : Endif
If clalev([M:ENT6])=0 : Local Mask ENTSAL6 [ENT6] : Endif
Gosub TIT
nolign = 1
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
Link [ID] With
& [AFF]AFF0~=[F:ID]FCY;GPROFIL;GUSRFCT,
& [FGR]FGR0=GGRPFCY;[F:ID]FCY,
& [FCY]FCY0=[F:ID]FCYORI,
& [CPY]CPY0=[F:FCY]LEGCPY
& As [ID_]
Return

$DEF_BOITE
Gosub HORODAT From WGOHRENT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OHRENT" From GFONCTION At A_STAMP With A_WINDPREV Mask [ENT0]
&   Folder Mask [ENT1]
& , Folder Mask [ENT2]
& , Folder Mask [ENT3]
& , Folder Mask [CTR3]
& , Invfol Mask [ENT4]
& , Folder Mask [ENT6]
&  Listbox [ID_] GAU_CHE
&   [L]SAIRAP(1) = [F:ID]REFNUM Using "K:15c" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:ID]NAM Using "K:40X" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:ID]SRN Using "K:40X" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = [F:ID]FCYORI Using "K:5c" Titled TITSEL(5) ,
&   [L]SAIRAP(6) = string$([F:FCY]LEG<>'',[F:FCY]LEG)+string$([F:FCY]LEG='',mess(91,187,1)) Using "K:10X" Titled TITSEL(6)
&  Listbox [ID9] GAU_CHE9
&   [L]SAIRAP(1) = [F:ID9]A_TAB1 Using "K:15c" Titled TITSEL9(1)  ,
&   [L]SAIRAP(2) = [F:ID9]A_TAB2 Using "K:40X" Titled TITSEL9(2)  ,
&   [L]SAIRAP(3) = [F:ID9]A_TAB3 Using "K:40X" Titled TITSEL9(3)  ,
&   [L]SAIRAP(4) = [F:ID9]A_TAB4 Using "K:5c" Titled TITSEL9(4)  ,
&   [L]SAIRAP(5) = [F:ID9]A_TAB5 Using "K:5c" Titled TITSEL9(5)  ,
&   [L]SAIRAP(6) = [F:ID9]A_TAB6 Using "K:10X" Titled TITSEL9(6)
& As [ENT1]
Titled [ENT1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOHRENT
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OHRENT" From GFONCTION At A_STAMP With A_WINDPREV Mask [ENT0]
&   Folder Mask [ENT1]
& , Folder Mask [ENT2]
& , Folder Mask [ENT3]
& , Folder Mask [CTR3]
& , Invfol Mask [ENT4]
& , Folder Mask [ENT6]
& As [ENT1]
Titled [ENT1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [ENT1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [ENT1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [ENT1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(3560,TITLIS) From OBJDIV
Local Char TITLIS9(30)
TITLIS9 = mess(196,123,1)
Local Char TITSEL(30)(1..6)
Call TEXTE(10793,TITSEL(1)) From OBJDIV
Call TEXTE(55,TITSEL(2)) From OBJDIV
Call TEXTE(1825,TITSEL(3)) From OBJDIV
Call TEXTE(1343,TITSEL(4)) From OBJDIV
Call TEXTE(9711,TITSEL(5)) From OBJDIV
Call TEXTE(26213,TITSEL(6)) From OBJDIV
Local Char TITSEL9(30)(1..6)
Call TEXTE(10793,TITSEL9(1)) From OBJDIV
Call TEXTE(55,TITSEL9(2)) From OBJDIV
Call TEXTE(1825,TITSEL9(3)) From OBJDIV
Call TEXTE(1343,TITSEL9(4)) From OBJDIV
Call TEXTE(9711,TITSEL9(5)) From OBJDIV
Call TEXTE(26213,TITSEL9(6)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(47506,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [ID_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [ENT1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [ENT1] GAU_CHE
 Else
  Fillbox [ENT1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [ID_]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 1
GAUTRELIS = 1
CLELISTE = "REFNUM"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [ID_]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [ID_] Order With CLELISTE
  Setlbox [ENT1] GAU_CHE
  Filter [ID_]
 When "GAU_CHE9"
  Gosub CLE_DERLU From =PROGOBJ
  Setlbox [ENT1] GAU_CHE9
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [ID_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [ID_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "ENTSAL0"      : ABMSK(0)  = "ENT0"     : AMA(0) = 1
NOMMSK(1) = "ENTSAL1"      : ABMSK(1)  = "ENT1"     : AMA(1) = 1
NOMMSK(2) = "ENTSAL2"      : ABMSK(2)  = "ENT2"     : AMA(2) = 1
NOMMSK(3) = "ENTSAL3"      : ABMSK(3)  = "ENT3"     : AMA(3) = 1
NOMMSK(4) = "CTR3"         : ABMSK(4)  = "CTR3"     : AMA(4) = 1
NOMMSK(5) = "ENTSAL4"      : ABMSK(5)  = "ENT4"     : AMA(5) = 0
NOMMSK(6) = "ENTSAL6"      : ABMSK(6)  = "ENT6"     : AMA(6) = 1
NBMASK = 6
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:ENT0])>0 : Default Mask [ENT0] : Endif
 When 1 : If clalev([M:ENT1])>0 : Default Mask [ENT1] : Endif
 When 2 : If clalev([M:ENT2])>0 : Default Mask [ENT2] : Endif
 When 3 : If clalev([M:ENT3])>0 : Default Mask [ENT3] : Endif
 When 4 : If clalev([M:CTR3])>0 : Default Mask [CTR3] : Endif
 When 5 : If clalev([M:ENT4])>0 : Default Mask [ENT4] : Endif
 When 6 : If clalev([M:ENT6])>0 : Default Mask [ENT6] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:ENT0])>0 : Gosub TITRES From W1ENTSAL0 : Endif
 When 1 : If clalev([M:ENT1])>0 : Gosub TITRES From W1ENTSAL1 : Endif
 When 2 : If clalev([M:ENT2])>0 : Gosub TITRES From W1ENTSAL2 : Endif
 When 3 : If clalev([M:ENT3])>0 : Gosub TITRES From W1ENTSAL3 : Endif
 When 4 : If clalev([M:CTR3])>0 : Gosub TITRES From W1CTR3 : Endif
 When 5 : If clalev([M:ENT4])>0 : Gosub TITRES From W1ENTSAL4 : Endif
 When 6 : If clalev([M:ENT6])>0 : Gosub TITRES From W1ENTSAL6 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:ENT0])>0 : Close Local Mask [ENT0] : Endif
If clalev([M:ENT1])>0 : Close Local Mask [ENT1] : Endif
If clalev([M:ENT2])>0 : Close Local Mask [ENT2] : Endif
If clalev([M:ENT3])>0 : Close Local Mask [ENT3] : Endif
If clalev([M:CTR3])>0 : Close Local Mask [CTR3] : Endif
If clalev([M:ENT4])>0 : Close Local Mask [ENT4] : Endif
If clalev([M:ENT6])>0 : Close Local Mask [ENT6] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:ENT0])>0 : Raz [M:ENT0] : Endif
 When 1 : If clalev([M:ENT1])>0 : Raz [M:ENT1] : Endif
 When 2 : If clalev([M:ENT2])>0 : Raz [M:ENT2] : Endif
 When 3 : If clalev([M:ENT3])>0 : Raz [M:ENT3] : Endif
 When 4 : If clalev([M:CTR3])>0 : Raz [M:CTR3] : Endif
 When 5 : If clalev([M:ENT4])>0 : Raz [M:ENT4] : Endif
 When 6 : If clalev([M:ENT6])>0 : Raz [M:ENT6] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:ENT0])>0 : Affzo [M:ENT0] : Endif
 When 1 : If clalev([M:ENT1])>0 : Affzo [M:ENT1] : Endif
 When 2 : If clalev([M:ENT2])>0 : Affzo [M:ENT2] : Endif
 When 3 : If clalev([M:ENT3])>0 : Affzo [M:ENT3] : Endif
 When 4 : If clalev([M:CTR3])>0 : Affzo [M:CTR3] : Endif
 When 5 : If clalev([M:ENT4])>0 : Affzo [M:ENT4] : Endif
 When 6 : If clalev([M:ENT6])>0 : Affzo [M:ENT6] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:ENT0])>0 : [F:ID] = [M:ENT0] : Endif
 When 1 : If clalev([M:ENT1])>0 : [F:ID] = [M:ENT1] : Endif
 When 2 : If clalev([M:ENT2])>0 : [F:ID] = [M:ENT2] : Endif
 When 3 : If clalev([M:ENT3])>0 : [F:ID] = [M:ENT3] : Endif
 When 4 : If clalev([M:CTR3])>0 : [F:ID] = [M:CTR3] : Endif
 When 5 : If clalev([M:ENT4])>0 : [F:ID] = [M:ENT4] : Endif
 When 6 : If clalev([M:ENT6])>0 : [F:ID] = [M:ENT6] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:ENT0])>0 : [M:ENT0] = [F:ID] : Endif
 When 1 : If clalev([M:ENT1])>0 : [M:ENT1] = [F:ID] : Endif
 When 2 : If clalev([M:ENT2])>0 : [M:ENT2] = [F:ID] : Endif
 When 3 : If clalev([M:ENT3])>0 : [M:ENT3] = [F:ID] : Endif
 When 4 : If clalev([M:CTR3])>0 : [M:CTR3] = [F:ID] : Endif
 When 5 : If clalev([M:ENT4])>0 : [M:ENT4] = [F:ID] : Endif
 When 6 : If clalev([M:ENT6])>0 : [M:ENT6] = [F:ID] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [ENT0]REFNUM
Else
 Grizo [ENT1]REFNUM
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [ENT0]REFNUM
Else
 Actzo [ENT1]REFNUM
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "1" : LBOUT(NBTEX) = 1101 : Call TEXTE(44767,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(1043,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "3" : LMEN(NBMEN) = 2001 : Call TEXTE(45690,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "5" : LMEN(NBMEN) = 2002 : Call TEXTE(45450,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "4" : LMEN(NBMEN) = 2003 : Call TEXTE(45640,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "3"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  PARBOUT(2) = [M]CTRDAT([M]WLIG)
  PARBOUT(3) = [M]CTRNUM([M]WLIG)
  FLGEXE = 1
  GACTION = "TRTGENCTR"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTGENCTR","TRTGENCTR",4,"XYTRTGENCTR") From GTRAITE
 When "5"
  FLGEXE = 1
  GACTION = "STD"
 When "4"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  FLGEXE = 1
  GACTION = "EXTRDUE"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","EXTRDUE","DEXTRDUE",4,"XYEXTRDUE") From GTRAITE
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


