#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################
# UTITRC02   Squelette pour Moulinette             Module Tronc commun   #
#            description de la moulinette                                #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MAJ_UTITRC02(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRC02(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTITRC02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CDI])  =0  Local File =DOSSIER+".CADIEDEF"   [CDI] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [CDI]

Delete [CDI] Where OBJ=12
Delete [CDI] Where OBJ=13
Delete [CDI] Where OBJ=15

Commit

Close Local File [CDI]

Call ECR_TRACE("UTITRC02 : Process End on : "+DOSSIER,0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : ENDIF
If [F:ADS]MODULE(9)<>2 : End : Endif
If filinfo(filpath("FIL","CADIEDEF","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRC02(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(9)<>2 : End : Endif
If filinfo(filpath("FIL","CADIEDEF","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRC02(APPLI)
End
