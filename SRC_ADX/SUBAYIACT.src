#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion champs interface
## Actions
#
#  Utilitaire:
##        - $GETWS_VAR      # Obtenir les informations d'un Web Services
#
#  Version 0001
#
######################################################################################
$ACTION
#Infbox GACTION
Case ACTION
  When "SEL_LISTE"        : Gosub SEL_LISTE
  When "VERF_LISTE"       : Gosub VER_LISTE
  When "TRT_DIV"          : Gosub TRT_DIV
Endcase
Return

######################################################################################
#  Actions
##     Code          Identifiant
#      AYIFIESEL     FIESEL        Sélection d'un champ de l'interfaces Xtend 
#      AYIFIECTL     FIECTL        Controle d'un champ de l'interfaces Xtend 
#      AYIFIEINI     FIEINI        Initialisation champ 
#      AYIGRPCTL     GRPCTL        Controle groupe interfaces Xtend 
#      AYIOPTISEL    OPTIMISEL     Sélection optimisation
#      AYIOPTICTL    OPTIMICTL     Controle optimisation
#      AYIOPTIMNL    OPTIMIMNL     Liste optimisation pour chps menu local
######################################################################################
$TRT_DIV
Case TRAIT
When "FIECTL"       :  Gosub FIE_CTL
When "FIEINI"       :  Gosub FIE_INI
When "GRPCTL"       :  Gosub GRP_CTL
When "OPTIMICTL"    :  Gosub OPTIMI_CTL
When "OPTIMIMNL"    :  Gosub OPTIMI_MNL
Endcase
Return

$SEL_LISTE
Case LISTE
  When "FIESEL" : Gosub FIE_SEL
  When "OPTIMISEL" : Gosub OPTIMI_SEL
Endcase
Return

$VER_LISTE
Case LISTE
  When "FIESEL" : Gosub FIE_VER
Endcase
Return

#    AYIFIESEL  Sélection d'un champ de l'interfaces Xtend 
######################################################################################
####  VALEUR    Ne pas utiliser. Suivant l'appel:  Code champ ou groupe
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#          3    Valeur        Option    "":tous les champs
#                                       "A" Champs par adresse (WS vers le serveur)
#          4    Adresse       Groupe du champ   
#          5    Adresse       Code champ interface
#
$FIE_SEL
#---------------------------------------------------------------#
Local Char FCYWRK(GLONAYG), INTCOD(GLONAYI), DSCCOD(12), DSCGRP(GLONAPU), OPTION
Local Integer WI
Local Integer WMAX : WMAX=350
If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
[L]FCYWRK= PARAM(1)  # site de travail
[L]INTCOD= PARAM(2)  # interface
[L]OPTION= PARAM(3)  # option
[L]DSCGRP= PARAM(4)  # Groupe du champ
[L]DSCCOD= PARAM(5)  # Code champ interface

Gosub GETWS_VAR      # Variables pour GETWS_INF

Read [AYI]AYI0 = [L]FCYWRK;[L]INTCOD
If fstat
    Call RSTA("AYI",[L]FCYWRK+"~"+[L]INTCOD) From GLOCK 
    Return
Endif

# Intitulés
Case [F:AYI]TYP
When 1,2,3,4      
    # Type accès: l'occurrence du champs interface sert à définir les enreg. donc inutile en sélection 
    Local Char     TEX(50)(1..WMAX ) , TEXTE(80)(1..WMAX ,1..3)
#<om
    #TIT(0)=mess(65,7900,1)
    TIT(0)=mess(218,7900,1)
#om> 
    TIT(1)=mess(1,89,1)
    TIT(2)=mess(82,123,1)
    TIT(3)=mess(58,9010,1)
When 20,21       
    # Type action
    Local Char     TEX(50)(1..WMAX ) , TEXTE(80)(1..WMAX ,1..4)
#<om
    #TIT(0)=mess(65,7900,1)
    TIT(0)=mess(218,7900,1)
#om> 

    TIT(1)=mess(1,89,1)
    TIT(2)=mess(82,123,1)
    TIT(3)=mess(58,9010,1)
    TIT(4)=mess(6,16,1)
When Default
    mkstat=2 : GMESSAGE="Interface type unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)
    Return
Endcase

# Gestion similaire à celle de AYI pour afficher le tableau
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD 
Gosub GETWS_INF     
Case [F:AYI]TYP
When 1,2,4,20     # Accès sous-programme généré accès sur table ou vue (ASU car mise à jour en premier)
                  # Accès sous-programme utilisateur
                  # Action sous-programme utilisateur
    If WS_RET and !(WS_RET=2) : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return : Endif
When Default
    If WS_RET : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return  : Endif
Endcase

#
Case [F:AYI]TYP
When 1,2,4   # Accès sous-programme généré accès sur table/vue (ASU car mise à jour en premier)
             # Accès sous-programme utilisateur
    If RUBNBR > 0 : Sorta RUBNBR RUBGRP,RUBCOD,RUBADR, RUBINTIT : Endif
    For WI=0 To RUBNBR-1
       # Exclure paramétres techniques requête
       If !find(RUBGRP(WI),"AX_PAR","AX_WHR","AX_ORD")
        If (OPTION="" | (OPTION="A" & RUBADR(WI)=1))  # Tous ou ceux par adresse uniquement
         NBTEX+=1
         TEX(NBTEX)=RUBGRP(WI)+"_"+RUBCOD(WI)
         TEXTE(NBTEX,1)=RUBCOD(WI)    # Champ
         Call TEXTE(RUBINTIT(WI), TEXTE(NBTEX,2)) From OBJDIV
         TEXTE(NBTEX,3)=RUBGRP(WI)    # Groupe
       Endif
     Endif
    Next 
    #
When 3    # Accès liste gauche 
    If RUBNBR > 0 : Sorta RUBNBR RUBGRP,RUBCOD,RUBADR, RUBINTIT : Endif
    For WI=0 To RUBNBR-1
       If (OPTION="" | (OPTION="A" & RUBADR(WI)=1))  # Tous ou ceux par adresse uniquement
         NBTEX+=1
         TEX(NBTEX)=RUBGRP(WI)+"_"+RUBCOD(WI)
         TEXTE(NBTEX,1)=RUBCOD(WI)
         Call TEXTE(RUBINTIT(WI), TEXTE(NBTEX,2)) From OBJDIV
         TEXTE(NBTEX,3)=RUBGRP(WI)
       Endif
    Next 
    #
When 20   # Action sous-programme utilisateur
    If RUBNBR > 0 : Sorta RUBNBR RUBGRP,RUBCOD,RUBADR, RUBINTIT,RUBDIM : Endif
    For WI=0 To RUBNBR-1
     # Exclure paramétres techniques requête
     If !find(RUBGRP(WI),"AX_PAR","AX_WHR","AX_ORD")
       If (OPTION="" | (OPTION="A" & RUBADR(WI)=1))  # Tous ou ceux par adresse uniquement
         NBTEX+=1
         TEX(NBTEX)=RUBGRP(WI)+"_"+RUBCOD(WI)
         TEXTE(NBTEX,1)=RUBCOD(WI)    # Champ
         Call TEXTE(RUBINTIT(WI), TEXTE(NBTEX,2)) From OBJDIV
         TEXTE(NBTEX,3)=RUBGRP(WI)    # Groupe
         TEXTE(NBTEX,4)=num$(RUBDIM(WI))
       Endif
     Endif
    Next 
When 21    # Action objet
    If RUBNBR > 0 : Sorta RUBNBR RUBGRP,RUBCOD,RUBADR,RUBINTIT,RUBDIM : Endif
    For WI=0 To RUBNBR-1
       If (OPTION="" | (OPTION="A" & RUBADR(WI)=1))  # Tous ou ceux par adresse uniquement
         NBTEX+=1
         TEX(NBTEX)=RUBGRP(WI)+"_"+RUBCOD(WI)
         TEXTE(NBTEX,1)=RUBCOD(WI)
         Call TEXTE(RUBINTIT(WI), TEXTE(NBTEX,2)) From OBJDIV
         TEXTE(NBTEX,3)=RUBGRP(WI)
         TEXTE(NBTEX,4)=num$(RUBDIM(WI))
       Endif
    Next 
Endcase

# Positionnement
WI = find([L]DSCGRP+"_"+[L]DSCCOD,TEX)
If WI : VALEUR=[L]DSCGRP+"_"+[L]DSCCOD : Endif
If !WI  & [L]DSCGRP<>""
    WI = find([L]DSCGRP,RUBGRP)
    If WI : VALEUR=RUBGRP(WI-1)+"_"+RUBCOD(WI-1) : Endif     # Propose le 1er du groupe
Endif
Return


$FIE_VER
#---------------------------------------------------------------#
WI = find(VALEUR,TEX)
If WI
 PARAM(4)=TEXTE(WI,3)
 PARAM(5)=TEXTE(WI,1)
Endif
Return

#    AYIFIECTL  Controle d'un champ de l'interfaces Xtend 
######################################################################################
####  VALEUR    Ne pas utiliser. Suivant l'appel:  Code champ ou groupe
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#          3    Valeur        Option    "":tous les champs
#                                       "A" Champs par adresse (WS vers le serveur)
#          4    Adresse       Groupe du champ   
#          5    Valeur        Code champ interface
#
$FIE_CTL
Local Char FCYWRK(GLONAYG), INTCOD(GLONAYI), WEBSRCCOD, DSCCOD(12), DSCGRP(GLONAPU), OPTION

Local Integer WI, WJ, ERRTRT
If VALEUR="" : Return : Endif         # Nota: obligatoire = paramétrage écran

If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Gosub GETWS_VAR      # Variables pour GETWS_INF

[L]FCYWRK= PARAM(1)  # site de travail
[L]INTCOD= PARAM(2)  # interface
[L]OPTION= PARAM(3)  # option
[L]DSCGRP= PARAM(4)  # Groupe du champ
[L]DSCCOD= PARAM(5)  # Code champ interface

Read [AYI]AYI0 = [L]FCYWRK;[L]INTCOD
If fstat
    Call RSTA("AYI",[L]FCYWRK+"~"+[L]INTCOD) From GLOCK 
    mkstat=2 
    Return
Endif

#
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD 
Gosub GETWS_INF 
Case [F:AYI]TYP
When 1,2,4,20     # Accès sous-programme généré accès sur table/vue (ASU car mise à jour en premier)
                  # Accès sous-programme utilisateur
                  # Action sous-programme utilisateur
    If WS_RET and !(WS_RET=2) : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return : Endif
When Default
    If WS_RET : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return  : Endif
Endcase


#
Case [F:AYI]TYP
When 1,2,4,20  # Accès sous-programme généré accès sur table/vue (ASU car mise à jour en premier)
               # Accès sous-programme utilisateur
               # Action sous-programme utilisateur
    WI = find([L]DSCCOD,RUBCOD)
    If !WI=0 
        If [L]DSCGRP=""    # On passe le groupe (simplification de saisie)
            [L]DSCGRP = RUBGRP(WI-1)
        Else
            If [L]DSCGRP<>RUBGRP(WI-1) # Groupe choisi mais pas le bon
                GMESSAGE=mess(66,7900,1)-[L]INTCOD
                mkstat=2 : Return
            Endif
        Endif
        If (OPTION="A" & RUBADR(WI-1)>1)  # Pas de type par adresse
            GMESSAGE=mess(93,7900,1)-[L]INTCOD
            mkstat=2 : Return
        Endif
    Else
        GMESSAGE=mess(66,7900,1)-[L]INTCOD
        mkstat=2 : Return
    Endif
    #
When 3,21  # Accès liste gauche
           # Action objet
    WI = find([L]DSCCOD,RUBCOD)
    If !WI=0 
        If [L]DSCGRP=""    # On passe le groupe (simplification de saisie)
            [L]DSCGRP = RUBGRP(WI-1)
        Else
            If [L]DSCGRP<>RUBGRP(WI-1) # Groupe choisi mais pas le bon
                GMESSAGE=mess(66,7900,1)-[L]INTCOD
                mkstat=2 : Return
            Endif
        Endif
        If (OPTION="A" & RUBADR(WI-1)<>1)  # Pas de type par adresse
            GMESSAGE=mess(93,7900,1)-[L]INTCOD
            mkstat=2 : Return
        Endif
    Else
        GMESSAGE=mess(66,7900,1)-[L]INTCOD
        mkstat=2 : Return
    Endif
    #
When Default
    mkstat=2 : GMESSAGE="Interface type  unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)-"Interface:"-[L]INTCOD
    Return
Endcase

#
PARAM(4) = [L]DSCGRP  # Groupe du champ
Return


#    AYIFIEINI  Initialisation d'un champ de l'interfaces Xtend à partir d'un code proposé
######################################################################################
####  VALEUR    Ne pas utiliser. Suivant l'appel:  Code champ ou groupe
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#          3    Valeur        Option    "":tous les champs
#                                       "A" Champs par adresse (WS vers le serveur)
#          4    Valeur        Code champ proposé
#          5    Adresse       Groupe du champ   
#          6    Adresse       Code champ interface
#
$FIE_INI
Local Char FCYWRK(GLONAYG), INTCOD(GLONAYI), WEBSRCCOD, FLDSUG(12),OPTION
Local Integer WI, ERRTRT

If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Gosub GETWS_VAR      # Variables pour GETWS_INF

[L]FCYWRK= PARAM(1)  # site de travail
[L]INTCOD= PARAM(2)  # interface
[L]OPTION= PARAM(3)  # option
[L]FLDSUG= PARAM(4)  # Code champ proposé

Read [AYI]AYI0 = [L]FCYWRK;[L]INTCOD
If fstat
    Return
Endif

#
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD 
Gosub GETWS_INF : If WS_RET : Raz GERR,GMESSAGE : Return : Endif
#
Case [F:AYI]TYP
When 1,2,20  # Accès sous-programme généré accès sur table (ASU car mise à jour en premier)
             # Accès sous-programme utilisateur
             # Action sous-programme utilisateur
    WI = find(FLDSUG,RUBCOD)
    If WI
       If (OPTION="" | (OPTION="A" & RUBADR(WI-1)=1))  # Tous ou ceux par adresse uniquement
         PARAM(5)=RUBGRP(WI-1)
         PARAM(6)=RUBCOD(WI-1)
       Endif
    Endif
    #
When 3,21  # Accès liste gauche
           # Action objet
    WI = find(FLDSUG,RUBCOD)
    If WI
      If (OPTION="" | (OPTION="A" & RUBADR(WI-1)=1))  # Tous ou ceux par adresse uniquement
        PARAM(5)=RUBGRP(WI-1)
        PARAM(6)=RUBCOD(WI-1)
      Endif
    Endif
    #
When Default
Endcase
#
Return


#    AYIGRPCTL  Controle groupe de l'interfaces Xtend 
######################################################################################
# VALEUR        Valeur        Groupe du champ       
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#          3    Valeur        Option    "":tous les champs
#                                       "A" Champs par adresse (WS vers le serveur)
#
$GRP_CTL
Local Char FCYWRK(GLONAYG), INTCOD(GLONAYI), WEBSRCCOD, DSCGRP(GLONAPU),OPTION
Local Integer WI, WJ, ERRTRT, WFIND
If VALEUR="" : Return : Endif         # Nota: obligatoire = paramétrage écran

If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Gosub GETWS_VAR      # Variables pour GETWS_INF

[L]FCYWRK= PARAM(1)  # site de travail
[L]INTCOD= PARAM(2)  # interface
[L]OPTION= PARAM(3)  # option
[L]DSCGRP= VALEUR    # Groupe du champ

Read [AYI]AYI0 = [L]FCYWRK;[L]INTCOD
If fstat
    Call RSTA("AYI",[L]FCYWRK+"~"+[L]INTCOD) From GLOCK 
    mkstat=2 
    Return
Endif

#
WS_INTTYP=[F:AYI]TYP : WS_WSRCOD=[F:AYI]WEBSRCCOD 
Gosub GETWS_INF 
Case [F:AYI]TYP
When 1,2,4,20     # Accès sous-programme généré accès sur table/vue (ASU car mise à jour en premier)
                  # Accès sous-programme utilisateur
                  # Action sous-programme utilisateur
    If WS_RET and !(WS_RET=2) : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return : Endif
When Default
    If WS_RET : GERR=1 : GMESSAGE=WS_MES : mkstat=2 : Return  : Endif
Endcase

#
Case [F:AYI]TYP
When 1,2,4,20  # Accès sous-programme généré accès sur table/vue (ASU car mise à jour en premier)
               # Accès sous-programme utilisateur
               # Action sous-programme utilisateur
    WI = find([L]DSCGRP,RUBGRP)
    If !WI
        GMESSAGE=mess(86,7900,1)-[L]INTCOD
        mkstat=2 : Return
    Endif

    If OPTION="A"     # Il faut au moins un champs par adresse
        WFIND=0        
        For WI=0 To RUBNBR-1
            If [L]DSCGRP=RUBGRP(WI)
               If RUBADR(WI)=1      # 1: adresse menu34
                 WFIND=WI : Break
               Endif
            Endif
        Next 
        If !WI
            GMESSAGE=mess(94,7900,1)-[L]INTCOD
            mkstat=2 : Return
        Endif
    Endif   
    #
When 3,21  # Accès liste gauche
           # Action objet
    WI = find([L]DSCGRP,RUBGRP)
    If !WI
        GMESSAGE=mess(86,7900,1)-[L]INTCOD
        mkstat=2 : Return
    Endif
    
    If OPTION="A"     # Il faut au moins un champs par adresse
        WFIND=0        
        For WI=0 To RUBNBR-1
            If [L]DSCGRP=RUBGRP(WI)
               If RUBADR(WI)=1            # 1: adresse menu34
                 WFIND=WI : Break
               Endif
            Endif
        Next 
        If !WI
            GMESSAGE=mess(94,7900,1)-[L]INTCOD
            mkstat=2 : Return
        Endif
    Endif   
    #

When Default
    mkstat=2 : GMESSAGE="Interface type  unknown:"-num$([F:AYI]TYP)-mess([F:AYI]TYP,7912,1)-"Interface:"-[L]INTCOD
    Return
Endcase

#
Return

#    AYIOPTICTL  Controle optimisation interface
######################################################################################
# VALEUR        Adresse       Code optimisation
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#
$OPTIMI_CTL
If VALEUR="" : Return : Endif
If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Raz [F:AYI]
Read [F:AYI]AYI0 = PARAM(1);PARAM(2)
If !find(VALEUR, [F:AYI]OPTIMI)
        GERR=1
        GMESSAGE=mess(125,7900,1)
        mkstat=2
Endif
Return

#    AYIOPTIMNL  Liste optimisation interface pour chps menu local
######################################################################################
# VALEUR        Adresse       Code optimisation
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#
$OPTIMI_MNL
If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Raz [F:AYI]
Read [F:AYI]AYI0 = PARAM(1);PARAM(2)
For WI=2 To len(mess(0,7933,1))    # Aucun tj permis
    If !find(WI,[F:AYI]OPTIMI) : GMENLOC(WI)=1 : Endif
Next
Return

#    AYIOPTISEL  Sélection optimisation interface
######################################################################################
# VALEUR        Adresse       Code optimisation
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code interface
#
$OPTIMI_SEL
#---------------------------------------------------------------#
If clalev([F:AYI])=0 : Local File AYTINT [AYI] : Endif
Read [F:AYI]AYI0 = PARAM(1);PARAM(2)
If fstat=0
    Local Integer WI
    TIT=mess(126,7900,1)-PARAM(1)
    For WI=0 To [F:AYI]OPTIMINBR-1
        NBTEX+=1
        TEX(NBTEX)=num$([F:AYI]OPTIMI(WI))
        TEXTE(NBTEX)=mess([F:AYI]OPTIMI(WI),7933,1)
    Next
Endif
If NBTEX=0
    GERR=2 : GMESSAGE =mess(99,100,1) : mkstat=2
Endif
Return

######################################################################################
## Xtend - Utilitaires 
######################################################################################

#------------------------------------------------------------#
# Obtenir les informations d'un Web Services:
#    - Caractéristiques associées (objet, trt...)
#        Voir liste dans GETWS_VAR
#    - Informations sur les rubriques du WS 
#        Variables locales: RUBNBR , RUBCOD(), RUBNBR() , RUBDIM()....
#
#
#    WS_RET    Code retour    0: OK    1: type inconnu    2: erreur accès trt
#                                  3: erreur lecture ASU       4: incohèrence entre le WS et le type de l'interface
#                                  5: erreur accès Publication WS
#
#    Nota $001: Peut-être utilisée sur une machine distante avec WS_DOSDES= [sodaix01:5000@XTEND]
#                 Ex: AYTWSRGES ( aide à la gestion des WS entre dossiers))
#
$GETWS_VAR
Local Integer  WS_INTTYP                 # (I) Type interface Xtend - menu 7912  
Local Char     WS_WSRCOD(10)             # (I) Nom de publication
Local Char     WS_DOSDES(GDIMFIC)        # (I) Nom dossier complet  ( sodaix01:5000@XTEND )
Local Integer  WS_RET                    # (O) 
Local Char     WS_MES(80)                # (O) 
Local Char     WS_ASUTRT(GLONADC)        # (O) Pour type ss-prgrm - trt (Clé accès ASU)
Local Char     WS_ASUSPG(GLONASU)        # (O) idem               - ss-prgrm (Clé accès ASU)
Local Char     WS_WXTRT(GLONADC+2)       # (O) Pour objet         - trt wrapper (exemple: WJAUS)
Local Char     WS_WXSPG(GLONASU)         # (O) idem               - etiquette définition wrapper ($XT_LISTE, XT_OBJET)
Local Char     WS_WXOBJ(GLONAOB)         # (O) idem               - code objet X3
Local Integer  WS_WXINV                  # (O) idem               - zone invisible
Local Char     WS_WXVAR(10)              # (O) idem               - code variante

#
Local Char     WS_MSG1 (250)
Local Char     WS_MSG2 (250)
Local Char     WS_MACDES(GDIMFIC), WS_DOSNAMDES(GDIMFIC)        # sodaix01:5000 et XTEND
Local Char     WS_NOMFIC (250)
Local Integer  WS_WI, WS_WJ

# Voir nota $001
  Local Char     WS_SVDGBSTR2 (250)                                 # Sauvegarde classes par défaut 
  If clalev([F:ASUX]) : Close Local File [ASUX] : Endif             # Fermeture si ouverture préalable (chgt dossier)
  If clalev([F:AWEX]) : Close Local File [AWEX] : Endif             # 
  Local Integer  WS_AWEFSTAT
Return

$GETWS_INF  
Raz WS_ASUTRT, WS_ASUSPG, WS_WXTRT, WS_WXSPG, WS_WXOBJ, WS_WXINV, WS_WXVAR, WS_RET, WS_MES
If WS_DOSDES="" : WS_DOSDES=nomap : Endif
#Inftxt "" At 2

# Verif cohérence
If clalev([F:AWEX])=0
    WS_SVDGBSTR2=dbgstr(2)                
    If WS_DOSDES="" or WS_DOSDES=nomap 
        Local File AWEBSERVIC [AWEX]
    Else 
        Local File =WS_DOSDES+".AWEBSERVIC"  [AWEX]
    Endif
    Default File WS_SVDGBSTR2             # Restitution ordre des fichiers
Endif
Read [AWEX]AWE1 = [L]WS_WSRCOD
WS_AWEFSTAT = fstat

Case WS_INTTYP
When 1       # Accès sous-programme généré accès sur table
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG    = "XT_SPG"
    WS_ASUTRT    = "WT"+WS_WSRCOD
    WS_ASUSPG    = "ACCTAB"
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Else
        If (WS_ASUTRT <> [AWEX]PRG or WS_ASUSPG <> [AWEX]SUBPRG)
            WS_RET=4 : WS_MES = mess(205, 7900, 1)    #-" ("-WS_ASUTRT-" -"-WS_ASUSPG-")"
            Return
        Endif 
    Endif

    Onerrgo WS_DATA_E
    Gosub XT_SPG From =WS_WXTRT  
    Onerrgo 
    If WS_RET 
      WS_MES+=" - XT_SPG" : Return
    Endif

When 2        # Accès sous-programme utilisateur
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG    = "XT_SPG"
    WS_ASUTRT    = [AWEX]PRG
    WS_ASUSPG    = [AWEX]SUBPRG
    # Les infos viennent de la fiche de publication
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Endif 
    If (left$(WS_ASUTRT,1)="W" )                    # W en 1er = prgm généré
        WS_RET=4 : WS_MES = mess(205, 7900, 1)    #-" ("-WS_ASUTRT-" -"-WS_ASUSPG-")"
        Return
    Endif 

    Onerrgo WS_DATA_E
    Gosub XT_SPG From =WS_WXTRT  
    Onerrgo 
    If WS_RET 
      WS_MES+=" - XT_SPG" : Return
    Endif

When 3    # Accès liste gauche
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG="XT_LISTE"
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Endif 

    WS_WXOBJ=[AWEX]OBJET
    WS_WXINV=[AWEX]INVISIBLE
    WS_WXVAR=[AWEX]VARIANTE

    Onerrgo WS_DATA_E
    Gosub XT_LISTE From =WS_WXTRT  
    Onerrgo 
    If WS_RET
      WS_MES+=" - XT_LISTE" : Return
    Endif

When 4       # Accès sous-programme généré accès sur vue 
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG    ="XT_SPG"
    WS_ASUTRT   ="WT"+WS_WSRCOD
    WS_ASUSPG   ="ACCVIEW"
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Else
        If ( WS_ASUTRT <> [AWEX]PRG or WS_ASUSPG <> [AWEX]SUBPRG)                  
            WS_RET=4 : WS_MES = mess(205, 7900, 1)    #-" ("-WS_ASUTRT-" -"-WS_ASUSPG-")"
            Return
        Endif 
    Endif

    Onerrgo WS_DATA_E
    Gosub XT_SPG From =WS_WXTRT  
    Onerrgo 
    If WS_RET 
      WS_MES+=" - XT_SPG" : Return
    Endif

When 20   # Action sous-programme utilisateur
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG="XT_SPG"
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Endif 

    WS_ASUTRT    = [AWEX]PRG
    WS_ASUSPG    = [AWEX]SUBPRG

    Onerrgo WS_DATA_E
    Gosub XT_SPG From =WS_WXTRT  
    Onerrgo 
    If WS_RET 
      WS_MES+=" - XT_SPG" : Return
    Endif

When 21   # Action objet
    WS_WXTRT    = "WJ"+WS_WSRCOD
    WS_WXSPG="XT_OBJET"
    If WS_AWEFSTAT
        WS_RET=5 : WS_MES = mess(206, 7900, 1)-[L]WS_WSRCOD
        Return
    Endif 

    WS_WXOBJ=[AWEX]OBJET
    WS_WXINV=[AWEX]INVISIBLE
    WS_WXVAR=[AWEX]VARIANTE

    Onerrgo WS_DATA_E
    Gosub XT_OBJET From =WS_WXTRT  
    Onerrgo 
    If WS_RET 
      WS_MES+=" - XT_OBJET" : Return
    Endif

When Default
    WS_RET=1
    WS_MES="Interface type unknown:"-num$(WS_INTTYP)-mess(WS_INTTYP,7912,1)
    Return
Endcase


If find(WS_INTTYP,1,2,4)
    Local Integer RUBRESMAX               # Nb de lignes résultats pour accès
    For WS_WI=0 To RUBNBR -1
     If RUBRESMAX=0 and !find(RUBGRP(WS_WI),"AX_PAR","AX_WHR","AX_ORD")
        RUBRESMAX=RUBDIM(WS_WI)
        Break
     Endif               
    Next 

    # Ctl source
    Gosub WS_SRCEXIST
    If WS_RET : Return :ENDIF

Endif

Return


$WS_DATA_E
WS_RET=2: WS_MES=mess(44,7900,1)-WS_WXTRT
Resume

$WS_SRCEXIST
# Source 
Call MACHINE(WS_DOSDES, WS_MACDES, WS_DOSNAMDES) From ORDSYS
#
If WS_DOSDES=nomap    # En local, recherche sur dossier mère (C4 - exemple sur SUBADC)
    WS_J=0
    For WS_WI=0 To 7
      If nomap(WS_WI)<>""
         WS_NOMFIC=func AYTGESFILE.GETPATH(WS_MACDES, WS_DOSNAMDES, "FILTRT","","",WS_ASUTRT)
         If filinfo(WS_NOMFIC, 0)>=0 : WS_WJ=1 : Break : Endif
      Endif
    Next 
    If WS_J : WS_RET=2: WS_MES=mess(44,7900,1)-WS_ASUTRT : Endif
Else                  # A distance - dossier renseigné uniquement
    WS_NOMFIC=func AYTGESFILE.GETPATH(WS_MACDES, WS_DOSNAMDES, "FILTRT","","",WS_ASUTRT)
    If filinfo(WS_NOMFIC, 0)<0
        WS_RET=2: WS_MES=mess(44,7900,1)-WS_ASUTRT
    Endif
Endif
Return

