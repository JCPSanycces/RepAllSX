######################################################################################
# Gestion du masque CEVREL
# Création
#     SBA - 09/04/13 - FQ 88316 - US 1527
#              - Campagnes d'entretiens - Suivi
######################################################################################



$ACTION
  Case ACTION
    When "INIT"         : Gosub INIT
    When "OUVRE"        : Gosub OUVRE
    When "CONTROLE"     : Gosub CONTROLE
    When "BOUTON"       : Gosub BOUTON
    When "DEBUT"        : Gosub DEBUT
    When "OK"           : Gosub OK
    When "EXEC"         : Gosub EXEC
    When "AVANT_OK"     : Gosub AVANT_OK
  Endcase
Return


$AVANT_OK
##FOK=1
If BOITE="CEVREL2"
  Local Integer W_GENERATE,WOK
  W_GENERATE=find(2,[M]FLGREL(0..NBLIG-1))
  If W_GENERATE Then
      Call OUINON(mess(125,10720,1), WOK) From GESECRAN : # Ce traitement est un traitement réel. Confirmez-vous ?
      If WOK = 1 Then
       FIN=0
       FOK=0
       GERR=1
     Endif
    Else
      FOK=0
    Endif
Else
#  If BOITE="CEVREL"
# Gosub CONTROLE_LEG_OK From =func GETNAMFIC
#  If !WOK
#    FIN=0
#    FOK=0
#    GERR=1
#
#  Endif
#  Endif
Endif
Return
$INIT
If clalev([M:DIA]) = 0  : Local Mask  CEVREL    [DIA]     : Endif
Raz [M:DIA]STASTR,[M:DIA]STAEND
 If func IS_PRHACTIF
    [M:DIA]STAEND=3
 Endif
  GERR=0
  GOK=1
  Gosub INIT_CEVREL
Return

$FINSAI
Return

$OUVRE
  # Ouverture des tables utilisées
  If clalev([M:DIA]) = 0  : Local Mask CEVREL     [DIA]   : Endif
  If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
  #If !clalev([F:CVRV])    : Local File CEVRELV   [CVRV]    : Endif
  # Ouverture des tables utilisées
  If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
  If clalev([F:CPY])=0    : Local File COMPANY    [CPY]   : Endif
  If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
#  If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
  If clalev([F:AD])=0     : Local File EMPLOAD    [AD]    : Endif
  If clalev([F:CPT])=0    : Local File EMPLOCPT   [CPT]   : Endif
  If clalev([F:RIB])=0    : Local File EMPLORIB   [RIB]   : Endif
  If clalev([F:MED])=0    : Local File EMPLOMED   [MED]   : Endif
  If clalev([F:CEV])=0    : Local File COMPEVAL   [CEV]   : Endif
  If clalev([F:EVE])=0    : Local File EVAEMP     [EVE]   : Endif
  If clalev([F:EVE2])=0   : Local File EVAEMP     [EVE2]  : Endif
  If clalev([F:EVC])=0    : Local File EVAEMPCPC  [EVC]   : Endif
  If clalev([F:EVD])=0    : Local File EVAEMPDET  [EVD]   : Endif
  If clalev([F:EVD2])=0   : Local File EVAEMPDET  [EVD2]  : Endif
  If clalev([F:EPO])=0    : Local File EMPLOPOT   [EPO]   : Endif
  If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
  If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif
  If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
  If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
  If clalev([F:CPE])=0    : Local File CPCEMP     [CPE]   : Endif
#  Gosub INIT_CEVREL
#  Affzo [M:DIA]
Return


$BOUTON
Case BOITE
  When "CEVREL2" :
      Case BOUT
        When "C","D" : Gosub GEST_FLGREL
      Endcase
Endcase
  Affzo [M:CVR2]
Return

$CONTROLE
  If GSTATUT<>GSTAOK or OK=0 Then
      FIN = 1
  Else
    TMP = 0
    TRA = 1
  Endif
Return

$DEBUT
If BOITE = "CEVREL2"
  Gosub INIT_CEVREL2
  Affzo [M:CVR2]NBLIG
Else
    If !func IS_PRHACTIF
      Chgfmt [M:DIA]STASTR With "-K:10947"
      Chgfmt [M:DIA]STAEND With "-K:10947"
    Endif
    If dim([M:DIA]LEG)>0 Then GCURLEG = [M:DIA]LEG : Endif
  Affzo [M:DIA]
Endif
Return

$OK
Local Char     TMP_MAT(60)
Local Char     TMP_NAM(60)
Local Integer  SAISIE,VALIDE, TMP_VAL
Local Integer  W_GENERATE
Local Integer  LOK,INOL
Local Char     PREF(250), NOMPROG(GLONADC), CODE(GLONAWA)
Local Char     USRWRK(GLONAUS), MAIWRK(GLONMAI)
Local Char     TEXOBJ(250), OBJJOI(20), CLEJOI(250), CONTXT(250)
Local Shortint DIMCLB : DIMCLB = func AWRK.DIMCLB : # Taille des blobs
Local Shortint DIMJOI : DIMJOI = 50          : # Nb maxi de pièces jointes
Local Shortint DIMUSR : DIMUSR = 50          : # Nb maxi de destinataires (principal+copie)
Local Integer  USR_SUIVI(1..DIMUSR) , USR_ENVOI(1..DIMUSR) , USR_DEL(1..DIMUSR)
Local Char     USR_EMAIL(GLONMAI)(1..DIMUSR)
Local Clbfile  TEXCLB(DIMCLB)
Local Integer  ERD, USR_NB, NBJOI
Local Char     PCEJOI(200)(1..DIMJOI), CHRONO(GLONVCR)
Local Char     LTEXT(250)(1..)
Local Integer  IT
#Local Clbfile  LTEXT
#LIPET - 2017-10-24 - X3-29327 - START
Local Date   WDATSTR, WDATEND
#LIPET - 2017-10-24 - X3-29327 - END

  If clalev([F:EVE])=0  : Local File EVAEMP     [EVE]  : Endif
  If clalev([F:AWA])=0  : Local File AWRKPAR    [AWA]  : Endif
  If clalev([F:AWG])=0  : Local File AWRKHISMES [AWG]  : Endif
  If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
  If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif

  If BOITE = "CEVREL2"
    [M:DIA]FLGRET=1
    Local Integer NB_REL
    Local Char L_CAMP(30)
    L_CAMP=[M:CVR2]ZCODCEV
    If([M:CVR2]ZCODCEV="") :L_CAMP=[M:CVR2]CODCEV :Endif
    Call OUVRE_TRACE(mess(127,10720,1)) From LECFIC

    Call ECR_TRACE(TIT- L_CAMP,0) From GESECRAN
    Call ECR_TRACE(mess(63,10720,1)- [M:CVR2]ZEVATYP-mess(190,10726,1)-format$("D:"+GFMDAT4,STRDAT)-mess(95,100,1)-format$("D:"+GFMDAT4,ENDDAT),0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN


    Sorta NBLIG [M]NBLIG Order By VALSRN(indice),VALREFNUM(indice),EVAVAL(indice),SRN(indice),REFNUM(indice),CTRNUM(indice) #,DEM(EVAVAL)

    USRWRK  = GUSER  : # User qui déclenche le workflow
    USR_NB  = 1

# If GUSER='MABON' Dbgaff Endif
    Local Char SEP(10) : SEP=""
    Local Char W_TEMP(150)
    TMP_MAT="" : TMP_VAL=0 : IT=1
    For nolign=1 To [M:CVR2]NBLIG
      If [M:CVR2]FLGREL(nolign-1)=2 Then
        If [M:CVR2]VALREFNUM(nolign-1)<>TMP_MAT or [M:CVR2]EVAVAL(nolign-1)<>TMP_VAL Then
          If TMP_MAT<>"" Then
            Gosub WORKFLOW
            Raz SAISIE,VALIDE
          Endif
          Raz LTEXT
          SEP=""
          IT=1 #: LTEXT(IT)=""
          TMP_MAT=[M:CVR2]VALREFNUM(nolign-1)
          TMP_NAM=[M:CVR2]VALSRN(nolign-1)
          TMP_VAL=[M:CVR2]EVAVAL(nolign-1)
          If [M:CVR2]EVAVAL(nolign-1)=1 Then
            CODE="EVAREL1"
          Elsif [M:CVR2]EVAVAL(nolign-1)=2 Then
            CODE="EVAREL2"
          Elsif [M:CVR2]EVAVAL(nolign-1)=3 Then
            CODE="EVAREL3"
          Endif
          Call SET_PREF(CODE,PREF) From SUBAWA
          NOMPROG = PREF+CODE
          # Ordre de lecture de la table principale
          Gosub ORDREF From =NOMPROG
          Read [F:AWA]AWA0=CODE
          ERD     = ([F:AWA]DEBUG=2)
          GRPENV  = ([F:AWA]GRPENV=2)
          INOL=nolign-1
        Endif
#LIPET - 2017-10-24 - X3-29327 - START
        WDATSTR=[M:CVR2]EVADATSTR(nolign-1)
        WDATEND=[M:CVR2]EVADATEND(nolign-1)
#        Read [F:EVE]EVE0=[M:CVR2]REFNUM(nolign-1);[M:CVR2]CTRNUM(nolign-1);[M:CVR2]STRDAT;[M:CVR2]ENDDAT;[M:CVR2]EVATYP
        Read [F:EVE]EVE0=[M:CVR2]REFNUM(nolign-1);[M:CVR2]CTRNUM(nolign-1);WDATSTR;WDATEND;[M:CVR2]EVATYP
#LIPET - 2017-10-24 - X3-29327 - END
        Read [F:ID]ID0=[M:CVR2]REFNUM(nolign-1)
        If [M:CVR2]EVAVAL(nolign-1)<>2 Then
          W_TEMP="-"-[M:CVR2]SRN(nolign-1)-"("+[M:CVR2]CTRNUM(nolign-1)
          If [M:CVR2]CTRDAT(nolign-1)<>[0/0/0] Then
            W_TEMP-=format$(GFMD,[M:CVR2]CTRDAT(nolign-1))
          Endif
          W_TEMP+=")"
          If(len(LTEXT(IT))+len(W_TEMP)>250 and IT<10)
             IT+=1
             SEP=""
          Endif
          LTEXT(IT)+=SEP+W_TEMP
          SEP=chr$(10)+chr$(13)
        Else
          # add ctr+dat only for trace
          LTEXT(1)="("+[M:CVR2]CTRNUM(nolign-1)
          If [M:CVR2]CTRDAT(nolign-1)<>[0/0/0] Then
            LTEXT(1)-=format$(GFMD,[M:CVR2]CTRDAT(nolign-1))
          Endif
          LTEXT(1)+=")"
        Endif

        If [M:CVR2]EVAVAL(nolign-1)=1 Then
          SAISIE+=1
        Else
          VALIDE+=1
        Endif
      Endif
    Next
    Gosub WORKFLOW
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE((num$(NB_REL)-tolower(mess(128,10720,1))),0) From GESECRAN
    Call FERME_TRACE From LECFIC
    # Fermeture de la fenêtre "Opération en cours"
    Call TEMPOFF From GESECRAN
    # Lecture de la trace, sinon avec SAI=1 plus bas, on ne la voit pas
    Call LEC_TRACE From LECFIC
  Endif
Return

$WORKFLOW
  NB_REL+=1
Local Char    SAVABR (GLONAOB), SAVFONC(GLONAFC)
Local Char    GRPDEB(250), GRPW(20)
Local Char    CLECUR2(30)(1..4)
Local Char    FORMULE(255)
Local Integer ERN, DIFFERE, STAT
Local Char    CPTWRK(GLONANM)

  SAVABR  = GABREV    : GABREV    = "EVA"
  SAVFONC = GFONCTION : GFONCTION = "GESEVA"
  USR_EMAIL(1)=[M:CVR2]VALEML(INOL) : USR_ENVOI(1)=2
#  CHRONO = [M:CVR2]CHRONO(INOL)
  CPTWRK = func SUBTCA.NAMCPT(1,2) : # Compteur chrono ligne

  # Attribution du chrono ligne
  If !adxlog
    Trbegin ADOVAL
    Call NUMERO(CPTWRK,"",date$,"",CHRONO,STAT) From SUBANM
    Commit
  Else
    Call NUMERO(CPTWRK,"",date$,"",CHRONO,STAT) From SUBANM
  Endif
  DIFFERE   = 0
  Gosub DISPLAY_TRACE
  Gosub TRT_TEXTE From AWRK
  Gosub TRT_MAIL  From AWRK

  GABREV = SAVABR   : GFONCTION=SAVFONC
  If !GOK           : # ne peut arriver que si le workflow est en mode débug
    GERR=1
    GMESSAGE=mess(7,21,1)-mess(1,75,1) : # Erreur Workflow
  Endif
Return

$DISPLAY_TRACE
Local Char W_TXT(30)
  If(TMP_VAL=1)
    W_TXT=mess(130,10720,1)
  Else
    W_TXT=mess(129,10720,1)
  Endif
  If(TMP_VAL=2)
    Call ECR_TRACE(W_TXT-TMP_NAM -LTEXT(1),0) From GESECRAN
    Raz LTEXT
  Else
    Call ECR_TRACE(W_TXT-TMP_NAM,0) From GESECRAN
  Endif
  Local Integer WI
  # var temp : raz var => var is not empty so we add blank line.
  # call ECR_TRACE( LTEXT(WI),0) is not ok. the supervisor take all indice)
  Local Char W_TMPTRA(255)
  For WI=1 To 10
    If(LTEXT(WI)="")
     Break
    Else
     W_TMPTRA=LTEXT(WI)
     If(WI>1)
      # on ajoute retour ligne pour mail
      LTEXT(WI)=chr$(10)+chr$(13)+LTEXT(WI)
     Endif
    Endif
    Call ECR_TRACE(W_TMPTRA,0) From GESECRAN
  Next WI
  Call ECR_TRACE("",0) From GESECRAN
Return

$DISPINFO
#Infbox( TMP_NAM+"("+TMP_MAT+")" -"---Saisie :"-num$(SAISIE)-"---Valide"- num$(VALIDE))
Return


$EXEC
# flag pour savoir si on laisse la fenêtre ouverte ou si on ferme la fonction
If([M:DIA]FLGRET)=1
  FIN=1
Else
  SAI=1
Endif
[M:DIA]FLGRET=0
Return

$FIN

Return

######################################################################################
## Functions
######################################################################################


######################################################################################
## Récupération du nom de fichier de ref pour les controles des champs
######################################################################################
Funprog GETNAMFIC
End "GENCEV"

######################################################################################
## Récupération du code user à partir du refnum
######################################################################################

Funprog GET_CODUSER(VALEUR)
Value Char VALEUR()
If clalev([F:ADU])=0 : Local File ADOVALAUS [ADU] : Endif
 Filter [F:ADU] Where PARAM='REFNUM' & VALEUR=[L]VALEUR Order By CODUSR
 If rowcount([F:ADU])>0 Then
    Read [F:ADU] First
    Filter [F:ADU]
    End [F:ADU]CODUSR
  Endif
End ""
######################################################################################
## Récupération des adresses mails comme le moniteur workflow
######################################################################################

Funprog GET_EMAIL(USR,MAT)
Value Char USR
Value Char MAT
Local Char RES(60)
If(USR="")
  #RES="#1"
  RES=func DIVPAYE.GETEML(MAT)
Else
  RES=func AWRKB.USERMAIL(USR)
Endif
If(RES="") : RES="#2" :Endif
End RES
######################################################################################
## Vérification des critères de sélection et positionnement de la vue des workflows
######################################################################################

Funprog CHECKOK_EVA
Local Integer RES : RES=0
RES=[F:EV1_]EVALIB<>""

End RES

Funprog LIBTYPEVA(TYPEVA)
Value Char TYPEVA
Local Char LIB(80)

  If clalev([F:AXX_])=0 : Local File ATEXTRA [AXX_] : Endif
  Read [F:AXX_]AXX0="ATABDIV";"LNGDES";GLANGUE;"464";TYPEVA
  If !fstat Then
    LIB=[F:AXX_]TEXTE
  Endif
End LIB

######################################################################################
## Etiquettes
######################################################################################
$GEST_FLGREL
Local Integer WI
If(BOUT="D")
  For WI=0 To [M]NBLIG-1
    [M]FLGREL(WI)=1
  Next
Else
  For WI=0 To [M]NBLIG-1
    [M]FLGREL(WI)=[M]FLGOK(WI)
  Next
Endif
Affzo [M]
Return
######################################################################################
## Initialisation de la fenêtre de critères
######################################################################################

$INIT_CEVREL
    [M:DIA]CODCEV = [F:CEV]COD
    [M:DIA]ALLCPY=2 : [M:DIA]CPY="" : If [F:CEV]CPYCEV<>"" Then [M:DIA]ALLCPY=1 : [M:DIA]CPY=[F:CEV]CPYCEV : Endif
    [M:DIA]ALLFCY=2 : [M:DIA]FCY="" : If [F:CEV]FCYCEV<>"" Then [M:DIA]ALLFCY=1 : [M:DIA]FCY=[F:CEV]FCYCEV : Endif
    [M:DIA]ALLSRV=2 : [M:DIA]SRV="" : If [F:CEV]SRVCEV<>"" Then [M:DIA]ALLSRV=1 : [M:DIA]SRV=[F:CEV]SRVCEV : Endif
    #Gestion législation
    [M:DIA]WLEG=[F:CEV]LEG
    GCURLEG=[F:CEV]LEG
     If GCURLEG="" & [M:DIA]CPY<>"" Then
      Read [F:CPY]CPY0=[M:DIA]CPY
      If !fstat Then
        Call LEG_CPY([M:DIA]CPY,GCURLEG) From =func GETNAMFIC

      Endif
      If GCURLEG="" & [M:DIA]FCY<>"" Then
        Read [F:FCY]FCY0=[M:DIA]FCY
        If !fstat Then
           Read [F:CPY]CPY0=[F:FCY]LEGCPY
           If !fstat Then
              GCURLEG = [F:FCY]LEG
           Endif
        Endif
      Endif
    Endif
    If dim([M:DIA]LEG)>0 Then [M:DIA]LEG=GCURLEG : Endif
    Local Char LEGAXX(8)
    LEGAXX=[F:CEV]LEG
    Call LECTEXTRA([M:DIA]PRFDES,"PROFIL","PRFDES",LEGAXX,[M:DIA]PRF) From ATEXTRA
    [M:DIA]POP    = [F:CEV]POPCEV
    [M:DIA]PRF    = [F:CEV]PRFCEV

    [M:DIA]POT    = [F:CEV]POTCEV
    [M:DIA]JOBPOT = [F:CEV]JOTCEV

    [M:DIA]EVATYP = [F:CEV]EVATYP
    [M:DIA]STRDAT = [F:CEV]STRDAT
    [M:DIA]ENDDAT = [F:CEV]ENDDAT

    If !func IS_PRHACTIF
      Chgfmt [M:DIA]STASTR With "-K:2410"
      Chgfmt [M:DIA]STAEND With "-K:2410"
    Endif
    Raz [M]MATSTR,[M]MATEND, [M]CRI

Return
######################################################################################
## Initialisation de la fenêtre de résultats
######################################################################################

$INIT_CEVREL2
     Raz [M:CVR2]
    [M:CVR2]CODCEV = [F:CEV]COD
    [M:CVR2]EVATYP = [F:CEV]EVATYP
    [M:CVR2]STRDAT = [F:CEV]STRDAT
    [M:CVR2]ENDDAT = [F:CEV]ENDDAT
    If GOK = 1 Then
      Gosub CALC_FLUX
      Gosub CALC_CRIT
      Gosub LOAD_RESULT
      Gosub ADD_STYLEERR
#LIPET - 2017-10-24 - X3-29327 - START
      If [M:DIA]PREEVA =2
        Chgtzn[M:CVR2]STRDAT With mess(156,10720,1) : # "Prochain entretien déb."
        #TODO pas en V6
        Chgtzn[M:CVR2]ENDDAT With mess(157,10720,1) : # "Prochain entretien fin"
      Endif
#LIPET - 2017-10-24 - X3-29327 - END
    Endif
Return
######################################################################################
## Calcul du flux
######################################################################################

$CALC_FLUX
  Local Char FLUX(30)
  Local Integer WNIVMGR(0..30),NIV
  #Récupération du nom du flux
  Call PARAM("","FLXPOREVA",[L]FLUX) From ADOVAL
  #Récupération du type de manager
  Call GET_TTYPMGR([L]FLUX, [L]WNIVMGR) From DIVPAYE
Return

######################################################################################
## Application eds critères
######################################################################################

$CALC_CRIT
Local Char LIS_CPY(GLONCPY)(0..100)
Local Clbfile CRITERE1(2)
Local Char CRITERE2(250)
CRITERE1="1=1"
  If [M:DIA]ALLCPY<>2 Then
    I=0 : Call CALC_GRPCPY([M:DIA]CPY, LIS_CPY, I) From TOOLSVAR
    If I>0 Then
      CRITERE1 -= "& find([F:FCY]LEGCPY,"
      For K=0 To I-1
        CRITERE1 += "'"+LIS_CPY(K)+"'"
        If K<I-1 Then CRITERE1 += "," : Endif
      Next
      CRITERE1 += ")>0"
    Else
      If [M:DIA]CPY <> ""
        CRITERE1="1=2"
      Endif
    Endif
  Endif
  If [M:DIA]ALLFCY<>2       Then CRITERE1  -= "& [F:FCY]FCY='"+[M:DIA]FCY+"'"       : Endif
  If [M:DIA]ALLSRV<>2       Then CRITERE1  -= "& [F:HRCTR]ETRSRV='"+[M:DIA]SRV+"'"    : Endif

  If [M:DIA]POP<>""         Then CRITERE1  -= "& [F:HRPOA]COD='"+[M:DIA]POP+"'"       : Endif
  If [M:DIA]PRF<>""         Then CRITERE1  -= "& [F:HRCTR]PROPRF='"+[M:DIA]PRF+"'"    : Endif
  If [M:DIA]POT<>""         Then CRITERE1  -= "& [F:HRCTR]POT='"+[M:DIA]POT+"'"       : Endif
  If [M:DIA]JOBPOT<>""      Then CRITERE1  -= "& [F:HRCTR]JOBPOT='"+[M:DIA]JOBPOT+"'" : Endif
  If dim([M:DIA]LEG)> 0 & [M:DIA]LEG<>""  Then CRITERE1  -=  "& (find([F:FCY]LEG,'"+[M:DIA]LEG+"','')>0)" : Endif
  CRITERE2="[F:EVE]CEV ='"+ [M:DIA]CODCEV+"' & [F:EVE]EVAVAL>="+num$([M:DIA]STASTR)-" & [F:EVE]EVAVAL<="+num$([M:DIA]STAEND)
  If [M:DIA]MATSTR<>""      Then CRITERE2  -= "& [F:EVE]REFNUM>='"+[M:DIA]MATSTR+"'" : Endif
  If [M:DIA]MATEND<>""      Then CRITERE2  -= "& [F:EVE]REFNUM<='"+[M:DIA]MATEND+"'" : Endif

If [M:DIA]POP<>"" Then
#  Link [F:EVE] With [F:ID]ID0=[F:EVE]REFNUM, [F:HRCTR]CTR0=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT, [F:FCY]FCY0=[F:HRCTR]ETRFCY, [F:HRPOA]POA0=[M:DIA]POP;[F:ID]REFNUM  As [EV1_] Where evalue(
#& CRITERE1) &
#& evalue(CRITERE2)

  Link [F:EVE] With [F:ID]ID0=[F:EVE]REFNUM, [F:HRCTR]CTR0=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT, [F:FCY]FCY0=[F:HRCTR]ETRFCY, [F:HRPOA]POA0~=[M:DIA]POP;[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT
&  As [EV1_]
& Where evalue(CRITERE1) &
& evalue(CRITERE2)

Else
  Link [F:EVE] With [F:ID]ID0=[F:EVE]REFNUM, [F:HRCTR]CTR0=[F:EVE]REFNUM;[F:EVE]CTRNUM;[F:EVE]CTRDAT, [F:FCY]FCY0=[F:HRCTR]ETRFCY As [EV1_]Where evalue(CRITERE1) & evalue(CRITERE2)
Endif

Return

######################################################################################
## Chargement des résultats
######################################################################################
$LOAD_RESULT
Local Integer W_DIMTAB, W_IND,W_TABRES : W_DIMTAB=dim([M:CVR2]SRN)
Local Char W_MAT(30)(1..W_DIMTAB*2),W_USR(30)(1..W_DIMTAB*2),W_NAM(60)(1..W_DIMTAB*2),W_MAIL(90)(1..W_DIMTAB*2)
Local Integer W_FLGOK(1..W_DIMTAB*2)
Local Char TMP_MAT(30),TMP_USR(30)
Local Char TMP_MAIL(60)
Filter [EV1_] Where evalue(CRITERE1) & evalue(CRITERE2)
Local Char WNT(30) : WNT=mess(31,10720,1) : #"Evaluateur non renseigné"
Local Char WCTR(30)
For [EV1_]
 If(!func CHECKOK_EVA)
    If NBLIG=W_DIMTAB
      Call ERREUR(func AFNC.MES1(mess(132,10720,1),num$(W_DIMTAB))) From GESECRAN :#"Le nombre de notifications de relance dépasse la limite autorisée ($1$). Veuillez restreindre votre population"
      Break
    Endif
    [M]NBLIG+=1
    nolign = [M]NBLIG
    [M:CVR2]=[F:EV1_]
    TMP_MAT=[F:EV1_]REFNUM
    Gosub GET_INDEX_BYREFNUM
    [M:CVR2]SRN(nolign-1)= W_NAM(W_IND)
    [M:CVR2]EMLCOL(nolign-1)=W_MAIL(W_IND)
    If [F:EV1_]EVAVAL=2
     [M:CVR2]FLGOK(nolign-1)=W_FLGOK(W_IND)
     Endif
    #on renseigne manager
    #WCTR=[M:CVR2]CTRNUM(nolign-1)
    TMP_MAT=[F:EV1_]EVAMAT
    If(TMP_MAT="")
        [M:CVR2]MATREFNUM(nolign-1)=WNT
    Else
        [M:CVR2]MATREFNUM(nolign-1)=TMP_MAT
        Gosub GET_INDEX_BYREFNUM
        [M:CVR2]MATEML(nolign-1)=W_MAIL(W_IND)
        [M:CVR2]MATSRN(nolign-1)=W_NAM(W_IND)
    Endif
    If [F:EV1_]EVAVAL=1 or [F:EV1_]EVAVAL=3
        [M:CVR2]VALREFNUM(nolign-1)=[M:CVR2]MATREFNUM(nolign-1)
        [M:CVR2]VALEML(nolign-1)=[M:CVR2]MATEML(nolign-1)
        [M:CVR2]VALSRN(nolign-1)=[M:CVR2]MATSRN(nolign-1)
        If [M:CVR2]MATSRN(nolign-1)=""
          [M:CVR2]FLGOK(nolign-1)=1
        Else
          [M:CVR2]FLGOK(nolign-1)=W_FLGOK(W_IND)
        Endif
    Else
        [M:CVR2]VALREFNUM(nolign-1)=[M:CVR2]REFNUM(nolign-1)
        [M:CVR2]VALEML(nolign-1)=[M:CVR2]EMLCOL(nolign-1)
        [M:CVR2]VALSRN(nolign-1)=[M:CVR2]SRN(nolign-1)
    Endif
      #Read [F:CVRV]CVRV0=[F:EV1_]CTRNUM+"~"+[F:EV1_]REFNUM+"~"+format$("D:YYYYMMDD",[F:EV1_]EVADATSTR)+"~"+format$("D:YYYYMMDD",[F:EV1_]EVADATEND)+"~"+[F:EV1_]EVATYP
      #If !fstat
      [M:CVR2]FLGREL(nolign-1)=[M:CVR2]FLGOK(nolign-1)
  Endif
Next
  Sorta NBLIG [M]NBLIG Order By -FLGREL(indice),VALSRN(indice),VALREFNUM(indice),EVAVAL(indice),SRN(indice),REFNUM(indice),CTRNUM(indice)#,DEM(EVAVAL)
Affzo [M]
Filter [EV1_]
Return
######################################################################################
## Ajout style erreur
######################################################################################

$ADD_STYLEERR
Local Integer WI
Local Char X3NT(50),EMLNT(30)
X3NT=mess(122,10720,1)
EMLNT=mess(38,143,1)
Local Integer  ISPRH:
ISPRH= func IS_PRHACTIF
While(WI<NBLIG)
If [M:CVR2]FLGOK(WI)=1
 Chgstl NBLIG(WI) With "AERROR"
Else
 If(ISPRH and ([M:CVR2]EMLCOL(WI)=X3NT or [M:CVR2]EMLCOL(WI)=EMLNT))
    Chgstl [M:CVR2]EVAVAL(WI) With "AERROR"
    Chgstl [M:CVR2]EMLCOL(WI) With "AERROR"
  Endif
Endif
WI+=1
Wend

Return
######################################################################################
## return les infos à partir d'un refnum
######################################################################################

$GET_INDEX_BYREFNUM
W_IND=find(TMP_MAT,W_MAT(1..W_TABRES))
If!W_IND
  Gosub SET_INFOBYREFNUM
  W_IND=W_TABRES
Endif
Return
######################################################################################
## return les infos à partir d'un user x3
######################################################################################

$GET_INDEX_BYUSR
W_IND=find(TMP_USR,W_USR(1..W_TABRES))
If!W_IND
  Gosub SET_INFOBYUSR
  W_IND=W_TABRES
Endif
Return
######################################################################################
## ajout d'info à partir d'un refnum
######################################################################################

$SET_INFOBYREFNUM

W_TABRES+=1
W_MAT(W_TABRES)=TMP_MAT
W_USR(W_TABRES)=func PORSUP.EMPUSR(TMP_MAT,"")
W_NAM(W_TABRES)=func PRHUTIWEB.GETNOMEML(TMP_MAT,1)
TMP_MAIL=func GET_EMAIL(W_USR(W_TABRES),W_MAT(W_TABRES))
Gosub SET_MAIL
#W_MAIL(W_TABRES)=func GET_EMAIL(W_USR(W_TABRES))


Return
######################################################################################
## ajout d'info à partir d'un user x3
######################################################################################

$SET_INFOBYUSR
W_TABRES+=1
W_MAT(W_TABRES)=func PORSUP.EMPUSR("",TMP_USR)
W_USR(W_TABRES)=TMP_USR
W_NAM(W_TABRES)=func PRHUTIWEB.GETNOMEML(W_MAT(W_TABRES),1)
#TMP_MAIL=[F:CVRV]EMAIL
TMP_MAIL=func GET_EMAIL(W_USR(W_TABRES),W_MAT(W_TABRES))
Gosub SET_MAIL
Return
######################################################################################
## Translation d'adresse mail à partir du code reçu
######################################################################################

$SET_MAIL
Case TMP_MAIL
  When "#1" :
      W_FLGOK(W_TABRES)=1
      W_MAIL(W_TABRES)=mess(122,10720,1)  :#"Fiche utilisateur non renseignée"
  When "#2" :
      W_FLGOK(W_TABRES)=1
      W_MAIL(W_TABRES)=mess(38,143,1)   :#"Email non renseigné"
  When "" :
      W_FLGOK(W_TABRES)=1
      W_MAIL(W_TABRES)=mess(38,143,1)   :#"Email non renseigné"
 When Default :
      W_FLGOK(W_TABRES)=2
      W_MAIL(W_TABRES)=TMP_MAIL
Endcase
Return
######################################################################################
## code prh actif
######################################################################################

Funprog IS_PRHACTIF
Local Integer RES
RES=func AFNC.ACTIV("PRH")
End RES

