Subprog AS_AMTVAL98(VALEUR)
Variable Decimal VALEUR
Goto AS_AMTVAL
Subprog AS_AMTVAL99(VALEUR)
Variable Decimal VALEUR
Goto AS_AMTVAL

$AS_AMTVAL
Local Integer COL
COL = val(right$(zoncou,7))
If COL>[M:TXM2]NBRCOL #| [M]INTIT(nolign-1)=""
 VALEUR = 0 : mkstat = 2
 End
Endif
Inftxt evalue("[M:TXM3]FRM"+num$(COL)+"(nolign-1)") At 1
#
# Tant que le client ne gérera pas le format par cellule
#
Local Char    FMT(30)
Local Integer IC , IL
IC = COL
IL = nolign
If mid$([M:TXM3]DEC(IL-1),IC,1)<>"0"
  FMT = "N3z:14."+mid$([M:TXM3]DEC(IL-1),IC,1)+"#"
Else
  FMT = "N3z:14#"
Endif
Gosub FORMAT_CELLULE From SUBTXW
#
Local Char    FORMULE(80) , FONC(10)
Local Integer ANA , J , K
Raz GBOUT1, GBOUT2
FORMULE = evalue("[M:TXM3]FRM"+num$(COL)+"(nolign-1)")
If left$(FORMULE,1)="-" : FORMULE = right$(FORMULE,2) : Endif
If left$(FORMULE,1)="["
 K = instr(1,FORMULE,"]")
 If K : FORMULE = right$(FORMULE,K+1) : Endif
Endif
If find(left$(FORMULE,1),"C","D")   : FORMULE = right$(FORMULE,2) : Endif
If find(left$(FORMULE,2),"MC","MD") : FORMULE = right$(FORMULE,3) : Endif
ANA = 0
For FONC="NM","NQ","EM","EQ","PM","PQ","GM","GQ","UM","UQ"
 If left$(FORMULE,len(FONC))=FONC or left$(FORMULE,len(FONC)+1)="-"+FONC
  ANA = 1 : Break
 Endif
Next FONC
If ANA
 GBOUT2 = mess(31,124,1)   :# écran de détail analytique
Else
 GBOUT1 = mess(31,124,1)
Endif
End

