Subprog AM_AMTVAL99(VALEUR)
Variable Decimal VALEUR
Local Integer IC
IC = 99 : Goto AM_AMTVAL

$AM_AMTVAL
Local Integer IL
IL = nolign
Read [TXM]TXM0 = [M:TXM0]TXSNAM;[M:TXM0]VERSION;IL;IC;0
Read [TXD]TXD0 = [M:TXM0]TXSNAM;IL;IC
[M]UPDCOL(IL-1) = func SUBTXS.REPCAR([M]UPDCOL(IL-1),"1",IC)
End

If VALEUR=0 | VALEUR=val([F:TXM]AMTVAL)
 [M]UPDCOL(IL-1) = func SUBTXS.REPCAR([M]UPDCOL(IL-1),"0",IC)
 VALEUR = val([F:TXM]AMTVAL)
Else
 [M]UPDCOL(IL-1) = func SUBTXS.REPCAR([M]UPDCOL(IL-1),"1",IC)
Endif
End

