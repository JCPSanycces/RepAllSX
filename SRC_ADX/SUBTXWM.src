#<AdxTL>@(#)12.0.0.0 $Revision$

Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

###############################################################
$ACTION
Case ACTION
 When "BB1_TXSNAM" : mkstat = 4
Endcase
Return

###############################################################
## Ecran TXSM0
###############################################################
Subprog C_TXSNAM(VALEUR)
Variable Char    VALEUR()
Read [TXS]TXS1 = VALEUR
If fstat
 GMESSAGE = mess(23,100,1)   :# Fiche inexistante
 mkstat = 2
Else
 If ([F:TXS]NBRCOL>20 & GFLAG="LIMIT") or ([F:TXS]NBRCOL<=20 & GFLAG="NOLIMIT")
  # Accès impossible à cette fiche
  GMESSAGE = mess(8,123,1) : mkstat=2 : End
 Endif
 [M]LSTGRP = [F:TXS]LSTGRP
 Call LECTEXTRA([M]TXSDES,"TXSA","TXSDES",[F:TXS]TXSNAM,"") From ATEXTRA
 Affzo TXSDES
 If VALEUR<>[M]TXSNAM
  Effzo [M]VERSION, VERDES
 Endif
Endif
End

Subprog C_VERSION(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Look [TXW]TXW1 = [M]TXSNAM;VALEUR
 If fstat
  GMESSAGE = mess(23,100,1)   :# Fiche inexistante
  mkstat = 2
 Endif
Endif
End

###############################################################
## Ecran TXSM1
###############################################################
Subprog AS_NBLIG
If nolign>[M]NBLIG
 mkstat = 2
Endif
End

Subprog AS_INTIT(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End

