$AV_AMTVAL
If [M]SAICOL(IC-1)=2
 Local Integer IL
 Local Char    FMT(30)
 IL = nolign
 If mid$([M:TXM3]DEC(IL-1),IC,1)<>"0"
  FMT = "NP3z:14."+mid$([M:TXM3]DEC(IL-1),IC,1)+"#"
 Else
  FMT = "NP3z:14#"
 Endif
 Gosub FORMAT_CELLULE From SUBTXW
Endif
End


