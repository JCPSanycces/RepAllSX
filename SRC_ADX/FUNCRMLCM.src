#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# Gestion resynchronisation des encours                           module  CRM aout 2006
##########################################################################################################
##########################################################################################################
$ACTION
  #--- Actions liées au traitement standard 
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE_BATCH" : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
    When Default
  Endcase
  #--- Actions liées à la fenêtre de saisie 
  Case ACTION
    When "DEBUT"      : Gosub DEBUT
    When "OK"         : GOK = 1
    When "END"        : GOK = 0 : FIN = 1
    When Default
  Endcase
Return

##########################################################################################################
$DEBUT
  If [M]TOUSOC = 2 Then
    Grizo [M]SOC
  Else
    Actzo [M]SOC
  Endif
  If [M]TOUCLIENT = 2 Then
    Grizo [M]CLIENT
  Else
    Actzo [M]CLIENT
  Endif
  Affzo [LCMA]1-99
Return

##########################################################################################################
$INIT
Local Char TIT(50)

  If GMODU(12) = 2 or GMODU(13) = 2 Then
    # En batch, il vaut mieux mettre onerrgo
    If GSERVEUR Then
      Onerrgo ERRBATCH
    Endif
    #Synchronisation des en-cours
    TIT = mess(446,177,1)
  Else
    # Le module Action commerciale n'est pas activé. Fonction inaccessible.
    GMESSAGE = mess(243,177,1)
    GERR = 2
    FIN = 1
    Return
  Endif
  # Chargement de l'écran en fonction des habilitations #
  # --------------------------------------------------- #
  Local Mask CRMLCM [LCMA]
  Raz [M:LCMA]
  [M]TOUSOC = 2 # FGR 07/08/2009 : X3SUIVI56992 remplacement [M]TOUSOC = 1
  If GUSRFCY(1) <> "\" and GNBAUZ <> GNBSITE Then
    [M:LCMA]TOUSOC = 1 
    Grizo [M:LCMA]TOUSOC
  Endif
  If [M]TOUSOC = 1 Then
    Call INICPY([M]SOC) From CPTSUB
    GSOCIETE = [M]SOC
  Else
    Raz GSOCIETE
  Endif
  [M]TOUCLIENT = 2
  [M]TRACE = 2
  Call LECMEMO ("STD", "[M:LCMA]", "ru1") From GMEMO
Return

##########################################################################################################
$INIT_DIA
  # --------------------------------------------------- #
  # Chargement de l'écran en fonction des habilitations #
  # --------------------------------------------------- #
  Local Mask CRMLCM [LCMA]
  Raz [M:LCMA]
  [M:LCMA]TOUSOC = 1
  If GUSRFCY(1) <> "\" and GNBAUZ <> GNBSITE Then
    [M:LCMA]TOUSOC = 1 
    Grizo [M:LCMA]TOUSOC
  Endif
  If [M]TOUSOC = 1 Then
    Call INICPY([M]SOC) From CPTSUB
    GSOCIETE = [M]SOC
  Else
    Raz GSOCIETE
  Endif
  [M]TOUCLIENT = 2
  [M]TRACE = 2
  Call LECMEMO ("STD","[M:LCMA]","ru1") From GMEMO
  Affzo [M:LCMA]1-99
Return

##########################################################################################################
$CONTROLE
  If GOK < 1 Then
    FIN = 1
    Return
  Else 
    TMP = 1
  Endif 
  If [M]TOUSOC = 1 Then
    If [M]SOC = "" Then
      # Il faut renseigner la société
      GMESSAGE = mess(451,177,1)
      GERR = 1
      SAI = 1
    Endif
  Endif
  If [M]TOUCLIENT = 1 Then
    If [M:LCMA]CLIENT = "" Then
      # Il faut renseigner le client
      GMESSAGE = mess(452,177,1)
      GERR = 1
      SAI = 1
    Endif
  Endif
Return

##########################################################################################################
$EXEC
Local Integer IBERROR

  IBERROR = 0
  If !GSERVEUR Then
    If [M:LCMA]TRACE = 2 Then
      # Ouverture de la trace
      Call OUVRE_TRACE(TIT) From LECFIC 
      Call ECR_TRACE(" ",0) From GESECRAN
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
      Call PRTSCR("CRMLCM","LCMA","",0,1) From ATRTX3
      Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
      Call ECR_TRACE(" ",0) From GESECRAN 
    Endif
  Endif
  Call ALIMENTE_LCM (nomap, [M:LCMA]TOUSOC, [M:LCMA]SOC, [M:LCMA]TOUCLIENT, [M:LCMA]CLIENT, IBERROR)
Return

##########################################################################################################
$OUVRE_TABLES
  #Ouvre les fichiers utilisés dans l'affichage des données de synchronisation
  Local File =SZAPPLI+".BPARTNER" [BPR]
  Local File =SZAPPLI+".LASTCUSMVT" [LCM]
  Local File =SZAPPLI+".FACILITY" [FCYC]      # FGR 11/08/2009 : X3SUIVI57005
  #
  Local File =SZAPPLI+".FACILITY" [FCY]       # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".TASK" [TSK6]          # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".PHONECALL" [CLL6]     # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".BAPPOINT" [BAP6]      # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".SERREQUEST" [SRE6]    # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".INTERVEN" [ITN6]      # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".OPPOR" [OPP6]         # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".CONTSERV" [CON6]      # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  #
  # FGR 11/08/2009 : X3SUIVI57005 Optimisation
  Local File =SZAPPLI+".TASK" [TSKO]
  Local File =SZAPPLI+".PHONECALL" [CLLO]
  Local File =SZAPPLI+".BAPPOINT" [BAPO]
  Local File =SZAPPLI+".SERREQUEST" [SREO]
  Local File =SZAPPLI+".INTERVEN" [ITNO]
  Local File =SZAPPLI+".OPPOR" [OPPO]
  Local File =SZAPPLI+".CONTSERV" [CONO]
  #
  ICNT_TSKO = rowcount([TSKO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_CLLO = rowcount([CLLO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_BAPO = rowcount([BAPO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_SREO = rowcount([SREO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_ITNO = rowcount([ITNO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_OPPO = rowcount([OPPO])                # FGR 11/08/2009 : X3SUIVI57005
  ICNT_CONO = rowcount([CONO])                # FGR 11/08/2009 : X3SUIVI57005
  #
  Local File =SZAPPLI+".COMPANY" [CPYX]       # FGR 11/08/2009 : X3SUIVI57005
Return

##########################################################################################################
Subprog ALIMENTE_LCM (SZAPPLI, ITOUSOC, SZCPY, ITOUCLIENT, SZCLIENT, IERROR)
Value Char SZAPPLI
Value Integer ITOUSOC
Value Char SZCPY
Value Integer ITOUCLIENT
Value Char SZCLIENT
Variable Integer IERROR

Local Integer INBRECORD
Local Integer ICOUNT
Local Integer IOK
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Shortint COMPTEUR, STOP
Local Char CLE2(GLONBPN), CRITERE(90)
Local Integer IBERROR
Local Char SZWHERE (250)
Local Char CRITERE (250)
Local Integer WFOR_CPY
Local Integer WNB_CPY_TRT
Local Char WTB_FCY(GLONFCY)(1..1000) # FGR 11/08/2009 : X3SUIVI57005
Local Integer WFOR_FCY               # FGR 11/08/2009 : X3SUIVI57005
Local Integer WNB_FCY_TRT            # FGR 11/08/2009 : X3SUIVI57005
Local Integer WIFLO                  # FGR 11/08/2009 : X3SUIVI57005

Local Integer ICNT_TSKO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_CLLO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_BAPO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_SREO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_ITNO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_OPPO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICNT_CONO              # FGR 11/08/2009 : X3SUIVI57005

Local Integer IFCY_TSKO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_CLLO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_BAPO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_SREO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_ITNO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_OPPO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer IFCY_CONO(1..1000)     # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_TSKO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_CLLO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_BAPO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_SREO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_ITNO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_OPPO              # FGR 11/08/2009 : X3SUIVI57005
Local Integer ICPY_CONO              # FGR 11/08/2009 : X3SUIVI57005

  IERROR = 0
  #
  INBRECORD = 0
  ICOUNT = 0
  IOK = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Raz COMPTEUR, CLE2, STOP
  IBERROR = 0
  WFOR_CPY = 0
  WNB_CPY_TRT = 0
  Raz SZWHERE
  Raz CRITERE
  #
  Gosub OUVRE_TABLES
  #
  SZWHERE = " ([F:LCM]IFFTYP=1 or [F:LCM]IFFTYP=2 or [F:LCM]IFFTYP=3 or [F:LCM]IFFTYP=11 or [F:LCM]IFFTYP=12 or [F:LCM]IFFTYP=13 or [F:LCM]IFFTYP=14)"
  #suppression des données
  If ITOUSOC = 1 and SZCPY <> "" Then
    SZWHERE = SZWHERE - "and [F:LCM]CPY=SZCPY "
  Endif
  If ITOUCLIENT = 1 and SZCLIENT <> "" Then
    SZWHERE = SZWHERE - "and [F:LCM]BPCNUM=SZCLIENT "
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [LCM]
  Delete Where evalue(SZWHERE)
  If fstat <> 0 Then
    #Erreur lors de la suppression des données
    IERROR = 1
    Call ECR_TRACE(mess(449,177,1), 1) From GESECRAN
    Rollback
    End
  Else
    Commit
    # ------------------------------------------------
    # Chargement du tableau des sociétés selon les cas
    If ITOUSOC = 1 and SZCPY <> "" Then
      # Cas UNE SOCIETE
      Local Char WTB_CPY(GLONCPY)(1..1)
      #
      Raz WTB_CPY
      WNB_CPY_TRT = 1
      WTB_CPY(1) = SZCPY
    Elsif ITOUSOC = 1 and SZCPY = "" Then
      # Cas plutot anormal : comme ça on ne fait rien
      Local Char WTB_CPY(GLONCPY)(1..1)
      #
      WNB_CPY_TRT = 0
      Raz WTB_CPY
    Elsif ITOUSOC = 2 Then
      # Cas TOUTES LES SOCIETES
      If SZAPPLI = nomap Then
        # Cas lancement depuis l'application
        Local Char WTB_CPY(GLONCPY)(1..GNBSOC)
        #
        WNB_CPY_TRT = GNBSOC
        Raz WTB_CPY
        For WFOR_CPY = 1 To WNB_CPY_TRT
          WTB_CPY(WFOR_CPY) = GSOC(WFOR_CPY)
        Next WFOR_CPY
      Else
        # Cas lancement dans procédure de migration
        WNB_CPY_TRT = 0
        For [CPYX]
          WNB_CPY_TRT += 1
        Next
        #
        Local Char WTB_CPY(GLONCPY)(1..WNB_CPY_TRT)
        #
        WFOR_CPY = 0
        Raz WTB_CPY
        For [CPYX]
          WFOR_CPY += 1
          WTB_CPY(WFOR_CPY) = [F:CPYX]CPY
        Next
      Endif
    Endif
    # ------------------------------------------------
    Raz SZWHERE
    SZWHERE = " ([F:BPR]BPCFLG=2 or [F:BPR]PPTFLG=2) "
    If ITOUCLIENT = 1 and SZCLIENT <> "" Then
      SZWHERE = SZWHERE - "and [F:BPR]BPRNUM=SZCLIENT "
    Endif
    # ------------------------------------------------
    Filter [BPR] Where evalue(SZWHERE)
    If !GSERVEUR Then
      INBRECORDTRT = rowcount([BPR]) * WNB_CPY_TRT
      # Synchronisation des en-cours
      Call OUVRE_BOITE(mess(446,177,1), INBRECORDTRT) From GESECRAN
      # num$(INBRECORDTRT) clients et prospects à traiter
      Call ECR_TRACE(num$(INBRECORDTRT)+" "+mess(447,177,1), 0) From GESECRAN
    Endif
    Filter [BPR]
    ###############################
    For WFOR_CPY = 1 To WNB_CPY_TRT
      # FGR 11/08/2009 : X3SUIVI57005 on boucle sur les sites de la société (début)
      Raz IFCY_TSKO
      Raz IFCY_CLLO
      Raz IFCY_BAPO
      Raz IFCY_SREO
      Raz IFCY_ITNO
      Raz IFCY_OPPO
      Raz IFCY_CONO
      ICPY_TSKO = 0
      ICPY_CLLO = 0
      ICPY_BAPO = 0
      ICPY_SREO = 0
      ICPY_ITNO = 0
      ICPY_OPPO = 0
      ICPY_CONO = 0
      Raz WTB_FCY
      WNB_FCY_TRT = 0
      Filter [FCYC] Where [F:FCYC]LEGCPY = WTB_CPY(WFOR_CPY)
      For [FCYC]FCY0
        WNB_FCY_TRT += 1
        WTB_FCY(WNB_FCY_TRT) = [F:FCYC]FCY
        Gosub IS_ENREG_SITE
      Next
      Filter [FCYC]
      WNB_FCY_TRT += 1
      If 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
        WTB_FCY(WNB_FCY_TRT) = ""  # On ajoute ça en dernier pour le faire au niveau société après l'avoir fait au niveau des sites
      Endif
      IFCY_TSKO(WNB_FCY_TRT) = ICPY_TSKO
      IFCY_CLLO(WNB_FCY_TRT) = ICPY_CLLO
      IFCY_BAPO(WNB_FCY_TRT) = ICPY_BAPO
      IFCY_SREO(WNB_FCY_TRT) = ICPY_SREO
      IFCY_ITNO(WNB_FCY_TRT) = ICPY_ITNO
      IFCY_OPPO(WNB_FCY_TRT) = ICPY_OPPO
      IFCY_CONO(WNB_FCY_TRT) = ICPY_CONO
      # FGR 11/08/2009 : X3SUIVI57005 on boucle sur les sites de la société (fin)
      If ICPY_TSKO > 0 or ICPY_CLLO > 0 or ICPY_BAPO > 0 or ICPY_SREO > 0 or ICPY_ITNO > 0 or ICPY_OPPO > 0 or ICPY_CONO > 0 Then
        # Pas la peine de venir ici s'il n'y a rien au niveau société null part
        STOP = 0
        #-----------
        $BOUCLE_BPR_SP
        #-----------
        Call DEBTRANS From GLOCK
        Trbegin [LCM]
        Raz CRITERE
        If STOP = 1 Then
          CRITERE = SZWHERE - 'and [F:BPR]BPRNUM>"'+CLE2+'"'
          STOP = 0
        Else
          CRITERE = SZWHERE
        Endif
        Raz COMPTEUR
        Filter [BPR] Where evalue(CRITERE) Order By [F:BPR]BPRNUM Asc
        For [BPR] 
          If !GSERVEUR Then
            ICOUNT += 1
            Call AFF_BOITE("("+ WTB_CPY(WFOR_CPY) + ")" - [F:BPR]BPRNUM, ICOUNT, IOK) From GESECRAN
          Endif
          #Traitement du client/propect +" : "+[F:BPR]BPRNUM+ " ("+ WTB_CPY(WFOR_CPY) +")"
          Call ECR_TRACE(mess(448,177,1) - ":" - [F:BPR]BPRNUM - "("+ WTB_CPY(WFOR_CPY) + ")" ,0) From GESECRAN
          For WFOR_FCY = 1 To WNB_FCY_TRT
            If WTB_FCY(WFOR_FCY) <> "" and 0=1 Then # FLORENT ICI : SZFCY retiré de la clé pour le moment
              Gosub OPTIM_SITE
            Else
              Gosub OPTIM_SOCIETE
            Endif
            If WIFLO = 1 Then
              IBERROR = 0
              #On doit resynchroniser
              If IFCY_TSKO(WFOR_CPY) > 0 or IFCY_CLLO(WFOR_CPY) > 0 or IFCY_BAPO(WFOR_CPY) > 0 Then
                #Premier contact
                Call LCM_BPRFIRSTCNT ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
                #
                Call LCM_BPRLASTCNT ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
                #
                Call LCM_BPRNEXTCNT ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM + " / "  + WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
              Endif
              #
              If IFCY_SREO(WFOR_CPY) > 0 Then
                Call LCM_BPRLASTSRE ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
              Endif
              #
              If IFCY_ITNO(WFOR_CPY) > 0 Then
                Call LCM_BPRLASTITN ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
              Endif
              #
              If IFCY_OPPO(WFOR_CPY) > 0 Then
                Call LCM_BPRLASTOPP ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
              Endif
              #
              If IFCY_CONO(WFOR_CPY) > 0 Then
                Call LCM_BPRLASTCON ([F:BPR]BPRNUM, WTB_CPY(WFOR_CPY), WTB_FCY(WFOR_FCY), IERRINF, ICHAPTER, IBRETOUR) From TRTLCMCRM
                If IBRETOUR = 0 Then
                  Call ECR_TRACE(mess(IERRINF,ICHAPTER,1) - "(" + [F:BPR]BPRNUM - "/" - WTB_CPY(WFOR_CPY) + "/" + WTB_FCY(WFOR_FCY) + ")",0) From GESECRAN
                  IBERROR = 1
                Endif
              Endif
            Endif
          Next WFOR_FCY
          If IBERROR = 0 Then
            #"           " +données mises à jour
            Call ECR_TRACE("           " +mess(450,177,1),0) From GESECRAN
          Endif
          #
          COMPTEUR += 1
          If COMPTEUR > 49 Then
            CLE2 = [F:BPR]BPRNUM
            STOP = 1
            Break
          Endif
        Next
        Commit
        If STOP Then
          Goto BOUCLE_BPR_SP
        Endif
      Endif
    Next WFOR_CPY
  Endif
End

##########################################################################################################
$IS_ENREG_SITE
  If ICNT_TSKO > 0 Then
    Filter [TSKO] Where [F:TSKO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_TSKO(WNB_FCY_TRT) = rowcount([TSKO])
    Filter [TSKO]
  Endif
  If ICNT_CLLO > 0 Then
    Filter [CLLO] Where [F:CLLO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_CLLO(WNB_FCY_TRT) = rowcount([CLLO])
    Filter [CLLO]
  Endif
  If ICNT_BAPO > 0 Then
    Filter [BAPO] Where [F:BAPO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_BAPO(WNB_FCY_TRT) = rowcount([BAPO])
    Filter [BAPO]
  Endif
  If ICNT_SREO > 0 Then
    Filter [SREO] Where [F:SREO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_SREO(WNB_FCY_TRT) = rowcount([SREO])
    Filter [SREO]
  Endif
  If ICNT_ITNO > 0 Then
    Filter [ITNO] Where [F:ITNO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_ITNO(WNB_FCY_TRT) = rowcount([ITNO])
    Filter [ITNO]
  Endif
  If ICNT_OPPO > 0 Then
    Filter [OPPO] Where [F:OPPO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_OPPO(WNB_FCY_TRT) = rowcount([OPPO])
    Filter [OPPO]
  Endif
  If ICNT_CONO > 0 Then
    Filter [CONO] Where [F:CONO]SALFCY=WTB_FCY(WNB_FCY_TRT)
    IFCY_CONO(WNB_FCY_TRT) = rowcount([CONO])
    Filter [CONO]
  Endif
  ICPY_TSKO += IFCY_TSKO(WNB_FCY_TRT)
  ICPY_CLLO += IFCY_CLLO(WNB_FCY_TRT)
  ICPY_BAPO += IFCY_BAPO(WNB_FCY_TRT)
  ICPY_SREO += IFCY_SREO(WNB_FCY_TRT)
  ICPY_ITNO += IFCY_ITNO(WNB_FCY_TRT)
  ICPY_OPPO += IFCY_OPPO(WNB_FCY_TRT)
  ICPY_CONO += IFCY_CONO(WNB_FCY_TRT)
Return

##########################################################################################################
$OPTIM_SITE
  WIFLO = 0
  If WIFLO = 0 and IFCY_TSKO(WFOR_FCY) > 0 Then
    Filter [TSKO] Where [F:TSKO]TSKCMP=[F:BPR]BPRNUM and [F:TSKO]SALFCY=WTB_FCY(WFOR_FCY)
    For [TSKO]
      WIFLO = 1
      Break
    Next
    Filter [TSKO]
  Endif
  If WIFLO = 0 and IFCY_CLLO(WFOR_FCY) > 0 Then
    Filter [CLLO] Where [F:CLLO]CLLCMP=[F:BPR]BPRNUM and [F:CLLO]SALFCY=WTB_FCY(WFOR_FCY)
    For [CLLO]
      WIFLO = 1
      Break
    Next
    Filter [CLLO]
  Endif
  If WIFLO = 0 and IFCY_BAPO(WFOR_FCY) > 0 Then
    Filter [BAPO] Where [F:BAPO]APTCMP=[F:BPR]BPRNUM and [F:BAPO]SALFCY=WTB_FCY(WFOR_FCY)
    For [BAPO]
      WIFLO = 1
      Break
    Next
    Filter [BAPO]
  Endif
  If WIFLO = 0 and IFCY_SREO(WFOR_FCY) > 0 Then
    Filter [SREO] Where [F:SREO]SREBPC=[F:BPR]BPRNUM and [F:SREO]SALFCY=WTB_FCY(WFOR_FCY)
    For [SREO]
      WIFLO = 1
      Break
    Next
    Filter [SREO]
  Endif
  If WIFLO = 0 and IFCY_ITNO(WFOR_FCY) > 0 Then
    Filter [ITNO] Where [F:ITNO]BPC=[F:BPR]BPRNUM and [F:ITNO]SALFCY=WTB_FCY(WFOR_FCY)
    For [ITNO]
      WIFLO = 1
      Break
    Next
    Filter [ITNO]
  Endif
  If WIFLO = 0 and IFCY_OPPO(WFOR_FCY) > 0 Then
    Filter [OPPO] Where [F:OPPO]OPPCMP=[F:BPR]BPRNUM and [F:OPPO]SALFCY=WTB_FCY(WFOR_FCY)
    For [OPPO]
      WIFLO = 1
      Break
    Next
    Filter [OPPO]
  Endif
  If WIFLO = 0 and IFCY_CONO(WFOR_FCY) > 0 Then
    Filter [CONO] Where [F:CONO]CONBPC=[F:BPR]BPRNUM and [F:CONO]SALFCY=WTB_FCY(WFOR_FCY)
    For [CONO]
      WIFLO = 1
      Break
    Next
    Filter [CONO]
  Endif
Return

##########################################################################################################
$OPTIM_SOCIETE
  # -1 parce que le dernier est toujours à vide, exprès.
  If WNB_FCY_TRT-1 > 60 Then
    # Le find est limité à 60 valeurs différentes. Si ça dépasse on regarde juste si le tiers est utilisé qq part.
    Gosub OPTIM_TIERS
    Return
  Endif
  WIFLO = 0
  If WIFLO = 0 and IFCY_TSKO(WFOR_FCY) > 0 Then
    Filter [TSKO] Where [F:TSKO]TSKCMP=[F:BPR]BPRNUM and find([F:TSKO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [TSKO]
      WIFLO = 1
      Break
    Next
    Filter [TSKO]
  Endif
  If WIFLO = 0 and IFCY_CLLO(WFOR_FCY) > 0 Then
    Filter [CLLO] Where [F:CLLO]CLLCMP=[F:BPR]BPRNUM and find([F:CLLO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [CLLO]
      WIFLO = 1
      Break
    Next
    Filter [CLLO]
  Endif
  If WIFLO = 0 and IFCY_BAPO(WFOR_FCY) > 0 Then
    Filter [BAPO] Where [F:BAPO]APTCMP=[F:BPR]BPRNUM and find([F:BAPO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [BAPO]
      WIFLO = 1
      Break
    Next
    Filter [BAPO]
  Endif
  If WIFLO = 0 and IFCY_SREO(WFOR_FCY) > 0 Then
    Filter [SREO] Where [F:SREO]SREBPC=[F:BPR]BPRNUM and find([F:SREO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [SREO]
      WIFLO = 1
      Break
    Next
    Filter [SREO]
  Endif
  If WIFLO = 0 and IFCY_ITNO(WFOR_FCY) > 0 Then
    Filter [ITNO] Where [F:ITNO]BPC=[F:BPR]BPRNUM and find([F:ITNO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [ITNO]
      WIFLO = 1
      Break
    Next
    Filter [ITNO]
  Endif
  If WIFLO = 0 and IFCY_OPPO(WFOR_FCY) > 0 Then
    Filter [OPPO] Where [F:OPPO]OPPCMP=[F:BPR]BPRNUM and find([F:OPPO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [OPPO]
      WIFLO = 1
      Break
    Next
    Filter [OPPO]
  Endif
  If WIFLO = 0 and IFCY_CONO(WFOR_FCY) > 0 Then
    Filter [CONO] Where [F:CONO]CONBPC=[F:BPR]BPRNUM and find([F:CONO]SALFCY,WTB_FCY(1..(WNB_FCY_TRT-1)))<>0
    For [CONO]
      WIFLO = 1
      Break
    Next
    Filter [CONO]
  Endif
Return

##########################################################################################################
$OPTIM_TIERS
  WIFLO = 0
  If WIFLO = 0 and IFCY_TSKO(WFOR_FCY) > 0 Then
    Filter [TSKO] Where [F:TSKO]TSKCMP=[F:BPR]BPRNUM
    For [TSKO]
      WIFLO = 1
      Break
    Next
    Filter [TSKO]
  Endif
  If WIFLO = 0 and IFCY_CLLO(WFOR_FCY) > 0 Then
    Filter [CLLO] Where [F:CLLO]CLLCMP=[F:BPR]BPRNUM
    For [CLLO]
