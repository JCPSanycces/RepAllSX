      Break
    Next
    Filter [CLLO]
  Endif
  If WIFLO = 0 and IFCY_BAPO(WFOR_FCY) > 0 Then
    Filter [BAPO] Where [F:BAPO]APTCMP=[F:BPR]BPRNUM
    For [BAPO]
