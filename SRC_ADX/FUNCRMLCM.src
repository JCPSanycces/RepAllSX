  Endif
  If WIFLO = 0 and IFCY_SREO(WFOR_FCY) > 0 Then
    Filter [SREO] Where [F:SREO]SREBPC=[F:BPR]BPRNUM
    For [SREO]
      WIFLO = 1
      Break
    Next
    Filter [SREO]
  Endif
  If WIFLO = 0 and IFCY_ITNO(WFOR_FCY) > 0 Then
    Filter [ITNO] Where [F:ITNO]BPC=[F:BPR]BPRNUM
    For [ITNO]
      WIFLO = 1
      Break
    Next
