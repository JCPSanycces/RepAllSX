##########################################################################################################
$TERMINE
  If !GSERVEUR Then
    Call FERME_BOITE From GESECRAN
  Endif
  If !GSERVEUR Then
   If [M]TRACE = 2 Then
     Call FERME_TRACE From LECFIC
     TRA = 1
   Endif
  Endif
Return

##########################################################################################################
$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

##########################################################################################################
Subprog AM_TOUSOC(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Raz GSOCIETE
    Raz [M]SOC  
    Grizo [M]SOC 
  Else
    Call INICPY([M]SOC) From CPTSUB
    GSOCIETE=[M]SOC
    Actzo [M]SOC 
  Endif
End

##########################################################################################################
Subprog AM_TOUCLIENT(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Raz [M]CLIENT  
    Grizo [M]CLIENT 
  Else
    Actzo [M]CLIENT 
  Endif
End
