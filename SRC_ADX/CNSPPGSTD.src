#<AdxTL>@(#)2.0.0.0 $Revision$ Inquiry PPG




####################################################################
$ACTION
#Infbox ACTION
Case ACTION 
  When "LECTURE"    : Gosub LECTURE
  When "EXEBOUT"    : Gosub EXEBOUT
  When "APRES_MODIF": Gosub APRES_MODIF From CNSTRGSTD
  When "OUVRE"      : Gosub OUVRE From CNSTRGSTD
  When "SETBOUT"    : Gosub SETBOUT
  When "FERME"      : Gosub FERME
Endcase
Return


#** #############################################################################################
#* SETBOUT disables inquiry export menu entries.
#*! #############################################################################################

$SETBOUT
    Disable GSTAXLS
    Disable GSTAXLS2
Return


#** #############################################################################################
#* FERME reenables inquiry export menu entries.
#*! #############################################################################################

$FERME
    Enable GSTAXLS
    Enable GSTAXLS2
Return


#** #############################################################################################
#* Sub chunk DEBUT 
#* sets the default values for the date range
#*! #############################################################################################
$LECTURE
  #Infbox "Debut"
  #beginning of the previous year
  [M:TRG0]DATDEB = gdat$(1, 1, year(date$) - 1)
  #end of the previous year
  [M:TRG0]DATFIN = gdat$(31, 12, year(date$) - 1)
  #refresh fields
  Affzo [M:TRG0]CPY
  Affzo [M:TRG0]CURSEL
  Affzo [M:TRG0]DATDEB
  Affzo [M:TRG0]DATFIN
Return


#** #############################################################################################
#* Sub chunk BOUTON 
#* is called when a bouton is pressed
#*! #############################################################################################
$EXEBOUT
  #Infbox BOUT
  Case BOUT
    When "A"
      #Start VAT processing and calculation
      Gosub EXEC_DFV
      MODIFFLAG = 0
    When "1"
      # Alert if the site is set for a real reporting is only allowed for companies not sites.
       If [M:TRG0]FCY <> ""
          Call ERREURT( mess(280,107,1), 1 ) From GESECRAN # "Only companies/company groups can print/export recap. stat. Please empty site field."
          Return
       Endif
      #start the screen for additional settings and file output
      Gosub ELSTERSCREEN
    When "4"
      MODIFFLAG = 1
  Endcase
Return


#** #############################################################################################
#* ELSTERSCREEN Opens the screen where the user can do additional settings and
#* generate a file for the ELSTER-client
#*! #############################################################################################
$ELSTERSCREEN
    Local Char RESULT(255)      : RESULT = ""       
    Local Char PARAMS(10)(2)
    If MODIFFLAG = 1 : Gosub EXEC_DFV : Endif
    #if total amount is negative show info
    If [M:PPG1]AMTVAT < 0
      Call ERREURT(mess(311,107,1) - mess(312,107,1),0) From GESECRAN
    Endif
    # Open the ELSTER screen
    PARAMS(0) = "DAU"
    If WARNING = 1 : PARAMS(1) = "ERR" : Endif
    Call SAISIE_CHAR( RESULT, PARAMS, "TRGP", "TRGP", "SPETRGP") From GSAISIE

Return

#** #############################################################################################
#* EXEC_DFV starts the calculation of the needed USTVA key data.
#* After running the chunk EXECUSTVAEXT from process CNSTRGSTD the value DFVSUM is available
#* which represents the total amount of VAT prepayment.
#*! #############################################################################################
$EXEC_DFV
  Local Char EXTCPY, EXTLEG, EXTFCY, EXTGRP
  Local Date EXTDATEB, EXTDATEE

  EXTCPY = [M:TRG0]CPY
  EXTLEG = [M:TRG0]LEG
  EXTFCY = [M:TRG0]FCY
  EXTGRP = [M:TRG0]GRP
  EXTDATEB = [M:TRG0]DATDEB
  EXTDATEE = [M:TRG0]DATFIN
  #start calculation of ustva
  Gosub EXECUSTVAEXT From CNSTRGSTD
  #set the calculated tax sum for "Dauerfristverlängerung"
  [M:PPG1]AMTVAT = DFVSUM
  Affzo [M:PPG1]AMTVAT
  #set 1/11 of the calculated tax sum
  If DFVSUM > 0
    [M:PPG1]AMTPRT11 = fix(DFVSUM / 11)#func THEELEVENTH(DFVSUM)
  Else
    [M:PPG1]AMTPRT11 = 0
  Endif
  Affzo [M:PPG1]AMTPRT11

Return

