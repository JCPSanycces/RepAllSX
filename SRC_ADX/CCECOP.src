#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "PRO"
Call TRAITE_CHAR(VALEUR,PARAM,"","CCECOP","CCECOP",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Gosub INIT_DIA
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Integer I , J , K
TMP = 1
Return

$INIT_DIA
[M:DIA]DIE = PARAM(1)
zonsui = "NDIE"
Return

$EXEC
Local File =[M:DIA]DOSORG+".GDIE"      [DIE1]
Local File =[M:DIA]DOSORG+".CACCE"     [CCE1]
Local File =[M:DIA]DOSORG+".ATEXTRA"   [AXX1]

Local File =[M:DIA]DOSDES+".GDIE"      [DIE2]
Local File =[M:DIA]DOSDES+".CACCE"     [CCE2]
Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]

Local File =[M:DIA]DOSDES+".COMPANY"   [CPY]
Local File =[M:DIA]DOSDES+".FACILITY"  [FCY]
Local File =[M:DIA]DOSDES+".ATABDIV"   [ADI]
Local File =[M:DIA]DOSDES+".GDIE"      [DIE]
Local File =[M:DIA]DOSDES+".ACCCOD"    [ACS]
Local File =[M:DIA]DOSDES+".CADISTMP"  [DTP]
Local File =[M:DIA]DOSDES+".TABUNIT"   [TUN]

Local File =[M:DIA]DOSDES+".GCCEPYMPRT" [CYP]
Local File =[M:DIA]DOSDES+".GCCEGRUPYM" [CRY]
Local File =[M:DIA]DOSDES+".GCCEGRUPYM" [CRY2]
Local File =[M:DIA]DOSDES+".CACCE"      [CCE]

Local Char OAXE(GLONDIE) , NAXE(GLONDIE)
OAXE = [M:DIA]DIE
NAXE = [M:DIA]NDIE
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [DIE2],[DIE2]
 Read [DIE1]DIE0 = OAXE
 If fstat
  Goto AB_TR1
 Endif
 Read [DIE2]DIE0 = NAXE
 If fstat
  [F:DIE2] = [F:DIE1]
  [F:DIE2]DIE = NAXE
  Write [DIE2]
  If fstat
   GOK = 0 : Call FSTA("DIE2") From GLOCK : Goto AB_TR1
  Endif
  Call COPTEXTRA("GDIE","COLHEA",OAXE,"",NAXE,"")
 Endif
 For [CCE1]CCE0 Where DIE=OAXE
  Read [CCE2]CCE0 = NAXE;[F:CCE1]CCE
  If fstat
   [F:CCE2] = [F:CCE1]
   [F:CCE2]DIE = NAXE
   If [M:DIA]DOSORG<>[M:DIA]DOSDES
    Gosub CONTROLES
   Endif
   Write [CCE2]
   If fstat
    GOK = 0 : Call FSTA("CCE2") From GLOCK : Break
   Endif
   Call COPTEXTRA("CACCE","DESTRA",OAXE,[F:CCE1]CCE,NAXE,[F:CCE1]CCE)
   If GOK<1 : Break : Endif
   Call COPTEXTRA("CACCE","DESSHO",OAXE,[F:CCE1]CCE,NAXE,[F:CCE1]CCE)
   If GOK<1 : Break : Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Call PYRAMPRT("",NAXE,[M:DIA]DOSDES) From LIENPYRCCE
If [M:DIA]DOSDES=nomap
 Call INIGLBDIE From SETGLBDIE
Endif
Return

$AB_TR1
Rollback
Return

$CONTROLES
If [F:CCE2]FCY<>""
 Read [CPY]CPY0 = [F:CCE2]FCY
 If fstat
  Read [FCY]FCY0 = [F:CCE2]FCY
  If fstat
   [F:CCE2]FCY = ""
  Endif
 Endif
Endif
If [F:CCE2]AUZ<>""
 Read [ADI]CODE = 322;[F:CCE2]AUZ
 If fstat
  [F:CCE2]AUZ = ""
 Endif
Endif
If [F:CCE2]ACS<>""
 Read [ACS]ACS0 = [F:CCE2]ACS
 If fstat
  [F:CCE2]ACS = ""
 Endif
Endif
I = 0
While I<=[F:CCE2]UOMNBR-1
 K = 1
 If [F:CCE2]UOM(I)<>""
  Read [TUN]TUN0 = [F:CCE2]UOM(I)
  If fstat
   K = 0
  Endif
 Endif
 If !K
  Dela I,1 [F:CCE2]UOM,[F:CCE2]QTY
  [F:CCE2]UOMNBR -= 1
 Else
  I += 1
 Endif
Wend
I = 0
While I<=[F:CCE2]DIENBR-1
 K = 1
 Read [DIE]DIE0 = [F:CCE2]OTHDIE(I)
 If fstat
  K = 0
 Elsif [F:CCE2]CCEDEF(I)<>""
  Read [CCE]CCE0 = [F:CCE2]OTHDIE(I);[F:CCE2]CCEDEF(I)
  If fstat
   [F:CCE2]CCEDEF(I) = ""
  Endif
 Endif
 If !K
  Dela I,1 [F:CCE2]OTHDIE,[F:CCE2]CCEDEF
  [F:CCE2]DIENBR -= 1
 Else
  I += 1
 Endif
Wend
Return

Subprog COPTEXTRA(FIC,CHP,OID1,OID2,NID1,NID2)
Value Char FIC
Value Char CHP
Value Char OID1
Value Char OID2
Value Char NID1
Value Char NID2
For [AXX1]AXX0 Where CODFIC=FIC & ZONE=CHP & IDENT1=OID1 & IDENT2=OID2
 Read [AXX2]AXX0 = FIC;CHP;[F:AXX1]LANGUE;NID1;NID2
 If fstat
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = NID1
  [F:AXX2]IDENT2 = NID2
  Write [AXX2]
 Else
  [F:AXX2] = [F:AXX1]
  [F:AXX2]IDENT1 = NID1
  [F:AXX2]IDENT2 = NID2
  Rewrite [AXX2]
 Endif
 If fstat
  GOK = 0 : Call FSTA("AXX2") From GLOCK : Break
 Endif
Next
End

########################################################
## Ecran GACCOP
########################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
GMODIF = 0
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [M]DOSORG
Endif
End


Subprog C_NDIE(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DIE & [M]DOSORG=[M]DOSDES
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End


