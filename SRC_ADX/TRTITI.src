##########################################################################################################
Subprog GOTO_DESTINATION(SITE, STREET, ZIPCOD, CITY, COUNTRY, SREQUETE)
Value Char SITE
Value Char STREET
Value Char ZIPCOD                                # FGR 03/10/2014 : X3SUIVI102390
Value Char CITY
Value Char COUNTRY                               # FGR 03/10/2014 : X3SUIVI102390
Variable Clbfile SREQUETE

Local Char FCYSTREET(GLONADL)
Local Char FCYZIP(GLONPOS)
Local Char FCYCITY(GLONCTY)
Local Char FCYCOUNTRY(GLONCRY)

  Call LOAD_ADRESSE_SITE(SITE, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
  # -------------------------------------------------
  # FGR 13/11/2014 : X3SUIVI103963 .com pas .fr
  SREQUETE  = 'maps.google.com/maps?saddr=+'          # saddr= Source address. Use this when asking for driving directions.
                                                      # Any text added in brackets is displayed in the sidebar in bold.
  SREQUETE += ctrans(FCYSTREET," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(FCYZIP - FCYCITY," ","+")   # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(FCYCOUNTRY," ","+")         # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += '&daddr='                               # daddr= Destination address(es). Use this when asking for driving directions
                                                      # Any text added in brackets is displayed in the sidebar in bold.
  SREQUETE += ctrans(STREET," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(ZIPCOD - CITY," ","+")      # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(COUNTRY," ","+")            # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += '&hl=' + func GET_LANGUE(GUSER)         # hl= Host language. Only a few languages are supported, e.g. hl=fr for French.
  SREQUETE += '&ie=UTF8'                              # ie= Can be used to specify the input character encoding set. e.g. ie=UTF8.
 #SREQUETE += '&ll=47.0,4.0'                          # ll=  Latitude,longitude of map centre - Note the order. Only decimal format is accepted.
                                                      # If this is used without a query, then the map is centred at the point but no marker or info window is displayed.
 #SREQUETE += '&spn=5.0,7.0'                          # spn=  Approximate lat/long span. The zoom level will be adjusted to fit if there's no z= parameter. Use this Mapki tool to find a lat and long.
 #SREQUETE += '&sll=46.0,4.0'                         # sll=  Latitude,longitude of the point from which the business search should be performed.
                                                      # You could use this to perform an off-centre busness search.
                                                      # Google use it so "link to this page" can record a map that has had the centre moved after performing a business search.
                                                      # When requesting a route <math>map.getBounds().getSouthWest().toUrlValue()</math> returns the same value maps.google.com uses.
 #SREQUETE += '&sspn=5.0,7.0'                         # sspn=  Stands for "Screen span". Map bounds dimensions in Degrees, to calculate this use:
                                                      # <math>new GLatLng(map.getBounds().getNorthEast().lat() - map.getBounds().getSouthWest().lat(),
                                                      #       map.getBounds().getNorthEast().lng() - map.getBounds().getSouthWest().lng()).toUrlValue()</math>
  SREQUETE += '&t=h'                                  # t= Map Type. The available options are "m" map, "k" satellite, "h" hybrid, "p" terrain, "e" GoogleEarth.
 #SREQUETE += '&z=6'                                  # z= Sets the zoom level. (Range from 1-20)
End

##########################################################################################################
Subprog ITINERAIRE_DESTINATION(SOBJET, STRT, SREQUETE)
Value Char SOBJET
Value Char STRT
Variable Clbfile SREQUETE

Local Integer ILIGNE
Local Integer ISVLIGNE
Local Char SCHRONO(GLONVCR)

  Gosub DECLARE_VAR
  Gosub RAZ_DEST
  ILIGNE = -1
  ISVLIGNE = -1
  #------------
  Onerrgo SP_INEXISTANT
  Repeat
    Call GET_CHRONO_ITI(ILIGNE, SCHRONO) From =STRT
    If ISVLIGNE = ILIGNE Then
      # Permet de traiter le cas où on reçoit plusieurs fois de suites la même ligne
      # Ca permet de sortir, sans entrer dans une boucle infinie
      ILIGNE = -1
      Raz SCHRONO
    Endif
    If ILIGNE >= 0 Then
      Case SOBJET
        When "BAP"
          Gosub READ_BAP
        When "ITN"
          Gosub READ_ITN
        When "SDH"
          Gosub READ_SDH
        When "SOH"
          Gosub READ_SOH
        When Default
          Break
      Endcase
      If func CHARGE_UNE_LIGNE(SADD, SZIP, SCTY, SCRY, SCMT, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT) = 1 Then
        Break
      Endif
      ISVLIGNE = ILIGNE
    Endif
  Until ILIGNE < 0
  Onerrgo
  #------------
  If BFIRST = 1 Then
    Call LOAD_ITINERAIRE(FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT, SREQUETE) # FGR 03/10/2014 : X3SUIVI102390
  Endif
End

##########################################################################################################
Subprog LOAD_ITINERAIRE(SFCYSTREET, SFCYZIPCOD, SFCYCITY, SFCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT, SREQUETE)
Value Char SFCYSTREET
Value Char SFCYZIPCOD                            # FGR 03/10/2014 : X3SUIVI102390
Value Char SFCYCITY
Value Char SFCYCOUNTRY                           # FGR 03/10/2014 : X3SUIVI102390
Value Integer NBDEST
Value Char TBSTREET()()
Value Char TBZIP()()
Value Char TBCITY()()
Value Char TBCOUNTRY()()
Value Char TBCMT()()
Variable Clbfile SREQUETE

Local Integer NI

  # FGR 13/11/2014 : X3SUIVI103963 .com pas .fr
  SREQUETE  = 'maps.google.com/maps?saddr='  # saddr= Source address. Use this when asking for driving directions.
                                                       # Any text added in brackets is displayed in the sidebar in bold.
  SREQUETE += ctrans(SFCYSTREET," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(SFCYZIPCOD - SFCYCITY," ","+")# FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(SFCYCOUNTRY," ","+")        # FGR 03/10/2014 : X3SUIVI102390

  SREQUETE += '&daddr=+'                               # daddr= Destination address(es). Use this when asking for driving directions
                                                       # Any text added in brackets is displayed in the sidebar in bold.
                                                       # "+to:" clauses can be appended to the destination to request multiple destination routing, like this daddr=Blackpool+to:Manchester+to:Leeds
                                                       # Text in brackets can also be added to the "+to:" clauses.
  SREQUETE += ctrans(TBSTREET(0)," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(TBZIP(0) - TBCITY(0)," ","+")# FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(TBCOUNTRY(0)," ","+")       # FGR 03/10/2014 : X3SUIVI102390
  If TBCMT(0) <> "" Then
    SREQUETE += '+('
    SREQUETE += ctrans(TBCMT(0)," ","+")
    SREQUETE += ')'
  Endif
  #
  For NI = 1 To NBDEST-1
    SREQUETE += '+to:'
    SREQUETE += ctrans(TBSTREET(NI)," ","+")
    SREQUETE += ','
    SREQUETE += ctrans(TBZIP(NI) - TBCITY(NI)," ","+")# FGR 03/10/2014 : X3SUIVI102390
    SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
    SREQUETE += ctrans(TBCOUNTRY(NI)," ","+")      # FGR 03/10/2014 : X3SUIVI102390
    #
    If TBCMT(NI) <> "" Then
      SREQUETE += '+('
      SREQUETE += ctrans(TBCMT(NI)," ","+")
      SREQUETE += ')'
    Endif
  Next NI
  SREQUETE += '+to:'
  SREQUETE += ctrans(SFCYSTREET," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(SFCYZIPCOD - SFCYCITY," ","+")# FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(SFCYCOUNTRY," ","+")        # FGR 03/10/2014 : X3SUIVI102390
  #
  SREQUETE += '&hl=' + func GET_LANGUE(GUSER)         # hl= Host language. Only a few languages are supported, e.g. hl=fr for French.
  SREQUETE += '&ie=UTF8'                              # ie= Can be used to specify the input character encoding set. e.g. ie=UTF8.
 #SREQUETE += '&ll=46.0,4.0'                          # ll=  Latitude,longitude of map centre - Note the order. Only decimal format is accepted.
                                                       # If this is used without a query, then the map is centred at the point but no marker or info window is displayed.
 #SREQUETE += '&spn=11.0,18.0'                        # spn=  Approximate lat/long span. The zoom level will be adjusted to fit if there's no z= parameter. Use this Mapki tool to find a lat and long.
 #SREQUETE += '&sll=46.0,4.0'                         # sll=  Latitude,longitude of the point from which the business search should be performed.
                                                       # You could use this to perform an off-centre busness search.
                                                       # Google use it so "link to this page" can record a map that has had the centre moved after performing a business search.
                                                       # When requesting a route <math>map.getBounds().getSouthWest().toUrlValue()</math> returns the same value maps.google.com uses.
 #SREQUETE += '&sspn=11.0,18.0'                       # sspn=  Stands for "Screen span". Map bounds dimensions in Degrees, to calculate this use:
                                                       # <math>new GLatLng(map.getBounds().getNorthEast().lat() - map.getBounds().getSouthWest().lat(),
                                                       #       map.getBounds().getNorthEast().lng() - map.getBounds().getSouthWest().lng()).toUrlValue()</math>
  SREQUETE += '&t=h'                                  # t= Map Type. The available options are "m" map, "k" satellite, "h" hybrid, "p" terrain, "e" GoogleEarth.
 #SREQUETE += '&z=6'                                  # z= Sets the zoom level. (Range from 1-20)
End

##########################################################################################################
$READ_BAP
  If !clalev([F:BAP]) : Local File BAPPOINT [BAP] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  #
  Read [BAP]APP0=SCHRONO
  If !fstat Then
    If BFIRST = 0 Then
      Call LOAD_ADRESSE_SITE([F:BAP]SALFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
      BFIRST = 1
    Endif
    Gosub CHARGE_BAP
  Endif
Return

##########################################################################################################
$CHARGE_BAP
Local Integer NI

  SADD = ctrans([F:BAP]APTADD(0))
  SZIP = ctrans([F:BAP]APTZIP)
  SCTY = ctrans([F:BAP]APTCTY)
  SCRY = ctrans([F:BAP]APTCRY)
  #--------------------------------------
  Read [BPR]BPR0=[F:BAP]APTCMP
  If !fstat Then
    SCMT = mess(2,967,1) - [F:BPR]BPRNAM(0)
    If [F:BPR]BPRNAM(1) <> "" Then
      SCMT += " " + [F:BPR]BPRNAM(1)
    Endif
    SCMT += " :" - format$("DD2",[F:BAP]APTDAT) - format$("##[:]##", [F:BAP]APTHOU)
    For NI = 0 To dim([F:BAP]APTCCNNUM)
      If [F:BAP]APTCCNNUM(NI) = "" Then
        Break
      Endif
      If !fstat Then
        Read [AIN]AIN0=[F:BAP]APTCCNNUM(NI)
        SCMT += " " + mess([F:AIN]CNTTTL,941,1) - [F:AIN]CNTLNA - [F:AIN]CNTFNA
      Endif
    Next NI
  Endif
Return

##########################################################################################################
Subprog LOAD_BAP(SMODE, SCHRONO, SREQUETE)
Value Char SMODE
Value Char SCHRONO
Variable Clbfile SREQUETE

Local Char SREP(GLONREP)
Local Date DDEBUT
Local Date DFIN

  Gosub DECLARE_VAR
  Gosub RAZ_DEST
  Local File BAPPOINT [BAP]
  Local File BPARTNER [BPR]
  Local File CONTACTCRM [AIN]
  #-----------------------
  Read [BAP]APP0=SCHRONO
  SREP = [F:BAP]ATPREPMNA
  Call GET_DATE_DEB_FIN(SMODE, [F:BAP]APTDAT, DDEBUT, DFIN)
  Call LOAD_ADRESSE_SITE([F:BAP]SALFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
  #---------------------------------------------------------
  Filter [BAP] Where [F:BAP]ATPREPMNA = SREP and [F:BAP]APTDAT >= DDEBUT and [F:BAP]APTDAT <= DFIN Order By [F:BAP]APTDAT; [F:BAP]APTHOU
  For [BAP]
    Gosub CHARGE_BAP
    #--------------------------------------
    If func CHARGE_UNE_LIGNE(SADD, SZIP, SCTY, SCRY, SCMT, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT) = 1 Then
      Break
    Endif
  Next
  Filter [BAP]
  Call LOAD_ITINERAIRE(FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT, SREQUETE) # FGR 03/10/2014 : X3SUIVI102390
End

##########################################################################################################
$READ_ITN
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  #
  Read [ITN]ITN0=SCHRONO
  If BFIRST = 0 Then
    Call LOAD_ADRESSE_SITE([F:ITN]SALFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
    BFIRST = 1
  Endif
  Gosub CHARGE_ITN
Return

##########################################################################################################
$CHARGE_ITN
  SADD = ctrans([F:ITN]ADD(0))
  SZIP = ctrans([F:ITN]ZIP)
  SCTY = ctrans([F:ITN]CTY)
  SCRY = ctrans([F:ITN]CRY)
  #--------------------------------------
  Read [BPR]BPR0=[F:ITN]BPC
  SCMT = mess(6,967,1) - [F:BPR]BPRNAM(0)
  If [F:BPR]BPRNAM(1) <> "" Then
    SCMT += " " + [F:BPR]BPRNAM(1)
  Endif
  SCMT += " :" - format$("DD2",[F:ITN]DAT) - format$("##[:]##", [F:ITN]HOU)
  If [F:ITN]CCN <> "" Then
    Read [AIN]AIN0=[F:ITN]CCN
    SCMT += " " + mess([F:AIN]CNTTTL,941,1) - [F:AIN]CNTLNA - [F:AIN]CNTFNA
  Endif
Return

##########################################################################################################
Subprog LOAD_ITN(SMODE, SCHRONO, SREQUETE)
Value Char SMODE
Value Char SCHRONO
Variable Clbfile SREQUETE

Local Char SREP(GLONREP)
Local Char SBPR(GLONBPR)
Local Date DDEBUT
Local Date DFIN
Local Char SCRITERE(250)

  Gosub DECLARE_VAR
  Gosub RAZ_DEST
  Local File INTERVEN [ITN]
  Local File BPARTNER [BPR]
  Local File CONTACTCRM [AIN]
  #-----------------------
  Read [ITN]ITN0=SCHRONO
  If [F:ITN]SCO = 2 Then
    # Sous-traitée
    SBPR = [F:ITN]SCONUM
    SCRITERE = "([F:ITN]SCO = 2 and [F:ITN]SCONUM = SBPR)"
  Else
    # Pas sous-traitée
    SREP = [F:ITN]REP
    SCRITERE = "([F:ITN]SCO <> 2 and [F:ITN]REP = SREP)"
  Endif
  Call GET_DATE_DEB_FIN(SMODE, [F:ITN]DAT, DDEBUT, DFIN)
  Call LOAD_ADRESSE_SITE([F:ITN]SALFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
  #---------------------------------------------------------
  Filter [ITN] Where evalue(SCRITERE) and [F:ITN]DAT >= DDEBUT and [F:ITN]DAT <= DFIN Order By [F:ITN]DAT; [F:ITN]HOU
  For [ITN]
    Gosub CHARGE_ITN
    #--------------------------------------
    If func CHARGE_UNE_LIGNE(SADD, SZIP, SCTY, SCRY, SCMT, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT) = 1 Then
      Break
    Endif
  Next
  Filter [ITN]
  Call LOAD_ITINERAIRE(FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT, SREQUETE) # FGR 03/10/2014 : X3SUIVI102390
End

##########################################################################################################
## Livraison : # Visualisation des tournées (X3Suivi 74795)
##########################################################################################################
$READ_SDH
  If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
  #
  Read [SDH]SDH0=SCHRONO
  If BFIRST = 0 Then
    Call LOAD_ADRESSE_SITE([F:SDH]STOFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY) : # Chargement adresse du site
    BFIRST = 1
  Endif
  Gosub CHARGE_SDH
Return

##########################################################################################################
$CHARGE_SDH
  If [F:SDH]BPDPOSCOD <> "" Then
    SADD = ctrans([F:SDH]BPDADDLIG(0))
    SZIP = ctrans([F:SDH]BPDPOSCOD)
    SCTY = ctrans([F:SDH]BPDCTY)
    SCRY = ctrans([F:SDH]BPDCRY)
  Else
    #-- Recherche adresse du client --#
    If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
    Read [BPA]BPA0=1;[F:SDH]BPCORD;[F:SDH]BPAADD
    If !fstat Then
      SADD = ctrans([F:BPA]BPAADDLIG(0))
      SZIP = ctrans([F:BPA]POSCOD)
      SCTY = ctrans([F:BPA]CTY)
      SCRY = ctrans([F:BPA]CRY)
    Endif
  Endif
  If [F:SDH]CNDNAM <> "" Then
    #Contact
    SCMT = mess(240,183,1) - ":" - [F:SDH]CNDNAM
  Endif
Return

##########################################################################################################
## Commandes  : # Visualisation des tournées (X3Suivi 74795)
##########################################################################################################
$READ_SOH
  If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
  #
  Read [SOH]SOH0=SCHRONO
  If BFIRST = 0 Then
    Call LOAD_ADRESSE_SITE([F:SOH]STOFCY, FCYSTREET, FCYZIP, FCYCITY, FCYCOUNTRY)
    BFIRST = 1
  Endif
  Gosub CHARGE_SOH
Return

##########################################################################################################
$CHARGE_SOH
  If [F:SOH]BPDPOSCOD <> "" Then
    SADD = ctrans([F:SOH]BPDADDLIG(0))
    SZIP = ctrans([F:SOH]BPDPOSCOD)
    SCTY = ctrans([F:SOH]BPDCTY)
    SCRY = ctrans([F:SOH]BPDCRY)
  Else
    #-- Recherche adresse du client --#
    If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
    Read [BPA]BPA0=1;[F:SOH]BPCORD;[F:SOH]BPAADD
    If !fstat Then
      SADD = ctrans([F:BPA]BPAADDLIG(0))
      SZIP = ctrans([F:BPA]POSCOD)
      SCTY = ctrans([F:BPA]CTY)
      SCRY = ctrans([F:BPA]CRY)
    Endif
  Endif
  If [F:SOH]CNDNAM <> "" Then
    # Contact
    SCMT = mess(240,183,1) - ":" - [F:SOH]CNDNAM
  Endif
Return

##########################################################################################################
#                               SOUS-PROGRAMMES ET FONCTIONS TECHNIQUES                                  #
##########################################################################################################
$RAZ_DEST
  Raz NBDEST
  Raz TBSTREET
  Raz TBZIP
  Raz TBCITY
  Raz TBCOUNTRY
  Raz TBCMT
Return

##########################################################################################################
$DECLARE_VAR
Local Char SADD(GLONADL)
Local Char SZIP(GLONPOS)
Local Char SCTY(GLONCTY)
Local Char SCRY(GLONCRY)
Local Char SCMT(250)
Local Integer BFIRST
Local Char FCYSTREET(GLONADL)
Local Char FCYZIP(GLONPOS)
Local Char FCYCITY(GLONCTY)
Local Char FCYCOUNTRY(GLONCRY)
Local Integer NBDEST
Local Char TBSTREET(GLONADL)(0..50)
Local Char TBZIP(GLONPOS)(0..50)
Local Char TBCITY(GLONCTY)(0..50)
Local Char TBCOUNTRY(GLONCRY)(0..50)
Local Char TBCMT(250)(0..50)

  Raz SADD
  Raz SZIP
  Raz SCTY
  Raz SCRY
  Raz SCMT
  BFIRST = 0
  Gosub RAZ_DEST
Return

##########################################################################################################
$SP_INEXISTANT
  Call GET_CHRONO_ITI(ILIGNE, SCHRONO)
Resume

##########################################################################################################
Subprog GET_CHRONO_ITI(ILIGNE, SCHRONO)
Variable Integer ILIGNE
Variable Char SCHRONO

  ILIGNE = -1
  Raz SCHRONO
End

##########################################################################################################
Funprog GET_LANGUE(SUSER)
Value Char SUSER

Local Char SARENDRE(10)      # FGR 28/04/2016 : X3SUIVI115604

  Local File TABLAN [TLA]
  #
  Read [TLA]TLA0=GLANGUE
  If fstat Then
    SARENDRE = "en"          # FGR 13/11/2014 : Par défaut replis sur la langue anglaise et pas "fr"
  Else
    SARENDRE = left$(LANISO,2)
    If SARENDRE = "" Then
      SARENDRE = "en"        # FGR 13/11/2014 : Par défaut replis sur la langue anglaise et pas "fr"
    Endif
  Endif
End SARENDRE

##########################################################################################################
Subprog LOAD_ADRESSE_SITE(SSITE, SSTREET, SZIP, SCITY, SCOUNTRY)
Value Char SSITE
Variable Char SSTREET
Variable Char SZIP
Variable Char SCITY
Variable Char SCOUNTRY

  Local File FACILITY [FCY]
  Local File BPADDRESS [BPA]
  #
  Read [FCY]FCY0=SSITE
  Read [BPA]BPA0=3;SSITE;[F:FCY]BPAADD
  #
  SSTREET = ctrans([F:BPA]BPAADDLIG(0))
  SZIP = ctrans([F:BPA]POSCOD)
  SCITY = ctrans([F:BPA]CTY)
  SCOUNTRY = ctrans([F:BPA]CRY)
End

##########################################################################################################
Funprog CHARGE_UNE_LIGNE(SADD, SZIP, SCTY, SCRY, SCMT, SFCYSTREET, SFCYZIP, SFCYCITY, SFCYCOUNTRY, NBDEST, TBSTREET, TBZIP, TBCITY, TBCOUNTRY, TBCMT)
Value Char SADD
Value Char SZIP
Value Char SCTY
Value Char SCRY
Value Char SCMT
Value Char SFCYSTREET
Value Char SFCYZIP
Value Char SFCYCITY
Value Char SFCYCOUNTRY
Variable Integer NBDEST
Variable Char TBSTREET()(0..)
Variable Char TBZIP()(0..)
Variable Char TBCITY()(0..)
Variable Char TBCOUNTRY()(0..)
Variable Char TBCMT()(0..)

Local Integer STAT

  STAT = 0
  If SADD = "" and SZIP = "" and SCTY = "" and SCRY = "" Then
    End STAT
  Else
    If (NBDEST = 0 and
&          (SFCYSTREET <> SADD
&        or SFCYZIP <> SZIP
&        or SFCYCITY <> SCTY
&        or SFCYCOUNTRY <> SCRY
&          )
&      )
&    or (NBDEST > 0 and
&          (TBSTREET(NBDEST-1) <> SADD
&        or TBZIP(NBDEST-1) <> SZIP
&        or TBCITY(NBDEST-1) <> SCTY
&        or TBCOUNTRY(NBDEST-1) <> SCRY
&          )
&       ) Then
      TBSTREET(NBDEST) = SADD
      TBZIP(NBDEST) = SZIP
      TBCITY(NBDEST) = SCTY
      TBCOUNTRY(NBDEST) = SCRY
      TBCMT(NBDEST) = SCMT
      #-------------
      NBDEST += 1
      If NBDEST = 25 Then
        # C'est la limite de Google Map. Ca permet d'arrêter la boucle
        STAT = 1
        #Inftxt mess(1022,196,1) At 2
      Endif
    Endif
  Endif
End STAT

##########################################################################################################
Subprog GET_DATE_DEB_FIN(SMODE, DDATE, DDEBUT, DFIN)
Value Char SMODE
Value Date DDATE
Variable Date DDEBUT
Variable Date DFIN

Local Integer IDAY
Local Integer IMONTH
Local Integer IYEAR
Local Integer IWEEK

  Case SMODE
    When "3"   # Itinéraire journée
      DDEBUT = DDATE
      DFIN = DDATE
    When "4"   # Itinéraire semaine
      IYEAR = year(DDATE)
      IWEEK = week(DDATE)
      DDEBUT = aweek(IWEEK, IYEAR)
      DFIN = DDEBUT + 4
    When "5"   # Itinéraire mois
      IMONTH = month(DDATE)
      IYEAR = year(DDATE)
      DDEBUT = gdat$(1, IMONTH, IYEAR)
      DFIN = eomonth(DDATE)
    When Default
      DDEBUT = DDATE
      DFIN = DDATE
  Endcase
End

