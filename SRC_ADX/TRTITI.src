#<AdxTL>@(#)0.0.0.0 $Revision$
# TRTITI
# -------------------------------------
Local Char PARMSK(250)(1..20)

  If 1=1 Then
    PARMSK(1) = "BAP"
    PARMSK(2) = "ACT000000000001"
    PARMSK(3) = "1"
    PARMSK(4) = "ANNECY"
    PARMSK(5) = "11 boulevard du fier"
    PARMSK(6) = "FR"
    PARMSK(7) = "74000"
    PARMSK(8) = "JAM"
    PARMSK(9) = ""
  Endif
  If 0=1 Then
    PARMSK(1) = "BAP"
    PARMSK(2) = "ACT000000000001"
    PARMSK(3) = "2"
    PARMSK(4) = "ANNECY"
    PARMSK(5) = "11 boulevard du fier"
    PARMSK(6) = "FR"
    PARMSK(7) = "74000"
    PARMSK(8) = "JAM"
    PARMSK(9) = ""
  Endif
  Call ITINERAIRE(PARMSK(1), PARMSK(2), PARMSK(3), PARMSK(4), PARMSK(5), PARMSK(6), PARMSK(7), PARMSK(8), PARMSK(9))
End
##########################################################################################################

##########################################################################################################
Subprog ITINERAIRE(OBJET,CHRONO,ACTION,VILLE,ADR,PAYS,CP,SITE,TRT)
Value    Char    OBJET
Value    Char    CHRONO
Value    Char    ACTION
Value    Char    VILLE
Value    Char    ADR
Value    Char    PAYS
Value    Char    CP
Value    Char    SITE
Value    Char    TRT

Local Char CITY(type(VILLE)-10)
Local Char STREET(type(ADR)-10)
Local Char COUNTRY(type(PAYS)-10)
Local Char ZIPCOD(type(CP)-10)
Local Clbfile SREQUETE(12)

  Raz SREQUETE
  CITY = ctrans(VILLE)
  STREET = ctrans(ADR)
  COUNTRY = ctrans(PAYS)
  ZIPCOD = ctrans(CP)
  #
  If (ACTION = "1" or ACTION = "2") and (CITY = "" and STREET = "" and COUNTRY = "" and ZIPCOD = "") Then
    # Si on n'a pas d'adresse, on ne peut pas y aller... Donc on sort tout de suite
    End
  Elsif ACTION = "6" and TRT = "" Then
    # Si on n'a pas de traitement, on ne sais pas ou aller... Donc on sort tout de suite
    End
  Else
    Gosub CHARGE_REQUETE
    Call AFFICHE_MAP(SREQUETE)
  Endif
End

##########################################################################################################
Funprog GET_REQUETE_HTTP(OBJET, CHRONO, ACTION, VILLE, ADR, PAYS, CP, SITE, TRT)
Value    Char    OBJET
Value    Char    CHRONO
Value    Char    ACTION
Value    Char    VILLE
Value    Char    ADR
Value    Char    PAYS
Value    Char    CP
Value    Char    SITE
Value    Char    TRT

Local Char CITY(type(VILLE)-10)
Local Char STREET(type(ADR)-10)
Local Char COUNTRY(type(PAYS)-10)
Local Char ZIPCOD(type(CP)-10)
Local Clbfile SREQUETE(12)

  Raz SREQUETE
  CITY = ctrans(VILLE)
  STREET = ctrans(ADR)
  COUNTRY = ctrans(PAYS)
  ZIPCOD = ctrans(CP)
  #
  If (ACTION = "1" or ACTION = "2") and (CITY = "" and STREET = "" and COUNTRY = "" and ZIPCOD = "") Then
    # Si on n'a pas d'adresse, on ne peut pas y aller... Donc on sort tout de suite
    End
  Elsif ACTION = "6" and TRT = "" Then
    # Si on n'a pas de traitement, on ne sais pas ou aller... Donc on sort tout de suite
    End
  Else
    Gosub CHARGE_REQUETE
  Endif
  SREQUETE = " https://" + vireblc(SREQUETE,1) + " "
End SREQUETE

##########################################################################################################
$CHARGE_REQUETE
  If ACTION = "1" Then
    Call DESTINATION(STREET, ZIPCOD, CITY, COUNTRY, SREQUETE)             # FGR 03/10/2014 : X3SUIVI102390
  Elsif ACTION = "2" Then
    Call GOTO_DESTINATION(SITE, STREET, ZIPCOD, CITY, COUNTRY, SREQUETE)  # FGR 03/10/2014 : X3SUIVI102390
  Elsif ACTION = "6" Then
    Call ITINERAIRE_DESTINATION(OBJET, TRT, SREQUETE)
  Elsif OBJET = "BAP" Then
    Call LOAD_BAP(ACTION, CHRONO, SREQUETE)
  Elsif OBJET = "ITN" Then
    Call LOAD_ITN(ACTION, CHRONO, SREQUETE)
  Endif
Return

##########################################################################################################
Subprog AFFICHE_MAP(SREQUETE)
Value Clbfile SREQUETE

Local Char RETOUR(200)
Local Char STBREQUETE(150)(1..100)
Local Integer NI
Local Integer LG
Local Integer LGCUM
Local Integer LGTOT

  If SREQUETE <> "" Then
    # Découpage
    Raz STBREQUETE
    NI = 0
    NI += 1
    STBREQUETE(NI) = "UIAction="+chr$(1) + "OpenFile"
    NI += 1
    STBREQUETE(NI) = "UILocalDir="+ chr$(1) + "HTTP"
    # -------------
    LGCUM = 0
    LGTOT = len(SREQUETE)
    LG = 100
    Repeat
      NI += 1
      STBREQUETE(NI) = "UILocalFile="+ chr$(NI) + mid$(SREQUETE, LGCUM+1, LG)
      LGCUM += len(mid$(SREQUETE, LGCUM+1, LG))
    Until LGCUM >= LGTOT
#    NI += 1                                              # hcb/ccora 89031
#    STBREQUETE(NI) = "UIAdxPubSubFile="+ chr$(1) + "1"   # hcb/ccora 89031
    #
    Callui RETOUR="" With STBREQUETE
  Endif
End

##########################################################################################################
Subprog DESTINATION(STREET, ZIPCOD, CITY, COUNTRY, SREQUETE)
Value Char STREET
Value Char ZIPCOD                                # FGR 03/10/2014 : X3SUIVI102390
Value Char CITY
Value Char COUNTRY                               # FGR 03/10/2014 : X3SUIVI102390
Variable Clbfile SREQUETE

  # FGR 21/10/2013 : X3SUIVI93662 : Street view plus appelable directement
  SREQUETE  = 'maps.google.com/maps?q='
  SREQUETE += ctrans(STREET," ","+")
  SREQUETE += ','
  SREQUETE += ctrans(ZIPCOD - CITY," ","+")      # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ','                                # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += ctrans(COUNTRY," ","+")            # FGR 03/10/2014 : X3SUIVI102390
  SREQUETE += '&hl=' + func GET_LANGUE(GUSER)         # hl= Host language. Only a few languages are supported, e.g. hl=fr for French.
  SREQUETE += '&ie=UTF8'                              # ie= Can be used to specify the input character encoding set. e.g. ie=UTF8.
  SREQUETE += '&spn=0.0,0.0'                          # spn=  Approximate lat/long span. The zoom level will be adjusted to fit if there's no z= parameter. Use this Mapki tool to find a lat and long.
  SREQUETE += '&t=h'                                  # t= Map Type. The available options are "m" map, "k" satellite, "h" hybrid, "p" terrain, "e" GoogleEarth.
  SREQUETE += '&z=18'                                 # z= Sets the zoom level. (Range from 1-20)
  SREQUETE += '&iwloc=A'                              # iwloc=  Specifies where the infowindow will be displayed. In a business search iwloc=A to iwloc=J will open the info window over
                                                      # the corresponding business marker, and iwloc=near will place it over the big green arrow if that's currently displayed.
                                                      # iwloc=addr  Can be used on map search to explicitly request the info window to be open on the address, but that's the default anyway.
                                                      # Directions search supports iwloc=start, iwloc=end and iwloc=pause1 etc. In My Maps can open the info window on specific feature, eg
  SREQUETE += '&layer=t'                              # layer= Activates overlay. Current option is "t" traffic.
  SREQUETE += '&t=h'                                  # t= Map Type. The available options are "m" map, "k" satellite, "h" hybrid, "p" terrain, "e" GoogleEarth.
  SREQUETE += '&hnear=' + ctrans(STREET," ","+") + ',' + ctrans(CITY," ","+")
  SREQUETE += '&geocode=+'
End

