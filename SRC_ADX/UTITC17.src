#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC17   Table RESOURCES les désignations deviennent        Module TC #
#           traduisibles                                                 #
##########################################################################
# FGR 24/09/2009 : X3SUIVI58059
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  # Issue 108760 - 2015-08-07 by MAE :
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    # Issue 108760 - 2015-08-07 by MAE :
    #Read [ADS]DOSSIER=[L]DOSSIER
    #If fstat THEN
    #  Raz [F:ADS]
    #Endif
    If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTITC17(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTITC17(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)

  IERR = 0
  Call ECR_TRACE("UTITC17: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table RESOURCES
  #
  If filinfo(filpath("FIL", "ATEXTRA", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".ATEXTRA" [AXX]
  #
  If filinfo(filpath("FIL", "RESOURCES", "fde", SZAPPLI), 0) > 0 Then
    Local File =SZAPPLI + ".RESOURCES" [RSS]
    If dim([F:RSS]TTR) > 0 Then
      Trbegin [RSS], [AXX]
      For [RSS]RSS0
        IUPDATE = 0
        If dim([F:RSS]TTR) > 0 Then
          If [F:RSS]TTR <> "" Then
            Call MAJTEXTRA([F:RSS]TTR, "RESOURCES", "RSSDESAXX", [F:RSS]NUM, "") From ATEXTRA
            If GOK < 1 Then
              Call ECR_TRACE("File ATEXTRA RESOURCES-RSSDESAXX" - [F:RSS]NUM + ",Error =" - num$(fstat), 1) From GESECRAN
              GOK = 1
              IERR = 1
              Break
            Endif
            IUPDATE = 1
            [F:RSS]TTR = ""
          Else
            Call LECTEXTRA(WCHAINE,"RESOURCES", "RSSDESAXX", [F:RSS]NUM, "") From ATEXTRA
            If WCHAINE = "" Then
              Call MAJTEXTRA(WCHAINE, "RESOURCES", "RSSDESAXX", [F:RSS]NUM, "") From ATEXTRA
            Endif
          Endif
        Endif
        If IUPDATE = 1 Then
          Rewrite [RSS]
        Endif
      Next
      If IERR = 0 Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [RSS]
  Endif
  Close Local File [AXX]
  #
  If IERR = 0 Then
    If clalev([F:AOB]) = 0 : Local File =SZAPPLI + ".AOBJET"  [AOB] : Endif
    WOBJET = "RSE"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      Call MAJ_SEL(SZAPPLI, WOBJET) From PATCHAOB
      #
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, SZAPPLI, 1, IERR) From VALWIN
        If IERR <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      Call VALID (WOBJET, SZAPPLI, 1, IERR) From VALOBJ
      If IERR <> 1 Then
        Call ECR_TRACE("Erreur revalidation objet" - WOBJET, 1) From GESECRAN
      Endif
    Endif
  Endif
  #
  Call ECR_TRACE("UTITC17 : records processed", 0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  # Issue 108760 - 2015-08-07 by MAE :
  #Read [ADS]DOSSIER=APPLI
  #If fstat THEN
  #  Raz [F:ADS]
  #Endif
  If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI,"RESOURCES") : End : Endif
  # End MAE 108760
  Call MAJ_UTITC17(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  # Issue 108760 - 2015-08-07 by MAE :
  If func DOSVUE.ISVIEW(APPLI,"RESOURCES") : End : Endif
  Call MAJ_UTITC17(APPLI)
End

