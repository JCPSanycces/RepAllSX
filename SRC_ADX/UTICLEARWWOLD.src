#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Clear WWOLD_* Scripts
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Clear WWOLD_* Scripts") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(APPLI)
Value Char APPLI
Local Char DOSSIER(GLONADS)
[L]DOSSIER = [L]APPLI : Gosub MAJTAB
Local Char WDOSX3(GLONADS)
Call PARAM("","SUPDOS",WDOSX3) From ADOVAL
If WDOSX3<>"" and APPLI<>WDOSX3
 [L]DOSSIER = [L]WDOSX3 : Gosub MAJTAB
Endif
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJTAB
Local Char ORDSYS(250),WMAC(250),FICHIER(250),TRT(250)
Local Char TRTFILE(250)
Local Integer ASUPP,STAT

WMAC=adxmac(0)
ORDSYS="" + WMAC +'@lsadx -a'-DOSSIER-'TRT src "WWOLD_*"'+""

Local File (TRTFILE) From System ORDSYS As [SYS_]
For [SYS_]
  ASUPP=0
  TRT=[F:SYS_]TRTFILE
  If left$(TRT,6)="WWOLD_"
    ASUPP=1
  Endif
  If ASUPP
    #Call ECR_TRACE("  "+DOSSIER-TRT,0) From GESECRAN
    Call EFFACE_ADX(WMAC,DOSSIER,TRT,STAT) From ORDSYS
    FICHIER = filpath("TRT",TRT,"src",DOSSIER,"",WMAC)
    Call EFFACE(FICHIER,STAT) From ORDSYS
  Endif
Next
Close Local File [SYS_]
Return

