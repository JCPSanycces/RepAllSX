##########################################################################
##########################################################################
### RMA * 03-02-2015 * report controls for POR Legislation
##########################################################################
##########################################################################
$ACTION

Case ACTION
  When "REPORT_CTL" : Gosub REPORT_CTL
  When "FILPAT"     : Gosub FILPAT
Endcase

Return
##########################################################################
##########################################################################
$REPORT_CTL

If func AFNC.ACTIV("KPO") #& RPTDEV = ""
  If GOK = 0  : Return : Endif

  #Declares variables and table buffers
  Gosub OUVRE_CTR_VARS From PORLEGRPTLIB

  #Get the list of reports that should be controlled
  Call GET_RPT_CTR_LST(OBJ_CTR_LST, RPT_CTR_LST) From PORLEGRPTLIB

  # if the current report being printed is on the control list we have to check if a portuguese company is on the print
  # request and in that case: check the digital signature of the report and set data in the temporary print table
  RPTI = find(RPTNAM,RPT_CTR_LST(1..maxtab(RPT_CTR_LST),1))
  If RPTI
    OBJI = find(RPT_CTR_LST(RPTI,2),OBJ_CTR_LST(1..maxtab(OBJ_CTR_LST),1))
    If OBJI | RPTNAM = 'P-RECIBO'
      #if the current data has POR companies
      If clalev([PRTLK]) : Close File [PRTLK] : Endif
      Gosub PORCPY From PORLEGRPTLIB
      If PORCPY = 1 & GOK
        Gosub CHECK_REPORT From PORLEGRPTLIB
      Endif
      If clalev([PRTLK]) : Close File [PRTLK] : Endif
    Endif
  Endif

  #Closes buffer tables previously opened
  Gosub CLOSE_CTR_VARS From PORLEGRPTLIB

Endif

Return
##########################################################################
##########################################################################
$FILPAT

#JOJAC - 2018-05-24 - X3-89451 - START
# Issue 114304 - 2016-02-09 by BRBAN : Delete locked files from temporary folder if they exist .
If GFILPATH<>'' & GFONCTION = 'FUNEMLPAY'

  Local Char WDIRIN(255)        : [L]WDIRIN  = ''
  Local Char WTMPLST(255)(1..)  : Raz [L]WTMPLST
  Local Char WFILE(255)         : [L]WFILE   = ''
  Local Char WFILSND(255)       : [L]WFILSND = ''
  Local Integer WSTAT           : [L]WSTAT   = 0
  Local Char WMACHINE(255)      : [L]WMACHINE = ''
  Local Char WORDSYS(255)       : [L]WORDSYS  = ''
  Local Char WFICHIER(255)      : [L]WFICHIER = ''
  Local Integer WNBDIR          : [L]WNBDIR   = 0
  Local Char WOPT(30)           : [L]WOPT     = ''

  #Folder to create the .lst file contain all files in tmp directory
  [L]WDIRIN = left$([L]FICJOB,instr(1,[L]FICJOB,"EPS")-1)

  #File to send on email
  [L]WFILSND = ctrans(right$([L]FICJOB,instr(1,[L]FICJOB,"EPS")),"#","")


  Call MACHINE( nomap,[L]WMACHINE ,[L]WFICHIER) From ORDSYS
  #Comand line to execute
  [L]WORDSYS  = 'lsadx -f "'+[L]WDIRIN +'"'

  #Get the list of files on [L]WTMPLST
  Call SYSTEME2([L]WMACHINE,[L]WORDSYS,[L]WOPT,[L]WNBDIR,[L]WTMPLST) From ORDSYS

  For I=1 To maxtab([L]WTMPLST)
    If left$([L]WTMPLST(I),3)='EPS' & [L]WTMPLST(I)<>[L]WFILSND
      Call EFFACE([L]WDIRIN+[L]WTMPLST(I),[L]WSTAT) From ORDSYS
    Endif
  Next

Endif

If GFONCTION="PRHPSL"
  Call MOVE(FICJOB,FICHIER,STAT) From ORDSYS
Endif
#If dim([V]EFAT_FILE)>0
#  EFAT_FILE = FICJOB+".efat"
#  Call COPIE(FICJOB,EFAT_FILE,STAT) From ORDSYS
#Endif
#JOJAC - 2018-05-24 - X3-89451 - END
Return
##########################################################################
##########################################################################

