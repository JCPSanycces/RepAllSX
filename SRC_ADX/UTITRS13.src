#<AdxTL>@(#)3.0.0.0 $Revision$
###########################################################################
# UTITRS13   Suppression des enregistrements de la ADI 3  & 304           #
###########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTITRS13") From LECFIC
  Call MAJ_UTITRS13(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTITRS13(DOSSIER)
Value Char    DOSSIER
Local Integer WCOMPTEUR, OK

Call ECR_TRACE("UTITRS13 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:ADI])  =0  Local File =DOSSIER+".ATABDIV"   [ADI] : Endif

Trbegin [ADI]
GOK=1

Delete [ADI] Where NUMTAB="3"
If fstat
 Call ERREUR("ATABDIV-3",3) From DOSDIC
Else
 Call ECR_TRACE("UTITRS13 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif

Delete [ADI] Where NUMTAB="304"
If fstat
 Call ERREUR("ATABDIV-3",3) From DOSDIC
Else
 Call ECR_TRACE("UTITRS13 : "+num$(adxdlrec)+" records deleted",0) From GESECRAN
Endif

Commit

Close Local File [ADI]

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTITRS13 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI 
If fstat : Raz [F:ADS] : Endif
#If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS13(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#If APPLI=GDOSX3: End : Endif
#If [F:ADS]MODULE(2)<>2 : End : Endif
If filinfo(filpath("FIL","ATABDIV","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRS13(APPLI)
End

