#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
#    Subprogram:    SUBGICA - Intercompany journal entry  SAM #88747
#
#    Authors:         BeSpr   Jun 17-28, 2013
#
#    Modifications:
#                     BeSpr   Jun xx, 2013   xxxx
######################################################################################
# This is a copy of SUBGASA with modifications to remove DACDIA and [F:GDE] references
# In addition, screen GIC1 is used as the main screen not HAE1
######################################################################################
Subprog INIMSKFMT(FCY,TYP,DAT,STAT)
Value Char       FCY()
Value Char       TYP()
Value Date       DAT
Variable Integer STAT

Gosub DECLARE

Local Integer TYPSAI : TYPSAI = 1 : # Entry type (1:Column 2:Row 3:Tab)
Local Integer TMPNBLED                             : # Number of ledger for the company
Local Char    TMPCODLED(GLONLED)(1..10)            : # Ledger  (LED)

Call LEC_FCY([L]FCY) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_GTE_LEG([F:CPY]LEG,[L]TYP) From CPTLEC
# Intercompany journal entry uses column entry for accounts
[L]TYPSAI = 1

Raz [M:HAEF]
[M:HAEF]FCY=[L]FCY
[M:HAEF]CPY=[F:CPY]CPY
[M:HAEF]TYP=[L]TYP
[M:HAEF]ACCDAT=[L]DAT
[M:HAEF]DACDIA=""

# For Intercompany GL we currently are only allowing 2 ledgers: Main Ledger (GTYPGEN) and Analytical Ledger (GTYPANA)
Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Raz GEN_NBRLED
# Always display both columns (Main and Analytical) even if they are the same
GEN_NBRLED = 2
GEN_LEDTYP(0) = GTYPGEN   # Main General Ledger type
GEN_LEDTYP(1) = GTYPANA   # Analytical Ledger type

# No Auto Ledgers for Intercompany GL
# Declaration of a table of ledger... Ledger "Entry" => All of ledger of account core models
#Raz GEN_NBRLED
#For I=1 To len(mess(0,2644,1))
# Call LEDTYPAUT([M:HAEF]CPY,I,[L]AUT) From CPTDIV : # 1:No 2:Yes
# If [L]AUT=1
#  GEN_LEDTYP(GEN_NBRLED) = I
#  GEN_NBRLED+=1
# Endif
#Next

For I=0 To len(mess(0,2644,1))-1
 [M:HAEF]RATDIVC(I) = [M:GIC1]RATDIV(I)
 [M:HAEF]RATMLTC(I) = [M:GIC1]RATMLT(I)
Next

Goto INIMSK
End

####################################################################################
$INIMSK
STAT = 0
Read [ATY]CODTYP="SAC"
TYPSAC="K:"+[F:ATY]FORTYP

# Maximun 10 Types of ledger
# - Reading of types of ledger depending on journal entry transaction
# - With the facility/company, reading of account core models
#                 (table of ledger with "Auto ledger" is setting of "No")
# - With the entry type, control of ledger type is setting of 'Autorized'
#                           Field AUZLED => ML2647 (None, Authorized,Mandatory)

[M:HAEF]TYPENT = [L]TYPSAI
[M:HAEF]GENLED = [F:GCM]GENLEDTYP
[M:HAEF]EQL    = 2 # Yes must be balanced # [F:GDE]FLGEQL

For I=0 To GEN_NBRLED-1

 IND = GEN_LEDTYP(I)-1      # Type of ledger of entry transaction

 Call LEDTYPAUT([M:HAEF]CPY,GEN_LEDTYP(I),[L]AUT) From CPTDIV : # 1:No 2:Yes

 If ([F:GCM]LED(IND)<>"" & [F:GCM]CFMAUT(IND)<>2 )
  # Ledger "No auto", "Authorized" or "Mandatory"  (or STD or "Entry by lot")
  If  ([L]AUT=1 &[F:GTE]AUZLED(IND) > 1  & [F:GCM]CFMAUT(IND)<>2)

   # Ledger
   [M:HAEF]LEDTYP(NBLED)=GEN_LEDTYP(I)
   [M:HAEF]LED(NBLED) = [F:GCM]LED(IND)
   [M:HAEF]CUR(NBLED) = [F:GCM]CUR(IND)
   If [F:LED]LED<>[M:HAEF]LED(NBLED)
    Read [LED]LED0 = [M:HAEF]LED(NBLED)
    If fstat  : Raz [LED] :  Endif
   Endif

   # Charts of accounts
   [M:HAEF]COA(NBLED) = [F:LED]COA
   If [F:COA]COA<>[M:HAEF]COA(NBLED)
    Read [COA]COA0 = [M:HAEF]COA(NBLED)
    If fstat  : Raz [COA] :  Endif
   Endif

   # Title and format (exception of entry by row)
   If [L]TYPSAI<>2
    If !GIMPORT
     Call LECTEXTRA([M:HAEF]INTCOA(NBLED),"GCOA","COLHEA",[F:COA]COA,"") From ATEXTRA
    Endif
#    [M:HAEF]INTCOA(NBLED) = [M:HAEF]INTCOA(NBLED)

    If [F:COA]ACCFMT<>""
     If !instr(1,[F:COA]ACCFMT,"#")
      [M:HAEF]FMTCOA(NBLED)="K:"+[F:COA]ACCFMT
     Elsif instr(1,[F:COA]ACCFMT,"#")
      If [F:COA]ACCLEN<>0
       [M:HAEF]FMTCOA(NBLED)="K:"+num$([F:COA]ACCLEN)+"C"
      Else
       [M:HAEF]FMTCOA(NBLED)="K:"+mid$([F:COA]ACCFMT,1,len([F:COA]ACCFMT)-1)+"C"
      Endif
     Endif
    Else
     [M:HAEF]FMTCOA(NBLED)="K:20C"
    Endif

    [M:HAEF]FMTSAC(NBLED)=TYPSAC
    [M:HAEF]FMTCPA(NBLED)="K:15c"
   Endif

   # Dimensions... depending on the entry
   [M:HAEF]NBDIE(NBLED) = [F:LED]DIENBR
   For J=0 To [F:LED]DIENBR-1
    If [F:LED]DIE(J)<>""
     Assign "[M:HAEF]DIE"+num$(J+1)+"("+num$(NBLED)+")"  With [F:LED]DIE(J)
     If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
     If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
      [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
      [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
      Read [DIE]DIE0 = [F:LED]DIE(J)
      If fstat  : Raz [DIE] :  Endif
      If !GIMPORT
       Call LECTEXTRA([M:HAEF]INTDIE(NBDIE),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
      Endif
      If [F:DIE]CCEFMT<>""
       [M:HAEF]FMTDIE(NBDIE)="K:"+[F:DIE]CCEFMT
       # One page type entry
       Call FMTCCE("1",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
      Else
       [M:HAEF]FMTDIE(NBDIE)="K:10C"
       # One page type entry
       Call FMTCCE("1",NBDIE+1,"K:15c",[F:DIE]DIE)
      Endif
      NBDIE+=1
     Endif
    Endif
   Next

   # Management of currency of ledger "Entry"
   [M:HAEF]AUTC(IND)    = 1
   [M:HAEF]TYPC(IND)    = IND+1
   [M:HAEF]LEDC(IND)    = [F:GCM]LED(IND)
   [M:HAEF]CURC(IND)    = [F:GCM]CUR(IND)
   [M:HAEF]VCRRATC(IND) = [F:GCM]FLGVCRRAT(IND)

   NBLED += 1
  Endif
 Endif
Next
If STAT : End : Endif


# Management of dimensions of propaged's ledger (ledger not entry)
For I=0 To dim([F:GCM]LED)-1
 If !find([F:GCM]LED(I),[M:HAEF]LED(0..[L]NBLED))
  If [F:LED]LED<>[F:GCM]LED(I)
   Read [LED]LED0 = [F:GCM]LED(I)
   If fstat  : Raz [LED] :  Endif
  Endif
  For J=0 To [F:LED]DIENBR-1
   If [F:LED]DIE(J)<>""
    If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
    If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
     [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
     [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
     Read [DIE]DIE0 = [F:LED]DIE(J)
     If fstat  : Raz [DIE] :  Endif
     If !GIMPORT
      Call LECTEXTRA([M:HAEF]INTDIE(NBDIE),"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
     Endif
     If [F:DIE]CCEFMT<>""
      [M:HAEF]FMTDIE(NBDIE)="K:"+[F:DIE]CCEFMT
      # One page entry
      Call FMTCCE("1",NBDIE+1,"K:"+[F:DIE]CCEFMT,[F:DIE]DIE)
     Else
      [M:HAEF]FMTDIE(NBDIE)="K:10C"
      # One page entry
      Call FMTCCE("1",NBDIE+1,"K:15c",[F:DIE]DIE)
     Endif
     NBDIE+=1
    Endif
   Endif
  Next
 Endif
Next

If ![L]NBLED : STAT = 36 : Endif

[M:HAEF]NBRL=9
[M:HAEF]NBRC=9
[M:HAEF]NBRLED = [L]NBLED
[M:HAEF]NBRAXI = [L]NBDIE

# Set the source number of dimensions
[M:GIC1]NBRCCE = [L]NBDIE

# Format of account "hidden"
For I=NBLED To 9
 [M:HAEF]FMTCOA(I) = "-K:15X"
 [M:HAEF]FMTSAC(I) = "-K:15X"
 [M:HAEF]FMTCPA(I) = "-K:15X"
Next

# Format of dimension "hidden"... only journal entry "Column"
For I=NBDIE To 19
 Call FMTCCE("1",I+1,"-K:15c",[F:DIE]DIE)
 If [M:HAEF]FMTDIE(I)="" : [M:HAEF]FMTDIE(I) = "-K:15c" :  Endif
Next

# Management of currency of propaged's ledger or ledger entry.
For I=0 To len(mess(0,2644,1))-1
 If [F:GTE]AUZLED(I)=3 & [F:GCM]LED(I) ="" : STAT=43 : Break : Endif
 If [F:GCM]LED(I)<>"" & [F:GTE]AUZLED(I)>1
  [M:HAEF]GENC(I)    = 2
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED(I)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]RNDOPT(I)  = [F:GCM]RNDOPTBAL(I)
 Endif
 # Update Fiscal Year/Fiscal Period
 Call GETPERSOC([F:CPY]CPY,I+1,[M:HAEF]ACCDAT,[M:HAEF]FIY(I),[M:HAEF]PER(I)) From CPTSUB
 Case [F:GTE]PER
  When 1       :
  When 2       : [M:HAEF]PER(I)  = 0
  When Default : [M:HAEF]PER(I) += [F:GTE]PER-2
 Endcase
 # Update Balance/Matching
 If [F:LED]LED<>[F:GCM]LED(I)
  Read [LED]LED0 = [F:GCM]LED(I)
  If fstat  : Raz [LED] :  Endif
 Endif
 [M:HAEF]BAL(I)    = [F:LED]BAL
 [M:HAEF]BALFCY(I) = [F:LED]FCYBAL
 [M:HAEF]MTC(I)    = [F:LED]MTCFLG
Next
If STAT : End : Endif

# Management of currency of automatic's ledger
[M:HAEF]FMTDOE = "-K:15X"
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]CFMAUT(I)=2 & [M:HAEF]LEDC([F:GCM]ORILEDTYP(I)-1)<>""
  [M:HAEF]AUTC(I)    = 2
  [M:HAEF]GENC(I)    = 1 #DdM53406
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED([F:GCM]ORILEDTYP(I)-1)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]DOELEDC(I) = [F:GCM]DOELED(I)
  If [F:GCM]DOELED(I) = 2 : [M:HAEF]FMTDOE = "K:15X" : Endif
 Endif
Next

#--- Save of ledger : Entry + Propagede
Raz GNBTYPLED, GTYPLED, GCODLED, GPLAN

For I=0 To [M:HAEF]NBRLED-1
 GNBTYPLED+=1
 GTYPLED(GNBTYPLED) = [M:HAEF]LEDTYP(I)
 GCODLED(GNBTYPLED) = [M:HAEF]LED(I)
 GPLAN(GNBTYPLED)   = [M:HAEF]COA(I)
Next

For I=0 To len(mess(0,2644,1))-1
 If !find(I+1,GTYPLED(1..GNBTYPLED)) & [M:HAEF]GENC(I)=2
  GNBTYPLED+=1
  GTYPLED(GNBTYPLED) = I+1
  GCODLED(GNBTYPLED) = [M:HAEF]LEDC(I)
  Call INDLED([M:HAEF]LEDC(I),"",IND,J) From CPTDIV
  GPLAN(GNBTYPLED) = GLEDCOA(IND)
 Endif
Next

End

####################################################################################
Subprog FMTCCE(MSK,NBRDIE,FMTDIE,DIE)
Value Char MSK()
Value Integer NBRDIE
Value Char FMTDIE()
Value Char DIE()

Assign "[M:GIC"+MSK+"]DIE("+num$(NBRDIE-1)+")" With DIE

Case MSK
 When "1" :
    Case NBRDIE
      When  1 : Chgfmt [M:GIC1]CCE1  With FMTDIE
      When  2 : Chgfmt [M:GIC1]CCE2  With FMTDIE
      When  3 : Chgfmt [M:GIC1]CCE3  With FMTDIE
      When  4 : Chgfmt [M:GIC1]CCE4  With FMTDIE
      When  5 : Chgfmt [M:GIC1]CCE5  With FMTDIE
      When  6 : Chgfmt [M:GIC1]CCE6  With FMTDIE
      When  7 : Chgfmt [M:GIC1]CCE7  With FMTDIE
      When  8 : Chgfmt [M:GIC1]CCE8  With FMTDIE
      When  9 : Chgfmt [M:GIC1]CCE9  With FMTDIE
      When 10 : Chgfmt [M:GIC1]CCE10 With FMTDIE
      When 11 : Chgfmt [M:GIC1]CCE11 With FMTDIE
      When 12 : Chgfmt [M:GIC1]CCE12 With FMTDIE
      When 13 : Chgfmt [M:GIC1]CCE13 With FMTDIE
      When 14 : Chgfmt [M:GIC1]CCE14 With FMTDIE
      When 15 : Chgfmt [M:GIC1]CCE15 With FMTDIE
      When 16 : Chgfmt [M:GIC1]CCE16 With FMTDIE
      When 17 : Chgfmt [M:GIC1]CCE17 With FMTDIE
      When 18 : Chgfmt [M:GIC1]CCE18 With FMTDIE
      When 19 : Chgfmt [M:GIC1]CCE19 With FMTDIE
      When 20 : Chgfmt [M:GIC1]CCE20 With FMTDIE
    Endcase
Endcase
End

####################################################################################
$DECLARE
# Data stucture linked of to the Account Core Model
Global Integer GNBTYPLED                             : # Number of ledger for the company
Global Integer GTYPLED(1..10)                        : # Types of ledger linked to the company
Global Char    GCODLED(GLONLED)(1..10)               : # Ledger  (LED)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Chart of Account (COA)

Local Integer NBDIE     : Raz NBDIE                  : # Nb of Dimensions use by company and sort Type of Transaction & Type of document
Local Integer NBDIELED  : Raz NBDIELED
Local Integer NBLED     : Raz NBLED                  : # Nb of ledgers
Local Integer IND,INDLED
Local Integer AUT, TYPREF
Local Integer I,J,K
Local Integer WACCNUM
Local Char    TYPSAC                                 : # Type of collectif
Local Char ABR(10) : ABR="GIC1"                      : # Abreviation
Local Integer GEN_NBRLED, GEN_LEDTYP(0..9)

If !clalev([F:CPY])  : Local File =GTABCPT+"COMPANY"    [CPY] : Endif
If !clalev([F:FCY])  : Local File =GTABCPT+"FACILITY"   [FCY] : Endif
If !clalev([F:FIY])  : Local File =GTABCPT+"FISCALYEAR" [FIY] : Endif
If !clalev([F:PER])  : Local File =GTABCPT+"PERIOD"     [PER] : Endif
If !clalev([F:GTE])  : Local File =GTABCPT+"GTYPACCENT" [GTE] : Endif
If !clalev([F:GCM])  : Local File =GTABCPT+"GACM"       [GCM] : Endif
If !clalev([F:LED])  : Local File =GTABCPT+"GLED"       [LED] : Endif
If !clalev([F:COA])  : Local File =GTABCPT+"GCOA"       [COA] : Endif
If !clalev([F:DIE])  : Local File =GTABCPT+"GDIE"       [DIE] : Endif
If !clalev([F:ATY])  : Local File =GTABCPT+"ATYPE"      [ATY] : Endif

Return

####################################################################################
$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
# This routine is used to initialize the HAEF varaibles when the company changes
# Called from SUBGIC; INI_GLOBAL
Subprog RESET_INIMSKFMT(FCY,STAT)
Value Char       FCY()
Variable Integer STAT

Local Integer NBDIE     : Raz NBDIE                  : # Nb of Dimensions use by company and sort Type of Transaction & Type of document
Local Integer NBLED     : Raz NBLED                  : # Nb of ledgers
Local Integer IND
Local Integer AUT
Local Integer I,J,K
Local Char    TYPSAC    : # Type of collectif
Local Integer GEN_NBRLED, GEN_LEDTYP(0..9)

If !clalev([F:ATY])  : Local File =GTABCPT+"ATYPE"      [ATY] : Endif

Call LEC_FCY([L]FCY) From CPTLEC
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC

[M:HAEF]FCY=[L]FCY
[M:HAEF]CPY=[F:CPY]CPY

# For Intercompany GL we currently are only allowing 2 ledgers: Main Ledger (GTYPGEN) and Analytical Ledger (GTYPANA)
Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
Raz GEN_NBRLED
# Always display both columns (Main and Analytical) even if they are the same
GEN_NBRLED = 2
GEN_LEDTYP(0) = GTYPGEN   # Main General Ledger type
GEN_LEDTYP(1) = GTYPANA   # Analytical Ledger type

# No Auto Ledgers for Intercompany GL
# Declaration of a table of ledger... Ledger "Entry" => All of ledger of account core models
# For intercompany GL we currently are only allowing 2 ledgers Main Ledger and Analytical Ledger
#Raz GEN_NBRLED
#For I=1 To len(mess(0,2644,1))
# Call LEDTYPAUT([M:HAEF]CPY,I,[L]AUT) From CPTDIV : # 1:No 2:Yes
# If [L]AUT=1
#  GEN_LEDTYP(GEN_NBRLED) = I
#  GEN_NBRLED+=1
# Endif
#Next

# Clear out previous company's data
Raz [M:HAEF]DIE
Raz [M:HAEF]AUTC
Raz [M:HAEF]GENC
Raz [M:HAEF]TYPC
Raz [M:HAEF]LEDC
Raz [M:HAEF]CURC
Raz [M:HAEF]VCRRATC
Raz [M:HAEF]DOELEDC

$RESET_INIMSK
STAT = 0
Read [ATY]CODTYP="SAC"
TYPSAC="K:"+[F:ATY]FORTYP

For I=0 To GEN_NBRLED-1
 IND = GEN_LEDTYP(I)-1      # Type of ledger of entry transaction
 Call LEDTYPAUT([M:HAEF]CPY,GEN_LEDTYP(I),[L]AUT) From CPTDIV : # 1:No 2:Yes
 If ([F:GCM]LED(IND)<>"" & [F:GCM]CFMAUT(IND)<>2 )
  # Ledger "No auto", "Authorized" or "Mandatory"  (or STD or "Entry by lot")
  If  ([L]AUT=1 &[F:GTE]AUZLED(IND) > 1  & [F:GCM]CFMAUT(IND)<>2)

   # Ledger
   [M:HAEF]LEDTYP(NBLED)=GEN_LEDTYP(I)
   [M:HAEF]LED(NBLED) = [F:GCM]LED(IND)
   [M:HAEF]CUR(NBLED) = [F:GCM]CUR(IND)
   If [F:LED]LED<>[M:HAEF]LED(NBLED)
    Read [LED]LED0 = [M:HAEF]LED(NBLED)
    If fstat  : Raz [LED] :  Endif
   Endif

   # Charts of accounts
   [M:HAEF]COA(NBLED) = [F:LED]COA
   If [F:COA]COA<>[M:HAEF]COA(NBLED)
    Read [COA]COA0 = [M:HAEF]COA(NBLED)
    If fstat  : Raz [COA] :  Endif
   Endif
    If [F:COA]ACCFMT<>""
     If !instr(1,[F:COA]ACCFMT,"#")
      [M:HAEF]FMTCOA(NBLED)="K:"+[F:COA]ACCFMT
     Elsif instr(1,[F:COA]ACCFMT,"#")
      If [F:COA]ACCLEN<>0
       [M:HAEF]FMTCOA(NBLED)="K:"+num$([F:COA]ACCLEN)+"C"
      Else
       [M:HAEF]FMTCOA(NBLED)="K:"+mid$([F:COA]ACCFMT,1,len([F:COA]ACCFMT)-1)+"C"
      Endif
     Endif
    Else
     [M:HAEF]FMTCOA(NBLED)="K:20C"
    Endif

   [M:HAEF]FMTSAC(NBLED)=TYPSAC
   # Dimensions... depending on the entry
   [M:HAEF]NBDIE(NBLED) = [F:LED]DIENBR
   For J=0 To [F:LED]DIENBR-1
    If [F:LED]DIE(J)<>""
     Assign "[M:HAEF]DIE"+num$(J+1)+"("+num$(NBLED)+")"  With [F:LED]DIE(J)
     If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
     If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
      [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
      [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
      Read [DIE]DIE0 = [F:LED]DIE(J)
      If fstat  : Raz [DIE] :  Endif
      NBDIE+=1
     Endif
    Endif
   Next

   NBLED += 1
  Endif
 Endif
Next
If STAT : End : Endif

# Management of dimensions of propaged's ledger (ledger not entry)
For I=0 To dim([F:GCM]LED)-1
 If !find([F:GCM]LED(I),[M:HAEF]LED(0..[L]NBLED))
  If [F:LED]LED<>[F:GCM]LED(I)
   Read [LED]LED0 = [F:GCM]LED(I)
   If fstat  : Raz [LED] :  Endif
  Endif
  For J=0 To [F:LED]DIENBR-1
   If [F:LED]DIE(J)<>""
    If NBDIE>GOPTCANA : STAT=38 : Break 2 : Endif
    If !find([F:LED]DIE(J),[M:HAEF]DIE(0..NBDIE-1))
     [M:HAEF]DIE(NBDIE) = [F:LED]DIE(J)
     [M:VT2]TBDIE(NBDIE)=[F:LED]DIE(J)
     Read [DIE]DIE0 = [F:LED]DIE(J)
     If fstat  : Raz [DIE] :  Endif
     NBDIE+=1
    Endif
   Endif
  Next
 Endif
Next

If ![L]NBLED : STAT = 36 : Endif

# This field needs to stay as the Source number of ledgers
#[M:HAEF]NBRLED = [L]NBLED
[M:HAEF]NBRAXI = [L]NBDIE

# Do NOT reformat for the Target
# Format of account "hidden"
#For I=NBLED To 9
# [M:HAEF]FMTCOA(I) = "-K:15X"
# [M:HAEF]FMTSAC(I) = "-K:15X"
#Next

# Management of currency of propaged's ledger or ledger entry.
For I=0 To len(mess(0,2644,1))-1
 If [F:GTE]AUZLED(I)=3 & [F:GCM]LED(I) ="" : STAT=43 : Break : Endif
 If [F:GCM]LED(I)<>"" & [F:GTE]AUZLED(I)>1
  [M:HAEF]GENC(I)    = 2
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED(I)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]RNDOPT(I)  = [F:GCM]RNDOPTBAL(I)
 Endif
 # Update Fiscal Year/Fiscal Period
 Call GETPERSOC([F:CPY]CPY,I+1,[M:HAEF]ACCDAT,[M:HAEF]FIY(I),[M:HAEF]PER(I)) From CPTSUB
 Case [F:GTE]PER
  When 1       :
  When 2       : [M:HAEF]PER(I)  = 0
  When Default : [M:HAEF]PER(I) += [F:GTE]PER-2
 Endcase
 # Update Balance/Matching
 If [F:LED]LED<>[F:GCM]LED(I)
  Read [LED]LED0 = [F:GCM]LED(I)
  If fstat  : Raz [LED] :  Endif
 Endif
 [M:HAEF]BAL(I)    = [F:LED]BAL
 [M:HAEF]BALFCY(I) = [F:LED]FCYBAL
 [M:HAEF]MTC(I)    = [F:LED]MTCFLG
Next
If STAT : End : Endif

# Management of currency of automatic's ledger
[M:HAEF]FMTDOE = "-K:15X"
For I=0 To len(mess(0,2644,1))-1
 If [F:GCM]CFMAUT(I)=2 & [M:HAEF]LEDC([F:GCM]ORILEDTYP(I)-1)<>""
  [M:HAEF]AUTC(I)    = 2
  [M:HAEF]GENC(I)    = 1 #DdM53406
  [M:HAEF]TYPC(I)    = I+1
  [M:HAEF]LEDC(I)    = [F:GCM]LED([F:GCM]ORILEDTYP(I)-1)
  [M:HAEF]CURC(I)    = [F:GCM]CUR(I)
  [M:HAEF]VCRRATC(I) = [F:GCM]FLGVCRRAT(I)
  [M:HAEF]DOELEDC(I) = [F:GCM]DOELED(I)
  If [F:GCM]DOELED(I) = 2 : [M:HAEF]FMTDOE = "K:15X" : Endif
 Endif
Next

#--- Save of ledger : Entry + Propagede
Raz GNBTYPLED, GTYPLED, GCODLED, GPLAN
For I=0 To [M:HAEF]NBRLED-1
 GNBTYPLED+=1
 GTYPLED(GNBTYPLED) = [M:HAEF]LEDTYP(I)
 GCODLED(GNBTYPLED) = [M:HAEF]LED(I)
 GPLAN(GNBTYPLED)   = [M:HAEF]COA(I)
Next

For I=0 To len(mess(0,2644,1))-1
 If !find(I+1,GTYPLED(1..GNBTYPLED)) & [M:HAEF]GENC(I)=2
  GNBTYPLED+=1
  GTYPLED(GNBTYPLED) = I+1
  GCODLED(GNBTYPLED) = [M:HAEF]LEDC(I)
  Call INDLED([M:HAEF]LEDC(I),"",IND,J) From CPTDIV
  GPLAN(GNBTYPLED) = GLEDCOA(IND)
 Endif
Next

End
