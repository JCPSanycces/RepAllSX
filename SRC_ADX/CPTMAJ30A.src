#<AdxTL>@(#)11.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Gosub INIVAR From CPTMAJ30
#Call ACPTMAJ30 From CPTMAJ30
#Call ATRSMAJ30 From CPTMAJ30
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
##########################################################################################################
# ... MAJ30 : Mises à jour à effectuer lors du passage à la version 6
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
# Données récupérées du dossiers de copie
##-------------------------------------------------------------------------------------------------------#
# $GACM  :  Modèle comptable
# $GLED  :  Référentiels
##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCOUNT
#   Reprise des comptes V5 à attribuer au Référentiel Général principal du modèle comptable
#   Reprise des nature  V5 à attribuer au Référentiel Général analytique du modèle comptable
#   Reprise des compte V5  pour le référentiel sectoriel / IAS
##-------------------------------------------------------------------------------------------------------#
# $GACCOUNT_GEN
# $GACCOUNT_ANA
# $GACCOUNT_IAS
# $DELETE_GAC
# $CAAUZ
##-------------------------------------------------------------------------------------------------------#
# Migrer les paramètres V5 sous le plan de compte V6 (Comptes divers)
##-------------------------------------------------------------------------------------------------------#
# $PARAMCOA
##-------------------------------------------------------------------------------------------------------#
# Ajout du code plan associé au Référentiel Général principal du modèle comptable
#  Mise à jour GAPARBSE, GAPARDUM, TABACCLIK, GTABACC2
##-------------------------------------------------------------------------------------------------------#
# $TABACCLIK  # PLAN de COMPTE => Compte de liaison
# $GAPARBSE   # PLAN de COMPTE => Code reporting
# $GTABACC2   # PLAN de COMPTE => Code écran
#
# $GAPARDUM   : Déversement d'un compte
# $PYRAM_ACC  : Pyrmaides compte
# $PYRAM_CCE  : Pyramide section
#
##-------------------------------------------------------------------------------------------------------#
# Mises à jour diverses
##-------------------------------------------------------------------------------------------------------#
#  GTYPACCENT   : Type de pièces
#  GCLCACEPAR   : Ecritures calculées
#  GACCCODE     : Codes Comptables
#  CADIEDEF     : Axes par défaut
#  CACCEDEF     : Sections par défaut
#  GDIAACC      : Schéma de comptes
#  BUDPAR       : Paramètrage budget + Version
#  BUDVER       : Version budget
#  BUDFOR       : Formule budget
#  GRPDSP       : Groupes de répartitions
#  CDIADSP      : Répartiotions à postériori
##-------------------------------------------------------------------------------------------------------#
# GDIAENTRY     # Récupération des transactions de saisie de pièces comptables
##-------------------------------------------------------------------------------------------------------#
End

##-------------------------------------------------------------------------------------------------------#
## Création d'autant de modèles comptables qu'il y a de sociétés gérées dans des devises différentes
## dans le dossier migré.
## Les modèles comptables sont créés à partir de ceux définis dans le dossier de copie :
##     - soit un modèle comptable de même code devise ou de même code langue du pays de la société existe
##       => dans ce cas on crée le modèle comptable à partir de celui-ci
##     - soit il n'existe pas de modèle comptable de même code que le code devise ou le code langue
##       => dans ce cas on crée le modèle comptable à partir du premier modèle comptable avec comme législation,
##          la législation de référence dans le dossier de copie
## On rattache chaque société au bon modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GACM
Local File =[F:ADS]DOSCOP+".GACM"        [GCMR]  # Modèle comptable dossier de copie
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]   # Modèle comptable

Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]   # Sociétés

Local File =[F:ADS]DOSSIER+".TABCOUNTRY" [TCY]   # Pays
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY2] Order By Key CLE = ACCCUR;CPY

Local Char DESIG1(GLONDES) , DESIG2(GLONSHO)

Call ECR_TIME(mess(81,125,1)-": GACM") From DOSSUB : # maj table

Trbegin [GCM]

GOK = 1

Read [GCMR]GCM0 = WGACM

Filter [CPY2] Where ACCCUR<>""
## Rupture sur chaque devise comptable...
For [CPY2]CLE(1)

 Raz [F:GCM]
 [F:GCM] = [F:GCMR]
 [F:GCM]GCM = [F:CPY2]ACCCUR

 If PLIAS=""
  Raz [F:GCM]LED(2)
  [F:GCM]CFMAUT(2) = 1
  Raz [F:GCM]ORILEDTYP(2)
  Raz [F:GCM]CUR(2)
  Raz [F:GCM]DACRAT(2)
  Raz [F:GCM]FLGVCRRAT(2)
  Raz [F:GCM]TYPRAT(2)
  Raz [F:GCM]RNDOPTBAL(2)

  Raz [F:GCM]LED(5)
  [F:GCM]CFMAUT(5) = 1
  Raz [F:GCM]ORILEDTYP(5)
  Raz [F:GCM]CUR(5)
  Raz [F:GCM]DACRAT(5)
  Raz [F:GCM]FLGVCRRAT(5)
  Raz [F:GCM]TYPRAT(5)
  Raz [F:GCM]RNDOPTBAL(5)

  Raz [F:GCM]NBRCTL
  Raz [F:GCM]LED1
  Raz [F:GCM]LED2

 Endif

 For IREF=1 To 3
  If [F:GCM]LED(IREF-1)<>""
   [F:GCM]CUR(IREF-1) = [F:CPY2]ACCCUR
  Endif
 Next
#  For IREF=4 To 6
#   If [F:GCM]LED(IREF-1)<>""
#    [F:GCM]CUR(IREF-1) = [L]MIGGSYSCUR
#   Endif
#  Next

 Write [GCM]
 If fstat
  GOK = 0 : Call ERREUR("GACM"-[F:GCM]GCM,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
#Call COPTEXTRA("GACM",[F:GCM]GCM) From CPTMAJ30
 Call LECTEXTRA(DESIG1,"GACM","DESTRA",WGACM,"") From CPTMAJ30
 Call LECTEXTRA(DESIG2,"GACM","SHOTRA",WGACM,"") From CPTMAJ30
 Call MAJTEXTRA(DESIG1,"GACM","DESTRA",[F:GCM]GCM,"") From CPTMAJ30
 Call MAJTEXTRA(DESIG2,"GACM","SHOTRA",[F:GCM]GCM,"") From CPTMAJ30


 For [CPY]CPY0 Where ACCCUR = [F:CPY2]ACCCUR
  [F:CPY]ACM = [F:CPY2]ACCCUR
#  [F:CPY]LEG = [F:GCMR]LEG
  Rewrite [CPY]
  If fstat
   Call ERREUR("COMPANY"-[F:CPY]CPY,1) From DOSDIC
  Endif
 Next

Next

Commit
Filter [CPY2]
Close Local File [GCM], [CPY], [CPY2]
Return

##-------------------------------------------------------------------------------------------------------#
# Donnée récupérée du dossier de copie : Le(s) Modèle(s) comptable(s)
#   Création des référentiels liés à ce(s) modèle(s)
##-------------------------------------------------------------------------------------------------------#
$GLED
Local File =[F:ADS]DOSSIER+".GLED"  [LED]   # Référentiel
Local File =[F:ADS]DOSSIER+".GACM"  [GCM]   # Modèle comptable

Call ECR_TIME(mess(81,125,1)-": GLED") From DOSSUB : # maj table

Local Integer MAXLED : [L]MAXLED = nbrecord([F:GCM])*10
Local Char WLED(30)(0..[L]MAXLED) : Raz WLED
Local Integer NBLED : Raz NBLED

Local Char WLEDANA(30)(0..[L]MAXLED) : Raz WLEDANA
Local Integer NBLEDANA : Raz NBLEDANA

# Même si la table ACV est déjà mise à jour...
# le code activité FIY nous intéresse pour "actualiser" le paramètrage du référentiel
Local Integer FLGACT : Raz FLGACT
Read [MACV]CODACT = "FIY"
If !fstat & [F:MACV]FLACT=2
 [L]FLGACT = 2
Endif


Trbegin [LED]
GOK = 1

For [GCM]

 For I=0 To dim([F:GCM]LED)-1

  If [F:GCM]LED(I)<>"" & !find([F:GCM]LED(I),WLED(0..NBLED))
   Read [RLED]LED0 = [F:GCM]LED(I)
   If !fstat
    Raz [F:LED]
    [F:LED] = [F:RLED]

    # Axes pour le référentiel analytique principal à supprimer... ils seront MAJ lors de la migration des axes.
    If [F:LED]LED = [F:GCM]LED([F:GCM]ANALEDTYP-1)
     For J=1 To dim([F:LED]DIE)
      Raz [F:LED]DIE(J-1)
     Next
     Raz [F:LED]DIENBR

     #  Sauvegarde du référentiel principal Analytique de chaque modèle comptable
     WLEDANA(NBLEDANA) = [F:LED]LED
     NBLEDANA+=1
    Endif

    If [L]FLGACT=2
     [F:LED]ENDVCR = 2
    Else
     [F:LED]ENDVCR = 1
    Endif

    Write [LED]
    If fstat
     GOK = 0 : Call ERREUR("GLED"-[F:LED]LED,1) From DOSDIC
    Endif
    WLED(NBLED) = [F:LED]LED
    NBLED+=1

    # Gestion des intitulés (V6 : Libellé traduisible)
    Call COPTEXTRA("GLED",[F:LED]LED) From CPTMAJ30
   Endif

  Endif
 Next
Next

# Saugevarde le 1er référentiel principal Analytique => utile lors de la migration comptable de la table CDIADSP
MIGLEGANA = WLEDANA(0)

Commit
Close Local File [LED], [GCM]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCOUNT via la table GACCOUNT
# Reprise du paramétrage du plan de compte V5 à attribuer au Référentiel Général principal du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GACCOUNT_GEN
Local File =[F:ADS]DOSSIER+".GACCOUNT"  [GAC]
Local File =[F:ADS]DOSSIER+".GACCOUNT"  [GA2]

Call ECR_TIME(mess(81,125,1)-": GACCOUNT (1)") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GAC
Raz NB
## <PP bug 56983>
#If GTYPDBA=2 #SQL
# Filter [GA2] Where TYP<>2 & COA=""  # En V6, les comptes paramétré avec un Type "CUMUL" sont obsolètes.
#Else
# Filter [GA2] Where TYP<>2           # En V6, les comptes paramétré avec un Type "CUMUL" sont obsolètes.
#Endif
Filter [GA2] Where TYP<>2 & COA=""  # En V6, les comptes paramétré avec un Type "CUMUL" sont obsolètes.
## <Fin bug 56983>

If STOP
 Raz STOP
 CRITERE = "[F:GA2]ACC>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GAC]
GOK = 1
For [GA2]GAC0 Where evalue(CRITERE)

 # Transclass
 Raz [F:GAC]
 [F:GAC] = [F:GA2]

 # Nx champs
 [F:GAC]COA    = PLGEN
 [F:GAC]ENAFLG = 2
 If [F:GAC]TYP = 3 : [F:GAC]SAC=2 : Else : [F:GAC]SAC=1 : Endif
 [F:GAC]CLSCOD  =  num$([F:GAC]CLS)

 # Code reporting renommé
 For I=0 To dim([F:GAC]RPTCODDEB)-1
  [F:GAC]RPTCODDEB(I) = [F:GA2]BSEDEB(I)
  [F:GAC]RPTCODCDT(I) = [F:GA2]BSECDT(I)
 Next

 # Nouvelle Gestion de la consolidation
 If [F:GAC]CSLFLG=2
  # V5 => un seul champ CSLCOD
  [F:GAC]CSLDEB = [F:GA2]CSLCOD
  [F:GAC]CSLCDT = [F:GA2]CSLCOD
  # [F:GAC]FLODEB = ""
  # [F:GAC]FLOCDT = ""
 Endif

 # Gestion compte par défaut...
 If [F:GAC]CNA<>"" & PLANA<>"" & PLGEN<>PLANA
  # En V5, le compte a un suivi en analytique
  Raz [F:GAC]COANBR
  [F:GAC]OTHCOA([F:GAC]COANBR) = PLANA
  [F:GAC]DEFACC([F:GAC]COANBR) = [F:GAC]CNA
  If [F:GAC]CNASCR=""
   [F:GAC]SCRACC([F:GAC]COANBR) = [F:GAC]CNA
  Else
   [F:GAC]SCRACC([F:GAC]COANBR) = [F:GAC]CNASCR
  Endif
  ## Dem 51540
  #If [F:GAC]CNASCR<>"" & [F:GAC]CNASCR<>"*"
  If [F:GAC]DEFACC([F:GAC]COANBR)<>""
   [F:GAC]OBYIPT([F:GAC]COANBR) = 2
  Else
   [F:GAC]OBYIPT([F:GAC]COANBR) = 1
  Endif
  [F:GAC]COANBR += 1
 Endif
 If PLIAS<>""
  # En V5, le compte a un suivi en sectoriel
  [F:GAC]OTHCOA([F:GAC]COANBR) = PLIAS
  [F:GAC]DEFACC([F:GAC]COANBR) = [F:GAC]ACC
  [F:GAC]SCRACC([F:GAC]COANBR) = "*"
  ## Dem 51540
  #If [F:GAC]CNASCR<>"" & [F:GAC]CNASCR<>"*"
  If [F:GAC]DEFACC([F:GAC]COANBR)<>""
   [F:GAC]OBYIPT([F:GAC]COANBR) = 2
  Else
   [F:GAC]OBYIPT([F:GAC]COANBR) = 1
  Endif
  [F:GAC]COANBR += 1
 Endif

 # Gestion des axes/sections par défaut
 If [F:GAC]CNA<>"" & PLGEN=PLANA  # Cas US
  Local File =[F:ADS]DOSSIER+".CACNA"     [CNA]
  Read [CNA]CNA0 = [F:GAC]ACC
  If !fstat
   For I=0 To dim([F:CNA]FLGANA)-1
    If I<[L]MIGGOPTCANA & [F:CNA]FLGANA(I)=2
     AXE = "AX"+num$(I+1)
     J = find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
     If !J
      If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
       [F:GAC]DIE([F:GAC]DACDIENBR)    = AXE
       [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:CNA]CCEDEF(I)
       [F:GAC]DACDIENBR += 1
      Endif
     Elsif [F:GAC]CCEDEF(J-1)=""
      [F:GAC]CCEDEF(J-1) = [F:CNA]CCEDEF(I)
     Endif
    Endif
   Next
   # Champs analytique
   [F:GAC]BUDTRK = [F:CNA]BUD
   [F:GAC]FLGUOM = [F:CNA]SAIUOM
   [F:GAC]UOM    = [F:CNA]UOM
   [F:GAC]VALUOM = [F:CNA]VALUOM
   [F:GAC]GACPVS = [F:CNA]CNAPVS
   [F:GAC]TIMDSP = [F:CNA]DISTMP
   [F:GAC]DSP     = [F:CNA]DSP
   If dim([F:GAC]IPT)>0 : [F:GAC]IPT=[F:CNA]IPT : Endif
  Endif
  Close Local File [CNA]
 Endif

 If [F:GAC]FLGVAT=2
  [F:GAC]FLGDEP = 2
 Else
  [F:GAC]FLGDEP = 1
 Endif

 # Gestion des axes/sections par défaut
 # En V5, il n'y a pas de axes/sections par défaut pour le code référentiel général (à alimenter pour l'analytique et sectoriel)

 [F:GAC]UPDUSR = GUSER
 [F:GAC]UPDDAT = date$
 [F:GAC]UPDTIM = time

 NB+=1
 Write [GAC]
 If fstat
  GOK = 0 : Call ERREUR("GACCOUNT"-PLGEN-[F:GAC]ACC,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:GA2]DES)>0
  Call MAJTEXTRA([F:GA2]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
 Endif
 If dim([F:GA2]DESSHO)> 0
  Call MAJTEXTRA([F:GA2]DESSHO,"GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GA2]ACC
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_GAC
Endif
Filter [GA2]
Gosub UNSET_FIRST From TRTFIRST

##-------------------------------------------------------------------------------------------------------#
# Mise à jour des Adresses des comptes
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BPA]
Local File =[F:ADS]DOSSIER+".BPADDRESS"  [BP2]

Call ECR_TIME(mess(81,125,1)-": BPADDRESS") From DOSSUB : # maj table

Filter [BP2] Where BPATYP=5

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_BPA
If GTYPDBA=2 #SQL
 Filter [BP2] Where BPATYP=5 & UPDDAT<>date$  # SQL
Else
 Filter [BP2] Where BPATYP=5
Endif
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:BP2]BPATYP="+num$(ICLE1)+" & [F:BP2]BPANUM='"+ACLE1+"' & [F:BP2]BPAADD>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:BP2]BPATYP="+num$(ICLE1)+" & [F:BP2]BPANUM>'"+ACLE1+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:BP2]BPATYP>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

Trbegin [BPA]
GOK = 1
For [BP2]BPA0 Where evalue(CRITERE)

 # Transclass
 Raz [F:BPA]
 [F:BPA] = [F:BP2]

 [F:BPA]BPANUM = format$("K:3X",PLGEN)+[F:BP2]BPANUM

 [F:BPA]UPDUSR = GUSER
 [F:BPA]UPDDAT = date$
 [F:BPA]UPDTIM = time

 NB+=1
 Write [BPA]
 If fstat
  GOK = 0 : Call ERREUR("BPADDRESS"-[F:BPA]BPANUM-[F:BPA]BPAADD,1) From DOSDIC
 Endif

 If PLIAS<>"" & PLIAS<>PLGEN
  [F:BPA]BPANUM = format$("K:3X",PLIAS)+[F:BP2]BPANUM
  NB+=1
  Write [BPA]
  If fstat
   GOK = 0 : Call ERREUR("BPADDRESS"-[F:BPA]BPANUM-[F:BPA]BPAADD,1) From DOSDIC
  Endif
 Endif

 If NB>GMAXUPDTRS
  ICLE1 = [F:BPA]BPATYP
  ACLE1 = [F:BPA]BPANUM
  ACLE2 = [F:BPA]BPAADD
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_BPA
Endif
Filter [BP2]
Gosub UNSET_FIRST From TRTFIRST


##-------------------------------------------------------------------------------------------------------#
# Mise à jour des RIB des comptes
##-------------------------------------------------------------------------------------------------------#
Local File =[F:ADS]DOSSIER+".BID"  [BID]
Local File =[F:ADS]DOSSIER+".BID"  [BI2]

Call ECR_TIME(mess(81,125,1)-": BID") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_BID
If GTYPDBA=2 #SQL
 Filter [BI2] Where BPATYP=5 & UPDDAT<>date$  # SQL
Else
 Filter [BI2] Where BPATYP=5
Endif
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:BI2]BPATYP="+num$(ICLE1)+" & [F:BI2]BPANUM='"+ACLE1+"' & [F:BI2]BIDNUM>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:BI2]BPATYP="+num$(ICLE1)+" & [F:BI2]BPANUM>'"+ACLE1+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:BI2]BPATYP>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

Trbegin [BID]
GOK = 1
For [BI2]BID0 Where evalue(CRITERE)

 # Transclass
 Raz [F:BID]
 [F:BID] = [F:BI2]

 [F:BID]BPANUM = format$("K:3X",PLGEN)+[F:BI2]BPANUM

 [F:BID]UPDUSR = GUSER
 [F:BID]UPDDAT = date$
 [F:BID]UPDTIM = time

 NB+=1
 Write [BID]
 If fstat
  GOK = 0 : Call ERREUR("BID"-[F:BID]BPANUM-[F:BID]BIDNUM,1) From DOSDIC
 Endif

 If PLIAS<>"" & PLIAS<>PLGEN
  [F:BID]BPANUM = format$("K:3X",PLIAS)+[F:BI2]BPANUM
  NB+=1
  Write [BID]
  If fstat
   GOK = 0 : Call ERREUR("BID"-[F:BID]BPANUM-[F:BID]BIDNUM,1) From DOSDIC
  Endif
 Endif

 If NB>GMAXUPDTRS
  ICLE1 = [F:BID]BPATYP
  ACLE1 = [F:BID]BPANUM
  ACLE2 = [F:BID]BIDNUM
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_BID
Endif
Filter [BI2]
Gosub UNSET_FIRST From TRTFIRST

Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCOUNT via la table CACNA
# Reprise du paramétrage des nature V5 à attribuer au Référentiel Général analytique du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GACCOUNT_ANA
Local Char AXE(30)         # Code axe

Local File =[F:ADS]DOSSIER+".CACNA"     [CNA]
Local File =[F:ADS]DOSCOP+".GCOA"      [RCOA]    # Plan de compte du dossier de copie (sera copié sur le dossier migré)

Local File =[F:ADS]DOSSIER+".APLSTD"    [STD2]

Call ECR_TIME(mess(81,125,1)-": GACCOUNT (2)") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CNA
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:CNA]CNA>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GAC]
GOK = 1
For [CNA]CNA0 Where evalue(CRITERE)

 # Transclass
 Raz [F:GAC]
 [F:GAC] = [F:CNA]

 # Nx champs
 [F:GAC]COA    = PLANA
 [F:GAC]ACC    = [F:CNA]CNA
 [F:GAC]ENAFLG = 2

 # Champs renommés
 [F:GAC]BUDTRK = [F:CNA]BUD
 [F:GAC]FLGUOM = [F:CNA]SAIUOM
 [F:GAC]GACPVS = [F:CNA]CNAPVS
 [F:GAC]TIMDSP = [F:CNA]DISTMP


 # Gestion compte par défaut...
  # Par défaut, le réfrentiel général principal est noté
  Raz [F:GAC]COANBR
  [F:GAC]OTHCOA([F:GAC]COANBR) = PLGEN
  [F:GAC]DEFACC([F:GAC]COANBR) = ""
  [F:GAC]SCRACC([F:GAC]COANBR) = "*"
  [F:GAC]OBYIPT([F:GAC]COANBR) = 1
  [F:GAC]COANBR += 1

  If PLIAS<>""
   [F:GAC]OTHCOA([F:GAC]COANBR) = PLIAS
   [F:GAC]DEFACC([F:GAC]COANBR) = ""
   [F:GAC]SCRACC([F:GAC]COANBR) = "*"
   [F:GAC]OBYIPT([F:GAC]COANBR) = 1
   [F:GAC]COANBR += 1
  Endif

 # Gestion des axes/sections par défaut
 For I=0 To dim([F:CNA]FLGANA)-1
  If I<[L]MIGGOPTCANA & [F:CNA]FLGANA(I)=2
   AXE = "AX"+num$(I+1)
   J = find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
   If !J
    If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
     [F:GAC]DIE([F:GAC]DACDIENBR)    = AXE
     [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:CNA]CCEDEF(I)
     [F:GAC]DACDIENBR += 1
    Endif
   Elsif [F:GAC]CCEDEF(J-1)=""
    [F:GAC]CCEDEF(J-1) = [F:CNA]CCEDEF(I)
   Endif
  Endif
 Next

 # Demande 6.2 (60477)
 #[F:GAC]CLSCOD = left$([F:CNA]CNA,1)
 Read [RCOA]COA0 = PLANA
 If !fstat
  [F:GAC]CLSCOD  = ""
  For I=0 To dim([F:RCOA]PFX)-1
   If left$([F:GAC]ACC,len([F:RCOA]PFX(I)))=[F:RCOA]PFX(I)
    [F:GAC]CLSCOD  = [F:RCOA]CLSCOD(I) : Break
   Endif
  Next I
 Endif
 If [F:GAC]CLSCOD = "" & [F:RCOA]PFXNBR>0 : [F:GAC]CLSCOD=[F:RCOA]CLSCOD([F:RCOA]PFXNBR-1) : Endif
 If [F:GAC]CLSCOD = ""
  Filter [STD2] Where LANCHP=638 & LAN = MIGGLANMAJ & LANNUM>0
  Read [STD2]LAN Last
  [F:GAC]CLSCOD=num$([F:STD2]LANNUM)
 Endif
 #

 [F:GAC]UPDUSR = GUSER
 [F:GAC]UPDDAT = date$
 [F:GAC]UPDTIM = time

 NB+=1
 Write [GAC]
 If fstat
  GOK = 0 : Call ERREUR("GACCOUNT"-[F:GAC]ACC,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CNA]DES)>0
  Call MAJTEXTRA([F:CNA]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
 Endif
 If dim([F:CNA]DESSHO)> 0
  Call MAJTEXTRA([F:CNA]DESSHO,"GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:CNA]CNA
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CNA
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CNA], [RCOA], [STD2]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCOUNT via la table GACCOUNT
# Reprise du paramétrage des comptes flagué sectoriel
##-------------------------------------------------------------------------------------------------------#
$GACCOUNT_IAS
Local File =[F:ADS]DOSCOP+".GCOA"      [RCOA]    # Plan de compte du dossier de copie (sera copié sur le dossier migré)
Local Char    AXE(30)         # Code axe
Local Integer NTAX

Call ECR_TIME(mess(81,125,1)-": GACCOUNT (3)") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_IAS
Raz NB
## <PP bug 56983>
#If GTYPDBA=2 #SQL
# Filter [GA2] Where TYP<>2 & COA="" # En V6, les comptes paramétré avec un Type "CUMUL" sont obsolètes.
#Else
# Filter [GA2] Where TYP<>2
#Endif
Filter [GA2] Where TYP<>2 & COA="" # En V6, les comptes paramétré avec un Type "CUMUL" sont obsolètes.
## <Fin bug 56983>
If STOP
 Raz STOP
 CRITERE = "[F:GA2]ACC>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GAC]
 GOK = 1
 For [GA2]GAC0 Where evalue(CRITERE)

  # Transclass
  Raz [F:GAC]
  [F:GAC] = [F:GA2]

  # Nx champs
  [F:GAC]COA    = PLIAS
  [F:GAC]ENAFLG = 2
  If [F:GA2]TYP = 3 : [F:GAC]SAC=2 : Else : [F:GAC]SAC=1 : Endif
  [F:GAC]CLSCOD  =  num$([F:GAC]CLS)

  # Code reporting renommé
  [F:GAC]BSEDEB = [F:GA2]RPTCODDEB
  [F:GAC]BSECDT = [F:GA2]RPTCODCDT

  # Nouvelle Gestion de la consolidation
  If [F:GAC]CSLFLG=2
   # V5 => un seul champ CSLCOD
   [F:GAC]CSLDEB = [F:GA2]CSLCOD
   [F:GAC]CSLCDT = [F:GA2]CSLCOD
   # [F:GAC]FLODEB = ""
   # [F:GAC]FLOCDT = ""
  Endif

  # Gestion compte par défaut...
  # Par défaut, le réfrentiel général principal est noté
  Raz [F:GAC]COANBR
  [F:GAC]OTHCOA([F:GAC]COANBR) = PLGEN
  [F:GAC]DEFACC([F:GAC]COANBR) = [F:GAC]ACC
  [F:GAC]SCRACC([F:GAC]COANBR) = "*"
  ## Dem 51540
  If [F:GAC]DEFACC([F:GAC]COANBR)<>""
   [F:GAC]OBYIPT([F:GAC]COANBR) = 2
  Else
   [F:GAC]OBYIPT([F:GAC]COANBR) = 1
  Endif
  [F:GAC]COANBR += 1

  If [F:GAC]CNA<>""
   # En V5, le compte a un suivi en analytique
   [F:GAC]OTHCOA([F:GAC]COANBR) = PLANA
   [F:GAC]DEFACC([F:GAC]COANBR) = [F:GA2]CNA
   If [F:GAC]CNASCR=""
    [F:GAC]SCRACC([F:GAC]COANBR) = "*"
   Else
    [F:GAC]SCRACC([F:GAC]COANBR) = [F:GAC]CNASCR
   Endif
   ## dem 51540
   #If [F:GA2]CNASCR<>"" & [F:GA2]CNASCR<>"*"
   If [F:GAC]DEFACC([F:GAC]COANBR)<>""
    [F:GAC]OBYIPT([F:GAC]COANBR) = 2
   Else
    [F:GAC]OBYIPT([F:GAC]COANBR) = 1
   Endif
   [F:GAC]COANBR += 1
  Endif

  # Gestion des axes/sections par défaut
#  If [F:GA2]SCT1<>""
  If dim([F:GA2]FLGSCT)>0 & [F:GA2]FLGSCT=2
   AXE = [L]AXEIAS1
   J = find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
   If !J
    If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
     [F:GAC]DIE([F:GAC]DACDIENBR)    = AXE
     [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:GA2]SCT1
     [F:GAC]DACDIENBR += 1
    Endif
   Elsif[F:GAC]CCEDEF(J-1)=""
    [F:GAC]CCEDEF(J-1) =  [F:GA2]SCT1
   Endif
  Endif
#  If [F:GA2]SCT2<>""
  If dim([F:GA2]FLGSCT)>0 & [F:GA2]FLGSCT=2
   AXE = [L]AXEIAS2
   J = find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
   If !J
    If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
     [F:GAC]DIE([F:GAC]DACDIENBR)    = AXE
     [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:GA2]SCT2
     [F:GAC]DACDIENBR += 1
    Endif
   Elsif[F:GAC]CCEDEF(J-1)=""
    [F:GAC]CCEDEF(J-1) =  [F:GA2]SCT2
   Endif
  Endif

  ## RAZ des champs taxes si le plan de comptes ne gère pas les taxes
  Read [RCOA]COA0 = PLIAS
  If !fstat & [F:RCOA]TAXMGT<>2
   [F:GAC]FLGVAT = 1
   [F:GAC]VATIPT = 0
   For NTAX=0 To dim([F:GAC]VAT)-1
    Raz [F:GAC]VAT(NTAX)
   Next
  Endif

  [F:GAC]UPDUSR = GUSER
  [F:GAC]UPDDAT = date$
  [F:GAC]UPDTIM = time

  NB+=1
  Write [GAC]
  If fstat
   GOK = 0 : Call ERREUR("GACCOUNT"-[F:GAC]ACC,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  If dim([F:GA2]DES)>0
   Call MAJTEXTRA([F:GA2]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
  Endif
  If dim([F:GA2]DESSHO)> 0
   Call MAJTEXTRA([F:GA2]DESSHO,"GACCOUNT","SHOTRA",[F:GAC]COA,[F:GAC]ACC) From CPTMAJ30
  Endif

  If NB>GMAXUPDTRS
   ACLE1 = [F:GAC]ACC
   STOP=1
   Break
  Endif

 Next

 Commit
 If STOP
  Goto LOOP_IAS
 Endif
 Filter [GA2]
 Gosub UNSET_FIRST From TRTFIRST

Close Local File [RCOA]
Return


$DELETE_GAC
Trbegin [GAC]
Delete [GAC] Where COA=""
If fstat
 GOK = 0 : Call ERREUR("GACCOUNT",3) From DOSDIC
Endif
Commit

Trbegin [BPA]
Delete [BPA] Where BPATYP=5 & UPDDAT<>date$
If fstat
 GOK = 0 : Call ERREUR("BPADDRESS",3) From DOSDIC
Endif
Commit

Trbegin [BID]
Delete [BID] Where BPATYP=5 & UPDDAT<>date$
If fstat
 GOK = 0 : Call ERREUR("BID",3) From DOSDIC
Endif
Commit

Filter [GAC] : Close Local File [GAC], [GA2]
Filter [BPA] : Close Local File [BPA], [BP2]
Filter [BID] : Close Local File [BID], [BI2]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour CAAUZ
##-------------------------------------------------------------------------------------------------------#
$CAAUZ
Local File =[F:ADS]DOSSIER+".CAAUZ"  [CAZ]
Local File =[F:ADS]DOSSIER+".CAAUZ"  [CA2]

Call ECR_TIME(mess(81,125,1)-": CAAUZ") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP

$LOOP_CAZ
Raz NB
Filter [CA2] Where TYP=2 & COBIVS=0

If STOP = 1
 STOP = 2
 CRITERE = "[F:CA2]AUZ1='"+ACLE1+"' & [F:CA2]AUZ2>'"+ACLE2+"'"
Elsif STOP = 2
 Raz STOP
 CRITERE = "[F:CA2]AUZ1>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CAZ]
 GOK = 1
 For [CA2] Where evalue(CRITERE)

  # Transclass
  Raz [F:CAZ]
  [F:CAZ] = [F:CA2]

  [L]ZONE     = [F:CA2]AUZ1
  [F:CAZ]AUZ1 = [F:CA2]AUZ2
  [F:CAZ]AUZ2 = [L]ZONE
  [F:CAZ]COBIVS = 99

  NB+=1
  Write [CAZ]
  If fstat
   GOK = 0 : Call ERREUR("CAAUZ"-[F:CAZ]AUZ1-[F:CAZ]AUZ2,1) From DOSDIC
  Endif

  If NB>GMAXUPDTRS
   ACLE1 = [F:CA2]AUZ1
   ACLE2 = [F:CA2]AUZ2
   STOP=1
   Break
  Endif

 Next

Commit
If STOP
 Goto LOOP_CAZ
Endif
Filter [CA2]
Gosub UNSET_FIRST From TRTFIRST
Close Local File [CAZ], [CA2]

Local File =[F:ADS]DOSSIER+".CAAUZ"  [CAZ]
Trbegin [CAZ]
Delete [CAZ] Where TYP=2 & COBIVS=0
If fstat
 GOK = 0 : Call ERREUR("CAAUZ",3) From DOSDIC
Endif
Commit

Trbegin [CAZ]
Update [CAZ] Where TYP=2 & COBIVS=99 With COBIVS=0
If fstat
 GOK = 0 : Call ERREUR("CAAUZ",2) From DOSDIC
Endif
Commit

Close Local File [CAZ]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GAPARBSE
#  Ajout du code plan associé au Référentiel Général principal du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GAPARBSE
Local File =[F:ADS]DOSSIER+".GAPARBSE"  [PBS]
Local File =[F:ADS]DOSSIER+".GAPARBSE"  [PB2]

Call ECR_TIME(mess(81,125,1)-": GAPARBSE") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_PBS
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:PB2] Where COA=""
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:PB2]NUM="+num$(ICLE1)+"& [F:PB2]ACCSTR>'"+ACLE1+"'"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PB2]NUM>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

Trbegin [PBS]
GOK = 1
For [PB2]PBS0 Where evalue(CRITERE)

 # Transclass
 Raz [F:PBS]
 [F:PBS] = [F:PB2]

 # Nx champs
 [F:PBS]COA    = PLGEN

 # Champs renommés
 [F:PBS]NUMCOD = [F:PB2]NUM
 [F:PBS]CODCDT = [F:PB2]BSECDT
 [F:PBS]CODDEB = [F:PB2]BSEDEB

 [F:PBS]UPDUSR = GUSER
 [F:PBS]UPDDAT = date$

 NB+=1
 Write [PBS]
 If fstat
  GOK = 0 : Call ERREUR("GAPARBSE"-[F:PBS]COA-num$([F:PBS]NUMCOD)-[F:PBS]ACCSTR,1) From DOSDIC
 Endif

 If NB>GMAXUPDTRS
  ICLE1 = [F:PBS]NUMCOD
  ACLE1 = [F:PBS]ACCSTR
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_PBS
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GAPARBSE.
#  Suppression des lignes avec le champ COA à vide
Trbegin [PBS]
Delete [PBS] Where [PBS]COA=""
If fstat
 GOK = 0 : Call ERREUR("GAPARBSE",3) From DOSDIC
Endif

Commit
Close Local File [PBS], [PB2]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GAPARDUM
#  Ajout du code plan associé au Référentiel Général principal du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GAPARDUM
Local File =[F:ADS]DOSSIER+".GAPARDUM"  [PDM]
Local File =[F:ADS]DOSSIER+".GAPARDUM"  [PD2]

Call ECR_TIME(mess(81,125,1)-": GAPARDUM") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_PDM
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:PD2] Where COA=""
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:PD2]DUM='"+ACLE1+"' & [F:PD2]NUMLIN>"+num$(ICLE1)
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:PD2]DUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [PDM]
GOK = 1
For [PD2]PDM0 Where evalue(CRITERE)

 # Transclass
 Raz [F:PDM]
 [F:PDM] = [F:PD2]

 # Nx champs
 [F:PDM]COA    = PLGEN
 [F:PDM]CREUSR = GUSER
 [F:PDM]CREDAT = date$
 [F:PDM]CRETIM = time
 [F:PDM]UPDUSR = GUSER
 [F:PDM]UPDDAT = date$
 [F:PDM]UPDTIM = time

 # Champ renommé
 [F:PDM]COD = [F:PD2]DUM

 NB+=1
 Write [PDM]
 If fstat
  GOK = 0 : Call ERREUR("GAPARDUM"-[F:PDM]COA-[F:PDM]COD-num$([F:PDM]NUMLIN),1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:PD2]DES)>0
  Call MAJTEXTRA([F:PD2]DES,"GAPARDUM","DESTRA",[F:PDM]COA,[F:PDM]COD) From CPTMAJ30
 Endif
 If dim([F:PD2]DESSHO)> 0
  Call MAJTEXTRA([F:PD2]DESSHO,"GAPARDUM","SHOTRA",[F:PDM]COA,[F:PDM]COD) From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:PD2]DUM
  ICLE1 = [F:PD2]NUMLIN
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_PDM
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GAPARBSE.
#  Suppression des lignes avec le champ COA à vide
Trbegin [PDM]
Delete [PDM] Where [PDM]COA=""
If fstat
 GOK = 0 : Call ERREUR("GAPARDUM",3) From DOSDIC
Endif

Commit

Close Local File [PDM], [PD2]
Return

##-------------------------------------------------------------------------------------------------------#
# PARAMCOA
#   Création des plans de comptes PLGEN, PLANA, PLIAS
#   Migrer les paramètres V5 sous le plan de compte V6 (Comptes divers)
#
##-------------------------------------------------------------------------------------------------------#
$PARAMCOA
Local File =[F:ADS]DOSCOP+".GCOA"      [CCOA]    # Plan de compte du dossier de copie
Local File =[F:ADS]DOSCOP+".GACCCLS"   [CCLS]    # Classe de compte du dossier de copie
Local File =[F:ADS]DOSCOP+".GACCCLS"   [CCL2]    # Classe de compte du dossier de copie
Local File =[F:ADS]DOSCOP+".GCACCOA"   [CGCO]    # Transaction saisie de code comptable du dossier de copie

Local File =[F:ADS]DOSSIER+".GACCCODE"  [CAC]
Local File =[F:ADS]DOSSIER+".GCOA"      [COA]
Local File =[F:ADS]DOSSIER+".GCACCOA"   [GCO]
Local File =[F:ADS]DOSSIER+".GACCCLS"   [CLS]
Local File =[F:ADS]DOSSIER+".APLSTD"    [STD2]


Local Char    OPT(1)            : # Option par société ou par site
Local Char    XTABCOA(3)(1..3)  : # Tableau des plans de comptes créés
Local Integer XNBCOA            : # Nombre de plans de comptes créés

Local Char    XTABCLS(20)(1..3) : # Tableau des classes de comptes créés
Local Integer XNBCLS            : # Nombre de classe de de comptes créés

Call ECR_TIME(mess(81,125,1)-": GCOA") From DOSSUB : # maj table

Trbegin [COA], [GCO]
GOK = 1

XNBCOA = 0

For [CCOA]COA0

 If find([F:CCOA]COA,PLGEN,PLANA,PLIAS)

  # Transclass
  Raz [COA]
  [F:COA] = [F:CCOA]

  # Mise à jour des paramètres "communs" uniquement pour le code plan générale et sectoriel
  If find([F:CCOA]COA,PLGEN,PLIAS)
   Read [MADW]ADW0 = "";"";"ACCCSL"
   If !fstat : [F:COA]ACCMIS(0) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"ACCDEF"
   If !fstat : [F:COA]ACCMIS(1) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"ACCTMP"
   If !fstat : [F:COA]ACCMIS(2) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"ANOUVO"
   If !fstat : [F:COA]ACCMIS(3) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"CNVACC1"
   If !fstat : [F:COA]ACCMIS(4) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"CNVACC3"
   If !fstat : [F:COA]ACCMIS(5) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"CNVACC4"
   If !fstat : [F:COA]ACCMIS(6) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"CNVACC2"
   If !fstat : [F:COA]ACCMIS(7) = [F:MADW]VALEUR : Endif
   Case [F:CCOA]COA
    When PLGEN
     Read [MADW]ADW0 = "";"";"CNVACC5"
     If !fstat : [F:COA]ACCMIS(8) = [F:MADW]VALEUR : Endif
     Read [MADW]ADW0 = "";"";"CNVACC6"
         If !fstat : [F:COA]ACCMIS(9) = [F:MADW]VALEUR : Endif
    When PLIAS
     Read [MADW]ADW0 = "";"";"CNVIAS1"
     If !fstat : [F:COA]ACCMIS(8) = [F:MADW]VALEUR : Endif
     Read [MADW]ADW0 = "";"";"CNVIAS2"
     If !fstat : [F:COA]ACCMIS(9) = [F:MADW]VALEUR : Endif
   Endcase
   Read [MADW]ADW0 = "";"";"CPTRES"
   If !fstat : [F:COA]ACCMIS(10) = [F:MADW]VALEUR : Endif

   If GSYSCUR=GEURO
    Read [MADW]ADW0 = "";"";"RNDGACLOCD"
    If !fstat : [F:COA]ACCMIS(11) = [F:MADW]VALEUR : Endif
    Read [MADW]ADW0 = "";"";"RNDGACLOCC"
    If !fstat : [F:COA]ACCMIS(12) = [F:MADW]VALEUR : Endif
   Endif

   # Nouveaux comptes de paramètrages. (Perte & Gain arrondi lettrage)
   Raz [F:COA]ACCMIS(13)
   Raz [F:COA]ACCMIS(14)

   Read [MADW]ADW0 = "";"";"WAICURACC1"
   If !fstat : [F:COA]ACCMIS(15) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"WAICURACC2"
   If !fstat : [F:COA]ACCMIS(16) = [F:MADW]VALEUR : Endif
   Read [MADW]ADW0 = "";"";"ACCEXSBAN"
   If !fstat : [F:COA]ACCMIS(17) = [F:MADW]VALEUR : Endif
  Endif

  XNBCOA += 1
  XTABCOA(XNBCOA) = [F:COA]COA

  If dim([F:COA]LEGCLS)>0 & [F:COA]LEGCLS<>"" & !find([F:COA]LEGCLS,XTABCLS(1..XNBCLS))
   XNBCLS += 1
   XTABCLS(XNBCLS) = [F:COA]LEGCLS
  Endif

  Write [COA]
  If fstat
   GOK = 0 : Call ERREUR("GCOA"-[F:COA]COA,1) From DOSDIC
  Endif

  # Gestion des intitulés (V6 : Libellé traduisible)
  Call COPTEXTRA("GCOA",[F:COA]COA) From CPTMAJ30

 Endif
Next

# Création d'une transaction Plan de compte / type code comptable
Raz [F:GCO]

Filter [F:CGCO] Where LEG = [L]LEGREF
Read [F:CGCO] First
If ! fstat
 [F:GCO]COD    = [F:CGCO]COD
Else
 [F:GCO]COD    = "STD"
Endif
[F:GCO]COA(0) = PLGEN
[F:GCO]NBRCOA += 1
If PLANA<>"" & PLGEN<>PLANA
 [F:GCO]COA(1) = PLANA
 [F:GCO]NBRCOA += 1
Endif
If PLIAS<>""
 [F:GCO]COA(2) = PLIAS
 [F:GCO]NBRCOA += 1
Endif

Write [GCO]
If fstat
 GOK = 0 : Call ERREUR("GCACCOA"-[F:GCO]COD,1) From DOSDIC
Endif

# Gestion des intitulés (V6 : Libellé traduisible)
Call COPTEXTRA("GCACCOA",[F:GCO]COD) From CPTMAJ30
#

# Récupération des classes de comptes
For I=1 To XNBCLS
 Filter [F:CCLS] Where LEG = XTABCLS(I)
 Read [F:CCLS] First
 If !fstat
  Raz [F:CLS]
  [F:CLS]LEG =  [F:CCLS]LEG
  Filter [STD2] Where LANCHP=638 & LAN = MIGGLANMAJ & LANNUM>0
  For [STD2]
   [F:CLS]CLSCOD  =  num$([F:STD2]LANNUM)
   [F:CLS]CLSNAM  =  [F:STD2]LANMES
   Call MAJTEXTRA([F:CLS]CLSNAM,"GACCCLS","DESTRA",[F:CLS]LEG,[F:CLS]CLSCOD) From CPTMAJ30

   Read [MADW]ADW0 = "";"";"CPTTYP"
   [F:CLS]TYP = val(mid$([F:MADW]VALEUR,[F:STD2]LANNUM,1))
   Read [MADW]ADW0 = "";"";"CPTCLAS"
   If val(mid$([F:MADW]VALEUR,[F:STD2]LANNUM,1))<>2
    [F:CLS]ERA = 2
   Else
    [F:CLS]ERA = 1
   Endif
   Read [CCL2]CLS0 = [F:CLS]LEG;[F:CLS]CLSCOD
   If !fstat
    [F:CLS]DEFSNS = [F:CCL2]DEFSNS
    [F:CLS]SNSANA = [F:CCL2]SNSANA
   Else
    Read [CCL2]CLS0 = [F:CLS]LEG;[F:CLS]CLSCOD
    If !fstat
     [F:CLS]DEFSNS = [F:CCL2]DEFSNS
     [F:CLS]SNSANA = [F:CCL2]SNSANA
    Else
     Filter [F:CCL2] Where LEG = [F:CCLS]LEG
     For [F:CCL2]
      If left$([F:CLS]CLSCOD,1)=left$([F:CCL2]CLSCOD,1)
       [F:CLS]DEFSNS = [F:CCL2]DEFSNS
       [F:CLS]SNSANA = [F:CCL2]SNSANA
       Break
      Endif
     Next
     Filter [F:CCL2]
    Endif
   Endif
   Write [CLS]
   If fstat
    GOK = 0 : Call ERREUR("GACCCLS"-[F:CLS]LEG-[F:CLS]CLSCOD,1) From DOSDIC
   Endif
  Next
  Filter [STD2]
 Endif
 Filter [CCLS]
Next

Commit
Close Local File [COA], [CCOA], [CAC], [GCO], [CCLS], [CCL2], [CLS], [STD2]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour TABACCLIK
#  Ajout du code plan associé au Référentiel Général principal du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$TABACCLIK
Local File =[F:ADS]DOSSIER+".TABACCLIK"  [TCK]
Local File =[F:ADS]DOSSIER+".TABACCLIK"  [TC2]

Call ECR_TIME(mess(81,125,1)-": TABACCLIK") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_TCK
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:TC2] Where COA=""
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:TC2]FCY1='"+ACLE1+"' & [F:TC2]FCY2>'"+ACLE2+"'"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:TC2]FCY1>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [TCK]
GOK = 1
For [TC2]TCK0 Where evalue(CRITERE)

 # Transclass
 [F:TCK] = [F:TC2]

 # Nx champs
 [F:TCK]COA    = PLGEN

 [F:TCK]UPDUSR = GUSER
 [F:TCK]UPDDAT = date$

 NB+=1
 Write [TCK]
 If fstat
  GOK = 0 : Call ERREUR("TABACCLIK"-[F:TCK]COA-[F:TCK]FCY1-[F:TCK]FCY2,1) From DOSDIC
 Endif

 If PLIAS<>"" & PLIAS<>PLGEN
  [F:TCK]COA    = PLIAS
  NB+=1
  Write [TCK]
  If fstat
   GOK = 0 : Call ERREUR("TABACCLIK"-[F:TCK]COA-[F:TCK]FCY1-[F:TCK]FCY2,1) From DOSDIC
  Endif
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:TC2]FCY1
  ACLE2 = [F:TC2]FCY2
  STOP=1
  Break
 Endif

Next

Commit

If STOP
 Goto LOOP_TCK
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GAPARBSE.
#  Suppression des lignes avec le champ COA à vide
Trbegin [TCK]
Delete [TCK] Where [TCK]COA=""
If fstat
 GOK = 0 : Call ERREUR("TABACCLIK",3) From DOSDIC
Endif

Commit

Close Local File [TCK], [TC2]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GTABACC2
#  Ajout du code plan associé au Référentiel Général principal du modèle comptable
##-------------------------------------------------------------------------------------------------------#
$GTABACC2
Local File =[F:ADS]DOSSIER+".GTABACC2"  [GT2]
Local File =[F:ADS]DOSSIER+".GTABACC2"  [GTB]

Call ECR_TIME(mess(81,125,1)-": GTABACC2") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GT2
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:GTB] Where COA=""
Endif
If STOP
 STOP = 0
 CRITERE = "[F:GTB]ACCROO>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GT2]
GOK = 1
For [GTB]GT20 Where evalue(CRITERE)

 # Transclass
 [F:GT2] = [F:GTB]

 # Nx champs
 [F:GT2]COA    = PLGEN

 # Champ renommé
 [F:GT2]SCECODGEN= [F:GTB]GTC

 [F:GT2]UPDUSR = GUSER
 [F:GT2]UPDDAT = date$

 NB+=1
 Write [GT2]
 If fstat
  GOK = 0 : Call ERREUR("GTABACC2"-[F:GT2]COA-[F:GT2]ACCROO,1) From DOSDIC
 Endif

 If PLIAS<>"" & PLIAS<>PLGEN
  [F:GT2]COA    = PLIAS
  NB+=1
  Write [GT2]
  If fstat
   GOK = 0 : Call ERREUR("GTABACC2"-[F:GT2]COA-[F:GT2]ACCROO,1) From DOSDIC
  Endif
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GT2]ACCROO
  STOP=1
  Break
 Endif

Next
Commit

If STOP
 Goto LOOP_GT2
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GAPARBSE.
#  Suppression des lignes avec le champ COA à vide
Trbegin [GT2]
Delete [GT2] Where [GT2]COA=""
If fstat
 GOK = 0 : Call ERREUR("GTABACC2",3) From DOSDIC
Endif

Commit
Close Local File [GT2], [GTB]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour GTYPACCENT : Type de pièce
#
##-------------------------------------------------------------------------------------------------------#
$GTYPACCENT
Local File =[F:ADS]DOSSIER+".GTYPACCENT"  [GTE]

Call ECR_TIME(mess(81,125,1)-": GTYPACCENT") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GTE
Raz NB
If STOP
 STOP = 0
 CRITERE = "[F:GTE]TYP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GTE]
GOK = 1
For [GTE]GTE0 Where evalue(CRITERE)

 [F:GTE]AUZLED(0) = 2
 [F:GTE]AUZLED(1) = 2
 [F:GTE]AUZLED(2) = 2
 # Type V5 purement analytique
 If [F:GTE]CAT=2
  [F:GTE]AUZLED(0) = 1   # Social
  [F:GTE]AUZLED(2) = 1   # IAS
 Endif
 # Type V5 non IAS
 If [F:GTE]IAS<>2
  [F:GTE]AUZLED(2) = 1   # IAS
 Else
  # Type V5 purement IAS
  If [F:GTE]FIS<>2
   [F:GTE]AUZLED(0) = 1   # Social
  Endif
 Endif

 #-- DUDTYP : Type d'échéance...
 #-> Si type journal 'Achat' et/ou 'Ventes' autorisé, initialiser le type d'échéance à 'Facture'
 #-> Si type journal 'Trésorerie autorisé, initialiser le type d'échéance à 'Règlement'
 #-> Dans tous les autres cas, initialiser le type d'échéance à 'Autres'
 If [F:GTE]AUZJOU(0)=2 or [F:GTE]AUZJOU(1)=2
  [F:GTE]DUDTYP = 2
 Elsif [F:GTE]AUZJOU(2)=2
  [F:GTE]DUDTYP = 3
 Else
 [F:GTE]DUDTYP = 4
 Endif

 # Champ renommé
 [F:GTE]VCRREA    = [F:GTE]REA
 [F:GTE]VCRSIM    = [F:GTE]SIM
 [F:GTE]VCROUTBSE = [F:GTE]OUTBSE

 [F:GTE]UPDUSR = GUSER
 [F:GTE]UPDDAT = date$

 NB+=1
 Rewrite [GTE]
 If fstat
  GOK = 0 : Call ERREUR("GTYPACCENT"-[F:GTE]TYP,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:GTE]DES)>0
  Call MAJTEXTRA([F:GTE]DES,"GTYPACCENT","DESTRA",[F:GTE]TYP,"") From CPTMAJ30
 Endif
 If dim([F:GTE]DESSHO)> 0
  Call MAJTEXTRA([F:GTE]DESSHO,"GTYPACCENT","SHOTRA",[F:GTE]TYP,"") From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GTE]TYP
  STOP=1
  Break
 Endif

Next

Commit

If STOP
 Goto LOOP_GTE
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [GTE]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GCLCACEPAR : Ecritures calculées
#
##-------------------------------------------------------------------------------------------------------#
$GCLCACEPAR
Local File =[F:ADS]DOSSIER+".GCLCACEPAR"  [CLP]

Call ECR_TIME(mess(81,125,1)-": GCLCACEPAR") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CLP
Raz NB
If STOP
 STOP = 0
 CRITERE = "[F:CLP]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CLP]
GOK = 1
For [CLP]CLP0 Where evalue(CRITERE)

 # Nx champs
  #-- LEDTYP : Type de référentiel
  #--  Initialisation par rapport au Référentile général principal du modèle
 [F:CLP]LEDTYP = [F:RGCM]GENLEDTYP

 [F:CLP]UPDUSR = GUSER
 [F:CLP]UPDDAT = date$
 [F:CLP]UPDTIM = time

 NB+=1
 Rewrite [CLP]
 If fstat
  GOK = 0 : Call ERREUR("GCLCACEPAR"-[F:CLP]COD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CLP]DES)>0
  Call MAJTEXTRA([F:CLP]DES,"GCLCACEPAR","DESTRA",[F:CLP]COD,"") From CPTMAJ30
 Endif
 If dim([F:CLP]DESSHO)> 0
  Call MAJTEXTRA([F:CLP]DESSHO,"GCLCACEPAR","SHOTRA",[F:CLP]COD,"") From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:CLP]COD
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CLP
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CLP]
Return

##-------------------------------------------------------------------------------------------------------#
# Récupération des transactions de saisie de pièces comtpables
#
##-------------------------------------------------------------------------------------------------------#
$GDIAENTRY
Local File =[F:ADS]DOSSIER+".AMSKZON"     [AMZ]

Local File =[F:ADS]DOSSIER+".GDIAENTRY"   [GDE]
Local File =[F:ADS]DOSSIER+".GDIAENTRYD"  [GDD]

Local File =[F:ADS]DOSSIER+".GDIAENTRYD"  [GD2]
Local File =[F:ADS]DOSSIER+".GACCSCR"     [GCR]

Local Integer AFFICHE, ECRAN_GEN, NBZONE
Local Integer CAT, CNAACC
Local Char AMZV5(50),AMZV6(50)

Local Char ZONE(30) : Raz ZONE
Read [MADW]ADW0 = "";"";"SCHSAISIE"
If !fstat
 ZONE = [F:MADW]VALEUR
Endif

Call ECR_TIME(mess(81,125,1)-": GDIAENTRY") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GDE
Raz NB
If STOP
 STOP = 0
 CRITERE = "[F:GDE]DIA>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GDE], [GDD]
GOK = 1
For [GDE]DIA Where evalue(CRITERE)

 # Nx champs
 # -- Transaction de type "Saisie colonne"
 [F:GDE]TYPENT = 1

 # -- Transaction d'une page
 If [F:GDE]MSK2=""
  [F:GDE]FLGPAG = 2
 Else
  [F:GDE]FLGPAG = 1
 Endif

 # -- Liste gauche
 [F:GDE]FLGBRO = 2

 # -- Nombre de cours
 [F:GDE]NBRRAT = 2

 #--  Ecran V5
 [L]CAT    = 1     # 1 : Saisie Générale  & 2 : Saisie Analytique & 3 : Saisie Onglet
 [L]CNAACC = 1     # 1 : Saisie Compte/Nature & 2 : Saisie Nature/compte
 If [F:GDE]MSK1="GACCCNA1" or [F:GDE]MSK1="GACCENT9"
  [L]CAT    = 2
  [L]CNAACC = 2
 Elsif left$([F:GDE]MSK1,5)="GENTL"
  [F:GDE]FLGLOT  = 2
 Elsif left$([F:GDE]MSK1,5)="WMAC1"
  Read [F:GCR]GCR0 = right$([F:GDE]MSK1,len([F:GDE]MSK1)-4)
  If !fstat
   [L]CAT    = [F:GCR]CAT
   [L]CNAACC = [F:GCR]CNAACC
  Endif
 Endif

  # -- Autorisation par référentiel
 If ZONE<>"" and ZONE=[F:GDE]DIA
  [F:GDE]LEDTYP([F:GDE]NBRLED) = 1
  [F:GDE]NBRLED += 1
  [F:GDE]LEDTYP([F:GDE]NBRLED) = 2
  [F:GDE]NBRLED += 1
  [F:GDE]LEDTYP([F:GDE]NBRLED) = 3
  [F:GDE]NBRLED += 1
  [F:GDE]LEDTYP([F:GDE]NBRLED) = 4
  [F:GDE]NBRLED += 1
 Elsif [L]CAT=2
  # Transaction V5 purement analytique
  [F:GDE]LEDTYP([F:GDE]NBRLED) = [F:RGCM]ANALEDTYP
  [F:GDE]NBRLED += 1
 Else
  # Transaction standard... général/ias/analytique
  If [L]CNAACC=2
   #-- V5, la nature était saisie en premier...
   [F:GDE]LEDTYP([F:GDE]NBRLED) = [F:RGCM]ANALEDTYP
   [F:GDE]NBRLED += 1
   If [F:RGCM]GENLEDTYP<>[F:RGCM]ANALEDTYP
    [F:GDE]LEDTYP([F:GDE]NBRLED) = [F:RGCM]GENLEDTYP
    [F:GDE]NBRLED += 1
   Endif
   If PLIAS<>""
    #-- Le dossier a paramètré un référentiel sectoriel (différent de social et analytique)
    If !find(3,[F:RGCM]GENLEDTYP,[F:RGCM]GENLEDTYP)
     [F:GDE]LEDTYP([F:GDE]NBRLED) = 3
     [F:GDE]NBRLED += 1
    Endif
   Endif
  Else
   #-- V5, la nature n'était pas saisie en premier...
   [F:GDE]LEDTYP([F:GDE]NBRLED) = [F:RGCM]GENLEDTYP
   [F:GDE]NBRLED += 1
   If PLIAS<>""
    #-- Le dossier a paramètré un référentiel sectoriel (différent de social et analytique)
    If !find(3,[F:RGCM]GENLEDTYP,[F:RGCM]ANALEDTYP)
     [F:GDE]LEDTYP([F:GDE]NBRLED) = 3
     [F:GDE]NBRLED += 1
    Endif
   Endif
   If [F:RGCM]GENLEDTYP<>[F:RGCM]ANALEDTYP
    [F:GDE]LEDTYP([F:GDE]NBRLED) = [F:RGCM]ANALEDTYP
    [F:GDE]NBRLED += 1
   Endif
  Endif
 Endif

 # -- Schéma de compte
 If [F:GDE]DIAACC<>""
  [F:GDE]GCM([F:GDE]NBRGDA)=[F:RGCM]GCM
  [F:GDE]DIAACC(0)= [F:GDE]DIAACC # inutle suite au transclass...
  [F:GDE]NBRGDA +=1
 Endif

 #-- Saisie équilibrée
 If [F:GDE]NBRLED=1 & [F:GDE]EQLDAC<>2
  [F:GDE]FLGEQL =2
 Endif


 [F:GDE]UPDUSR = GUSER
 [F:GDE]UPDDAT = date$

 # Revoir les formules des lignes de la transaction de saisie
 Gosub GDIAENTRYD

 # Si l'écriture s'est bien passée pour GDIAENTRYD,
 If GOK
  Rewrite [GDE]
  If fstat
   GOK = 0 : Call ERREUR("GDIAENTRY"-[F:GDE]DIA,1) From DOSDIC
  Endif
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:GDE]DES)>0
  Call MAJTEXTRA([F:GDE]DES,"GDIAENTRY","DESTRA",[F:GDE]DIA,"") From CPTMAJ30
 Endif
 If dim([F:GDE]DESSHO)> 0
  Call MAJTEXTRA([F:GDE]DESSHO,"GDIAENTRY","SHOTRA",[F:GDE]DIA,"") From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:GDE]DIA
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_GDE
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [GDE], [GDD], [GD2], [GCR], [AMZ]

# Une fois les fichiers à jour, il faut générer les nouvels écrans et supprimer les anciens écrans obsolètes.
#Call GENDOS([F:ADS]DOSSIER) From SUBGDE

#For [GCR]GCR0
# Read [GDE]DIA = [F:GCR]COD
# If fstat
#  # Effacement masque précédent
#  If left$([F:GDE]MSK1,5)="WMAC1"
#   Call TR_DELMSK([F:GDE]MSK1,[F:ADS]DOSSIER) From MSKDIV
#   If GOK>0
#    If left$([F:GDE]MSK2,5)="WMAC2"
#     Call TR_DELMSK([F:GDE]MSK2,[F:ADS]DOSSIER) From MSKDIV
#    Endif
#   Endif
#  Endif
# Endif
#Next

Local File =[F:ADS]DOSSIER+".AMSK"     [AMK]
Local File =[F:ADS]DOSSIER+".AWINDOW"  [AWI]

Filter [AMK] Where left$([F:AMK]CODMSK,5)="WMAC1"
For [AMK]
 Call TR_DELMSK([F:AMK]CODMSK,[F:ADS]DOSSIER) From MSKDIV
Next
Filter [AMK]

Filter [AMK] Where left$([F:AMK]CODMSK,5)="WMAC2"
For [AMK]
 Call TR_DELMSK([F:AMK]CODMSK,[F:ADS]DOSSIER) From MSKDIV
Next
Filter [AMK]

Filter [AWI] Where OBJ="GAS"
For [AWI]
 If left$([F:AWI]WIN,1)="W"
  Call TR_DELWIN([F:AWI]WIN,[F:ADS]DOSSIER) From MSKDIV
 Endif
Next

Close Local File [AMK], [AWI]
Return

$GDIAENTRYD
NBZONE = 0

If [F:GDE]MSK0<>""
 #For [AMZ]CODE Where CODMSK=[F:GDE]MSK0
 ECRAN_GEN = 0 : If left$([F:GDE]MSK0,1)="G" : ECRAN_GEN=1 : Endif
 For [AMZ]CODE Where CODMSK="GACCENT0"
  [L]AMZV5 = "HAE0."+[F:AMZ]CODZON
  Gosub LECTURE
 Next
Endif

If [F:GDE]MSK1<>""
 #For [AMZ]CODE Where CODMSK=[F:GDE]MSK1
 ECRAN_GEN = 0 : If left$([F:GDE]MSK1,1)="G" : ECRAN_GEN=1 : Endif
 For [AMZ]CODE Where CODMSK="GACCENTR1"
  [L]AMZV5 = "HAE1."+[F:AMZ]CODZON
  Gosub LECTURE
 Next
Endif

If [F:GDE]MSK2<>""
 #For [AMZ]CODE Where CODMSK=[F:GDE]MSK2
 ECRAN_GEN = 0 : If left$([F:GDE]MSK2,1)="G" : ECRAN_GEN=1 : Endif
 For [AMZ]CODE Where CODMSK="GACCENTR3"
  [L]AMZV5 = "HAE2."+[F:AMZ]CODZON
  Gosub LECTURE
 Next
Endif

# Nouveaux champs V6... qui resteront invisible
AMZV6  = "TYPO"  : Gosub ENREG_INV : # Type de pièce (Document d'origine)
AMZV6  = "NUMO"  : Gosub ENREG_INV : # Numéro de pièce (Document d'origine)
AMZV6  = "CSLC"  : Gosub ENREG_INV : # Partenaire
AMZV6  = "CSLF"  : Gosub ENREG_INV : # Flux
AMZV6  = "MDAS"  : Gosub ENREG_INV : # DAS déclarée
AMZV6  = "DIG"   : Gosub ENREG_INV : # Transaction de saisie pour les LOT   ([F:GDE]FLGLOT=2)
AMZV6  = "DRAT"  : Gosub ENREG_INV : # Date de cours
AMZV6  = "VAT"   : Gosub ENREG_INV : # TVA déclarée

AMZV6  = "IDT"   : Gosub ENREG : # Identifiant ligne uniquement an saisie ligne/onglet  ([F:GDE]TYPENT>1)

If [F:GDE]FLGLOT<>2 & [F:GDE]FLGPAG=2 & NBZONE>18
 # Trop de zones... : # Paramétrage à revoir
 Call ECR_TRACE([F:GDE]DIA-":"-mess(78,105,1)-"("+num$(NBZONE)+"/18)"+"\"+mess(86,105,1),-1) From GESECRAN
Endif
Return


$LECTURE
Read [GD2]GDD0 = [F:GDE]DIA;[L]AMZV5

If !fstat
 [L]AFFICHE = 1
Else
 [L]AFFICHE = 0
Endif

Case [F:AMZ]CODZON

  When "FCY"       :  [L]AMZV6  = "FCY"     : Gosub ENREG : # Site
  When "TYP"       :  [L]AMZV6  = "TYP"     : Gosub ENREG : # Type de pièce
  When "NUM"       :  [L]AMZV6  = "NUM"     : Gosub ENREG : # Numéro de pièce
  When "ACCDAT"    :  [L]AMZV6  = "ACCDAT"  : Gosub ENREG : # Date comptable
  When "JOU"       :  [L]AMZV6  = "JOU"     : Gosub ENREG : # Journal
  When "CAT"       :  [L]AMZV6  = "CAT"     : Gosub ENREG : # Catégorie
  When "STA"       :  [L]AMZV6  = "STA"     : Gosub ENREG : # Etat

  When "BPRVCR"    :  [L]AMZV6  = "DOC"     : Gosub ENREG : # Document d'origine
  When "BPRDATVCR" :  [L]AMZV6  = "DDOC"    : Gosub ENREG : # Date d'origine
  When "CUR"       :  [L]AMZV6  = "CUR"     : Gosub ENREG : # Devise
  When "TYPRAT"    :  [L]AMZV6  = "TRAT"    : Gosub ENREG : # Type de cours

  When "RATCUR"    :  [L]AMZV6  = "MLT1"    : Gosub ENREG : # Cours multiplicateur
                      [L]AMZV6  = "DIV1"    : Gosub ENREG : # Cours diviseur
  When "RATRPT"    :  [L]AMZV6  = "MLT2"    : Gosub ENREG : # Cours multiplicateur
                      [L]AMZV6  = "DIV2"    : Gosub ENREG : # Cours diviseur

  When "SCTENT1"   :  If [L]AXEIAS1<>""  : [L]AMZV6  = "CCE."+[L]AXEIAS1 : Gosub ENREG  : Endif
  When "SCTENT2"   :  If [L]AXEIAS2<>""  : [L]AMZV6  = "CCE."+[L]AXEIAS2 : Gosub ENREG  : Endif

  When "ENDDAT"    :  [L]AMZV6  = "DENT"    : Gosub ENREG : # Date de saisie
  When "DUDDAT"    :  [L]AMZV6  = "DDUD"    : Gosub ENREG : # Date d'échéance
  When "BANDAT"    :  [L]AMZV6  = "DBAN"    : Gosub ENREG : # Date de banque
  When "VALDAT"    :  [L]AMZV6  = "DVAL"    : Gosub ENREG : # Date de valeur

  When "REF"       :  [L]AMZV6  = "REF"     : Gosub ENREG : # Référence pièce
  When "REFSIM"    :  [L]AMZV6  = "SIM"     : Gosub ENREG : # Référence simulation
  When "RVS"       :  [L]AMZV6  = "RVS"     : Gosub ENREG : # Extourne
  When "RVSDAT"    :  [L]AMZV6  = "DRVS"    : Gosub ENREG : # Date d'extourne

  When "BOLLATO"   :  [L]AMZV6  = "BOL"     : Gosub ENREG : # Chrono Bollato
  When "DACDIA"    :  [L]AMZV6  = "DIA"     : Gosub ENREG : # Code Transaction
  When "DESVCR"    :  [L]AMZV6  = "LIB"     : Gosub ENREG : # Libellé par défaut
  When "BANCIB"    :  [L]AMZV6  = "CIB"     : Gosub ENREG : # Code interbancaire
  When "FLGFUP"    :  [L]AMZV6  = "FUP"     : Gosub ENREG : # Relance
  When "FLGDAS"    :  [L]AMZV6  = "DAS"     : Gosub ENREG : # DAS2
  When "FLGPAZ"    :  [L]AMZV6  = "PAZ"     : Gosub ENREG : # Bon à payer

  When "ORIMOD"    :  [L]AMZV6  = "MOD"     : Gosub ENREG : # Module
  When "FCYLIN"    :  [L]AMZV6  = "FCYL"    : Gosub ENREG : # Site ligne

  When "SAC"
   For J=1 To [F:GDE]NBRLED
    [L]AMZV6  = "SAC"+num$(J) :  Gosub ENREG : # Collectif
   Next
  When "ACC"
   For J=1 To [F:GDE]NBRLED
    [L]AMZV6  = "ACC"+num$(J) :  Gosub ENREG : # Compte
   Next
  When "ACCDES"    :  [L]AMZV6  = "DACC"    : Gosub ENREG : # Intitulé compte ligne
  When "BPR"       :  [L]AMZV6  = "BPR"     : Gosub ENREG : # Tiers
  When "DEB"       :  [L]AMZV6  = "DEB"     : Gosub ENREG : # Débit
  When "CDT"       :  [L]AMZV6  = "CDT"     : Gosub ENREG : # Crédit
  When "DES"       :  [L]AMZV6  = "DES"     : Gosub ENREG : # Libellé
  When "TAX"       :  [L]AMZV6  = "TAX"     : Gosub ENREG : # Taxe
  When "OFFACC"    :
   For J=1 To [F:GDE]NBRLED
    [L]AMZV6  = "CPA"+num$(J) : Gosub ENREG : # Contrepartie
   Next
  When "UOM"       :  [L]AMZV6  = "UOM"    : Gosub ENREG :  # Unité
  When "QTY"       :  [L]AMZV6  = "QTY"    : Gosub ENREG :  # Quantité
  When "DSP"       :  [L]AMZV6  = "DSP"    : Gosub ENREG :  # Répartition

  When "CCE1"      :  If 1<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX1": Gosub ENREG : Endif   # Sections Analytique Axe 1
  When "CCE2"      :  If 2<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX2": Gosub ENREG : Endif   # Sections Analytique Axe 2
  When "CCE3"      :  If 3<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX3": Gosub ENREG : Endif   # Sections Analytique Axe 3
  When "CCE4"      :  If 4<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX4": Gosub ENREG : Endif   # Sections Analytique Axe 4
  When "CCE5"      :  If 5<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX5": Gosub ENREG : Endif   # Sections Analytique Axe 5
  When "CCE6"      :  If 6<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX6": Gosub ENREG : Endif   # Sections Analytique Axe 6
  When "CCE7"      :  If 7<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX7": Gosub ENREG : Endif   # Sections Analytique Axe 7
  When "CCE8"      :  If 8<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX8": Gosub ENREG : Endif   # Sections Analytique Axe 8
  When "CCE9"      :  If 9<=[L]MIGGOPTCANA :  [L]AMZV6  = "CCE.AX9": Gosub ENREG : Endif   # Sections Analytique Axe 9

  When "ACCNUM"    :  [L]AMZV6  = "LIN"   : Gosub ENREG :  # No écriture
  When "AMTVAT"    :  [L]AMZV6  = "VAT"   : Gosub ENREG :  # Tva déclarée

  When "CHK"       :  [L]AMZV6  = "CHK"    : Gosub ENREG :  # Pointage
  When "CHKDAT"    :  [L]AMZV6  = "CHD"    : Gosub ENREG :  # Date pointage
  When "CHRNUM"    :  [L]AMZV6  = "CHR"    : Gosub ENREG :  # No chrono
  When "MTC"       :  [L]AMZV6  = "MTC"    : Gosub ENREG :  # Lettre
  When "MTCDAT"    :  [L]AMZV6  = "MDA"    : Gosub ENREG :  # Date lettrage
  When "MTCDATMAX" :  [L]AMZV6  = "MDX"    : Gosub ENREG :  # Date maxi lettrage
  When "MTCDATMIN" :  [L]AMZV6  = "MDY"    : Gosub ENREG :  # Date mini lettrage

  When "STT1"      :  [L]AMZV6  = "ST1"    : Gosub ENREG :  # Code stat 1
  When "STT2"      :  [L]AMZV6  = "ST2"    : Gosub ENREG :  # Code stat 2
  When "STT3"      :  [L]AMZV6  = "ST3"    : Gosub ENREG :  # Code stat 3

  When "FREREF"    :  [L]AMZV6  = "FRER"   : Gosub ENREG : # Référence libre

  When Default
    If [F:AMZ]CODZON>="X" & [F:AMZ]CODACT<>""
     [L]AMZV6  = [F:AMZ]CODZON :  Gosub ENREG     # Champs spécifiques
    Endif
Endcase

Return


$ENREG
# Sous le champ AMZV6, contient le nom du champ V6.
#  Récupérer les formules du dossier V5

Read [GDD]GDD0 = [F:GDE]DIA;[L]AMZV6

If !fstat
 If AFFICHE = 1
  If [F:GD2]DAC=2
   [F:GDD]DAC    = 1
  Else
   [F:GDD]DAC    = 2
  Endif
  If [F:GD2]CRD = 2
   [F:GDD]CRD   = 1
  Else
   [F:GDD]CRD   = 2
  Endif
  [F:GDD]DEFVAL = [F:GD2]DEFVAL
  [F:GDD]CTL    = [F:GD2]CTL
 Else
  If ![L]ECRAN_GEN or [F:AMZ]NUMBLOC=4
   [F:GDD]DAC    = 3
  Else
   [F:GDD]DAC    = [F:AMZ]SAIAFF
  Endif
 Endif
 # Zone forcée
 Gosub FORDAC
 Rewrite [GDD]
 If fstat
  GOK = 0 : Call ERREUR("GDIAENTRYD"-[F:GDD]DIA-[F:GDD]FLD,1) From DOSDIC
 Endif
Else
 Raz [F:GDD]
 [F:GDD]DIA    = [F:GDE]DIA
 [F:GDD]FLD    = AMZV6
 If AFFICHE = 1
  If [F:GD2]DAC=2
   [F:GDD]DAC    = 1
  Else
   [F:GDD]DAC    = 2
  Endif
  If [F:GD2]CRD = 2
   [F:GDD]CRD   = 1
  Else
   [F:GDD]CRD   = 2
  Endif
  [F:GDD]DEFVAL = [F:GD2]DEFVAL
  [F:GDD]CTL    = [F:GD2]CTL
 Else
  If ![L]ECRAN_GEN or [F:AMZ]NUMBLOC=4
   [F:GDD]DAC    = 3
  Else
   [F:GDD]DAC    = [F:AMZ]SAIAFF
  Endif
 Endif
 # Zone forcée
 Gosub FORDAC
 Write [GDD]
 If fstat
  GOK = 0 : Call ERREUR("GDIAENTRYD"-[F:GDD]DIA-[F:GDD]FLD,1) From DOSDIC
 Endif
Endif
If [F:GDE]FLGPAG = 2 & [F:AMZ]DIME<2 & ([F:GDD]DAC=1 or [F:GDD]DAC=2)
 NBZONE+=1
Endif
Return

$ENREG_INV
Read [GDD]GDD0 = [F:GDE]DIA;[L]AMZV6
If !fstat
 [F:GDD]DAC    = 3
 [F:GDD]CRD    = 1
 [F:GDD]DEFVAL = ""
 [F:GDD]CTL    = ""
 Rewrite [GDD]
 If fstat
  GOK = 0 : Call ERREUR("GDIAENTRYD"-[F:GDD]DIA-[F:GDD]FLD,1) From DOSDIC
 Endif
Else
 Raz [F:GDD]
 [F:GDD]DIA    = [F:GDE]DIA
 [F:GDD]FLD    = AMZV6
 [F:GDD]DAC    = 3
 [F:GDD]CRD    = 1
 Write [GDD]
 If fstat
  GOK = 0 : Call ERREUR("GDIAENTRYD"-[F:GDD]DIA-[F:GDD]FLD,1) From DOSDIC
 Endif
Endif
Return

$FORDAC
If find([L]AMZV6,"DEB","CDT")
 [F:GDD]DAC  = 1
Elsif find([L]AMZV6,"ACCDAT")
 [F:GDD]DAC  = 1
Elsif find(left$([L]AMZV6,3),"ACC")
 [F:GDD]DAC  = 1
Elsif find(left$([L]AMZV6,3),"CCE","JOU","CAT","STA")
 [F:GDD]DAC  = 1
Elsif find([L]AMZV6,"TYP","NUM","FCY")
 [F:GDD]DAC  = 1
Endif
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GDIAACC : Schéma de comptes
#  En V5, le compte ACC devient le compte lié au plan de compte générale principale
#         la nature CNA devient le compte lié au plan de compte analytique principale.
#         Pas d'IAS
##-------------------------------------------------------------------------------------------------------#
$GDIAACC
Local File =[F:ADS]DOSSIER+".GDIAACC"   [GDA]
Local File =[F:ADS]DOSSIER+".GDIAACCD"  [GDC]

Call ECR_TIME(mess(81,125,1)-": GDIAACC") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GDA
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:GDA] Where NUMLIG>0
Endif

If STOP = 1
 STOP = 2
 CRITERE = "[F:GDA]DIA='"+ACLE1+"' & [F:GDA]NUMLIG>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:GDA]DIA>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GDA]
GOK = 1

For [GDA]GDA0(1) Where evalue(CRITERE)

 Raz I, J
 For [GDA]GDA0

  # Transclass pour enregsitrer les lignes du schéma de comptes.
  Raz [F:GDC]
  [F:GDC] = [F:GDA]

  I+=1
  [F:GDC]LINNUM = I

  # Compte V5 devient la ligne du plan de compte générale principale  (indice 0)
  [F:GDC]ACC(0) = [F:GDA]ACC

  # Nature V5 devient la ligne du plan de compte analytique principale (indice 1)
  If [F:GDA]CNA<>""

   [F:GDC]ACC(1) = [F:GDA]CNA

   For K=1 To [L]MIGGOPTCANA
    [F:GDC]CCE(K-1) = evalue("[F:GDA]CCE"+num$(K))
   Next
   J+=1
  Endif

  Write [GDC]
  If fstat
   GOK = 0 : Call ERREUR("GDIAACCD"-[F:GDC]DIA,1) From DOSDIC
  Endif

 Next

 # Enregsitrer l'entête du schéma de comptes.
 [F:GDA]NBRACC = I
 [F:GDA]NUMLIG = 0

 Raz [F:GDA]COANBR
 [F:GDA]COA([F:GDA]COANBR) = PLGEN
 [F:GDA]COANBR+=1

 If J
  [F:GDA]COA([F:GDA]COANBR) = PLANA
  [F:GDA]COANBR+=1
  For J=1 To [L]MIGGOPTCANA
   [F:GDA]DIE([F:GDA]NBRDIE) = "AX"+num$(J)
   [F:GDA]NBRDIE+=1
  Next
 Endif

 [F:GDA]UPDUSR = GUSER
 [F:GDA]UPDDAT = date$

 NB+=1
 Rewrite [GDA]
 If fstat
  GOK = 0 : Call ERREUR("GDIAACC"-[F:GDA]DIA,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:GDA]DES)>0
  Call MAJTEXTRA([F:GDA]DES,"GDIAACC","DESTRA",[F:GDA]DIA,"") From CPTMAJ30
 Endif
 If dim([F:GDA]DESSHO)> 0
  Call MAJTEXTRA([F:GDA]DESSHO,"GDIAACC","SHOTRA",[F:GDA]DIA,"") From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GDA]DIA
  ICLE1 = [F:GDA]NUMLIG
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_GDA
Endif
Gosub UNSET_FIRST From TRTFIRST


# Fin de la mise à jour de la table GDIAACC.
Trbegin [GDA]
Delete [GDA] Where [GDA]NUMLIG>0
If fstat
 GOK = 0 : Call ERREUR("GDIAACC",3) From DOSDIC
Endif
Commit

Close Local File [GDA], [GDC]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCCODLIG : Ligne de codes comptables
#
#
##-------------------------------------------------------------------------------------------------------#
$GACCCODLIG
Local Integer NBRLIG
Local File =[F:ADS]DOSSIER+".GACCCODLIG"  [CCL]

Call ECR_TIME(mess(81,125,1)-": GACCCODLIG") From DOSSUB : # maj table

Trbegin [CCL]

 Delete [CCL] Where TYP=2 & NUMLIG=19
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/2",1) From DOSDIC
 Endif

 Delete [CCL] Where TYP=3 & NUMLIG=19
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/3",1) From DOSDIC
 Endif

 Raz [CCL]
 [F:CCL]TYP    = 14
 [F:CCL]NUMLIG = 3
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 130
 [F:CCL]TYPCPT = 3
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/14-1",1) From DOSDIC
 Endif

 Raz [CCL]
 [F:CCL]TYP    = 14
 [F:CCL]NUMLIG = 4
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 131
 [F:CCL]TYPCPT = 3
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/14-2",1) From DOSDIC
 Endif


 Filter [CCL] Where TYP=1
 NBRLIG = rowcount([CCL])

 Delete [CCL] Where TYP=1 & NUMLIG=52
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/1-1",1) From DOSDIC
 Endif


 If NBRLIG>52
  Filter [CCL] Where TYP=1 and NUMLIG>52

  For [CCL]
   [F:CCL]NUMLIG -=   1
   Rewrite [CCL]
   If fstat
    GOK = 0 : Call ERREUR("GACCCODLIG/1-2",1) From DOSDIC : Break
   Endif
  Next

  Filter [CCL]
 Endif

 Raz [CCL]
 [F:CCL]TYP    = 21
 [F:CCL]NUMLIG = 1
 [F:CCL]OBL    = 2
 [F:CCL]TXT    = 132
 [F:CCL]TYPCPT = 1
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/21-1",1) From DOSDIC
 Endif

 Raz [CCL]
 [F:CCL]TYP    = 21
 [F:CCL]NUMLIG = 2
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 133
 [F:CCL]TYPCPT = 3
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/21-2",1) From DOSDIC
 Endif

 Raz [CCL]
 [F:CCL]TYP    = 21
 [F:CCL]NUMLIG = 3
 [F:CCL]OBL    = 1
 [F:CCL]TXT    = 133
 [F:CCL]TYPCPT = 1
 [F:CCL]TYPDES = [F:CCL]TYP
 Write [CCL]
 If fstat
  GOK = 0 : Call ERREUR("GACCCODLIG/21-3",1) From DOSDIC
 Endif

Commit
Close Local File [CCL]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour GACCCODE : codes comptables
#    En V5, une ligne de code comptable ACC/CNA et éclaté en 2 lignes de code comtable V6
##-------------------------------------------------------------------------------------------------------#
$GACCCODE
Local File =[F:ADS]DOSSIER+".GACCCODE"  [CAC]
Local File =[F:ADS]DOSSIER+".GACCCODE"  [CA2]

Call ECR_TIME(mess(81,125,1)-": GACCCODE") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CAC
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:CA2] Where COA=""
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:CA2]TYP="+num$(ICLE1)+"& [F:CA2]ACCCOD>'"+ACLE1+"'"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:CA2]TYP>"+num$(ICLE1)
Else
 CRITERE = "1=1"
Endif

Trbegin [CAC]
GOK = 1
For [CA2]CAC0 Where evalue(CRITERE)

 # Transclass
 Raz [F:CAC]
 [F:CAC] = [F:CA2]

 # Compte V5 devient la ligne du plan de compte générale principale
 [F:CAC]COA = PLGEN
 Gosub WRI_CAC

 If PLIAS<>""
  [F:CAC]COA = PLIAS
  Gosub WRI_CAC
 Endif

 # Nature V5 devient la ligne du plan de compte analytique principale (indice 1)
 If PLANA<>PLGEN
  For I=0 To dim([F:CA2]CNA)-1
   [F:CAC]ACC(I) = [F:CA2]CNA(I)
  Next
  [F:CAC]COA = PLANA
  Gosub WRI_CAC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 # Pour les intitulés des codes comptables, seuls TYP+ACCCOD
 If dim([F:CAC]DES)>0
  Call MAJTEXTRA([F:CAC]DES,"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
  Call MAJTEXTRA(left$([F:CAC]DES,GLONAX1),"GACCCODE","SHOTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ICLE1 = [F:CAC]TYP
  ACLE1 = [F:CAC]ACCCOD
  STOP=1
  Break
 Endif
Next

Commit
If STOP
 Goto LOOP_CAC
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GACCCODE .
#  Suppression des lignes avec le champ COA à vide
Trbegin [CAC]
Delete [CAC] Where [CAC]COA=""
If fstat
 GOK = 0 : Call ERREUR("GACCCODE",3) From DOSDIC
Endif

Commit
Close Local File [CAC], [CA2]
Return

$WRI_CAC
[F:CAC]UPDUSR = GUSER
[F:CAC]UPDDAT = date$
[F:CAC]UPDTIM = time
If dim([F:CAC]TYPCAR)>0
 [F:CAC]TYPCAR = num$([F:CAC]TYP)
Endif
Write [CAC]
If fstat
 GOK = 0 : Call ERREUR("GACCCODE"-[F:CAC]ACCCOD,1) From DOSDIC
Endif
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour CADIEDEF : Axes par défaut
#                        AJOUT des axes analytiques
##-------------------------------------------------------------------------------------------------------#
$CADIEDEF
Local File =[F:ADS]DOSSIER+".CADIEDEF"  [CDI]

Call ECR_TIME(mess(81,125,1)-": CADIEDEF") From DOSSUB : # maj table


Trbegin [CDI]
GOK = 1

For J=1 To len(mess(0,2230,1))
 If J<12 or J=14 or J>15   #55002 : Pas d'Axes par défaut pour "Banque", "Destination comptable" et "Tiers Divers"
  Raz [CDI]

  [F:CDI]OBJ = J
  For I=1 To [L]MIGGOPTCANA
   [F:CDI]DIE(I-1) = "AX"+num$(I)
   [F:CDI]NBRDIE += 1
  Next

  If PLIAS<>""
   [F:CDI]DIE([L]MIGGOPTCANA) = [L]AXEIAS1
   [F:CDI]NBRDIE += 1

   [F:CDI]DIE([L]MIGGOPTCANA+1) = [L]AXEIAS2
   [F:CDI]NBRDIE += 1
  Endif

  Write [CDI]
  If fstat
   GOK = 0 : Call ERREUR("CADIEDEF "-mess([F:CDI]OBJ,2230,1),1) From DOSDIC
  Endif
 Endif
Next

Commit

Close Local File [CDI]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour CACCEDEF  : sections par défaut
#                        AJOUT des axes analytiques
# On récupère les initialisations par axe mais on copie les identifiants à partir du dossier de copie
# V6
##-------------------------------------------------------------------------------------------------------#
$CACCEDEF
Local File =[F:ADS]DOSSIER+".CACCEDEF"  [CDE]
Local File =[F:ADS]DOSCOP+".CACCEDEF"  [RCDE]

Local Integer NO_IDENT
Local Integer AXE, I, IND, VU

Call ECR_TIME(mess(81,125,1)-": CACCEDEF") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CDE
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:CDE]COD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [CDE]
GOK = 1

For [CDE]CDE0 Where evalue(CRITERE)

 Read [F:RCDE]CDE0 = [F:CDE]COD ; [F:CDE]CPY
 If !fstat : VU=1 : Else : VU=0 : Endif

 For I=1 To [L]MIGGOPTCANA
  [F:CDE]DIE(I-1) = "AX"+num$(I)
 Next
 [F:CDE]NBRDIE = [L]MIGGOPTCANA

 If VU
  For NO_IDENT = 0 To dim([F:RCDE]FLD)-1
   [F:CDE]FLD(NO_IDENT) = [F:RCDE]FLD(NO_IDENT)
  Next
 Endif

 For AXE=1 To [L]MIGGOPTCANA
  For IND=0 To dim([F:CDE]CCE1)-1
   If evalue("[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")") = 21
    Assign "[F:CDE]CCE"+num$(AXE)+"("+num$(IND)+")" With 22
    Break
   Endif
  Next
 Next

 Rewrite [CDE]
 If fstat
  GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 # Section par défaut, en V5, il n'y a pas la notion de société... le code sera repris pour toute société.
 If dim([F:CDE]DES)>0
  Call MAJTEXTRA([F:CDE]DES,"CACCEDEF","DESTRA",[F:CDE]COD,"") From CPTMAJ30
 Endif
 If dim([F:CDE]DESSHO)> 0
  Call MAJTEXTRA([F:CDE]DESSHO,"CACCEDEF","SHOTRA",[F:CDE]COD,"") From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:CDE]COD
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CDE
Endif
Gosub UNSET_FIRST From TRTFIRST

## Copie des nouveaux codes sections par défaut
Local Char SECTION(20)

Trbegin [RCDE], [CDE]
GOK = 1
For [RCDE]CDE0
& Where find([F:RCDE]COD,'PIV','PNH','POV','PTH','PTV','SDDAU','SDH','SDHAU',
&                        'SIV','SQD','SQH','SRH','SRL','SRLD','SDV','SQV','SOV',
&                        'SCI','SCM','SCS','MWISCI','MWISCS','MWISCM','SCOOVEMAT','SCOOVESCO',
&                        'GACCD')
 SECTION = [F:RCDE]COD
 Gosub TR_COP
Next
Commit
Close Local File [CDE], [RCDE]
Return

$TR_COP

Call ECR_TIME(mess(81,125,1)-": CACCEDEF"-[F:RCDE]COD) From DOSSUB

Delete [CDE] Where COD=SECTION
If fstat
 GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,3) From DOSDIC
Endif

[F:CDE] = [F:RCDE]

For I=1 To [L]MIGGOPTCANA
 [F:CDE]DIE(I-1) = "AX"+num$(I)
 Assign "[F:CDE]CCE"+num$(I)+"(0)" With 22
Next
[F:CDE]NBRDIE = [L]MIGGOPTCANA

Write [CDE]
If fstat
 GOK = 0 : Call ERREUR("CACCEDEF"-[F:CDE]COD,1) From DOSDIC
Endif

# Gestion des intitulés (V6 : Libellé traduisible)
Call COPTEXTRA("CACCEDEF",[F:CDE]COD) From CPTMAJ30
Return

##-------------------------------------------------------------------------------------------------------#
# Création des pyramides COMPTES
##-------------------------------------------------------------------------------------------------------#
$PYRAM_ACC

Local File =[F:ADS]DOSSIER+".CPYRAMIDH"   [CPH]        # Pyramides (entête)
Local File =[F:ADS]DOSSIER+".CPYRAMIDG"   [CPG]        # Pyramides (lignes)

Local File =[F:ADS]DOSSIER+".CPYRAMIDN"   [CPN]        # Pyramides - groupes NATURE  V5

Local File =[F:ADS]DOSSIER+".GACCPYM"     [GYM]        # Pyramides COMPTES V6
Local File =[F:ADS]DOSSIER+".GACCGRUPYM"  [GRY]        # Pyramides - groupes COMPTES V6

Local File =[F:ADS]DOSCOP+".GCOA"        [RCOA]        # Plan de compte du dossier de copie (sera copié sur le dossier migré)

Local File =[F:ADS]DOSSIER+".APLSTD"     [STD2]

Local Integer LIN
# Gestion de l'entête de pyramides comptes
Call ECR_TIME(mess(81,125,1)-": GACCPYM") From DOSSUB : # maj table

Filter [CPH] Where TYP=1

Trbegin [GYM]
For [CPH]CPH0

 [F:GYM]PYM = [F:CPH]PYR
 [F:GYM]COA = PLANA
 [F:GYM]ACS = [F:CPH]ACS

 [F:GYM]CREUSR = [F:CPH]CREUSR
 [F:GYM]CREDAT = [F:CPH]CREDAT
 [F:GYM]UPDUSR = GUSER
 [F:GYM]UPDDAT = date$
 [F:GYM]CRETIM = time
 [F:GYM]UPDTIM = time
 [F:GYM]EXPNUM = [F:CPH]EXPNUM

 Write [GYM]
 If fstat
  GOK = 0 : Call ERREUR("GACCPYM"-[F:GYM]PYM,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CPH]DES)> 0
  Call MAJTEXTRA([F:CPH]DES,"GACCPYM","DESTRA",[F:GYM]PYM,"") From CPTMAJ30
 Endif
 If dim([F:CPH]DESSHO)> 0
  Call MAJTEXTRA([F:CPH]DESSHO,"GACCPYM","SHOTRA",[F:GYM]PYM,"") From CPTMAJ30
 Endif

Next
Commit
Filter [CPH]

# Gestion des pyramides-groupes comptes
Call ECR_TIME(mess(81,125,1)-": GACCGRUPYM") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CPN
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CPG]TYP=1 & [F:CPG]GRP='"+ACLE1+"' & [F:CPG]LIN>"+num$(ICLE1)
Elsif STOP = 2
 Raz STOP
 CRITERE = "[F:CPG]TYP=1 & [F:CPG]GRP>'"+ACLE1+"'"
Else
 CRITERE = "[F:CPG]TYP=1"
Endif

Trbegin [GRY]
GOK = 1
For [CPG]CPG0(1) Where evalue(CRITERE)

 Raz [L]LIN
 For [CPG]CPG0

  Raz [F:GRY]
  [F:GRY]PYM    = [F:CPG]PYR
  [F:GRY]GRU    = [F:CPG]GRP
  [F:GRY]LEV    = [F:CPG]LEV
  [F:GRY]PRNROW = [F:CPG]PRNROW

  # Demande 6.2 (60477)
  Read [RCOA]COA0 = PLANA
  If !fstat
   [F:GRY]CLSCOD  = ""
   For I=0 To dim([F:RCOA]PFX)-1
    If left$([F:CPG]GRP,len([F:RCOA]PFX(I)))=[F:RCOA]PFX(I)
     [F:GRY]CLSCOD  = [F:RCOA]CLSCOD(I) : Break
    Endif
   Next I
   If [F:GRY]CLSCOD = "" & [F:RCOA]PFXNBR>0 : [F:GRY]CLSCOD=[F:RCOA]CLSCOD([F:RCOA]PFXNBR-1) : Endif
   If [F:GRY]CLSCOD = ""
    Filter [STD2] Where LANCHP=638 & LAN = MIGGLANMAJ & LANNUM>0
    Read [STD2]LAN Last
    [F:GRY]CLSCOD=num$([F:STD2]LANNUM)
   Endif
  Endif
  #

  [F:GRY]UOMDAC = [F:CPG]SAIUOM
  [F:GRY]UOM    = [F:CPG]UOM
  [F:GRY]DEFVAL = [F:CPG]VALUOM
  [F:GRY]BUDTRK = [F:CPG]BUD
  [F:GRY]TIMDSP = [F:CPG]DISTMP
  [F:GRY]SBBGRU = [F:CPG]SUBGRP
  [F:GRY]COA     = PLANA
  [F:GRY]CREUSR = [F:CPG]CREUSR
  [F:GRY]CREDAT = [F:CPG]CREDAT
  [F:GRY]CRETIM = time
  [F:GRY]UPDUSR = GUSER
  [F:GRY]UPDDAT = date$
  [F:GRY]UPDTIM = time
  [F:GRY]EXPNUM = [F:CPN]EXPNUM

  If [F:CPG]SUBGRP<>""
   [L]LIN+=1
   [F:GRY]LIN    = [L]LIN
   Write [GRY]
   If fstat
#   GOK = 0 : Call ERREUR("GACCGRUPYM"-[F:GRY]PYM-[F:GRY]GRU-num$([F:GRY]LIN),1) From DOSDIC
   Endif
  Endif
 Next

 #F65168
 For [F:CPN] Where [F:CPN]GRP=[F:CPG]GRP & [F:CPN]CNA<>""
  [L]LIN+=1
  [F:GRY]LIN    = [L]LIN
  [F:GRY]SBBGRU  = ""
  [F:GRY]ACC    = [F:CPN]CNA
  Write [GRY]
  If fstat
   #  GOK = 0 : Call ERREUR("GACCGRUPYM"-[F:GRY]PYM-[F:GRY]GRU-num$([F:GRY]LIN),1) From DOSDIC
  Endif
 Next
 #

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CPG]DES) >0
  Call MAJTEXTRA([F:CPG]DES,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From CPTMAJ30
 Endif
 If dim([F:CPG]DESSHO) >0
  Call MAJTEXTRA([F:CPG]DESSHO,"GACCGRUPYM","SHOTRA",[F:GRY]PYM,[F:GRY]GRU) From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:CPG]GRP
  ICLE1 = [F:CPG]LIN
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CPN
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CPH], [CPG], [CPN], [GYM], [GRY], [RCOA], [STD2]
Return

##-------------------------------------------------------------------------------------------------------#
# Création des pyramides SECTIONS
##-------------------------------------------------------------------------------------------------------#
$PYRAM_CCE

Local File =[F:ADS]DOSSIER+".CPYRAMIDH"   [CPH]        # Pyramides (entête)
Local File =[F:ADS]DOSSIER+".CPYRAMIDG"   [CPG]        # Pyramides (lignes)

Local File =[F:ADS]DOSSIER+".CPYRAMIDC"   [CPC]        # Pyramides - groupes SECTION V5

Local File =[F:ADS]DOSSIER+".GCCEPYM"     [CYM]        # Pyramides SECTION V6
Local File =[F:ADS]DOSSIER+".GCCEGRUPYM"  [CRY]        # Pyramides - groupes SECTION V6

Local Integer LIN
# Gestion de l'entête de pyramides sections
Call ECR_TIME(mess(81,125,1)-": GCCEPYM") From DOSSUB : # maj table
Filter [CPH] Where TYP=2

Trbegin [CYM]
For [CPH]CPH0

 [F:CYM]PYM = [F:CPH]PYR
 [F:CYM]DIE = "AX"+num$([F:CPH]AXE)
 [F:CYM]ACS = [F:CPH]ACS

 [F:CYM]CREUSR = [F:CPH]CREUSR
 [F:CYM]CREDAT = [F:CPH]CREDAT
 [F:CYM]UPDUSR = GUSER
 [F:CYM]UPDDAT = date$
 [F:CYM]CRETIM = time
 [F:CYM]UPDTIM = time
 [F:CYM]EXPNUM = [F:CPH]EXPNUM

 Write [CYM]
 If fstat
  GOK = 0 : Call ERREUR("GCCEPYM"-[F:CYM]PYM,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CPH]DES)> 0
  Call MAJTEXTRA([F:CPH]DES,"GCCEPYM","DESTRA",[F:CYM]PYM,"") From CPTMAJ30
 Endif
 If dim([F:CPH]DESSHO)> 0
  Call MAJTEXTRA([F:CPH]DESSHO,"GCCEPYM","SHOTRA",[F:CYM]PYM,"") From CPTMAJ30
 Endif

Next
Commit
Filter [CPH]

# Gestion des pyramides-groupes comptes
Call ECR_TIME(mess(81,125,1)-": GCCEGRUPYM") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_CPC
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:CPG]TYP=2 & [F:CPG]GRP='"+ACLE1+"' & [F:CPG]LIN>"+num$(ICLE1)
Elsif STOP = 2
 Raz STOP
 CRITERE = "[F:CPG]TYP=2 & [F:CPG]GRP>'"+ACLE1+"'"
Else
 CRITERE = "[F:CPG]TYP=2"
Endif

Trbegin [CRY]
GOK = 1

For [CPG]CPG0(1) Where evalue(CRITERE)

 Raz [L]LIN
 For [CPG]CPG0

  Raz [F:CRY]
  [F:CRY]PYM    = [F:CPG]PYR
  [F:CRY]GRU    = [F:CPG]GRP
  [F:CRY]LEV    = [F:CPG]LEV
  [F:CRY]PRNROW = [F:CPG]PRNROW
  [F:CRY]BUDTRK = [F:CPG]BUD
  [F:CRY]SBBGRU = [F:CPG]SUBGRP
  [F:CRY]CREUSR = [F:CPG]CREUSR
  [F:CRY]CREDAT = [F:CPG]CREDAT
  [F:CRY]UPDUSR = GUSER
  [F:CRY]UPDDAT = date$
  [F:CRY]EXPNUM = [F:CPC]EXPNUM

  If [F:CPG]SUBGRP<>""
   [L]LIN+=1
   [F:CRY]LIN    = [L]LIN
   Write [CRY]
   If fstat
#   GOK = 0 : Call ERREUR("GCCEGRUPYM"-[F:CRY]PYM-[F:CRY]GRU-num$([F:CRY]LIN),1) From DOSDIC
   Endif
  Endif
 Next

 #F65168
 For [F:CPC] Where [F:CPC]GRP=[F:CPG]GRP & [F:CPC]CCE<>""
  [L]LIN+=1
  [F:CRY]LIN    = [L]LIN
  [F:CRY]SBBGRU  = ""
  [F:CRY]CCE    = [F:CPC]CCE
  Write [CRY]
  If fstat
   #  GOK = 0 : Call ERREUR("GACCGRUPYM"-[F:CRY]PYM-[F:CRY]GRU-num$([F:CRY]LIN),1) From DOSDIC
  Endif
 Next
 #

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:CPG]DES) > 0
  Call MAJTEXTRA([F:CPG]DES,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From CPTMAJ30
 Endif
 If dim([F:CPG]DESSHO) > 0
  Call MAJTEXTRA([F:CPG]DESSHO,"GCCEGRUPYM","SHOTRA",[F:CRY]PYM,[F:CRY]GRU) From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:CPG]GRP
  ICLE1 = [F:CPG]LIN
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_CPC
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CPH], [CPG], [CPC], [CYM], [CRY]
Return

##-------------------------------------------------------------------------------------------------------#
# Mise à jour BUDPAR  : paramètrage des budgets
##-------------------------------------------------------------------------------------------------------#
$BUDPAR
Local File =[F:ADS]DOSSIER+".BUDPAR"     [BUP]
Local File =[F:ADS]DOSSIER+".BUDPARAXI"  [BPX]

Call ECR_TIME(mess(81,125,1)-": BUDPAR") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_BUP
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:BUP]BUD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [BUP]
GOK = 1
For [BUP]BUP0 Where evalue(CRITERE)

 [F:BUP]COA       = PLANA
 [F:BUP]PYMACC    = [F:BUP]PYRCNA
 [F:BUP]PYMACCLEV = [F:BUP]LEVPYRCNA

 Read [BPX]BPX0 = [F:BUP]PARAXI
 If !fstat

  For I=1 To [F:BPX]NBRAXI
   [F:BUP]DIE       = "AX"+num$(evalue("[F:BPX]AXI"+num$(I)))
   [F:BUP]PYMCCE    = [F:BUP]PYRCCE
   [F:BUP]PYMCCELEV = [F:BUP]LEVPYRCCE
  Next
 Endif

 Rewrite [BUP]
 If fstat
  GOK = 0 : Call ERREUR("BUDPAR"-[F:BUP]BUD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:BUP]DES)>0
  Call MAJTEXTRA([F:BUP]DES,"BUDPAR","DESTRA",[F:BUP]BUD,"") From CPTMAJ30
 Endif
 If dim([F:BUP]DESSHO)> 0
  Call MAJTEXTRA([F:BUP]DESSHO,"BUDPAR","SHOTRA",[F:BUP]BUD,"") From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:BUP]BUD
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_BUP
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [BUP], [BPX]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour BUDVER  : Version budgets
##-------------------------------------------------------------------------------------------------------#
$BUDVER
Local File =[F:ADS]DOSSIER+".BUDPAR"     [BUP]
Local File =[F:ADS]DOSSIER+".BUDVER"     [BUV]

Call ECR_TIME(mess(81,125,1)-": BUDVER") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_VER
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:BUP]BUD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [BUP]
GOK = 1
For [BUP]BUP0 Where evalue(CRITERE)

 Raz [BUV]
 [F:BUV]BUD = [F:BUP]BUD
 [F:BUV]VER = "1"
 [F:BUV]STA = 1
 [F:BUV]CTL = 2
 [F:BUV]DEF = 1

 Write [BUV]
 If fstat
  GOK = 0 : Call ERREUR("BUDVER"-[F:BUV]BUD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 Call COPTEXTRA("BUDVER",[F:BUV]BUD) From CPTMAJ30

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:BUP]BUD
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_VER
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [BUP], [BUV]
Return


##-------------------------------------------------------------------------------------------------------#
# Mise à jour BUDFOR  : Formules budgets
##-------------------------------------------------------------------------------------------------------#
$BUDFOR
Local File =[F:ADS]DOSSIER+".BUDFORCAL"  [BUC]
Local File =[F:ADS]DOSSIER+".BUDPAR"     [BUP]


Call ECR_TIME(mess(81,125,1)-": BUDFOR") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_BUC
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:BUC]BUDFOR='"+ACLE1+"' & [F:BUC]LIN>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:BUC]BUDFOR>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [BUC]
GOK = 1
For [BUC]BUC0 Where evalue(CRITERE)

 [F:BUC]ACC      = [F:BUC]CNA
 [F:BUC]VER      = "1"
 [F:BUC]LEDTYP   = [L]TYPANA

 Rewrite [BUC]
 If fstat
  GOK = 0 : Call ERREUR("BUDFOR"-[F:BUC]BUDFOR-num$([F:BUC]LIN),1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:BUC]DES)>0
  Call MAJTEXTRA([F:BUC]DES,"BUDFORCAL","DESTRA",[F:BUC]BUDFOR,"0") From CPTMAJ30
 Endif
 If dim([F:BUC]DESSHO)> 0
  Call MAJTEXTRA([F:BUC]DESSHO,"BUDFORCAL","SHOTRA",[F:BUC]BUDFOR,"0") From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:BUC]BUDFOR
  ICLE1 = [F:BUC]LIN
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_BUP
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [BUP], [BUC]
Return



##-------------------------------------------------------------------------------------------------------#
# Mise à jour GRPDSP : Groupes de répartitions
##-------------------------------------------------------------------------------------------------------#
$GRPDSP
Local File =[F:ADS]DOSSIER+".GRPDSP"  [GSP]
Local File =[F:ADS]DOSSIER+".GRPDSP"  [GS2]

Call ECR_TIME(mess(81,125,1)-": GRPDSP") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_GSP
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:GS2] Where COD=""
Endif
If STOP = 1
 STOP = 0
 CRITERE = "[F:GS2]GRP>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [GSP]
GOK = 1
For [GS2]GSP0 Where evalue(CRITERE)

 # Transclass
 Raz [GSP]
 [F:GSP] = [F:GS2]

 # Champs renommés
 [F:GSP]COD   = [F:GS2]GRP
 If [F:GS2]AXI>0 : [F:GSP]DIE   = "AX"+num$([F:GS2]AXI) : Endif

 [F:GSP]UPDUSR = GUSER
 [F:GSP]UPDDAT = date$

 For I=1 To [F:GS2]NBCCE
  [F:GSP]CCE =  [F:GS2]CCE(I-1)
  [F:GSP]COE =  [F:GS2]COEF(I-1)

  Write [GSP]
  If fstat
   GOK = 0 : Call ERREUR("GRPDSP"-[F:GSP]COD,1) From DOSDIC
  Endif

 Next
 NB+=1

 # Gestion des intitulés (V6 : Libellé traduisible)
 # Groupe de répartition, en V5, il n'y a pas la axe/section... en V6, l'intitulé s'enregisrement sur DIE/COD
 If dim([F:GS2]DES)>0
  Call MAJTEXTRA([F:GS2]DES,"GRPDSP","DESTRA",[F:GSP]DIE,[F:GSP]COD) From CPTMAJ30
 Endif
 If dim([F:GS2]DESSHO)> 0
  Call MAJTEXTRA([F:GS2]DESSHO,"GRPDSP","SHOTRA",[F:GSP]DIE,[F:GSP]COD) From CPTMAJ30
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:GS2]GRP
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_GSP
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table GRPDSP.
Trbegin [GSP]
Delete [GSP] Where [GSP]COD=""
If fstat
 GOK = 0 : Call ERREUR("GRPDSP",3) From DOSDIC
Endif

Commit
Close Local File [GSP], [GS2]
Return



##-------------------------------------------------------------------------------------------------------#
# Mise à jour CDIADSP : Répartitions à postériori
##-------------------------------------------------------------------------------------------------------#
$CDIADSP
Local File =[F:ADS]DOSSIER+".CDIADSP"  [DAD]
Local File =[F:ADS]DOSSIER+".CDIADSP"  [DA2]

Call ECR_TIME(mess(81,125,1)-": CDIADSP") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST
Raz STOP
$LOOP_DAD
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:DA2] Where LED=""
Endif
If STOP = 1
 STOP = 2
 CRITERE = "[F:DA2]DIA='"+ACLE1+"' & [F:DA2]LIN>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:DA2]DIA>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [DAD]
GOK = 1
For [DA2]DAD0 Where evalue(CRITERE)

 # Transclass
 Raz [DAD]
 [F:DAD] = [F:DA2]

 # Champs renommés
 [F:DAD]LED    = MIGLEGANA
 [F:DAD]COD    = [F:DA2]DIA
 If [F:DA2]AXI>0 : [F:DAD]DIE    = "AX"+num$([F:DA2]AXI) : Endif
 [F:DAD]COA    = PLANA
 [F:DAD]ACCREF = [F:DA2]CNAREF
 [F:DAD]ACCDSP = [F:DA2]CNADSP
 [F:DAD]ACCORI = [F:DA2]CNAORI
 [F:DAD]ACCDEN = [F:DA2]CNADEN

 [F:DAD]UPDUSR = GUSER
 [F:DAD]UPDDAT = date$
 [F:DAD]UPDTIM = time
 [F:DAD]CRETIM = time

 Write [DAD]
 If fstat
  GOK = 0 : Call ERREUR("CDIADSP"-[F:DAD]COD,1) From DOSDIC
 Endif

 # Gestion des intitulés (V6 : Libellé traduisible)
 If dim([F:DA2]DES)>0
  Call MAJTEXTRA([F:DA2]DES,"CDIADSP","DESTRA",[F:DAD]LED,[F:DAD]COD) From CPTMAJ30
 Endif
 If dim([F:DA2]DESSHO)> 0
  Call MAJTEXTRA([F:DA2]DESSHO,"CDIADSP","SHOTRA",[F:DAD]LED,[F:DAD]COD) From CPTMAJ30
 Endif

 NB+=1
 If NB>GMAXUPDTRS
  ACLE1 = [F:DAD]COD
  ICLE1 = [F:DAD]LIN
  STOP=1
  Break
 Endif

Next

Commit
If STOP
 Goto LOOP_DAD
Endif
Gosub UNSET_FIRST From TRTFIRST

# Fin de la mise à jour de la table CDIADSP.
Trbegin [DAD]
Delete [DAD] Where [DAD]LED=""
If fstat
 GOK = 0 : Call ERREUR("CDIADSP",3) From DOSDIC
Endif

Commit
Close Local File [DAD], [DA2]
Return
